#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# TRTACHELT1      Traitements des éléments facturation     Module ACHAT #
# --------------------------------------------------------------------- #
# Sous-programmes :                                                     #
#   - INIT_ELEMENTS  Initialisation éléments de facturation en création #
#   - ENREG_ELEMENTS Enregistrements éléments facturation du document   #
#   - CHARG_ELEMENTS Chargement des éléments de facturation en $LIENS   #
#   - ENREG_TAXES    Enregistrement tableau des taxes                   #
#   - CHARG_TAXES    Chargement tableau des taxes en $LIENS             #
#########################################################################

#########################################################################
#  Sous-programme de garnissage des éléments de facturation             #
#  dans la classe [M]                                                   #
#  avec les valeurs par défaut, et celle du fournisseur                 #
# --------------------------------------------------------------------- #
# Subprog INIT_ELEMENTS (WVCRTYP,WTYPCUR,WCURORI,WCURDES)               #
#  WVCRTYP : Type du document                                           #
#              3 = Commande                                             #
#              5 = Commande ouverte                                     #
#              6 = Réception                                            #
#              8 = Facture                                              #
#  WTYPCUR : Type de cours                                              #
#  WCURORI : Devise origine                                             #
#  WCURDES : Devise destination                                         #
#                                                                       #
# Attention : GLOCALDEV doit être la devise de la société courante      #
# --------------------------------------------------------------------- #
# Classe [M] chargée au retour                                          #
#  [M:xxxx]NBFAC     Nbre de postes (variable bas de tableau)           #
#  [M:xxxx]INVDTA    No élément de facturation                          #
#  [M:xxxx]INVDTALIB Intitulé court de l'élément de facturation         #
#  [M:xxxx]INVDTAAMT Valeur par défaut convertie si en création         #
#  [M:xxxx]AMTCODLIB Libellé pour commande uniquement (% ou devise)     #
#  [M:xxxx]INVORDAMT Montant pied de commande                           #
#  [M:xxxx]INVDTAFLG Indicateur élément non saisi                       #
#  [M:xxxx]INVLINFLG Indicateur présence sur ligne                      #
#  [M:xxxx]INVORDFLG Indicateur présence sur commande                   #
#  [M:xxxx]DISVATFLG Indicateur remise sur taxe                         #
#  [M:xxxx]DEBCDT    Débit/crédit                                       #
#  [M:xxxx]INVDTAVAT Code taxe                                          #
#  [M:xxxx]AMTCOD    % ou Mt (Menu Local)                               #
#  [M:xxxx]FORMAT    Format de saisie de l'élément                      #
#########################################################################
Subprog INIT_ELEMENTS (WVCRTYP,WTYPCUR,WCURORI,WCURDES)
Value    Integer  WVCRTYP
Value    Libelle  WTYPCUR
Value    Char     WCURORI
Value    Char     WCURDES
#-----
Local Integer  SAV_NOLIGN : SAV_NOLIGN=nolign
Local Integer  I, J, K
Local Decimal  COURS
Local Integer  WRET
Local Decimal  MTBPR
Local Char     SAV_BPSNUM(GLONBPS)
Local Char     WBPSNUM(GLONBPS)
Local Char     WBPSORD(GLONBPS)
Local Char     WBPSINV(GLONBPS)
Local Char     WFILTRE(120)
Local Libelle  WBPSORI
Local Char     WSHO(GLONAX1)
Local Char     WVAC(GLONTVB)
Local Char     WVAT(GLONVAT)
Local Char     WFORMAT(20)
Local Char     WAMTCODLIB(GLONCUR)
Local Integer  WINVDTAFLG
Local Integer  WINVCPLFLG
Local Integer  WMAX
Local Char     WABREV(5)
#----- Sauvegarde clé du buffer fournisseur -----#
SAV_BPSNUM=[F:BPS]BPSNUM
#-----
If !clalev([F:BPS2]) Local File BPSUPPLIER [BPS2] : Endif
If !clalev([F:PFI])  Local File PFOOTINV   [PFI]  : Endif
If !clalev([F:TCU])  Local File TABCUR     [TCU]  : Endif
If !clalev([F:AXX])  Local File ATEXTRA    [AXX]  : Endif
If !clalev([F:TVC])  Local File TABVAC     [TVC]  : Endif
#-----
Call LECDEV (WCURDES) From TRTDIV
Call COURDEV (WCURORI,WCURDES,WTYPCUR,datesyst,COURS,WRET) From TRTDIV
#-----
Gosub RAZ_ELEMENTS : # Effacement du tableau des éléments si nécessaire
#-----
K=0
#----- Chargement des éléments depuis le fournisseur et tarif -----#
Case WVCRTYP
  When 3 : #----- Commande -----#
    WBPSORD=[M:POH0]BPSNUM
    WBPSINV=[M:POH1]BPSINV
    WFILTRE="[F:PFI]ENAFLG=2 & [F:PFI]DACORD=2"
    WMAX   =dim([M:POH3]INVDTA)
    WVAC   =[M:POH1]VACBPR
    WABREV ="POH3"
  When 5 : #----- Commande ouverte -----#
    WBPSORD=[M:POC0]BPSNUM
    WBPSINV=[M:POC1]BPSINV
    WFILTRE="[F:PFI]ENAFLG=2 & [F:PFI]DACORD=2"
    WMAX   =dim([M:POC3]INVDTA)
    WVAC   =[M:POC1]VACBPR
    WABREV ="POC3"
  When 6 : #----- Réception -----#
    WBPSORD=[M:PTH0]BPSNUM
    WBPSINV=[M:PTHC]BPSINV
    WFILTRE="[F:PFI]ENAFLG=2 & ([F:PFI]DACORD=2 | [F:PFI]DACLIN=2)"
    WMAX   =dim([M:PTH2]INVDTA)
    WVAC   =[M:PTH0]VACBPR
    WABREV="PTH2"
  When 8 : #----- Facture -----#
    WBPSORD=[M:PIH0]BPR
    WBPSINV=[M:PIH0]BPR
    WFILTRE="[F:PFI]ENAFLG=2"
    WMAX   =dim([M:PIH4]INVDTA)
    WVAC   =[M:PIH1]VAC
    WABREV="PIH4"
Endcase
WFILTRE-="& [F:PFI]BPSORI=WBPSORI"
If GDEPMGTMOD>1  WFILTRE-="& [F:PFI]DISVATFLG<>2" : Endif
#-----
WBPSNUM=WBPSORD
WBPSORI=1
Gosub CHARG_ELEMENTS_FOU : # Chargement éléments du fournisseur commande
#-----
WBPSNUM=WBPSINV
WBPSORI=2
Gosub CHARG_ELEMENTS_FOU : # Chargement éléments du fournisseur facture
#-----
Gosub CHARG_ELEMENTS_TAR : # Chargement éléments venant de la ligne tarif
#----- Si inter-sociétés avec flux automatique (commandes uniquement) -----#
Case WVCRTYP
  When 3 : #----- Commande classique -----#
    If [M:POH0]BETFCY=2 & [M:POH0]SALFCY<>""
      Call IS_DTAPOH([M:POH0]POHFCY,[M:POH0]SALFCY,"POH3",[M:POH0]BPSNUM,
&                  [M:POH1]BPCINV,WTYPCUR,WCURORI,[M:POH0]ORDDAT,WRET) From FUNBCH
    Endif
    #-----
    For I=0 To [M:POH3]NBFAC-1
      nolign=I+1 : Call AM_INVDTAAMT([M:POH3]INVDTAAMT(I)) From SUBPOH
      Call MAJ_ELEMENT (I,0,+1) From SUBPOHC
    Next I
    #-----
  When 5 : #----- Commande ouverte -----#
    If [M:POC0]BETFCY=2 & [M:POC0]SALFCY<>""
      Call IS_DTAPOH([M:POC0]POHFCY,[M:POC0]SALFCY,"POC3",[M:POC0]BPSNUM,
&                  [M:POC1]BPCINV,WTYPCUR,WCURORI,[M:POC0]ORDDAT,WRET) From FUNBCH
    Endif
Endcase
#----- Relecture fournisseur si nécessaire -----#
If SAV_BPSNUM<>"" & [F:BPS]BPSNUM<>SAV_BPSNUM
  Read [BPS] BPS0=SAV_BPSNUM
Endif
#-----
nolign=SAV_NOLIGN
End


#--------------------------------------------------#
# Effacement du tableau des éléments si nécessaire #
#--------------------------------------------------#
$RAZ_ELEMENTS
#-----
Case WVCRTYP
  When 3 : #----- Commande -----#
    If [M:POH3]NBFAC>0
      For I=0 To [M:POH3]NBFAC-1
        #----- Mise à jour des cumuls comme pour une suppression de ligne -----#
        nolign=I+1 : status=65 : Call AVANT_NBFAC From SUBPOH
        #-----
        Raz [M:POH3]INVDTA(I),    [M:POH3]INVDTALIB(I), [M:POH3]INVDTAAMT(I),
&           [M:POH3]INVORDAMT(I), [M:POH3]INVLINAMT(I), [M:POH3]INVCPLAMT(I),
&           [M:POH3]INVDTAFLG(I), [M:POH3]INVLINFLG(I), [M:POH3]INVORDFLG(I),
&           [M:POH3]DEBCDT(I),    [M:POH3]INVDTAVAT(I), [M:POH3]DTAAMTTAX(I),
&           [M:POH3]DTADEDTAX(I), [M:POH3]AMTCOD(I),    [M:POH3]AMTCODLIB(I),
&           [M:POH3]FORMAT(I),    [M:POH3]CLCORD(I),    [M:POH3]CLCBAS(I)
        If dim([M:POH3]DISVATFLG)>0  Raz [M:POH3]DISVATFLG(I) : Endif
        If dim([M:POH3]DTADISBAS)>0  Raz [M:POH3]DTADISBAS(I) : Endif
        For J=1 To GNBCOA
          Case J
            When  1 : Raz [M:POH3]ACC1 (I)
            When  2 : Raz [M:POH3]ACC2 (I)
            When  3 : Raz [M:POH3]ACC3 (I)
            When  4 : Raz [M:POH3]ACC4 (I)
            When  5 : Raz [M:POH3]ACC5 (I)
            When  6 : Raz [M:POH3]ACC6 (I)
            When  7 : Raz [M:POH3]ACC7 (I)
            When  8 : Raz [M:POH3]ACC8 (I)
            When  9 : Raz [M:POH3]ACC9 (I)
            When 10 : Raz [M:POH3]ACC10(I)
          Endcase
        Next J
        If dim([M:POH3]DSP)>0  Raz [M:POH3]DSP(I) : Endif
        For J=1 To GNBDIE
          Case J
            When  1 : Raz [M:POH3]PFICCE1 (I)
            When  2 : Raz [M:POH3]PFICCE2 (I)
            When  3 : Raz [M:POH3]PFICCE3 (I)
            When  4 : Raz [M:POH3]PFICCE4 (I)
            When  5 : Raz [M:POH3]PFICCE5 (I)
            When  6 : Raz [M:POH3]PFICCE6 (I)
            When  7 : Raz [M:POH3]PFICCE7 (I)
            When  8 : Raz [M:POH3]PFICCE8 (I)
            When  9 : Raz [M:POH3]PFICCE9 (I)
            When 10 : Raz [M:POH3]PFICCE10(I)
            When 11 : Raz [M:POH3]PFICCE11(I)
            When 12 : Raz [M:POH3]PFICCE12(I)
            When 13 : Raz [M:POH3]PFICCE13(I)
            When 14 : Raz [M:POH3]PFICCE14(I)
            When 15 : Raz [M:POH3]PFICCE16(I)
            When 16 : Raz [M:POH3]PFICCE17(I)
            When 17 : Raz [M:POH3]PFICCE17(I)
            When 18 : Raz [M:POH3]PFICCE18(I)
            When 19 : Raz [M:POH3]PFICCE19(I)
            When 20 : Raz [M:POH3]PFICCE20(I)
          Endcase
        Next J
      Next I
      Raz [M:POH3]NBFAC
    Endif
  When 5 : #----- Commande ouverte -----#
    If [M:POC3]NBFAC>0
      For I=0 To [M:POC3]NBFAC-1
        #----- Mise à jour des cumuls comme pour une suppression de ligne -----#
        nolign=I+1 : status=65 : Call AVANT_NBFAC From SUBPOC
        #-----
        Raz [M:POC3]INVDTA(I),    [M:POC3]INVDTALIB(I), [M:POC3]INVDTAAMT(I),
&           [M:POC3]INVORDAMT(I), [M:POC3]INVLINAMT(I), [M:POC3]INVCPLAMT(I),
&           [M:POC3]INVDTAFLG(I), [M:POC3]INVLINFLG(I), [M:POC3]INVORDFLG(I),
&           [M:POC3]DEBCDT(I),    [M:POC3]INVDTAVAT(I), [M:POC3]AMTCOD(I),
&           [M:POC3]AMTCODLIB(I), [M:POC3]FORMAT(I),    [M:POC3]CLCORD(I),
&           [M:POC3]CLCBAS(I)
        If dim([M:POC3]DISVATFLG)>0  Raz [M:POC3]DISVATFLG(I) : Endif
        If dim([M:POC3]DTADISBAS)>0  Raz [M:POC3]DTADISBAS(I) : Endif
        For J=1 To GNBCOA
          Case J
            When  1 : Raz [M:POC3]ACC1 (I)
            When  2 : Raz [M:POC3]ACC2 (I)
            When  3 : Raz [M:POC3]ACC3 (I)
            When  4 : Raz [M:POC3]ACC4 (I)
            When  5 : Raz [M:POC3]ACC5 (I)
            When  6 : Raz [M:POC3]ACC6 (I)
            When  7 : Raz [M:POC3]ACC7 (I)
            When  8 : Raz [M:POC3]ACC8 (I)
            When  9 : Raz [M:POC3]ACC9 (I)
            When 10 : Raz [M:POC3]ACC10(I)
          Endcase
        Next J
        If dim([M:POC3]DSP)>0  Raz [M:POC3]DSP(I) : Endif
        For J=1 To GNBDIE
          Case J
            When  1 : Raz [M:POC3]PFICCE1 (I)
            When  2 : Raz [M:POC3]PFICCE2 (I)
            When  3 : Raz [M:POC3]PFICCE3 (I)
            When  4 : Raz [M:POC3]PFICCE4 (I)
            When  5 : Raz [M:POC3]PFICCE5 (I)
            When  6 : Raz [M:POC3]PFICCE6 (I)
            When  7 : Raz [M:POC3]PFICCE7 (I)
            When  8 : Raz [M:POC3]PFICCE8 (I)
            When  9 : Raz [M:POC3]PFICCE9 (I)
            When 10 : Raz [M:POC3]PFICCE10(I)
            When 11 : Raz [M:POC3]PFICCE11(I)
            When 12 : Raz [M:POC3]PFICCE12(I)
            When 13 : Raz [M:POC3]PFICCE13(I)
            When 14 : Raz [M:POC3]PFICCE14(I)
            When 15 : Raz [M:POC3]PFICCE16(I)
            When 16 : Raz [M:POC3]PFICCE17(I)
            When 17 : Raz [M:POC3]PFICCE17(I)
            When 18 : Raz [M:POC3]PFICCE18(I)
            When 19 : Raz [M:POC3]PFICCE19(I)
            When 20 : Raz [M:POC3]PFICCE20(I)
          Endcase
        Next J
      Next I
      Raz [M:POC3]NBFAC
    Endif
  When 6 : #----- Réception -----#
    If [M:PTH2]NBFAC>0
      For I=0 To [M:PTH2]NBFAC-1
        #----- Mise à jour des cumuls comme pour une suppression de ligne -----#
        nolign=I+1 : status=65 : Call AVANT_NBFAC From SUBPTH
        #-----
        Raz [M:PTH2]INVDTA(I),    [M:PTH2]INVDTALIB(I), [M:PTH2]INVDTAAMT(I),
&           [M:PTH2]INVORDAMT(I), [M:PTH2]INVLINAMT(I), [M:PTH2]INVCPLAMT(I),
&           [M:PTH2]INVDTAFLG(I), [M:PTH2]INVLINFLG(I), [M:PTH2]INVLINFLG(I),
&           [M:PTH2]INVORDFLG(I), [M:PTH2]DEBCDT(I),    [M:PTH2]INVDTAVAT(I),
&           [M:PTH2]DTAAMTTAX(I),
&           [M:PTH2]DTADEDTAX(I), [M:PTH2]CLCORD(I),    [M:PTH2]CLCBAS(I)
        If dim([M:PTH2]DISVATFLG)>0  Raz [M:PTH2]DISVATFLG(I) : Endif
        If dim([M:PTH2]DTADISBAS)>0  Raz [M:PTH2]DTADISBAS(I) : Endif
        For J=1 To GNBCOA
          Case J
            When  1 : Raz [M:PTH2]ACC1 (I)
            When  2 : Raz [M:PTH2]ACC2 (I)
            When  3 : Raz [M:PTH2]ACC3 (I)
            When  4 : Raz [M:PTH2]ACC4 (I)
            When  5 : Raz [M:PTH2]ACC5 (I)
            When  6 : Raz [M:PTH2]ACC6 (I)
            When  7 : Raz [M:PTH2]ACC7 (I)
            When  8 : Raz [M:PTH2]ACC8 (I)
            When  9 : Raz [M:PTH2]ACC9 (I)
            When 10 : Raz [M:PTH2]ACC10(I)
          Endcase
        Next J
        If dim([M:PTH2]DSP)>0  Raz [M:PTH2]DSP(I) : Endif
        For J=1 To GNBDIE
          Case J
            When  1 : Raz [M:PTH2]PFICCE1 (I)
            When  2 : Raz [M:PTH2]PFICCE2 (I)
            When  3 : Raz [M:PTH2]PFICCE3 (I)
            When  4 : Raz [M:PTH2]PFICCE4 (I)
            When  5 : Raz [M:PTH2]PFICCE5 (I)
            When  6 : Raz [M:PTH2]PFICCE6 (I)
            When  7 : Raz [M:PTH2]PFICCE7 (I)
            When  8 : Raz [M:PTH2]PFICCE8 (I)
            When  9 : Raz [M:PTH2]PFICCE9 (I)
            When 10 : Raz [M:PTH2]PFICCE10(I)
            When 11 : Raz [M:PTH2]PFICCE11(I)
            When 12 : Raz [M:PTH2]PFICCE12(I)
            When 13 : Raz [M:PTH2]PFICCE13(I)
            When 14 : Raz [M:PTH2]PFICCE14(I)
            When 15 : Raz [M:PTH2]PFICCE16(I)
            When 16 : Raz [M:PTH2]PFICCE17(I)
            When 17 : Raz [M:PTH2]PFICCE17(I)
            When 18 : Raz [M:PTH2]PFICCE18(I)
            When 19 : Raz [M:PTH2]PFICCE19(I)
            When 20 : Raz [M:PTH2]PFICCE20(I)
          Endcase
        Next J
      Next I
      Raz [M:PTH2]NBFAC
    Endif
  When 8 : #----- Facture -----#
    For I=0 To dim([M:PIH1]INVDTA1)-1
      #----- Mise à jour des cumuls comme pour une suppression de ligne -----#
      nolign=I+1 : status=65 : Call AVANT_NBFAC From SUBPIH
      #-----
      Raz [M:PIH1]INVDTA1(I),    [M:PIH1]INVDTALIB1(I),
&         [M:PIH1]INVDTAAMT1(I), [M:PIH1]DEBCDT1(I),    [M:PIH1]INVDTAFLG1(I)
    Next I
    Raz [M:PIH1]NBFAC1
    For I=0 To dim([M:PIH4]INVDTA)-1
      Raz [M:PIH4]INVDTA(I),     [M:PIH4]INVDTALIB(I),
&         [M:PIH4]INVDTAAMT(I),  [M:PIH4]INVORDAMT(I),  [M:PIH4]INVLINAMT(I),
&         [M:PIH4]INVLINFLG(I),  [M:PIH4]INVDIFAMT(I),  [M:PIH4]INVDTAVAT(I),
&         [M:PIH4]DTAAMTTAX(I),  [M:PIH4]DTADEDTAX(I),  [M:PIH4]DEBCDT(I),
&         [M:PIH4]CLCORD(I),     [M:PIH4]CLCBAS(I)
        If dim([M:PIH4]DISVATFLG)>0  Raz [M:PIH4]DISVATFLG(I) : Endif
        If dim([M:PIH4]DTADISBAS)>0  Raz [M:PIH4]DTADISBAS(I) : Endif
        # Issue 83026 - 2012-06-26 by MUARN : early escompte
        Raz [M:PIH4]DEPFLG(I), [M:PIH4]INCDCR(I)
      For J=1 To GNBCOA
        Case J
          When  1 : Raz [M:PIH4]ACC1 (I)
          When  2 : Raz [M:PIH4]ACC2 (I)
          When  3 : Raz [M:PIH4]ACC3 (I)
          When  4 : Raz [M:PIH4]ACC4 (I)
          When  5 : Raz [M:PIH4]ACC5 (I)
          When  6 : Raz [M:PIH4]ACC6 (I)
          When  7 : Raz [M:PIH4]ACC7 (I)
          When  8 : Raz [M:PIH4]ACC8 (I)
          When  9 : Raz [M:PIH4]ACC9 (I)
          When 10 : Raz [M:PIH4]ACC10(I)
        Endcase
      Next J
      If dim([M:PIH4]DSP)>0  Raz [M:PIH4]DSP(I) : Endif
      For J=1 To GNBDIE
        Case J
          When  1 : Raz [M:PIH4]PFICCE1 (I)
          When  2 : Raz [M:PIH4]PFICCE2 (I)
          When  3 : Raz [M:PIH4]PFICCE3 (I)
          When  4 : Raz [M:PIH4]PFICCE4 (I)
          When  5 : Raz [M:PIH4]PFICCE5 (I)
          When  6 : Raz [M:PIH4]PFICCE6 (I)
          When  7 : Raz [M:PIH4]PFICCE7 (I)
          When  8 : Raz [M:PIH4]PFICCE8 (I)
          When  9 : Raz [M:PIH4]PFICCE9 (I)
          When 10 : Raz [M:PIH4]PFICCE10(I)
          When 11 : Raz [M:PIH4]PFICCE11(I)
          When 12 : Raz [M:PIH4]PFICCE12(I)
          When 13 : Raz [M:PIH4]PFICCE13(I)
          When 14 : Raz [M:PIH4]PFICCE14(I)
          When 15 : Raz [M:PIH4]PFICCE16(I)
          When 16 : Raz [M:PIH4]PFICCE17(I)
          When 17 : Raz [M:PIH4]PFICCE17(I)
          When 18 : Raz [M:PIH4]PFICCE18(I)
          When 19 : Raz [M:PIH4]PFICCE19(I)
          When 20 : Raz [M:PIH4]PFICCE20(I)
        Endcase
      Next J
    Next I
    Raz [M:PIH4]NBFAC
Endcase
#-----
Return


#----------------------------------------------------#
# Chargement d'un élément de facturation fournisseur #
#----------------------------------------------------#
$CHARG_ELEMENTS_FOU
#----- lecture du fournisseur commande ou facture si nécessaire -----#
If [F:BPS2]BPSNUM<>WBPSNUM
  Read [BPS2] BPS0=WBPSNUM : If fstat  Raz  [F:BPS2] : Endif
Endif
#------
For I=0 To dim([F:BPS2]INVDTA)-1
  If [F:BPS2]INVDTA(I)<>0
    Read [PFI] PFI0=[F:BPS2]INVDTA(I) : If fstat  Raz [F:PFI] : Endif
    If evalue(WFILTRE)
      If K>WMAX-1  Call ERREUR (mess(26,100,1)) From GESECRAN : Break : Endif
      Call LECTEXTRA(WSHO,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
      If [F:PFI]VATRUL=2
        Call RECHVATFOOT(2,WBPSORD,[F:PFI]PFINUM,WABREV,WVAT) From TRTX3
      Else
        Raz WVAT
      Endif
      If [F:BPS2]AMTCOD(I)=1
        WAMTCODLIB="%"     : WFORMAT=func TRTX3FNC.GETFMTREM(1)
        MTBPR=[F:BPS2]INVDTAAMT(I)
      Else
        WAMTCODLIB=WCURDES : WFORMAT="NZ:"+[F:TCU]CURFMT1+"[ ]"
        If WCURORI<>WCURDES
          Call CONVERT(WCURORI,WCURDES,GLOCALDEV,WTYPCUR,datesyst,[F:BPS2]INVDTAAMT(I),MTBPR,WRET) From TRTDEV
        Else
          MTBPR=[F:BPS2]INVDTAAMT(I)
        Endif
      Endif
      If [F:PFI]INCDCR=2 & MTBPR>0
        If WVCRTYP=3 | WVCRTYP=5
          If [F:BPS2]AMTCOD(I)>1  MTBPR=-MTBPR : Endif
        Else
          MTBPR=-MTBPR
        Endif
      Endif
      #-----
      Case WVCRTYP
        When 3 : #----- Commande -----#
          [M:POH3]INVDTA   (K)=[F:BPS2]INVDTA(I)
          [M:POH3]INVDTALIB(K)=WSHO
          [M:POH3]INVDTAAMT(K)=abs(MTBPR)
          [M:POH3]AMTCODLIB(K)=WAMTCODLIB
          If [F:BPS2]AMTCOD(I)=2
            [M:POH3]INVORDAMT(K)=MTBPR
          Endif
          [M:POH3]INVDTAVAT(K)=WVAT
          [M:POH3]INVDTAFLG(K)=1
          [M:POH3]INVLINFLG(K)=[F:PFI]DSPLIN
          [M:POH3]INVORDFLG(K)=[F:PFI]DACORD
          If dim([M:POH3]DISVATFLG)>0  [M:POH3]DISVATFLG(K)=[F:PFI]DISVATFLG : Endif
          [M:POH3]DEBCDT   (K)=[F:PFI]INCDCR
          If dim([M:POH3]DSP)>0
            [M:POH3]DSP    (K)=[F:PFI]DSP
          Endif
          [M:POH3]AMTCOD   (K)=[F:BPS2]AMTCOD(I)
          [M:POH3]FORMAT   (K)=WFORMAT
          [M:POH3]CLCORD   (K)=[F:PFI]CLCORD
          [M:POH3]CLCBAS   (K)=[F:PFI]CLCBAS
          [M:POH3]NBFAC=K+1
          #nolign=K+1 : Call AM_INVDTAAMT([M:POH3]INVDTAAMT(K)) From SUBPOH
          #-----
          #Call MAJ_ELEMENT (K,0,+1) From SUBPOHC
          #-----
        When 5 : #----- Commande ouverte -----#
          [M:POC3]INVDTA   (K)=[F:BPS2]INVDTA(I)
          [M:POC3]INVDTALIB(K)=WSHO
          [M:POC3]INVDTAAMT(K)=abs(MTBPR)
          [M:POC3]AMTCODLIB(K)=WAMTCODLIB
          If [F:BPS2]AMTCOD(I)=2
            [M:POC3]INVORDAMT(K)=MTBPR
          Endif
          [M:POC3]INVDTAVAT(K)=WVAT
          [M:POC3]INVDTAFLG(K)=1
          [M:POC3]INVLINFLG(K)=[F:PFI]DSPLIN
          [M:POC3]INVORDFLG(K)=[F:PFI]DACORD
          If dim([M:POC3]DISVATFLG)>0  [M:POC3]DISVATFLG(K)=[F:PFI]DISVATFLG : Endif
          [M:POC3]DEBCDT   (K)=[F:PFI]INCDCR
          If dim([M:POC3]DSP)>0
            [M:POC3]DSP    (K)=[F:PFI]DSP
          Endif
          [M:POC3]AMTCOD   (K)=[F:BPS2]AMTCOD(I)
          [M:POC3]FORMAT   (K)=WFORMAT
          [M:POC3]CLCORD   (K)=[F:PFI]CLCORD
          [M:POC3]CLCBAS   (K)=[F:PFI]CLCBAS
          [M:POC3]NBFAC=K+1
        When 6 : #----- Réception -----#
          [M:PTH2]INVDTA   (K)=[F:BPS2]INVDTA(I)
          [M:PTH2]INVDTALIB(K)=WSHO
          If [F:PFI]AMTCOD=2
            #[M:PTH2]INVDTAAMT(K)=MTBPR : # On ne charge pas de Mt pour les réceptions !
          Endif
          [M:PTH2]INVDTAVAT(K)=WVAT
          [M:PTH2]INVDTAFLG(K)=1
          [M:PTH2]INVLINFLG(K)=[F:PFI]DSPLIN
          [M:PTH2]INVORDFLG(K)=[F:PFI]DACORD
          If dim([M:PTH2]DISVATFLG)>0
            [M:PTH2]DISVATFLG(K)=[F:PFI]DISVATFLG
            If [F:PFI]DISVATFLG=2
              [M:PTH2]INVORDAMT(K)=abs(MTBPR)
            Endif
          Endif
          [M:PTH2]DEBCDT   (K)=[F:PFI]INCDCR
          If dim([M:PTH2]DSP)>0
            [M:PTH2]DSP    (K)=[F:PFI]DSP
          Endif
          [M:PTH2]CLCORD   (K)=[F:PFI]CLCORD
          [M:PTH2]CLCBAS   (K)=[F:PFI]CLCBAS
          [M:PTH2]NBFAC=K+1
        When 8 : #----- Facture -----#
          [M:PIH1]INVDTA1   (K)=[F:BPS2]INVDTA(I)
          [M:PIH4]INVDTA    (K)=[F:BPS2]INVDTA(I)
          [M:PIH1]INVDTALIB1(K)=WSHO
          [M:PIH4]INVDTALIB (K)=WSHO
          If [F:PFI]DACORD=1 & [F:PFI]AMTCOD=2
            [M:PIH1]INVDTAAMT1(K)=MTBPR
            [M:PIH4]INVDTAAMT (K)=MTBPR
          Endif
          [M:PIH4]INVDTAVAT (K)=WVAT
          [M:PIH1]INVDTAFLG1(K)=1
          [M:PIH4]INVLINFLG (K)=[F:PFI]DSPLIN
          [M:PIH4]INVORDFLG (K)=[F:PFI]DACORD
          If dim([M:PIH4]DISVATFLG)>0
            [M:PIH4]DISVATFLG(K)=[F:PFI]DISVATFLG
            If [F:PFI]DISVATFLG=2
              [M:PIH4]INVORDAMT(K)=abs(MTBPR)
            Endif
          Endif
          If [M:PIH0]PIHTYP<3
            [M:PIH1]DEBCDT1 (K)=[F:PFI]INCDCR
          Else
            [M:PIH1]DEBCDT1 (K)=3-[F:PFI]INCDCR
          Endif
          [M:PIH4]DEBCDT    (K)=[M:PIH1]DEBCDT1(K)
          If dim([M:PIH4]DSP)>0
            [M:PIH4]DSP     (K)=[F:PFI]DSP
          Endif
          [M:PIH4]CLCORD   (K)=[F:PFI]CLCORD
          [M:PIH4]CLCBAS   (K)=[F:PFI]CLCBAS
          # Issue 83026 - 2012-06-26 by MUARN : early escompte
          [M:PIH4]DEPFLG(K)   =[F:PFI]DEPFLG
          [M:PIH4]INCDCR(K)   =[F:PFI]INCDCR
          [M:PIH1]NBFAC1=K+1
          [M:PIH4]NBFAC =K+1
      Endcase
      K+=1
    Endif
  Endif
Next I
#-----
Return


#----------------------------------------------#
# Chargement des éléments de facturation tarif #
#----------------------------------------------#
$CHARG_ELEMENTS_TAR
If WVCRTYP<>3 & WVCRTYP<>6 & WVCRTYP<>8  Return : Endif
For I=0 To 8
  If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
    If K>WMAX-1  Call ERREUR (mess(26,100,1)) From GESECRAN : Break : Endif
    Read [PFI] PFI0=GINVDTALIN(I) : If fstat  Raz [F:PFI] : Endif
    Call LECTEXTRA(WSHO,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
    If [F:PFI]VATRUL=2
      Call RECHVATFOOT(2,WBPSORD,[F:PFI]PFINUM,WABREV,WVAT) From TRTX3
    Else
      Raz WVAT
    Endif
    #-----
    If [F:PFI]AMTCOD=1
      WAMTCODLIB="%"     : WFORMAT=func TRTX3FNC.GETFMTREM(1)
    Else
      WAMTCODLIB=WCURDES : WFORMAT="NZz:"+[F:TCU]CURFMT1+"[ ]"
    Endif
    #-----
    Case WVCRTYP
      When 3 : #----- Commande -----#
        [M:POH3]INVDTA    (K)=GINVDTALIN(I)
        [M:POH3]INVDTALIB (K)=WSHO
        [M:POH3]AMTCODLIB (K)=""
        [M:POH3]INVDTAVAT (K)=WVAT
        [M:POH3]INVDTAFLG (K)=1
        [M:POH3]INVLINFLG (K)=6
        [M:POH3]INVORDFLG (K)=[F:PFI]DACORD
        If dim([M:POH3]DISVATFLG)>0  [M:POH3]DISVATFLG(K)=[F:PFI]DISVATFLG : Endif
        [M:POH3]DEBCDT    (K)=[F:PFI]INCDCR
        If dim([M:POH3]DSP)>0
          [M:POH3]DSP     (K)=[F:PFI]DSP
        Endif
        [M:POH3]CLCORD    (K)=[F:PFI]CLCORD
        [M:POH3]CLCBAS    (K)=[F:PFI]CLCBAS
        [M:POH3]FORMAT    (K)=WFORMAT
        [M:POH3]NBFAC=K+1
        [M:POH2]INVDTAVAT1(I)=WVAT
      When 6 : #----- Réception -----#
        [M:PTH2]INVDTA    (K)=GINVDTALIN(I)
        [M:PTH2]INVDTALIB (K)=WSHO
        [M:PTH2]INVDTAVAT (K)=WVAT
        [M:PTH2]INVLINFLG (K)=6
        [M:PTH2]INVORDFLG (K)=[F:PFI]DACORD
        If dim([M:PTH2]DISVATFLG)>0  [M:PTH2]DISVATFLG(K)=[F:PFI]DISVATFLG : Endif
        [M:PTH2]DEBCDT    (K)=[F:PFI]INCDCR
        If dim([M:PTH2]DSP)>0
          [M:PTH2]DSP     (K)=[F:PFI]DSP
        Endif
        [M:PTH2]CLCORD    (K)=[F:PFI]CLCORD
        [M:PTH2]CLCBAS    (K)=[F:PFI]CLCBAS
        [M:PTH2]NBFAC=K+1
        [M:PTH1]INVDTAVAT1(I)=WVAT
      When 8 : #----- Facture -----#
        [M:PIH1]INVDTA1   (K)=GINVDTALIN(I)
        [M:PIH4]INVDTA    (K)=GINVDTALIN(I)
        [M:PIH1]INVDTALIB1(K)=WSHO
        [M:PIH4]INVDTALIB (K)=WSHO
        [M:PIH4]INVDTAVAT (K)=WVAT
        [M:PIH1]INVDTAFLG1(K)=1
        [M:PIH4]INVLINFLG (K)=6
        [M:PIH4]INVORDFLG (K)=[F:PFI]DACORD
        If dim([M:PIH4]DISVATFLG)>0  [M:PIH4]DISVATFLG(K)=[F:PFI]DISVATFLG : Endif
        If [M:PIH0]PIHTYP<3
          [M:PIH1]DEBCDT1 (K)=[F:PFI]INCDCR
        Else
          [M:PIH1]DEBCDT1 (K)=3-[F:PFI]INCDCR
        Endif
        [M:PIH4]DEBCDT    (K)=[M:PIH1]DEBCDT1(K)
        If dim([M:PIH4]DSP)>0
          [M:PIH4]DSP     (K)=[F:PFI]DSP
        Endif
        [M:PIH4]CLCORD    (K)=[F:PFI]CLCORD
        [M:PIH4]CLCBAS    (K)=[F:PFI]CLCBAS
        # Issue 83026 - 2012-06-26 by MUARN : early escompte
        [M:PIH4]DEPFLG(K)   =[F:PFI]DEPFLG
        [M:PIH4]INCDCR(K)   =[F:PFI]INCDCR
        [M:PIH1]NBFAC1=K+1
        [M:PIH4]NBFAC =K+1
        [M:PIH3]INVDTAVAT1(I)=WVAT
    Endcase
    K+=1
  Endif
Next I
#-----
Return


################################################################################
# ENREG_ELEMENTS : S/P de mise à jour de la table PVCRFOOT        MBT 22/11/07 #
# ---------------------------------------------------------------------------- #
# Subprog ENREG_ELEMENTS (WVCRTYP,WVCRNUM,WABRMSK,WMAJCOD)                     #
#   Sous-programme appelé lors de l'écriture ou de la réécriture des tables    #
#   d'entête de document achats                                                #
# ---------------------------------------------------------------------------- #
#   WVCRTYP : Type du document                                                 #
#                3 = Commande                                                  #
#                5 = Commande ouverte                                          #
#                6 = Réception                                                 #
#                8 = Facture/Avoir                                             #
#   WVCRNUM : Numéro du document                                               #
#   WABRMSK : Abréviation du masque écran contenant le tableau des éléments    #
#               "POH3" pour commande                                           #
#               "POC3" pour commande ouverte                                   #
#               "PTH2" pour réception                                          #
#               "PIH4" pour facture                                            #
#   WMAJCOD : Code mise à jour                                                 #
#               "C" = Création                                                 #
#               "M" = Modification                                             #
#               "A" = Annulation                                               #
################################################################################
Subprog ENREG_ELEMENTS(WVCRTYP,WVCRNUM,WABRMSK,WMAJCOD)
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Char    WABRMSK
Value Char    WMAJCOD
#-----
Local Integer SAV_NOLIGN      : SAV_NOLIGN=nolign
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Integer I, J
Local Date    WCREDAT
Local Char    WCREUSR(GLONAUS)
Local Char    WNOMDSP(20)
#-----
If !clalev([F:PVF])  Local File PVCRFOOT  [PVF] : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#----- Suppression des enregistrements concernant le document -----#
If WMAJCOD="M" | WMAJCOD="A"
  #----- Récup date et opérateur de création -----#
  Read [PVF] PVF1=WVCRTYP;WVCRNUM;1 : If fstat  Raz [F:PVF] : Endif
  WCREDAT=[F:PVF]CREDAT
  WCREUSR=[F:PVF]CREUSR
  #----- Suppression des enregistrements éléments de facturation -----#
  Delete [PVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  If fstat=1
    GOK=-1 : GLOCK="$PVCRFOOT"-num$(WVCRTYP)-WVCRNUM : End
  Endif
  #----- Suppression des enregistrements comptes et sections analytiques -----#
  Delete [CAL] Where ABRFIC="PVF" & VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN PVF"-num$(WVCRTYP)-WVCRNUM : End
  Endif
  #-----
  If WMAJCOD="A"  End : Return : Endif
Endif
#----- Création des enregistrements concernant le document -----#
Raz [F:PVF]
[F:PVF]VCRTYP=WVCRTYP
[F:PVF]VCRNUM=WVCRNUM
[F:PVF]AMTCOD=2 : # Sera remis à jour par le transclasse des commandes !
#----- Pour le bon fonctionnement des pièces auto -----#
Case WVCRTYP
  When 3,5 : [F:PVF]POHNUM=WVCRNUM
  When 6   : [F:PVF]PTHNUM=WVCRNUM
  When 8   : [F:PVF]NUM   =WVCRNUM
Endcase
#-----
If WMAJCOD="C"
  [F:PVF]CREDAT=date$
  [F:PVF]CREUSR=GUSER
Else
  [F:PVF]CREDAT=WCREDAT
  [F:PVF]CREUSR=WCREUSR
  [F:PVF]UPDDAT=date$
  [F:PVF]UPDUSR=GUSER
Endif
#-----
Raz [F:CAL]
[F:CAL]ABRFIC="PVF"
[F:CAL]VCRTYP=WVCRTYP
[F:CAL]VCRNUM=WVCRNUM
[F:CAL]ANALIG=1
#-----
Default Mask "["+WABRMSK+"]"
For I=0 To evalue("[M:"+WABRMSK+"]NBFAC")-1
  #----- Ecriture des éléments de facturation -----#
  nolign=I+1 : [F:PVF] = [M]
  #----- Particularité factures (deux tableaux d'éléments de facturation) -----#
  If WVCRTYP=8
    [F:PVF]INVDTAFLG=[M:PIH1]INVDTAFLG1(I)
  #----- Pour les commandes et réceptions, il faut remettre le mt facturé non signé -----#
  Elsif dim([M]INVCPLAMT)>0 & [M]DEBCDT(I)=2
    [F:PVF]INVCPLAMT=-[M]INVCPLAMT(I)
  Endif
  #-----
  [F:PVF]IND=I+1
  Write [PVF]
  If fstat  GOK=0 : Call FSTA("PVF") From GLOCK : Break : Endif
  #----- Ecriture des comptes et sections des éléments de facturation -----#
  If evalue("dim([M:"+WABRMSK+"]DSP)")>0
    WNOMDSP="[M:"+WABRMSK+"]DSP"
  Else
    WNOMDSP=""
  Endif
  Call ENREG_ACCCCE(nolign-1,"[M:"+WABRMSK+"]ACC",WNOMDSP,"[M:"+WABRMSK+"]PFICCE","PVF",
&                   WVCRTYP,WVCRNUM,0,I+1,"","C") From TRTX3CPT
  If GOK<1  Break : Endif
  #-----
Next I
#-----
Default Mask SAV_DEFMSK
nolign=SAV_NOLIGN
#-----
End


################################################################################
# CHARG_ELEMENTS : S/P d'alimentation de la classe [M]            MBT 23/11/07 #
#                  à partir des tables PVCRFOOT et CPTANALIN                   #
# ---------------------------------------------------------------------------- #
# Subprog CHARG_ELEMENTS (WVCRTYP,WVCRNUM,WABRMSK)                             #
#   Sous-programme appelé généralement lors de l'action LIENS de l'objet       #
# ---------------------------------------------------------------------------- #
#   WVCRTYP : Type du document                                                 #
#                3 = Commande                                                  #
#                5 = Commande ouverte                                          #
#                6 = Réception                                                 #
#                8 = Facture/Avoir                                             #
#   WVCRNUM : Numéro du document                                               #
#   WABRMSK : Abréviation du masque écran contenant le tableau des éléments    #
#               "POH3" pour commande                                           #
#               "POC3" pour commande ouverte                                   #
#               "PTH2" pour réception                                          #
#               "PIH4" pour facture                                            #
################################################################################
Subprog CHARG_ELEMENTS(WVCRTYP,WVCRNUM,WABRMSK)
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Char    WABRMSK
#-----
Local Integer SAV_NOLIGN      : SAV_NOLIGN=nolign
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Char    WSHO(GLONAX1)
Local Char    WNOMACC(GLONAVA+8)
Local Char    WNOMDSP(GLONAVA+8)
Local Char    WNOMCCE(GLONAVA+8)
#-----
If !clalev([F:PVF])  Local File PVCRFOOT  [PVF] : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#-----
WNOMACC="[M:"+WABRMSK+"]ACC"
WNOMDSP="[M:"+WABRMSK+"]DSP"
WNOMCCE="[M:"+WABRMSK+"]PFICCE"
#-----
Default Mask "["+WABRMSK+"]"
nolign=0
For [PVF] PVF1 Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  #----- Transclasse -----#
  nolign+=1 : [M] = [F:PVF]
  # Issue 85145 - 2012-10-16 by MUARN : tunel sur élément de facturation avec document en devise
  If [M]AMTCODLIB(nolign-1)=""
    [M]AMTCODLIB(nolign-1)=GCUR
  Endif
  #----- Libellé traduit en fonction de GLANGUE -----#
  Call LECTEXTRA(WSHO,"PFOOTINV","SHOAXX",num$([F:PVF]INVDTA),"") From ATEXTRA
  Assign "[M:"+WABRMSK+"]INVDTALIB(nolign-1)" With WSHO
  #----- Particularité pour les factures (deux tableaux d'éléments) -----#
  If WVCRTYP=8
    [M:PIH1]INVDTA1   (nolign-1)=[M:PIH4]INVDTA   (nolign-1)
    [M:PIH1]INVDTALIB1(nolign-1)=[M:PIH4]INVDTALIB(nolign-1)
    [M:PIH1]INVDTAAMT1(nolign-1)=[M:PIH4]INVDTAAMT(nolign-1)
    [M:PIH1]DEBCDT1   (nolign-1)=[M:PIH4]DEBCDT   (nolign-1)
    [M:PIH1]INVDTAFLG1(nolign-1)=[F:PVF]INVDTAFLG
  #----- Pour les commandes et réceptions, il faut signer le mt facturé -----#
  Elsif dim([M]INVCPLAMT)>0 & [M]DEBCDT(nolign-1)=2
    [M]INVCPLAMT(nolign-1)=-[M]INVCPLAMT(nolign-1)
  Endif
  #----- Chargement des comptes et sections analytiques -----#
  Call CHARG_ACCCCE(nolign-1,WNOMACC,WNOMDSP,WNOMCCE,
&                   "PVF",WVCRTYP,WVCRNUM,0,nolign,"") From TRTX3CPT
  #-----
Next
Assign "[M:"+WABRMSK+"]NBFAC" With nolign
If WVCRTYP=8  [M:PIH1]NBFAC1=nolign : Endif
#----- Une petite vérif pour la mise au point, sera supprimé à terme -----#
If nolign>0 & nolign<>[F:PVF]IND
  Infbox "Désynchro éléments facturation ("+num$(nolign)+"<->"+num$([F:PVF]IND)+")"
Endif
#-----
Default Mask SAV_DEFMSK
nolign=SAV_NOLIGN
#-----
End


################################################################################
# ENREG_TAXES : S/P de mise à jour de la table PVCRVAT            MBT 27/11/07 #
# ---------------------------------------------------------------------------- #
# Subprog ENREG_TAXES (WVCRTYP,WVCRNUM,WABRMSK,WMAJCOD)                        #
#   Sous-programme appelé lors de l'écriture ou de la réécriture des tables    #
#   d'entête de document achats                                                #
# ---------------------------------------------------------------------------- #
#   WVCRTYP : Type du document                                                 #
#                3 = Commande                                                  #
#                5 = Commande ouverte                                          #
#                6 = Réception                                                 #
#                8 = Facture/Avoir                                             #
#   WVCRNUM : Numéro du document                                               #
#   WABRMSK : Abréviation du masque écran contenant le tableau des éléments    #
#               "POH3" pour commande                                           #
#               "POC3" pour commande ouverte                                   #
#               "PTH2" pour réception                                          #
#               "PIH4" pour facture                                            #
#   WMAJCOD : Code mise à jour                                                 #
#               "C" = Création                                                 #
#               "M" = Modification                                             #
#               "A" = Annulation                                               #
################################################################################
Subprog ENREG_TAXES(WVCRTYP,WVCRNUM,WABRMSK,WMAJCOD)
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Char    WABRMSK
Value Char    WMAJCOD
#-----
Local Integer SAV_NOLIGN      : SAV_NOLIGN=nolign
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Integer I, J
Local Date    WCREDAT
Local Char    WCREUSR(GLONAUS)
Local Date    WDATE
Local Integer WRET	:#--CPO 71937 TVT et multi-lèg
#-----
If !clalev([F:PVV])  Local File PVCRVAT   [PVV] : Endif
If !clalev([F:TRA])  Local File TABRATVAT [TRA] : Endif
If !clalev([F:TVT])  Local File TABVAT    [TVT] : Endif :#--CPO 71937 TVT et multi-lèg
#-----
Case WABRMSK
  When "POH3"  : WDATE=[M:POH0]ORDDAT
  When "POC3"  : WDATE=[M:POC0]ORDDAT
  When "PTH2"  : WDATE=[M:PTH0]RCPDAT
  When "PIH4"  : Gosub RECH_DATE_TAXE From SUBPIHB : WDATE=GBIDA1
  When Default : WDATE=date$
Endcase
#----- Suppression des enregistrements concernant le document -----#
If WMAJCOD="M" | WMAJCOD="A"
  #----- Récup date et opérateur de création -----#
  Read [PVV] PVV1=WVCRTYP;WVCRNUM;1 : If fstat  Raz [F:PVV] : Endif
  WCREDAT=[F:PVV]CREDAT
  WCREUSR=[F:PVV]CREUSR
  #----- Suppression des enregistrements taxes -----#
  Delete [PVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  If fstat=1
    GOK=-1 : GLOCK="$PVCRVAT"-num$(WVCRTYP)-WVCRNUM : End
  Endif
  #-----
  If WMAJCOD="A"  End : Return : Endif
Endif
#----- Création des enregistrements concernant le document -----#
Raz [F:PVV]
[F:PVV]VCRTYP=WVCRTYP
[F:PVV]VCRNUM=WVCRNUM
#----- Pour le bon fonctionnement des pièces auto -----#
Case WVCRTYP
  When 3,5 : [F:PVV]POHNUM=WVCRNUM
  When 6   : [F:PVV]PTHNUM=WVCRNUM
  When 8   : [F:PVV]NUM   =WVCRNUM
Endcase
#-----
If WMAJCOD="C"
  [F:PVV]CREDAT=date$
  [F:PVV]CREUSR=GUSER
Else
  [F:PVV]CREDAT=WCREDAT
  [F:PVV]CREUSR=WCREUSR
  [F:PVV]UPDDAT=date$
  [F:PVV]UPDUSR=GUSER
Endif
#-----
Default Mask "["+WABRMSK+"]"
For I=0 To evalue("[M:"+WABRMSK+"]NBTAX")-1
  #----- Ecriture des éléments de facturation -----#
  nolign=I+1 : [F:PVV] = [M]
  #----- Chargement des taux de taxe -----#
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:PVV]TAX,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif

  #Filter [TRA] Where CPY=GSOCIETE & VAT=[F:PVV]TAX & STRDAT<=WDATE
  Filter [TRA] Where CPY=GSOCIETE & VAT=[F:PVV]TAX & STRDAT<=WDATE & LEG=[F:TVT]LEG
  Read [TRA] TRA0 Last
  If fstat>2
    #Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=WDATE
    Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=WDATE & LEG=[F:TVT]LEG
    Read [TRA]TRA0 Last
    If fstat>2  Raz [F:TRA] : Endif
  Endif
  #--/CPO
  [F:PVV]VATRAT=[F:TRA]VATRAT
  [F:PVV]DEDRAT=[F:TRA]DEDRAT
  #-----
  [F:PVV]IND=I+1
  Write [PVV]
  If fstat  GOK=0 : Call FSTA("PVV") From GLOCK : Break : Endif
Next I
Filter [TRA]
#-----
Default Mask SAV_DEFMSK
nolign=SAV_NOLIGN
#-----
End


################################################################################
# CHARG_TAXES : S/P d'alimentation de la classe [M]               MBT 27/11/07 #
#                 à partir de la table PVCRVAT                                 #
# ---------------------------------------------------------------------------- #
# Subprog CHARG_TAXES (WVCRTYP,WVCRNUM,WABRMSK)                                #
#   Sous-programme appelé généralement lors de l'action LIENS de l'objet       #
# ---------------------------------------------------------------------------- #
#   WVCRTYP : Type du document                                                 #
#                3 = Commande                                                  #
#                5 = Commande ouverte                                          #
#                6 = Réception                                                 #
#                8 = Facture/Avoir                                             #
#   WVCRNUM : Numéro du document                                               #
#   WABRMSK : Abréviation du masque écran contenant le tableau des éléments    #
#               "POH3" pour commande                                           #
#               "POC3" pour commande ouverte                                   #
#               "PTH2" pour réception                                          #
#               "PIH4" pour facture                                            #
################################################################################
Subprog CHARG_TAXES(WVCRTYP,WVCRNUM,WABRMSK)
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Char    WABRMSK
#-----
Local Integer SAV_NOLIGN      : SAV_NOLIGN=nolign
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Char    WSHO(GLONAX1)
Local Integer WRET :#--CPO 71937 TVT et multi-lèg
#-----
If !clalev([F:PVV])  Local File PVCRVAT [PVV] : Endif
If !clalev([F:TVT])  Local File TABVAT  [TVT] : Endif :#--CPO 71937 TVT et multi-lèg
#-----
Default Mask "["+WABRMSK+"]"
nolign=0
For [PVV] PVV1 Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  #----- Transclasse -----#
  nolign+=1 : [M] = [F:PVV]
  #----- Libellé traduit en fonction de GLANGUE -----#
  #--CPO 71937 TVT et multi-lèg
  #Call LECTEXTRA(WSHO,"TABVAT","SHOAXX",[F:PVV]TAX,"") From ATEXTRA
  Call LEC_TVT_LEG(GCURLEG,[F:PVV]TAX,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,WSHO) From TRTX3TEX
  #--/CPO
  Assign "[M:"+WABRMSK+"]LIBTAX(nolign-1)" With WSHO
  #-----
Next
Assign "[M:"+WABRMSK+"]NBTAX" With nolign
#----- Une petite vérif pour la mise au point, sera supprimé à terme -----#
If nolign>0 & nolign<>[F:PVV]IND
  Infbox "Désynchro taxes ("+num$(nolign)+"<->"+num$([F:PVV]IND)+")"
Endif
#-----
Default Mask SAV_DEFMSK
nolign=SAV_NOLIGN
#-----
End

#--CPO 71937 TABDEPAGIO
Subprog ALIDISVAT_LEG(WDEP,WLEG,WABRMSK)
Value Char WDEP
Value Char WLEG
Value Char WABRMSK

Gosub ALIDISVAT2

End


################################################################################
# ALIDISVAT : S/P de chargement ou remplacement de la             MBT 08/09/10 #
#                 remise sur taxe (settlement discount)                        #
#                 induite par le code escompte                                 #
# ---------------------------------------------------------------------------- #
# Subprog ALIDISVAT (WDEP,WABRMSK)                                             #
#   Sous-programme appelé lors du chargement ou de la modification du code     #
#   escompte sur l'entête de document achats                                   #
# ---------------------------------------------------------------------------- #
#   WDEP    : Code escompte                                                    #
#   WABRMSK : Abréviation du masque écran contenant le tableau des éléments    #
#               "POH3" pour commande                                           #
#               "POC3" pour commande ouverte                                   #
#               "PTH2" pour réception                                          #
#               "PIH4" pour facture                                            #
################################################################################
Subprog ALIDISVAT(WDEP,WABRMSK)
Value Char WDEP
Value Char WABRMSK
#-----
#--CPO 71937 TABDEPAGIO
Local Char WLEG(GLONADI)
WLEG=""
If dim(GCURLEG)>0 : WLEG=GCURLEG : Endif

Gosub ALIDISVAT2

End

$ALIDISVAT2
#--/CPO
Local Integer  WINVDTA
Local Decimal  WINVDTAAMT
Local Integer  I
Local Shortint NOL
Local Libelle  WUPDFLG
Local Integer  SVG_NOLIGN : SVG_NOLIGN=nolign
#-----
If !clalev([F:TDA])  Local File TABDEPAGIO [TDA] : Endif
#-----
#--CPO 71937 TABDEPAGIO
#If [F:TDA]DEP<>WDEP
#  Read [TDA] TDA0=WDEP : If fstat  Raz [F:TDA] Endif
#Endif
Local Integer WRET
Call LEC_TDA_LEG(WLEG,WDEP,WRET) From TRTLECLEG
If WRET : Raz [F:TDA] : Endif
#--/CPO
# Issue 102698 - 2014-11-19 by MUARN : ajout escompte belge
If [F:TDA]PFINUM<>0 & (GDEPMGTMOD=1 | GDEPMGTMOD=5)
  # Issue 102698 - 2014-11-19 by MUARN : contrôler que l'élément de facturation est bien une remise sur taxe avant alimentation variables
  If !clalev([F:PFI])  Local File PFOOTINV [PFI] : Endif
  Read [F:PFI]PFI0 = [TDA]PFINUM
  If fstat Raz [F:PFI] : Endif
  If [F:PFI]DISVATFLG=2
    WINVDTA   =[F:TDA]PFINUM
    WINVDTAAMT=abs(min([F:TDA]DEPRAT))
  Endif
Endif
#----- Aucun taux négatif trouvé, alors pas de remise sur taxe
If WINVDTAAMT=0  Raz WINVDTA : Endif
#-----
Case WABRMSK
  When "POH3"
    #----- Si une remise sur taxe existe déjà, il faut la modifier -----#
    If find(2,[M:POH3]DISVATFLG(0..[M:POH3]NBFAC-1))
      WUPDFLG=1
      NOL=find(2,[M:POH3]DISVATFLG(0..[M:POH3]NBFAC-1))-1
      Call MAJ_ELEMENT(NOL,0,-1) From SUBPOHC
    Else
      WUPDFLG=0
    Endif
    #----- Y a t-il une nouvelle remise sur taxe ? -----#
    If WINVDTA<>0
      #----- Modification de l'ancienne ligne remise sur taxe -----#
      If WUPDFLG=1
         #----- Elément différent -----#
         If [M:POH3]INVDTA(NOL)<>WINVDTA
           nolign=NOL+1 : status=75 : Gosub RAZ_DISVAT : Gosub CHARG_DISVAT
         #----- Même élément -----#
         Else
           [M:POH3]INVDTAAMT(NOL)=WINVDTAAMT
           [M:POH3]INVDTAFLG(NOL)=1
           Raz [M:POH3]INVORDAMT(NOL),[M:POH3]DTADISBAS(NOL),
&              [M:POH3]DTAAMTTAX(NOL),[M:POH3]DTADEDTAX(NOL)
         Endif
      #----- Création de la ligne remise sur taxe -----#
      Else
        NOL=[M:POH3]NBFAC
        [M:POH3]NBFAC+=1
        nolign=NOL+1 : status=73 : Gosub CHARG_DISVAT
      Endif
      Call MAJ_ELEMENT(NOL,0,+1) From SUBPOHC
      If !GIMPORT  Affzo [POH3]5 : Endif
    Else
      #----- Suppression ancienne ligne remise sur taxe non remplacée -----#
      If WUPDFLG=1
        Dela NOL,1,[M:POH3]NBFAC-1 [M:POH3]NBFAC : [M:POH3]NBFAC-=1
        If !GIMPORT  Affzo [POH3]5 : Endif
      Endif
    Endif
    #-----
    If WUPDFLG=1 | WINVDTA<>0
      For GPOH_INDTAX=1 To [M:POH3]NBTAX
        Gosub CAL_TAXE_GLOB From SUBPOHC
      Next GPOH_INDTAX
      If !GIMPORT  Affzo [POH3]10,15 : Endif
    Endif
    #-----
  When "POC3"
    #----- Si une remise sur taxe existe déjà, il faut la modifier -----#
    If find(2,[M:POC3]DISVATFLG(0..[M:POC3]NBFAC-1))
      WUPDFLG=1
      NOL=find(2,[M:POC3]DISVATFLG(0..[M:POC3]NBFAC-1))-1
    Else
      WUPDFLG=0
    Endif
    #----- Y a t-il une nouvelle remise sur taxe ? -----#
    If WINVDTA<>0
      #----- Modification de l'ancienne ligne remise sur taxe -----#
      If WUPDFLG=1
         #----- Elément différent -----#
         If [M:POC3]INVDTA(NOL)<>WINVDTA
           nolign=NOL+1 : status=75 : Gosub RAZ_DISVAT : Gosub CHARG_DISVAT
         #----- Même élément -----#
         Else
           [M:POC3]INVDTAAMT(NOL)=WINVDTAAMT
           [M:POC3]INVDTAFLG(NOL)=1
           [M:POC3]INVORDAMT(NOL)=0
         Endif
      #----- Création de la ligne remise sur taxe -----#
      Else
        NOL=[M:POC3]NBFAC
        [M:POC3]NBFAC+=1
        nolign=NOL+1 : status=73 : Gosub CHARG_DISVAT
      Endif
      If !GIMPORT  Affzo [POC3]5 : Endif
    Else
      #----- Suppression ancienne ligne remise sur taxe non remplacée -----#
      If WUPDFLG=1
        Dela NOL,1,[M:POC3]NBFAC-1 [M:POC3]NBFAC : [M:POC3]NBFAC-=1
        If !GIMPORT  Affzo [POC3]5 : Endif
      Endif
    Endif
    #-----
  When "PTH2"
    #----- Si une remise sur taxe existe déjà, il faut la modifier -----#
    If find(2,[M:PTH2]DISVATFLG(0..[M:PTH2]NBFAC-1))
      WUPDFLG=1
      NOL=find(2,[M:PTH2]DISVATFLG(0..[M:PTH2]NBFAC-1))-1
      Call MAJ_ELEMENT(NOL,0,-1) From SUBPTHD
    Else
      WUPDFLG=0
    Endif
    #----- Y a t-il une nouvelle remise sur taxe ? -----#
    If WINVDTA<>0
      #----- Modification de l'ancienne ligne remise sur taxe -----#
      If WUPDFLG=1
         #----- Elément différent -----#
         If [M:PTH2]INVDTA(NOL)<>WINVDTA
           nolign=NOL+1 : status=75 : Gosub RAZ_DISVAT : Gosub CHARG_DISVAT
         #----- Même élément -----#
         Else
           [M:PTH2]INVORDAMT(NOL)=WINVDTAAMT
           [M:PTH2]INVDTAFLG(NOL)=1
           Raz [M:PTH2]INVDTAAMT(NOL),[M:PTH2]DTADISBAS(NOL),
&              [M:PTH2]DTAAMTTAX(NOL),[M:PTH2]DTADEDTAX(NOL)
         Endif
      #----- Création de la ligne remise sur taxe -----#
      Else
        NOL=[M:PTH2]NBFAC
        [M:PTH2]NBFAC+=1
        nolign=NOL+1 : status=73 : Gosub CHARG_DISVAT
      Endif
      Call MAJ_ELEMENT(NOL,0,+1) From SUBPTHD
      If !GIMPORT  Affzo [PTH2]5 : Endif
    Else
      #----- Suppression ancienne ligne remise sur taxe non remplacée -----#
      If WUPDFLG=1
        Dela NOL,1,[M:PTH2]NBFAC-1 [M:PTH2]NBFAC : [M:PTH2]NBFAC-=1
        If !GIMPORT  Affzo [PTH2]5 : Endif
      Endif
    Endif
    #-----
    If WUPDFLG=1 | WINVDTA<>0
      For GPTH_INDTAX=1 To [M:PTH2]NBTAX
        Gosub CAL_TAXE_GLOB From SUBPTHD
      Next GPTH_INDTAX
      If !GIMPORT  Affzo [PTH2]10,15 : Endif
    Endif
    #-----
  When "PIH4"
    #----- Si 2ème tableau vide, le charger à partir du 1er -----#
    If [M:PIH1]NBFAC1>0 & [M:PIH4]NBFAC=0
      [M:PIH4]NBFAC=[M:PIH1]NBFAC1
      For I=0 To [M:PIH1]NBFAC1-1
        Call MAJ_ELEMENT (I,1,+1) From SUBPIHB
      Next I
      For GPIH_INDTAX=1 To [M:PIH4]NBTAX
        Gosub CAL_TAXE_GLOB From SUBPIHB
      Next GPIH_INDTAX
      If !GIMPORT Affzo [PIH4]5 : Endif
    Endif
    #----- Si une remise sur taxe existe déjà, il faut la modifier -----#
    If find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1))
      WUPDFLG=1
      NOL=find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1))-1
      Call MAJ_ELEMENT(NOL,0,-1) From SUBPIHB
    Else
      WUPDFLG=0
    Endif
    #----- Y a t-il une nouvelle remise sur taxe ? -----#
    If WINVDTA<>0
      #----- Modification de l'ancienne ligne remise sur taxe -----#
      If WUPDFLG=1
         #----- Elément différent -----#
         If [M:PIH4]INVDTA(NOL)<>WINVDTA
           nolign=NOL+1 : status=75 : Gosub RAZ_DISVAT : Gosub CHARG_DISVAT
         #----- Même élément -----#
         Else
           [M:PIH4]INVORDAMT (NOL)=WINVDTAAMT
           [M:PIH1]INVDTAFLG1(NOL)=1
           Raz [M:PIH4]INVDTAAMT(NOL),[M:PIH4]DTADISBAS(NOL),
&              [M:PIH4]DTAAMTTAX(NOL),[M:PIH4]DTADEDTAX(NOL)
         Endif
      #----- Création de la ligne remise sur taxe -----#
      Else
        NOL=[M:PIH1]NBFAC1
        [M:PIH1]NBFAC1+=1
        [M:PIH4]NBFAC+=1
        nolign=NOL+1 : status=73 : Gosub CHARG_DISVAT
      Endif
      Call MAJ_ELEMENT(NOL,0,+1) From SUBPIHB
      If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]5 : Endif
    Else
      #----- Suppression ancienne ligne remise sur taxe non remplacée -----#
      If WUPDFLG=1
        Dela NOL,1,[M:PIH1]NBFAC1-1 [M:PIH1]NBFAC1 : [M:PIH1]NBFAC1-=1
        Dela NOL,1,[M:PIH4]NBFAC-1  [M:PIH4]NBFAC  : [M:PIH4]NBFAC-=1
        # Issue 102698 - 2014-11-19 by MUARN : escomptes belges
        Raz [M:PIH1]DEPRAT
        If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]5 : Endif
      Endif
    Endif
    #-----
    If WUPDFLG=1 | WINVDTA<>0
      For GPIH_INDTAX=1 To [M:PIH4]NBTAX
        Gosub CAL_TAXE_GLOB From SUBPIHB
      Next GPIH_INDTAX
      If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]1-99 : Endif
      Gosub MAJ_STATUT From SUBPIH
    Endif
    #-----
Endcase
#-----
nolign=SVG_NOLIGN
#-----
#End
Return :#--CPO 71937 TABDEPAGIO


##################################################
# Chargement de la ligne élément remise sur taxe #
##################################################
$CHARG_DISVAT
If [F:PFI]PFINUM<>WINVDTA
  Read [PFI] PFI0=WINVDTA : If fstat  Raz [F:PFI] : Endif
Endif
Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$(WINVDTA),"") From ATEXTRA
Case WABRMSK
  When "POH3"
    [M:POH3]INVDTA   (NOL)=WINVDTA
    [M:POH3]INVDTALIB(NOL)=GBIDC3
    [M:POH3]AMTCODLIB(NOL)="%"
    [M:POH3]INVDTAVAT(NOL)=""
    [M:POH3]INVDTAAMT(NOL)=WINVDTAAMT
    [M:POH3]INVORDAMT(NOL)=0
    [M:POH3]AMTCOD   (NOL)=1
    [M:POH3]FORMAT   (NOL)=func TRTX3FNC.GETFMTREM(1)
    [M:POH3]CLCORD   (NOL)=[F:PFI]CLCORD
    [M:POH3]CLCBAS   (NOL)=[F:PFI]CLCBAS
    [M:POH3]INVDTAFLG(NOL)=1
    [M:POH3]INVLINFLG(NOL)=[F:PFI]DSPLIN
    [M:POH3]INVORDFLG(NOL)=[F:PFI]DACORD
    [M:POH3]DISVATFLG(NOL)=[F:PFI]DISVATFLG
    [M:POH3]DEBCDT   (NOL)=[F:PFI]INCDCR
    [M:POH3]DSP      (NOL)=[F:PFI]DSP
  When "POC3"
    [M:POC3]INVDTA   (NOL)=WINVDTA
    [M:POC3]INVDTALIB(NOL)=GBIDC3
    [M:POC3]AMTCODLIB(NOL)="%"
    [M:POC3]INVDTAVAT(NOL)=""
    [M:POC3]INVDTAAMT(NOL)=WINVDTAAMT
    [M:POC3]INVORDAMT(NOL)=0
    [M:POC3]AMTCOD   (NOL)=1
    [M:POC3]FORMAT   (NOL)=func TRTX3FNC.GETFMTREM(1)
    [M:POC3]CLCORD   (NOL)=[F:PFI]CLCORD
    [M:POC3]CLCBAS   (NOL)=[F:PFI]CLCBAS
    [M:POC3]INVDTAFLG(NOL)=1
    [M:POC3]INVLINFLG(NOL)=[F:PFI]DSPLIN
    [M:POC3]INVORDFLG(NOL)=[F:PFI]DACORD
    [M:POC3]DISVATFLG(NOL)=[F:PFI]DISVATFLG
    [M:POC3]DEBCDT   (NOL)=[F:PFI]INCDCR
    [M:POC3]DSP      (NOL)=[F:PFI]DSP
  When "PTH2"
    [M:PTH2]INVDTA   (NOL)=WINVDTA
    [M:PTH2]INVDTALIB(NOL)=GBIDC3
    [M:PTH2]INVDTAVAT(NOL)=""
    [M:PTH2]INVDTAAMT(NOL)=0
    [M:PTH2]INVORDAMT(NOL)=WINVDTAAMT
    [M:PTH2]CLCORD   (NOL)=[F:PFI]CLCORD
    [M:PTH2]CLCBAS   (NOL)=[F:PFI]CLCBAS
    [M:PTH2]INVDTAFLG(NOL)=1
    [M:PTH2]INVLINFLG(NOL)=[F:PFI]DSPLIN
    [M:PTH2]INVORDFLG(NOL)=[F:PFI]DACORD
    [M:PTH2]DISVATFLG(NOL)=[F:PFI]DISVATFLG
    [M:PTH2]DEBCDT   (NOL)=[F:PFI]INCDCR
    [M:PTH2]DSP      (NOL)=[F:PFI]DSP
  When "PIH4"
    [M:PIH1]INVDTA1   (NOL)=WINVDTA
    [M:PIH4]INVDTA    (NOL)=WINVDTA
    [M:PIH1]INVDTALIB1(NOL)=GBIDC3
    [M:PIH4]INVDTALIB (NOL)=GBIDC3
    [M:PIH4]INVDTAVAT (NOL)=""
    [M:PIH1]INVDTAAMT1(NOL)=0
    [M:PIH4]INVDTAAMT (NOL)=0
    [M:PIH4]INVORDAMT (NOL)=WINVDTAAMT
    [M:PIH4]CLCORD    (NOL)=[F:PFI]CLCORD
    [M:PIH4]CLCBAS    (NOL)=[F:PFI]CLCBAS
    [M:PIH1]INVDTAFLG1(NOL)=1
    [M:PIH4]INVLINFLG (NOL)=[F:PFI]DSPLIN
    [M:PIH4]INVORDFLG (NOL)=[F:PFI]DACORD
    [M:PIH4]DISVATFLG (NOL)=[F:PFI]DISVATFLG
    If [M:PIH0]PIHTYP<3
      [M:PIH1]DEBCDT1 (NOL)=[F:PFI]INCDCR
      [M:PIH4]DEBCDT  (NOL)=[F:PFI]INCDCR
    Else
      [M:PIH1]DEBCDT1 (NOL)=3-[F:PFI]INCDCR
      [M:PIH4]DEBCDT  (NOL)=3-[F:PFI]INCDCR
    Endif
    [M:PIH4]DSP       (NOL)=[F:PFI]DSP
    # Issue 83026 - 2012-06-26 by MUARN : early escompte
    [M:PIH4]DEPFLG(NOL)   =[F:PFI]DEPFLG
    [M:PIH4]INCDCR(NOL)   =[F:PFI]INCDCR
    # Issue 102698 - 2014-11-19 by MUARN : escomptes belges
    If GDEPMGTMOD= 5 : [M:PIH1]DEPRAT = WINVDTAAMT : Endif
Endcase
Return


##################################################
# Effacement de la ligne élément remise sur taxe #
##################################################
$RAZ_DISVAT
Case WABRMSK
  When "POH3"
    Raz [M:POH3]DTADISBAS(NOL),[M:POH3]DTAAMTTAX(NOL),[M:POH3]DTADEDTAX(NOL)
    For I=1 To GNBCOA
      Case I
        When  1 : Raz [M:POH3]ACC1 (NOL)
        When  2 : Raz [M:POH3]ACC2 (NOL)
        When  3 : Raz [M:POH3]ACC3 (NOL)
        When  4 : Raz [M:POH3]ACC4 (NOL)
        When  5 : Raz [M:POH3]ACC5 (NOL)
        When  6 : Raz [M:POH3]ACC6 (NOL)
        When  7 : Raz [M:POH3]ACC7 (NOL)
        When  8 : Raz [M:POH3]ACC8 (NOL)
        When  9 : Raz [M:POH3]ACC9 (NOL)
        When 10 : Raz [M:POH3]ACC10(NOL)
      Endcase
    Next I
    For I=1 To GNBDIE
      Case I
        When  1 : Raz [M:POH3]PFICCE1 (NOL)
        When  2 : Raz [M:POH3]PFICCE2 (NOL)
        When  3 : Raz [M:POH3]PFICCE3 (NOL)
        When  4 : Raz [M:POH3]PFICCE4 (NOL)
        When  5 : Raz [M:POH3]PFICCE5 (NOL)
