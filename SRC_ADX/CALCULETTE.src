#<AdxTL>@(#)8.1.5.2 $Revision$
Call CALCULETTE
End

##################################################################################################
# Pas de modélisation de la calculette pour ne pas perdre l'environnement appelant
##################################################################################################

Subprog CALCULETTE
Gosub SAUVE
Call CALCUL
Gosub RESTAURE
End

$SAUVE
Local Char    AKL_SVG(30)(1..20)
Local Char    AKL_VAR(10)(1..20)
Local Integer AKL_NBV , AKL_I
AKL_NBV = 0
AKL_NBV += 1 : AKL_VAR(AKL_NBV) = "GUSER"
AKL_NBV += 1 : AKL_VAR(AKL_NBV) = "GPROFIL"
AKL_NBV += 1 : AKL_VAR(AKL_NBV) = "GUSRACS"
AKL_NBV += 1 : AKL_VAR(AKL_NBV) = "GDEBUG"
For AKL_I=1 To AKL_NBV
 AKL_SVG(AKL_I) = num$(evalue(AKL_VAR(AKL_I)))
Next AKL_I
dbgmode = 0
Call SAVBOUT From GESECRAN
Return

$RESTAURE
For AKL_I=1 To AKL_NBV
 Case evalue("type("+AKL_VAR(AKL_I)+")")
  When 1,2,4,5,6,7,8,9
   Assign AKL_VAR(AKL_I) With val(AKL_SVG(AKL_I))
  When Default
   Assign AKL_VAR(AKL_I) With AKL_SVG(AKL_I)
 Endcase
Next AKL_I
If GDEBUG=2
 dbgmode = 1
Else
 dbgmode = 0
Endif
Call RESTBOUT From GESECRAN
Return

Subprog CALCUL
#109413
If !(dim([S]ADXORIGINALUSER)>0 & [S]ADXORIGINALUSER="admin" & adxusr="admin")
 #102739
 If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE
  Call ERREUR(mess(74,100,1)) From GESECRAN
  End
 Endif
Endif
If clalev([M:AKL]) : End : Endif
Onerrgo ERREUR
Gosub DECLARE
Gosub OUVRE_BOITE From =[L]AKL_WINPROG
Gosub INIT
While 1=1
 Gosub SAISIE_BOITE From =[L]AKL_WINPROG
 If find([L]REPONSE,GSTAESC,GSTAEND) : # Bouton Fin s'il existe ou croix
  Break
 Elsif GBROWS & [M:AKL]TXTSRV=""
  Break
 Endif
 Gosub EXEC
Wend
Gosub TERMINE
Gosub FERME_BOITE From =[L]AKL_WINPROG
End

##################################################################################################
$DECLARE
Local Integer AKL_TYP                : # Type de la variable dans la calculette
Local Integer AKL_LNGTXT             : # Nbre de caractères de la variable de saisie
Local Char    AKL_TXT(250)           : # Valeur saisie avant evalue
Local Char    AKL_FMT(50)            : # Format du résultat affiché
Local Integer AKL_I                  : # Indicateur formule/résultat
Local Char    AKL_SEP(1)             : # Séparateur décimal affiché
Local Char    AKL_FOR(250)           : # Dernière formule demandée
Local Char    AKL_RES(250)           : # Résultat du calcul
Local Char    AKL_DEFMSK(250)        : # Masques par défaut de l'appli appelante
Local Char    AKL_WINPROG(GLONADC)
Local Char    AKL_PROGRAMME(GLONADC)
Local Char    AKL_RESOLUTION(10)
Local Integer REPONSE
[L]AKL_DEFMSK = dbgstr(1)
Call NOMTRTWIN("CALCULETTE",[L]AKL_WINPROG) From MSKDIV
[L]AKL_PROGRAMME = GPROGRAMME
GPROGRAMME = ""
Return

##################################################################################################
$INIT
If [M:AKL]NBRDEC=0
 If dim([V]GCALDEC)>0
  [M:AKL]NBRDEC = GCALDEC
 Else
  [M:AKL]NBRDEC = 2
 Endif
Endif
# adxsca position 2= Séparateur décimal saisi, 3= Sép. 3 chiffres, 4= Sép. déc. affiché
[L]AKL_SEP = mid$(adxsca,4,1)
# JML 01/02/01 Bug 7806, Désormais le superviseur utilise ',' comme Sép. déc. affiché
#              Donc format$("N:26F","2.3*2") renvoi 4,6 et oui VIRGULE !
#              Et val("4,6") renvoi 4 CQFD !
#              En forçant '.' tout rentre dans l'ordre
adxsca = left$(adxsca,3)+"."+right$(adxsca,5)
[L]AKL_LNGTXT = mod(type([M:AKL]TXTSRV)-10,256)
If len([L]AKL_DEFMSK)>1
 Default Mask [L]AKL_DEFMSK
Endif
Diszo [AKL]TXTRES
If GBROWS and GFUSION<>1
 [M:AKL]TXTICO = "94" : # Pour sortir de la calculette en WEB
 Affzo [AKL]TXTICO
Endif
Return

##################################################################################################
$EXEC
[M:AKL]TXTRES=""
While [M:AKL]TXTSRV<>""
 [L]AKL_I = 0
 If [L]AKL_FOR=[M:AKL]TXTSRV
  [L]AKL_I = 2
  [M:AKL]TXTRES = [L]AKL_RES
 Endif
 If ![L]AKL_I or [L]AKL_I=2
  [L]AKL_FOR = [M:AKL]TXTSRV
  # JML 30/03/99 On tente de savoir le type de la variable si ce n'est pas une formule
  GERREUR = 0
  Onerrgo RIEN
  [L]AKL_TYP = evalue("type("+format$("KTv2:250X",[M:AKL]TXTSRV)+")")
  Onerrgo ERREUR
  dbgmode = 0
  If [L]AKL_TYP<0 or GERREUR
   [L]AKL_TYP = 0
   GERREUR    = 0
   # 12/04/99 Astuce Boppiesque, on utilise une variable non déclarée
   MA_VARIABLE_NON_DECLAREE = evalue([M:AKL]TXTSRV)
   dbgmode = 0
   If GERREUR : Break : Endif
   [L]AKL_TYP = type(MA_VARIABLE_NON_DECLAREE)
   If [L]AKL_TYP>=10 & find([L]AKL_TYP,525,526)=0 :#117539 take into account uuid and datettime
    [L]AKL_TYP = 10+len(MA_VARIABLE_NON_DECLAREE)
   Endif
  Endif
  GERREUR = 0
  [L]AKL_TXT  = [M:AKL]TXTSRV
  Case [L]AKL_TYP
   When 522 : # Blob, on ne peut rien faire ...
    [M:AKL]TXTRES = '""'
   When 523 : # Clob
    Call LIRE_CLOB([M:AKL]TXTSRV,[M:AKL]TXTRES)
   When Default
    If [L]AKL_TYP>=0 & dim(MA_VARIABLE_NON_DECLAREE)>0
     [M:AKL]TXTRES = num$(MA_VARIABLE_NON_DECLAREE)
     Kill MA_VARIABLE_NON_DECLAREE
    Else
     [M:AKL]TXTRES = num$(evalue([M:AKL]TXTSRV))
    Endif
  Endcase
  dbgmode = 0
  If GERREUR
   [M:AKL]TXTRES= ""
   [L]AKL_RES    = ""
  Else
   Case [L]AKL_TYP
    When 1
     [L]AKL_FMT = "N:3#"  : # Libellé
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 2
     [L]AKL_FMT = "N:6#"  : # Entier court (Short)
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 3
     [L]AKL_FMT = "DD2"   : # Date
     # C'est une date, y'a rien à faire circulez...
     [M:AKL]TXTRES = '['+[M:AKL]TXTRES+']'
    When 4
     [L]AKL_FMT = "N:10#" : # Entier long (Integer)
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 5
     [L]AKL_FMT = "N:9F"  : # Nbre flottant (Float Obsolète)
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 6
     [L]AKL_FMT = "N:15F" : # Nbre Double précision (Double Obsolète)
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 7,9
     If val([M:AKL]TXTRES)>10^26 or instr(1,[M:AKL]TXTRES,"e")
      [L]AKL_FMT = "K:50X" : # DCB et DCB IBM (Decimal)
     Else
      [L]AKL_FMT = "N:28F" : # DCB et DCB IBM (Decimal)
     Endif
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 8
     [L]AKL_FMT = "N:10#" : # JML 01/04/99 Var. Bas de tableau Entier long (Integer)
     [M:AKL]TXTRES = vireblc(format$([L]AKL_FMT,[M:AKL]TXTRES),2)
     [M:AKL]TXTRES = num$(arr(val([M:AKL]TXTRES),1/10^[M:AKL]NBRDEC))
    When 522,523
     # Blob , Clob
    When Default
     [L]AKL_LNGTXT = len([M:AKL]TXTRES)
     [L]AKL_FMT    = "K:"+num$([L]AKL_LNGTXT)+"X" : # Alpha
     If [L]AKL_LNGTXT>0
      [M:AKL]TXTRES = '"'+format$([L]AKL_FMT,[M:AKL]TXTRES)+'"'
     Else
      [M:AKL]TXTRES = '""' : # Pour cas de variables vide, JML 20/04/99 GREP
     Endif
   Endcase
   [L]AKL_RES = [M:AKL]TXTRES
   If ![L]AKL_I
    Call MAJHISCAL([L]AKL_FOR,[L]AKL_RES)
   Endif
  Endif
 Endif
 Break
Wend
Affzo [AKL]TXTRES
Return

##################################################################################################
Subprog MAJHISCAL(FORMULE,RESULTAT)
Value Char FORMULE, RESULTAT
Local Char    AKL_HIS(10)
Local Integer AKL_TRANS
GERREUR = 0
If clalev([F:AKL])=0 : Local File ACALCUL [AKL]  : Endif
If GERREUR : End : Endif
Call PARAMUTIL("HISTCALC",[L]AKL_HIS,"","") From SUBAUS
Read [AKL]AKL0=GUSER;1
If fstat or [F:AKL]FORMUL<>[L]FORMULE
 GOK = 1
 GERREUR = 0
 If !adxlog
  Trbegin [AKL]
   Gosub MAJCAL
  Commit
 Else
  Gosub MAJCAL
 Endif
Endif
End

$MAJCAL
# On augmente l'historique de +1
Update [AKL] Where USR=GUSER With NUM += 1
# On crée la nouvelle ligne
Raz [F:AKL]
[F:AKL]USR    = GUSER
[F:AKL]NUM    = 1
[F:AKL]FORMUL = [L]FORMULE
[F:AKL]RES    = [L]RESULTAT
Write [AKL]
If fstat
 GOK = 0 : Call FSTA("AKL") From GLOCK
Endif
Delete [AKL] Where USR=GUSER & NUM>val([L]AKL_HIS)
Return

$ERREUR
GERREUR = errn
Call ERREUR(mess(127,100,1)+"\"+errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Resume

$RIEN
GERREUR = errn
Resume

########################################
$TERMINE
#[M:AKL]TXTSRV = [L]AKL_FOR
GPROGRAMME = [L]AKL_PROGRAMME
GERREUR = 0
adxsca  = left$(adxsca,3)+[L]AKL_SEP+right$(adxsca,5)
mkstat  = 1
Return

#################################################################################################
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "FIN"          : Gosub FIN
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "VERF_TABLE"   : Gosub VERF_TABLE
Endcase
Return

########################################
# Action CALCULHIS Historique
########################################

$SEL_TABLE
GERREUR = 0
If clalev([F:AKL])=0 : Local File ACALCUL [AKL]  : Endif
If GERREUR : OK = 0 : Return : Endif
Default File [AKL]
TIT(0) = mess(3,139,1) : # Historique
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = 'vireblc(format$("KT:250X",FORMUL),2)' : TIT(NBCOL) = mess(200,133,1) : # Formule
NBCOL += 1 : COL(NBCOL) = 'RES' : TIT(NBCOL) = mess(4,139,1)  : # Résultat
NBCOL += 1 : COL(NBCOL) = 'NUM' : TIT(NBCOL) = mess(3,9016,1) : # No
CRITERE = 'USR = "'+GUSER+'"'
ORDRE = "USR;NUM"
START = "FORMUL"
Return

$VERF_TABLE
Read [AKL]AKL0=GUSER;[F:AKL]NUM
VALEUR = [F:AKL]FORMUL
mkstat = 2
Return

###################################################################
# Pour afficher la valeur d'un Clob avec la longueur du clob ()
###################################################################

Subprog LIRE_CLOB(TXTSRV,TXTRES)
Value    Char TXTSRV
Variable Char TXTRES
Local Char    CODTRT(GLONADC) , TRTSRC(GDIMFIC)
Local Integer STAT , OKTRT
CODTRT = "WMW"+num$(adxuid(1))
TRTSRC = filpath("TRT",CODTRT,"src")
Openo TRTSRC,0 Using [WCAL]
Iomode adxifs "" Using [WCAL]
Iomode adxirs chr$(10) Using [WCAL]
Iomode adxium GUTF8 Using [WCAL]
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" Using [WCAL]
Wrseq "Subprog LIRE_CLOB(TXTSRV,TXTRES)" Using [WCAL]
Wrseq "Variable Char TXTSRV, TXTRES" Using [WCAL]
Wrseq "Local Char TEXTE(250)(1..500)" Using [WCAL]
Wrseq "Local Integer I" Using [WCAL]
Wrseq "Onerrgo ERREUR" Using [WCAL]
Wrseq "Setlob TEXTE With "+format$("KTv2:250X",TXTSRV) Using [WCAL]
Wrseq "Onerrgo" Using [WCAL]
Wrseq "For I=dim(TEXTE) To 1 Step -1" Using [WCAL]
Wrseq " If TEXTE(I)<>'' : Break : Endif" Using [WCAL]
Wrseq "Next I" Using [WCAL]
Wrseq "If I=0" Using [WCAL]
Wrseq " TXTRES = '"+'""'+"'" Using [WCAL]
Wrseq "Else" Using [WCAL]
Wrseq " I = (I-1)*250+len(TEXTE(I))" Using [WCAL]
Wrseq " TXTRES = '['+num$(I)+']'-TEXTE(1)" Using [WCAL]
Wrseq "Endif" Using [WCAL]
Wrseq "End" Using [WCAL]
Wrseq "" Using [WCAL]
Wrseq "$ERREUR" Using [WCAL]
Wrseq "TEXTE = '"+'""'+"'" Using [WCAL]
Wrseq "Resume" Using [WCAL]
Openo Using [WCAL]
Call VALID("TRT",CODTRT,nomap,STAT) From VALMSKSUB
Call EXISTE_ADX("",nomap,CODTRT,OKTRT) From ORDSYS
If OKTRT>0
 Call LIRE_CLOB(TXTSRV,TXTRES) From =CODTRT
 Call EFFACE_ADX("",nomap,CODTRT,STAT) From ORDSYS
Endif
Call EFFACE(TRTSRC,STAT) From ORDSYS
End

########################################
# Action CALCULDEC Saisie décimales
########################################

$DEBUT
Local Integer O_NBRDEC
Local Mask CALCULDEC [AKD]
If [M:AKL]NBRDEC<>0
 [M:AKD]NBRDEC = [M:AKL]NBRDEC
Else
 [M:AKD]NBRDEC = 2
Endif
O_NBRDEC = [M:AKD]NBRDEC
Return

$FIN
If find(GSTATUT,GSTAEND,GSTAFIN,GSTAESC)
 [M:AKD]NBRDEC = O_NBRDEC
 [M:AKL]NBRDEC = O_NBRDEC
Elsif O_NBRDEC<>[M:AKD]NBRDEC
 [M:AKL]NBRDEC = [M:AKD]NBRDEC
Endif
Return

########################################
Subprog B4_TXTSRV(VALEUR)
Variable Char    VALEUR()
Call CLASSE_VARCAL From DEBUGGER
End

########################################
Subprog C_TXTSRV(VALEUR)
Variable Char    VALEUR()
Local Integer AI , AJ , AOK
Local Char    AFOR(255) , AABR(GLONABR) , AVAR(GLONAVA) , AMSK(GLONAMK)
If VALEUR="" & (GBROWS=0 or GFUSION=1)
 # JML 30/03/00 on prend le dernier de l'historique (Soit No 1)
 GERREUR = 0
 If clalev([F:AKL])=0 : Local File ACALCUL [AKL]  : Endif
 If GERREUR : End : Endif
 Read [AKL]AKL0=GUSER;1
 If !fstat
  VALEUR = [F:AKL]FORMUL
  [M]TXTSRV = VALEUR
  Affzo TXTSRV
 Endif
Endif
If GDEBUG<>2
 [L]AFOR = vireblc(format$("KT:250X",VALEUR),2)
 [L]AOK = 1
 If instr(1,[L]AFOR,"sigma")
  [L]AOK = 0
 Else
  Local File AMSKZON [AMZX]
  For [L]AI=1 To 25
   [L]AABR = maskabr([L]AI)
   [L]AMSK = masknam([L]AI)
   If [L]AABR<>""
    For [L]AJ=1 To evalue("clanbs(["+[L]AABR+"],1)")
     [L]AVAR = evalue("clavar(["+[L]AABR+"],"+num$([L]AJ)+")")
     If [L]AVAR<>""
      Read [AMZX]CODE=[L]AMSK;[L]AVAR
      If !fstat
       If [F:AMZX]CODACC<>""
        If instr(1,[L]AFOR,[L]AVAR)
         [L]AOK = -1 : Break
        Elsif [L]AOK<>-2
         [L]AOK = -2
        Endif
       Endif
      Endif
     Endif
    Next [L]AJ
   Endif
  Next [L]AI
  Close Local File [AMZX]
 Endif
 Case [L]AOK
  When -2
   If instr(1,[L]AFOR,"evalue")
    GMESSAGE = mess(210,126,1) : # Expression non autorisée
    mkstat = 2 : End
   Endif
  When -1
   GMESSAGE = mess(270,139,1) : # Variable non accessible
   mkstat = 2 : End
  When 0
   GMESSAGE = mess(210,126,1) : # Expression non autorisée
   mkstat = 2 : End
 Endcase
Endif
End

Subprog CL_TXTICO(VALEUR)
Variable Char    VALEUR()
mkstat = 1024+7
End

Subprog B1_TXTRES(VALEUR)
Variable Char    VALEUR()
Infbox VALEUR Titled mess(4,139,1) : # Résultat
End

Subprog IB_TXTSRV
If GDEBUG<>2
 Raz GBOUT4
Endif
End

