Call PATCH(nomap)
End

Subprog PATCH (APPLI)
Value Char    APPLI

If filinfo(filpath("FIL","GACTXSARR","fde",APPLI),0)<0 : End : Endif
If filinfo(filpath("FIL","GACTXSARRD","fde",APPLI),0)<0 : End : Endif
If filinfo(filpath("FIL","GACTXSFIE","fde",APPLI),0)<0 : End : Endif

Local File =APPLI+".GACTXSARR" [TXA], =APPLI+".GACTXSARRD" [TAD]
&        , =APPLI+".GACTXSFIE" [TXF]

Local Libelle L_PAGE

Trbegin [TXA], [TXF]
 For [TXA]TXA0
  Case [F:TXA]TXSARRCOD
   When "DGI2025A"   : L_PAGE = 1
   When "DGI2025C"   : L_PAGE = 2
   When "DGI2025D"   : L_PAGE = 3
   When "DGI2027A"   : L_PAGE = 9
   When "DGI2027B"   : L_PAGE = 10
   When "DGI2050"    : L_PAGE = 25
   When "DGI2051"    : L_PAGE = 26
   When "DGI2052"    : L_PAGE = 27
   When "DGI2053"    : L_PAGE = 28
   When "DGI205310"  : L_PAGE = 28
   When "DGI205311"  : L_PAGE = 28
   When "DGI2054A"   : L_PAGE = 29
   When "DGI2054B"   : L_PAGE = 29
   When "DGI2054BA1" : L_PAGE = 30
   When "DGI2055A"   : L_PAGE = 31
   When "DGI2055B"   : L_PAGE = 31
   When "DGI2055D"   : L_PAGE = 31
   When "DGI2056"    : L_PAGE = 32
   When "DGI205610"  : L_PAGE = 32
   When "DGI205611"  : L_PAGE = 32
   When "DGI205612"  : L_PAGE = 32
   When "DGI205613"  : L_PAGE = 32
   When "DGI205614"  : L_PAGE = 32
   When "DGI205615"  : L_PAGE = 32
   When "DGI2057A"   : L_PAGE = 33
   When "DGI2057B"   : L_PAGE = 33
   When "DGI2058A"   : L_PAGE = 34
   When "DGI2058BA"  : L_PAGE = 35
   When "DGI2058BB"  : L_PAGE = 35
   When "DGI2058BB1" : L_PAGE = 35
   When "DGI2058BB2" : L_PAGE = 35
   When "DGI2058BB3" : L_PAGE = 35
   When "DGI2058CA"  : L_PAGE = 36
   When "DGI2058CA1" : L_PAGE = 36
   When "DGI2058CB"  : L_PAGE = 36
   When "DGI2058IS"  : L_PAGE = 37
   When "DGI2059AA1" : L_PAGE = 38
   When "DGI2059AB1" : L_PAGE = 38
   When "DGI2059BA"  : L_PAGE = 39
   When "DGI2059BB"  : L_PAGE = 39
   When "DGI2059C1"  : L_PAGE = 40
   When "DGI2059C4"  : L_PAGE = 40
   When "DGI2059D1"  : L_PAGE = 41
   When "DGI2059D2A" : L_PAGE = 41
   When "DGI2059D3"  : L_PAGE = 41
   When "DGI2059E"   : L_PAGE = 42
   When "DGI2059F"   : L_PAGE = 43
   When "DGI2059F10" : L_PAGE = 43
   When "DGI2059F11" : L_PAGE = 43
   When "DGI2059G"   : L_PAGE = 44
   When "DGI2059G10" : L_PAGE = 44
   When "DGI2059H"   : L_PAGE = 45
   When "DGI2059I"   : L_PAGE = 46
   When "2065A"      : L_PAGE = 47
   When "2065C"      : L_PAGE = 47
   When "2065BIS10"  : L_PAGE = 48
   When "2065BIS11"  : L_PAGE = 48
   When "2065BISD"   : L_PAGE = 48
   When "2065BISE1"  : L_PAGE = 48
   When "2065TER10"  : L_PAGE = 49
   When "2065TER11"  : L_PAGE = 49
   When "2065TER12"  : L_PAGE = 49
   When "2065TERH"   : L_PAGE = 49
   When "2065TERI"   : L_PAGE = 49
   When "2065TERJ"   : L_PAGE = 49
   When "2065TERK"   : L_PAGE = 49
   When "2065VERSO"  : L_PAGE = 49
   When "DGI2066"    : L_PAGE = 50
   When "2067A"      : L_PAGE = 51
   When "2067A2"     : L_PAGE = 51
   When "2067B"      : L_PAGE = 51
   When "2067C"      : L_PAGE = 51
   When "ANNEXLIB2"  : L_PAGE = 52
   When "ANNEXLIB21" : L_PAGE = 52
   When "ANNEXLIB3"  : L_PAGE = 53
   When "ANNEXLIB31" : L_PAGE = 53
   When "ANNEXLIB32" : L_PAGE = 53
   When "CA17PROREC" : L_PAGE = 54
   When "CA18CHAPAY" : L_PAGE = 55
   When "CA19CHAREP" : L_PAGE = 56
   When "CA20CHAAVA" : L_PAGE = 57
   When "CA21PROAVA" : L_PAGE = 58
   When "IDENT"      : L_PAGE = 59
   When "NADDT"      : L_PAGE = 59
   When "NADFR"      : L_PAGE = 59
   When "NADHP"      : L_PAGE = 59
   When "NADIV"      : L_PAGE = 59
   When "NADMR"      : L_PAGE = 59
   When "NADMS"      : L_PAGE = 59
   When Default      : L_PAGE = 60
  Endcase
  [F:TXA]PAGE = L_PAGE : Rewrite [TXA]
  For [TAD]TAD0 Where GRUCPY=[F:TXA]GRUCPY & YEAPAR=[F:TXA]YEAPAR & TXSARRCOD=[F:TXA]TXSARRCOD
   If [F:TAD]TXSCOD<>""
    Read [TXF]TXF0=[F:TAD]GRUCPY;[F:TAD]YEAPAR;[F:TAD]TXSCOD
    If !fstat
     [F:TXF]PAGE = L_PAGE : Rewrite [TXF]
    Endif
   Endif
  Next
 Next
Commit
End

