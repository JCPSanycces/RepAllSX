$ON_FILTRE
Onevent BEFORE_INPUT Call AS_FILTRE(zc) From W1SMH1
Onevent CONTROL Call C_FILTRE(zc) From W1SMH1
Return

Subprog AS_FILTRE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]FILTRE(INDIC) = VALEUR
  Affzo FILTRE(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_FILTRE(zc) From W1SMH1
Onkey 130 Titled GBOUT2 Call B2_FILTRE(zc) From W1SMH1
Onkey 131 Titled GBOUT3 Call B3_FILTRE(zc) From W1SMH1
Gosub _AFF
End

Subprog C_FILTRE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRCONT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFRCONT"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FILTRE" : GZNUM = 11526 : Endif
Endif
Gosub _AFF
End

Subprog B1_FILTRE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"EMPLOID","EMPLOAD","EMPLOENT","EMPLOCTR","EMPLOPRO") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_FILTRE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_FILTRE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = "EMPLOID"
 PARMSK(2) = "EMPLOAD"
 PARMSK(3) = "EMPLOENT"
 PARMSK(4) = "EMPLOCTR"
 PARMSK(5) = "EMPLOPRO"
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


