Onevent AFTER_LINE Call APRES_NBRLIG From W1SMH1
Return

Subprog C_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call C_NBRLIG From SUBSMH
 If mkstat : GERR = 1 : GZONE = "NBRLIG" : GZNUM = 0 : Endif
Endif
Gosub _AFF
End

Subprog AVANT_NBRLIG
Local Decimal BASPAG
## Action STD
Call AVANT_NBRLIG From SUBSMH
If mkstat : End : Endif
Gosub _AFF
End

Subprog APRES_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call APRES_NBRLIG From SUBSMH
 If mkstat : End : Endif
Endif
Gosub _AFF
End

$ON_FLD
Onevent CONTROL Call C_FLD(zc) From W1SMH1
Onevent BEFORE_INPUT Call AS_FLD(zc) From W1SMH1
Return

Subprog AS_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(4574,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 130 Titled GBOUT2 Call B2_FLD(zc) From W1SMH1
Onkey   2 Titled GBOUTS Call S_FLD(zc) From W1SMH1
Gosub _AFF
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
If !mkstat
 ## Action STD
 Call C_FLD(VALEUR) From SUBSMH
 If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action SMHEXP
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "SMHEXP"
   PARMSK(1) = num$(nolign)
   Call TRAITE_CHAR(VALEUR,PARMSK,"","SUBSMH","GENEMPEX",4,"SPESMH") From GTRAITE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "DIC"
 PARMSK(2) = "P"
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B2_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B2_FLD(VALEUR) From SUBSMH
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

