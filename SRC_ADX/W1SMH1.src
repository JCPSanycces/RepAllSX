Call CONTSEL("ACS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
If !mkstat
 ## Action CONTACC
 Call CONTACC(VALEUR) From SUBACS
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
Endif
Gosub _AFF
End

