#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIBPRCPY                                                        #
# Manages main class EDIBPRCPY (this) class EDIBPRCPYD                        #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
      Endcase
    When "EBCD"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub EBCD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub EBCD_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"           : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "BPRNUM"
      Case [L]ARULE
        When "CONTROL"   : Gosub BPRNUM_CONTROL
        When "PROPAGATE" : Gosub BPRNUM_PROPAGATE
      Endcase
    When "CPY"
      Case [L]ARULE
        When "CONTROL"   : Gosub CPY_CONTROL
        When "PROPAGATE" : Gosub CPY_PROPAGATE
      Endcase
    When "PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
        When "CONTROL"   : Gosub PARTYP_CONTROL   #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Endcase
    When "EBCD.CATCOD"
      Case [L]ARULE
        When "INIT"      : Gosub EBCD_CATCOD_INIT
        When "CONTROL"   : Gosub EBCD_CATCOD_CONTROL
        When "PROPAGATE" : Gosub EBCD_CATCOD_PROPAGATE
      Endcase
    When "EBCD.CATTYP"
      Case [L]ARULE
        When "INIT"    : Gosub EBCD_CATTYP_INIT
      Endcase
    When "EBCD.CATACT"
      Case [L]ARULE
        When "INIT"      : Gosub EBCD_CATACT_INIT
        When "PROPAGATE" : Gosub EBCD_CATACT_PROPAGATE
      Endcase
    When "EBCD.FLOCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub EBCD_FLOCOD_CONTROL
        When "PROPAGATE" : Gosub EBCD_FLOCOD_PROPAGATE
      Endcase
    When "EBCD.FLOREL"
      Case [L]ARULE
        When "CONTROL"   : Gosub EBCD_FLOREL_CONTROL
        When "PROPAGATE" : Gosub EBCD_FLOREL_PROPAGATE
      Endcase
  Endcase
Return

#####################################################################

$BPRNUM_CONTROL
  If this.BPRNUM <> ""
#    this.BPRNUM = format$("Kv4:15B",this.BPRNUM)
    this.BPRNUM = func EDILIBA.FORMATVAL("BPRNUM", this.BPRNUM)
  Endif
Return

$BPRNUM_PROPAGATE
  this.VALID = [V]CST_ANO

  Local Integer WOK
  Local Char WBPRNAM(35)
  WOK = func EDILIBB.GET_BPRNAM(this.BPRNUM, WBPRNAM)
  this.BPRNAM = WBPRNAM
Return

###################################################################

$CPY_CONTROL
  If this.CPY <> ""
#  this.CPY = format$("Kv4:5B",this.CPY)
    this.CPY = func EDILIBA.FORMATVAL("CPY", this.CPY)
  Endif
Return

$CPY_PROPAGATE
  this.VALID = [V]CST_ANO
  this.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"CPYNAM")
Return

####################################################################

$PARCOD_PROPAGATE
  this.VALID = [V]CST_ANO
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")
  Call DELETELINES(this, "EBCD") From EDILIBA
Return

####################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_CONTROL  #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  Local Char WERR (250)
#  WERR = "Type de partenaire interdit"
  WERR = mess(216,2006,1)
  If this.PARTYP <> 2 #Controle Tiers-société
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$EBCD_CATCOD_INIT
  this.CATCOD = ""
Return

$EBCD_CATCOD_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  If this.PARCOD <> "" and this.CATCOD <> ""
    If func EDILIBA.CATEGORY_IS_AUTHORIZED(this.PARCOD, this.CATCOD, WERR) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("CATCOD",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$EBCD_CATCOD_PROPAGATE
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.CATTYP = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATTYP")
  this.CATACT = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATACT")

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif

  Local Integer I
  Local Char WERR(250)
  For I = 1 To maxtab(this.APARENT.EBCD)
    If this.APARENT.EBCD(I)<>null
&       and this.APARENT.EBCD(I).NUMLIN <> this.NUMLIN
&       and this.APARENT.EBCD(I).ASTALIN <> [V]CST_ADEL
&       and this.APARENT.EBCD(I).ASTALIN <> [V]CST_ANEWDEL
#      If this.APARENT.EBCD(I).CATTYP = this.CATTYP and this.APARENT.EBCD(I).CATACT = this.CATACT
      If this.APARENT.EBCD(I).CATTYP = this.CATTYP and this.APARENT.EBCD(I).CATACT = this.CATACT and this.APARENT.EBCD(I).CATOPE = this.CATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
        #WERR = "Category already assigned to this setup"
        WERR = mess(6,2006,1)
        ASTATUS = fmet this.ASETERROR("CATACT",WERR,[V]CST_AERROR)
        Break
      Endif
    Endif
  Next I

  this.FLOREL = ""
  this.FLOCOD = ""
Return

####################################################################

$EBCD_CATTYP_INIT
  this.CATACT = 1
Return

####################################################################

$EBCD_CATACT_INIT
  this.CATACT = 1
Return

$EBCD_CATACT_PROPAGATE
  this.FLOREL = ""
  this.FLOCOD = ""
Return

####################################################################

$EBCD_FLOCOD_CONTROL
  If this.FLOCOD <> ""
#  this.FLOCOD = format$("Kv4:20B",toupper(this.FLOCOD))
    this.FLOCOD = func EDILIBA.FORMATVAL("FLOCOD", this.FLOCOD)
  Endif
Return

$EBCD_FLOCOD_PROPAGATE
  Local Char WERR(250) : WERR = ""
  If this.FLOCOD = ""
    this.FLOREL = ""
    this.FLODES = ""
  Else
    Local Integer WFOUND_FLOCOD : WFOUND_FLOCOD = [V]CST_AFALSE
    Local Integer WFOUND_PARCOD : WFOUND_PARCOD = [V]CST_AFALSE
    Local Integer WFOUND_CATCOD : WFOUND_CATCOD = [V]CST_AFALSE
    Local Integer WFOUND_CATACT : WFOUND_CATACT = [V]CST_AFALSE
    Local Integer WFOUND_FLGACT : WFOUND_FLGACT = [V]CST_AFALSE
    Local Integer WFOUND_VALID  : WFOUND_VALID  = [V]CST_AFALSE
    If this.CATCOD = ""
      #WERR = "Category not defined" #
      WERR = mess(10,2006,1)
      ASTATUS = fmet this.ASETERROR("CATCOD",WERR,[V]CST_AERROR)
    Else
      If this.FLOCOD = ""
        #WERR = "Flow not defined"
        WERR = mess(31,2006,1)
        ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
      Else
        Local File EDIFLO [EFL]
        Filter [EFL] Where [EFL]FLOCOD = this.FLOCOD
        For [EFL]
          WFOUND_FLOCOD = [V]CST_ATRUE
          Break
        Next
        Filter [EFL]
        If WFOUND_FLOCOD = [V]CST_AFALSE
          #WERR = "Flow not found"
          WERR = mess(32,2006,1)
          ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
        Else
          Filter [EFL] Where [EFL]FLOCOD = this.FLOCOD and [EFL]PARCOD = this.PARCOD
          For [EFL]
            WFOUND_PARCOD = [V]CST_ATRUE
            Break
          Next
          Filter [EFL]
          If WFOUND_PARCOD = [V]CST_AFALSE
           #WERR = "Flow not assigned to the EDI partner" # "Le flux n'est pas associé au partenaire EDI"
            WERR = mess(30,2006,1)
            ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
          Else
            Filter [EFL] Where [EFL]FLOCOD = this.FLOCOD and [EFL]PARCOD = this.PARCOD and [EFL]CATCOD = this.CATCOD
            For [EFL]
              WFOUND_CATCOD = [V]CST_ATRUE
              Break
            Next
            Filter [EFL]
            If WFOUND_CATCOD = [V]CST_AFALSE
              #WERR = "Flow not assigned to the category" # "Le flux n'est pas associé à la catégorie"
              WERR = mess(29,2006,1)
              ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
            Else
              Filter [EFL] Where [EFL]FLOCOD = this.FLOCOD and [EFL]PARCOD = this.PARCOD and [EFL]CATCOD = this.CATCOD and [EFL]CATACT = this.CATACT
              For [EFL]
                WFOUND_CATACT = [V]CST_ATRUE
                Break
              Next
              Filter [EFL]
              If WFOUND_CATACT = [V]CST_AFALSE
                WERR = mess(190,2006,1) #"Le flux n'est pas associé à l'action"
                ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
              Else
                Filter [EFL] Where [EFL]FLOCOD = this.FLOCOD and [EFL]PARCOD = this.PARCOD and [EFL]CATCOD = this.CATCOD and [EFL]CATACT = this.CATACT and [EFL]VALID = 2
                For [EFL]
                  WFOUND_VALID = [V]CST_ATRUE
                  Break
                Next
                Filter [EFL]
                If WFOUND_VALID = [V]CST_AFALSE
                  #WERR = "Invalid flow"
                  WERR = mess(41,2006,1)
                  ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AERROR)
    #            Else
                  #: WERR = "Le flux correspond"
                Endif
              Endif
            Endif
          Endif
        Endif
        LogicClose File [EFL]
      Endif
    Endif
  Endif
Return

####################################################################

$EBCD_FLOREL_CONTROL
  If this.FLOREL <> ""
  #  this.FLOREL = format$("Kv4:5B",toupper(this.FLOREL))
    this.FLOREL = func EDILIBA.FORMATVAL("FLOREL", this.FLOREL)
  Endif

  Local Char WERR(250) : WERR = ""

  If this.CATCOD <> "" and this.FLOCOD <> "" and this.FLOREL <> ""
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = this.FLOCOD; this.FLOREL
    If fstat
      #WERR = "Nonexistent flow" # "Le flux est incorrect"
      WERR= mess(32,2006,1)
      ASTATUS = fmet this.ASETERROR("FLOREL",WERR,[V]CST_AERROR)
    Endif
    LogicClose File [EFL]
  Endif
Return

$EBCD_FLOREL_PROPAGATE
  Local Char WERR(250) : WERR = ""

  If this.CATCOD <> "" and this.FLOCOD <> "" and this.FLOREL <> ""
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = this.FLOCOD; this.FLOREL
    If !fstat
      #on verifie que le FLO+REL correspond au CATCOD+PARCOD et est valide
      If [F:EFL]CATCOD = this.CATCOD and [F:EFL]PARCOD = this.PARCOD and [F:EFL]VALID = 2
        this.FLGACT = [F:EFL]FLGACT
        this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
        If this.FLGACT = 1
          #WERR = "Inactive flow"
          WERR = mess(33,2006,1)
          ASTATUS = fmet this.ASETERROR("FLOREL",WERR,[V]CST_AWARNING)
        Endif
      Else
        this.FLGACT = 1
        this.FLODES = ""
        #WERR = "Invalid Flow"
        WERR = mess(41,2006,1)
        ASTATUS = fmet this.ASETERROR("FLOREL",WERR,[V]CST_AERROR)
      Endif
    Else
      this.FLGACT = 1
      this.FLODES = ""
      #WERR = "Nonexistent flow"
      WERR = mess(66,2006,1)
      ASTATUS = fmet this.ASETERROR("FLOREL",WERR,[V]CST_AERROR)
    Endif
    LogicClose File [EFL]
  Endif

Return

####################################################################

$EBCD_ADDLINE_BEFORE
  If this.PARCOD = ""
    #"EDI partner must be defined"
    ASTATUS = fmet this.ASETERROR("",mess(19,2006,1),[V]CST_AERROR)
  Endif
Return

####################################################################

$EBCD_ADDLINE_AFTER
  #Manage key identifiers
  this.PARTYP = this.APARENT.PARTYP
  #on ajoute une ligne
  this.NUMLIN    = 1 + max(this.APARENT.EBCD(1..maxtab(this.APARENT.EBCD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EBCD)
    If this.APARENT.EBCD(I) <> null
      If this.APARENT.EBCD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EBCD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EBCD(AFT_LINE).SORT
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EBCD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EBCD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EBCD)
        If this.APARENT.EBCD(I) <> null
          OFFSET_LINE = this.APARENT.EBCD(I).AORDER - this.AORDER
#          If this.APARENT.EBCD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EBCD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EBCD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EBCD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  this.FLGACT = 1
Return

####################################################################

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#* Goal:
#*!
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#* Goal:
#*!
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
#  #we only test that at least a line exists (even if the line is not valid)
  Local Char WERR(250)  : WERR = ""
  Local Integer WNBLINE : WNBLINE = 0
  Local Integer I

  For I = 1 To maxtab(this.EBCD())
    If this.EBCD(I)<>null and find(this.EBCD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WNBLINE = WNBLINE + 1
      Break
    Endif
  Next I

  If WNBLINE = 0
    this.VALID = [V]CST_ANO
    WERR = mess(63,2006,1) #at least one line is mandatory...
    ASTATUS = fmet this.ASETERROR("VALID",WERR,[V]CST_AWARNING)
  Else
    this.VALID = [V]CST_AYES
    #WERR = "Setup is valid"
#    WERR = mess(100,2006,1)
#    ASTATUS = fmet this.ASETERROR("VALID",WERR,[V]CST_AINFO)
  Endif

  If this.VALID = [V]CST_AYES
    ARET_VALUE = [V]CST_AOK
  Else
    ARET_VALUE = [V]CST_AERROR
  Endif
Return

