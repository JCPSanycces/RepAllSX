#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion des textes
###############################################################################
## Gestion des clobs
###############################################################################
## Subprog INI_CLOB
## Subprog RAZ_CLOB
## Subprog RANGE_CLOB(CLOB,IDENT,STAT)    : # STAT 1=plus de mémoire, 2=ident vide
## Subprog LIRE_CLOB(CLOB,IDENT,STAT)     : # STAT 1=inexistant
## Subprog VIRE_CLOB(IDENT,STAT)          : # STAT 1=inexistant
###############################################################################
Local Char PARAM(30)(1..10) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ACLOB","ACLOB","") From GSAISIE
End
GCONSDIA = 2
Call INI_CLOB
Call TRAITE_CHAR(VALEUR,PARAM,"","ACLOB","ACLOB",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

$INIT
#Call INI_CLOB
Local Integer STAT
Return

$INIT_DIA
If PARAM(3)<>"" : Gosub ACTION From=PARAM(3) : Endif
Call LIRE_CLOB([M:ACL]CLOB,PARAM(1),STAT)
[M:ACL]CLOBSVG = [M:ACL]CLOB
Return

$CONTROLE
If GHISTO : FIN = 1 : Endif
Return

$EXEC
If PARAM(3)<>"" : Gosub ACTION From=PARAM(3) : Endif
Call RANGE_CLOB([M:ACL]CLOB,PARAM(1),STAT)
If STAT=1
 Call ERREUR(mess(215,126,1)-"("+num$(GCLOMEM)-"Ko)") From GESECRAN
# Taille mémoire des textes dépassée
Endif
Return

###############################################################################
## Définition des globales
###############################################################################
Subprog INI_CLOB
Local  Char _CLOMAX(10)
Call PARAM("","CLOMAX",[L]_CLOMAX) From ADOVAL
Global Integer  GCLOMAX                                   :  : # Nb maximum de clob
If val([L]_CLOMAX)>1000
 GCLOMAX = val([L]_CLOMAX)
Else
 GCLOMAX = 1000
Endif

Global Char     GCLOIDE(17)(1..GCLOMAX)                   : # Identifiant (17caractères ?) : #  12->17  113739 CCL
Global Shortint GCLOPTR(1..GCLOMAX)                       : # Pointeur
Global Integer  GCLOLNG                 : GCLOLNG = 250   : # Longueur de rangement
Local  Char     PARAM(10)
Local  Integer  LIBRE

Call PARAM("","MEMTXT",PARAM) From ADOVAL                 : # Taille mémoire allouée en Ko
LIBRE = int((freemem/1024-5*1024))                        : # On se réserve 5 Mo pour le reste
If val(PARAM)>LIBRE : PARAM = num$(LIBRE) : Endif
If    val(PARAM)<=0    : PARAM = "256"
Elsif val(PARAM)>15999 : PARAM = "15999"
Endif

Global Integer  GCLOMEM    : GCLOMEM = val(PARAM)*1024/2
Global Integer  GCLOLIG    : GCLOLIG = min(32767,int(GCLOMEM/GCLOLNG)+1)

Global Char     GCLOTXT(GCLOLNG)(1..GCLOLIG)              : # Texte des clobs
Global Shortint GCLONXT(1..GCLOLIG)                       : # Chaînage
Global Shortint GCLONBR                                   : # Nb de clobs

End

###############################################################################
## Remise à zéro
###############################################################################
Subprog RAZ_CLOB
Raz GCLOTXT,GCLONXT,GCLOIDE,GCLOPTR,GCLONBR
End

###############################################################################
## Stockage clob
###############################################################################
Subprog RANGE_CLOB(CLOB,IDENT,STAT)
Variable Clbfile CLOB
Value    Char    IDENT
Variable Integer STAT

Local Integer I , J , K
Local Integer PTR , NPT , LIG , PLEIN , LONG , CLOTAI

LONG   = len(CLOB)
CLOTAI = int(LONG/GCLOLNG)+1

Local Char    TEXTE(GCLOLNG)(1..CLOTAI)

If IDENT=""
 STAT = 2
 End
Endif

Setlob TEXTE With CLOB
If len(TEXTE(1))=0
 STAT = 0
 End
Endif

K = find(IDENT,GCLOIDE(1..GCLONBR))
If K
 PTR = GCLOPTR(K)
Else
 PTR = find(0,GCLONXT)
 If PTR=0
  STAT = 1
  End
 Endif
 If GCLONBR<GCLOMAX
  GCLONBR += 1
  GCLOIDE(GCLONBR) = IDENT
  GCLOPTR(GCLONBR) = PTR
 Else
  STAT = 1
  End
 Endif
Endif

LIG   = 1
PLEIN = 0
While LIG<=CLOTAI & len(TEXTE(LIG))>0
 GCLOTXT(PTR) = TEXTE(LIG)
 If LIG>=CLOTAI or len(TEXTE(LIG+1))=0
  NPT = GCLONXT(PTR)
  GCLONXT(PTR) = -1
  PTR = NPT
  While PTR>0
   NPT = GCLONXT(PTR)
   GCLONXT(PTR) = 0
   PTR = NPT
  Wend
 Else
  NPT = GCLONXT(PTR)
  If NPT<=0
   GCLONXT(PTR) = -1
   NPT = find(0,GCLONXT)
   If NPT=0
    PLEIN = 1 : Break
   Endif
   GCLONXT(PTR) = NPT
  Endif
  PTR = NPT
 Endif
 LIG += 1
Wend
If PLEIN
 STAT = 1
Else
 STAT = 0
Endif
End

###############################################################################
## Lecture clob
###############################################################################
Subprog LIRE_CLOB(CLOB,IDENT,STAT)
Variable Clbfile CLOB
Value    Char    IDENT
Variable Integer STAT

Local Integer I , J , K
Local Integer PTR , LIG

Raz CLOB
K = find(IDENT,GCLOIDE(1..GCLONBR))
If K
 PTR = GCLOPTR(K)
 LIG = 0
 While PTR>0
  LIG += 1
  PTR = GCLONXT(PTR)
 Wend
 Local Char TEXTE(GCLOLNG)(1..LIG)
 PTR = GCLOPTR(K)
 LIG = 0
 While PTR>0
  LIG += 1
  TEXTE(LIG) = GCLOTXT(PTR)
  PTR = GCLONXT(PTR)
 Wend
 Setlob CLOB With TEXTE(1..LIG)
 STAT = 0
Else
 STAT = 1
 End
Endif
End

###############################################################################
## Déstockage
###############################################################################
Subprog VIRE_CLOB(IDENT,STAT)
Value    Char    IDENT
Variable Integer STAT

Local Integer I , J , K
Local Integer PTR , NPT

K = find(IDENT,GCLOIDE(1..GCLONBR))
If K
 PTR = GCLOPTR(K)
 While PTR>0
  NPT = GCLONXT(PTR)
  GCLONXT(PTR) = 0
  PTR = NPT
 Wend
 Dela K,1,GCLONBR GCLOIDE,GCLOPTR
 GCLONBR -= 1
 STAT = 0
Else
 STAT = 1
Endif
End

