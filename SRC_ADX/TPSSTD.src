#Controles des zones paramétrées comme obligatoire dans la transaction de saisie
####################################
Subprog CONTTPS (VALEUR,ZONE,TYPZO)
Value Char    VALEUR ()
Value Char    ZONE ()
Value Integer TYPZO
Read[F:STD]STD1=GFLAG;ZONE
If [F:STD]OBG=2 & ((TYPZO=1 & VALEUR="0") | (TYPZO=2 & VALEUR=""))
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
End

