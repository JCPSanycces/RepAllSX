########################################################################
# Etiquettes ecran tableau (Plage horaire)
########################################################################

#Il faut que l'evènement soit cocher "Saisie plage horaire" et mono date
####################################
Subprog AS_STRTIM(VALEUR)
Variable Char    VALEUR()
Local Integer JNUIT,INI
Local Char    CCE(GLONCCE)(1..)
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]PLGHOR<>2 | [M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 mkstat=1 : End
Endif
If VALEUR=""
 Gosub DEC_PLAGE
 Call JOUR([M]REFNUM,[M]STRDAT(NOL),TYPJOU,JOUR,HEURE,JNUIT,[M]FCY,[M]CTRNUM,[M]NUMPLG(NOL),VALEUR,
&          [M]ENDTIM(NOL),[M]BRKTIM(NOL),[M]NATCOD(NOL),CCE,INI) From SUBPLN
Endif
End

####################################
Subprog C_STRTIM(VALEUR)
Variable Char    VALEUR()
Local Integer I

If VALEUR="" | GNBHOR<=1 : End : Endif
Call CONTTPS (VALEUR,zoncou,2)
If mkstat : End : Endif

Gosub SETNOL
For I=0 To [M]NBRLIG-1
 If I<>NOL
  If [M]STRDAT(NOL)=[M]STRDAT(I) : # Même date
   If (val([M]STRTIM(I))<val([M]ENDTIM(I)) & val(VALEUR)>val([M]STRTIM(I)) & val(VALEUR)<val([M]ENDTIM(I)))
&   | (val([M]STRTIM(I))>val([M]ENDTIM(I)) & (val(VALEUR)>val([M]STRTIM(I)) | val(VALEUR)<val([M]ENDTIM(I))))
  #ADNGO - 2017-01-09 - X3-11765 - START
    #GMESSAGE = mess(126,709,1)-num$(I+1) : # Infos déjà saisie pour cette date dans la plage xx
    GMESSAGE = mess(126,10709,1)-num$(I+1) : # Infos déjà saisie pour cette date dans la plage xx
  #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat = 2 : Break
   Endif
  Endif
 Endif
Next I
If mkstat : End : Endif
End


#Il faut que l'evènement soit cocher "Saisie plage horaire" et mono date
####################################
Subprog AS_ENDTIM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]PLGHOR<>2 |[M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 mkstat=1 : End
Endif
End

####################################
Subprog C_ENDTIM(VALEUR)
Variable Char    VALEUR()
Local Integer I
Gosub SETNOL

#Pas d'heure de fin si pas d'heure de début
If VALEUR<>"" & [M]STRTIM(NOL)=""
 Raz VALEUR
Endif

If VALEUR="" | GNBHOR<=1 : End : Endif

Call CONTTPS (VALEUR,zoncou,2)
If mkstat : End : Endif

For I=0 To [M]NBRLIG-1
 If I<>NOL
  If [M]STRDAT(NOL)=[M]STRDAT(I) : # Même date
   If val(VALEUR)>val([M]STRTIM(I)) & val(VALEUR)<val([M]ENDTIM(I))
&    | ( val(VALEUR)>val([M]STRTIM(NOL)) & val(VALEUR)>val([M]STRTIM(I)) & val([M]STRTIM(NOL))<val([M]ENDTIM(I)))
&    | ( val(VALEUR)<val([M]STRTIM(NOL)) & val(VALEUR)>val([M]STRTIM(I)) & val([M]STRTIM(NOL))>val([M]ENDTIM(I)))
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(126,709,1)-num$(I+1) : # Infos déjà saisie pour cette date dans la plage xx
   GMESSAGE = mess(126,10709,1)-num$(I+1) : # Infos déjà saisie pour cette date dans la plage xx
  #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat = 2 : Break
   Endif
  Endif
 Endif
Next I
If mkstat : End : Endif
End

#Il faut que l'evènement soit cocher "Saisie plage horaire" et mono date
####################################
Subprog AS_BRKTIM(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]PLGHOR<>2 |[M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 mkstat=1 : End
Endif
End

####################################
Subprog C_BRKTIM(VALEUR)
Variable Decimal VALEUR
If VALEUR<0
 # Temps de pause incorrect
 #ADNGO - 2017-01-09 - X3-11765- START
  #GMESSAGE = mess(115,709,1)
  GMESSAGE = mess(115,10709,1)
 #ADNGO - 2017-01-09 - X3-11765- END
  mkstat = 2 : End
Endif
Call CONTTPS (num$(VALEUR),zoncou,1)
If mkstat : End : Endif
Call MAJHOU ([M]STRTIM(nolign-1),[M]ENDTIM(nolign-1),VALEUR)
End

