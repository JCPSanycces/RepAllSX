####################################
Subprog CONTCCE(VALEUR,AXE,FCY,DAT,TIM,CCE,NOL)
Variable Char VALEUR
Value Integer AXE
Value Char    FCY()
Value Date    DAT
Value Char    TIM()
Value Char    CCE    : # "[M]CCE#" par exemple, # indique zone indicée
Value Integer NOL

#Mains controls are in the action CNTCCE linked on field (i.e. Subprog SECTION() from SUPCPT)

If VALEUR="" | [L]CCE="" : End : Endif

Local Integer I, J, K
Local Char    BID([V]GLONCCE)

# SBA liens comptable
If GCOMPTA<>3
  If clalev([F:AUZ])=0 : Local File =GTABCPT+"CAAUZ" [AUZ] : Endif
  If !clalev([F:CCE2]) : Local File =GTABCPT+"CACCE" [CCE2] : Endif
Else
  If clalev([F:AUZ])=0 : Local File CAAUZ [AUZ]  : Endif
  If !clalev([F:CCE2]) : Local File CACCE [CCE2] : Endif
Endif

For I=1 To [M]NBRDIE
 If I<>AXE
  J=find([M]WDIE(I-1),[F:TIM]DIE(0..dim([F:TIP]DIE)-1))
  If J & evalue("[F:TIM]CCEDAC(J-1)")=2
   K = instr(1,[L]CCE,"#")
   If K
    BID = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(NOL)+")")
   Else
    BID = evalue([L]CCE+"("+num$(NOL)+")")
   Endif
   If BID<>"" : # Section vide => pas d'interdiction
    Read [CCE2]CCE0 = [M]WDIE(I-1) ; BID
    If !fstat
#MIPEA - 2017-02-18- X3-11609- START
      Look [AUZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
#     If GCOMPTA<>3
#      Look [AUZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
#     Else
#      Look [AUZ]AUZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
#     Endif
#MIPEA - 2017-02-18- X3-11609- START
     If !fstat
      GMESSAGE = VALEUR-mess(26,106,1)-[F:CCE2]CCE : # Interdit avec la section
      mkstat = 1 : Break
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
End

####################################
Subprog MAJHOU(DEBTIM,FINTIM,BRKTIM)
Value Char    DEBTIM, FINTIM
Value Decimal BRKTIM

Local Decimal SUMHRS, VALHMDEB, VALHMFIN
Local Integer I, J, JNUIT, OK
Local Decimal JOUR , HEURE , JPASS
Local Decimal VALHOU

## Calcul du nb d'heure = Heure fin-heure debut-temps de pause
Call CONVERTHM(DEBTIM,VALHMDEB)From SUBSTY
Call CONVERTHM(FINTIM,VALHMFIN)From SUBSTY
If VALHMFIN>=VALHMDEB
 SUMHRS = VALHMFIN-VALHMDEB
Else
 SUMHRS = 24-VALHMDEB + VALHMFIN
Endif
SUMHRS -=  BRKTIM
SUMHRS = ar2(SUMHRS)

If SUMHRS<0
 # Temps de pause incorrect
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(115,709,1)
  GMESSAGE = mess(115,10709,1)
#ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : End
Elsif SUMHRS=0 & BRKTIM<>0
#ADNGO - 2017-01-09 - X3-11765 - START
  #OK = 1 : Call AVERTIR(mess(146,709,1),OK) From GESECRAN
  OK = 1 : Call AVERTIR(mess(146,10709,1),OK) From GESECRAN
#ADNGO - 2017-01-09 - X3-11765 - END
# Temps de pause égal au temps d'activité
  If OK<>2 : mkstat = 2 : End : Endif
Endif

For I=0 To [M]NBRLIG-1
 If I<>nolign-1 & [M]STRDAT(I)=[M]STRDAT(nolign-1) & [M]ENDDAT(I)=[M]STRDAT(nolign-1) & [M]DATPYRT(nolign-1)=[M]PYRDAT
  HEURE += [M]NBRHOU(I)
  JPASS += [M]NBRDAY(I)
 Endif
Next I

For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT=[M]STRDAT(nolign-1) & ENDDAT=[M]ENDDAT(nolign-1) & DATPYR<>[M]PYRDAT
  HEURE += [F:TIP]NBRHOU
  JPASS += [F:TIP]NBRDAY
Next
HEURE+=SUMHRS

VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M]FCY))
If VALHOU>0 & HEURE>VALHOU
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU) : # Maximum d'heures par jour
 GMESSAGE = mess(4,10709,1)-":"-num$(VALHOU) : # Maximum d'heures par jour
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif

[M]NBRHOU(nolign-1)=SUMHRS


Call VALORIS([M]STRDAT(nolign-1),[M]ENDDAT(nolign-1),[M]REFNUM,[M]TIM(nolign-1),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN

If HEURE<>0
 [M]NBRDAY(nolign-1) = min(JOUR-JPASS,ar2(SUMHRS*JOUR/HEURE))
Else
 [M]NBRDAY(nolign-1) = 0
Endif

Affzo [M]NBRDAY(nolign-1)
Affzo [M]NBRHOU(nolign-1)
End

####################################
Subprog MODULATION(DATEPAYE,DATD,DATF,MATRI,CTR)
Value    Date DATEPAYE
Value    Char MATRI, CTR
Variable Date DATD, DATF
Local    Char MOIDEB(2), MOIFIN(2)
Local    Char VALPAR(10)

  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATEPAYE | (FLGRET=2 & RETDATEFF<=DATEPAYE))
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
#  If !fstat & [F:HRCTR]MODTPS=2
  If !fstat Then
    # FQ106856 - 10/03/15 - Récupération du paramètre MODTPS
    #ADNGO - 2017-01-09 - X3-11765 - START
    #If clalev([F:SIT])=0 : Local File SITEPAYE [SIT] : Endif
    #Read [F:SIT]SIT0=[F:HRCTR]ETRFCY
    #If clalev([F:HRSIT])=0 : Local File SITEPAYE [HRSIT] : Endif
    #Read [F:HRSIT]HRSIT0=[F:HRCTR]ETRFCY
    #Call PARAM([F:HRSIT]FCY,"MODTPS",VALPAR) From ADOVAL
    #ADNGO - 2017-01-09 - X3-11765 - END
    #ADNGO - 2017-02-14 - X3-11765 - START
    If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
    Call PARAM([F:FCY]FCY,"MODTPS",VALPAR) From ADOVAL
    #ADNGO - 2017-02-14 - X3-11765 - END
    If VALPAR="2" & [F:HRCTR]MODTPS=2
      Local Char FCYP(GLONFCY)
      #ADNGO - 2017-01-12 - X3-11765 - START
      #FCYP=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATEPAYE,"ETRFCY","CTR")
      FCYP=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATEPAYE,"ETRFCY","HRCTR")
      #ADNGO - 2017-01-12 - X3-11765 - END
      Call PARAM(FCYP,"MTTPERDEB",MOIDEB) From ADOVAL
      Call PARAM(FCYP,"MTTPERFIN",MOIFIN) From ADOVAL
      #JOJAC - 2017-01-06 - START
      #If num$(month(DATEPAYE))=MOIDEB : DATD = [F:PEO]PERSTR(0) : Endif : # Premier lundi du premier mois de l'année
      #If num$(month(DATEPAYE))=MOIFIN : DATF = [F:PEO]PEREND(0) : Endif : # Dernier dimanche du dernier mois de l'année
      If num$(month(DATEPAYE))=MOIDEB : DATD = [F:HRPEOD]PERSTR(0) : Endif : # Premier lundi du premier mois de l'année
      If num$(month(DATEPAYE))=MOIFIN : DATF = [F:HRPEOD]PEREND(0) : Endif : # Dernier dimanche du dernier mois de l'année
      #JOJAC - 2017-01-06 - END
#    Elsif !fstat & [F:HRCTR]MODTPS<>2
    Else
      #JOJAC - 2017-01-06 - START
      #DATD = [F:PEO]PERSTR(0)
      #DATF = [F:PEO]PEREND(0)
      DATD = [F:HRPEOD]PERSTR(0)
      DATF = [F:HRPEOD]PEREND(0)
      #JOJAC - 2017-01-06 - END
    Endif
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TPSSTD) 09/11/2009 17:51:00
######################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call SELCTR([M]REFNUM,[M]PYRDAT,[M]PYRDAT,VALEUR) From DIVPAYE
Endif
End

Subprog CONTROL_CTRDAT(MAT,CTR,CTRDAT,ENDDAT,PYRDAT,WEEKP,XITDAT)
Value    Char    MAT,CTR
Value    Date    CTRDAT,ENDDAT,PYRDAT
Value    Integer WEEKP
Variable Date    XITDAT

  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  # Contrôle existence
  Read [F:HRCTR]CTR0=[L]MAT;[L]CTR;[L]CTRDAT
  If fstat
  #ADNGO - 2017-01-09 - X3-11765 - START
    #GMESSAGE=mess(26,701,1) : # Contrat inexistant
    GMESSAGE=mess(26,10701,1) : # Contrat inexistant
  #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat=2 : End
  Else
    # Conrôle règle métier
    If  ([F:HRCTR]CTRDAT<=[L]PYRDAT | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[L]PYRDAT))
&     & ([F:HRCTR]XITDAT=[0/0/0] | [L]ENDDAT<=[F:HRCTR]XITDAT | (WEEKP=2 & [F:HRCTR]XITDAT>=[L]ENDDAT-7 & [F:HRCTR]XITDAT<=[L]ENDDAT)) Then
      [L]XITDAT=[F:HRCTR]XITDAT
    Else
    #ADNGO - 2017-01-09 - X3-11765 - START
      #GMESSAGE=mess(138,701,1) : # Contrat incompatible avec l'événement
      GMESSAGE=mess(138,10701,1) : # Contrat incompatible avec l'événement
    #ADNGO - 2017-01-09 - X3-11765 - END
      mkstat=2 : End
    Endif
  Endif
End

# Contrôle la date de début d'activité. La règle est :
#   - (La date de fin de période d'activité est vide
#   - OU La date de fin d'événement est <= à la date de fin de période d'activité)
#   - ET La date début de période d'activité est <= à la date de paie
Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
Local    Date    XITDAT

  If VALEUR=[0/0/0] Then End : Endif
  Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,VALEUR,[M]ENDDAT(nolign-1),[M]PYRDAT,1,[L]XITDAT) From TPSSTD
  If !mkstat Then
    If dim([M]SCTRDAT)>0 Then
      [M]SCTRDAT(nolign-1)=[L]XITDAT : Affzo [M]SCTRDAT(nolign-1)
    Endif
    If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
    Read [F:CTRD]CTR0=[M]REFNUM;[M]CTRNUM;VALEUR
    If !fstat & dim([M]FCYT)>0 Then
      [M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([F:CTRD]REFNUM,[F:CTRD]CTRNUM,[F:CTRD]CTRDAT,[M]PYRDAT,"ETRFCY","CTRD")
      Affzo [M]FCYT(nolign-1)
    Endif
    If !fstat & dim([M]SRVT)>0 Then
      [M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([F:CTRD]REFNUM,[F:CTRD]CTRNUM,[F:CTRD]CTRDAT,[M]PYRDAT,"ETRSRV","CTRD")
      Affzo [M]SRVT(nolign-1)
    Endif
  Endif
End


#**
#* Recherche de la période d'activité. Les règles métiers sont les suivantes :
#*    - La date de fin d'événement est comprise entre la date début et fin de contrat
#*    - Si paie décalée, c'est la dernière période d'activité active à la date de paie
#* A noter que si modif dans ce sous-pro, voir s'il faut modifier aussi CALC_CTRDATDEF2
#*
#* @param REFNUM    : Matricule
#* @param CTRNUM    : Contrat
#* @param DATFIN    : Date de référence, pour laquelle on veut connaître la date de début du contrat correspondant
#* @param PYRDAT    : Date de paie
#* @param ENDDATTPS : Date de fin de l'événement
#* @param WEEKP     :
#*    =1 : Le calcul est fait pour une saisie en mois
#*    =2 : Le calcul est fait pour une saisie en jour
#*    =3 : Le calcul est fait pour une saisie en semaine
#*!
Funprog CALC_CTRDATDEF(REFNUM,CTRNUM,DATFIN,PYRDAT,ENDDATTPS,WEEKP)
Value   Char    REFNUM,CTRNUM
Value   Date    DATFIN,PYRDAT,ENDDATTPS
Value   Integer WEEKP
Local   Date    CTRDATREF
Local   Integer OKFLGRET
Local   Char    VALPAR(2)
Local   Integer LASTMOIS

  OKFLGRET=0
  If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
  # FQ113421 - Paie décalée : se baser sur le paramètre DMA plutôt
  LASTMOIS=0
  Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM Order By CTRDAT Desc
  Read  [F:CTRD] Last
  If !fstat Then
     Call PARAM([F:CTRD]ETRFCY,"DMA",VALPAR) From ADOVAL
      If VALPAR=""
        LASTMOIS=12
      Else
        LASTMOIS=val(VALPAR)
      Endif
  Endif

  # FQ113421 - Paie décalée : se baser sur le paramètre DMA plutôt
#  If month([L]DATFIN)=month([L]PYRDAT) | WEEKP=3 Then : # Règle 1 si paie non décalée
  If LASTMOIS=12 | (LASTMOIS=0 & month([L]DATFIN)=month([L]PYRDAT)) | WEEKP=3 Then : # Règle 1 si paie non décalée
    Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & [F:CTRD]FLGRET=2
    For [F:CTRD]
# FQ98507 - 27/05/14 - Auparavant, on avait WEEKP soit =1 soit =2 dans les appels à ce sous-pro. Maintenant, on peut aussi avoir =3, d'où
# le changement de test
#&      & ([F:CTRD]XITDAT=[0/0/0] | [F:CTRD]XITDAT>=[L]ENDDATTPS | (WEEKP=2 & [F:CTRD]XITDAT>=[L]ENDDATTPS-7 & [F:CTRD]XITDAT<=[L]ENDDATTPS)) Then
      If ([L]ENDDATTPS>=[F:CTRD]CTRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]ENDDATTPS))
&      & ([F:CTRD]XITDAT=[0/0/0] | [F:CTRD]XITDAT>=[L]ENDDATTPS | (WEEKP>1 & [F:CTRD]XITDAT>=[L]ENDDATTPS-7 & [F:CTRD]XITDAT<=[L]ENDDATTPS)) Then
        [L]CTRDATREF=[F:CTRD]CTRDAT
        OKFLGRET=1
        Break
      Endif
    Next
    If !OKFLGRET
      Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM
      For [F:CTRD]
# FQ98507 - 27/05/14 - Auparavant, on avait WEEKP soit =1 soit =2 dans les appels à ce sous-pro. Maintenant, on peut aussi avoir =3, d'où
# le changement de test
#&       & ([F:CTRD]XITDAT=[0/0/0] | [F:CTRD]XITDAT>=[L]ENDDATTPS | (WEEKP=2 & [F:CTRD]XITDAT>=[L]ENDDATTPS-7 & [F:CTRD]XITDAT<=[L]ENDDATTPS)) Then
        If ([L]ENDDATTPS>=[F:CTRD]CTRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]ENDDATTPS))
&       & ([F:CTRD]XITDAT=[0/0/0] | [F:CTRD]XITDAT>=[L]ENDDATTPS | (WEEKP>1 & [F:CTRD]XITDAT>=[L]ENDDATTPS-7 & [F:CTRD]XITDAT<=[L]ENDDATTPS)) Then
          [L]CTRDATREF=[F:CTRD]CTRDAT
          Break
        Endif
      Next
    Endif
  Else : # Règle 2 si paie décalée pas de test sur rétroactivité car on lit par ordre descendant de CTRDAT
    Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM Order By CTRDAT Desc
    For [F:CTRD]
      If [F:CTRD]CTRDAT<=[L]PYRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]PYRDAT) Then
        [L]CTRDATREF=[F:CTRD]CTRDAT
        # FQ95642 - 20/01/14 - Du fait de l'affectation du temps sur le 2nd bulletin en cas de changement de période d'activité,
        # la date doit être celle du dernier contrat du mois dont la date de début est antérieure à la date de fin de l'événement.
        # D'où l'ajout du test sur ENDDATTPS
        If month([F:CTRD]CTRDAT)=month([L]DATFIN) & [F:CTRD]CTRDAT>=ENDDATTPS Then
        Else
          Break
        Endif
      Endif
    Next
  Endif
  Filter [F:CTRD]

  GPOINT = "CTRDATREF" : Gosub ENTREE From EXEFNC
End CTRDATREF

######################################################################################
# Recherche de la période d'activité. Les règles métiers sont les suivantes :
#   - La date de fin d'événement est comprise entre la date début et fin de contrat
#   - Si paie décalée, c'est la dernière période d'activité active à la date de paie
#   - Test s'il existe sur une autre période d'activité > à  [L]CTRDAT  et retourne NBCTR
Funprog CALC_CTRDATDEF2(REFNUM,CTRNUM,CTRDAT,DATFIN,PYRDAT,ENDDATTPS,NBCTR)
Value   Char  REFNUM,CTRNUM
Value   Date  CTRDAT,DATFIN,PYRDAT,ENDDATTPS
Variable Integer NBCTR
Local   Date  CTRDATREF
Local   Integer OKFLGRET
OKFLGRET=0

NBCTR=0
  If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
  If month([L]DATFIN)=month([L]PYRDAT) Then : # Règle 1 si paie non décalée
    Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT>[L]CTRDAT & [F:CTRD]FLGRET=2
    For [F:CTRD]
      NBCTR+=1
      If ([L]ENDDATTPS>=[F:CTRD]CTRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]ENDDATTPS))
&      & ([F:CTRD]XITDAT=[0/0/0] | [F:CTRD]XITDAT>=[L]ENDDATTPS) Then
        [L]CTRDATREF=[F:CTRD]CTRDAT
        OKFLGRET=1
        Break
      Endif
    Next
    If !OKFLGRET
      Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT>[L]CTRDAT
      For [F:CTRD]
        NBCTR+=1
#      If [L]STRDATTPS>=[F:CTRD]CTRDAT & [L]ENDDATTPS>=[F:CTRD]CTRDAT & ([F:CTRD]XITDAT=[0/0/0] | [L]ENDDATTPS<=[F:CTRD]XITDAT) Then
        If ([L]ENDDATTPS>=[F:CTRD]CTRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]ENDDATTPS))
&       & ([F:CTRD]XITDAT=[0/0/0] | [L]ENDDATTPS<=[F:CTRD]XITDAT) Then
          [L]CTRDATREF=[F:CTRD]CTRDAT
          Break
        Endif
      Next
    Endif
  Else : # Règle 2 si paie décalée
    Filter [CTRD] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT>[L]CTRDAT Order By CTRDAT Desc
    For [F:CTRD]
      NBCTR+=1
      If [F:CTRD]CTRDAT<=[L]PYRDAT | ([F:CTRD]FLGRET=2 & [F:CTRD]RETDATEFF<=[L]PYRDAT) Then
        [L]CTRDATREF=[F:CTRD]CTRDAT
        # FQ95642 - 20/01/14 - Du fait de l'affectation du temps sur le 2nd bulletin en cas de changement de période d'activité,
        # la date doit être celle du dernier contrat du mois dont la date de début est antérieure à la date de fin de l'événement.
        # D'où l'ajout du test sur ENDDATTPS
        If month([F:CTRD]CTRDAT)=month([L]DATFIN) & [F:CTRD]CTRDAT>=ENDDATTPS Then
        Else
          Break
        Endif
      Endif
    Next
  Endif
  Filter [F:CTRD]

  GPOINT = "CTRDATREF" : Gosub ENTREE From EXEFNC
End CTRDATREF

