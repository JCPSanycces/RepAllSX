##**92876
####################################
$D_CCE
If AXE>[M]NBRDIE : End : Endif
Local Char SAU_GSOCIETE(GLONCPY)
Local Integer ISEDITABLE

SAU_GSOCIETE=GSOCIETE
#Control if the dimension type is following by the company (site)
If [M]DSP(nolign-1)=""
 Local Integer OK
 Call CPY_AXE (AXE, [M]FCYT(nolign-1), OK) From TPSDIV
 If OK
  GSOCIETE=func DIVPAYE.GETSOC([M]FCYT(nolign-1))
  If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
  Call AXECODINICCE([M]NATCOD(nolign-1),[M]TIM(nolign-1),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
  GSOCIETE=SAU_GSOCIETE
 Endif
Endif
End

