Subprog C_CMT(VALEUR)
Variable Char    VALEUR()
Call CONTTPS (VALEUR,zoncou,2)
If len(VALEUR)<3
 Gosub SETNOL
 #ADNGO - 2017-01-09 - X3-11765 - START
 #Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
 #MIPEA - 2017-01-25- X3-12033- START
  Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
# Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
 #MIPEA - 2017-01-25- X3-12033- END
 #ADNGO - 2017-01-09 - X3-11765 - END
 If [F:TIM]CMTOBG=2
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif
Endif
End

####################################
Subprog D_TYPDAY(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]NATCOD(NOL)<>""
 Call LECT_NATCOD ([M]NATCOD(NOL)) From TPSDIV
 VALEUR=[F:NAT]TYPDAY
Else
 Case dayn([M]STRDAT(NOL))
  When 6,7     : VALEUR = 2
  When Default : VALEUR = 1
 Endcase
Endif
End

