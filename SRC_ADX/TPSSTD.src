#<AdxTL>@(#)0.0.0.0 $Revision$
##**********************************************************
#* Modifications :
#*    MABON - 23/12/10 - Calcul de la date de fin de période (DATFIN2) et de fin de mois (FMOIS2)
#*    en fonction de la date de sortie éventuelle du salarié : si sa sortie est définitive (XITFNL=2), ou
#*    si on doit solder ses événements temps (CLEEVETIM=2), on récupère sa date de sortie dans DATFIN2, et la date
#*    de fin de mois correspondant à sa sortie dans FMOIS2.
#*    Les contrôles de date se font sur ces infos.
#     SEGAY - 22/09/11 - bug 76457
#          Test du Kill sur Variable globale
#     SEGAY - 20/10/11 - bug 77201
#      Quand on vient des réguls on peut saisir plusieurs lignes avec des périodes sur plusieurs jours
#     SEGAY - 06/12/11 - bug 78174
#      BSAH : En modulation Interprêter cette saisie en allant rechercher par calcul
#      le lundi le plus proche de la date de début et le dimanche le proche de la date de fin
#     SEGAY - 28/12/11 - bug 78817
#      Lors du controle Jour ou heure, si l'évènement saisie est = GTPSW
#      à l'appel de VALORI on ne passe pas le type d'évènement à blanc
#      ce qui permet de ne pas tenir compte des jours fériés pour le calcul des heures ou des jours
#     SEGAY - 25/01/12 - bug 79703
#      Test si la période peut dépasser la taille du tableau de présence 80 jours
#     SEGAY - 13/02/12 - FQ74044 -
#      Ajout vérification du nouveau champ FILTRE sur la nature d'évènement
#     FQ93293 - 15/10/13 - Dans FMOIS2, il faut prendre le max entre la date de fin de saisie (soit PEREND(0) soit date sortie),
#      et la fin du mois (soit [PEREND(1), soit fin du mois de la date de sortie)
#     FQ85820 - 29/04/13 - prise en compte date d'effet + fiches de rétroactivité
#     FQ95144 - 16/12/13 - Recherche de la bonne période d'extraction
#     FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#     FQ106856 - 10/03/15 - Récupération du paramètre MODTPS dans la modulation
######################################################################################
#*!

GUSRAUZ(1) = "123456"
GDEFSCR=""
FONCTION = "TPSSTD"
Local Char PARAM(30)(1..3) ,  VALEUR(10)
PARAM(1) = ""
PARAM(2) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"TPSSTD","TPSSTD","",5,"XWTPSSTD") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT From TPSJOU
 When "SEL_LISTE"   : Gosub SEL_LISTE From TPSJOU
 When "FIN_LISTE"   : Gosub FIN_LISTE From TPSJOU
 When "CONTROLE"    : Gosub CONTROLE From TPSJOU
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "END"         : Gosub FIN
 When "TRN"         : FIN =1
 When "EXEC"        : If GSTATUT=GSTATRN : SAI = 1 : Endif
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "MEN"         : Gosub MENU
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SUI"         : Gosub SUI
 When "PRE"         : Gosub PRE
 When "FIR"         : Gosub FIR
 When "LAS"         : Gosub LAS
 When "TERMINE"     : Gosub KILLVARG
Endcase
Return

$KILLVARG
If dim(GEVT)>0         : Kill GEVT         : Endif
If dim(FROM_NAVIG)>0   : Kill FROM_NAVIG   : Endif
Return

#####################################################################################
# Saisie des temps
#####################################################################################

####################################
$OUVRE
Gosub OUVRE From TPSJOU
I=0 : J=0
Raz [M:TPS]

#ADNGO - 2017-01-09 - X3-11765- START
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#ADNGO - 2017-01-09 - X3-11765- END

##**92876 : We don't want to manage CCE* fields here
For [F:STD]STD0 Where COD=GFLAG & [F:STD]FRMFLD<>"" & !find(FLD,"TIM","STRDAT","ENDDAT") & left$(FLD,3)<>'CCE'
 [M]FRMFLD(I)=[F:STD]FRMFLD
 I+=1
Next
##**92876 : We want to manage them here
Gosub OUVRE_CCE
Gosub OUVRE_IJSS
Global Integer FROM_NAVIG
Return

##**92876 : CCE fields
#####################################
$OUVRE_CCE
If dim([M]NBRDIE)>=0
 Read[F:STH]STH0=GFLAG
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If ! fstat
   [M]NBRDIE=[F:CDT]NBRDIE
   For J=0 To [M]NBRDIE-1
    [M]WDIE(J)=[F:CDT]DIE(J)
    # Affiché ou saisie
    If [F:CDT]OPT(J)=2
     [M]FRMFLD(I)="KP:"
    Else
     [M]FRMFLD(I)="K:"
    Endif
    Call INICCEFMT([F:CDT]DIE(J)) From SETGLBDIE
    [M]FRMFLD(I)+=GCCEFMT
    Call LECTEXTRA([M]TITFLD(J),"GDIE","COLHEA",[F:CDT]DIE(J),"") From ATEXTRA
    I+=1
   Next
  Endif
 Endif
Endif
Return

####################################
$OUVRE_IJSS
# Appelé de TPSJOU et TPSSTDR
Global Char    GEVT(GLONTPS)(0..8)
GEVT(0) = func AFNC.PARAM("AT","")
GEVT(1) = func AFNC.PARAM("MALADIE","")
GEVT(2) = func AFNC.PARAM("MATERNITE","")
GEVT(3) = func AFNC.PARAM("ATTRAJET","")
GEVT(4) = func AFNC.PARAM("PATERNITE","")
GEVT(5) = func AFNC.PARAM("MALPROF","")
GEVT(6) = func AFNC.PARAM("PATHPREN","")
GEVT(7) = func AFNC.PARAM("PATHPOST","")
GEVT(8) = func AFNC.PARAM("ENCEINTE","")
Return

####################################
$DEBUT
Local Integer SEMAINE
Local Char    VALPAR(10)
Local Char    CRITSAL(250) , SYMBOLE(50)
Local Integer DEFILE , SAVCONS
Local Char    SOCIETE(80)
Local Integer INDCP
#LIPET - 12-12-2016 - X3-12033 - START
Local Char    LESITE(GLONFCY)
#Local Char LEPERCOD(GLONHRPEO)
#LIPET - 12-12-2016 - X3-12033 - END

SAVCONS  = GCONSULT
GCONSULT = 0
GREP = "" : REP = ""
DEFILE = 1

Gosub INIPAR
Affzo [M]5
zoncou="NBRLIG" : Gosub CHG_FMT From W1TPSSTD

Affzo 20
Return

####################################
$APRES_MODIF
Case COUZON
 When "NBRLIG"
  If GREP=""
   Gosub VERROU
   If OK
    GREP = "M" : REP = "M"
    Gosub GRISE
   Else
    GMESSAGE = mess(10,100,1) : # Modif en cours...
    GERR = 1
   Endif
  Endif
 When "PYRDAT"
  SUIZON = "NBRLIG(0)"
Endcase
Return

####################################
$VERROU
#90728
#SYMBOLE = "TPS"+format$("D:"+GFMDAT,[M]PYRDAT)+"\"+[M]REFNUM+"\"+[M]CTRNUM+format$("D:"+GFMDAT,[M]CTRDAT)
SYMBOLE = "TPS"+format$("D:"+GFMDAT,[M]PYRDAT)+"\"+[M]CTRNUM+format$("D:"+GFMDAT,[M]CTRDAT)
Lock =SYMBOLE
If fstat
 OK = 0
Else
 OK = 1
Endif
Return

####################################
$DEVERROU
If SYMBOLE<>""
 Unlock =SYMBOLE
 SYMBOLE = ""
Endif
Return

####################################
$SETBOUT
CHMEN = ""
REPORT1 = GREPORT1
REPORT2 = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Else
 CHBOU = "09ILT"
 If [M]REFNUM<>"" & [M]PYRDAT<>[0/0/0]
  CHBOU += "<>"
  CHMEN = "5"
  #JOJAC - 2017-01-06 - START
  #If [F:PEO]STA=2 | instr(1,GUSRAUZ(1),"5") | instr(1,GUSRAUZ(1),"6")
  If [F:HRPEOD]STA=2 | instr(1,GUSRAUZ(1),"5") | instr(1,GUSRAUZ(1),"6")
  #JOJAC - 2017-01-06 - END
   If GPAYE=1
    Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[M]PYRDAT & CTRNUM=[M]CTRNUM
    Read [VEP]VEP0 First
    Filter [VEP]
    If fstat | [F:VEP]PST<2
     CHMEN += "4"
    Endif
   Else
    CHMEN += "4"
   Endif
  Endif
 #LIPET - 2017-06-14 - START
 If func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
  #Tunnel vers synthèse des temps
  Look [F:TIR]TIR0=[M]REFNUM;[M]CTRNUM;[M]PYRDAT
  If !fstat :   CHMEN += "6" : Endif
 Endif
#LIPET - 2017-06-14 - END
  If instr(1,GUSRAUZ(1),"2") & GVISA=2 & left$([M]FRMFLD(20),1)<>"-": # Saisie visa
   CHMEN += "V"
  Endif
  If instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
   REPORT2 = GREPORT2
   Case DEFILE
    When 1
     CHMEN += "23"
    When 2
     CHMEN += "13"
    When 3
     CHMEN += "12"
   Endcase
  Endif
 Endif
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

####################################
$INIPAR

If PARAM(2)="" | PARAM(2)="[0/0/0]"
 VALPAR = func DIVPAYE.INIPARUSR("DATPAY","","")
Else
 VALPAR = PARAM(2)
Endif
If PARAM(1)=""  or !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Call PARAMUTIL("REFNUM",[M]REFNUM,GUSER,"") From SUBAUS
Else
 [M]REFNUM = PARAM(1)
Endif
If PARAM(1)<>"" or !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 If [M]REFNUM=""
  FIN = 1
 Else
  Read [ID]ID0 = [M]REFNUM
  If [F:ID]ENAFLG<>2 or [F:ID]FLGTPS<>2
   FIN = 1
  Endif
 Endif
 If FIN
  GERR = 2
  #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(113,709,1) : # Saisie des temps inactive
  GMESSAGE = mess(113,10709,1) : # Saisie des temps inactive
  #ADNGO - 2017-01-09 - X3-11765 - END
  Return
 Endif
 Diszo REFNUM
 DEFILE = 3
Endif

If [M]REFNUM<>""
 Read [ID]ID0 = [M]REFNUM
 Affzo REFNUM
 Call AM_REFNUM([M]REFNUM) From =PROG
 If PARAM(3)<>""
  [M]CTRNUM = PARAM(3)
  Call AM_CTRNUM([M]CTRNUM) From =PROG
 Endif

 If [F:ID]FLGMULCTR<>2 | [M]CTRNUM<>""
  LESITE = [M]FCY
  #JOJAC - 2017-01-06 - START
#  Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#  Read [PEO]PEO0 = LESITE;gdat$(VALPAR)
#  If fstat Then
#    Read [PEO]PEO0(1) = LESITES
#    If fstat<=2 & [F:PEO]PYRDAT<gdat$(VALPAR)
#      Filter [PEO] Where FCY=LESITE & PYRDAT>=gdat$(VALPAR) & STA=2
#      Read [PEO]PEO0 First
#      Filter [PEO]
#      If fstat> 2
#       Filter [PEO] Where FCY="" & PYRDAT>=gdat$(VALPAR) & STA=2
#       Read [PEO]PEO0 First
#       Filter [PEO]
#      Endif
#    Else
#      Filter [PEO] Where FCY="" & PYRDAT>=gdat$(VALPAR)
#      Read [PEO]PEO0 First
#      Filter [PEO]
#    Endif
    Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
    #ADNGO - 2017-01-09 - X3-11765 - START
    #Read [HRPEOD]HRPEOD0 = LEPERCOD;gdat$(VALPAR)
    Read [HRPEOD]HRPEOD0 = [F:HRCTR]PERCOD;gdat$(VALPAR)
    #ADNGO - 2017-01-09 - X3-11765 - END
#    If fstat Then
#      Read [PEO]PEO0(1) = LESITE
#      If fstat<=2 & [F:PEO]PYRDAT<gdat$(VALPAR)
#        Filter [PEO] Where FCY=LESITE & PYRDAT>=gdat$(VALPAR) & STA=2
#        Read [PEO]PEO0 First
#        Filter [PEO]
#        If fstat> 2
#         Filter [PEO] Where FCY="" & PYRDAT>=gdat$(VALPAR) & STA=2
#         Read [PEO]PEO0 First
#         Filter [PEO]
#        Endif
#      Else
#        Filter [PEO] Where FCY="" & PYRDAT>=gdat$(VALPAR)
#        Read [PEO]PEO0 First
#        Filter [PEO]
#      Endif
#  Endif
#JOJAC - 2017-01-06 - END
  If fstat<=2
  #JOJAC - 2017-01-06 - START
   #[M]PYRDAT = [F:PEO]PYRDAT
   [M]PYRDAT = [F:HRPEOD]PYRDAT
  #JOJAC - 2017-01-06 - END
   Call C_PYRDAT([M]PYRDAT) From =PROG
   If mkstat=0 : Call AM_PYRDAT([M]PYRDAT) From =PROG : Endif
   If mkstat=2 : Raz [M]PYRDAT : Endif :# FQ91472 US2857/58
   Affzo PYRDAT
  Endif
 Endif
Endif
Return

####################################
$GRISE
Diszo PYRDAT, REFNUM, CTRNUM
GPOINT = "GRISE" : Gosub ENTREE From EXEFNC
Return

####################################
$DEGRISE
If PARAM(1)<>"" | !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Actzo PYRDAT
 If [F:ID]FLGMULCTR=2
  Actzo CTRNUM
 Endif
Else
 Actzo PYRDAT, REFNUM
 If [F:ID]FLGMULCTR=2
  Actzo CTRNUM
 Endif
Endif
GPOINT = "DEGRISE" : Gosub ENTREE From EXEFNC
Return

####################################
$ENREGISTRE
Local Char SAUFCY(GLONFCY)
SAUFCY=[M]FCY
Call DEBTRANS From GLOCK
Gosub TR1
[M]FCY=SAUFCY
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
#ADNGO - 2017-01-09 - X3-11765 - START
#If find(mess(26,709,1), [M]CMT)>0 Then
If find(mess(26,10709,1), [M]CMT)>0 Then
#ADNGO - 2017-01-09 - X3-11765 - END
  Local Integer LOK
  #ADNGO - 2017-01-09 - X3-11765 - START
  #Call OUINON(mess(196,709,1), LOK) From GESECRAN : # Voulez-vous relancer la génération automatique des temps ?
  Call OUINON(mess(196,10709,1), LOK) From GESECRAN : # Voulez-vous relancer la génération automatique des temps ?
  #ADNGO - 2017-01-09 - X3-11765 - END
  If LOK=2 Then
    Call MAJ([M]REFNUM,[M]PYRDAT,[M]CTRNUM,1,0) From TRTREM
    # FQ91472 US2857/58 - SEGAY 02/09/14
    Gosub MAJ_TRTREM
  Endif
Endif
Gosub CHARGE
Return

####################################
$ABANDON
Gosub CHARGE
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
Return

####################################
$FIN
Gosub DEVERROU
GFONCTION = SAVFONC
Call AUTORIS From EXEFNC
GCONSULT = SAVCONS
GFLAG=""
Return

########################################
$CHARGE
Local Date    OLDDAT
Local Integer NUMERO, OKENR, I ,J
Local Date    DATEDEBT, DATEFINT
Local Char    SAUFCY(GLONFCY)

Raz [M:VT2]
Effzo 20
nolign = 0
#JOJAC - 2017-01-06 - START
#If clalev([F:PEOT])=0 : Local File PERIOD   [PEOT] : Endif
If clalev([F:HRPEODT1])=0 : Local File HRPEODET   [HRPEODT1] : Endif
#JOJAC - 2017-01-06 - END
If clalev([F:CTRT])=0 : Local File EMPLOCTR [CTRT] : Endif
If clalev([F:TIMT])=0 : Local File TIMCOD   [TIMT] : Endif

SAUFCY=[M]FCY
For [TIP]TIP4 Where REFNUM=[M]REFNUM & (DATPYR=[M]PYRDAT |(STRDAT>=[M]DATDEB & STRDAT<=[M]DATFIN2)|(ENDDAT>=[M]DATDEB & ENDDAT<=[M]DATFIN2))
&                 & CTRNUM=[M]CTRNUM
 OKENR=1
 If [F:TIP]FCY<>SAUFCY Then
 #JOJAC - 2017-01-06 - START
#   Read [F:PEOT]PEO0=[F:TIP]FCY;[M]PYRDAT
#   If fstat Then
#    Read [F:PEOT]PEO0="";[M]PYRDAT
#    If fstat Then Raz [F:PEOT] : Endif
#   Endif
#   DATDEBT = [F:PEOT]PERSTR(0)
#   DATFINT = [F:PEOT]PEREND(1)
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Read [F:HRPEODT]HRPEOD1=LEPERCOD;[M]PYRDAT
   Read [F:HRPEODT1]HRPEOD1=[F:HRCTR]PERCOD;[M]PYRDAT
   #ADNGO - 2017-01-09 - X3-11765 - END
   #If fstat Then
    #Read [F:PEOT]PEO0="";[M]PYRDAT
    If fstat Then Raz [F:HRPEODT1] : Endif
   #Endif
   DATDEBT = [F:HRPEODT1]PERSTR(0)
   DATFINT = [F:HRPEODT1]PEREND(1)
   #JOJAC - 2017-01-06 - END
   If [F:TIP]STRDAT<DATDEBT | [F:TIP]STRDAT>DATFINT | [F:TIP]ENDDAT<DATDEBT | [F:TIP]ENDDAT>DATFINT Then
    OKENR=0
   Endif
 Endif
 #ADNGO - 2017-01-17 - X3-11765 - START
 #Read [F:TIM]TIM0=[F:TIP]TIM
 Read [F:TIM]TIM0=GCURLEG;[F:TIP]TIM
 #ADNGO - 2017-01-17 - X3-11765 - END
 If !fstat Then
  If [F:TIM]MONDAC=2 & ([F:TIP]STRDAT<[M]DATDEB | [F:TIP]STRDAT>=gdat$(1,month([M]PYRDAT)+1,year([M]PYRDAT)))Then
    OKENR=0
  Endif
 Endif
 If OKENR Then
   nolign += 1
   [M] = [F:TIP]
   Gosub AM_PM
   [M]OLIG(nolign-1)   = [F:TIP]LIG
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 2017-01-09 - X3-11765 - END
   If [F:TIM]CATTIM=3
    [M]ONBRDAY(nolign-1) = [F:TIP]NBRDAY
    [M]OTIM(nolign-1)    = [F:TIP]TIM
   Else
    [M]ONBRDAY(nolign-1) = 0
    [M]OTIM(nolign-1)    = ""
   Endif
   [M]FLGMOD(nolign-1) = 0         :#ligne non encore modifiée
   If [F:TIP]STRDAT=[F:TIP]ENDDAT
    If OLDDAT<>[F:TIP]STRDAT       :#n° de plages horaire si evt mono-date
     NUMERO=1
     OLDDAT=[F:TIP]STRDAT
    Else
     NUMERO+=1
    Endif
    [M]NUMPLG(nolign-1)=NUMERO
   Endif
   Gosub CHARGE_ANA
   If [TIP]DATPYR<>[M]PYRDAT
    [M]FLGVISU(nolign-1)=-1         :#ligne en visu uniquement
   Else
    [M]FLGVISU(nolign-1)=0
   Endif
   If dim([M]SCTRDAT)>0 Then
    Read [F:CTRT]CTR0=[M]REFNUM;[M]CTRNUM;[M]CTRDAT(nolign-1)
    If !fstat Then
      [M]SCTRDAT(nolign-1)=[F:CTRT]XITDAT
    Endif
   Endif
   [M]FCYT(nolign-1)=[F:TIP]FCY
   [M]SRVT(nolign-1)=[F:TIP]SRV
   [M]DATPYRT(nolign-1)=[F:TIP]DATPYR
  Endif
Next
[M]ONBLIG = nolign
[M]NBRLIG = nolign
[M]FCY=SAUFCY

Chgstl [M]NBRLIG With ""
For nolign=1 To [M]NBRLIG
 If [M]FCYT(nolign-1)<>[M]FCY Then
  Chgstl [M]NBRLIG(nolign-1) With "PLGCUR"
  Affzo [M]NBRLIG(nolign-1)
 Endif
Next
Affzo 20
Gosub AUTORIS
Return

$AM_PM
[M]LEADAY(nolign-1)=3 : # Journée
If [F:TIP]STRDAT=[F:TIP]ENDDAT & [F:TIP]STRDAY=2 & [F:TIP]ENDDAY=1
 [M]LEADAY(nolign-1)=1 : # Matin
Endif
If [F:TIP]STRDAT=[F:TIP]ENDDAT & [F:TIP]STRDAY=1 & [F:TIP]ENDDAY=2
 [M]LEADAY(nolign-1)=2 : # AM
Endif
Return

##**92876 :  New process (V7 process)
####################################
$CHARGE_ANA
For I=1 To [M]NBRDIE
 If I>GOPTCANA : Break : Endif
 # ici on affecte pas [M]WDIE par [F:TIP]DIE car on repart des DIE issue de la transaction (CDT)
 # Par contre on cherche le bon DIE pour charger le bon CCE dans la bonne colonne
 J=find([M]WDIE(I-1),[F:TIP]DIE(0..dim([F:TIP]DIE)-1))
 If J
  If I<=27
   Assign "[M]CCE"+num$(I)+"(nolign-1)" With [F:TIP]CCE(J-1)
  Endif
 Endif
Next I

#92876_US2757
If [F:TIP]ANAFLG=1
 K = [M:VT2]PTVENT+1
 [M]PTV(nolign-1) = K
 For [TIA]TIA0 Where LIG=[F:TIP]LIG
  For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   # Par contre on cherche le bon DIE pour charger le bon CCE dans le bon champ
   #Utilisation de [M]WDIE pour pouvoir faire le lien entre les axes affichés
   #dans TPSSTD et ceux qui sont dans la table TIA
   J=find([M]WDIE(I-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If J
    Assign "[M:VT2]TBCCE"+num$(I)+"(K)" With [F:TIA]CCE(J-1)
    If [M:VT2]TBDIE(J-1)="" : [M:VT2]TBDIE(J-1)=[F:TIA]DIE(J-1) : Endif
   Endif
  Next I
  [M:VT2]TBAMT(K) = [F:TIA]NBRHOU
  K += 1
  [M:VT2]PTVENT += 1
 Next
 [M]PTF(nolign-1) = K-1
 If dim([M]DSP)>0 :[M]DSP(nolign-1) = "$" : Endif
Endif
Return

####################################
$AUTORIS
GCONSULT = 0
If GPAYE
 Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[M]PYRDAT & CTRNUM=[M]CTRNUM
 Read [VEP]VEP0 First
 Filter [VEP]
 # Saisie sur paie comptabilisée ou sur paie calculée
 If !fstat & ([F:VEP]PST>=2 | ([F:VEP]STA>=2 & !instr(1,GUSRAUZ(1),"3")))
  GCONSULT=1
 Endif
Endif
#JOJAC - 2017-01-06 - START
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6")
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6")
#JOJAC - 2017-01-06 - END
 GCONSULT = 1
Endif
Return

####################################
$DEFVARWRK
Local Integer MAXWRK : MAXWRK = 10
Local Integer LIGWRK : LIGWRK = 20
Local Integer NBWRK , IWRK , JWRK , WRKMOD
Local Char    WRK(80)
Local Char    WRKCOD(GLONTPS)(1..MAXWRK)
Local Integer WRKLIG(1..MAXWRK)
Local Char    WRKTXT(120)(1..MAXWRK,1..LIGWRK)
Return

####################################
$WORKFLOW
Call LECTURE("EML",[F:TIP]REFNUM,"") From CONTOBJ
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]WRKEVT=2
 IWRK = find([F:TIP]TIM,WRKCOD(1..NBWRK))
 If !IWRK
  If NBWRK<MAXWRK
   NBWRK += 1
   WRKCOD(NBWRK) = [F:TIP]TIM
   IWRK = NBWRK
  Else
   Return
  Endif
 Endif
 If WRKLIG(IWRK)<LIGWRK
  WRKLIG(IWRK) += 1
#ADNGO - 2017-01-09 - X3-11765 - START
#  WRKTXT(IWRK,WRKLIG(IWRK)) = WRK-mess(78,709,1)-format$("D:"+GFMDAT4,[F:TIP]STRDAT)
#&                             -mess(79,709,1)-format$("D:"+GFMDAT4,[F:TIP]ENDDAT)
#&                             -"("+num$([F:TIP]NBRDAY)-mess(81,709,1)+")"
#&                             -[F:TIP]CMT
  WRKTXT(IWRK,WRKLIG(IWRK)) = WRK-mess(78,10709,1)-format$("D:"+GFMDAT4,[F:TIP]STRDAT)
&                             -mess(79,10709,1)-format$("D:"+GFMDAT4,[F:TIP]ENDDAT)
&                             -"("+num$([F:TIP]NBRDAY)-mess(81,10709,1)+")"
&                             -[F:TIP]CMT
#ADNGO - 2017-01-09 - X3-11765 - END
# ...du...au...jours
  If GVISA=2 & [F:TIP]STAFLG<>""
  #ADNGO - 2017-01-09 - X3-11765 - START
   #WRKTXT(IWRK,WRKLIG(IWRK)) -= "-"-mess(80,709,1)-[F:TIP]STAFLG : # Visa
   WRKTXT(IWRK,WRKLIG(IWRK)) -= "-"-mess(80,10709,1)-[F:TIP]STAFLG : # Visa
  #ADNGO - 2017-01-09 - X3-11765 - END
  Endif
 Else
  Return
 Endif
Endif
Return

####################################
$TR1
GOK = 1
Gosub DEFVARWRK
Local Decimal HEURE(1..42), JOUR(1..42)
Local Date CTRDAT_VEP : # FQ91472 US2857/58 - SEGAY 02/09/14
Raz CTRDAT_VEP
NBWRK = 0
Trbegin [TIP]
 For I=0 To [M]ONBLIG-1
  If !find([M]OLIG(I),[M]LIG(0..[M]NBRLIG-1)) : # Ligne existante a été effacée
   Read [TIP]TIP0 = [M]OLIG(I)
   #ADNGO - 2017-01-09 - X3-11765 - START
   #WRK = mess(74,709,1) : Gosub WORKFLOW : # Suppression
   WRK = mess(74,10709,1) : Gosub WORKFLOW : # Suppression
   #ADNGO - 2017-01-09 - X3-11765 - END
   #Maj cp pris avant suppression
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
   Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#   Call LECTURE("HRTIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
   #ADNGO - 2017-01-09 - X3-11765 - END
   If [F:TIM]CATTIM=3
    Call SUPP_CPPRIS From TPSSTD1
    If GOK<1 : Break : Endif
   Endif
   Delete [TIP] Where LIG=[M]OLIG(I)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMEMP"-num$([M]OLIG(I)) : Break
   Endif
   Delete [TIA] Where LIG=[M]OLIG(I)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMANA"-num$([M]OLIG(I)) : Break
   Endif
   GPOINT = "WRKSUP" : Gosub ENTREE From EXEFNC
   Read[F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIP]CTRDAT
   If !fstat & GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  Endif
 Next I
 If   GOK=-1 : Goto ROLL_TR1
 Elsif !GOK  : Goto AB_TR1
 Endif
 For nolign=1 To [M]NBRLIG
  Raz HEURE,JOUR
  If [M]LIG(nolign-1)=0
   Raz [F:TIP]
   Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
   Read[F:HRCTR]CTR0 Last
   Filter [F:HRCTR]
   If !fstat
   #ADNGO - 2017-01-12 - X3-11765 - START
      #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
      #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
      [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
      [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
   #ADNGO - 2017-01-12 - X3-11765 - END
   Endif
   [F:TIP] = [M]
   Local Date MCTRDAT
   If dim([M]CTRDAT)<=0 | [M]CTRDAT(nolign-1)=[0/0/0] Then
    MCTRDAT=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
   Else
    MCTRDAT=[M]CTRDAT(nolign-1)
   Endif
   [F:TIP]CTRDAT=MCTRDAT
   If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
   If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
   If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
   # Entry point for update [F:TIP]LIG
   GPOINT = "WRKUNIQID" : Gosub ENTREE From EXEFNC
   If GOK<1 : Break : Endif
   If [F:TIP]LIG=0
     [F:TIP]LIG    = uniqid([TIP])
   Endif
   [F:TIP]DATPYR = [M]PYRDAT
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
   Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#   Call LECTURE("HRTIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
   #ADNGO - 2017-01-09 - X3-11765 - END
   If [F:TIM]CATTIM=3
    If [F:TIP]STRDAT<>[F:TIP]ENDDAT
     Call VALORDET([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
    Else
     JOUR = [F:TIP]NBRDAY
    Endif
    Call ADD_CPPRIS(JOUR) From TPSSTD1
    If GOK<1 : Break : Endif
   Endif
   Gosub ANA
   If GOK<1 : Break : Endif
   Write [TIP]
   If fstat
    GOK = 0 : Call FSTA("TIP") From GLOCK : Break
   Endif
   #ADNGO - 2017-01-09 - X3-11765 - START
   #WRK = mess(75,709,1) : Gosub WORKFLOW : # Ajout
   WRK = mess(75,10709,1) : Gosub WORKFLOW : # Ajout
   #ADNGO - 2017-01-09 - X3-11765 - END
   If  GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  Elsif [M]FLGMOD(nolign-1)
   Readlock [TIP]TIP0 = [M]LIG(nolign-1)
   If fstat=1
    GOK = -1 : GLOCK = "$TIMEMP"-num$([M]LIG(nolign-1)) : Break
   Endif
   WRKMOD = 0
   If  [F:TIP]STRDAT<>[M]STRDAT(nolign-1) or [F:TIP]ENDDAT<>[M]ENDDAT(nolign-1)
&   or [F:TIP]NBRDAY<>[M]NBRDAY(nolign-1) or [F:TIP]CMT<>[M]CMT(nolign-1)
&   or (GVISA=2 & [F:TIP]STAFLG<>[M]STAFLG(nolign-1))
    WRKMOD = 1
    #ADNGO - 2017-01-09 - X3-11765 - START
    #WRK = mess(76,709,1) : Gosub WORKFLOW : # Modif (avant)
    WRK = mess(76,10709,1) : Gosub WORKFLOW : # Modif (avant)
    #ADNGO - 2017-01-09 - X3-11765 - END
   Endif
   #On supprime l'ancienne pose de cp
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Call LECTURE("TIM",[M]OTIM(nolign-1),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
   Call LECTURE("HRTIM",[M]OTIM(nolign-1),GCURLEG) From CONTOBJ
#   Call LECTURE("HRTIM",[M]OTIM(nolign-1),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
   #ADNGO - 2017-01-09 - X3-11765 - END
   If [F:TIM]CATTIM=3
    Call SUPP_CPPRIS From TPSSTD1
    If GOK<1 : Break : Endif
   Endif
   If [F:TIP]ANAFLG=1
    Delete [TIA] Where LIG=[F:TIP]LIG
    If fstat=1
     GOK = -1 : GLOCK = "$TIMANA"-num$([F:TIP]LIG) : Break
    Endif
   Endif
   Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
   Read[F:HRCTR]CTR0 Last
   Filter [F:HRCTR]
   If !fstat
   #ADNGO - 2017-01-12 - X3-11765 - START
    #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
    #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
    [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
    [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
   #ADNGO - 2017-01-12 - X3-11765 - END
   Endif
   [F:TIP] = [M]
   If dim([F:TIP]UPDDAT)>0 : [F:TIP]UPDDAT = date$ : Endif
   If dim([F:TIP]UPDUSR)>0 : [F:TIP]UPDUSR = GUSER : Endif
   If dim([F:TIP]UPDTIM)>0 : [F:TIP]UPDTIM = time  : Endif
   [F:TIP]DATPYR = [M]PYRDAT
   #ADNGO - 2017-01-09 - X3-11765 - START
   #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
   Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#   Call LECTURE("HRTIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
   #ADNGO - 2017-01-09 - X3-11765 - END
   #On créé la nouvelle pose de cp -> donc après le transclass
   If [F:TIM]CATTIM=3
    If [F:TIP]STRDAT<>[F:TIP]ENDDAT
     Call VALORDET([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
    Else
     JOUR = [F:TIP]NBRDAY
    Endif
    Call ADD_CPPRIS(JOUR) From TPSSTD1
    If GOK<1 : Break : Endif
   Endif
   Gosub ANA
   If GOK<1 : Break : Endif
   Rewrite [TIP]
   If fstat
    GOK = 0 : Call FSTA("TIP") From GLOCK : Break
   Endif
   If WRKMOD
   #ADNGO - 2017-01-09 - X3-11765 - START
    #WRK = mess(77,709,1) : Gosub WORKFLOW : # Modif (après)
    WRK = mess(77,10709,1) : Gosub WORKFLOW : # Modif (après)
   #ADNGO - 2017-01-09 - X3-11765 - END
   Endif
   If  GOK & CTRDAT_VEP <> [F:TIP]CTRDAT : Gosub FLGVEP : Endif : # FQ91472 US2857/58 - SEGAY 02/09/14
  Endif
  GPOINT = "WRKCREMOD" : Gosub ENTREE From EXEFNC
  Next nolign
 If   GOK=-1 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Gosub MEL
Return

#En modif je décoche tous les flags de VEP
####################################
$FLGVEP
# FQ91472 US2857/58 - SEGAY 02/09/14
OK = 1
GPOINT = "MAJFLGTPS" : Gosub ENTREE From EXEFNC
If !OK
 OK = 1 : Return
Endif
If GPAYE & GOK
 Local Date    DATPAY2
 [L]DATPAY2=[M]PYRDAT
 If clalev([F:TIP])>0 & dim(CTRDAT_VEP)>0  Then
    CTRDAT_VEP=[F:TIP]CTRDAT
#MIPEA - 2017-01-25- X3-12033- START
    Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIP]CTRDAT,[F:HRCTR]XITDAT,[M]PYRDAT,[F:TIP]FCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
#    Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIP]CTRDAT,[F:HRCTR]XITDAT,[M]PYRDAT,[F:TIP]FCY,[L]DATPAY2) From TRTTPS
#MIPEA - 2017-01-25- X3-12033- END
 Endif
 Gosub FILTRE_VEP From TRTTPS
 Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[L]DATPAY2 & CTRNUM=[M]CTRNUM & evalue(CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[F:VEP]BUL
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,1,1,[0/0/0]) From SUBVEP :#Génération auto
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,2,1,[0/0/0]) From SUBVEP :#Synthèse
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,3,1,[0/0/0]) From SUBVEP :#Maj variables
   Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,4,1,[0/0/0]) From SUBVEP :#Maj analytique
   Kill GNUMBUL
Endif
Endif
Return

####################################
$MEL
If NBWRK
 For IWRK=1 To NBWRK
  Raz GWRK
  For JWRK=1 To WRKLIG(IWRK)
   GWRK(JWRK) = WRKTXT(IWRK,JWRK)
  Next JWRK
  #ADNGO - 2017-01-09 - X3-11765 - START
  #Call LECTURE("TIM",WRKCOD(IWRK),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
  Call LECTURE("HRTIM",WRKCOD(IWRK),GCURLEG) From CONTOBJ
#  Call LECTURE("HRTIM",WRKCOD(IWRK),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
  #ADNGO - 2017-01-09 - X3-11765 - START
  Call WORKFLOW(7,WRKCOD(IWRK),"","") From AWRK
 Next IWRK
Endif
Return

##**92876 :  New process (V7 process)
####################################
$ANA
If [F:TIP]DSP="$"
 [F:TIP]DSP    = ""
 [F:TIP]ANAFLG = 1
 #92876_US2757
 For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   If [F:TIP]CCE(I-1)<>"" : [F:TIP]CCE(I-1)="" : Endif
 Next
 For K=[M]PTV(nolign-1) To [M]PTF(nolign-1)
  Raz [F:TIA]
  [F:TIA]LIG    = [F:TIP]LIG
  [F:TIA]LIGANA = K+1-[M]PTV(nolign-1)
  For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
   J=find([M]WDIE(I-1),[F:TIA]DIE(0..dim([F:TIA]DIE)-1))
   If !J
    J=1
    While [F:TIA]DIE(J-1)<>"" & J<dim([F:TIA]DIE)
     J+=1
    Wend
    If [F:TIA]DIE(J-1)="" : [F:TIA]DIE(J-1)=[M]WDIE(I-1) : Endif
   Endif
   If J
    [F:TIA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
   Endif
  Next I
  [F:TIA]NBRHOU = [M:VT2]TBAMT(K)
  Write [TIA]
  If fstat
   GOK = 0 : Call FSTA("TIA") From GLOCK : Break
  Endif
 Next K
Else
 [F:TIP]ANAFLG = 0
 For I=1 To [M]NBRDIE
  If I>GOPTCANA : Break : Endif
  # Par contre on cherche le bon DIE pour sauver le bon CCE dans le bon champ
  J=find([M]WDIE(I-1),[F:TIP]DIE(0..dim([F:TIP]DIE)-1))
  If !J
   J=1
   While [F:TIP]DIE(J-1)<>"" & J<dim([F:TIP]DIE)
    J+=1
   Wend
   If [F:TIP]DIE(J-1)="" :   [F:TIP]DIE(J-1)=[M]WDIE(I-1) : Endif
  Endif
  If J
   If I<=27
    [F:TIP]CCE(J-1)= evalue("[M]CCE"+num$(I)+"(nolign-1)")
   Endif
  Endif
 Next I
Endif
Return

####################################
$AB_TR1
Rollback
Return

####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

####################################
$SUI
FROM_NAVIG=2
Case DEFILE
 When 1 : # Par matricule
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 > [M]REFNUM;[M]CTRNUM
  Goto SUIVPREC
 When 2 : # Par site/service
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 > [M]FCY;[M]SRV;[M]REFNUM;[M]CTRNUM
  Goto SUIVPREC
 When 3 : # Par date de paye
  LESITE = [M]FCY
  #JOJAC - 2017-01-06 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-01-06 - END
  Local Integer FOUND
  FOUND=1
  If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
  Filter [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT>[M]PYRDAT | (FLGRET=2 & RETDATEFF>[M]PYRDAT))
  Read [F:HRCTR2] Last
  Filter [F:HRCTR2]
  If !fstat Then
    If ([F:HRCTR2]CTRDAT>=[M]DATDEB | ([F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF>=[M]DATDEB))
      LESITE=[F:HRCTR2]ETRFCY
      Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
    Endif
  Else
    Filter [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]PYRDAT | (FLGRET=2 & RETDATEFF<=[M]PYRDAT))
    Read [F:HRCTR2] Last
    Filter [F:HRCTR2]
    If !fstat Then
      If ([F:HRCTR2]CTRDAT>=[M]DATDEB | ([F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF>=[M]DATDEB))
        LESITE=[F:HRCTR2]ETRFCY
        Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
      Endif
    Else
      For [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM<>[M]CTRNUM & (CTRDAT<=[M]PYRDAT | (FLGRET=2 & RETDATEFF<=[M]PYRDAT))
        If [F:HRCTR2]CTRDAT>[F:HRCTR]CTRDAT Then
        #JOJAC - 2017-01-06 - START
          #Filter [PEO] Where FCY=[F:HRCTR2]ETRFCY & PYRDAT>=[M]PYRDAT & STA=2
          #Read [PEO]PEO0 First
          #Filter [PEO]
          #If fstat> 2
           #Filter [PEO] Where FCY="" & PYRDAT>=[M]PYRDAT & STA=2
           #Read [PEO]PEO0 First
           #Filter [PEO]
           Filter [HRPEOD] Where PERCOD=[F:HRCTR2]PERCOD & PYRDAT>=[M]PYRDAT & STA=2
           Read [HRPEOD]HRPEOD0 First
           Filter [HRPEOD]
          #If fstat> 2
           #Filter [PEO] Where FCY="" & PYRDAT>=[M]PYRDAT & STA=2
           #Read [PEO]PEO0 First
           #Filter [PEO]
          #Endif
           #JOJAC - 2017-01-06 - END
          If ([F:HRCTR2]CTRDAT>=[M]DATDEB | ([F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF>=[M]DATDEB))
            FOUND=2
            Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
            Break
          Endif
        Endif
      Next
    Endif
  Endif
  If FOUND=2 Then
    [M]CTRNUM = [F:HRCTR]CTRNUM
    Affzo CTRNUM
    Call AM_CTRNUM([M]CTRNUM) From =PROG
  Else
    #JOJAC - 2017-01-06 - START
#    Filter [PEO] Where FCY=LESITE & PYRDAT>[M]PYRDAT
#    Read [PEO]PEO0 First
#    Filter [PEO]
#    If fstat>2
#     Filter [PEO] Where FCY="" & PYRDAT>[M]PYRDAT
#     Read [PEO]PEO0 First
#     Filter [PEO]
     #ADNGO - 2017-01-09 - X3-11765 - START
     #Filter [PEO] Where PERCOD=LEPERCOD & PYRDAT>[M]PYRDAT
     Filter [PEO] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>[M]PYRDAT
     #Read [PEO]PEO0 First
     Read [HRPEOD]HRPEOD0 First
     Filter [HRPEOD]
     #ADNGO - 2017-01-09 - X3-11765 - END
#    If fstat>2
#     Filter [PEO] Where FCY="" & PYRDAT>[M]PYRDAT
#     Read [PEO]PEO0 First
#     Filter [PEO]
#    Endif
#JOJAC - 2017-01-06 - END
#ADNGO - 2017-01-09 - X3-11765 - START
    #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
    [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
#ADNGO - 2017-01-09 - X3-11765 - END
    [M]CTRNUM=[F:HRCTR]CTRNUM
    Affzo [M]FCY,CTRNUM
    Goto SUIVPREC
  Endif
Endcase
Return

####################################
$PRE
FROM_NAVIG=2
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 < [M]REFNUM;[M]CTRNUM
  Goto SUIVPREC
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 < [M]FCY;[M]SRV;[M]REFNUM;[M]CTRNUM
  Goto SUIVPREC
 When 3
  LESITE = [M]FCY
  #JOJAC - 2017-06-06 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #JOJAC - 2017-06-06 - END
  Local Integer FOUND
  FOUND=1
  If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
  Filter [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]PYRDAT | (FLGRET=2 & RETDATEFF<=[M]PYRDAT))
  Read [F:HRCTR2] Last
  Filter [F:HRCTR2]
  If !fstat Then
    #JOJAC - 2017-01-06 - START
    #If ([F:HRCTR2]XITDAT=[0/0/0] | [F:HRCTR2]XITDAT>[F:PEO]PERSTR(0))
    If ([F:HRCTR2]XITDAT=[0/0/0] | [F:HRCTR2]XITDAT>[F:HRPEOD]PERSTR(0))
    #JOJAC - 2017-01-06 - END
      LESITE=[F:HRCTR2]ETRFCY
      Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
    Endif
  Else
    Filter [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]PYRDAT | (FLGRET=2 & RETDATEFF<=[M]PYRDAT))
    Read [F:HRCTR2] Last
    Filter [F:HRCTR2]
    If !fstat Then
    #JOJAC - 2017-01-06 - START
      #If ([F:HRCTR2]XITDAT=[0/0/0] | [F:HRCTR2]XITDAT>[F:PEO]PERSTR(0))
      If ([F:HRCTR2]XITDAT=[0/0/0] | [F:HRCTR2]XITDAT>[F:HRPEOD]PERSTR(0))
    #JOJAC - 2017-01-06 - END
        LESITE=[F:HRCTR2]ETRFCY
        Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
      Endif
    Else
      For [F:HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM<>[M]CTRNUM & (CTRDAT<=[M]PYRDAT | (FLGRET=2 & RETDATEFF<=[M]PYRDAT))
      #JOJAC - 2017-01-06 - START
        #Filter [PEO] Where FCY=[F:HRCTR2]ETRFCY & PYRDAT>=[M]PYRDAT & STA=2
        #Read [PEO]PEO0 First
        #Filter [PEO]
        #If fstat> 2
         #Filter [PEO] Where FCY="" & PYRDAT>=[M]PYRDAT & STA=2
         #Read [PEO]PEO0 First
         #Filter [PEO]
        #Endif
        Filter [HRPEOD] Where PERCOD=[F:HRCTR2]PERCOD & PYRDAT>=[M]PYRDAT & STA=2
        Read [HRPEOD]HRPEOD0 First
        Filter [HRPEOD]
        #JOJAC - 2017-01-06 - END
        #JOJAC - 2017-01-06 - START
        #If [F:HRCTR2]XITDAT>[F:PEO]PERSTR(0) Then
        If [F:HRCTR2]XITDAT>[F:HRPEOD]PERSTR(0) Then
        #JOJAC - 2017-01-06 - END
          FOUND=2
          Read [F:HRCTR]CTR0=[F:HRCTR2]REFNUM;[F:HRCTR2]CTRNUM;[F:HRCTR2]CTRDAT
          Break
        Endif
      Next
    Endif
  Endif
  If FOUND=2 Then
    [M]CTRNUM = [F:HRCTR]CTRNUM
    Affzo [M]CTRNUM
    Call AM_CTRNUM([M]CTRNUM) From =PROG
  Else
    #JOJAC - 2017-01-06 - START
#    Filter [PEO] Where FCY=LESITE & PYRDAT<[M]PYRDAT
#    Read [PEO]PEO0 Last
#    Filter [PEO]
#    If fstat>2
#     Filter [PEO] Where FCY="" & PYRDAT<[M]PYRDAT
#     Read [PEO]PEO0 Last
#     Filter [PEO]
#    Endif
    #ADNGO - 2017-01-09 - X3-11765 - START
    #Filter [HRPEOD] Where PERCOD=LEPERCOD & PYRDAT<[M]PYRDAT
    Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT<[M]PYRDAT
    #ADNGO - 2017-01-09 - X3-11765 - END
    Read [HRPEOD]HRPEOD0 Last
    Filter [HRPEOD]
    #JOJAC - 2017-01-06 - END
    #ADNGO - 2017-01-12 - X3-11765 - START
    #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
    [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
    #ADNGO - 2017-01-12 - X3-11765 - END
    [M]CTRNUM=[F:HRCTR]CTRNUM
    Affzo [M]FCY,CTRNUM
    Goto SUIVPREC
  Endif
Endcase
Return

####################################
$FIR
Local Date DATREF
DATREF=GMOIPAY
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 First
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 First
 When 3
  LESITE = [M]FCY
  #JOJAC - 2017-01-06 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
  #Filter [PEO] Where FCY=LESITE & PYRDAT<DATREF
  #Read [PEO]PEO0 First
  #Filter [PEO]
  #If fstat
  # Filter [PEO] Where FCY="" & PYRDAT<DATREF
  # Read [PEO]PEO0 First
  # Filter [PEO]
  #Endif
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #ADNGO - 2017-01-09 - X3-11765 - START
  #Filter [HRPEOD] Where PERCOD=LEPERCOD & PYRDAT<DATREF
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT<DATREF
  #ADNGO - 2017-01-09 - X3-11765 - END
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
#JOJAC - 2017-01-06 - END
Endcase
Goto SUIVPREC

####################################
$LAS
Local Date DATREF
DATREF=GMOIPAY
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 Last
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 Last
 When 3
  LESITE = [M]FCY
  #JOJAC - 2017-01-06 - START
  #Call PERIO(LESITE,[M]REFNUM) From SUBPEO
  #Filter [PEO] Where FCY=LESITE & PYRDAT>DATREF
  #Read [PEO]PEO0 Last
  #Filter [PEO]
  #If fstat
  # Filter [PEO] Where FCY="" & PYRDAT>=DATREF
  # Read [PEO]PEO0 Last
  # Filter [PEO]
  #Endif
  Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
  #ADNGO - 2017-01-09 - X3-11765 - START
  #Filter [HRPEOD] Where PERCOD=LEPERCOD & PYRDAT>DATREF
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>DATREF
  #ADNGO - 2017-01-09 - X3-11765 - END
  Read [HRPEOD]HRPEOD0 Last
  Filter [HRPEOD]

Endcase
Goto SUIVPREC

####################################
$SUIVPREC
If fstat<=2
 If DEFILE<3
  [M]REFNUM = [F:ID]REFNUM
  [M]CTRNUM = [F:ECT]CTRNUM
  [M]NAM    = [F:ID]NAM-[F:ID]SRN
  [M]FCY    = [F:ECT]FCY
  [M]SRV    = [F:ECT]SRV
  If [F:ID]FLGMULCTR<>2
   Diszo CTRNUM
  Else
   Actzo CTRNUM
  Endif
  Affzo REFNUM, CTRNUM, NAM, FCY, SRV
  Call AM_CTRNUM([M]CTRNUM) From =PROG
 Else
 #JOJAC - 2017-01-06 - START
  #If [F:PEO]FCY<>"" & [F:PEO]FCY<>LESITE
  #ADNGO - 2017-01-09 - X3-11765 - START
  #If [F:PEO]PERCOD <> LEPERCOD
  If [F:HRPEOD]PERCOD <> [F:HRCTR]PERCOD
  #ADNGO - 2017-01-09 - X3-11765 - END
 #JOJAC - 2017-01-06 - END
   # Début/Fin de fichier
   GMESSAGE = mess(11,100,1)
   GERR = 1 : Return
  Endif
  #JOJAC - 2017-01-06 - START
  #[M]PYRDAT = [F:PEO]PYRDAT
  [M]PYRDAT = [F:HRPEOD]PYRDAT
  #JOJAC - 2017-01-06 - END
  Call C_PYRDAT([M]PYRDAT) From =PROG
  If mkstat=0 : Call AM_PYRDAT([M]PYRDAT) From =PROG : Endif
  Affzo PYRDAT
 Endif
Else
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1)
 GERR = 1 : Return
Endif
Gosub AUTORIS
Return

####################################
$BOUTON
Case BOUT
 When "V"
 #ADNGO - 2017-01-09 - X3-11765 - START
  #OK = 2 : Call OUINON(mess(27,709,1),OK) From GESECRAN : # Confirmation du visa
  OK = 2 : Call OUINON(mess(27,10709,1),OK) From GESECRAN : # Confirmation du visa
 #ADNGO - 2017-01-09 - X3-11765 - END
  If OK=2
   Call DEBTRANS From GLOCK
   Gosub TR2
   If GOK=1
    Gosub CHARGE
   Endif
  Endif
Endcase
Return

####################################
$MENU
Case BOUT
 When "1"
  DEFILE = 1
 When "2"
  DEFILE = 2
 When "3"
  DEFILE = 3
 When "4"
  Call MAJ([M]REFNUM,[M]PYRDAT,[M]CTRNUM,0,0) From TRTREM
  # FQ91472 US2857/58 - SEGAY 02/09/14
  Gosub MAJ_TRTREM
  Gosub CHARGE
Endcase
Return

# FQ91472 US2857/58 - SEGAY 02/09/14
$MAJ_TRTREM
Local Date CTRDAT_VEP
Local Date DATPAY2
Raz CTRDAT_VEP
If !GPAYE : Return : Endif
If clalev([F:TIPW])=0  : Local File TIMEMP    [TIPW]  : Endif
If dim(GNUMBUL)<0 Then Global Char GNUMBUL (GLONVCR) : Endif
For [TIPW]TIP4 Where REFNUM=[M]REFNUM & (DATPYR=[M]PYRDAT |(STRDAT>=[M]DATDEB & STRDAT<=[M]DATFIN2)|(ENDDAT>=[M]DATDEB & ENDDAT<=[M]DATFIN2))
&                 & CTRNUM=[M]CTRNUM
  Read[F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIPW]CTRDAT
  If !fstat & CTRDAT_VEP <> [F:TIPW]CTRDAT
     CTRDAT_VEP=[F:TIPW]CTRDAT
     [L]DATPAY2=[M]PYRDAT
#MIPEA - 2017-01-25- X3-12033- START
     Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIPW]CTRDAT,[F:HRCTR]XITDAT,[M]PYRDAT,[F:HRCTR]ETRFCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
#     Call TPSDATPAY([M]REFNUM,[M]CTRNUM,[F:TIPW]CTRDAT,[F:HRCTR]XITDAT,[M]PYRDAT,[F:HRCTR]ETRFCY,[L]DATPAY2) From TRTTPS
#MIPEA - 2017-01-25- X3-12033- END
     Raz GNUMBUL
     If [L]DATPAY2<>[M]PYRDAT
       Gosub FILTRE_VEP From TRTTPS
       Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[L]DATPAY2 & CTRNUM=[M]CTRNUM & evalue(CRITVEP)
       Read [VEP]VEP0 Last
       Filter [VEP]
       If !fstat & [F:VEP]FLGGEN <> 2 & [F:VEP]FLGLOCK<>2
        GNUMBUL=[F:VEP]BUL
        Call MAJFLGTPS ([M]REFNUM,[L]DATPAY2,[M]CTRNUM,1,2,[0/0/0]) From SUBVEP
       Endif
     Endif
  Endif
Next
If dim(GNUMBUL)>0 Then Kill GNUMBUL : Endif
Return
####################################
$TR2
GOK = 1
Trbegin [TIP]
 Update [TIP] Where REFNUM=[M]REFNUM & DATPYR=[M]PYRDAT & CTRNUM=[M]CTRNUM With STAFLG=GUSER
 If fstat
  GOK = 0 : Call RSTA("TIP",[M]REFNUM) From GLOCK : Goto AB_TR2
 Endif
Commit
Return

####################################
$AB_TR2
Rollback
Return

########################################################################
# Etiquettes ecran d'entête
########################################################################

########################################
Subprog C_PYRDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - 2017-01-09 - X3-11765 - START
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
#ADNGO - 2017-01-09 - X3-11765 - END
# FQ104783 - 12/12/14
#ADNGO - 2017-01-09 - X3-11765 - START
#If dim([M]DATDEB) > 0 & [M]DATDEB <= [0/0/0] & mkstat = 3 : GMESSAGE = mess(12,709,1):  mkstat=2 : Endif
If dim([M]DATDEB) > 0 & [M]DATDEB <= [0/0/0] & mkstat = 3 : GMESSAGE = mess(12,10709,1):  mkstat=2 : Endif
#ADNGO - 2017-01-09 - X3-11765 - END
If mkstat : End : Endif
If [F:ID]FLGMULCTR=2
#JOJAC - 2017-01-06 - START
# Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[F:PEO]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:PEO]PEREND(1)))
#&                   & (XITDAT=[0/0/0] | XITDAT>=[F:PEO]PERSTR(0))
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[F:HRPEOD]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:HRPEOD]PEREND(1)))
&                   & (XITDAT=[0/0/0] | XITDAT>=[F:HRPEOD]PERSTR(0))
#JOJAC - 2017-01-06 - END
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  #Contrat non valide à cette date
  #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(12,715,1)
  GMESSAGE = mess(12,10715,1)
  #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : GERR = 1 : End
 Endif
Endif
If GPAYE & !instr(1,GUSRAUZ(1),"3") : # Saisie sur paye calculée
 Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=VALEUR & CTRNUM=[M]CTRNUM
 Read [VEP]VEP0 First
 Filter [VEP]
 If !fstat & [F:VEP]STA>=2
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(15,709,1) : # Paye déjà calculée
  GMESSAGE = mess(15,10709,1) : # Paye déjà calculée
 #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : GERR = 1 : End
 Endif
Endif
End

####################################
Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
Local Integer SEMAINE , NOL
Local Date    DAT , DATDEB , DATFIN
#JOJAC - 2017-01-06 - START
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur période fermée
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur période fermée
#JOJAC - 2017-01-06 - END
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(58,709,1) : # Période non ouverte à la saisie
 GMESSAGE = mess(58,10709,1) : # Période non ouverte à la saisie
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : GERR = 1 : End
Else
 If (([F:ID]FLGMULCTR<>2 & [M]CTRNUM="") | [F:ID]FLGMULCTR=2)  & FROM_NAVIG<>2
  If [M]CTRNUM<>""
  #JOJAC - 2017-01-06 - START
  # Filter [HRCTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:PEO]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:PEO]PEREND(1))) & CTRNUM=[M]CTRNUM
  #Else
   #Filter [HRCTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:PEO]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:PEO]PEREND(1)))
   Filter [HRCTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:HRPEOD]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:HRPEOD]PEREND(1))) & CTRNUM=[M]CTRNUM
  Else
   Filter [HRCTR] Where REFNUM=[M]REFNUM & (CTRDAT<=[F:HRPEOD]PEREND(1) | (FLGRET=2 & RETDATEFF<=[F:HRPEOD]PEREND(1)))
  #JOJAC - 2017-01-06 - END
  Endif
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
  #ADNGO - 2017-01-12 - X3-11765 - START
   #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,VALEUR,"ETRFCY","CTR")
   [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,VALEUR,"ETRFCY","HRCTR")
  #ADNGO - 2017-01-12 - X3-11765 - END
   [M]CTRNUM = [F:HRCTR]CTRNUM
   Affzo [M]FCY,CTRNUM
   #ADNGO - 2017-01-09 - X3-11765- START
   #Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
   Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
   #ADNGO - 2017-01-09 - X3-11765- END
  Endif
 Endif
 #JOJAC - 2017-01-06 - START
 #[M]DATDEB = [F:PEO]PERSTR(0)
 #[M]DATFIN = [F:PEO]PEREND(0)
 [M]DATDEB = [F:HRPEOD]PERSTR(0)
 [M]DATFIN = [F:HRPEOD]PEREND(0)
 #JOJAC - 2017-01-06 - END
 Call MODULATION(VALEUR,[M]DATDEB,[M]DATFIN,[M]REFNUM,[M]CTRNUM)
 #JOJAC - 2017-01-06 - START
 #[M]FMOIS  = [F:PEO]PEREND(1)
 [M]FMOIS  = [F:HRPEOD]PEREND(1)
 #JOJAC - 2017-01-06 - END
 Affzo DATDEB,DATFIN,FMOIS
 Local    Integer EXITSAL
 [M]DATFIN2 = [M]DATFIN
 [M]FMOIS2  = [M]FMOIS
 # FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
 #ADNGO - 2017-01-20 - X3-11765- START
 #Call CALC_DATEND([M]FCY, VALEUR, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, [M]DATDEB, [M]DATFIN2, [M]FMOIS2, EXITSAL) From TRTTPS
 Call CALC_DATEND([M]FCY, VALEUR, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, [M]DATDEB, [M]DATFIN2, [M]FMOIS2, EXITSAL,[F:HRCTR]PERCOD) From TRTTPS
 #ADNGO - 2017-01-20 - X3-11765- END
 [M]FMOIS2=max([M]DATFIN2, [M]FMOIS2)
 Affzo [M]DATFIN2
 If [M]REFNUM<>""
  [M]PYRDAT = VALEUR
  If FROM_NAVIG<>2 Then
    Gosub PRESENCE
  Endif
  Gosub CHARGE
 Endif
 [M]PYRDAT = VALEUR
 FROM_NAVIG=1
 GPOINT = "AM_PYRDAT" : Gosub ENTREE From EXEFNC
Endif
End

####################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

Read [ID]ID0 = VALEUR
[M]NAM = [F:ID]NAM-[F:ID]SRN
Affzo NAM
[M]REFNUM = VALEUR
Raz [M]CTRNUM

#JOJAC - 2017-05-05 - START
#If [F:ID]FLGMULCTR<>2
# Effzo CTRNUM
# Diszo CTRNUM
# Affzo CTRNUM
#Else
# Actzo CTRNUM
# Affzo CTRNUM
#Endif
#JOJAC - 2017-05-05 - END

If [F:ID]FLGMULCTR<>2
 If [M]PYRDAT<>[0/0/0]
  If [M]CTRNUM<>""
   Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M]FMOIS | (FLGRET=2 & RETDATEFF<=[M]FMOIS)) & CTRNUM=[M]CTRNUM
  Else
   Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M]FMOIS | (FLGRET=2 & RETDATEFF<=[M]FMOIS))
  Endif
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
  #ADNGO - 2017-01-12 - X3-11765 - START
   #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
   #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
   [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
   [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
  #ADNGO - 2017-01-12 - X3-11765 - END
   [M]CTRNUM = [F:HRCTR]CTRNUM
  Endif
  Affzo FCY, SRV,CTRNUM
  #ADNGO - 2017-01-09 - X3-11765- START
  #Call CADRE_PYRDAT([M]PYRDAT,[M]FCY) From TPSSUB
  Call CADRE_PYRDAT([M]PYRDAT,[F:HRCTR]PERCOD) From TPSSUB
  #ADNGO - 2017-01-09 - X3-11765- END
  If mkstat=0
  #JOJAC - 2017-01-06 - START
   #[M]DATDEB = [F:PEO]PERSTR(0)
   #[M]DATFIN = [F:PEO]PEREND(0)
   #[M]FMOIS  = [F:PEO]PEREND(1)
   [M]DATDEB = [F:HRPEOD]PERSTR(0)
   [M]DATFIN = [F:HRPEOD]PEREND(0)
   [M]FMOIS  = [F:HRPEOD]PEREND(1)
  #JOJAC - 2017-01-06 - END
   Call MODULATION([M]PYRDAT,[M]DATDEB,[M]DATFIN,VALEUR,[M]CTRNUM)
   Affzo DATDEB, DATFIN, FMOIS
   Local    Integer EXITSAL
   [M]DATFIN2 = [M]DATFIN
   [M]FMOIS2  = [M]FMOIS
   # FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
   #ADNGO - 2017-01-20 - X3-11765- START
   #Call CALC_DATEND([M]FCY, [M]PYRDAT, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, [M]DATDEB, [M]DATFIN2, [M]FMOIS2, EXITSAL) From TRTTPS
   Call CALC_DATEND([M]FCY, [M]PYRDAT, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, [M]DATDEB, [M]DATFIN2, [M]FMOIS2, EXITSAL,[F:HRCTR]PERCOD) From TRTTPS
   #ADNGO - 2017-01-20 - X3-11765- END
   [M]FMOIS2=max([M]DATFIN2, [M]FMOIS2)
  Endif
  Gosub PRESENCE
  Gosub CHARGE
 Else
  [M]FCY = [F:ID]FCY
  [M]SRV = [F:ID]SRV
  Affzo FCY, SRV
  Call LECTURE("FCY",[F:ID]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("SRV",[F:ID]SRV,"") From CONTOBJ
 Endif
 Gosub CONGES_PARTIEL
Endif
End

####################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
If [M]PYRDAT<>[0/0/0]
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & (CTRDAT<=[M]FMOIS | (FLGRET=2 & RETDATEFF<=[M]FMOIS))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
 #ADNGO - 2017-01-12 - X3-11765 - START
  #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
  #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
 #ADNGO - 2017-01-12 - X3-11765 - END
  Affzo FCY, SRV
 Endif
 #ADNGO - 2017-01-09 - X3-11765- START
 #Call CADRE_PYRDAT([M]PYRDAT,[M]FCY) From TPSSUB
 Call CADRE_PYRDAT([M]PYRDAT,[F:HRCTR]PERCOD) From TPSSUB
 #ADNGO - 2017-01-09 - X3-11765- END
 If mkstat=0
  Call MODULATION([M]PYRDAT,[M]DATDEB,[M]DATFIN,[M]REFNUM,VALEUR)
  Affzo DATDEB, DATFIN
 Endif
 [M]CTRNUM = VALEUR
 Gosub PRESENCE
 Gosub CHARGE
 Gosub CONGES_PARTIEL
Else
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY=[F:HRCTR]ETRFCY
  [M]SRV=[F:HRCTR]ETRSRV
  Affzo FCY, SRV
 Endif
Endif
#ADNGO - 2017-01-09 - X3-11765 - START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] First
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:TPS]LEG = GCURLEG
    Affzo [M:TPS]LEG
    Endif
#ADNGO - 2017-01-09 - X3-11765 - END

End

####################################
$PRESENCE
Local Date    DATDEBCTR
Raz [M]FCY, SRV
Raz [M]PRE
For [HRCTR]CTR0 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
 DATDEBCTR=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:HRCTR]RETDATEFF
 Endif
 If [F:HRCTR]XITDAT=[0/0/0] & DATDEBCTR<=[M]FMOIS2
  If [M]FMOIS2-[M]DATDEB+1>dim([M]PRE)
     # Tableau plein
    Call ERREUR(mess(26,100,1)) From GESECRAN
    Break
  Endif

  For I=max([M]DATDEB,DATDEBCTR)-[M]DATDEB+1 To [M]FMOIS2-[M]DATDEB+1
   [M]PRE(I) = 1
  Next I
 Elsif [F:HRCTR]XITDAT>=[M]DATDEB & DATDEBCTR<=[M]FMOIS2
  If min([M]FMOIS2,[F:HRCTR]XITDAT)-[M]DATDEB+1>dim([M]PRE)
      # Tableau plein
    Call ERREUR(mess(26,100,1)) From GESECRAN
    Break
  Endif

  For I=max([M]DATDEB,DATDEBCTR)-[M]DATDEB+1 To min([M]FMOIS2,[F:HRCTR]XITDAT)-[M]DATDEB+1
   [M]PRE(I) = 1
  Next I
 Endif
# FQ100127 - 16/05/14 - Contrôle par rapport à FMOIS2
# If DATDEBCTR<=[M]FMOIS
 If DATDEBCTR<=[M]FMOIS2
 #ADNGO - 2017-01-12 - X3-11765 - START
  #[M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
  #[M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
  [M]FCY=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
  [M]SRV=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
 #ADNGO - 2017-01-12 - X3-11765 - END
 Endif
Next
If [M]FCY="" Then [M]FCY=[F:ID]FCY : Endif
If [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Call LECTURE("SRV",[M]SRV,"") From CONTOBJ
 Affzo FCY,SRV
Endif
Return

####################################
$CONGES_PARTIEL
Local Char CONTCP(10)
Call PARAM("","CPOUVRA",CONTCP) From ADOVAL
If val(CONTCP)=2
 Call PARAM([M]FCY,"CPA",[M]CPA) From ADOVAL
Else
 [M]CPA = "***"
Endif
Return


########################################################################
# Etiquettes ecran tableau
########################################################################

####################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

####################################
Subprog C_NBRLIG
Local Integer NOL , NOL1 , NOL2
If find(status,65,68,83,75)
 If status=68 or status=83
  NOL1 = nolign-1 : NOL2 = nolign1-1
 Else
  NOL1 = nolign-1 : NOL2 = NOL1
 Endif
 For NOL=NOL1 To NOL2
  If GVISA=2 & [M]STAFLG(NOL)<>"" & !instr(1,GUSRAUZ(1),"4") : # Modif visa
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(102,709,1) : # Ligne visée, modification impossible
   GMESSAGE = mess(102,10709,1) : # Ligne visée, modification impossible
  #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2 : Break
  Endif
  #JOJAC - 2017-01-06 - START
  #If [F:PEO]STA<>2
  If [F:HRPEOD]STA<>2
  #JOJAC - 2017-01-06 - END
   If !instr(1,GUSRAUZ(1),"5") and ([M]TIM(NOL)<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
    #ADNGO - 2017-01-09 - X3-11765 - START
    #GMESSAGE = mess(103,709,1) : # Période fermée, modification impossible
    GMESSAGE = mess(103,10709,1) : # Période fermée, modification impossible
    #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat = 2 : Break
   Endif
  Endif
  If [M]FLGVISU(NOL)=-1
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(108,709,1) : # Ligne non modifiable : Evènement saisi sur paye précédente
   GMESSAGE = mess(108,10709,1) : # Ligne non modifiable : Evènement saisi sur paye précédente
  #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2
   Break
  Endif
 Next NOL
 If mkstat : End : Endif
Endif
If find(status,65,68,83,75,82,73)
 If GCONSULT : mkstat = 2 : End : Endif
Endif
End

####################################
Subprog APRES_NBRLIG
Local Date XITDAT
If ![M]FLGVISU(nolign-1)        :#Si Ligne modifiable...
 [M]FLGMOD(nolign-1) = 1        :#Ligne a réécrire
Endif
If dim ([M]NBRDAY)>=0 & varmode ([M]NBRDAY(nolign-1)) = 1
 Gosub SETNOL
 Local Decimal VALEUR
 Local Integer  OK
 VALEUR=[M]NBRDAY(nolign-1)
 Gosub VERIFCP
 If mkstat=2 : End : Endif
Endif
If dim([M]CTRDAT)>0 Then
  mkstat=0
  # On contrôle la date si elle est renseignée, au cas où on aurait changé les dates d'événement, et que la date du contrat ne soit plus valide
  If [M]CTRDAT(nolign-1)<>[0/0/0] Then
    Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,[M]CTRDAT(nolign-1),[M]ENDDAT(nolign-1),[M]PYRDAT,1,[L]XITDAT) From TPSSTD
  Endif
  # Si la date du contrat est vide, ou que le contrôle a retourné une erreur, on recalcule la date
  If mkstat | [M]CTRDAT(nolign-1)=[0/0/0] Then
    mkstat=0
    [M]CTRDAT(nolign-1)=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
  Endif
  # On contrôle dans tous les cas, au moins pour recalculer la date de sortie
  Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,[M]CTRDAT(nolign-1),[M]ENDDAT(nolign-1),[M]PYRDAT,1,[L]XITDAT) From TPSSTD
  If !mkstat & dim([M]SCTRDAT)>0 Then
    [M]SCTRDAT(nolign-1)=[L]XITDAT : Affzo [M]SCTRDAT(nolign-1)
  Endif
  Affzo [M]CTRDAT(nolign-1)
Endif
Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
Read[F:HRCTR]CTR0 Last
Filter [F:HRCTR]
If !fstat
#ADNGO - 2017-01-12 - X3-11765 - START
 #[M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
 [M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
#ADNGO - 2017-01-12 - X3-11765 - END
 Affzo [M]FCYT(nolign-1)
#ADNGO - 2017-01-12 - X3-11765 - START
 #[M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
 [M]SRVT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
#ADNGO - 2017-01-12 - X3-11765 - END
 Affzo [M]SRVT(nolign-1)
 [M]DATPYRT(nolign-1)=[M]PYRDAT
 If [M]FCYT(nolign-1)<>[M]FCY Then
  Chgstl [M]NBRLIG(nolign-1) With "PLGCUR"
  Affzo [M]NBRLIG(nolign-1)
 Endif
Endif
# FQ95668 - 02/07/15 - Si le type d'arrêt n'est pas saisissable, il reste à 0
# FQ111902 Ajout test si TIM est vide
#If dim([M]TYPPGN)>0 & [M]TYPPGN(nolign-1)=0 & find([M]TIM(nolign-1),GEVT)
If dim([M]TYPPGN)>0 & dim([M]TIM)>0 & [M]TIM(nolign-1)<>"" & [M]TYPPGN(nolign-1)=0 & find([M]TIM(nolign-1),GEVT)
  Call AS_TYPPGN([M]TYPPGN(nolign-1))
  Affzo [M]TYPPGN(nolign-1)
Endif
End

####################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
Local Decimal NBRDAY,NBRHOU
If nolign=1
 VALEUR = [M]DATDEB-1
Else
 VALEUR = [M]ENDDAT(nolign-2)
Endif
Repeat
 VALEUR += 1
 Call VALORIS(VALEUR,VALEUR,[M]REFNUM,GTPSW,NBRDAY,NBRHOU,[M]FCY,[M]CTRNUM) From SUBPLN
Until VALEUR>=[M]DATFIN2 or NBRHOU<>0
VALEUR = min([M]DATFIN2,VALEUR)
End

####################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DATDEB or VALEUR>[M]FMOIS2
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(1,709,1) : # Date en dehors de la période
 GMESSAGE = mess(1,10709,1) : # Date en dehors de la période
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
Gosub SETNOL
Local Integer I

# Evénement multi-dates incluant cette date dans le tableau
For I=0 To [M]NBRLIG-1
 If I<>NOL
  If [M]STRDAT(I)<>[M]ENDDAT(I) & VALEUR>=[M]STRDAT(I) & VALEUR<=[M]ENDDAT(I)
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(2,709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
   GMESSAGE = mess(2,10709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
  #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2 : Break
  Endif
 Endif
Next I
If mkstat : End : Endif

# Evénement multi-dates sur une autre date de paye qui commence avant
For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT<=[M]DATFIN2 & ENDDAT>=[M]DATDEB & DATPYR<>[M]PYRDAT
 If VALEUR>=[F:TIP]STRDAT & VALEUR<=[F:TIP]ENDDAT & [F:TIP]STRDAT<>[F:TIP]ENDDAT
  #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(34,709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
  GMESSAGE = mess(34,10709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
  #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : Break
 Endif
Next
If mkstat : End : Endif

# Evénement multi-dates sur une autre date de paye qui commence après
If VALEUR>[M]DATFIN2
 For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT>[M]DATFIN2 & STRDAT<=[M]FMOIS2 & DATPYR<>[M]PYRDAT
  If VALEUR>=[F:TIP]STRDAT & VALEUR<=[F:TIP]ENDDAT & [F:TIP]STRDAT<>[F:TIP]ENDDAT
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(34,709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
   GMESSAGE = mess(34,10709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
  #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2 : Break
  Endif
 Next
If mkstat : End : Endif
Endif

End

####################################
Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = [M]STRDAT(nolign-1)
End

####################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]STRDAT(nolign-1)
 VALEUR = [M]STRDAT(nolign-1)
Endif
pcolor = GCOUL(1)
End

####################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DATDEB or VALEUR>[M]FMOIS2
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(1,709,1) : # Date en dehors de la période
 GMESSAGE = mess(1,10709,1) : # Date en dehors de la période
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
Gosub SETNOL
Local Integer I

# Evénement multi-dates dans le tableau
For I=0 To [M]NBRLIG-1
 If I<>NOL
  If VALEUR=[M]STRDAT(NOL) : # Date unique
   If [M]STRDAT(I)<>[M]ENDDAT(I) & VALEUR>=[M]STRDAT(I) & VALEUR<=[M]ENDDAT(I)
   #ADNGO - 2017-01-09 - X3-11765 - START
    #GMESSAGE = mess(2,709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
    GMESSAGE = mess(2,10709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
   #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat = 2 : Break
   Endif
  Else                     : # Période
   If [M]STRDAT(NOL)<=[M]ENDDAT(I) & VALEUR>=[M]STRDAT(I)
   #ADNGO - 2017-01-09 - X3-11765 - START
    #GMESSAGE = mess(2,709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
    GMESSAGE = mess(2,10709,1)-num$(I+1) : # Infos déjà saisie pour cette date en ligne xx
   #ADNGO - 2017-01-09 - X3-11765 - END
    mkstat = 2 : Break
   Endif
  Endif
 Endif
Next I
If mkstat : End : Endif

# Présence de l'employé sur la période
For I=[M]STRDAT(nolign-1)-[M]DATDEB+1 To VALEUR-[M]DATDEB+1
 If [M]PRE(I)=0
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(10,709,1)-format$("D:"+GFMDAT4,[M]DATDEB+I-1) : # Employé non présent au
  GMESSAGE = mess(10,10709,1)-format$("D:"+GFMDAT4,[M]DATDEB+I-1) : # Employé non présent au
 #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif

# Evénement sur une autre date de paye qui commence avant
For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT<=[M]DATFIN2 & ENDDAT>=[M]DATDEB & DATPYR<>[M]PYRDAT
 If [M]STRDAT(nolign-1)<=[F:TIP]ENDDAT & VALEUR>=[F:TIP]STRDAT
& & ([F:TIP]STRDAT<>[F:TIP]ENDDAT or [M]STRDAT(NOL)<>VALEUR)
#ADNGO - 2017-01-09 - X3-11765- START
  #GMESSAGE = mess(34,709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
  GMESSAGE = mess(34,10709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
#ADNGO - 2017-01-09 - X3-11765- END
  mkstat = 2 : Break
 Endif
Next
If mkstat : End : Endif

# Evénement sur une autre date de paye qui commence après
If VALEUR>[M]DATFIN2
# For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT>[M]DATFIN & STRDAT<=[M]FMOIS & DATPYR<>[M]PYRDAT
 For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT>[M]DATFIN2 & STRDAT<=[M]FMOIS2 & DATPYR<>[M]PYRDAT
  If [M]STRDAT(nolign-1)<=[F:TIP]ENDDAT & VALEUR>=[F:TIP]STRDAT
& & ([F:TIP]STRDAT<>[F:TIP]ENDDAT or [M]STRDAT(NOL)<>VALEUR)
#ADNGO - 2017-01-09 - X3-11765- START
   #GMESSAGE = mess(34,709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
   GMESSAGE = mess(34,10709,1)-format$("D:"+GFMDAT,[F:TIP]DATPYR) : # Evénement à cette date saisi sur la paye du
#ADNGO - 2017-01-09 - X3-11765- END
   mkstat = 2 : Break
  Endif
 Next
 If mkstat : End : Endif
Endif

#Mutation de site ou de service durant la période saisie
If VALEUR<>[M]STRDAT(NOL) :
#ADNGO - 2017-02-14 - X3-11765 - START
 #Local Char SITDEB (GLONSIT), SITFIN (GLONSIT)
 #Local Char SITDEB (GLONHRSIT), SITFIN (GLONHRSIT)
 Local Char SITDEB (GLONFCY), SITFIN (GLONFCY)
#ADNGO - 2017-02-14 - X3-11765 - END
 Local Char SRVDEB (GLONSRV), SRVFIN (GLONSRV)
 Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M]STRDAT(nolign-1)))
 Read[F:HRCTR]CTR0 Last
 Filter [F:HRCTR]
 If !fstat
 #ADNGO - 2017-01-12 - X3-11765 - START
  #SITDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
  #SRVDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
  SITDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
  SRVDEB=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
 #ADNGO - 2017-01-12 - X3-11765 - END
 Endif
 Filter [F:HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=VALEUR | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read[F:HRCTR]CTR0 Last
 Filter [F:HRCTR]
 If !fstat
  #ADNGO - 2017-01-12 - X3-11765 - START
  #SITFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
  #SRVFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","CTR")
  SITFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
  SRVFIN=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRSRV","HRCTR")
  #ADNGO - 2017-01-12 - X3-11765 - END
 Endif
 If SITDEB<>SITFIN | SRVDEB<>SRVFIN
   #Période à cheval sur une mutation.
   #ADNGO - 2017-01-09 - X3-11765- START
   #GMESSAGE = mess(125,709,1)
   GMESSAGE = mess(125,10709,1)
   #ADNGO - 2017-01-09 - X3-11765- END
   mkstat = 2 : End
 Endif
Endif
End

####################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
# Affecte n° plage evt mono-date uniquement, si pas encore initialisé
If [M]STRDAT(NOL)<>VALEUR | [M]NUMPLG(NOL)<>0 : End : Endif
[M]NUMPLG(NOL)=1
Local Integer I
For I=0 To [M]NBRLIG-1
 If I<>NOL
  If VALEUR=[M]ENDDAT(I)
   [M]NUMPLG(NOL)=[M]NUMPLG(I)+1
  Endif
 Endif
Next I

##**92876 : We need to know the line site earlier because in V7 we use it in DSP & CCE controls
If clalev([F:CTRT])=0 : Local File EMPLOCTR [CTRT] : Endif
Local Date CTRDATT
CTRDATT=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,VALEUR,1)
Read [F:CTRT]CTR0=[M]REFNUM;[M]CTRNUM;CTRDATT
If !fstat
 [M]FCYT(NOL)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTRT]CTRDAT,[M]PYRDAT,"ETRFCY","CTRT")
Endif
End

####################################
Subprog D_TIM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-01-09 - X3-11765 - START
#VALEUR = GTPSDEF
Local Char VALPAR(10)
Call PARAM([M]FCY,"TPSDEF",VALPAR) From ADOVAL
VALEUR = VALPAR
#ADNGO - 2017-01-09 - X3-11765 - END
End

####################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
Local Char    VALPAR(10)
Local Integer OK
Local Decimal POSE
Local Integer CTRDATFINT #107130 PE CTRDATFIN

If clalev([F:TIM])=0 : Local File TIMCOD   [TIM] : Endif
If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CNE])=0 : Local File CNGEMP   [CNE] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY   [CNG] : Endif

#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",VALEUR,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END

Gosub SETNOL

#Interdire la saisie multi date sur les évènements cocher "Saisie plage horaire"
#si le dossier gère au moins une plage (GNBHOR>0)
#et que la saisie de ces plages sont dans la transaction
If GNBHOR & [F:TIM]PLGHOR=2 & [M]STRDAT(NOL)<>[M]ENDDAT(NOL) & left$([M]FRMFLD(2),1)<>"-"
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(119,709,1) : #Saisie multi-date interdite pour ce code temps
 GMESSAGE = mess(119,10709,1) : #Saisie multi-date interdite pour ce code temps
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
If [F:TIM]CTLDAC=2 & eomonth([M]STRDAT(NOL))> eomonth(GMOIPAY)
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(109,709,1) : #Saisie anticipée interdite pour ce code temps
 GMESSAGE = mess(109,10709,1) : #Saisie anticipée interdite pour ce code temps
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif

If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 If fstat or [F:ACC]EXEC<>2
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = VALEUR-":"-mess(61,709,1) : # Vous n'avez pas accès à ce code
  GMESSAGE = VALEUR-":"-mess(61,10709,1) : # Vous n'avez pas accès à ce code
 #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : End
 Endif
Endif

If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Local Integer RET
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M]REFNUM,[M]CTRNUM,RET) From DIVPAYE
  If RET>0 Then
    GMESSAGE= VALEUR-":"-mess(320,199,1) : # Nature d'événement incompatible avec ce salarié
    mkstat=2 : End
  Endif
Endif

Gosub CTL_TYPPGN
If mkstat=2 : End : Endif
Local Date DATFINT, CTRDATT
Local Char FCYT(GLONFCY)
If clalev([F:CTRT])=0 : Local File EMPLOCTR [CTRT] : Endif
CTRDATT=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
Read [F:CTRT]CTR0=[M]REFNUM;[M]CTRNUM;CTRDATT
If !fstat Then
  FCYT=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:CTRT]CTRDAT,[M]PYRDAT,"ETRFCY","CTRT")
Endif
If FCYT<>[M]FCY Then
  #JOJAC - 2017-01-06 - START
#  If clalev([F:PEOT])=0 : Local File PERIOD [PEOT] : Endif
#  Read [F:PEOT]PEO0=FCYT;[M]PYRDAT
#  If fstat Then
#    Read [F:PEOT]PEO0="";[M]PYRDAT
#    If fstat Then Raz [F:PEOT] : Endif
#  Endif
#  DATFINT = [F:PEOT]PEREND(1)
  If clalev([F:HRPEODT])=0 : Local File HRPEOD [HRPEODT] : Endif
  Read [F:HRPEODT]HRPEOD1=PERCODT;[M]PYRDAT
  #If fstat Then
  #  Read [F:PEOT]PEO0="";[M]PYRDAT
  #  If fstat Then Raz [F:PEOT] : Endif
  #Endif
  DATFINT = [F:HRPEODT]PEREND(1)
  #JOJAC - 2017-01-06 - END
Else
  DATFINT=[M]DATFIN2
Endif
#107130 PE CTRENDDAT
[V]GPE = 0
GPOINT = "CTRENDDAT" : Gosub ENTREE From EXEFNC
#If [F:TIM]MONDAC<>2 & [M]ENDDAT(NOL)>DATFINT
If ![V]GPE & [F:TIM]MONDAC<>2 & [M]ENDDAT(NOL)>DATFINT
#ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(31,709,1)-format$("D:"+GFMDAT,DATFINT) : # Ce code ne peut être saisi au delà du
 GMESSAGE = mess(31,10709,1)-format$("D:"+GFMDAT,DATFINT) : # Ce code ne peut être saisi au delà du
 #ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
#JOJAC - 2017-01-06 - START
#If [F:PEO]STA<>2
If [F:HRPEOD]STA<>2
#JOJAC - 2017-01-06 - END
 If !instr(1,GUSRAUZ(1),"5") and (VALEUR<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(104,709,1) : # Période fermée, événement interdit
  GMESSAGE = mess(104,10709,1) : # Période fermée, événement interdit
 #ADNGO - 2017-01-09 - X3-11765 - END
  mkstat = 2 : End
 Endif
Endif
#ADNGO - 2017-01-09 - X3-11765 - START
#If VALEUR<>[M]TIM(NOL) & [M]CMT(NOL)=mess(26,709,1)
If VALEUR<>[M]TIM(NOL) & [M]CMT(NOL)=mess(26,10709,1)
#ADNGO - 2017-01-09 - X3-11765 - END
 [M]CMT(NOL) = "" : Affzo CMT(NOL)
Endif

If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Filter [CNG] Where CPY=[F:FCY]LEGCPY & TIM=VALEUR & ( (STRDAT<=[M]STRDAT(NOL) & ENDDAT>=[M]ENDDAT(NOL)) | (DEBDAT<=[M]STRDAT(NOL) & FINDAT>=[M]ENDDAT(NOL)) )
 Read [CNG]CNG0 First
 Filter [CNG]
 If !fstat
  Read [CNE]CNE0=[F:CNG]YEA;[M]REFNUM;[M]CTRNUM;VALEUR
  If fstat
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(165,709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
   GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
  #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = mess(319,199,1)-[F:TIM]COD : # Fiche période de congé inexistante pour l'évènement
  mkstat = 2 : End
 Endif
 If [M]STRDAT(NOL)<>[M]ENDDAT(NOL) & [F:TIM]FLGBLC=2
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,VALEUR,[M]NBRDAY(NOL),[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
  Call CTRL_CP ([M]FCY,VALEUR,[M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]CTRNUM,[M]NBRDAY(NOL)-[M]ONBRDAY(NOL),[F:TIM]BLCMIN,OK) From TPSSTD1
  If !OK : mkstat=2 : End : Endif
 Endif
Endif

# Congés en jours ouvrables => on doit reprendre un jour ouvré
If VALEUR=[M]CPA : # Pour Adonix, faura peut être limiter aux temps partiels ??
#MIPEA - 2017-11-27- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M]REFNUM & [F:HRCTR8]CTRNUM = [M]CTRNUM
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
 If func TPSSTD1.OUVRABLE([M]REFNUM,[M]ENDDAT(NOL)+1,[M]CTRNUM)
 #ADNGO - 2017-01-09 - X3-11765 - START
  #OK = 1 : Call AVERTIR(mess(70,709,1),OK) From GESECRAN
  OK = 1 : Call AVERTIR(mess(70,10709,1),OK) From GESECRAN
 #ADNGO - 2017-01-09 - X3-11765 - END
  # Reprise d'activité un jour ouvrable
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif

End

$CTL_TYPPGN
If find(VALEUR,GEVT) & left$([M]FRMFLD(0),1)="-"
 # La zone "Type d'arrêt" n'est pas activée dans cet écran. Veuillez choisir une autre transaction de saisie.
 #ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(185,709,1)
 GMESSAGE = mess(185,10709,1)
 #ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : Return
Endif
Return

####################################
Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",VALEUR,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]NATACT<>2
 Raz [M]NATCOD(NOL)
 Call AM_NATCOD ([M]NATCOD(NOL))
Endif
If [F:TIM]CMTOBG=2 & varmode(CMT,0)=1
 # Saisie du commentaire obligatoire.
 # Transaction inadaptée à la saisie de cet évènement.
 #ADNGO - 2017-01-09 - X3-11765 - START
 #GMESSAGE = mess(144,709,1)
 GMESSAGE = mess(144,10709,1)
 #ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
[M]TYPPGN(nolign-1)=0
End


Subprog AS_TYPPGN(VALEUR)
Variable Integer VALEUR
If !find([M]TIM(nolign-1),GEVT)
 mkstat=1 : End
Endif

If VALEUR : End : Else : VALEUR=1 : Endif

#Si un congé patho prénatal PATHM est suivi d'un congés maternité, la maternité doit être typé 'prolongation'
If [M]TIM(nolign-1) = func AFNC.PARAM("MATERNITE","")
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPREN","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),func AFNC.PARAM("PATHPREN",""),[M]REFNUM,[M]STRDAT(nolign-1))
 Endif
#Si un congé patho postnatal PATHO est suivi d'un congés maladie, la maladie doit être typé 'prolongation'
Elsif [M]TIM(nolign-1) = func AFNC.PARAM("MALADIE","")
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPOST","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),func AFNC.PARAM("PATHPOST",""),[M]REFNUM,[M]STRDAT(nolign-1))
 Endif
Elsif find([M]TIM(nolign-1),GEVT) :# Prologuation si 2 mêmes evt se suivent...
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1)) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),[M]TIM(nolign-1),[M]REFNUM,[M]STRDAT(nolign-1))
 Endif
Endif
End

Subprog INIT_TYPPNG(VALEUR,PEVT,PEVT2,PEMP,PDAT)
Variable Integer VALEUR
Value Char PEVT  ()
Value Char PEVT2 ()
Value Char PEMP  ()
Value Date PDAT
If clalev([F:TIP2])=0  : Local File TIMEMP    [TIP2]  : Endif
Filter [TIP2] Where REFNUM=PEMP & STRDAT<PDAT & (TIM=PEVT | TIM=PEVT2)
Read[TIP2]TIP1 Last
Filter [TIP2]
If !fstat & [TIP2]ENDDAT+1=PDAT
 VALEUR=2 : End
Endif
End


Subprog AS_LEADAY(VALEUR)
Variable Integer  VALEUR
If [M]STRDAT(nolign-1)<>[M]ENDDAT(nolign-1) | [F:TIM]CATTIM<>3
 VALEUR = 3 : #Journée
 mkstat = 2 : End
Endif
End

Subprog AP_LEADAY(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : [M]STRDAY(nolign-1) = 2 : [M]ENDDAY(nolign-1) = 1 : # Matin
 When 2 : [M]STRDAY(nolign-1) = 1 : [M]ENDDAY(nolign-1) = 2 : # Après-midi
 When 3 : [M]STRDAY(nolign-1) = 1 : [M]ENDDAY(nolign-1) = 1 : # Journée
Endcase
End

####################################
Subprog D_NBRDAY(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [M]STRDAT(NOL)=[M]ENDDAT(NOL) & [F:TIM]CATTIM=3 &([M]LEADAY(NOL)=1 | [M]LEADAY(NOL)=2) : # 1/2 journée
 Call VALORISAM([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM,1) From SUBPLN
Else
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
Endif
End

####################################
Subprog AS_NBRDAY(VALEUR)
Variable Decimal VALEUR
Local Char    VALPAR(10)
Local Integer I, OK
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
 If VALEUR : mkstat = 2 : End  : Endif
Endif
# If the dates are updated to become equal, we have to recalculate the result : (Case to have VALEUR>1 here)
If [M]STRDAT(NOL)=[M]ENDDAT(NOL) & VALEUR>1
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM) From SUBPLN
Endif
##**DBA : Why we don't call VALORISAM() in the first condition too ?
If [M]STRDAT(NOL)=[M]ENDDAT(NOL) & ([F:TIM]CATTIM=3 | [F:TIM]DAYDAC=2)
 If ([M]LEADAY(NOL)=1 | [M]LEADAY(NOL)=2) : # 1/2 journée
  If [F:TIM]DAYDAC=2 Then
    VALEUR = 0.5
  Else
    Call VALORISAM([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),VALEUR,[M]NBRHOU(NOL),[M]FCY,[M]CTRNUM,1) From SUBPLN
  Endif
 Elsif [M]LEADAY(NOL)=3 & VALEUR<=0.5 : # journée
  VALEUR = 1    ##**DBA : Why we don't call VALORIS() here ?
 Endif
Endif
If [F:TIM]DAYDAC<>2 : mkstat = 2 : End : Endif
End

####################################
Subprog C_NBRDAY(VALEUR)
Variable Decimal VALEUR
Call CONTTPS (num$(VALEUR),zoncou,1)
Gosub SETNOL
Local Integer I, OK
Local Decimal JOUR,HEURE
Local Char    VALPAR(10)
For I=0 To [M]NBRLIG-1
 If I<>NOL & [M]STRDAT(I)=[M]STRDAT(NOL) & [M]ENDDAT(I)=[M]STRDAT(NOL) & ![M]FLGVISU(I)
  JOUR += [M]NBRDAY(I)
 Endif
Next I
For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT=[M]STRDAT(NOL) & ENDDAT=[M]ENDDAT(NOL) & DATPYR<>[M]PYRDAT
 JOUR += [F:TIP]NBRDAY
Next
# FQ108256 - 01/06/15 - Si STRDAT<>ENDDAT, on n'est pas sur une seule journée, donc on compare avec ces données
#If JOUR+abs(VALEUR)>1
If JOUR+abs(VALEUR)>[M]ENDDAT(NOL)-[M]STRDAT(NOL)+1
 If [M]STRDAT(NOL)=[M]ENDDAT(NOL) Then
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(3,709,1) : # Pas plus de 1 jour par journée calendaire
  GMESSAGE = mess(3,10709,1) : # Pas plus de 1 jour par journée calendaire
 #ADNGO - 2017-01-09 - X3-11765 - END
 Else
 #ADNGO - 2017-01-09 - X3-11765 - START
  #GMESSAGE = mess(182,709,1) : # Nombre de jours trop important
  GMESSAGE = mess(182,10709,1) : # Nombre de jours trop important
 #ADNGO - 2017-01-09 - X3-11765 - END
 Endif
 mkstat = 2 : End
Endif
Gosub VERIFCP
If mkstat=2 : End : Endif
If [M]TIM(NOL)=GTPSW
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,"",JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Else
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Endif
If JOUR<>0
 [M]NBRHOU(NOL) = ar2(HEURE*VALEUR/JOUR)
Endif
End

####################################
$VERIFCP
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If VALEUR>0 & [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 Call CTRL_CP ([M]FCY,[M]TIM(NOL),[M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]CTRNUM,VALEUR-[M]ONBRDAY(NOL),[F:TIM]BLCMIN,OK) From TPSSTD1
 If !OK : mkstat=2 : Return : Endif
Endif
Return

####################################
Subprog D_NBRHOU(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
##101660 : To do the same thing as Subprog D_NBRDAY(), to manage the case where [M]NBRDAY is hidden (screen transaction).
##In this case the subprog D_NBRDAY doesn't run so we have to do it here.
#Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),[M]NBRDAY(NOL),VALEUR,[M]FCY,[M]CTRNUM) From SUBPLN
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [M]STRDAT(NOL)=[M]ENDDAT(NOL) & [F:TIM]CATTIM=3 &([M]LEADAY(NOL)=1 | [M]LEADAY(NOL)=2) : # 1/2 journée
 Call VALORISAM([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),[M]NBRDAY(NOL),VALEUR,[M]FCY,[M]CTRNUM,1) From SUBPLN
Else
 Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),[M]NBRDAY(NOL),VALEUR,[M]FCY,[M]CTRNUM) From SUBPLN
Endif
##
End

#Il faut que l'evènement ait comme type de saisie "En heures" et soit mono-date
####################################
Subprog AS_NBRHOU(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If (varmode ([M]NBRDAY)<>0) : # 107133
  ##101660 : It's mandatory to recalcule NBRDAY and NBRHOU here to manage the case where [M]NBRDAY isn't enterable (screen transaction)
  ##In this case the subprog AS_NBRDAY and C_NBRDAY don't run so we have to do it here
  If [M]STRDAT(NOL)=[M]ENDDAT(NOL) & [F:TIM]CATTIM=3 &([M]LEADAY(NOL)=1 | [M]LEADAY(NOL)=2) : # 1/2 journée
    Call VALORISAM([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),[M]NBRDAY(NOL),VALEUR,[M]FCY,[M]CTRNUM,1) From SUBPLN
  Else
    Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),[M]NBRDAY(NOL),VALEUR,[M]FCY,[M]CTRNUM) From SUBPLN
  Endif
  Affzo [M]NBRDAY(NOL)
Endif
##
If [F:TIM]HOUDAC<>2 or [M]STRDAT(NOL)<>[M]ENDDAT(NOL)
 mkstat = 2 : End
Endif
If [M]STRTIM(NOL)<>""
 Gosub SUMHRS :  VALEUR=SUMHRS :  mkstat = 2 : End
Endif
End

####################################
Subprog C_NBRHOU(VALEUR)
Variable Decimal VALEUR
Call CONTTPS (num$(VALEUR),zoncou,1)
Gosub SETNOL
Local Integer I
Local Decimal JOUR , HEURE , JPASS
Local Decimal VALHOU
For I=0 To [M]NBRLIG-1
 If I<>NOL & (([M]STRDAT(I)=[M]STRDAT(NOL) & [M]ENDDAT(I)=[M]STRDAT(NOL))
& | ([M]STRDAT(NOL)<>[M]ENDDAT(NOL) & [M]STRDAT(I)=[M]STRDAT(NOL) & [M]ENDDAT(I)=[M]ENDDAT(NOL)))
  HEURE += [M]NBRHOU(I)
  JPASS += [M]NBRDAY(I)
 Endif
Next I
For [TIP]TIP1 Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & STRDAT=[M]STRDAT(NOL) & ENDDAT=[M]ENDDAT(NOL) & DATPYR<>[M]PYRDAT
 HEURE += [F:TIP]NBRHOU
 JPASS += [F:TIP]NBRDAY
Next
If [M]STRDAT(NOL)=[M]ENDDAT(NOL)
  VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M]FCY))
  # FQ109294 - 06/07/15 - On peut venir des réguls, donc avoir une VALEUR négative, et au final un HEURE+VALEUR négatif
#  If VALHOU>0 & HEURE+VALEUR>VALHOU
  If VALHOU>0 & abs(HEURE+VALEUR)>VALHOU
  #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU) : # Maximum d'heures par jour
   GMESSAGE = mess(4,10709,1)-":"-num$(VALHOU) : # Maximum d'heures par jour
  #ADNGO - 2017-01-09 - X3-11765- END
   mkstat = 2 : End
  Endif
  Gosub SUMHRS
  If VALEUR<>SUMHRS & SUMHRS & VALEUR>0
   #ADNGO - 2017-01-09 - X3-11765 - START
   #GMESSAGE=mess(117,709,1)    :#Nombre d'heures incorrect
   GMESSAGE=mess(117,10709,1)    :#Nombre d'heures incorrect
   #ADNGO - 2017-01-09 - X3-11765 - END
   mkstat = 2 : End
  Endif
Endif
If [M]TIM(NOL)=GTPSW
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,"",JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Else
  Call VALORIS([M]STRDAT(NOL),[M]ENDDAT(NOL),[M]REFNUM,[M]TIM(NOL),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Endif

If HEURE<>0
 [M]NBRDAY(NOL) = min(JOUR-JPASS,ar2(VALEUR*JOUR/HEURE))
Else
 [M]NBRDAY(NOL) = 0
Endif
Affzo NBRDAY(NOL)
End

#Calcul du nb d'heure = Heure fin-heure debut-temps de pause
####################################
$SUMHRS
Local Decimal SUMHRS, VALHMDEB, VALHMFIN
SUMHRS=0
Call CONVERTHM([M]STRTIM(NOL),VALHMDEB)From SUBSTY
Call CONVERTHM([M]ENDTIM(NOL),VALHMFIN)From SUBSTY
If VALHMDEB<=VALHMFIN
 SUMHRS = VALHMFIN-VALHMDEB-[M]BRKTIM(NOL)
Else
 SUMHRS = 24-VALHMDEB+VALHMFIN-[M]BRKTIM(NOL)
Endif
SUMHRS = ar2(SUMHRS)
Return

####################################
Subprog D_DAYNGT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]NATCOD(NOL)<>""
 Call LECT_NATCOD ([M]NATCOD(NOL)) From TPSDIV
  VALEUR=[F:NAT]DAYNGT
Else
 VALEUR = 1 :#Par défaut->jour
Endif
End

####################################
Subprog AS_DAYNGT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If [F:TIM]NGTDAY<>2 : mkstat = 1 : End : Endif
GMENLOC(3) = 1
End

####################################
Subprog C_DAYNGT(VALEUR)
Variable Integer VALEUR
Call CONTTPS (num$(VALEUR),zoncou,1)
End

####################################
Subprog D_STAFLG(VALEUR)
Variable Char VALEUR()
If !instr(1,GUSRAUZ(1),"2") | GVISA<>2 : # Visa
 VALEUR = ""
Else
 VALEUR = GUSER
Endif
End

####################################
