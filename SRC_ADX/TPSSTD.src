#J=find([M]WDIE(AXE-1),[F:TIM]DIE(0..dim([F:TIP]DIE)-1))
#If J
Call AXECODINICCE([M]NATCOD(nolign-1),[M]TIM(nolign-1),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
If ISEDITABLE<>2
  mkstat=2
Endif
# If [F:TIM]CCEDAC(J-1)<>2
