## Etiquette ajoutée par le superviseur (écran TPSSTD) 07/12/2012 12:32:47 (MABON)
######################################################################################
Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR<>[0/0/0] : End : Endif
  VALEUR=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DATFIN,[M]PYRDAT,[M]ENDDAT(nolign-1),1)
End


