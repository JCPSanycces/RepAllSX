# Etiquettes ecran tableau (Analytique)
########################################################################

####################################
Subprog AS_DSP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
#ADNGO - 2017-01-09 - X3-11765 - START
#Call LECTURE("TIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",[M]TIM(NOL),GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",[M]TIM(NOL),"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-09 - X3-11765 - END
If !find(2,[F:TIM]CCEDAC(0..GOPTCANA-1))
 mkstat = 1 : End
Endif
End

####################################
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Decimal TOT
VALEUR=toupper(VALEUR)
Call CONTTPS (VALEUR,zoncou,2)
If VALEUR<>"" & VALEUR<>"$"
 Call CONTROLE("DSP","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 #92876_US2757
 Call VERIF([F:DSP]FCY,[M]FCYT(nolign-1),VALEUR) From CFYSUB
 If mkstat : End : Endif
 #
 Call CONTEXE([F:DSP]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 Call CTLVLYDAT([M]STRDAT(nolign-1),[F:DSP]VLYSTR,[F:DSP]VLYEND) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 Call CHARGE_VTE(VALEUR) From TPSVENT
 [M:VTL]TIM = [M]TIM(nolign-1)
 [M:VTL]DAT = [M]STRDAT(nolign-1)
 # FQ103597 - 27/10/14 - Renseignement du site avant sa récupération, s'il est vide
 If [M]FCYT(nolign-1)="" Then
 #ADNGO - 2017-01-09 - X3-11765 - START
  #[M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR")
  [M]FCYT(nolign-1)=func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[M]CTRNUM,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
 #ADNGO - 2017-01-09 - X3-11765 - END
 Endif
 # FQ100947 - 23/06/14 - Renseignement du site
 [M:VTL]FCY = [M]FCYT(nolign-1)
 Call CONTVENT From TPSVENT
 If mkstat : End : Endif
 [M]PTV(nolign-1) = 0
 [M]PTF(nolign-1) = 0
Endif
If VALEUR="$"
 For I=[M]PTV(nolign-1) To [M]PTF(nolign-1)
  TOT += [M:VT2]TBAMT(I)
 Next
 If TOT<>[M]NBRHOU(nolign-1)
  I = 1
 #ADNGO - 2017-01-09 - X3-11765 - START
  #Call AVERTIR(mess(54,709,1),I) From GESECRAN
  Call AVERTIR(mess(54,10709,1),I) From GESECRAN
 #ADNGO - 2017-01-09 - X3-11765 - END
  If I=1 : # Annuler
   mkstat = 2 : End
  Endif
 Endif
Endif
#92876_US2757
If VALEUR<>""
 For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   Assign "[M]CCE"+num$(I)+"(nolign-1)" With ""
 Next
Endif
End

