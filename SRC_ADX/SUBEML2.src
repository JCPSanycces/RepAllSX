$VERIF
## Dates de validit‚ des cartes
Local Date VALID_SEJOUR, VALID_TRAVAIL
Local Char CARTE_SEJOUR(15), CARTE_TRAVAIL (15)
Local Char ZONE(10)

# FQ81085 US525 - SEGAY 05/07/12
#**
#* Returns the list of legislations of an employee
#*
#* @param EMP     : personal ID
#* @param FLDLEG  : name of the LEG field in the table where the selection must be done
#* @param LISTLEG : list of legislations of the employee
#* @param CRIT    : criteria with the different legislations, on the LEG field
#*!
Gosub INIWVARCIV
If WREFNUM <> ""
  If WCIV <> [F:ID]CIV
  Call LIST_LEG_EML(WREFNUM, WFLDLEG,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG
   If WNBLEG > 1
    # Il y a au moins un contrat avec une l‚gislation diff‚rente : pensez … modifier sa civilit‚
    Call MESSAGE(mess(131,10701,1)) From GESECRAN
   Endif
   Endif
Endif

ZONE = "DATBRN"
Gosub SET_ZONE
If MA
  If WREFNUM <> ""
    mkstat = 0
    If ![M]FLGDATBRN
      Local Char    WDATE
      WDATE=DATBRN
      BIRTHDATE = DATBRN
      Gosub CTR_DATBRN
      If mkstat
        Raz mkstat
        GERR = 1
        GOK=0
        If WOK =1 : OK = 0 : Endif
        Return
      Endif
    Endif
    [M]FLGDATBRN=0
  Endif

Endif
# END FQ81085 US525 - SEGAY 05/07/12

ZONE = "STYCRD"
Gosub SET_ZONE
If MA
 CARTE_SEJOUR = [M]STYCRD
 ZONE = "DATSTY"
 Gosub SET_ZONE
 If MA
  VALID_SEJOUR = [M]DATSTY
  mkstat = 0
  Call CONTROLE_VALID(CARTE_SEJOUR,VALID_SEJOUR)
  If mkstat : Raz mkstat : GERR = 1 : Return : Endif
 Endif
Endif

ZONE = "WRKCRD"
Gosub SET_ZONE
If MA
 CARTE_TRAVAIL = [M]WRKCRD
 ZONE = "DATWRK"
 Gosub SET_ZONE
 If MA
  VALID_TRAVAIL = [M]DATWRK
  mkstat = 0
  Call CONTROLE_VALID(CARTE_TRAVAIL,VALID_TRAVAIL)
  If mkstat : Raz mkstat : GERR = 1 : Return : Endif
 Endif
Endif

#Pourcentage participation & interessement
ZONE = "FDSPARPRC0"
Gosub SET_ZONE
If MA
 Call CONTROLE_PARTICIP
 If GERR : OK = 0 : Return : Endif
Endif


# Pourcentage types de paiement
ZONE = "NBRRIB"
Gosub SET_ZONE
