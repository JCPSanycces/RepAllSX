Subprog AS_WADD6(VALEUR)
Variable Integer VALEUR
If [M]WSTRDATTRY<>[0/0/0] & !find([M]WSTRDATTRY,[M]STRDATTRY(0..[M]NBRTRY-1))
 [M]FLGADD2 = 1
 Local Integer NOL
 NOL = [M]NBRTRY
 Gosub DECHARGE_TRY
 [M]NBRTRY += 1
 #29411
 Sorta [M]NBRTRY [M]NBRTRY Order By [M]STRDATTRY([S]indice)Desc
 Affzo 30
 VALEUR = 1
 [M]WLIG2 = find([M]WSTRDATTRY,[M]STRDATTRY(0..[M]NBRTRY-1))
 If !GBROWS : zonsui = "WSTRDATTRY" : Endif #72698
Endif
End

