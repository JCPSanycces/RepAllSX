##                             Ecran HRMAT9 - Dipl“mes/Exp‚riences
################################################################################

## Dipl“mes

Subprog AS_NBREXM
Gosub SETNOL
If NOL>=0 & [M]NBREXM>0
 If NOL<=[M]NBREXM
  Gosub CHARGE_EXM
 Else
  Effzo 20
 Endif
Else
 Effzo 20
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog FIRST_NBREXM
Local Integer NOL
NOL=0
Gosub CHARGE_EXM
End

Subprog C_NBREXM
If status=82 : mkstat = 1 : Endif
If find(status,65,68,83)
 [M]FLGADD1 = 1
Endif
End

$CHARGE_EXM
Local Char SUFFIXE(3)
SUFFIXE = "EXM"
Gosub CHARGE_W
[M]WLIG1      = NOL
Affzo 20
Grizo WADD5
Return

$DECHARGE_EXM
Local Char SUFFIXE(3)
SUFFIXE = "EXM"
Gosub DECHARGE_W
[M]WLIG1          = NOL
Grizo WADD5
Return

Subprog C_WDATEXM(VALEUR)
Variable Date    VALEUR
Local Integer NOL
#LIPET - 2017-05-18 - X3-30751 - START
#If VALEUR = [0/0/0] : End : Endif
If VALEUR = [0/0/0]
  Raz [M]WDOMDES
  Raz [M]WLEVDES
  Raz [M]WORGDES
  :End
Endif
#LIPET - 2017-05-18 - X3-30751 - END
NOL = find(VALEUR,[M]DATEXM(0..[M]NBREXM-1))-1
If NOL>=0
 Gosub CHARGE_EXM
Else
 [M]WLIG1 = [M]NBREXM
 Actzo WADD5
Endif
End

Subprog AM_WDATEXMEND(VALEUR)
Variable Date    VALEUR
[M]DATEXMEND([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
End

Subprog AM_WDOMEXM(VALEUR)
Variable Char    VALEUR()
[M]DOMEXM([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
# FQ81085 - MABON 07/09/12 - US774 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
Call LECTEXTRA([M]WDOMDES,"ATABDIV","LNGDES","10381",VALEUR) From ATEXTRA
End

Subprog AM_WDESEXM(VALEUR)
Variable Char    VALEUR()
[M]DESEXM([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
End

Subprog AM_WLEVEXM(VALEUR)
Variable Char    VALEUR()
[M]LEVEXM([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
# FQ81085 - MABON 07/09/12 - US774 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
Call LECTEXTRA([M]WLEVDES,"ATABDIV","LNGDES","10382",VALEUR) From ATEXTRA
End

Subprog AM_WORGEXM(VALEUR)
Variable Char    VALEUR()
[M]ORGEXM([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
