#**
#* Find the good local menu for the title, depending on the site
#* 05/07/12 SEGAY 81085 US524
#* @param PINI : 1= Initialisation (Create Employee)
#* @param PLEG : LEG
#* @param PFCY : Site
#* @param PCIV : Num‚ric Field Civility (Item of ML)
#*!
Subprog SETCPYLGEG(PINI,PLEG,PFCY,PCIV)
Value Integer PINI
Value Char PLEG()
Value Char PFCY()
Value Integer PCIV
Local Char    CRITCTRL (250), SOC(GLONCPY), VOIDCHAR(250)
Local Char TMPLEG (20)
Local Integer OK
Local Char NUMLIB(10), LEGOLD, LEGNEW, LEGI, LEGC
Local Integer WCIVI
Local Char    LISTLEG(5)(1..10), WFLDLEG
Local Char    WCRIT(250)
Local Integer WNBLEG
Local Integer PNOLIB,OKPAR
Local Integer WSITFAM
# Multi_leg & multi_soci‚t‚

If PFCY<>""
 Call LECTURE("FCY",PFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ

 GSOCIETE=[F:CPY]CPY : [M:EMP0]CPYORI=GSOCIETE

 # Compare site legislation to see if legislation has changed
 TMPLEG = GCURLEG
 If dim([F:CPY]LEG)>0
   GCURLEG =[F:CPY]LEG : [M:EMP0]LEGORI=GCURLEG

#   TODO
   If dim([F:FCY]LEG)>0 & [F:FCY]LEG <> "" & [F:FCY]LEG <> [F:CPY]LEG
     GCURLEG =[F:FCY]LEG : [M:EMP0]LEGORI=GCURLEG

   Endif
 Endif
 GSOCIETE=[F:CPY]CPY
 [M:EMP0]CPYORI=GSOCIETE

 If TMPLEG <> "" & TMPLEG <> GCURLEG
   [M:EMP0]CIV=0
   [M:EMP0]CIVA = ""
 Endif
 WCIVI=[M:EMP0]CIV

 Call VERIF_AML_EML(PFCY,WCIVI,1,"CIVIL",PNOLIB,LEGI,LEGC,OKPAR) From SUBEML2
 [M:EMP0]NOLIB=PNOLIB

#Get back to this
#If dim([M:EMP1]CODSEE)>0: [M:EMP1]CODSEE = [F:ID]CODSEE: Affzo[M:EMP1]CODSEE: Infbox([F:ID]CODSEE):Infbox([M:EMP1]CODSEE):Endif


 If !OKPAR
   mkstat=2 : End
 Endif

 # FQ81085 - 22/11/13 - Marital status
 If TMPLEG <> "" & TMPLEG <> GCURLEG
   [M:EMP2]SITFAM  = 0
   [M:EMP2]SITFAMA = ""
 Endif
 WSITFAM=[M:EMP2]SITFAM
 Call VERIF_AML_EML(PFCY,WSITFAM,1,"SITFAM",PNOLIB,LEGI,LEGC,OKPAR) From SUBEML2
 [M:EMP2]NOLIBM=PNOLIB
 If OKPAR
  [M:EMP2]SITFAM  = WSITFAM
  If(WSITFAM<>0)
    [M:EMP2]SITFAMA = mess(WSITFAM,[M:EMP2]NOLIBM,1)
  Else
    [M:EMP2]SITFAMA=""
  Endif
Else
 [M:EMP2]SITFAMA=""
Endif
 Affzo [M:EMP2]SITFAMA
 # Fin FQ81085


 If TMPLEG <> GCURLEG
   WFLDLEG=GCURLEG

   Call LECTURE("FCY",[F:ID]FCYORI,"")  From CONTOBJ : LEGOLD = [F:FCY]LEG : # LEGOLD=leg old of the employee
   Call LECTURE("FCY",PFCY,"")        From CONTOBJ : LEGNEW = [F:FCY]LEG : # LEGNEW=leg new of the employee
   If [M:EMP0]CIV<>0 Then
    [M:EMP0]CIVA=mess([M:EMP0]CIV,[M:EMP0]NOLIB,1)
   Else
    Raz [M:EMP0]CIVA
   Endif
   If [F:ID]FCYORI ="" & GREP="C"  & PCIV=0 Then
     [M:EMP0]CIV=1
     [M:EMP0]CIVA=mess([M:EMP0]CIV,[M:EMP0]NOLIB,1)
   Endif
#   If [M:EMP0]CIVA="" & [F:ID]FCYORI <>"" & PINI=1 & [M:EMP0]NOLIB>0 Then
#     [M:EMP0]CIV=1
#     [M:EMP0]CIVA=mess([M:EMP0]CIV,[M:EMP0]NOLIB,1)
#   Endif
 Else
   [M:EMP0]CIVA=mess([M:EMP0]CIV,[M:EMP0]NOLIB,1)
 Endif
Endif
Affzo [M:EMP0]CIVA

If dim([M:EMP0]LEGORI)>0
  Affzo [M:EMP0]LEGORI
  Affzo [M:EMP0]ZLEGORI
Endif

If (GREP="C" | GREP="D")
 # Display\Hide fields based on legislation
 # SBA - 'ici'
Gosub STYLE From SUBEML

Endif
WCIVI=[M:EMP0]CIV
Call GRISE_OLDNAM(WCIVI)

ZONE = "NBAXE" : Gosub SET_ZONE From SUBEML2
If dim([M]DIE)>0
   # Rang 2 dans le menu 2230 Service
