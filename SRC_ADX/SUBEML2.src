Subprog GRISE_HANDICAP(VALEUR)
Value Integer VALEUR
If ! GPAYE : End : Endif
Local Char ZONE(10) : ZONE = "FLGHDC"
Gosub SET_ZONE
If MA
 #LIPET - 2017-05-02 - X3-34892 - START
 If func DIVPAYE.EXISTE_KXX("SUBEMLKSA") &  func AFNC.ACTIV("KGZA")>0 Then
  Call GRISE_HANDICAP(VALEUR) From SUBEMLKSA
 Endif
 #LIPET - 2017-05-02 - X3-34892 - END
  If VALEUR=2
    #DEHEN - 2017-02-16 - X3-18830 - Start
    If GCURLEG = "BRI" Then
      Actzo [M:EMP3]HDCNTE
      Actzo [M:EMP3]HDCTYP
    Endif
    #DEHEN - 2017-02-16 - X3-18830 - End
    Actzo NBHDC
  Else
    Grizo NBHDC
    #DEHEN - 2017-02-16 - X3-18830 - Start
    If GCURLEG = "BRI" Then
      Grizo [M:EMP3]HDCNTE
      Grizo [M:EMP3]HDCTYP
    Endif
    #DEHEN - 2017-02-16 - X3-18830 - End
  Endif
Endif
End

