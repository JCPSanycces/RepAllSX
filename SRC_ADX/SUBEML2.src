Subprog AM_NTT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & dim ([M]CODUE)>=0
 Local Integer RESULT
 Call SETCODUE(VALEUR,RESULT)
 [M]CODUE= RESULT    :#Ecrasement du CODUE en modif de NTT
 Affzo CODUE
Endif
End

