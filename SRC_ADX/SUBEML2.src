  If GCURLEG = "BRI"
    If dim([M:EMP7]BNKACCNUM)>0 Chgfmt [M:EMP7]BNKACCNUM  With "-N:9"  : Endif
  Else
    If dim([M:EMP7]BNKACCNUM)>0 Chgfmt [M:EMP7]BNKACCNUM  With "+N:9"  : Endif
  Endif
#HEGES - 2017-06-30- X3-45711 - END
