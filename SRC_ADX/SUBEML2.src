Subprog AV_DATISS(VALEUR)
Variable Date    VALEUR
If !func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) Then
  If dim([M:EMP3]DATISS(0))>0 : Chgfmt [M:EMP3]DATISS(0)  With "-D:"+GFMT  : Raz [M:EMP3]DATISS(0) : Endif
  If dim([M:EMP3]DATISS(1))>0 : Chgfmt [M:EMP3]DATISS(1)  With "-D:"+GFMT  : Raz [M:EMP3]DATISS(1) : Endif
  If dim([M:EMP3]DATISS(2))>0 : Chgfmt [M:EMP3]DATISS(2)  With "-D:"+GFMT  : Raz [M:EMP3]DATISS(2) : Endif
Endif

End
#ADNGO - 2017-08-22 - X3-53120 - END

#ADNGO - 2017-08-22 - X3-53120 - START
Subprog AV_DATRTR(VALEUR)
Variable Date    VALEUR
If !func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) Then
  If dim([M:EMP3]DATRTR(0))>0 : Chgfmt [M:EMP3]DATRTR(0)  With "-D:"+GFMT  : Raz [M:EMP3]DATRTR(0) : Endif
  If dim([M:EMP3]DATRTR(1))>0 : Chgfmt [M:EMP3]DATRTR(1)  With "-D:"+GFMT  : Raz [M:EMP3]DATRTR(1) : Endif
  If dim([M:EMP3]DATRTR(2))>0 : Chgfmt [M:EMP3]DATRTR(2)  With "-D:"+GFMT  : Raz [M:EMP3]DATRTR(2) : Endif
Endif

End
