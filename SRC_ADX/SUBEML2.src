Grizo WADD6
Return

Subprog C_WSTRDATTRY(VALEUR)
Variable Date    VALEUR
Local Integer NOL
If VALEUR = [0/0/0] : End : Endif
NOL = find(VALEUR,[M]STRDATTRY(0..[M]NBRTRY-1))-1
If NOL>=0
 Gosub CHARGE_TRY
Else
 [M]WLIG2 = [M]NBRTRY
 Actzo WADD6
Endif
End

