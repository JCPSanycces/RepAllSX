Subprog C_CTYBRN(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)


#JOJAC - 2016-09-01 - X3PEOP-1621 - START
  If func AFNC.ACTIV("KFR") & func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #JOJAC - 2016-09-01 - X3PEOP-1621 - END
   If [M]CTYBRNSEE<>""
    #75590 : replace [M]CRY by [M]CRYBRN inside filters
    Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR & POSCTYCOD=[M]CTYBRNSEE
    Read [POS]POS0 First
    If fstat
     Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
    Endif
   Else
    Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
   Endif
   Read [POS]POS0 First
   Filter [POS]
   If fstat<=2
    [M]CTYBRNSEE = [F:POS]POSCTYCOD
    If left$([F:POS]POSCTYCOD,2)="2A" | left$([F:POS]POSCTYCOD,2)="2B"
     [M]DEPBRN    = left$([F:POS]POSCTYCOD,2)
    Else
     [M]DEPBRN    = left$([F:POS]POSCOD,2)
    Endif
    Affzo CTYBRNSEE,DEPBRN
   Endif
  #JOJAC - 2016-09-01 - X3PEOP-1621 - START
  Endif
  #JOJAC - 2016-09-02 - X3PEOP-1621 - END
End

