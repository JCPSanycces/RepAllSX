######################################################################################
Subprog C_WMEDTYP(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, I

#JASMI - 2016-10-28 - START
#If func AFNC.ACTIV("KPO")>0 & func AFNC.ACTIV("KSA")=0 & func AFNC.ACTIV("KFR")=0 Then
If func DIVPAYE.IS_KPO_LEG(GCURLEG)
#JASMI - 2016-10-28 - END
  Call C_WMEDTYP(VALEUR)  From SUBEMLKPO
Endif

# Issue X3-99531 - 2018-07-25 by BRBAN : added MEDTYP in the key
NOL=-1
If [M]WMEDDAT<>[0/0/0] Then
  For I=0 To [M]NBRVIS-1
    If [M]WMEDDAT=[M]MEDDAT(I) & VALEUR=[M]MEDTYP(I) Then
      NOL=I : Break
    Endif
  Next
Endif
If NOL>=0
 Gosub CHARGE_VIS
Else
 If [M]NBRVIS< dim([M]MEDDAT)
  [M]WLIG4 = [M]NBRVIS
  Actzo WADD4
  Call AFF_MEDORG([M]WMEDDAT,1)
  Affzo MEDCTY-MEDORG
 Else
  GMESSAGE=mess(26,100,1) #: Tableau plein
  mkstat=2 : End
 Endif
Endif

End

