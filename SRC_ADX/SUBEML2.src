######################################################################################
## Section automatically added (screen HRMAT3) 10/11/2017 13:05:04 (ANCOA)
######################################################################################
Subprog C_PASNUM(VALEUR)
Variable Char    VALEUR()

  If GCURLEG='BRI' & num$(VALEUR) <> num$([M:EMP3]PASNUM(nolign-1))
    If [M:EMP3]PASDATNEW(nolign-1) = [0/0/0] or [M:EMP3]PASDATNEW(nolign-1) = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
      [M:EMP3]PASAMD(nolign-1) = 1
      Affzo [M:EMP3]PASAMD(nolign-1)
    Else
      [M:EMP3]PASAMD(nolign-1) = 2
      [M:EMP3]PASDATAMD(nolign-1) = [0/0/0]
      Affzo [M:EMP3]PASDATAMD(nolign-1)
      Affzo [M:EMP3]PASAMD(nolign-1)
    Endif
  Endif
End


