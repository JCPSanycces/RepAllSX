# FQ81085 US524 - SEGAY 05/07/12 Multi_leg & multi_soci‚t‚
Subprog AM_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Char    CRITCTRL (250), SOC(GLONCPY), VOIDCHAR(250)
Local Char TMPLEG (20)
Local Integer OK

# Multi_leg & multi_soci‚t‚
If VALEUR<>""

 Call SETCPYLGEG(0,"",VALEUR,[M:EMP0]CIV) From SUBEML2
# Call SETCPYLGEG(1,"",VALEUR,[M:EMP0]CIV) From SUBEML2
 If mkstat = 2 : End : Endif
# If GREP="C" Then
#  Read [F:ID]ID0=[M]REFNUM
#  If !fstat & [F:ID]FCYORI<>"" & [F:ID]FCYORI<>VALEUR Then
#    Call AVERTIR(mess(129,10701,1),OK) From GESECRAN : # La l‚gislation de ce site est diff‚rente de celle du site principal du salari‚
#    If OK=1 : mkstat = 2 : End : Endif
#  Endif
# Endif
Else
 [M:EMP0]CPYORI=GSOCIETE
 If dim([M:EMP0]LEGORI)>0
   [M:EMP0]LEGORI=GCURLEG
 Endif
Endif
If dim([M:EMP0]LEGORI)>0
  Affzo [M:EMP0]LEGORI
  Affzo [M:EMP0]ZLEGORI
Endif

#FQ 82362 -MABOS-15/10/2012- Hide or not the social numbers
[M:EMP0]FCYORI=VALEUR
# if main sit country ="" -> RAZ social number + not seizable
Local Char PAYSSIT (5)
PAYSSIT = func TRTDIV.LECPAYSIT([M:EMP0]FCYORI)
If PAYSSIT =""
  [M:EMP2]NUMSSC=""
  [M:EMP2]NUMSSC2=""
Endif
Affzo [M:EMP2]NUMSSC, NUMSSC2
If PAYSSIT =""
 Grizo [M:EMP2]NUMSSC, NUMSSC2
  Else
 Actzo [M:EMP2]NUMSSC, NUMSSC2
Endif

End


