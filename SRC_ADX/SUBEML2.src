################################################################################
##                             Ecran HRMAT10 - Infos diverses
################################################################################
Subprog AS_NBRVIS
Gosub SETNOL
If NOL>=0 & [M]NBRVIS>0
 If NOL<=[M]NBRVIS
  Gosub CHARGE_VIS
 Else
  Effzo 20-50
 Endif
Endif
End

Subprog FIRST_NBRVIS
Local Integer NOL
NOL=0

Gosub CHARGE_VIS
End

Subprog C_NBRVIS
If status=82 : mkstat = 1 : Endif
If find(status,65,68,83)
 [M]FLGADD = 1
 If [M]NBRVIS=1 | [M]NBRVIS=nolign1-nolign+1 :  Effzo MEDNEX-WMEDDAT : Grizo WMEDOBS-WMEDHOU : Endif
Endif
End

$CHARGE_VIS
Local Char PREFIXE(4)
PREFIXE = "WMED"
Gosub CHARGE_W

#JASMI - 2016-10-28 - START
If NOL=0
  If [M]WMEDCTR<>"" & [M]WMEDDAT<>[0/0/0]
  Local Integer WOK
  Local Integer WDISPMSG
  Local Char WRESULT
    WOK=0
    Call GET_LEGHRCTRDAT([M:EMP0]REFNUM,[M]WMEDCTR,[M]WMEDDAT,WOK,WRESULT,0) From TOOLSHRLEG
    If WOK
      [M]WMEDLEG=WRESULT
      [M]WMEDCPY=[F:CPY]CPY
    Endif
  Endif
Endif
#JASMI - 2016-10-28 - END

#[M]WLIG4      = NOL
If [M]WMEDDAT=[0/0/0]
 Effzo MEDCTY-MEDORG, MEDNEX
 Grizo WMEDOBS-WMEDHOU
Else
 Actzo WMEDOBS-WMEDHOU
 Call AFF_MEDORG([M]WMEDDAT,0)
Endif

# Multi_leg & multi_soci‚t‚
If [M]WMEDCTR<>"" & [M]WMEDDAT<>[0/0/0]
# FQ81085 US524 - SEGAY 05/07/12
# Filter [HRCTR] Where REFNUM=[F:ID]REFNUM & CTRNUM=[M]WMEDCTR & CTRDAT<=[M]WMEDDAT
# Read [HRCTR]CTR1 Last
# Filter [HRCTR]
# If !fstat
#  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#  GSOCIETE et GCURLEG init in $LIEN
#  GSOCIETE=[F:CPY]CPY : GCURLEG=[F:CPY]LEG
# Endif
# FQ81085 US525 - SEGAY 05/07/12
   Local Integer WOK
   Local Integer WDISPMSG
   Local Char WRESULT
   WOK=0
   Call GET_LEGHRCTRDAT([M:EMP0]REFNUM,[M]WMEDCTR,[M]WMEDDAT,WOK,WRESULT,0) From TOOLSHRLEG
   If WOK
     [M]WMEDLEG=WRESULT
     [M]WMEDCPY=[F:CPY]CPY
   Endif
# END FQ81085 US525 - SEGAY 05/07/12

   If [M]WMEDDAT<>[0/0/0] & [M]MEDTYP>""
    Read [F:HRMDT]HRMDT0=[M]MEDTYP;[M]WMEDLEG
    If !fstat
     [M]MEDNEX=addmonth([M]WMEDDAT,[F:HRMDT]NBRMON)
    Endif
   Endif

Endif

If [F:ID]FLGMULCTR<>2
 Diszo WMEDCTR
Else
 Actzo WMEDCTR
Endif
Diszo MEDORG
Grizo WADD4
Affzo 20
Return

$DECHARGE_VIS
Local Char PREFIXE(4)
PREFIXE = "WMED"
Gosub DECHARGE_W
[M]WLIG4          = NOL
Grizo WADD4
Return

Subprog C_WMEDDAT(VALEUR)
Variable Date    VALEUR
Local Integer NOL
If VALEUR = [0/0/0]
 If [M]NBRVIS=0 :  Effzo MEDNEX-WMEDHOU : Grizo WMEDOBS-WMEDHOU : Endif
 End
Endif
Actzo WMEDOBS-WMEDHOU


# Issue X3-99531 - 2018-07-25 by BRBAN : Update the MED1 key
#NOL = find(VALEUR,[M]MEDDAT(0..[M]NBRVIS-1))-1
NOL=-1
If [M]WMEDTYP<>"" Then
  For I=0 To [M]NBRVIS-1
    If VALEUR=[M]MEDDAT(I) & [M]WMEDTYP=[M]MEDTYP(I) Then
      NOL=I : Break
    Endif
  Next
Endif

If NOL>=0
 Gosub CHARGE_VIS
Else
 If [M]NBRVIS< dim([M]MEDDAT)
  [M]WLIG4 = [M]NBRVIS
  Actzo WADD4
  Call AFF_MEDORG(VALEUR,1)
  Affzo MEDCTY-MEDORG
 Else
  GMESSAGE=mess(26,100,1) #: Tableau plein
  mkstat=2 : End
 Endif
Endif
End

######################################################################################
## Etiquette ajout‚e par le superviseur (‚cran HRMAT10) 20/04/2012 15:52:53 (DBA)
######################################################################################
Subprog AM_WMEDCTR(VALEUR)
Variable Char    VALEUR()
# FQ81085 US525 - SEGAY 05/07/12
 If dim([M]WMEDLEG)>0
   Local Integer WOK
   Local Integer WDISPMSG
   Local Char WRESULT
   WOK=0
   Call GET_LEGHRCTRDAT([M:EMP0]REFNUM,VALEUR,[M]WMEDDAT,WOK,WRESULT,0) From TOOLSHRLEG
   If WOK
     [M]WMEDLEG=WRESULT
     [M]WMEDCPY=[F:CPY]CPY
   Endif
  Endif
# FQ83765 - SEGAY 05/07/12
  [M]MEDCTR([M]WLIG4) = VALEUR
  [M]FLGMOD([M]WLIG4) = 1
  Call AFF_MEDORG([M]WMEDDAT,0)
  Affzo MEDCTY-MEDORG
  Call CONTHRMDT([M]WMEDTYP,[M]WMEDLEG,"") From SUBHRMDT
  If mkstat
   mkstat=0
   Call MESSAGE(GMESSAGE) From GESECRAN
   GMESSAGE=""
   zonsui ="[M]WMEDTYP"
   End
  Endif
  Call CONTHRMDP([M]WMEDAPT,[M]WMEDLEG,"") From SUBHRMDP
  If mkstat
   mkstat=0
   Call MESSAGE(GMESSAGE) From GESECRAN
   GMESSAGE=""
   zonsui ="[M]WMEDAPT"
   End
  Endif
# END FQ83765 - SEGAY 05/07/12
# END FQ81085 US525 - SEGAY 05/07/12
End


Subprog AM_WMEDHOU(VALEUR)
Variable Char    VALEUR()
[M]MEDHOU([M]WLIG4) = VALEUR
[M]FLGMOD([M]WLIG4) = 1
End

Subprog AM_WMEDDCT(VALEUR)
Variable Char    VALEUR()
[M]MEDDCT([M]WLIG4) = VALEUR
[M]FLGMOD([M]WLIG4) = 1
End

Subprog AS_WMEDTYP(VALEUR)
Variable Char    VALEUR()
# FQ81085 US525 - SEGAY 05/07/12
 If dim([M]WMEDLEG)>0 & [M]WMEDLEG <> ""
   GCURLEG =[M]WMEDLEG
 Endif
 If dim([M]WMEDCPY)>0
   GSOCIETE=[M]WMEDCPY
 Endif
# END FQ81085 US525 - SEGAY 05/07/12

If [L]VALEUR>"" | [M]NBRVIS<1 : End : Endif
[L]VALEUR=[M]MEDTYP(find(max([M]MEDDAT),[M]MEDDAT)-1)
End

Subprog AM_WMEDTYP(VALEUR)
Variable Char    VALEUR()
[M]MEDTYP([M]WLIG4) = VALEUR
[M]FLGMOD([M]WLIG4) = 1
If [M]WMEDDAT<>[0/0/0]
# FQ81085 US525 - SEGAY 05/07/12
# Read [F:HRMDT]HRMDT0=VALEUR;GCURLEG
 Read [F:HRMDT]HRMDT0=VALEUR;[M]WMEDLEG
 If !fstat
  [M]MEDNEX=addmonth([M]WMEDDAT,[F:HRMDT]NBRMON)
 Endif
 Affzo [M]MEDNEX
Endif
End


# FQ81085 US525 - SEGAY 05/07/12
Subprog AP_WMEDTYP(VALEUR)
Variable Char    VALEUR()
 If dim(GCURLEG)>0
   GCURLEG=[M:EMP0]LEGORI
Endif
If dim(GSOCIETE)>0
   GSOCIETE=[M:EMP0]CPYORI
Endif
End


# FQ81085 US525 - SEGAY 05/07/12
Subprog AS_WMEDAPT(VALEUR)
Variable Char    VALEUR()
# FQ81085 US525 - SEGAY 05/07/12
 If dim(GCURLEG)>0 & dim([M]WMEDLEG)>0 & [M]WMEDLEG <> ""
   GCURLEG =[M]WMEDLEG
 Endif
 If dim(GSOCIETE)>0 & dim([M]WMEDCPY)>0
   GSOCIETE=[M]WMEDCPY
 Endif
# END FQ81085 US525 - SEGAY 05/07/12

End

# FQ81085 US525 - SEGAY 05/07/12
Subprog AP_WMEDAPT(VALEUR)
Variable Char    VALEUR()
If dim(GCURLEG)>0
   GCURLEG=[M:EMP0]LEGORI
Endif
If dim(GSOCIETE)>0
   GSOCIETE=[M:EMP0]CPYORI
Endif
End


######################################################################################


Subprog AFF_MEDORG(DAT,FLGSEL)
Value Date    DAT
Value Integer FLGSEL
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif
#MIPEA - 2016-09-28 - X3PEOP-752 - END
#If !GPAYE : Return : Endif
# FQ81085 US525 - SEGAY 05/07/12
If dim(GCURLEG)>0 : Local Char SAV2_GCURLEG(GLONADI) : SAV2_GCURLEG = GCURLEG   : Endif
If dim(GSOCIETE)>0 : Local Char SAV2_GSOCIETE(GLONCPY) : SAV2_GSOCIETE = GSOCIETE   : Endif
If FLGSEL
# FQ81085 US525 - SEGAY 05/07/12
# Call SELCTR([F:ID]REFNUM,DAT,DAT,[M]WMEDCTR) From DIVPAYE
 Call SELCTRMLEG([F:ID]REFNUM,DAT,DAT,"",[M]WMEDCTR) From TOOLSHRLEG
# END FQ81085 US525 - SEGAY 05/07/12
 If GMESSAGE<>""
  If dim(GCURLEG)>0 : GCURLEG=SAV2_GCURLEG    : Endif
  If dim(GSOCIETE)>0 : GSOCIETE=SAV2_GSOCIETE : Endif
  mkstat = 2 : End
 Endif
 [M]MEDCTR([M]WLIG4) = [M]WMEDCTR
 If [F:ID]FLGMULCTR<>2
  Diszo WMEDCTR
 Else
  Actzo WMEDCTR
 Endif
 Affzo [M]WMEDCTR
 # FQ81085 US525 - SEGAY 05/07/12
 If dim(GCURLEG)>0
  [M]WMEDLEG=GCURLEG
 Endif
 If dim(GSOCIETE)>0
  [M]WMEDCPY=GSOCIETE
 Endif
 # END FQ81085 US525 - SEGAY 05/07/12
Endif
#72680
If !GPAYE : End : Endif

Call LECTURE("FCY",[F:ID]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
# FQ81085 US525 - SEGAY 05/07/12
If dim(GCURLEG)>0
  GCURLEG=[M]WMEDLEG
Endif
If dim(GSOCIETE)>0
  GSOCIETE=[M]WMEDCPY
Endif

#MIPEA - 2016-09-28 - X3PEOP-752 - START
Filter [ADIZZ]
Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
  If [ADIZZ]CODE = [V]GINDMED
    [L]ORGLINE=[L]COUNTER-1 : Break
  Endif
Next
# END FQ81085 US525 - SEGAY 05/07/12
Call ORGANISME([F:ID]REFNUM,[F:ID]FCY,[M]WMEDCTR,[M]MEDORG,[L]ORGLINE) From SUBORG
#Call ORGANISME([F:ID]REFNUM,[F:ID]FCY,[M]WMEDCTR,[M]MEDORG,[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END

Call LECTURE("ORG",[M]MEDORG,[F:CPY]LEG) From CONTOBJ
# FQ81085 US525 - SEGAY 05/07/12
If dim(GCURLEG)>0
  GCURLEG=SAV2_GCURLEG
Endif
If dim(GSOCIETE)>0
  GSOCIETE=SAV2_GSOCIETE
Endif
# END FQ81085 US525 - SEGAY 05/07/12
For I=0 To 2 : [M]MEDADD(I)=[F:ORG]ADD(I) : Next
[M]MEDCTY=[F:ORG]CTY
[M]MEDPOS=[F:ORG]POS
End

Subprog AM_WMEDAPT(VALEUR)
Variable Char    VALEUR()
[M]MEDAPT([M]WLIG4) = VALEUR
[M]FLGMOD([M]WLIG4) = 1
End

Subprog AM_WMEDOBS(VALEUR)
Variable Char    VALEUR()
[M]MEDOBS([M]WLIG4) = VALEUR
[M]FLGMOD([M]WLIG4) = 1
End

Subprog AS_WADD4(VALEUR)
Variable Integer VALEUR
Local    Integer I, NOL
# Issue X3-99531 - 2018-07-25 by BRBAN : added MEDYTP in the key
#If [M]WMEDDAT<>[0/0/0] & !find([M]WMEDDAT,[M]MEDDAT(0..[M]NBRVIS-1))
If [M]WMEDDAT<>[0/0/0]
 NOL=-1
 For I=0 To [M]NBRVIS-1
   If [M]WMEDDAT=[M]MEDDAT(I) & [M]WMEDTYP=[M]MEDTYP(I) Then
     NOL=I : Break
   Endif
 Next
 If NOL=-1
   [M]FLGADD = 1
   NOL = [M]NBRVIS
   Gosub DECHARGE_VIS
   [M]NBRVIS += 1
   Sorta [M]NBRVIS [M]NBRVIS Order By [M]MEDDAT([S]indice)Desc
   Affzo 10
   VALEUR = 1
  # Issue X3-99531 - 2018-07-25 by BRBAN : added MEDYTP in the key
  # [M]WLIG4 = find([M]WMEDDAT,[M]MEDDAT(0..[M]NBRVIS-1))
   [M]WLIG4=-1
   For I=0 To [M]NBRVIS-1
     If [M]WMEDDAT=[M]MEDDAT(I) & [M]WMEDTYP=[M]MEDTYP(I) Then
       [M]WLIG4=I : Break
     Endif
   Next
   If !GBROWS : zonsui = "WMEDDAT" : Endif
 Endif
Endif
End

