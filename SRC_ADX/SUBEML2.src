#79333
Subprog CAL_NCKNAM (SURNAM, NAM)
Value Char SURNAM ()
Value Char NAM ()
#80910
Local Char ZONE(10)

ZONE = "NCKNAM"
Gosub SET_ZONE
If MA
#
 # R‚init des initiales que si vide ou si en cr‚ation \duplication
 If [M]NCKNAM="" | GREP="C" | GREP="D"
# FQ81085 US525 - SEGAY 05/07/12 format=C only blank
#  [M]NCKNAM=toupper(left$(SURNAM,2)+left$(NAM,3))

  [M]NCKNAM=toupper(left$(vireblc(SURNAM,4),2)+left$(vireblc(NAM,4),3))

  #If GCURLEG= "ZAF"
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
    MYLEN = len(SURNAM)
    INIT=toupper(left$(vireblc(SURNAM,4),1))

    For I = 2 To MYLEN
      If mid$(SURNAM,I,1) = " " Then
        INIT+=mid$(SURNAM,I+1,1)
      Endif
    Next

    INIT=toupper(vireblc(INIT,4))
    [M]NCKNAM=INIT

  #append initials from second name
    If [M]SECNAM<>""
      MYLEN = len([M]SECNAM)
      INIT=toupper(left$(vireblc([M]SECNAM,4),1))

      For I = 2 To MYLEN
        If mid$([M]SECNAM,I,1) = " " Then
          INIT+=mid$([M]SECNAM,I+1,1)
        Endif
      Next

      INIT=toupper(vireblc(INIT,4))
      [M]NCKNAM+=INIT
    Endif
    Affzo [M]NCKNAM
  Endif

  Affzo [M]NCKNAM
 Else
  If instr ( 1, [M]NCKNAM, " " ) > 0
    [M]NCKNAM=vireblc([M]NCKNAM,4) # FQ81085 US525 - SEGAY 05/07/12 format=C only blank
    Affzo [M]NCKNAM
  Endif
 Endif
Endif
End
