[M]MENEXM([M]WLIG1)  = VALEUR
[M]FLGMOD1([M]WLIG1) = 1
End

Subprog AS_WADD5(VALEUR)
Variable Integer VALEUR
If [M]WDATEXM<>[0/0/0] & !find([M]WDATEXM,[M]DATEXM(0..[M]NBREXM-1))
 [M]FLGADD1 = 1
 Local Integer NOL
 NOL = [M]NBREXM
 Gosub DECHARGE_EXM
 [M]NBREXM += 1
 #29411
 Sorta [M]NBREXM [M]NBREXM Order By [M]DATEXM([S]indice)Desc
 Affzo 10
 VALEUR = 1
 [M]WLIG1 = find([M]WDATEXM,[M]DATEXM(0..[M]NBREXM-1))
 If !GBROWS : zonsui = "WDATEXM" : Endif #72698
Endif
End

Subprog AS_WDATEXMEND(VALEUR)
Variable Date    VALEUR
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
End

Subprog AS_WDESEXM(VALEUR)
Variable Char    VALEUR()
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
End

Subprog AS_WMENEXM(VALEUR)
Variable Char    VALEUR()
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
End

Subprog AS_WDOMEXM(VALEUR)
Variable Char    VALEUR()
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
# FQ81085 - MABON 07/09/12 - US774 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
#GCURLEG2 = GCURLEG
GCURLEG2 = ""
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If [M]WLEVEXM<>"" Then
  Read [F:ADI]CODE=10382;[M]WLEVEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
If [M]WORGEXM<>"" Then
  Read [F:ADI]CODE=10383;[M]WORGEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# Si aucun des autres champs n'est renseign‚, on r‚cupŠre la leg du champ en cours
If GCURLEG2="" Then
  Read [F:ADI]CODE=10381;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# End MABON
End

Subprog AS_WLEVEXM(VALEUR)
Variable Char    VALEUR()
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
# FQ81085 - MABON 07/09/12 - US774 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
#GCURLEG2 = GCURLEG
GCURLEG2 = ""
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If [M]WDOMEXM<>"" Then
  Read [F:ADI]CODE=10381;[M]WDOMEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
If [M]WORGEXM<>"" Then
  Read [F:ADI]CODE=10383;[M]WORGEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# Si aucun des autres champs n'est renseign‚, on r‚cupŠre la leg du champ en cours
If GCURLEG2="" Then
  Read [F:ADI]CODE=10382;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# End MABON
End

Subprog AS_WORGEXM(VALEUR)
Variable Char    VALEUR()
If [M]WDATEXM=[0/0/0] : mkstat=1 : End : Endif
# FQ81085 - MABON 07/09/12 - US774 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
#GCURLEG2 = GCURLEG
GCURLEG2 = ""
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If [M]WDOMEXM<>"" Then
  Read [F:ADI]CODE=10381;[M]WDOMEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
If [M]WLEVEXM<>"" Then
  Read [F:ADI]CODE=10382;[M]WLEVEXM
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# Si aucun des autres champs n'est renseign‚, on r‚cupŠre la leg du champ en cours
If GCURLEG2="" Then
  Read [F:ADI]CODE=10383;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
# End MABON
End

