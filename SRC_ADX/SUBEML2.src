Subprog C_MODSTL(VALEUR)
Variable Char    VALEUR()

Local Shortint I



For I=0 To [M]NBRRIB-1
 If I<>nolign-1 & [M]TYPPAY(I)=[M]TYPPAY(nolign-1) & [M]MODSTL(I)<>[L]VALEUR
  [V]GMESSAGE=func AFNC.MES2(mess(24,10701,1),num$(I+1),[M]MODSTL(I))
  #           Un type de paiement ne peut avoir qu'un seul mode de rŠglement.
  #           Or la ligne $1$ a d‚j… le mode $2$
  mkstat     =2
  Break
 Endif
Next
If mkstat : End : Endif
Read [ADI]CODE=10387;VALEUR
If !fstat
#MIPEA - 2017-06-14- US X3-11287- START
 If [F:ADI]N1=2 :#espŠce
  [M]BANCAI(nolign-1)="HRCAI"
 Else
  [M]BANCAI(nolign-1)="HRBAN"
 Endif
# If [F:ADI]N1=2 :#espŠce
#  [M]BANCAI(nolign-1)="CAI"
# Else
#  [M]BANCAI(nolign-1)="BAN"
# Endif
#MIPEA - 2017-06-14- US X3-11287- END
Endif
End

Subprog C_CPYBAN(VALEUR)
Variable Char    VALEUR()
Read [ADI]CODE=10387;[M]MODSTL(nolign-1)
If !fstat
#MIPEA - 2017-06-14- US X3-11287- START
 If [F:ADI]N1=2 :#espŠce
  [M]BANCAI(nolign-1)="HRCAI"
 Else
  [M]BANCAI(nolign-1)="HRBAN"
 Endif
# If [F:ADI]N1=2 :#espŠce
#  [M]BANCAI(nolign-1)="CAI"
# Else
#  [M]BANCAI(nolign-1)="BAN"
# Endif
#MIPEA - 2017-06-14- US X3-11287- END
Endif
If VALEUR<>""
 Call CONTROLE([M]BANCAI(nolign-1),"",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End


