Subprog C_LNKPAR(VALEUR)
Variable Char    VALEUR()
Local Integer WI
Local Char PAR(180)
  VALEUR=vireblc(VALEUR,2)
  If VALEUR="" : End : Endif
  For WI=1 To [M]NBRJNT
      [L]PAR=vireblc([M]SJNTNAM(WI-1)-[M]SJNTSRN(WI-1),2)
      If toupper(left$([L]PAR,len(VALEUR)))=toupper(VALEUR)
&        & len([L]PAR) = len(VALEUR)
        End : # on a trouv‚, on sort
      Elsif toupper(left$([L]PAR,len(VALEUR)))=toupper(VALEUR)
        VALEUR=[L]PAR
        End : # on a trouv‚, on sort
      Else

      Endif
  Next
  GMESSAGE = VALEUR - mess(171,10701,1) : mkstat=2
  #'doit ˆtre d‚fini comme conjoint
End

