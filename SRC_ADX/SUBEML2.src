######################################################################################
Subprog SETCODUE(PAYS,NUMCOD)
Value Char PAYS
Variable Integer NUMCOD
Case PAYS
 When 'FR' :
  NUMCOD=1         :#Fran‡ais
 When Default :
  If clalev([F:WTCY]) =0 : Local File TABCOUNTRY [WTCY] : Endif
  Read [F:WTCY]TCY0 = PAYS
  If !fstat
   If [F:WTCY]EECFLG=2
    NUMCOD=2        :#Ressortissant de l'UE
   Elsif [F:WTCY]FLGSEPA=2
    NUMCOD=3        :#Ressortissant de l'EEE
   Else
    NUMCOD=4        :#Ressortissant hors EEE
   Endif
  Endif
  Close Local File [WTCY]
Endcase
End
######################################################################################
## Section automatically added (screen HRMAT2) 04/12/2016 15:48:58 (MAPAD)
######################################################################################
Subprog AS_CODUE(VALEUR)
Variable Integer VALEUR
If !VALEUR & [M]NTT<>""
 Call SETCODUE([M]NTT,VALEUR)
Endif
End

Subprog C_CODUE(VALEUR)
Variable Integer VALEUR
Local Integer RESULT, OK
Call SETCODUE([M]NTT,RESULT)
If RESULT<>VALEUR
 # Valeur incorrecte
 OK = 2
 Call AVERTIR (mess(1,10702,1)-'('+[M]NTT+')',OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End


