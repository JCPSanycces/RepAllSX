Affzo
Return

################################################################################
## Chargement et d‚chargement des variables commencant par W
################################################################################
$CHARGE_W
Local Integer I
Local Char    CLASSE(10) , NAMFLD(GLONAVA), DESEXM, NUMADI
CLASSE = clanam([M])
For I=1 To clanbs([M],1)
 NAMFLD = clavar([M],I)
 If left$(NAMFLD,1)="W" & evalue("dim("+CLASSE+right$(NAMFLD,2)+")")>0
  #LIPET - 2017-04-12 - X3-30751 - START
# If dim([L]SUFFIXE)<=0 or pat(NAMFLD,"*"+SUFFIXE) or pat(NAMFLD,"*"+SUFFIXE+"#")
  If dim([L]SUFFIXE)<=0 or pat(NAMFLD,"*"+SUFFIXE) or pat(NAMFLD,"*"+SUFFIXE+"#") or pat(NAMFLD,"*"+SUFFIXE+"???")    :#110316
  #LIPET - 2017-04-12 - X3-30751 - END
   If dim([L]PREFIXE)<=0 or pat(NAMFLD,PREFIXE+"*")
    Assign CLASSE+NAMFLD With evalue(CLASSE+right$(NAMFLD,2)+"("+num$(NOL)+")")
    # FQ81085 - MABON 07/09/12 - US774 To allow a domain, theme or organism in a different legislation than the contract
    # we had to change the datatype of these fields. So we have to get the title by a LECTEXTRA
    If evalue("dim("+CLASSE+left$(NAMFLD,4)+"DES)")>0 Then
      If evalue(CLASSE+NAMFLD)<>"" Then
        Case NAMFLD
          When "WSTATRY" : NUMADI="10380"
          When "WDOMEXM" : NUMADI="10381"
          When "WLEVEXM" : NUMADI="10382"
          When "WORGEXM" : NUMADI="10383"
        Endcase
        Call LECTEXTRA(DESEXM,"ATABDIV","LNGDES",NUMADI,evalue(CLASSE+NAMFLD)) From ATEXTRA
        Assign CLASSE+left$(NAMFLD,4)+"DES" With DESEXM
      Else
        Assign CLASSE+left$(NAMFLD,4)+"DES" With ""
      Endif
    Endif
    # End MABON
   Endif
  Endif
 Endif
Next I
Return

$DECHARGE_W
Local Integer I
Local Char    CLASSE(10) , NAMFLD(GLONAVA)
CLASSE = clanam([M])
For I=1 To clanbs([M],1)
 NAMFLD = clavar([M],I)
 If left$(NAMFLD,1)="W" & evalue("dim("+CLASSE+right$(NAMFLD,2)+")")>0
  If dim([L]SUFFIXE)<=0 or pat(NAMFLD,"*"+SUFFIXE) or pat(NAMFLD,"*"+SUFFIXE+"#")
   If dim([L]PREFIXE)<=0 or pat(NAMFLD,PREFIXE+"*")
    Assign CLASSE+right$(NAMFLD,2)+"("+num$(NOL)+")" With evalue(CLASSE+NAMFLD)
   Endif
  Endif
 Endif
Next I
Return

