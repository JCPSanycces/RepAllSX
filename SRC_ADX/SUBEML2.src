$INIWVARCIV
Local Char WCIVA
Local Char WREFNUM
Local Integer WCIV
Local Char    LISTLEG(5)(1..10), WFLDLEG
Local Char    WCRIT(250)
Local Integer WNBLEG
ZONE = "CIVA"
Gosub SET_ZONE
If MA
  WCIVA = [M]CIVA
Endif
ZONE = "CIV"
Gosub SET_ZONE
If MA
   WCIV = [M]CIV
Endif
ZONE = "REFNUM"
Gosub SET_ZONE
If MA
   WREFNUM = [M]REFNUM
Endif
ZONE = "LEGORI"
Gosub SET_ZONE
If MA
  WFLDLEG = [M]LEGORI
Endif
