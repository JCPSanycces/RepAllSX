# FQ81085 - MABON 07/09/12 - US774 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
Subprog C_WDOMEXM(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  # On recalcule GCURLEG2 si les autres champs sont vides
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If [M]WLEVEXM="" & [M]WORGEXM="" Then
    Read [F:ADI]CODE=10381;VALEUR
    If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  Endif
  Call CONTADI_SANS_LEG(VALEUR,"10381","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End

Subprog C_WLEVEXM(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  # On recalcule GCURLEG2 si les autres champs sont vides
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If [M]WDOMEXM="" & [M]WORGEXM="" Then
    Read [F:ADI]CODE=10382;VALEUR
    If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  Endif
  Call CONTADI_SANS_LEG(VALEUR,"10382","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End

Subprog C_WORGEXM(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  # On recalcule GCURLEG2 si les autres champs sont vides
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  #LIPET - 2017-03-28 - X3-30770 - START
#  If [M]WDOMEXM="" & [M]WLEGEXM="" Then
#    Read [F:ADI]CODE=10383;VALEUR
#    If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  If [M]WDOMEXM=""  Then
    Read [F:ADI]CODE=10383;VALEUR
    If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  #LIPET - 2017-03-28 - X3-30770 - END
  Endif
  Call CONTADI_SANS_LEG(VALEUR,"10383","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End

Subprog C_WSTATRY(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  GCURLEG2 = ""
  Read [F:ADI]CODE=10380;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  Call CONTADI_SANS_LEG(VALEUR,"10380","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End
# End MABON

