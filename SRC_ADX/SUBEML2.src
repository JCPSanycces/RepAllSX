Subprog AS_NBRPAR
Gosub SETNOL
If NOL>=0 & [M]NBRPAR>0
 If NOL<=[M]NBRPAR
  Gosub CHARGE_PAR
 Else
  Effzo 20-50
 Endif
Endif
End

Subprog FIRST_NBRPAR
Local Integer NOL
NOL=0
Gosub CHARGE_PAR
End

Subprog C_NBRPAR
If status=82 : mkstat = 1 : Endif
If find(status,65,68,83)
 Effzo 20-50 : [M]FLGADD = 1
Endif
End

$CHARGE_PAR
Gosub CHARGE_W
Gosub CHARGE_TABLEAU
[M]WLIG7 = NOL
Affzo 20-50
Grizo WADD7
Return

$CHARGE_TABLEAU
#Participation
For I=1 To [M]NBRFDSPAR(NOL)
 [M]WFDSPAR(I-1)=evalue("[M]FDSPAR"+num$(I-1)+"(NOL)")
 [M]WFDSPARPRC(I-1)=evalue("[M]FDSPARPRC"+num$(I-1)+"(NOL)")
Next
#Interessement
For I=1 To [M]NBRFDSITS(NOL)
 [M]WFDSITS(I-1)=evalue("[M]FDSITS"+num$(I-1)+"(NOL)")
 [M]WFDSITSPRC(I-1)=evalue("[M]FDSITSPRC"+num$(I-1)+"(NOL)")
Next
Return

$DECHARGE_PAR
Gosub DECHARGE_W
Gosub DECHARGE_TABLEAU
[M]WLIG7 = NOL
Grizo WADD7
Return

DECHARGE_TABLEAU
For I=1 To [M]WNBRFDSPAR
 Assign "[M]FDSPAR"+num$(I-1)+"(NOL)" With [M]WFDSPAR(I-1)
 Assign "[M]FDSPARPRC"+num$(I-1)+"(NOL)" With [M]WFDSPARPRC(I-1)
Next
For I=1 To [M]WNBRFDSITS
 Assign "[M]FDSITS"+num$(I-1)+"(NOL)" With [M]WFDSITS(I-1)
 Assign "[M]FDSITSPRC"+num$(I-1)+"(NOL)" With [M]WFDSITSPRC(I-1)
Next
Return

#Init date participation … la date d'entr‚e ou date du jour
Subprog AS_WPARDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = date$
Endif
End

Subprog C_WPARDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] : End : Endif
NOL = find(VALEUR,[M]PARDAT(0..[M]NBRPAR-1))-1
If NOL>=0
 Gosub CHARGE_PAR
Else
 [M]WLIG7 = [M]NBRPAR
 Actzo WADD7
Endif
End

Subprog AS_WFLGPAR(VALEUR)
Variable Integer VALEUR
If [M]WPARDAT=[0/0/0]
 mkstat=1
 End
Endif
End

Subprog AM_WFLGPAR(VALEUR)
Variable Integer VALEUR
[M]FLGPAR([M]WLIG7) = VALEUR
[M]FLGMOD([M]WLIG7) = 1
If VALEUR=1
 For I=0 To [M]WNBRFDSPAR-1
  Raz [M]WFDSPAR(I),WFDSPARPRC(I)
  Assign "[M]FDSPAR"+num$(I)+"([M]WLIG7)" With ""
  Assign "[M]FDSPARPRC"+num$(I)+"([M]WLIG7)" With 0
 Next
 Raz [M]WNBRFDSPAR
 Raz [M]NBRFDSPAR([M]WLIG7)
 Affzo
Endif
End

Subprog AS_WFLGITS(VALEUR)
Variable Integer VALEUR
If [M]WPARDAT=[0/0/0]
 mkstat=1
 End
Endif
End

Subprog AM_WFLGITS(VALEUR)
Variable Integer VALEUR
Local    Integer I
[M]FLGITS([M]WLIG7) = VALEUR
[M]FLGMOD([M]WLIG7) = 1
If VALEUR=1
 For I=0 To [M]WNBRFDSITS-1
  Raz [M]WFDSITS(I),WFDSITSPRC(I)
  Assign "[M]FDSITS"+num$(I)+"([M]WLIG7)" With ""
  Assign "[M]FDSITSPRC"+num$(I)+"([M]WLIG7)" With 0
 Next
 Raz [M]WNBRFDSITS
 Raz [M]NBRFDSITS([M]WLIG7)
 Affzo
Endif
End

Subprog C_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]WFDSPAR(0..[M]NBRFDSPAR-1)) From OBJDIV
End

Subprog C_WFDSITS(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]WFDSITS(0..[M]NBRFDSITS-1)) From OBJDIV
End

Subprog AM_WFDSPAR(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Assign "[M]FDSPAR"+num$(NOL)+"([M]WLIG7)" With VALEUR
[M]FLGMOD([M]WLIG7) = 1
End

Subprog AM_WFDSITS(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Assign "[M]FDSITS"+num$(NOL)+"([M]WLIG7)" With VALEUR
[M]FLGMOD([M]WLIG7) = 1
End

Subprog AM_WFDSPARPRC(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Assign "[M]FDSPARPRC"+num$(NOL)+"([M]WLIG7)" With VALEUR
[M]FLGMOD([M]WLIG7) = 1
End

Subprog AM_WFDSITSPRC(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Assign "[M]FDSITSPRC"+num$(NOL)+"([M]WLIG7)" With VALEUR
[M]FLGMOD([M]WLIG7) = 1
End

Subprog C_WNBRFDSPAR
If adxgtb=0 & [M]WFLGPAR<>2 : mkstat=2 : End : Endif
#61642 : Sortie du tableau -> on raz & on restocke...
If adxgtb=2 : Gosub FDSPAR : Endif
End

#61642
$FDSPAR
#RAZ
For I=0 To dim([F]FDSPAR)-1
 Assign "[M]FDSPAR"+num$(I)+"([M]WLIG7)" With ""
 Assign "[M]FDSPARPRC"+num$(I)+"([M]WLIG7)" With 0
Next
#Restockage
For I=0 To [M]WNBRFDSPAR-1
 Assign "[M]FDSPAR"+num$(I)+"([M]WLIG7)" With [M]WFDSPAR(I)
 Assign "[M]FDSPARPRC"+num$(I)+"([M]WLIG7)" With [M]WFDSPARPRC(I)
Next
[M]NBRFDSPAR([M]WLIG7) = [M]WNBRFDSPAR
[M]FLGMOD([M]WLIG7) = 1
Return

Subprog C_WNBRFDSITS
If adxgtb=0 & [M]WFLGITS<>2 : mkstat=2 : End : Endif
#61642 : Sortie du tableau -> on raz & on restocke...
If adxgtb=2 : Gosub FDSITS : Endif
End

#61642
$FDSITS
#RAZ
For I=0 To dim([F]FDSITS)-1
 Assign "[M]FDSITS"+num$(I)+"([M]WLIG7)" With ""
 Assign "[M]FDSITSPRC"+num$(I)+"([M]WLIG7)" With 0
Next
#Restockage
For I=0 To [M]WNBRFDSITS-1
 Assign "[M]FDSITS"+num$(I)+"([M]WLIG7)" With [M]WFDSITS(I)
 Assign "[M]FDSITSPRC"+num$(I)+"([M]WLIG7)" With [M]WFDSITSPRC(I)
Next
[M]NBRFDSITS([M]WLIG7) = [M]WNBRFDSITS
[M]FLGMOD([M]WLIG7) = 1
Return

Subprog AM_WNBRFDSPAR
[M]NBRFDSPAR([M]WLIG7) = [M]WNBRFDSPAR
[M]FLGMOD([M]WLIG7) = 1
End

Subprog AM_WNBRFDSITS
[M]NBRFDSITS([M]WLIG7) = [M]WNBRFDSITS
[M]FLGMOD([M]WLIG7) = 1
End

Subprog AS_WADD7(VALEUR)
Variable Integer VALEUR
If [M]WPARDAT<>[0/0/0] & !find([M]WPARDAT,[M]PARDAT(0..[M]NBRPAR-1))
 [M]FLGADD = 1
 Local Integer NOL
 NOL = [M]NBRPAR
 Gosub DECHARGE_PAR
 [M]NBRPAR += 1
 Sorta [M]NBRPAR [M]NBRPAR Order By [M]PARDAT([S]indice)Desc
 Affzo 10
 VALEUR = 1
 [M]WLIG7 = find([M]WPARDAT,[M]PARDAT(0..[M]NBRPAR-1))
 If !GBROWS : zonsui = "WPARDAT" : Endif #72698
Endif
End

################################################################################
##                             Grisages / d‚grisages
################################################################################

$SET_ZONE
Local Integer MA , I
Local Char    AB(1)
MA=0
# FQ80566 - MABON 08/03/12 - Initialisation de la date de note de frais, en duplication
#For I=1 To 14
# AB = mid$("0123456789ABCD",I,1)
For I=1 To 15
 AB = mid$("0123456789ABCDE",I,1)
# Fin MABON
 If evalue("dim([M:EMP"+AB+"]"+ZONE+")")>0
  MA = I
  Break
 Endif
Next I
Case MA
 When  1 : Default Mask [EMP0]
 When  2 : Default Mask [EMP1]
 When  3 : Default Mask [EMP2]
 When  4 : Default Mask [EMP3]
 When  5 : Default Mask [EMP4]
 When  6 : Default Mask [EMP5]
 When  7 : Default Mask [EMP6]
 When  8 : Default Mask [EMP7]
 When 10 : Default Mask [EMP9]
 When 11 : Default Mask [EMPA]
 When 12 : Default Mask [EMPB]
 When 13 : Default Mask [EMPC]
 When 14 : Default Mask [EMPD]
 When 15 : Default Mask [EMPE] : # FQ80566 - MABON 08/03/12 - Initialisation de la date de note de frais, en duplication
Endcase
Return

Subprog GRISE_CONJOINT(VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "JNTNAM"
Local Char DISPLAYIND(2)
Gosub SET_ZONE
If MA
 # FQ81085 - 25/11/13 - On ne grise le conjoint que si on est leg FRA
   If VALEUR=1
    Effzo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Grizo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Call MRGDAT(VALEUR) From SUBEML2LEG
    Call SPOMDNNAM(VALEUR) From SUBEML2LEG
   Else
    Actzo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Call MRGDAT(VALEUR) From SUBEML2LEG
    Call SPOMDNNAM(VALEUR) From SUBEML2LEG
   Endif
Endif
End


Subprog GRISE_ETRANGER(VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "STG"
Gosub SET_ZONE
If MA
 If VALEUR=1
  Effzo STYCRD,DATSTY,WRKCRD,DATWRK
  Grizo STYCRD,DATSTY,WRKCRD,DATWRK
 Else
  Actzo STYCRD,DATSTY,WRKCRD,DATWRK
 Endif
Endif
End

