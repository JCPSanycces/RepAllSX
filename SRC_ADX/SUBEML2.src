Subprog C_FLGMULCTR(VALEUR)
Variable Integer VALEUR
Local Integer NB
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
# On passe le salari‚ de multi contrats en mono contrat
# alors qu'il a plusieurs contrats simultan‚s
If VALEUR<>2 & [M]FLGMULCTR=2
 Filter [CTR1] Where REFNUM=[M]REFNUM
 Raz NB
 For [CTR1]CTR0
  If [F:CTR1]XITDAT=[0/0/0]
   NB +=1
   If NB>1 : Break : Endif
  Endif
 Next
 Filter [CTR1]
 If NB>1
  # Le salari‚ a plusieurs contrats simultan‚s. Pour ˆtre mono contrat, les contrats doivent ˆtre successifs.
  GMESSAGE = mess(81,10701,1)
  mkstat = 2 : End
 Endif
Endif
## SBA
# only for french create function GINTMT + gcurleg=fra
If GINTMT=1
 Call GRISE_FLGINT(VALEUR)
 #61592
 If VALEUR<>2
  Call GRISE_NUMCCS([M]FLGINT)
 Endif
 #
Endif
End

Subprog AM_FLGINT(VALEUR)
Variable Integer VALEUR
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:PSN])=0    : Local File PRESTATION [PSN]   : Endif
If VALEUR=1 & [M]FLGINT=2 : # Pas intermittent
 Filter [HRCTR] Where REFNUM=[M:EMP0]REFNUM
 For [HRCTR]CTR1
  If [F:HRCTR]STACTR=2
  ##61597 : Si le contrat est valid‚ et qu'il n'y a pas de prestation … l'enregistrement
  #on remettra le contrat … 'Saisi' donc pas de message d'erreur a afficher !
   Read [PSN]PSN0=[F:HRCTR]CTRNUM;1
   If !fstat
    # Le salari‚ a un contrat valid‚ en tant qu'intermittent
    GMESSAGE = mess(31,10701,1)
    mkstat = 2 : Break
   Endif
  Endif
  Filter [PSN] Where CTRNUM=[F:HRCTR]CTRNUM
  For [PSN]PSN0
   If [F:PSN]BUL<>""
    # Le salari‚ a des prestations pay‚es en tant qu'intermittent
    GMESSAGE = mess(30,10701,1)
    mkstat = 2 : Break
   Endif
  Next
  Filter [PSN]
  If mkstat=2 : Break : Endif
 Next
 Filter [HRCTR]
 If mkstat=2 : End : Endif
Endif
End

Subprog C_FLGINT(VALEUR)
Variable Integer VALEUR
Call GRISE_NUMCCS(VALEUR)
Affzo NUMCCS
End

