Subprog CONTROLE_BIDNUM(VALEUR,PAYS)
Variable Char VALEUR()
Variable Char PAYS()
If VALEUR <>""
 Call CONTRIB(VALEUR,PAYS)From CONTNUM
Endif
End

#Controle validit‚ carte de s‚jour
Subprog CONTROLE_VALID(CARTE,VALID)
Variable Char CARTE()
Variable Date VALID
If CARTE<>""
 If VALID=[00/00/00]
  GMESSAGE = mess(23,10702,1) :# Date de valit‚ obligatoire pour les cartes de s‚jour et de travail
  mkstat = 1 : End
 Endif
Endif
End

#Controle no de dads
## A virer !!!!
Subprog CONTROLE_NUMDDS(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>2
  GMESSAGE = mess(1,10702,1) : # Valeur incorrecte
  mkstat = 1 : End
Endif
End

#Controle validit‚ taux handicap
Subprog CONTROLE_TXHDC(VALEUR)
Variable Decimal VALEUR
mkstat=0
If VALEUR>100 or VALEUR<0
  # Le taux maximum = 100
#  GMESSAGE = mess(215,10702,1)
  # Le taux de handicap doit ˆtre sup‚rieur ou egal … 0% et ne peut pas d‚passer 100%
  GMESSAGE = mess(245,10702,1) : # US2520 96993
  mkstat = 2
Endif
End

#Controle handicap
Subprog CONTROLE_HDC(TAUX,DATSTR,DATEND,MESHDC,DTX)
Variable Decimal TAUX(0..)
Variable Date DATSTR(0..)
Variable Date DATEND(0..)
Variable Char MESHDC()()
Variable Decimal DTX(0..)
Local Integer I,J,K,WOK
mkstat=0
GMESSAGE=""
K=1
WOK=1
# 94474  Rate not mandatory
Gosub WMESLINE_CTR_HDC
# END 94474
For I=0 To dim(TAUX)-1
    WOK =1
    If TAUX(I)<0 or TAUX(I) >100
       # Le taux de handicap doit ˆtre sup‚rieur … 0% et ne peut pas d‚passer 100%
#       MESHDC(K) = WMESLINE-num$(I+1)-mess(215,10702,1)
       # Le taux de handicap doit ˆtre sup‚rieur ou egal … 0% et ne peut pas d‚passer 100%
       MESHDC(K) = WMESLINE-num$(I+1)-mess(245,10702,1) : # US2520 96993
       K=K+1
       WOK =0
    Endif
    If WOK and DATEND(I)<DATSTR(I) and DATEND(I)<>[0/0/0]
       # Date de fin inf‚rieure … date de d‚but
       MESHDC(K)=WMESLINE-num$(I+1)-mess(217,10702,1)
       K=K+1
       WOK =0
    Endif
    If WOK and I<dim(TAUX)-1 and DATSTR(I)=[0/0/0] and DATSTR(I+1)<>[0/0/0]
       # Date de d‚but obligatoire
       MESHDC(K) = WMESLINE-num$(I+1)-mess(218,10702,1)
       K=K+1
       WOK =0
    Endif
# US2520 96993 - GESEML : Lever le contr“le sur le chevauchement des p‚riodes de handicap
#       If WOK and I<dim(TAUX)-1 and DATSTR(I+1)<>[0/0/0] and DATEND(I)=[0/0/0]
#          # Date de fin obligatoire
#          MESHDC(K) = WMESLINE-num$(I+1)-mess(223,10702,1)
#          K=K+1
#          WOK =0
#       Endif
#
#       If I>0
#         If WOK and ((DATSTR(I)<>[0/0/0] and DATSTR(I)<DATSTR(I-1)) or (DATEND(I)<>[0/0/0] and DATEND(I)<DATSTR(I-1)))
#          # Date incorrecte : les p‚riodes saisies doivent ˆtre chronologiques
#          MESHDC(K) = WMESLINE-num$(I+1)-mess(222,10702,1)
#          K=K+1
#          WOK =0
#         Endif
#         If WOK and ((DATSTR(I)<>[0/0/0] and DATSTR(I) <= DATEND(I-1)) or (DATEND(I)<>[0/0/0] and DATEND(I)<=DATEND(I-1)))
#          # Chevauchement de date
#          MESHDC(K)= WMESLINE-num$(I+1)-mess(221,10702,1)+" "+"("+WMESLINE-num$(I)+")"
#          K=K+1
#          WOK =0
#         Endif
#       Endif
#       If WOK
#         For J=I To 0 Step -1
#           If J<>I
#            If WOK and DATSTR(I)<>[0/0/0] and (DATSTR(I)<DATSTR(J) or (DATEND(I)<>[0/0/0] and DATEND(I)<DATSTR(J)))
#              # Date incorrecte : les p‚riodes saisies doivent ˆtre chronologiques
#              MESHDC(K) = WMESLINE-num$(I+1)-mess(222,10702,1)
#              K=K+1
#              WOK =0
#             Endif
#             If WOK and DATSTR(I)<>[0/0/0] and (DATSTR(I) <= DATEND(J) or (DATEND(I)<>[0/0/0] and DATEND(I)<=DATEND(J)))
#              # Chevauchement de date
#              MESHDC(K)= WMESLINE-num$(I+1)-mess(221,702,1)+" "+"("+WMESLINE-num$(I)+")"
#              K=K+1
#              WOK =0
#             Endif
#            Endif
#          Next J
#        Endif
#    Endif
    If !WOK : mkstat = 2  : TAUX(I)=0 : DATEND(I)=[0/0/0] : DATSTR(I)=[0/0/0] : Endif :# 94474  Rate not mandatory
Next I
End
# 94474  Rate not mandatory
$WMESLINE_CTR_HDC
Local Char WMESLINE(250) :
Local Integer WPOS1, WPOS2
WPOS1=instr( 1, mess(219,10702,1), '(')
WPOS2=instr( 1, mess(219,10702,1), ')')
Raz WMESLINE
If WPOS1 & WPOS1 < WPOS2
   WMESLINE = seg$(mess(219,10702,1),WPOS1+1,WPOS2-1)
Endif
Return
##########################################################################
#Controle pourcentage participation & interessement
##########################################################################
Subprog CONTROLE_PARTICIP
Local Decimal TOTPAR, TOTINT
For nolign=1 To [M]WNBRFDSPAR
 TOTPAR+=[M]WFDSPARPRC(nolign-1)
Next
For nolign=1 To [M]WNBRFDSITS
 TOTINT+=[M]WFDSITSPRC(nolign-1)
Next
If TOTPAR>100 | TOTINT>100
 #Total pourcentage incorrect
 GMESSAGE = mess(19,10706,1)
 GERR = 1 : End
Endif
End

################################################################################
#
# Notes de frais
#
################################################################################

$CHARGE_EXN0
[M]NBREXN0=0
For K=0 To [M]NBREXN-1
 If !find([M]EXSDAT(K),[M]EXSDAT0(0..[M]NBREXN0-1))
  [M]EXSDAT0([M]NBREXN0) =[M]EXSDAT(K)
  [M]NBREXN0            +=1
 Endif
Next
#29411
Sorta [M]NBREXN0 [M]NBREXN0 Order By [M]EXSDAT0([S]indice)Desc
Return

$CHARGE_EXN
If [M]WNBREXN : Dela 0, [M]WNBREXN [M]WNBREXN : [M]WNBREXN=0 : Endif
Local Integer I, J
[M]WLIG53=-1
[M]WLIG54=-1

For I=0 To [M]NBREXN-1
 If [M]EXSDAT(I)=[M]EXSDAT0([L]NOL)
  Case [M]EXSVAR(I)
  When "#10553"
   [M]WBKT  =[M]EXSAMT(I)
   [M]WLIG53=I
  When "#10554"
   [M]WCAT  =[M]EXSAMT(I)
   [M]WLIG54=I
  When Default
   [M]WEXSVAR(J) =[M]EXSVAR(I)
   [M]WEXSAMT(J) =[M]EXSAMT(I)
   # SEF : If dim([M]EXNS)>=J : [M]WEXNS(J)=[M]EXNS(I) : Endif
   [M]WLIG14 (J) =I
   J            +=1
  Endcase
 Endif
Next

# pour les enregs corrompus
If [M]WLIG53=-1 & [M]EXSDAT0([L]NOL)>[0/0/0]
 [M]EXSDAT(I) =[M]EXSDAT0([L]NOL)
 [M]EXSVAR(I) ="#10553"
 [M]WBKT      =0
 [M]WLIG53    =I
 I           +=1
 [M]NBREXN   +=1
 [M]FLGADD    =1
Endif
If [M]WLIG54=-1 & [M]EXSDAT0([L]NOL)>[0/0/0]
 [M]EXSDAT(I) =[M]EXSDAT0([L]NOL)
 [M]EXSVAR(I) ="#10554"
 [M]WCAT      =0
 [M]WLIG54    =I
 I           +=1
 [M]NBREXN   +=1
 [M]FLGADD    =1
Endif

[M]WEXSDAT=[M]EXSDAT0([L]NOL)
[M]WNBREXN=J
Affzo 20-40
Grizo WADD14
Return

$DECHARGE_EXN
Local Integer I, J
For I=0 To [M]WNBREXN-1
 [M]EXSDAT([L]NOL) =[M]WEXSDAT
 [M]EXSVAR([L]NOL) =[M]WEXSVAR(I)
 [M]EXSAMT([L]NOL) =[M]WEXSAMT(I)
 # SEF If dim([M]EXNS)>=[L]NOL : [M]EXNS([L]NOL)=[M]WEXNS(I) : Endif
 [M]FLGMOD([L]NOL) =1
 [M]WLIG14(I)      =[L]NOL
 [L]NOL           +=1
Next
[M]EXSDAT([L]NOL) =[M]WEXSDAT
[M]EXSVAR([L]NOL) ="#10554"
[M]EXSAMT([L]NOL) =[M]WCAT
[M]FLGMOD([L]NOL) =1
[M]WLIG54         =[L]NOL
[L]NOL           +=1
[M]EXSDAT([L]NOL) =[M]WEXSDAT
[M]EXSVAR([L]NOL) ="#10553"
[M]EXSAMT([L]NOL) =[M]WBKT
[M]FLGMOD([L]NOL) =1
[M]WLIG53         =[L]NOL
[L]NOL           +=1

[M]EXSDAT0([M]NBREXN0) =[M]WEXSDAT
[M]NBREXN0            +=1
Grizo WADD14
Return

########################################
Subprog AS_NBREXN0

Gosub SETNOL
If [L]NOL>=0 & [M]NBREXN0>0
 If [L]NOL<=[M]NBREXN0
  Gosub CHARGE_EXN
 Else
  Effzo 20-40
 Endif
Endif

End

#29411
Subprog FIRST_NBREXN0
Local Integer NOL
NOL=0
Gosub CHARGE_EXN
End

########################################
Subprog C_NBREXN0

#40533
Local Shortint I, J

If find(status,65,68,83)
 [M]FLGADD=1
 For I=nolign-1 To (nolign1-1)*(status<>65)+(nolign-1)*(status=65)
  For J=0 To [M]NBREXN-1
   #40614
   #If [M]EXSDAT(J)=[M]EXSDAT0(I) : Dela J,1 [M]NBREXN : [M]NBREXN-=1 : Endif
   If [M]EXSDAT(J)=[M]EXSDAT0(I)
    Dela J,1 [M]NBREXN
    [M]NBREXN -=1
    J -=1
   Endif
   #40614
  Next
 Next
 If ![M]NBREXN : Effzo [M] 30,40 : Endif
Endif

End

########################################
Subprog AS_WEXSDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = date$
Endif
End

########################################
Subprog C_WEXSDAT(VALEUR)
Variable Date    VALEUR

Local Integer NOL

[L]NOL=find([L]VALEUR,[M]EXSDAT0(0..[M]NBREXN0-1))-1
If NOL>=0
 Gosub CHARGE_EXN
Else
 Raz [M]WLIG14, [M]WLIG53, [M]WLIG54
 Actzo WADD14
Endif

End

########################################
Subprog C_WNBREXN

If !varmode([M]WADD14) : End : Endif

Local Shortint I, J

Case status
When 65
 For I=0 To [M]NBREXN-1
  If [M]WLIG14(I)>[M]WLIG14(nolign-1) : [M]WLIG14(I)-=1 : Endif
 Next
 If [M]WLIG53>[M]WLIG14(nolign-1) : [M]WLIG53-=1 : Endif
 If [M]WLIG54>[M]WLIG14(nolign-1) : [M]WLIG54-=1 : Endif
 Dela [M]WLIG14(nolign-1),1 [M]NBREXN
 [M]NBREXN-=1
 [M]FLGADD =1
When 68,83
 For I=nolign1-1 To nolign-1
  For I=0 To [M]NBREXN-1
   If [M]WLIG14(I)>[M]WLIG14(J) : [M]WLIG14(I)-=1 : Endif
  Next
  If [M]WLIG53>[M]WLIG14(J) : [M]WLIG53-=1 : Endif
  If [M]WLIG54>[M]WLIG14(J) : [M]WLIG54-=1 : Endif
  Dela [M]WLIG14(J),1 [M]NBREXN
  [M]NBREXN-=1
 Next
 [M]FLGADD=1
Endcase

End

#########################################
Subprog APRES_WNBREXN

If !varmode([M]WADD14) | [M]WLIG14(nolign-1) | [M]WEXSVAR(nolign-1)=""
&| ([M]WEXSDAT=[M]EXSDAT(0) & [M]WEXSVAR(nolign-1)=[M]EXSVAR(0))
 End
Endif

[M]WLIG14(nolign-1)            =[M]NBREXN
[M]NBREXN                     +=1
[M]EXSDAT([M]WLIG14(nolign-1)) =[M]WEXSDAT
[M]EXSVAR([M]WLIG14(nolign-1)) =[M]WEXSVAR(nolign-1)
[M]EXSAMT([M]WLIG14(nolign-1)) =[M]WEXSAMT(nolign-1)
# SEF If dim([M]EXNS)>=[M]NBREXN
# [M]EXNS ([M]WLIG14(nolign-1)) =[M]WEXNS  (nolign-1)
# Endif
[M]FLGADD                      =1

End

########################################
Subprog AM_WEXSVAR(VALEUR)
Variable Char    VALEUR()

If !varmode([M]WADD14) | [M]WEXSVAR(nolign-1)="" : End : Endif

[M]FLGMOD([M]WLIG14(nolign-1))=1
[M]EXSVAR([M]WLIG14(nolign-1))=[L]VALEUR

End

########################################
Subprog AM_WEXSAMT(VALEUR)
Variable Decimal VALEUR

If !varmode([M]WADD14) | [M]WEXSAMT(nolign-1)=0 : End : Endif

[M]FLGMOD([M]WLIG14(nolign-1))=1
[M]EXSAMT([M]WLIG14(nolign-1))=[L]VALEUR

End

########################################
Subprog AM_WCAT(VALEUR)
Variable Integer VALEUR
If !varmode([M]WADD14) : End : Endif
 [M]FLGMOD([M]WLIG54)=1
 [M]EXSAMT([M]WLIG54)=[L]VALEUR
End

########################################
Subprog AM_WBKT(VALEUR)
Variable Integer VALEUR

If !varmode([M]WADD14) : End : Endif

[M]FLGMOD([M]WLIG53)=1
[M]EXSAMT([M]WLIG53)=[L]VALEUR

End

########################################
Subprog AS_WADD14(VALEUR)
Variable Integer VALEUR

If [M]WEXSDAT<>[0/0/0] & !find([M]WEXSDAT,[M]EXSDAT(0..[M]NBREXN-1))
 [M]FLGADD = 1
 Local Integer NOL
 [L]NOL=[M]NBREXN
 Gosub DECHARGE_EXN
 [M]NBREXN=[L]NOL
 #29411
 Sorta [M]NBREXN0 [M]NBREXN0 Order By [M]EXSDAT0([S]indice)Desc
 Affzo 10
 [L]VALEUR = 1
 If ![V]GBROWS : zonsui="WEXSDAT" : Endif
Endif
End

$LIRE_SITE
Call LECTURE("FCY",[M]ETRFCY,"") From CONTOBJ

Return

