   GMESSAGE = mess(00012,11800,1)
   mkstat=2
Endif
If VALEUR<2 # Percentage
  Actzo [M:EMP7]PAYPCT(nolign-1)
  Raz   [M:EMP7]PAYAMT(nolign-1)
  Grizo [M:EMP7]PAYAMT(nolign-1)
Else
  Actzo [M:EMP7]PAYAMT(nolign-1)
  Raz   [M:EMP7]PAYPCT(nolign-1)
  Grizo [M:EMP7]PAYPCT(nolign-1)
Endif
