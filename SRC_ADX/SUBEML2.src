######################################################################################

Subprog AS_NBRCTR
If nolign>[M]NBRCTR : End : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If nolign>=1 & [M]CTRNUM(nolign-1)<>""
 Read [HRCTR]CTR0=[M]REFNUM;[M]CTRNUM(nolign-1);[M]CTRDAT(nolign-1)
 # Multi_leg & multi_soci‚t‚
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim([M]SOCCTR)>=0 : [M]SOCCTR(nolign-1)=[F:CPY]CPY : Endif
 If dim([M]LEGCTR)>=0 : [M]LEGCTR(nolign-1)=[F:CPY]LEG : Endif
 #We need to affect GCURLEG to have the designation linked
 #Be carreful if another GCURLEG must be use in the same function for another things....
# Now GCURLEG affect in $LIEN because FCYORI is mandatory
#  GCURLEG=[F:CPY]LEG : GSOCIETE =[F:CPY]CPY

 [M] = [F:HRCTR]
 [M]WCTRDAT = [F:HRCTR]CTRDAT
 [M]WCTRNUM = [F:HRCTR]CTRNUM
 # FQ74282 - 10/09/13 - Afficher l'ic“ne si le contrat est accessible
 [M]ICO = "21"
 # Fin FQ74282
 Affzo [M]
 If  ( GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
& |  ( GUSRFCY<>"\" & GNBAUZ<>GNBSITE & !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ)) )
  Effzo [M]20
  Effzo [M]30
  Effzo [M]40
 Endif
Endif
End

