#44743
Subprog C_CHEF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:ID5])=0 : Local File EMPLOID [ID5] : Endif
Read [ID5]ID0=VALEUR
If fstat
 # Matricule inexistant
 GMESSAGE = mess(83,10702,1)
 mkstat = 2 : End
Elsif [F:ID5]FLGNEWSAL=2 | [F:ID5]ENAFLG<>2
 # Salari‚ inactif
 GMESSAGE = mess(33,10702,1)
 mkstat = 2 : End
Endif
End
