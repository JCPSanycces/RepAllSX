#Read [ID]ID0=[L]OREFNUM

#72074
If clalev([F:ID2])=0    : Local File EMPLOID    [ID2]   : Endif
Read [ID2]ID0=[M]CHEF(nolign-1)
If !fstat
 [L]VALEUR=toupper([F:ID2]NAM)-tolower([F:ID2]SRN)
Else
 [L]VALEUR="" : End
Endif
End

