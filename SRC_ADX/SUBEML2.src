######################################################################################
#* SYMEU V6.1 Module Formation - Formateur interne - Fiche 70028
#* Quand le salari‚ devient inactif, s'il est aussi formateur interne et s'il est
#* trouv‚ dans une session ou un stage, on affiche un message d'avertissement
#*!
######################################################################################
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = 1 and func AFNC.ACTIV("FRT")>0 Then
  Local Integer L_OK : L_OK = 1
  Gosub VERIF_STG_SES
  If L_OK < 1 Then
    # Ce salari‚ est aussi un formateur interne et il est renseign‚ dans un stage ou une session
    Call MESSAGE(mess(189,10717,1)) From GESECRAN
  Endif
Endif
End

#**
#* SYMEU V6.1 Module Formation - Formateur interne
#* V‚rification que le salari‚ n'est pas renseign‚ en tant que formateur
#* dans les stages ou les sessions
#*!
$VERIF_STG_SES
  If clalev([F:STG])=0   : Local File STAGE    [STG]   : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  Filter [F:STG] Where [F:STG]TCHEMP = [M:EMP0]REFNUM
  If rowcount([F:STG]) > 0 Then
    L_OK = 0
  Endif
  Filter [F:STG]
  If L_OK<1 Then Return Endif

  Filter [F:HRSES] Where [F:HRSES]TCHEMP = [M:EMP0]REFNUM
  If rowcount([F:HRSES]) > 0 Then
    L_OK = 0
  Endif
  Filter [F:HRSES]
Return

