Variable Char    VALEUR()
#If func AFNC.ACTIV("KMIEA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) & (!func DIVPAYE.IS_KFR_LEG(GCURLEG) & !func DIVPAYE.IS_KPO_LEG(GCURLEG))
  If func DIVPAYE.EXISTE_KXX("SUBEMLMID")
    Call CL_PJ(VALEUR) From SUBEMLMID
