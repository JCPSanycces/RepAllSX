######################################################################################
Subprog C_DATBRN(VALEUR)
Variable Date    VALEUR
# FQ81085 US524 - SEGAY 05/07/12
# Display\hide fields based on legilation code
Local Char    WDATE
Local Date    BIRTHDATE
#ADNGO - 2018-07-19 - X3-92892 - START
If func DIVPAYE.EXISTE_KXX("SUBEMLKSA") & func DIVPAYE.IS_KZA(GCURLEG) Then
 Call C_DATBRN(VALEUR) From SUBEMLKSA
Endif
#ADNGO - 2018-07-19 - X3-92892 - END
WDATE=VALEUR
BIRTHDATE = VALEUR
Gosub CTR_DATBRN
End


$CTR_DATBRN
# FQ81085 US524 - SEGAY 05/07/12
# Display\hide fields based on legilation code
Local Char    LISTLEG(5)(1..10)
Local Char    WCRIT(250)
Local Integer WNBLEG
Local Integer WOK
WOK=2

WNBLEG=0
[M]FLGDATBRN=0

If WDATE < "000001"
 Call LIST_LEG_EML([M:EMP0]REFNUM, [M:EMP0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG

 If find("BRI",LISTLEG) > 0 or ([M:EMP0]LEGORI="BRI")
  If WNBLEG > 1 or (WNBLEG=1 & ([M:EMP0]LEGORI<>"BRI"))
# "La date de naissance est obligatoire pour la l‚gislation BRI."
# "Òtes-vous s–r que vous ne voulez pas la saisir ?"
     Call AVERTIR (mess(133,10701,1)-mess(134,10701,1),WOK) From GESECRAN
     If WOK=1
      mkstat = 2
      Return
     Else
      [M]FLGDATBRN=1
     Endif
  Else
    GMESSAGE = mess(133,10701,1) # "La date de naissance est obligatoire pour la l‚gislation BRI."
    mkstat = 2 : Return
  Endif
 Endif
 #DEKEE - 2016-12-14 - X3-12544 - START
Else
 Call LIST_LEG_EML([M:EMP0]REFNUM, [M:EMP0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG
 If find("BRI",LISTLEG) > 0 or ([M:EMP0]LEGORI="BRI")
  Local Integer AGE
  Local Integer DAYS, BIRTHDAYS
  If [L]BIRTHDATE <> [0/0/0]
    [L]DAYS = nday(date$)
    [L]BIRTHDAYS = nday([L]BIRTHDATE)
    [L]AGE = [L]DAYS - [L]BIRTHDAYS

    If(dim([M:EMP2]AGE) >= 0)
      [M:EMP2]AGE = year(nday$([L]AGE)) - 1600
    Endif
  Endif
  Affzo [M:EMP2]AGE
 Endif

#  [L]DAYS = nday(date$) : [L]BIRTHDAYS = nday([L]BIRTHDATE)
#  [L]AGE = [L]DAYS - [L]BIRTHDAYS
#
#  If(dim([M:EMP2]AGE) >= 0)
#    [M:EMP2]AGE = year(nday$([L]AGE)) - 1600
#  Endif
#  Affzo [M:EMP2]AGE
# Endif
 #FRLAA - 2017-04-25 - Issue End


 #DEKEE - 2016-12-14 - X3-12544 - END
Endif
Return

