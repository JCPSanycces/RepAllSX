Raz GPILOBJ
Call OBJET("EML",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
##                             Actions particuliŠres
################################################################################
$ACT

Case ACT
 When "GRISE"    : Gosub GRISE
 When "AFFICHE"  : Gosub AFFICHE
 When "VERIF"    : Gosub VERIF
 When "INIT"     : Gosub INIT
Endcase
Return

#86255
$ACTION

Case ACTION
Endcase
Return

$GRISE
Local Integer TEMPO
Call GRISE_CONJOINT([F:ID]SITFAM)
Call GRISE_ETRANGER([F:AD]STG)
Call GRISE_HANDICAP([F:AD]FLGHDC)

If GINTMT=1
 #61592 : inversion des 2 call
 Call GRISE_FLGINT([F:ID]FLGMULCTR)
 Call GRISE_NUMCCS([F:ID]FLGINT)
 #
Endif
TEMPO = [F:ID]CIV

Call GRISE_OLDNAM(TEMPO)
If dim([M:EMP9]WADD5)>0 : Grizo [M:EMP9]WADD5 : Endif
If dim([M:EMP9]WADD6)>0 : Grizo [M:EMP9]WADD6 : Endif
If dim([M:EMPA]WADD4)>0 : Grizo [M:EMPA]WADD4 : Endif
If dim([M:EMPC]WADD7)>0 : Grizo [M:EMPC]WADD7 : Endif
#MABOS
ZONE = "ICOS"
Gosub SET_ZONE
If MA
[M]ICOS="21"
Affzo [M]ICOS
Endif
#end MABOS
Return

$AFFICHE
Case TABLE
 When "EMPLOCPT"

 #** V7 : Waiting Update Accounting **#
 #** If GOPTCANA>0 : Call AS_NBAXE : Endif
 #**

 When "EMPLOMED"
  Sorta [M]NBRVIS [M]NBRVIS Order By [M]MEDDAT ([S]indice)Desc
  Call FIRST_NBRVIS
 When "EMPLOEXM"
  Sorta [M]NBREXM [M]NBREXM Order By [M]DATEXM ([S]indice)Desc
  Call FIRST_NBREXM
 When "EMPLOTRY"
  Sorta [M]NBRTRY [M]NBRTRY Order By [M]STRDATTRY ([S]indice)Desc
  Call FIRST_NBRTRY
 When "EMPLOPAR"
  Sorta [M]NBRPAR [M]NBRPAR Order By [M]PARDAT ([S]indice)Desc
  Call FIRST_NBRPAR
 When "EMPLOEXN"
  Gosub CHARGE_EXN0
  nolign=evalue("[M:EMP"+MSKTAB(I)+"]NBREXN0")
  Sorta [M]NBREXN0 [M]NBREXN0 Order By [M]EXSDAT0([S]indice)Desc
  Call FIRST_NBREXN0
 When "EMPLOCTR"
  Sorta [M]NBRCTR [M]NBRCTR Order By [M]CTRDAT ([S]indice), [M]CTRNUM ([S]indice) Desc
  For nolign=1 To [M]NBRCTR
   Read [HRCTR]CTR0=[M]REFNUM;[M]CTRNUM(nolign-1);[M]CTRDAT(nolign-1)
   If [F:HRCTR]XITDAT=[0/0/0]
    Chgstl [M]CTRNUM(nolign-1),CTRDAT(nolign-1) With "CONTRAT"
   Else
    Chgstl [M]CTRNUM(nolign-1),CTRDAT(nolign-1) With ""
   Endif
   Affzo [M]CTRNUM(nolign-1),CTRDAT(nolign-1)
  Next
  nolign = 1
  If (GREP<>"C" & GREP<>"D") | TUNNEL=1
   [M]ICO = "21"
   Actzo [M]ICO
  Else
   Raz [M]ICO
   Grizo [M]ICO
  Endif
  Affzo [M]ICO
  Call AS_NBRCTR
Endcase
Return

# FQ81085 US525 - SEGAY 05/07/12
#**
#* Init work var for the list of legislations of an employee
