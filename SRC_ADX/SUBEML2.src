Subprog AS_PAYPCT(VALEUR)
Variable Decimal VALEUR
If [L]VALEUR<>0 : End : Endif
Local Shortint I, PCT
For I=0 To [M]NBRRIB-1
 If I<>nolign-1 & [M]TYPPAY(I)=[M]TYPPAY(nolign-1) : [L]PCT+=[M]PAYPCT(I) : Endif
Next
[L]VALEUR=100-[L]PCT
End


Subprog C_PAYPCT(VALEUR)
Variable Decimal VALEUR
#MIPEA - 2017-05-17- US X3-11287- START
If VALEUR<1
 [V]GMESSAGE=mess(29,11800,1)
 mkstat     =2
Endif
#MIPEA - 2017-05-17- US X3-11287- END
If [L]VALEUR>100
 [V]GMESSAGE=mess(23,10701,1) : # Le pourcentage doit ˆtre inf‚rieur ou ‚gal … 100 %
 mkstat     =2
Endif
End

