Subprog IB_MNL(NOLIB)
Value Integer NOLIB


  If clalev([F:AST])=0  : Local File APLSTD  [AST]  : Endif
  If NOLIB<100
    Read [AST]CLE = 0;NOLIB;GLANGUE
  Else
    Read [AST]CLE = 200;NOLIB-200;GLANGUE
  Endif
  GBOUT1=[F:AST]LANMES
End

