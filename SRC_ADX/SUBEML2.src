Subprog C_BIDNUM(VALEUR)
Variable Char VALEUR()

Local Char     PAYS(GLONCRY)
Local Shortint I

PAYS = [M]BIDCRY(nolign-1)
Call CONTROLE_BIDNUM(VALEUR,PAYS)
If mkstat : End : Endif
If VALEUR=""
 Read [ADI]CODE=10387;[M:EMP7]MODSTL(nolign-1)
 If fstat=0
  If [F:ADI]N1=3 :#Virement
   # zone obligatoire
   GMESSAGE=mess(10,123,1)
   mkstat=2 : End
  Endif
 Else
#MIPEA - 2017-06-14- US X3-11287- START
  GMESSAGE = mess(17,10704,1)-"10387" : # "Erreur sur la table diverse no:"
#  GMESSAGE = mess(17,10704,1)-"387" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-06-14- US X3-11287- END
  mkstat=2 : End
 Endif
Endif

For I=0 To [M]NBRRIB-1
 If I<>nolign-1 & [M]TYPPAY(I)=[M]TYPPAY(nolign-1) & [M]MODSTL(I)=[M]MODSTL(nolign-1)
& & [M]CPYBAN(I)=[M]CPYBAN(nolign-1) & [M]BNF(I)=[M]BNF(nolign-1)
& & [M]BIDCRY(I)=[M]BIDCRY(nolign-1) & [M]BIDNUM(I)=[L]VALEUR
  [V]GMESSAGE=func AFNC.MES1(mess(21,10701,1),num$(I+1))
#             Type, mode, banque, b‚n‚ficiaire, pays et RIB identiques … ceux de la ligne $1$
  mkstat     =2
  Break
 Endif
Next
If mkstat : End : Endif

If dim([M]IBAN)>0
 Call IBAN(PAYS,VALEUR,[M]IBAN(nolign-1)) From TRTBPA
 Affzo IBAN(nolign-1)
Endif
End

