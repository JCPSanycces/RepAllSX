#      #                          Le type de paiement $1$ est r‚parti sur $2$ % au lieu de 100 %
#      [L]OK      =0
#      Break
#     Else
#      OK = 2
#      Call AVERTIR (func AFNC.MES2(mess(22,10701,1),[M]TYPPAY(I),num$(J)),OK) From GESECRAN
#      If OK=1 : OK=0 : Endif
#     Endif
#    Endif
#   Endif
#  Next
#  If ![L]OK : Return : Endif
# Endif
#MIPEA - 2017-09-14- US X3-33811- END
#MASHI - 2017-03-22 - JIRA X3-18818 - START
Endif
#MASHI - 2017-03-22 - JIRA X3-18818 - END

ZONE = "FLGHDC"
Gosub SET_ZONE
If MA
  #DEHEN_REF - 2017-02-16 - Start
  #For Britain the mandatory fields that specify dates are hidden in SUBEMLLEG
  If GCURLEG <> "BRI" : Call CONTROLE_HANDI : Endif
  #DEHEN_REF - 2017-02-16   - END
 If GERR : OK = 0 : Return : Endif
Endif

Return

$INIT

# Tri des types de paiements
Local Char ZONE(10)
ZONE = "NBRRIB"
Gosub SET_ZONE
#MIPEA - 2017-09-14- US X3-33811- START
If [M]PAYSPT<>2
  If MA
   Sorta [M]NBRRIB [M]NBRRIB Order By [M]TYPPAY(indice), [M]PAYPCT(indice) Desc
  Endif
Endif
#If MA
# Sorta [M]NBRRIB [M]NBRRIB Order By [M]TYPPAY(indice), [M]PAYPCT(indice) Desc
#Endif
