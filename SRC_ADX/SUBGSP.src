#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GSP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "LIENS"       : Gosub LIENS
 When "TIROIR"      : Gosub TIROIR
 When "GAUCHE"      : Gosub GAUCHE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : Gosub EFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
Endcase
Return

$OUVRE
If clalev([GSP]) = 0 : Local File GRPDSP [GSP] : Endif
If clalev([DIE]) = 0 : Local File GDIE [DIE] : Endif
If !GIMPORT & !TUNNEL
 Raz CLE1,CLE2
 If CLE1 = ""
  Read [GSP]GSP0 First
  CLE1 = [F:GSP]DIE
  CLE2 = [F:GSP]COD
 Endif
 GBIDC1 = CLE1
 GBIDC2 = CLE2
Elsif TUNNEL
 GBIDC1 = CLE2
 GBIDC2 = CLE1
Endif
[M]DIE = GBIDC1
Return

$INICRE
$INIMOD
# abandon de la création si code axe non renseigné
If [M:GSP1]DIE=""
 # "Axe incorrect"
 GMESSAGE = mess(40,103,1)
 GOK=0
Endif
If dim([F:GSP]DES)>0
 [F:GSP]DES = [M:GSP1]DESTRA
Endif
Return

$OUVRE_BOITE
Local Integer BROWSEC , BROWSER 
Local Char  AXCUR(3)
AXCUR=[M]DIE
Local Char  BOXSEC(10)
BROWSEC = find("CCE",OBJLIS(1..8)) : BOXSEC = "GAU_CHE"+num$(BROWSEC)
Gosub REMP_SEC
Return

$LIENS
# si code axe vide, initialisation avec le 1er axe de la table
If [M:GSP1]DIE=""
 Read [DIE] First
 [M:GSP1]DIE = [F:DIE]DIE
 Filter [GSP] Where DIE=[F:DIE]DIE
  Read [GSP] First
  [M:GSP1]COD=[F:GSP]COD
 Filter [GSP]
Endif

Call LECTEXTRA([M:GSP1]DESTRA,"GRPDSP","DESTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
Call LECTEXTRA([M:GSP1]SHOTRA,"GRPDSP","SHOTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
If [M]DIE<>AXCUR & BOXCURR=BOXSEC
 Gosub REMP_SEC
Endif
Return

$RAZCRE
[M]DIE = AXCUR
Gosub REMP_SEC
Return

$EFFMASK
If MA=0
 [M:GSP1]DIE = GBIDC1
 Affzo [M:GSP1]DIE
Endif
Return

$FILGAUCHE
FILGAUCHE = '[F:GSP]DIE="'+GBIDC1+'"'
Return

$FILTRE
If GFONCTION="GESGSP" 
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:GSP]DIE="'+GBIDC1+'"'
Endif
Return

$SETBOUT
If GBIDC1 = ""
 Call VIREBOUT(CHAINE,"CA") From GOBJET
Else
 If !find('A',CHAINE) Then CHAINE += 'A' : Endif
 If CLECUR = 0 Then 
  Call VIREBOUT(CHAINE,"A") From GOBJET
 Endif 
Endif 
Return

$EXEBOUT
Case BOUT
 When "1"
  Effzo
  [M:GSP1]DIE  =   VALBOUT
  GBIDC1       =   [M]DIE
  AXCUR        =   [M]DIE 
  Gosub REMP_SEC
  Affzo [M]DIE
  Gosub REMPLIT From GOBJSUB
  Filter [GSP] Where DIE=GBIDC1
  Read [GSP]GSP0 First
  Filter [GSP]
  If !fstat
   CLECUR1     =   [F:GSP]DIE
   Gosub LECTURE From GOBJSUB
  Endif
Endcase
Return


$TIROIR
Case currbox
 When BOXSEC
  If CLECUR : Gosub REMP_SEC : Endif
Endcase
Return

$REMP_SEC
AXCUR = [M]DIE
If !GIMPORT
 Raz CRITERE, FILGAUSUP
 FILGAUSUP = '[F:CCE]DIE="'+AXCUR+'"'
 BROWSER = BROWSEC
 Gosub REMPLIT
Endif
Return

$REMPLIT
Case BROWSER
 When 1 : Gosub REMPLIT_1 From WGOGSP
 When 2 : Gosub REMPLIT_2 From WGOGSP
 When 3 : Gosub REMPLIT_3 From WGOGSP
 When 4 : Gosub REMPLIT_4 From WGOGSP
 When 5 : Gosub REMPLIT_5 From WGOGSP
 When 6 : Gosub REMPLIT_6 From WGOGSP
 When 7 : Gosub REMPLIT_7 From WGOGSP
 When 8 : Gosub REMPLIT_8 From WGOGSP
Endcase
Return

$GAUCHE
Case currbox
 When BOXSEC
  If [M]NBCCE<dim([M]CCE) & !find([F:CCE]CCE,[M]CCE(0..[M]NBCCE-1))
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    Read [CCE]CCE0 = [M]DIE;[F:CCE]CCE
    [M]CCE([M]NBCCE)    = [F:CCE]CCE
   # [M]ZCCE([M]NBCCE)   = [F:CCE]DES
    [M]COE([M]NBCCE)   = 1
    [M]NBCCE += 1
    Affzo CCE([M]NBCCE-1),ZCCE([M]NBCCE-1),COE([M]NBCCE-1)
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GRPDSP","DESTRA",CLECUR2,CLECUR1,"GRPDSP","DESTRA",[M:GSP1]DIE,[M:GSP1]COD)  From ATEXTRA
 Call DUPTEXTRA("GRPDSP","SHOTRA",CLECUR2,CLECUR1,"GRPDSP","SHOTRA",[M:GSP1]DIE,[M:GSP1]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:GSP1]DESTRA,"GRPDSP","DESTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
Call MAJTEXTRA([M:GSP1]SHOTRA,"GRPDSP","SHOTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
Return


$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GRPDSP","DESTRA",[M:GSP1]DIE,[M:GSP1]COD,[M:GSP1]DIE,NCODE) From ATEXTRA
#Call CHGTEXTRA("GRPDSP","SHOTRA",[M:GSP1]DIE,[M:GSP1]COD,[M:GSP1]DIE,NCODE) From ATEXTRA
Call CHGTEXTRA("GRPDSP","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("GRPDSP","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("GRPDSP","DESTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
Call SUPTEXTRA("GRPDSP","SHOTRA",[M:GSP1]DIE,[M:GSP1]COD) From ATEXTRA
Return

Subprog IB_DESTRA
End

######################################################################################
## Etiquette du mask GSP1  JHA
######################################################################################

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CCE(0..[M]NBCCE)) From OBJDIV
End
######################################################################################

