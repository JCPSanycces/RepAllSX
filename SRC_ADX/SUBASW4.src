#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet ASW
########################################################################
# Fenêtres de saisie                                                   #
# ------------------                                                   #
# ASWINVLNK: Liens invalides                                           #
# ASWMEN   : Menus                                                     #
# ASWATYP  : Content Types                                             #
########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Return

$FIN
nolign=SAVNOLIGN
Return

$DEBUT
Case GACTION
 When "ASWINVLNK"  : Gosub DEB_ASWINVLNK
 When "ASWMEN"     : Gosub DEB_ASWMEN
 When "ASWATYP"    : Gosub DEB_ASWATYP
Endcase
Return

$OK
Case GACTION
 When "ASWATYP"    : Gosub OK_ASWATYP
Endcase
Return


#----------------------------------------------------------
$DEB_ASWINVLNK
Effzo [M:ASW6B]
Local Integer J
# links (screen ASW6)
For J=0 To [M:ASW6]NBRLNK-1
 If [M:ASW6]INVLNK(J)=2
    [M:ASW6B]CODLNK([M:ASW6B]NBRLNK) = [M:ASW6]CODLNK(J)
    [M:ASW6B]INTITLNK([M:ASW6B]NBRLNK) = [M:ASW6]INTITLNK(J)
    [M:ASW6B]INTLNK([M:ASW6B]NBRLNK) = [M:ASW6]INTLNK(J)
    [M:ASW6B]TYPLNK([M:ASW6B]NBRLNK) = [M:ASW6]TYPLNK(J)
    [M:ASW6B]REPLNK([M:ASW6B]NBRLNK) = [M:ASW6]REPLNK(J)
    [M:ASW6B]CMPLNK([M:ASW6B]NBRLNK) = [M:ASW6]CMPLNK(J)
    [M:ASW6B]TARLNK([M:ASW6B]NBRLNK) = [M:ASW6]TARLNK(J)
    If [M:ASW6B]TARLNK([M:ASW6B]NBRLNK)=0 : [M:ASW6B]TARLNK([M:ASW6B]NBRLNK)=1 : Endif
    [M:ASW6B]CLAPTRLNK([M:ASW6B]NBRLNK) = [M:ASW6]CLAPTRLNK(J)
    [M:ASW6B]CLALNK([M:ASW6B]NBRLNK) = [M:ASW6]CLALNK(J)
    [M:ASW6B]METLNK([M:ASW6B]NBRLNK) = [M:ASW6]METLNK(J)
    [M:ASW6B]CODFNCLNK([M:ASW6B]NBRLNK) = [M:ASW6]CODFNCLNK(J)
    [M:ASW6B]FREELNK([M:ASW6B]NBRLNK) = [M:ASW6]FREELNK(J)
    [M:ASW6B]RPTCOD([M:ASW6B]NBRLNK) = [M:ASW6]RPTCOD(J) :#104754/3
    [M:ASW6B]MENLNK([M:ASW6B]NBRLNK) = [M:ASW6]MENLNK(J)
    [M:ASW6B]ORDLNK([M:ASW6B]NBRLNK) = [M:ASW6]ORDLNK(J)
    [M:ASW6B]AFFLNK([M:ASW6B]NBRLNK) = [M:ASW6]AFFLNK(J)
    [M:ASW6B]ANCLNK([M:ASW6B]NBRLNK) = [M:ASW6]ANCLNK(J)
    [M:ASW6B]ATTLNK([M:ASW6B]NBRLNK) = [M:ASW6]ATTLNK(J)
    If [M:ASW6B]ATTLNK([M:ASW6B]NBRLNK)=0 : [M:ASW6B]ATTLNK([M:ASW6B]NBRLNK)=1 : Endif
    [M:ASW6B]FLGSTDLNK([M:ASW6B]NBRLNK) = [M:ASW6]FLGSTDLNK(J)
    [M:ASW6B]REMSTDLNK([M:ASW6B]NBRLNK) = [M:ASW6]REMSTDLNK(J)
    [M:ASW6B]ACVLNK([M:ASW6B]NBRLNK) = [M:ASW6]ACVLNK(J)
    [M:ASW6B]DETLNK([M:ASW6B]NBRLNK) = [M:ASW6]DETLNK(J)
    [M:ASW6B]QRYLNK([M:ASW6B]NBRLNK) = [M:ASW6]QRYLNK(J)
    [M:ASW6B]EDILNK([M:ASW6B]NBRLNK) = [M:ASW6]EDILNK(J)
    [M:ASW6B]LOKLNK([M:ASW6B]NBRLNK) = [M:ASW6]LOKLNK(J)
    [M:ASW6B]SUMLNK([M:ASW6B]NBRLNK) = [M:ASW6]SUMLNK(J)
    [M:ASW6B]ENALNK([M:ASW6B]NBRLNK) = [M:ASW6]ENALNK(J)
    [M:ASW6B]INVLNK([M:ASW6B]NBRLNK) = [M:ASW6]INVLNK(J)
    [M:ASW6B]NBRLNK += 1
 Endif
Next
Affzo [M:ASW6B]
Return

#----------------------------------------------------------
$DEB_ASWATYP
Effzo [M:ASW10]
[M:ASW10]CURFLD=[M:ASW9]CODFLD(SAVNOLIGN-1)
[M:ASW10]CODTYP=[M:ASW9]CODTYP(SAVNOLIGN-1)
Local Integer J
# parameters (ASW5)
For J=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]TYPPAR(J)=2 & [M:ASW10]CURFLD=[M:ASW5]CODFLD(J) & [M:ASW5]CODTYP(J)=[M:ASW10]CODTYP
    [M:ASW10]ATYP([M:ASW10]NBRTYP) = [M:ASW5]VALEUR(J)
    Read [ATYP]ATYP0=[M:ASW10]ATYP([M:ASW10]NBRTYP)
    If !fstat
     [M:ASW10]PROTYP([M:ASW10]NBRTYP)=[F:ATYP]PROTYP
    Endif
    [M:ASW10]NBRTYP += 1
 Endif
Next
Affzo [M:ASW10]
Return

#----------------------------------------------------------
$OK_ASWATYP
Local Integer J
# parameters (ASW5)
For J=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]TYPPAR(J)=2 & [M:ASW10]CURFLD=[M:ASW5]CODFLD(J)
     Dela J,1 [M:ASW5]NBRPAR
     [M:ASW5]NBRPAR -=1
     J-=1
 Endif
Next
For J=0 To [M:ASW10]NBRTYP-1
   [M:ASW5]STDNEW([M:ASW5]NBRPAR)    = 1
   [M:ASW5]CODTYP([M:ASW5]NBRPAR)    = [M:ASW10]CODTYP
   [M:ASW5]CODPAR([M:ASW5]NBRPAR)    = "ATYP~"+num$(J+1)
   [M:ASW5]TYPPAR([M:ASW5]NBRPAR)    = 2
   [M:ASW5]CODFLD([M:ASW5]NBRPAR)    = [M:ASW10]CURFLD
   [M:ASW5]CODLNK([M:ASW5]NBRPAR)    = ""
   [M:ASW5]AFFLNK([M:ASW5]NBRPAR)    = 1
   [M:ASW5]TYPKEY([M:ASW5]NBRPAR)    = 1
   [M:ASW5]VALEUR([M:ASW5]NBRPAR)    = [M:ASW10]ATYP(J)
   [M:ASW5]NUMPAR([M:ASW5]NBRPAR)    = J+1
   [M:ASW5]TYPINTPAR([M:ASW5]NBRPAR) = 7
   [M:ASW5]IDENT2(J)=func SUBASW_TOOL.BUILD_ASW5_IDENT2(2,1,1,"",[M:ASW5]CODFLD([M:ASW5]NBRPAR),[M:ASW5]CODPAR([M:ASW5]NBRPAR))
   [M:ASW5]NBRPAR  +=1
Next
Return

#----------------------------------------------------------
$DEB_ASWMEN
Effzo [M:ASW8B]
Local Integer AFAC,TROUVE
For AFAC=1 To 5
 If [M:ASW1]ENAFAC(AFAC-1)=2
  TROUVE=1
  Break
 Endif
Next
If TROUVE
 [M:ASW8B]FACETTE=AFAC
 Affzo [M:ASW8B]FACETTE
Else
 FIN=1
 Return
Endif
Affzo [M:ASW8B]
Call _LOAD_MENU(0,1,nomap,[M:ASW0]CODREP)
Affzo [M:ASW8B]10
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran ASHW8B) 03/05/2013 09:13:56 (VPO)
######################################################################################
Subprog AS_FACETTE(VALEUR)
Variable Integer VALEUR
Local Integer AFAC
For AFAC=1 To 5
 If [M:ASW1]ENAFAC(AFAC-1)<>2
  GMENLOC(AFAC) = 1
 Endif
Next
End

Subprog AM_FACETTE(VALEUR)
Variable Integer VALEUR
[M:ASW8B]FACETTE=VALEUR
Effzo [M:ASW8B]10
Call _LOAD_MENU(0,1,nomap,[M:ASW0]CODREP)
Affzo [M:ASW8B]10
End


######################################################################################

#----------------------------------------------------------#
Subprog _LOAD_MENU(TEST,SILENCE,DOSSIER,CODREP)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP

Local Integer SAVNOLIGN : SAVNOLIGN=nolign

Gosub OPEN_FILE  From ASHWVALLEC
Gosub DEFVAR From ASHWVALLEC

Local  Instance  AERR(1..) Using C_AERROR
Local  Instance  ASHW Using C_ASW

ASHW  = NewInstance C_ASW AllocGroup null
If clalev([M:ASW0])>0 & clalev([M:ASW1])>0 & [M:ASW0]CODREP=[L]CODREP
  SetInstance ASHW With [M:ASW1]
  ASHW.CODREP = [L]CODREP
  ASHW.CODECLA =  ASHW.CODREP
  ASHW.INTITREP = [M:ASW0]AZINTREP
  For AFAC=1 To 5
     ASHW.ASWFAC(AFAC) = NewInstance C_ASWFAC AllocGroup ASHW
     ASHW.ASWFAC(AFAC).CODFAC = AFAC
     ASHW.ASWFAC(AFAC).ENAFAC = [M:ASW1]ENAFAC(AFAC-1)
     If func AFNC.ACTIV([M:ASW8]ACTLNKFAC(AFAC-1))
      ASHW.ASWFAC(AFAC).DEFLNKFAC = [M:ASW8]DEFLNKFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).AFFLNKFAC = [M:ASW8]AFFLNKFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).LNKMENFAC = [M:ASW8]LNKMENFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).ACTLNKFAC = [M:ASW8]ACTLNKFAC(AFAC-1)
      Call DEFLNKFAC(AFAC,ASHW,ASHW.ASWFAC(AFAC)) From SUBASW
     Endif
  Next
Else
  Read [ASW]ASW0=[L]CODREP
  If fstat : Goto FIN_LOAD_MENU : Endif
  SetInstance ASHW With [F:ASW]
  ASHW.INTITREP = func ASYRFNC.TEXTE([F:ASW]INTREP)
  For AFAC=1 To 5
     ASHW.ASWFAC(AFAC) = NewInstance C_ASWFAC AllocGroup ASHW
     ASHW.ASWFAC(AFAC).CODFAC = AFAC
     ASHW.ASWFAC(AFAC).ENAFAC = [F:ASW]ENAFAC(AFAC-1)
     If func AFNC.ACTIV([F:ASW]ACTLNKFAC(AFAC-1))
      ASHW.ASWFAC(AFAC).DEFLNKFAC = [F:ASW]DEFLNKFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).AFFLNKFAC = [F:ASW]AFFLNKFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).LNKMENFAC = [F:ASW]LNKMENFAC(AFAC-1)
      ASHW.ASWFAC(AFAC).ACTLNKFAC = [F:ASW]ACTLNKFAC(AFAC-1)
      Call DEFLNKFAC(AFAC,ASHW,ASHW.ASWFAC(AFAC)) From SUBASW
     Endif
  Next
Endif
ASHW.ACLA  = NewInstance C_ACLA AllocGroup ASHW
Read [ACLA]ACLA0=ASHW.CODCLA
SetInstance ASHW.ACLA With [F:ACLA]
Call CHARGE_ACLE(ASHW.CODCLA,ASHW.ACLA,AERR) From ACLAVALLEC
If maxtab(AERR)>0  : Goto FIN_LOAD_MENU : Endif

Gosub CHARGE_ASWMN From ASHWVALLEC   : # Menus (necessaires dans CHARGE_ASWK)
If maxtab(AERR)>0 : Goto FIN_LOAD_MENU : Endif

Gosub CHARGE_ASWK From ASHWVALLEC   : # Liens
If maxtab(AERR)>0 : Goto FIN_LOAD_MENU : Endif

Gosub CHARGE_ASWFAC From ASHWVALLEC   : # Menus/facette selon les liens
If maxtab(AERR)>0 : Goto FIN_LOAD_MENU : Endif

Gosub CHARGE_ASW8B

$FIN_LOAD_MENU
#Gosub CLOSE_FILE From ASHWVALLEC
If ASHW<>null
 FreeGroup ASHW
Endif
nolign=SAVNOLIGN
End

#----------------------------------------------------------#
Funprog IS_FACOK(AFAC,ASWK)
Value Integer AFAC
Variable Instance ASWK Using C_ASWLNK

Case AFAC
When 1 : End (ASWK.DETLNK=2)
When 2 : End (ASWK.EDILNK=2)
When 3 : End (ASWK.QRYLNK=2)
When 4 : End (ASWK.LOKLNK=2)
When 5 : End (ASWK.SUMLNK=2)
Endcase
End 0
#----------------------------------------------------------#
$CHARGE_ASW8B
Local Integer WLEV
Local Integer NOMEN,AFAC
AFAC=[M:ASW8B]FACETTE
WLEV=1
Call PLUS_FACETTE(AFAC,WLEV)
WLEV=2
#######################################################
# Ordre de chargement:
# 1- 1er lien ou menu
# 2- les liens sans menu (sauf déjà chargé en 1)
# 3- les menus (sauf déjà chargé en 1)
#######################################################

# 1- 1er lien ou menu
If ASHW.ASWFAC(AFAC).LNKMENFAC<>""
 If ASHW.ASWFAC(AFAC).AFFLNKFAC<>0
  #lien
  For NOLNK=1 To maxtab(ASHW.ASWK)
   If func IS_FACOK(AFAC,ASHW.ASWK(NOLNK)) & ASHW.ASWK(NOLNK).AFFLNK=ASHW.ASWFAC(AFAC).AFFLNKFAC & ASHW.ASWK(NOLNK).CODLNK=ASHW.ASWFAC(AFAC).LNKMENFAC
    Call PLUS_LNK(AFAC,ASHW,ASHW.ASWK(NOLNK),WLEV)
   Endif
  Next
 Else
  #menu
  For NOMEN=1 To maxtab(ASHW.ASWFAC(AFAC).ASWMN)
   If ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU=ASHW.ASWFAC(AFAC).LNKMENFAC
    Call PLUS_MENU(AFAC,ASHW,ASHW.ASWFAC(AFAC).ASWMN(NOMEN),WLEV)
    Call SOUS_LNK(AFAC,ASHW,ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU,WLEV)
    Call SOUS_MENU(AFAC,ASHW,ASHW.ASWFAC(AFAC),ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU,WLEV)
   Endif
  Next
 Endif
Endif

# 2- les liens sans menu (sauf déjà chargé en 1)
For NOLNK=1 To maxtab(ASHW.ASWK)
 If func IS_FACOK(AFAC,ASHW.ASWK(NOLNK)) & ASHW.ASWK(NOLNK).AFFLNK=4 & ASHW.ASWK(NOLNK).MENLNK="" &
&  ASHW.ASWK(NOLNK).TARLNK<3 &
&  !(ASHW.ASWK(NOLNK).AFFLNK=ASHW.ASWFAC(AFAC).AFFLNKFAC & ASHW.ASWK(NOLNK).CODLNK=ASHW.ASWFAC(AFAC).LNKMENFAC)
  Call PLUS_LNK(AFAC,ASHW,ASHW.ASWK(NOLNK),WLEV)
 Endif
Next

# 3- les menus (sauf déjà chargé en 1)
For NOMEN=1 To maxtab(ASHW.ASWFAC(AFAC).ASWMN)
 If ASHW.ASWFAC(AFAC).ASWMN(NOMEN).PARMENU="" &
& !(ASHW.ASWFAC(AFAC).AFFLNKFAC=0 & ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU=ASHW.ASWFAC(AFAC).LNKMENFAC)
  Call PLUS_MENU(AFAC,ASHW,ASHW.ASWFAC(AFAC).ASWMN(NOMEN),WLEV)
  Call SOUS_LNK(AFAC,ASHW,ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU,WLEV)
  Call SOUS_MENU(AFAC,ASHW,ASHW.ASWFAC(AFAC),ASHW.ASWFAC(AFAC).ASWMN(NOMEN).CODMENU,WLEV)
 Endif
Next

Return

#----------------------------------------------------------#
Subprog PLUS_LNK(AFAC,ASHW,ASWK,LIGLEV)
Value Integer AFAC
Variable  Instance  ASHW Using C_ASW
Variable Instance ASWK Using C_ASWLNK
Value Integer LIGLEV
Local Integer NO
NO=[M:ASW8B]NBR
[M:ASW8B]NBR+=1
[M:ASW8B]LEV(NO)=LIGLEV
#---

[M:ASW8B]ORD(NO)=ASWK.ORDLNK
[M:ASW8B]CODE(NO)=ASWK.CODLNK
[M:ASW8B]LIB(NO)=ASWK.INTLNK
If ASWK.AFFLNK=ASHW.ASWFAC(AFAC).AFFLNKFAC & ASWK.CODLNK=ASHW.ASWFAC(AFAC).LNKMENFAC
[M:ASW8B]INTITLIB(NO)="*"-func ASYRFNC.TEXTE([M:ASW8B]LIB(NO))-"-----> "
Else
[M:ASW8B]INTITLIB(NO)=func ASYRFNC.TEXTE([M:ASW8B]LIB(NO))-"-----> "
Endif
#---
If ASWK.MENLNK=""
[M:ASW8B]PARKEY(NO)="FACETTE"-mess(AFAC,7964,1)
Else
[M:ASW8B]PARKEY(NO)=ASWK.MENLNK
Endif
[M:ASW8B]KEYC(NO)="LNK-4-"+ASWK.CODLNK
[M:ASW8B]ICO(NO)="ico.gif"
[M:ASW8B]EXPFLG(NO)=1 : #Déplier à Non pour les liens
#---
[M:ASW8B]ACV(NO)=ASWK.ACVLNK
#---
[M:ASW8B]TYPLNK(NO)=ASWK.TYPLNK
[M:ASW8B]LIBTYPLNK(NO)=mess(ASWK.TYPLNK,7974,1)
[M:ASW8B]REPLNK(NO)=ASWK.REPLNK
[M:ASW8B]CMPLNK(NO)=ASWK.CMPLNK
If ASWK.CMPLNK<>0
[M:ASW8B]LIBCMPLNK(NO)=mess(ASWK.CMPLNK,7971,1)
Endif
[M:ASW8B]TARLNK(NO)=ASWK.TARLNK
If ASWK.TARLNK<>0
[M:ASW8B]LIBTARLNK(NO)=mess(ASWK.TARLNK,7975,1)
Endif
[M:ASW8B]CLAPTRLNK(NO)=ASWK.CLAPTRLNK
[M:ASW8B]CLALNK(NO)=ASWK.CLALNK
[M:ASW8B]METLNK(NO)=ASWK.CODMETLNK+ASWK.CODOPELNK
[M:ASW8B]CODFNCLNK(NO)=ASWK.CODFNCLNK
[M:ASW8B]FREELNK(NO)=ASWK.FREELNK
[M:ASW8B]RPTCOD(NO)=ASWK.RPTCOD :#104754/3

End
#----------------------------------------------------------#
Subprog PLUS_MENU(AFAC,ASHW,ASWMEN,LIGLEV)
Value Integer AFAC
Variable  Instance  ASHW Using C_ASW
Variable Instance ASWMEN Using C_ASWMEN
Value Integer LIGLEV
Local Integer NO
NO=[M:ASW8B]NBR
[M:ASW8B]NBR+=1
[M:ASW8B]LEV(NO)=LIGLEV
#---

[M:ASW8B]ORD(NO)=ASWMEN.ORDMENU
[M:ASW8B]CODE(NO)=ASWMEN.CODMENU
[M:ASW8B]LIB(NO)=ASWMEN.LIBMENU
If ASHW.ASWFAC(AFAC).AFFLNKFAC=0 & ASWMEN.CODMENU=ASHW.ASWFAC(AFAC).LNKMENFAC
[M:ASW8B]INTITLIB(NO)="*"-func ASYRFNC.TEXTE([M:ASW8B]LIB(NO))
Else
[M:ASW8B]INTITLIB(NO)=func ASYRFNC.TEXTE([M:ASW8B]LIB(NO))
Endif
#---
If ASWMEN.PARMENU=""
[M:ASW8B]PARKEY(NO)="FACETTE"-mess(AFAC,7964,1)
Else
[M:ASW8B]PARKEY(NO)=ASWMEN.PARMENU
Endif
[M:ASW8B]KEYC(NO)=ASWMEN.CODMENU
[M:ASW8B]ICO(NO)="Folder.gif"
[M:ASW8B]EXPFLG(NO)=1 : #Déplier à Non pour les menus
#---
[M:ASW8B]ACV(NO)=ASWMEN.ACTMENU

End

#----------------------------------------------------------#
Subprog PLUS_FACETTE(AFAC,LIGLEV)
Value Integer AFAC
Value Integer LIGLEV
Local Integer NO
NO=[M:ASW8B]NBR
[M:ASW8B]NBR+=1
[M:ASW8B]LEV(NO)=LIGLEV
#---

[M:ASW8B]ORD(NO)=AFAC
[M:ASW8B]CODE(NO)=mess(AFAC,7964,1)
[M:ASW8B]INTITLIB(NO)=mess(AFAC,7964,1)
#---
[M:ASW8B]PARKEY(NO)=""
[M:ASW8B]KEYC(NO)="FACETTE"-mess(AFAC,7964,1)
[M:ASW8B]ICO(NO)="Folder.gif"
[M:ASW8B]EXPFLG(NO)=2 : #Déplier à Oui pour la facette
#---
[M:ASW8B]ACV(NO)=""

End

#----------------------------------------------------------#
Subprog SOUS_MENU(AFAC,ASHW,ASWFAC,PARENT,LIGLEV)
Value Integer AFAC
Variable Instance ASHW Using C_ASW
Variable Instance ASWFAC Using C_ASWFAC
Value Char PARENT
Value Integer LIGLEV

Local Integer WLEV,NOMEN
WLEV=LIGLEV+1

For NOMEN=1 To maxtab(ASWFAC.ASWMN)
 If ASWFAC.ASWMN(NOMEN).PARMENU=PARENT
  Call PLUS_MENU(AFAC,ASHW,ASWFAC.ASWMN(NOMEN),WLEV)
  Call SOUS_LNK(AFAC,ASHW,ASWFAC.ASWMN(NOMEN).CODMENU,WLEV)
  Call SOUS_MENU(AFAC,ASHW,ASWFAC,ASWFAC.ASWMN(NOMEN).CODMENU,WLEV)
 Endif
Next
End

#----------------------------------------------------------#
Subprog SOUS_LNK(AFAC,ASHW,PARENT,LIGLEV)
Value Integer AFAC
Variable Instance ASHW Using C_ASW
Value Char PARENT
Value Integer LIGLEV

Local Integer WLEV,NOLNK
WLEV=LIGLEV+1

For NOLNK=1 To maxtab(ASHW.ASWK)
 If func IS_FACOK(AFAC,ASHW.ASWK(NOLNK)) & ASHW.ASWK(NOLNK).AFFLNK=4 & ASHW.ASWK(NOLNK).MENLNK=PARENT
  Call PLUS_LNK(AFAC,ASHW,ASHW.ASWK(NOLNK),WLEV)
 Endif
Next
End

######################################################################################
Subprog C_ATYP(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:ASW10]ATYP(0..[M:ASW10]NBRTYP-1)) From OBJDIV
If mkstat : End : Endif
Local Integer WTYPINT
Read [ATY]CODTYP=[M:ASW10]CODTYP
WTYPINT=[F:ATY]TYPTYP
Read [ATYP]ATYP0=VALEUR
If WTYPINT<>[F:ATYP]TYPTYP
    GMESSAGE = mess(260,143,1)
    GERR=1
    mkstat=2
    End
Elsif [F:ATYP]PREFLG=2
    GMESSAGE = mess(83,123,1)
    GERR=1
    mkstat=2
    End
Endif
End


######################################################################################
Subprog AM_ATYP(VALEUR)
Variable Char    VALEUR()
Read [ATYP]ATYP0=VALEUR
If !fstat
 [M:ASW10]PROTYP(nolign-1)=[F:ATYP]PROTYP
Else
 [M:ASW10]PROTYP(nolign-1)=""
Endif
Affzo [M:ASW10]PROTYP(nolign-1)
End


######################################################################################

