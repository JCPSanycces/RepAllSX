#<AdxTL>@(#)2.0.0.0 $Revision$

Call CLNCALTRT()
End

$ACTION
  Case ACTION
   When "TRT_DIV" : Call CLNCALTRT()
  Endcase
Return
##################################################
Subprog CLNCALTRT
  Local Integer LOK
  Local Char LDOS_INDUS, LDOS_DEV, LCHEMIN(50), WCODOPE(100)(1..2)

  LDOS_DEV   = adxmother(0)

  Call OUINON(LDOS_DEV - ": Les sources du calcul batch vont être regénérés. Voulez-vous continuer ?", LOK) From GESECRAN
  If (LOK = 2) Then
    LOK = 1
    Call NETTOYER_SOURCES (LOK, LDOS_DEV, "")
  Endif
End


############################################################################################
Subprog NETTOYER_SOURCES(PENVINDUS, PDOSSIER, PCHEMIN)
Value Integer PENVINDUS # env dev = 1. env indus = 2.
Value Char PDOSSIER()
Value Char PCHEMIN

Local Integer WFIN
Local Char    LINE_IN(255)
Local Char    LINE_OUT(255)
Local Char    LINE(255)
Local Integer BWRITE    : BWRITE   = 0
Local Integer BECRFI    : BECRFI   = 0
Local Integer IPOS
Local Integer OK

Local Char    TRAITEMENT

TRAITEMENT = ""
TRAITEMENT = "CLEAN"

#----------------------------------
# Ouverture de la Trace
#----------------------------------

  If ( !(GSERVEUR) and GTRACE = "" ) Then
    Call OUVRE_TRACE(mess(1,404,1) - "(" + PDOSSIER + ")")  From LECFIC
  Endif
  Call ECR_TRACE(" ", 0) From GESECRAN
  Call ECR_TRACE("------------------------------------------- ", 0) From GESECRAN
  Call ECR_TRACE("REGENERATION DES SOURCES POUR CALCUL BATCH", 0) From GESECRAN
  Call ECR_TRACE("------------------------------------------- ", 0) From GESECRAN
  If PENVINDUS = 2
    Call ECR_TRACE("Env Indus :" - PDOSSIER, 0) From GESECRAN
  Else
    Call ECR_TRACE("Env Dev :"- PDOSSIER, 0) From GESECRAN
  Endif
  Call ECR_TRACE(" ", 0) From GESECRAN

##############################################
  Local Char LNOM_IN, LNOM_OUT, LTXTCOMPIL

  # Dictionnaire de traitement
 If !clalev([F:ADC])  : Local File ADICTRT [ADC]  : Endif

#
#----------------------------------
#  GLOBI* -> GLOBB*
#----------------------------------

    LNOM_IN  = "GLOBI"
    LNOM_OUT = "GLOBB"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI0"
    LNOM_OUT = "GLOBB0"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI1"
    LNOM_OUT = "GLOBB1"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI2"
    LNOM_OUT = "GLOBB2"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI3"
    LNOM_OUT = "GLOBB3"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI4"
    LNOM_OUT = "GLOBB4"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI4FR"
    LNOM_OUT = "GLOBB4FR"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI4RU"
    LNOM_OUT = "GLOBB4RU"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI4PL"
    LNOM_OUT = "GLOBB4PL"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI5"
    LNOM_OUT = "GLOBB5"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI5RU"
    LNOM_OUT = "GLOBB5RU"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI5PL"
    LNOM_OUT = "GLOBB5PL"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI6"
    LNOM_OUT = "GLOBB6"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI7"
    LNOM_OUT = "GLOBB7"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI8"
    LNOM_OUT = "GLOBB8"
    Gosub LANCE_CPY

    LNOM_IN  = "GLOBI9"
    LNOM_OUT = "GLOBB9"
    Gosub LANCE_CPY


  # Fermeture du Compte-rendu
  If ( !(GSERVEUR) ) Then
    Call FERME_TRACE From LECFIC
  Endif
  # Visualisation du Compte-rendu
  If !( GSERVEUR ) Then : Call LEC_TRACE From LECFIC : Endif

End


############################################################################################


############################################################################################
$LANCE_CPY

  # Fichier d'entrée
  If ( filinfo(filpath("TRT", LNOM_IN, "src", PCHEMIN, "", ""), 0) < 0 ) Then
    Infbox "Fichier source" - PDOSSIER - ":" - LNOM_IN - "non trouvé"
    Return
  Endif
  # Fichier de sortie
  If ( filinfo(filpath("TRT", LNOM_OUT, "src", PCHEMIN, "", ""), 0) < 0 ) Then
    Infbox "Fichier source" - PDOSSIER - ":" - LNOM_OUT - "non trouvé"
    Return
  Endif

  #-- Ouverture du fichier d'entrée
  Openi filpath("TRT", LNOM_IN,"src", PCHEMIN,"","")      Using [FINP]
  Iomode adxifs ""                Using [FINP]
  Iomode adxirs chr$(10)          Using [FINP]
  Iomode adxium GUTF8             Using [FINP]

  #-- Ouverture du fichier de sortie (avec positionnement du pointeur en debut de fichier)
  Openo filpath("TRT", LNOM_OUT, "src", PCHEMIN,"",""),0    Using [FOUT]
  Iomode adxifs ""                Using [FOUT]
  Iomode adxirs chr$(10)          Using [FOUT]
  Iomode adxium GUTF8             Using [FOUT]

  Gosub CPY_SRC

  # Compilation
  If PENVINDUS = 2
    Call ECR_TRACE(LNOM_OUT - "regénéré MAIS non compilé", 0) From GESECRAN
  Else
    Call VALID("TRT", LNOM_OUT, nomap, OK) From VALMSKSUB
    If OK
      LTXTCOMPIL = ""
    Else
      LTXTCOMPIL = " (Erreur)"
    Endif
    # Marquage correction.
    Call MAJ(LNOM_OUT, "", 14, "") From SUBADC
    Call ECR_TRACE(LNOM_OUT - "a été regénéré à partir de" - LNOM_IN - "et recompilé" + LTXTCOMPIL, 0) From GESECRAN
  Endif

Return
#========================
$CPY_SRC
  WFIN = 0
  Repeat
     Rdseq LINE_IN Using [FINP]
     If ( fstat ) Then WFIN=1
       If ( LINE_IN <> "" ) Then
         Gosub CHG_SRC
       Endif
     Elsif (LINE_IN <> "" ) Then
         Gosub CHG_SRC
     Endif
  Until WFIN
  #-- Fermeture du fic. de lecture
  Openi Using [FINP]
  Openo Using [FOUT]
Return

#========================
$CHG_SRC

  # Ne sont pas recopiées :
  # 1°) Les lignes de commentaires
  # 2°) Les lignes contenant ECR_FICH ainsi que les éventuelles lignes de continuation
  # 3°) Les lignes contenant PKTPOINTTRT      ( Visualisation informations du calcul)
  # 4°) Les lignes contenant DEBUG_VISU_MSK   ( Visualisation informations du calcul)
  # 5°) Les lignes contenant ADDLVL ou RMVLVL ( Pile d'appel des fonctions)
  # 6°) Les champs =G_GLOBn renommés GLOBBn

  BWRITE = 1

  If ( TRAITEMENT  = "CLEAN" ) Then
    # Suppression des blancs
    LINE = vireblc ( LINE_IN, 4 )

    # Pas de réécriture des lignes de continuation (&) en relation avec ECR_FICH
    If ( BECRFI ) Then
      If ( instr(1, LINE, "&") = 1 ) Then
        BWRITE = 0
      Else
        BECRFI = 0
      Endif
    Endif
    # Pas de réécriture des lignes de commentaires sauf #CHECK
    If  ( instr(1, LINE, "#") = 1 and instr(1, LINE, "#CHECK") = 0  ) Then
      BWRITE = 0
    Endif
    # Pas de réécriture de la ligne contenant ECR_FICH
    If  ( instr(1, LINE, "ECR_FICH") <> 0 and instr(1, LINE, "Subprog") = 0 ) Then
      BWRITE = 0
      BECRFI = 1
    Endif
    # Pas de réécriture de la ligne contenant PKTPOINTTRT
    If  ( instr(1, LINE, "PKTPOINTTRT") <> 0 ) Then
      BWRITE = 0
    Endif
    # Pas de réécriture de la ligne contenant DEBUG_VISU_MSK
    If  ( instr(1, LINE, "DEBUG_VISU_MSK") <> 0 ) Then
      BWRITE = 0
    Endif
    # Pas de réécriture de la ligne contenant ADDLVL
    If  ( instr(1, LINE, "ADDLVL") <> 0 and instr(1, LINE, "$CAL_ADDLVL") = 0  ) Then
      BWRITE = 0
    Endif
    # Pas de réécriture de la ligne contenant RMVLVL
    If  ( instr(1, LINE, "RMVLVL") <> 0 and instr(1, LINE, "$CAL_RMVLVL") = 0  ) Then
      BWRITE = 0
    Endif

  Endif

  ###If  (BWRITE) Then
  ###  LINE_OUT= LINE_IN
  ###  Wrseq LINE_OUT Using [FOUT]
  ###Endif

  If  (BWRITE) Then
    # La chaine "=G_GLOB" et remplacée par "  GLOBB"
    Local Integer IPOS
    LINE_OUT= LINE_IN
    If (  instr(1, LINE, "=G_GLOB") <> 0 ) Then
      IPOS = instr(1, LINE_IN, "=G_GLOB")
      LINE_OUT = seg$(LINE_IN,1,IPOS-1) +"  GLOBB"+ right$(LINE_IN,IPOS+7)
    Endif
    Wrseq LINE_OUT Using [FOUT]
  Endif


Return

