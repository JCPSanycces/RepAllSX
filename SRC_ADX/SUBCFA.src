#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque CFGAUT0
# Action de l'automate de configuration       SAICFGAUT
# Action de saisie des réponses de l'automate SAICFGREP
#
# SUBCFA  Version: 0001
############################################################
$ACTION
If GTRACE<>""
    Call ECR_TRACE("Action "+ACTION,0) From GESECRAN
Endif
Case ACTION
  When "OUVRE" :
    Case GACTION
      When "SAICFGAUT"     : Gosub OUVRE_AUT
      When "SAICFGREP"     : Gosub OUVRE_REP
    Endcase
  When "DEBUT" :
    Case GACTION
      When "SAICFGAUT"     : Gosub DEBUT_AUT
      When "SAICFGREP"     : Gosub DEBUT_REP
    Endcase
  When "APRES_MODIF" :
    Case GACTION
      When "SAICFGAUT"     : Gosub APRES_MODIF_AUT
    Endcase
  When "SETBOUT"
    Case GACTION
      When "SAICFGAUT"     : Gosub SETBOUT_AUT
    Endcase
  When "BOUTON"
    Case GACTION
      When "SAICFGAUT"     : Gosub BOUTON_AUT
      When "SAICFGREP"     : Gosub BOUTON_REP
    Endcase
  When "AVANT_OK" :
    Case GACTION
      When "SAICFGAUT"     : Gosub AVOK_AUT
      When "SAICFGREP"     : Gosub AVOK_REP
    Endcase
  When "OK" :
    Case GACTION
      When "SAICFGAUT"     : Gosub OK_AUT
      When "SAICFGREP"     : Gosub OK_REP
    Endcase
  When "EDI" :
    Case GACTION
      When "SAICFGAUT"     : Gosub EDI_AUT
    Endcase
  When "END" :
    Case GACTION
      When "SAICFGAUT"     : Gosub END_AUT
      When "SAICFGREP"     : Gosub END_REP
    Endcase
  When "FIN" :
    Case GACTION
      When "SAICFGAUT"     : Gosub FIN_AUT
      When "SAICFGREP"     : Gosub FIN_REP
    Endcase
  When "FINSAI" :
    Case GACTION
      When "SAICFGAUT"     : Gosub FINSAI_AUT
    Endcase
Endcase

If GTRACE<>""
    Case ACTION
        When "INIT_DIA", "CONTROLE", "EXEC", "TERMINE"
            Call ECR_TRACE("Action2 "+ACTION-"clalev([cfa0])="+num$(clalev([M:CFA0]))-"clalev([cfa0])="+num$(clalev([M:CFA1]))-"clalev([cfa0])="+num$(clalev([M:CFA2])),0) From GESECRAN
    Endcase
Endif
Return
############################################################
# Action SAICFGAUT Automate création
############################################################
$OUVRE_AUT
Call ACT_CFGUSR("FUNCFGAUT",FIN) From CFGLIBD
If FIN = 1
  GERR = 1
  Goto OUVRE_AUT_FIN
Endif
Gosub OPEN_CFG       From CFGLIB    # Issue 100646 GA 06/2014
If dim(S_TRAFLG) < 0 | dim(S_DOSSIER) < 0
   Gosub CFG_CONSTANTES From CFGLIB
   Gosub CFG_CRESYMSYS  From CFGLIB
Endif
Gosub CFG_SYMBOLES   From CFGLIB    # FQ 71856 GA 02/2011 idem SUBCFG
Gosub TAB_SYMBOLES   From WUVAR
Call OUVRE_TRACE(mess(121,188,1)) From LECFIC
Local Char    Z_EVA(250)
Local Char    Z_AFF(250)
Local Char    Z_DSY(120)
Local Integer Z_RET
Local Integer Z_I, Z_J, Z_K, Z_L, Z_M, Z_N
Local Integer Z_TEST, Z_VAL, Z_GEN
$OUVRE_AUT_FIN
Return
############################################################
$DEBUT_AUT
Raz [M:CFA0]
Raz [M:CFA1]
Gosub MEI_CFA2
[M:CFA0]SIMFLG = 2
Affzo [M:CFA0]
Return
############################################################
$MEI_CFA2
Raz [M:CFA2]
Repeat
[M:CFA2]ASWMAX += 1
Until evalue("dim([M:CFA2]ASW"+format$("N0:3#",[M:CFA2]ASWMAX)+")<0")
[M:CFA2]ASWMAX -= 1
[M:CFA2]IPTDAT = date$
Return
############################################################
$APRES_MODIF_AUT
If COUZON ="SCENUM"
  Call TEMPON("O") From GESECRAN
  Gosub MEI_CFA2
  If dim(CZ) > 0
    PARAM(1) = CZ
  Else
    PARAM(1) = zc
  Endif
  PARAM(2) = [M:CFA0]FCY
  PARAM(3) = ""
  PARAM(4) = ""
  PARAM(5) = date$
  PARAM(6) = "0"
  PARAM(7) = "0"
  Gosub INIT_CFGSCE  From CFGLIBB
  Gosub OUVRE_CFGSCE From CFGLIBB
  [M:CFA1] = [F:CSC]
  Gosub LOA_PARAM
  Affzo [M:CFA1]
  Grizo [M:CFA1]
  Affzo [M:CFA2]
  Call TEMPOFF From GESECRAN
Endif
Return
############################################################
$SETBOUT_AUT
If [M:CFA2]CFGNBR = 0
  ETABOU(GVALI) = 0
  ETABOU(GSPE1) = 0
  ETABOU(GEDIT) = 0
Else
  ETABOU(GVALI) = 1
  ETABOU(GSPE1) = 1
  ETABOU(GEDIT) = 1
Endif
Return
############################################################
$BOUTON_AUT
Case BOUT
  When "a"
    Call ECR_TRACE("-->"-mess(121,188,1)-":"-mess(223,188,1),0) From GESECRAN
    Z_TEST = 1
    Gosub TRT_SCENARIO
    Z_TEST = 0
    If GERR <> 0
      Call ERREUR(GMESSAGE) From GESECRAN
    Endif
    GERR     = 0
    GMESSAGE = ""
    FIN      = 0
    # FQ 47601 GA 09/2008
    Call ECR_TRACE("-->"-mess(121,188,1)-":"-mess(223,188,1)-mess(39,71,1),0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endcase
Return
############################################################
$AVOK_AUT
#
If sum([M:CFA2]ASWNBR(0..[M:CFA2]NBLIG-1)) <> 0
  If [M:CFA0]SIMFLG <> 2
    Call AVERTIR(mess(124,188,1)-"("-num$([M:CFA2]CFGNBR)-mess(125,188,1)+")",Z_VAL) From GESECRAN
  Else
    Call AVERTIR(mess(123,188,1)-"("-num$([M:CFA2]CFGNBR)-mess(125,188,1)+")",Z_VAL) From GESECRAN
  Endif
Else
  GMESSAGE = mess(128,188,1)
  GERR     = 2
  FIN      = 0
Endif
Return
############################################################
$OK_AUT
If Z_VAL = 2
  If [M:CFA0]SIMFLG = 2
    Call ECR_TRACE("-->"-mess(121,188,1)-":"-mess(123,188,1),0) From GESECRAN
    Gosub TRT_SCENARIO
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
    Call OUVRE_TRACE(mess(121,188,1)) From LECFIC
    FIN = 0
  Else
   Call ECR_TRACE("-->"-mess(121,188,1)-":"-mess(175,188,1),0) From GESECRAN
    Gosub TRT_SCENARIO
    FIN = 1
  Endif
Else
  FIN = 0
Endif
Return
############################################################
$TRT_SCENARIO
Local Integer WRET         # JPJ E21934 - Protection par symbole logique
Local Char WMSG(250)
Call LOCK_CFGSYM(WRET,WMSG) From SUBCFG
If WRET : GMESSAGE=WMSG : GERR=1 : Return : Endif    # JPJ E21934 <-

If clalev([M:CFV0]) = 0 : Local Mask CFGVAL0 [CFV0] : Endif
If clalev([M:CFV1]) = 0 : Local Mask CFGVAL1 [CFV1] : Endif
If clalev([M:CFV2]) = 0 : Local Mask CFGVAL2 [CFV2] : Endif
If clalev([M:CFV3]) = 0 : Local Mask CFGVAL3 [CFV3] : Endif
If clalev([M:CFV4]) = 0 : Local Mask CFGVAL4 [CFV4] : Endif
If clalev([M:CFV9]) = 0 : Local Mask CFGVAL9 [CFV9] : Endif
If clalev([M:CFP0]) = 0 : Local Mask CFGPIL  [CFP0] : Endif
#
Gosub OUVRE_CFGVAL From CFGLIBC # Issue 100646 GA 06/2014
#
If [F:CSC]QSTNBR > 0  # Issue 102093 GA 08/2014
  If filinfo(filpath("ECR","ZUX"+[F:CSC]SCENUM,"msk",0),0)>0
    BOITE = "ZUX"+[F:CSC]SCENUM
  Else
    BOITE = "WUX"+[F:CSC]SCENUM
  Endif
  # Issue 80297
  If GVERSION>"1.6.4"
      Call ISSCREENOK (S_DOSSIER,BOITE) From INTRUTILB
  Endif
Endif

Gosub LOA_PILE From CFGLIBB
[M:CFP0] = [M:CFP]
If [M:CFP]PILIND <> 0
  GMESSAGE = mess(50,188,1)
  GERR = 1
  FIN  = 1
  Goto TRT_SCE_END
Endif
#
Z_J = 0
For Z_I = 0 To [M:CFA2]NBLIG-1
  If [M:CFA2]ASWNBR(Z_I) <> 0
    Z_J += 1
  Endif
Next Z_I
#
If Z_J <> 0
  Local Integer Z_NBR    (Z_J)
  Local Integer Z_IND    (Z_J)
  Local Integer Z_NBL    (Z_J)
  Local Char    Z_LAB(GLONCQU)(Z_J)   # Issue 103969 suite 82300 GA 11/2014 Z_LAB(08)(Z_J)
  Local Char    Z_ALP(20)(Z_J)
  Local Decimal Z_NUM    (Z_J)
  Local Date    Z_DAT    (Z_J)
#
  Z_J = 0
  For Z_I = 0 To [M:CFA2]NBLIG-1
    If [M:CFA2]ASWNBR(Z_I) <> 0
      Z_LAB(Z_J) = [M:CFA2]QSTNUM(Z_I)
      Z_NBR(Z_J) = [M:CFA2]ASWNBR(Z_I)
      Z_IND(Z_J) = 0
      Z_NBL(Z_J) = Z_I
      Z_J += 1
    Endif
  Next Z_I
  Z_J -= 1
  [M:CFA2]CFGNBRPRO = 0
  If Z_TEST = 1
    Gosub TRT_COMBINAISON
    Call UNLOCK_CFGSYM() From SUBCFG        # JPJ E21934 - car EDI_CFGVAL donne la main à l'utilisateur
    Gosub EDI_CFGVAL From CFGLIBC
    Call IMPSCR From ATRTX3
  Else
    While Z_IND(0) <> Z_NBR(0)
      Gosub TRT_COMBINAISON
      If GOK <> 1 : Break : Endif     # Pb systéme
      [M:CFP] = [M:CFP0]
    Wend
  Endif
Endif
Call TEMPOFF From GESECRAN
$TRT_SCE_END
Call UNLOCK_CFGSYM() From SUBCFG        # JPJ E21934 - Protection par symbole logique
Return
############################################################
$TRT_COMBINAISON
Raz Z_ALP, Z_NUM, Z_DAT, Z_DSY, Z_AFF
#
Trbegin [CFT]
Delete [CFT] Where PRONUM = adxuid(1)
Commit
S_SEQTEX = 0
#
Z_I = 0
$TRT_COMBINAISON1
If Z_NBR(Z_I) = Z_IND(Z_I)
  If Z_I = 0
    Return
  Else
    For Z_K = Z_I To Z_J
      Z_IND(Z_K) = 0
    Next Z_K
    Z_I -= 1
    Z_IND(Z_I) += 1
  Endif
  Goto TRT_COMBINAISON
Endif
$TRT_COMB2
# Issue 100646 GA 06/2014 - raz Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(Z_NBL(Z_I)) = 4 |[M:CFA2]CTLTYP(Z_NBL(Z_I)) = 2 | [M:CFA2]CTLTYP(Z_NBL(Z_I)) = 4
#If [M:CFA2]ASWTYP(Z_NBL(Z_I)) = 4 | find([M:CFA2]CTLTYP(Z_NBL(Z_I)),2,3,4,6)
If [M:CFA2]ASWTYP(Z_NBL(Z_I)) = 4 | find([M:CFA2]CTLTYP(Z_NBL(Z_I)),2,4)
  Z_EVA = "[M:CFA2]COD"+format$("N0:3#",Z_IND(Z_I)+1)+"("+num$(Z_NBL(Z_I))+")"
  Z_L   = 0
Else
  Z_EVA = "[M:CFA2]STRVAL("+num$(Z_NBL(Z_I))+")"
  Z_L   = 1
Endif
# FQ 53410 QSTSHO remplacé par le lien
#If Z_AFF = ""
#  Z_AFF  = ([M:CFA2]QSTSHO(Z_NBL(Z_I))+" :")
#Else
#  Z_AFF += (" / "+[M:CFA2]QSTSHO(Z_NBL(Z_I))+" :")
#Endif
Case [M:CFA2]ASWTYP(Z_NBL(Z_I))
  When 1 :
    Z_ALP(Z_I)  = evalue(Z_EVA)
    Z_DSY      -= evalue(Z_EVA)
    Z_AFF      -= evalue(Z_EVA)
  When 2 :
    Z_NUM(Z_I)  = evalue("val("+Z_EVA+")")
    If Z_L = 1
      Z_NUM(Z_I) += evalue("[M:CFA2]STEVAL("+num$(Z_NBL(Z_I))+")*Z_IND(Z_I)")
    Endif
    Z_DSY      -= num$(Z_NUM(Z_I))
    Z_AFF      -= num$(Z_NUM(Z_I))
  When 3 :
    Z_DAT(Z_I)  = evalue(Z_EVA)
    If Z_L = 1
      Z_DAT(Z_I) += evalue("[M:CFA2]STEVAL("+num$(Z_NBL(Z_I))+")*Z_IND(Z_I)")
    Endif
    Z_DSY      -= num$(Z_DAT(Z_I))
    Z_AFF      -= num$(Z_DAT(Z_I))
  When 4 :
    Z_NUM(Z_I)  = evalue("val("+Z_EVA+")")
    If Z_NUM(Z_I) = 2
      Z_DSY -= mess(2,1,1)
      Z_AFF -= mess(2,1,1)
    Else
      Z_DSY -= mess(1,1,1)
      Z_AFF -= mess(1,1,1)
    Endif
  When 5 :
    # --- Issue 100646 GA 08/2014 --- text type !!!!
    #Z_NUM(Z_I)  = evalue("val("+Z_EVA+")")
    #If Z_NUM(Z_I) = 2
    #  Z_DSY -= mess(2,1,1)
    #  Z_AFF -= mess(2,1,1)
    #Else
    #  Z_DSY -= mess(1,1,1)
    #  Z_AFF -= mess(1,1,1)
    #Endif
    Z_ALP(Z_I)  = evalue(Z_EVA)
    Z_DSY      -= evalue(Z_EVA)
    Z_AFF      -= evalue(Z_EVA)
Endcase
#
If Z_I <> Z_J
  Z_I += 1
  Goto TRT_COMBINAISON1
Else
  Z_IND(Z_I) += 1
# Effacement des questions et variables
  For Z_M = 0 To dim(W_VARLAB)-1
    W_VAR = W_VARLAB(Z_M)
    Gosub SUP_SYMBOLE From WUVAR
  Next Z_M
  # Initialisation variables systèmes
  If dim(S_TRAFLG) < 0 | dim(S_DOSSIER) < 0
     Gosub CFG_CRESYMSYS  From CFGLIB
  Endif

  S_CFGCFG = 1              : # Mode scénario
  S_AUTCFG = 1              : # Mode automate
  S_AUTERR = ""             : # Erreur Mode automate     # FQ 47601 GA 09/2008
  S_ENDINP = 0              : # Mode saisie
  S_SCENUM = [F:CSC]SCENUM  : # Numéro de scénario
  S_SCEDES = [F:CSC]SCEDES  : # Intitulé scénario
  S_FCY    = [M:CFA0]FCY    : # Site
  S_CUR    = GLOCALDEV      : # Devise
  S_BPRNUM = ""             : # Numéro de tiers
  S_BPRREF = ""             : # Référence tiers
  S_IPTDAT = [M:CFA2]IPTDAT : # Date de référence
  S_SALTXT = 0              : # Choix texte ventes
  S_CPTCFG = ""             : # Compteur configurations
  # --- Issue 100646 GA 08/2014 --- New System Variables
  If dim(S_BOMALTREF)>0 S_BOMALTREF=[F:CSC]BOMALTREF Endif
  If dim(S_BOMALT)   >0 S_BOMALT   =[F:CSC]BOMALT    Endif
  If dim(S_ROUALTREF)>0 S_ROUALTREF=[F:CSC]ROUALTREF Endif
  If dim(S_ROUALT)   >0 S_ROUALT   =[F:CSC]ROUALT    Endif

# Création des questions et affectation des réponses
  For Z_M = 0 To [M:CFA2]NBLIG-1
    W_VAR = W_PRS+[M:CFA2]QSTNUM(Z_M)
    Read [CQU]CQU0=[M:CFA2]QSTNUM(Z_M)
    If fstat = 0
      Gosub CRE_SYMBOLE From WUVAR
      Z_N = find([M:CFA2]QSTNUM(Z_M),Z_LAB)
      If Z_N = 0
        Gosub SET_DEFAUT From WUVAR
      Else
        W_ALP = ""
        W_NUM = 0
        W_DAT = [0/0/0]
        Case [F:CQU]ASWTYP
          When 1 : W_ALP = Z_ALP(Z_N-1)
          When 2 : W_NUM = Z_NUM(Z_N-1)
          When 3 : W_DAT = Z_DAT(Z_N-1)
          When 4 : W_NUM = Z_NUM(Z_N-1)-1
          When 5 : W_ALP = Z_ALP(Z_N-1)
        Endcase
        Gosub SET_SYMBOLE From WUVAR
      Endif
      If [F:CQU]CTLTYP = 2
        Case [F:CQU]ASWTYP
          When 1 :
            Read [TCT]TCT1=[F:CQU]TCT;W_ALP;0
            If fstat = 0
              Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
              Assign W_PRL+[F:CQU]QSTNUM With W_DESTCT
            Endif
          When 2 :
            Read [TCT]TCT1=[F:CQU]TCT;"";W_NUM
            If fstat = 0
              Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
              Assign W_PRL+[F:CQU]QSTNUM With W_DESTCT
            Endif
        Endcase
      Endif
    Endif
  Next Z_M
  [M:CFA2]CFGNBRPRO += 1
# Texte détaillé si taille suffisante à l'affichage
  If len(Z_AFF) <= type([M:CFA2]PRODSY)-10
    Z_DSY = Z_AFF
  Endif
  [M:CFA2]PRODSY = Z_DSY
  Affzo [M:CFA2]CFGNBRPRO
  Affzo [M:CFA2]PRODSY
  GMESSAGE = ""
  GERR     = 0
  # Issue 87724 GA 08/2014 TRT_SCENARIO necessary with automate mode (CFGEXEBAT)
  Gosub TRT_SCENARIO From CFGLIBB
  If (GOK<>1 | S_ABORT | W_MSG <> "")
     Return
  Else
     Gosub DEBUT_CFGVAL From CFGLIBC
  Endif
  If S_AUTCFG > 1    # Plus de 1 si il manque une question
    GMESSAGE = S_AUTERR-mess(126,188,1)
    Call ECR_TRACE(S_AUTERR-mess(126,188,1),1) From GESECRAN
    GERR     = 1
    FIN      = 1
  Else
    If GOK=1    # Pas d'erreur système
        Case GERR
          When 0 :    # 52: Config avec succès \ N° de config   122: Traitement réponse (les codes suivent des questions)
            Call ECR_TRACE(mess(52,188,1)-S_CPTCFG-"("+S_CURITM+")",0) From GESECRAN
            Call ECR_TRACE(mess(122,188,1)+Z_DSY,0)                    From GESECRAN
            If [M:CFA0]SIMFLG = 2 | Z_TEST <> 0
              Gosub DEL_CONFIG From CFGLIBC
            Else
              Gosub GENERATION_CFGVAL From CFGLIBC
            Endif
          When 1 :
            Call ECR_TRACE(GMESSAGE-mess(53,188,1),1) From GESECRAN    # 53: Configuration abandonnée
            Call ECR_TRACE(mess(122,188,1)+Z_DSY,1)   From GESECRAN
            Gosub DEL_CONFIG From CFGLIBC
          When 2 :
            Call ECR_TRACE(GMESSAGE,0)                From GESECRAN    # Soit: "un composé équivalent a été sélectionné"
                                                                       #       "le composé a une référence provisoire..."
            Call ECR_TRACE(mess(122,188,1)+Z_DSY,0)   From GESECRAN
            If [M:CFA0]SIMFLG = 2 | Z_TEST <> 0
              Gosub DEL_CONFIG From CFGLIBC
            Else
              Gosub GENERATION_CFGVAL From CFGLIBC   # Issue 100646 GA 08/2014
            Endif
        Endcase
    Else
        Call ECR_TRACE(GMESSAGE-mess(53,188,1),1) From GESECRAN    # 53: Configuration abandonnée
        Call ECR_TRACE(mess(122,188,1)+Z_DSY,1)   From GESECRAN
    Endif
    GERR     = 0
    GMESSAGE = ""
  Endif
Endif
Return
############################################################
$EDI_AUT
Local Char WMSK(10)(3)
Local Char WABR(06)(3)
WMSK(0) = "CFGAUT0"
WABR(0) = "CFA0"
WMSK(1) = "CFGAUT1"
WABR(1) = "CFA1"
WMSK(2) = "CFGAUT2"
WABR(2) = "CFA2"
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return
############################################################
$END_AUT
If sum([M:CFA2]ASWNBR(0..[M:CFA2]NBLIG-1)) <> 0
  Z_I = 1
  Call AVERTIR(mess(51,100,1),Z_I) From GESECRAN
  If Z_I = 1
    FIN = 0
  Endif
Endif
Return
############################################################
$FIN_AUT
#
If dim(S_TRAFLG)> 0    # Protection si l'utilisateur n'a rien fait (bouton FIN)  # JPJ E24169
    Gosub TRA_PILE From CFGLIBB  # Trace
Endif

# Affichage trace
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
#
If clalev([M:CFP]) > 0
  Raz [M:CFP]
  Close Local Mask [CFP]
Endif
Gosub SUP_GLOBALES From WUVAR
Call IMPSCR From ATRTX3
Return
############################################################
$FINSAI_AUT
Call DEA_CFGUSR("FUNCFGAUT") From CFGLIBD
Return
############################################################
$LOA_PARAM
[M:CFA2]NBLIG = 0
Read [CQU]CQU0="BPRNUM"
If fstat = 0
  Gosub LOA_QUESTION
Endif
Read [CQU]CQU0="BPRREF"
If fstat = 0
  Gosub LOA_QUESTION
Endif
#
For W_I = 0 To [F:CSC]QSTNBR-1
  Read [CQU]CQU0=[F:CSC]QSTNUM(W_I)
  If fstat = 0
    Gosub LOA_QUESTION
    If [F:CQU]CTLTYP = 4
      Filter [CSH] Where SHACAT = [F:CSC]QSTNUM(W_I)
      For [CSH]
        For W_J = 0 To [F:CSH]SYMNBR-1
          Read [CQU]CQU0=[F:CSH]SYMNUM(W_J)
          If fstat = 0
            Gosub LOA_QUESTION
          Endif
         Next W_J
      Next
      Filter [CSH]
    Endif
  Endif
Next W_I

Return
############################################################
$LOA_QUESTION
If !find([F:CQU]QSTNUM,[M:CFA2]QSTNUM(0..[M:CFA2]NBLIG-1))
  If [M:CFA2]NBLIG < dim([M:CFA2]QSTNUM)-1
    [M:CFA2]NBLIG += 1
    nolign = [M:CFA2]NBLIG
    W_VAR = W_PRS+[F:CQU]QSTNUM
    Gosub CRE_SYMBOLE From WUVAR
    [M:CFA2]QSTNUM(nolign-1) = [F:CQU]QSTNUM
    # FQ 53410 QSTSHO remplacé par le lien
    #[M:CFA2]QSTSHO(nolign-1) = evalue(W_PRX+[F:CQU]QSTNUM)
    [M:CFA2]ASWTYP(nolign-1) = [F:CQU]ASWTYP
    [M:CFA2]ASWCHA(nolign-1) = [F:CQU]ASWCHA
    [M:CFA2]CTLTYP(nolign-1) = [F:CQU]CTLTYP
    Case [F:CQU]ASWTYP
      When 1 :
        [M:CFA2]DEFVAL(nolign-1) = [F:CQU]ALPDEFVAL
      When 2 :
        [M:CFA2]DEFVAL(nolign-1) = num$([F:CQU]NUMDEFVAL)
      When 3 :
        [M:CFA2]DEFVAL(nolign-1) = num$([F:CQU]DATDEFVAL)
      When 4 :
        [M:CFA2]DEFVAL(nolign-1) = mess(1,1,1)
      #When 5 :  # no default value on symbol text :-)
      #  [M:CFA2]DEFVAL(nolign-1) = [F:CQU]ALPDEFVAL
    Endcase
  Endif
Endif
Return
############################################################
# Action SAICFGREP Sélection réponses
############################################################
$OUVRE_REP
Local Char    WEVA(40)
Local Integer WNOL : WNOL = val(PARAM(1))-1
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)
Endif
Local Char    W_FLDTCT(10)
Local Integer I, J
# Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(WNOL) = 4 | [M:CFA2]CTLTYP(WNOL) = 2 | [M:CFA2]CTLTYP(WNOL) = 4
If [M:CFA2]ASWTYP(WNOL) = 4 | find([M:CFA2]CTLTYP(WNOL),2,3,4,6)
  FIN = 0
Else
  FIN = 1
Endif
Return
############################################################
$DEBUT_REP
Raz [M:CFR]
# FQ 53410 QSTSHO remplacé par le lien
#[M:CFR]QSTDES = [F:CQU]QSTSHO-"("+[F:CQU]QSTNUM+")"
Case [F:CQU]ASWTYP
  When 4 :
    Gosub LOA_BOO
  When Default :
   Case [F:CQU]CTLTYP
      When 2 :  Gosub LOA_TCT
      When 3 :  Gosub LOA_TAB : # Issue 97416 GA 04/2014
      When 4 :  Gosub LOA_SHA
      When 6 :  Gosub LOA_ADI : # Issue 97416 GA 04/2014
    Endcase
Endcase
Affzo [M:CFR]
Return
############################################################
$LOA_TCT
Filter [TCT] Where TCT = [F:CQU]TCT
&            Order By Key TCT0
For [TCT]
  [M:CFR]TCTTYP = [F:TCT]TCTTYP
  If [M:CFR]NBLIG < dim([M:CFR]SELFLG)-1
    [M:CFR]SELFLG   ([M:CFR]NBLIG) = 1
    Case [F:TCT]TCTTYP
      When 1 :
        [M:CFR]COD   ([M:CFR]NBLIG) = [F:TCT]ALPCOD
        [M:CFR]ALPCOD([M:CFR]NBLIG) = [F:TCT]ALPCOD
        [M:CFR]NUMCOD([M:CFR]NBLIG) = 0
        For I = 1 To [M:CFA2]ASWMAX
          If evalue("[M:CFA2]COD"+format$("N0:3#",I)+"(WNOL)") = [F:TCT]ALPCOD
            [M:CFR]SELFLG   ([M:CFR]NBLIG) = 2
            Break
          Endif
        Next I
      When 2 :
        [M:CFR]COD   ([M:CFR]NBLIG) = num$([F:TCT]NUMCOD)
        [M:CFR]ALPCOD([M:CFR]NBLIG) = ""
        [M:CFR]NUMCOD([M:CFR]NBLIG) = [F:TCT]NUMCOD
        For I = 1 To [M:CFA2]ASWMAX
          If evalue("val([M:CFA2]COD"+format$("N0:3#",I)+"(WNOL))") = [F:TCT]NUMCOD
            [M:CFR]SELFLG   ([M:CFR]NBLIG) = 2
            Break
          Endif
        Next I
    Endcase
    Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
    [M:CFR]DESCOD   ([M:CFR]NBLIG) = W_DESTCT
    [M:CFR]NBLIG += 1
  Else
    Break
  Endif
Next
Filter [TCT]
Return
############################################################
# Chargement type booléen
$LOA_BOO
[M:CFR]TCTTYP = 2
[M:CFR]SELFLG(0) = 1
For I = 1 To [M:CFA2]ASWMAX
  If evalue("val([M:CFA2]COD"+format$("N0:3#",I)+"(WNOL))") = 1
    [M:CFR]SELFLG   (0) = 2
    Break
  Endif
Next I
[M:CFR]COD   (0) = "0"
[M:CFR]DESCOD(0) = mess(1,1,1)
[M:CFR]ALPCOD(0) = ""
[M:CFR]NUMCOD(0) = 1
#
[M:CFR]SELFLG(10) = 1
For I = 1 To [M:CFA2]ASWMAX
  If evalue("val([M:CFA2]COD"+format$("N0:3#",I)+"(WNOL))") = 2
    [M:CFR]SELFLG   (1) = 2
    Break
  Endif
Next I
[M:CFR]COD   (1) = "1"
[M:CFR]DESCOD(1) = mess(2,1,1)
[M:CFR]ALPCOD(1) = ""
[M:CFR]NUMCOD(1) = 2
#
[M:CFR]NBLIG     = 2
Return
############################################################
$LOA_SHA
Filter [CSH] Where SHACAT = [F:CQU]QSTNUM
&            Order By Key CSH0
For [CSH]
  [M:CFR]TCTTYP = 1
  If [M:CFR]NBLIG < dim([M:CFR]SELFLG)-1
    [M:CFR]SELFLG   ([M:CFR]NBLIG) = 1
    [M:CFR]COD      ([M:CFR]NBLIG) = [F:CSH]SHANUM
    [M:CFR]ALPCOD   ([M:CFR]NBLIG) = [F:CSH]SHANUM
    [M:CFR]NUMCOD   ([M:CFR]NBLIG) = 0
    For I = 1 To [M:CFA2]ASWMAX
      If evalue("[M:CFA2]COD"+format$("N0:3#",I)+"(WNOL)") = [F:CSH]SHANUM
        [M:CFR]SELFLG   ([M:CFR]NBLIG) = 2
        Break
      Endif
    Next I
    # FQ 60007 GA 11/2009
    # [M:CFR]DESCOD   ([M:CFR]NBLIG) = [F:CSH]SHANUMDES
    Call LECTEXTRA(GBIDC2,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
    [M:CFR]DESCOD([M:CFR]NBLIG) = GBIDC1
    [M:CFR]NBLIG += 1
  Else
    Break
  Endif
Next
Filter [CSH]
Return
############################################################
$LOA_ADI                           # Issue 97416 GA 04/2014

Filter [ADI] Where NUMTAB = val([F:CQU]CODFIC)
&            Order By Key CODE
For [ADI]
  If [M:CFR]NBLIG < dim([M:CFR]SELFLG)-1
    [M:CFR]SELFLG   ([M:CFR]NBLIG) = 1
    [M:CFR]COD      ([M:CFR]NBLIG) = [F:ADI]CODE
    [M:CFR]ALPCOD   ([M:CFR]NBLIG) = [F:ADI]CODE
    [M:CFR]NUMCOD   ([M:CFR]NBLIG) = [F:ADI]N1
    For I = 1 To [M:CFA2]ASWMAX
      If evalue("[M:CFA2]COD"+format$("N0:3#",I)+"(WNOL)") = [F:ADI]CODE
        [M:CFR]SELFLG   ([M:CFR]NBLIG) = 2
        Break
      Endif
    Next I
    Call LECTEXTRA (GBIDC1, "ATABDIV", "LNGDES", num$([F:ADI]NUMTAB), [F:ADI]CODE) From ATEXTRA
    [M:CFR]DESCOD([M:CFR]NBLIG) = GBIDC1
    [M:CFR]NBLIG += 1
  Endif
Next
Filter [ADI]
Return
############################################################
$LOA_TAB                           # Issue 97416 GA 04/2014
Local Char WVALALP(250)
W_VAR = W_PRS+[F:CQU]QSTNUM

Gosub OPE_FILTER From WUVAR
Gosub SET_FILTER From WUVAR

Local File ATABLE [ATBW]
Read [ATBW]CODFIC = [F:CQU]CODFIC
If fstat Return Endif
If filinfo(filpath("FIL",[F:CQU]CODFIC,"fde"),0) < 0 Return Endif
If S_FILTER="" S_FILTER="1=1" Endif
Local File =[F:CQU]CODFIC [LNK]

Filter [LNK] Where evalue(S_FILTER)
For [LNK]
  If [M:CFR]NBLIG < dim([M:CFR]SELFLG)-1
    [M:CFR]SELFLG   ([M:CFR]NBLIG) = 1
    [M:CFR]COD      ([M:CFR]NBLIG) = evalue("[F:LNK]"+[F:CQU]CODFLD)
    [M:CFR]ALPCOD   ([M:CFR]NBLIG) = [M:CFR]COD([M:CFR]NBLIG)
    [M:CFR]NUMCOD   ([M:CFR]NBLIG) = 0
    For I = 1 To [M:CFA2]ASWMAX
      If evalue("[M:CFA2]COD"+format$("N0:3#",I)+"(WNOL)") = [M:CFR]COD([M:CFR]NBLIG)
        [M:CFR]SELFLG   ([M:CFR]NBLIG) = 2
        Break
      Endif
    Next I
    If [F:ATBW]INTIT<>""
       If evalue("dim([F:LNK]"+[F:ATBW]INTIT+")")>0 # Issue 100646 GA 08/2014
          [M:CFR]DESCOD([M:CFR]NBLIG) = evalue("[F:LNK]"+[F:ATBW]INTIT)
       Endif
    Endif
    [M:CFR]NBLIG += 1
  Endif
Next
Filter [LNK]

W_VAR = W_PRS+[F:CQU]QSTNUM
Gosub RESET_FILTER From WUVAR
Return
############################################################
$BOUTON_REP
For I = 0 To [M:CFR]NBLIG-1
  Case BOUT
    When "a" : [M:CFR]SELFLG(I) = 2
    When "b" : [M:CFR]SELFLG(I) = 1
  Endcase
Next I
Affzo [M:CFR]
Return
############################################################
$AVOK_REP
J = 0
For I = 0 To [M:CFR]NBLIG-1
  If [M:CFR]SELFLG(I) = 2
    J += 1
  Endif
Next I
If J > 0
  Case [F:CQU]CTLTYP
    When 2 :
      If J > [M:CFA2]ASWMAX
        GMESSAGE = num$(J)-mess(127,188,1)-num$([M:CFA2]ASWMAX)
        GERR     = 1
        FIN      = 0
      Endif
    When 3,4,6 : # Issue 97416 GA 04/2014 before 4
      If J > 1
        GMESSAGE = num$(J)-mess(127,188,1)-"1"
        GERR     = 1
        FIN      = 0
      Endif
  Endcase
Endif
Return
############################################################
$OK_REP
For I = 1 To [M:CFA2]ASWMAX
  Assign "[M:CFA2]ASW"+format$("N0:3#",I)+"(WNOL)" With ""
  Assign "[M:CFA2]COD"+format$("N0:3#",I)+"(WNOL)" With ""
Next I
J = 1
For I = 0 To [M:CFR]NBLIG-1
  If [M:CFR]SELFLG(I) = 2
    If J <= [M:CFA2]ASWMAX
      Assign "[M:CFA2]ASW"+format$("N0:3#",J)+"(WNOL)" With [M:CFR]DESCOD(I)
      Case [M:CFR]TCTTYP
        When 1 :
          Assign "[M:CFA2]COD"+format$("N0:3#",J)+"(WNOL)" With [M:CFR]ALPCOD(I)
          If J=1 [M:CFA2]STRVAL(WNOL)=[M:CFR]ALPCOD(I) Endif  # Issue 100646 GA 08/2014
        When 2 :
          Assign "[M:CFA2]COD"+format$("N0:3#",J)+"(WNOL)" With num$([M:CFR]NUMCOD(I))
          If J=1 [M:CFA2]STRVAL(WNOL)=num$([M:CFR]NUMCOD(I)) Endif  # Issue 100646 GA 08/2014
      Endcase
      J += 1
    Else
      Break
    Endif
  Endif
Next I
Gosub CAL_CFGNBR
Affzo [M:CFA2]
FIN = 1
Return
############################################################
# Calcul nombre de réponses par ligne et nombre combinaisons
$CAL_CFGNBR
For I = 0 To [M:CFA2]NBLIG-1
  [M:CFA2]ASWNBR(I) = 0
  # Issue 100646 GA 06/2014 Raz Issue 97416 GA 04/2014
  #If [M:CFA2]ASWTYP(I) = 4 | [M:CFA2]CTLTYP(I) = 2 | [M:CFA2]CTLTYP(I) = 4
  #If [M:CFA2]ASWTYP(I) = 4 | find([M:CFA2]CTLTYP(I),2,3,4,6)
  If [M:CFA2]ASWTYP(I) = 4 | find([M:CFA2]CTLTYP(I),2,4)
    For J = 1 To [M:CFA2]ASWMAX
      If evalue("[M:CFA2]ASW"+format$("N0:3#",J)+"(I)") <> ""
        [M:CFA2]ASWNBR(I)+= 1
      Endif
    Next J
  Else
    If [M:CFA2]NBRVAL(I)=0 & [M:CFA2]STRVAL(I)<>"" # Issue 100646 GA 08/2014
       [M:CFA2]NBRVAL(I)=1
    Endif
    [M:CFA2]ASWNBR(I) += [M:CFA2]NBRVAL(I)
  Endif
Next I
# Calcul combinaisons
[M:CFA2]CFGNBR = 0
For I = 0 To [M:CFA2]NBLIG-1
  If [M:CFA2]ASWNBR(I) <> 0
    If [M:CFA2]CFGNBR = 0
      [M:CFA2]CFGNBR = 1
    Endif
    [M:CFA2]CFGNBR *= [M:CFA2]ASWNBR(I)
  Endif
Next I
#
Return
############################################################
$END_REP
FIN = 1
Return
############################################################
$FIN_REP
mkstat = 4
Return
############################################################
############################################################
# Actions écran
############################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return
############################################################
Subprog AS_NBLIG
If !GINTRA
  Gosub SET_NOL
  Read [CQU]CQU0=[M:CFA2]QSTNUM(NOL)
  If !fstat
   # Issue 97416 GA 04/2014
   #If [F:CQU]TCT <> "" | [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 4
   If [F:CQU]TCT <> "" | [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),3,4,6)
      End
    Else
      GBOUT1 = ""
    Endif
  Else
    GBOUT1 = ""
  Endif
Endif
End
############################################################
Subprog IB_NBLIG
If GINTRA
  Gosub SET_NOL
  Read [CQU]CQU0=[M]QSTNUM(NOL)
  If fstat = 0
   # Issue 97416 GA 04/2014
   #If [F:CQU]TCT <> "" | [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 4
   If [F:CQU]TCT <> "" | [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),3,4,6)
      End
    Else
      GBOUT1 = ""
    Endif
  Else
    GBOUT1 = ""
  Endif
Endif
End
###########################################################
Subprog AS_STRVAL(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
# Issue 100646 GA 06/2014 Raz Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 2 | [M:CFA2]CTLTYP(NOL) = 4
#If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),3,4,6)
If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,4)
  mkstat = 2
Endif
End
############################################################
Subprog C_STRVAL(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
Local Char    WALP(250),WVAL(250)
Local Decimal WNUM
Local Date    WDAT
WVAL=VALEUR
Call SAI_VARIABLE(WVAL,[M:CFA2]ASWTYP(NOL),[M:CFA2]ASWCHA(NOL),WALP,WNUM,WDAT,mkstat)
&    From CFGLIBD
If mkstat = 0
  Case [M:CFA2]ASWTYP(NOL)
    When 1 :
      [M:CFA2]COD001(NOL) = WALP
      Call CFGCTRALP(WALP,[M:CFA2]QSTNUM(NOL)) From CFGLIB
      If VALEUR <> "" & [M:CFA2]QSTNUM(NOL) = "BPRNUM"
        VALEUR = toupper(VALEUR)
        Read [BPR]BPR0=VALEUR
        If fstat
          mkstat = 2
        Endif
      Endif
    When 2 :
      [M:CFA2]COD001(NOL) = num$(WNUM)
      Call CFGCTRNUM(WNUM,[M:CFA2]QSTNUM(NOL)) From CFGLIB
    When 3 :
      [M:CFA2]COD001(NOL) = WDAT
      Call CFGCTRDAT(WDAT,[M:CFA2]QSTNUM(NOL)) From CFGLIB
    When 5 :
      [M:CFA2]COD001(NOL) = WALP   # Issue 100646 GA 08/2014
      Call CFGCTRTXT(WALP,[M:CFA2]QSTNUM(NOL)) From CFGLIB
  Endcase
  VALEUR=WVAL
  Affzo [M:CFA2]COD001(NOL)
Endif
End
###########################################################
Subprog AS_NBRVAL(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
# Issue 100646 GA 08/2014 - Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 2 | [M:CFA2]CTLTYP(NOL) = 4
#If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,3,4,6)
If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,4)
  VALEUR = 0
  mkstat = 2
Else
  If [M:CFA2]ASWTYP(NOL) = 1
    VALEUR = 1
    mkstat = 2
  Else
    If VALEUR = 0
      VALEUR = 1
    Endif
  Endif
Endif
End
############################################################
Subprog C_NBRVAL(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
Local Decimal WVALEUR
WVALEUR             = [M:CFA2]NBRVAL(NOL)
[M:CFA2]NBRVAL(NOL) = VALEUR
Gosub CAL_CFGNBR
[M:CFA2]NBRVAL(NOL) = WVALEUR
Affzo [M:CFA2]CFGNBR
End
###########################################################
Subprog AS_STEVAL(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
# Issue 100646 GA 08/2014 - Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 2 | [M:CFA2]CTLTYP(NOL) = 4
#If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,3,4,6)
If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,4)
&  | [M:CFA2]NBRVAL(NOL) = 1
  VALEUR = 0
  mkstat = 2
Else
  If [M:CFA2]ASWTYP(NOL) = 1
    VALEUR = 0
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog C_STEVAL(VALEUR)
Variable Decimal VALEUR
Local Decimal WNUM
Local Date    WDAT
Local Integer I
Gosub SET_NOL
Case [M:CFA2]ASWTYP(NOL)
  When 2 :
    WNUM = val([M:CFA2]COD001(NOL))
  When 3 :
    WDAT = [M:CFA2]COD001(NOL)
  When Default :
    End
Endcase
I = [M:CFA2]NBRVAL(NOL)
While I > 0
  Case [M:CFA2]ASWTYP(NOL)
    When 2 :
      Call CFGCTRNUM(WNUM,[M:CFA2]QSTNUM(NOL)) From CFGLIB
      If mkstat
        Break
      Else
        WNUM += VALEUR
      Endif
    When 3 :
      Call CFGCTRDAT(WDAT,[M:CFA2]QSTNUM(NOL)) From CFGLIB
      If mkstat
        Break
      Else
        WDAT += VALEUR
      Endif
  Endcase
  I - = 1
Wend
If mkstat = 0
  # FQ 53410 QSTSHO remplacé par le lien
  #Affzo [M:CFA2]QSTSHO(NOL)
Endif
End
########################################
Subprog AV_QSTSHO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
#
# Issue 100646 GA 08/2014 - Issue 97416 GA 04/2014
#If [M:CFA2]ASWTYP(NOL) = 4 | [M:CFA2]CTLTYP(NOL) = 2 | [M:CFA2]CTLTYP(NOL) = 4
#If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,3,4,6)
If [M:CFA2]ASWTYP(NOL) = 4 | find([M:CFA2]CTLTYP(NOL),2,4)
  pcolor = GCOUL(3)
Else
  pcolor = GCOUL(0)
Endif
End


######################################################################################

