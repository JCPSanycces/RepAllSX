######################################################################################
Subprog AM_CIGCOD(VALEUR)
Variable Char    VALEUR

If VALEUR <> "" 
   GCIGCOD  = VALEUR 
Endif   

End

######################################################################################
## Rubrique EFFDAT : Date d'effet                                                   ## 
######################################################################################
Subprog AS_EFFDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR = [0/0/0]
     [M:CIG0]EFFDAT  = date$ 
     Affzo [M:CIG0]EFFDAT
  Endif

 [M:CIR3]RULTPFDAT =  gdat$ ( 31, 12, year([M:CIG0]EFFDAT)-1)  
 Affzo  [M:CIR3]RULTPFDAT

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CIG0) 27/07/2006 15:47:50 (MDR)
######################################################################################
Subprog AM_EFFDAT(VALEUR)
Variable Date    VALEUR
Local Date WEFFDAT

  [M:CIR3]RULTPFDAT =  gdat$ ( 31, 12, year(VALEUR)-1)
  Affzo  [M:CIR3]RULTPFDAT

End
######################################################################################
## Rubrique REFSELCIG : Selection                                                   ## 
######################################################################################
Subprog AM_REFSELCIG(VALEUR)
Variable Char    VALEUR()


If VALEUR  <> "" &  GCSOCSRC = "" 
        VALEUR = ""
        GMESSAGE = mess(174,GML_MSGCIG,1)    : GERR=1 
        mkstat=2 : End
Else  
  Call LECTURE("CIS",VALEUR,"") From CONTOBJ
  [M:CIR1]CIGREXSEL(nolign-1)= [F:CIS]SELCIGDES
  Affzo   [M:CIR1]CIGREXSEL(nolign-1)
Endif 

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CIR4) 01/09/2005 11:50:26 (JDE)
######################################################################################
Subprog AV_REFCDF(VALEUR)
Variable Char    VALEUR()

If VALEUR  <> "" &  GCSOCSRC = "" 
        VALEUR = ""
        GMESSAGE = mess(174,GML_MSGCIG,1)    : GERR=1 
        mkstat=2 : End
Else  
  Call LECTURE("REC",VALEUR,"") From CONTOBJ
  [M:CIR4]REFCDF(nolign-1)= [F:REC]REFCDF
  Affzo    [M:CIR4]REFCDF(nolign-1)
Endif 

End

