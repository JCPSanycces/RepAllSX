      OK=0
      mkstat=2
Endif 

If VALEUR <> ""
 #    Call CTRL_DPM (VALEUR, GCSOCDES , [M:CIR2]DPRPLN (nolign-1), 0, LERROR) From TRTFAS
 #   If (LERROR) Then
