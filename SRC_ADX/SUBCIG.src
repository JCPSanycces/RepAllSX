######################################################################################
Subprog AM_REFCDF(VALEUR)
Variable Char    VALEUR()

If VALEUR  <> "" &  GCSOCSRC = "" 
        VALEUR = ""
        GMESSAGE = mess(174,GML_MSGCIG,1)    : GERR=1 
        mkstat=2 : End
Else  
  Call LECTURE("CIR",VALEUR,"") From CONTOBJ
  If fstat=0
    [M:CIR4]REFCDF(nolign-1)= VALEUR        : Affzo [M:CIR4]REFCDF(nolign-1)
    [M:CIR4]REFDES(nolign-1)= [F:CDF]REFDES : Affzo  [M:CIR4]REFDES(nolign-1)
  Endif   
  Affzo   [M:CIR1]CIGREXSEL(nolign-1)
Endif 

End
######################################################################################
Subprog C_RULTPFDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR > [M:CIG0]EFFDAT
      GMESSAGE = mess(212,GML_MSGCIG,1)    : GERR=1 
      mkstat=2   : End
  Endif

End
######################################################################################
Subprog AM_RULTPFDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR > [M:CIG0]EFFDAT
      GMESSAGE = mess(212,GML_MSGCIG,1)    : GERR=1 
      mkstat=2 : End
  Else 
      [M:CIR3]RULTPFDAT  = VALEUR
      Affzo [M:CIR3]RULTPFDAT 
  Endif

End
######################################################################################
### FQ-53890
######################################################################################
Subprog AM_VATTRFFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = G_OUI
   [M:CIR3]ISSVATRAT  = 0
   Diszo[M:CIR3]ISSVATRAT
Else
   Actzo [M:CIR3]ISSVATRAT
Endif  
 Affzo [M:CIR3]ISSVATRAT

End
######################################################################################
### FQ-53890  
######################################################################################
Subprog AS_ISSVATRAT(VALEUR)
Variable Decimal VALEUR

If [M:CIR3]VATTRFFLG = G_OUI or [M:CIG0]CIGTYP <> GVML_TOVTEIG
   [M:CIR3]ISSVATRAT  = 0
   Diszo [M:CIR3]ISSVATRAT
Else
   Actzo [M:CIR3]ISSVATRAT
Endif  
 Affzo [M:CIR3]ISSVATRAT

End
######################################################################################
### FQ-54321 
######################################################################################
Subprog AM_ISSVATRAT(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> 0 and [M:CIG0]CIGTYP <> GVML_TOVTEIG
      [M:CIR3]ISSVATRAT  = 0
      Diszo[M:CIR3]ISSVATRAT
  Else 
      [M:CIR3]ISSVATRAT = VALEUR
      Affzo [M:CIR3]ISSVATRAT
  Endif


End
