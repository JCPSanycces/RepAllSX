######################################################################################
## Rubrique PLNTPL: combo des plans modèles                                         ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_PLNTPL(VALEUR)
Variable Integer VALEUR

# Si plan cible = Origine , les Valeurs proviennent obligatoirement du  plan modèle Comptable
If [M:CIR2]DPRPLN (nolign-1) = G301ORI             
    Raz GMENLOC
    GMENLOC(G301FIS)=1 
    GMENLOC(G301MIN)=1 
    GMENLOC(G301ORI)=1 
    GMENLOC(G301R76)=1 
    GMENLOC(G301IAS)=1 
    GMENLOC(G301TEC)=1 
    GMENLOC(G301RET)=1 
    GMENLOC(G301SUB)=1 
    GMENLOC(G301LI1)=1 
    GMENLOC(G301LI2)=1 
    GMENLOC(G301LI3)=1 
    GMENLOC(G301LI4)=1 
    GMENLOC(G301LI5)=1 
    GMENLOC(G301LI6)=1 
    GMENLOC(G301AUC)=1 
Endif 

# Si la règle de gestion = Prix de cession ou Valeur identique --> il n'y a pas de plan modèle a saisir 
If [M:CIR2]RULPRO (nolign-1) = GML_VBPRICES or [M:CIR2]RULPRO (nolign-1) = GML_VAIDENTI
    Raz GMENLOC
    GMENLOC(G301CPT)=1 
    GMENLOC(G301FIS)=1 
    GMENLOC(G301MIN)=1 
    GMENLOC(G301ORI)=1 
    GMENLOC(G301R76)=1 
    GMENLOC(G301IAS)=1 
    GMENLOC(G301TEC)=1 
    GMENLOC(G301RET)=1 
    GMENLOC(G301SUB)=1 
    GMENLOC(G301LI1)=1 
    GMENLOC(G301LI2)=1 
    GMENLOC(G301LI3)=1 
    GMENLOC(G301LI4)=1 
    GMENLOC(G301LI5)=1 
    GMENLOC(G301LI6)=1 
    GMENLOC(G301AUC)=1 
Endif 

# Supprimer les plans non gérés par la société source 

Filter [APL] Where [F:APL]LANCHP = GML_NPLAN and [F:APL]LAN = GLANGUE 
For [APL]
  If func GLOBIENS.CPY_PLN_GERE(GCSOCSRC ,[F:APL]LANNUM)=G_NON
    GMENLOC([F:APL]LANNUM)=1
  Endif 
Next 
Filter [APL] 

End
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_PLNTPL(VALEUR)
Variable Integer VALEUR
Local Integer WICONTEXTE


Local Char    WCDEVS 
Local Char    WCDEVC
Local Integer WINORMS 
Local Integer WINORMC 
Local Integer WIPLN     
Local Integer WAIDENTI  

WCDEVS = "" 
WCDEVC = "" 
WIPLN = 0 

If VALEUR <> 0 
    ## Message d'erreur si le contexte du plan modèle n'est pas exprimé dans la même devise
    ## que le plan à alimenter 
    
    # Devise du plan modèle (société source)
    Call GET_CNX_FROM_PLAN (GCSOCSRC, VALEUR, WICONTEXTE) From GLOBIENS
    Read [F:CNX]CNX0=GCSOCSRC ;WICONTEXTE
    If fstat = 0 
         WCDEVS = [F:CNX]CUR    
    Else
         WCDEVS = GEURO  
    Endif
    
    # Devise du plan à alimenter (société cible)
    Call GET_CNX_FROM_PLAN (GCSOCDES, [M:CIR2]DPRPLN (nolign-1), WICONTEXTE) From GLOBIENS
    Read [F:CNX]CNX0=GCSOCDES ;WICONTEXTE
    If fstat = 0 
         WCDEVC = [F:CNX]CUR    
    Else
         WCDEVC = GEURO  
    Endif
    
    If WCDEVS <> WCDEVC 
          GMESSAGE = format$("Kb:41X", mess(114,GML_MSGCIG,1)+mess([M:CIR2]DPRPLN (nolign-1),301,1))+mess(113,GML_MSGCIG,1)
&                    + WCDEVC + '\' + format$("Kb:40X", mess(114,GML_MSGCIG,1) +  mess(VALEUR,301,1)) + mess(113,GML_MSGCIG,1)
&                    + WCDEVS + '\' + '\' +  mess(112,GML_MSGCIG,1) 
          GOK=0
          OK=0
          mkstat=2
    Endif 
     
    # Normes du plan modèle 
    WINORMS = func GLOBIENS.GET_NORME_PLAN(GCSOCSRC , VALEUR)
    
    # Normes du plan à alimenter  
    WINORMC = func GLOBIENS.GET_NORME_PLAN(GCSOCDES , [M:CIR2]DPRPLN (nolign-1))
    
    #  Si normes du plan à alimenter = IAS/IFRS    --> normes du plan modèle peut être dans toutes les normes 
    
    ##*Fq-72771  Si règle de gestion <>  "Valeur brute = valeur nette du plan modèle"
    If [M:CIR2]RULPRO(nolign-1)<> GML_VBVANPLM       
      #  Si normes du plan à alimenter = STANDARD    --> normes du plan modèle doivent être : Standard
      If  WINORMC = GVML_NPSTD and WINORMS <> GVML_NPSTD
         GMESSAGE =  mess(116,GML_MSGCIG,1) 
          GOK=0
          OK=0
          mkstat=2
       Endif        
      #  Si normes du plan à alimenter = CRC 2002-10 --> normes du plan modèle doivent être : Standard ou CRC200210
      If  WINORMC = GVML_NPCRC    and WINORMS <> GVML_NPSTD and WINORMS <> GVML_NPCRC    
         GMESSAGE =  mess(117,GML_MSGCIG,1) 
         GOK=0 : OK=0 : mkstat=2
      Endif 
    Endif   #Fq-72771

    If ([M:CIR2]RULPRO (nolign-1)= GML_VAIDENTI)  or ([M:CIR2]RULPRO = GML_VAIDEPLM) 
      WAIDENTI = G_OUI
      WIPLN = VALEUR      
      Gosub COMPARE_EXERCICES_DEVISES
    Endif 

Endif 

End
######################################################################################
