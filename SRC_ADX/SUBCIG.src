## Rubrique CPYDES: Société cible                                                   ##
######################################################################################


#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_CPYDES(VALEUR)
Variable Char    VALEUR()


Call CHANGE_SOC_DES_COURANTE (0)

If nolign = 1  
  GCSOCDES = VALEUR 
Endif

End

