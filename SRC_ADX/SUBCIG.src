#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################################
##   Source : SUBCIG                                                                                  ##                      
##   Auteur : JDE                                                                                      ##                       
##   Parametrage de la Cession intra-groupe                                                          ##                     
##  Date création : 17/10/05   
##  MDJ  29/06/2011 (FQ 72446) : Recodif non rattachée à la CIG ==> ajout msg erreur              ##    
##  MDJ  03/11/2010 (FQ 68840) : Ecrans grizés si cession terminée                                ##      
##  MDJ  03/06/2009 (FQ 54321) : Corrections sur transfert TVA     
##  MDJ  03/06/2009 (FQ 53890) : Corrections sur transfert TVA                                      ## 
##  MDJ  03/06/2009 (FQ 54321) : Corrections sur transfert TVA                                      ## 
##  MDJ: 08/10/2008 (*V6) : Aménagements V6       
#######################################################################################################
##------------------------------------------------------------------------------------------------##
##  La fonction GESCIG permet d'inserer l'action GOBJET avec le parametre CIG dans le menu               
##  L'action GOBJET appelle : 
##       - La fenètre OCIG qui appelle les écrans CIG0  
##       - Le traitement SUBCIG 
##------------------------------------------------------------------------------------------------##
## PRINCIPALES ETIQUETTES UTILISEES                                                               ## 
##   $OUVRE                  : Avant ouverture de l'écran                                         ##   
##   $AP_ANNULE              : Action faite après l'annulation de la table principale             ##   
##   $VERIF                                                                                       ##
##       Gosub CONTROLE_SAISIE1                                                                   ##
##       Gosub CONTROLE_SAISIE2                                                                   ##   
##   $LIENS                  : Après lecture d'un enregistrement                                  ##
##       Gosub CHARGE_ENTETE                                                                      ##
##       Gosub CHARGE_ONGLET_123                                                                  ##
##       Gosub CHARGE_ONGLET_4_RECOD                                                              ##
##   $CONTROLE-SAISIE1        : Controle de cohérence de la saisie des infos principal entete     ##
##   $CONTROLE-SAISIE2        : Controle de cohérence de la saisie des onglets                    ##
##   $APRES_CRE               : Après la création de l'enregistrement                             ##  
##       $ECRIT_TABLE_CIR         : Ecriture des postes du tableau dans la table CIR              ##
##       $TEST_SEL_SOC            : Test que les onglets du bas de l'ecran sont bien alimentés    ##  
##------------------------------------------------------------------------------------------------##
  
## Gestion du masque CIG
#
Raz GPILOBJ
Call OBJET("CIG",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
    When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
    When "OUVRE"        : Gosub OUVRE       
    When "RAZCRE"       : Gosub RAZCRE       
    When "RAZDUP"       : Gosub RAZDUP       
    When "LIENS"        : Gosub LIENS    
    When "STYLE"        : Gosub STYLE    
    When "APRES_CRE"    : Gosub APRES_CRE   : # Après la création de l'enregistrement 
    When "APRES_MOD"    : Gosub APRES_MOD   : # Après la modification de l'enregistrement 
    When "AP_ANNULE"    : Gosub AP_ANNULE   : # Après l'annulation de l'enregistrement 
    When "SETBOUT"      : Gosub SETBOUT     : # Gestion des boutons  
    When "VERIF_CRE"    : Gosub VERIF_CRE   : # Avant la transaction de création de l'enregistrement 
    When "VERIF_MOD"    : Gosub VERIF_MOD   : # Avant la modification de l'enregistrement    
    When "EXEBOUT"      : Gosub EXEBOUT     : # Boutons : B : Saisie d'une sélection  
    When "END"          : Gosub FIN
    When "FIN"          : Gosub FIN
    When "APRES_CHOI"   : Gosub APRES_CHOI
    When "SEL_LISTE"    : Gosub SEL_LISTE   : # Sélection des référence de sélection CIG par click droit     

When Default
Endcase

Return
####################################################################################################
## $AVANT_OUVRE: avant ouverture de l'écran                                                       ##   
####################################################################################################
$AVANT_OUVRE
Global Char GCSOCSRC
Global Char GCSOCDES
Global Char GCIGCOD
Global Char GCSRCAV
Global Char GCSRCAP
Global Char GCDESAV
Global Char GCDESAP
Global Char GSELCIG
Global Integer GISUPLIG
Global Integer GIADDLIG

GISUPLIG = G_NON
GIADDLIG = G_NON

Return 
###################################################################################################
## $OUVRE: avant ouverture de l'écran                                                             ##   
####################################################################################################
$OUVRE

Local Integer WILIG

GOK = 1

If clalev([F:CIG2]) =0 : Local File CIGDEF    [CIG2]          : Endif : # Définition CIG 
If clalev([F:CIR])  =0 : Local File CIGREX    [CIR]           : Endif : # Paramétrage CIG 
If clalev([F:CIS])  =0 : Local File CIGREXSEL [CIS]           : Endif : # Sélection CIG 
If clalev([F:CIB])  =0 : Local File CIGFXDSOR [CIB]           : Endif : # Tables des biens sortis  
If clalev([F:CDF])  =0 : Local File CDFPAR    [CDF]           : Endif : # Paramétrage de recodification 
If clalev([F:ATB])  =0 : Local File ATABLE    [ATB]           : Endif : # Table des Tables 
If clalev([F:ATX2]) =0 : Local File ATEXTE    [ATX2]          : Endif : # Table des textes 
If clalev([F:APL])  =0 : Local File APLSTD    [APL]           : Endif : # Table des menus locaux   
If clalev([F:CNX])  =0 : Local File CONTEXT   [CNX]           : Endif : # Tables des contextes
If clalev([F:DPM])  =0 : Local File DPRMOD    [DPM]           : Endif : # Tables des modes d'amortissement 

Local Mask CIG0 [CIG0]
Local Mask CIR4 [CIR4]

Raz [M:CIR4]

  # Sauvegarde du contexte - variables globales
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif

Local Integer WICTRLOK
WICTRLOK = G_OUI

Return
###################################################################################################
## $RAZCRE                                                                                        ##
####################################################################################################
$RAZCRE
    # On initialise le statut de l'opération à "En préparation"
     [M:CIG0]CIGSTA = GVML_CIGSTAP
     Gosub REINIT_ONGLET
     GCSOCSRC = ""
     GCSOCDES = ""
     #GCIGCOD = ""
     Actzo [M:CIG0]

Return
####################################################################################################
## $REINIT_ONGLET: Reinitialisation des onglets                                                   ## 
####################################################################################################
$REINIT_ONGLET

Effzo [M:CIR1] NBRSEL
Effzo [M:CIR1] REFSELCIG
Effzo [M:CIR1] GACACNWIP
Effzo [M:CIR1] GACACNREA
Effzo [M:CIR1] OWNTYPLEA
Effzo [M:CIR1] PURDATEFF
Effzo [M:CIR1] OUTDATEFF
Effzo [M:CIR1] SALPRIMOD
Effzo [M:CIR1] SALPRIPLN
Effzo [M:CIR1] SALPRI
Effzo [M:CIR1] SALPRIDEF
Effzo [M:CIR1] CUR

Effzo [M:CIR2] NBRPLN
Effzo [M:CIR2] DPRPLN
Effzo [M:CIR2] RULPRO
Effzo [M:CIR2] PLNTPL
Effzo [M:CIR2] DPRDPM
Effzo [M:CIR2] DPRDUR
Effzo [M:CIR2] DPRDURDEF
Effzo [M:CIR3] TAXBASTPF
Effzo [M:CIR3] VATTRFFLG 
Effzo [M:CIR3] ISSVATRAT 
Effzo [M:CIR3] PURITSDAT
Effzo [M:CIR3] PURNAT
Effzo [M:CIR3] BASGAL
Effzo [M:CIR3] GALPRO
Effzo [M:CIR3] GALPLNSRC
Effzo [M:CIR3] GALPLNDES
Effzo [M:CIR3] GALDAT
Effzo [M:CIR3] GALDPM
Effzo [M:CIR3] GALDUR

Return
####################################################################################################
## $RAZDUP                                                                                        ##
####################################################################################################
$RAZDUP
    # On initialise le statut de l'opération à "En préparation"
     [M:CIG0]CIGSTA = GVML_CIGSTAP
     Actzo [M:CIG0]
Return
####################################################################################################
## $APRES_CRE                                                                                     ##
####################################################################################################
$APRES_CRE

Gosub ECRIT_TABLE_CIR
Gosub TEST_SEL_SOC 

Call SOC_SRC_COURANTE(0)
Call SOC_DES_COURANTE(0)

Return
####################################################################################################
## CHANGE_SOC_SRC_COURANTE : recoit le numéro de ligne                                              ##
####################################################################################################
Subprog CHANGE_SOC_SRC_COURANTE (PNUMLIG)
Value  Integer  PNUMLIG

Local Integer WN
For WN = 0 To [M:CIG0]NBCPY-1
    If WN = PNUMLIG 
         Call SOC_SRC_COURANTE(WN)
    Else 
        Chgstl [M:CIG0]CPYSRC(WN) With ""
    Endif 
Next 

End 
####################################################################################################
## CHANGE_SOC_DES_COURANTE : recoit le numéro de ligne                                              ##
####################################################################################################
Subprog CHANGE_SOC_DES_COURANTE (PNUMLIG)
Value  Integer  PNUMLIG

Local Integer WN
For WN = 0 To [M:CIG0]NBCPY-1
    If WN = PNUMLIG 
         Call SOC_DES_COURANTE(WN)
    Else 
        Chgstl [M:CIG0]CPYDES(WN) With ""
    Endif 
Next 

End 
####################################################################################################
## SOC_SRC_COURANTE : recoit le numéro de ligne                                                   ##
####################################################################################################
Subprog SOC_SRC_COURANTE (PNUMLIG)
Value  Integer  PNUMLIG

If varmode([M:CIG0]CIGCOD,0) = 0
    Chgstl [M:CIG0]CPYSRC(PNUMLIG) With "CIG1"
Else 
    Chgstl [M:CIG0]CPYSRC(PNUMLIG) With "CIG2"
Endif 

If [M:CIG0]CPYSRC(PNUMLIG) <> ""
    GCSOCSRC = [M:CIG0]CPYSRC(PNUMLIG)
Endif 

End 
####################################################################################################
## SOC_DES_COURANTE : recoit le numéro de ligne                                                   ##
####################################################################################################
Subprog SOC_DES_COURANTE (PNUMLIG)
Value  Integer  PNUMLIG

If varmode([M:CIG0]CIGCOD,0) = 0
    Chgstl [M:CIG0]CPYDES(PNUMLIG) With "CIG1"
Else 
    Chgstl [M:CIG0]CPYDES(PNUMLIG) With "CIG2"
Endif 

If [M:CIG0]CPYDES(PNUMLIG) <> ""
     GCSOCDES = [M:CIG0]CPYDES(PNUMLIG)
Endif 

End 
####################################################################################################
## $TEST_SEL_SOC                                                                                  ##
####################################################################################################
$TEST_SEL_SOC 
Local Integer WK 
Local Integer WL 
Local Integer CTRLOK 
Local Char    WCSOCSRC1 
Local Char    WCSOCDES1 
##------------------------------------------------------------------------------------------------##
## Controle de l'existence d'une reference de selection et l'existence du parametrage des plans   ## 
##------------------------------------------------------------------------------------------------##                   
CTRLOK = G_OUI
Read [F:CIG2]  =  [M:CIG0]CIGCOD
If fstat = 0 

    WCSOCSRC1 = [F:CIG2]CPYSRC(0)
    WCSOCDES1 = [F:CIG2]CPYDES(0)

    For WK = 0 To [F:CIG2]NBCPY-1  
       
       If [F:CIG2]CIGTYP = GVML_TOFUSIO
             GCSOCDES = WCSOCDES1 
       Elsif [F:CIG2]CPYDES(WK) <> "" 
             GCSOCDES = [F:CIG2]CPYDES(WK)
       Endif 
        
       If [F:CIG2]CIGTYP = GVML_TOSCISS
             GCSOCSRC = WCSOCSRC1 
       Elsif [F:CIG2]CPYSRC(WK) <> "" 
             GCSOCSRC = [F:CIG2]CPYSRC(WK)
       Endif 

       Read [F:CIR]CIR0  =  [M:CIG0]CIGCOD; GCSOCSRC  ; GCSOCDES 
       If fstat <>  0 
           GMESSAGE = mess(17,GML_MSGCIG,1) + ' : ' +   format$("Kb:5X", GCSOCSRC ) + '    ' + 
&                     mess(18,GML_MSGCIG,1) + ' : ' +  format$("Kb:5X", GCSOCDES ) + '    ' + mess(151,GML_MSGCIG,1)   
           GERR=1 
           mkstat=4
           CTRLOK = G_NON
 
       Elsif  [F:CIR]REFSELCIG (0) = "" 
             ##---------------------------------------------------------------------------------------------##
             ## Lecture selection                                                                           ##
             ##---------------------------------------------------------------------------------------------##
             GMESSAGE = mess(17,GML_MSGCIG,1) + ' : ' +   format$("Kb:5X", GCSOCSRC ) + '    ' +
&                       mess(18,GML_MSGCIG,1) + ' : ' +  format$("Kb:5X", GCSOCDES ) + '    ' + mess(151,GML_MSGCIG,1)  
             GERR=1 
             mkstat=4
             zonsui = "[M:CIR1]REFSELCIG(0)"
             CTRLOK = G_NON
       
       Elsif [F:CIR]DPRPLN (0) = 0 
             ##---------------------------------------------------------------------------------------------##
             ## Lecture du plan                                                                             ##
             ##---------------------------------------------------------------------------------------------##
             GMESSAGE =  mess(17,GML_MSGCIG,1) + ' : ' +   format$("Kb:5X", GCSOCSRC ) + '    ' +
&                        mess(18,GML_MSGCIG,1) + ' : ' +  format$("Kb:5X", GCSOCDES ) + '    ' + mess(152,GML_MSGCIG,1) 
             GERR=1 
             mkstat=4
             zonsui = "[M:CIR2]DPRPLN(0)"
             CTRLOK = G_NON
       Endif 
         
       If  CTRLOK = G_NON 
            ##------------------------------------------------------------------------------------------------##
            ## Si erreur --> On se met en modification sur la soc source et soc cible                         ##  
            ##               On met en gras la soc source et cible                                            ## 
            ##               On affiche l'onglet 1,2,3,4 pour le couple de société                            ##   
            ##------------------------------------------------------------------------------------------------##
       
            For WL = 0 To [M:CIG0]NBCPY-1
               If [M:CIG0]CPYSRC (WL ) = GCSOCSRC 
                  Call SOC_SRC_COURANTE(WL)
               Endif 
               If [M:CIG0]CPYDES (WL ) = GCSOCDES 
                  Call SOC_DES_COURANTE(WL)
               Endif 
            Next      
        
            ##------------------------------------------------------------------------------------------------##
            ## - Chargement des informations de l'ONGLET 1,2,3                                                ##    
            ##------------------------------------------------------------------------------------------------##
            Gosub CHARGE_ONGLET_123
               
            Enable  GSTAENR

            Break     
        Endif   
    Next
Endif 

Return  
####################################################################################################
## $APRES_MOD                                                                                     ##
####################################################################################################
$APRES_MOD
Local Char WCSOCSUPSRC
Local Char WCSOCSUPDES
Local Integer WN

If GISUPLIG = G_NON
    Gosub ECRIT_TABLE_CIR
    Gosub TEST_SEL_SOC 
Else 
   #Si une ligne du tableau des sociétés a été suppprimé --> suppression des enregistrements de CIGREX correspondant 
    If GCSRCAV <> ""
        WCSOCSUPSRC =  GCSRCAV 
    Else 
        WCSOCSUPSRC =  [M:CIG0]CPYSRC(0) 
    Endif 
 
    If GCDESAV <> ""
        WCSOCSUPDES =  GCDESAV 
    Else 
        WCSOCSUPDES =  [M:CIG0]CPYDES(0) 
    Endif 
    Delete [F:CIR] Where   [F:CIR]CIGCOD = [M:CIG0]CIGCOD and [F:CIR]CPYSRC = WCSOCSUPSRC and [F:CIR]CPYDES = WCSOCSUPDES 
    If [S]fstat <> 0
       Return
    Endif 
    Actzo [M:CIG0]

    Call CHANGE_SOC_SRC_COURANTE (0)
    Call CHANGE_SOC_DES_COURANTE (0)
 
    Affzo [M:CIG0]

    Gosub CHARGE_ONGLET_123

Endif 

Return
####################################################################################################
## $LIENS                                                                                         ##
####################################################################################################
$LIENS

Affzo [M:CIG0]

# Si le statut est supérieur à "En préparation", l'opération de Cession Intra-Groupe
# n'est plus modifiable
If [M:CIG0]CIGSTA = GVML_CIGSTAP 
    Actzo [M:CIG0]
    Affzo [M:CIG0]
    Actzo [M:CIR1]
    Affzo [M:CIR1]
    Actzo [M:CIR2]
    Affzo [M:CIR2]
    Actzo [M:CIR3]
    Affzo [M:CIR3]
    Actzo [M:CIR4] #FQ-68840
    Affzo [M:CIR4] #FQ-68840
Else 
    Diszo [M:CIG0]
    Diszo [M:CIR1]  #FQ-68840
    Diszo [M:CIR2]
    Diszo [M:CIR3]
    Diszo [M:CIR4] #FQ-68840
Endif

Call CHANGE_SOC_SRC_COURANTE (0)
Call CHANGE_SOC_DES_COURANTE (0)


##------------------------------------------------------------------------------------------------##
## - Chargement des informations de l'entête d'écran                                              ##    
##------------------------------------------------------------------------------------------------##
Gosub CHARGE_ENTETE

GCSOCSRC = [M:CIG0]CPYSRC (0)
GCSOCDES = [M:CIG0]CPYDES (0)

##------------------------------------------------------------------------------------------------##
## - Chargement des informations de l'ONGLET 1,2,3                                                ##    
##------------------------------------------------------------------------------------------------##

Gosub CHARGE_ONGLET_123

##------------------------------------------------------------------------------------------------##
## - Chargement, dans le 4ème onglet, des recodifcations liées a cette CIG                        ##    
##------------------------------------------------------------------------------------------------##
Gosub CHARGE_ONGLET_4_RECOD

GISUPLIG = G_NON
GIADDLIG = G_NON

If [M:CIG0]CIGSTA = GVML_CIGSTAP #FQ-68840
  Affzo [M:CIG0]
  Affzo [M:CIR1]
  Affzo [M:CIR2] 
  Affzo [M:CIR3]
  Affzo [M:CIR4] #FQ-68840
Endif

Affzo [M:CIG0]CPYDES (0)
Affzo [M:CIG0]CPYSRC (0)

GCIGCOD =  [M:CIG0]CIGCOD

Return 

####################################################################################################
## $STYLE                                                                                         ##
####################################################################################################
$STYLE
Return 
####################################################################################################
## $ECRIT_TABLE_CIR: Ecriture des postes du tableau dans la table CIR                             ##
####################################################################################################
$ECRIT_TABLE_CIR
Local Integer WI
##------------------------------------------------------------------------------------------------##
## - Lecture du tableau                                                                           ##    
##------------------------------------------------------------------------------------------------##
Delete [F:CIR] Where   [F:CIR]CIGCOD = [M:CIG0]CIGCOD and [F:CIR]CPYSRC = GCSOCSRC and [F:CIR]CPYDES = GCSOCDES 
If [S]fstat <> 0
   Return
Endif 

Affzo [M:CIG0]
Affzo [M:CIR1]
Affzo [M:CIR2]
Affzo [M:CIR3]

[F:CIR]CIGCOD = [M:CIG0]CIGCOD
[F:CIR]CPYSRC = GCSOCSRC 
[F:CIR]CPYDES = GCSOCDES 


##--------------- Chargement en table des valeurs du 1er onglet ----------------------------------##
For WI = 0 To 9
        [F:CIR]REFSELCIG(WI)  = [M:CIR1]REFSELCIG(WI) 
        [F:CIR]GACACNWIP(WI)  = [M:CIR1]GACACNWIP(WI) 
        [F:CIR]GACACNREA(WI)  = [M:CIR1]GACACNREA(WI) 
        [F:CIR]OWNTYPLEA(WI)  = [M:CIR1]OWNTYPLEA(WI) 
        [F:CIR]PURDATEFF(WI)  = [M:CIR1]PURDATEFF(WI) 
        [F:CIR]OUTDATEFF(WI)  = [M:CIR1]OUTDATEFF(WI) 
        [F:CIR]SALPRIMOD(WI)  = [M:CIR1]SALPRIMOD(WI) 
        [F:CIR]SALPRIPLN(WI)  = [M:CIR1]SALPRIPLN(WI) 

        [F:CIR]SALPRI(WI)     = [M:CIR1]SALPRI(WI) 
        [F:CIR]SALPRIDEF(WI)  = [M:CIR1]SALPRIDEF(WI) 
        [F:CIR]CUR(WI)        = [M:CIR1]CUR(WI) 
        [F:CIR]NBRSEL         = [M:CIR1]NBRSEL 
Next 
##--------------- Chargement en table des valeurs du 2ème onglet ---------------------------------##
For WJ = 0 To 14

        [F:CIR]DPRPLN(WJ)     = [M:CIR2]DPRPLN(WJ) 
        [F:CIR]RULPRO(WJ)     = [M:CIR2]RULPRO(WJ) 
        [F:CIR]PLNTPL(WJ)     = [M:CIR2]PLNTPL(WJ) 
        [F:CIR]DPRDPM(WJ)     = [M:CIR2]DPRDPM(WJ) 
        [F:CIR]DPRDUR(WJ)     = [M:CIR2]DPRDUR(WJ) 
        [F:CIR]DPRDURDEF(WJ)  = [M:CIR2]DPRDURDEF(WJ) 
        [F:CIR]NBRPLN         = [M:CIR2]NBRPLN 
Next 
##--------------- Chargement en table des valeurs du 3ème onglet ---------------------------------##
[F:CIR]TAXBASTPF  = [M:CIR3]TAXBASTPF
[F:CIR]VATTRFFLG  = [M:CIR3]VATTRFFLG  
If [M:CIR3]VATTRFFLG <> G_OUI             # FQ-53890
   [F:CIR]ISSVATRAT  = [M:CIR3]ISSVATRAT  # FQ-46680
Endif
[F:CIR]RULTPFDAT  = [M:CIR3]RULTPFDAT  
[F:CIR]PURITSDAT  = [M:CIR3]PURITSDAT
[F:CIR]PURNAT     = [M:CIR3]PURNAT
[F:CIR]BASGAL     = [M:CIR3]BASGAL
[F:CIR]GALPRO     = [M:CIR3]GALPRO
[F:CIR]GALPLNSRC  = [M:CIR3]GALPLNSRC
[F:CIR]GALPLNDES  = [M:CIR3]GALPLNDES
[F:CIR]GALDAT     = [M:CIR3]GALDAT
[F:CIR]GALDPM     = [M:CIR3]GALDPM
[F:CIR]GALDUR     = [M:CIR3]GALDUR
Write [F:CIR]
If [S]fstat <> 0
   Return
Endif 

Return
####################################################################################################
## $AP_ANNULE                                                                                     ##
####################################################################################################
$AP_ANNULE

Delete [F:CIB]  Where   [F:CIB]CIGCOD    = [M:CIG0]CIGCOD
Delete [F:CIR]  Where   [F:CIR]CIGCOD    = [M:CIG0]CIGCOD
Delete [F:CIG2] Where   [F:CIG2]CIGCOD   = [M:CIG0]CIGCOD

Return
####################################################################################################
## $KILL_GLOBAL : KIll de toutes les globales                                                     ##                   
####################################################################################################
KILL_GLOBAL

If dim(GCSOCSRC)         >0      : Kill GCSOCSRC   : Endif     
If dim(GCSOCDES)         >0      : Kill GCSOCDES   : Endif
If dim(GCSRCAV)          >0      : Kill GCSRCAV    : Endif
If dim(GCSRCAP)          >0      : Kill GCSRCAP    : Endif
If dim(GCDESAV)          >0      : Kill GCDESAV    : Endif
If dim(GCDESAP)          >0      : Kill GCDESAP    : Endif
If dim(GISUPLIG)         >0      : Kill GISUPLIG   : Endif
If dim(GIADDLIG)         >0      : Kill GIADDLIG   : Endif
If dim(GREFSEL)          >0      : Kill GREFSEL    : Endif
If dim(GSELCIG)          >0      : Kill GSELCIG    : Endif

Return 
####################################################################################################
## $VERIF_CRE                                                                                     ##
####################################################################################################
$VERIF_CRE

Gosub VERIF

Return
####################################################################################################
## $VERIF_MOD                                                                                     ##
####################################################################################################
$VERIF_MOD

Gosub VERIF

Return
####################################################################################################
## $VERIF : Verification des cohérences de l'écran                                                ##
####################################################################################################
$VERIF

   WICTRLOK = G_NON
   If GISUPLIG = G_NON
       Gosub CONTROLE_SAISIE1
       Gosub CONTROLE_SAISIE2
       If WICTRLOK = G_NON
           OK = 0 
           FIN = 1
           GOK = 0
       Endif 
   Endif 

Return
####################################################################################################
## $CONTROLE-SAISIE1: Controle de cohérence de la saisie de l'entete                              ##
####################################################################################################
$CONTROLE_SAISIE1 

Local Integer WICODERET
Local Integer LOK
Local Integer WINBSOC
Local Integer WI
Local Integer WJ
Local Integer WICONTEXTE
Local Integer WINUMPLAN
Local Date    WDDATE(1..5)
Local Char    WCCPY 
Local Char    WCDEV1     
Local Char    WCDEV2     

Local Integer WIUNPLANOK
Local Integer WITTPLANOK
Local Integer LOK
Local Integer WINUMPLAN

WINBSOC = 0
#--------------------------------------------------------------------------------------------------#
# Controle de l'entete de l'ecran                                                                  #
#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#
# Controle tableau des sociétés                                                                    #
#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#
# Si type CIG est « 3 -Scission » ou « 4 - Vente intra-groupe » :                                  #
# Une et une seule société source doit être indiquée                                               #
#--------------------------------------------------------------------------------------------------#
WINBSOC = 0 
If [M:CIG0]CIGTYP = GVML_TOSCISS  or [M:CIG0]CIGTYP = GVML_TOVTEIG 
    For WI = 0 To [M:CIG0]NBCPY-1
        
        If WI = 0
            WCCPY = [M:CIG0]CPYSRC(WI)

            # Devise du plan comptable de la société source   
            If WICONTEXTE > 0 
                # Récupération de la devise comptable 
                Read [F:CNX]CNX0=[M:CIG0]CPYSRC(WI);WICONTEXTE
                If fstat = 0 
                     WCDEV1 = [F:CNX]CUR    
                Else
                     WCDEV1 = GEURO    
                Endif
             Endif         
        Endif   

        # Devise du plan comptable de la société cible suivante   
        If WICONTEXTE > 0 
            # Récupération de la devise comptable 
            Read [F:CNX]CNX0=[M:CIG0]CPYDES(WI);WICONTEXTE
            If fstat = 0 
                 WCDEV2 = [F:CNX]CUR    
            Else
                 WCDEV2 = GEURO    
            Endif
         Endif 
        
        # Message d'erreur si devise différence    
        If WCDEV1 <> WCDEV2 
            GMESSAGE = mess(143,GML_MSGCIG,1) - [M:CIG0]CPYDES(WI) - mess(144,GML_MSGCIG,1) - [M:CIG0]CPYSRC(WI)     : GERR=1 
            mkstat=2
            Return 
        Endif 
   
        # Message d'erreur si la soc existe à la fois dans les socs sources et les socs cibles    
        If WCCPY <> "" and   WCCPY = [M:CIG0]CPYDES(WI)
            GMESSAGE = mess(139,GML_MSGCIG,1) + WCCPY    : GERR=1 
            mkstat=2
            Return 
        Endif 

        If [M:CIG0]CPYSRC(WI) <>  ""
               WINBSOC += 1  
        Endif         
    Next

    # Message d'erreur s'il n'y a pas de société cible      
    If [M:CIG0]CPYDES(0) = ""
        GMESSAGE = mess(148,GML_MSGCIG,1)     : GERR=1 
        mkstat=2
        Return 
    Endif 

    # Une scission doit avoir au moins 2 sociétés cibles     
    If [M:CIG0]CIGTYP = GVML_TOSCISS  and [M:CIG0]CPYDES(1) = ""
        GMESSAGE = mess(149,GML_MSGCIG,1)     : GERR=1 
        mkstat=2
        Return 
    Endif 

    # Message d'erreur s'il plusieurs socs source alors que type CIG : 3 Scission ou 4 Vente intra-groupe   
    If WINBSOC <> 1  
        GMESSAGE = mess(140,GML_MSGCIG,1) + ' ' + mess([M:CIG0]CIGTYP,372,1)   : GERR=1 
        mkstat=2
        Return 
    Endif 
Endif
#--------------------------------------------------------------------------------------------------#
# Si type CIG est « 1 -Apport partiel d'actif » ou « 2 - Fusion  »  ou « 4 - Vente intra-groupe »  #
# Une et une seule société cible doit être indiquée                                                #
#--------------------------------------------------------------------------------------------------#
WINBSOC = 0 
If [M:CIG0]CIGTYP = GVML_TOAPPOR   or [M:CIG0]CIGTYP = GVML_TOFUSIO or [M:CIG0]CIGTYP = GVML_TOVTEIG       
    For WI = 0 To [M:CIG0]NBCPY-1
        
        If WI = 0
             WCCPY = [M:CIG0]CPYDES(WI)
       
            # Devise du plan comptable de la société cible    
            If WICONTEXTE > 0 
                # Récupération de la devise comptable 
                Read [F:CNX]CNX0=[M:CIG0]CPYDES(WI);WICONTEXTE
                If fstat = 0 
                     WCDEV1 = [F:CNX]CUR    
                Else
                     WCDEV1 = GEURO    
                Endif
             Endif 

       Endif 
       
       # Devise du plan comptable de la société source suivante   
       If WICONTEXTE > 0 
            # Récupération de la devise comptable 
            Read [F:CNX]CNX0=[M:CIG0]CPYSRC(WI);WICONTEXTE
            If fstat = 0 
                 WCDEV2 = [F:CNX]CUR    
            Else
                 WCDEV2 = GEURO    
            Endif
         Endif 
        
       # Message d'erreur si devise différence    
       If WCDEV1 <> WCDEV2 
            GMESSAGE = mess(143,GML_MSGCIG,1) - [M:CIG0]CPYSRC(WI) - mess(144,GML_MSGCIG,1) - [M:CIG0]CPYDES(WI)     : GERR=1 
            mkstat=2
            Return 
        Endif 

      # Message d'erreur si la soc existe à la fois dans les socs sources et les socs cibles    
      If WCCPY <> "" and WCCPY = [M:CIG0]CPYSRC(WI)
            GMESSAGE = mess(139,GML_MSGCIG,1) + WCCPY    : GERR=1 
            mkstat=2
            Return 
      Endif 

      If [M:CIG0]CPYDES(WI) <>  ""
               WINBSOC += 1  
      Endif 
        
    Next
    
    # Message d'erreur s'il n'y a pas de société source     
    If [M:CIG0]CPYSRC(0) = ""
        GMESSAGE = mess(145,GML_MSGCIG,1)     : GERR=1 
        mkstat=2
        Return 
    Endif 
    
    # Message d'err si plusieurs socs cible alors que type CIG: 1-Apport partiel ou 2-Fusion ou 4-Vente intra-groupe  
    If WINBSOC <> 1  
        GMESSAGE = mess(142,GML_MSGCIG,1) + ' ' + mess([M:CIG0]CIGTYP,372,1)   : GERR=1 
        mkstat=2
        Return 
    Endif 
Endif
#--------------------------------------------------------------------------------------------------#
# Verification qu'il n'y a pas 2 fois la même société dans les sociétés sources                    #
#--------------------------------------------------------------------------------------------------#
For WI = 0 To [M:CIG0]NBCPY-1
    
    If [M:CIG0]CPYSRC(WI) <> "" 
        WCCPY = [M:CIG0]CPYSRC(WI)
        WINBSOC = 0  
        For WJ = 0 To [M:CIG0]NBCPY-1
            If WCCPY = [M:CIG0]CPYSRC(WJ)
                   WINBSOC += 1  
            Endif 
        Next 
        If WINBSOC > 1  
             GMESSAGE = mess(141,GML_MSGCIG,1) + WCCPY    : GERR=1 
             mkstat=2
             Return 
        Endif 
    Endif 
Next
#--------------------------------------------------------------------------------------------------#
# Verification qu'il n'y a pas 2 fois la même société dans les sociétés cibles                     #
#--------------------------------------------------------------------------------------------------#
For WI = 0 To [M:CIG0]NBCPY-1
    
    If [M:CIG0]CPYDES(WI) <> "" 
        WCCPY = [M:CIG0]CPYDES(WI)
        WINBSOC = 0  
        For WJ = 0 To [M:CIG0]NBCPY-1
            If WCCPY = [M:CIG0]CPYDES(WJ)
                WINBSOC += 1 
            Endif 
        Next    
        If WINBSOC > 1  
             GMESSAGE = mess(141,GML_MSGCIG,1) + WCCPY    : GERR=1 
             mkstat=2
             Return 
        Endif
    Endif  
Next

#Call GET_CNX_FROM_PLN (G301CPT , WICONTEXTE) From GLOBIENS

Return 

####################################################################################################
## $CONTROLE-SAISIE2: Controle de cohérence de la saisie des onglets                              ##
####################################################################################################
$CONTROLE_SAISIE2 
Local Integer WICONTEXTE
Local Integer WICODERET
Local Date    WDDATE(1..5)

#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#
# Controle Onglet selection                                                                        #
#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#

# Message d'erreur s'il n'y a pas de selection      
If [M:CIR1]REFSELCIG (0) = ""
    GMESSAGE = mess(146,GML_MSGCIG,1)     : GERR=1 
    mkstat=2
    Return 
Endif 

# Message d'erreur s'il n'y a pas de référence recodification      
If [M:CIR4]REFCDF (0) = ""
    GMESSAGE = mess(87,GML_MSGCIG,1)     : GERR=1 
Endif 

#--------------------------------------------------------------------------------------------------#
# Controle que Immos en cours ou immo en service est à 'Oui'                                       #
#--------------------------------------------------------------------------------------------------#
For WI = 0 To [M:CIR1]NBRSEL - 1
    If [M:CIR1]GACACNWIP(WI) = G_NON  and [M:CIR1]GACACNREA(WI) = G_NON
        GMESSAGE = mess(131,GML_MSGCIG,1) + ' ' + mess(132,GML_MSGCIG,1) + ' : ' + [M:CIR1]REFSELCIG(WI)   : GERR=1 
        mkstat=2
        Return 
    Endif 
Next 


#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#
# Controle Onglet Plans                                                                         #
#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#

# 
# Message d'erreur s'il n'y a pas de plan  :#
# Vous devez renseigner le mode d'alimentation de chacun des plans de la société cible     
If [M:CIR2]DPRPLN (0) = 0
    GMESSAGE = mess(195,GML_MSGCIG,1)     : GERR=1 
    mkstat=2
    Return 
Endif 


#--------------------------------------------------------------------------------------------------#
# Controle que tous les plans gérés sont alimentés par le paramétrage                              #
#--------------------------------------------------------------------------------------------------#


WITTPLANOK = G_OUI
Filter [APL] Where [F:APL]LANCHP = GML_NPLAN and [F:APL]LAN = GLANGUE 
For [APL]
  #--------------------------------------------------------------------------------------------------#
  # Société Cible                                                                                    #
  #--------------------------------------------------------------------------------------------------#
  If func GLOBIENS.CPY_PLN_GERE(GCSOCDES ,[F:APL]LANNUM) = G_OUI
    #--------------------------------------------------------------------------------------------------#
    # si plan géré :  Test si le plan est paramétré dans les plans cibles                              #
    #--------------------------------------------------------------------------------------------------#
    WIUNPLANOK= G_NON
    For WI = 0 To [M:CIR2]NBRPLN-1
        If [F:APL]LANNUM = [M:CIR2]DPRPLN(WI) 
               WIUNPLANOK= G_OUI
        Endif  
    Next

    #--------------------------------------------------------------------------------------------------#
    # si plan géré en tant que plan cible                                                              #
    #    - Test si date d'effet est, pour soc cible,  dans l'exercice du contexte du plan              #
    #--------------------------------------------------------------------------------------------------#
    Call GET_CNX_FROM_PLAN (GCSOCDES, [F:APL]LANNUM, WICONTEXTE) From GLOBIENS
    ##---------------------------------------------------------------------------------------------##
    ## Récup date deb et fin d'exe pour contexte correspondant au  plan parametré pour chaque sél  ##
    ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ## 
    ##---------------------------------------------------------------------------------------------##
    Call GET_CNX_DAT(GCSOCDES ,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS 
    If [M:CIG0]EFFDAT < WDDATE(1) or [M:CIG0]EFFDAT > WDDATE(2)  : # Debut et Fin exercice 
            GMESSAGE = mess(187,GML_MSGCIG,1) + ' ' + mess([F:APL]LANNUM,301,1)-    mess(188,GML_MSGCIG,1) + ' ' + GCSOCDES + '   (' + format$("DD2",WDDATE(1)) + ' - ' + format$("DD2",WDDATE(2)) + ')' : GERR=1 
            mkstat=2
            Break  
    Endif 

    #--------------------------------------------------------------------------------------------------#
    # si plan géré en tant que plan source                                                             #
    #    - Test si date d'effet est, pour soc source,  dans l'exercice du contexte géré                #
    #    - Test si date d'effet est, pour soc source,  dans l'exercice du contexte du plan modele      #
    #--------------------------------------------------------------------------------------------------#
  For WI = 0 To [M:CIR2]NBRPLN-1
        If [F:APL]LANNUM = [M:CIR2]DPRPLN(WI)  and [M:CIR2]PLNTPL(WI) = 0  
             Call GET_CNX_FROM_PLAN (GCSOCSRC, [F:APL]LANNUM, WICONTEXTE) From GLOBIENS
            ##---------------------------------------------------------------------------------------------##
            ## Récup date deb et fin d'exe pour contexte correspondant au  plan parametré pour chaque sél  ##
            ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ## 
            ##---------------------------------------------------------------------------------------------##
            Call GET_CNX_DAT(GCSOCSRC ,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS 
            If [M:CIG0]EFFDAT < WDDATE(1) or [M:CIG0]EFFDAT > WDDATE(2)  : # Debut et Fin exercice 
                    GMESSAGE = mess(187,GML_MSGCIG,1) + ' ' + mess([F:APL]LANNUM,301,1)-    mess(188,GML_MSGCIG,1) + ' ' + GCSOCSRC  : GERR=1 
                    mkstat=2
                    Break  
            Endif 

       Endif 
      
       If [F:APL]LANNUM = [M:CIR2]PLNTPL(WI) 
             Call GET_CNX_FROM_PLAN (GCSOCSRC,[F:APL]LANNUM, WICONTEXTE) From GLOBIENS
            ##---------------------------------------------------------------------------------------------##
            ## Récup date deb et fin d'exe pour contexte correspondant au  plan parametré pour chaque sél  ##
            ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ## 
            ##---------------------------------------------------------------------------------------------##
            Call GET_CNX_DAT(GCSOCSRC ,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS 
            If [M:CIG0]EFFDAT < WDDATE(1) or [M:CIG0]EFFDAT > WDDATE(2)  : # Debut et Fin exercice 
                    GMESSAGE = mess(187,GML_MSGCIG,1) + ' ' + mess([F:APL]LANNUM,301,1)-    mess(188,GML_MSGCIG,1) + ' ' + GCSOCSRC : GERR=1 
                    mkstat=2
                    Break  
            Endif 

       Endif 

    Next

    #--------------------------------------------------------------------------------------------------#
    # si plan géré : Test si le plan est paramétré dans les plans de +/- value                        #
    #--------------------------------------------------------------------------------------------------#
   If  [F:APL]LANNUM = [M:CIR3]GALPLNDES
            WIUNPLANOK= G_OUI
    Endif  
 
   If WIUNPLANOK= G_NON
       WINUMPLAN =  [F:APL]LANNUM
       WITTPLANOK = G_NON
   Endif 
Endif 
Next 
Filter [APL] 



If WITTPLANOK = G_NON
  GMESSAGE =mess(17,GML_MSGCIG,1)+' : '+format$("Kb:5X",GCSOCSRC)+'    '+ mess(18,GML_MSGCIG,1)+ ' : ' +format$("Kb:5X",GCSOCDES )
&          + '\' + mess(108,GML_MSGCIG,1)+ '\'+ mess(183,GML_MSGCIG,1) + ' ' + mess(WINUMPLAN,301,1)   
  GERR=1 
  mkstat=2
  Return 
Endif
#--------------------------------------------------------------------------------------------------#
# Controle Onglet Autres regles                                                                    #
#--------------------------------------------------------------------------------------------------#
#--------------------------------------------------------------------------------------------------#
# Si +/Value est géré : contrôles des rubriques liées                                              #
#--------------------------------------------------------------------------------------------------#

If [M:CIR3]GALPRO  = G_OUI 

     If [M:CIR3]GALPLNSRC = 0
        GMESSAGE = mess(125,GML_MSGCIG,1)   : GERR=1 
        mkstat=2
        Return 
     Endif  

     If [M:CIR3]GALPLNDES= 0
        GMESSAGE = mess(126,GML_MSGCIG,1)   : GERR=1 
        mkstat=2
        Return  
     Endif  

     If [M:CIR3]GALDAT= [0/0/0]
        GMESSAGE = mess(127,GML_MSGCIG,1)  : GERR=1 
        mkstat=2
        Return  
     Endif  

     If [M:CIR3]GALDPM = ""
        GMESSAGE = mess(128,GML_MSGCIG,1)   : GERR=1 
        mkstat=2
        Return  
     Endif  

     If [M:CIR3]GALDUR < 1 
        GMESSAGE = mess(129,GML_MSGCIG,1)   : GERR=1 
        mkstat=2
        Return  
     Endif  

Endif 

WICTRLOK = G_OUI

Return 
#--------------------------------------------------------------------------------------------------#
# Controle Onglet recodification                                                                   #
#--------------------------------------------------------------------------------------------------#

# Message d'erreur s'il n'y a pas de recodification    
#If [M:CIR1]REFCDF(0) = ""
If [M:CIR1]REFSELCIG(0) = ""
    GMESSAGE = mess(87,GML_MSGCIG,1)     : GERR=1 
    mkstat=2
    Return 
Endif 
####################################################################################################
## $CHARGE_ENTETE: Alimentation des infos statut CIG , Type CIG , ..                                  ##
####################################################################################################
$CHARGE_ENTETE

nolign=1
Read [F:CIG2]= [M:CIG0]CIGCOD
If [S]fstat = 0 
      [M:CIG0] = [F:CIG2]
      For I= 0 To [F:CIG2]NBCPY-1
        If [F:CIG2]CPYSRC(I) <> "" or [F:CIG2]CPYDES(I)<> ""
          [M:CIG0]CPYSRC(nolign-1) = [F:CIG2]CPYSRC(I)
          [M:CIG0]CPYDES(nolign-1) = [F:CIG2]CPYDES(I)
          nolign += 1 
        Else
          Break
        Endif
      Next I
      [M:CIG0]NBCPY = nolign-1 
Endif

Affzo [M:CIG0]

Return

####################################################################################################
## $CHARGE_ONGLET_123: Alimentation des onglets 1,2,3                                             ##
####################################################################################################
$CHARGE_ONGLET_123

Local Integer WI
Local Integer WJ
Local Char    WCLIB

Gosub  REINIT_ONGLET

##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau                                                                       ##    
##------------------------------------------------------------------------------------------------##
## La 1ère alimentée est la ligne avec l'indice = 0                                               ##    
## La variable de bas de tableau doit avoir le nombre de ligne (indice +1)                        ##    
##------------------------------------------------------------------------------------------------##
 
Read [F:CIR]CIR0=[M:CIG0]CIGCOD ;GCSOCSRC ; GCSOCDES 
If [S]fstat = 0
    
    ##--------------- Alimentation du 1er onglet -------------------------------------------------##
    For WI=0 To  [F:CIR]NBRSEL-1
      
        [M:CIR1]REFSELCIG(WI)  = [F:CIR]REFSELCIG(WI) 
        # Récupération de la désignation de la sélection
        Read [F:CIS] = [M:CIR1]REFSELCIG(WI)
        If fstat = 0
          [M:CIR1]CIGREXSEL(WI)= [F:CIS]SELCIGDES
        Endif 
        [M:CIR1]GACACNWIP(WI)  = [F:CIR]GACACNWIP(WI) 
        [M:CIR1]GACACNREA(WI)  = [F:CIR]GACACNREA(WI) 
        [M:CIR1]OWNTYPLEA(WI)  = [F:CIR]OWNTYPLEA(WI) 
        [M:CIR1]PURDATEFF(WI)  = [F:CIR]PURDATEFF(WI) 
        [M:CIR1]OUTDATEFF(WI)  = [F:CIR]OUTDATEFF(WI) 
        [M:CIR1]SALPRIMOD(WI)  = [F:CIR]SALPRIMOD(WI) 
        [M:CIR1]SALPRIPLN(WI)  = [F:CIR]SALPRIPLN(WI) 
        [M:CIR1]SALPRI(WI)     = [F:CIR]SALPRI(WI) 
        [M:CIR1]SALPRIDEF(WI)  = [F:CIR]SALPRIDEF(WI) 
        [M:CIR1]CUR(WI)        = [F:CIR]CUR(WI) 
    Next 

    ##--------------- Alimentation du 2ème onglet ------------------------------------------------##
    For WJ=0 To  [F:CIR]NBRPLN-1

        [M:CIR2]DPRPLN(WJ)     = [F:CIR]DPRPLN(WJ) 
        [M:CIR2]RULPRO(WJ)     = [F:CIR]RULPRO(WJ) 
        [M:CIR2]PLNTPL(WJ)     = [F:CIR]PLNTPL(WJ) 
        [M:CIR2]DPRDPM(WJ)     = [F:CIR]DPRDPM(WJ) 
        [M:CIR2]DPRDUR(WJ)     = [F:CIR]DPRDUR(WJ) 
        [M:CIR2]DPRDURDEF(WJ)  = [F:CIR]DPRDURDEF(WJ) 
     

    Next 

    ##--------------- Alimentation du 3ème onglet ------------------------------------------------##

    [M:CIR3]TAXBASTPF  = [F:CIR]TAXBASTPF
    [M:CIR3]VATTRFFLG  = [F:CIR]VATTRFFLG    
    [M:CIR3]ISSVATRAT  = [F:CIR]ISSVATRAT   
    [M:CIR3]RULTPFDAT  = [F:CIR]RULTPFDAT    
    [M:CIR3]PURITSDAT  = [F:CIR]PURITSDAT
    [M:CIR3]PURNAT     = [F:CIR]PURNAT
    [M:CIR3]BASGAL     = [F:CIR]BASGAL
    [M:CIR3]GALPRO     = [F:CIR]GALPRO
    [M:CIR3]GALPLNSRC  = [F:CIR]GALPLNSRC
    [M:CIR3]GALPLNDES  = [F:CIR]GALPLNDES
    [M:CIR3]GALDAT     = [F:CIR]GALDAT
    [M:CIR3]GALDPM     = [F:CIR]GALDPM
    [M:CIR3]GALDUR     = [F:CIR]GALDUR
    If [M:CIR3]VATTRFFLG = G_OUI    # FQ-53890
       Diszo  [M:CIR3]ISSVATRAT
    Endif

Endif 


##------------------------------------------------------------------------------------------------##
## Dimensionnement des tableaux : Alimentation variable de bas de tableau                         ##    
##------------------------------------------------------------------------------------------------##
If WI <> 0
    [M:CIR1]NBRSEL = WI 
Endif 

If WJ <> 0
    [M:CIR2]NBRPLN = WJ 
Endif 

If [M:CIR3]GALPRO   = G_NON
    Grizo [M:CIR3]GALPLNSRC
    Grizo [M:CIR3]GALPLNDES
    Grizo [M:CIR3]GALDAT
    Grizo [M:CIR3]GALDPM
    Grizo [M:CIR3]GALDUR
Else
    Actzo [M:CIR3]GALPLNSRC
    Actzo [M:CIR3]GALPLNDES
    Actzo [M:CIR3]GALDAT
    Actzo [M:CIR3]GALDPM
    Actzo [M:CIR3]GALDUR
Endif 

Affzo [CIR1]
Affzo [CIR2]
Affzo [CIR3]

Return 
####################################################################################################
## $CHARGE_ONGLET_4_RECOD: Alimentation du tableau des recodifcations à partir de la table CDF    ##
####################################################################################################
$CHARGE_ONGLET_4_RECOD
Local Integer I
Local Integer WI
Local Char    WCLIB

   Effzo [M:CIR4] REFCDF     
   Effzo [M:CIR4] REFDES     
   Effzo [M:CIR4] TABNAM     
   
   WI= 0 
##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau                                                                       ##    
##------------------------------------------------------------------------------------------------##
## La 1ère alimentée est la ligne avec l'indice = 0                                               ##    
## La variable de bas de tableau doit avoir le nombre de ligne (indice +1)                        ##    
##------------------------------------------------------------------------------------------------##
   Filter[F:CDF] 
   For [F:CDF] Where [F:CDF]REFTRFCMP=[M:CIG0]CIGCOD
     
       [M:CIR4]REFCDF(WI)  = [F:CDF]REFCDF
       [M:CIR4]REFDES(WI)  = [F:CDF]REFDES
       [M:CIR4]TABNAM(WI)  = [F:CDF]TABNAM
       Gosub AFFICHE_NOMTABDES
       WI +=1
   Next 
   Filter[F:CDF] 
   
   [M:CIR4]NBRCDF = WI 
   
   Affzo [M:CIR4]NBRCDF 
   Actzo [M:CIR4] REFCDF(0)     

##------------------------------------------------------------------------------------------------##
## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##    
##------------------------------------------------------------------------------------------------##
If WI <> 0
    [M:CIR4]NBRCDF = WI 
Endif 

Affzo [CIR4]
Return

####################################################################################################
## $AFFICHE_NOMTABDES : Affichage du libelle de la table                                           ##
####################################################################################################
$AFFICHE_NOMTABDES
Local Char    WCTABNAMDES
Local Integer WINUMTEXTE 

If [F:CDF]TABNAM = 'LOC' 
      WINUMTEXTE = 0 
      Read [F:ATB]ABRFIC = [F:CDF]TABNAM
      If [S]fstat = 0
        WINUMTEXTE = [F:ATB]INTITFIC
        Read [F:ATX2]= GLANGUE;WINUMTEXTE  
        If [S]fstat = 0
           [M:CIR4]TABNAMDES(WI)  = [F:ATX2]TEXTE
        Endif 
      Endif
Elsif  [F:CDF]TABNAM = 'FCY'  
      WINUMTEXTE = 0 
      Read [F:ATB]ABRFIC = [F:CDF]TABNAM
      If [S]fstat = 0
        WINUMTEXTE = [F:ATB]INTITFIC
        Read [F:ATX2]= GLANGUE;WINUMTEXTE  
        If [S]fstat = 0
           [M:CIR4]TABNAMDES(WI)  = [F:ATX2]TEXTE + ' ' + mess(61,GML_MSGREC,1) 
        Endif 
      Endif
Elsif left$ ([F:CDF]TABNAM,3) = 'CCE' 
      Read [F:APL] = GML_AXEANAL; val(mid$([F:CDF]TABNAM,4,1));GLANGUE 
      If [S]fstat = 0
           [M:CIR4]TABNAMDES(WI) = mess(46,GML_MSGREC,1) + [F:APL]LANMES + ')'
      Endif
Elsif [F:CDF]TABNAM <> ''
      Call LECTEXTRA(WCTABNAMDES,"ATABTAB","LNGDES",num$([F:CDF]TABNAM), "" ) From ATEXTRA 
      [M:CIR4]TABNAMDES(WI) = WCTABNAMDES
Endif 

Return


