######################################################################################
## Rubrique DPRDUR : durée d'amortissement                                          ##
######################################################################################
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_DPRDUR(VALEUR)
Variable Integer VALEUR


End

#------------------------------------------------------------------------------------#
# Après_zone                                                                         #
#------------------------------------------------------------------------------------#
Subprog AP_DPRDUR(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0  and [M:CIR2]RULPRO (nolign-1)  = GML_VAIDENTI
      GMESSAGE =  mess(119,GML_MSGCIG,1) + ' ' + mess(GML_VAIDENTI,336,1) 
      GOK=0
      OK=0
      mkstat=2
Endif

If VALEUR <> 0  and [M:CIR2]RULPRO (nolign-1)  = GML_VAIDEPLM
      GMESSAGE =  mess(119,GML_MSGCIG,1) + ' ' + mess(GML_VAIDEPLM,336,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 
 
If VALEUR = 0  and ([M:CIR2]RULPRO (nolign-1)  <> GML_VAIDEPLM and  [M:CIR2]RULPRO (nolign-1) <> GML_VAIDENTI) 
      GMESSAGE =  mess(120,GML_MSGCIG,1) + ' ' + mess(GML_VAIDEPLM,336,1) + ' ' + mess(121,GML_MSGCIG,1) + ' ' + mess(GML_VAIDENTI,336,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 
 
End



#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_DPRDUR(VALEUR)
Variable Integer VALEUR

# Si règle de gestion = Reprise à l'identique  ou Valeurs identiques au plan modèle
# --> pas de saisie du durée
If [M:CIR2]RULPRO (nolign-1)  = GML_VAIDEPLM  or [M:CIR2]RULPRO (nolign-1)  = GML_VAIDENTI
    Raz GMENLOC
    GMENLOC(GVML_CIGDRES)=1 
    GMENLOC(GVML_CIGDPRE)=1 
Endif 

End



######################################################################################
## Rubrique DPRDURDEF : durée d'amortissement par défaut                            ##
######################################################################################
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_DPRDURDEF(VALEUR)
Variable Decimal VALEUR


End


#------------------------------------------------------------------------------------#
# Après_zone                                                                         #
#------------------------------------------------------------------------------------#
Subprog AP_DPRDURDEF(VALEUR)
Variable Decimal VALEUR

# A saisir obligatoirement si durée = Durée résiduelle
If VALEUR < 1  and [M:CIR2]DPRDUR  (nolign-1)  = GVML_CIGDRES
      GMESSAGE =  mess(122,GML_MSGCIG,1) + ' ' + mess(GVML_CIGDRES,338,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 

# Interdire dans le cas contraire 
If VALEUR <> 0  and [M:CIR2]DPRDUR  (nolign-1)  = GVML_CIGDPRE
      GMESSAGE =  mess(123,GML_MSGCIG,1) + ' ' + mess(GVML_CIGDPRE,338,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 

# Interdire dans le cas contraire 
If VALEUR <> 0  and [M:CIR2]DPRDUR  (nolign-1)  = GVML_CIGDPRE
      GMESSAGE =  mess(123,GML_MSGCIG,1) + ' ' + mess(GVML_CIGDPRE,338,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 

# Interdire dans le cas contraire 
If VALEUR <> 0  and [M:CIR2]RULPRO (nolign-1)  = GML_VAIDEPLM
      GMESSAGE =  mess(124,GML_MSGCIG,1)  + ' ' + mess(GML_VAIDEPLM,336,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 

If VALEUR <> 0  and [M:CIR2]RULPRO (nolign-1)  = GML_VAIDENTI
      GMESSAGE =  mess(124,GML_MSGCIG,1)  + ' ' + mess(GML_VAIDENTI,336,1) 
      GOK=0
      OK=0
      mkstat=2
Endif 


End

######################################################################################
## Rubrique GALPRO: Traitement de la +/- value                                      ##
######################################################################################
#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_GALPRO(VALEUR)
Variable Integer VALEUR

Local Char WCMODE

If VALEUR = G_OUI 
    Actzo [M:CIR3]GALPLNSRC
    [M:CIR3]GALPLNDES = 0 : Actzo [M:CIR3]GALPLNDES
    Actzo [M:CIR3]GALDAT
    Actzo [M:CIR3]GALDPM
    Actzo [M:CIR3]GALDUR


    If [M:CIR3]GALPLNDES = 0 

        WIPLANLIBRE = G301LI1
        Gosub TEST_PLAN_LIBRE
        If WIPLANOK    = G_OUI 
            [M:CIR3]GALPLNDES = WIPLANLIBRE 
        Else 
            WIPLANLIBRE = G301LI2
            Gosub TEST_PLAN_LIBRE
            If WIPLANOK    = G_OUI 
                [M:CIR3]GALPLNDES = WIPLANLIBRE 
            Else 
                WIPLANLIBRE = G301LI3
                Gosub TEST_PLAN_LIBRE
                If WIPLANOK    = G_OUI 
                    [M:CIR3]GALPLNDES = WIPLANLIBRE 
                Else  
                    WIPLANLIBRE = G301LI4
                    Gosub TEST_PLAN_LIBRE
                    If WIPLANOK    = G_OUI 
                        [M:CIR3]GALPLNDES = WIPLANLIBRE 
                    Else  
                        WIPLANLIBRE = G301LI5
                        Gosub TEST_PLAN_LIBRE
                        If WIPLANOK    = G_OUI 
                            [M:CIR3]GALPLNDES = WIPLANLIBRE 
                        Else  
                            WIPLANLIBRE = G301LI6
                            Gosub TEST_PLAN_LIBRE
                            If WIPLANOK    = G_OUI 
                                [M:CIR3]GALPLNDES = WIPLANLIBRE 
                            Endif 
                        Endif 
                     Endif 
                 Endif 
              Endif 
         Endif 
     Endif          

    Affzo [M:CIR3]
 
    If [M:CIR3]GALPLNDES = 0 
      GMESSAGE = mess(196,GML_MSGCIG,1) : GERR=1 
      mkstat=2 
      [M:CIR3]GALPLNSRC = 0 
      [M:CIR3]GALPLNDES = 0 
      [M:CIR3]GALDAT    = [0/0/0]
      [M:CIR3]GALDPM    = ""
      [M:CIR3]GALDUR    = 0 
      Diszo [M:CIR3]GALPLNSRC
      Diszo [M:CIR3]GALPLNDES
      Diszo [M:CIR3]GALDAT
      Diszo [M:CIR3]GALDPM
      Diszo [M:CIR3]GALDUR
      Affzo [M:CIR3] 
      End
    Endif

    If [M:CIR3]GALDAT = [0/0/0] and  [M:CIR3]GALPLNDES <> 0 
        [M:CIR3]GALDAT = [M:CIG0]EFFDAT 
    Endif 
    
    If [M:CIR3]GALDPM = "" and  [M:CIR3]GALPLNDES <> 0 
 
        WCMODE = 'LP'
        Read [F:DPM]= WCMODE;GCSOCDES    
        If [S]fstat = 0 
              [M:CIR3]GALDPM= WCMODE  
        Else
              Read [F:DPM]= WCMODE;""   
              If  [S]fstat = 0 
                  [M:CIR3]GALDPM= WCMODE 
              Endif  
        Endif 
    Endif 

    If [M:CIR3]GALDUR    = 0  and  [M:CIR3]GALPLNDES <> 0 
         [M:CIR3]GALDUR    = 1 
    Endif 

Else 
    [M:CIR3]GALPLNSRC = 0 
    [M:CIR3]GALPLNDES = 0 
    [M:CIR3]GALDAT    = [0/0/0]
    [M:CIR3]GALDPM    = ""
    [M:CIR3]GALDUR    = 0 
    #[M:CIR3]GALPRO    = G_NON  
    Affzo [M:CIR3]GALPLNSRC     : Diszo [M:CIR3]GALPLNSRC
    Affzo [M:CIR3]GALPLNDES     : Diszo [M:CIR3]GALPLNDES
    Affzo [M:CIR3]GALDAT        : Diszo [M:CIR3]GALDAT
    Affzo [M:CIR3]GALDPM        : Diszo [M:CIR3]GALDPM
    Affzo [M:CIR3]GALDUR        : Diszo [M:CIR3]GALDUR
Endif 


Affzo [M:CIR3] 

End



#####################################################################################
