End



######################################################################################
## Rubrique NBCPY variable de bas de tableau                                        ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
#------------------------------------------------------------------------------------#
# Les societés sont mises en gras                                                      # 
# lors du click sur une ligne du tableau                                             #
#------------------------------------------------------------------------------------#
Subprog AS_NBCPY
Local Integer WILIGCLICK 
Local Integer WI 
Local Integer WISRCUNIQ 
Local Integer WIDESUNIQ

#Infbox 'as_NBCPY' 

If [M:CIG0]CPYSRC(1) = ""
     WISRCUNIQ  = G_OUI
Else 
     WISRCUNIQ  = G_NON
Endif 

If [M:CIG0]CPYDES(1) = ""
     WIDESUNIQ  = G_OUI
Else 
     WIDESUNIQ  = G_NON
Endif 

WILIGCLICK = nolign-1
 
If nolign-1 <> 0
  If WISRCUNIQ  = G_OUI
      If [M:CIG0]CPYDES (nolign-1) <> "" 
          Call SOC_SRC_COURANTE(0)
          Call SOC_DES_COURANTE(nolign-1)
      Endif 
  Else 
      If [M:CIG0]CPYSRC (nolign-1) <> "" 
          Call SOC_SRC_COURANTE(nolign-1)
          Call SOC_DES_COURANTE(0)
      Endif 
  Endif 
Else 
  Call SOC_SRC_COURANTE(nolign-1)
  Call SOC_DES_COURANTE(nolign-1)
Endif 

If GREP <> 'C' and GIADDLIG = G_NON 

    If GISUPLIG = G_NON 
        For WI = 0 To NBCPY-1
            If WI  <> WILIGCLICK 
                    If WIDESUNIQ  = G_NON
                        Chgstl [M:CIG0]CPYDES(WI) With ""
         
                    Endif 
                    If WISRCUNIQ  = G_NON
                        Chgstl [M:CIG0]CPYSRC(WI) With ""
                    Endif  
            Endif 
        Next 
    Endif 
   
    ##------------------------------------------------------------------------------------------------##
    ## - Chargement des informations de l'ONGLET 1,2 ,3                                               ##    
    ##------------------------------------------------------------------------------------------------##
    Gosub CHARGE_ONGLET_123
    
    ##------------------------------------------------------------------------------------------------##
    ## - Chargement, dans le 4ème onglet, des recodifcations liées a cette CIG                        ##    
    ##------------------------------------------------------------------------------------------------##
    Gosub CHARGE_ONGLET_4_RECOD

Endif 

GIADDLIG = G_NON



End

######################################################################################
## Rubrique NBCPY de bas de tableau                                                 ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant_zone                                                                         #
#------------------------------------------------------------------------------------#
Subprog AV_NBCPY

End
#------------------------------------------------------------------------------------#
# Avant_ligne                                                                        #
#------------------------------------------------------------------------------------#
Subprog AVANT_NBCPY

GCSRCAV = [M:CIG0]CPYSRC(nolign-1)
GCDESAV = [M:CIG0]CPYDES(nolign-1) 
GISUPLIG = G_NON
GIADDLIG = G_NON
Call SOC_SRC_COURANTE(nolign-1)
Call SOC_DES_COURANTE(nolign-1)

End
#------------------------------------------------------------------------------------#
# Après_ligne                                                                        #
#------------------------------------------------------------------------------------#
Subprog APRES_NBCPY

Local Integer WM, WI, SAV_NOLIGN
Local Integer WNUMLIG
Local Char    WCSUPSRC 
Local Char    WCSUPDES  
Local Char    WCADDSRC 
Local Char    WCADDDES  

GCSRCAP = [M:CIG0]CPYSRC(nolign - 1 )
GCDESAP = [M:CIG0]CPYDES(nolign - 1 ) 

WCSUPSRC  = "" 
WCSUPDES  = "" 
WCADDSRC  = "" 
WCADDDES  = "" 

#------------------------------------------------------------------------------------#
# Recherche du couple sociétés supprimé                                              #
#------------------------------------------------------------------------------------#
If GCDESAV  <> "" 
    WCSUPDES = GCDESAV   
    WCSUPSRC = [M:CIG0]CPYSRC(0)
Endif 

If GCSRCAV  <> "" 
    WCSUPSRC = GCSRCAV   
    WCSUPDES = [M:CIG0]CPYDES(0)
Endif 

#------------------------------------------------------------------------------------#
# Recherche du couple sociétés ajouté                                                #
#------------------------------------------------------------------------------------#
If GCDESAP  <> "" 
    WCADDDES = GCDESAP   
    WCADDSRC = [M:CIG0]CPYSRC(0)
Endif 

If GCSRCAP  <> "" 
    WCADDSRC = GCSRCAP   
    WCADDDES = [M:CIG0]CPYDES(0)
Endif 

#------------------------------------------------------------------------------------#
# Constat d'une suppression de ligne société                                         #
#------------------------------------------------------------------------------------#
If  GCSRCAP  = "" and  GCDESAP   = "" and (GCSRCAV  <> "" or   GCDESAV  <>  "")
         GISUPLIG = G_OUI
         GMESSAGE = mess(163,GML_MSGCIG,1) - WCSUPSRC - '-' - WCSUPDES + '.' + '\' + mess(164,GML_MSGCIG,1) : GERR = 2 
         Diszo [M:CIG0]
         Call CHANGE_SOC_SRC_COURANTE (0)
         Call CHANGE_SOC_DES_COURANTE (0)
         Affzo [M:CIG0]
         Raz [M:CIR1]
         Raz [M:CIR2]
         Raz [M:CIR3]
         Affzo [M:CIR1]
         Affzo [M:CIR2]
         Affzo [M:CIR3]
Endif 
#------------------------------------------------------------------------------------#
# Constat de l'ajout d'une ligne société                                             #
#------------------------------------------------------------------------------------#
If  GCSRCAV  = "" and  GCDESAV   = "" and (GCSRCAP  <> "" or   GCDESAP  <>  "")
     GIADDLIG = G_OUI

     If GCSRCAP  <> ""
        Call SOC_SRC_COURANTE(nolign-1)
        If nolign > 1 
           For WM = 0 To nolign-2
                Chgstl [M:CIG0]CPYSRC(WM) With ""
                Affzo  [M:CIG0]CPYSRC(WM) 
           Next
        Endif  
     Endif 
   
     If GCDESAP  <> ""
         Chgstl [M:CIG0]CPYDES With ""
         Affzo  [M:CIG0]CPYDES
         Call SOC_DES_COURANTE(nolign-1)
         WNUMLIG = nolign  
         
         If WNUMLIG > 1 
           For WM = 0 To WNUMLIG-2
                Chgstl [M:CIG0]CPYDES(WM) With ""
                Affzo  [M:CIG0]CPYDES(WM) 
           Next
         Endif  
     Endif 
 
     Raz [M:CIR1]
     Raz [M:CIR2]
     Raz [M:CIR3]
     Affzo [M:CIR1]
     Affzo [M:CIR2]
     Affzo [M:CIR3]
  
   GMESSAGE = mess(192,GML_MSGCIG,1) - WCADDSRC - 'et' - WCADDDES + '.' + '\' + mess(193,GML_MSGCIG,1) + '\' + mess(194,GML_MSGCIG,1) 
   GERR =  2  
   zonsui =  "NBRSEL"  
Endif

 [M:CIR3]RULTPFDAT =  gdat$ ( 31, 12, year([M:CIG0]EFFDAT)-1)  
 Affzo  [M:CIR3]RULTPFDAT

End
######################################################################################
## Rubrique CPYSRC: Société source                                                  ##
######################################################################################

#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_CPYSRC(VALEUR)
Variable Char    VALEUR()

Call CHANGE_SOC_SRC_COURANTE (0)

If VALEUR <> [M:CIG0]CPYSRC(nolign-1) and [M:CIG0]CPYSRC(nolign-1) <> ""
  GMESSAGE = mess(168,GML_MSGCIG,1)-[M:CIG0]CPYSRC(nolign-1)-mess(171,GML_MSGCIG,1)-VALEUR+'\'+ mess(169,GML_MSGCIG,1)-[M:CIG0]CPYSRC(nolign-1)
&     + '-' + GCSOCDES + '.' + '\' + mess(170,GML_MSGCIG,1) - [M:CIG0]CPYSRC(nolign-1) -  mess(172,GML_MSGCIG,1) - VALEUR  + '.' : 

  GERR = 2 
  mkstat = 2 
Endif 

If nolign = 1  
  GCSOCSRC = VALEUR 
Endif


# Si plusieurs sociétés source et type CIG <> scission ==> 1 seule société cible
If VALEUR <> "" & nolign > 1 & [M:CIG0]CIGTYP  <> GVML_TOSCISS
  Diszo [M:CIG0]CPYDES(nolign-1) 
  Affzo [M:CIG0]CPYDES(nolign-1) 
Endif
  

End
