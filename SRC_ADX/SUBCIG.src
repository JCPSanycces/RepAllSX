Subprog C_REFCDF(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif
Call UNICITE(VALEUR,[M]REFCDF(0..[M]NBRCDF-1)) From OBJDIV
If !mkstat
 Call CONTROLE("CIR","",VALEUR,"",mkstat) From CONTOBJ
Endif
End

#Fq-72446
 Read [CDF]CDF0=VALEUR
 If fstat= 0
    If [F:CDF]REFTRFCMP <> [M:CIG0]CIGCOD
      GMESSAGE = mess(226,GML_MSGCIG,1)  
      GERR=1  :  mkstat=2 : End   
