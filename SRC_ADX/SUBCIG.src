Return
####################################################################################################
## $SETBOUT: Gestion de l'inaccessibilité des boutons en fonction de la référence de CIG          ##
##               (La 1ere fois)                                                                   ##
##           Par défaut, ces boutons son accessibles                                              ##
####################################################################################################
$SETBOUT
##------------------------------------------------------------------------------------------------##
## - BOUTON OK                                                                                    ##    
##------------------------------------------------------------------------------------------------##
If [M:CIG0]CIGSTA <> GVML_CIGSTAP and [M:CIG0]CIGSTA <> GVML_CIGSTAE 
   # On desactive le Bouton standard Supprimer   
   Call VIREBOUT(CHAINE,"A") From GOBJET
Endif 

If  (GREP = 'D' or GREP = 'M' or GREP = 'A')  & ([CIG0]CIGSTA <> GVML_CIGSTAP)
  Call VIREBOUT(CHAINE,"B") From GOBJET
Else
  # On affiche le bouton B : Sélection 
  CHAINE+="B" 
Endif 

Affzo [M:CIG0]

Return
####################################################################################################
## $EXEBOUT                                                                                       ##
####################################################################################################
$EXEBOUT
Local Integer WITRTREC
Local Integer WIRETOUROK            

Case BOUT
 When "B" :
Endcase 
Return

####################################################################################################
## $TEST_PLAN_LIBRE: Test plans libres si géré et si dans devise société                          ##
####################################################################################################
$TEST_PLAN_LIBRE

Local Integer WICONTEXTE

WIPLANOK    = G_OUI 

If func GLOBIENS.CPY_PLN_GERE(GCSOCDES ,WIPLANLIBRE ) = G_NON
            WIPLANOK    = G_NON 
Else 
    # Devise du plan comptable (la même que plan fiscal)   
    Call GET_CNX_FROM_PLAN (GCSOCDES, G301CPT , WICONTEXTE) From GLOBIENS
    If WICONTEXTE > 0 
        # Récupération de la devise comptable 
        Read [F:CNX]CNX0=GCSOCSRC ;WICONTEXTE
        If fstat = 0 
             WCDEV6 = [F:CNX]CUR    
        Else
             WCDEV6 = GEURO    
        Endif
     Endif 

   # Devise du plan libre  
    Call GET_CNX_FROM_PLAN (GCSOCDES, WIPLANLIBRE , WICONTEXTE) From GLOBIENS
    Read [F:CNX]CNX0=GCSOCDES ;WICONTEXTE
    If fstat = 0 
         WCDEV5= [F:CNX]CUR    
    Else
         WCDEV5= GEURO  
    Endif
 
    # menu caché si devise différente 
    If WCDEV5 <> WCDEV6
            WIPLANOK    = G_NON 
    Endif   

Endif 

Return 
######################################################################################################
## $COMPARE_EXERCICES_DEVISES : si Valeurs reprise à l'identique :                         ## 
## - les exercices/périodes du plan des sociétés source et cible doivent être identiques            ##
## - les devises du plan des sociétés source et cible doivent être identiques                       ##
######################################################################################################
$COMPARE_EXERCICES_DEVISES

Local Integer WICNXSRC
Local Integer WIRETSRC
Local Integer WINOK
Local Integer WICNXDES
Local Integer WIRETDES
Local Date    WDDATSRC(1..5)
Local Date    WDDATDES(1..5)
Local Char    WCCURSRC
Local Char    WCCURDES


WIOK    = G_OUI 

If func GLOBIENS.CPY_PLN_GERE(GCSOCDES ,[M:CIR2]DPRPLN(nolign-1)) = G_NON
  WIOK    = G_NON 
Else

  ##---------------------------------------------------------------------------------------------##
  ## Récup date deb et fin d'exe pour contexte correspondant au  plan de la société source       ##
  ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ## 
  ##---------------------------------------------------------------------------------------------##
  If WAIDENTI = G_OUI
    Call GET_CNX_FROM_PLAN (GCSOCSRC, [M:CIR2]DPRPLN(nolign-1), WICNXSRC) From GLOBIENS
  Else
    Call GET_CNX_FROM_PLAN (GCSOCSRC,WIPLN, WICNXSRC) From GLOBIENS  
  Endif
  If WICNXSRC> 0 
      Call GET_CNX_DAT(GCSOCSRC,WICNXSRC ,WDDATSRC,WIRETSRC) From GLOBIENS 
      ##---------------------------------------------------------------------------------------------##
      ## Récup devise pour contexte correspondant au  plan de la société source                      ##
      ##---------------------------------------------------------------------------------------------##
      Read [F:CNX]CNX0=GCSOCSRC ;WICNXSRC
        If fstat = 0 
             WCCURSRC= [F:CNX]CUR    
        Else
             WCCURSRC= GEURO    
        Endif  
  Endif
  ##---------------------------------------------------------------------------------------------##
  ## Récup date deb et fin d'exe pour contexte correspondant au  plan de la société cible        ##
  ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ## 
  ##---------------------------------------------------------------------------------------------##
  Call GET_CNX_FROM_PLAN (GCSOCDES, [M:CIR2]DPRPLN(nolign-1), WICNXDES) From GLOBIENS
  If WICNXDES > 0 
        Call GET_CNX_DAT(GCSOCDES,WICNXDES ,WDDATDES,WIRETDES) From GLOBIENS 
      ##---------------------------------------------------------------------------------------------##
      ## Récup devise pour contexte correspondant au  plan de la société source                      ##
      ##---------------------------------------------------------------------------------------------##
      Read [F:CNX]CNX0=GCSOCDES;WICNXDES
        If fstat = 0 
             WCCURDES= [F:CNX]CUR    
        Else
             WCCURDES= GEURO    
        Endif  
  Endif

    #  NOK si date exercice courant et dates périodes courante différentes 

    If ( WDDATSRC(1) <> WDDATDES(1) ) or  ( WDDATSRC(2) <> WDDATDES(2) ) or ( WDDATSRC(3) <> WDDATDES(3) ) or
&      ( WDDATSRC(4) <> WDDATDES(4) )     
      WIOK =   G_NON
    Endif


    If WIOK =   G_NON
       GMESSAGE = mess(198,GML_MSGCIG,1)    : GERR=1
       mkstat   = 2  
       Return 
    Endif 


    # NOK si devise différente 
    If WCCURDES<> WCCURSRC
       GMESSAGE = mess(197,GML_MSGCIG,1)    : GERR=1
       mkstat   = 2  
       Return 
    Endif 
Endif

Return 
####################################################################################################
## $SEL_LISTE: Affichage d'une boite de selection contenant                                       ##
##              les sélection CIG                                                                 ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
## Le champ REFSELCIG posséde une sélection appelant l'action SELCIG3                             ##
## L'action SELCIG3 (modele standard SEL_LISTE) appelle le traitement standard SUBCIG             ##
##------------------------------------------------------------------------------------------------##


$SEL_LISTE
  Case LISTE
    When "SELCIG3"     : Gosub SELCIG3
    When "SELCIG5"     : Gosub SELCIG5
  Endcase
Return

##------------------------------------------------------------------------------------------------##
## Selection des CIS                                                                              ##
##------------------------------------------------------------------------------------------------##
$SELCIG3
Local Integer I

Filter [F:CIS] Where CPYSRC=GCSOCSRC
TIT = mess(159,GML_MSGCIG,1) 


I = 0
For [F:CIS] 
  I    += 1
  TEX(I)   = [F:CIS]REFSELCIG
  TEXTE(I) = [F:CIS]REFSELCIG + '           ' +    [F:CIS]SELCIGDES 

Next
Filter [F:CIS]

NBTEX = I

If NBTEX = 0 
    mkstat   = 2 
    GMESSAGE = mess(160,GML_MSGCIG,1) - GCSOCSRC   : GERR=1 

Endif 


Return
##------------------------------------------------------------------------------------------------##
## Selection des CDF                                                                              ##
##------------------------------------------------------------------------------------------------##
$SELCIG5
Local Integer I


GREFCIG = [M:CIG0]CIGCOD 
Filter [F:CDF] Where REFTRFCMP=[M:CIG0]CIGCOD 
TIT = mess(159,GML_MSGCIG,1) 


I = 0
For [F:CDF] 
  I    += 1
  TEX(I)   = [F:CDF]REFCDF
  TEXTE(I) = [F:CDF]REFCDF+ '           ' +    [F:CDF]REFDES 

Next
Filter [F:CDF]

NBTEX = I
#If NBTEX = 0  & nolign=1
#    mkstat   = 2 
#    GMESSAGE = mess(87,GML_MSGCIG,1) + ' :  '- [M:CIG0]CIGCOD   : GERR=1 
#Endif 


Return



######################################################################################
## Rubrique DPRPLN : combo des plans d'amortissements                               ##
######################################################################################

#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR
Local Integer WIPLN

# Supprimer les plans déjà paramétrés
 


Raz GMENLOC

For WI = 0 To [M:CIR2]NBRPLN-1
     If WI <> nolign-1
       GMENLOC([M:CIR2]DPRPLN(WI))=1
     Endif 
Next 


# Supprimer le plan cible de la +/- value 
If [M:CIR3]GALPLNDES <> 0 and [M:CIR3]GALPRO  = G_OUI
   GMENLOC([M:CIR3]GALPLNDES )=1
Endif 


# Supprimer les plans non gérés : Lecture  des plans : si non géré --> cacher le menu
 
Filter [APL] Where [F:APL]LANCHP = GML_NPLAN and [F:APL]LAN = GLANGUE 
For [APL]
  If func GLOBIENS.CPY_PLN_GERE(GCSOCDES ,[F:APL]LANNUM)=G_NON
    GMENLOC([F:APL]LANNUM)=1
  Endif 
Next 
Filter [APL] 

End



######################################################################################
## Rubrique RULPRO: combo des règles de gestion                                     ##
######################################################################################
#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_RULPRO(VALEUR)
Variable Integer VALEUR

# Si plan cible = Origine , les Valeurs proviennent obligatoirement du  plan modèle Comptable
If [M:CIR2]DPRPLN (nolign-1) = G301ORI             
    Raz GMENLOC
    GMENLOC(GML_VAIDENTI)=1
    GMENLOC(GML_VBPRICES)=1
    GMENLOC(GML_VBVANPLM)=1
Endif 

# Si plan cible non géré dans soc source , la Valeur reprise à l'identique n'est pas proposée 
If func GLOBIENS.CPY_PLN_GERE(GCSOCSRC,[M:CIR2]DPRPLN (nolign-1)) = G_NON
    Raz GMENLOC
    GMENLOC(GML_VAIDENTI)=1
Endif 

End


#------------------------------------------------------------------------------------#
# Après_modif                                                                        #
# Si vente intra-groupe : valeur reprise a l'identique                               #
#------------------------------------------------------------------------------------#
Subprog AM_RULPRO(VALEUR)
Variable Integer VALEUR

Local Integer WAIDENTI

WAIDENTI=G_NON

If VALEUR  = GML_VAIDENTI or VALEUR   = GML_VAIDEPLM
          [M:CIR2]DPRDPM (nolign-1) = "" 
          [M:CIR2]DPRDUR (nolign-1) = 0 
          Affzo [M:CIR2]DPRDPM (nolign-1)
          Affzo [M:CIR2]DPRDUR (nolign-1)
          Diszo [M:CIR2]DPRDPM (nolign-1)
          Diszo [M:CIR2]DPRDUR (nolign-1)
Else
          Actzo [M:CIR2]DPRDPM (nolign-1)
          Actzo [M:CIR2]DPRDUR (nolign-1)
Endif 

# Champ plan modèle inaccessible si règle="valeurs reprises à l'id."
If (VALEUR <>  GML_VAIDEPLM) & (VALEUR <> GML_VBVANPLM)
  Raz   [M:CIR2]PLNTPL (nolign-1)     
  Diszo [M:CIR2]PLNTPL (nolign-1)
Else
  Affzo [M:CIR2]PLNTPL (nolign-1)
  Actzo [M:CIR2]PLNTPL (nolign-1)
Endif

 
If VALEUR = GML_VAIDENTI
  WAIDENTI=G_OUI
  Gosub COMPARE_EXERCICES_DEVISES
Endif


End



