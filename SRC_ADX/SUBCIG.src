#-----------------------------------------------------------------------------------#
# Après_zone                                                                        #
#-----------------------------------------------------------------------------------#
Subprog AP_GALDPM(VALEUR)
Variable Char    VALEUR()

Local Integer LERROR

If VALEUR  = "" and [M:CIR3]GALPRO  = G_OUI 
    GMESSAGE = mess(128,GML_MSGCIG,1) : GERR=1 
    mkstat=2
    End 
Endif  


