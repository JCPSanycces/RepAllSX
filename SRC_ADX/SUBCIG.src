######################################################################################
## Rubrique SALPRIPLN : Plan précisé                                                ##
######################################################################################
#------------------------------------------------------------------------------------#
# Après_zones                                                                        #
#------------------------------------------------------------------------------------#
Subprog AP_SALPRIPLN(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0 and [M:CIR1]SALPRIMOD (nolign-1) = GVML_CIGPRC 
      GMESSAGE =  mess(133,GML_MSGCIG,1)  + mess([M:CIR1]SALPRIMOD (nolign-1), 3278,1)
      GOK=0
      OK=0
      mkstat=2
Endif  

If VALEUR = 0 and [M:CIR1]SALPRIMOD (nolign-1) <> GVML_CIGPRC 
      GMESSAGE =  mess(133,GML_MSGCIG,1)  + mess([M:CIR1]SALPRIMOD (nolign-1), 3278,1)
      GOK=0
      OK=0
      mkstat=2
Endif  

End


#------------------------------------------------------------------------------------#
# Avant_saisie                                                                       #
#------------------------------------------------------------------------------------#
Subprog AS_SALPRIPLN(VALEUR)
Variable Integer VALEUR

If [M:CIR1]SALPRIMOD (nolign-1) = GVML_CIGPRC
    GMENLOC(G301CPT)=1 
    GMENLOC(G301FIS)=1 
    GMENLOC(G301MIN)=1 
    GMENLOC(G301ORI)=1 
    GMENLOC(G301R76)=1 
    GMENLOC(G301IAS)=1 
    GMENLOC(G301TEC)=1 
    GMENLOC(G301RET)=1 
    GMENLOC(G301SUB)=1 
    GMENLOC(G301LI1)=1 
    GMENLOC(G301LI2)=1 
    GMENLOC(G301LI3)=1 
    GMENLOC(G301LI4)=1 
    GMENLOC(G301LI5)=1 
    GMENLOC(G301LI6)=1 
    GMENLOC(G301AUC)=1 
    End
Endif 


# seul les plans géré dans soc source sont proposés 
Raz GMENLOC
Filter [APL] Where [F:APL]LANCHP = GML_NPLAN and [F:APL]LAN = GLANGUE 
For [APL]
  If func GLOBIENS.CPY_PLN_GERE(GCSOCSRC,[F:APL]LANNUM) = G_NON
        GMENLOC([F:APL]LANNUM)=1
  Endif 
Next 
Filter [APL] 
Affzo [M:CIR1]SALPRIPLN

End


