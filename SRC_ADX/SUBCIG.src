 #   Call CTRL_DPM (VALEUR, GCSOCDES , [M:CIR3]GALPLNDES, 0, LERROR) From TRTFAS
 #   If (LERROR) Then
 #         GMESSAGE =  mess(115,GML_MSGCIG,1)  
 #         GOK=0
 #         OK=0
 #         mkstat=2
 #   Endif
Endif 

End

