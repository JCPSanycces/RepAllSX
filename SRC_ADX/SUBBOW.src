#<AdxTL>@(#)5.0.0.0 $Revision$
###################################################################################
# Traitement d'affichage des cas d'emploi de composants
###################################################################################
# En Web un choix en radio btn (TRT) remplace les 3 boutons
# Fenêtres principales :
# Affichage des cas d'emploi
# écrans liens : multi-niveau
# - alternatives de production  BOW1
# - alternatives commerciales   BOW2
# - alternatives sous-traitance BOW4
#
# - alternatives dernier niveau BOW3
###################################################################################
$ACTION
Case ACTION
    When "INIT_DIA"    : Gosub INIT_DIA
    When "INIT"        : Gosub INIT
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When "SORTIE"      : Gosub SORTIE
    When "AVANT_PAR"   : Gosub AVANT_PAR

    When "AB1_CPNSEL"  : Local Integer SAVCONS :  SAVCONS=GCONSULT : GCONSULT=1
    When "BB1_CPNSEL"  : GCONSULT=SAVCONS

    # pour GSAISIE de la fenêtre principale
    When "DEBUT"       : If BOITE="FBOMWUSL" | BOITE="FBOMWUS" Gosub DEBUT Endif
    When "AV_CHOIX"    : Gosub AV_CHOIX
    When "APRES_MODIF" : Gosub APRES_MODIF  # pour saisie directe de l'alt
    When "FIR"         : Gosub DEBUT
    When "LAS"         : Gosub DERNIER
    When "PRE"         : Gosub PREC
    When "SUI"         : Gosub SUIV
    When "FIN"         : Gosub FIN

    When "SEL_TABLE"   : Case COUZON
                             When "ECCVALMAJ","ECCVALMIN" : Gosub SELECCVAL
                             When "B3_NBLIG"              : Gosub SELB3_NBLIG
                         Endcase
    When "VERF_TABLE"  : Case COUZON
                             When "ECCVALMAJ"             : Gosub VERFECCVAL
                             When "B3_NBLIG"              : Gosub VERFB3_NBLIG
                         Endcase
Endcase
Return

###################################################################################
$INIT
Local Integer TOK, OK

If clalev([F:TBO])  = 0 : Local File TABBOMALT [TBO]  : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT [TBO1] : Endif
If clalev([F:ITB])  = 0 : Local File ITMBOM    [ITB]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER [ITM]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR    [TFO]  : Endif : # GH 28/11/12 FQ 85169
If clalev([F:EVL])  = 0 : Local File ECCVAL    [EVL]  : Endif
Return

###################################################################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]DATREF = date$
Return

###################################################################################
$AVANT_PAR
# Issue 101318 GA 07/2014
Local Char SAVACT(20) : SAVACT = GACTION
#MAE, EVOL_ERGO
If GFONCTION = "GESITM"
    #si click sur bouton FIN
    If FIN or !FOK  : Goto SORTIE  : Endif
    #pas d'affichage de la fenêtre de critères
    #TYPPRG = 0
    If clalev([M:DIA])  = 0
        Local Mask BOW0 [DIA]
    Endif
    #affectation des paramètres
    #composant
 #  [M:DIA]CPNSEL = [F:ITM]ITMREF
    [M:DIA]CPNSEL = [M:ITM0]ITMREF
    Affzo[M:DIA]CPNSEL
    #date de référence
    [M:DIA]DATREF = date$
    Affzo[M:DIA]DATREF
    #mode de traitement : multi niveaux
    [M:DIA]TRT = 3
    Affzo[M:DIA]TRT
    #type d'alternative début
    [M:DIA]ALTTYPDEB = 1
    #type d'alternative fin
    [M:DIA]ALTTYPFIN = 3

Elsif GFONCTION="GESITF"
    If clalev([M:DIA])  = 0
        Local Mask BOW0[DIA]
    Endif
    #composant
 #   [M:DIA]CPNSEL = [F:ITF]ITMREF
    [M:DIA]CPNSEL = [M:ITF0]ITMREF
    Affzo[M:DIA]CPNSEL
    #date de référence
    [M:DIA]DATREF = date$
    Affzo[M:DIA]DATREF

Elsif GFONCTION="VISUBOMG"
# GA 18/09/2008 utilisé aussi par VISUBOMG

    If clalev([M:DIA])  = 0
        Local Mask BOW0[DIA]
    Endif
    #composant
#   [M:DIA]CPNSEL = [F:ITF]ITMREF
    [M:DIA]CPNSEL = [M:VBOG]XCPNITMREF

    #date de référence
    [M:DIA]DATREF = [M:VBOG]DATREF
    #mode de traitement : multi niveaux
    [M:DIA]TRT = 3
    #type d'alternative début
    [M:DIA]ALTTYPDEB = 2
    #type d'alternative fin
    [M:DIA]ALTTYPFIN = 3
    [M:DIA]ALTDEB = [M:VBOG]BOMALT
    [M:DIA]ALTFIN = [M:VBOG]BOMALT

Elsif GFONCTION ="VISUBOMROU" | GFONCTION ="VISUROUBOM"
    If clalev([M:DIA])  = 0
        Local Mask BOW0[DIA]
    Endif
    [M:DIA]CPNSEL = [M:VBOR]CPNITMREF(nolign-1)
    [M:DIA]DATREF = [M:VBOR]DATREF
    [M:DIA]TRT = 3
    [M:DIA]ALTTYPDEB = 2
    [M:DIA]ALTTYPFIN = 3
    [M:DIA]ALTDEB = [M:VBOR]BOMALT
    [M:DIA]ALTFIN = [M:VBOR]BOMALT
  Affzo[M:DIA]TRT,CPNSEL,DATREF

# FQ 67302 nomenclature sous-traitance objet BOS: on a GFONCTION ="GESBOS"
# Bug 69539 Il manquait GESBODP
Elsif find(GFONCTION,"GESBOD","GESBODC","GESBODS","GESBOS","GESBODP")
  If clalev([M:DIA])  = 0
    Local Mask BOW0[DIA]
  Endif
  [M:DIA]CPNSEL = [M:BOD1]CPNITMREF(nolign-1)
  If dim([M:DIA]ECCVALMAJ)=1 : [M:DIA]ECCVALMAJ = [M:BOD1]ECCVALMAJ(nolign-1) : Endif
  If dim([M:DIA]ECCVALMIN)=1 : [M:DIA]ECCVALMIN = [M:BOD1]ECCVALMIN(nolign-1) : Endif
  [M:DIA]DATREF = [M:BOH0]DATREF
  [M:DIA]TRT = 3
  [M:DIA]ALTTYPDEB = 1
  [M:DIA]ALTTYPFIN = 3
  [M:DIA]ALTDEB = [M:BOH0]BOMALT
  [M:DIA]ALTFIN = [M:BOH0]BOMALT
  Case GFONBOD
    When "BOMP" :  GFONCTION = "GESBODP"
    When "BOMS" :  GFONCTION = "GESBODS"
    When "BOMC" :  GFONCTION = "GESBODC"
  Endcase
  Affzo[M:DIA]TRT,CPNSEL,DATREF

Elsif SAVACT="VISUWUS"            # Issue 101318 GA 07/2014

    #si click sur bouton FIN
    If FIN or !FOK  : Goto SORTIE  : Endif
    # no display of selection criteria
    If clalev([M:DIA])  = 0
        Local Mask BOW0 [DIA]
    Endif
    # received paramters
    # 1) wich product
    [M:DIA]CPNSEL = PARAM(1)
    #date de référence
    [M:DIA]DATREF = date$
    # 2) what to display 3= All levels
    If PARAM(2)<>""
       [M:DIA]TRT = val(PARAM(2))
    Else
       [M:DIA]TRT = 1
    Endif
    # 3) BOM's type (From)
    If PARAM(3)<>""
       [M:DIA]ALTTYPDEB = val(PARAM(3))
    Else
       [M:DIA]ALTTYPDEB = 1
    Endif
    # 4) BOM's type (To)
    If PARAM(3)<>""
       [M:DIA]ALTTYPFIN = val(PARAM(4))
    Else
       [M:DIA]ALTTYPFIN = 3
    Endif
Endif

If dim([M:DIA]CPNSEL)=1 & [M:DIA]CPNSEL<>"" : # to redo diszo instructions
   Raz [M:DIA]INV
Endif
Return

##################################################################################
$CONTROLE
# trt différent et boite adaptée
If [M:DIA]TRT = 1
         Call TRAITPREM(OK)
Else
         Call FILTDERMUL(OK)
Endif
If OK = 0
   GMESSAGE = mess(13,100,1)-"BOMWUS"
   GERR = 2
   SAI = 1
Endif

If find([M:DIA]TRT,1,3)
  BOITE = "FBOMWUS"
Else
  BOITE = "FBOMWUSL"
Endif
If [M:DIA]SCRFLG = 1
   BOITE = "" # pour ne rien afficher
Endif


If clalev([F:BOW])=0  : Local File BOMWUS [BOW]  Where CREUSR=GUSER & BOWUID=adxuid(1) : Endif
If clalev([F:BOW1])=0 : Local File BOMWUS [BOW1] Where CREUSR=GUSER & BOWUID=adxuid(1) : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
Local    Integer EOF, I_ALT
Local    Integer ALT_AFF
Local    Integer ALTTYP_AFF
Local    Integer VERIF_OK

Read [BOW1]BOW1(3) First
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Else
    EOF = 1
Endif
Gosub VERIF
If VERIF_OK = 0 Gosub SUIV_VERIF Endif
If GERR=2 Then
  If !find(GNAVIG(GPILNAV),"GESITM","GESITF","CASNOMENP") Then
    FIN=1
  Else
    Case GFONCTION
      When "VISUBOMROU","GESBOD","GESBODC","GESBODS","VISUROUBOM" : FIN =1
    Endcase
    SAI=1
  Endif
Endif
Return

###################################################################################
$VERIF
VERIF_OK = 1
# retrier les liens selon l'ordre de parcours pour le multi niveau
If [M:DIA]TRT = 3
   Filter [BOW] Where BOMALT = ALT_AFF & BOMALTTYP = ALTTYP_AFF Order By IMULT
Else
   Filter [BOW] Where BOMALT = ALT_AFF & BOMALTTYP = ALTTYP_AFF
Endif

Read [BOW] First : # tester s'il existe qqchose dans cette altern.
If fstat VERIF_OK = 0 : Return : Endif
Return

###################################################################################
$SUIV_VERIF
ALT_AFF = 0 : EOF = 0
Read [BOW1]BOW1(3) Next
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Else
    EOF = 1
Endif
If EOF = 0 & ALT_AFF <> 0
   Gosub AFF
   If VERIF_OK = 0 : Goto SUIV_VERIF : Endif :# continue + loin si filtre vide
Endif
If EOF
   GMESSAGE = mess(11,100,1) : # Début/fin de fichier
   GERR = 2
   Read [BOW1]BOW1(3) Last
   Gosub VERIF
Elsif ALT_AFF = 0
   GMESSAGE = mess(298,199,1) # "Début/Fin de liste"
   GERR = 2
Endif
Return

###################################################################################
$EXEC
# EDITION du résultat selon la case à cocher
If [M:DIA]PRNFLG = 2
   Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
   Call ETAT("BOMWUS",GFONCTION,TBPAR,TBVAL) From ETAT
Endif
Return

###################################################################################
$TERMINE
#MAE EVOL_ERGO # GA 09/2008 ajout VISUBOMG
If find(GFONCTION, "GESITM", "VISUBOMG","VISUBOMROU","VISUROUBOM","GESBODP","GESBODS","GESBODC")
&    | GACTION="VISUWUS"
    SAI=0
Else
    SAI=1
Endif
Return

###################################################################################
$DEBUT
If clalev([F:BOW])=0  : Local File BOMWUS [BOW]  Where CREUSR=GUSER & BOWUID=adxuid(1) : Endif
If clalev([F:BOW1])=0 : Local File BOMWUS [BOW1] Where CREUSR=GUSER & BOWUID=adxuid(1) : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
Local    Integer EOF, I_ALT
Local    Integer ALT_AFF
Local    Integer ALTTYP_AFF
Local    Integer AFF_OK

Read [BOW1]BOW1(3) First
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Else
    EOF = 1
Endif
Gosub AFF
If AFF_OK = 0 Gosub SUIV Endif
Return

###################################################################################
$AV_CHOIX
If find([M:DIA]TRT,1,3)
  If ALTTYP_AFF = 1
     SUIZON = "ALTAFF2"
  Elsif ALTTYP_AFF = 3
     SUIZON = "ALTAFF4"
  Else
     SUIZON = "ALTAFF"
  Endif
Else
  SUIZON = "ALTAFF"
Endif
Return

###################################################################################
# étiquette où l'on se branche à partir de DEBUT, PREC, SUIV et DERNIER
# Chargement et Affichage
$AFF

AFF_OK = 1
# retrier les liens selon l'ordre de parcours pour le multi niveau
If [M:DIA]TRT = 3
   Filter [BOW] Where BOMALT = ALT_AFF & BOMALTTYP = ALTTYP_AFF Order By IMULT
Else
   Filter [BOW] Where BOMALT = ALT_AFF & BOMALTTYP = ALTTYP_AFF
Endif


Read [BOW] First : # tester s'il existe qqchose dans cette altern.
If fstat AFF_OK = 0 : Return : Endif

# charger les 3 écrans selon le type d'alternative...
# et se positionner sur l'alternative (au début et après Prec Suiv)
# sur l'un ou l'autre des masques BOW1/BOW2/BOW4
If find([M:DIA]TRT,1,3)
    Effzo [BOW1]
    Effzo [BOW2]
    Effzo [BOW4]

    If ALTTYP_AFF = 1
        Default Mask [BOW2]
        [M:BOW2]ALTAFF2 = ALT_AFF
        [M:BOW2]ALTTYP = 1
    Elsif ALTTYP_AFF = 3
        Default Mask [BOW4]
        [M:BOW4]ALTAFF4 = ALT_AFF
        [M:BOW4]ALTTYP = 3
    Else
        Default Mask [BOW1]
        [M:BOW1]ALTAFF = ALT_AFF
        [M:BOW1]ALTTYP = 2
    Endif
Else
    Default Mask [BOW3]
    Effzo [BOW3]
    If ACTION <> "APRES_MODIF" : SUIZON = "ALTAFF"  : Endif
    [M:BOW3]ALTAFF3 = ALT_AFF
    [M:BOW3]BOMALTTYP = ALTTYP_AFF
Endif

[M:BOWH]CPNAFF = [M:DIA]CPNSEL :# le composant selectionné (en mode direct)
If dim([M:DIA]ECCVALMAJ)=1 : [M:BOWH]ECCVALMAJ = [M:DIA]ECCVALMAJ : Endif
If dim([M:DIA]ECCVALMIN)=1 : [M:BOWH]ECCVALMIN = [M:DIA]ECCVALMIN : Endif
Call LECTURE("ITM",[M:BOWH]CPNAFF,"") From CONTOBJ
If ALTTYP_AFF = 1
    [M:BOWH]STU = [F:ITM]SAU    : # unité de vente pour les alt. commercial
Else
    [M:BOWH]STU = [F:ITM]STU
Endif

nolign = 0
For [BOW]
  # test de la capacité du tableau   17/01/01
  If nolign = dim([M]ITMREF)
     GMESSAGE = mess(26,100,1)    # "tableau plein"
     GERR = 2
     Break
  Endif
  nolign += 1
  [M] = [F:BOW]
  # alimentation des zones "mal affichées" (13/05/03)
  If [M:DIA]TRT <> 2
    Call LECTURE("ITM",[M]CPNITMREF(nolign-1),"") From CONTOBJ
    If ALTTYP_AFF = 1
      [M]STU2(nolign-1) = [F:ITM]SAU
    Else
      [M]STU2(nolign-1) = [F:ITM]STU
    Endif
  Endif
  Call LECTURE("ITM",[M]ITMREF(nolign-1),"") From CONTOBJ
#  [M]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  # process 03.03 MM
  If dim([M]BOMUOM(nolign-1))>0
    If [M]BOMUOM(nolign-1)="":[M]BOMUOM(nolign-1) = [M]STU2(nolign-1): Endif
    If [M]BOMSTUCOE(nolign-1)=0 : [M]BOMSTUCOE(nolign-1)=1 : Endif
    If [M]BOMQTY(nolign-1)=0: [M]BOMQTY(nolign-1)=[F:BOW]LIKQTY : Endif
  Endif
  # Fin process 03.03 MM
Next
[M]NBLIG = nolign

Filter [BOW]  : # pour annuler les filtres

Affzo [BOWH]
Diszo [BOWH]

If find([M:DIA]TRT,1,3)
  # GH 25/07/2013 bug 87682 Qté nette et brute non calculées en 1er niveau
  If [M:DIA]TRT=1
   Chgfmt [M:BOW1]GROQTY With "-N:15F"
   Chgfmt [M:BOW1]NETQTY With "-N:15F"
  Endif

  Affzo [BOW1] : Diszo [BOW1]10
  Affzo [BOW2] : Diszo [BOW2]10
  Affzo [BOW4] : Diszo [BOW4]10 : # GA 23/11/2005
Else
  Affzo [BOW3] : Diszo [BOW3]10
Endif
Return

###################################################################################
$PREC
ALT_AFF = 0 : EOF = 0
Read [BOW1]BOW1(3) Prev
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Else
    EOF = 1
Endif
If EOF = 0 & ALT_AFF <> 0
   Gosub AFF
   If AFF_OK = 0 : Goto PREC : Endif :# continue + loin si filtre vide
Endif
If EOF
   GMESSAGE = mess(11,100,1)
   GERR = 2
   Read [BOW1]BOW1(3) First
   Gosub AV_CHOIX
   Gosub AFF
Elsif ALT_AFF = 0
   GMESSAGE = mess(298,199,1) # "Début/Fin de liste"
   GERR = 2
Endif
# Attention : réaffichage quand l'alt extreme n'a aucun cas d'emploi
Return

###################################################################################
$SUIV
ALT_AFF = 0 : EOF = 0
Read [BOW1]BOW1(3) Next
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Else
    EOF = 1
Endif
If EOF = 0 & ALT_AFF <> 0
   Gosub AFF
   If AFF_OK = 0 : Goto SUIV : Endif :# continue + loin si filtre vide
Endif
If EOF
   GMESSAGE = mess(11,100,1)
   GERR = 2
   Read [BOW1]BOW1(3) Last
   Gosub AV_CHOIX
   Gosub AFF
Elsif ALT_AFF = 0
   GMESSAGE = mess(298,199,1) # "Début/Fin de liste"
   GERR = 2
Endif
Return

###################################################################################
$DERNIER
# Lecture de la dernière alternative
Read [BOW1]BOW1(3) Last
If !fstat
    ALT_AFF    = [F:BOW1]BOMALT
    ALTTYP_AFF = [F:BOW1]BOMALTTYP
Endif
Gosub AFF
If AFF_OK = 0 Gosub PREC Endif
Return

###################################################################################
$SORTIE
# FQ60765 - MABON 09/12/09 - Si on vient de la fiche Articles, il faut bien remettre GCONSULT à 0
# sinon, on reste en mode consultation, et la fiche Articles n'est plus modifiable
GCONSULT=0
If clalev([F:BOD])
   Filter [BOD] # Issue 101318 GA 07/2014
Endif
Return

###################################################################################
$FILTRE
Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2
# l'ecran par défaut ici doit être l'entete de selection (DIA)

XCRITERE1 = "1=1"

If ([M:DIA]ALTTYPDEB <> 1 | [M:DIA]ALTTYPFIN <> 3)
    XCRITERE = "BOMALTTYP >= [M:DIA]ALTTYPDEB & BOMALTTYP <= [M:DIA]ALTTYPFIN"
    Gosub LOAD_CRITERE
Endif

If ([M:DIA]ALTDEB <> 0 | [M:DIA]ALTFIN <> 0)
    XCRITERE = "BOMALT >= [M:DIA]ALTDEB & BOMALT <= [M:DIA]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return


############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif

Return

###################################################################################
# Sous-pro pour cas d'emploi premier niveau
###################################################################################
Subprog TRAITPREM(OK)
Variable      Integer OK
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)

## versioning
Local Char    FILTRE2(255)
If dim([M:DIA]ECCVALMAJ)=1 & [M:DIA]ECCVALMAJ<>""
   FILTRE2-= "& ECCVALMAJ = '"+[M:DIA]ECCVALMAJ+"'"
Endif

If dim([M:DIA]ECCVALMIN)=1 & [M:DIA]ECCVALMIN<>""
   FILTRE2-= "& ECCVALMIN = '"+[M:DIA]ECCVALMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif
##

Gosub FILTRE

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If clalev([F:BOD]) = 0 : Local File BOMD [BOD] : Endif
If [M:DIA]DATREF <> [0/0/0]
  Filter [BOD] Where CPNITMREF = [M:DIA]CPNSEL & CPNTYP<>7 &
&                    (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0]) &
&                    (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0]) &
&                    evalue(XCRITERE1) & evalue(FILTRE2)
Else
  Filter [BOD] Where CPNITMREF = [M:DIA]CPNSEL  & CPNTYP<>7 &
&                    evalue(XCRITERE1) & evalue(FILTRE2)
Endif

Local File BOMWUS [BOW]
Trbegin [BOW]
# purge des éventuels enreg du user
Delete [BOW] Where CREUSR = GUSER & BOWUID = adxuid(1)
If fstat = 1 : Rollback : OK = 0 : Goto FIN_TRAITPREM : Endif
Commit

Gosub ANALYSE_FORMULE

GOK = 1
Trbegin [BOW]
For [BOD]BOD1

    ## Vérification des droits
    mkstat = 0
    Call CTLVISALT([F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM
    If mkstat <> 0 : GMESSAGE="" : Goto NXT_BOD_PREM : Endif

    ## Analyse de la formule de sélection
    Gosub CONTEXTE_FORMULE
    If !evalue(FORMULE1) : Goto NXT_BOD_PREM : Endif

    If dim([M:DIA]ECCVALMAJ)=1 & func ECCLIB.NBRCPN([F:BOD]ITMREF) : ## versioning
       If [M:DIA]DATREF=[0/0/0]
          Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                          & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                          & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
       Else
         Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                         & STRDAT<=[M:DIA]DATREF & (ENDDAT=[0/0/0] | ENDDAT>=[M:DIA]DATREF)
&                         & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                         & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
       Endif
       Look [EVL]EVL0 = [F:BOD]ITMREF
       Filter [EVL]
       If fstat>2 : Goto NXT_BOD_PREM : Endif
    Endif

    Raz [F:BOW]
    [F:BOW]= [F:BOD]
    [F:BOW]CPNDES = [M:DIA]CPNDES
    [F:BOW]BOWUID = adxuid(1)
    [F:BOW]CREDAT = date$
    [F:BOW]CREUSR = GUSER
    [F:BOW]TRTCOD = 1  : # code Premier niveau
    Write [BOW]
    If fstat : GOK = 0 : Break : Endif

$NXT_BOD_PREM
Next
If GOK = 0 : Rollback : OK = 0 : Goto FIN_TRAITPREM : Endif
OK=1
Commit

$FIN_TRAITPREM
Filter [BOD]
End

###################################################################################
## GH 28/11/12 FQ 85169 ajout de formule
## Analyse présence formule de sélection

$ANALYSE_FORMULE
Local Char    FORMULE1(255)
Local Integer WITM, WBOH, WTBO

If [M:DIA]FORMULE  <> ""
    If !clalev([F:TFO]) : Local File TABFOR    [TFO]  : Endif
    Read [TFO]TFO0=31;[M:DIA]FORMULE
    If !fstat
       FORMULE1  = [F:TFO]FORFOR
    Endif
Endif
If FORMULE1 = "" : FORMULE1 = "1=1" : Return : Endif

Local Char    FORMULE2(255)
FORMULE2 = vireblc(FORMULE1,4)

If instr(1,FORMULE2,"[ITM]") | instr(1,FORMULE2,"[F:ITM]")
   WITM=1
   If !clalev([F:ITM]) : Local File ITMMASTER [ITM]  : Endif
Endif

If instr(1,FORMULE2,"[TBO]") | instr(1,FORMULE2,"[F:TBO]")
   WTBO=1
   If !clalev([F:TBO]) : Local File TABBOMALT [TBO]  : Endif
Endif

If instr(1,FORMULE2,"[BOH]") | instr(1,FORMULE2,"[F:BOH]")
   WBOH=1
   If !clalev([F:BOH]) : Local File BOM [BOH]  : Endif
Endif
Return

###################################################################################
## GH 28/11/12 FQ 85169 ajout de formule
## Lectures pour application de la formule de sélection

$CONTEXTE_FORMULE
If FORMULE1="1=1" : Return : Endif

If WTBO & ([F:TBO]BOMALTTYP<>[F:BOD]BOMALTTYP | [F:TBO]BOMALT<>[F:BOD]BOMALT)
   Read [TBO]TBO0 = [F:BOD]BOMALTTYP;[F:BOD]BOMALT
   If fstat : Raz [F:TBO] : Endif
Endif
If WITM & [F:ITM]ITMREF<>[F:BOD]ITMREF
   Read [ITM]ITM0 = [F:BOD]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif
If WBOH & ([F:BOH]ITMREF<>[F:BOD]ITMREF | [F:BOH]BOMALT<>[F:BOD]BOMALT | [F:BOH]BOMALTTYP<>[F:BOD]BOMALTTYP)
   Read [BOH]BOH0 =  [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
   If fstat : Raz [F:BOH] : Endif
Endif
Return

###################################################################################
# Sous-pro filtrant BOD selon les sélections
###################################################################################
Subprog FILTDERMUL(OK)
Variable Integer OK

Local    Integer I
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)

Global Integer GINIV, GORD
Global Decimal GQTY, GNQTY  : # quantités brute et nette
If clalev([F:BOH]) = 0 : Local File BOM [BOH] : Endif
Local File BOMWUS [BOW]

Trbegin [BOW]
Delete [BOW] Where CREUSR = GUSER : # & BOWUID = adxuid(1)
If fstat = 1 : Rollback : OK = 0 : Goto FIN1 : Endif
Commit

Gosub FILTRE

OK = 1
GQTY = 1 : GNQTY = 1

## versioning
Local Char    VMAJ(GLONICVVAL), VMIN(GLONICVVAL)
If dim([M:DIA]ECCVALMAJ)=1
   VMAJ=[M:DIA]ECCVALMAJ
Endif
If dim([M:DIA]ECCVALMIN)=1
   VMIN=[M:DIA]ECCVALMIN
Endif
##

For [TBO] Where evalue(XCRITERE1)
    mkstat = 0
    Call CTLVISALT([F:TBO]BOMALT,[F:TBO]BOMALTTYP) From TRTBOM
    If mkstat=0
        If [M:DIA]TRT = 2
            Call TRAITDER([M:DIA]CPNSEL,VMAJ,VMIN,[F:TBO]BOMALT,[F:TBO]BOMALTTYP,OK)
        Else
            Call TRAITMUL([M:DIA]CPNSEL,VMAJ,VMIN,[F:TBO]BOMALT,[F:TBO]BOMALTTYP,OK)
        Endif
        If OK = 0 : Break : Endif
        GORD = 0 : # ràz du compteur de parcours
    Endif
Next

$FIN1
End

###################################################################################
# Sous-pro pour les cas d'emploi dernier niveau (récursif)
###################################################################################
Subprog TRAITDER(CPN,VMAJ,VMIN,ALT,ALTTYP,OK)
Value Char       CPN, VMAJ, VMIN
Value Integer    ALT
Value Integer    ALTTYP
Variable Integer OK

Local Integer J
Local Integer WLLCTYP :  WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
Local Decimal SGQTY, SNQTY :# locales pour conserver la qté à chaque noeud

## versioning
Local Char    VMAJ2(GLONICVVAL), VMIN2(GLONICVVAL)
Local Integer SEQ2, ITB
Local Char    FILTRE2(255)

If [L]VMAJ<>""
   FILTRE2-= "& ECCVALMAJ='"+[L]VMAJ+"'"
Endif
If [L]VMIN<>""
   FILTRE2-= "& ECCVALMIN='"+[L]VMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif
##

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If [M:DIA]DATREF <> [0/0/0]
   Local File BOMD [BOD] Where CPNITMREF=CPN & BOMALT=ALT & BOMALTTYP=ALTTYP & CPNTYP <> 7
&                            & evalue(FILTRE2)
&                            & (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0])
&                            & (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0])
Else
   Local File BOMD [BOD] Where CPNITMREF=CPN & BOMALT=ALT & BOMALTTYP=ALTTYP & CPNTYP<>7
&                            & evalue(FILTRE2)
Endif

Gosub ANALYSE_FORMULE

J=0
For [BOD]BOD3

  ## Analyse de la formule de sélection
  Gosub CONTEXTE_FORMULE
  If !evalue(FORMULE1) : Goto NXT_BOD_DER : Endif

  If !J : J=1 : GINIV+=1 : Endif : # il existe au moins un lien

  If !WBOH
      Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
  Endif
  SGQTY  = GQTY
  SNQTY  = GNQTY
  GQTY   = GQTY * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
  GNQTY  = GNQTY * [F:BOD]LIKQTY / [F:BOH]BASQTY

  SEQ2 = 0 : ITB = 0
  Repeat
    If dim([M:DIA]ECCVALMAJ)=1 : ## versioning
      # search item parent versions for which the current BOM line is used according to its validity period
      If [M:DIA]DATREF=[0/0/0]
        Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                        & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                        & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Else
        Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                        & STRDAT<=[M:DIA]DATREF & (ENDDAT=[0/0/0] | ENDDAT>=[M:DIA]DATREF)
&                        & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                        & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Endif
      Read [EVL]EVL0 > [F:BOD]ITMREF;[L]SEQ2;[F:BOD]BOMALTTYP
      Filter [EVL]
      If fstat<=2
         SEQ2  = [F:EVL]ECCSEQ
      Elsif SEQ2 | func ECCLIB.NBRCPN([F:BOD]ITMREF)
         Break
      Else
         Raz [F:EVL]
      Endif
      [L]VMAJ2 = [F:EVL]ECCVALMAJ
      [L]VMIN2 = [F:EVL]ECCVALMIN
    Endif

    # Si le composé n'a pas de cas d'emploi on est en haut de l'arborescence
    If !ITB
       Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
       If fstat : Raz [F:ITB] : Endif
       ITB = 1 + ([F:ITB]WUSEXIFLG=2)
    Endif
    If ITB = 2
       Call TRAITDER([F:BOD]ITMREF,[L]VMAJ2,[L]VMIN2,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
    Else
       Gosub ECRBOW
       If OK : Break : Endif
    Endif
    If OK = 0 : Break 2 : Endif
  Until SEQ2<1

  GQTY = SGQTY
  GNQTY = SNQTY

$NXT_BOD_DER
Next

If J = 1 : GINIV -= 1 : Endif
Close Local File
End

###################################################################################
$ECRBOW
Trbegin [BOW]
[F:BOW]BOWUID    = adxuid(1)
[F:BOW]CREUSR    = GUSER
[F:BOW]CREDAT    = date$
[F:BOW]CPNITMREF = [M:DIA]CPNSEL
[F:BOW]CPNDES    = [M:DIA]CPNDES
[F:BOW]NIV       = GINIV  : # niveau dans l'arborescence
[F:BOW]ITMREF    = [F:BOD]ITMREF
[F:BOW]BOMALT    = [F:BOD]BOMALT
[F:BOW]BOMALTTYP = [F:BOD]BOMALTTYP     # V6
[F:BOW]CPNTYP    = [F:BOD]CPNTYP        # llc 05.00 sous-produit
[F:BOW]GROQTY    = GQTY
Call QTEARR([F:BOW]GROQTY,[F:BOD]BOMUOM) From TRTDIV    # sr 11.04 demande 26626
[F:BOW]NETQTY    = GNQTY
Call QTEARR([F:BOW]NETQTY,[F:BOD]BOMUOM) From TRTDIV
[F:BOW]BOMSEQ    = 1 : # fictif, sert à dissocier les doublons
[F:BOW]TRTCOD    = 2 : # pour distinguer l'édition Dernier niveau

###################################################################################
$ECRIT
Write [BOW]
# en remontant l'arborescence, on peut trouver plusieurs occurences
# (composé,alternative), BOMSEQ servira à les distinguer :
If fstat = 3 : [F:BOW]BOMSEQ += 1 : Goto ECRIT : Endif
If fstat : OK = 0 : Rollback : Return : Endif
Commit
Return

###################################################################################
$ECRBOWMUL
Trbegin [BOW]
[F:BOW]BOWUID    = adxuid(1)
[F:BOW]          = [F:BOD]
[F:BOW]CREUSR    = GUSER
[F:BOW]CREDAT    = date$
[F:BOW]NIV       = GINIV : # niveau dans l'arborescence
[F:BOW]IMULT     = GORD  : # ordre de parcours
[F:BOW]TRTCOD    = 3     : # pour distinguer l'édition Multi niveau
# FQ 73424 GA 05/2011 idem TRAITDER + écran BOW1 champs rajoutés GROQTY et NETQTY
[F:BOW]GROQTY    = GQTY
Call QTEARR([F:BOW]GROQTY,[F:BOD]BOMUOM) From TRTDIV
[F:BOW]NETQTY    = GNQTY
Call QTEARR([F:BOW]NETQTY,[F:BOD]BOMUOM) From TRTDIV

Write [BOW]

# Le cas du doublon peut se produire sans pb : même composant à 2 séq
# seul le cas de la table lockée arrête le trt
If fstat=1 : OK = 0 : Rollback : Return : Endif
Commit
Return

###################################################################################
# Sous-pro pour les cas d'emploi multi niveau (récursif)
###################################################################################
Subprog TRAITMUL(CPN,VMAJ,VMIN,ALT,ALTTYP,OK)
Value Char       CPN, VMAJ, VMIN
Value Integer    ALT
Value Integer    ALTTYP
Variable Integer OK

Local Integer J, I, K
Local Integer WLLCTYP : :  WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
Local Decimal SGQTY, SNQTY :   # FQ 73424 GA 05/2011 idem TRAITDER

## versioning
Local Char    VMAJ2(GLONICVVAL), VMIN2(GLONICVVAL)
Local Integer SEQ2, ITB
Local Char    FILTRE2(255)

If [L]VMAJ<>""
   FILTRE2-= "& ECCVALMAJ='"+[L]VMAJ+"'"
Endif
If [L]VMIN<>""
   FILTRE2-= "& ECCVALMIN='"+[L]VMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif
##

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If [M:DIA]DATREF <> [0/0/0]
   Local File BOMD [BOD] Where CPNITMREF  = CPN & BOMALT = ALT & BOMALTTYP = ALTTYP & CPNTYP<>7
&                            & evalue([L]FILTRE2)
&                            & (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0])
&                            & (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0])
Else
   Local File BOMD [BOD] Where CPNITMREF  = CPN & BOMALT = ALT & BOMALTTYP = ALTTYP & CPNTYP<>7
&                            & evalue([L]FILTRE2)
Endif

Gosub ANALYSE_FORMULE

J=0 : K=0
For [BOD]BOD3
  K=1

  ## Analyse de la formule de sélection
  Gosub CONTEXTE_FORMULE
  If !evalue(FORMULE1)
     Goto NXT_BOD_MUL
  Endif

  I=J
  If !J : J=1 : GINIV+=1 : Endif : # il existe au moins un lien

  GORD += 1 : # séquence de parcours

  If !WBOH
      # FQ 73424 GA 05/2011 idem TRAITDER
      Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
  Endif
  SGQTY  = GQTY
  SNQTY  = GNQTY
  GQTY   = GQTY  * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
  GNQTY  = GNQTY * [F:BOD]LIKQTY / [F:BOH]BASQTY

  #Gosub ECRBOWMUL
  #If OK = 0 : Break : Endif

  SEQ2 = 0 : ITB = 0
  Repeat
    If dim([M:DIA]ECCVALMAJ)=1 : ## versionning
      # search item parent versions for which the current BOM line is used according to its validity period
      If [M:DIA]DATREF=[0/0/0]
        Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                        & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                        & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Else
        Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                        & STRDAT<=[M:DIA]DATREF & (ENDDAT=[0/0/0] | ENDDAT>=[M:DIA]DATREF)
&                        & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                        & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Endif
      Read [EVL]EVL0 > [F:BOD]ITMREF;[L]SEQ2;[F:BOD]BOMALTTYP
      Filter [EVL]
      If fstat<=2
         SEQ2 = [F:EVL]ECCSEQ
      Elsif SEQ2 | func ECCLIB.NBRCPN([F:BOD]ITMREF)
         Break
      Else
         Raz [F:EVL]
      Endif
      [L]VMAJ2 = [F:EVL]ECCVALMAJ
      [L]VMIN2 = [F:EVL]ECCVALMIN
    Endif

    If !ITB
       Gosub ECRBOWMUL
       If OK = 0 : Break 2 : Endif

       Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
       If fstat : Raz [F:ITB] : Endif
       ITB = 1 + ([F:ITB]WUSEXIFLG=2)
    Endif

    If ITB=2
     Call TRAITMUL([F:BOD]ITMREF,[L]VMAJ2,[L]VMIN2,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
      If OK=2
        Trbegin [BOW]
          Delete [BOW] Where BOWUID=adxuid(1) & ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & BOMSEQ=[F:BOD]BOMSEQ
&                          & CPNITMREF=[F:BOD]CPNITMREF & BOMALTTYP=[F:BOD]BOMALTTYP
          If fstat=1 | fstat>5 : Rollback : OK=0 : Break 2 : Endif
        Commit
      Endif
      If OK=2
        J=I : If !J : GINIV-=1 : Endif
        If !J & GINIV=0 : OK=1 : Endif
      Endif
      If OK = 0 : Break 2 : Endif
    Endif

  Until SEQ2<1

  # FQ 73424 GA 05/2011 idem TRAITDER
  GQTY  = SGQTY
  GNQTY = SNQTY

$NXT_BOD_MUL
Next
If !J & K : OK=2 : Endif

If J = 1 : GINIV -= 1 : Endif
Close Local File # pour libérer la mémoire (bug 12546) 25/01/02
End

###################################################################################
#sur la zone Alternative controle du type avec Options sur TBO
$APRES_MODIF
Case COUZON
    When "ALTAFF":
       Read [TBO1]TBO0= 2;val(CZ)
       Effzo [M]10
       ALT_AFF = val(CZ)
       ALTTYP_AFF = [F:TBO1]BOMALTTYP
       # FGR 16/09/2009 : X3SUIVI57824
       #If dim([M]ALTAFFDES)>0 : [M]ALTAFFDES = [F:TBO1]TBODES : Endif
       If dim([M]ALTAFFDES)>0
         Call LECTEXTRA([M]ALTAFFDES,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA
       Endif
       Gosub AFF    # message "Aucun cas d'emploi..."si rien trouvé  (17/01/02)
       If AFF_OK = 0 GERR=2 : GMESSAGE=mess(102,199,1) Endif
    When "ALTAFF2":
       Read [TBO1]TBO0= 1;val(CZ)
       Effzo [M]10
       ALT_AFF = val(CZ)
       ALTTYP_AFF = [F:TBO1]BOMALTTYP
       # FGR 16/09/2009 : X3SUIVI57824
       #If dim([M]ALTAFFDES2)>0 : [M]ALTAFFDES2 = [F:TBO1]TBODES : Endif
       If dim([M]ALTAFFDES2)>0
         Call LECTEXTRA([M]ALTAFFDES2,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA
       Endif
       Gosub AFF    # message "Aucun cas d'emploi..."si rien trouvé  (17/01/02)
       If AFF_OK = 0 GERR=2 : GMESSAGE=mess(102,199,1) Endif
    When "ALTAFF4":
       Read [TBO1]TBO0= 3;val(CZ)
       Effzo [M]10
       ALT_AFF = val(CZ)
       ALTTYP_AFF = [F:TBO1]BOMALTTYP
       # FGR 16/09/2009 : X3SUIVI57824
       #If dim([M]ALTAFFDES4)>0 : [M]ALTAFFDES4 = [F:TBO1]TBODES : Endif
       If dim([M]ALTAFFDES4)>0
         Call LECTEXTRA([M]ALTAFFDES4,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA
       Endif
       Gosub AFF    # message "Aucun cas d'emploi..."si rien trouvé  (17/01/02)
       If AFF_OK = 0 GERR=2 : GMESSAGE=mess(102,199,1) Endif
    When "ALTAFF3":
       Read [TBO1]TBO0= [M]BOMALTTYP;val(CZ)
       Effzo [M]10
       ALT_AFF = val(CZ)
       ALTTYP_AFF = [F:TBO1]BOMALTTYP
       # FGR 16/09/2009 : X3SUIVI57824
       #If dim([M]ALTAFFDES3)>0 : [M]ALTAFFDES3 = [F:TBO1]TBODES : Endif
       If dim([M]ALTAFFDES3)>0
         Call LECTEXTRA([M]ALTAFFDES3,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA
       Endif
       Gosub AFF    # message "Aucun cas d'emploi..."si rien trouvé  (17/01/02)
       If AFF_OK = 0 GERR=2 : GMESSAGE=mess(102,199,1) Endif
Endcase
Return

###################################################################################
# quand on sort de la fenêtre principale :
$FIN
Filter [BOW]  : # pour annuler l'ancien filtre
If [M:DIA]PRNFLG = 1
  Trbegin [BOW]
  Delete [BOW] Where CREUSR = GUSER & BOWUID = adxuid(1) : # les enreg du User et prss courant
  If fstat = 1
    Rollback : GLOCK="$BOMWUS"+GUSER
  Else
    Commit
  Endif
Endif

Raz [M:BOWH]
If find([M:DIA]TRT,1,3)
  Raz [M:BOW1]
  Raz [M:BOW2]
  Raz [M:BOW4] : # GA 23/11/2005 nomenc sous-traitance
Else
  Raz [M:BOW3]
Endif
#MAE EVOL_ERGO # GA 09/2008 ajout VISUBOMG
If find(GFONCTION, "GESITM", "VISUBOMG")
    Raz [M:DIA]
Endif
If dim(WBOUALT)>0 Then Kill WBOUALT Endif
# Issue 101318 GA 07/2014
If GACTION="VISUWUS"
   FIN=1
   Raz [M:DIA]
Endif
Return

###################################################################################
# Etiquettes des zones de sélection
###################################################################################
Subprog C_CPNSEL(VALEUR)
Variable Char     VALEUR

# GH 06/05/2013 bug 89819
If [F:ITM]SCSFLG = 2
   GMESSAGE = mess(164,199,1) : # "Article de type 'service' non autorisé"
   mkstat = 2 : End
Endif

# versioning
Call ECCAFF(VALEUR)
If dim([M:DIA]ECCVALMAJ)=1 & [M:DIA]ECCVALMAJ<>"" & varmode([M:DIA]ECCVALMAJ)
   Effzo [DIA]ECCVALMAJ
Endif
If dim([M:DIA]ECCVALMIN)=1 & [M:DIA]ECCVALMIN<>"" & varmode([M:DIA]ECCVALMIN)
   Effzo [DIA]ECCVALMIN
Endif

#[M]CPNDES = [F:ITM]ITMDES1 : # pour stockage dans BOMWUS (ITM a été lu par le AUT)
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]CPNDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
End

###################################################################################
