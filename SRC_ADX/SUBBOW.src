######################################################################################
## Etiquette ajoutée par le superviseur (écran BOW0) 03/04/2006 10:05:39 (LLCX)
######################################################################################
Subprog AV_ALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer WALTTYP

If [M:DIA]ALTTYPDEB <= 1 & [M:DIA]ALTTYPFIN >= 1  : WALTTYP += 1 : Endif
If [M:DIA]ALTTYPDEB <= 2 & [M:DIA]ALTTYPFIN >= 2  : WALTTYP += 2 : Endif
If [M:DIA]ALTTYPDEB <= 3 & [M:DIA]ALTTYPFIN >= 3  : WALTTYP += 4 : Endif

[M:DIA]ALTTYPS = WALTTYP
End

