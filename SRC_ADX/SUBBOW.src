######################################################################################
Subprog IB_NBLIG

# On ne peut pas aller dans les articles... si on en vient
If find("GESITM", GNAVIG(1..GPILNAV)) Then
  GBOUT1=""
Endif

If [M]ALTTYP=1 | dim([M:DIA]ECCVALMAJ)<1 | func ECCLIB.NBRCPN([M]ITMREF(nolign-1))<1
   GBOUT3=""
   If find("BOD",GPILCOD(1..GPILOBJ)) | find("BOS",GPILCOD(1..GPILOBJ))
      GBOUT2=""
   Endif
Else
   GBOUT2=""
Endif

If GBOUT2<>""
   Global Char WBOUALT(3)
   If [M:DIA]DATREF<>[0/0/0]             : [V]GDATEREF=[M:DIA]DATREF
   Elsif [M]BOMSTRDAT(nolign-1)<>[0/0/0] : [V]GDATEREF=[M]BOMSTRDAT(nolign-1)
   Endif
   Case [M]ALTTYP
     When 1 : GFONBOD="BOMC" : GBOMALT(0)=[M]ALTAFF2
     When 2 : GFONBOD="BOMP" : GBOMALT(0)=[M]ALTAFF
     When 3 : GFONBOD="BOMS" : GBOMALT(0)=[M]ALTAFF4
   Endcase
   WBOUALT=num$(GBOMALT(0))
Endif
End

######################################################################################
## Versioning (GH 05/15)
## Labels for screens
######################################################################################

Subprog ECCAFF(ITM)
Value Char ITM()
If dim([M:DIA]ECCVALMAJ)<0 : End : Endif

Case func ECCLIB.NBRCPN(ITM)
     When 0 : Grizo [DIA] ECCVALMAJ, ECCVALMIN
     When 1 : Actzo [DIA] ECCVALMAJ : Grizo [DIA] ECCVALMIN
     When 2 : Actzo [DIA] ECCVALMAJ, ECCVALMIN
Endcase
End

######################################################################################

Subprog D_INV(VALEUR)
Variable Char    VALEUR

Call ECCAFF([M:DIA]CPNSEL)
End

######################################################################################

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

Read [EVL]EVL1(2) = [M]CPNSEL;VALEUR
If fstat>2 : mkstat=2 : Endif
End

######################################################################################

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ECCVALMAJ="" : mkstat=1 : Endif
End

######################################################################################

Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Read [EVL]EVL1(3) = [M]CPNSEL;[M]ECCVALMAJ;VALEUR
If fstat>2 : mkstat=2 : Endif
End

######################################################################################
$SELECCVAL
Gosub SELECCVAL3 From ECCLIB
If !PSTD : Return : Endif

CRITERE="[EVL3]ITMREF='"+[M]CPNSEL+"'"
I=find("[F:EVL3]ITMREF",COL(1..NBCOL))
If I
   Dela I COL,TIT
   NBCOL-=1
Endif
Case COUZON
  When "ECCVALMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M]ECCVALMIN+"'"
  When "ECCVALMIN"
       CRITERE-="& [EVL3]ECCVALMAJ='"+[M]ECCVALMAJ+"'"
       EXPSTART="ECCVALMAJ='"+[M]ECCVALMAJ+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase
Return

$VERFECCVAL
VALEUR = [F:EVL3]ECCVALMAJ
START  = ""

If [F:EVL3]ECCVALMIN<>[M]ECCVALMIN
   [M]ECCVALMIN = [F:EVL3]ECCVALMIN
   Affzo ECCVALMIN
Endif
Return

######################################################################################
## Right button 'BOMs" for Item managed with version
## = Version selection + BOM tunnel with reference date = startind date of the chosen version
######################################################################################

$SELB3_NBLIG
OBJET="EVL1"
CRITERE="ITMREF='"+[M]ITMREF(nolign-1)+"' & ECCTYP="+num$([M]ALTTYP)
Case [M]ALTTYP
   When 1 : CRITERE+=" & BOMALT="+num$([M]ALTAFF2)
   When 2 : CRITERE+=" & BOMALT="+num$([M]ALTAFF)
   When 3 : CRITERE+=" & BOMALT="+num$([M]ALTAFF4)
Endcase

If [M:DIA]DATREF=[0/0/0]
   If [M]BOMSTRDAT(nolign-1)<>[0/0/0]
     CRITERE+=" & STRDAT>=["+format$(GFMD,[M]BOMSTRDAT(nolign-1))+"]"
   Endif
   If [M]BOMENDDAT(nolign-1)<>[0/0/0]
     CRITERE+=" & STRDAT<=["+format$(GFMD,[M]BOMENDDAT(nolign-1))+"]"
   Endif
Else
   CRITERE+=" & STRDAT<=["+format$(GFMD,[M:DIA]DATREF)+"]"
   CRITERE+=" & (ENDDAT>=["+format$(GFMD,[M:DIA]DATREF)+"] | ENDDAT=[0/0/0])"
Endif
Return

######################################################################################

$VERFB3_NBLIG
If find("BOD",GPILCOD(1..GPILOBJ)) | find("BOS",GPILCOD(1..GPILOBJ)) : Return : Endif

Global Char WBOUALT(3)
Local Date SAVDAT

GBOMALT(0)=[F:EVL]BOMALT
WBOUALT=num$([F:EVL]BOMALT)
Case [M]ALTTYP
   When 1 : GFONBOD="BOMC"
   When 2 : GFONBOD="BOMP"
   When 3 : GFONBOD="BOMS"
Endcase
SAVDAT = [V]GDATEREF
[V]GDATEREF=[F:EVL]STRDAT
Call OBJET_CHAR(WBOUALT,"BOD",[F:EVL]ITMREF+"~"+num$([F:EVL]ECCTYP)) From GOBJET
[V]GDATEREF=SAVDAT
Return
