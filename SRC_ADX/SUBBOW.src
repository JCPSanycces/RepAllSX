Subprog AV_STU2(VALEUR)
Variable Char     VALEUR
If maskcou <> "BOW3"
   Call LECTURE("ITM",[M]CPNITMREF(nolign-1),"") From CONTOBJ
   If maskcou = "BOW2"
      VALEUR = [F:ITM]SAU
   Else
      VALEUR = [F:ITM]STU
   Endif
Endif
End

