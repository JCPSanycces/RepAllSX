#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT_DIA"
  Case GACTION
   When "RAPBANRECH" : Gosub INIT_RECH
   When "RAPBANPRO"  : Gosub INIT_PRO
  Endcase
 When "DEBUT"
  Case GACTION
   When "RAPBANTRI"  : Gosub INIT_TRI : Affzo
  Endcase
 When "OK"
  Case GACTION
   When "RAPBANTRI"
    [M:RB3]  = [M:DIA] 
    PARAM(1) = "2"   :# Boutons OK de la fenetre de tri
  Endcase
 When "END"
  Case GACTION
   When "RAPBANTRI"
    [M:DIA]  = [M:RB3] 
    PARAM(1) = "1"   :# Boutons FIN de la fenetre de tri
  Endcase
 When "CONTROLE"
  Case GACTION
   When "RAPBANTRI"  : Gosub CONTROLE_TRI
   When "RAPBANRECH" : Gosub CONTROLE_RECH
   When "RAPBANPRO"  : Gosub CONTROLE_PRO
  Endcase
 When "SORTIE"  
  Case GACTION
   When "RAPBANRECH" : Gosub SORTIE_RECH
   When "RAPBANPRO"  : Gosub SORTIE_PRO
  Endcase
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "VERF_LISTE"   : Gosub VERF_LISTE
Endcase
Return


################################################
# ECRAN RAPBAN0 FENETRE DE SAISIE DES PARAMETRES
################################################

Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Call BANDEF(VALEUR) From SUBCHK : Endif
End

Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 GMESSAGE = mess(25,120,1)-" "-VALEUR : #Vous n'avez pas accés à la banque
 mkstat = 2
 End
Endif
#Recherche du compte banque
Read [BAN]BAN0 = VALEUR
If !fstat
 [M]BANACC = [F:BAN]BANACC
 [M]BANBPR = [F:BAN]BANBPR
Endif
End

Subprog AS_DATACE(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M]DATRBK
Endif
End

Subprog AS_DATRBK(VALEUR)
Variable Date    VALEUR
#Recherche de la date du dernier relevé
If VALEUR=[0/0/0]
 Filter [RBK] Where BAN=[M]BAN & RECTYP=3
 Read [RBK]RBK1 Last
 If fstat<=2
  VALEUR = [F:RBK]OPEDAT
 Else
  VALEUR = [0/0/0]
 Endif
 Filter [RBK]
Endif
End


################################################
# ECRAN RAPBAN0 FENETRE DE SELECTION
################################################
$SEL_LISTE
Case LISTE
 When "DATRBK" : Gosub SEL_DATRBK
Endcase
Return

$VERF_LISTE
Case LISTE
 When "DATRBK" : Gosub VERF_DATRBK
Endcase
Return

$SEL_DATRBK
Local Char    CHP(100)
NBTEX = 0
Filter [RBK] Where BAN=[M]BAN & RECTYP=3 Order By Key CLE=OPEDAT Desc; RBKNUM
For [RBK]CLE(2)
 CHP = mess(46,120,1)+" "+format$("K:20X",[F:RBK]RBKNUM) : # Relevé No
 Filter [RBKF] Where BAN=[M]BAN and RBKNUM=[F:RBK]RBKNUM
 Read [RBKF]RBK1 First
 If fstat<=2
  CHP += " "+mess(94,100,1)+"  "+format$("D:"+GFMDAT,[F:RBKF]OPEDAT)+"   " : # Du
 Else
  CHP += " "+mess(94,100,1)+"  "+[0/0/0]+"   " : # Du
 Endif
 Read [RBKF]RBK1 Last
 If fstat<=2
  CHP += "  "+mess(95,100,1)+"  "+format$("D:"+GFMDAT,[F:RBKF]OPEDAT) : # au
 Else
  CHP += "  "+mess(95,100,1)+"  "+[0/0/0] : # au
 Endif
 Filter [RBKF]
 # TEX(0..200)=>dim(TEX)=201 but (1) is the first filled index
 If NBTEX+1>min(dim(TEX)-1,dim(TEXTE)-1) : Break : Endif
 NBTEX += 1
 TEX(NBTEX)   = format$("D:YYYYMMDD",[F:RBKF]OPEDAT)
 TEXTE(NBTEX) = CHP
Next
Filter [RBK]
Return

$VERF_DATRBK
Return

#####################################
# ECRAN RAPBAN3 FENETRE DE TRI
#####################################

Subprog C_ORDRE(VALEUR)
Variable Decimal VALEUR
If VALEUR >[M]NBLIG
 GMESSAGE = mess(16,120,1) : #Ordre de tri incorrect
 mkstat = 2 : End
Endif
End

Subprog AV_TRI(VALEUR)
Variable Integer VALEUR
If VALEUR = 0 : VALEUR = 1 : Endif
End

$INIT_TRI
# Première fois que l'on exécute bouton Tri
If [M:DIA]CRITERE(0)=""
 Call LECMEMO("STD","[M:DIA]","tri") From GMEMO
Endif
[M:DIA]CRITERE(0) = mess(37,120,1)    : # MONTANT
[M:DIA]CRITERE(1) = mess(38,120,1)    : # DATE  
[M:DIA]CRITERE(2) = mess(40,120,1)    : # CIB
If GFONCTION="POINTAGE" or GFONCTION = "BANREC"
 [M:DIA]CRITERE(3) = mess(64,120,1)   : # REFERENCE
 [M:DIA]CRITERE(4) = mess(67,120,1)   : # NUMERO DE PIECE
 [M:DIA]CRITERE(5) = mess(63,120,1)   : # LIBELLE
 [M:DIA]NBLIG = 6
 If GFONCTION = "BANREC"
  [M:DIA]CRITERE(6) = mess(68,120,1) : # Mark
  [M:DIA]NBLIG = 7
 Endif
Else
 [M:DIA]CRITERE(3) = mess(62,120,1)   : # NUMERO DE REMISE/REFERENCE
 [M:DIA]CRITERE(4) = mess(63,120,1)   : # LIBELLE
 [M:DIA]NBLIG = 5
Endif
Return

$CONTROLE_TRI
For I=0 To [M:RB3]NBLIG - 1
 If find([M:RB3]ORDRE(I),[M:RB3]ORDRE(0..I-1),9999,[M:RB3]ORDRE(I+1..[M:RB3]NBLIG-1))
& & [M:RB3]ORDRE(I)<>0
  GERR = 1 : GMESSAGE = mess(16,120,1) : #Ordre de tri incorrect
  Break
 Endif
Next I
If GERR
 SAI = 1 : Return
Endif
Return

################################################
# ECRAN RAPBAN4 FENETRE DE RECHERCHE 
################################################
Subprog AS_MTRECH(VALEUR) 
Variable Decimal VALEUR 
If [M]BANCIB <> "" | [M]REFC <> "" : mkstat = 2  : Endif 
End 
 
Subprog C_MTRECH(VALEUR) 
Variable Decimal VALEUR 
If ([M]BANCIB <> "" | [M]REFC <> "") & VALEUR <> 0 
 GMESSAGE = (mess(18,120,1)) : #Un critère de recherche a déjà été saisi 
 mkstat = 2 
Endif 
End 
 
Subprog AS_BANCIB(VALEUR) 
Variable Char    VALEUR() 
If [M]MTRECH <> 0 | [M]REFC <> "" : mkstat = 2 : Endif 
End 
 
Subprog C_BANCIB(VALEUR) 
Variable Char    VALEUR() 
If ([M]MTRECH <> 0 | [M]REFC <> "") & VALEUR <> "" 
 GMESSAGE = (mess(18,120,1)) : #Un critère de recherche a déjà été saisi 
 mkstat = 2 
Endif 
End 
 
Subprog AS_REFC(VALEUR) 
Variable Char    VALEUR() 
If [M]BANCIB <> "" | [M]MTRECH <> 0 : mkstat = 2 : Endif 
End 
 
Subprog C_REFC(VALEUR) 
Variable Char    VALEUR() 
If ([M]MTRECH <> 0 | [M]BANCIB <> "") & VALEUR <> "" 
 GMESSAGE = mess(18,120,1) : #Un critère de recherche a déjà été saisi 
 mkstat = 2  
Endif  
End 

$INIT_RECH
Raz [M:DIA]
[M:DIA]CUR = [M:SAI1]CUR   
Return

$CONTROLE_RECH
[M:RB4] = [M:DIA]
Return

$SORTIE_RECH
PARAM(1)=num$(OK)   :# Boutons OK, FIN de la fenetre de recherche
Return


################################################
# ECRAN RAPBAN2 PROPOSITION AUTOMATIQUE 
################################################
Subprog AS_RAPPCE(VALEUR)
Variable Integer VALEUR
If [M:SAI1]NBLIG=0 : mkstat = 1 : Endif
End

Subprog AS_RAPPREC(VALEUR)
Variable Decimal VALEUR
If [M]RAPPCE <> 2 : mkstat = 1 : Endif
End

Subprog AS_RAPMTOPT(VALEUR)
Variable Integer VALEUR
If [M]RAPMT <> 2 : mkstat = 2 : Endif
End

Subprog C_RAPPREC(VALEUR)
Variable Decimal VALEUR
If VALEUR>=8 | VALEUR<0 
 GMESSAGE = mess(24,120,1)        : # Nombre compris entre 0 et 8 
 mkstat = 2 
Endif
End

Subprog RAPPREC(R0,PREC)
Variable Char R0()
Value Integer PREC
Local Integer I,J
Local Char R1(50), L(1)
If PREC<>0 : #On prend les X derniers caractères de entnum 
 R0 = right$(R0,max(0,len(R0)-PREC+1))
Else : #On prend dans entnum la première série de chiffres sans 0 devant
 R1 = ""
 For I=0 To len(R0)
  L = mid$(R0,I,1)
  If !instr(1,"0123456789",L)
   J = 2
   Break
  Elsif L<>"0" | J=1
   R1 +=L
   J = 1
  Endif
 Next I
 If J=1
  R0 = R1
 Endif
Endif
End 

$INIT_PRO
If [M:RB2]RAPPCE=0
 Raz [M:DIA] : [M:DIA]RAPPREC =7 : [M:DIA]RAPPCE = 2
Else
 [M:DIA] = [M:RB2]
Endif
Return

$CONTROLE_PRO
[M:RB2] = [M:DIA]
Return

$SORTIE_PRO
PARAM(1)=num$(OK)   :# Boutons OK, FIN de la fenetre de proposition
Return

