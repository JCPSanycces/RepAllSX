######################################################################################

Subprog C_LEGCOD(VALEUR)
Variable Char    VALEUR()
  If [M]LEV <> 2 : Effzo [M]LEGCOD : Endif
End


######################################################################################

######################################################################################
#JIRA:X3-52254 - 2017-08-09 - LIPET
######################################################################################
Subprog CONTLSTFLD(COD)
Variable Char    COD()

If COD="" : End : Endif
If clalev([F:HRLSTH])=0 : Local File HRLVESUBHEA [HRLSTH] : Endif
If COD <> ""
  Filter [F:HRLSTH] Where COD=[L]COD
  Read [F:HRLSTH] First
  Filter [F:HRLSTH]
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Read [F:HRLSTH]HRLST0 = GCURLEG;[L]COD
      If fstat
        Filter [F:HRLSTH] Where COD=[L]COD & LEG=GCURLEG
        Read [F:HRLSTH] First
        Filter [F:HRLSTH]
        If [F:HRLSTH]LEG<>""
          GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRLSTH]LEG
          mkstat = 2 : End
        Endif
      Endif
  Endif
Endif
Filter [F:HRLSTH]

End

