######################################################################################
## Section automatically added (screen HRLST2) 06/07/2017 21:20:58 (SAVAN)
######################################################################################
Subprog C_LVEPAYDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  mkstat=2
  GMESSAGE = mess(10,123,1)
Else
  Local Integer DEFAULTVALUEEXISTS: DEFAULTVALUEEXISTS = 0
  Local Integer ROWSEXISTS: ROWSEXISTS = 0

  For nolign = 1 To dim([M:HRLST2]LVEPAYDEF)
    If [M:HRLST2]LVEPAYDES(nolign - 1) <> "" and tolower([M:HRLST2]LVEPAYDES(nolign - 1)) = tolower(VALEUR)
      mkstat = 2
      GMESSAGE = mess(278,123,1)
    Endif
  Next

  If nolign = 1
    [M:HRLST2]LVEPAYDEF([M:HRLST2]LVEPAYNR) = 2 #Set the default value to "Yes" on the first row
  Endif
Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen HRLST0) 07/05/2017 11:54:41 (SAVAN)
######################################################################################
Subprog AM_DES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  mkstat=2
  GMESSAGE = mess(10,123,1)
Else
  If clalev([AXXX]) = 0 : Local File ATEXTRA [AXXX] : Endif
  Filter [AXXX] Where [AXXX]CODFIC = "HRLVESUBHEA" and [AXXX]LANGUE = [V]GLANGUE and [AXXX]TEXTE = VALEUR
  Read [AXXX] First
  Close File [AXXX]

  If (fstat < 4)
    mkstat = 2
    GMESSAGE = mess(278,123,1)
  Endif
Endif

End


