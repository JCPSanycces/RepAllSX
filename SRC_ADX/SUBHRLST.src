Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2017-08-23- US X3-53618- START
#Local Integer X
#MIPEA - 2017-08-23- US X3-53618- END
  GCURLEG=VALEUR

  Gosub STYLE
  Affzo [HRLST0]

#MIPEA - 2017-08-09- US X3-39538- START
If func DIVPAYE.IS_BRI_LEG(GCURLEG)
  [M:HRLST2]LVEPAYDES(0) = mess(1,11691,1)
  [M:HRLST2]LVEPAYDEF(0)    = 2
  [M:HRLST2]LVEPAYDES(1) = mess(2,11691,1)
  [M:HRLST2]LVEPAYDEF(1)    = 1
  [M:HRLST2]LVEPAYDES(2) = mess(3,11691,1)
  [M:HRLST2]LVEPAYDEF(2)    = 1
  [M:HRLST2]LVEPAYDES(3) = mess(4,11691,1)
  [M:HRLST2]LVEPAYDEF(3)    = 1
  [M:HRLST2]LVEPAYDES(4) = mess(5,11691,1)
  [M:HRLST2]LVEPAYDEF(4)    = 1
  [M:HRLST2]LVEPAYDES(5) = mess(6,11691,1)
  [M:HRLST2]LVEPAYDEF(5)    = 1
  [M:HRLST2]LVEPAYDES(6) = mess(7,11691,1)
  [M:HRLST2]LVEPAYDEF(6)    = 1
  LVEPAYNR=7
  Affzo [M:HRLST2]40
  Grizo [M:HRLST2]40
Endif
#MIPEA - 2017-08-09- US X3-39538- END

#MIPEA - 2017-08-23- US X3-53618- START
#For X = 0 To [M:HRLST1]HRLSTNR-1
#  If [M:HRLST1]LEV=2
#    [M:HRLST1]LEGCOD = VALEUR
#  Endif
#Next

  Effzo [HRLST1] : [M:HRLST1]LEV=3 : [M:HRLST1]POP="" : Affzo [HRLST1]
#MIPEA - 2017-08-23- US X3-53618- END

End

######################################################################################

Subprog CONTHRLST(COD) ##REMEMBER TO CHANGE FOR CONTROL ON COD
Variable Char    COD()

If GFONCTION = "GESHRLST" | COD="" : End : Endif
If clalev([F:HRLSTH])=0 : Local File HRLVESUBHEA [HRLSTH] : Endif
If COD <> ""
  Filter [F:HRLSTH] Where COD=[L]COD
  Read [F:HRLSTH] First
  Filter [F:HRLSTH]
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Read [F:HRLSTH]HRLST0 = GCURLEG;[L]COD
      If fstat
        Filter [F:HRLSTH] Where COD=[L]COD & LEG=GCURLEG
        Read [F:HRLSTH] First
        Filter [F:HRLSTH]
        If [F:HRLSTH]LEG<>""
          GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRLSTH]LEG
          mkstat = 2 : End
        Endif
      Endif
  Endif
Endif
Filter [F:HRLSTH]

End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

#LIPET - 2017-08-21 - X3-53396 - START
If [M]LEV(nolign-1)=4
 Call UNICITE(VALEUR,[M]CPY(0..[M]HRLSTNR-1)) From OBJDIV
If mkstat=2 : End : Endif
Endif
#LIPET - 2017-08-21 - X3-53396 - END

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & GCURLEG <> [F:CPY]LEG Then
     mkstat=2
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
   Endif
Endif
Filter [CPY]
########################################################################################
##New Control
########################################################################################
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
If [M]LEV(nolign-1)=4
 If VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
 SITSOC=VALEUR : Raz MATRI,CTR
 Endif
# pas 2 fois le même couple société+population
If [M]LEV(nolign-1)=2 | [M]LEV(nolign-1)=3
 ZONE=[M]POP(nolign-1)+"|"+VALEUR+"|"+[M]FCY(nolign-1)
 Call UNICITE(ZONE,[M]POP(0..[M]HRLSTNR-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif





End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)

#LIPET - 2017-08-21 - X3-53396 - START
If [M]LEV(nolign-1)=5
 Call UNICITE(VALEUR,[M]FCY(0..[M]HRLSTNR-1)) From OBJDIV
If mkstat=2 : End : Endif
Endif
#LIPET - 2017-08-21 - X3-53396 - END

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Filter [FCY] Where [F:FCY]FCY = VALEUR
Read [FCY] First
If !fstat
  If [F:FCY]LEGCPY <>[M:HRLST1]CPY & [M:HRLST1]CPY <> ""
  mkstat=2
   GMESSAGE = VALEUR-func AFNC.MES1(mess(171,104,1),[M:HRLST1]CPY)
  Else
   If GCURLEG <> [F:FCY]LEG &  VALEUR <> "" & GCURLEG <> ""
           mkstat=2
     GMESSAGE=VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
   Endif
   Endif
Endif
Filter [FCY]

If [M]LEV(nolign-1)=5
 If VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
 SITSOC=VALEUR : Raz MATRI,CTR
 Endif


End


