######################################################################################
## Section added (screen HRLST2) 03/23/2017 12:47:47 (SAVAN)
######################################################################################
$SEL_TABLE
Case TABLE
When "SELHRLST"
  If clalev ([F:HRLSTH])=0 : Local File HRLVESUBHEA [HRLSTH] : Endif
  Filter [F:HRLSTH]
  OBJET     = "HRLST"
  If GFONCTION= "GESHRTRF"
    If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
    If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
    If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
    If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
    If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
    If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
    If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
    If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
    If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
    If clalev ([HRACCR]) = 0   : Local File HRLVEACCRU [HRACCR] Endif
    If clalev ([HRACCR1]) = 0   : Local File HRLVEACCRU [HRACCR1] Endif
    If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
    If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif
    If clalev([F:DCG])=0 : Local File DEMCONGE   [DCG] : Endif
    If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
    If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
    If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif

    Local Integer S, L
    Local Char CRITACC1(250),CRITACC2(250)
    Local Integer CRITCOUNT
    #Local Char CRITACC(250)
    Global Char LIS_HRLST(GLONHRLST)(0..100)
    Filter [TIM] Where ([TIM]LVEENHANCE=2 & ([TIM]CATTIM=3 |[TIM]CATTIM=2))  and [TIM]ENAFLG=2
#Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
    For [TIM]
      For S=1 To dim([TIM]LVESUBTYP)
        CRITACC1 = "1=0"
        CRITACC2 = "1=0"
        If [TIM]LVESUBTYP(S-1) <> ""
          CRITCOUNT=1
          #CRITACC = "1=0"
          For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1)
           If len(CRITACC1)>=200 : CRITCOUNT=2 : Endif
           If CRITCOUNT=1
            Case [HRLSTD]LEV
              When 1  : CRITACC = CRITACC - " | 1=1"  #Folder
              When 2  : CRITACC = CRITACC - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC = CRITACC - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC = CRITACC - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC = CRITACC - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC = CRITACC - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC = CRITACC - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC = CRITACC - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC = CRITACC - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC = CRITACC - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
            Else
              Case [HRLSTD]LEV
                When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
                When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Endif
       Next

If [HRLSTD]LEV=3
           Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&          As [LNK]
&             Where evalue(CRITACC1) or evalue(CRITACC2)
#&          Where evalue(CRITACC)

Else
           Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
& As [LNK]
&             Where evalue(CRITACC1) or evalue(CRITACC2)
#&          Where evalue(CRITACC)

Endif

Filter [LNK] Where CTRNUM=PARAM(1)
If rowcount([LNK])>0 & !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
Filter [LNK]
            Endif
        Next
      Next
Filter [TIM]
[L]CRITERE(1) = "find(COD,LIS_HRLST)>0"
#MIPEA - 2017-08-09- US X3-39538- START
#Selection of sub types linked to TIMCOD selected on screen only for current LEG
    Elsif GFONCTION="GESVRA"
      If clalev([TIM]) = 0         : Local File TIMCOD [TIM] Endif
      If clalev([HRLSTH]) = 0      : Local File HRLVESUBDET [HRLSTH] Endif

      Local Integer S, L
      Global Char LIS_HRLST(GLONHRLST)(0..100)
      Filter [TIM] Where [TIM]COD = [M:VRA1]TIMCOD & LEG=GCURLEG

      For [TIM]
        For S=1 To dim([TIM]LVESUBTYP)
          If [TIM]LVESUBTYP(S-1) <> ""
            Read [HRLSTH]HRLST0 = GCURLEG;[TIM]LVESUBTYP(S-1)
            If [HRLSTH]LVEPAYDES(0)<>""
              If !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
            Endif
          Endif
        Next
      Next
Filter [TIM]
[L]CRITERE(1) = "find(COD,LIS_HRLST)>0"
#MIPEA - 2017-08-09- US X3-39538- END
    Else
      If GCURLEG<>""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRLSTH]LEG="'+GCURLEG+'" | [F:HRLSTH]LEG="")',"&") From GOBJSUB
      Endif
  Endif
Endcase
Return

