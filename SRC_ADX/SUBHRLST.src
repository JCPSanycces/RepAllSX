Local Char CTR (GLONHRCTR)
MATRI=VALEUR : Raz SITSOC,CTR

#LIPET - 2017-08-21 - X3-53396 - START
If [M]LEV(nolign-1)=10
 Call UNICITE(VALEUR,[M]PRFCOD(0..[M]HRLSTNR-1)) From OBJDIV
If mkstat=2 : End : Endif
Endif
#LIPET - 2017-08-21 - X3-53396 - END

If [M]LEV(nolign-1)=10
 If VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
 SITSOC=VALEUR : Raz MATRI,CTR
 Endif
End

Subprog AM_PRFCOD(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_CLLCVT(VALEUR)
Variable Char    VALEUR()
  If [M]LEV(nolign-1)<>9 : mkstat=1 : End : Endif
End

Subprog C_CLLCVT(VALEUR)
Variable Char    VALEUR()
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)

  #LIPET - 2017-08-21 - X3-53396 - START
  If [M:HRLST1]LEV(nolign-1)=9
   Call UNICITE(VALEUR,[M]CLLCVT(0..[M]HRLSTNR-1)) From OBJDIV
  If mkstat=2 : End : Endif
  Endif
  #LIPET - 2017-08-21 - X3-53396 - END

  MATRI=VALEUR : Raz SITSOC,CTR
  If [M]LEV(nolign-1)=9
   If VALEUR=""
    #Zone obligatoire
    GMESSAGE=mess(10,123,1)
    mkstat=2 : End
   Endif
   SITSOC=VALEUR : Raz MATRI,CTR
   Endif
  End

  Subprog AM_CLLCVT(VALEUR)
  Variable Char    VALEUR()
End


