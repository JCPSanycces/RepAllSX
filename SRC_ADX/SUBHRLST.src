#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE

Call OBJET("HRLST",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "STYLE"     : Gosub STYLE
 When "FERME"     : Gosub FERME
 When "INIMOD"    : Gosub INIMOD
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "CREATION"  : Gosub CREATION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "VERF_ANU"  : Gosub VERF_ANU #ADNGO - 2017-08-08 - X3-51921
Endcase
Return

$OUVRE

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If clalev ([F:HRLSTH])=0 : Local File HRLVESUBHEA [HRLSTH] : Endif
If clalev ([F:HRLSTD])=0 : Local File HRLVESUBDET [HRLSTD] : Endif
If clalev ([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
If clalev ([F:HRACCR1])=0 : Local File HRLVEACCRU [HRACCR1] : Endif
  Call MANAGE_LOCALISATION("OHRLST") From DIVPAYE

Return

$LIENS

If [M]LEG<>""
  GCURLEG=[M]LEG
Endif

nolign=0
Local Integer PAYOUTROWS: PAYOUTROWS = 0
Local Integer PAYOUTDEFAULTROWS: PAYOUTDEFAULTROWS = 0

For [F:HRLSTD] Where COD = [M:HRLST0]COD and LEG = [M:HRLST0]LEG

 [M:HRLST1]LEV(nolign)     = [F:HRLSTD]LEV
 [M:HRLST1]POP(nolign)     = [F:HRLSTD]POP
 [M:HRLST1]REFNUM(nolign)  = [F:HRLSTD]REFNUM
 [M:HRLST1]SERVICE(nolign) = [F:HRLSTD]SERVICE
 [M:HRLST1]PRFCOD(nolign)  = [F:HRLSTD]PRFCOD
 [M:HRLST1]CTRNUM(nolign)  = [F:HRLSTD]CTRNUM
 [M:HRLST1]CLLCVT(nolign)  = [F:HRLSTD]CLLCVT
 #MIPEA - 2018-05-18-  X3-86553- START
 If [M:HRLST1]LEV(nolign) = 2
  [M:HRLST1]LEGCOD(nolign)  = [F:HRLSTD]LEGCOD
 Endif
# [M:HRLST1]LEGCOD(nolign)  = [F:HRLSTD]LEGCOD
 #MIPEA - 2018-05-18-  X3-86553- END
 [M:HRLST1]CPY(nolign)     = [F:HRLSTD]CPY
 [M:HRLST1]FCY(nolign)     = [F:HRLSTD]FCY
 #SAVAN - 2018/04/24 - X3-86552 - start
 [M:HRLST1]CTRDAT(nolign)     = [F:HRLSTD]CTRDAT
 #SAVAN - 2018/04/24 - X3-86552 - end
 nolign += 1
Next

[M:HRLST1]HRLSTNR = nolign

For [F:HRLSTH] Where COD = [M:HRLST0]COD and LEG = [M:HRLST0]LEG
  For nolign = 0 To dim([F:HRLSTH]LVEPAYDES)-1
    If [F:HRLSTH]LVEPAYDES(PAYOUTROWS) <> ""
      PAYOUTROWS += 1
    Endif
  Next
Next

[M:HRLST2]LVEPAYNR = PAYOUTROWS

Affzo [M:HRLST1]
Affzo [M:HRLST2]

Gosub STYLE

Call LECTEXTRA([M]DES,"HRLVESUBHEA","DES",GCURLEG,[M:HRLST0]COD) From ATEXTRA
Call LECTEXTRA([M]SHO,"HRLVESUBHEA","SHO",GCURLEG,[M:HRLST0]COD) From ATEXTRA

#LIPET - X3-57780 -2017-09-28 - START
  Local Integer FOUND : FOUND = 0
  Local Integer S,L

    If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
    If clalev([F:HRCTR5])=0  : Local File EMPLOCTR [HRCTR5]  : Endif
    If clalev([F:FCY3])=0  : Local File FACILITY [FCY3]  : Endif
    If clalev([F:FCY5])=0  : Local File FACILITY [FCY5]  : Endif
    If clalev([F:DCG3])=0  : Local File DEMCONGE [DCG3]  : Endif

    Link [F:HRACCR1] With
&   [F:HRCTR3]CTR0(1)=[F:HRACCR1]CTR,
&   [F:FCY3]FCY0=[F:HRCTR3]ETRFCY
&    As [LNK] Where [HRACCR1]LVEACCLST = [M:HRLST0]COD# and [F:FCY3]LEG = [M:HRLST0]LEG

#Read [LNK] First
#    Infbox num$([LNK]LVEACCLST)-num$(rowcount([LNK]))
#
#    For [LNK]
#        If [LNK]LVEACCTYP = "Accrual" Then
#          FOUND = 1 : Break
#        Endif
#    Next

  For [LNK]
     Filter  [HRCTR5] Where CTRNUM=[LNK]CTR
     Read [HRCTR5] Last
     Filter [HRCTR5]
     Read [FCY5]FCY0 = [F:HRCTR5]ETRFCY
     If fstat=0 Then
      If [F:FCY5]LEG = GCURLEG & [LNK]LVEACCTYP = "Accrual" Then
         FOUND = 1 : Break
      Endif
     Endif
  Filter [F:FCY5]
  Next
  Filter [F:HRACCR1]
  Filter [F:FCY3]
  Filter [F:HRCTR3]

  If FOUND = 0 Then
    Link [F:DCG3] With
&   [HRCTR3]CTR0(2)=[DCG3]REFNUM;[DCG3]CTRNUM,
&   [FCY3]FCY0=[F:HRCTR3]ETRFCY
&    As [LNK1] Where [FCY3]LEG = GCURLEG  Order By [DCG3]TIM

  For  [LNK1]
      Filter [TIM] Where COD = [LNK1]TIM & LEG = GCURLEG
      Read [TIM] First
      Filter [TIM]
      If fstat = 0 Then
        For L=1 To dim([TIM]LVESUBTYP)
          If [TIM]LVESUBTYP(L-1) <> "" Then
            If [TIM]LVESUBTYP(L-1) = [M:HRLST0]COD Then
             FOUND = 1 : Break
            Endif
          Endif
        Next
      Endif
    Next
  Endif

  If FOUND = 1 Then
    Grizo [M:HRLST2]5-40
   Else
    Actzo [M:HRLST2]5-40
  Endif
#LIPET - X3-57780 - 2017-09-28 - END
Return

$MODIF

Gosub TEXTRA
If GOK<1 : Return : Endif
Return
#ADNGO - X3PEOP-1240 - 26-10-2016 - END

#ADNGO - X3PEOP-1240 - 11-10-2016 - START
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  #ADNGO - X3PEOP-1240 - 09-02-2017 - START
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONNAT) : Endif
  #ADNGO - X3PEOP-1240 - 09-02-2017 - START
  VCOD = CLE1
Return

$STYLE
Gosub DISPLAY_HIDE From SUBHRLSTLEG
Return

$TEXTRA
If GREP="D"

 Call DUPTEXTRA("HRLVESUBHEA","DES",CLECUR1,"","HRLVESUBHEA","DES",GCURLEG,[F:HRLSTH]COD)  From ATEXTRA
 Call DUPTEXTRA("HRLVESUBHEA","SHO",CLECUR1,"","HRLVESUBHEA","SHO",GCURLEG,[F:HRLSTH]COD)  From ATEXTRA
Endif

Call MAJTEXTRA([M]DES,"HRLVESUBHEA","DES",GCURLEG,[F:HRLSTH]COD) From ATEXTRA
Call MAJTEXTRA([M]SHO,"HRLVESUBHEA","SHO",GCURLEG,[F:HRLSTH]COD) From ATEXTRA

Return
#ADNGO - 2017-08-08 - X3-51921 - START
$VERF_ANU
   If [M]HRLSTNR > 0
    GERR=1
    GMESSAGE = mess(18,11691,1)
    GOK=0
    FIN=0
    Return
 Endif
Return
#ADNGO - 2017-08-08 - X3-51921 - END
######################################################################################
#To delete translated texts(data type AX3)
$ANNULE

 Call SUPTEXTRA("HRLVESUBHEA","DES",[L]CODE,SUPP) From ATEXTRA
 Call SUPTEXTRA("HRLVESUBHEA","SHO",[L]CODE,SUPP) From ATEXTRA
Return

######################################################################################

$CREATION
$INIMOD
  # Check to see if a default pay-out rate has been selected
  Local Integer DEFAULTVALUEEXISTS: DEFAULTVALUEEXISTS = 0
  Local Integer ROWSEXISTS: ROWSEXISTS = 0
  For nolign = 1 To dim([M:HRLST2]LVEPAYDEF)
    If [M:HRLST2]LVEPAYDES(nolign - 1) <> ""
      ROWSEXISTS = 1
      If [M:HRLST2]LVEPAYDEF(nolign - 1) = 2
        DEFAULTVALUEEXISTS += 1
      Endif
    Endif
  Next
  If ROWSEXISTS = 1 & DEFAULTVALUEEXISTS = 0
    GOK = 0
    GMESSAGE = mess(19,11691,1)
    Return
  Elsif ROWSEXISTS = 1 & DEFAULTVALUEEXISTS > 1
    GOK = 0
    GMESSAGE = mess(20,11691,1)
    Return
  Endif

## PEVAN 2017-08-24 X3-53691 START
  If ([M:HRLST2]LVECARFWD <> "" and [M:HRLST2]LVECARFWD <> "0") and [M:HRLST2]LVECARSUB = ""
    GOK = 0
    GMESSAGE = mess(21,11691,1)
    Return
  Endif
## PEVAN 2017-08-24 X3-53691 END

  Gosub TEXTRA
  If GOK<1 : Return : Endif

  Gosub SAUVE_ECRAN

Return
######################################################################################
#$VERF_ANU
#Filter [TIM] Where LVESUBTYP=[M]COD and LEG=[M]LEG
#Read [TIM]
#Filter [TIM]
#If !fstat
# GMESSAGE = "This leave sub type is linked"
# GOK=0
#Endif
#Return
######################################################################################
$SAUVE_ECRAN
#If clalev([F:HRLST])=0 : Local File HRLVESUBTYP [HRLST] : Endif
Delete [F:HRLSTD] Where COD=[M]COD & LEG=[M]LEG
If fstat=1
 GOK =-1 : GLOCK = "$HRLVESUBDET" : Return
Endif
For nolign=1 To [M]HRLSTNR

 [F:HRLSTD]COD        = [M]COD
 [F:HRLSTD]LEG        = [M]LEG
 [F:HRLSTD]LEV        = [M]LEV(nolign-1)
 [F:HRLSTD]POP        = [M]POP(nolign-1)
 [F:HRLSTD]REFNUM     = [M]REFNUM(nolign-1)
 [F:HRLSTD]SERVICE    = [M]SERVICE(nolign-1)
 [F:HRLSTD]PRFCOD     = [M]PRFCOD(nolign-1)
 [F:HRLSTD]CPY        = [M]CPY(nolign-1)
 [F:HRLSTD]FCY        = [M]FCY(nolign-1)
 [F:HRLSTD]CTRNUM     = [M]CTRNUM(nolign-1)
 [F:HRLSTD]CLLCVT     = [M]CLLCVT(nolign-1)
 [F:HRLSTD]LEGCOD     = [M]LEGCOD(nolign-1)
  #SAVAN - 2018/04/24 - X3-86552 - start
 [F:HRLSTD]CTRDAT     = [M]CTRDAT(nolign-1)
 #SAVAN - 2018/04/24 - X3-86552 - end
#SAVAN - 2017-03-10 - X3PEOP-858 - START

 Write [HRLSTD]
 If fstat<>0
  GOK = 0 : Call FSTA("HRLSTD") From GLOCK
 Endif
Next
#SAVAN - 2018/04/26 - X3-86552 - start
#Gosub LINKING_ACCRUALS From SUBACCRUAL
Call LINKING_ACCRUALS_PROG("",[F:HRLSTD]COD,"","",[0/0/0],2,0) From SUBACCRUAL
#SAVAN - 2018/04/26 - X3-86552 - start
Return

