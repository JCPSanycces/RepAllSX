## Section automatically added (screen HRLST1) 03/13/2017 10:09:41 (SAVAN)
######################################################################################
Subprog AM_LEV(VALEUR)
Variable Integer VALEUR

  #LIPET - 2017-08-21 - X3-53396 - START
  For X=0 To HRLSTNR-1
    If VALEUR=2 and [M]LEGCOD(X) <> ""
      Call UNICITE([M]LEGCOD(X),[M]LEGCOD(0..[M]HRLSTNR-1)) From OBJDIV
    If mkstat=2 : End : Endif
    Endif

  Next
  #LIPET - 2017-08-21 - X3-53396 - END

  #LIPET - 2017-07-31 - X3-50678 - START
  If VALEUR=2  :  [M]LEGCOD(nolign-1)=GCURLEG : Affzo [M]LEGCOD(nolign-1) : Endif
  #LIPET - 2017-07-31 - X3-50678 - END

End


