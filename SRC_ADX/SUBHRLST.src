Subprog C_LEV(VALEUR)
Variable Integer VALEUR
  # pas 2 fois la valeur dossier...
  If VALEUR=1
   Call UNICITE(VALEUR,[M]LEV(0..[M]HRLSTNR-1)) From OBJDIV
   If mkstat=2 : End : Endif
  Endif

  #LIPET - 2017-08-02 - X3-51611 - START
  If VALEUR <> 2 : Effzo [M]LEGCOD(nolign-1) : Endif
  #LIPET - 2017-08-02 - X3-51611 - END
End


