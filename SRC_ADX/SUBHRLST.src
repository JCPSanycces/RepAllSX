Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
  If VALEUR>'' and [M:HRLST1]CTRDAT(nolign-1) = [0/0/0]
    If !clalev([F:HRCTR]) : Local File EMPLOCTR [F:HRCTR] : Endif
    Columns [F:HRCTR] (CTRDAT)
    Filter [F:HRCTR] Where [F:HRCTR]CTRNUM = VALEUR and ([F:HRCTR]XITDAT = [0/0/0] or [F:HRCTR]XITDAT >= date$)
    Read [F:HRCTR] Last
    If !fstat
      [M:HRLST1]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT
    Endif
    Columns [F:HRCTR]
  Endif
End

