########################################
Subprog C_PRFCOD(VALEUR)
Variable Char    VALEUR()

Call LECTURE("AFT",VALEUR,"") From CONTOBJ
If [F:AFT]ALLFCT = 2
 GMESSAGE = mess(36,130,1) : # Ce profil a déjà toutes les autorisations
 mkstat = 2
Endif

If GPROFIL="ADMCA" and VALEUR="ADMCA"
 GMESSAGE = mess(8,123,1) : # ACCÈS IMPOSSIBLE À CETTE FICHE
 mkstat =2  : End
Endif
End

########################################
Subprog AM_FNC(VALEUR)
Variable Char    VALEUR()
Local Char    OPT(23)
Local Integer J

Read [F:AFC]CODINT = VALEUR
If [F:AFC]FCYAUZ <> 2
   [M]NBAFP = 1
   [M]FCYGRUCOD = 0
   [M]FCYGRU = ""
Endif

# recherche d'options
[L]OPT=""
If [F:AFC]TYP=2
 [L]OPT = "CMS"
 If func OPT(VALEUR) : [L]OPT += "N" : Endif
Endif
For J = 0 To [F:AFC]NBOPT-1
     [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
Next J
# tri des options
Call TRI([L]OPT) From SUBAFP2
For I = 0 To NBAFP-1
    If [M:AFP0]ACS(I) = 2 : [M:AFP0]OPT(I) = [L]OPT : Endif
Next

If NBAFP = 0
    [M:AFP0]ACS(0) = 2
    [M:AFP0]OPT(0) = [L]OPT
Endif
Affzo [M:AFP0]5

End

########################################
Subprog C_FNC(VALEUR)
Variable Char    VALEUR()

Read [F:AFC]CODINT = VALEUR
If [F:AFC]TYPTRAIT = 2                              # type de traitement MENU à exclure
   GMESSAGE = mess(74,100,1)                        # fonction non autorisée
   mkstat = 2
   End
Endif

# Issue X3-74666 - 2018-01-31 by CCC : Don't allow to create profile with higher rights than current profile

# Check if the function is authorized for current profile. If not => error
If func SUBAFP.IS_FUNCTION_AVAILABLE_FOR_PROFILE(GPROFIL,VALEUR)<>[V]CST_AYES
    GMESSAGE = mess(74,100,1)                        # fonction non autorisée
    mkstat = 2
    End
Endif

End

#######################################
Subprog AV_MODULE(VALEUR)
Variable Char    VALEUR()                     # affichage du module de la fonction sélectionnée

If [M:AFP0]FNC <> ""
Call LECTURE("AFC",[M:AFP0]FNC,"") From CONTOBJ
#Read [AST]CLE = 14;[F:AFC]MODULE;"FRA"
If fstat = 0 : VALEUR = mess([F:AFC]MODULE,14,1) : Endif
Endif

End

########################################
Subprog AS_FCYGRUCOD(VALEUR)
Variable Integer VALEUR

Read [F:AFC]CODINT = [M]FNC
If [F:AFC]FCYAUZ <> 2   : mkstat = 1 : Endif       # Autorisation de site négative

End

########################################
Subprog IB_FCYGRU
If [M]FCYGRUCOD(nolign-1) = 1
    GBOUT1 = mess(68,104,1)    # Regroupement
    GBIDC1 = "AGF"
Else
    GBOUT1 = mess(7,47,1)       # Site
    GBIDC1 = "FCY"
Endif
End

Subprog AS_FCYGRU(VALEUR)
Variable Char    VALEUR()
Read [F:AFC]CODINT = [M]FNC
If [F:AFC]FCYAUZ <> 2   : mkstat = 1 : Endif       # Autorisation de site négative
End

########################################
Subprog C_FCYGRU(VALEUR)
Variable Char  VALEUR()                        # controle d'unicité & d'existence
Local Integer I
Call UNICITE(VALEUR, [M]FCYGRU(0..[M]NBAFP-1)) From OBJDIV
If mkstat : End : Endif

If [M]FCYGRUCOD(nolign-1) <> 2
  If VALEUR <> "" : Call CONTROLE("AGF","",VALEUR,"",mkstat) From CONTOBJ : Endif
Else
    Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
Endif
If mkstat : End :Endif
End

########################################
Subprog AM_ACS(VALEUR)
Variable Integer VALEUR
Local Char OPT(23)

# recherche d'options
[L]OPT = ""
If VALEUR = 2
    Read [F:AFC]CODINT = [M:AFP0]FNC
    If [F:AFC]TYP=2
     [L]OPT = "CMS"
     If func OPT([M:AFP0]FNC)
      [L]OPT += "N"
     Endif
    Endif
    For J = 0 To [F:AFC]NBOPT-1
        [L]OPT = [L]OPT  + [F:AFC]FLAG(J)
    Next J
Endif

# tri des options
Call TRI([L]OPT) From SUBAFP2
[M:AFP0]OPT(nolign-1) = [L]OPT

End

########################################
Subprog AS_OPT(VALEUR)
Variable Char VALEUR()
Local Integer J

Read [F:AFC]CODINT = [M:AFP0]FNC
If [M:AFP0]ACS(nolign-1) <> 2 or ([F:AFC]FLAG(0)= "" and [F:AFC]TYP <> 2)
    mkstat = 1
Endif

End

########################################
Subprog C_OPT(VALEUR)
Variable Char VALEUR()
Local Integer I , OPTENA

##controle de doublons
For I=1 To len(VALEUR)
    For J=I+1 To len(VALEUR)
        If mid$(VALEUR,I,1) = mid$(VALEUR,J,1)
            GMESSAGE = mid$(VALEUR,I,1)-" : "-mess(69,104,1)      # doublon
            mkstat = 2
            Break 2
        Endif
    Next J
Next I
If mkstat : End : Endif

##controle de l'existence des options
Read [F:AFC]CODINT = [M]FNC
Call OPTENA([F:AFC]CODINT,OPTENA)

#différence selon le "type accés objet"
If [F:AFC]TYP = 2
    For I = 1 To len(VALEUR)
      If !find(mid$(VALEUR,I,1),[F:AFC]FLAG(0..[F:AFC]NBOPT-1),"C","M","S") & (!OPTENA or (OPTENA & mid$(VALEUR,I,1)<>"N"))
         GMESSAGE = mid$(VALEUR,I,1)-" : "-mess(99,123,1)      # option incorrecte
         mkstat = 2
         Break
      Endif
    Next I
Else
    For I = 1 To len(VALEUR)
      If !find(mid$(VALEUR,I,1),[AFC]FLAG(0..[F:AFC]NBOPT-1))
         GMESSAGE = mid$(VALEUR,I,1)-" : "-mess(99,123,1)      # option incorrecte
         mkstat = 2
         Break
      Endif
    Next I
Endif
If mkstat : End : Endif

# Issue X3-74666 - 2018-01-31 by CCC : Don't allow to create profile with higher rights than current profile
If GPROFIL<>GSUPER
    If [F:AFC]FCYAUZ <> [V]CST_AYES : # For functions without site authorization
        # Can't add option not in current profile
        Read [AFP3]AFP0=GPROFIL;[M:AFP0]FNC;[M:AFP0]FCYGRU(nolign-1)
        If fstat=[V]CST_AOK
            For I = 1 To len(VALEUR)
                If !instr(1,[F:AFP3]OPT,mid$(VALEUR,I,1))
                    GMESSAGE = mid$(VALEUR,I,1)-" : "-mess(99,123,1)      # option incorrecte
                    mkstat = 2
                    Break
                Endif
            Next
        Else
            GMESSAGE = mess(74,100,1)                        # fonction non autorisée
            mkstat = 2
        Endif
    Else
        # if the function is managed by site, no control
    Endif
Endif
If mkstat : End : Endif


##trie des options
Call TRI(VALEUR) From SUBAFP2
[M:AFP0]OPT(nolign-1) = VALEUR : Affzo [M:AFP0]OPT(nolign-1)

End

Funprog OPT(FONCTION)
Value Char    FONCTION
Local Integer OPTENA
Call OPTENA(FONCTION,OPTENA)
End OPTENA

Subprog OPTENA(FONCTION,OPTENA)
Value Char FONCTION
Variable Integer OPTENA
Local Integer ER
Local Char OBJET(GLONAOB)
OPTENA = 0
Local File AFONCTION [AFCS]
Read [AFCS]CODINT = FONCTION
If !fstat & [F:AFCS]ACTION="GOBJET"
 Onerrgo ER
 OBJET = evalue([F:AFCS]VALPAR(0))
 Onerrgo
 If !ER & OBJET<>""
  If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
  Read [AOB]ABREV=OBJET
  If !fstat & [F:AOB]NOMFIC<>""
   If filinfo(filpath("FIL",[F:AOB]NOMFIC,"fde"),0)>0
    Local File =[F:AOB]NOMFIC [AA__]
    OPTENA = (dim([F:AA__]ENAFLG)>0)
    Close Local File [AA__]
   Endif
  Endif
 Endif
Endif
End

$ER
ER = errn
Resume

########################################
Subprog C_NBAFP

#If status>=65 & status<=90
#ON reste dans le tableau
#Elsif status<>7 & status<1792
# 7,1792 --> abandon,fin
# 73 --> insertion d'une ligne dans le tableau

Read [F:AFC]CODINT = [M]FNC
If [F:AFC]FCYAUZ <> 2
 If nolign>1 & (status>=65 & status<=90)
  mkstat = 2
 Endif
# If nolign>1 & (status>=65 & status<=90) & status<>7 & status<1792 : mkstat = 2
# Elsif status=73 & [M]NBAFP=1 : mkstat = 2
# Endif
Endif

End

