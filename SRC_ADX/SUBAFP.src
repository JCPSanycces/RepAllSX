################################################################################
Subprog AV_DELTYP(VALEUR)
Variable Integer VALEUR
Gosub GRISE_TYP
End

Subprog AM_DELTYP(VALEUR)
Variable Integer VALEUR
[M]DELTYP = VALEUR : Gosub GRISE_TYP
End

$GRISE_TYP
If [M]DELTYP<>3
 [M]MODULE = 0
 Affzo MODULE
 Grizo MODULE
Else
 Actzo MODULE
Endif
Return


################################################################################
#######    ECRAN AFP3     ######################################################
################################################################################
################################################################################
########################################
Subprog C_PRFCOD3(VALEUR)
Variable Char    VALEUR()

Call LECTURE("AFT",VALEUR,"") From CONTOBJ
If mkstat : End : Endif
If [F:AFT]ALLFCT = 2 or [M:AFP0]PRFCOD = VALEUR
 GMESSAGE = mess(206,139,1) : # Profil fonction incorrect
 mkstat = 2 : End
Endif
End


########################################
Subprog B3_OPT(VALEUR)
Variable Char    VALEUR()

Local Integer J , OPTENA
Local Char    LIBEL(50), MESSAGE(250)
Raz MESSAGE

If clalev([F:FCT])=0 : Local File AFONCTION [AFC] : Endif

Read [F:AFC]CODINT = [M:AFP0]FNC
If [F:AFC]TYP = 2
    MESSAGE   = "C : "-mess(59,123,1)-"\"
    MESSAGE  += "M : "-mess(3,85,1)-"\"
    If func OPT([M:AFP0]FNC)
     MESSAGE  += "N : "-mess(117,75,1)-"\"
    Endif
    MESSAGE  += "S : "-mess(2,24,1)-"\"
Endif
For J = 0 To ([F:AFC]NBOPT-1)
    Call TEXTE([F:AFC]OPTION(J),LIBEL) From OBJDIV
    If len(MESSAGE)+len([F:AFC]FLAG(J)-" : "-LIBEL-"\")>250
     MESSAGE += "..." : Break
    Else
     MESSAGE += [F:AFC]FLAG(J)-" : "-LIBEL-"\"
    Endif
Next
Call MESSAGE(MESSAGE) From GESECRAN
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AFP0) 09/12/2016 08:08:44 (ADMIN)
######################################################################################
Subprog AM_PRFCOD(VALEUR)
Variable Char    VALEUR()
If GPROFIL<>GSUPER & GADONIX<>2 and VALEUR="ADMCA"
 GMESSAGE = mess(8,123,1) : # ACCÈS IMPOSSIBLE À CETTE FICHE
 mkstat =2  : End
Endif
End

#**
#* Indicates if a function is available for a profile
#*
#* @param PPROFIL : Profile code
#* @param PFNC    : Function code
#* @return  [V]CST_AYES if the function is available otherwise [V]CST_ANO
#*!
Funprog IS_FUNCTION_AVAILABLE_FOR_PROFILE(PPROFIL,PFNC)
Value Char PPROFIL
Value Char PFNC

Local Integer LRES
LRES = [V]CST_AYES
If GPROFIL<>GSUPER
    Local File AFCTPRF [AFP]
    Filter [AFP] Where PRFCOD=[L]PPROFIL
&                    & FNC=[L]PFNC
&                    & ACS=[V]CST_AYES
    Look [AFP]AFP0 First
    Filter [AFP]
    If fstat
       LRES = [V]CST_ANO
    Endif
    LogicClose File [AFP]
Endif
End LRES

#**
#* To get options of a function linked to a profile
#*
#* @param PPROFIL : profile code
#* @param PFNC    : function code
#* @param POPT    : list of options corresponding to profile/function<br>
#* For function with site authorizations or Admin profile, returns all possible options defined in the function
#* @return [V]CST_AYES if the function is available for the current profile
#*!
Funprog GET_FUNCTION_OPTIONS_FOR_PROFILE(PPROFIL,PFNC,POPT)
Value Char PPROFIL
Value Char PFNC
Variable Char POPT

Local Integer J, LRES

[L]POPT = ""
[L]LRES = [V]CST_AYES

Local File AFONCTION [AFC]
Local File AFCTPRF [AFP]

Read [F:AFC]CODINT = [L]PFNC

# check if the function is available for current profile
If GPROFIL<>GSUPER
    Filter [AFP] Where PRFCOD=[L]PPROFIL
&                    & FNC=[L]PFNC
&                    & ACS=[V]CST_AYES
    Read [AFP]AFP0 First
    Filter [AFP]
    If fstat
       LRES = [V]CST_ANO
    Endif
Endif

If [F:AFC]FCYAUZ<>2 & GPROFIL<>GSUPER
    # If authorization of the function doesn't depend on sites
    # get options of current profile
    If [L]LRES = [V]CST_AYES
        [L]POPT = [F:AFP]OPT
    Endif
Else
    # get all options of the function
    If [F:AFC]TYP = 2
     [L]POPT="CMS"
     If func SUBAFP.OPT([F:AFC]CODINT)
      [L]POPT += "N"
     Endif
    Endif
    For J = 0 To min([F:AFC]NBOPT-1,dim([F:AFC]FLAG)-1)
        [L]POPT = [L]POPT  + [F:AFC]FLAG(J)
    Next J
Endif

LogicClose File [AFC]
LogicClose File [AFP]

End [L]LRES

#**
#* Get common options of 2
#*
#* @param POPT1 : list of options
#* @param POPT2 : list of options
#* @return a string with common caracters of POPT1 and POPT2<br>
#* ex: POPT1="ABCD" & POPT2="BDE" --> "BD"
#*!
Funprog MATCH_OPTIONS(POPT1, POPT2)
Value Char POPT1
Value Char POPT2

Local Integer I
Local Char LOPT(min(len([L]POPT1),len([L]POPT2))+1)

For I=1 To len([L]POPT1)
    If instr(1,[L]POPT2,mid$([L]POPT1,I,1))
        [L]LOPT += mid$([L]POPT1,I,1)
    Endif
Next

End [L]LOPT

