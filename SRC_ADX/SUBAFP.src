#<AdxTL>@(#)0.0.0.0 $Revision$ Habilitations fonctionnelles
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AFP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "MODIF"       : Gosub MODIF
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "FILTRE"      : Gosub FILTRE
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
Endcase
Return

$INIT
Case GACTION
 When "AFPFUS"    : Gosub INIT_FUS
 When "AFPANU"    : Gosub INIT_SUPP
 When "AFPRAPPEL" : Gosub INIT_RAPPEL
Endcase
Return

$INIT_DIA
Case GACTION
 When "AFPFUS" : Gosub INIT_DIA_FUS
Endcase
Return

$EXEC
Case GACTION
 When "AFPFUS"    : Gosub EXEC_FUS
 When "AFPANU"    : Gosub EXEC_SUPP
 When "AFPCHRGT"  : Gosub EXEC_CHRGT
 When "AFPRAPPEL" : Gosub EXEC_RAPPEL
Endcase
Return

$SORTIE
Case GACTION
 When "AFPANU" : Gosub SORTIE_SUPP
Endcase
Return

$OUVRE
Gosub OUVFIC
Local Char PROFIL(GLONAFT)
If TUNNEL & SAVCLE1<>""
 PROFIL = SAVCLE1
Endif
Return

$OUVFIC
If clalev([F:AFP3])=0 : Local File AFCTPRF   [AFP3] : Endif  # majaff
If clalev([F:AFP4])=0 : Local File AFCTPRF   [AFP4] : Endif  # suppression
If clalev([F:AFF])=0  : Local File AFCTFCY   [AFF]  : Endif
If clalev([F:AFC])=0  : Local File AFONCTION [AFC]  : Endif
If clalev([F:AFC2])=0 : Local File AFONCTION [AFC2] : Endif
If clalev([F:AFT])=0  : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:FCYA])=0 : Local File FACILITY  [FCYA] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
If clalev([F:FGRA])=0 : Local File FACGROUP  [FGRA] : Endif
If clalev([F:FGRL])=0 : Local File FACGROUP  [FGRL] : Endif
If clalev([F:FGRM])=0 : Local File FACGROUP  [FGRM] : Endif
Return

$SETBOUT
If REP <> ""
 Call VIREBOUT(CHAINE,"B") From GOBJET
Else
 CHAINE += "A"
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"OUA") From GOBJET
 If !TUNNEL
  Call VIREBOUT(CHAINE,"B") From GOBJET
 Endif
Endif
If PROFIL<>""
 [M]PRFCOD = PROFIL
 Affzo PRFCOD
 Grizo PRFCOD
Endif
If GPROFIL<>GSUPER & GADONIX<>2 & [M]PRFCOD ="ADMCA"   # 120186
 Call VIREBOUT(CHAINE,"BOUCA") From GOBJET
Endif
Return

$FILTRE
If dim(TUNNEL)>0 & TUNNEL & SAVCLE1<>""
 FILTRE = 'PRFCOD="'+SAVCLE1+'"'
Endif
If GADONIX<>2 & GPROFIL="ADMCA"    # 120186
  # If FILTRE<>"" : FILTRE += " and " : Endif   # X3-55089 BODEL.so
  # FILTRE += 'PRFCOD<>"ADMCA"'                 # X3-55089 BODEL.so

  # X3-55089 BODEL.sn
  # Do not show ADMCA profile codes if we are the ADMCA user
  # Check to see if the filter is already populated.
  # If it has a value append to it, else set it.
  If FILTRE <> ""
    # Does filter already exist?
    If pat(FILTRE,'*PRFCOD<>"ADMCA"*') = 0
      FILTRE += ' and PRFCOD<>"ADMCA"'
    Else
      # Do nothing. Filter has a value, and it has our value, do not add it again
    Endif
  Else
    # Filter is blank, so set it
    FILTRE += 'PRFCOD<>"ADMCA"'
  Endif  #X3-55089 BODEL.en

Endif
Return

$MODIF
Local Char LOK
Local Integer K

## verification des options (utile si fonction est modifiée simultanément)
For K = 0 To ([M:AFP0]NBAFP-1)
    Call C_OPT([M:AFP0]OPT(K))
    If mkstat = 2
        GERR = 1 : GMESSAGE = mess(99,123,1)     # option incorrect
        OK = 0 : Return
    Endif
Next

## lock AFP
LOK = "AFP"+[M:AFP0]PRFCOD
Lock =LOK With lockwait=0
If fstat
  GERR = 1 : GMESSAGE = mess(10,100,1)
  OK = 0 : Return
Endif
Call MAJAFCTFCY("MAJ")
Unlock =LOK

Return

$APRES_CRE
$APRES_MOD
 If GACTX.APRFCOD=CLECUR2(0)
  If fmet GACTX.ACLEANRIGHT()>[V]CST_AWARNING
   Local Integer AI
   For AI=1 To maxtab(GACTX.AERROR)
    If GACTX.AERROR(AI)<>null & GACTX.AERROR(AI).STA>[V]CST_AWARNING
     GMESSAGE=GACTX.AERROR(AI).MES
     GERR=1
     Break
    Endif
   Next AI
  Endif
 Endif
 Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

###############################################################
# Vérification de la compatibilité des données                #
# selon les sites déjà saisis (nb sites = NBAFP, bas de page) #
###############################################################
$VERIF

For I = 0 To NBAFP-1         #  NBAFP = nb regpmt/profil&fct

    ## 1er element de la comparaison, un regroupement
    If [M]FCYGRUCOD(I) <> 2
        For [FGRM]FGR0 Where [FGRM]CPY = [M]FCYGRU(I)
            For J=I+1 To NBAFP-1
                ## 2ème element de la comparaison, un regroupement
                If [M]FCYGRUCOD(J) <> 2
                    For [FGRL]FGR0 Where [FGRL]CPY = [M]FCYGRU(J)
                        If [FGRM]FCY  = [FGRL]FCY and
&                         ([M]ACS(I) <> [M]ACS(J) or
&                          [M]OPT(I) <> [M]OPT(J))
                            GERR = 1 : GMESSAGE = [M]FCYGRU(I)-" & "-[M]FCYGRU(J)-":"-
&                                       mess(66,104,1)
                                        # sites incompatibles
                            OK = 0
                            Break 4
                        Endif
                    Next [FGRL]FGR0
                Else
                    ## 2ème element de la comparaison, un site
                    If [FGRM]FCY  = [M]FCYGRU(J) and
&                     ([M]ACS(I) <> [M]ACS(J) or
&                      [M]OPT(I) <> [M]OPT(J))
                        GERR = 1 : GMESSAGE = [M]FCYGRU(I)-" & "-[M]FCYGRU(J)-":"-
&                                    mess(66,104,1)
                                     # sites incompatibles
                        OK = 0
                        Break 3
                    Endif
                Endif
            Next J
        Next [FGRM]FGR0
    Else
        ## 1er element de la comparaison, un site
        For J=I+1 To NBAFP-1
            ## 2ème element de la comparaison, un regroupement
            If [M]FCYGRUCOD(J) <> 2
                For [FGRL]FGR0 Where [FGRL]CPY = [M]FCYGRU(J)
                    If [M]FCYGRU(I) = [FGRL]FCY and
&                     ([M]ACS(I)   <> [M]ACS(J) or
&                      [M]OPT(I)   <> [M]OPT(J))
                        GERR = 1 : GMESSAGE = [M]FCYGRU(I)-" & "-[M]FCYGRU(J)-":"-
&                                    mess(66,104,1)
                                     # sites incompatibles
                        OK = 0
                        Break 3
                    Endif
                Next [FGRL]FGR0
            Endif
        Next J
    Endif
Next I
Return

$INIT_SUPP
TMP = 1
Return

$EXEC_SUPP
Local Char    IDENT(GLONID)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16)
CLECUR1 = [M:AFP0]FNC
CLECUR2 = [M:AFP0]PRFCOD
Call IDENT3("AFP",[L]IDENT,CLECUR1,CLECUR2) From GOBJTXT
Call WRKGLOB(172,[L]IDENT,"AFCTPRF","") From GOBJACT
Call WORKFLOW(2,"AFP","A",[L]IDENT) From AWRK

$TR_SUPP
Trbegin [AFP4], [AFF]
   If [M:DIA]DELTYP=2 : # Profil fonction
       ##suppresion dans la table AFP
       Delete [AFP4] Where [F:AFP4]PRFCOD = [M:AFP0]PRFCOD
       If fstat = 1
          GOK = -1 : Call RSTA("AFP","") From GLOCK : Goto ROLL_SUPP
       Elsif fstat
          GOK = 0  : Call FSTA("AFP") From GLOCK : Goto AB_SUPP
       Endif
       ##suppresion dans la table AFF
       Delete [AFF] Where [F:AFF]PRFCOD = [M:AFP0]PRFCOD
       If fstat = 1
          GOK = -1 : Call RSTA("AFF","") From GLOCK : Goto ROLL_SUPP
       Elsif fstat
          GOK = 0  : Call FSTA("AFF") From GLOCK : Goto AB_SUPP
       Endif

   Elsif [M:DIA]DELTYP=3 : # Module
       Filter [F:AFC2] Where MODULE=[F:AFC]MODULE
       For [AFC2]MODULE
           ##suppresion dans la table AFP
           Delete [AFP4] Where [F:AFP4]PRFCOD = [M:AFP0]PRFCOD
&                          and [F:AFP4]FNC    = [F:AFC2]CODINT
           If fstat = 1
              GOK = -1 : Call RSTA("AFP","") From GLOCK : Break
           Elsif fstat
              GOK = 0  : Call FSTA("AFP") From GLOCK : Break
           Endif
           ##suppresion dans la table AFF
           Delete [AFF] Where [F:AFF]PRFCOD = [M:AFP0]PRFCOD
&                         and [F:AFF]FNC   = [F:AFC2]CODINT             # Bug 11842 (CP : 04/12/01)
           If fstat = 1
              GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
           Elsif fstat
              GOK = 0  : Call FSTA("AFF") From GLOCK : Break
           Endif
       Next
       Filter [F:AFC2]

       If GOK<0 : Goto ROLL_SUPP
       Elsif GOK<1 : Goto AB_SUPP : Endif

   Elsif [M:DIA]DELTYP=1 : # Focntion
       ##suppresion dans la table AFP
       Delete [AFP4] Where [F:AFP4]PRFCOD = [M:AFP0]PRFCOD
&                      and [F:AFP4]FNC    = [M:AFP0]FNC
       If fstat = 1
          GOK = -1 : Call RSTA("AFP","") From GLOCK : Goto ROLL_SUPP
       Elsif fstat
          GOK = 0  : Call FSTA("AFP") From GLOCK : Goto AB_SUPP
       Endif
       ##suppresion dans la table AFF
       Delete [AFF] Where [F:AFF]PRFCOD = [M:AFP0]PRFCOD
&                     and [F:AFF]FNC    = [M:AFP0]FNC
       If fstat = 1
          GOK = -1 : Call RSTA("AFF","") From GLOCK : Goto ROLL_SUPP
       Elsif fstat
          GOK = 0  : Call FSTA("AFF") From GLOCK  : Goto AB_SUPP
       Endif
   Endif
   Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Commit
Return

$AB_SUPP
Rollback
Return

$ROLL_SUPP
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_SUPP : Endif

$SORTIE_SUPP
PARAM(1) = num$(GSTARAF)
Return


#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AFCTPRF [AFP1]
 Local File AFCTFCY [AFF1]
 Local File AFCTFCT [AFT1]
Else
 Local File =[M]DOSORG+".AFCTPRF" [AFP1]
 Local File =[M]DOSORG+".AFCTFCY" [AFF1]
 Local File =[M]DOSORG+".AFCTFCT" [AFT1]
Endif
If [M]DOSDES=nomap
 Local File AFCTPRF  [AFP2]
 Local File AFCTFCY  [AFF2]
 Local File AFCTFCT  [AFT2]
 Local File FACILITY [FCY2]
 Local File COMPANY  [CPY2]
Else
 Local File =[M]DOSDES+".AFCTPRF"  [AFP2]
 Local File =[M]DOSDES+".AFCTFCY"  [AFF2]
 Local File =[M]DOSDES+".AFCTFCT"  [AFT2]
 Local File =[M]DOSDES+".FACILITY" [FCY2]
 Local File =[M]DOSDES+".COMPANY"  [CPY2]
Endif
Local Integer ATRACE
Call OUVRE_TRACE(mess(61,104,1)-[L]TABLE) From LECFIC : # Copie habilitations
Call DEBTRANS From GLOCK
Gosub TR_COP
Call FERME_TRACE From LECFIC
Close Local File [AFP1], [AFF1], [AFT1], [AFP2], [AFF2], [AFT2]
Return

$TR_COP
GOK = 1
Trbegin [AFP2], [AFF2], [AFT2]
 Delete [F:AFP2] Where [F:AFP2]PRFCOD=[L]TABLE & [F:AFP2]FNC=[L]TABLE2
 If fstat=1 : GOK = -1 : GLOCK = [F:AFP2]PRFCOD : Goto ROLL_TR_COP : Endif
 Delete [F:AFF2] Where [F:AFF2]PRFCOD=[L]TABLE & [F:AFF2]FNC=[L]TABLE2
 If fstat=1 : GOK = -1 : GLOCK = [F:AFF2]PRFCOD : Goto ROLL_TR_COP : Endif
 Delete [F:AFT2] Where [F:AFT2]PRFCOD=[L]TABLE
 If fstat=1 : GOK = -1 : GLOCK = [F:AFT2]PRFCOD : Goto ROLL_TR_COP : Endif
 Read [F:AFT1]AFT0 = TABLE
 Raz [AFT2]
 [F:AFT2] = [F:AFT1]
 Write [AFT2]
 If fstat
  GOK = 0 : Call FSTA("AFP2") From GLOCK
 Endif
 For [AFP1] Where PRFCOD=[L]TABLE & FNC=[L]TABLE2
  If [F:AFP1]FCYGRU<>""
   If [F:AFP1]FCYGRUCOD=1
    Look [CPY2]CPY0 = [F:AFP1]FCYGRU
    If fstat
     Look [FCY2]FCY0 = [F:AFP1]FCYGRU
    Endif
   Else
    Look [FCY2]FCY0 = [F:AFP1]FCYGRU
   Endif
  Endif
  If [F:AFP1]FCYGRU<>"" & fstat
   Call ECR_TRACE([F:AFP1]FCYGRU-mess(60,104,1),1) From GESECRAN : # Société/site non transféré
  Else
   Raz [F:AFP2]
   [F:AFP2] = [F:AFP1]
   If dim([F:AFP2]UPDUSR)>0 : [F:AFP2]UPDUSR = GUSER : Endif
   If dim([F:AFP2]UPDDAT)>0 : [F:AFP2]UPDDAT = date$ : Endif
   Write [AFP2]
   If fstat
    GOK = 0 : Call FSTA("AFP2") From GLOCK : Break
   Endif
  Endif
 Next
 For [AFF1]AFF1 Where PRFCOD=[L]TABLE & FNC=[L]TABLE2
  If [F:AFF1]FCY<>""
   Look [FCY2]FCY0 = [F:AFF1]FCY
  Endif
  If [F:AFF1]FCY<>"" & fstat
   Call ECR_TRACE([F:AFF1]FCY-mess(59,104,1),1) From GESECRAN : # Site non transféré
  Else
   Raz [F:AFF2]
   [F:AFF2] = [F:AFF1]
   Write [AFF2]
   If fstat
    GOK = 0 : Call FSTA("AFF2") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<0   : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call  UPDATE_RIGHTSETAG([M]DOSDES) From ASYRFNC
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


########################################
$INIT_FUS
Local Integer REP
Local Char    PRFCOD(GLONAFT)
Local Char    OPT(50)

PRFCOD = PARAM(1)

If clalev([F:AFP1])  = 0 : Local File AFCTPRF   [AFP1] : Endif
If clalev([F:AFP2])  = 0 : Local File AFCTPRF   [AFP2] : Endif
If clalev([F:AFF1])  = 0 : Local File AFCTFCY   [AFF1] : Endif
If clalev([F:AFP3])  = 0 : Local File AFCTPRF   [AFP3] : Endif

TIT = mess(67,104,1)    # Fusion
Return

$INIT_DIA_FUS
Return

$EXEC_FUS
Local Char MESSA(255),ERRSITES(250)(1..)
Local Integer NBERRSITE
MESSA = mess(231,126,1) : # Les fonctions du profil $1$ vont être rajoutées au profil $2$
MESSA = func AFNC.MES2(MESSA,[L]PRFCOD,[M:DIA]PRFCOD3)
MESSA += "\"+mess(67,126,1) : # Confirmation de fusion
REP = 0 : Call OUINON(MESSA,REP) From GESECRAN
If REP = 2
  Call TEMPON("E") From GESECRAN
  Gosub TR_INIT
  Call TEMPOFF From GESECRAN
  Call MAJAFF([M:DIA]PRFCOD3) From SUBAFP1
Endif
Raz GERR
If NBERRSITE>0
 If NBERRSITE=1
  Call ERREUR(ERRSITES(NBERRSITE)-":"-mess(66,104,1)) From GESECRAN
 Else
  Call OUVRE_TRACE(mess(66,104,1)) From LECFIC
  Call ECR_TRACE(mess(66,104,1),0) From GESECRAN
  For I=1 To NBERRSITE
   Call ECR_TRACE(ERRSITES(I),1) From GESECRAN
  Next
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
 Endif
Endif
Return

$TR_INIT
Trbegin [AFP2], [AFF1]

            LOK = "AFP"+[M:DIA]PRFCOD3
            Lock =LOK With lockwait=0
            If fstat
               GLOCK="%"+"AFP"+[M:DIA]PRFCOD3
               GOK=-1 : Goto ROLL_INIT
            Endif

            # vérification de l'existance
            Look [F:AFP]AFP0(1) = [M:DIA]PRFCOD3
            If fstat
                # cas d'un duplication
                For [F:AFP1] Where [F:AFP1]PRFCOD = [L]PRFCOD
                    # Issue X3-74666 - 2018-01-31 by CCC : Can copy only if the function is available for current profile
                    If func SUBAFP.GET_FUNCTION_OPTIONS_FOR_PROFILE(GPROFIL,[F:AFP1]FNC,[L]OPT)=[V]CST_AYES
                        Raz [F:AFP2]
                        [F:AFP2] = [F:AFP1]
                        [F:AFP2]PRFCOD = [M:DIA]PRFCOD3
                        [F:AFP2]OPT = func SUBAFP.MATCH_OPTIONS([L]OPT,[F:AFP1]OPT)
                        Write [AFP2]
                        If fstat
                           GOK = 0  : Call FSTA("AFP") From GLOCK : Break
                        Endif
                    Endif
                Next
            Else
                # cas d'une fusion
                For [F:AFP1] Where [F:AFP1]PRFCOD = [L]PRFCOD
                    # Issue X3-74666 - 2018-01-31 by CCC : Can copy only if the function is available for current profile
                    If func SUBAFP.GET_FUNCTION_OPTIONS_FOR_PROFILE(GPROFIL,[F:AFP1]FNC,[L]OPT)=[V]CST_AYES
                        Read [F:AFP2]AFP0 = [M:DIA]PRFCOD3;[F:AFP1]FNC;[F:AFP1]FCYGRU
                        If fstat
                            [F:AFP2] = [F:AFP1]
                            [F:AFP2]PRFCOD = [M:DIA]PRFCOD3
                            [F:AFP2]OPT = func SUBAFP.MATCH_OPTIONS([L]OPT,[F:AFP1]OPT)
                            Gosub VERIF_SITE
                            If !GERR
                              Write [AFP2]
                              If fstat
                                 GOK = 0  : Call FSTA("AFP") From GLOCK : Break
                              Endif
                            Endif
                        Else
                            If [F:AFP1]ACS <> [F:AFP2]ACS
                                If [F:AFP1]ACS = 2
                                    [F:AFP2]ACS = [F:AFP1]ACS
                                    # Issue X3-74666 - 2018-01-31 by CCC : can't get more options than current profile
                                    #[F:AFP2]OPT = [F:AFP1]OPT
                                    [F:AFP2]OPT = func SUBAFP.MATCH_OPTIONS([L]OPT,[F:AFP1]OPT)
                                Endif
                            Else
                                If [F:AFP1]ACS = 2
                                    If len([F:AFP1]OPT) > len([F:AFP2]OPT)
                                        # Issue X3-74666 - 2018-01-31 by CCC : can't get more options than current profile
                                        #[F:AFP2]OPT = [F:AFP1]OPT
                                        [F:AFP2]OPT = func SUBAFP.MATCH_OPTIONS([L]OPT,[F:AFP1]OPT)
                                    Endif
                                Endif
                            Endif
                            Gosub VERIF_SITE
                            If !GERR
                              Rewrite [AFP2]
                              If fstat = 1
                                  GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
                              Elsif fstat
                                  GOK = 0  : Call FSTA("AFF") From GLOCK : Break
                              Endif
                           Endif
                        Endif
                    Endif
                Next
            Endif

            If GOK<0 : Goto ROLL_INIT
            Elsif GOK<1 : Goto AB_INIT
            Endif

            Unlock =LOK

Commit
Return

$AB_INIT
Rollback
Return

$ROLL_INIT
Rollback
Call ROLL From GLOCK
If GROLL : Return  : Else : Goto TR_INIT : Endif

$VERIF_SITE
Raz GERR
## 1er element de la comparaison, un regroupement
If [AFP2]FCYGRUCOD <> 2
    For [FGRM]FGR0 Where [FGRM]CPY = [AFP2]FCYGRU
        For [AFP3] Where PRFCOD=[AFP2]PRFCOD &  FNC=[AFP2]FNC & FCYGRU<>[AFP2]FCYGRU
            ## 2ème element de la comparaison, un regroupement
            If [AFP3]FCYGRUCOD <> 2
                For [FGRL]FGR0 Where [FGRL]CPY = [AFP3]FCYGRU
                    If [FGRM]FCY  = [FGRL]FCY and ([AFP2]ACS <> [AFP3]ACS or [AFP2]OPT <> [AFP3]OPT)
                        GERR = 1 :
                        #GMESSAGE = [AFP2]FNC-" : "-[AFP2]FCYGRU-" & "-[AFP3]FCYGRU-":"- mess(66,104,1) : # sites incompatibles
                        NBERRSITE +=1
                        ERRSITES(NBERRSITE) = [AFP2]FNC-" : "-[AFP2]FCYGRU-" & "-[AFP3]FCYGRU
                        Break 3
                    Endif
                Next [FGRL]FGR0
            Else
                ## 2ème element de la comparaison, un site
                If [FGRM]FCY  =  [AFP3]FCYGRU and ([AFP2]ACS <> [AFP3]ACS or  [AFP2]OPT <> [AFP3]OPT) : # CCL 115223
                    GERR = 1 :
                    #GMESSAGE =  [AFP2]FNC-" : "- [AFP2]FCYGRU-" & "- [AFP3]FCYGRU-":"-mess(66,104,1) : # sites incompatibles
                    NBERRSITE +=1
                    ERRSITES(NBERRSITE) = [AFP2]FNC-" : "-[AFP2]FCYGRU-" & "-[AFP3]FCYGRU
                    Break 2 : # 118215
                Endif
            Endif
        Next AFP3
    Next [FGRM]FGR0
Else
    ## 1er element de la comparaison, un site
   For [AFP3] Where PRFCOD=[AFP2]PRFCOD &  FNC=[AFP2]FNC & FCYGRU<>[AFP2]FCYGRU
        ## 2ème element de la comparaison, un regroupement
        If [AFP3]FCYGRUCOD <> 2
            For [FGRL]FGR0 Where [FGRL]CPY = [AFP3]FCYGRU
                If [AFP2]FCYGRU = [FGRL]FCY and ([AFP2]ACS   <> [AFP3]ACS or [AFP2]OPT   <> [AFP3]OPT)
                    GERR = 1 :
                    #GMESSAGE = [AFP2]FNC-" : "-  [AFP2]FCYGRU-" & "- [AFP3]FCYGRU-":"-mess(66,104,1) :  # sites incompatibles
                    NBERRSITE +=1
                    ERRSITES(NBERRSITE) = [AFP2]FNC-" : "-[AFP2]FCYGRU-" & "-[AFP3]FCYGRU
                    Break 2
                Endif
            Next [FGRL]FGR0
        Endif
    Next AFP3
Endif
Return

########################################
$EXEC_CHRGT                # CP 12/04/01

Filter [F:AFC2] Where MODULE=[M]MODULE & TYPTRAIT<>2 & MENU<>""
For [F:AFC2]MODULE
    OK = 1

    ## contrôle d'existence
    If find([F:AFC2]CODINT,[M:AFP1]FNC1(0..[M:AFP1]NBLIG-1))
        OK = 0
    Endif

    ## Controle sur la dimension du tableau
    If [M:AFP1]NBLIG + 1 > dim([M:AFP1]FNC1)
        GERR = 1 : GMESSAGE = mess(26,100,1) : # Tableau plein
        OK = 0
        Break
    Endif

    # Issue X3-74666 - 2018-01-31 by CCC : add only functions available for current profile
    If func SUBAFP.IS_FUNCTION_AVAILABLE_FOR_PROFILE(GPROFIL, [F:AFC2]CODINT)<>[V]CST_AYES
        OK=0
    Endif

    ## Controle d'insertion
    If OK=1
        NOL = [M:AFP1]NBLIG
        Insa NOL,1, [M:AFP1]NBLIG [M:AFP1]FNC1, [M:AFP1]MODULE1, [M:AFP1]MENU1,[M:AFP1]LIBFNC1,[M:AFP1]COMBI

        ## Remplissage du tableau
        [M:AFP1]NBLIG += 1
        [M:AFP1]FNC1(NOL)    = [F:AFC2]CODINT
        [M:AFP1]MODULE1(NOL) = [F:AFC2]MODULE
        [M:AFP1]MENU1(NOL)   = [F:AFC2]MENU
        [M:AFP1]COMBI(NOL)   = num$([F:AFC2]MODULE)+[F:AFC2]MENU+[F:AFC2]CODINT
        Call TEXTE([F:AFC2]NOM,[M:AFP1]LIBFNC1(NOL)) From OBJDIV
       Call ISWINDOWOK(nomap,"OAF1") From INTRUTILB
        [F:AFC] = [F:AFC2] : Gosub REPICK From WGOAF1

    Endif
Next
Filter [F:AFC2]
Affzo [M:AFP1]5
Return

########################################
$INIT_RAPPEL
If clalev([F:AFP2])  = 0 : Local File AFCTPRF   [AFP2] : Endif
Return

########################################
$EXEC_RAPPEL

For [AFP2] Where PRFCOD=[M]PRFCOD

    OK = 1

    ## contrôle d'existence
    If find([F:AFP2]FNC,[M:AFP1]FNC1(0..[M:AFP1]NBLIG-1))
        OK = 0
    Endif

    ## Controle sur la dimension du tableau
    If [M:AFP1]NBLIG + 1 > dim([M:AFP1]FNC1)
        GERR = 1 : GMESSAGE = mess(26,100,1) : # Tableau plein
        OK = 0
        Break
    Endif

    ## Controle d'insertion
    If OK=1
        NOL = [M:AFP1]NBLIG
        Insa NOL,1, [M:AFP1]NBLIG [M:AFP1]FNC1, [M:AFP1]MODULE1, [M:AFP1]MENU1,[M:AFP1]LIBFNC1,[M:AFP1]COMBI

        ## Remplissage du tableau
        [M:AFP1]NBLIG += 1
        [M:AFP1]FNC1(NOL)    = [F:AFP2]FNC
        Read [AFC2]CODINT=[F:AFP2]FNC
        [M:AFP1]MODULE1(NOL) = [F:AFC2]MODULE
        [M:AFP1]MENU1(NOL)   = [F:AFC2]MENU
        [M:AFP1]COMBI(NOL)   = num$([F:AFC2]MODULE)+[F:AFC2]MENU+[F:AFC2]CODINT
        Call TEXTE([F:AFC2]NOM,[M:AFP1]LIBFNC1(NOL)) From OBJDIV
       Call ISWINDOWOK(nomap,"OAF1") From INTRUTILB
        [F:AFC] = [F:AFC2] : Gosub REPICK From WGOAF1

    Endif
Next
Affzo [M:AFP1]5
Return

########################################
Subprog MAJAFCTFCY(MAJ)             ### MISE A JOUR DE LA TABLE AFCTFCY
Value Char MAJ                      ###  par rapport a la table AFCTPRF
Local Integer I

Call TEMPON("E") From GESECRAN

##cas de MAJ (création,modification)
If MAJ = "MAJ"
    Call DELT([M:AFP0]PRFCOD,[M:AFP0]FNC)
    For [F:AFP3] Where [F:AFP3]PRFCOD = [M:AFP0]PRFCOD
&                  and [F:AFP3]FNC    = [M:AFP0]FNC
      Call TRTMAJ([F:AFP3]PRFCOD,[F:AFP3]FNC,[F:AFP3]FCYGRUCOD,[F:AFP3]FCYGRU,[F:AFP3]ACS,[F:AFP3]OPT)
      If GOK<1 : Break : Endif
    Next
Endif

##cas de INIT (initialisation)
If MAJ = "INIT"
    For I=0 To [M:AFP1]NBLIG(I)-1
        For [F:AFP3] Where [F:AFP3]PRFCOD = [M:AFP1]PRFCOD
&                     and  [F:AFP3]FNC    = [M:AFP1]FNC1(I)
          Call TRTMAJ([F:AFP3]PRFCOD,[F:AFP3]FNC,[F:AFP3]FCYGRUCOD,[F:AFP3]FCYGRU,[F:AFP3]ACS,[F:AFP3]OPT)
          If GOK<1 : Break 2 : Endif
        Next
    Next
Endif
Call TEMPOFF From GESECRAN
End

########################################
Subprog TRTMAJ(PRFCOD,FNC,FCYGRUCOD,FCYGRU,ACS,OPT)
Value Char PRFCOD,FNC,FCYGRU,OPT
Value Integer FCYGRUCOD,ACS

## Traitement spécial pour les fonctions dont le flag autorisation/site est décoché
Read [F:AFC]CODINT = [L]FNC
If [F:AFC]FCYAUZ = 2   # flag "autorisation/site" coché
    ## Traitement du Regmt de site "VIDE" avec condition sur accés
    If [L]FCYGRU = ""
       If [L]ACS = 1
            Call DELT([L]PRFCOD,[L]FNC)
       Else Call MAJT([L]PRFCOD,[L]FNC,[L]OPT)
       Endif
    ## Traitement selon regroupement ou site avec condition sur accés
    Else
       If ([L]FCYGRUCOD <> 2)      # Regroupements
          If [L]ACS = 1
               Call DELP([L]FCYGRU,[L]PRFCOD,[L]FNC)
          Else Call MAJP([L]FCYGRU,[L]PRFCOD,[L]FNC,[L]OPT)
          Endif
       Else                         # Site
          If [L]ACS = 1
               Call DELS([L]FCYGRU,[L]PRFCOD,[L]FNC)
          Else Call MAJS([L]FCYGRU,[L]PRFCOD,[L]FNC,[L]OPT)
          Endif
       Endif
    Endif
Endif
If GOK<1 : End : Endif

## Création site vide pour la fonction
Read [AFF]AFF0 = "";[L]PRFCOD;[L]FNC
If fstat
 Raz [F:AFF]
 [F:AFF]PRFCOD = [L]PRFCOD
 [F:AFF]FCY    = ""
 [F:AFF]FNC    = [L]FNC
 [F:AFF]OPT    = [L]OPT
 Write [AFF]
 If fstat
  GOK = 0  : Call FSTA("AFF") From GLOCK : End
 Endif
Endif

End

########################################
Subprog MAJT(PRFCOD,FNC,OPT)    ## MAJ TOTALE (tous sites)
Value Char PRFCOD,FNC,OPT

GPE = 0 : GPOINT = "MAJT" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

For [FCY]FCY0
    Read [F:AFF]AFF0 = [F:FCY]FCY;[L]PRFCOD;[L]FNC
    Raz [F:AFF]
    [F:AFF]PRFCOD = [L]PRFCOD
    [F:AFF]FCY    = [FCY]FCY
    [F:AFF]FNC    = [L]FNC
    [F:AFF]OPT    = [L]OPT

    If fstat = 0
         Rewrite [AFF]
         If fstat = 1
           GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
         Elsif fstat
           GOK = 0  : Call FSTA("AFF") From GLOCK : Break
         Endif
    Else
         Write [AFF]
         If fstat
           GOK = 0  : Call FSTA("AFF") From GLOCK : Break
         Endif
    Endif

Next FCY

End

########################################
Subprog MAJP(FCYGRU,PRFCOD,FNC,OPT)   ## MAJ PARTIELLE (1 regmt site)
Value Char FCYGRU,PRFCOD,FNC,OPT

GPE = 0 : GPOINT = "MAJP" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

For [F:FGRA] Where [F:FGRA]CPY = [L]FCYGRU
    Read [F:AFF]AFF0 = [F:FGRA]FCY;[L]PRFCOD;[L]FNC
    Raz [F:AFF]
    [F:AFF]PRFCOD = [L]PRFCOD
    [F:AFF]FCY    = [FGRA]FCY
    [F:AFF]FNC    = [L]FNC
    [F:AFF]OPT    = [L]OPT

    If fstat = 0
         Rewrite [AFF]
         If fstat = 1
           GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
         Elsif fstat
           GOK = 0  : Call FSTA("AFF") From GLOCK : Break
         Endif
    Else
         Write [AFF]
         If fstat
           GOK = 0  : Call FSTA("AFF") From GLOCK : Break
         Endif

    Endif
Next
End

########################################
Subprog MAJS(FCYGRU,PRFCOD,FNC,OPT)   ## MAJ D'UN SITE
Value Char FCYGRU,PRFCOD,FNC,OPT

GPE = 0 : GPOINT = "MAJS" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

Read [F:AFF]AFF0 = [L]FCYGRU;[L]PRFCOD;[L]FNC
Raz [F:AFF]
[F:AFF]PRFCOD = [L]PRFCOD
[F:AFF]FCY    = [L]FCYGRU
[F:AFF]FNC    = [L]FNC
[F:AFF]OPT    = [L]OPT

If fstat = 0
   Rewrite [AFF]
   If fstat = 1
      GOK = -1 : Call RSTA("AFF","") From GLOCK
   Elsif fstat
      GOK = 0  : Call FSTA("AFF") From GLOCK
   Endif
Else
   Write [AFF]
   If fstat
      GOK = 0  : Call FSTA("AFF") From GLOCK
   Endif
Endif
End

########################################
Subprog DELT(PRFCOD,FNC)              ## SUPPRESION TOTALE (Rgmt site vide)
Value Char PRFCOD,FNC

Delete [AFF] Where [F:AFF]PRFCOD = [L]PRFCOD
&                and [F:AFF]FNC = [L]FNC

If fstat = 1
    GOK = -1 : Call RSTA("AFF","") From GLOCK
Elsif fstat
    GOK = 0  : Call FSTA("AFF") From GLOCK
Endif
End

########################################
Subprog DELP(FCYGRU,PRFCOD,FNC)       ## SUPPRESION PARTIELLE (1 Rgmt site)
Value Char FCYGRU,PRFCOD,FNC

For [FGRA] Where [FGRA]CPY = FCYGRU
    Delete [F:AFF] Where [F:AFF]PRFCOD = [L]PRFCOD
&                    and [F:AFF]FNC    = [L]FNC
&                    and [F:AFF]FCY    = [F:FGRA]FCY
    If fstat = 1
      GOK = -1 : Call RSTA("AFF","") From GLOCK : Break
    Elsif fstat
      GOK = 0  : Call FSTA("AFF") From GLOCK : Break
    Endif
Next
End

########################################
Subprog DELS(FCYGRU,PRFCOD,FNC)       ## SUPPRESION D'UN SITE
Value Char FCYGRU,PRFCOD,FNC

Delete [F:AFF] Where [F:AFF]PRFCOD = [L]PRFCOD
&                and [F:AFF]FNC    = [L]FNC
&                and [F:AFF]FCY    = [L]FCYGRU

If fstat = 1
    GOK = -1 : Call RSTA("AFF","") From GLOCK
Elsif fstat
    GOK = 0  : Call FSTA("AFF") From GLOCK
Endif
End

################################################################################
$SEL_TABLE
Case TABLE
 When "FCYGRU" : Gosub SEL_FCYGRU
Endcase
Return

$SEL_LISTE
Case LISTE
 When "OPT"    : Gosub SEL_OPT
Endcase
Return

$VERF_LISTE
Case LISTE
 When "OPT"    : Gosub VERF_OPT
Endcase
Return

########################################
$SEL_FCYGRU
If [M]FCYGRUCOD(nolign-1) = 1
   OBJET = "CPY"
Else
   OBJET = "FCY"
Endif
Return

########################################
$SEL_OPT
Local Integer J
Local Char    LIBEL(50) , OOPT(23)

OOPT = VALEUR

If clalev([F:FCT])=0 : Local File AFONCTION [AFC] : Endif

Read [F:AFC]CODINT = [M:AFP0]FNC
If [F:AFC]TYP = 2
    NBTEX+= 1
    TEX(NBTEX)   = "C"
    TEXTE(NBTEX) = TEX(NBTEX)-mess(59,123,1)
    NBTEX+= 1
    TEX(NBTEX)   = "M"
    TEXTE(NBTEX) = TEX(NBTEX)-mess(3,85,1)
    If func OPT([M:AFP0]FNC)
     NBTEX+= 1
     TEX(NBTEX)   = "N"
     TEXTE(NBTEX) = TEX(NBTEX)-mess(117,75,1)
    Endif
    NBTEX+= 1
    TEX(NBTEX)   = "S"
    TEXTE(NBTEX) = TEX(NBTEX)-mess(2,24,1)
Endif
For J = 0 To ([F:AFC]NBOPT-1)
    NBTEX+ = 1
    Call TEXTE([F:AFC]OPTION(J),LIBEL) From OBJDIV
    TEX(NBTEX)   = [F:AFC]FLAG(J)
    TEXTE(NBTEX) = num$([F:AFC]FLAG(J))-LIBEL
Next
Sorta NBTEX TEX(1..NBTEX) , TEXTE(1..NBTEX)
Return

$VERF_OPT
If !instr(1,OOPT,VALEUR)
 OOPT += VALEUR
Endif
VALEUR = OOPT
Return

