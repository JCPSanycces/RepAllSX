 zoncou = "STAFED" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STAFED(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSTAFED)")>indice
 [M]STAFED(indice) = VALEUR
 Affzo ZSTAFED(indice)
Endif
Gosub _AFF
End

Subprog S_STAFED(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "80"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_STAFED(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"80") From GOBJET
Gosub _AFF
End

Subprog SA_STAFED(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "80"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_STAFED(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "80"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSTAFED
Onevent BEFORE_AREA Gosub AV_ZSTAFED From W2ITF1
Return

$AV_ZSTAFED
Call LECTEXTRA(zc,"ATABDIV","LNGDES","80",num$([M]STAFED(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_FRTCLS
Onevent CONTROL Call C_FRTCLS(zc) From W2ITF1
Onevent BEFORE_INPUT Call AS_FRTCLS(zc) From W2ITF1
Onevent AFTER_CHANGE Gosub AMM_FRTCLS From W2ITF1
Return

Subprog IB_FRTCLS(VALEUR)
Variable Char    VALEUR()
## Action IBTUNLEG
Call IBTUNLEG("") From TRTVENCTL
Gosub _AFF
End

Subprog AS_FRTCLS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53091,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_FRTCLS(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_FRTCLS(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_FRTCLS(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_FRTCLS(zc) From W2ITF1
Onkey 146 Titled GBOUTA Call SA_FRTCLS(zc) From W2ITF1
Gosub _AFF
End

Subprog C_FRTCLS(VALEUR)
Variable Char    VALEUR()
## Action CONTFRT
Call CONTFRT(VALEUR,[V]GCURLEG,"") From SUBFRT
If mkstat : GERR = 1 : GZONE = "FRTCLS" : GZNUM = 53091 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FRTCLS" : GZNUM = 53091 : Endif
Endif
Gosub _AFF
End

$AMM_FRTCLS
Call AM_FRTCLS(zc)
If !mkstat & GOBJET
 zoncou = "FRTCLS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FRTCLS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZFRTCLS)")>indice
 [M]FRTCLS(indice) = VALEUR
 Affzo ZFRTCLS(indice)
Endif
Gosub _AFF
End

Subprog S_FRTCLS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELFRTLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFRTLEG"
 PARMSK(1) = [V]GCURLEG
 PARMSK(2) = [M:ITF0]STOFCY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELFRT","SUBFRT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_FRTCLS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNFRT
 Call TUNFRT(VALEUR,[V]GCURLEG) From SUBFRT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_FRTCLS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FRT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_FRTCLS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FRT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZFRTCLS
Onevent BEFORE_AREA Gosub AV_ZFRTCLS From W2ITF1
Return

$AV_ZFRTCLS
Call LECTEXTRA(zc,"FRTCLS","DESAXX",num$([M]FRTCLS(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_NMFC
Onevent CONTROL Call C_NMFC(zc) From W2ITF1
Onevent BEFORE_INPUT Call AS_NMFC(zc) From W2ITF1
Onevent AFTER_CHANGE Gosub AMM_NMFC From W2ITF1
Return

Subprog AS_NMFC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53395,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NMFC(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_NMFC(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_NMFC(zc) From W2ITF1
Onkey 146 Titled GBOUTA Call SA_NMFC(zc) From W2ITF1
Gosub _AFF
End

Subprog C_NMFC(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("FCC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "NMFC" : GZNUM = 53399 : Endif
Gosub _AFF
End

$AMM_NMFC
Call AM_NMFC(zc)
If !mkstat & GOBJET
 zoncou = "NMFC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NMFC(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZNMFC)")>indice
 [M]NMFC(indice) = VALEUR
 Affzo ZNMFC(indice)
Endif
Gosub _AFF
End

Subprog S_NMFC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCC"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_NMFC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNFCC
 Call TUNFCC(VALEUR,1) From SUBFCC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_NMFC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NMFC(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNMFC
Onevent BEFORE_AREA Gosub AV_ZNMFC From W2ITF1
Return

$AV_ZNMFC
Call LECTEXTRA(zc,"FRTCOMCOD","SHOAXX",num$([M]NMFC(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


