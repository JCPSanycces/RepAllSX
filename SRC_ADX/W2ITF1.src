#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITF1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_TCTRNUM
Onevent CONTROL Call C_TCTRNUM(zc) From W2ITF1
Onevent BEFORE_INPUT Call AS_TCTRNUM(zc) From W2ITF1
Return

Subprog AS_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(7892,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TCTRNUM(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_TCTRNUM(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_TCTRNUM(zc) From W2ITF1
Onkey 146 Titled GBOUTA Call SA_TCTRNUM(zc) From W2ITF1
Gosub _AFF
End

Subprog C_TCTRNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TCTR","A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
Endif
Gosub _AFF
End

Subprog S_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCTR"
PARMSK(2) = "A"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCTR",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_PCU
Onevent AFTER_CHANGE Gosub AMM_PCU From W2ITF1
Onevent BEFORE_INPUT Call AS_PCU(zc) From W2ITF1
Onevent CONTROL Call C_PCU(zc) From W2ITF1
Return

Subprog AS_PCU(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3612,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PCU(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_PCU(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_PCU(zc) From W2ITF1
Onkey 146 Titled GBOUTA Call SA_PCU(zc) From W2ITF1
Gosub _AFF
End

Subprog C_PCU(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PCU" : GZNUM = 2685 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TUN","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PCU" : GZNUM = 2685 : Endif
Endif
Gosub _AFF
End

$AMM_PCU
Call AM_PCU(zc)
If !mkstat & GOBJET
 zoncou = "PCU" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PCU(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "PCU" : GZNUM = 2685 : Endif
Gosub _AFF
End

Subprog S_PCU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STKSELUOMN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "STKSELUOMN"
 PARMSK(1) = "1"
 PARMSK(2) = "1"
 Call S_LIS_CHAR(VALEUR,PARMSK,"STKSELUOMN","STKSEL","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PCU(VALEUR)
Variable Char    VALEUR()
Call OBJET("TUN",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_PCU(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TUN"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PCU(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TUN",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_TCTRPCUCOE
Onevent CONTROL Call C_TCTRPCUCOE(zc) From W2ITF1
Return

Subprog C_TCTRPCUCOE(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCTRPCUCOE" : GZNUM = 1003468 : Endif
If !mkstat
 ## Action STD
 Call C_TCTRPCUCOE(VALEUR) From SUBITF
 If mkstat : GERR = 1 : GZONE = "TCTRPCUCOE" : GZNUM = 1003468 : Endif
Endif
Gosub _AFF
End

$ON_PLANNER
Onevent INIT_AREA Call D_PLANNER(zc) From W2ITF1
Onevent CONTROL Call C_PLANNER(zc) From W2ITF1
Onevent BEFORE_INPUT Call AS_PLANNER(zc) From W2ITF1
Onevent AFTER_CHANGE Gosub AMM_PLANNER From W2ITF1
Return

Subprog D_PLANNER(VALEUR)
Variable Char    VALEUR()
If varinit([M]PLANNER,indice)=0
 ## Action STD
 Call D_PLANNER(VALEUR) From SUBITF
Endif
Gosub _AFF
End

Subprog AS_PLANNER(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(485,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PLANNER(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_PLANNER(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_PLANNER(zc) From W2ITF1
Onkey 146 Titled GBOUTA Call SA_PLANNER(zc) From W2ITF1
Gosub _AFF
End

Subprog C_PLANNER(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("AUS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PLANNER" : GZNUM = 15504 : Endif
If !mkstat
 ## Action STD
 Call C_PLANNER(VALEUR) From SUBITF
 If mkstat : GERR = 1 : GZONE = "PLANNER" : GZNUM = 15504 : Endif
Endif
Gosub _AFF
End

$AMM_PLANNER
Call AM_PLANNER(zc)
If !mkstat & GOBJET
 zoncou = "PLANNER" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PLANNER(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPLANNER)")>indice
 [M]PLANNER(indice) = VALEUR
 Affzo ZPLANNER(indice)
Endif
Gosub _AFF
End

Subprog S_PLANNER(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "AUS"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

