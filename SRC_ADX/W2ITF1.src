Subprog D_STAFED(VALEUR)
Variable Char    VALEUR()
If varinit([M]STAFED,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"80","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_STAFED(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"80") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_STAFED(zc) From W2ITF1
Onkey   2 Titled GBOUTS Call S_STAFED(zc) From W2ITF1
Onkey 144 Titled GBOUTP Call P_STAFED(zc) From W2ITF1
