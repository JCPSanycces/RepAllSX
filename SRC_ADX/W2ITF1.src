End

Subprog C_STAFED(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"80","") From SUBADI
If mkstat : GERR = 1 : GZONE = "STAFED" : GZNUM = 36804 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"80",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "STAFED" : GZNUM = 36804 : Endif
Endif
Gosub _AFF
End

