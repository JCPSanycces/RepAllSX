If mkstat : GERR = 1 : GZONE = "LTIQLYCRD" : GZNUM = 33909 : Endif
Gosub _AFF
End

$AMM_LTIQLYCRD
Call AM_LTIQLYCRD(zc)
If !mkstat & GOBJET
 zoncou = "LTIQLYCRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

