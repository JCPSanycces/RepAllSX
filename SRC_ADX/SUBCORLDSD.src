#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant.
#
# l'affectation se fait à partir des tables
##########################################################################################################
$COR_SET_HEA_INFO
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      [M:COR0]CNTNUM = [F:AIN]CNTNUM
      [M:COR0]UPDCNTNUM = 0
    When "CORTYPMEN"
      #Type (ici 2 = Lead)
      [M:COR0]CORTYPMEN = 2
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [F:AIN]CNTEMA
    When "HOMZIP"
      [M:COR3]HOMZIP = [F:AIN]ZIP
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [F:AIN]SAT
    When "LNA"
      #Nom
      [M:COR0]LNA = [F:AIN]CNTLNA
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [F:AIN]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [F:AIN]CRYNAM
    When "FNA"
      #Prénom
      [M:COR0]FNA = [F:AIN]CNTFNA
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [F:AIN]ADD(0)
        When 1
          [M:COR3]HOMADD(1) = [F:AIN]ADD(1)
        When 2
          [M:COR3]HOMADD(2) = [F:AIN]ADD(2)
      Endcase
    When "HOMFAX"
      #Fax (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTFAX, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMFAX = ""
      Else
        [M:COR3]HOMFAX = [F:AIN]CNTFAX
      Endif
    When "HOMTEL"
      #Téléphone (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTETS, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMTEL = ""
      Else
        [M:COR3]HOMTEL = [F:AIN]CNTETS
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      [M:COR3]HOMMOB = [F:AIN]CNTMOB
    When "TTL"
      #Civilité
      [M:COR0]TTL = [F:AIN]CNTTTL
    When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [F:AIN]CTY
    When "BPRLIB"
      #libelle tiers
      [M:COR2]BPRLIB = [F:LDS]CPYNAM
    When "CPYBPADES"
      [M:COR2]CPYBPADES = [F:BPA]BPADES
    When "CPYADD"
      Case indice
        When 0
          [M:COR2]CPYADD(0) = [F:BPA]BPAADDLIG(0)
        When 1
          [M:COR2]CPYADD(1) = [F:BPA]BPAADDLIG(1)
        When 2
          [M:COR2]CPYADD(2) = [F:BPA]BPAADDLIG(2)
      Endcase
    When "CPYZIP"
      [M:COR2]CPYZIP = [F:BPA]POSCOD
    When "CPYCTY"
      [M:COR2]CPYCTY = [F:BPA]CTY
    When "CPYSAT"
      [M:COR2]CPYSAT = [F:BPA]SAT
    When "CPYCRY"
      [M:COR2]CPYCRY = [F:BPA]CRY
    When "CPYCRYNAM"
      [M:COR2]CPYCRYNAM = [F:BPA]CRYNAM
    When "CPYEML"
      [M:COR2]CPYEML = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
    When "CPYTEL"
      [M:COR2]CPYTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
    When "CPYFAX"
      [M:COR2]CPYFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
    When "CPYMOB"
      [M:COR2]CPYMOB = [F:BPA]TEL(4)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]MOB
    When "NBLIGNCOP"
      If GREP = "C" Then
        If GSZREP <> "" Then
          [M:COR4]NBLIGNCOP = 1
          [M:COR4]COPREP(0) = GSZREP
        Endif
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        If indice = 0 Then
          If GSZREP <> "" Then
            IMPMOD = 1
            [M:COR4]COPREP(indice) = GSZREP
          Endif
        Endif
      Endif
  Endcase
Return

