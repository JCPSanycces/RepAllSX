#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$SETBOUT
If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return


$OUVRE
Gosub OUVRE_OUT

#Manage Localisations
Call MANAGE_LOCALISATION("ESSPERCNTAV") From DIVPAYE

Return

$OUVRE_OUT
#Opening tables and declaring an instance of the main class
If clalev([F:EWID1])      = 0 : Local File ESSWRKEMP    [EWID1]     : Endif
If clalev([F:ESWD2])      = 0 : Local File ESSWRKFLWDET     [ESWD2]     : Endif
Return


$DEBUT
Gosub DEBUT_OUT

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPERCNTAVHIDE
Call SHOW_LEGACTCALLS From WESSPERCNTAVSHOW

Affzo [M:ESPRC]1-99

Return

$DEBUT_OUT
Local Char GLOBEML(GLONEML)
nolign = 0

Raz [M:ESPRC]
Read [EWID1]EWID0 = val(PARAM(2))
If fstat : Return : Endif

nolign = 1
[M:ESPRC] = [F:EWID1]
[M:ESPRC]NBCNT = nolign

GLOBEML   = [F:EWID1]REFNUM

GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1)

[M:ESPRC]DEST = PARAM(3)
[M:ESPRC]CHRONO = PARAM(4)

#Style
Gosub DECLARE_EMPSTYLE From ESS_FUNCTIONS

WFILENAME = "WESSEMPPERCNTDETSTYLE_"+GUSER

 Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
  #Indicate changed fields
  If [F:EWID1]WRK = "M"
    WSTYLECODE = "ECCBODC"
    [M:ESPRC]WRKREQ = 2
    Chgstl [M:ESPRC]WRKREQ With "ECCBODC"
    Filter [F:ESWD2] Where UID = [F:EWID1]UID and WRK = "M" and MAIREC <> 2
    For [F:ESWD2]
      If evalue("dim([M:ESPRC]"+[F:ESWD2]FLDNAM+")")>0
        WFIELDNAME = "[M:ESPRC]"+[F:ESWD2]FLDNAM+"(nolign-1)"
        #WFIELDNAME = [F:ESWD2]FLDNAM+"nolign(-1)"
        STYLESTAT+=1
        Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
      Endif
    Next
    Filter [F:ESWD2]
  Elsif [F:EWID1]WRK = "D"
    WSTYLECODE = "ECCBODA"
    [M:ESPRC]WRKREQ = 3
    Chgstl [M:ESPRC]WRKREQ With "ECCBODA"
    Chgstl NBCNT(nolign-1) With "ECCBODA"
  Elsif [F:EWID1]WRK = "C"
    WSTYLECODE = "ECCBODC"
    [M:ESPRC]WRKREQ = 1
    Chgstl [M:ESPRC]WRKREQ With "ECCBODC"
    Chgstl NBCNT(nolign-1) With "ECCBODC"
  Endif
  #Close script
  Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

  If STYLESTAT
    #Run script
    Call STYLE_FIELDS() From =WFILENAME
  Endif
Return

