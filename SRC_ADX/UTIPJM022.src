#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM022
# Issue X3-26714 - 2017-07-05 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM022(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM022(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE

  Call ECR_TRACE("UTIPJM022: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:OPP]) = 0  : Local File =DOSSIER + ".OPPOR"      [OPP]  : Endif
  If clalev([F:JTT]) = 0  : Local File =DOSSIER + ".PJMTSKITM"  [JTT]  : Endif
  If clalev([F:PJLB]) = 0 : Local File =DOSSIER + ".PJMBUDLIG"  [PJLB] : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [JTT]
  If dim([F:JTT]BUDVLTCOD) > 0 Then
    # -----------------
    Link [F:JTT] With [F:OPP]OPP0=[F:JTT]OPPNUM As [LNK]
    # -----------------
    Filter [LNK] Where [F:JTT]BUDVLTCOD = 0 or [F:JTT]BUDVLTCOD = 0 or [F:JTT]CUR = ""
    For [LNK]
      IUPDATE = 0
      If [F:JTT]BUDVLTCOD = 0 Then
        [F:JTT]BUDVLTCOD = 1
        IUPDATE = 1
      Endif
      If [F:JTT]BUDVLT2 = 0 Then
        [F:JTT]BUDVLT2 = 1
        IUPDATE = 1
      Endif
      If [F:JTT]CUR = "" Then
        [F:JTT]CUR = [F:OPP]CUR
        IUPDATE = 1
      Endif
      If IUPDATE = 1 Then
        Rewrite [JTT]
        COMPTEUR += 1
        If fstat Then
          Call ECR_TRACE("File PJMTSKITM" - [F:PJMRPT]OPPNUM - [F:PJMRPT]TASCOD - num$([F:PJMRPT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
    Next
    Filter [LNK]
  Endif
  # -----------------
  If dim([F:PJLB]PLBPRIFRC) > 0 Then
    Filter [PJLB] Where [F:PJLB]PLBPRIFRC = 0
    For [PJLB]
      [F:PJLB]PLBPRIFRC = 1
      # -----------------
      Rewrite [PJLB]
      COMPTEUR += 1
      If fstat Then
        Call ECR_TRACE("File PJMBUDLIG" - [F:PJLB]OPPNUM - [F:PJLB]PBUCOD - num$([F:PJLB]PLBSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------------
    Next
    Filter [PJLB]
  Endif
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM022 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM022 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [OPP]
  Close Local File [JTT]
  Close Local File [PJLB]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPOR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPOR") : End : Endif
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  If filinfo(filpath("FIL","PJMBUDLIG","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMBUDLIG") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM022(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPOR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPOR") : End : Endif
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  If filinfo(filpath("FIL","PJMBUDLIG","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMBUDLIG") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM022(APPLI)
End

