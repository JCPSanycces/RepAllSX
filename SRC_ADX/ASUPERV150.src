                Read [XXX]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XXX]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub GEOIND140_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif
Endif

If GPRODUIT = 3
    #---------------------------------------------
    # mise a jour ABEIND140
    # lecture dans le fichier XXY code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
