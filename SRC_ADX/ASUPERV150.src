##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits pour la V5
#  utilise par INDUS
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_150
Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE

# test connexion avec la v140
# plus de mise a jour
If GFOLDER_PRODUIT (0) = ""
    Goto MAJ_150
Endif



#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en v140
# et ensuite on regarde pour la v150
# ----------------------------------------
If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour X3IND140
    # lecture dans le fichier XXZ code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 140 pour x3 code XXZ X3IND140


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XXZ] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XXZ]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XXZ]NUMERO
    Next
    Filter [XXZ]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur X3IND140
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XXZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XXZ]COMMENT = WTEXTE_COMMENT
                Gosub X3IND140_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XXZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XXZ]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND140_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif
Endif

If GPRODUIT = 1
    #---------------------------------------------
    # mise a jour GEOIND140
    # lecture dans le fichier XXZ code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour egalement de atexte de la version 140 pour GEOde code XXX GEOIND140

    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XXX] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XXX]
        WTAB_INDICE +=1
