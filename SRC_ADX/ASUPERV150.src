        # lecture dans le fichier XVZ code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 

        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XVZ] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XVZ]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XVZ]NUMERO
        Next
        Filter [XVZ]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur geode on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XVZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XVZ]COMMENT = WTEXTE_COMMENT
                    Gosub X3IND150_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XVZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVZ]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif
    #---------------------------------------------
    # mise a jour ABELX V5
     If GFOLDER_V150(4) <> ""

        # lecture dans le fichier XVY code langue FRA
        # recherche du texte correspond 
        # dans abelx3 ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 

        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XVY] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XVY]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XVY]NUMERO
        Next
        Filter [XVY]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur abelx3 on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XVY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XVY]COMMENT = WTEXTE_COMMENT
                    Gosub ABEIND150_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XVY]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVY]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub ABEIND150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif

Endif

Return





