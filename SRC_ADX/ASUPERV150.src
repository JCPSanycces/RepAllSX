                    Endif
                Endif
        Next W_INDICE
    Endif


Endif


If GPRODUIT = 2
    #---------------------------------------------
    # on n'a pas de trad sur la 140 -- donc rien
    Raz WTAB_NUM
    W_INDICE  =0

Endif

$MAJ_150

###################################
# mise a jour ATEXTE de superv150

# lecture dans le fichier XVS code langue FRA
# recherche du texte correspond 
# dans superv150 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 

Raz WTAB_NUM
W_INDICE  =0

Filter [XVS] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XVS]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XVS]NUMERO
Next
Filter [XVS]


If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv150 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XVS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XVS]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV150_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XVS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XVS]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV150_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif



