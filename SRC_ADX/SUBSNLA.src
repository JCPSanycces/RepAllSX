#<AdxTL>@(#)9.0.0.0 $Revision$

# hcb 74380 deb
######################################################################"
# VERROU                                                        VERROU
######################################################################"
$VERROU

SYMBOLE2 = "CUL"+[F:CUL]CUNSSSNUM+"\"+[F:CUL]CUNLISNUM
Lock = SYMBOLE2
# modification en cours sur un autre poste
If fstat
   Unlock =SYMBOLE
   OK=0
   Return
Endif

Return
######################################################################"
# DEVERROU                                                    DEVERROU
######################################################################"
$DEVERROU

#  deverrouillage logique liste
If [M:SNL0]CUNLISNUM <> ""
   SYMBOLE2 = "CUL"+[M:SNL0]CUNSSSNUM+"\"+[M:SNL0]CUNLISNUM
   Unlock = SYMBOLE2
Endif

Return
# hcb 74380 fin

######################################################################"
# OUVRE                                                          OUVRE
######################################################################"
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  Endif
If clalev([M:SNLSW])=0 Local Mask SNLSEREW   [SNLSW] Endif  # hcb 110327
If clalev([M:SNLS]) =0 Local Mask SNLSERE    [SNLS]  Endif  # hcb 110327

#lecture code activite nombre de lignes par liste d inventaire
Global Integer GCOD_INV
Read [ACV]CODACT="INV"
If !fstat
   GCOD_INV =[F:ACV]DIME
Endif
#lecture code activite nombre de listes d inventaire par session
Global Integer GCOD_INL
Read [ACV]CODACT="INL"
If !fstat
   GCOD_INL =[F:ACV]DIME
Endif
#lecture code activite gestion emplacement
Global Integer GCOD_EMP
Read[ACV]CODACT="EMP"
If !fstat
   GCOD_EMP =[F:ACV]FLACT
Endif

Call INIVAR From GLOBSTO
# Initialisation des tables nécessaires à la gestion d'emplacements
Gosub STK_INILOC From STKLOC

# initialisation à 0 rubrique ajout ligne d inventaire
GAJOUINV = 0

GSRTNUM = GFLAG

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>6 | [F:SRT]SRTNUM<>GSNLNUM                    # hcb 50197
   Read [SRT]SRT0=6;GSNLNUM : If fstat  Raz [F:SRT] : Endif
Endif

Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0    # Ana
If fstat                                                 # Ana
   Raz [F:DTR]                                           # Ana
Endif                                                    # Ana
GFCY=GFCYDEF(7)                                                # Ana
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",6,GSNLNUM) From TRTX3CPT                             # hcb 50197
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
Endif                                                          # Ana
GORITITCOL=1                                                   # Ana
Global Shortint GSNLSTAIMG3   # hcb 74380
Raz GSNLSTAIMG3

#                                                           # hcb 71659 pe
Global Integer GINICPT
Raz GINICPT
GPOINT = "INICPT"
Gosub  ENTREE From EXEFNC
#                                                           # hcb 71659 pe

Return

######################################################################"
# FERME                                                          FERME
######################################################################"
$FERME

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
If GFONCTION = GFONC1
#-----
   If dim(GCOD_INV) > 0
      Kill GCOD_INV
   Endif
   If dim(GCOD_INL) > 0
      Kill GCOD_INL
   Endif
   If dim(GCOD_EMP) > 0
      Kill GCOD_EMP
   Endif
Endif

Return



######################################################################"
# FIN                                                              FIN
######################################################################"
$FIN
# si ajout de lignes il faut renumeroter la liste
If GAJOUINV = 1
#message opération en cours ...
   Call TEMPON("O") From GESECRAN
# renumerotation
   Gosub RENUM_CUD From STKINV
#suppression message opération en cours ...
   Call TEMPOFF   From GESECRAN

Endif


If GFONC1 = "GESSNX"
   mkstat = 4
Endif
#                                                             # hcb 110327 deb
If dim(GSNLSERE) > 0
   Kill GSNLSERE
Endif
#                                                             # hcb 110327 fin
Return


######################################################################"
# SETBOUT                                                      SETBOUT
######################################################################"
$SETBOUT
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
# Menu Options / Visu transaction
CHMEN += "d"
# Menu Options / Section analytique
CHMEN += "M"

# hcb 090205 28218 deb
Local Integer WI
WI = find(2,[M:SNL0]MODFLG(0..[M:SNL0]NBLIG-1))
If WI > 0 | [M:SNL0]CULIPTDAT <> [M:SNL0]IPTDAT
   REP  = "M"
Else
   REP  = ""
Endif

#                                                                                         # hcb 71659 deb
# Menu Options / Raz comptage(s)
CHMEN += "e"
# si liste annulée ,validée partielle, validée ou cloturée : raz  comptage(s) interdite
# seuls à compter et comptée l autorisent
If !find([M:SNL0]CUNLISSTA,1,3)
   Call VIREBOUT(CHMEN,"e") From GOBJET
Endif
If [M:SNL0]MODFLG3 = 2
   REP  = "M"
Endif
#                                                                                         # hcb 71659 fin

# hcb 090205 28218 deb

#si pas dernier lu
If  [F:CUL]CUNSSSNUM  = ""
   Call VIREBOUT(CHAINE,"abc") From GOBJET
Endif

#Bouton déblocage  absent si liste deja dévérouillée
If [F:CUL]CUNLOKFLG  = 1
   Call VIREBOUT(CHAINE,"a") From GOBJET
Endif

#Bouton validation absent si liste deja validée ou close
If [F:CUL]CUNLISSTA  > 4
   Call VIREBOUT(CHAINE,"b") From GOBJET
   Call VIREBOUT(CHAINE,"a") From GOBJET
Endif

#Bouton cloture absent si liste deja close
If [F:CUL]CUNLISSTA  = 6
   Call VIREBOUT(CHAINE,"c") From GOBJET
   Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
# Pas de sections analytiques si invisible
If [F:DTR]HEACCECOD=3
   Call VIREBOUT(CHMEN,"M") From GOBJET
Endif
# hcb 74380 deb
If GSTAIMG(3) = 1
   #Boutons cloture, validation, abandon, enregistrement, absents si liste lockée
   Call VIREBOUT(CHAINE,"c") From GOBJET
   Call VIREBOUT(CHAINE,"b") From GOBJET
   Call VIREBOUT(CHAINE,"a") From GOBJET
   Raz REP
Endif
# hcb 74380 fin


Return

######################################################################"
# AVANTBOUT                                                  AVANTBOUT
######################################################################"
$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
# V = Validation                    #
#-- Habilitation si on trouve V dans la chaine des boutons autorisés
Raz GBIDI2
GFCY=[M:SNL0]STOFCY
GBIDC2="V" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)  : GERR=1 : OK=0 : Return : Endif

Return


######################################################################"
# AVANT_MODFIC                                            AVANT_MODFIC
######################################################################"
$AVANT_MODFIC

#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Local Integer WI
   For WI = 0 To [M:SNL0]NBLIG-1
       If [M:SNL0]MODFLG(WI) = 2  & [M:SNL0]CTG1(WI) = 2 & [M:SNL0]CTG2(WI) = 0
#                                                            # hcb 71659 pe deb
          Raz GPE
          If GINICPT <> 0
             GPOINT = "INICPTSNL0"
             Gosub  ENTREE From EXEFNC
          Endif
          If GPE =  0
#                                                            # hcb 71659 pe fin
             If ([M:SNL0]QTYPCUNEW1 (WI)= [M:SNL0]QTYPCUNEW2 (WI))
&      &        ([M:SNL0]QTYSTUNEW1 (WI)= [M:SNL0]QTYSTUNEW2 (WI))
&      &        ([M:SNL0]PCUSTUNEW1 (WI)= [M:SNL0]PCUSTUNEW2 (WI))
&      &        ([M:SNL0]ZERSTOFLG1 (WI)= [M:SNL0]ZERSTOFLG2 (WI))
                [M:SNL0]QTYPCUNEW  (WI)= [M:SNL0]QTYPCUNEW2 (WI)
                [M:SNL0]QTYSTUNEW  (WI)= [M:SNL0]QTYSTUNEW2 (WI)
                [M:SNL0]PCUSTUNEW  (WI)= [M:SNL0]PCUSTUNEW2 (WI)
                [M:SNL0]ZERSTOFLG  (WI)= [M:SNL0]ZERSTOFLG2 (WI)
             Endif
          Endif                                              # hcb 71659 pe
       Endif
   Next
Endif
If [M:SNL0]MODFLG3 <> 0
   If [M:SNL0]CTGUSR <> ""
      Call MAJTEXTRA([M:SNL0]CTGUSR,"CUNLISTE","CTGUSR",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")     From ATEXTRA
   Else
      Call SUPTEXTRA("CUNLISTE","CTGUSR",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")     From ATEXTRA
   Endif
   If [M:SNL0]CTGUSR1 <> ""
      Call MAJTEXTRA([M:SNL0]CTGUSR1,"CUNLISTE","CTGUSR1",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")   From ATEXTRA
   Else
      Call SUPTEXTRA("CUNLISTE","CTGUSR1",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")   From ATEXTRA
   Endif
   If [M:SNL0]CTGUSR2 <> ""
      Call MAJTEXTRA([M:SNL0]CTGUSR2,"CUNLISTE","CTGUSR2",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")   From ATEXTRA
   Else
      Call SUPTEXTRA("CUNLISTE","CTGUSR2",[F:CUL]CUNSSSNUM,"[F:CUL]CUNLISNUM")   From ATEXTRA
   Endif
Endif
#                                                                                         # hcb 71659 fin

Gosub MOD_INV_RGP From STKINV

Effzo [M:SNL0]25
#                                                                                         # hcb 71659 deb
Local Integer WLODCOD1
WLODCOD1 = [F:SRT]LODCOD1
If [M:SNL0]MULCTGFLG = 2
   Raz [F:SRT]LODCOD1
Endif
#                                                                                         # hcb 71659 fin
Gosub LOAD_SNL0   From SUBSNL
[F:SRT]LODCOD1 = WLODCOD1                                                                 # hcb 71659

Return

######################################################################"
# APRES_MOD                                                  APRES_MOD
######################################################################"
$APRES_MOD
Local Integer LRET
Call STKDELRES(0,[M:SNL0]STOFCY,"",LRET) From STKLOC

Return

######################################################################"
# LIENS                                                          LIENS
######################################################################"
$LIENS
Effzo [M:SNL0]25

Gosub LOAD_SNL0 From SUBSNL
Gosub FORMAT_INV_MULTI From STKINV                                                        # hcb 71659

Return

######################################################################"
# FILGAUCHE                                                  FILGAUCHE
######################################################################"
$FILGAUCHE
# dans la liste gauche n apparaissent pas les session en cours de création
Default File [CUL]
#FILGAUSUP += '[F:CUN]CUNSSSSTA > 1'

Return

######################################################################"
# DEFTRANS                                                    DEFTRANS
######################################################################"
$DEFTRANS

Local Shortint OUVFICFLG
If GFONC1 <> "GESSNL" Raz GFLAG Endif
If GFLAG<>""
  Read [F:SRT] SRT0=6;GFLAG
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0
        Local File ACCES  [ACC]
        OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return
######################################################################"
# VARIANTE                                                    VARIANTE
######################################################################"
$VARIANTE
# La transaction lue est elle utilisable ?
Read [SRT]SRT0=6;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2
   OK = 0
Endif

Return
######################################################################"
# SETTRANS                                                    SETTRANS
######################################################################"
$SETTRANS
If clalev([F:SRT])=0 Local File STKTRS      [SRT]  Endif
Read [SRT]SRT0=6;GFLAG

Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0    # Ana
If fstat                                                 # Ana
   Raz [F:DTR]                                           # Ana
Endif                                                    # Ana

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GSNLNUM = [F:SRT]SRTNUM       # hcb 50197

Return

########################################################################
# MAJ_ANA_CUL     Maj Analytique suivant saisie SAISTOANA dans CUNLISTE
########################################################################
$MAJ_ANA_CUL
Call DEBTRANS From GLOCK
Trbegin [CUL]
Readlock [CUL]CUL0=[M:SNL0]CUNSSSNUM;[M:SNL0]CUNLISNUM
Case fstat
     When 0 :
     When 1 :
          GOK = -1
          GMESSAGE = mess(20,100,1)-"CUNLISTE"-[M:SNL0]CUNLISNUM
          Gosub AB_TRT From STKINV
          Return
     When Default :
          GOK = 0
          Call FSTA("CUL") From GLOCK
          Gosub AB_TRT From STKINV
          Return
Endcase
Local Integer Y

For Y=1 To GNBDIE                                # Ana
    [F:CUL]CCE(Y-1) = [M]CCE(Y-1)            # Ana
Next                                             # Ana

[F:CUL]UPDUSR    = GUSER
[F:CUL]UPDDAT    = date$
Rewrite  [CUL]
If fstat
   GOK = 0
   Call FSTA("CUL") From GLOCK
   Gosub AB_TRT From STKINV
   Return
Endif

Commit
Return

########################################################################
# MAJ_ANA_CUD     Maj Analytique suivant saisie SAISTOANA dans CUNLISDET
########################################################################
$MAJ_ANA_CUD

Local Integer Y
Call DEBTRANS From GLOCK
Trbegin [CUD]

Filter [CUD] Where STOFCY     = [M:SNL1]STOFCY        &
&                  ITMREF     = [M:SNL1]ITMREF        &
&                  CUNLISNUM  = [M:SNL1]CUNLISNUM     &
&                  CUNSSSNUM  = [M:SNL1]CUNSSSNUM
&            Order By Key CUD1
For [CUD]
    Readlock [CUD] Curr
    If fstat
       GOK  = 0
       Call FSTA("CUD") From GLOCK
       Gosub AB_TRT From STKINV
       Break
    Endif

    [F:CUD]UPDUSR   = GUSER
    [F:CUD]UPDDAT   = date$
    For Y=1 To GNBDIE                                # Ana
        [F:CUD]CCE(Y-1) = [M]CCE(Y-1)            # Ana
    Next                                             # Ana

    Rewrite [F:CUD]
    If fstat
       GOK = 0
       Call FSTA("CUD") From GLOCK
       Gosub AB_TRT From STKINV
       Break
    Endif
Next

If GOK = 0
   Return
Endif

Commit

Return

