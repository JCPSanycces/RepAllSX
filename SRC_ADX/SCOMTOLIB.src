#########################################################################
$SUP_MTO_SCM
If [F:SCM]SCOFLG = 3  : Return : Endif

Gosub CHECK_MTO From MTOLINKLIB

# raz des affectations
Raz [M:MLIK]
# GH 18/06/12
#If func MTOLINKLIB.IS_DIRECT_ORDER([F:SCI]PRHFCY, 36, [F:SCM]SCONUM, [F:SCM]SCILIN, 0)
#    [M:MLIK]FMIFLG = 9  # pour forcer la suppression
