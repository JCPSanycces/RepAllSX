[M:MLIK]DEMTYP    = 36
[M:MLIK]DEMNUM    = [F:SCM]SCONUM
[M:MLIK]DEMLIN    = [F:SCM]SCILIN
[M:MLIK]DEMSEQ    = [F:SCM]SCMLIN
[M:MLIK]DWIPTYP   = 3
[M:MLIK]FRCPRO    = 2                     # pour supprimer les affectations forcées
