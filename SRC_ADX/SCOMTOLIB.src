#########################################################################
$VERF_ANU
Local Integer WRET

Gosub CHECK_MTO From MTOLINKLIB

WRET = 0
Call CHECK_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WRET) From MTOLINKLIB
If WRET
    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:SCO1]PTOCOD
        Read [PTO]PTO0=[M:SCO1]PTOCOD
        If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]FRCPRO <> 2
        OK = 1
        # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
        Call OUINON(mess(227,190,1),OK) From GESECRAN
        If OK = 1 : OK = 0 : Return : Endif
    Endif
Endif
Return

#########################################################################
$CTL_MAJ_EOFP
# passage du statut Ferme à Planifié: ctrl de présence d'affectations
Local Integer IFRC, WRET

Gosub CHECK_MTO From MTOLINKLIB

IFRC = 0 : WRET = 0
Call CHECK_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WRET) From MTOLINKLIB
If WRET
    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:SCO1]PTOCOD
        Read [PTO]PTO0=[M:SCO1]PTOCOD
        If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]FRCPRO <> 2 : IFRC = 1 : Endif
Endif

OK = 2
If IFRC
  # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
  Call OUINON(mess(227,190,1),OK) From GESECRAN
Endif
Return

#############################################################################
$MAJ_MTO_AP_ALL
Local Integer IMAT, K,  N
Local Libelle WMTOMAJ
Local Decimal WDEMQTY, WFRCQTY
#Local Integer WTYP2, WLIN2, WSEQ2
#Local Char    WNUM2(GLONVCR)

IMAT = 1 + [M:SCO2]NBLIG
If IMAT>0
 Local Char    TITM(GLONITM) (IMAT)
 Local Char    TFCY(GLONFCY) (IMAT)
 Local Char    TELT(1+GLONITM+GLONFCY) (IMAT)
 Local Libelle TFRC(IMAT)
Endif

Gosub CHECK_MTO From MTOLINKLIB

# si contremarque, on modifie la qté de l'affectation
If func MTOLINKLIB.IS_DIRECT_ORDER([M:SCO1]PRHFCY, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0)
# GH 09/07/2014 bug 101361
#    Call GET_DIRECT_ORDER([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13,
#&                         WTYP2, WNUM2, WLIN2, WSEQ2) From MTOLINKLIB
    GOK=0
    If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
    Filter [ORDB] Where ITMREF=[M:SCO0]ITMREF
    Read [ORDB]ORD3 = [M:SCO1]PRHFCY;2;[M:SCO1]VCRNUMORI;[M:SCO1]VCRLINORI;[M:SCO1]VCRSEQORI
    #Read [ORDB]ORD3 = [M:SCO1]PRHFCY;2;WNUM2;WLIN2;WSEQ2
    If !fstat
        WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
        Filter [ORDB] Where WIPTYP=13 & ITMREF=[M:SCO0]ITMREF
        Read [ORDB]ORD3 = [M:SCO1]PRHFCY;36;[M:SCO0]SCONUM;[M:SCO1]SCILIN;0
        If !fstat
           WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
           GOK=1
        Endif
    Endif
    Filter [ORDB]
    If !GOK : GOK=1 : Goto NXT_MAJ_MTOI : Endif

    Trbegin [MLK]
        Raz [M:MLIK]
        [M:MLIK]MAJCOD  = "M"
        [M:MLIK]ITMREF  = [M:SCO0]ITMREF
        [M:MLIK]STOFCY  = [M:SCO1]PRHFCY
        # la demande
        [M:MLIK]DEMTYP  = 2
        #[M:MLIK]DEMNUM  = WNUM2
        #[M:MLIK]DEMLIN  = WLIN2
        #[M:MLIK]DEMSEQ  = WSEQ2
        [M:MLIK]DEMNUM  = [M:SCO1]VCRNUMORI
        [M:MLIK]DEMLIN  = [M:SCO1]VCRLINORI
        [M:MLIK]DEMSEQ  = [M:SCO1]VCRSEQORI
        [M:MLIK]DWIPTYP = 1
        # la ressource
        [M:MLIK]RESSTYP = 36
        [M:MLIK]RESSNUM = [M:SCO0]SCONUM
        [M:MLIK]RESSLIN = [M:SCO1]SCILIN
        [M:MLIK]RESSSEQ = 0
        # quantité
        [M:MLIK]LIKQTY  = WDEMQTY
        [M:MLIK]FRCFLG  = 2
        [M:MLIK]FMIFLG  = 2

        Call UPDMTOLINK             From MTOLINKLIB
        If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
         Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
        Endif
    If GOK : Commit : Else : Rollback : Endif
    Goto NXT_MAJ_MTOI
Endif

# lecture règle si nécessaire
If [F:PTO]PTOCOD <> [M:SCO1]PTOCOD
    Read [PTO]PTO0=[M:SCO1]PTOCOD
    If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

If WMTOMAJ
    K=find([M:SCO0]ITMREF-[M:SCO1]PRHFCY,TELT(0..N-1))-1
    If K<0
       TELT(N)=[M:SCO0]ITMREF-[M:SCO1]PRHFCY
       TITM(N)=[M:SCO0]ITMREF
       TFCY(N)=[M:SCO1]PRHFCY
       TFRC(N)=1+([F:PTO]FRCPRO=2)
       K=N : N+=1
    Endif
Endif

If !WMTOMAJ | TFRC(K) <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where WIPTYP=13 & ITMREF=[M:SCO0]ITMREF
   Read [ORDB]ORD3 = [M:SCO1]PRHFCY;36;[M:SCO0]SCONUM;[M:SCO1]SCILIN;0
   Filter [ORDB]
   If !fstat
      If !WMTOMAJ
         Call GET_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, -36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WDEMQTY) From MTOLINKLIB
      Endif
     Call GET_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
        GOK=1
        Trbegin [MLK]
            Raz [M:MLIK]
            If !WMTOMAJ
                [M:MLIK]MAJCOD    = "R"
                [M:MLIK]PRPTYP    = 1                # annule & remplace
                [M:MLIK]PRPMOD    = 1                # mise à jour
            Else
                [M:MLIK]MAJCOD    = "Z"
            Endif
            [M:MLIK]STOFCY    = [M:SCO1]PRHFCY
            [M:MLIK]ITMREF    = [M:SCO0]ITMREF
            [M:MLIK]RESSTYP   = 36
            [M:MLIK]RESSNUM   = [M:SCO0]SCONUM
            [M:MLIK]RESSLIN   = [M:SCO1]SCILIN
            [M:MLIK]RESSSEQ   = 0
            [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
            [M:MLIK]FEEDBACK  = 1
            Call UPDMTOLINK From MTOLINKLIB
        If GOK>0 : Commit : Else Rollback : Endif
     Endif
   Endif
Endif

$NXT_MAJ_MTOI
# boucle sur les matières
For IMAT = 0 To [M:SCO2]NBLIG - 1

    # si matière soldée ou exclue
    If [M:SCO2]MATSTA(IMAT) > 2  : Goto NXT_MAJ_MTOM : Endif

    # si composant autre qu'une matière
    If [M:SCO2]CPNTYP(IMAT) <> 1 : Goto NXT_MAJ_MTOM : Endif

    # si matière fournie par le sous-traitant
    If [M:SCO2]SCOFLG(IMAT) = 3  : Goto NXT_MAJ_MTOM : Endif

    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:SCO2]PTOCOD(IMAT)
        Read [PTO]PTO0=[M:SCO2]PTOCOD(IMAT)
        If fstat : Raz [F:PTO] : Endif
    Endif

    WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4DEM=2)

    If WMTOMAJ
        K=find([M:SCO2]CPNITMREF(IMAT)-[M:SCO2]STOFCY(IMAT),TELT(0..N-1))-1
        If K<0
           TELT(N)=[M:SCO2]CPNITMREF(IMAT)-[M:SCO2]STOFCY(IMAT)
           TITM(N)=[M:SCO2]CPNITMREF(IMAT)
           TFCY(N)=[M:SCO2]STOFCY(IMAT)
           TFRC(N)=1+([F:PTO]FRCPRO=2)
           K=N : N+=1
        Endif
    Endif

    If !WMTOMAJ | TFRC(K) <> 2
       If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
       Filter [ORDB] Where WIPTYP=3 & ITMREF=[M:SCO2]CPNITMREF(IMAT)
       Read [ORDB]ORD3 = [M:SCO2]STOFCY(IMAT);36;[M:SCO0]SCONUM;[M:SCO1]SCILIN;[M:SCO2]SCMLIN(IMAT)
       Filter [ORDB]
       If !fstat
         If !WMTOMAJ
            Call GET_FRCQTY([M:SCO2]STOFCY(IMAT), [M:SCO2]CPNITMREF(IMAT), -36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, [M:SCO2]SCMLIN(IMAT), 3, WDEMQTY) From MTOLINKLIB
         Endif
         Call GET_FRCQTY([M:SCO2]STOFCY(IMAT), [M:SCO2]CPNITMREF(IMAT), 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, [M:SCO2]SCMLIN(IMAT), 3, WFRCQTY) From MTOLINKLIB
         If WFRCQTY > ([F:ORDB]RMNEXTQTY-[F:ORDB]ALLQTY) | (!WMTOMAJ & WDEMQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
            # demande sur-affectée
            GOK=1
            Trbegin [MLK]
                Raz [M:MLIK]
                If !WMTOMAJ
                    [M:MLIK]MAJCOD    = "R"
                    [M:MLIK]PRPTYP    = 1                # annule & remplace
                    [M:MLIK]PRPMOD    = 1                # mode mise à jour
                Else
                    [M:MLIK]MAJCOD    = "Z"
                Endif
                [M:MLIK]STOFCY    = [M:SCO2]STOFCY(IMAT)
                [M:MLIK]ITMREF    = [M:SCO2]CPNITMREF(IMAT)
                [M:MLIK]DEMTYP    = 36
                [M:MLIK]DEMNUM    = [M:SCO0]SCONUM
                [M:MLIK]DEMLIN    = [M:SCO1]SCILIN
                [M:MLIK]DEMSEQ    = [M:SCO2]SCMLIN(IMAT)
                [M:MLIK]DWIPTYP   = 3
                [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
                [M:MLIK]FEEDBACK  = 1
                Call UPDMTOLINK From MTOLINKLIB
            If GOK>0 : Commit : Else Rollback : Endif
         Endif
       Endif
    Endif

$NXT_MAJ_MTOM
Next IMAT

For IMAT = 0 To N - 1
   # recalcul complet des affectations de l'article suivant la règle
   GOK=1
   Trbegin [MLK]
        Raz [M:MLIK]
        [M:MLIK]MAJCOD    = "P"
        [M:MLIK]PRPTYP    = 1                    # annule & remplace
        [M:MLIK]PRPMOD    = 1                    # mode mise à jour
        [M:MLIK]STOFCY    = TFCY(IMAT)
        [M:MLIK]ITMREF    = TITM(IMAT)
        [M:MLIK]FEEDBACK  = 1
        [M:MLIK]FRCPRO    = TFRC(IMAT)
        Call UPDMTOLINK From MTOLINKLIB
    If GOK>0 : Commit : Else Rollback : Endif
Next IMAT
Return

#########################################################################
$MAJ_MTO_SCI
Local Decimal WDEMQTY, WFRCQTY
Local Libelle WMTOMAJ
Local Char    WPTOCOD(GLONPTO) : # V6 Règle d'affectation
#Local Integer WTYP2, WLIN2, WSEQ2
#Local Char    WNUM2(GLONVCR)

Gosub CHECK_MTO From MTOLINKLIB

# si contremarque, on modifie la qté de l'affectation
If func MTOLINKLIB.IS_DIRECT_ORDER([F:SCI]PRHFCY, 36, [F:SCI]SCONUM, [F:SCI]SCILIN, 0)
# GH 09/07/2014 bug 101361
#    Call GET_DIRECT_ORDER([F:SCI]PRHFCY, [F:SCI]ITMREF, 36, [F:SCI]SCONUM, [F:SCI]SCILIN, 0, 13,
#&                         WTYP2, WNUM2, WLIN2, WSEQ2) From MTOLINKLIB
    GOK=0
    If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
    Filter [ORDB] Where ITMREF=[F:SCI]ITMREF
    Read [ORDB]ORD3 = [F:SCI]PRHFCY;2;[F:SCI]VCRNUMORI;[F:SCI]VCRLINORI;[F:SCI]VCRSEQORI
    #Read [ORDB]ORD3 = [F:SCI]PRHFCY;2;WNUM2;WLIN2;WSEQ2
    If !fstat
        WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
        Filter [ORDB] Where WIPTYP=13 & ITMREF=[F:SCI]ITMREF
        Read [ORDB]ORD3 = [F:SCI]PRHFCY;36;[F:SCI]SCONUM;[F:SCI]SCILIN;0
        If !fstat
           WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
           GOK=1
        Endif
    Endif
    Filter [ORDB]
    If !GOK : GOK=1
       Return : # Goto NXT_MAJ_MTOI : # GH 26/07/13 bug 91385
    Endif

    #Trbegin [MLK] :  # GH 26/07/13 bug 91385
        Raz [M:MLIK]
        [M:MLIK]MAJCOD  = "M"
        [M:MLIK]ITMREF  = [F:SCI]ITMREF
        [M:MLIK]STOFCY  = [F:SCI]PRHFCY
        # la demande
        [M:MLIK]DEMTYP  = 2
        #[M:MLIK]DEMNUM  = WNUM2
        #[M:MLIK]DEMLIN  = WLIN2
        #[M:MLIK]DEMSEQ  = WSEQ2
        [M:MLIK]DEMNUM  = [F:SCI]VCRNUMORI
        [M:MLIK]DEMLIN  = [F:SCI]VCRLINORI
        [M:MLIK]DEMSEQ  = [F:SCI]VCRSEQORI
        [M:MLIK]DWIPTYP = 1
        # la ressource
        [M:MLIK]RESSTYP = 36
        [M:MLIK]RESSNUM = [F:SCI]SCONUM
        [M:MLIK]RESSLIN = [F:SCI]SCILIN
        [M:MLIK]RESSSEQ = 0
        # quantité
        [M:MLIK]LIKQTY  = WDEMQTY
        [M:MLIK]FRCFLG  = 2
        [M:MLIK]FMIFLG  = 2
        # Issue 107513/US2 GA 04/2015 : ECC for table SCOITM
        If dim([M:MLIK]ECCVALMAJ)>0 & [F:ITM]ITMREF=[F:SCI]ITMREF & [F:ITM]ECCSTO>1
           [M:MLIK]ECCVALMAJ=[F:SCI]ECCVALMAJ
        Endif
        If dim([M:MLIK]ECCVALMIN)>0 & [F:ITM]ITMREF=[F:SCI]ITMREF & [F:ITM]ECCSTO>2
           [M:MLIK]ECCVALMIN=[F:SCI]ECCVALMIN
        Endif

        Call UPDMTOLINK             From MTOLINKLIB
        If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
         Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
        Endif
    Return : #If GOK : Commit : Else : Rollback : Endif : Goto NXT_MAJ_MTOI : # GH 26/07/13 bug 91385
Endif

WPTOCOD = func ITMLIB.GET_PTOCOD([F:SCI]ITMREF,[F:SCI]PRHFCY)
# lecture règle si nécessaire
If [F:PTO]PTOCOD <> WPTOCOD
    Read [PTO]PTO0=WPTOCOD
    If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

If !WMTOMAJ | [F:PTO]FRCPRO <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where WIPTYP=13 & ITMREF=[F:SCI]ITMREF
   Read [ORDB]ORD3 = [F:SCI]PRHFCY;36;[F:SCI]SCONUM;[F:SCI]SCILIN;0
   Filter [ORDB]
   If !fstat
     If !WMTOMAJ
        Call GET_FRCQTY([F:SCI]PRHFCY, [F:SCI]ITMREF, -36, [F:SCI]SCONUM, [F:SCI]SCILIN, 0, 13, WDEMQTY) From MTOLINKLIB
     Endif
     Call GET_FRCQTY([F:SCI]PRHFCY, [F:SCI]ITMREF, 36, [F:SCI]SCONUM, [F:SCI]SCILIN, 0, 13, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
        # GH 26/07/13 bug 91385
        #GOK=1
        #Trbegin [MLK]
            Raz [M:MLIK]
            If !WMTOMAJ
                [M:MLIK]MAJCOD    = "R"
                [M:MLIK]PRPTYP    = 1                # annule & remplace
                [M:MLIK]PRPMOD    = 1                # mise à jour
            Else
                [M:MLIK]MAJCOD    = "Z"
            Endif
            [M:MLIK]STOFCY    = [F:SCI]PRHFCY
            [M:MLIK]ITMREF    = [F:SCI]ITMREF
            [M:MLIK]RESSTYP   = 36
            [M:MLIK]RESSNUM   = [F:SCI]SCONUM
            [M:MLIK]RESSLIN   = [F:SCI]SCILIN
            [M:MLIK]RESSSEQ   = 0
            [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
            [M:MLIK]FEEDBACK  = 1
            Call UPDMTOLINK From MTOLINKLIB
        #If GOK>0 : Commit : Else Rollback : Endif : # GH 26/07/13 bug 91385
     Endif
   Endif
Endif

# GH 26/07/13 bug 91385
If WMTOMAJ
    # recalcul complet des affectations de l'article suivant la règle
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    # annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = [F:SCI]PRHFCY
    [M:MLIK]ITMREF    = [F:SCI]ITMREF
    [M:MLIK]FRCPRO    = [F:PTO]FRCPRO
    [M:MLIK]FEEDBACK  = 1
    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
Endif
#
Return

#########################################################################
$MAJ_MTO_SCM
Local Char    WPTOCOD(GLONPTO)
Local Decimal WFRCQTY, WDEMQTY
Local Libelle WMTOMAJ

Gosub CHECK_MTO From MTOLINKLIB

# pas de contremarque

WPTOCOD = func ITMLIB.GET_PTOCOD([F:SCM]CPNITMREF,[F:SCM]STOFCY)
# lecture règle si nécessaire
If [F:PTO]PTOCOD <> WPTOCOD
   Read [PTO]PTO0=WPTOCOD
   If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4DEM=2)

If !WMTOMAJ | [F:PTO]FRCPRO <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where WIPTYP=3 & ITMREF=[F:SCM]CPNITMREF
   Read [ORDB]ORD3 = [F:SCM]STOFCY;36;[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN
   Filter [ORDB]
   If !fstat
     If !WMTOMAJ
        Call GET_FRCQTY([F:SCM]STOFCY, [F:SCM]CPNITMREF, -36, [F:SCM]SCONUM, [F:SCM]SCILIN, [F:SCM]SCMLIN, 3, WDEMQTY) From MTOLINKLIB
     Endif
     Call GET_FRCQTY([F:SCM]STOFCY, [F:SCM]CPNITMREF, 36, [F:SCM]SCONUM, [F:SCM]SCILIN, [F:SCM]SCMLIN, 3, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > ([F:ORDB]RMNEXTQTY-[F:ORDB]ALLQTY) | (!WMTOMAJ & WDEMQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
        # demande sur-affectée
        Raz [M:MLIK]
        If !WMTOMAJ
            [M:MLIK]MAJCOD    = "R"
            [M:MLIK]PRPTYP    = 1                # annule & remplace
            [M:MLIK]PRPMOD    = 1                # mode mise à jour
        Else
            [M:MLIK]MAJCOD    = "Z"
        Endif
        [M:MLIK]STOFCY    = [F:SCM]STOFCY
        [M:MLIK]ITMREF    = [F:SCM]CPNITMREF
        [M:MLIK]DEMTYP    = 36
        [M:MLIK]DEMNUM    = [F:SCM]SCONUM
        [M:MLIK]DEMLIN    = [F:SCM]SCILIN
        [M:MLIK]DEMSEQ    = [F:SCM]SCMLIN
        [M:MLIK]DWIPTYP   = 3
        [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
        [M:MLIK]FEEDBACK  = 1
        # Issue 107513/US2 GA 04/2015 : ECC for table SCOMAT
        If dim([M:MLIK]ECCVALMAJ)>0 & [F:ITM]ITMREF=[F:SCM]CPNITMREF & [F:ITM]ECCSTO>1
           [M:MLIK]ECCVALMAJ=[F:SCM]ECCVALMAJ
        Endif
        If dim([M:MLIK]ECCVALMIN)>0 & [F:ITM]ITMREF=[F:SCM]CPNITMREF & [F:ITM]ECCSTO>2
           [M:MLIK]ECCVALMIN=[F:SCM]ECCVALMIN
        Endif
        GOK=1
        Call UPDMTOLINK From MTOLINKLIB
     Endif
   Endif
Endif

If WMTOMAJ
    # recalcul complet des affectations de l'article suivant la règle
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    # annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = [F:SCM]STOFCY
    [M:MLIK]ITMREF    = [F:SCM]CPNITMREF
    [M:MLIK]FRCPRO    = [F:PTO]FRCPRO
    [M:MLIK]FEEDBACK  = 1
    # Issue 107513/US2 GA 04/2015 : ECC for table SCOMAT
    If dim([M:MLIK]ECCVALMAJ)>0 & [F:ITM]ITMREF=[F:SCM]CPNITMREF & [F:ITM]ECCSTO>1
       [M:MLIK]ECCVALMAJ=[F:SCM]ECCVALMAJ
    Endif
    If dim([M:MLIK]ECCVALMIN)>0 & [F:ITM]ITMREF=[F:SCM]CPNITMREF & [F:ITM]ECCSTO>2
       [M:MLIK]ECCVALMIN=[F:SCM]ECCVALMIN
    Endif
    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
Endif
Return

#########################################################################
# création affectation entre SO et EO (PEC ou contremarque)
$CRE_MTO_SO_EO
# GH 25/04/2014 bug 84573 affectation générée ssi cde vente sans ctm ou avec ctm=SST
If !find([M:SCOK]FMI,1,5) : Return : Endif

Gosub CHECK_MTO From MTOLINKLIB

If [M:SCOK]FMI <> 5
  Local Char WPTOCOD(GLONPTO)
  WPTOCOD = func ITMLIB.GET_PTOCOD([M:SCOK]ITMREF,[M:SCOK]PRHFCY)
  # lecture règle si nécessaire
  If [F:PTO]PTOCOD <> WPTOCOD
     Read [PTO]PTO0=WPTOCOD
     If fstat : Raz [F:PTO] : Endif
  Endif

  # si affectation temps réel non active et pas une contremarque -> pas d'affectation
  If [F:PTO]PTOREAL < 2 : Return : Endif
Endif

GOK=0
Local Decimal WDEMQTY
If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
Filter [ORDB] Where ITMREF=[M:SCOK]ITMREF
Read [ORDB]ORD3 = [M:SCOK]PRHFCY;2;[M:SCOK]VCRNUMORI;[M:SCOK]VCRLINORI;[M:SCOK]VCRSEQORI
If !fstat
 If ([M:SCOK]FMI<>5 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0                    # GH 25/04/2014 bug 84573
   WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY - [F:ORDB]MTOQTY              # GH 11/10/2012 bug 84918 # [F:ORDB]EXTQTY - [F:ORDB]ALLQTY
   Filter [ORDB] Where WIPTYP=13 & ITMREF=[M:SCOK]ITMREF
   Read [ORDB]ORD3 = [M:SCOK]PRHFCY;36;[M:SCOK]SCONUM;[M:SCOK]SCILIN;0
   If !fstat
    If ([M:SCOK]FMI<>5 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0                 # GH 25/04/2014 bug 84573
      WDEMQTY = min([F:ORDB]RMNEXTQTY-[F:ORDB]MTOQTY,WDEMQTY)                 # GH 11/10/2012 bug 84918 # min([F:ORDB]RMNEXTQTY,WDEMQTY)
      If [M:SCOK]CODMAJ ="S" : WDEMQTY = min(WDEMQTY,[M:SCOK]EXTQTY) : Endif  # GH 15/05/2014 bug 99197
      If WDEMQTY>0 : GOK=1 : Endif
    Endif
   Endif
 Endif
Endif
Filter [ORDB]
If !GOK : GOK=1 : Return : Endif

Raz [M:MLIK]
[M:MLIK]MAJCOD  = "C"
[M:MLIK]STOFCY  = [M:SCOK]PRHFCY
[M:MLIK]ITMREF  = [M:SCOK]ITMREF
# la demande
[M:MLIK]DEMTYP  = 2
[M:MLIK]DEMNUM  = [M:SCOK]VCRNUMORI
[M:MLIK]DEMLIN  = [M:SCOK]VCRLINORI
[M:MLIK]DEMSEQ  = [M:SCOK]VCRSEQORI
[M:MLIK]DWIPTYP = 1
# la ressource
[M:MLIK]RESSTYP = 36
[M:MLIK]RESSNUM = [M:SCOK]SCONUM
[M:MLIK]RESSLIN = [M:SCOK]SCILIN
[M:MLIK]RESSSEQ = 0
# quantité
[M:MLIK]LIKQTY  = WDEMQTY
[M:MLIK]FRCFLG  = 2
If [M:SCOK]FMI  = 6 : [M:MLIK]FMIFLG  = 2 : Else [M:MLIK]FMIFLG  = 1 : Endif
# Issue 107513/US2 GA 04/2015 : ECC for table SCOITM
If dim([M:MLIK]ECCVALMAJ)>0 & [F:ITM]ITMREF=[M:SCOK]ITMREF & [F:ITM]ECCSTO>1
   [M:MLIK]ECCVALMAJ=[M:SCOK]ECCVALMAJ
Endif
If dim([M:MLIK]ECCVALMIN)>0 & [F:ITM]ITMREF=[M:SCOK]ITMREF & [F:ITM]ECCSTO>2
   [M:MLIK]ECCVALMIN=[M:SCOK]ECCVALMIN
Endif

Call UPDMTOLINK             From MTOLINKLIB
If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
   Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
Endif
Return

###########################################
# Allocation basée sur affectation
# $MAJ_MTO_ALLOCATION de PURMTOLIB
###########################################

