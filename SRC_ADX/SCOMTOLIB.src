#<AdxTL>@(#)5.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# **** SCOMTOLIB selon MFGMTOLIB                              GA 07/2008    #
# voir aussi MFGMTOLIB,SCOMTOLIB,PURMTOLIB,SALMTOLIB en cas de mise à jour  #
#---------------------------------------------------------------------------#
# $AVANT_MODFIC    Action  AVANT_MODFIC         de SUBSCOA
# $MAJ_MTO_AP_ALL  Actions APRES_CRE, APRES_MOD de SUBSCOA
# $SUP_MTO_AV_ALL  Action  AV_ANNULE            de SUBSCOA
# CTL_MAJ_EOFP     Appel   C_SCOSTA             de SUBSCO1
# VERF_ANU         Appel   VERF_ANU             de SUBSCOA
#---------------------------------------------------------------------------#
# $SUP_MTO_SCI     Appel de SCOAUTLIB
# $SUP_MTO_SCM     Appel de SCOAUTLIB
# $MAJ_MTO_SCI     Appel de SCOAUTLIB
# $MAJ_MTO_SCM     Appel de SCOAUTLIB
# $CRE_MTO_SO_EO   Appel de SCOAUTLIB
#---------------------------------------------------------------------------#
# FQ 73203 GA 04/2011 Problème suite FQ 71360 remplacer [ORD1] par [ORDB]
#############################################################################
$AVANT_MODFIC
Local Integer IMAT

Gosub CHECK_MTO From MTOLINKLIB

# V6 Affectations
# ici il faut supprimer les affectations des:
#     - EOs passés de ferme à planifié
#     - articles lancés présents dans l'EO avant modification et absents du tableau
#     - articles lancés soldés
#     - matières exclues/soldées
# car la suppression des affectations s'appuie sur les encours

# changement d'article lancé
For [SCI]SCI0 Where SCONUM = [M:SCO0]SCONUM
    If [F:SCI]ITMREF<>[M:SCO0]ITMREF : Gosub SUP_MTO_AV_SCI : Endif
Next

If [M:SCO1]SCOSTA = 2 & [F:SCO]SCOSTA = 1
   # si passage de ferme à planifié
   Gosub SUP_MTO_AV_ALL

Else
   # si l'article lancé est commandé, réceptionné ou soldé
   If [M:SCO1]ITMSTA > 2
      Gosub SUP_MTO_AV_SCO1
   Endif

   # les matières soldées, exclues, commandées ou réceptionnées & type de composant normal & Type d'appro <> fournie par le sous-traitant
   For IMAT = 0 To [M:SCO2]NBLIG - 1
       If [M:SCO2]MATSTA(IMAT) > 2 & [M:SCO2]CPNTYP(IMAT) = 1 & [M:SCO2]SCOFLG(IMAT) <> 3
           Gosub SUP_MTO_AV_SCO2
       Endif
   Next IMAT
Endif
Return

#########################################################################
$SUP_MTO_AV_ALL
Local Integer IMAT

Gosub CHECK_MTO From MTOLINKLIB

# raz des affectations
Raz [M:MLIK]
## GH 18/06/12
#If func MTOLINKLIB.IS_DIRECT_ORDER([M:SCO1]PRHFCY, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0)
#      [M:MLIK]FMIFLG = 9  # pour forcer la suppression
#Else
#    [M:MLIK]FMIFLG = 1
#Endif
[M:MLIK]MAJCOD    = "Z"
[M:MLIK]STOFCY    = [M:SCO1]PRHFCY
[M:MLIK]ITMREF    = [M:SCO0]ITMREF
[M:MLIK]RESSTYP   = 36
[M:MLIK]RESSNUM   = [M:SCO0]SCONUM
[M:MLIK]RESSLIN   = [M:SCO1]SCILIN
[M:MLIK]RESSSEQ   = 0
[M:MLIK]FRCPRO    = 2                # pour supprimer les affectations forcées
[M:MLIK]FMIFLG    = 9                # pour supprimer les affectations de contremarque  # GH 18/06/12
[M:MLIK]FEEDBACK  = 1

GOK=1
Call UPDMTOLINK From MTOLINKLIB
GOK=1

# boucle sur les matières
For IMAT = 0 To [M:SCO2]NBLIG - 1

    If [M:SCO2]CPNTYP(IMAT) <> 1 : Goto NXT_SUP_MTOMT : Endif

    If [M:SCO2]SCOFLG(IMAT) = 3  : Goto NXT_SUP_MTOMT : Endif

    # raz des affectations
    Raz [M:MLIK]
    [M:MLIK]MAJCOD   = "Z"
    [M:MLIK]STOFCY   = [M:SCO1]PRHFCY
    [M:MLIK]ITMREF   = [M:SCO2]CPNITMREF(IMAT)
    [M:MLIK]DEMTYP   = 36
    [M:MLIK]DEMNUM   = [M:SCO0]SCONUM
    [M:MLIK]DEMLIN   = [M:SCO1]SCILIN
    [M:MLIK]DEMSEQ   = [M:SCO2]SCMLIN(IMAT)
    [M:MLIK]DWIPTYP  = 3
    [M:MLIK]FRCPRO   = 2                    # pour supprimer les affectations forcées
    [M:MLIK]FEEDBACK = 1

    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
    GOK=1
$NXT_SUP_MTOMT
Next IMAT
Return

