#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","COPTRT","ACOPTRT",3,"XYCOPTRT") From GTRAITE
End

#---------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#---------------------------------------------------#
$INIT
TMP = 1
Return

#---------------------------------------------------#
$CONTROLE
Local Char    TABLE(GLONADC) , FICDES(GDIMFIC)
Local Char    MACDES(GLONAMC) , DOSDES(GLONADD) , FICDES(GDIMFIC)
Local Char    MACORG(GLONAMC) , DOSORG(GLONADD) , FICORG(GDIMFIC)
Local Integer STAT , OKTRT , OKSRC
Local Char    FICLCK(250)

Call MACHINE([M]DOSORG,[L]MACORG,[L]DOSORG) From ORDSYS
Call MACHINE([M]DOSDES,[L]MACDES,[L]DOSDES) From ORDSYS

TABLE = [M]TRT
Call PATHFIL(FICORG,"TRT",TABLE,"src",DOSORG,"",MACORG) From DOSCONT
If filinfo(FICORG,0)<=0
 Call ERREUR(mess(90,123,1)) From GESECRAN : # Traitement inexistant
 OK = 0 : Return
Endif
Call PATHFIL(FICDES,"TRT",TABLE,"src",DOSDES,"",MACDES) From DOSCONT
If filinfo(FICDES,0)>=0
 # Traitement $1$ existant dans le dossier $2$
 # Voulez-vous continuer ?
 OK = 1
 Call AVERTIR(func AFNC.MES2(mess(217,139,1),TABLE,DOSDES)+"\"+mess(205,100,1),OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif
Call PATHFIL(FICLCK,"TRT",TABLE,"LCKsrc",DOSDES,"",MACDES) From DOSCONT
If filinfo(FICLCK,0)>=0
 Call ERREUR("|"+FICLCK-"|\"-mess(13,139,1)) From GESECRAN : # Traitement verrouillé
 OK = 0 : Return
Endif
Return

#---------------------------------------------------#
$EXEC
# Copie dictionnaire
Call COPOBJ([M]DOSORG,[M]DOSDES,"ADC",TABLE,"","","") From ACOPIE
If GOK=1
 Gosub COPTRT
Endif
zonsui = "TRT"
SAI = 1
Return

#---------------------------------------------------#
$COPTRT
# On efface les objets destination pour propager le nouveau propriétaire de ces objets
OKSRC = 0
Call PATHFIL(FICORG,"TRT",TABLE,"src",DOSORG,"",MACORG) From DOSCONT
If filinfo(FICORG,0)>=0
 Call PATHFIL(FICDES,"TRT",TABLE,"src",DOSDES,"",MACDES) From DOSCONT
 If filinfo(FICDES,0)>0
  Call EFFACE(FICDES,STAT) From ORDSYS
 Endif
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 OKSRC = 1
Endif
Call PATHFIL(FICORG,"TRT",TABLE,"xrc",DOSORG,"",MACORG) From DOSCONT
Call PATHFIL(FICDES,"TRT",TABLE,"xrc",DOSDES,"",MACDES) From DOSCONT
If filinfo(FICDES,0)>0
 Call EFFACE(FICDES,STAT) From ORDSYS
Endif
If filinfo(FICORG,0)>=0
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
Endif
Call EXISTE_ADX(MACORG,DOSORG,TABLE,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX(MACDES,DOSDES,TABLE,STAT) From ORDSYS
Endif
Call PATHFIL(FICDES,"TRT",TABLE,"adx",DOSDES,"",MACDES) From DOSCONT
If filinfo(FICDES,0)>0
 Call EFFACE(FICDES,STAT) From ORDSYS
Endif
If OKSRC & MACDES<>"" : # mb 31.1.8 pour éviter des pb de versions d'archive
 Call VALID("TRT",TABLE,MACDES+"@"+DOSDES,STAT) From VALMSKSUB
Else
 Call COPIE_ADX(MACORG,DOSORG,TABLE,MACDES,DOSDES,TABLE,STAT) From ORDSYS
Endif
Return

#---------------------------------------------------#
Subprog C_TRT(VALEUR)
Variable Char    VALEUR()
Local Char MAC(GDIMFIC) , DOS(GDIMFIC)
Local Integer OKTRT
Call MACHINE([M]DOSORG,MAC,DOS) From ORDSYS
Call EXISTE_ADX(MAC,DOS,VALEUR,OKTRT) From ORDSYS
If !OKTRT
 GMESSAGE = mess(90,123,1) : # Traitement inexistant
 mkstat = 2 : End
Endif
End

Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AV_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AV_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AS_DOSORG(VALEUR) From ACOPIE
End

Subprog AM_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AM_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
Call AS_DOSDES(VALEUR) From ACOPIE
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORG,VALEUR) From DOSCONT
If mkstat : End : Endif
GDOSPATH = VALEUR
End

Subprog IB_DOSDES
Call IB_DOSDES From ACOPIE
End
