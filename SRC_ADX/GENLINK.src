#<AdxTL>@(#)0.0.0.0 $Revision$
#Local Char PARAM(10)(1..2) , VALEUR(10)
#Call TRAITE_CHAR(VALEUR,PARAM,"","GENLINK","",2,"") From GTRAITE

Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "GENLINK"
Call TRAITE_CHAR(VALEUR,PARAM,"","GENLINK","GENPLAN",3,"") From GTRAITE


End

$ACTION
Case ACTION
 When "INIT_DIA": Gosub INIT_DIA
 When "TIT_DIA" : TITCRIT=mess(81,10703,1) : GCURLEG = GLEGFIL
 When "EXEC"    : Gosub EXEC
 When "SORTIE"  : Gosub SORTIE
Endcase
Return

$INIT_DIA
Raz [M:DIA]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$EXEC
If dim([M:DIA]ALLLEG)>0 & [M:DIA]ALLLEG=2
  Call GENDOS (nomap)
Else
 If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
 Call GENLINK(nomap,GCURLEG)    :#Later add a screen to enter the code legislation wanted...
Endif
Return

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer I
For I=1 To GNBLEG
 Call GENLINK(APPLI,GDOSLEG(I))
Next
End

Subprog GENLINK(APPLI,LEGPLAN)
Value Char APPLI
Value Char LEGPLAN

Local Integer MAXREF
MAXREF = 100
Local Integer I , J , K , T , OK
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
Local Char    FORMULE(250)
Local Integer NRUB , NVAR , NCUM , MESSNUM
Local Char    TRUB(GLONRUB)(1..MAXREF) , TVAR(GLONVRA)(1..MAXREF) , TCUM(GLONCUM)(1..MAXREF)
Local Char    OBJSRC(30) , OBJDES(30) , CLESRC(80) , CLEDES(30) , LIBDES(50)
Local Char    LIBRUB(30) , LIBCUM(30)
Local Integer MESSRUB , MESSCUM

If clalev([F:RUB])=0 : Local File =APPLI+".RUBRIQUE" [RUB] : Endif
If clalev([F:VRA])=0 : Local File =APPLI+".VARIA"    [VRA] : Endif
If clalev([F:CUM])=0 : Local File =APPLI+".CUMUL"    [CUM] : Endif
If clalev([F:ALI])=0 : Local File =APPLI+".ALINK"    [ALI] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"   [ATX] : Endif

LIBRUB = mess(55,10702,1) : # Rubrique
LIBCUM = mess(82,10702,1) : # Cumul
Read [ATX]TEXTE = GLANGUE;LIBRUB
If !fstat
 MESSRUB = [F:ATX]NUMERO
Endif
Read [ATX]TEXTE = GLANGUE;LIBCUM
If !fstat
 MESSCUM = [F:ATX]NUMERO
Endif

Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
Local Integer TILD
GOK = 1
Trbegin [ALI]

 For [ALI]ALI0 Where USRCOD=GLIAISON(1) & DSTOBJ="RUB" & AUTFLG=2
  TILD=instr(1,[F:ALI]SRCKEY,"~")
  If TILD & right$([F:ALI]SRCKEY,TILD+1)= LEGPLAN
   Delete Curr
   If fstat=1
    GOK = -1 : GLOCK = "$ALINK"-GLIAISON(1)-"RUB" : Break
   Endif
  Endif
 Next
 If GOK<0 : Goto ROLL_TR1 : Endif

 For [ALI]ALI0 Where USRCOD=GLIAISON(1) & DSTOBJ="CUM" & AUTFLG=2
  TILD=instr(1,[F:ALI]SRCKEY,"~")
  If TILD & right$([F:ALI]SRCKEY,TILD+1)= LEGPLAN
   Delete Curr
   If fstat=1
    GOK = -1 : GLOCK = "$ALINK"-GLIAISON(1)-"CUM" : Break
   Endif
   Endif
 Next
 If GOK<0 :  : Goto ROLL_TR1 : Endif

 For [RUB]RUB0 Where LEG=LEGPLAN
  Raz NRUB,NCUM,NVAR
  FORMULE = [F:RUB]CNDCAL    : Gosub SETDEP
  FORMULE = [F:RUB]BAS       : Gosub SETDEP
  FORMULE = [F:RUB]RAT1      : Gosub SETDEP
  FORMULE = [F:RUB]RAT2      : Gosub SETDEP
  For K=0 To dim([F:RUB]TBLFRM)-1
   FORMULE = [F:RUB]TBLFRM(K) : Gosub SETDEP
  Next K
  For K=0 To [F:RUB]ITVNBR-1
   FORMULE = [F:RUB]ITVAMT(K) : Gosub SETDEP
  Next K
  For K=0 To dim([F:RUB]AMTMAX)-1
   FORMULE = [F:RUB]AMTMAX(K) : Gosub SETDEP
  Next K
  For K=0 To [F:RUB]NBRCUM-1
   If !find([F:RUB]CUM(K),TCUM(1..NCUM))
    NCUM += 1
    TCUM(NCUM) = [F:RUB]CUM(K)
   Endif
  Next K
  For K=0 To dim([F:RUB]CUMMAX)-1
   If [F:RUB]CUMMAX(K)<>"" & !find([F:RUB]CUMMAX(K),TCUM(1..NCUM))
    NCUM += 1
    TCUM(NCUM) = [F:RUB]CUMMAX(K)
   Endif
  Next K
  For K=0 To dim([F:RUB]CUMAMT)-1
   If [F:RUB]CUMAMT(K)<>"" & !find([F:RUB]CUMAMT(K),TCUM(1..NCUM))
    NCUM += 1
    TCUM(NCUM) = [F:RUB]CUMAMT(K)
   Endif
  Next K
  If [F:RUB]CUMBAS<>"" & !find([F:RUB]CUMBAS,TCUM(1..NCUM))
   NCUM += 1
   TCUM(NCUM) = [F:RUB]CUMBAS
  Endif
  For K=0 To dim([F:RUB]TEXVRI)-1
   If [F:RUB]TEXVRI(K)<>"" & !find([F:RUB]TEXVRI(K),TVAR(1..NVAR))
    NVAR += 1
    TVAR(NVAR) = [F:RUB]TEXVRI(K)
   Endif
  Next K
  OBJDES  = "RUB"
  CLEDES  = [F:RUB]COD+"~"+LEGPLAN
  Call LECTEXTRA(LIBDES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
  MESSNUM = MESSRUB
  Gosub SETLINK
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [CUM]CUM0 Where LEG=LEGPLAN
  Raz NRUB,NCUM,NVAR
  FORMULE = [F:CUM]CUMINI : Gosub SETDEP
  FORMULE = [F:CUM]CUMREP : Gosub SETDEP
  OBJDES  = "CUM"
  CLEDES  = [F:CUM]CUMCOD+"~"+LEGPLAN
  Call LECTEXTRA(LIBDES,"CUMUL","CUMDES",[F:CUM]LEG,[F:CUM]CUMCOD) From ATEXTRA
  MESSNUM = MESSCUM
  Gosub SETLINK
 Next
Commit
Return

$SETLINK
For K=1 To NRUB
 OBJSRC = "RUB"
 CLESRC = TRUB(K)+"~"+LEGPLAN
 Gosub CRELINK
Next K
For K=1 To NVAR
 OBJSRC = "VRA"
 CLESRC = TVAR(K)+"~"+LEGPLAN
 Gosub CRELINK
Next K
For K=1 To NCUM
 OBJSRC = "CUM"
 CLESRC = TCUM(K)+"~"+LEGPLAN
 Gosub CRELINK
Next K
Return

$CRELINK
If OBJSRC=OBJDES & CLESRC=CLEDES : Return : Endif
Raz [F:ALI]
[F:ALI]USRCOD = GLIAISON(1)
[F:ALI]SRCOBJ = OBJSRC
[F:ALI]SRCKEY = CLESRC
[F:ALI]DSTOBJ = OBJDES
[F:ALI]DSTKEY = CLEDES
[F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
[F:ALI]DSTTIT = MESSNUM
[F:ALI]DSTDES = LIBDES
[F:ALI]LNK    = "U"
[F:ALI]INVFLG = 2
[F:ALI]AUTFLG = 2
[F:ALI]ENAFLG = 2
[F:ALI]CREDAT = date$
[F:ALI]CREUSR = GUSER
Write [ALI]
If fstat
 GOK = 0 : Call FSTA("ALI") From GLOCK
 Return
Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#Tax band
$SETDEP
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_" :  #65041
    If !find(CODE,TRUB(1..NRUB))
     NRUB += 1
     TRUB(NRUB) = CODE
    Endif
   When "V_"
    If !find(CODE,TVAR(1..NVAR))
     NVAR += 1
     TVAR(NVAR) = CODE
    Endif
   When "C_"
    If !find(CODE,TCUM(1..NCUM))
     NCUM += 1
     TCUM(NCUM) = CODE
    Endif
  Endcase
  I += 1
 Else
  I += 1
 Endif
Wend
Return

