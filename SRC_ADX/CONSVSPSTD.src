#<AdxTL>@(#)10.0.0.0 $Revision$ Inquiry VSP
######################################################################################
# Spanish tax inquiry
######################################################################################
$ACTION
   Case ACTION
        When "OUVRE"   : Gosub OUVRE
        When "LECTURE" : Gosub LECTURE
        When "SORTIE"  : Gosub SORTIE
    Endcase
Return

#------------------------------------------------------------------------------#
$SORTIE
Kill GNL
Return

$OUVRE
    # Variables declaration
    Local Char    CRITERE(250)(1..4), AUXLNK(100)
    Local Char    INITIPOIVA(1), FINTIPOIVA(1), INITYP(GLONGTE), FINTYP(GLONGTE), PARTNER(GLONBPR)
    Local Char    ININUM(GLONVCR), FINNUM(GLONVCR), INIVAT(GLONVAT), FINVAT(GLONVAT)
    Local Integer ICRIT, NBSITE, INIREGTYP, FINREGTYP, RETENCION, CANARIAS
    Local Libelle GRP
    If !clalev([F:TCY]): Local File TABCOUNTRY [TCY] : Endif
    If !clalev([F:FCY]): Local File FACILITY   [FCY] : Endif
    NBSITE = max(1,GNBSITE)
    Local Char    TSITE(GLONFCY)(1..NBSITE)
    NBSITE = 0
    RPTCOD=GREPORT2
    Gosub DEFCRIT
    Local Integer XX: XX=0
Return

######################################################################################

$DEFCRIT
    If GUSRFCY(1)<>"\" and GNBAUZ=1 : PARAM(1) = GUSRFCY(1) : Endif

    # Parameters
    For I=1 To dim(PARAM)
        Case I
            When 1 : # Site
                If PARAM(I)<>""
                    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
                        [M:VSP1]FCY = PARAM(I)
                        [M:VSP1]CPY = [F:FCY]LEGCPY
                        PARAM(2)=""
                    Endif
                Endif
            When 2 : # Company
                If PARAM(I)<>""
                    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
                    If !fstat
                        [M:VSP1]CPY = PARAM(I)
                        If [M:VSP1]FCY<>""
                            Call LECTURE("FCY",[M:VSP1]FCY,"") From CONTOBJ
                            If [F:FCY]LEGCPY<>[M:VSP1]CPY : [M:VSP1]FCY="" : Endif
                        Endif
                    Endif
                Endif
            When 3 : # Initial date
                If instr(1,PARAM(I),"/")
                    [M:VSP1]ACCDATDEB = "["+PARAM(I)+"]"
                Elsif PARAM(I)<>""
                    [M:VSP1]ACCDATDEB = PARAM(I)
                Endif
            When 4 : # End date
                If instr(1,PARAM(I),"/")
                    [M:VSP1]ACCDATFIN = "["+PARAM(I)+"]"
                Elsif PARAM(I)<>""
                    [M:VSP1]ACCDATFIN = PARAM(I)
                Endif
            When 5 : Break
        Endcase
    Next I

    # Default values
    If [M:VSP1]FCY="" & [M:VSP1]CPY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
        [M:VSP1]FCY = GFCYDEF
        Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
        [M:VSP1]CPY = [F:FCY]LEGCPY
    Endif

    If [M:VSP1]ACCDATDEB=[0/0/0] or [M:VSP1]ACCDATFIN=[0/0/0] or [M:VSP1]ACCDATFIN>[M:VSP1]ACCDATDEB
        [M:VSP1]ACCDATDEB=gdat$(1,1,year(date$))
        [M:VSP1]ACCDATFIN=gdat$(31,12,year(date$))
    Endif

    [M:VSP1]TAXTYP=3
    [M:VSP1]PROCESS=3

    #90370 Cash VAT
    [M:VSP1]CSHVAT=1
    [M:VSP1]PAYCSH=1

Return
######################################################################################

$LECTURE
    Gosub CHANGE_MSK From GCONSULT
    If CHGPAG<0 : NOL = MAXLIG : Endif
    If XX=0: XX=1: Return: Endif  ##
    Gosub INIT
    Gosub LOAD_FILTER

    # ------------------------------------------------------- #
    # CHGPAG = 1    :    Search                               #
    # ------ = 2    :    Next                                 #
    #        = 3    :    F5 (Update page)                     #
    # CHGPAG = -1   :    Last                                 #
    # ------ = -2   :    Previous (previous page)             #
    # ------------------------------------------------------- #

    If CHGPAG > 0
        SUITE=1
        If CHGPAG = 1
            RETOUR = 1
        Elsif CHGPAG = 2
            RETOUR = 2
        Endif
        Filter [F:DVS] Where evalue(CRITERE) Order By Key DVS4
    Else
        RETOUR=1
        If CHGPAG = -1
            SUITE = 1
        Else
            SUITE = 2
        Endif
        Filter [F:DVS] Where evalue(CRITERE) Order By Key DVS4 Desc
    Endif
    If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:VSP2] : Endif

    For [F:DVS] With Nohint
      If GUSRFCY(1) = "\" | find([F:DVS]FCY, GUSRFCY(1..GNBAUZ))
        Gosub CARGA_VSP2
        If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
            Break
        Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
            Break
        Endif
      Endif
    Next
    # Calculation for totals on selection
    Raz [M:VSP2]SBASESOP, [M:VSP2]SBASEREP, [M:VSP2]SQUOTASOP, [M:VSP2]SQUOTAREP, [M:VSP2]SREGSOP, [M:VSP2]SREGREP
    For [F:DVS]
     If GUSRFCY(1) = "\" | find([F:DVS]FCY, GUSRFCY(1..GNBAUZ))
      Raz CANARIAS

      Call LEC_FCY([F:DVS]FCY)From CPTLEC
      If fstat=0: CANARIAS=[F:FCY]SPAOPEIGIC : Endif
      If [DVS]TAXTYP="S"
       If [F:DVS]IMPORT<>2 or CANARIAS=2
         [M:VSP2]SBASESOP+=[F:DVS]AMTNOTL*[F:DVS]SNS
       Endif
         [M:VSP2]SQUOTASOP+=[F:DVS]AMTTAXL*[F:DVS]SNS
         [M:VSP2]SREGSOP+=1
      Endif
      If [DVS]TAXTYP="R"
         If [DVS]VATTYP<>2
           [M:VSP2]SBASEREP+=[F:DVS]AMTNOTL*[F:DVS]SNS
         Endif
         [M:VSP2]SQUOTAREP+=[F:DVS]AMTTAXL*[F:DVS]SNS
         [M:VSP2]SREGREP+=1
      Endif
     Endif
    Next
      Affzo [M:VSP2]SBASESOP
      Affzo [M:VSP2]SBASEREP
      Affzo [M:VSP2]SQUOTASOP
      Affzo [M:VSP2]SQUOTAREP
      Affzo [M:VSP2]SREGSOP
      Affzo [M:VSP2]SREGREP

    Filter [F:DVS]
Return

######################################################################################

$INIT
    Call LECTURE("CPY",[M:VSP1]CPY,"") From CONTOBJ
    GRP=([F:CPY]CPYLEGFLG=1)

    If GRP
        NBSITE = 0
        For [FGR]FGR0 Where CPY = [M:VSP1]CPY
            Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
            NBSITE+=1
            TSITE(NBSITE) = [F:FGR]FCY
        Next
    Endif
Return

######################################################################################

$LOAD_FILTER
    Raz CRITERE, ICRIT

    # Company/Site
    If !GRP
        If [M:VSP1]CPY<>""
            Call ADDCRIT(CRITERE,ICRIT,"CPY",'[F:DVS]CPY="'+[M:VSP1]CPY+'"'," & ") From GOBJSUB
        Endif
        If [M:VSP1]FCY<>""
            Call ADDCRIT(CRITERE,ICRIT,"FCY",'[F:DVS]FCY="'+[M:VSP1]FCY+'"'," & ") From GOBJSUB
        Endif
    Else
        # Site group
        Call ADDCRIT(CRITERE,ICRIT,"FCY",'find([F:DVS]FCY,TSITE(1..NBSITE))'," & ") From GOBJSUB
    Endif

    # Site autorization
    If GUSRFCY(1)<>"\" & ([M:VSP1]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
        Call ADDCRIT(CRITERE,ICRIT,"FCY",'find([F:DVS]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
    Endif

    # Tax type
    If [M:VSP1]TAXTYP=1
        Call ADDCRIT(CRITERE,ICRIT,"TAXTYP",'[F:DVS]TAXTYP="R"'," & ") From GOBJSUB
    Elsif [M:VSP1]TAXTYP=2
        Call ADDCRIT(CRITERE,ICRIT,"TAXTYP",'[F:DVS]TAXTYP="S"'," & ") From GOBJSUB
    Endif

    # Tax codes
    If [M:VSP1]VATDEB<>""
        Call ADDCRIT(CRITERE, ICRIT,"VATDEB",'[F:DVS]VAT>="'+[M:VSP1]VATDEB+'"'," & ") From GOBJSUB
    Endif
    If [M:VSP1]VATFIN<>""
        Call ADDCRIT(CRITERE, ICRIT,"VATFIN",'[F:DVS]VAT<="'+[M:VSP1]VATFIN+'"'," & ") From GOBJSUB
    Endif

    # Accounting dates
    If [M:VSP1]ACCDATDEB<>[0/0/0]
        Call ADDCRIT(CRITERE, ICRIT,"ACCDATDEB",'[F:DVS]ACCDAT>=['+format$(GFMD,[M:VSP1]ACCDATDEB)+']'," & ") From GOBJSUB
    Endif
    If [M:VSP1]ACCDATFIN<>[0/0/0]
        Call ADDCRIT(CRITERE, ICRIT,"ACCDATFIN",'[F:DVS]ACCDAT<=['+format$(GFMD,[M:VSP1]ACCDATFIN)+']'," & ") From GOBJSUB
    Endif

    # To process
    If [M:VSP1]PROCESS=1
        Call ADDCRIT(CRITERE,ICRIT,"PROFLG",'[F:DVS]PROFLG=2'," & ") From GOBJSUB
    Elsif [M:VSP1]PROCESS=2
        Call ADDCRIT(CRITERE,ICRIT,"PROFLG",'[F:DVS]PROFLG<>2'," & ") From GOBJSUB
    Endif

    # BPs
    If [M:VSP1]PARTNER<>""
        Call ADDCRIT(CRITERE, ICRIT,"PARTNER",'[F:DVS]BPRNUM="'+[M:VSP1]PARTNER+'"'," & ") From GOBJSUB
    Endif

    # Bp tax rules
    If [M:VSP1]REGIMEN<>""
        Call ADDCRIT(CRITERE, ICRIT,"REGIMEN",'[F:DVS]VAC="'+[M:VSP1]REGIMEN+'"'," & ") From GOBJSUB
    Endif


    # Retention
    If [M:VSP1]RETENCION=2
        Call ADDCRIT(CRITERE,ICRIT,"RETENCION",'[F:DVS]REGTYP=4'," & ") From GOBJSUB
    Elsif [M:VSP1]RETENCION=1
        Call ADDCRIT(CRITERE,ICRIT,"RETENCION",'[F:DVS]REGTYP<>4'," & ") From GOBJSUB
 #   Endif    #107344
        If [M:VSP1]CSHVAT=2 and [M:VSP1]PAYCSH<>2     # 90370 Cash VAT
          Call ADDCRIT(CRITERE,ICRIT,"CSHVAT",'[F:DVS]CSHVAT=2'," & ") From GOBJSUB
          Call ADDCRIT(CRITERE, ICRIT,"REGTYP2",'[F:DVS]REGTYP<11'," &") From GOBJSUB
        Endif
        If [M:VSP1]CSHVAT<>2 and [M:VSP1]PAYCSH<>2
          Call ADDCRIT(CRITERE,ICRIT,"CSHVAT",'[F:DVS]CSHVAT<>2'," & ") From GOBJSUB
          Call ADDCRIT(CRITERE, ICRIT,"REGTYP2",'[F:DVS]REGTYP<11'," &") From GOBJSUB
        Endif
        If [M:VSP1]CSHVAT=2 and [M:VSP1]PAYCSH=2
          Call ADDCRIT(CRITERE,ICRIT,"CSHVAT",'[F:DVS]CSHVAT=2'," & ") From GOBJSUB
        Endif
        If [M:VSP1]CSHVAT<>2 and [M:VSP1]PAYCSH=2
          Call ADDCRIT(CRITERE,ICRIT,"CSHVAT",'[F:DVS]CSHVAT=2'," & ") From GOBJSUB
          Call ADDCRIT(CRITERE, ICRIT,"REGTYP2",'[F:DVS]REGTYP>10'," &") From GOBJSUB
        Endif  #107344
    Endif

    Case CHGPAG
        When 3 : # Update page
            AUXLNK=INITIPOIVA+INITYP+ININUM+INIVAT+num$(INIREGTYP)
            Call ADDCRIT(CRITERE,ICRIT,"XDILNK",'[F:DVS]INDLNK>="'+AUXLNK+'"'," & ") From GOBJSUB
        When 2 : # Next
            AUXLNK=FINTIPOIVA+FINTYP+FINNUM+FINVAT+num$(FINREGTYP)
            Call ADDCRIT(CRITERE,ICRIT,"XDILNK",'[F:DVS]INDLNK>"'+AUXLNK+'"'," & ") From GOBJSUB
        When -2 : # Previous
            AUXLNK=INITIPOIVA+INITYP+ININUM+INIVAT+num$(INIREGTYP)
            Call ADDCRIT(CRITERE,ICRIT,"XDILNK",'[F:DVS]INDLNK<"'+AUXLNK+'"'," & ") From GOBJSUB
    Endcase
Return

######################################################################################
# Load VSP2 screen                                                                   #
######################################################################################
$CARGA_VSP2
    If NBLU = 1
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:VSP2] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0
        If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
        NOL    += 1
        If NOL=0
            INITIPOIVA = [F:DVS]TAXTYP
            INITYP     = [F:DVS]TYP
            ININUM     = [F:DVS]NUM
            INIVAT     = [F:DVS]VAT
            INIREGTYP  = [F:DVS]REGTYP
        Endif
        FINTIPOIVA = [F:DVS]TAXTYP
        FINTYP     = [F:DVS]TYP
        FINNUM     = [F:DVS]NUM
        FINVAT     = [F:DVS]VAT
        FINREGTYP  = [F:DVS]REGTYP
    Else
        If NOL <= 0 : RETOUR=2 : Return : Endif
        NOL    -= 1
        If NOL=MAXLIG-1
            FINTIPOIVA = [F:DVS]TAXTYP
            FINTYP     = [F:DVS]TYP
            FINNUM     = [F:DVS]NUM
            FINVAT     = [F:DVS]VAT
            FINREGTYP  = [F:DVS]REGTYP
        Endif
        INITIPOIVA = [F:DVS]TAXTYP
        INITYP     = [F:DVS]TYP
        ININUM     = [F:DVS]NUM
        INIVAT     = [F:DVS]VAT
        INIREGTYP  = [F:DVS]REGTYP
    Endif

    nolign = NOL+1
    [M:VSP2]=[F:DVS]
    [M:VSP2]AMTNOTL(nolign-1)*=[F:DVS]SNS
    [M:VSP2]AMTTAXL(nolign-1)*=[F:DVS]SNS
    [M:VSP2]DEDAMTL(nolign-1)*=[F:DVS]SNS
    If [M:VSP2]TAXTYP(nolign-1) = "R"
        [M:VSP2]STAXTYP(nolign-1) = mess(1,3609,1)
        [M:VSP2]SREGTYP(nolign-1) = mess(5,14,1)
        If [DVS]REGTYP>10: [M:VSP2]SREGTYP(nolign-1)= mess(335,107,1): Endif #90370
    Elsif [M:VSP2]TAXTYP(nolign-1) = "S"
        [M:VSP2]STAXTYP(nolign-1) = mess(2,3609,1)
        [M:VSP2]SREGTYP(nolign-1) = mess([F:DVS]REGTYP,646,1)
        If [DVS]REGTYP=4 : [M:VSP2]SREGTYP(nolign-1)= mess(250,107,1): Endif
        If [DVS]REGTYP>10: [M:VSP2]SREGTYP(nolign-1)= mess(336,107,1): Endif #90370
    Endif
    If [M:VSP2]CRN(nolign-1)="": [M:VSP2]CRN(nolign-1)=[F:DVS]EECNUM: Endif
Return

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char VALEUR()
#Local Char FNCLEG
FNCLEG="SPA"
  If VALEUR<>""
    Read [CPY]CPY0=VALEUR
    If fstat=0
        Call CTLCPYLEGVAT([F:CPY]CPY,FNCLEG) From DCLVATSTD
    Endif
  Endif
End
######################################################################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
    If GUSRFCY(1)<>"\" and GNBAUZ=1
        If [M:VSP1]FCY=""
            [M:VSP1]FCY=GUSRFCY(1)
        Endif
        Read [F:FCY]FCY0=[M:VSP1]FCY
        If fstat : Raz [F:FCY] : Endif
        VALEUR=[F:FCY]LEGCPY

        Diszo [M:VSP1]CPY, FCY
    Endif
End

######################################################################################

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
    If [M:VSP1]CPY<>""
        Read [F:CPY]CPY0=[M:VSP1]CPY
        If fstat : Raz [F:CPY] : Endif
        # If Site group, don´t select a site
        If [F:CPY]CPYLEGFLG<2 : mkstat=1 : Endif
    Endif
End

######################################################################################

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
    If VALEUR <> ""
        If [F:FCY]FCY<>VALEUR
            Read [F:FCY]FCY0=VALEUR
            If fstat : Raz [F:FCY] : Endif
        Endif
        If [M:VSP1]CPY<>[F:FCY]LEGCPY
            [M:VSP1]CPY = [F:FCY]LEGCPY
            Affzo [M:VSP1]CPY
            If dim([M:VSP1]ZCPY)>0 : Affzo [M:VSP1]ZCPY : Endif
        Endif
    Else
        Call CONTALLFCY([M:VSP1]CPY) From CPTSUB
    Endif
End

######################################################################################

Subprog AM_PROFLG(VALEUR)
Variable Integer VALEUR
Local Integer NOL
Local Char    AUXMSG(100)

    NOL = nolign-1
    If clalev([F:DVS])=0 : Local File DCLVATSPA [DVS] : Endif
    Call DEBTRANS From GLOCK
    Gosub TR1
End
######################################################################################

$TR1
    GOK = 1
    Trbegin [DVS]

    Readlock [F:DVS]DVS0 = [M]TAXTYP(NOL);[M]TYP(NOL);[M]NUM(NOL);[M]VAT(NOL);[M]REGTYP(NOL)
    If fstat=1
        AUXMSG = [M]TAXTYP(NOL) - [M]TYP(NOL) - [M]NUM(NOL) - [M]VAT(NOL) - num$([M]REGTYP(NOL))
        GOK=-1 : GLOCK="$DCLVATSPA" - AUXMSG : Goto ROLL_TR1
    Elsif fstat
        GOK = 0 : Call FSTA("DVS") From GLOCK : Goto AB_TR1
    Endif
    [F:DVS]PROFLG = VALEUR
    Rewrite [DVS]
    If fstat
        GOK=0 : Call FSTA("DVS") From GLOCK : Goto AB_TR1
    Endif
    Commit
Return

$AB_TR1
    Rollback
Return

$ROLL_TR1
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR1 : Endif
Return

######################################################################################
Subprog AV_AMTNOTL(VALEUR)
Variable Decimal VALEUR
Local Integer CANARIAS

Read [FCY]FCY0=[F:DVS]FCY
If fstat=0: CANARIAS=[F:FCY]SPAOPEIGIC : Endif
If ([M]IMPORT(nolign-1)=2 and CANARIAS<>2) or [M]VATTYP(nolign-1)=2
& or (CANARIAS<>2 and [M]IMPORT(nolign-1)=1 and [F:DVS]SCDREF<>"")
   pcolor = GCOUL(2)
Else
   pcolor = GCOUL(0)
Endif

End

######################################################################################
Subprog AM_CODOPE(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Char    AUXMSG(100)

    NOL = nolign-1
    If clalev([F:DVS])=0 : Local File DCLVATSPA [DVS] : Endif
    Call DEBTRANS From GLOCK
    Gosub TR2
End

######################################################################################
$TR2
    GOK = 1
    Trbegin [DVS]

    Readlock [F:DVS]DVS0 = [M]TAXTYP(NOL);[M]TYP(NOL);[M]NUM(NOL);[M]VAT(NOL);[M]REGTYP(NOL)
    If fstat=1
        AUXMSG = [M]TAXTYP(NOL) - [M]TYP(NOL) - [M]NUM(NOL) - [M]VAT(NOL) - num$([M]REGTYP(NOL))
        GOK=-1 : GLOCK="$DCLVATSPA" - AUXMSG : Goto ROLL_TR2
    Elsif fstat
        GOK = 0 : Call FSTA("DVS") From GLOCK : Goto AB_TR2
    Endif
    [F:DVS]CODOPE = VALEUR

    If [M]TAXTYP(NOL)="S": [F:DVS]COD347 = "A" : Elsif [M]TAXTYP(NOL)="R": [F:DVS]COD347 = "B": Endif
    If VALEUR="R": Gosub CODOPE_R
    Else
        Raz [M:VSP2]BUILOC(NOL): Raz [F:DVS]BUILOC
        Raz [M:VSP2]CDRREF(NOL): Raz [F:DVS]CDRREF
        Affzo [M:VSP2]BUILOC(NOL), CDRREF(NOL)
    Endif

    If VALEUR="S"
        If [M]TAXTYP(NOL)="S": [F:DVS]COD347 = "E" : Elsif [M]TAXTYP(NOL)="R": [F:DVS]COD347 = "B": Endif
    Endif
    If VALEUR="T": [F:DVS]COD347 = "C": Endif
    If VALEUR="U"
        If [M]TAXTYP(NOL)="S": [F:DVS]COD347 = "A" Elsif [M]TAXTYP(NOL)="R": [F:DVS]COD347 = "B": Endif
    Endif
    If VALEUR="V": [F:DVS]COD347 = "G": Endif
    If VALEUR="W": [F:DVS]COD347 = "B": Endif
    If VALEUR="X": [F:DVS]COD347 = "A": Endif
    If VALEUR="N": [F:DVS]COD347 = "F": Endif
    If VALEUR="F": [F:DVS]COD347 = "A": Endif

    [F:DVS]BUILOC=[M:VSP2]BUILOC(NOL)
    [F:DVS]CDRREF=[M:VSP2]CDRREF(NOL)

    Rewrite [DVS]
    If fstat
        GOK=0 : Call FSTA("DVS") From GLOCK : Goto AB_TR2
    Endif
    Commit
Return

$AB_TR2
    Rollback
Return

$ROLL_TR2
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR2 : Endif
Return


######################################################################################
Subprog AM_CRN(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Char    AUXMSG(100)

    NOL = nolign-1
    If clalev([F:DVS])=0 : Local File DCLVATSPA [DVS] : Endif
    Call DEBTRANS From GLOCK
    Gosub TR3
End

######################################################################################
$TR3
    GOK = 1
    Trbegin [DVS]

    Readlock [F:DVS]DVS0 = [M]TAXTYP(NOL);[M]TYP(NOL);[M]NUM(NOL);[M]VAT(NOL);[M]REGTYP(NOL)
    If fstat=1
        AUXMSG = [M]TAXTYP(NOL) - [M]TYP(NOL) - [M]NUM(NOL) - [M]VAT(NOL) - num$([M]REGTYP(NOL))
        GOK=-1 : GLOCK="$DCLVATSPA" - AUXMSG : Goto ROLL_TR3
    Elsif fstat
        GOK = 0 : Call FSTA("DVS") From GLOCK : Goto AB_TR3
    Endif
    [F:DVS]CRN = VALEUR
    Rewrite [DVS]
    If fstat
        GOK=0 : Call FSTA("DVS") From GLOCK : Goto AB_TR3
    Endif
    Commit
Return

$AB_TR3
    Rollback
Return

$ROLL_TR3
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR3 : Endif
Return

######################################################################################
Subprog AP_CODOPE(VALEUR)
Variable Char    VALEUR()
If VALEUR="R":
    Call DEBTRANS From GLOCK
    Gosub TR4
    Call DEBTRANS From GLOCK
    Gosub TR5
Endif

End

######################################################################################
Subprog IB_NBLIG
Local Integer NOL : NOL = nolign-1
#If [M:VSP2]NUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
#If [M:VSP2]NUM(NOL)="" : Raz GBOUT1, GBOUT2, GBOUT3: Endif # 90370
If [M:VSP2]NUM(NOL)="" : Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4: Endif # 108201
GBOUT1=mess(145,117,1)
GBOUT2=mess(251,107,1)
GBOUT3=mess(337,107,1)
GBOUT4=mess(53,117,1)   # 108201
If [M:VSP2]CODOPE(NOL)<>"R": Raz GBOUT2: Endif
If [M:VSP2]CSHVAT(NOL)<>2 or [M:VSP2]REGTYP(NOL)<11: Raz GBOUT3: Endif #90370
If [M:VSP2]INVUPDFLG(NOL)=0 : Raz GBOUT4: Endif # 108201
End


######################################################################################
Subprog B2_NBLIG
Local Integer NOL : NOL = nolign-1
Global Integer GNL: GNL=NOL

Case [M:VSP2]CODOPE(NOL)
When "R"
    Gosub CODOPE_R
    Call DEBTRANS From GLOCK
    Gosub TR4
    Call DEBTRANS From GLOCK
    Gosub TR5
When Default: Raz GBOUT2
Endcase
End

######################################################################################
Subprog B3_NBLIG            #90370 cash VAT
Local Integer NOL : NOL = nolign-1
Global Integer GNL: GNL=NOL
If [M:VSP2]CSHVAT(NOL)=2 and [M:VSP2]REGTYP(NOL)>10
  Gosub CASHCRI
Else Raz GBOUT3
Endif

End
######################################################################################
Subprog B4_NBLIG     # 108201

Local Integer NOL : NOL = nolign-1
Global Integer NL: NL=NOL

If [M:VSP2]INVUPDFLG(NOL)<>0
  Gosub DOC_ORI: Gosub TR6: Gosub TR7
Else Raz GBOUT4
Endif

End


######################################################################################
Subprog APRES_NBLIG
Local Integer NOL : NOL = nolign-1
Global Integer GNL: GNL=NOL
If [M:VSP2]CODOPE(GNL)="R"
    Call DEBTRANS From GLOCK
    Gosub TR5
    Endif

End


#########################################################################################
$CODOPE_R
Local Char SOC(GLONCPY)
Local Char    PARMSK(250)(1..20), SAVACT(20)

PARMSK(1)= num$(nolign-1)
SOC=[M:VSP1]CPY
SAVACT = GACTION : GACTION = "BUILOCSPA"

Call TRAITE_CHAR(SOC,PARMSK,"","BUILOCSPA","BUILOCSPA",4,"SPEBUILOCSPA") From GTRAITE
GACTION = SAVACT

Return

#########################################################################################
$CASHCRI            #90370 cash VAT
Local Char SOC(GLONCPY)
Local Char    PARMSK(250)(1..20), SAVACT(20)
Global Integer GNL

SOC=[M:VSP1]CPY
SAVACT = GACTION : GACTION = "CSHVATSPA"
GNL=NOL
Call TRAITE_CHAR(SOC,PARMSK,"","CSHVATSPA","CSHVATSPA",4,"SPECVATSPA") From GTRAITE
GACTION = SAVACT
If GNL=-1: VALEUR=[M:VSP2]CSHVAT(NOL): Endif
Raz GNL

Return
#########################################################################################
$DOC_ORI         #108201
Local Char SOC(GLONCPY)
Local Char    PARMSK(250)(1..20), SAVACT(20)
Global Integer NL

SOC=[M:VSP1]CPY
SAVACT = GACTION : GACTION = "INVNUMSPA"
NL=NOL
Call TRAITE_CHAR(SOC,PARMSK,"","INVNUMSPA","INVNUMSPA",4,"INVNUMSPA") From GTRAITE
GACTION = SAVACT
If NL=-1: VALEUR=[M:VSP2]INVUPDFLG(NOL): Endif
Raz NL

Return


###############################################################################
$TR4
  GOK = 1
Local Integer NOL : NOL = nolign-1
Trbegin [DVS]
Readlock [F:DVS]DVS0 = [M]TAXTYP(NOL);[M]TYP(NOL);[M]NUM(NOL);[M]VAT(NOL);[M]REGTYP(NOL)
A=NOL
If fstat=1
   AUXMSG = [M]TAXTYP(NOL) - [M]TYP(NOL) - [M]NUM(NOL) - [M]VAT(NOL) - num$([M]REGTYP(NOL))
   GOK=-1 : GLOCK="$DCLVATSPA" - AUXMSG : Goto ROLL_TR4
Elsif fstat
   GOK = 0 : Call FSTA("DVS") From GLOCK : Goto AB_TR4
Endif

[F:DVS]BUILOC=[M:VSP2]BUILOC(NOL)
[F:DVS]CDRREF=[M:VSP2]CDRREF(NOL)

Rewrite [DVS]
If fstat
    GOK=0 : Call FSTA("DVS") From GLOCK : Goto AB_TR4
Endif

Commit
Return

$AB_TR4
    Rollback
Return

$ROLL_TR4
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR4 : Endif
Return

####################################################################################
$TR5
If clalev([F:BLS])=0: Local File BUILOCSPA [BLS]: Endif
Local Integer NOL : NOL = nolign-1

GOK = 1
[F:BLS]NUM=[M]NUM(NOL)

Trbegin [BLS]
Readlock [BLS]BLS0=[M]NUM(NOL)
If fstat=1
  GOK=-1 : GLOCK="$"-[M]NUM(NOL)
Endif

[F:BLS]BUILOC=[M:VSP2]BUILOC(NOL)
[F:BLS]CDRREF=[M:VSP2]CDRREF(NOL)

If fstat=0
  Rewrite [BLS]
  If fstat
    GOK=0: Call FSTA("BLS") From GLOCK
  Endif
Elsif fstat>3
  Write [BLS]
  If fstat
    GOK=0: Call FSTA("BLS") From GLOCK
  Endif
Endif

Commit
Return

####################################################################################
$TR6         #108201
GOK = 1
Local Integer NOL : NOL = nolign-1
Trbegin [DVS]
Readlock [F:DVS]DVS0 = [M]TAXTYP(NOL);[M]TYP(NOL);[M]NUM(NOL);[M]VAT(NOL);[M]REGTYP(NOL)
A=NOL
If fstat=1
   AUXMSG = [M]TAXTYP(NOL) - [M]TYP(NOL) - [M]NUM(NOL) - [M]VAT(NOL) - num$([M]REGTYP(NOL))
   GOK=-1 : GLOCK="$DCLVATSPA" - AUXMSG : Goto ROLL_TR6
Elsif fstat
   GOK = 0 : Call FSTA("DVS") From GLOCK : Goto AB_TR6
Endif

[F:DVS]INVNUMDAT=[M:VSP2]INVNUMDAT(NOL)
[F:DVS]INVNUM=[M:VSP2]INVNUM(NOL)

Rewrite [DVS]
If fstat
    GOK=0 : Call FSTA("DVS") From GLOCK : Goto AB_TR6
Endif

Commit
Return
$AB_TR6
    Rollback
Return

$ROLL_TR6
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR6 : Endif
Return

####################################################################################
$TR7       # 108201
If clalev([F:ISP])=0: Local File INVNUMSPA [ISP]: Endif
Local Integer NOL : NOL = nolign-1

  GOK = 1
  [F:ISP]NUM=[M]NUM(NOL)

  Trbegin [ISP]
  Readlock [ISP]ISP0=[M]NUM(NOL)
  If fstat=1
    GOK=-1 : GLOCK="$"-[M]NUM(NOL)
  Endif

  [F:ISP]INVNUMDAT=[M:VSP2]INVNUMDAT(NOL)
  [F:ISP]INVNUM   =[M:VSP2]INVNUM(NOL)

  If fstat=0
    Rewrite [ISP]
    If fstat
      GOK=0: Call FSTA("ISP") From GLOCK
    Endif
  Elsif fstat>3
    Write [ISP]
    If fstat
      GOK=0: Call FSTA("ISP") From GLOCK
    Endif
  Endif

  Commit
Return

####################################################################################
