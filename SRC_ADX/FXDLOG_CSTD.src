#**
#* Class FXDLOG !help to format an array in a trace
#*
#*!

$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

$METHODS

  Case [L]CURPTH
  When ""
    Case [L]AMETHOD
      When "LOG_INIT"                     : Gosub LOG_INIT                      # Init the class log
      When "LOG_CREATE"                   : Gosub LOG_CREATE                    # Create the trace's file
      When "LOG_CLOSE"                    : Gosub LOG_CLOSE                     # Close the trace's file

      When "LOG_SET_PARAMS"               : Gosub LOG_SET_PARAMS                #
      When "LOG_SET_H_SIM"                : Gosub LOG_SET_H_SIM                 #
      When "LOG_SET_H_USR"                : Gosub LOG_SET_H_USR                 #
      When "LOG_SET_H_CPY"                : Gosub LOG_SET_H_CPY                 #
      When "LOG_SET_H_FCY"                : Gosub LOG_SET_H_FCY                 #

      When "LOG_ADD_COLUMN"               : Gosub LOG_ADD_COLUMN                #
      When "LOG_SET_COLUMN"               : Gosub LOG_SET_COLUMN                #
      When "LOG_REMOVE_ALL_COLUMNS"       : Gosub LOG_REMOVE_ALL_COLUMNS        #

      When "LOG_WRITE_HEADER"             : Gosub LOG_WRITE_HEADER              #

      When "LOG_INIT_LINE"                : Gosub LOG_INIT_LINE                 #
      When "LOG_PUT_COLUMN"               : Gosub LOG_PUT_COLUMN                #
      When "LOG_PUT_STR_COLUMN"           : Gosub LOG_PUT_STR_COLUMN            #
      When "LOG_PUT_INT_COLUMN"           : Gosub LOG_PUT_INT_COLUMN            #
      When "LOG_PUT_DEC_COLUMN"           : Gosub LOG_PUT_DEC_COLUMN            #
      When "LOG_PUT_DATE_COLUMN"          : Gosub LOG_PUT_DATE_COLUMN           #
      When "LOG_PUT_COLUMNS"              : Gosub LOG_PUT_COLUMNS               #
      When "LOG_PUT_COLUMNS_AND_WRITE"    : Gosub LOG_PUT_COLUMNS_AND_WRITE     #
      When "LOG_PUT_COLUMNS_AND_WRITE_5"  : Gosub LOG_PUT_COLUMNS_AND_WRITE_5   #
      When "LOG_PUT_COLUMNS_AND_WRITE_10" : Gosub LOG_PUT_COLUMNS_AND_WRITE_10  #

      When "LOG_GET_LINE"                 : Gosub LOG_GET_LINE                  #
      When "LOG_WRITE"                    : Gosub LOG_WRITE                     #
      When "LOG_WRITE_STRING"             : Gosub LOG_WRITE_STRING              #
      When "LOG_WRITE_STRING_WARNING"     : Gosub LOG_WRITE_STRING_WARNING      #
      When "LOG_WRITE_STRING_ERROR"       : Gosub LOG_WRITE_STRING_ERROR        #
      When "LOG_WRITE_STRING_STATUS"      : Gosub LOG_WRITE_STRING_STATUS       #
      When "LOG_WRITE_STRING_SEPARATOR"   : Gosub LOG_WRITE_STRING_SEPARATOR    #
      When "LOG_WRITE_LINEFEED"           : Gosub LOG_WRITE_LINEFEED            #
      When "LOG_WRITE_TITLES"             : Gosub LOG_WRITE_TITLES              #
      When "LOG_WRITE_SUM"                : Gosub LOG_WRITE_SUM                 #
      When "LOG_FLUSH"                    : Gosub LOG_FLUSH                     #

      When "LOG_WRITE_FOOTER"             : Gosub LOG_WRITE_FOOTER              #
      When "LOG_NB_OK"                    : Gosub LOG_NB_OK                     #
    Endcase
  Endcase
Return

$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

#**
#* Init the class log
#*
#*!
$LOG_INIT

  # Init then properties of the class
  this.SEPARATOR = "!"
  this.UNDERLINE = "-"
  this.LINE_LIMIT = 100
  this.NBCOL = 0

  this.H_SIM = AVOID.AINT
  this.H_USR = AVOID.ACHAR
  this.H_CPY = AVOID.ACHAR
  this.H_FCY = AVOID.ACHAR
Return

#**
#* Create the trace's file
#*
#* @param   PTITLE : File's title
#*!
$LOG_CREATE

  ARET_VALUE = fmet this.TRC_CLASS(1).ABEGINLOG(PTITLE)
  this.LOG_NAME = fmet this.TRC_CLASS(1).AGETNAME()

Return

#**
#* Close the trace's file
#*
#*!
$LOG_CLOSE

  ARET_VALUE = fmet this.TRC_CLASS(1).AENDLOG

Return

#**
#* Flush the lines in buffer
#*
#*!
$LOG_FLUSH

  ARET_VALUE = fmet this.TRC_CLASS(1).AFLUSHLOG

Return

#**
#* Set the parameters
#*
#* @param   PSEPARATOR   Column's separator
#* @param   PUNDERLINE   Column's under line
#* @param   PSPACE       Caracter between separator and value
#* @param   PLINE_LIMIT  If a string is longer than PLINE_LIMIT, it's all written on the next line
#*!
$LOG_SET_PARAMS

  If PSEPARATOR <> AVOID.ACHAR
    this.SEPARATOR = PSEPARATOR
  Endif

  If PUNDERLINE <> AVOID.ACHAR
    this.UNDERLINE = PUNDERLINE
  Endif

  this.SPACE = PSPACE

  If PLINE_LIMIT > 0
    this.LINE_LIMIT = PLINE_LIMIT
  Endif

  ARET_VALUE = [V]CST_AOK

Return

#**
#* Set and init a column
#*
#* @param PNUMCOL  : column number
#* @param PTYPCOL  : (A)lpha (I)nteger (M)ontant (D)ate
#* @param PLEFTCOL : write to the left CST_AYES, CST_ANO
#* @param PLGCOL   : column's number characters
#* @param PZERO    : write if value = 0 (or blank if not) CST_AYES, CST_ANO
#* @param PNBDEC   : number of decimals (if amount)
#* @param PFORMAT  : column's format
#* @param PWRAP    : Continue on next line (for alphabetic field)
#* @param PTITLE   : column's title
#*!
$LOG_SET_COLUMN

Local Integer OK, I

  If PNUMCOL <= this.NBCOL
    ARET_VALUE = fmet this.ASETERROR("", "Column already defined", [V]CST_AERROR)
    Return
  Endif

  # Add column in collection CEL_DEF
  this.NBCOL = fmet this.ADDLINE("CEL_DEF", PNUMCOL)
  If this.NBCOL = [V]CST_ANOTDEFINED
    ARET_VALUE = [V]CST_AERROR
    Return
  Endif

  # Set the parameters column
  this.CEL_DEF(this.NBCOL).TYPCOL  = PTYPCOL
  this.CEL_DEF(this.NBCOL).LEFTCOL = PLEFTCOL
  this.CEL_DEF(this.NBCOL).LGCOL   = PLGCOL
  this.CEL_DEF(this.NBCOL).ZERO    = PZERO
  this.CEL_DEF(this.NBCOL).NBDEC   = PNBDEC
  this.CEL_DEF(this.NBCOL).FORMAT  = PFORMAT
  this.CEL_DEF(this.NBCOL).WRAP    = PWRAP
  this.CEL_DEF(this.NBCOL).TITLE   = PTITLE

  # Compute character's number of a line
  this.NBCHAR = 0
  For [L]I = 1 To this.NBCOL
    this.NBCHAR += this.CEL_DEF([L]I).LGCOL + 1 + len(this.SPACE)
  Next [L]I
  this.NBCHAR += 1 + len(this.SPACE)
  # Build the separator line
  this.LINE_SEP = string$(this.NBCHAR, this.UNDERLINE)

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Add and init a column
#*
#* @param PTYPCOL  : (A)lpha (I)nteger (M)ontant (D)ate
#* @param PLEFTCOL : write to the left CST_AYES, CST_ANO
#* @param PLGCOL   : column's number characters
#* @param PZERO    : write if value = 0 (or blank if not) CST_AYES, CST_ANO
#* @param PNBDEC   : number of decimals (if amount)
#* @param PFORMAT  : column's format
#* @param PWRAP    : Continue on next line (for alphabetic field)
#* @param PTITLE   : column's title
#*!
$LOG_ADD_COLUMN

Local Integer OK, I, WNUMCOL

  [L]WNUMCOL = this.NBCOL + 1
  ARET_VALUE = fmet this.LOG_SET_COLUMN([L]WNUMCOL, PTYPCOL, PLEFTCOL, PLGCOL, PZERO, PNBDEC, PFORMAT, PWRAP, PTITLE)

Return

#**
#* Remove all the columns - Deprecated method
#*
#*!
$LOG_REMOVE_ALL_COLUMNS

Local Integer LINE, OK
Local Instance TMPALOGD Using OBJECT

  For [L]LINE = 1 To this.NBCOL
    TMPALOGD = this.CEL_DEF([L]LINE)
    this.CEL_DEF([L]LINE) = null
    FreeInstance TMPALOGD
  Next [L]LINE

  this.NBCOL = 0
  ARET_VALUE = [V]CST_AOK

Return

#**
#* For writing header
#*
#* @param PSIM : If it's the simulation's mode
#*!
$LOG_SET_H_SIM

  If PSIM = [V]CST_AYES or PSIM = [V]CST_ANO
    this.H_SIM = PSIM
  Endif
  ARET_VALUE = [V]CST_AOK

Return

#**
#* For writing header
#*
#* @param PUSR : User's code
#*!
$LOG_SET_H_USR

  this.H_USR = PUSR
  ARET_VALUE = [V]CST_AOK

Return

#**
#* For writing header
#*
#* @param PCPY : Company
#*!
$LOG_SET_H_CPY

  this.H_CPY = PCPY
  ARET_VALUE = [V]CST_AOK

Return

#**
#* For writing header
#*
#* @param PFCY    Facility
#*!
$LOG_SET_H_FCY

  this.H_FCY = PFCY
  ARET_VALUE = [V]CST_AOK

Return

#**
#* Set the formatted value for an alphabetic property
#*
#* @param PNUMCOL : column's row
#* @param PVALUE  : alpha value
#*!
$LOG_PUT_COLUMN

Local Integer OK

  # Alpha ou forçage______________________________________________
  If this.CEL_DEF(PNUMCOL).TYPCOL = "A"
& or (this.FOOTER = [V]CST_ATRUE and this.CEL_DEF(PNUMCOL).TYPCOL = "D")

    ARET_VALUE = fmet this.LOG_PUT_STR_COLUMN(PNUMCOL, PVALUE)

  # Entier ______________________________________________
  Elsif this.CEL_DEF(PNUMCOL).TYPCOL = "I"

    ARET_VALUE = fmet this.LOG_PUT_INT_COLUMN(PNUMCOL, val(PVALUE))

  # Montant ______________________________________________
  Elsif this.CEL_DEF(PNUMCOL).TYPCOL = "M"

    ARET_VALUE = fmet this.LOG_PUT_DEC_COLUMN(PNUMCOL, val(PVALUE))

  # Date ______________________________________________
  Elsif this.CEL_DEF(PNUMCOL).TYPCOL = "D"
    Local Date WDTVALUE

    # Cast date value to char value
    [L]WDTVALUE = PVALUE
    ARET_VALUE = fmet this.LOG_PUT_DATE_COLUMN(PNUMCOL, [L]WDTVALUE)

  Endif

Return

#**
#* Set the formatted value for an alphanumeric property
#*
#* @param PNUMCOL : column's row
#* @param PVALUE  : char value
#*!
$LOG_PUT_STR_COLUMN

Local Char WCOL(250)

  If len(PVALUE) > this.CEL_DEF(PNUMCOL).LGCOL and this.CEL_DEF(PNUMCOL).WRAP = [V]CST_ANO
    # Troncate the value to len of column if non wrap
    PVALUE = left$(PVALUE, this.CEL_DEF(PNUMCOL).LGCOL)
  Endif

  # ???
  If len(PVALUE) > this.LINE_LIMIT
    this.LINE_MSG = PVALUE
    PVALUE = "(*) ->"
#      PVALUE = left$(PVALUE, this.CEL_DEF(PNUMCOL).LGCOL)
  Endif

  # Align on left or right side
  Call LOG_ALIGN_COLUMN (PVALUE, this.CEL_DEF(PNUMCOL).LGCOL, this.CEL_DEF(PNUMCOL).LEFTCOL, [L]WCOL)

  this.LINE_CUR = 1
  Gosub ADDWRAP

  ARET_VALUE = [V]CST_AOK

Return

#**
#* Set the formatted value for an integer property
#*
#* @param PNUMCOL   column's row
#* @param PVALUE    integer value
#*!
$LOG_PUT_INT_COLUMN

Local Char WMT(30), WCOL(250)

  If this.CEL_DEF(PNUMCOL).ZERO = [V]CST_ANO and PVALUE = 0
    [L]WMT = ""
  Else
    [L]WMT = num$(PVALUE)
  Endif

  this.CEL_DEF(PNUMCOL).CUMUL += PVALUE

  # Troncate value to len of column
  If len([L]WMT) > this.CEL_DEF(PNUMCOL).LGCOL
    [L]WMT = left$(WMT, this.CEL_DEF(PNUMCOL).LGCOL)
  Endif

  # Align on left or right side
  Call LOG_ALIGN_COLUMN ([L]WMT, this.CEL_DEF(PNUMCOL).LGCOL, this.CEL_DEF(PNUMCOL).LEFTCOL, [L]WCOL)

  this.CEL_VALUE(PNUMCOL).COLWRAP = [L]WCOL
  # No wrap for numeric column

  ARET_VALUE = [V]CST_AOK

Return

#**
#* Set the formatted value for a decimal property
#*
#* @param PNUMCOL : column's row
#* @param PVALUE  : decimal value
#*!
$LOG_PUT_DEC_COLUMN

Local Char WMT(30), WCOL(250)

  this.CEL_DEF(PNUMCOL).CUMUL += PVALUE

  If this.CEL_DEF(PNUMCOL).ZERO = [V]CST_ANO and PVALUE = 0
    [L]WMT = ""
  Else
    [L]WMT = num$(PVALUE)
  Endif

  # Troncate value to len of column
  If len([L]WMT) > this.CEL_DEF(PNUMCOL).LGCOL
    [L]WMT = string$(this.CEL_DEF(PNUMCOL).LGCOL - 1, "x")
  Else
    If this.CEL_DEF(PNUMCOL).FORMAT = AVOID.ACHAR
      If this.CEL_DEF(PNUMCOL).NBDEC > 0
        [L]WMT = format$(num$(this.CEL_DEF(PNUMCOL).LGCOL - (this.CEL_DEF(PNUMCOL).NBDEC + 2)) + "." + num$(this.CEL_DEF(PNUMCOL).NBDEC) + "#", val([L]WMT))
      Else
        [L]WMT = num$(PVALUE)
      Endif
    Else
      [L]WMT = format$(this.CEL_DEF(PNUMCOL).FORMAT, PVALUE)
    Endif
  Endif

  # Align on left or right side
  Call LOG_ALIGN_COLUMN ([L]WMT, this.CEL_DEF(PNUMCOL).LGCOL, this.CEL_DEF(PNUMCOL).LEFTCOL, [L]WCOL)

  this.CEL_VALUE(PNUMCOL).COLWRAP = [L]WCOL
  # No wrap for numeric column

  ARET_VALUE = [V]CST_AOK

Return

#**
#* Set the formatted value for a date property
#*
#* @param PNUMCOL : column's row
#* @param PVALUE  : date value
#*!
$LOG_PUT_DATE_COLUMN

Local Char WDT(30), WCOL(250)

  If this.CEL_DEF(PNUMCOL).FORMAT = AVOID.ACHAR
    [L]WDT = format$("D:DD[/]MM[/]YYYY", PVALUE)
  Else
    [L]WDT = format$(this.CEL_DEF(PNUMCOL).FORMAT, PVALUE)
  Endif

  # Align on left or right side
  Call LOG_ALIGN_COLUMN ([L]WDT, this.CEL_DEF(PNUMCOL).LGCOL, this.CEL_DEF(PNUMCOL).LEFTCOL, [L]WCOL)

  this.CEL_VALUE(PNUMCOL).COLWRAP = [L]WCOL
  # No wrap for date column

  ARET_VALUE = [V]CST_AOK

Return

#**
#* Prepare the array for printing a line (or a group of)
#* if necessary (and asked), add more lines if string is too long
#*
#*!
$ADDWRAP

Local Integer ICOL, ICELL, OK

  While [L]WCOL <> AVOID.ACHAR

    # line's number (for this case)
    If this.LINE_CUR > this.LINE_NBR
      this.LINE_NBR = this.LINE_CUR
    Endif

    # line's max number (general)
    If this.LINE_NBR > this.LINE_NBR_TOT
      # create the new columns for this line (which has this.NBCOL)
      For [L]ICOL = 1 To this.NBCOL
        [L]OK = fmet this.ADDLINE("CEL_VALUE", [V]CST_ALASTPOS)
      Next [L]ICOL
      this.LINE_NBR_TOT = this.LINE_NBR
    Endif

    [L]ICELL = (this.NBCOL * (this.LINE_CUR - 1)) + PNUMCOL
    If len([L]WCOL) > this.CEL_DEF(PNUMCOL).LGCOL
      #
      this.CEL_VALUE([L]ICELL).COLWRAP = left$([L]WCOL, this.CEL_DEF(PNUMCOL).LGCOL)

      [L]WCOL = right$([L]WCOL, this.CEL_DEF(PNUMCOL).LGCOL + 1)
      this.LINE_CUR += 1
      # Continue While
    Else
      #
      this.CEL_VALUE([L]ICELL).COLWRAP = [L]WCOL
      this.CEL_VALUE([L]ICELL).COLWRAP += string$(max(0, this.CEL_DEF(PNUMCOL).LGCOL - len([L]WCOL)), " ")

      [L]WCOL = AVOID.ACHAR
      # End While
    Endif

  Wend

Return

#**
#* Set the formatted value for all the columns
#*
#* @param PVALUES : array (begins 1..)
#*!
$LOG_PUT_COLUMNS

Local Integer I, OK

  ARET_VALUE = fmet this.LOG_INIT_LINE()
  For [L]I = 1 To this.NBCOL
    ARET_VALUE = fmet this.LOG_PUT_COLUMN([L]I, PVALUES([L]I))
  Next [L]I

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Set the formatted value for all the columns
#* and Write the line
#*
#* @param PVALUES : array (begins 1..)
#* @param PSTAT   : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_PUT_COLUMNS_AND_WRITE

  ARET_VALUE = fmet this.LOG_PUT_COLUMNS(PVALUES)
  If ARET_VALUE = [V]CST_AOK
    ARET_VALUE = fmet this.LOG_WRITE(PSTAT)
  Endif

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Set the formatted value for a maximum of 5 values in the columns
#* and Write the line
#*
#* @param PVALUE1 : value 1
#* @param PVALUE2 : value 2
#* @param PVALUE3 : value 3
#* @param PVALUE4 : value 4
#* @param PVALUE5 : value 5
#* @param PSTAT   : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_PUT_COLUMNS_AND_WRITE_5

Local Char WTCOL(100)(1..5)

  WTCOL(1) = PVALUE1
  WTCOL(2) = PVALUE2
  WTCOL(3) = PVALUE3
  WTCOL(4) = PVALUE4
  WTCOL(5) = PVALUE5

  ARET_VALUE  = fmet this.LOG_PUT_COLUMNS(WTCOL)
  If ARET_VALUE = [V]CST_AOK
    ARET_VALUE = fmet this.LOG_WRITE(PSTAT)
  Endif

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Set the formatted value for a maximum of 10 values in the columns
#*
#* and Write the line
#* @param PVALUE1  : value 1
#* @param PVALUE2  : value 2
#* @param PVALUE3  : value 3
#* @param PVALUE4  : value 4
#* @param PVALUE5  : value 5
#* @param PVALUE6  : value 6
#* @param PVALUE7  : value 7
#* @param PVALUE8  : value 8
#* @param PVALUE9  : value 9
#* @param PVALUE10 : value 10
#* @param PSTAT    : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_PUT_COLUMNS_AND_WRITE_10

Local Char WTCOL(100)(1..10)

  WTCOL(1) = PVALUE1
  WTCOL(2) = PVALUE2
  WTCOL(3) = PVALUE3
  WTCOL(4) = PVALUE4
  WTCOL(5) = PVALUE5
  WTCOL(6) = PVALUE6
  WTCOL(7) = PVALUE7
  WTCOL(8) = PVALUE8
  WTCOL(9) = PVALUE9
  WTCOL(10) = PVALUE10

  ARET_VALUE  = fmet this.LOG_PUT_COLUMNS(WTCOL)
  If ARET_VALUE = [V]CST_AOK
    ARET_VALUE = fmet this.LOG_WRITE(PSTAT)
  Endif

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Init the line's property
#*!
$LOG_INIT_LINE

Local Integer I

  For [L]I = 1 To (this.LINE_NBR * this.NBCOL)
    this.CEL_VALUE([L]I).COLWRAP = AVOID.ACHAR
  Next [L]I

  this.LINE = AVOID.ACHAR
  this.LINE_MSG = AVOID.ACHAR
  this.LINE_CUR = 0
  this.LINE_NBR = 0

  ARET_VALUE = [V]CST_AOK

Return

End

#**
#* Get a line
#*
#* @param PLINE : Line number to get
#* @return : line value (alpha)
#*!
$LOG_GET_LINE

Local Char WLINE(250)
Local Integer ICELL, JCOL

    # Control the PLINE parameter
    If PLINE < 1
      PLINE = 1
    Endif
    If PLINE > this.LINE_NBR
      PLINE = this.LINE_NBR
    Endif

    # Construct the line
    [L]WLINE = AVOID.ACHAR
    For [L]JCOL = 1 To this.NBCOL
      ICELL = this.NBCOL * (PLINE - 1) + [L]JCOL

      # Column separator
      [L]WLINE += this.SEPARATOR
      # Space separator
      If this.CEL_DEF([L]JCOL).LEFTCOL = [V]CST_AYES
        [L]WLINE += this.SPACE
      Endif
      # Column value
      If this.CEL_VALUE(ICELL).COLWRAP = AVOID.ACHAR
        # If none value in column, blank value
        [L]WLINE += string$(this.CEL_DEF([L]JCOL).LGCOL, " ")
      Else
        [L]WLINE += this.CEL_VALUE(ICELL).COLWRAP
      Endif
      # Space separator
      If this.CEL_DEF([L]JCOL).LEFTCOL = [V]CST_ANO
        [L]WLINE += this.SPACE
      Endif

    Next [L]JCOL
    # Column separator
    [L]WLINE += this.SEPARATOR

  # Return the line
  ARET_VALUE = [L]WLINE

Return

#**
#* Write the line(s)
#*
#* @param PSTAT : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_WRITE

Local Integer OK, I, J

  For [L]I = 1 To this.LINE_NBR

    # Get the line
    this.LINE = fmet this.LOG_GET_LINE([L]I)

    # Write the line
    ARET_VALUE = fmet this.LOG_WRITE_STRING_STATUS(this.LINE, PSTAT)
  Next [L]I

  # ???
  If this.LINE_MSG <> AVOID.ACHAR
    ARET_VALUE = fmet this.TRC_CLASS(1).APUTLINE(this.LINE_MSG, PSTAT)
    this.LINE_MSG = AVOID.ACHAR
  Endif

  # Reset columns values
  ARET_VALUE = fmet this.LOG_INIT_LINE()

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Write a free string
#*
#* @param PVALUE : String
#*!
$LOG_WRITE_STRING

  ARET_VALUE = fmet this.LOG_WRITE_STRING_STATUS(PVALUE, [V]CST_AOK)

Return

#**
#* Write a free string with warning status
#*
#* @param PVALUE : String
#*!
$LOG_WRITE_STRING_WARNING

  ARET_VALUE = fmet this.LOG_WRITE_STRING_STATUS(PVALUE, [V]CST_AWARNING)

Return

#**
#* Write a free string with error status
#*
#* @param PVALUE : String
#*!
$LOG_WRITE_STRING_ERROR

  ARET_VALUE = fmet this.LOG_WRITE_STRING_STATUS(PVALUE, [V]CST_AERROR)

Return

#**
#* Write a free string with status parameters
#*
#* @param PVALUE : String
#* @param PSTAT  : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_WRITE_STRING_STATUS

  ARET_VALUE = fmet this.TRC_CLASS(1).APUTLINE(PVALUE, PSTAT)

Return

#**
#* Write a separator line
#*
#*!
$LOG_WRITE_STRING_SEPARATOR

  ARET_VALUE = fmet this.LOG_WRITE_STRING(this.LINE_SEP)

Return

#**
#* Write line(s) feed
#*
#* @param PNUMBER : Number line to feed
#*!
$LOG_WRITE_LINEFEED

Local Integer I

  # corrected the parameter if bad
  If PNUMBER < 1
    PNUMBER = 1
  Endif

  ARET_VALUE = [V]CST_AOK
  For [L]I = 1 To PNUMBER
    ARET_VALUE = fmet this.LOG_WRITE_STRING("")
  Next [L]I

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Write the column's title
#*
#*!
$LOG_WRITE_TITLES

Local Integer I, OK

  [L]OK = [V]CST_ATRUE

  ARET_VALUE = fmet this.LOG_INIT_LINE()

  For [L]I = 1 To this.NBCOL
    ARET_VALUE = fmet this.LOG_PUT_STR_COLUMN([L]I, this.CEL_DEF([L]I).TITLE)
    If ARET_VALUE >= [V]CST_AERROR
      [L]OK = [V]CST_AFALSE
      Break
    Endif
  Next [L]I

  If [L]OK = [V]CST_ATRUE
    # Write line only if all title colunms are set
    ARET_VALUE = fmet this.LOG_WRITE([V]CST_AOK)
  Endif

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Write the sum of numerics fields
#*
#* #* @param PSTAT : []CST_AOK, []CST_AERROR, []CST_AWARNING
#*!
$LOG_WRITE_SUM

Local Integer I, OK

  this.FOOTER = [V]CST_ATRUE

  ARET_VALUE = fmet this.LOG_INIT_LINE()
  For [L]I = 1 To this.NBCOL
    If this.CEL_DEF([L]I).TYPCOL = "A"
      If [L]I = 1
        ARET_VALUE = fmet this.LOG_PUT_COLUMN([L]I, "sum")
      Else
        ARET_VALUE = fmet this.LOG_PUT_COLUMN([L]I, "")
      Endif
    Elsif this.CEL_DEF([L]I).TYPCOL = "D"
      ARET_VALUE = fmet this.LOG_PUT_COLUMN([L]I, "")
    Else
      ARET_VALUE = fmet this.LOG_PUT_COLUMN([L]I, num$(this.CEL_DEF([L]I).CUMUL))
    Endif
  Next [L]I
  this.FOOTER = [V]CST_AFALSE
  ARET_VALUE = fmet this.LOG_WRITE(PSTAT)

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Write the header
#*
#*!
$LOG_WRITE_HEADER

  ARET_VALUE = fmet this.LOG_WRITE_STRING("Date :" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$)

  # Write the user
  If this.H_USR <> AVOID.ACHAR # GACTX.USER
    ARET_VALUE = fmet this.LOG_WRITE_STRING(mess(2, 63, 1) - ":" - this.H_USR)
  Endif
  ARET_VALUE = fmet this.LOG_WRITE_LINEFEED(1)

  # Cpy
  If this.H_CPY <> AVOID.ACHAR
    ARET_VALUE = fmet this.LOG_WRITE_STRING("Société :" - this.H_CPY)
  Endif

  # Fcy
  If this.H_FCY <> AVOID.ACHAR
    ARET_VALUE = fmet this.LOG_WRITE_STRING("Site :" - this.H_FCY)
  Endif

  # Simulation
  If this.H_SIM = [V]CST_AYES or this.H_SIM = [V]CST_ANO
    ARET_VALUE = fmet this.LOG_WRITE_STRING("Simulation :" - mess(this.H_SIM, 1, 1))
  Endif

  ARET_VALUE = fmet this.AGETMAXERROR("")

Return

#**
#* Write the footer
#*
#*!
$LOG_WRITE_FOOTER

  ARET_VALUE  = fmet this.LOG_WRITE_STRING_SEPARATOR()
  ARET_VALUE  = fmet this.LOG_WRITE_STRING("Date :" - format$("D:DD[/]MM[/]YYYY", date$) - "-" - time$)

Return


#**
#* Write the counter Ok and Ko
#*!
$LOG_NB_OK

  ARET_VALUE = fmet this.LOG_WRITE_STRING("Total :" - num$(PNBTOT) - "Ok :" - num$(PNBOK) - "Ko :" - num$(PNBKO))

Return

# Issue 110494
#--------------------------------------------------------------------------------------------------
#**
#* Write error stack of an object into Syracuse ALOG
#* Use this subprog for general counters.
#* @param POBJ   : object instance
#* @param PLOG   : log class instance
#* @param RNBINFO : receive +1 if info message number
#* @param RNBWARNING : receive +1 if warning message number
#* @param RNBERROR : receive +1 if error or fatal error message number
#*!
Subprog LOG_WRITE_AERROR_GENERAL_COUNT(POBJ, PLOG, RNBINFO, RNBWARNING, RNBERROR)
Value Instance POBJ Using OBJECT
Value Instance PLOG Using OBJECT
Variable Integer RNBINFO
Variable Integer RNBWARNING
Variable Integer RNBERROR

Local Integer NBINFO, NBWARNING, NBERROR, NBFATAL
  Raz NBINFO, NBWARNING, NBERROR, NBFATAL

  Call LOG_WRITE_AERROR_STACK_COUNT(POBJ, PLOG, NBINFO, NBWARNING, NBERROR, NBFATAL)

  RNBINFO    += min(1, [L]NBINFO)
  RNBWARNING += min(1, [L]NBWARNING)
  RNBERROR   += min(1, [L]NBERROR + [L]NBFATAL)

End
# End Issue 110494
#--------------------------------------------------------------------------------------------------
#**
#* Write error stack of an object into Syracuse ALOG
#*
#* @param POBJ   : object instance
#* @param PLOG   : log class instance
#* @param RNBINFO : receive info message number
#* @param RNBWARNING : receive warning message number
#* @param RNBERROR : receive error message number
#* @param RNBFATAL : receive fatal error message number
#*!
Subprog LOG_WRITE_AERROR_STACK_COUNT(POBJ, PLOG, RNBINFO, RNBWARNING, RNBERROR, RNBFATAL)
Value Instance POBJ Using OBJECT
Value Instance PLOG Using OBJECT
Variable Integer RNBINFO
Variable Integer RNBWARNING
Variable Integer RNBERROR
Variable Integer RNBFATAL

  Local Integer N_I, RET
  Local Char PRO(250)

  # ----------------------------------------------------
  #   Stack error status | log (trace) status
  # ----------------------------------------------------
  #   CST_AINFO          | CST_AOK      (standard color)
  #   CST_AWARNING       | CST_AWARNING (green color)
  #   CST_AERROR         | CST_AERROR   (red color)
  #   CST_AFATAL         | CST_AERROR   (red color)
  # ----------------------------------------------------

  For [L]N_I = 1 To maxtab(POBJ.AERROR)
    If POBJ.AERROR(N_I) <> null
      PRO = POBJ.AERROR([L]N_I).PRO
      If PRO <> AVOID.ACHAR
        PRO += "/"
      Endif
      Case POBJ.AERROR([L]N_I).STA
        When [V]CST_AINFO, [V]CST_ASUCCESS:
          RNBINFO += 1
        When [V]CST_AWARNING:
          RNBWARNING += 1
        When [V]CST_AERROR:
          RNBERROR += 1
        When [V]CST_AFATAL:
          RNBFATAL += 1
        When Default:
      Endcase
      [L]RET = fmet PLOG.LOG_WRITE_STRING_STATUS("-> " - PRO - POBJ.AERROR([L]N_I).MES -
&                     "(" + num$(POBJ.AERROR([L]N_I).NUM) + "/" + num$(POBJ.AERROR([L]N_I).STA) + ")",
&                     POBJ.AERROR([L]N_I).STA)
    Endif
  Next N_I

End

#--------------------------------------------------------------------------------------------------
#**
#* Write error stack of an object into Syracuse ALOG
#*
#* @param POBJ   : object instance
#* @param PLOG   : log class instance
#*!
Subprog LOG_WRITE_AERROR_STACK(POBJ, PLOG)
Value Instance POBJ Using OBJECT
Value Instance PLOG Using OBJECT

  Local Integer N_I, RET
  Local Char PRO(250)

  # ----------------------------------------------------
  #   Stack error status | log (trace) status
  # ----------------------------------------------------
  #   CST_AINFO          | CST_AOK      (standard color)
  #   CST_AWARNING       | CST_AWARNING (green color)
  #   CST_AERROR         | CST_AERROR   (red color)
  #   CST_AFATAL         | CST_AERROR   (red color)
  # ----------------------------------------------------

  For [L]N_I = 1 To maxtab(POBJ.AERROR)
    If POBJ.AERROR(N_I) <> null
      PRO = POBJ.AERROR([L]N_I).PRO
      If PRO <> AVOID.ACHAR
        PRO += "/"
      Endif
      [L]RET = fmet PLOG.LOG_WRITE_STRING_STATUS("-> " - PRO - POBJ.AERROR([L]N_I).MES -
&                     "(" + num$(POBJ.AERROR([L]N_I).NUM) + "/" + num$(POBJ.AERROR([L]N_I).STA) + ")",
&                     POBJ.AERROR([L]N_I).STA)
    Endif
  Next N_I

End

#**
#* Construct the string align to left, right ou center
#*
#* @param PVALUE    : value to align
#* @param PLGCOL    : len of column
#* @param PALIGNCOL : align code
#* @param RVALUE    : receive value
#* @return void
#*!
Subprog LOG_ALIGN_COLUMN (PVALUE, PLGCOL, PALIGNCOL, RVALUE)
Value Char PVALUE
Value Integer PLGCOL
Value Integer PALIGNCOL
Variable Char RVALUE

Local Char WSPACE(100), WLSPACE(100), WRSPACE(100)

  # Align on left or right side
  [L]WSPACE = string$(max(0, PLGCOL - len(PVALUE)), " ")
  Case PALIGNCOL
    When 0 :
      # Center align
      [L]WLSPACE = string$(len([L]WSPACE) / 2, " ")
      [L]WRSPACE = string$(PLGCOL - len([L]WLSPACE) - len(PVALUE), " ")
    When [V]CST_ANO :
      # Right align
      [L]WLSPACE = [L]WSPACE
      [L]WRSPACE = ""
    When Default :
      # Left align
      [L]WLSPACE = ""
      [L]WRSPACE = [L]WSPACE
  Endcase
  RVALUE = [L]WLSPACE + PVALUE + [L]WRSPACE

End

