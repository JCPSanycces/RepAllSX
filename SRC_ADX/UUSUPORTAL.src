#<AdxTL>@(#)2.0.0.0 $Revision$
Call OUVRE_TRACE("Delete APTLPAR") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

# Moulinette pour virer la table APTLPAR des dossiers filles
# Cette table étant maintenant de type "Système"

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Char TABLE(GLONATB) , ORDSYS(250)(1..2) , FICTRA(GDIMFIC) , APPLI(GLONADS) , MESSAGE(250)(1..5)
Local Integer STAT
TABLE = "APTLPAR"
If DOSSIER<>GDOSX3 : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER=APPLI
Endif
For [ADS] Where DOSSIER<>GDOSX3
 If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".ADOVAL" [AD_]
  Read [AD_]ADW0="";"";"SUPDOS"
  If !fstat & [F:AD_]VALEUR=GDOSX3
   APPLI = [F:ADS]DOSSIER
   Gosub VIRE_TABLE
   Read [AD_]ADW0="";"";"HISDOS"
   If !fstat & [F:AD_]VALEUR<>""
    APPLI = [F:AD_]VALEUR
    Gosub VIRE_TABLE
   Endif
  Endif
  Close Local File [AD_]
 Endif
Next ADS
Close Local File
End

$VIRE_TABLE
If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<=0
 Return
Endif
FICTRA = filpath("tmp",TABLE,"tra",APPLI)
Call EFFACE(FICTRA ,STAT) From ORDSYS
ORDSYS(1) = "valfil -d"-APPLI-TABLE
ORDSYS(2)  = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
adxifs = ""
adxirs = chr$(10)
Openi FICTRA Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Openi Using [TR_]
If MESSAGE(1)<>""
 Call ECR_TRACE("Error"-APPLI-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
Else
 Call EFFACE(filpath("FIL",TABLE,"fde",APPLI),STAT) From ORDSYS
 Call EFFACE(filpath("FIL",TABLE,"srf",APPLI),STAT) From ORDSYS
 Call EFFACE(filpath("FIL",TABLE,"viw",APPLI),STAT) From ORDSYS
 Call EFFACE(FICTRA,STAT) From ORDSYS
 Call ECR_TRACE(APPLI-TABLE-": File deleted",0) From GESECRAN
Endif
Return
