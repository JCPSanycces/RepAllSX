#<AdxTL>@(#)0.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Action   : DETREVMUL - Détail révision
#   Fenêtre  : DETREVMUL
#   Ecran concerné : DETREVMUL
#   Description : Dans le cas d'une révision multiples, offre dans un
#                 tableau la liste les objets concerné par la demande
#
#--------------------------------------------------------------------------

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
Endcase
Return

$OUVRE
If !clalev([F:BVD])  : Local File BUDREVDET [BVD]  : Endif
If !clalev([F:BRV2]) : Local File BUDREV    [BRV2] : Endif
If !clalev([F:ENV2]) : Local File ENVELOPPE [ENV2] : Endif
If !clalev([F:ENF2]) : Local File ENVFIY    [ENF2] : Endif
If !clalev([F:BUD2]) : Local File BUD       [BUD2] : Endif
Local Mask DETREVMUL [DRM]
Local Integer I, L
Local Decimal REALISE
Local Integer INDENV, INDENT, INDCCE3
Return

$DEBUT
If PARAM(1)<>""
 Gosub CHARGE_TAB
Else
 FIN=1
Endif
Return

$CHARGE_TAB
Raz [M:DRM]
Read [BRV2]BRV0 = PARAM(1)
If !fstat
 Filter [BVD] Where NUMREV=[F:BRV2]NUM
 I=0
 For [BVD]BVD0
  [M:DRM]TYP(I)    = [F:BVD]TYP
  [M:DRM]ENV(I)    = [F:BVD]ENV
  [M:DRM]FIY(I)    = [F:BVD]FIY
  #-----------#
  # pour recuperer l'intitule court de l'exercice
  Call LECTURE("ENV",[F:BVD]ENV,"") From CONTOBJ
  Local Libelle LEDTYPGEN, LEDTYPANA
  Call SETMAINREF([F:ENV]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BVD]FIY
  If !fstat
   [M:DRM]INTFIY(I) = num$([F:BVD]FIY)+"-"+[F:FIY]DESSHO
  Endif
  #-----------#
  [M:DRM]ACC(I)    = [F:BVD]ACC
  [M:DRM]CUR(I)    = [F:BVD]CUR
  [M:DRM]AMT(I)    = [F:BVD]AMT
  [M:DRM]AMTASK(I) = [F:BVD]AMTASK
  [M:DRM]AMTPRS(I) = [F:BVD]AMTPRS
  [M:DRM]AMTPNV(I) = [F:BVD]AMTPNV
  [M:DRM]AMTRAL(I) = [F:BVD]AMTRAL
  Call LEC_ENV([F:BVD]ENV) From CPTLEC
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

  #Montant réalisé et solde
  Case [F:BVD]TYP
   When 1
    Call CAL_REALISE(1,[F:BVD]ENV,0,INDENV,"",REALISE) From SUBBRVR
    Read [ENV2]ENV0 = [F:BVD]ENV
    If !fstat
     [M:DRM]SOLDE(I) = [F:ENV2]AMTENV-REALISE
    Endif
   When 2
    Call CAL_REALISE(2,[F:BVD]ENV,[F:BVD]FIY,INDENV,"",REALISE) From SUBBRVR
    Read [ENF2]ENF0 = [F:BVD]ENV;[F:BVD]FIY
    If ! fstat
     [M:DRM]SOLDE(I) = [F:ENF2]AMTBUDFIY-REALISE
    Endif
   When 3
    Call CAL_REALISE(3,[F:BVD]ENV,[F:BVD]FIY,INDENV,[F:BVD]ACCNUM,REALISE) From SUBBRVR
    Read [BUD2]BUD1 = [F:BVD]ACCNUM
    If ! fstat
     [M:DRM]SOLDE(I)  = [F:BUD2]AMT(0)-REALISE
     [M:DRM]ENTDEN(I) = [F:BUD2]CCE1
    Endif
  Endcase
  [M:DRM]REALISE(I)=[L]REALISE
  I+=1
 Next
 Filter [BVD]
 [M:DRM]NBLIG=I
 Affzo [M:DRM]
 Gosub COLORIZE
Endif
Return

$COLORIZE
For I=0 To [M]NBLIG-1
 Chgstl [M]NBLIG(I) With "GDD"+num$([M]TYP(I))
Next
Affzo [M]
Return

