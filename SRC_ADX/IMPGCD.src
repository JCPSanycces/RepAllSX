#<AdxTL>@(#)2.0.0.0 $Revision$

$ACTION
 Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 Endcase
Return


$IMP_OUVRE
If clalev([COA]) = 0 : Local File GCOA     [COA] : Endif
If clalev([DIE]) = 0 : Local File GDIE     [DIE] : Endif
If clalev([CCE]) = 0 : Local File CACCE    [CCE] : Endif
Return


$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
Return


$CONTROLE
#--------- Le champs COAORI est obligatoire et existant
If [F:GCD]COA=""
 GMESSAGE ="COA"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:GCD]COA
 If fstat
  GMESSAGE = "COA"-mess(83,123,1)-[F:GCD]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
 If [F:COA]ANATRK<>2
  GMESSAGE = [F:GCD]COA-mess(83,123,1)-[F:GCD]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs LIN est obligatoire
If [F:GCD]LIN=0 
 GMESSAGE ="LIN"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Endif

#--------- Le champs ACCSTR est obligatoire
If [F:GCD]ACCSTR=""
 GMESSAGE = "ACCSTR"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Endif 

#--------- Le champs DIE est obligatoire et doit existé
If [F:GCD]DIE=""
 GMESSAGE = "DIE"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [F:DIE]DIE0 = [F:GCD]DIE
 If fstat
  GMESSAGE = [F:GCD]DIE-mess(80,103,1) # Axe inexistant
  OK=0 : Return
 Endif
Endif

#--------- Le champs CCE doit existé
If [F:GCD]CCE<>""
 Read [F:CCE]CCE0 = [F:GCD]DIE;[F:GCD]CCE
 If fstat
  GMESSAGE = [F:GCD]CCE-mess(35,106,1)-"("+[F:GCD]DIE+")"  # Section inexistante
  OK=0 : Return
 Endif
Endif
Return



