#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:57 080


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOIDUKI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOIDUKI

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOIDUKI
Else
 Gosub AINSERT_EMPLOIDUKI
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOIDUKI.freeSnapshot
EMPLOIDUKI.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOIDUKI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOIDUKI.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOIDUKI
Trbegin [F:IDUKI]
 Gosub AINSERT_EMPLOIDUKI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOIDUKI
Raz [F:IDUKI]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOIDUKI._MAJSQL_EMPLOIDUKI(EMPLOIDUKI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOIDUKI.snapshotEnabled=1
 [L]A_RETIK = EMPLOIDUKI.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOIDUKI.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOIDUKI.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOIDUKI.ASTALIN = [V]CST_ALL
Endif
Return



