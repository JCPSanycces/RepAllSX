#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet PWA
# Table PARWIPACC paramètres des clés d'agrégation des wipcost pour la production

$ACTION
Case ACTION
 When "AFFMASK"  Gosub AFFMASK
 When "RAZCRE"   Gosub RAZCRE
 When "RAZDUP"   Gosub RAZCRE
 When "SETBOUT"  Gosub SETBOUT
 When "EXEBOUT"  Gosub EXEBOUT
 When Default
Endcase
Return

##########################################################################
$AFFMASK
Call FMTLEG From TRTX3
Return

##########################################################################
$RAZCRE
If func AFNC.ACTIV("LEG")=0
    [M:PWA1]LEG = GDOSLEG(1)
Endif
Return

##########################################################################
$SETBOUT
CHAINE += "A"    # Suppression
Return

##########################################################################
$EXEBOUT
Case BOUT
    When "V":
        Local Integer LRET1, LRET2
        
        # génération du traitement qui servira à la comptabilisation
        # d'un groupe d'enregistrements de Wipcost
        Lock WIPACC With lockwait=0  # à faire avant la génération du trt (eventuellmt lu par qq'un)
          ## ou locker par société à partir d'un code site saisi MAIS le trt généré ne doit pas être touché !
        If fstat
          # Afficher un message d'erreur, car quelqu'un est déjà en train de comptabiliser les encours d'OF
          GMESSAGE = mess(270,197,1) # "Interface comptable deja en cours"
          GERR = 2
        Else
            Call OUVRE_TRACE(mess(147,123,1)) From LECFIC
            Call ECR_TRACE(mess(97,187,1),0) From GESECRAN
            LRET1 = func FUNWIPACC.CTRVALPWA(nomap,"")
            Call ECR_TRACE(mess(98,187,1),0) From GESECRAN
            LRET2 = func FUNWIPACC.CTRVALSWA(nomap,"")
            Call FERME_TRACE() From LECFIC
            If LRET1 | LRET2
                Call LEC_TRACE From LECFIC
            Endif
            Raz LRET1
            Call GENTRT(nomap,LRET1) From FUNWIPACC
            Unlock WIPACC
        Endif
Endcase
Return
