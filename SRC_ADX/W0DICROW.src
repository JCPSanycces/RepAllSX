#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DICROW 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
indice = 0
status = 1
zoncou = "NBRLIG"
If varmode([M]NBRLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRLIG = nolign
   status = 75
   Call SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
IMPENT = [M]ENAFLG(indice)
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG(indice) = IMPENT

## Zone ENASEL
mkstat = 0
zoncou = "ENASEL"
IMPENT = [M]ENASEL(indice)
If varinit([M]ENASEL,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENASEL,indice)=0
 [M]ENASEL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENASEL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENASEL(indice)
 Endif
Endif
[M]ENASEL(indice) = IMPENT

## Zone MSFLG
mkstat = 0
zoncou = "MSFLG"
IMPENT = [M]MSFLG(indice)
If varinit([M]MSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MSFLG,indice)=0
 [M]MSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MSFLG(indice)
 Endif
Endif
[M]MSFLG(indice) = IMPENT

## Zone ROW
mkstat = 0
zoncou = "ROW"
If varmode([M]ROW,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ROW" : Gosub ACTION From =IMPTRT
 Endif
 If [M]ROW(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ROW" : GZNUM = 747 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone POTFLG
mkstat = 0
zoncou = "POTFLG"
IMPENT = [M]POTFLG(indice)
If varinit([M]POTFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]POTFLG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POTFLG(IMPENT) From DICROW
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]POTFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "POTFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]POTFLG(indice)
 Endif
Endif
[M]POTFLG(indice) = IMPENT

## Zone FLGRET
mkstat = 0
zoncou = "FLGRET"
IMPENT = [M]FLGRET(indice)
If varinit([M]FLGRET,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGRET,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FLGRET(IMPENT) From DICROW
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]FLGRET(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGRET" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGRET(indice)
 Endif
Endif
[M]FLGRET(indice) = IMPENT

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DICROW"
Return

