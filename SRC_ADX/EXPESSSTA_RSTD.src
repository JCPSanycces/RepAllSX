#<AdxTL>@(#)0.0.0.0 $Revision$
# Class EXPESSSTA_EXPENSES

$EVENTS
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$METHODS
Case [L]CURPTH
   When ""
    Case [L]ACTION
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

$AQUERY_CRITERIA_AFTER
Local Char ESS_REFNUM(GLONEML)
ESS_REFNUM = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and EXSSTA ne 2 and EXSSTA ne 5 and EXSSTA ne 1 and (REFNUM eq '"+ESS_REFNUM+"')"
  Else
    PQRY.QWHERE = "EXSSTA ne 2 and EXSSTA ne 5 and EXSSTA ne 1 and (REFNUM eq '"+ESS_REFNUM+"')"
  Endif
Return

