#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe DPRMOD

$ACTION
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase
Return

###############
# METHODS
###############
$METHODS
  Case CURPTH
    When ""
      Case AMETHOD
        When "AREAD_AFTER" : Gosub AREAD_AFTER_DPM
      Endcase
  Endcase
Return

$AREAD_AFTER_DPM
  Local Integer I
  For I = 1 To 15
    this.PLN(I).DPRPLN = I
  Next I
Return

#############
# PROPERTIES
#############
$PROPERTIES
  Case CURPRO
    When "CNSRAT" : Gosub CNSRAT
    When "RATCUM" : Gosub RATCUM
  Endcase
Return

# CNSRAT
$CNSRAT
  Case ACTION
    When "GET"    : Gosub CNSRAT_GET
  Endcase
Return

$CNSRAT_GET
  If this.RATCOETYP = GVML_COBSMTC or this.RATCOETYP = GVML_COBSDTC
    this.CNSRAT = this.DMR(1).RAT
  Endif

  If this.RATCOETYP = GVML_COANNUI or this.RATCOETYP = GVML_COBSMTM
    this.CNSRAT = 0
  Endif
Return

# RATCUM
$RATCUM
  Case ACTION
    When "GET"    : Gosub RATCUM_GET
  Endcase
Return

$RATCUM_GET
  Local Integer I

  this.RATCUM = 0

  For I = 1 To maxtab(this.DMR)
    If this.DMR(I) <> null
      this.RATCUM += this.DMR(I).RAT
    Endif
  Next
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

