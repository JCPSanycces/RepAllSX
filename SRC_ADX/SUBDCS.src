########################################
Subprog AM_CODDCS2(VALEUR)
Variable Char    VALEUR()
Local Integer VOK
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If [M:DCS1]TYPDCS(nolign-1)<>0 : End : Endif
Read[ADI]CODE=10378;VALEUR
If !fstat
 Case[M:DCS1]CAICOD(nolign-1)
 When GINDARR :
  VAGF=val(right$([F:ADI]A2,1+len([F:ADI]A2)-2))
  If (VAGF>=30 & VAGF<=39)
   [M:DCS1]TYPDCS(nolign-1)=1
  Else
   #51407 : Ajout test TYPDCS (vaut 1  pour l'AGFF)
   VOK=1
   Call OUINON (mess(29,10714,1),VOK) From GESECRAN    :#Cotisation AGFF
   [M:DCS1]TYPDCS(nolign-1)=VOK-1
  Endif
 When GINDAGI :
  VAGF=val(right$([F:ADI]A2,1+len([F:ADI]A2)-2))
  If (VAGF>=30 & VAGF<=39)
   [M:DCS1]TYPDCS(nolign-1)=1
  Else
   #51407 : Ajout test TYPDCS (vaut 1  pour l'AGFF)
   VOK=1
   Call OUINON (mess(29,10714,1),VOK) From GESECRAN    :#Cotisation AGFF
   [M:DCS1]TYPDCS(nolign-1)=VOK-1
  Endif
 Endcase
Endif
End

