########################################
Subprog AS_STRCOT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M]STRDAT : Endif
End

##64313
########################################
Subprog AS_ENDCOT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=eomonth([M]STRCOT) : Endif
End

