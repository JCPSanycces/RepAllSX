########################################
Subprog D_CAICOD(VALEUR)
Variable Integer VALEUR
If [M:DCS0]CAI<3
 VALEUR=[M:DCS0]CAI
Elsif [M:DCS0]CAI>=3 & [M:DCS0]CAI<=5
 VALEUR=[M:DCS0]CAI+1            :#Prevoyance , Arrco & Agirc décalage de 1 entre l'entête et les lignes !
Else
 VALEUR=GINDARR :#Arrco par défaut
Endif
End

########################################
Subprog D_ORGCOD(VALEUR)
Variable Char    VALEUR()
If [M:DCS0]CAI<6
 VALEUR=[M:DCS0]ORG
Endif
End

########################################
Subprog AS_CAICOD(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,10329,1))
 GMENLOC(I)=1
Next
Case GFLAG
 When "DCS" : GMENLOC(GINDURS)=0
 When "DCA" : GMENLOC(GINDASS)=0
 When "DCI" : GMENLOC(GINDARR)=0 : GMENLOC(GINDAGI)=0 : GMENLOC(GINDPREV)=0
Endcase
#Pas un groupe
If [M:DCS0]CAI<3
 VALEUR=[M:DCS0]CAI
 mkstat=2 : End
Elsif [M:DCS0]CAI>=3 & [M:DCS0]CAI<=5
 VALEUR=[M:DCS0]CAI+1
 mkstat=2 : End
Else
 If !VALEUR
  VALEUR=GINDARR :#Arrco par défaut
 Endif
Endif
End

########################################
Subprog AS_ORGCOD(VALEUR)
Variable Char    VALEUR()
#Pas un groupe
If [M:DCS0]CAI<6
 VALEUR=[M:DCS0]ORG
 mkstat=2 : End
Endif
End

########################################
Subprog C_ORGCOD(VALEUR)
Variable Char    VALEUR()
Read [F:ORG]ORG0=GCURLEG;VALEUR
If fstat | [F:ORG]TYPIRC+1<>[M:DCS1]CAICOD(nolign-1)
 #Cet organisme est de nature : xxx
 GMESSAGE=mess(20,10714,1)-":"- mess([F:ORG]TYPIRC,10386,1)
 mkstat=2 : End
Endif
End

########################################
Subprog C_GRDNBR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]GRDNBR(0..[M]NBLIG-1)) From OBJDIV
If mkstat=2 : End : Endif
End

########################################
Subprog C_TRSRAT1(VALEUR)
Variable Decimal VALEUR
I=find(VALEUR,[M:DCS3]TRSRAT1(0..NBRTRS-1))
If I & I<>nolign & [M:DCS3]TRSCODSEE(I-1)=[M:DCS3]TRSCODSEE(nolign-1)
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat=2 : End
Endif
End

########################################
Subprog C_TATRAT1(VALEUR)
Variable Decimal VALEUR
I=find(VALEUR,[M:DCS3]TATRAT1(0..NBRTAT-1))
If I & I<>nolign & [M:DCS3]TATCODSEE(I-1)=[M:DCS3]TATCODSEE(nolign-1)
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat=2 : End
Endif
End

########################################
Subprog AS_QTY2(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1 | [M:DCS1]AMT2(nolign-1)=0 :#Urssaf
 mkstat=1 : End
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

########################################
Subprog AS_RAT(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI=1
 If [M:DCS1]AMT1(nolign-1)=0 :  mkstat=1 : End : Endif
Else
 If abs([M:DCS1]AMT1(nolign-1))+ abs([M:DCS1]AMT2(nolign-1))=0 : mkstat=1 : End : Endif
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

########################################
Subprog AS_RAT2(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI=1
 If [M:DCS1]AMT2(nolign-1)=0 : mkstat=1 : End : Endif
Else
 If abs([M:DCS1]AMT1(nolign-1))+ abs([M:DCS1]AMT2(nolign-1))=0 : mkstat=1 : End : Endif
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

