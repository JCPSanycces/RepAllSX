#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du fichier DUCS0
Raz GPILOBJ
Call OBJET("DCS",GBIDC1,"") From GOBJET
End

##############################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "AVANTBOUT" : Gosub AVANTBOUT
 When "VERF_ANU"  : Gosub VERF_ANU
 When "CREATION"  : Gosub CREATION
 When "INICRE"    : Gosub INICRE
 When "MODIF"     : Gosub MODIF
 When "INIMOD"    : Gosub INIMOD
 When "FILTRE"    : Gosub FILTRE
 When "FERME"     : Gosub FERME
Endcase
Return

##############################################
$OUVRE
If clalev([F:DCS])=0 : Local File DUCS0      [DCS] : Endif
If clalev([F:DCL])=0 : Local File DUCS1      [DCL] : Endif
If clalev([F:DCT])=0 : Local File DUCS2      [DCT] : Endif
If clalev([F:DCX])=0 : Local File DUCS3      [DCX] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:PCA])=0 : Local File CAISSE     [PCA] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
Local Integer I, TROUVE

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

##############################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

##############################################
$SETBOUT
#pour désactiver le bouton "creer" et chgt clé
Call VIREBOUT (CHAINE,"H") From GOBJET
#Proposition de l'édition adaptée l'organisme
If CLECUR & [M:DCS0]CPY<>"" & [M:DCS0]ORG<>""
  Case [M:DCS0]CAI
   When 1        : REPORT1 ="DURSSAF"
   When 2        : REPORT1 ="DASSEDIC"
   When Default  : REPORT1 ="DIRC"
  Endcase
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
#39925
If GREP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"B") From GOBJET
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

##############################################
$AVANTBOUT
Case BOUT
 When "B" :
 OK=1
 #Une nouvelle extraction écrasera les données existantes. Voulez-vous continuez ?
 Call AVERTIR (mess(24,10714,1), OK) From GESECRAN
 If OK<>2 : OK=0 : Endif
Endcase
Return

##############################################
$FILTRE
Case GFLAG
 When "DCS" : FILTSUP ="CAI="+num$(GINDURS)
 When "DCA" : FILTSUP ="CAI="+num$(GINDASS)
 When "DCI" : FILTSUP ="CAI>"+num$(GINDASS)+"& CAI<8"
Endcase
Return

##############################################
$VERF_ANU
Trbegin [DCS],[DCL],[DCT],[DCX]
 Delete [DCS] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$DUCS0" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [F:DCL] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$DUCS1" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [F:DCT] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$DUCS2" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [F:DCX] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$DUCS3" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

##############################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

##############################################
$AB_ANN
Rollback
Return

##############################################
$LIENS
Call LECTURE('CPY',[M:DCS0]CPY,'') From CONTOBJ
If dim( [F:CPY]LEG )> 0
  GCURLEG=[F:CPY]LEG
Endif

Local Integer TEMPO
Gosub CHARGE_LIGNES
TEMPO=[F:DCS]NULEMP
Call AM_NULEMP(TEMPO)
TEMPO=[F:DCS]ENDACT
Call AM_ENDACT(TEMPO)
Case [F:DCS]CAI
When 1 :
 Gosub CHARGE_TRS
 Gosub CHARGE_TAT
When 2 :
 Gosub CHARGE_EFF
Endcase
Return

##############################################
$CHARGE_LIGNES
nolign = 0
For [F:DCL]DCL0 Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
  nolign += 1
  [M:DCS1]=[F:DCL]
Next
[M:DCS1]BPAG = nolign
Return

##############################################
$CHARGE_TRS
nolign = 0
For [F:DCT]DCT0 Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
 nolign += 1
 [M:DCS3]TRSCODSEE(nolign-1)=[F:DCT]TRSCODSEE
 [M:DCS3]TRSRAT1(nolign-1)=[F:DCT]TRSRAT(0)
 [M:DCS3]TRSBAS1(nolign-1)=[F:DCT]TRSBAS(0)
 [M:DCS3]TRSRAT2(nolign-1)=[F:DCT]TRSRAT(1)
 [M:DCS3]TRSBAS2(nolign-1)=[F:DCT]TRSBAS(1)
 [M:DCS3]TRSRAT3(nolign-1)=[F:DCT]TRSRAT(2)
 [M:DCS3]TRSBAS3(nolign-1)=[F:DCT]TRSBAS(2)
Next
[M:DCS3]NBRTRS = nolign
#87653: Ajout totaux transport
Gosub RECAL_TOTTRS
Return

##############################################
$CHARGE_TAT
nolign = 0
For [F:DCX]DCX0 Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
  nolign += 1
 [M:DCS3]TATCODSEE(nolign-1)=[F:DCX]TATCODSEE
 [M:DCS3]TATRAT1(nolign-1)=[F:DCX]TATRAT(0)
 [M:DCS3]TATBAS1(nolign-1)=[F:DCX]TATBAS(0)
 [M:DCS3]TATRAT2(nolign-1)=[F:DCX]TATRAT(1)
 [M:DCS3]TATBAS2(nolign-1)=[F:DCX]TATBAS(1)
 [M:DCS3]TATRAT3(nolign-1)=[F:DCX]TATRAT(2)
 [M:DCS3]TATBAS3(nolign-1)=[F:DCX]TATBAS(2)
Next
[M:DCS3]NBRTAT = nolign
#87653: Ajout totaux transport
Gosub RECAL_TOTTAT
Return

##############################################
$CHARGE_EFF
If dim([M:DCS4]NBRCDDM)<=0 : Return : Endif
[M:DCS4]NBRCDDM=[F:DCS]NBRCDD(0) : [M:DCS4]NBRCDDW=[F:DCS]NBRCDD(1)
[M:DCS4]NBRCDIM=[F:DCS]NBRCDI(0) : [M:DCS4]NBRCDIW=[F:DCS]NBRCDI(1)
[M:DCS4]NBRAPPM=[F:DCS]NBRAPP(0) : [M:DCS4]NBRAPPW=[F:DCS]NBRAPP(1)
[M:DCS4]NBROLDM=[F:DCS]NBROLD(0) : [M:DCS4]NBROLDW=[F:DCS]NBROLD(1)
[M:DCS4]NBRDIRM=[F:DCS]NBRDIR(0) : [M:DCS4]NBRDIRW=[F:DCS]NBRDIR(1)
[M:DCS4]NBRCESM=[F:DCS]NBRCES(0) : [M:DCS4]NBRCESW=[F:DCS]NBRCES(1)
[M:DCS4]NBRCNEM=[F:DCS]NBRCNE(0) : [M:DCS4]NBRCNEW=[F:DCS]NBRCNE(1)
For nolign=1 To dim([F:DCS]GRDNBR)
 If [F:DCS]GRDNBR(nolign-1)="" : Break : Endif
 [M:DCS4]GRDNBR(nolign-1)=[F:DCS]GRDNBR(nolign-1)
Next
[M:DCS4]NBLIG=nolign-1
Return


##############################################
$CREATION
$MODIF
Gosub SAUVE_LIGNES
If [F:DCS]CAI=1 : :#Urssaf
 Gosub SAUVE_TRS
 Gosub SAUVE_TAT
Endif
Return

##############################################
$INICRE
$INIMOD
[F:DCS]CAI=[M:DCS0]CAI
#Utiliser dans les éditions...
Call ORGAFFIL ([M:DCS0]ORG,[M:DCS0]FCY,"","",[F:DCS]NUMAFF,[F:DCS]NUMCTR) From SUBORA
#Effectif Assedic
If [F:DCS]CAI=2 : Gosub SAUVE_EFF : Endif
Return

##############################################
$SAUVE_EFF
If dim([M:DCS4]NBRCDDM)<=0 : Return : Endif
[F:DCS]NBRCDD(0)=[M:DCS4]NBRCDDM : [F:DCS]NBRCDD(1)=[M:DCS4]NBRCDDW
[F:DCS]NBRCDI(0)=[M:DCS4]NBRCDIM : [F:DCS]NBRCDI(1)=[M:DCS4]NBRCDIW
[F:DCS]NBRAPP(0)=[M:DCS4]NBRAPPM : [F:DCS]NBRAPP(1)=[M:DCS4]NBRAPPW
[F:DCS]NBROLD(0)=[M:DCS4]NBROLDM : [F:DCS]NBROLD(1)=[M:DCS4]NBROLDW
[F:DCS]NBRDIR(0)=[M:DCS4]NBRDIRM : [F:DCS]NBRDIR(1)=[M:DCS4]NBRDIRW
[F:DCS]NBRCES(0)=[M:DCS4]NBRCESM : [F:DCS]NBRCES(1)=[M:DCS4]NBRCESW
[F:DCS]NBRCNE(0)=[M:DCS4]NBRCNEM : [F:DCS]NBRCNE(1)=[M:DCS4]NBRCNEW
For I=0 To [M:DCS4]NBLIG-1
 [F:DCS]GRDNBR(I)=[M:DCS4]GRDNBR(I)
Next
Return

##############################################
$SAUVE_LIGNES
Delete [F:DCL] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
If fstat=1
 GOK =-1 : GLOCK = "$DUCS1" : End
Endif
For nolign=1 To [M:DCS1]BPAG
 Raz [DCL]
 [F:DCL]=[M:DCS1]
 [F:DCL]CPY=[M:DCS0]CPY
 [F:DCL]FCY=[M:DCS0]FCY
 [F:DCL]ORG=[M:DCS0]ORG
 [F:DCL]CAI=[M:DCS0]CAI
 [F:DCL]STRDAT=[M:DCS0]STRDAT
 [F:DCL]ENDDAT=[M:DCS0]ENDDAT
 [F:DCL]NUMLIG=nolign
 Write [DCL]
 If fstat<>0
  GOK = 0 : Call FSTA("DCL") From GLOCK : Break
 Endif
Next
Return

##############################################
$SAUVE_TRS
Delete [F:DCT] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
If fstat=1
 GOK =-1 : GLOCK = "$DUCS2" : End
Endif
For nolign=1 To [M:DCS3]NBRTRS
 Raz [DCT]
 [F:DCT]TRSCODSEE=[M:DCS3]TRSCODSEE(nolign-1)
 [F:DCT]TRSRAT(0)=[M:DCS3]TRSRAT1(nolign-1)
 [F:DCT]TRSBAS(0)=[M:DCS3]TRSBAS1(nolign-1)
 [F:DCT]TRSRAT(1)=[M:DCS3]TRSRAT2(nolign-1)
 [F:DCT]TRSBAS(1)=[M:DCS3]TRSBAS2(nolign-1)
 [F:DCT]TRSRAT(2)=[M:DCS3]TRSRAT3(nolign-1)
 [F:DCT]TRSBAS(2)=[M:DCS3]TRSBAS3(nolign-1)
 [F:DCT]CPY=[M:DCS0]CPY
 [F:DCT]FCY=[M:DCS0]FCY
 [F:DCT]ORG=[M:DCS0]ORG
 [F:DCT]CAI=[M:DCS0]CAI
 [F:DCT]STRDAT=[M:DCS0]STRDAT
 [F:DCT]ENDDAT=[M:DCS0]ENDDAT
 [F:DCT]NUMLIG=nolign
 Write [DCT]
 If fstat<>0
  GOK = 0 : Call FSTA("DCT") From GLOCK : Break
 Endif
Next
Return

##############################################
$SAUVE_TAT
Delete [F:DCX] Where  CPY=[M:DCS0]CPY & FCY=[M:DCS0]FCY & ORG=[M:DCS0]ORG & STRDAT=[M:DCS0]STRDAT & ENDDAT=[M:DCS0]ENDDAT
If fstat=1
 GOK =-1 : GLOCK = "$DUCS3" : End
Endif
For nolign=1 To [M:DCS3]NBRTAT
 Raz [DCX]
 [F:DCX]TATCODSEE=[M:DCS3]TATCODSEE(nolign-1)
 [F:DCX]TATRAT(0)=[M:DCS3]TATRAT1(nolign-1)
 [F:DCX]TATBAS(0)=[M:DCS3]TATBAS1(nolign-1)
 [F:DCX]TATRAT(1)=[M:DCS3]TATRAT2(nolign-1)
 [F:DCX]TATBAS(1)=[M:DCS3]TATBAS2(nolign-1)
 [F:DCX]TATRAT(2)=[M:DCS3]TATRAT3(nolign-1)
 [F:DCX]TATBAS(2)=[M:DCS3]TATBAS3(nolign-1)
 [F:DCX]CPY=[M:DCS0]CPY
 [F:DCX]FCY=[M:DCS0]FCY
 [F:DCX]ORG=[M:DCS0]ORG
 [F:DCX]CAI=[M:DCS0]CAI
 [F:DCX]STRDAT=[M:DCS0]STRDAT
 [F:DCX]ENDDAT=[M:DCS0]ENDDAT
 [F:DCX]NUMLIG=nolign
 Write [DCX]
 If fstat<>0
  GOK = 0 : Call FSTA("DCX") From GLOCK : Break
 Endif
Next
Return

################################################################################
#                            ETIQUETTES ECRAN
################################################################################

########################################
Subprog AM_CPY(VALEUR)
Variable Char   VALEUR
Effzo [M:DCS0]FCY
Effzo [M:DCS0]ORG
Affzo[M:DCS0]

Call LECTURE('CPY',VALEUR,'') From CONTOBJ
GCURLEG=[F:CPY]LEG

End

########################################
Subprog D_CAI(VALEUR)
Variable Integer VALEUR
Case GFLAG
 When "DCS" : VALEUR=1
 When "DCA" : VALEUR=2
 When "DCI" : VALEUR=3
Endcase
End

########################################
Subprog AS_CAI(VALEUR)
Variable Integer VALEUR
Local Integer I, DEB, FIN
Case GFLAG
 When "DCS" : DEB=2 : FIN=len(mess(0,10386,1))
 When "DCA" : GMENLOC(1)=1 : DEB=3 : FIN=len(mess(0,10386,1))
 When "DCI" : DEB=1 : FIN=2 : GMENLOC(8)=1
Endcase
For I=DEB To FIN
 GMENLOC(I)=1
Next
End

########################################
Subprog C_ORG(VALEUR)
Variable Char   VALEUR
Local Char CRIT(100)
CRIT="[F:ORG]TYPIRC="+num$([M]CAI)
Case[M]CAI
 When 3    : CRIT-="| [F:ORG]TYPIRC=7"
 When 4,5  : CRIT-="| ([F:ORG]TYPIRC>=6 & [F:ORG]TYPIRC<8)"
 When 6    : CRIT-="| [F:ORG]TYPIRC=4 | [F:ORG]TYPIRC=5"
 When 7    : CRIT-="| ([F:ORG]TYPIRC>=3 & [F:ORG]TYPIRC<8)"
Endcase
Read [F:ORG]ORG0=GCURLEG;VALEUR
If fstat | !evalue(CRIT)
 #Cet organisme est de nature : xxx
 GMESSAGE=mess(20,10714,1)-":"- mess([F:ORG]TYPIRC,10386,1)
 mkstat=2 : End
Endif
End

########################################
Subprog AM_ENDACT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:DCS2]DATENDACT
Else
 Effzo [M:DCS2]DATENDACT
 Grizo [M:DCS2]DATENDACT
Endif
End

########################################
Subprog AM_NULEMP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:DCS2]DATNULEMP
Else
 Effzo [M:DCS2]DATNULEMP
 Grizo [M:DCS2]DATNULEMP
Endif
End

########################################
Subprog AS_AMT1(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1 & [M:DCS1]AMT2(nolign-1)<>0
 mkstat=1 : End
Endif
End

########################################
Subprog AM_AMT1(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1
 [M:DCS1]AMT1(nolign-1)=VALEUR
 Gosub RECAL_AMT3
Endif
End

########################################
Subprog AS_AMT2(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1 & [M:DCS1]AMT1(nolign-1)<>0
 mkstat=1 : End
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

########################################
Subprog AM_AMT2(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1
 [M:DCS1]AMT2(nolign-1)=VALEUR
 Gosub RECAL_AMT3
Endif
End

########################################
Subprog AM_RAT(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1
 [M:DCS1]RAT(nolign-1)=VALEUR
 Gosub RECAL_AMT3
Endif
End

########################################
Subprog AS_RATWAC(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI<>1 :#Urssaf
 mkstat=1 : End
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

########################################
$RECAL_AMT3
#64379 : Notre plan de paie gère les forfaits de façon particulière car c'est le taux qui contient la base !
If [M:DCS1]NBREMP2(nolign-1)>0
 [M:DCS1]AMT3(nolign-1)=arr(([M:DCS1]AMT2(nolign-1)*[M:DCS1]NBREMP2(nolign-1)),0.01)
Else
 If [M:DCS1]AMT1(nolign-1)<>0 & [M:DCS1]RAT(nolign-1)
  [M:DCS1]AMT3(nolign-1)=arr(([M:DCS1]AMT1(nolign-1)*[M:DCS1]RAT(nolign-1)/100),0.01)
 Elsif [M:DCS1]AMT2(nolign-1)<>0 & [M:DCS1]RAT(nolign-1)
  [M:DCS1]AMT3(nolign-1)=arr(([M:DCS1]AMT2(nolign-1)*[M:DCS1]RAT(nolign-1)/100),0.01)
 Endif
Endif
Affzo [M:DCS1]AMT3(nolign-1)
Return

########################################
Subprog AS_AMT3(VALEUR)
Variable Decimal VALEUR
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
If [M:DCS0]CAI=1 : End : Endif
#64379 : Notre plan de paie gère les forfaits de façon particulière car c'est le taux qui contient la base !
If [M:DCS1]NBREMP2(nolign-1)>0
 VALEUR=arr(([M:DCS1]AMT2(nolign-1)*[M:DCS1]NBREMP2(nolign-1)),0.01)
Else
 If [M:DCS1]AMT1(nolign-1)<>0 & [M:DCS1]RAT(nolign-1)
  VALEUR=arr(([M:DCS1]AMT1(nolign-1)*[M:DCS1]RAT(nolign-1)/100),0.01)
  End
 Endif
 If [M:DCS1]AMT2(nolign-1)<>0 & [M:DCS1]RAT(nolign-1)
  VALEUR=arr(([M:DCS1]AMT2(nolign-1)*[M:DCS1]RAT(nolign-1)/100),0.01)
 Endif
Endif
End

########################################
Subprog AS_AMT4(VALEUR)
Variable Decimal VALEUR
If [M:DCS0]CAI=2 :#Assedic
 mkstat=1 : End
Endif
#87135
Read[F:ADI]CODE=377;[M:DCS1]CODDCS(nolign-1)
If !fstat & [F:ADI]A2='400'
mkstat=1 : End
Endif
#
End

########################################
Subprog APRES_BPAG
Gosub RECAL_TOT
End

########################################
Subprog AS_BPAG
Gosub RECAL_TOT
End

########################################
$RECAL_TOT
Local Integer I
Raz[M:DCS1]TOTAMT,TOTREG
For I=0 To [M:DCS1]BPAG-1
 [M:DCS1]TOTAMT+=[M:DCS1]AMT3(I)
 [M:DCS1]TOTREG+=[M:DCS1]AMT4(I)
Next
Affzo[M:DCS1]TOTAMT,TOTREG
Return

########################################
#87653: Ajout totaux transport
Subprog AS_NBRTRS
Gosub RECAL_TOTTRS
End

Subprog APRES_NBRTRS
Gosub RECAL_TOTTRS
End

Subprog AS_NBRTAT
Gosub RECAL_TOTTAT
End

Subprog APRES_NBRTAT
Gosub RECAL_TOTTAT
End

########################################
#87653: Ajout totaux transport
$RECAL_TOTTRS
Local Integer I
Raz [M:DCS3]TOTTRS
For I=0 To [M:DCS3]NBRTRS-1
  [M:DCS3]TOTTRS+=[M:DCS3]TRSRAT1(I)*([M:DCS3]TRSBAS1(I)/100)+[M:DCS3]TRSRAT2(I)*([M:DCS3]TRSBAS2(I)/100)
& +[M:DCS3]TRSRAT3(I)*([M:DCS3]TRSBAS3(I)/100)
Next
Affzo[M:DCS3]TOTTRS
Return

########################################
#87653: Ajout totaux transport
$RECAL_TOTTAT
Local Integer I
Raz [M:DCS3]TOTTAT
For I=0 To [M:DCS3]NBRTAT-1
 [M:DCS3]TOTTAT+=[M:DCS3]TATRAT1(I)*([M:DCS3]TATBAS1(I)/100)+[M:DCS3]TATRAT2(I)*([M:DCS3]TATBAS2(I)/100)
& +[M:DCS3]TATRAT3(I)*([M:DCS3]TATBAS3(I)/100)
Next
Affzo [M:DCS3]TOTTAT
Return

