###################################################################################################
$ENAFLG
  Case [L]ARULE
    When "INIT" : Gosub ENAFLG_INIT
  Endcase
Return

$ENAFLG_INIT
  this.ENAFLG = [V]CST_AYES
Return

###################################################################################################
$PCCFCY
  Case [L]ARULE
    When "CONTROL"   : Gosub PCCFCY_CONTROL
    When "PROPAGATE" : Gosub PCCFCY_PROPAGATE
  Endcase
Return

$PCCFCY_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.snapshot.PCCFCY <> this.PCCFCY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCCFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

$PCCFCY_PROPAGATE
Local Integer ISTATUS

  # ---------------------------------------
  If this.PCCFCY <> AVOID.ACHAR Then
    # ---------------------------------------
    # A partir du site récupération du modèle, référentiels,...
    I_FCY = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.PCCFCY)
    If I_FCY <> [V]CST_ANOTDEFINED Then
      L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PCCFCY,"LEGCPY")
    Endif
    # ---------------------------------------
    this.PCCCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(L_CPY,"RGCCUR")
  Endif
  # ---------------------------------------
  ISTATUT = fmet this.CDIE_ERASE_COLLECTION()
  If ISTATUT = [V]CST_AOK Then
    ISTATUT = fmet this.CDIE_INIT()
    [L]ASTATUS = max([L]ASTATUS, ISTATUS)
  Else
    [L]ASTATUS = max([L]ASTATUS, ISTATUS)
  Endif
  # ---------------------------------------
Return

