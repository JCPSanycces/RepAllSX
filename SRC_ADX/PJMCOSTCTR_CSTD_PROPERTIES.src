###################################################################################################
# Class PJMCOSTCTR
###################################################################################################
# Properties
###################################################################################################
$TCHREPDIECCE
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  Case [L]ARULE
    When "INIT" : Gosub TCHREPDIECCE_INIT
  Endcase
Return

$TCHREPDIECCE_INIT
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  this.TCHREPDIECCE = [V]CST_AYES
Return

