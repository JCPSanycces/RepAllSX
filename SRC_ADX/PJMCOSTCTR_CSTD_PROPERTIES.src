###################################################################################################
$PCCCUR
  Case [L]ARULE
    When "PROPAGATE" : Gosub PCCCUR_PROPAGATE
  Endcase
Return

$PCCCUR_PROPAGATE
Local Integer NI

  For NI = 1 To maxtab(this.DATRATE)
    If this.DATRATE(NI) <> null and find(this.DATRATE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      this.DATRATE(NI).PCCCUR = this.PCCCUR
    Endif
  Next NI
Return

###################################################################################################
$PCCPROV
  Case [L]ARULE
    When "INIT"    : Gosub PCCPROV_INIT
  Endcase
Return

$PCCPROV_INIT
  this.PCCPROV = [V]CST_ANO
Return

###################################################################################################
$PCCPRCT
  Case [L]ARULE
    When "CONTROL" : Gosub PCCPRCT_CONTROL
  Endcase
Return

$PCCPRCT_CONTROL
  If this.PCCPRCT < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCCPRCT", mess(314,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PCCCOD2
  Case [L]ARULE
    When "CONTROL" : Gosub PCCCOD2_CONTROL
  Endcase
Return

$PCCCOD2_CONTROL
  If this.PCCCOD2 <> AVOID.ACHAR Then
    # ----------------------------------
    Local File PJMCOSTCTR [PJCC]
    Read [PJCC]PCC0=this.PCCCOD2
    If [F:PJCC]PCCPROV = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCCCOD2", mess(342,2260,1), [V]CST_AERROR))
    Endif
    # ----------------------------------
  Endif
Return

###################################################################################################
$ITMREF
  # Issue X3-3414/119352 - 2016-10-24 by SINGC
  Case [L]ARULE
    When "CONTROL" : Gosub ITMREF_CONTROL
  Endcase
Return

$ITMREF_CONTROL
# Issue X3-3414/119352 - 2016-10-24 by SINGC
Local Integer IRET
Local Char SMESSAGE(250)

  If this.ITMREF <> AVOID.ACHAR Then
    # ----------------------------------
    IRET = func PJMCOSTCTR_CSTD_PROGS.IS_ITMREF_VALID(this.ITMREF, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("ITMREF", SMESSAGE, IRET))
    Endif
    # ----------------------------------
  Endif
Return

###################################################################################################
$ACCCOD
  # Issue X3-66481 - 2018-05-28 by SINGC
  Case [L]ARULE
    When "CONTROL" : Gosub ACCCOD_CONTROL
  Endcase
Return

$ACCCOD_CONTROL
  # Issue X3-66481 - 2018-05-28 by SINGC
  If this.ACCCOD <> AVOID.ACHAR Then
    Local File GACCCODE [CAC]
    # ----------------------------------
    Read [CAC]CAC0(2)=36;this.ACCCOD
    If fstat Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("ACCCOD", mess(11,114,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$CDIE_CCE
  Case [L]ARULE
    When "CONTROL"   : Gosub CDIE_CCE_CONTROL
  Endcase
Return

$CDIE_CCE_CONTROL
Local Char SMESSAGE(250)

  # Note : in this case .APARENT. is mandatory existing because this is a dimensionned property in the table
  #        => this.APARENT can't be = null in this case
  [L]ASTATUS = func FINCCE_SYRA.CTL_CCE (this.ACTX, this.CCE, this.DIE, this.APARENT.PCCFCY, [0/0/0],  SMESSAGE)
  If [L]ASTATUS <> [V]CST_AOK Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("CCE", SMESSAGE, [L]ASTATUS))
  Endif
Return

###################################################################################################
$CDIE_CHX
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  Case [L]ARULE
    When "INIT"    : Gosub CDIE_CHX_INIT
    When "CONTROL" : Gosub CDIE_CHX_CONTROL
  Endcase
Return

$CDIE_CHX_INIT
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  this.CHX = [V]CST_AYES
Return

$CDIE_CHX_CONTROL
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  If this.ASTALIN = [V]CST_AUPD Then
    If this.snapshot.CHX = [V]CST_AYES and this.CHX = [V]CST_ANO Then
      If this.CCE <> AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("CHX", this.DIE - ":" - mess(18,9804,1), [V]CST_AERROR))
      Endif
    Endif
    # -------------------------
    If this.CHX = [V]CST_AYES Then
      Local File GDIE [DIE]
      Call LEC_DIE(this.DIE) From CPTLEC
      If this.APARENT.PCCCOD <> vireblc(format$([F:DIE]CCEFMT,this.APARENT.PCCCOD),1) Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("CHX", this.DIE - ":" - mess(435,2260,1), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
COSTGRP_PCGTYP
  Case [L]ARULE
    When "PROPAGATE" : Gosub COSTGRP_PCGTYP_PROPAGATE
  Endcase
Return

$COSTGRP_PCGTYP_PROPAGATE
Local Integer NI
Local Integer IMAXPCGGRP

  IMAXPCGGRP = 0
  Case this.PCGTYP
    When 1
      For NI = 1 To maxtab(this.APARENT.COSTGRP)
        If this.APARENT.COSTGRP(NI) <> null and find(this.APARENT.COSTGRP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.APARENT.COSTGRP(NI) <> this Then
            If this.APARENT.COSTGRP(NI).PCGTYP = this.PCGTYP Then
              IMAXPCGGRP = max(IMAXPCGGRP, this.APARENT.COSTGRP(NI).PCGGRPMAT)
            Endif
          Endif
        Endif
      Next NI
      If len(mess(0,325,1)) >= IMAXPCGGRP+1 Then
        this.PCGGRPMAT = IMAXPCGGRP+1
      Endif
      this.PCGGRPLAB = 0
      this.PCGGRPMAC = 0
    When 2
      For NI = 1 To maxtab(this.APARENT.COSTGRP)
        If this.APARENT.COSTGRP(NI) <> null and find(this.APARENT.COSTGRP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.APARENT.COSTGRP(NI) <> this Then
            If this.APARENT.COSTGRP(NI).PCGTYP = this.PCGTYP Then
              IMAXPCGGRP = max(IMAXPCGGRP, this.APARENT.COSTGRP(NI).PCGGRPLAB)
            Endif
          Endif
        Endif
      Next NI
      If len(mess(0,316,1)) >= IMAXPCGGRP+1 Then
        this.PCGGRPLAB = IMAXPCGGRP+1
      Endif
      this.PCGGRPMAT = 0
      this.PCGGRPMAC = 0
    When 3
      For NI = 1 To maxtab(this.APARENT.COSTGRP)
        If this.APARENT.COSTGRP(NI) <> null and find(this.APARENT.COSTGRP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.APARENT.COSTGRP(NI) <> this Then
            If this.APARENT.COSTGRP(NI).PCGTYP = this.PCGTYP Then
              IMAXPCGGRP = max(IMAXPCGGRP, this.APARENT.COSTGRP(NI).PCGGRPMAC)
            Endif
          Endif
        Endif
      Next NI
      If len(mess(0,316,1)) >= IMAXPCGGRP+1 Then
        this.PCGGRPMAC = IMAXPCGGRP+1
      Endif
      this.PCGGRPMAT = 0
      this.PCGGRPLAB = 0
  Endcase
Return

