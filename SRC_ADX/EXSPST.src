#&                  , UID   =-adxuid(2), VCRNUM=[V]GNUMPCE, VCRTYP=[V]GTYPPCE
#  If fstat
#   [V]GOK=0
#   Call RSTA("EXS",[L]IDENT(2)-[L]IDENT(3)-[L]IDENT(4)-[L]IDENT(5)) From GLOCK
