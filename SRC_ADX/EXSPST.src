#
# If [L]TRA
#  Call TRACE_PIECE(1) From CPTBATCH
# Endif
#Until 0
#If [V]GOK<0 : Return : Endif
#
#If [M:EXSP]SIMFLG<2
## V6
## Raz [F:ADI]
## If dim([F:ADI]CRETIM)>0 : [F:ADI]CRETIM=-adxuid(2) : Endif
#
## 109411 : version V7. Modifier Modéle de donnée FRAIS2
#  Raz [F:ADI]
#  If dim([F:ADI]N1)>0 : [F:ADI]N1=-adxuid(2) : Endif
#
# Call WORKFLOW(1,"CNF","","") From AWRK
# If [V]GOK<1 : Return : Endif
#
# Update [EXS] Where UID=-adxuid(2) With UID=0
# If fstat
#  [V]GOK=0
#  Call RSTA("EXS",num$(-adxuid(2))) From GLOCK
#  Return
# Endif
#Endif
# # 117743 : clean datas if error before. Pb link with bug 101687
# # if error, uid isn't reset and we keep the error later
# Update [EXS] Where UID=adxuid(2) With UID=0
Repeat
 Filter [HREXS] Where UID=adxuid(2)
#JASMI - 2017-09-29 - X3-58158 - START
# Read [HREXS]EXS1(0) First
 Read [HREXS]HREXS1(0) First
#JASMI - 2017-09-29 - X3-58158 - END
 Filter [HREXS]
 If fstat : Break : Endif

 [L]IDENT(1)=num$(adxuid(2))
 [L]IDENT(2)=[F:HREXS]CUR
 [L]IDENT(3)=[F:HREXS]FCY
 [L]IDENT(4)=[F:HREXS]VCRTYP
 [L]IDENT(5)=num$([F:HREXS]EXSNUM)

 If [M:EXSP]SIMFLG=2

  Call SIMPCE([L]PCEAUTO,[L]IDENT,[L]STAT,[L]MESSA) From CPTAUTO
  If [L]STAT
   Call ECR_TRACE([L]MESSA-"("-num$([L]STAT)-")",1) From GESECRAN
   If [L]TRA
    Call TRACE_PIECE(1) From CPTBATCH
   Endif
   Break
  Endif

  Update [HREXS] Where UID=adxuid(2) & CUR=[L]IDENT(2) & FCY=[L]IDENT(3) & VCRTYP=[L]IDENT(4) & EXSNUM=val([L]IDENT(5)) With UID=0
  If fstat
   [V]GOK=0
   Call RSTA("HREXS",[L]IDENT(2)-[L]IDENT(3)-[L]IDENT(4)-[L]IDENT(5)) From GLOCK
   Break
  Endif

 Else
  Call VALPCE([L]PCEAUTO,[L]IDENT,[L]STAT,[L]MESSA) From CPTAUTO
  If [L]STAT
   Call ECR_TRACE([L]MESSA-"("-num$([L]STAT)-")",1) From GESECRAN
   If [L]TRA
    Call TRACE_PIECE(1) From CPTBATCH
   Endif
   Break
  Endif

  #DEHEN - 2016-10-18 - JIRRA X3PEOP-2176 : Sub Task 2312 - START
  #ENTRY POINT#
  GPOINT = "AFT_PCEAUTO" : Gosub ENTREE From EXEFNC
  #DEHEN - 2016-10-18 - JIRRA X3PEOP-2176 : Sub Task 2312 - END

  I=find(func DIVPAYE.GETSOC([F:HREXS]FCY),[V]GSOC(1..[V]GNBSOC))
  For [LNK2]HREXS0(1) Hint Key EXS1 Where UID=adxuid(2) & CUR=[L]IDENT(2) & FCY=[L]IDENT(3) & VCRTYP=[L]IDENT(4) & EXSNUM=val([L]IDENT(5))
   Raz [L]MTFRAIS, [L]MTAVANCE
   For [LNK2]HREXS0
    Call CONVERT( [F:HREXS]CUR,[V]GDEVSOC(I),[V]GDEVSOC(I),[F:HREXS]TYPRAT, [F:HREXS]DATEXS,[F:HREXS]RFUCUR,[F:HREXS]RFUCUR,[L]STAT) From TRTDEV
    If [L]STAT
     Call ECR_TRACE( mess(34,110,1)-"("+[F:HREXS]CUR-"->"-[V]GDEVSOC(I)+")",1) From GESECRAN
     # Erreur de conversion en devise
     [V]GOK     =0
     Break 3
    Else
#DIRAS - 2017/06/07 - JIRA X3-35887 - START
     If [F:HRTES]DEB=2 : [L]STAT=-1 : Else [L]STAT=1 : Endif
     If [F:HRTES]PRO=2 : [L]MTAVANCE+= (-[L]STAT)*[F:HREXS]RFUCUR : Endif
#     If [F:TES]DEB=2 : [L]STAT=-1 : Else [L]STAT=1 : Endif
#     If [F:TES]PRO=2 : [L]MTAVANCE+= (-[L]STAT)*[F:HREXS]RFUCUR : Endif
#DIRAS - 2017/06/07 - JIRA X3-35887 - END
     [L]MTFRAIS+=[L]STAT*[F:HREXS]RFUCUR
    Endif
   Next

   If [L]MTFRAIS | [L]MTAVANCE
    Readlock [SDP]SDP0=[F:HREXS]REFNUM;[F:HREXS]CTRNUM
    [L]STAT=fstat
    If fstat=1
     [V]GOK  =-1
     [V]GLOCK="$SOLDPAY"-[F:HREXS]REFNUM-[F:HREXS]CTRNUM
     Break 2
    Elsif fstat
     Raz [F:SDP]
     [F:SDP]EMP   =[F:HREXS]REFNUM
     [F:SDP]CTRNUM=[F:HREXS]CTRNUM
     Read [ID]ID0=[F:HREXS]REFNUM
     If !fstat : [F:SDP]CODACS=[F:ID]CODACS : Endif
     Read [ECT]ECT0=[F:HREXS]REFNUM;[F:HREXS]CTRNUM
     If !fstat : [F:SDP]FCY=[F:ECT]FCY : [F:SDP]SRV=[F:ECT]SRV : Endif
    Endif
#MIPEA - 2017-06-07 - X3-35887 - START
    Call ADDSOLDE([L]IFRAIS,[L]MTFRAIS) From SUBHRSLD
    Call ADDSOLDE([L]IAVANCE,[L]MTAVANCE) From SUBHRSLD
#    Call ADDSOLDE([L]IFRAIS,[L]MTFRAIS) From SUBSLD
#    Call ADDSOLDE([L]IAVANCE,[L]MTAVANCE) From SUBSLD
#MIPEA - 2017-06-07 - X3-35887 - END

    If [L]STAT : Write [SDP] : Else Rewrite [SDP] Curr : Endif
    If fstat
     [V]GOK=0
     Call FSTA("SDP") From GLOCK
     Break 2
    Endif
   Endif
  Next

  Update [HREXS] Where UID=adxuid(2) & CUR=[L]IDENT(2) & FCY=[L]IDENT(3) & VCRTYP=[L]IDENT(4) & EXSNUM=val([L]IDENT(5)) With STA =2
&                  , UID   =-adxuid(2), VCRNUM=[V]GNUMPCE, VCRTYP=[V]GTYPPCE
  If fstat
   [V]GOK=0
   Call RSTA("HREXS",[L]IDENT(2)-[L]IDENT(3)-[L]IDENT(4)-[L]IDENT(5)) From GLOCK
   Break
  Endif

  # Création pièce
  Call ECR_TRACE( mess(40,107,1)-[V]GTYPPCE-[V]GNUMPCE-"("+[L]IDENT(2)-[L]IDENT(3)- [L]IDENT(4)-[L]IDENT(5)+")",0) From GESECRAN #CHECK IGNORE_LINE
 Endif

 If [L]TRA
  Call TRACE_PIECE(1) From CPTBATCH
 Endif
Until 0
If [V]GOK<0 : Return : Endif

If [M:EXSP]SIMFLG<2
# V6
# Raz [F:ADI]
# If dim([F:ADI]CRETIM)>0 : [F:ADI]CRETIM=-adxuid(2) : Endif

# 109411 : version V7. Modifier Modéle de donnée FRAIS2
  Raz [F:ADI]
  If dim([F:ADI]N1)>0 : [F:ADI]N1=-adxuid(2) : Endif

 Call WORKFLOW(1,"CNF","","") From AWRK
 If [V]GOK<1 : Return : Endif

 Update [HREXS] Where UID=-adxuid(2) With UID=0
 If fstat
  [V]GOK=0
  Call RSTA("HREXS",num$(-adxuid(2))) From GLOCK
  Return
 Endif
Endif
 # 117743 : clean datas if error before. Pb link with bug 101687
 # if error, uid isn't reset and we keep the error later
 Update [HREXS] Where UID=adxuid(2) With UID=0
#LIPET - 2017-05-05 - X3-35887 - END
Return

