#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char    PARAM(10)(1..2)
Local Integer VALEUR
Call TRAITE_LIB([L]VALEUR,[L]PARAM,"","EXSPST","DEXSPST",4,"") From GTRAITE
End

$ACTION
Case [L]ACTION
 When "INIT"     : Goto INIT
 When "INIT_DIA" : Goto INIT_DIA
 When "CONTROLE" : Goto CONTROLE
 When "EXEC"     : Goto EXEC
 When "TERMINE"  : Goto TERMINE
 When "SORTIE"   : Goto SORTIE
#-------------------------------------------------------------------------------
 When "DEBUT"    : Affzo [EXSP] : Goto DEBUT
 When "OK"       : Goto OK
Endcase
Return

################################################################################
#
# GTRAITE
#
################################################################################



$INIT
#92876-US2780
## FQ 105501
#GERR=1
#GMESSAGE=mess(246,702,1)
## FQ 105501 fin
#92876-US2780 : fin
#-------------
#FQ 122610
#Local Libelle I, IFRAIS, IAVANCE
Local Integer I
Local Libelle IFRAIS, IAVANCE
#------------
Local Char    SYMBOLE(50), CRITERE(255), PCEAUTO([V]GLONGAU)
Local Char    MESSA(250), IDENT(50)(1..5)
Local Integer STAT
Local Decimal MTFRAIS, MTAVANCE
Local Char CRITFCY (250)

If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif
If !clalev([F:ID])  : Local File EMPLOID   [ID]  : Endif
If !clalev([F:CPT]) : Local File EMPLOCPT  [CPT] : Endif
#MIPEA - 2017-06-07 - X3-35887 - START
If !clalev([F:HRPOA]) : Local File POPULA    [HRPOA] : Endif
#If !clalev([F:POA]) : Local File POPULA    [POA] : Endif
#MIPEA - 2017-06-07 - X3-35887 - END
#LIPET - 2017-05-05 - X3-35887 - START
#If !clalev([F:EXS]) : Local File EXPENSES  [EXS] : Endif
If !clalev([F:HREXS]) : Local File HREXPENSES  [HREXS] : Endif
#LIPET - 2017-05-05 - X3-35887 - END
If !clalev([F:SDP]) : Local File SOLDPAY   [SDP] : Endif
#DIRAS - 2017/06/07 - JIRA X3-35887 - START
If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif
#If !clalev([F:TES]) : Local File TABEXPENS [TES] : Endif
#DIRAS - 2017/06/07 - JIRA X3-35887 - END
#LIPET - 2017-05-05 - X3-35887 - START
#If !clalev([F:CTR]) : Local File EMPLOCTR  [CTR] : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR] : Endif
#LIPET - 2017-05-05 - X3-35887 - END
If !clalev([F:ECT]) : Local File EMPCTR    [ECT] : Endif
If !clalev([F:CPR]) : Local File EMPLOCTRCPT [CPR] : Endif

Local Char WBPR([V]GLONBPR)
#LIPET - 2017-05-05 - X3-35887 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 2017-05-05 - X3-35887 - END
If !clalev([F:BPR]) & dim([V]GTABCPT)>0 & [V]GTABCPT<>""
&& find("BPR",[V]GABRCPT(1..[V]GNBTABCPT))
 Local File =[V]GTABCPT+"BPARTNER" [BPE]
Endif

If dim([V]GTYPPCE)=-1 : Global Char GTYPPCE([V]GLONGTE) : Endif
If dim([V]GNUMPCE)=-1 : Global Char GNUMPCE([V]GLONVCR) : Endif

Local Mask EXSPST : Gosub INIT_DIA
Return

#-------------------------------------------------------------------------------
$INIT_DIA
Raz [M:EXSP]
#LIPET - 2017-05-05 - X3-35887 - START
#Call LECMEMO("STD","[M:EXSP]","exs") From GMEMO
#Call LITDAT("EXS",[M:EXSP]DATDEB,[M:EXSP]DATFIN) From SUBEXS
Call LECMEMO("STD","[M:EXSP]","HREXS") From GMEMO
Call LITDAT("HREXS",[M:EXSP]DATDEB,[M:EXSP]DATFIN) From SUBHREXS
#LIPET - 2017-05-05 - X3-35887 - END
Return

#-------------------------------------------------------------------------------
$DEBUT
#LIPET - 2017-05-05 - X3-35887 - START
If [M:EXSP]LEG<>""
  GCURLEG = [M:EXSP]LEG
Endif
#LIPET - 2017-05-05 - X3-35887 - END
Return
#-------------------------------------------------------------------------------

$OK
#LIPET - 2017-05-05 - X3-35887 - START
If [M:EXSP]LEG="" Then
   GERR  = 1
   GMESSAGE = mess(232,143,1)
   zonsui = "[M:EXSP]LEG" #Put the focus on the field.
   FIN = 0 # Instruct the supervisor to keep the window open
   GOK = 0
   Return
Endif
#LIPET - 2017-05-05 - X3-35887 - END
Return

$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif

#LIPET - 2017-05-05 - X3-35887 - START
#Call PARAM("","EXSPAY",[L]PCEAUTO) From ADOVAL
Call PARAM(GCURLEG,"EXSPAY",[L]PCEAUTO) From ADOVAL
#LIPET - 2017-05-05 - X3-35887 - END
If [L]PCEAUTO=""
 [V]GMESSAGE=mess(136,199,1)-"(NOF EXSPAY)" : # Paramètre non renseigné
 [V]GERR    =1
 [L]SAI     =1
 Return
Else
#LIPET - 2017-05-05 - X3-35887 - START
 #Call LECTURE("ADI",[L]PCEAUTO,"365") From CONTOBJ
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Filter [ADI] Where NUMTAB=10365 & LEG=GCURLEG
Read [ADI]CODE=10365;[L]PCEAUTO
Filter [ADI]
# Call LECTURE("ADI",[L]PCEAUTO,"10365") From CONTOBJ
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#LIPET - 2017-05-05 - X3-35887 - END
 If fstat | [F:ADI]N1<1
  #LIPET - 2017-05-05 - X3-35887 - START
  #[V]GMESSAGE=mess(12,718,1)-"(365"-[L]PCEAUTO+")" : # No interne incorrect sur la table diverse
  [V]GMESSAGE=mess(12,10718,1)-"(10365"-[L]PCEAUTO+")" :
  #LIPET - 2017-05-05 - X3-35887 - END
  [V]GERR    =1
  [L]SAI     =1
  Return
 Else
  [L]IFRAIS=[F:ADI]N1
 Endif
Endif

#LIPET - 2017-05-05 - X3-35887 - START
#Call PARAM("","EXSADV",[L]PCEAUTO) From ADOVAL
Call PARAM(GCURLEG,"EXSADV",[L]PCEAUTO) From ADOVAL
#LIPET - 2017-05-05 - X3-35887 - END
If [L]PCEAUTO=""
 [V]GMESSAGE=mess(136,199,1)-"(NOF EXSADV)" : # Paramètre non renseigné
 [V]GERR    =1
 [L]SAI     =1
 Return
Else
 If val([L]PCEAUTO)<1
  #LIPET - 2017-05-05 - X3-35887 - START
  #[V]GMESSAGE=mess(20,718,1)-":"+[L]PCEAUTO    : # Référence du solde des avances sur frais incorrecte
  [V]GMESSAGE=mess(20,10718,1)-":"+[L]PCEAUTO    :
  #LIPET - 2017-05-05 - X3-35887 - END
  [V]GERR    =1
  [L]SAI     =1
  Return
 Else
  [L]IAVANCE=val([L]PCEAUTO)
 Endif
Endif

#LIPET - 2017-05-05 - X3-35887 - START
#Call PARAM("","ODFRAIS",[L]PCEAUTO) From ADOVAL
Call PARAM(GCURLEG,"ODFRAIS",[L]PCEAUTO) From ADOVAL
#LIPET - 2017-05-05 - X3-35887 - END
If [L]PCEAUTO=""
 [V]GMESSAGE=mess(39,114,1) : # Pièce automatique inexistante
 [V]GERR    =1
 [L]SAI     =1
 Return
Endif

If [M:EXSP]CRI>""
 #LIPET - 2017-05-05 - X3-35887 - START
 #Gosub OUVRE From DEFTABLE
 Gosub OUVRE From WPDEFTABLE
 #LIPET - 2017-05-05 - X3-35887 - END
Endif

#LIPET - 2017-05-05 - X3-35887 - START
#[L]CRITERE="1=1"
#[L]CRITFCY=""
#If [M:EXSP]ALLCPY<>2
# If [M:EXSP]ALLFCY<>2
#  [L]CRITFCY='[CTR]ETRFCY="'+[M:EXSP]FCY+'"'
# Else
#  For I=1 To [V]GNBSITE
#   If [V]GSOCSITE(I)=[M:EXSP]CPY : [L]CRITFCY-=',"'+[V]GSITE(I)+'"' : Endif
#  Next
#  If instr(2,[L]CRITFCY,",") : [L]CRITFCY='find([CTR]ETRFCY'+[L]CRITFCY+')<>0'
#  Else                         [L]CRITFCY='[CTR]ETRFCY='+right$([L]CRITFCY,2)
#  Endif
# Endif
#Endif
#If [L]CRITFCY="" : [L]CRITFCY="1=1" : Endif
#
#If [M:EXSP]MATDEB>"" : [L]CRITERE-='& REFNUM>="'+[M:EXSP]MATDEB+'"' : Endif
#If [M:EXSP]MATFIN>"" : [L]CRITERE-='& REFNUM<="'+[M:EXSP]MATFIN+'"' : Endif
#If [M:EXSP]ALLSRV<>2 : [L]CRITERE-='& [CTR]ETRSRV="'+[M:EXSP]SRV+'"'    : Endif
#If [M:EXSP]ALLPRF<>2 : [L]CRITERE-='& [CTR]PROPRF="'+[M:EXSP]PRF+'"'    : Endif
## 3=Accepté 2=Demande
#If [M:EXSP]STAFLG=2 : [L]CRITERE-='& EXSSTA=3'
#Else                  [L]CRITERE-='& find(EXSSTA,2,3)<>0'
#Endif
#
#If [M:EXSP]POP>""
# Link [EXS] With [POA]POA0   ~=[M:EXSP]POP;REFNUM
#&              , [CTR]CTR0(2) =REFNUM;CTRNUM
#&              , [ID]ID0      =REFNUM
#&             As [LNK]
#Else
# Link [EXS] With [ID]ID0=REFNUM
#&              , [CTR]CTR0(2) =REFNUM;CTRNUM
#&             As [LNK]
#Endif
#Link [EXS] With [TES]TES0=CODEXP As [LNK2]
#
#Filter [LNK] Order By Key CLE=DATEXS
#For [LNK]CLE Where evalue([L]CRITERE) & STA<2 & ENDDAT<[M:EXSP]DATDEB & evalue(CRITFCY)
# Call CONTROLE([F:EXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
# If [L]STAT
#  Call AVERTIR( mess(14,718,1)-"("+[F:EXS]REFNUM-format$([V]GFMD,[F:EXS]DATEXS)+")", [L]OK) From GESECRAN
#  #             Il existe des frais antérieurs non comptabilisés
#  If [L]OK<>2 : [V]GERR=1 : [L]SAI=1 : Endif
#  Break
# Endif
#Next
#Filter [LNK]
#If [V]GERR : Return : Endif
#
#[L]TMP=1
#[L]TIT=mess(8,718,1) : # Comptabilisation des notes de frais
#If [V]GSERVEUR | [M:EXSP]TRCFLG=2 : [L]TRA=1 : Endif
[L]CRITERE="1=1"
[L]CRITFCY=""
If [M:EXSP]ALLCPY<>2
 If [M:EXSP]ALLFCY<>2
  [L]CRITFCY='[HRCTR]ETRFCY="'+[M:EXSP]FCY+'"'
 Else
  For I=1 To [V]GNBSITE
   If [V]GSOCSITE(I)=[M:EXSP]CPY : [L]CRITFCY-=',"'+[V]GSITE(I)+'"' : Endif
  Next
  If instr(2,[L]CRITFCY,",") : [L]CRITFCY='find([HRCTR]ETRFCY'+[L]CRITFCY+')<>0'
  Else                         [L]CRITFCY='[HRCTR]ETRFCY='+right$([L]CRITFCY,2)
  Endif
 Endif
Endif
If [L]CRITFCY="" : [L]CRITFCY="1=1" : Endif

If [M:EXSP]MATDEB>"" : [L]CRITERE-='& REFNUM>="'+[M:EXSP]MATDEB+'"' : Endif
If [M:EXSP]MATFIN>"" : [L]CRITERE-='& REFNUM<="'+[M:EXSP]MATFIN+'"' : Endif
If [M:EXSP]ALLSRV<>2 : [L]CRITERE-='& [HRCTR]ETRSRV="'+[M:EXSP]SRV+'"'    : Endif
If [M:EXSP]ALLPRF<>2 : [L]CRITERE-='& [HRCTR]PROPRF="'+[M:EXSP]PRF+'"'    : Endif
# 3=Accepté 2=Demande
If [M:EXSP]STAFLG=2 : [L]CRITERE-='& EXSSTA=3'
Else                  [L]CRITERE-='& find(EXSSTA,2,3)<>0'
Endif

If [M:EXSP]POP>""
 Link [HREXS] With [HRPOA]POA0(3)   ~=[M:EXSP]POP;REFNUM;CTRNUM
&              , [HRCTR]CTR0(2) =REFNUM;CTRNUM
&              , [ID]ID0      =REFNUM
&             As [LNK]
Else
 Link [HREXS] With [ID]ID0=REFNUM
&              , [HRCTR]CTR0(2) =REFNUM;CTRNUM
&             As [LNK]
Endif
#DIRAS - 2017/06/07 - JIRA X3-35887 - START
Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK2]
#Link [HREXS] With [TES]TES0=CODEXP As [LNK2]
#DIRAS - 2017/06/07 - JIRA X3-35887 - END

Filter [LNK] Order By Key CLE=DATEXS
For [LNK]CLE Where evalue([L]CRITERE) & STA<2 & ENDDAT<[M:EXSP]DATDEB & evalue(CRITFCY)
 Call CONTROLE([F:HREXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
 If [L]STAT
  Call AVERTIR( mess(14,10718,1)-"("+[F:HREXS]REFNUM-format$([V]GFMD,[F:HREXS]DATEXS)+")", [L]OK) From GESECRAN
  #             Il existe des frais antérieurs non comptabilisés
  If [L]OK<>2 : [V]GERR=1 : [L]SAI=1 : Endif
  Break
 Endif
Next
Filter [LNK]
If [V]GERR : Return : Endif

[L]TMP=1
[L]TIT=mess(8,10718,1) : # Comptabilisation des notes de frais
If [V]GSERVEUR | [M:EXSP]TRCFLG=2 : [L]TRA=1 : Endif
#LIPET - 2017-05-05 - X3-35887 - END
Return

#-------------------------------------------------------------------------------
$EXEC
Gosub OUVRE_CPTAUTO From DIVPAYE
If [L]TRA
 If ![V]GSERVEUR
  #LIPET - 2017-05-05 - X3-35887 - START
  #Call OUVRE_TRACE(mess(8,718,1)) From LECFIC
  Call OUVRE_TRACE(mess(8,10718,1)) From LECFIC
  #LIPET - 2017-05-05 - X3-35887 - END
  #                Comptabilisation des notes de frais
 Else
  #LIPET - 2017-05-05 - X3-35887 - START
  #Call ECR_TRACE(mess(8,718,1),0) From GESECRAN
  Call ECR_TRACE(mess(8,10718,1),0) From GESECRAN
  #LIPET - 2017-05-05 - X3-35887 - END
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

[L]OK=-1
#LIPET - 2017-05-05 - X3-35887 - START
#For [LNK]EXS0(2) Where evalue([L]CRITERE) & STA<2  & evalue(CRITFCY) & STRDAT>=[M:EXSP]DATDEB & ENDDAT<=[M:EXSP]DATFIN
For [LNK]HREXS0(2) Where evalue([L]CRITERE) & STA<2  & evalue(CRITFCY) & STRDAT>=[M:EXSP]DATDEB & ENDDAT<=[M:EXSP]DATFIN
 #Call CONTROLE([F:EXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
  Call CONTROLE([F:HREXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
 #LIPET - 2017-05-05 - X3-35887 - END
 If [L]STAT
  #LIPET - 2017-05-05 - X3-35887 - START
  #[L]SYMBOLE="EXS"+num$([F:EXS]EXSNUM)+"\"+[F:EXS]REFNUM+"\"+[F:EXS]CTRNUM
  [L]SYMBOLE="HREXS"+num$([F:HREXS]EXSNUM)+"\"+[F:HREXS]REFNUM+"\"+[F:HREXS]CTRNUM
  #LIPET - 2017-05-05 - X3-35887 - END
  Lock =[L]SYMBOLE
  If fstat : [L]OK=0 : Elsif [L]OK=-1 : [L]OK=1 : Endif
  If fstat
   Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
   If [L]TRA
    #LIPET - 2017-05-05 - X3-35887 - START
    #Call ECR_TRACE([F:EXS]REFNUM+"\"+[V]GMESSAGE,1) From GESECRAN
    Call ECR_TRACE([F:HREXS]REFNUM+"\"+[V]GMESSAGE,1) From GESECRAN
    #LIPET - 2017-05-05 - X3-35887 - END
    [V]GMESSAGE=""
   Else
    Break
   Endif
  Endif
 Endif
Next

If [L]OK=-1
 [L]OK=0
 If [L]TRA
  Call ECR_TRACE(mess(45,107,1) ,1) From GESECRAN : # Aucune pièce à générer
 Else
  [V]GMESSAGE=mess(45,107,1) : # Aucune pièce à générer
 Endif
Endif
If ![L]OK : If ![L]TRA : [V]GERR=1 : [L]SAI=1 : Endif : Return : Endif

Call DEBTRANS From GLOCK

$TR_COMPTA
[V]GOK=1
#JASMI - 2017-09-29 - X3-58158 - START
#Trbegin [EXS]
Trbegin [HREXS]
#JASMI - 2017-09-29 - X3-58158 - END

 Gosub COMPTA
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Return : Else Goto TR_COMPTA : Endif
 Elsif ![V]GOK
  Rollback
  Return
 Endif
Commit
Return

#-------------------------------------------------------------------------------
$TERMINE
If ![V]GSERVEUR & [L]TRA
 Call FERME_TRACE From LECFIC
Endif
If ![L]OK & [L]TRA : [L]SAI=1 : Endif
Return

#-------------------------------------------------------------------------------
$SORTIE
#LIPET - 2017-05-05 - X3-35887 - START
#Call SAVDAT("exs",[M:EXSP]DATDEB,[M:EXSP]DATFIN) From SUBEXS
#Call DELOCK("EXS") From GLOCK
Call SAVDAT("HREXS",[M:EXSP]DATDEB,[M:EXSP]DATFIN) From SUBEXS
Call DELOCK("HREXS") From GLOCK
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 2017-05-05 - X3-35887 - END
Return

################################################################################
#
# Transactions
#
################################################################################

$COMPTA

#LIPET - 2017-05-05 - X3-35887 - START
#For [LNK]EXS0(1) Where evalue([L]CRITERE) & STA<2 & evalue(CRITFCY) & ENDDAT>=[M:EXSP]DATDEB & STRDAT<=[M:EXSP]DATFIN
# Call CONTROLE([F:EXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
# If [L]STAT
#  If [F:CPT]REFNUM<>[F:EXS]REFNUM
#   Read [CPT]CPT0=[F:EXS]REFNUM
#   If fstat
#    Raz [F:CPT]
#   Elsif [F:CPT]BPR>"" & clalev([F:BPR])
#    Read [BPR]BPR0=[F:CPT]BPR
#    If fstat : Raz [F:BPR] : Endif
#   Endif
#   [L]WBPR = [F:CPT]BPR
#   Filter [F:CPR] Where [F:CPR]REFNUM = [F:CTR]REFNUM & [F:CPR]CTRNUM = [F:CTR]CTRNUM & [F:CPR]CTRDAT = [F:CTR]CTRDAT
#   Read [F:CPR]CPR0 Last
#   If fstat <= 2 & [F:CPR]BPR <> ""
#        [L]WBPR = [F:CPR]BPR
#        If [F:CPR]BPR <> "" & clalev([F:BPR])
#            Read [F:BPR]BPR0 = [F:CPR]BPR
#            If fstat : Read [F:BPR] : Endif
#        Endif
#   Endif
#  Endif
#
#  For [LNK]EXS0
#   [F:EXS]UID=adxuid(2)
#   [F:EXS]BPR=[L]WBPR
#   If clalev([F:BPR]) : [F:EXS]VCRTYP=[F:BPR]BPRGTETYP : Endif
#   Rewrite [EXS] Curr
#   If fstat=1
#    Read [EXS] Curr
#    [V]GOK  =-1
#    [V]GLOCK="$EXPENSES"-[F:EXS]REFNUM-num$([F:EXS]EXSNUM)-num$([F:EXS]LIN)
#    Break 2
#   Elsif fstat
#    Read [EXS] Curr
#    [V]GOK=0
#    Call FSTA("EXS") From GLOCK
#    Break 2
#   Endif
#  Next
# Endif
#Next
For [LNK]HREXS0(1) Where evalue([L]CRITERE) & STA<2 & evalue(CRITFCY) & ENDDAT>=[M:EXSP]DATDEB & STRDAT<=[M:EXSP]DATFIN
 Call CONTROLE([F:HREXS]REFNUM,datesyst,"",[M:EXSP]CRI,[L]STAT,1) From DIVPAYE
 If [L]STAT
  If [F:CPT]REFNUM<>[F:HREXS]REFNUM
   Read [CPT]CPT0=[F:HREXS]REFNUM
   If fstat
    Raz [F:CPT]
   Elsif [F:CPT]BPR>"" & clalev([F:BPR])
    Read [BPR]BPR0=[F:CPT]BPR
    If fstat : Raz [F:BPR] : Endif
   Endif
   [L]WBPR = [F:CPT]BPR
   Filter [F:CPR] Where [F:CPR]REFNUM = [F:HRCTR]REFNUM & [F:CPR]CTRNUM = [F:HRCTR]CTRNUM & [F:CPR]CTRDAT = [F:HRCTR]CTRDAT
   Read [F:CPR]CPR0 Last
   If fstat <= 2 & [F:CPR]BPR <> ""
        [L]WBPR = [F:CPR]BPR
        If [F:CPR]BPR <> "" & clalev([F:BPR])
            Read [F:BPR]BPR0 = [F:CPR]BPR
            If fstat : Read [F:BPR] : Endif
        Endif
   Endif
  Endif

  For [LNK]HREXS0
   [F:HREXS]UID=adxuid(2)
   [F:HREXS]BPR=[L]WBPR
   If clalev([F:BPR]) : [F:HREXS]VCRTYP=[F:BPR]BPRGTETYP : Endif
   Rewrite [HREXS] Curr
   If fstat=1
    Read [HREXS] Curr
    [V]GOK  =-1
    [V]GLOCK="$HREXPENSES"-[F:HREXS]REFNUM-num$([F:HREXS]EXSNUM)-num$([F:HREXS]LIN)
    Break 2
   Elsif fstat
    Read [HREXS] Curr
    [V]GOK=0
    Call FSTA("HREXS") From GLOCK
    Break 2
   Endif
  Next
 Endif
Next
#LIPET - 2017-05-05 - X3-35887 - END
If [V]GOK<1 : Return : Endif

#LIPET - 2017-05-05 - X3-35887 - START
#Repeat
# Filter [EXS] Where UID=adxuid(2)
# Read [EXS]EXS1(0) First
# Filter [EXS]
# If fstat : Break : Endif
#
# [L]IDENT(1)=num$(adxuid(2))
# [L]IDENT(2)=[F:EXS]CUR
# [L]IDENT(3)=[F:EXS]FCY
