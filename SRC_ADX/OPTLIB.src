#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
# Routines diverses pour extraction optimisation
###########################################################################
# Subprog OPTPAR                                                          #
# Subprog OPTWST                                                          #
# Subprog OPTMFG                                                          #
###########################################################################
# Export fichiers "paramètres" via masque buffer OPTK
###########################################################################
Subprog OPTPAR(LFONC, LOPT1)
Value     Char    LFONC
Variable  Integer LOPT1

Local Date    WEXTDAT
Local Integer WDSP
Local Char    OPTPAR(200)
Local Char    OPTTUN(200)
Local Integer SAVIUM : SAVIUM = adxium

# 99508 mm 11.2014 - License management V7
#Gosub TRT_DEB
If GBROWS = 0 & GADONIX = 2
  LOPT1 = 1
Else
  LOPT1 = func GET_ACTGANT()
Endif
If !LOPT1
    Call ERREUR(mess(329,139,1)) From GESECRAN
    End
Endif

# génération fichier paramètres optimisation
OPTPAR = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilpar",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

WDSP = 0
If [M:OPTK]DSPLEV1 = 2 : WDSP += 1 : Endif
If [M:OPTK]DSPLEV2 = 2 : WDSP += 2 : Endif
If [M:OPTK]DSPLEV3 = 2 : WDSP += 4 : Endif


# Ouverture du fichier OPTPAR en écriture
Openo OPTPAR,0

# écriture le l'enregistrement paramètres
#
Wrseq [M:OPTK]MFGFCY;[M:OPTK]TRTDAT;[M:OPTK]TRTMOD;[M:OPTK]WOMAR;[M:OPTK]FACTOR(0);[M:OPTK]FACTOR(1);[M:OPTK]FACTOR(2);
&     [M:OPTK]FACTOR(3);[M:OPTK]FACTOR(4);[M:OPTK]FACTOR(5);WDSP;[M:OPTK]FRHOR;[M:OPTK]DSPHOR;[M:OPTK]STRTEAM1;
&     [M:OPTK]STRTEAM2;[M:OPTK]CALSTRDAT;[M:OPTK]CALDAYNBR;GDEFDIH;[M:OPTK]LAN;2;WEXTDAT
#107226 mm 03.2015 - LOPT1 set to 2

# fermeture de l'enregistrement paramètres
Openo

# génération ficher pour les tunnels
OPTTUN = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"iltun",0)

adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)
adxium = GUTF8

# Ouverture du fichier OPTTUN en écriture
Openo OPTTUN,0

# écriture le l'enregistrement paramètres
Wrseq "MFG";"MWS";"TWD";"ROU";"ITM";"TUV";"TWD"

# fermeture de l'enregistrement paramètres
Openo

adxium = SAVIUM

End

#########################################################################
# Export fichiers postes, remplaçants postes et variations de capacité
Subprog OPTWST_OLD
Local Integer WLIMCAP
Local Date    WEXTDAT
Local Char    OPTWST(200)
Local Char    OPTRPLWST(200)
Local Char    OPTCAPVAR(200)
Local Integer I,J
Local Integer WRET      : WRET = 0
Local Integer WNBRPW    : WNBRPW = 0
Local Integer WNBCPV    : WNBCPV = 0
Local Integer WFLGMAJ
Local Char    WCHAIN(50), WSPECHAR
Local Integer WWSTDSP, WWCRDSP
Local Integer SAVIUM : SAVIUM = adxium
Local Char    WWST

# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
Local Char    XSBB
Local Char    XSBBWST(70), XSBBWSTB(70)
Local Char    XWST
Local Integer XIND, XINDB
Local Integer XWSTNBR
Local Integer K,L,M

OPTWST    = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilwst",0)
OPTRPLWST = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilrpw",0)
OPTCAPVAR = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilcpv",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:RPW])  = 0 : Local File RPLWST     [RPW]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:MFO2]) = 0 : Local File MFGOPE     [MFO2] : Endif        # distinction

Openo OPTWST,0     Using [OPTW]
Openo OPTRPLWST,0  Using [OPTR]
Openo OPTCAPVAR,0  Using [OPTC]

# parcours l'ensemble des postes du site
Filter [F:MWS] Where WCRFCY = [M:OPTK]MFGFCY
For [F:MWS]

    # si poste de sous-traitance : force capa à 1 H/J
    If [F:MWS]WSTTYP = 3 : WLIMCAP = 1 : Else : WLIMCAP = [F:MWS]CONSTRAINT : Endif
    If !find(WLIMCAP, 1, 2) : WLIMCAP = 1 : Endif

    WWST = [F:MWS]WST
    Call CHANGE_CHAR(WWST)

    Call LECTEXTRA(WCHAIN,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    [F:MWS]WSTDES = WCHAIN
    Call CHANGE_CHAR([F:MWS]WSTDES)

    Call LECTEXTRA(WCHAIN,"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    [F:MWS]WSTSHO = WCHAIN
    Call CHANGE_CHAR([F:MWS]WSTSHO)

    If [F:TWC]WCR <> [F:MWS]WCR
        Read [TWC]TWC0=[F:MWS]WCR
        If fstat : WWCRDSP = 1 : Else : WWCRDSP = [F:TWC]DSPLEV : Endif
    Endif
    WWSTDSP = [F:MWS]DSPLEV

    # distinction des exemplaires
    If [F:MWS]SBBFLG = 1
        # écriture de l'enregistrement poste
        Wrseq WWST;[F:MWS]WSTDES;[F:MWS]WSTSHO;WWSTDSP;[F:MWS]WCR;WWCRDSP;[F:MWS]GRPFLG;[F:MWS]GRPHOR;[F:MWS]WSTTYP;[F:MWS]WSTNBR;[F:MWS]TWD;
&             WLIMCAP;[F:MWS]RPLAUTO;WEXTDAT;WFLGMAJ Using [OPTW]
        # lecture et écriture remplaçants
#        Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY
#        If fstat : Raz [RPW] : Endif
#
#        For I = 0 To 24
#            If [F:RPW]RPLWST(I) <> ""
#                Wrseq WWST;I+1;[F:RPW]RPLWST(I);[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
#                WNBRPW += 1
#            Endif
#        Next I
#        Openo
    Else
        Gosub SBB_EXTRACT
        Gosub SBB_GEN
    Endif
    # Bug 73734 gbe 17/02/12 même si on a une distinction de poste il faut extraire les postes de remplacement
    # lecture et écriture remplaçants
    Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY
    If fstat : Raz [RPW] : Endif

    For I = 0 To 24
        If [F:RPW]RPLWST(I) <> ""
            Wrseq WWST;I+1;[F:RPW]RPLWST(I);[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
            WNBRPW += 1
        Endif
    Next I
    Openo

    # lecture et écriture variations
    Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
    If fstat : Raz [CPV] : Endif

    For I = 0 To 24
        If [F:CPV]STRDAT(I) <> [0/0/0]
            Wrseq WWST;I+1;[F:CPV]STRDAT(I);[F:CPV]ENDDAT(I);[F:CPV]CODVAR(I);[F:CPV]TWD(I);[F:CPV]WSTNBR(I);
&                 WEXTDAT;WFLGMAJ  Using [OPTC]
            WNBCPV += 1
        Endif
    Next I
    Openo
Next
If WNBRPW = 0 : Wrseq "No record"  Using [OPTR]: Endif
If WNBCPV = 0 : Wrseq "No record"  Using [OPTC]: Endif

Openo Using [OPTW]
Openo Using [OPTR]
Openo Using [OPTC]
Filter [F:MWS]
adxium = SAVIUM

# la suite des données de capacité
Call OPTTWD From OPTLIB
Call OPTDIH From OPTLIB
Call OPTTUV From OPTLIB
Call OPTADI From OPTLIB

End
Subprog OPTWST
Local Integer WLIMCAP
Local Date    WEXTDAT
Local Char    OPTWST(200)
Local Char    OPTRPLWST(200)
Local Char    OPTCAPVAR(200)
Local Integer I,J
Local Integer WRET      : WRET = 0
Local Integer WNBRPW    : WNBRPW = 0
Local Integer WNBCPV    : WNBCPV = 0
Local Integer WFLGMAJ
Local Char    WCHAIN(50), WSPECHAR
Local Integer WWSTDSP, WWCRDSP
Local Integer SAVIUM : SAVIUM = adxium
Local Char    WWST

# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
# Bug 73734 gbe 28/02/12
Local Integer NBSBBR : NBSBBR = 0
Local Char    XSBBTR(15)(100)
Local Char    SOURCEWST(70)
Local Char    CIBLEWST(70)
Local Integer N,N2

Local Char    XSBB
Local Char    XSBBWST(70), XSBBWSTB(70)
Local Char    XWST
Local Integer XIND, XINDB
Local Integer XWSTNBR
Local Integer K,L,M
Local Char TEMPOGBE

OPTWST    = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilwst",0)
OPTRPLWST = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilrpw",0)
OPTCAPVAR = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilcpv",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
# Bug 73734 gbe 28/02/12
If clalev([F:MWS2])  = 0 : Local File WORKSTATIO [MWS2]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:RPW])  = 0 : Local File RPLWST     [RPW]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:MFO2]) = 0 : Local File MFGOPE     [MFO2] : Endif        # distinction

Openo OPTWST,0     Using [OPTW]
Openo OPTRPLWST,0  Using [OPTR]
Openo OPTCAPVAR,0  Using [OPTC]

# parcours l'ensemble des postes du site
Filter [F:MWS] Where WCRFCY = [M:OPTK]MFGFCY
For [F:MWS]

    # si poste de sous-traitance : force capa à 1 H/J
    If [F:MWS]WSTTYP = 3 : WLIMCAP = 1 : Else : WLIMCAP = [F:MWS]CONSTRAINT : Endif
    If !find(WLIMCAP, 1, 2) : WLIMCAP = 1 : Endif

    WWST = [F:MWS]WST
    Call CHANGE_CHAR(WWST)

    Call LECTEXTRA(WCHAIN,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    [F:MWS]WSTDES = WCHAIN
    Call CHANGE_CHAR([F:MWS]WSTDES)

    Call LECTEXTRA(WCHAIN,"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    [F:MWS]WSTSHO = WCHAIN
    Call CHANGE_CHAR([F:MWS]WSTSHO)

    If [F:TWC]WCR <> [F:MWS]WCR
        Read [TWC]TWC0=[F:MWS]WCR
        If fstat : WWCRDSP = 1 : Else : WWCRDSP = [F:TWC]DSPLEV : Endif
    Endif
    WWSTDSP = [F:MWS]DSPLEV

    # Bug 73734 gbe 28/02/12 Re écriture de l'algo pour traiter correctement les distinctions
    Raz [CPV]
    Raz [RPW]
    # distinction des exemplaires
    If [F:MWS]SBBFLG = 1
      # écriture de l'enregistrement poste
        Wrseq WWST;[F:MWS]WSTDES;[F:MWS]WSTSHO;WWSTDSP;[F:MWS]WCR;WWCRDSP;[F:MWS]GRPFLG;[F:MWS]GRPHOR;[F:MWS]WSTTYP;[F:MWS]WSTNBR;[F:MWS]TWD;
&             WLIMCAP;[F:MWS]RPLAUTO;WEXTDAT;WFLGMAJ Using [OPTW]
        # lecture et écriture remplaçants
      Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY
      If fstat : Raz [RPW] : Endif
      For I = 0 To 24
        If [F:RPW]RPLWST(I) <> ""
          TEMPOGBE = [F:RPW]RPLWST(I)
          Read [F:MWS2]WST0=[F:RPW]RPLWST(I);[F:MWS]WCRFCY
          If fstat : Raz [F:MWS2] : Endif

          # Si le poste de remplacement gère des distinctions
          If [F:MWS2]SBBFLG = 2
            Gosub SBB_EXTRACTR
            For J =0 To NBSBBR-1
              XIND = J
              XSBB = XSBBTR(J)
              XWST = [F:MWS2]WST
              Gosub SBB_NAME
              Wrseq WWST;I+1;XSBBWST;[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
              WNBRPW += 1
            Next J
          Else
              Wrseq WWST;I+1;[F:RPW]RPLWST(I);[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
              WNBRPW += 1
          Endif
        Endif
      Next I # Fin boucle poste de remplacement
      # lecture et écriture variations
      Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
      If fstat : Raz [CPV] : Endif
      For I = 0 To 24
          If [F:CPV]STRDAT(I) <> [0/0/0]
              Wrseq WWST;I+1;[F:CPV]STRDAT(I);[F:CPV]ENDDAT(I);[F:CPV]CODVAR(I);[F:CPV]TWD(I);[F:CPV]WSTNBR(I);
&                 WEXTDAT;WFLGMAJ  Using [OPTC]
              WNBCPV += 1
          Endif
    Next I
    Else
#        Gosub SBB_EXTRACT
#        Gosub SBB_GEN
        # Extraction des critères de distinction
        Gosub SBB_EXTRACT
        For N=0 To NBSBB-1
          XIND = N
          XSBB = XSBBT(XIND)
          XWST = WWST
          Gosub SBB_NAME # on génère le nom du poste en tenant compte des critères
          SOURCEWST = XSBBWST # On a le poste source
          # Ecriture du poste
          Wrseq SOURCEWST;[F:MWS]WSTDES;[F:MWS]WSTSHO;WWSTDSP;[F:MWS]WCR;WWCRDSP;[F:MWS]GRPFLG;[F:MWS]GRPHOR;[F:MWS]WSTTYP;[F:MWS]WSTNBR;[F:MWS]TWD;
&             WLIMCAP;[F:MWS]RPLAUTO;WEXTDAT;WFLGMAJ Using [OPTW]
          If N = 0
            ORIGINEWST = SOURCEWST # On sauvegarde le premier poste
            # Lecture des variations de capa
            Read [CPV]CPV0=ORIGINEWST;[F:MWS]WCRFCY
            If fstat : Raz [CPV] : Endif
          Endif
          For I = 0 To 24
              If [F:CPV]STRDAT(I) <> [0/0/0]
                  Wrseq SOURCEWST;I+1;[F:CPV]STRDAT(I);[F:CPV]ENDDAT(I);[F:CPV]CODVAR(I);[F:CPV]TWD(I);[F:CPV]WSTNBR(I);
&                 WEXTDAT;WFLGMAJ  Using [OPTC]
                  WNBCPV += 1
              Endif
          Next I # Fin boucle sur les variations de capa
          M = 1
          For N2=0 To NBSBB-1
            If N <> N2
              XIND = N2
              XSBB = XSBBT(XIND)
              XWST = WWST
              Gosub SBB_NAME
              CIBLEWST = XSBBWST # On à le poste cible
              Wrseq SOURCEWST;I+1;CIBLEWST;I+1;WEXTDAT;WFLGMAJ  Using [OPTR]
              WNBRPW += 1
            Endif
          Next N2 # Fin boucle secondaire sur les distinctions d'exemplaires
          # On traite les remplaçants
          If N = 0
            Read [RPW]RPW0=ORIGINEWST;[F:MWS]WCRFCY
            If fstat : Raz [RPW] : Endif
          Endif
          For I = 0 To 24
            If [F:RPW]RPLWST(I) <> ""
              Read [F:MWS2]WST0=[F:RPW]RPLWST;[F:MWS]WCRFCY
              If fstat : Raz [F:MWS2] : Endif

              # Si le poste de remplacement gère des distinctions
              If [F:MWS2]SBBFLG = 2
                Gosub SBB_EXTRACTR
                For J =0 To NBSBBR-1
                  XIND = J
                  XSBB = XSBBTR(J)
                  XWST = [F:MWS2]WST
                  Gosub SBB_NAME
                  Wrseq SOURCEWST;I+1;XSBBWST;[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
                  WNBRPW += 1
                Next J
              Else
                  Wrseq SOURCEWST;I+1;[F:MWS2]WST;[F:RPW]PIO(I);WEXTDAT;WFLGMAJ  Using [OPTR]
                  WNBRPW += 1
              Endif
            Endif
          Next I # Fin boucle poste de remplacement
        Next N # Fin boucle sur les distinctions d'exemplaires
    Endif
Next
If WNBRPW = 0 : Wrseq "No record"  Using [OPTR]: Endif
If WNBCPV = 0 : Wrseq "No record"  Using [OPTC]: Endif

Openo Using [OPTW]
Openo Using [OPTR]
Openo Using [OPTC]
Filter [F:MWS]
adxium = SAVIUM

# la suite des données de capacité
Call OPTTWD From OPTLIB
Call OPTDIH From OPTLIB
Call OPTTUV From OPTLIB
Call OPTADI From OPTLIB

End

#########################################################################
# distinction des exemplaires
$SBB_EXTRACT
# recherche des critères de distinction sur le poste
Filter [MFO2] Where MFGFCY = [M:OPTK]MFGFCY &
&                   EXTWST = [F:MWS]WST     &
&                   SCHSBB <> ""
&               Order By Key MFO2(3)

NBSBB  = 0
XSBBT(NBSBB) = ""
NBSBB += 1
For [MFO2]
    If NBSBB >= [F:MWS]WSTNBR : Break : Endif
    XSBBT(NBSBB) = [F:MFO2]SCHSBB
    NBSBB       += 1
Next

Filter [MFO2]
Return

#########################################################################
# distinction des exemplaires poste de remplacement
$SBB_EXTRACTR
# recherche des critères de distinction sur le poste
Filter [MFO2] Where MFGFCY = [M:OPTK]MFGFCY &
&                   EXTWST = [F:MWS2]WST    &
&                   SCHSBB <> ""
&               Order By Key MFO2(3)

NBSBBR  = 0
XSBBTR(NBSBBR) = "" : # GH 05/06/2014 bug 99910 # XSBBTR(NBSBB)
NBSBBR += 1
For [MFO2]
    If NBSBBR >= [F:MWS2]WSTNBR : Break : Endif
    XSBBTR(NBSBBR) = [F:MFO2]SCHSBB
    NBSBBR       += 1
Next

Filter [MFO2]
Return

#########################################################################
# distinction des exemplaires
$SBB_GEN
If NBSBB = 0 : Return : Endif

# pseudo code sous-poste 0
XWST = [F:MWS]WST
XIND = 0
Gosub SBB_NAME

# écriture sous-poste 0
If NBSBB >= [F:MWS]WSTNBR
    XWSTNBR = 1
Else
    XWSTNBR = [F:MWS]WSTNBR - NBSBB + 1
Endif
Gosub WRXSBB

For K = 1 To NBSBB - 1
    # constitution pseudo code sous-poste
    XIND = K
    XSBB = XSBBT(XIND)
    Gosub SBB_NAME

    # écriture
    XWSTNBR = 1
    Gosub WRXSBB
Next K

Return

#########################################################################
# distinction des exemplaires
$SBB_NAME
If XIND = 0 : XSBBWST = XWST : Return : Endif

## GH 05/06/2014 bug 99910
#XSBBWST = format$("Kb:"+num$(GLONWST+1)+"X",XWST)+"-"-format$("N0:2",XIND)-format$("Kb:15X",XSBB)
XSBBWST = XSBB
Call CHANGE_CHAR(XSBBWST)
XSBBWST = format$("Kb:"+num$(GLONWST+1)+"X",XWST)+"-"-format$("N0:2",XIND)-format$("Kb:15X",XSBBWST)
##
Return

#########################################################################
# distinction des exemplaires
$WRXSBB
Wrseq XSBBWST;[F:MWS]WSTDES;[F:MWS]WSTSHO;WWSTDSP;[F:MWS]WCR;WWCRDSP;[F:MWS]GRPFLG;[F:MWS]GRPHOR;[F:MWS]WSTTYP;XWSTNBR;[F:MWS]TWD;
&     WLIMCAP;[F:MWS]RPLAUTO;WEXTDAT;WFLGMAJ Using [OPTW]

M = 0
For L = 0 To NBSBB - 1
    If L <> XIND
        XINDB = XIND
        XIND = L
        XSBB = XSBBT(XIND)
        XSBBWSTB = XSBBWST
        Gosub SBB_NAME
        Wrseq XSBBWSTB;M+1;XSBBWST;M+1;WEXTDAT;WFLGMAJ  Using [OPTR]
        WNBRPW += 1
        M += 1
        XSBBWST = XSBBWSTB
        XIND = XINDB
    Endif
Next L
Return

#########################################################################
# Export schémas hebdomadaires
Subprog OPTTWD
Local Date    WEXTDAT
Local Char    OPTTWD(200)
Local Integer I,J
Local Integer WRET      : WRET = 0
Local Integer WFLGMAJ
Local Char    WCHAIN, WSPECHAR
Local Integer SAVIUM : SAVIUM = adxium

OPTTWD = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"iltwd",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif

Openo OPTTWD,0

For [TWD]TWD0
    Call LECTEXTRA(WCHAIN,"TABWEEDIA","TWDDESAXX",[F:TWD]TWD,"") From ATEXTRA
    [F:TWD]TWDDES = WCHAIN
    Call CHANGE_CHAR([F:TWD]TWDDES)

    # écriture de l'enregistrement poste
    Wrseq [F:TWD]TWD;[F:TWD]TWDDES;[F:TWD]DAYCAP(0);[F:TWD]DAYCAP(1);[F:TWD]DAYCAP(2);[F:TWD]DAYCAP(3);[F:TWD]DAYCAP(4);
&         [F:TWD]DAYCAP(5);[F:TWD]DAYCAP(6);[F:TWD]DIAHOU(0);[F:TWD]DIAHOU(1);[F:TWD]DIAHOU(2);[F:TWD]DIAHOU(3);[F:TWD]DIAHOU(4);
&         [F:TWD]DIAHOU(5);[F:TWD]DIAHOU(6);WEXTDAT;WFLGMAJ
Next
Openo
adxium = SAVIUM
End

#########################################################################
# Export schémas horaires
Subprog OPTDIH
Local Date    WEXTDAT
Local Char    OPTDIH(200)
Local Integer I,J
Local Integer WRET      : WRET = 0
Local Integer WFLGMAJ
Local Char    WCHAIN, WSPECHAR
Local Integer SAVIUM : SAVIUM = adxium
Local Decimal WSTRHOU(5), WENDHOU(5)

OPTDIH = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ildih",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:DIH])  = 0 : Local File DIAHOU  [DIH]  : Endif

Openo OPTDIH,0

For [DIH]DIH0
    Call LECTEXTRA(WCHAIN,"DIAHOU","DIANAMAXX",[F:DIH]NUM,"") From ATEXTRA
    [F:DIH]DIANAM = WCHAIN
    Call CHANGE_CHAR([F:DIH]DIANAM)

    Raz WSTRHOU, WENDHOU
    For I = 0 To 4
        If [F:DIH]STRHOU(I) = "" : Break : Endif
        Call CONVHOU([F:DIH]STRHOU(I), WSTRHOU(I)) From JALLIBB
        Call CONVHOU([F:DIH]ENDHOU(I), WENDHOU(I)) From JALLIBB
    Next I

    # écriture de l'enregistrement poste
    Wrseq [F:DIH]NUM;[F:DIH]DIANAM;WSTRHOU(0);WENDHOU(0);WSTRHOU(1);WENDHOU(1);WSTRHOU(2);WENDHOU(2);
&         WSTRHOU(3);WENDHOU(3);WSTRHOU(4);WENDHOU(4);I;WEXTDAT;WFLGMAJ
Next
Openo
adxium = SAVIUM
End

#########################################################################
# Export indisponibilités
Subprog OPTTUV
Local Date    WEXTDAT
Local Char    OPTTUV(200)
Local Integer L,J
Local Integer WRET      : WRET = 0
Local Integer WFLGMAJ
Local Char    WCHAIN, WSPECHAR
Local Integer SAVIUM : SAVIUM = adxium

OPTTUV = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"iltuv",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:TUV])  = 0 : Local File TABUNAVAIL  [TUV]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif

Call LECTURE ("FCY", [M:OPTK]MFGFCY, "") From CONTOBJ
# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD
If fstat : Raz [TUV] : Endif

Openo OPTTUV,0
If [F:TUV]UVYNBR  = 0
    Wrseq "No record"
    Goto END_TUV
Endif

For L = 0 To [F:TUV]UVYNBR - 1
    Call LECTEXTRA(WCHAIN,"TABUNAVAIL","DESAXX",[F:TUV]UVYCOD,"") From ATEXTRA
    [F:TUV]UVYNAM(L) = WCHAIN
    Call CHANGE_CHAR([F:TUV]UVYNAM(L))

    Wrseq [F:TUV]UVYCOD;L+1;[F:TUV]UVYSTRDAT(L);[F:TUV]UVYENDDAT(L);[F:TUV]UVYNAM(L);WEXTDAT;WFLGMAJ
Next L
Openo

$END_TUV
adxium = SAVIUM
End

#########################################################################
# Export table diverse 801 (motif variation)
Subprog OPTADI
Local Date    WEXTDAT
Local Char    OPTADI(200)
Local Integer I,J
Local Integer WRET      : WRET = 0
Local Integer WFLGMAJ
Local Char    WCHAIN, WSPECHAR
Local Char    WSHODES

Local Integer SAVIUM : SAVIUM = adxium

OPTADI = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"iladi",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)

WEXTDAT = date$

If clalev([F:ADI])  = 0 : Local File ATABDIV  [ADI]  : Endif

Openo OPTADI,0
For [ADI] Where NUMTAB = 801
    Call LECTEXTRA(WSHODES,"ATABDIV", "SHODES", num$([F:ADI]NUMTAB), [F:ADI]CODE) From ATEXTRA
    Call CHANGE_CHAR(WSHODES)

    Wrseq [F:ADI]NUMTAB;[F:ADI]CODE;WSHODES;WEXTDAT;WFLGMAJ
Next
Openo

$END_ADI
adxium = SAVIUM
End

#########################################################################
# Export fichiers "en-tête OF", "opérations", "liens de succession"
Subprog OPTMFG
Local Date    WEXTDAT
Local Char    OPTMFG(200)
Local Char    OPTOPE(200)
Local Char    OPTLNK(200)
Local Date    WSTRDAT
Local Date    WENDDAT
Local Date    WOBJDAT
Local Date    WSTRCAL
Local Date    WENDCAL
Local Integer WRET      : WRET = 0
Local Integer WOK       : WOK = 0
Local Integer WSCDMOD
Local Integer WSCDFLG
Local Decimal WSCDLTI, WRATIO
Local Char    WWCR
Local Char    WTAB
Local Char    WCLE
Local Char    WTEX(80)
Local Char    WMFGFCY(GLONFCY)
Local Char    WSTU(GLONUOM)
Local Decimal WRMNEXTQTY
Local Integer WMFGPIO
Local Date    WSTROPD
Local Decimal WSTRFRD
Local Date    WENDOPD
Local Decimal WENDFRD
Local Decimal WOPDUR
Local Decimal WOPTIM
Local Decimal WCOELAB
Local Integer WSCDCODP
Local Decimal WDAYCAP
Local Decimal WDAYFR
Local Char    WFRCHOU(5)
Local Date    WFRCENDD
Local Decimal WFRCENDF
Local Decimal WFRCSTRH
Local Decimal WPRPTIMA
Local Decimal WSETTIMA
Local Decimal WSETTIMSTDA
Local Decimal WEXTTIMA
Local Decimal WOPTTIMA
Local Decimal WPSPTIMA
Local Decimal WFRCSTRA
Local Decimal WOPESTRA
Local Decimal WINFSTRA
Local Decimal WINFENDA
Local Decimal WOPEENDA
# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
Local Char    XSBB
Local Char    XSBBWST
Local Char    XWST
Local Integer XIND
Local Integer XWSTNBR
Local Integer K,L
#
Local Integer I,J,IS,JS,IP,JP,IPREC
Local Integer NBOP,NBOPR,NBOPFC,DOPNT,NBOPNT,WPREC,WSUIV,WSPLSUIV
Local Decimal WNUM,WWSTEFF
#
Local Integer NBOPMX   : NBOPMX=GMFOMAX   : # dimension tables op
Local Integer NBLKMX   : NBLKMX=GMFOMAX   : # dimension tables liens
Local Integer NBJCAL   : NBJCAL=2000      : # dimension tables calendrier
#
Local Integer  WOPENUM (NBOPMX)           : # numéro oper    # FQ 70035 avant Shortint
Local Shortint WOPESPLNUM (NBOPMX)        : # fract. oper
Local Char    WWST    (30) (NBOPMX)       : # poste
Local Char    WLAB    (GLONWST) (NBOPMX)  : # main d'oeuvre
Local Char    WSCO    (GLONWST) (NBOPMX)  : # sous-traitance
Local Decimal WSETLABC (NBOPMX)           : # coeff réglage MO
Local Decimal WOPELABC (NBOPMX)           : # coeff oper MO
Local Integer WOPESTA (NBOPMX)            : # état opération
Local Date    WOPESTR (NBOPMX)            : # date début
Local Date    WOPEEND (NBOPMX)            : # date fin
Local Integer WWSTN (NBOPMX)              : # nb de postes
Local Integer WLABN (NBOPMX)              : # nb de personnes
Local Decimal WPRPTIM (NBOPMX)            : # temps préparation
Local Decimal WSETTIM (NBOPMX)            : # temps réglage
Local Decimal WSETTIMSTD (NBOPMX)         : # temps réglage
Local Decimal WOPETIM (NBOPMX)            : # temps opératoire
Local Decimal WOPTTIM (NBOPMX)            : # temps fabrication total
Local Decimal WPSPTIM (NBOPMX)            : # temps post oper
Local Decimal WSCOLTI (NBOPMX)            : # délai sous-traitance en jours
Local Decimal WQTY (NBOPMX)               : # quantité restante
Local Date    WFRCSTRD (NBOPMX)           : # date début forcé
Local Decimal WFRCSTRF (NBOPMX)           : # Fraction de jour début forcé
Local Integer WWSTTYP (NBOPMX)            : # code sous-traitance
Local Char    WWIPNUM (GLONVCR)(NBOPMX)   : # n° encours sous-traitance
Local Char    WSCOITMREF(GLONITM)(NBOPMX) : # article sous-traitance
#
Local Integer WSCDCOD (NBOPMX)            : # code jalonnement
Local Integer WNEXOPEN (NBOPMX)           : # no op suivante
Local Integer WNEXSPLN (NBOPMX)           : # fract. op suivante (créé dans PG)
Local Integer WOPERG (NBOPMX)             : # rang op
Local Integer WOPETRT (NBOPMX)            : # ope traitée en classement
Local Decimal WSCDPCT (NBOPMX)            : # % chev
#
Local Date    WINFSTRD (NBOPMX)           : # date début à capa inf
Local Decimal WINFSTRF (NBOPMX)           : # fraction de jour début
Local Date    WINFENDD (NBOPMX)           : # date fin à capa inf
Local Decimal WINFENDF (NBOPMX)           : # fraction de jour fin
Local Date    WOPESTRD (NBOPMX)           : # date début préparation
Local Decimal WOPESTRF (NBOPMX)           : # fraction de jour début prep
Local Date    WOPEENDD (NBOPMX)           : # date fin opération
Local Decimal WOPEENDF (NBOPMX)           : # fraction de jour fin oper
Local Char    WSCHGRP(15)(NBOPMX)         : # code regroupement
Local Char    WSCHSBB(15)(NBOPMX)         : # code distinction

Local Decimal WRMNQTY(NBOPMX)             : # quantité restante opération
#
Local Integer  WCONOPENUM (NBLKMX)        : # numéro oper conditionnante # FQ 70035 avant Shortint
Local Shortint WCONOPSNUM (NBLKMX)        : # fract. oper conditionnante
Local Integer  WLNKOPENUM (NBLKMX)        : # numéro oper conditionnée   # FQ 70035 avant Shortint
Local Shortint WLNKOPSNUM (NBLKMX)        : # fract. oper conditionnée
Local Integer WLNKTYP (NBLKMX)            : # type de lien
Local Decimal WLNKTIM (NBLKMX)            : # temps du lien
Local Decimal WLNKSCDCOD (NBLKMX)         : # code jalonnement

#
Local Decimal WCAP (NBJCAL)               : # capacité journalière poste
Local Integer WNBR(NBJCAL)                : # nombre d'exemplaire

Local Integer WFLGMAJ                     : # flag MAJ = 0
Local Integer OPTIM                       : # flag OPT
Local Integer WMFGMST                     : # opération de production
Local Char    WMESS(150)
Local Char    WCHAIN, WSPECHAR
Local Integer SAVIUM : SAVIUM = adxium

[M:OPTK]CODRET = 0
# initialise les fichiers de sortie
OPTMFG = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilmfg",0)
OPTOPE = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilope",0)
OPTLNK = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"illnk",0)

GSCHFOCUS = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilfocus",0)
GSCHINV   = func OPTLIB.FILNAM([M:OPTK]MFGFCY,"ilinv",0)

adxium = GUTF8
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(10)
WEXTDAT = date$
# test type de calcul
GOK=1
$TR_OPT
Goto TEST_STA

#########################################################################
# test statut OF
#     si OF ferme ou planifié : on charge l'OF à partir de MFGHEAD et
#                               SCHEDULING+MFGOPE
#     si OF suggéré : on charge l'OF à partir de SCHEDULING+OPERATIONS
#     si OF clos : message d'erreur puis retour
$TEST_STA
Case [M:OPTK]MFGSTA
  When 1,2 : Goto LOAD_OFFP
  When 3   : Goto LOAD_OFS
  When 4   : Goto OF_CLOS
Endcase

#########################################################################
# chargement OF ferme ou planifié
$LOAD_OFFP
#   ouverture des fichiers
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING [SCH]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:OPS2]) = 0 : Local File OPERATIONS [OPS2] : Endif
If clalev([F:MFO2]) = 0 : Local File MFGOPE     [MFO2] : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif

If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif

#   lecture en-tête
Read [MFG]MFG0=[M:OPTK]MFGNUM
If fstat : WTAB="MFG" : WCLE=[M:OPTK]MFGNUM : Goto AB_OPT : Endif
#
WSTRDAT    = [F:MFG]STRDAT
WENDDAT    = [F:MFG]ENDDAT
If [F:MFG]OBJDAT <> [0/0/0]
    WOBJDAT    = [F:MFG]OBJDAT
Else
    WOBJDAT    = [F:MFG]ENDDAT
Endif
WSTU       = [F:MFG]STU
WRMNEXTQTY = [F:MFG]RMNEXTQTY
WMFGPIO    = [F:MFG]MFGPIO
WMFGFCY    = [F:MFG]MFGFCY

#   chargement des opérations en mémoire
Link [MFO] With [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&          As   [SCOP]
&          Where [F:MFO]MFGNUM = [M:OPTK]MFGNUM
&          Order By Key MFO0
#
I=0
IPREC=-1
NBOPR=0
NBOPFC=0
For [SCOP]
  Read [OPS2]OPS1=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
  If fstat : Goto LEC_OPE_SUIV : Endif
  If find([F:MFO]OPESTA, 5, 6)     : Goto LEC_OPE_SUIV : Endif
  If [F:MFO]CPLQTY > [F:MFO]EXTQTY : Goto LEC_OPE_SUIV : Endif

  WOPENUM(I)    = [F:MFO]OPENUM
  WOPESPLNUM(I) = [F:MFO]OPESPLNUM
  WOPESTA(I)    = [F:MFO]OPESTA
  NBOPR +=1
  If [F:MFO]CPLWST = ""
    WWST(I)     = [F:MFO]EXTWST
  Else
    WWST(I)     = [F:MFO]CPLWST
  Endif
  If [F:MFO]CPLLAB = ""
    WLAB(I)     = [F:MFO]EXTLAB
  Else
    WLAB(I)     = [F:MFO]CPLLAB
  Endif
  WSCO(I)       = [F:MFO]SCOWST
  Call CHANGE_CHAR([F:MFO]SCHGRP) : # GH 05/06/2014 bug 99910
  WSCHGRP(I)    = [F:MFO]SCHGRP
  WSCHSBB(I)    = [F:MFO]SCHSBB
  WSETLABC(I)   = [F:MFO]SETLABCOE
  WOPELABC(I)   = [F:MFO]OPELABCOE
  WOPESTR(I)    = [M:OPTK]TRTDAT
  WOPEEND(I)    = [F:MFO]OPEEND
  WFRCSTRD(I)   = [F:MFO]FRCSTRDAT
  WRMNQTY(I)    = [F:MFO]EXTQTY - [F:MFO]CPLQTY
  If WRMNQTY(I) < 0 : WRMNQTY(I) = 0 : Endif
  WFRCSTRF(I)   = 0
  If WFRCSTRD(I) <> [0/0/0]
    NBOPFC     +=1
    WFRCHOU     = [F:MFO]FRCSTRHOU
    Call CONVHOU(WFRCHOU,WFRCSTRH) From JALLIBB
    Gosub CALDFR_FRC
    WFRCSTRF(I) = WDAYFR
  Endif
  WWSTN(I)    = [F:MFO]EXTWSTNBR
  If WWSTN(I) < 1 : WWSTN(I) = 1 : Endif
  If WLAB(I) = ""
    WLABN(I) = 0
  Else
    WLABN(I) = [F:MFO]EXTLABNBR
    If WLABN(I) < 1 : WLABN(I) = 1 : Endif
  Endif
#
  WSETTIM(I)    = [F:MFO]EXTSETTIM - [F:MFO]CPLSETTIM
  If WSETTIM(I) < 0 : WSETTIM(I) = 0 : Endif
  If [F:MFO]CPLQTY <> 0
      WPRPTIM(I)    = 0
      WSETTIM(I)    = 0
      WRATIO        = ([F:MFO]EXTQTY - [F:MFO]CPLQTY) / [F:MFO]EXTQTY
      WOPETIM(I)    = [F:MFO]EXTOPETIM * WRATIO
  Else
      WPRPTIM(I)    = [F:MFO]PRPTIM
      WOPETIM(I)    = [F:MFO]EXTOPETIM - [F:MFO]CPLOPETIM
      If WOPETIM(I) < 0 : WOPETIM(I) = 0 : Endif
  Endif
  WOPTTIM(I)    = WSETTIM(I) + WOPETIM(I)

  If [F:MFO]SCHGRP <> "" : WSETTIMSTD(I) = [F:MFO]STDSETTIM : Endif

#      convertit en H si nécessaire
  If [F:MFO]TIMUOMCOD = 2
    WSETTIM(I) /= 60
    WOPETIM(I) /= 60
    WOPTTIM(I) /= 60
  Endif
#
  If [F:MFO]PSPTIM > [F:MFO]WAITIM
      WPSPTIM(I)    = [F:MFO]PSPTIM
  Else
      WPSPTIM(I)    = [F:MFO]WAITIM
  Endif
  WSCOLTI(I)       = [F:MFO]SCOLTI
  If WSCOLTI(I) = 0 : WSCOLTI(I) = 1 : Endif
  WQTY(I)       = [F:MFO]EXTQTY - [F:MFO]CPLQTY

  Read [MWS]WST0=WWST(I);WMFGFCY
  If fstat : WTAB="MWS" : WCLE=WWST(I) : Goto AB_OPT : Endif

  # distinction exemplaires
  If [F:MWS]SBBFLG = 2
      If [F:MWS]WST <> XWST : Gosub SBB_EXTRACT : Endif
      XWST = [F:MWS]WST
      If [F:MFO]SCHSBB = ""
          # pseudo code sous-poste 0
          XIND = 0
      Else
          XIND = find([F:MFO]SCHSBB,XSBBT(0..NBSBB-1))
          If XIND = 0 : XSBB = "" : Else : XIND -= 1 : XSBB = XSBBT(XIND) : Endif
      Endif
      Gosub SBB_NAME
      WWST(I)  = XSBBWST
      WWSTN(I) = 1
  Endif

  WWSTTYP(I)    = [F:MWS]WSTTYP
  WSCOLTI(I)    = [F:MFO]SCOLTI
  If WSCOLTI(I) = 0 : WSCOLTI(I) = 1 : Endif
  WWIPNUM(I)    = [F:MFO]WIPNUM
  WSCOITMREF(I) = [F:MFO]SCOITMREF

  If WWSTTYP(I) = 3
      If [F:MFO]OPESTA = 7
          If [F:MFO]OPESTR < [M:OPTK]TRTDAT & [F:MFO]OPEEND >= [M:OPTK]TRTDAT
              If WSCOLTI(I) > ([F:MFO]OPEEND - [M:OPTK]TRTDAT)
                  WSCOLTI(I) = [F:MFO]OPEEND - [M:OPTK]TRTDAT
                  WFRCSTRD(I)   = [M:OPTK]TRTDAT
              Endif
          Else
              WFRCSTRD(I)   = [F:MFO]OPESTR
              WOPESTR(I)    = [F:MFO]OPESTR    # 73813 + 75117
          Endif
      Endif
  Endif

  If [F:MFO]OPESTA = 4 :   WFRCSTRD(I)   = [M:OPTK]TRTDAT     : Endif

#
  WSCDCOD(I)    = [F:SCH]SCDCOD

# BUG 78639
#  # si sous-traitance commandée sur opération <> première : paralléle ordre
#  If I > 0 & WOPESTA(I) = 7 : WSCDCOD(I) = 7 : Endif

  # si chevauchement en qté ou temps et opération déja suivie au delà du seuil
  # de chevauchement, on force une synchro début

  If find(WSCDCOD(I),2,3,4)       # si chevauchement
      If [F:MFO]OPESTA > 3        # si opération au moins en cours
          Case WSCDCOD(I)
              When 2:    If [F:MFO]CPLQTY    >= [F:SCH]LOTQTY * [F:SCH]SCDLOT : WSCDCOD(I) = 5 : Endif
              When 3:    If [F:MFO]CPLOPETIM >= [F:SCH]SCDTIM                 : WSCDCOD(I) = 5 : Endif
              When 4:    If [F:MFO]CPLQTY    >= [F:SCH]SCDQTY :                 WSCDCOD(I) = 5 : Endif
          Endcase
      Endif
  Endif

#      traitement particulier des op splittées
#        rétablit SCDCOD sur op précédente (pour homogénéité)
  If I>0 & IPREC >=0
    If WOPENUM(I) = WOPENUM(IPREC)
      If WSCDCOD(IPREC) <> 8 : WSCDCOD(IPREC) = 8 : Endif
    Else
      If WSCDCOD(IPREC) = 8 : WSCDCOD(IPREC) = 1 : Endif
    Endif
  Endif
#
  Case [F:MFG]SCDFLG
      When 2:  WOPESTRD(I)   = [F:SCH]OPESTRDAT
               WOPESTRF(I)   = [F:SCH]OPESTRFRD
               WINFSTRD(I)   = [F:SCH]INFCAPSTR
               WINFSTRF(I)   = [F:SCH]INFCAPSTF
               WINFENDD(I)   = [F:SCH]INFCAPEND
               WINFENDF(I)   = [F:SCH]INFCAPENF
               WOPEENDD(I)   = [F:SCH]OPEENDDAT
               WOPEENDF(I)   = [F:SCH]OPEENDFRD
      When 4:  WOPESTRD(I)   = [F:SCH]OPESTRDAT
               WOPESTRF(I)   = [F:SCH]OPEFITSTF
               WINFSTRD(I)   = [F:SCH]FITCAPSTR
               WINFSTRF(I)   = [F:SCH]FITCAPSTF
               WINFENDD(I)   = [F:SCH]FITCAPEND
               WINFENDF(I)   = [F:SCH]FITCAPENF
               WOPEENDD(I)   = [F:SCH]FITOPEEND
               WOPEENDF(I)   = [F:SCH]FITOPEENF
  Endcase
#     si sous traitance : SCDCOD imposé à 1 si différent de 8
  If WWSTTYP(I) = 3 & !find(WSCDCOD(I),7,8) : WSCDCOD(I) = 1 : Endif
#     calcul % chev
  Case WSCDCOD(I)
    When 1 :
      WSCDPCT(I) = 1.00
    When 2 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
            WSCDPCT(I) = 0
        Else
            WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
            If WNUM < 0 : WNUM = 0 : Endif
             WSCDPCT(I) = WNUM + ((([F:SCH]LOTQTY * [F:SCH]SCDLOT) - [F:MFO]CPLQTY) / WQTY(I))
        Endif
    When 3 :
        If ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM) = 0
            WSCDPCT(I) = 0
        Else
            WNUM = ([F:SCH]SCDTIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM)
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM / ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM)
        Endif
    When 4 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | WQTY(I) = 0)
            WSCDPCT(I) = 0
        Else
            If ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM) = 0
                WNUM = 0
            Else
                WNUM = WSETTIM(I) / ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM)
            Endif
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM + (([F:SCH]SCDQTY- [F:MFO]CPLQTY) / WQTY(I))
        Endif
    When 5 :
      WSCDPCT(I) = 0
  Endcase
#
# en sequence obligatoirement
  If I > 0
    If WOPENUM(I-1) <> WOPENUM(I)
        WNEXOPEN(I-1) = WOPENUM(I)
        WNEXSPLN(I-1) = WOPESPLNUM(I)
    Endif
  Endif

  IPREC=I

  WNEXOPEN(I)   = [F:SCH]NEXOPENUM
  WMFGMST = 0
  If [F:SCH]MFGMST = 2 : WMFGMST = [F:SCH]OPENUM : Endif

#      traitement particulier des op splittées
#        redéfinit NEXOPENUM (décomposé en NEXOPEN et NEXSPLN)
  WNEXSPLN(I)   = 0
  If I>0
    If WOPENUM(I) = WOPENUM(I-1)
      WNEXOPEN(I-1) = WOPENUM(I)
      WNEXSPLN(I-1) = WOPESPLNUM(I)
    Endif
  Endif
#
  # point d'entrée OPE_FOCUS
  If GSCHENTRY : GPOINT = "OPE_FOCUS" : Gosub ENTREE From EXEFNC : Endif

  I +=1
$LEC_OPE_SUIV
Next

# en sequence obligatoirement
If I > 0
    If WNEXOPEN(I-1) <> 0
        WNEXOPEN(I-1) = 0
    Endif
    # code jalonnement dernière opération = successeur
    # sauf si //toutes opérations
    If WSCDCOD(I-1) <> 7 : WSCDCOD(I-1) = 1 : Endif
Endif

#
NBOP = I
Goto CLAST_OPE

#########################################################################
# chargement OF suggéré
$LOAD_OFS
#
#   ouverture des fichiers
#
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING [SCH]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:OPS2]) = 0 : Local File OPERATIONS [OPS2] : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif

# recherche si optimisé
For [ORD]ORD0 Where WIPTYP = 5 & WIPNUM = [M:OPTK]MFGNUM & WIPSTA = 3
    If [F:ORD]OPTFLG = 2 : OPTIM = 2 : Else : OPTIM = 0 : Endif
    Break
Next

#
WSTU       = [M:OPTK]STU
WRMNEXTQTY = [M:OPTK]RMNEXTQTY
WMFGPIO    = [M:OPTK]MFGPIO
WMFGFCY    = [M:OPTK]MFGFCY

#   chargement des opérations en mémoire
Link [OPS2] With [SCH]SCH0=[F:OPS2]MFGNUM;[F:OPS2]OPENUM;[F:OPS2]OPESPLNUM
&          As   [SCOP]
&          Where [F:OPS2]MFGNUM = [M:OPTK]MFGNUM
&          Order By Key OPS1

I=0
For [SCOP]
  WOPENUM(I)    = [F:OPS2]OPENUM
  WOPESPLNUM(I) = [F:OPS2]OPESPLNUM
  WWST(I)       = [F:OPS2]EXTWST
  WLAB(I)       = [F:OPS2]EXTLAB
  WSCO(I)       = [F:OPS2]SCOWST
  Call CHANGE_CHAR([F:OPS2]SCHGRP) : # GH 05/06/2014 bug 99910
  WSCHGRP(I)    = [F:OPS2]SCHGRP
  WSCHSBB(I)    = [F:OPS2]SCHSBB
  WSETLABC(I)   = [F:OPS2]SETLABCOE
  WOPELABC(I)   = [F:OPS2]OPELABCOE
  WOPESTA(I)    = [F:OPS2]OPESTA
  WWSTN(I)      = [F:OPS2]EXTWSTNBR
  If WWSTN(I) < 1 : WWSTN(I) = 1  : Endif
  WRMNQTY(I)    = [F:OPS2]EXTQTY
  If WLAB(I) = ""
    WLABN(I) = 0
  Else
    WLABN(I) = [F:OPS2]EXTLABNBR
    If WLABN(I) < 1 : WLABN(I) = 1 : Endif
  Endif
#
  WPRPTIM(I)    = [F:OPS2]PRPTIM
  WSETTIM(I)    = [F:OPS2]EXTSETTIM
  WOPETIM(I)    = [F:OPS2]EXTOPETIM
  WOPTTIM(I)    = WSETTIM(I) + WOPETIM(I)

#  If [F:OPS]SCHGRP <> "" : WSETTIMSTD(I) = [F:MFO]STDSETTIM : Endif
  If [F:OPS2]SCHGRP <> "" : WSETTIMSTD(I) = [F:OPS2]EXTSETTIM : Endif # GH 18/06/2014 selon mail de LLC

#      convertit en H si nécessaire
  If [F:OPS2]TIMUOMCOD = 2
    WSETTIM(I) /= 60
    WOPETIM(I) /= 60
    WOPTTIM(I) /= 60
  Endif
#
  If [F:OPS2]PSPTIM > [F:OPS2]WAITIM
      WPSPTIM(I)    = [F:OPS2]PSPTIM
  Else
      WPSPTIM(I)    = [F:OPS2]WAITIM
  Endif
  WSCOLTI(I)    = [F:OPS2]SCOLTI
  If WSCOLTI(I) = 0 : WSCOLTI(I) = 1 : Endif
  WQTY(I)       = [F:OPS2]EXTQTY
#      code sous-traitance positionné en fonction de poste principal
  Read [MWS]WST0=WWST(I);WMFGFCY
  If fstat : WTAB="MWS" : WCLE=WWST(I) : Goto AB_OPT : Endif

  WWSTTYP(I)    = [F:MWS]WSTTYP
  WSCOLTI(I)    = [F:OPS2]SCOLTI
  If WSCOLTI(I) = 0 : WSCOLTI(I) = 1 : Endif
  WWIPNUM(I)    = [F:OPS2]WIPNUM
  WSCOITMREF(I) = [F:OPS2]SCOITMREF
#     récupère dates début et fin OF sur op
  If I = 0
    WSTRDAT     = [F:OPS2]OPESTR
    WENDDAT     = [F:OPS2]OPEEND
    WMFGFCY     = [F:OPS2]MFGFCY
  Else
    If WSTRDAT > [F:OPS2]OPESTR : WSTRDAT = [F:OPS2]OPESTR : Endif
    If WENDDAT < [F:OPS2]OPEEND : WENDDAT = [F:OPS2]OPEEND : Endif
  Endif
  WOBJDAT    = [F:ORD]ENDDAT

#
  WSCDCOD(I)    = [F:SCH]SCDCOD
  WNEXOPEN(I)   = [F:SCH]NEXOPENUM
 # en sequence obligatoirement
  If I > 0
      If WOPENUM(I-1) <> WOPENUM(I)
           WNEXOPEN(I-1) = WOPENUM(I)
           WNEXSPLN(I-1) = WOPESPLNUM(I)
       Endif
  Endif

# on prend les données finies ou infinies suivant flag optimisation
  Case OPTIM
      When 0:  WOPESTRD(I)   = [F:SCH]OPESTRDAT
               WOPESTRF(I)   = [F:SCH]OPESTRFRD
               WINFSTRD(I)   = [F:SCH]INFCAPSTR
               WINFSTRF(I)   = [F:SCH]INFCAPSTF
               WINFENDD(I)   = [F:SCH]INFCAPEND
               WINFENDF(I)   = [F:SCH]INFCAPENF
               WOPEENDD(I)   = [F:SCH]OPEENDDAT
               WOPEENDF(I)   = [F:SCH]OPEENDFRD
      When 2:  WOPESTRD(I)   = [F:SCH]OPESTRDAT
               WOPESTRF(I)   = [F:SCH]OPEFITSTF
               WINFSTRD(I)   = [F:SCH]FITCAPSTR
               WINFSTRF(I)   = [F:SCH]FITCAPSTF
               WINFENDD(I)   = [F:SCH]FITCAPEND
               WINFENDF(I)   = [F:SCH]FITCAPENF
               WOPEENDD(I)   = [F:SCH]FITOPEEND
               WOPEENDF(I)   = [F:SCH]FITOPEENF
  Endcase

#     si sous traitance : SCDCOD imposé à 1 si différent de 8
  If WWSTTYP(I) = 3 & WSCDCOD(I) <> 8 : WSCDCOD(I) = 1 : Endif
#     calcul % chev
  Case WSCDCOD(I)
    When 1 :
      WSCDPCT(I) = 1.00
    When 2 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
            WSCDPCT(I) = 0
        Else
            WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM + (([F:SCH]LOTQTY * [F:SCH]SCDLOT) / WQTY(I))
        Endif
    When 3 :
        If WSETTIM(I) = 0 & WOPETIM(I) = 0
            WSCDPCT(I) = 0        Else
            WSCDPCT(I) = [F:SCH]SCDTIM / (WSETTIM(I)+WOPETIM(I))
        Endif
    When 4 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
            WSCDPCT(I) = 0
        Else
            WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM + ([F:SCH]SCDQTY / WQTY(I))
        Endif
    When 5 :
      WSCDPCT(I) = 0
  Endcase
#
  I +=1
Next
# en sequence obligatoirement
If I > 0
    If WNEXOPEN(I-1) <> 0
        WNEXOPEN(I-1) = 0
    Endif
    WSCDCOD(I-1) = 1        # code jalonnement dernière opération = successeur
Endif

NBOP   = I
NBOPR  = I
NBOPFC = 0
Goto CLAST_OPE
#
##########################################################################
# établit l'ordre de consultation des opérations
$CLAST_OPE
#
If NBOPR <= 0 : Goto END_OPT : Endif
#
#    controle préalable pour op suivante splittée sans op principale
#
For I = 0 To NBOP-1
#
#     saute les op terminées
#
# llc 12.00 il ne faut pas sauter les opérations soldées
# If (WOPESTA(I) > 4 & WOPESTA(I) < 7) : Goto CONT_OPE_SUIV : Endif
  If (WOPESTA(I) = 6) : Goto CONT_OPE_SUIV : Endif
#
  If WNEXOPEN(I) <> 0 & WNEXSPLN(I) = 0
    For J = 0 To NBOP-1
      If WOPENUM(J) = WNEXOPEN(I)
        WNEXSPLN(I) = WOPESPLNUM(J)
        Break 1
      Endif
    Next J
  Endif
$CONT_OPE_SUIV
Next I
#
NBOPNT = NBOP - 1
If NBOPNT <= 0
  WOPERG(NBOPNT) = 0
  Goto CRE_LIENS
Endif
DOPNT = NBOPNT
WSUIV = 0
WSPLSUIV = 0
Raz WOPETRT(0..NBOPNT)
#
$CLAST_INIT
I = 0
#
$CLAST_SUITE
I += 1
If I > DOPNT + 1 : I = 1 : Endif
J = DOPNT + 1 - I
If (WNEXOPEN(J) <> WSUIV | (WNEXOPEN(J) = WSUIV & WNEXSPLN(J) <> WSPLSUIV))
  Goto CLAST_SUITE
Endif
WOPERG(NBOPNT) = J
WSUIV = WOPENUM(J)
WSPLSUIV = WOPESPLNUM(J)
WOPETRT(J) = 1
NBOPNT -= 1
If NBOPNT < 0 : Goto CRE_LIENS : Endif
If J <> DOPNT : Goto CLAST_SUITE : Endif
While WOPETRT(DOPNT) = 1
  DOPNT -= 1
Wend
#
Goto CLAST_INIT

#########################################################################
# Elaboration des liens de succession
$CRE_LIENS
#
NBLK = 0
# Point d'entrée INIT_JAL pour ajuster des données avant jalonnement
GPOINT = "INIT_JAL" : Gosub  ENTREE From EXEFNC

For I = 0 To NBOP-1
  J = WOPERG(I)
  If WOPESTA(J) > 4 & WOPESTA(J) < 7
    Goto LNK_OPE_SUIV
  Endif
  WLNKSCDCOD(NBLK) = WSCDCOD(J)
  # Issue 59758 GH 15/11/2017 - to display successor instead of start synchro
  #                             for details of an operation with scheduling code = 9
  If WSCDCOD(J)=9
     WLNKSCDCOD(NBLK) = 1
  Endif
  Case WSCDCOD(J)
    When 1, 9  : # Issue 59758 GH 15/11/2017 - new scheduling code = 9 added
      IS = I
$LNK1_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7 : Goto LNK_OPE_SUIV : Endif
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK1_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 2
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
      If WSCDCOD(JS) = 6
        Goto LNK1_SUIV
      Endif
    When 2,3,4
      IS = I
$LNK2_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK2_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = WSCDPCT(J) * 100
        WLNKTIM(NBLK) = ar2(WLNKTIM(NBLK))
        NBLK += 1
      Endif
      If WSCDCOD(JS) = 6
        Goto LNK2_SUIV
      Else
$LNK3_SUIV
        If WSCDCOD(JS) <> 1
          IS += 1
          If IS >= NBOP : Goto LNK_OPE_SUIV : Endif
          If IS < NBOP
            JS = WOPERG(IS)
            Goto LNK3_SUIV
          Endif
        Else
          IS += 1
          If IS >= NBOP : Goto LNK_OPE_SUIV : Endif
          If IS < NBOP
            JS = WOPERG(IS)
            WCONOPENUM(NBLK) = WOPENUM(J)
            WCONOPSNUM(NBLK) = WOPESPLNUM(J)
            WLNKOPENUM(NBLK) = WOPENUM(JS)
            WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
            WLNKTYP(NBLK) = 2
            WLNKTIM(NBLK) = 0
            NBLK += 1
          Endif
        Endif
      Endif
    When 5
      IS = I
$LNK4_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK4_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
$LNK5_SUIV
      If WSCDCOD(JS) <> 1
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif
        If IS < NBOP
          JS = WOPERG(IS)
          Goto LNK5_SUIV
        Endif
      Else
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif
        If IS < NBOP
          JS = WOPERG(IS)
          WCONOPENUM(NBLK) = WOPENUM(J)
          WCONOPSNUM(NBLK) = WOPESPLNUM(J)
          WLNKOPENUM(NBLK) = WOPENUM(JS)
          WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
          WLNKTYP(NBLK) = 2
          WLNKTIM(NBLK) = 0
          NBLK += 1
        Endif
      Endif
    When 6
      IS = I
$LNK6_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK6_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 3
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
    When 7
      If I = 0
        IS = I
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif
        If IS < NBOP
          JS = WOPERG(IS)
          WCONOPENUM(NBLK) = WOPENUM(J)
          WCONOPSNUM(NBLK) = WOPESPLNUM(J)
          WLNKOPENUM(NBLK) = WOPENUM(JS)
          WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
          WLNKTYP(NBLK) = 1
          WLNKTIM(NBLK) = 0
          NBLK += 1
        Endif
      Else
        JP = WOPERG(0)
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JP)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JP)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
    When 8
      IS = I
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK1_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
  Endcase
#
$LNK_OPE_SUIV
#
Next I

##########################################################################
# Ecriture fichiers
$ECR_FICH
#   Fichier en-tête OF
#     Ouverture du fichier OPTMFG en écriture
If [M:OPTK]PREMFG = 0
  Openo OPTMFG,0
  [M:OPTK]PREMFG = 1
Else
  Openo OPTMFG
Endif

  Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [M:OPTK]ITMREF, WCHAIN, "[F:ITM]") From TRTX3
  [M:OPTK]ITMDES1 = WCHAIN
  Call CHANGE_CHAR([M:OPTK]ITMDES1)

  Call CHANGE_CHAR([M:OPTK]ITMREF)

  Call CHANGE_CHAR([M:OPTK]PJT)

#     écriture le l'enregistrement en-tête OF
  Wrseq [M:OPTK]MFGNUM;[M:OPTK]MFGFCY;[M:OPTK]ITMREF;[M:OPTK]ITMDES1;[M:OPTK]PJT;[M:OPTK]RMNEXTQTY;
&         [M:OPTK]STU;[M:OPTK]MFGSTA;WSTRDAT,WENDDAT;WMFGPIO;WOBJDAT;WEXTDAT;WFLGMAJ
#     fermeture du fichier en-tête OF
Openo
#

# -----------------------------------------------------------
#   PE pour extraction des liens de succession entre OFs
  GPOINT = "ACT_LINK" : Gosub ENTREE From EXEFNC
# -----------------------------------------------------------

#   Fichier des opérations
#     Ouverture du fichier OPTOPE en écriture
If [M:OPTK]PREOPE = 0
  Openo OPTOPE,0
  [M:OPTK]PREOPE = 1
Else
  Openo OPTOPE
Endif

#     écriture des enregistrements opération
For I = 0 To NBOP-1
  J = WOPERG(I)
  If WOPESTA(J) > 4 & WOPESTA(J) < 7
    Goto ECR_OPE_SUIV
  Endif

#       arrondit les fractions
  WPRPTIMA = func TRTX3.ARRTYP("", "", "TIH", WPRPTIM(J))
  WOPTTIMA = func TRTX3.ARRTYP("", "", "TIH", WOPTTIM(J))
  WSETTIMA = func TRTX3.ARRTYP("", "", "TIH", WSETTIM(J))
  WSETTIMSTDA = func TRTX3.ARRTYP("", "", "TIH", WSETTIMSTD(J))
  WEXTTIMA = func TRTX3.ARRTYP("", "", "TIH", WOPETIM(J))
  WPSPTIMA = func TRTX3.ARRTYP("", "", "TIH", WPSPTIM(J))
  WFRCSTRA = arr(WFRCSTRF(J),0.0001)
  WOPESTRA = arr(WOPESTRF(J),0.0001)
  WINFSTRA = arr(WINFSTRF(J),0.0001)
  WINFENDA = arr(WINFENDF(J),0.0001)
  WOPEENDA = arr(WOPEENDF(J),0.0001)

  Wrseq [M:OPTK]MFGNUM;WOPENUM(J);WOPESPLNUM(J);WOPESTA(J);WWST(J);WLAB(J);WSCO(J);WSCHGRP(J);WOPELABC(J);WRMNQTY(J);
&           WPRPTIMA;WSETTIMA;WSETTIMSTDA;WEXTTIMA;WPSPTIMA;WSCOLTI(J);WWSTN(J);WLABN(J);WOPESTR(J);WFRCSTRD(J);
&           WFRCSTRA;WOPESTRD(J);WOPESTRA;WINFSTRD(J);WINFSTRA;WINFENDD(J);
&           WINFENDA;WOPEENDD(J);WOPEENDA;WEXTDAT;WFLGMAJ
$ECR_OPE_SUIV
Next I

#     fermeture du fichier opérations
Openo

#   Fichier des liens de succession
#     Ouverture du fichier OPTLNK en écriture
If [M:OPTK]PRELNK = 0
  Openo OPTLNK,0
  [M:OPTK]PRELNK = 1
Else
  Openo OPTLNK
Endif

#     écriture des enregistrements liens de succession
For I = 0 To NBLK-1
    Wrseq [M:OPTK]MFGNUM;WCONOPENUM(I);WCONOPSNUM(I);[M:OPTK]MFGNUM;WLNKOPENUM(I);WLNKOPSNUM(I);
&           WLNKTYP(I);WLNKTIM(I);WLNKSCDCOD(I);WEXTDAT;WFLGMAJ
Next I

#     fermeture du fichier liens de succession
Openo

Goto END_OPT

#########################################################################
# Calcul fraction début op forcée
$CALDFR_FRC

#     lecture poste
    Read [MWS]WST0=WWST(I);WMFGFCY
    If fstat : WTAB="MWS" : WCLE=WWST(I) : Goto AB_OPT : Endif

    #  nouvelle gestion des capacités
    Call LOACAPO(WFRCSTRD(I),WFRCSTRD(I),WCAP,WNBR,WRET) From JALLIBB


    WDAYCAP = WCAP(0)
    J = I
    Call CALDFR(WMFGFCY,WFRCSTRD(I),WFRCSTRH,WFRCHOU,WDAYCAP,WDAYFR,WWST(I)) From JALLIBB
Return
#
#########################################################################
# OF clos :
#   écriture d'un message
$OF_CLOS
End

#########################################################################
# fin normale :
#   synchronisation
#   écriture d'un message
$END_OPT
adxium = SAVIUM
End

#########################################################################
# fin anormale :
#   rollback
#   écriture d'un message
$AB_OPT
[M:OPTK]CODRET = 1
End

#########################################################################
## Remplacé par CHANGE_CHAR
#########################################################################
# Enlève un caractère d'une chaine
# alimenter la variable WCHAIN et le caractère WSPECHAR

$REMOVE_CHAR
Local Integer RCI

RCI = instr(0,WCHAIN, WSPECHAR)
While (RCI > 0)
    WCHAIN = left$(WCHAIN,RCI-1)+right$(WCHAIN,RCI+1)
    RCI = instr(0, WCHAIN, WSPECHAR) : # GH 05/06/2014 bug 99910 # RCI = instr(0, WCHAIN, ",")
Wend

Return

########################################################################
## Sous-programme créé le 05/06/2014 suite au bug 99910
## Remplace $REMOVE_CHAR

Subprog CHANGE_CHAR(CHAINE)
Variable Char CHAINE()

CHAINE=ctrans(CHAINE,",;","")
End

#########################################################################
# connection
$TRT_DEB
# llc 09.02 License
Case LFONC
    When "FUNSCA" : # 99508 mm 11.2014 - License management V7
                    #Call CONNECT("SCALE", LOPT1) From GLOCK
                    Call CONNECT("MAXWEIGHTING", LOPT1) From GLOCK
                    If LOPT1 : LOPT1 += 1 : Endif
Endcase
Return

#########################################################################
# déconnection
$TRT_END
Case GFONC1
    When "FUNSCA" : # 99508 mm 11.2014 - License management V7
                    #Call DECONNECT("SCALE") From GLOCK
                    Call DECONNECT("MAXWEIGHTING") From GLOCK
Endcase
Return

#########################################################################
# 99508 mm 11.2014 - License management V7
# Récupération de la valeur du flag ACTGANTT
# afin de déterminer si les fonctions du GANTT sont accessibles ou non
# à l'utilisateur

# en cas d'erreur, on renvoie 0
Funprog GET_ACTGANT
Local Integer VALFLG : VALFLG = 0
Local Char VALPARAM(30)
If dim(GACTX) > -1
  If fmet GACTX.AGETLICPAR("ACTGANTT",VALPARAM)=[V]CST_ATRUE
     If VALPARAM = "true"
        VALFLG = [V]CST_ATRUE
     Else
        VALFLG = [V]CST_AFALSE
     Endif
  Endif
Endif

End VALFLG

#########################################################################
## Sous-programme créé le 26/09/2013 suite au bug 92509

Funprog FILNAM(FCY,ILNAM,OPT)
Value Char FCY()
Value Char ILNAM()
Value Integer OPT

Case OPT
  When 0 : # Pour l'ouverture du fichier via openo/openi
    # GH 26/09/2013 bug 92509
    # End  filpath("tmp",tolower([L]FCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")),[L]ILNAM)
    End  filpath("tmp",func ILDEB([L]FCY),[L]ILNAM,nomap)

  When 1 : # Pour le PATH de Callui
    If GBROWS=1 & GFUSION=1 : # GH 24/11/2014 dm 103835
       End "TMP"+"/"+func ILDEB([L]FCY)+"."+[L]ILNAM
    Else
       End "tmp"+"/"+func ILDEB([L]FCY)+"."+[L]ILNAM
    Endif
Endcase
End ""

########################################################################
## Sous-programme créé le 24/11/2014 suite à la dem 103835

Funprog ILDEB(FCY)
Value Char FCY()

End tolower([L]FCY)+"_"+tolower(ctrans(adxusr,"./*\@","_"))

########################################################################
## Sous-programme créé le 26/09/2013 suite au bug 92509
## transfert le fichier ILNAM du serveur vers le fichier CSVNAM.csv du client

Subprog FIL2CSV(NAM,EXT,PATH,CSVNAM)
Value Char NAM()
Value Char EXT()
Value Char PATH()
Value Char CSVNAM()

Local Integer TYP : TYP=2
Goto GENCSV

########

Subprog ILFIL2CSV(FCY,ILNAM,CSVNAM)
Value Char FCY()
Value Char ILNAM()
Value Char CSVNAM()
# FCY doit être renseigné

Local Integer TYP : TYP=1
Goto GENCSV

#######

$GENCSV
Local Char SRVNAM(GDIMFIC)

If GBROWS=1 & GFUSION=1 : # GH 24/11/2014 dm 103835
   Local Integer EXISTE, STAT

   Case [L]TYP
    When 1
      Local Char    FICHIER(GDIMFIC)
      [L]FICHIER = func OPTLIB.FILNAM([L]FCY,[L]ILNAM,0)

      Call EXISTE([L]FICHIER,EXISTE) From ORDSYS
      If EXISTE
         Call COPIE([L]FICHIER
&                  ,filpath(nomap+"/TMP",func OPTLIB.ILDEB([L]FCY),[L]ILNAM,"X3_PUB")
&                  ,[L]STAT) From ORDSYS
      Endif
      [L]SRVNAM = func OPTLIB.FILNAM([L]FCY,[L]ILNAM,1)

    When 2
      Call EXISTE([L]PATH,EXISTE) From ORDSYS
      If EXISTE
         Call COPIE([L]PATH
&                  ,filpath(nomap+"/TMP",[L]NAM,[L]EXT,"X3_PUB")
&                  ,[L]STAT) From ORDSYS
      Endif
      If [L]EXT<>""
         [L]SRVNAM = "TMP/"+[L]NAM+"."+[L]EXT
      Else
         [L]SRVNAM = "TMP/"+[L]NAM
      Endif
   Endcase

   Callui RETOUR="" With "UIAction="+chr$(1)+"GetFileAlways",
&                        "UIRemoteFile="+ chr$(1) +[L]SRVNAM,
&                        "UILocalDir="+ chr$(1) +"UserTemp",
&                        "UILocalFile="+ chr$(1) +[L]CSVNAM+".csv",
&                        "UIDownLoad="+ chr$(1) + "ILOG"

Else
   Case [L]TYP
    When 1
      [L]SRVNAM = func OPTLIB.FILNAM([L]FCY,[L]ILNAM,1)
    When 2
      [L]SRVNAM = [L]PATH
   Endcase

   Callui RETOUR="" With "UIAction="+chr$(1)+"GetFileAlways",
&                        "UIRemoteFile="+ chr$(1) +[L]SRVNAM,
&                        "UILocalDir="+ chr$(1) +"UserTemp",
&                        "UILocalFile="+ chr$(1) +[L]CSVNAM+".csv"
Endif
End

########################################################################
## Sous-programme créé le 26/09/2013 suite au bug 92509
## transfert le fichier CSVNAM.csv du client vers le fichier ILNAM du serveur

Subprog CSV2ILFIL(FCY,ILNAM,CSVNAM)
Value Char FCY()
Value Char ILNAM()
Value Char CSVNAM()

If GBROWS=1 & GFUSION=1 : # GH 24/11/2014 dm 103835
   Local Integer RES1, STAT
   Local Blbfile FUPLOAD(10)
   Local Char    SRVNAM(GDIMFIC)

   [L]RES1 = Funciu "XDT_ILOG:UPLOAD" With ([L]FUPLOAD, [L]CSVNAM+".csv")
   If [L]RES1 <> 0
     [L]SRVNAM = func OPTLIB.FILNAM([L]FCY,[L]ILNAM,0)
     Openo [L]SRVNAM,0 Using [XTRF]
     Putseq 1, [L]FUPLOAD Using [XTRF]
     Openo Using [XTRF]
   Endif
Else
   Callui RETOUR="" With "UIAction="+chr$(1)+"PutFileAlways",
&                        "UIRemoteFile="+ chr$(1) +func OPTLIB.FILNAM([L]FCY,[L]ILNAM,1),
&                        "UILocalDir="+ chr$(1) +"UserTemp",
&                        "UILocalFile="+ chr$(1) +[L]CSVNAM+".csv"
Endif
End

