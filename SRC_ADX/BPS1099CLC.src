#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
#    Process Name:    BPS1099CLC - Calculate Supplier 1099 Payments
#
######################################################################################
$ACTION

Case ACTION

    When "INIT"         : Gosub INIT
    When "DEBUT"       : Affzo [DIA]1-99
    When "EXEC"         : Gosub EXEC
    When "OK"           : GOK=1
    When "END"          : GOK=0 : FIN=1
    When "CONTROLE"     : Gosub CONTROLE
    When "TERMINE"      : Gosub TERMINE

Endcase

Return

######################################################################################
$INIT

If clalev([F:BPS])=0 : Local File BPSUPPLIER    [BPS] : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH      [PYH] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD      [PYD] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE      [PIH] : Endif
If clalev([F:PID])=0 : Local File PINVOICED     [PID] : Endif
If clalev([F:PIL])=0 : Local File BPSINVLIG     [PIL] : Endif

If clalev([F:B9P])=0 : Local File BPS1099PAY    [B9P] : Endif

If clalev([F:PYH2])=0 : Local File PAYMENTH     [PYH2] : Endif
If clalev([F:PYD2])=0 : Local File PAYMENTD     [PYD2] : Endif
If clalev([F:B9P2])=0 : Local File BPS1099PAY   [B9P2] : Endif
If clalev([F:B9G])=0  : Local File BPS1099GEN   [B9G]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD   [DAE]  : Endif

#108437.sn
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE2])=0  : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:DUD])=0   : Local File GACCDUDATE [DUD]  : Endif
#108437.en

Local Mask BPS1099CLC [DIA]

Local Integer KOUNT, JCOUNT  #108437.o

Local Integer OK, STAT
Local Char    TIT(50), CRITERE(250)
Local Char    WMESS(80), CURBPS

TIT = mess(79,122, 1)    # Calculate 1099 supplier payments

Raz [M:DIA]

[M:DIA]THEYEAR = year(date$)
If month(date$) < 6
    [M:DIA]THEYEAR -= 1
Endif
[M:DIA]TRACE=2
Affzo[M:DIA]TRACE
Return

######################################################################################
$CONTROLE

If GOK < 1  FIN=1 Endif

Return

######################################################################################
$EXEC
Local Integer XOK

Look [F:B9G]B9G1(1) = [M]THEYEAR
If [S]fstat <=2 # Generate record exists
  Call OUINON(mess(81,122,1),XOK) From GESECRAN # Warning message prompt
  If XOK<>2
    GERR=1
    OK=0
  Endif
Endif

If !GSERVEUR and [M:DIA]TRACE = 2
    Call OUVRE_TRACE(TIT) From LECFIC
Endif

Gosub CREATE_RECORDS

Return


######################################################################################
#108437.sn

$CREATE_RECORDS

Local Decimal LAMT1099, PREVAMT1099
Local Integer XCURP, XCURI


KOUNT = 0
GOK = 1

Trbegin [F:B9P]
#
# Loop 1099 Suppliers determining the payments that were made to them for the given year
#
For [F:BPS] Where FRM1099 > 1

    Filter [F:PYH] Where BPR = [F:BPS]BPSNUM and year(ACCDAT) = [M:DIA]THEYEAR and STA >= 9 Order By NUM

    For [F:PYH]
        Raz XCURP, XCURI, JCOUNT
        For [F:PYD] Where NUM = [F:PYH]NUM

            # Check if there is any manual/automatic matching when invoice # is not existed
            If [F:PYD]VCRNUM = ""
              # Search for payment record in the Accounting entries header (GACCENTRY)
              For [F:HAE] Where BPRVCR = [F:PYH]NUM
                 # Search a payment record in the Accounting entries detail (GACCENTRYD)
                 For [F:DAE] Where NUM = [F:HAE]NUM and TYP = [F:HAE]TYP
                   # process this payment when the match code is not blank. This indicate the payment was matched
                   If [F:DAE]MTC <> ""
                     # The match code exists, search for invoice #
                     For [F:DAE2] Where MTC=[F:DAE]MTC and CPY=[F:DAE]CPY and FCYLIN=[F:DAE]FCYLIN and BPR=[F:DAE]BPR and TYP <> [F:DAE]TYP
                       # Search invoice record using the invoice # from the accounting entries detail table and process it
                       Read  [F:PIH]PIH0=[F:DAE2]NUM
                       If fstat = 0
                         JCOUNT += 1        # Count # of invoice(s) this payment applied to to use for the line #
                         # Invoie is found
                         Gosub PROCESS_INV
                       Endif
                    Next   # End of the For [F:DAE] Where NUM=[F:HAE]NUM
                  Endif   # If [F:DAE]MTC <> ""
                Next # End of the For [F:DAE] Where NUM=[F:HAE]NUM
              Next  # End of the For [F:HAE] Where BPRVCR = [F:PYH]NUM
            Else
              # Invoice (VCRNUM) field in the Payment Detail table (PAYMENTD) is not blank - current process
              # Read Invoice
              Read [F:PIH]PIH0=[F:PYD]VCRNUM

              If fstat = 0
                 Gosub PROCESS_INV
              Endif

            Endif  # End of the If [F:PYD]VCRNUM = ""

        Next # End of the For [F:PYD] Where NUM = [F:PYH]NUM

    Next # End of the For [F:PYH]

Next # End of the For [F:BPS] Where FRM1099 > 1

If GOK
    Commit
Else
    Rollback
Endif

Filter [F:PYH]

Return
#108437.en
#######################################################################################
#108437.sn
$PROCESS_INV

#
# See if a 1099 payment record exists out there for this payment line, if so, skip it
#

# Check if this is Manual/automatic matching or regular payment
If [F:PYD]VCRNUM = ""
  Read [F:B9P]B9P0 = [M:DIA]THEYEAR;[F:PYH]CPY;[F:BPS]BPSNUM;[F:PYD]NUM; JCOUNT       # Manual/automatic matching
Else
  Read [F:B9P]B9P0 = [M:DIA]THEYEAR;[F:PYH]CPY;[F:BPS]BPSNUM;[F:PYD]NUM; [F:PYD]LIN   # Regular payment
Endif


If fstat

    # Update PINVOICE, PINVOICED and BPSINVLIG tables if necessary
    If [M:DIA]DEFFRMBOX = 2 and [F:PIH]FRM1099 <= 1

        [F:PIH]FRM1099         = [F:BPS]FRM1099
        [F:PIH]BOX1099         = [F:BPS]BOX1099
        If [F:PIH]CUR = [F:PIH]CURLED # invoice currency = ledger currency
         [F:PIH]AMTSUBJ1099     = [F:PIH]AMTNOT
        Else
         [F:PIH]AMTSUBJ1099     = 0
         XCURI=1
        Endif
        If [F:PYH]CUR <> [F:PIH]CURLED # payment currency <> ledger currency
          [F:PIH]AMTSUBJ1099    = 0
          XCURP=1
        Endif

        Rewrite [F:PIH]
        If [F:PIH]ORIMOD = 3            #A/P Accounting
            Update [F:PIL] Where NUM = [F:PIH]NUM With FLG1099 = 2

        Else
            Update [F:PID] Where NUM = [F:PIH]NUM With FLG1099 = 2
        Endif

    Endif

    # Because of the partial payments we need to get the pay amount from the GACCDUDATE-Open items table for manual/automatic matching
    If [F:PYD]VCRNUM = ""
      For [F:DUD] Where TYP = [F:DAE2]TYP and NUM = [F:DAE2]NUM and LIG = [F:DAE2]LIN and DUDLIG = [F:DAE2]LEDTYP
        If fstat = 0
          LAMT1099 = [F:DUD]PAYCUR
        Endif
      Next
    Else
      LAMT1099 = [F:PIH]AMTSUBJ1099
    Endif

    #  Calculate prior payments against this invoce so we can deduct/determine
    #  Check 1099 Payments table for this year

    PREVAMT1099 = 0
    For [F:B9P2] Where YR1099 = [M:DIA]THEYEAR and CPY = [F:PYH]CPY and BPSNUM = [F:BPS]BPSNUM and INVNUM = [F:PIH]NUM
        PREVAMT1099 += [F:B9P2]AMT1099
    Next

    #  Check standard PAYMENTD table for prior years
    Link [F:PYD2] With [PYH2]PYH0=[PYD2]NUM As [LNK2] Where [F:PYH2]BPR = [F:BPS]BPSNUM and year([F:PYH2]ACCDAT) < [M:DIA]THEYEAR and [F:PYD2]VCRNUM = [F:PIH]NUM
    For [LNK2]
        PREVAMT1099 += [F:PYD2]AMTLIN2
    Next

    LAMT1099 -= PREVAMT1099

    If LAMT1099 > [F:PYD]AMTLIN2
        LAMT1099 = [F:PYD]AMTLIN2
    Endif

    If [F:PYH]CUR <> [F:PIH]CURLED # payment currency <> ledger currency
     LAMT1099=0
     XCURP=1
    Endif ###


# X3-83027 - We were not creating BPS1099PAY records for negative amounts
# For instance, credit memos that were not applied to any specific invoice
#    If LAMT1099 > 0  #X3-83027.o

    If LAMT1099 <> 0  #X3-83027.n

      # Write 1099 payment record
      Raz [F:B9P]
      [F:B9P]BPSNUM      = [F:BPS]BPSNUM
      [F:B9P]YR1099      = [M:DIA]THEYEAR
      [F:B9P]CPY         = [F:PYH]CPY
      [F:B9P]INVNUM      = [F:PIH]NUM
      [F:B9P]PAYNUM      = [F:PYD]NUM
      If [F:PYD]VCRNUM = ""
        [F:B9P]PAYLIN      = JCOUNT
      Else
        [F:B9P]PAYLIN      = [F:PYD]LIN
      Endif
      [F:B9P]AMT1099     = LAMT1099
      [F:B9P]FRM1099     = [F:PIH]FRM1099
      [F:B9P]CUR         = [F:PIH]CURLED
      If [F:B9P]FRM1099 < 1
          [F:B9P]FRM1099 = 1
      Endif
      [F:B9P]BOX1099     = [F:PIH]BOX1099
      Write [F:B9P]
      If fstat
         GOK=0 : Call FSTA("B9P") From GLOCK : Return
      Endif
    Endif

    If [M:DIA]TRACE = 2

        If CURBPS <> [F:B9P]BPSNUM
            Call ECR_TRACE(mess(00017,00007,1) - [F:B9P]BPSNUM - " - " - [F:BPS]BPSNAM, 0) From GESECRAN
            CURBPS = [F:B9P]BPSNUM
        Endif
        If XCURP # Ledger and payment currency differ
         Call ECR_TRACE("             " + mess(47,109,1) + ":" -[F:PYH]NUM - mess(86,122,1),0) From GESECRAN
        Endif
        If XCURI # Ledger and invoice currency differ
         Call ECR_TRACE("             " + mess(47,109,1) + ":" -[F:PYH]NUM - mess(84,122,1),0) From GESECRAN
        Endif
        If !XCURI & !XCURP
         Call ECR_TRACE("             " + mess(00047,00109,1) + ":" -[F:B9P]PAYNUM,0) From GESECRAN
        Endif
    Endif

    KOUNT += 1
Endif

Return
#108437.en

######################################################################################
$TERMINE

If !GSERVEUR and [M:DIA]TRACE = 2

    Call ECR_TRACE(" ",0) From GESECRAN

    Call ECR_TRACE(num$(KOUNT) - mess(103,141,1),0) From GESECRAN

    Call FERME_TRACE From LECFIC

    TRA=1

Endif

If !GSERVEUR and [M:DIA]TRACE = 1
    Call ECR_TRACE(num$(KOUNT) - mess(103,141,1),0) From GESECRAN
Endif

Return

######################################################################################
