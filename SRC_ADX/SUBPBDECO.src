# < DEBUG> #################################################################################### #
End
# </DEBUG> #################################################################################### #



#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "SEL_TABLE" : If TABLE = "PBDECOCOD" : Gosub SEL_TABLE_SELPBDECO : Endif
        When Default
    Endcase
Return



Subprog CONTPBDECO( COD, LEG )
Variable Char COD()
Value Char LEG

    If COD <> ""
        If clalev([F:PBDECO])=0 : Local File PBDECOCOD [PBDECO] : Endif

        Read [F:PBDECO]PBDECO0 = COD; LEG
        If fstat
            GMESSAGE = mess(23,100,1) # 'Record does not exist'
            mkstat = 2
        Endif
    Endif
End



Subprog SELPBDECO( COD, LEG )
Variable Char COD()
Value Char LEG

    Local Char PARMSK(30)(1..10)

    If clalev([F:PBDECO])=0 : Local File PBDECOCOD [PBDECO] : Endif

    PARMSK(1)=[L]LEG
    PARMSK(2)=""
    Call S_TAB_CHAR( COD, PARMSK, "PBDECOCOD", "SUBPBDECO", "" ) From GACTION
End



$SEL_TABLE_SELPBDECO

    If clalev([F:PBDECO])=0 : Local File PBDECOCOD [PBDECO] : Endif

    Local Char LEG(255) : LEG = PARAM(1)

    Default File [F:PBDECO]

    OBJET = "PBDECO"
    START = "[F:PBDECO]COD"
    CRITERE(1) = 'LEG = "' + LEG + '"'
    ORDRE = "[F:PBDECO]COD"
Return
