# Fields T01..T04 and T07..T09 exclude each other
######################################################################################
Subprog AS_GSTADDT07(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT01(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT02(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT03(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End

######################################################################################
# Fields T01..T04 and T07..T09 exclude each other
######################################################################################
Subprog AS_GSTADDT08(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT01(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT02(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT03(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End

######################################################################################
# Fields T01..T04 and T07..T09 exclude each other
######################################################################################
Subprog AS_GSTADDT09(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT01(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT02(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT03(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End


######################################################################################
Subprog C_GSTADDT02(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0 or VALEUR > 100 Then
    mkstat = 2
    GMESSAGE = func AFNC.MES2(mess(227,7703,1), num$(0 ), num$( 100 ) ) #  'Values must be in the range $1$ to $2$.'
Endif
End

Subprog C_GSTADDT03(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0 or VALEUR > 100 Then
    mkstat = 2
    GMESSAGE = func AFNC.MES2(mess(227,7703,1), num$(0 ), num$( 100 ) ) #  'Values must be in the range $1$ to $2$.'
Endif
End


######################################################################################
Subprog AM_GSTADDW02(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDW02(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD2 = fix(VALEUR + [M:GSTP1]GSTADDW03(nolign-1) + [M:GSTP1]GSTADDW04(nolign-1))
    Affzo [M:GSTPH]GSTADD2
Endif
End

Subprog AM_GSTADDW03(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDW03(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD2 = fix(VALEUR + [M:GSTP1]GSTADDW02(nolign-1) + [M:GSTP1]GSTADDW04(nolign-1))
