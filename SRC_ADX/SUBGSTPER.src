#<AdxTL>@(#)0.0.0.0 $Revision$ Object management GSTPER
######################################################################################
# Handling of screens GSTPERH / GSTPER1 /GSTPER2 : GST reporting periods (for Australian GST reporting)
# Caution, this screen is managed with hybrid code
# If you change something, be sure that you don't have to change the class
# Classes : GSTPER and GSTPERD
# Treatments : GSTPER_CSTD, GSTPERD_CSTD
# Author : Bader
#
# 2018-01-02  DNE   Refactoring (GSTGRP -> CODGSTGRP, GSTPERCOD -> CODGSTPER)
# 2018-01-11  DNE   Initialize start and end date
# 2018-01-12  Bader DATSTR / DATEND are disabled in LIENS when CODGSTPER is not empty
#                   Affzo [M:GSTPH] after LIENS in CREATION to show created CODGSTPER
# 2018-01-15  Bader Add AVANT_MOD to prevent the "Save" button to be activated in final status
#                   Disable CODGSTGRP after the creation (in LIENS)
# 2018-01-17  Bader Call the correct messages from local menu 7704
# 2018-01-19  Gregolec X3-68993: Close reporting period and finalize data in VERIF_MOD
# 2018-01-26  Bader Add APRES_MODIF to suppress "SAVE" button from details grid
# 2018-01-29  Gregolec Add X3-72949 Import of previous reported periods
# 2018-02-02  Gregolec     X3-75295 Dependencies of Buttons when "Save" is active and/or period is closed
# 2018-02-07  Bader X3-75342 Additional fields in member company grid, "Total" section in header
# 2018-02-28  Bader X3-80836 Totals of GSTADD7C/GSTADD7D in header fields GSTADD03/GSTADD04
# 2018-03-07  Bader X3-78978 small changes after code review
# 2018-03-09  Bader Remove alphanumerical CODGSTPER & rename numerical CODGSTPER1 to CODGSTPER
# 2018-03-12  Bader Add GSTPER_UPDGSTDATA (calls action GSTUPDPER and calls Subprog GSTPER_CALCULATE)
#                   LIENS: Call GSTPER_CALCULATE to update "Preview" tab
# 2018-03-15  Bader GSTPER_CALCULATE: skip companies which do not belong to period (with same reporting code)
# 2018-03-23  Bader X3-82842: Add GSTPER_EXCEXP (Excel export)
# 2018-03-27  Bader X3-84021: Support G4 / G13 / G14
# 2018-04-06  angre X3-84019: Additonal field ORIMOD in Excel export
# 2018-04-13  angre X3-85913: Cut of decimals for Group BAS values
# 2018-04-17  angre X3-85910: BAS values can only be entered for the head company
# 2018-04-19  angre X3-86380: Handling temporary journals on closing period
# 2018-04-18  Bader X3-86403: AM_FLGPRE: Default date from new parameter AUSGSTASOF
# 2018-04-27  Bader X3-85913: Additional values may only be changed on "leading company" > no cumulation over all members
# 2018-05-08  Bader X3-87426: GSTPER_UPDGSTDATA: save period header in database after update
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "LIENS"        : Gosub LIENS
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "APRES_CRE"    : Gosub APRES_CRE
 When "DEFLIG"       : Gosub DEFLIG
 When "AV_ANNULE"    : Gosub AV_ANNULE
 When "ANNULE"       : Gosub ANNULE
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "INICRE_LIG"   : Gosub INICRE_LIG
 When "LIENS_LIG"    : Gosub LIENS_LIG
 When "VALLIG"       : Gosub VALLIG
 When "FERME"        : Gosub FERME
# 2018-01-11 DNE INSERT BEGIN
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
# 2018-01-11 DNE INSERT END
# 2018-01-15 DNE INSERT BEGIN
 When "SETBOUT"      : Gosub SETBOUT
# 2018-01-15 DNE INSERT END
Endcase
Return


# 2018-01-16 DNE INSERT BEGIN
$VERIF_CRE
    Local Libelle RETC
    Local Date DATSTR, DATEND

    # Check on given dates against automatic suggestion.
    Call INIT_DATES( [M:GSTPH]CODGSTGRP, DATSTR, DATEND )
    If ( [M:GSTPH]DATSTR <> DATSTR ) or ( [M:GSTPH]DATEND <> DATEND )
        Qstbox mess(40,7704,1) Titled mess(66,123,1) Using RETC # 'Period date range differs from proposed date range. Continue?'
        If RETC = 2 : OK = 0 : Endif
    Endif
    If !OK : Return : Endif
    Gosub VERIF_MOD # Do further checks.
Return
# 2018-01-16 DNE INSERT END

# 2018-01-11 DNE INSERT BEGIN
$VERIF_MOD
    Local Libelle RETC

    # Check ..
    If [GSTPH]GSTGRPSTA = 3 # Closed period
      # US X3-86380 check for temporary journals
      If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif

      Filter [F:HAE] Where [F:HAE]NUMDCL= [M:GSTPH]CODGSTPER & [F:HAE]STA=1
      If rowcount([F:HAE]) > 0
        Local Char PARAM(2)
        Call PARAM("AUS","AUSTMPBLK",PARAM) From ADOVAL
        If  PARAM = "2"
          Errbox mess(308,107,1)
          OK = 0
          Return
        Else
           Local Integer STA : STA = 2
           Wrnbox mess(308,107,1) Using STA
           If STA <> 1
            OK = 0
            Return
           Endif
        Endif
      Endif
      Filter [F:HAE]

      For I= 0 To [M:GSTP1]NBLIG - 1
        If [M:GSTP1]GSTMEMSTA(I) < 2
            # 'At least one member is in status '$1$'. Do you really want to close the period?'
                Qstbox  func AFNC.MES1( mess(39,7704,1), mess( [M:GSTP1]GSTMEMSTA(I), 3699, 1) )
&               Titled mess(66,123,1) Using RETC # 'Warning'
          If RETC = 2 : OK = 0 : Break : Endif
          Break
      Endif
      Next
      If RETC <> 2
        Local Tinyint ERRCOD
        Local Integer PERCOD : PERCOD = [M:GSTPH]CODGSTPER
        Call FINALIZEPERIOD(PERCOD, ERRCOD) From DCLVATAUSPER
        If ERRCOD : OK = 0 : Endif
      Endif
    Endif

    # 2018-05-15 DNE X3-87426
    # Prevent class object from complaining about different update ticks.
    If dim( ANOUPDTICK ) > 0
        ANOUPDTICK = 1
    Endif
Return
# 2018-01-11 DNE INSERT END

# 2018-01-15 DNE INSERT BEGIN
$SETBOUT
    # We can only create reports if the report code already exists.
    If [M:GSTPH]CODGSTPER = 0 Then
        Call VIREBOUT(CHAINE, "u") From GOBJET # Button Update data
    Endif

    # We may not delete a period if it is in "final" state
    If [M:GSTPH]GSTGRPSTA = 3 Then
        Call VIREBOUT(CHAINE, "A") From GOBJET # Button "Delete"
        Call VIREBOUT(CHAINE, "u") From GOBJET
    Endif

    #if save button is active, deactivate GST Report and Update data menu
    If GREP <> "" Then
        Call VIREBOUT(CHAINE, "u") From GOBJET # Button Update data
    Endif

    # 2018-02-26 DNE X3-77324
    Call VIREBOUT( CHMEN, "51" ) From GOBJET
    CHMEN += "51"
    # 2018-03-23 Bader X3-82842
    Call VIREBOUT( CHMEN, "52" ) From GOBJET
    If GREP = "" Then CHMEN += "52" Endif  # if save button is inactive, activate Tax invoice inquiry
    # 2018-09-04 Bader X3-79061
    Call VIREBOUT( CHMEN, "53" ) From GOBJET
    If GREP = "" Then CHMEN += "53" Endif
Return
# 2018-01-15 DNE INSERT END

$DECL_VAR_LOCAL
#----------------------------------#
# Local variable declaration       #
#----------------------------------#
Local  Integer  I
Local  Shortint NOL
Local  Integer MY_STATUS, WRET
Return

#-------------------------------------------------------------#
$DEFLIG
#----------------------------------#
# Lines file definition            #
#----------------------------------#
Default Mask [GSTP1]
Default File [GSTPD]
CRIT   = 'CODGSTPER='+num$([M:GSTPH]CODGSTPER)
FICLIG = "GSTPERD"
ABLIG  = "GSTPD"
ZONLIG = "LIN"
Return

#-------------------------------------------------------------#
$VALLIG
#---------------------------------------------------------------#
# After each creation, modification or deletion lines           #
#---------------------------------------------------------------#
Case TRTLIG
  When  "C"   Gosub VALLIG_CRE
  When  "M"   Gosub VALLIG_UPD
  When  "A"   Gosub VALLIG_DEL
Endcase
Return

#-------------------------------------------------------------#
$VALLIG_CRE
#--------------------------------#
# After creation lines           #
#--------------------------------#
Gosub INS_LIG
Return
#-------------------------------------------------------------#

$VALLIG_UPD
#--------------------------------#
# After modification lines       #
#--------------------------------#
If SIGN = -1 Gosub UPD_LIG Endif
Return

#-------------------------------------------------------------#
$VALLIG_DEL
#--------------------------------#
# After deletion lines           #
#--------------------------------#
If GREP <> "A" Gosub DEL_LIG : Endif
Return

#-------------------------------------------------------------#
$INS_LIG
#---------------------------------------#
# Insert one line in container class    #
#---------------------------------------#
Local Integer WPOS
WPOS = fmet WGSTPER.ADDLINE("LINES",[V]CST_ALASTPOS)
If WPOS = [V]CST_ANOTDEFINED
  #--The insertion was not possible
  GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'LINES','GSTPER')
  GOK=0 : GERR=1
  Return
Endif
Gosub SET_VALUES_LIG
Return

#-------------------------------------------------------------#
$DEL_LIG
#---------------------------------------#
# Delete one line in container class    #
#---------------------------------------#
Local Integer WPOS, WRET
Raz WRET
#--- Find the AUUID of the del line
WPOS = find([F:GSTPD]AUUID, WGSTPER.LINES(1..maxtab(WGSTPER.LINES)).AUUID)
If WPOS <> 0
  WRET=fmet WGSTPER.ADELLINE ("LINES", WGSTPER.LINES(WPOS).AORDER)
  If WRET>=[V]CST_AERROR
    GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','GSTPER')
    GOK=0 : GERR=1
    Return
  Endif
Endif
Return

#-------------------------------------------------------------#
$UPD_LIG
#---------------------------------------#
# Update one line in container class    #
#---------------------------------------#
Local Integer WPOS
#--- Find the AUUID of the update line
WPOS = find([F:GSTPD]AUUID, WGSTPER.LINES(1..maxtab(WGSTPER.LINES)).AUUID)
  If WPOS <> 0
    #--- Affect new values(M class) in the container class
    Gosub SET_VALUES_LIG
  Endif
Return


#-------------------------------------------------------------#
SET_VALUES_LIG
WGSTPER.LINES(WPOS).CODGSTGRP = [M:GSTPH]CODGSTGRP
WGSTPER.LINES(WPOS).CODGSTPER = [M:GSTPH]CODGSTPER
WGSTPER.LINES(WPOS).LIN = [M:GSTP1]LIN(nolign-1)
WGSTPER.LINES(WPOS).CPY = [M:GSTP1]CPY(nolign-1)
WGSTPER.LINES(WPOS).GSTHEA = [M:GSTP1]GSTHEA(nolign-1)
WGSTPER.LINES(WPOS).GSTMEMSTA = [M:GSTP1]GSTMEMSTA(nolign-1)
WGSTPER.LINES(WPOS).GSTADD7C = [M:GSTP1]GSTADD7C(nolign-1)
WGSTPER.LINES(WPOS).GSTADD7D = [M:GSTP1]GSTADD7D(nolign-1)
WGSTPER.LINES(WPOS).GSTADDF01 = [M:GSTP1]GSTADDF01(nolign-1)
WGSTPER.LINES(WPOS).GSTADDF02 = [M:GSTP1]GSTADDF02(nolign-1)
WGSTPER.LINES(WPOS).GSTADDF03 = [M:GSTP1]GSTADDF03(nolign-1)
WGSTPER.LINES(WPOS).GSTADDF04 = [M:GSTP1]GSTADDF04(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT01 = [M:GSTP1]GSTADDT01(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT02 = [M:GSTP1]GSTADDT02(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT03 = [M:GSTP1]GSTADDT03(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT04 = [M:GSTP1]GSTADDT04(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT07 = [M:GSTP1]GSTADDT07(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT08 = [M:GSTP1]GSTADDT08(nolign-1)
WGSTPER.LINES(WPOS).GSTADDT09 = [M:GSTP1]GSTADDT09(nolign-1)
WGSTPER.LINES(WPOS).GSTADDW01 = [M:GSTP1]GSTADDW01(nolign-1)
WGSTPER.LINES(WPOS).GSTADDW02 = [M:GSTP1]GSTADDW02(nolign-1)
WGSTPER.LINES(WPOS).GSTADDW03 = [M:GSTP1]GSTADDW03(nolign-1)
WGSTPER.LINES(WPOS).GSTADDW04 = [M:GSTP1]GSTADDW04(nolign-1)
Return


#-------------------------------------------------------------#
$INICRE_LIG
#----------------------------#
# Before line write          #
#----------------------------#
Return

#-------------------------------------------------------------#
$OUVRE
#-------------------------------#
# before the Window opening     #
#-------------------------------#
#--- To use the class CRUD instead of the object CRUD
ANOWRITE = 1
#---
Local File GSTPERD  [GSTPD1]
#---- Local variables
Gosub DECL_VAR_LOCAL
#--- Array variables
Gosub DECLARE From TABLEAUX
#--- Container class : global for sub prog ANUCOD
Global Instance WGSTPER Using C_GSTPER
Return

#-------------------------------------------------------------#
$RAZCRE
    If WGSTPER<> null : FreeGroup WGSTPER :Endif
    #--- Class instanciation
    WGSTPER = NewInstance C_GSTPER AllocGroup null
    [L]MY_STATUS = fmet WGSTPER.AINIT()
    If [L]MY_STATUS >= [V]CST_AERROR
      #--- Header errors
      GMESSAGE = func LCCLIB.MAXMSG(WGSTPER)
      If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
      Endif
    Endif
    SetInstance [F:GSTPH] With WGSTPER
    [M:GSTPH] = [F:GSTPH]
    Affzo [M:GSTPH]1-99
Return

#-------------------------------------------------------------#
$RAZDUP
    If WGSTPER<> null : FreeGroup WGSTPER :Endif
    #--- Class instanciation
    WGSTPER = NewInstance C_GSTPER AllocGroup null
    [L]MY_STATUS = fmet WGSTPER.AINIT()
    If [L]MY_STATUS >= [V]CST_AERROR
      #--- Header errors
      GMESSAGE = func LCCLIB.MAXMSG(WGSTPER)
      If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
      Endif
    Endif
    SetInstance [F:GSTPH] With WGSTPER
    [M:GSTPH] = [F:GSTPH]
    Affzo [M:GSTPH]1-99
Return

#-------------------------------------------------------------#
$CREATION
#----------------------------------#
# Container creation               #
#----------------------------------#
#Local Integer I
## Collection reinit in case of modification after a first creation with error
#For I=1 To maxtab(WGSTPER.LINES)
#  If (WGSTPER.LINES(I) <> null and find(WGSTPER.LINES(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0)
#    WRET=fmet WGSTPER.ADELLINE ("LINES", WGSTPER.LINES(I).AORDER)
#    If WRET<>[V]CST_AOK
#      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','GSTPER')
#      GOK=0 : GERR=1
#      Return
#    Endif
#  Endif
#Next
# 2018-02-09 Bader recreate instance because of multiple errors in combination with controls on class
#--- Free instance
If WGSTPER<> null  : FreeGroup WGSTPER :Endif
#--- class instantiation
WGSTPER = NewInstance C_GSTPER AllocGroup null
# NOTE (DNE): Data writing is disabled because ANOWRITE = 1!
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif

#--- Assign the Syracuse class with [M]class
[F:GSTPH] = [M:GSTPH]
SetInstance WGSTPER With [F:GSTPH]
WGSTPER.CODGSTGRP = [M:GSTPH]CODGSTGRP
WGSTPER.CODGSTPER = [M:GSTPH]CODGSTPER
#--- AINSERT method
MY_STATUS = fmet WGSTPER.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTPER)
  If GOK=0 : Return : Endif
Endif
SetInstance [F:GSTPH] With WGSTPER
[M:GSTPH]CODGSTPER = WGSTPER.CODGSTPER
Gosub LIENS
Affzo [M:GSTPH]
Return

#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification container               #
#--------------------------------------#
#Local Integer I
## Collection reinit in case of modification after a first creation with error
#For I=1 To maxtab(WGSTPER.LINES)
#  If (WGSTPER.LINES(I) <> null and find(WGSTPER.LINES(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL, [V]CST_ALL) = 0)
#    WRET=fmet WGSTPER.ADELLINE ("LINES", WGSTPER.LINES(I).AORDER)
#    If WRET<>[V]CST_AOK
#      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','GSTPER')
#      GOK=0 : GERR=1
#      Return
#    Endif
#  Endif
#Next
# 2018-02-09 Bader recreate instance because of multiple errors in combination with controls on class
#--- Free instance
If WGSTPER<> null  : FreeGroup WGSTPER :Endif
#--- class instantiation
WGSTPER = NewInstance C_GSTPER AllocGroup null
#--- Read method
WRET = fmet WGSTPER.AREAD([M:GSTPH]CODGSTPER)
If WRET >= [V]CST_AERROR
  Call GET_ERRORS(WGSTPER)
  If GOK=0 : Return : Endif
Endif
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif

#--- Assign the Syracuse class with [M]class
[F:GSTPH] = [M:GSTPH]
SetInstance WGSTPER With [F:GSTPH]
WGSTPER.CODGSTGRP = [M:GSTPH]CODGSTGRP
WGSTPER.CODGSTPER = [M:GSTPH]CODGSTPER
#--- AUPDATE method
MY_STATUS = fmet WGSTPER.AUPDATE()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTPER)
  If GOK=0 : Return : Endif
Endif

# 2018-05-15 DNE X3-87426
# Prevent class object from complaining about different update ticks.
If dim( ANOUPDTICK ) > 0
    ANOUPDTICK = 0
Endif
Return

#-------------------------------------------------------------#
$AV_ANNULE
#--- Must define again ANOWRITE because of subprog ANUCOD
ANOWRITE = 1
If WGSTPER.GSTGRPSTA = 2 Then
    Local Libelle YESNO
    # You have already validated this reporting period. Delete anyway?
    Qstbox(mess(33,7704,1)) Titled mess(66,123,1) Using YESNO
    If YESNO <> 1 Then
        GOK = 0
        GERR = 1
    Endif
Endif
Return

#-------------------------------------------------------------#
$ANNULE
#--------------------------------------#
# Deletion container                   #
#--------------------------------------#
# NOTE (DNE): Data writing is disabled because ANOWRITE = 1!
Gosub ANNULE From TABLEAUX
#--- ADELETE method
MY_STATUS = fmet WGSTPER.ADELETE()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTPER)
  If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------#
$FERME
#--- Free instance
If WGSTPER<> null
  FreeGroup WGSTPER
Endif
Kill WGSTPER
Return

#-------------------------------------------------------------#
$APRES_CRE
Gosub LIENS From TABLEAUX
Return

#-------------------------------------------------------------#
$APRES_MOD
Gosub LIENS From TABLEAUX
 If [M:GSTPH]FLGPRE = 2
    Diszo [M:GSTPH]FLGPRE
    Diszo [M:GSTPH]PREDAT
  Endif
Return

#-------------------------------------------------------------#
$AVANT_MOD
If [M:GSTPH]GSTGRPSTA = 3 OK = 0 Endif
Return

#-------------------------------------------------------------#
$APRES_MODIF
If COUZON = "NBLIGD" OK = -1 Endif
Return

#------------------------------------#
$LIENS
#------------------------------------#

    #--- Free instance
    If WGSTPER<> null  : FreeGroup WGSTPER :Endif
    #--- class instantiation
    WGSTPER = NewInstance C_GSTPER AllocGroup null
    #--- Read method
    WRET = fmet WGSTPER.AREAD([M:GSTPH]CODGSTPER)
    If WRET >= [V]CST_AERROR
      Call GET_ERRORS(WGSTPER)
      If GOK=0 : Return : Endif
    Endif
    Gosub LIENS From TABLEAUX

    If WGSTPER.GSTGRPSTA = 3 Then
        Diszo [M:GSTPH]1-99         # disable complete screen
        Diszo [M:GSTP1]GSTMEMSTA    # disable complete column
#        Diszo [M:GSTP2]1-99         # disable complete screen
    Else
        Actzo [M:GSTPH]1-99         # enable complete screen
        Actzo [M:GSTP1]GSTMEMSTA    # enable complete column
#        Actzo [M:GSTP2]1-99         # enable complete screen
    Endif
    If WGSTPER.CODGSTPER <> 0 Then
        Diszo [M:GSTPH]DATSTR
        Diszo [M:GSTPH]DATEND
        Diszo [M:GSTPH]CODGSTGRP
        Diszo [M:GSTPH]PREDAT

        If [M:GSTPH]FLGPRE = 2 or WGSTPER.GSTGRPSTA = 3 Then
          Diszo [M:GSTPH]FLGPRE
        Endif
    Else
        Actzo [M:GSTPH]DATSTR
        Actzo [M:GSTPH]DATEND
        Actzo [M:GSTPH]CODGSTGRP
        # angre SET PRE-PERIOD Date Field
        Diszo [M:GSTPH]PREDAT
    Endif

    [M:GSTPH]GSTNET = [M:GSTPH]GST1A - [M:GSTPH]GST1B

    #X3-85910 BAS values can only be entered for the head company
    Local Integer I
    For I=0 To [M:GSTP1]NBLIG-1
      If [M:GSTP1]GSTHEA(I) <= 1
        Diszo [M:GSTP1]CODGSTGRP(I)
        Diszo [M:GSTP1]CPY(I)
        Diszo [M:GSTP1]GSTHEA(I)
        #Diszo [M:GSTP1]GSTMEMSTA(I)
        Diszo [M:GSTP1]GSTADD7C(I)
        Diszo [M:GSTP1]GSTADD7D(I)
        Diszo [M:GSTP1]GSTADDF01(I)
        Diszo [M:GSTP1]GSTADDF02(I)
        Diszo [M:GSTP1]GSTADDF03(I)
        Diszo [M:GSTP1]GSTADDF04(I)
        Diszo [M:GSTP1]GSTADDT01(I)
        Diszo [M:GSTP1]GSTADDT02(I)
        Diszo [M:GSTP1]GSTADDT03(I)
        Diszo [M:GSTP1]GSTADDT04(I)
        Diszo [M:GSTP1]GSTADDT07(I)
        Diszo [M:GSTP1]GSTADDT08(I)
        Diszo [M:GSTP1]GSTADDT09(I)
        Diszo [M:GSTP1]GSTADDW01(I)
        Diszo [M:GSTP1]GSTADDW02(I)
        Diszo [M:GSTP1]GSTADDW03(I)
        Diszo [M:GSTP1]GSTADDW04(I)
     Endif
     Affzo [M:GSTP1]
   Next

    Call GSTPER_CALCULATE()         # calculate data for "Preview" tab
Return

#------------------------------------#
$LIENS_LIG
#------------------------------------#
Return

#------------------------------------#
#--- Get the errors                  #
#------------------------------------#
Subprog GET_ERRORS(WGSTPER)
Variable Instance WGSTPER Using C_GSTPER
Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WGSTPER)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors
  For I=1 To maxtab(WGSTPER.LINES)
    GMESSAGE = func LCCLIB.MAXMSG(WGSTPER.LINES(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
      Break:  Endif
  Next I
Endif
GOK=0 : GERR=1
End


######################################################################################
Subprog AM_CODGSTGRP(VALEUR)
Variable Char VALEUR
Local Integer I                          # Hybrid part

    If WGSTPER = null Then
        #--- class instantiation
        WGSTPER = NewInstance C_GSTPER AllocGroup null
        #--- Read method
        WRET = fmet WGSTPER.AINIT()
        If WRET >= [V]CST_AERROR
          Call GET_ERRORS(WGSTPER)
          If GOK=0 : Return : Endif
        Endif
    Endif

    If WGSTPER.CODGSTGRP <> VALEUR
        Raz [M:GSTP1]
        WGSTPER.CODGSTGRP = VALEUR
      #  [L]MY_STATUS = fmet WGSTPER.HANDLE_CPYLST()
        nolign = 1
        For I=1 To maxtab(WGSTPER.LINES)
          If WGSTPER.LINES(I) <> null and find(WGSTPER.LINES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [M:GSTP1]CODGSTGRP(nolign-1) = WGSTPER.LINES(I).CODGSTGRP
            [M:GSTP1]CODGSTPER(nolign-1) = WGSTPER.LINES(I).CODGSTPER
            [M:GSTP1]LIN(nolign-1) = WGSTPER.LINES(I).LIN
            [M:GSTP1]CPY(nolign-1) = WGSTPER.LINES(I).CPY
            [M:GSTP1]GSTHEA(nolign-1) = WGSTPER.LINES(I).GSTHEA
            [M:GSTP1]GSTMEMSTA(nolign-1) = 1
            [M:GSTP1]GSTADD7C(nolign-1) = WGSTPER.LINES(I).GSTADD7C
            [M:GSTP1]GSTADD7D(nolign-1) = WGSTPER.LINES(I).GSTADD7D
            [M:GSTP1]GSTADDF01(nolign-1) = WGSTPER.LINES(I).GSTADDF01
            [M:GSTP1]GSTADDF02(nolign-1) = WGSTPER.LINES(I).GSTADDF02
            [M:GSTP1]GSTADDF03(nolign-1) = WGSTPER.LINES(I).GSTADDF03
            [M:GSTP1]GSTADDF04(nolign-1) = WGSTPER.LINES(I).GSTADDF04
            [M:GSTP1]GSTADDT01(nolign-1) = WGSTPER.LINES(I).GSTADDT01
            [M:GSTP1]GSTADDT02(nolign-1) = WGSTPER.LINES(I).GSTADDT02
            [M:GSTP1]GSTADDT03(nolign-1) = WGSTPER.LINES(I).GSTADDT03
            [M:GSTP1]GSTADDT04(nolign-1) = WGSTPER.LINES(I).GSTADDT04
            [M:GSTP1]GSTADDT07(nolign-1) = WGSTPER.LINES(I).GSTADDT07
            [M:GSTP1]GSTADDT08(nolign-1) = WGSTPER.LINES(I).GSTADDT08
            [M:GSTP1]GSTADDT09(nolign-1) = WGSTPER.LINES(I).GSTADDT09
            [M:GSTP1]GSTADDW01(nolign-1) = WGSTPER.LINES(I).GSTADDW01
            [M:GSTP1]GSTADDW02(nolign-1) = WGSTPER.LINES(I).GSTADDW02
            [M:GSTP1]GSTADDW03(nolign-1) = WGSTPER.LINES(I).GSTADDW03
            [M:GSTP1]GSTADDW04(nolign-1) = WGSTPER.LINES(I).GSTADDW04
            nolign += 1
          Endif
        Next
        [M:GSTP1]NBLIG = nolign-1
        Affzo [M:GSTP1]1-99
    Endif

    # Initialize start and end date
    Call INIT_DATES( VALEUR, [M:GSTPH]DATSTR, [M:GSTPH]DATEND )
    Affzo [M:GSTPH]DATSTR, DATEND
End


# 2018-01-10 DNE INSERT BEGIN
######################################################################################
Subprog AS_GSTMEMSTA(VALEUR)
    Variable Integer VALEUR

    GMENLOC(3) = 1
End
# 2018-01-10 DNE INSERT END



Subprog INIT_DATES( GSTGRP, DATSTR, DATEND )
Value Char GSTGRP
Variable Date DATSTR
Variable Date DATEND
    Local File GSTPER [GSTPH]
    Local File GSTGRP [GSTGH]

    Read [F:GSTGH]GSTGH0 = GSTGRP
    If !fstat
        Filter [F:GSTPH] Where CODGSTGRP = GSTGRP
        Read [F:GSTPH]GSTPH1 Last
        Filter [F:GSTPH]
        If !fstat
            DATSTR = [F:GSTPH]DATEND + 1
        Else
            Case [F:GSTGH]GSTPER
                When 1 : DATSTR = eomonth( addmonth( date$, - 2 ) ) + 1
                When 2 : DATSTR = eomonth( addmonth( date$, - 3 - mod( month( date$ ), 3 ) ) ) + 1
            Endcase
        Endif
        Read [F:GSTGH]GSTGH0 = GSTGRP
        Case [F:GSTGH]GSTPER
            When 1 : DATEND = addmonth( DATSTR, 1 ) - 1
            When 2 : DATEND = addmonth( DATSTR, 3 ) - 1
        Endcase
     Endif
End

######################################################################################


##################################################
Subprog GSTPER_CALCULATE()
Local File DCLVATBOXH [MYVATH]
Local Decimal L_1A, L_1B, L_G1, L_G2, L_G3, L_G4, L_G10, L_G11, L_G13, L_G14, L_NET
Local Char LAST_CPY(GLONCPY)

Raz [M:GSTP3]
Raz LAST_CPY
# clear total values in header screen
Raz [M:GSTPH]GST1A, [M:GSTPH]GST1B, [M:GSTPH]GSTG1, [M:GSTPH]GSTG2, [M:GSTPH]GSTG3, [M:GSTPH]GSTG10, [M:GSTPH]GSTG11
Raz [M:GSTPH]GSTNET, [M:GSTPH]GSTG4, [M:GSTPH]GSTG13, [M:GSTPH]GSTG14
Filter [F:MYVATH] Where NUMRPT = [M:GSTPH]CODGSTPER and DCLVATTYP = 1 Order By CPY # only DCLVATBOXDBD supported for Australia
[M:GSTP3]NBLIGD = 0
[S]nolign = 0
If rowcount([F:MYVATH]) > 0           # if at least 1 record exists in DCLVATBOXH
    For [F:MYVATH]
      If find([F:MYVATH]CPY,[M:GSTP1]CPY(0..[M:GSTP1]NBLIG-1) )
        If LAST_CPY <> ""
            If [F:MYVATH]CPY <> LAST_CPY
                Gosub SET_VALUES
                Raz L_1A, L_1B, L_G1, L_G2, L_G3, L_G4, L_G10, L_G11, L_G13, L_G14
                LAST_CPY = [F:MYVATH]CPY
            Endif
        Else
            LAST_CPY = [F:MYVATH]CPY
        Endif
        Case [F:MYVATH]VATBOX
            When "1A"  : L_1A  += [F:MYVATH]AMT
            When "1B"  : L_1B  += [F:MYVATH]AMT
            When "G1"  : L_G1  += [F:MYVATH]AMT
            When "G2"  : L_G2  += [F:MYVATH]AMT
            When "G3"  : L_G3  += [F:MYVATH]AMT
            When "G4"  : L_G4  += [F:MYVATH]AMT
            When "G10" : L_G10 += [F:MYVATH]AMT
            When "G11" : L_G11 += [F:MYVATH]AMT
            When "G13" : L_G13 += [F:MYVATH]AMT
            When "G14" : L_G14 += [F:MYVATH]AMT
        Endcase
      Endif
    Next
    Gosub SET_VALUES              # set values for last company
Else                              # no DCLVATBOXH record found > search in DCLVATBOXDBD
    Local File DCLVATBOXDBD [MYVATD]
    Filter [F:MYVATD] Where NUMRPT = [M:GSTPH]CODGSTPER Order By CPY
    If rowcount([F:MYVATD]) > 0           # if at least 1 record exists in DCLVATBOXDBD
        For [F:MYVATD]
          If find([F:MYVATD]CPY,[M:GSTP1]CPY(0..[M:GSTP1]NBLIG-1) )
            If LAST_CPY <> ""
                If [F:MYVATD]CPY <> LAST_CPY
                    Gosub SET_VALUES
                    Raz L_1A, L_1B, L_G1, L_G2, L_G3, L_G4, L_G10, L_G11, L_G13, L_G14
                    LAST_CPY = [F:MYVATD]CPY
                Endif
            Else
                LAST_CPY = [F:MYVATD]CPY
            Endif
            Case [F:MYVATD]VATBOX
                When "1A"  : L_1A  += [F:MYVATD]AMT
                When "1B"  : L_1B  += [F:MYVATD]AMT
                When "G1"  : L_G1  += [F:MYVATD]AMT
                When "G2"  : L_G2  += [F:MYVATD]AMT
                When "G3"  : L_G3  += [F:MYVATD]AMT
                When "G4"  : L_G4  += [F:MYVATD]AMT
                When "G10" : L_G10 += [F:MYVATD]AMT
                When "G11" : L_G11 += [F:MYVATD]AMT
                When "G13" : L_G13 += [F:MYVATD]AMT
                When "G14" : L_G14 += [F:MYVATD]AMT
            Endcase
          Endif
        Next
        Gosub SET_VALUES              # set values for last company
    Endif
Endif

Filter [F:MYVATH]

Diszo [M:GSTP3]GST1A
Diszo [M:GSTP3]GST1B
Diszo [M:GSTP3]GSTG1
Diszo [M:GSTP3]GSTG2
Diszo [M:GSTP3]GSTG3
Diszo [M:GSTP3]GSTG4
Diszo [M:GSTP3]GSTG10
Diszo [M:GSTP3]GSTG11
Diszo [M:GSTP3]GSTG13
Diszo [M:GSTP3]GSTG14
Affzo [M:GSTP3]1-99
Affzo [M:GSTPH]1-99

LogicClose File [MYVATH]
End


##################################################
$SET_VALUES
[M:GSTP3]CPY(nolign) = LAST_CPY
[M:GSTP3]GST1A(nolign) = L_1A
[M:GSTP3]GST1B(nolign) = L_1B
[M:GSTP3]GSTG1(nolign) = L_G1
[M:GSTP3]GSTG2(nolign) = L_G2
[M:GSTP3]GSTG3(nolign) = L_G3
[M:GSTP3]GSTG4(nolign) = L_G4
[M:GSTP3]GSTG10(nolign) = L_G10
[M:GSTP3]GSTG11(nolign) = L_G11
[M:GSTP3]GSTG13(nolign) = L_G13
[M:GSTP3]GSTG14(nolign) = L_G14
[M:GSTP3]GSTNET(nolign) = L_1A - L_1B
[M:GSTP3]NBLIGD += 1
[S]nolign += 1

# update total values in header screen
[M:GSTPH]GST1A  = fix([M:GSTPH]GST1A + L_1A)
[M:GSTPH]GST1B  = fix([M:GSTPH]GST1B + L_1B)
[M:GSTPH]GSTG1  = fix([M:GSTPH]GSTG1 + L_G1)
[M:GSTPH]GSTG2  = fix([M:GSTPH]GSTG2 + L_G2)
[M:GSTPH]GSTG3  = fix([M:GSTPH]GSTG3 + L_G3)
[M:GSTPH]GSTG4  = fix([M:GSTPH]GSTG4 + L_G4)
[M:GSTPH]GSTG10 = fix([M:GSTPH]GSTG10 + L_G10)
[M:GSTPH]GSTG11 = fix([M:GSTPH]GSTG11 + L_G11)
[M:GSTPH]GSTG13 = fix([M:GSTPH]GSTG13 + L_G13)
[M:GSTPH]GSTG14 = fix([M:GSTPH]GSTG14 + L_G14)
[M:GSTPH]GSTNET = fix([M:GSTPH]GSTNET + (L_1A - L_1B))
Return


##################################################
Subprog GSTPER_UPDGSTDATA()
   Local Char VALEUR(10)
   Local Char PARAM(250)(1..20) , SAVACT(10)
   Local Integer WRET

   # first step: call action "GSTUPDPER" to update GST data
   SAVACT = GACTION : GACTION = "GSTUPDPER"
   Call TRAITE_CHAR(VALEUR,PARAM,"","DCLVATAUSPER","",1,"") From GTRAITE
   GACTION = SAVACT

   # second step: calculate data for "Preview" tab
# X3-87426 start
   If GOK > 0               # check result of GSTUPDPER
# X3-87426 end
      Call GSTPER_CALCULATE()
# X3-87426 start
      # save period header after recalculation
      Read [F:GSTPH]GSTPH0 = [M:GSTPH]CODGSTPER
      If !fstat
          [F:GSTPH] = [M:GSTPH]
          Rewrite [F:GSTPH]
          If !fstat
              WRET = fmet WGSTPER.AREAD([M:GSTPH]CODGSTPER)
          Endif
      Endif
   Endif
# X3-87426 end
End



######################################################################################
Subprog AM_FLGPRE(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    Local Char P_AUSGSTASOF(10)
    Actzo [M:GSTPH]PREDAT
    Call PARAM("AUS","AUSGSTASOF",P_AUSGSTASOF) From ADOVAL
    If P_AUSGSTASOF <> ""
     [M:GSTPH]PREDAT = P_AUSGSTASOF
    Endif
    If [M:GSTPH]PREDAT=[0/0/0] : [M:GSTPH]PREDAT=[01/01/2000] : Endif
#    Local File GSTGRP [GSTGH]
#    Read [F:GSTGH]GSTGH0 = [M:GSTPH]CODGSTGRP
#    Case [F:GSTGH]GSTPER
#        When 1 : [M:GSTPH]PREDAT = addmonth( [M:GSTPH]DATSTR, -1 )
#        When 2 : [M:GSTPH]PREDAT = addmonth( [M:GSTPH]DATSTR, -3)
#    Endcase
  Else
    Raz [M:GSTPH]PREDAT
    Diszo [M:GSTPH]PREDAT
  Endif
  Affzo [M:GSTPH]PREDAT
End


######################################################################################
Subprog IB_NBLIG
    If GREP <> "" #if save button is active, deactivate GST Report in line
      GBOUT1 = ""
    Endif
End


######################################################################################
# Field F01 is written into the header (Fringe benefit)
######################################################################################
Subprog AM_GSTADDF01(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDF01(nolign-1) <> VALEUR and [M:GSTP1]GSTADDF03(nolign-1) = 0.0
    [M:GSTPH]GSTADD4 = fix(VALEUR)
    Affzo [M:GSTPH]GSTADD4
Endif
End

######################################################################################
Subprog AM_GSTADDF03(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDF03(nolign-1) <> VALEUR
    If [M:GSTP1]GSTADDF03(nolign-1) <> 0.0        # if F03 held a value already before
        If VALEUR = 0.0                           # F03 is deleted
            [M:GSTPH]GSTADD4 = fix([M:GSTP1]GSTADDF01(nolign-1)) # > use F1 for header
        Else
            [M:GSTPH]GSTADD4 = fix(VALEUR)        # use new value of F3 for header
        Endif
    Else                                          # if F03 didn't hold a value already before
        [M:GSTPH]GSTADD4 = fix(VALEUR)
    Endif
    Affzo [M:GSTPH]GSTADD4
Endif
End


######################################################################################
Subprog AM_GSTADDT01(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT01(nolign-1) <> VALEUR
    If [M:GSTP1]GSTADDT02(nolign-1) <> 0.0
        [M:GSTPH]GSTADD1 = fix(VALEUR * ([M:GSTP1]GSTADDT02(nolign-1)/100))
    Elsif [M:GSTP1]GSTADDT03(nolign-1) <> 0.0
        [M:GSTPH]GSTADD1 = fix(VALEUR * ([M:GSTP1]GSTADDT03(nolign-1)/100))
    Endif
    Affzo [M:GSTPH]GSTADD1
Endif
End

Subprog AM_GSTADDT02(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT02(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD1 = fix([M:GSTP1]GSTADDT01(nolign-1) * (VALEUR/100))
    Affzo [M:GSTPH]GSTADD1
Endif
End

Subprog AM_GSTADDT03(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT03(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD1 = fix([M:GSTP1]GSTADDT01(nolign-1) * (VALEUR/100))
    Affzo [M:GSTPH]GSTADD1
Endif
End

Subprog AM_GSTADDT07(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT07(nolign-1) <> VALEUR and [M:GSTP1]GSTADDT09(nolign-1) = 0.0 # T09 empty > T07 has been used so far
    [M:GSTPH]GSTADD1 = fix(VALEUR)
    Affzo [M:GSTPH]GSTADD1
Endif
End


######################################################################################
Subprog AM_GSTADDT09(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT09(nolign-1) <> VALEUR
    If [M:GSTP1]GSTADDT09(nolign-1) <> 0.0        # if T09 held a value already before
        If VALEUR = 0.0                           # T09 is deleted
            [M:GSTPH]GSTADD1 = fix([M:GSTP1]GSTADDT07(nolign-1)) # > use T07 for header
        Else
            [M:GSTPH]GSTADD1 = fix(VALEUR)        # > use new value of T09 for header
        Endif
    Else                                          # if T09 didn't hold a value already before
        [M:GSTPH]GSTADD1 = fix(VALEUR)
    Endif
    Affzo [M:GSTPH]GSTADD1
Endif
End


######################################################################################
# Fields T01..T04 and T07..T09 exclude each other
######################################################################################
Subprog AS_GSTADDT01(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT07(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT08(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT09(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End

######################################################################################
# Fields T01..T04 and T07..T09 exclude each other, T02 and T03 as well
######################################################################################
Subprog AS_GSTADDT02(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT07(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT08(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT09(nolign-1) <> 0.0
&    or [M:GSTP1]GSTADDT03(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End

######################################################################################
# Fields T01..T04 and T07..T09 exclude each other, T02 and T03 as well
######################################################################################
Subprog AS_GSTADDT03(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDT07(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT08(nolign-1) <> 0.0 or [M:GSTP1]GSTADDT09(nolign-1) <> 0.0
&    or [M:GSTP1]GSTADDT02(nolign-1) <> 0.0
    VALEUR = 0.0
    mkstat = 2
Endif
End

######################################################################################
# Fields T01..T04 and T07..T09 exclude each other
######################################################################################
Subprog AS_GSTADDT04(VALEUR)
Variable Char    VALEUR()
If [M:GSTP1]GSTADDT03(nolign-1) = 0.0 and [M:GSTP1]GSTADDT09(nolign-1) = 0.0
    VALEUR = ""
    mkstat = 2
Endif
End

