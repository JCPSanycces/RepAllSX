Endif
End

Subprog AM_GSTADDW04(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADDW04(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD2 = fix(VALEUR + [M:GSTP1]GSTADDW02(nolign-1) + [M:GSTP1]GSTADDW03(nolign-1))
    Affzo [M:GSTPH]GSTADD2
Endif
End


######################################################################################
Subprog AM_GSTADD7C(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADD7C(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD3 = fix(VALEUR)
    Affzo [M:GSTPH]GSTADD3
Endif
End

Subprog AM_GSTADD7D(VALEUR)
Variable Decimal VALEUR
If [M:GSTP1]GSTADD7D(nolign-1) <> VALEUR
    [M:GSTPH]GSTADD5 = fix(VALEUR)
    Affzo [M:GSTPH]GSTADD5
Endif
End


######################################################################################
# Excel export of table DCLVATBOXDBD
######################################################################################
Subprog GSTPER_EXPEXC(PNUMRPT)
Value Integer PNUMRPT

Local Integer STAT
Local Char NAMEF(200),NAMEF1(100)
Local Char LANCOU(GLONLAN)
Local Clbfile HDRLIN(6)
Local Char TFLGVAT(50), TVATIPT(50), TTYPAMT(50),TORIMOD(50)

Raz HDRLIN
LANCOU=GLANGUE

If clalev([F:DLVBD])=0  : Local File DCLVATBOXDBD  [DLVBD] : Endif
If clalev([F:ATX])=0    : Local File ATEXTE        [ATX]   : Endif
If clalev([F:ATZ])=0    : Local File ATABZON       [ATZ]  : Endif

Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
NAMEF = filpath(nomap+DIRSEP+"TMP","","","X3_PUB")
NAMEF1="F"+num$(adxuid(1))+"_"+GBOITE+"_"+num$(time)
NAMEF1+=".csv"
NAMEF+=DIRSEP+NAMEF1

Gosub SET_INIVAR From ALHE
Openo NAMEF,0 Using [CSV_]
If IUM=GUTF8
 Iomode adxifs "" Using [CSV_]
 Iomode adxirs "" Using [CSV_]
 Iomode adxium GASCII Using [CSV_]
 Wrseq chr$(239)+chr$(187)+chr$(191) Using [CSV_]
Endif
Iomode adxifs IFS Using [CSV_]
Iomode adxirs IRS Using [CSV_]
Iomode adxium IUM Using [CSV_]

# Write headline
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"NUM"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"LIN"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"VATBOX" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"AMT"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"VAT"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"ACC"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"ACCDAT" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"TYP"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"FLGVAT" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"TYPAMT" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"VATIPT" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"VATRAT" : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"COA"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"CUR"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"CPY"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"FCY"    : Gosub ADD_TO_HDRLIN
Read [F:ATZ]CODZONE = "DCLVATBOXDBD";"ORIMOD" : Gosub ADD_TO_HDRLIN
Wrseq HDRLIN Using [CSV_]

# Write data
Filter [F:DLVBD] Where NUMRPT = PNUMRPT Order By CPY;VATBOX
For [F:DLVBD]
    TFLGVAT = mess([F:DLVBD]FLGVAT,608,1)
    TVATIPT = mess([F:DLVBD]VATIPT,609,1)
    TTYPAMT = mess([F:DLVBD]TYPAMT,686,1)
    TORIMOD = mess([F:DLVBD]ORIMOD,14,1)
    Wrseq [F:DLVBD]NUM;[F:DLVBD]LIN;[F:DLVBD]VATBOX;format$("N3:13.2",[F:DLVBD]AMT);[F:DLVBD]VAT;[F:DLVBD]ACC;[F:DLVBD]ACCDAT;
&         [F:DLVBD]TYP;TFLGVAT;TTYPAMT;TVATIPT;[F:DLVBD]VATRAT;
&         [F:DLVBD]COA;[F:DLVBD]CUR;[F:DLVBD]CPY;[F:DLVBD]FCY;TORIMOD Using [CSV_]
Next

Openo Using [CSV_]

Call COPCLI(NAMEF,NAMEF,STAT) From ORDSYS
End


$ADD_TO_HDRLIN
Read [ATX]NUMERO = LANCOU;[F:ATZ]NOLONG
If HDRLIN = ""
    HDRLIN += [F:ATX]TEXTE
Else
    HDRLIN += ";"+[F:ATX]TEXTE
Endif
Return

