#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Gestion du masque PJMTXTCLB
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    # Buttons
    When "OK"                          : Gosub OK
    When "END"                         : Gosub DO_END
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  # -----------------------------
  # Issue X3-25775/121534 - 2017-02-23 by SINGC : START
  #If PARAM(1) <> "PJBU0" and PARAM(1) <> "PJBU1" and PARAM(1) <> "PJTA0" and PARAM(1) <> "PJTA1" and PARAM(1) <> "PJTA2" and PARAM(1) <> "PTED" and PARAM(1) <> "PTEAFF" Then
  If PARAM(1) <> "PJBU0" and PARAM(1) <> "PJBU1" and PARAM(1) <> "PJTA0" and PARAM(1) <> "PJTA1" and PARAM(1) <> "PJTA2" and PARAM(1) <> "PTED" and PARAM(1) <> "PTEAFF" and PARAM(1) <> "PJTAC1"
& and PARAM(1) <> "PJOPE1" Then # Issue X3-15943 - 2017-04-20 by SINGC
  # Issue X3-25775/121534 - 2017-02-23 by SINGC : END
    GMESSAGE = mess(186,123,1)
    FIN = 1
    Return
  Endif
  If PARAM(1) = "PTED" or PARAM(1) = "PTEAFF" Then
    # Time entries
    If dim(GZINSPJMTH) <= 0  Then
      GMESSAGE = mess(186,123,1)
      FIN = 1
      Return
    Endif
  Else
    # Project
    If dim(GZINSPJM) <= 0 Then
      GMESSAGE = mess(186,123,1)
      FIN = 1
      Return
    Endif
  Endif
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

##########################################################################################################
$DEBUT
Local Char SFROM(type(PARAM)-10)
Local Integer ITABLIN
Local Integer ICOLLIN

  SFROM = PARAM(1)
  ITABLIN = val(PARAM(2))
  Case SFROM
    When "PJBU0"
      ICOLLIN = 0
    When "PJBU1"
      ICOLLIN = [M:PJBU1]COLLIN(ITABLIN)
    When "PJTA0"
      ICOLLIN = 0
    When "PJTA1"
      ICOLLIN = [M:PJTA1]COLLIN(ITABLIN)
    When "PJTA2"
      ICOLLIN = [M:PJTA2]COLLIN(ITABLIN)
    When "PJTAC1"                         # Issue X3-25775/121534 - 2017-02-23 by SINGC
      ICOLLIN = [M:PJTAC1]COLLIN(ITABLIN) # Issue X3-25775/121534 - 2017-02-23 by SINGC
    When "PTED"
      ICOLLIN = [M:PTED]COLLIN(ITABLIN)
    When "PTEAFF"
      ICOLLIN = [M:PTEAFF]COLLIN(ITABLIN)
    When "PJOPE1"                         # Issue X3-15943 - 2017-04-20 by SINGC
      ICOLLIN = [M:PJOPE1]COLLIN(ITABLIN) # Issue X3-15943 - 2017-04-20 by SINGC
    When Default
  Endcase
  Gosub SHOW_TEXTS
Return

##########################################################################################################
$OK
  Case SFROM
    When "PJBU0"
      GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUDESTEX = [M:PJMC]DESTEX
      GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUCOMTEX = [M:PJMC]COMTEX
    When "PJBU1"
      GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ICOLLIN).PLBDESTEX = [M:PJMC]DESTEX
      GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ICOLLIN).PLBCOMTEX = [M:PJMC]COMTEX
    When "PJTA0"
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASDESTEX = [M:PJMC]DESTEX
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASCOMTEX = [M:PJMC]COMTEX
    When "PJTA1"
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTDESTEX = [M:PJMC]DESTEX
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTCOMTEX = [M:PJMC]COMTEX
    When "PJTA2"
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPEDESTEX = [M:PJMC]DESTEX
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPECOMTEX = [M:PJMC]COMTEX
    When "PJTAC1"                                                                                          # Issue X3-25775/121534 - 2017-02-23 by SINGC
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(ICOLLIN).POALGDES = [M:PJMC]DESTEX # Issue X3-25775/121534 - 2017-02-23 by SINGC
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(ICOLLIN).POALGCOM = [M:PJMC]COMTEX # Issue X3-25775/121534 - 2017-02-23 by SINGC
    When "PTED"
      GZINSPJMTH.TIMENT(ICOLLIN).PTEDESTEX = [M:PJMC]DESTEX
      GZINSPJMTH.TIMENT(ICOLLIN).PTECOMTEX = [M:PJMC]COMTEX
    When "PTEAFF"
      GZINSPJMTH.TIMENT(ICOLLIN).PTEDESTEX = [M:PJMC]DESTEX
      GZINSPJMTH.TIMENT(ICOLLIN).PTECOMTEX = [M:PJMC]COMTEX
    When "PJOPE1"                                                                                           # Issue X3-15943 - 2017-04-20 by SINGC
      GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(ICOLLIN).POALGDES = [M:PJMC]DESTEX # Issue X3-15943 - 2017-04-20 by SINGC
      GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(ICOLLIN).POALGCOM = [M:PJMC]COMTEX # Issue X3-15943 - 2017-04-20 by SINGC
    When Default
  Endcase
Return

##########################################################################################################
$DO_END
  Raz [M:PJMC]DESTEX
  Raz [M:PJMC]COMTEX
Return

##########################################################################################################
$SHOW_TEXTS
  Case SFROM
    When "PJBU0"
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUDESTEX
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).PBUCOMTEX
    When "PJBU1"
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ICOLLIN).PLBDESTEX
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(ICOLLIN).PLBCOMTEX
    When "PJTA0"
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASDESTEX
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASCOMTEX
    When "PJTA1"
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTDESTEX
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTCOMTEX
    When "PJTA2"
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPEDESTEX
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPECOMTEX
    When "PJTAC1"                                                                                          # Issue X3-25775/121534 - 2017-02-23 by SINGC
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(ICOLLIN).POALGDES # Issue X3-25775/121534 - 2017-02-23 by SINGC
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(ICOLLIN).POALGCOM # Issue X3-25775/121534 - 2017-02-23 by SINGC
    When "PTED"
      [M:PJMC]DESTEX = GZINSPJMTH.TIMENT(ICOLLIN).PTEDESTEX
      [M:PJMC]COMTEX = GZINSPJMTH.TIMENT(ICOLLIN).PTECOMTEX
    When "PTEAFF"
      [M:PJMC]DESTEX = GZINSPJMTH.TIMENT(ICOLLIN).PTEDESTEX
      [M:PJMC]COMTEX = GZINSPJMTH.TIMENT(ICOLLIN).PTECOMTEX
    When "PJOPE1"                                                                                           # Issue X3-15943 - 2017-04-20 by SINGC
      [M:PJMC]DESTEX = GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(ICOLLIN).POALGDES # Issue X3-15943 - 2017-04-20 by SINGC
      [M:PJMC]COMTEX = GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(ICOLLIN).POALGCOM # Issue X3-15943 - 2017-04-20 by SINGC
    When Default
  Endcase
  Affzo [M:PJMC]1-99
Return

