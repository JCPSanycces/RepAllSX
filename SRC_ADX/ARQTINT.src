#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################### 
##  Interruption d'une requête  
####################################################################### 

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Integer REQUETE , IRQT , GRPNUM
REQUETE = val(PARAM(1))
If REQUETE=0 : FIN = 1 : Return : Endif
Read [ABR]NUMREQ = REQUETE
If fstat : FIN = 1 : Return : Endif
IRQT = find(REQUETE,[M:ABR1]NUMREQ(0..[M:ABR1]NBLIG-1))-1
If IRQT<0 : FIN = 1 : Return : Endif
If [M:ABR1]FLAG(IRQT)<>2 : FIN = 1 : Return : Endif
Return

$EXEC
GRPNUM = 0
Call DEBTRANS From GLOCK 
Gosub TR_INTERR 
If GOK<1 : Return : Endif
[M:ABR1]FLAG(IRQT) = 5
Affzo [M:ABR1]FLAG(IRQT) 
If GRPNUM<>0
 For I=1 To [M:ABR1]NBLIG
  If [M:ABR1]NUMGRP=GRPNUM & [M:ABR1]FLAG(I-1)=4
   [M:ABR1]FLAG(I-1) = 6
   [M:ABR1]DFIN(I-1) = date$
   [M:ABR1]HFIN(I-1) = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
   Affzo [M:ABR1]FLAG(I-1) , DFIN(I-1) , HFIN(I-1)
  Endif
 Next I
Endif
Return 
 
$TR_INTERR 
Trbegin [ABR] 

 Readlock [ABR]NUMREQ = [M:ABR1]NUMREQ(IRQT) 
 If fstat=1 
  GOK=-1 : GLOCK="$ABATRQT"-num$([M:ABR1]NUMREQ(IRQT)) : Goto ROLL_INTERR 
 Elsif fstat>=5 
  GOK=0 : Call RSTA("ABR",num$([M:ABR1]NUMREQ(IRQT))) From GLOCK 
  Goto AB_INTERR 
 Endif 
 
 If [F:ABR]FLAG<>2 
  [M:ABR1]FLAG(IRQT) = [F:ABR]FLAG 
  GOK=0 : Goto AB_INTERR 
 Endif 
 
 Update [ABR] 
& Where NUMREQ=[M:ABR1]NUMREQ(IRQT)
& With  FLAG = 5
&     , MOTINT = [M:DIA]MOTINT
&     , USRINT = GUSER
 If fstat 
  GOK=0 : Call RSTA("ABR",num$([M:ABR1]NUMREQ(IRQT))) From GLOCK 
  Goto AB_INTERR 
 Endif 
 
 ## 1: En attente
 ## 2: En cours
 ## 3: Terminée
 ## 4: Bloquée
 ## 5: A tuer
 ## 6: Avortée
 ## 7: Erreur
 ## 8: Hors délai
 ## 9: Warning

 If [F:ABR]NUMGRP<>0
  GRPNUM = [F:ABR]NUMGRP
  Update [ABR] 
& Where NUMGRP=[L]GRPNUM & FLAG=4
& With  FLAG = 6
&     , MOTINT = [M:DIA]MOTINT
&     , USRINT = GUSER
&     , DFIN   = date$
&     , HFIN   = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
  If fstat 
   GOK=0 : Call RSTA("ABR",num$([F:ABR]NUMREQ)) From GLOCK 
   Goto AB_INTERR 
  Endif 
 Endif
 
Commit 
Return 
 
$AB_INTERR 
Rollback 
Return 
 
$ROLL_INTERR 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_INTERR : Endif  
 
