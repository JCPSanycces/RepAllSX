########################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End
 
########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR
mkstat = 2
End
######################################################################################
Subprog AS_CLODAT(VALEUR)
Variable Date    VALEUR
If GMFGCLOSE<> "3" | [M:MFS0]MFGSTA >= 4 | [M:MFS1]MFGTRKFLG < 4 : mkstat = 2 : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS1) 15/11/2004 09:01:50 (SR)
######################################################################################
Subprog C_CLODAT(VALEUR)
Variable Date    VALEUR
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
GMESSAGE = ""
Call STKCTRIPT(VALEUR,[M:MFS0]MFGFCY,"1") From STKLIB
If GMESSAGE <> "": mkstat = 1 : End : Endif
GCLODAT = VALEUR
End


