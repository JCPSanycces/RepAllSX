#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 25 Mars      2013 12:15:18
# Moulinette pour modification de la liste gauche de l'objet SOH
# FQ88836
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN15: Wrong text for DLVSTA field in the left list") From LECFIC
  Call EXE_UTIVEN15(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIVEN15(APPLI)
 Value Char APPLI
  If clalev([F:ZAOL]) : Close Local File [ZAOL] : Endif
  Local File =APPLI+".AOBJLST" [ZAOL]
  Call ECR_TRACE("UTIVEN15: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIVEN15
  Call ECR_TRACE("UTIVEN15: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIVEN15
  Trbegin [ZAOL]

  Read [F:ZAOL]AOL0="SOH"
  If fstat
   Call ECR_TRACE("Error : The SOH object dont exit.",-1) From GESECRAN
   GOK=0 : Goto AB_UTIVEN15
  Endif
  If [F:ZAOL]SELZON(5)<>"DLVSTA" : Rollback : Return : Endif
  [F:ZAOL]SELINT(5)=23637
  Rewrite [F:ZAOL]
  If fstat
   GOK=0
   Call ECR_TRACE("   Error Rewrite [F:ZAOL] fstat="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("   Left list of the SOH object modified",0) From GESECRAN
  Endif
  If !GOK Then
    Goto AB_UTIVEN15
  Else
    Commit
  Endif
  Call VALID("SOH",APPLI,0,GOK) From VALOBJ
  If !clalev([F:ZAWI]) : Local File =APPLI+".AWINDOW" [ZAWI] : Endif
  Call ECR_TRACE("Generated windows validation",0) From GESECRAN
  For [F:ZAWI] Where OBJ="SOH"
   Call ISWINDOWOK(APPLI,[F:ZAWI]WIN) From INTRUTILB 
  Next 
Return

$AB_UTIVEN15
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIVEN15(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIVEN15(APPLI)
End


