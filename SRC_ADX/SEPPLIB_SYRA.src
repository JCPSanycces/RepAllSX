######################################################################################

# Determine if the document payment terms are linked to a payment method marked
#  for Sage Exchange processing
####################################################################################
Funprog SEPP_DOC(PTE)
Value Char PTE

  # Syrapedia compatible FGR 19/06/2013
  Local File TABPAYTERM [TPT]
  Local File TABPAM     [TAM]
  Link [TPT] With [TAM]TAM0=PAM;LEG As [LTPT]
&            Where PTE=[L]PTE & (LEG=GCURLEG | LEG="") & PAMTYP=1 & [TAM]SEPFLG=2
  Look [LTPT] First
End !fstat

# Remaining amount, sans markup
####################################################################################
Funprog GET_REMAIN_AMT_NMU(VCRTYP,VCRNUM)
Value Integer VCRTYP
Value    Char VCRNUM

Local Decimal AMT,TAXAMT

  Call GET_REMAIN_AMT_TAX(VCRTYP,VCRNUM,AMT,TAXAMT,0)
End AMT

####################################################################################
Subprog GET_REMAIN_AMT_TAX(VCRTYP,VCRNUM,AMT,TAXAMT,MARKUP)
Value    Integer VCRTYP
Value    Char VCRNUM
Variable Decimal AMT
Variable Decimal TAXAMT
Value    Integer MARKUP

  # If verifying card, set auth amt as verif amt
  If [F:SEU]POSTAUT=3
    AMT = [F:SER]VERIFAMT
    TAXAMT = 0
    End
  Endif
  # Local menu 2097
  Case VCRTYP
    When 2  # Order
      # Order amount
      Local File SORDER [SOH]
      Read [SOH]SOH0=VCRNUM
      AMT  = [F:SOH]ORDINVATI - func GET_SEUAMT2([F:SOH]SOHNUM)
      If MARKUP Then
        AMT += func AUTH_MARKUP([F:SOH]ORDINVNOT)
      Endif
      If [F:SEU]SOHNUM="" Then
        [F:SEU]SOHNUM = [F:SOH]SOHNUM
      Endif
      If TAXAMT=0 Then
        TAXAMT = [F:SOH]ORDATI - [F:SOH]ORDNOT
      Endif
    When 4  # Shipment
      Local File SDELIVERY [SDH]
      Read [SDH]SDH0=VCRNUM
      AMT  = [F:SDH]DLVINVATI - func GET_SEUAMT2([F:SDH]SDHNUM)
      If MARKUP
        AMT += func AUTH_MARKUP([F:SDH]DLVINVNOT)
      Endif
      If [F:SEU]SOHNUM="" Then
        [F:SEU]SOHNUM = [F:SDH]SOHNUM
      Endif
      If TAXAMT=0 Then
        TAXAMT = [F:SDH]DLVATI - [F:SDH]DLVNOT
      Endif
    When 5,18,40,41  # Sales or Customer - Invoice or Credit
      Local File SINVOICE [SIH]
      Read [SIH]SIH0=VCRNUM
      AMT = [F:SIH]AMTATI - func GET_SEUAMT2([F:SIH]NUM)
      # add markup for post-order auth
      If [F:SEU]POSTAUT=2 & [F:SEU]STAFLG<3
        If MARKUP Then
          AMT += func AUTH_MARKUP([F:SIH]AMTNOT)
        Endif
      Endif
      If [F:SEU]SOHNUM="" & find(VCRTYP,5,18) Then
        [F:SEU]SOHNUM = [F:SID]SOHNUM
      Endif
      If TAXAMT=0 Then
        TAXAMT = [F:SIH]AMTATI - [F:SIH]AMTNOT
      Endif
    When 50,51 # Payment or Receipt
      Local File PAYMENTH [PYH]
      Read [PYH]PYH0=VCRNUM
      AMT = [F:PYH]AMTCUR - func GET_SEUAMT2([F:PYH]NUM)
  Endcase
  If [F:SEU]SOHNUM<>""  # Subtract amount of prepayments
    AMT -= func CALPRE()
  Endif
End

# find amount against original document, not including current doc
####################################################################################
Funprog GET_SEUAMT2(VCRNUM)
Value    Char    VCRNUM

Local Decimal AMT

  # Syrapedia compatible FGR 19/06/2013
  Local File SEAUTH [SEU2]
  For [SEU2] Where find(STAFLG,3,6,7) & find([L]VCRNUM,SOHNUM,SDHNUM,SIHNUM,VCRNUM)
    If [F:SEU2]STAFLG=3 & VCRNUM<>[L]VCRNUM
      AMT += [F:SEU2]AUTAMT
    Elsif find([F:SEU2]STAFLG,6,7)
      AMT += [F:SEU2]PAYAMT
    Endif
  Next
End AMT

# Authorization Markup
####################################################################################
Funprog AUTH_MARKUP(IAMT)
Value Decimal IAMT
End ar2(IAMT * [F:SER]AUTPCT / 100)  # Round to 2 decimal places

# Calculate Prepayment amount
####################################################################################
Funprog CALPRE()

Local Decimal PREAMT

  # Syrapedia compatible FGR 19/06/2013
  Local File GACCDUDATE [DUD]
  Local File PAYORDER [PYO]
  For [DUD]DUD0 Where TYP="*SO" & NUM=[F:SEU]SOHNUM & SENINS=2 & DUDDAT<=date$
    For [PYO] Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
      PREAMT += [F:PYO]DUDPAYAMT
    Next
  Next
  If dim([F:SIH]ACCNUM)>0
    For [PYO] Where INVNUM=[F:SIH]ACCNUM
      PREAMT += [F:PYO]DUDPAYAMT
    Next
  Endif
End PREAMT

####################################################################################
Funprog GET_SEUAMT(VCRTYP,VCRNUM,STAFLG)
Value    Integer VCRTYP
Value    Char    VCRNUM
Value    Integer STAFLG

Local Decimal AMT

  # Syrapedia compatible FGR 19/06/2013
  Local File SEAUTH [SEU2]
  If [L]STAFLG<3 Then
    [L]STAFLG = 3
  Endif
  For [SEU2] Where VCRTYP=[L]VCRTYP & VCRNUM=[L]VCRNUM & STAFLG=[L]STAFLG
    If STAFLG=3
      AMT += [F:SEU2]AUTAMT
    Elsif STAFLG=6
      AMT += [F:SEU2]PAYAMT
    Endif
  Next
End AMT
