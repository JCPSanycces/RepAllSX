#<AdxTL>@(#)3.0.0.0 $Revision$
$AMIGPORT

# Declaration for the log file generation
Local Instance MYLOG Using C_ALOG
Local Char LOGFILE_NAME(250)

# Identifier of the portal to be analyzed
Local Char IDENTIFIER(100)

# Clob result and error code
Local Integer ERR
Local Clbfile WCLOB(12)
Local Decimal TIM

# Http header and body sent as response
Local Clbfile RESHEAD(1)
Local Clbfile RESBODY(1)

# Node arrays to get the details of the integration return
Local Instance  NODES(1..) Using C_ASYRJSO
Local Instance  NODE  Using C_ASYRJSO

# Counts of items menu, portal, and dashboards created or updated
Local Integer NB1,NB2,NB3

# Array storing the messages returned by the integration
Local Integer INDEX
Local Integer SEVERTAB(1..)
Local Char MESSTAB(250)(1..)
Local Char MESSA(200) : Local Integer STAVAL
Local Integer TRACEDET : TRACEDET=0
# Start timing
#  Dbgaff
  TIM=val(timestamp$)

# Start a logfile
  MYLOG=NewInstance With C_ALOG
  ERR=fmet MYLOG.ABEGINLOG("Portal migration")
  LOGFILE_NAME=fmet MYLOG.AGETNAME

  If this.TYP=mess(2,63,1) : # User
    IDENTIFIER=this.CLE
  Else
    IDENTIFIER="_"+this.CLE : # Trade code
  Endif

# Call the X3 meta data extraction
  Call GENERATION(IDENTIFIER,MYLOG,WCLOB,ERR,NB1,NB2,NB3)

# Local log
  If TRACEDET=2
    If filinfo("/home/dbopp/tmp",0)>0
      Openo "/home/dbopp/tmp/myprocess.json",0 Using [JSO9]
      Wrseq WCLOB Using [JSO9]
      Openo Using [JSO9]
    Elsif filinfo("/home/dom/tmp",0)>0
      Openo "/home/dom/tmp/myprocess.json",0 Using [JSO9]
      Wrseq WCLOB Using [JSO9]
      Openo Using [JSO9]
    Endif
  Endif

  If this.ObjectType="C_AMIGPORT"
   Gosub END_AMIGPORT
  Elsif this.ObjectType="C_AMIGDASH"
   Gosub END_AMIGDASH
  Endif

Return

$END_AMIGDASH
this.CLOB = WCLOB
Return


$END_AMIGPORT
# Call the javascript import procedure
  If ERR=0
    STAVAL = func IMPORT(IDENTIFIER, WCLOB, RESHEAD, RESBODY)
    #STAVAL=val(func AJSONLIB.GET_PROP(RESHEAD,"statusCode"))
    MESSA=func AJSONLIB.GET_PROP(RESHEAD,"message")
    If STAVAL=200
      ERR=fmet this.ASETERROR("", func AFNC.MES1(mess(30,146,1),num$((val(timestamp$)-TIM)/1000)),[V]CST_ASUCCESS)
      #ERR=fmet this.ASETERROR("", func AFNC.MES3(mess(32,146,1),num$(NB1),num$(NB2),num$(NB3)),[V]CST_AINFO)
      # Handle the errors returned by the javascript procedure
      ERR = func ASYRJSONPARSE.PARSEJSON(GACTX,"JSO",RESBODY,NODES,NODE)
    Else
      If len(RESBODY)=0
        ERR=fmet this.ASETERROR("", func AFNC.MES2(mess(31,146,1),num$(STAVAL),MESSA),[V]CST_AERROR)
      Else
        # Handle the errors returned by the javascript procedure
        ERR = func ASYRJSONPARSE.PARSEJSON(GACTX,"JSO",RESBODY,NODES,NODE)
      Endif
    Endif
  Endif

  INDEX=1

  If ERR=0
    If NODE<>null
      Call PARSENODE(NODE, INDEX, SEVERTAB, MESSTAB)
    Endif
  Elsif ERR = 4
   ERR=fmet this.ASETERROR("","An error has occured while parsing import diagnoses",[V]CST_AWARNING)
  Else
   ERR=fmet this.ASETERROR("","Error #"-num$(ERR)-"found",ASTATUS)
  Endif

  For I = 1 To maxtab(SEVERTAB)
    ERR=fmet this.ASETERROR("",MESSTAB(I),SEVERTAB(I))
  Next

Return

#########################################################
# IMPORT
# --------------
# This action calls node.js module
# module = 'syracuse-import/lib/jsonImport'
# function = 'jsonImportFromJson'
# arguments = options
# mode = 'wait'
# This action must store new dashboard in Syracuse.
#########################################################
Funprog IMPORT(USER, WCLOB, RESHEAD, RESBODY)
Value Char USER()
Value Clbfile WCLOB()
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

#Local Blbfile BYTES(12)
#Local Clbfile CLB(0)
#Local Integer COUNT

#If adxmac(-2) = "po037285.sagefr.adinternal.com" : Dbgaff : Endif
If freemem/1024 < 16000
  maxmem = int((maxmem-freemem)/1024) + 16000
Endif

Local Char MODULE(100)
Local Char FONCTION(30)
Local Char MODE(10)
Local Clbfile ARGUMENTS(0)
Local Char ENCODINGS(40)
Local Integer CALLBACKINDEX
Local Char RETURNS(50)
Local Char RETURNS_ENC(3)

Local Clbfile OPT(0)
  OPT = '{"importMode":"update","createSession":true}'
  MODULE = 'syracuse-import/lib/jsonImport'
  FONCTION = 'jsonImportFromJson'
  MODE = 'wait'
  ARGUMENTS = '"' + USER + '",' + WCLOB + ',' + OPT
  ENCODINGS = '0,0,0'
  CALLBACKINDEX = 0
  RETURNS = ''
  RETURNS_ENC = '0'

  Local Integer STATUSCODE
  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, CALLBACKINDEX, RETURNS, RETURNS_ENC, RESHEAD, RESBODY)

End STATUSCODE

#------------------------------------------------#
# PARSENODE
#------------------------------------------------#
# 1 Info
# 2 Warning
# 3 Error
# 4 Fatal error
#---------------------------#
Subprog PARSENODE(NODE, INDEX, SEVERTAB, MESSTAB)
Variable Integer INDEX
Variable Integer SEVERTAB(1..)
Variable Char MESSTAB()(1..)
Variable Instance  NODE  Using C_ASYRJSO

Local Integer SEVERITY
Local Char NODE_CNT(255)
  If "" <> NODE.PRO

    If NODE.PRO = "$severity" and NODE.NEX.PRO = "$message"

      Case fmet NODE.AGETCNT
         When '"info"' : SEVERITY=[V]CST_AINFO
         When '"warning"' : SEVERITY=2
         When '"error"' : SEVERITY=[V]CST_AERROR
         When Default : SEVERITY=0
      Endcase

      SEVERTAB(INDEX) = SEVERITY
      NODE_CNT=fmet NODE.NEX.AGETCNT
      MESSTAB(INDEX) = seg$(NODE_CNT, 2, len(NODE_CNT)-1)
      INDEX = INDEX + 1

    Endif
  Endif

  If null <> NODE.SUB
      Call PARSENODE(NODE.SUB, INDEX, SEVERTAB, MESSTAB)
  Endif

  If null <> NODE.NEX
      Call PARSENODE(NODE.NEX, INDEX, SEVERTAB, MESSTAB)
  Endif

End

Subprog WRITEFILE(WCLOB, FICJSON)
Value Clbfile WCLOB()
Value Char FICJSON()

  Openo FICJSON,0 Using [JSO]
  Iomode adxifs "" Using [JSO]
  Iomode adxirs "" Using [JSO]
  Wrseq WCLOB Using [JSO]
  Openo Using [JSO]
End


# Tool for migrating the V6 portal meta data
# through generation of an import file that will be managed by Syracuse
# The main parameter is the user code

Subprog GENERATION(USER,MYLOG,WCLOB,ERR,NBM,NBP,NBD)
Value Char USER()
Variable Instance MYLOG Using C_ALOG
Variable Integer ERR
Variable Integer NBM,NBP,NBD
Variable Clbfile WCLOB() : # The import file contents


##  FOR DEBUGGING PURPOSES
Local Integer MULTI_TITLE : MULTI_TITLE=0 : # 1 if multi-language titles (doesn't work yet !!!)
Local Integer JSONEMB : # 1 if JSON embedded (for debug purposes)
JSONEMB=0


# Variables declaration
Local Integer NBL      : # The number of languages
Local Integer IL, TID
Local Integer I,J,K,L,M,N

Local Char CRLF(5) : CRLF=chr$(10)
Local Char CHAINE(250)

# Portal organization page variables
Local Char CODMET(4)
Local Integer NBPORT            : # Total number of portlet entries found
Local Integer NBONG
Local Char PORTLET(150)(1..200)
Local Libelle NUMONG(1..200)
Local Libelle NUMCOL(1..200)
Local Libelle NUMPOR(1..200)
Local Char TITPOR(100)(1..200)
Local Char PARAMPORT(200)(1..200,1..5)
Local Char VALPAR(100)(1..200,1..5)
Local Char USR_PREFIX(100)
Local Char ADM_PREFIX(100)
Local Char MEN_PREFIX(100)
Local Char PRD_PREFIX(100)
Local Integer MAXPROF
Local Char PROFIL(20)
Local Integer CUR_LEVEL : # Current level for menu generation

# Tables declaration
  If clalev([ATX])  : LogicClose File [ATX]  : Endif : Local File ATEXTE
  If clalev([AFC])  : LogicClose File [AFC]  : Endif : Local File AFONCTION
  If clalev([ADS])  : LogicClose File [ADS]  : Endif : Local File ADOSSIER
  If clalev([TLA])  : LogicClose File [TLA]  : Endif : Local File TABLAN
  If clalev([APF])  : LogicClose File [APF]  : Endif : Local File APROFIL
  If clalev([AMU])  : LogicClose File [AMU]  : Endif : Local File AMENUSER
  If clalev([AUS])  : LogicClose File [AUS]  : Endif : Local File AUTILIS
  If clalev([AOB])  : LogicClose File [AOB]  : Endif : Local File AOBJET
  If clalev([AZZ])  : LogicClose File [AZZ]  : Endif : Local File ATEXTE [AZZ]
  If clalev([AZS])  : LogicClose File [AZS]  : Endif : Local File APLSTD [AZS]
  If clalev([ACB])  : LogicClose File [ACB]  : Endif : Local File ACLOB
  If clalev([AME])  : LogicClose File [AME]  : Endif : Local File AMETUTI
  If clalev([ACLA]) : LogicClose File [ACLA] : Endif : Local File ACLASSE
  If clalev([ASW])  : LogicClose File [ASW]  : Endif : Local File ASHW
  If clalev([APV])  : LogicClose File [APV]  : Endif : Local File APTLVW
  If clalev([PS2])  : LogicClose File [PS2]  : Endif : Local File PARSTA2
  If clalev([ALH])  : LogicClose File [ALH]  : Endif : Local File ALISTEH
  If clalev([APR])  : LogicClose File [APR]  : Endif : Local File APROCESSUS
  If clalev([AXX])  : LogicClose File [AXX]  : Endif : Local File ATEXTRA
  If clalev([ACV])  : LogicClose File [ACV]  : Endif : Local File ACTIV
  If clalev([ATB])  : LogicClose File [ATB]  : Endif : Local File ATABLE
  If clalev([APU])  : LogicClose File [APU]  : Endif : Local File APORTUSER
  If clalev([APA])  : LogicClose File [APA]  : Endif : Local File APORTTAB
  If clalev([AMO])  : LogicClose File [AMO]  : Endif : Local File APORTMOD
  If clalev([ADW])  : LogicClose File [ADW]  : Endif : Local File ADOVAL

# Search the product type in order to define the right prefix (Dominique Bopp, added Nov 12, 2013)
Local Char APPLICATION_CODE(100),CONTRACT_CODE(100)

  APPLICATION_CODE='"application":"'
  CONTRACT_CODE='"contract":"'
  Read [ADW]ADW0 = "";"";"TYPDOS"
  Case val([ADW]VALEUR)
    When 0,1       : CONTRACT_CODE+='erp"'  : APPLICATION_CODE+='x3"'  : PRD_PREFIX="STD" : # Supervisor, X3
    When 2         : CONTRACT_CODE+='erp"'  : APPLICATION_CODE+='x3"'  : PRD_PREFIX="STD" : # Geode
    When 3         : CONTRACT_CODE+='hrm"'  : APPLICATION_CODE+='x3"' : PRD_PREFIX="HRM" : # HRM
    When 4         : CONTRACT_CODE+='erp"'  : APPLICATION_CODE+='x3"'  : PRD_PREFIX="STD" : # Fixed asset (BOB)
    When Default   : CONTRACT_CODE+='erp"'  : APPLICATION_CODE+='x3"'  : PRD_PREFIX="STD" : # Unknown
  Endcase

# Store the list of languages for generation, as well as their iso code
Local Char TABLAN(3)(1..dim([ADS]LAN)), ISOLAN(10)(1..dim([ADS]LAN))
Local Integer NBL
Local Char LANGUE(20)

  Read [ADS]DOSSIER=GACTX.AFOLDER
  If fstat : ERR=2 : End : Endif
  # If the iso language code is not defined, ignore the language
  For [TLA] Where find([TLA]LAN,[ADS]LAN(0..[ADS]NBRLAN-1))<>0 and LANISO<>""
    NBL+=1
    # The expected iso language code must be with a dash '-', so replace underscore '_'
    TABLAN(NBL)=[TLA]LAN : ISOLAN(NBL)=tolower([TLA]LANISO)
  Next

  # But if no language is set properly, propose at least English and French !!!
  If NBL=0
    NBL+=1 : TABLAN(NBL)="ENG" : ISOLAN(NBL)="en-us"
    NBL+=1 : TABLAN(NBL)="FRA" : ISOLAN(NBL)="fr-fr"
  Endif

  MAXPROF=nbrecord([AFC])+100

  # Check if the user or the trade code exists, get the menu profile code
  If left$(USER,1)="_"
    [L]CODMET = right$(USER,2)
    USR_PREFIX=right$(USER,2)
    Read [AME]AME0=USR_PREFIX
    ERR=(fstat<>0)
    If ERR : End : Endif
    PROFIL=[AME]PRFMEN
    If PROFIL="" : ERR=2 : End : Endif
    USR_PREFIX="AME_"+GACTX.AFOLDER+"_"+USR_PREFIX+"_"
  Else
    Read [AUS]CODUSR=USER
    ERR=(fstat<>0)
    If ERR : End : Endif
    [L]CODMET = [AUS]CODMET
    If [AUS]PRFMEN<>""
      PROFIL=[AUS]PRFMEN
      Raz [AME]
    Elsif CODMET<>""
      Read [AME]AME0=[AUS]CODMET
      PROFIL=[AME]PRFMEN
    Else
      ERR=2 : ERR
    Endif
    USR_PREFIX="USR_"+GACTX.AFOLDER+"_"+USER+"_"
  Endif
  Read [APF]APF1=PROFIL
  ERR=(fstat<>0)
  If ERR : End : Endif

# Get the maximum reasonable dimension for menu buffer
  Filter [AMU] Where CODPRF=PROFIL
  MAXPROF=rowcount([AMU])+500
  Filter [AMU]

Local Integer NBFONC, LEV       : # Total number of entry menu found
Local Integer NBFONCINI         : # Pointer on first item of a menu
Local Integer FIRSTFAV          : # First entry corresponding to favorites
Local Libelle TYPEFONC(1..MAXPROF),NIVFONC(1..MAXPROF),MAXNIVFONC
Local Libelle DUPLICATES(1..MAXPROF) : # set to 1 if the entry was already found
Local Char CODEFONC(30)(1..MAXPROF),PARAM(100)(1..MAXPROF),MENUFONC(20)(1..MAXPROF),TITREFONC(100)(1..MAXPROF)
Local Char FONCMEN(30)(1..100),PARAMEN(100)(1..100)
Local Char TEXTOTRANS(250)
Local Integer IFCONVERGENCE_ONLY : # If set to 2, the generation creates only convergence links
Local Integer LOCALIZATIONS(0..),NB_LOCALIZATIONS

Local Char MENU_STACK(30)(1..100) : # List of menus at level 2 that have direct level 3 functions attached
Local Integer NB_STACK
Local Integer CONTENT : # For defining the content section (authoring)

# Manage the super user profile code
Local Char GSUPERX3(20)
  GSUPERX3 = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","ADMUSR")
  If GSUPERX3="" : GSUPERX3="ADMIN" : Endif
  ADM_PREFIX="USR_"+GACTX.AFOLDER+"_"+GSUPERX3+"_"
  MEN_PREFIX="USR_"+GACTX.AFOLDER+"_"+PROFIL+"_"

# Read the convergence flsg
  IFCONVERGENCE_ONLY=fmet GACTX.APARAM.AGETUSERVALNUM("ACONVONLY")

# Indicator set to 1 if the menu is the same than the standard ADMIN menu
Local Libelle STDMEN(1..MAXPROF)

Local Char IDFONC(50)(1..MAXPROF)
# FIRST STEP : Fill the buffers

# Get the definition of portal, returns ERR=3 if an error occurs
  Call GET_POR(USER,NBPORT,PORTLET,NBONG,NUMONG,NUMCOL,TITPOR,PARAMPORT,MYLOG,ERR)
  If ERR : End : Endif

# Read the standard profile list
  Gosub READ_MENGEN

# Read the favorite list
  FIRSTFAV=NBFONC
# Gosub READ_MENFAV
  NBM=NBFONC-1

# SECOND STEP : Generate the JSON file

# Write the header
  Call HEADER(WCLOB,LANGUE) : # includes the opening "$items" : [ group

# Flag for adding "," in the JSON list
  L=0

# Only for ADMIN, generate the menu entries
#  If USER=GSUPERX3 : # (modif 4 June)
    Gosub GENE_MENULIST
#  Endif: # (modif 4 June)

  Gosub GENE_PORTLIST

  Gosub GENE_PORTLET

  Gosub GENE_PAGES

# Close the portlet array
  Append WCLOB,"]"+CRLF


# Close the section
  Append WCLOB,"}"+CRLF

# Close the logfile
  ERR=fmet MYLOG.AENDLOG

End


#
# Subprograms filling the fonction hierarchy buffers by analyzing the menus
# Routine loading the user's menu

$READ_MENGEN
  MAXNIVFONC=1
  NBFONC=1 : CODEFONC(1)="MENU" : PARAM(1)=[APF]MENDEP : NIVFONC(1)=1 : TYPEFONC(1)=1
  STDMEN(1)=(PROFIL=GSUPERX3)
  DUPLICATES(NBFONC)=0
  J=1

# First pass : fill the menu table
  While J<=NBFONC
    If TYPEFONC(J)=1
      STDMEN(J)=(PROFIL=GSUPERX3)
      For [AMU]MENCOD Where CODPRF=[APF]CODPRF and MENU=PARAM(J)
        NO_FONC=0
        Read [AFC]CODINT=[AMU]FONCTION
        If fstat
          NO_FONC=1
        Elsif [AFC]CODACT<>""
          Read [ACV]CODACT=[AFC]CODACT
          If fstat<>0 or [ACV]FLACT=1
            NO_FONC=1
          Endif
        Endif
        If NO_FONC=0
          NBFONC+=1 : CODEFONC(NBFONC)=[AMU]FONCTION : NIVFONC(NBFONC)=NIVFONC(J)+1 : MENUFONC(NBFONC)=PARAM(J)
          MAXNIVFONC=max(MAXNIVFONC,NIVFONC(J)+1)
          K=0
          If CODEFONC(NBFONC)="MENU"
            TYPEFONC(NBFONC)=1
            PARAM(NBFONC)=[AMU]CODMEN
          Else
            TYPEFONC(NBFONC)=2
            If CODEFONC(NBFONC)="SYSTEME"
              PARAM(NBFONC)=[AMU]ORDSYS
            Else
              Read [AFC]CODINT=CODEFONC(NBFONC)
              K=find(CODEFONC(NBFONC),CODEFONC(1..NBFONC-1))
              If fstat=0 and [AFC]VALEUR(0)="#"
                PARAM(NBFONC)=[AMU]CODMEN
              Endif
            Endif
          Endif
          DUPLICATES(NBFONC)=0
          If K
            If PARAM(K)=PARAM(NBFONC)
              DUPLICATES(NBFONC)=1
            Endif
          Endif
          TITREFONC(NBFONC)=""
          If [AMU]LIBMENU
            Read [AZZ]NUMERO=GACTX.LAN;[AMU]LIBMENU
            If fstat : Raz [AZZ] : Endif
          Else
            Read [AFC]CODINT=CODEFONC(NBFONC)
            If fstat=0
              Read [AZZ]NUMERO=GACTX.LAN;[AFC]LIBMENU
            Endif
            If fstat : Raz [AZZ] : Endif
          Endif
          If [AZZ]NUMERO
            TITREFONC(NBFONC)="@"+num$([AZZ]NUMERO)
          Else
            TITREFONC(NBFONC)=[AMU]INTIT
          Endif
          TITREFONC(NBFONC)+=string$(vireblc(TITREFONC(NBFONC),2)="",CODEFONC(NBFONC)-PARAM(NBFONC))
        Endif
      Next
    Endif
    J+=1
  Wend

Return


#
# ROUTINE FILLING THE CLOB CONTAINING THE RESULT CLOB with the menus
# L counts the number of entries written

GENE_MENULIST
  K=0

# First loop on the users menus (level 2 only : goes on a portlet except if direct functions)
  For J=1 To FIRSTFAV-1
    Gosub ASSIGN_IDFONC
    If NIVFONC(J)=2
      # Menus
      If TYPEFONC(J)=1
        # an additional entry will be created
        L+=1
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"menuItem",'
        Append WCLOB,'"linkType":"$dashboard",'

        # Add the common definitions
        Append WCLOB,'"dashboard":"'+IDFONC(J)+'",'
        Append WCLOB,'"code":"'+IDFONC(J)+'",'
        TEXTOTRANS=TITREFONC(J): Gosub TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,"}"
      Else
        Gosub LNKFUNC
      Endif
    Endif
  Next J

# Loop to search if functions exist at third level of the hierarchy
# If they exist, prepare a list of the concerned menu to generate later portlets
  For J=1 To FIRSTFAV-1
    If NIVFONC(J)=3 and TYPEFONC(J)=1 and find(MENUFONC(J),MENU_STACK(1..NB_STACK))=0
      NB_STACK+=1
      MENU_STACK(NB_STACK)=MENUFONC(J)
    Endif
  Next J

# Loop to assign IDFONC for the favorites (fixes the issue #1055)
  For J=FIRSTFAV To NBFONC
    Gosub ASSIGN_IDFONC
  Next J

# Second loop on the final functions (not including favorites)
  For J=1 To FIRSTFAV-1
    If TYPEFONC(J)=2 and ((NIVFONC(J)>2) or J>=FIRSTFAV)and DUPLICATES(J)=0
      Gosub LNKFUNC
    Endif
  Next J
Return

# IDFUNC assignment
$ASSIGN_IDFONC
  If TYPEFONC(J)=1
    IDFONC(J)=string$(STDMEN(J)=1,ADM_PREFIX)+string$(STDMEN(J)=0,MEN_PREFIX)+PARAM(J)
  Elsif CODEFONC(J)>="X"
    IDFONC(J)="SPE_"+GACTX.AFOLDER+"_"+CODEFONC(J)+string$(PARAM(J)<>"","_"+func STRG(PARAM(J)))
  Elsif PARAM(J)<>""
    IDFONC(J)="PAR_"+GACTX.AFOLDER+"_"+CODEFONC(J)+"_"+func STRG(PARAM(J))
  Else
    IDFONC(J)=PRD_PREFIX+CODEFONC(J)
  Endif
Return


# Assignment of titles and description
$TITLE_TRANS
  Append WCLOB,'"title":{'
  For IL=1 To NBL
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+func TRADTXT(TABLAN(IL),TEXTOTRANS)+'"'
  Next IL
  Append WCLOB,"}"
Return

$DESC_TRANS
  Append WCLOB,'"description":{'
  For IL=1 To NBL
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+func TRADTXT1(TABLAN(IL),TEXTOTRANS)+'"'
  Next IL
  Append WCLOB,"}"
Return

$VIG_TITLE_TRANS
  Append WCLOB,'"title":{'
  For IL=1 To NBL
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+func TRADINT(TABLAN(IL),"APORTVIG","INTIT1",TEXTOTRANS)+'"'
  Next IL
  Append WCLOB,"}"
Return

$DESC_FUNC_TRANS
  Append WCLOB,'"description":{'
  For IL=1 To NBL
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+TEXTOTRANS+'"'
  Next IL
  Append WCLOB,"}"
Return

# The same than TRADTXT, but empty string is possible
Funprog TRADTXT1(LAN,CHAINE)
Value Char LAN(),CHAINE()
If CHAINE=""
  End ""
Else
  End func TRADTXT(LAN,CHAINE)
Endif
End

# Handle constants or localized messages, don't allow empty texts
Funprog TRADTXT(LAN,CHAINE)
Value Char LAN(),CHAINE()
Local Integer I,J,K
Local Char NUMBER(30)
  I=instr(1,CHAINE,"@")
  If I
    NUMBER=right$(CHAINE,I+1)
    K=instr(1,NUMBER,",")
    If K=0
      Read [AZZ]NUMERO=LAN;val(NUMBER)
      If fstat : Raz [AZZ] : Endif
      CHAINE=[AZZ]TEXTE
    Else
      Read [AZS]CLE=val(left$(NUMBER,K-1)); val(right$(NUMBER,K+1));LAN
      If fstat : Raz [AZS] : Endif
      CHAINE=[AZS]LANMES
    Endif
  Endif

  # Handle empty texts and replace them by "(empty)" (in the right language)
  If CHAINE=""
    Read [AZS]CLE=147;23;LAN
    End "("+[AZS]LANMES+")"
  Endif

End escJson(CHAINE)

# Check the translation, use English by default, otherwise nothing
Funprog TRADINT(LAN,TABLETRAD,CHAMPTRAD,CLETRAD)
Value Char LAN(),TABLETRAD(),CHAMPTRAD(),CLETRAD()
Read [AXX]AXX0=TABLETRAD;CHAMPTRAD;LAN;CLETRAD;""
If fstat=0
  If [AXX]TEXTE="" : End func TRADTXT(LAN,[AXX]TEXTE) : Endif
  End escJson([AXX]TEXTE)
Endif
Read [AXX]AXX0=TABLETRAD;CHAMPTRAD;"ENG";CLETRAD;""
If fstat=0
  End escJson([AXX]TEXTE)
Endif
End ""

# Generates an entry item for a function
$LNKFUNC

# First of all, check if a representation has been found (K=1)
  K=0
  If left$(CODEFONC(J),3)="GES" and IFCONVERGENCE_ONLY<>2
    Read [AFC]CODINT=CODEFONC(J)
    CHAINE=vireblc([AFC]VALPAR(0),2)
    If pat(CHAINE,'"*"')
      Read [AOB]ABREV=seg$(CHAINE,2,len(CHAINE)-1)
      K=(fstat=0)
    Endif
    If K
      K=0
      For [ACLA] Where TYPCLA=2 and TABREF=[AOB]NOMFIC
        K=1 : Break
      Next
      If K
        K=0
        For [ASW] Where CODCLA=[ACLA]CODCLA
          K=1 : Break
        Next
      Endif
    Endif
  Endif

# Now let's generate (and add 1 to the number of entries created)
  L+=1
  Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"menuItem",'

  # First define the type of function
  If K or (find(CODEFONC(J),"EXEALH","CONSSTA") and PARAM(J)<>"")
    Append WCLOB,'"linkType":"$representation",'
  Else
    Append WCLOB,'"linkType":"$function",'
  Endif

  # The code of the function depends on the case
  Append WCLOB,'"code":"'
  Append WCLOB,IDFONC(J)+'",'

  # Add the common definitions
  TEXTOTRANS=TITREFONC(J): Gosub TITLE_TRANS
  Append WCLOB,','
  TEXTOTRANS=CODEFONC(J) : Gosub DESC_FUNC_TRANS

  # If a class and a representation where found, call them
  If K
    Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
    Append WCLOB,'"representationRef":{'
    Append WCLOB,'"entity":"'+[ACLA]CODCLA+'",'
    Append WCLOB,'"representation":"'+[ASW]CODREP+'"},'
    Append WCLOB,'"facet":"$query"}'
  Else
    Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
    Case CODEFONC(J)
      When "EXEALH" : # Requester, a Syracuse function
        If PARAM(J)=""
          Append WCLOB,'"fusionFunction":"'+CODEFONC(J)+'",'
          Append WCLOB,'"fusionKey":"'+PARAM(J)+'"' : # Will be replaced later
          Append WCLOB,"}"
        Else
          Append WCLOB,'"representationRef":{"entity":"QUERY('+"'"+PARAM(J)+"'"+')",'
          Append WCLOB,'"representation":"QUERY~'+PARAM(J)+'~1"},'
          Append WCLOB,'"facet":"$query"}'
        Endif
      When "CONSSTA" : # Statistical inquiry, a Syracuse function
        If PARAM(J)=""
          Append WCLOB,'"fusionFunction":"'+CODEFONC(J)+'",'
          Append WCLOB,'"fusionKey":"'+PARAM(J)+'"' : # Will be replaced later
          Append WCLOB,"}"
        Else
          Append WCLOB,'"representationRef":{"entity":"STATS('+"'"+PARAM(J)+"'"+')",'
          Append WCLOB,'"representation":"STATS~'+PARAM(J)+'"},'
          Append WCLOB,'"facet":"$cube"'
          Append WCLOB,"}"
        Endif
      When Default : # Fusion link
        Append WCLOB,'"fusionFunction":"'+CODEFONC(J)+'",'
        Append WCLOB,'"fusionKey":"'+PARAM(J)+'"' : # Will be replaced later
        Append WCLOB,"}"
    Endcase
  Endif
Return

# Write the portlet menu list
$GENE_PORTLIST

# First step : generate the portlet in the main portal
# Done only if not ADMIN
  If USER<>GSUPERX3
    For I=1 To NBPORT
      Case PARAMPORT(I,1)
        When "$ext"
          L+=1
          Append WCLOB,string$(L>1,','+CRLF)+' {"$type":"menuItem",'
          Append WCLOB,'"linkType":"$external",'
          Append WCLOB,'"code":"'+PORTLET(I)+'",'
          TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
          Append WCLOB,','
          Gosub DESC_TRANS
          Append WCLOB,','
          Append WCLOB,'"externalUrl":"'+func STRG(PARAMPORT(I,2))+'"}'
        When "$rss"
          L+=1
          Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"menuItem",'
          Append WCLOB,'"linkType":"$rss",'
          TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
          Append WCLOB,','
          Gosub DESC_TRANS
          Append WCLOB,','
          Append WCLOB,'"NumberOfItems":'+func STRG(PARAMPORT(I,2))+','
          Append WCLOB,'"Display":'+func STRG(PARAMPORT(I,3))+','
          Append WCLOB,'"externalUrl":"'+func STRG(PARAMPORT(I,4))+'"}'
        When "$menu","$header" : # menus and header are not concerned
        When "$table" : # Tabular representation of statistical inquiry, request, or other types
          # Find out the type of data source
          Read [APV]APV0=PARAMPORT(I,4)
          If fstat=0
            Case [APV]SRCCODTYP
              When "REQ", "MLT"
                Gosub ADD_QUERY
              When "STA"
                Gosub ADD_STAT
              When Default
                # Inquiries, program generated feeds have to be managed here...
            Endcase
          Else
            # A pseudo portlet displaying an error message should be defined here
          Endif
        When "$flash" : # Flash representation of statistical inquiry, request, process
          # Find out the type of data source
          If PARAMPORT(I,3)="SUBAPR:CLOBEXP"
            Gosub ADD_PROC
          Else
            Read [APV]APV0=PARAMPORT(I,4)
            If fstat=0
              Case [APV]SRCCODTYP
                When "STA"
                  Gosub ADD_STAT
                When "REQ"
                  Gosub ADD_QUERY
                When Default
                  # A pseudo portlet displaying an error message should be defined here
              Endcase
            Else
              # A pseudo portlet displaying an error message should be defined here
            Endif
          Endif
        When Default
          L+=1
          Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"menuItem",'
          Append WCLOB,'"linkType":"$representation",'
          Append WCLOB,'"code":"'+PORTLET(I)+'",'
          Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
          Append WCLOB,'"representationRef":{"entity":"DISPLAY",'
          Append WCLOB,'"representation":"DISPLAY"},'
          Append WCLOB,'"facet":"$details",'
          Append WCLOB,'"parameters":['
          J=1
          While J<dim(PARAMPORT,2) and PARAMPORT(I,J)<>""
            Append WCLOB,string$(J>1,",")+'{"name":"p'+num$(I)+'","title":"P'+num$(I)+'","value":"'+PARAMPORT(I,J)+'"}'
            J+=1
          Wend
          Append WCLOB,"]}"
      Endcase
    Next I
  Endif

# Second step : generate the portlet for the level 2 menu
# Only for supervisor menus
# If USER=GSUPERX3 : # (modif 4 June)
    # an additional entry will be created
    L+=1
    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
    Append WCLOB,'"type":"$menu",'

    # Add the common definitions
    IDFONC(1)=string$(STDMEN(1)=1,ADM_PREFIX)+string$(STDMEN(1)=0,MEN_PREFIX)+PARAM(1)
    Append WCLOB,'"code":"'+IDFONC(1)+'",'
    Append WCLOB,'"title":{'
    For IL=1 To NBL
      Read [AZS]CLE=146;33;TABLAN(IL) : If fstat : Raz [AZS] : Endif
      Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+escJson(func AFNC.MES1([AZS]LANMES,USER))+'"'
    Next IL
    Append WCLOB,"}"
    Append WCLOB,','
    TEXTOTRANS=TITREFONC(1)
    Gosub DESC_TRANS
    Append WCLOB,','

    # Add the item list
    Append WCLOB,'"items":['
    N=0
    For J=1 To FIRSTFAV-1
      If NIVFONC(J)=2 and CODEFONC(J)="MENU"
        # an additional entry will be created
        N+=1
        Append WCLOB,string$(N>1,",")+'"'+IDFONC(J)+'"'
      Endif
    Next J
    Append WCLOB,"]"
    Append WCLOB,"}"
# Endif : # (modif 4 June)

# Third step : generate the portlet linked to a level 3 menu
# Only for supervisor menus
# If USER=GSUPERX3 : # (modif 4 June)
    For I=1 To FIRSTFAV-1
      If TYPEFONC(I)=1 and NIVFONC(I)=3
        IDFONC(I)=string$(STDMEN(I)=1,ADM_PREFIX)+string$(STDMEN(I)=0,MEN_PREFIX)+PARAM(I)
        L+=1
        NBP+=1
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
        Append WCLOB,'"type":"$menu",'
        Append WCLOB,'"code":"'+IDFONC(I)+'",'
        TEXTOTRANS=TITREFONC(I) : Gosub TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,',"items":['+CRLF+" "
        N=0
        For J=1 To FIRSTFAV-1
          If NIVFONC(J)=4
            If TYPEFONC(J)=2
              If MENUFONC(J)=PARAM(I)
                N+=1
                Append WCLOB,string$(N>1,",")+'"'+IDFONC(J)+'"'
                If mod(N,10)=0 : Append WCLOB,CRLF+"  " : Endif
              Endif
            Elsif MENUFONC(J)=PARAM(I)
              For K=1 To FIRSTFAV-1
                If NIVFONC(K)=5 and TYPEFONC(K)=2 and MENUFONC(K)=PARAM(J) : # See later if additional level exist
                  N+=1
                  Append WCLOB,string$(N>1,",")+'"'+IDFONC(K)+'"'
                  If mod(N,10)=0 : Append WCLOB,CRLF+"   " : Endif
                Elsif NIVFONC(K)=5 and TYPEFONC(K)=1 and MENUFONC(K)=PARAM(J)
                  For M=1 To FIRSTFAV-1
                    If NIVFONC(M)=6 and TYPEFONC(M)=2 and MENUFONC(M)=PARAM(K)
                      N+=1
                      Append WCLOB,string$(N>1,",")+'"'+IDFONC(M)+'"'
                    Endif
                  Next M
                Endif
              Next K
            Endif
          Endif
        Next J
        Append WCLOB,"]}"
      Elsif TYPEFONC(I)=2 and NIVFONC(I)=3 : # factoriser IDFONC plus tard
        J=I : Gosub ASSIGN_IDFONC
#       If CODEFONC(I)>="X"
#         IDFONC(I)="SPE_"+GACTX.AFOLDER+"_"+CODEFONC(I)+string$(PARAM(I)<>"","_"+func STRG(PARAM(I)))
#       Elsif PARAM(I)<>""
#         IDFONC(I)="PAR_"+GACTX.AFOLDER+"_"+CODEFONC(I)+"_"+func STRG(PARAM(I))
#       Else
#         IDFONC(I)="STD_"+CODEFONC(I)
#       Endif
        L+=1
        NBP+=1
#       MODIFICATION DONE THE 18TH OF JUNE (INSULATED LEVEL 3 FUNCTIONS)
#       Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
#       Append WCLOB,'"type":"$page",'
#       Append WCLOB,'"code":"'+IDFONC(I)+'",'
#       TEXTOTRANS=TITREFONC(I) : Gosub TITLE_TRANS
#       Append WCLOB,','
#       Gosub DESC_TRANS
#       Append WCLOB,'}'
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
        Append WCLOB,'"type":"$menu",'
        Append WCLOB,'"code":"'+IDFONC(I)+'",'
        TEXTOTRANS=TITREFONC(I) : Gosub TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,',"items":[ "'+IDFONC(I)+'"'
        Append WCLOB,']}'
#       END OF MODIFICATION DONE THE 18TH OF JUNE (INSULATED LEVEL 3 FUNCTIONS)
      Endif
    Next I
# Endif : # (modif 4 June)
Return

# Add a query portlet
$ADD_QUERY
  L+=1
  Read [ALH]ALH0=[APV]SRCCOD
  If fstat=0
    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"menuItem",'
    Append WCLOB,'"linkType":"$representation",'
    Append WCLOB,'"code":"'+PORTLET(I)+'",'
    TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
    Append WCLOB,','
    Gosub DESC_TRANS

    Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
    Append WCLOB,'"representationRef":{"entity":"QUERY('+"'"+[APV]SRCCOD+"'"+')",'
    Append WCLOB,'"representation":"QUERY~'+[APV]SRCCOD+'~99"},'
    Append WCLOB,'"facet":"$query",'

    Append WCLOB,'"parameters":['
    Append WCLOB, '{"name":"level","title":"Stat level","value":99},'
    Append WCLOB, '{"name":"cube","title":"Cube mode","value":"false"},'
    Append WCLOB, '{"name":"PORTVIEW", "title":"Portal code", "value":"'+[APV]APVCOD+'"}'
    Append WCLOB,"]}"
  Else
    # Portal view referring a not existent request code, generate an error widget
  Endif
Return

# Add a stat portlet
$ADD_STAT
  L+=1
  Read [PS2]PS20=[APV]SRCCOD
  If fstat=0
    Append WCLOB,string$(L>1,','+CRLF)+' { "$type":"menuItem",'
    Append WCLOB,' "linkType":"$representation",'
    Append WCLOB,' "code":"'+PORTLET(I)+'",'
    TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
    Append WCLOB,','
    Gosub DESC_TRANS
    Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
    Append WCLOB,' "representationRef":{"entity":"STATS",'
    Append WCLOB,' "representation":"STATS~'+[APV]SRCCOD+'"},'
    Append WCLOB,' "keyParameter":"'+[APV]SRCCOD+'",'
    Append WCLOB,' "facet":"$cube",'
    Append WCLOB,' "parameters":[ { "name":"PORTVIEW", "title":"Portal code", "value":"'+[APV]APVCOD+'"}]'
    Append WCLOB,' }'
  Else
    # Portal view referring a not existent stat code, generate an error widget
  Endif
Return

# Add a process portlet
# Modifications have been done in order to ensure that a process is read even if leg does not fit
$ADD_PROC
  L+=1
  J=instr(1,PARAMPORT(I,4),";")
  If J
    Read [APR]APR2=left$(PARAMPORT(I,4),J-1);right$(PARAMPORT(I,4),J+1)
    If fstat
      Read [APR]APR2=left$(PARAMPORT(I,4),J-1);""
      If fstat
        Read [APR]APR2(1)=left$(PARAMPORT(I,4),J-1)
      Endif
    Endif
  Else
    Read [APR]APR2=PARAMPORT(I,4);""
    If fstat
       Read [APR]APR2(1)=PARAMPORT(I,4)
    Endif
  Endif

  If fstat=0
    Append WCLOB,string$(L>1,','+CRLF)+' { "$type":"menuItem",'
    Append WCLOB,' "linkType":"$representation",'
    Append WCLOB,' "code":"'+PORTLET(I)+'",'
    TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
    Append WCLOB,','
    Gosub DESC_TRANS
    Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
    Append WCLOB,' "representationRef":{"entity":"PROCESS",'
    If PARAMPORT(I,5)<>"" : # CODE THAT WILL BE ACTIVATED LATER (FOR MENU PROCESS MANAGEMENT)
      Append WCLOB,' "representation":"PROCESS~~'+[APR]CODPRO+"~"+PARAMPORT(I,5)+'"},'
      Append WCLOB,' "keyParameter":"'+"~"+[APR]CODPRO+"~"+PARAMPORT(I,5)+'",'
    Else
      Append WCLOB,' "representation":"PROCESS~'+[APR]CODPRO+'"},'
      Append WCLOB,' "keyParameter":"'+[APR]CODPRO+'",'
    Endif
    Append WCLOB,' "facet":"$details"}'
  Else
    # Process referring a not existent process code, generate an error widget
  Endif
Return

# Write the portlet menu list for the main portal
$GENE_PORTLET
  For I=1 To NBPORT
    Case PARAMPORT(I,1)
      When "$ext","$rss","$table","$flash"
      # Portlet displaying an URL (RSS is done the same way for the moment), or a tabular function
      # The generation is here the same, because the page is directly fed by the menu item (no intermediate link)
        L+=1
        NBP+=1
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
        Append WCLOB,'"type":"$page",'
        Append WCLOB,'"code":"'+PORTLET(I)+'",'
        TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        If find(PARAMPORT(I,3),"SUBAPR:CLOBEXP","SUBAPSMON:CLOBEXP")
          Append WCLOB,',"pageItem":"'+PORTLET(I)+'"'
        Endif
        Append WCLOB,"}"
        N=1
     When "$menu" : # Standard menus, no more favorites
        If PARAMPORT(I,2)="GEN" : # and USER=GSUPERX3 : # (modif 4 june)
          L+=1
          NBP+=1
          Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
          Append WCLOB,'"type":"$menu",'
          Append WCLOB,'"code":"'+PORTLET(I)+'",'
          TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
          Append WCLOB,','
          Gosub DESC_TRANS
         Append WCLOB,',"items":['+CRLF+"   "
          N=1
          For M=2 To FIRSTFAV-1
            If TYPEFONC(M)=1 and NIVFONC(M)=2
              Append WCLOB,string$(N>1,",")+'"'+string$(STDMEN(M)=1,ADM_PREFIX)
&                         +string$(STDMEN(M)=0,MEN_PREFIX)+func STRG(PARAM(M))+'"'
              N+=1
              If mod(N,10)=0 : Append WCLOB,CRLF+"   " : Endif
            Elsif TYPEFONC(M)=2 and NIVFONC(M)=2
              Append WCLOB,string$(N>1,",")+'"'+IDFONC(M)+'"'
              N+=1
              If mod(N,10)=0 : Append WCLOB,CRLF+"   " : Endif
            Endif
          Next M
          J=1 : K=FIRSTFAV-1 : CUR_LEVEL=1
          Append WCLOB,"]}" : # Moved
        Endif
        # Append WCLOB,"]}"
      When "$header" : # Ignore the header
      When Default : # Display a message for the moment
        L+=1
        NBP+=1
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"portlet",'
        Append WCLOB,'"type":"$page",'
        Append WCLOB,'"code":"'+PORTLET(I)+'",'
        TEXTOTRANS=TITPOR(I) : Gosub VIG_TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,',"pageItem":"'+PORTLET(I)+'"}'
    Endcase
  Next I
Return

$GENE_PAGES
# First generate the main portal
  L+=1
  NBD+=1

####
# 2013_07_29 : TCA : Authoring is now managed by Syracuse client
# We only generate a JSON content that include data informations !
####
  If USER<>GSUPERX3
    # Authoring for portal page
    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"pageData",'
    Append WCLOB,'"code":"'+PORTLET(1)+'",'
    Append WCLOB,'"content":'
    Gosub PORTAL_AUTHORING_INFO
    If JSONEMB=0
      Append WCLOB,'"'+escJson(WINFO)+'"'
    Else
      Append WCLOB,WINFO
    Endif
    L+=1
    If NB_LOCALIZATIONS>0
      Gosub TAB_LOCALIZATION
      Append WCLOB,',"localization":'
      If JSONEMB=0
        Append WCLOB,'"{'
        Append WCLOB,escJson(JSONLOCALTAB)
        Append WCLOB,'}"'
      Else
        Append WCLOB,'{'+JSONLOCALTAB+'}'
      Endif
      L+=1
    Endif
    Append WCLOB, '}'
  Else
    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"pageData",'
    Append WCLOB,'"code":"'+USR_PREFIX+'"}'
  Endif

###
# Old section to manage authoring
###
#  If USER<>GSUPERX3
#    # Authoring page portail
#    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"pageData",'
#    Append WCLOB,'"code":"'+PORTLET(1)+'",'
#    Append WCLOB,'"content":'
#    Gosub ART_PORTAL
#    If JSONEMB=0
#      Append WCLOB,'"'+ESCJSON(WCLOB1)+'"}'
#    Else
#      Append WCLOB,WCLOB1+"}"
#    Endif
#    L+=1
#  Else
#    Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"pageData",'
#    Append WCLOB,'"code":"'+USR_PREFIX+'"}'
#  Endif
###
#
###
  Append WCLOB,',{"$type":"dashboardDef",'
  Append WCLOB,'"dashboardName":"home",'
  Append WCLOB,'"variants":[{'
  Append WCLOB,'"code":"'+USR_PREFIX+'",'
  If USER<>GSUPERX3 : Append WCLOB,'"pageData":"'+PORTLET(1)+'",' : Endif
  Append WCLOB,'"title":{'
  For IL=1 To NBL
    Read [AZS]CLE=146;33;TABLAN(IL) : If fstat : Raz [AZS] : Endif
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+escJson(func AFNC.MES1([AZS]LANMES,USER))+'"'
  Next IL
  Append WCLOB,'},'
  Append WCLOB,'"description":{'
  For IL=1 To NBL
    Read [AZS]CLE=146;33;TABLAN(IL) : If fstat : Raz [AZS] : Endif
    Append WCLOB,string$(IL>1,",")+'"'+ISOLAN(IL)+'":"'+escJson(func AFNC.MES1([AZS]LANMES,USER))+'"'
  Next IL
  Append WCLOB,'},'
  Append WCLOB,'"allApplications":false'
  Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'
  Append WCLOB,'"vignettes":['+CRLF+"   "
  N=0
  # The first virtual portlet ($header) has not to be generated
  # If USER=GSUPERX3 : # (modif 4 June)
     Append WCLOB,string$(N>0,",")+'{"portlet":"'+IDFONC(1)+'",'
     TEXTOTRANS=TITREFONC(1) : Gosub TITLE_TRANS
     Append WCLOB,','
     Gosub DESC_TRANS
     Append WCLOB,',"allEndpoints":true, "isTOC":true}'
     N+=1
  # Else : # (modif 4 June)
    If GUSER<>GSUPERX3 : # Modification to regenerate the menus
    For I=2 To NBPORT
      If USER=GSUPERX3 or PARAMPORT(I,1)<>"$menu" or PARAMPORT(I,2)<>"GEN"
        Append WCLOB,string$(N>0,",")+'{"portlet":"'+PORTLET(I)+'",'
        Append WCLOB,'"allEndpoints":true}'
        If mod(I-1,5)=0 : Append WCLOB,CRLF+"   " : Endif
        N+=1
      Endif
    Next I
  Endif
  Append WCLOB,"]}" : # Closes the "vignettes" section + application section
  Append WCLOB,"]}" : # Closes the "variants" section

# Generate the level 2 menus
# If USER=GSUPERX3 : # (modif 4 June)
    For I=1 To FIRSTFAV-1
      If TYPEFONC(I)=1 and NIVFONC(I)=2

        # Dashboard header
        L+=1
        NBD+=1
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"pageData",'
        Append WCLOB,'"code":"'+IDFONC(I)+'",'
        Append WCLOB,'"content":'
        CONTENT=I : Gosub CONTENT
        If JSONEMB=0
          Append WCLOB,'"'+escJson(WCLOB1)+'"'
        Else
          Append WCLOB,WCLOB1
        Endif
        L+=1
        If NB_LOCALIZATIONS>0
          Gosub LOCALIZATION
          Append WCLOB,',"localization":'
          If JSONEMB=0
            Append WCLOB,'"{'
            Append WCLOB,escJson(JSONLOCAL)
            Append WCLOB,'}"'
          Else
            Append WCLOB,'{'+JSONLOCAL+'}'
          Endif
          L+=1
        Endif
        Append WCLOB,'}'
        Append WCLOB,string$(L>1,','+CRLF)+'{"$type":"dashboardDef",'
        TEXTOTRANS=TITREFONC(I) : Gosub TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,',"dashboardName":"'+IDFONC(I)+'",'
        Append WCLOB,'"variants":[{'
        Append WCLOB,'"code":"'+PROFIL+'",'
        Append WCLOB,'"pageData":"'+IDFONC(I)+'",'
        TEXTOTRANS=TITREFONC(I) : Gosub TITLE_TRANS
        Append WCLOB,','
        Gosub DESC_TRANS
        Append WCLOB,',"allApplications":false'
        Append WCLOB,',"application":{'+ APPLICATION_CODE +','+CONTRACT_CODE+'},'+CRLF
        Append WCLOB,'"vignettes":['+CRLF+"   "
        N=0

        # Other portlets present
        For J=2 To FIRSTFAV-1
          If MENUFONC(J)=PARAM(I) and NIVFONC(J)=3 : # and TYPEFONC(J)=1 : # Added Jan 14
            Append WCLOB,string$(N>0,",")+'{"portlet":"'+IDFONC(J)+'",'
            TEXTOTRANS=TITREFONC(J) : Gosub TITLE_TRANS
            Append WCLOB,','
            Gosub DESC_TRANS

            Append WCLOB,',"allEndpoints":true}'
                If mod(J-1,2)=0 : Append WCLOB,CRLF+"   " : Endif
                N+=1
          Endif
        Next J

        # Add an entry to the general portlet, so the right link panel will be updated
         Append WCLOB,string$(N>0,",")+'{"portlet":"'+IDFONC(1)+'",'
         Append WCLOB,'"allEndpoints":true, "isTOC":true}'

        Append WCLOB,"]}]}" : # Closes "vignette" list (']'), "variant" list ('}]') and dashboard def
      Endif
    Next I
# Endif : # (modif 4 June)
Return


$PORTAL_AUTHORING_INFO
  Local Clbfile WINFO(10)
  WINFO = ''
  NB_LOCALIZATIONS=0
  Case [L]CODMET
      When "ACHE", "ADVT", "APPR", "ADDO", "ATEL", "CCPT", "COMM", "ETUD", "HDK", "MAGA", "PLAN", "RCPC", "RCPF", "RESS", "DIRE", "CGES",
&          "ACCT", "ADMNA", "AP", "AR", "COST", "CS", "DES", "EXEC","MAT", "PLN", "PRD", "PUR", "SLS", "SVC", "WH"
        Local Integer PID
        Local Integer TBL_CNT
        Local Integer FLA_CNT

          Append WINFO, '{"$article": {'
          Append WINFO, '"$importHint": "mainDashboard",'
          Append WINFO, '"$contentHint": {'
          Append WINFO, '"$title":"'+USER+'",'
          Append WINFO, '"$profile":"' + CODMET+'",'
          Append WINFO, '"$tabs": ['
          # Iterate on tabs
          For TID = 1 To NBONG
            TBL_CNT = 0 : FLA_CNT = 0
            Append WINFO, string$(TID>1,",") + '{'
            Append WINFO,'"title":'
            LOCALIZATIONS(0)= TID : Gosub ADD_LOCAL
            Append WINFO, '"{@tab-' + num$(TID)+'}"'

            Append WINFO,',"$queries":['
            For PID=2 To NBPORT
              If NUMONG(PID) = TID
                If PARAMPORT(PID,1)="$table" : # Handle of queries
                  Append WINFO,string$(TBL_CNT>0,",")+'"'+PORTLET(PID)+'"'
                  TBL_CNT+=1
                Endif
              Endif
            Next PID
            Append WINFO,']'

            Append WINFO,',"$processes":['
            For PID=2 To NBPORT
              If NUMONG(PID) = TID
                If PARAMPORT(PID,1)="$flash" : # Handle of processes
                  Append WINFO,string$(FLA_CNT>0,",")+'"'+PORTLET(PID)+'"'
                  FLA_CNT+=1
                Endif
              Endif
            Next PID
            Append WINFO,']'
            Append WINFO, '}'
          Next TID
          Append WINFO, ']'
          Append WINFO, '}'
          Append WINFO, '}'
          Append WINFO, '}'
      When Default
        Return
    Endcase
Return



