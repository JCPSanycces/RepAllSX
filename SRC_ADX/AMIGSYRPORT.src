# Standard header generation subprogram
# Includes the prototype and the header of the items section (  '"$items" : ['  )
Subprog HEADER(WCLOB,LANGUE)
Variable Clbfile WCLOB()
Value Char LANGUE()

Local Char CRLF(2)
Local Char C(255),D(255)

  CRLF=chr$(10)

# The prototype is a constant, simply push the strings
  WCLOB="{"+CRLF+'"$prototypes": {'
&          +CRLF+'"menuItem": {'+CRLF+'"$key":"code",'
&          +CRLF+'"parameters":{'+CRLF+'"$key":"name"},'
&          +CRLF+'"application":{'+CRLF+'"$key":["application","contract"]'
&          +CRLF+'}'+CRLF+'},'+CRLF
  Append WCLOB,'"portlet":{'+CRLF+'"$key":"code",'
&        +CRLF+'"application":{'+CRLF+'"$key":["application","contract"]'
&        +CRLF+'},'
&        +CRLF+'"items":{'+CRLF+'"$key":"code"},'
&        +CRLF+'"pageItem":{"$key":"code"}'
&        +CRLF+'},'+CRLF
  Append WCLOB,'"pageData":{'+CRLF+'"$key":"code"'
&        +CRLF+'},'+CRLF
  Append WCLOB,'"dashboardDef":{'+CRLF+'"$key":"dashboardName",'
&        +CRLF+'"variants":{'+CRLF+'"$key":"code",'
&        +CRLF+'"vignettes":{'+CRLF+'"$key":"portlet",'
&        +CRLF+'"portlet":{'+CRLF+'"$key":"code"'
&        +CRLF+'}},'
&        +CRLF+'"application":{'+CRLF+'"$key":["application","contract"]},'
&        +CRLF+'"pageData":{'+CRLF+'"$key":"code"}}}},'
   Append WCLOB,CRLF+'"$items":['+CRLF

End

# Gets the portal structure and layout associated to the user in variables
Subprog GET_POR(USER,NBPORT,PORTLET,NBONG,NUMONG,NUMCOL,TITPOR,PARAMPORT,MYLOG,ERR)
Value Char USER()
Variable Integer NBPORT
Variable Char PORTLET()(1..)
Variable Integer NBONG
Variable Libelle NUMONG(1..)
Variable Libelle NUMCOL(1..)
Variable Char TITPOR()(1..)
Variable Char PARAMPORT()(1..,1..)
Variable Instance MYLOG Using C_ALOG
Variable Integer ERR

Local Integer I,J,K,ER
Local Integer NBCOL
Local Char PORT_ROOT(150), USERP(20)

# Dominique Bopp 10th of October 2013
# This flag is set to 1 if on the first tab at least another real portlet (not the menu) has been found
Local Integer REAL_TAB

  ER=0
  REAL_TAB=0

  If left$(USER,1)<>"_"
    USERP=USER
    Read [APU]APU0=USER
    If fstat<>0 or USER=fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","ADMUSR")
      # If no portal is found, or if ADMIN menu is generated a default portal with only standard menus is displayed
      NBPORT=1
      NBONG=1
      PORTLET(NBPORT)="USR_"+GACTX.AFOLDER+"_"+USER : TITPOR(NBPORT)=USER : # To be translated ?
      NUMONG(NBPORT)=NBONG : NUMCOL(NBPORT)=1
      PARAMPORT(NBPORT,1)="$menu"
      PARAMPORT(NBPORT,2)="GEN"
      PARAMPORT(NBPORT,3)="1"
      ER=0
      End
    Endif
  Else
    USERP=right$(USER,2)
    Read [APU]APU0=USERP
  Endif

  NBPORT=0

# A first virtual portlet contains the title of the dashboard
  NBPORT+=1
  NUMONG(NBPORT)=0 : NUMCOL(NBPORT)=0 : PARAMPORT(NBPORT,1)="$header"
  If left$(USER,1)<>"_"
    PORTLET(NBPORT)="USR_"+GACTX.AFOLDER+"_"+USER : TITPOR(NBPORT)=USER
  Else
    PORTLET(NBPORT)="TRD_"+GACTX.AFOLDER+USER : TITPOR(NBPORT)=right$(USER,2)
  Endif
  PORT_ROOT=PORTLET(NBPORT)
  ER=fmet MYLOG.APUTLINE("Root portlet :"+PORT_ROOT,0)

  NBONG=0
  For I=1 To [APU]NBTAB
    Read [APA]APA0=USERP;[APU]CODTAB(I-1)
    If fstat=0
      If NBONG<>1 or REAL_TAB<>0 : NBONG+=1 : Endif
      For J=1 To [APA]NBMOD
        Read [AMO]AMO0=USERP;[APA]CODTAB;[APA]CODMOD(J-1)
        If fstat=0 & find(PORT_ROOT+"_"+[AMO]CODMOD,PORTLET(1..NBPORT))=0 : # Sometimes, duplicate entry exist (portal's bug)
          NBPORT+=1
          PORTLET(NBPORT)=PORT_ROOT+[AMO]CODMOD : NUMONG(NBPORT)=NBONG : NUMCOL(NBPORT)=[APA]COLNUM(J-1)
          #TITPOR(NBPORT)=[AMO]TITELT+string$([AMO]TITELT="",PORTLET(NBPORT))
          TITPOR(NBPORT) = [AMO]VIGNETTE
          Case [AMO]MODTYP
            When "x3navigreader" : # Menus
              PARAMPORT(NBPORT,1)="$menu"
              PARAMPORT(NBPORT,2)="GEN"
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Unfolded menu (true/false)
            When "framereader" : # Web page within a frame
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$ext"
              If left$(vireblc([AMO]VALPAR(2),0),1)="="
                PARAMPORT(NBPORT,2)=func EVALERR(right$(vireblc([AMO]VALPAR(2),0),2))
              Else
                PARAMPORT(NBPORT,2)=[AMO]VALPAR(2)
              Endif
            When "x3flashreader" : # Flash component
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$flash"
              For K=1 To min(dim([AMO]VALPAR),dim(PARAMPORT,2))-1
                PARAMPORT(NBPORT,K+1)=[AMO]VALPAR(K-1)
                Break [AMO]VALPAR(K-1)=""
              Next K
            When "x3favorireader" : # Menu favorites is now ignored
              NBPORT-=1
#              NBONG-=1
#              PARAMPORT(NBPORT,1)="$menu"
#              PARAMPORT(NBPORT,2)="FAV"
#              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Heigth
            When "webnote" : # Notes
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$notes"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(0) : # Default text
            When "xmlrssreader" : # RSS reader
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$rss"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(2) : # Nb items
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Display (true, false)
              PARAMPORT(NBPORT,4)=[AMO]VALPAR(0) : # Url
            When "x3tabreader" : # Tabular data
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$table"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(0) : # Nb of items
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Call
              PARAMPORT(NBPORT,4)=[AMO]VALPAR(2) : # Type
              PARAMPORT(NBPORT,5)=[AMO]VALPAR(3) : # Refresh time
            When "x3exaleadreader" : # Exalead search page
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$search"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(0) : # heigth
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Scrolling (true, false)
              PARAMPORT(NBPORT,4)=[AMO]VALPAR(2) : # Delay
            When "x3tracereader" : # Log display
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$trace"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(0) : # heigth
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Data access
              PARAMPORT(NBPORT,4)=[AMO]VALPAR(2) : # Parameters
            When "x3flvreader" : # Video stream reader
              REAL_TAB=1
              PARAMPORT(NBPORT,1)="$video"
              PARAMPORT(NBPORT,2)=[AMO]VALPAR(0) : # heigth
              PARAMPORT(NBPORT,3)=[AMO]VALPAR(1) : # Url
              PARAMPORT(NBPORT,4)=[AMO]VALPAR(2) : # Waiting message
          Endcase
          ER=fmet MYLOG.APUTLINE(" Portlet"-PORTLET(NBPORT)-"Type="-PARAMPORT(NBPORT,1),0)
        Endif
      Next J
    Endif
  Next I
End

Funprog EVALERR(FORMUL)
Value Char FORMUL()
Onerrgo ERRR
End evalue(FORMUL)
$ERRR
Onerrgo
End

# Escapes the double quote in a string JSON constant
Funprog STRG(CHAINE)
Value Char CHAINE
Local Char RESULT(250)
Local Integer POS1,POS2
POS2=1
POS1=instr(POS2,CHAINE,'"')
While POS1<>0
    RESULT+=mid$(CHAINE,POS2,POS1-POS2)+'\"'
    POS2=POS1+1
    POS1=instr(POS2,CHAINE,'"')
  Wend
End RESULT+right$(CHAINE,POS2)

# Generation of the authoring section
# Called for each menu at level 2
# In JSON in a first step
$CONTENT

Local Clbfile JSONLAYOUT(10)(1..2), WCLOB1(10)
Local Integer NBITEMS(1..2)
Local Integer M3,M4,M5,M6,M7,M8,M9,M10

  If CONTENT=0 : Append WCLOB1,"{}" : Return : Endif
  NB_LOCALIZATIONS=0

# Current item
  J=1

# Start the JSON layout
  Append WCLOB1,"{"
  Append WCLOB1,'"$article": '
  Append WCLOB1,'{'
  Append WCLOB1,'"$importHint" : "navigationMenu",'
  Append WCLOB1, '"$category":"dashboard",'
  Append WCLOB1,'"$title":"'
  If left$(TITREFONC(I),1)="@"
    If JSONEMB=0
      Append WCLOB1,"{"+TITREFONC(I)+'}",'
    Else
      Read [AZZ]NUMERO=GACTX.LAN;val(right$(TITREFONC(I),2))
      Append WCLOB1,"{"+TITREFONC(I)+'}'+escJson([AZZ]TEXTE)+'",'
    Endif
    LOCALIZATIONS(0)=val(right$(TITREFONC(I),2)) : Gosub ADD_LOCAL
  Else
    Append WCLOB1,escJson(TITREFONC(I))+'",'
  Endif
  Append WCLOB1,'"$layout":{"$layoutType":"row","$items":['

  # For each menu at level 3
  For M3=1 To FIRSTFAV-1
    If TYPEFONC(M3)=1 and NIVFONC(M3)=3 and MENUFONC(M3)=PARAM(I)
      Gosub MEN3
    Endif
  Next M3

  # Are there functions directly at level 3 ?
  For M3=1 To FIRSTFAV-1 : Break TYPEFONC(M3)=2 and NIVFONC(M3)=3 and MENUFONC(M3)=PARAM(I) : Next M3
  If M3<FIRSTFAV
    M4=M3
    Gosub MEN3
  Endif


  # End of loop
  If NBITEMS(1)>1 : Append JSONLAYOUT(1),"]}" : Endif
  If NBITEMS(2)>1 : Append JSONLAYOUT(2),"]}" : Endif

  Append WCLOB1,JSONLAYOUT(1)+string$(NBITEMS(2)>1,",")+JSONLAYOUT(2)+"]}}}"

Return

# Article for portal
# Handle the menu 3 level
$MEN3
  # Column switch if necessary
  If NBITEMS(3-J)<NBITEMS(J) and USER=GSUPERX3
    J=3-J
  Endif

  # Add the header if necessary or a comma
  If NBITEMS(J)=0
    Append JSONLAYOUT(J),'{"$layoutType": "stack","$items": ['
  Else
    Append JSONLAYOUT(J),','
  Endif

  Append JSONLAYOUT(J),'{"$category":"section",'

  # If not a direct function, add the title
  If TYPEFONC(M3)=1
    Append JSONLAYOUT(J),'"$title":"'
    If left$(TITREFONC(M3),1)="@"
      If JSONEMB=0
        Append JSONLAYOUT(J),"{"+TITREFONC(M3)+'}",'
      Else
        Read [AZZ]NUMERO=GACTX.LAN;val(right$(TITREFONC(M3),2))
        Append JSONLAYOUT(J),"{"+TITREFONC(M3)+'}'+escJson([AZZ]TEXTE)+'",'
      Endif
      LOCALIZATIONS(0)=val(right$(TITREFONC(M3),2)) : Gosub ADD_LOCAL
    Else
      Append JSONLAYOUT(J),escJson(TITREFONC(M3))+'",'
    Endif

    # A title counts as 2 lines
    NBITEMS(J)+=2
  Endif

  M6=0
  Append JSONLAYOUT(J),'"$layout": {"$items": ['

  # Are there functions directly at level 4 ?
  If TYPEFONC(M3)=1
    For M4=1 To FIRSTFAV-1 : Break TYPEFONC(M4)=2 and NIVFONC(M4)=4 and MENUFONC(M4)=PARAM(M3) : Next M4
    If M4<FIRSTFAV
      M6+=1
      M7=0
      M8=0
      M9=0
      Append JSONLAYOUT(J),string$(M6>1,",")
      Append JSONLAYOUT(J),'{"$category":"menus","$layout": {"$layoutType": "row","$items": [{"$layoutType": "stack",'+string$(JSONEMB=1,CRLF)

    # First pass to count the items
      For M5=1 To FIRSTFAV-1
        If TYPEFONC(M5)=2 and NIVFONC(M5)=4 and MENUFONC(M5)=PARAM(M3)
          M8+=1
        Elsif TYPEFONC(M5)=1 and TYPEFONC(M4)=1 and NIVFONC(M5)=5 and MENUFONC(M5)=PARAM(M4)
          M8+=sigma(1,FIRSTFAV-1,TYPEFONC(indcum)=2 and NIVFONC(indcum)=6 and MENUFONC(indcum)=PARAM(M5))
        Endif
      Next M5

      Append JSONLAYOUT(J),'"$items": ['
      For M5=M4 To FIRSTFAV-1
        If TYPEFONC(M5)=2 and NIVFONC(M5)=4 and MENUFONC(M5)=PARAM(M3)
          M7+=1
          M9+=1
          Append JSONLAYOUT(J),string$(M9>1,',')+'{"$bind":"'+IDFONC(M5)+'"}'
          NBITEMS(J)+=1

          # If the column are filled at 1/3, break
          If M7=int((M8+2)/3) or M7=int((M8+2)/3)+int((M8+2)/3) : # and M7<M8
            Append JSONLAYOUT(J),']},{"$layoutType": "stack","$items": ['
            M9=0
            If (M7=M8) and M8<3 : Append JSONLAYOUT(J),'{"$category":"space"}' : M9+=1 : Endif
          Endif
        Endif
      Next M5
      # End of loop
      Append JSONLAYOUT(J),']}]}}'+string$(JSONEMB=1,CRLF)
    Endif
  Endif

  # For every sub-menu at level 4
  If TYPEFONC(M3)=1
    For M4=1 To FIRSTFAV-1
      If TYPEFONC(M4)=1 and NIVFONC(M4)=4 and MENUFONC(M4)=PARAM(M3)
        Gosub MEN4
      Endif
    Next M4
  Else
    M4=M3
    Gosub MEN4
  Endif

  # End of loop
  Append JSONLAYOUT(J),']}}'+string$(JSONEMB=1,CRLF)

Return

$MEN4
  M6+=1
  M7=0
  M8=0
  M9=0
  Append JSONLAYOUT(J),string$(M6>1,",")
  Append JSONLAYOUT(J),'{"$category":"menus",'
  If TYPEFONC(M4)=1
    Append JSONLAYOUT(J),'"$title":"'
    If left$(TITREFONC(M4),1)="@"
      If JSONEMB=0
        Append JSONLAYOUT(J),"{"+TITREFONC(M4)+'}",'
      Else
        Read [AZZ]NUMERO=GACTX.LAN;val(right$(TITREFONC(M4),2))
        Append JSONLAYOUT(J),"{"+TITREFONC(M4)+'}'+escJson([AZZ]TEXTE)+'",'
      Endif
      LOCALIZATIONS(0)=val(right$(TITREFONC(M4),2)) : Gosub ADD_LOCAL
    Else
      Append JSONLAYOUT(J),escJson(TITREFONC(M4))+'",'
    Endif
  Endif
  Append JSONLAYOUT(J),'"$layout": {"$layoutType": "row","$items": [{"$layoutType": "stack",'+string$(JSONEMB=1,CRLF)

# First pass to count the items
  For M5=1 To FIRSTFAV-1
    If (TYPEFONC(M5)=2) and ((TYPEFONC(M4)=1 and NIVFONC(M5)=5 and MENUFONC(M5)=PARAM(M4))
&                         or (TYPEFONC(M4)=2 and NIVFONC(M4)=NIVFONC(M5) and MENUFONC(M5)=MENUFONC(M4)))
      M8+=1
    Elsif TYPEFONC(M5)=1 and TYPEFONC(M4)=1 and NIVFONC(M5)=5 and MENUFONC(M5)=PARAM(M4)
      M8+=sigma(1,FIRSTFAV-1,TYPEFONC(indcum)=2 and NIVFONC(indcum)=6 and MENUFONC(indcum)=PARAM(M5))
    Endif
  Next M5

  Append JSONLAYOUT(J),'"$items": ['

  For M5=1 To FIRSTFAV-1
    If (TYPEFONC(M5)=2) and ((TYPEFONC(M4)=1 and NIVFONC(M5)=5 and MENUFONC(M5)=PARAM(M4))
&                         or (TYPEFONC(M4)=2 and NIVFONC(M4)=NIVFONC(M5) and MENUFONC(M5)=MENUFONC(M4)))
      M7+=1
      M9+=1

      Append JSONLAYOUT(J),string$(M9>1,',')+'{"$bind":"'+IDFONC(M5)+'"}'
      NBITEMS(J)+=1

      # If the column are filled at 1/3, break
      If M7=int((M8+2)/3) or M7=int((M8+2)/3)+int((M8+2)/3) : # and M7<M8
         Append JSONLAYOUT(J),']},{"$layoutType": "stack","$items": ['
         M9=0
         If (M7=M8) and M8<3 : Append JSONLAYOUT(J),'{"$category":"space"}' : M9+=1 : Endif
      Endif

    Elsif TYPEFONC(M5)=1 and TYPEFONC(M4)=1 and NIVFONC(M5)=5 and MENUFONC(M5)=PARAM(M4)
      For M10=1 To FIRSTFAV-1
        If TYPEFONC(M10)=2 and NIVFONC(M10)=6 and MENUFONC(M10)=PARAM(M5)
          M7+=1
          M9+=1
          Append JSONLAYOUT(J),string$(M9>1,',')+'{"$bind":"'+IDFONC(M10)+'"}'
          NBITEMS(J)+=1

          # If the column are filled at 1/3, break
          If M7=int((M8+2)/3) or M7=int((M8+2)/3)+int((M8+2)/3) : # and M7<M8
            Append JSONLAYOUT(J),']},{"$layoutType": "stack","$items": ['
            M9=0
            If (M7=M8) and M8<3 : Append JSONLAYOUT(J),'{"$category":"space"}' : M9+=1 : Endif
          Endif
        Endif
      Next M10
    Endif
  Next M5

  # End of loop
  Append JSONLAYOUT(J),']}]}}'+string$(JSONEMB=1,CRLF)

Return

###
# Tabs localization for authoring
###
$TAB_LOCALIZATION

  Local Clbfile JSONLOCALTAB(10)
  Local Integer IL1,IL2

  JSONLOCALTAB=""

  For IL1=1 To NBL
    Append JSONLOCALTAB,string$(IL1>1,string$(JSONEMB=1,CRLF)+",")+'"'+ISOLAN(IL1)+'": {'+string$(JSONEMB=1,CRLF)
    For IL2=1 To NB_LOCALIZATIONS
      Append JSONLOCALTAB,string$(IL2>1,string$(JSONEMB=1,CRLF)+",")+'"@tab-'+num$(LOCALIZATIONS(IL2))+'":"'
      If LOCALIZATIONS(IL2) = 1
          Read [AZS]CLE=7837;16;TABLAN(IL1) : If fstat : Raz [AZS] : Endif
          Append JSONLOCALTAB, func AFNC.MES1([AZS]LANMES,USER)+'"'
      Else
        Case left$(USER,1)
          When "_"
              Append JSONLOCALTAB, + func TRADINT(TABLAN(IL1),"AMETUTI","INTMET",right$(USER,2))+'"'
          When Default
              Append JSONLOCALTAB, func TRADINT(TABLAN(IL1),"AUTILIS","INTUSR",USER)+'"'
        Endcase
      Endif
    Next IL2
    Append JSONLOCALTAB,"}"
  Next IL1

Return


###

$LOCALIZATION

Local Clbfile JSONLOCAL(10)
Local Integer IL1,IL2

 JSONLOCAL=""

  For IL1=1 To NBL
    Append JSONLOCAL,string$(IL1>1,string$(JSONEMB=1,CRLF)+",")+'"'+ISOLAN(IL1)+'": {'+string$(JSONEMB=1,CRLF)
    For IL2=1 To NB_LOCALIZATIONS
      Append JSONLOCAL,string$(IL2>1,string$(JSONEMB=1,CRLF)+",")+'"@'+num$(LOCALIZATIONS(IL2))+'":"'
      Read [AZZ]NUMERO=TABLAN(IL1);LOCALIZATIONS(IL2)
      If fstat : Raz [AZZ] : Endif
      Append JSONLOCAL,escJson([AZZ]TEXTE)+'"'
    Next IL2
    Append JSONLOCAL,"}"
  Next IL1

Return

$ADD_LOCAL
 If find(LOCALIZATIONS(0),LOCALIZATIONS(1..NB_LOCALIZATIONS))=0
   NB_LOCALIZATIONS+=1 : LOCALIZATIONS(NB_LOCALIZATIONS)=LOCALIZATIONS(0)
 Endif
Return

Funprog TTT(CH1)
Value Clbfile CH1
Local Integer I
Clbfile CH2
I=instr(1,CH1,"%")
While I
  CH2+=left$(CH1,I-1)+chr$(16*(ascii(mid$(CH1,I+1,1))-48-7*(mid$(CH1,I+1,1)>="A"))+ascii(mid$(CH1,I+2,1))-48-7*(mid$(CH1,I+2,1)>="A"))
  CH1=right$(CH1,I+3)
  I=instr(1,CH1,"%")
Wend
End CH2
