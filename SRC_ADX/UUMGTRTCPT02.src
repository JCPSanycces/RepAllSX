#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT02                                      Module  Accounting   #
#                    Migration Process                                   #
#      Flow for IAS Journal                                              #
#                                                                        #
#            GACEIAS/GACEIASD                                            #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   GACEIAS  : CPY;TYP;NUM                                               #
#   GACEIASD : CPY;TYP;NUM;LIG                                           #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   GACEIAS  : TYP;NUM                                                   #
#   GACEIASD : TYP;NUM;LIG                                               #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT02") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT02(DOSSIER)
  Call MAJ_UUMGTRTCPT02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTCPT02(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMHIAM,WNAMDIAM
Call MIGTABNAME (DOSSIER,"GACEIAS",WNAMHIAM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"GACEIASD",WNAMDIAM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMHIAM,"fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMDIAM,"fde",DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT02",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT02(DOSSIER)
Value Char DOSSIER
Local Integer ERR
Local Integer TOTNBR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMHIAM,WNAMDIAM
Call MIGTABNAME (DOSSIER,"GACEIAS",WNAMHIAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"GACEIASD",WNAMDIAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMHIAM,"fde",DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMDIAM,"fde",DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",7,ERR) From TRTMIG : End : Endif

#----- GACEIAS = Obsolete table => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"GACEIAS",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGTRTCPT02",TOTNBR,ERR) From TRTMIG
Commit

# Issue 81808 - 2012-04-24 by VPO : ne pas passer par recréation des index si pas de lignes IAS
If TOTNBR=0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGTRTCPT02 IAS journals Process : Update GACCENTRY/GACCENTRYD/GACCENTRYA") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Call MIGTABINIT (DOSSIER,"GACCENTRY",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCENTRYD",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCENTRYA",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:HAE]) = 0 :  Local File =DOSSIER+".GACCENTRY"    [HAE]   : Endif     # Accounting Journal
If clalev([F:DAE]) = 0 :  Local File =DOSSIER+".GACCENTRYD"   [DAE]   : Endif     # General Acccounting Line
If clalev([F:DAA]) = 0 :  Local File =DOSSIER+".GACCENTRYA"   [DAA]   : Endif     # Analytical Accounting Line

# X3 Renamed File
If clalev([F:HIAM]) = 0 :  Local File =DOSSIER+"."+WNAMHIAM  [HIAM]   : Endif     # IAS Accounting Journal
If clalev([F:DIAM]) = 0 :  Local File =DOSSIER+"."+WNAMDIAM  [DIAM]   : Endif     # IAS Accounting Journal Line

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

# X3 file linked to the migration process
If clalev([F:GTE])  = 0 : Local File =DOSSIER+".GTYPACCENT"  [GTE]    : Endif     # Document type
If clalev([F:ANM])  = 0 : Local File =DOSSIER+".ACODNUM"     [ANM]    : Endif     # Doc sequence numbers
If clalev([F:AVN])  = 0 : Local File =DOSSIER+".AVALNUM"     [AVN]    : Endif     # Sequence number values

If clalev([F:ADW])  = 0 : Local File =DOSSIER+".ADOVAL"      [ADW]    : Endif
Local Char ZONE1(30), ZONE2(30)
Raz ZONE1, ZONE2
Read [ADW]ADW0 = "";"";"SCHSAISIE"
If !fstat
 ZONE1 = [F:ADW]VALEUR
Endif
Read [ADW]ADW0 = "";"";"SCHSTDC"
If !fstat
 ZONE2 = [F:ADW]VALEUR
Endif

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_HAE (100) (adxwrb)
Local Char WTAB_DAE (100) (adxwrb)
Local Char WTAB_DAA (100) (adxwrb)
Local Shortint WCPT_HAE,WCPT_DAE,WCPT_DAA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Variables linked to the migration process
Local Integer ACCNUM_IAS, NBESSAI, STAT
Local Char    NUM_IAS
Local Char    MESSA(80), GMESSAGE(80)
#

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(4))

#-----  Link of Head Table & Line Table (except Analytic, including in For)
#-----  We don't have the line number in the key !
Link [DIAM] With [HIAM]HIA0~=[F:DIAM]TYP;[F:DIAM]NUM
&    As [LNK]
&    Where [F:HIAM]FLG=1
&    Order By Key CLE = [F:HIAM]CPY;[F:HIAM]TYP;[F:HIAM]NUM

# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTCPT02" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT02
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:HIAM]CPY='"+TABMIGKEY(1)+"' & [F:HIAM]TYP='"+TABMIGKEY(2)+"' & [F:HIAM]NUM>'"+TABMIGKEY(3)+"'"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:HIAM]CPY='"+TABMIGKEY(1)+"' & [F:HIAM]TYP>'"+TABMIGKEY(2)+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:HIAM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [HAE],[DAE],[DAA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:HIAM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(2)
  # By document type - Initialization of document sequence
  Raz [L]NUM_IAS
  Gosub INI_ANM
  If !GOK : Break 2 : Endif

  For [LNK]CLE(3)

   NBLUS+=1

   # EP to delete line
   If FILTRELIN
    FLUX="UUMGTRTCPT02" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
   Endif

   # By number - To Assign a new document number
   Raz [L]NUM_IAS
   Look [HAE]HAE0 = [F:HIAM]TYP;[F:HIAM]NUM
   If fstat
    [L]NUM_IAS = [F:HIAM]NUM
   Else
    Raz NBESSAI
    Gosub INI_NUM
    If !GOK | [L]NUM_IAS="" : Break 3 : Endif
   Endif

   # To Update GACCENTRY table - Header of Journal Entry
   Gosub MAJ30_HAE
   If GOK<1 : Break 3 : Endif

   For [LNK]CLE
    # To Update GACCENTRYD/GACCENTRYA tables - Lines of Journal Entry
    Gosub MAJ30_DAE
    If !GOK : Break 4 : Endif
   Next

   NB+=1
   If NB>GMAXUPDTRS
    TABMIGKEY(1)= [F:HIAM]CPY
    TABMIGKEY(2)= [F:HIAM]TYP
    TABMIGKEY(3)= [F:HIAM]NUM
    STOP=1
    Break 3
   Endif
  $SUITE_BOUCLE
  Next
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT02",7,ERR) From TRTMIG
Else
 Flush [F:HAE]
 If fstat
  Call ECR_TRACE("File GACCENTRY, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub HAE_ERRTRA :
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:DAE]
 If fstat
  Call ECR_TRACE("File GACCENTRYD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub DAE_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:DAA]
 If fstat
  Call ECR_TRACE("File GACCENTRYA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub DAA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(4)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT02",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT02
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [DAE], [DAA]
Close Local File [HIAM], [DIAM]
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"GACCENTRY",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GACCENTRYD",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"GACCENTRYA",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT02") From TRTMIG
Call ECR_TIME("UUMGTRTCPT02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$INI_ANM
If [F:HIAM]TYP<>[F:GTE]TYP
 Read [GTE]GTE0 = [F:HIAM]TYP
 If fstat
  # Reading error -  Non-existent  Journal Type
  Call ERREUR([F:HIAM]TYP-mess(17,114,1),4) From DOSDIC : GOK=0 : Return
 Endif
Endif
If [F:GTE]COU=""
 # Reading error - Non-existent  Sequence Number
 Call ERREUR([F:GTE]COU-mess(12,114,1),4) From DOSDIC : GOK=0 : Return
Else
 If [F:GTE]COU<>[F:AVN]CODNUM
  Read [ANM]ANM0 = [F:GTE]COU
  If fstat
   # Reading error - Non-existent  Sequence Number
   Call ERREUR([F:GTE]COU-mess(12,114,1),4) From DOSDIC : GOK=0 : Return
  Endif
 Endif
Endif
Return

$INI_NUM
Call NUMERO([F:GTE]COU,[F:HIAM]FCY,[F:HIAM]ACCDAT,[F:HIAM]JOU,[L]NUM_IAS,STAT) From SUBANM
If GOK<1 | STAT
 # Problem during the recovering of the sequence number
 Gosub MESSAGE From SUBANM
 GMESSAGE=mess(60,199,1)-"("+[F:GTE]COU+") : "+MESSA
 Call ERREUR(GMESSAGE,4) From DOSDIC
 GOK = 0 : Return
Endif

Look [HAE]HAE0 = [F:HIAM]TYP;[L]NUM_IAS
If !fstat : # It already exist, we take next
 NBESSAI += 1
 If NBESSAI>100 : # Still! We will not loop forever
  Call RSTA("ANM","#"+mess(78,106,1)) From GLOCK
  GOK = 0 : Return
 Else
  Goto INI_NUM
 Endif
Endif
Return

$MAJ30_HAE
If [L]NUM_IAS<>""
 #--- Transclass
 #Raz [HAE]  # expensive... must RAZ new V6 fields
 [HAE] = [HIAM]

 [F:HAE]NUM = [L]NUM_IAS
 [F:HAE]BPRVCR = [F:HIAM]NUM
 [F:HAE]BPRDATVCR = datesyst

 [F:HAE]FLGGEN = 2

 #--- New fields's assignation
 For IREF=1 To dim([F:GCM]LED)
  If [F:GCM]LED(IREF-1)<>""
   [F:HAE]LED(IREF-1)    = [F:GCM]LED(IREF-1)
   [F:HAE]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
   [F:HAE]RATDIV(IREF-1) = 1
   [F:HAE]RATMLT(IREF-1) = 1
  Else # useful to delete intruction RAZ
   [F:HAE]LED(IREF-1)    = ""
   [F:HAE]CURLED(IREF-1) = ""
   [F:HAE]RATDIV(IREF-1) = 0
   [F:HAE]RATMLT(IREF-1) = 0
  Endif
 Next

 #--- Initialization of gererals fields
 [F:HAE]CAT    = 1
 [F:HAE]STA    = 2
 [F:HAE]TYPRAT = 1
 [F:HAE]CUR    = [F:GCM]CUR([L]LEDGENMAIN-1)

 #--- A problem - we must have a IAS transaction    ... warning !!
 [F:HAE]DACDIA = ZONE1
 If [F:HAE]DACDIA=""
  [F:HAE]DACDIA = ZONE2
 Endif

 Gosub WRI_HAE
Endif
Return


$MAJ30_DAE
#--- Transclass
#Raz [F:DAE]    # expensive... must RAZ a new field V6
[F:DAE] = [F:DIAM]
[F:DAE]NUM = [L]NUM_IAS

#--- New fields's assignation
# Renamed field
[F:DAE]LIN    = [F:DIAM]LIG

# News fields
[F:DAE]IDTLIN  = num$([F:DAE]LIN)  # Journal Entry transaction are "Colum" entry type
[F:DAE]FIY     = [F:HIAM]FIY
[F:DAE]PER     = [F:HIAM]PER
[F:DAE]LEDTYP  = [L]TYPIAS
[F:DAE]LED     = [L]LEDIAS
[F:DAE]COA     = [L]COAIAS
[F:DAE]CURLED  = [F:GCM]CUR([F:DAE]LEDTYP-1)
[F:DAE]AMTLED  = [F:DIAM]AMTLOC
Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)  # It must initialize a new ACCNUM
[F:DAE]ACCNUMORI = 0
[L]ACCNUM_IAS = [F:DAE]ACCNUM

Gosub WRI_DAE
If GOK<1 : Return : Endif

If [F:DIAM]SCT1<>"" or [F:DIAM]SCT2<>""
 # To Save on DAA
 Raz [DAA]   # We keep RAZ (Analytic & IAS : 24 fiels on DAA)
 # Transclass... Initialization relative to DAE
 [DAA] = [DAE]
 [F:DAA]ANALIN+=1
 [F:DAA]DIE(0) = [L]AXEI(1)
 [F:DAA]CCE(0) = [F:DIAM]SCT1
 [F:DAA]DIE(1) = [L]AXEI(2)
 [F:DAA]CCE(1) = [F:DIAM]SCT2
 [F:DAA]AMTLED = [F:DIAM]AMTLOC
 Gosub WRI_DAA
 If GOK<1 : Return : Endif

 # Management of Automatic ledgers at the same time (recovering of the forced amount...)
 If [L]TYPAUTIAS
  [F:DAA]LEDTYP  = [L]TYPAUTIAS
  [F:DAA]CURLED  = [F:GCM]CUR([F:DAA]LEDTYP-1)
  [F:DAA]AMTLED  = [F:DIAM]AMTRPT
  Gosub WRI_DAA
  If GOK<1 : Return : Endif

  # Management of Automatic ledgers at the same time (ACCNUM assignation & recovering of the forced amount...)
  [F:DAE]LEDTYP = [L]TYPAUTIAS
  [F:DAE]CURLED = [F:GCM]CUR([F:DAE]LEDTYP-1)
  [F:DAE]AMTLED = [F:DIAM]AMTRPT
  Call ACCNUM_DAE(DOSSIER,[F:DAE]ACCNUM)  # It must initialize a new ACCNUM
  [F:DAE]ACCNUMORI = [L]ACCNUM_IAS
  Gosub WRI_DAE
  If GOK<1 : Return : Endif
 Endif
Endif
Return

Subprog ACCNUM_DAE(DOS,NUM)
Value Char DOS()
Variable Integer NUM
Local File =[L]DOS+".GACCENTRYD" [DAE]
NUM = uniqid([F:DAE])
End

# Write Instruction
$WRI_HAE
# To Save reference
Gosub HAE_STK
WriteB [F:HAE]
If fstat
 Call ECR_TRACE("File GACCENTRY, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub HAE_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_DAE
# To Save reference
Gosub DAE_STK
WriteB [F:DAE]
If fstat
 Call ECR_TRACE("File GACCENTRYD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub DAE_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_DAA
# To Save reference
Gosub DAA_STK
WriteB [F:DAA]
If fstat
 Call ECR_TRACE("File GACCENTRYA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub DAA_ERRTRA
 GOK=0 : Return
Endif
Return

##############################################################################################
$HAE_STK
Call STK (WTAB_HAE,WCPT_HAE,[F:HAE]TYP-'/'-[F:HAE]NUM) From TRTMIG
Return
$DAE_STK
Call STK (WTAB_DAE,WCPT_DAE,[F:DAE]TYP-'/'-[F:DAE]NUM-'/'-num$([F:DAE]LIN)-'/'-num$([F:DAE]LEDTYP)) From TRTMIG
Return
$DAA_STK
Call STK (WTAB_DAA,WCPT_DAA,[F:DAA]TYP-'/'-[F:DAA]NUM-'/'-num$([F:DAA]LIN)-'/'-num$([F:DAA]LEDTYP)-'/'-num$([F:DAA]ANALIN)) From TRTMIG
Return
##############################################################################################
$HAE_ERRTRA
Call ERRTRA (WTAB_HAE,WCPT_HAE,"File GACCENTRY(TYP/NUM)=") From TRTMIG
Return
$DAE_ERRTRA
Call ERRTRA (WTAB_DAE,WCPT_DAE,"File GACCENTRYD(TYP/NUM/LIN/LEDTYP)=") From TRTMIG
Return
$DAA_ERRTRA
Call ERRTRA (WTAB_DAA,WCPT_DAA,"File GACCENTRYA(TYP/NUM/LIN/LEDTYP/ANALIN)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT02(APPLI)
End

