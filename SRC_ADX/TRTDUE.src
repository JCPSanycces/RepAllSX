#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char    PARAM(10)(1..2)
Local Integer VALEUR
Call TRAITE_LIB([L]VALEUR,[L]PARAM,"","TRTDUE","DTRTDUE",4,"") From GTRAITE
End

$ACTION
Case [L]ACTION
 When "INIT"     : Goto INIT
 When "CONTROLE" : Goto CONTROLE
 When "EXEC"     : Goto EXEC
 When "TERMINE"  : Goto TERMINE
 When "SORTIE"   : Gosub SORTIE
#-------------------------------------------------------------------------------
 When "DEBUT"    : Gosub DEBUT
 When "BOUTON"   : Gosub BOUTON From EXTRDUE :#81085
Endcase
Return

################################################################################
#
# GTRAITE
#
################################################################################
$INIT
Local Integer STAT, MAXFIL
Local Char    CRITERE(250), SYMBOLE(50)

Global Integer GMAXDPAE
GMAXDPAE =100

If !clalev([F:ADI])   : Local File ATABDIV   [ADI]    : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]     : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR]  : Endif
If !clalev([F:FEH])   : Local File FILEDIH   [FEH]    : Endif
If !clalev([F:DUE])   : Local File DUEEMP    [DUE]    : Endif
If !clalev([F:HRPOA]) : Local File POPULA    [HRPOA]  : Endif
If !clalev([F:CPY])   : Local File COMPANY   [CPY]    : Endif
If !clalev([F:FCY])   : Local File FACILITY  [FCY]    : Endif
If !clalev([F:BPAF])  : Local File BPADDRESS [BPAF]   : Endif
If !clalev([F:BPAC])  : Local File BPADDRESS [BPAC]   : Endif
If !clalev([F:FEL])   : Local File FILEDIL   [FEL]    : Endif
If !clalev([F:FGR])   : Local File FACGROUP2 [FGR]    : Endif

Local Mask TRTDUE [TDUE]
Raz [M:TDUE]

[L]MAXFIL=int(10*1024*1024/990) : # 10 Mo / 990 octets par ligne => nb lignes

#81085
Call LECMEMO("STD","[M:TDUE]","due2") From GMEMO
Call AFF_MEMO From DIVPAYE
Return

###########################################
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#83271
GCURLEG="FRA"
If dim([M:TDUE]LEG)>=0 : [M:TDUE]LEG=GCURLEG : Endif
#end 83271
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
#92870
If [M:TDUE]TYPEXP = 1
  Grizo [M:TDUE]FIL
Else
  Actzo [M:TDUE]FIL
Endif
#81085
Affzo [M:TDUE]
Setmok [TDUE] With 0
Call AFF_MEMO From DIVPAYE
Return

###########################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Call DELOCK("DUE") From GLOCK
Return

#-------------------------------------------------------------------------------
$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif

[L]TMP=1
[L]TIT=mess(11,10721,1) : # Génération des DUE
If [V]GSERVEUR | 1 : [L]TRA=1 : Endif

Gosub OUVRE From WPDEFTABLE

If dim([M:TDUE]LEG)>=0 : GCURLEG=[M:TDUE]LEG : Endif :#because superviseur did GCURLEG = SAVCURLEG in GSAISIE

If [M:TDUE]FILFLG<>2      : [L]CRITERE='find(STA,2,5)<>0'
Else                        [L]CRITERE='STA=3'
Endif
If [M:TDUE]DATDEB>[0/0/0] : [L]CRITERE-='& CTRDAT>=['+num$([M:TDUE]DATDEB)+']' : Endif
If [M:TDUE]DATFIN>[0/0/0] : [L]CRITERE-='& CTRDAT<=['+num$([M:TDUE]DATFIN)+']' : Endif
If [M:TDUE]MATDEB>""      : [L]CRITERE-='& REFNUM>="'+[M:TDUE]MATDEB+'"'       : Endif
If [M:TDUE]MATFIN>""      : [L]CRITERE-='& REFNUM<="'+[M:TDUE]MATFIN+'"'       : Endif
If [M:TDUE]ALLFCY<>2      : [L]CRITERE-='& [HRCTR]ETRFCY="'+[M:TDUE]FCY+'"'      : Endif
If [M:TDUE]ALLSRV<>2      : [L]CRITERE-='& [HRCTR]ETRSRV="'+[M:TDUE]SRV+'"'      : Endif
If [M:TDUE]ALLPRF<>2      : [L]CRITERE-='& [HRCTR]PROPRF="'+[M:TDUE]PRF+'"'      : Endif
CRITERE-= '& [HRCTR]FLGRET<>2'


If [M:TDUE]CPY<>""
 If [M:TDUE]POP<>""
  Link [DUE] With [ID]ID0   =REFNUM
&               , [HRCTR]CTR0 =REFNUM;CTRNUM;CTRDAT
&               , [HRPOA]POA0~=[M:TDUE]POP;REFNUM
&               , [FGR]FGR0~=[M:TDUE]CPY;[HRCTR]ETRFCY
&              As [DUEK]
&           Where evalue([L]CRITERE)
 Else
  Link [DUE] With [ID]ID0   =REFNUM
&               , [HRCTR]CTR0 =REFNUM;CTRNUM;CTRDAT
&               , [FGR]FGR0~=[M:TDUE]CPY;[HRCTR]ETRFCY
&              As [DUEK]
&           Where evalue([L]CRITERE)
 Endif

Else

 If [M:TDUE]POP<>""
  Link [DUE] With [ID]ID0   =REFNUM
&               , [HRCTR]CTR0 =REFNUM;CTRNUM;CTRDAT
&               , [HRPOA]POA0~=[M:TDUE]POP;REFNUM
&              As [DUEK]
&           Where evalue([L]CRITERE)
 Else
  Link [DUE] With [ID]ID0   =REFNUM
&               , [HRCTR]CTR0 =REFNUM;CTRNUM;CTRDAT
&              As [DUEK]
&           Where evalue([L]CRITERE)
 Endif
Endif

Link [FCY] With [CPY]CPY0    =[FCY]LEGCPY
&             , [BPAF]BPA0(2)=3;FCY
&             , [BPAC]BPA0(2)=2;[FCY]LEGCPY
&            As [FCYK]
&         Where [FCY]LEG=GCURLEG & [BPAF]CRY="FR" & [BPAC]CRY="FR"
&  Order By Key CLE=FCY;[BPAF]BPAADDFLG Desc;[BPAC]BPAADDFLG Desc

Return

#-------------------------------------------------------------------------------
$EXEC
If [L]TRA
 If ![V]GSERVEUR
  Call OUVRE_TRACE([L]TIT) From LECFIC
# Else
  Call ECR_TRACE([L]TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

[L]OK=-1
For [DUEK]DUE0
 If [L]OK>GMAXDPAE
  If [L]TRA
   #Nombre maximum de DPAE atteint. La génération de fichiers supplémentaires sera nécessaire.
   Call ECR_TRACE(num$(GMAXDPAE)-':'-mess(25,10721,1) ,-1) From GESECRAN
  Else
   [V]GMESSAGE=num$(GMAXDPAE)-':'-mess(25,10721,1)
  Endif
  Break
 Endif
 Call CONTROLE( [F:DUE]REFNUM,[F:DUE]CTRDAT,[F:DUE]CTRNUM,[M:TDUE]CRI,[L]STAT,0
&             ) From DIVPAYE
 #58832
 # Un salarié provisoire n'est pas flagué ENAFLG
 If [L]STAT & [F:ID]ENAFLG<>2 & [F:ID]FLGNEWSAL<>2
  [L]STAT = 0
 Endif
 # fin 58832

 #83271
 If [L]STAT
   Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   If dim([F:CPY]LEG)>0 &  [F:CPY]LEG<>GCURLEG
    [L]STAT = 0
   Endif
 Endif
 #end 83271

 If [L]STAT
  [L]SYMBOLE="DUE"+[F:DUE]CTRNUM+"\"+[F:DUE]REFNUM+"\"+num$([F:DUE]CTRDAT)
  Lock =[L]SYMBOLE
  If fstat : [L]OK=0 : Elsif [L]OK=-1 : [L]OK=1 : Else [L]OK+=1 : Endif
  If fstat
   Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
   If [L]TRA
    Call ECR_TRACE([F:DUE]REFNUM-[F:DUE]CTRNUM-format$([V]GFMD,[F:DUE]CTRDAT)+"\"+[V]GMESSAGE,1) From GESECRAN
    [V]GMESSAGE=""
   Else
    Break
   Endif
  Endif
 Endif
Next

If [L]OK=-1
 If [L]TRA
  Call ECR_TRACE(mess(4,10721,1) ,1) From GESECRAN : # Aucun salarié à déclarer
 Else
  [V]GMESSAGE=mess(4,10721,1) : # Aucun salarié à déclarer
 Endif
 [L]OK=0
Elsif [L]OK>[L]MAXFIL
 If [L]TRA
  Call ECR_TRACE( func AFNC.MES2(mess(12,10721,1),num$([L]OK),num$([L]MAXFIL)),1
&               ) From GESECRAN
  #               Fichier trop grand : $1$ fiches sélectionnées pour un maximum de $2$
 Else
  [V]GMESSAGE=func AFNC.MES2(mess(12,10721,1),num$([L]OK),num$([L]MAXFIL))
  #           Fichier trop grand : $1$ fiches sélectionnées pour un maximum de $2$
 Endif
 [L]OK=0
Else
 [L]OK=1
Endif

If ![L]OK
 Call DELOCK("DUE") From GLOCK
 If ![L]TRA : [V]GERR=1 : [L]SAI=1 : Endif
 Return
Endif

Call EMISSION([L]TRA)

Kill GMAXDPAE
Return

#-------------------------------------------------------------------------------
$TERMINE
If ![V]GSERVEUR & [L]TRA
 Call FERME_TRACE From LECFIC
Endif
If ![L]OK & [L]TRA : [L]SAI=1 : Endif
Return

################################################################################
#
# Routines
#
################################################################################

Subprog EMISSION(TRA)
#56523
#Value Integer TRA
Variable Integer TRA

Local Integer STAT, NBERR, I
Local Char    MATRI([V]GLONEML), FEH([V]GLONADI), CTR([V]GLONHRCTR)
Local Char    FICHIER([V]GDIMFIC), FICCLI([V]GDIMFIC), OLDFCY(GLONFCY) :# 58887
Local Date    DATMAT

Local Integer NBRDUE

[L]FEH="DUE"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
Gosub DEFVAR

[L]EMISSION=1

[L]FICHIER=[M:TDUE]FIL
If [M:TDUE]TYPEXP=2
 [L]FICHIER=filpath([V]GDIRBQE,[M:TDUE]FIL,"due",0)
Else
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]MATRI) From ORDSYS
Endif

Call DEBTRANS From GLOCK

$TR_EMISSION
[V]GOK=1
Trbegin [DUE]
 Gosub ECRITURE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN : Else Goto TR_EMISSION : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN
 Endif
Commit

#-------------------------------------------------------------------------------
$FIN
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM

If [M:TDUE]TYPEXP<2
 Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
 #56523
 If [L]STAT<>0 : [L]TRA = 0 : Endif
Endif

End

#-------------------------------------------------------------------------------
$DEFVAR
Local Char    DATFMT(8), SAVIRS(2), SAVIFS(1)
Local Libelle SAVIUM

[L]DATFMT  ="DDMMYYYY"
[L]SAVIRS  =adxirs
[L]SAVIFS  =adxifs
[L]SAVIUM  =adxium
adxirs     =chr$(10)
adxifs     =""
adxium     =[V]GASCII
Return

#-------------------------------------------------------------------------------
$ECRITURE

Openo [L]FICHIER, 0 Using [OPO]

#58887
#Filter [DUEK] Order By Key CLE=[HRCTR]ETRFCY
Filter [DUEK] Order By Key CLE=[HRCTR]ETRFCY;[F:HRCTR]REFNUM

Columns [FEH] (LOC,LNG,ZON)
For [DUEK]CLE(1)
 Read [FCYK]CLE(1)=[F:HRCTR]ETRFCY
 If !fstat
  For [DUEK]CLE

   If [L]NBRDUE>=GMAXDPAE : Break 2 : Endif

   Call CONTROLE( [F:DUE]REFNUM,[F:DUE]CTRDAT,[F:DUE]CTRNUM,[M:TDUE]CRI,[L]STAT,0
&               ) From DIVPAYE
   #58832
   # Un salarié provisoire n'est pas flagué ENAFLG
   If [L]STAT & [F:ID]ENAFLG<>2 & [F:ID]FLGNEWSAL<>2
    [L]STAT = 0
   Endif
   # fin 58832

   #83271
   If [L]STAT
     Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     If dim([F:CPY]LEG)>0 &  [F:CPY]LEG<>GCURLEG
      [L]STAT = 0
     Endif
   Endif
   #end 83271

   If [L]STAT

    If [F:DUE]STA<>3
     Readlock [DUE]DUE0 =
     If fstat=1
      [V]GOK  =-1
      [V]GLOCK="$DUEEMP"-[F:DUE]REFNUM-[F:DUE]CTRNUM-num$([F:DUE]CTRDAT)
      Break 2
     Elsif fstat
      [V]GOK=0
      Call RSTA("DUE",[F:DUE]REFNUM-[F:DUE]CTRNUM-num$([F:DUE]CTRDAT)) From GLOCK
      Break 2
     Endif
    Endif

    If [M:TDUE]CRI=""
     [L]MATRI =[F:DUE]REFNUM
     [L]CTR   =[F:DUE]CTRNUM
     [L]DATMAT=[F:DUE]CTRDAT
     Gosub LECEMP From WPDEFTABLE
    Endif

    Gosub EMISSION From =[L]FEHTRT

    If [L]TRA
     Call ECR_TRACE("",0) From GESECRAN
     #58887
     #Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
     If OLDFCY<>[F:HRCTR]ETRFCY
      Call ECR_TRACE(mess(12,105,1)-[F:HRCTR]ETRFCY,0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      OLDFCY = [F:HRCTR]ETRFCY
     Endif
     Call ECR_TRACE( [F:DUE]REFNUM-[F:ID]NAM-[F:ID]SRN-[F:DUE]CTRNUM
&                  - format$([V]GFMD,[F:DUE]CTRDAT)-format$("K:##[:]##",[F:DUE]ETRTIM),0
&                  ) From GESECRAN
    Endif

    [L]NBERR=0
    If [F:DUE]STA<>3
     Onerrgo ERREURWW
     Gosub CONTROLE From =[L]FEHTRT
     Onerrgo
    Endif

    If ![L]NBERR
     I=adxseek("OPO")
     For [FEH]FEH0 Where FEH=[L]FEH
      If [F:FEH]ZON=""
       Wrseq space$([F:FEH]LNG); Using [OPO]
      #58649 : un numérique a traiter comme un alph : cadrage à gauche
      Elsif [F:FEH]ZON="LIGLNG"
       Wrseq left$(num$(evalue("[L]"+[F:FEH]ZON)),[F:FEH]LNG); Using [OPO]
       Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
      #
      Else
       Case evalue("type([L]"+[F:FEH]ZON+")")
       When 1,2,4,8,5,6,7,9
        Wrseq format$("N:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
       When 3
        Wrseq format$("D:"+[L]DATFMT,evalue("[L]"+[F:FEH]ZON)); Using [OPO]
       When Default
        Wrseq left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG); Using [OPO]
       Endcase
       Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
      Endif
     Next
     Wrseq Using [OPO]

     If [F:DUE]STA<>3
      Gosub MAJFIC From =[L]FEHTRT
      [F:DUE]STA=3 : # Attente CIRSO
      Rewrite [DUE] Curr
      If fstat
       [V]GOK=0
       Call FSTA("DUE") From GLOCK
       Break 2
      Endif
     Endif
     [L]NBRDUE+=1
    Endif
   Endif
  Next
 Endif
Next
Filter  [DUEK]
Columns [FEH]
Openo Using [OPO]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Openo Using [OPO]
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Goto FIN

################################################################################
#
# Etiquettes de l'écran TRTDUE
#
################################################################################

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If [V]GBATCH & [L]VALEUR<2
 [V]GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat     =2
 End
Endif

If [L]VALEUR=2 : Actzo [TDUE] FIL
Else             Grizo [TDUE] FIL
Endif

End

########################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If [L]VALEUR<2
 Call SET_NAMCLI([M:TDUE]FIL) From ORDSYS
Endif

End

########################################
Subprog C_FIL(VALEUR)
Variable Char    VALEUR()
Local Integer OK

Call C_NOMEXP([L]VALEUR,"due")
If mkstat=2 : End : Endif

Call EXISTE(filpath([V]GDIRBQE,[L]VALEUR,"due",0),[L]OK) From ORDSYS
If [L]OK
 [V]GMESSAGE=mess(132,133,1) : # Fichier déjà existant
 [V]GERR    =3
 End
Endif

End

Subprog C_NOMEXP(VALEUR, EXT)
Variable Char VALEUR()
Value Char EXT()
Local Integer ER , K
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Char    NAM(GDIMFIC) , SUF(30)
If VALEUR=""
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat=1 : End
Elsif left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif

If instr(1,VALEUR,".")
 #59562 Pb si le chemin contient '.'
 #[L]VALEUR = left$(VALEUR,instr(1,VALEUR,".")-1)
 Call SETNAM(VALEUR,NAM,SUF) From GOBJTXT
 If SUF<>""
  [L]VALEUR = left$(VALEUR,instr(1,VALEUR,"."+SUF)-1)
 Endif
 #
Endif

Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Endif
Raz ER
Call EXISTE(VALEUR,ER) From ORDSYS
Case ER
 When 2 : # répertoire
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : End
 When 0 : # fichier
  Call ABSOLU(VALEUR,ER) From ORDSYS
  If ER
   [L]FICHIER=filpath([V]GDIRBQE,VALEUR,EXT,0)
  Else
   [L]FICHIER = VALEUR
  Endif
  Call SETNAM([L]FICHIER,NAM,SUF) From GOBJTXT
  If SUF<>""
   NAM += "."+SUF
  Endif
  REPERT = left$([L]FICHIER,instr(1,FICHIER,NAM)-1)
  Call EXISTE(REPERT,ER) From ORDSYS
  If ER<>2
   #59562
   #GMESSAGE = mess(9,141,1) : # Répertoire inexistant
   Onerrgo ERRACSCLI
   Openi FICHIER Using [ATST]
   Openi Using [ATST]
   Onerrgo
   If ER=0 or ER=27
    GMESSAGE = mess(147,141,1) : #Répertoire inaccessible
   Else
    GMESSAGE = mess(9,141,1) : # Répertoire inexistant
   Endif
   mkstat = 2 : End
  Endif
Endcase
End

$ERRACSCLI
ER = errn
Resume
######################################################################################

