##*==================================================================
#**** 11/2004 Attention, on ne traite pas encore les association
#**** pour l'objet-métier Subventions
#*===================================================================
#**************************************************************************************
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("RDE",GBIDC1,GBIDC2) From GOBJET
End
#********************************************************************
$ACTION

Case ACTION
  When "OUVRE"               : Gosub OUVRE
  When "VERROU"              : Gosub VERROU
  When "DEVERROU"            : Gosub DEVERROU
  When "RAZCRE"              : Gosub RAZCRE
  When "RAZDUP"              : Gosub RAZDUP
  When "LIENS"               : Gosub LIENS
  When "CREATION"            : Gosub CREATION
  When "AVANT_MODFIC"        : Gosub AVANT_MODFIC
  When "MODIF"               : Gosub MODIF
  When "AVANT_MOD"           : Gosub AVANT_MOD
  When "APRES_MODIF"         : Gosub APRES_MODIF
  When "INIMOD"              : Gosub INICRE
  When "INICRE"              : Gosub INICRE
  When "VERF_ANU"            : Gosub VERF_ANU
  When "SETBOUT"             : Gosub SETBOUT
  When "AVANTBOUT"           : Gosub AVANTBOUT
  When "APRES_CHOI"          : Gosub APRES_CHOI
  When "FIN"                 : Gosub FIN
  When Default
Endcase

Return
#********************************************************************
$OUVRE

# Déclaration de variables
Local Char    SYMBRVA(20)
Local Char    SYMBCNX(20)
Local Integer VERROU_RVA
Local Integer VERROU_CNX
Local Integer OUINON                 : # réponse call OUINON
Local Integer STAT                   : # réponse call VERFALLCPY
Local Char    L_CPY(GLONCPY)         : # société pour contrôle habilitation

# Déclaration des tables

If clalev([F:WRDE])=0 : Local File RUBASSDEF [WRDE] : Endif   # définition des associations
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif   # tables diverses
If clalev([F:ATX])=0  : Local File ATEXTE    [ATX]  : Endif   # textes
If clalev([F:ATZ])=0  : Local File ATABZON   [ATZ]  : Endif   # champs
If clalev([F:AST])=0  : Local File APLSTD    [AST]  : Endif   # messages applicatifs
If clalev([F:FRF])=0  : Local File FREFLD    [FRF]  : Endif   # zones libres
If clalev([F:RVA])=0  : Local File RUBASSVAL [RVA]  : Endif   # associations-valeurs
If clalev([F:AMZB])=0 : Local File AMSKZON   [AMZB] : Endif   # Dictionnaire des champs écran


Return
#********************************************************************
$VERROU


Local Char LLOCK(200)

# On positionne un symbole pour locker l'ensemble des valeurs correspondant
# à l'association
SYMBRVA ="RVA"+num$([M:RDE1]REFOBJ)+num$([M:RDE1]DETAAS)+[M:RDE1]ACM+[M:RDE1]CPY
Lock = SYMBRVA With lockwait = 0
If !fstat
  VERROU_RVA = 1
Else
  VERROU_RVA = 0
Endif

# Si quelqu'un est positionné sur un contexte de la société de définition de l'association
# on bloque la mise à jour de l'association
If VERROU_CNX = 0
  If func GLOBIENS.IS_SYMBOLE_LOCKED ("CNX", [M:RDE1]CPY, "") = 0
    OK = 0
    GMESSAGE = mess(104,GML_MSGFASPR,1)-G_MSGQUILOCK
    Return
  Else
    # On positionne un symbole pour locker l'ensemble des valeurs correspondant
    # à l'association
    SYMBCNX ="CNX"+[M:RDE1]CPY
    Lock = SYMBCNX With lockwait = 0
    If !fstat
      VERROU_CNX = 1
    Else
      VERROU_CNX = 0
    Endif
  Endif
Endif


Return
#-------------------------------------------------------------------------------
$DEVERROU
Local Char LLOCK(200)

If VERROU_RVA
 Unlock = SYMBRVA
 VERROU_RVA = 0
Endif

If VERROU_CNX
 Unlock = SYMBCNX
 VERROU_CNX = 0
Endif

# on déverouille les contextes de la société
Call UNLOCK_SYMBOLE("CNX", [M:RDE1]CPY, "") From GLOBIENS


Return
#-------------------------------------------------------------------------------
$AVANT_MOD
# Contrôle habilitation / société
L_CPY=[M:RDE1]CPY
Gosub AUZ_CPY
Return

$APRES_MODIF
# Contrôle habilitation / société
If COUZON="CPY"
  L_CPY=CZ
  Gosub AUZ_CPY
Endif
Return
#-------------------------------------------------------------------------------
$AUZ_CPY
# Fonction de contrôle de l'habilitation / société
If GNBAUZ <> GNBSITE : # Pas d'habilitation tous sites
  If L_CPY <> ""
    mkstat=0
    Call CONTALLFCY(L_CPY) From SUPCPT
    If mkstat : OK=0 : mkstat=0 : Endif
  Else
    # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
    OK=0 : GMESSAGE=mess(113,GML_MSGFASPR,1)
  Endif
Endif
Return
#-------------------------------------------------------------------------------
$SETBOUT

If CLECUR CHAINE+="A"
Endif

If GREP = "C" or GREP="M" or !CLECUR
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif


# Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
  If [M]CPY="" & GNBAUZ <> GNBSITE
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
# Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
    Call VERFALLFCY([M:RDE1]CPY,[L]STAT) From SUPCPT
    If [L]STAT < 1 : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
  Endif

Return
#********************************************************************
$AVANTBOUT

Case BOUT
When "V"
  [M:RDE1]NUMASS= sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY )
Endcase

Return
#********************************************************************
$FIN

Gosub DEVERROU

Return
#********************************************************************
$RAZCRE

  Raz [M:RDE1]

Return
#********************************************************************
$RAZDUP


Return
#********************************************************************
$LIENS
Local Integer      I, J, NEWPLAN, GERE
Local Char         TEXTE(30), TEXTE2(30), WENTITE
Local Char         LTEXTE, LTEXTE2
Local Char         CODFIC(10)
Local Char         ZONE(30)
Local Char         LANGUE
Local Char         IDENT1(30)
Local Char         IDENT2(30)
Local Shortint     WLANNUM

NEWPLAN=0
#*-----------------------------------------------------------
#* Lecture des déterminés dans la table RUBASSDEF(RDE)
#*-----------------------------------------------------------
#*
# FQ69690B
If TUNNEL
  Read [RDE]RDE0 = [M:RDE1]REFOBJ; [M:RDE1]DETAAS; [M:RDE1]ACM; [M:RDE1]CPY
Endif

For nolign= 1 To [F:RDE]NBRUB0
  If  nolign=1
    [M:RDE1]ENTITE(nolign-1) = mess([M:RDE1]REFOBJ,GML_OBJMETIE,1)  # libellé objet métier (ML 341)
  Endif

  If [F:RDE]RUBRAS(nolign-1) <> ""
   [M:RDE1]RUBRAS(nolign-1) = [F:RDE]RUBRAS(nolign-1)
   #*---------------------------------------------------------------------
    #* Récupération de l'intitulé des zones libres dans la table FREFLD
    #*---------------------------------------------------------------------
    If left$([F:RDE]RUBRAS(nolign-1),6)="USRFLD"
      CODFIC = "FREFLD"
      IDENT1 = num$([M:RDE1]REFOBJ)
      IDENT2 = [M:RDE1]CPY
      ZONE   = [M:RDE1]RUBRAS(nolign-1)
    Else
      #*-----------------------------------------------------------------------------------------------------------------
      #* sinon, on recherche l'intitulé dans la table diverse 961 (GTD_ASSORUB): table des rubriques déterminées
      #*-----------------------------------------------------------------------------------------------------------------
      CODFIC = "ATABDIV"
      ZONE   = "LNGDES"
      IDENT1 = num$(GTD_ASSORUB)
      IDENT2  = [M:RDE1]RUBRAS(nolign-1)
    Endif
    Call LECTEXTRA (LTEXTE, CODFIC, ZONE, IDENT1, IDENT2) From ATEXTRA
    If LTEXTE<>""
      [M:RDE1]INTIT(nolign-1)  = LTEXTE
    Else
      #*--------------------------------------------------------------------------------------------------------------
      #* si la recherche de l'intitulé de la zone libre a échouée pour la société que l'on traite, on récupère
      #* le libellé dans la société par défaut
      #*---------------------------------------------------------------------------------------------------------------------
      Call LECTEXTRA (LTEXTE2, CODFIC, ZONE, IDENT1, "") From ATEXTRA
      [M:RDE1]INTIT(nolign-1)  = LTEXTE2
    Endif
  Endif
Next

#*
#* si l'objet est le Bien Comptable lecture des déterminés/plan
#*
If  [M:RDE1]REFOBJ = GVML_OMBIEN
  #*------------------------------------------------------------------------------------------------
  #* on réinitialise nolign avec le nombre de rubriques  déterminées (NBRUB0) + 2 lignes
  #* pour afficher les rubriques/plan après les rubriques hors plan
  #* sinon on initialise nolign à 2 pour afficher les rubriques/plan en début de tableau
  #*------------------------------------------------------------------------------------------------
  nolign = NBRUB0+2
  #*----------------------------------------------------------------------------------
  #* Recherche des plans existants dans le Menu Local 301
  #*----------------------------------------------------------------------------------
  For WLANNUM = 1 To 15
    WENTITE = mess(82,GML_MSGFASPR,1)-mess(WLANNUM,GML_NPLAN,1)
  #*------------------------------------------------------------------
  #* récupération des plans gérés pour la société saisie
  #*------------------------------------------------------------------
    If [M:RDE1]CPY <> ""
      If func GLOBIENS.CPY_PLN_GERE([M:RDE1]CPY,WLANNUM)=G_NON
        GERE=G_NON
      Else
        GERE = G_OUI
      Endif
    Else
      GERE = G_OUI
    Endif

    If GERE = G_OUI
      Read [RDP]RDP0=[M:RDE1]REFOBJ;[M:RDE1]DETAAS;[M:RDE1]ACM;[M:RDE1]CPY;WLANNUM
      If fstat = 0
        #*-------------------------------------------------------------------------------
        #* si un contexte est géré et que l'association existe déjà pour le plan
        #* on affiche les rubriques
        #*
        [M:RDE1]ENTITE(nolign-2) = WENTITE
        [M:RDE1]DPRPLN(nolign-2) = [F:RDP]DPRPLN
        [M:RDE1]MGTFLG(nolign-2)  =   G_NON
        [M:RDE1]UPDFLG(nolign-2)  =   G_NON
        [M:RDE1]FRCFLG(nolign-2)  =   G_NON
        For I = 0 To 8
          If [F:RDP]RUBRASP(I) <> ""
            [M:RDE1]RUBRASP(nolign-1)  = [F:RDP]RUBRASP(I)
            [M:RDE1]DPRPLN(nolign-1)   = [F:RDP]DPRPLN
            # WPLN est un champ invisible contenant le n° du plan
            [M:RDE1]WPLN(nolign-1)     = [F:RDP]DPRPLN
            #*-------------------------------------------------------------------------------
            #* Récup. de l'intitulé (LNGDES) de chaque poste de la table diverse 951
            #*
            Call LECTEXTRA (TEXTE, "ATABDIV", "LNGDES", num$(GTD_ASSORUB), [F:RDP]RUBRASP(I)) From ATEXTRA
            [M:RDE1]INTIT(nolign-1)   = TEXTE
            [M:RDE1]MGTFLG(nolign-1)  =   [F:RDP]MGTFLGP(I)
            [M:RDE1]UPDFLG(nolign-1)  =   [F:RDP]UPDFLGP(I)
            [M:RDE1]FRCFLG(nolign-1)  =   [F:RDP]FRCFLGP(I)
          Else
            Break
          Endif
          nolign+=1
        Next I
        nolign+=1
      Else
        #-------------------------------------------------------------------------
        #* si nouveau contexte : affichage des nouveaux plans gérés et création
        #* des enreg. correpondants dans RUBASSDEFP
        #*
        nolign-=1
        NEWPLAN=1
        Gosub AFFICH_PLAN
        nolign+=1
        NEWPLAN=0
        #--------------------------------------------------------------------------
      Endif
    Endif
  Next
Endif

[M:RDE1]NBRUB = nolign-1

Affzo [M:RDE1]NBRUB
Actzo [M:RDE1]NBRUB

[M:RDE1]NUMASS= sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY )

If [M:RDE1]NBRUB0 > 0
  For nolign = [M:RDE1]NBRUB0 To [M:RDE1]NBRUB+1
    If ([M:RDE1]ENTITE(nolign-1)<> "")  or ([M:RDE1]INTIT(nolign-1)= "")
      Diszo[M:RDE1]MGTFLG(nolign-1)
      Diszo[M:RDE1]UPDFLG(nolign-1)
      Diszo[M:RDE1]FRCFLG(nolign-1)
    Endif
  Next
Endif

#> Chargement du masque de travail contenant le paramétrage comptable de la société
If [M:RDE1]CPY <> ""
 Raz [M:FPC]
 Local Integer ERR
 Call LOAD_FASPARCPY([M:RDE1]CPY,"",G_NON,ERR) From GLOFCYCPY
Endif

Read [GCM]GCM0=[M:RDE1]ACM
If fstat=0
   # FQ61528
   # [M:RDE1]LEG = [F:GCM]LEG
   If (dim([M:RDE1]LEG)>0) Then : [M:RDE1]LEG = [F:GCM]LEG : Endif
Endif

# FQ61528
# Affzo [M:RDE1]LEG
If (dim([M:RDE1]LEG)>0) Then : Affzo [M:RDE1]LEG : Endif
Gosub VERROU

Return
#********************************************************************
$INICRE

  [F:RDE]NUMASS= sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY)
  [F:RDP]NUMASS= sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY)

Return
#********************************************************************
$CREATION

  Gosub INSERT

Return
#********************************************************************
$AVANT_MODFIC

Local Integer I
#
# avant la mise à jour de l'enregistrement [RDE] on détecte la modification
# de l'indicateur de gestion d'une rubrique déterminée
#  1. si une nouvelle rubrique est gérée ==> on rajoute cette rubrique dans
#     les enregistrements valeurs du  jeu d'association objet/déterminant/société
#  2. si une rubrique n'est plus gérée, on la supprime dans les enregistrements
#     valeurs du  jeu d'association objet/déterminant/société
#

For nolign=1 To [M:RDE1]NBRUB0
  If [M:RDE1]MGTFLG(nolign-1)= G_OUI & [F:RDE]MGTFLG(nolign-1)= G_NON
    Gosub AJOUT_RUBVAL
    If GOK=0 : Return : Endif
  Endif
  If  [M:RDE1]MGTFLG(nolign-1)= G_NON  & [F:RDE]MGTFLG(nolign-1)= G_OUI
    Gosub SUPPRESS_RUBVAL
    If GOK=0 : Return : Endif
  Endif
Next nolign

#  avant la mise à jour de l'enregistrement [RDE] on détecte l'ajout d'un nouveau plan
#  géré pour la société Si un nouveau plan est affiché
#  ==> on crée dans la table RUBASSDEFP l'enregistrement correspondant
#
For nolign = [M:RDE1]NBRUB0 To [M:RDE1]NBRUB
  If [M:RDE1]WPLN(nolign) > 0
    Read[RDP]RDP0=[M:RDE1]REFOBJ;[M:RDE1]DETAAS;[M:RDE1]ACM;[M:RDE1]CPY;[M:RDE1]WPLN(nolign)
    If fstat <> 0
      Gosub INSERT_NEW_PLAN
      If GOK=0 : Return : Endif
    Endif
    If [M:RDE1]MGTFLG(nolign-1) = G_OUI
      For I = 0 To 8
        If [F:RDP]MGTFLGP(I)= G_OUI
          I+=1
          Break
        Endif
      Next I
      If I > 0
       Gosub AJOUT_RUBVALP
      Endif
    Endif
  Endif
Next nolign


Return
#********************************************************************
$AJOUT_RUBVAL

Local Integer I

#FQ-96683 Filter[RVA] Where (NUMASS=[M:RDE1]NUMASS)
Filter[RVA] Where ( REFOBJ=[M:RDE1]REFOBJ  &
&                   DETAAS=[M:RDE1]DETAAS  &
&                   ACM=[M:RDE1]ACM        &
&                   CPY=[M:RDE1]CPY )
For [RVA]
  I=[F:RVA]NBLIG
  [F:RVA]RUBRAS(I) = [M:RDE1]RUBRAS(nolign-1)
  [F:RVA]NBLIG +=1
  #---------------
  Rewrite [RVA]
  If fstat
    GOK=0
    Call FSTA("RVA") From GLOCK
    Break
  Endif
Next
Filter[RVA]

Return
#********************************************************************
$SUPPRESS_RUBVAL
Local Integer J, K

#FQ-96683 Filter[RVA] Where (NUMASS=[M:RDE1]NUMASS)
Filter[RVA] Where ( REFOBJ=[M:RDE1]REFOBJ  &
&                   DETAAS=[M:RDE1]DETAAS  &
&                   ACM=[M:RDE1]ACM        &
&                   CPY=[M:RDE1]CPY )
For [RVA]
  I = find([M:RDE1]RUBRAS(nolign-1),[F:RVA]RUBRAS(0..[F:RVA]NBLIG-1))
  If I
    Dela I-1, 1, [F:RVA]NBLIG  [F:RVA]NOADI, [F:RVA]NOLIB, [F:RVA]RUBRAS,[F:RVA]VALDETEAS
    [F:RVA]NBLIG -=1
    Rewrite [RVA]
    If fstat
      GOK=0
      Call FSTA("RVA") From GLOCK
      Break
    Endif
  Endif
Next
Filter[RVA]

Return
#********************************************************************
$AJOUT_RUBVALP

Local Integer I
Local Char WVALDET

#FQ-96683Filter[RVA] Where (NUMASS=[M:RDE1]NUMASS) Order By [F:RVA]VALDETAAS
Filter[RVA] Where ( REFOBJ=[M:RDE1]REFOBJ  &
&                   DETAAS=[M:RDE1]DETAAS  &
&                   ACM=[M:RDE1]ACM        &
&                   CPY=[M:RDE1]CPY ) Order By [F:RVA]VALDETAAS
For [RVA]
  [F:RVP]VALDETAAS  = [F:RVA]VALDETAAS
  [F:RVP]NUMASS     = [F:RVA]NUMASS
  [F:RVP]DPRPLN     = [M:RDE1]WPLN(nolign)
  [F:RVP]DPM        = ""
  [F:RVP]DPRDUR     = 0
  [F:RVP]DPRRAT     = 0
  [F:RVP]ALWCOD     = 0
  [F:RVP]CRBVEHCOD  = ""
  [F:RVP]DPRRAT2    = 0
  [F:RVP]PRATYP     = 0
  [F:RVP]ACLCOE     = 0
  [F:RVP]CPY     = [M:RDE1]CPY
  [F:RVP]REFOBJ  = [M:RDE1]REFOBJ
  [F:RVP]DETAAS  = [M:RDE1]DETAAS
  [F:RVP]ACM     = [M:RDE1]ACM
  # FQ61528
  # [F:RVP]LEG     = [M:RDE1]LEG
  If (dim([M:RDE1]LEG)>0) Then : [F:RVP]LEG = [M:RDE1]LEG : Else : [F:RVP]LEG = GDOSLEG : Endif
  [F:RVP]CRBVEHCOD = ""
  #---------------
  Write [RVP]
  If fstat > 0 and fstat <> 3
    GOK=0
    Call FSTA("RVP") From GLOCK
    Break
  Endif
Next
Filter [RVA]
Return
#********************************************************************
$MODIF

Local Integer I, WMODFLG

  Gosub SUPPRESS
  Gosub INSERT

Return
#********************************************************************
$SUPPRESS

#*  Delete des déterminants/plans

  Delete [RDP] Where (REFOBJ=[M:RDE1]REFOBJ &
&                     DETAAS=[M:RDE1]DETAAS &
&                     ACM=[M:RDE1]ACM &
&                     CPY=[M:RDE1]CPY )
  If fstat=1
    GOK=0
    Call RSTA("RDP",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
    Return
  Endif

#Infbox "enreg RDP supprimés="+num$(adxdlrec)

Return
#********************************************************************
$APRES_CHOI

If dim(REPONSE)>0
Case REPONSE
  When GSTAANU : Gosub CTL_ANU : # Avertissement annulation paramétrage association
Endcase
Endif

Return
#********************************************************************
$CTL_ANU

#FQ-96683 Filter[RVA] Where (NUMASS=[M:RDE1]NUMASS)
Filter[RVA] Where ( REFOBJ=[M:RDE1]REFOBJ  &
&                   DETAAS=[M:RDE1]DETAAS  &
&                   ACM=[M:RDE1]ACM        &
&                   CPY=[M:RDE1]CPY)

Read[RVA]First
If !fstat : # Il existe au moins un enregistrement RVA pour l'association en cours
            #  êtes-vous sûr de vouloir supprimer ce paramétrage
  Call OUINON (mess(83,GML_MSGFASPR,1)-mess(59,GML_MSGFASPR,1),[L]OUINON) From GESECRAN
  If [L]OUINON<>G_OUI : REPONSE=0 : Endif
Endif
Filter[RVA]

Return
#********************************************************************
$VERF_ANU

Trbegin [RVA], [RVP], [RDP], [RDE]

#FQ-96683 Delete [RVA] Where (NUMASS=[M:RDE1]NUMASS)
  Delete [RVA] Where ( REFOBJ=[M:RDE1]REFOBJ  &
&                      DETAAS=[M:RDE1]DETAAS  &
&                      ACM=[M:RDE1]ACM        &
&                      CPY=[M:RDE1]CPY )
  If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$RUBASSVAL" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif


#FQ-96683Delete [RVP] Where (NUMASS=[M:RDE1]NUMASS)
  Delete [RVP] Where ( REFOBJ=[M:RDE1]REFOBJ   &
&                      DETAAS=[M:RDE1]DETAAS   &
&                      ACM=[M:RDE1]ACM         &
&                      CPY=[M:RDE1]CPY )
If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$RUBASSVALP" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif


#FQ-96683Delete [RDP] Where (NUMASS=[M:RDE1]NUMASS)
  Delete [RDP] Where (  REFOBJ=[M:RDE1]REFOBJ  &
&                       DETAAS=[M:RDE1]DETAAS  &
&                       ACM=[M:RDE1]ACM        &
&                       CPY=[M:RDE1]CPY )
If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$RUBASSDEFP" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif


#FQ-96683Delete [RDE] Where (NUMASS=[M:RDE1]NUMASS)
  Delete [RDE] Where ( REFOBJ=[M:RDE1]REFOBJ   &
&                      DETAAS=[M:RDE1]DETAAS   &
&                      ACM=[M:RDE1]ACM         &
&                      CPY=[M:RDE1]CPY )
If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$RUBASSDEF" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif

Commit

OK = 0 # pour ne pas passer dans la suppression standard (TB 06/10/00)

If !GSERVEUR & !GIMPORT
 Call MESSAGE(mess(151,GML_MSGFASPR,1)-[M:RDE1]CPY-"/"-mess([M:RDE1]REFOBJ,GML_OBJMETIE,1)-"/"-mess([M:RDE1]DETAAS,GML_DETASSO,1)) From GESECRAN : # Supression du jeu d'association effectuée
Endif


Return
#********************************************************************
$ROLL_ANN

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return
  Else
    Goto VERF_ANU
  Endif
#*****************
$AB_ANN

 Rollback
 OK = 0 # pour ne pas passer dans la suppression standard (TB 06/10/00)

 Return
#************************************************************************
# création des  enregistrements "RUBASSDEFP" (1 enreg par plan)
#************************************************************************
$INSERT

Local Integer I, J, P

For nolign = [M:RDE1]NBRUB0 To [M:RDE1]NBRUB
If [M:RDE1]WPLN(nolign) > 0
  Raz [F:RDP]
  [F:RDP]REFOBJ = [M:RDE1]REFOBJ
  [F:RDP]DETAAS = [M:RDE1]DETAAS
  [F:RDP]CPY    = [M:RDE1]CPY
  [F:RDP]ACM    = [M:RDE1]ACM
  # FQ61528
  # [F:RDP]LEG    = [M:RDE1]LEG
  If (dim([M:RDE1]LEG)>0) Then : [F:RDP]LEG = [M:RDE1]LEG : Else : [F:RDP]LEG = GDOSLEG : Endif
  [F:RDP]ENAFLG = [M:RDE1]ENAFLG
  [F:RDP]NUMASS = sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY)
  [F:RDP]DPRPLN  = [M:RDE1]WPLN(nolign)
  I = 0
  While  [M:RDE1]WPLN(nolign) = [F:RDP]DPRPLN
      If   [M:RDE1]RUBRASP(nolign) <> ""
        #---------------
        [F:RDP]RUBRASP(I) = [M:RDE1]RUBRASP(nolign)
        [F:RDP]MGTFLGP(I) = [M:RDE1]MGTFLG(nolign)
        [F:RDP]UPDFLGP(I) = [M:RDE1]UPDFLG(nolign)
        [F:RDP]FRCFLGP(I) = [M:RDE1]FRCFLG(nolign)
        I+=1
      Endif
      #---------------
    nolign+=1
  Wend
  [F:RDP]NBRUBP = I
  If I > 0
    #---------------
    Write [RDP]
     # Infbox "enreg créé="+num$([F:RDP]NUMASS)
    If fstat
      GOK=0
      Call FSTA("RDP") From GLOCK
      Break
    Endif
  Endif
Endif
Next


Return
#=============================================================================
$CHARGE_RUB

Local Integer     NEWPLAN, GERE
Local Shortint    WLANNUM
Local Char        TEXTE(30)
Local Char        CODFIC
Local Char        ZONE, CODE
Local Char        LANGUE
Local Char        IDENT1, IDENT2
#*
#* Initialisation des paramètres permettant de récupérer l'intitulé de chaque
#* rubrique dans la table ATEXTRA
#*
#* Chargement des rubriques déterminées en fonction du type d'association demandé
[M:RDE1]NBRUB = 0
[M:RDE1]NBRUBP = 0
nolign = 1

#*===================================
#* Si l'objet est "DEPENSES"
#*===================================
If [M:RDE1]REFOBJ = GVML_OMDEPEN
  [M:RDE1]ENTITE(0) = mess([M:RDE1]REFOBJ,GML_OBJMETIE,1)  # libellé objet métier (ML 341)
  Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"*D*"))  Order By N1 Asc; CODE Asc
     Gosub CHARGE_TABLEAU
     [M:RDE1]NBRUB0  = nolign-1
     [M:RDE1]NBRUB   = nolign-1
     Affzo [M:RDE1]NBRUB0
Endif

#*===================================
#* Si l'objet est "BIEN COMPTABLE"
#*===================================
If [M:RDE1]REFOBJ = GVML_OMBIEN
  [M:RDE1]ENTITE(0) = mess([M:RDE1]REFOBJ,GML_OBJMETIE,1)  # libellé objet métier (ML 341)
  Case [M:RDE1]DETAAS
    When  GVML_DTAFAM :  Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"B*" ))  Order By N1 Asc; CODE Asc
    When  GVML_DTACCO :  Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"BT*"))  Order By N1 Asc; CODE Asc
  Endcase
  Gosub CHARGE_TABLEAU
  [M:RDE1]NBRUB0  = nolign-1
  Gosub CHARGE_PLAN
  [M:RDE1]NBRUB  = nolign-1
Endif
#*========================================================================
#* Si l'objet est "SUBVENTION" : on ne traite pas encore les subventions
#*=========================================================================
If [M:RDE1]REFOBJ =GVML_OMSUBV
  #*Fq-47029 ajout critère de tri CODE
  Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"S*" ))  Order By N1; CODE Asc
  Gosub CHARGE_TABLEAU
  Filter [ADI]
Endif

Affzo [M:RDE1]NBRUB
Actzo [M:RDE1]NBRUB


If [M:RDE1]NBRUB0 > 0
  For nolign = [M:RDE1]NBRUB0 To [M:RDE1]NBRUB+1
    If ([M:RDE1]ENTITE(nolign-1)<> "")  or ([M:RDE1]INTIT(nolign-1)= "")
      Diszo[M:RDE1]MGTFLG(nolign-1)
      Diszo[M:RDE1]UPDFLG(nolign-1)
      Diszo[M:RDE1]FRCFLG(nolign-1)
    Endif
  Next
Endif

Return
#=============================================================================
$CHARGE_TABLEAU

Local Integer     NEWPLAN, GERE
Local Shortint    WLANNUM
Local Char        TEXTE(30), TEXTE2
Local Char        CODFIC
Local Char        ZONE, CODE
Local Char        LANGUE
Local Char        IDENT1, IDENT2

For [ADI]
   If [F:ADI]A2 = "CCN" and G_ACTCCN = G_NON
      Goto NEXTADI
   Endif
     [M:RDE1]RUBRAS(nolign-1)  = [F:ADI]CODE
     #*------------------------------------------------------------------------------
     #* Récup. de l'intitulé long (LNGDES) de chaque poste de la table diverse 961
     #*------------------------------------------------------------------------------
     Call LECTEXTRA (TEXTE, "ATABDIV", "LNGDES", num$(GTD_ASSORUB), [F:ADI]CODE) From ATEXTRA
     [M:RDE1]INTIT(nolign-1)  = TEXTE
     #*------------------------------------------------------------------------------
     nolign += 1
 $NEXTADI
Next
Filter[ADI]

Gosub CHARGE_FREEFLD

Return
#=============================================================================
$CHARGE_PLAN

Local Shortint     WLANNUM
#*----------------------------------------------------------------------
#* Recherche des plans existants dans le Menu Local 3001
#*----------------------------------------------------------------------
For WLANNUM = 1 To 15
  #*-------------------------------------------------------
  #* récupération des plans gérés pour la société saisie
  #*-------------------------------------------------------
  If [M:RDE1]CPY <> ""
    If func GLOBIENS.CPY_PLN_GERE([M:RDE1]CPY,WLANNUM)=G_NON
      GERE = G_NON
    Else
      GERE = G_OUI
    Endif
    NEWPLAN=0
    If GERE = G_OUI
      Gosub AFFICH_PLAN
    Endif
  Else
    Gosub AFFICH_PLAN
  Endif
Next

NBRUB = nolign-1

Return
#======================================================================
$CHARGE_FREEFLD

Local Char LINTIT, TEXTE2, LCPY, TEXTE

Read[FRF]FRF0=[M:RDE1]REFOBJ;[M:RDE1]CPY
If fstat=0
  LCPY= [M:RDE1]CPY
Else
  LCPY = ""
Endif
#*---------------------------------------------------------------
#* Chargement des rubriques de type Zones Libres
#*---------------------------------------------------------------
Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"F*"))  Order By N1; CODE Asc
For [ADI]
   CODFIC = "FREFLD"
   IDENT1 = num$([M:RDE1]REFOBJ)
   IDENT2 = [M:RDE1]CPY
   ZONE   = [F:ADI]CODE
   Call LECTEXTRA (TEXTE, CODFIC, ZONE, IDENT1, LCPY) From ATEXTRA   #*Fq-63982
   If TEXTE <> ""
      [M:RDE1]RUBRAS(nolign-1)  = [F:ADI]CODE
      [M:RDE1]INTIT(nolign-1)  = TEXTE
      [M:RDE1]DPRPLN(nolign-1) = 0
      [M:RDE1]WPLN(nolign-1) = 0
      nolign += 1
   Endif
Next
Filter [ADI]

Return
#============================================================================
$VERIF_DOUBLONS

Local Integer I, J, LOK
LOK = 1
I = 0
#*  on vérifie que les rubriques déterminées cochées comme  étant gérées
#*   n'a pas été déjà définie comme telle  pour un autre déterminant

Filter [RDE] Where (REFOBJ=[M:RDE1]REFOBJ & DETAAS <> [M:RDE1]DETAAS & (ACM=[M:RDE1]ACM) & CPY=[M:RDE1]CPY )
For [RDE]
  I = find([M:RDE1]RUBRAS(nolign-1),[F:RDE]RUBRAS(0..[F:RDE]NBRUB0-1))
  If I & ([F:RDE]MGTFLG(I-1) = G_OUI)
    GERR = 1
    GMESSAGE = mess(50,GML_MSGFASPR,1)-mess([F:RDE]DETAAS,GML_DETASSO,1) # Rubrique déjà déterminée par un autre déterminant
    mkstat = 2
  Endif
 Next
Filter [RDE]

J=0
Filter [RDP] Where (REFOBJ=[M:RDE1]REFOBJ) & (DETAAS <> [M:RDE1]DETAAS) & (ACM=[M:RDE1]ACM) & (CPY=[M:RDE1]CPY) &
&                  (DPRPLN = [M:RDE1]WPLN(nolign-1))
For [RDP]
  J = find([M:RDE1]RUBRASP(nolign-1),[F:RDP]RUBRASP(0..[F:RDP]NBRUBP-1))
  If J & ([F:RDP]MGTFLGP(J-1) = G_OUI)
    GERR = 1
    GMESSAGE = mess(50,GML_MSGFASPR,1)-mess([F:RDE]DETAAS,GML_DETASSO,1) # Rubrique déjà déterminée par un autre déterminant
    mkstat = 2
  Endif
 Next
Filter [RDP]

Return
#=======================================================================================
$AFFICH_PLAN

# si les subventions ne sont pas gérées (code activité GRT non activé
# on n'affiche pas le plan Subvention
#
If ( WLANNUM = G301SUB and G_ACTGRT = G_NON ) or ( WLANNUM = G301IAS and G_ACTIAS = G_NON )
  Return
Endif

[M:RDE1]DPRPLN(nolign-1)     = WLANNUM
[M:RDE1]WPLN(nolign-1)       = 0
[M:RDE1]ENTITE(nolign-1)     = mess(82,GML_MSGFASPR,1)-mess(WLANNUM,GML_NPLAN,1)
Diszo[M:RDE1]MGTFLG(nolign-1) : Diszo[M:RDE1]UPDFLG(nolign-1) : Diszo[M:RDE1]FRCFLG(nolign-1)
nolign+=1
#*-------------------------------------------------------------------
#* Chargement des rubriques concernant chaque plan
#*-------------------------------------------------------------------
Filter [ADI] Where (NUMTAB = GTD_ASSORUB and pat(A1,"P*"))  Order By N1
#FQ61528
Local Char L_LEG
If ( dim([M:RDE1]LEG) > 0 ) Then : L_LEG=[M:RDE1]LEG : Else : L_LEG=GDOSLEG : Endif
For [ADI]
   # FQ61528
   #If ( [F:ADI]LEG = "" ) or ( [F:ADI]LEG =[M:RDE1]LEG )
   If ( [F:ADI]LEG = "" ) or ( [F:ADI]LEG =L_LEG )
      [M:RDE1]RUBRASP(nolign-1)  = [F:ADI]CODE
      #*-----------------------------------------------------------------------------
      #* Récup. de l'intitulé long (LNGDES) de chaque postes de la table diverse 961
      #*-----------------------------------------------------------------------------
      IDENT2  = [F:ADI]CODE
      If IDENT2 <> ""
        Call LECTEXTRA (TEXTE, "ATABDIV", "LNGDES", num$(GTD_ASSORUB), IDENT2) From ATEXTRA
        [M:RDE1]INTIT(nolign-1)  = TEXTE
        [M:RDE1]WPLN(nolign-1)   = WLANNUM
        [M:RDE1]DPRPLN(nolign-1) = WLANNUM
        [M:RDE1]MGTFLG(nolign-1) = 1
        [M:RDE1]UPDFLG(nolign-1) = 1
        [M:RDE1]FRCFLG(nolign-1) = 1
      Endif
      nolign += 1
   Endif
Next
Filter [ADI]

Return
#=================================================================================
#*********************************************************************************
# création des  nouveaux plans gérés dans  "RUBASSDEFP" (1 enreg par plan)
#*********************************************************************************
$INSERT_NEW_PLAN

  # Enregistrement des nouveaux plans gérés dans la table RUBASSDEFP
  [F:RDP]REFOBJ = [M:RDE1]REFOBJ
  [F:RDP]DETAAS = [M:RDE1]DETAAS
  [F:RDP]CPY    = [M:RDE1]CPY
  [F:RDP]ACM    = [M:RDE1]ACM
  # FQ61528
  #[F:RDP]LEG    = [M:RDE1]LEG
  If ( dim([M:RDE1]LEG) > 0 ) Then : [F:RDP]LEG = [M:RDE1]LEG : Else : [F:RDP]LEG = GDOSLEG : Endif
  [F:RDP]NUMASS = sum(num$([M:RDE1]REFOBJ),num$([M:RDE1]DETAAS),[M:RDE1]ACM,[M:RDE1]CPY)
  [F:RDP]DPRPLN = [M:RDE1]WPLN(nolign)
  [F:RDP]RUBRASP(0)  = "DPM"
  [F:RDP]RUBRASP(1)  = "DPRDUR"
  [F:RDP]RUBRASP(2)  = "DPRRAT"
  [F:RDP]RUBRASP(3)  = "ALWCOD"
  [F:RDP]RUBRASP(4)  = "CRBVEHCOD"
  [F:RDP]RUBRASP(5)  = "DPRRAT2"
  [F:RDP]RUBRASP(6)  = "PRATYP"
  [F:RDP]RUBRASP(7)  = "ACLCOE"
  [F:RDP]ENAFLG  = [M:RDE1]ENAFLG
  [F:RDP]NBRUBP = 8
  #---------------
  Write [RDP]
   # Infbox "RDP created ="+num$([F:RDP]NUMASS)+num$([F:RDP]DPRPLN)
  If fstat
    GOK=0
    Call FSTA("RDP") From GLOCK
  Endif

Return
#=======================================================================
Subprog AS_REFOBJ(VALEUR)
Variable Integer VALEUR

# on ne propose pas pour le moment les choix suivants  :
#  GMENLOC(3)   "Contrat de Location financement"
#  GMENLOC(4)   "Subventions"
#  GMENLOC(5)   "Inventaire"
#  GMENLOC(6)   "Eléments physiques"

 GMENLOC(3)=1
 GMENLOC(4)=1
 GMENLOC(5)=1
 GMENLOC(6)=1
 GMENLOC(7)=1  #*Fq-58773
 Call LIMOBJ From TRTLIC

End
#=======================================================================
Subprog AS_DETAAS(VALEUR)
Variable Integer VALEUR

# si l'objet = Dépenses :  pas les choix  "Code Comptable" et "Organisme"
# si l'objet = Biens comptables  :  pas le choix "Organisme"
# si l'objet = Subventions  : pas les choix " Famille"  et "Code Comptable"

Case [M:RDE1]REFOBJ
  When GVML_OMDEPEN   :   GMENLOC(GVML_DTACCO)=1   :  GMENLOC(GVML_DTAORG)=1
  When GVML_OMBIEN    :   GMENLOC(GVML_DTAORG)=1
  When GVML_OMSUBV    :   GMENLOC(GVML_DTAFAM)=1   :  GMENLOC(GVML_DTACCO)=1
Endcase

End
###################################################################
## AM_REFOBJ : on charge le tableau de rubriques correspondant
###################################################################
Subprog AM_REFOBJ(VALEUR)
Variable Integer VALEUR

Read[WRDE]RDE0 = VALEUR;[M:RDE1]DETAAS;[M:RDE1]ACM;[M:RDE1]CPY
If (fstat > 0) & ([M:RDE1]DETAAS > 0)
  [M:RDE1]REFOBJ = VALEUR
  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB") From GLOBIENS
  Gosub CHARGE_RUB
  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB") From GLOBIENS
Endif

End
###################################################################
## AM_DETAAS : on charge le tableau de rubriques correspondant
###################################################################
Subprog AM_DETAAS(VALEUR)
Variable Integer VALEUR

Read[WRDE]RDE0 = [M:RDE1]REFOBJ;VALEUR;[M:RDE1]ACM;[M:RDE1]CPY
If (fstat > 0)   & ([M:RDE1]REFOBJ > 0)
  [M:RDE1]DETAAS = VALEUR
  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB0") From GLOBIENS
  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB") From GLOBIENS
  Gosub CHARGE_RUB
  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB0") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB") From GLOBIENS
Endif

End

#==================================================================
Subprog AM_CPY(VALEUR)
Variable Char VALEUR

#*FQ-98734 If VALEUR <>  [M:RDE1]CPY
If VALEUR <>  [M:RDE1]CPY or GREP="C"
    [M:RDE1]CPY= VALEUR
    Read [CPY]CPY0= VALEUR
    If fstat=0
       [M:RDE1]ACM = [F:CPY]ACM
       Read [GCM]GCM0=[F:CPY]ACM
       If fstat=0
         # FQ61528
         # [M:RDE1]LEG = [F:GCM]LEG
         If (dim([M:RDE1]LEG)>0) Then : [M:RDE1]LEG = [F:GCM]LEG : Endif
       Endif
       Affzo [M:RDE1]ACM :   Diszo [M:RDE1]ACM
       # FQ61528
       # Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG
       If (dim([M:RDE1]LEG)>0) Then : Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG : Endif
    Endif
Endif

#* si la société est renseignée et que l'objet est le Bien Comptable, on va rechercher
#* les plans gérés pour la société

Read[WRDE]RDE0 = [M:RDE1]REFOBJ;[M:RDE1]DETAAS;[M:RDE1]CPY;[M:RDE1]ACM
If (fstat > 0)  & ([M:RDE1]DETAAS > 0) & ([M:RDE1]REFOBJ > 0)
  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB") From GLOBIENS
  Gosub CHARGE_RUB
  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB") From GLOBIENS
Endif

End
#===#*FQ-98734 ===============================================================
Subprog AP_CPY(VALEUR)
Variable Char VALEUR

If VALEUR <>  [M:RDE1]CPY or GREP="C"
    [M:RDE1]CPY= VALEUR
    Read [CPY]CPY0= VALEUR
    If fstat=0
       [M:RDE1]ACM = [F:CPY]ACM
       Read [GCM]GCM0=[F:CPY]ACM
       If fstat=0
         If (dim([M:RDE1]LEG)>0) Then : [M:RDE1]LEG = [F:GCM]LEG : Endif
       Endif
       Affzo [M:RDE1]ACM :   Diszo [M:RDE1]ACM
       If (dim([M:RDE1]LEG)>0) Then : Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG : Endif
    Endif
Endif
# Issue 111594 - 2015-10-28 by MDJ : supprimé car effet de bord en retour de tunnel
##* si la société est renseignée et que l'objet est le Bien Comptable, on va rechercher
##* les plans gérés pour la société
#Read[WRDE]RDE0 = [M:RDE1]REFOBJ;[M:RDE1]DETAAS;[M:RDE1]CPY;[M:RDE1]ACM
#If (fstat > 0)  & ([M:RDE1]DETAAS > 0) & ([M:RDE1]REFOBJ > 0)
#  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB") From GLOBIENS
#  Gosub CHARGE_RUB
#  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB") From GLOBIENS
#Endif
# End issue 111594

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran RDE1) 07/11/2008 16:33:21 (MDJ)
######################################################################################
Subprog AS_ACM(VALEUR)
Variable Char    VALEUR()

If [M:RDE1]CPY <> ""
    Read [CPY]CPY0=[M:RDE1]CPY
    If fstat=0
       [M:RDE1]ACM = [F:CPY]ACM
       Diszo [M:RDE1]ACM
    Endif
Else
   Actzo [M:RDE1]ACM
Endif

Affzo [M:RDE1]ACM

Read [GCM]GCM0=[M:RDE1]ACM
If fstat=0
   # FQ61528
   # [M:RDE1]LEG = [F:GCM]LEG
   If (dim([M:RDE1]LEG)>0) Then : [M:RDE1]LEG = [F:GCM]LEG : Endif
Endif

# FQ61528
# Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG
If (dim([M:RDE1]LEG)>0) Then : Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG : Endif

End
######################################################################################
Subprog AM_ACM(VALEUR)
Variable Char    VALEUR()

If  [M:RDE1]CPY <> ""
   Read [CPY]CPY0=[M:RDE1]CPY
   If  VALEUR <>  [F:CPY]ACM
      GERR = 1
      GMESSAGE = mess(50,GML_MSGFASPR,1)
      mkstat = 2  : End
   Endif
Endif

Read [GCM]GCM0=VALEUR
If fstat=0
   # FQ61528
   # [M:RDE1]LEG = [F:GCM]LEG
   If (dim([M:RDE1]LEG)>0) Then : [M:RDE1]LEG = [F:GCM]LEG : Endif
Endif
# FQ61528
# Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG
If (dim([M:RDE1]LEG)>0) Then : Affzo [M:RDE1]LEG : Diszo [M:RDE1]LEG : Endif
#* si la société est renseignée et que l'objet est le Bien Comptable, on va rechercher
#* les plans gérés pour la société/le modèle comptable

Read[WRDE]RDE0 = [M:RDE1]REFOBJ;[M:RDE1]DETAAS;VALEUR;[M:RDE1]CPY
If (fstat > 0)  & ([M:RDE1]DETAAS > 0) & ([M:RDE1]REFOBJ > 0)
  Call ACTION_BLOCK (ACB_EFFZO, "RDE1", "NBRUB") From GLOBIENS
  Gosub CHARGE_RUB
  Call ACTION_BLOCK (ACB_AFFZO, "RDE1", "NBRUB") From GLOBIENS
Endif

End

#=======================================================================================
# si flag "géré" = 'NON' ==> les autres flags sont réinitialisés à 'NON'
# si flag "géré" = 'OUI' ==> le flag "modifiable est initialisé à 'OUI'
#=======================================================================================
Subprog AM_MGTFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = G_OUI
  Gosub VERIF_DOUBLONS
  If mkstat End : Endif
  [M:RDE1]UPDFLG(nolign-1) = G_OUI :   Affzo  [M:RDE1]UPDFLG(nolign-1)
Else
  [M:RDE1]FRCFLG(nolign-1) = G_NON :   Affzo  [M:RDE1]FRCFLG(nolign-1)
  [M:RDE1]UPDFLG(nolign-1) = G_NON :   Affzo  [M:RDE1]UPDFLG(nolign-1)
Endif

End
#=======================================================================================
# si flag "Modifiable" = 'OUI' ==> le flag "géré" est initialisé à 'OUI'
#=======================================================================================
Subprog AM_UPDFLG(VALEUR)
Variable Integer VALEUR


If VALEUR = G_OUI
  Gosub VERIF_DOUBLONS
  If mkstat : End : Endif
  [M:RDE1]MGTFLG(nolign-1) = G_OUI :    Affzo  [M:RDE1]MGTFLG(nolign-1)
Else
  [M:RDE1]UPDFLG(nolign-1) = G_NON :      Affzo  [M:RDE1]UPDFLG(nolign-1)
Endif


End
#=======================================================================================
# si flag "Forçage" = 'OUI' ==> le flag "géré" est initialisé à 'OUI'
# si flag "Forçage" = 'OUI' ==> le flag "modifiable" est initialisé à 'OUI'
#=======================================================================================
Subprog AM_FRCFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = G_OUI
  Gosub VERIF_DOUBLONS
  If mkstat : End : Endif
  [M:RDE1]MGTFLG(nolign-1) = G_OUI :      Affzo  [M:RDE1]MGTFLG(nolign-1)
  [M:RDE1]UPDFLG(nolign-1) = G_OUI :      Affzo  [M:RDE1]UPDFLG(nolign-1)
Else
  [M:RDE1]FRCFLG(nolign-1) = G_NON :      Affzo  [M:RDE1]FRCFLG(nolign-1)
Endif


End

