#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Opération : OPE_UPDATE_LPN<br/>
#* Update the dates in the LPN
#* @param LPNNUM : LPN
#* @param DDATE : date d'imputation
#* @param LOC : emplacement
#* @param STAT : statut (1=libre, 2=en stock
#* @return CST_AOK si OK, sinon erreur
#*!
$OPE_UPDATE_LPN

[L]ARET_VALUE = [V]CST_AOK
  [L]ARET_VALUE = fmet this.AREAD(LPNNUM)
  If [L]ARET_VALUE = [V]CST_AOK
    #First date of use
    If ((this.LPNFDAT = AVOID.ADATE) & (DDATE <> AVOID.ADATE))
      this.LPNFDAT = DDATE
    Endif
    #Last date of use
    If ((this.snapshot.LPNLDAT<>DDATE) & (DDATE <> AVOID.ADATE))
      this.LPNLDAT = DDATE
    Endif
    #location
    If ((this.snapshot.LOC <> LOC) & (LOC <> AVOID.ACHAR))
      this.LOC = LOC
    Endif
    #statut
    If this.LPNSTAT <> STAT
      this.LPNSTAT = STAT
    Endif
    [L]ARET_VALUE = fmet this.AUPDATE()
  Endif
Return

