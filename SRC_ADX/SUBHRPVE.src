#**
#* Vérification existence de la variable dans le code liste fourni dans le paramètre CODPVE
#*
#* @param VALEUR
#*!
Subprog C_VRACOD(VALEUR)
Variable Char    VALEUR()
Local    Char    CODPVH(GLONPVH)

  Call CONTROLE_VRACOD("CODPVE", VALEUR) From TOOLSVAR
End

Subprog C_ELTAMT(VALEUR)
Variable Char    VALEUR()
Local    Char    TEX(80)(1..200), TIT(80)(0..2), PARAM(80)(1..2)
Local    Integer NBTEX

#DIRAS - 2017/06/08 - JIRA X3-11598 - START
  PARAM(1)='HREXPENSES'
#  PARAM(1)='EXPENSES'
#DIRAS - 2017/06/08 - JIRA X3-11598 - START
  Gosub SELAMT From TRTSELAMT
  If !find(VALEUR, TEX) Then
    mkstat=2
  Endif
End


