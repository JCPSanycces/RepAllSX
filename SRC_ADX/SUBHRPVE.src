Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

  GCURLEG=VALEUR
  Call C_LEG_LEV(VALEUR) From TOOLSVAR

End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)

End
