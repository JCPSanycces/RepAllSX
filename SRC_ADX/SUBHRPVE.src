#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion de la table PARVAREXP (objet PVE)
#
# Création : MABON 12/05/11
######################################################################################

$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LIENS2"     : Gosub LIENS2
    When Default
  Endcase
Return

#**
#* Ouverture des tables
#*!
$OUVRE
  Gosub OUVRE From TOOLSVAR
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif

Return

#**
#*  Création de la clé : Code frais + élément montant + niveau + valeur relative au niveau
#*!
#JASMI - 2017-06-05 - START
#Funprog CRE_KEY(CODEXP, ELTAMT, LEV, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD)
#Value    Char    CODEXP, ELTAMT, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD
Funprog CRE_KEY(CODEXP, ELTAMT, LEV, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD)
Value    Char    CODEXP, ELTAMT, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD
#JASMI - 2017-06-05 - END
Value    Integer LEV
Local    Char    KEYPVE

  KEYPVE=CODEXP+"~"+ELTAMT+"~"+num$(LEV)
  Case LEV
    When 1 : KEYPVE += "~"+ADXDOS
#JASMI - 2017-06-05 - START
#    When 1 : KEYPVE += "~"+ADXDOS
#    When 2 : KEYPVE += "~"+POP
#    When 3 : KEYPVE += "~"+CPY
#    When 4 : KEYPVE += "~"+FCY
#    When 5 : KEYPVE += "~"+REFNUM
#    When 6 : KEYPVE += "~"+CTRNUM
#    When 7 : KEYPVE += "~"+SERVICE
#    When 8 : KEYPVE += "~"+CLLCVT
#    When 9 : KEYPVE += "~"+PRFCOD
    When 2 : KEYPVE += "~"+GCURLEG
    When 3 : KEYPVE += "~"+POP
    When 4 : KEYPVE += "~"+CPY
    When 5 : KEYPVE += "~"+FCY
    When 6 : KEYPVE += "~"+REFNUM
    When 7 : KEYPVE += "~"+CTRNUM
    When 8 : KEYPVE += "~"+SERVICE
    When 9 : KEYPVE += "~"+CLLCVT
    When 10 : KEYPVE += "~"+PRFCOD
#JASMI - 2017-06-05 - END
  Endcase
End KEYPVE

#**
#* Calcul de la zone clé KEYPVE pour chacune des lignes
#*!
$LIENS2
Local Integer I

  For I=1 To [M]NBPVE
    [M]KEYPVE(I-1) = func CRE_KEY([M]CODEXP(I-1),[M]ELTAMT(I-1),[M]LEV(I-1),[M]ADXDOS(I-1),[M]POP(I-1),[M]CPY(I-1),
&                                 [M]FCY(I-1),[M]REFNUM(I-1),[M]CTRNUM(I-1),[M]SERVICE(I-1),[M]CLLCVT(I-1),[M]PRFCOD(I-1))
  Next

Return

######################################################################################
#           GESTION DES CHAMPS DE L'ECRAN PVE0
######################################################################################


#**
#* Reconstitution de la clé KEYPVE après changement du code frais
#*
#* @param VALEUR
#*!
Subprog AM_CODEXP(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVE(nolign-1) = func CRE_KEY(VALEUR,[M]ELTAMT(nolign-1),[M]LEV(nolign-1),[M]ADXDOS(nolign-1),[M]POP(nolign-1),
&                                    [M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),
&                                    [M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clé KEYPVE après changement de l'élément montant
#*!
Subprog AM_ELTAMT(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVE(nolign-1) = func CRE_KEY([M]CODEXP(nolign-1),VALEUR,[M]LEV(nolign-1),[M]ADXDOS(nolign-1),[M]POP(nolign-1),
&                                    [M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),
&                                    [M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clé KEYPVE après changement du niveau
#*
#* @param VALEUR
#*!
Subprog AM_LEV(VALEUR)
Variable Integer VALEUR

  # On annule d'abord la valeur du champ rattaché à l'ancien niveau
  Case [M]LEV(nolign-1)
    When 1 : [M]ADXDOS(nolign-1)  = ""
    When 2 : [M]POP(nolign-1)     = ""
    When 3 : [M]CPY(nolign-1)     = ""
    When 4 : [M]FCY(nolign-1)     = ""
    When 5 : [M]REFNUM(nolign-1)  = ""
    When 6 : [M]CTRNUM(nolign-1)  = ""
    When 7 : [M]SERVICE(nolign-1) = ""
    When 8 : [M]CLLCVT(nolign-1)  = ""
    When 9 : [M]PRFCOD(nolign-1)  = ""
  Endcase

  If VALEUR=1 Then
    [M]LEV(nolign-1)=VALEUR
    [M]ADXDOS(nolign-1)=nomap
    Call VERIF_UNICITE([M]ADXDOS(nolign-1))
  Endif

  [M]KEYPVE(nolign-1) = func CRE_KEY([M]CODEXP(nolign-1),[M]ELTAMT(nolign-1),VALEUR,[M]ADXDOS(nolign-1),[M]POP(nolign-1),
&                                    [M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),
&                                    [M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

######################################################################################
# La combinaison Code frais+Elément montant+Niveau+champ relatif au niveau doit être unique
######################################################################################
Subprog VERIF_UNICITE(VALEUR)
Value Char    VALEUR

  Call UNICITE([M]CODEXP(nolign-1)+"~"+[M]ELTAMT(nolign-1)+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR, [M]KEYPVE) From OBJDIV
  If GMESSAGE="" Then
    [M]KEYPVE(nolign-1)=[M]CODEXP(nolign-1)+"~"+[M]ELTAMT(nolign-1)+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR
  Endif
End

Subprog AM_ADXDOS(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_SERVICE(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CLLCVT(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_PRFCOD(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

