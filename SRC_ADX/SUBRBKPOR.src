#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
 Case ACTION
  When "RBKIMP" : Gosub RBKIMP
  When "SNSFRM" : Gosub SNSFRM
 Endcase
Return

$RBKIMP
# anûÀlise da parametrizaûÏûÈo que arranca: splitagem pela extensûÈo do ficheiro atûˋ arranjar algo melhor....
Read [F:BAN]BAN0=[M:DIA]BAN
If [F:BAN]FILEXT=""
 Call ERREUR([M:DIA]BAN-": Este banco nûÈo tem extensûÈo de ficheiro definida") From GESECRAN
 GPE=1 : Goto F_RBKIMP
Endif
Filter [F:TFB] Where FILREF=[F:BAN]FILEXT & BAN=[M:DIA]BAN
Read [F:TFB]First
If fstat
 Filter [F:TFB] Where FILREF=[F:BAN]FILEXT
 Read [F:TFB]First
 If fstat
  Call ERREUR("NûÈo existe nenhuma parametrizaûÏûÈo de ficheiro cuja extensûÈo seja"-[F:BAN]FILEXT)
&      From GESECRAN
  GPE=1 : Goto F_RBKIMP
 Endif
Endif
[M:DIA]NOMFIC=[F:TFB]COD
If  [M:DIA]NOMFIC="BCP"
 Call IMPRBK2 ([L]FICDON,[M:DIA]BAN)
Elsif [M:DIA]NOMFIC="NORMA43"
 Call NORMA43([L]FICDON)
 [M:DIA]NOMFIC="NORMA43"
Elsif [M:DIA]NOMFIC="SIFI"
 [M:DIA]NOMFIC="SIFI"
 Call IMPRBK3 ([L]FICDON,[M:DIA]BAN)
 GPE=1
Endif
$F_RBKIMP
Filter [F:TFB]
Return

#################################################################################
$SNSFRM
If [M:DIA]NOMFIC="BCP"
 Case left$(CHP,1)
  When"C" : SENS = 1
  When"D" : SENS = -1
 Endcase
 GPE=1
 IMPMONT = val(mid$(CHP,2,I-1))/100
Elsif [M:DIA]NOMFIC="SIFI" & [F:TFB]FILREF<>'si'
 Case mid$(CHP,14,1)
  When"C" : SENS = 1
  When"K" : SENS = -1
 Endcase
 GPE=1
 IMPMONT = val(mid$(CHP,2,I-1))/100
Elsif [M:DIA]NOMFIC="SIFI" & [F:TFB]FILREF='si'
 Case mid$(CHP,I,1)
  When"+" : SENS = 1
  When"-" : SENS = -1
 Endcase
 GPE=1
 IMPMONT = val(mid$(CHP,1,I-1))/100
Endif
Return

###########################################################################
Subprog IMPRBK2(FICHIER,BANQUE)
###########################################################################
Variable Char FICHIER()
Variable Char BANQUE()

Gosub DECLARE From SUBRBK

Call MACHINE(FICHIER,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS        = chr$(10)
                SEP_CHEMIN = "/"
 When Default : IRS        = chr$(13)+chr$(10)
                SEP_CHEMIN = "\"
Endcase

POS1 = 1
POS2 = 0
Repeat
 POS2 = instr(POS1,FICHIER,SEP_CHEMIN)
 If POS2>=POS1 : POS1 = POS2+1 : Endif
Until !POS2
FIC = right$(FICHIER,POS1) : # JML 26/04/00 Ne sert plus !

COK=1
#--- En espagne comme au portugal, il n'ont pas d'enreg. de type Sous-Total.
# Donc au lieu d'imposer une entûˆte + un dûˋtail + un total + un sous-total
# on impose uniquement la prûˋsence d'une entûˆte + un dûˋtail + un total.
For I = 1 To 4
 Read [TFB]TFB0 = [M:DIA]NOMFIC;[M:DIA]BAN;I
 If fstat
  If I<>4
   COK = 0 : Break
  Else
   NBRECTYP=3 : Break
  Endif
 Else
  RECTYP(I) = [F:TFB]FRM
 Endif
Next I
If NBRECTYP=3
 # XYZ : Pas d'enregistrement Sous-total
 Call ECR_TRACE([M:DIA]NOMFIC-":"-mess(65,120,1),0) From GESECRAN
Endif
If !COK
 # Problû´me paramûˋtrage fichier bancaire
 Call ECR_TRACE(mess(155,117,1)-[M:DIA]NOMFIC,1) From GESECRAN
 End
Endif

For [TFB]TFB0 Where COD=[M:DIA]NOMFIC & BAN=[M:DIA]BAN & RECTYP=1
 LONG += [F:TFB]LNG : #Longueur d'un champ
Next
Local Schar CHAMP(LONG)
Gosub IMPORTATION_POR
GPE=1
End

$IMPORTATION_POR
Raz J,K, OLD_SOLDE, TOT_MVT, NBR

#Positionnement sur la premiû´re ligne valide
Openi FICHIER,0
Gosub LECTEST From SUBRBK
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST From SUBRBK
Wend

#Test si sûˋparateur d'enregistrement
Openi FICHIER,J
Gosub LECTURE From SUBRBK
Gosub LECTEST From SUBRBK
K = 0
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST From SUBRBK
Wend
Openi FICHIER,J
Local Schar CHAMP(K+LONG)

#Traitement du fichier
MAJCHRONO = 0
Raz OLDRIB
Gosub LECTURE From SUBRBK
While !fstat
 RG = 1
 COK = 1
 ENREGOK = 1
 NOCOMP = [F:RBK]RBKNUM
 Raz [F:RBK]
 [F:RBK]RBKNUM = NOCOMP
 [F:RBK]ORI = 1
 If !find(left$(CHAMP,1),RECTYP(1..NBRECTYP))
  Call TRACE(left$(CHAMP,1),mess(4,120,1),[0/0/0]) From SUBRBK
  #Code enregistrement inexistant
  COK = -1
 Else
  Gosub CALCRIB_POR
  If ![L]TRANSAC :# Pas de transaction en cours
   Trbegin [RBK]
   [L]TRANSAC = 1
   FIN        = 0
   LIN_REL    = 1
   REM_REL    = 0
   OLDRIB     = NEWRIB
   MAJCHRONO  = 1
  Else
   If OLDRIB <> NEWRIB
    # RIB diffûˋrent
    Call TRACE(mess(51,120,1),NEWRIB,[0/0/0]) From SUBRBK
    COK = 0
   Endif
  Endif
  If COK=1
   Case left$(CHAMP,1)
    When RECTYP(1) : Gosub TRTENTETE_POR
    When RECTYP(2) : Gosub TRTDETAIL_POR
    When RECTYP(3) : Gosub TRTTOTAL_POR
    When RECTYP(4) : Gosub TRTCOMP_POR
   Endcase
  Endif
 Endif

 # Intrûˋgration dûˋveloppement Emmanuel LATOUR : Ecriture des enregistrements de type 05
 # dans la table des commentaires des relevûˋs de comptes bancaires
 If left$(CHAMP,2)=RECTYP(4) & LOAD05
  [F:RBK]NUMRBK = uniqid([F:RBK])
  Write [RBR]
  If fstat
   GOK = 0 : Call FSTA("RBR") From GLOCK : Goto ROLL_RBK
  Endif
  REM_REL+=1
 Endif

 If ENREGOK
  If COK=1
   If MAJCHRONO=1
    COMPTREG = ""
    Call LEC_CPY([F:BAN]CPY) From CPTLEC
    If [F:CPY]MAIFCY=""
     # Pas de site principal rattachûˋ û  la sociûˋtûˋ - F56436
     Call ECR_TRACE(mess(68,107,1)-[F:BAN]CPY,1) From GESECRAN : Goto ROLL_RBK
    Else
     Call GETSOC([F:CPY]MAIFCY) From DEVSUB
     Call LECTCA(3,OKTCA) From SUBTCA
     If OKTCA : COMPTREG = [F:TCA]CODNUM(5) : Endif
     If COMPTREG="" : COMPTREG = "RBK" : Endif
     Call NUMERO(COMPTREG,[F:CPY]MAIFCY,datesyst,"",[F:RBK]RBKNUM,STAT) From SUBANM
     If STAT | GOK<1
      # Problû´me lors de la rûˋcupûˋration du compteur
      Gosub MESSAGE From SUBANM
      Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN : Goto ROLL_RBK
     Endif
    Endif
    MAJCHRONO = 0
   Endif
   [F:RBK]RBKLIN = LIN_REL
   [F:RBK]NUMRBK = uniqid([F:RBK])
   Write [RBK]
   If fstat
    GOK = 0 : Call FSTA("RBK") From GLOCK : Goto ROLL_RBK
   Endif
   LIN_REL +=1
   GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC
   If GOK<1 : Goto ROLL_RBK : Endif
   Gosub LECTURE From SUBRBK
  Endif
  If COK<1
   If COK=0 : Gosub ROLL_RBK : Endif
   Repeat : #Saut jusqu'au prochain rib
    Gosub LECTURE From SUBRBK
    If !fstat & !DBL : Gosub CALCRIB_POR : Endif
   Until (!DBL & find(left$(CHAMP,1),RECTYP(1),RECTYP(2)) & NEWRIB<>OLDRIB) |
&         (DBL & find(left$(CHAMP,1),RECTYP(1))) | fstat
  Endif
  # Les lignes d'un RIB se terminent par une ligne Total 03
  If [F:RBK]RECTYP=3 & !FIN
   Commit
   [L]TRANSAC = 0
   NBR = 1
   If !REM_REL
    # lignes importûˋes du relevûˋ Nô¯
    Call TRACE(num$(LIN_REL-1)-mess(14,120,1),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Else
   # lignes et commentaires importûˋs du relevûˋ Nô¯
   Call TRACE(num$(LIN_REL-1)-tolower(mess(7,105,1))+","-num$(REM_REL)-tolower(mess(61,120,1)),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Endif
  Endif
 Else
  Gosub LECTURE From SUBRBK

 Endif
Wend
If [L]TRANSAC  :# Transaction en cours
 Gosub ROLL_RBK From SUBRBK

 # Pas d'enregistrement total
 Call ECR_TRACE(mess(52,120,1),0) From GESECRAN
Endif
If !NBR
 Call ECR_TRACE(mess(8,120,1),0) From GESECRAN
 #Pas de relevûˋ û  importer
Endif
Return

##############
$ROLL_RBK
Rollback
[L]TRANSAC = 0
FIN = 1
Return

##############################################################33
$CALCRIB_POR
RANG = 1
Raz NEWRIB
Case left$(CHAMP,1)
 When RECTYP(1) : Call FILTRE(1) From SUBRBK
 When RECTYP(2) : Call FILTRE(2) From SUBRBK
 When RECTYP(3) : Call FILTRE(3) From SUBRBK
 When RECTYP(4) : Call FILTRE(4) From SUBRBK
Endcase
For [TFB]TFB0
 Case [F:TFB]FRM
  When "BANQUE"  : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG)
  When "GUICHET" : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG)
  When "COMPTE"  : NEWRIB += mid$(CHAMP,RANG,[F:TFB]LNG) : Break
 Endcase
 RANG +=[F:TFB]LNG
Next
Filter [TFB]
Return
###########################
$TRTENTETE_POR
DBL = 0  : # initialisation du tûˋmoin de recyclage
# TRESO -- Fiche 62-13/09/02-GB -
Raz OLD_SOLDE,TOT_MVT  # initialisation de l'ancien solde et du total mouvement
# TRESO -- Fin ------------------

Call FILTRE(1) From SUBRBK
[F:RBK]RECTYP = 1
Gosub TRTCOMMUN_POR
Filter [TFB]
OLD_SOLDE = [F:RBK]AMTCUR * [F:RBK]SNS

If COK = 1
 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=3 & OPEDAT <= [F:RBK]OPEDAT &
&                      CUR=[F:RBK]CUR
 Read [RBKK]RBK1 Last
 Filter [RBKK]
 If !fstat & [F:RBKK]AMTCUR <> [F:RBK]AMTCUR
  # L'ancien solde ne correspond pas au solde prûˋcûˋdent
  Call TRACE(mess(11,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
 Endif

 If !fstat & [F:RBKK]OPEDAT <> [F:RBK]OPEDAT
  # Date ancien solde ne correspond pas au relevûˋ prûˋcûˋdent
  Call TRACE(mess(60,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
 Endif

 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=1 & OPEDAT=[F:RBK]OPEDAT &
&                    CUR=[F:RBK]CUR & AMTCUR=[F:RBK]AMTCUR
 Read [RBKK]RBK1 First
 Filter [RBKK]
 If !fstat
  # Relevûˋ dûˋjû  importûˋ No
  Call TRACE(mess(10,120,1),mess(49,120,1)-num$([F:RBKK]RBKNUM)-[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
  DBL = 1 : COK = 0 : Return
 Endif
Endif
Return

$TRTCOMMUN_POR
[F:RBK]CHK = ""
[F:RBK]DATCHK=[0/0/0]
[F:RBK]SNS=0
COK=1
For [TFB]TFB0
 Gosub CTR_FRM From SUBRBK
 If COK=1
  Case [F:TFB]FRM
   When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG) : LNGBQE=[F:TFB]LNG
   When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG) : LNGGUI=[F:TFB]LNG
   When "DEVISE"  : Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
   When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
   When "COMPTE"  : LNGCPT =[F:TFB]LNG : Gosub LECBANK_POR
   When "DTSOLDE" : Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
   When "MTSOLDE" : Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
   When "DTXTR"   : Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]DATXTR) From SUBRBK
  Endcase
  Gosub MAJ_FRM From SUBRBK
  RG +=[F:TFB]LNG
 Endif
 If COK=0 : Break : Endif
Next
Return

$TRTDETAIL_POR
Call FILTRE(2) From SUBRBK
[F:RBK]RECTYP = 2
For [TFB]TFB0(4)
 For [TFB]TFB0
  Gosub CTR_FRM  From SUBRBK
  Case [F:TFB]FRM
   When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG): LNGBQE=[F:TFB]LNG
   When "COI"     : IMPCOI = mid$(CHAMP,RG,[F:TFB]LNG):
   When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG): LNGGUI=[F:TFB]LNG
   When "DEVISE"  : Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
   When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
   When "COMPTE"  : LNGCPT=[F:TFB]LNG : Gosub LECBANK_POR
   When "CIB"     : Gosub CODCIB
   When "REJET"   : Gosub CODREJ
   When "LIBEL"   : [F:RBK]DES    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "NO"      : [F:RBK]ENTNUM = mid$(CHAMP,RG,[F:TFB]LNG)
   When "IEXO"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDCOM = 1 : Endif
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDCOM = 2 : Endif
   When "IIND"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDUVY = 1 : Endif
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDUVY = 2 : Endif
   When "REF"     : [F:RBK]REF    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "MONTANT"
    Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
    If [F:RBK]AMTCUR = 0
     [F:RBK]CHK = "*"
     [F:RBK]DATCHK=date$
    Else
     [F:RBK]CHK = ""
     [F:RBK]DATCHK=[0/0/0]
    Endif
   When "DTOPE"
      Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
   When "DTVAL"
        Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]VALDAT) From SUBRBK
  Endcase
  Gosub MAJ_FRM From SUBRBK
  RG +=[F:TFB]LNG
  If COK=0 : Break 2 : Endif
 Next
 TOT_MVT = TOT_MVT + ([F:RBK]AMTCUR * [F:RBK]SNS)
Next
Filter [TFB]
If LOAD05
 Raz [F:RBR]REMNUM
Endif
Return

$CODCIB
CODCIB = [F:BAN]CRY+mid$(CHAMP,RG,[F:TFB]LNG)
If find(CODCIB,TCODCIB(1..NCODCIB))
 [F:RBK]BANCIB = CODCIB
Else
 [F:RBK]BANCIB = mid$(CHAMP,RG,[F:TFB]LNG)
Endif
Return

$CODREJ
CODREJ = [F:BAN]CRY+mid$(CHAMP,RG,[F:TFB]LNG)
If find(CODREJ,TCODREJ(1..NCODREJ))
 [F:RBK]RENREJ = CODREJ
Else
 [F:RBK]RENREJ = mid$(CHAMP,RG,[F:TFB]LNG)
Endif
Return


$TRTTOTAL_POR
Call FILTRE(3) From SUBRBK
[F:RBK]RECTYP = 3
Gosub TRTCOMMUN_POR
Filter [TFB]
If (OLD_SOLDE + TOT_MVT) <> [F:RBK]AMTCUR * [F:RBK]SNS
 Call TRACE(mess(13,120,1),[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
 #Nouveau solde <> Ancien solde + Total des mouvements
 COK = 0
Endif
Raz OLD_SOLDE,TOT_MVT
Return


$TRTCOMP_POR
ENREGOK = 0
If !LOAD05
 If TEM=0
  # Filtrage d'enregistrements complûˋmentaires : 05
  Call TRACE(mess(57,120,1),left$(CHAMP,2),[0/0/0]) From SUBRBK
  TEM = 1
 Endif
Else
 # Intûˋgration dûˋveloppement Emmanuel LATOUR : Ecriture dans RELBANKREM...
 [F:RBR]RBKNUM = [F:RBK]RBKNUM
 [F:RBR]BAN    = [F:BAN]BAN
 [F:RBR]RBKLIN = LIN_REL-1
 [F:RBR]REMNUM +=1
 Raz [F:RBR]REM
 Call FILTRE(4) From SUBRBK
 For [TFB]TFB0
  Case [F:TFB]FRM
   When "REM"     : [F:RBR]REM = mid$(CHAMP,RG,[F:TFB]LNG)
  Endcase
  RG +=[F:TFB]LNG
 Next
 Filter [TFB]
Endif
Return

$LECBANK_POR
Raz [F:BAN]
Filter [BAN] Where mid$(BIDNUM,1,LNGBQE)=IMPBQE &
&                  mid$(BIDNUM,LNGBQE+1,LNGGUI)=IMPGUI &
&                  mid$(BIDNUM,LNGBQE+LNGGUI+1,LNGCPT)=mid$(CHAMP,RG,[F:TFB]LNG)
#Filter [BAN] Where BIDNUM=NIB
COK = 0
For [BAN]BAN0
 If ([F:BAN]BAN=[M:DIA]BAN) | [M:DIA]BAN=""
  If [F:BAN]CUR=""
   Call SETCUR(1,[F:BAN]CPY,[F:BAN]CUR) From CPTDIV
  Endif
  If ([F:BAN]CUR=[F:RBK]CUR) | [F:RBK]CUR=""
   [F:RBK]BAN = [F:BAN]BAN
   [F:RBK]CUR = [F:BAN]CUR
   COK = 1
   Break
  Else COK=-1
  Endif
 Elsif COK=0 : COK=-2
 Endif
Next
Filter [BAN]
If COK = 0
 Call TRACE(mess(5,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
 #Rib du relevûˋ inexistant dans fichier BANK
Elsif COK<>1
 If COK=-1
  Call TRACE(mess(6,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Devise banque diffûˋrente de la devise du relevûˋ
 Elsif COK=-2
  Call TRACE(mess(50,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Relevûˋ d'une autre banque
 Endif
 COK=0
Endif
If val(IMPDEC)=0
 If [F:RBK]CUR<>[F:TCU]CUR
  Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
 Endif
 If [F:TCU]DECNBR<>0 : IMPDEC=num$([F:TCU]DECNBR) : Endif
Endif
Return

##################################################
Subprog NORMA43(VFICDON)
Value Char VFICDON
##################################################
#### COPIA DEL FICHERO ORIGINAL               ####
##################################################
Local Char ENR(250)
Local Integer DET
Gosub DECLARE From SUBRBK
FICHIER=[L]VFICDON

Call MACHINE(FICHIER,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS        = chr$(10)
                SEP_CHEMIN = "/"
 When Default : IRS        = chr$(13)+chr$(10)
                SEP_CHEMIN = "\"
Endcase

POS1 = 1
POS2 = 0
Repeat
 POS2 = instr(POS1,FICHIER,SEP_CHEMIN)
 If POS2>=POS1 : POS1 = POS2+1 : Endif
Until !POS2
FIC = right$(FICHIER,POS1) : # JML 26/04/00 Ne sert plus !
Openo filpath(mid$(FICHIER,1,POS1-1),FIC,"BAK"),0
Openi [L]FICHIER

Rdseq ENR
While fstat=0
Wrseq ENR
Rdseq ENR
Wend

Openo
##################################################
#### TRANSFORMACIûN DEL FICHERO NORMA 43      ####
#### EN EL FORMATO NECESARIO PARA RELBAN      ####
##################################################
Local Char ENREG(81),BANQUE(5),GUICHET(5),COMPTE(11),DTSOLDE(6),SENS(1)
Local Char IMPORTE(14),CAR(1),CIB(2),REF(16), LIBEL(31)
Local Char DTOPE(6), DTVAL(6), DTFIN(6), DEVISE(3), NBDEC(1)
Local Char C1,C2
Local Integer I,A,B,J


##################################################
#### APERTURA DE FICHEROS                     ####
##################################################

Openi filpath(mid$(FICHIER,1,POS1-1),FIC,"BAK")
Openo [L]VFICDON,0
adxirs=chr$(13)+chr$(10)

##################################################
#### LECTURA SECUENCIAL DEL FICHERO           ####
##################################################
Rdseq ENREG
While fstat=0
Gosub TRATAMIENTO
Rdseq ENREG
Wend

Openo
 Call IMPRBK3([L]VFICDON,[M:DIA]BAN)
GPE=1

End

$TRATAMIENTO
##################################################
#### TRATAMIENTO SEGûN CADA TIPO DE REGISTRO  ####
##################################################

Case left$(ENREG,2)
    When "11" : Gosub CABECERA : Return
    When "22" : Gosub DETALLE  : Return
    When "23" : Gosub DET23    : Return
    When "33" : Gosub TOTAL    : Return
    When Default               : Return
Endcase
Return

$CABECERA
##################################################
### REGISTROS DE CABECERA                     ####
##################################################

DET=0
[L]BANQUE=mid$(ENREG,3,5)
[L]GUICHET=mid$(ENREG,8,3)
[L]COMPTE=mid$(ENREG,11,10)
Gosub DIGIT_CONTROL
[L]DTSOLDE=mid$(ENREG,25,2)+mid$(ENREG,23,2)+mid$(ENREG,21,2)
[L]DTFIN=mid$(ENREG,31,2)+mid$(ENREG,29,2)+mid$(ENREG,27,2)

[L]SENS=mid$(ENREG,33,1)
Case mid$(ENREG,48,3)
    When "230"  : [L]DEVISE="ESP": [L]NBDEC="2"
    When "978"  : [L]DEVISE="EUR": [L]NBDEC="2"    #CODIGO EUR#
    When Default: [L]DEVISE="EUR": [L]NBDEC="2"
Endcase
[L]IMPORTE=mid$(ENREG,34,14): Gosub FORM_IMPORTE

Wrseq "01";                            :#   2
Wrseq [L]BANQUE;                       :#   7
Wrseq space$(4);                       :#   11
Wrseq [L]GUICHET;                      :#   16
Wrseq [L]DEVISE;                       :#   19
Wrseq [L]NBDEC;                        :#   20
Wrseq space$(1);                       :#   21
Wrseq format$("11X",[L]COMPTE);        :#   32
Wrseq space$(2);                       :#   34
Wrseq [L]DTSOLDE;                      :#   40
Wrseq space$(50);                      :#   90
Wrseq [L]IMPORTE;                      :#   104
Wrseq space$(16)                       :#   120

Return

$DETALLE
###################################################
#### REGISTROS DETALLE                         ####
###################################################
If DET=1
Wrseq format$("120X",REGISTRO)
Endif
DET=1:RESGISTRO=""
[L]CIB=mid$(ENREG,23,2)
[L]DTOPE=mid$(ENREG,15,2)+mid$(ENREG,13,2)+mid$(ENREG,11,2)
[L]DTVAL=mid$(ENREG,21,2)+mid$(ENREG,19,2)+mid$(ENREG,17,2)
[L]LIBEL=mid$(ENREG,51,30)
[L]REF=mid$(ENREG,43,10)
[L]SENS=mid$(ENREG,28,1)
[L]IMPORTE=mid$(ENREG,29,14): Gosub FORM_IMPORTE

REGISTRO="04"
REGISTRO +=[L]BANQUE                       :#   7
REGISTRO +=space$(4)                       :#   11
REGISTRO +=[L]GUICHET                      :#   16
REGISTRO += [L]DEVISE                      :#   19
REGISTRO += [L]NBDEC                        :#   20
REGISTRO += space$(1)                       :#   21
REGISTRO += format$("11X",[L]COMPTE)        :#   32
REGISTRO += [L]CIB                         :#   34
REGISTRO += [L]DTOPE                        :#   40
REGISTRO += space$(2)                       :#   42
REGISTRO += [L]DTVAL                        :#   48
REGISTRO += format$("31X",[L]LIBEL)         :#   79
REGISTRO += space$(11)                      :#   90
REGISTRO += [L]IMPORTE                      :#   104
REGISTRO += format$("16X",[L]REF)           :#   120

Return

$DET23
######################################################
### registros de tipo 23
######################################################
If mid$(ENREG,5,31)="                               "
[L]LIBEL=mid$(ENREG,5,31)
Endif
If [L]LIBEL="                               "
[L]LIBEL=mid$(ENREG,43,31)
Endif

REGISTRO=mid$(REGISTRO,1,48)+format$("31X",[L]LIBEL)+mid$(REGISTRO,80,30)

Return

$TOTAL
###################################################
#### REGISTROS TOTAL                           ####
###################################################
Wrseq format$("120X",REGISTRO)
[L]SENS=mid$(ENREG,59,1)
[L]IMPORTE=mid$(ENREG,60,14): Gosub FORM_IMPORTE

Wrseq "07";                            :#   2
Wrseq [L]BANQUE;                       :#   7
Wrseq space$(4);                       :#   11
Wrseq [L]GUICHET;                      :#   16
Wrseq [L]DEVISE;                       :#   19
Wrseq [L]NBDEC;                        :#   20
Wrseq space$(1);                       :#   21
Wrseq format$("11X",[L]COMPTE);        :#   32
Wrseq space$(2);                       :#   34
Wrseq [L]DTFIN;                        :#   40
Wrseq space$(50);                      :#   90
Wrseq [L]IMPORTE;                      :#   104
Wrseq space$(16)                       :#   120

Return

$FORM_IMPORTE
###################################################
#### FORMATO DEL IMPORTE                       ####
###################################################
CAR=mid$(IMPORTE,14,1)
If [L]SENS="2"
    Case CAR
         When "0" : CAR="{"
         When "1" : CAR="A"
         When "2" : CAR="B"
         When "3" : CAR="C"
         When "4" : CAR="D"
         When "5" : CAR="E"
         When "6" : CAR="F"
         When "7" : CAR="G"
         When "8" : CAR="H"
         When "9" : CAR="I"
    Endcase
Else
    Case CAR
         When "0" : CAR="}"
         When "1" : CAR="J"
         When "2" : CAR="K"
         When "3" : CAR="L"
         When "4" : CAR="M"
         When "5" : CAR="N"
         When "6" : CAR="O"
         When "7" : CAR="P"
         When "8" : CAR="Q"
         When "9" : CAR="R"
    Endcase
Endif
IMPORTE=mid$(IMPORTE,1,13)+CAR
Return

$DIGIT_CONTROL
###################################################
#### CALCULO DE LOS DIGITOS DE CONTROL         ####
###################################################
C1=[L]BANQUE+[L]GUICHET
P1="37498625"
J=0
    For I=1 To 8
        J+=(val(mid$(C1,I,1)))*(1+val(mid$(P1,I,1)))
    Next I
    A=J/11
    A=J-A*11
    A=11-A
    If A=11 : A=0 : Endif
    If A=10 : A=1 : Endif

[L]GUICHET += num$(A)

C2=[L]COMPTE
P2="0137498625"
J=0
    For I=1 To 10
        J+=(val(mid$(C2,I,1)))*(1+val(mid$(P2,I,1)))
    Next I
    B=J/11
    B=J-B*11
    B=11-B
    If B=11 : B=0 : Endif
    If B=10 : B=1 : Endif

[L]GUICHET += num$(B)
Return



###########################################################################
Subprog IMPRBK3(FICHIER,BANQUE)
###########################################################################
Variable Char FICHIER()
Variable Char BANQUE()

Gosub DECLARE From SUBRBK
Call MACHINE(FICHIER,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS        = chr$(10)
                SEP_CHEMIN = "/"
 When Default : IRS        = chr$(13)+chr$(10)
                SEP_CHEMIN = "\"
Endcase

POS1 = 1
POS2 = 0
Repeat
 POS2 = instr(POS1,FICHIER,SEP_CHEMIN)
 If POS2>=POS1 : POS1 = POS2+1 : Endif
Until !POS2
FIC = right$(FICHIER,POS1) : # JML 26/04/00 Ne sert plus !
COK=1

#DBA le 18/08/03 : En espagne comme au portugal, il n'ont pas
#d'enreg. de type Sous-Total.
#Donc au lieu d'imposer une entûˆte + un dûˋtail + un total + un sous-total
#on impose uniquement la prûˋsence d'une entûˆte + un dûˋtail + un total.
For I = 1 To 4
 Read [TFB]TFB0 = [M:DIA]NOMFIC;"";I
 If fstat
  If I<>4
   COK = 0 : Break
  Else
   NBRECTYP=3 : Break
  Endif
 Else
  RECTYP(I) = [F:TFB]FRM
 Endif
Next I
If NBRECTYP=3
 # XYZ : Pas d'enregistrement Sous-total
 Call ECR_TRACE([M:DIA]NOMFIC-":"-mess(65,120,1),0) From GESECRAN
Endif
If !COK
 # Problû´me paramûˋtrage fichier bancaire
 Call ECR_TRACE(mess(155,117,1)-[M:DIA]NOMFIC,1) From GESECRAN
 End
Endif

For [TFB]TFB0 Where COD=[M:DIA]NOMFIC & BAN="" & RECTYP=1
 LONG += [F:TFB]LNG : #Longueur d'un champ
Next
Local Schar CHAMP(LONG)
Gosub IMPORTATION
End


$IMPORTATION
Raz J,K, OLD_SOLDE, TOT_MVT, NBR
#Positionnement sur la premiû´re ligne valide
Openi FICHIER,0
Gosub LECTEST From SUBRBK
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST From SUBRBK
Wend

#Test si sûˋparateur d'enregistrement
Openi FICHIER,J
Gosub LECTURE From SUBRBK
Gosub LECTEST From SUBRBK
K = 0
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST From SUBRBK
Wend
Openi FICHIER,J
Local Schar CHAMP(K+LONG)

#Traitement du fichier
MAJCHRONO = 0
Raz OLDRIB
Gosub LECTURE From SUBRBK
While !fstat
 RG = 1
 COK = 1
 ENREGOK = 1
 NOCOMP = [F:RBK]RBKNUM
 Raz [F:RBK]
 [F:RBK]RBKNUM = NOCOMP
 [F:RBK]ORI = 1
 If !find(left$(CHAMP,2),RECTYP(1..NBRECTYP))
  Call TRACE(left$(CHAMP,2),mess(4,120,1),[0/0/0]) From SUBRBK
  #Code enregistrement inexistant
  COK = -1
 Else
  Gosub CALCRIB From SUBRBK
  If ![L]TRANSAC :# Pas de transaction en cours
   Trbegin [RBK]
   [L]TRANSAC = 1
   FIN        = 0
   LIN_REL    = 1
   REM_REL    = 0
   OLDRIB     = NEWRIB
   MAJCHRONO  = 1
  Else
   If OLDRIB <> NEWRIB & [F:TFB]FILREF<>'si'
    # RIB diffûˋrent
    Call TRACE(mess(51,120,1),NEWRIB,[0/0/0]) From SUBRBK
    COK = 0
   Endif
  Endif
  If COK=1
   Case left$(CHAMP,2)
    When RECTYP(1) : Gosub TRTENTETE
    When RECTYP(2) : Gosub TRTDETAIL
    When RECTYP(3) : Gosub TRTTOTAL
    When RECTYP(4) : Gosub TRTCOMP From SUBRBK
   Endcase
  Endif
 Endif

 # Intrûˋgration dûˋveloppement Emmanuel LATOUR : Ecriture des enregistrements de type 05
 # dans la table des commentaires des relevûˋs de comptes bancaires
 If left$(CHAMP,2)=RECTYP(4) & LOAD05
  [F:RBK]NUMRBK = uniqid([F:RBK])
  Write [RBR]
  If fstat
   GOK = 0 : Call FSTA("RBR") From GLOCK : Goto ROLL_RBK
  Endif
  REM_REL+=1
 Endif

 If ENREGOK
  If COK=1
   If MAJCHRONO=1
    COMPTREG = ""
    Call LEC_CPY([F:BAN]CPY) From CPTLEC
    If [F:CPY]MAIFCY=""
     # Pas de site principal rattachûˋ û  la sociûˋtûˋ - F56436
     Call ECR_TRACE(mess(68,107,1)-[F:BAN]CPY,1) From GESECRAN : Goto ROLL_RBK
    Else
     Call GETSOC([F:CPY]MAIFCY) From DEVSUB
     Call LECTCA(3,OKTCA) From SUBTCA
     If OKTCA : COMPTREG = [F:TCA]CODNUM(5) : Endif
     If COMPTREG="" : COMPTREG = "RBK" : Endif
     Call NUMERO(COMPTREG,[F:CPY]MAIFCY,datesyst,"",[F:RBK]RBKNUM,STAT) From SUBANM
     If STAT | GOK<1
      # Problû´me lors de la rûˋcupûˋration du compteur
      Gosub MESSAGE From SUBANM
      Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN : Goto ROLL_RBK
     Endif
    Endif
    MAJCHRONO = 0
   Endif
   [F:RBK]RBKLIN = LIN_REL
   [F:RBK]NUMRBK = uniqid([F:RBK])
   Write [RBK]
   If fstat
    GOK = 0 : Call FSTA("RBK") From GLOCK : Goto ROLL_RBK
   Endif
   LIN_REL +=1
   GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC
   If GOK<1 : Goto ROLL_RBK : Endif
   Gosub LECTURE From SUBRBK
  Endif
  If COK<1
   If COK=0 : Gosub ROLL_RBK : Endif
   Repeat : #Saut jusqu'au prochain rib
    Gosub LECTURE From SUBRBK
    If !fstat & !DBL : Gosub CALCRIB From SUBRBK : Endif
   Until (!DBL & find(left$(CHAMP,2),RECTYP(1),RECTYP(2)) & NEWRIB<>OLDRIB) |
&         (DBL & find(left$(CHAMP,2),RECTYP(1))) | fstat
  Endif
  # Les lignes d'un RIB se terminent par une ligne Total 03
  If [F:RBK]RECTYP=3 & !FIN
   Commit
   [L]TRANSAC = 0
   NBR = 1
   If !REM_REL
    # lignes importûˋes du relevûˋ Nô¯
    Call TRACE(num$(LIN_REL-1)-mess(14,120,1),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Else
    # lignes et commentaires importûˋs du relevûˋ Nô¯
    Call TRACE(num$(LIN_REL-1)-tolower(mess(7,105,1))+","-num$(REM_REL)-tolower(mess(61,120,1)),mess(49,120,1)-num$([F:RBK]RBKNUM)
&           -[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
   Endif
  Endif
 Else
  Gosub LECTURE From SUBRBK
 Endif
Wend
If [L]TRANSAC  :# Transaction en cours
 Gosub ROLL_RBK
 # Pas d'enregistrement total
 Call ECR_TRACE(mess(52,120,1),0) From GESECRAN
Endif
If !NBR
 Call ECR_TRACE(mess(8,120,1),0) From GESECRAN
 #Pas de relevûˋ û  importer
Endif
Return

$LECBANK
Raz [F:BAN]
If [F:TFB]FILREF = 'si'
  Filter [BAN] Where mid$(BIDNUM,1,LNGBQE-1)=right$(IMPBQE,2) &
&                    mid$(BIDNUM,LNGBQE+LNGGUI-1,LNGCPT)=mid$(CHAMP,RG,[F:TFB]LNG)
Else
  Filter [BAN] Where mid$(BIDNUM,1,LNGBQE)=IMPBQE &
&                    mid$(BIDNUM,LNGBQE+1,LNGGUI)=IMPGUI &
&                    mid$(BIDNUM,LNGBQE+LNGGUI+1,LNGCPT-1)=mid$(CHAMP,RG,[F:TFB]LNG-1)
Endif
COK = 0
For [BAN]BAN0
 If ([F:BAN]BAN=[M:DIA]BAN) | [M:DIA]BAN=""
  If [F:BAN]CUR=""
   Call SETCUR(1,[F:BAN]CPY,[F:BAN]CUR) From CPTDIV
  Endif
  If ([F:BAN]CUR=[F:RBK]CUR) | [F:RBK]CUR=""
   [F:RBK]BAN = [F:BAN]BAN
   [F:RBK]CUR = [F:BAN]CUR
   COK = 1
   Break
  Else COK=-1
  Endif
 Elsif COK=0 : COK=-2
 Endif
Next
Filter [BAN]
If COK = 0
 Call TRACE(mess(5,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
 #Rib du relevûˋ inexistant dans fichier BANK
Elsif COK<>1
 If COK=-1
  Call TRACE(mess(6,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Devise banque diffûˋrente de la devise du relevûˋ
 Elsif COK=-2
  Call TRACE(mess(50,120,1),IMPBQE-IMPGUI-mid$(CHAMP,RG,[F:TFB]LNG),[0/0/0]) From SUBRBK
  # Relevûˋ d'une autre banque
 Endif
 COK=0
Endif
If val(IMPDEC)=0
 If [F:RBK]CUR<>[F:TCU]CUR
  Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
 Endif
 If [F:TCU]DECNBR<>0 : IMPDEC=num$([F:TCU]DECNBR) : Endif
Endif
Return

$TRTCOMMUN
[F:RBK]CHK = ""
[F:RBK]DATCHK=[0/0/0]
[F:RBK]SNS=0
COK=1
For [TFB]TFB0
 Gosub CTR_FRM From SUBRBK
 If COK=1
  Case [F:TFB]FRM
   When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG) : LNGBQE=[F:TFB]LNG
   When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG) : LNGGUI=[F:TFB]LNG
   When "DEVISE"  : Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
   When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
   When "COMPTE"  : LNGCPT =[F:TFB]LNG : Gosub LECBANK
   When "DTSOLDE" : Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
   When "MTSOLDE" : Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
   When "DTXTR"   : Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]DATXTR) From SUBRBK
  Endcase
  Gosub MAJ_FRM From SUBRBK
  RG +=[F:TFB]LNG
 Endif
 If COK=0 : Break : Endif
Next
Return

$TRTDETAIL
Call FILTRE(2) From SUBRBK
[F:RBK]RECTYP = 2
For [TFB]TFB0(4)
 For [TFB]TFB0
  Gosub CTR_FRM  From SUBRBK
  Case [F:TFB]FRM
   When "BANQUE"  : IMPBQE = mid$(CHAMP,RG,[F:TFB]LNG): LNGBQE=[F:TFB]LNG
   When "COI"     : IMPCOI = mid$(CHAMP,RG,[F:TFB]LNG)
   When "GUICHET" : IMPGUI = mid$(CHAMP,RG,[F:TFB]LNG): LNGGUI=[F:TFB]LNG
   When "DEVISE"  : Call DEV((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]CUR,COK) From SUBRBK
   When "NBDEC"   : IMPDEC = mid$(CHAMP,RG,[F:TFB]LNG)
   When "COMPTE"  : LNGCPT=[F:TFB]LNG : Gosub LECBANK
   When "CIB"     : Gosub CODCIB
   When "REJET"   : Gosub CODREJ
   When "LIBEL"   : [F:RBK]DES    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "NO"      : [F:RBK]ENTNUM = mid$(CHAMP,RG,[F:TFB]LNG)
   When "IEXO"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDCOM = 1 : Endif
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDCOM = 2 : Endif
   When "IIND"    : If mid$(CHAMP,RG,[F:TFB]LNG) = "0" : [F:RBK]INDUVY = 1 : Endif
                    If mid$(CHAMP,RG,[F:TFB]LNG) = "1" : [F:RBK]INDUVY = 2 : Endif
   When "REF"     : [F:RBK]REF    = mid$(CHAMP,RG,[F:TFB]LNG)
   When "MONTANT"
    Call MT((mid$(CHAMP,RG,[F:TFB]LNG)),IMPDEC,[F:RBK]AMTCUR,[F:RBK]SNS,COK) From SUBRBK
    If [F:RBK]AMTCUR = 0
     [F:RBK]CHK = "*"
     [F:RBK]DATCHK=date$
    Else
     [F:RBK]CHK = ""
     [F:RBK]DATCHK=[0/0/0]
    Endif
   When "DTOPE"
    Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]OPEDAT) From SUBRBK
   When "DTVAL"
    Call DAT((mid$(CHAMP,RG,[F:TFB]LNG)),[F:RBK]VALDAT) From SUBRBK
  Endcase
  Gosub MAJ_FRM From SUBRBK
  RG +=[F:TFB]LNG
  If COK=0 : Break 2 : Endif
 Next
 TOT_MVT = TOT_MVT + ([F:RBK]AMTCUR * [F:RBK]SNS)
Next
Filter [TFB]
If LOAD05
 Raz [F:RBR]REMNUM
Endif
Return

$TRTENTETE
DBL = 0  : # initialisation du tûˋmoin de recyclage
# TRESO -- Fiche 62-13/09/02-GB -
Raz OLD_SOLDE,TOT_MVT  # initialisation de l'ancien solde et du total mouvement
# TRESO -- Fin ------------------

Call FILTRE(1) From SUBRBK
[F:RBK]RECTYP = 1
Gosub TRTCOMMUN
Filter [TFB]
OLD_SOLDE = [F:RBK]AMTCUR * [F:RBK]SNS

If COK = 1
 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=3 & OPEDAT <= [F:RBK]OPEDAT &
&                      CUR=[F:RBK]CUR
 Read [RBKK]RBK1 Last
 Filter [RBKK]
 If !fstat & [F:RBKK]AMTCUR <> [F:RBK]AMTCUR
  # L'ancien solde ne correspond pas au solde prûˋcûˋdent
  Call TRACE(mess(11,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
 Endif

 If !fstat & [F:RBKK]OPEDAT <> [F:RBK]OPEDAT
  # Date ancien solde ne correspond pas au relevûˋ prûˋcûˋdent
  Call TRACE(mess(60,120,1),[F:RBK]BAN-num$([F:RBK]AMTCUR),[F:RBK]OPEDAT) From SUBRBK
 Endif

 Filter [RBKK] Where BAN=[F:RBK]BAN & RECTYP=1 & OPEDAT=[F:RBK]OPEDAT &
&                    CUR=[F:RBK]CUR & AMTCUR=[F:RBK]AMTCUR
 Read [RBKK]RBK1 First
 Filter [RBKK]
 If !fstat
  # Relevûˋ dûˋjû  importûˋ No
  Call TRACE(mess(10,120,1),mess(49,120,1)-num$([F:RBKK]RBKNUM)-[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
  DBL = 1 : COK = 0 : Return
 Endif
Endif
Return

$TRTTOTAL
Call FILTRE(3) From SUBRBK
[F:RBK]RECTYP = 3
Gosub TRTCOMMUN
Filter [TFB]
If (OLD_SOLDE + TOT_MVT) <> [F:RBK]AMTCUR * [F:RBK]SNS
 Call TRACE(mess(13,120,1),[F:RBK]BAN,[F:RBK]OPEDAT) From SUBRBK
 #Nouveau solde <> Ancien solde + Total des mouvements
 COK = 0
Endif
Raz OLD_SOLDE,TOT_MVT
Return

