#<AdxTL>@(#)0.0.0.0 $Revision$
# TRTDIMBIVEN    Traitement pour les dimensions des documents de ventes BI         #
# -------------------------------------------------------------------------------- #
# FIN_SQUOTE_ELT_FAC    : Màj dimension SORDER avec les demandes de livraison      #
# FIN_SORDER_DEM_LIVR   : Màj dimension SORDER avec les demandes de livraison      #
# FIN_SORDER_ELT_FAC    : Màj dimension SORDER avec les éléments de facturation    #
# FIN_SDELIVERY_ELT_FAC : Màj dimension SDELIVERY avec les éléments de facturation #
# FIN_SINVOICE_ELT_FAC  : Màj dimension SINVOICE avec les éléments de facturation  #
# FIN_SINVOICE_ECHEANCE : Màj dimension SINVOICE avec les échéances                #
####################################################################################
# 06/01/2010 (SYMEU) : Si toutes les règles de synchronisation alimentées par la   #
# Fiche 61356          table d'origine de la dimension sont désactivées, le trai-  #
#                      tement n'est pas exécuté                                    #
####################################################################################
# 12/01/2010 (SYMEU) : Problème dans la requête sql avec les demandes de livraison #
# Fiche 61511          fermes quand on est sous sql                                #
####################################################################################
# 15/01/2010 (SYMEU) : Pb d'écriture sous sql-server quand le code postal con-     #
# Fiche 61649          tient des espaces                                           #
####################################################################################

###################################################################
## ACTION Mise à jour des dimensions X3                           #
###################################################################
$ACTION
  Case ACTION
    When "DEBUT_DIM"  : Gosub DEBUT_DIM
    When "OUVRE_DIM"  : Gosub OUVRE_DIM #--CPO 92324 V7.1: BI modification for data by legislation
    When "FERME_DIM"  : Gosub FERME_DIM #--CPO 92324 V7.1: BI modification for data by legislation
    When "FIN_DIM"    : Gosub FIN_DIM
  Endcase
Return

###################################################################
$DEBUT_DIM
  #Case TABLE
  #  When "D_XXX" : Gosub DEBUT_XXX
  #Endcase
Return

###################################################################
$FIN_DIM
  Gosub FIN_TABLE
Return

###################################################################################
#--CPO 92324 V7.1: BI modification for data by legislation
$OUVRE_DIM
  Gosub FERME_DIM
  Case TABLE
    When "D_SQUOTE"    : Gosub OUVRE_DIM_SQUOTE
    When "D_SORDER"    : Gosub OUVRE_DIM_SORDER
    When "D_SDELIVERY" : Gosub OUVRE_DIM_DELIVERY
    When "D_SINVOICE"  : Gosub OUVRE_DIM_SINVOICE
    When "D_SRETURN"   : Gosub OUVRE_DIM_SRETURN
  Endcase
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_SQUOTE
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".SQUOTED"    [WSQD]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_SORDER
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".TABSOHTYP"  [TSO]
  Local File   =GDOSSIER+".TABSDHTYP"  [TSD]
  Local File   =GDOSSIER+".SORDERQ"    [WSOQ]    # FGR 16/06/2014 : X3SUIVI98503
  Local File   =GDOSSIER+".SORDERP"    [WSOP]    # FGR 16/06/2014 : X3SUIVI98503
  Local File   =GDOSSIER+".SORDERC"    [WSOC]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_DELIVERY
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".TABSDHTYP"  [TSD]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".SDELIVERYD" [WSDD]    # FGR 16/06/2014 : X3SUIVI98503
Return
#----------------------------------------------------------------------------------
$OUVRE_DIM_SINVOICE
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".TABSIVTYP"  [TSV]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".SINVOICED"  [WSID]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_SRETURN
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".TABSRHTYP"  [TRE]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".SRETURND"   [WSRD]    # FGR 16/06/2014 : X3SUIVI98503
Return

###################################################################################
#--CPO 92324 V7.1: BI modification for data by legislation
$FERME_DIM
  If clalev([F:TVB])  : Close Local File [TVB] : Endif
  If clalev([F:TVT])  : Close Local File [TVT] : Endif
  If clalev([F:TPT])  : Close Local File [TPT] : Endif
  If clalev([F:TDA])  : Close Local File [TDA] : Endif
  If clalev([F:TSD])  : Close Local File [TSD] : Endif
  If clalev([F:TRE])  : Close Local File [TRE] : Endif
  If clalev([F:TSO])  : Close Local File [TSO] : Endif
  If clalev([F:TSV])  : Close Local File [TSV] : Endif
  If clalev([F:TSC])  : Close Local File [TSC] : Endif
  If clalev([F:TEC])  : Close Local File [TEC] : Endif
  If clalev([F:WSQD]) : Close Local File [WSQD] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSOQ]) : Close Local File [WSOQ] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSOP]) : Close Local File [WSOP] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSOC]) : Close Local File [WSOC] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSDD]) : Close Local File [WSDD] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSID]) : Close Local File [WSID] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WSRD]) : Close Local File [WSRD] : Endif     # FGR 16/06/2014 : X3SUIVI98503
Return

###################################################################################
## FIN_TABLE : Mise à jour des dimensions avec les éléments de facturation        #
###################################################################################
$FIN_TABLE
  Gosub DECL_VAR
  Gosub READ_DIM
  #
  # SYMEU - Fiche 61356 - début
  # Toutes les règles de synchronisation alimentées par la table d'origine de la dimension sont
  # désactivées : on n'exécute pas le traitement
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  Case TABLE
    When "D_SQUOTE"    : Local File =MACHINE+"@"+[F:ABW]COD+".D_SQUOTE" [F:BBB_]    # Dimension SQUOTE
    When "D_SORDER"    : Local File =MACHINE+"@"+[F:ABW]COD+".D_SORDER" [F:BBB_]    # Dimension SORDER
    When "D_SDELIVERY" : Local File =MACHINE+"@"+[F:ABW]COD+".D_SDELIVERY" [F:BBB_] # Dimension SDELIVERY
    When "D_SINVOICE"  : Local File =MACHINE+"@"+[F:ABW]COD+".D_SINVOICE" [F:BBB_]  # Dimension SINVOICE
    When "D_SRETURN"   : Return  # Dimension SRETURN  (CPO)
    When Default       : Return  # FGR 16/06/2014 : X3SUIVI98503
  Endcase
  # Boucle sur les dossiers
  For D = 1 To NBDOS
    If [F:ABI]MULDOS <> 2 & D = 2 Then
      Break
    Endif # la dimension n'est pas multi-dossier
    GDOSSIER=TBDOS(D)
    Case TABLE
      When "D_SQUOTE"    : Gosub FIN_SQUOTE_ELT_FAC
      When "D_SORDER"    : Gosub FIN_SORDER_DEM_LIVR
                           Gosub FIN_SORDER_ELT_FAC
      When "D_SDELIVERY" : Gosub FIN_SDELIVERY_ELT_FAC
      When "D_SINVOICE"  : Gosub FIN_SINVOICE_ELT_FAC
                           Gosub FIN_SINVOICE_ECHEANCE
    Endcase
  Next D
  Close Local File [F:BBB_]
Return

###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SQUOTE
###################################################################################
$FIN_SQUOTE_ELT_FAC
Local Integer W_SQDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro SQUOTEINV.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("SQUOTEINV")
  If [L]DESFLG = 2 Then Return : Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","SVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SQUOTE" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de SVCRFOOT
    WREQ(0)= "select SVF.VCRNUM_0, SVF.DTA_0, SQH.QUODAT_0, SQH.VLYDAT_0, SQH.QUOSTA_0, SQH.EECICT_0, "
    WREQ(0)+="SQH.FFWNUM_0, SQH.VACBPR_0, SVF.DTAVAT_0, SQH.PTE_0, SQH.DEP_0, SQH.PBYPRC_0, "
    WREQ(0)+="SFI.ITMREF_0, SQH.BPCPOSCOD_0, SQH.BPCCTY_0, SQH.BPCCRY_0, "
    WREQ(1)= "SQH.BPDNAM_0, SQH.BPDPOSCOD_0, SQH.BPDCTY_0, SQH.BPDCRY_0, CPY.LEG_0 "
    WREQ(1)+="From "+GDOSSIER+".SVCRFOOT SVF,"+GDOSSIER+".SFOOTINV SFI,"+GDOSSIER+".SQUOTE SQH,"+GDOSSIER+".COMPANY CPY "
    WREQ(2)= "Where SFI.SFINUM_0=SVF.DTA_0 and SQH.SQHNUM_0=SVF.VCRNUM_0 and CPY.CPY_0=SQH.CPY_0 "
    WREQ(2)+="and SVF.VCRTYP_0=1 and SFI.PROCOD_0<>3 and SFI.DSPLIN_0>0 and SFI.ITMREF_0<>' '"
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer DTA, Date QUODAT, Date VLYDAT, Integer QUOSTA, Char EECICT(5),
#&        Char FFWNUM(15), Char VACBPR(5), Char DTAVAT(5), Char PTE(15), Char DEP(3), Integer PBYPRC,
#&        Char ITMREF(20), Char BPCPOSCOD(10), Char BPCCTY(40), Char BPCCRY(3),
#&        Char BPDNAM(35), Char BPDPOSCOD(10), Char BPDCTY(40), Char BPDCRY(3), Char CPYLEG(3))
#&        From WBASE Sql WREQ(0..2) As [F:REQ_]
    For (Char VCRNUM(GLONVCR), Integer DTA, Date QUODAT, Date VLYDAT, Integer QUOSTA, Char EECICT(GLONICT),
&        Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char DTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA), Integer PBYPRC,
&        Char ITMREF(GLONITM), Char BPCPOSCOD(GLONPOS), Char BPCCTY(GLONCTY), Char BPCCRY(GLONCRY),
&        Char BPDNAM(GLONNAM), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY), Char CPYLEG(GLONADI))
&        From WBASE Sql WREQ(0..2) As [F:REQ_]
      # Vérification que le devis existe dans la dimension SQUOTE qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      #Filter [F:BBB_] Where SQHNUM=[F:REQ_]VCRNUM
      #NB_ENREG = rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]SQD0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # le devis a été trouvé
        W_SQDLIN = func TRTX3BI.GETLASTLIN("SQUOTED",[F:REQ_]VCRNUM)+[F:REQ_]DTA
        #Read [F:BBB_]SQD0=[F:REQ_]VCRNUM;W_SQDLIN
        Look [F:BBB_]SQD0=[F:REQ_]VCRNUM;W_SQDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension SQUOTE avec les éléments de facturation
          [F:BBB_]SQHNUM = [F:REQ_]VCRNUM       #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]SQDLIN = W_SQDLIN           #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]QUODAT)>0     : [F:BBB_]QUODAT     = [F:REQ_]QUODAT   : Endif
          If dim([F:BBB_]VLYDAT)>0     : [F:BBB_]VLYDAT     = [F:REQ_]VLYDAT   : Endif
          If dim([F:BBB_]QUOSTA)>0     : [F:BBB_]QUOSTA     = [F:REQ_]QUOSTA   : Endif
          If dim([F:BBB_]EECICT)>0     : [F:BBB_]EECICT     = [F:REQ_]EECICT   : Endif
          If dim([F:BBB_]FFWNUM)>0     : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM   : Endif
          If dim([F:BBB_]VACBPR)>0     : [F:BBB_]VACBPR     = [F:REQ_]VACBPR   : Endif
          If dim([F:BBB_]VACBPR_LEG)>0 : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0        : [F:BBB_]VAT        = [F:REQ_]DTAVAT   : Endif
          If dim([F:BBB_]VAT_LEG)>0    : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]DTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0        : [F:BBB_]PTE        = [F:REQ_]PTE      : Endif
          If dim([F:BBB_]PTE_LEG)>0    : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0        : [F:BBB_]DEP        = [F:REQ_]DEP      : Endif
          If dim([F:BBB_]DEP_LEG)>0    : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PBYPRC)>0     : [F:BBB_]PBYPRC     = [F:REQ_]PBYPRC   : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0    : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF, WBASE) : Endif
          #         [F:BBB_]BPCPOSCOD=[F:REQ_]BPCPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPCPOSCOD)>0  : [F:BBB_]BPCPOSCOD  = vireblc([F:REQ_]BPCPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPCCTY)>0     : [F:BBB_]BPCCTY     = [F:REQ_]BPCCTY   : Endif
          If dim([F:BBB_]BPCCRY)>0     : [F:BBB_]BPCCRY     = [F:REQ_]BPCCRY   : Endif
          If dim([F:BBB_]BPDNAM)>0     : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM   : Endif
          #         [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPDPOSCOD)>0  : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPDCTY)>0     : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY   : Endif
          If dim([F:BBB_]BPDCRY)>0     : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY   : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]SQHNUM-num$([F:BBB_]SQDLIN)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SQUOTE" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

################################################################################################
## Parcours de SORDERQ pour alimenter la dimension SORDER avec les demandes de livraison fermes
################################################################################################
$FIN_SORDER_DEM_LIVR
  If filinfo(filpath("FIL","SORDERQ","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : SORDERQ"-mess(6,2246,1)-"SORDER" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de SORDERQ
    WREQ(0)= "select SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0, SOH.SOHTYP_0, SOH.SOHCAT_0, SOH.ORDDAT_0, SOH.REVNUM_0, "
    WREQ(0)+="SOQ.SOQSTA_0, SOQ.INVFLG_0, SOQ.DEMSTA_0, SOQ.DEMDLVDAT_0, SOQ.SHIDAT_0, SOQ.EXTDLVDAT_0,"
    WREQ(0)+="SOQ.DAYLTI_0, SOQ.FMI_0, SOQ.MDL_0, "
    WREQ(1)= "SOH.EECICT_0, SOQ.BPTNUM_0, SOH.FFWNUM_0, SOQ.PCK_0, SOQ.PCKCAP_0, SOH.VACBPR_0, "
    WREQ(1)+="SOH.PTE_0, SOH.DEP_0, SOQ.CCLREN_0, SOQ.CCLDAT_0, "
    WREQ(1)+="SOH.BPCNAM_0, SOH.CNTNAM_0, SOH.BPCPOSCOD_0,"
    WREQ(2) ="SOH.BPCCTY_0,SOH.BPCCRY_0,SOH.BPDNAM_0,SOH.CNDNAM_0,SOH.BPDPOSCOD_0,SOH.BPDCTY_0, "
    WREQ(2)+="SOH.BPDCRY_0,SOH.BPINAM_0,SOH.CNINAM_0,SOH.BPIPOSCOD_0,SOH.BPICTY_0, SOH.BPICRY_0, "
    WREQ(2)+="SOQ.FMINUM_0, SOQ.FMILIN_0, SOQ.FMISEQ_0, SOQ.POHNUM_0, SOQ.POPLIN_0, SOQ.POQSEQ_0 "
    WREQ(3) =", CPY.LEG_0 From "+GDOSSIER+".SORDERQ SOQ,"+GDOSSIER+".SORDER SOH,"+GDOSSIER+".COMPANY CPY "
    WREQ(3)+="Where SOQ.SOHCAT_0=4 and SOQ.DEMSTA_0=1 and SOH.SOHNUM_0=SOQ.SOHNUM_0 and CPY.CPY_0=SOH.CPY_0 "
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char SOHNUM(20), Integer SOPLIN, Integer SOQSEQ, Char SOHTYP(5), Integer SOHCAT, Date ORDDAT, Integer REVNUM,
#&        Integer SOQSTA, Integer INVFLG, Integer DEMSTA, Date DEMDLVDAT, Date SHIDAT, Date EXTDLVDAT,
#&        Integer DAYLTI, Integer FMI, Char MDL(5),
#&        Char EECICT(5), Char BPTNUM(15), Char FFWNUM(15), Char PCK(5), Decimal PCKCAP, Char VACBPR(5),
#&        Char PTE(15), Char DEP(3), Char CCLREN(5), Date CCLDAT,
#&        Char BPCNAM(35), Char CNTNAM(15), Char BPCPOSCOD(10),
#&        Char BPCCTY(40), Char BPCCRY(3), Char BPDNAM(35), Char CNDNAM(15), Char BPDPOSCOD(10), Char BPDCTY(40),
#&        Char BPDCRY(3), Char BPINAM(35), Char CNINAM(15), Char BPIPOSCOD (10), Char BPICTY(40), Char BPICRY(3),
#&        Char FMINUM(20), Integer FMILIN, Integer FMISEQ, Char POHNUM(20), Integer POPLIN, Integer POQSEQ, Char CPYLEG(3))
#&        From WBASE Sql WREQ(0..3) As [F:REQ_]
    For (Char SOHNUM(GLONSOH), Integer SOPLIN, Integer SOQSEQ, Char SOHTYP(GLONTSO), Integer SOHCAT, Date ORDDAT, Integer REVNUM,
&        Integer SOQSTA, Integer INVFLG, Integer DEMSTA, Date DEMDLVDAT, Date SHIDAT, Date EXTDLVDAT,
&        Integer DAYLTI, Integer FMI, Char MDL(GLONMDL),
&        Char EECICT(GLONICT), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char PCK(GLONPCK), Decimal PCKCAP, Char VACBPR(GLONTVB),
&        Char PTE(GLONPTE), Char DEP(GLONTDA), Char CCLREN(GLONADI), Date CCLDAT,
&        Char BPCNAM(GLONNAM), Char CNTNAM(GLONAIN), Char BPCPOSCOD(GLONPOS),
&        Char BPCCTY(GLONCTY), Char BPCCRY(GLONCRY), Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY),
&        Char BPDCRY(GLONCRY), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN), Char BPIPOSCOD (GLONPOS), Char BPICTY(GLONCTY), Char BPICRY(GLONCRY),
&        Char FMINUM(GLONVCR), Integer FMILIN, Integer FMISEQ, Char POHNUM(GLONVCR), Integer POPLIN, Integer POQSEQ, Char CPYLEG(GLONADI))
&        From WBASE Sql WREQ(0..3) As [F:REQ_]
      #Read [F:BBB_]SOQ0=[F:REQ_]SOHNUM;[F:REQ_]SOPLIN;[F:REQ_]SOQSEQ
      Look [F:BBB_]SOQ0=[F:REQ_]SOHNUM;[F:REQ_]SOPLIN;[F:REQ_]SOQSEQ  # FGR 16/06/2014 :X3SUIVI98503
      If fstat Then
        # Pour chaque demande de livraison, je vais rechercher le bon enregistrement dans SORDERP, pour valoriser la demande
        WREQ3(0) ="select SOP.VAT_0, SOP.ITMDES1_0, SOP.LINTYP_0, SOP.FOCFLG_0, SOP.GROPRI_0, SOP.NETPRI_0, SOP.CPRPRI_0, "
        WREQ3(0)+="SOP.PFM_0, SOP.SAU_0, SOP.SAUSTUCOE_0, SOP.REPRAT1_0, SOP.REPRAT2_0, SOP.SQHNUM_0, SOP.SQDLIN_0 "
        WREQ3(0)+="From "+GDOSSIER+".SORDERP SOP "
        WREQ3(1)="Where SOP.SOHNUM_0='"+[F:REQ_]SOHNUM+"' and SOP.SOPLIN_0="+num$([F:REQ_]SOPLIN)+" and SOP.STRDAT_0<="
        If WBASE = "3" Then
          # Oracle
          WREQ3(1)+="TO_DATE('"+[F:REQ_]DEMDLVDAT+"','YYYYMMDD')"
        Else
          #         WREQ3(1)+="'"+num$([F:REQ_]DEMDLVDAT)+"'" # SYMEU 61511
          WREQ3(1)+="convert(char,"+[F:REQ_]DEMDLVDAT+")" # SYMEU 61511
        Endif
        WREQ3(1)+=" Order by SOP.STRDAT_0 desc"
        Raz [F:BBB_]
        [F:BBB_]SOHNUM = [F:REQ_]SOHNUM #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]SOPLIN = [F:REQ_]SOPLIN #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]SOQSEQ = [F:REQ_]SOQSEQ #--CPO Elément de clé => pas de test if dim()
        #--CPO 81446 Test sur l'existence d'un champ avant init
        If dim([F:BBB_]SOHTYP)>0      : [F:BBB_]SOHTYP     = [F:REQ_]SOHTYP    : Endif
        If dim([F:BBB_]SOHTYP_LEG)>0  : [F:BBB_]SOHTYP_LEG = func TRTX3BIVEN.GETLEG_SOHTYP([F:REQ_]SOHTYP, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]SOHCAT)>0      : [F:BBB_]SOHCAT     = [F:REQ_]SOHCAT    : Endif
        If dim([F:BBB_]ORDDAT)>0      : [F:BBB_]ORDDAT     = [F:REQ_]ORDDAT    : Endif
        If dim([F:BBB_]REVNUM)>0      : [F:BBB_]REVNUM     = [F:REQ_]REVNUM    : Endif
        If dim([F:BBB_]SOQSTA)>0      : [F:BBB_]SOQSTA     = [F:REQ_]SOQSTA    : Endif
        If dim([F:BBB_]INVFLG)>0      : [F:BBB_]INVFLG     = [F:REQ_]INVFLG    : Endif
        If dim([F:BBB_]DEMSTA)>0      : [F:BBB_]DEMSTA     = [F:REQ_]DEMSTA    : Endif
        If dim([F:BBB_]DEMDLVDAT)>0   : [F:BBB_]DEMDLVDAT  = [F:REQ_]DEMDLVDAT : Endif
        If dim([F:BBB_]SHIDAT)>0      : [F:BBB_]SHIDAT     = [F:REQ_]SHIDAT    : Endif
        If dim([F:BBB_]EXTDLVDAT)>0   : [F:BBB_]EXTDLVDAT  = [F:REQ_]EXTDLVDAT : Endif
        If dim([F:BBB_]DAYLTI)>0      : [F:BBB_]DAYLTI     = [F:REQ_]DAYLTI    : Endif
        If dim([F:BBB_]FMI)>0         : [F:BBB_]FMI        = [F:REQ_]FMI       : Endif
        If dim([F:BBB_]MDL)>0         : [F:BBB_]MDL        = [F:REQ_]MDL       : Endif
        If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
        If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM    : Endif
        If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
        If dim([F:BBB_]PCK)>0         : [F:BBB_]PCK        = [F:REQ_]PCK       : Endif
        If dim([F:BBB_]PCKCAP)>0      : [F:BBB_]PCKCAP     = [F:REQ_]PCKCAP    : Endif
        If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR    : Endif
        If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
        If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP       : Endif
        If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]CCLREN)>0      : [F:BBB_]CCLREN     = [F:REQ_]CCLREN    : Endif
        If dim([F:BBB_]CCLDAT)>0      : [F:BBB_]CCLDAT     = [F:REQ_]CCLDAT    : Endif
        If dim([F:BBB_]BPCNAM)>0      : [F:BBB_]BPCNAM     = [F:REQ_]BPCNAM    : Endif
        If dim([F:BBB_]CNTNAM)>0      : [F:BBB_]CNTNAM     = [F:REQ_]CNTNAM    : Endif
        #       [F:BBB_]BPCPOSCOD=[F:REQ_]BPCPOSCOD # SYMEU 61649
        If dim([F:BBB_]BPCPOSCOD)>0   : [F:BBB_]BPCPOSCOD  = vireblc([F:REQ_]BPCPOSCOD,1) : Endif  # SYMEU 61649
        If dim([F:BBB_]BPCCTY)>0      : [F:BBB_]BPCCTY     = [F:REQ_]BPCCTY    : Endif
        If dim([F:BBB_]BPCCRY)>0      : [F:BBB_]BPCCRY     = [F:REQ_]BPCCRY    : Endif
        If dim([F:BBB_]BPDNAM)>0      : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM    : Endif
        If dim([F:BBB_]CNDNAM)>0      : [F:BBB_]CNDNAM     = [F:REQ_]CNDNAM    : Endif
        #       [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
        If dim([F:BBB_]BPDPOSCOD)>0   : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
        If dim([F:BBB_]BPDCTY)>0      : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY    : Endif
        If dim([F:BBB_]BPDCRY)>0      : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY    : Endif
        If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPINAM    : Endif
        If dim([F:BBB_]CNINAM)>0      : [F:BBB_]CNINAM     = [F:REQ_]CNINAM    : Endif
        #       [F:BBB_]BPIPOSCOD=[F:REQ_]BPIPOSCOD # SYMEU 61649
        If dim([F:BBB_]BPIPOSCOD)>0   : [F:BBB_]BPIPOSCOD  = vireblc([F:REQ_]BPIPOSCOD,1) : Endif  # SYMEU 61649
        If dim([F:BBB_]BPICTY)>0      : [F:BBB_]BPICTY     = [F:REQ_]BPICTY    : Endif
        If dim([F:BBB_]BPICRY)>0      : [F:BBB_]BPICRY     = [F:REQ_]BPICRY    : Endif
        If dim([F:BBB_]FMINUM)>0      : [F:BBB_]FMINUM     = [F:REQ_]FMINUM    : Endif
        If dim([F:BBB_]FMILIN)>0      : [F:BBB_]FMILIN     = [F:REQ_]FMILIN    : Endif
        If dim([F:BBB_]POHNUM)>0      : [F:BBB_]POHNUM     = [F:REQ_]POHNUM    : Endif
        If dim([F:BBB_]POPLIN)>0      : [F:BBB_]POPLIN     = [F:REQ_]POPLIN    : Endif
        If dim([F:BBB_]POQSEQ)>0      : [F:BBB_]POQSEQ     = [F:REQ_]POQSEQ    : Endif
        # FGR 10/10/2014 : X3SUIVI102999
#        For (Char VAT(5), Char ITMDES1(30), Integer LINTYP, Integer FOCFLG, Decimal GROPRI, Decimal NETPRI,
#&            Decimal CPRPRI, Decimal PFM, Char SAU(3), Decimal SAUSTUCOE, Decimal REPRAT1, Decimal REPRAT2,
#&            Char SQHNUM(20), Integer SQDLIN) From WBASE Sql WREQ3(0..1) As [RE3_]
        For (Char VAT(GLONVAT), Char ITMDES1(GLONDES), Integer LINTYP, Integer FOCFLG, Decimal GROPRI, Decimal NETPRI,
&            Decimal CPRPRI, Decimal PFM, Char SAU(GLONUOM), Decimal SAUSTUCOE, Decimal REPRAT1, Decimal REPRAT2,
&            Char SQHNUM(GLONSQH), Integer SQDLIN) From WBASE Sql WREQ3(0..1) As [RE3_]
          # Alimentation de la dimension PORDER avec les demandes de livraison
          If dim([F:BBB_]VAT)>0       : [F:BBB_]VAT        = [RE3_]VAT       : Endif
          If dim([F:BBB_]VAT_LEG)>0   : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:RE3_]VAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]ITMDES1)>0   : [F:BBB_]ITMDES1    = [RE3_]ITMDES1   : Endif
          If dim([F:BBB_]LINTYP)>0    : [F:BBB_]LINTYP     = [RE3_]LINTYP    : Endif
          If dim([F:BBB_]FOCFLG)>0    : [F:BBB_]FOCFLG     = [RE3_]FOCFLG    : Endif
          If dim([F:BBB_]GROPRI)>0    : [F:BBB_]GROPRI     = [RE3_]GROPRI    : Endif
          If dim([F:BBB_]NETPRI)>0    : [F:BBB_]NETPRI     = [RE3_]NETPRI    : Endif
          If dim([F:BBB_]CPRPRI)>0    : [F:BBB_]CPRPRI     = [RE3_]CPRPRI    : Endif
          If dim([F:BBB_]PFM)>0       : [F:BBB_]PFM        = [RE3_]PFM       : Endif
          If dim([F:BBB_]SAU)>0       : [F:BBB_]SAU        = [RE3_]SAU       : Endif
          If dim([F:BBB_]SAUSTUCOE)>0 : [F:BBB_]SAUSTUCOE  = [RE3_]SAUSTUCOE : Endif
          #--CPO 73819 : Activity code dependent fields (REPRAT1 and REPRAT2)
          If dim([F:BBB_]REPRAT1)>0   : [F:BBB_]REPRAT1    = [RE3_]REPRAT1   : Endif
          If dim([F:BBB_]REPRAT2)>0   : [F:BBB_]REPRAT2    = [RE3_]REPRAT2   : Endif
          #--End 73819
          [F:BBB_]SQHNUM = [RE3_]SQHNUM
          [F:BBB_]SQDLIN = [RE3_]SQDLIN
          Break # On ne prend que le premier enregistrement de SORDERP
        Next
        #--/CPO
        IBBB_WRITE += 1   # FGR 15/05/2014 :X3SUIVI98503
        CHAINE = [F:BBB_]SOHNUM-num$([F:BBB_]SOPLIN)-num$([F:BBB_]SOQSEQ)
        Write [F:BBB_]
        If fstat Then
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : SORDERQ"-mess(6,2246,1)-"SORDER" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SORDER
###################################################################################
$FIN_SORDER_ELT_FAC
Local Integer W_SOPLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro SORDERINV.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("SORDERINV")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","SVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SORDER" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de SVCRFOOT
    WREQ(0)= "select SVF.VCRNUM_0, SVF.DTA_0, SOH.SOHTYP_0, SOH.SOHCAT_0, SOH.ORDDAT_0, SOH.REVNUM_0, "
    WREQ(0)+="SOH.EECICT_0, SOH.BPTNUM_0, SOH.FFWNUM_0, SOH.VACBPR_0, SVF.DTAVAT_0, SOH.PTE_0, SOH.DEP_0, "
    WREQ(0)+="SOH.CCLREN_0, SOH.CCLDAT_0, SFI.ITMREF_0, "
    WREQ(1)= "SOH.BPCNAM_0, SOH.CNTNAM_0, SOH.BPCPOSCOD_0, SOH.BPCCTY_0, SOH.BPCCRY_0, SOH.BPDNAM_0, "
    WREQ(1)+="SOH.CNDNAM_0, SOH.BPDPOSCOD_0, SOH.BPDCTY_0, SOH.BPDCRY_0, SOH.BPINAM_0, SOH.CNINAM_0, "
    WREQ(1)+="SOH.BPIPOSCOD_0, SOH.BPICTY_0, SOH.BPICRY_0, CPY.LEG_0 "
    WREQ(2)= "From "+GDOSSIER+".SVCRFOOT SVF,"+GDOSSIER+".SFOOTINV SFI,"+GDOSSIER+".SORDER SOH,"+GDOSSIER+".COMPANY CPY "
    WREQ(3) ="Where SFI.SFINUM_0=SVF.DTA_0 and SOH.SOHNUM_0=SVF.VCRNUM_0 and CPY.CPY_0=SOH.CPY_0 "  # FGR 16/01/2015 : X3SUIVI105492 : pb de longueur de chaîne
    WREQ(3)+="and SVF.VCRTYP_0=20 and SFI.PROCOD_0<>3 and SFI.DSPLIN_0>0 and SFI.ITMREF_0<>' '"     # FGR 16/01/2015 : X3SUIVI105492 : pb de longueur de chaîne
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer DTA, Char SOHTYP(5), Integer SOHCAT, Date ORDDAT, Integer REVNUM,
#&        Char EECICT(5), Char BPTNUM(15), Char FFWNUM(15), Char VACBPR(5), Char DTAVAT(5), Char PTE(15), Char DEP(3),
#&        Char CCLREN(5), Date CCLDAT, Char ITMREF(20),
#&        Char BPCNAM(35), Char CNTNAM(15), Char BPCPOSCOD(10), Char BPCCTY(40), Char BPCCRY(3), Char BPDNAM(35),
#&        Char CNDNAM(15), Char BPDPOSCOD(10), Char BPDCTY(40), Char BPDCRY(3), Char BPINAM(35), Char CNINAM(15),
#&        Char BPIPOSCOD(10), Char BPICTY(40), Char BPICRY(3),  Char CPYLEG(3)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    For (Char VCRNUM(GLONVCR), Integer DTA, Char SOHTYP(GLONTSO), Integer SOHCAT, Date ORDDAT, Integer REVNUM,
&        Char EECICT(GLONICT), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char DTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA),
&        Char CCLREN(GLONADI), Date CCLDAT, Char ITMREF(GLONITM),
&        Char BPCNAM(GLONNAM), Char CNTNAM(GLONAIN), Char BPCPOSCOD(GLONPOS), Char BPCCTY(GLONCTY), Char BPCCRY(GLONCRY), Char BPDNAM(GLONNAM),
&        Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN),
&        Char BPIPOSCOD(GLONPOS), Char BPICTY(GLONCTY), Char BPICRY(GLONCRY),  Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..3) As [F:REQ_]
      # Vérification que la commande existe dans la dimension SORDER qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where SOHNUM=[F:REQ_]VCRNUM
      #NB_ENREG = rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]SOQ0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la commande a été trouvée
        W_SOPLIN = func TRTX3BI.GETLASTLIN("SORDERQ",[F:REQ_]VCRNUM)+[F:REQ_]DTA
        #Read [F:BBB_]SOQ0=[F:REQ_]VCRNUM;W_SOPLIN;1000
        Look [F:BBB_]SOQ0=[F:REQ_]VCRNUM;W_SOPLIN;1000   # FGR 16/06/2014 : X3SUIVI98503
        If fstat
          Raz [F:BBB_]
          # Alimentation de la dimension SORDER avec les éléments de facturation
          [F:BBB_]SOHNUM = [F:REQ_]VCRNUM #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]SOPLIN = W_SOPLIN     #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]SOQSEQ = 1000         #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]SOHTYP)>0      : [F:BBB_]SOHTYP     = [F:REQ_]SOHTYP : Endif
          If dim([F:BBB_]SOHTYP_LEG)>0  : [F:BBB_]SOHTYP_LEG = func TRTX3BIVEN.GETLEG_SOHTYP([F:REQ_]SOHTYP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]SOHCAT)>0      : [F:BBB_]SOHCAT     = [F:REQ_]SOHCAT : Endif
          If dim([F:BBB_]ORDDAT)>0      : [F:BBB_]ORDDAT     = [F:REQ_]ORDDAT : Endif
          If dim([F:BBB_]REVNUM)>0      : [F:BBB_]REVNUM     = [F:REQ_]REVNUM : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT : Endif
          If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]DTAVAT : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]DTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE    : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP    : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]CCLREN)>0      : [F:BBB_]CCLREN     = [F:REQ_]CCLREN : Endif
          If dim([F:BBB_]CCLDAT)>0      : [F:BBB_]CCLDAT     = [F:REQ_]CCLDAT : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF,WBASE) : Endif
          If dim([F:BBB_]BPCNAM)>0      : [F:BBB_]BPCNAM     = [F:REQ_]BPCNAM : Endif
          If dim([F:BBB_]CNTNAM)>0      : [F:BBB_]CNTNAM     = [F:REQ_]CNTNAM : Endif
          #         [F:BBB_]BPCPOSCOD=[F:REQ_]BPCPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPCPOSCOD)>0   : [F:BBB_]BPCPOSCOD  = vireblc([F:REQ_]BPCPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPCCTY)>0      : [F:BBB_]BPCCTY     = [F:REQ_]BPCCTY : Endif
          If dim([F:BBB_]BPCCRY)>0      : [F:BBB_]BPCCRY     = [F:REQ_]BPCCRY : Endif
          If dim([F:BBB_]BPDNAM)>0      : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM : Endif
          If dim([F:BBB_]CNDNAM)>0      : [F:BBB_]CNDNAM     = [F:REQ_]CNDNAM : Endif
          #         [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPDPOSCOD)>0   : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPDCTY)>0      : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY : Endif
          If dim([F:BBB_]BPDCRY)>0      : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY : Endif
          If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPINAM : Endif
          If dim([F:BBB_]CNINAM)>0      : [F:BBB_]CNINAM     = [F:REQ_]CNINAM : Endif
          #         [F:BBB_]BPIPOSCOD=[F:REQ_]BPIPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPIPOSCOD)>0   : [F:BBB_]BPIPOSCOD  = vireblc([F:REQ_]BPIPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPICTY)>0      : [F:BBB_]BPICTY     = [F:REQ_]BPICTY : Endif
          If dim([F:BBB_]BPICRY)>0      : [F:BBB_]BPICRY     = [F:REQ_]BPICRY : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]SOHNUM-num$([F:BBB_]SOPLIN)-num$([F:BBB_]SOQSEQ)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SORDER" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SDELIVERY
###################################################################################
$FIN_SDELIVERY_ELT_FAC
Local Integer W_SDDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro SDELIVINV.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("SDELIVINV")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","SVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SDELIVERY" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de SVCRFOOT
    WREQ(0)= "select SVF.VCRNUM_0, SVF.DTA_0, SDH.SDHCAT_0, SDH.LND_0, SDH.SHIDAT_0, SDH.DAYLTI_0, "
    WREQ(0)+="SDH.LNDRTNDAT_0, SDH.INVFLG_0, SDH.MDL_0, SDH.EECICT_0, SDH.EECSCH_0, SDH.EECNAT_0, "
    WREQ(0)+="SDH.BPTNUM_0, SDH.FFWNUM_0, SVF.DTAVAT_0, SDH.PTE_0, SDH.DEP_0, SFI.ITMREF_0, "
    WREQ(1)= "SDH.BPDNAM_0, SDH.CNDNAM_0, SDH.BPDPOSCOD_0, SDH.BPDCTY_0, SDH.BPDCRY_0, "
    WREQ(1)+="SDH.BPINAM_0, SDH.CNINAM_0, SDH.BPIPOSCOD_0, SDH.BPICTY_0, SDH.BPICRY_0, SDH.SCO_0, CPY.LEG_0, SDH.VACBPR_0, SDH.SDHTYP_0 "               #--CPO 75115 - 202 Remplacement SDHCAT par SCO
    WREQ(2) = "From "+GDOSSIER+".SVCRFOOT SVF,"+GDOSSIER+".SFOOTINV SFI,"+GDOSSIER+".SDELIVERY SDH,"+GDOSSIER+".COMPANY CPY "
    WREQ(3) = "Where SFI.SFINUM_0=SVF.DTA_0 and SDH.SDHNUM_0=SVF.VCRNUM_0 and CPY.CPY_0=SDH.CPY_0 "
    WREQ(3)+="and SVF.VCRTYP_0=2 and SFI.PROCOD_0<>3 and SFI.DSPLIN_0>0 and SFI.ITMREF_0<>' '"
    WREQ(3)+="and SDH.CFMFLG_0=2"
    #--CPO 75115 - 202 Remplacement SDHCAT par SCO
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer DTA, Integer SDHCAT, Integer LND, Date SHIDAT, Integer DAYLTI,
#&        Date LNDRTNDAT, Integer INVFLG, Char MDL(5), Char EECICT(5), Char EECSCH(5), Char EECNAT(5),
#&        Char BPTNUM(15), Char FFWNUM(15), Char DTAVAT(5), Char PTE(15), Char DEP(3), Char ITMREF(20),
#&        Char BPDNAM(35), Char CNDNAM(15), Char BPDPOSCOD(10), Char BPDCTY(40), Char BPDCRY(3),
#&        Char BPINAM(35), Char CNINAM(15), Char BPIPOSCOD(10), Char BPICTY(40), Char BPICRY(3),
#&        Integer SCO,     Char CPYLEG(3),  Char VACBPR(5), Char SDHTYP(5))
#&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char VCRNUM(GLONVCR), Integer DTA, Integer SDHCAT, Integer LND, Date SHIDAT, Integer DAYLTI,
#&        Date LNDRTNDAT, Integer INVFLG, Char MDL(GLONMDL), Char EECICT(GLONICT), Char EECSCH(GLONTSC), Char EECNAT(GLONTEC),
#&        Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char DTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM),
#&        Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY),
#&        Char BPINAM(GLONNAM), Char CNINAM(GLONAIN), Char BPIPOSCOD(GLONPOS), Char BPICTY(GLONCTY), Char BPICRY(GLONCRY),
#&        Integer SCO,     Char CPYLEG(GLONADI),  Char VACBPR(GLONTVB), Char SDHTYP(GLONTSD))
#&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char VCRNUM(GLONVCR), Integer DTA, Integer SDHCAT, Integer LND, Date SHIDAT, Integer DAYLTI,
&        Date LNDRTNDAT, Integer INVFLG, Char MDL(GLONMDL), Char EECICT(GLONICT), Char EECSCH(WLONTSC), Char EECNAT(WLONTEC),
&        Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char DTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM),
&        Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY),
&        Char BPINAM(GLONNAM), Char CNINAM(GLONAIN), Char BPIPOSCOD(GLONPOS), Char BPICTY(GLONCTY), Char BPICRY(GLONCRY),
&        Integer SCO,     Char CPYLEG(GLONADI),  Char VACBPR(GLONTVB), Char SDHTYP(GLONTSD))
&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # End issue 113406
      # Vérification que la livraison existe dans la dimension SDELIVERY qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where SDHNUM=[F:REQ_]VCRNUM
      #NB_ENREG = rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]SDD0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la livraison a été trouvée
        W_SDDLIN = func TRTX3BI.GETLASTLIN("SDELIVERYD",[F:REQ_]VCRNUM)+[F:REQ_]DTA
        #Read [F:BBB_]SDD0=[F:REQ_]VCRNUM;W_SDDLIN
        Look [F:BBB_]SDD0=[F:REQ_]VCRNUM;W_SDDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension SDELIVERY avec les éléments de facturation
          [F:BBB_]SDHNUM = [F:REQ_]VCRNUM
          [F:BBB_]SDDLIN = W_SDDLIN      #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
           #--CPO 75115 - 202 Remplacement SDHCAT par SCO
          If dim([F:BBB_]SDHCAT)>0      : [F:BBB_]SDHCAT     = [F:REQ_]SDHCAT     : Endif #- Le SDHCAT contiendra la catégorie de livraison
          If dim([F:BBB_]SCO)>0         : [F:BBB_]SCO        = [F:REQ_]SCO        : Endif #- SCO contient maintenant le flag sous-traitance
           #--/CPO 75115
          If dim([F:BBB_]LND)>0         : [F:BBB_]LND        = [F:REQ_]LND        : Endif
          If dim([F:BBB_]SHIDAT)>0      : [F:BBB_]SHIDAT     = [F:REQ_]SHIDAT     : Endif
          If dim([F:BBB_]DAYLTI)>0      : [F:BBB_]DAYLTI     = [F:REQ_]DAYLTI     : Endif
          If dim([F:BBB_]LNDRTNDAT)>0   : [F:BBB_]LNDRTNDAT  = [F:REQ_]LNDRTNDAT  : Endif
          If dim([F:BBB_]INVFLG)>0      : [F:BBB_]INVFLG     = [F:REQ_]INVFLG     : Endif
          If dim([F:BBB_]MDL)>0         : [F:BBB_]MDL        = [F:REQ_]MDL        : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT     : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH     : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT     : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM     : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM     : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]DTAVAT     : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]DTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE        : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP        : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR     : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_DEP([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF, WBASE) : Endif
          If dim([F:BBB_]BPDNAM)>0      : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM     : Endif
          If dim([F:BBB_]CNDNAM)>0      : [F:BBB_]CNDNAM     = [F:REQ_]CNDNAM     : Endif
          #         [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPDPOSCOD)>0   : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPDCTY)>0      : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY     : Endif
          If dim([F:BBB_]BPDCRY)>0      : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY     : Endif
          If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPINAM     : Endif
          If dim([F:BBB_]CNINAM)>0      : [F:BBB_]CNINAM     = [F:REQ_]CNINAM     : Endif
          #         [F:BBB_]BPIPOSCOD=[F:REQ_]BPIPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPIPOSCOD)>0   : [F:BBB_]BPIPOSCOD  = vireblc([F:REQ_]BPIPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPICTY)>0      : [F:BBB_]BPICTY     = [F:REQ_]BPICTY     : Endif
          If dim([F:BBB_]BPICRY)>0      : [F:BBB_]BPICRY     = [F:REQ_]BPICRY     : Endif
          If dim([F:BBB_]SDHTYP)>0      : [F:BBB_]SDHTYP     = [F:REQ_]SDHTYP     : Endif
          If dim([F:BBB_]SDHTYP_LEG)>0  : [F:BBB_]SDHTYP_LEG = func TRTX3BIVEN.GETLEG_SDHTYP([F:REQ_]SDHTYP, [F:REQ_]CPYLEG) : Endif
          #--CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]SDHNUM-num$([F:BBB_]SDDLIN)
          Write [F:BBB_]
          If fstat
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SDELIVERY" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SINVOICE
###################################################################################
$FIN_SINVOICE_ELT_FAC
Local Integer W_SIDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro SINVOICEIN.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("SINVOICEIN")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","SVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SINVOICE" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de SVCRFOOT
    WREQ(0)= "select SVF.VCRNUM_0, SVF.DTA_0, SIV.SIVTYP_0, SIV.INVTYP_0, SIV.INVDAT_0, SIH.BPRFCT_0, "
    WREQ(0)+="SIV.EECICT_0, SIV.EECSCH_0, SIV.EECNAT_0, SIV.FFWNUM_0, SIH.VAC_0, SVF.DTAVAT_0, "
    WREQ(0)+="SIH.PTE_0, SIH.DEP_0, SIV.CNOREN_0, SFI.ITMREF_0, SIV.BPINAM_0, SIV.CNINAM_0, "
    WREQ(1)= "SIH.POSCOD_0, SIH.CTY_0, SIH.CRY_0, SIV.BPDNAM_0, SIV.CNDNAM_0, SIV.BPDPOSCOD_0, SIV.BPDCTY_0, "
    WREQ(1)+="SIV.BPDCRY_0, SIH.BPYNAM_0, SIH.BPYPOSCOD_0, SIH.BPYCTY_0, SIH.BPYCRY_0, CPY.LEG_0 "
    WREQ(2)= "From "+GDOSSIER+".SVCRFOOT SVF,"+GDOSSIER+".SFOOTINV SFI,"+GDOSSIER+".SINVOICE SIH,"
    WREQ(2)+= GDOSSIER+".SINVOICEV SIV,"+GDOSSIER+".COMPANY CPY Where SFI.SFINUM_0=SVF.DTA_0 and SIH.NUM_0=SVF.VCRNUM_0 and SIV.NUM_0=SVF.VCRNUM_0 "
    WREQ(3)="and SVF.VCRTYP_0=4 and SFI.PROCOD_0<>3 and SFI.DSPLIN_0>0 and SFI.ITMREF_0<>' ' "
    WREQ(3)+="and SIH.STA_0=3 and SIH.ORIMOD_0=5 and CPY.CPY_0=SIH.CPY_0 "
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer DTA, Char SIVTYP(5), Integer INVTYP, Date INVDAT, Char BPRFCT(15),
#&        Char EECICT(5), Char EECSCH(5), Char EECNAT(5), Char FFWNUM(15), Char VAC(5), Char DTAVAT(5),
#&        Char PTE(15), Char DEP(3), Char CNOREN(5), Char ITMREF(20), Char BPINAM(35), Char CNINAM(15),
#&        Char POSCOD(10), Char CTY(40), Char CRY(3), Char BPDNAM(35), Char CNDNAM(15), Char BPDPOSCOD(10), Char BPDCTY(40),
#&        Char BPDCRY(3), Char BPYNAM(35), Char BPYPOSCOD(10), Char BPYCTY(40), Char BPYCRY(3), Char CPYLEG(3))
#&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char VCRNUM(GLONVCR), Integer DTA, Char SIVTYP(GLONTSV), Integer INVTYP, Date INVDAT, Char BPRFCT(GLONFCT),
#&        Char EECICT(GLONICT), Char EECSCH(GLONTSC), Char EECNAT(GLONTEC), Char FFWNUM(GLONBPR), Char VAC(GLONTVB), Char DTAVAT(GLONVAT),
#&        Char PTE(GLONPTE), Char DEP(GLONTDA), Char CNOREN(GLONADI), Char ITMREF(GLONITM), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN),
#&        Char POSCOD(GLONPOS), Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY),
#&        Char BPDCRY(GLONCRY), Char BPYNAM(GLONNAM), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI))
#&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char VCRNUM(GLONVCR), Integer DTA, Char SIVTYP(GLONTSV), Integer INVTYP, Date INVDAT, Char BPRFCT(GLONFCT),
&        Char EECICT(GLONICT), Char EECSCH(WLONTSC), Char EECNAT(WLONTEC), Char FFWNUM(GLONBPR), Char VAC(GLONTVB), Char DTAVAT(GLONVAT),
&        Char PTE(GLONPTE), Char DEP(GLONTDA), Char CNOREN(GLONADI), Char ITMREF(GLONITM), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN),
&        Char POSCOD(GLONPOS), Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY),
&        Char BPDCRY(GLONCRY), Char BPYNAM(GLONNAM), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI))
&       From WBASE Sql WREQ(0..3) As [F:REQ_]
    # End issue 113406
      # Vérification que la facture existe dans la dimension SINVOICE qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where SIHNUM=[F:REQ_]VCRNUM
      #NB_ENREG = rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]SID0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la facture a été trouvée
        W_SIDLIN = func TRTX3BI.GETLASTLIN("SINVOICED",[F:REQ_]VCRNUM)+[F:REQ_]DTA
        #Read [F:BBB_]SID0=[F:REQ_]VCRNUM;W_SIDLIN
        Look [F:BBB_]SID0=[F:REQ_]VCRNUM;W_SIDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension SINVOICE avec les éléments de facturation
          [F:BBB_]SIHNUM = [F:REQ_]VCRNUM   #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]SIDLIN = W_SIDLIN       #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]SIVTYP)>0      : [F:BBB_]SIVTYP     = [F:REQ_]SIVTYP : Endif
          If dim([F:BBB_]SIVTYP_LEG)>0  : [F:BBB_]SIVTYP_LEG = func TRTX3BIVEN.GETLEG_SIVTYP([F:REQ_]SIVTYP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]INVTYP)>0      : [F:BBB_]INVTYP     = [F:REQ_]INVTYP : Endif
          If dim([F:BBB_]INVDAT)>0      : [F:BBB_]INVDAT     = [F:REQ_]INVDAT : Endif
          If dim([F:BBB_]BPRFCT)>0      : [F:BBB_]BPRFCT     = [F:REQ_]BPRFCT : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM : Endif
          If dim([F:BBB_]VAC)>0         : [F:BBB_]VAC        = [F:REQ_]VAC    : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VAC, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]DTAVAT : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]DTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE    : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP    : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]CNOREN)>0      : [F:BBB_]CNOREN     = [F:REQ_]CNOREN : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF,WBASE) : Endif
          If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPINAM : Endif
          If dim([F:BBB_]CNINAM)>0      : [F:BBB_]CNINAM     = [F:REQ_]CNINAM : Endif
          #         [F:BBB_]POSCOD=[F:REQ_]POSCOD  # SYMEU 61649
          If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY    : Endif
          If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY    : Endif
          If dim([F:BBB_]BPDNAM)>0      : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM : Endif
          If dim([F:BBB_]CNDNAM)>0      : [F:BBB_]CNDNAM     = [F:REQ_]CNDNAM : Endif
          #         [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPDPOSCOD)>0   : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPDCTY)>0      : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY : Endif
          If dim([F:BBB_]BPDCRY)>0      : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY : Endif
          If dim([F:BBB_]BPYNAM)>0      : [F:BBB_]BPYNAM     = [F:REQ_]BPYNAM : Endif
          #         [F:BBB_]BPYPOSCOD=[F:REQ_]BPYPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPYPOSCOD)>0   : [F:BBB_]BPYPOSCOD  = vireblc([F:REQ_]BPYPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPYCTY)>0      : [F:BBB_]BPYCTY     = [F:REQ_]BPYCTY : Endif
          If dim([F:BBB_]BPYCRY)>0      : [F:BBB_]BPYCRY     = [F:REQ_]BPYCRY : Endif
          #--CPO
          IBBB_WRITE += 1   # FGR 15/05/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]SIHNUM-num$([F:BBB_]SIDLIN)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : SVCRFOOT"-mess(7,2246,1)-"SINVOICE" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de GACCDUDATE pour alimenter la dimension SINVOICE
###################################################################################
$FIN_SINVOICE_ECHEANCE
Local Integer W_SIDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro SINVOICEDU.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("SINVOICEDU")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","GACCDUDATE","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIVEN : GACCDUDATE"-mess(8,2246,1)-"SINVOICE" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de GACCDUDATE
    # FGR 16/06/2014 : X3SUIVI98503 : Ajout de , DUD.DUDLIG_0
    WREQ(0) ="select DUD.NUM_0, DUD.LIG_0, DUD.DUDLIG_0, SIV.SIVTYP_0, SIV.INVTYP_0, SIV.INVDAT_0, SIH.BPRFCT_0, "
    WREQ(0)+="SIV.EECICT_0, SIV.EECSCH_0, SIV.EECNAT_0, SIV.FFWNUM_0, SIH.VAC_0, SIH.PTE_0, "
    WREQ(0)+="SIV.DEP_0, SIV.CNOREN_0, SIV.BPINAM_0, SIV.CNINAM_0, SIH.POSCOD_0, SIH.CTY_0, "
    WREQ(1) ="SIH.CRY_0, SIV.BPDNAM_0, SIV.CNDNAM_0, SIV.BPDPOSCOD_0, SIV.BPDCTY_0, SIV.BPDCRY_0, "
    WREQ(1)+="SIH.BPYNAM_0, SIH.BPYPOSCOD_0, SIH.BPYCTY_0, SIH.BPYCRY_0, CPY.LEG_0 "
    # Issue X3-36424 - 2017-05-09 by CPO : (SAM 122819) BI synchro: error Oracle ORA-00933: SQL command not properly
   #WREQ(1)+="From "+GDOSSIER+".GACCDUDATE DUD,"+GDOSSIER+".SINVOICE SIH,"+GDOSSIER+".SINVOICEV SIV,"+GDOSSIER+".COMPANY CPY "
    WREQ(2) =" From "+GDOSSIER+".GACCDUDATE DUD,"+GDOSSIER+".SINVOICE SIH,"+GDOSSIER+".SINVOICEV SIV,"+GDOSSIER+".COMPANY CPY "
    #WREQ(2)= "Where SIH.NUM_0=DUD.NUM_0 and SIV.NUM_0=DUD.NUM_0 and SIH.STA_0=3 and SIH.ORIMOD_0=5 "
    #WREQ(2)+="and DUD.BPRTYP_0=1 and (DUD.PAYCUR_0+DUD.TMPCUR_0)>0 and CPY.CPY_0=SIH.CPY_0 "
    WREQ(3) =" Where SIH.NUM_0=DUD.NUM_0 and SIV.NUM_0=DUD.NUM_0 and SIH.STA_0=3 and SIH.ORIMOD_0=5 "
    WREQ(3)+="and DUD.BPRTYP_0=1 and (DUD.PAYCUR_0+DUD.TMPCUR_0)>0 and CPY.CPY_0=SIH.CPY_0 "
    # End issue X3-36424
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char NUM(20), Integer LIG, Integer DUDLIG, Char SIVTYP(5), Integer INVTYP, Date INVDAT, Char BPRFCT(15),
#&        Char EECICT(5), Char EECSCH(5), Char EECNAT(5), Char FFWNUM(15), Char VAC(5), Char PTE(15),
#&        Char DEP(3), Char CNOREN(5), Char BPINAM(35), Char CNINAM(15), Char POSCOD(10), Char CTY(40),
#&        Char CRY(3), Char BPDNAM(35), Char CNDNAM(15), Char BPDPOSCOD(10), Char BPDCTY(40), Char BPDCRY(3),
#&        Char BPYNAM(35), Char BPYPOSCOD(10), Char BPYCTY(40), Char BPYCRY(3), Char CPYLEG(3))
#&        From WBASE Sql WREQ(0..2) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char NUM(GLONVCR), Integer LIG, Integer DUDLIG, Char SIVTYP(GLONTSV), Integer INVTYP, Date INVDAT, Char BPRFCT(GLONBPR),
#&        Char EECICT(GLONICT), Char EECSCH(GLONTSC), Char EECNAT(GLONTEC), Char FFWNUM(GLONBPR), Char VAC(GLONTVB), Char PTE(GLONPTE),
#&        Char DEP(GLONTDA), Char CNOREN(GLONADI), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN), Char POSCOD(GLONPOS), Char CTY(GLONCTY),
#&        Char CRY(GLONCRY), Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY),
#&        Char BPYNAM(GLONNAM), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI))
#&        From WBASE Sql WREQ(0..2) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char NUM(GLONVCR), Integer LIG, Integer DUDLIG, Char SIVTYP(GLONTSV), Integer INVTYP, Date INVDAT, Char BPRFCT(GLONBPR),
&        Char EECICT(GLONICT), Char EECSCH(WLONTSC), Char EECNAT(WLONTEC), Char FFWNUM(GLONBPR), Char VAC(GLONTVB), Char PTE(GLONPTE),
&        Char DEP(GLONTDA), Char CNOREN(GLONADI), Char BPINAM(GLONNAM), Char CNINAM(GLONAIN), Char POSCOD(GLONPOS), Char CTY(GLONCTY),
&        Char CRY(GLONCRY), Char BPDNAM(GLONNAM), Char CNDNAM(GLONAIN), Char BPDPOSCOD(GLONPOS), Char BPDCTY(GLONCTY), Char BPDCRY(GLONCRY),
&        Char BPYNAM(GLONNAM), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI))
&        From WBASE Sql WREQ(0..3) As [F:REQ_] #(0..2) -> (0..3) # Issue X3-36424 - 2017-05-09 by CPO : (SAM 122819) BI synchro: error Oracle ORA-00933: SQL command not properly
    # End issue 113406
      # Vérification que la facture existe dans la dimension SINVOICE qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where SIHNUM=[F:REQ_]NUM
      #NB_ENREG = rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]SID0(1)=[F:REQ_]NUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la facture a été trouvée
        #W_SIDLIN = func TRTX3BI.GETLASTLIN("SINVOICED",[F:REQ_]NUM)+1000+[F:REQ_]LIG
        W_SIDLIN = func TRTX3BI.GETLASTLIN("SINVOICED",[F:REQ_]NUM)+1000+([F:REQ_]LIG*100)+[F:REQ_]DUDLIG  # FGR 16/06/2014 X3SUIVI98503
        #Read [F:BBB_]SID0=[F:REQ_]NUM;W_SIDLIN
        Look [F:BBB_]SID0=[F:REQ_]NUM;W_SIDLIN    # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension SINVOICE avec les échéances
          [F:BBB_]SIHNUM = [F:REQ_]NUM
          [F:BBB_]SIDLIN = W_SIDLIN   #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]SIVTYP)>0      : [F:BBB_]SIVTYP     = [F:REQ_]SIVTYP : Endif
          If dim([F:BBB_]SIVTYP_LEG)>0  : [F:BBB_]SIVTYP_LEG = func TRTX3BIVEN.GETLEG_SIVTYP([F:REQ_]SIVTYP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]INVTYP)>0      : [F:BBB_]INVTYP     = [F:REQ_]INVTYP : Endif
          If dim([F:BBB_]INVDAT)>0      : [F:BBB_]INVDAT     = [F:REQ_]INVDAT : Endif
          #--CPO 74690 Activity code dependent field
          If dim([F:BBB_]BPRFCT)>0      : [F:BBB_]BPRFCT     = [F:REQ_]BPRFCT : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM : Endif
          If dim([F:BBB_]VAC)>0         : [F:BBB_]VAC        = [F:REQ_]VAC    : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VAC, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE    : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP    : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]CNOREN)>0      : [F:BBB_]CNOREN     = [F:REQ_]CNOREN : Endif
          If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPINAM : Endif
          If dim([F:BBB_]CNINAM)>0      : [F:BBB_]CNINAM     = [F:REQ_]CNINAM : Endif
          #         [F:BBB_]POSCOD=[F:REQ_]POSCOD # SYMEU 61649
          If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY    : Endif
          If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY    : Endif
          If dim([F:BBB_]BPDNAM)>0      : [F:BBB_]BPDNAM     = [F:REQ_]BPDNAM : Endif
          If dim([F:BBB_]CNDNAM)>0      : [F:BBB_]CNDNAM     = [F:REQ_]CNDNAM : Endif
          #         [F:BBB_]BPDPOSCOD=[F:REQ_]BPDPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPDPOSCOD)>0   : [F:BBB_]BPDPOSCOD  = vireblc([F:REQ_]BPDPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPDCTY)>0      : [F:BBB_]BPDCTY     = [F:REQ_]BPDCTY : Endif
          If dim([F:BBB_]BPDCRY)>0      : [F:BBB_]BPDCRY     = [F:REQ_]BPDCRY : Endif
          If dim([F:BBB_]BPYNAM)>0      : [F:BBB_]BPYNAM     = [F:REQ_]BPYNAM : Endif
          #         [F:BBB_]BPYPOSCOD=[F:REQ_]BPYPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPYPOSCOD)>0   : [F:BBB_]BPYPOSCOD  = vireblc([F:REQ_]BPYPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPYCTY)>0      : [F:BBB_]BPYCTY     = [F:REQ_]BPYCTY : Endif
          If dim([F:BBB_]BPYCRY)>0      : [F:BBB_]BPYCRY     = [F:REQ_]BPYCRY : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 15/05/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]SIHNUM-num$([F:BBB_]SIDLIN)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIVEN : GACCDUDATE"-mess(8,2246,1)-"SINVOICE" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################
# Déclarations des variables de travail communes
###################################################################
$DECL_VAR
Local Char WREQ(255)(4)  : Raz WREQ  # Requete générique pour base Oracle et SqlServer 7
Local Char WREQ2(255)    : Raz WREQ2 # Requete secondaire pour lire ATEXTRA
Local Char WREQ3(255)(2) : Raz WREQ3 # Requete secondaire pour SORDERP
Local Integer D
Local Integer NB_ENREG   : NB_ENREG=0
Local Char WBASE(1)      : WBASE=" "
Local Integer DESFLG, NBACT, NBDES   # SYMEU - Fiche 61356

Local Integer ITIMEBEG               # FGR 16/06/2014 :X3SUIVI98503 : time début
Local Integer IBBB_WRITE             # FGR 16/06/2014 :X3SUIVI98503 : time début

  # Alimentation du type de Database
  Gosub ALIM_WBASE
Return

#####################################################################
# Lecture de la dimension, pour voir si elle gère le multi-dossiers #
# Lecture de(s) la (les) règles de synchro                          #
#####################################################################
$READ_DIM
  If clalev([F:ABI]) = 0 : Local File =APPLI+".ABIDIM" [ABI] : Endif
  If [F:ABI]CODDIM <> right$(TABLE,3) Then
    Read [ABI]ABI0=right$(TABLE,3)
    If fstat Then
      Raz [F:ABI]
    Endif
  Endif
  # SYMEU - Fiche 61356 - début
  # On teste si toutes les règles de synchronisation ayant la même table d'origine que la dimension
  # sont désactivées. Si c'est le cas, le traitement de la dimension n'est pas exécuté
  [L]DESFLG = 1
  [L]NBACT = 0 # nombre de règles activées
  [L]NBDES = 0 # nombre de règles désactivées
  If [F:ABI]TABORG <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    For [F:ABV] Where TABORG = [F:ABI]TABORG
      If dim([F:ABV]DESFLG) > 0 Then
        If [F:ABV]DESFLG = 2 Then # règle désactivée
          [L]NBDES+=1
        Else                      # règle activée
          [L]NBACT+=1
        Endif
      Endif
    Next
  Endif
  If [L]NBACT = 0 and [L]NBDES <> 0 Then # on n'a trouvé que des règles de synchro désactivées
    [L]DESFLG = 2
  Endif
  # SYMEU - Fiche 61356 - fin
Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de      #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
  Case GTYPDBA
    When 1 : WBASE = "3" : # Oracle
    When 2 : WBASE = "5" : # Sql
    When 3 : WBASE = "2" : # Cisam
    When 4 : WBASE = "4" : # DB2
  Endcase
Return

##########################################################################################
# LECT_DES_TRAD : Lecture de la désignation traduite d'un article reçu en paramètre
##########################################################################################
# Parameters E : code de l'article
# Return       : désignation 1 traduite de l'article
##########################################################################################
Funprog LECT_DES_TRAD(P_ITMREF,P_WBASE)
Value    Char P_ITMREF
Value    Char P_WBASE

Local    Char  DESAXX(80)  # Désignation traduite

  DESAXX=""
  WREQ2="select TEXTE_0 From "+GDOSSIER+".ATEXTRA Where CODFIC_0='ITMMASTER' and ZONE_0='DES1AXX' and LANGUE_0='"+GLANGUE+"' and IDENT1_0='"+P_ITMREF+"'"
  For (Char TEXTE(80)) From P_WBASE Sql WREQ2 As [RE2_]
    DESAXX = [RE2_]TEXTE
    Break
  Next
End DESAXX

##########################################################################################
# SYMEU - Fiche 61356
##########################################################################################
# READ_REGLE : Lecture des règles de synchro
##########################################################################################
# Parameters E : règle de synchro à lire
# Return       : flag de désactivation de la règle de synchro
##########################################################################################
Funprog READ_REGLE(CODE_REGLE)
Value Char CODE_REGLE

Local Integer DESACT

  DESACT = 1
  If CODE_REGLE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_REGLE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT





