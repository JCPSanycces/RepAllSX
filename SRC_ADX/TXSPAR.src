#<AdxTL>@(#)7.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

## We use the table AREPORTM to record the lines' titles from the table ATEXTRA. Thus, in Crystal Report we can link 
## the field [TXS]LIG with the field [ARM]N1 because they have the same type (numeric). In the table ATEXTRA the field which
## contains the line number is IDENT2 and this field has the type alpha. The link is impossible.

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    FDENAM(GLONTXS) :# Name of the Financial Data Extraction to print  
Local Char    LANG(GLONLAN)   :# Language used to print the titles
Local Char    REPNAM(GLONARP) :# Name of the report
Local Char    PARAM(30)       :# Number of the request in an alpha type
Local Integer NUMREQ          :# Number of the request in a numeric type
Local Integer I               :# Numbers each record in the table AREPORTM

If clalev([F:ARM])=0 : Local File AREPORTM [ARM] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

Call GETPARAM("tableau",NBPAR,PARAMETRE,[L]FDENAM) From ETAT
Call GETPARAM("X3LAN",NBPAR,PARAMETRE,[L]LANG) From ETAT
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]REPNAM) From ETAT 
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,[L]PARAM) From ETAT 
[L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)

Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
Gosub TR1
End

$TR1
Trbegin [ARM]
 GOK = 1
 I = 0
 Delete [ARM] Where RPTCOD=[L]REPNAM & USR=GUSER & CREDAT<date$
 If fstat=1 | fstat>5
  GOK=-1 : GLOCK="$AREPORTM" : Goto ROLL_TR1
 Endif
 Filter [AXX] Where CODFIC="TXSD" & ZONE="DES" & LANGUE=[L]LANG & IDENT1=[L]FDENAM
 For [AXX]
  Raz [ARM]
  I +=1
  [F:ARM]RPTCOD = [L]REPNAM
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = I
  [F:ARM]CLEN1  = val([F:AXX]IDENT2)
  [F:ARM]CLEA1  = mid$([F:AXX]TEXTE,1,20)
  [F:ARM]CLEA2  = mid$([F:AXX]TEXTE,21,20)
  [F:ARM]CLEA3  = mid$([F:AXX]TEXTE,41,20)
  [F:ARM]CLEA4  = mid$([F:AXX]TEXTE,61,20)
  [F:ARM]CREDAT = date$
  Write [ARM]
  If fstat
   GOK = 0 : Break
  Endif
 Next
 Filter [AXX]
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Call FSTA("ARM") From GLOCK
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return
