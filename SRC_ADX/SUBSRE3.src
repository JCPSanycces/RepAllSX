#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque SRE3
##########################################################################################################
Subprog AM_KEYWRDFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Actzo [M:SRE3]KEYWRD
  Else
    [M:SRE3]KEYWRD = ""
    Grizo [M:SRE3]KEYWRD
  Endif
  Affzo [M:SRE3]KEYWRD
End

##########################################################################################################
Subprog AM_TTRDESFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Actzo [M:SRE3]TTRDESSAM
    Actzo [M:SRE3]SREHD1FLG
    Actzo [M:SRE3]TTRDES
  Else
    [M:SRE3]SREHD1FLG = 1
    [M:SRE3]TTRDES = ""
    Grizo [M:SRE3]TTRDESSAM
    Grizo [M:SRE3]SREHD1FLG
    Grizo [M:SRE3]TTRDES
  Endif
  [M:SRE3]TTRDESSAM = 1
  Affzo [M:SRE3]TTRDES
  Affzo [M:SRE3]TTRDESSAM
  Affzo [M:SRE3]SREHD1FLG
End

##########################################################################################################
Subprog AM_TTRDESSAM(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:SRE3]TTRDES = [M:SRE3]KEYWRD
  Else
    If [M:SRE3]TTRDES = [M:SRE3]KEYWRD Then
      [M:SRE3]TTRDES = ""
    Endif
  Endif
  Affzo [M:SRE3]TTRDES
End

##########################################################################################################
Subprog AM_SOLFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Actzo [M:SRE3]SOLSAM
    Actzo [M:SRE3]SOLHD3FLG
    Actzo [M:SRE3]SOL
  Else
    [M:SRE3]SOLHD3FLG = 1
    [M:SRE3]SOL = ""
    Grizo [M:SRE3]SOLSAM
    Grizo [M:SRE3]SOLHD3FLG
    Grizo [M:SRE3]SOL
  Endif
  [M:SRE3]SOLSAM = 1
  Affzo [M:SRE3]SOL
  Affzo [M:SRE3]SOLSAM
  Affzo [M:SRE3]SOLHD3FLG
End

##########################################################################################################
Subprog AM_SOLSAM(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:SRE3]SOL = [M:SRE3]KEYWRD
  Else
    If [M:SRE3]SOL = [M:SRE3]KEYWRD Then
      [M:SRE3]SOL = ""
    Endif
  Endif
  Affzo [M:SRE3]SOL
End

##########################################################################################################
Subprog AM_CREDATFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Actzo [M:SRE3]STRDAT
    Actzo [M:SRE3]ENDDAT
    [M:SRE3]STRDAT = date$
    [M:SRE3]ENDDAT = date$
  Else
    [M:SRE3]STRDAT = [00/00/00]
    [M:SRE3]ENDDAT = [00/00/00]
    Grizo [M:SRE3]STRDAT
    Grizo [M:SRE3]ENDDAT
  Endif
  Affzo [M:SRE3]STRDAT
  Affzo [M:SRE3]ENDDAT
End

##########################################################################################################
Subprog AM_AUS(VALEUR)
Variable Char    VALEUR()

Local Char SZVAL

  SZVAL = toupper(VALEUR)
  VALEUR = SZVAL
  If VALEUR <> "" Then
    GIAUS = 1
  Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  Read [AUS]CODUSR=VALEUR
  If fstat Then
    VALEUR = ""
    [M:SRE3]AUSNAM(nolign-1) = VALEUR
  Else
    [M:SRE3]AUSNAM(nolign-1) = [F:AUS]NOMUSR
  Endif
  [M:SRE3]AUS(nolign-1) = VALEUR
  Affzo [M:SRE3]AUS(nolign-1)
  Affzo [M:SRE3]AUSNAM(nolign-1)
End

##########################################################################################################
Subprog C_PBLGRP(VALEUR)
Variable Char    VALEUR()

  Gosub CTLSHORTCUT From SUBPBLB
End

##########################################################################################################
Subprog AM_PBLGRP(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SRE3]PBLCLA(nolign-1) = ""
  Else
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:SRE3]PBLCLA(nolign-1) = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SRE3]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SRE3]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
    GIPBLGRP = 1
  Endif
  Affzo [M:SRE3]PBLCLA(nolign-1)
End

##########################################################################################################
Subprog C_AUS(VALEUR)
Variable Char    VALEUR()

Local Char SZVAL

  SZVAL = toupper(VALEUR)
  VALEUR = SZVAL
  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  Read [AUS]CODUSR=VALEUR
  If fstat Then
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_KEYWRD(VALEUR)
Variable Char    VALEUR()

  [M:SRE3]KEYWRD = VALEUR
  If [M:SRE3]TTRDESFLG = 2 Then
    If [M:SRE3]TTRDESSAM = 2 Then
      [M:SRE3]TTRDES = [M:SRE3]KEYWRD
    Endif
  Endif
  If [M:SRE3]SOLFLG = 2 Then
    If [M:SRE3]SOLSAM = 2 Then
      [M:SRE3]SOL = [M:SRE3]KEYWRD
    Endif
  Endif
  Affzo [M:SRE3]1-99
End

##########################################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

  If [M:SRE3]ENDDAT <> [00/00/00] Then
    If VALEUR <> [00/00/00] Then
      If [M:SRE3]ENDDAT < VALEUR Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  If [M:SRE3]STRDAT <> [00/00/00] Then
    If VALEUR <> [00/00/00] Then
      If [M:SRE3]STRDAT > VALEUR Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
  Endif
End
