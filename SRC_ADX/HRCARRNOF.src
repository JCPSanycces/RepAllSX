End

Subprog AS_DATEND(VALEUR)
Variable Date    VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
#  If clalev([F:HRPEO])=0 : Local File HRPERIOD [HRPEO] : Endif
#  Filter [F:HRPEO] Where PYRDAT=[M:DIA]DAT and FCY=''
