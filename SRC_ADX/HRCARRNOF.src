#**#####################################################################################
#* Exécution de l'action
#*!
$OK
Local  Char    CODPVE
Local  Integer LOK, NBENREG_EXS
Local  Integer ILIG
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Local  Char    REF_ENC(GLONEML)
#Local  Char    REF_ENC(GLONMAT)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Global Char    KEYFRT(40)(0..1000)

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If !find(2, [M:HRLEXS]SELFLG) Then
    Infbox mess(31,10718,1) : # Aucune note de frais à traiter
#    If !find(2, [M:LEXS]SELFLG) Then
#    Infbox mess(31,718,1) : # Aucune note de frais à traiter
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    Return
  Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If [M:DIA]SIMUL=1 Then
    Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
#  If [M:DIA]SIMUL=1 Then
#    Call OUINON(mess(191,717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    If LOK = 1 Then Return : Endif
  Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    TIT=mess(29,10718,1) : # Arrêté de notes de frais
#    TIT=mess(29,718,1) : # Arrêté de notes de frais
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If [M:DIA]SIMUL=2 Then
    #Call ECR_TRACE(toupper(mess(27,10107,1)),0) From GESECRAN : # SIMULATION
#  If [M:DIA]SIMUL=2 Then
    Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    Call ECR_TRACE("------------------------------------",0) From GESECRAN
  Endif

  # Récupération du code liste à utiliser pour le bordereau de notes de frais
  #LIPET - 2018-08-08 - X3-97301 - START
  #Call PARAM("", "CODPVE", CODPVE) From ADOVAL
  Call PARAM(GCURLEG, "CODPVE", CODPVE) From ADOVAL
  #LIPET - 2018-08-08 - X3-97301 - END
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If [M:HRLEXS]NBEXS>0 and find(2, [M:HRLEXS]SELFLG)>0 Then
#  If [M:LEXS]NBEXS>0 and find(2, [M:LEXS]SELFLG)>0 Then
#DIRAS - 2017/05/10 - JIRA X3-11253 - ENd
    GOK=1
    If GPAYE Then
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
      Trbegin [F:PPH], [F:PPD], [F:HREXS]
#      Trbegin [F:PPH], [F:PPD], [F:EXS]
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    For nolign=1 To [M:HRLEXS]NBEXS
      If [M:HRLEXS]SELFLG(nolign-1)=2 Then
#    For nolign=1 To [M:LEXS]NBEXS
#      If [M:LEXS]SELFLG(nolign-1)=2 Then
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
        ILIG = nolign-1
        # Relecture des enregistrements relatifs à la ligne en cours
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    Read [F:HREXS]HREXS0=[M:HRLEXS]REFNUM(ILIG);[M:HRLEXS]EXSNUM(ILIG);[M:HRLEXS]CTRNUM(ILIG);[M:HRLEXS]LIN(ILIG)
#    Read [F:EXS]EXS0=[M:LEXS]REFNUM(ILIG);[M:LEXS]EXSNUM(ILIG);[M:LEXS]CTRNUM(ILIG);[M:LEXS]LIN(ILIG)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

        Gosub MAJ_EXS : If GOK=0 Then Break : Endif
      Endif
    Next

    If GOK Then
      If [M:DIA]SIMUL=1 Then
        Commit
      Else
        Rollback
      Endif
    Else
      Rollback
    Endif
  Endif

  # Gestion de la trace
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If NBENREG_EXS>0 Then
    Call ECR_TRACE(mess(30,10718,1)-":"-num$(NBENREG_EXS),0) From GESECRAN : # Nombre de notes de frais mises à jour
  Else
    Call ECR_TRACE(mess(31,10718,1),0) From GESECRAN : # Aucune note de frais à traiter
  Endif

#  If NBENREG_EXS>0 Then
#    Call ECR_TRACE(mess(30,718,1)-":"-num$(NBENREG_EXS),0) From GESECRAN : # Nombre de notes de frais mises à jour
#  Else
#    Call ECR_TRACE(mess(31,718,1),0) From GESECRAN : # Aucune note de frais à traiter
#  Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  Call FERME_TRACE From LECFIC
  # FQ72152 - MABON 08/03/11 - Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
  Call LEC_TRACE From LECFIC
  GMESSAGE=""
Return

#**
#* Création des bordereaux
#*!
$MAJ_EXS
Local Integer NBD, AUZCFY
Local Char    WREQNUM
Local Char    DESREQ(255), CRITERE(250)

  GOK=1

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  Filter [F:HRCTR] Where REFNUM=[F:HREXS]REFNUM & CTRNUM=[F:HREXS]CTRNUM Order By CTRDAT Desc
#  Filter [F:CTR] Where REFNUM=[F:EXS]REFNUM & CTRNUM=[F:EXS]CTRNUM Order By CTRDAT Desc
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "HRCARRNOF")
#  AUZCFY = func SUBSES.GET_AUZ([F:FCY]LEGCPY, [F:CTR]ETRFCY, "CARRNOF")
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


  If AUZCFY=2 Then
    # On cherche si le bordereau existe déjà, et on crée un nouveau bordereau s'il n'existe pas encore
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    CRITERE="REF_ENC<>[F:HREXS]REFNUM"
    DESREQ  = mess(29,10718,1) : # Arrêté de notes de frais
#    CRITERE="REF_ENC<>[F:EXS]REFNUM"
#    DESREQ  = mess(29,718,1) : # Arrêté de notes de frais
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    # Création du borderau et de ses lignes
    # Le manager est en fait le REFNUM du user qui saisit l'arrêté de formation (donc variable globale GREFNUM
    # en paramètre de CRE_REQ)
    If clalev([F:TBD])=0 : Local File ATABZON [TBD] : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    Filter [F:TBD] Where CODFIC="HREXPENSES" & (CODTYP='MD2' or CODTYP='DCB' or CODZONE='QTY')
#    Filter [F:TBD] Where CODFIC="EXPENSES" & (CODTYP='MD2' or CODTYP='DCB' or CODZONE='QTY')
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#    Call CRE_REQ(GREFNUM, CODPVE, [M:DIA]DAT, evalue(CRITERE), WFCY, 0, DESREQ, [F:EXS]REFNUM, [F:EXS]CTRNUM, "CARRNOF", NBD, WREQNUM) From TOOLSVAR
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    Call CRE_REQ(GREFNUM, CODPVE, [M:DIA]DAT, [M:DIA]DATEND, evalue(CRITERE), WFCY, 0, DESREQ, [F:HREXS]REFNUM, [F:HREXS]CTRNUM, "HRCARRNOF", NBD, WREQNUM) From TOOLSVAR
    # Fin MABON
    Filter [F:TBD]
    REF_ENC=[F:HREXS]REFNUM

    If GOK & NBD>0 Then
      [F:HREXS]TRFREQ=2
      If WREQNUM<>"" Then [F:HREXS]REQNUM=WREQNUM : Endif
      If [M:DIA]SIMUL=1 Then
        Rewrite [F:HREXS]
      Endif
      If fstat Then
        GOK=0 : Call FSTA("HREXS") From GLOCK
      Else
        NBENREG_EXS += 1
        If WREQNUM<>"" Then
          # xxx : Bordereau préparatoire xxx xx/xx/xx
          # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#          Call ECR_TRACE([F:EXS]REFNUM-":"-mess(193,702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT),0) From GESECRAN
          Call ECR_TRACE([F:HREXS]REFNUM-":"-mess(193,10702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)-format$("D:"+GFMDAT,[M:DIA]DATEND),0) From GESECRAN
          # Fin MABON
        Endif
      Endif
    Endif
  Endif

#Call CRE_REQ(GREFNUM, CODPVE, [M:DIA]DAT, [M:DIA]DATEND, evalue(CRITERE), WFCY, 0, DESREQ, [F:EXS]REFNUM, [F:EXS]CTRNUM, "CARRNOF", NBD, WREQNUM) From TOOLSVAR
#    # Fin MABON
#    Filter [F:TBD]
#    REF_ENC=[F:EXS]REFNUM
#
#    If GOK & NBD>0 Then
#      [F:EXS]TRFREQ=2
#      If WREQNUM<>"" Then [F:EXS]REQNUM=WREQNUM : Endif
#      If [M:DIA]SIMUL=1 Then
#        Rewrite [F:EXS]
#      Endif
#      If fstat Then
#        GOK=0 : Call FSTA("EXS") From GLOCK
#      Else
#        NBENREG_EXS += 1
#        If WREQNUM<>"" Then
#          # xxx : Bordereau préparatoire xxx xx/xx/xx
#          # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
##          Call ECR_TRACE([F:EXS]REFNUM-":"-mess(193,702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT),0) From GESECRAN
#          Call ECR_TRACE([F:EXS]REFNUM-":"-mess(193,702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)-format$("D:"+GFMDAT,[M:DIA]DATEND),0) From GESECRAN
#          # Fin MABON
#        Endif
#      Endif
#    Endif
#  Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Return

#**
#* Surcharge de l'étiquette FIND_REQ appelée par CRE_REQ de TOOLSVAR
#*!
$FIND_REQ

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  Call FIND_REQNUM([F:HREXS]REFNUM, WREQNUM) From TOOLSVAR
#  Call FIND_REQNUM([F:EXS]REFNUM, WREQNUM) From TOOLSVAR
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Return

#**
#* Surcharge de l'étiquette CALC_VRA appelée par CRE_REQ de TOOLSVAR
#*!
$CALC_VRA
Local Char    CODEXP, ELTAMT
Local Integer IKEY

#DIRAS - 2017/05/10 - JIRA X3-11253 - START

  CODEXP = [F:HREXS]CODEXP
  ELTAMT = [F:TBD]CODZONE
#JASMI - 2017-06-08 - START
#  Read [F:HRPVE]PVE0=CODEXP;ELTAMT;6;"";"";"";"";"";[F:HREXS]CTRNUM;"";"";""             : # Niveau Contrat
#  If fstat Then
#    Read [F:HRPVE]PVE0=CODEXP;ELTAMT;5;"";"";"";"";[F:HREXS]REFNUM;"";"";"";""           : # Niveau Salarié
#    If fstat Then
#      Read [F:HRPVE]PVE0=CODEXP;ELTAMT;9;"";"";"";"";"";"";"";"";[F:HRCTR]PROPRF         : # Niveau Profil
#      If fstat Then
#        Read [F:HRPVE]PVE0=CODEXP;ELTAMT;7;"";"";"";"";"";"";[F:HRCTR]ETRSRV;"";""       : # Niveau Service
#        If fstat Then
#          Read [F:HRPVE]PVE0=CODEXP;ELTAMT;8;"";"";"";"";"";"";"";[F:HRCTR]CLLCVT;""     : # Niveau Convention collective
#          If fstat Then
#            Read [F:HRPVE]PVE0=CODEXP;ELTAMT;4;"";"";"";[F:HRCTR]ETRFCY;"";"";"";"";""   : # Niveau Site
#            If fstat Then
#              Read [F:HRPVE]PVE0=CODEXP;ELTAMT;3;"";"";[F:FCY]LEGCPY;"";"";"";"";"";""   : # Niveau Société
#              If fstat Then
#                Read [F:HRPVE]PVE0=CODEXP;ELTAMT;2;"";[M:DIA]POP;"";"";"";"";"";"";""  : # Niveau Population

  Read [F:HRPVE]PVE0=CODEXP;ELTAMT;7;"";"";"";"";"";[F:HREXS]CTRNUM;"";"";"";""             : # Niveau Contrat
  If fstat Then
    Read [F:HRPVE]PVE0=CODEXP;ELTAMT;6;"";"";"";"";[F:HREXS]REFNUM;"";"";"";"";""           : # Niveau Salarié
    If fstat Then
      Read [F:HRPVE]PVE0=CODEXP;ELTAMT;10;"";"";"";"";"";"";"";"";[F:HRCTR]PROPRF;""         : # Niveau Profil
      If fstat Then
        Read [F:HRPVE]PVE0=CODEXP;ELTAMT;8;"";"";"";"";"";"";[F:HRCTR]ETRSRV;"";"";""       : # Niveau Service
        If fstat Then
          Read [F:HRPVE]PVE0=CODEXP;ELTAMT;9;"";"";"";"";"";"";"";[F:HRCTR]CLLCVT;"";""     : # Niveau Convention collective
          If fstat Then
            Read [F:HRPVE]PVE0=CODEXP;ELTAMT;5;"";"";"";[F:HRCTR]ETRFCY;"";"";"";"";"";""   : # Niveau Site
            If fstat Then
              Read [F:HRPVE]PVE0=CODEXP;ELTAMT;4;"";"";[F:FCY]LEGCPY;"";"";"";"";"";"";""   : # Niveau Société
              If fstat Then
                Read [F:HRPVE]PVE0=CODEXP;ELTAMT;3;"";[M:DIA]POP;"";"";"";"";"";"";"";""  : # Niveau Population
                If fstat Then
                  Read [F:HRPVE]PVE0=CODEXP;ELTAMT;1;nomap;"";"";"";"";"";"";"";"";""       : # Niveau Dossier
                  If fstat Then
                    Read [F:HRPVE]PVE0=CODEXP;ELTAMT;2;"";"";"";"";"";"";"";"";"";[M:DIA]LEG      : # Niveau Dossier
                    Endif
#JASMI - 2017-06-08 - END
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

#
#  CODEXP = [F:EXS]CODEXP
#  ELTAMT = [F:TBD]CODZONE
#  Read [F:PVE]PVE0=CODEXP;ELTAMT;6;"";"";"";"";"";[F:EXS]CTRNUM;"";"";""             : # Niveau Contrat
#  If fstat Then
#    Read [F:PVE]PVE0=CODEXP;ELTAMT;5;"";"";"";"";[F:EXS]REFNUM;"";"";"";""           : # Niveau Salarié
#    If fstat Then
#      Read [F:PVE]PVE0=CODEXP;ELTAMT;9;"";"";"";"";"";"";"";"";[F:CTR]PROPRF         : # Niveau Profil
#      If fstat Then
#        Read [F:PVE]PVE0=CODEXP;ELTAMT;7;"";"";"";"";"";"";[F:CTR]ETRSRV;"";""       : # Niveau Service
#        If fstat Then
#          Read [F:PVE]PVE0=CODEXP;ELTAMT;8;"";"";"";"";"";"";"";[F:CTR]CLLCVT;""     : # Niveau Convention collective
#          If fstat Then
#            Read [F:PVE]PVE0=CODEXP;ELTAMT;4;"";"";"";[F:CTR]ETRFCY;"";"";"";"";""   : # Niveau Site
#            If fstat Then
#              Read [F:PVE]PVE0=CODEXP;ELTAMT;3;"";"";[F:FCY]LEGCPY;"";"";"";"";"";"" : # Niveau Société
#              If fstat Then
#                Read [F:PVE]PVE0=CODEXP;ELTAMT;2;"";[M:DIA]POP;"";"";"";"";"";"";""  : # Niveau Population
#                If fstat Then
#                  Read [F:PVE]PVE0=CODEXP;ELTAMT;1;nomap;"";"";"";"";"";"";"";""     : # Niveau Dossier
#                Endif
#              Endif
#            Endif
#          Endif
#        Endif
#      Endif
#    Endif
#  Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  # Fin MABON

  If !fstat Then
    WVRACOD=[F:HRPVE]VRACOD
  Else
    WVRACOD=""
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    If !find(num$([F:HREXS]EXSNUM)+"~"+[F:HREXS]CODEXP+"~"+[F:TBD]CODZONE, KEYFRT) Then
      # Note de frais Code / Montant : Correspondance Code frais-Montant / Variable non définie
      Call ECR_TRACE(mess(33,10718,1)-num$([F:HREXS]EXSNUM)-mess(34,10718,1)-[F:HREXS]CODEXP-"/"-[F:TBD]CODZONE-":"-mess(32,10718,1),0) From GESECRAN
      IKEY=find("",KEYFRT)
      KEYFRT(IKEY-1)=num$([F:HREXS]EXSNUM)+"~"+[F:HREXS]CODEXP+"~"+[F:TBD]CODZONE
    Endif

#    If !find(num$([F:EXS]EXSNUM)+"~"+[F:EXS]CODEXP+"~"+[F:TBD]CODZONE, KEYFRT) Then
#      # Note de frais Code / Montant : Correspondance Code frais-Montant / Variable non définie
#      Call ECR_TRACE(mess(33,718,1)-num$([F:EXS]EXSNUM)-mess(34,718,1)-[F:EXS]CODEXP-"/"-[F:TBD]CODZONE-":"-mess(32,718,1),0) From GESECRAN
#      IKEY=find("",KEYFRT)
#      KEYFRT(IKEY-1)=num$([F:EXS]EXSNUM)+"~"+[F:EXS]CODEXP+"~"+[F:TBD]CODZONE
#    Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  Endif
  fstat=0
Return

#**
#* Surcharge de l'étiquette CALC_AMT appelée par CRE_REQ de TOOLSVAR
#*!
$CALC_AMT

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  ACPAMT = evalue("[F:HREXS]"+[F:TBD]CODZONE)
#  ACPAMT = evalue("[F:EXS]"+[F:TBD]CODZONE)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Return

#**
#* Surcharge de l'étiquette CALC_CTRDAT appelée par CRE_REQ de TOOLSVAR
#*!
$CAL_CTRDAT
Local Date DATDEREXS

#  If clalev([F:EXS2])=0 : Local File EXPENSES [EXS2] : Endif
#  Filter [F:EXS2] Where REFNUM=[F:EXS]REFNUM & CTRNUM=[F:EXS]CTRNUM & EXSNUM=[F:EXS]EXSNUM Order By [F:EXS2]DATEXS Desc
#  Read [F:EXS2] First
#  Filter [F:EXS2]
#  WCTRDAT=func TPSSTD.CALC_CTRDATDEF([F:EXS]REFNUM,[F:EXS]CTRNUM,[M:DIA]DATEND,[M:DIA]DATEND,[F:EXS2]DATEXS,1)

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  WCTRDAT=func TPSSTD.CALC_CTRDATDEF([F:HREXS]REFNUM,[F:HREXS]CTRNUM,[M:DIA]DATEND,[M:DIA]DATEND,[F:HREXS]DATEXS,1)
#  WCTRDAT=func TPSSTD.CALC_CTRDATDEF([F:EXS]REFNUM,[F:EXS]CTRNUM,[M:DIA]DATEND,[M:DIA]DATEND,[F:EXS]DATEXS,1)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Return

#**
#* On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
#* en réel après l'avoir lancé en simulation)
#*!
$EXEC

  SAI=1
Return

$FIN

  If dim(KEYFRT)>0 Then Kill KEYFRT : Endif
Return

