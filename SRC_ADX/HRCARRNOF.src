#    Filter [F:HRPEO] Where PYRDAT>=[M:DIA]DAT and FCY='' Order By PYRDAT
#    Read [F:HRPEO] First
#    If !fstat Then
#      VALEUR=[F:HRPEO]PYRDAT
#    Endif
#    Filter [F:HRPEO]
#  Endif
#  Filter [F:HRPEO]
#  fstat=0

  If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
  Filter [F:HRPEOD] Where PYRDAT>=[M:DIA]DAT and PERCOD=[F:HRCTR]PERCOD Order By PYRDAT
  Read [F:HRPEOD] First
  If !fstat Then
      VALEUR=[F:HRPEOD]PYRDAT
  Endif
  Filter [F:HRPEOD]
  fstat=0
End

