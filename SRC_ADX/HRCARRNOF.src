#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque CARRNOF
# Création
#     MABON - 13/05/11 - EXI 66382 LOT 1
#              - Arrêté de notes de frais
# Modification :
#     SEGAY - 06/09/11 - FQ75536 - Nom-Prénom
######################################################################################

$ACTION
  Case ACTION
    When "INIT_DIA"   : Gosub INIT_DIA
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "LIENS"      : Gosub LIENS
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    When "CONTROLE"   : Gosub CONTROLE
    When "BOUTON"     : Gosub BOUTON
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
    When "SEL_TABLE"
      Case [L]COUZON
        When "EXSNUMSTR", "EXSNUMEND" : Gosub S_EXSNUM
      Endcase
    When "INIT" : Gosub INIT
  Endcase
Return

#**#####################################################################################
#*
#*!

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
$OUVRE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$LIENS
#MIPEA - 2017/05/30 - JIRA X3-11253 - START
  GCURLEG = [M:DIA]LEG
#  GCURLEG = [F:DIA]LEG
#MIPEA - 2017/05/30 - JIRA X3-11253 - END
Return
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#92876-US2780
$INIT
# idem dans CARRNOF,EXSPST
## ##  FQ 105501 The function is available in V7.1
##GERR=1
##GMESSAGE=mess(246,702,1)
Return


$INIT_DIA

  # Ouverture des tables utilisées
  If clalev([F:FCY])=0  : Local File FACILITY      [FCY]  : Endif
  If clalev([F:CPY])=0  : Local File COMPANY       [CPY]  : Endif
  If clalev([F:POA])=0  : Local File POPULA        [POA]  : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If clalev([F:HREXS])=0 : Local File HREXPENSES   [HREXS]  : Endif
  If clalev([F:HRPEOD])=0 : Local File HRPEODET    [HRPEOD]  : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR    [HRCTR]  : Endif
#  If clalev([F:EXS])=0  : Local File EXPENSES      [EXS]  : Endif
#  If clalev([F:PEO])=0  : Local File PERIOD        [PEO]  : Endif
#  If clalev([F:CTR])=0  : Local File EMPLOCTR      [CTR]  : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
  If clalev([F:ID])=0   : Local File EMPLOID       [ID]   : Endif
  If clalev([F:AD])=0   : Local File EMPLOAD       [AD]   : Endif
  If clalev([F:CPT])=0  : Local File EMPLOCPT      [CPT]  : Endif
  If clalev([F:RIB])=0  : Local File EMPLORIB      [RIB]  : Endif
  If clalev([F:MED])=0  : Local File EMPLOMED      [MED]  : Endif
  If GPAYE Then
    If clalev([F:PPH])=0  : Local File PPREQUESTH  [PPH]  : Endif
    If clalev([F:PPD])=0  : Local File PPREQUESTD  [PPD]  : Endif
    If clalev([F:VEP])=0  : Local File VALEMP      [VEP]  : Endif
    If clalev([F:VEP2])=0 : Local File VALEMP      [VEP2] : Endif
    If clalev([F:HRPVE])=0  : Local File HRPARVAREXP   [HRPVE]  : Endif
    If clalev([F:HRPPD])=0: Local File PPREQUESTD  [HRPPD]: Endif  : #LIPET - 2018-08-08 - X3-97301
  Endif

  Raz [M:DIA]

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If GFONCTION="GESHREXS" Then
    Call CALC_CFY([F:HREXS]REFNUM, [F:HREXS]CTRNUM, [F:HREXS]STRDAT, [M:DIA]FCY, [M:DIA]CPY) From TOOLSVAR
    If [M:DIA]CPY<>"" Then [M:DIA]ALLCPY=1 : Endif
    If [M:DIA]FCY<>"" Then [M:DIA]ALLFCY=1 : Endif

    Filter [F:HRCTR] Where REFNUM=[F:HREXS]REFNUM & CTRNUM=[F:HREXS]CTRNUM Order By CTRDAT Desc
    Read [F:HRCTR] First
    Filter [F:HRCTR]

    [M:DIA]CTRNUMSTR = [F:HREXS]CTRNUM
    [M:DIA]CTRNUMEND = [F:HREXS]CTRNUM

    [M:DIA]MATSTR    = [F:HREXS]REFNUM
    [M:DIA]MATEND    = [F:HREXS]REFNUM

    If [F:HRCTR]PROPRF<>"" Then
      [M:DIA]ALLPRF    = 1
      [M:DIA]PRF       = [F:HRCTR]PROPRF
    Endif

    If [F:HRCTR]ETRSRV<>"" Then
      [M:DIA]ALLSRV    = 1
      [M:DIA]SRV       = [F:HRCTR]ETRSRV
    Endif

    [M:DIA]EXSNUMSTR = [F:HREXS]EXSNUM
    [M:DIA]EXSNUMEND = [F:HREXS]EXSNUM

    If [F:HRCTR]CLLCVT<>"" Then
      [M:DIA]ALLCLLCVT = 1
      [M:DIA]CLLCVT    = [F:HRCTR]CLLCVT
    Endif

    [M:DIA]CODEXPSTR = ""
    [M:DIA]CODEXPEND = ""
  Endif

#If GFONCTION="GESEXS" Then
#    Call CALC_CFY([F:EXS]REFNUM, [F:EXS]CTRNUM, [F:EXS]STRDAT, [M:DIA]FCY, [M:DIA]CPY) From TOOLSVAR
#    If [M:DIA]CPY<>"" Then [M:DIA]ALLCPY=1 : Endif
#    If [M:DIA]FCY<>"" Then [M:DIA]ALLFCY=1 : Endif
#
#    Filter [F:CTR] Where REFNUM=[F:EXS]REFNUM & CTRNUM=[F:EXS]CTRNUM Order By CTRDAT Desc
#    Read [F:CTR] First
#    Filter [F:CTR]
#
#    [M:DIA]CTRNUMSTR = [F:EXS]CTRNUM
#    [M:DIA]CTRNUMEND = [F:EXS]CTRNUM
#
#    [M:DIA]MATSTR    = [F:EXS]REFNUM
#    [M:DIA]MATEND    = [F:EXS]REFNUM
#
#    If [F:CTR]PROPRF<>"" Then
#      [M:DIA]ALLPRF    = 1
#      [M:DIA]PRF       = [F:CTR]PROPRF
#    Endif
#
#    If [F:CTR]ETRSRV<>"" Then
#      [M:DIA]ALLSRV    = 1
#      [M:DIA]SRV       = [F:CTR]ETRSRV
#    Endif
#
#    [M:DIA]EXSNUMSTR = [F:EXS]EXSNUM
#    [M:DIA]EXSNUMEND = [F:EXS]EXSNUM
#
#    If [F:CTR]CLLCVT<>"" Then
#      [M:DIA]ALLCLLCVT = 1
#      [M:DIA]CLLCVT    = [F:CTR]CLLCVT
#    Endif
#
#    [M:DIA]CODEXPSTR = ""
#    [M:DIA]CODEXPEND = ""
#  Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


# FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#  [M:DIA]DAT    = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  [M:DIA]DAT    = gdat$(1,month(func DIVPAYE.INIPARUSR("DATPAY","","")),year(func DIVPAYE.INIPARUSR("DATPAY","","")))
  [M:DIA]DATEND = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  # Fin MABON

Return

#####################################
$CONTROLE

  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif
Return

#**
#* Boutons "Tout cocher" et "Tout décocher"
#*!
$BOUTON
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  Case BOUT
    When "C" : For I=0 To [M:HRLEXS]NBEXS-1 : [M:HRLEXS]SELFLG(I)=2 : Next
    When "D" : For I=0 To [M:HRLEXS]NBEXS-1 : [M:HRLEXS]SELFLG(I)=1 : Next
  Endcase
  Affzo [M:HRLEXS]

#  Case BOUT
#    When "C" : For I=0 To [M:LEXS]NBEXS-1 : [M:LEXS]SELFLG(I)=2 : Next
#    When "D" : For I=0 To [M:LEXS]NBEXS-1 : [M:LEXS]SELFLG(I)=1 : Next
#  Endcase
#  Affzo [M:LEXS]
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Return

#**
#* Calcul des critères de sélection
#*!
$CALC_CRIT
Local Integer ONE_CRIT, I
Local Char    LIS_CPY(GLONCPY)(0..100)

  CRITAUT="1=1"
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
#  If [M:DIA]ALLCPY<>2 Then
#    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From SUBSES
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
    If I>0 Then
      CRITAUT -= "& find(WCPY,"
      For K=0 To I-1
        CRITAUT += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITAUT += "," : Endif
      Next
      CRITAUT += ")>0"
    Endif
  Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  If [M:DIA]ALLFCY<>2       Then CRITAUT  -= "& WFCY='"+[M:DIA]FCY+"'"                      : Endif
  If [M:DIA]POP<>""         Then CRITAUT  -= "& [F:POA]COD='"+[M:DIA]POP+"'"                : Endif
  If [M:DIA]ALLSRV<>2       Then CRITAUT  -= "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"           : Endif
  If [M:DIA]ALLPRF<>2       Then CRITAUT  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"           : Endif
  If [M:DIA]CLLCVT<>""      Then CRITAUT  -= "& [F:HRCTR]CLLCVT='"+[M:DIA]CLLCVT+"'"        : Endif

  # La note de frais ne doit pas avoir été déjà transférée + elle doit avoir le statut Accepté ou Annulation refusée

  CRITERE1 = "[F:HREXS]TRFREQ<>2 & find([F:HREXS]EXSSTA,3,7)>0"
  If [M:DIA]MATSTR<>""      Then CRITERE1 -= "& [F:HREXS]REFNUM>='"+[M:DIA]MATSTR+"'"       : Endif
  If [M:DIA]MATEND<>""      Then CRITERE1 -= "& [F:HREXS]REFNUM<='"+[M:DIA]MATEND+"'"       : Endif
  If [M:DIA]CTRNUMSTR<>""   Then CRITERE1 -= "& [F:HREXS]CTRNUM>='"+[M:DIA]CTRNUMSTR+"'"    : Endif
  If [M:DIA]CTRNUMEND<>""   Then CRITERE1 -= "& [F:HREXS]CTRNUM<='"+[M:DIA]CTRNUMEND+"'"    : Endif

  CRITERE2 = "1=1"
  If [M:DIA]EXSNUMSTR>0     Then CRITERE2 -= "& [F:HREXS]EXSNUM>="+num$([M:DIA]EXSNUMSTR)   : Endif
  If [M:DIA]EXSNUMEND>0     Then CRITERE2 -= "& [F:HREXS]EXSNUM<="+num$([M:DIA]EXSNUMEND)   : Endif
  If [M:DIA]CODEXPSTR<>""   Then CRITERE2 -= "& [F:HREXS]CODEXP>='"+[M:DIA]CODEXPSTR+"'"    : Endif
  If [M:DIA]CODEXPEND<>""   Then CRITERE2 -= "& [F:HREXS]CODEXP<='"+[M:DIA]CODEXPEND+"'"    : Endif

#  If [M:DIA]ALLFCY<>2       Then CRITAUT  -= "& WFCY='"+[M:DIA]FCY+"'"                    : Endif
#  If [M:DIA]POP<>""         Then CRITAUT  -= "& [F:POA]COD='"+[M:DIA]POP+"'"              : Endif
#  If [M:DIA]ALLSRV<>2       Then CRITAUT  -= "& [F:CTR]ETRSRV='"+[M:DIA]SRV+"'"           : Endif
#  If [M:DIA]ALLPRF<>2       Then CRITAUT  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"           : Endif
#  If [M:DIA]CLLCVT<>""      Then CRITAUT  -= "& [F:HRCTR]CLLCVT='"+[M:DIA]CLLCVT+"'"        : Endif

  # La note de frais ne doit pas avoir été déjà transférée + elle doit avoir le statut Accepté ou Annulation refusée

#  CRITERE1 = "[F:EXS]TRFREQ<>2 & find([F:EXS]EXSSTA,3,7)>0"
#  If [M:DIA]MATSTR<>""      Then CRITERE1 -= "& [F:EXS]REFNUM>='"+[M:DIA]MATSTR+"'"       : Endif
#  If [M:DIA]MATEND<>""      Then CRITERE1 -= "& [F:EXS]REFNUM<='"+[M:DIA]MATEND+"'"       : Endif
#  If [M:DIA]CTRNUMSTR<>""   Then CRITERE1 -= "& [F:EXS]CTRNUM>='"+[M:DIA]CTRNUMSTR+"'"    : Endif
#  If [M:DIA]CTRNUMEND<>""   Then CRITERE1 -= "& [F:EXS]CTRNUM<='"+[M:DIA]CTRNUMEND+"'"    : Endif
#
#  CRITERE2 = "1=1"
#  If [M:DIA]EXSNUMSTR>0     Then CRITERE2 -= "& [F:EXS]EXSNUM>="+num$([M:DIA]EXSNUMSTR)   : Endif
#  If [M:DIA]EXSNUMEND>0     Then CRITERE2 -= "& [F:EXS]EXSNUM<="+num$([M:DIA]EXSNUMEND)   : Endif
#  If [M:DIA]CODEXPSTR<>""   Then CRITERE2 -= "& [F:EXS]CODEXP>='"+[M:DIA]CODEXPSTR+"'"    : Endif
#  If [M:DIA]CODEXPEND<>""   Then CRITERE2 -= "& [F:EXS]CODEXP<='"+[M:DIA]CODEXPEND+"'"    : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Return

#**
#* Affichage de la fenêtre de sélection des notes de frais
#*!
$DEBUT
Local Char    CRITERE1(250), CRITERE2(250), CRITAUT(250), MESST(250)
Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY)
Local Integer I, OKPAY

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  Gosub CALC_CRIT
  Filter [F:HREXS] Where evalue(CRITERE1) & evalue(CRITERE2) Order By [F:HREXS]REFNUM
  nolign=1 : Raz [M:HRLEXS]
  For [F:HREXS]
    # Détermination des données relatives au matricule de l'inscription, afin d'évaluer CRITAUT
    Call CALC_CFY([F:HREXS]REFNUM, [F:HREXS]CTRNUM, [F:HREXS]STRDAT, WFCY, WCPY) From TOOLSVAR
    # Lecture de la population pour alimenter [F:POA] utilisé dans CRITAUT
    If [M:DIA]POP<>"" Then
      Read [F:POA]POA0=[M:DIA]POP;[F:HREXS]REFNUM
      If fstat Then Raz [F:POA] : Endif
    Endif
    # Lecture du contrat pour alimenter [F:CTR] utilisé dans CRITAUT
    Filter [F:HRCTR] Where REFNUM=[F:HREXS]REFNUM & CTRNUM=[F:HREXS]CTRNUM Order By CTRDAT Desc
    Read [F:HRCTR] First
    If fstat Then Raz [F:HRCTR] : Endif
    Filter [F:HRCTR]

    OKPAY=1
    If [M:DIA]CRI<>"" Then
      # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [M:DIA]CRI
      Read [F:ID]ID0=[F:HREXS]REFNUM
      Read [F:AD]AD0=[F:HREXS]REFNUM
      Read [F:CPT]CPT0=[F:HREXS]REFNUM
      Filter [F:RIB] Where REFNUM=[F:HREXS]REFNUM
      Read [F:RIB] Last
      Filter [F:RIB]
      Filter [F:MED] Where REFNUM=[F:HREXS]REFNUM
      Read [F:MED] Last
      Filter [F:MED]
      Call CONTROLE([F:HREXS]REFNUM,[F:HRCTR]CTRDAT,[F:HREXS]CTRNUM,[M:DIA]CRI,OKPAY,0) From DIVPAYE
    Endif
    If OKPAY & evalue(CRITAUT)>0 Then
      If nolign-1<dim([M:HRLEXS]SELFLG) Then
        [M:HRLEXS]SELFLG(nolign-1) = 2
#segay 06/09/11 75536
        Read [F:ID]ID0=[F:HREXS]REFNUM
        [M:HRLEXS]NAM(nolign-1)    = [F:ID]NAM-[F:ID]SRN
#END 06/09/11 75536
        [M:HRLEXS]REFNUM(nolign-1) = [F:HREXS]REFNUM
        [M:HRLEXS]CTRNUM(nolign-1) = [F:HREXS]CTRNUM
        [M:HRLEXS]EXSNUM(nolign-1) = [F:HREXS]EXSNUM
        [M:HRLEXS]STRDAT(nolign-1) = [F:HREXS]STRDAT
        [M:HRLEXS]ENDDAT(nolign-1) = [F:HREXS]ENDDAT
        [M:HRLEXS]TIT(nolign-1)    = [F:HREXS]TIT
        [M:HRLEXS]DATEXS(nolign-1) = [F:HREXS]DATEXS
        [M:HRLEXS]CODEXP(nolign-1) = [F:HREXS]CODEXP
        [M:HRLEXS]EXSSTA(nolign-1) = [F:HREXS]EXSSTA
        [M:HRLEXS]FCY(nolign-1)    = [F:HREXS]FCY
        [M:HRLEXS]QTY(nolign-1)    = [F:HREXS]QTY
        [M:HRLEXS]CUR(nolign-1)    = [F:HREXS]CUR
        [M:HRLEXS]PAYCUR(nolign-1) = [F:HREXS]PAYCUR
        [M:HRLEXS]RFUCUR(nolign-1) = [F:HREXS]RFUCUR
        [M:HRLEXS]VATCUR(nolign-1) = [F:HREXS]VATCUR
        [M:HRLEXS]TAXCUR(nolign-1) = [F:HREXS]TAXCUR
        [M:HRLEXS]DEDCUR(nolign-1) = [F:HREXS]DEDCUR
        [M:HRLEXS]PAYSHR(nolign-1) = [F:HREXS]PAYSHR
        [M:HRLEXS]RFUSHR(nolign-1) = [F:HREXS]RFUSHR
        [M:HRLEXS]LIN(nolign-1)    = [F:HREXS]LIN

        nolign += 1
      Else
        MESST = mess(54,126,1)-":"-num$(dim([M:HRLEXS]SELFLG)) : # Nombre de lignes maximum dépassé
        MESST += chr$(10)+mess(410,197,1)                    : # Vous pouvez affiner vos critères
        Infbox MESST
        Break
      Endif
    Endif
  Next
  Filter [F:HREXS]
  [M:HRLEXS]NBEXS=nolign-1
  Affzo [M:HRLEXS]

