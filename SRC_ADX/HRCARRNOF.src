#**
#*  Sélection des notes de frais
#*!
$S_EXSNUM

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
  [L]OBJET="HREXS"
#  [L]OBJET="EXS"
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
#  [L]CRITERE="REFNUM=[M:DIA]REFNUM & CTRNUM=[M:DIA]CTRNUM"
  [L]CRITERE="1=1"
  If [M:DIA]CTRNUMSTR<>"" Then
    [L]CRITERE -= "& CTRNUM>=[M:DIA]CTRNUMSTR"
  Endif
  If [M:DIA]CTRNUMEND<>"" Then
    [L]CRITERE -= "& CTRNUM<=[M:DIA]CTRNUMEND"
  Endif
  If [M:DIA]MATSTR<>"" Then
    [L]CRITERE -= "& REFNUM>=[M:DIA]MATSTR"
  Endif
  If [M:DIA]MATEND<>"" Then
    [L]CRITERE -= "& REFNUM<=[M:DIA]MATEND"
  Endif
  If [M:DIA]CODEXPSTR<>"" Then
    [L]CRITERE -= "& CODEXP>=[M:DIA]CODEXPSTR"
  Endif
  If [M:DIA]CODEXPEND<>"" Then
    [L]CRITERE -= "& CODEXP<=[M:DIA]CODEXPEND"
  Endif

#  [L]CRITERE="1=1"
#  If [M:DIA]CTRNUMSTR<>"" Then
#    [L]CRITERE -= "& CTRNUM>=[M:DIA]CTRNUMSTR"
#  Endif
#  If [M:DIA]CTRNUMEND<>"" Then
