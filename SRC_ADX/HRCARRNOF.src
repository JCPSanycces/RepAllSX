######################################################################################
## Section automatically added (screen HRCARRNOF) 05/23/2017 10:29:26 (DIRAS)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG=VALEUR
End


######################################################################################

######################################################################################
## Section automatically added (screen HRCARRNOF) 06/12/2017 13:00:13 (DIRAS)
######################################################################################
Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()

  If ([M:DIA]CTRNUMSTR = [M:DIA]CTRNUMEND)
    Call GETCTRLEG([M:DIA]CTRNUMSTR)
  Endif

  If ([M:DIA]ALLCPY = 2)
    If clalev([F:CPY])=0 : Local File COMPANY [CPY]  : Endif

    Read [CPY]CPY0 = [M:DIA]CPY
    [M:DIA]LEG = [F:CPY]LEG
    Affzo [M:DIA]LEG
  Endif

  If ([M:DIA]ALLFCY = 2)
    If clalev([F:FCY2])=0   : Local File FACILITY [FCY2]   : Endif

    Read [FCY]FCY0 = [M:DIA]FCY
    [M:DIA]LEG = [F:FCY]LEG
    Affzo [M:DIA]LEG
  Endif

End


######################################################################################

#DIRAS - 2017/06/12 - JIRA X3-11253 - START
Subprog GETCTRLEG(VALEUR)
Value Char VALEUR()

If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0   : Local File FACILITY [FCY2]   : Endif

  If VALEUR<>""
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] Last
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:DIA]LEG = GCURLEG
    Affzo [M:DIA]LEG
    Endif
  Endif
End
#DIRAS - 2017/06/12 - JIRA X3-11253 - END

