##########################################################################################################
Subprog AM_APTCCNNUM(VALEUR)
Variable Char    VALEUR()

Local Integer BAPNOL

  Raz [M:BAP1]APTCOR(nolign-1)
  If nolign-1 = 0 and [M:BAP0]APTCMP = "" and [M:BAP3]APTPLC = 1 Then
    Call FILAPPPLC([M:BAP3]APTPLC, 9, VALEUR) From SUBBAPB
  Endif
  BAPNOL = nolign-1
  [M:BAP1]APTCCNNUM(BAPNOL) = VALEUR
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBBAPB
  Affzo [M:BAP1]1-99
End

##########################################################################################################
Subprog C_APTCCNNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer IBERROR
Local Integer ILIGSAVE

  If VALEUR = "" Then
    End
  Endif
  IBERROR = 0
  ILIGSAVE = nolign
  #Vérifie si cet interlocuteur n'a pas déjà  été préalablement saisi dans ce tableau.
  For I = 0 To dim ([M:BAP1]APTCCNNUM)-1
    If I <> ILIGSAVE-1 Then
      If [M:BAP1]APTCCNNUM(I) = VALEUR and [M:BAP1]APTCCNNUM(I) <> "" Then
        IBERROR = 1
        Break
      Endif
    Endif
  Next
  If IBERROR = 1 Then
    #Cet interlocuteur a déjà  été saisi.
    GMESSAGE = mess(438,196,1)
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_APTREPNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer IBERROR
Local Integer ILIGSAVE

  IBERROR = 0
  ILIGSAVE = nolign
  If !GIMPORT Then
    If VALEUR = "" Then
      End
    Endif
    #Vérifie si ce représentant n'a pas déjà  été préalablement saisi dans ce tableau.
    For I = 0 To dim ([M:BAP2]APTREPNUM)-1
      If I <> ILIGSAVE-1 Then
        If [M:BAP2]APTREPNUM(I) = VALEUR and [M:BAP2]APTREPNUM(I) <> "" Then
          IBERROR = 1
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    #Ce collaborateur a déjà  été saisi.
    GMESSAGE = mess(432,196,1)
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_APTRER(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    mkstat = 2
    End
  Endif
  Read [RRS]RRS0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    mkstat = 2
    End
  Else
    # FGR 24/07/2009 : X3SUIVI56702
    If [M:BAP0]SALFCY <> [F:RRS]SALFCY and [F:RRS]SALFCY <> "" Then
      GMESSAGE = mess(967,196,1)
      mkstat = 2
      End
    Endif
    If [F:RRS]RRSORI > 1 Then
      If [F:RRS]RRSORI = 2 Then
        If [F:RRS]RRSORIVCR <> [M:BAP0]APTNUM Then
          #Cette ressource est déjà utilisée pour un autre rendez-vous.
          GMESSAGE = mess(170,182,1)
          mkstat = 2
        Endif
      Else
        #Cette ressource est déjà utilisée pour une intervention.
        GMESSAGE = mess(168,182,1)
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
#---------------------------------------------------#
# Vérifie s'il existe une duplication de représentants dans la liste des intervenants du rendez-vous
#---------------------------------------------------#
Subprog CHKDUPREP(SZREP)
Value Char SZREP

Local Integer IT
Local Integer IT2

  IT2 = 0
  #Recherche un doublon
  For IT = 1 To dim([M:BAP2]APTREPNUM)-1
    If [M:BAP2]APTREPNUM(IT) = SZREP Then
      IT2 = IT
      Break
    Endif
  Next
  #Décale le tableau d'une ligne vers le haut à  partir du doublon trouvé
  If IT2 Then
    While IT2 < dim([M:BAP2]APTREPNUM)-1
      [M:BAP2]APTREPNUM(IT2) = [M:BAP2]APTREPNUM(IT2+1)
      IT2 += 1
    Wend
    [M:BAP2]APTREPNUM(dim([M:BAP2]APTREPNUM)-1) = ""
    [M:BAP2]NBLIGREP -= 1
  Endif
End

##########################################################################################################
Subprog IB_APTADD
Local Integer IMOREADD

  IMOREADD = 0
  Case [M:BAP3]APTPLC
    When 1
      If indice > 0 Then
        Raz GBOUT1
      Else
        Call CHKADD([M:BAP3]APTPLC, IMOREADD) From TRTBAP6
        If !IMOREADD Then
          Raz GBOUT1
        Endif
      Endif
    When 2
      If indice > 0 Then
        Raz GBOUT1
      Else
        Call CHKADD([M:BAP3]APTPLC, IMOREADD) From TRTBAP6
        If !IMOREADD Then
          Raz GBOUT1
        Endif
      Endif
    When Default
      Raz GBOUT1
  Endcase
End

