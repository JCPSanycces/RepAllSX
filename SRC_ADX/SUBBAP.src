##########################################################################################################
Subprog IB_APTORIADI
  # FGR 11/03/2010 : X3SUIVI62924
  If [M:BAP1]APTORITYP <> 2 Then
    If varmode ([M:BAP1]APTORIADI, 0) = 0 Then
      Raz GBOUT2
    Else
      GBOUT2 = mess(257,177,1)
    Endif
  Else
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog AM_APTORIADI(VALEUR)
Variable Char    VALEUR()

  # FGR 11/03/2010 : X3SUIVI62924
Local Char SZAPTORIAOB(GLONAOB)

  If VALEUR = "" Then
    VALEUR = "MAN1"
  Endif
  SZAPTORIAOB = [M:BAP1]APTORIAOB
  [M:BAP1]APTORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI(VALEUR)
  #Gosub DEFOBJORI From SUBBAPB
  Call DEFOBJORI([M:BAP1]APTORIAOB, [M:BAP1]APTORIAVA) From CRMUTIL150    # FGR 11/03/2010 : X3SUIVI62924
  If SZAPTORIAOB <> [M:BAP1]APTORIAOB Then
    Raz [M:BAP1]APTORIVCR
    Raz [M:BAP1]APTORIVCRL
    Raz [M:BAP1]APTCMGNUM
    Raz [M:BAP1]APTOPGTYP
    Raz [M:BAP1]APTOPGNUM
    Raz [M:BAP1]APTORIVCRD
    Affzo [M:BAP1]1-99
  Endif
End

##########################################################################################################
Subprog B2_APTORIADI(VALEUR)
Variable Char    VALEUR()

  # FGR 11/03/2010 : X3SUIVI62924
  Actzo [M:BAP1]APTORIADI
  Actzo [M:BAP1]APTORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog IB_APTORIVCR

  If [M:BAP1]APTORIADI = "MAN1" Then
    # Si c'est "MAN1" on ne peut pas indiquer d'objet donc pas de bouton
    Raz GBOUTS
    Raz GBOUT1
    Raz GBOUT2
  Else
    Raz GBOUT1
    If [M:BAP1]APTORITYP <> 2 Then
      If varmode( [M:BAP1]APTORIVCR, 0) <> 0 Then
        Raz GBOUTS
        GBOUT2= mess(257,177,1)
      Else
        Raz GBOUT2
      Endif
    Else
      Raz GBOUTS
      Raz GBOUT2
    Endif
    #If [M:BAP1]APTORIOBC <> "" and [M:BAP1]APTORIVCR <> "" Then
    If [M:BAP1]APTORIAOB <> "" and [M:BAP1]APTORIVCR <> "" Then   # FGR 11/03/2010 : X3SUIVI62924
      #Détail pièce
      GBOUT1 = mess(103,182,1)
    Endif
  Endif
End

##########################################################################################################
Subprog B2_APTORIVCR(VALEUR)
Variable Char    VALEUR()

  #Actzo [M:BAP1]APTORITXT
  Actzo [M:BAP1]APTORIADI   # FGR 11/03/2010 : X3SUIVI62924
  Actzo [M:BAP1]APTORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog C_APTORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  #If [M:BAP1]APTORIOBC = "" Then
  If [M:BAP1]APTORIAOB = "" Then   # FGR 11/03/2010 : X3SUIVI62924
    If VALEUR <> "" Then
      #Vous devez d'abord choisir une origine
      GMESSAGE = mess(526,177,1)
      mkstat = 1
      End
    Endif
  Endif
  #If VALEUR <> "" and [M:BAP1]APTORIOBC <> "" Then
  If VALEUR <> "" and [M:BAP1]APTORIAOB <> "" Then   # FGR 11/03/2010 : X3SUIVI62924
    # FGR 21/01/2009 : X3SUIVI33671 : ajout du site
    #Call VERIFOBJCODE ([M:BAP1]APTORIOBC, [M:BAP0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
    Call VERIFOBJCODE ([M:BAP1]APTORIAOB, [M:BAP0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150   # FGR 11/03/2010 : X3SUIVI62924
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      mkstat = 1
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_APTORIVCR(VALEUR)
Variable Char    VALEUR()

    # FGR 01/12/2008 : X3SUIVI50722
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZCMGNUM(GLONVCR)

  If left$([M:BAP1]APTORIADI, 3) = "MKT" Then          # FGR 11/03/2010 : X3SUIVI62924
    #If VALEUR <> "" and [M:BAP1]APTORIOBC <> "" Then
    If VALEUR <> "" and [M:BAP1]APTORIAOB <> "" Then   # FGR 11/03/2010 : X3SUIVI62924
      #Call GETCMG_OBJCODE ("", [M:BAP1]APTORIOBC, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150
      Call GETCMG_OBJCODE ("", [M:BAP1]APTORIAOB, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150   # FGR 11/03/2010 : X3SUIVI62924
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        mkstat = 1
        End
      Endif
      [M:BAP1]APTCMGNUM = SZCMGNUM
      #[M:BAP1]APTOPGTYP = [M:BAP1]APTORIOBC  # FGR 21/04/2009 : X3SUIVI54457 : ça manquait un peu !
      [M:BAP1]APTOPGTYP = [M:BAP1]APTORIAOB   # FGR 11/03/2010 : X3SUIVI62924
      [M:BAP1]APTOPGNUM = VALEUR              # FGR 21/04/2009 : X3SUIVI54457 : ça manquait un peu !
    Endif
  Else
    Raz [M:BAP1]APTCMGNUM
    Raz [M:BAP1]APTOPGTYP
    Raz [M:BAP1]APTOPGNUM
  Endif
End

