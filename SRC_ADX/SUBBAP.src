#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier BAPPOINT
Call OBJET ("BAP", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"       : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "OUVRE"       : Gosub OUVRE
    When "SETBOUT"     : Gosub SETBOUT
    When "AVANTBOUT"   : Gosub AVANTBOUT
    When "LIENS"       : Gosub LIENS
    When "FERME"       : Gosub FERME
    When "RAZCRE"      : Gosub RAZCRE
    When "RAZDUP"      : Gosub RAZDUP
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
   #When "AP_ANNULE"   : Gosub AP_ANNULE    # FGR 12/08/2009 : X3SUIVI57005
    When "APRES_ANNULE": Gosub APRES_ANNULE # FGR 22/10/2009 : X3SUIVI57254
    When "ABANDON"     : Gosub ABANDON
    When "FILTRE"      : Gosub FILTRE
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When "AVANT_CHOI"  : Gosub AVANT_CHOI
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer IBUSYREP(10)
Global Char GSZCONFAPP(GLONBAP)(100)
Global Char GBAP2CFLRS(GLONBAP)(10)
Global Char GCBAPCPT(GLONANM)       # Code compteur
Global Char GTBBAPFIELDSYL(30)(50)
Global Char GTBBAPVALSYL(250)(50)
Global Char GTBBAPCHRONOSYL(30)(50)
Global Integer GIBAPNBSYL
Global Char GTBBAPVALREP(30)(dim([M:BAP2]APTREPNUM))
Global Char GTBBAPVALUSR(30)(dim([M:BAP2]APTREPNUM))
Global Integer GIBAPNBREP
Global Integer GIBAP1RRSUPD
Global Char GBOXBAP(10)
Global Char GBOXBA2(10)
Global Integer GBAPTUNNEL

Local Char SZSITE(GLONFCY)

  GBAPTUNNEL = TUNNEL
  If !clalev([F:BPR]) Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) Local File BPADDRESS [BPA] : Endif
  If !clalev([F:CPY]) Local File COMPANY [CPY] : Endif
  If !clalev([F:FCY]) Local File FACILITY [FCY] : Endif
  If !clalev([F:SYL]) Local File SYNCLINK [SYL] : Endif
  If !clalev([F:TCA]) Local File TABCOUAFF [TCA] : Endif
  #
  Raz GTBBAPFIELDSYL
  Raz GTBBAPVALSYL
  Raz GTBBAPCHRONOSYL
  GIBAPNBSYL = 0
  Raz GTBBAPVALREP
  Raz GTBBAPVALUSR
  GIBAPNBREP = 0
  GIBAP1RRSUPD = 0
  GCBAPCPT = ""
  Raz IBUSYREP    #Initialise IBUSYREP
  Raz GSZCONFAPP  #Initialise GSZCONFAPP
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  GCBAPCPT = [F:TCA]CODNUM(0)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBBAP"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:B_AP]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [B_AP] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [BAP] With [B_AP]APP2=[F:BAP]APTDAT;[F:BAP]APTHOU;[F:BAP]APTNUM,
&                 [AFF]AFF0~=[F:BAP]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:BAP]SALFCY,
&                 [COR]COR0=[F:BAP]APTCOR
&              As [BA2]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "BAP" Then
    GBOXBAP= "GAU_CHE"
  Else
    GBOXBAP = "GAU_CHE"+num$(find("BAP",OBJLIS(1..8))) : #Appels à  effectuer
  Endif
  If OBJLIS(0) = "BA2" Then
    GBOXBA2= "GAU_CHE"
  Else
    GBOXBA2 = "GAU_CHE"+num$(find("BA2",OBJLIS(1..8))) : #Appels effectués
  Endif
Return

##########################################################################################################
$SETBOUT
  #Menu Actions   Module Action Co
  # { : Enregistrer un appel
  # ~ : Enregistrer une tâche
  # ! : Enregistrer une affaire
  # % : Enregistrer une demande de service
  # ( : Planifier un appel
  # £ : Planifier une tâche
  # N : Traçabilité pièces              # FGR 17/10/2012 : X3SUIVI71278
  If REP = "" Then
    CHMEN += "{~!(£N"
  Endif
  If REP = "" and GMODU(12) = 2 Then
    CHMEN += "%"
  Endif
  #
  If REP = "" Then
    If [M:BAP3]APTPLC <> 2 Then
      # Itinéraire que pour les rendez-vous non "2: En nos locaux"
      CHMEN += "1234"
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  [M:BAP0]NVGCOD = BOUT
  Case BOUT
    When "("
      #Planifier Appel
      GBCRMFLGNEW = 1
    When "£"
      #Planifier Tache
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer Tache
      GBCRMFLGNEW = 1
    When "!"
      #Enregistrer Affaire
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCRE
Local Char SZTYP
Local Char SZNUM
Local Char SZFNC
Local Integer IFNC
Local Integer INBLIG
Local Integer BAPNOL
Local Char SZNVGCOD(GLONNVG)
Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  BAPNOL = 0
  SZTYP = ""
  SZNUM = ""
  SZFNC = ""
  IFNC = 0
  INBLIG = 0
  Raz GTBBAPFIELDSYL
  Raz GTBBAPVALSYL
  Raz GTBBAPCHRONOSYL
  GIBAPNBSYL = 0
  Raz GTBBAPVALREP
  Raz GTBBAPVALUSR
  GIBAPNBREP = 0
  Raz SZNVGCOD
  IBRETOUR=0
  Raz SZMESSAGE
  #Initialise les valeurs par défaut de l'enregistrement
  # FGR 07/04/2015 : X3SUIVI107457 (début)
  If [M:BAP0]APTCMP <> "" Then
    Local Char SVALEUR(type([M:BAP0]APTCMP)-10)

    SVALEUR = [M:BAP0]APTCMP
    Call AM_APTCMP(SVALEUR) From W1BAP0
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (fin)
  [M:BAP1]TYPFULOBJ = "BAPOBJ"
  [M:BAP4]TYPFULRPO = "BAPRPO"
  Raz [M:BAP0]APTRERDEL
  If [M:BAP1]APTDAT = [00/00/00] Then
    [M:BAP1]APTDAT = date$
    [M:BAP1]APTDATX = date$
    [M:BAP1]APTWEE = week(date$)
  Else
    [M:BAP1]APTWEE = week([M:BAP1]APTDAT)
    [M:BAP1]APTDATX = [M:BAP1]APTDAT
  Endif
  If [M:BAP1]APTHOU = "" Then
    [M:BAP1]APTHOU = "0930"
  Endif
  # FGR 05/10/2015 : X3SUIVI110908 (début)
  #If [M:BAP1]APTDATEND = [00/00/00] Then
  #  [M:BAP1]APTDATEND = [M:BAP1]APTDAT
  #  Call  DAY_ADD_DURE([M:BAP1]APTDAT, [M:BAP1]APTHOU, 0, 1, 0, [M:BAP1]APTDATEND, [M:BAP1]APTHOUEND, SZMESSAGE, IBRETOUR) From CRMUTIL150
  #  [M:BAP1]APTDUR = "0100"
  #Endif
  If [M:BAP1]APTDATEND = [00/00/00] Then
    [M:BAP1]APTDATEND = [M:BAP1]APTDAT
  Endif
  If [M:BAP1]APTHOUEND = "" Then
    Call  DAY_ADD_DURE([M:BAP1]APTDAT, [M:BAP1]APTHOU, 0, 1, 0, [M:BAP1]APTDATEND, [M:BAP1]APTHOUEND, SZMESSAGE, IBRETOUR) From CRMUTIL150
    [M:BAP1]APTDUR = "0100"
  Endif
  # FGR 05/10/2015 : X3SUIVI110908 (fin)
  If [M:BAP1]APTDUR = "" Then
    If [M:BAP1]APTDAT <> [00/00/00] and [M:BAP1]APTHOU <> "" and [M:BAP1]APTDATEND <> [00/00/00] and  [M:BAP1]APTHOUEND <> "" Then
      Call GETDUR(nday([M:BAP1]APTDAT), [M:BAP1]APTHOU, nday([M:BAP1]APTDATEND), [M:BAP1]APTHOUEND, SZDUR) From CRM_UTIL
      [M:BAP1]APTDUR = SZDUR
    Endif
  Endif
  [M:BAP1]APTDURX = mess(1,976,1)
  [M:BAP3]APTPLC = 1
  Call DEFVALADI(433, [M:BAP1]APTTYP) From CRMUTIL140
  #On initialise le site
  Call SITECRMDEF("ACT", [M:BAP0]SALFCY) From CRM_UTIL
  GFCY = [M:BAP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Représentant connecté prioritaire
  If GCRMREPBAP = 2 Then
    Read [REP]REP1=GUSER
    If !fstat Then
      Raz [M:BAP2]APTREPNUM
      Raz [M:BAP2]APTREPSRV
      [M:BAP2]APTREPNUM(0) = [F:REP]REPNUM
    Endif
  Endif
  #Origine
  [M:BAP1]CREDAT = date$
  [M:BAP1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:BAP1]FULNAMUSR = GUSER
  Else
    [M:BAP1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  # FGR 11/03/2010 : X3SUIVI62924 (début)
  #[M:BAP1]APTORIOBC = ""
  #[M:BAP1]APTORI = 1
  #[M:BAP1]APTORITXT = ""
  #Diszo [M:BAP1]APTORITXT
  If [M:BAP1]APTORIADI = "" Then
    Raz [M:BAP1]APTORIAOB
    [M:BAP1]APTORIADI = "MAN1"
  Else
    # FGR 17/03/2010 : X3SUIVI62924 : pour faire correctement si on vient en création tunnel.
    [M:BAP1]APTORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:BAP1]APTORIADI)
    Call DEFOBJORI([M:BAP1]APTORIAOB, [M:BAP1]APTORIAVA) From CRMUTIL150
    Call LIEN_OBJ_DYNAMIC([M:BAP1]APTORIVCR,[M:BAP1]APTORIAOB,[M:BAP1]APTORIAVA,"","","[M:BAP1]APTORIVCRD") From CRMUTIL140
  Endif
  Diszo [M:BAP1]APTORIADI
  # FGR 11/03/2010 : X3SUIVI62924 (fin)
  Diszo [M:BAP1]APTORIVCR
  If !GIMPORT Then
    [M:BAP1]APTORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:BAP1]APTORITYP = 2
    Else
      [M:BAP1]APTORITYP = 3
    Endif
  Endif
  #[M:BAP1]APTORILIB = mess([M:BAP1]APTORITYP,3037,1)  # FGR 11/03/2010 : X3SUIVI62924
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  #Initialisation des champs déductibles du Tiers
  If [M:BAP0]APTCMP <> "" Then
    #Définit l'adresse par défaut du rendez-vous
    If [M:BAP3]APTPLC = 1 Then
      Call FILAPPPLC([M:BAP3]APTPLC, 0, [M:BAP0]APTCMP) From SUBBAPB
    Endif
    #Définit l'interlocuteur par défaut du rendez-vous
    If [M:BAP1]APTCCNNUM(0) = "" Then
      Call GETDEFCNT([M:BAP0]APTCMP, [M:BAP1]APTCCNNUM(0)) From CRMUTIL140
    Endif
    #Définit le représentant par défaut.
    If [M:BAP2]APTREPNUM(0) = "" Then
      Read [BPR]BPR0=[M:BAP0]APTCMP
      If !fstat Then
        If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
          Read [BPC]BPC0=[M:BAP0]APTCMP
          If !fstat Then
            If [F:BPC]REP(0) <> "" Then
              [M:BAP2]APTREPNUM(0) = [F:BPC]REP(0)
            Else
              If [F:BPC]REP(1) <> "" Then
                [M:BAP2]APTREPNUM(0) = [F:BPC]REP(1)
              Endif
            Endif
          Endif
        Else
          [M:BAP2]APTREPNUM(0) = ""
        Endif
      Endif
    Endif
    #Affiche le nom en clair du tiers sélectionné.
    [M:BAP0]APTCMPCLA = [F:BPR]BPRNAM
    #Affiche le type du tiers sélectionné.
    Call AFFICHE_BCK_TIERS([M:BAP0]APTCMP) From SUBBAPB
  Endif
  #
  If [M:BAP1]APTCCNNUM(0) <> "" Then
    [M:BAP1]NBLIGCCN += 1
    #Affichage de l'interlocuteur
    Gosub DISPCCN From SUBBAPB
    If [M:BAP0]APTCMP = "" and [M:BAP3]APTPLC = 1 Then
      Call FILAPPPLC([M:BAP3]APTPLC, 9, [M:BAP1]APTCCNNUM(0)) From SUBBAPB
    Endif
  Endif
  #
  If !GIMPORT Then
    If TUNNEL = 0 Then
      #On ne vient de nulle part
      If GDONDEFBAP = 2 Then
        SZNVGCOD = "}"
      Else
        SZNVGCOD = ")"
      Endif
    Else
      #On vient de quelque part
      Case GNAVIG(GPILNAV-1)
        When "GESSRE"
          SZNVGCOD = [M:SRE0]NVGCOD
          Call GETSREOPP([M:SRE0]SRENUM, [M:BAP0]APTPJT) From SUBSREB2
        When "FUNHDKAGD"
          SZNVGCOD = [M:HDK0]NVGCOD
          Call GETSREOPP([M:HDK0]HDKSRE, [M:BAP0]APTPJT) From SUBSREB2
        When "GESBPR"
          SZNVGCOD = [M:BPR0]NVGCOD
        When "GESBPP"
          SZNVGCOD = [M:BPP0]NVGCOD
        When "GESBPC"
          SZNVGCOD = [M:BPC0]NVGCOD
        When "FUNCRM9"
          SZNVGCOD = [M:CRM9]NVGCOD
        When "FUNCRMAGD"
          SZNVGCOD = [M:CRM0]NVGCOD
        When "GESTSK"
          SZNVGCOD = [M:TSK0]NVGCOD
        When "GESCLL"
          SZNVGCOD = [M:CLL0]NVGCOD
        When "GESOPP"
          SZNVGCOD = [M:OPP0]NVGCOD
        When "GESLDS"
          # FGR 16/04/2012 : X3SUIVI81045
          SZNVGCOD = [M:LDS0]NVGCOD
        When Default
          If GDONDEFBAP = 2 Then
            SZNVGCOD = "}"
          Else
            SZNVGCOD = ")"
          Endif
      Endcase
    Endif
    If SZNVGCOD = ")" Then
      #RDV à  planifier
      [M:BAP0]APTDON = 1
    Elsif SZNVGCOD = "}" Then
      #RDV effectué
      [M:BAP0]APTDON = 2
    Endif
  Endif
  If GCRMDEFREP = 2 Then
    If [M:BAP2]APTREPNUM(0) = "" Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:BAP2]APTREPNUM(0) = [F:REP]REPNUM
      Endif
    Endif
  Endif
  #Affichage de la fonction des représentants
  INBLIG = 0
  [M:BAP2]NBLIGREP = 0
  For INBLIG = 0 To dim([M:BAP2]APTREPNUM)-1
    If [M:BAP2]APTREPNUM(INBLIG) = "" Then
      Break
    Endif
    Read [REP]REP0=[M:BAP2]APTREPNUM(INBLIG)
    If fstat Then
      [M:BAP2]APTREPSRV(0) = ""
    Else
      If [F:REP]AUSNUM = "" Then
        Call TEXTE(2929, [M:BAP2]APTREPSRV(INBLIG)) From OBJDIV      #Représentant
      Else
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        If IFNC = 1 Then
          Call TEXTE(2929, [M:BAP2]APTREPSRV(INBLIG)) From OBJDIV      #Représentant
        Else
          [M:BAP2]APTREPSRV(INBLIG) = mess(val(SZFNC),3022,1)
        Endif
      Endif
    Endif
    [M:BAP2]NBLIGREP += 1
  Next
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  Gosub SAVEVALINI From SUBBAPB
  #Utilisation ou non du site du représentant
  Call SITECRMREP("ACT", [M:BAP2]APTREPNUM(0), [M:BAP0]SALFCY) From CRM_UTIL
  GFCY = [M:BAP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBBAPB
  Affzo [M:BAP0]1-99
  Affzo [M:BAP1]1-99
  Affzo [M:BAP2]1-99
  Affzo [M:BAP3]1-99
  Affzo [M:BAP4]1-99
Return

##########################################################################################################
$RAZDUP
  Raz GTBBAPFIELDSYL
  Raz GTBBAPVALSYL
  Raz GTBBAPCHRONOSYL
  GIBAPNBSYL = 0
  #Origine
  [M:BAP1]CREDAT = date$
  [M:BAP1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:BAP1]FULNAMUSR = GUSER
  Else
    [M:BAP1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  If !GIMPORT Then
    [M:BAP1]APTORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:BAP1]APTORITYP = 2
    Else
      [M:BAP1]APTORITYP = 3
    Endif
  Endif
  #[M:BAP1]APTORILIB = mess([M:BAP1]APTORITYP,3037,1)  # FGR 11/03/2010 : X3SUIVI62924
  # FGR 11/03/2010 : X3SUIVI62924 (début)
  #[M:BAP1]APTORIOBC = ""
  #[M:BAP1]APTORI = 1
  #[M:BAP1]APTORITXT = ""
  #Diszo [M:BAP1]APTORITXT
  Raz [M:BAP1]APTORIAOB
  [M:BAP1]APTORIADI = "MAN1"
  Diszo [M:BAP1]APTORIADI
  # FGR 11/03/2010 : X3SUIVI62924 (fin)
  Diszo [M:BAP1]APTORIVCR
  Affzo [M:BAP1]1-99
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If not (GSYNCOUTLOOK = 1 and vireblc([M:BAP0]APTNUM,2) <> "") Then
    #On n'est pas en restauration de synchro
    Call READ_COUNTER([M:BAP0]SALFCY, 13, 0, GSOCIETE, GCURLEG, GCBAPCPT, GMANCOU) From CRM_UTIL   # FGR 20/05/2015 : X3SUIVI107775
    # Récupération du compteur de contrat de service.
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:BAP0]SALFCY, GCBAPCPT, date$, "", [M:BAP0]APTNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        [F:BAP]APTNUM = [M:BAP0]APTNUM
        Affzo [M:BAP0]APTNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
  [F:BAP]NUMFULOBJ = [M:BAP0]APTNUM
  [F:BAP]NUMFULRPO = [M:BAP0]APTNUM
  [M:BAP1]NUMFULOBJ = [M:BAP0]APTNUM
  [M:BAP4]NUMFULRPO = [M:BAP0]APTNUM
  [F:BAP]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Char SZMESS(250)
Local Char SZFNC
Local Integer IFNC
Local Integer IASK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  GOK = 1
  SZMESS = ""
  IASK = 0
  SZFNC = ""
  IFNC = 0
  IBRETOUR = 1
  Raz [F:ADI]
  If [M:BAP1]APTTYP <> "" Then
    Read [ADI]CODE=433;[M:BAP1]APTTYP
    If !fstat Then
      If [F:ADI]N1 = 2 Then
        #Une absence doit toujours être effectuée
        [M:BAP0]APTDON = 2
        Affzo [M:BAP0]APTDON
        #Un rdv de type absence ne peut pas être programmé en date floue
        If [M:BAP1]APTDAT = [00/00/00] Then
          #Un rendez-vous de type Absence ne peut pas être planifié en date floue.
          GMESSAGE = mess(706,182,1)
          GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
          OK = 0
          Return
        Endif
        If [M:BAP1]APTDATEND = [00/00/00] Then
          #Un rendez-vous de type Absence ne peut pas être planifié en date floue.
          GMESSAGE = mess(706,182,1)
          GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
  # FGR 06/07/2011 : X3SUIVI74797 : En fait pas si l'origine est "synchronisation" sinon ça devient obligatoire lorsqu'on modifie dans l'écran
  # FGR 09/10/2009 : X3SUIVI58275 : Pas si synchronisation outlook : l'info n'y est pas.
  #If [M:BAP0]APTCMP = "" and [M:BAP1]NBLIGCCN = 0 and [F:ADI]N1 <> 2 and GSYNCOUTLOOK = 0 Then
  If [M:BAP0]APTCMP = "" and [M:BAP1]NBLIGCCN = 0 and [F:ADI]N1 <> 2 and [M:BAP1]APTORITYP <> 3 Then
    # FGR 20/08/2009 : X3SUIVI57294 : Au moins un des champs est renseigné... sauf si c'est une abscence
    GMESSAGE = mess(976,196,1) #Aucun représentant n'est mentionné.
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  #
  Gosub VERIFDATE From SUBBAPB
  If OK = 0 Then
    Return
  Endif
  #Affecte le rendez-vous à  l'utilisateur si rien n'a été saisi ni déduit.
  If [M:BAP2]NBLIGREP = 0 Then
    Read [REP]REP1=GUSER
    If fstat Then
      If ACTION = "VERIF_CRE" Then
        GMESSAGE = mess(248,196,1) #Aucun représentant n'a été affecté. Création refusée.
      Else
        GMESSAGE = mess(249,196,1) #Aucun représentant n'a été affecté. Création refusée.
      Endif
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return    # FGR 11/01/2013 : X3SUIVI87120 :  ca manque un peu
    Else
      #Aucun représentant n'a été saisi pour cette action. Souhaitez-vous l'affecter à  :
      SZMESS = mess(409,182,1) - [F:REP]REPNAM - "(" + [F:REP]REPNUM + ")"
      Call OUINON(SZMESS, IASK) From GESECRAN
      If IASK = 2 Then
        [M:BAP2]APTREPNUM(0) = [F:REP]REPNUM
        If [F:REP]AUSNUM = "" Then
          Call TEXTE(2929, [M:BAP2]APTREPSRV(0)) From OBJDIV      #Représentant
        Else
          Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
          If SZFNC = "" Then
            IFNC = 1
          Else
            IFNC = val(SZFNC)
          Endif
          If IFNC = 1 Then
            Call TEXTE(2929, [M:BAP2]APTREPSRV(0)) From OBJDIV      #Représentant
          Else
            [M:BAP2]APTREPSRV(0) = mess(val(SZFNC),3022,1)
          Endif
        Endif
        [M:BAP2]NBLIGREP += 1
        #Utilisation ou non du site du représentant
        Call SITECRMREP("ACT", [M:BAP2]APTREPNUM(0), [M:BAP0]SALFCY) From CRM_UTIL
        GFCY = [M:BAP0]SALFCY
        Call GETDEV(GFCY) From DEVSUB
        Affzo [M:BAP0]SALFCY
        Affzo [M:BAP2]1-99
      Else
        If ACTION = "VERIF_CRE" Then
          GMESSAGE = mess(248,196,1) #Aucun représentant n'a été affecté. Création refusée.
        Else
          GMESSAGE = mess(249,196,1) #Aucun représentant n'a été affecté. Création refusée.
        Endif
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        Return    # FGR 11/01/2013 : X3SUIVI87120 :  ca manque un peu
      Endif
    Endif
  Endif
  #Vérifie que l'organisateur appartient à  la liste des participants
  Gosub VERIF_ORGANISATEUR From SUBBAPB
  If GOK < 1 Then
    OK = 0
    Return
  Endif
  #Vérifie un éventuel conflit horaire
  Gosub CHKAPPDISP From SUBBAPB
  If GOK < 1 Then
    OK = 0
    Return
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Assure enregistrement description abrégé
  #  If [M:BAP1]FULOBJ = "" Then
  #    [M:BAP1]APTOBJ = ""
  #  Else
  #    [M:BAP1]APTOBJ = left$([M:BAP1]FULOBJ,250)
  #  Endif
  #  #Assure enregistrement début cpt rendu
  #  If [M:BAP4]FULRPO = "" Then
  #    [M:BAP4]APTRPO = ""
  #  Else
  #    [M:BAP4]APTRPO = left$([M:BAP4]FULRPO,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Assure le bon enregistrement de l'origine de la tâche
  # FGR 11/03/2010 : X3SUIVI62924 (début)
  #If [M:BAP1]APTORI > 1 Then
  #  [M:BAP1]APTORITXT = mess([M:BAP1]APTORI,2994,1)
  #Else
  #  [M:BAP1]APTORITXT = ""
  #Endif
  # FGR 11/03/2010 : X3SUIVI62924 (fin)
  Gosub VERIFORI From SUBBAPB
  If GERR <> 0 Then
    OK = 0
    Return
  Endif
  Gosub BAPGEREALLAINCOR From SUBBAPB
  If GOK < 1 Then
    OK = 0
    Return
  Endif
  Gosub BAPGEREALLREPCOR From SUBBAPB
  If GOK < 1 Then
    OK = 0
    Return
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ZH
Local Char SZMESSAGE(250)

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  #Supprime les réservations de ressources supprimées
  For ZH = 0 To dim([M:BAP0]APTRERDEL)-1
    If [M:BAP0]APTRERDEL(ZH) <> ""
      Read [RRS]RRS0=[M:BAP0]APTRERDEL(ZH)
      If !fstat Then
        Delete [RRS]Curr
        If fstat Then
          #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
          GMESSAGE = mess(476,196,1)
          GERR = 1
          Call FSTA("RRS") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données de synchronisation pour tous les représentants
  Gosub CRESYDALLREP From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  Call ADDOPPSTE("BAP", [M:BAP0]PREOPP, [M:BAP0]APTPJT, [M:BAP0]APTNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #  Endif
  #  If GOK < 1 Then
  #    Return
  #  Endif
  If [M:BAP0]APTPJT <> "" or [M:BAP0]PREOPP <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_ADD_STEPB([M:BAP0]APTPJT, "BAP", [M:BAP0]APTNUM, [M:BAP0]PREOPP)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:BAP0]APTPJT - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  Call UPDRRSORI From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSBAP From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  Call CLEANRRSORI (2, [M:BAP0]APTNUM, "[M:BAP5]APTRER", SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  Diszo [M:BAP1]APTORIVCR
  #Diszo [M:BAP1]APTORITXT
  Diszo [M:BAP1]APTORIADI  # FGR 11/03/2010 : X3SUIVI62924
  # Maj des statistiques
  Call VALSTA("BAP",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ZH

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  #Gestion des données de synchronisation pour tous les représentants
  If FORCAGEREP <> "" Then
    #cas du forà§age
    Gosub FORCEBAP From SUBBAPB
  Else
    Gosub GERESYDALLREP From SUBBAPB
  Endif
  #Supprime les réservations de ressources supprimées
  For ZH = 0 To dim([M:BAP0]APTRERDEL)-1
    If [M:BAP0]APTRERDEL(ZH) <> "" Then
      Read [RRS]RRS0=[M:BAP0]APTRERDEL(ZH)
      If !fstat Then
        Delete [RRS] Curr
        If fstat Then
          #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
          GMESSAGE = mess(476,196,1)
          GERR = 1
          Call FSTA("RRS") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  #traitement des erreurs de transcodification
  If GIBAPNBSYL > 0 Then
    While IINDICE < GINBSYL
      If GTBBAPVALSYL(IINDICE) <> evalue ("[M]" + GTBBAPFIELDSYL(IINDICE)) Then
        #On a une modification du champs, on estime transcodif faite
        Read [SYL]SYL0=GTBBAPCHRONOSYL(IINDICE)
        If fstat = 0 Then
          [F:SYL]SYLFLGDPT = 0
          Rewrite [SYL]
        Endif
      Endif
      IINDICE = IINDICE + 1
    Wend
  Endif
  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  Call ADDOPPSTE("BAP", [M:BAP0]PREOPP, [M:BAP0]APTPJT, [M:BAP0]APTNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #    Return
  #  Endif
  If [M:BAP0]APTPJT <> "" or [M:BAP0]PREOPP <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_ADD_STEPB([M:BAP0]APTPJT, "BAP", [M:BAP0]APTNUM, [M:BAP0]PREOPP)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:BAP0]APTPJT - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  Call UPDRRSORI From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  Call UPDRRSBAP From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  Call CLEANRRSORI (2, [M:BAP0]APTNUM, "[M:BAP5]APTRER", SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
    Return
  Endif
  Diszo [M:BAP1]APTORIVCR
  #Diszo [M:BAP1]APTORITXT
  Diszo [M:BAP1]APTORIADI  # FGR 11/03/2010 : X3SUIVI62924
  # Maj des statistiques
  Call VALSTA("BAP",-1) From SUBPS2
  Call VALSTA("BAP",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  Raz [M:BAP0]APTRERDEL
  #Incrémentation des étapes avant-vente de l'affaire
  [M:BAP1]CREHOU = [F:BAP]CREHOU
  Gosub SAVEVALINI From SUBBAPB
  Gosub COMPLETREP From SUBBAPB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBBAPB
  Affzo [M:BAP1]1-99
  Affzo [M:BAP2]1-99
  Affzo [M:BAP4]1-99
Return

