$APRES_MOD
  Raz [M:BAP0]APTRERDEL
  #Incrémentation des étapes avant-vente de l'affaire
  Gosub SAVEVALINI From SUBBAPB
  Gosub COMPLETREP From SUBBAPB
  #---------------------------------------------------#
  #Affichage des icà´nes
  #---------------------------------------------------#
  Gosub DISPICON From SUBBAPB
  Affzo [M:BAP1]1-99
  Affzo [M:BAP4]1-99
Return

##########################################################################################################
$AV_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Suppression des clobs
  Gosub DELCLOB From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
  # FGR 12/08/2009 : X3SUIVI57005 : C'est pas là que ça doit être
  #Enregistrement des données pour les encours
  #Gosub GERE_LCM_ANNULE From SUBBAPB
  #If GOK < 1 Then
  #  Return
  #Endif
  #Suppression des réservations de ressources
  Call DELRRS([M:BAP0]APTNUM) From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
Local Instance GZINSOPP Using C_OPPOR # Issue X3-60113 - 2017-10-20 by FGR : was missing

  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  # FGR 05/05/2011 : X3SUIVI71031 (début)
  #  Call DELOPPSTE("BAP", [M:BAP0]APTPJT, [M:BAP0]APTNUM, SZMESSAGE, IBRETOUR) From SUBOPPB
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #    Return
  #  Endif
  #  # FGR 05/05/2011 : X3SUIVI71031 (fin)
  If [M:BAP0]APTPJT <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_DEL_STEPB([M:BAP0]APTPJT, "BAP", [M:BAP0]APTNUM)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:BAP0]APTPJT - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  # Suppression des données de synchronisation pour tous les représentants
  Gosub DELLSYDALLREP From SUBBAPB
  #Suppression donnée transcodif
  Call SYLDELETE("BAP", [M:BAP0]APTNUM, IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
  # Maj des statistiques
  Call VALSTA("BAP",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais les Premier/Dernier/Prochain ne seront pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBBAPB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ABANDON
Local Integer ZH

  If [M:BAP0]APTNUM = "" Then
    #Supprime les éventuelles réservations de ressources effectuées
    Call DEBTRANS From GLOCK
    Trbegin [RRS]
    For ZH = 0 To [M:BAP5]NBRER-1
      If [M:BAP5]APTRER(ZH) <> "" Then
        Read [RRS]RRS0=[M:BAP5]APTRER(ZH)
        If !fstat Then
          Delete [RRS]Curr
          If fstat Then
            GERR = 1
            #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
            GMESSAGE = mess(476,196,1)
            Rollback
            Break
          Endif
        Endif
      Endif
    Next
    If GERR Then
      Return
    Endif
    For ZH = 0 To dim([M:BAP0]APTRERDEL)-1
      If [M:BAP0]APTRERDEL(ZH) <> "" Then
        Read [RRS]RRS0=[M:BAP0]APTRERDEL(ZH)
        If !fstat Then
          Delete [RRS] Curr
          If fstat Then
            GERR = 1
            #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
            GMESSAGE = mess(476,196,1)
            Rollback
            Break
          Endif
        Endif
      Endif
    Next
    If GERR Then
      Return
    Endif
    Commit
  Endif
  Raz [M:BAP0]APTRERDEL
Return

##########################################################################################################
$APRES_MODIF
  #Réinitialise le tableau des contrà´les de conflits
  Raz IBUSYREP
  Affzo [M:BAP2]1-99
Return

##########################################################################################################
$FILTRE
  Default File [BAP]
Return

##########################################################################################################
$FILGAUCHE
  Default File [BAP]
  If currbox = GBOXBAP Then
    #RDV à  effectuer
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "APTDON <> 2", "&") From GOBJSUB
  Elsif currbox = GBOXBA2 Then
    #RDV effectués
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "APTDON = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "BAP") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$LIENS
#Réinitialise le tableau des contrà´les de conflits
Local Integer Y
Local Char SZTYP
Local Integer BPRCLOSINGFLG
Local Integer BAPNOL
Local Integer TESTNBLIG
Local Integer I
Local Char SZNULL

  Raz [M:BAP0]APTRERDEL
  BAPNOL = 0
  BPRCLOSINGFLG = 0
  SZTYP = ""
  Raz IBUSYREP
  GFCY = [M:BAP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Lecture des clobs
  Gosub LOADCLOB From SUBBAPB
  #---------------------------------------------------#
  # Origine
  #---------------------------------------------------#
  If [M:BAP1]CREUSR <> "" Then
    Read[AUS]CODUSR=[M:BAP1]CREUSR
    If fstat = 0 Then
     [M:BAP1]FULNAMUSR = [F:AUS]NOMUSR
    Endif
    Affzo [M:BAP1]FULNAMUSR
  Endif
  If [M:BAP1]APTORITYP = 0 Then
    [M:BAP1]APTORITYP = 1
  Endif
  #[M:BAP1]APTORILIB = mess([M:BAP1]APTORITYP,3037,1)  # FGR 11/03/2010 : X3SUIVI62924
  # FGR 11/03/2010 : X3SUIVI62924 (début)
  #If [M:BAP1]APTORI = 0 Then
  #  [M:BAP1]APTORI = 1
  #Endif
  #If [M:BAP1]APTORI = 1 Then
  #  [M:BAP1]APTORITXT = ""
  #Else
  #  [M:BAP1]APTORITXT = mess([M:BAP1]APTORI,2994,1)
  #Endif
  # FGR 11/03/2010 : X3SUIVI62924 (fin)
  #Définition du type de pià¨ce
  #Gosub DEFOBJORI From SUBBAPB
  Call DEFOBJORI([M:BAP1]APTORIAOB, [M:BAP1]APTORIAVA) From CRMUTIL150    # FGR 11/03/2010 : X3SUIVI62924
  Diszo [M:BAP1]APTORIVCR
  #Diszo [M:BAP1]APTORITXT
  Diszo [M:BAP1]APTORIADI    # FGR 11/03/2010 : X3SUIVI62924
  #Call LIEN_OBJ_DYNAMIC([M:BAP1]APTORIVCR,[M:BAP1]APTORIOBC,[M:BAP1]APTORIAVA,"","","[M:BAP1]APTORIVCRD") From CRMUTIL140 # FGR 12/02/2009 : X3SUIVI52443
  Call LIEN_OBJ_DYNAMIC([M:BAP1]APTORIVCR,[M:BAP1]APTORIAOB,[M:BAP1]APTORIAVA,"","","[M:BAP1]APTORIVCRD") From CRMUTIL140 # FGR 11/03/2010 : X3SUIVI62924
  #---------------------------------------------------#
  #  Remplit les tableaux
  #---------------------------------------------------#
  SZNULL = ""
  # Calcul de NBLIG pour le tableau des interlocuteurs
  TESTNBLIG = 0
  For I = 0 To dim([F:BAP]APTCCNNUM)-1
    If [M:BAP1]APTCCNNUM(I) = "" and [M:BAP1]APTCOR(I) = "" Then
      Break
    Endif
    TESTNBLIG += 1
  Next
  [M:BAP1]NBLIGCCN = TESTNBLIG
  For I = 0 To [M:BAP1]NBLIGCCN-1
    BAPNOL = I
    #Affichage de l'interlocuteur
    Gosub DISPCCN From SUBBAPB
  Next
  #Compelete le tableau des représentants
  Gosub COMPLETREP From SUBBAPB
  # Calcul de NBRER pour le tableau des ressources.
  TESTNBLIG = 0
  For I = 0 To dim([F:BAP]APTRER)-1
    If [M:BAP5]APTRER(I) = "" Then
      Break
    Else
      Call LECTURE_RESRES (I, [M:BAP5]APTRER(I)) # FGR 24/07/2009 : X3SUIVI56702
    Endif
    TESTNBLIG += 1
  Next
  [M:BAP5]NBRER = TESTNBLIG
  #---------------------------------------------------#
  #  Renseigne le lieu du rendez-vous
  #---------------------------------------------------#
  # Note FGR 24/11/2008 : Je ne comprends pas cette partie qui semble bizarre.
  #                       On recharche une adresse, sans tenir compte de ce qu'il y a en base.
  #                       En lecture on présente les info de la base, on ne les redétermine pas sinon à
  #                       quoi ça sert de les stocker ?
  #If [M:BAP3]APTRECADD = "" Then
  #  #Chargement normal d'une adresse
  #  Call FILAPPPLC([M:BAP3]APTPLC, 0, SZNULL) From SUBBAPB
  #Else
  #  #Chargement d'une autre adresse.
  #  Call LOADPLC From SUBBAPB
  #Endif
  #---------------------------------------------------#
  #  Initialise le champs APTDURX
  #---------------------------------------------------#
  [M:BAP1]APTDURX = mess(1,976,1)
  # Grise ou dérgise le champs Durée du RDV
  If [M:BAP1]APTDAT <> [00/00/00] Then
    Grizo [M:BAP1]APTDUR
    Grizo [M:BAP1]APTDURX
  Else
    Actzo [M:BAP1]APTDUR
    Actzo [M:BAP1]APTDURX
  Endif
  Affzo [M:BAP1]APTDURX, APTDUR
  Affzo [M:BAP2]1-99
  #---------------------------------------------------#
  #Affiche le nom en clair du tiers sélectionné.
  #---------------------------------------------------#
  Read [BPR]BPR0=[M:BAP0]APTCMP
  If !fstat Then
    [M:BAP0]APTCMPCLA = [F:BPR]BPRNAM
  Endif
  #---------------------------------------------------#
  #Affiche le type du tiers sélectionné.
  #---------------------------------------------------#
  Call AFFICHE_BCK_TIERS([M:BAP0]APTCMP) From SUBBAPB
  #---------------------------------------------------#
  #Contrà´le du pays
  #---------------------------------------------------#
  If [M:BAP3]APTCRY = "" Then
    [M:BAP3]APTCRY = GPAYS
  Endif
  #---------------------------------------------------#
  # Gestion des valeurs modifiées
  #---------------------------------------------------#
  Gosub SAVEVALINI From SUBBAPB
  #---------------------------------------------------#
  # Contrà´le de l'incrémentation du cyle de vente des affaires
  #---------------------------------------------------#
  Call SETPREOPP("BAP") From SUBOPPB
  #Gestion de la transcodif
  Raz GTBBAPFIELDSYL
  Raz GTBBAPVALSYL
  Raz GTBBAPCHRONOSYL
  GINBSYL = 0
  For [SYL] Where [F:SYL]SYLTYP = "BAP" and [F:SYL]SYLKEY = [M:BAP0]APTNUM and [F:SYL]SYLFLGDPT = 1
    GTBBAPFIELDSYL(GIBAPNBSYL) = [F:SYL]SYLFIE
    GTBBAPVALSYL(GIBAPNBSYL) = evalue("[M]"+[F:SYL]SYLFIE)
    GTBBAPCHRONOSYL(GIBAPNBSYL) = [F:SYL]SYLNUM
    GIBAPNBSYL = GINBSYL + 1
  Next
  #---------------------------------------------------#
  #Affichage des icà´nes
  #---------------------------------------------------#
  Gosub DISPICON From SUBBAPB
  Affzo [M:BAP1]1-99
  Affzo [M:BAP4]1-99
Return

##########################################################################################################
$FERME
  Kill IBUSYREP
  Kill GSZCONFAPP
  Kill GBAP2CFLRS
  Kill GCBAPCPT   #Code compteur
  Kill GIBAP1RRSUPD
  If dim(GBOXBAP) > 0 Then
    Kill GBOXBAP
    Kill GBOXBA2
  Endif
  Kill GTBBAPFIELDSYL
  Kill GTBBAPVALSYL
  Kill GTBBAPCHRONOSYL
  Kill GIBAPNBSYL
  Kill GTBBAPVALREP
  Kill GTBBAPVALUSR
  Kill GIBAPNBREP
  Kill GBAPTUNNEL
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
Subprog LECTURE_RESRES (ILIGNE, SZAPTRER)
Value Integer ILIGNE
Value Char SZAPTRER

  # FGR 24/07/2009 : X3SUIVI56702
  Read [RRS]RRS0=SZAPTRER
  If !fstat Then
    Read [RSS]RSS0=[F:RRS]RSSNUM
    # FGR 24/09/2009 : X3SUIVI58059
    #[M:BAP5]RSS(ILIGNE) = left$([F:RSS]TTR, GLONNAM)
    #Call LECTEXTRA([M:BAP5]RSS(ILIGNE),"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
    # FGR 30/09/2009 : X3SUIVI57403
    [M:BAP5]RSSNUM(ILIGNE) = [F:RRS]RSSNUM
    [M:BAP5]RERSTRDAT(ILIGNE) = [F:RRS]RERDAT
    [M:BAP5]RERSTRHOU(ILIGNE) = [F:RRS]HOUSTR
    [M:BAP5]RERENDDAT(ILIGNE) = [F:RRS]RERDATEND
    [M:BAP5]RERENDHOU(ILIGNE) = [F:RRS]HOUEND
    Read [REP]REP0=[F:RRS]RERREP
    If fstat Then
      [M:BAP5]RSSREP(ILIGNE) = [F:RRS]RERREP
    Else
      [M:BAP5]RSSREP(ILIGNE) = [F:REP]REPNAM
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  If GREP = "C" Then
    Local Char SZFCY(GLONFCY)
    Local Char SZCRMREP(GLONREP)
    Local Integer ICRMREP
    Local Char SZCRMDEF
    Local Integer ICRMDEF
    Local Char SZDONDEF
    Local Integer IDONDEF

    Raz [M:BAP2]APTREPNUM
    Raz [M:BAP2]APTREPSRV
    [M:BAP2]APTREPNUM(0) = ""
    SZFCY = VALEUR
    SZCRMREP = ""
    ICRMREP = 1
    SZCRMDEF = ""
    ICRMDEF = 1
    SZDONDEF = ""
    IDONDEF = 1
    Call PARAMUTIL("CRMREPBAP", SZCRMREP, GUSER, SZFCY) From SUBAUS
    If SZCRMREP = "" Then
      ICRMREP = 1
    Else
      ICRMREP = val(SZCRMREP)
    Endif
    Call PARAMUTIL("CRMDEFREP", SZCRMDEF, GUSER, SZFCY) From SUBAUS
    If SZCRMDEF = "" Then
      ICRMDEF = 1
    Else
      ICRMDEF = val(SZCRMDEF)
    Endif
    Call PARAMUTIL("DONDEFBAP", SZDONDEF, GUSER, SZFCY) From SUBAUS
    If SZDONDEF = "" Then
      IDONDEF = 1
    Else
      IDONDEF = val(SZDONDEF)
    Endif
    #Représentant connecté prioritaire
    If ICRMREP = 2 Then
      Read [REP]REP1=GUSER
      If !fstat Then
        Raz [M:BAP2]APTREPNUM
        Raz [M:BAP2]APTREPSRV
        [M:BAP2]APTREPNUM(0) = [F:REP]REPNUM
      Endif
    Endif
    If [M:BAP0]APTCMP <> "" Then
      #Définit le représentant par défaut.
      If [M:BAP2]APTREPNUM(0) = "" Then
        Read [BPR]BPR0=[M:BAP0]APTCMP
        If !fstat Then
          If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
            Read [BPC]BPC0=[M:BAP0]APTCMP
            If !fstat Then
              If [F:BPC]REP(0) <> "" Then
                [M:BAP2]APTREPNUM(0) = [F:BPC]REP(0)
              Else
                If [F:BPC]REP(1) <> "" Then
                  [M:BAP2]APTREPNUM(0) = [F:BPC]REP(1)
                Endif
              Endif
            Endif
          Else
            [M:BAP2]APTREPNUM(0) = ""
          Endif
        Endif
      Endif
    Endif
    If ICRMDEF = 2 Then
      If [M:BAP2]APTREPNUM(0) = "" Then
        Read [REP]REP1=GUSER
        If !fstat Then
          [M:BAP2]APTREPNUM(0) = [F:REP]REPNUM
        Endif
      Endif
    Endif
    If !GIMPORT Then
      If GBAPTUNNEL = 0 Then
        #On ne vient de nulle part
        If IDONDEF = 2 Then
          #RDV effectué
          [M:BAP0]APTDON = 2
        Else
          #RDV a planifier
          [M:BAP0]APTDON = 1
        Endif
      Endif
    Endif
  Endif
  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:BAP2]1-99
  Affzo [M:BAP0]1-99
End

##########################################################################################################
Subprog AM_APTWEE(VALEUR)
Variable Decimal VALEUR
Local Integer INBDAY

  If VALEUR <> [M:BAP1]APTWEE Then
    Raz [M:BAP1]APTDAT
    Raz [M:BAP1]APTHOU
    Raz [M:BAP1]APTDATEND
    Raz [M:BAP1]APTHOUEND
    Actzo [M:BAP1]APTDUR, APTDURX
    Affzo [M:BAP1]APTDAT, APTHOU, APTDATEND, APTHOUEND, FULDAY, APTDUR
  Endif
  #Si le rdv est exprimé en semaine. La date correspondante doit toujours être un Lundi.
  INBDAY = dayn([M:BAP1]APTDATX) - 1
  [M:BAP1]APTDATX = [M:BAP1]APTDATX - INBDAY
  If VALEUR > [M:BAP1]APTWEE Then
    [M:BAP1]APTDATX = [M:BAP1]APTDATX + ((VALEUR - [M:BAP1]APTWEE) * 7)
  Else
    [M:BAP1]APTDATX = [M:BAP1]APTDATX - (([M:BAP1]APTWEE - VALEUR) * 7)
  Endif
End

##########################################################################################################
Subprog C_APTWEE(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 0 or VALEUR > 53 Then
    #Contrà´le de la validité du numéro de semaine
    GMESSAGE = mess(187,196,1)
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_APTDAT(VALEUR)
Variable Date    VALEUR

Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  If VALEUR = [00/00/00] Then
    Raz [M:BAP1]APTHOU
  Else
    If [M:BAP1]APTHOU = "" Then
      [M:BAP1]APTHOU = "0900"
    Endif
    Affzo [M:BAP1]APTHOU
    #Met à  jour le numéro de semaine avec la nouvelle date
    [M:BAP1]APTWEE = week(VALEUR)
    Affzo [M:BAP1]APTWEE
    #Met à  jour la date correspondant au numéro de semaine pour une exploitation ultérieure.
    [M:BAP1]APTDATX = VALEUR
  Endif
  #Met à  jour la durée du rendez-vous.
  SZDUR = ""
  If VALEUR <> [00/00/00] and [M:BAP1]APTHOU <> "" and [M:BAP1]APTDATEND <> [00/00/00] and [M:BAP1]APTHOUEND <> "" Then
    Call GETDUR(nday(VALEUR), [M:BAP1]APTHOU, nday([M:BAP1]APTDATEND), [M:BAP1]APTHOUEND, SZDUR) From CRM_UTIL
    [M:BAP1]APTDUR = SZDUR
  Else
    [M:BAP1]APTDUR = ""
  Endif
  # Grise le champs Durée du RDV
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDUR
  Affzo [M:BAP1]APTDURX
End

##########################################################################################################
Subprog AM_APTPLC(VALEUR)
Variable Integer    VALEUR()
Local Char SZNULL

  SZNULL = ""
  Call FILAPPPLC(VALEUR, 1, SZNULL) From SUBBAPB
  [M:BAP3]APTPLC = VALEUR
  Affzo [M:BAP3]APTPLC
End

##########################################################################################################
Subprog IB_APTCMP

  # FGR 05/04/2011 : X3SUIVI72615
  GBOUT1 = [M:BAP0]APTCMPLIB
  If [M:BAP0]APTCMPAOB = "BPR" Then
    Raz GBOUT3
  Endif
  Call IB_NOTECHECK([M:BAP0]APTCMP,"CRM",4)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog AM_APTCMP(VALEUR)
Variable Char    VALEUR()
Local Char SZTYP
Local Char SZNUM
Local Integer INBLIG
Local Char SZFNC
Local Integer IFNC
Local Integer BAPNOL

  BAPNOL = 0
  SZTYP = ""
  SZNUM = ""
  IFNC = 0
  #Définit l'adresse par défaut du rendez-vous
  If [M:BAP3]APTPLC = 1 Then
    Call FILAPPPLC([M:BAP3]APTPLC, 0, VALEUR) From SUBBAPB
  Endif
  #Définit l'interlocuteur par défaut du rendez-vous
  Raz [M:BAP1]APTCCNNUM
  Raz [M:BAP1]APTCOR
  Raz [M:BAP1]APTCCNCLA
  Raz [M:BAP1]NBLIGCCN
  Call GETDEFCNT(VALEUR, [M:BAP1]APTCCNNUM(0)) From CRMUTIL140
  If [M:BAP1]APTCCNNUM(0) <> "" Then
    #Affichage de l'interlocuteur
    [M:BAP0]APTCMP = VALEUR      # FGR 23/03/2011 : X3SUIVI71451
    Gosub DISPCCN From SUBBAPB
    [M:BAP1]NBLIGCCN = 1
  Endif
  #Définit le représentant et le site par défaut.
  If [M:BAP2]APTREPNUM(0) = "" Then
    Read [BPR]BPR0=VALEUR
    If !fstat Then
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        Read [BPC]BPC0=VALEUR
        If !fstat Then
          If [F:BPC]REP(0) <> "" Then
            Raz [M:BAP2]APTREPNUM
            Raz [M:BAP2]APTREPSRV
            [M:BAP2]APTREPNUM(0) = [F:BPC]REP(0)
            Call CHKDUPREP([M:BAP2]APTREPNUM(0))
          Else
            If [F:BPC]REP(1) <> "" Then
              Raz [M:BAP2]APTREPNUM
              Raz [M:BAP2]APTREPSRV
              [M:BAP2]APTREPNUM(0) = [F:BPC]REP(1)
              Call CHKDUPREP([M:BAP2]APTREPNUM(0))
            Endif
          Endif
        Endif
      Else
        [M:BAP2]APTREPNUM(0) = ""
      Endif
    Endif
  Endif
  #Affiche le nom en clair du tiers sélectionné.
  [M:BAP0]APTCMPCLA = [F:BPR]BPRNAM
  #Affiche le type du tiers sélectionné.
  Call AFFICHE_BCK_TIERS(VALEUR) From SUBBAPB
  #Affichage de la fonction des représentants
  [M:BAP2]NBLIGREP = 0
  For INBLIG = 0 To dim([M:BAP2]APTREPNUM)-1
    If [M:BAP2]APTREPNUM(INBLIG) = "" Then
      Break
    Endif
    Read [REP]REP0=[M:BAP2]APTREPNUM(INBLIG)
    If fstat Then
      [M:BAP2]APTREPSRV(0) = ""
    Else
      If [F:REP]AUSNUM = "" Then
        Call TEXTE(2929, [M:BAP2]APTREPSRV(INBLIG)) From OBJDIV      #Représentant
      Else
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        If IFNC = 1 Then
          Call TEXTE(2929, [M:BAP2]APTREPSRV(INBLIG)) From OBJDIV      #Représentant
        Else
          [M:BAP2]APTREPSRV(0) = mess(val(SZFNC),3022,1)
        Endif
      Endif
    Endif
    [M:BAP2]NBLIGREP += 1
  Next
  #Utilisation ou non du site du représentant
  Call SITECRMREP("ACT", [M:BAP2]APTREPNUM(0), [M:BAP0]SALFCY) From CRM_UTIL
  GFCY = [M:BAP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  [M:BAP0]APTCMP = VALEUR
  Affzo [M:BAP0]1-99
  Affzo [M:BAP1]1-99
  Affzo [M:BAP2]1-99
  Affzo [M:BAP3]1-99
End

##########################################################################################################
Subprog AM_APTRER(VALEUR)
Variable Char    VALEUR()

  Call LECTURE_RESRES (nolign-1, VALEUR) # FGR 24/07/2009 : X3SUIVI56702
  [M:BAP5]APTRER(nolign-1) = VALEUR
  # FGR 22/10/2009 : X3SUIVI59070
  #Affzo [M:BAP5]RSS(nolign-1), APTRER(nolign-1), RERSTRDAT(nolign-1), RERSTRHOU(nolign-1), RERENDDAT(nolign-1), RERENDHOU(nolign-1), RSSREP(nolign-1)
  Affzo [M:BAP5]APTRER(nolign-1), RERSTRDAT(nolign-1), RERSTRHOU(nolign-1), RERENDDAT(nolign-1), RERENDHOU(nolign-1), RSSREP(nolign-1)
End

##########################################################################################################
Subprog AS_NBRER
End

##########################################################################################################
Subprog C_NBRER
Local Integer NUMLIGNE
Local Integer ITER

  NUMLIGNE = 0
  If status = 65 Then
    #Effacement d'une seule ligne
    If !find([M:BAP5]APTRER(nolign-1), [M:BAP0]APTRERDEL) Then
      For ITER = 0 To dim([M:BAP0]APTRERDEL)-1
        If [M:BAP0]APTRERDEL(ITER) = "" Then
          [M:BAP0]APTRERDEL(ITER) = [M:BAP5]APTRER(nolign-1)
          Break
        Endif
      Next
    Endif
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      If !find([M:BAP5]APTRER(NUMLIGNE), [M:BAP0]APTRERDEL) Then
        For ITER = 0 To dim([M:BAP0]APTRERDEL)-1
          If [M:BAP0]APTRERDEL(ITER) = "" Then
            [M:BAP0]APTRERDEL(ITER) = [M:BAP5]APTRER(NUMLIGNE)
            Break
          Endif
        Next
      Endif
    Next
  Endif
End

##########################################################################################################
Subprog AM_APTREPNUM(VALEUR)
Variable Char    VALEUR()
Local Char SZFNC
Local Integer IFNC

  SZFNC = ""
  IFNC = 0
  If nolign-1 = 0 Then
    #Utilisation ou non du site du représentant
    Call SITECRMREP("ACT", VALEUR, [M:BAP0]SALFCY) From CRM_UTIL
    GFCY = [M:BAP0]SALFCY
    Call GETDEV(GFCY) From DEVSUB
    Affzo [M:BAP0]SALFCY
  Endif
  If VALEUR = "" Then
    [M:BAP2]APTREPSRV(nolign-1) = ""
  Else
    Read [REP]REP0=VALEUR
    If fstat Then
      [M:BAP2]APTREPSRV(nolign-1) = ""
    Else
      If [F:REP]AUSNUM = "" Then
        Call TEXTE(2929, [M:BAP2]APTREPSRV(nolign-1)) From OBJDIV      #Représentant
      Else
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        If IFNC = 1 Then
          Call TEXTE(2929, [M:BAP2]APTREPSRV(nolign-1)) From OBJDIV      #Représentant
        Else
          [M:BAP2]APTREPSRV(nolign-1) = mess(val(SZFNC),3022,1)
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULDAY(VALEUR)
Variable Integer VALEUR

Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  If VALEUR = 2 Then
    If [M:BAP1]APTDAT = [00/00/00] Then
      [M:BAP1]APTDAT = date$
    Endif
    [M:BAP1]APTDATEND = [M:BAP1]APTDAT
    [M:BAP1]APTHOU = "0900"
    [M:BAP1]APTHOUEND = "1800"
    [M:BAP1]APTDUR = "0900"
    #Met à  jour le numéro de semaine avec la nouvelle date
    [M:BAP1]APTWEE = week([M:BAP1]APTDAT)
    [M:BAP1]APTDATX =[M:BAP1]APTDAT
  Endif
  #Met à  jour la durée du rendez-vous.
  SZDUR = ""
  If [M:BAP1]APTDAT <> [00/00/00] and [M:BAP1]APTHOU <> "" and [M:BAP1]APTDATEND <> [00/00/00] and [M:BAP1]APTHOUEND <> "" Then
    Call GETDUR(nday([M:BAP1]APTDAT), [M:BAP1]APTHOU, nday([M:BAP1]APTDATEND), [M:BAP1]APTHOUEND, SZDUR) From CRM_UTIL
    [M:BAP1]APTDUR = SZDUR
  Else
    [M:BAP1]APTDUR = ""
  Endif
  # Grise le champs Durée du RDV
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDUR
  Affzo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDAT, APTHOU, APTDATEND, APTHOUEND, APTDUR
End

##########################################################################################################
Subprog AM_APTDATEND(VALEUR)
Variable Date    VALEUR

Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  #Met à  jour la durée du rendez-vous.
  SZDUR = ""
  If [M:BAP1]APTDAT <> [00/00/00] and [M:BAP1]APTHOU <> "" and  VALEUR <> [00/00/00] and [M:BAP1]APTHOUEND <> "" Then
    Call GETDUR(nday([M:BAP1]APTDAT), [M:BAP1]APTHOU, nday(VALEUR), [M:BAP1]APTHOUEND, SZDUR) From CRM_UTIL
    [M:BAP1]APTDUR = SZDUR
  Else
    [M:BAP1]APTDUR = ""
  Endif
  # Grise le champs Durée du RDV
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDUR
  Affzo [M:BAP1]APTDURX
End

##########################################################################################################
Subprog AM_APTHOUEND(VALEUR)
Variable Char    VALEUR()

Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  #Met à  jour la durée du rendez-vous.
  SZDUR = ""
  If [M:BAP1]APTDAT <> [00/00/00] and [M:BAP1]APTHOU <> "" and [M:BAP1]APTDATEND <> [00/00/00] and VALEUR <> "" Then
    Call GETDUR(nday([M:BAP1]APTDAT), [M:BAP1]APTHOU, nday([M:BAP1]APTDATEND), VALEUR, SZDUR) From CRM_UTIL
    [M:BAP1]APTDUR = SZDUR
  Else
    [M:BAP1]APTDUR = ""
  Endif
  # Grise le champs Durée du RDV
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDUR
  Affzo [M:BAP1]APTDURX
End

##########################################################################################################
Subprog AM_APTHOU(VALEUR)
Variable Char    VALEUR()

Local Char SZDUR(type([M:BAP1]APTDUR)-10)  # FGR 02/04/2013 : X3SUIVI88542 longueur chaîne

  #Met à  jour la durée du rendez-vous.
  SZDUR = ""
  If [M:BAP1]APTDAT <> [00/00/00] and VALEUR <> "" and [M:BAP1]APTDATEND <> [00/00/00] and [M:BAP1]APTHOUEND <> "" Then
    Call GETDUR(nday([M:BAP1]APTDAT), VALEUR, nday([M:BAP1]APTDATEND), [M:BAP1]APTHOUEND, SZDUR) From CRM_UTIL
    [M:BAP1]APTDUR = SZDUR
  Else
    [M:BAP1]APTDUR = ""
  Endif
  # Grise le champs Durée du RDV
  Grizo [M:BAP1]APTDUR
  Grizo [M:BAP1]APTDURX
  Affzo [M:BAP1]APTDUR
  Affzo [M:BAP1]APTDURX
End

##########################################################################################################
