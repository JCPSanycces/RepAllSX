#<AdxTL>@(#)9.0.0.0 $Revision$
# TS 08/10/2009 : Lot D04
# UUTC023  Maj code actité WRH et suppression WRE

  Call MAJ_UUTC023(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UUTC023(APPLI)
End

########################################################################
Subprog MAJ_UUTC023(DOSSIER)
Value Char DOSSIER

  If DOSSIER <> GDOSX3 Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Maj code activité WRH et WRE") From DOSSUB
  #------------------------------------------------------
  Call MAJ_UTITC23(DOSSIER) From UTITC23
  Call ECR_TIME("FIN => Maj code activité WRH et WRE") From DOSSUB
  #------------------------------------------------------
End
