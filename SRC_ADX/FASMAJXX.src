#<AdxTL>@(#)3.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#############################################################
#
# Moulinette de migration en V8 du module Immobilisation
#  CBO   28.11.2014  FQ104360  : Undo a linked expense when balance sht val is changed

# --> Change ATBDIV 611 (family) in an object FAM
#  MDJ   05.03.2015  FQ101861/9   : Change ATBDIV 604 (building) in an object BUI
#
#############################################################

Subprog FASMAJXX

  Call OUVRE_TRACE("FASMAJXX") From LECFIC
  Call ECR_TRACE("Start FASMAJXX on" - [F:ADS]DOSSIER, 0) From GESECRAN

  # change ATBDIV 611 (family) in an object FAM
  Gosub MAJ_FAM_611

  # change ATBDIV 604 (building) in an object BUI
  Gosub MAJ_BUI_604

  # change LOCALIZAT in PHYLOC
  Gosub MAJ_LOCATION

  # initialize flag FLGDETEXP
  Gosub MAJ_LAYOUTFAS # FQ104360

  Call ECR_TRACE("End FASMAJXX",0) From GESECRAN
  Call FERME_TRACE() From LECFIC

End
################################################################

########################################
#
# change ATBDIV 611 (family) in an object FAM
#
########################################

$MAJ_FAM_611

Local Integer N_FAM_DEPART, N_FAM_CRT, N_FAM_EXIST

  Call ECR_TRACE("Change ATBDIV 611 (family) in an object FAM", 0) From GESECRAN

  If clalev([F:ADI])
    Close File  [ADI]
  Endif
  Local File =[F:ADS]DOSSIER + ".ATABDIV" [ADI]

  If clalev([F:ADV])
    Close File  [ADV]
  Endif
  Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]

  If clalev([F:AXX2])
    Close File  [AXX2]
  Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

  If clalev([F:AXX3])
    Close File  [AXX3]
  Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX3]

  If clalev([F:FAM])
    Close File  [FAM]
  Endif
  Local File =[F:ADS]DOSSIER + ".FASFAM" [FAM]


  GOK = 1
  Raz N_FAM_CRT, N_FAM_DEPART, N_FAM_EXIST
  Onerrgo ERR_FAM611

  Trbegin [ADI]
  For [F:ADI]CODE Where NUMTAB = 611

    N_FAM_DEPART += 1
    [F:FAM]FAMREF  = [F:ADI]CODE
    [F:FAM]GFY  = [F:ADI]SOC

    If GLEGACT = G_OUI
      [F:FAM]LEG     = [F:ADI]LEG
    Else
      [F:FAM]LEG     = ""
    Endif

    For [F:AXX2]AXX0 Where CODFIC = "ATABDIV" and (ZONE = "LNGDES" or ZONE = "SHODES") and IDENT1 = num$(611) and IDENT2 = [F:ADI]CODE
      [F:AXX3] = [F:AXX2]
      [F:AXX3]CODFIC = "FASFAM"
      If [F:AXX2]ZONE = "LNGDES"
        [F:AXX3]ZONE   = "FAMDES"
      Else
        [F:AXX3]ZONE   = "SHODES"
      Endif
      [F:AXX3]LANGUE = [F:AXX2]LANGUE
      [F:AXX3]LANORI = [F:AXX2]LANORI
      [F:AXX3]IDENT1 = [F:FAM]FAMREF
      [F:AXX3]IDENT2 = ""
      [F:AXX3]TEXTE = [F:AXX2]TEXTE

      Write [F:AXX3]
    Next

    Write [F:FAM]
    If fstat = 3  # already exists
      N_FAM_EXIST += 1
    Elsif fstat
      GOK = 0
      Call ECR_TRACE("Error writing [FASFAM] <" + [F:FAM]FAMREF + "> fstat=" + num$(fstat), 1) From GESECRAN
      Break
    Else
      N_FAM_CRT += 1
    Endif
  Next

  If GOK # and 1111 = 2222
    Delete [F:AXX2] Where CODFIC="ATABDIV" and IDENT1=num$(611)
    Delete [F:ADI]  Where NUMTAB=611
    Delete [F:ADV]  Where NUMTAB=611
  Endif


  If GOK
    Commit
  Else
    Rollback
  Endif

  #Infbox num$(N_FAM_DEPART) - "families (611) and" - num$(N_FAM_CRT) - "created +" - num$(N_FAM_EXIST) - "exist in FASFAM"
  Onerrgo

  Call ECR_TRACE("From" - num$(N_FAM_DEPART) - "families in 611 ATABDIV", 0) From GESECRAN
  Call ECR_TRACE(num$(N_FAM_CRT) - "accounting groups created in FASFAM", 0) From GESECRAN
  Call ECR_TRACE(num$(N_FAM_EXIST) - "accounting groups already exist in FASFAM", 0) From GESECRAN


  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of Change ATBDIV 611 (family) in an object FAM", 0) From GESECRAN

Return

$ERR_FAM611
    GOK = 0
Resume
################################################################

###################################################
#
# change ATBDIV 604 (building) in an object BUI
#
###################################################
$MAJ_BUI_604

Local Integer N_BUI_TO_MIGRAT
Local Integer N_BUI_CRT
Local Integer N_BUI_EXIST
Local Char    SVLANGUE(10)

  Call ECR_TRACE("Change ATBDIV 604 (building) in an object BUI", 0) From GESECRAN

  If clalev([F:ADI]) :   Close File  [ADI] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABDIV" [ADI]

  If clalev([F:ADV]) :   Close File  [ADV] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]

  If clalev([F:AXX2]) :  Close File  [AXX2] :  Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

  If clalev([F:BUI]) :   Close File  [BUI] :   Endif
  Local File =[F:ADS]DOSSIER + ".BUILDING" [BUI]

  GOK = 1
  Raz N_BUI_CRT
  Raz N_BUI_TO_MIGRAT
  Raz N_BUI_EXIST

  SVLANGUE = GLANGUE

  Onerrgo ERR_BUI604

  Trbegin [ADI]
  #---------------------------------
  For [F:ADI]CODE Where NUMTAB = 604
    N_BUI_TO_MIGRAT += 1
    [F:BUI]BUICOD  = [F:ADI]CODE
    For [F:AXX2]AXX0 Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and IDENT1 = num$(604) and IDENT2 = [F:ADI]CODE
      GLANGUE = [F:AXX2]LANGUE
      Call MAJTEXTRA([F:AXX2]TEXTE, "BUILDING", "BUIDES", [F:BUI]BUICOD, "") From ATEXTRA
    Next
    #------------
    Write [F:BUI]
    If fstat = 3  # already exists
        N_BUI_EXIST += 1
    Elsif fstat
        GOK = 0
        Call ECR_TRACE("Error writing [BUILDING] <" + [F:BUI]BUICOD + "> fstat=" + num$(fstat), 1) From GESECRAN
        Break
    Else
        N_BUI_CRT += 1
    Endif
  Next
  #---------------------------------
  GLANGUE = SVLANGUE

  If GOK # and 1=0
    Delete [F:AXX2] Where CODFIC="ATABDIV" and IDENT1=num$(604)
    Delete [F:ADI]  Where NUMTAB=604
    Delete [F:ADV]  Where NUMTAB=604
  Endif

  If GOK
    Commit
  Else
    Rollback
  Endif

  Onerrgo

  Call ECR_TRACE("From" - num$(N_BUI_TO_MIGRAT) - " Buildings in 604 ATABDIV", 0) From GESECRAN
  Call ECR_TRACE("        "- num$(N_BUI_CRT) -  " Buildings created in BUILDING table", 0) From GESECRAN
  Call ECR_TRACE("        "- num$(N_BUI_EXIST)- " Building already exist in BUILDING table", 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of Change ATABDIV 604 (BUILDING) in an object BUI", 0) From GESECRAN

Return

$ERR_BUI604
    GLANGUE = SVLANGUE
Resume
################################################################

########################################
#
# # change LOCALIZAT in PHYLOC
#
########################################
$MAJ_LOCATION

    Call ECR_TRACE("# change LOCALIZAT table in PHYLOC", 0) From GESECRAN

    Local Integer N_BUI_DEPART, N_BUI_CRT, N_BUI_EXIST

    If clalev([F:LOC])
        Close File  [LOC]
    Endif
    Local File =[F:ADS]DOSSIER + ".LOCALIZAT" [LOC]

    If clalev([F:LCT])
        Close File  [LCT]
    Endif
    Local File =[F:ADS]DOSSIER + ".PHYLOC" [LCT]

    If clalev([F:AXX2])
        Close File  [AXX2]
    Endif
    Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

    GOK = 1
    Raz N_BUI_CRT, N_BUI_DEPART, N_BUI_EXIST
    Onerrgo ERR_LOCATION


    Trbegin [LOC]
    For [F:LOC]LOC0

        N_BUI_DEPART += 1

        [F:LCT]LCTCOD   = [F:LOC]LOCCOD
        [F:LCT]BUICOD   = [F:LOC]LOCBUI
        [F:LCT]FLOOR    = [F:LOC]LOCFLO
        [F:LCT]BAC      = [F:LOC]LOCBAC
        [F:LCT]DFLFLG   = [V]CST_ANO
        [F:LCT]FCY      = [F:LOC]LOCIVYFCY

        For I = 0 To [F:ADS]NBRLAN - 1
          [F:AXX2]CODFIC = "PHYLOC"
          [F:AXX2]ZONE   = "LCTDES"
          [F:AXX2]LANGUE = [F:ADS]LAN(I)
          [F:AXX2]IDENT1 = [F:LCT]LCTCOD
          [F:AXX2]IDENT2 = ""
          [F:AXX2]TEXTE  = [F:LOC]LOCDES
          Write [AXX2]
        Next I

        Write [F:LCT]
        If fstat = 3  # already exists
            N_BUI_EXIST += 1
        Elsif fstat
            GOK = 0
            Call ECR_TRACE("Error writing [LOCATION] <" + [F:LCT]LCTCOD + "> fstat =" - num$(fstat), 1) From GESECRAN
            Break
        Else
            N_BUI_CRT += 1
        Endif
    Next

#    If GOK :
#        Delete [F:LOC]
#    Endif

    If GOK
        Commit
    Else
        Rollback
    Endif

    Infbox num$(N_BUI_DEPART) - "LOCALIZAT and" - num$(N_BUI_CRT) - "created +" - num$(N_BUI_EXIST) - "exist in PHYLOC"
    Onerrgo

    Call ECR_TRACE("From" - num$(N_BUI_DEPART) - "LOCALIZAT", 0) From GESECRAN
    Call ECR_TRACE(num$(N_BUI_EXIST) - "already exist in LOCALIZAT and" - num$(N_BUI_CRT) - "are created", 0) From GESECRAN


    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("End of change LOCALIZAT table in PHYLOC", 0) From GESECRAN

Return

$ERR_LOCATION
Resume
################################################################

$MAJ_LAYOUTFAS

    Call ECR_TRACE("# Initialize FLGDETEXP in LAYOUTFAS table", 0) From GESECRAN

    If clalev([F:LOF])
        Close File  [LOF]
    Endif
    Local File =[F:ADS]DOSSIER + ".LAYOUTFAS" [LOF]

    GOK = 1
    Onerrgo ERR_LAYOUTFAS

    Trbegin [LOF]
    Update [LOF] Where FLGDETEXP = 0 With FLGDETEXP = 2

    If GOK
        Commit
    Else
        Rollback
    Endif
    Onerrgo

    Call ECR_TRACE(num$(adxuprec) - "updated enreg. in LAYOUTFAS", 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("End of change in LAYOUTFAS table", 0) From GESECRAN

Return

$ERR_LAYOUTFAS
    GOK = 0
Resume
