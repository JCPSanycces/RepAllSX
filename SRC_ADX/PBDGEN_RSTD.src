#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]AMETHOD
#      Endcase
#Endcase
Return


$PROPERTIES
Case [L]CURPRO
 When "CSTAYES" : Gosub CSTAYES
 When "CSTANO" : Gosub CSTANO
Endcase
Return

  # SAM # 111399 changed ACTION to ARULE
$CSTAYES
 Case [L]ARULE
   When "GET"         : Gosub GET_CSTAYES
Endcase
Return
  # SAM # 111399 changed ACTION to ARULE
$CSTANO
 Case [L]ARULE
   When "GET"         : Gosub GET_CSTANO
Endcase
Return

$GET_CSTAYES
   this.CSTAYES=[V]CST_AYES
Return

$GET_CSTANO
   this.CSTANO=[V]CST_ANO
Return

