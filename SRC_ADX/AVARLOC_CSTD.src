#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure AVARLOC

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
      When "AINSERT"                : Gosub AINSERT
      When "AUPDATE"                : Gosub AUPDATE
      When "ADELETE"                : Gosub ADELETE
    Endcase
  When "COLAVR"
    Case [L]AEVENT
      When "AREAD_AFTER"   : Gosub AVARLOCD_AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
When "TYP"    : Gosub TYP
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



##############################################################################################
$TYP
Case [L]ARULE
    When "PROPAGATE"     : Gosub TYP_PROPAGATE
Endcase
Return

$TYP_PROPAGATE
Gosub TYP_MANDATORY
Return

##############################################################################################
$AREAD
  Local File AVARLOC [AVR]
  Local Integer ILINE

  For [AVR] Where [F:AVR]TYP=this.TYP and [F:AVR]FCT=this.FCT
    ILINE = fmet this.ADDLINE("COLAVR",CST_ALASTPOS)
    [L]ASTATUS = fmet this.COLAVR(ILINE).AREAD([F:AVR]TYP,[F:AVR]FCT,[F:AVR]COD)
    Break [L]ASTATUS>=[V]CST_AERROR
  Next
  Gosub TYP_MANDATORY

Return

$AINSERT
Gosub TYP_MANDATORY
# Loop on every line that has to be created
  For ILINE=1 To maxtab(this.COLAVR)
    If this.COLAVR(ILINE)<>null
      If this.COLAVR(ILINE).ASTALIN = CST_ANEW
        this.COLAVR(ILINE).TYP = this.TYP
        this.COLAVR(ILINE).FCT = this.FCT
        [L]ASTATUS = fmet this.COLAVR(ILINE).AINSERT()
        Break ([L]ASTATUS>=[V]CST_AERROR)
      Endif
    Endif
  Next
Return


$AUPDATE
Local Integer ILINE
# Delete the lines
  For ILINE= 1 To maxtab(this.COLAVR)
    If this.COLAVR(ILINE)<>null
      If this.COLAVR(ILINE).ASTALIN = [V]CST_ADEL
        this.COLAVR(ILINE).TYP = this.TYP
        this.COLAVR(ILINE).FCT = this.FCT
        [L]ASTATUS = fmet this.COLAVR(ILINE).ADELETE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
      Endif
    Endif
  Next

# Update the lines
  For ILINE= 1 To maxtab(this.COLAVR)
    If this.COLAVR(ILINE)<>null
      If this.COLAVR(ILINE).ASTALIN = [V]CST_AUPD
        this.COLAVR(ILINE).TYP = this.TYP
        this.COLAVR(ILINE).FCT = this.FCT
        [L]ASTATUS = fmet this.COLAVR(ILINE).AUPDATE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
      Endif
    Endif
  Next

# Insert the lines
  For ILINE= 1 To maxtab(this.COLAVR)
    If this.COLAVR(ILINE)<>null
      If this.COLAVR(ILINE).ASTALIN = [V]CST_ANEW
        this.COLAVR(ILINE).TYP = this.TYP
        this.COLAVR(ILINE).FCT = this.FCT
        [L]ASTATUS = fmet this.COLAVR(ILINE).AINSERT()
        Break [L]ASTATUS>=[V]CST_AERROR
      Endif
    Endif
  Next
Return

#####################################################################################################
$ADELETE
Local Integer ILINE
  For ILINE= 1 To maxtab(this.COLAVR)
    If !find(this.COLAVR(ILINE).ASTALIN, [V]CST_ANEWDEL, [V]CST_ANEW)
      If this.COLAVR(ILINE)<>null
        [L]ASTATUS = fmet this.COLAVR(ILINE).ADELETE()
        Break [L]ASTATUS>=[V]CST_AERROR
      Endif
    Endif
  Next
Return

#####################################################################################################
$AVARLOCD_AREAD_AFTER
  # Assign ASTALIN to CST_ALL (they have the value 'CST_ANEW' just after AREAD method)
  this.ASTALIN = [V]CST_ALL
Return

##############################################################################################
$TYP_MANDATORY
Local Integer MY_STATUS
If this.TYP=2
  [L]MY_STATUS = fmet this.ASETATTRIBUTE("FCT", "$isMandatory", "true")
Else
  [L]MY_STATUS = fmet this.ASETATTRIBUTE("FCT", "$isMandatory", "false")
Endif
Return

