#<AdxTL>@(#)3.0.0.0 $Revision$
# Issue X3-64203 - 2017-11-27 by FHA : Trade name 2 of the BP
Raz GPILOBJ
Call OBJET("BIC",GBIDC1,GBIDC2) From GOBJET
End

# Gestion du masque ADRFACREG
#######################################################################
# Etiquettes ACTION                                                   #
#######################################################################
#--- Actions liés au type fenêtre de saisie
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "TITRE"         : Gosub TITLE
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "OK"            : Gosub OK
 When "ABA"           : Gosub ABA
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################

$OUVRE
Case GACTION
 When "SAIADR"  : Gosub OUV_SAIADR
Endcase
Return

$DEBUT
Case GACTION
 When "SAIADR"  : Gosub DEB_SAIADR
Endcase
Return

$TITLE
Case GACTION
 When "SAIADR"  : Gosub TIT_SAIADR
Endcase
Return

$OK
Case GACTION
 When "SAIADR"  : Gosub OK_SAIADR
Endcase
Return

$ABA
Case GACTION
 When "SAIADR"  : Gosub ABA_SAIADR
Endcase
Return

$APRES_MODIF
Case GACTION
 When "SAIADR"  : REP = "M"
                  If zoncou <> "BPAADD" and dim([M:AFR]ADRVAL) > 0 & [M:AFR]ADRVAL <>  1 : [M:AFR]ADRVAL = 1 : Affzo [M:AFR]ADRVAL : Endif #LTA.n
Endcase
Return

#####################################################################
# SAIADRBPR    : Saisie de l'adresse                                #
# ----------------------------------------------------------------- #
# FACREG: Numéro du type d'adresse                                  #
#         1 = Adresse Facture en saisie facture                     #
#         2 = Adresse Règlement en saisie facture                   #
#         3 = Adresse Règlement en saisie règlement                 #
# NUMT  : Numéro du tiers dont l'adresse est à saisir               #
# MSG   : Numéro du message pour titre de la fenêtre                #
#         0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
# CHAP  : Numéro de chapitre du message pour titre de la fenêtre    #
#         0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
# ----------------------------------------------------------------- #
#####################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIADR
Local Integer  FACREG : FACREG=val(PARAM(1))
Local Char     NUMT   : NUMT  =PARAM(2)
Local Integer  MSG    : MSG   =val(PARAM(3))
Local Integer  CHAP   : CHAP  =val(PARAM(4))
Local Integer  CLIFOU : CLIFOU=val(PARAM(5))
#Infbox num$(FACREG)-NUMT-num$(MSG)-num$(CHAP)-num$(CLIFOU)

#----- Variables locales pour sauvegarde du masque -----#
Local Char     BPRNAM(GLONNAM)(2)
Local Char     BPAADD(3)
Local Char     BPAADDLIG(GLONADL)(3)
Local Char     CRY(GLONCRY)
Local Char     CRYNAM(GLONNCY)
Local Char     SAT(GLONSAT)
Local Char     POSCOD(GLONPOS)
Local Char     CTY(GLONCTY)

#------ Ouverture des fichiers si besoin ------#
If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif

#------ Contrôle validité des paramètres ------#
If (NUMT="" & FACREG<>3) | (NUMT="" & FACREG=3 & [M:PAY1]ACC="") : # Saisie règlement sur compte
 # Aucun tiers n'est précisé. Action abandonnée.
 Call MESSAGE(mess(156,177,1)) From GESECRAN
 FIN=1 : Return
Endif
If MSG=0 | CHAP=0  MSG=4 : CHAP=195 : Endif

Local Integer BPRTYPBIS : BPRTYPBIS = 0
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TIT_SAIADR
TIT=mess(MSG,CHAP,1)
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIADR
Raz [M:AFR]

[M:AFR]AFRBPR=NUMT

Case FACREG
 When 1 : # Facture
  Gosub CHARGE_ADR_FAC
 When 2 : # Règlements
  Gosub CHARGE_ADR_REG
 When 3 : # Règlement
  Gosub CHARGE_ADR_REG2
Endcase

#----- Raz masque et lecture BPARTNER si nécessaire -----#
If [M:AFR]AFRBPR<>NUMT  Raz [M:AFR] : Endif
If [F:BPR]BPRNUM<>NUMT
  Read [BPR]BPR0=NUMT : If fstat  Raz [F:BPR] : Endif
Endif

#----- Read the account address when no partner is captured -----#
If NUMT="" & FACREG=3 & [M:AFR]BPAADDLIG(0)="" & [M:AFR]BPAADDLIG(1)="" & [M:AFR]BPAADDLIG(2)=""
&& [M:AFR]POSCOD="" & [M:AFR]SAT="" & [M:AFR]CTY=""
 Read [GAC]GAC0=GPLAN(1);[M:PAY1]ACC
 If !fstat & [M:AFR]BPAADD="" : [M:AFR]BPAADD=[F:GAC]BPAADD : Endif : # Ce cas ne devrait pas se produire
 Read [BPA]BPA0=5;GPLAN(1)+[M:PAY1]ACC;[M:AFR]BPAADD
 If fstat
  Raz [F:BPA]
 Else
  Call LECTEXTRA([M:AFR]BPRNAM(0),"GACCOUNT","DESTRA",GPLAN(1),[M:PAY1]ACC) From ATEXTRA
  [M:AFR]BPRNAM(1)    = GPLAN(1)+[M:PAY1]ACC
  [M:AFR]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AFR]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AFR]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AFR]CRY          = [F:BPA]CRY
  [M:AFR]CRYNAM       = [F:BPA]CRYNAM
  [M:AFR]SAT          = [F:BPA]SAT
  [M:AFR]POSCOD       = [F:BPA]POSCOD
  [M:AFR]CTY          = [F:BPA]CTY
 Endif
Endif

If NUMT<>"" & FACREG=3 & [M:AFR]BPAADDLIG(0)="" & [M:AFR]BPAADDLIG(1)="" & [M:AFR]BPAADDLIG(2)=""
&& [M:AFR]POSCOD="" & [M:AFR]SAT="" & [M:AFR]CTY=""
 Read [BPA] BPA0=1;NUMT;[M:AFR]BPAADD
 If fstat  Raz [F:BPA] : Endif
 [M:AFR]AFRBPR       = [F:BPR]BPRNUM
 [M:AFR]BPRNAM(0)    = [F:BPR]BPRNAM(0)
 [M:AFR]BPRNAM(1)    = [F:BPR]BPRNAM(1)
 [M:AFR]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
 [M:AFR]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
 [M:AFR]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
 [M:AFR]CRY          = [F:BPA]CRY
 [M:AFR]CRYNAM       = [F:BPA]CRYNAM
 [M:AFR]SAT          = [F:BPA]SAT
 [M:AFR]POSCOD       = [F:BPA]POSCOD
 [M:AFR]CTY          = [F:BPA]CTY
Endif

#----- Lecture de l'adresse si nécessaire -----#
If [M:AFR]BPAADD=""
 [M:AFR]BPAADD=[F:BPR]BPAADD
 Read [BPA] BPA0=1;NUMT;[M:AFR]BPAADD
 If fstat  Raz [F:BPA] : Endif
 [M:AFR]AFRBPR       = [F:BPR]BPRNUM
 [M:AFR]BPRNAM(0)    = [F:BPR]BPRNAM(0)
 [M:AFR]BPRNAM(1)    = [F:BPR]BPRNAM(1)
 [M:AFR]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
 [M:AFR]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
 [M:AFR]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
 [M:AFR]CRY          = [F:BPA]CRY
 [M:AFR]CRYNAM       = [F:BPA]CRYNAM
 [M:AFR]SAT          = [F:BPA]SAT
 [M:AFR]POSCOD       = [F:BPA]POSCOD
 [M:AFR]CTY          = [F:BPA]CTY
 If dim([M:AFR]ADRVAL) > 0 : [M:AFR]ADRVAL = [F:BPA]ADRVAL : Endif  #LTA.n
Endif

#LTA.sn
# If func AFNC.ACTIV("LTA") and dim([M:AFR]VALADR) > 0 and (FACREG <> 1 or GLOCUSATAX = 0 or !func TRTADRLIB.CHKADR_CRY([M:AFR]CRY))   # 106867.so
#  Chgfmt [M:AFR]VALADR With "-K:3X"
#  Chgfmt [M:AFR]ADRVAL With "-K:10X"   # 106867.eo
If func AFNC.ACTIV("LTA") and dim([M:AFR]VALADR) > 0 and (FACREG <> 1 or CLIFOU <> 1 or [F:CPY]SSTTAXACT <> 2 or !func TRTADRLIB.CHKADR_CRY([M:AFR]CRY))   # 106867.sn
  Chgfmt [M:AFR]VALADR With "-K:10X"
  Chgfmt [M:AFR]ADRVAL With "-LA:1"   # 106867.en
Endif
#LTA.en

#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:AFR]

Affzo [M:AFR]

If FACREG=3 & clalev([F:TPY])>0 & dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2
 Grizo [M:AFR]
Else
 Actzo [M:AFR]
Endif

If FACREG=3
Call BPRTYP([M:AFR]AFRBPR,BPRTYPBIS) From SUBAFR
If [L]BPRTYPBIS=0 : Diszo [M:AFR]BPRNAM : Endif
Else
 Call BPRTYPFAC([M:AFR]AFRBPR,BPRTYPBIS,CLIFOU) From SUBAFR
 If [L]BPRTYPBIS=0 : Diszo [M:AFR]BPRNAM : Endif
Endif
Return

#---------------------------------------------------#
# Chargement de l'adresse Facture en saisie facture #
#---------------------------------------------------#
$CHARGE_ADR_FAC
Case CLIFOU
 When 1 : # Client
  [M:AFR]BPAADD = [M:BIC0]BPAINV
  [M:AFR]=[M:BIC0]
  [M:AFR]BPRNAM(0)=[M:BIC0]BPRNAMBIS(0)
  [M:AFR]BPRNAM(1)=[M:BIC0]BPRNAMBIS(1)
  If [F:BPC]BPCTYP <> 2
   Diszo [M:AFR]BPRNAM
  Else
   Actzo [M:AFR]BPRNAM
  Endif
  If [M:BIC1]STA =3
   Diszo [M:AFR]
  Endif
 When 2 : # Fournisseur
  Call LECTURE("BPS",[M]AFRBPR,"") From CONTOBJ
  [M:AFR]BPAADD = [M:BIS0]BPAINV
  [M:AFR]=[M:BIS0]
  [M:AFR]BPRNAM(0)=[M:BIS0]BPRNAMBIS(0)
  [M:AFR]BPRNAM(1)=[M:BIS0]BPRNAMBIS(1)
  If [F:BPS]BPSTYP <> 3
   Diszo [M:AFR]BPRNAM
  Else
   Actzo [M:AFR]BPRNAM
  Endif
  If [M:BIS1]STA =3
   Diszo [M:AFR]
  Endif
Endcase
Return


#-----------------------------------------------------#
# Chargement de l'adresse Reglement en saisie facture #
#-----------------------------------------------------#
$CHARGE_ADR_REG
Case CLIFOU
 When 1 : # Client
  Call LECTURE("BPC",[M]AFRBPR,"") From CONTOBJ
  # Si le Tiers est de type Divers alors adresse payeur est = adresse facture du mask
  If [F:BPC]BPCTYP = 2
   [M:AFR]BPAADD       = [M:BIC1]BPAPAY
   [M:AFR]BPRNAM (0)   = [M:BIC0]BPRNAMBIS(0)
   [M:AFR]BPRNAM (1)   = [M:BIC0]BPRNAMBIS(1)
   [M:AFR]BPAADDLIG(0) = [M:BIC0]BPAADDLIG(0)
   [M:AFR]BPAADDLIG(1) = [M:BIC0]BPAADDLIG(1)
   [M:AFR]BPAADDLIG(2) = [M:BIC0]BPAADDLIG(2)
   [M:AFR]CRY          = [M:BIC0]CRY
   [M:AFR]CRYNAM       = [M:BIC0]CRYNAM
   [M:AFR]SAT          = [M:BIC0]SAT
   [M:AFR]POSCOD       = [M:BIC0]POSCOD
   [M:AFR]CTY          = [M:BIC0]CTY
   Diszo [M:AFR]BPAADD, BPRNAM
  Else
   [M:AFR]BPAADD = [M:BIC1]BPAPAY
   [M:AFR]BPRNAM (0)   = [M:BIC1]BPYNAM(0)
   [M:AFR]BPRNAM (1)   = [M:BIC1]BPYNAM(1)
   Diszo [M:AFR]BPRNAM
   Filter[DUD] Where ACCNUM=[F:SIH]ACCNUM & (FLGCLE=2 | FLGCLE=4)
   Read [DUD]DUD6 First
   Filter[DUD]
   If !fstat
    Diszo [M:AFR]BPAADD
   Endif
   Read [BPA]BPA0 = 1;NUMT;[M:AFR]BPAADD
   If fstat
    Raz [F:BPA]
   Else
    [M:AFR] = [F:BPA]
   Endif
  Endif
 When 2 : # Fournisseur
  Call LECTURE("BPS",[M]AFRBPR,"") From CONTOBJ
  # Si le Tiers est de type Divers alors adresse payeur est = adresse facture saisie (celle du mask BIS0)
  If [F:BPS]BPSTYP = 3
   [M:AFR]BPAADD       = [M:BIS1]BPAPAY
   [M:AFR]BPRNAM (0)   = [M:BIS0]BPRNAMBIS(0)
   [M:AFR]BPRNAM (1)   = [M:BIS0]BPRNAMBIS(1)
   [M:AFR]BPAADDLIG(0) = [M:BIS0]BPAADDLIG(0)
   [M:AFR]BPAADDLIG(1) = [M:BIS0]BPAADDLIG(1)
   [M:AFR]BPAADDLIG(2) = [M:BIS0]BPAADDLIG(2)
   [M:AFR]CRY          = [M:BIS0]CRY
   [M:AFR]CRYNAM       = [M:BIS0]CRYNAM
   [M:AFR]SAT          = [M:BIS0]SAT
   [M:AFR]POSCOD       = [M:BIS0]POSCOD
   [M:AFR]CTY          = [M:BIS0]CTY
   Diszo [M:AFR]BPAADD, BPRNAM
  Else
   [M:AFR]BPAADD = [M:BIS1]BPAPAY
   [M:AFR]BPRNAM (0)   = [M:BIS1]BPYNAM(0)
   [M:AFR]BPRNAM (1)   = [M:BIS1]BPYNAM(1)
   Diszo [M:AFR]BPRNAM
   Filter[DUD] Where ACCNUM=[F:SIH]ACCNUM & (FLGCLE=2 | FLGCLE=4)
   Read [DUD]DUD6 First
   Filter[DUD]
   If !fstat
    Diszo [M:AFR]BPAADD
   Endif
   Read [BPA]BPA0 = 1;NUMT;[M:AFR]BPAADD
   If fstat
    Raz [F:BPA]
   Else
    [M:AFR] = [F:BPA]
   Endif
  Endif
Endcase
Diszo CRY,CRYNAM,BPAADDLIG,SAT,POSCOD,CTY
Return

#-------------------------------------------------------#
# Chargement de l'adresse Reglement en saisie règlement #
#-------------------------------------------------------#
$CHARGE_ADR_REG2
# Adresse en saisie règlement
[M:AFR]=[M:PAY1]
[M:AFR]BPRNAM(0)=[M:PAY1]BPRNAM
Raz [M:AFR]BPRNAM(1)
# Issue X3-64203
If [F:BPR]BPRNUM<>""
  [M:AFR]BPRNAM(1)=[F:BPR]BPRNAM(1)
Elsif [M:PAY1]ACC<>""
  [M:AFR]BPRNAM(1)=GPLAN(1)+[M:PAY1]ACC
Endif
# End issue X3-64203
[M:AFR]BPAADD = [M:PAY1]BPAINV
Affzo [M:AFR]
Return

Subprog BPRTYP(AFRBPR,BPRTYP)
Value    Char AFRBPR()
Variable Integer BPRTYP

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Call LECTURE("BPR",[L]AFRBPR,"") From CONTOBJ
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
[L]BPRTYP=0
#si tiers four. et client cde adr depend sns=recette=2 alors client sns=depense=1 alors four.
If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=2
 If [F:TPY]SNS=2
  Call LECTURE("BPC",[L]AFRBPR,"")  From CONTOBJ
  If [F:BPC]BPCTYP = 2
   [L]BPRTYP=1  #Customer divers
  Endif
 Elsif [F:TPY]SNS=1
  Call LECTURE("BPS",[L]AFRBPR,"")  From CONTOBJ
  If [F:BPS]BPSTYP = 3
   [L]BPRTYP=2 #Supplier divers
  Endif
 Endif
Elsif [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2
 Call LECTURE("BPC",[L]AFRBPR,"")  From CONTOBJ
 If [F:BPC]BPCTYP = 2
  [L]BPRTYP=1  #Customer divers
 Endif
Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2
 Call LECTURE("BPS",[L]AFRBPR,"")  From CONTOBJ
 If [F:BPS]BPSTYP = 3
  [L]BPRTYP=2 #Supplier divers
 Endif
Endif
End

Subprog BPRTYPFAC(AFRBPR,BPRTYP,CLIFOU)
Value    Char AFRBPR()
Variable Integer BPRTYP
Value    Integer CLIFOU

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Call LECTURE("BPR",[L]AFRBPR,"") From CONTOBJ
[L]BPRTYP=0
If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=2
 If CLIFOU=1
  Call LECTURE("BPC",[L]AFRBPR,"")  From CONTOBJ
  If [F:BPC]BPCTYP = 2
   [L]BPRTYP=1  #Customer divers
  Endif
 Elsif CLIFOU=2
  Call LECTURE("BPS",[L]AFRBPR,"")  From CONTOBJ
  If [F:BPS]BPSTYP = 3
   [L]BPRTYP=2 #Supplier divers
  Endif
 Endif
Elsif CLIFOU=1 & [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2
 Call LECTURE("BPC",[L]AFRBPR,"")  From CONTOBJ
 If [F:BPC]BPCTYP = 2
  [L]BPRTYP=1  #Customer divers
 Endif
Elsif CLIFOU=2 & [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2
 Call LECTURE("BPS",[L]AFRBPR,"")  From CONTOBJ
 If [F:BPS]BPSTYP = 3
  [L]BPRTYP=2 #Supplier divers
 Endif
Endif
End

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIADR
#LTA.sn - Check if address customer invoice's billing address has been validated when local taxing is applicable
# If FACREG=1 and CLIFOU = 1 and GLOCUSATAX and dim([M:AFR]ADRVAL) > 0 and [M:AFR]ADRVAL <> 2 and func AFNC.ACTIV("LTA") and func TRTADRLIB.CHKADR_CRY([M:AFR]CRY)   # 106867.o
If FACREG=1 and CLIFOU = 1 and [F:CPY]SSTTAXACT = 2 and dim([M:AFR]ADRVAL) > 0 and [M:AFR]ADRVAL <> 2 and func AFNC.ACTIV("LTA") and func TRTADRLIB.CHKADR_CRY([M:AFR]CRY)   # 106867.n
  Local Integer WOK : WOK = 2
  Call VALADRFF_CLICK() From TRTADRLIB  # Try to validate the address
  If [M:AFR]ADRVAL <> 2
    If func TRTADRLIB.CHKADR_MANDATORY()
      WOK = 1  # Address validation mandatory, so don't let them leave
    Else
      Call AVERTIR(mess(61,115,1), WOK) From GESECRAN # Do they want to leave despite address validation failure
    Endif
    If WOK=1
      FIN=0
      Return
    Endif
  Endif
Endif
#LTA.en
#----- Récupération de l'adresse modifiée dans l'écran d'adresse d'origine -----#
Case FACREG
 When 1 : #--Invoice
  Case CLIFOU
   When 1 : # Customer
   [M:BIC0]BPAINV = [M:AFR]BPAADD
   [M:BIC0]=[M:AFR]
   Affzo [M:BIC0]
   [M:BIC0]BPRNAMBIS(0)=[M:AFR]BPRNAM(0)
   [M:BIC0]BPRNAMBIS(1)=[M:AFR]BPRNAM(1)
   [M:BIC0]BPRNAM(0)   =[M:AFR]BPRNAM(0)
   When 2 : # Supplier
   [M:BIS0]BPAINV = [M:AFR]BPAADD
   [M:BIS0]=[M:AFR]
   [M:BIS0]BPRNAMBIS(0)=[M:AFR]BPRNAM(0)
   [M:BIS0]BPRNAMBIS(1)=[M:AFR]BPRNAM(1)
   [M:BIS0]BPRNAM(0)   =[M:AFR]BPRNAM(0)
   Affzo [M:BIS0]
   #If Misc supplier then also modify the code address BPAPAY
   If [F:BPS]BPSTYP = 3
    [M:BIS1]BPAPAY = [M:AFR]BPAADD
    Affzo [M:BIS1]BPAPAY
   Endif
  Endcase

 When 2 : #--Payment
  Case CLIFOU
   When 1 : # Customer
    [M:BIC1]BPAPAY       = [M:AFR]BPAADD
    [M:BIC1]BPYNAM(0)    = [M:AFR]BPRNAM(0)
    [M:BIC1]BPYNAM(1)    = [M:AFR]BPRNAM(1)
    [M:BIC1]BPYADDLIG(0) = [M:AFR]BPAADDLIG(0)
    [M:BIC1]BPYADDLIG(1) = [M:AFR]BPAADDLIG(1)
    [M:BIC1]BPYADDLIG(2) = [M:AFR]BPAADDLIG(2)
    [M:BIC1]BPYCRY       = [M:AFR]CRY
    [M:BIC1]BPYCRYNAM    = [M:AFR]CRYNAM
    [M:BIC1]BPYSAT       = [M:AFR]SAT
    [M:BIC1]BPYPOSCOD    = [M:AFR]POSCOD
    [M:BIC1]BPYCTY       = [M:AFR]CTY
    Affzo [M:BIC1]
   When 2 : # Supplier
    [M:BIS1]BPAPAY       = [M:AFR]BPAADD
    [M:BIS1]BPYNAM(0)    = [M:AFR]BPRNAM(0)
    [M:BIS1]BPYNAM(1)    = [M:AFR]BPRNAM(1)
    [M:BIS1]BPYADDLIG(0) = [M:AFR]BPAADDLIG(0)
    [M:BIS1]BPYADDLIG(1) = [M:AFR]BPAADDLIG(1)
    [M:BIS1]BPYADDLIG(2) = [M:AFR]BPAADDLIG(2)
    [M:BIS1]BPYCRY       = [M:AFR]CRY
    [M:BIS1]BPYCRYNAM    = [M:AFR]CRYNAM
    [M:BIS1]BPYSAT       = [M:AFR]SAT
    [M:BIS1]BPYPOSCOD    = [M:AFR]POSCOD
    [M:BIS1]BPYCTY       = [M:AFR]CTY
    Affzo [M:BIS1]
  Endcase

 When 3 : #--Adresse en saisie règlement
  [M:PAY1]BPAINV = [M:AFR]BPAADD
  [M:PAY1]=[M:AFR]
  [M:PAY1]BPRNAM = [M:AFR]BPRNAM(0)
  Affzo [M:PAY1]
Endcase
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIADR
[M:AFR]=[L] : REP=""
Affzo [AFR]1-99
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADRFACREG) 24/12/2007 11:20:58 (JHA) ##
######################################################################################

Subprog S_BPAADD(VALEUR)
#---------------------------#
# Sélection du code adresse #
#---------------------------#
Variable Char    VALEUR()
Local    Integer TYP : TYP=1
Call SELADR(TYP,AFRBPR,BPRNAM,VALEUR) From TRTX3
If VALEUR="" VALEUR=BPAADD : mkstat=1 : Endif
End

Subprog C_BPAADD(VALEUR)
#-----------------------#
# Contrôle code adresse #
#-----------------------#
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]BPAADD
 If [M]AFRBPR<>""
  Read [BPA] BPA0=1;AFRBPR;VALEUR
 Else
  Read [BPA] BPA0=5;GPLAN(1)+[M:PAY1]ACC;VALEUR
 Endif
 If fstat
  # Adresse inexistante
  GMESSAGE = mess(10,119,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_BPAADD(VALEUR)
#------------------------------------#
# Après modification du code adresse #
#------------------------------------#
Variable Char    VALEUR()
[M:AFR]BPAADD      =[F:BPA]BPAADD
[M:AFR]BPAADDLIG(0)=[F:BPA]BPAADDLIG(0)
[M:AFR]BPAADDLIG(1)=[F:BPA]BPAADDLIG(1)
[M:AFR]BPAADDLIG(2)=[F:BPA]BPAADDLIG(2)
[M:AFR]CRY         =[F:BPA]CRY
[M:AFR]CRYNAM      =[F:BPA]CRYNAM
[M:AFR]SAT         =[F:BPA]SAT
[M:AFR]POSCOD      =[F:BPA]POSCOD
[M:AFR]CTY         =[F:BPA]CTY
If dim([M:AFR]ADRVAL) > 0 : [M:AFR]ADRVAL = [F:BPA]ADRVAL : Endif #LTA.n
Gosub SHOWHIDE_ADRVAL              #LTA.n
Affzo [M:AFR]
End

Subprog AM_CRY(VALEUR)
#-------------------------------------#
# Après modification du code pays     #
# Chargement et affichage nom du pays #
#-------------------------------------#
Variable Char    VALEUR()
If !clalev([AXX]) : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = "TABCOUNTRY";"CRYDES";GLANGUE;VALEUR;""
If !fstat : [M:AFR]CRYNAM=[F:AXX]TEXTE : Endif
Affzo [M:AFR]CRYNAM
[M:AFR]CRY=VALEUR   #LTA.sn
Gosub SHOWHIDE_ADRVAL  #LTA.en
End

#LTA.sn
$SHOWHIDE_ADRVAL
# If func AFNC.ACTIV("LTA") and GLOCUSATAX and func TRTADRLIB.CHKADR_CRY([M:AFR]CRY)  #LTA.sn  # 106867.o and display defect here
If GFONCTION="GESBIC" & func AFNC.ACTIV("LTA") and [F:CPY]SSTTAXACT = 2 and func TRTADRLIB.CHKADR_CRY([M:AFR]CRY)   # 106867.n
  Chgfmt [M:AFR]VALADR  With "K:10X"
  Affzo [M:AFR]VALADR # Need to execute the init action so the icon displays
  Chgfmt [M:AFR]ADRVAL  With "LA:1"
Else
  Chgfmt [M:AFR]VALADR With "-K:10X"
  Chgfmt [M:AFR]ADRVAL With "-LA:1"
Endif #LTA.en
Return
#LTA.en

Subprog AP_BPAADDLIG(VALEUR)
#-----------------------------------------------#
# Suppression des blancs en deb et fin de ligne #
#-----------------------------------------------#
Variable Char    VALEUR()
Local Integer I
For I=0 To dim([M:AFR]BPAADDLIG)-1
 [M:AFR]BPAADDLIG(I)=vireblc([M:AFR]BPAADDLIG(I),2)
Next I
End

######################################################################################
Subprog AV_SAT(VALEUR)
Variable Char    VALEUR()

  If !GWEBSERV Then
    If GFMT<>"" Then
      Chgfmt [M:AFR]SAT With "K:"+GFMT
    Else
      Chgfmt [M:AFR]SAT With "-K:1X"
    Endif
  Endif
End


