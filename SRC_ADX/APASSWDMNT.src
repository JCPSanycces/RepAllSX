#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char VALEUR(GLONADD) , PARAM(250)(1..3)
Call SAISIE_CHAR(VALEUR,PARAM,"APASSWDMNT","APASSWDMNT","") From GSAISIE
Infbox num$(mkstat)
End

#-----------------------------------#
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "END"   : PARAM(2) = "" : mkstat = 1
 When "OK"    : PARAM(2) = [M]MOTIF
Endcase
Return

#-----------------------------------#
$OUVRE
Local Integer K , M , ER
Local Char    DOSSIER(GDIMFIC) , USER(GLONAUS) , MOTIF(GLONADI)
If PARAM(1)<>""
 DOSSIER = PARAM(1)
Else
 DOSSIER = nomap
Endif
MOTIF   = PARAM(2)
If dim(PARAM)>=3 & PARAM(3)<>""
 USER = PARAM(3)
Else
 USER = GUSER
Endif
If (func AFNC.PARAMUTIL("ASIGMNT","","")<>"2" or GADONIX=2)
 FIN = 1 : Return
Endif
If DOSSIER=nomap
 Local File AUTILIS [AUS]
Else
 Local File =DOSSIER+".AUTILIS" [AUS]
Endif
Return

#-----------------------------------#
$DEBUT
Raz [M]
[M]DOSSIER = DOSSIER
[M]MOTIF   = MOTIF
Affzo DOSSIER
If USER<>""
 Call CONTROLE("AUS","",USER,"",mkstat) From CONTOBJ
 If !mkstat
  [M]USER = USER
  Affzo USER
  zonsui = "PASSE"
 Endif
Else
 [M]USER = GUSER
Endif
GMESSAGE = ""
Return

#-----------------------------------#
Subprog CONTPAS(DOSSIER,USER,OK)
Value Char DOSSIER , USER
Variable Integer OK
OK = 0
If DOSSIER=nomap & USER=GUSER
 OK = 1
Elsif DOSSIER<>nomap & USER=GUSER
 Read [AUS]CODUSR=USER
 If !fstat
  Local File AUTILIS [AUS2]
  Read [AUS2]CODUSR=USER
  If !fstat
   If [F:AUS2]NEWPAS<>"" & [F:AUS]NEWPAS<>""
    If [F:AUS2]NEWPAS=[F:AUS]NEWPAS
     OK = 1
    Endif
   Elsif [F:AUS2]PASSE<>""
    If [F:AUS2]PASSE=[F:AUS]PASSE
     OK = 1
    Endif
   Endif
  Endif
 Endif
Endif
End

#-------------------------------------------------#
Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Char    MOTPASSE(24) , MESSAGE(80)
Local Integer OK , ASTAT
Read [AUS]CODUSR = [M]USER
MOTPASSE = VALEUR
ASTAT = func ANUPAS.DAT_PASSWD([M]DOSSIER,[M]USER,MOTPASSE,MESSAGE)
If ASTAT<>CST_AOK
 GMESSAGE = MESSAGE
 mkstat = 2 : End
Endif
Call CTLPAS(MOTPASSE,OK) From GESUSER
If !OK
 GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
 mkstat  = 2 : End
Endif
End

