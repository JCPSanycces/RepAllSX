#################################################################
# MDJ - 11/08/2010 FQ 60276
# Alimentation du code plan à partir du référentiel dans la table CONTEXT
#################################################################
 Call PATCH(nomap)   
End 
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

 If filinfo(filpath("FIL","CONTEXT","fde",PAPPLI),0)<=0
  End
 Else
  Call EXE_MAJ_COA(PAPPLI)
 Endif

End
Call OUVRE_TRACE("Update context with plan code") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
  Call PATCH(nomap)
End
#######################################################################
# Pour exécution depuis intégration de patch
########################################################################
Subprog PATCH(PAPPLI)
  Value Char PAPPLI
  Local Char FICHIER(250)
  
 If PAPPLI=GDOSX3  End : Endif
 
  FICHIER=filpath("FIL","CONTEXT","fde",PAPPLI)
 If filinfo(FICHIER,0) < 0 :   End
 Else
  Call EXE_MAJ_COA(PAPPLI)
 Endif 

End

#-------------------------------------------------------------
# Initialisation du champ COA pour chaque plan du contexte
#-------------------------------------------------------------
Subprog EXE_MAJ_COA (LDOSSIER)
Value Char LDOSSIER

# FQ 60276
# Initialisation de la zone dimensionnée : code plan
# pour chaque plan d'amortissement du contexte

Call ECR_TRACE("UTIMAJCNXCOA : Process Start on : "+LDOSSIER,0) From GESECRAN

#----- Variables locales -----#
Local Integer NBENR : NBENR=0
Local Char RCOA

GOK=1
#-----
Call ECR_TRACE("UTIMAJCNXCOA : Update accounting plan on CONTEXT table "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If !clalev([F:CNX]) : Local File  =LDOSSIER+".CONTEXT" [CNX] : Endif  # définition des contextes

#-------------------------------#
#   mise a jour table CONTEXT   #
#-------------------------------#
Trbegin [CNX]

For [CNX]
   For I = 1 To [F:CNX]NBPLC  
      If  [F:CNX]COA(I-1)=""
         Call LECPLAN([F:CNX]CPY,[F:CNX]LEDTYP(I-1),RCOA) From CPTDIV  
         If RCOA <> ""
           [F:CNX]COA(I-1) = RCOA 
         Endif
      Endif 
   Next I 
   Rewrite [CNX]
   NBENR+=1
Next

$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif
#----- Fin du traitement -----#
Close Local File [CNX]
Call ECR_TRACE("UTIMAJCNXCOA : "-num$(NBENR)-"RECORD PROCESSED",0) From GESECRAN

End
#######################################################################

