Subprog ESSLTABAL()
Local Char ORG_FONCTION(30)
Local Integer FROM_ESSHRLTA
Local Integer INCL_SUBTYPE
[L]FROM_ESSHRLTA = 2
[L]ORG_FONCTION= GFONCTION

GFONCTION = "CONSLTA"
Gosub GET_BALANCES  From SUBHRLTA
GFONCTION = ORG_FONCTION

#Calculating the totals for ESS Balances
  #FRLAA X3-112532 2018-10-15 START
  #Only store and total values
  Local Char PREVTIM(GLONTPS), CURTIM(GLONTPS)
  Local Integer X
  For nolign = 1 To [M:HRLTA2]NBLIG
    [L]CURTIM = [M:HRLTA2]LVEACCTIM(nolign-1)
    If [L]CURTIM <> [L]PREVTIM : X+=1 : Endif

    [M:HRLTA2]BALTIM(X-1)     =   [M:HRLTA2]LVEACCTIM(nolign-1)
    [M:HRLTA2]BALDES(X-1)     =   [M:HRLTA2]LVETIMDES(nolign-1)
    [M:HRLTA2]BALBAL(X-1)     +=  [M:HRLTA2]LVEBALANC(nolign-1)
    [M:HRLTA2]BALTAKCYC(X-1)  +=  [M:HRLTA2]LVETAKCYC(nolign-1)
    [M:HRLTA2]BALPLAN(X-1)    +=  [M:HRLTA2]LVEPLANNE(nolign-1)
    [M:HRLTA2]BALFUTPEN(X-1)  +=  [M:HRLTA2]LVEFUTPEN(nolign-1)
    [M:HRLTA2]BALHISPEN(X-1)  +=  [M:HRLTA2]LVEHISPEN(nolign-1)

    [L]PREVTIM = [M:HRLTA2]LVEACCTIM(nolign-1)
  Next
  [M:HRLTA2]NBLIGN = X

#Check if the subtypes are still needed
  [L]X=[M:HRLTA2]NBLIG
  For nolign = 1 To [M:HRLTA2]NBLIG
    Read [TIM]TIM0 = [M:HRLTA1]LEG;[M:HRLTA2]LVEACCTIM(nolign-1)
    If !fstat
      If [F:TIM]DSPSUBTYP <> 2
        Dela nolign-1 [M:HRLTA2]NBLIG
        [L]X-=1
      Endif
    Else
      Dela nolign-1 [M:HRLTA2]NBLIG
       [L]X-=1
    Endif
  Next
[M:HRLTA2]NBLIG = X

  Affzo [M:HRLTA2]
  #FRLAA X3-112532 2018-10-15 END

End


Subprog ESSLTATRN
Local Char ORG_FONCTION(30)
ORG_FONCTION= GFONCTION

GFONCTION = "CONSLTA"
Gosub GET_SYSTEM_TRANSACTIONS From SUBHRLTA
GFONCTION = ORG_FONCTION



End

