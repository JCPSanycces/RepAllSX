#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask management ESSLTA4
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Global Integer BALANCE_GRID_ROWS, TRANSACTION_GRID_ROWS, TRANSACTION_SUB_GRID_ROWS, SYSTEM_TRANSACTIONS_GRID_ROWS
Global Char GLMCYCLESTR(250)
Global Date GLMCYCLE

If !clalev([F:DEMCONGE])  : Local File DEMCONGE   [DCG]  : Endif
If !clalev([F:ACCRU]) : Local File HRLVEACCRU    [ACCRU] : Endif
If !clalev([F:HRHEA]) : Local File HRLVESUBHEA  [HRHEA] : Endif
If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif

Gosub OUVRE From WPDEFTABLE

Return

$DEBUT
Raz [M:HRLTA1]
Raz [M:HRLTA2]
Raz [M:HRLTA3]
Raz [M:HRLTA4]

#Save parameter values
If PARAM(1) = "" #Employee code - set from logged in user
  PARAM(1) = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Endif

[M:HRLTA1]REFNUM1 = PARAM(1)
[M:HRLTA1]CTRNUM =  PARAM(2)
If [M:HRLTA1]CTRNUM <> ""
  Call C_CTRNUM([M:HRLTA1]CTRNUM)
Endif

[M:HRLTA1]FILDAT =  PARAM(4)
If [M:HRLTA1]FILDAT = [0/0/0] : [M:HRLTA1]FILDAT = datesyst : Endif


[M:HRLTA2]LVEACTONLY = 2
[M:HRLTA3]LVEACTONL = 2
[M:HRLTA3]LVECYCLEO = 2
[M:HRLTA4]LVEACTONL4 = 2
[M:HRLTA4]LVECYCLEO4 = 2

Affzo [M:HRLTA1]1-99
Affzo [M:HRLTA2]1-99
Affzo [M:HRLTA3]1-99
Affzo [M:HRLTA4]1-99

Return

$OK
Return


