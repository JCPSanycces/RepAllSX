#<AdxTL>@(#)4.0.0.0 $Revision$
#####################################################################################
#                                       Module Ventes - Decembre 2006               #
#                                                                                   #
#                 CONSULTATIONS GRAPHIQUES COMMANDES                                #
#                                                                                   #
#####################################################################################
#                                                                                   #
#                                                                                   #
#            Commandes par période                                                  #
#            ---------------------                                                  #
# GACTION  : TRTGRHSOH1 : Sélections                                                #
#            (Fenêtre : DGRHSOH1)                                                   #
#            (Ecran   : SGRHSOH1 DIA)                                               #
#            VISUGRHSO1 : Montant HT / Catégorie                                    #
#            (Fenêtre : IGRHSOH1)                                                   #
#            (Ecran   : SGO1    SGO1)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par catégorie=1)                     #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            VISUGRHSO3 : Montant HT / Statut                                       #
#            (Fenêtre : IGRHSOH3                                                    #
#            (Ecran   : SGO3    SGO3)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par statut=2)                        #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Palmarès Commandes                                                     #
#            ------------------                                                     #
# GACTION  : TRTGRHSOH2 : Sélections                                                #
#            (Fenêtre : DGRHSOH2)                                                   #
#            (Ecran   : SGRHSOH2 DIA)                                               #
#            VISUGRHSO2 : Palmarès                                                  #
#            (Fenêtre : IGRHSOH2)                                                   #
#            (Ecran   : SGO2    SGO2)                                               #
#            (Param ABREV   : Abrév du masque contenant les critères)               #
#            (Param TYPTIERS: Type de graphique (palmarès clt=1 ou représentant=2)  #
#            (Param DATDEB  : Date début)                                           #
#            (Param DATFIN  : Date fin)                                             #
#                                                                                   #
#                                                                                   #
#####################################################################################
# Prérequis VISUGRHSO1 et 2 et 3 : Le masque contenant les critères doit être ouvert#
#####################################################################################
#####################################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION
            When "TRTGRHSOH1"  :  Gosub OUVRE_TRTGRHSOH
            When "VISUGRHSO1"  :  Gosub OUVRE_VISUGRHSO1
            When "VISUGRHSO3"  :  Gosub OUVRE_VISUGRHSO1
            When "TRTGRHSOH2"  :  Gosub OUVRE_TRTGRHSOH
            When "VISUGRHSO2"  :  Gosub OUVRE_VISUGRHSO2
        Endcase
    When "DEBUT"          :
        Case GACTION
            When "TRTGRHSOH1"  :  Gosub DEBUT_TRTGRHSOH1
            When "VISUGRHSO1"  :  Gosub DEBUT_VISUGRHSO1
            When "VISUGRHSO3"  :  Gosub DEBUT_VISUGRHSO1
            When "TRTGRHSOH2"  :  Gosub DEBUT_TRTGRHSOH2
            When "VISUGRHSO2"  :  Gosub DEBUT_VISUGRHSO2
        Endcase
    When "TITRE"
        Case GACTION
            When "VISUGRHSO1"  :  Gosub TIT_VISUGRHSO1
            When "VISUGRHSO3"  :  Gosub TIT_VISUGRHSO1
            When "VISUGRHSO2"  :  Gosub TIT_VISUGRHSO2
        Endcase
    When "SETBOUT"          :
        Case GACTION
            When "TRTGRHSOH2"  :  Gosub SETB_TRTGRHSOH2
        Endcase
    When "BOUTON"
        Case GACTION
            When "TRTGRHSOH1"  :  Gosub BOUT_TRTGRHSOH
            When "TRTGRHSOH2"  :  Gosub BOUT_TRTGRHSOH
            When "VISUGRHSO1"  :  Gosub BOUT_VISUGRHSO1
            When "VISUGRHSO3"  :  Gosub BOUT_VISUGRHSO1
            When "VISUGRHSO2"  :  Gosub BOUT_VISUGRHSO2
        Endcase
    When "FIN"
        Case GACTION
            When "VISUGRHSO1"  :  Gosub FIN_VISUGRHSO1
            When "VISUGRHSO3"  :  Gosub FIN_VISUGRHSO1
            When "VISUGRHSO2"  :  Gosub FIN_VISUGRHSO2
        Endcase
    When Default
Endcase
Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSOH1                       #
#                                TRTGRHSOH2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_TRTGRHSOH

Gosub OUVRE

Return
###################################################################
###################################################################
$OUVRE

If clalev([F:SOH])=0 Local File SORDER     [SOH]  : Endif
If clalev([F:SOQ])=0 Local File SORDERQ    [SOQ]  : Endif
If clalev([F:SOP])=0 Local File SORDERP    [SOP]  : Endif
If clalev([F:BPC])=0 Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:CPY])=0 Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU]  : Endif
If clalev([F:PER])=0 Local File PERIOD     [PER]  : Endif
If clalev([F:ACN])=0 Local File ACONSULT   [ACN]  : Endif

Return
###################################################################
$DEBUT

[M]SALFCY=GFCYDEF(5)
If [M]SALFCY <> "" : # Parametre Site
    If [F:FCY]FCY <> [M]SALFCY  Read [F:FCY]FCY0 = [M]SALFCY
                                If fstat Raz [F:FCY], [M]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M]SALFCY <> ""
             Call GETDEV([M]SALFCY) From DEVSUB
             [M]CPY  = GSOCIETE
        Endif
    Endif
Endif

Return
###################################################################
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSOH1                       #
#                                                                 #
#                    HT par catégorie ou par statut               #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSOH1

Raz [M:DIA]

[M]PERCOD=4         : # Init. de la périodicité au mois
[M]PERNBR=3         : # Init. du nombre de période à 3
[M]ORDDATFIN=eomonth(date$)
[M]ORDDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

[M:DIA]SOHCATNOR=2  :    # On prend les commandes normales
[M:DIA]SOHCATLND=2  :    # On prend les commandes de prêt
[M:DIA]SOHCATFAC=2  :    # On prend les commandes à facturation directe

[M:DIA]ORDSTAO=2    :    # On prend les commandes soldées
[M:DIA]ORDSTAN=2    :    # On prend les commandes non soldées

[M:DIA]APPFLGO=2    :    # On prend les commandes signées
[M:DIA]APPFLGN=2    :    # On prend les commandes non signées

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg3") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$BOUT_TRTGRHSOH

Case BOUT
    When "1", "2" :
        Affzo [M:DIA]1-99
Endcase

Return

###################################################################
#                                                                 #
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSOH2                       #
#                                                                 #
#                    Palmarès HT commandé client et représentant  #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSOH2

Raz [M:DIA]

[M]ORDDATFIN=eomonth(date$)
[M]ORDDATDEB=gdat$(01,month(addmonth(date$,-5)),year(addmonth(date$,-5)))

[M:DIA]SOHCATNOR=2  :    # On prend les commandes normales
[M:DIA]SOHCATLND=2  :    # On prend les commandes de prêt
[M:DIA]SOHCATFAC=2  :    # On prend les commandes à facturation directe

[M:DIA]ORDSTAO=2    :    # On prend les commandes soldées
[M:DIA]ORDSTAN=2    :    # On prend les commandes non soldées

[M:DIA]APPFLGO=2    :    # On prend les commandes signées
[M:DIA]APPFLGN=2    :    # On prend les commandes non signées

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg4") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
$SETB_TRTGRHSOH2

# Pas de palmarès client si la consultation n'est pas multi-client
If [M:DIA]BPCORD<>"" ETABOU(GSPE4) = 0 : Endif

# Pas de palmarès représentant si la consultation n'est pas multi-client ou si les représentants ne sont pas gérés
If [M:DIA]BPCORD<>""
    ETABOU(GSPE5) = 0
Else
    If func AFNC.ACTIV("REP")<1
        ETABOU(GSPE5) = 0
    Endif
Endif

Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSO1 VISUGRHSO3            #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSO1

Local Integer  WSAVPERCOD, WPERCOD : # Périodicité 1=jour,2=Semaine,3=Quinz.,4=Mois,5=Trimestre,6=Semestre,7=Année,8=Décade
Local Date     WSAVDATDEB, WDATDEB : # Date début
Local Date     WSAVDATFIN, WDATFIN : # Date fin
Local Integer  WSAVPERNBR, WPERNBR : # Nombre de période

Local Char     WCURS(GLONCUR)    : # Devise société
Local Char     WCURD(GLONCUR)    : # Devise dossier

Local Char     WPROGSPE(GLONADC) : # Nom du programme spécifique
Local Integer  WOK

# Variables communes avec la consultation commande
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSO")
# -- > "DIA"  : On vient de la fonction graphique montant HT commande
# -- > "CCSO" : On vient de la consultation commandes
Local Char    WABREV : WABREV=PARAM(1)
# Type de graphique
# -- > 1 : Montant HT par catégorie
# -- > 2 : Montant HT par statut
Local Integer WTYP : WTYP=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations commande
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSO"
   If !clalev([M:CSO1])  Local Mask CONSCSO1 [CSO1] : Endif
   If !clalev([M:CCSO])  Local Mask CRITCSO  [CCSO] : Endif
Endif

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #

If evalue("dim([M:"+WABREV+"]PERCOD)")>0
    WPERCOD=evalue("[M:"+WABREV+"]PERCOD")
    WSAVPERCOD=WPERCOD
Else
    WPERCOD=4
Endif
If evalue("dim([M:"+WABREV+"]ORDDATDEB)")>0
    WDATDEB=evalue("[M:"+WABREV+"]ORDDATDEB")
    WSAVDATDEB=WDATDEB
    If WPERCOD=4 WDATDEB=gdat$(01,month(WDATDEB),year(WDATDEB)) : Endif
Else
    WDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
If evalue("dim([M:"+WABREV+"]ORDDATFIN)")>0
    WDATFIN=evalue("[M:"+WABREV+"]ORDDATFIN")
    WSAVDATFIN=WDATFIN
    If WPERCOD=4 WDATFIN=eomonth(WDATFIN) Endif
Else
    WDATFIN=eomonth(date$)
Endif

If evalue("dim([M:"+WABREV+"]PERNBR)")>0
    WPERNBR=evalue("[M:"+WABREV+"]PERNBR")
    WSAVPERNBR=WPERNBR
Else
#    WPERNBR=3
    If year(WDATFIN)=year(WDATDEB)
        WPERNBR=month(WDATFIN)-month(WDATDEB)+1
    Else
        WPERNBR=13-month(WDATDEB)+month(WDATFIN)
    Endif
    WPERNBR=max(1,WPERNBR)
Endif

Gosub CHARGE_CCSO

Return
###################################################################
$TIT_VISUGRHSO1
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYP=1
    If [M:CCSO]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSO]BPCORD Endif
Else
    If [M:CCSO]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSO]BPCORD Endif
Endif

Return

###################################################################
$DEBUT_VISUGRHSO1

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M]
[M]CPY=[M:CCSO]CPY
[M]PERCOD=WPERCOD
[M]ORDDATDEB=WDATDEB
[M]ORDDATFIN=WDATFIN
[M]PERNBR=WPERNBR
[M]CURS=WCURS
[M]WTYP=WTYP

# Si la société est renseignée, le cdé HT est dans la devise société sinon il est en devise dossier
If [M:CCSO]CPY<>"" [M]CUR=[M]CURS Else [M]CUR=GSYSCUR Endif

# -- Chargement des périodes

# Test pour supprimer la colonne
#Chgfmt [M]WLNDAMT With "-Nz:0#[       ]"

Effzo [M]10
Gosub CHARGE_PERIODE_SGO1

[M:CCSO]ORDDATDEB=[M]ORDDATDEB
[M:CCSO]ORDDATFIN=[M]ORDDATFIN
Gosub ENTCRIT From WWCNSCSO    : # Charge [M:CSO1] à partir de [M:CCSO]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSOSTD
If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGO1] ou [M:SGO3]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGO1

Affzo [M]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSO1

Case BOUT
    When "R" :
        # -- Rechargement du tableau
        # -- Chargement des périodes
        Effzo [M]10
        Gosub CHARGE_PERIODE_SGO1
        [M:CCSO]ORDDATDEB=[M]ORDDATDEB
        [M:CCSO]ORDDATFIN=[M]ORDDATFIN
        Gosub ENTCRIT From WWCNSCSO    : # Charge [M:CSO1] à partir de [M:CCSO]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGO1
        Affzo [M]10
Endcase

Return
###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSO1
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
PARAM(5)=num$(WSAVPERCOD)
PARAM(6)=num$(WSAVPERNBR)
Return

###################################################################

# -------------------------------------- #
# Chargement des périodes                #
# -------------------------------------- #
$CHARGE_PERIODE_SGO1
Local Date    WDTE
Local Integer WPER, WMOIS
Local Char    WLIB
Local Integer I,WCOUNT

Effzo [M]10
WCOUNT=0

WDTE=[M]ORDDATDEB
WPER=[M]PERCOD
For I = 0 To [M]PERNBR-1
    If I > dim([M]WABS) - 1 : Break Endif
    WCOUNT+=1
    [M]WSTRDAT(I) = WDTE
#    [M]WABS(I) = format$("D:"+GFMDAT,[M]WSTRDAT(I))
    Gosub DET_PER_LIB From TRTVENGRH : [M]WABS(I)=WLIB
    Case [M]PERCOD
        When 1 : [M]WENDDAT(I) = WDTE                                 : # jour
        When 2 : [M]WENDDAT(I) = WDTE + (7-dayn(WDTE))                : # Semaine
        When 3 :                                                      : # Quinzaine
        When 4 : [M]WENDDAT(I) = eomonth([M]WSTRDAT(I))               : # Mois
        When 5 : WMOIS=month([M]WSTRDAT(I))                           : # Trimestre
                 Case WMOIS
                    When 1,2,3    : [M]WENDDAT(I)=gdat$(31,03,year([M]WSTRDAT(I)))
                    When 4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9    : [M]WENDDAT(I)=gdat$(30,09,year([M]WSTRDAT(I)))
                    When 10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 6 : WMOIS=month([M]WSTRDAT(I))                           : # Semestre
                 Case WMOIS
                    When 1,2,3,4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9,10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 7 : [M]WENDDAT(I) = gdat$(31,12,year([M]WSTRDAT(I)))     : # Année
        When 8 :                                                      : # Décade
    Endcase
    WDTE = [M]WENDDAT(I) + 1
Next I
  [M]NBLIGG=WCOUNT
Return
###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGO1

Local Decimal WNORAMT,WFACAMT,WLNDAMT
Local Decimal WCDEAMT,WODLAMT,WDLVAMT,WINVAMT,WCCLAMT
Local Decimal WDLVQTY, WNETPRINOT

Local Decimal WMNTORG(0..4), WMNTDES(0..4)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR


#-- Application des Filtres
Filter [SOH] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2)

#-- lecture
$BOUCLE_SOH1
For [SOH] With Nohint

    # Filtre sur la société
    If [M]CPY <> ""
        If [F:FCY]FCY <> [F:SOH]SALFCY  Read [F:FCY]FCY0 = [F:SOH]SALFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSO]CPY Goto SUIV_SOH1 : Endif
    Endif
    If [M]CPY="" & [M:CCSO]SALFCY=""
        Call GETDEV([F:SOH]SALFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M]CURS
    Endif
    Raz WNORAMT, WFACAMT, WLNDAMT
    Raz WCDEAMT, WODLAMT, WDLVAMT, WINVAMT, WCCLAMT

    Case WTYP
      When 1 :
        # --------------------- #
        # HT par catégorie      #
        # --------------------- #
        If [F:SOH]SOHCAT=1
          WNORAMT = [F:SOH]ORDINVNOT
        Elsif [F:SOH]SOHCAT=2
          WLNDAMT = [F:SOH]ORDINVNOT
        Elsif [F:SOH]SOHCAT=3
          WFACAMT = [F:SOH]ORDINVNOT
        Endif
      When 2 :
        # --------------------- #
        # HT par statut         #
        # --------------------- #
        # Il faut lire les lignes, les statuts de la commande ne suffisent pas
        For [F:SOQ]SOQ0 Where SOHNUM=[F:SOH]SOHNUM
            Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
            If fstat Raz [F:SOP] Endif
            # 107888 : Scheduled invoices : (LD:20/05/16)
            #If [F:SOH]SOHCAT<>3
            If [F:SOH]SOHCAT<>3 & [F:SOQ]DLVFLG=2
                # --> Commande normale/prêt et article livrable
                # 107888 : Scheduled invoices : (LD:20/05/16)
                WDLVQTY=[F:SOQ]ODLQTY + [F:SOQ]DLVQTY
            Else
                # --> Commande à facturation directe              : # 107888 : Scheduled invoices : (LD:20/05/16)
                # --> Commande normale et article non livrable    : # 107888 : Scheduled invoices : (LD:20/05/16)
                WDLVQTY=[F:SOQ]ODLQTY + [F:SOQ]INVQTY
            Endif
            If [F:SOQ]SOQSTA=3
                # On ne prend en compte la partie soldée que si on a demandé les cdes soldées
#                If [M:CCSO]ORDSTAO=2
                    # Soldé       : Soldé manuel (Soldé non livré)
                    WCCLAMT += ([F:SOQ]QTY-min(WDLVQTY,[F:SOQ]QTY))*[F:SOP]NETPRINOT
#                Endif
            Else
                # En commande : Commandé non livré
                WCDEAMT += ([F:SOQ]QTY-WDLVQTY)*[F:SOP]NETPRINOT
            Endif
            # 107888 : Scheduled invoices : (LD:20/05/16)
            #If [F:SOH]SOHCAT<>3
            If [F:SOH]SOHCAT<>3 & [F:SOQ]DLVFLG=2
                # --> Commande normale/prêt et article livrable
            # 107888 : Scheduled invoices : (LD:20/05/16)
                # En cours de livraison
                WODLAMT += [F:SOQ]ODLQTY * [F:SOP]NETPRINOT
                # Livré non facturé
                WDLVAMT += ([F:SOQ]DLVQTY-[F:SOQ]INVQTY) * [F:SOP]NETPRINOT
            Else
                # --> Commande à facturation directe              : # 107888 : Scheduled invoices : (LD:20/05/16)
                # --> Commande normale et article non livrable    : # 107888 : Scheduled invoices : (LD:20/05/16)
                # Facturé
                WINVAMT += [F:SOQ]ODLQTY * [F:SOP]NETPRINOT
            Endif
            # Facturé
            WINVAMT += [F:SOQ]INVQTY * [F:SOP]NETPRINOT
        Next
        Call ARRDEV (WCDEAMT, [F:SOH]CUR) From TRTDIV
        Call ARRDEV (WCCLAMT, [F:SOH]CUR) From TRTDIV
        Call ARRDEV (WODLAMT, [F:SOH]CUR) From TRTDIV
        Call ARRDEV (WDLVAMT, [F:SOH]CUR) From TRTDIV
        Call ARRDEV (WINVAMT, [F:SOH]CUR) From TRTDIV

        If WCDEAMT=[F:SOH]ORDNOT WCDEAMT=[F:SOH]ORDINVNOT Endif
        If WCCLAMT=[F:SOH]ORDNOT WCCLAMT=[F:SOH]ORDINVNOT Endif
        If WODLAMT=[F:SOH]ORDNOT WODLAMT=[F:SOH]ORDINVNOT Endif
        If WINVAMT=[F:SOH]ORDNOT WINVAMT=[F:SOH]ORDINVNOT Endif
    Endcase

    # Recherche de la période à laquelle appartient la commande
    For WJ=0 To [M]NBLIGG-1
        If [F:SOH]ORDDAT>=[M]WSTRDAT(WJ) & [F:SOH]ORDDAT<=[M]WENDDAT(WJ) Break Endif
    Next

    If WJ<[M]NBLIGG & WJ>=0
        # Conversion des montants calculés dans la devise d'affichage
        If [F:SOH]CUR <> [M]CUR
            Case WTYP
                When 1 :
                    WMNTORG (0) = WNORAMT
                    WMNTORG (1) = WLNDAMT
                    WMNTORG (2) = WFACAMT
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(2), WMNTDES(2),SPSTAT) From TRTDEV
                    If [F:TCU]CUR <> [M]CUR
                        Read [F:TCU]TCU0 = [M]CUR
                        If fstat Raz [F:TCU] : Endif
                    Endif
                    [M:SGO1]WNORAMT(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
                    [M:SGO1]WLNDAMT(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
                    [M:SGO1]WFACAMT(WJ) += arr(WMNTDES(2),[F:TCU]CURRND)
                When 2 :
                    WMNTORG (0) = WCDEAMT
                    WMNTORG (1) = WODLAMT
                    WMNTORG (2) = WDLVAMT
                    WMNTORG (3) = WINVAMT
                    WMNTORG (4) = WCCLAMT
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(2), WMNTDES(2),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(3), WMNTDES(3),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SOH]CUR, [M]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(4), WMNTDES(4),SPSTAT) From TRTDEV
                    If [F:TCU]CUR <> [M]CUR
                        Read [F:TCU]TCU0 = [M]CUR
                        If fstat Raz [F:TCU] : Endif
                    Endif
                    [M:SGO3]WCDEAMT(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
                    [M:SGO3]WODLAMT(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
                    [M:SGO3]WDLVAMT(WJ) += arr(WMNTDES(2),[F:TCU]CURRND)
                    [M:SGO3]WINVAMT(WJ) += arr(WMNTDES(3),[F:TCU]CURRND)
                    [M:SGO3]WCCLAMT(WJ) += arr(WMNTDES(4),[F:TCU]CURRND)
            Endcase
        Else
            Case WTYP
                When 1 :
                    [M:SGO1]WNORAMT(WJ) += WNORAMT
                    [M:SGO1]WLNDAMT(WJ) += WLNDAMT
                    [M:SGO1]WFACAMT(WJ) += WFACAMT
                When 2 :
                    [M:SGO3]WCDEAMT(WJ) += WCDEAMT
                    [M:SGO3]WODLAMT(WJ) += WODLAMT
                    [M:SGO3]WDLVAMT(WJ) += WDLVAMT
                    [M:SGO3]WINVAMT(WJ) += WINVAMT
                    [M:SGO3]WCCLAMT(WJ) += WCCLAMT
            Endcase
        Endif
    Endif

  $SUIV_SOH1
Next
Filter [SOH]

Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSO2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSO2

Local Date    WSAVDATDEB            :    # Date début
Local Date    WSAVDATFIN            :    # Date fin

Local Char    WCURS(GLONCUR)        :    # Devise société
Local Char    WCURD(GLONCUR)        :    # Devise dossier

Local Char    WPROGSPE(GLONADC)     :    # Nom du programme spécifique
Local Integer WOK

# Variables communes avec la consultation commande
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSO")
# -- > "DIA"  : On vient de la fonction graphique montant HT commande
# -- > "CCSO" : On vient de la consultation commande
Local Char WABREV : WABREV=PARAM(1)
# -- > 1 : Palmarès client
# -- > 2 : Palmarès représentant
Local Integer WTYPTIERS : WTYPTIERS=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations commande
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSO"
   If !clalev([M:CSO1])  Local Mask CONSCSO1 [CSO1] : Endif
   If !clalev([M:CCSO])  Local Mask CRITCSO  [CCSO] : Endif
Endif

WSAVDATDEB=evalue("[M:"+WABREV+"]ORDDATDEB")
WSAVDATFIN=evalue("[M:"+WABREV+"]ORDDATFIN")

Return
###################################################################
$TIT_VISUGRHSO2
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYPTIERS=1 TIT=mess(272,195,1) Else TIT=mess(273,195,1) Endif

Return

###################################################################
$DEBUT_VISUGRHSO2

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #
Gosub CHARGE_CCSO

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M:SGO2]
[M:SGO2]CPY=[M:CCSO]CPY
[M:SGO2]ORDDATDEB=[M:CCSO]ORDDATDEB
[M:SGO2]ORDDATFIN=[M:CCSO]ORDDATFIN
[M:SGO2]CURS=WCURS
[M:SGO2]WTYPTIERS=WTYPTIERS

# Si la société est renseignée, le cdé HT est dans la devise société sinon il est en devise dossier
If [M:CCSO]CPY<>"" [M:SGO2]CUR=[M:SGO2]CURS Else [M:SGO2]CUR=GSYSCUR Endif

[M:SGO2]NBRTOP=10

Gosub ENTCRIT From WWCNSCSO    : # Charge [M:CSO1] à partir de [M:CCSO]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSOSTD
# -- Palmarès représentant
# --> Il faut que le représentant 1 soit renseigné
If WTYPTIERS=2 WFIL += "&[F:SOH]REP(0)<>''" Endif

If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGO2]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M:SGO2]WFIL =WFIL
[M:SGO2]WFIL1=WFIL1
[M:SGO2]WFIL2=WFIL2

# -- Chargement des données
Gosub CHARGE_DONNEES_SGO2

Affzo [M:SGO2]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSO2

Case BOUT
    When "R" :
        # -- Chargement des données
        [M:CCSO]ORDDATDEB=[M:SGO2]ORDDATDEB
        [M:CCSO]ORDDATFIN=[M:SGO2]ORDDATFIN
        Gosub ENTCRIT From WWCNSCSO    : # Charge [M:CSO1] à partir de [M:CCSO]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGO2

        Affzo [M:SGO2]10
Endcase

Return

###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSO2
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
Return

###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGO2

Local Decimal WORDAMT,WNORDAMT,WEXYAMT
Local Decimal WMNT
Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

Local Char    WBPR
Local Integer WTOP : WTOP=[M:SGO2]NBRTOP

#Dbgaff
Effzo [M:SGO2]10
#-- Application des Filtres
Case [M:SGO2]WTYPTIERS
    When 1 :
        Filter [SOH] Where evalue([M:SGO2]WFIL) & evalue([M:SGO2]WFIL1) & evalue([M:SGO2]WFIL2)
&                    Order By Key SOH1
    When 2 :
        Filter [SOH] Where evalue([M:SGO2]WFIL) & evalue([M:SGO2]WFIL1) & evalue([M:SGO2]WFIL2)
&                    Order By Key CLE=[F:SOH]REP(0)

Endcase
#-- lecture
$BOUCLE_SOH2
For [SOH] With Nohint

    # Filtre sur la société
    If [M:SGO2]CPY <> ""
        If [F:FCY]FCY <> [F:SOH]SALFCY  Read [F:FCY]FCY0 = [F:SOH]SALFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSO]CPY Goto SUIV_SOH2 : Endif
    Endif
    If [M:SGO2]CPY="" & [M:CCSO]SALFCY=""
        Call GETDEV([F:SOH]SALFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M:SGO2]CURS
    Endif

    If WBPR=""
        If [M:SGO2]WTYPTIERS=1 WBPR=[F:SOH]BPCORD Else WBPR=[F:SOH]REP(0) Endif
        Raz WORDAMT
    Endif

    # Changement de tiers : chargement du tiers qui vient d'être traité dans le graphique
    If (WBPR<>[F:SOH]BPCORD & [M:SGO2]WTYPTIERS=1) | (WBPR<>[F:SOH]REP(0) & [M:SGO2]WTYPTIERS=2)
        If WORDAMT<>0 Gosub CHARGE_BPR Endif
        If [M:SGO2]WTYPTIERS=1 WBPR=[F:SOH]BPCORD Else WBPR=[F:SOH]REP(0) Endif
        Raz WORDAMT
    Endif
    If (WBPR=[F:SOH]BPCORD & [M:SGO2]WTYPTIERS=1) | (WBPR=[F:SOH]REP(0) & [M:SGO2]WTYPTIERS=2)
        # Même tiers traité : On cumule le montant HT cdé
        WMNT=[F:SOH]ORDINVNOT
        # Conversion des montants calculés dans la devise d'affichage
        If [F:SOH]CUR <> [M:SGO2]CUR
            WMNTORG (0) = WMNT
            Call CONVERT2([F:SOH]CUR, [M:SGO2]CUR, WCUR, [F:SOH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
            If [F:TCU]CUR <> [M:SGO2]CUR
                Read [F:TCU]TCU0 = [M:SGO2]CUR
                If fstat Raz [F:TCU] : Endif
            Endif
            WORDAMT  += arr(WMNTDES(0),[F:TCU]CURRND)
        Else
            WORDAMT  += WMNT
        Endif
    Endif

    $SUIV_SOH2
Next
Filter [SOH]

If WORDAMT<>0 Gosub CHARGE_BPR Endif
If [M:SGO2]NBLIGG>0
    If [M:SGO2]NBLIGG<WTOP
        Sorta [M:SGO2]NBLIGG [M:SGO2]NBLIGG Order By [M:SGO2]WORDAMT(indice)*-1
    Else
        [M:SGO2]WABSBPR(WTOP)=[M:SGO2]WABSBPR(WTOP+1)
        [M:SGO2]WORDAMT(WTOP)=[M:SGO2]WORDAMT(WTOP+1)
        Raz [M:SGO2]WABSBPR(WTOP+1), [M:SGO2]WORDAMT(WTOP+1)
    Endif
Endif

# Une fois le chargement terminé, il faut mettre à 0 les valeurs négatives du graph
If [M:SGO2]NBLIGG>0
    WI=[M:SGO2]NBLIGG
    While [M:SGO2]WORDAMT(WI-1)<0
        Raz [M:SGO2]WORDAMT(WI-1)
        WI-=1 : If WI=0 Break Endif
    Wend
Endif
Return

# -------------------------------------------------------------------------- #
# Chargement des valeurs du tiers (client ou représentant) dans le tableau   #
# -------------------------------------------------------------------------- #
$CHARGE_BPR
If [M:SGO2]NBLIGG<WTOP
    # On charge les 10 premiers tiers
    [M:SGO2]WABSBPR([M:SGO2]NBLIGG)=WBPR
    [M:SGO2]WORDAMT([M:SGO2]NBLIGG)=WORDAMT
    [M:SGO2]NBLIGG+=1
    If [M:SGO2]NBLIGG=WTOP
        Sorta [M:SGO2]NBLIGG [M:SGO2]NBLIGG Order By [M:SGO2]WORDAMT(indice)*-1
    Endif
Else
#Dbgaff
    # On met le tiers qui vient d'être traité en dernière position (11ème) et on trie les 11 lignes du tableau
    [M:SGO2]WABSBPR(WTOP)=WBPR
    [M:SGO2]WORDAMT(WTOP)=WORDAMT
    Sorta WTOP+1 [M:SGO2]NBLIGG Order By [M:SGO2]WORDAMT(indice)*-1
    # On bascule le dernier tiers (11ème) dans la position Autres (12ème position)
    [M:SGO2]WABSBPR(WTOP+1)=mess(20,127,1)
    [M:SGO2]WORDAMT(WTOP+1)+=[M:SGO2]WORDAMT(WTOP)
    Raz [M:SGO2]WABSBPR(WTOP), [M:SGO2]WORDAMT(WTOP)
    [M:SGO2]NBLIGG=WTOP+1
Endif

Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSO1 VISUGRHSO3            #
#                                VISUGRHSO2                       #
#                                                                 #
###################################################################
# -------------------------------------------------------------------------- #
# Chargement systématique des écrans consultations commande                  #
# --> Pour pouvoir exploiter l'action FILTRE spécifique                      #
# --> Pour pouvoir évaluer   les filtres depuis les actions champs           #
# -------------------------------------------------------------------------- #
$CHARGE_CCSO

If WABREV<>"CCSO"
   [M:CCSO]CPY      =evalue("[M:"+WABREV+"]CPY")
   [M:CCSO]SALFCY   =evalue("[M:"+WABREV+"]SALFCY")
   [M:CCSO]BPCORD   =evalue("[M:"+WABREV+"]BPCORD")
   [M:CCSO]SOHNUMDEB=evalue("[M:"+WABREV+"]SOHNUMDEB")
   [M:CCSO]SOHNUMFIN=evalue("[M:"+WABREV+"]SOHNUMFIN")
   [M:CCSO]ORDDATDEB=evalue("[M:"+WABREV+"]ORDDATDEB")
   [M:CCSO]ORDDATFIN=evalue("[M:"+WABREV+"]ORDDATFIN")
   [M:CCSO]SOHCATNOR=evalue("[M:"+WABREV+"]SOHCATNOR")
   [M:CCSO]SOHCATLND=evalue("[M:"+WABREV+"]SOHCATLND")
   [M:CCSO]SOHCATFAC=evalue("[M:"+WABREV+"]SOHCATFAC")
   [M:CCSO]ORDSTAO  =evalue("[M:"+WABREV+"]ORDSTAO")
   [M:CCSO]ORDSTAN  =evalue("[M:"+WABREV+"]ORDSTAN")
   [M:CCSO]APPFLGO  =evalue("[M:"+WABREV+"]APPFLGO")
   [M:CCSO]APPFLGN  =evalue("[M:"+WABREV+"]APPFLGN")
Endif

If !find([M:CCSO]SOHCATNOR,1,2) : [M:CCSO]SOHCATNOR= 2 : Endif
If !find([M:CCSO]SOHCATLND,1,2) : [M:CCSO]SOHCATLND= 2 : Endif
If !find([M:CCSO]SOHCATFAC,1,2) : [M:CCSO]SOHCATFAC= 2 : Endif
If !find([M:CCSO]ORDSTAO,1,2)   : [M:CCSO]ORDSTAO= 2   : Endif
If !find([M:CCSO]ORDSTAN,1,2)   : [M:CCSO]ORDSTAN= 2   : Endif
If !find([M:CCSO]APPFLGO,1,2)   : [M:CCSO]APPFLGO= 2   : Endif
If !find([M:CCSO]APPFLGN,1,2)   : [M:CCSO]APPFLGN= 2   : Endif

# -- Récupération du nom du traitement spécifique pour pouvoir utiliser l'action FILTRE
Read [ACN] ACN0="CSO" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

# -------------------------------------------------------------------------- #
# Analyse paramères, initialisations                                         #
# -------------------------------------------------------------------------- #
If [M:CCSO]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CCSO]SALFCY,GUSRFCY(1..GNBAUZ)) [M:CCSO]SALFCY="" Endif

If [M:CCSO]BPCORD <> "" : # Parametre Client
    If [F:BPC]BPCNUM<>[M:CCSO]BPCORD Read [F:BPC]BPC0 = [M:CCSO]BPCORD
                                     If fstat Raz [F:BPC], [M:CCSO]BPCORD Endif
    Endif
Endif

If [M:CCSO]SALFCY <> "" : # Paramètre Site
    If [F:FCY]FCY <> [M:CCSO]SALFCY  Read [F:FCY]FCY0 = [M:CCSO]SALFCY
                                     If fstat Raz [F:FCY], [M:CCSO]SALFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M:CCSO]SALFCY,GUSRFCY(1..GNBAUZ))
        If [M:CCSO]SALFCY <> ""
             Call GETDEV([M:CCSO]SALFCY) From DEVSUB
             [M:CCSO]CPY  = GSOCIETE
             WCURS = GLOCALDEV
        Endif
    Endif
Elsif [M:CCSO]CPY<>""
    If [F:CPY]CPY <> [M:CCSO]CPY  Read [F:CPY]CPY0 = [M:CCSO]CPY
                           If fstat Raz [F:CPY], [M:CCSO]CPY Endif
    Endif
    WCURS = [F:CPY]ACCCUR
Endif

Return

#############################################################################
#                                                                           #
##     Etiquettes masques SGRHSOH1, SGRHSOH2                               ##
#                                                                           #
#############################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSOH2) 02/01/2007 10:32:10 (LD)
######################################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
  GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]SALFCY = ""
  # Mail CH : 03/03/04
  #  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  #  Raz [M]CURS
#  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
  GSOCIETE="" : GLOCALDEV=""
Endif
End
############################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Affzo ZCPY
Raz [M]SALFCY, ZSALFCY
Affzo SALFCY,ZSALFCY
If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
#    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End
############################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Affzo CPY, ZCPY
Endif
End
############################################################
Subprog AM_SOHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SOHNUMFIN= VALEUR : Endif
End
######################################################################################
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSOH1,SGO1,SGO3                                        ##
#                                                                                    #
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSOH1) 15/01/2007 16:11:27 (LD)
######################################################################################
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Quinzaine
GMENLOC(8)=1 : # Décade
End
########################################
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
# -- Recalcul du nbre de périodes
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo [M]PERNBR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER(VALEUR,[M]PERNBR,"-",[0/0/0],[M]ORDDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]ORDDATDEB=WDATE : Affzo [M]ORDDATDEB
Endif
End
########################################
Subprog C_PERNBR(VALEUR)
Variable Decimal VALEUR
#If VALEUR<1 | VALEUR>24 mkstat=2 Endif
End
########################################
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"-",[0/0/0],[M]ORDDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]ORDDATDEB=WDATE : Affzo [M]ORDDATDEB
Endif
End
######################################################################################
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSOH1,SGRHSOH2,SGO1,SGO2,SGO3                          ##
#                                                                                    #
######################################################################################
########################################
Subprog AM_ORDDATDEB(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  # -- Recalcul date fin en fonction de la périodicité et du nbre de périodes
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]ORDDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]ORDDATFIN=WDATE : Affzo [M]ORDDATFIN
  Endif
  #-----
#Elsif VALEUR>[M]DATFIN
#  [M]DATFIN=VALEUR
Elsif VALEUR <> [0/0/0]
  [M]ORDDATFIN= VALEUR
Endif
End
########################################
Subprog AM_ORDDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]ORDDATFIN,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]ORDDATDEB=WDATE : Affzo [M]ORDDATDEB
  Endif
  #-----
Endif
End
######################################################################################
#                                                                                    #
##     Etiquettes masques SGO2                                                      ##
#                                                                                    #
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGO2) 05/04/2007 11:13:08 (LD)
######################################################################################
Subprog C_NBRTOP(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>60
  GMESSAGE=mess(6,199,1) : mkstat=1 : End : # Valeur incorrecte !
Endif
End
######################################################################################

