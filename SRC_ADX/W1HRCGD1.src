Return

Subprog D_SSPGRD(VALEUR)
Variable Char    VALEUR()
If varinit([M]SSPGRD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10344","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SSPGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10344") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SSPGRD(zc) From W1HRCGD1
Onkey   2 Titled GBOUTS Call S_SSPGRD(zc) From W1HRCGD1
Onkey 144 Titled GBOUTP Call P_SSPGRD(zc) From W1HRCGD1
Onkey 146 Titled GBOUTA Call SA_SSPGRD(zc) From W1HRCGD1
Gosub _AFF
End

Subprog C_SSPGRD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10344","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10344",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
 If !mkstat
  ## Action STD
  Call C_SSPGRD(VALEUR) From SUBHRCGD
  If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SSPGRD
Call AM_SSPGRD(zc)
If !mkstat & GOBJET
 zoncou = "SSPGRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SSPGRD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSSPGRD)")>indice
 [M]SSPGRD(indice) = VALEUR
 Affzo ZSSPGRD(indice)
Endif
Gosub _AFF
End

Subprog S_SSPGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10344"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SSPGRD(VALEUR)
