Subprog C_CTRXITAUT(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_CTRXITAUT(VALEUR) From SUBHRCGD
If mkstat : GERR = 1 : GZONE = "CTRXITAUT" : GZNUM = 47723 : Endif
Gosub _AFF
End

$ON_CTRXITGRD
Onevent BEFORE_INPUT Call AS_CTRXITGRD(zc) From W1HRCGD1
Onevent CONTROL Call C_CTRXITGRD(zc) From W1HRCGD1
Onevent AFTER_CHANGE Gosub AMM_CTRXITGRD From W1HRCGD1
Return

Subprog AS_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(37037,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRXGD
Call DEFHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
If mkstat=2
 [M]CTRXITGRD(INDIC) = VALEUR
 Affzo CTRXITGRD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CTRXITGRD(zc) From W1HRCGD1
Onkey   2 Titled GBOUTS Call S_CTRXITGRD(zc) From W1HRCGD1
Onkey 144 Titled GBOUTP Call P_CTRXITGRD(zc) From W1HRCGD1
Onkey 146 Titled GBOUTA Call SA_CTRXITGRD(zc) From W1HRCGD1
Gosub _AFF
End

Subprog C_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
## Action CONTHRXGD
Call CONTHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
 If !mkstat
  ## Action STD
  Call C_CTRXITGRD(VALEUR) From SUBHRCGD
  If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CTRXITGRD
Call AM_CTRXITGRD(zc)
If !mkstat & GOBJET
 zoncou = "CTRXITGRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCTRXITGRD)")>indice
 [M]CTRXITGRD(indice) = VALEUR
 Affzo ZCTRXITGRD(indice)
Endif
Gosub _AFF
End

Subprog S_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRXGD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRXGD"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRXGD","SUBHRXGD","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRXGD
 Call TUNHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRXGD"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRXGD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCTRXITGRD
Onevent BEFORE_AREA Gosub AV_ZCTRXITGRD From W1HRCGD1
Return

$AV_ZCTRXITGRD
Call LECTEXTRA(zc,"HRXITGRD","DESAXX",num$([M]CTRXITGRD(indice)),"") From ATEXTRA
Gosub _AFF
Return

