#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRCGD1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:35"
A_USER  = "DOC"
A_STAMP = "20181109230435"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRCGD1 [HRCGD1]
Gosub HORODAT
Local Inpbox "HRCGD1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRCGD1] As [SIM_]
Grizo [HRCGD1]5
Grizo [HRCGD1]10
Grizo [HRCGD1]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRCGD1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=86 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=86 : Y1(1)=4 : Y2(1)=17
X1(2)=1 : X2(2)=86 : Y1(2)=18 : Y2(2)=28
Return

$ON_COD
Onevent BEFORE_INPUT Call AS_COD(zc) From W1HRCGD1
Onevent CONTROL Call C_COD(zc) From W1HRCGD1
Onevent AFTER_CHANGE Gosub AMM_COD From W1HRCGD1
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(2675,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCGD
Call DEFHRCGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRCGD
If mkstat=2
 [M]COD(INDIC) = VALEUR
 Affzo COD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_COD(zc) From W1HRCGD1
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1HRCGD1
Onkey 144 Titled GBOUTP Call P_COD(zc) From W1HRCGD1
Onkey 146 Titled GBOUTA Call SA_COD(zc) From W1HRCGD1
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
If !mkstat
 ## Action CONTHRCGD
 Call CONTHRCGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRCGD
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
  If !mkstat
   ## Action CONTOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARMSK(1) = "HRCGD"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_COD
Call AM_COD(zc)
If !mkstat & GOBJET
 zoncou = "COD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCOD)")>indice
 [M]COD(indice) = VALEUR
 Affzo ZCOD(indice)
Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJETL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJETL"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_COD" : PROGSUB = "SUBHRCGD" : PROGSPE = "SPEHRCGD" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "HRCGD"
 PARMSK(2) = "COD"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJET","SELOBJ","") From GACTION
 ACTION = "BS_COD" : PROGSUB = "SUBHRCGD" : PROGSPE = "SPEHRCGD" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCGD
 Call TUNHRCGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRCGD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCGD"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_COD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCGD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCOD
Onevent BEFORE_AREA Gosub AV_ZCOD From W1HRCGD1
Return

$AV_ZCOD
Call LECTEXTRA(zc,"HRCTRGRD","DESAXX",num$([M]COD(indice)),"") From ATEXTRA
Gosub _AFF
Return

