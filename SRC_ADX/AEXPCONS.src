#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(10)(1..7)
PARAM(1) = "0" : # option navig
PARAM(2) = "ASN" : # site stocjkage
PARAM(3) = ""    : # filtre table
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""

Raz GNBMASKOUV,GMESSAGE
GCONSULT = 0

Local Char MESSA(250),FICHIER(GDIMFIC)
Local Integer EXPSTA,EXPORT
Call EXPCONS("SAR","",PARAM,1,MESSA,EXPSTA,FICHIER)
#Infbox "*"-GMESSAGE
If EXPSTA
 Infbox MESSA-"---"-num$(EXPSTA)-FICHIER
Endif
End

########################################################################
#**
#* Ce sous-programme permet d'exporter complétement une consultation. Pour cela on se base sur les parametres associé à l'action pour définir l'axe d'analyse.
#*
#* @param CNSCOD Consultation
#* @param CECRAN Code écran
#* @param PARAM Paramètres actions
#* @param TYPEXP Export
#* @param EXPMES Message d'erreur
#* @param EXPSTA Statut
#* @param EXPFIC Fichier
#*!
Subprog EXPCONS(CNSCOD,CECRAN,PARAM,TYPEXP,EXPMES,EXPSTA,EXPFIC)
Value Char        CNSCOD()
Value Char        CECRAN()
Value Char        PARAM()(1..)
Value Integer     TYPEXP
Variable Char     EXPMES()
Variable Integer  EXPSTA
Variable Char     EXPFIC

EXPSTA = 0
EXPMES = ""
EXPFIC = ""

If CNSCOD="" : # Consultation non définie
 EXPMES =mess(16,126,1)
 EXPSTA =1
 End
Endif

Local File ACONSULT [ACN]
Read [ACN]ACN0 = CNSCOD
If fstat : # Consultation non définie
 EXPMES = CNSCOD-":"-mess(16,126,1)
 EXPSTA =1
 End
Endif

#  A-t-on le droit de naviguer vers cette action
Call CNAVIG(2,"","","","",[F:ACN]WND1,"",EXPMES) From EXEFNC
If EXPMES<>"" : EXPSTA = 1 : End : Endif

Close Local File [ACN]
Local Char MESSAGE(250)
Gosub DECLARE From GCONSULT

SAVFONC    = GFONCTION
SAVOBJET   = GOBJET
SAVPROG    = GPROGRAMME
SAVTITCOL  = GORITITCOL
SAVNOL     = nolign
SAVBOITE   = GBOITE
GORITITCOL = 0
GFONCTION  = "CONS"+CNSCOD
PROGCNS    = "WWCNS"+CNSCOD
Gosub NOMFIC From =PROGCNS
If PROGSTD<>""
 Call EXISTE_ADX("","",PROGSTD,OKTRT) From ORDSYS
 If !OKTRT
  PROGSTD = ""
 Else
  PROG = PROGSTD
 Endif
Endif
If PROGSPE<>""
 Call EXISTE_ADX("","",PROGSPE,OKTRT) From ORDSYS
 If !OKTRT
  PSPE = 0 : PROGSPE = ""
 Else
  PSPE = 1
 Endif
Endif

GOBJET = 1
GPROGRAMME = "GCONSULT"
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

Call AUTORIS From EXEFNC
If GNBAUZ=0
 # Fonction non autorisée
 EXPMES =  GFONCTION-":"-mess(1,123,1) : EXPSTA= 1 :  Goto FIN
Endif
OK = 1 : ACTION = "AUTORIS" : Gosub ACTION From GCONSULT
If !OK : EXPSTA= 1  : Goto FIN : Endif

NBMASK = 2
For MA=2 To dim(NOMMSK)-1
 If NOMMSK(MA)=""
  NBMASK = MA-1 : Break
 Endif
Next MA

OK = 1
If CODMSKDEF<>""
 Call VERFGTC(CNSCOD,CODMSKDEF,CODMSKDEF,MESSAGE,OK) From GCONSULT
Endif
For MA=-1 To NBMASK
 If MA=1 & CODMSKDEF<>""
  If OK
   NOMMSK(1) = "WM"+CNSCOD+CODMSKDEF
  Else
   GMESSAGE = ""
  Endif
 Elsif MA=2 & CNSCOD="STA" & CODMSKDEF<>""
  If OK
   NOMMSK(2) = "WMSTB"+CODMSKDEF
  Else
   GMESSAGE = ""
  Endif
 Endif
 Gosub OUVRE_MSK From =PROGCNS
Next MA

MSKDEF = NOMMSK(1)

If CODMSKDEF<>"" & OK
 GBOITE = "WM"+CNSCOD+CODMSKDEF
Elsif CECRAN<>""
 GBOITE = "WM"+CNSCOD+CECRAN
Else
 GBOITE = BOITE
Endif
BOXDEF = GBOITE

If CABMSK="" or evalue("dim([M:"+CABMSK+"]MEMO)<=0")
 MEMO = ""
Endif

Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV

For MA=-1 To NBMASK
 Gosub RAZMASK From =PROGCNS
Next MA

Raz CHARGMT   # Bug 9630 : Préchargement oui/non (CP:12/07/01)
Gosub OUVRE From =PROGCNS

Raz FILSIT, FILACC
If NOMFIC<>""
 Gosub SETCLE From =PROGCNS
 If NBCMP
  # Filtre sur sites autorisés
  If GUSRFCY(1)<>"\" & dim([L]ZSITE)>0 & [L]ZSITE<>"" & GNBAUZ<>GNBSITE
   FILSIT = '([F:'+ABFIC+']'+ZSITE+'="" or find([F:'+ABFIC+']'+ZSITE+',GUSRFCY(1..GNBAUZ))<>0)'
  Endif
  # Filtre sur codes d'accès
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  If GUSRACS<>2 & [L]ZACC<>""
   FILACC = '([F:'+ABFIC+']'+ZACC+'="" or [F:ACC]CONSUL=2)'
  Else
   FILACC = "1=1"
  Endif
 Endif
Endif
If OBJDERLU<>""
 If GNBDERNIER>0 & !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif
 PROGOBJ = "WO"+OBJDERLU
Endif

ACTION = "OUVRE" : Gosub ACTION From GCONSULT
EXPCONS=1 : Gosub CHANGE_MSK From GCONSULT
If OK<0 : EXPMES = GMESSAGE : EXPSTA = 1 : Goto FIN : Endif
EXPCONS=1 : EXPCLI= TYPEXP : Gosub EXPORT_XLS From GCONSULT
If ERSTA : EXPMES = GMESSAGE : EXPSTA = 1 : Goto FIN : Endif
EXPFIC = FICSRV
EXPMES = GMESSAGE
Setmode
#End        : #  CC  24/06/2009

$FIN
ACTION = "FERME" : Gosub ACTION From GCONSULT
If BOX
 Gosub FERME_BOITE From =WINPROG
 BOX = 0
Endif
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
GFONCTION  = SAVFONC
GBOITE     = SAVBOITE
Call AUTORIS From EXEFNC : # Restauration des autorisations
GORITITCOL = SAVTITCOL
If dim(GNBMASKOUV)>0
 GNBMASKOUV-=1
 GNBMASKOUV=max(0,GNBMASKOUV)
Endif
Setmode
End


# -----------------------------------------------------------------------------------------------------

#  Export excel consultation pour portail
Call CONSEXCEL("ZZJCNSSTA",2)
End


Subprog CONSEXCEL(VUE,TYPEXP)
Value Char VUE
Value Integer TYPEXP
# CODVUE : Code de la vue
# TYP    : Type d'export
#          1 : csv
#          2 : Excel

Raz GNBMASKOUV
GCONSULT = 0

Local Char     PARAM(100)(1..20)
Local Char     EXPMES(250)
Local Integer  EXPSTA
Local Char     EXPFIC(GDIMFIC)
Gosub CHPARAM

Call EXPCONS(C_CNSCODE,C_CNSECR,PARAM,TYPEXP,EXPMES,EXPSTA,EXPFIC) From AEXPCONS
End


$CHPARAM
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
If clalev([F:APV])  = 0 : Local File APTLVW [APV]  : Endif    # vue portail
Read [APV]APV0=VUE
If fstat<>0 : Return : Endif
Gosub C_INIT
C_CNSCODE=[F:APV]SRCCOD
   # Lecture des paramètres sources de données
    Raz C_CNSECR, C_CNSMAXROW
    For CW_I=0 To [F:APV]SRCPARNBR-1
        C_LSTPARCOD(CW_I)=[F:APV]SRCPARCOD(CW_I)
        U_PARCODE=C_LSTPARCOD(CW_I) : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR=UC_ERRG : Break : Endif
        C_LSTPARVALC(CW_I)=U_PARVAL
        C_LSTPARVALN(CW_I) = U_PARVALTYP
        Case U_PARVALTYP
        When 3 # numérique
            C_LSTPARVALN(CW_I)=U_PARVALNUM
        When 7 # date
            C_LSTPARVALD(CW_I)=U_PARVALDAT
        Endcase
        # Code ecran consultation
        If C_LSTPARCOD(CW_I) = CC_CNSECRCOD : C_CNSECR = U_PARVAL : Endif
        # Nb de ligne maxi à retourner
        If C_LSTPARCOD(CW_I) = CC_CNSMAX    : C_CNSMAXROW = val(U_PARVAL) : Endif
    Next
    If U_ERR=UC_ERRG : Return : Endif


$C_LDCNSACT
    If !clalev([F:ATR]) : Local File ACTPAR [ATR] : Endif
    #
    Filter [ATR] Where ACTION="CONS"+C_CNSCODE
    CW_I = rowcount([ATR])+1
    #Local Char C_PARCOD(GLONAAR)(1..CW_I)
    #
    CW_I=0
    For [ATR]NOPAR
        CW_I+=1
        CW_J=find([F:ATR]CODPAR, C_LSTPARCOD)
        If CW_J
            PARAM(CW_I)=C_LSTPARVALC(CW_J-1)
        Endif
    Next
    Filter [ATR]
Return


# Variables
# - - - - - - - - - - - - - - - - - -
$C_INIT
# Travail
Local Integer CW_I, CW_DES, CW_ROW, CW_COL, CW_BTN, CW_NBREC
Local Char CW_STRINTVAL(200), CW_STRVAL(200), CW_STREVAL(20)
#Local Char CW_URL(220)            # 30 de reserves pour le codage
Local Decimal CW_DEC
Local Date    CW_DAT
# Actions portails
Local Char CQ_ACTINIT(10) : CQ_ACTINIT='LOAD'                # Donnée à partir du début niveau 1

#        Pour compatibilité tableau
Local Char SQ_ACTREFRESH(10) : CQ_ACTREFRESH='REFRESH'
Local Char C_ACTCNS       # Action prgrms consultation

# Action ss-prgrm consultations
Local Char CQ_CNSFIRST(10) : CQ_CNSFIRST='TOP'              # Données depuis le début
Local Char CQ_CNSNEXT(10) : CQ_CNSNEXT='NEXT'               # Données suivantes

# Zones de messages communes
Local Integer  C_NBMES
Local Integer  C_TYPMES(0..10)
Local Char     C_MES(200)(0..10)

# Table type
If clalev([F:ATY])  = 0 : Local File ATYPE [ATY] : Endif
# Elts principaux de la consultation
Call LECTURE("ATY","ACN","") From CONTOBJ
Local Char C_CNSCODE([F:ATY]LNGTYP)    # Code
Call LECTURE("ATY","GTC","") From CONTOBJ
Local Char C_CNSECR([F:ATY]LNGTYP)      # Ecran éventuel

#Paramètres sources de données
Local Char CC_ECRAN(5) : CC_ECRAN="ECRAN"
Local Integer C_LEVEL
Local Char C_PROGCNS

# Parametres issus de la vue portail
Local Integer CC_PTLPARDIM : CC_PTLPARDIM = dim([F:APV]SRCPARCOD)
Local Char    C_LSTPARCOD(10)(0..CC_PTLPARDIM -1)
Local Integer C_LSTPARTYP(0..CC_PTLPARDIM -1)
Local Char    C_LSTPARVALC(200)(0..CC_PTLPARDIM -1)
Local Date    C_LSTPARVALD(0..CC_PTLPARDIM -1)
Local Decimal C_LSTPARVALN(0..CC_PTLPARDIM -1)
Local Char    CC_CNSECRCOD : CC_CNSECRCOD = "CNS_ECR"
Local Char    CC_CNSMAX    : CC_CNSMAX    = "CNS_MAX"

# Informations générales consultations
Call LECTURE("ATY","DES","") From CONTOBJ : CW_DES = [F:ATY]LNGTYP
Local Char    C_CNSTITLE(CW_DES)
Call LECTURE("ATY","AMK","") From CONTOBJ
Local Char    C_CNSMASK([F:ATY]LNGTYP)
Local Char    C_CNSMASKABR(GLONABR+4)  # [M:xx]
Local Integer C_CNSMAXROW
Local Integer CC_NBMAXCOL : CC_NBMAXCOL = 50    # Nb maxi de colonne géré
Local Char    C_CLSCOD(10)(0..CC_NBMAXCOL-1)
Local Char    C_CLSTITLE(CW_DES)(0..CC_NBMAXCOL-1)
Local Integer C_CLSTYP(0..CC_NBMAXCOL-1)
Local Integer C_CLSMNL(0..CC_NBMAXCOL-1)
Local Decimal C_CLSLNG(0..CC_NBMAXCOL-1)       # Format de la zone sous forme 12.4
Local Integer C_CLSFLGEXP(0..CC_NBMAXCOL-1)    # 0: non exporté  - 1: exporté
Local Integer C_CLSNB



# Vues du portail
Local Char U_VIEWCODE    # Code vue
Local Char UC_VIEWOBJ : UC_VIEWOBJ="APV"                  # Objet X3 de gestion
Local Char U_PARCODE(10)        # Code paramètre à lire
Local Char     U_PARVAL(200)    # Valeur char
Local Decimal  U_PARVALNUM      #     idem numérique
Local Date     U_PARVALDAT      #     idem date
Local Integer  U_PARVALTYP      # Type résultat   10: evaluation char ; 7: evaluation date ; 3: evaluation num
Local Integer U_PAREXIST                  # 0 si non trouvé, sinon indice dans le tableau
Local Char U_SRCPARVAL(50)(0..dim([F:APV]SRCPARCOD))    # stockage résultats évaluations para sources de données

# Evaluation de formule
Local Char     U_EVAFOR(250)    # Formule à évaluer
Local Char     U_RESFOR(250)    # Résultat de l'évaluation
Local Decimal  U_RESFORNUM      #     idem numérique
Local Date     U_RESFORDAT      #     idem date
Local Integer  U_RESFORTYP      # Type résultat   10: evaluation char ; 7: evaluation date ; 3: evaluation num
Local Char     U_CTXFOR(100)    # Contexte de la formule pour tracer l'erreur

# Gestion messages et erreurs
Local Char U_MESCODE(30)                      # Code message
Local Char U_MESP1(100)                        # Par1 message (optionnel)
Local Char U_MESP2(100)                        # Par2 message
Local Char U_MESP3(100)                        # Par3 message
Local Integer U_ERR, UW_ERR                   # Gravité (0:OK, 1:Warning, 2:Arrêt) et err de travail
Local Integer UC_ERRG, UC_ERRW, UC_ERRNO : UC_ERRG=2 : UC_ERRW=1 : UC_ERRNO=0
Local Integer U_NBMES                         # Nb messages
Local Integer UC_TMESMAX : UC_TMESMAX=30      # Nb maxi de messages en tableau
Local Char U_TMESCODE(30) (1..UC_TMESMAX)     # Liste      Codes message
Local Char U_TMESP1(40) (1..UC_TMESMAX)       #            Par1 message (optionnel)
Local Char U_TMESP2(40) (1..UC_TMESMAX)       #            Par2 message
Local Integer U_TMESERR (1..UC_TMESMAX)       #            Gravité
Local Char U_MES(250)                         # Message (texte)
Local Char U_CALLUIRET(20)                    # code retour fct callui (dernier caractère)


Return






