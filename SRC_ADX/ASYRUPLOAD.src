#<AdxTL>@(#)0.0.0.0 $Revision$
End

######################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"   : Gosub DEBUT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#**
#* INIT
#*!
$INIT
Return

#**
#* DEBUT
#*!
$DEBUT
Return

#**
#* EXEC
#*!
$EXEC
Local Char    FICDES (250),PATHDES(250), FICSRV (250),FICCLI (250),VOLUME(20),VOLDES(20),SUBFOLDER(250),NAMFIC(250),FICNAM(250)
Local Integer OK,FILEDESINFO
Gosub ENUM_VOLFIL_TYPE From ASYRSTO

# 1 Copy on [TMP] volume
VOLUME = ""
FICSRV = VOLUME
OK = func ASYRSTO.UPLOAD(FICCLI,FICSRV)
If OK<>1
 Goto ERREXEC
Endif

# 2 Copy in the good folder
VOLDES =PARAM(1)
If VOLDES=""
 VOLDES="ATT"
Endif
NAMFIC= PARAM(2)
SUBFOLDER = PARAM(3)
If find(left$(SUBFOLDER,1),"/","\")>0
 SUBFOLDER = right$(SUBFOLDER,2)
Endif
FICNAM = string$(SUBFOLDER<>"", '/' +[L]SUBFOLDER)+"/"
If NAMFIC<>""
 FICNAM += NAMFIC
Else
 FICNAM += FICCLI
Endif
FICDES =   '[' + VOLDES+ ']' + FICNAM
OK  = func ASYRSTO.CTL_VOLFIL(2,FICDES,PATHDES,E_TYPE_FILEOVERWRITE,GMESSAGE)
If !OK
 If FICSRV <> PATHDES :#SAM 120662
  OK = func ASYRSTO.GETFILEINFO(VOLDES ,FICNAM,0,FILEDESINFO)
  If FILEDESINFO>0
   Call OUINON(mess(127,105,1),OK) From GESECRAN : #  : Fichier existant, souhaitez-vous l'écraser ?
   If OK<>2 : Goto FINEXEC : Endif
  Endif
 Endif:#SAM 120662
 GPOINT = "CHANGEFIC" : Gosub ENTREE From EXEFNC : # ccl 117374
 If FICSRV <> PATHDES :#SAM 120662
  Call MOVE(FICSRV,PATHDES,OK) From ORDSYS
 Endif :#SAM 120662
 If OK>0 : Goto ERREXEC : Endif
 PARAM(4) = FICDES
Else
 Goto ERREXEC
Endif
Return

$ERREXEC
Call ERREUR(mess(12,139,1)-string$(GMESSAGE<>"",":")-GMESSAGE)From GESECRAN :# Copie non réalisée'
$FINEXEC
Call EFFACE(FICSRV,OK) From ORDSYS : # Clear tempory file on [TMP]
PARAM(2) = ""
Return

#OK = func ASYRSTO.UPLOAD(FICCLI,FICSRV)
#If OK = 1 :#File uploaded on the server
# PARAM(2) = VOLUME + "/" + FICCLI
#Else
# Infbox mess(64,149,1)
#Endif
#Return

