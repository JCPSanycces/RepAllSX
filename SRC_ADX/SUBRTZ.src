#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier RITENZIONE
##########################################
# SUBRTZ - GESTION DU FICHIER RITENZIONE #
##########################################
# CREE LE    : 14/01/2000 - NG           #
# MODIFIE LE : 03/02/2000 - NG           #
##########################################


###########################################
# APPEL A L'OBJET DE GESTION DES RETENUES #
###########################################

GBIDC1="" : GBIDC2=""
Call OBJET ("RTZ",GBIDC1,GBIDC2) From GOBJET
End


##############################
# DEBRANCHEMENT CONDITIONNEL #
##############################

$ACTION
Case ACTION
 When "OUVRE"     : Gosub $OUVRE
 When "RAZCRE"    : Gosub $RAZCRE       # raz a la creation d'une nouvelle fiche
 When "INICRE"    : Gosub $INICRE
 When "INIMOD"    : Gosub $INIMOD
 When "LIENS"     : Gosub $LIENS        # liens a l'ouverture de chaque fiche
 When "SETBOUT"   : Gosub SETBOUT
Endcase
Return


##############################
# IMPLEMENTATION DES ACTIONS #
##############################

$OUVRE
If func AFNC.ACTIV("KIT") <> 0
 Local Char RTZCUR(GLONCUR) # devise de ritenzione
 Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL
 If [L]RTZCUR="" Then
  GMESSAGE="RTZCUR"-mess(136,199,1) # parametre non renseigne
  OK=0
 Endif
Endif
Local Char LEGCUR(GLONADI) : # Législation courante
Return

$RAZCRE # on passe ici a la creation d'une fiche, après l'effacement des zones
[M:RTZ2]CUR=[L]RTZCUR     # devise de ritenzione
Call AFF_TYPES_CHARGES () # affichage du tableau des types de charges
Return

$LIENS # on passe dans cette etiquette a chaque ouverture de fiche
If dim([M:RTZ1]LEG)>0
 LEGCUR = [M:RTZ1]LEG
Else
 LEGCUR = GDOSLEG(1)
Endif
Case [L]LEGCUR
 When "ITA"
  Local Char RTZCUR(GLONCUR) # devise de ritenzione
  Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL
 When Default
  [L]RTZCUR = GCURSHR
Endcase
[M:RTZ2]CUR=[L]RTZCUR # devise de ritenzione
Call AFF_TYPES_CHARGES () # affichage des types de charges
# RECOPIES DANS LES ZONES DE SEUILS ET/OU DE TAUX
Case [M:RTZ2]MET
 When 1
  [M:RTZ2]TX_SIMPLE=[M:RTZ2]RAT(0)
  If func AFNC.ACTIV("KAG") <> 0
   [M:RTZ2]TX_TSD=[M:RTZ2]TSDBKT(0)
  Endif
  [M:RTZ2]NBLIG=0
 When 2
  nolign=1
  While [M:RTZ2]BKT(nolign-1)<>0
   nolign+=1
  Wend
  [M:RTZ2]NBLIG=nolign # mise a jour de la var. de bas de tableau
 When 3
  [M:RTZ2]MINI=[M:RTZ2]BKT(0)
  [M:RTZ2]MAXI=[M:RTZ2]BKT(1)
  [M:RTZ2]TX_SEUIL=[M:RTZ2]RAT(0)
  [M:RTZ2]NBLIG=0
Endcase
Call GRIZO_MASK2 ([M:RTZ2]MET) # grisage des zones du masque 2

If func AFNC.ACTIV("KAG")<>0
 If [M:RTZ2]BASRTZ = 3 : # Mensuel
  [M:RTZ2]BASTSD = 0 : Grizo [M:RTZ2]BASTSD
 Else
  Actzo [M:RTZ2]BASTSD
 Endif
 If [M:RTZ1]CAT = 7 : # Ingresos Brutos
  Actzo [M:RTZ2]SAT
 Else
  [M:RTZ2]SAT = "" : Grizo [M:RTZ2]SAT
 Endif
Endif
Return

$INICRE
Gosub TRANSFIC
Return

$INIMOD
Gosub TRANSFIC
Return

$TRANSFIC
If func AFNC.ACTIV("LEG")=0 : [F:RTZ]LEG = GDOSLEG(1) : Endif
Case [F:RTZ]MET
 When 1
  [F:RTZ]RAT(0) = [M:RTZ2]TX_SIMPLE
  If func AFNC.ACTIV("KAG") <> 0
   [F:RTZ]TSDBKT(0) = [M:RTZ2]TX_TSD
  Endif
 When 3
  [F:RTZ]BKT(0) = [M:RTZ2]MINI
  [F:RTZ]BKT(1) = [M:RTZ2]MAXI
  [F:RTZ]RAT(0) = [M:RTZ2]TX_SEUIL
Endcase
Return
##############################################
$SETBOUT
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
###########################################
# SOUS-PROGRAMMES APPELES PAR LES ACTIONS #
###########################################

Subprog AFF_TYPES_CHARGES ()
# affichage des types de charges dans le
# tableau du masque 1 prevu a cet effet
For nolign=1 To len(mess(0,953,1)) # nb de choix du menu local
 [M:RTZ1]CHRTYP(nolign-1)=mess(nolign,953,1) # type de charge
 If [M:RTZ1]BAS(nolign-1)=0 Then # si oui/non pas encore positionné
  [M:RTZ1]BAS(nolign-1)=1 # alors on met a "non" par defaut
 Endif
Next nolign
[M:RTZ1]NBLIG=(nolign-1) # mise a jour de la var. de bas de tableau
End

Subprog GRIZO_MASK2 (METHODE)
Value Integer METHODE
# grisage des zones de saisies du masque 2
# selon la methode de calcul choisie (arg. methode)
Actzo # on commence par reafficher toutes les zones
Case METHODE # grisage des zones selon la methode de calcul
  When 1 : Effzo [RTZ2] 15,20 : Grizo 20     # cas taux simple
  When 2 : Effzo [RTZ2] 10,20 : Grizo 10,20  # cas taux par tranche
  When 3 : Effzo [RTZ2] 10,15 : Grizo 10     # cas taux avec seuil mini-maxi
Endcase
# GH 14/04/00 on n fait pas le grizo sur le tableau de rang 15 pour 2 raisons
# a) aucun impact visuel b) lorsqu'on clique sur un tableau grisé, on boucle
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
If [M]CAT=1 : # Retenue a la source -> Sur reglement + Tout sur le compte Caisse/Etat
 [M:RTZ1]COE1=1  # tout a la charge du fournisseur (fige)
 [M:RTZ1]COE2=0  # rien a la charge du client (fige)
 [M:RTZ1]ACC2="" # le compte de charge vide (fige)
 Affzo [M:RTZ1]COE1,COE2,ACC1,ACC2 # refresh des zones affectees
 VALEUR=1 : mkstat=2
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR=[M:RTZ1]TYP : End : Endif
# modif du type de retenue (sur Facture, sur Reglement)
# entraine saisie ou non du compte caisse/etat.
If VALEUR=2  # Retenue sur facture -> Tout sur le compte de charge
 [M:RTZ1]COE1=0  # rien a la charge du fournisseur (fige)
 [M:RTZ1]COE2=1  # tout a la charge du client (fige)
 [M:RTZ1]ACC1="" # le compte caisse/etat vide (fige)
Endif
Affzo [M:RTZ1]COE1,COE2,ACC1,ACC2 # refresh des zones affectees
End


Subprog AP_MET(VALEUR) # modif. de la methode de calcul
Variable Integer VALEUR
Call GRIZO_MASK2 (VALEUR) # grisage des zones en consequence
End

Subprog C_TX_SIMPLE(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100 Then
 GMESSAGE=mess(17,131,1) # Taux incorrect
 mkstat=2 : End
Endif
End

Subprog D_BKT0(VALEUR) # init automatique de la borne inf. du seuil
Variable Decimal VALEUR
If nolign=1 Then
 VALEUR=0 # Borne inf. du premier seuil = 0
Else
 VALEUR=[M:RTZ2]BKT(nolign-2)+1 # Borne inf. = Borne sup. du seuil precedent + 1
Endif
End

Subprog C_BKT(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M:RTZ2]BKT0(nolign-1) and VALEUR<>0 Then
 GMESSAGE=mess(1,131,1) # maxi < mini
 mkstat=2 : End
Endif
End

Subprog AM_BKT(VALEUR)
Variable Decimal VALEUR
[M:RTZ2]BKT0(nolign-1+1)=VALEUR+1 # Borne inf. suivante = Borne sup. courante + 1
Affzo [M:RTZ2]BKT0(nolign-1+1)
End

Subprog C_BASRAT(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100 Then
 GMESSAGE=mess(17,131,1) # Taux incorrect
 mkstat=2 : End
Endif
End

Subprog C_RAT(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100 Then
 GMESSAGE=mess(17,131,1) # Taux incorrect
 mkstat=2 : End
Endif
End

Subprog C_MINI(VALEUR)
Variable Decimal VALEUR
If VALEUR<0
 GMESSAGE=mess(21,131,1) # Valeur doit etre positive
 mkstat=2 : End
Endif
End

Subprog C_MAXI(VALEUR) # controle validite du seuil maxi
Variable Decimal VALEUR
If VALEUR<0
 GMESSAGE=mess(21,131,1) # Valeur doit etre positive
 mkstat=2 : End
Endif
End

Subprog C_TX_SEUIL(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100 Then
 GMESSAGE=mess(17,131,1) # Taux incorrect
 mkstat=2 : End
Endif
End

Subprog AS_NBLIG
# GH 14/04/00 ne pas griser le tableau, car on bloque en cliquant sur un tableau grisé
If [M:RTZ2]MET<>2 : mkstat=2 : End : Endif
End

Subprog AS_COE1(VALEUR)
Variable Decimal VALEUR
## <PP 12/12/2002>
If [M]TYP=1 & [M]CAT=1
 mkstat = 2 : End
Endif
## <PP 14/11/02> on veut pouvoir imputer le coefficient si retenue Enasarco sur la Facture ...
#If ([M]TYP=1 & [M]CAT=1) | ([M]TYP=2 & [M]CAT<>3)
# mkstat = 2 : End
#Endif
##If [M]TYP=2 | [M]CAT=1 : mkstat=2 : Endif
##If [M]TYP=2 & [M]CAT=3 : mkstat=0 : Endif
End

Subprog C_COE1(VALEUR)
Variable Decimal VALEUR
If VALEUR<0
 GMESSAGE=mess(21,131,1)
 mkstat=2 : End
Elsif VALEUR>1
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Elsif VALEUR=0 # coef. client nul
 Raz [M:RTZ1]ACC1 # raz compte caisse/état
 Affzo [M:RTZ1]ACC1
Endif
End

Subprog AS_ACC1(VALEUR)
Variable Char    VALEUR()
If [M]COE1=0 : mkstat=1 : End : Endif
End

Subprog AS_COE2(VALEUR)
Variable Decimal VALEUR
## <PP 12/12/2002>
If [M]TYP=1 & [M]CAT=1
 mkstat = 2 : End
Endif
## <PP 14/11/02> on veut pouvoir imputer le coefficient si retenue Enasarco sur la Facture ...
#If ([M]TYP=1 & [M]CAT=1) | ([M]TYP=2 & [M]CAT<>3)
# mkstat = 2 : End
#Endif
#If [M]TYP=2 | [M]CAT=1 : mkstat=2 : Endif
#If [M]TYP=2 & [M]CAT=3 : mkstat=0 : Endif
End

Subprog C_COE2(VALEUR)
Variable Decimal VALEUR
If VALEUR<0
 GMESSAGE=mess(21,131,1)
 mkstat = 2 : End
Elsif VALEUR>1
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Elsif [M]COE1 + VALEUR <> 1
 # La somme des coefficients doit être égale à 1
 GMESSAGE = mess(31,131,1)
 mkstat = 2 : End
Elsif VALEUR=0 # coef. client nul
 Raz [M:RTZ1]ACC2 # raz compte de charge
 Affzo [M:RTZ1]ACC2
 If [M:RTZ1]COE1=0 : [M:RTZ1]COE1=1 : Affzo [RTZ1]COE1 : Endif
Endif
End

Subprog AS_ACC2(VALEUR)
Variable Char    VALEUR()
If [M]COE2=0 : mkstat=1 : End : Endif
End

Subprog C_ACC2(VALEUR)
Variable Char    VALEUR()
If [M]COE2<>0 & VALEUR=""
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
Call C_ACC(VALEUR)
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif # comptes generaux
If [M]TYP=2 & VALEUR<>""
 Call LECTURE ("GAC",VALEUR,[M]COA) From CONTOBJ
 If [F:GAC]RITTYP>0 & [M]BAS([F:GAC]RITTYP-1)=2  # type de charge inclus dans la base
  # type de charge du compte inclus dans la base de calcul
  GMESSAGE = mess(30,131,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_RITAMT1(VALEUR)
Variable Decimal  VALEUR
If [M]RITAMTDED<>0 & VALEUR<>0
 mkstat = 2
Endif
End

Subprog AM_RITAMT1(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Decimal MT
Read [F:RTZ]RTZ0=[M:DIA]RITCOD(NOL)  # lecture fiche retenue
If [F:RTZ]TYP=1 & VALEUR<>0   # Retenue sur reglement
 If [F:RTZ]COE1<>0 : # Retenues sur règlement
  [L]MT = VALEUR*[F:RTZ]COE1/([F:RTZ]COE1+[F:RTZ]COE2)
  Call ARRDEV(MT,[M:DIA]CUR) From TRTDIV
 Else
  [L]MT=0
 Endif
 [M:DIA]RITAMT2(NOL)=VALEUR-[L]MT # montant sur compte de charge
Endif
Affzo RITAMT2(NOL)
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

##########################################################################
## Etiquettes masques RTZ1, RTZ2
##########################################################################
Subprog C_ACC1(VALEUR)
Variable Char    VALEUR()
If [M]COE1<>0 & VALEUR=""
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
Call C_ACC(VALEUR)
End


Subprog AS_CAT(VALEUR)
Variable Integer VALEUR
Local Char LEGCUR(GLONADI)
If dim([M:RTZ1]LEG)>0
 LEGCUR = [M:RTZ1]LEG
Else
 LEGCUR = GDOSLEG(1)
 Gosub INIT_CHP
Endif
If LEGCUR="ARG"
 Local Integer I
 For I=1 To 5
  GMENLOC(I) = 1
 Next
Elsif LEGCUR="ITA" : # Retenues Italiennes
 For I=6 To len(mess(0,950,1))
  GMENLOC(I) = 1
 Next
Endif
End

Subprog AM_BASRTZ(VALEUR)
Variable Integer VALEUR
If VALEUR = 3 : # Mensuel
 [M:RTZ2]BASTSD = 0  : Grizo [M:RTZ2]BASTSD
 [M:RTZ2]SAT    = "" : Grizo [M:RTZ2]SAT
 [M:RTZ2]PAYPRT = 1
Else
 [M:RTZ2]BASTSD = 1 : Actzo [M:RTZ2]BASTSD
 Actzo [M:RTZ2]SAT
 If VALEUR = 1 : # Montant HT
  [M:RTZ2]PAYPRT = 1
 Else
  [M:RTZ2]PAYPRT = 2 : # Retenues IVA sont tjs dues lors du premier règlement....
 Endif
Endif
End

Subprog AS_BASTSD(VALEUR)
Variable Integer VALEUR
If [M:RTZ2]BASRTZ = 3 : # Mensuel (spécial Argentine)
 VALEUR = "" : Grizo [M:RTZ2]BASTSD
Else
 Actzo [M:RTZ2]BASTSD
Endif
## si paiement partiel = "Sur premier règlement", la base seuil est toujours = "Par document individuel"
## (Mail Flavio du 01/08/05)
If dim([M:RTZ2]PAYPRT)>0 & [M:RTZ2]PAYPRT=2
 VALEUR = 1 : mkstat = 2 : End
Endif
End


Subprog AS_SAT(VALEUR)
Variable Char    VALEUR()
If [M:RTZ1]CAT=7 : # Ingresos Brutos
 Actzo SAT
Else
 VALEUR = "" : Grizo SAT
Endif
End

Subprog AS_MET(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("KAG")<>0
 If find([M:RTZ2]BASRTZ,1,2)
  Call GRIZO_MASK2(1)
  VALEUR = 1 : mkstat = 2 : End
 Else
  VALEUR = 2
  Call GRIZO_MASK2(2)
  Call AP_MET(VALEUR) From SUBRTZ : mkstat = 2 : End
 Endif
Endif
End

Subprog AS_PAYPRT(VALEUR)
Variable Integer VALEUR
If [M:RTZ2]BASRTZ = 3
 VALEUR = 1 : mkstat = 2 : End
Endif
End


Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
Local Char LEGCUR(GLONADI)
LEGCUR = VALEUR
Gosub INIT_CHP
End

$INIT_CHP
Local Char RTZCUR(GLONCUR) # devise de ritenzione
Case [L]LEGCUR
 When "ITA"
  Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL
 When Default
  [L]RTZCUR = GCURSHR
Endcase
[M:RTZ2]CUR=[L]RTZCUR # devise de ritenzione
Return

Subprog D_COA(VALEUR)
Variable Char    VALEUR()
If clalev([F:GCM])=0 : Local File GACM [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED [LED] : Endif
Filter [GCM] Where LEG=[M]LEG
Read [GCM]GCM0 First
Filter [GCM]
If fstat
 # Aucun modèle comptable défini pour cette législation
 GMESSAGE = mess(184,105,1)
 mkstat = 2 : End
Else
 Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
 VALEUR = [F:LED]COA
Endif
End

Subprog C_COA(VALEUR)
Variable Char    VALEUR()
If clalev([F:GCM])=0 : Local File GACM [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED [LED] : Endif
Local Integer OK
OK = 0

For [GCM] Where LEG=[M]LEG
 Call LEC_LED([F:GCM]LED([F:GCM]GENLEDTYP-1)) From CPTLEC
 If [F:LED]COA=VALEUR
  OK = 1
  Break
 Endif
Next
If !OK
 GMESSAGE = VALEUR-":"-mess(93,102,1)-"\"-mess(238,133,1)-[M]LEG
 mkstat = 2 : End
Endif
End

###########################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'une retenue                      #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File RITENZIONE [RTZ1]
Else
  Local File =[M]DOSORG+".RITENZIONE" [RTZ1]
Endif
If [M]DOSDES=nomap
  Local File RITENZIONE [RTZ2]
Else
  Local File =[M]DOSDES+".RITENZIONE" [RTZ2]
Endif
OK=1
Look [RTZ2]RTZ0=TABLE
If !fstat
  OK= 2 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
  If OK<>2  OK=0 : Endif
Endif
If OK
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
Endif
Close Local File [RTZ1], [RTZ2]

Return

$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'une retenue               #
#--------------------------------------------------#
GOK=1
Local Integer ILIG
Trbegin [RTZ2]
  Delete [RTZ2] Where RITCOD=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".RITENZIONE"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("RTZ2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  Read [RTZ1]RTZ0=TABLE
  If !fstat
    #--- copie des données
    [F:RTZ2]=[F:RTZ1]
    Write [RTZ2]
    If fstat GOK=0 : Call FSTA("RTZ2") From GLOCK : Endif
  Endif
  If GOK=0 : Goto AB_COPIE : Endif
Commit

Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif

Return

