###################################################################################################
# Classe TECSOQITM
# Issue X3-18442/120906 - 2017-01-13 by FGR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SOQ_ADD_LINE"                : Gosub SOQ_ADD_LINE
    #
    When "_GET_KEYCONCAT"              : Gosub _GET_KEYCONCAT
    When "_EXIST_KEYCONCAT"            : Gosub _EXIST_KEYCONCAT
    When "_LOAD_ONE_OPPNUM"            : Gosub _LOAD_ONE_OPPNUM
    When "_SOQ_COPY"                   : Gosub _SOQ_COPY
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

###################################################################################################
# METHODS
###################################################################################################
$SOQ_ADD_LINE
#Value Char SPJT ()
#Value Char SITMREF ()
#Value Char SSOHNUM ()       # Issue X3-31898 - 2017-11-23 by FGR
#Value Integer ISOPLIN       # Issue X3-31898 - 2017-11-23 by FGR
#Value Integer ISOQSEQ       # Issue X3-31898 - 2017-11-23 by FGR
#Variable Integer INDEX      # Issue X3-31898 - 2017-11-23 by FGR
#Local Integer ARET_VALUE

Local Integer ILINE
Local Char SCONCAT(250)
Local Integer IRET
Local Char SOPPNUM(GLONVCR)
Local Char SPBUCOD(GLONPBU)
Local Char STASCOD(GLONTAC)

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  # ------------------------------------
  # Method called from sales orders to add in to technical class all the information to manage
  # ORDERS in the project.
  # Only if needed :
  #   * PJT(Task) is not empty
  #   * ITMREF is not empty
  #   * ITMREF is managed on the task (in PJMTSKITM)
  # ------------------------------------
  [L]ARET_VALUE = [V]CST_AOK
  INDEX = [V]CST_ANOTDEFINED
  # ------------------------------------
  If SITMREF <> AVOID.ACHAR and SPJT <> AVOID.ACHAR Then
    Local File ITMMASTER [ITM]         # Issue X3-21639/121055 - 2017-01-20 by FGR
    Read [ITM]ITM0=SITMREF             # Issue X3-21639/121055 - 2017-01-20 by FGR
    If [F:ITM]STOMGTCOD = 2 Then       # Issue X3-21639/121055 - 2017-01-20 by FGR : If product is managed in stock
      SCONCAT = fmet this._GET_KEYCONCAT(SPJT, SITMREF)
      #If fmet this._EXIST_KEYCONCAT(SCONCAT) = [V]CST_ANO Then      # Issue X3-31898 - 2017-11-23 by FGR
        IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, SPJT, SOPPNUM, SPBUCOD, STASCOD)
        Local File PJMTSKITM [JTT]
        Filter [JTT] Where [F:JTT]OPPNUM = SOPPNUM and [F:JTT]TASCOD = STASCOD and [F:JTT]ITMREF = SITMREF
        For [JTT]
          ILINE = fmet this.ADDLINE("SOQ", [V]CST_ALASTPOS)
          If ILINE <> [V]CST_ANOTDEFINED Then
            INDEX = ILINE
            this.SOQ(ILINE).PJT = SPJT
            this.SOQ(ILINE).ITMREF = SITMREF
            this.SOQ(ILINE).CONCAT = SCONCAT
            this.SOQ(ILINE).OPPNUM = SOPPNUM
            this.SOQ(ILINE).TASCOD = STASCOD
            this.SOQ(ILINE).SOHNUM = SSOHNUM                         # Issue X3-31898 - 2017-11-23 by FGR
            this.SOQ(ILINE).SOPLIN = ISOPLIN                         # Issue X3-31898 - 2017-11-23 by FGR
            this.SOQ(ILINE).SOQSEQ = ISOQSEQ                         # Issue X3-31898 - 2017-11-23 by FGR
          Endif
          Break
        Next
        Filter [JTT]
      #Endif                                                         # Issue X3-31898 - 2017-11-23 by FGR
    Endif                              # Issue X3-21639/121055 - 2017-01-20 by FGR
  Endif
  # ------------------------------------
Return

###################################################################################################
$_GET_KEYCONCAT
#Value Char SPJT ()
#Value Char SITMREF ()
#Local Char ARET_VALUE(250)

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = SPJT + "~" + SITMREF
Return

###################################################################################################
$_EXIST_KEYCONCAT
#Value Char SKEY ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------------------
  NI = find(SKEY, this.SOQ(1..maxtab(this.SOQ)).CONCAT)
  While NI > 0
    If this.SOQ(NI) <> null and find(this.SOQ(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Else
      NI1 = NI
      NI = find(SKEY, this.SOQ(NI+1..maxtab(this.SOQ)).CONCAT)
      If NI > 0 Then
        NI += NI1
      Endif
    Endif
  Wend
Return

###################################################################################################
$_LOAD_ONE_OPPNUM
#Variable Instance TECSOQITM Using C_TECSOQITM : #
#Local Integer ARET_VALUE

Local Char SOPPNUM(GLONVCR)
Local Integer NI
Local Integer ILINE
Local Integer IRET

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  Raz SOPPNUM
  For NI = 1 To maxtab(TECSOQITM.SOQ)
    If TECSOQITM.SOQ(NI) <> null and find(TECSOQITM.SOQ(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If SOPPNUM = AVOID.ACHAR Then
        SOPPNUM = TECSOQITM.SOQ(NI).OPPNUM
      Endif
      If TECSOQITM.SOQ(NI).OPPNUM = SOPPNUM Then
        ILINE = fmet this.ADDLINE("SOQ", [V]CST_ALASTPOS)
        If ILINE <> [V]CST_ANOTDEFINED Then
          IRET = fmet this._SOQ_COPY(TECSOQITM, NI, ILINE)
          If IRET < [V]CST_AERROR Then
            IRET = fmet TECSOQITM.ADELLINE("SOQ", TECSOQITM.SOQ(NI).AORDER)
          Endif
        Endif
      Endif
    Endif
  Next NI
  # ------------------------------------
Return

###################################################################################################
$_SOQ_COPY
#Variable Instance TECSOQITM Using C_TECSOQITM : #
#Value Shortint LINEFROM
#Value Shortint LINETO
#Local Integer ARET_VALUE

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  this.SOQ(LINETO).PJT = TECSOQITM.SOQ(LINEFROM).PJT       # 1
  this.SOQ(LINETO).ITMREF = TECSOQITM.SOQ(LINEFROM).ITMREF # 2
  this.SOQ(LINETO).OPPNUM = TECSOQITM.SOQ(LINEFROM).OPPNUM # 3
  this.SOQ(LINETO).TASCOD = TECSOQITM.SOQ(LINEFROM).TASCOD # 4
  this.SOQ(LINETO).CONCAT = TECSOQITM.SOQ(LINEFROM).CONCAT # 5
  this.SOQ(LINETO).SOHNUM = TECSOQITM.SOQ(LINEFROM).SOHNUM # 6
  this.SOQ(LINETO).SOPLIN = TECSOQITM.SOQ(LINEFROM).SOPLIN # 7
  this.SOQ(LINETO).SOQSEQ = TECSOQITM.SOQ(LINEFROM).SOQSEQ # 8
  # ------------------------------------
Return

