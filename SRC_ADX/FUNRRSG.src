#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################################################
# Recherche ressource                                                      Module CRM          24 février 2010 #
################################################################################################################
###############################################################################
$ACTION
  Case ACTION
    When "DEBUT"        : Gosub DEBUT
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

###############################################################################
$DEBUT
Local Integer IAOB
Local Char SORIVCR(GLONVCR)
Local Integer IORIVCRL
Local Integer NBLIGRES  # FGR 30/06/2011 : X3SUIVI74675

  # PARAM(1) : Site
  # PARAM(2) : Date début
  # PARAM(3) : Heure début
  # PARAM(4) : Date fin
  # PARAM(5) : Heure fin
  # PARAM(6) : Objet d'origine
  # PARAM(7) : Référence d'origine
  # PARAM(8) : Ligne d'origine
  If !clalev ([F:RRS]) : Local File RESRES [RRS] : Endif
  If !clalev ([F:RSS]) : Local File RESOURCES [RSS] : Endif
  #
  [M:RRSG]SALFCY = PARAM(1)
  [M:RRSG]DATDEB = PARAM(2)
  [M:RRSG]HOUDEB = PARAM(3)
  [M:RRSG]DATEND = PARAM(4)
  [M:RRSG]HOUEND = PARAM(5)
  IAOB = val(PARAM(6))
  SORIVCR = PARAM(7)
  IORIVCRL = val(PARAM(8))
  Affzo [M:RRSG]5
  # Bidouille pour avoir une largeur sur la colonne "Nom" du graphique
  Effzo [M:RRSG]10
  # FGR 30/06/2011 : X3SUIVI74675 (début)
  NBLIGRES = 0
  [M:RRSG]NUM(NBLIGRES) = space$(GLONVCR)                                       # Clé
  [M:RRSG]RSSDES(NBLIGRES) = left$(mess(1020,196,1)+space$(GLONVCR), GLONVCR)   # Nom
  NBLIGRES += 1
  Call AFFICHE_LIGNE (NBLIGRES, space$(GLONVCR), [M:RRSG]DATEND, [M:RRSG]HOUDEB, [M:RRSG]DATEND, [M:RRSG]HOUEND, 2)
  [M:RRSG]NBLIGC = NBLIGRES
  # FGR 30/06/2011 : X3SUIVI74675 (fin)
  Affzo [M:RRSG]10
Return

###############################################################################
$BOUTON
Local Integer ILIGNE
Local Integer I

  Case BOUT
    When "A"
      ILIGNE = nolign-1
      If (ILIGNE) >= 0 Then
        If [M:RRSG]NUM(ILIGNE) <> "" and [M:RRSG]NUM(ILIGNE) <> space$(GLONVCR) Then # FGR 30/06/2011 : X3SUIVI74675
          For I = ILIGNE To [M:RRSG]NBLIGC
            If [M:RRSG]NUM(I) <> [M:RRSG]NUM(ILIGNE) Then
              ILIGNE = -1
              Break
            Endif
            If [M:RRSG]TYPTPS(I) = 2 Then
              ILIGNE = I
              Break
            Endif
          Next
          If ILIGNE <> -1 Then
            VALEUR = [M:RRSG]NUM(ILIGNE)
            PARAM(2) = [M:RRSG]DATDEB
            PARAM(3) = [M:RRSG]HOUDEB
            PARAM(4) = [M:RRSG]DATEND
            PARAM(5) = [M:RRSG]HOUEND
            FIN = 1
          Else
            GMESSAGE = mess(127,184,1)
            FIN = 0
            GERR = 1
          Endif
        Else
          GMESSAGE = mess(127,184,1)
          FIN = 0
          GERR = 1
        Endif
      Endif
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

###############################################################################
$ONLOAD
Local Integer IRESUSED
Local Integer NBLIGRES
Local Integer IFIRST
Local Integer ICODRES

  NBLIGRES = 0
  Effzo [M:RRSG]10
  Filter [RSS] Where ([F:RSS]SALFCY = [M:RRSG]SALFCY) and [F:RSS]CAT = [M:RRSG]CAT Order By [F:RSS]NUM
  For [RSS]
    [M:RRSG]NUM(NBLIGRES) = [F:RSS]NUM                                                             # Clé
    Call LECTEXTRA([M:RRSG]RSSDES(NBLIGRES),"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA    # Nom
    NBLIGRES += 1
    #
    IRESUSED = 0
    IFIRST = 1
    Filter [RRS] Where [F:RRS]RSSNUM = [F:RSS]NUM and [F:RRS]RERDAT <= [M:RRSG]DATEND and [F:RRS]RERDATEND >= [M:RRSG]DATDEB Order By [F:RRS]RERDAT; [F:RRS]HOUSTR
    For [RRS]
      IRESUSED = 1
      #--------------------------------------------------------------
      If IFIRST = 1 Then
        # Pour la première fois on regarde si ça commence au début
        If [F:RRS]RERDAT >= [M:RRSG]DATDEB Then
          If [F:RRS]HOUSTR > "0800" Then
            # Si ça ne commence pas en début de journée, on note libre le début
            Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATDEB, "0800", [F:RRS]RERDAT, [F:RRS]HOUSTR, 1)
          Endif
        Endif
        IFIRST = 0
      Else
        # pour les suivantes on regarde si la réservation qui arrive est consécutive. Sinon on complète
        If [M:RRSG]WDATEND(NBLIGRES-1) <> [F:RRS]RERDAT or [M:RRSG]WHOUEND(NBLIGRES-1) <> [F:RRS]HOUSTR Then
          If [M:RRSG]SENDDAT(NBLIGRES-1) <= [M:RRSG]DATDEB + [M:RRSG]HOUDEB and [F:RRS]RERDAT + [F:RRS]HOUSTR >= [M:RRSG]DATEND + [M:RRSG]HOUEND Then
            If [M:RRSG]SENDDAT(NBLIGRES-1) < [M:RRSG]DATDEB + [M:RRSG]HOUDEB Then
              Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [M:RRSG]DATDEB, [M:RRSG]HOUDEB, 1)
            Endif
            Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATDEB, [M:RRSG]HOUDEB, [M:RRSG]DATEND, [M:RRSG]HOUEND, 2)
            If [F:RRS]RERDAT + [F:RRS]HOUSTR > [M:RRSG]WDATEND(NBLIGRES-1) + [M:RRSG]WHOUEND(NBLIGRES-1) Then
              Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [F:RRS]RERDAT, [F:RRS]HOUSTR, 1)
            Endif
          Else
            # Il n'y a pas la place du besoin
            Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [F:RRS]RERDAT, [F:RRS]HOUSTR, 1)
          Endif
        Endif
      Endif
      #--------------------------------------------------------------
      # Pour chaque ligne ici, on indique la ressource comme utilisée
      # Si la réservation ne correspond pas à ce qu'on fait c'est 3. Sinon c'est 4
      If (IAOB = 2 or IAOB = 3) and [F:RRS]RRSORI = IAOB and [F:RRS]RRSORIVCR = SORIVCR Then
        ICODRES = 4
      Else
        ICODRES = 3
      Endif
      Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [F:RRS]RERDAT, [F:RRS]HOUSTR, [F:RRS]RERDATEND, [F:RRS]HOUEND, ICODRES)
      #--------------------------------------------------------------
    Next
    Filter [RRS]
    If IRESUSED = 1 Then
      #--------------------------------------------------------------
      # Si la ressource n'est pas utilisée jusqu'en fin de journée, on note libre la fin de journée
      If [M:RRSG]WDATEND(NBLIGRES-1) <= [M:RRSG]DATEND and [M:RRSG]WHOUEND(NBLIGRES-1) < "1800" Then
        If [M:RRSG]SENDDAT(NBLIGRES-1) <= [M:RRSG]DATDEB + [M:RRSG]HOUDEB and [M:RRSG]DATEND + [M:RRSG]HOUEND < [M:RRSG]DATEND + "1800" Then
          If [M:RRSG]SENDDAT(NBLIGRES-1) < [M:RRSG]DATDEB + [M:RRSG]HOUDEB Then
            Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [M:RRSG]DATDEB, [M:RRSG]HOUDEB, 1)
          Endif
          Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATDEB, [M:RRSG]HOUDEB, [M:RRSG]DATEND, [M:RRSG]HOUEND, 2)
          If [M:RRSG]DATEND + [M:RRSG]HOUEND < [M:RRSG]DATEND + "1800" Then
            Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [M:RRSG]DATEND, "1800", 1)
          Endif
        Else
          # Il n'y a pas la place du besoin
          Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]WDATEND(NBLIGRES-1), [M:RRSG]WHOUEND(NBLIGRES-1), [M:RRSG]DATEND, "1800", 1)
        Endif
      Endif
    Else
      #--------------------------------------------------------------
      # Si la ressources n'est pas utilisé... c'est qu'elle est libre
      If [M:RRSG]HOUDEB > "0800" Then
        Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATDEB, "0800", [M:RRSG]DATDEB, [M:RRSG]HOUDEB, 1)
      Endif
      Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATDEB, [M:RRSG]HOUDEB, [M:RRSG]DATEND, [M:RRSG]HOUEND, 2)
      If [M:RRSG]HOUEND < "1800" Then
        Call AFFICHE_LIGNE (NBLIGRES, [F:RSS]NUM, [M:RRSG]DATEND, [M:RRSG]HOUEND, [M:RRSG]DATEND, "1800", 1)
      Endif
    Endif
  Next
  Filter [RSS]
  #
  # FGR 30/06/2011 : X3SUIVI74675 (début)
  If NBLIGRES = 0 Then
    [M:RRSG]NUM(NBLIGRES) = space$(GLONVCR)                                       # Clé
    [M:RRSG]RSSDES(NBLIGRES) = left$(mess(1021,196,1)+space$(GLONVCR), GLONVCR)   # Nom
    NBLIGRES += 1
    Call AFFICHE_LIGNE (NBLIGRES, space$(GLONVCR), [M:RRSG]DATEND, [M:RRSG]HOUDEB, [M:RRSG]DATEND, [M:RRSG]HOUEND, 3)
    [M:RRSG]NBLIGC = NBLIGRES
  Endif
  # FGR 30/06/2011 : X3SUIVI74675 (fin)
  #
  [M:RRSG]NBLIGC = NBLIGRES
  Affzo [M:RRSG]10
Return

###############################################################################
Subprog AFFICHE_LIGNE (ILIGRES, SNUM, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ITYPE)
Variable Integer ILIGRES
Value Char SNUM
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND
Value Integer ITYPE

Local Decimal LLTI

  LLTI = func CALCUL_DUREE(DDATEDEB, SHOUDEB, DDATEEND, SHOUEND)
  [M:RRSG]NUM(ILIGRES)     = SNUM                # Clé
  [M:RRSG]INTDAT(ILIGRES)  = DDATEDEB + SHOUDEB  # Date interne
  [M:RRSG]SENDDAT(ILIGRES) = DDATEEND + SHOUEND
  [M:RRSG]LTIAFF(ILIGRES)  = LLTI                # Durée affichée
  [M:RRSG]TYPTPS(ILIGRES)  = ITYPE               # Type : Proposition
  [M:RRSG]LTI(ILIGRES)     = LLTI                # Durée interne
  [M:RRSG]WDATDEB(ILIGRES) = DDATEDEB 
  [M:RRSG]WDATEND(ILIGRES) = DDATEEND
  [M:RRSG]WHOUDEB(ILIGRES) = SHOUDEB
  [M:RRSG]WHOUEND(ILIGRES) = SHOUEND
  ILIGRES += 1
End

###############################################################################
Funprog CALCUL_DUREE(DDATEDEB, SHOUDEB, DDATEEND, SHOUEND)
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND

Local Decimal ARENDRE
Local Decimal IHHDEB
Local Decimal IMMDEB
Local Decimal IHHFIN
Local Decimal IMMFIN
Local Decimal ITEMPS1
Local Decimal ITEMPS2


  If DDATEDEB = DDATEEND Then
    # C'est dans la même journée
    IHHDEB = func REND_TEMPS(SHOUDEB)
    IHHFIN = func REND_TEMPS(SHOUEND)
    ARENDRE = IHHFIN - IHHDEB
  Else
    # C'est sur plusieurs jours
    ARENDRE = DDATEEND - DDATEDEB + 0
    IHHDEB = func REND_TEMPS("0000")
    IHHFIN = func REND_TEMPS(SHOUDEB)
    ITEMPS1 = IHHFIN - IHHDEB
    IHHDEB = func REND_TEMPS("0000")
    IHHFIN = func REND_TEMPS(SHOUEND)
    ITEMPS2 = IHHFIN - IHHDEB
    ARENDRE = ARENDRE - ITEMPS1 + ITEMPS2
  Endif
End ARENDRE

###############################################################################
Funprog REND_TEMPS(SHOUR)
Value Char SHOUR

Local Decimal ARENDRE
Local Decimal IHHDEB
Local Decimal IMMDEB

  IHHDEB = val(left$(SHOUR, 2)) / 24
  IMMDEB = (val(right$(SHOUR, 3)) / 60) / 24
  ARENDRE = IHHDEB + IMMDEB
End ARENDRE
