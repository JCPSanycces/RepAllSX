#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################
## Versioning management for Multi-Level BOM
##
## 109708 - 2015-08 by JUSYN :
## External Label and Procedures for Multi-Level BOM
## (VISUBOMG)
##
######################################################
# Selection done by Action GSELECT; treatment ASELGEN
######################################################
$ACTION
# "SEL_TABLE"  Action started before selection window is opened.
# "VERF_TABLE" Action called when choice has been done.
Case ACTION
    When "SEL_TABLE"        : Case COUZON
                                  When "VBOGECCMAJ","VBOGECCMIN"  : Gosub SELVBOGECC
                              Endcase
    When "VERF_TABLE"       : Case COUZON
                                  When "VBOGECCMAJ"               : Gosub SELVBOGECCMIN
                              Endcase
Endcase
Return

######################################################
# Definition of the parameters for selection window
######################################################
$SELVBOGECC
OBJET="EVL1"
CRITERE="ITMREF='"+[M:VBOG]PARITMREF+"' & ECCTYP="+num$([M:VBOG]BOMALTTYP)+" & USESTA="+num$([M:VBOG]USESTA)
Case COUZON
    When "VBOGECCMAJ"
        EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M:VBOG]VBOGECCMIN+"'"
    When "VBOGECCMIN"
        CRITERE-="& ECCVALMAJ='"+[M:VBOG]VBOGECCMAJ+"'"
        EXPSTART="ECCVALMAJ='"+[M:VBOG]VBOGECCMAJ+"' & ECCVALMIN='"+VALEUR+"'"
        START="ECCVALMIN"
Endcase
Return

######################################################
# Treatment after choice in selection screen done
######################################################
$SELVBOGECCMIN
VALEUR = [F:EVL]ECCVALMAJ
START  = ""

# Assignment of reference date
If ([F:EVL]ECCVALMAJ<>[M:VBOG]VBOGECCMAJ | [F:EVL]ECCVALMIN<>[M:VBOG]VBOGECCMIN)
&  & ([M:VBOG]DATREF<[F:EVL]STRDAT | ([M:VBOG]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0]))
    GDATEREF=[F:EVL]STRDAT : [M:VBOG]DATREF=GDATEREF : Affzo [VBOG]DATREF
Endif

# Assignment of minor version
If [F:EVL]ECCVALMIN<>[M:VBOG]VBOGECCMIN
    [M:VBOG]VBOGECCMIN = [F:EVL]ECCVALMIN
    Affzo [VBOG]VBOGECCMIN
    mkstat=4
Endif
Return

#########################################################################
# Treatment to find major and minor version including period of validity
#########################################################################
$READECC
If dim([M:VBOG]VBOGECCMAJ) = 1
    Raz [M:VBOG]ECCSTRDAT, [M:VBOG]ECCENDDAT
    If ACTION <> "DEBUT"
        Raz [M:VBOG]VBOGECCMAJ, [M:VBOG]VBOGECCMIN
    Endif
    If [M:VBOG]USESTA=1
         Filter [EVL] Where ITMREF = [M:VBOG]PARITMREF & ECCTYP = [M:VBOG]BOMALTTYP & USESTA = 1
    Else
         Filter [EVL] Where ITMREF = [M:VBOG]PARITMREF & ECCTYP = [M:VBOG]BOMALTTYP & USESTA = 2
&                           & [M:VBOG]DATREF >= [F:EVL]STRDAT & ([M:VBOG]DATREF <= [F:EVL]ENDDAT | [F:EVL]ENDDAT = [0/0/0])
    Endif
    Read [EVL]EVL0 Last
    If fstat > 2
        Filter [EVL] Where ITMREF = [M:VBOG]PARITMREF & ECCTYP = [M:VBOG]BOMALTTYP
        Read [EVL]EVL0 Last
    Endif
    Filter [EVL]
    If fstat <= 2
        If [M:VBOG]DATREF <> [0/0/0]
            [M:VBOG]VBOGECCMAJ = [F:EVL]ECCVALMAJ
            [M:VBOG]VBOGECCMIN = [F:EVL]ECCVALMIN
            [M:VBOG]ECCSTRDAT  = [F:EVL]STRDAT
            [M:VBOG]ECCENDDAT  = [F:EVL]ENDDAT
            If [M:VBOG]DATREF < [F:EVL]STRDAT | ([M:VBOG]DATREF > [F:EVL]ENDDAT & [F:EVL]ENDDAT <> [0/0/0])
                [M:VBOG]DATREF = [F:EVL]STRDAT : GDATEREF = [M:VBOG]DATREF
            Endif
        Endif
    Endif
    Affzo [VBOG] ECCSTRDAT, ECCENDDAT, DATREF
Endif
Return

