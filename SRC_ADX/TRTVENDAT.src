#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
#                                                                                  #
#           TRAITEMENTS de DATES et PERIODES dans les VENTES                       #
#                                                                                  #
####################################################################################
# Subprog CALC_DAT2(SCONTEXTE, ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)#
#      Calcul d'une date avec date et delai et ctrl jours indispo avec context     #
#      d'appel (SHI ou DLV)                                                        #
# Subprog CALC_DAT (ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)           #
#      Calcul d'une date avec date et delai et ctrl jours indispo                  #
#                                                                                  #
# Subprog CALC_SHIDAT(ORIDAT, LTI, ORIFCY, SENCAL, SENDEC, DSTDAT)                 #
#      Calcul date expédition avec date délai et ctrl jours indispo site           #
#                                                                                  #
# Subprog CALC_DLVDAT(ORIDAT, LTI, BPAADD, BPCORD, SENCAL,SENDEC,DSTDAT)           #
#      Calcul date livraison avec date delai et ctrl jours indispo bpd             #
#                                                                                  #
####################################################################################
#----------------------------------------------------------------#
# Calcul d'une date avec une date et un delai                    #
#                        et ctrl jours et périodes indispo       #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         UVYDAY   : Jours indisponibilités                      #
#         UVYCOD   : Code période indisponibilité                #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DAT2(SCONTEXTE, ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)
Value    Char     SCONTEXTE  # FGR 21/02/2012 : X3SUIVI64565
Value    Date     ORIDAT
Value    Integer  LTI
Value    Libelle  UVYDAY 
Value    Char     UVYCOD
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT

If SENCAL = 0
     DSTDAT = ORIDAT + LTI
Else DSTDAT = ORIDAT - LTI:Endif
# ---------------------------------------------------------------------#
#  Point d'entree calcul d'une date                                    #
# ---------------------------------------------------------------------#
Local Integer WPE_CTLDAT : WPE_CTLDAT=1
GPOINT="CALCDAT" : Gosub ENTREE From EXEFNC
If WPE_CTLDAT=0 End Endif
# --> Controle date par rapport jours indisponibilites
Call CTL_JOU(DSTDAT, UVYDAY, UVYCOD, SENDEC) From CONTX3
End

#----------------------------------------------------------------#
# Calcul d'une date avec une date et un delai                    #
#                        et ctrl jours et périodes indispo       #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         UVYDAY   : Jours indisponibilités                      #
#         UVYCOD   : Code période indisponibilité                #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DAT (ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Libelle  UVYDAY 
Value    Char     UVYCOD
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT

  # FGR 24/02/2012 : X3SUIVI64565 : Pour compatiblité avec les spé.
  Call CALC_DAT2(SCONTEXTE, ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, SENDEC, DSTDAT)
End

#----------------------------------------------------------------#
# Calcul d'une date d'expedition avec une date et un délai       #
#                        et ctrl jours et périodes indispo site  #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         ORIFCY   : Site expedition                             #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
#         CTRDAT   : Date à controler                            #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_SHIDAT(ORIDAT, LTI, ORIFCY, SENCAL, SENDEC, CTRDAT, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     ORIFCY
Value    Integer  SENCAL
Value    Integer  SENDEC
Value    Date     CTRDAT
Variable Date     DSTDAT

Local    Integer  UVYDAY (0..6)
Local    Integer  I

If [F:FCY]FCY <> ORIFCY
    Read [F:FCY]FCY0 = ORIFCY
    If fstat Raz [F:FCY] : Endif
Endif
# FGR 21/02/2012 : X3SUIVI64565 : Ajout du context "SHI" pour savoir d'où on vient dans le PE
Call CALC_DAT2("SHI", ORIDAT, LTI, [F:FCY]UVYDAY, [F:FCY]UVYCOD, SENCAL, SENDEC, DSTDAT)
# --> La date à contrôler est renseignée on ctrl
If CTRDAT <> [0/0/0] & DSTDAT < CTRDAT
    DSTDAT=CTRDAT
Endif

End

#----------------------------------------------------------------#
# Calcul d'une date de livraison avec une date et un délai       #
#                        et ctrl jours et périodes indispo bpd   #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         BPAADD   : Client livré                                #
#         BPCORD   : Client commande                             #
#         SENCAL   : Sens de calcul date                         #
#         SENDEC   : Sens décalage si jours indisponibilité      #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DLVDAT(ORIDAT, LTI, BPAADD, BPCORD, SENCAL, SENDEC, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     BPAADD
Value    Char     BPCORD
Value    Integer  SENCAL
Value    Integer  SENDEC
Variable Date     DSTDAT

Local    Integer  UVYDAY (0..6)
Local    Integer  I

If [F:BPD]BPCNUM <> BPCORD | [F:BPD]BPAADD <> BPAADD 
   Read [BPD]BPD0 = BPCORD;BPAADD
   If fstat Raz [F:BPD] : Endif
Endif 

For I=0 To 6
    UVYDAY(I) = evalue ("[F:BPD]UVYDAY"+num$(I+1))
Next
# FGR 21/02/2012 : X3SUIVI64565 : Ajout du context "DLV" pour savoir d'où on vient dans le PE
Call CALC_DAT2("DLV", ORIDAT, LTI, UVYDAY, [F:BPD]UVYCOD, SENCAL, SENDEC, DSTDAT)
End

