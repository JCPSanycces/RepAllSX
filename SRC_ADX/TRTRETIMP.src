#<AdxTL>@(#)9.0.0.0 $Revision$
#-----------------------------------------------
# TRTRETIMP
#-----------------------------------------------
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
GACTION = "TRTRETIMP"
[L]PARBOUT(1) = "RET-00000008"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"TRTRETIMP","TRTRETIMP","XYTRTRETIMP") From GSAISIE
End

$ACTION
Case [L]ACTION
    When "OK"
        Gosub OK
    When "OUVRE"
        Gosub OUVRE
    When "DEBUT"
        Gosub DEBUT
Endcase
Return

$OUVRE
If not clalev([F:RET]) : Local File RETRO [RET] : Endif
If not clalev([F:REC]) : Local File RETROCAL [REC] : Endif
If not clalev([F:VEP]) : Local File VALEMP [VEP] : Endif
Local Integer NBBUL_EDITION, NBMAXBUL_EDITION
[L]NBMAXBUL_EDITION = 5000
Local Char TBUL_EDITION(type([F:REC]RECBUL)-10)([L]NBMAXBUL_EDITION)
Return

$DEBUT
[M:DIA]RETNUM = [L]PARAM(1)
Read [F:RET]RET0 = [M:DIA]RETNUM
Affzo [M:DIA]
Return

$OK
Filter [F:REC] Where [F:REC]RETNUM = [F:RET]RETNUM & [F:REC]RECBUL <> ""
Raz [L]NBBUL_EDITION, [L]TBUL_EDITION
For [F:REC]REC1(1)
    [L]TBUL_EDITION([L]NBBUL_EDITION) = [F:REC]RECBUL
    [L]NBBUL_EDITION += 1
Next
Filter [F:REC]         :#72216
Call IMPRIME([L]TBUL_EDITION, [M:DIA]PRT, 1) From TRTRETVAL
Return
