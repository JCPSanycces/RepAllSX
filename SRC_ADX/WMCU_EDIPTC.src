#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## CRUD-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 851


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub _AVARIABLES From WMC00EDIPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EDIPTC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub AVARIABLES From WMC00EDIPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EDIPTC.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EDIPTC
Else
 Gosub AUPDATE_EDIPTC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EDIPTC.freeSnapshot
EDIPTC.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIPTC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EDIPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIPTC.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EDIPTC.ASTALIN)<>""
 [L]A_ASTALIN = EDIPTC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEW & EDIPTC.ASTALIN=[V]CST_ADEL
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ANEW & find(EDIPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIPTC.EPTD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIPTC.EPTD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEW & EDIPTC.ASTALIN=[V]CST_ADEL
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ANEW & find(EDIPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIPTC.EPTM(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIPTC.EPTM(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIPTC.EPTD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIPTC.EPTD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIPTC.EPTM(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIPTC.EPTM(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

If [V]CST_ASTALIN(EDIPTC.ASTALIN)<>""
 [L]A_ASTALIN = EDIPTC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EDIPTC
Trbegin [F:EPT]
 Gosub AUPDATE_EDIPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EDIPTC
[L]A_ASTALIN = EDIPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIPTC._MAJSQL_EDIPTC(EDIPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW
 #-----------------------#
 For A_N2=1 To maxtab(EDIPTC.EPTD)
  If EDIPTC.EPTD(A_N2) <> null and
& (EDIPTC.EPTD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ALL)
   If EDIPTC.EPTD(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIPTC.EPTD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIPTC.EPTD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCD(EDIPTC.EPTD(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIPTC.EPTD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIPTC.EPTD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
 #-----------------------#
 For A_N2=1 To maxtab(EDIPTC.EPTM)
  If EDIPTC.EPTM(A_N2) <> null and
& (EDIPTC.EPTM(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ALL)
   If EDIPTC.EPTM(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIPTC.EPTM(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIPTC.EPTM(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCM(EDIPTC.EPTM(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIPTC.EPTM(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIPTC.EPTM(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDIPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EDIPTC.snapshotEnabled=1
 [L]A_RETIK = EDIPTC.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTD)
 If EDIPTC.EPTD(A_N2) <> null
  If EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTM)
 If EDIPTC.EPTM(A_N2) <> null
  If EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet EDIPTC.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EDIPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIPTC.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTD)
 If EDIPTC.EPTD(A_N2) <> null
  If EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ADEL or EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIPTC.EPTD(A_N2)
   EDIPTC.EPTD(A_N2) = null
  Elsif EDIPTC.EPTD(A_N2).ASTALIN <> [V]CST_ALL
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIPTC.EPTM)
 If EDIPTC.EPTM(A_N2) <> null
  If EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ADEL or EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIPTC.EPTM(A_N2)
   EDIPTC.EPTM(A_N2) = null
  Elsif EDIPTC.EPTM(A_N2).ASTALIN <> [V]CST_ALL
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



