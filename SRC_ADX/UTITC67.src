#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# Created by : RMA
# Date       : 12/11/2014
# Tool for feeding the RECTYP and SAFTTRNTYP in table TABSRHTYP
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC67: QAV7.1 P7 : Default values for RECTYP and SAFTTRNTYP on TABSRHTYP") From LECFIC
  Call EXE_UTITC67(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog EXE_UTITC67(APPLI)
Value Char APPLI

If clalev([F:TRE]) : Close Local File [TRE] : Endif
Local File =APPLI+".TABSRHTYP" [TRE]

Call ECR_TRACE("UTITC67: Process Start on : "+APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC67
Call ECR_TRACE("UTITC67: Process End on : "+APPLI,0) From GESECRAN

End
########################################
#### Tool - Begin                   ####
########################################
$TR_UTITC67

Local Shortint DO_SAFTTRNTYP : DO_SAFTTRNTYP = 0
Local Shortint DO_RECTYP     : DO_RECTYP     = 0
Local Shortint RUPD          : RUPD          = 0

If dim([F:TRE]RECTYP) > 0
  DO_RECTYP = 1
Endif

If dim([F:TRE]SAFTTRNTYP) > 0
  DO_SAFTTRNTYP = 1
Endif

For [F:TRE]
  RUPD = 0
  If DO_RECTYP = 1
    If [F:TRE]RECTYP = 0
      [F:TRE]RECTYP = 1
      RUPD          = 1
      Call ECR_TRACE([F:TRE]SRHTYP + ":RECTYP updated with"-mess([F:TRE]RECTYP,2029,1), 0) From GESECRAN
    Endif
  Endif
  If DO_SAFTTRNTYP > 0
    If [F:TRE]SAFTTRNTYP = 0
      [F:TRE]SAFTTRNTYP = 1
      RUPD = 1
      Call ECR_TRACE([F:TRE]SRHTYP + ":SAFTTRNTYP updated with"-mess([F:TRE]SAFTTRNTYP,2046,1), 0) From GESECRAN
    Endif
  Endif
  If RUPD = 1
    Trbegin [F:TRE]
    Rewrite [F:TRE]
    If fstat
      Rollback
      Break
    Endif
    Commit
  Endif
Next

Return
########################################
#### Tool - End                   ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSRHTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC67(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier to update
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSRHTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC67(APPLI)
End
