Local Char PVHCOD(50),VRACODLAB(0)(0..100),VRACOD(0)(0..100)
PVHCOD="WGA2"
Call GETPVH(PVHCOD, VRACODLAB,VRACOD)From PORPPH
Infbox(VRACODLAB(0))
End


###########################################################################################
#     
# Liste des variables pour modele
#   
###########################################################################################

Subprog GETINFVARCRIT(AXPARCOD,AXPARVAL,REFNUM, PVHCOD, PVHLIB, SOCCOD, SITCOD, SRVCOD, PRFCOD, POPCOD)
Variable  Char      AXPARCOD()()
Variable  Char      AXPARVAL()()     
Value     Char      REFNUM()
Variable Char PVHCOD()(), PVHLIB()()
Variable Char SOCCOD()(), SITCOD()(), SRVCOD()(), PRFCOD()(), POPCOD()()
Call GETLSTPVH (REFNUM, PVHCOD, PVHLIB, SOCCOD, SITCOD, SRVCOD, PRFCOD, POPCOD)From PORPPH
End

###########################################################################################
#     
# Détail des variables à partir d'un code liste variable
#   
###########################################################################################

Subprog GETDETVAR(AXPARCOD,AXPARVAL,PVHCOD, VRACOD , VRACODLAB)
Variable  Char      AXPARCOD()()
Variable  Char      AXPARVAL()()     
Value     Char      PVHCOD()
Variable Char VRACOD()(), VRACODLAB()()

Call GETPVH(PVHCOD, VRACODLAB,VRACOD)From PORPPH
End


Subprog GETSYNTHESE(AXPARCOD,AXPARVAL,DEM, MATRICULE ,VRACOD,VRACODLAB,DEMAMT,NBVRA,NBBRO,NBINA,NBDEM,NBREF,NBACP,NBPEC)
Variable  Char      AXPARCOD()()
Variable  Char      AXPARVAL()()     
Value     Char      DEM(),MATRICULE()
Variable Char       VRACOD()(),VRACODLAB()()
Variable Decimal    DEMAMT()
Variable Integer    NBVRA(),NBBRO(),NBINA(),NBDEM(),NBREF(),NBACP(),NBPEC()  
Call GETSYNPPH(DEM,VRACOD,VRACODLAB,DEMAMT,NBVRA,NBBRO,NBINA,NBDEM,NBREF,NBACP,NBPEC)From PORPPH
End


Subprog ACTDEMPPH(AXPARCOD,AXPARVAL,AACTION
&       ,CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP
&       ,MATRICULE,CONTRAT
&       ,MSGERR,MSGWARM
&       ,MANAGER,REQNUM,PVHCOD,DEMDAT,EXEDAT,REQSTA,APLDAT,PYRDAT,DES,CMT
&       ,REFNUM,CTRNUM,NAM,VRACOD,ZVRACOD,DEMAMT,VRACMT,FLGAPP,STA,STA_LBL,BUL,NUMLIG,IDPPD,ACPAMT,CHRONO,FLGCMTOBG)

Variable  Char      AXPARCOD()(),AXPARVAL()() 
Value     Char      AACTION()
Variable  Char      CRICPY(),CRIFCY(),CRISRV(),CRIPRF(),CRIPOP()
# FDB - MATRICULE/CONTRAT - Liste des personnes sélectionnées via les checkboxes
Variable  Char      MATRICULE()(),CONTRAT()(),MSGERR()(),MSGWARM()()
Variable  Char      MANAGER(),REQNUM(),PVHCOD()
Variable  Date      DEMDAT,EXEDAT,APLDAT,PYRDAT
Variable  Char      DES(),CMT()
Variable  Integer   REQSTA
Variable  Char      REFNUM()(),CTRNUM()(),NAM()(),VRACOD()(),ZVRACOD()(),VRACMT()()
Variable  Decimal   DEMAMT(),ACPAMT()
Variable  Integer   FLGAPP(),STA(),NUMLIG(),IDPPD()
Variable  Char      BUL()(),STA_LBL()()
Variable  Char       CHRONO()()
Variable  Integer   FLGCMTOBG()

Local Char CHRN

If AACTION="SEND"
# Can be modify before to be send
Call SETDEMPPH2 ( "MODIFY",MANAGER,REQNUM,PVHCOD,DEMDAT,APLDAT
&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP
&                  , CHRN, MATRICULE,CONTRAT, MSGERR, MSGWARM
&                  , REQSTA,DES,PYRDAT,CMT
&                  , NUMLIG,IDPPD,REFNUM,CTRNUM,NAM
&                  , VRACOD,ZVRACOD,DEMAMT,ACPAMT,VRACMT
&                  , STA,STA_LBL,BUL,CHRONO
&                  , FLGAPP,FLGCMTOBG
&                 )From PORPPH
Endif
If GERR=0
Call SETDEMPPH2 ( AACTION,MANAGER,REQNUM,PVHCOD,DEMDAT,APLDAT
&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP
&                  , CHRN, MATRICULE,CONTRAT, MSGERR, MSGWARM
&                  , REQSTA,DES,PYRDAT,CMT
&                  , NUMLIG,IDPPD,REFNUM,CTRNUM,NAM
&                  , VRACOD,ZVRACOD,DEMAMT,ACPAMT,VRACMT
&                  , STA,STA_LBL,BUL,CHRONO
&                  , FLGAPP,FLGCMTOBG
&                 )From PORPPH
Endif
#Call SETDEMPPH(AACTION,MANAGER,)From PORPPH               
#Call SEMDEMPPH2( AACTION,MANAGER,REQNUM,REQSTA,PVHCOD,DEMDAT,APLDAT,DES,PYRDAT
#&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP,CMT
#&                  , MATRICULE,CONTRAT,MSGERR,MSGWARM 
#&                  , NUMLIG,IDPPD,REFNUM,CTRNUM,NAM
#&                  , VRACOD,ZVRACOD,DEMANT,ACPAMT,VRACMT
#&                  , STA,BUL
#&                 )From PORPPH

End

Subprog PRHPPHGESDRAFT(AXPARCOD,AXPARVAL,TYPACT,PMATRICULE,DEM,CREDAT,DES,PVHCOD)
Variable  Char      AXPARCOD()(),AXPARVAL()()
Variable  Char      TYPACT(),PMATRICULE()
Variable  Char      DEM()(),DES()(),PVHCOD()()
Variable  Date      CREDAT()
Local     Char      STATUTS(20)
Local     Date      PDATDEB,PDATFIN
Local     Char      PDEM
Local     Integer   REQSTA(0..dim(DEM)-1)
Local     Char   CODPVH(1)(0..dim(DEM)-1)
Local     Date   APLDAT(0..dim(DEM)-1)
  If TYPACT="DEM"
    STATUTS="2"
  Else
    STATUTS="1"
  Endif  
Call GETBDXPPH (PMATRICULE, STATUTS, PDATDEB, PDATFIN, DEM, DES, CREDAT,APLDAT, REQSTA,CODPVH,PVHCOD)From PORPPH

End
