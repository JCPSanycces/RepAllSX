#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier CFGABQ
$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "OUVRE_BOITE"  : Gosub OUVRE_BOITE    # FQ 60150 GA 11/2009
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "FILTRE"       : Gosub FILTRE
  When "OUVRE"        : Gosub OUVRE
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "LIENS2"       : Gosub LIENS2
  When "RAZCRE"       : Gosub RAZCRE
  When "VERF_ANU"     : Gosub VERF_ANU
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0 
  When "FERME"        : Gosub FERME 
  When "INICRE"       : Gosub INICRE
  When "INIMOD"       : Gosub INICRE
  When "ANNULE"       : Gosub ANNULE
  When "CHANGE"       : Call CHANGE_AXX ("CFGABQ", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
###########################################################
$INICRE
Call MAJTEXTRA([M:CAB1]ABQAXX,"CFGABQ","ABQAXX",[M:CAB1]ABQNUM,"") From ATEXTRA
Call MAJTEXTRA([M:CAB1]ABSAXX,"CFGABQ","ABSAXX",[M:CAB1]ABQNUM,"") From ATEXTRA
Call MAJTEXTRA([M:CAB1]RESAXX,"CFGABQ","RESAXX",[M:CAB1]ABQNUM,"") From ATEXTRA
Return
###########################################################
$ANNULE
Delete [AXX] Where CODFIC="CFGABQ" & IDENT1=[M:CAB1]ABQNUM
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Endif
Return
###########################################################
$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXCAB(10),GBOXCTC(10)
GBOXCAB="GAU_CHE"+num$(find("CAB",OBJLIS(1..8))) : # Abaques simples
GBOXCTC="GAU_CHE"+num$(find("CTC",OBJLIS(1..8))) : # Tables conversion
Return

###########################################################
$FILTRE
FILTRE  = "[F:CAB]ABQCOD < 3"
Return
###########################################################
$FILGAUCHE
# FQ 60150 GA 11/2008 ne pas filtrer le tiroir "Derniers lus"
#FILTSUP      = "[F:CAB]ABQCOD= 1 & [F:CAB]ABQLIN = 1"
#FILGAUSUP(0) = "[F:CAB]ABQCOD= 2 & [F:CAB]ABQLIN = 1"
Case currbox
  When GBOXCTC                     : # Tables conversion
    FILGAUSUP(0)= "[F:CAB]ABQCOD= 2 & [F:CAB]ABQLIN = 1"
  When "GAU_CHE"                   : # Abaques simples (GBOXCAB ?)
    FILTSUP     = "[F:CAB]ABQCOD= 1 & [F:CAB]ABQLIN = 1"
  When "GAU_CHE9"                  : # Derniers lus
    FILGAUSUP(0)= ""
    FILTSUP= ""
Endcase
Return
###########################################################
$OUVRE
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Global Char GSABSTXT0(15)
Global Char GSABSTXT1(28)
Global Char GSABSTXT2(28)
Global Char GSRESTXT (15)
Global Char GSSTRTXT (10)
Global Char GSENDTXT (10)
Call INTFLD("CABQ1","DMYTXT0",GSABSTXT0)
Call INTFLD("CABQ1","DMYTXT1",GSABSTXT1)
Call INTFLD("CABQ1","DMYTXT2",GSABSTXT2)
Call INTFLD("CABQ1","DMYTXT3",GSRESTXT)
Call INTFLD("CABQ1","DMYTXTSTR",GSSTRTXT)
Call INTFLD("CABQ1","DMYTXTEND",GSENDTXT)
Return
###########################################################
$RAZCRE
Actzo [M:CAB1]
Return
###########################################################
$SETBOUT
# cas du tunnel pour consultation
If GFONC1 <> "GESCAB"
  Call VIREBOUT(CHAINE,"A2") From GOBJET
Else 
  Call VIREBOUT(CHAINE,"H") From GOBJET
Endif
If GCONSULT = 1
  Call VIREBOUT(CHAINE,"CMADH") From GOBJET
Endif
# cas du tunnel pour consultation sans recherche
If GCONSULT = 2
  Call VIREBOUT(CHAINE,"RCMAD><LI09SH") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Local Char WDMY
Case REP 
   When "a"
     adxmbm = adxmbm
     Gosub SUP_GLOBALES   From WUVAR
     Gosub CFG_CONSTANTES From CFGLIB
     Gosub CFG_SYMBOLES   From CFGLIB
   When "2" :
     If !GINTRA
       Call COPIE([M:CAB1]ABQNUM)
     Endif
Endcase
Return
############################################################
$LIENS2
If [F:CAB]RESFLG = 0
  [M]RESFLG = 2
  [F:CAB]RESFLG = 2
Endif
For I = 0 To [M]NBLIG-1
  Case [M]ABQTYP
    When 1 : 
      [M]STRVAL(I) = [M]ALPSTRVAL(I)
      [M]ENDVAL(I) = [M]ALPENDVAL(I)
    When 2 :
      [M]STRVAL(I) = num$([M]NUMSTRVAL(I))
      [M]ENDVAL(I) = num$([M]NUMENDVAL(I))
    When 3 :
      [M]STRVAL(I) = format$("DfZz:"+GFMDAT,[M]DATSTRVAL(I))
      [M]ENDVAL(I) = format$("DfZz:"+GFMDAT,[M]DATENDVAL(I))
  Endcase
  Case [M]RESTYP
    When 1 :
      [M]RESVAL(I) = [M]ALPRESVAL(I)
    When 2 :
      [M]RESVAL(I) = num$([M]NUMRESVAL(I))
    When 3 :
      [M]RESVAL(I) = format$("DfZz:"+GFMDAT,[M]DATRESVAL(I))
  Endcase
Next I

Call GET_ATEXTRA("CFGABQ","ABSAXX",GLANGUE,GSABSTXT1) From TRTX3TEX
GSABSTXT2 = GSABSTXT1
If GSABSTXT1 <> ""
  If [M]ABQCOD <> 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    #GSABSTXT1 -= "["+GSSTRTXT+"]"
    #GSABSTXT2 -= "]"+GSENDTXT+"["
    GSABSTXT1 -= "]"+GSSTRTXT+"["
    GSABSTXT2 -= "["+GSENDTXT+"]"
  Else
    GSABSTXT2 = ""
  Endif
Else
  If [M]ABQCOD <> 2
    Call INTFLD("CABQ1","DMYTXT1",GSABSTXT1)
    Call INTFLD("CABQ1","DMYTXT2",GSABSTXT2)
  Else
    Call INTFLD("CABQ1","DMYTXT0",GSABSTXT1)
    GSABSTXT2 = ""
  Endif 
Endif
Call GET_ATEXTRA("CFGABQ","RESAXX",GLANGUE,GSRESTXT) From TRTX3TEX
If GSRESTXT = ""
  Call INTFLD("CABQ1","DMYTXT3",GSRESTXT)
Endif
Grizo [M:CAB1]ABQCOD
Grizo [M:CAB1]ABQTYP
Grizo [M:CAB1]ABQCHA
Grizo [M:CAB1]RESTYP
Grizo [M:CAB1]RESCHA
Return
###########################################################
Subprog INTFLD(LMSK,LZON,LTXT)
Value    Char LMSK
Value    Char LZON
Variable Char LTXT
If clalev([F:AMZ]) = 0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE  [ATX] : Endif
Read [AMZ]CODE=LMSK;LZON
If fstat = 0
  Call TEXTE([F:AMZ]INTIT,LTXT) From OBJDIV
Endif
End
###########################################################
$FERME
Kill GSABSTXT1
Kill GSABSTXT2
Kill GSRESTXT
Kill GSSTRTXT
Kill GSENDTXT
#
Call  IMPSCR       From ATRTX3
If GFONC1 = "GESCAB"
  Gosub SUP_GLOBALES From WUVAR
Endif
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
###########################################################
$COP_ECRAN
Call PRTSCR("CABQ1","CAB1","",0,0) From ATRTX3
Return
############################################################
$VERF_ANU
If clalev([F:CLN]) = 0 : Local File CFGLNK [CLN] : Endif
Filter [CLN] Where SYMTYP = 10             &
&                  SYMNUM = [M:CAB1]ABQNUM
&            Order By Key CLN1
For [CLN]
  Call ERREUR(mess(174,188,1)-mess([F:CLN]SYMTYPWUS,752,1)-[F:CLN]SYMNUMWUS) From GESECRAN
  OK = 0
  Break
Next 
Filter [CLN]
Return
############################################################
############################################################
Subprog COPIE(LPAR)
Value Char    LPAR
#
Local Char    W_TRA(100)
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(113,188,1)-LPAR) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(78,188,1)+" : "+LPAR
  W_OK = 2
  zonsui = "DOSDES"  
  Call DIALWIN(W_OK,mess(113,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File CFGABQ    [CAB1]
  Local File ATEXTRA   [AXX1]
Endif
# tables en ecriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".CFGABQ"    [CAB2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
Endif
# Contrôle copie possible (les elements existants doivent etre de meme nature)
Read [CAB1]CAB0=LPAR;1
If fstat 
  Goto COPIE_FIN
Endif
Read [CAB2]CAB0=LPAR;1
If fstat = 0
  If [F:CAB1]ABQTYP <> [F:CAB2]ABQTYP |
&    [F:CAB1]RESTYP <> [F:CAB2]RESTYP 
    W_TRA = [F:CAB1]ABQNUM-mess(93,188,1)
    W_ERR = 1
    Call ECR_TRACE(W_TRA,1) From GESECRAN
  Else
    W_OK = 2
    Call OUINON(mess(148,196,1),W_OK) From GESECRAN
    If W_OK <> 2
      Call OUVRE_TRACE(mess(112,188,1)-LPAR) From LECFIC
      Goto COPIE_FIN
    Endif
  Endif
Endif
Gosub OUVDOS From ATEXTRA
If W_ERR <> 0
  Goto COPIE_FIN
Endif
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Call DEBTRANS    From GLOCK
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
$TRT_COPIE
Trbegin [CAB2]
Delete [CAB2] Where ABQNUM = LPAR
# Copie abaques
Filter [CAB1] Where ABQNUM = LPAR
For [CAB1]    
  [F:CAB2] = [F:CAB1]
  [F:CAB2]CREUSR = GUSER
  [F:CAB2]CREDAT = date$
  [F:CAB2]UPDUSR = ""
  [F:CAB2]UPDDAT = [0/0/0]
  Write [CAB2]

  If fstat
    GOK = 0
    Call FSTA("CAB2") From GLOCK
    Break
  Endif
  If [F:CAB2]ABQLIN = 1
    W_TRA = mess(91,123,1)-mess(78,188,1)-[F:CAB2]ABQNUM
    Call ECR_TRACE(W_TRA,0) From GESECRAN
  Endif

  Call COPTEXTRA("CFGABQ","ABQAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
  Call COPTEXTRA("CFGABQ","ABSAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
  Call COPTEXTRA("CFGABQ","ORDAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
  Call COPTEXTRA("CFGABQ","RESAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
  If !GOK : Break : Endif
Next
Filter [CAB1] 
If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return
############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return
############################################################
Subprog AP_ABQNUM(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AS_ABQTYP(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(4) = 1
  GMENLOC(5) = 1
Endif
End
############################################################
Subprog AM_ABQTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M]ABQCHA = 0
  Affzo [M]ABQCHA
Endif
End
############################################################
Subprog AS_ABQCHA(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0 | [M]ABQTYP <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_RESTYP(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(4) = 1
  GMENLOC(5) = 1
Endif
End
############################################################
Subprog AM_RESTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M]RESCHA = 0
  Affzo [M]RESCHA
Endif
End
############################################################
Subprog AS_RESCHA(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0 | [M]RESTYP <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_STRVAL(VALEUR)
Variable Char VALEUR()
If [M]ABQCOD <> 2
  If nolign > 1
    mkstat = 2
    Case [M]ABQTYP
      When 1 : 
        VALEUR = [M]ENDVAL(nolign-2)
        [M]ALPSTRVAL(nolign-1) = [M]ALPENDVAL(nolign-2)
      When 2 :
        VALEUR = [M]ENDVAL(nolign-2)
        [M]NUMSTRVAL(nolign-1) = [M]NUMENDVAL(nolign-2)
      When 3 : 
        VALEUR = [M]ENDVAL(nolign-2)
        [M]DATSTRVAL(nolign-1) = [M]DATENDVAL(nolign-2)
    Endcase
  Endif
Endif
End
############################################################
Subprog UNICITE(LFLD,LLIG)
Value Char     LFLD
Value Shortint LLIG
Local Integer I
For I = 0 To [M]NBLIG-1
  If I <> LLIG
    If evalue(LFLD+"(I)="+LFLD+"("+num$(LLIG)+")")
      mkstat = 2
      GMESSAGE = mess(24,123,1)-num$(I+1) 
    Endif
  Endif
Next I
End
############################################################
Subprog C_STRVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYP,[M]ABQCHA,[M]ALPSTRVAL(nolign-1),
&    [M]NUMSTRVAL(nolign-1),[M]DATSTRVAL(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  Case [M]ABQTYP
    When 1 :
      If [M]ABQCOD = 2
        Call UNICITE ("[M]ALPSTRVAL",nolign-1)
      Endif
    When 2 :
      If [M]ABQCOD = 2
        Call UNICITE ("[M]NUMSTRVAL",nolign-1)
      Endif
    When 3 :
      If [M]ABQCOD = 2
        Call UNICITE ("[M]DATSTRVAL",nolign-1)
      Endif
  Endcase
Endif
End
############################################################
Subprog AS_ENDVAL(VALEUR)
Variable Char VALEUR()
If [M]ABQCOD = 2
  VALEUR = [M]STRVAL(nolign-1)
  Case [M]ABQTYP
    When 1 : [M]ALPENDVAL(nolign-1) = VALEUR
    When 2 : [M]NUMENDVAL(nolign-1) = val(VALEUR)
    When 3 : [M]DATENDVAL(nolign-1) = format$("DfZz:"+GFMDAT,VALEUR)
  Endcase
  mkstat = 2
Endif
End
############################################################
Subprog C_ENDVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYP,[M]ABQCHA,[M]ALPENDVAL(nolign-1),
&    [M]NUMENDVAL(nolign-1),[M]DATENDVAL(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  Case [M]ABQTYP
    When 1 : 
      If [M]ALPENDVAL(nolign-1) < [M]ALPSTRVAL(nolign-1) 
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Else
        Call UNICITE ("[M]ALPENDVAL",nolign-1)
      Endif
    When 2 : 
      If [M]NUMENDVAL(nolign-1) < [M]NUMSTRVAL(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Else
        Call UNICITE ("[M]NUMENDVAL",nolign-1)
      Endif
    When 3 : 
      If [M]DATENDVAL(nolign-1) < [M]DATSTRVAL(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Else
        Call UNICITE ("[M]DATENDVAL",nolign-1)
      Endif
  Endcase
Endif
End
############################################################
Subprog C_RESVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]RESTYP,[M]RESCHA,[M]ALPRESVAL(nolign-1),
&    [M]NUMRESVAL(nolign-1),[M]DATRESVAL(nolign-1),mkstat)  From CFGLIBD
End
############################################################
Subprog AP_RESTYP(VALEUR)
Variable Integer  VALEUR
Raz GMENLOC
End
############################################################
Subprog AP_ABQTYP(VALEUR)
Variable Integer  VALEUR
Raz GMENLOC
End
############################################################
Subprog C_ABQNUM(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"/")
  mkstat = 2
Endif
End
############################################################
Subprog AS_ABQCOD(VALEUR)
Variable Integer  VALEUR
If [M:CAB1]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(3) = 1
Endif
End
########################################
Subprog AM_ABSAXX(VALEUR)
Variable Char    VALEUR()
Local Char BASPAG(10)
If VALEUR <> ""
  If [M:CAB1]ABQCOD <> 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    #GSABSTXT1 = VALEUR -"["+GSSTRTXT+"]"
    #GSABSTXT2 = VALEUR -"]"+GSENDTXT+"["
    GSABSTXT1 = VALEUR -"]"+GSSTRTXT+"["
    GSABSTXT2 = VALEUR -"["+GSENDTXT+"]"
  Else
    GSABSTXT1 = VALEUR
    GSABSTXT2 = ""
  Endif
Else
  If [M:CAB1]ABQCOD <> 2
    Call INTFLD("CABQ1","DMYTXT1",GSABSTXT1)
    Call INTFLD("CABQ1","DMYTXT2",GSABSTXT2)
  Else
    Call INTFLD("CABQ1","DMYTXT0",GSABSTXT1)
    GSABSTXT2 = ""
  Endif
Endif
BASPAG = "NBLIG" 
Gosub TIT_COL From W1CABQ1
End
########################################
Subprog AM_RESAXX(VALEUR)
Variable Char    VALEUR()
Local Char BASPAG(10)
If VALEUR <> ""
  GSRESTXT = VALEUR
Else
  Call INTFLD("CABQ1","DMYTXT3",GSRESTXT)
Endif
BASPAG = "NBLIG" 
Gosub TIT_COL From W1CABQ1
End

