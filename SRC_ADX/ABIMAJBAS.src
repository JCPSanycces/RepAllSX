#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ABIMAJBAS","ABIMAJBAS",3,"") From GTRAITE
End


#------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "EXEC"        : Gosub EXEC
Endcase
Return

#------------------------------------------------------------#
$OUVRE_BATCH
$INIT
Local Integer  W , SILENCE
Local Char     MACHINE(255)
TIT = mess(8,148,1) : # SynchrofNISATION Datawarehouse
Return

#------------------------------------------------------------#
$CONTROLE
$CONT_BATCH
If [M]CODDOS=""
 SAI = 1 : Return
Endif
Return

#------------------------------------------------------------#
$INIT_DIA
Raz [M]
If PARAM(1)<>""
 [M]CODDOS = PARAM(1)
Else
 Local File ABIDATWRH [ABW]
 For [ABW] Where LAN=GLANGUE
  Call MACHINE_BO([F:ABW]SOLBI,MACHINE) From ABICREBAS
  If MACHINE<>"" & filinfo(filpath("","","",[F:ABW]COD,"",MACHINE),0)>0
   If filinfo(filpath("FIL","ADOVAL","fde",[F:ABW]COD,"",MACHINE),0)<0
    [M]CODDOS = [F:ABW]COD
    Break
   Endif
  Endif
 Next ABW
 Close Local File [ABW]
Endif
Return

#------------------------------------------------------------#
$EXEC
# Affichage boîte d'info ??
If GSERVEUR
 SILENCE = 1
Else
 SILENCE = 0
 TRA = 1
Endif

If TRA
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If !SILENCE
 Call OUVRE_VLC(TIT-[M]CODDOS,"","") From GESECRAN
Endif
Call SYNCHRO(nomap,[M]CODDOS,SILENCE
&    , [M]TYPVAL , [M]GEN , [M]DET , [M]EPUAUD , [M]SIMU , [M]SACC , [M]SDAT , [M]SDOS , [M]SAUZ , [M]SMEN , [M]SADI , [M]SDIM
&    , [M]SFAT , [M]SAGG , [M]DEBACC , [M]FINACC , [M]DEBDAT , [M]FINDAT , [M]DEBAUZ , [M]FINAUZ
&    , [M]DEBMEN , [M]FINMEN , [M]DEBADI , [M]FINADI , [M]DEBDIM , [M]FINDIM , [M]DEBFAT , [M]FINFAT
&    , [M]DEBAGG , [M]FINAGG)
Call ECR_TRACE("",0) From GESECRAN
If !SILENCE
 Call FERME_VLC From GESECRAN
Endif

If TRA
 Call FERME_TRACE From LECFIC
Endif
Return

#-----------------#
$INFO
Call ECR_TIME(mess(9,148,1)-INFO) From DOSSUB : # Synchronisation de la table
If !SILENCE
 K = instr(1,INFO,"-")
 If K : INFO = left$(INFO,K-1) : Endif
 Call AFF_VLC(mess(9,148,1),INFO) From GESECRAN : # Synchronisation de la table
Endif
Return

#----------------------------------------------------------------------------------------------------#
Subprog SYNCHRO(APPLI,DATWAR,SILENCE
&            , TYPVAL , GEN , DET , EPUAUD , SIMU , SACC , SDAT , SDOS , SAUZ , SMEN , SADI , SDIM
&            , SFAT , SAGG , DEBACC , FINACC , DEBDAT , FINDAT , DEBAUZ , FINAUZ
&            , DEBMEN , FINMEN , DEBADI , FINADI , DEBDIM , FINDIM , DEBFAT , FINFAT
&            , DEBAGG , FINAGG)
Value Char     APPLI , DATWAR
Value Integer  SILENCE
Value Integer  TYPVAL , GEN , DET , EPUAUD , SIMU , SACC , SDAT , SDOS , SAUZ , SMEN , SADI , SDIM , SFAT , SAGG
Value Char     DEBACC , FINACC
Value Date     DEBDAT , FINDAT
Value Char     DEBAUZ , FINAUZ
Value Integer  DEBMEN , FINMEN , DEBADI , FINADI
Value Char     DEBDIM , FINDIM , DEBFAT , FINFAT , DEBAGG , FINAGG

Local Char     PREF(5) , TABLE(30) , TABORG(30) , USRADM(30) , ACTION(20)
Local Char     MACHINE(GDIMFIC) , DOSSIER(GDIMFIC) , OUVTAB(GDIMFIC)
Local Date     DAT , UDAT , CDAT
Local Char     ORDSYS(250)
Local Date     DATMAJ
Local Integer  I , J , K , N , NUM , OK , D , W , R , III , NBA, NBN ,II
Local Integer  CRE , MAJ , SUP , ER , ERFIC , ERFOR , LEC , INTE , OKTRT , STAT, CAS
Local Integer  OKTRTSTD,OKTRTSPE,OKTRTSPV
Local Char     NOMPRG(GLONADC+1) , PRGAGG(GLONADC+1)
Local Char     CHAINE(255) , ZON(GLONAVA) , RUPTURE(250)
Local Char     CRITERE(255) , CRITERE2(255)
Local Integer  MAXUSR , MAXREP , MAXFIC , MAXDOS , MAXFLD , MAXCLE , MAXORG , MAXREG , MAXDIM
Local Integer  LSYNCDIM      # =[V]CST_AYES to synchronize dimensions using same origin tables as fact tables that are synchronized
LSYNCDIM=[V]CST_AYES    # This value can be modified in an entry point (e.g. INITMAX)

MAXUSR = 1000
MAXREP = 500
MAXFIC = 500
MAXDOS = 20
MAXFLD = 250
MAXCLE = 16
MAXORG = 100
MAXREG = 100
MAXDIM = 1000

GPOINT = "INITMAX" : Gosub ENTREE From EXEFNC : # Init max

Local Integer  NBUSR , NBREP , NBFIC , NBDOS , NBFLD , NBORG , NBADX , NBREG
Local Char     LISFIC(30)(1..MAXFIC) , TBADX(250)(1..MAXDOS)
Local Schar    TBDOS(GDIMFIC)(1..MAXDOS)
Local Schar    TBREG(GLONABV)(1..MAXREG) , TBFAT(GLONABF)(1..MAXREG) , TBAPP(GDIMFIC)(1..MAXREG)
Local Integer  TBRAZ(1..MAXREG)
Local Schar    TBUSR(30)(1..MAXUSR) , TBPRF(GLONAFT)(1..MAXUSR)
Local Schar    TBREP(30)(1..MAXREP) , TBFNC(GLONAFC)(1..MAXREP)
Local Integer  NBTCLE , NBCLE , NBVAL , OKRAZFAT , TTYP(1..MAXCLE)
Local Char     TCLE(GLONAVA)(1..MAXCLE) , CLE(GLONAVA)(1..MAXCLE)
Local Char     INFO(100) , FORMULE(250) , FLD(30) , TABR(GLONABR) , VALCLE(GLONID2)(1..MAXCLE)
Local Char     TBFLD(GLONAVA)(1..MAXFLD) , TBFOR(250)(1..MAXFLD) , TBNUM(10)(1..MAXFLD)
Local Schar    TBORG(GLONATB)(1..MAXORG),ABR_TABORG(GLONABR)
Local Integer  TBMES(1..MAXFLD) , TBTYP(1..MAXFLD) , ITYP

Local Clbfile  B_CRITERE(3)
Local Integer  B_STOP , B_BREAK , B_NBENREG

Local Integer  NDDIM,NBLISTDOS,NBTAB
Local Char     TDAPP(GDIMFIC)(1..MAXDIM),TDDIM(GLONABI)(1..MAXDIM),LISTDOS(250)(MAXDOS),TABLES(GLONATB)(1..MAXFIC)

Local Char     RUPTTBL(GLONATB),RUPTURE(250),RUPTURE2(250), EVTFIRST,EVTLAST
Local Integer  SEQFISRT , SEQLAST, WSEQ

Local Integer  SPECRE

Global Integer GCAS
Local Integer  FLGAUDITBI
Local Char     TABAUDIT

Local Integer  NBRAZDIM
Local Char     RAZDIM(GLONABI)(1..MAXDIM), FMDDATSAV(20)

Local Char    DOSAUD(GLONADS)(0..25),CRITAUD(250)
Local Integer NBDOSAUD, NBDATAWAREHOUSE
Local Decimal MAXAUD(0..25)

Local Clbfile FLTDELINC(0)  # Will get the filter necessary to find a record to delete in a dimension
Local Integer NBFLD
Local Char    FLDDIM(255)(1..)
Local Char    FLDORG(255)(1..)
Local Char    MSGERR(255)
Local Integer CTLAUZINCDEL  # =[V]CST_AYES if the control of incremental deletion must be done. This control will be done only once per dimension
Local Integer AUZINCDEL     # =[V]CST_AYES if deletion can be done in incremental mode

# X3-76739 - JPGA - 2018-05-31 : BEGIN - In Multi-Datawarehouse for a folder, we need to update rights for the current one used
If clalev([F:ABW])=0 : Local File =APPLI+".ABIDATWRH" [ABW] : Endif
Filter [ABW] : [L]NBDATAWAREHOUSE=rowcount([ABW])
# X3-76739 - JPGA - 2018-05-31 : END   - In Multi-Datawarehouse for a folder, we need to update rights for the current one used

If clalev([F:ABV])=0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
If clalev([F:ABY])=0 : Local File =APPLI+".ABIREGDES" [ABY] : Endif
If clalev([F:ABZ])=0 : Local File =APPLI+".ABITABFLD" [ABZ] : Endif
If clalev([F:ABI])=0 : Local File =APPLI+".ABIDIM"    [ABI] : Endif
If clalev([F:ABJ])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ] : Endif
If clalev([F:ABF])=0 : Local File =APPLI+".ABITABDAT" [ABF] : Endif
If clalev([F:ABE])=0 : Local File =APPLI+".ABITABAGG" [ABE] : Endif
If clalev([F:ABO])=0 : Local File =APPLI+".ABIREPORT" [ABO] : Endif
If clalev([F:ABM])=0 : Local File =APPLI+".ABIDATMRT" [ABM] : Endif
If clalev([F:AC2])=0 : Local File =APPLI+".ACTIV"     [AC2] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER            [ADS] : Endif

If clalev([F:ATB]) : Close Local File [ATB] : Endif
If clalev([F:ATI]) : Close Local File [ATI] : Endif
If clalev([F:ATY]) : Close Local File [ATY] : Endif
If clalev([F:AXX]) : Close Local File [AXX] : Endif
If clalev([F:ATX]) : Close Local File [ATX] : Endif
If clalev([F:ADI]) : Close Local File [ADI] : Endif
If clalev([F:ACC]) : Close Local File [ACC] : Endif
If clalev([F:AUS]) : Close Local File [AUS] : Endif
If clalev([F:AST]) : Close Local File [AST] : Endif
If clalev([F:AFF]) : Close Local File [AFF] : Endif

USRADM   = "Administrator"
DATMAJ   = date$
OKRAZFAT = 1

## Pour les dimesions
Local File ATYPE [DATY]

Read [ABW]ABW0=DATWAR
If fstat
 Call ECR_TRACE(DATWAR-":"-mess(1,148,1),1) From GESECRAN : # Datawarehouse inexistante
 End
Else
 Call MACHINE_BO([F:ABW]SOLBI,MACHINE) From ABICREBAS
 If MACHINE=""
  Call ECR_TRACE([F:ABW]COD-":"-mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
  End
 Elsif filinfo(filpath("FIL","","",[F:ABW]COD,"",MACHINE),0)<0
  Call ECR_TRACE([F:ABW]COD-":"-mess(1,148,1),1) From GESECRAN : # Datawarehouse inexistante
  End
 Elsif filinfo(filpath("FIL","ADOVAL","fde",[F:ABW]COD,"",MACHINE),0)>0
  Call TYPDOS(MACHINE+"@"+[F:ABW]COD,K,CHAINE) From DOSCONT
  # Ce dossier correspond à une application
  Call ECR_TRACE([F:ABW]COD-":"-mess(208,139,1)-CHAINE,1) From GESECRAN
  End
 Elsif filinfo(filpath("","synchro","",[F:ABW]COD,"",MACHINE),0)>0 & 0
  # Resynchronisation en cours
  Call ECR_TRACE([F:ABW]COD-":"-mess(148,124,1),1) From GESECRAN
  End
 Elsif filinfo(filpath("","valid","",[F:ABW]COD,"",MACHINE),0)>0
  # En cours de validation
  Call ECR_TRACE([F:ABW]COD-":"-mess(128,117,1),1) From GESECRAN
  End
 Elsif filinfo(filpath("","epuration","",[F:ABW]COD,"",MACHINE),0)>0
  # En cours de validation
  Call ECR_TRACE([F:ABW]COD-":"-mess(146,148,1),1) From GESECRAN
  End
 Else
  Call VERF_REFBO(MACHINE,[F:ABW]COD,CHAINE,OK) From SUBABW
  If !OK
   # Ce datawarehouse est utilisé par le dossier #
   Call ECR_TRACE(func AFNC.MES(mess(98,148,1),CHAINE),-1) From GESECRAN
   End
  Endif
 Endif
Endif

Call ECR_TRACE(mess(8,148,1)-[F:ABW]COD,0) From GESECRAN : # Synchronisation Datawarehouse

ORDSYS = "lsadx -a"-[F:ABW]COD-"FIL fde"
Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS
If NBFIC<=0 : End : Endif

# Droits sur le dossier

Call SET_DROITS From TRTGRANT

# adxodbc adxora
#Call SETADXORA_ADXODBC(APPLI,DATWAR,OK) From ABICREBAS
GPE = 0
GPOINT = "SETMACHINE" : Gosub ENTREE From EXEFNC : # set MACHINE
# X3-76739 - JPGA - 2018-05-31 : In Multi-Datawarehouse for a folder ([L]NBDATAWAREHOUSE>1), we need to update rights for the current one used
If GPE or ([L]NBDATAWAREHOUSE>1)
  If ([L]NBDATAWAREHOUSE>1) :  Call ECR_TRACE(func AFNC.MES1(mess(168,148,1),num$([L]NBDATAWAREHOUSE)),0) From GESECRAN : Endif : # N DatawareHouses existent sur ce dossier, droits d'accès MAJ
  Call CREDROIT(APPLI,2,OK) From ABICREBAS
  If !OK : Goto FIN : Endif
Endif

# Dossiers de référence X3

Raz NBDOS
For I=1 To [F:ABW]NBRDOS
 If [F:ABW]ADXDOS(I-1)<>""
  NBDOS += 1
  TBDOS(NBDOS) = [F:ABW]ADXDOS(I-1)
 Endif
Next I
If NBDOS=0
 NBDOS += 1
 TBDOS(NBDOS) = APPLI
Endif

FLGAUDITBI=1

Call EXISTE_ADX("","","SPETRIGGER",OKTRT) From ORDSYS
If OKTRT>0
 Onerrgo RIEN
 ACTION = "AVTRIG"
 Gosub ACTION From SPETRIGGER
 Onerrgo
Endif

If FLGAUDITBI>0
 FLGAUDITBI = (filinfo(filpath("FIL","AUDITBI","fde",APPLI),0)>0)
Endif

If !FLGAUDITBI
 TABAUDIT = "AUDITH"
Else
 TABAUDIT = "AUDITBI"
Endif

# Mise en memoire du max de audith
Onerrgo RIEN
Call EXISTE_ADX("","","ABIMAJBASB",OKTRT) From ORDSYS : # 118250
If OKTRT>0
 ACTION = "AV_AUDIT"
 Gosub ACTION From ABIMAJBASB
Endif
For [ADS]DOSSIER
 If filinfo(filpath("FIL",TABAUDIT,"fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+"."+TABAUDIT [AUD_]
  Read [AUD_]AUD0 Last
  If !fstat
   DOSAUD(NBDOSAUD) = [F:ADS]DOSSIER
   MAXAUD(NBDOSAUD) = [F:AUD_]SEQ
   NBDOSAUD += 1
  Endif
  Close Local File [AUD_]
 Endif
Next
Onerrgo

# Synchronisation des dimensions superviseur

For N=1 To NBFIC
 If left$(LISFIC(N),3)="AX3"
  TABLE = LISFIC(N)
  INFO = TABLE
  Case TABLE
   When "AX3ACC"    : If [L]SACC=2 : Gosub MAJ_AX3ACC : Endif
   When "AX3DAT"    : If [L]SDAT=2 : Gosub MAJ_AX3DAT : Endif
   When "AX3DOS"    : If [L]SDOS=2 : Gosub MAJ_AX3DOS : Endif
   When "AX3FCTFCY" : If [L]SAUZ=2 : Gosub MAJ_AX3FCTFCY : Endif
   When Default
    Case left$(LISFIC(N),6)
     When "AX3MNL"  : If [L]SMEN=2 : Gosub MAJ_AX3MNL : Endif
     When "AX3ADI"  : If [L]SADI=2 : Gosub MAJ_AX3ADI : Endif
    Endcase
  Endcase
 Endif
Next N

# Synchronisation des autres dimensions

Raz LISTDOS,NBLISTDOS,NBORG
If [L]SDIM=2
 CRITERE  = 'CODDIM>="'+[L]DEBDIM+'"'
 If [L]FINDIM<>""
  CRITERE += ' & CODDIM<="'+[L]FINDIM+'"'
 Else
  CRITERE += ' & CODDIM<="ZZZZZZZZZZ"'
 Endif

 ## tableau table origine
 If [L]GEN<>2
  For [ABI] Where evalue(CRITERE)
   If [F:ABI]TYPMAJ=3
    TABLE = 'D_'+[ABI]CODDIM
    If find(TABLE,LISFIC(1..NBFIC))
     For J=1 To [F:ABI]NBRDOS
      If [F:ABI]ADXDOS(J-1)<>""
       K += 1
       NDDIM += 1
       TDAPP(NDDIM) = [F:ABI]ADXDOS(J-1)+"~"+[F:ABI]TABORG
       TDDIM(NDDIM) = [F:ABI]CODDIM
       If !find([F:ABI]TABORG,TBORG(1..NBORG))
        NBORG += 1
        TBORG(NBORG) = [F:ABI]TABORG
       Endif
      Endif
     Next J
     If !K
      NDDIM += 1
      TDAPP(NDDIM) = APPLI+"~"+[F:ABI]TABORG
      TDDIM(NDDIM) = [F:ABI]CODDIM
      If !find([F:ABI]TABORG,TBORG(1..NBORG))
       NBORG += 1
       TBORG(NBORG) = [F:ABI]TABORG
      Endif
     Endif
    Endif
   Endif
  Next
 Endif

 NBRAZDIM = 0
 For [ABI] Where evalue(CRITERE)
  TABLE = 'D_'+[ABI]CODDIM
  If find(TABLE,LISFIC(1..NBFIC)) : # & func TABLEORI_ABV([ABI]CODDIM)>0 : 84447 CCL BI : desactivation regle de synchro/dimension ^m table orig.
   If  ([F:ABI]TYPMAJ<>3 or [L]GEN=2)
    NBRAZDIM         += 1
    RAZDIM(NBRAZDIM)  = [ABI]CODDIM
    If [F:ABI]TYPMAJ= 3
     If !find([F:ABI]TABORG,TBORG(1..NBORG))
      NBORG += 1
      TBORG(NBORG) = [F:ABI]TABORG
     Endif
    Endif
   Endif
  Endif
 Next ABI

 For III=1 To NBRAZDIM
  Read [F:ABI]ABI0 = RAZDIM(III)
  If !fstat
   TABLE = 'D_'+[ABI]CODDIM
   Gosub MAJ_DIM
  Endif
 Next

Endif

# Si pas de mise à jour de tables de faits/aggrégats
# on remets NBORG (compteur table origine) à 0
If [L]SFAT=1 and [L]SAGG=1
 Raz [L]TBORG,[L]TBORG
Endif

# Recherche des tables de faits à traiter

If [L]SFAT=2 or [L]SAGG=2 or NBORG<>0
 If [L]SFAT=2 or [L]SAGG=2
  If [L]SFAT=2
   CRITERE  = '[F:ABY]TABDES>="'+[L]DEBFAT+'"'
   If [L]FINFAT<>""
    CRITERE += ' & [F:ABY]TABDES<="'+[L]FINFAT+'"'
   Else
    CRITERE += ' & [F:ABY]TABDES<="ZZZZZZZZZZ"'
   Endif
  Else
   CRITERE = "1=1"
  Endif

  # Recherche des tables origine

  For [ABY]ABY2(2) Where evalue(CRITERE)
   TABLE = 'F_'+[F:ABY]TABDES
   If find(TABLE,LISFIC(1..NBFIC))
    Read [ABV]ABV0=[F:ABY]CODREG
    If !fstat & !find([F:ABV]TABORG,TBORG(1..NBORG)) & (dim([F:ABV]DESFLG)<0 or (dim([F:ABV]DESFLG)>0 & [F:ABV]DESFLG<>2))
     If !find([F:ABV]TABORG,TBORG(1..NBORG))
      NBORG += 1
      TBORG(NBORG) = [F:ABV]TABORG
     Endif
    Endif
   Endif
  Next ABY2(2)
 Endif

 # Remplissage du tableau des tables de parcours
 Raz NBREG
 For I=1 To NBORG
  For [ABV]ABV0 Where TABORG=TBORG(I)
   If (dim([F:ABV]DESFLG)<0 or (dim([F:ABV]DESFLG)>0 & [F:ABV]DESFLG<>2))
    Raz TABLE
    For [ABY]ABY2 Where CODREG=[F:ABV]CODREG
     If find('F_'+[F:ABY]TABDES,LISFIC(1..NBFIC))
      TABLE = [F:ABY]TABDES : Break
     Endif
    Next ABY2(2)
    # Si Table de fait début=table de fait fin, alors on ne traite que la table de fait saisie, et pas les autres
    If [L]DEBFAT=[L]FINFAT and DEBFAT<>""
     If [L]TABLE<>[L]DEBFAT
      [L]TABLE=""
     Endif
    Endif
    # Si table de fait début et fin difféérentes # Alors on regarde si table de fait à mettre à jour # Est comprise en début et fin
    If [L]DEBFAT<>[L]FINFAT
     If [L]TABLE<[L]DEBFAT
      [L]TABLE=""
     Endif
     If [L]TABLE>[L]FINFAT
      [L]TABLE=""
     Endif
    Endif
    If TABLE<>""
     Read [ABF]ABF0=TABLE
     K = 0
     For J=1 To [F:ABV]NBRDOS
      If [F:ABV]ADXDOS(J-1)<>""
       K += 1
       NBREG += 1
       TBAPP(NBREG) = [F:ABV]ADXDOS(J-1)+"~"+TBORG(I)
       TBREG(NBREG) = [F:ABV]CODREG
       TBFAT(NBREG) = TABLE
       TBRAZ(NBREG) = ([F:ABF]TYPMAJ=2) : # Annule et remplace
      Endif
     Next J
     If !K
      NBREG += 1
      TBAPP(NBREG) = APPLI+"~"+TBORG(I)
      TBREG(NBREG) = [F:ABV]CODREG
      TBFAT(NBREG) = TABLE
      TBRAZ(NBREG) = ([F:ABF]TYPMAJ=2) : # Annule et remplace
     Endif
    Endif
   Endif
  Next ABV
 Next I
Endif

#### recherch edimension a traiter par rapport aux table de fait traitéses, si elle partage la meme table de fait.
If  [L]GEN<>2
& & LSYNCDIM=[V]CST_AYES        # Issue X3-59123 - 2018-07-03 by CCC : allow to avoid synchronization of dimensions with fact tables
 For I=1 To NBORG
  For [ABI] Where TABORG=TBORG(I)  & find([F:ABI]TYPMAJ,1,3)>0
   TABLE = 'D_'+[ABI]CODDIM
   K =0
   If find(TABLE,LISFIC(1..NBFIC))
    For J=1 To [F:ABI]NBRDOS
     If [F:ABI]ADXDOS(J-1)<>""
      K += 1
      If !find([F:ABI]ADXDOS(J-1)+"~"+[F:ABI]TABORG,TDAPP(1..NDDIM))
       NDDIM += 1
       TDAPP(NDDIM) = [F:ABI]ADXDOS(J-1)+"~"+[F:ABI]TABORG
       TDDIM(NDDIM) = [F:ABI]CODDIM
      Endif
     Endif
    Next J
    If !K
     If !find(APPLI+"~"+[F:ABI]TABORG,TDAPP(1..NDDIM))
      NDDIM += 1
      TDAPP(NDDIM) = APPLI+"~"+[F:ABI]TABORG
      TDDIM(NDDIM) = [F:ABI]CODDIM
     Endif
    Endif
   Endif
  Next
 Next I
Endif

#### Maj des dimension en audit incrementale
If [L]NDDIM>0
 # Synchro inc audit
 Onerrgo ERR
 Sorta NDDIM TDAPP,TDDIM Order By TDAPP(indice+1)
 For R=1 To NDDIM
  K = 0
  If RUPTURE=""
   K = 1
  Elsif TDAPP(R)<>RUPTURE
   K = 1
  Endif
  If K
   RUPTURE = TDAPP(R)
   If !find(TDDIM(R),RAZDIM)
    If TDDIM(R)<>[F:ABI]CODDIM
     Read [F:ABI]ABI0 = TDDIM(R)
    Endif
    If  [L]GEN=2
     TABLE = 'D_'+[ABI]CODDIM
     Gosub MAJ_DIM
    Else
     Gosub MAJ_INCDIM
    Endif
   Endif
  Endif
 Next
 Onerrgo
Endif

If NBREG<>0
 Onerrgo ERR
 # Raz des tables de faits
 Sorta NBREG TBFAT,TBAPP,TBREG,TBRAZ Order By TBFAT(indice+1)
 RUPTURE = ""
 For R=1 To NBREG
  K = 0
  If RUPTURE=""
   K = 1
  Elsif TBFAT(R)<>RUPTURE
   K = 1
  Endif
  If K
   RUPTURE = TBFAT(R)
   If TBRAZ(R) or [L]GEN=2
    Call RAZ_TABLE(MACHINE,[F:ABW]COD,'F_'+TBFAT(R),[L]SIMU)
   Endif
  Endif
 Next R
 # Synchronisation

 Sorta NBREG TBAPP,TBFAT,TBREG,TBRAZ Order By TBAPP(indice+1)
 RUPTURE = ""
 For R=1 To NBREG
  K = 0
  If RUPTURE=""
   K = 1
  Elsif TBAPP(R)+num$(TBRAZ(R))<>RUPTURE
   K = 1
  Endif
  If K
   RUPTURE = TBAPP(R)+num$(TBRAZ(R))
   ERFIC = 0
   Raz OKTRTSTD,OKTRTSPE,OKTRTSPV
   Onerrgo ERFIC
   If clalev([ATY]) : Close Local File [ATY] : Endif
   If clalev([ATB]) : Close Local File [ATB] : Endif
   If clalev([ATI]) : Close Local File [ATI] : Endif
   If clalev([AXX]) : Close Local File [AXX] : Endif
   If clalev([ATZ]) : Close Local File [ATZ] : Endif
   K = instr(1,TBAPP(R),"~")
   OUVTAB = left$(TBAPP(R),K-1)+".ATYPE"   : Local File =OUVTAB [ATY]
   OUVTAB = left$(TBAPP(R),K-1)+".ATABLE"  : Local File =OUVTAB [ATB]
   OUVTAB = left$(TBAPP(R),K-1)+".ATABIND" : Local File =OUVTAB [ATI]
   OUVTAB = left$(TBAPP(R),K-1)+".ATEXTRA" : Local File =OUVTAB [AXX]
   OUVTAB = left$(TBAPP(R),K-1)+".ATABZON" : Local File =OUVTAB [ATZ]
   Onerrgo ERR
   If !ERFIC
    Read [ABV]ABV0=TBREG(R)
    Raz SPECRE
    If [F:ABV]TRTSTD<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSTD,OKTRTSTD) From ORDSYS : Endif
    If dim([F:ABV]TRTSPE)>0 & [F:ABV]TRTSPE<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPE,OKTRTSPE) From ORDSYS : Endif
    If dim([F:ABV]TRTSPV)>0 & [F:ABV]TRTSPV<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPV,OKTRTSPV) From ORDSYS : Endif
    ACTION = "AVANT_FAT" : Gosub ACTIONF
    If TBRAZ(R) or [L]GEN=2
     Gosub MAJ_RAZ_FAT
    Else
     Gosub MAJ_INC_FAT
    Endif
   Endif
  Endif
 Next R
 Onerrgo RIEN
 Close Local File [ATY] , [ATB] , [ATI] , [AXX] , [ATZ]
 Onerrgo
Endif

# Synchronisation des tables agrégats à partir des tables de faits

If [L]SAGG=2
 Onerrgo ERR
 Sorta NBREG TBFAT,TBAPP,TBREG,TBRAZ Order By TBFAT(indice+1)
 RUPTURE = ""
 For R=1 To NBREG
  K = 0
  If RUPTURE=""
   K = 1
  Elsif TBFAT(R)<>RUPTURE
   K = 1
  Endif
  If K
   RUPTURE = TBFAT(R)
   If TBRAZ(R) or [L]GEN=2 or [L]SFAT<>2
    Gosub MAJ_RAZ_AGG
   Endif
  Endif
 Next R
 Onerrgo
Endif

If [L]SIMU=2      : Goto FIN : Endif
If [L]EPUAUD=2  : Goto FIN : Endif
If [L]GEN=2       : Goto FIN : Endif

### mise a jour audit flag stabi= 4 ----> 3 pour les tables de faits
For I=1 To NBREG
 K = instr(1,TBAPP(I),"~")
 If filinfo(filpath("FIL",TABAUDIT,"fde",left$(TBAPP(I),K-1)),0)>0
  Local File =left$(TBAPP(I),K-1)+"."+TABAUDIT [AUD_]
  CRITAUD = func CRITAUD(left$(TBAPP(I),K-1),DOSAUD,MAXAUD,NBDOSAUD)
  Trbegin [AUD_]
   Update [AUD_] Where STABI=4 & evalue(CRITAUD) With STABI=3
  Commit
 Endif
 Close Local File [AUD_]
Next

### mise a jour audit flag stabi= 4 ----> 3 pour les tables de faits
For I=1 To NDDIM
 K = instr(1,TDAPP(I),"~")
 If filinfo(filpath("FIL",TABAUDIT,"fde",left$(TDAPP(I),K-1)),0)>0
  Local File =left$(TDAPP(I),K-1)+"."+TABAUDIT [AUD_]
  CRITAUD = func CRITAUD(left$(TDAPP(I),K-1),DOSAUD,MAXAUD,NBDOSAUD)
  Trbegin [AUD_]
   Update [AUD_] Where STABI=4 & evalue(CRITAUD) With STABI=3
  Commit
 Endif
 Close Local File [AUD_]
Next

$FIN
#CloseCom MACHINE
End

#-------#
$ERR
ER = errn
Call ECR_TRACE(errp+"("+num$(errl)+")"-mess(6,123,1)-num$(ER)-errmes$(ER)-errm,1) From GESECRAN
Resume

#-------#
$ERFIC
ERFIC = errn
Call ECR_TRACE(mess(196,133,1)-":|"-OUVTAB+"|"-errmes$(ERFIC)-"|"-errm,1) From GESECRAN
Resume

#-------#
$ERFOR
ERFOR = errn
Call ECR_TRACE(FLD-":"-mess(65,106,1)-FORMULE+"\"+errmes$(ERFOR)-errm,1) From GESECRAN
Resume

#-------#
$RIEN
Resume

#-----------------------------------------------------------------#
$MAJ_AX3DAT
If [L]DEBDAT=[0/0/0] : Return : Endif
Gosub INFO
If [L]GEN=2
 Call ECR_TRACE("***"-mess(170,100,1)+"("+DOSSIER-"AX3DOS"+")",0) From GESECRAN : # Raz fichier
Endif

If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

DAT = [L]DEBDAT-1
CRE = 0
Trbegin [AAA_]
 If [L]GEN=2
  Delete [AAA_] Where 1=1
 Else
  Delete [AAA_] Where DATDAT>=[L]DEBDAT & DATDAT<=[L]FINDAT
 Endif
 While DAT<[L]FINDAT
  DAT += 1
  Raz [AAA_]
  GPE = 0
  GPOINT = "MAJDAT" : Gosub ENTREE From EXEFNC : # Bug 82436 pouvoir modifier la table AX3DAT
  If GPE=0
   Raz [AAA_]
   [F:AAA_]DATDAT = DAT
   Call MAJDAT([F:AAA_]DATDAY,1,DAT)
   Call MAJDAT([F:AAA_]DATWEK,2,DAT)
   Call MAJDAT([F:AAA_]DATDEC,3,DAT)
   Call MAJDAT([F:AAA_]DATQUI,4,DAT)
   Call MAJDAT([F:AAA_]DATMOI,5,DAT)
   Call MAJDAT([F:AAA_]DATTRE,6,DAT)
   Call MAJDAT([F:AAA_]DATSIX,7,DAT)
   Call MAJDAT([F:AAA_]DATYEA,8,DAT)
   Write [AAA_]
   If fstat
    Call ERREUR(TABLE-num$(DAT),1) From DOSDIC
   Else
    CRE += 1
   Endif
  Endif
 Wend
 # Création d'un enregistrement vide
 Raz [AAA_]
 Read [AAA_] =
 If !fstat
  Rewrite [AAA_]
 Else
  Write [AAA_]
 Endif
Commit

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(CRE)-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#-----------------------------------------------------------------#
Subprog MAJDAT(VALDAT,TYPDAT,REFDAT)
Variable Char    VALDAT
Value    Integer TYPDAT
Value    Date    REFDAT
Local Integer K
Case TYPDAT
 When 1 : # Jour
  VALDAT = format$("N0:3#",nday(REFDAT)-(nday(gdat$(1,1,year(REFDAT)))-1))
 When 2 : # Semaine
  VALDAT = format$("N0:2#",week(aweek(week(REFDAT),year(REFDAT))))
  VALDAT -= num$(year(aweek(week(REFDAT),year(REFDAT))))
 When 3 : # Décade
  If day(REFDAT)>20    : K = 3
  Elsif day(REFDAT)>10 : K = 2
  Else                 : K = 1
  Endif
  VALDAT = num$(K)-format$("N0:2#",month(REFDAT))-num$(year(REFDAT))
 When 4 : # Quinzaine
  If day(REFDAT)>15 : K = 2
  Else              : K = 1
  Endif
  VALDAT = num$(K)-format$("N0:2#",month(REFDAT))-num$(year(REFDAT))
 When 5 : # Mois
  VALDAT = format$("N0:2#",month(REFDAT))-num$(year(REFDAT))
 When 6 : # Trimestre
  If month(REFDAT)>9    : K = 4
  Elsif month(REFDAT)>6 : K = 3
  Elsif month(REFDAT)>3 : K = 2
  Else                  : K = 1
  Endif
  VALDAT = num$(K)-num$(year(REFDAT))
 When 7 : # Semestre
  If month(REFDAT)>6 : K = 2
  Else               : K = 1
  Endif
  VALDAT = num$(K)-num$(year(REFDAT))
 When 8 : # Année
  VALDAT = num$(year(REFDAT))
Endcase
End

#-----------------------------------------------------------------#
$MAJ_AX3DOS
Gosub INFO

Call ECR_TRACE("***"-mess(170,100,1)+"("+DOSSIER-"AX3DOS"+")",0) From GESECRAN : # Raz fichier

If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

Trbegin [AAA_]
 Delete [AAA_] Where 1=1
 For D=1 To NBDOS
  Raz [F:AAA_]
  K = instr(1,TBDOS(D),"@")
  If K
   [F:AAA_]CODDOS = right$(TBDOS(D),K+1)
  Else
   [F:AAA_]CODDOS = TBDOS(D)
  Endif
  [F:AAA_]ADXDOS = TBDOS(D)
  Write [AAA_]
  If fstat
   Call ERREUR(TABLE-TBDOS(D),1) From DOSDIC
  Endif
 Next D
 # Création d'un enregistrement vide
 Raz [AAA_]
 Write [AAA_]
Commit

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#-----------------------------------------------------------------#
$MAJ_AX3ACC
Gosub INFO
Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)
If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

CRITERE  = 'ACC>="'+[L]DEBACC+'"'
CRITERE2 = 'CODACC<>"" & CODACC>="'+[L]DEBACC+'"'
If [L]FINACC<>""
 CRITERE += ' & ACC<="'+[L]FINACC+'"'
 CRITERE2 += ' & CODACC<="'+[L]FINACC+'"'
Else
 CRITERE += ' & ACC<="ZZZZZZZZZZ"'
 CRITERE2 += ' & CODACC<="ZZZZZZZZZZ"'
Endif

#CHECK UNUSED_BEGIN
GPE = 0
GPOINT = "MAJAX3ACC" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
If GPE=0
 Local Char WUSRBI(10)
 For D=1 To NBDOS
  ERFIC = 0
  Onerrgo ERFIC
  OUVTAB = TBDOS(D)+".ACCES"     : Local File =OUVTAB [ACC]
  OUVTAB = TBDOS(D)+".AUTILIS"   : Local File =OUVTAB [AUS]
  OUVTAB = TBDOS(D)+".ABIPRFUSR" : Local File =OUVTAB [AIU]
  OUVTAB = TBDOS(D)+".ACCCOD"    : Local File =OUVTAB [ACS]
  OUVTAB = TBDOS(D)+".AMETUTI"   : Local File =OUVTAB [AME]
  Onerrgo
  If !ERFIC
   If !SILENCE
    Call OUVRE_BOITE(TBDOS(D),100) From GESECRAN
    Call SET_BOITE(TABLE,nbrecord([F:ACC])) From GESECRAN
   Endif
   Raz NBUSR
   For [AIU]AIU0
    NBUSR += 1
    TBUSR(NBUSR) = [F:AIU]USR
   Next AIU
   If NBUSR=0
    NBUSR += 1
    TBUSR(NBUSR) = USRADM
   Endif
   Trbegin [AAA_]
    LEC = 0
    For [ACC] Where evalue(CRITERE2) & CONSUL=2
     If !SILENCE
      LEC += 1
      Call AFF_BOITE("",LEC,INTE) From GESECRAN
     Endif
     Raz [F:AAA_]
     If [F:AUS]USR<>[F:ACC]USR
         Read [AUS]CODUSR=[F:ACC]USR
     Endif
     If [F:AUS]USRBI=""
      Read [AME]AME0 = [F:AUS]CODMET
      WUSRBI = [F:AME]USRBI
     Else
      WUSRBI = [F:AUS]USRBI
     Endif
     If [F:AUS]USR=[F:ACC]USR & WUSRBI<>""
      If [F:AIU]PRF<>WUSRBI
          Read [AIU]AIU0=WUSRBI
      Endif
      If [F:AIU]PRF=WUSRBI
       Read [AAA_]AXAC0=[F:AIU]USR;[F:ACC]CODACC
       If fstat
        [F:AAA_] = [F:ACC]
        [F:AAA_]ACC = [F:ACC]CODACC
        [F:AAA_]USR = [F:AIU]USR
        Write [AAA_]
        If fstat
         Call ERREUR(TABLE-[F:AIU]USR-[F:ACC]CODACC,1) From DOSDIC
        Endif
       Endif
      Endif
     Endif
    Next ACC
    # Création des enregistrements vides
    For I=1 To NBUSR
     Read [AAA_]AXAC0=TBUSR(I);""
     If fstat
      [F:AAA_] = [F:ACC]
      [F:AAA_]ACC = ""
      [F:AAA_]USR = TBUSR(I)
      Write [AAA_]
      If fstat
       Call ERREUR(TABLE-[F:AAA_]USR,1) From DOSDIC
      Endif
     Endif
    Next I
    # Création des codes acces pour Administrateur
    For [ACS]
     Read [AAA_]AXAC0=USRADM;[F:ACS]CODACC
     If fstat
      [F:AAA_] = [F:ACS]
      [F:AAA_]ACC = [F:ACS]CODACC
      [F:AAA_]USR = USRADM
      Write [AAA_]
      If fstat
       Call ERREUR(TABLE-USADM-[F:ACS]CODACC,1) From DOSDIC
      Endif
     Endif
    Next I
   Commit
   If !SILENCE
    Call FERME_BOITE From GESECRAN
   Endif
  Endif
  Onerrgo RIEN
  Close Local File [ACC] , [AUS] , [ACS] , [AIU] , [AME]
  Onerrgo
 Next D
Endif

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#-----------------------------------------------------------------#
$MAJ_AX3MNL
NUM = val(right$(TABLE,7))

If NUM<[L]DEBMEN or ([L]FINMEN>0 & NUM>[L]FINMEN)
 Return
Endif
Gosub INFO

Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)

If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

GPE = 0
#CHECK UNUSED_BEGIN
GPOINT = "MAJAX3MNL" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
If GPE=0
 For D=1 To NBDOS
  ERFIC = 0
  Onerrgo ERFIC
  OUVTAB = TBDOS(D)+".APLSTD"   : Local File =OUVTAB [AST]
  Onerrgo
  If NBDOS>1 & !ERFIC
   Call EXISTE_ADX("","","SPEABIAX3",OKTRT) From ORDSYS
   If OKTRT
    Onerrgo ERR
    Gosub AX3MNL From SPEABIAX3
    Onerrgo
   Endif
  Endif
  If NBDOS>1 & !ERFIC
   Call EXISTE_ADX("","","ASTDABIAX3",OKTRT) From ORDSYS
   If OKTRT
    Onerrgo ERR
    Gosub AX3MNL From ASTDABIAX3
    Onerrgo
   Endif
  Endif
  If !ERFIC
   Trbegin [AAA_]
    For [AST]LAN Where LAN=GLANGUE & LANCHP=NUM & LANNUM<>0
     Raz [F:AAA_]
     [F:AAA_] = [F:AST]
     Write [AAA_]
     If fstat
      Call ERREUR(TABLE-num$([F:AST]LANNUM),1) From DOSDIC
     Endif
    Next AST
    If NUM<100
     Read [AST]CLE = 0;NUM;GLANGUE
    Else
     Read [AST]CLE = 200;NUM-200;GLANGUE
    Endif
    [F:AAA_] = [F:AST]
    [F:AAA_]LANNUM = 0
    Write [AAA_]
    If fstat
     Call ERREUR(TABLE-"0",1) From DOSDIC
    Endif
    # Création d'un enregistrement vide
    Raz [AAA_]
    Write [AAA_]
   Commit
  Endif
  Onerrgo RIEN
  Close Local File [AST]
  Onerrgo
 Next D
Endif

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#-----------------------------------------------------------------#
$MAJ_AX3ADI
NUM = val(right$(TABLE,7))

If NUM<[L]DEBADI or ([L]FINADI>0 & NUM>[L]FINADI)
 Return
Endif
Gosub INFO

Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)

If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

GPE = 0
#CHECK UNUSED_BEGIN
GPOINT = "MAJAX3ADI" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
If GPE=0
 For D=1 To NBDOS
  ERFIC = 0
  Onerrgo ERFIC
  OUVTAB = TBDOS(D)+".ATABDIV"   : Local File =OUVTAB [ADI]
  OUVTAB = TBDOS(D)+".ATEXTRA"   : Local File =OUVTAB [AXX]
  OUVTAB = TBDOS(D)+".ATABTAB"   : Local File =OUVTAB [ADV]
  OUVTAB = TBDOS(D)+".APLSTD"    : Local File =OUVTAB [AST]
  OUVTAB = TBDOS(D)+".ATYPE"     : Local File =OUVTAB [ATY]
  Onerrgo
  If NBDOS>1 & !ERFIC
   Call EXISTE_ADX("","","SPEABIAX3",OKTRT) From ORDSYS
   If OKTRT
    Onerrgo ERR
    Gosub AX3ADI From SPEABIAX3
    Onerrgo
   Endif
  Endif
  If NBDOS>1 & !ERFIC
   Call EXISTE_ADX("","","ASTDABIAX3",OKTRT) From ORDSYS
   If OKTRT
    Onerrgo ERR
    Gosub AX3ADI From ASTDABIAX3
    Onerrgo
   Endif
  Endif
  If !ERFIC
   Read [ADV]CODE=NUM
   If !fstat
    Trbegin [AAA_]
     Raz NBA,NBN
     For [ADI] Where NUMTAB=NUM
      Raz [F:AAA_]
      For ZON="CODE","LNGDES","SHODES"
       Case ZON
        When "CODE"
         [F:AAA_]CODE = [F:ADI]CODE
        When "LNGDES"
         Call LECTEXTRA([F:AAA_]LNGDES,"ATABDIV","LNGDES",num$(NUM),[F:ADI]CODE) From ATEXTRA
        When "SHODES"
         Call LECTEXTRA([F:AAA_]SHODES,"ATABDIV","SHODES",num$(NUM),[F:ADI]CODE) From ATEXTRA
        When Default
       Endcase
      Next

      Raz NBA
      For II=0 To dim([F:ADV]COLALPTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLALPDES",num$(NUM),num$(II)) From ATEXTRA
       If CHAINE<>""
        Raz CHAINE
        NBA +=1
        K = 0
        ZON = "A"+num$(NBA)
        CHAINE = [F:ADV]COLALPTYP(II) : J = val([F:ADV]COLALPSUP(II))
        If [F:ATY]CODTYP<>CHAINE
         Read [ATY]CODTYP=CHAINE
        Endif
        If [F:ATY]CODTYP=CHAINE & CHAINE<>"" & [F:ATY]TYPTYP=1 & J<>0 & K<>0
         Read [AST]CLE=J;K;GLANGUE
         Assign "[F:AAA_]"+ZON With [F:AST]LANMES
        Else
         Case evalue("type([F:AAA_]"+ZON+")")
          When 1,2,4,5,6,7 : Assign "[F:AAA_]"+ZON With val(num$(evalue("[F:ADI]"+ZON)))
          When Default     : Assign "[F:AAA_]"+ZON With num$(evalue("[F:ADI]"+ZON))
         Endcase
        Endif
       Endif
      Next

      Raz NBN
      For II=0 To dim([F:ADV]COLNUMTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLNUMDES",num$(NUM),num$(II)) From ATEXTRA
       If CHAINE<>""
        Raz CHAINE
        NBN +=1
        Assign "K" With evalue("[F:ADI]N"+num$(NBN))
        ZON = "N"+num$(NBN)
        CHAINE = [F:ADV]COLNUMTYP(II) : J = val([F:ADV]COLNUMSUP(II))
        If [F:ATY]CODTYP<>CHAINE
         Read [ATY]CODTYP=CHAINE
        Endif
        If [F:ATY]CODTYP=CHAINE & CHAINE<>"" & [F:ATY]TYPTYP=1 & J<>0 & K<>0
         Read [AST]CLE=J;K;GLANGUE
         Assign "[F:AAA_]"+ZON With [F:AST]LANMES
        Else
         Case evalue("type([F:AAA_]"+ZON+")")
          When 1,2,4,5,6,7 : Assign "[F:AAA_]"+ZON With val(num$(evalue("[F:ADI]"+ZON)))
          When Default     : Assign "[F:AAA_]"+ZON With num$(evalue("[F:ADI]"+ZON))
         Endcase
        Endif
       Endif
      Next

      Write [AAA_]
      If fstat
       Call ERREUR(TABLE-num$([F:ADI]CODE),1) From DOSDIC
      Endif
     Next ADI
     # Création d'un enregistrement vide
     Raz [AAA_]
     Write [AAA_]
    Commit
   Endif
  Endif
  Onerrgo RIEN
  Close Local File [ADI] , [AXX] , [ADV] , [AST] , [ATY]
  Onerrgo
 Next D
Endif

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#-----------------------------------------------------------------#
$MAJ_AX3FCTFCY
Gosub INFO
Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)

If [L]SIMU=2 : Return : Endif

Local File =MACHINE+"@"+[F:ABW]COD+"."+TABLE [AAA_]

CRITERE  = 'USR>="'+[L]DEBAUZ+'"'
If [L]FINAUZ<>""
 CRITERE += ' & USR<="'+[L]FINAUZ+'"'
Else
 CRITERE += ' & USR<="ZZZZZZZZZZ"'
Endif

Raz NBREP
For [ABM] Where AUZFCY=2
 NBREP += 1
 TBREP(NBREP) = [F:ABM]COD
 TBFNC(NBREP) = [F:ABM]FNC
Next

GPE = 0
#CHECK UNUSED_BEGIN
GPOINT = "MAJAX3FCTFCY" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
If GPE=0
 Local Char WUSRBI(10)
 For D=1 To NBDOS
  ERFIC = 0
  Onerrgo ERFIC
  OUVTAB = TBDOS(D)+".AFCTFCY"   : Local File =OUVTAB [AFF]
  OUVTAB = TBDOS(D)+".AUTILIS"   : Local File =OUVTAB [AUS]
  OUVTAB = TBDOS(D)+".AMETUTI"   : Local File =OUVTAB [AME]
  OUVTAB = TBDOS(D)+".ABIPRFUSR" : Local File =OUVTAB [AIU]
  OUVTAB = TBDOS(D)+".FACILITY"  : Local File =OUVTAB [FCY]
  Onerrgo
  If !ERFIC
   If !SILENCE
    Call OUVRE_BOITE(TBDOS(D),100) From GESECRAN
    Call SET_BOITE(TABLE,nbrecord([F:AFF])) From GESECRAN
   Endif
   Raz NBUSR
   Filter [AUS]
   For [AUS]
    If [F:AUS]USRBI=""
     Read [AME]AME0 = [F:AUS]CODMET
     WUSRBI = [F:AME]USRBI
    Else
     WUSRBI = [F:AUS]USRBI
    Endif
    If WUSRBI<>""
     If [F:AIU]PRF<>WUSRBI
         Read [AIU]AIU0=WUSRBI
     Endif
     If [F:AIU]PRF=WUSRBI & !find([F:AIU]USR,TBUSR(1..NBUSR))
      NBUSR += 1
      TBUSR(NBUSR) = [F:AIU]USR
      If [F:AUS]PRFFCT=""
       Read [AME]AME0 = [F:AUS]CODMET
       TBPRF(NBUSR) = [F:AME]PRFFCT
      Else
       TBPRF(NBUSR) = [F:AUS]PRFFCT
     Endif
     Endif
    Endif
   Next AUS
   Filter [AUS]

   If NBUSR=0
    NBUSR += 1
    TBUSR(NBUSR) = USRADM
    Local File =TBDOS(D)+".ADOVAL" [ADW]
    Read [ADW]ADW0="";"";"USRADM"
    If !fstat & [F:ADW]VALEUR<>""
     TBPRF(NBUSR) = [F:ADW]VALEUR
    Else
     TBPRF(NBUSR) = "ADMIN"
    Endif
    Close Local File [ADW]
   Endif
   Trbegin [AAA_]
    LEC = 0
    For [AFF]
     If find([F:AFF]PRFCOD,TBPRF(1..NBUSR)) & find([F:AFF]FNC,TBFNC(1..NBREP))
      If !SILENCE
       LEC += 1
       Call AFF_BOITE("",LEC,INTE) From GESECRAN
      Endif
      For I=1 To NBUSR
       If TBPRF(I)=[F:AFF]PRFCOD & TBUSR(I)>=[L]DEBAUZ & ([L]FINAUZ="" or TBUSR(I)<=[L]FINAUZ)
        For J=1 To NBREP
         If TBFNC(J)=[F:AFF]FNC
          Read [AAA_]AXFC0=[F:AFF]FCY;TBUSR(I);TBREP(J)
          If fstat
           Raz [F:AAA_]
           [F:AAA_] = [F:AFF]
           [F:AAA_]USR = TBUSR(I)
           [F:AAA_]REP = TBREP(J)
           Write [AAA_]
           If fstat
            Call ERREUR(TABLE-[F:AFF]FCY-TBUSR(I)-TBREP(J),1) From DOSDIC
           Endif
          Endif
         Endif
        Next J
       Endif
      Next I
     Endif
    Next AFF
    # Création des enregistrements vides
    For [AAA_]AXFC0(2) Where evalue(CRITERE)
     Look [AAA_]AXFC0=[F:AAA_]FCY;[F:AAA_]USR;""
     If fstat
      [F:AAA_]REP = ""
      Write [AAA_]
      If fstat
       Call ERREUR(TABLE-[F:AAA_]FCY-[F:AAA_]USR,1) From DOSDIC
      Endif
     Endif
    Next AAA_
    # Création des autorisations pour l'Administrateur
    For [FCY]
     For I=1 To NBREP
      Look [AAA_]AXFC0=[F:FCY]FCY;USRADM;TBREP(I)
      If fstat
       [F:AAA_]FCY = [F:FCY]FCY
       [F:AAA_]USR = USRADM
       [F:AAA_]REP = TBREP(I)
       Write [AAA_]
       If fstat
        Call ERREUR(TABLE-[F:FCY]FCY-USRADM-TBREP(I),1) From DOSDIC
       Endif
      Endif
     Next I
    Next FCY
   Commit
   If !SILENCE
    Call FERME_BOITE From GESECRAN
   Endif
  Endif
  Onerrgo RIEN
  Close Local File [AFF] , [AUS] , [FCY] , [AIU] , [AME]
  Onerrgo
 Next D
Endif

# nbre d'enregistrements créés
Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN

Close Local File [AAA_]
Return

#--------------------------------------------------------------------------------#
$MAJ_INCDIM
B_BREAK = 200000
K = instr(1,TDAPP(R),"~")
GDOSSIER = left$(TDAPP(R),K-1)
TABORG   = right$(TDAPP(R),K+1)
DOSSIER  = MACHINE+"@"+[F:ABW]COD
Onerrgo RIEN : Gosub DEFVARDEB : Onerrgo ERR
If !clalev([F:AUD]) : Local File =GDOSSIER+"."+TABAUDIT [AUD] : Endif
CRITAUD = func CRITAUD(GDOSSIER,DOSAUD,MAXAUD,NBDOSAUD)
Filter [AUD] Where TBL=[L]TABORG & (STABI=2 or STABI=4) & evalue(CRITAUD): # A traiter
Call DEBTRANS From GLOCK
Gosub TR_INCDIM
Close Local File [AUD]
Onerrgo RIEN : Gosub DEFVARFIN : Onerrgo ERR
Return

$TR_INCDIM
Trbegin [AUD]
 For F=1 To NDDIM
  If TDAPP(F)=TDAPP(R)
   Raz CRE , MAJ , SUP
   TABLE = 'D_'+TDDIM(F)
   If TDDIM(F)<>[F:ABI]CODDIM
    Read [F:ABI]ABI0 = TDDIM(F)
   Endif

   # Issue X3-59123 - 2018-06-07 by CCC : for control concerning incremental deletion
   # Reset to Yes for each dimension
   CTLAUZINCDEL = [V]CST_AYES
   AUZINCDEL = [V]CST_AYES

   Call SET_PREF([F:ABI]CODDIM,PREF) From SUBABI
   NOMPRG = PREF+[F:ABI]CODDIM
   If !SILENCE
    Call OUVRE_BOITE(GDOSSIER,100) From GESECRAN
    Call SET_BOITE(TABLE,rowcount([F:AUD])) From GESECRAN
   Endif
   INFO = 'D_'+TDDIM(F)-"-"-mess(3,7820,1) : # Inc audit
   Gosub INFO
   If [L]SIMU<>2
    ERFIC = 0
    Raz OKTRTSTD,OKTRTSPE,OKTRTSPV
    Gosub DCLE From =APPLI+"."+NOMPRG
    Onerrgo ERFIC
    OUVTAB = MACHINE+"@"+[F:ABW]COD+"."+TABLE : Local File =OUVTAB [AAA_]
    If clalev([F:ATY]) : Close Local File [F:ATY] : Endif
    If clalev([F:ATB]) : Close Local File [F:ATB] : Endif
    If clalev([F:AXX]) : Close Local File [F:AXX] : Endif
    If clalev([F:ATZ]) : Close Local File [F:ATZ] : Endif
    If clalev([F:ATI]) : Close Local File [F:ATI] : Endif
    OUVTAB = GDOSSIER +".ATYPE"   : Local File =OUVTAB [ATY]
    OUVTAB = GDOSSIER +".ATABLE"  : Local File =OUVTAB [ATB]
    OUVTAB = GDOSSIER +".ATEXTRA" : Local File =OUVTAB [AXX]
    OUVTAB = GDOSSIER +".ATABIND" : Local File =OUVTAB [ATI]
    OUVTAB = GDOSSIER +".ATABZON" : Local File =OUVTAB [ATZ]
    Gosub OUVRE  From =APPLI+"."+NOMPRG
    If [F:ABI]TRTSTD<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSTD,OKTRTSTD) From ORDSYS  : Endif
    If dim([F:ABV]TRTSPE)>0 & [F:ABI]TRTSPE<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSPE,OKTRTSPE) From ORDSYS  : Endif
    If dim([F:ABV]TRTSPV)>0 & [F:ABI]TRTSPV<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSPV,OKTRTSPV) From ORDSYS  : Endif
    ACTION = "OUVRE_DIM" : Gosub ACTIONB
    Onerrgo
    # Action de début
    ACTION = "DEBUT_DIM" : Gosub ACTIONB
    # Clé de la table origine
    Raz CHAINE
    If [F:ATB]CODFIC<>[F:ABI]TABORG
        Read [ATB]CODFIC=[F:ABI]TABORG
    Endif
    If [F:ATB]CODFIC=[F:ABI]TABORG
     If [F:ATB]AUDCLE<>""
      Read [ATI]CODIND=[F:ABI]TABORG;[F:ATB]AUDCLE
      If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
     Else
      Read [ATI]NUMLIG(2)=[F:ABI]TABORG;1
      If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
     Endif
    Endif
    Raz NBTCLE,TCLE
    If CHAINE<>""
     Call SETCLE(NBTCLE,TCLE,CHAINE) From LNKSUB
     B_CRITERE = "1=1"  : B_STOP = 0
     Gosub ECR_INCDIM
     If !SILENCE
      Call FERME_BOITE From GESECRAN
     Endif
     # Action de fin
     ACTION = "FIN_DIM" : Gosub ACTIONB
    Else
     Call ECR_TRACE(mess(144,148,1),1) From GESECRAN : # "Champ ACLE: Paramétrage incorrecte"
    Endif
    # Enregistrements créés/Enregistrements modifiés/Enregistrements supprimés
    CHAINE = "***  "+num$(CRE)-mess(103,141,1)+"/"+num$(MAJ)-mess(104,141,1)+"/"+num$(SUP)-mess(163,148,1)
    Call ECR_TRACE(CHAINE,0) From GESECRAN
    Onerrgo RIEN
    ACTION = "FERME_DIM" : Gosub ACTIONB
    Gosub FERME From =APPLI+"."+NOMPRG
    Close Local File [AAA_]
    Close Local File [ATY],[ATB],[AXX],[ATI],[ATZ]
    Onerrgo ERR
   Endif
  Endif
 Next F
Commit

Return

#-------------------#
$ECR_INCDIM2
For [LNK_] Where evalue(B_CRITERE)
 K = 1
 If [F:ABI]FILTRE<>""
  FLD = "FILTRE"
  FORMULE = [F:ABI]FILTRE
  Onerrgo ERFOR
  K = evalue(FORMULE)
  Onerrgo ERR
 Endif
 If K
  Gosub INC_DIMDET
  If ERFOR : Break : Endif
 Endif
 B_NBENREG += 1
 If B_BREAK>0 & B_NBENREG>=B_BREAK
  B_CRITERE = "[F:AUD]SEQ>"+num$([F:AUD]SEQ)
  B_STOP = 1
  Break
 Endif
Next
If B_BREAK>0 & B_STOP>0
 B_NBENREG = 0
 B_STOP    = 0
 Goto ECR_INCDIM2
Endif
Return

#-------------------#
$ECR_INCDIM
Raz ERFOR , LEC

# Issue X3-59123 - 2018-06-08 by CCC : Get the filter for incremental update
Call GET_FLTDELINC(FLTDELINC) From =APPLI+"."+NOMPRG

For [AUD]
 If !SILENCE
  LEC += 1
  Call AFF_BOITE("",LEC,INTE) From GESECRAN
 Endif
 NBVAL = 1
 VALCLE(NBVAL) = [F:AUD]ID1
 CHAINE = [F:AUD]ID2
 While CHAINE<>""
  NBVAL += 1
  K = instr(1,CHAINE,"~")
  If K
   VALCLE(NBVAL) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   VALCLE(NBVAL) = CHAINE
   CHAINE = ""
  Endif
 Wend
 Raz [LNK_], [AAA_]
 I = 0
 While I<NBTCLE
  I += 1
  Case evalue("type([F:LNK_]"+TCLE(I)+")")
   When 1,2,4,5,6,7
    Assign "[F:LNK_]"+TCLE(I) With val(VALCLE(I))
   When 3
    Raz GMESSAGE
    FMDDATSAV = GFMDAT4
    GFMDAT4 = "DD[/]MM[/]YYYY"
    Call CHARGE(VALCLE(I),"D",0,0,CHAINE) From FMTVAR
    GFMDAT4 = FMDDATSAV
    If GMESSAGE<>""
     Call ECR_TRACE(GMESSAGE,1) From GESECRAN
     Raz GMESSAGE
    Else
     Assign "[F:LNK_]"+TCLE(I) With CHAINE
    Endif
   When 525
    Assign "[F:LNK_]"+TCLE(I) With toUuid(func ABIMAJBAS.VALUE_TO_UUID(VALCLE(I)))
   When 526
    Assign  "[F:LNK_]"+TCLE(I) With gdatetime$(VALCLE(I))
   When Default
    CHAINE = VALCLE(I)
    If len(CHAINE)>0 & vireblc(CHAINE,2)=""
     CHAINE = space$(len(CHAINE)-1)
    Endif
    Assign "[F:LNK_]"+TCLE(I) With CHAINE
  Endcase
 Wend
 K = 0
 # Issue X3-59123 - 2018-05-22 by CCC
 # Try to read [LNK_] only if the record has not been deleted
 If [F:AUD]EVT<>"DELETE"
    # Lecture de l'enregistrement de la table origine auditée
    Read [LNK_] =
     If !fstat
      K = 1
      If [F:ABI]FILTRE<>""
       FLD = "FILTRE"
       FORMULE = [F:ABI]FILTRE
       Onerrgo ERFOR
       K = evalue(FORMULE)
       Onerrgo ERR
      Endif
     Else
      If [F:AUD]EVT<>"DELETE"
       K =0
       [F:AUD]STABI = 4
       Rewrite [AUD]
      Endif
     Endif
 Endif
 If K or ([F:AUD]EVT="DELETE")
  Gosub INC_DIMDET
  If ERFOR : Break : Endif
 Endif
Next AUD
Return

$INC_DIMDET
If [L]DET=2
 # Enregistrement audit
 CHAINE = "*    "+mess(43,148,1)-":"-[F:AUD]ID1-[F:AUD]ID2
 CHAINE -= "("+[F:AUD]EVT-format$(GFMD,[F:AUD]DAT)-format$("K:##[:]##[:]##",[F:AUD]HOU)+")"
 Call ECR_TRACE(CHAINE,0) From GESECRAN
Endif
ACTION = "BOUCLE_DIM" : Gosub ACTIONB
# Insert/Update/Delete de l'enregistrement de la table de faits (et des agrégats)
Case [F:AUD]EVT
 When "INSERT"
  Gosub CHARGE_CLED
  Raz [F:AAA_]
  Gosub CHARGE_FLDDIM
  K = 0
  Write [AAA_]
  If fstat
   Read [AAA_] =
   If !fstat
    Gosub CHARGE_FLDDIM
    K = 1
    Rewrite [AAA_]
   Endif
   If fstat
    For I=1 To NBDCLE
     If CHAINE<>"" : CHAINE += "~" : Endif
     CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
    Next I
    Call ERREUR(TABLE-CHAINE,1+K) From DOSDIC
   Else
    MAJ += 1
    [F:AUD]STABI = 4
    Rewrite [AUD]
   Endif
  Elsif !ERFOR
   CRE += 1
   If [L]DET=2
    CHAINE = ""
    For I=1 To NBDCLE
     If CHAINE<>"" : CHAINE += "~" : Endif
     CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
    Next I
    Call ECR_TRACE("**   "+mess(59+K,123,1)-CHAINE,0) From GESECRAN
   Endif
   [F:AUD]STABI = 4
   Rewrite [AUD]
  Endif
 When "UPDATE"
  Gosub CHARGE_CLED
  Read [AAA_] =
  If fstat
   Raz [F:AAA_]
   Gosub CHARGE_FLDDIM
   K = 0
   Write [AAA_]
   If !fstat : CRE += 1 : Endif
  Else
   Gosub CHARGE_FLDDIM
   K = 1
   Rewrite [AAA_]
   If !fstat : MAJ += 1 : Endif
  Endif
  If fstat
   For I=1 To NBDCLE
    If CHAINE<>"" : CHAINE += "~" : Endif
    CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
   Next I
   Call ERREUR(TABLE-CHAINE,1+K) From DOSDIC
  Elsif !ERFOR
   If [L]DET=2
    CHAINE = ""
    For I=1 To NBDCLE
     If CHAINE<>"" : CHAINE += "~" : Endif
     CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
    Next I
    Call ECR_TRACE("**   "+mess(59+K,123,1)-CHAINE,0) From GESECRAN
   Endif
   [F:AUD]STABI = 4
   Rewrite [AUD]
  Endif
 When "DELETE"
    # Issue X3-59123 - 2018-05-22 by CCC : Check that incremental delete can be processed
    # this must be done once per dimension (--> CTLAUZINCDEL)
    If CTLAUZINCDEL = [V]CST_AYES
        CTLAUZINCDEL = [V]CST_ANO
        Raz NBFLD, FLDDIM, FLDORG
        # Get list of fields and their formula for the control function
        For [ABJ] Where [ABJ]CODDIM=[F:ABI]CODDIM
            NBFLD+=1
            FLDDIM(NBFLD) = [F:ABJ]FLDDIM
            FLDORG(NBFLD) = [F:ABJ]FLDORG
        Next
        # Control if incremental deletion is possible for the dimension. If not => error message and the dimension is not updated by deletions
        If func SUBABI.CHECK_INCUPD(GDOSSIER, [F:ABI]TABORG, [F:ABI]INDLEC, FLDDIM, FLDORG, NBFLD, [F:ABI]CLE, MSGERR)<>[V]CST_AOK
            MSGERR = [F:ABI]CODDIM-mess(169,148,1)+"\"+MSGERR
            Call ECR_TRACE(MSGERR,1) From GESECRAN
            AUZINCDEL = [V]CST_ANO
        Endif
    Endif
    # If incremental deletion is authorized, delete the corresponding record
    If AUZINCDEL = [V]CST_AYES & FLTDELINC<>""
        Delete [AAA_] Where evalue(FLTDELINC)
        If fstat
            For I=1 To NBDCLE
             If CHAINE<>"" : CHAINE += "~" : Endif
             CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
            Next I
            Call ERREUR(TABLE-CHAINE,3) From DOSDIC
        Elsif !ERFOR
            [L]SUP+=adxdlrec
            If [L]DET=2
             CHAINE = ""
             For I=1 To NBDCLE
              If CHAINE<>"" : CHAINE += "~" : Endif
              CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
             Next I
             Call ECR_TRACE("**   "+mess(53,123,1)-CHAINE,0) From GESECRAN
            Endif
            [F:AUD]STABI = 4
            Rewrite [AUD]
        Endif
    Endif
Endcase
If ERFOR : Return : Endif
Return

$CHARGE_CLED
Onerrgo ERFOR
Gosub CHARGE_CLE From =APPLI+"."+NOMPRG
Onerrgo ERR
Return

#--------------------------------------------------------------------------------#
$MAJ_DIM
Raz CRE , MAJ
INFO = 'D_'+[ABI]CODDIM
If [F:ABI]TYPMAJ=2 or [L]GEN=2
 INFO -= "-"-mess(2,7820,1) : # Annule et remplace
Else
 INFO -= "-"-mess(1,7820,1) : # Incrémental
Endif
Gosub INFO
Call SET_PREF([F:ABI]CODDIM,PREF) From SUBABI
NOMPRG = PREF+[F:ABI]CODDIM
Gosub DCLE From =APPLI+"."+NOMPRG
If [F:ABI]TYPMAJ=2 or [L]GEN=2
 Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)
Endif
If [L]SIMU=2 : Return : Endif
ERFIC = 0
Raz OKTRTSTD,OKTRTSPE,OKTRTSPV
Onerrgo ERFIC
OUVTAB = MACHINE+"@"+[F:ABW]COD+"."+TABLE : Local File =OUVTAB [AAA_]
Local File =OUVTAB [ASAV]
Onerrgo
# Action de début
If [F:ABI]TRTSTD<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSTD,OKTRTSTD) From ORDSYS  : Endif
If dim([F:ABV]TRTSPE)>0 & [F:ABI]TRTSPE<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSPE,OKTRTSPE) From ORDSYS  : Endif
If dim([F:ABV]TRTSPV)>0 & [F:ABI]TRTSPV<>"" : Call EXISTE_ADX("","",[F:ABI]TRTSPV,OKTRTSPV) From ORDSYS  : Endif
ACTION = "DEBUT_DIM" : Gosub ACTIONB
For D=1 To NBDOS
 If dim([F:ABI]MULDOS)>0 & [F:ABI]MULDOS<>2 & D=2 :  Break : Endif
 GDOSSIER = TBDOS(D)
 Onerrgo RIEN : Gosub DEFVARDEB : Onerrgo ERR
 If NBDOS>1 : Call ECR_TRACE(mess(1,45,1)-":"-GDOSSIER,0) From GESECRAN : Endif
 ERFIC = 0
 Onerrgo ERFIC
 If clalev([F:ATY]) : Close Local File [F:ATY] : Endif
 If clalev([F:ATB]) : Close Local File [F:ATB] : Endif
 If clalev([F:AXX]) : Close Local File [F:AXX] : Endif
 OUVTAB = GDOSSIER +".ATYPE"   : Local File =OUVTAB [ATY]
 OUVTAB = GDOSSIER +".ATABLE"  : Local File =OUVTAB [ATB]
 OUVTAB = GDOSSIER +".ATEXTRA" : Local File =OUVTAB [AXX]
 Gosub OUVRE From =APPLI+"."+NOMPRG
 ACTION = "OUVRE_DIM" : Gosub ACTIONB
 Onerrgo ERR
 If !ERFIC
  If !SILENCE
   Call OUVRE_BOITE(GDOSSIER,100) From GESECRAN
   Call SET_BOITE(TABLE,rowcount([F:LNK_])) From GESECRAN
  Endif
  # Pour l'abréviation de la table origine
  If !find(2,[F:ABI]FLDDAT(0..[F:ABI]NBRLNK-1))
   If [F:ATB]CODFIC<>[F:ABI]TABORG or [F:ATB]CODFIC=""
    Read [ATB]CODFIC=[F:ABI]TABORG
    TABR = [F:ATB]ABRFIC
   Endif
  Else
   If [F:ATB]CODFIC<>[F:ABI]TABLNK(find(2,[F:ABI]FLDDAT(0..[F:ABI]NBRLNK-1))-1)
    If [F:ABI]ABRLNK(find(2,[F:ABI]FLDDAT(0..[F:ABI]NBRLNK-1))-1) <> ""
     TABR = [F:ABI]ABRLNK(find(2,[F:ABI]FLDDAT(0..[F:ABI]NBRLNK-1))-1)
    Else
     Read [ATB]CODFIC=[F:ABI]TABLNK(find(2,[F:ABI]FLDDAT(0..[F:ABI]NBRLNK-1))-1)
     TABR = [F:ATB]ABRFIC
    Endif
   Endif
  Endif
  If [F:ABI]TYPMAJ=1 & [L]GEN<>2
   If evalue("dim([F:"+TABR+"]CREDAT)")<=0
    TABR = ""
   Elsif evalue("dim([F:"+TABR+"]UPDDAT)")<=0
    TABR = ""
   Endif
  Endif
  If TABR=""
   Call ECR_TRACE(mess(46,148,1),1) From GESECRAN : # Synchronisation incrémentale impossible
  Else
   Call DEBTRANS From GLOCK
   Gosub TR_MAJDIM
  Endif
  If !SILENCE
   Call FERME_BOITE From GESECRAN
  Endif
 Endif
 Onerrgo RIEN
 ACTION = "FERME_DIM" : Gosub ACTIONB
 Gosub FERME From =APPLI+"."+NOMPRG
 Gosub DEFVARFIN
 Onerrgo ERR
Next D
# Création d'un enregistrement vide
Raz [F:AAA_]
CHAINE = ""
For I=1 To NBDCLE
 Case evalue("type([F:AAA_]"+DCLE(I)+")")
  When 1,2,4,5,6,7 : Assign "[F:AAA_]"+DCLE(I) With 0
  When 3           : Assign "[F:AAA_]"+DCLE(I) With [0/0/0]
  When 525         : Assign "[F:AAA_]"+DCLE(I) With NullUuid       : # 119483
  When 526         : Assign "[F:AAA_]"+DCLE(I) With gdatetime$("") : # 119483
  When Default     : Assign "[F:AAA_]"+DCLE(I) With ""
 Endcase
 If CHAINE<>"" : CHAINE += "~" : Endif
 CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
Next I
Default File [AAA_]
Trbegin [AAA_]
 Read [AAA_] =
 If fstat & [F:ABI]SUPVID <> 2
 Raz [F:AAA_]
 Write [AAA_]
 If fstat
  Call ERREUR(TABLE-CHAINE,1) From DOSDIC
 Else
  CRE += 1
 Endif
Elsif !fstat & [F:ABI]SUPVID = 2
 Delete [F:AAA_]
 If fstat
  Call ERREUR(TABLE-CHAINE,3) From DOSDIC
 Endif
Endif
If filinfo(filpath("FIL",TABAUDIT,"fde",GDOSSIER),0)>0 & [L]GEN<>2
 # Raz des flag audits de la table $1$ sur le dossier $2$
 Call ECR_TIME(func AFNC.MES2(mess(58,148,1),[F:ABI]TABORG,GDOSSIER)) From DOSSUB
 Local File =GDOSSIER+"."+TABAUDIT [AUD_]
 CRITAUD = func CRITAUD(GDOSSIER,DOSAUD,MAXAUD,NBDOSAUD)
 Update [AUD_] Where TBL=[F:ABI]TABORG & STABI=2 & evalue(CRITAUD) With STABI=4
 Close Local File [AUD_]
Endif
Commit
# ACTION de fin
ACTION = "FIN_DIM" : Gosub ACTIONB
# Enregistrements créés/Enregistrements modifiés
Call ECR_TRACE("***  "+num$(CRE)-mess(103,141,1)+"/"+num$(MAJ)-mess(104,141,1),0) From GESECRAN
Close Local File [AAA_]
Close Local File [ASAV]
Trbegin [ABI]
 Readlock [ABI] Curr
 If !fstat
  [F:ABI]DATMAJ = [L]DATMAJ
  Rewrite [ABI]
  If fstat
   Call ERREUR(TABLE-[F:ABI]CODDIM,2) From DOSDIC
  Endif
 Endif
Commit
Return

$ACTIONB
GPE = 0
GPV = 0
If dim([F:ABV]TRTSPE)>0 & [F:ABI]TRTSPE<>"" & OKTRTSPE
 Onerrgo ERR
 Gosub ACTION From =[F:ABI]TRTSPE
 Onerrgo
Endif
If dim([F:ABV]TRTSPV)>0 & [F:ABI]TRTSPV<>"" & OKTRTSPV & !GPV
 Onerrgo ERR
 Gosub ACTION From =[F:ABI]TRTSPV
 Onerrgo
Endif
If [F:ABI]TRTSTD<>"" & OKTRTSTD & !GPE
 Onerrgo ERR
 Gosub ACTION From =[F:ABI]TRTSTD
 Onerrgo
Endif
Return

#-----------------------------------------------------------------#
$TR_MAJDIM
Raz ERFOR , LEC
Openo
Trbegin [AAA_]
 For [LNK_]
  If !SILENCE
   LEC += 1
   Call AFF_BOITE("",LEC,INTE) From GESECRAN
  Endif
  K = 1
  If [F:ABI]TYPMAJ=1 & [L]GEN<>2
   UDAT = evalue("[F:"+TABR+"]UPDDAT")
   CDAT = evalue("[F:"+TABR+"]CREDAT")
   If UDAT<>[0/0/0]
    If UDAT<[F:ABI]DATMAJ : K = 0 : Endif
   Elsif CDAT<[F:ABI]DATMAJ
    K = 0
   Endif
  Endif
  If K & [L]FILTRE<>""
   Onerrgo ERFOR
   FLD = TABLE
   FORMULE = [L]FILTRE
   K = evalue(FORMULE)
   Onerrgo ERR
  Endif
  If K
   ACTION = "BOUCLE_DIM" : Gosub ACTIONB
   Gosub CHARGE_FLDDIM
   If [F:ABI]TYPMAJ=2 or [L]GEN=2
    K = 0
    Write [AAA_]
    If fstat
     [F:ASAV] = [F:AAA_]
     Read [F:AAA_] =
     If !fstat
      K = 1
      [F:AAA_]=[F:ASAV]
      Rewrite [AAA_]
      If ! fstat : MAJ += 1 : Endif
     Endif
    Else
     CRE += 1
    Endif
   Else
    [F:ASAV] = [F:AAA_]
    Read [F:AAA_] =
    If fstat
     K = 0
     Raz [F:AAA_]
     [F:AAA_]=[F:ASAV]
     Write [AAA_]
     If !fstat : CRE += 1 : Endif
    Else
     K = 1
     [F:AAA_]=[F:ASAV]
     Rewrite [AAA_]
     If !fstat : MAJ += 1 : Endif
    Endif
   Endif
   If fstat
    CHAINE = ""
    For I=1 To NBDCLE
     If CHAINE<>"" : CHAINE += "~" : Endif
     CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
    Next I
    Call ERREUR(TABLE-CHAINE,1+K) From DOSDIC
   Elsif [L]DET=2 & !ERFOR
    CHAINE = ""
    For I=1 To NBDCLE
     If CHAINE<>"" : CHAINE += "~" : Endif
     CHAINE += num$(evalue("[F:AAA_]"+DCLE(I)))
    Next I
    Call ECR_TRACE("**   "+mess(59+K,123,1)-CHAINE,0) From GESECRAN
   Endif
   If ERFOR : Break : Endif
  Endif
 Next LNK_
 If GOK=0
  Goto AB_TR_MAJDIM
 Elsif GOK<0
  Goto ROLL_TR_MAJDIM
 Endif
Commit
Return

$AB_TR_MAJDIM
Rollback
Return

$ROLL_TR_MAJDIM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJDIM : Endif

#-----------------------#
$CHARGE_FLDDIM
ERFOR = 0
Onerrgo ERFOR
Gosub MAJFLD From =APPLI+"."+NOMPRG
Onerrgo ERR
Return

#-------------------------------------------#
Subprog RAZ_TABLE(MACHINE,DOSSIER,TABLE,SIMU)
Value Char MACHINE , DOSSIER , TABLE
Local Char    ORDSYS(250)
Local Integer STAT
Call ECR_TRACE("***"-mess(170,100,1)+"("+DOSSIER-TABLE+")",0) From GESECRAN : # Raz fichier
If [L]SIMU=2 : End : Endif
ORDSYS = "valfil -z"-DOSSIER-TABLE
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
End

#------------------------------------------------------------------------------#
$MAJ_RAZ_FAT
K = instr(1,TBAPP(R),"~")
GDOSSIER = left$(TBAPP(R),K-1)
TABORG   = right$(TBAPP(R),K+1)
DOSSIER  = MACHINE+"@"+[F:ABW]COD
Onerrgo RIEN : Gosub DEFVARDEB : Onerrgo ERR
Call DEBTRANS From GLOCK
Gosub TR_RAZFAT
Onerrgo RIEN : Gosub DEFVARFIN : Onerrgo ERR
Return

#-----------------#
$TR_RAZFAT
Trbegin ADOVAL
 For F=1 To NBREG
  If TBAPP(F)=TBAPP(R) and TBRAZ(F)=TBRAZ(R)
   Raz CRE
   TABLE = 'F_'+TBFAT(F)
   If [F:ABV]CODREG<>TBREG(F)
    Read [ABV]ABV0=TBREG(F)
   Endif
   Call SET_PREF([F:ABV]CODREG,PREF) From SUBABV
   NOMPRG = PREF+[F:ABV]CODREG
   ERFIC = 0
   OUVTAB = DOSSIER+"."+TABLE : Local File =OUVTAB [AAA_]
   Onerrgo ERFIC
   Gosub OUVRE From =APPLI+"."+NOMPRG
   ACTION = "OUVRE_FAT" : Gosub ACTIONF
   Onerrgo ERR
   Raz OKTRTSTD,OKTRTSPE,OKTRTSPV
   If [F:ABV]TRTSTD<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSTD,OKTRTSTD) From ORDSYS : Endif
   If dim([F:ABV]TRTSPE)>0 & [F:ABV]TRTSPE<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPE,OKTRTSPE) From ORDSYS : Endif
   If dim([F:ABV]TRTSPV)>0 & [F:ABV]TRTSPV<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPV,OKTRTSPV) From ORDSYS : Endif
   If !ERFIC
    INFO = TABLE-"("+[F:ABV]CODREG+") -"-mess(2,7820,1) : # Annule et remplace
    Gosub INFO
    If [L]SIMU<>2
     # Action de début
     ACTION = "DEBUT_FAT" : Gosub ACTIONF
     If !SILENCE
      Call OUVRE_BOITE(GDOSSIER,100) From GESECRAN
      Call SET_BOITE(TABLE,rowcount([F:LNK_])) From GESECRAN
     Endif
     # Clé de la table origine
     Raz CHAINE
     If [F:ATB]CODFIC<>[F:ABV]TABORG
         Read [ATB]CODFIC=[F:ABV]TABORG
     Endif
     [L]ABR_TABORG = [F:ATB]ABRFIC
     If [F:ATB]CODFIC=[F:ABV]TABORG
      If [F:ATB]AUDCLE<>""
       Read [ATI]CODIND=[F:ABV]TABORG;[F:ATB]AUDCLE
       If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
      Else
       Read [ATI]NUMLIG(2)=[F:ABV]TABORG;1
       If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
      Endif
     Endif
     Call ECR_TRACE(GBIDC1,0) From GESECRAN
     If CHAINE<> ""
      Call SETCLE(NBTCLE,TCLE,CHAINE) From LNKSUB
      B_CRITERE = "1=1" : B_BREAK = 0 : B_STOP = 0
      ACTION = "B_BREAK" : Gosub ACTIONF
      If OKRAZFAT
       Gosub ECR_RAZFAT
      Endif
      OKRAZFAT = 1
      If !SILENCE
       Call FERME_BOITE From GESECRAN
      Endif
      # Action de début
      ACTION = "FIN_FAT" : Gosub ACTIONF
      Else
      Call ECR_TRACE(mess(144,148,1),1) From GESECRAN : # "Champ ACLE: Paramétrage incorrecte"
     Endif
     # Enregistrements créés
     Call ECR_TRACE("***  "+num$(CRE+SPECRE)-mess(103,141,1),0) From GESECRAN
    Endif
    Onerrgo RIEN
    Gosub FERME From =APPLI+"."+NOMPRG
    Close Local File [AAA_]
    Onerrgo ERR
   Endif
  Endif
 Next F
 If [L]SIMU<>2 &  filinfo(filpath("FIL",TABAUDIT,"fde",GDOSSIER),0)>0 & [L]GEN<>2
  # Raz des flag audits de la table $1$ sur le dossier $2$
  Call ECR_TIME(func AFNC.MES2(mess(58,148,1),TABORG,GDOSSIER)) From DOSSUB
  Local File =GDOSSIER+"."+TABAUDIT [AUD_]
  CRITAUD = func CRITAUD(GDOSSIER,DOSAUD,MAXAUD,NBDOSAUD)
  Update [AUD_] Where TBL=TABORG & STABI=2 & evalue(CRITAUD) With STABI=4
  Close Local File [AUD_]
 Endif
Commit
Return

$ACTIONF
GPE = 0
GPV = 0
If dim([F:ABV]TRTSPE)>0 & [F:ABV]TRTSPE<>"" & OKTRTSPE
 Onerrgo ERR
 Gosub ACTION From =[F:ABV]TRTSPE
 Onerrgo
Endif
If dim([F:ABV]TRTSPV)>0 & [F:ABV]TRTSPV<>"" & OKTRTSPV & !GPV
 Onerrgo ERR
 Gosub ACTION From =[F:ABV]TRTSPV
 Onerrgo
Endif
If [F:ABV]TRTSTD<>"" & OKTRTSTD & !GPE
 Onerrgo ERR
 Gosub ACTION From =[F:ABV]TRTSTD
 Onerrgo
Endif
Return

#-----------------------------------------------------------------#
$ECR_RAZFAT
Raz ERFOR , LEC
ACTION = "B_LOOP" : Gosub ACTIONF
For [LNK_] Where evalue(B_CRITERE)
 If !SILENCE
  LEC += 1
  Call AFF_BOITE("",LEC,INTE) From GESECRAN
 Endif
 K = 1
 If [L]FILTRE<>""
  Onerrgo ERFOR
  FLD = TABLE
  FORMULE = [L]FILTRE
  K = evalue(FORMULE)
  Onerrgo ERR
 Endif
 If K
  ACTION = "BOUCLE_FAT" : Gosub ACTIONF
  Case [F:ABV]TYPLNK
   When 1,3 : # 1,1
    indice = 0
    Raz [AAA_]
    Gosub CHARGE_FLDREG
    If !ERFOR
     Write [AAA_]
     If fstat
      Read [AAA_] =
      If !fstat
       Rewrite [AAA_]
      Endif
      If fstat
       Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
      Endif
     Else
      If [L]DET=2
       Call ECR_TRACE("**   "+mess(59,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0) From GESECRAN
      Endif
      CRE += 1
     Endif
    Endif
   When 2,4 : # 1,n
    J = evalue("dim([F:LNK_]"+[F:ABV]FLDDEC+")")
    For indice=0 To J-1
     K = 0
     If [F:ABV]CNDLIG=""
      K = 1
     Else
      Raz FLD , ERFOR
      Onerrgo ERFOR
      FORMULE = [F:ABV]CNDLIG
      K = evalue(FORMULE)
      If ERFOR : K = 0 : Endif
      Onerrgo ERR
     Endif
     If K
      Raz [AAA_]
      Gosub LIEN From =APPLI+"."+NOMPRG
      Gosub CHARGE_FLDREG
      If !ERFOR
       Write [AAA_]
       If fstat
        Read [AAA_] =
        If !fstat
         Rewrite [AAA_]
        Endif
        If fstat
         Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
        Endif
       Else
        If [L]DET=2
         Call ECR_TRACE("**   "+mess(59,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&        From GESECRAN
        Endif
        CRE += 1
       Endif
      Endif
     Endif
    Next indice
  Endcase
  If ERFOR : Break : Endif
  B_NBENREG += 1
  If B_BREAK>0 & B_NBENREG>=B_BREAK
   ACTION = "B_CRITERE" : Gosub ACTIONF
   B_NBENREG = 0
   Break
  Endif
 Endif
Next LNK_
If B_BREAK>0 & B_STOP>0
 Goto ECR_RAZFAT
Endif
Return

#-----------------------#
$CHARGE_FLDREG
ERFOR = 0
Onerrgo ERFOR
Gosub MAJFLD From =APPLI+"."+NOMPRG
Onerrgo ERR
Return

#-----------------------------------------------------------------#
$MAJ_INC_FAT
B_BREAK = 200000
K = instr(1,TBAPP(R),"~")
GDOSSIER = left$(TBAPP(R),K-1)
TABORG   = right$(TBAPP(R),K+1)
DOSSIER  = MACHINE+"@"+[F:ABW]COD
Onerrgo RIEN : Gosub DEFVARDEB : Onerrgo ERR
If !clalev([F:AUD]) : Local File =GDOSSIER+"."+TABAUDIT [AUD] : Endif
CRITAUD = func CRITAUD(GDOSSIER,DOSAUD,MAXAUD,NBDOSAUD)
Filter [AUD] Where TBL=TABORG & (STABI=2 or STABI=4) & evalue(CRITAUD) : # A traiter
Call DEBTRANS From GLOCK
Gosub TR_INCFAT
Close Local File [AUD]
Onerrgo RIEN : Gosub DEFVARFIN : Onerrgo ERR
Return

#----------------------------------#
$TR_INCFAT
Trbegin [AUD]
 For F=1 To NBREG
  If TBAPP(F)=TBAPP(R) and TBRAZ(F)=TBRAZ(R)
   Raz CRE , MAJ , SUP
   TABLE = 'F_'+TBFAT(F)
   If [ABV]CODREG<>TBREG(F)
    Read [ABV]ABV0=TBREG(F)
   Endif
   # Pour gérer les tables d'agrégats
   Call SET_PREF(TBFAT(F),PREF) From SUBABF
   PRGAGG = PREF+TBFAT(F)
   # Pour gérer les tables de faits
   Call SET_PREF([F:ABV]CODREG,PREF) From SUBABV
   NOMPRG = PREF+[F:ABV]CODREG
   INFO = TABLE-"("+[F:ABV]CODREG+")"
   #If TBRAZ(F) or [L]GEN=2
   # INFO -= "-"-mess(2,7820,1) : # Annule et remplace
   #Else
   INFO -= "-"-mess(1,7820,1) : # Incrémental
   #Endif
   Gosub INFO
   If [L]SIMU<>2
    If !SILENCE
     Call OUVRE_BOITE(GDOSSIER,100) From GESECRAN
     Call SET_BOITE(TABLE,rowcount([F:AUD])) From GESECRAN
    Endif
    Raz OKTRTSTD,OKTRTSPE,OKTRTSPV
    If [F:ABV]TRTSTD<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSTD,OKTRTSTD) From ORDSYS : Endif
    If dim([F:ABV]TRTSPE)>0 & [F:ABV]TRTSPE<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPE,OKTRTSPE) From ORDSYS : Endif
    If dim([F:ABV]TRTSPV)>0 & [F:ABV]TRTSPV<>"" : Call EXISTE_ADX("","",[F:ABV]TRTSPV,OKTRTSPV) From ORDSYS : Endif
    ERFIC = 0
    Onerrgo ERFIC
    OUVTAB = DOSSIER+"."+TABLE : Local File =OUVTAB [AAA_]
    Gosub OUVRE From =APPLI+"."+PRGAGG
    # Clé de la table origine
    Raz CHAINE
    If [F:ATB]CODFIC<>[F:ABV]TABORG
     Read [ATB]CODFIC=[F:ABV]TABORG
    Endif
    [L]ABR_TABORG = [F:ATB]ABRFIC
    If [F:ATB]CODFIC=[F:ABV]TABORG
     If [F:ATB]AUDCLE<>""
      Read [ATI]CODIND=[F:ABV]TABORG;[F:ATB]AUDCLE
      If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
     Else
      Read [ATI]NUMLIG(2)=[F:ABV]TABORG;1
      If !fstat : CHAINE = [F:ATI]DESCRIPT : Endif
     Endif
    Endif
    If CHAINE<>"" : Call SETCLE(NBTCLE,TCLE,CHAINE) From LNKSUB : Endif
    For ITYP=1 To NBTCLE
     Read [F:ATZ]CODZONE = [F:ABV]TABORG;TCLE(ITYP)
     If !fstat
     Read [ATY]CODTYP = [F:ATZ]CODTYP
      If !fstat
       TTYP(ITYP) = [F:ATY]TYPTYP
      Endif
     Endif
     If TTYP(ITYP)=0 : TTYP(ITYP) = 7 : Endif
    Next
    # Action de début
    ACTION = "DEBUT_FAT" : Gosub ACTIONF
    Gosub OUVRE  From =APPLI+"."+NOMPRG
    ACTION = "OUVRE_FAT" : Gosub ACTIONF
    Onerrgo ERR
    If !ERFIC
     # Action de début
     If CHAINE<>""
      B_CRITERE = "1=1" : B_STOP = 0
      Gosub ECR_INCFAT
      If !SILENCE
       Call FERME_BOITE From GESECRAN
      Endif
      # Action de début
      ACTION = "FIN_FAT" : Gosub ACTIONF
     Else
      Call ECR_TRACE(mess(144,148,1),1) From GESECRAN : # "Champ ACLE: Paramétrage incorrecte"
     Endif
    Endif
    # Enregistrements créés/Enregistrements modifiés/Enregistrements supprimés
    CHAINE = "***  "+num$(CRE)-mess(103,141,1)+"/"+num$(MAJ)-mess(104,141,1)+"/"+num$(SUP)-mess(163,148,1)
    Call ECR_TRACE(CHAINE,0) From GESECRAN
    Onerrgo RIEN
    Gosub FERME From =APPLI+"."+NOMPRG
    Gosub FERME From =APPLI+"."+PRGAGG
    Close Local File [AAA_]
    Onerrgo ERR
   Endif
  Endif
 Next F
Commit
Return

#-----------------------------------------------------------------#
$ECR_INCFAT2
For [LNK_] Where evalue(B_CRITERE)
 If !SILENCE
  LEC += 1
  Call AFF_BOITE("",LEC,INTE) From GESECRAN
 Endif
 K = 1
 If [F:ABV]FILTRE<>""
  FLD = "FILTRE"
  FORMULE = [F:ABV]FILTRE
  Onerrgo ERFOR
  K = evalue(FORMULE)
  Onerrgo ERR
 Endif
 If K
  Gosub ECR_INCFATDET
  B_NBENREG += 1
  If B_BREAK>0 & B_NBENREG>=B_BREAK
   B_CRITERE = "[F:AUD]SEQ>"+num$([F:AUD]SEQ)
   B_STOP = 1
   Break
  Endif
 Endif
Next LNK_
If B_BREAK>0 & B_STOP>0
 B_NBENREG = 0
 B_STOP    = 0
 Goto ECR_INCFAT2
Endif
Return

#-----------------------------------------------------------------#
$ECR_INCFAT
Raz ERFOR , LEC
For [AUD]
 If !SILENCE
  LEC += 1
  Call AFF_BOITE("",LEC,INTE) From GESECRAN
 Endif
 NBVAL = 1
 VALCLE(NBVAL) = [F:AUD]ID1
 CHAINE = [F:AUD]ID2
 While CHAINE<>""
  NBVAL += 1
  K = instr(1,CHAINE,"~")
  If K
   VALCLE(NBVAL) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   VALCLE(NBVAL) = CHAINE
   CHAINE = ""
  Endif
 Wend
 Raz [LNK_]
 I = 0
 While I<NBTCLE
  I += 1
  Case evalue("type([F:LNK_]"+TCLE(I)+")")
   When 1,2,4,5,6,7
    Assign "[F:LNK_]"+TCLE(I) With val(VALCLE(I))
   When 3
    Raz GMESSAGE
    FMDDATSAV = GFMDAT4
    GFMDAT4 = "DD[/]MM[/]YYYY"
    Call CHARGE(VALCLE(I),"D",0,0,CHAINE) From FMTVAR
    GFMDAT4 = FMDDATSAV
    If GMESSAGE<>""
     Call ECR_TRACE(GMESSAGE,1) From GESECRAN
     Raz GMESSAGE
    Else
     Assign "[F:LNK_]"+TCLE(I) With CHAINE
    Endif
   When 525
    Assign "[F:LNK_]"+TCLE(I) With toUuid(func ABIMAJBAS.VALUE_TO_UUID(VALCLE(I)))
   When 526
    Assign  "[F:LNK_]"+TCLE(I) With gdatetime$(VALCLE(I))
   When Default
    CHAINE = VALCLE(I)
    If len(CHAINE)>0 & vireblc(CHAINE,2)=""
     CHAINE = space$(len(CHAINE)-1)
    Endif
    Assign "[F:LNK_]"+TCLE(I) With CHAINE
  Endcase
 Wend
 K = 0
 # Lecture de l'enregistrement de la table origine auditée
 Read [LNK_] =
 If !fstat
  K = 1
  If [F:ABV]FILTRE<>""
   FLD = "FILTRE"
   FORMULE = [F:ABV]FILTRE
   Onerrgo ERFOR
   K = evalue(FORMULE)
   Onerrgo ERR
  Endif
 Else
  If [F:AUD]EVT<>"DELETE"
   K =0
   [F:AUD]STABI = 4
   Rewrite [AUD]
  Endif
 Endif
 If K or ([F:AUD]EVT="DELETE")
  Gosub ECR_INCFATDET
 Endif
Next AUD
Return

$ECR_INCFATDET
If [L]DET=2
 # Enregistrement audit
 CHAINE = "*    "+mess(43,148,1)-":"-[F:AUD]ID1-[F:AUD]ID2
 CHAINE -= "("+[F:AUD]EVT-format$(GFMD,[F:AUD]DAT)-format$("K:##[:]##[:]##",[F:AUD]HOU)+")"
 Call ECR_TRACE(CHAINE,0) From GESECRAN
Endif
ACTION = "BOUCLE_FAT" : Gosub ACTIONF
# Insert/Update/Delete de l'enregistrement de la table de faits (et des agrégats)
Case [F:AUD]EVT
 When "INSERT"
  Case [F:ABV]TYPLNK
   When 1,3 : # 1,1
    indice = 0
    Gosub CHARGE_CLE
    Raz [F:AAA_]
    Gosub CHARGE_FLDREG
    K = 0
    Write [AAA_]
    If fstat
     Read [AAA_] =
     If !fstat
      Gosub CHARGE_FLDREG
      K = 1
      Rewrite [AAA_]
     Endif
     If fstat
      Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
     Else
      MAJ += 1
      If [L]DET=2
       Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&        From GESECRAN
      Endif
      Gosub INSERT From =APPLI+"."+PRGAGG
      [F:AUD]STABI = 4 : # CCL
      Rewrite [AUD]
     Endif
    Elsif !ERFOR
     CRE += 1
     If [L]DET=2
      Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&       From GESECRAN
     Endif
     Gosub INSERT From =APPLI+"."+PRGAGG
     [F:AUD]STABI = 4 : # CCL
     Rewrite [AUD]
    Endif
   When 2,4 : # 1,n
    J = evalue("dim([F:LNK_]"+[F:ABV]FLDDEC+")")
    For indice=0 To J-1
     K = 0
     If [F:ABV]CNDLIG=""
      K = 1
     Else
      Raz FLD , ERFOR
      Onerrgo ERFOR
      FORMULE = [F:ABV]CNDLIG
      K = evalue(FORMULE)
      If ERFOR : K = 0 : Endif
      Onerrgo ERR
     Endif
     If K
      Gosub LIEN From =APPLI+"."+NOMPRG
      Gosub CHARGE_CLE
      Write [AAA_]
      If fstat
       Read [AAA_] =
       If !fstat
        Gosub CHARGE_FLDREG
        K = 1
        Rewrite [AAA_]
       Endif
       If fstat
        Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
       Else
        MAJ += 1
        If [L]DET=2
         Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&          From GESECRAN
        Endif
        Gosub INSERT From =APPLI+"."+PRGAGG
        [F:AUD]STABI = 4 : # CCL
        Rewrite [AUD]
       Endif
      Elsif !ERFOR
       CRE += 1
       If [L]DET=2
        Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&       From GESECRAN
       Endif
       Gosub INSERT From =APPLI+"."+PRGAGG
       [F:AUD]STABI = 4 : # CCL
       Rewrite [AUD]
      Endif
     Endif
    Next indice
  Endcase
 When "UPDATE"
  Case [F:ABV]TYPLNK
   When 1,3 : # 1,1
    indice = 0
    Gosub CHARGE_CLE
    Read [AAA_] =
    If fstat
     Raz [F:AAA_]
     Gosub CHARGE_FLDREG
     K = 0
     Write [AAA_]
     If !fstat : CRE += 1 : Endif
    Else
     Gosub ERASE From =APPLI+"."+PRGAGG
     Gosub CHARGE_FLDREG
     K = 1
     Rewrite [AAA_]
     If !fstat : MAJ += 1 : Endif
    Endif
    If fstat
     Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
    Elsif !ERFOR
     If [L]DET=2
      Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&       From GESECRAN
     Endif
     Gosub INSERT From =APPLI+"."+PRGAGG
     [F:AUD]STABI = 4 : # CCL 3
     Rewrite [AUD]
    Endif
   When 2,4 : # 1,n
    J = evalue("dim([F:LNK_]"+[F:ABV]FLDDEC+")")
    For indice=0 To J-1
     K = 0
     If [F:ABV]CNDLIG=""
      K = 1
     Else
      Raz FLD , ERFOR
      Onerrgo ERFOR
      FORMULE = [F:ABV]CNDLIG
      K = evalue(FORMULE)
      If ERFOR : K = 0 : Endif
      Onerrgo ERR
     Endif
     If K
      Gosub LIEN From =APPLI+"."+NOMPRG
      Gosub CHARGE_CLE
      Read [AAA_] =
      If fstat
       Raz [F:AAA_]
       Gosub CHARGE_FLDREG
       K = 0
       Write [AAA_]
       If !fstat : CRE += 1 : Endif
      Else
       Gosub ERASE From =APPLI+"."+PRGAGG
       Gosub CHARGE_FLDREG
       K = 1
       Rewrite [AAA_]
       If !fstat : MAJ += 1 : Endif
      Endif
      If fstat
       Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
      Elsif !ERFOR
       If [L]DET=2
        Call ECR_TRACE("**   "+mess(59+K,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0) From GESECRAN
       Endif
       Gosub INSERT From =APPLI+"."+PRGAGG
       [F:AUD]STABI = 4 : # CCL 3
       Rewrite [AUD]
      Endif
     Endif
    Next indice
  Endcase
 When "DELETE"
  Case [F:ABV]TYPLNK
   When 1,3 : # 1,1
    indice = 0
    Gosub CHARGE_CLE
    Read [AAA_] =
    If !fstat
     Gosub ERASE From =APPLI+"."+PRGAGG
     Delete [AAA_] Curr
     If fstat
      Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,3) From DOSDIC
     Elsif !ERFOR
      SUP += 1
      If [L]DET=2
       Call ECR_TRACE("**   "+mess(53,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&        From GESECRAN
      Endif
      [F:AUD]STABI = 4 : # CCL 3
      Rewrite [AUD]
     Endif
    Else
     [F:AUD]STABI = 4
     Rewrite [AUD]
    Endif
   When 2,4 : # 1,n
    J = evalue("dim([F:LNK_]"+[F:ABV]FLDDEC+")")
    For indice=0 To J-1
     K = 0
     If [F:ABV]CNDLIG=""
      K = 1
     Else
      Raz FLD , ERFOR
      Onerrgo ERFOR
      FORMULE = [F:ABV]CNDLIG
      K = evalue(FORMULE)
      If ERFOR : K = 0 : Endif
      Onerrgo ERR
     Endif
     If K
      Gosub LIEN From =APPLI+"."+NOMPRG
      Gosub CHARGE_CLE
      Read [AAA_] =
      If !fstat
       Gosub ERASE From =APPLI+"."+PRGAGG

       Delete [AAA_] Curr
       If fstat
        Call ERREUR(TABLE-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,1) From DOSDIC
       Elsif !ERFOR
        SUP += 1
        If [L]DET=2
         Call ECR_TRACE("**   "+mess(53,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0)
&          From GESECRAN
        Endif
        [F:AUD]STABI = 4 : # CCL 3
        Rewrite [AUD]
       Endif
      Else
       [F:AUD]STABI = 4
       Rewrite [AUD]
      Endif
     Endif
    Next indice
  Endcase
Endcase
If ERFOR : Return : Endif
Return

#------------------------------------#
$CHARGE_CLE
K = instr(1,GDOSSIER,"@")
If K
 [F:AAA_]ADOS = right$(GDOSSIER,K+1)
Else
 [F:AAA_]ADOS = GDOSSIER
Endif
[F:AAA_]AREG = [F:ABV]CODREG
[F:AAA_]AIND = indice
FLD = "ACLE"
[F:AAA_]ACLE = ""
If  [F:AUD]EVT <>"DELETE"
 For I=1 To NBTCLE
  If [F:AAA_]ACLE<>"" : [F:AAA_]ACLE += "~" : Endif
   FORMULE = '[F:'+[L]ABR_TABORG+']'+TCLE(I)
  [F:AAA_]ACLE += num$(evalue(FORMULE))
 Next I
Else
 For I=1 To NBTCLE
  CHAINE = ""
  If [F:AAA_]ACLE<>"" : [F:AAA_]ACLE += "~" : Endif
  Case evalue("type([F:"+[L]ABR_TABORG+"]"+TCLE(I)+")")
   When 1,2,4,5,6,7
    CHAINE = VALCLE(I)
   When 3
    Raz GMESSAGE
    FMDDATSAV = GFMDAT4
    GFMDAT4 = "DD[/]MM[/]YYYY"
    Call CHARGE(VALCLE(I),"D",0,0,CHAINE) From FMTVAR
    GFMDAT4 = FMDDATSAV
    If GMESSAGE<>""
     Call ECR_TRACE(GMESSAGE,1) From GESECRAN
     Raz GMESSAGE
    Endif
    CHAINE = VALCLE(I)
   When 525
    CHAINE = VALCLE(I)
   When 526
    CHAINE = VALCLE(I)
   When Default
    CHAINE = VALCLE(I)
    If len(CHAINE)>0 & vireblc(CHAINE,2)=""
     CHAINE = space$(len(CHAINE)-1)
    Endif
   Endcase
   [F:AAA_]ACLE += CHAINE
 Next I
Endif
Return

#-----------------------------------------------------------------#
$MAJ_RAZ_AGG
DOSSIER = MACHINE+"@"+[F:ABW]COD
For [ABE]ABE1 Where CODABF=TBFAT(R)
 TABLE = [F:ABE]CODABF+"_"+[F:ABE]CODAGG
 If TABLE>=[L]DEBAGG & ([L]FINAGG="" or TABLE<=[L]FINAGG) & find(TABLE,LISFIC(1..NBFIC))
  INFO = TABLE
  Gosub INFO
  If [L]SIMU<>2
   Call SET_PREF([F:ABE]CODABF,PREF) From SUBABF
   NOMPRG = PREF+[F:ABE]CODABF
   Call RAZ_TABLE(MACHINE,[F:ABW]COD,TABLE,[L]SIMU)
   Case [F:ABE]NUMAGG
    When 1 : Gosub ALIM_1 From =APPLI+"."+NOMPRG
    When 2 : Gosub ALIM_2 From =APPLI+"."+NOMPRG
    When 3 : Gosub ALIM_3 From =APPLI+"."+NOMPRG
    When 4 : Gosub ALIM_4 From =APPLI+"."+NOMPRG
    When 5 : Gosub ALIM_5 From =APPLI+"."+NOMPRG
    When 6 : Gosub ALIM_6 From =APPLI+"."+NOMPRG
    When 7 : Gosub ALIM_7 From =APPLI+"."+NOMPRG
    When 8 : Gosub ALIM_8 From =APPLI+"."+NOMPRG
   Endcase
   If clalev([F:AAA_])>0
    # nbre d'enregistrements créés
    Call ECR_TRACE("***  "+num$(nbrecord([F:AAA_]))-mess(103,141,1),0) From GESECRAN
    Close Local File [AAA0] , [AAA_]
   Endif
  Endif
 Endif
Next ABE
Return

#########################################################################################
##" verif si une regle de synchro est associé a la table d'origine de la dimension et si elel est deasctivé
#########################################################################################
Funprog TABLEORI_ABV(DIMENSION)
Value Char DIMENSION

If !clalev([ABI_]) : Local File ABIDIM    [ABI_] : Endif
If !clalev([ABV_]) : Local File ABIREGORG [ABV_] : Endif

Local Integer NBTAB,NBTABDIS

Read [ABI_]ABI0 = DIMENSION
If fstat : End 0 : Endif
For [ABV_]ABV1 Where TABORG = [ABI_]TABORG
 NBTAB += 1
 If dim([F:ABV_]DESFLG)>0 & [F:ABV_]DESFLG=2
  NBTABDIS += 1
 Endif
Next ABV_

If NBTAB = 0          : End 1 : Endif   : # Aucune regle ne prend en compte cette table    :    on traite la dimension
If NBTAB=NBTABDIS     : End 0 : Endif   : # Toutes les regles sont inactives alors         :    on ne traite pas la dimension
If NBTAB<>NBTABDIS    : End 1 : Endif   : # Toutes les regles ne sont pas inactives alors  :    on traite la dimension
End 1

#########################################################################################
# Evalue cle pour break_lig
#########################################################################################
Funprog EVAL_CLE(CLE,TYP)
Value Char CLE
Value Integer TYP
Local Char CHAINE
Case TYP
 When 1,2,3,4,5,6   : CHAINE = num$(evalue(CLE))
 When 8             : CHAINE = num$(evalue(CLE))
 When Default       : CHAINE = '"'+evalue(CLE)+'"'
Endcase
End CHAINE

#########################################################################################
# Evalue cle pour break_lig
#########################################################################################
Funprog CRITAUD(DOSSIER,DOSAUD,MAXAUD,NBDOSAUD)
Value Char DOSSIER
Value Char DOSAUD()
Value Decimal MAXAUD(0..)
Value Integer NBDOSAUD


Local Char CRITAUD(250)

CRITAUD = "1=1"
For I=0 To NBDOSAUD-1
 If [L]DOSSIER=DOSAUD(I)
  CRITAUD = "SEQ<="+num$(MAXAUD(I))
  Break
 Endif
Next

End CRITAUD

########################################################################################
# POur le multidossier deb
########################################################################################
$DEFVARDEB
If GDOSSIER<>nomap & [L]SIMU<>2
 Local Integer LCPY,LTCU,LFCY
 If clalev([F:CPY])>0 : Close Local File [CPY] : LCPY=1 : Endif
 If clalev([F:FCY])>0 : Close Local File [FCY] : LFCY=1 : Endif
 If clalev([F:TCU])>0 : Close Local File [TCU] : LTCU=1 : Endif

 Local File =GDOSSIER+".COMPANY"  [CPY]
 Local File =GDOSSIER+".FACILITY" [FCY]
 Local File =GDOSSIER+".TABCUR"   [TCU]

 Call INISOC From GLOBSUP
 Call INIDEV From GLOBSUP
Endif
Return

########################################################################################
# POur le multidossier fin
########################################################################################
$DEFVARFIN
If GDOSSIER<>nomap & [L]SIMU<>2
 If clalev([F:CPY])>0 : Close Local File [CPY] : Endif
 If clalev([F:FCY])>0 : Close Local File [FCY] : Endif
 If clalev([F:TCU])>0 : Close Local File [TCU] : Endif

 Local File COMPANY  [CPY]
 Local File FACILITY [FCY]
 Local File TABCUR   [TCU]

 Call INISOC From GLOBSUP
 Call INIDEV From GLOBSUP

 If dim(LCPY)>0 & LCPY=0 : Close Local File [CPY] : Endif
 If dim(LTCU)>0 & LTCU=0 : Close Local File [TCU] : Endif
 If dim(LFCY)>0 & LFCY=0 : Close Local File [FCY] : Endif
Endif
Return

#---------------------------------------------------------------------------------------#
Subprog C_CODDOS(VALEUR)
Variable Char    VALEUR()
Read [F:ABW]ABW0 = VALEUR
If !fstat & [F:ABW]LAN <> GLANGUE
 GMESSAGE = func AFNC.MES2(mess(165,148,1),[F:ABW]LAN,GLANGUE)
 mkstat =2 : End
Endif
End

Subprog AV_TYPVAL(VALEUR)
Variable Integer VALEUR
Gosub GRISE_TYP
End

Subprog AM_TYPVAL(VALEUR)
Variable Integer VALEUR
[M]TYPVAL = VALEUR : Gosub GRISE_TYP
End

$GRISE_TYP
Case [M]TYPVAL
 When 2
  [M]SACC = 2 : [M]DEBACC = ""      : [M]FINACC = ""
  [M]SDAT = 2
  #If GPRODUIT=2
  # [M]DEBDAT = min(GDATDEB,gdat$(1,1,year(GDATDEB)-70))
  #Else
  # [M]DEBDAT = GDATDEB
  #Endif
  #[M]FINDAT = min(GDATFIN,gdat$(31,12,int(year(GDATDEB)/100)*100+99))
  # bug 64024
  [M]DEBDAT  = gdat$(01,01,1899)
  [M]FINDAT  = gdat$(31,12,2099)
  [M]SDOS = 2
  [M]SAUZ = 2 : [M]DEBAUZ = ""      : [M]FINAUZ = ""
  [M]SMEN = 2 : [M]DEBMEN = 0       : [M]FINMEN = 0
  [M]SADI = 2 : [M]DEBADI = 0       : [M]FINADI = 0
  [M]SDIM = 2 : [M]DEBDIM = ""      : [M]FINDIM = ""
  [M]SFAT = 2 : [M]DEBFAT = ""      : [M]FINFAT = ""
  [M]SAGG = 2 : [M]DEBAGG = ""      : [M]FINAGG = ""
  Affzo [DIA]20-25
  Actzo GEN
  Diszo SACC , DEBACC , FINACC
  Diszo SDAT : # , DEBDAT , FINDAT
  Actzo DEBDAT , FINDAT

  Diszo SDOS
  Diszo SAUZ , DEBAUZ , FINAUZ
  Diszo SMEN , DEBMEN , FINMEN
  Diszo SADI , DEBADI , FINADI
  Diszo SDIM , DEBDIM , FINDIM
  Diszo SFAT , DEBFAT , FINFAT
  Diszo SAGG , DEBAGG , FINAGG
 When Default
  Actzo [DIA]
  Gosub GRISE_ACC
  Gosub GRISE_DAT
  Gosub GRISE_AUZ
  Gosub GRISE_MEN
  Gosub GRISE_ADI
  Gosub GRISE_DIM
  Gosub GRISE_FAT
  Gosub GRISE_AGG
Endcase
Return

Subprog AM_GEN(VALEUR)
Variable Integer VALEUR
[M]GEN = VALEUR : Gosub GRISE_TYP
End

Subprog AM_SACC(VALEUR)
Variable Integer VALEUR
Effzo DEBACC , FINACC
[M]SACC = VALEUR : Gosub GRISE_ACC
End

Subprog AM_SDAT(VALEUR)
Variable Integer VALEUR
Effzo DEBDAT , FINDAT
[M]SDAT = VALEUR : Gosub GRISE_DAT
End

Subprog AM_SAUZ(VALEUR)
Variable Integer VALEUR
Effzo DEBAUZ , FINAUZ
[M]SAUZ = VALEUR : Gosub GRISE_AUZ
End

Subprog AM_SMEN(VALEUR)
Variable Integer VALEUR
Effzo DEBMEN , FINMEN
[M]SMEN = VALEUR : Gosub GRISE_MEN
End

Subprog AM_SADI(VALEUR)
Variable Integer VALEUR
Effzo DEBADI , FINADI
[M]SADI = VALEUR : Gosub GRISE_ADI
End

Subprog AM_SDIM(VALEUR)
Variable Integer VALEUR
Effzo DEBDIM , FINDIM
[M]SDIM = VALEUR : Gosub GRISE_DIM
End

Subprog AM_SFAT(VALEUR)
Variable Integer VALEUR
Effzo DEBFAT , FINFAT
[M]SFAT = VALEUR : Gosub GRISE_FAT
Gosub GRISE_AGG
End

Subprog AM_SAGG(VALEUR)
Variable Integer VALEUR
Effzo DEBAGG , FINAGG
[M]SAGG = VALEUR : Gosub GRISE_AGG
End

Subprog D_FINACC(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBACC<>"" : VALEUR = [M]DEBACC : Endif
End

Subprog D_FINDAT(VALEUR)
Variable Date    VALEUR
VALEUR = min(GDATFIN,gdat$(31,12,int(year(GDATDEB)/100)*100+99))
End

Subprog D_FINAUZ(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBAUZ<>"" : VALEUR = [M]DEBAUZ : Endif
End

Subprog D_FINMEN(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M]DEBMEN<>0 : VALEUR = [M]DEBMEN : Endif
End

Subprog D_FINADI(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M]DEBADI<>0 : VALEUR = [M]DEBADI : Endif
End

Subprog D_FINDIM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBDIM<>"" : VALEUR = [M]DEBDIM : Endif
End

Subprog D_FINFAT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBFAT<>"" : VALEUR = [M]DEBFAT : Endif
End

Subprog D_FINAGG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DEBAGG<>"" : VALEUR = [M]DEBAGG : Endif
End

Subprog D_DEBDAT(VALEUR)
Variable Date    VALEUR
If GPRODUIT=2
 VALEUR = min(GDATDEB,gdat$(1,1,year(GDATDEB)-70))
Else
 VALEUR = GDATDEB
Endif
End

Subprog C_FINDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DEBDAT : mkstat = 2 : End : Endif
End

$GRISE_ACC
If [M]SACC<>2
 [M]DEBACC = ""
 [M]FINACC = ""
 Diszo DEBACC , FINACC
Else
 Actzo DEBACC , FINACC
Endif
Return

$GRISE_DAT
If [M]SDAT<>2
 [M]DEBDAT = [0/0/0]
 [M]FINDAT = [0/0/0]
 Diszo DEBDAT , FINDAT
Else
 Actzo DEBDAT , FINDAT
Endif
Return

$GRISE_AUZ
If [M]SAUZ<>2
 [M]DEBAUZ = ""
 [M]FINAUZ = ""
 Diszo DEBAUZ , FINAUZ
Else
 Actzo DEBAUZ , FINAUZ
Endif
Return

$GRISE_MEN
If [M]SMEN<>2
 [M]DEBMEN = 0
 [M]FINMEN = 0
 Diszo DEBMEN , FINMEN
Else
 Actzo DEBMEN , FINMEN
Endif
Return

$GRISE_ADI
If [M]SADI<>2
 [M]DEBADI = 0
 [M]FINADI = 0
 Diszo DEBADI , FINADI
Else
 Actzo DEBADI , FINADI
Endif
Return

$GRISE_DIM
If [M]SDIM<>2
 [M]DEBDIM = ""
 [M]FINDIM = ""
 Diszo DEBDIM , FINDIM
Else
 Actzo DEBDIM , FINDIM
Endif
Return

$GRISE_FAT
If [M]SFAT<>2
 [M]DEBFAT = ""
 [M]FINFAT = ""
 Diszo DEBFAT , FINFAT
 If [M]TYPVAL=2
  [M]SAGG = 2
  Affzo SAGG
  Diszo SAGG
 Elsif [M]TYPVAL=3
  [M]SAGG = 1
  Affzo SAGG
  Diszo SAGG
 Else
  Actzo SAGG
 Endif
Else
 If !find([M]TYPVAL,2)
  Actzo DEBFAT , FINFAT
 Else
  [M]DEBFAT = ""
  [M]FINFAT = ""
  Diszo DEBFAT , FINFAT
 Endif
 [M]SAGG = 2
 Affzo SAGG
 Diszo SAGG
Endif
Gosub GRISE_AGG
Return

$GRISE_AGG
If [M]SFAT=2 or [M]SAGG<>2 or ([M]GEN=2 & find([M]TYPVAL,2))
 [M]DEBAGG = ""
 [M]FINAGG = ""
 Affzo DEBAGG , FINAGG
 Diszo DEBAGG , FINAGG
Else
 Actzo DEBAGG , FINAGG
Endif
Return



Funprog VALUE_TO_UUID(VALUE_UUID)
Value Char VALUE_UUID

If len(VALUE_UUID)=32
 VALUE_UUID = mid$(VALUE_UUID,1,8)+"-"+mid$(VALUE_UUID,9,4)+"-"+mid$(VALUE_UUID,13,4)+"-"+mid$(VALUE_UUID,17,4)+"-"+mid$(VALUE_UUID,21,12)
Endif

End VALUE_UUID

