#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################################################
#   Consultation des synthèses                                     Module CRM          5 Décembre 2003
#########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
Global Integer GISYNHBDISP
GISYNHBDISP = 0

If PARAM(1) = ""
    #Aucun contexte n'a été communiqué. Accès refusé.
    GMESSAGE = mess(828, 182, 2)
    GERR = 1
    FIN = 1
    Return
Endif

Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Grizo [M:SYN1]SYN

Case PARAM(1)
    When "LKP8SRE"
        [M:SYN1]SYN = [M:LKP8]DES

    When "SRE4SRE"
        [M:SYN1]SYN = [M:SRE4]DES

    When "SRE4SOL"
        [M:SYN1]SYN = [M:SRE4]SOL

    When "SSOSRE"
        [M:SYN1]SYN = [M:SSO1]PBLDES

    When "SSOSOL"
        [M:SYN1]SYN = [M:SSO2]SOLDES

    When Default
Endcase

Affzo [M:SYN1]

GISYNHBDISP = 1
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
If GISYNHBDISP
    Raz [M:SYN1]
Endif

Kill GISYNHBDISP
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
