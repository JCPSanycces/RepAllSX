#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque POHA
##########################################################################
# TRTACHREV1         Traitements liés aux avenants          Module ACHAT #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                   #
#   - VISUREVPOQ : Visualisation historique avenants ligne de commande   #
##########################################################################


$ACTION
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "VISUREVPOQ"  : Gosub OUV_VISUREVPOQ 
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "VISUREVPOQ"  : TIT=mess(174,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "VISUREVPOQ"  : Gosub DEB_VISUREVPOQ
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "VISUREVPOQ"  : Gosub FINSAI_VISUREVPOQ
  Endcase
Endcase
Return


#############################################################################
# AVENANTS_LIG_CDE : S/P d'affichage de l'historique des       MBT 20/07/99 #
#                    avenants d'une ligne de commande                       #
#   NUMCDE   : Numéro   de la commande à traiter                            #
#   LINCDE   : Numéro   de la ligne de commande à traiter                   #
#   SEQCDE   : Séquence de la ligne de commande à traiter                   #
#   ABMSK    : Abréviation du masque écran contenant les lignes             #
#   NOL      : Numéro de ligne tableau des lignes commande (nolign-1)       #
#  Attention : GCUR est la devise de la commande                            #
# ------------------------------------------------------------------------- #
# Remplacé par l'action VISUREVPOQ avec paramètres :           MBT 05/12/00 #
#   PARAM(1) = NUM    : Numéro   de la commande à traiter                   #
#   PARAM(2) = LIN    : Numéro   de la ligne de commande à traiter          #
#   PARAM(3) = SEQ    : Séquence de la ligne de commande à traiter          #
#   PARAM(4) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(5) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUREVPOQ
#----- Variables locales -----#
Local Char     NUMCDE(GLONPOH) : NUMCDE=PARAM(1)
Local Integer  LINCDE          : LINCDE=val(PARAM(2))
Local Integer  SEQCDE          : SEQCDE=val(PARAM(3))
Local Char     WABMSK(4)       : WABMSK =PARAM(4)
Local Shortint NOL             : NOL=val(PARAM(5))
Local Integer  I
Local Shortint SAVGNOLIGN
SAVNOLIGN=nolign
If evalue("[M:"+WABMSK+"]LINREVNUM(NOL)=0") | 
&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''")   | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUREVPOQ
Raz [M:POHA]
Call TEMPON("O") From GESECRAN
#----- Lecture ligne commande à traiter si nécessaire -----#
If [F:POQ]POHNUM<>NUMCDE | [F:POQ]POPLIN<>LINCDE | [F:POQ]POQSEQ<>SEQCDE
  Read [POQ] POQ0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:POQ] : Endif
Endif
If [F:POP]POHNUM<>NUMCDE | [F:POP]POPLIN<>LINCDE | [F:POP]POPSEQ<>SEQCDE
  Read [POP] POP0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:POP] : Endif
Endif
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:UOQ])<=0 Local File UPORDERQ [UOQ] : Endif
If clalev([F:UOP])<=0 Local File UPORDERP [UOP] : Endif
#----- Chargement des zones dans le masque -----#
nolign=1
[M:POHA]=[F:POQ] : [M:POHA]=[F:POP] : # Chargement 1ère ligne du tableau
[M:POHA]LINREVDAT(0) = [F:POQ]UPDDAT
[M:POHA]VAT1(0)=[F:POP]VAT(0)
[M:POHA]VAT2(0)=[F:POP]VAT(1)
[M:POHA]VAT3(0)=[F:POP]VAT(2)
#----- Chargement des comptes et sections analytiques -----#
Call CHARG_ACCCCE(0,"[M:POHA]LINACC","","[M:POHA]CCE","POP",
&         0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"") From TRTX3CPT
#----- Chargement des autres lignes du tableau -----#
Filter [UOQ] Where POHNUM=NUMCDE & POPLIN=LINCDE Order By Key POQ0 Desc
For [UOQ]
  If [F:UOQ]REVCOD="A" Break: Endif
  Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]LINREVNUM;LINCDE;[F:UOQ]POQSEQ
  If fstat Raz [F:UOP] : Endif
  nolign+=1
  [M:POHA]=[F:UOQ] : [M:POHA]=[F:UOP] : [M:POHA]LINREVDAT(nolign-1)=[F:UOQ]CREDAT
  [M:POHA]VAT1(nolign-1)=[F:POP]VAT(0)
  [M:POHA]VAT2(nolign-1)=[F:POP]VAT(1)
  [M:POHA]VAT3(nolign-1)=[F:POP]VAT(2)
  Call CHARG_ACCCCE(nolign-1,"[M:POHA]LINACC","","[M:POHA]CCE","UOP",
&         0,[F:UOP]POHNUM,[F:UOP]POPLIN,[F:UOP]POPSEQ,num$([F:UOP]LINREVNUM)) From TRTX3CPT
  If nolign>dim([M:POHA]LINREVNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
[M:POHA]NBLIG=nolign
#----- Chargement zones d'entête -----#
[M:POHA]POHNUM = NUMCDE
[M:POHA]POPLIN = LINCDE
[M:POHA]ITMREF = evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:POHA]CUR    = GCUR
For I=0 To 8
    [M:POHA]FMTREM(I) = evalue("[M:"+WABMSK+"]FMTREM(I)")
Next
#----- Affichage foreground -----# 
Filter [UOQ]
Affzo [POHA] 
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUREVPOQ
nolign=SAVNOLIGN
Return
