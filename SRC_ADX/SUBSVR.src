#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("SVR",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "SETBOUT"   : Gosub SETBOUT
 When "FERME"     : Gosub FERME
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "AS_COD"    : Raz GCURLEG        :#Used in SELOBJETL action to disable the filter under the current legislation
Endcase
Return

########################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONSVR) : Endif
VCOD = CLE2
Return

########################################
$LIENS
#Multi_leg
GCURLEG=[F:SVR]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
#ADNGO - 2017-07-13 - X3-46580 - START
#Call LECTEXTRA([M]DES,"SCRVRA","DES",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]DES,"SCRVRA","DES",GCURLEG,[M]COD) From ATEXTRA
#ADNGO - 2017-07-13 - X3-46580 - END
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 #ADNGO - 2017-07-13 - X3-46580 - START
 #Call DUPTEXTRA("SCRVRA","DES",CLECUR1,"","SCRVRA","DES",[F:SVR]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("SCRVRA","DES",CLECUR1,"","SCRVRA","DES",GCURLEG,[F:SVR]COD)  From ATEXTRA
 #ADNGO - 2017-07-13 - X3-46580 - END
Endif
#ADNGO - 2017-07-13 - X3-46580 - START
#Call MAJTEXTRA([M]DES,"SCRVRA","DES",[F:SVR]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]DES,"SCRVRA","DES",GCURLEG,[F:SVR]COD) From ATEXTRA
#ADNGO - 2017-07-13 - X3-46580 - END
Return

########################################
$SETBOUT
If GREP<>"" | CLECUR=0 | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M:SVR0]NBRVAR=0
 GMESSAGE = mess(47,10702,1) : # Saisissez au moins une variable
 OK=0 : Return
Endif
Return

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
#ADNGO - 2017-07-13 - X3-46580 - START
#Call CHGTEXTRA("SCRVRA","DES",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("SCRVRA","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
#ADNGO - 2017-07-13 - X3-46580 - END
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("SCRVRA","DES",SUPP,[L]CODE) From ATEXTRA
Return

#Button COPY
########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCRVRA   [SVR1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".SCRVRA"   [SVR1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File SCRVRA   [SVR2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".SCRVRA"   [SVR2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [SVR1], [SVR2]
Close Local File [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [SVR2]
 Delete [SVR2] Where COD=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRVRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SVR2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [SVR1] Where COD=TABLE & LEG=TABLE2
  [F:SVR2] = [F:SVR1]
  Call COPTEXTRA("SCRVRA","DES",TABLE,TABLE2) From ATEXTRA
  If dim([F:SVR2]UPDUSR)>0 : [F:SVR2]UPDUSR = GUSER : Endif
  If dim([F:SVR2]UPDDAT)>0 : [F:SVR2]UPDDAT = date$ : Endif
  If dim([F:SVR2]UPDTIM)>0 : [F:SVR2]UPDTIM = time : Endif
  Write [SVR2]
  If fstat
   GOK = 0 : Call FSTA("SVR2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

######################################################################################
## Actions linked to data type SVR
######################################################################################
$SEL_TABLE
Case TABLE
  When "SELSVR"
    If clalev([F:SVR])=0 : Local File SCRVRA     [SVR] : Endif
    OBJET="SVR"
    START = "[F:SVR]COD"
    #Filter based on code legislation
    If PARAM(1)<>""
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:SVR]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
    Endif
Endcase
Return

########################################
Subprog CONTSVR(COD,LEG)
Variable Char    COD()
Value    Char    LEG

If GFONCTION = "GESSVR" | COD="" : End : Endif

If clalev([F:SVR])=0 : Local File SCRVRA     [SVR] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""
 Read [SVR]SVR0(1)=COD
 If !fstat
  LEG = [F:SVR]LEG
 Endif
Endif


Read [SVR]SVR0=COD;LEG
If fstat
 Filter [SVR] Where COD=COD
 Look [SVR]SVR0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [SVR]
 mkstat = 2 : End
Endif

Call CONTROLE("SVR","",LEG,COD,mkstat) From CONTOBJ

#Acces code
If GUSRACS<>2
 If [F:SVR]CODACS <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:SVR]CODACS
  If fstat or [F:ACC]CONSUL<>2
   GMESSAGE = [F:SVR]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

#Activity code
If [F:SVR]CODACT<>""
 If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
 Read [ACV]CODACT = [F:SVR]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = mess(42,10703,1) : # Variable diseable
  mkstat = 2 : End
 Endif
Endif

End

##################################################
Subprog TUNSVR(COD,LEG)
Variable Char    COD()
Value    Char    LEG
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONSVR)
 TOKILL = 1
Endif

If clalev([F:SVR])=0 : Local File SCRVRA     [SVR] : Endif

# To update the SVR code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""
 Read [SVR]SVR0(1)=VCOD
 If !fstat
  LEG = [F:SVR]LEG
 Endif
Endif

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [SVR] Where LEG=[L]LEG
  Read [F:SVR] First
  Filter [SVR]
  If !fstat : VCOD=[F:SVR]COD : Endif
Else
  Read [SVR]SVR0 = VCOD;LEG
Endif

If fstat : LEG = "" : Endif

Call OBJET("SVR",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End

##################################
Subprog FINDLEG(COD,LEG)
Value Char COD ()
Variable Char LEG ()
If clalev([F:SVR])=0 : Local File SCRVRA     [SVR] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG=""
 Read [SVR]SVR0(1)=COD
 If !fstat
  LEG = [F:SVR]LEG
 Endif
Endif

Read [SVR]SVR0 = COD;LEG
If fstat : Raz [SVR] : Raz LEG : Endif
End


######################################################################################
## Screens
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
Effzo [M]10
End

########################################
Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call LECTURE ("VRA",VALEUR,GCURLEG) From CONTOBJ
# Acces code execution
If VALEUR<>[M]VARCOD(nolign-1) & [F:VRA]CODACC<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;ACCES
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(41,10703,1)-[M]VARCOD(nolign-1) : # Accès interdit à cette variable
  mkstat = 2 : End
 Endif
Endif
End

########################################
Subprog AS_VARDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call LECTEXTRA( VALEUR,"VARIA","DESSHO",GCURLEG,[M]VARCOD(nolign-1)) From ATEXTRA
 If VALEUR=""
  Call LECTEXTRA( VALEUR,"VARIA","DES",GCURLEG,[M]VARCOD(nolign-1)) From ATEXTRA
 Endif
Endif
End

