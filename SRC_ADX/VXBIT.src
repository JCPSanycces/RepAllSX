#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Intersite Transfer - Stock Change
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, FCYDES, ITMREF, QTYSTUDES, STU
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# STADES, LOCDES, LOCTYPDES
# WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Inter-site
# Field 'Form'           --> No print
#
# VXBIT is the VT screen
#
########################################################

########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC
Local Integer TUNNEL            #--- Lot V01
Gosub OUVRE_SCS From ENVADC

Local Mask STOCOUW [STCW]

Return

########################################################
$DEBUT

Local Integer WOK, WCPT, LRET
Local Decimal WSVGQTY

# GFLAG contains the stock change transaction
GFLAG = func ENVADC.SETTRANS(4)

[M:XBIT]SRTNUM = GFLAG

Gosub DEBUT_SCS From ENVADC

Gosub INIT_SCREEN

If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN=1 : Return
Endif

Return

########################################################
$SETBOUT

#If !find("O",CHBOU) CHBOU+="O" Endif
If !find("1",CHMEN) CHMEN+="1" Endif

Return

########################################################
$OK

# Pour interdire la navigation
GREP="C"
FIN = 0
WSVGQTY = [M:XBIT]QTYSTUDES
# Alimentation  STOCHGW
Call CHGSTOCHGW("XBIT",2,"","",[M:XBIT]QTYSTUDES,LRET) From STKADC
If LRET<>0
   If [M:XBIT]QTYSTUDES<>WSVGQTY
      GMESSAGE = mess(45,196,1)-num$(WSVGQTY)-mess(507,197,1)-":"-num$([M:XBIT]QTYSTUDES)
   Endif
   GERR=1
Endif

WORISVG = [M:XBIT]ORI

[L]WCPT = [M:XBIT]WCPT
Effzo [M:XBIT]1-99
[M:XBIT]WCPT   = [L]WCPT+1
[M:XBIT]STOFCY = [M:SCS1]STOFCY
[M:XBIT]FCYDES = [M:SCS1]FCYDES
[M:XBIT]SRTNUM = GFLAG
[M:XBIT]ORI    = WORISVG
Affzo [M:XBIT]1-99

zonsui = "[M:XBIT]ITMREF"

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA
# Issue 110327
If [M:SCS1]NBLIG >0
  Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
Else
  Call RAZSTOCHGW From SUBSCSB
Endif
# End Issue 110327 - 2016-09-13 by MAE
Gosub INIT_SCREEN
GREP = ""
zonsui = "[M:XBIT]ITMREF"

Return

########################################################
$CRE
If [M:STCW]NBLIG<>0
   WSVGQTY = [M:XBIT]QTYSTUDES
   # Alimentation  STOCHGW
   Call CHGSTOCHGW("XBIT",2,"","",[M:XBIT]QTYSTUDES,LRET) From STKADC
   If LRET<>0
      If [M:XBIT]QTYSTUDES<>WSVGQTY
         GMESSAGE = mess(45,196,1)-num$(WSVGQTY)-mess(507,197,1)-":"-num$([M:XBIT]QTYSTUDES)
      Endif
      GERR=1 : Return
   Endif
Endif

Call CRE_SCS From ENVADC
#--- Lot V01
#-----impression des étiquettes ----#
If [F:SRT]PRNCOD1 = 2
   Call PRINT_ETI([M:SCS1]FCYDES ,[M:SCS1]VCRTYP,[M:SCS1]VCRNUM) From STKADC
Endif

GPROGRAMME = "GSAISIE"
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From= WINPROG
GREP="" : REP=""
GNOLIG = 0

Gosub INIT_SCREEN

GREP = ""
zonsui = "[M:XBIT]ITMREF"

Return

########################################################
$CHECK

If [M:SCS1]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XBIT]ITMREF" : Return
   Endif
Endif

Return

########################################################
$FIN

Gosub FIN_SCS From ENVADC

Raz [M:STCW]

GVTMOD=0

Return

########################################################
$INIT_SCREEN

Default Mask [SCS1]

Raz [M:SCS1]

# [M:SCS1]IPTDAT contains the date
# [M:SCS1]STOFCY contains the site
# [M:SCS1]DESFCY contains the destination site
[M:SCS1]IPTDAT = date$
[M:SCS1]STOFCY = GXAFCY

WORISVG = [M:XBIT]ORI

Raz [M:XBIT]
Raz [M:STCW]

Gosub INIT_SCS From ENVADC
[M:XBIT]ORI = WORISVG

# Issue 110327
#----- Ecran des paramètres d'allocations
If clalev([M:ALP])=0
  Local Mask ALLPAR    [ALP]
Endif

# Chargement du paramétrage lié au site
If GFCY<>[M:SCS1]STOFCY
   GFCY=[M:SCS1]STOFCY
   Gosub CHARG_PARAM From SUBSCSA
Endif

Affzo [XBIT]1-99

Return

########################################################
# Actions champs
########################################################

Subprog AM_SRTNUM(VALEUR)
Variable Char    VALEUR()
GFLAG = VALEUR
#--- Lot V01
GSCSNUM = VALEUR

[M:SCS1]TRSCOD = [F:SRT]TRSCOD
[M:SCS1]TRSFAM = [F:SRT]TRSFAMDEF
[M:SCS1]ENTCOD = [F:SRT]ENTCOD
End

Subprog AS_ORI(VALEUR)
Variable Integer VALEUR
If dim([M]LOT)   <0 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1 : Endif
If dim([M]SLO)   <0 : GMENLOC(1)=1 : GMENLOC(3)=1 : Endif
If dim([M]SERNUM)<0 : GMENLOC(5)=1 : GMENLOC(6)=1 : Endif
If dim([M]LOC)   <0 : GMENLOC(7)=1 : GMENLOC(8)=1 : Endif
If dim([M]PALNUM)<0 : GMENLOC(9)=1 : GMENLOC(10)=1 : Endif
End

Subprog C_ORI(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When  1 : If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  2 : If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  3 : Grizo [M]ITMREF
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  4 : Grizo [M]ITMREF
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  5 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  6 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  7 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  8 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  9 : Actzo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
 When 10 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
Endcase
End

Subprog AM_ORI(VALEUR)
Variable Integer VALEUR
Raz [M]ITMREF
If dim([M]LOT)   >0 Raz [M]LOT    Endif
If dim([M]SLO)   >0 Raz [M]SLO    Endif
If dim([M]SERNUM)>0 Raz [M]SERNUM Endif
If dim([M]LOC)   >0 Raz [M]LOC    Endif
If dim([M]PALNUM)>0 Raz [M]PALNUM Endif
End

Subprog C_FCYDES(VALEUR)
Variable Char    VALEUR()
Local Char WLIB(30)

# Destination site must be different than source site
If VALEUR=[M:SCS1]STOFCY : mkstat=2 : End : Endif

If clalev([F:FCY1])=0 : Local File FACILITY [FCY1] : Endif
Read [FCY1]FCY1 = [F:FCY]LEGCPY;[M:SCS1]STOFCY
# Inter-société
If fstat
  Local Char WFINFCY(GLONFCY)
  Local Char WLEGFCY(GLONCPY)
  [M:SCS1]BETCPY = 2
  Raz [F:FCY1]
  Read [FCY1]FCY0 = [M:SCS1]STOFCY
  If !fstat & [F:FCY1]SALFLG<>2
    WLEGCPY = [F:FCY1]LEGCPY
    Read [FCY1]FCY0 = [F:FCY1]FINRSPFCY
    If !fstat & [F:FCY1]SALFLG<>2
      WFINFCY=[F:FCY1]FCY
      Filter [FCY1] Where FINRSPFCY=WFINFCY & SALFLG=2
      Read [FCY1]FCY0 First
      Filter [FCY1]
      If fstat
        Filter [FCY1] Where LEGCPY=WLEGCPY & SALFLG=2
        Read [FCY1]FCY1 First
        Filter [FCY1]
      Endif
    Endif
  Endif
  If fstat
    # Pas de site de vente dans cette société
    Call TEXTE(1720,WLIB) From OBJDIV
    GMESSAGE=WLIB-":"-[M:SCS1]STOFCY-"\"+mess(132,184,1)-":"-WLEGCPY
    mkstat=2 : End
  Else
    # Alimentation site de vente
    [M:SCS1]SALFCY = [F:FCY1]FCY
    [M:SCS1]INVSGH = 2
    # Alimentation site d'achat
    If [F:FCY]PURFLG=2
      [M:SCS1]PURFCY=VALEUR
    Else
      Filter [FCY1] Where LEGCPY=[F:FCY]LEGCPY & PURFLG=2
      Read [FCY1]FCY1 First
      Filter [FCY1]
      If fstat
        # Pas de site d'achat dans cette société
        Call TEXTE(18038,WLIB) From OBJDIV
        GMESSAGE=WLIB-":"-VALEUR-"\"+mess(133,184,1)-":"-[F:FCY]LEGCPY
        mkstat=2 : End
      Else
        [M:SCS1]PURFCY=[F:FCY1]FCY
      Endif
    Endif
  Endif
# Intra-société
Else
  [M:SCS1]BETCPY = 1
  Raz [M:SCS1]SALFCY,[M:SCS1]PURFCY
  [M:SCS1]INVSGH = 1
Endif
[M:SGW]FCYDES = VALEUR
End

Subprog AM_FCYDES(VALEUR)
Variable Char    VALEUR()
Local Char    LSEC
Local Integer I

[M:SCS1]FCYADD = [F:FCY]BPAADD

# Récupération de la société
[M:SCS1]CPYDES = [F:FCY]LEGCPY
# Récupération des devises
Call GETDEV(VALEUR) From DEVSUB
[M:SCS1]CURDES = GLOCALDEV
Call GETDEV([M:SCS1]STOFCY) From DEVSUB    # Pour positionner glocaldev
If [M:SCS1]BETCPY<>2
   Raz [M:SCS1]PRI
Endif

# Initialisation des sections ana
# doit être fait en am_fcydes car des sections peuvent être fonction du site
[M:SCS1]FCYDES=VALEUR
For I=1 To GNBDIE
    If dim([M:SCS1]CCE)>0
        If [M:SCS1]BETCPY=2
            Call INISEC (LSEC, "ICOH", I) From TRTX3CPT
        Else
            Call INISEC (LSEC, "TRSH", I) From TRTX3CPT
        Endif
        [M:SCS1]CCE(I-1) = LSEC
    Else
        Break
    Endif
Next
End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,5,7) & VALEUR="" mkstat=2 Endif
End

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,7,8) & VALEUR=""     mkstat=2 Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,3,4) & VALEUR="" mkstat=2 Endif
End

Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,3) & VALEUR=""     mkstat=2 Endif
End

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,5,6) & VALEUR=""     mkstat=2 Endif
End

Subprog C_PALNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,9,10) & VALEUR=""             mkstat=2 Endif
End

Subprog AS_QTYSTUDES(VALEUR)
Variable Decimal VALEUR()
Local    Decimal WQTY,WQTA
Local    Integer LRET
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER), WSERF(GLONSER) # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif

# Issue 110327 - 2016-10-13 by MAE : pas d'appel au RECSTO si SERMGTCOD = 4
If [F:ITM]SERMGTCOD <> 4
  #--- Issue 103217 : ajout [M]PCU et [M]PCUSTUCOE
  # Issue 110327 - 2017-03-07 by MAE : Ajout de WSERF
  Call RECSTO(3,[F:SRT]TRSCOD,[M]ORI,[M]STOFCY,[M]FCYDES,[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,[M:XBIT]PCU,[M:XBIT]PCUSTUCOE,WQTY,WQTA) From STKADC

  VALEUR = WQTY
  If WQTY=0
    Call ERREUR(mess(314,184,1)) From GESECRAN
    zonsui = "[M:XBIT]ITMREF"
    End
  Endif
Endif

If [M]ITMREF<>"" Affzo [M]ITMREF Endif
If dim([M]LOT)>0
   [M]LOT=WLOT : Affzo [M]LOT
   If dim([M]SLO)>0
      [M]SLO=WSLO : Affzo [M]SLO
   Endif
Endif
If dim([M]SER)>0
   [M]SER=WSER : Affzo [M]SER
Endif
If dim([M]LOC)>0
   [M]LOC=WLOC : Affzo [M]LOC
Endif

# Si un seul article, alimentation statuts autorisés pour flux d'entrée
If [M]ITMREF<>""
   Call LECSRU([M]FCYDES,[F:ITM]TCLCOD,28,[F:SRT]TRSCOD,"",LRET) From STKLIB
   If LRET=0
      GSCSAUZSST = [F:SRU]AUZSST
   Else
      GSCSAUZSST = "A*,Q*,R*"
   Endif
Else
   GSCSAUZSST = "A*,Q*,R*"
Endif

End

Subprog C_QTYSTUDES(VALEUR)
Variable Decimal VALEUR
# Issue 110327
Local    Decimal WQTY, WQTA
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER)
Local    Char    WSERF(GLONSER)   # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
Local    Char    WPCU(GLONUOM)
Local    Decimal WPCUSTUCOE
Local    Decimal LQTYF
# End issue 110327
If VALEUR=0 mkstat=2 Endif
# Issue 110327
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]SERNUMF)>0 WSERF=[M]SERNUMF Endif   # Issue 110327
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
If dim([M]STA)>0 WSTA=[M]STA Endif
If [F:ITM]SERMGTCOD<>4
  If VALEUR>[M]QTYSTUDES
   mkstat=2 : Call ERREUR(mess(446,196,1)) From GESECRAN
  Endif
Else
# Issue 110327 - 2016-10-13 by MAE : gestion de SERMGTCOD= 4
  If [F:ITM]SERMGTCOD = 4
    [M:ALP]TRSTYP     = 28
    [M:ALP]TRSCOD     = [M:SCS1]TRSCOD
    [M:ALP]STOFCY     = [M]STOFCY
    [M:ALP]ITMREF     = [F:ITM]ITMREF
    [M:ALP]BESDAT     = [M:SCS1]IPTDAT
    [M:ALP]DLVDAT     = [M:SCS1]IPTDAT
    [M:ALP]PECINTLOC  = 2
    [M:ALP]PECSCOLOC  = 1
    [M:ALP]PECPLFLOC  = 2
    [M:ALP]STA        = "*"
    # Détermination no série fin
    Call CTLSORSER("SCS",0,[M]SERNUM,VALEUR,WSERF,LQTYF) From STKSOR
    If LQTYF=0
      Raz VALEUR, [M]SERNUMF
    Else
      [M]SERNUMF=WSERF
    Endif
    WQTY = VALEUR
    Call RECSTO(1,[F:SRT]TRSCOD,[M]ORI,[M]STOFCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
    If WQTY=0
      Call ERREUR(mess(314,184,1)) From GESECRAN
      zonsui = "[M:XSC1]ITMREF"
      End
    Else
      If dim([M]LOT)   >0  [M]LOT = WLOT  : Affzo [M]LOT  Endif
      If dim([M]SLO)   >0  [M]SLO = WSLO  : Affzo [M]SLO   Endif
      If dim([M]LOC)   >0  [M]LOC = WLOC   : Affzo [M]LOC Endif
      If dim([M]PALNUM)>0  [M]PALNUM = WPAL : Affzo [M]PALNUM Endif
      If dim([M]STA)>0     [M]STA = WSTA : Affzo [M]STA Endif
    Endif
  Endif
Endif

End

Subprog C_STADES(VALEUR)
Variable Char    VALEUR()
# Si statut origine unique et statut destination <> statut origine
If [M]STA<>"" & VALEUR<>[M]STA
   # Si emplacement unique et changement de stock sans chgt d'emplacement,
   # on restreint les statuts autorisés par la règle par ceux de l'emplacement
   If [M]LOC<>"" & [F:SRT]CHGEMPCOD<>2
      If [F:STC]LOC<>[M]LOC
         Read [STC]STC0=[M]STOFCY;[M]LOC
      Endif
      Call STKCTRSTA(VALEUR,[F:STC]AUZSST,1,2,0,mkstat) From STKACT
   Endif
Endif
End

Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
Local Shortint W_K : Raz W_K
# Si emplacement et statut destination
If [M]LOCDES<>"" & VALEUR<>""
  If [M]LOCDES<>[F:STC]LOC
    Read [STC]STC0=[M]STOFCY;[M]LOCDES
    # Raz emplacement saisi s'il n'accepte pas ce statut
    Call STKCTRSTA(VALEUR,[F:STC]AUZSST,0,0,0,W_K) From STKACT
    If W_K <> 0
      Raz [M]LOCDES
      Raz [M]LOCTYPDES
      Affzo [M]LOCDES
    Endif
  Endif
Endif
End

Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
Local Char LSTA(GLONSTA), LOPT(3)
# Pas de contrôle unité et quantité si plusieurs lignes de stock
If[M:STCW]NBLIG>1 LOPT="QU" Endif
# Si statut non unique, pas de contrôle statut
If [M]STADES="" & [M]STA="" LOPT+="S" Endif
# Si changement de statut, contrôle sur statut destination
If [F:SRT]CHGSTACOD=2
   LSTA=[M]STADES
Else
   LSTA=[M]STA
Endif
# Emplacement destination obligatoire si pas de modification de statut
If (VALEUR="" | VALEUR=[M]LOC) & ([M]STADES="" | [M]STADES=[M]STA)
   mkstat=2 : End
Endif

#--- Issue 103217
#Call STKCTREMP([M]WLOCSEQ,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M]FCYDES,[M]ITMREF,
#&              [M]STU,[M]QTYSTUDES,LSTA,[M]LOCTYPDES,VALEUR,"",1,mkstat,GBIDD1,
#&              LOPT,GFILLOCENT,"") From STKLOC
If [M:XBIT]PCU="***"
   LOPT="QU"
   Call STKCTREMP([M]WLOCSEQ,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M]FCYDES,[M]ITMREF,
&              [M]STU,[M]QTYSTUDES,LSTA,[M]LOCTYPDES,VALEUR,"",1,mkstat,GBIDD1,
&              LOPT,GFILLOCENT,"") From STKLOC
Else
   Local Decimal WQTYPCUDES
   If [M]PCUSTUCOE=0 [M]PCUSTUCOE=1 Endif
   WQTYPCUDES= [M]QTYSTUDES/[M]PCUSTUCOE
   Call STKCTREMP([M]WLOCSEQ,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M]FCYDES,[M]ITMREF,
&              [M:XBIT]PCU,WQTYPCUDES,LSTA,[M]LOCTYPDES,VALEUR,"",1,mkstat,GBIDD1,
&              LOPT,GFILLOCENT,"") From STKLOC
Endif
#---

If mkstat=2 End Endif
[M]LOCTYPDES = [F:STC]LOCTYP
End

######################################################################################
# Issue 110327
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXBIT) 07/03/2017 14:01:05 (MAE)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
LAFF=1
Call LECFICSOR(VALEUR,[M:SCS1]STOFCY,28,[M:SCS1]TRSCOD,LAFF) From STKECR
If mkstat End Endif
If [F:ITM]SERMGTCOD>1 & !find([M]ORI,5,6)
  Call ERREUR(mess(89,182,1)) From GESECRAN
  mkstat = 2
Endif
End

Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
If [F:ITM]SERMGTCOD = 0
   Filter [STS] Where SERNUM = VALEUR and STOFCY = [M]STOFCY
   Read [STS]First
   If fstat
      Call ERREUR(mess(43,196,1)) From GESECRAN
      mkstat=2 : End
   Endif
   LAFF=1
   Call LECFICSOR([F:STS]ITMREF,[M:SCS1]STOFCY,28,[M:SCS1]TRSCOD,LAFF) From STKECR
   If mkstat End Endif
   Filter [STS]
Endif
End
######################################################################################
# End issue 110327

