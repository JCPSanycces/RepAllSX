$ALIM_AQ04BN_1
#Valores no início do período N-1 (campo A5201)
Filter [F:BAL] Where CUR="EUR" & CPY=[L]CPY & FCY="" & (left$(ACC,1)="5" | left$(ACC,1)="8") & BPR="" & FIY=[F:FIY]FIYNUM-1 &
& [F:BAL]LEDTYP=val(PLEDTYP)
For [F:BAL]
    If left$([F:BAL]ACC,2)="51"
      A04BA5201(1) = num$(val(A04BA5201(1)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="52"
      A04BA5201(2) = num$(val(A04BA5201(2)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="53"
      A04BA5201(3) = num$(val(A04BA5201(3)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="54"
      A04BA5201(4) = num$(val(A04BA5201(4)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,3)="551"
      A04BA5201(5) = num$(val(A04BA5201(5)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,3)="552"
      A04BA5201(6) = num$(val(A04BA5201(6)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="56"
      A04BA5201(7) = num$(val(A04BA5201(7)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="57"
      A04BA5201(8) = num$(val(A04BA5201(8)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="58"
      A04BA5201(9) = num$(val(A04BA5201(9)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="59"
      A04BA5201(10) = num$(val(A04BA5201(10)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,3)="818"
      A04BA5201(11) = num$(val(A04BA5201(11)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
Next
Filter [F:BAL]

