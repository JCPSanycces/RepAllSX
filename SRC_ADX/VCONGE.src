#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VCONGE","VCONGE","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SUI"         : Gosub SUIVANT
 When "PRE"         : Gosub PRECEDENT
 When Default
Endcase
Return

$DEBUT
Gosub DECLARE
Raz [M]
[M]DATDEB = gdat$(1,month(datesyst),year(datesyst))
[M]DATFIN = eomonth(datesyst)
[M]FCY    = GFCYDEF
[M]SRV    = GSRVDEF
Affzo 1-19
#58530
If func AFNC.ACTIV("PLSRV")>0
 Gosub REMPLIT
Endif
Return

$DECLARE

# Tableau des effectifs

Local Char TEAM(1)(2) : # pour GETTEAM From SUBPOP

Local Integer MAXEMP
MAXEMP = 1000
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    REFNUM(GLONEML)(1..MAXEMP)
Local Char    CONTRAT(GLONHRCTR)(1..MAXEMP)
#Local Char    REFNUM(GLONMAT)(1..MAXEMP)
#Local Char    CONTRAT(GLONCTR)(1..MAXEMP)
#MIPEA - 2017-06-07- US X3-43919- END
Local Char    NOMSAL(40)(1..MAXEMP)
Local Char    PRENOM(40)(1..MAXEMP)
Local Char    PLANNING(GLONPLN)(1..MAXEMP)

# Tableau du planning

Local Integer MAXJOUR
MAXJOUR = 400
Local Date    JOUR(1..MAXJOUR)
Local Char    WTY(GLONSTY)(1..MAXJOUR)
Local Integer TYPJOUR(1..MAXJOUR)
Local Decimal NBJOUR(1..MAXJOUR)
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    CTRNUM(GLONHRCTR)(1..MAXJOUR)
#Local Char    CTRNUM(GLONCTR)(1..MAXJOUR)
#MIPEA - 2017-06-07- US X3-43919- END
Local Char    PL1DEB(5)(1..MAXJOUR)
Local Char    PL2DEB(5)(1..MAXJOUR)
Local Char    PL3DEB(5)(1..MAXJOUR)
Local Char    PL1FIN(5)(1..MAXJOUR)
Local Char    PL2FIN(5)(1..MAXJOUR)
Local Char    PL3FIN(5)(1..MAXJOUR)

# Tableau des congés

Local Integer MAXCNG
MAXCNG = 300
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    CTRCNG(GLONHRCTR)(1..MAXCNG)
#Local Char    CTRCNG(GLONCTR)(1..MAXCNG)
#MIPEA - 2017-06-07- US X3-43919- END
Local Date    DDEB(1..MAXCNG)
Local Integer MATDEB(1..MAXCNG)
Local Date    DFIN(1..MAXCNG)
Local Integer APMFIN(1..MAXCNG)
Local Char    TYPEVT(GLONTPS)(1..MAXCNG)
Local Integer STATUT(1..MAXCNG)
Local Decimal NBCNG(1..MAXCNG)
Local Char    TIMDES(1)(1..MAXCNG)

#61257 : temporaire pour qu'en C/S ça fonctionne...
Local Integer VUID(1..MAXCNG), VUPDNUM(1..MAXCNG), VTYPPGN(1..MAXCNG), VFLGANU(1..MAXCNG)
#MIPEA - 2017-06-07- US X3-43919- START
Local Char    VRPL(GLONEML)(1..MAXCNG), VRPLNAM(50)(1..MAXCNG)
#Local Char    VRPL(GLONMAT)(1..MAXCNG), VRPLNAM(50)(1..MAXCNG)
#MIPEA - 2017-06-07- US X3-43919- END
Local Integer VDEM(1..MAXCNG)


# Variables diverses

Local Integer NBMAT , NBLIG , NBJOU
Local Integer I , J , K
Local Integer P , X , IND , NOL , ERR , DELTA
Local Integer TYPTRAV(1..MAXJOUR,1..2)
Local Integer NBPLAG(1..MAXJOUR)
Local Char    SITCUR(GLONFCY)
Local Date    FERIE(1..50)

# Tables

If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If clalev([F:WTY])=0 : Local File TYPWEEK  [WTY] : Endif
If clalev([F:PLN])=0 : Local File PLANTYP  [PLN] : Endif
If clalev([F:DCG])=0 : Local File DEMCONGE [DCG] : Endif
If clalev([F:HLY])=0 : Local File HLYDAY   [HLY] : Endif
If clalev([F:TIM])=0 : Local File TIMCOD   [TIM] : Endif
#MIPEA - 2017-06-07- US X3-43919- START
If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
#If clalev([F:POA])=0 : Local File POPULA   [POA] : Endif
#MIPEA - 2017-06-07- US X3-43919- END
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

# CP/RTT

Local Integer NBCP , NBRTT, NBAUT
Local Char    TBCP(GLONTPS)(1..50) , TBRTT(GLONTPS)(1..50) , TBAUT(GLONTPS)(1..50)
#57881
#For [TIM] Where CATTIM=3
# If [F:TIM]VLTEVT=1
#  NBRTT += 1 : TBRTT(NBRTT) = [F:TIM]COD
# Else
#  NBCP  += 1 : TBCP(NBCP)   = [F:TIM]COD
# Endif
#Next
For [TIM] Where PLNGRP>0 & PLNGRP<len(mess(0,10418,1))
 Case [F:TIM]PLNGRP
  When 1 : NBCP  += 1 : TBCP(NBCP)   = [F:TIM]COD
  When 2 : NBRTT += 1 : TBRTT(NBRTT) = [F:TIM]COD
  When 3 : NBAUT += 1 : TBAUT(NBAUT) = [F:TIM]COD
 Endcase
Next

Return

$APRES_MODIF
If find(COUZON,"CPY","FCY","SRV","POP","DATDEB","DATFIN")
 Assign "[M]"+COUZON With zc
 If [M]DATFIN>=[M]DATDEB & [M]DATFIN-[M]DATDEB<=MAXJOUR-1
  Gosub REMPLIT
 Else
  Effzo 20
 Endif
Endif
Return

$SUIVANT
DELTA = 1
Goto SUIVPREC

$PRECEDENT
DELTA = -1
Goto SUIVPREC

$SUIVPREC
[M]DATDEB = addmonth([M]DATDEB,DELTA)
If eomonth([M]DATFIN)=[M]DATFIN
 [M]DATFIN = eomonth(addmonth([M]DATFIN,DELTA))
Else
 [M]DATFIN = addmonth([M]DATFIN,DELTA)
Endif
Affzo DATDEB,DATFIN
Gosub REMPLIT
Return

$ERREUR
#Infbox num$(errn)-errmes$(errn)
ERR = 1
Resume

# TYPTRAV (menu 423)
# 0 = Jours non travaillés (WE ou jours sans travail)
# 1 = Jours travaillés
# 2 = Jours fériés
# 3 = CP validés
# 4 = RTT validés
# 5 = Autres absences validées
# 6 = Absences non validées

$REMPLIT
[M]MAXJOU = MAXJOUR
NBJOU  = [M]DATFIN-[M]DATDEB+1

Effzo [M]20

# Recherche des personnes à afficher

Raz REFNUM,CONTRAT,NOMSAL,PRENOM,PLANNING
Onerrgo ERREUR
ERR = 0
If dim([L]GROUPE)>1
 Call GETTEAM([M]CPY,[M]FCY,[M]SRV,[M]POP,[L]GROUPE,[M]DATDEB,[M]DATFIN,REFNUM,CONTRAT,NOMSAL,PRENOM,PLANNING,"","") From PORMAT
Else : # pour PLNSRV From PORTPS
 Call GETTEAM([M]CPY,[M]FCY,[M]SRV,[M]POP,[L]TEAM,[M]DATDEB,[M]DATFIN,REFNUM,CONTRAT,NOMSAL,PRENOM,PLANNING,"","") From PORMAT
Endif
Onerrgo
If ERR
# FQ66624 - SEGAY 09/09/10
# Call MESSAGE(mess(183,709,1)-"("+num$(MAXEMP)+")") From GESECRAN : # Trop de salariés sélectionnés
 If dim([V]GPLANNING) < 0
   Call MESSAGE(mess(178,139,1)-"(GPLANNING)") From GESECRAN : # Variable Globale inexistante
 Else
  #MIPEA - 2017-06-07- US X3-43919- START
     Call MESSAGE(mess(183,10709,1)-"("+num$(MAXEMP)+")") From GESECRAN : # Trop de salariés sélectionnés
#   Call MESSAGE(mess(183,709,1)-"("+num$(MAXEMP)+")") From GESECRAN : # Trop de salariés sélectionnés
#MIPEA - 2017-06-07- US X3-43919- END
 Endif
 Return
Endif

For I=1 To MAXEMP
 If REFNUM(I)="" : NBMAT = I-1 : Break : Endif
Next I

# Boucle sur les salariés

SITCUR = ""
NOL = 0
For I=1 To NBMAT
 # Planning
 Raz JOUR,TYPJOUR,NBJOUR,PL1DEB,PL1FIN,PL2DEB,PL2FIN,PL3DEB,PL3FIN
 Call GETSEMTYP("",REFNUM(I),CONTRAT(I),[M]DATDEB,[M]DATFIN,CTRNUM,JOUR,WTY,TYPJOUR,NBJOUR
&              ,PL1DEB,PL1FIN,PL2DEB,PL2FIN,PL3DEB,PL3FIN) From PORTPS

 Raz TYPTRAV, NBPLAG
 For K=1 To MAXJOUR
  If JOUR(K)=[0/0/0] : Break : Endif
  IND = JOUR(K)-[M]DATDEB+1
  If IND>=1
   If PL1DEB(K)<>"" & PL2DEB(K)<>""
    If PL3DEB(K)="" & NBJOUR(K)>0.5         : # Exactement 2 plages
     NBPLAG(IND)    = 2
     TYPTRAV(IND,1) = 1
     TYPTRAV(IND,2) = 1
    Else                                    : # Journée entière
     NBPLAG(IND)    = 1
     TYPTRAV(IND,1) = 1
    Endif
   Elsif PL1DEB(K)="" & PL2DEB(K)<>""       : # 1/2 journée l'après-midi
    NBPLAG(IND)    = 2
    TYPTRAV(IND,2) = 1
   Elsif PL1DEB(K)<>"" & PL2DEB(K)=""
    If NBJOUR(K)>0.5                        : # Journée entière
     NBPLAG(IND)    = 1
     TYPTRAV(IND,1) = 1
    Else                                    : # 1/2 journée le matin
     NBPLAG(IND)    = 2
     TYPTRAV(IND,1) = 1
    Endif
   Else                                     : # Pas de travail
    NBPLAG(IND)  = 2
   Endif
  Endif
 Next K

 # Demandes de congés

 Raz CTRCNG,DDEB,DFIN,MATDEB,APMFIN,TYPEVT,STATUT,NBCNG
 Call GETDEMCNG(REFNUM(I),CONTRAT(I),[M]DATDEB,[M]DATFIN,"2,3,5,7",CTRCNG
&              ,DDEB,MATDEB,DFIN,APMFIN,TYPEVT,TIMDES,STATUT,NBCNG
&              ,VUID,VUPDNUM,VTYPPGN,VFLGANU,VRPL,VRPLNAM,VDEM) From PORDCG        :#61257 : temporaire pour qu'en C/S ça fonctionne...

#
# Status
# 1=Brouillon          => non visualisé
# 2=En attente         => non validé
# 3=Accepté            => validé
# 4=Refusé             => non visualisé
# 5=Demande annulation => non validé
# 6=Annulation accepté => non visualisé
# 7=Annulation refusée => validé
#
 For J=1 To MAXCNG
  If DDEB(J)=[0/0/0] : Break : Endif
  #57881
  #If find(STATUT(J),2,6)
  If find(STATUT(J),2,5)
   X = 6 : # Absence non validée
  Elsif find(TYPEVT(J),TBCP(1..NBCP),"CP") : # FQ66623 - MABON 06/09/10
   X = 3 : # CP
  Elsif find(TYPEVT(J),TBRTT(1..NBRTT))
   X = 4 : # RTT
  #57881
  #Else
  Elsif find(TYPEVT(J),TBAUT(1..NBAUT))
   X = 5 : # Autres absences validées
  Endif
  For K=1 To DFIN(J)-DDEB(J)+1
   IND = DDEB(J)-[M]DATDEB+K
    # FQ66346 - SEGAY 10/09/10   If IND>=1
#   If IND>=1
#    If K=1 & MATDEB(J)=2 & NBPLAG(IND)=2
#     TYPTRAV(IND,2) = X
#    Elsif K=DFIN(J)-DDEB(J)+1 & APMFIN(J)=2 & NBPLAG(IND)=2
#     TYPTRAV(IND,1) = X
#    Else
#     TYPTRAV(IND,1) = X
#     If NBPLAG(IND)=2
#      TYPTRAV(IND,2) = X
#     Endif
#    Endif
#   Endif

    # FQ66346 - SEGAY 10/09/10
   If IND>=1
    # Si Absence non validée et Jour non travaillé  X = 6 & TYPTRAV(IND,x)=0 NBCNG(J)=0
    # On laisse en jour non travaillé TYPTRAV(IND,x)=0
    If K=1 & MATDEB(J)=2 & NBPLAG(IND)=2
     If X <> 6 or TYPTRAV(IND,2)<>0 or NBCNG(J)<>0
      TYPTRAV(IND,2) = X
     Endif
    Elsif K=DFIN(J)-DDEB(J)+1 & APMFIN(J)=2 & NBPLAG(IND)=2
     If X <> 6 or TYPTRAV(IND,1)<>0 or NBCNG(J)<>0
      TYPTRAV(IND,1) = X
     Endif
    Else
     If X <> 6 or TYPTRAV(IND,1)<>0 or NBCNG(J)<>0
      TYPTRAV(IND,1) = X
     Endif
     If NBPLAG(IND)=2
      If X <> 6 or TYPTRAV(IND,2)<>0 or NBCNG(J)<>0
       TYPTRAV(IND,2) = X
      Endif
     Endif
    Endif
   Endif

  Next K
 Next J

 # Jours fériés
#MIPEA - 2017-06-07- US X3-43919- START
 Read [HRCTR]CTR0(2) = REFNUM(I);CONTRAT(I)
 If [F:HRCTR]ETRFCY<>SITCUR
  SITCUR = [F:HRCTR]ETRFCY
# Read [CTR]CTR0(2) = REFNUM(I);CONTRAT(I)
# If [F:CTR]ETRFCY<>SITCUR
#  SITCUR = [F:CTR]ETRFCY
#MIPEA - 2017-06-07- US X3-43919- END
  Raz FERIE
  Call GETJOURFERIE(SITCUR,[M]DATDEB,[M]DATFIN,FERIE) From PORTPS
 Endif
 For J=1 To MAXJOUR
  If FERIE(J)=[0/0/0] : Break : Endif
  IND = FERIE(J)-[M]DATDEB+1
  TYPTRAV(IND,1) = 2
  If NBPLAG(IND)=2
   TYPTRAV(IND,2) = 2
  Endif
 Next J

 # Déversement dans le tableau d'affichage

 [M]MATRI(NOL) = REFNUM(I)
 [M]NOM(NOL)   = NOMSAL(I)-PRENOM(I)-CONTRAT(I)
 NOL += 1
 For J=1 To NBJOU
  If NBPLAG(J)=2
   Gosub MATIN
   Gosub APRES_MIDI
  Else
   Gosub JOURNEE
  Endif
  If NOL>=dim([M]MATRI)-2
   Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
   Break 2
  Endif
 Next J
Next I

#58530
If NOL :[M]NBLIG = NOL : Endif
Affzo 20
Return

$MATIN
If J>1 & REFNUM(I)=[M]MATRI(NOL-1) & TYPTRAV(J,1)=[M]TYPJOU(NOL-1)
 [M]DUREE(NOL-1)  += 0.5
 [M]DURAFF(NOL-1) += 0.5
Else
 [M]MATRI(NOL)  = REFNUM(I)
 [M]NOM(NOL)    = ""
 [M]DAT(NOL)    = [M]DATDEB+J-1
 [M]DATI(NOL)   = format$("D:YYYYMMDD",[M]DAT(NOL))+"0000"
 [M]DURAFF(NOL) = 0.5    : # Largeur de la barre
 [M]DUREE(NOL)  = 0.5    : # Durée en nb de jours ouvrés
 [M]TYPJOU(NOL) = TYPTRAV(J,1)
 NOL += 1
Endif
Return

$APRES_MIDI
If REFNUM(I)=[M]MATRI(NOL-1) & TYPTRAV(J,2)=[M]TYPJOU(NOL-1)
 [M]DUREE(NOL-1)  += 0.5
 [M]DURAFF(NOL-1) += 0.5
Else
 [M]MATRI(NOL)  = REFNUM(I)
 [M]NOM(NOL)    = ""
 [M]DAT(NOL)    = [M]DATDEB+J-1
 [M]DATI(NOL)   = format$("D:YYYYMMDD",[M]DAT(NOL))+"1200"
 [M]DURAFF(NOL) = 0.5    : # Largeur de la barre
 [M]DUREE(NOL)  = 0.5    : # Durée en nb de jours ouvrés
 [M]TYPJOU(NOL) = TYPTRAV(J,2)
 NOL += 1
Endif
Return

$JOURNEE
If J>1 & REFNUM(I)=[M]MATRI(NOL-1) & TYPTRAV(J,1)=[M]TYPJOU(NOL-1)
 [M]DUREE(NOL-1)  += 1
 [M]DURAFF(NOL-1) += 1
Else
 [M]MATRI(NOL)  = REFNUM(I)
 [M]NOM(NOL)    = ""
 [M]DAT(NOL)    = [M]DATDEB+J-1
 [M]DATI(NOL)   = format$("D:YYYYMMDD",[M]DAT(NOL))+"0000"
 [M]DURAFF(NOL) = 1    : # Largeur de la barre
 [M]DUREE(NOL)  = 1    : # Durée en nb de jours ouvrés
 [M]TYPJOU(NOL) = TYPTRAV(J,1)
 NOL += 1
Endif
Return

######################################################################################
## Ecran VCONGE
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]FCY  = ""
 [M]ZFCY = ""
 [M]POP  = ""
 [M]ZPOP = ""
 Affzo FCY,ZFCY,POP,ZPOP
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CPY  = ""
 [M]ZCPY = ""
 [M]POP  = ""
 [M]ZPOP = ""
 Affzo CPY,ZCPY,POP,ZPOP
Endif
End

Subprog C_SRV(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]POP  = ""
 [M]ZPOP = ""
 Affzo POP,ZPOP
Endif
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]FCY  = ""
 [M]ZFCY = ""
 [M]CPY  = ""
 [M]ZCPY = ""
 [M]SRV  = ""
 [M]ZSRV = ""
 Affzo FCY,ZFCY,CPY,ZCPY,SRV,ZSRV
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DATDEB
 GMESSAGE = mess(1,104,1) : # Date incorrecte
 mkstat   = 2
Elsif VALEUR>[M]DATDEB+[M]MAXJOU-1
#MIPEA - 2017-06-07- US X3-43919- START
 GMESSAGE = mess(182,10709,1)-"("+num$([M]MAXJOU)+")" : # Nombre de jours trop important
# GMESSAGE = mess(182,709,1)-"("+num$([M]MAXJOU)+")" : # Nombre de jours trop important
 #MIPEA - 2017-06-07- US X3-43919- END
 mkstat   = 2
Endif
End

Subprog B1_NBLIG
Call OBJET("DCG",[M]MATRI(nolign-1),"") From GOBJET
End

