#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# IMPOPPCRM
# Issue X3-67352 - 2017-12-11 by FGR
###################################################################################################
$ACTION
  Case ACTION
    When "EXPORT"         : Gosub EXPORT
    #
    When "IMPORT"         : Gosub IMPORT
    When "IMP_RAZCRE"     : Gosub IMP_RAZCRE
    When "AP_IMPORT"      : Gosub AP_IMPORT
    When "IMP_ZONE"       : Gosub IMP_ZONE
    When "IMP_VERIF_CRE"  : Gosub IMP_VERIF_CRE
    When "IMP_VERIF_MOD"  : Gosub IMP_VERIF_MOD
  Endcase
Return

###################################################################################################
# EXPORT
###################################################################################################
$EXPORT
  Read [PIM]PIM0=[F:OPP]OPPNUM
  If [F:PIM]PIMTYP <> 1 and [F:PIM]PIMTYP <> 3 Then
    OK = 0           # To export only CRM projects and mixt projects
  Endif
Return

###################################################################################################
# IMPORT
###################################################################################################
$IMPORT
Local Integer IINDEX

  If GREP = "M" Then
    # In update case, need to find if the line is existing, and where ?
    Case IMPFIC
      When "OCP"
        # Project competitor
        IINDEX = fmet GZINSOPP.CPP_GET_INDEX([F:OCP]CPP)
        If IINDEX > 0 Then
          nolign = find(IINDEX, [M:OPP2]COLLIN(0..[M:OPP2]NBOPP2-1))
        Endif
      When "OSB"
        # Project pre-sales steps
        IINDEX = fmet GZINSOPP.CRM(1).STPSTB_GET_INDEX([F:OSB]ENDDAT, [F:OSB]STE)
        If IINDEX > 0 Then
          nolign = find(IINDEX, [M:OPP3]COLLIN(0..[M:OPP3]NBOPP3-1))
        Endif
      When "OSA"
        # Project after-sales steps
        IINDEX = fmet GZINSOPP.CRM(1).STPSTA_GET_INDEX([F:OSA]ENDDATX, [F:OSA]STEX)
        If IINDEX > 0 Then
          nolign = find(IINDEX, [M:OPP4]COLLIN(0..[M:OPP4]NBOPP4-1))
        Endif
      When "OBB"
        # Sub-project
        IINDEX = fmet GZINSOPP.SBB_GET_INDEX([F:OBB]SBBPJT)
        If IINDEX > 0 Then
          nolign = find(IINDEX, [M:OPP5]COLLIN(0..[M:OPP5]NBOPP5-1))
        Endif
    Endcase
  Endif
Return

###################################################################################################
$IMP_RAZCRE
Local Integer NI
Local Integer IRET

  GZINSOPP.TCHIMPORT = [V]CST_AYES
  # ------------------------------------------------------------------------
  # Pre-sales and After-sales are imported. Delete the automatically created
  Call TST_CHAMP("OSB", "STE", IRET) From SUBIMPOBJ
  If IRET Then
    # If pre-sales are in the model, they are imported. nothing automatically created
    For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTB)
      If GZINSOPP.CRM(1).STPSTB(NI) <> null and find(GZINSOPP.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        IRET = fmet GZINSOPP.CRM(1).ADELLINE("STPSTB", GZINSOPP.CRM(1).STPSTB(NI).AORDER)
      Endif
    Next NI
  Endif
  #
  Call TST_CHAMP("OSA", "STEX", IRET) From SUBIMPOBJ
  If IRET Then
    # If after-sales are in the model, they are imported. nothing automatically created
    For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTA)
      If GZINSOPP.CRM(1).STPSTA(NI) <> null and find(GZINSOPP.CRM(1).STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        IRET = fmet GZINSOPP.CRM(1).ADELLINE("STPSTA", GZINSOPP.CRM(1).STPSTA(NI).AORDER)
      Endif
    Next NI
  Endif
  # ------------------------------------------------------------------------
Return

###################################################################################################
$IMP_ZONE
  Case IMPFIC
    When "OPP"
      Case IMPZON
        When "OPPDESAXX"
          [M:OPP0]OPPDESAXX = "Temporary"
      Endcase
    When "PIM"
      Case IMPZON
        When "OPPDESAXX"
          If dim(SOPPDESAXX) >= 0 Then
            [M:OPP0]OPPDESAXX = SOPPDESAXX
            Kill SOPPDESAXX
          Endif
      Endcase
  Endcase
Return

###################################################################################################
$AP_IMPORT
  Case IMPFIC
    When "PIM"
      Global Char SOPPDESAXX(type([M:OPP0]OPPDESAXX)-10)

      SOPPDESAXX = [F:AXX]TEXTE
  Endcase
Return

###################################################################################################
$IMP_VERIF_CRE
Local Integer MY_STATUS

  [L]MY_STATUS = fmet GZINSOPP.AINSERT()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1180,196,1)
    Endif
    Return
  Endif
  If GTRACE <> AVOID.ACHAR Then
    Call ECR_TRACE(func AFNC.MES1(mess(1201,196,1), GZINSOPP.OPPNUM), 0) From GESECRAN
  Endif
Return

###################################################################################################
$IMP_VERIF_MOD
Local Integer MY_STATUS

  [L]MY_STATUS = fmet GZINSOPP.AUPDATE()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1181,196,1)
    Endif
    Return
  Endif
  If GTRACE <> AVOID.ACHAR Then
    Call ECR_TRACE(func AFNC.MES1(mess(1202,196,1), GZINSOPP.OPPNUM), 0) From GESECRAN
  Endif
Return

