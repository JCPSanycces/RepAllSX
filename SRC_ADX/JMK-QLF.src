#<AdxTJ>@(#)4.0.0.0 $Revision$
Call OUVRE_TRACE("QLF") From LECFIC
Call EXEC_QLF 
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End 

Subprog EXEC_QLF 
Local Integer I,J
#Local Integer NBLU : NBLU = 7000 
#Local Char WDES(120)(0..NBLU), WFIC(10)(0..NBLU), WCOM(20)(0..NBLU), WTRI(20)(0..NBLU) 
Local Clbfile RESULT

Local File (FICHE(30)) From System 'lsadx -a '+nomap+' TRT adx' As [FTR] Where left$([F:FTR]FICHE,3) = "QLF"
#& , (Char FIC(10), Char DES(120), Char COM(20), Char TRI(20)) 
#& From Variable WFIC, WDES ,WCOM, WTRI As [FT2] 


# Appel des QLF
For [FTR] Where FICHE ="QLFRTM_DATETIME" 
 I+=1 

RESULT = func =[FTR]FICHE + ".TESTSUITE" With ()
Infbox num$(GXUNIT_CASE_SUCCESS)
Infbox num$(GXUNIT_CASE_FAILURE)
Infbox GXUNIT_SUITE_DESCRIPTION
Infbox RESULT

Next 
End 
