#<AdxTL>@(#)3.0.0.0 $Revision$
#* X3-105432 (SMO) GESBUC - Budget calculation import - Translation text issue

$ACTION
Case ACTION
 When "IMPORT"    : Gosub IMPORT
Endcase
Return

$IMPORT
# Seul le masqqe BUC1 est déclaré sous l'objet BUC, par conséquent, le masque BUC0 doit être alimenté sous le traitement d'import.
[M:BUC0] = [F:BUC]

# Spécificité des textes traduisibles.
OGLANGUE = GLANGUE
GLANGUE = "imp"
Call LECTEXTRA([M:BUC0]DESTRA,"BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call LECTEXTRA([M:BUC0]SHOTRA,"BUDFORCAL","SHOTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
#start X3-105432
If instr(1,[M:BUC0]DESTRA,"~~")
  [M:BUC0]DESTRA = left$([M:BUC0]DESTRA, instr(1,[M:BUC0]DESTRA,"~~")-1)
Endif
If instr(1,[M:BUC0]SHOTRA,"~~")
  [M:BUC0]SHOTRA = left$([M:BUC0]SHOTRA, instr(1,[M:BUC0]SHOTRA,"~~")-1)
Endif
#end X3-105432
Call SUPTEXLAN("BUDFORCAL","DESTRA",GLANGUE,[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call SUPTEXLAN("BUDFORCAL","SHOTRA",GLANGUE,[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
GLANGUE = OGLANGUE

If [F:BUC]LIN<1 : Return : Endif
I = find([F:BUC]LIN,[M:BUC1]LIN(0..[M:BUC1]NBLIG-1))
If I
 nolign = I
Else
 [M:BUC1]NBLIG += 1
 nolign = [M:BUC1]NBLIG
Endif
For I=1 To dim([F:BUP]DIE)
 Assign "[M:BUC1]CCE"+num$(I)+"(nolign-1)" With [F:BUC]CCE(I-1)
Next
Return

