######################################################################################################
# Project       : Swiss Localization
# File          : SWIIMPBVR
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 26.03.15
######################################################################################################
# Module        : ACCOUNTING
# Description   : - Import ISR in temp table
######################################################################################################
 # Updates :
 # Date    |Author|Version|Description
######################################################################################################

######################################################################################################
#                        ACTION standard                                                             #
######################################################################################################
$ACTION
Case ACTION
     When "INIT"          : Gosub INIT_
     When "CONTROLE"      : Gosub CONTROLE_
     When "EXEC"          : Gosub EXEC_
     When "TERMINE"       : Gosub TERMINE_
     When "SORTIE"        : Gosub SORTIE_
Endcase
Return

#
#*****************************************************************************************************
#INIT_: Action ce déroulant lors de l'appel du début de traitement.                                  *
#                                                                                                    *
#Description: Il sert a définir les variables et à ouvrir les tables néces-                          *
#*****************************************************************************************************
$INIT_
Local Integer STAT_ : STAT_=0
  #***Variables pour le chemin du fichier***#
  Global Char REP_(255)

  #***Ouverture des tables
  If !clalev([DUD2])   : Local File GACCDUDATE [DUD2] : Endif
  If !clalev([FCY2])   : Local File FACILITY   [FCY2] : Endif
  If !clalev([CPY2])   : Local File COMPANY    [CPY2] : Endif
  If !clalev([BAN2])   : Local File BANK       [BAN2] : Endif
  If !clalev([SWIIMP]) : Local File SWIIMPBVR  [SWIIMP] : Endif
  #test de lock du symbole "GESXTI"
  Local Char SYMBOLE2(20), USER(20), MACHINE(50)
  SYMBOLE2="GESSWIBVR"
  Lock =SYMBOLE2 With lockwait = 0

  # mise en comme. pour tests
  If fstat
    Call QUILOCKE(SYMBOLE2,MACHINE,USER) From OBJDIV
    End
  Endif

Return
#*******************************************************************************

#*******************************************************************************
#CONTROLE_: Action ce déroulant après la saisie de la boîte de dialogue        *
#                                                                              *
#Description: On vérifie que le site et la banque rensigné soit OK             *
#*******************************************************************************
$CONTROLE_
  #***On recherche la devise société ([M:DIA]CUR)
  Read [FCY2]FCY0 = [M:DIA]FCY
  If fstat = 0
     Read [CPY2]CPY0 = [F:FCY2]LEGCPY
     If fstat = 0
        [M:DIA]CUR = [F:CPY2]ACCCUR
     Else
        GERR=1 : GMESSAGE=mess(4,3648,1)
        [M:DIA]CUR = ""
        SAI = 1  :#On revient à l'écran de saisie
     Endif
  Else
     GERR=1 : GMESSAGE=mess(4,3648,1)
     [M:DIA]CUR = ""
     SAI = 1 : #On revient à l'écran de saisie
  Endif
Return
#*******************************************************************************

#*******************************************************************************
#EXEC_: Action ce déroulant après avoir cliqué sur le bouton OK                *
#                                                                              *
#Description: Lit le fichier reçu de la banque et le charge dans la table tem- *
#             poraire.                                                         *
#*******************************************************************************
$EXEC_
    Call EXECIMP_() From SWIBVRLIB1
Return
#*******************************************************************************

#*******************************************************************************
#New ETIQUETTE            *
#*******************************************************************************
$TERMINE_
Return
#*******************************************************************************

#*******************************************************************************
#SORTIE_                  *
#*******************************************************************************
$SORTIE_
Unlock =SYMBOLE2
Return
#*******************************************************************************

