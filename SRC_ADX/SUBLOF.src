#*!
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("LOF",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION

  Case ACTION
    When "SETTRANS"         : Local Integer LLOFTRS : Gosub SET_TRS_PARM From SUBTSH
    When "OUVRE"            : Gosub OUVRE
    When "OUVRE_BOITE"      : Gosub OUVRE_BOITE
    When "LIENS"            : Gosub LIENS
    When "STYLE"            : Gosub STYLE
    When "VERROU"           : Gosub VERROU
    When "DEVERROU"         : Gosub DEVERROU
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "RAZCRE"           : Gosub RAZCRE
    When "RAZDUP"           : Gosub RAZDUP
    When "INICRE"           : Gosub INICRE
    When "INIMOD"           : Gosub INIMOD
    When "VERF_ANU"         : Gosub VERF_ANU
    When "AV_ANNULE"        : Gosub AV_ANNULE
    When "ANNULE"           : Gosub ANNULE
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "AVANT_MODFIC"     : Gosub AVANT_MODFIC
    When "APRES_CRE"        : Gosub APRES_CRE
    When "APRES_MOD"        : Gosub APRES_MOD
    When "AB_MODIF"         : Gosub AB_MODIF
    When "APRES_CHOI"       : Gosub APRES_CHOI
    When "SETBOUT"          : Gosub SETBOUT
    When "AVANTBOUT"        : Gosub AVANTBOUT
    When "EXEBOUT"          : Gosub EXEBOUT
    When "FIN_ACTION"       : Gosub FIN_ACTION
    When "FILGAUCHE"        : Gosub FILGAUCHE
    When "TIROIR"           : Gosub TIROIR
    When "GAUCHE"           : Gosub GAUCHE
    When "FERME"            : Gosub FERME
    When "FIN"              : Gosub FIN
    When Default
  Endcase
Return

################################################################################
#-------------------------------------------------------------------------------
$OUVRE

  Global Integer    G_DEFORCE_LOF     :  # Indicateur zone déforcée (1 ou 0)
  Global Decimal    G_DEDVAT, G_CRBVAT, G_INIDEDAMT
  Global Date       G_FINPERCPF, G_FINPERIAS
  Global Integer    G_LOFSPL : G_LOFSPL= G_NON   #*Fq-85231
  Local  Decimal    DEDVATSAV
  Local  Char       ACTSAV (GLONADI)
  Local  Integer    LCNXIAS        : LCNXIAS = 0
  Global Integer    G_NBAXE           : #Fq-79815 Nb d'axes à saisir (max 20)
  Global Integer    G_LOFDELAUT       : #FQ97977 User authorization to cancel expense
  #-------------------------------------------------------------------#
  # Si on vient par tunnel il faut sauvegarder les variables globales #
  #-------------------------------------------------------------------#
  If (TUNNEL)   : Gosub SAUVE_GLOBAL_SV From GLOBIMM     : Endif
  If (TUNNEL)   : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif
  #-------------------------
  # Appel à la fonction de gestion des zones libres
  Gosub OUVRE From SUBFRZ
  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY
  #-------------------------
  # Numérotation automatique
  Local Integer AUTONUM_PAR, STAT, Z
  Local Char    L_COMPTEUR(5), MESSA(80)
  Local Char    L_PARAM(10)
  Local Char    L_CODLOF
  Local Integer L_LINLOF
  #-------------------------
  # VARIABLES DE L'ECRAN
  Global Integer GMODE_PLUS1
  #-------------------------
  If clalev([F:LOF]) =0    : Local File LAYOUTFAS           [LOF]  : Endif  : # Dépenses
  If clalev([F:LOFB])=0    : Local File LAYOUTFAS           [LOFB] : Endif  : # Dépenses
  If clalev([F:CNX]) =0    : Local File CONTEXT             [CNX]  : Endif  : # Contextes
  If clalev([F:SEA]) =0    : Local File SECACT              [SEA]  : Endif  : # secteurs d'activité
  If clalev([F:BPR]) =0    : Local File =GTABCPT+"BPARTNER" [BPR]  : Endif  : # Fournisseurs
  If clalev([F:TCA]) =0    : Local File TABCOUAFF           [TCA]  : Endif  : # Table des compteurs de documents
  If clalev([F:ADW]) =0    : Local File ADOVAL              [ADW]  : Endif  : # Valeur des paramètres
  If clalev([F:ADI]) =0    : Local File ATABDIV             [ADI]  : Endif  : # table des tables diverses
  If clalev([F:ATX]) =0    : Local File ATEXTE              [ATX]  : Endif  : # table des textes
  If clalev([FAM])=0       : Local File FASFAM              [FAM]  : Endif

  #-------------------------
  If (CLE2 <> "")
    # On arrive par liaison depuis le bien comptable
    If ( instr( 0, CLE2, '@') <> 0 )
      L_CODLOF = left$(CLE2, instr( 0, CLE2, '@')-1)
      L_LINLOF = val(mid$(CLE2, instr( 0, CLE2, '@')+1, len(CLE2)))
      [M:LOF0]CODLOF = L_CODLOF
      [M:LOF0]LINLOF = L_LINLOF
      CLE2           = ""        : # Remise à vide, pour ne rien perturber
      Affzo [M:LOF0]CODLOF
      Affzo [M:LOF0]LINLOF
      CLE1 = num$([M:LOF0]LINLOF)
      CLE2 = [M:LOF0]CODLOF
    Endif
  Else
    L_CODLOF = ""
    L_LINLOF = 0
  Endif
  #-------------------------

#=> Liste des actions métiers

#> Suppression des globales si elles existaient déjà à cause d'un plantage par exemple.

 If dim(LIS_ACT)>0 : Kill LIS_ACT : Endif
 If dim(LIS_NAM)>0 : Kill LIS_NAM : Endif
 If dim(LIS_TYP)>0 : Kill LIS_TYP : Endif


Return

#-------------------------------------------------------------------------------
$OUVRE_BOITE : #GLE 27849
  #-------------------------
  # Tiroirs
  Local Char LTI_DEPLIEE : LTI_DEPLIEE = 'GAU_CHE'+num$(find('LO1',OBJLIS(1..10))) : # Dépenses liées
  Local Char LTI_DEPIMMO : LTI_DEPIMMO = 'GAU_CHE'+num$(find('LO3',OBJLIS(1..10))) : # Dépenses immobilisables

  # FQ92277 : redéfinition du link du tiroir LO3 pour ajouter le contrôle d'habilitation (voir WOLO3 $INIT_BOITE)
  If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
  Link [LOF] With
& [AFF]AFF0~=[F:LOF]FCY;GPROFIL;GUSRFCT,
& [L_OF]LOF1=[F:LOF]CPY;[F:LOF]CODLOF;[F:LOF]LINLOF;[F:LOF]FLGLIKAAS;[F:LOF]GACACN
& As [LO3]
Return

#-------------------------------------------------------------------------------
$VERROU
Local Char LLOCK(200)


  # Pour interdire toute modification sur l'objet
  LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF0]CODLOF, [M:LOF0]LINLOF)
  If func GLOBIENS.IS_SYMBOLE_LOCKED ("LOF", [M:LOF0]CPY, LLOCK) = 0
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    OK = 0
    Return
  Else
    # sinon on gère à la main le verrou identifiant+société pour permettre le contrôle
    # de tester si le lockage de la table pour la société est possible
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("LOF", [M:LOF0]CPY, LLOCK, 0) = 0
      # on teste rien, normalement ça marche puisqu'on a pu locker l'enregistrement
      # et que la société n'est pas lockée
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$DEVERROU
Local Char LLOCK(200)

  LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF0]CODLOF, [M:LOF0]LINLOF)
  Call UNLOCK_SYMBOLE_CPY ("LOF", [M:LOF0]CPY, LLOCK) From GLOBIENS
Return

#-------------------------------------------------------------------------------
$APRES_CRE

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]FCY", 0) = G_OUI   : Diszo [M:LOF0]FCY : Endif

  CLECUR2 = [F:LOF]CODLOF
  CLECUR1 = num$([F:LOF]LINLOF)
  Gosub RELIT From GOBJSUB

 #Local Integer ERROR
 #Call COMPTA_DIRECTE([M:LOF0]CPY, [M:LOF0]FCY, [M:LOF0]CODLOF, 0, "", ERROR) From TRTCPTINT

Return

#-------------------------------------------------------------------------------
$APRES_MODIF

  If ( GREP = "C" or GREP = "D" )
    If ( COUZON = "CPY" or COUZON = "FCY" )
      If func GLOBIENS.IS_SYMBOLE_LOCKED ("LOF", [M:LOF0]CPY, "¤¤¤") = 0
        # Test si la société est verrouillée sur cette table pour en empêcher la création
        # Obligé de mettre n'importe quoi dans l'identifiant parce que sinon ça demande si c'est
        # la société qui est lockable, et si quelqu'un est dessus ça refuse.
        OK       = 0
        GMESSAGE = G_MSGQUILOCK
        Return
      Endif
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$LIENS

  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:LOF]CPY,"",G_NON,ERR) From GLOFCYCPY

  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:LOF]","[M:FPC]","[M:LOF2]",LNBRCCE) From GLOBIENSANA
  [M:LOF2]NBRCCE=LNBRCCE

  G_NBAXE = LNBRCCE  #Fq-79815

  GMODE_PLUS1 = G_NON : # On n'est pas en mode +1
  DEDVATSAV   = [M:LOF1]AMTVATRCPY
  ACTSAV      = [M:LOF1]ACT
  G_INIDEDAMT = [M:LOF1]AMTVATRCPY

  If ([M:LOF1]ACT <> "")
    Read [F:SEA]SEA0=[M:LOF0]CPY;[M:LOF1]ACT
    [M:LOF1]SACDES = [F:SEA]SACDES
  Endif
  Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS

  Gosub MODIF_REDUITE

  # Affichage de l'icône permettant de consulter la dépense d'origine si origine X3
  If [M:LOF2]CPMCREORI <> 0 and GTABCPT = ""
    [M:LOF2]ICOINV = "21"
  Else
    [M:LOF2]ICOINV = ""
  Endif
  Affzo [M:LOF2]ICOINV

   #Fq67577-Pologne
   Gosub LIENS From SUBLOFKPL


Return

#-------------------------------------------------------------------------------
$STYLE
  Gosub MODIF_REDUITE
Return

#-------------------------------------------------------------------------------
$APRES_MOD
  #-------------------------------
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  #-------------------------------

  CLECUR2 = [F:LOF]CODLOF
  CLECUR1 = num$([F:LOF]LINLOF)
  Gosub RELIT From GOBJSUB

 #Local Integer ERROR
 #Call COMPTA_DIRECTE([M:LOF0]CPY, [M:LOF0]FCY, [M:LOF0]CODLOF, 0, "", ERROR) From TRTCPTINT

Return

#-------------------------------------------------------------------------------
$AB_MODIF
  #-------------------------------
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  #-------------------------------
Return

#-------------------------------------------------------------------------------
$VERIF_CRE

  # Contrôle cohérence société/site
  OK = func GLOFCYCPY.IS_CPYFCY_OK([M:LOF0]CPY,[M:LOF0]FCY)
  # Site financier et société incompatibles
  If !OK : Return : Endif

  # Contrôle de validité des axes analytiques
  Gosub CTRL_TAB_CCE From GLOBIENSANA
  #Fq-79815 ajout de l'alimentation des axes par défaut, si non-renseignés en Import
  If GIMPORT
     If LERR
        Call  AS_NBRCCE() From SUBLOF
        GMESSAGE="" : OK=1
     Endif
  Endif  #Fq-79815

$VERIF_MOD
  If ( G_ACTIAS = G_OUI )
    If ( ([M:LOF1]IASACN = GVML_NIENCOU and [M:LOF1]GACACN = GVML_NIENSER) or
&        ([M:LOF1]IASACN = GVML_NIENSER and [M:LOF1]GACACN = GVML_NIENCOU)    )
      GMESSAGE = mess(54,GML_MSGLOF,1) : # l'imputation PCG/IFRS en cours/en service ou en service/en cours est incorrecte
      GERR     = 1
      OK=0
    Endif
  Endif

  #FQ102516 si la dépense est rattachée à 1 bien et est subventionnée :
  #FQ102516 vérification que le projet du bien est identique au projet de la dépense
  #FQ102516   --> si non : avertissement
  If ( G_ACTGRT = G_OUI )
    If  [M:LOF1]FLGLIKAAS = G_OUI and [M:LOF2]FLGGRA = G_OUI
       If clalev([F:WFAS])=0  : Local File FXDASSETS   [WFAS]  : Endif  : # Biens comptabels
       Read[FAS]FAS0=[M:LOF1]AASREF
       If fstat=0
          If [F:FAS]INVPLN <> [M:LOF2]PLNINV
            If [F:FAS]INVPLN = ""
               [F:FAS]INVPLN = [M:LOF2]PLNINV
               Rewrite [FAS]
               If ( fstat ) Then
                 GOK = 0
                 Call FSTA("FAS") From GLOCK
               Endif
            Else
              Look [LOF]LOF6=[M:LOF1]AASREF
              If fstat
                [F:FAS]INVPLN = [M:LOF2]PLNINV
                Rewrite [FAS]
                If ( fstat ) Then
                  GOK = 0
                  Call FSTA("FAS") From GLOCK
                Endif
              Else
                #Le projet d’une dépense immobilisée doit être identique au projet du bien comptable.
                GMESSAGE = mess(107,GML_MSGLOF,1)
                GERR     = 1
                OK=0
              Endif
            Endif
          Endif
       Endif
     Endif
   Endif
   #FQ102516 END

Return

#-------------------------------------------------------------------------------
$AVANT_MODFIC
Local Integer LERROR

  #-------------------------------
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  #-------------------------------
  If ( LERROR <> 0 )
    # l'éclatement a échoué... dire un petit quelque chose
    GOK = 0
    Return
  Endif
Return

#-------------------------------------------------------------------------------
$APRES_CHOI
  #-------------------------------
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  #-------------------------------
Return

#-------------------------------------------------------------------------------
$RAZCRE

  [M:LOF1]ASJCOE    = 1.
  [M:LOF1]TAXCOE    = 1.
  [M:LOF1]TAXCOEFLG = 1
  [M:LOF1]ADMCOE    = 1.
  [M:LOF1]DEDCOE    = 1.

  #------------------------------------
  GMODE_PLUS1 = G_NON : # On n'est pas en mode +1
  #------------------------------------
  Gosub INIT_RUBRIQUES
  Call ACTION_BLOCK (ACB_AFFZO, "LOF1", "FLGVATFCR") From GLOBIENS
  Gosub MODIF_REDUITE
  If ( GREMAFCY = G_NON )
    zonsui = "[M:LOF0]FCY"
  Else
    zonsui = "[M:LOF0]CODLOF"
  Endif
  #------------------------------------
  DEDVATSAV = 0
  ACTSAV    = ""
  G_INIDEDAMT = 0
Return

#-------------------------------------------------------------------------------
$RAZDUP
  #------------------------------------
  Gosub RAZ_RUBRIQUES
  Gosub MODIF_REDUITE
  #------------------------------------
  DEDVATSAV = 0
  ACTSAV    = ""
  G_INIDEDAMT = 0
Return

#-------------------------------------------------------------------------------
$INICRE
  #-------------------------
  # Numérotation automatique
  If ( GMODE_PLUS1 = G_NON )
    # Si pas en mode +1 on calcul s'il le faut le numéro automatique
    If ( GLOFAUTNUM = 2 or (GLOFAUTNUM = 3 and [M:LOF0]CODLOF = "") )
      # Recherche du compteur de document
      # X3Suivi:23365 FQ85464
      Call GET_NUMERO_CODLOF( [M:LOF0]CPY, [M:LOF0]FCY, date$, [F:LOF]CODLOF, GMESSAGE)
      If GMESSAGE <> ""
        GOK       = 0
        Return
      Endif
      [M:LOF0]CODLOF = [F:LOF]CODLOF
      Affzo [M:LOF0]CODLOF
      [F:LOF]LINLOF  = 1
      [M:LOF0]LINLOF = [F:LOF]LINLOF
      Affzo [LOF0]LINLOF
      [M:LOF0]LINLOF = 0 : # FQ45871
    Endif
    If GIMPORT
      # FQ45871
      If [M:LOF0]LINLOF = 0
        [M:LOF0]LINLOF  = 1
        [F:LOF]LINLOF   = [M:LOF0]LINLOF
      Endif
    Else
      [F:LOF]LINLOF  = 1
      [M:LOF0]LINLOF = [F:LOF]LINLOF
      Affzo [LOF0]LINLOF
    Endif
  Else
    # Si mode +1, on recalcule juste le numéro de ligne sur la référence en cours
    Filter [LOFB] Where CODLOF=[M:LOF0]CODLOF
    Read [LOFB]LOF0 Last
    Filter [LOFB]
    If ( fstat > 2 )
      [M:LOF0]LINLOF = 1
    Else
      [M:LOF0]LINLOF = [F:LOFB]LINLOF+1
    Endif
    [F:LOF]LINLOF = [M:LOF0]LINLOF
    Affzo [M:LOF0]LINLOF
  Endif

  If ([M:LOF1]RATVATREC <> 100 )
    Local Date    W_CNX_DATE(1..5)
    Local Integer LCDRET, CDRET
    Local Char    LCDINT(10)

    If clalev([F:MAS1])= 0 : Local File LAYOUTFAS [MAS1] : Endif  : # Dépenses pour Evénement
    [F:MAS1] = [F:LOF]
    G_INIDEDAMT = [M:LOF1]AMTVATRCPY

    # Génération des évènements
    LCDINT= "LOFVATREG1"
    G_CRBVAT = 0
    G_DEDVAT = 0

    # Récupération date de fin de période contexte fiscale & comptable pour génération événement
    Call GET_CNX_DAT([F:MAS1]CPY, G300CPFI, W_CNX_DATE, CDRET) From GLOBIENS
    G_FINPERCPF = W_CNX_DATE(4)
    If ( G_FINPERCPF = [0/0/0] )
      G_FINPERCPF = W_CNX_DATE(2)
    Endif
    Call GENER_EVE
&        (GVML_OMDEPEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]CODLOF,[F:MAS1]LINLOF,LCDINT,G_FINPERCPF,[0/0/0],LCDRET)
&        From GENEVE
    If ( GCNXPROIAS = G_OUI and LCDRET <= 20 )
      # Récupération date de fin de période contexte IAS pour génération événement
      Call GET_CNX_FROM_PLAN ([F:MAS1]CPY, G301IAS, LCNXIAS) From GLOBIENS
      Call GET_CNX_DAT([F:MAS1]CPY, LCNXIAS, W_CNX_DATE, CDRET) From GLOBIENS
      G_FINPERIAS = W_CNX_DATE(4)
      If ( G_FINPERIAS = [0/0/0] )
        G_FINPERIAS = W_CNX_DATE(2)
      Endif
      LCDINT= "LOFVATREG6"
      Call GENER_EVE
&         (GVML_OMDEPEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]CODLOF,[F:MAS1]LINLOF,LCDINT,G_FINPERIAS,[0/0/0],LCDRET)
&         From GENEVE
    Endif
    If ( LCDRET > 20 )
      GERR = 1
      GMESSAGE = mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
      GOK = 0: Return
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$INIMOD

  Local Date    W_CNX_DATE(1..5)
  Local Integer LCDRET, CDRET
  Local Char    LCDINT(10)
  Local Decimal LREGUL

  If dim(G_ACT_NAM)>0 and G_ACT_NAM = "LOFECL"  : Return : Endif # on vient de l'éclatement ==> pas d'evt généré

  If clalev([F:MAS1])= 0 : Local File LAYOUTFAS [MAS1] : Endif  : # Dépenses pour Evénement
  [F:MAS1] = [F:LOF]

  #*Fq-85231 si la modification de la dépense n'est pas due à un éclatement en cours
  #* et que le montant de TVA récupérée a été modifié
  If ( G_LOFSPL <> G_OUI )
  LREGUL = [F:MAS1]AMTVATRCPY - DEDVATSAV
  Else
     LREGUL = 0
  Endif
  # FQ46680
  #- 1 ------------------------------------------------------
  If ([M:LOF1]RATVATREC <> 100 and LREGUL <> 0 )
    # Génération des évènements
    LCDINT= "LOFVATREG1"
    If (LREGUL < 0 )
      G_DEDVAT = 0
      G_CRBVAT = abs(LREGUL)
    Else
      G_CRBVAT = 0
      G_DEDVAT = LREGUL
    Endif
    G_INIDEDAMT = [M:LOF1]AMTVATRCPY

    # Récupération date de fin de période contexte fiscale & comptable pour génération événement
    Call GET_CNX_DAT([F:MAS1]CPY, G300CPFI, W_CNX_DATE, CDRET) From GLOBIENS
    G_FINPERCPF = W_CNX_DATE(4)
    If ( G_FINPERCPF = [0/0/0] )
      G_FINPERCPF = W_CNX_DATE(2)
    Endif
    Call GENER_EVE
&        (GVML_OMDEPEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]CODLOF,[F:MAS1]LINLOF,LCDINT,G_FINPERCPF,[0/0/0],LCDRET)
&        From GENEVE
    If ( GCNXPROIAS = G_OUI and LCDRET <= 20 )
      # Récupération date de fin de période contexte IAS pour génération événement
      Call GET_CNX_FROM_PLAN ([F:MAS1]CPY, G301IAS, LCNXIAS) From GLOBIENS
      Call GET_CNX_DAT([F:MAS1]CPY, LCNXIAS, W_CNX_DATE, CDRET) From GLOBIENS
      G_FINPERIAS = W_CNX_DATE(4)
      If ( G_FINPERIAS = [0/0/0] )
        G_FINPERIAS = W_CNX_DATE(2)
      Endif
      LCDINT= "LOFVATREG6"
      Call GENER_EVE
&          (GVML_OMDEPEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]CODLOF,[F:MAS1]LINLOF,LCDINT,G_FINPERIAS,[0/0/0],LCDRET)
&          From GENEVE
    Endif
    If ( LCDRET > 20 )
      GERR = 1
      GMESSAGE = mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
      GOK = 0: Return
    Endif
  Endif
  #- 1 ------------------------------------------------------

Return

#-------------------------------------------------------------------------------
$VERF_ANU
#-------------------------------------------
  # Pour éviter de virer toutes les dépenses d'un N° de ligne donné
  If ( [M:LOF0]CODLOF = "" )
    GMESSAGE = mess(53,GML_MSGLOF,1) # Dépense sans référence : Suppression interdite
    If GADONIX=G_OUI : GMESSAGE += ", contacter G.Boisson ou E.Latour" : Endif
    OK=0 : Return
  Endif

  #If ( [M]CREORI=GVML_COIMPOR ) FQ104766
  If ( [M:LOF2]CPMCREORI <> 0)
    Local Integer OK
    Call AVERTIR(mess(65,GML_MSGLOF,1),OK) From GESECRAN
    If OK=1
      OK=0
    Else
      OK=1
    Endif
   Endif

Return

#-------------------------------------------------------------------------------
$AV_ANNULE
#-------------------------------------------
  Local Integer LCDRET
  Local Integer NBEVESUP
  Call SUPP_EVE_OBJ(GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,[0/0/0],NBEVESUP,LCDRET) From GENEVE
  If LCDRET
   Infbox "SUPP_EVE_OBJ =>"-num$(LCDRET)
   GOK=0
   Return
  Endif
  Call CRE_EVE_CNL_OBJ(GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,[0/0/0],LCDRET) From GENEVE
  If LCDRET
   Infbox "CRE_EVE_CNL_OBJ =>"-num$(LCDRET)
   GOK=0
   Return
  Endif
Return

#-------------------------------------------------------------------------------
$ANNULE
#-------------------------------------------

  # Evénement
  Local Integer LCDRET
  #  Affichage conditionné de la jauge dans DETRICOTE_EVE
  Local Integer LJAUGE

  # Gestion de l'annulation des événements en cas d'annulation
  #  Affichage conditionné de la jauge dans DETRICOTE_EVE
  LJAUGE = G_OUI
  Call DETRICOTE_EVE
&      (GVML_OMDEPEN, [F:LOF]CPY, [F:LOF]CODLOF, [F:LOF]LINLOF, [F:LOF]DATIMP, LJAUGE, LCDRET) From GENEVE
  If ( LCDRET > 20 )
    GOK = 0
    Call FSTA("ELOFVATREG") From GLOCK
    Return
  Endif
  #------------------------
Return

#-------------------------------------------------------------------------------
$SETBOUT
#-------------------------------------------
# Codes des boutons spécifiques aux dépenses
# 1     - +1
# 4     - Eclater (Bomb)
#-------------------------------------------
  #-------------------------
  Local Char LIS_ACT1(15)(10)
  LIS_ACT1(0) = "4"  : # éclater
  Gosub ACTION From TRTOBJACT                                      #=> Modèle action unitaire V1
  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
  #-------------------------

  # Dépenses créées par import peuvent être supprimées si on est le superutilisateur
  #*FQ97977 Local Char ADMUSR
  #*FQ97977 Call PARAM("","ADMUSR",ADMUSR) From ADOVAL
  #*FQ97977 : Param : User authorized to cancel expense
  Local Char WPARAM(10)
  Call PARAMUTIL("LOFDELAUT",WPARAM,"","") From SUBAUS
  G_LOFDELAUT=val(WPARAM)
  If G_LOFDELAUT=0 : G_LOFDELAUT=G_NON : Endif
   #*FQ97977 END

  #If ( [M:LOF1]FLGLIKAAS = G_OUI or ( [M]CREORI = GVML_COIMPOR and GUSER<>ADMUSR ) ) : # FQ104766
  #*FQ97977 If ( [M:LOF1]FLGLIKAAS = G_OUI or ( [M]CPMCREORI <> 0 and GUSER <> ADMUSR ) )
  #*FQ97977 the user parameter "Authorized to cancel expenses" is controlled
  If ( [M:LOF1]FLGLIKAAS = G_OUI or ( [M]CPMCREORI <> 0 and G_LOFDELAUT<> G_OUI)  )
    # si la dépense est liée à un bien ou qu'elle a été créée par un flux :
    #   - on ne peut plus la supprimer
    Call VIREBOUT (CHAINE, "A") From GOBJET   : # Supprimer
  Endif

  If ( GREP = "C" or GREP = "D" or GREP = "M" or GREP = "A" or CLECUR <> 1 )
& or ( !func GLOBIENS.AUTORIS_OPT([M]FCY,"C") )   : # FQ68568
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # +1
  Endif

  # FGR 17/10/2012 : X3SUIVI81498 (début)
  If REP = ""
    CHMEN += "N"
  Endif
  # FGR 17/10/2012 : X3SUIVI81498 (fin)

  CHMEN += "E"

  # FQ101291
  If GREP = "M"
    Diszo [M:LOF0]CODLOF, LINLOF
  Endif

  Gosub SET_BOUT_SPE From GSAISIE
Return

#-------------------------------------------------------------------------------
$AVANTBOUT
  # ------------------------------
  Case BOUT
    When "1"  : # Bouton "+1"
      # FQ65623 : contrôle du paramètre CREDIRLOF pour les sociétés en législation française
      If [M:FPC]CREDIRLOF=G_NON
        GMESSAGE = mess(83,GML_MSGLOF,1)-[M:FPC]CPY
        GERR     = 1
        Return
      Endif

      GMODE_PLUS1 = G_OUI
      Gosub DEVERROU
      REP = "D"
      Gosub RAZDUP
      # FQ102570
      Raz [M:LOF1]AMTNOTIAS
      Raz [M:LOF1]AMTVATIAS
      Raz [M:LOF1]AMTVATRIAS
    When Default
  Endcase
  # ------------------------------
  Local Char LIS_ACT1(15)(10)
  LIS_ACT1(0) = "4"  : # éclater
  Gosub ACTION From TRTOBJACT
  Gosub SETMASK From GOBJET
  #------------------------------
Return

#-------------------------------------------------------------------------------
$EXEBOUT
  Case BOUT
    When "1"  : # Bouton "+1"
      Raz [M:LOF0]LINLOF
      Affzo [M:LOF0]LINLOF
      zonsui = "[M:LOF0]DES"

      # On invalide les masques pour forcer les contrôle (fiche 27168)
      Setmok [M:LOF0] With 0
      Setmok [M:LOF1] With 0
      Setmok [M:LOF2] With 0
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$FIN_ACTION
  # ------------------------------
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  # ------------------------------
Return

#-------------------------------------------------------------------------------
$FILGAUCHE
  If ( dim(LTI_DEPLIEE) = -1 )   : Return : Endif

  If ( currbox = LTI_DEPLIEE )
    # Dépenses regroupées
    Raz FILGAUSUP
    FILGAUSUP(0) = "[F:LOF]AASREF=[M:LOF1]AASREF &[F:LOF]AASREF<>''"
    FILGAUSUP(1) = "&[F:LOF]FLGLIKAAS=G_OUI &[F:LOF]FLGLIKAAS=[M:LOF1]FLGLIKAAS"
  Elsif ( currbox = LTI_DEPIMMO )
    # Dépenses Immobilisables
    Raz FILGAUSUP
    FILGAUSUP(0) = "[F:LOF]FLGLIKAAS=G_NON &([F:LOF]GACACN=GVML_NIENCOU or [F:LOF]GACACN=GVML_NIENSER)"
    # FQ92277 : Suppression du find car plantage si grand nombre de sites
    #FILGAUSUP(1) = "& find([F:LOF]FCY,GUSRFCY) & [F:LOF]FLGVAL=G_OUI"
    FILGAUSUP(1) = "& [F:LOF]FLGVAL=G_OUI"
  Endif
Return

#-------------------------------------------------------------------------------
$TIROIR
Return

#-------------------------------------------------------------------------------
$GAUCHE
Return

#-------------------------------------------------------------------------------
$FIN
 Local Integer FROMSUBOBJ
 Gosub ACTION From TRTOBJACT
 If dim(G_LOFSPL)     >0 : Kill G_LOFSPL     : Endif    #*Fq-85231
 If dim(G_LOFDELAUT)  >0 : Kill G_LOFDELAUT  : Endif    #*FQ97977
#  If dim(G_NBAXE)     >0 : Kill G_NBAXE  : Endif    #*Fq-85231 # FQ93595
 Kill FROMSUBOBJ
Return

#-------------------------------------------------------------------------------
$FERME
  #----------------------------------------------------------------------#
  # Si on est venu par tunnel il faut restaurer les variables globales   #
  #----------------------------------------------------------------------#
  If (TUNNEL)
    Gosub RESTAURE_GLOBAL_SV From GLOBIMM
  Endif

  Kill G_DEFORCE_LOF    : # Indicateur de déforçage.
  If dim(G_DEDVAT)     >0 : Kill G_DEDVAT     : Endif
  If dim(G_CRBVAT)     >0 : Kill G_CRBVAT     : Endif
  If dim(G_INIDEDAMT)  >0 : Kill G_INIDEDAMT  : Endif
  If dim(G_FINPERCPF)  >0 : Kill G_FINPERCPF  : Endif
  If dim(G_FINPERIAS)  >0 : Kill G_FINPERIAS  : Endif
  If dim(G_LOFSPL)     >0 : Kill G_LOFSPL     : Endif    #*Fq-85231
  If dim(G_LOFDELAUT)  >0 : Kill G_LOFDELAUT  : Endif    #*FQ97977

  If dim(GMODE_PLUS1)>0 : Kill GMODE_PLUS1 : Endif
  If dim(LIS_ACT)>0     : Kill LIS_ACT     : Endif
  If dim(LIS_NAM)>0     : Kill LIS_NAM     : Endif
  If dim(LIS_TYP)>0     : Kill LIS_TYP     : Endif
  If dim(LIS_ACT1)>0    : Kill LIS_ACT1    : Endif

  If (TUNNEL)
    Gosub RESTAURE_GLOB_TUNNEL From TRUPROACT
  Endif

Return

#-------------------------------------------------------------------------------
$ACTIVE_TOUTES_RUBRIQUES
Local Integer N_I

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES", 0)    = G_NON   : Actzo [M:LOF0]DES    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES2", 0)   = G_NON   : Actzo [M:LOF0]DES2   : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]FCY", 0)    = G_NON   : Actzo [M:LOF0]FCY    : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPR", 0)    = G_NON   : Actzo [M:LOF1]BPR    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ORDBUY", 0) = G_NON   : Actzo [M:LOF1]ORDBUY : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPRVCR", 0) = G_NON   : Actzo [M:LOF1]BPRVCR : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ITMREF", 0) = G_NON   : Actzo [M:LOF1]ITMREF : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]UOM", 0)    = G_NON   : Actzo [M:LOF1]UOM    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]QTY", 0)    = G_NON   : Actzo [M:LOF1]QTY    : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CUR", 0)    = G_NON   : Actzo [M:LOF1]CUR    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATVCR", 0) = G_NON   : Actzo [M:LOF1]DATVCR : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_NON   : Actzo [M:LOF1]CURTYP : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATCUR", 0) = G_NON   : Actzo [M:LOF1]RATCUR : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TYPVCR", 0) = G_NON   : Actzo [M:LOF1]TYPVCR : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACGGRP", 0) = G_NON   : Actzo [M:LOF1]ACGGRP : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACT", 0)    = G_NON   : Actzo [M:LOF1]ACT    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ASJCOE", 0) = G_NON   : Actzo [M:LOF1]ASJCOE : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_NON   : Actzo [M:LOF1]TAXCOE : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ADMCOE", 0) = G_NON   : Actzo [M:LOF1]ADMCOE : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTNOTCUR", 0) = G_NON   : Actzo [M:LOF1]AMTNOTCUR : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVAT", 0)    = G_NON   : Actzo [M:LOF1]RATVAT    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGVATFCR", 0) = G_NON   : Actzo [M:LOF1]FLGVATFCR : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGRECFVR", 0) = G_NON   : Actzo [M:LOF1]FLGRECFVR : Endif
  Call AP_RATVATREC([M:LOF1]RATVATREC)

  # Cette rubrique est tj disable, on veut que le tunnel
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AASREF", 0) = G_OUI   : Diszo [M:LOF1]AASREF : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATIMP", 0) = G_NON   : Actzo [M:LOF1]DATIMP : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GACACN", 0) = G_NON   : Actzo [M:LOF1]GACACN : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GAC", 0)    = G_NON   : Actzo [M:LOF1]GAC    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACN", 0) = G_NON   : Actzo [M:LOF1]IASACN : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACC", 0) = G_NON   : Actzo [M:LOF1]IASACC : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]JOU", 0)    = G_NON   : Actzo [M:LOF1]JOU    : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]USRDEN", 0) = G_NON   : Actzo [M:LOF2]USRDEN : Endif

  #####If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]LOC"   , 0) = G_NON   : Actzo [M:LOF2]LOC    : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DSP"   , 0) = G_NON   : Actzo [M:LOF2]DSP    : Endif

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]FIYBUD", 0) = G_NON   : Actzo [M:LOF2]FIYBUD : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]PLNINV", 0) = G_NON   : Actzo [M:LOF2]PLNINV : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]BUDINV", 0) = G_NON   : Actzo [M:LOF2]BUDINV : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DEMINV", 0) = G_NON   : Actzo [M:LOF2]DEMINV : Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CONNUM", 0) = G_NON   : Actzo [M:LOF2]CONNUM : Endif
  If ( dim([M:LOF2]FLGGRA) > 0 & G_ACTGRT = G_OUI )
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]FLGGRA", 0) = G_NON )   : Actzo [M:LOF2]FLGGRA  : Endif
  Endif

  If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DSP"   , 0) = G_NON )   : Actzo [M:LOF2]DSP       : Endif

  Call ACTION_BLOCK (ACB_AFFZO, "LOF2", "NBRCCE") From GLOBIENS
  For N_I = 1 To GOPTCANA
    If (func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_I-1) = G_NON)  : Actzo [M:LOF2]CCE(N_I-1): Endif
  Next N_I

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]IASCGU", 0)  = G_NON   : Actzo [M:LOF2]IASCGU : Endif
Return

#-------------------------------------------------------------------------------
$MODIF_REDUITE
  #-------------------------
  Gosub ACTIVE_TOUTES_RUBRIQUES
  #-------------------------
  # Activation/désactivation des rubriques déterminées
  # (FGR) Cette partie me désactive systématiquement les natures et compte IAS.
  # Or, dans le cas où "mes règles à moi" ne disent pas que ces rubriques
  # ne sont pas modifiables et qu'il n'y a pas d'association (ce qui est le
  # cas sur ma société), elles devraient être accessibles.

  If ( dim(ACTION) > 0 & ACTION = "STYLE" )
    Call RUBRIQUES_DETERMINEES(GVML_OMDEPEN, [M:LOF0]CPY, G_OUI) From TRTASSO
  Else
    Call RUBRIQUES_DETERMINEES(GVML_OMDEPEN, [M:LOF0]CPY, G_NON) From TRTASSO
  Endif
  #-------------------------
  If ( [M:LOF1]CUR = GCNXCURCPF )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_OUI   : Diszo [M:LOF1]CURTYP : Endif
  Else
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_NON   : Actzo [M:LOF1]CURTYP : Endif
  Endif
  If ([M:LOF1]ACT = "" and [M:LOF1]ASJCOE = 0. )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_OUI   : Diszo [M:LOF1]TAXCOE : Endif
  Endif
  Gosub RUBRIQUE_ENCREATION
  Gosub RUBRIQUE_ENMODIF
  Gosub RUBRIQUE_DEPENSE_IMMOBILISEE
  #FQ102691 If func AFNC.PARAM("FRADGI",[M:LOF0]CPY)="2" : # FQ72247
  If func AFNC.PARAM("FRADGI",[M:LOF0]CPY)="2" or ([F:LOF]CPMCREORI  = 6)
    Gosub RUBRIQUE_DEPENSE_GENEREE : # FQ65625
  Endif
  Gosub RUBRIQUES_IMPORT
  Gosub RUBRIQUES_IAS
  #-------------------------
Return
#-------------------------------------------------------------------------------
$RUBRIQUE_ENCREATION

  If ( GREP = "C" or GREP = "D" )
    If ( dim([M:LOF2]FLGGRA) > 0 and G_ACTGRT = G_OUI )
      If ( [M:LOF2]FLGGRA <> G_OUI )
        If (func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]AMTGRA", 0) = G_OUI)   : Diszo [M:LOF2]AMTGRA : Endif
      Endif
    Endif
    If ( [M:LOF1]ASJCOE = 0. )
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_OUI   : Diszo [M:LOF1]TAXCOE : Endif
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$RUBRIQUE_ENMODIF

  If ( GREP <> "C" and GREP <> "D" )
    If (func GLOBIENS.IS_CHAMP_ENABLE("[M:LOF0]FCY", 0) = G_OUI)   : Diszo [M:LOF0]FCY : Endif
      If ( dim([M:LOF2]FLGGRA) > 0 and G_ACTGRT = G_OUI )
      If ( [M:LOF2]FLGGRA <> G_OUI )
        If (func GLOBIENS.IS_CHAMP_ENABLE("[M:LOF2]AMTGRA", 0) = G_OUI)   : Diszo [M:LOF2]AMTGRA : Endif
      Endif
    Endif
    If ([M:LOF1]DATIMP < GDEBEXECPF )
      If (func GLOBIENS.IS_CHAMP_ENABLE("[M:LOF1]ACT", 0) = G_OUI)   : Diszo [M:LOF1]ACT : Endif
    Endif

    If [M:LOF2]DSP <> ""
      For N_I = 1 To GOPTCANA
        If (func GLOBIENS.IS_CHAMP_ENABLE("[M:LOF2]CCE", N_I-1) = G_OUI)  : Diszo [M:LOF2]CCE(N_I-1): Endif
      Next N_I
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$RUBRIQUE_DEPENSE_IMMOBILISEE
  # Désactive certaines rubriques si la dépense a été immobilisée

  Local Integer N_I

  # Gestion modification réduite ou pas
  If ( [M:LOF1]FLGLIKAAS = G_OUI )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES", 0)    = G_OUI   : Diszo [M:LOF0]DES    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES2", 0)   = G_OUI   : Diszo [M:LOF0]DES2   : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]FCY", 0)    = G_OUI   : Diszo [M:LOF0]FCY    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPR", 0)    = G_OUI   : Diszo [M:LOF1]BPR    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ORDBUY", 0) = G_OUI   : Diszo [M:LOF1]ORDBUY : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPRVCR", 0) = G_OUI   : Diszo [M:LOF1]BPRVCR : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ITMREF", 0) = G_OUI   : Diszo [M:LOF1]ITMREF : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]UOM", 0)    = G_OUI   : Diszo [M:LOF1]UOM    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]QTY", 0)    = G_OUI   : Diszo [M:LOF1]QTY    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CUR", 0)    = G_OUI   : Diszo [M:LOF1]CUR    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATVCR", 0) = G_OUI   : Diszo [M:LOF1]DATVCR : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_OUI
     Diszo [M:LOF1]CURTYP
    Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATCUR", 0) = G_OUI   : Diszo [M:LOF1]RATCUR : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TYPVCR", 0) = G_OUI   : Diszo [M:LOF1]TYPVCR : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACT", 0)    = G_OUI   : Diszo [M:LOF1]ACT    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_OUI   : Diszo [M:LOF1]TAXCOE : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ASJCOE", 0) = G_OUI   : Diszo [M:LOF1]ASJCOE : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ADMCOE", 0) = G_OUI   : Diszo [M:LOF1]ADMCOE : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTNOTCUR", 0)  = G_OUI   : Diszo [M:LOF1]AMTNOTCUR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVAT", 0)     = G_OUI   : Diszo [M:LOF1]RATVAT     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGVATFCR", 0)  = G_OUI   : Diszo [M:LOF1]FLGVATFCR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATCUR", 0)  = G_OUI   : Diszo [M:LOF1]AMTVATCUR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVATREC", 0)  = G_OUI   : Diszo [M:LOF1]RATVATREC  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGRECFVR", 0)  = G_OUI   : Diszo [M:LOF1]FLGRECFVR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATRCUR", 0) = G_OUI   : Diszo [M:LOF1]AMTVATRCUR : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AASREF", 0) = G_OUI   : Diszo [M:LOF1]AASREF : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATIMP", 0) = G_OUI   : Diszo [M:LOF1]DATIMP : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACGGRP", 0) = G_OUI   : Diszo [M:LOF1]ACGGRP : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GACACN", 0) = G_OUI   : Diszo [M:LOF1]GACACN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GAC", 0)    = G_OUI   : Diszo [M:LOF1]GAC    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACN", 0) = G_OUI   : Diszo [M:LOF1]IASACN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACC", 0) = G_OUI   : Diszo [M:LOF1]IASACC : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]JOU", 0)    = G_OUI   : Diszo [M:LOF1]JOU    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]USRDEN", 0) = G_OUI   : Diszo [M:LOF2]USRDEN : Endif

    ###If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]LOC"   , 0) = G_OUI   : Diszo [M:LOF2]LOC    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]FIYBUD", 0) = G_OUI   : Diszo [M:LOF2]FIYBUD : Endif
    # FQ102516
    #If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]PLNINV", 0) = G_OUI   : Diszo [M:LOF2]PLNINV : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]BUDINV", 0) = G_OUI   : Diszo [M:LOF2]BUDINV : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DEMINV", 0) = G_OUI   : Diszo [M:LOF2]DEMINV : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CONNUM", 0) = G_OUI   : Diszo [M:LOF2]CONNUM : Endif

    If ( dim([M:LOF2]FLGGRA) > 0 and G_ACTGRT = G_OUI )
      # FQ102516
      #If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]FLGGRA", 0)   = G_OUI  : Diszo [M:LOF2]FLGGRA    : Endif
    Endif
    If ( dim([M:LOF2]FLGAMTGRA) > 0 and G_ACTGRT = G_OUI )
      # FQ102516
      #If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]FLGAMTGRA", 0)= G_OUI  : Diszo [M:LOF2]FLGAMTGRA : Endif
    Endif
    If ( dim([M:LOF2]AMTGRA) > 0 and G_ACTGRT = G_OUI )
      # FQ102516
      #If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]AMTGRA", 0)   = G_OUI  : Diszo [M:LOF2]AMTGRA    : Endif
    Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DSP"   , 0) = G_OUI      : Diszo [M:LOF2]DSP       : Endif

    For N_I = 1 To GOPTCANA
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_I-1) = G_OUI   : Diszo [M:LOF2]CCE(N_I-1) : Endif
    Next N_I

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]IASCGU", 0)  = G_OUI   : Diszo [M:LOF2]IASCGU : Endif
  Endif
Return

#------------------------------------------------------------------------------- FQ65625
$RUBRIQUE_DEPENSE_GENEREE
  # Désactive certaines rubriques si la dépense est créée à partir d'une facture ou d'une pièce comptable avec FRADGI à Oui
  Local Integer N_I

  # Gestion modification réduite ou pas
  If ( [M:LOF2]CPMCREORI <> 0 )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES", 0)    = G_OUI   : Diszo [M:LOF0]DES    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]DES2", 0)   = G_OUI   : Diszo [M:LOF0]DES2   : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]FCY", 0)    = G_OUI   : Diszo [M:LOF0]FCY    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPR", 0)    = G_OUI   : Diszo [M:LOF1]BPR    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ORDBUY", 0) = G_OUI   : Diszo [M:LOF1]ORDBUY : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPRVCR", 0) = G_OUI   : Diszo [M:LOF1]BPRVCR : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ITMREF", 0) = G_OUI   : Diszo [M:LOF1]ITMREF : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]UOM", 0)    = G_OUI   : Diszo [M:LOF1]UOM    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]QTY", 0)    = G_OUI   : Diszo [M:LOF1]QTY    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CUR", 0)    = G_OUI   : Diszo [M:LOF1]CUR    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATVCR", 0) = G_OUI   : Diszo [M:LOF1]DATVCR : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_OUI
     Diszo [M:LOF1]CURTYP
    Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATCUR", 0) = G_OUI   : Diszo [M:LOF1]RATCUR : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TYPVCR", 0) = G_OUI   : Diszo [M:LOF1]TYPVCR : Endif
    #*FQ98116 If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACT", 0)    = G_OUI   : Diszo [M:LOF1]ACT    : Endif
    #*FQ98116 If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_OUI   : Diszo [M:LOF1]TAXCOE : Endif
    #*FQ98116 If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ASJCOE", 0) = G_OUI   : Diszo [M:LOF1]ASJCOE : Endif
    #*FQ98116 If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ADMCOE", 0) = G_OUI   : Diszo [M:LOF1]ADMCOE : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTNOTCUR", 0)  = G_OUI   : Diszo [M:LOF1]AMTNOTCUR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVAT", 0)     = G_OUI   : Diszo [M:LOF1]RATVAT     : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGVATFCR", 0)  = G_OUI   : Diszo [M:LOF1]FLGVATFCR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATCUR", 0)  = G_OUI   : Diszo [M:LOF1]AMTVATCUR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVATREC", 0)  = G_OUI   : Diszo [M:LOF1]RATVATREC  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGRECFVR", 0)  = G_OUI   : Diszo [M:LOF1]FLGRECFVR  : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATRCUR", 0) = G_OUI   : Diszo [M:LOF1]AMTVATRCUR : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AASREF", 0) = G_OUI   : Diszo [M:LOF1]AASREF : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATIMP", 0) = G_OUI   : Diszo [M:LOF1]DATIMP : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACGGRP", 0) = G_OUI   : Diszo [M:LOF1]ACGGRP : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GACACN", 0) = G_OUI   : Diszo [M:LOF1]GACACN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GAC", 0)    = G_OUI   : Diszo [M:LOF1]GAC    : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACN", 0) = G_OUI   : Diszo [M:LOF1]IASACN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACC", 0) = G_OUI   : Diszo [M:LOF1]IASACC : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]JOU", 0)    = G_OUI   : Diszo [M:LOF1]JOU    : Endif

    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DSP"   , 0) = G_OUI      : Diszo [M:LOF2]DSP       : Endif

    For N_I = 1 To GOPTCANA
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_I-1) = G_OUI   : Diszo [M:LOF2]CCE(N_I-1) : Endif
    Next N_I

    #*FQ98116 Taux TVA facturée forcé
    If [M:LOF1]FLGVATFCR = G_OUI
      Diszo [M:LOF1]RATVAT
      Diszo [M:LOF1]AMTVATCUR
    Endif
    #*FQ98116 Taux TVA récupérée forcé
    If [F:LOF]FLGRECFVR = G_OUI
      Diszo [M:LOF1]RATVATREC
      Diszo [M:LOF1]AMTVATRCUR
    Endif #*FQ98116 END

  Endif
Return

#-------------------------------------------------------------------------------
$RUBRIQUES_IAS
  # Désactive les rubriques liées à l'IAS s'il n'y a pas de contexte IAS sur la société

  If ( GCNXPROIAS = G_NON )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACN", 0)     = G_OUI   : Diszo [M:LOF1]IASACN : Endif
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACC", 0)     = G_OUI   : Diszo [M:LOF1]IASACC : Endif
  Endif
Return

#-------------------------------------------------------------------------------
$RUBRIQUES_IMPORT
  # Désactive certaines rubrique si la dépense a été créée par import et que ces rubriques
  # sont alimentées

  # FQ102224
  # If ( [M]CREORI = GVML_COIMPOR )
  If ( [M]CPMCREORI <> 0 )
    If [M:LOF0]FCY    <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF0]FCY",    0) = G_OUI   Diszo [M:LOF0]FCY    : Endif

    If [M:LOF1]BPR    <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPR",    0) = G_OUI   Diszo [M:LOF1]BPR    : Endif
    If [M:LOF1]ORDBUY <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ORDBUY", 0) = G_OUI   Diszo [M:LOF1]ORDBUY : Endif
    If [M:LOF1]ITMREF <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ITMREF", 0) = G_OUI   Diszo [M:LOF1]ITMREF : Endif
    If [M:LOF1]BPRVCR <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]BPRVCR", 0) = G_OUI   Diszo [M:LOF1]BPRVCR : Endif

    If [M:LOF1]UOM    <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]UOM",    0) = G_OUI   Diszo [M:LOF1]UOM    : Endif
    If [M:LOF1]QTY    <> 0    and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]QTY",    0) = G_OUI   Diszo [M:LOF1]QTY    : Endif

    If [M:LOF1]CUR    <> ""   and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CUR",    0)    = G_OUI   Diszo [M:LOF1]CUR : Endif
    If [M:LOF1]DATVCR <> [0/0/0] and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATVCR", 0) = G_OUI   Diszo [M:LOF1]DATVCR    : Endif
    If [M:LOF1]CURTYP <> 0    and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]CURTYP", 0) = G_OUI   Diszo [M:LOF1]CURTYP : Endif
    If [M:LOF1]RATCUR <> 0    and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATCUR", 0) = G_OUI   Diszo [M:LOF1]RATCUR : Endif
    If [M:LOF1]TYPVCR <> 0    and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TYPVCR", 0) = G_OUI   Diszo [M:LOF1]TYPVCR : Endif

    # FQ75672
    If ([M:LOF1]AMTNOTCUR <> 0 or [M:LOF1]AMTNOTCPY <> 0) and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTNOTCUR", 0) = G_OUI
      Diszo [M:LOF1]AMTNOTCUR
    Endif

    If [M:LOF1]RATVAT    <> 0 and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVAT", 0) = G_OUI
      Diszo [M:LOF1]RATVAT
      Diszo [M:LOF1]FLGVATFCR
      Diszo [M:LOF1]AMTVATCUR
    Endif

    If [M:LOF1]RATVATREC <> 0 and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]RATVATREC", 0) = G_OUI
      Diszo [M:LOF1]RATVATREC
      Diszo [M:LOF1]FLGRECFVR
      Diszo [M:LOF1]AMTVATRCUR
    Endif

    If [M:LOF1]DATIMP <> [0/0/0] and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]DATIMP",0) = G_OUI   Diszo [M:LOF1]DATIMP    : Endif
    If ([M:LOF1]GAC <> "" or [M:LOF1]IASACC <> "") and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]ACGGRP", 0) = G_OUI   Diszo [M:LOF1]ACGGRP    : Endif
    If [M:LOF1]GACACN <> 0       and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GACACN",0) = G_OUI   Diszo [M:LOF1]GACACN    : Endif
    If [M:LOF1]GAC    <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]GAC",   0) = G_OUI   Diszo [M:LOF1]GAC       : Endif

    If [M:LOF1]IASACN <> 0       and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACN",0) = G_OUI   Diszo [M:LOF1]IASACN    : Endif
    If [M:LOF1]IASACC <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]IASACC",0) = G_OUI   Diszo [M:LOF1]IASACC    : Endif

    If [M:LOF1]JOU    <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]JOU",   0) = G_OUI   Diszo [M:LOF1]JOU       : Endif

    If [M:LOF2]USRDEN <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]USRDEN",0) = G_OUI   Diszo [M:LOF2]USRDEN    : Endif

    If [M:LOF2]DSP    <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]DSP",   0) = G_OUI   Diszo [M:LOF2]DSP       : Endif

    For N_I = 1 To GOPTCANA
      If ([M:LOF2]CCE(N_I-1) <> "" | [M:LOF2]DSP<>"") and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_I-1) = G_OUI   Diszo [M:LOF2]CCE(N_I-1) : Endif
    Next N_I

    If [M:LOF2]IASCGU <> ""      and func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]IASCGU",0) = G_OUI   Diszo [M:LOF2]IASCGU    : Endif
  Endif
Return

#-------------------------------------------------------------------------------
$INIT_RUBRIQUES

  If (not GIMPORT)   : [M:LOF1]FLGVAL=G_OUI  : Affzo [M:LOF1]FLGVAL : Endif

  [M:LOF1]FLGLIKAAS  = G_NON
  [M:LOF1]FLGLOFMAI  = G_NON
  [M:LOF1]FLGDETEXP  = G_OUI # FQ104360

  [M:LOF1]FLGVATFCR  = G_NON
  [M:LOF1]FLGRECFVR  = G_NON

  If ACTION = "RAZCRE"
    Call CALCUL_MONTANTS()
  Endif

  If ( dim([M:LOF2]FLGGRA) > 0 and G_ACTGRT = G_OUI )
    [M:LOF2]FLGGRA     = G_NON
  Endif


  If ( G_ACTGRT = G_OUI )
    [M:LOF2]FLGAMTGRA     = G_NON
    Diszo [M:LOF2]AMTGRA
  Endif

Return

#-------------------------------------------------------------------------------
$RAZ_RUBRIQUES
  # Réinitialise les valeurs des rubriques fonctionnelles
  Gosub INIT_RUBRIQUES

  Raz [M:LOF0]DES
  Raz [M:LOF0]DES2
  Call ACTION_BLOCK (ACB_AFFZO, "LOF0", "DES") From GLOBIENS

  Raz [M:LOF1]ITMREF
  Raz [M:LOF1]UOM
  Raz [M:LOF1]QTY
  Affzo [M:LOF1]ITMREF,UOM,QTY : #GLE 14/06/05 FQ28049

  Raz [M:LOF1]AASREF
  Call ACTION_BLOCK (ACB_AFFZO, "LOF1", "AASREF") From GLOBIENS

  Raz [M:LOF1]AMTNOTCUR
  Call ACTION_BLOCK (ACB_AFFZO, "LOF1", "FLGVATFCR") From GLOBIENS
  Call CALCUL_MONTANTS()

  Raz [M:LOF1]ACGGRP
  Effzo [M:LOF1]GACACN
  [M:LOF1]GACACN = 0
  Raz [M:LOF1]GAC
  Raz [M:LOF1]GACORI
  Effzo [M:LOF1]IASACN
  [M:LOF1]IASACN = 0
  Raz [M:LOF1]IASACC
  Raz [M:LOF1]IASACCORI
  Call ACTION_BLOCK (ACB_AFFZO, "LOF1", "GACORI") From GLOBIENS

  If ( dim([M:LOF2]AMTGRA) > 0 and G_ACTGRT = G_OUI )
    Raz [M:LOF2]AMTGRA
    Call ACTION_BLOCK (ACB_AFFZO, "LOF2", "FLGGRA") From GLOBIENS
  Endif

  Call INIT_CREORI From SUBFRZ
  Call ACTION_BLOCK (ACB_EFFZO, "LOF2", "CPMCREORI") From GLOBIENS : # Origine X3
Return

########################################
Subprog GET_NUMERO_CODLOF( PCPY, PFCY, PDATE, RCODLOF, RMESSAGE)
Value    Char PCPY
Value    Char PFCY
Value    Date PDATE
Variable Char RCODLOF()
Variable Char RMESSAGE()
  # FQ85464
  Local Integer LSTAT

  # Appel du compteur de document
  Call GET_NUMERO("LOF",GVML_NUMLOF-1,1,PCPY,PFCY,PDATE,RCODLOF,LSTAT) From GLOBIENS
  If (LSTAT)
    RMESSAGE = GMESSAGE
  Endif
End

################################################################################
# ECRAN : LOF0
################################################################################

########################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer ISITE, ISOC, OK
  Local Char    SOCIETE (GLONCPY)
  Local Char    DEVISE  (GLONCUR)

  # Recherche de la société du site
  ISITE = find(VALEUR,GSITE(1..GNBSITE))
  If (ISITE)
    SOCIETE = GSOCSITE(ISITE)
  Else
    GMESSAGE = mess(15,104,1) : # Site inexistant
    mkstat = 2 : End
  Endif

  # FQ65623 : contrôle du paramètre CREDIRLOF pour les sociétés en législation française
  Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
  # FQ79743 généralisation toutes législations et ajout du site en lecture de CREDIRLOF
#  If [F:CPY]LEG="FRA"
  Local Char LPARM(5)
  Call PARAM(VALEUR, "CREDIRLOF", LPARM) From ADOVAL
  If LPARM <> "2" # Oui
    GMESSAGE = mess(83, GML_MSGLOF, 1) - SOCIETE
    mkstat   = 2
    End
  Endif
#  Endif

  # Recherche de la devise de la société du site
  ISOC = find(SOCIETE,GSOC(1..GNBSOC))
  If (ISOC)
    DEVISE = GDEVSOC(ISOC)
  Else
    DEVISE = "EUR" : # Devise par défaut en cas de pb
  Endif

  # Pas de changement de site entrainant un changement de devise société si la dépense contient des éléments
  # de valorisation (présence du taux de change)
  If ([M:LOF0]FCY<>"" and VALEUR<>[M:LOF0]FCY and DEVISE<>GCOUDEV and [M:LOF1]RATCUR<>0 )
    # Modification interdite : la devise comptable est différente de celle de la société XXX
    GMESSAGE = mess(57,GML_MSGLOF,1)-GCOUSOC
    mkstat = 2 : End
  Endif

  # Contrôle de l'existence du contexte Comptable et fiscal
  OK=1
  If ( SOCIETE <> GCOUSOC )
    Look [CNX]CNX0=SOCIETE;G300CPFI
    If fstat : OK=0 : Endif
  Else
    If GCNXPROCPF = G_NON : OK=0 : Endif
  Endif
  If !OK
    # Opération impossible. Le contexte "fiscal & comptable" de la société doit avoir été défini au préalable.
    GMESSAGE = mess(115,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

########################################
Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()

End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  #------------------------------------
  If ( dim([M]ZCPY) > 0 )
    Affzo [M]ZCPY
  Endif

# Fq-52532
#  If !clalev([M:FCP]) # Issue 115510
     #> Chargement du masque de travail contenant le paramétrage comptable de la société
     Local Integer ERR
     Call LOAD_FASPARCPY([M:LOF0]CPY,"",G_NON,ERR) From GLOFCYCPY
#  Endif # Issue 115510

  [M:LOF1]CUR    = GCOUDEV
  [M:LOF1]DEVSOC = GCOUDEV
  Affzo [M:LOF1]CUR
  Affzo [M:LOF1]RATVAT
  Affzo [M:LOF1]RATVATREC
  Affzo [M:LOF1]DEVSOC
  #------------------------------------
  # En cas de changement de site, on efface la famille et le code comptable
  # pour rejouer proprement les associations et refaire les controles sur les comptes.
  Effzo [M:LOF1]ACGGRP
  Effzo [M:LOF1]GAC
  Effzo [M:LOF1]IASACC
  Effzo [M:LOF1]ACT
  Effzo [M:LOF1]SACDES
  [M:LOF1]ASJCOE    = 1. : Affzo [M:LOF1]ASJCOE
  [M:LOF1]TAXCOE    = 1. : Affzo [M:LOF1]TAXCOE
  [M:LOF1]TAXCOEFLG = 1  : Affzo [M:LOF1]TAXCOEFLG
  [M:LOF1]ADMCOE    = 1. : Affzo [M:LOF1]ADMCOE
  [M:LOF1]DEDCOE    = 1. : Affzo [M:LOF1]DEDCOE
  # FQ65673 : raz également des informations analytiques et géographiques
  Call ACTION_BLOCK (ACB_EFFZO, "LOF2", "DSP")    From GLOBIENS
  Call ACTION_BLOCK (ACB_EFFZO, "LOF2", "NBRCCE") From GLOBIENS
  #------------------------------------
  # Recherche du type de cours par défaut sur le contexte comptable et fiscal

  Read [CNX]CNX0=[M:LOF0]CPY;G300CPFI
  If ( fstat )
    # on n'a pas le contexte : on ne fait rien, faudra saisir
  Else
    If ( [F:CNX]CURTYP > 0 )
      [M:LOF1]CURTYP = [F:CNX]CURTYP
      Affzo [M:LOF1]CURTYP
    Endif
  Endif

  #------------------------------------
  If ( GREP = "C" or GREP = "D" )
    Gosub MODIF_REDUITE
  Endif
  #------------------------------------

  Gosub CONDITIONNE_IAS_LOF1 From TRTFAS : # FQ57624
End

########################################
Subprog AS_CODLOF(VALEUR)
Variable Char    VALEUR()

  If ( GMODE_PLUS1 = G_OUI )
    # En mode +1 le champ référence n'est pas accessible
    mkstat = 2
  Endif
End

########################################
Subprog AM_CODLOF(VALEUR)
Variable Char    VALEUR()

  [M:LOF0]LINLOF = 1
  Affzo [M:LOF0]LINLOF
End

########################################
Subprog C_CODLOF(VALEUR)
Variable Char    VALEUR()
  If ( GLOFAUTNUM = 1 and VALEUR = "" )
    GERR     = 1
    GMESSAGE = mess(3,GML_MSGFAS, 1)
    mkstat   = 2
  Elsif ( VALEUR = "" and !GIMPORT )
    mkstat   = 4 : # ELA : on force la création
  Endif
End

########################################
Subprog AS_LINLOF(VALEUR)
Variable Decimal VALEUR
  If ( GREP = "C" or GREP = "D" )
    # en création ou duplication, le numéro de ligne est tj calculé automatiquement (sauf en import)
    mkstat = 2
  Endif
End

######################################## FQ65623
Subprog C_LINLOF(VALEUR)
Variable Decimal VALEUR
  Look [F:LOF]LOF0=[M]CODLOF;VALEUR
  If fstat and [M:FPC]CREDIRLOF=G_NON
    GMESSAGE = mess(258,7770,1)-[M:FPC]CPY
    mkstat   = 2
    End
  Endif
End

######################################################################################
#FQ61803
Subprog AS_DES(VALEUR)
Variable Char    VALEUR()
 If GDEBUG<>G_OUI : GBOUT1 = "" : Endif
End

################################################################################
# ECRAN : LOF1
################################################################################
########################################
Subprog CALCUL_MONTANTS()

Local Decimal MTDES
Local Integer STAT

  If ( [M:LOF0]CPY <> "" )
    # Montant HT devise société -----------------
    Call CONVERT3([M:LOF1]CUR, GCOUDEV, GCOUDEV, [M:LOF1]CURTYP, [M:LOF1]DATVCR, [M:LOF1]AMTNOTCUR, MTDES, [M:LOF1]RATCUR, STAT) From CPTSUB
    If ( STAT = 0 )
      Call GET_MNT_ARRONDI (MTDES, GCOUDEV, MTDES) From GLOBIENS
      [M:LOF1]AMTNOTCPY = MTDES
      Affzo [M:LOF1]AMTNOTCPY
    Else
      GMESSAGE = mess(2,GML_MSGLOF,1) : # Erreur lors de la conversion en devise société
      GERR     = 1
      mkstat   = 2
      End
    Endif

    # Montant TVA facturée -----------------
    If ( [M:LOF1]FLGVATFCR <> G_OUI )
      Call GET_MNT_ARRONDI ([M:LOF1]AMTNOTCUR * [M:LOF1]RATVAT / 100, [M:LOF1]CUR, MTDES) From GLOBIENS
      [M:LOF1]AMTVATCUR = MTDES
      Affzo [M:LOF1]AMTVATCUR
    Else
      If ( [M:LOF1]AMTVATCUR = 0 )
        [M:LOF1]RATVAT = 0
        Affzo [M:LOF1]RATVAT
      Endif
    Endif
    # Devise société
    Call CONVERT3([M:LOF1]CUR, GCOUDEV, GCOUDEV, [M:LOF1]CURTYP, [M:LOF1]DATVCR, [M:LOF1]AMTVATCUR, MTDES, [M:LOF1]RATCUR, STAT) From CPTSUB
    If ( STAT = 0 )
      Call GET_MNT_ARRONDI (MTDES, GCOUDEV, MTDES) From GLOBIENS
      [M:LOF1]AMTVATCPY = MTDES
      Affzo [M:LOF1]AMTVATCPY
    Else
      GMESSAGE = mess(2,GML_MSGLOF,1) : # Erreur lors de la conversion en devise société
      GERR     = 1
      mkstat   = 2
      End
    Endif

    # Montant TVA récupérée -----------------
    If ( [M:LOF1]FLGRECFVR <> G_OUI )
      Call GET_MNT_ARRONDI ([M:LOF1]AMTVATCUR * [M:LOF1]RATVATREC / 100, [M:LOF1]CUR, MTDES) From GLOBIENS
      [M:LOF1]AMTVATRCUR = MTDES
      Affzo [M:LOF1]AMTVATRCUR
    Else
      If ( [M:LOF1]AMTVATRCUR = 0 )
        [M:LOF1]RATVATREC = 0
        Affzo [M:LOF1]RATVATREC
      Endif
    Endif
    # Devise société
    Call CONVERT3([M:LOF1]CUR, GCOUDEV, GCOUDEV, [M:LOF1]CURTYP, [M:LOF1]DATVCR, [M:LOF1]AMTVATRCUR, MTDES, [M:LOF1]RATCUR, STAT) From CPTSUB
    If ( STAT = 0 )
      Call GET_MNT_ARRONDI (MTDES, GCOUDEV, MTDES) From GLOBIENS
      [M:LOF1]AMTVATRCPY = MTDES
      Affzo [M:LOF1]AMTVATRCPY
    Else
      GMESSAGE = mess(2,GML_MSGLOF,1) : # Erreur lors de la conversion en devise société
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
End

################################################################################
########################################
Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()

Local Integer OK
  If ( VALEUR = "" )   : End : Endif  : # Le fournisseur n'est pas obligatoire

  Read [BPR]BPR0=VALEUR
  If (fstat)
    GMESSAGE = mess(49,GML_MSGLOF,1) : # Fournisseur inexistant
    GERR     = 1
    mkstat   = 2
    End
  Else
    If ( [F:BPR]CUR <> "" )
      If ( [M:LOF1]AMTNOTCUR > 0  and  [M:LOF1]CUR <> [F:BPR]CUR )
        # Si un montant existe déjà demander confirmation pour changer la devise
        # La devise du Fourn. est <> de celle de la dépense et un mont. est renseigné. Voulez-vous l'effacer ?
        Call OUINON (mess(50,GML_MSGLOF,1), OK) From GESECRAN :
        If ( OK = G_OUI )
          [M:LOF1]AMTNOTCUR = 0
          Affzo [M:LOF1]AMTNOTCUR
        Endif
      Endif
      [M:LOF1]CUR    = [F:BPR]CUR
      [M:LOF1]DEVTRA = [F:BPR]CUR : # GLE 04/02/05 FICHE 28282
      Affzo [M:LOF1]CUR,DEVTRA    : # GLE 04/02/05 FICHE 28282
      Call AM_CUR([M:LOF1]CUR)
    Elsif ( [M:LOF1]CUR = "" )
      [M:LOF1]CUR = GCOUDEV
      Affzo [M:LOF1]CUR
      Call AM_CUR([M:LOF1]CUR)
    Endif
  Endif
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer ERROR
Local Char UNITE
Local Char WCFAMILLE

  # Si la liaison dépense/Bien n'est pas faite, on peut modifier l'unité.
  If ( [M:LOF1]FLGLIKAAS = G_NON )
    # Alimente par défaut l'unité si elle est renseignée dans l'article
    UNITE = func GLOBIENS.GET_UNITE_ARTICLE (VALEUR)
    If ( UNITE <> "" )
      [M:LOF1]UOM = UNITE
      Affzo [M:LOF1]UOM
    Endif
  Endif

  # Si la liaison dépense/Bien n'est pas faite, on peut modifier la famille .
  If ( [M:LOF1]FLGLIKAAS = G_NON )
    # Alimente par défaut la famille si elle est renseignée dans l'article
    WCFAMILLE = func GLOBIENS.GET_FAMILLE_ARTICLE (VALEUR, [M:FPC]LEG)
    If ( WCFAMILLE <> "" )
      [M:LOF1]ACGGRP= WCFAMILLE
      Affzo [M:LOF1]ACGGRP
    Endif
  Endif
End

########################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
  # Recalcul tout
  [M:LOF1]CUR = VALEUR
  Call CDVCAL([M:LOF1]RATCUR, VALEUR, GCOUDEV, [M:LOF0]CPY, [M:LOF1]CURTYP, [M:LOF1]DATVCR) From TRTDIV
  Affzo [M:LOF1]RATCUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog AP_CUR(VALEUR)
Variable Char    VALEUR()
  If ( VALEUR = GCNXCURCPF and GREP <> "" )
    [M:LOF1]CURTYP = 1
    Affzo [M:LOF1]CURTYP
  Endif
  If ( VALEUR = GCNXCURCPF )
    Diszo [M:LOF1]CURTYP
  Else
    Actzo [M:LOF1]CURTYP
  Endif
End

########################################
Subprog AM_CURTYP(VALEUR)
Variable Integer VALEUR
  Call CDVCAL([M:LOF1]RATCUR, [M:LOF1]CUR, GCOUDEV, [M:LOF0]CPY, VALEUR, [M:LOF1]DATVCR) From TRTDIV
  Affzo [M:LOF1]RATCUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog AM_DATVCR(VALEUR)
Variable Date    VALEUR
  # Alimente la date d'imputation si cette dernière est vide.
  If ( [M:LOF1]DATIMP = [0/0/0] )
    [M:LOF1]DATIMP = VALEUR
    Affzo [M:LOF1]DATIMP
  Endif
End

########################################
Subprog AM_RATCUR(VALEUR)
Variable Decimal    VALEUR()

  # Recalcul tout
  [M:LOF1]RATCUR = VALEUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog AM_TYPVCR(VALEUR)
Variable Integer VALEUR

  # Si type facture = Avoir on passe les montants en négatifs
  # Sinon on passe les montants en positifs.
  If ( VALEUR = GVML_TDAVOIR )
    If ( [M:LOF1]AMTNOTCUR > 0 )
      [M:LOF1]AMTNOTCUR = -[M:LOF1]AMTNOTCUR
    Endif
    If ( [M:LOF1]AMTVATCUR > 0 )
      [M:LOF1]AMTVATCUR = -[M:LOF1]AMTVATCUR
    Endif
    If ( [M:LOF1]AMTVATRCUR > 0 )
      [M:LOF1]AMTVATRCUR = -[M:LOF1]AMTVATRCUR
    Endif
    Affzo [M:LOF1]AMTNOTCUR
    # Recalcul tout
    Call CALCUL_MONTANTS()
  Elsif ( VALEUR <> GVML_TDFACT )
    If ( [M:LOF1]AMTNOTCUR < 0 )
      [M:LOF1]AMTNOTCUR = -[M:LOF1]AMTNOTCUR
    Endif
    If ( [M:LOF1]AMTVATCUR < 0 )
      [M:LOF1]AMTVATCUR = -[M:LOF1]AMTVATCUR
    Endif
    If ( [M:LOF1]AMTVATRCUR < 0 )
      [M:LOF1]AMTVATRCUR = -[M:LOF1]AMTVATRCUR
    Endif
    Affzo [M:LOF1]AMTNOTCUR
    # Recalcul tout
    Call CALCUL_MONTANTS()
  Endif
End

########################################
Subprog D_CPMCREORI(VALEUR)
Variable Integer VALEUR

  VALEUR = 0
End

########################################
Subprog AM_AMTNOTCUR(VALEUR)
Variable Decimal VALEUR

  # Si le montant est négatif et que le "Type facture" est autre que "Avoir", ou
  # si le montant est positif et que le "Type facture" est "Avoir",
  # -> on change le montant saisi de signe
  If (( VALEUR < 0 ) and (( [M:LOF1]TYPVCR <> GVML_TDAVOIR ) and ( [M:LOF1]TYPVCR <> GVML_TDFACT )))
& or (( VALEUR > 0 ) and ( [M:LOF1]TYPVCR =  GVML_TDAVOIR ))
    VALEUR *= -1
  Endif

  [M]AMTNOTCUR = VALEUR
  Affzo [M:LOF1]AMTNOTCUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog AP_AMTNOTCUR(VALEUR)
Variable Decimal VALEUR

Local Integer OK

  # ... et si le montant est à zéro on met un message de confirmation
  If ( (GREP<>"C" and GREP<>"D" and VALEUR=0 and VALEUR<>[M:LOF1]AMTNOTCUR ) or
&      ((GREP="C" or GREP="D") and VALEUR=0) )
    Call AVERTIR (mess(18,GML_MSGLOF,1), OK) From GESECRAN : # Le montant de la dépense est à zéro
    If OK = 1
      GERR   = 1
      mkstat = 2
      End
    Endif
  Endif
End

########################################
Subprog AM_RATVAT(VALEUR)
Variable Decimal VALEUR
  # Recalcul tout
  [M:LOF1]RATVAT = VALEUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog AM_FLGVATFCR(VALEUR)
Variable Integer VALEUR

End

########################################
Subprog AV_AMTVATCUR(VALEUR)
Variable Decimal VALEUR
  If ( [M:LOF1]FLGVATFCR = G_OUI )
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]AMTVATCUR With "FORCAGE"
    Else
      Chgstl [M:LOF1]AMTVATCUR With "TFORCAGE"
    Endif
  Else
    Chgstl [M:LOF1]AMTVATCUR With ""
  Endif
End

########################################
Subprog AS_AMTVATCUR(VALEUR)
Variable Decimal VALEUR
  If ([M:LOF1]FLGVATFCR <> G_OUI or
&     func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATCUR", 0) = G_NON )
    GBOUT1 = ""
  Endif
End

########################################
Subprog AM_AMTVATCUR(VALEUR)
Variable Decimal VALEUR

  # Le montant TVA doit être du même signe que le montant HT
  If ([M:LOF1]AMTNOTCUR > 0 and VALEUR < 0) or ([M:LOF1]AMTNOTCUR < 0 and VALEUR > 0)
    If (GIMPORT)
      # En import, on adapte automatiquement le signe du montant de TVA en fonction de celui du montant HT
      VALEUR = VALEUR * -1
    Else
      GMESSAGE = mess(5,GML_MSGLOF,1) : # Le montant TVA doit être du même signe que le montant HT
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif

  # On contrôle que le ABS(montant TVA) ne soit pas supérieur ABS(montant HT)
  If ( abs (VALEUR) > abs([M:LOF1]AMTNOTCUR) )
    GMESSAGE = mess(3,GML_MSGLOF,1) : # Le montant TVA ne peux excéder le montant HT
    GERR     = 1
    mkstat   = 2
    End
  Endif

  # Gestion du code forçage
  If ( G_DEFORCE_LOF and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE_LOF = 0
  Else
    [M:LOF1]FLGVATFCR = G_OUI:  Affzo [M:LOF1]FLGVATFCR
    Affzo [M:LOF1]AMTVATCUR
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]AMTVATCUR With "FORCAGE"
    Else
      Chgstl [M:LOF1]AMTVATCUR With "TFORCAGE"
    Endif
  Endif

  # Recalcul tout
  [M:LOF1]AMTVATCUR = VALEUR
  Call CALCUL_MONTANTS()

End

########################################
Subprog B1_AMTVATCUR(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:LOF1]FLGVATFCR = G_NON : Affzo [M:LOF1]FLGVATFCR

  # Recalcul tout
  [M:LOF1]AMTVATCUR = VALEUR
  Call CALCUL_MONTANTS()
  VALEUR= [M:LOF1]AMTVATCUR

  # Gestion du code forçage
  G_DEFORCE_LOF = 1
  Chgstl [M:LOF1]AMTVATCUR With ""
  Affzo [M:LOF1]AMTVATCUR

  mkstat = 99
End


########################################
Subprog AM_RATVATREC(VALEUR)
Variable Decimal VALEUR

  # Recalcul tout
  [M:LOF1]RATVATREC = VALEUR
  If ( VALEUR = 100 )
    [M:LOF1]FLGRECFVR = G_NON
    Affzo [M:LOF1]FLGRECFVR
  Endif
  Call CALCUL_MONTANTS()
End

########################################
Subprog AP_RATVATREC(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR = 100 )
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGRECFVR", 0) = G_OUI   : Diszo [M:LOF1]FLGRECFVR : Endif
  Else
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]FLGRECFVR", 0) = G_NON   : Actzo [M:LOF1]FLGRECFVR : Endif
  Endif
End

########################################
Subprog AM_FLGRECFVR(VALEUR)
Variable Integer VALEUR

End

########################################
Subprog AV_AMTVATRCUR(VALEUR)
Variable Decimal VALEUR
  If ([M:LOF1]FLGRECFVR = G_OUI )
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]AMTVATRCUR With "FORCAGE"
    Else
      Chgstl [M:LOF1]AMTVATRCUR With "TFORCAGE"
    Endif
  Else
    Chgstl [M:LOF1]AMTVATRCUR With ""
  Endif

  ##*FQ98116 Si origine saisie = création directe : montant TVA récupérée accessible si taux <> 100 et <> 0
  If ( [M:LOF2]CPMCREORI = 0 )
    If ( [M:LOF1]RATVATREC = 100 or [M:LOF1]RATVATREC = 0.)
       Diszo [M:LOF1]AMTVATRCUR
    Else
       Actzo [M:LOF1]AMTVATRCUR
    Endif
  Else
    # #*FQ98116 sinon montant TVA récupérée non modifiable
    Diszo [M:LOF1]AMTVATRCUR
  Endif
End

########################################
Subprog AS_AMTVATRCUR(VALEUR)
Variable Decimal VALEUR

  If ([M:LOF1]FLGRECFVR <> G_OUI or
&     func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]AMTVATRCUR", 0) = G_NON )
    GBOUT1 = ""
  Endif

End

########################################
Subprog AM_AMTVATRCUR(VALEUR)
Variable Decimal VALEUR

  # Le montant TVA réc doit être du même signe que le montant TVA
  If ([M:LOF1]AMTVATCUR > 0 and VALEUR < 0) or ([M:LOF1]AMTVATCUR < 0 and VALEUR > 0)
    If (GIMPORT)
      # En import, on adapte automatiquement le signe du montant de TVA récupérée du montant de TVA
      VALEUR = VALEUR * -1
    Else
      GMESSAGE = mess(6,GML_MSGLOF,1) : # Le montant TVA récupérée doit être du même signe que le montant TVA
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif

  # On contrôle que le ABS(montant TVA rec) ne soit pas supérieur ABS(montant TVA)
  If ( abs(VALEUR) > abs ([M:LOF1]AMTVATCUR) )
    GMESSAGE = mess(4,GML_MSGLOF,1) : # Le montant TVA récupérée ne peux éxcéder le montant TVA
    GERR     = 1
    mkstat   = 2
    End
  Endif

  # Gestion du code forçage
  If ( G_DEFORCE_LOF and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE_LOF = 0
  Else
    [M:LOF1]FLGRECFVR = G_OUI:  Affzo [M:LOF1]FLGRECFVR
    Affzo [M:LOF1]AMTVATRCUR
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]AMTVATRCUR With "FORCAGE"
    Else
      Chgstl [M:LOF1]AMTVATRCUR With "TFORCAGE"
    Endif
  Endif

  # Recalcul tout
  [M:LOF1]AMTVATRCUR = VALEUR
  Call CALCUL_MONTANTS()
End

########################################
Subprog B1_AMTVATRCUR(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:LOF1]FLGRECFVR = G_NON : Affzo [M:LOF1]FLGRECFVR

  # Recalcul tout
  [M:LOF1]AMTVATRCUR = VALEUR
  Call CALCUL_MONTANTS()
  VALEUR = [M:LOF1]AMTVATRCUR

  # Gestion du code forçage
  G_DEFORCE_LOF = 1
  Chgstl [M:LOF1]AMTVATRCUR With ""
  Affzo [M:LOF1]AMTVATRCUR
  mkstat = 99
End


########################################
Subprog AM_DATIMP(VALEUR)
Variable Date    VALEUR

Local Integer OK

  # La date d'imputation ne peut être inférieure à la date de facture
  If ( VALEUR < [M:LOF1]DATVCR )
    GMESSAGE = mess(7,GML_MSGLOF,1) : # La date d'imputation ne peut être inférieure à la date de facture
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AP_DATIMP(VALEUR)
Variable Date    VALEUR

Local Integer OK

  # message d'avertissement si date imputation < date debut exercice comptable et fiscal.
  # pas de message si pas de contexte comptable et fiscal
  If ( VALEUR <> [M:LOF1]DATIMP or GREP = "C" or GREP = "D" )
    If ( GCNXPROCPF = G_OUI )
      If ( VALEUR < GDEBEXECPF )
        # La date d'imputation est inférieure à la date de début d'exercice du contexte comptable et fiscal
        # OK à 2 provoque l'émission d'une trace plutôt que d'une erreur dans AVERTIR en batch
        If (GIMPORT)   : OK = 2 : Endif
        Call AVERTIR (mess(8,GML_MSGLOF,1), OK) From GESECRAN
        If ( OK = 1 )
          GERR   = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
End

######################################################################################
## Réactivation préalable des postes du menu local,car quand alimente cette zone via
## les association (c'est-à-dire avant d'être positionné sur le champ lui-même), les
## postes de menus locaux qui ont été désactivés dans des traitements(sortie,éclatement
## d'un bien...) interfèrent avec ceux du menu local associé au champ  GACACN.
## Comme l'on fait un appel à C_GACACN de W1LOF1 dans le TRTASSO, on détecte que le
## GMENLOC(valeur déterminée du n° de poste) est égal à 1 ==> erreur(mkstat=1)
######################################################################################
Subprog AV_GACACN(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_NIENCOU) = 0
  GMENLOC(GVML_NIENSER) = 0
  GMENLOC(GVML_NICHARG) = 0

End
########################################
Subprog AS_GACACN(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_NIAUTRE) = 1

End
######################################################################################
## Réactivation préalable des postes du menu local,car quand alimente cette zone via
## les association (c'est-à-dire avant d'être positionné sur le champ lui-même), les
## postes de menus locaux qui ont été désactivés dans des traitements(sortie,éclatement
## d'un bien...) interfèrent avec ceux du menu local associé au champ IASACN.
## Comme l'on fait un appel à C_GACACN de W1LOF1 dans le TRTASSO, on détecte que le
## GMENLOC(valeur déterminée du n° de poste) est égal à 1 ==> erreur(mkstat=1)
######################################################################################
Subprog AV_IASACN(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_NIENCOU) = 0
  GMENLOC(GVML_NIENSER) = 0
  GMENLOC(GVML_NICHARG) = 0

End
######################################################################################
Subprog AS_IASACN(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_NIAUTRE) = 1

End

########################################
Subprog AM_GAC(VALEUR)
Variable Char    VALEUR()

  # Vérifier le concordance du compte saisi avec la nature PCG

  # Alimente automatiquement de compte PCG origine lorsque le compte PCG est saisissable
  [M:LOF1]GACORI = VALEUR
  Affzo [M:LOF1]GACORI
  If ( dim([M:LOF1]ZGACORI) > 0 )   : Affzo [M:LOF1]ZGACORI : Endif
End

######################################## FQ73862
Subprog AV_IASACC(VALEUR)
Variable Char    VALEUR()
  # Si le champ est invisible, il faut mettre GFMTACC à vide pour que le traitement généré Superviseur
  # ne fasse pas réapparaitre le champ. Voir W2LOF1 étiquette $AV_IASACC.
  If varmode([M]IASACC)=3 : GFMTACC = "" : Endif
End

########################################
Subprog AM_IASACC(VALEUR)
Variable Char    VALEUR()
  # Vérifier le concordance du compte saisi avec la nature IAS
  # Alimente automatiquement de compte IAS origine lorsque le compte IAS est saisissable
  [M:LOF1]IASACCORI = VALEUR
  Affzo [M:LOF1]IASACCORI
  If ( dim([M:LOF1]ZIASACCORI) > 0 )   : Affzo [M:LOF1]ZIASACCORI : Endif
End

######################################## FQ73862
Subprog AV_IASACCORI(VALEUR)
Variable Char    VALEUR()
  # Si le champ est invisible, il faut mettre GFMTACC à vide pour que le traitement généré Superviseur
  # ne fasse pas réapparaitre le champ. Voir W2LOF1 étiquette $AV_IASACC.
  If varmode([M]IASACCORI)=3 : GFMTACC = "" : Endif
End
################################################################################
# ECRAN : LOF2
################################################################################
########################################
Subprog AM_ACT(VALEUR)
Variable Char    VALEUR()

Local Integer ERROR
Local Decimal TXTVAREC

  [M:LOF1]FLGRECFVR = G_NON:  Affzo [M:LOF1]FLGRECFVR
  TXTVAREC = [M:LOF1]RATVATREC
  #-1 -----------------------
  If ( VALEUR <> "" )
    Read [F:SEA]SEA0=[M:LOF0]CPY;VALEUR
    If (fstat)
      # Secteur d'activité invalide
      GERR=1 : mkstat = 2 :  GMESSAGE = mess(636,GML_MSGFAS,1) :  End
    Endif
    [M:LOF1]ASJCOE = [F:SEA]ASJCOE : Affzo [M:LOF1]ASJCOE
    Call AM_ASJCOE ([M:LOF1]ASJCOE)
    If ([M:LOF1]TAXCOEFLG <> G_OUI)
      [M:LOF1]TAXCOE = [F:SEA]TAXCOEINI : Affzo [M:LOF1]TAXCOE
      Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
      Affzo [M:LOF1]DEDCOE

      TXTVAREC = [M:LOF1]DEDCOE * 100.
    Endif
  #-1 -----------------------
  Else
    If ( [M:LOF1]ASJCOE = 0. )
      [M:LOF1]TAXCOEFLG = 2
      [M:LOF1]TAXCOE    = 0. : Affzo [M:LOF1]TAXCOE
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_OUI   : Diszo [M:LOF1]TAXCOE : Endif
      Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
      Affzo [M:LOF1]DEDCOE
      TXTVAREC = [M:LOF1]DEDCOE * 100.
    Endif
    If ( [M:LOF1]TAXCOEFLG <> G_OUI )
      [M:LOF1]TAXCOE = 1. : Affzo [M:LOF1]TAXCOE
      Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
      Affzo [M:LOF1]DEDCOE
      TXTVAREC = [M:LOF1]DEDCOE * 100.
    Endif
  Endif
  #-1 -----------------------
  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    [M:LOF1]FLGRECFVR = G_NON # FQ98116
    Call CALCUL_MONTANTS()
  Endif
  #--------------------------
  If (VALEUR <> "")
    [M:LOF1]SACDES = [F:SEA]SACDES : Affzo [M:LOF1]SACDES
  Else
    Effzo [M:LOF1]SACDES
  Endif

End

######################################################################################
Subprog AM_PLNINV(VALEUR)
Variable Char    VALEUR()

Local Char LCODE

  If ( VALEUR <> "" )
    LCODE=VALEUR
    If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif   # tables diverses
    Read[ADI]CODE=GTD_INVPLN;LCODE
    If (fstat = 0)
      If ( G_ACTGRT = G_OUI )
         If ( [M:LOF2]FLGGRA = G_OUI and [F:ADI]A1 <> [M:LOF0]CPY )
           GERR=1
           GMESSAGE = mess(63,GML_MSGLOF,1) :
           mkstat = 2 : End
         Else
           If  ( [M:LOF2]FLGGRA = G_NON and [F:ADI]A1 <> [M:LOF0]CPY and [F:ADI]A1<> "" )
             GERR=1
             # le projet doit être rattaché à la société de la dépense ou n'être rattaché à aucune société
             GMESSAGE = mess(64,GML_MSGLOF,1) :
             mkstat = 2 : End
           Endif
         Endif
      Endif
    Endif

  Endif

End

########################################
Subprog AM_ACGGRP(VALEUR)
Variable Char    VALEUR()

Local Integer FLGASS

  # activation de toutes les rubriques pouvant être déterminées par association
  # avant l'application de l'association.
  If ( [M:LOF1]ACGGRP <> "" )
    Call  RUBRIQUES_DETERMINEES(GVML_OMDEPEN, [M:LOF0]CPY, G_NON) From TRTASSO
  Endif

  # on applique l'association si la famille est renseignée
  If ( VALEUR <> "" )
    #Call GERER_ASSOCIATION(VALEUR,"FAM","LOF", 0, GBOITE,FLGASS) From TRTASSO
    Call GERER_ASSOCIATION(VALEUR,"FAM","LOF", 0, "OLOF",FLGASS) From TRTASSO
  Endif

Local Decimal TXTVAREC
  Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
  TXTVAREC = [M:LOF1]DEDCOE * 100.
  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    Call CALCUL_MONTANTS()
  Endif

  Gosub RUBRIQUES_IAS
  Affzo [M:LOF1]
  Affzo [M:LOF2]
End

######################################################################
Subprog C_ACGGRP(VALEUR)
Variable Char    VALEUR()
#  Read [ADI]CODE = GTD_FAMCPT;VALEUR
  Read [FAM]FAM0 = VALEUR
  If fstat=0
    If   !(func TRTFAS.IS_LEG_ACGGRP_OK([M:FPC]LEG, VALEUR))
      GERR= 1: GMESSAGE = mess(683,GML_MSGFAS,1)-" "-[M:FPC]LEG
      mkstat = 2 : End
    Endif
  Endif
End

######################################################################################
Subprog C_IASACN(VALEUR)
Variable Integer VALEUR

  If ( (VALEUR = GVML_NIENCOU and [M:LOF1]GACACN = GVML_NIENSER) or
&      (VALEUR = GVML_NIENSER and [M:LOF1]GACACN = GVML_NIENCOU)   )
    # L'imputation PCG/IFRS en cours/en service ou en service/en cours est incorrecte
    GMESSAGE = mess(54,GML_MSGLOF,1)
    GERR     = 1 :  mkstat   = 2
    End
  Endif

End

########################################
Subprog AV_AMTGRA(VALEUR)
Variable Decimal VALEUR

  If ( G_ACTGRT = G_OUI )
    If ([M:LOF2]FLGAMTGRA = G_OUI )
      If ( GBROWS = 0 )
        Chgstl [M:LOF2]AMTGRA With "FORCAGE"
      Else
        Chgstl [M:LOF2]AMTGRA With "TFORCAGE"
      Endif
    Else
      Chgstl [M:LOF2]AMTGRA With ""
    Endif
  Endif
End

########################################
Subprog AS_AMTGRA(VALEUR)
Variable Decimal VALEUR

  If ( G_ACTGRT = G_OUI )
    # Gestion du code forçage
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]AMTGRA", 0) = G_NON )
      GBOUT1 = ""
      GBOUT2 = ""
    Else
      If ( [M:LOF2]FLGAMTGRA <> G_OUI )
        GBOUT1 = ""
      Else
        GBOUT2 = ""
      Endif
    Endif
  Endif
End

########################################
Subprog AM_AMTGRA(VALEUR)
Variable Decimal VALEUR

  If ( G_ACTGRT = G_OUI )
    # Gestion du code forçage
    If (G_DEFORCE_LOF and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
      G_DEFORCE_LOF = 0
    Else
      [M:LOF2]FLGAMTGRA = G_OUI:  Affzo [M:LOF2]FLGAMTGRA
      Affzo [M:LOF2]AMTGRA
      If ( GBROWS = 0 )
        Chgstl [M:LOF2]AMTGRA With "FORCAGE"
      Else
        Chgstl [M:LOF2]AMTGRA With "TFORCAGE"
      Endif
    Endif
  Endif
End

########################################
Subprog B1_AMTGRA(VALEUR)
Variable Decimal VALEUR

  If ( G_ACTGRT = G_OUI )
    # Gestion du code forçage
    [M:LOF2]FLGAMTGRA = G_NON : Affzo [M:LOF2]FLGAMTGRA

    Raz [M:LOF2]AMTGRA
    Raz VALEUR

    # Gestion du code forçage
    G_DEFORCE_LOF = 1
    Chgstl [M:LOF2]AMTGRA With ""
    Affzo [M:LOF2]AMTGRA

    mkstat=99
  Endif
End

########################################
Subprog B2_AMTGRA(VALEUR)
Variable Decimal VALEUR

  If ( G_ACTGRT = G_OUI )
    # Gestion du code forçage
    [M:LOF2]FLGAMTGRA = G_OUI : Affzo [M:LOF2]FLGAMTGRA
    Affzo [M:LOF2]AMTGRA
    If ( GBROWS = 0 )
      Chgstl [M:LOF2]AMTGRA With "FORCAGE"
    Else
      Chgstl [M:LOF2]AMTGRA With "TFORCAGE"
    Endif
  Endif

End
########################################
Subprog AM_FLGGRA(VALEUR)
Variable Integer VALEUR


If G_ACTGRT = G_OUI
  If VALEUR = G_OUI
    Actzo [M:LOF2]AMTGRA
    Actzo [M:LOF2]FLGAMTGRA
    If [M:LOF2]PLNINV <> ""
       If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif   # tables diverses
       Read[ADI]CODE=GTD_INVPLN;[M:LOF2]PLNINV
       If fstat = 0
         If ([F:ADI]A1 <> [M:LOF0]CPY)
            # Le projet doit être rattaché à la société de la dépense
            GERR=1 :   GMESSAGE = mess(63,GML_MSGLOF,1)
            zonsui = "[M:LOF2]PLNINV"
        Endif
      Endif
      #Une subvention "en cours" doit exister pour le projet
       If clalev([F:GRT])=0  : Local File GRANTS      [GRT] : Endif
       Filter[GRT] Where (INVPLN= [M:LOF2]PLNINV)
       Read [GRT] First
       If fstat
          [M:LOF2]FLGGRA = G_NON : Affzo [M:LOF2]FLGGRA
          #* Une subvention "en cours" doit exister pour le projet
          GERR=1 :  GMESSAGE = mess(69,GML_MSGLOF,1) :
          mkstat=2 : End
       Endif
    Else
       [M:LOF2]FLGGRA = G_NON : Affzo [M:LOF2]FLGGRA
       #*Le projet est obligatoire si la dépense est subventionnée
       GERR=1 :  GMESSAGE = mess(68,GML_MSGLOF,1) :
       mkstat=2 : End
    Endif
  Else
      If  [M:LOF2]FLGGRA = G_OUI
        [M:LOF2]FLGAMTGRA = G_NON : Diszo [M:LOF2]FLGAMTGRA
         Effzo [M:LOF2]AMTGRA : Diszo [M:LOF2]AMTGRA
      Endif
  Endif
Endif


End

#######################################
Subprog AS_FLGAMTGRA(VALEUR)
Variable Integer VALEUR

  If ( G_ACTGRT = G_OUI )
    If ( VALEUR = G_NON )
      Diszo[M:LOF2]AMTGRA  : Affzo[M:LOF2]AMTGRA
    Endif
  Endif

End
########################################
Subprog AM_FLGAMTGRA(VALEUR)
Variable Integer VALEUR

  If ( G_ACTGRT = G_OUI )
    If ( VALEUR = G_OUI )
      Actzo[M:LOF2]AMTGRA  : Affzo[M:LOF2]AMTGRA
    Else
      Diszo[M:LOF2]AMTGRA  : Affzo[M:LOF2]AMTGRA
    Endif
  Endif

End

########################################
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()

  If ( VALEUR <> "" )
    # FQ95579 : affectation de clesup à 1
    Call CTRL_AUT_OBJ("DSP", VALEUR, "1", [M:LOF0]FCY, date$) From GLOBIENS
  Endif
End

########################################
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
  Local Integer N_CCE

  For N_CCE = 0 To GOPTCANA-1
    If ( VALEUR = "" )
      # Si une clé de répartition est remise à blanc, il faut dégriser les axes
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_CCE) = G_NON   : Actzo [M:LOF2]CCE(N_CCE) : Endif
    Else
      # Si une clé de répartition est saisie, il faut griser les axes
      [M:LOF2]CCE(N_CCE) = ""
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF2]CCE", N_CCE) = G_OUI   : Diszo [M:LOF2]CCE(N_CCE) : Endif
    Endif
  Next N_CCE

End
#######################################
Subprog AV_ASJCOE(VALEUR)
Variable Decimal VALEUR


  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:LOF0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" ) # FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" )
    Chgfmt [M:LOF1]ASJCOE With "-N+:3.2#"
  Else
    Chgfmt [M:LOF1]ASJCOE With "N+:3.2#"
  Endif
End

#######################################
Subprog AM_ASJCOE(VALEUR)
Variable Decimal VALEUR


Local Decimal TXTVAREC

  If ( VALEUR < 0. or VALEUR > 1. )
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  If ( VALEUR = 0. and [M:LOF1]ACT = "")
    # Si le coefficient d'assujettissement est à 0
    # alors le coefficient de taxation est à 0
    [M:LOF1]TAXCOEFLG = 2
    [M:LOF1]TAXCOE    = 0. : Affzo [M:LOF1]TAXCOE : Diszo [M:LOF1]TAXCOE
  Endif

  If ( VALEUR <> 0. and [M:LOF1]ACT = "" )
    [M:LOF1]TAXCOEFLG = 1
    [M:LOF1]TAXCOE    = 1. : Affzo [M:LOF1]TAXCOE : Actzo [M:LOF1]TAXCOE
  Endif

  Call TVA_COE_DEDUCTION ( VALEUR, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
  TXTVAREC = [M:LOF1]DEDCOE * 100.

  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    [M:LOF1]FLGRECFVR = G_NON # FQ98116
    Call CALCUL_MONTANTS()
  Endif
End

#######################################
Subprog AV_TAXCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:LOF0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" ) FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" )
    Chgfmt [M:LOF1]TAXCOE With "-N+:3.2#"
  Else
    Chgfmt [M:LOF1]TAXCOE With "N+:3.2#"
  Endif

  If ([M:LOF1]TAXCOEFLG = G_OUI )
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]TAXCOE With "FORCAGE"
    Else
      Chgstl [M:LOF1]TAXCOE With "TFORCAGE"
    Endif
  Else
    Chgstl [M:LOF1]TAXCOE With ""
  Endif
End

#######################################
Subprog AS_TAXCOE(VALEUR)
Variable Decimal VALEUR


  If ([M:LOF1]TAXCOEFLG <> G_OUI) or (func GLOBIENS.IS_CHAMP_ENABLE ("[M:LOF1]TAXCOE", 0) = G_NON)
& or ([M:LOF1]ACT="") : # FQ98116
    GBOUT1 = ""
  Endif
End

#######################################
Subprog AM_TAXCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC

  If ( VALEUR < 0. or VALEUR > 1. )
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE_LOF and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE_LOF = 0
  Else
    [M:LOF1]TAXCOEFLG = G_OUI:  Affzo [M:LOF1]TAXCOEFLG
    Affzo [M:LOF1]TAXCOE
    If ( GBROWS = 0 )
      Chgstl [M:LOF1]TAXCOE With "FORCAGE"
    Else
      Chgstl [M:LOF1]TAXCOE With "TFORCAGE"
    Endif
  Endif

  Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, VALEUR, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
  TXTVAREC = [M:LOF1]DEDCOE * 100.

  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    [M:LOF1]FLGRECFVR = G_NON # FQ98116
    Call CALCUL_MONTANTS()
  Endif
End

#######################################
Subprog B1_TAXCOE(VALEUR)
Variable Decimal VALEUR


Local Decimal TXTVAREC

  TXTVAREC = [M:LOF1]RATVATREC
  [M:LOF1]TAXCOE = VALEUR
  # Gestion du code forçage
  [M:LOF1]TAXCOEFLG = G_NON : Affzo [M:LOF1]TAXCOEFLG
  #-1 -----------------------
  If ( [M:LOF1]ACT <> "" )
    Read [F:SEA]SEA0=[M:LOF0]CPY;[M:LOF1]ACT
    [M:LOF1]TAXCOE = [F:SEA]TAXCOEINI
    Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
    TXTVAREC = [M:LOF1]DEDCOE * 100.
  #-1 -----------------------
  Else
    [M:LOF1]TAXCOE = 1.
    Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, [M:LOF1]ADMCOE, [M:LOF1]DEDCOE ) From TRTFAS
    TXTVAREC = [M:LOF1]DEDCOE * 100.
  Endif
  #-1 -----------------------
  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    # Gestion du code forçage
    [M:LOF1]TAXCOEFLG = G_NON : Affzo [M:LOF1]TAXCOEFLG

    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    Call CALCUL_MONTANTS()
  Endif
  VALEUR = [M:LOF1]TAXCOE

  # Gestion du code forçage
  G_DEFORCE_LOF = 1
  Chgstl [M:LOF1]TAXCOE With ""
  Affzo [M:LOF1]TAXCOE
  mkstat = 99
End

#######################################
Subprog AV_ADMCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:LOF0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" ) FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:LOF0]CPY) = "FRA" )
    Chgfmt [M:LOF1]ADMCOE With "-N+:3.2#"
  Else
    Chgfmt [M:LOF1]ADMCOE With "N+:3.2#"
  Endif
End

#######################################
Subprog AM_ADMCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC

  If ( VALEUR < 0. or VALEUR > 1. )
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  Call TVA_COE_DEDUCTION ( [M:LOF1]ASJCOE, [M:LOF1]TAXCOE, VALEUR, [M:LOF1]DEDCOE ) From TRTFAS
  TXTVAREC = [M:LOF1]DEDCOE * 100.

  If ( [M:LOF1]RATVATREC <> TXTVAREC )
    [M:LOF1]RATVATREC = TXTVAREC : Affzo [M:LOF1]RATVATREC
    [M:LOF1]FLGRECFVR = G_NON # FQ98116
    Call CALCUL_MONTANTS()
  Endif
End

#######################################
Subprog AV_FLGVAL(VALEUR)
Variable Integer VALEUR


  If ( VALEUR = G_OUI )
    Chgfmt [M:LOF1]FLGVAL With "-LO:1X"
  Else
    Chgfmt [M:LOF1]FLGVAL With "LO:1X"
  Endif
End


#######################################
Subprog C_PLNINV(VALEUR)
Variable Char    VALEUR()

  If (G_ACTGRT = G_OUI)
    If ([M:LOF2]FLGGRA = G_OUI)
      If (VALEUR <> "")
        # Une subvention "en cours" doit exister pour le projet
        If clalev([F:GRT])=0  : Local File GRANTS      [GRT] : Endif
        Filter[GRT] Where (INVPLN= VALEUR)
        Read [GRT] First
        If (fstat)
          [M:LOF2]FLGGRA    = G_NON    : Affzo [M:LOF2]FLGGRA
          [M:LOF2]FLGAMTGRA = G_NON    : Affzo [M:LOF2]FLGAMTGRA
          # Une subvention "en cours" doit exister pour le projet
          GERR=1 :  GMESSAGE = mess(69,GML_MSGLOF,1) : mkstat= 2 : End
        Endif
      Else
        # Le projet est obligatoire si la dépense est subventionnée
        GERR=1 :  GMESSAGE = mess(70,GML_MSGLOF,1) : mkstat=2 : End
      Endif
    Endif
  Endif
End

#######################################
Subprog CL_ICOINV(VALEUR)
Variable Char    VALEUR()

  If CPMCREORI = 1
    Call OBJET("PIH",[F:LOF]CODLOF,"") From GOBJET
  Elsif CPMCREORI = 2
    Call OBJET("BIS",[F:LOF]CODLOF,"") From GOBJET
  Elsif CPMCREORI = 3
    Call OBJET("GAS",[F:LOF]CODLOF,[F:LOF]TYPORI) From GOBJET
  Elsif CPMCREORI = 4   #FQ68023 Loupe sur Règlement ou pièce
    Call OBJET("PAY",[F:LOF]BPRVCR," ")  From GOBJET
  Elsif CPMCREORI = 6   #FQ102691 Loupe sur Sortie de stock
    Call OBJET("SMO",[F:LOF]CODLOF,"20")  From GOBJET
  Endif
End

#######################################
Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()
  Gosub CONDITIONNE_IAS_LOF1 From TRTFAS
End

