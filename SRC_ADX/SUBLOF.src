######################################################################################
##Fq-79815 Activation et contrôle des sections analytiques
######################################################################################
Subprog AS_NBRCCE

  # Pour récupèree les sections par défautce il faut être en  Création/Duplication de dépense
 # .... et ne pas avoir renseigné de clé répartition
 If (GREP <> "C"  and GREP <> "D" ) or  [M:LOF2]DSP <> ""
    End
 Endif

  Local Integer AXE

  ##Fq-79815 Section analytiques par défaut
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
     [M:LOF2]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
     If [M:LOF1]GAC <> ""
        WACC = [M:LOF1]GAC
     Else
        WACC = [M:LOF1]IASACC
     Endif
     If [M:LOF2]CCE(I_DIE-1)= ""
        #ne fonctionne pas si le compte n'est pas SUIVI en analytique et teste le compte en 1er
        # qqsoit le paramétrage dans la table CACCEDEF
        #Call INICCE([M:LOF2]CCE(I_DIE-1), [M:FPC]DIE(I_DIE-1),LED(GLEDTYPANA),WACC,"FXDASSETS") From CPTINI
        Call INISEC([M:LOF2]CCE(I_DIE-1),"FXDASSETS",[M:FPC]DIE(I_DIE-1)) From SUBCDE
     Endif
     Affzo [M:LOF2]DIE(I_DIE-1) : Affzo [M:LOF2]ZDIE(I_DIE-1)
     Affzo [M:LOF2]CCE(I_DIE-1) : Affzo [M:LOF2]ZCCE(I_DIE-1)
  Next I_DIE
  Affzo [M:LOF2]NBRCCE
  #Fq-79815

   For AXE=1 To G_NBAXE
     Actzo [M:LOF2]CCE(AXE-1)
     Affzo [M:LOF2]CCE(AXE-1)
   Next

End
#######################################
Subprog C_NBRCCE

# adxgtb= 0 = On est encore en saisie dans le tableau
# adxgtb= 1 = Sortie invalide du tableau ==> pas la peine de faire ces contrôles car il y a au préalable des anomalies à corriger
# adxgtb= 2 = Sortie valide du tableau ==>  on fait des contrôles complémentaires sur chaque ligne du tableau
If adxgtb=2
   If clalev([F:CAZ])=0  : Local File CAAUZ   [CAZ]  : Endif
   If clalev([F:CCE])=0  : Local File CACCE   [CCE]  : Endif  : # Sections
   If clalev([F:CCE2])=0 : Local File CACCE   [CCE2] : Endif  : # Sections

   For AXE=1 To G_NBAXE
      If [M]CCE(AXE-1)<>""
         nolign=AXE
         # Contrôle interdiction section/section
         Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
         For I=AXE+1 To G_NBAXE
            If [M]CCE(I-1)<>""
               Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
               Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
               If !fstat
                  # Interdit avec la section
                  GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
                  mkstat = 1 : Break 2
               Endif
            Endif
         Next
      Endif
   Next
Endif

End

