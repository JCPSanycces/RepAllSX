#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet DPZ
Raz [V]GPILOBJ, [V]GBIDC1, [v]GBIDC2, [v]GPILNAV, [V]GNBMASKOUV
Call OBJET("DPZ",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "FIN"          : Gosub FIN
#-------------------------------------------------------------------------------
 When "EFFMASK"      : Gosub INIDAT
 When "AFFMASK"      : Gosub INIDAT : Gosub GRISE_MAT
 When "RAZCRE"       : Gosub INIDAT
 When "LIENS"        : Gosub LIENS
 When "DEGRISE"      : Gosub GRISE_MAT
#-------------------------------------------------------------------------------
 When "FILTRE"       : Gosub FILTRE
 When "EXEACT"       : Gosub EXEACT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "STATUT"       : Gosub STATUT
 When "AVANT_VERROU" : [L]SYMBOLE="DPI"+right$([L]SYMBOLE,4)
#-------------------------------------------------------------------------------
 When "INIMOD"       : Read [ID] =
 When "MODIF"        : Gosub MODIF
Endcase
Return

################################################################################
#
# GOBJET1
#
################################################################################

$OUVRE
Local Date     DATDEB, DATFIN
Local Libelle  DEFILE
Local Shortint I55O, I55N
Local Integer  CHRONO
Local Char     SYMBOLE2(50)

If [L]CLE1>"" | !instr(1,[V]GUSRAUZ(1),"1") : [L]DEFILE=4 : # par période
Else                                          [L]DEFILE=3 : # par service
Endif

# Tunnel à partir du moniteur workflow
If clalev([M:AWP0]) & [F:AWS]VALCTX1>""
 [L]CHRONO=val([F:AWS]VALCTX1)
Else
#todo
# EXN (note de frais  PAYE not exist in ERP)
# Call LITDAT("dpz",[L]DATDEB,[L]DATFIN) From SUBEXS
Endif
Return

#-------------------------------------------------------------------------------
$SETBOUT
If [V]GREP>"" : [L]CHAINE=ctrans([L]CHAINE,"P","") : Endif
If !instr(1,[V]GUSRAUZ(1),"2") | [L]REP="M" | ![L]CLECUR | [V]GHISTO=1
 [L]CHAINE=ctrans([L]CHAINE,"V","")
Endif
If instr(1,[V]GUSRAUZ(1),"1") : [L]CHMEN+=ctrans("134",num$([L]DEFILE),"") : Endif
If instr(1,[V]GUSRAUZ(1),"2") & [L]CLECUR & [L]REP=""
 If ![V]GHISTO : [L]CHMEN+="2" : Endif
 [L]CHMEN+="56"
Endif
Return

#-------------------------------------------------------------------------------
$FIN
If !clalev([M:AWP0])
#todo
# EXN (note de frais  PAYE not exist in ERP)
# Call SAVDAT("dpz",[M:DPZ1]DATDEB,[M:DPZ1]DATFIN) From SUBEXS
Endif
Return

################################################################################
#
# Initialisation des masques
#
################################################################################

$LIENS
Gosub INIDAT
Gosub CHARGE
Return

################################################################################
#
# Evénements
#
################################################################################

$FILTRE
If [V]GUSRACS<>2
 [L]FILTSUP="find([ID]SRV,[V]GAUTSRV(1..[V]GNBSERV))<>0"
Endif
Return

#-------------------------------------------------------------------------------
$EXEACT
If [L]DEFILE<>4 : Return : Endif

Link [DPZ] With [DPI]DPI0=REFNUM;DEM As [DPZK]
I=1
J=dim([M:DPZ1]NBLIG)
Case [L]BOUT
When "0"
 Filter [DPZK] Where REFNUM=[M:DPZ1]REFNUM Order By Key CLE=[DPI]CREDAT
 For [DPZK]CLE(1)
  If I : [L]DATDEB=[F:DPI]CREDAT : I=0 : Endif
  For [DPZK]CLE : J-=1 : Next
  If J>0 : [L]DATFIN=[F:DPI]CREDAT : Else Break : Endif
 Next

When "9"
 Filter [DPZK] Where REFNUM=[M:DPZ1]REFNUM Order By Key CLE=[DPI]CREDAT Desc
 For [DPZK]CLE(1)
  If I : [L]DATFIN=[F:DPI]CREDAT : I=0 : Endif
  For [DPZK]CLE : J-=1 : Next
  If J>0 : [L]DATDEB=[F:DPI]CREDAT : Else Break : Endif
 Next

When "<"
 [L]SAVDAT=[L]DATFIN
 [L]DATFIN=[L]DATDEB-1
 Filter [DPZK] Where REFNUM=[M:DPZ1]REFNUM & CREDAT<=[L]DATFIN
&       Order By Key CLE=[DPI]CREDAT Desc
 For [DPZK]CLE(1)
  I=0
  For [DPZK]CLE : J-=1 : Next
  If J>0 : [L]DATDEB=[F:DPI]CREDAT : Else Break : Endif
 Next
 If [L]DATFIN<[L]DATDEB : [L]DATDEB=[L]DATFIN+1 : [L]DATFIN=[L]SAVDAT : Endif

When ">"
 [L]SAVDAT=[L]DATDEB
 [L]DATDEB=[L]DATFIN+1
 Filter [DPZK] Where REFNUM=[M:DPZ1]REFNUM & CREDAT>=[L]DATDEB
&       Order By Key CLE=[DPI]CREDAT
 For [DPZK]CLE(1)
  I=0
  For [DPZK]CLE : J-=1 : Next
  If J>0 : [L]DATFIN=[F:DPI]CREDAT : Else Break : Endif
 Next
 If [L]DATFIN<[L]DATDEB : [L]DATFIN=[L]DATDEB-1 : [L]DATDEB=[L]SAVDAT : Endif

When Default
 Return
Endcase

If I
 [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
 [V]GERR    =1
 [L]OK      =0
 Return
Endif

Gosub INIDAT
Gosub CHARGE
Affzo [DPZ1] 20, 30
[L]OK=0
Return

#-------------------------------------------------------------------------------
$EXEBOUT
Case [L]BOUT
When "B" : # Période
 [L]DATDEB=[M:DPZ1]DATDEB
 [L]DATFIN=[M:DPZ1]DATFIN
 Gosub CHARGE
 Affzo [DPZ1] 20, 30

When "V"
 [L]OK=2
 Call OUINON(mess(27,10709,1),[L]OK) From GESECRAN : # Confirmation du visa
 If [L]OK=2
  [L]SYMBOLE2="ID "+[M:DPZ1]REFNUM
  Lock =[L]SYMBOLE2
  If fstat
   Call QUILOCKE([L]SYMBOLE2,1) From DIVPAYE
   [V]GERR=1
   [L]OK  =0
   Return
  Endif

  Call DEBTRANS From GLOCK
  Gosub TR_VISA
  If [V]GOK=1
   For I=0 To [M:DPZ1]NBLIG-1
    If [M:DPZ1]STA(I)=2 : [M:DPZ1]STA(I)=3 : Endif
   Next
   Affzo [DPZ1] STA
  Endif
  Unlock =[L]SYMBOLE2
 Endif
Endcase
Return

#-------------------------------------------------------------------------------
$STATUT
Case [L]BOUT
When "2"
 Call SIGNATURE("DPI",num$([M:DPZ1]DEM(nolign-1)),[M:DPZ1]REFNUM,[L]OK) From GOBJACT
 If [L]OK
  Gosub CHARGE
  Affzo [DPZ1] 20,30
 Endif
When "5"
 Call HISTOSIG("DPI",num$([M:DPZ1]DEM(nolign-1)),[M:DPZ1]REFNUM) From GOBJACT
When "6"
 Call CIRCUITSIG("DPI",num$([M:DPZ1]DEM(nolign-1)),[M:DPZ1]REFNUM) From GOBJACT
When "1", "3"
 [L]DEFILE=val([L]BOUT)
 [L]INDGES=[L]DEFILE
When "4"
 [L]DEFILE=val([L]BOUT)
Endcase
Return

################################################################################
#
# Transactions
#
################################################################################

$MODIF
For [DPI]DPI0 Where REFNUM=[M:DPZ1]REFNUM & CREDAT>=[M:DPZ1]DATDEB
&                 & CREDAT<=[M:DPZ1]DATFIN
 nolign=find([F:DPI]DEM,[M:DPZ1]DEM(0..[M:DPZ1]NBLIG-1))
 [F:DPI]      =[M:DPZ1]
 [F:DPI]UPDUSR=[v]GUSER
 [F:DPI]UPDDAT=date$
 [F:DPI]UPDTIM=time

 Rewrite [DPI] Curr
 If fstat=1
  [V]GOK  =-1
  [V]GLOCK="$DPERSOID"-[F:DPI]REFNUM-num$([F:DPI]DEM)
  Break
 Elsif fstat
  [V]GOK=0
   Call FSTA("DPI") From GLOCK
  Break
 Endif
Next
If [V]GOK<1 : Return : Endif
Return

#-------------------------------------------------------------------------------
$TR_VISA
[V]GOK=1
Trbegin [DPI]
 For [DPI]DPI0 Where REFNUM=[M:DPZ1]REFNUM & CREDAT>=[M:DPZ1]DATDEB
&                  & CREDAT<=[M:DPZ1]DATFIN & STA=2
  Gosub VISA From SUBDPI
  If [v]GOK<1 : Break : Endif
 Next
 If [V]GOK<1 : Rollback : Return : Endif

 Update [DPI] Where REFNUM=[M:DPZ1]REFNUM & CREDAT>=[M:DPZ1]DATDEB
&                 & CREDAT<=[M:DPZ1]DATFIN & STA=2
&              With STA   =3
&                 , UPDDAT=date$
&                 , UPDTIM=time
&                 , UPDUSR=[v]GUSER
 If fstat
  [V]GOK=0
  Call RSTA("DPI",[M:DPZ1]REFNUM) From GLOCK
  Rollback
  Return
 Endif
Commit
Return

################################################################################
#
# Routines
#
################################################################################

$CHARGE
If [M:DPZ1]NBLIG : Dela 0, [M:DPZ1]NBLIG [M:DPZ1]NBLIG : [M:DPZ1]NBLIG=0 : Endif

nolign=0
Link [DPZ] With [DPI]DPI0=REFNUM;DEM
&             , [ATZ]DICO=ZON
&             , [ATX]NUMERO=[V]GLANGUE;[ATZ]NOLONG
&             , [ATY]CODTYP=[ATZ]CODTYP
&            As [LNK]
&         Where left$([ATZ]CODFIC,5)="EMPLO"
&  Order By Key CLE=[DPI]CREDAT;[DPI]DEM;ABRFIC;OLDLIG;NEWLIG;[ATZ]NUMLIG;IND

For [LNK]CLE Where REFNUM=[M:DPZ1]REFNUM & [DPI]CREDAT>=[M:DPZ1]DATDEB
&                & [DPI]CREDAT<=[M:DPZ1]DATFIN & ZON>""
 If nolign=dim([M:DPZ1]CREDAT)
  I=find([F:DPI]CREDAT,[M:DPZ1]CREDAT)-1
  If I>=0
   Dela I,nolign-I [M:DPZ1]NBLIG
   nolign        =I
   [M:DPZ1]DATFIN=[M:DPZ1]CREDAT(I-1)
  Endif
  Call ERREUR(mess(26,100,1)) From GESECRAN   # Tableau plein
  Break
 Endif

 nolign                +=1
 [M:DPZ1]               =[F:DPI]
 [M:DPZ1]STA0(nolign-1) =[F:DPI]STA
 Case [F:DPZ]ZON
 When "EXSVAR"
  If find([F:DPZ]OLDVAL,"#10553","#10554")
   [L]I55O                 =val(right$([F:DPZ]OLDVAL,2))
   [M:DPZ1]OLDVAL(nolign-1)=mess([L]I55O-200,200,1)
  Else
   [M:DPZ1]OLDVAL(nolign-1)=[F:DPZ]OLDVAL
  Endif
  If find([F:DPZ]NEWVAL,"#10553","#10554")
   [L]I55N                 =val(right$([F:DPZ]NEWVAL,2))
   [M:DPZ1]NEWVAL(nolign-1)=mess([L]I55N-200,200,1)
  Else
   [M:DPZ1]NEWVAL(nolign-1)=[F:DPZ]NEWVAL
  Endif
 When "EXSAMT"
  If [L]I55O : [M:DPZ1]OLDVAL(nolign-1)=mess(val([F:DPZ]OLDVAL),[L]I55O,1) : [L]I55O=0
  Else         [M:DPZ1]OLDVAL(nolign-1)=[F:DPZ]OLDVAL
  Endif
  If [L]I55N : [M:DPZ1]NEWVAL(nolign-1)=mess(val([F:DPZ]NEWVAL),[L]I55N,1) : [L]I55N=0
  Else         [M:DPZ1]NEWVAL(nolign-1)=[F:DPZ]NEWVAL
  Endif
 When Default
  Case [F:ATY]TYPTYP
  When 1
   [M:DPZ1]OLDVAL(nolign-1)=mess(val([F:DPZ]OLDVAL),[F:ATZ]NOLIB,1)
   [M:DPZ1]NEWVAL(nolign-1)=mess(val([F:DPZ]NEWVAL),[F:ATZ]NOLIB,1)
  When 2,3,4,5,6,7
   [M:DPZ1]OLDVAL(nolign-1)=[F:DPZ]OLDVAL
   [M:DPZ1]NEWVAL(nolign-1)=[F:DPZ]NEWVAL
  When 8
   If [F:DPZ]OLDVAL>""
    [M:DPZ1]OLDVAL(nolign-1)=format$([V]GFMD,gdat$([F:DPZ]OLDVAL))
   Endif
   If [F:DPZ]NEWVAL>""
    [M:DPZ1]NEWVAL(nolign-1)=format$([V]GFMD,gdat$([F:DPZ]NEWVAL))
   Endif
  Endcase
 Endcase
 [M:DPZ1]LIB(nolign-1)  =[F:ATX]TEXTE
 If ![F:DPZ]OLDLIG & [F:DPZ]NEWLIG
  [M:DPZ1]ACT(nolign-1) =3 : # Création
  [M:DPZ1]LIB(nolign-1)+="("+num$([F:DPZ]NEWLIG)+")"
 Elsif [F:DPZ]OLDLIG & ![F:DPZ]NEWLIG
  [M:DPZ1]ACT(nolign-1) =2 : # Suppression
  [M:DPZ1]LIB(nolign-1)+="("+num$([F:DPZ]OLDLIG)+")"
 Else
  [M:DPZ1]ACT(nolign-1)=1 : # Modification
  If    [F:ATZ]DIME>1 : [M:DPZ1]LIB(nolign-1)+="("+num$([F:DPZ]IND+1)+")"
  Elsif [F:DPZ]NEWLIG : [M:DPZ1]LIB(nolign-1)+="("+num$([F:DPZ]NEWLIG)+")"
  Endif
 Endif
Next
[M:DPZ1]NBLIG=nolign

[M:DPZ1]NAMSRN=toupper([F:ID]NAM)-tolower([F:ID]SRN)
Return

#-------------------------------------------------------------------------------
$GRISE_MAT
If !instr(1,[V]GUSRAUZ(1),"1") : Grizo [DPZ1] REFNUM : Endif
Return

#-------------------------------------------------------------------------------
$INIDAT
[M:DPZ1]DATDEB=[L]DATDEB
[M:DPZ1]DATFIN=[L]DATFIN
Return

################################################################################
#
# Etiquettes de l'écran DPZ1
#
################################################################################

########################################
Subprog C_NBLIG

If nolign & ([M:DPZ1]STA0(nolign-1)>2 | !instr(1,[V]GUSRAUZ(1),"2")) & status=75
 [V]GMESSAGE=mess(9,123,1) : # Modification impossible
 mkstat     =2
Endif

End

########################################
Subprog AS_STA(VALEUR)
Variable Integer VALEUR

[V]GMENLOC(1)=1
[V]GMENLOC(5)=1
[V]GMENLOC(6)=1
[V]GMENLOC(7)=1

End

########################################
Subprog AM_STA(VALEUR)
Variable Integer VALEUR

Local Shortint I, J

For I=0 To [M:DPZ1]NBLIG-1
 If [M:DPZ1]DEM(I)=[M:DPZ1]DEM(nolign-1)
  [M:DPZ1]STA(I)=[L]VALEUR
  J             =1
 Endif
Next

If J : Affzo [DPZ1] STA : Endif

End
