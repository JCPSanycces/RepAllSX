#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTIVEN04 - Utilitaire d'initialisation de [F:SDH]PRHFCY   Module Vente #
##########################################################################
Call MAJ_UTIVEN04
End

Subprog MAJ_UTIVEN04
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIVEN04 : Process for sales ") From LECFIC

Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIVEN04(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIVEN04(DOSSIER)
Value Char DOSSIER

Call ECR_TIME("Sales Delivery Process : Update SDELIVERY") From DOSSUB
Call ECR_TRACE("Initialization Receipt facility (PRHFCY)",0) From GESECRAN

If filinfo(filpath("FIL","BPDLVCUST","fde",DOSSIER),0) < 0     End Endif
If filinfo(filpath("FIL","SDELIVERY","fde",DOSSIER),0) < 0     End Endif

If clalev([F:BPD])=0  Local File =DOSSIER+".BPDLVCUST" [BPD] : Endif
If clalev([F:SDH])=0  Local File =DOSSIER+".SDELIVERY" [SDH] : Endif

Local Char     CLE1(GLONVCR)
Local Integer  NBENR
Local Shortint STOP
Local Integer  COMPTEUR

Raz CLE1, NBENR
Trbegin [SDH]

$BOUCLE_SDH
Raz COMPTEUR
Raz STOP

For [SDH]SDH1 Where BETFCY=2 & PRHFCY="" & SDHNUM>CLE1 With Nohint
    If [F:BPD]BPCNUM<>[F:SDH]BPCORD | [F:BPD]BPAADD<>[F:SDH]BPAADD
        Read [BPD]BPD0=[F:SDH]BPCORD;[F:SDH]BPAADD
        If fstat Raz [F:BPD]RCPFCY Endif
    Endif
    If [F:BPD]RCPFCY<>""  
        Readlock [SDH] Curr
        If fstat 
            Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM-", Error ="-num$(fstat),1) From GESECRAN
        Else
           [F:SDH]PRHFCY=[F:BPD]RCPFCY
           NBENR+=1
#           Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM-[F:SDH]BPCORD-num$([F:SDH]BPAADD)-[F:SDH]PRHFCY,0) From GESECRAN
           Rewrite [SDH]
           If fstat
               Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
           Else
               COMPTEUR+=1    
           Endif
        Endif
    Endif 
    If COMPTEUR>GMAXUPDTRS 
        Commit
        Trbegin [SDH]
        CLE1=[F:SDH]SDHNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SDH : Endif
Commit

Call ECR_TRACE("UTIVEN04 : Processed records number :"-num$(NBENR),0) From GESECRAN

Close Local File [SDH]
Close Local File [BPD]

End

#######################################################################
# Pour exécution depuis dosmaj14 (validation dossier) A conserver ?????
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(4) <> 2 : End : Endif
Call EXE_UTIVEN04(APPLI)
End


