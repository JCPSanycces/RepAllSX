#<AdxTL>@(#)6.0.0.0 $Revision$ Librairies générateur de doc
###################################################################
# AGENLIBA
# Ensemble de procédures appelées depuis tous les programmes du générateur de DOC.
#
#  Prog splitté en deux car on a atteint a la limte
#  AGENLIB et AGENLIBA (à partir de la v7)
################################################
$INIT_DIA
Local Char    WLANREF(250)
Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
[M:DIA]LANREF=WLANREF
If [M:DIA]LANREF="" : [M:DIA]LANREF=GLANDEF : Endif

Local Char    WLANTRA(250)
Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
[M:DIA]LAN=WLANTRA
If [M:DIA]LAN="" : [M:DIA]LAN=GLANGUE : Endif
If [M:DIA]LAN=[M:DIA]LANREF : [M:DIA]LAN="ENG" : Endif

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return

################################################
$CONTROLE
If [M:DIA]LAN=[M:DIA]LANREF
        GERR = 1
        GMESSAGE = mess(54,176,1)
        SAI=1
Endif
Return

######################################################################################
#
# Sous-programmes divers de gestion de doc (extraits de AGENADO)
#
######################################################################################

# Ecriture de l'en-tête
$ECR_HEADER
  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
  ## On a ces 2 variables qui indique sur quel type d'aide on est
  ##ECR_HEADER_DOC=1 ou ECR_HEADER_DOC=0
  ##ECR_HEADER_FLD=0    ECR_HEADER_FLD=1
  Wrseq '<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" '; Using [DOC]
  Wrseq '"http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">' Using [DOC]
  Wrseq '<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en">' Using [DOC]
  Wrseq '<head>' Using [DOC]
  Wrseq '  <meta http-equiv="content-type" content="text/html; charset=utf-8">' Using [DOC]
  Wrseq '  <meta name="author" content="ADONIX">' Using [DOC]
  Wrseq '  <meta name="keywords" content="'+KEYWORDS+'">' Using [DOC]
  Wrseq '  <meta name="description" content="'+TITRED+'">' Using [DOC]
  # JPGA 28/03/2013 EXI-97343-1 : Ajout meda module afin de pouvoir faire des recherches dans le HTML sur le module
  If GPRODUIT=-1 : # Si on est sur une Application SUPERVISEUR : on met superviseur comme Module, sinon on met le bon MODULE
    Wrseq '  <meta name="module" content="'+func AGENADO.MST(1,97)+'">'       Using [DOC]
  Else
    Wrseq '  <meta name="module" content="'+func AGENADO.MST(MODULED,14)+'">' Using [DOC]
  Endif
  Wrseq '  <meta name="robots" content="all">' Using [DOC]
  Wrseq '  <title>'+TITRED+'</title>' Using [DOC]
  Wrseq '  <script type="text/javascript"></script>' Using [DOC]

  Wrseq '  <link rel=Stylesheet type="text/css" media=all href="ADXHelp_main.css">' Using [DOC]

  Wrseq '  <script type="text/javascript" src="help1.js"></script>' Using [DOC]
  Wrseq '</head>' Using [DOC]
  Wrseq '<body id="adx-help">' Using [DOC]
  Wrseq '  <div id="container">' Using [DOC]

# Sauf si on génère les menus ou les tables / menus locaux, types, on génère la barre de menus principale
  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
  #If find([ADO]TYP,"APM","ATB","AML","ATY")=0
  #VPO 19/06/08 39766 ajout ATD: différences de tables
  If ECR_HEADER_DOC=1 & ECR_HEADER_FLD=0 & find([ADO]TYP,"APM","ATD","ATB","AML","ATY")=0


# Barre de menus principale, obtenue par rupture sur les premiers niveaux de rang
    Wrseq '    <div id="linkList">' Using [DOC]
    Wrseq '      <div id="linkList2">' Using [DOC]
    Wrseq '        <div id="lmainmenu">' Using [DOC]
    Wrseq '          <ul>' Using [DOC]

# On filtre certains paragraphes qui ne soivent pas apparaitre dans les menus
    For [AD1]ADO0(4) Where [AD1]LAN=[ADO]LAN and [AD1]TYP=[ADO]TYP and [AD1]COD=[ADO]COD
      Gosub FIL_PAR            From AGENLIBA
      Gosub REINIT_HEADER_PRQ  From AGENLIBA
      If II
          Wrseq '            <li>' Using [DOC]
          If [AD1]PAR="INC"
              Call ANCRE(NOMANCR,[AD1]PAR,I_LEV,I_SUBLEV) From AGENDOCA
              Wrseq '              <a href="#'+NOMANCR+'">'+[ADO2]TIT+'</a>' Using [DOC]
          Else
              Call ANCRE(NOMANCR,[AD1]PAR,[AD1]LEV,[AD1]SUBLEV) From AGENDOCA
              Call TITANC([AD1]PAR,[AD1]TIT) From AGENDOCA
              Wrseq '              <a href="#'+NOMANCR+'">'+[AD1]TIT+'</a>' Using [DOC]
          Endif
          Wrseq '            </li>' Using [DOC]
      Endif
    Next
    Wrseq '          </ul>' Using [DOC]
    Wrseq '        </div>' Using [DOC]
    Wrseq '      </div>' Using [DOC]
    Wrseq '    </div>' Using [DOC]
  Endif
  FIRST_BLK=1
  BLK_MAT=0
  Wrseq '    <div id="topNavBar">' Using [DOC]
  Wrseq '      <div id="topNBHome">' Using [DOC]
  #VPO 16/11/07 bug 44103
  If [ADO]TYP="PA"
  Wrseq '        <p><span><a href="ADXPATCH.htm"><img src="aide-bump-home.gif"></a></span></p>' Using [DOC]
  Else
  Wrseq '        <p><span><a href="../index.htm"><img src="aide-bump-home.gif"></a></span></p>' Using [DOC]
  Endif
  Wrseq '      </div>' Using [DOC]

# Ecriture de la pile des menus dans la barre de navigation HAUTE
  Gosub ECR_NAV  From AGENLIBA

  #VPO 07/11/08 47899 ajout ouverture/fermeture livre (Version non V5)
  If IF_DOCV5=0
  Wrseq '        <body onload="ActivAllshowhide()" >' Using [DOC]
  Wrseq '          <TABLE id="topTabOpen" border=0 cellPadding=0 cellSpacing=0 cols=4 >' Using [DOC]
  Wrseq '            <TD width="90%"></TD>' Using [DOC]
  Wrseq '            <TD id=tabOpen ><a href="javascript:;" ><img src="bkopen.gif" alt="'+func AGENADO.MST(281,142)+'" onClick="allshowhide('+"'block'"+')"></a></TD>' Using [DOC]
  Wrseq '            <TD id=tabClose ><a href="javascript:;" ><img src="bkclose.gif" alt="'+func AGENADO.MST(282,142)+'" onClick="allshowhide('+"'none'"+')"></a></TD>' Using [DOC]
  Wrseq '            <TD width="10%"></TD>' Using [DOC]
  Wrseq '          </TABLE>' Using [DOC]
  Wrseq '        </body>' Using [DOC]
  Endif

  Wrseq '      </div>' Using [DOC]

# Ecriture du début de la zone de liens dans le titre
  Wrseq '      <div id="topNBLinks">' Using [DOC]
  Wrseq '        <p>' Using [DOC]

# Ecriture du lien vers la doc ergonomie
  If LIENSGEN<>""
    # "Ergonomie"

    # JPGA-BUG-94339-20/11/2013 : Pour la V7, Modification du lien sur les pages Ergonomies
    #Wrseq '          <a href="./ERGO_'+LIENSGEN+'.htm">'+func AGENADO.MST(110,142)+'</a>&nbsp;|&nbsp;' Using [DOC]
    Wrseq '          <a href="'+func AGENLIBA.LIEN_ERGONOMIE+'">'+func AGENADO.MST(110,142)+'</a>&nbsp;|&nbsp;' Using [DOC]
  Endif

# Ecriture du lien vers la rubrique "Mes notes" (à revoir plus tard)
  # "Mes notes"
  # Wrseq '          <a href="../local/'+NOMDOC+'.htm">'+func AGENADO.MST(112,142)+'</a>&nbsp;|&nbsp;'  Using [DOC]

# Ecriture du lien vers l'index général
  #VPO 16/11/07 bug 44103
  If [ADO]TYP="PA"
  Wrseq '          <a href="ADXPATCH.htm">'+func AGENADO.MST(109,142)+'</a>' Using [DOC] : # "Sommaire"
  Else
  Wrseq '          <a href="../index.htm">'+func AGENADO.MST(109,142)+'</a>' Using [DOC] : # "Sommaire"
  Endif

# Ecriture de la fin de la zone de liens
  Wrseq '        </p>' Using [DOC]
  Wrseq '      </div>' Using [DOC]

# Ecriture du titre
  Wrseq '    </div>' Using [DOC]
  Wrseq '    <div id="pageHeader">' Using [DOC]
  Wrseq '      <h1 class="g1"><span>'+TITRED+'</span></h1>' Using [DOC]
  Wrseq '      <h2 class="g1"><span></span></h2>' Using [DOC]
  Wrseq '    </div>' Using [DOC]

Return

# Détermination du titre de la doc
$RECHTIT
  Case [ADO]TYP
    When 'AFC' : Read [AFC]CODINT=[ADO]COD
                 If fstat
                     TITRED=func AGENADO.MST(75,123)-[ADO]COD : # Fonction
                 Else
                     TITRED=func AGENADO.RDT([AFC]LIBMENU)
                 Endif
    When 'ACT' : Read [ACT]ACTION=[ADO]COD
                 If fstat=0
                     TITRED=func AGENADO.MST(30,124)-'<i>'+func AGENADO.RDT([ACT]INTITA)+'</i>'
                 Else
                     TITRED=func AGENADO.MST(30,124)
                 Endif
    When 'ACV' : Read [ACV]CODACT=[ADO]COD
                 If fstat=0
                     TITRED=func AGENADO.MST(14,115)-'<i>'+func AGENADO.RDT([ACV]LIBACT)+'</i>'
                 Else
                     TITRED=func AGENADO.MST(14,115)
                 Endif
    When 'PLA' : #VPO 07/01/08 evol 45065
                 #VPO 07/07/08 evol 48427 ajout par="LNK"
                 RECH=left$([ADO]COD,3)
                 If [ADO]COD="PLA_0"
                    TITRED=func AGENADO.RDX("ATABDIV","LNGDES","910",RECH)
                 Elsif [ADO]PAR="LNK"
                    TITRED=[ADO]TIT
                 Else
                    Read [AOB]ABREV=RECH
                    If fstat=0
                        TITRED=func AGENADO.RDT([AOB]LIBEL)
                    Else
                        TITRED=""
                    Endif
                 Endif

    When Default : TITRED=""
  Endcase
Return

#
# Ecriture de la fin du fichier
#
$FIN_FIC

# On ne fait pas de génération dans le cas des types de doc AD et FI
  If ([ADO]TYP="FI") or (NOMDOC="") : Return : Endif
  If FIRST_BLK=0
      Wrseq '      </div>' Using [DOC]
  Endif
  Wrseq '    </div>' Using [DOC]

$FIN_FIC1
  Wrseq '    <div id="footer">' Using [DOC]
  Wrseq '       &copy; &nbsp; <a href="http://www.'; Using [DOC]
  #JPGA 14/12/2009 BUG-60794 : Pour le copyright : prendre datesyst au lieu de date$ pour avoir la date de la boite de connexion
  If dim([L]COPYRIGHT)<0
    Local Date COPYRIGHT
    [L]COPYRIGHT=datesyst
  Endif
  #VPO 29/10/07 BUG43788 : ajout 1999-année du jour de génération
  Case [V]COD_LAN
    When "FRA" : Wrseq 'sage.fr" title="Site Sage">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "POR" : Wrseq 'sage.pt" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "SPA" : Wrseq 'sage.es" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "GER" : Wrseq 'sage.de" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "BRI" : Wrseq 'sage.co.uk" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "CHI" : Wrseq 'sagechina.cn" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "ENG" : Wrseq 'sagenorthamerica.com" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When "ITA" : Wrseq 'formula.it" title="Official Formula site">Formula site</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
    When Default : Wrseq 'sage.com" title="Official Sage site">Sage</a>'-'1999-'+format$("D:YYYY",[L]COPYRIGHT); Using [DOC]
  Endcase
  Wrseq '' Using [DOC]

  Wrseq '    </div>' Using [DOC]
  Wrseq '  </div>' Using [DOC]
  Wrseq '  <div id="extraDiv1"><span></span></div>' Using [DOC]
  Wrseq '  <div id="extraDiv2"><span></span></div>' Using [DOC]
  Wrseq '  <div id="extraDiv3"><span></span></div>' Using [DOC]
  Wrseq '</body>' Using [DOC]
  Wrseq '</html>' Using [DOC]

  Openo Using [DOC]
  Gosub FICOUV_COPIE_D
Return


#
# Sous-programmes génériques d'écriture de paragraphes
#

# En-tête de paragraphe, incluant éventuellement les champs d'un écran
# Le paragraphe (classe [ADO]) est censé être en ligne
# Seuls les paramètres différents de la classe [ADO] sont passés

Subprog ENT_PAR(PAR,STY,TIT,INCLUT_TEXTE,BOT_PAR)
Value Char PAR(),TIT()
Value Shortint STY
Variable Integer INCLUT_TEXTE
Value Char BOT_PAR()

Local Char MSK(GLONAMK)

# Variables utilisées pour analyser les masques
Local Integer NBT,NBB
Local Char TITRE_BLOC(40)(1..16)
Local Shortint TYPE_BLOC(1..16)
# Variables pour gérer les blocs d'un onglet
Local Decimal ONG_BLOC(1..16),ONG_NO_2(1..16)

Local Integer NB_CHAMP, BLOC_CHAMP(250), UNAFF_CHAMP(250)
Local Char CHAMPS_ECR(GLONAWA)(1..250),
&     HELP_CHAMP(10)(1..250),
&     INT_CHAMP(type([ATX]TEXTE)-10)(1..250),TYPE_CHAMP(GLONATY)(1..250)
Local Char DEBTXT(100)

# Variables utilisées pour les aides sur champ
Local Integer KK,KKBD,KKBE,LL, HELP_EXIST, HELP_LAST

# Buffer pour aide sur champ : sa taille limite la taille de l'aide sur champ
Local Char AIDECHP(250)(1..100)

# Numéro d'onglet
Local Integer NONG

# Valeurs par défaut
  If STY=0  : STY=[ADO]STY : Endif
  MSK=[ADO]MSK

# On recherche si les champs d'un masque doivent être inclus
# Si la fenêtre est de type VT, on n'intègre pas l'aide sur champ (modification au 15/09/2006)
  JJ=1
  If [AWI]FVT<>2
    If MSK<>"" and PAR<>""
        Raz JJ
        Read [AMK]CODMSK=MSK
    Elsif pat(PAR,"ON*")<>0 or PAR="ENT" : # On l'inclut d'office pour les onglets (sécurité)
        Raz JJ
        NONG=pat(PAR,"ON*")*((right$(PAR,3)>="A")*(ascii(right$(PAR,3))-55)+val(right$(PAR,3)))
        If NONG=0
            Read [AMK]CODMSK=[AWI]MSKENT
        Else
            Read [AMK]CODMSK=[AWI]NOMMSK(NONG-1)
        Endif
    Endif
  Endif

  If STY=-1 : # Bouton
      Wrseq '        <table>' Using [DOC]
      Wrseq '          <tr>' Using [DOC]
      Wrseq '            <td valign="top">' Using [DOC] : #VPO 04/11/08 50198 bouton au debut du texte associé
  Endif

  If PAR<>""
    Wrseq '        <a name="'+PAR+'"></a>' Using [DOC]
    # JPGA 13/09/2010 BUG-60799: Pour les champs d'écran de Barre de Menu : ne pas afficher tout de suite la partie à masquer
    If JJ=0 and STY=-1
        Wrseq '        <div onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">' Using [DOC]
    Endif
  Endif

  If PAR<>"" and JJ=0 and STY<>4
     If STY=-1
         Wrseq '              <input type="button" value="'+TIT+'"/>' Using [DOC]
         Wrseq '            </td>' Using [DOC]
         Wrseq '            <td>' Using [DOC]
         # JPGA 13/09/2010 BUG-60799: Création d'une balise champs pour Plier/Déplier correctement les champs d'écran de Barre de Menu
         Wrseq '        </div>' Using [DOC]
     Else
         Wrseq '        <h'+num$(STY)+' class="g1"><u>'+TIT+'</u></h'+num$(STY)+'>' Using [DOC]
     Endif
  Else
     If STY=-1
         Wrseq '              <input type="button" value="'+TIT+'"/>' Using [DOC]
         Wrseq '            </td>' Using [DOC]
         Wrseq '            <td>' Using [DOC]
     #VPO 06/11/08 47899 deplier fonctions accessibles par clic droit (Version non V5)
     Elsif IF_DOCV5=0 & TIT=func AGENADO.MST(73,142) & BOT_PAR<>""
         If BOT_PAR="ECR"
            Wrseq '        <p>&nbsp;</p>' Using [DOC] : # Pour ne pas avoir de collision
         Endif
         Wrseq '        <div class="bdesc" onClick="showhide(fct_'+tolower(BOT_PAR)+",'"+BOT_PAR+"'"+')">' Using [DOC]
         Wrseq '          <p>'+TIT+'</p>' Using [DOC]
         Wrseq '        </div>' Using [DOC]
        # Début de la section dépliante
          Wrseq '        <div id=fct_'+tolower(BOT_PAR)+' class="ddesc">' Using [DOC]


     Else
         Wrseq '        <h'+num$(STY)+' class="g1">'+TIT+'</h'+num$(STY)+'>' Using [DOC]
     Endif
  Endif

  If JJ : Raz [AMK] : End : Endif : # Cà ne devrait pas arriver, mais autant bien le gérer

  If IF_DOCV5=0 : # VPO 04/11/08 47899 ajout description sur onglets (Version non V5)
    If STY=4
     Gosub TXT_PAR
     If DEBTXT<>""
         Wrseq '        <div class="bdesc" onClick="showhide(desc_'+tolower(PAR)+",'"+PAR+"'"+')">' Using [DOC]
         Wrseq '          <p>'+func AGENADO.MST(2,142)+'</p>' Using [DOC]
         Wrseq '        </div>' Using [DOC]

        # Début de la section dépliante
          Wrseq '        <div id=desc_'+tolower(PAR)+' class="ddesc" style="display: block;">' Using [DOC]

        # Inclusion du texte du CLOB s'il n'est pas vide
          If INCLUT_TEXTE
            If dim(TEXTES)<0 : Local Char TEXTES(250)(1..2000) : Endif
            Gosub LEC_ADO From AGENDOCA
            If TEXBASE
                If pat(vireblc(toupper(TEXTES(1)),0),"<P*")=0
                    Wrseq '        <p>' Using [DOC]
                Endif
                Gosub WR_TEX From AGENDOCA
                If pat(vireblc(toupper(TEXTES(1)),0),"<P*")=0
                    Wrseq '        </p>' Using [DOC]
                Endif
            Endif
          Endif

        # Ajout du bouton de fermeture
          Wrseq '          <p></p>' Using [DOC] : # Pour ne pas avoir de collision avec le bouton de fermeture
          Wrseq '          <div class="bdesc" onClick="showhide(desc_'+tolower(PAR)+",'"+PAR+"'"+')">' Using [DOC]
          Wrseq '            <p>'+ctrans(func AGENADO.MST(55,9138),"&","")+'</p>' Using [DOC] : # "Fermer"
          Wrseq '          </div>' Using [DOC]

          Wrseq "        </div>" Using [DOC]
          Wrseq '        <p>&nbsp;</p>' Using [DOC] : # Pour ne pas avoir de collision avec le bouton champs
     Endif
     INCLUT_TEXTE=0
    Endif
  Endif

# Ecriture de l'en-tête d'inclusion dédié
  # JPGA 13/09/2010 BUG-60799: Création d'une balise champs pour Plier/Déplier correctement les champs d'écran de Barre de Menu
  If STY=4 or (PAR<>"" and JJ=0 and STY<>4 and STY<>-1)
     Wrseq '        <div class="bfields" onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">' Using [DOC]
     Wrseq '          <p>'+func AGENADO.RDM("PS22","0")+'</p>' Using [DOC]
     Wrseq '        </div>' Using [DOC]
  Endif

# Début de la section dépliante
  Wrseq '        <div id='+tolower(PAR)+' class="dfields">' Using [DOC]
 # "Les champs suivants sont présents dans cet onglet"
  If STY=4
     Wrseq '          <p>'+func AGENADO.MST(130,142)+' : </p>' Using [DOC]
  Elsif STY=-1
     Wrseq '          <p>'+func AGENADO.MST(245,142)+' : </p>' Using [DOC]
  Else
     Wrseq '          <p>'+func AGENADO.MST(246,142)+' : </p>' Using [DOC]
  Endif

# Analyse de l'écran pour remplir les tableaux blocs et champs

  Gosub ANAMSK From AGENDOCA

  # JPGA 06/04/2011 Bug-71500 : Tri des Blocs des onglets par Position du Bloc dans l'écran et non selon l'induce de ligne dans le masque
  Gosub TRI_ONGLET_BLOC From AGENLIBA

  For LL=1 To NBB
    JJ=ONG_NO_2(LL)
    If TITRE_BLOC(JJ)<>""
        If TITRE_BLOC(JJ)<>"!" : # Le cas où un seul bloc est visible
            # JPGA 15/04/2011 Bug-73238 : En V7 Modification du bandeau de séparation des Blocs de champs en prenant en compte la charte graphique
            Gosub BAL_BLOCCHAMPS_DEB
            Wrseq "          <p><b>";          Using [DOC]
            If TYPE_BLOC(JJ)=1
                Wrseq '<a href="../FCT/TBL_MGT.htm">'+func AGENADO.MST(132+(val(TITRE_BLOC(JJ))=0),142)+'</a><i>'-TITRE_BLOC(JJ)+'</i>'; Using [DOC]
            Else
                Wrseq TITRE_BLOC(JJ);          Using [DOC]
            Endif
            Wrseq "</b></p>"                   Using [DOC]
            Gosub BAL_BLOCCHAMPS_FIN
        Elsif TYPE_BLOC(JJ)=1
            Gosub BAL_BLOCCHAMPS_DEB
            Wrseq '<a href="../FCT/TBL_MGT.htm">'+func AGENADO.MST(133,142)+'</a></i>'; Using [DOC]
            Gosub BAL_BLOCCHAMPS_FIN
        Endif
        Wrseq '          <table class="fld1">' Using [DOC]
        For II=1 To NB_CHAMP
            If BLOC_CHAMP(II)=JJ and CHAMPS_ECR(II)<>"" and find(TYPE_CHAMP(II),"ABS","W")=0
              If UNAFF_CHAMP(II)<2   # Si UNAFFHTM à 0 ou à 1 : Champs devant être visible. Si 2 : Champs invisible
                Wrseq '            <tr>' Using [DOC]
                If IF_DOCV5=0
                Wrseq '              <td>' Using [DOC] : # VPO 04/11/08 47899 nom des champs en ligne avec puce
                Else
                Wrseq '              <td width="40%" valign=top>' Using [DOC] : # nom du champs à gauche
                Endif
                Wrseq '                <ul>' Using [DOC]
                If IF_DOCV5=0
                Wrseq '                  <li class="fld">'; Using [DOC] : # VPO 04/11/08 47899 nom des champs en ligne avec puce
                Else
                Wrseq '                  <li>'; Using [DOC]
                Endif
                If INT_CHAMP(II)<>""
                    Wrseq INT_CHAMP(II)+" ("; Using [DOC]
                Endif
                If TYPE_CHAMP(II)<>""
                    Wrseq '<a href="./GES'+TYPE_CHAMP(II)+'.htm">'; Using [DOC]
                Endif
                If INT_CHAMP(II)<>""
                    Wrseq func AGENADO.MST(131,142)-CHAMPS_ECR(II); Using [DOC] : # "champ"
                Else
                    Wrseq func AGENADO.MST(131,142)-CHAMPS_ECR(II); Using [DOC] : # Première lettre majuscule
                Endif
                If TYPE_CHAMP(II)<>""
                    Wrseq '</a>'; Using [DOC]
                Endif
                If INT_CHAMP(II)<>""
                    Wrseq ')'; Using [DOC]
                Endif
                Wrseq "</li>" Using [DOC]
                Wrseq '                </ul>' Using [DOC]
                Wrseq '              </td>' Using [DOC]
                If IF_DOCV5=0
                Wrseq '              </tr><td>' Using [DOC]  : # VPO 04/11/08 47899 nom des champs en ligne avec puce
                Else
                Wrseq '              <td width="60%">' Using [DOC]
                Endif

                # JPGA 08/08/2013 EXI-91038-1 : Aide indicée qui ne s'affiche pas dans le HTML.
                [L]HELP_EXIST=find(HELP_CHAMP(II),HELP_CHAMP(1..II-1))
                If HELP_CHAMP(II)<>"" & [L]HELP_EXIST
                  # Recherche de l'indice de la dernière AIDE déjà rencontrée pendant le parcours des blocs
                  For KK=II-1 To 1 Step -1
                    If HELP_CHAMP(KK)=HELP_CHAMP(II)
                      [L]HELP_LAST=KK : Break
                    Endif
                  Next KK
                Else
                  Raz [L]HELP_LAST
                Endif

                # On ne répète pas les aides présentes sur plusieurs champs consécutifs
                # On ne répète pas non plus l'aide de champs de type XXN... si l'aide a déjà été incluse
                If HELP_CHAMP(II)<>""
&               & (II=1 or TYPE_CHAMP(II)="ABS" or (HELP_CHAMP(II-1)<>HELP_CHAMP(II)))
&               & (II<2 or instr(1,"234567890",right$(CHAMPS_ECR(II),len(CHAMPS_ECR(II))))=0
&                   or ! [L]HELP_EXIST
&                   or ( [L]HELP_EXIST & BLOC_CHAMP([L]HELP_LAST)<>BLOC_CHAMP(II) ))
                    Gosub INCL_AIDE From AGENADO
                Else
                    Wrseq "                <p>&nbsp</p>" Using [DOC]
                Endif
                Wrseq '              </td>' Using [DOC]
                Wrseq '            </tr>' Using [DOC]
              Endif
            Endif
        Next II
        Wrseq "          </table>" Using [DOC]
    Endif
  Next LL

# Ajout du bouton de fermeture
  Wrseq '          <p></p>' Using [DOC] : # Pour ne pas avoir de collision avec le bouton de fermeture
  Wrseq '          <div class="bfields" onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">' Using [DOC]
  Wrseq '            <p>'+ctrans(func AGENADO.MST(55,9138),"&","")+'</p>' Using [DOC] : # "Fermer"
  Wrseq '          </div>' Using [DOC]

  Wrseq "        </div>" Using [DOC]

  # VPO 04/11/08 47899 nom des champs en ligne avec puce
  If IF_DOCV5=0 & STY=4
  Wrseq '        <p>&nbsp;</p>' Using [DOC] : # Pour ne pas avoir de collision avec la suite
  Endif

  # JPGA 13/09/2010 BUG-60799: A quoi sert TXT_PAR ici ?
  #Gosub TXT_PAR
End

############
# JPGA 15/04/2011 Bug-73238 : En V7 Modification du bandeau de séparation des Blocs de champs en prenant en compte la charte graphique
$BAL_BLOCCHAMPS_DEB
   # JPGA 06/04/2011 Bug-71500 : Affichage d'un bandeau de séparation entre les Blocs pour + de lisibilité
   If ( IF_DOCV5 | IF_DOCV6)
      Wrseq '          <h4 class="g1">'  Using [DOC]
   Else
      Wrseq '          <h4 class="bloctitle">'  Using [DOC]
   Endif
Return

############
$BAL_BLOCCHAMPS_FIN
   # JPGA 06/04/2011 Bug-71500 : Affichage d'un bandeau de séparation entre les Blocs pour + de lisibilité
   Wrseq '          </h4>'            Using [DOC]
Return

############
$TXT_PAR
  If IF_DOCV5=0 : # VPO 04/11/08 47899 ajout description sur onglets
    If STY=4 & INCLUT_TEXTE=0
        Return
    Endif
  Endif

# Si aucun texte n'a été mis dans le paragraphe, on met un texte introductif en plus pour ouvrir les champs
  Read [ADH]ADH0=[ADO]LAN;[ADO]TYP;[ADO]COD;[ADO]LEV;[ADO]SUBLEV
  If fstat=0
      Setlob DEBTXT With [ADH]TEXTE
  Else
      Read [ADH2]ADH0=[ADO]LAN;[ADO]TYP;[ADO]COD;[ADO]LEV;[ADO]SUBLEV
      If fstat=0
          Setlob DEBTXT With [ADH2]TEXTE
      Else
          Raz DEBTXT
      Endif
  Endif

#VPO 23/09/08 49344
If 1=0
  If DEBTXT=""
    Wrseq '          <p onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">'
&                  +"<u>"+func AGENADO.MST(130,142)+"</u></p>" Using [DOC] : # "Les champs suivants sont présents..."
  Endif
Else
  If DEBTXT="" | STY<>4
  If STY=4
    #VPO 06/11/08 47899 enlever le texte "Les champs suivants sont présents dans cet onglet"
    If IF_DOCV5=0
    Else
    Wrseq '          <p onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">'
&                  +"<u>"+func AGENADO.MST(130,142)+"</u></p>" Using [DOC] : # "Les champs suivants sont présents dans cet onglet"
    Endif
  Elsif STY=-1
    Wrseq '          <p onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">'
&                  +"<u>"+func AGENADO.MST(245,142)+"</u></p>" Using [DOC] : # "Les champs suivants sont présents dans la fenêtre ouverte par ce bouton"
  Else
    Wrseq '          <p onClick="showhide('+tolower(PAR)+",'"+PAR+"'"+')">'
&                  +"<u>"+func AGENADO.MST(246,142)+"</u></p>" Using [DOC] : # "Les champs suivants sont présents dans cette fenêtre"
  Endif
  Endif
Endif
Return


##########################
# Titre de paragraphe
Subprog TIT_PAR(STY,TIT)
Value Char TIT()
Value Shortint STY
  Wrseq '        <h'+num$(STY)+' class="g1">'+TIT+'</h'+num$(STY)+'>' Using [DOC]
End


# Paragraphe isolé
Subprog PAR_PAR(TXT)
Value Char TXT()
  Wrseq '        <p>'+TXT+'</p>' Using [DOC]
End

# Début de paragraphe isolé
Subprog PAR_DEB(TXT)
Value Char TXT()
  Wrseq '        <p>'+TXT Using [DOC]
End

# Suite de paragraphe isolé
Subprog PAR_SUI(TXT)
Value Char TXT()
  Wrseq '           '+TXT Using [DOC]
End

# Fin de paragraphe HTML
Subprog PAR_FIN
  Wrseq '        </p>' Using [DOC]
End


# Filtre des paragraphes ne devant pas apparaître dans les tables des matières
$FIL_PAR
  If [AD1]PAR<>"INC"
      II=(find([AD1]PAR,"PRE","TIT","BOT","MIN","LNK")=0) and ([AD1]CODACT<>"FAL")
      #VPO 14/01/08 40245
      If II
          If [AD1]CODACT>="X" and GEN_FIN=2
            II=0
          Elsif [AD1]CODACT<>"" and GEN_FIN<>2
                Read [ACV]CODACT=[AD1]CODACT
                If [ACV]FLACT<>2
                    II=0
                Endif
          Endif
      Endif

      If [AD1]PAR="UTI" & II
          Gosub LEC_AD1 From AGENDOCA
          If TEXBASE=0
            II=0
          Endif
      Endif
  Else
      Gosub LEC_AD1 From AGENDOCA
      I_LEV=[AD1]LEV : I_SUBLEV=[AD1]SUBLEV : Gosub RECH_INCL From AGENDOCA
      Read [ADO2]ADO0=[AD1]LAN;I_TYP;I_COD;I_LEV;I_SUBLEV
      II=(find([ADO2]PAR,"PRE","TIT","BOT","MIN","LNK")=0) and ([ADO2]CODACT<>"FAL")
      #VPO 14/01/08 40245
      If II
          If [ADO2]CODACT>="X" and GEN_FIN=2
            II=0
          Elsif [ADO2]CODACT<>"" and GEN_FIN<>2
                Read [ACV]CODACT=[ADO2]CODACT
                If [ACV]FLACT<>2
                    II=0
                Endif
          Endif
      Endif
  Endif
Return


# En-tête de bouton
Subprog ENT_BOU(ANCR,TIT)
Value Char ANCR()
Value Char TIT()
  Wrseq '        <table>' Using [DOC]
  Wrseq '          <tr>' Using [DOC]
  Wrseq '            <td>' Using [DOC]
  If ANCR<>""
      Wrseq '              <a name="'+ANCR+'"></a>' Using [DOC]
  Endif
  Wrseq '              <input type="button" value="'+TIT+'"/>' Using [DOC]
  Wrseq '            </td>' Using [DOC]
  Wrseq '            <td>' Using [DOC]
End

# Fin de paragraphe complète
Subprog FIN_PAR_BOU
  ##If [ADO]PAR="BOU"
      Wrseq '            </td>' Using [DOC]
      Wrseq '          </tr>' Using [DOC]
      Wrseq '        </table>' Using [DOC]
      Wrseq '        <p></p>' Using [DOC]
  ##Endif
End

# Fin de paragraphe fct bot
Subprog FIN_PAR_BOT(BOT_PAR)
Value Char BOT_PAR()
  Wrseq '          <p>&nbsp;</P>' Using [DOC]
  If BOT_PAR<>""
      Wrseq '          <div class="bdesc" onClick="showhide(fct_'+tolower(BOT_PAR)+",'"+BOT_PAR+"'"+')">' Using [DOC]
      Wrseq '            <p>'+ctrans(func AGENADO.MST(55,9138),"&","")+'</p>' Using [DOC] : # "Fermer"
      Wrseq '          </div>' Using [DOC]
      Wrseq '        </div>' Using [DOC]
      Wrseq '        <p>&nbsp;</P>' Using [DOC]
  Endif
End

##########################################################################################
$GEN_DOCF_LNKFLD
If clalev([ADO3])=0 : Local File ADOCUMENT [ADO3] : Endif
# Issue 75246/7 - 2012-07-19 by VPO :  mot clé d'aide
#If clalev([AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
If clalev([AMC2])=0  : Local File AMOTCLE [AMC2] : Endif
If clalev([ADZ2])=0 : Local File ADOCFLD [ADZ2] : Endif
VV_LAN=[ADO]LAN
VV_TYP=[ADO]TYP
VV_COD=[ADO]COD

#VPO 04/01/08 BUG44500
# Issue 75246/7 - 2012-07-19 by VPO :  mot clé d'aide
#Link [AMZ2] With [ADO3]ADO0(3)=VV_LAN;VV_TYP;VV_COD,[ADZ4]ADZ0(1)=VV_LAN As [AZZ]
#&                Where [AMZ2]CODMSK=[ADO3]MSK and [AMZ2]MOTCLE=[ADZ4]MOTCLE
Link [AMC2] With [ADO3]ADO0(3)=VV_LAN;VV_TYP;VV_COD,[ADZ4]ADZ0(1)=VV_LAN As [AZZ]
&                Where [AMC2]TYPZON=2 & [AMC2]IDENT1=[ADO3]MSK and [AMC2]MOTCLE=[ADZ4]MOTCLE
For [AZZ]
    [ADZ]=[ADZ4]
    Gosub GEN_DOCF_FLD
Next

# Issue 75246/7 - 2012-07-19 by VPO :  mot clé d'aide
#Link [AMZ2] With [ADO3]ADO0(3)=VV_LAN;VV_TYP;VV_COD,[ADZ2]ADZ0(1)=VV_LAN As [AZZ]
#&                Where [AMZ2]CODMSK=[ADO3]MSK and [AMZ2]MOTCLE=[ADZ2]MOTCLE
Link [AMC2] With [ADO3]ADO0(3)=VV_LAN;VV_TYP;VV_COD,[ADZ2]ADZ0(1)=VV_LAN As [AZZ]
&                Where [AMC2]TYPZON=2 & [AMC2]IDENT1=[ADO3]MSK and [AMC2]MOTCLE=[ADZ2]MOTCLE
For [AZZ]
    [ADZ]=[ADZ2]
    Gosub GEN_DOCF_FLD
Next

Return

######################################################################################
#
# génération pour 1 champ
#
$GEN_DOCF_FLD
    COD_LAN=[ADZ]LAN
    Gosub INIT_COD_ISO From AGENDOCA                  : # TCH SI023 95209_1 : code iso doit etre en phase avec COD_LAN
    #VPO 01/02/08 45586 ne generer la doc que si le texte n'est pas vide
    If [ADZ]TEXTE<>""
        Gosub REPERT_LAN From AGENDOCA
        # JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
        REPERT_DOC=func AGENLIBA.REMPLACE_VOLUME (REPERT_DOC)
        #JPGA BUG-80540 13/03/2012 : Ne plus afficher DUMMY dans le contenu HTML du MOTCLE : DUMMY
        #JPGA BUG-80814 16/03/2012 : Rechercher l'intitulé : Aides sur champs et non l'intitulé du champs HLPFLD de l'écran AGENDOCA
        TITRED=func AGENADO.MST(59,9841)-"("+func AGENLIBA.TRT_SPECIAL_DUMMY([ADZ]MOTCLE)+")"
        IPIL=2 : LIENSGEN=""
        PILE_NOMEN(1)=TITRED
        FICOUV=REPERT_DOC+SLASH+"FLD"+SLASH+[ADZ]MOTCLE+".htm"
        Gosub FICOUV_OPEN From AGENLIBA
        # Ecriture de l'en-tête  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
        [L]MODULED=[ADZ]MODULE : ECR_HEADER_DOC=0 : ECR_HEADER_FLD=1 : Gosub ECR_HEADER From AGENLIBA

        #VPO 14/11/08 modif charte
        If IF_DOCV5=0
            # Début du texte principal
            Wrseq '    <div id="supportingText">' Using [DOC]
        Endif

        If [ADZ]LNKHLP<>"" & [ADZ]LNKORD=1
            Read [ADZ3]ADZ0=COD_LAN;[ADZ]LNKHLP
            #VPO 04/01/08 BUG44500
            If fstat
               Read [ADZ5]ADZ0=COD_LAN;[ADZ]LNKHLP
               [ADZ3]=[ADZ5]
            Endif
            Wrseq [ADZ3]TEXTE Using [DOC]
        Endif
        Wrseq [ADZ]TEXTE Using [DOC]
        If [ADZ]LNKHLP<>"" & [ADZ]LNKORD=2
            Read [ADZ3]ADZ0=COD_LAN;[ADZ]LNKHLP
            #VPO 04/01/08 BUG44500
            If fstat
               Read [ADZ5]ADZ0=COD_LAN;[ADZ]LNKHLP
               [ADZ3]=[ADZ5]
            Endif
            Wrseq [ADZ3]TEXTE Using [DOC]
        Endif
        #VPO 14/11/08 modif charte
        If IF_DOCV5=0
            # Fin du texte principal
            Wrseq '    </div>' Using [DOC]
        Endif

        Gosub FIN_FIC1 From AGENLIBA
#       Openo Using [DOC]
    Endif
Return

# On vérifie s'il existe des blobs liés au document.
# Si c'est le cas, on les extrait soit dans le même répertoire, soit dans le répertoire donné...
# Si le nom n'est pas imposé, on reprend le nom du document d'origine suivi de _nnn.jpg
# Dans le cas des documentations de type AD, on remplace le nom fonction_d par fonction$

######################################################################################
$PCEJOIN

# Petite verrue rajoutée suite à demande de Cathy Girard :
# Pour les documentations de type FI et de nom REPERT_###, on extrait d'abord les docs FI de nom _###
# Si des docs spécifiques existent, elles seront écrasées ensuite
  If [ADO]TYP="FI" & pat([ADO]COD,"*_*")

    If pat([ADO]COD,"A_#*") : Return : Endif : # Rien n'est généré sur les docs FI / A_nnn
    If vireblc(ctrans([ADO]COD,"_"," "),4)="A"
        CHAINE1='pat(COD,"A_0*")<>0'
    Else
        CHAINE1='COD="A"+right$([ADO]COD,instr(1,[ADO]COD,"_"))'
    Endif

    If IF_DOSSUP

        For [ADB2]ADB0 Where LAN=COD_LAN and TYP=[ADO]TYP and evalue(CHAINE1)
&                       and LEV=[ADO]LEV and SUBLEV=[ADO]SUBLEV
            [ADB]=[ADB2]
            Gosub FIC_JOINTS
        Next
    Endif

    For [ADB]ADB0 Where LAN=COD_LAN and TYP=[ADO]TYP and evalue(CHAINE1)
&                   and LEV=[ADO]LEV and SUBLEV=[ADO]SUBLEV
        Gosub FIC_JOINTS
    Next
  Endif

  If IF_DOSSUP
    For [ADB2]ADB0 Where LAN=COD_LAN and TYP=[ADO]TYP and COD=[ADO]COD and LEV=[ADO]LEV and SUBLEV=[ADO]SUBLEV
        [ADB]=[ADB2]
        Gosub FIC_JOINTS1
    Next
  Endif

  For [ADB]ADB0 Where LAN=COD_LAN and TYP=[ADO]TYP and COD=[ADO]COD and LEV=[ADO]LEV and SUBLEV=[ADO]SUBLEV
    Gosub FIC_JOINTS1
  Next

Return

######################################################################################
$FIC_JOINTS1
    MM=0
    If [ADB]REPERT="" or [ADB]REPERT="A"
        FICOUV=REPERT_DOC+SLASH+ctrans(SOUS_REPERT,"_",SLASH)+SLASH
    Else
        FICOUV=REPERT_DOC+SLASH+[ADB]REPERT+SLASH
    Endif
    If [ADB]NAM=""
        FICOUV+=NOMDOC+"_"+format$("N0:3",[ADB]LIG)+".jpg"
    Else
        If [ADB]TYP="AD" and pat([ADB]NAM,"*_d.htm")<>0
            MM=instr(1,[ADB]NAM,"_d")
            FICOUV+=left$([ADB]NAM,MM-1)+"$.htm"
        Else
            FICOUV+=[ADB]NAM
        Endif
    Endif
    Gosub TEST_SOUS_REPERT From AGENDOCA

    Gosub FICOUV_OPEN_D
    Openo FICOUV2,0 Using [BLO]
    Putseq 1,[ADB]PICTUR Using [BLO]
    Openo Using [BLO]
    Gosub FICOUV_COPIE_D
Return

######################################################################################
$FIC_JOINTS
  If [ADB]REPERT=""
      FICOUV=REPERT_DOC+SLASH+ctrans(SOUS_REPERT,"_",SLASH)+SLASH
  Else
      FICOUV=REPERT_DOC+SLASH+[ADB]REPERT+SLASH
  Endif
  If [ADB]NAM=""
      FICOUV+=NOMDOC+"_"+format$("N0:3",[ADB]LIG)+".jpg"
  Else
      FICOUV+=[ADB]NAM
  Endif
  Gosub TEST_SOUS_REPERT From AGENDOCA
  Gosub FICOUV_OPEN_D
  Openo FICOUV2,0 Using [BLO]
  Putseq 1,[ADB]PICTUR Using [BLO]
  Openo Using [BLO]
  Gosub FICOUV_COPIE_D
Return

######################################################################################
# JPGA 18/08/2009 BUG-54802 : Gestion globale des caractères $ de fin de documentation pour toute doc
#                             Creation en remplacant par Z et copie du fichier en $
######################################################################################
$FICOUV_OPEN_D
    # Infâme magouille pour gérer les noms de fichiers avec un $ dedans
    FICOUV2 = ctrans(FICOUV,"$","Z")
Return

$FICOUV_COPIE_D
    # Infâme magouille pour gérer les noms de fichiers avec un $ dedans
    MM=instr(1,FICOUV,"$")
    If MM
        NN=instr(1,FICOUV,"@")
        If NN
            MACHI=left$(FICOUV,NN-1)
            FICOUV=right$(FICOUV,NN+1)
        Else
            MACHI=""
        Endif
        MM=instr(1,FICOUV,"$")
        ORSY = 'ae_mv "'+left$(FICOUV,MM-1)+"Z"+right$(FICOUV,MM+1)+'"'-'"'+FICOUV+'"'
        Call SYSTEME2(MACHI,ORSY,"",MM,CHAINE) From ORDSYS
    Endif
Return

$FICOUV_OPEN
# Ouverture du fichier doc
  Gosub TEST_SOUS_REPERT From AGENDOCA
  Gosub FICOUV_OPEN_D    From AGENLIBA
$FICOUV2_OPEN
  Openo FICOUV2,0                 Using [DOC]
  Iomode adxifs chr$(0)           Using [DOC]
  Iomode adxirs chr$(13)+chr$(10) Using [DOC]
  Iomode adxium GADXHTENT         Using [DOC]
Return

$FICOUV2_APPEND
  Openo FICOUV2                   Using [DOC]
  Iomode adxifs chr$(0)           Using [DOC]
  Iomode adxirs chr$(13)+chr$(10) Using [DOC]
  Iomode adxium GADXHTENT         Using [DOC]
Return

######################################################################################
#
# Traitements de copie de doc
#
######################################################################################
$COPIE_FLD
Local Char V_TEXTE (255)
Raz V_TEXTE
If clalev([ADZZ])<>0 : Close File [ADZZ] : Endif
If clalev([ADZZ])=0 : Local File =GDOSX3+".ADOCFLD" [ADZZ] : Endif

#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
If func AGENLIBA.TEST_GROUPE_OK("ADZ", [M:DIA]LAN, "", [ADZ2]MOTCLE, "[M:DIA]ALLCREGRP")
  Read [ADZ]ADZ0=[M:DIA]LAN;[ADZ2]MOTCLE
  If fstat<>0
    Read [ADZZ]ADZ0=[M:DIA]LAN;[ADZ2]MOTCLE
    If fstat<>0
        [ADZ]=[ADZ2] : [ADZ]LAN=[M:DIA]LAN
        Setlob [ADZ]TEXTE With V_TEXTE
        [ADZ]CREDAT=[ADZ]CREDAT-1
        Write [ADZ]
    Else
        [ADZ]=[ADZZ]
        Write [ADZ]
    Endif
    #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Marquage Réalisé pour les Ecritures de la Génération ADOCUMENT (On ne le fait que sur TIT en CREATION)
    Gosub TRACE_COR_ADZ From AGENLIBA
  Endif
  A_REW=0
  If [ADZ]MODULE<>[ADZ2]MODULE
    [ADZ]MODULE=[ADZ2]MODULE : A_REW=1
  Endif
  If [ADZ]GEN<>[ADZ2]GEN
    [ADZ]GEN=[ADZ2]GEN: A_REW=1
  Endif
  If [ADZ]LNKHLP<>[ADZ2]LNKHLP
    [ADZ]LNKHLP=[ADZ2]LNKHLP: A_REW=1
  Endif
  If [ADZ]LNKORD<>[ADZ2]LNKORD
    [ADZ]LNKORD=[ADZ2]LNKORD: A_REW=1
  Endif
  If A_REW=1 : Rewrite [ADZ] : Endif
  # JPGA 18/03/2011 BUG-70761 : Lors d'une extraction simple, la génération + Copie lance la Remontée de TRad à Tord. Elle ne doit être lancée que lors de l'import
  # Call MAJ_ENVINDUS_FLD ([M:DIA]LAN,[ADZ2]MOTCLE)
Endif
Return

######################################################################################
$COPIE_LNKFLD
If clalev([ADO3])=0 : Local File ADOCUMENT [ADO3] : Endif
# Issue 75246/7 - 2012-07-19 by VPO :  mot clé d'aide
#If clalev([AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
If clalev([AMC2])=0  : Local File AMOTCLE [AMC2] : Endif
If clalev([ADZ2])=0 : Local File ADOCFLD [ADZ2] : Endif
If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
If clalev([ZDZ1])=0 : Local File =GDOSX3+".ADOCFLD" [ZDZ1] : Endif

#Link [AMZ2] With [ADO3]ADO0(3)=[M:DIA]LAN;[ZDO0]VTYP;[ZDO0]VCOD As [AZZ]
#&                Where [AMZ2]CODMSK=[ADO3]MSK and [AMZ2]MOTCLE>""
#&                Order By [AMZ2]MOTCLE
Link [AMC2] With [ADO3]ADO0(3)=[M:DIA]LAN;[ZDO0]VTYP;[ZDO0]VCOD As [AZZ]
&                Where [AMC2]TYPZON=2 & [AMC2]IDENT1=[ADO3]MSK and [AMC2]MOTCLE>""
&                Order By [AMC2]MOTCLE
Raz [ADZ2]
For [AZZ]
  If [ADZ2]MOTCLE<>[AMC2]MOTCLE
    # on passe [ADZ2] à COPIE_FLD
    Read [ADZ2]ADZ0=[M:DIA]LANREF;[AMC2]MOTCLE
    If fstat<>0
        Read [ZDZ1]ADZ0=[M:DIA]LANREF;[AMC2]MOTCLE
        If fstat<>0
            Raz [ADZ2]
        Else
            [ADZ2]=[ZDZ1]
        Endif
    Endif
    If [ADZ2]MOTCLE<>""
        Gosub COPIE_FLD
    Endif
  Endif
Next
Return

######################################################################################
# Transfert de langue de ref vers la langue choisie (copie)
######################################################################################
$EXEC
  If clalev([ADB2])=0 : Gosub DECLARE_TABLES From AGENLIBA : Endif

  Local Char EV(200)

  Local Char SQLREQ (250) (3) : Raz SQLREQ
  SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
  SQLREQ(0) -= "WHERE A.LAN_0='"+[M:DIA]LANREF+"' "
  EV =string$( [M:DIA]ALLTYP=1,"AND A.TYP_0='"+[M:DIA]TYP+"'" )
  EV-=string$( [M:DIA]ALLCOD=1,"AND A.COD_0>='"+[M:DIA]CODDEB+string$([M:DIA]CODDEB=""," ")+"' AND A.COD_0<='"+[M:DIA]CODFIN+string$([M:DIA]CODFIN=""," ")+"'" )
  SQLREQ(0) -= EV
  If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:DIA]LANREF+"' "
  EV =string$( [M:DIA]ALLTYP=1,"AND B.TYP_0='"+[M:DIA]TYP+"'" )
  EV-=string$( [M:DIA]ALLCOD=1,"AND B.COD_0>='"+[M:DIA]CODDEB+string$([M:DIA]CODDEB=""," ")+"' AND B.COD_0<='"+[M:DIA]CODFIN+string$([M:DIA]CODFIN=""," ")+"'" )
  SQLREQ(1) -= EV
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
  Endif
  SQLREQ(2) -="ORDER BY 1,2"

  Local Char VAPPREFOLD(30) : Raz VAPPREFOLD

  Trbegin [AD1],[ADH]
  For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1) Sql SQLREQ As [ZDO0]
      # on boucle sur TYP+COD pour la langue de ref
      If VAPPREFOLD<>[ZDO0]VAPPREF
          If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
          If clalev([ZDO2])=0 : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
      Endif
    DOC_ERR=0
    DOC_AEXT=0
    For [ZDO2]ADO0 Where LAN=[M:DIA]LANREF and TYP=[ZDO0]VTYP and COD=[ZDO0]VCOD
        ## VPO 18/01/07 on empeche copie s'il n'existe aucun paragraphe (manque génération)
        Read [AD1]ADO0=[M:DIA]LAN;[ZDO2]TYP;[ZDO2]COD
        If fstat<>0
            # il n'existe aucun paragraphe, on ne copie pas la doc
            DOC_ERR=1
            Break
        Endif

        # on copie les paragraphes inexistants, on met à jour les autres
        Read [AD1]ADO0=[M:DIA]LAN;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
        If fstat<>0
            [AD1]=[ZDO2] : [AD1]LAN=[M:DIA]LAN
            [AD1]VLDFLG=1 : [AD1]VLDDAT=[0/0/0] : # ajout VPO 10/01/07
            Write [AD1]
        Endif
        A_REW=0
        # VPO 27/03/07 bug40511 : toujours récuperer le code activité
        #If [AD1]CODACT<>"FAL" & [ZDO2]CODACT="FAL"
        #    [AD1]CODACT="FAL" : A_REW=1
        #Endif
        If [ZDO2]CODACT<>[AD1]CODACT
            [AD1]CODACT=[ZDO2]CODACT: A_REW=1
        Endif
        If [AD1]PAR<>"INC" & [ZDO2]PAR="INC"
            [AD1]PAR="INC" : A_REW=1
        Endif
        If [AD1]PAR<>"MIS" & [ZDO2]PAR="MIS"
            [AD1]PAR="MIS" : [AD1]TIT=[ZDO2]TIT : A_REW=1
        Endif
        If [AD1]PAR<>"MIN" & [ZDO2]PAR="MIN"
            [AD1]PAR="MIN" : [AD1]TIT=[ZDO2]TIT : A_REW=1
        Endif
        If [ZDO2]TIT<>"" & [AD1]TIT=""
            [AD1]TIT=[ZDO2]TIT : A_REW=1
        Endif
        If [ZDO2]STY<>[AD1]STY
            [AD1]STY=[ZDO2]STY: A_REW=1
        Endif
        If [ZDO2]MSK<>[AD1]MSK
            [AD1]MSK=[ZDO2]MSK: A_REW=1
        Endif
        If [ZDO2]MODULE<>[AD1]MODULE
            [AD1]MODULE=[ZDO2]MODULE: A_REW=1
        Endif
        If [ZDO2]PAR="INC"
            Read [ADH1]ADH0=[M:DIA]LANREF;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
            If fstat<>0
                Read [ADH2]ADH0=[M:DIA]LANREF;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
                [ADH1]=[ADH2]
            Endif
            Read [ADH]ADH0=[M:DIA]LAN;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
            If fstat<>0
                [ADH]=[ADH1] : [ADH]LAN=[M:DIA]LAN : Write [ADH]
            Endif
        Endif
        #VPO 19/06/08 39766 ajout ATD: différences de tables
        If find([ZDO2]TYP,"APM","ATD","ATB","AML","ATY","FI")
            #VPO 13/12/07 BUG44457 on n'extrait que les fichiers htm pour la trad
            VLDOK=1
            If [M:DIA]HLPFIL=2 & [ZDO2]TYP="FI"
                If clalev([ADBZ])=0 : Local File ADOCBLB [ADBZ] : Endif
                # JPGA 30/03/2012 BUG-80530 : Mauvais traitement de la Traduction des fichiers liés dans un Dossier Fille
                Filter [ADBZ] Where LAN=[M:DIA]LANREF & TYP=[ZDO2]TYP & COD=[ZDO2]COD & LEV=[ZDO2]LEV & SUBLEV=[ZDO2]SUBLEV
                If rowcount([ADBZ])      # Recherche dans dossier Courant en Langue de REF si au moins 1 Enreg
                   For [ADBZ]
                      If pat([ADBZ]NAM,"*.htm*")<>0  :  VLDOK=0  :  Break  :  Endif
                   Next ADBZ
                Else                     # Recherche dans dossier Racine  en Langue de REF
                  If GDOSX3<>nomap
                   For [ADB2] Where LAN=[M:DIA]LANREF & TYP=[ZDO2]TYP & COD=[ZDO2]COD & LEV=[ZDO2]LEV & SUBLEV=[ZDO2]SUBLEV
                      If pat([ADB2]NAM,"*.htm*")<>0  :  VLDOK=0  :  Break  :  Endif
                   Next ADB2
                  Endif
                Endif
                Filter [ADBZ]
            Endif
            Raz [ADH]
            Raz [ADH1]
            Raz [ADH2]
            Read [ADH1]ADH0=[M:DIA]LANREF;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
            If fstat<>0
                Read [ADH2]ADH0=[M:DIA]LANREF;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
                [ADH1]=[ADH2]
            Endif
            Read [ADH]ADH0=[M:DIA]LAN;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
            If [ADH]TEXTE=[ADH1]TEXTE & VLDOK=1
                [AD1]VLDFLG=[ZDO2]VLDFLG: A_REW=1
                [AD1]VLDDAT=[ZDO2]VLDDAT: A_REW=1
            Else
                DOC_AEXT=1
                [AD1]VLDFLG=1 : [AD1]VLDDAT=[0/0/0] : A_REW=1
            Endif
        Else
            DOC_AEXT=1
        Endif
        If A_REW=1 : Rewrite [AD1] : Endif
    Next
    If DOC_ERR=0
        #VPO 19/06/08 39766 ajout ATD: différences de tables
        If find([ZDO0]VTYP,"APM","ATD","ATB","AML","ATY","FI")<>0 & DOC_AEXT=0
            Call ECR_TRACE("      "+mess(75,176,1),0) From GESECRAN
        Endif
        If [M:DIA]HLPLNKFLD=2
            Gosub COPIE_LNKFLD
        Endif
        If [M:DIA]HLPFIL=2
            If clalev([ADBZ])=0 : Local File ADOCBLB [ADBZ] : Endif
            # JPGA 30/03/2012 BUG-80530 : Mauvais traitement de la Traduction des fichiers liés dans un Dossier Fille
            Filter [ADBZ]  Where LAN=[M:DIA]LANREF and TYP=[ZDO0]VTYP and COD=[ZDO0]VCOD
            If rowcount([ADBZ])      # Recherche dans dossier Courant en Langue de REF si au moins 1 Enreg
              For [ADBZ]
                Read [ADB]ADB0=[M:DIA]LAN;[ADBZ]TYP;[ADBZ]COD;[ADBZ]LEV;[ADBZ]SUBLEV;[ADBZ]LIG
                If fstat
                  [ADB]=[ADBZ] : [ADB]LAN=[M:DIA]LAN
                  Write [ADB]
                Endif
              Next ADBZ
            Else                     # Recherche dans dossier Racine  en Langue de REF
              For [ADB2] Where LAN=[M:DIA]LANREF and TYP=[ZDO0]VTYP and COD=[ZDO0]VCOD
                Read [ADB]ADB0=[M:DIA]LAN;[ADB2]TYP;[ADB2]COD;[ADB2]LEV;[ADB2]SUBLEV;[ADB2]LIG
                If fstat
                  [ADB]=[ADB2] : [ADB]LAN=[M:DIA]LAN
                  Write [ADB]
                Endif
              Next ADB2
            Endif
            Filter [ADBZ]
        Endif
        # JPGA 18/03/2011 BUG-70761 : Lors d'une extraction simple, la génération + Copie lance la Remontée de TRad à Tord. Elle ne doit être lancée que lors de l'import
        # Call MAJ_ENVINDUS_DOC ([M:DIA]LAN,[ZDO0]VTYP,[ZDO0]VCOD,[M:DIA]HLPFIL)
    Endif
    VAPPREFOLD=[ZDO0]VAPPREF
  Next ZDO0
  If [M]HLPFLD=2
    # on passe [ADZ2] à COPIE_FLD
    If clalev([ADZ2])=0 : Local File ADOCFLD [ADZ2] : Endif

    Raz SQLREQ
    SQLREQ(0) = "SELECT DISTINCT A.MOTCLE_0,'"+nomap+"' FROM "+nomap+".ADOCFLD A"
    SQLREQ(0) -= "WHERE A.LAN_0='"+[M:DIA]LANREF+"'"
    SQLREQ(0) -= "AND A.MOTCLE_0>='"+[M:DIA]FLDDEB+string$([M:DIA]FLDDEB=""," ")+"' AND A.MOTCLE_0<='"+[M:DIA]FLDFIN+string$([M:DIA]FLDFIN=""," ")+"'"
    If GDOSX3<>nomap
    SQLREQ(0) -= "UNION"
    SQLREQ(1) -= "SELECT DISTINCT B.MOTCLE_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCFLD B"
    SQLREQ(1) -= "WHERE B.LAN_0='"+[M:DIA]LANREF+"'"
    SQLREQ(1) -= "AND B.MOTCLE_0>='"+[M:DIA]FLDDEB+string$([M:DIA]FLDDEB=""," ")+"' AND B.MOTCLE_0<='"+[M:DIA]FLDFIN+string$([M:DIA]FLDFIN=""," ")+"'"
    SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCFLD A WHERE A.LAN_0=B.LAN_0 AND A.MOTCLE_0=B.MOTCLE_0)"
    Endif
    SQLREQ(2) -="ORDER BY 1"

    Raz VAPPREFOLD
    For (Char VMOT(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1) Sql SQLREQ As [ZDZ0]
        # on boucle sur MOTCLE pour la langue de ref
        If VAPPREFOLD<>[ZDZ0]VAPPREF
            If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
            If clalev([ZDZ1])=0 : Local File =[ZDZ0]VAPPREF+".ADOCFLD" [ZDZ1] : Endif
        Endif
        Read [ZDZ1]ADZ0=[M:DIA]LANREF;[ZDZ0]VMOT
        If fstat<>0
            Raz [ADZ2]
        Else
            [ADZ2]=[ZDZ1]
        Endif
        If [ADZ2]MOTCLE<>""
            Gosub COPIE_FLD
        Endif
    Next ZDZ0
  Endif
  Commit
Return


###########################################################################
### TRACES Des Modifs dans MNTPRD
###########################################################################
$DEBUT_TRC
# JPGA-Bug 54028-31/03/2009 : IF_DOCV5 = 0 : on est pas en V5, on trace dans INDUSPRD, sinon MNTPRD
Gosub MAC_TRC
If !IF_DOCV5
   APPMNTPRD=MAC_INDUSPRD+":"+[L]POR_INDUSPRD+"@"+[L]DOS_INDUSPRD
Else
   APPMNTPRD=MAC_MNTPRD+":"+[L]POR_MNTPRD+"@"+[L]DOS_MNTPRD
Endif

If clalev([XID])<>0 : Close Local File  [XID] : Endif
If clalev([XID])=0 : Local File  =APPMNTPRD+".XIDPRDIND"   [XID] : Endif
If clalev([XTO])<>0 : Close Local File  [XTO] : Endif
If clalev([XTO])=0 : Local File  =APPMNTPRD+".XXTRCADO"   [XTO] : Endif
If clalev([XTZ])<>0 : Close Local File  [XTZ] : Endif
If clalev([XTZ])=0 : Local File  =APPMNTPRD+".XXTRCADZ"   [XTZ] : Endif
If clalev([XTF])<>0 : Close Local File  [XTF] : Endif
If clalev([XTF])=0 : Local File  =APPMNTPRD+".XXTRCADF"   [XTF] : Endif

Local Date    DATREF    : DATREF=date$
Local Integer TIMREF    : TIMREF=time
Local Char    TRT_XID(5)
Return

$FIN_TRC
If clalev([XID])<>0 : Close Local File  [XID] : Endif
If clalev([XTO])<>0 : Close Local File  [XTO] : Endif
If clalev([XTZ])<>0 : Close Local File  [XTZ] : Endif
If clalev([XTF])<>0 : Close Local File  [XTF] : Endif
Return

# JPGA-Bug -07/04/2009 : Procedure initialisant la machine de MNTPRD ou INDUSPRD
$MAC_TRC
    # JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation
    If dim(DOS_MNTPRD)<0 | dim(POR_MNTPRD)<0 | dim(MAC_MNTPRD)<0
      Local Char  DOS_MNTPRD(12), POR_MNTPRD(12), MAC_MNTPRD(12)
      [L]POR_MNTPRD="15005"
      [L]DOS_MNTPRD="MNTPRD"
      [L]MAC_MNTPRD='AWS-X3-INDV5'    # SAM 103450 : migration nom machine
    Endif
    If dim(DOS_INDUSPRD)<0 | dim(POR_INDUSPRD)<0 | dim(MAC_INDUSPRD)<0
      Local Char  DOS_INDUSPRD(12), POR_INDUSPRD(12), MAC_INDUSPRD(12)
      [L]POR_INDUSPRD="16001"
      [L]DOS_INDUSPRD="INDUSPRD"
      [L]MAC_INDUSPRD='AWS-X3-INDUS'  # SAM 103450 : migration nom machine
    Endif
    If dim(CODE_SUPERV)<0
      Local Char  CODE_SUPERV(12)
      [L]CODE_SUPERV="PL"
    Endif
Return

# JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation
$RECH_APPLIS_TRC
  If dim(APPLIS_INDUS)<0 | dim(APPLIS_SUPER)<0
    Local Char  APPLIS_INDUS(200), APPLIS_SUPER(200)
    If GSOPHIA    # Chez Nous : Recherche à faire
      If dim(GINDUS)<0
        Gosub DEFVAR From AGLOBTRAD
      Endif
      If GINDUS<>""   # Appli d'INDUS : OK. Sinon, pas de traçage
        Raz [L]APPLIS_INDUS, [L]APPLIS_SUPER
        # APPLIS_INDUS et APPLIS_SUPER sous la forme : 'SUPERV150','SUPERV6','X3IND150','X3INDV6','PAYINDV6','ABEIND150','GEOIND150','PAYIND150'

        If !IF_DOCV5
          # Chargement de l'ensemble des applications Industrialisation et Superviseur dans des variables pour la V6 et +
          If  clalev([XIDZ]) : Close Local File  [XIDZ] : Endif
          Local File  =MAC_INDUSPRD+":"+[L]POR_INDUSPRD+"@"+[L]DOS_INDUSPRD+".XIDPRDIND"   [XIDZ]
          Gosub RECH_APPLIS_BOUCLE
          If  clalev([XIDZ]) : Close Local File  [XIDZ] : Endif
        Else
          # Chargement de l'ensemble des applications Industrialisation et Superviseur dans des variables pour la V5
          If  clalev([XIDZ]) : Close Local File  [XIDZ] : Endif
          Local File  =MAC_MNTPRD+":"+[L]POR_MNTPRD+"@"+[L]DOS_MNTPRD+".XIDPRDIND"   [XIDZ]
          Gosub RECH_APPLIS_BOUCLE
          If  clalev([XIDZ]) : Close Local File  [XIDZ] : Endif
        Endif
      Endif
    Endif
    # En clientèle pas de recherche ou si pas de dossiers trouvés: Doit être toujours faux (concaténation du dossier courant avec ZZ)
    [L]APPLIS_INDUS+=string$([L]APPLIS_INDUS ="", "'ZZ"+nomap(0)+"ZZ'")
    [L]APPLIS_SUPER+=string$([L]APPLIS_SUPER ="", "'ZZ"+nomap(0)+"ZZ'")
  Endif
Return

# Boucle de recherche des applications dans XIDPRDIND de INDUSPRD et MNTPRD
$RECH_APPLIS_BOUCLE
    Gosub INIT_XID_FILTER
    Filter [XIDZ] Where  evalue([L]XID_FILTER)
    For [XIDZ]
      If [XIDZ]XCOD=[L]CODE_SUPERV
        [L]APPLIS_SUPER+=string$([L]APPLIS_SUPER<>"",", ")+"'"+[XIDZ]XDOSIND+"'"
      Else
        [L]APPLIS_INDUS+=string$([L]APPLIS_INDUS<>"",", ")+"'"+[XIDZ]XDOSIND+"'"
      Endif
    Next XIDZ
    Filter [XIDZ]
Return

# JPGA-Bug 54028-31/03/2009 : Procedure initialisant les variables testant le tracage
$IF_TRC
    Gosub MAC_TRC
    Gosub RECH_APPLIS_TRC
    If dim(IF_TRC_MAC)<0
       # Machine courante devant etre celle de l'indus
       Local Integer IF_TRC_MAC
       IF_TRC_MAC = left$(toupper(adxmac(-1)),12)=MAC_INDUSPRD    # SAM 103450 : migration nom machine
       # SAM 103450 : migration nom machine
       If !IF_TRC_MAC
          IF_TRC_MAC = left$(toupper(adxmac(-1)),12)=MAC_MNTPRD
       Endif
    Endif

    # JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation
    If dim(IF_TRC_DOSS)<0
       Local Integer IF_TRC_DOSS
       # Dossier courant dans la liste des dossiers devant etre tracés en V5 ou + ?
       #IF_TRC_DOSS = find(nomap(0),'SUPERV150','SUPERV6','X3IND150','X3INDV6','PAYINDV6','ABEIND150','GEOIND150','PAYIND150')
       IF_TRC_DOSS = evalue("find(nomap(0), " + [L]APPLIS_SUPER +", "+ [L]APPLIS_INDUS +")")
    Endif

    If dim(IF_TRC_NOMAP)<0 & dim(NOMAPP)>0
       Local Integer IF_TRC_NOMAP
       # Dossier courant dans la liste des dossiers devant etre tracés en V5 ou + ?
       #IF_TRC_NOMAP = find(NOMAPP,'SUPERV150','SUPERV6','X3IND150','X3INDV6','PAYINDV6','ABEIND150','GEOIND150','PAYIND150')
       IF_TRC_NOMAP = evalue("find(NOMAPP, " + [L]APPLIS_SUPER +", "+ [L]APPLIS_INDUS +")")
    Endif

    If dim(IF_TRC_NOMA2)<0 & dim(NOMAPP)>0
       Local Integer IF_TRC_NOMA2
       # Dossier courant dans la liste des dossiers devant etre tracés en V5 ou + ?
       #IF_TRC_NOMA2 = find(NOMAPP,'X3IND150','X3INDV6','PAYINDV6','ABEIND150','GEOIND150','PAYIND150')
       IF_TRC_NOMA2 = evalue("find(NOMAPP, " + [L]APPLIS_INDUS +")")
    Endif

    If dim(IF_TRC_MERE)<0
       Local Integer IF_TRC_MERE
       # Dossier courant devant être mère et non fille
       IF_TRC_MERE = adxmother(0)=nomap(0) & adxmother(1)=nomap(0) & adxmother(2)=""
    Endif

    If dim(IF_TRC_SUPER)<0
       Local Integer IF_TRC_SUPER
       # element superviseur ?
       #IF_TRC_SUPER = nomap(0)='SUPERV150' | nomap(0)='SUPERV6'
       IF_TRC_SUPER = evalue("find(nomap(0), "+ [L]APPLIS_SUPER +")")
    Endif

    If dim(IF_TRC_MNT)<0
       Local Integer IF_TRC_MNT
       # element MNTPRD ou INDUSPRD ?
       IF_TRC_MNT = nomap(0)=[L]DOS_MNTPRD | nomap(0)=[L]DOS_INDUSPRD
    Endif
Return

# JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation - Init de VERMAJ
$INIT_XID_FILTER
  #JPGA 20/12/2013 EXI-95405-1 : Positionnemùent de VERMAJ en amont afin de pouvoir utiliser les Sous-programmes par d'autres dossiers
  If dim([L]VERMAJ)<=0
    Gosub VERDOC From AGENDOCA
  Endif

  If dim([L]XID_FILTER)<0
    Local Char  XID_FILTER(200)
  Endif
  # Filtre MINIMUN : APPLI cochée A MARQUER et version correspondant au dossier courant
  [L]XID_FILTER=" XTRCFLG=2 & XVERM="+num$([L]VERMAJ)+" "
Return

# JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation - Lecture XID avec XID_FILTER
$RECHERCHES_XID
  Filter [XID] Where  evalue([L]XID_FILTER)
  # Recherche préliminaire pour savoir s'il existe 1/plusierus enregistrements. Sinon : Erreur
  Look [XID] First
  If fstat
    GMESSAGE = "Produit non référencé en industrialisation avec paramètres "-[L]XID_FILTER
    GMESSAGE += "\Pas de trace des modifs de documentations."
    STAT=1
    Return
  Endif

  # Enregistrement du Traçage pour chaque enregistrement trouvé selon XID_FILTER
  For [XID]
    Case [L]TRT_XID
      When "ADO"  :  Gosub ADOTRCPRD
      When "ADF"  :  Gosub ADFTRCPRD
      When "ADZ"  :  Gosub ADZTRCPRD
    Endcase
  Next XID
  Filter [XID]
Return

# JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation - Lecture XID Tous les produits
$TRACAGE_XID_TOUS
  # PRODUIT tous : On doit creer pour 1 par produit + 1 pour le Superviseur
  Gosub INIT_XID_FILTER
  Gosub RECHERCHES_XID
Return

# JPGA-07/09/2011-BUG-76087 - Tracage Docs : Recherche Dynamique des Applications d'industrialisation - Lecture XID Un seul produit selon PRODREF
$TRACAGE_XID_SEUL
  # PRODUIT seul : On doit creer pour 1 produit
  Gosub INIT_XID_FILTER
  Case left$(PRODREF, 1)
    When "X3", "X" : PRODNUM=1  :  # X3           : GPRODUIT=0
    When "PA", "P" : PRODNUM=2  :  # Paye         : GPRODUIT=2
    When "GX", "G" : PRODNUM=3  :  # Geode        : GPRODUIT=1
    When "AB", "A" : PRODNUM=5  :  # Abelx3       : GPRODUIT=3
    When "SU", "S" : PRODNUM=6  :  # Superviseur  : GPRODUIT=-1
    When Default   : PRODNUM=0  :  # Non Reconnu
  Endcase
  [L]XID_FILTER+=string$(dim([L]XID_FILTER)>0, string$([L]XID_FILTER<>"","& ") +"XPRD="+num$(PRODNUM)+" ")

  Gosub RECHERCHES_XID
Return


