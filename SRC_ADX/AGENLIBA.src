##################################################################################
Funprog DOCUMENTATION_VALIDE (VV_LAN, VV_TYP, VV_COD, VV_LEV, VV_SUBLEV)
Value Char       VV_LAN(), VV_TYP() , VV_COD()
Value Integer    VV_LEV  , VV_SUBLEV

# La documentation est elle valide ou pas ? (valide par défaut)

  # Si on a coché la prise en compte des documentation uniquement validées sur le paragraphe : on effectue le test de validité
  If [M]HLPVLD=2
    If VV_LAN<>[AD1]LAN | VV_TYP<>[AD1]TYP | VV_COD<>[AD1]COD | VV_LEV<>[AD1]LEV | VV_SUBLEV<>[AD1]SUBLEV
      Read [AD1]ADO0=VV_LAN;VV_TYP;VV_COD;VV_LEV;VV_SUBLEV
    Endif
    If ([AD1]VLDDAT=[0/0/0] | [AD1]VLDFLG<2)
      End 0
    Endif
  Endif
End 1

##################################################################################
Funprog DOC_NE_PAS_GENERER (GEN_DOC, GEN_LAN, GEN_TYP, GEN_COD)
Value Integer    GEN_DOC
Value Char       GEN_LAN(), GEN_TYP(), GEN_COD()

Local Integer PAS_GENERER
  # Test si la documentation est à générer dans ADOCUMENT ou pas.
  # - En Génération Documentations existantes : Le CODE RETOUR est mis à 1 si la doc n'existe pas
  # - En Génération Toutes Documentations     : Le CODE RETOUR est mis à 0 dans tous les cas pour être Générée
  If !clalev([F:ADO]) : Local File ADOCUMENT  [ADO] : Endif

  [L]PAS_GENERER=(GEN_DOC=3)  # Champs Génération ADOCUMENT du masque courant (Menu Local 2924) : GEN_DOC=3 Documentations existantes
  If  [L]PAS_GENERER
    Look [ADO]ADO0(3)=GEN_LAN;GEN_TYP;GEN_COD
    If !fstat                 # Documentation trouvée
      [L]PAS_GENERER=0
    Endif
  Endif
End   [L]PAS_GENERER

######################################################################################
### Fonctions gérant la nouvelle fonctionnalité V7 de test du groupe du User par rapport au Groupe créateur
######################################################################################
#INIT_GROUPE : Etiquette gestion d'ECRAN : Initialisation zone : [M]CREGRP
$INIT_GROUPE
  If func AGENLIBA.IS_ENV_GROUPE
    If dim([M]CREGRP)>0
      [M]CREGRP=[V]GAGRPDEV
      Call CHGSTL_GROUPE("[M]CREGRP")  From AGENLIBA
      Affzo [M]CREGRP
    Endif
  Endif
Return

#DECL_VALLCREGRP : Etiquette gestion d'ECRAN : Déclaration zone de travail : V_ALLCREGRP
$DECL_VALLCREGRP
  If func AGENLIBA.IS_ENV_GROUPE
    If dim([V]V_ALLCREGRP)<0
      Global Integer V_ALLCREGRP
    Endif
  Endif
Return

#KILL_VALLCREGRP : Etiquette gestion d'ECRAN : Suppression zone de travail : V_ALLCREGRP
$KILL_VALLCREGRP
  If func AGENLIBA.IS_ENV_GROUPE
    If dim([V]V_ALLCREGRP)>0
      Kill [V]V_ALLCREGRP
    Endif
  Endif
Return

#TRACE_COR_ADZ : Etiquette de tracage des mots clés d'aide dans la génération ADOCUMENT (Copie des aides pour Traduction)
$TRACE_COR_ADZ
   #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Marquage Réalisé pour les Ecritures de la Génération ADOCUMENT (On ne le fait que sur TIT en CREATION)
   # Le besoin réside seulement dans la création du Lien OBJET-GROUPE et non le Marquage pour le Pousse-pousse mais TRACE_COR fait les 2 !
   Call TRACE_GROUPE("ADZ", [ADZ]LAN, "", MOTCLE, "C") From AGENLIBA
Return

######################################################################################
####### IS_ENV_GROUPE : Est on en environnement ou les Groupes-Créateurs sont gérés ?
Funprog IS_ENV_GROUPE()

Local Integer RET_CODE : [L]RET_CODE=0

  # CAS d'environnement éligible à la notion de GROUPE de développement :
  #   - Developpement STANDARD
  #   - Fichier sophia-gaillard présent à la racine du dossier
  #   - Paramètre AGRPDEV existant via la globale associée : GAGRPDEV
  #   - Table de lien OBJET-GROUPE (AOBJGRPDEV) présente
  If GADONIX=2 & GSOPHIA & dim([V]GAGRPDEV)>0 & filinfo(filpath("FIL","AOBJGRPDEV","fde"),0)>0
    [L]RET_CODE=1
  Endif
End [L]RET_CODE

####### INIT_ALLCREGRP : Sous-programme gestion d'ECRAN : Initialisation zone en entrée selon le Masque
Subprog INIT_ALLCREGRP(MSK_ZONE)
Value Char MSK_ZONE
  If func AGENLIBA.IS_ENV_GROUPE
    If evalue("dim("+MSK_ZONE+")")>0
       Assign MSK_ZONE With 1
    Endif
  Endif
End

####### TRANS_ALLCREGRP : Sous-programme gestion d'ECRAN : Transfert de zone inter-Masque zone en entrée selon le Masque
Subprog TRANS_ALLCREGRP(MSK_ZONE_OUT, MSK_ZONE_IN)
Value Char MSK_ZONE_OUT, MSK_ZONE_IN
  If func AGENLIBA.IS_ENV_GROUPE
    If evalue("dim("+MSK_ZONE_OUT+")")>0 & evalue("dim("+MSK_ZONE_IN+")")>0
       Assign MSK_ZONE_OUT  With  evalue(MSK_ZONE_IN)
    Endif
  Endif
End

####### CHGSTL_GROUPE : Sous-programme gestion d'ECRAN : Mise en Rouge ou non : Zone en Entrée d'un masque
Subprog CHGSTL_GROUPE(MSK_ZONE)
Value Char MSK_ZONE

  ###### Si on en Environnement éligible : On change le style de la zone
  If func AGENLIBA.IS_ENV_GROUPE
    Case MSK_ZONE
      When "[M]CREGRP"    # On ne fait le changement de style que pour la zone [M]CREGRP et pas d'autres éventuelles zones
        If evalue("dim("+MSK_ZONE+")")>0
          If evalue(MSK_ZONE+'=[V]GAGRPDEV') or evalue(MSK_ZONE+'=""')
            Chgstl [M]CREGRP With ""
          Else
            Chgstl [M]CREGRP With "AWARNHIGH"
          Endif
        Endif
    Endcase
  Endif
End

####### AFFMASK_GROUPE : Sous-programme gestion d'ECRAN : Affichage ou non : Zone en Entrée d'un masque
Subprog AFFMASK_GROUPE(MSK_ZONE)
Value Char MSK_ZONE

Local Char MSK_GROUP(10), MSK_ALLGP(10)
Local Char GROUP_FORMAT(10) : [L]GROUP_FORMAT="10X"   #  Groupe     : 10 caractères Alpha
Local Char GROUP_SUP(10)    : [L]GROUP_SUP   ="-K"    #  Groupe     : Suppression de la zone
Local Char GROUP_AFF(10)    : [L]GROUP_AFF   ="KP"    #  Groupe     : Affichage   de la zone
Local Char ALLGP_FORMAT(10) : [L]ALLGP_FORMAT="1X"    #  ALL Groupe : Menu Local n°1
Local Char ALLGP_SUP(10)    : [L]ALLGP_SUP   ="-K"    #  ALL Groupe : Suppression de la zone
Local Char ALLGP_AFF(10)    : [L]ALLGP_AFF   ="LA"    #  ALL Groupe : Affichage   de la zone

  ###### Si on est pas en Environnement éligible : On masque  la zone
  If ! func AGENLIBA.IS_ENV_GROUPE
    [L]MSK_GROUP=[L]GROUP_SUP
    [L]MSK_ALLGP=[L]ALLGP_SUP
  Else # Si on est     en Environnement éligible : On affiche la zone
    [L]MSK_GROUP=[L]GROUP_AFF
    [L]MSK_ALLGP=[L]ALLGP_AFF
  Endif

  # Modification du format d'affichage de la zone du masque
  Case MSK_ZONE
    When "[M]CREGRP"         : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M]CREGRP         With [L]MSK_GROUP+":"+[L]GROUP_FORMAT : Endif
    When "[M:TRA2]CREGRP"    : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M:TRA2]CREGRP    With [L]MSK_GROUP+":"+[L]GROUP_FORMAT : Endif
    When "[M:TRA3]CREGRP"    : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M:TRA3]CREGRP    With [L]MSK_GROUP+":"+[L]GROUP_FORMAT : Endif
    When "[M]ALLCREGRP"      : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M]ALLCREGRP      With [L]MSK_ALLGP+":"+[L]ALLGP_FORMAT : Endif
    When "[M:DIA]ALLCREGRP"  : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M:DIA]ALLCREGRP  With [L]MSK_ALLGP+":"+[L]GROUP_FORMAT : Endif
    When "[M:TRA4]ALLCREGRP" : If evalue("dim("+MSK_ZONE+")")>0 : Chgfmt [M:TRA4]ALLCREGRP With [L]MSK_ALLGP+":"+[L]GROUP_FORMAT : Endif
  Endcase
End

####### ALIMENT_GROUPE : Sous-programme gestion d'ECRAN : Alimentation de la Zone Groupe
Subprog ALIMENT_GROUPE(OBJET, GEN_LAN, GEN_TYP, GEN_COD,MSK_ZONE)
Value Char OBJET, GEN_LAN, GEN_TYP, GEN_COD, MSK_ZONE
# OBJET   = Abréviation de l'objet à Tracer. Exemple : "ADO" ou "ADZ"
# GEN_LAN    = Langue de Documentation          . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# GEN_TYP    = Type   de Documentation          . Exemple : [F:ADO]TYP ou ""
# GEN_COD    = code   de Documentation          . Exemple : [F:ADO]COD ou [F:ADZ]MOTCLE
# MSK_ZONE= Zone Ecran du groupe           . Exemple : [M]CREGRP ou [M:TRA2]CREGRP

  If func AGENLIBA.IS_ENV_GROUPE
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif

    Case OBJET
      When "ADO"  :  [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
      When "ADZ"  :  [L]DOC_CLE1=GEN_COD  :  [L]DOC_CLE2   =GEN_LAN
    Endcase
    If [L]DOC_CLE1<>"" & [L]DOC_CLE2<>""
      Assign MSK_ZONE With func AGENLIBA.RECH_GROUPE(OBJET, [L]DOC_CLE1, [L]DOC_CLE2)
      Call CHGSTL_GROUPE(MSK_ZONE)  From AGENLIBA
    Endif
  Endif
End

####### TEST_GROUPE_OK : Sous-programme D'appel principal : Test de validité de la zone Groupe (Par défaut : Oui)
Funprog TEST_GROUPE_OK(OBJET, GEN_LAN, GEN_TYP, GEN_COD, VALLCREGRP)
Value Char       OBJET, GEN_LAN(), GEN_TYP(), GEN_COD(), VALLCREGRP()
# OBJET      = Abréviation de l'objet à Tracer  . Exemple : "ADO" ou "ADZ"
# GEN_LAN    = Langue de Documentation          . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# GEN_TYP    = Type   de Documentation          . Exemple : [F:ADO]TYP ou ""
# GEN_COD    = code   de Documentation          . Exemple : [F:ADO]COD ou [F:ADZ]MOTCLE
# VALLCREGRP = Zone contenant la zone ALLCREGRP . Exemple : "[M:DIA]ALLCREGRP"

Local Integer RET_CODE
Local Char    GLOBAL_OBJET

  If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif

  Case OBJET
    When "ADO"  :  [L]GLOBAL_OBJET="ADO" : [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
    When "ADB"  :  [L]GLOBAL_OBJET="ADO" : [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
    When "ADZ"  :  [L]GLOBAL_OBJET="ADZ" : [L]DOC_CLE1=GEN_COD  :  [L]DOC_CLE2   =GEN_LAN
  Endcase

  [L]RET_CODE=func AGENLIBA.IS_GROUPE_OK([L]GLOBAL_OBJET, [L]DOC_CLE1, [L]DOC_CLE2, VALLCREGRP)
  If ![L]RET_CODE     # En cas de Groupe Différent : On affiche un message d'erreur
    If GTRACE <> ""   # En mod Intéractif : on n'affiche Rien car il peut y avoir une succession de DOCs à traiter
      Case OBJET
        When "ADO"  :  Call ECR_TRACE("      ADO"+":"+[L]DOC_CLE2(0)+"~"+[L]DOC_CLE1+"~"+[L]DOC_CLE2(1)-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE([L]GLOBAL_OBJET, [L]DOC_CLE1, [L]
& DOC_CLE2), [V] GAGRPDEV),-1) From GESECRAN
        When "ADB"  :  Call ECR_TRACE("      ADB"+":"+[L]DOC_CLE2(0)+"~"+[L]DOC_CLE1+"~"+[L]DOC_CLE2(1)-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE([L]GLOBAL_OBJET, [L]DOC_CLE1, [L]
& DOC_CLE2), [V] GAGRPDEV),-1) From GESECRAN
        When "ADZ"  :  Call ECR_TRACE("      ADZ"+":"+[L]DOC_CLE2+"~"+[L]DOC_CLE1-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE([L]GLOBAL_OBJET, [L]DOC_CLE1, [L]DOC_CLE2), [V]GAGRPDEV),-1)
& From GESECRAN
      Endcase
    Endif
  Endif
End  [L]RET_CODE

####### MESSAGE_GROUPE : Sous-programme gestion d'ECRAN : Affichage à l'écran d'un message d'alerte de différence de groupe
Subprog MESSAGE_GROUPE(OBJET, GEN_LAN, GEN_TYP, GEN_COD)
Value Char       OBJET, GEN_LAN(), GEN_TYP(), GEN_COD()
# OBJET      = Abréviation de l'objet à Tracer  . Exemple : "ADO" ou "ADZ"
# GEN_LAN    = Langue de Documentation          . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# GEN_TYP    = Type   de Documentation          . Exemple : [F:ADO]TYP ou ""
# GEN_COD    = code   de Documentation          . Exemple : [F:ADO]COD ou [F:ADZ]MOTCLE

  If func AGENLIBA.IS_ENV_GROUPE
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif

    Case OBJET
      When "ADO"  :  [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
      When "ADZ"  :  [L]DOC_CLE1=GEN_COD  :  [L]DOC_CLE2   =GEN_LAN
    Endcase
    If GTRACE=""    # En mode Intéractif seul ! En mode BATCH : une trace a déjà été écrite via la fonction TEST_GROUPE_OK !
      Case OBJET
        When "ADO"  :  Call MESSAGE("ADO"+":"+[L]DOC_CLE2(0)+"~"+[L]DOC_CLE1+"~"+[L]DOC_CLE2(1)-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE(OBJET, [L]DOC_CLE1, [L]DOC_CLE2), [V] GAGRPDEV
& )
& ) From GESECRAN
        When "ADZ"  :  Call MESSAGE("ADZ"+":"+[L]DOC_CLE2+"~"+[L]DOC_CLE1-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE(OBJET, [L]DOC_CLE1, [L]DOC_CLE2), [V] GAGRPDEV)) From GESECRAN
      Endcase
    Endif
  Endif
End

####### IS_GROUPE_OK : Sous-programme D'appel secondaire : Test de validité de la zone Groupe (Par défaut : Oui)
Funprog IS_GROUPE_OK(OBJET, CLE1, CLE2, MSK_ZONE)
Value Char    OBJET, CLE1, CLE2, MSK_ZONE
# OBJET   = Abréviation de l'objet à Tracer. Exemple : "ADO" ou "ADZ"
# CLE1    = Deuxième  champs de Clé        . Exemple : [F:ADO]TYP ou [F:ADZ]LAN
# CLE2(O) = Premier   champs de Clé        . Exemple : [F:ADO]LAN ou [F:ADZ]MOTCLE
# CLE2(1) = Troisième champs de Clé        . Exemple : [F:ADO]COD
# CLE2(n) etc ...
# MSK_ZONE= Zone Ecran "Tous les Groupes"  . Exemple : [M]ALLCREGRP

Local Integer RET_CODE        : [L]RET_CODE=1

  # Par défaut, on sort en OK si on est pas en Environnement éligible à la notion de Groupe
  If func AGENLIBA.IS_ENV_GROUPE
    # Si on ne doit pas prendre tous les groupes mais uniquement ceux correspond au Groupe du USER : on lance le test de groupe
    If evalue("dim("+MSK_ZONE+")")>0 & evalue(MSK_ZONE+"=1")
      Case OBJET
        When "ADO"
          If !clalev([F:ADO_]) : Local File ADOCUMENT  [ADO_] : Endif
          # Si la Doc n'est pas trouvée : On considère que c'est OK (Pour la traduction d'une nouvelle DOC par exemple)
          Look [ADO_]ADO0(3)=CLE2(0);CLE1;CLE2(1)
          If ! fstat                 # Documentation   trouvée
            Call VERIF_GROUPE(OBJET, CLE1, CLE2, [L]RET_CODE) From AGENLIBA
          Endif
        When "ADZ"
          If !clalev([F:ADZ_]) : Local File ADOCFLD            [ADZ_] : Endif
          If !clalev([F:ADZZ]) : Local File =GDOSX3+".ADOCFLD" [ADZZ] : Endif
          # Si la Doc n'est pas trouvée : On considère que c'est OK (Pour la traduction d'une nouvelle DOC par exemple)
          Look   [ADZ_]ADZ0=CLE2(0);CLE1
          If fstat & GDOSX3<>nomap   # Aide sur champs non trouvée : on essaye sur le Dossier Racine s'il est différent
            Look [ADZZ]ADZ0=CLE2(0);CLE1
          Endif
          If ! fstat                 # Aide sur champs trouvée
            Call VERIF_GROUPE(OBJET, CLE1, CLE2, [L]RET_CODE) From AGENLIBA
          Endif
      Endcase
    Endif
  Endif
End  [L]RET_CODE

####### VERIF_GROUPE : Sous-programme D'appel terciaire : Test de validité de la zone Groupe (En retour : Groupe OK ou non)
Subprog VERIF_GROUPE(OBJET, CLE1, CLE2, RETCODE)
Value    Char    OBJET, CLE1, CLE2
Variable Integer RETCODE
# OBJET   = Abréviation de l'objet à Tracer. Exemple : "ADO" ou "ADZ"
# CLE1    = Deuxième  champs de Clé        . Exemple : [F:ADO]TYP ou [F:ADZ]LAN
# CLE2(O) = Premier   champs de Clé        . Exemple : [F:ADO]LAN ou [F:ADZ]MOTCLE
# CLE2(1) = Troisième champs de Clé        . Exemple : [F:ADO]COD
# CLE2(n) etc ...
# RETCODE = Code Retour de recherche Groupe. Exemple : 1 pour OK ou 0 pour KO

Local Char    DOC_GROUPE(50)  :  Raz [L]DOC_GROUPE

  If func AGENLIBA.IS_ENV_GROUPE
    [L]DOC_GROUPE=func AGENLIBA.RECH_GROUPE(OBJET,CLE1,CLE2)
    If [L]DOC_GROUPE<>[V]GAGRPDEV
      RETCODE=0
    Endif
  Endif
End

####### RECH_GROUPE : Sous-programme : Recherche du Groupe Créateur d'objet dans table AOBJGRPDEV [AGD]
Funprog RECH_GROUPE(OBJET,CLE1,CLE2)
Value Char OBJET, CLE1, CLE2
# OBJET   = Abréviation de l'objet à Tracer. Exemple : "ADO"      ou "ADZ"
# CLE1    = Deuxième  champs de Clé        . Exemple : [F:ADO]TYP ou [F:ADZ]MOTCLE
# CLE2(O) = Premier   champs de Clé        . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# CLE2(1) = Troisième champs de Clé        . Exemple : [F:ADO]COD
# CLE2(n) etc ...

Local Char RET_GROUPE(50)  :  Raz [L]RET_GROUPE
Local Char CODOBJ(255)     :  Raz [L]CODOBJ

  If func AGENLIBA.IS_ENV_GROUPE
    If !clalev([F:AGD]) : Local File AOBJGRPDEV  [AGD] : Endif

    Case OBJET
      When "ADO"   :  [L]CODOBJ=CLE2(0)+"~"+CLE1+"~"+CLE2(1)
      When "ADZ"   :  [L]CODOBJ=CLE2+"~"+CLE1
      When Default :  Raz [L]CODOBJ
    Endcase
    If [L]CODOBJ<>""
      Read [AGD]AGD0 = OBJET;[L]CODOBJ
      If !fstat
        [L]RET_GROUPE=[AGD]GRP
      Endif
    Endif
  Endif
End [L]RET_GROUPE

####### TRACE_GROUPE : Sous-programme : Procédure de Tracage des Documentations si on est en Environnement de gestion de GROUPE créateur
Subprog TRACE_GROUPE(OBJET, GEN_LAN, GEN_TYP, GEN_COD, TRA)
Value Char       OBJET, GEN_LAN, GEN_TYP, GEN_COD, TRA
# OBJET      = Abréviation de l'objet à Tracer  . Exemple : "ADO" ou "ADZ"
# GEN_LAN    = Langue de Documentation          . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# GEN_TYP    = Type   de Documentation          . Exemple : [F:ADO]TYP ou ""
# GEN_COD    = code   de Documentation          . Exemple : [F:ADO]COD ou [F:ADZ]MOTCLE)
# TRA        = Mode de marquage                 . Exemple : "A" Annulation / "C" Création / "M" Modification

  If func AGENLIBA.IS_ENV_GROUPE
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif

    Case OBJET
      When "ADO"  :  [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
      When "ADZ"  :  [L]DOC_CLE1=GEN_COD  :  [L]DOC_CLE2   =GEN_LAN
    Endcase
    If [L]DOC_CLE1<>"" & [L]DOC_CLE2<>""
      Call TRACE_COR(OBJET,[L]DOC_CLE1,[L]DOC_CLE2,TRA) From AGENLIBA
    Endif
  Endif
End

####### ALLLAN_GROUPE_OK : Sous-programme gestion d'ECRAN : Procédure de Vérification du Groupe du user par rapport à celui de la Documentation pour Toutes Langues
Funprog ALLLAN_GROUPE_OK(OBJET, GEN_TYP, GEN_COD)
Value Char    OBJET, GEN_TYP, GEN_COD

Local Integer RET_CODE  : [L]RET_CODE=1

  If func AGENLIBA.IS_ENV_GROUPE
    If !clalev([F:ADO_]) : Local File ADOCUMENT  [ADO_] : Endif

    For [ADO_]ADO0(1)    # Boucle par LANGUE : Au premier NON répondu à la question Groupe : On sort !
      If !func AGENLIBA.CONTROLE_GROUPE_OK(OBJET, [ADO_]LAN, GEN_TYP, GEN_COD)
        [L]RET_CODE=0  :  Break
      Endif
    Next ADO_
  Endif
End  [L]RET_CODE

####### CONTROLE_GROUPE_OK : Sous-programme gestion d'ECRAN : Procédure de Vérification du Groupe du user par rapport à celui de la Documentation
Funprog CONTROLE_GROUPE_OK(OBJET, GEN_LAN, GEN_TYP, GEN_COD)
Value Char    OBJET, GEN_LAN, GEN_TYP, GEN_COD

Local Integer RET_CODE  : [L]RET_CODE=1

  If func AGENLIBA.IS_ENV_GROUPE
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif

    Case OBJET
      When "ADO"  :  [L]DOC_CLE1=GEN_TYP  :  [L]DOC_CLE2(0)=GEN_LAN  :  [L]DOC_CLE2(1)=GEN_COD
      When "ADZ"  :  [L]DOC_CLE1=GEN_COD  :  [L]DOC_CLE2   =GEN_LAN
    Endcase
    If [L]DOC_CLE1<>"" & [L]DOC_CLE2<>""
      Call VERIF_GRP(OBJET,[L]DOC_CLE1,[L]DOC_CLE2,[L]RET_CODE) From GOBJET
      # Pour l'instant il n'est pas nécessaire de surcharger d'une 2ième boite de dialogue le message d'alerte !
      #If ! [L]RET_CODE
      #  Case OBJET
      #    When "ADO"  :  GMESSAGE="ADO"+":"+[L]DOC_CLE2(0)+"~"+[L]DOC_CLE1+"~"+[L]DOC_CLE2(1)-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE(OBJET, [L]DOC_CLE1, [L]DOC_CLE2), [V]GAGRPDEV)
      #    When "ADZ"  :  GMESSAGE="ADZ"+":"+[L]DOC_CLE2+"~"+[L]DOC_CLE1-func AFNC.MES2 (mess(111,176,1),func AGENLIBA.RECH_GROUPE(OBJET, [L]DOC_CLE1, [L]DOC_CLE2), [V]GAGRPDEV)
      #  Endcase
      #Endif
    Endif
  Endif
End  [L]RET_CODE
######################################################################################

####### IS_DEVLANG_IMPORT : prend une langue en paramètre et retourne vrai ou faux
#######                     si cette langue est considérée comme une langue de dev
Funprog IS_DEVLANG_IMPORT(PLAN)
Value Char PLAN
Local Integer RETOUR : [L]RETOUR=0

Gosub DEFVAR From AGLOBTRAD

For ILAN=1 To GNBLANSTD
    # import bloqué en FRA dans le dossier de ref
    If nomap=GREFER(ILAN)
      If find(PLAN,'FRA') : [L]RETOUR=1 : Break : Endif
    Endif
Next ILAN

End RETOUR

######################################################################################
### Fonctions gérant la nouvelle fonctionnalité V7 de séparation des Paragraphes de PRE-REQUIS dans un autre fichier HTML
######################################################################################
#PRQ_DEBUT : Etiquette d'initialisation du fichier des PRE-REQUIS si la Documentation est elligible à la séparation des PRE-REQUIS
$PRQ_DEBUT
  Raz [L]PREREQUIS_CREE, [L]FICOUV_STD, [L]FICOUV_PRQ, [L]FICOUV2_STD, [L]FICOUV2_PRQ
  If func AGENLIBA.IS_DOCUMENTATION_PRQ([ADO]LAN, [ADO]TYP, [ADO]COD)
    [L]PREREQUIS_CREE=1
    # Mémorisation du fichier HTML de la documentation courante pour réouverture dans l'Etiquette de FIN de paragraphe
    [L]FICOUV_STD =[L]FICOUV  :  [L]FICOUV2_STD=[L]FICOUV2
    # Mémorisation du flag de Premier paragraphe à traiter pour le fichier Standard
    [L]FIRST_BLK_STD=FIRST_BLK
    # Mémorisation du pointeur en FIN de fichier et Fermeture de l'ancien fichier doc
    [L]FINENR_STD=adxseek("DOC")
    Openo                         Using [DOC]

    # Ouverture du fichier doc des PRE-REQUIS= PRQ_AFC_nomdoc.htm
    [L]NOMFIC_PRQ='PRQ_'+[ADO]TYP+'_'+NOMDOC+".htm"
    [L]FICOUV=REPERT_DOC+SLASH+SOUS_REPERT+SLASH+[L]NOMFIC_PRQ
    Gosub FICOUV_OPEN             From AGENLIBA
    # Mémorisation du fichier HTML de la documentation courante des PRE-REQUIS pour réouverture à chaque paragraphe des PRE-REQUIS
    [L]FICOUV_PRQ =[L]FICOUV  :  [L]FICOUV2_PRQ=[L]FICOUV2
    # Ecriture de l'en-tête  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
    TITRED_STD=TITRED
    TITRED=TITRED-"-"-func AGENADO.MST(116,176)
    [L]MODULED=[ADO]MODULE : ECR_HEADER_DOC=1 : ECR_HEADER_FLD=0 : Gosub ECR_HEADER  From AGENLIBA
    TITRED=TITRED_STD
    # Mémorisation du flag de Premier paragraphe à traiter pour le fichier des PRE-REQUIS
    [L]FIRST_BLK_PRQ=FIRST_BLK
    # Début du texte principal
    Wrseq '    <div id="supportingText">'     Using [DOC]
    # Fermeture du fichier des PRE-REQUIS et positionnement sur l'ancien fichier de DOC
    [L]FINENR_PRQ=adxseek("DOC")
    Openo                         Using [DOC]

    # Ouverture du Fichier de DOC standard
    [L]FICOUV =[L]FICOUV_STD  :  [L]FICOUV2=[L]FICOUV2_STD
    Gosub FICOUV2_APPEND          From AGENLIBA
    Gosub POSITIONNEMENT_STD      From AGENLIBA
  Endif
Return

#PRQ_FIN : Etiquette de fin du fichier des PRE-REQUIS si la Documentation est elligible à la séparation des PRE-REQUIS
$PRQ_FIN
  # ATTENTION : le fichier HTML de DOC a précédement dû être fermé car on ouvre directement celui des PRE-REQUIS ici !
  If [L]PREREQUIS_CREE
    [L]FICOUV =[L]FICOUV_PRQ  :  [L]FICOUV2=[L]FICOUV2_PRQ
    Gosub FICOUV2_APPEND          From AGENLIBA  : # Ouverture du Fichier des PRE-REQUIS en mode APPEND
    Gosub POSITIONNEMENT_PRQ      From AGENLIBA
    Gosub FIN_FIC                 From AGENLIBA  : # Ecriture de la fin du fichier de doc
  Endif
  Raz [L]PREREQUIS_CREE
Return

#POSITIONNEMENT_STD : Après ouverture du Fichier Standard : Positionnement en fin de fichier et restauration des variables necessaires à la suite du traitement
$POSITIONNEMENT_STD
    # Positionnement à la fin du fichier du fichier Standard
    Seek First + [L]FINENR_STD    Using [DOC]
    # Positionnement du flag de Premier paragraphe à traiter pour le fichier Standard
    FIRST_BLK_PRQ=FIRST_BLK  :  FIRST_BLK=FIRST_BLK_STD
Return

#POSITIONNEMENT_PRQ : Après ouverture du Fichier des PRE-REQUIS : Positionnement en fin de fichier et restauration des variables necessaires à la suite du traitement
$POSITIONNEMENT_PRQ
    # Positionnement à la fin du fichier des PRE-REQUIS
    Seek First + [L]FINENR_PRQ    Using [DOC]   : # Positionnement à la fin du fichier
    # Positionnement du flag de Premier paragraphe à traiter pour le fichier des PRE-REQUIS
    FIRST_BLK_STD=FIRST_BLK  :  FIRST_BLK=FIRST_BLK_PRQ
Return

#PRQ_PARAGRAPHE_DEBUT : Etiquette en DEBUT de paragraphe : Si séparation de paragraphe : ouverture fichier des PRE-REQUIS
$PRQ_PARAGRAPHE_DEBUT
  If [L]PREREQUIS_CREE & func AGENLIBA.IS_PARAGRAPHE_PRQ([ADO]TYP, [ADO]PAR, [ADO]LEV)
    # DEBUT des PRE-REQUIS : Paragraphe PRQ : Génération d'un paragraphe PRE-REQUIS avec lien vers fichiers des PRE-REQUIS
    Gosub PRQ_PARAGRAPHE_LIE      From AGENLIBA
    # Fermeture de l'ancien fichier DOC
    [L]FINENR_STD=adxseek("DOC")
    Openo                         Using [DOC]

    # Ouverture du Fichier des PRE-REQUIS
    [L]FICOUV =[L]FICOUV_PRQ  :  [L]FICOUV2=[L]FICOUV2_PRQ
    Gosub FICOUV2_APPEND          From AGENLIBA
    Gosub POSITIONNEMENT_PRQ      From AGENLIBA
    # Génération de la table des matières intermédiaires
    RONG=0
    Gosub TABLE_MAT               From AGENADO
    Raz RONG
  Endif
Return

#PRQ_PARAGRAPHE_FIN : Etiquette en FIN de paragraphe : Si séparation de paragraphe : Fermeture fichier des PRE-REQUIS
$PRQ_PARAGRAPHE_FIN
  If [L]PREREQUIS_CREE & func AGENLIBA.IS_PARAGRAPHE_PRQ([ADO]TYP, [ADO]PAR, [ADO]LEV)
    # Fermeture de l'ancien fichier des PRES-REQUIS
    [L]FINENR_PRQ=adxseek("DOC")
    Openo                         Using [DOC]

    # Ouverture du Fichier de DOC
    [L]FICOUV =[L]FICOUV_STD  :  [L]FICOUV2=[L]FICOUV2_STD
    Gosub FICOUV2_APPEND          From AGENLIBA
    Gosub POSITIONNEMENT_STD      From AGENLIBA
  Endif
Return

#PRQ_PARAGRAPHE_LIE : Pour le fichier HTML standard  et concernant le Paragraphe PRQ : Création d'un lien vers le fichier des PRE-REQUIS
$PRQ_PARAGRAPHE_LIE
  # Attention : On ne teste pas sue le nom du paragraphe : PRQ car il peut s'agir d'un INC, on teste alors sur niveau et sous-niveau
  If func AGENLIBA.IS_TYPE_PRQ([ADO]TYP, [ADO]PAR, [ADO]LEV, [ADO]SUBLEV)
    # Calcul de l'ancre (modification : on la calcule avant le remplacement du code INC (20/3/2006)
    Call ANCRE(NOMANCR,[ADO]PAR,[ADO]LEV,[ADO]SUBLEV) From AGENDOCA
    # Style par défaut = style 3
    If [ADO]STY=0 : [ADO]STY=3 : Endif
    # On n'inclut pas le texte du paragraphe s'il en a 1 ... On ne va générer qu'un lien
    INCLUT_TEXTE=1
    # Génrération du titre du Paragraphe
    If [ADO]TIT<>"!"
      Call ENT_PAR(NOMANCR,0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif

    # Ecriture du lien vers le fichier des PRE-REQUIS en positionnant le lien directement sur le paragraphe conerné dans la page HTML
    Wrseq '          <p><IMG src="SEEREFERTTO" alt="SEEREFERTTO" KEEPS="true" realloc="SEEREFERTTO"/> '+
&     func AFNC.MES1 (func AGENADO.MST(117,176),' <a href="'+[L]NOMFIC_PRQ+'#'+NOMANCR+'">'+func AGENADO.MST(116,176)+'</a>') Using [DOC]
    Wrseq '          </p>'        Using [DOC]
  Endif
Return

#REINIT_HEADER_PRQ : Pour le HEADER du fichier des PRE-REQUIS : on n'affiche que le menu concernant les PRE-REQUIS dans la partie gauche du menu de navigation
$REINIT_HEADER_PRQ
  If [L]PREREQUIS_CREE & [L]FICOUV=[L]FICOUV_PRQ
    If !func AGENLIBA.IS_TYPE_PRQ([AD1]TYP, [AD1]PAR, [AD1]LEV, [AD1]SUBLEV)
      II=0
    Endif
  Endif
Return

#ECR_NAV : Ecriture de la pile des menus de la barre de Navigation en haut de la page HTML
$ECR_NAV
  Wrseq '      <div id="topNBPath">'                        Using [DOC]
  Wrseq '        <p><span>'                                 Using [DOC]
  If [L]PREREQUIS_CREE & [L]FICOUV=[L]FICOUV_PRQ
    # Dans le cas des PRE-REQUIS : Ecriture du titre des PRE-REQUIS à la fin
    For II=IPIL-1 To 1 Step -1
      Wrseq '          '+'<a href="'+PILE_MEN(II)+'.htm">'; Using [DOC]
      Wrseq PILE_NOMEN(II);                                 Using [DOC]
      Wrseq '</a>'+'&nbsp;&gt;&nbsp;'                       Using [DOC]
    Next II
    Wrseq TITRED;                                           Using [DOC]
  Else
    For II=IPIL-1 To 1 Step -1
      Wrseq '          '+string$(II<>1,'<a href="'+PILE_MEN(II)+'.htm">'); Using [DOC]
      Wrseq PILE_NOMEN(II);                                 Using [DOC]
      Wrseq string$(II<>1,'</a>'+'&nbsp;&gt;&nbsp;')        Using [DOC]
    Next II
  Endif
  Wrseq "        &nbsp;</span></p>"                         Using [DOC]
Return

#REINIT_TABLE_STD : Pour la table des matiere du fichier standard HTML : on n'affiche pas les sous-menus des PRE-REQUIS
$REINIT_TABLE_STD
  If [L]PREREQUIS_CREE & [L]FICOUV=[L]FICOUV_STD
    If func AGENLIBA.IS_PARAGRAPHE_PRQ([ADO]TYP, [ADO]PAR, [ADO]LEV)
      II=0
    Endif
  Endif
Return


######################################################################################
####### IS_DOCUMENTATION_PRQ : La Documentation doit elle être traitée en tant que DOC avac séparation des PRE-REQUIS ?
Funprog IS_DOCUMENTATION_PRQ(DOC_LAN, DOC_TYP, DOC_COD)
Value Char    DOC_LAN, DOC_TYP, DOC_COD

Local Integer RET_CODE : [L]RET_CODE=0

  If !clalev([ADO2]) : Local File ADOCUMENT [ADO2] : Endif

  # Recherche pour savoir si la Documentation possède au moins un paragraphe faisant partie des PRE-REQUIS
  Filter [ADO2] Where LAN=DOC_LAN & TYP=DOC_TYP & COD=DOC_COD & (LEV=30 or LEV=100)
  If rowcount([ADO2])>0 & func AGENLIBA.IS_PARAGRAPHE_PRQ(DOC_TYP, 'PRQ', 30)
    [L]RET_CODE=1
  Endif
  Filter [ADO2]
End [L]RET_CODE

######################################################################################
####### IS_PARAGRAPHE_PRQ : Est ce que le paragraphe courant fait partie des PREREQUIS à séparer
Funprog IS_PARAGRAPHE_PRQ(DOC_TYP, DOC_PAR, DOC_LEV)
Value Char    DOC_TYP, DOC_PAR
Value Integer DOC_LEV

Local Integer RET_CODE : [L]RET_CODE=0

  # CAS de documentation éligible à la notion de séparation des paragraphes des PRE-REQUIS :
  #   - Documentation de type : AFC   et   - Niveau de Paragraphes : 30
  If find (DOC_TYP, 'AFC') & find(DOC_LEV, 30, 100)
    [L]RET_CODE=1
  Endif
End [L]RET_CODE

######################################################################################
####### IS_TYPE_PRQ : Est ce que le paragraphe est considéré comme étant le PRQ
Funprog IS_TYPE_PRQ(DOC_TYP, DOC_PAR, DOC_LEV, DOC_SUBLEV)
Value Char    DOC_TYP, DOC_PAR
Value Integer DOC_LEV, DOC_SUBLEV

Local Integer RET_CODE : [L]RET_CODE=0

  # CAS de paragraphe considéré comme PRQ :
  #   - Documentation de Niveau 30 ou 100 et sous-niveau 10 car le paragraphe peut être un type INC
  If func AGENLIBA.IS_PARAGRAPHE_PRQ(DOC_TYP, DOC_PAR, DOC_LEV) & DOC_SUBLEV=10
    [L]RET_CODE=1
  Endif
End [L]RET_CODE

##################################################################################
Funprog TRACAGE_DESACTIVE ()
# Permet on le tracage des DOC dans les tables XXTRCADO et XXTRCADZ de INDUSPRD en V6 et + ?

Local Integer RET_DESACTIVE
  # JPGA 29/10/2013 BUG-93965 : Tracage des DOCS plus realisé suite passage INDUSPRD en V7. (Uniquement pour la V6)
  If IF_DOCV6
    [L]RET_DESACTIVE=1
  Else
    [L]RET_DESACTIVE=0
  Endif
End [L]RET_DESACTIVE

##################################################################################
Funprog LIEN_ERGONOMIE ()
# Permet de retourner le lien sur la page de Documentation Ergonomie
# JPGA-BUG-94339-20/11/2013 : Pour la V7, l'ergonomie doit pointer sur les pages créées par DOM sur le Wiki et converties ensuite en HTML dans GITHUB dans V7DEV

Local Char RET_LINK(80)
  [L]RET_LINK="../../en-US/V7DEV/Ui-convergence-pages.html"
End [L]RET_LINK

##################################################################################
Funprog REMPLACE_VOLUME (IN_REPERT)
Value Char    IN_REPERT ()
# Permet de remplacer un code VOLUME V7 da la table AVOLUME par son chemin complet
# JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.

Local Char OUT_REPERT(GDIMFIC)

   [L]OUT_REPERT=func ASYRSYS._GETFULLPATH(IN_REPERT)
   If [L]OUT_REPERT=""
      [L]OUT_REPERT=IN_REPERT
   Endif
End   [L]OUT_REPERT

