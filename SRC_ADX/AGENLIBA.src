$ADOTRCPRD
##insertion d'une ligne pour un produit
Raz [XTO]
[XTO]XXXVER=[F:XID]XVERX              ##1.5.0##
[XTO]XXXPRD=[F:XID]XCOD               #[L]CODPRD="X3";"PA";"PL"
[XTO]XXXDAT=DATREF
[XTO]XXXTIM=TIMREF
[XTO]XXXCOM=nomap-"("+GUSER+")"-GFONCTION-string$(NOMAPP<>nomap, NOMAPP)
If GFONCTION="GESADO"
    [XTO]XXXCOM-="("
    If dim([M]LAN)>0 : [XTO]XXXCOM-=[M]LAN : Endif
    If dim([M]TYP)>0 : [XTO]XXXCOM-=[M]TYP : Endif
    If dim([M]COD)>0 : [XTO]XXXCOM-=[M]COD : Endif
    If dim([M]LEV)>0 : [XTO]XXXCOM-=num$([M]LEV) : Endif
    If dim([M]SUBLEV)>0 : [XTO]XXXCOM-=num$([M]SUBLEV) : Endif
    [XTO]XXXCOM-=")"
Endif
[XTO]XXXUSR=GUSER
[XTO]XXXLAN=PLANTRA
[XTO]XXXTYP=PTYP
[XTO]XXXCOD=PCOD
Write [XTO]
##si doublons ce n'est pas grave
If fstat & fstat<>3 : Call FSTA("XTO") From GLOCK  : Endif
Return


