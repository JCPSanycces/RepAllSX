###########################################################################
### Procédure de Tracage des Documentations
###########################################################################
Subprog TRACE_COR(OBJET,CLE1,CLE2,TRA)
Value Char OBJET, CLE1, CLE2, TRA
# OBJET   = Abréviation de l'objet à Tracer. Exemple : "ADO"      ou "ADZ"
# CLE1    = Deuxième  champs de Clé        . Exemple : [F:ADO]TYP ou [F:ADZ]MOTCLE
# CLE2(O) = Premier   champs de Clé        . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# CLE2(1) = Troisième champs de Clé        . Exemple : [F:ADO]COD
# CLE2(n) etc ...
# TRA     = Mode de marquage               . Exemple : "A" Annulation / "C" Création / "M" Modification

   # Lancement du Tracage uniquement à partir de la V6 et sur un dossier Interne
   Gosub VERDOC From AGENDOCA
   If !IF_DOCV5
      If GADONIX=2
         Call TRACE_COR(OBJET,CLE1,CLE2,TRA) From GOBJET
      Endif
   Endif
End

###########################################################################
### For SCM : trace des Documentations
###########################################################################

Subprog TRACE_COR_ADO(CLE1,CLE2,TRA)
Value Char CLE1,CLE2,TRA
Local Char DOC_CLE1(250), DOC_CLE2(250)(0..1)
[L]DOC_CLE1=CLE1:  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=CLE2
Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "M")
End

###########################################################################
### Procédure de Lancement du Marquage en cas de copie inter-Dossier SUPERV
###########################################################################
Subprog MARQUAGE_SUPERV(DES_DOS, OBJET, CLE1, CLE2, ACOPMARQFLG)
Value Char DES_DOS, OBJET, CLE1, CLE2
Variable Integer ACOPMARQFLG
# DES_DOS      = Dossier destination de copie   . Exemple : aydaix06:16000@SUPERV6 (SUPERV6 sans machine ni port ne marche pas !)
# OBJET        = Abréviation de l'objet à Tracer. Exemple : "ADO"      ou "ADZ"
# CLE1         = Deuxième  champs de Clé        . Exemple : [F:ADO]TYP ou [F:ADZ]MOCLE
# CLE2(0)      = Premier   champs de Clé        . Exemple : [F:ADO]LAN ou [F:ADZ]LAN
# CLE2(1)      = Troisième champs de Clé        . Exemple : [F:ADO]COD
# CLE2(n)      etc ...

  # Lancement du Marquage uniquement : En Interne et STANDARD et dans le SUPERVISEUR et pour la V6 et +
  If dim(IF_DOCV5)<0  :  Gosub VERDOC  From AGENDOCA  :  Endif
  If !IF_DOCV5 & GSOPHIA  &  GADONIX=2 & ( (find('ADO',OBJET) & CLE2(1)<'X') | (find('ADZ',OBJET) & CLE1<'X') )
    Local Char    DES_USR (GLONALO), DES_PASS(50), DES_LAN(GLONLAN), DES_APPLI(GLONAMC), DES_MACHINE(GLONAMC), TYP_MARQUAGE(1), OPADXD_MESS (250)
    Local Integer ELIGIBLE, ORI_TYPDOS, DES_TYPDOS, OPADXD_OPEN, I, RESULT, POUSSE_STA
    Local Char    DOSSIER, TRACE_CLE (50), POUSSE_TYP(5), POUSSE_OBJ(250)

    Local File   ADOVAL [ADW0]
    If DES_DOS=nomap
      Local File ADOVAL [ADWZ], AUTILIS [AUSZ], ADOCUMENT [ADOZ], ADOCFLD [ADZZ]
    Else
      Local File =DES_DOS+".ADOVAL" [ADWZ], =DES_DOS+".AUTILIS" [AUSZ], =DES_DOS+".ADOCUMENT" [ADOZ], =DES_DOS+".ADOCFLD" [ADZZ]
    Endif
    # TYP_MARQUAGE = Mode de marquage  .Exemple : "A" Annulation / "C" Création / "M" Modification
    [L]TYP_MARQUAGE="M"                # On fixe le type de Marquage à Modification pour ne pas s'embêter.
    #JPGA_2013/10/16_EXI-93252-2 : Problème dans le cas où LOGIN<>USR
    #[L]DES_USR=GUSER
    [L]DES_USR=adxusr
    [L]DES_LAN=GLANGUE
    I=instr(1,DES_DOS,"@")
    If !I               : End : Endif  # Si le Dossier Destination n'est pas distant sous la forme : MACHINE:PORT@APPLI : On ne fait rien
    [L]DES_APPLI  =right$(DES_DOS,I+1)
    [L]DES_MACHINE=left$ (DES_DOS,I-1)

    # Lecture du paramètre TYPDOS dans le Dossier ORIGINE     afin de savoir s'il est de type SUPERVISEUR TYPDOS=0
    Read [ADW0]ADW0 = "";"";"TYPDOS"
    If fstat            : End : Endif  # Le paramètre TYPDOS est inexistant du Dossier ORIGINE : On ne fait rien
    [L]ORI_TYPDOS=val([ADW0]VALEUR)
    # Lecture du paramètre TYPDOS dans le Dossier DESTINATION afin de savoir s'il est de type SUPERVISEUR TYPDOS=0
    Read [ADWZ]ADW0 = "";"";"TYPDOS"
    If fstat            : End : Endif  # Le paramètre TYPDOS est inexistant du Dossier DESTINATION : On ne fait rien
    [L]DES_TYPDOS=val([ADWZ]VALEUR)

    # Le paramètre TYPDOS du Dossier ORIGINE et DESTINATION doivent être de même type SUPERVISEUR tous les 2 ou NON SUPERVISEUR tous les 2
    [L]ELIGIBLE=evalue( '([L]ORI_TYPDOS=[L]DES_TYPDOS) & func AGENLIBA.FICHIER_DANS_DOSSIER(DES_DOS, "FIL", "XXCORT", "fde")' )

    # Si les environnements sont élligibles au Marquage : on peut lencer la procédure de Marquage
    If [L]ELIGIBLE
      If DES_DOS=nomap
        Local File APRODUIT [APDS]
      Else
        Local File =DES_DOS+".APRODUIT" [APDS]
      Endif
      [L]ACOPMARQFLG=0 # Issue 86303 - 2012-12-07
      # Lecture de l'utilisateur courant dans le dossier DESTINATION afin de récupérer son mot de passe
      #JPGA_2013/10/16_EXI-93252-2 : Problème dans le cas où LOGIN<>USR
      #Read [AUSZ]CODUSR=[L]DES_USR
      Read [AUSZ]LOGIN=toupper([L]DES_USR)
      If fstat
        Call MESSAGE(func AFNC.MES1 (mess(106,176,1), DES_DOS)+"\"+func AFNC.MES1 (mess(107,176,1), [L]DES_USR)) From GESECRAN
        End
      Endif
      If dim([F:AUSZ]NEWPAS)>0 : # nouveau cryptage
        [L]DES_PASS=[F:AUSZ]NEWPAS
        If [L]DES_PASS<>""
          Call VARPSE([L]DES_PASS) From GESUSER
        Endif
      Else
        Call DECRYPTO("CRYPT:"+[F:AUSZ]PASSE,[L]DES_PASS) From GESUSER
      Endif
      # Ouverture du Canal de communication vers le Dossier Destination
      Gosub OPADXD_SUPERV_OPEN
      If GERR     :  Call MESSAGE (func AFNC.MES1 (mess(106,176,1), DES_DOS)+"\"+mess(108,176,1)-[L]OPADXD_MESS) From GESECRAN : End : Endif
      # Marquage de la Documentation correspondante via le Canal de communication
      Case OBJET
        When "ADO","ADZ" :
          Gosub OPADXD_MARQUAGE
          If GERR : Call MESSAGE (func AFNC.MES1 (mess(106,176,1), DES_DOS)+"\"+mess(109,176,1)-[L]OPADXD_MESS)  From GESECRAN : End : Endif
          #Gosub OPADXD_POUSSE
      Endcase
      Gosub OPADXD_CLOSE
    Endif
  Endif
End

$OPADXD_SUPERV_OPEN
  [L]OPADXD_OPEN=0
  Gosub    OPADXD_OPEN
  If GERR & [L]OPADXD_OPEN
    Gosub OPADXD_CLOSE
    Gosub OPADXD_OPEN
  Endif
Return

$OPADXD_OPEN
  Raz GERR :  Raz [L]OPADXD_MESS : # Issue 86303 - 2012-12-03 by VPO
  Onerrgo  ERR_OPADXD
  Opadxd [L]DES_MACHINE With [L]DES_APPLI, [L]DES_LAN, [L]DES_USR, [L]DES_PASS Using [EXT]
  Onerrgo
Return

$OPADXD_MARQUAGE
  Onerrgo  ERR_OPADXD
  # JPGA 10/06/2013 Bug-90329 : Correction Marquage suite Split AGENLIB en AGENLIB/AGENLIBA pour implementation code ISO
  If func AGENLIBA.FICHIER_DANS_DOSSIER(DES_DOS, "TRT", "AGENLIBA", "src")
    Calliu "AGENLIBA:TRACE_COR"  With OBJET,CLE1,CLE2,[L]TYP_MARQUAGE  Using [EXT]
  Else
    Calliu "AGENLIB:TRACE_COR"   With OBJET,CLE1,CLE2,[L]TYP_MARQUAGE  Using [EXT]
  Endif
  Onerrgo
Return

$OPADXD_POUSSE
  [L]POUSSE_TYP=OBJET
  Case POUSSE_TYP
      When "ADO"
        [L]TRACE_CLE=" "+OBJET+"~"+CLE2(0)+"~"+CLE1+"~"+CLE2(1)
        [L]POUSSE_OBJ=CLE2(0)+"~"+CLE1+"~"+CLE2(1)
      When "ADZ"
        [L]TRACE_CLE=" "+OBJET+"~"+CLE2(0)+"~"+CLE1
        [L]POUSSE_OBJ=CLE2(0)+"~"+CLE1
   Endcase

   For [APDS] Where ENAFLG=2
      [L]DOSSIER = ctrans(vireblc([F:APDS]FDR,4))
      Onerrgo  ERR_OPADXD
      [L]RESULT = Funciu "INTEGSUB:TYPPRO" Using [EXT] With ([L]DOSSIER)
      Onerrgo
      If GERR : RESULT=-1 : Call ERREUR([L]TRACE_CLE+"\=> "+func AFNC.MES2(mess(114,176,1),[L]DES_DOS,[APDS]COD)+"\"+mess(7,21,1)-"Funciu TYPPRO") From GESECRAN : Endif
      If RESULT<>-1
         Call TEMPON([L]TRACE_CLE+" => "+func AFNC.MES2(mess(113,176,1),[L]DES_DOS,[APDS]COD)) From GESECRAN # transfert depuis $1$ vers $2$
         [L]POUSSE_STA=0
         Onerrgo  ERR_OPADXD
         Calliu = "INTEGCOR:COPIE" With [APDS]COD,[L]POUSSE_TYP,[L]POUSSE_OBJ,[L]POUSSE_STA Using [EXT]
         Onerrgo
         Call TEMPOFF From GESECRAN
         If GERR : [L]POUSSE_STA=-1 : Endif # on met -1 pour préciser que l'erreur est sur le calliu
         # INTEGCOR:COPIE - Test du statut de retour : [L]POUSSE_STA= 2:OK / 1:WARNING,pas de copie) / 0:ERREUR / -1:erreur calliu
         If [L]POUSSE_STA<>2
            #Le transfert depuis $1$ vers $2$ a échoué
            Call ERREUR([L]TRACE_CLE+"\=> "+func AFNC.MES2(mess(114,176,1),[L]DES_DOS,[APDS]COD)+"\"+mess(7,21,1)-"STA :"-num$([L]POUSSE_STA)) From GESECRAN
         Endif
      Endif
   Next APDS
Return

$OPADXD_CLOSE
  Opadxd Using [EXT]
Return

$ERR_OPADXD
  # erreur 126 : canal en cours utilisation il faut fermer avant
  If errn=126 & ![L]OPADXD_OPEN : # Canal en cours d'utilisation (consécutif à un plantage précédent du TRT...)
    GERR = 1  :  [L]OPADXD_OPEN=1
  Else
    GERR = 1  :  [L]OPADXD_MESS=errmes$(errn)-string$(errm<>errmes$(errn),errm)+"\"+errp+"("+num$(errl)+")"
  Endif
Resume

###########################################################################
### Procédure de Test pour savoir si un Dossier distant contient un fichier dans un sous-répertoire
###########################################################################
Funprog FICHIER_DANS_DOSSIER(DES_DOS, DES_REP, DES_FIC, DES_EXT)
Value Char      DES_DOS, DES_REP, DES_FIC, DES_EXT
# DES_DOS = Dossier destination de copie        . Exemple : aydaix06:16000@SUPERV6 (SUPERV6 sans machine ni port ne marche pas !)
# DES_REP = Sous-répertoire distant de recherche. Exemple : "FIL"
# DES_FIC = Abréviation du fichier à rechercher . Exemple : "AMOTCLE"
# DES_EXT = Extension   du fichier à rechercher . Exemple : "fde"

  Local Char    DES_APP(GLONADS), DES_MAC(GLONAMC)
  Local Integer I
  Local Integer RET_CODE : [L]RET_CODE=0

  # Recherche découpage : MAC:PORT@APPLI
  I=instr(1,DES_DOS,"@")
  If I  # Si le Dossier Destination est distant sous la forme : MACHINE:PORT@APPLI
    [L]DES_APP=right$(DES_DOS,I+1)
    [L]DES_MAC=left$ (DES_DOS,I-1)
  Else
    [L]DES_APP=DES_DOS
    [L]DES_MAC=""
  Endif

  If filinfo(filpath(DES_REP, DES_FIC, DES_EXT, [L]DES_APP, "", [L]DES_MAC),0)<0
    [L]RET_CODE=0
  Elsif dim(GSOPHIA)>0 & GSOPHIA>0 & [L]DES_APP="REPOSX3"
    [L]RET_CODE=0
  Else
    [L]RET_CODE=1
  Endif
End [L]RET_CODE


###########################################################################
### Procédures de gestion des clé multiples pour la Documentation
###########################################################################

# JPGA 19/08/2009 Bug-52238 : Procedure initialisant les variables testant les clé multiples selon le type de doc et Ouverture de l'objet
$DOC_RECH_CLE_MULTIPLE
# En entrée : DOC_TYPE = type de documentation
# En sortie : IF_DOCTABLE = Si le type de doc est une table
#             DOC_CLE1, DOC_CLE2, DOC_CLE3, DOC_CLE4 = 1 à 4 clés
Local Integer I, IF_DOC_TABLE
Local Char    DOC_CLE1(2*GLONAVA), DOC_CLE2(2*GLONAVA), DOC_CLE3(2*GLONAVA), DOC_CLE4(2*GLONAVA)
Local Char    WPLUS(1) : [L]WPLUS="+"

  Raz IF_DOC_TABLE, DOC_CLE1, DOC_CLE2, DOC_CLE3, DOC_CLE4
  If !clalev([AOB]) : Local File AOBJET  [AOB] : Endif
  If !clalev([ATB]) : Local File ATABLE  [ATB] : Endif
  If !clalev([ATI]) : Local File ATABIND [ATI] : Endif

  # Recherche du premier Index trouvé de la table courante
  Read [AOB]ABREV=DOC_TYPE
  If !fstat & [F:AOB]NOMFIC<>"" & filinfo(filpath("FIL",[F:AOB]NOMFIC,"fde"),0)>=0
    IF_DOC_TABLE=1

    Read [ATB]CODFIC=[F:AOB]NOMFIC
    If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")<=0
      Local File =[F:AOB]NOMFIC
    Endif
    Read [ATI]NUMLIG(2)=[F:AOB]NOMFIC;1

    # JPGA 19/08/2009 Bug-52238 : Prise en compte des clé Multiples pour les types de docs le nécessitant
    # Recherche de 4 champs de la clé au maximum qui est sous la forme : CHAMPS1+CHAMPS2+CHAMPS3+CHAMPS4
    I = instr(1, [F:ATI]DESCRIPT, [L]WPLUS)
    If I
      DOC_CLE1 =  left$([F:ATI]DESCRIPT,I-1)
      DOC_CLE2 = right$([F:ATI]DESCRIPT,I+1)
      I =  instr(1, DOC_CLE2, [L]WPLUS)
      If I
        DOC_CLE3 = right$(DOC_CLE2,I+1)
        DOC_CLE2 =  left$(DOC_CLE2,I-1)
        I =  instr(1, DOC_CLE3, [L]WPLUS)
        If I
          DOC_CLE4 = right$(DOC_CLE3,I+1)
          DOC_CLE3 =  left$(DOC_CLE3,I-1)
          I =  instr(1, DOC_CLE4, [L]WPLUS)
          If I
            DOC_CLE4 = left$(DOC_CLE4,I-1)
          Endif
        Endif
      Endif
    Else
      DOC_CLE1 = [F:ATI]DESCRIPT
    Endif
  Endif

  If !clalev([AOB]) : Close Local File  [AOB] : Endif
  If !clalev([ATB]) : Close Local File  [ATB] : Endif
  If !clalev([ATI]) : Close Local File  [ATI] : Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procedure Alimentant les clés multiples des types de documentation
$DOC_ALIM_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
#             DOC_TYPE = type de documentation
#           : DOC_CLE1, DOC_CLE2, DOC_CLE3, DOC_CLE4 = 1 à 4 clés
Local Integer I
Local Char    DOC_CLE(2*GLONAVA), VALCLE(30), VALCLE2(30)

   Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
   # JPGA 19/08/2009 Bug-52238 : Alimentation de clé multiples pour lecture du fichier de table
   # Alimentation de l'index par le code DOC avant lecture pour 4 champs de clé au maximum qui est sous la forme : CHAMPS1_CHAMPS2_CHAMPS3_CHAMPS4
   # JPGA 28/09/2009 Bug-58132 : Bug d'alimentation si "_" trouvé dans le code alors qu'il ne s'agit pas de clé multiple (exemple: AGB)
   DOC_CLE = DOC_CLE1 : VALCLE  = DOC_CODE : VALCLE2 = DOC_CODE
   I = instr(1,VALCLE2,[L]WTIRET)
   If !I or DOC_CLE2 = ""
      Gosub DOC_ALIM_DOC_CLE2
   Else
      Gosub DOC_ALIM_DOC_CLE
      DOC_CLE = DOC_CLE2
      I=instr(1,VALCLE2,[L]WTIRET)
      If !I or DOC_CLE3 = ""
         Gosub DOC_ALIM_DOC_CLE2
      Else
         Gosub DOC_ALIM_DOC_CLE
         DOC_CLE = DOC_CLE3
         I=instr(1,VALCLE2,[L]WTIRET)
         If !I or DOC_CLE4 = ""
            Gosub DOC_ALIM_DOC_CLE2
         Else
            Gosub DOC_ALIM_DOC_CLE
            DOC_CLE = DOC_CLE4
            I=instr(1,VALCLE2,[L]WTIRET)
            If !I
               Gosub DOC_ALIM_DOC_CLE2
            Else
               Gosub DOC_ALIM_DOC_CLE
            Endif
         Endif
      Endif
   Endif
Return

$DOC_ALIM_DOC_CLE
   VALCLE  =  left$(VALCLE2,I-1)
   VALCLE2 = right$(VALCLE2,I+1)

   Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE+")")
      When 1,2,4,5,6,7 : Assign "[F:"+DOC_TYPE+"]"+DOC_CLE With val(VALCLE)
      When Default     : Assign "[F:"+DOC_TYPE+"]"+DOC_CLE With VALCLE
   Endcase
Return

$DOC_ALIM_DOC_CLE2
   Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE+")")
      When 1,2,4,5,6,7 : Assign "[F:"+DOC_TYPE+"]"+DOC_CLE With val(VALCLE2)
      When Default     : Assign "[F:"+DOC_TYPE+"]"+DOC_CLE With VALCLE2
   Endcase
Return

# JPGA 19/08/2009 Bug-52238 : Procedure Alimentant les clés multiples pour les Action de Sélection
$DOC_SEL_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
#             DOC_TYPE = type de documentation
#           : DOC_CLE1, DOC_CLE2, DOC_CLE3, DOC_CLE4 = 1 à 4 clés
# En sortie : DOC_EXPR = expression du type : [F:CDE]COD="CCA" & [F::CDE]CPY=""
Local Char    DOC_EXPR(100)
Local Integer I

   Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
   # ATTENTION : Il faut que la doc. soit comme l'index par défaut (ligne 1 du tableau des Index) selon l'ordre : Cle1 Cle2 Cle3 Cle4
   If DOC_CLE1 <> ""
     I = instr(1,DOC_CODE,[L]WTIRET)
     If !I
       I = len(DOC_CODE)+1
     Endif
     Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE1+")")
       When 1,2,4,5,6,7 : [L]DOC_EXPR ='[F:'+DOC_TYPE+']'+DOC_CLE1+'='+val(left$(DOC_CODE,I-1))
       When Default     : [L]DOC_EXPR ='[F:'+DOC_TYPE+']'+DOC_CLE1+'="'+left$(DOC_CODE,I-1)+'"'
     Endcase
     DOC_CODE=right$(DOC_CODE,I+1)
   Endif

   If DOC_CLE2 <> ""
     I = instr(1,DOC_CODE,[L]WTIRET)
     If !I
       I = len(DOC_CODE)+1
     Endif
     Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE2+")")
       When 1,2,4,5,6,7 : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE2+'='+val(left$(DOC_CODE,I-1))
       When Default     : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE2+'="'+left$(DOC_CODE,I-1)+'"'
     Endcase
   Endif

   If DOC_CLE3 <> ""
     I = instr(1,DOC_CODE,[L]WTIRET)
     If !I
       I = len(DOC_CODE)+1
     Endif
     Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE3+")")
       When 1,2,4,5,6,7 : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE3+'='+val(left$(DOC_CODE,I-1))
       When Default     : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE3+'="'+left$(DOC_CODE,I-1)+'"'
     Endcase
   Endif

   If DOC_CLE4 <> ""
     I = instr(1,DOC_CODE,[L]WTIRET)
     If !I
       I = len(DOC_CODE)+1
     Endif
     Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE4+")")
       When 1,2,4,5,6,7 : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE4+'='+val(left$(DOC_CODE,I-1))
       When Default     : [L]DOC_EXPR-='&'-'[F:'+DOC_TYPE+']'+DOC_CLE4+'="'+left$(DOC_CODE,I-1)+'"'
     Endcase
   Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procedure re retour de sélection alimentant VALEUR pour les clés multiples des Actions de Sélection
$DOC_FIN_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
#             DOC_TYPE = type de documentation
#           : DOC_CLE1, DOC_CLE2, DOC_CLE3, DOC_CLE4 = 1 à 4 clés
# En sortie : DOC_EXPR = expression du type : Cle1_Cle2_Cle3_Cle4
Local Char    DOC_EXPR(100)
Local Integer I

   Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
   # Si la valeur n'est pas sous la forme : Cle1_Cle2_Cle3_Cle4, on la reconstitue pour qu'elle soit ainsi
   # ATTENTION : Il faut que l'index par défaut (ligne 1 du tableau des Index) soit aussi selon l'ordre : Cle1 Cle2 Cle3 Cle4
   I = instr(1,DOC_CODE,[L]WTIRET)
   If !I
     If DOC_CLE1 <> ""
        Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE1+")")
          When 1,2,4,5,6,7 : [L]DOC_EXPR = num$(evalue('[F:'+DOC_TYPE+']'+DOC_CLE1))
          When Default     : [L]DOC_EXPR = evalue('[F:'+DOC_TYPE+']'+DOC_CLE1)
       Endcase
     Endif

     If DOC_CLE2 <> ""
       Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE2+")")
         When 1,2,4,5,6,7 : [L]DOC_EXPR+=[L]WTIRET+num$(evalue('[F:'+DOC_TYPE+']'+DOC_CLE2))
         When Default     : [L]DOC_EXPR+=[L]WTIRET+evalue('[F:'+DOC_TYPE+']'+DOC_CLE2)
       Endcase
     Endif

     If DOC_CLE3 <> ""
       Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE3+")")
         When 1,2,4,5,6,7 : [L]DOC_EXPR+=[L]WTIRET+num$(evalue('[F:'+DOC_TYPE+']'+DOC_CLE3))
         When Default     : [L]DOC_EXPR+=[L]WTIRET+evalue('[F:'+DOC_TYPE+']'+DOC_CLE3)
       Endcase
     Endif

     If DOC_CLE4 <> ""
       Case evalue("type([F:"+DOC_TYPE+"]"+DOC_CLE4+")")
         When 1,2,4,5,6,7 : [L]DOC_EXPR+=[L]WTIRET+num$(evalue('[F:'+DOC_TYPE+']'+DOC_CLE4))
         When Default     : [L]DOC_EXPR+=[L]WTIRET+evalue('[F:'+DOC_TYPE+']'+DOC_CLE4)
       Endcase
     Endif
     If [L]DOC_EXPR=[L]WTIRET or [L]DOC_EXPR=string$(2,[L]WTIRET)  or [L]DOC_EXPR=string$(3,[L]WTIRET) or [L]DOC_EXPR=string$(4,[L]WTIRET)
        [L]DOC_EXPR = [L]DOC_CODE
     Endif
   Else
     [L]DOC_EXPR = [L]DOC_CODE
   Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procedure d'initialisation de variable pour connaitre les Docs à cle multiple !!! A UTILISER PARTOUT !!!
$DOC_INIT_CLE_MULTIPLE
# En sortie : DOC_CLE_MULT = tableau des Docs à clé multiples
   If dim([L]DOC_CLE_MULT)<0
      # Initialisation de la variable contenant la liste des Docs sur clé multiple
      Gosub VERDOC From AGENDOCA
      Local Char   DOC_CLE_MULT(50)(1..50)
      # JPGA 06/10/2009 Bug-57459 : ATTENTION pour la PAYE V6 : la clé est resté simple pour les CDE : code section
      If IF_DOCV5                    # Saisir ici les Objets V5      à clé multiples
        [L]DOC_CLE_MULT(1)="ASU"
      Else                           # Saisir ici les Objets V6 et + à clé multiples
        Case GPRODUIT                # Exception de la PAYE V6 pour les CDE !!!
          When 2
            [L]DOC_CLE_MULT(1)="ASU"
          When Default
            [L]DOC_CLE_MULT(1)="ASU"
            [L]DOC_CLE_MULT(2)="CDE"
        Endcase
      Endif
   Endif
   If dim([L]WTIRET)<0
      Local Char   WTIRET(1) : [L]WTIRET="_"
   Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procédure en saisie permettant de savoir si une DOC de clé multiple contient le caractère _
$DOC_CONT_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
#             DOC_TYPE = type de documentation
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find([L]DOC_TYPE, [L]DOC_CLE_MULT)  &  !instr(0, [L]DOC_CODE, [L]WTIRET)
    GMESSAGE=mess(42,0,1)-[L]DOC_TYPE-':'-mess(117,141,1)-[L]WTIRET
    mkstat=2
  Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procedure pour Actions permettant de scinder la clé en 2 selon Cle2 et Cle1~Cle3~Cle4
# Utilisé pour l'action CONTOBJ du SUBADF ou ATUNDOC de SUBADO
$DOC_ACT_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
# En sortie : DOC_EXPR = expression du type : Cle2
#           : DOC_EXPR2= expression du type : Cle1~Cle3~Cle4
Local Char    VALCLE(GLONAVA),DOC_EXPR(100), DOC_EXPR2(100)
Local Char    WTILD(1)  : [L]WTILD="~"
Local Integer I

   Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
   # Si la valeur est sous la forme : Cle1_Cle2_Cle3_Cle4, on extrait les valeurs
   # ATTENTION : Il faut que l'index par défaut (ligne 1 du tableau des Index) soit aussi selon l'ordre : Cle1 Cle2 Cle3 Cle4
   I = instr(1,DOC_CODE,[L]WTIRET)
   If !I
     [L]DOC_EXPR=DOC_CODE
   Else
     [L]DOC_EXPR2= left$(DOC_CODE,I-1)
     [L]VALCLE   = right$(DOC_CODE,I+1)
     I = instr(1,[L]VALCLE,[L]WTIRET)
     If !I
        [L]DOC_EXPR=[L]VALCLE
     Else
        [L]DOC_EXPR  =left$([L]VALCLE,I-1)
        [L]VALCLE    =ctrans(right$([L]VALCLE,I+1),[L]WTIRET,[L]WTILD)
        [L]DOC_EXPR2+=[L]WTILD+[L]VALCLE
     Endif
   Endif
Return

# JPGA 19/08/2009 Bug-52238 : Procedure pour Lecture vers ATEXTRA pour scinder la clé en 2 selon CLECUR1 et CLECUR2
$DOC_AXX_CLE_MULTIPLE
# En entrée : DOC_CODE = code de documentation
#             DOC_TYPE = type de documentation
#             NOMFIC   = Table ayant les AXX a aller rechercher
#             NOMINT   = Champs de type AXX a rechercher
# En sortie : DOC_EXPR = expression du type : valeur de CLECUR1 de la donnee AXX
#           : DOC_EXPR2= expression du type : valeur de CLECUR2 de la donnee AXX
Local Char    DOC_EXPR(100), DOC_EXPR2(100)

# ATTENTION : CLECUR1 ou CLECUR2 doivent obligatoirement être décrits dans la description de la table sous la forme :
#             ZONE ou "" (et pas [F]ZONE ni [F:XXX]ZONE ou autre chose, sinon le code plantera : on evalue directement)
   If !clalev([F:AMP]) : Local File AMSKPAR [AMP] : Endif

   Read [AMP]CODPAR=2;NOMFIC;NOMINT;"CLECUR1"
   If !fstat & [F:AMP]VALPAR<>'""'
      [L]DOC_EXPR=evalue("[F:"+[L]DOC_TYPE+"]"+[F:AMP]VALPAR)
   Else
      [L]DOC_EXPR=[L]DOC_CODE
   Endif

   Read [AMP]CODPAR=2;NOMFIC;NOMINT;"CLECUR2"
   If !fstat & [F:AMP]VALPAR<>'""'
      [L]DOC_EXPR2=evalue("[F:"+[L]DOC_TYPE+"]"+[F:AMP]VALPAR)
   Else
      [L]DOC_EXPR2=""
   Endif
Return


###########################################################################
### Procédures de gestion du Répertoire initialisé par le paramètre DIRDOC
###########################################################################

# JPGA 09/04/2010 Bug-51883 : Procedure pour Controler l'existence du repertoire d'extraction sur un poste local. Appelé depuis Action CONTROLE
Subprog CONTROLE_REPERTOIRE(DOC_REPERT, DOC_LAN, DOC_CODERET, TEST_SOUSREP)
Value Char       DOC_REPERT(), DOC_LAN()
Value Integer    TEST_SOUSREP
Variable Integer DOC_CODERET
# En entrée : DOC_REPERT  = Repertoire de documentation au format #@ ou MACHINE:PORT ou [VOLUME]
#             DOC_LAN     = Langue
#             TEST_SOUSREP= 1 on fait un test de création de fichier / 0 pas de test de fait
# En sortie : DOC_CODERET = Code retour pour savoir si le Repertoire est OK ou non

Local Char       MACHINE(GDIMFIC), DOC_REP(GDIMFIC), DOC_FIC(GDIMFIC), OS(10), DOC_REPTOTAL(GDIMFIC)
Local Integer    I, II, ER
   DOC_CODERET=0
   Gosub DECL_COMVAR From AGENLIBA

   II = instr(1,DOC_REPERT,"%")
   If II
     #JPGA 2013/12/11 BUG-95146 : Activation Code-ISO en V7 + Changement caractère - en _
     If dim (GISO_COD_LAN) >=0
       If GISO_COD_LAN <> ""
         [L]DOC_REP=left$(DOC_REPERT,II-1)+GISO_COD_LAN+right$(DOC_REPERT,II+1)
       Else
         [L]DOC_REP=left$(DOC_REPERT,II-1)+DOC_LAN     +right$(DOC_REPERT,II+1)
       Endif
     Else
         [L]DOC_REP=left$(DOC_REPERT,II-1)+DOC_LAN     +right$(DOC_REPERT,II+1)
     Endif
   Else
     [L]DOC_REP=DOC_REPERT
   Endif

   # JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
   [L]DOC_REPTOTAL=func AGENLIBA.REMPLACE_VOLUME ([L]DOC_REP)

   # Controle sur le contenu en fonction de l'OS de la machine destination
   Call MACHINE([L]DOC_REPTOTAL,MACHINE,[L]DOC_FIC) From ORDSYS
   Call GET_OS (MACHINE,OS)                         From ORDSYS
   Case OS
     When "unix"
            For I=1 To len([L]DOC_FIC)
              If find(mid$([L]DOC_FIC,I,1), "\", "<", ">", "|", "*", "?")
                DOC_CODERET=2 : End
              Endif
            Next I
     When Default
            For I=1 To len([L]DOC_FIC)
              If find(mid$([L]DOC_FIC,I,1), "/", "<", ">", "|", "*", "?")
                DOC_CODERET=3 : End
              Endif
            Next I
   Endcase
   If left$([L]DOC_REPTOTAL,2)<>"#@"   # Serveur
      Call ABSOLU([L]DOC_REPTOTAL,II) From ORDSYS
      If II
         DOC_CODERET=4 : End
      Endif
   Endif

   # Si le Test de sous-répertoire est activé : On le lance en essayant de créer un fichier
   If TEST_SOUSREP
     Call CONTROLE_SOUS_REPERTOIRE([L]DOC_REPTOTAL, DOC_CODERET)
     If [L]DOC_CODERET : End : Endif
   Endif
End

# JPGA 09/04/2010 Bug-51883 : Procedure pour Controler l'existence du repertoire d'extraction sur un poste local. Appelé depuis Action CONTROLE
Subprog CONTROLE_SOUS_REPERTOIRE(DOC_REPERT, DOC_CODERET)
Value Char       DOC_REPERT()
Variable Integer DOC_CODERET
# En entrée : DOC_REPERT  = Repertoire de documentation complet
# En sortie : DOC_CODERET = Code retour pour savoir si le Test de sous-Repertoire est OK ou non

Local Char       MACHINE(GDIMFIC), DOC_FIC(GDIMFIC), OS(10)

   Call MACHINE(DOC_REPERT,MACHINE,[L]DOC_FIC) From ORDSYS
   Call GET_OS(MACHINE,OS) From ORDSYS

   Gosub DECL_COMVAR       From AGENLIBA

   SLASH  = string$(instr(1,DOC_REPERT,"\")=0,"/")+string$(instr(1,DOC_REPERT,"\")<>0,"\")
   FICOUV = DOC_REPERT+SLASH+"AGENLIB.tmp"

   # On crée éventuellement l'arborescence permettant le tester l'écriture d'un fichier
   Gosub TEST_SOUS_REPERT From AGENDOCA

   Onerrgo ERR_REPERT
   # Test Création du fichier par Ouverture Output
   Openo   FICOUV,0 Using [AREP]
   #Gosub   SUITE_REPERT
   Goto   SUITE_REPERT

$ERR_REPERT
   DOC_CODERET=1

$SUITE_REPERT
   Onerrgo
   Openo Using [AREP]

   # S'il existe, on le supprime
   MM = instr(1,FICOUV,"@")
   If filinfo(FICOUV,0) > 0
      If MM
         ORSY = 'ae_rm'-'"'+right$(FICOUV,MM+1)+'"'
      Else
         ORSY = 'ae_rm'-'"'+FICOUV+'"'
      Endif
      Call SYSTEME(MACHINE,ORSY,"",II) From ORDSYS
   Endif
   # En erreur de création de fichier et Si le répertoire de dernier niveau n'existait pas auparavant, on le supprime
   If [L]DOC_CODERET and ! EXISTE
      If MM
         ORSY = 'ae_rmdir'-'"'+right$(DOC_REPERT,MM+1)+'"'
      Else
         ORSY = 'ae_rmdir'-'"'+DOC_REPERT+'"'
      Endif
      Call SYSTEME(MACHINE,ORSY,"",II) From ORDSYS
   Endif

$END_REPERT
End

# JPGA 09/04/2010 Bug-51883 : Appel à la procédure de recherche du Répertoire html ou xml d'extraction
Subprog INIT_REPERT_LAN(REPERTOIRE, TYPE_EXTRACT)
Value    Char TYPE_EXTRACT ()
Variable Char REPERTOIRE ()
Local Char    COD_LAN(GLONLAN), SLASH(1)

   # Initialisation de REPERT_DOC et SLASH avec utilisation de COD_LAN
   [L]COD_LAN="%"
   Gosub REPERT_LAN From AGENDOCA

   Case TYPE_EXTRACT
     When "xml"
      If REPERTOIRE=""
         If dim(GREPDOC)>0 & GREPDOC<>""
            REPERTOIRE = GREPDOC+GREPDOC1+SLASH+"xml"
         Elsif dim(GDIRDOC)>0
            REPERTOIRE = GDIRDOC+SLASH+"xml"
         Endif
      Endif
     When "html"
         REPERTOIRE = REPERT_DOC
     When Default
   Endcase
End

###########################################################################
### Procédures de Recherche dynamique des intitulés des Tables selon ATABLE
###########################################################################

# JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE
Funprog RECH_DESIGNATION(IN_ABREV, IN_CODE, IN_CLESUITE)
Value    Char IN_ABREV(), IN_CODE(), IN_CLESUITE

   If dim([V]COD_LAN)>0 & [V]COD_LAN <> ""               # ATTENTION : [V]COD_LAN doit être Initialisé sinon, on ne peut pas traduire !
      Read [ATB]ABRFIC = left$(IN_ABREV,3)               # Lecture de ATABLE selon l'abbréviation de la table à rechercher
      If !fstat
         Read [ATZ]CODZONE = [ATB]CODFIC ; [ATB]INTIT    # Lecture de ATABZON pour rechercher le type du champs Intitulé
         If !fstat
            If find([ATZ]CODTYP,"AXX","AX1","AX2","AX3") # Si le champs intitulé de la table est un AXX : Recherche du texte traduit
               End func AGENADO.RDX([ATB]CODFIC, [ATB]INTIT, IN_CODE, IN_CLESUITE)
            Else
               End evalue("[F:"+IN_ABREV+"]"+[ATB]INTIT) # Sinon, on évalué directement le champs Intitulé de la table
            Endif
         Endif
      Endif
   Endif
End ""


###########################################################################
### Procédures de Tri des écrans et des blocs d'écran pour les générations
###########################################################################
# Tri des différents onglets de la fenêtre dans l'ordre d'apparition
$TRI_FENETRE_ONGLET
    For II=1 To [AWI]NBMSK
        ONG_NOM(II)=[AWI]NOMMSK(II-1)
        ONG_RG(II)=[AWI]ROWMSK(II-1)
        ONG_NO(II)=II
        ONG_ACT(II)=[AWI]ACTMSK(II-1)
    Next II
    Sorta [AWI]NBMSK ONG_RG,ONG_NOM,ONG_NO,ONG_ACT
Return

# JPGA 06/04/2011 Bug-71500 : Tri des Blocs des onglets par Position du Bloc dans l'écran et non selon l'induce de ligne dans le masque
$TRI_ONGLET_BLOC

  # Tri des différents Blocs de l'onglet dans l'ordre d'apparition selon la Position du Bloc; Les Blocs invisibles ne sont pas comptés
  Sorta NBB ONG_BLOC, ONG_NO_2
Return

###########################################################################
### Procédures de Contrôle en Génération ADOCUMENT
###########################################################################
Subprog CONTROLE_TOUTES_DOC(GENERATION, ALL_TYP, DOC_TYP, DOC_DEB, DOC_FIN)
Value Integer GENERATION, ALL_TYP
Value Char    DOC_TYP(),  DOC_DEB(), DOC_FIN()

  #JPGA 12/12/2011 BUG-78621 : Affinage du controle de Génération ADOCUMENT sur une plage de DOC.
  # En génération ADOCUMENT : on lance un message d'alerte si Touts la génération est sélectionnée avec un seul code DOC
  # Test : Genération ADOCUMENT et code DOC portant une plage de DOC et Type de DOC n'étant pas sur les types gérés en plage
  If GENERATION = 2  &  (DOC_DEB="" | DOC_FIN="" | DOC_DEB<>DOC_FIN )
     If ALL_TYP=2  | !find(DOC_TYP, 'APM','ATD','AT3','ATB','AML','ATY','PLA','MC')
        # ATTENTION : La génération ADOCUMENT va être lancée pour plus d'un objet. Voulez vous continuer ?
        [V]GMESSAGE=func AFNC.MES2 (mess(98,176,1), DOC_DEB, DOC_FIN)+"\"+mess(100,176,1)
        GERR=3
     Endif
  Endif
End

Subprog CONTROLE_TOUTES_LAN(GENERATION, ALL_LAN, REPERT)
Value Integer GENERATION, ALL_LAN
Value Char    REPERT()

Local Char    WPOURCENT(1)  : [L]WPOURCENT="%"
  #JPGA 09/01/2012 BUG-79154 : Génération HTML Si toutes langues sélectionné : contrôle présence du caractère % dans DIRDOC.
  If GENERATION > 1  &  ALL_LAN=2
    If ! instr(1,REPERT,[L]WPOURCENT)
      # Génération Toutes langues sélectionnée mais le répertoire de génération ne possède pas de caractère % à tort (Vérifier le paramètre DIRDOC...)
      [V]GMESSAGE=mess(104,176,1)
      mkstat=2
    Endif
  Endif
End

###########################################################################
### Procédure de Formatage des Menus Locaux (4 cars en V5,V6 et 5 en V7)
###########################################################################
Funprog FORMAT_AML(DOC_AML)
Value Integer DOC_AML
#JPGA 16/01/2012 BUG-79300 : A partir de la V7, les menus locaux peuvent avoir 5 Caractères
# Cette procédure centralise le format traité par le générateur (AGENDOCA,AGENADO,AGENADOF)
Local Integer NBCAR_AML
  If IF_DOCV5 | IF_DOCV6
    [L]NBCAR_AML=4
  Else
    [L]NBCAR_AML=5
  Endif
End format$("N0:"+num$([L]NBCAR_AML),DOC_AML)

######################################################################################
### Traitement SPECIAL pour le champs DUMMY qui ne doit plus apparaitre dans le contenu HTML
### NOTE : FAIT à la demande des USA car DUMMY est un mot grossier.
######################################################################################
Funprog TRT_SPECIAL_DUMMY(DOC_MOTCLE)
Value Char DOC_MOTCLE ()

Local Char DOC_DUMMY (GLONADZ) : [L]DOC_DUMMY="DUMMY"
Local Char DOC_NONE  (GLONADZ) : [L]DOC_NONE ="NONE"
Local Char DOC_FLDMAJ(GLONADZ)

  [L]DOC_FLDMAJ=DOC_MOTCLE
  If ! IF_DOCV5
    If DOC_MOTCLE=[L]DOC_DUMMY
      [L]DOC_FLDMAJ=[L]DOC_NONE
    Endif
  Endif
End [L]DOC_FLDMAJ

