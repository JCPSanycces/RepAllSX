Subprog  KPL_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, E04PSEPLN, E04SESFLG, S04DURDET)
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT, E04PSEPLN
Value Integer      E04SESFLG
Variable Decimal   S04DURDET : S04DURDET = 0
Local Shortint CALL_E04
Goto $DEB_KPL_DUR_DET
$GSB_KPL_DUR_DET
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Char      E04PSEPLN       : E04PSEPLN    = [M:DIV]PC(1)
  Local Integer   E04SESFLG       : E04SESFLG    = [M:DIV]PE(0)
  Local Decimal   S04DURDET
$DEB_KPL_DUR_DET
Local Date    L04DTDBDET , L04DTFNDET
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From   GLOBB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  Else
    If ( E04PSEPLN <> "" and E04SESFLG = G_OUI ) Then
      Local Integer IM
      S04DURDET = sigma( IM= month(L04DTDBDET), month(L04DTFNDET), [F:PSE]ACTFLG(IM-1) =G_OUI)
    Else
      [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : S04DURDET = [M:DIV]RV(0)
    Endif
  Endif
  If ( S04DURDET < 0 ) Then : S04DURDET = 0 : Endif
If (dim(CALL_E04)<0) Then
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
End
Subprog  KPL_DUR_REST_AMT (PVLNREF, PDOTREF, PDOTPERMIN, PSESFLG, PSESTYP, PPSEOPN, RDOTM, RNBM_REST_AMT)
Value    Decimal   PVLNREF
Value    Decimal   PDOTREF
Value    Decimal   PDOTPERMIN
Value    Integer   PSESFLG
Value    Integer   PSESTYP
Value    Integer   PPSEOPN
Variable Decimal   RDOTM
Variable Integer   RNBM_REST_AMT : RNBM_REST_AMT = 0
  RDOTM = PDOTREF /12
  If (PSESFLG = G_OUI and PSESTYP = GVML_STINCR) Then
    RDOTM = PDOTREF /PPSEOPN
  Endif
  [M:DIV]PV(0)= RDOTM : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : RDOTM = [M:DIV]RV(1)
  Local Decimal L_NBM
  L_NBM = PVLNREF / RDOTM
  Local    Decimal   L_DECI   : L_DECI = L_NBM - fix(L_NBM)
  Local    Decimal   L_ENT    : L_ENT  = L_NBM - L_DECI
  If ( L_DECI <> 0 ) Then
    Local Decimal  WLSTDOTPER
    WLSTDOTPER = PVLNREF - (RDOTM * L_ENT)
    If ( WLSTDOTPER < PDOTPERMIN ) Then
      RNBM_REST_AMT = L_ENT
    Else
      RNBM_REST_AMT = L_ENT + 1
    Endif
  Else
    RNBM_REST_AMT = L_ENT
  Endif
End
Subprog CAL_DATE_FIN_AMORT_MODE_ML ( PDTDBREF, PNBMACT, PPSEPLN, PSESFLG, RDTFNAMT )
Value    Date      PDTDBREF
Value    Integer   PNBMACT
Value    Char      PPSEPLN
Value    Integer   PSESFLG
Variable Date      RDTFNAMT
  Local Integer IMREG
  Local Integer IMMAX
  Local Integer IM
  IMMAX = (PNBMACT+1)*12
  IMCUR = month(PDTDBREF)
  IM = 0
  For IMREG = 1 To IMMAX
    If ( PPSEPLN <> "" and PSESFLG = G_OUI ) Then
      If ( [F:PSE]ACTFLG(IMCUR-1) = G_OUI ) Then
        IM = IM+1
        If (IM = PNBMACT) Then : Break : Endif
      Endif
      IMCUR = IMCUR +1
      If (IMCUR = 13) Then : IMCUR = 1 : Endif
    Else
      IMREG = PNBMACT : Break
    Endif
  Next IMREG
  RDTFNAMT = PDTDBREF - 1
  RDTFNAMT = addmonth(RDTFNAMT, IMREG)
  RDTFNAMT = eomonth(RDTFNAMT)
End
Subprog  CAL_DOT_EXE_ML
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  Local Integer IM
  If([M:DIV]BMDR and [M:DIV2]LSTMDRDAT <> [0/0/0])
    IM = find([M:DIV2]LSTMDRDAT, [M:DEP]PERSTRDAT)
    Case [M:DIV]TYPCAL
      When "R","T"
        [M:DIV]VALAMT = [M:DEP]DPRBAS(IM-1)-[F:DEPC]RSDVAL
      When "I"
        [M:DIV]VALAMT = [M:DEP]BSEVAL(IM-1)-[F:DEPC]RSDVAL
    Endcase
  Endif
  Local Date     L_DTDBPER
  Local Decimal  L_VLNAMT
  If ([M:DIV]DTDBPER > [M:DIV]DTDBAMTREG) Then
    L_DTDBPER   = [M:DIV]DTDBPER
  Else
    L_DTDBPER   = [M:DIV]DTDBAMTREG
  Endif
  Local Date L_KMDRDAT
  L_KMDRDAT = [0/0/0]
  If ( [F:DEPC]KMDRDAT <> [0/0/0]) Then
    If ( [F:DEPC]KMDRDAT <= [F:DEPC]PERSTRDAT ) Then
      L_DTDBPER   = [F:DEPC]KMDRDAT
      L_KMDRDAT   = [F:DEPC]KMDRDAT
    Else
      If ([M:DIV2]LSTMDRDAT <> [0/0/0])
        L_DTDBPER   = [M:DIV2]LSTMDRDAT
        L_KMDRDAT   = [M:DIV2]LSTMDRDAT
      Else
        L_DTDBPER   = [F:DEPC]KMDRDAT
        L_KMDRDAT   = [F:DEPC]KMDRDAT
      Endif
    Endif
  Endif
  L_VLNAMT         = [M:DIV]VLNAMT
  [M:DIV]MDRCUMP_1 = 0
  IM = find(L_DTDBPER, [M:DEP]PERSTRDAT)
  [F:WDEP]= [F:DEPC]
  nolign = IM
  [F:DEPC] = [M:DEP]
  [F:DEPC]BSEVAL = [M:DIV]VALAMT
  [F:DEPC]DPRBAS = [M:DIV]VALAMT
  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT = [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUM
      Endif
    When "T"
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT = [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMT
      Endif
    When "I"
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT= [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMI
      Endif
  Endcase
  [F:DEPC] = [F:WDEP]
  If ( not([M:DIV]BMDR) and [F:DEPC]KMDRDEV <> 0) Then
    [M:DIV]VALAMT = [M:DIV]VALAMT-[F:DEPC]KMDRDEV
  Endif
  [M:DIV]SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))
  Local Decimal L_VALAMT
  L_VALAMT      = [M:DIV]VALAMT
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [M:DIV]DURAMTREG )  From   GLOBB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  Else
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    [F:DEPC]DPRRAT = arr( (1/[F:DEPC]DPRDUR), 0.000001)
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
  Endif
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From   GLOBB9
  Local Decimal L_DOTEXEREF
  L_DOTEXEREF = [M:DIV]VALAMT * [M:DIV]TXAMT * [F:DEPC]ACLCOE
  [M:DIV]PV(0)= L_DOTEXEREF : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : L_DOTEXEREF = [M:DIV]RV(1)
  Case [M:DIV]TYPCAL
      When "R" : [M:DIV]DOTEXEREF  = L_DOTEXEREF
      When "T" : [M:DIV]DOTEXEREFT = L_DOTEXEREF
      When "I" : [M:DIV]DOTEXEREFI = L_DOTEXEREF
  Endcase
  Local Decimal L_DOTPERREF
  Local Integer L_NBM_AMT
  Call KPL_DUR_REST_AMT
&      (L_VLNAMT, L_DOTEXEREF, [M:DIV]DOTPERMIN, [M:DIV]SESFLG , [M:DIV]SESTYP, [M:DIV]PSEMOPN,
&       L_DOTPERREF, L_NBM_AMT) From   GLOBB4PL
  [M:DIV]PD(0) = L_DTDBPER
  [M:DIV]PE(0) = L_NBM_AMT
  Gosub CAL_DATE_FIN_AMORT_ML From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  Local Date L_MDRDAT
  If ([M:DIV]BMDR) Then
    If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
      L_MDRDAT = [M:DIV2]LSTMDRDAT
    Else
      L_MDRDAT = [F:DEPC]KMDRDAT
    Endif
  Else
    L_MDRDAT = [0/0/0]
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= L_MDRDAT
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
  Gosub GSB_KPL_DUR_DET From   GLOBB4PL
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Local Integer WDUREXE
  WDUREXE = 12
  If ([M:DIV]SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Else
    [M:DIV]DOTEXE = L_DOTEXEREF * ( WDURDET / WDUREXE)
  Endif
  [M:DIV]DOTEXE = [M:DIV]DOTEXE + [M:DIV]MDRCUMP_1
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  CAL_DOT_EXE_MD
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  If([M:DIV]BMDR and [M:DIV2]LSTMDRDAT <> [0/0/0])
    Local Integer IM
    IM = find([M:DIV2]LSTMDRDAT, [M:DEP]PERSTRDAT)
    Case [M:DIV]TYPCAL
      When "R","T"
        [M:DIV]VALAMT = [M:DEP]DPRBAS(IM-1)-[F:DEPC]RSDVAL
      When "I"
        [M:DIV]VALAMT = [M:DEP]BSEVAL(IM-1)-[F:DEPC]RSDVAL
    Endcase
  Endif
  Local Date     L_DTDBPER
  Local Decimal  L_VLNAMT
  If ([M:DIV]DTDBPER > [M:DIV]DTDBAMTREG) Then
    L_DTDBPER = [M:DIV]DTDBPER
  Else
    L_DTDBPER = [M:DIV]DTDBAMTREG
  Endif
  Local Date L_KMDRDAT
  L_KMDRDAT = [0/0/0]
  If ( [F:DEPC]KMDRDAT <> [0/0/0]) Then
    If ( [F:DEPC]PERSTRDAT >= [F:DEPC]KMDRDAT ) Then
      L_DTDBPER   = [F:DEPC]KMDRDAT
      L_KMDRDAT   = [F:DEPC]KMDRDAT
    Else
      If ([M:DIV2]LSTMDRDAT <> [0/0/0])
        L_DTDBPER   = [M:DIV2]LSTMDRDAT
        L_KMDRDAT   = [M:DIV2]LSTMDRDAT
      Else
        L_DTDBPER   = [F:DEPC]KMDRDAT
        L_KMDRDAT   = [F:DEPC]KMDRDAT
      Endif
    Endif
  Endif
  [M:DIV]MDRCUMP_1 = 0
  [F:WDEP]= [F:DEPC]
  If ( L_DTDBPER <> [F:DEPC]PERSTRDAT ) Then
    Local Integer IM
    IM = find(L_DTDBPER, [M:DEP]PERSTRDAT)
    nolign = IM : [F:DEPC] = [M:DEP]
  Endif
  [F:DEPC]BSEVAL = [M:DIV]VALAMT
  [F:DEPC]DPRBAS = [M:DIV]VALAMT
  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]PC(0)= "RDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT = [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUM
      Endif
    When "T"
      [M:DIV]PC(0)= "TDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT = [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMT
      Endif
    When "I"
      [M:DIV]PC(0)= "IDE" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From   GLOBB4
      L_VLNAMT= [M:DIV]RV(1)
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMI
      Endif
  Endcase
  [F:DEPC] = [F:WDEP]
  If ( not([M:DIV]BMDR) and [F:DEPC]KMDRDEV <> 0) Then
    [M:DIV]VALAMT = [M:DIV]VALAMT-[F:DEPC]KMDRDEV
  Endif
  [M:DIV]SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [F:DEPC]DPRDUR )  From   GLOBB9
  Else
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
  Endif
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From   GLOBB9
  Local Decimal L_LINEXEREF
  L_LINEXEREF = [M:DIV]VALAMT * [M:DIV]TXAMT
  [M:DIV]PV(0)= L_LINEXEREF : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : L_LINEXEREF = [M:DIV]RV(1)
  Case [M:DIV]TYPCAL
      When "R" : [M:DIV]DOTEXEREF  = L_LINEXEREF
      When "T" : [M:DIV]DOTEXEREFT = L_LINEXEREF
      When "I" : [M:DIV]DOTEXEREFI = L_LINEXEREF
  Endcase
  [M:DIV]DTFNAMT = [0/0/0]
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  Local Date L_MDRDAT
  If ([M:DIV]BMDR) Then
    If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
      L_MDRDAT = [M:DIV2]LSTMDRDAT
    Else
      L_MDRDAT = [F:DEPC]KMDRDAT
    Endif
  Else
    L_MDRDAT = [0/0/0]
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE    : [M:DIV]PD(2)= L_MDRDAT
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
  Gosub GSB_KPL_DUR_DET From   GLOBB4PL
  If ([M:DIV]ERROR) Then : End : Endif
  WDURDET = [M:DIV]RV(1)
  Local Integer WDUREXE
  WDUREXE = 12
  If ([M:DIV]SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif
  [M:DIV]DOTEXE = L_VLNAMT * [M:DIV]TXAMT * [F:DEPC]ACLCOE * ( WDURDET / WDUREXE)
  Local Decimal L_DOTLIN
  L_DOTLIN = L_LINEXEREF * ( WDURDET / WDUREXE)
  If ( [M:DIV]DOTEXE < L_DOTLIN ) Then
    [M:DIV]DOTEXE      = L_DOTLIN
    [M:DIV]LINFLG      = G_OUI
  Else
    [M:DIV]LINFLG     = G_NON
  Endif
  [M:DIV]DOTEXE = [M:DIV]DOTEXE + [M:DIV]MDRCUMP_1
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  KRO_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, S04DURDET)
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT
Variable Decimal   S04DURDET : S04DURDET = 0
Local Shortint CALL_E04
Goto $DEB_KRO_DUR_DET
$GSB_KRO_DUR_DET
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Decimal   S04DURDET
$DEB_KRO_DUR_DET
Local Date    L04DTDBDET , L04DTFNDET
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From   GLOBB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  Else
    [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : S04DURDET = [M:DIV]RV(0)
  Endif
  S04DURDET = S04DURDET - [F:DEPC]KFIYNBMSTP
  If ( S04DURDET < 0 ) Then : S04DURDET = 0 : Endif
If (dim(CALL_E04)<0) Then
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
End
Subprog  KRO_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, RDUR_REST_AMT)
Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Variable  Decimal  RDUR_REST_AMT : RDUR_REST_AMT = 0
Local     Date     LDAT
  LDAT = max(PDTDBAMT, PDTDB)
  If ( LDAT <= PDTFNAMT ) Then
    [M:DIV]PD(0)= LDAT: [M:DIV]PD(1)= PDTFNAMT : [M:DIV]PC(0)= "M"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : RDUR_REST_AMT = [M:DIV]RV(0)
  Endif
  RDUR_REST_AMT = RDUR_REST_AMT - [F:DEPC]KFIYNBMSTP
  If ( RDUR_REST_AMT < 0 ) Then : RDUR_REST_AMT = 0 : Endif
End
Subprog  CAL_DOT_EXE_RL
Local Decimal WDURDET    : WDURDET     = 0.   : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.   : # Durée restant à amortir
Local Decimal WDOTEXE    : WDOTEXE     = 0.   : # Dotation exercice
  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [M:DIV]DURAMTREG )  From   GLOBB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  Else
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    [F:DEPC]DPRRAT = arr( (1/[F:DEPC]DPRDUR), 0.000001)
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
  Endif
  Gosub CAL_DATE_FIN_AMORT_RL From   GLOBB8
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
  Endif
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    End
  Endif
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_KRO_DUR_DET From   GLOBB4PL
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
    Call  KRO_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From   GLOBB4PL
    If ( WDURRES <> 0 ) Then
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
  Else
    If ( ([F:DEPC]KNBMSTPDEP = 0  and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP)          or
&        ([F:DEPC]KNBMSTPDEP <> 0 and find ([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSRSTPR) <> 0)  ) Then
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From   GLOBB4PL
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Local Integer WDUREXE
      WDUREXE = 12
    WDOTEXE = ( [M:DIV]VALAMT * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
    Else
      Local Decimal WCUMP_1    : WCUMP_1    = 0.   : # Cumul P-1
      Case [M:DIV]TYPCAL
        When "R"
          WCUMP_1 = [F:DEPC]PERCLOCUM
        When "T"
          WCUMP_1 = [F:DEPC]PERCLOCUMT
        When "I"
          WCUMP_1 = [F:DEPC]PERCLOCUMI
      Endcase
      [M:DIV]PD(0)= [M:DIV]DTDBPER : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From   GLOBB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]DTDBPER, [M:DIV]DTFNAMT, "M", WDURRES) From   GLOBB8
      If ( WDURRES <> 0 ) Then
        WDOTEXE = ( ([M:DIV]VLNAMT-WCUMP_1) * ( WDURDET / WDURRES)) + WCUMP_1
      Else
        WDOTEXE = 0
  Endif
    Endif
  Endif
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  CAL_DOT_EXE_RX
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDURD50    : WDURD50     = 0.     : # Durée restant à amortir à 50%
  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
  [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  [F:DEPC]DPRRAT = arr( (1/([F:DEPC]DPRDUR-1)), 0.000001)
  [M:DIV]TXAMT = (1/([F:DEPC]DPRDUR-1))
  Gosub CAL_DATE_FIN_AMORT_RX From   GLOBB8
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
  Endif
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    End
  Endif
  Local Integer WDUREXE
  WDUREXE = 12
  Local Date WDTFN50
  WDTFN50 = func GLOBI9.CAL_DAT_PLUS( [M:DIV]DTDBAMTREG-1, 12+[F:DEPC]KNBMSTPDEP, [M:DIV]TYPPRODAT )
  WDTFN50 = func GLOBB9.CAL_DAT_DERN( WDTFN50 , "M")
  Local Decimal WVALA50
  [M:DIV]PV(0)= [M:DIV]VALAMT * 0.5 : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WVALA50 = [M:DIV]RV(1)
  If ( WDTFN50 >= [M:DIV]DTFNEXE) Then
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From   GLOBB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]DOTEXE = WVALA50 * ( WDURDET / WDUREXE)
  Elsif( func GLOBB9.CAL_DAT_INSIDE(WDTFN50, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= WDTFN50 : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From   GLOBB4PL
    WDURD50 = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From   GLOBB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    WDURDET = WDURDET - WDURD50
    If (WDURDET <> 0) Then
      [M:DIV]DOTEXE = WVALA50 - [F:DEPC]DPRCUM
    Endif
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
      Call  KRO_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From   GLOBB4PL
      If ( WDURRES <> 0 ) Then
        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    Else
      If ( [F:DEPC]KNBMSTPDEP <> 0 ) Then
        Call  KRO_DUR_REST_AMT(WDTFN50+1, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From   GLOBB4PL
        If ( WDURRES <> 0 ) Then
          [M:DIV]DOTEXE += ([M:DIV]VALAMT - WVALA50) * ( WDURDET / WDURRES)
        Endif
      Else
      [M:DIV]DOTEXE += ( ([M:DIV]VALAMT - WVALA50) * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
    Endif
    Endif
  Else
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From   GLOBB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
      Call  KRO_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From   GLOBB4PL
      If ( WDURRES <> 0 ) Then
        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    Else
      If ( [F:DEPC]KNBMSTPDEP = 0 ) Then
      [M:DIV]DOTEXE = ( ([M:DIV]VALAMT - WVALA50) * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
      Else
        Local Decimal WCUMP_1    : WCUMP_1    = 0.   : # Cumul P-1
        Case [M:DIV]TYPCAL
          When "R"
            WCUMP_1 = [F:DEPC]PERCLOCUM
          When "T"
            WCUMP_1 = [F:DEPC]PERCLOCUMT
          When "I"
            WCUMP_1 = [F:DEPC]PERCLOCUMI
        Endcase
        [M:DIV]PD(0)= [F:DEPC]PERSTRDAT : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From   GLOBB8
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        Call  CAL_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]DTDBPER, [M:DIV]DTFNAMT, "M", WDURRES) From   GLOBB8
        If ( WDURRES <> 0 ) Then
          [M:DIV]DOTEXE = ( ([M:DIV]VLNAMT-WCUMP_1) * ( WDURDET / WDURRES)) + WCUMP_1
        Else
          [M:DIV]DOTEXE = 0
        Endif
    Endif
  Endif
  Endif
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  CAL_DOT_EXE_RD
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Integer BP_1       : BP_1        = 0      : # Reconstution P-1 et intègration dans période courante
  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
  [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  Call CAL_TAUX_MODE_RD([F:DEPC]DPRDUR, [M:DIV]TXAMT, [F:DEPC]DPRRAT) From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  Gosub CAL_DATE_FIN_AMORT_RD From   GLOBB8
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
  Endif
  If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
    Local Integer SDPRDUR : SDPRDUR = [F:DEPC]DPRDUR
    Call  CAL_DUR_REST_AMT([M:DIV]DTDBAMTREG, [F:DEPC]KBIRDAT, [M:DIV]DTFNAMT, "M", WDURRES) From   GLOBB8
    [F:DEPC]DPRDUR = WDURRES /12
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From   GLOBB9
    Call CAL_TAUX_MODE_RD([M:DIV]DURAMTREG, [M:DIV]TXAMT, [F:DEPC]DPRRAT) From   GLOBB8
  Endif
  Local Integer WDUREXE
  WDUREXE = 12
  Call CAL_INI_PER_EXE ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT ) From   GLOBB7
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [F:DEPC]LSTCLODAT = [0/0/0] and
&   func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and
&   [M:DIV]DTDBAMTREG < [F:DEPC]PERSTRDAT ) Then : BP_1 = 1 : Endif
  Local Decimal R_VLNANI : R_VLNANI = 0
  Local Decimal L_VLNANI
  Local Decimal L_VALNET
  L_VALNET = [M:DIV]VLNAMT
  Case [M:DIV]TYPCAL
    When "R"
      L_VLNANI = [F:DEPC]KBIRNBV  - [F:DEPC]RSDVAL
    When "T"
      L_VLNANI = [F:DEPC]KBIRNBVT - [F:DEPC]RSDVAL
    When "I"
      L_VLNANI = [F:DEPC]KBIRNBVI - [F:DEPC]RSDVAL
  Endcase
  Local Date L_DATANI
  If ([F:DEPC]KBIRDAT = [0/0/0] or [F:DEPC]PERENDDAT <= [M:DIV]DTDBAMTREG or BP_1 ) Then
    L_DATANI = [M:DIV]DTDBAMTREG
    [F:DEPC]KBIRDAT = L_DATANI
  Else
    L_DATANI = [F:DEPC]KBIRDAT
  Endif
  Local Decimal L_DOTPER(1..24)
  Local Decimal L_DOT1AP(1..24)
  Local Decimal L_EXCPER(1..24)
  Local Decimal L_EXC1AP(1..24)
  Local Decimal L_BIRNBV(1..24)
  Local Date    L_BIRDAT(1..24)
  I_P = find([F:DEPC]PERSTRDAT-1, [M:DIV2]PERENDDAT)
  If (I_P <> 0) Then
    Case [M:DIV]TYPCAL
      When "R"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUM
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUM
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXC
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXC
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUM - [F:DEPC]PERCLOEXC
      When "T"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUMT
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUMT
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXCT
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXCT
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUMT + [F:DEPC]PERCLOEXCT
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUMT - [F:DEPC]PERCLOEXCT
      When "I"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUMI
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUMI
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXCI
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXCI
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUMI + [F:DEPC]PERCLOEXCI
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUMI - [F:DEPC]PERCLOEXCI
    Endcase
  Endif
  For I_P = 1 To [M:DIV2]NB_PER
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) and ([M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT or BP_1) ) Then
      Case [M:DIV]TYPCAL
        When "R"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBV  - [F:DEPC]RSDVAL
        When "T"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBVT - [F:DEPC]RSDVAL
        When "I"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBVI - [F:DEPC]RSDVAL
      Endcase
   Endif
  Next I_P
  For I_P = 1 To [M:DIV2]NB_PER
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) and ([M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT or BP_1) ) Then
      If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [M:DIV2]PERENDDAT(I_P-1)  ) Then
        If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
          [M:DIV]PD(0)= [F:DEPC]KBIRDAT : [M:DIV]PD(1)= [M:DIV2]PERENDDAT(I_P-1) : [M:DIV]PC(0)= "M"
          Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WNBM = [M:DIV]RV(0)
        Else
        [M:DIV]PD(0)= [M:DIV]DTDBAMTREG : [M:DIV]PD(1)= [M:DIV2]PERENDDAT(I_P-1) : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WNBM = [M:DIV]RV(0)
          WNBM = WNBM - [F:DEPC]KNBMSTPDEP
        Endif
        If ( mod(WNBM, 12) = 1 ) Then
          L_VLNANI = L_VALNET
          L_DATANI = [M:DIV2]PERSTRDAT((I_P-1))
        Endif
        If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
          L_BIRDAT(I_P) =  [F:DEPC]KBIRDAT
        Else
        L_BIRDAT(I_P) =  L_DATANI
        Endif
        L_BIRNBV(I_P) =  L_VLNANI
        If (L_VLNANI <> R_VLNANI) Then
          R_VLNANI = L_VLNANI
          Local Decimal R_DOTDEG : R_DOTDEG = 0
          R_DOTDEG = R_VLNANI * [M:DIV]TXAMT
          [M:DIV]PV(0)= R_DOTDEG : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : R_DOTDEG = [M:DIV]RV(1)
          Local Decimal R_DOTLIN : R_DOTLIN = 0
          Local Date    L_CURANI
          If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
            If (month(L_DATANI) = 1 ) Then
              L_CURANI = gdat$(01,01, year([M:DIV2]PERSTRDAT(0)))
            Elsif (month(L_DATANI) = month([M:DIV2]PERSTRDAT(I_P-1))) Then
              L_CURANI = [M:DIV2]PERSTRDAT(I_P-1)
            Else
              L_CURANI = gdat$(01,month(L_DATANI), year([M:DIV2]PERSTRDAT(0))-1)
            Endif
          Else
            L_CURANI = L_DATANI
          Endif
          [M:DIV]PD(0)= L_CURANI   : [M:DIV]PD(1)= [M:DIV]DTFNAMT : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL  : [M:DIV]PD(5)= [M:DIV]DATNUL
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From   GLOBB8
          WDURRES = [M:DIV]RV(1)
          If ([M:DIV]ERROR) Then : End : Endif
          If (WDURRES <> 0 ) Then
            R_DOTLIN = (R_VLNANI / WDURRES )  * 12
          Endif
          [M:DIV]PV(0)= R_DOTLIN : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : R_DOTLIN = [M:DIV]RV(1)
        Endif
        If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
          L_DOTPER(I_P) =  0.
        Else
          If (R_DOTDEG > R_DOTLIN) Then
            L_DOTPER(I_P) =  L_VLNANI * [M:DIV]TXAMT / 12
          Else
            [M:DIV]PD(0)= [M:DIV2]PERSTRDAT(I_P-1) : [M:DIV]PD(1)= [M:DIV]DTFNAMT   : [M:DIV]PD(2)= [M:DIV]DATNUL
            [M:DIV]PD(3)= [M:DIV]DATNUL            : [M:DIV]PD(4)= [M:DIV]DATNUL    : [M:DIV]PD(5)= [M:DIV]DATNUL
            [M:DIV]PD(6)= [M:DIV]DATSOREXE         : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
            Gosub GSB_CAL_DUR_DET From   GLOBB8
            WDURRES = [M:DIV]RV(1)
            If ( WDURRES <> 0 ) Then
            L_DOTPER(I_P) = L_VALNET /WDURRES
            Endif
          Endif
          [M:DIV]PV(0)= L_DOTPER(I_P) : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : L_DOTPER(I_P) = [M:DIV]RV(1)
        Endif
        If ( abs(L_DOTPER(I_P)) > abs(L_VALNET) ) Then
          L_DOTPER(I_P) = L_VALNET
        Endif
        [M:DIV]DOTEXE          += L_DOTPER(I_P)
        L_VALNET               -= L_DOTPER(I_P)
        If (I_P > 1 ) Then :  L_DOT1AP(I_P) = L_DOT1AP(I_P-1) : Endif
        L_DOT1AP(I_P) += L_DOTPER(I_P)
      Endif
    Endif
  Next I_P
  For I_P = 1 To [M:DIV2]NB_PER
    [M:DIV2]BIRDAT(I_P-1) = L_BIRDAT(I_P)
    Case [M:DIV]TYPCAL
      When "R"
        [M:DIV2]DOTPER (I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1AP (I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPER (I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1AP (I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBV (I_P-1) = L_BIRNBV(I_P)
      When "T"
        [M:DIV2]DOTPERT(I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1APT(I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPERT(I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1APT(I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBVT(I_P-1) = L_BIRNBV(I_P)
      When "I"
        [M:DIV2]DOTPERI(I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1API(I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPERI(I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1API(I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBVI(I_P-1) = L_BIRNBV(I_P)
    Endcase
  Next I_P
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
  If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
   [F:DEPC]DPRDUR   = SDPRDUR
   [M:DIV]DURAMTREG = SDPRDUR
  Endif
End
Subprog  CAL_DOT_EXE_AL
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  [M:DIV]TXAMT     = 1 / [F:DEPC]DPRDUR
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  If ([M:DIV]NIVDET > 7 ) Then
  Endif
  Gosub CAL_DATE_FIN_AMORT_AL From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
    End
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    If ( [M:DIV]DUREXE <> 0 ) Then
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / 365 )
    Else
      WDOTEXE = 0
    Endif
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXE = [M:DIV]RV(1)
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From   GLOBB8
    If ( WDURRES <> 0 ) Then
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
  Endif
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub EVALUE_FLGSLDPER From   GLOBB4
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  CAL_DOT_EXE_AD
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  If ([M:DIV]NIVDET > 7) Then
  Endif
  Local Decimal WACLCOE
  If ( [F:WFAS]PURDAT >= [10/05/2006] ) Then
    WACLCOE = 2.
  Else
    WACLCOE = 1.5
  Endif
  [M:DIV]TXAMT     = (1 / [F:DEPC]DPRDUR)  * WACLCOE
  If ([M:DIV]TXAMT > 1.) Then : [M:DIV]TXAMT = 1. : Endif
  Gosub CAL_DATE_FIN_AMORT_AD From   GLOBB8
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / 365 )
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Local Decimal WDOTEXEMIN : WDOTEXEMIN = [M:DIV]DOTEXEMIN
  If (WDOTEXEMIN = 0.) Then : WDOTEXEMIN = 1. : Endif
  If (  abs([M:DIV]DOTEXE) <= WDOTEXEMIN ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
End
Subprog  CAL_DOT_EXE_HL
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  [M:DIV]TXAMT     = 1 / [F:DEPC]DPRDUR
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  If ([M:DIV]NIVDET > 7 ) Then
  Endif
  Gosub CAL_DATE_FIN_AMORT_HL From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
    End
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    If ( [M:DIV]DUREXE <> 0 ) Then
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXE = [M:DIV]RV(1)
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From   GLOBB8
    If ( WDURRES <> 0 ) Then
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
  Endif
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub EVALUE_FLGSLDPER From   GLOBB4
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
Subprog  CAL_DOT_EXE_HD
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  If ([M:DIV]NIVDET > 7) Then
  Endif
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
  Else
    [M:DIV]TXAMT = (1 / [F:DEPC]DPRDUR)
  Endif
  If ([M:DIV]TXAMT > 1.) Then : [M:DIV]TXAMT = 1. : Endif
  Gosub CAL_DATE_FIN_AMORT_HD From   GLOBB8
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Local Decimal WNETVALWRO : WNETVALWRO = [M:DIV]ENDNVLWRO
  If (WNETVALWRO = 0.) Then : WNETVALWRO = 1. : Endif
  If (  abs([M:DIV]VLNAMT) <= WNETVALWRO ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
  If ([F:DEPC]DPRRATFLG <> G_OUI ) Then :  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
End
Subprog  CAL_DOT_EXE_TL
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    Call  CAL_DUREE_SELON_TAUX_LINEAIRE ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From   GLOBB8
  Else
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    Call CAL_TAUX_LINEAIRE ([M:DIV]FLGRNDCHG, [M:DIV]DURAMTREG, [M:DIV]TXAMT) From   GLOBB8
  Endif
  If ([M:DIV]NIVDET > 7 ) Then
  Endif
  Gosub CAL_DATE_FIN_AMORT_TL From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    End
  Endif
  Local Integer B_TXPRI : B_TXPRI = 0
  If ( [M:DIV]FLGTXPRI = G_OUI and [M:DIV]VLNAMT <> 0 and [F:DEPC]DPRRATFLG = G_OUI  and
&      ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE or func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) ) Then
    B_TXPRI = 1
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXE, 1, "D" )
    Local Date WDTFNEXE, WDTDBEXE
    Local Integer WINDEXE
    [M:DIV]PD(0)= [M:DIV]DTFNAMT : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From   GLOBB8
    WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]DTFNAMT = WDTFNEXE
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    If ( [M:DIV]DUREXE <> 0 ) Then
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXE = [M:DIV]RV(1)
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From   GLOBB8
    If ( WDURRES <> 0 ) Then
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
  Endif
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub EVALUE_FLGSLDPER From   GLOBB4
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
  If ( B_TXPRI ) Then
    If ( [M:DIV]DOTEXE = 0 ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
    Else
      WDURRES  = ([M:DIV]VLNAMT / [M:DIV]DOTEXE ) * 365.25
      [M:DIV]DTFNAMT = (func GLOBB9.CAL_DAT_PLUS( max([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE), WDURRES, "D" )) - 1
    Endif
  Endif
End
Subprog  CAL_DOT_EXE_TD
Local Decimal WTXAMT     : WTXAMT      = 0.     : # Taux d'amortissement
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle
Local Date    WDTDBAMT   :                      : # Date de début d'amort régularisé pour dotation exercice
  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  If ( [M:DIV]VLNAMT = 0 ) Then
    [M:DIV]DOTEXE = 0.
    End
  Endif
  If ( [M:DIV]NIVDET > 7 ) Then
  Endif
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  WTXAMT = ( 1 / [M:DIV]DURAMTREG ) * [F:DEPC]ACLCOE
  [M:DIV]TXAMT   = 0.00
  Gosub CAL_DATE_FIN_AMORT_TD From   GLOBB8
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    End
  Endif
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From   GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  WDOTEXEDEG = [M:DIV]VLNAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )
    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXEDEG = [M:DIV]RV(1)
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From   GLOBB8
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif
    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXELIN = [M:DIV]RV(1)
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif
  [M:DIV]PV(0)= [M:DIV]DOTEXE: [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Gosub EVALUE_FLGSLDPER From   GLOBB4
  Gosub PLAFONNEMENT_A_VLNAMT From   GLOBB4
End
