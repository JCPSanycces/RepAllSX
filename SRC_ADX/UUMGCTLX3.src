#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLX3                                       Product X3 All Modules   #
#                Controls                                                  #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPREX3") From LECFIC
  Endif

  Gosub ALL_X3CTL

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
$ALL_X3CTL

Call MAJ_UUMGCTLCPT00(DOSSIER) From UUMGCTLCPT00
Call MAJ_UUMGCTLTRS00(DOSSIER) From UUMGCTLTRS00
Call MAJ_UUMGCTLSAL01(DOSSIER) From UUMGCTLSAL01
Call MAJ_UUMGCTLSAL02(DOSSIER) From UUMGCTLSAL02
Call MAJ_UUMGCTLSAL06(DOSSIER) From UUMGCTLSAL06
Call MAJ_UUMGCTLSAL07(DOSSIER) From UUMGCTLSAL07
Call MAJ_UUMGCTLSAL08(DOSSIER) From UUMGCTLSAL08
Call MAJ_UUMGCTLPUR01(DOSSIER) From UUMGCTLPUR01
Call MAJ_UUMGCTLPUR02(DOSSIER) From UUMGCTLPUR02
Call MAJ_UUMGCTLPUR03(DOSSIER) From UUMGCTLPUR03
Call MAJ_UUMGCTLPUR06(DOSSIER) From UUMGCTLPUR06
Call MAJ_UUMGCTLPUR07(DOSSIER) From UUMGCTLPUR07
Call MAJ_UUMGCTLPUR08(DOSSIER) From UUMGCTLPUR08

Return

