#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher. (Does nothing at the moment.)
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE" : Gosub OUVRE
        When "SETBOUT"    : If CLECUR and SUPPR : CHAINE += "A" : Endif
        When "APRES_CHOI" : If REPONSE = GSTAANU : Gosub ANNULER : REPONSE = 0 Endif
    Endcase
Return



#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    - Opens needed tables.
#*
#*! #####################################################################################

$OUVRE
    If !clalev( [F:TVB] ) : Local File TABVACBPR [TVB] : Endif
    If !clalev( [F:RLI] ) : Local File REPLINDEF [RLI] : Endif
Return



#** #####################################################################################
#*
#* Sub chunk:  ANNULER
#*
#* Purpose:    - ...
#*
#*! #####################################################################################

$ANNULER
    # Check for an existing lock.
    If !VERROU
        Gosub VERROU From GOBJET
        If !VERROU
            # A lock exists: Display an error message and leave.
            Call ERREUR( mess(10,100,1) ) From GESECRAN # "Change In Progress on another workstation"
            Return
        Else
            AFFICHE = 1

            # Restore the grid.
            Gosub RELIT From GOBJSUB
        Endif
    Endif

    # Let's ask if the user really wishes to delete all rows.
    OK = 2 # Default is NO.
    If dim([V]GCONF) <= 0 or [V]GCONF(1) = 2
        Call OUINON( mess(123,105,1) - "(" + [M]LEG + "~" + [M]VAT + ")", OK ) From GESECRAN # "Confirm delete?"
    Endif

    # If NO cancel the deletion.
    If OK <> 2
        Return
    Endif

    # Otherwise delete.
    Call DEBTRANS From GLOCK
    Trbegin [RSP]
    Delete [RSP] Where LEG=[M]LEG & VAT=[M]VAT
    If fstat = 1
      Call RSTA("RSP",[M]LEG-[M]VAT) From GLOCK
      Rollback
    Else

        Commit
    Endif
    CLECUR = 0

    # Restore the grid.
    Gosub RELIT From GOBJSUB
Return



