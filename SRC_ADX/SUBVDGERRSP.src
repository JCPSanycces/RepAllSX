#################################################################################################################
#
#    Event: Check while entering the turnover type.
#    Does:  Make sure that only RS turnover types corresponding to the given legislation are valid.
#
#################################################################################################################

Subprog C_TRNTYP(VALEUR)
Variable Char VALEUR()

    # Make sure the correct turnover type is used.
    Read [RLI]RLI0 = [M]LEG; 2; VALEUR
    If fstat
        GMESSAGE = mess(265,107,1) # "Incorrect turnover type"
        mkstat = 2
    Endif
End



#################################################################################################################
#
#    Event: ...
#    Does:  ...
#
#################################################################################################################

Subprog C_VACBPR(VALEUR)
Variable Char VALEUR()

    # ...
    Read [TVB]TVB0 = VALEUR; [M]LEG
    If fstat
        GMESSAGE = mess(267,107,1) # "Tax rule uses a non EU regime."
        mkstat = 2
    Endif
End



#################################################################################################################
#
#    Event: Before entering the field VACBPR (tax rule).
#    Does:  Suggests a tax rule corresponding to the chosen VAT code.
#
#################################################################################################################

Subprog AS_VACBPR(VALEUR)
Variable Char VALEUR()
Local Integer WRET :#--CPO 71937
# Fill only tax rule field if it is empty and VAT code and legislation are not empty.
#--CPO 71937 TVT and leg part of the key
#--No need to test [M]LEG because the subprog will read first on [m]leg and than on leg=""
#If ( VALEUR = "" ) and ( [M]VAT <> "" ) and ( [M]LEG <> "" )
If ( VALEUR = "" ) and ( [M]VAT <> "" )
Call LEC_TVT_LEG([M]LEG,[M]VAT,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] Endif
VALEUR = [F:TVT]VATVAC
# # Read the corresponding tax rule
# Read [TVT]TVT0 = [M]VAT; [M]LEG
# If !fstat
#   # If a tax rule exists return it as a suggestion.
#   VALEUR = [F:TVT]VATVAC
# Endif
Endif
End
