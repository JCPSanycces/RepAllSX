#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA41   Modification paramétrage section par défaut    Module GPA   #
##########################################################################
# Issue 90205 - 2013-08-07 by CCC
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTIGPA41(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTIGPA41(DOSSIER)
Value Char DOSSIER

Local Integer LNB, LREW
Call ECR_TRACE("UTIGPA41 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CDE])  =0  Local File =DOSSIER+".CACCEDEF"   [CDE] : Endif

LNB = 0
Call DEBTRANS From GLOCK

Trbegin [CDE]
For [CDE] Where find(COD,"STKEOF","STKSOF")>0
    Raz LREW
    Readlock [CDE] Curr
    If fstat = 0
        # --- fields and rewrite
        If vireblc([F:CDE]FLD(5),4)='funcTRTX3CPT.TRFSECMSK(string$(clalev([M:MTK2]),"MTK2")+string$(clalev([M:MBI]),"MBI"),AXE)'
            [F:CDE]FLD(5)='func TRTX3CPT.TRFSECX ("MTK2,MBI,MTIK,MKI", "M,M,M,F", AXE)'
            LREW=1
        Elsif vireblc([F:CDE]FLD(5),4)='funcTRTX3CPT.TRFSECMSK(string$(clalev([M:MTK3]),"MTK3")+string$(clalev([M:MBM]),"MBM"),AXE)'
            [F:CDE]FLD(5)='func TRTX3CPT.TRFSECX ("MTK3,MBM", "M,M", AXE)'
            LREW=1
        Endif
        If LREW
            Rewrite [F:CDE]
            If !fstat LNB += 1 Endif
        Endif
   Endif
Next
Commit

Close Local File [CDE]

Call ECR_TRACE("UTIGPA41 : "+num$(LNB)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIGPA41 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 : End : Endif

If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIGPA41(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(7)<>2 : End : Endif
If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIGPA41(APPLI)
End
