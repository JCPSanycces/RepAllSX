   CRITERE3_3 += "&"
Endif
CRITERE3_3 += CRITERE
Return

########################################################################
#TRI_TAB                              tri du tableau suivant parametrage
########################################################################
$TRI_TAB
If [M:REO1]NBLIG <> 0
    #--- Issue 112829
    # pour changer le tri du tableau, utiliser le PE de la façon suivante :
    # mettre 0 dans [M:REO1]SRTCRIT1 et écrire le Sorta souhaité
    GPOINT="TRI_REO1" : Gosub ENTREE From EXEFNC
    #---
    Case [M:REO1]SRTCRIT1
        When 1        : Sorta [M:REO1]NBLIG [M:REO1]NBLIG Order By [M:REO1]LOCORI(indice)
        When 2        : Sorta [M:REO1]NBLIG [M:REO1]NBLIG Order By [M:REO1]ITMREF(indice)
        When 3        : Sorta [M:REO1]NBLIG [M:REO1]NBLIG Order By [M:REO1]ORIREO(indice),
&                                                                  [M:REO1]LOCORI(indice)
        When 4        : Sorta [M:REO1]NBLIG [M:REO1]NBLIG Order By [M:REO1]ORIREO(indice),
&                                                                  [M:REO1]ITMREF(indice)
    Endcase
    Grizo  [M:REO1]ITMREF
#si type zones de consommation pas choisi alors locori n est pas saisissable sur des lignes existantes
    If GCSMREO <> 2
       If dim([M:REO1]LOCORI) > 0
          Grizo  [M:REO1]LOCORI
       Endif
       If dim([M:REO1]WRHORI) > 0
          Grizo  [M:REO1]WRHORI
       Endif
    Endif
    Actzo  [M:REO1]COCHAGE

    If [M:REO1]SRGPPSSTR <> ""
       If dim([M:REO1]STA) > 0
          Grizo [M:REO1]STA
       Endif
       If dim([M:REO1]WRH) > 0
          Grizo [M:REO1]WRH
       Endif
       If dim([M:REO1]LPNNUM) > 0                                                        # hcb x3-82749
#          Grizo [M:REO1]LPNNUM                                                           # hcb x3-82749
       Endif                                                                             # hcb x3-82749
       If dim([M:REO1]LOC) > 0
          Grizo [M:REO1]LOC
       Endif
       If dim([M:REO1]LOT) > 0
          Grizo [M:REO1]LOT
       Endif
       If dim([M:REO1]SLO) > 0
          Grizo [M:REO1]SLO
       Endif
       If dim([M:REO1]SERNUM) > 0
          Grizo [M:REO1]SERNUM
       Endif
       If dim([M:REO1]PALNUM) > 0        # hcb 27200
          Grizo [M:REO1]PALNUM           # hcb 27200
          Grizo [M:REO1]CTRNUM           # hcb 27200
       Endif                             # hcb 27200
       If dim([M:REO1]MVTDES) > 0
          Grizo [M:REO1]MVTDES
       Endif
       If dim([M:REO1]CLEFLG) > 0
          Grizo [M:REO1]CLEFLG
       Endif

       Affzo [M:REO1]30                                      # hcb X3-107136

       Local Integer NOL
       If [M:REO1]LSTWIOFLG = 2
          For I = 0 To [M:REO1]NBLIG-1
             If [M:REO1]COCHAGE (I) <> 2
                NOL = I
                Gosub ACT_RUB_DESTINATION
             Endif
          Next
          Affzo [M:REO1]30                                   # hcb X3-107136
       Endif
    Else
       Affzo [M:REO1]30                                      # hcb X3-107136
    Endif
Endif

# il faut activer les zones de cle sur la ligne vide ....
Local  Integer NOL
NOL = [M:REO1]NBLIG
Gosub ACT_RUB_CLE

Return

########################################################################
# RECH_CLE   optimisation STOREO Emplacement reapprovisonement
########################################################################
$RECH_CLE

Local Integer WCLE
WCLE = 0
If [M:REO1]SRGPPSSTR <> "" & [M:REO1]LSTWIOFLG <> 2
   WCLE = 1
   Return
Endif
If [M:REO1]ITMREFSTR  <> ""
    WCLE = 0
    Return
Endif

Return
########################################################################
# RECH_CLE_2  optimisation STOALL Zone de consommation
########################################################################
$RECH_CLE_2
Local Integer WCLE
WCLE = 0
Return
########################################################################
# RECH_CLE_4  optimisation STOALL Rupture sur emplacement
########################################################################
$RECH_CLE_4
Local Integer WCLE
WCLE = 0
Return

########################################################################
# CTR_EXI_REO1 Controle existance tableau REO1 suite selection ou saisie
########################################################################
$CTR_EXI_REO1

Gosub FORMATAGE_CLE
Local Integer WEXI
WEXI = 0
WEXI = find ( WCLE_FOR,[M:REO1]WCLE(0..[M:REO1]NBLIG))
Return

########################################################################
# FORMATAGE_CLE            Formatage d une zone pour recherche existance
########################################################################
$FORMATAGE_CLE
Local Char WCLE_FOR(30)
WCLE_FOR += [F:REO]ITMREF
WCLE_FOR += [F:REO]LOC
Return
########################################################################
# DECOCHAGE_REO1  Mise à jour du flag STAFLG à 1 en cas d abandon ou fin
#                                        pour les enregistrements coches
########################################################################
$DECOCHAGE_REO1
Local Integer I
Raz I
For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE (I) = 2 &  [M:REO1]COCHAGE_AV (I) <> 2
       Call MAJ_STA_STAFLG(I,1)  From TRTREOA    # mise à jour du flag STAFLG à 1
    Endif
Next I
Return

########################################################################
# LECTURE_STOREO                                          lecture STOREO
########################################################################
$LECTURE_STOREO
Local Decimal WSTUACTDIS          : #--- Dem 64662
Local Integer WLEC, I
WLEC = 0
Local Integer WSTATUS  # hcb 84841
# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
WMAX = dim([M:REO1]COCHAGE)     # mémorisation nombre de ligne maxi

For [REO]

# Verification que l enregistrement n existe pas dans le tableau
    If VERIF = 2
       Gosub CTR_EXI_REO1 From TRTREOA
       If WEXI <> 0
          Goto NEXTREO
       Endif
    Endif

    #--- Dem 64662
    # On ne charge que les lignes réapprovisionnable (stock disponible)
    If [M:REO1]STODIS=2
      I=0
      # S'il y a des allocations, la ligne sera chargée
      If [F:REO]VCRNUM<>""
        Columns [STA] (STOFCY,ITMREF,VCRTYP,SRGNUM,SRGLIN,ALLTYP)
        For [STA]STA0 Where STOFCY=[F:REO]STOFCY & ITMREF=[F:REO]ITMREF &
&                           SRGNUM=[F:REO]VCRNUM & SRGLIN=[F:REO]VCRLIN
            I=1 : Break
        Next
        Columns [STA]
      Endif
      # Pas d'allocation --> test sur stock dispo
      If I=0
        Read [ITV]ITV0=[F:REO]ITMREF;[F:REO]STOFCY
        If fstat Raz [F:ITV] Endif
        # Calcul stock disponible (emp internes et sous-traitant, statuts A,Q,R)
        WSTATUS = 7                                                            # hcb 84841
        GPOINT = "STODISTOT" : Gosub ENTREE From EXEFNC                        # hcb 84841
        Call STODISTOT("",5,WSTATUS,[M:REO1]STOFCY,WSTUACTDIS) From STKLIB     # hcb 84841
        # Pas de stock dispo
        If WSTUACTDIS<=0
           Goto NEXTREO
        #--- Bug 68398
        Else
           # Diminution du dispo de la quantité de l'emp à réapprovisionner
           For [STO]STO3 Where ITMREF=[F:REO]ITMREF & STOFCY=[F:REO]STOFCY & LOC=[F:REO]LOC
              WSTUACTDIS-=[F:STO]QTYSTUACT
           Next
           If WSTUACTDIS<=0
              Goto NEXTREO
           Endif
        Endif
        #---
      Endif
    Endif
    #---

    If nolign = WMAX : Break : Endif
    WLEC += 1
    [M:REO1]NBRLOC +=1
    [M:REO1]ORIREO      (nolign-1)   = 1
    [M:REO1]DEFTYPLOC   (nolign-1)   = ""
    [M:REO1]DEFLOC      (nolign-1)   = ""

    [M:REO1]MODFLG      (nolign-1)   = 1
    [M:REO1]CREFLG      (nolign-1)   = 0
    [M:REO1]WFLG        (nolign-1)   = 1
    [M:REO1]CLEFLG      (nolign-1)   = 1
    [M:REO1]WSTOFLG     (nolign-1)   = 0
    [M:REO1]ITMREF      (nolign-1)   = [F:REO]ITMREF
    [M:REO1]BPRNUM      (nolign-1)   = [F:REO]BPRNUM
    [M:REO1]SRGLIN      (nolign-1)   = [F:REO]VCRLIN
    [M:REO1]SRGPPS      (nolign-1)   = [F:REO]VCRNUM
    [M:REO1]SRGPPS_AV   (nolign-1)   = [F:REO]VCRNUM
    If dim([M:REO1]WRHORI) > 0
       [M:REO1]WRHORI   (nolign-1)   = [F:REO]WRH
    Endif
    [M:REO1]LOCORI      (nolign-1)   = [F:REO]LOC
    [M:REO1]BESDAT      (nolign-1)   = [F:REO]BESDAT
    [M:REO1]PCUORI      (nolign-1)   = [F:REO]PCU
    [M:REO1]QTYPCUORI   (nolign-1)   = [F:REO]QTYPCU
    [M:REO1]PCUSTUCOEO  (nolign-1)   = [F:REO]PCUSTUCOE
    [M:REO1]QTYSTUORIA  (nolign-1)   = [F:REO]QTYSTUACT
    [M:REO1]QTYSTUORI   (nolign-1)   = [F:REO]QTYSTU

    If [F:ITM]ITMREF<>[F:REO]ITMREF
        Read [F:ITM]ITM0=[F:REO]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif

    [M:REO1]STU         (nolign-1)   = [F:ITM]STU

# si liste à ranger = blanc alors liste du filtre si saisie manuelle
    If VERIF = 2
       If   [M:REO1]SRGPPS(nolign-1) = ""
            [M:REO1]SRGPPS(nolign-1) = [M:REO1]SRGPPSSTR
       Endif
    Endif

    If   [M:REO1]SRGPPS(nolign-1) = ""
         [M:REO1]COCHAGE(nolign-1)    = 1
         [M:REO1]COCHAGE_AV(nolign-1) = 1
    Endif
    If   [M:REO1]SRGPPS(nolign-1) <> ""
         [M:REO1]COCHAGE(nolign-1)    = 2
         [M:REO1]COCHAGE_AV(nolign-1) = 2
    Endif
    If [F:REO]VCRNUM <> ""
       [M:REO1]CREFLG    (nolign-1)   = 1
       [M:REO1]QTYSTUACT (nolign-1)   = [F:REO]QTYSTUORIA
       [M:REO1]CLEFLG    (nolign-1)   = [F:REO]CLEFLG
       Local    Integer  WRET
       Local    Integer  LBID
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
       Call STKWSTOSEQ("REO1",nolign-1,[M:REO1]NBLIG,1,LBID,WRET) From STKECR
       If WRET = 0
          Gosub SET_NOL From TRTREOA
          Gosub ALI_ALP From TRTREOA
   # Chargement STOSORW à partir des allocations
          Call ALLSTOSORW("REO1",nolign-1,[M:REO1]NBLIG,0,0,0,WRET) From STKSOR

          If WRET = 0
             Call RECSTOSOR (3,"REO1",nolign-1,[M:ALP]STOFCY,[M:ALP]ITMREF,
&                              [M:ALP]VCRTYP,"",0,"",WRET) From STKECR
          Endif
       Endif
    Endif
   # Demande 54822
    GPOINT = "REO_REO1" : Gosub ENTREE From EXEFNC

    NOL = nolign-1
    [M:REO1]NBLIG  = nolign
    nolign += 1
    Gosub FORMATAGE_CLE
    [M:REO1]WCLE   (NOL)   = WCLE_FOR

$NEXTREO
Next
Filter [F:REO]
Return


########################################################################
# LECTURE_STOALL_2                  lecture STOALL zones de consommation
########################################################################
$LECTURE_STOALL_2
Local Integer WLEC
WLEC = 0

# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
WMAX = dim([M:REO1]COCHAGE)     # mémorisation nombre de ligne maxi

For [STA]

# Verification que l enregistrement n existe pas dans le tableau
#    If VERIF = 2
#       Gosub CTR_EXI_REO1 From TRTREOA
#       If WEXI <> 0
#          Goto NEXTALL_2
#       Endif
#    Endif
    If nolign = WMAX : Break : Endif
    WLEC += 1
    [M:REO1]NBRCSM +=1
    [M:REO1]ORIREO      (nolign-1)   = 2
    [M:REO1]DEFTYPLOC   (nolign-1)   = [F:STA]DEFLOCTYP
    [M:REO1]DEFLOC      (nolign-1)   = [F:STA]DEFLOC
    [M:REO1]MODFLG      (nolign-1)   = 1
    [M:REO1]CREFLG      (nolign-1)   = 0
    [M:REO1]WFLG        (nolign-1)   = 1
    [M:REO1]CLEFLG      (nolign-1)   = 1
    [M:REO1]WSTOFLG     (nolign-1)   = 0
    [M:REO1]ITMREF      (nolign-1)   = [F:STA]ITMREF
    [M:REO1]BPRNUM      (nolign-1)   = ""
    [M:REO1]SRGLIN      (nolign-1)   = [F:STA]SRGLIN
    [M:REO1]SRGPPS      (nolign-1)   = [F:STA]SRGNUM
    [M:REO1]SRGPPS_AV   (nolign-1)   = [F:STA]SRGNUM
    If [F:STA]SRGNUM <> ""
        [M:REO1]LOCORI  (nolign-1)   = [F:STA]SRGLOC
        If dim([M:REO1]WRHORI) > 0
            Read [STC]STC0=[M:REO1]STOFCY;[F:STA]SRGLOC
            If !fstat [M:REO1]WRHORI(nolign-1)=[F:STC]WRH Endif
        Endif
    Else
        If !instr(1,[F:STA]DEFLOC ,'*') & !instr(1,[F:STA]DEFLOC,'?')
&        & !instr(1,[F:STA]DEFLOC ,'!') & !instr(1,[F:STA]DEFLOC,'#')
            [M:REO1]LOCORI      (nolign-1) = [F:STA]DEFLOC
            If dim([M:REO1]WRHORI) > 0
                [M:REO1]WRHORI  (nolign-1) = [F:STA]DEFWRH
            Endif
        Endif
    Endif
    [M:REO1]BESDAT      (nolign-1)   = [F:STA]BESDAT
    [M:REO1]QTYPCUORI   (nolign-1)   = [F:STA]QTYSTUACT
    [M:REO1]PCUSTUCOEO  (nolign-1)   = 1
    [M:REO1]QTYSTUORIA  (nolign-1)   = [F:STA]QTYSTUACT
    [M:REO1]QTYSTUORI   (nolign-1)   = [F:STA]QTYSTUACT
    [M:REO1]STOCOU      (nolign-1)   = [F:STA]STOCOU
    [M:REO1]VCRNUM      (nolign-1)   = [F:STA]VCRNUM
    [M:REO1]SEQ         (nolign-1)   = [F:STA]SEQ

    If [F:ITM]ITMREF<>[F:STA]ITMREF
        Read [F:ITM]ITM0=[F:STA]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
    [M:REO1]STU         (nolign-1)   = [F:ITM]STU
    [M:REO1]PCUORI      (nolign-1)   = [F:ITM]STU

    Read [STO] STO0=[F:STA]STOFCY;[F:STA]STOCOU
    If fstat
       Raz [F:STO]
       Goto NEXTALL_2               # si pas de ligne de stock correspondant on ignore
    Endif

    [M:REO1]STA      (nolign-1)   = [F:STO]STA
    If dim([M:REO1]WRH) > 0
       [M:REO1]WRH  (nolign-1)    = [F:STO]WRH
    Endif
    [M:REO1]LOC      (nolign-1)   = [F:STO]LOC
    If dim([M:REO1]LPNNUM) > 0                                                           # hcb x3-82749
 #      [M:REO1]LPNNUM(nolign-1)   = [F:STO]LPNNUM                                        # hcb x3-82749
       Raz [M:REO1]LPNNUM(nolign-1)                                                      # hcb x3-82749
    Endif                                                                                # hcb x3-82749
    If dim([M:REO1]LOT) > 0                                # hcb 27200
       [M:REO1]LOT      (nolign-1)   = [F:STO]LOT
    Endif                                                  # hcb 27200
    If dim([M:REO1]SLO) > 0                                # hcb 27200
       [M:REO1]SLO      (nolign-1)   = [F:STO]SLO
    Endif                                                  # hcb 27200
    If dim([M:REO1]SERNUM) > 0                             # hcb 27200
       [M:REO1]SERNUM   (nolign-1)   = [F:STO]SERNUM
    Endif                                                  # hcb 27200
    If dim([M:REO1]PALNUM) > 0                             # hcb 27200
       [M:REO1]PALNUM(nolign-1)   = [F:STO]PALNUM          # hcb 27200
       [M:REO1]CTRNUM(nolign-1)   = [F:STO]CTRNUM          # hcb 27200
    Endif                                                  # hcb 27200
    [M:REO1]QTYSTUACT (nolign-1)  = [F:STA]QTYSTUACT

# si liste à ranger = blanc alors liste du filtre si saisie manuelle
#    If VERIF = 2
#       If   [M:REO1]SRGPPS(nolign-1) = ""
#            [M:REO1]SRGPPS(nolign-1) = [M:REO1]SRGPPSSTR
#       Endif
#    Endif

    If   [M:REO1]SRGPPS(nolign-1) = ""
         [M:REO1]COCHAGE(nolign-1)    = 1
         [M:REO1]COCHAGE_AV(nolign-1) = 1
    Endif
    If   [M:REO1]SRGPPS(nolign-1) <> ""
         [M:REO1]COCHAGE(nolign-1)    = 2
         [M:REO1]COCHAGE_AV(nolign-1) = 2
    Endif
    If [F:STA]SRGNUM <> ""
       [M:REO1]CREFLG    (nolign-1)   = 1
       [M:REO1]QTYSTUACT (nolign-1)   = [F:STA]SRGQTYSTU
    Endif
   # Demande 84470
    GPOINT = "REO_REO1" : Gosub ENTREE From EXEFNC

    NOL = nolign-1
    [M:REO1]NBLIG  = nolign
    nolign += 1
$NEXTALL_2
Next
Filter [F:STA]
Return

########################################################################
# LECTURE_STOALL_4                 lecture STOALL rupture emplacement
########################################################################
$LECTURE_STOALL_4
Local Decimal WSTUACTDIS          : #--- Dem 64662
Local Integer WLEC, I
WLEC = 0
Local Integer WSTATUS  # hcb 84841

# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
WMAX = dim([M:REO1]COCHAGE)     # mémorisation nombre de ligne maxi

For [STA1]

# Verification que l enregistrement n existe pas dans le tableau
#    If VERIF = 2
#       Gosub CTR_EXI_REO1 From TRTREOA
#       If WEXI <> 0
#          Goto NEXTALL_4
#       Endif
#    Endif

   #--- Dem 64662
   # On ne charge que les lignes réapprovisionnable (stock disponible)
   If [M:REO1]STODIS=2
     I=0
     # S'il y a des allocations, la ligne sera chargée
     If [F:REO]VCRNUM<>""
       Columns [STA] (STOFCY,ITMREF,VCRTYP,SRGNUM,SRGLIN,ALLTYP)
       For [STA]STA0 Where STOFCY=[F:STA1]STOFCY & ITMREF=[F:STA1]ITMREF &
&                          SRGNUM=[F:STA1]VCRNUM & SRGLIN=[F:STA1]VCRLIN
           I=1 : Break
       Next
       Columns [STA]
     Endif
     # Pas d'allocation --> test sur stock dispo
     If I=0
       Read [ITV]ITV0=[F:STA1]ITMREF;[F:STA1]STOFCY
       If fstat Raz [F:ITV] Endif
       # Calcul stock disponible (emp internes et sous-traitant, statuts A,Q,R)
        WSTATUS = 7                                                            # hcb 84841
        GPOINT = "STODISTOT" : Gosub ENTREE From EXEFNC                        # hcb 84841
        Call STODISTOT("",5,WSTATUS,[M:REO1]STOFCY,WSTUACTDIS) From STKLIB     # hcb 84841
       # Pas de stock dispo
       If WSTUACTDIS<=0 Goto NEXTALL_4 Endif
     Endif
   Endif
   #---

    If nolign = WMAX : Break : Endif
    WLEC += 1
    [M:REO1]NBRSHT +=1
    [M:REO1]ORIREO      (nolign-1)   = 3
    [M:REO1]DEFTYPLOC   (nolign-1)   = ""
    [M:REO1]DEFLOC      (nolign-1)   = ""

    [M:REO1]MODFLG      (nolign-1)   = 1
    [M:REO1]CREFLG      (nolign-1)   = 0
    [M:REO1]WFLG        (nolign-1)   = 1
    [M:REO1]CLEFLG      (nolign-1)   = 1
    [M:REO1]WSTOFLG     (nolign-1)   = 0
    [M:REO1]ITMREF      (nolign-1)   = [F:STA1]ITMREF
    [M:REO1]BPRNUM      (nolign-1)   = ""
    [M:REO1]SRGLIN      (nolign-1)   = [F:STA1]SRGLIN
    [M:REO1]SRGPPS      (nolign-1)   = [F:STA1]SRGNUM
    [M:REO1]SRGPPS_AV   (nolign-1)   = [F:STA1]SRGNUM
    [M:REO1]LOCORI      (nolign-1)   = [F:STA1]LOC
    If dim([M:REO1]WRHORI) > 0
        [M:REO1]WRHORI  (nolign-1)   = [F:STA1]WRH
    Endif
    [M:REO1]BESDAT      (nolign-1)   = [F:STA1]BESDAT
    [M:REO1]QTYPCUORI   (nolign-1)   = [F:STA1]QTYSTUACT
    [M:REO1]PCUSTUCOEO  (nolign-1)   = 1
    [M:REO1]QTYSTUORIA  (nolign-1)   = [F:STA1]QTYSTUACT
    [M:REO1]QTYSTUORI   (nolign-1)   = [F:STA1]QTYSTUACT
    [M:REO1]VCRNUM      (nolign-1)   = [F:STA1]VCRNUM
    [M:REO1]STOCOU      (nolign-1)   = [F:STA1]STOCOU
    [M:REO1]SEQ         (nolign-1)   = [F:STA1]SEQ

    [M:REO1]STA         (nolign-1)   = [F:STA1]STA
    If dim([M:REO1]LOT) > 0                             # hcb 27200
       [M:REO1]LOT         (nolign-1)   = [F:STA1]LOT
    Endif                                               # hcb 27200
    If dim([M:REO1]SLO) > 0                             # hcb 27200
       [M:REO1]SLO         (nolign-1)   = [F:STA1]SLO
    Endif                                               # hcb 27200
    If dim([M:REO1]SERNUM) > 0                          # hcb 27200
       [M:REO1]SERNUM      (nolign-1)   = [F:STA1]SERNUM
    Endif                                               # hcb 27200
    If [F:ITM]ITMREF<>[F:STA1]ITMREF
        Read [F:ITM]ITM0=[F:STA1]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif

    [M:REO1]STU         (nolign-1)   = [F:ITM]STU
    [M:REO1]PCUORI      (nolign-1)   = [F:ITM]STU

# si liste à ranger = blanc alors liste du filtre si saisie manuelle
#    If VERIF = 2
#       If   [M:REO1]SRGPPS(nolign-1) = ""
#            [M:REO1]SRGPPS(nolign-1) = [M:REO1]SRGPPSSTR
#       Endif
#    Endif

    If   [M:REO1]SRGPPS(nolign-1) = ""
         [M:REO1]COCHAGE(nolign-1)    = 1
         [M:REO1]COCHAGE_AV(nolign-1) = 1
    Endif
    If   [M:REO1]SRGPPS(nolign-1) <> ""
         [M:REO1]COCHAGE(nolign-1)    = 2
         [M:REO1]COCHAGE_AV(nolign-1) = 2
    Endif
    If [F:STA1]SRGNUM <> ""
       [M:REO1]CREFLG    (nolign-1)   = 1
       [M:REO1]QTYSTUACT (nolign-1)   = [F:STA1]SRGQTYSTU
       Local    Integer  WRET
       Local    Integer  LBID
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
       Call STKWSTOSEQ("REO1",nolign-1,[M:REO1]NBLIG,1,LBID,WRET) From STKECR
       If WRET = 0
          Gosub SET_NOL From TRTREOA
          Gosub ALI_ALP From TRTREOA
          # Chargement STOSORW à partir des allocations
          Call ALLSTOSORW("REO1",nolign-1,[M:REO1]NBLIG,0,0,0,WRET) From STKSOR
          If WRET = 0
             Call RECSTOSOR (3,"REO1",nolign-1,[M:ALP]STOFCY,[M:ALP]ITMREF,
&                              [M:ALP]VCRTYP,"",0,"",WRET) From STKECR
          Endif
       Endif

    Endif
   # Demande 84470
    GPOINT = "REO_REO1" : Gosub ENTREE From EXEFNC

    NOL = nolign-1
    [M:REO1]NBLIG  = nolign
    nolign += 1

$NEXTALL_4
Next
Filter [F:STA1]
Return

########################################################################
# ACT_PIKREO Selection par saisie rubrique cle remplisssage tableau REO1
#                                                     apres_modif ITMREF
########################################################################
$ACT_PIKREO
Local Char    CRITERE(255)
Local Char    CRITER2(255)
Local Char LSRG(GLONVCR)               # hcb 57490
LSRG = ""
# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif
Local Integer VERIF
VERIF = 2

CRITERE = "[F:REO]STAFLG<>2&[F:REO]STOFCY=[M:REO1]STOFCY&[F:REO]VCRNUM=LSRG"
CRITER2 = "[F:REO]LOC=[M:REO1]LOCORI(NOL)&[F:REO]ITMREF=VALEUR"

Filter [REO]  Where evalue(CRITERE)&evalue(CRITER2)
&                Order By Key REO0

Gosub LECTURE_STOREO

Filter [REO]
If WLEC = 0
   mkstat=2
   If WEXI <> 0
      GMESSAGE=mess(14,184,1)    #  Enregistrement  déjà présent dans le tableau  !
   Else
      GMESSAGE=mess(13,184,1)    # Aucun enregistrement en attente de rangement correspondant
   Endif
Else
   [M:REO1]MODFLG     (NOL)  = 2
   [M:REO1]COCHAGE    (NOL)  = 2

   [M:REO1]SAIFLG     = 2         # saisie manuelle à oui permet de desactiver les boutons recherche critere
   [M:REO1]QTYSTUACT   (NOL) = [M:REO1]QTYSTUORIA   (NOL)
   If   [M:REO1]SRGPPS(NOL) = ""
        [M:REO1]SRGPPS(NOL) = [M:REO1]SRGPPSSTR
   Endif
   Affzo [M:REO1]30                        # hcb X3-107136
   Affzo [M:REO1]NBRLOC

 # il faut activer les zones de cle sur la ligne vide ....

   NOL = [M:REO1]NBLIG
   Gosub ACT_RUB_CLE

Endif
Return

########################################################################
# APRES_STOSOR          Mise à jour complémentaires après enregistrement
########################################################################
$APRES_STOSOR
Local Integer OK
Local Integer NOL

#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOR]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOR]SORQTY    contient la quantité US qui était à sortir
#   [M:SOR]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOR]PECQTY    contient la quantité US sortie
#   [M:SOR]PECQTYACT contient la quantité en UA sortie
#   [M:SOR]SHTQTY    contient la quantité UA sortie manquante
Local Decimal WQTY
Local Integer J
Raz WQTY

If WGENR=1
    GREP = "M"

    [M:REO1]QTYSTUACT(LNOL) = [M:SOR]PECQTYACT+[M:SOR]SHTQTY
    [M:REO1]MODFLG(LNOL) = 2

    If [M:REO1]QTYSTUACT(LNOL) < [M:REO1]QTYSTUORIA(LNOL) & [M:REO1]CLEFLG(LNOL) <> 2 & [M:REO1]ORIREO(LNOL) = 1
        GMESSAGE = mess(74,184,1)
      # Non par défaut
        OK=0
        Call OUINON(GMESSAGE,OK) From GESECRAN
        Raz GMESSAGE
      # Saisie non confirmée
        If OK = 2
          [M:REO1]CLEFLG(LNOL) = 2
        Endif
    Endif
Endif
# controle qu il y ai une sortie de faite sinon effacement et decochage

WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:REO1]WSTOSEQ(LNOL)))
# si qty = 0 à sortir est <> qty sortie  et que le solde = non  => rouge
If WQTY = 0 & [M:REO1]CLEFLG(LNOL) <> 2
       [M:REO1]COCHAGE           (LNOL)    = 1
        Raz [M:REO1]SRGPPS        (LNOL)
        Raz [M:REO1]WSTOFLG       (LNOL)
        Raz [M:REO1]QTYSTUACT     (LNOL)
        If [M:REO1]ORIREO(LNOL) <> 2
           If dim([M:REO1]LOT) > 0
              Raz [M:REO1]LOT           (LNOL)
           Endif
           If dim([M:REO1]SLO) > 0
              Raz [M:REO1]SLO           (LNOL)
           Endif
           If dim([M:REO1]SERNUM) > 0
              Raz [M:REO1]SERNUM        (LNOL)
              Raz [M:REO1]SERNUMF       (LNOL)
           Endif
           If dim([M:REO1]PALNUM) > 0                  # hcb 27200
              Raz [M:REO1]PALNUM        (LNOL)         # hcb 27200
              Raz [M:REO1]CTRNUM        (LNOL)         # hcb 27200
           Endif                                       # hcb 27200
           Raz [M:REO1]STA              (LNOL)
           If dim([M:REO1]LPNNUM) > 0                                                    # hcb x3-82749
              Raz [M:REO1]LPNNUM        (LNOL)                                           # hcb x3-82749
#              Affzo [M:REO1]LPNNUM      (LNOL)                                           # hcb x3-82749
           Endif                                                                         # hcb x3-82749
           If dim([M:REO1]LOC) > 0
              Raz [M:REO1]LOC           (LNOL)
           Endif
           If dim([M:REO1]WRH) > 0
              Raz [M:REO1]WRH           (LNOL)
           Endif
        Endif
        Raz [M:REO1]MVTDES        (LNOL)
        Raz [M:REO1]CLEFLG        (LNOL)

        Affzo [M:REO1]COCHAGE     (LNOL)
        Affzo [M:REO1]SRGPPS      (LNOL)
        Affzo [M:REO1]WSTOFLG     (LNOL)
        Affzo [M:REO1]QTYSTUACT   (LNOL)
        If dim([M:REO1]LOT) > 0
           Affzo [M:REO1]LOT         (LNOL)
        Endif
        If dim([M:REO1]SLO) > 0
           Affzo [M:REO1]SLO         (LNOL)
        Endif
        If dim([M:REO1]SERNUM) > 0
           Affzo [M:REO1]SERNUM      (LNOL)
           Affzo [M:REO1]SERNUMF     (LNOL)
        Endif
        If dim([M:REO1]PALNUM) > 0                  # hcb 27200
           Affzo [M:REO1]PALNUM      (LNOL)         # hcb 27200
           Affzo [M:REO1]CTRNUM      (LNOL)         # hcb 27200
        Endif                                       # hcb 27200

        Affzo [M:REO1]STA         (LNOL)
        If dim([M:REO1]LOC) > 0
           Affzo [M:REO1]LOC         (LNOL)
        Endif
        If dim([M:REO1]WRH) > 0
           Raz [M:REO1]WRH           (LNOL)
        Endif
        Affzo [M:REO1]MVTDES      (LNOL)
        Affzo [M:REO1]CLEFLG      (LNOL)

        If dim([M:REO1]CLEFLG(LNOL)) > 0
          Actzo [M:REO1]CLEFLG(LNOL)
        Endif

        Raz   [M:REO1]WSTOFLG     (LNOL)
        [M:REO1]MODFLG            (LNOL)    = 1
        Call MAJ_STA_STAFLG(LNOL,1)  From TRTREOA    # mise à jour du flag STAFLG à 1
        NOL = LNOL
Else
     If WQTY <> [M:REO1]QTYSTUACT(LNOL)
        [M:REO1]QTYSTUACT(LNOL) = [M:SOR]PECQTYACT+[M:SOR]SHTQTY
        Call MAJ_STA_STAFLG(LNOL,2)  From TRTREOA    # mise à jour QTYSTUORIA
     Endif
Endif

Return

########################################################################
# AB_TRT                                       Abandon de la transaction
########################################################################
$AB_TRT
Rollback
Return

#########################################################################
# ALI_ALP       Chargement du masque de paramétrage pour composants stock
#########################################################################
$ALI_ALP

Gosub LEC_STOLOC From TRTREOA
[M:ALP]VCRTYP    = [M:REO1]VCRTYP       # 34
[M:ALP]TRSTYP    = [M:REO1]TRSTYP       # 25
[M:ALP]TRSCOD    = [M:REO1]TRSCOD       # hcb 50197
[M:ALP]STOFCY    = [M:REO1]STOFCY
[M:ALP]ITMREF    = [M:REO1]ITMREF(NOL)
[M:ALP]QTY       = [M:REO1]QTYSTUACT(NOL)
[M:ALP]TYPQTY    = 2
[M:ALP]PCU       = [M:REO1]PCUORI(NOL)
[M:ALP]PCUSTUCOE = [M:REO1]PCUSTUCOEO(NOL)

[M:ALP]BESDAT    = [M:REO1]BESDAT(NOL)
[M:ALP]DLVDAT    = [M:REO1]BESDAT(NOL)
[M:ALP]ALLDAT    = [0/0/0]
[M:ALP]STOLOC    = ""
[M:ALP]PECINTLOC = 2
[M:ALP]PECSCOLOC = 1
[M:ALP]PECPLFLOC = 2
[M:ALP]PECCUNLOK = 1
[M:ALP]VCRNUM    = [M:REO1]SRGPPS  (NOL)
[M:ALP]AUZSST    = [F:STC]AUZSST
[M:ALP]LOCCAT    = [F:STC]LOCCAT
# test pour ne pas alimenter l emplacement par lui meme"
# filsto rajouer pour eviter d alimenter l emplacement par lui meme ...
GREOLOC   = [M:REO1]LOCORI(NOL)
[M:ALP]FILSTO    = '[F:STO1]LOC <> GREOLOC'
If [M:REO1]SRGPPS  (NOL) <> ""
   [M:ALP]VCRLIN     = [M:REO1]SRGLIN  (NOL)
Else
   [M:ALP]VCRLIN     = 0
Endif
[M:ALP]VCRSEQ    = 0
Raz [M:ALP]LOT, [M:ALP]LOC, [M:ALP]STA
If dim([M:REO1]WRH)>0 [M:ALP]WRH=[M:REO1]WRH(NOL) Endif

Return

########################################################################
# TRT_LCK                    Traitement des blocages (conflit d'accès) #
########################################################################
$TRT_LCK
GMESSAGE=GLOCK-mess(60,100,1)          # Enregistrement verrouillé
If [M:STW]TRAFLG>1
  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Else
  Call MESSAGE(GMESSAGE)     From GESECRAN
Endif
GOK=-1
LRET = 1

Return

########################################################################
# TRT_ERR                                       Traitement des erreurs #
########################################################################
#  1 = Erreur d'accès sur le fichier                                   #
#  2 = Erreur d'écriture sur le fichier                                #
$TRT_ERR
Case WERR
  When 1 : GMESSAGE=mess(12,100,1)-WCLE
  When 2 : GMESSAGE=mess(13,100,1)-WCLE
  When 3 : GMESSAGE= mess(842,196,1)
  When 4 : GMESSAGE= mess(30,196,1)
Endcase
If [M:STW]TRAFLG>1
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
GOK=0
LRET = 1

Return

########################################################################
# CTL_VALIDATION       Controle que la validation peut bien etre faite #
########################################################################
$CTL_VALIDATION
# Pour chaque ligne cochée il faut une quantitée <> 0 sauf si solde à oui
Raz LRET
For NOL = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(NOL) = 2
       If [M:REO1]CLEFLG(NOL) <> 2 & [M:REO1]QTYSTUACT(NOL) = 0
          LRET = 1
          Break
       Endif
    Endif
$SUIT_VAL
Next NOL

Return

########################################################################
# LEC_STOLOC                                            Lecture STOLOC #
########################################################################
$LEC_STOLOC
If [M:REO1]LOCORI(NOL)<>""
   If [F:STC]STOFCY<>[M:REO1]STOFCY | [F:STC]LOC<>[M:REO1]LOCORI(NOL)
      Read [STC] STC0=[M:REO1]STOFCY ;[M:REO1]LOCORI(NOL)
      If fstat
         Raz [F:STC]
      Endif
    Endif
Endif
Return

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
########################################################################
# ACT_SELREO   bouton RECHERCHE             remplisssage du tableau REO1
# ACT_LISREO   bouton LISTE    affectation d un numéro de liste à ranger
# ACT_ENRREO   bouton ENREGISTREMENT       enregistrement liste à ranger
# ACT_VALREO   bouton VALIDATION réalisation  changements d emplacements
# ACT_TRIREO   bouton TRI          Tri du tableau REO1 selon parametrage

########################################################################
Subprog ACT_SELREO

Gosub DECOCHAGE_REO1
Effzo [M:REO1]30                                    # hcb X3-107136
nolign = 1
REP = ""
GREP = ""

Local Char    CRITERE   (255)
Local Char    CRITERE0  (255)
Local Char    CRITERE1  (255)
Local Char    CRITERE3  (255)
Local Char    CRITERE0_2(255)
Local Char    CRITERE1_2(255)
Local Char    CRITERE3_2(255)
Local Char    CRITERE0_3(255)
Local Char    CRITERE1_3(255)
Local Char    CRITERE3_3(255)
Local Char    FORMULE1(250)
Local Char    FORMULE2(250)
Local Char    FORMULE3(250)

Local Date    TODAY : TODAY = date$

Local Integer NOL
Local Integer I
I = 0

# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif
Local Integer VERIF
VERIF = 1

If GLOCREO = 2
   Raz [M:REO1]NBRLOC
# filtre bloc filtre
   Gosub LOAD_FILTER
# filtre bloc borne debut/fin
   Gosub LOAD_FILTER3

   # Demande 49877
   GPOINT = "NEW_CRIT" : Gosub ENTREE From EXEFNC

   nolign = 1
   If [M:REO1]SRGPPSSTR <> ""
      Filter [REO]  Where evalue(CRITERE0)
&                   Order By Key REO1
      Gosub LECTURE_STOREO

      If [M:REO1]LSTWIOFLG = 1
         Goto LEC_STA2
      Endif
   Endif

   If CRITERE1  = "" CRITERE1  = "1=1"  : Endif
   If CRITERE3  = "" CRITERE3  = "1=1"  : Endif

# analyse présence formule de sélection
   If [M:REO1]FORMULE  = ""
      FORMULE1 = "1=1"
   Else
      Read [F:TFO]TFO0=20;[M:REO1]FORMULE
      If fstat
         FORMULE1 = "1=1"
      Else
         FORMULE1 = [F:TFO]FORFOR
      Endif
   Endif

# RECHERCHE meilleur cle pour optimisation
   Gosub RECH_CLE

   Case WCLE
        When 0 :
           Filter [REO]  Where evalue(CRITERE1)&evalue(CRITERE3)&
&                              evalue(FORMULE1)
&                        Order By Key REO0
        When 1 :
           Filter [REO]  Where evalue(CRITERE1)&evalue(CRITERE3)&
&                              evalue(FORMULE1)
&                        Order By Key REO1
   Endcase
   Gosub LECTURE_STOREO
Endif

$LEC_STA2

If GCSMREO = 2
   Raz [M:REO1]NBRCSM
# filtre bloc filtre
   Gosub LOAD_FILTER_2
# filtre bloc borne debut/fin
   Gosub LOAD_FILTER3_2

   # Demande 49877
   GPOINT = "NEW_CRIT" : Gosub ENTREE From EXEFNC

   If [M:REO1]SRGPPSSTR <> ""
      Filter [STA]  Where evalue(CRITERE0_2)
&                   Order By Key STA0
      Gosub LECTURE_STOALL_2

      If [M:REO1]LSTWIOFLG = 1
         Goto LEC_STA4
      Endif
   Endif

   If CRITERE1_2  = "" CRITERE1_2  = "1=1"  : Endif
   If CRITERE3_2  = "" CRITERE3_2  = "1=1"  : Endif

# analyse présence formule de sélection
   If [M:REO1]FORMUL2  = ""
      FORMULE2 = "1=1"
   Else
      #MAE, bg 82647
      #Read [F:TFO]TFO0=20;[M:REO1]FORMUL2
      Read [F:TFO]TFO0=24;[M:REO1]FORMUL2
      If fstat
         FORMULE2 = "1=1"
      Else
         FORMULE2 = [F:TFO]FORFOR
      Endif
   Endif

# RECHERCHE meilleur cle pour optimisation
   Gosub RECH_CLE_2

   Case WCLE
        When 0 :
           Filter [STA]  Where evalue(CRITERE1_2)&evalue(CRITERE3_2)&
&                              evalue(FORMULE2)
&                        Order By Key STA0
        When 1 :
           Filter [STA]  Where evalue(CRITERE1_2)&evalue(CRITERE3_2)&
&                              evalue(FORMULE2)
&                        Order By Key STA1
        When 2 :
           Filter [STA]  Where evalue(CRITERE1_2)&evalue(CRITERE3_2)&
&                              evalue(FORMULE2)
&                        Order By Key STA3
   Endcase

   Gosub LECTURE_STOALL_2
Endif

$LEC_STA4

If GSHTREO = 2
   Raz [M:REO1]NBRSHT
# filtre bloc filtre
   Gosub LOAD_FILTER_3
# filtre bloc borne debut/fin
   Gosub LOAD_FILTER3_3
   # Demande 49877
   GPOINT = "NEW_CRIT" : Gosub ENTREE From EXEFNC

   If [M:REO1]SRGPPSSTR <> ""
      Filter [STA1]  Where evalue(CRITERE0_3)
&                   Order By Key STA0
      Gosub LECTURE_STOALL_4

      If [M:REO1]LSTWIOFLG = 1
         Goto TRI_REO1
      Endif
   Endif

   If CRITERE1_3  = "" CRITERE1_3  = "1=1"  : Endif
   If CRITERE3_3  = "" CRITERE3_3  = "1=1"  : Endif

# analyse présence formule de sélection
   If [M:REO1]FORMUL3  = ""
      FORMULE3 = "1=1"
   Else
      #MAE, bg 82647
      #Read [F:TFO]TFO0=20;[M:REO1]FORMUL3
      Read [F:TFO]TFO0=25;[M:REO1]FORMUL3
      If fstat
         FORMULE3 = "1=1"
      Else
         FORMULE3 = [F:TFO]FORFOR
      Endif
   Endif

# RECHERCHE meilleur cle pour optimisation
   Gosub RECH_CLE_4

   Case WCLE
        When 0 :
           Filter [STA1]  Where evalue(CRITERE1_3)&evalue(CRITERE3_3)&
&                              evalue(FORMULE3)
&                        Order By Key STA0
        When 1 :
           Filter [STA1]  Where evalue(CRITERE1_3)&evalue(CRITERE3_3)&
&                              evalue(FORMULE3)
&                        Order By Key STA1
        When 2 :
           Filter [STA1]  Where evalue(CRITERE1_3)&evalue(CRITERE3_3)&
&                              evalue(FORMULE3)
&                        Order By Key STA2
   Endcase

   Gosub LECTURE_STOALL_4
Endif

$TRI_REO1

If [M:REO1]NBLIG > 0
   Gosub TRI_TAB
Endif
Affzo [M:REO1]NBRLOC
Affzo [M:REO1]NBRCSM
Affzo [M:REO1]NBRSHT
End

########################################################################
# ACT_LISREO   bouton LISTE    affectation d un numéro de liste à ranger
########################################################################
Subprog ACT_LISREO
Local Integer WRET
Local Integer I
Local Integer WCOCHAGE
# attentio on ne reaffecte pas de liste dont la liste precedente à ete mise à blanc
#  probleme de gestion des allocations

For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE (I) = 2 & [M:REO1]SRGPPS (I) = "" & [M:REO1]CREFLG (I) = 0
       WCOCHAGE = 1
       Break
    Endif
Next I

If WCOCHAGE = 1
   Call DEBTRANS From GLOCK
   Trbegin [REO]
   Raz [M:REO1]SRGPPSEND
   Call NUMERO(GSTKCPT(18),[M:REO1]STOFCY,date$,[M:REO1]ITMREF(I),[M:REO1]SRGPPSEND,WRET) From SUBANM
   If WRET = 1
      GERR = 1
      GMESSAGE= mess(842,196,1)
   Endif
   If WRET = 2
      GERR = 1
      GMESSAGE= mess(30,196,1)
   Endif
   If WRET = 0
      Commit
   Else
      Rollback
      End
   Endif

   For I = 0 To [M:REO1]NBLIG-1
       If [M:REO1]COCHAGE (I) = 2 & [M:REO1]SRGPPS   (I) = "" & [M:REO1]CREFLG (I) = 0
          [M:REO1]SRGPPS  (I) =     [M:REO1]SRGPPSEND
       Endif
   Next I
Endif
Affzo [M:REO1]

End

########################################################################
# ACT_ENRREO         bouton ENREGISTREMENT enregistrement liste à ranger
########################################################################
Subprog ACT_ENRREO

Local Integer I
Local Integer NOL
# enregistrement impossible si enregistrements cochés sans liste à ranger
#                sauf si liste avant renseigné (mise à blanc du numero)

Local Integer WOK
WOK = 0
For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(I) = 2 & [M:REO1]SRGPPS(I) = "" & [M:REO1]SRGPPS_AV(I) = ""
       WOK = 9
       Break
    Endif
Next I
If WOK = 9
      GERR = 1
      GMESSAGE=mess(15,184,1)    # Enregistrement(s) coché(s) sans liste à ranger !
      End
Endif

Call DEBTRANS From GLOCK
Trbegin [REO]
I = 0

For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(I) = 2
       NOL = I
       Call MAJ_REO_SRGPPS (I,[M:REO1]SRGPPS(I))   # reecriture STOREO avec new liste et staflg à 1
       If GOK < 1
          Gosub AB_TRT
          End
       Endif
       If  [M:REO1]ORIREO(I) <> 2               # si type 2 (zone de consommation) pas de creation d alloc !
           Gosub LEC_STOLOC From TRTREOA
           [M:ALP]VCRTYP    = [M:REO1]VCRTYP    # 34
           [M:ALP]TRSTYP    = [M:REO1]TRSTYP    # 25
           [M:ALP]TRSCOD    = [M:REO1]TRSCOD    # hcb 50197
           [M:ALP]STOFCY    = [M:REO1]STOFCY
           [M:ALP]ITMREF    = [M:REO1]ITMREF     (I)
           [M:ALP]QTY       = [M:REO1]QTYSTUACT  (I)
           [M:ALP]MVTDES    = [M:REO1]MVTDES     (I)
           [M:ALP]PCU       = [M:REO1]PCUORI     (I)
           [M:ALP]PCUSTUCOE = [M:REO1]PCUSTUCOEO (I)
           [M:ALP]BESDAT    = [M:REO1]BESDAT     (I)
           [M:ALP]AUZSST    = [F:STC]AUZSST
           [M:ALP]LOCCAT    = [F:STC]LOCCAT
           [M:ALP]STOLOC    = ""
           [M:ALP]PECINTLOC = 2
           [M:ALP]PECSCOLOC = 1
           [M:ALP]PECPLFLOC = 2
           [M:ALP]PECCUNLOK = 1
           [M:ALP]VCRNUM    = [M:REO1]SRGPPS     (I)
           If [M:REO1]SRGPPS  (I) <> ""
              [M:ALP]VCRLIN     = [M:REO1]SRGLIN (I)
           Else
              [M:ALP]VCRLIN     = 0
           Endif
# cas de mise à blanc de la liste il faut annuler les allocations
           If [M:REO1]SRGPPS  (I) = "" & [M:REO1]SRGPPS_AV  (I) <> ""
              [M:ALP]VCRNUM       = [M:REO1]SRGPPS_AV  (I)
              [M:ALP]VCRLIN       = [M:REO1]SRGLIN     (I)
              [M:ALP]QTY          = 0
           Endif
           [M:ALP]VCRSEQ    = 0
           [M:ALP]FILSTO    = ""
           [M:ALP]TYPQTY    = 2
           Raz [M:ALP]ALLDAT   , [M:ALP]DESQTY   , [M:ALP]ALLQTY
           Raz [M:ALP]VCRTYPORI, [M:ALP]VCRNUMORI,[M:ALP]VCRLINORI
           Raz [M:ALP]VCRSEQORI, [M:ALP]ALLTYPORI
           Raz [M:ALP]LOT      , [M:ALP]LOC      , [M:ALP]STA
       # Mise à jour des allocations à partir de l'écran de travail STOSORW
           Call ENRSTOALL([M:REO1]WSTOSEQ(I),0,WOK) From STKALL
           If WOK<>0
              Gosub AB_TRT
              End
           Endif
          [M:REO1]CREFLG(I) = 1
       Endif
       [M:REO1]CREFLG(I) = 1    # hcb 67209
    Endif
$NEXTI_ENRSSL
Next I

Commit

REP = ""
GREP = ""

Local Integer LRET
Call STKDELRES(0,[M:REO1]STOFCY,"",LRET) From STKLOC

End

########################################################################
# ACT_VALREO  bouton VALIDATION  réalisation  changements d emplacements
########################################################################
Subprog ACT_VALREO

Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR
Local Integer LNBJ
Local Integer LRET
Local Integer NOL
Local Integer WSOLDE
Local Char    WCLE(60)
Local Char    WFIC(10)
Local Integer WERR
Local Integer WVCRLIN
Local Char    WVCRNUM(GLONVCR)               # hcb 57490
Local Char    WSRGPPS_ORI2 (GLONVCR)         # hcb 57490
Local Char    MES(255)
Raz MES
Raz WVCRNUM
Raz WVCRLIN
Raz WSRGPPS_ORI2
LRET = 0

# Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
If GSTOTRACE>1
  Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 9 | [F:SRT]SRTNUM <> GREONUM                   # hcb 50197
   Read [SRT]SRT0=9;GREONUM : If fstat Raz [F:SRT] : Endif
Endif

Gosub  CTL_VALIDATION From TRTREOA
If LRET = 1
    Call ERREUR(mess(79,184,1)-num$(NOL)) From GESECRAN
   End
Endif
Call DEBTRANS From GLOCK
Trbegin [REO]

# calcul  numero document réappro zone consommation
Call NUMERO(GSTKCPT(19),[M:REO1]STOFCY,date$,[M:REO1]ITMREF(0),WVCRNUM,LRET) From SUBANM
If LRET = 1
   Call ERREUR(mess(842,196,1)) From GESECRAN
   Commit
   End
Endif
If LRET = 2
   Call ERREUR(mess(30,196,1)) From GESECRAN
   Commit
   End
Endif

For NOL = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(NOL) = 2
       WSOLDE = 0
#       [M:STW]TRAFLG= [F:SRT]TRAFLG         # hcb 50197
#       If GUSER  = "HCB"
#          [M:STW]TRAFLG=4
#       Endif

       If [M:REO1]QTYSTUACT(NOL) <> 0
       # Initialisation de l'en-tête
           Raz [M:STW]
          [M:STW]STOFCY     = [M:REO1]STOFCY         # Site
          [M:STW]TRSTYP     = 25                     # Réappro zones de consommation
          [M:STW]ITMREF     = [M:REO1]ITMREF (NOL)   # Article
          If [M:REO1]ORIREO (NOL)  = 2
             [M:STW]SEQALL  = [M:REO1]SEQ    (NOL)   # sequence allocation uniquement zone de consommation
             If [M:REO1]CREFLG(NOL) = 0 & [M:REO1]SRGPPS(NOL) =  ""
                If WSRGPPS_ORI2 = ""
                   Call NUMERO(GSTKCPT(18),[M:REO1]STOFCY,date$,[M:REO1]ITMREF(NOL),WSRGPPS_ORI2,LRET) From SUBANM
                   If LRET <> 0
                      WERR = LRET + 2
                      Gosub TRT_ERR
                      Break
                   Endif
                Endif
                [M:REO1]SRGPPS(NOL) = WSRGPPS_ORI2
                [M:REO1]CREFLG(NOL) = 1
                Call MAJ_REO_SRGPPS (NOL,[M:REO1]SRGPPS(NOL))   # reecriture STOREO avec new liste et staflg à 1
                If GOK < 1
                   LRET = 1
                   Break
                Endif
             Endif
          Else
             [M:STW]SEQALL  = 0
          Endif
          [M:STW]LOCENT     = [M:REO1]LOCORI (NOL)   # Emplacement de destination
          [M:STW]MVTDES     = [M:REO1]MVTDES (NOL)   # Désignation mouvement
          [M:STW]ENTCOD     = [F:SRT]ENTCOD          # Famille mouvement
          [M:STW]IPTDAT     = date$                  # Date imputation
          [M:STW]PRIORDH    = 0
          [M:STW]PJT        = ""
          [M:STW]TRSFAM     = ""
#          [M:STW]CCECOD     = "STJSOR"               # CODE section analytique stock sortie
# mis en commentaire le 01 06 04 à la demande de Gilles lefevbre
          [M:STW]CUR       = GLOCALDEV
          [M:STW]BPRNUM    = ""

          WVCRLIN +=1
# cas de creation sans liste à ranger  origine = stosorw
          If [M:REO1]CREFLG(NOL) <> 1
             [M:STW]VCRTYP  = [M:REO1]VCRTYP         # Type réappro zone consommation
             [M:STW]VCRNUM  = WVCRNUM                # Numéro document réappro zone consommation
             [M:STW]VCRLIN  = WVCRLIN*100            # Numero ligne document réappro zone consommation
             Call ALISTOWORK( 3, [M:REO1]WSTOSEQ(NOL), LQTA, LSHT,LNBR,LNBJ, LRET ) From STKINT
          Else
# cas de creation avec liste à ranger  origine = stoall
             If [M:REO1]SRGPPS(NOL) <> ""
                [M:STW]VCRTYP  = [M:REO1]VCRTYP         # Type réappro zone consommation
                [M:STW]VCRNUM  = [M:REO1]SRGPPS (NOL)   # Numero liste à ranger
                [M:STW]VCRLIN  = [M:REO1]SRGLIN (NOL)   # Numero ligne liste à ranger
                Call ALISTOWORK( 1, [M:REO1]WSTOSEQ(NOL), LQTA, LSHT,LNBR,LNBJ, LRET ) From STKINT
                [M:STW]VCRTYP  = [M:REO1]VCRTYP         # Type réappro zone consommation
                [M:STW]VCRNUM  = WVCRNUM                # Numéro document réappro zone consommation
                [M:STW]VCRLIN  = WVCRLIN*100            # Numero ligne document réappro zone consommation
             Endif
          Endif
        #Mise à jour des stock
          If LRET=0
             Call MAJ_STOCK From STKMAJ
          Endif
          If LRET <> 0 | GOK < 1
             LRET = 1
             Break
          Endif
       Endif
       Case [M:REO1]ORIREO(NOL)
            When 1
# prise en compte choix solde de la ligne
               WSOLDE = [M:REO1]CLEFLG(NOL)
# si quantité sortie > ou = on solde la ligne
               If WSOLDE <> 2
                  If [M:REO1]QTYSTUACT(NOL) >= [M:REO1]QTYSTUORIA(NOL)
                     WSOLDE = 2
                  Endif
               Endif
# si solde on supprime la ligne STOREO
               WCLE = "STOREO"-[M:REO1]STOFCY-[M:REO1]ITMREF(NOL)-[M:REO1]LOCORI(NOL)

               If WSOLDE = 2
                  Delete [F:REO] Where STOFCY     = [M:REO1]STOFCY      &
&                                      LOC        = [M:REO1]LOCORI(NOL) &
&                                      ITMREF     = [M:REO1]ITMREF(NOL)

                  If fstat=1
                     GLOCK="$STOREO"-WCLE
                     Gosub TRT_LCK
                     Break
                  Elsif fstat
                     Call RSTA("REO",[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)) From GLOCK
                     WERR=1           # Erreur d'accès sur le fichier
                     Gosub TRT_ERR
                     Break
                  Endif

                  If [M:STW]TRAFLG>2
                     WMESSAGE=mess(175,197,1) : # Suppression
                     WFIC ="STOREO"
                     Gosub TRACE_DETAILLEE From STKMAJSUP
                  Endif
               Else
                  Readlock [F:REO]REO0 = [M:REO1]STOFCY;[M:REO1]LOCORI(NOL);[M:REO1]ITMREF(NOL)
                  If fstat=1
                     GLOCK="$STOREO"-WCLE
                     Gosub TRT_LCK
                     Break
                  Elsif fstat
                     Call RSTA("REO",[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)) From GLOCK
                     WERR=1           # Erreur d'accès sur le fichier
                     Gosub TRT_ERR
                     Break
                  Endif
# si pas solde reécriture de la ligne avec le reste à sortir

                  Raz [F:REO]QTYSTUORIA,[F:REO]CLEFLG
                  Raz [F:REO]VCRNUM,    [F:REO]VCRTYP
                  [F:REO]QTYSTUACT = [M:REO1]QTYSTUORIA(NOL) - [M:REO1]QTYSTUACT(NOL)
                  If [F:REO]DEFPOT <> 0
                     [F:REO]QTYSTU    = ([F:REO]QTYSTUACT * 100) / [F:REO]DEFPOT
                     Call QTEARR([F:REO]QTYSTU,[F:REO]STU) From TRTDIV
                  Else
                     [F:REO]QTYSTU    = [F:REO]QTYSTUACT
                  Endif

                  [F:REO]QTYPCU = [F:REO]QTYSTU
                  [F:REO]PCU    = [F:REO]STU
                  [F:REO]STAFLG = 1
                  [F:REO]PCUSTUCOE = 1
                  [F:REO]UPDDAT = date$
                  [F:REO]UPDUSR = GUSER
                  Rewrite [F:REO]
                  If fstat
                     Call RSTA("REO",[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)) From GLOCK
                     WERR=2          # Erreur d'écriture sur le fichier
                     Gosub TRT_ERR
                     Break
                  Endif
                  If [M:STW]TRAFLG>2
                      WMESSAGE=mess(232,197,1) # Réécriture
                      WFIC ="STOREO"
                      Gosub TRACE_DETAILLEE From STKMAJSUP
                  Endif
               Endif
            When 3
               #--- Dem 71718
               Local Decimal LSTOCOU
               Local Decimal WALLQTY
               Local Decimal WQTYSTUORI             # hcb 84767
               Local Decimal WQTYSTUORIA            # hcb 84767
               Local Date    WDAT
               Local Integer WRET
               Local Integer LMODALL
               WRET=0
               Read [STA]STA0=[M:REO1]STOFCY;[M:REO1]ITMREF(NOL);
&                             [M:REO1]STOCOU(NOL);[M:REO1]SEQ(NOL)
               If !fstat
                  [M:ALP]VCRTYP = [F:STA]VCRTYP
                  [M:ALP]VCRNUM = [F:STA]VCRNUM
                  [M:ALP]VCRLIN = [F:STA]VCRLIN
                  [M:ALP]VCRSEQ = [F:STA]VCRSEQ
                  [M:ALP]ITMREF = [M:REO1]ITMREF(NOL)
                  WDAT          = [F:STA]ALLDAT
                  WALLQTY       = [F:STA]QTYSTUACT
                  Raz [M:ALP]ALLQTY
                  # Boucle sur les changements d'emplacements (mvt +)
                  For [STJ]STJ1 Where STOFCY=[M:REO1]STOFCY & VCRTYP=[M:REO1]VCRTYP
&                                   & VCRNUM=WVCRNUM & VCRLIN=WVCRLIN*100 & ACTQTY>0
                     #--- Issue X3-53322 : Ajout LPN
                     # Recherche du chrono stock correspondant au mvt
                     Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&                                [F:STJ]BPSLOT,[F:STJ]PALNUM,[F:STJ]CTRNUM,
&                                [F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,[F:STJ]PCUSTUCOE,
&                                [F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                                [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,LSTOCOU)
&                                From STKLIB
                     # Création de l'allocation
                     If LSTOCOU<>0
                        #--- Issue 118555
                        If [F:STJ]ACTQTY + [M:ALP]ALLQTY > [M:REO1]QTYSTUORIA (NOL)
                            WQTYSTUORIA =  [M:REO1]QTYSTUORIA(NOL) - [M:ALP]ALLQTY
                            WQTYSTUORI  =  [F:STJ]QTYSTU*WQTYSTUORIA/[F:STJ]ACTQTY
                            #--- Issue X3-70814 : ajout de (NOL)
                            Call QTEARR(WQTYSTUORI,[M:REO1]STU(NOL)) From TRTDIV
                        Else
                            WQTYSTUORI  = [F:STJ]QTYSTU
                            WQTYSTUORIA = [F:STJ]ACTQTY
                        Endif
                        #If [F:STJ]QTYSTU + [M:ALP]ALLQTY > [M:REO1]QTYSTUORI (NOL)  # hcb 104551
                        #    WQTYSTUORI  =  [M:REO1]QTYSTUORI (NOL) - [M:ALP]ALLQTY  # hcb 104551
                        #    WQTYSTUORIA =  [M:REO1]QTYSTUORIA(NOL) - [M:ALP]ALLQTY  # hcb 104551
                        #Else                                        # ts  84767
                        #    WQTYSTUORI  = [F:STJ]QTYSTU             # ts  84767
                        #    WQTYSTUORIA = [F:STJ]ACTQTY             # ts  84767
                        #Endif                                       # hcb 84767
                        #--- End issue 118755
#                                   [F:STJ]QTYSTU,[F:STJ]ACTQTY,[M:ALP]VCRTYP  + ligne plus bas # hcb 84767

                        #--- TS 106217 ajout paramètre LECC (avant dernier)
#                          # hcb X3-106162 remplacement [F:STJ]QTYSTU et [F:STJ]ACTQTY par WQTYSTUORI et WQTYSTUORIA
                        Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,LSTOCOU,WDAT,
&                                   WQTYSTUORI,WQTYSTUORIA,[M:ALP]VCRTYP,
&                                   [M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,
&                                   "",[M:REO1]BESDAT(NOL),"","","","","",
&                                   "",0,0,"","","","",1,"",WRET) From STKALL
                        If WRET=0 [M:ALP]ALLQTY += WQTYSTUORIA Endif   #hcb 84767
                     Endif
                     If [M:ALP]ALLQTY >= WALLQTY                              # hcb 104551
                        Break                                                 # hcb 104551
                     Endif                                                    # hcb 104551
                  Next
                  Raz GPE          # hcb 87129
                  If [M:ALP]ALLQTY>=WALLQTY
                     # Suppression de la rupture
                     Call SUPALL([M:REO1]STOFCY,[M:REO1]ITMREF(NOL),[M:REO1]STOCOU(NOL),
&                                [M:REO1]SEQ(NOL),WRET) From STKALL
                  Elsif [M:ALP]ALLQTY<>0
                     # Diminution de la rupture
                     GPE = 1         # hcb 87129
                     Call MODALL([M:REO1]STOFCY,[M:REO1]ITMREF(NOL),[M:REO1]STOCOU(NOL),
&                                [M:REO1]SEQ(NOL),[M:ALP]ALLQTY*-1,WRET) From STKALL
                  Endif
               Else
                  WRET=1
               Endif
               If WRET=0
                  # Maj du document origine
                  LMODALL=2
                  Gosub MAJ_DOC From TRTSHTCOM
                  GPOINT = "MAJREOSRG" : Gosub ENTREE From EXEFNC                        # hcb 86396
               Else
                  # MAJ STOALL (Raz SRGNUM, SRGLIN et SRGQTYSTU)
                  Call MAJ_REO_SRGPPS (NOL,"")   # reecriture STOALL
               Endif
               #  mise à jour stoall (raz srgnum et srtqtystu ,srglin)
               #Call MAJ_REO_SRGPPS (NOL,"")   # reecriture STOALL
               #--- End 71718
       Endcase
       SYMBOLE2 = "REO"+[M:REO1]STOFCY+"\"+[M:REO1]LOCORI(NOL)+"\"+[M:REO1]ITMREF(NOL)   # hcb 85881
       Unlock = SYMBOLE2                                                                 # hcb 85881
    Endif
Next NOL

If LRET <> 0
   Gosub AB_TRT
   Goto FAVANT_END
   End
Endif

Commit
#---- Régularisation des mouvements et alloc -----#
Call REGFROMENT( 0, "REO1", "[M:REO1]COCHAGE(I)=2", "ITMREF", [M:REO1]STOFCY ) From TRTSHTCOM

# affichage numero document réappro zone consommation
MES = mess(2,2720,1)-WVCRNUM+"\"                            # Réapprovisionnement
MES += mess(654,200,1)-" : "-num$([M:REO1]VCRTYP)+"\"       # Type de document
MES += mess(52,9009,1)-" : "-num$(WVCRLIN)                  # Nombre de lignes
Call MESSAGE(MES) From GESECRAN

Gosub DEBUT_SAIREO
$SUITE

If MES <> ""
   Call ECR_TRACE (MES,0) From GESECRAN
Endif

Call STKDELRES(0,[M:REO1]STOFCY,"",LRET) From STKLOC
$FAVANT_END
# Issue X3-106909 - 2018-09-21 by MAE
If GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

End

########################################################################
# ACT_TRIREO bouton TRI            Tri du tableau REO1 selon parametrage
########################################################################
Subprog ACT_TRIREO
Gosub TRI_TAB
End

########################################################################
# PASSAIREO
# utilisé en AS_ de STA LOC LOT SLO SERNUM MVTDES
########################################################################
Subprog PASSAIREO(LRUB)
Value Char    LRUB

Gosub SET_NOL From TRTREOA

# les rubriques STA LOC LOT SLO SERNUM sont saisissables uniquement si type <> zone de consommation
If [M:REO1]ORIREO(NOL) = 2 & LRUB <> "MVTDES"
   mkstat = 2
   End
Endif
# les rubriques STA LOT SLO SERNUM non saisissables si type rupture et renseignées
If [M:REO1]ORIREO(NOL) = 3
   Case LRUB
        When "STA"
             If  [M:REO1]STA(NOL) <> ""
                 mkstat = 2
                 End
             Endif
        When "LOT"
             If  [M:REO1]LOT(NOL) <> ""
                 mkstat = 2
                 End
             Endif
        When "SLO"
             If  [M:REO1]SLO(NOL) <> ""
                 mkstat = 2
                 End
             Endif
        When "SERNUM"
             If  [M:REO1]SERNUM(NOL) <> ""
                 mkstat = 2
                 End
             Endif
   Endcase
Endif
# si une liste à ranger etait deja présente(donc une saise à deja eu lieu) pas de modif possible = clic droit
If [M:REO1]SRGPPS_AV(NOL)<> ""
   mkstat=2
   End
Endif
# on ne recalcul pas les zones si une saisie à ete deja faite
If [M:REO1]MODFLG(NOL) = 2
   End
Endif
If [M:REO1]COCHAGE(NOL) = 2
   End
Endif
If [M:REO1]ITMREF(NOL) = ""
   mkstat = 2
    End
Endif

# cas ou on saisie directement
If GOUVSOR = 0
   End
Endif
Gosub TRT_COCHAGE From TRTREO
GOUVSOR = 0
End

##################################################
Subprog ACT_INCREO
Local Integer  NOL
Local Shortint WRET
Local Shortint WAFF
Local Integer WRET1
RAZWRET1
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN

For NOL = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(NOL) <> 2
       Call MAJ_STA_STAFLG(NOL,2)  From TRTREOA    # mise à jour du flag STAFLG à 2
       If GOK > 0
          Default Mask [REO1]
          Case [M:REO1]ORIREO(NOL)
          When 1 , 3
# Lecture article et règle de gestion
             Call INIZONSOR("REO1",[M:REO1]ITMREF(NOL),[M:REO1]STOFCY,NOL,[M:REO1]TRSTYP,[M:REO1]TRSCOD,"") From STKECR   # hcb 50197
#RUBRIQUE origine défaut
             If [M:REO1]QTYSTUACT        (NOL) = 0
                [M:REO1]QTYSTUACT        (NOL) = [M:REO1]QTYSTUORIA  (NOL)
             Endif
             If   [M:REO1]SRGPPS         (NOL) = ""
                  [M:REO1]SRGPPS         (NOL) = [M:REO1]SRGPPSSTR
             Endif
             Gosub LEC_STOLOC From TRTREOA

# Alimentation de [M:ALP]
             Gosub ALI_ALP From TRTREOA
# Détermination du stock à sortir (automatisme, saisie)
             Call OUVSOR("REO1",NOL,[M:REO1]NBLIG,[M:REO1]WSTOSEQ(NOL),[M:REO1]STKFLG,WRET1) From STKSOR           # hcb 50197
             If GOUVSOR <> 0
                Call MAJ_STA_STAFLG(NOL,1)  From TRTREOA    # mise à jour du flag STAFLG à 1
                Call DELSTOSORW(NOL,NOL,"REO1",[M:REO1]STOFCY,WRET1) From STKSOR
                If WRET<>0 : mkstat=2 : Endif
                Raz [M:REO1]SRGPPS           (NOL)
                Raz [M:REO1]WSTOFLG          (NOL)
                Raz [M:REO1]QTYSTUACT        (NOL)
                If dim([M:REO1]LOT) > 0
                   Raz [M:REO1]LOT           (NOL)
                Endif
                If dim([M:REO1]SLO) > 0
                   Raz [M:REO1]SLO           (NOL)
                Endif
                If dim([M:REO1]SERNUM) > 0
                   Raz [M:REO1]SERNUM        (NOL)
                   Raz [M:REO1]SERNUMF       (NOL)
                Endif

                If dim([M:REO1]PALNUM) > 0                  # hcb 27200
                    Raz [M:REO1]PALNUM        (NOL)         # hcb 27200
                    Raz [M:REO1]CTRNUM        (NOL)         # hcb 27200
                Endif                                       # hcb 27200
                Raz [M:REO1]STA              (NOL)
                If dim([M:REO1]LPNNUM) > 0                                               # hcb x3-82749
                   Raz [M:REO1]LPNNUM        (NOL)                                       # hcb x3-82749
                Endif                                                                    # hcb x3-82749
                If dim([M:REO1]LOC) > 0
                   Raz [M:REO1]LOC           (NOL)
                Endif
                If dim([M:REO1]WRH) > 0
                   Raz [M:REO1]WRH           (NOL)
                Endif
                Raz [M:REO1]MVTDES           (NOL)
                Raz [M:REO1]CLEFLG           (NOL)
                [M:REO1]COCHAGE(NOL)    = 1
                GOUVSOR = 0                      # rajouter que dans passaireo le trt_cochage ne se fasse
                If [M:REO1]SRGPPS_AV         (NOL) = ""
                   [M:REO1]SRGPPS            (NOL) = ""
                   Raz   [M:REO1]WSTOFLG(NOL)
                   [M:REO1]MODFLG            (NOL) = 1
                Endif
             Else
                WAFF = 1
                [M:REO1]COCHAGE               (NOL) = 2
                [M:REO1]MODFLG                (NOL) = 2
                GREP = "M"
             Endif
          When 2
          Endcase
       Endif
    Endif
Next

#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:REO1]30                                      # hcb X3-107136
Else
   Call ERREUR(mess(210,184,1)) From GESECRAN   # Aucune ligne complete
Endif

End

##################################################
Subprog ACT_EXCREO
Local Integer  NOL
Local Shortint WAFF
Local Integer  WRET
Raz WRET
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN
Call DELSTOSORW(-1,NOL,"REO1",[M:REO1]STOFCY,WRET) From STKSOR

For NOL = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(NOL) = 2
       Call MAJ_STA_STAFLG(NOL,1)  From TRTREOA    # mise à jour du flag STAFLG à 1
       If WRET<>0 : mkstat=2 : Endif
       Raz [M:REO1]SRGPPS           (NOL)
       Raz [M:REO1]WSTOFLG          (NOL)
       Raz [M:REO1]QTYSTUACT        (NOL)
       If  [M:REO1]ORIREO(NOL) <> 2
           If dim([M:REO1]LOT) > 0
              Raz [M:REO1]LOT           (NOL)
           Endif
           If dim([M:REO1]SLO) > 0
              Raz [M:REO1]SLO           (NOL)
           Endif
           If dim([M:REO1]SERNUM) > 0
              Raz [M:REO1]SERNUM        (NOL)
              Raz [M:REO1]SERNUMF       (NOL)
           Endif
           If dim([M:REO1]PALNUM) > 0                 # hcb 27200
              Raz [M:REO1]PALNUM        (NOL)         # hcb 27200
              Raz [M:REO1]CTRNUM        (NOL)         # hcb 27200
           Endif                                      # hcb 27200
           Raz [M:REO1]STA              (NOL)
           If dim([M:REO1]LPNNUM) > 0                                                    # hcb x3-82749
              Raz [M:REO1]LPNNUM        (NOL)                                            # hcb x3-82749
           Endif                                                                         # hcb x3-82749
           If dim([M:REO1]LOC) > 0
              Raz [M:REO1]LOC           (NOL)
           Endif
           If dim([M:REO1]WRH) > 0
              Raz [M:REO1]WRH           (NOL)
           Endif
       Endif
       Raz [M:REO1]MVTDES           (NOL)
       Raz [M:REO1]CLEFLG           (NOL)
       [M:REO1]COCHAGE              (NOL) = 1
       GOUVSOR = 0                      # rajouter que dans passaireo le trt_cochage ne se fasse
       If [M:REO1]SRGPPS_AV         (NOL) = ""
          [M:REO1]SRGPPS            (NOL) = ""
          Raz   [M:REO1]WSTOFLG     (NOL)
       Endif
       WAFF = 1
       [M:REO1]MODFLG               (NOL) = 1
       GREP = "M"
   Endif
Next

#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:REO1]30                                               # hcb X3-107136
Endif

End

