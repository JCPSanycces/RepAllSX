If [M:REO1]SRGPPSSTR <> ""
   CRITERE = "[F:STA]SRGNUM=[M:REO1]SRGPPSSTR"        # filtre liste à ranger
   CRITERE0_2 = CRITERE1_2
   CRITERE0_2 += "&"
   CRITERE0_2 += CRITERE
Endif

LNUM = ""
CRITERE = "[F:STA]SRGNUM=LNUM"                        # filtre liste à ranger
Gosub LOAD_CRITERE_2

Return

