    CRITERE = "[F:STA]DEFLOC=[M]LOCSTR"
    Gosub LOAD_CRITERE3_2
  Endif
Else
  If [M:REO1]LOCSTR <> ""
    #--- Bug 63571
    #CRITERE = "[F:STA]LOC>=[M]LOCSTR"
    CRITERE = "[F:STA]DEFLOC>=[M]LOCSTR"
    Gosub LOAD_CRITERE3_2
  Endif
  If [M:REO1]LOCEND <> ""
    #--- Bug 63571
    #CRITERE = "[F:STA]LOC<=[M]LOCEND"
    CRITERE = "[F:STA]DEFLOC<=[M]LOCEND"
    Gosub LOAD_CRITERE3_2
  Endif
Endif
If [M:REO1]VCRNUMSTR2 = [M:REO1]VCRNUMEND2
  If [M:REO1]VCRNUMSTR2 <> ""
    CRITERE = "[F:STA]VCRNUM=[M]VCRNUMSTR2"
    Gosub LOAD_CRITERE3_2
  Endif
Else
  If [M:REO1]VCRNUMSTR2 <> ""
    CRITERE = "[F:STA]VCRNUM>=[M]VCRNUMSTR2"
    Gosub LOAD_CRITERE3_2
  Endif
  If [M:REO1]VCRNUMEND2<>""
    CRITERE = "[F:STA]VCRNUM<=[M]VCRNUMEND2"
    Gosub LOAD_CRITERE3_2
  Endif
Endif
If [M:REO1]VCRTYP2-1 <> 0
  CRITERE = "[F:STA]VCRTYP=[M]VCRTYP2-1"
  Gosub LOAD_CRITERE3_2
Endif
If dim([M:REO1]WRHSTR)>0
  If [M:REO1]WRHSTR = [M:REO1]WRHEND
    If [M:REO1]WRHSTR <> ""
      CRITERE = "([F:STA]DEFWRH=''|[F:STA]DEFWRH=[M]WRHSTR)"
      Gosub LOAD_CRITERE3_2
    Endif
  Else
    If [M:REO1]WRHSTR <> ""
      CRITERE = "([F:STA]DEFWRH=''|[F:STA]DEFWRH>=[M]WRHSTR)"
      Gosub LOAD_CRITERE3_2
    Endif
    If [M:REO1]WRHEND <> ""
      CRITERE = "[F:STA]DEFWRH<=[M]WRHEND"
      Gosub LOAD_CRITERE3_2
    Endif
  Endif
Endif

Return


