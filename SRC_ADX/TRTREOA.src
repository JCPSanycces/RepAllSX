#<AdxTL>@(#)10.0.0.0 $Revision$

########################################################################
#  Sous programmes                                      appeles par CALL
########################################################################
# MAJ_STA_STAFLG         Mise à jour STAFLG (cochage / decochage) STOREO
# ACTRUB_LIGNE                  desactivation / activation des rubriques
# CTRCLEREO                                    CONTROLE existence STOREO
# CTRPPSREO                Controle existence liste à ranger dans STOREO
# MAJ_REO_SRGPPS              Mise à jour VCRNUM (enregistrement) STOREO
# CHARGE_STOSOR Chargement des PARAMèTRES  STOSOR pour saisie des sorties

########################################################################
#  Sous programmes                                     appeles par GOSUB
########################################################################
# STKSELTRS                                        Selection transaction
# STKSELALLE                                Selection sur fichier STOREO
# STKSELALL      Selection sur fichier STOREO   numero de liste à ranger
# STKVERREO                                      controle fichier STOREO
# SET_NOL                                      Alimentation rubrique NOL
# ACT_RUB_CLE                              activation des rubriques cles
# DES_RUB_DESTINATION           desactivation des rubriques destinations
# ACT_RUB_DESTINATION              activation des rubriques destinations
# LOAD_FILTER            Préparation du filtre bloc filtre  table STOREO
# LOAD_FILTER3  Préparation du filtre bloc Bornes debut fin table STOREO
# LOAD_CRITERE                                     Concaténation CRITERE
# LOAD_CRITERE3                                   Concaténation CRITERE3
# TRI_TAB                             tri du tableau suivant parametrage
# RECH_CLE                      RECHERCHE meilleur cle pour optimisation
# CTR_EXI_REO1 Controle existance tableau REO1 suite selection ou saisie
# FORMATAGE_CLE            Formatage d une zone pour recherche existance
# DECOCHAGE_REO1  Mise à jour du flag STAFLG à 1 en cas d abandon ou fin
# LECTURE_STOREO                                          lecture STOREO
# ACT_PIKREO Selection par saisie rubrique cle remplisssage tableau REO1
# APRES_STOSOR          Mise à jour complémentaires après enregistrement
# AB_TRT                                       Abandon de la transaction
# ALI_ALP       Chargement du masque de paramétrage pour composants stock
# TRT_LCK                      Traitement des blocages (conflit d'accès)
# TRT_ERR                                         Traitement des erreurs
# CTL_VALIDATION       Controle que la validation peut bien etre faite #
# LEC_STOLOC                                            Lecture STOLOC #

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
# ACT_SELREO  bouton RECHERCHE              remplisssage du tableau REO1
# ACT_LISREO  bouton LISTE     affectation d un numéro de liste à ranger
# ACT_ENRREO  bouton ENREGISTREMENT        enregistrement liste à ranger
# ACT_VALREO  bouton VALIDATION  réalisation  changements d emplacements
# ACT_TRIREO  bouton TRI            Tri du tableau REO1 selon parametrage

########################################################################
# ACTION fenetres
########################################################################


#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","9",GREONUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GREONUM-":"-TIT
Return

######################################################################"
# SELTABLE
######################################################################"
$SELTABLE

Case GACTION
     When "STKSELALLE"      : Gosub STKSELALLE
Endcase
Return

######################################################################"
# CONTROLE
######################################################################"
$CONTROLE
If GFLAG = ""
   FIN = 1
Endif
Return

######################################################################"
# SELLISTE
######################################################################"
$SELLISTE

Case LISTE
     When "SAIREO"          : Gosub STKSELTRS
     When "STKSELALL"       : Gosub STKSELALL
Endcase
Return

######################################################################"
# FINLISTE
######################################################################"
$FINLISTE
Case LISTE
     When "SAIREO"          : Gosub STKFINTRS
Endcase
Return

######################################################################"
# VERFTABLE
######################################################################"
$VERFTABLE

Case TABLE
  When "STKSELALLE"    : Gosub STKVERREO
Endcase
Return

######################################################################"
# INIT
######################################################################"
$INIT
Return

######################################################################"
# OUVRE_BOITE
######################################################################"
$OUVREBOITE
Case GACTION
     When "SAIREO"       : Gosub OUVRE_SAIREO
     When "TRTCRIREO"    : Gosub OUVRE_TRTCRIREO
Endcase
Return

$OUVRE_SAIREO

# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
If dim(GHCBBOI)>0
   If GHCBBOI <> ""
      BOITE = GHCBBOI
   Endif
   Kill GHCBBOI
Endif

Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="REO1"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif
Gosub CHANGE_AWI From TRTREOA
If GCURLEG = ""                  # hcb 96825
   GCURLEG = GDOSLEG
Endif


Call INIVAR From GLOBSTO
Global Char GHCBFCY(GLONFCY)
Global Char GREOLOC(GLONLOC)

Return

$OUVRE_TRTCRIREO
Return

######################################################################"
#                                                                OUVRE
######################################################################"
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If clalev([F:FCY]) =0 Local File FACILITY   [FCY]  Endif
If clalev([F:STL]) =0 Local File STOLOT     [STL]  Endif
If clalev([F:ITF]) =0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM]) =0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:TUN]) =0 Local File TABUNIT    [TUN]  Endif
If clalev([F:STJ]) =0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO]) =0 Local File STOCK      [STO]  Endif
If clalev([F:STS]) =0 Local File STOSER     [STS]  Endif
If clalev([F:REO]) =0 Local File STOREO     [REO]  Endif
If clalev([F:STA]) =0 Local File STOALL     [STA]  Endif
If clalev([F:STA1])=0 Local File STOALL     [STA1] Endif
If clalev([F:ITG]) =0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:SRU]) =0 Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST]) =0 Local File TABSTASTO  [TST]  Endif
If clalev([F:TLO]) =0 Local File TABLOCTYP  [TLO]  Endif
If clalev([F:STC]) =0 Local File STOLOC     [STC]  Endif
If clalev([F:SRT]) =0 Local File STKTRS     [SRT]  Endif
If clalev([F:TFO]) =0 Local File TABFOR     [TFO]  Endif
If clalev([F:ITV]) =0 Local File ITMMVT     [ITV]  Endif
If clalev([M:STW]) =0 Local Mask STOWORK    [STW]  Endif  #  ecran stockage mvt à mettre à jour
If clalev([M:SVW]) =0 Local Mask STOVALWORK [SVW]  Endif  #  ecran stockage valo mvt à mettre à jour
If clalev([M:SOW]) =0 Local Mask STOSORW    [SOW]  Endif  #  ecran stockage mvt sorties
If clalev([M:REOC])=0 Local Mask REOC       [REOC] Endif #  ecran criteres
If clalev([M:ALP]) =0 Local Mask ALLPAR     [ALP]  Endif
If clalev([M:SRO1])=0 Local Mask SRO1       [SRO1] Endif  # ecran parametrage pour calcul de l origine
If clalev([F:LPN]) =0 Local File LPN        [LPN]  Endif                                 # hcb x3-82749

#-----
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

GSRTNUM = GFLAG
GREONUM = GFLAG                  # hcb 50197
Read [SRT] SRT0=9;GFLAG
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif

Gosub STK_INILOC From STKLOC

Return

######################################################################"
#                                                                DEBUT
######################################################################"
$DEBUT
Case GACTION
     When "SAIREO"       : Gosub DEBUT_SAIREO
     When "TRTCRIREO"    : Gosub DEBUT_TRTCRIREO
Endcase
Return

$DEBUT_SAIREO
# Remise à zero du masque STOSORW
Call RAZSTOSORW From STKSOR
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 9 | [F:SRT]SRTNUM <> GREONUM                   # hcb 50197
   Read [SRT]SRT0=9;GREONUM : If fstat Raz [F:SRT] : Endif
Endif

Raz   [M:REO1]
Grizo [M:REO1]LSTWIOFLG
[M:REO1]SRTCRIT1  = [F:SRT]CRIT1
[M:REO1]VCRTYP    = 34          #  Plan réappro zones consommation
[M:REO1]TRSTYP    = 25          #  Réappro zones de consommation
# hcb 91033 deb
If clalev([M:REOC])=0  Local Mask REOC   [REOC]  Endif  # hcb  92464
Raz   [M:REOC]
If filinfo(filpath("ETM",GUSER+"_"+"STD","reo",0),0)>=0
   Call LECMEMO("STD","[M:REOC]","reo") From GMEMO
   # On applique le code mémo STD si c'est la transaction à laquelle il se rapporte
   [M:REO1]     = [M:REOC]
Endif
# hcb 91033 fin


[M:REO1]LOCREO    = [F:SRT]LOCREO
[M:REO1]CSMREO    = [F:SRT]CSMREO
[M:REO1]SHTREO    = [F:SRT]SHTREO
[M:REO1]SRGWAIFLG = [F:SRT]SRGWAIFLG    # hcb 50197
[M:REO1]STKFLG    = [F:SRT]STKFLG       # hcb 50197
[M:REO1]TRSCOD    = [F:SRT]TRSCOD       # hcb 50197
[M:REO1]SRGPPSCOD = [F:SRT]SRGPPSCOD    # hcb 50197

# calcul du poid de l origine  : GORIGINE

# GORIGINE = 2  6 10 14   locreo à oui
# GORIGINE = 4  6 12 14   csmreo à oui
# GORIGINE = 8 10 12 14   shtreo à oui
# GLOCREO = 2
# GCSMREO = 2
# GSHTREO = 2
[M:SRO1]LOCREO    = [F:SRT]LOCREO
[M:SRO1]CSMREO    = [F:SRT]CSMREO
[M:SRO1]SHTREO    = [F:SRT]SHTREO
Gosub ANA_ORIGINE From SUBSRO

Affzo [M:REO1]LOCREO
Affzo [M:REO1]CSMREO
Affzo [M:REO1]SHTREO
Grizo [M:REO1]COCHAGE(0)

# controle ajoute le 18 03 04 HCB  : si on change la societe ,DEBUT_SAISSL remet celle par defaut
If GHCBFCY <> ""
   If  [M:REO1]STOFCY <> GHCBFCY
       [M:REO1]STOFCY =  GHCBFCY
   Endif
Endif
Affzo [M:REO1] 5, 15 ,25 , 30
Actzo [M:REO1] 15 , 25
REP = ""
GREP = ""

#--- Bug 65256
Onerrgo TRT_ONERRGO

Return

#--- Bug 65256
$TRT_ONERRGO
Gosub DECOCHAGE_REO1
Resume
#---

$DEBUT_TRTCRIREO
Raz   [M:REOC]
Transmask [M:REO1] To [M:REOC]  # Issue 25606_Transmask [M:REOC] = [M:REO1]
If GLOCREO = 2
   Actzo [M:REOC]20
Else
   Diszo [M:REOC]20
Endif
If GCSMREO = 2
   Actzo [M:REOC]25
Else
   Diszo [M:REOC]25
Endif
If GSHTREO = 2
   Actzo [M:REOC]30
Else
   Diszo [M:REOC]30
Endif

Affzo [M:REOC]

Return
######################################################################"
#                                                              ABANDON
######################################################################"
$ABANDON
Case GACTION
     When "SAIREO"       : Gosub ABANDON_SAIREO
     When "TRTCRIREO"    : Gosub ABANDON_TRTCRIREO
Endcase
Return

$ABANDON_SAIREO
Local Integer WRET

Call DELSTOSORW(-1,-1,"REO1",[M:REO1]STOFCY,WRET) From STKSOR
Gosub DECOCHAGE_REO1

Raz [M:REO1]SAIFLG

Call ACT_SELREO From TRTREOA

Affzo [M:REO1]10,15
REP = ""
GREP = ""
Return

$ABANDON_TRTCRIREO

Return

######################################################################"
#                                                             FINTABLE
######################################################################"
$FINTABLE
Return

######################################################################"
#                                                                  FIN
######################################################################"
$FINSAI
Case GACTION
     When "SAIREO"       : Gosub FIN_SAIREO
     When "TRTCRIREO"    : Gosub FIN_TRTCRIREO
Endcase
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return

$FIN_SAIREO

Local Integer WRET

Call DELSTOSORW(-1,-1,"REO1",[M:REO1]STOFCY,WRET) From STKSOR
Gosub DECOCHAGE_REO1
Kill GHCBFCY

Return

$FIN_TRTCRIREO
Return
######################################################################"
#                                                               FIN
######################################################################"

$FIN
Return


######################################################################"
#                                                             APCHOIX
######################################################################"
$APCHOIX

Case GACTION
     When "SAIREO"       : Gosub APCHOIX_SAIREO
     When "TRTCRIREO"    : Gosub APCHOIX_TRTCRIREO
Endcase
Return

$APCHOIX_SAIREO
If [M:REO1]NBLIG = 0
   REP = ""
   GREP = ""

Endif
# interception de la touche return
#  recherche si pas de lignes cochées
Local Integer I
Raz I
If REPONSE = GSTARET & !find( 2, [M:REO1]COCHAGE(I..[M:REO1]NBLIG-1))
   Call ACT_SELREO From TRTREOA
Endif

Return

$APCHOIX_TRTCRIREO
Return


######################################################################"
#                                                               ACTEND
######################################################################"
$ACTEND

Case GACTION
     When "SAIREO"       : Gosub END_SAIREO
     When "TRTCRIREO"    : Gosub END_TRTCRIREO
Endcase
Return

$END_SAIREO
Local Integer WOK
WOK = 0
For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE (I) = 2 & GREP = "M"
       WOK = 9
       Break
    Endif
Next I
If WOK = 9
   WOK = 0
# Avez vous enregistré  les enregistrements cochés ?
   Call OUINON(mess(61,184,1), WOK) From GESECRAN
   If WOK <> 2
      FIN = 0
   Endif
Endif
Return

$END_TRTCRIREO
Return

######################################################################"
#                                                                   OK
######################################################################"
$OK
Case GACTION
     When "SAIREO"       : Gosub OK_SAIREO
     When "TRTCRIREO"    : Gosub OK_TRTCRIREO
Endcase
Return

$OK_SAIREO

Return

$OK_TRTCRIREO
[M:REO1]           = [M:REOC]
Call ACT_SELREO From TRTREOA

Affzo [M:REO1]10,15

Return


######################################################################"
#                                                               BOUTON
######################################################################"
$BOUTON

Case GACTION
     When "SAIREO"       : Gosub BOUTON_SAIREO
     When "TRTCRIREO"    : Gosub BOUTON_TRTCRIREO
Endcase
Return

$BOUTON_SAIREO

Return

$BOUTON_TRTCRIREO

Return

######################################################################"
#                                                              SETBOUT
######################################################################"
$SETBOUT

Case GACTION
     When "SAIREO"       : Gosub SETBOUT_SAIREO
     When "TRTCRIREO"    : Gosub SETBOUT_TRTCRIREO
Endcase
Return

$SETBOUT_SAIREO
# Menu Options / Visu transaction
CHMEN += "H"
REP = GREP
Local Integer NOL
Local Integer WLISTE
Raz WLISTE
Raz NOL
# ------------------------------------------------------------------------------------- #
# Suppression des boutons                                                               #
# ------------------------------------------------------------------------------------- #
#     A : Recherche                                                                     #
#     I : Tout inclure                                                                  #
#     J : Tout exclure                                                                  #
#     D : Criteres                                                                      #
#     C : Liste à ranger                                                                #
#     E : Enregistrement                                                                #
#     F : Validation                                                                    #
#     G : Tri                                                                           #
# ------------------------------------------------------------------------------------- #
Local Integer I
I = 0
# Pas de bouton "Recherche","Criteres", si saisie manuelle
If [M:REO1]SAIFLG = 2
   Call VIREBOUT(CHMEN,"AD") From GOBJET
Endif

# Pas de bouton "Recherche","Criteres",  si on est rentrer en modif
If REP = "M"
   Call VIREBOUT(CHMEN,"AD") From GOBJET
Endif

# Pas de bouton  Liste à ranger  si pas de cochage
If !find( 2, [M:REO1]COCHAGE(I..[M:REO1]NBLIG-1))
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif
# Pas de bouton  Liste à ranger  si pas de nouvelles lignes
If !find( 0, [M:REO1]CREFLG(I..[M:REO1]NBLIG-1))
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

# Pas de bouton  Tri  si Si REO1 vide
If [M:REO1]NBLIG  = 0 | [M:REO1]SAIFLG <> 2
   Call VIREBOUT(CHMEN,"G") From GOBJET
Endif

# Pas de bouton  Liste à ranger  si on est pas rentrer en modif
If REP = ""
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

# Pas de bouton  Critere si  Liste à ranger  est inclure sans liste  <> 2
If [M:REO1]SRGPPSSTR <> "" & [M:REO1]LSTWIOFLG <> 2
   Call VIREBOUT(CHMEN,"D") From GOBJET
Endif

# Pas de bouton  Enregistrement validation Tout inclure par defaut
Call VIREBOUT(CHMEN,"EFJ") From GOBJET

# Bouton "enregistrement" si liste et cochage et modif
# Bouton "validation"     si cochage ou si liste et pas de modif
# Bouton "Tout exclure "  si cochage

For NOL = 0 To [M:REO1]NBLIG-1
    If [M:REO1]COCHAGE(NOL) = 2
       WLISTE = 1
       If [M:REO1]SRGPPS(NOL) <> "" | [M:REO1]SRGPPS_AV(NOL) <> ""
          WLISTE = 2
          Break
       Endif
    Endif
Next
If WLISTE = 2 & REP = "M"
   CHMEN += "EJ"
Else
   If WLISTE >  0
     CHMEN += "FJ"
   Endif
Endif

# Bouton "Recherche" si on est rentrer en modif , REO1 vide et liste à ranger
If REP = "M" & [M:REO1]NBLIG  = 0 & [M:REO1]SRGPPSSTR <> ""
   CHMEN += "A"
Endif

# Bouton "Recherche" "Criteres"si on est rentrer en modif , pas cochage
If REP = "M" & !find( 2, [M:REO1]COCHAGE(I..[M:REO1]NBLIG-1))
   CHMEN += "AD"
Endif
# PAS de bouton  Liste à ranger  si parametrage liste à ranger = invisible
If [M:REO1]SRGPPSCOD = 3              # hcb 50197
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

# Pas de bouton  Tout inclure si pas de ligne
If  [M:REO1]NBLIG  = 0
   Call VIREBOUT(CHMEN,"I") From GOBJET
Endif

# Pas de bouton  Tout inclure si pas sortie autmatique
If  [M:REO1]STKFLG <> 2              # hcb 50197
   Call VIREBOUT(CHMEN,"I") From GOBJET
Endif

# Pas de bouton  Tout inclure si pas  article , emplacement debut de renseignées
If  [M:REO1]NBLIG  > 0 &  [M:REO1]ITMREFSTR = "" & [M:REO1]LOCSTR = ""
   Call VIREBOUT(CHMEN,"I") From GOBJET
Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

$SETBOUT_TRTCRIREO
Return

#########################################################################
$APRES_MODIF
Local Integer I
# si modif alors rep = M
If find( 2, [M:REO1]MODFLG(I..[M:REO1]NBLIG-1))
   REP = "M"
   GREP = "M"
Endif
Return

$CHARG_PARAM
Return

#########################################################################
$AVANT_LIS
# L enregistrement a t il ete fait ?
Local Integer WOK
WOK = 9

Call OUINON(mess(22,184,1), WOK) From GESECRAN
If WOK <> 2
   Call ACT_ENRREO From TRTREOA
Endif

Local Integer I
#tri du tableau REO1 par liste à ranger pour n editer une seule fois chaque liste
If [M:REO1]NBLIG <> 0
    Sorta [M:REO1]NBLIG [M:REO1]NBLIG Order By [M:REO1]SRGPPS(indice)
Endif

Raz [M:REO1]SRGPPSDEB
Raz [M:REO1]SRGPPSFIN

# edition de chaque liste à ranger
For I = 0 To [M:REO1]NBLIG-1
    If [M:REO1]SRGPPS(I) = ""
       Goto NEXTIMP
    Endif
    If [M:REO1]SRGPPSDEB  = ""
       [M:REO1]SRGPPSDEB  = [M:REO1]SRGPPS(I)
    Endif
    If [M:REO1]SRGPPS(I)  > [M:REO1]SRGPPSFIN
       [M:REO1]SRGPPSFIN  = [M:REO1]SRGPPS(I)
    Endif
$NEXTIMP
Next I

Return

########################################################################
# CHANGE_AWI                               chargement traitement fenetre
########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

#########################################################################
# MAJ_STA_STAFLG         Mise à jour STAFLG (cochage / decochage) STOREO
#########################################################################
Subprog MAJ_STA_STAFLG (NOL,COCHAGE)
Value    Integer NOL
Value    Integer COCHAGE
Case [M:REO1]ORIREO(NOL)
     When 1
# verrouillage  / deverrouillage logique
        If COCHAGE       = 2
           SYMBOLE2 = "REO"+[M:REO1]STOFCY+"\"+[M:REO1]LOCORI(NOL)+"\"+[M:REO1]ITMREF(NOL)
           Lock = SYMBOLE2
# modification en cours sur un autre poste
           If fstat
              GERR=1
              Call ERREUR([M:REO1]STOFCY+"\"+[M:REO1]LOCORI(NOL)+"\"+[M:REO1]ITMREF(NOL)-":"-mess(10,100,1)) From GESECRAN
              GOK=0 : End
           Endif
        Else
           SYMBOLE2 = "REO"+[M:REO1]STOFCY+"\"+[M:REO1]LOCORI(NOL)+"\"+[M:REO1]ITMREF(NOL)
           Unlock = SYMBOLE2
        Endif

        Call DEBTRANS From GLOCK
        Trbegin [REO]
        Readlock [F:REO]REO0 = [M:REO1]STOFCY;[M:REO1]LOCORI(NOL);[M:REO1]ITMREF(NOL)
        If    fstat=1 GOK=-1 : GLOCK="$STOREO"-[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)
              SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
              Unlock = SYMBOLE2
              Gosub AB_TRT : End
        Elsif fstat   GOK=0  : Call RSTA("REO",[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)) From GLOCK
              SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
              Unlock = SYMBOLE2
              Gosub AB_TRT
              End
        Endif

        If COCHAGE       = 2 & [F:REO]VCRNUM = ""
          [F:REO]STAFLG  = 2
        Else
          [F:REO]STAFLG  = 1
        Endif
        If  [F:REO]VCRNUM <> ""
#            [F:REO]QTYSTUORIA    = [M:REO1]QTYSTUACT (NOL)     # hcb 37874
#            [F:REO]CLEFLG        = [M:REO1]CLEFLG    (NOL)     # hcb 37874
        Else
            Raz  [F:REO]QTYSTUORIA
            Raz  [F:REO]CLEFLG
            Raz  [F:REO]VCRLIN

        Endif
        [F:REO]UPDDAT  = date$
        [F:REO]UPDUSR  = GUSER
        Rewrite [F:REO]
        If fstat
           GOK = 0 : Call FSTA("REO") From GLOCK
           SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
           Unlock = SYMBOLE2
           Gosub AB_TRT
           End
        Endif
        Commit
     When 2,3
# verrouillage  / deverrouillage logique
        If COCHAGE       = 2
           SYMBOLE2 = "STA"+[M:REO1]STOFCY+"\"+[M:REO1]ITMREF(NOL)+"\"+num$([M:REO1]STOCOU(NOL))+"\"+num$([M:REO1]SEQ(NOL))
           Lock = SYMBOLE2
# modification en cours sur un autre poste
           If fstat
              GERR=1
              Call ERREUR([M:REO1]STOFCY+"\"+[M:REO1]ITMREF(NOL)+"\"+num$([M:REO1]STOCOU(NOL))+"\"+num$([M:REO1]SEQ(NOL))-":"-mess(10,100,1)) From GESECRAN
              GOK=0 : End
           Endif
        Else
           SYMBOLE2 = "STA"+[M:REO1]STOFCY+"\"+[M:REO1]ITMREF(NOL)+"\"+num$([M:REO1]STOCOU(NOL))+"\"+num$([M:REO1]SEQ(NOL))
           Unlock = SYMBOLE2
        Endif

        Call DEBTRANS From GLOCK
        Trbegin [STA]
        Readlock [F:STA]STA0 = [M:REO1]STOFCY;[M:REO1]ITMREF(NOL);[M:REO1]STOCOU(NOL);[M:REO1]SEQ(NOL)
        If    fstat=1 GOK=-1 : GLOCK="$STOALL"-[M:REO1]STOFCY-[M:REO1]ITMREF(NOL)-num$([M:REO1]STOCOU(NOL))-num$([M:REO1]SEQ(NOL))
              SYMBOLE2 = "STA"+[M:REO1]STOFCY+"\"+[M:REO1]ITMREF(NOL)+"\"+num$([M:REO1]STOCOU(NOL))+"\"+num$([M:REO1]SEQ(NOL))
              Unlock = SYMBOLE2
              Gosub AB_TRT : End
        Elsif fstat   GOK=0  : Call RSTA("STA",[M:REO1]STOFCY-[M:REO1]ITMREF(NOL)-num$([M:REO1]STOCOU(NOL))-num$([M:REO1]SEQ(NOL))) From GLOCK
           SYMBOLE2 = "STA"+[M:REO1]STOFCY+"\"+[M:REO1]ITMREF(NOL)+"\"+num$([M:REO1]STOCOU(NOL))+"\"+num$([M:REO1]SEQ(NOL))
              Unlock = SYMBOLE2
              Gosub AB_TRT
              End
        Endif
        If  [F:STA]SRGNUM <> ""
            [F:STA]SRGQTYSTU      = [M:REO1]QTYSTUACT (NOL)
        Else
            Raz [F:STA]SRGQTYSTU
            Raz [F:STA]SRGLIN
            Raz [F:STA]SRGLOC
        Endif
        [F:STA]UPDDAT  = date$
        [F:STA]UPDUSR  = GUSER
        Rewrite [F:STA]
        If fstat
           GOK = 0 : Call FSTA("STA") From GLOCK
              SYMBOLE2 = "STA"+[F:STA]STOFCY+"\"+[F:STA]ITMREF+"\"+num$([F:STA]STOCOU)+"\"+num$([F:STA]SEQ)
           Unlock = SYMBOLE2
           Gosub AB_TRT
           End
        Endif
        Commit

Endcase

End

#########################################################################
#ACTRUB_LIGNE                    desactivation / activation des rubriques
#########################################################################
Subprog ACTRUB_LIGNE (NOL)
Value    Integer NOL
#saisie de nouvelle ligne il faut activer les zones de cle
If [M:REO1]WFLG(NOL) = 0
    Gosub DES_RUB_DESTINATION
    Gosub ACT_RUB_CLE
    End
Endif
#si saisie détail la modif se fait par clic droit

If [M:REO1]WSTOSEQ(NOL) <> 0
    Gosub DES_RUB_DESTINATION
    If dim([M:REO1]SRGPPS(NOL)) > 0
       Actzo [M:REO1]SRGPPS(NOL)
    Endif
    End
Endif
End
########################################################################
# CTRCLERE0                                    Controle existence STOREO
#                                  suite à saisie d un element dans REO1
########################################################################
Subprog CTRCLEREO(LECR,LCHO,LLOC,LITM)
Value    Char     LECR
Value    Integer  LCHO
Value    Char     LLOC
Value    Char     LITM

Local Integer LRET
Local Char LFCY(GLONFCY)
If LECR = "REO1"
   LFCY = [M:REO1]STOFCY
Endif
Local Char CRITERE(255)
Local Char CRITER1(255)
Raz CRITERE
Raz CRITER1

Local Char LREO(GLONVCR)               # hcb 57490
LREO = ""
CRITERE = "[F:REO]STOFCY=LFCY&[F:REO]STAFLG<>2&[F:REO]VCRNUM=LREO"

Case LCHO
     When 1 :
  CRITER1 = "[F:REO]LOC=LLOC"
     When 2 :
  CRITER1 = "[F:REO]LOC=LLOC&[F:REO]ITMREF=LITM"
Endcase

If CRITER1 = ""
   CRITER1 = "1=1"
Endif

Filter [REO]  Where evalue(CRITERE)&evalue(CRITER1)
&             Order By Key REO0

LRET = 1
For [REO]
LRET = 2
Break

Next

Filter [F:REO]

If LRET = 1
   mkstat=2
   GMESSAGE=mess(13,184,1)    # Aucun enregistrement  correspondant
Endif
End

########################################################################
# CTRPPSREO      Controle existence liste à ranger dans STOREO et STOALL
########################################################################
Subprog CTRPPSREO(LFCY,LSRG)
Value    Char     LFCY
Value    Char     LSRG
Local Integer LRET

Local Char CRITERE(255)
Local Char CRITER1(255)
Raz CRITERE
LRET = 1
If GLOCREO = 2
   CRITERE = "[F:REO]STOFCY=LFCY&[F:REO]VCRNUM=LSRG"
   Filter [REO]  Where evalue(CRITERE)
&                Order By Key REO1
   LRET = 1
   For [REO]
       LRET = 2
       Break
   Next

   Filter [F:REO]
Endif

If GCSMREO = 2 & LRET = 1
   Filter [STA] Where  [F:STA]STOFCY=LFCY & [F:STA]SRGNUM=LSRG & [F:STA]ALLTYP=2
&                      & ([F:STA]DEFLOC<>"" | [F:STA]DEFLOCTYP<>"")
&                      & find([F:STA]VCRTYP,2,10,36)>0
&  Order By Key STA0
   LRET = 1
   For [STA]
       LRET = 2
       Break
   Next
   Filter [STA]
Endif

If GSHTREO = 2 & LRET = 1
   Filter [STA] Where  [F:STA]STOFCY = LFCY & [F:STA]SRGNUM = LSRG
&                    & [F:STA]ALLTYP = 4    & [F:STA]LOC <> ""
&  Order By Key STA0
   LRET = 1
   For [STA]
       LRET = 2
       Break
   Next
   Filter [STA]
Endif

If LRET = 1
   mkstat=2
   GMESSAGE=mess(16,184,1)    # Numéro de liste inexistant
Endif
End

#########################################################################
# MAJ_REO_SRGPPS               Mise à jour VCRNUM (enregistrement) STOREO
#                              STAFLG = 1
#                              VCRNUM = numero de liste
#########################################################################
Subprog MAJ_REO_SRGPPS (NOL,NUMLIS)
Value    Integer  NOL
Value    Char     NUMLIS

Case [M:REO1]ORIREO(NOL)
     When 1
        Readlock [F:REO]REO0 = [M:REO1]STOFCY;[M:REO1]LOCORI(NOL);[M:REO1]ITMREF(NOL)
        If  fstat=1 GOK=-1 : GLOCK="$STOREO"-[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL) : Gosub AB_TRT : End
            Elsif fstat   GOK=0  : Call RSTA("REO",[M:REO1]STOFCY-[M:REO1]LOCORI(NOL)-[M:REO1]ITMREF(NOL)) From GLOCK
            End
        Endif

        [F:REO]STAFLG  = 1
        [F:REO]VCRTYP  = 34
        [F:REO]VCRNUM  = NUMLIS
        [F:REO]UPDDAT  = date$
        [F:REO]UPDUSR  = GUSER

        If [F:REO]VCRNUM <> ""
           If [F:REO]VCRLIN = 0
              [F:REO]VCRLIN        = uniqid([STA])
           Endif
           [F:REO]QTYSTUORIA    = [M:REO1]QTYSTUACT (NOL)
           [F:REO]CLEFLG        = [M:REO1]CLEFLG    (NOL)
           [M:REO1]SRGLIN (NOL) = [F:REO]VCRLIN
        Else
           Raz  [F:REO]QTYSTUORIA , [F:REO]VCRLIN
           Raz  [F:REO]CLEFLG     , [F:REO]VCRTYP
#           Raz  [M:REO1]SRGLIN (NOL)

        Endif

        Rewrite [F:REO]
        If fstat
           GOK = 0 : Call FSTA("REO") From GLOCK : End
        Endif

        SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
        Unlock = SYMBOLE2
     When 2,3
        Readlock [F:STA]STA0 = [M:REO1]STOFCY;[M:REO1]ITMREF(NOL);[M:REO1]STOCOU(NOL);[M:REO1]SEQ(NOL)
        If  fstat=1 GOK=-1 : GLOCK="$STOALL"-[M:REO1]STOFCY-[M:REO1]ITMREF(NOL)-num$([M:REO1]STOCOU(NOL))-num$([M:REO1]SEQ(NOL)) : Gosub AB_TRT : End
# Elsif fstat   GOK=0  : Call RSTA("STA",[M:REO1]STOFCY-[M:REO1]ITMREF(NOL)-num$([M:REO1]STOCOU(NOL))-num$([M:REO1]SEQ(NOL))) From GLOCK  # hcb 130212
            Elsif fstat                         # hcb 130212
        Endif
        [F:STA]SRGNUM  = NUMLIS
        [F:STA]UPDDAT  = date$
        [F:STA]UPDUSR  = GUSER

        If [F:STA]SRGNUM <> ""
           If [F:STA]SRGLIN = 0
              [F:STA]SRGLIN        = uniqid([STA])
           Endif
           [F:STA]SRGQTYSTU     = [M:REO1]QTYSTUACT (NOL)
           [M:REO1]SRGLIN (NOL) = [F:STA]SRGLIN
           If [M:REO1]ORIREO(NOL) = 2
              [F:STA]SRGLOC       = [M:REO1]LOCORI (NOL)
           Endif
        Else
           Raz  [F:STA]SRGQTYSTU
           Raz  [F:STA]SRGLIN
        Endif
        Rewrite [F:STA]
        If fstat
           GOK = 0 : Call FSTA("STA") From GLOCK : End
        Endif

        SYMBOLE2 = "STA"+[F:STA]STOFCY+"\"+[F:STA]ITMREF+"\"+num$([F:STA]STOCOU)+"\"+num$([F:STA]SEQ)
        Unlock = SYMBOLE2

Endcase

End

#########################################################################
# CHARGE_STOSOR Chargement des PARAMèTRES  STOSOR pour saisie des sorties
#########################################################################
$CHARGE_STOSOR

Local Integer NOL
NOL = LNOL
Gosub LEC_STOLOC From TRTREOA
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 9 | [F:SRT]SRTNUM <> GREONUM                   # hcb 50197
   Read [SRT]SRT0=9;GREONUM : If fstat Raz [F:SRT] : Endif
Endif

# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
[M:SOR]WSTOSEQ   = [M:REO1]WSTOSEQ    (LNOL)
[M:SOR]TRSTYP    = [M:REO1]TRSTYP
[M:SOR]TRSCOD    = [F:SRT]TRSCOD
[M:SOR]TRFFCY    = ""
[M:SOR]VCRTYP    = [M:REO1]VCRTYP
[M:SOR]VCRNUM    = [M:REO1]SRGPPS     (LNOL)
[M:SOR]VCRLIN    = [M:REO1]SRGLIN     (LNOL)
[M:SOR]MVTDES    = [M:REO1]MVTDES     (LNOL)
[M:SOR]STU       = [M:REO1]STU        (LNOL)
[M:SOR]PCU       = [M:REO1]PCUORI     (LNOL)
[M:SOR]PCUSTUCOE = [M:REO1]PCUSTUCOEO (LNOL)
[M:SOR]SORQTYACT = [M:REO1]QTYSTUACT  (LNOL)

[M:SOR]RETDAT    = [M:REO1]BESDAT     (LNOL)
[M:SOR]DLVDAT    = [M:REO1]BESDAT     (LNOL)
[M:SOR]AUZSST    = [F:STC]AUZSST
[M:SOR]PECINTLOC = 2
[M:SOR]PECPLFLOC = 2
[M:SOR]PECSCOLOC = 1
[M:SOR]PECQLYCTL = 1
# filsto rajouer pour eviter d alimenter l emplacement par lui meme ...
GREOLOC   = [M:REO1]LOCORI(LNOL)
[M:SOR]FILSTO    = '[F:STO]LOC<>GREOLOC'

[M:SOR]STOLOC    = ""
[M:SOR]XLOT      = ""
[M:SOR]XLOC      = ""
[M:SOR]XSTA      = ""
[M:SOR]CUR       = GLOCALDEV
[M:SOR]CCECODS   = [F:SRT]CCECODS

[M:SOR]BPRNUM    = ""
[M:SOR]GLOALLQTY = 0
If dim([M:REO1]WRH)>0 [M:SOR]XWRH=[M:REO1]WRH(LNOL) Endif

Return
########################################################################
# STKSELTRS                                        Selection transaction
########################################################################
$STKSELTRS
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    CRITERE(250)

If dim(GHCBBOI)<=0
    Global Char GHCBBOI(GLONFEN)
Endif
Raz GHCBBOI

If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif

CRITERE = "SRTTYP=9  & [F:SRT]ENAFLG = 2"     # hcb 88573

If GPROFIL<>GSUPER
  For [ACC]CODACC Where USR=GUSER
    If [F:ACC]EXEC=2
      [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1)
      NBACS +=1
    Endif
    If NBACS>99 Break Endif
  Next
  CRITERE += "&(ACSCOD=''|find(ACSCOD,TABACS(0..99)))"
Endif

If GFLAG=""
    Filter [SRT] Where evalue(CRITERE)
    If rowcount([SRT])=1
        Read [SRT] First
        If !fstat
            GFLAG  =[F:SRT]SRTNUM
            GREONUM=[F:SRT]SRTNUM           # hcb 50197
        Endif
    Endif
    Filter [SRT]
Endif
If GFLAG<>""
    Filter [SRT] Where evalue(CRITERE)
    Read [SRT] SRT0=9;GFLAG
    Filter [SRT]
    If !fstat
        GHCBBOI = "WQREO"+[F:SRT]SRTNUM+"1"
        GREONUM = [F:SRT]SRTNUM           # hcb 50197
        OK=0
    Endif
Endif
If GHCBBOI=""
    For [F:SRT] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:SRT]SRTNUM
        Call LECTEXTRA(TEXTE(NBTEX),"STKTRS","DESAXX",num$([F:SRT]SRTTYP),[F:SRT]SRTNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

$STKFINTRS
If VALEUR = ""
   Raz GFLAG
   Kill GHCBBOI
   Return
Endif
Read [SRT] SRT0=9;VALEUR
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif
GHCBBOI = "WQREO"+[F:SRT]SRTNUM+"1"                      # hcb 76010
GFLAG  = [F:SRT]SRTNUM

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GREONUM = [F:SRT]SRTNUM           # hcb 50197

Return

#########################################################################
# STKSELALLE                                 Selection sur fichier STOREO
#########################################################################
$STKSELALLE
Local Char    LFCY(GLONFCY)   : LFCY =      PARAM(1)
Local Char    LRUB            : LRUB =      PARAM(2)
Local Integer LLIG            : LLIG =  val(PARAM(3))
Local Integer LCHO            : LCHO =  val(PARAM(4))

Local Char LFIC(10)
LFIC = "STOREO"

If clalev([F:REO])  = 0 : Local File STOREO    [REO]  : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
TIT(0) = mess(17,213,1)

NBCOL = 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PCU"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QTYPCU"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PCUSTUCOE"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

Local Char WLISTE(GLONVCR)               # hcb 57490
WLISTE = ""
#
ORDRE   = "LOC;ITMREF"
Case LCHO
     When 0 : START   = "LOC"
              CRITERE = "[F:REO]STOFCY=LFCY&[F:REO]STAFLG<>2&[F:REO]VCRNUM=WLISTE"
     When 1 : START   = "LOC"
              CRITERE = "[F:REO]STOFCY=LFCY&[F:REO]STAFLG<>2&[F:REO]VCRNUM=WLISTE"
     When 2 : START   = "ITMREF"
              CRITERE = "[F:REO]STOFCY=LFCY&[F:REO]STAFLG<>2&[F:REO]LOC=LRUB&[F:REO]VCRNUM=WLISTE"

Endcase
SIZLIG  = 100
SIZCOL  = 200
Default File [REO]
Return

#########################################################################
# STKSELALL       Selection sur fichier STOREO   numero de liste à ranger
#########################################################################
$STKSELALL
Local Char    LFCY(GLONFCY)        : LFCY =      PARAM(1)
Local Char NUMLIS(GLONVCR)               # hcb 57490
NUMLIS = ""
Local Integer Z
Local Char SZTIT
Local Integer WLOC
Local Integer WCSM
Z    = 0
WLOC = 0
WCSM = 0
SZTIT = ""

If GLOCREO = 2
   Filter [REO] Where [F:REO]STOFCY = LFCY & [F:REO]VCRNUM <> "" Order By [F:REO]VCRNUM Asc
   For [REO]
       If NUMLIS = [F:REO]VCRNUM
          Goto NEXTLIS
       Endif
   NUMLIS = [F:REO]VCRNUM
   If Z >= dim(TEX) - 1 : Break : Endif
   Z += 1
   TEX(Z)   = [F:REO]VCRNUM
   TEXTE(Z) = [F:REO]VCRNUM
   WLOC = 1
$NEXTLIS
Next
Filter [REO]
Endif

Raz NUMLIS

If GCSMREO = 2
   Filter [STA] Where [F:STA]STOFCY=LFCY & [F:STA]SRGNUM<>"" & [F:STA]ALLTYP=2
&                     & ([F:STA]DEFLOC<>"" | [F:STA]DEFLOCTYP<>"")
&                     & find([F:STA]VCRTYP,2,10,36)>0
&  Order By [F:STA]SRGNUM Asc
   For [STA]
       If NUMLIS = [F:STA]SRGNUM
          Goto NEXTLIS_2
       Endif
       If WLOC = 1
          If find([F:STA]SRGNUM,TEX(0..dim(TEX) - 1))
             Goto NEXTLIS_2
          Endif
       Endif
       NUMLIS = [F:STA]SRGNUM                 # hcb 71611
       If Z >= dim(TEX) - 1 : Break : Endif
       Z += 1
       TEX(Z)   = [F:STA]SRGNUM
       TEXTE(Z) = [F:STA]SRGNUM
       WCSM = 1
$NEXTLIS_2
   Next
   Filter [STA]
Endif

Raz NUMLIS

If GSHTREO = 2
   Filter [STA] Where  [F:STA]STOFCY = LFCY & [F:STA]SRGNUM <> ""
&                    & [F:STA]ALLTYP = 4    & [F:STA]LOC <> ""
&  Order By [F:STA]SRGNUM Asc
   For [STA]
       If NUMLIS = [F:STA]SRGNUM
          Goto NEXTLIS_4
       Endif
       If WLOC = 1 | WCSM = 1
          If find([F:STA]SRGNUM,TEX(0..dim(TEX) - 1))
             Goto NEXTLIS_4
          Endif
       Endif
       NUMLIS = [F:STA]SRGNUM               # hcb 71611
       If Z >= dim(TEX) - 1 : Break : Endif
       Z += 1
       TEX(Z)   = [F:STA]SRGNUM
       TEXTE(Z) = [F:STA]SRGNUM
$NEXTLIS_4
   Next
   Filter [STA]
Endif

Sorta  Z TEX,TEXTE    Order By TEX(indice)

NBTEX = Z
SZTIT = mess(454,198,1) #Liste à ranger
TIT = left$(SZTIT, 20)

Return


#########################################################################
# STKVERREO                                       controle fichier STOREO
#########################################################################
$STKVERREO
Local Integer NOL
If [F:REO]STOFCY = ""
   Return
Endif


Read [REO]REO0=[F:REO]STOFCY;[F:REO]LOC;[F:REO]ITMREF
If fstat
   Return
Endif
# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif

Gosub CTR_EXI_REO1 From TRTREOA
If WEXI <> 0
   GERR = 1
   mkstat = 2
   GMESSAGE=mess(14,184,1)       #  Enregistrement  déjà présent dans le tableau  !
   Return
Endif

[M:REO1]ORIREO     (LLIG) = 1
[M:REO1]DEFTYPLOC  (LLIG) = ""
[M:REO1]DEFLOC     (LLIG) = ""
[M:REO1]CREFLG     (LLIG) = 0
[M:REO1]MODFLG     (LLIG) = 2
[M:REO1]CLEFLG     (LLIG) = 1
[M:REO1]WFLG       (LLIG) = 1
[M:REO1]WSTOFLG    (LLIG) = 0
[M:REO1]COCHAGE    (LLIG) = 2
[M:REO1]ITMREF     (LLIG) = [F:REO]ITMREF
[M:REO1]BPRNUM     (LLIG) = [F:REO]BPRNUM
[M:REO1]SRGLIN     (LLIG) = [F:REO]VCRLIN
[M:REO1]SRGPPS     (LLIG) = [F:REO]VCRNUM
[M:REO1]SRGPPS_AV  (LLIG) = [F:REO]VCRNUM
[M:REO1]LOCORI     (LLIG) = [F:REO]LOC
If dim([M:REO1]WRHORI)>0
   [M:REO1]WRHORI  (LLIG) = [F:REO]WRH
Endif
[M:REO1]BESDAT     (LLIG) = [F:REO]BESDAT
[M:REO1]PCUORI     (LLIG) = [F:REO]PCU
[M:REO1]QTYPCUORI  (LLIG) = [F:REO]QTYPCU
[M:REO1]PCUSTUCOEO (LLIG) = [F:REO]PCUSTUCOE
[M:REO1]QTYSTUORIA (LLIG) = [F:REO]QTYSTUACT
[M:REO1]QTYSTUORI  (LLIG) = [F:REO]QTYSTU
[M:REO1]QTYSTUACT  (LLIG) = [F:REO]QTYSTUACT
If [M:REO1]SRGPPS  (LLIG) = ""
   [M:REO1]SRGPPS  (LLIG) = [M:REO1]SRGPPSSTR
Endif

If [F:ITM]ITMREF<>[F:REO]ITMREF
    Read [F:ITM]ITM0=[F:REO]ITMREF
    If fstat
       Raz [F:ITM]
    Endif
Endif
[M:REO1]STU        (LLIG)   = [F:ITM]STU

Affzo  [M:REO1]LOCORI(LLIG)
Grizo  [M:REO1]ITMREF(LLIG)
Grizo  [M:REO1]LOCORI(LLIG)
If dim([M:REO1]WRHORI)>0
   Affzo [M:REO1]WRHORI(LLIG)
   Grizo [M:REO1]WRHORI(LLIG)
Endif
# initialisation liste à ranger par celui de la selection
If   [M:REO1]SRGPPS(LLIG) = ""
     [M:REO1]SRGPPS(LLIG) = [M:REO1]SRGPPSSTR
Endif
NOL = LLIG

Grizo [M:REO1]SRGPPS(LLIG)

Gosub FORMATAGE_CLE From TRTREOA

[M:REO1]WCLE   (LLIG)   = WCLE_FOR
[M:REO1]SAIFLG = 2         # saisie manuelle à oui permet de desactiver les boutons recherche critere
[M:REO1]NBRLOC +=1
Affzo [M:REO1]

[M:REO1]NBLIG  = LLIG+1

# il faut activer les zones de cle sur la ligne vide ....

NOL = [M:REO1]NBLIG
Gosub ACT_RUB_CLE

Return

#########################################################################
#SET_NOL                                        Alimentation rubrique NOL
#########################################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return

#########################################################################
# ACT_RUB_CLE                               activation des rubriques cles
#########################################################################
$ACT_RUB_CLE

If dim([M:REO1]COCHAGE) > 0
   Grizo [M:REO1]COCHAGE(NOL)
Endif

If GORIGINE  <> 2
#   Return
Endif
If dim([M:REO1]ITMREF) > 0
   Actzo [M:REO1]ITMREF(NOL)
Endif
If dim([M:REO1]LOCORI) > 0
   Actzo [M:REO1]LOCORI(NOL)
Endif
If dim([M:REO1]WRHORI) > 0
   Actzo [M:REO1]WRHORI(NOL)
Endif

Return

#########################################################################
# DES_RUB_DESTINATION            desactivation des rubriques destinations
#########################################################################
$DES_RUB_DESTINATION

If dim([M:REO1]COCHAGE) > 0
   Actzo [M:REO1]COCHAGE(NOL)
Endif
If dim([M:REO1]STA) > 0
   Grizo [M:REO1]STA(NOL)
Endif
If dim([M:REO1]WRH) > 0
   Grizo [M:REO1]WRH(NOL)
Endif
If dim([M:REO1]LPNNUM) > 0                                                               # hcb x3-82749
#  Grizo [M:REO1]LPNNUM(NOL)                                                             # hcb x3-82749
Endif                                                                                    # hcb x3-82749
If dim([M:REO1]LOC) > 0
   Grizo [M:REO1]LOC(NOL)
Endif
If dim([M:REO1]LOT) > 0
   Grizo [M:REO1]LOT(NOL)
Endif
If dim([M:REO1]SLO) > 0
   Grizo [M:REO1]SLO(NOL)
Endif
If dim([M:REO1]SERNUM) > 0
   Grizo [M:REO1]SERNUM(NOL)
Endif
If dim([M:REO1]PALNUM) > 0             # hcb 27200
   Grizo [M:REO1]PALNUM(NOL)           # hcb 27200
   Grizo [M:REO1]CTRNUM(NOL)           # hcb 27200
Endif                                  # hcb 27200
If dim([M:REO1]MVTDES) > 0
   Grizo [M:REO1]MVTDES(NOL)
Endif
If dim([M:REO1]CLEFLG) > 0
   Grizo [M:REO1]CLEFLG(NOL)
Endif

Return

#########################################################################
# ACT_RUB_DESTINATION               activation des rubriques destinations
#########################################################################
$ACT_RUB_DESTINATION

If dim([M:REO1]COCHAGE) > 0
   Actzo [M:REO1]COCHAGE(NOL)
Endif
If dim([M:REO1]STA) > 0
   Actzo [M:REO1]STA(NOL)
Endif
If dim([M:REO1]WRH) > 0
   Actzo [M:REO1]WRH(NOL)
Endif
If dim([M:REO1]LPNNUM) > 0                                                               # hcb x3-82749
#   Actzo [M:REO1]LPNNUM(NOL)                                                             # hcb x3-82749
Endif                                                                                    # hcb x3-82749
If dim([M:REO1]LOC) > 0
   Actzo [M:REO1]LOC(NOL)
Endif
If dim([M:REO1]LOT) > 0
   Actzo [M:REO1]LOT(NOL)
Endif
If dim([M:REO1]SLO) > 0
   Actzo [M:REO1]SLO(NOL)
Endif

If dim([M:REO1]SERNUM) > 0
   Actzo [M:REO1]SERNUM(NOL)
Endif
If dim([M:REO1]PALNUM) > 0             # hcb 27200
   Actzo [M:REO1]PALNUM(NOL)           # hcb 27200
   Actzo [M:REO1]CTRNUM(NOL)           # hcb 27200
Endif                                  # hcb 27200
If dim([M:REO1]MVTDES) > 0
   Actzo [M:REO1]MVTDES(NOL)
Endif
If dim([M:REO1]CLEFLG) > 0
   Actzo [M:REO1]CLEFLG(NOL)
Endif

Return

########################################################################
#LOAD_FILTER              Préparation du filtre bloc filtre table STOREO
########################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE0
Local Char LNUM(GLONVCR)               # hcb 57490
CRITERE = "[F:REO]STAFLG<>2"                          # filtre statut
Gosub LOAD_CRITERE

If [M:REO1]STOFCY <> ""
   CRITERE = "[F:REO]STOFCY=[M:REO1]STOFCY"           # filtre site
   Gosub LOAD_CRITERE
Endif

If [M:REO1]SRGPPSSTR <> ""
   CRITERE = "[F:REO]VCRTYP=34 & [F:REO]VCRNUM=[M:REO1]SRGPPSSTR"        # filtre liste à ranger
   CRITERE0 = CRITERE1
   CRITERE0 += "&"
   CRITERE0 += CRITERE
Endif

LNUM = ""
CRITERE = "[F:REO]VCRNUM=LNUM"                        # filtre liste à ranger
Gosub LOAD_CRITERE

Return

#---------------------------------------------------

########################################################################
#LOAD_FILTER3   Préparation du filtre bloc Bornes debut fin table STOREO
########################################################################
$LOAD_FILTER3
Raz CRITERE
Raz CRITERE3

If [M:REO1]ITMREFSTR = [M:REO1]ITMREFEND
  If [M:REO1]ITMREFSTR <> ""
    CRITERE = "[F:REO]ITMREF=[M:REO1]ITMREFSTR"
    Gosub LOAD_CRITERE3
  Endif
Else
  If [M:REO1]ITMREFSTR <> ""
    CRITERE = "[F:REO]ITMREF>=[M:REO1]ITMREFSTR"
    Gosub LOAD_CRITERE3
  Endif
  If [M:REO1]ITMREFEND <> ""
    CRITERE = "[F:REO]ITMREF<=[M:REO1]ITMREFEND"
    Gosub LOAD_CRITERE3
  Endif
Endif
If [M:REO1]LOCSTR = [M:REO1]LOCEND
  If [M:REO1]LOCSTR <> ""
    CRITERE = "[F:REO]LOC=[M:REO1]LOCSTR"
    Gosub LOAD_CRITERE3
  Endif
Else
  If [M:REO1]LOCSTR <> ""
    CRITERE = "[F:REO]LOC>=[M:REO1]LOCSTR"
    Gosub LOAD_CRITERE3
  Endif
  If [M:REO1]LOCEND <> ""
    CRITERE = "[F:REO]LOC<=[M:REO1]LOCEND"
    Gosub LOAD_CRITERE3
  Endif
Endif
If dim([M:REO1]WRHSTR)>0
  If [M:REO1]WRHSTR = [M:REO1]WRHEND
    If [M:REO1]WRHSTR <> ""
      CRITERE = "([F:REO]WRH=''|[F:REO]WRH=[M:REO1]WRHSTR)"
      Gosub LOAD_CRITERE3
    Endif
  Else
    If [M:REO1]WRHSTR <> ""
      CRITERE = "([F:REO]WRH=''|[F:REO]WRH>=[M:REO1]WRHSTR)"
      Gosub LOAD_CRITERE3
    Endif
    If [M:REO1]WRHEND <> ""
      CRITERE = "[F:REO]WRH<=[M:REO1]WRHEND"
      Gosub LOAD_CRITERE3
    Endif
  Endif
Endif

Return

########################################################################
# LOAD_CRITERE                                     Concaténation CRITERE
########################################################################
$LOAD_CRITERE
If CRITERE1 <> ""
   CRITERE1 += "&"
Endif
CRITERE1 += CRITERE
Return

########################################################################
# LOAD_CRITERE3                                   Concaténation CRITERE3
########################################################################
$LOAD_CRITERE3
