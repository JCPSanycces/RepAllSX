Subprog AS_ITMREFCAL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_CFGLIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  [M:CSE0]CFGLINAXX = ""
  Affzo [M:CSE0]CFGLINAXX
Else
  Read [TLP]TLP0=VALEUR
  If fstat 
    [M:CSE0]CFGLINAXX = ""
    Affzo [M:CSE0]CFGLINAXX
    mkstat = 2
  Else 
    Call GET_ATEXTRA("TABLINCFG","CFGLINAXX",GLANGUE,[M:CSE0]CFGLINAXX) From TRTX3TEX
    Affzo [M:CSE0]CFGLINAXX
  Endif
Endif
End
