###########################################################
Subprog C_SELTBL(VALEUR)
Variable Char    VALEUR()
If !find([F:ATB]CODFIC,"ITMMASTER","ITMFACILIT","ITMMVT","ITMSALES")
  [M:CSE1]SELTBLTXT(nolign-1) = ""
  Affzo [M:CSE1]SELTBLTXT(nolign-1)
  mkstat = 2
Else
  Read [ATB]CODFIC = VALEUR
  If fstat
    [M:CSE1]SELTBLTXT(nolign-1) = ""
    Affzo [M:CSE1]SELTBLTXT(nolign-1)
    mkstat = 2
  Else
    Call TEXTE([F:ATB]INTITFIC,[M:CSE1]SELTBLTXT(nolign-1)) From OBJDIV
    Affzo [M:CSE1]SELTBLTXT(nolign-1)
  Endif
Endif
End
###########################################################
Subprog C_SELFLD(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I = 0 To [M:CSE1]SELFLDNBR-1
  If I <> nolign-1 &
&    [M:CSE1]SELTBL(I) = [M:CSE1]SELTBL(nolign-1) &
&    [M:CSE1]SELFLD(I) = VALEUR
    GMESSAGE = mess(24,123,1)-num$(I)
    mkstat = 2
    Break
  Endif
Next I
If mkstat = 0
  Read [ATZ]CODZONE=[M:CSE1]SELTBL(nolign-1);VALEUR
  If fstat 
    [M:CSE1]SELFLDTXT(nolign-1) = ""
    Affzo [M:CSE1]SELFLDTXT(nolign-1)
    mkstat = 2
  Else
    Call FLD_TXT("","",[M:CSE0]CFGLIN,[M:CSE1]SELFLDTXT(nolign-1)) From CFGLIB        
    Affzo [M:CSE1]SELFLDTXT(nolign-1)
  Endif
Endif
End
############################################################
Subprog AS_SELLINNBR(VALEUR)
Variable Decimal  VALEUR
If [M:CSE0]SELTYP <> 1
  VALEUR = 0
  mkstat = 2
