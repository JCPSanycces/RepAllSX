Subprog C_ITMREFFOR(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:CSE2]ITMREFLOA(nolign-1) = ""
  mkstat = 2
Endif
End
###########################################################
Subprog AM_SELKEY(VALEUR)
Variable Integer VALEUR
Local Char    WIND(80) : WIND = "ITMREF"
Local Integer I
Filter [ATI] Where CODFIC="ITMMASTER" & NUMLIG = VALEUR
&            Order By Key NUMLIG
For [ATI]
  WIND = [F:ATI]DESCRIPT
  I = instr(1,[F:ATI]DESCRIPT,"+")
  If I <> 0 
    WIND = left$([F:ATI]DESCRIPT,I-1)
    Break
  Endif
  I = instr(1,[F:ATI]DESCRIPT,"-")
  If I <> 0 
    WIND = left$([F:ATI]DESCRIPT,I-1)
    Break
  Endif
Next
Filter [ATI]
[M:CSE1]SELKEYFLD = WIND
End
############################################################
############################################################
Subprog AS_REFDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
  VALEUR = date$
Endif
End
############################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char    WITM(30) : WITM    = [M:CSE3]PARITM
Local Date    WDAT     : WDAT    = [M:CSE3]REFDAT
Local Integer WNOLIGN  : WNOLIGN = nolign
Local Integer I        : I       = 0
#
[M:CSE3]NBLIG = 0
nolign        = 0
Filter [BOH] Where ITMREF    = WITM   &
&                  BOMALTTYP = 1      & 
&   ([F:BOH]BOHSTRDAT = [0/0/0] | ([F:BOH]BOHSTRDAT <= WDAT & [F:BOH]BOHSTRDAT <> [0/0/0])) &
&   ([F:BOH]BOHENDDAT = [0/0/0] | ([F:BOH]BOHENDDAT >= WDAT & [F:BOH]BOHENDDAT <> [0/0/0]))
For [BOH]
  I = 1
Next
Filter [BOH]
If I <> 0
  Filter [BOD] Where ITMREF = [M:CSE3]PARITM &
&                    BOMALT = VALEUR         &
&                    BOMALTTYP = 1           & 
&                    CPNTYP < 4              &
&     ([F:BOD]BOMSTRDAT = [0/0/0] | ([F:BOD]BOMSTRDAT <= WDAT & [F:BOD]BOMSTRDAT <> [0/0/0])) &
&     ([F:BOD]BOMENDDAT = [0/0/0] | ([F:BOD]BOMENDDAT >= WDAT & [F:BOD]BOMENDDAT <> [0/0/0]))
  For [BOD]
    If nolign < dim([M:CSE3]CPNITMREF)-1
      nolign        += 1
      [M:CSE3]NBLIG += 1
      [M:CSE3]       = [F:BOD]
      Read [ITM]ITM0=[F:BOD]CPNITMREF
      If fstat
        Raz [F:ITM]
      Endif
      [M:CSE3]       = [F:ITM]
    Else
      Break
    Endif
  Next 
  Filter [BOD]
Endif
Affzo [M:CSE3]10
If nolign = 0
  GMESSAGE = mess(140,197,1)
  mkstat = 2
Endif
nolign = WNOLIGN
End
############################################################
Subprog AS_SELMUL(VALEUR)
Variable Integer VALEUR
Local Integer W_I
For W_I = 1 To len(mess(0,763,1))
  GMENLOC(W_I) = 1
Next I
GMENLOC(2) = 0
GMENLOC(3) = 0
GMENLOC(4) = 0
GMENLOC(5) = 0
GMENLOC(6) = 0
End
############################################################
Subprog AS_MACNUM(VALEUR)
Variable Char     VALEUR
If [M:CSE0]SELMOD = 1
  mkstat = 2
Endif
End
