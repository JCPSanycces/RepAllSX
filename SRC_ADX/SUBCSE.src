Subprog AS_SELFORNBR
If [M:CSE0]SELTYP <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_ITMREFNBR
If [M:CSE0]SELTYP = 1 
  mkstat = 2
Else
  If [M:CSE2]ITMREFNBR <> 0
    GBOUT1 = ""
  Endif
Endif
End
############################################################
Subprog AS_ITMREFSEQ(VALEUR)
Variable Decimal VALEUR
Case [M:CSE0]SELTYP 
  When 2 :
    If nolign > 1 & VALEUR = 0
      VALEUR = [M:CSE2]ITMREFSEQ(nolign-2)
    Endif
  When 3 :
    If nolign > 1
      VALEUR = [M:CSE2]ITMREFSEQ(nolign-2)
      mkstat = 2
    Endif
  When Default :
    mkstat = 2
Endcase
End
############################################################
Subprog C_ITMREFSEQ(VALEUR)
Variable Decimal VALEUR
If nolign > 1
  If VALEUR < [M:CSE2]ITMREFSEQ(nolign-2)
    mkstat = 2
    GMESSAGE = mess(22,188,1)
  Endif
Endif
End
############################################################
Subprog AM_ITMREFSEQ(VALEUR)
Variable Decimal VALEUR
Local Integer W_I
End
############################################################
Subprog AS_ITMOPVAXX(VALEUR)
Variable Char    VALEUR()
Case [M:CSE0]SELTYP 
  When 2 :
    If nolign > 1 & [M:CSE2]ITMREFSEQ(nolign-1) = [M:CSE2]ITMREFSEQ(nolign-2)
      VALEUR = [M:CSE2]ITMOPVAXX(nolign-2)
      mkstat = 2   
    Endif
  When Default :
    mkstat = 2
Endcase
End
############################################################
Subprog AM_ITMOPVAXX(VALEUR)
Variable Char    VALEUR()
Local Integer W_I
Case [M:CSE0]SELTYP
  When 2 :
    For W_I = 0 To [M:CSE2]ITMREFNBR -1
      If [M:CSE2]ITMREFSEQ(W_I) = [M:CSE2]ITMREFSEQ(nolign-1) & W_I <> nolign-1
        [M:CSE2]ITMOPVAXX(W_I) = VALEUR
        Affzo [M:CSE2]ITMOPVAXX(W_I)
      Endif
    Next W_I
Endcase
End
############################################################
Subprog AS_ITMREFQTY(VALEUR)
Variable Integer VALEUR
If [M:CSE1]SELQTY = 1
  VALEUR = 1
  mkstat = 2
Else
  GMENLOC(3) = 1
Endif
End
############################################################
Subprog C_RULOPT1(VALEUR)
Variable Decimal VALEUR
Local Integer W_I
W_I = find(VALEUR,[M:CSE2]ITMREFSEQ(0..[M:CSE2]ITMREFNBR-1))
If W_I = 0
  [M:CSE2]RULOPTTXT1(nolign-1) = ""
  Affzo [M:CSE2]RULOPTTXT1(nolign-1)
  mkstat = 2
Else
  [M:CSE2]RULOPTTXT1(nolign-1) = [M:CSE2]ITMOPVAXX(W_I-1)
  Affzo [M:CSE2]RULOPTTXT1(nolign-1)
Endif
End
###########################################################
Subprog AS_RULOPT2(VALEUR)
Variable Decimal VALEUR
If [M:CSE2]RUL(nolign-1) = 1
  mkstat = 2
Endif
End
############################################################
Subprog C_RULOPT2(VALEUR)
Variable Decimal VALEUR
Local Integer W_I
W_I = find(VALEUR,[M:CSE2]ITMREFSEQ(0..[M:CSE2]ITMREFNBR-1))
If W_I = 0 | VALEUR = [M:CSE2]RULOPT1(nolign-1)
  [M:CSE2]RULOPTTXT2(nolign-1) = ""
  Affzo [M:CSE2]RULOPTTXT2(nolign-1)
  mkstat = 2
Else
  [M:CSE2]RULOPTTXT2(nolign-1) = [M:CSE2]ITMOPVAXX(W_I-1)
  Affzo [M:CSE2]RULOPTTXT2(nolign-1)
Endif
End
