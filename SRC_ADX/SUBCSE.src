#<AdxTL>@(#)0.0.0.0 $Revision$
#    Objet CSE - Sélections configurateur
#
$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "OUVRE"        : Gosub OUVRE
  When "FILTRE"       : Gosub FILTRE
  When "AFFMASK"      : Gosub AFFMASK 
  When "SETBOUT"      : Gosub SETBOUT 
  When "EXEBOUT"      : Gosub EXEBOUT
  When "APRES_CHOI"   : Gosub APRES_CHOI
  When "RAZCRE"       : Gosub RAZCRE
  When "RAZDUP"       : Gosub RAZDUP
  When "LIENS"        : Gosub LIENS
  When "INICRE"       : Gosub INICRE
  When "INIMOD"       : Gosub INIMOD
  When "VERIF_CRE"    : Gosub VERIF_CRE 
  When "VERIF_MOD"    : Gosub VERIF_MOD
  When "APRES_MOD"    : Gosub APRES_MOD
  When "VERF_ANU"     : Gosub VERF_ANU
  When "ANNULE"       : Gosub ANNULE
  When "ABANDON"      : Gosub ABANDON
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0 
  When "FERME"        : Gosub FERME
  When "FIN_ACTION"   : Gosub FIN_ACTION     # JPJ E26080
  When "CHANGE"       : Call CHANGE_AXX ("CFGSEL", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default :
Endcase
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Local Char    W_GFONC1 : W_GFONC1 = GFONC1
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Else
  If GFONC1 = "GESCFG"
    If ABREV = "CSE" 
      GFONC1 = "GESCSE"
    Else
      GFONC1 = "GESCOV"
    Endif
  Endif 
#
  Case GFONC1
    When "GESCSE" : 
      GSINTV1 =  mess(4,752,1)
    When "GESCOV" :
      GSINTV1 = mess(5,752,1)
  Endcase
Endif
Return
###########################################################
$OUVRE
adxmbm = adxmbm
Gosub OPEN_FILES     From CFGLIB
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Local Char    W_SYMAV(10)(100)
Local Decimal W_NBRAV
Local Decimal W_NBR
Local Char    W_SCE(5)
Local Char    W_SCM(5)(100)
Local Char    W_MSG(250)
Local Integer I_SCM, W_I, W_J
#
Case GFONC1
  When "GESCSE" : 
    [M:CSE0]SELTYP = 1
    If clalev([M:CSE2]) = 0 : Local Mask CSE2SE [CSE2] : Endif
  When "GESCOV" :
    [M:CSE0]SELTYP = 2
Endcase  
If clalev([F:CSE0]) = 0 : Local File CFGSEL    [CSE0] : Endif
If clalev([F:CSC1]) = 0 : Local File CFGSCE    [CSC1] : Endif
If clalev([F:CSL1]) = 0 : Local File CFGSCELIN [CSL1] : Endif
If clalev([F:BOH])  = 0 : Local File BOM       [BOH]  : Endif
If clalev([F:BOD])  = 0 : Local File BOMD      [BOD]  : Endif
Return
###########################################################
$VERF_ANU
If clalev([F:CLN]) = 0 : Local File CFGLNK [CLN] : Endif
Filter [CLN] Where SYMTYP = [M:CSE0]SELTYP &
&                  SYMNUM = [M:CSE0]SELNUM
&            Order By Key CLN1
For [CLN]
  Call ERREUR(mess(174,188,1)-mess([F:CLN]SYMTYPWUS,752,1)-[F:CLN]SYMNUMWUS) From GESECRAN
  OK = 0
  Break
Next 
Filter [CLN]
Return
###########################################################
$FERME
GFONC1 = W_GFONC1
Call IMPSCR        From ATRTX3
Gosub SUP_GLOBALES From WUVAR
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
###########################################################
$FILTRE
If dim([M:CSE0]SELTYP) > 0
  Case GFONC1
    When "GESCSE" : FILTSUP = "[F:CSE]SELTYP = 1"
    When "GESCOV" : FILTSUP = "[F:CSE]SELTYP = 2"
  Endcase
Endif
Return
###########################################################
$AFFMASK
Return
###########################################################
$EXEBOUT 
Local Char WDMY
Case REP 
  When "a"
    adxmbm = adxmbm
    Gosub SUP_GLOBALES   From WUVAR
    Gosub CFG_CONSTANTES From CFGLIB
    Gosub CFG_SYMBOLES   From CFGLIB
    Raz [M:CSE0]FILTAB
    Raz [M:CSE0]TEXCON
    Call CFGSETFOR(7,[M:CSE0]CFGLIN,"DEFG",[M:CSE0]FILTAB,[M:CSE0]TEXCON,[M:CSE0]VARSUP) From CFGLIB
  When "b"
    adxmbm = adxmbm
    Gosub SUP_GLOBALES   From WUVAR
    Gosub CFG_CONSTANTES From CFGLIB
    Gosub CFG_SYMBOLES   From CFGLIB
  When "c"
    Gosub GEN_ECRAN
    If GOK = 1 & [M:CSE0]RETCOD = 0
      Commit
    Else
      Rollback
    Endif
  When "d" :
    Call VISUM("WUS"+CLECUR1) From SUBAMK
    If [M:CSE0]SELMOD = 2
      If filinfo(filpath("ECR","WUA"+CLECUR1,"msk",0),0) > 0
        Call VISUM("WUA"+CLECUR1) From SUBAMK
      Endif 
    Endif
  When "2" :
    If !GINTRA
      Call COPIE([M:CSE0]SELNUM)
    Endif
Endcase
Return 
########################################################### 
$SETBOUT
If GINTRA
  Call VIREBOUT(CHAINE,"d2") From GOBJET
Else
  If [M]SELNUM = "" 
    Call VIREBOUT(CHAINE,"cd2") From GOBJET
  Endif
Endif 
Return
############################################################
$APRES_CHOI
Case REPONSE
  When GSTARET :
    Case GREP
      When "C", "D" : REPONSE = GSTACRE
      When "M"      : REPONSE = GSTAENR
    Endcase
Endcase
Case REPONSE
  When GSTAENR :
    Trbegin [CSE]
    GOK = 1
    Gosub MAJ_SEL 
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR)
    If [M:CSE0]SELMOD = 2
      [M:CSE0]PAR001 = nomap
      [M:CSE0]PAR002 = "CFGINI"
      [M:CSE0]PAR006 = GSINTV1
    Else
      [M:CSE0]PAR002 = ""
    Endif
  When GSTACRE :
    Trbegin [CSE]
    GOK = 1 
    Gosub MAJ_SEL
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR)
    If [M:CSE0]SELMOD = 2
      [M:CSE0]PAR001 = nomap
      [M:CSE0]PAR002 = "CFGINI"
      [M:CSE0]PAR006 = GSINTV1
    Else
      [M:CSE0]PAR002 = ""
    Endif
  When 1803 :
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR)
    If [M:CSE0]SELMOD = 2
      [M:CSE0]PAR001 = nomap
      [M:CSE0]PAR002 = "CFGINI"
      [M:CSE0]PAR006 = GSINTV1
    Else
      [M:CSE0]PAR002 = ""
    Endif
    Trbegin [CSE]
    GOK = 1 
Endcase
Return
############################################################
$MAJ_SEL
Local Integer WI
Local Integer WJ : WJ = [M:CSE0]SELTYP+3    # = 4 ou 5
#
Call PURCLN(WJ,[M:CSE0]SELNUM,0) From CFGLIBE
#
If GOK = 1
  If [M:CSE1]MACNUM <> ""
    Call ECRCLN(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",7,[M:CSE1]MACNUM,"MACNUM") From CFGLIBE
  Endif
  If [M:CSE1]PRIFOR <> ""
    # FGR 27/07/2009 : X3SUIVI56760
    #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE1]PRIFOR,"PRIFOR") From CFGLIBE
    Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE1]PRIFOR,"PRIFOR") From CFGLIBE
  Endif
  If [M:CSE1]QTYFOR <> ""
    # FGR 27/07/2009 : X3SUIVI56760
    #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE1]QTYFOR,"QTYFOR") From CFGLIBE
    Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE1]QTYFOR,"QTYFOR") From CFGLIBE
  Endif
  If [M:CSE1]SELFIL <> ""
    # FGR 27/07/2009 : X3SUIVI56760
    #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE1]SELFIL,"SELFIL") From CFGLIBE
    Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE1]SELFIL,"SELFIL") From CFGLIBE
  Endif
  If [M:CSE1]SELFORNBR > 0
    For WI = 0 To [M:CSE1]SELFORNBR -1
      If [M:CSE1]SELFOR(WI) <> ""
        # FGR 27/07/2009 : X3SUIVI56760
        #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE1]SELFOR(WI),"SELFOR") From CFGLIBE
        Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE1]SELFOR(WI),"SELFOR") From CFGLIBE
      Endif  
    Next WI
  Endif
  If [M:CSE2]RULNBR > 0
    For WI = 0 To [M:CSE2]RULNBR -1
      If [M:CSE2]RULCND(WI) <> ""
        # FGR 27/07/2009 : X3SUIVI56760
        #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE2]RULCND(WI),"RULCND") From CFGLIBE
        Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE2]RULCND(WI),"RULCND") From CFGLIBE
      Endif
    Next WI
  Endif
  If [M:CSE2]ITMREFNBR > 0
    For WI = 0 To [M:CSE2]ITMREFNBR -1
      If [M:CSE2]ITMREFFOR(WI) <> ""
        # FGR 27/07/2009 : X3SUIVI56760
        #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE2]ITMREFFOR(WI),"ITMREFFOR") From CFGLIBE
        Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE2]ITMREFFOR(WI),"ITMREFFOR") From CFGLIBE
      Endif
      If [M:CSE2]ITMREFCAL(WI) <> ""
        # FGR 27/07/2009 : X3SUIVI56760
        #Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"","[M:CSE0]",[M:CSE2]ITMREFCAL(WI),"ITMREFCAL") From CFGLIBE
        Call CFGWUSEXP(WJ,[M:CSE0]SELNUM,"",[M:CSE2]ITMREFCAL(WI),"ITMREFCAL") From CFGLIBE
      Endif
    Next WI
  Endif
Endif
Return
############################################################
$INICRE
Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR)
Call MAJTEXTRA([M:CSE0]SELAXX,"CFGSEL","SELAXX",[M:CSE0]SELNUM,"") From ATEXTRA
Return
############################################################
$INIMOD
Call MAJTEXTRA([M:CSE0]SELAXX,"CFGSEL","SELAXX",[M:CSE0]SELNUM,"") From ATEXTRA
Return
########################################################### 
$VERIF_CRE
If [M:CSE0]RETCOD = 0
  If [M:CSE0]SELTYP <> 1 & [M:CSE2]ITMREFNBR = 0
    Call ERREUR(mess(21,188,1)) From GESECRAN
    Rollback
    OK = 0
  Else
    If [M:CSE0]SELTYP <> 1
      Gosub MAJ_OPTVAR
    Endif 
    Gosub GEN_ECRAN
    If GOK = 1
      Commit
    Else
      Rollback
      OK = 0
    Endif
  Endif
Else
  Rollback
  OK = 0
Endif
Return
########################################################### 
$VERIF_MOD
If [M:CSE0]RETCOD = 0
  If [M:CSE0]SELTYP <> 1 & [M:CSE2]ITMREFNBR = 0
    Call ERREUR(mess(21,188,1)) From GESECRAN
    Rollback
    OK = 0
  Else
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR)
    W_J = 0
    Call DIFSYM(W_SYMAV,W_NBRAV,[M:CSE0]SYMNUM,[M:CSE0]SYMNBR,W_J) From CFGLIBE
    If W_J <> 0
      W_I = 1
      Gosub CAS_EMPLOI
      Call AVERTIR(W_MSG,W_I) From GESECRAN      
      If W_I <> 2
        OK  = 0
        W_J = 0
        Return
      Endif
    Endif  
    If [M:CSE0]SELTYP <> 1
      Gosub MAJ_OPTVAR
    Endif 
    If W_J <> 0
      Gosub GEN_ECRAN
      W_MSG = ""
  # Desactivation scenarios utilisant la selection
      Filter [CSL] Where (SYMTYP = 4 | SYMTYP = 5) &
&                         SYMNUM = [M:CSE0]SELNUM
&                  Order By Key CSL1 
      For [CSL]
        Read [CSC]CSC0=[F:CSL]SCENUM
        If fstat = 0
          [F:CSC]ENAFLG = 1
          Rewrite [CSC]
          If fstat
            Call FSTA("CSC") From GLOCK
            GOK = 0
            Break
          Endif
          If W_MSG = ""
            W_MSG = mess(145,188,1)
          Endif
          W_MSG -= [F:CSC]SCENUM
        Endif 
      Next
      Filter [CSL] 
    Endif
    If GOK = 1
      Commit
    Else
      Rollback
      OK = 0
    Endif
  Endif
Else
  Rollback
  OK = 0
Endif
Return
############################################################
$APRES_MOD
If W_MSG <> "" 
  Call MESSAGE(W_MSG) From GESECRAN
Endif
Return
############################################################
$CAS_EMPLOI
Raz W_SCM, I_SCM
W_MSG = mess(81,188,1)+"\"
#
Filter [CSL] Where (SYMTYP = 4 | SYMTYP = 5) &
&                   SYMNUM = [M:CSE0]SELNUM
&            Order By Key CSL1 
For [CSL]
  If !find([F:CSL]SCENUM,W_SCM(0..I_SCM-1))
    If I_SCM < dim(W_SCM)
      W_SCM(I_SCM) = [F:CSL]SCENUM
      W_MSG += [F:CSL]SCENUM+", "
      I_SCM += 1
    Endif
  Endif
Next
Filter [CSL] 
Return
############################################################
$RAZCRE
Case GFONC1
  When "GESCSE" : [M:CSE0]SELTYP = 1
  When "GESCOV" : [M:CSE0]SELTYP = 2
Endcase
[M:CSE0]FILTBL    = 'find(CODFIC,"ITMMASTER","ITMFACILIT","ITMMVT","ITMSALES")'     # JPJ E26173
Gosub MEI_ECRAN
[M:CSE1]SELTBL(0) = "ITMMASTER"
[M:CSE1]SELFLD(0) = "ITMREF"
[M:CSE1]SELTBL(1) = "ITMMASTER"
[M:CSE1]SELFLD(1) = "ITMDES1"
[M:CSE1]SELTBL(2) = "ITMMASTER"
[M:CSE1]SELFLD(2) = "CFGLIN"
[M:CSE1]SELTBL(3) = "ITMMVT"
[M:CSE1]SELFLD(3) = "PHYSTO"
[M:CSE1]SELFLDNBR = 4
[M:CSE1]SELKEY    = 1
[M:CSE1]SELKEYFLD = "ITMREF" 
Gosub TXT_FLD
Affzo [M:CSE1]1-99
Return
############################################################
$RAZDUP
Case GFONC1
  When "GESCSE" : [M:CSE0]SELTYP = 1
  When "GESCOV" : [M:CSE0]SELTYP = 2
Endcase
Gosub MEI_ECRAN
Return
############################################################
$MEI_ECRAN
Local Integer W_I
Raz [M:CSE0]FILTAB
Raz [M:CSE0]TEXCON
Call CFGSETFOR(7,[M:CSE0]CFGLIN,"DEFG",[M:CSE0]FILTAB,[M:CSE0]TEXCON,[M:CSE0]VARSUP) From CFGLIB

Return
############################################################
$LIENS
Local Integer I, J, K
[M:CSE0]SELNUMCOP = [M:CSE0]SELNUM
[M:CSE0]FILTBL    = 'find(CODFIC,"ITMMASTER","ITMFACILIT","ITMMVT","ITMSALES")'
Case GFONC1
  When "GESCSE", "GESCOV" :
    Gosub MEI_ECRAN
    Gosub TXT_FLD
Endcase
nolign = 0
Read [TLP]TLP0=[M:CSE0]CFGLIN
If fstat = 0
    Call GET_ATEXTRA("TABLINCFG","CFGLINAXX",GLANGUE,[M:CSE0]CFGLINAXX) From TRTX3TEX
Endif
#
Case GFONC1
  When "GESCSE" : [M:CSE0]SELTYP = 1
  When "GESCOV" : [M:CSE0]SELTYP = 2
Endcase
If [M:CSE0]SELTYP <> 1
  Filter [COV] Where SELNUM = [M:CSE0]SELNUM
&              Order By Key COV0
  For [COV]
    If nolign < dim([M:CSE2]ITMREFLOA)-1
      nolign += 1
      Read [ITM]ITM0 = [F:COV]ITMREFLOA
      If fstat
        Raz [F:ITM]
      Endif
      Read [TLP]TLP0=[F:ITM]CFGLIN
      If fstat
        Raz [F:TLP]
      Endif
      [M:CSE2] = [F:COV]
      Call GET_ATEXTRA("CFGOPTVAR","ITMOPVAXX",GLANGUE,[M:CSE2]ITMOPVAXX(nolign-1)) From TRTX3TEX
      [M:CSE2] = [F:ITM]
      [M:CSE2] = [F:TLP]
      [M:CSE2]CFGLINNUM(nolign-1) = [F:TLP]CFGLIN
    Else
      Break
    Endif
  Next
  Filter [COV]
  [M:CSE2]ITMREFNBR = nolign
  If [M:CSE0]SELTYP = 2 
    For J = 0 To  [M:CSE2]RULNBR-1
      K = find([M:CSE2]RULOPT1(J),[M:CSE2]ITMREFSEQ(0..[M:CSE2]ITMREFNBR-1))
      If K <> 0
        [M:CSE2]RULOPTTXT1(J) = [M:CSE2]ITMOPVAXX(K-1)
      Endif 
      K = find([M:CSE2]RULOPT2(J),[M:CSE2]ITMREFSEQ(0..[M:CSE2]ITMREFNBR-1))
      If K <> 0
        [M:CSE2]RULOPTTXT2(J) = [M:CSE2]ITMOPVAXX(K-1)
      Endif 
    Next J
  Endif
  If GFONC1 <> "FUNCFGUTI"
    Affzo [M:CSE2]1-99
  Endif
Endif
Call GEN_LABELS(W_SYMAV,W_NBRAV)
Return
############################################################
$TXT_FLD
For W_I = 0 To [M:CSE1]SELFLDNBR-1
  Read [ATB]CODFIC=[M:CSE1]SELTBL(W_I)
  If fstat = 0 
    Call TEXTE([F:ATB]INTITFIC,[M:CSE1]SELTBLTXT(W_I)) From OBJDIV
  Endif
  Read [ATZ]CODZONE=[M:CSE1]SELTBL(W_I);[M:CSE1]SELFLD(W_I)
  If fstat = 0
    Call FLD_TXT("","",[M:CSE0]CFGLIN,[M:CSE1]SELFLDTXT(W_I)) From CFGLIB
  Endif
Next W_I
Return
############################################################
$MAJ_OPTVAR
Local Integer I
Delete [COV] Where SELNUM = [M:CSE0]SELNUM
If fstat
  Call FSTA("COV") From GLOCK
  GOK = 0
Endif
#
If GOK = 1
  For nolign = 1 To [M:CSE2]ITMREFNBR
    Raz [F:COV]
    [F:COV]          = [M:CSE2]
    [F:COV]SELNUM    = [M:CSE0]SELNUM
    [F:COV]SELSEQ    = nolign
    [F:COV]EXPNUM    = [C]EXPORT
    [F:COV]CREUSR    = GUSER
    [F:COV]CREDAT    = date$
    Write [COV]
    If fstat
      GOK = 0
      Call FSTA("Cov") From GLOCK
      Break
    Endif
    Call MAJTEXTRA([M:CSE2]ITMOPVAXX(nolign-1),"CFGOPTVAR","ITMOPVAXX",[F:COV]SELNUM,num$([F:COV]SELSEQ)) From ATEXTRA
  Next nolign
Endif
#
Return
############################################################
$GEN_ECRAN
Local Char WPAR(21)([M:CSE1]SELFLDNBR)
Local Integer W_I
If [M:CSE0]PAR001 = ""
  [M:CSE0]PAR001 = nomap
Endif
For W_I = 0 To [M:CSE1]SELFLDNBR-1
  WPAR(W_I) = [M:CSE1]SELTBL(W_I)+","+[M:CSE1]SELFLD(W_I)
Next W_I
If [M:CSE0]SELTYP = 1
  If [M:CSE1]SELFORNBR > 4
    Call GEN_SEL([M:CSE0]PAR001,"CFGSEL1","WUS"+[M:CSE0]SELNUM,[M:CSE1]SELLINNBR,[M:CSE1]SELQTY,
&               [M:CSE1]SELPRI,WPAR,[M:CSE0]CFGLIN,[M:CSE1]SELFOR) From CFGLIBA
  Else
    Call GEN_SEL([M:CSE0]PAR001,"CFGSEL","WUS"+[M:CSE0]SELNUM,[M:CSE1]SELLINNBR,[M:CSE1]SELQTY,
&               [M:CSE1]SELPRI,WPAR,[M:CSE0]CFGLIN,[M:CSE1]SELFOR) From CFGLIBA
  Endif
Else
  If find("",[M:CSE2]ITMREFLOA(0..[M:CSE2]ITMREFNBR-1))
    [M:CSE1]SELLINNBR = 999
  Else
    [M:CSE1]SELLINNBR = [M:CSE2]ITMREFNBR
  Endif
  Call GEN_SEL([M:CSE0]PAR001,"CFGOPV","WUS"+[M:CSE0]SELNUM,[M:CSE1]SELLINNBR,[M:CSE1]SELQTY,
&             [M:CSE1]SELPRI,WPAR,[M:CSE0]CFGLIN,[M:CSE1]SELFOR) From CFGLIBA
Endif
#
Return
############################################################
Subprog GEN_LABELS(LTAB,LNBR)
Variable Char    LTAB
Variable Decimal LNBR
Raz LTAB, LNBR
#
If [M:CSE0]SELTYP = 1
  Call QSTSEL([M:CSE0]SELNUM,LTAB,LNBR) From CFGLIBE
Else
  Call QSTOPV([M:CSE0]SELNUM,LTAB,LNBR) From CFGLIBE
Endif
End
############################################################
$ANNULE
Case [M:CSE0]SELTYP
  When 1       : Call PURCLN(4,[M:CSE0]SELNUM,0) From CFGLIBE
  When Default : Call PURCLN(5,[M:CSE0]SELNUM,0) From CFGLIBE
Endcase
Call DEL_WIN(nomap,"WUS"+[M:CSE0]SELNUM,"","") From CFGLIBA
Call DEL_WIN(nomap,"WUA"+[M:CSE0]SELNUM,"","") From CFGLIBA
Delete [AXX] Where CODFIC="CFGOPTVAR" & IDENT1=[M:CSE0]SELNUM
Delete [AXX] Where CODFIC="CFGSEL" & IDENT1=[M:CSE0]SELNUM
Return
############################################################
$ABANDON
#If GREP = "D"      # JPJ E26080
#  Rollback
#Endif
Return
############################################################
$FIN_ACTION     # JPJ E26080
If adxlog       # Protection sur Trbegin fait dans l'APRES_CHOI
  Rollback
Endif
Return
############################################################
$COP_ECRAN
Local Char WMSK(10)(3)
Local Char WABR(06)(3)
WMSK(0) = "CSE0"
Case [M:CSE0]SELTYP
  When 1 : WMSK(1) = "CSE1"
  When 2 : WMSK(1) = "CSE1OV"
           WMSK(2) = "CSE2"
Endcase
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return
############################################################
############################################################
Subprog COPIE(LPAR)
Value Char    LPAR
#
Local Char    W_SYM(10)(500)
Local Decimal W_NBR
#
Local Char    W_NUM(10)(300)
Local Integer W_TYP    (300)
Local Integer W_NBN
#
Local Char    W_FOR(250)
Local Char    W_TRA(100)
Local Char    W_EVA1(80)
Local Char    W_EVA2(80) 
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(111,188,1)-LPAR) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(110,188,1)+" : "+LPAR
  W_OK = 2
  zonsui = "DOSDES"  
  Call DIALWIN(W_OK,mess(111,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File APLSTD    [AST1]
  Local File TABLINCFG [TLP1] 
  Local File CFGQST    [CQU1]
  Local File CFGABQ    [CAB1]
  Local File CFGSEL    [CSE1]
  Local File CFGOPTVAR [COV1]
  Local File CFGMAC    [CFM1]
  Local File CFGSHA    [CSH1]
  Local File CBLOB     [CBB1]
  Local File TABCTL    [TCT1]
  Local File ATEXTRA   [AXX1]
Endif
# tables en ecriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".TABLINCFG" [TLP2]
  Local File =[M:DIA]DOSDES+".APLSTD"    [AST2]
  Local File =[M:DIA]DOSDES+".CFGQST"    [CQU2]
  Local File =[M:DIA]DOSDES+".CFGABQ"    [CAB2]
  Local File =[M:DIA]DOSDES+".CFGSEL"    [CSE2]
  Local File =[M:DIA]DOSDES+".CFGOPTVAR" [COV2]
  Local File =[M:DIA]DOSDES+".CFGMAC"    [CFM2]
  Local File =[M:DIA]DOSDES+".CFGSHA"    [CSH2]
  Local File =[M:DIA]DOSDES+".CBLOB"     [CBB2]
  Local File =[M:DIA]DOSDES+".TABCTL"    [TCT2]
  Local File =[M:DIA]DOSDES+".ITMMASTER" [ITM2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
Endif
# Contrôle copie possible (les elements existants doivent etre de meme nature)
Read [CSE1]CSE0=LPAR
If fstat 
  Goto COPIE_FIN
Endif
# Contrôle intitules lignes de produits
Filter [AST1] Where LANCHP = 760     &
&                   LAN    = GLANGUE &
&                   LANNUM > 0
&             Order By Key CLE
For [AST1]
  Read [AST2]CLE=[F:AST1]LANCHP;[F:AST1]LANNUM;[F:AST1]LAN
  If fstat
    W_TRA = mess(107,188,1)-num$([F:AST1]LANNUM)-mess(108,188,1)
    Call ECR_TRACE(W_TRA,0) From GESECRAN
  Else 
    If [F:AST1]LANMES <> [F:AST2]LANMES
      W_TRA = mess(107,188,1)-num$([F:AST1]LANNUM)-mess(109,188,1)
      Call ECR_TRACE(W_TRA,0) From GESECRAN
      W_TRA = "      ("+[F:AST1]LANMES+"/"+[F:AST2]LANMES+")" 
      Call ECR_TRACE(W_TRA,0) From GESECRAN
    Endif
  Endif
Next
Filter [AST1]
# Contrôle lignes de produits
Filter [TLP1]
For [TLP1]
  Read [TLP2]TLP0=[F:TLP1]CFGLIN
  If fstat = 0
    For W_I = 0 To dim([G:TLP1]adxfname)-1 
      If !find([G:TLP1]adxfname(W_I),"CREUSR","CREDAT","UPDUSR","UPDDAT","EXPNUM")
        W_EVA1 = "[F:TLP1]"+[G:TLP1]adxfname(W_I)
        W_EVA2 = "[F:TLP2]"+[G:TLP1]adxfname(W_I)
        If evalue("dim("+W_EVA1+")=1")
          If evalue(W_EVA1) <>  evalue(W_EVA2)
            W_TRA = [F:TLP1]CFGLIN-mess(106,188,1)-"("+[G:TLP1]adxfname(W_I)+")"
            W_ERR = 1
            Call ECR_TRACE(W_TRA,1) From GESECRAN
          Endif
        Else
          For W_J = 0 To evalue("dim("+W_EVA1+")-1")
            If evalue(W_EVA1+"("+num$(W_J)+")") <>  evalue(W_EVA2+"("+num$(W_J)+")")
              W_TRA = [F:TLP1]CFGLIN-mess(106,188,1)-"("+[G:TLP1]adxfname(W_I)+")"
              W_ERR = 1
              Call ECR_TRACE(W_TRA,1) From GESECRAN
            Endif
          Next W_J 
        Endif
      Endif 
    Next W_I
  Endif
Next
Filter [TLP1]
If W_ERR <> 0
  Goto COPIE_FIN
Endif
#
Raz W_SYM, W_NBR
# Lecture de la selections
Read [CSE1]CSE0=LPAR
If fstat = 0
  W_FOR = [F:CSE1]SELFIL 
  Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
  W_FOR = [F:CSE1]PRIFOR 
  Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
  For W_K = 0 To dim([F:CSE1]SELFOR)-1
    W_FOR = [F:CSE1]SELFOR(W_K)
    Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
  Next W_K
  For W_K = 0 To [F:CSE1]RULNBR-1
    W_FOR = [F:CSE1]RULCND(W_K)
    Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
  Next W_K 
  If [F:CSE1]SELTYP = 2
    Filter [COV1] Where SELNUM = [F:CSE1]SELNUM
    For [COV1]
      W_FOR = [F:COV1]ITMREFFOR
      Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      W_FOR = [F:COV1]ITMREFCAL
      Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      If [F:COV1]ITMREFLOA <> ""
        Read [ITM2]ITM0=[F:COV1]ITMREFLOA
        If fstat
          W_TRA = [F:COV1]ITMREFLOA-mess(97,188,1)
          Call ECR_TRACE(W_TRA,0) From GESECRAN
        Endif
      Endif
    Next 
    Filter [COV1]
  Endif
  If [F:CSE1]MACNUM <> ""
    Filter [CFM1] Where MACNUM = [F:CSE1]MACNUM
    For [CFM1]
      Case [F:CFM1]SYMTYP
        When 1, 2, 9 :
          W_FOR = W_PRS+[F:CFM1]SYMNUM
          Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      Endcase
      W_FOR = [F:CFM1]CNDFOR
      Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      W_FOR = [F:CFM1]FORFOR
      Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      If [F:CFM1]SYMTYP = 9
        If W_NBN < dim(W_NUM)-1
          W_NUM(W_NBN) = [F:CFM1]SYMNUM
          W_TYP(W_NBN) = [F:CFM1]SYMTYP
          W_NBN += 1
        Endif
      Endif
      If [F:CFM1]ABQVAL <> ""
        W_FOR = W_PRS+[F:CFM1]ABQVAL
        Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
        If W_NBN < dim(W_NUM)-1
          W_NUM(W_NBN) = [F:CFM1]ABQNUM
          W_TYP(W_NBN) = 0
          W_NBN += 1
        Endif
      Endif
      If [F:CFM1]ABQVALY <> ""
        W_FOR = W_PRS+[F:CFM1]ABQVALY
        Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
        If W_NBN < dim(W_NUM)-1
          W_NUM(W_NBN) = [F:CFM1]ABQNUM
          W_TYP(W_NBN) = 0
          W_NBN += 1
        Endif
      Endif
    Next
    Filter [CFM1] 
  Endif
Endif
# Traitement des formes
For W_I = 0 To W_NBN-1
  If W_TYP(W_I) = 9
    Filter [CSH1] Where SHACAT = W_NUM(W_I)
    For [CSH1]
      For W_K = 0 To [F:CSH1]SYMNBR-1
        W_FOR = W_PRS+[F:CSH1]SYMNUM(W_K)
        Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      Next W_K
#
      For W_K = 0 To [F:CSH1]VARNBR-1
        W_FOR = W_PRS+[F:CSH1]VARNUM(W_K)
        Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
        W_FOR = [F:CSH1]VARFOR(W_K)
        Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
      Next W_K
    Next 
  Endif
Next W_I
# Contrôle symboles memes caracteristiques si existant
For W_I = 0 To W_NBR-1
  Read [CQU1]CQU0=W_SYM(W_I)
  If fstat 
    W_TRA = W_SYM(W_I)-mess(90,188,1)
    W_ERR = 1
    Call ECR_TRACE(W_TRA,1) From GESECRAN
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT1]TCT0=[F:CQU1]TCT;1
    If fstat
      W_TRA = [F:CQU1]TCT-mess(104,188,1)
      W_ERR = 1
      Call ECR_TRACE(W_TRA,1) From GESECRAN
    Endif
  Endif
  Read [CQU2]CQU0=W_SYM(W_I)
  If fstat = 0
    If [F:CQU1]QSTTYP <> [F:CQU2]QSTTYP |
&      [F:CQU1]QSTORI <> [F:CQU2]QSTORI |
&      [F:CQU1]ASWTYP <> [F:CQU2]ASWTYP |
&      [F:CQU1]CTLTYP <> [F:CQU2]CTLTYP |
&      [F:CQU1]TCT    <> [F:CQU2]TCT 
      W_TRA = W_SYM(W_I)-mess(90,188,1)
      W_ERR = 1
      Call ECR_TRACE(W_TRA,1) From GESECRAN
    Endif
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT2]TCT0=[F:CQU1]TCT;1
    If fstat = 0
      If [F:TCT1]TCTTYP <> [F:TCT2]TCTTYP
        W_TRA = [F:CQU1]TCT-mess(103,188,1)
        W_ERR = 1
        Call ECR_TRACE(W_TRA,1) From GESECRAN
      Endif 
    Endif
  Endif
Next W_I
# Contrôle abaques memes caracteristiques si existant
For W_I = 0 To W_NBN-1
  If W_TYP(W_I) = 0
    Read [CAB1]CAB0=W_NUM(W_I);1
    If fstat
      W_TRA = W_SYM(W_I)-mess(92,188,1)
      W_ERR = 1
      Call ECR_TRACE(W_TRA,1) From GESECRAN
    Endif
    Read [CAB2]CAB0=W_NUM(W_I);1
    If fstat = 0
      If [F:CAB1]ABQTYP <> [F:CAB2]ABQTYP |
&        [F:CAB1]RESTYP <> [F:CAB2]RESTYP 
        W_TRA = W_SYM(W_I)-mess(93,188,1)
        W_ERR = 1
        Call ECR_TRACE(W_TRA,1) From GESECRAN
      Endif
    Endif
  Endif
Next W_I
If W_ERR <> 0
   Goto COPIE_FIN 
Endif
#
Read [CSE2]CSE0=LPAR
If fstat = 0
  W_OK = 2
  Call OUINON(mess(148,196,1),W_OK) From GESECRAN
  If W_OK <> 2
    Call OUVRE_TRACE(mess(111,188,1)-LPAR) From LECFIC
    Goto COPIE_FIN
  Endif
Endif
Gosub OUVDOS From ATEXTRA
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Call DEBTRANS    From GLOCK
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
$TRT_COPIE
Local Char    WAMK(GLONAMK) : # FQ 49403 GA 01/2009
Trbegin [CSE2]
Delete [CSE2] Where SELNUM = LPAR
Delete [COV2] Where SELNUM = LPAR

# Copie lignes de produits
Filter [TLP1]
For [TLP1]
  Read [TLP2]TLP0=[F:TLP1]CFGLIN
  If fstat 
    [F:TLP2] = [F:TLP1]
    [F:TLP2]CREUSR = GUSER
    [F:TLP2]CREDAT = date$
    [F:TLP2]UPDUSR = ""
    [F:TLP2]UPDDAT = [0/0/0]
    Write [TLP2]
    If fstat
      GOK = 0
      Call FSTA("TLP2") From GLOCK
      Goto AB_COPIE
    Endif
    Call COPTEXTRA("TABLINCFG","CFGLINAXX",[F:TLP1]CFGLIN,"") From ATEXTRA 

    # FQ 49403 copie fenêtre+écran - Ligne de produit
    WAMK = "WUL"+[F:TLP1]CFGLIN
    Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA

    W_TRA = mess(91,123,1)-mess(4,761,1)-[F:TLP2]CFGLIN
    Call ECR_TRACE(W_TRA,0) From GESECRAN
  Endif
Next
Filter [TLP1]
# Copie selection
Read [CSE1]CSE0=LPAR
If fstat
  GOK = 0
  Call FSTA("CSE1") From GLOCK
  Goto AB_COPIE
Else
  [F:CSE2] = [F:CSE1]
  [F:CSE2]CREUSR = GUSER
  [F:CSE2]CREDAT = date$
  [F:CSE2]UPDUSR = ""
  [F:CSE2]UPDDAT = [0/0/0]
  Write [CSE2]
  If fstat
    GOK = 0
    Call FSTA("CSE2") From GLOCK
    Goto AB_COPIE
  Endif
  Call COPTEXTRA("CFGCSE","SELAXX",[F:CSE1]SELNUM,"") From ATEXTRA 
 
  # FQ 49403 copie fenêtre+écran - Selection
  WAMK = "WUS"+[F:CSE1]SELNUM
  Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA
        
  # FQ 49403 copie fenêtre+écran - Réponses Selection
  WAMK = "WUA"+[F:CSE1]SELNUM
  Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA
  
  W_TRA = mess(91,123,1)-mess([F:CSE2]SELTYP+3,752,1)-[F:CSE2]SELNUM
  Call ECR_TRACE(W_TRA,0) From GESECRAN
Endif
If [F:CSE2]SELTYP = 2
  Filter [COV1] Where SELNUM = LPAR
&               Order By Key COV0
  For [COV1]
    [F:COV2] = [F:COV1]
    [F:COV2]CREUSR = GUSER
    [F:COV2]CREDAT = date$
    Write [COV2]
    If fstat
      GOK = 0
      Call FSTA("COV2") From GLOCK
      Break
    Endif
    Call COPTEXTRA("CFGOPTVAR","ITMOPVAXX",[F:COV1]SELNUM,num$([F:COV1]SELSEQ)) From ATEXTRA 
  Next
  Filter [COV1]
Endif
If GOK <> 1
  Goto AB_COPIE
Endif
# Copie procedure
If [F:CSE1]MACNUM <> ""
  Read [CFM2]CFM0=W_NUM(W_I);1
  If fstat 
    Filter [CFM1] Where MACNUM = W_NUM(W_I)
    For [CFM1]    
      [F:CFM2] = [F:CFM1]
      [F:CFM2]CREUSR = GUSER
      [F:CFM2]CREDAT = date$
      [F:CFM2]UPDUSR = ""
      [F:CFM2]UPDDAT = [0/0/0]
      Write [CFM2]
      If fstat
        GOK = 0
        Call FSTA("CFM2") From GLOCK
        Break
      Endif
      If [F:CFM2]MACLIN = 1
        Call COPTEXTRA("CFGMAC","MACAXX",[F:CFM1]MACNUM,"") From ATEXTRA 

        # FQ 49403 copie fenêtre+écran - Procédure
        WAMK = "WUI"+[F:CFM1]MACNUM
        Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA

        W_TRA = mess(91,123,1)-mess(7,752,1)-[F:CFM2]MACNUM
        Call ECR_TRACE(W_TRA,0) From GESECRAN
      Endif 
      Call COPTEXTRA("CFGMAC","TXTAXX",[F:CFM1]MACNUM,num$([F:CFM1]MACLIN)) From ATEXTRA 
    Next
    Filter [CFM1] 
  Endif
Endif 
If GOK <> 1
  Goto AB_COPIE
Endif
# Copie abaques
For W_I = 0 To W_NBN-1
  If W_TYP(W_I) = 0
    Read [CAB2]CAB0=W_NUM(W_I);1
    If fstat 
      Filter [CAB1] Where ABQNUM = W_NUM(W_I)
      For [CAB1]    
        [F:CAB2] = [F:CAB1]
        [F:CAB2]CREUSR = GUSER
        [F:CAB2]CREDAT = date$
        [F:CAB2]UPDUSR = ""
        [F:CAB2]UPDDAT = [0/0/0]
        Write [CAB2]
        If fstat
          GOK = 0
          Call FSTA("CAB2") From GLOCK
          Break
        Endif
        If [F:CAB2]ABQLIN = 1
          Call COPTEXTRA("CFGABQ","ABQAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
          Call COPTEXTRA("CFGABQ","ABSAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
          Call COPTEXTRA("CFGABQ","ORDAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
          Call COPTEXTRA("CFGABQ","RESAXX",[F:CAB1]ABQNUM,"") From ATEXTRA 
          W_TRA = mess(91,123,1)-mess(78,188,1)-[F:CAB2]ABQNUM
          Call ECR_TRACE(W_TRA,0) From GESECRAN
        Endif
      Next
      Filter [CAB1] 
    Endif
  Endif 
Next W_I
If GOK <> 1
  Goto AB_COPIE
Endif
# Copie formes / modeles
For W_I = 0 To W_NBN-1
  If W_TYP(W_I) = 9
    Filter [CSH1] Where SHACAT = W_NUM(W_I)
    For [CSH1]    
      Read [CSH2]CSH0=[F:CSH1]SHACAT;[F:CSH1]SHANUM
      If fstat 
        [F:CSH2] = [F:CSH1]
        [F:CSH2]CREUSR = GUSER
        [F:CSH2]CREDAT = date$
        [F:CSH2]UPDUSR = ""
        [F:CSH2]UPDDAT = [0/0/0]
        Write [CSH2]
        If fstat
          GOK = 0
          Call FSTA("CSH2") From GLOCK
          Break
        Endif
        Call COPTEXTRA("CFGSHA","SHACATAXX",[F:CSH1]SHACAT,[F:CSH1]SHANUM) From ATEXTRA 
        Call COPTEXTRA("CFGSHA","SHANUMAXX",[F:CSH1]SHACAT,[F:CSH1]SHANUM) From ATEXTRA 
        Read [CBB1]CBB0="CSH";[F:CSH1]SHACAT;[F:CSH1]SHANUM
        If !fstat
            Read [CBB2]CBB0="CSH";[F:CSH1]SHACAT;[F:CSH1]SHANUM
            If fstat
                [F:CBB2] = [F:CBB1]
                Raz [F:CBB2]UPDUSR, [F:CBB2]UPDDAT, [F:CBB2]UPDTIM
                #Call ECRCBB From TRTX3BLB # utilise le buffer [F:CBB]
                [F:CBB2]CREUSR = GUSER
                [F:CBB2]CREDAT = date$
                Write [CBB2]
                If fstat
                   GOK = 0
                   Call FSTA("CBB2") From GLOCK
                   Break
                Endif
            Endif
        Endif

        # FQ 49403 copie fenêtre+écran - Réponses formes & modèles
        WAMK = "WUF"+[F:CSH1]SHACAT+[F:CSH1]SHANUM
        Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA
        
        W_TRA = mess(91,123,1)-mess(9,752,1)-[F:CSH2]SHACAT-[F:CSH2]SHANUM
        Call ECR_TRACE(W_TRA,0) From GESECRAN
      Endif
    Next
    Filter [CSH1] 
  Endif 
Next W_I
If GOK <> 1
  Goto AB_COPIE
Endif
# Copie symboles
For W_I = 0 To W_NBR-1
  Read [CQU1]CQU0=W_SYM(W_I)
  If fstat
    GOK = 0
    Call FSTA("CQU1") From GLOCK
    Break
  Endif
  Read [CQU2]CQU0=W_SYM(W_I)
  If fstat
    [F:CQU2] = [F:CQU1]
    [F:CQU2]CREUSR = GUSER
    [F:CQU2]CREDAT = date$
    [F:CQU2]UPDUSR = ""
    [F:CQU2]UPDDAT = [0/0/0]
    Write [CQU2] 
    If fstat
      GOK = 0
      Call FSTA("CQU2") From GLOCK
      Break
    Endif
    W_TRA = mess(91,123,1)-mess([F:CQU2]QSTTYP,752,1)-[F:CQU2]QSTNUM
    Call ECR_TRACE(W_TRA,0) From GESECRAN
    Call COPTEXTRA("CFGQST","QSTAXX",[F:CQU1]QSTNUM,"") From ATEXTRA 
    Read [CBB1]CBB0="CQU";[F:CQU1]QSTNUM;""
    If !fstat
        Read [CBB2]CBB0="CQU";[F:CQU1]QSTNUM;""
        If fstat
            [F:CBB2] = [F:CBB1]
            Raz [F:CBB2]UPDUSR, [F:CBB2]UPDDAT, [F:CBB2]UPDTIM
            #Call ECRCBB From TRTX3BLB # utilise le buffer [F:CBB]
            [F:CBB2]CREUSR = GUSER
            [F:CBB2]CREDAT = date$
            Write [CBB2]
            If fstat
               GOK = 0
               Call FSTA("CBB2") From GLOCK
               Break
            Endif
        Endif
    Endif
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT2]TCT0=[F:CQU1]TCT;1
    If fstat
      Filter [TCT1] Where TCT = [F:CQU1]TCT
      For [TCT1]
        [F:TCT2] = [F:TCT1]
        [F:TCT2]CREUSR = GUSER
        [F:TCT2]CREDAT = date$
        [F:TCT2]UPDUSR = ""
        [F:TCT2]UPDDAT = [0/0/0]
        Write [TCT2] 
        If fstat
          GOK = 0
          Call FSTA("TCT2") From GLOCK
          Break
        Endif
        If [F:TCT2]TCTLIN = 1
          W_TRA = mess(91,123,1)-mess(105,188,1)-[F:TCT2]TCT
          Call ECR_TRACE(W_TRA,0) From GESECRAN
        Endif
      Next
      Filter [TCT1]
    Endif
  Endif   
Next W_I
If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return
############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return
############################################################
Subprog AS_SELNUM(VALEUR)
Variable Char    VALEUR()
Case GFONC1
  When "GESCSE" : 
    [M:CSE0]SELTYP = 1
  When "GESCOV" :
    [M:CSE0]SELTYP = 2
Endcase  
End
############################################################
Subprog C_SELNUM(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"/")
  mkstat = 2
Endif
End
