############################################################
Subprog C_ITMREFLOA(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Call UNICITE(VALEUR,[M:CSE2]ITMREFLOA(0..[M:CSE2]ITMREFNBR-1)) From OBJDIV
  If mkstat = 0
    Read [ITM]ITM0=VALEUR
    If fstat
      Raz [F:ITM]
      mkstat = 2
    Endif
    Read [TLP]TLP0=[F:ITM]CFGLIN
    If fstat
      Raz [F:TLP]
    Endif
    #[M:CSE2]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CSE2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:CSE2]CFGLINNUM(nolign-1)  = [F:TLP]CFGLIN
    Call GET_ATEXTRA("TABLINCFG","CFGLINAXX",GLANGUE,[M:CSE2]CFGLINAXX(nolign-1)) From TRTX3TEX
  Endif
Else
  [M:CSE2]ITMDES1(nolign-1)   = ""
  [M:CSE2]CFGLINNUM(nolign-1) = ""
  [M:CSE2]CFGLINAXX(nolign-1) = ""
Endif
Affzo [M:CSE2]ITMDES1(nolign-1)
Affzo [M:CSE2]CFGLINNUM(nolign-1)
Affzo [M:CSE2]CFGLINAXX(nolign-1)
End
