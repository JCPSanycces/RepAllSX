Subprog AM_RUL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:CSE2]RULOPT2(nolign-1)    = 0
  [M:CSE2]RULOPTTXT2(nolign-1) = ""
  Affzo [M:CSE2]RULOPT2(nolign-1)
  Affzo [M:CSE2]RULOPTTXT2(nolign-1)
Endif
End
