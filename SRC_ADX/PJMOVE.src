#######################################################################################
Funprog TAS_GET_PARENTS(SOPPNUM, STASCOD, STBCODE)
Value Char SOPPNUM ()
Value Char STASCOD ()
Variable Char STBCODE ()(1..)

Local Integer ARET_VALUE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array
Local Integer INBTAB

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Call LOAD_FILTER(SFILTER)            # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  # -------------------
  Gosub LOCAL_FILE_PJMTSK From PJMOVE
  # -------------------
  Raz STBCODE
  INBTAB = 0
  Repeat
    Filter [PJTA] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]TASCOD = STASCOD
    Read [PJTA]First
    If !fstat Then
      INBTAB += 1
      STBCODE(INBTAB) = [F:PJTA]TASCOD
      STASCOD = [F:PJTA]TASPAE
    Endif
    Filter [PJTA]
  Until fstat or STASCOD = AVOID.ACHAR
End ARET_VALUE

#######################################################################################
Funprog TAS_CHECK_IF_FAMILY_DISPLAY(SOPPNUM, STASCOD)
Value Char SOPPNUM
Value Char STASCOD

Local Char SFILTER(250)(0..)
Local Char SFILTER1(250)(0..)
Local Integer IARENDRE
Local Integer ITBTASCOD
Local Char STBTASCOD(GLONTAC)(1..)
Local Integer NI

  # Issue X3-91018 - 2018-05-21 by TEJAC/FGR
  IARENDRE = [V]CST_ANO
  ITBTASCOD = 0
  # -------------------------
  Call LOAD_FILTER(SFILTER)
  Call GET_PJMTAS_FILTER(SFILTER1)
  # -------------------------
  Gosub LOCAL_FILE_PJMTSK
  #
  Local File PJMTSKCAT [PTC]
  Link [F:PJTA] With [F:PTC]CTA0=[F:PJTA]TCACOD As [LNK]
  # -------------------------
  Filter [LNK] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]TASPAE = STASCOD
  For [LNK]
    If evalue(SFILTER1) Then
      IARENDRE = [V]CST_AYES
      Break
    Else
      ITBTASCOD += 1
      STBTASCOD(ITBTASCOD) = [F:PJTA]TASCOD
    Endif
  Next
  Filter [LNK]
  # -------------------------
  LogicClose File [PJTA]
  LogicClose File [PTC]
  # -------------------------
  If IARENDRE = [V]CST_ANO Then
    For NI = 1 To ITBTASCOD
      IARENDRE = func TAS_CHECK_IF_FAMILY_DISPLAY(SOPPNUM, STBTASCOD(NI))
      If IARENDRE = [V]CST_AYES Then
        Break
      Endif
    Next NI
  Endif
  # -------------------------
End IARENDRE

