#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Mask management PJMOVE0
# Issue X3-68131 - 2018-02-12 by FGR : 1°) work without class but with [F]
#######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "BOUTON"       : Gosub BOUTON
    When "TITRE"        : Gosub TITLE     # Issue X3-76891 - 2018-03-26 by TEJAC
    When Default
  Endcase
Return

#######################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

#######################################################################################
$DEBUT
  [M:POV0]CALLBY = AVOID.ACHAR
  Raz [M:POV0]OPPNUM
  [M:POV0]KEYEXT = PARAM(2)       # Issue X3-76891 - 2018-03-27 by TEJAC
  If PARAM(1) <> AVOID.ACHAR Then
    [M:POV0]CALLBY = "PJM"
    Grizo [M:POV0]OPPNUM
    Call LOAD_SCREEN_DEFAULT(PARAM(1))
    If GERR = 1 Then
      FIN = 1
      Return
    Endif
    Call LOAD_PAGE()
  Endif
Return

#######################################################################################
$BOUTON
  Case BOUT
    When "1"
      Call LOAD_PAGE()
  Endcase
Return

#######################################################################################
$TITLE
  # Issue X3-76891 - 2018-03-26 by TEJAC
  If PARAM(2) <> AVOID.ACHAR Then
    TIT = func SUBPJMOPSNP.GET_KEYEXT_DESC(PARAM(2))
  Endif
Return

#######################################################################################
## Screen POV0
#######################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  Call LOAD_SCREEN_DEFAULT(VALEUR)
  If [M:POV0]TIMUOM = AVOID.ACHAR Then
    GMESSAGE = func AFNC.MES1(mess(398,2260,1), GET_FCY_VALUE(GACTX, [M:POV0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE))
    GERR = 1
    Effzo [M:POV1]
    End
  Endif
  Call LOAD_PAGE()
End

#######################################################################################
Subprog AM_BUD(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_ANO Then
    [M:POV0]BUDLIN = [V]CST_ANO
    Grizo [M:POV0]BUDLIN
    Grizo [M:POV0]PBUSTATE  # Issue X3-91018 - 2018-05-17 by TEJAC
  Else
    Actzo [M:POV0]BUDLIN
    Actzo [M:POV0]PBUSTATE  # Issue X3-91018 - 2018-05-17 by TEJAC
  Endif
  Affzo [M:POV0]BUDLIN
  Affzo [M:POV0]PBUSTATE    # Issue X3-91018 - 2018-05-17 by TEJAC
End

#######################################################################################
Subprog AM_TAS(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_ANO Then
    [M:POV0]OPE = [V]CST_ANO
    [M:POV0]OPELIN = [V]CST_ANO
    [M:POV0]ITMFLG = [V]CST_ANO
    [M:POV0]DISPLAY = [V]CST_ANO
    [M:POV0]ITMAVA = [V]CST_ANO
    Grizo [M:POV0]OPE
    Grizo [M:POV0]OPELIN
    Grizo [M:POV0]ITMFLG
    Grizo [M:POV0]DISPLAY
    Grizo [M:POV0]ITMAVA
    # Issue X3-91018 - 2018-05-18 by TEJAC : START
    Grizo [M:POV0]TASSTATE
    Grizo [M:POV0]TCACOD
    Grizo [M:POV0]TASPROGF
    Grizo [M:POV0]TASPROGT
    Grizo [M:POV0]TASSTARTDAT
    Grizo [M:POV0]TASENDDT
    Grizo [M:POV0]DUEDATF
    Grizo [M:POV0]DUEDATT
    Grizo [M:POV0]PRCCPLADI
    Grizo [M:POV0]TASPIMTYP
    # Issue X3-91018 - 2018-05-18 by TEJAC : END
  Else
    Actzo [M:POV0]OPE
    Actzo [M:POV0]ITMFLG
    # Issue X3-91018 - 2018-05-18 by TEJAC : START
    Actzo [M:POV0]TASSTATE
    Actzo [M:POV0]TCACOD
    Actzo [M:POV0]TASPROGF
    Actzo [M:POV0]TASPROGT
    Actzo [M:POV0]TASSTARTDAT
    Actzo [M:POV0]TASENDDT
    Actzo [M:POV0]DUEDATF
    Actzo [M:POV0]DUEDATT
    Actzo [M:POV0]PRCCPLADI
    Actzo [M:POV0]TASPIMTYP
    # Issue X3-91018 - 2018-05-18 by TEJAC : END
  Endif
  Affzo [M:POV0]OPE
  Affzo [M:POV0]OPELIN
  Affzo [M:POV0]ITMFLG
  Affzo [M:POV0]DISPLAY
  Affzo [M:POV0]ITMAVA
  # Issue X3-91018 - 2018-05-18 by TEJAC : START
  Affzo [M:POV0]TASSTATE
  Affzo [M:POV0]TCACOD
  Affzo [M:POV0]TASPROGF
  Affzo [M:POV0]TASPROGT
  Affzo [M:POV0]TASSTARTDAT
  Affzo [M:POV0]DUEDATF
  Affzo [M:POV0]DUEDATT
  Affzo [M:POV0]PRCCPLADI
  Affzo [M:POV0]TASENDDT
  Affzo [M:POV0]TASPIMTYP
  # Issue X3-91018 - 2018-05-18 by TEJAC : END
End

#######################################################################################
Subprog AM_OPE(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_ANO Then
    [M:POV0]OPELIN = [V]CST_ANO
    Diszo [M:POV0]OPELIN
  Else
    Actzo [M:POV0]OPELIN
  Endif
  Affzo [M:POV0]OPELIN
End

#######################################################################################
Subprog AM_ITMFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_ANO Then
    [M:POV0]DISPLAY = [V]CST_ANO
    [M:POV0]ITMAVA = [V]CST_ANO
    Diszo [M:POV0]DISPLAY
    Diszo [M:POV0]ITMAVA
  Else
    Actzo [M:POV0]DISPLAY
    Actzo [M:POV0]ITMAVA
  Endif
  Affzo [M:POV0]DISPLAY
  Affzo [M:POV0]ITMAVA
End

#######################################################################################
Subprog C_TIMUOM(VALEUR)
Variable Char    VALEUR()

Local Integer IUOMTYP

  IUOMTYP = fmet GACTX.ACACHE.ATUN.AGETVALNUM(VALEUR, "UOMTYP")
  If IUOMTYP <> 5 Then
    GMESSAGE = mess(190,2260,1)
    GOK = 0
    GERR = 1
    End
  Endif
End

######################################################################################
Subprog AM_TCACOD(VALEUR)
Variable Char    VALEUR()

  # Issue X3-91018 - 2018-06-11 by TEJAC
  If VALEUR <> AVOID.ACHAR Then
    [M:POV0]TASPIMTYP = 1
    Diszo [M:POV0]TASPIMTYP
  Else
    Actzo [M:POV0]TASPIMTYP
  Endif
  Affzo [M:POV0]TASPIMTYP
End

######################################################################################
Subprog AM_TASPIMTYP(VALEUR)
Variable Integer VALEUR

  # Issue X3-91018 - 2018-05-22 by TEJAC
  If [M:POV0]TCACOD <> AVOID.ACHAR and VALEUR > 1 Then
    Diszo [M:POV0]TCACOD
  Else
    Actzo [M:POV0]TCACOD
  Endif
  Affzo [M:POV0]TCACOD
End

######################################################################################
Subprog AM_TASPROGF(VALEUR)
Variable Decimal VALEUR

  # Issue X3-91018 - 2018-05-22 by TEJAC
  If VALEUR < 0 or VALEUR > 100 Then
    GMESSAGE = mess(981,2260,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  # --------------------------
  If VALEUR > 0 and [M:POV0]TASPROGT = 0 Then
    [M:POV0]TASPROGT = VALEUR
  Endif
End

######################################################################################
Subprog AM_TASPROGT(VALEUR)
Variable Decimal VALEUR

  # Issue X3-91018 - 2018-05-22 by TEJAC
  If VALEUR < 0 or VALEUR > 100 Then
    GMESSAGE = mess(981,2260,1)
    GERR = 1
    mkstat = 2
    End
  Endif
End

######################################################################################
Subprog AM_PRCCPLADI(VALEUR)
Variable Char    VALEUR()

Local Integer ITODO

  # Issue X3-91018 - 2018-05-22 by TEJAC
  Local File ATABDIV[ADI]
  # --------------------------
  ITODO = [V]CST_AYES
  If VALEUR <> AVOID.ACHAR Then
    Read [ADI]CODE=387;VALEUR
    If not ([M:POV0]TASPROGF >= [F:ADI]N1 and (([F:ADI]N2 < 100 and [M:POV0]TASPROGF < [F:ADI]N2) or ([F:ADI]N2 = 100 and [M:POV0]TASPROGF <= [F:ADI]N2))) Then
      [M:POV0]TASPROGF = [F:ADI]N1
      [M:POV0]TASPROGT = [F:ADI]N2
      ITODO = [V]CST_ANO
    Endif
  Endif
  # --------------------------
  If ITODO = [V]CST_AYES Then
    Filter [ADI] Where [F:ADI]NUMTAB = 387
    For [ADI]CODE
      If [M:POV0]TASPROGF >= [F:ADI]N1 and (([F:ADI]N2 < 100 and [M:POV0]TASPROGF < [F:ADI]N2) or ([F:ADI]N2 = 100 and [M:POV0]TASPROGF <= [F:ADI]N2)) Then
        [M:POV0]TASPROGF = [F:ADI]N1
        [M:POV0]TASPROGT = [F:ADI]N2
        Break
      Endif
    Next
    Filter [ADI]
  Endif
  # --------------------------
  Affzo [M:POV0]TASPROGF
  Affzo [M:POV0]TASPROGT
End

######################################################################################
Subprog AM_DUEDATF(VALEUR)
Variable Date    VALEUR

  # Issue X3-91018 - 2018-05-23 by TEJAC
  If [M:POV0]DUEDATT <> AVOID.ADATE Then
    If [M:POV0]DUEDATT < VALEUR Then
      [M:POV0]DUEDATT = VALEUR
    Endif
  Endif
End

######################################################################################
Subprog AM_DUEDATT(VALEUR)
Variable Date    VALEUR

  # Issue X3-91018 - 2018-05-23 by TEJAC
  If [M:POV0]DUEDATF <> AVOID.ADATE Then
    If [M:POV0]DUEDATF > VALEUR Then
      GMESSAGE = mess(1084,2260,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

