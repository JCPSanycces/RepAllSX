#######################################################################################
Subprog LOAD_TREEVIEW_TAS_ITM(NE, ISAV_NE)
Variable Integer NE
Value Integer ISAV_NE

Local Integer SAV_NE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array
Local Integer IFIRST

  If [M:POV0]ITMFLG = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
    # --------------------------
    Gosub LOCAL_FILE_PJMTSKITM
    # --------------------------
    IFIRST = [V]CST_AYES
    Filter [JTT] Where evalue(SFILTER) and [F:JTT]OPPNUM = [F:PJTA]OPPNUM and [F:JTT]TASCOD = [F:PJTA]TASCOD
    For [JTT]
      If IFIRST = [V]CST_AYES Then
        IFIRST = [V]CST_ANO
        SAV_NE = ISAV_NE
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + mess(507,2260,1)
        [M:POV1]OBJDES(NE) = mess(507,2260,1)
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]PSDLVL(NE) = [V]CST_AYES
        SAV_NE = NE
      Endif
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        Break
      Endif
      [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + num$([F:JTT]ITTSEQ)
      [M:POV1]OBJDES(NE)    = [F:JTT]ITMREF - func JTT_GET_ITMDES1([F:JTT]OPPNUM, [F:JTT]TASCOD, [F:JTT]ITTSEQ)
      [M:POV1]EXPFLG(NE)    = [V]CST_ANO
      [M:POV1]ICO(NE)       = "261.png"
      [M:POV1]PIMTYP(NE)    = [F:PIM]PIMTYP
      [M:POV1]PIMSTA(NE)    = [F:PIM]PIMSTA
      [M:POV1]STATE(NE)     = [F:PJTA]TASSTATE
      [M:POV1]TASCOD(NE)    = [F:PJTA]TASCOD
      [M:POV1]FCY(NE)       = [F:PJTA]TASFCY
      [M:POV1]TASNUM(NE)    = [F:PJTA]TASNUM
      [M:POV1]KEYCONCAT(NE) = [F:PJTA]KEYCONCAT
      [M:POV1]ITMREF(NE)    = [F:JTT]ITMREF
      [M:POV1]QTY(NE)       = [F:JTT]ITTQTY
      [M:POV1]UOM(NE)       = [F:JTT]UOM
      [M:POV1]ORI(NE)       = "T"
      Call CMT_LOAD_TREEVIEW_TAS_ITM(NE)
      Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), 0, AVOID.ACHAR, 0,
&                     [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
      Call LOAD_TREEVIEW_TAS_ITM_ORDERS(NE, NE)
    Next
  Endif
End

#######################################################################################
Subprog LOAD_TREEVIEW_TAS_ITM_ORDERS(NE, ISAV_NE)
Variable Integer NE
Variable Integer ISAV_NE

Local Integer SAV_NE

  If [M:POV0]ITMAVA = [V]CST_AYES Then
    If GMODU(8) = [V]CST_AYES Then
      # If manufacturing module
      Local File VPJMAVADATMF [PJAVDA]
    Else
      # If not
      Local File VPJMAVADAT [PJAVDA]
    Endif
    # --------------------------
    If func PJMAVADAT.IS_AVADAT_RECORD_EXIST(GACTX, [F:JTT]OPPNUM, [F:JTT]TASCOD, [F:JTT]ITMREF, 1) = [V]CST_AYES Then
      # Purchase order
      SAV_NE = ISAV_NE
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        End
      Endif
      [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~1"
      [M:POV1]OBJDES(NE) = mess(1,7725,1)
      [M:POV1]EXPFLG(NE) = [V]CST_ANO
      [M:POV1]PSDLVL(NE) = [V]CST_AYES
      SAV_NE = NE
      # --------------------------
      Filter [PJAVDA] Where [F:PJAVDA]OPPNUM = [F:JTT]OPPNUM and [F:PJAVDA]TASCOD = [F:JTT]TASCOD and [F:PJAVDA]ITMREF = [F:JTT]ITMREF Order By [F:PJAVDA]DAT Desc
      For [PJAVDA]
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + [F:PJAVDA]POHNUM
        [M:POV1]OBJDES(NE) = [F:PJAVDA]POHNUM
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]ICO(NE)    = "produitsoustraite.gif"
        [M:POV1]STATE(NE)  = [F:PJTA]TASSTATE
        [M:POV1]TASCOD(NE) = [F:PJAVDA]TASCOD
        [M:POV1]ITMREF(NE) = [F:PJAVDA]ITMREF
        [M:POV1]QTY(NE)    = [F:PJAVDA]QTY
        [M:POV1]UOM(NE)    = [F:PJAVDA]UOM
        [M:POV1]AOB(NE)    = [F:PJAVDA]AOB
        [M:POV1]POHNUM(NE) = [F:PJAVDA]POHNUM
        [M:POV1]POPLIN(NE) = [F:PJAVDA]POPLIN
        [M:POV1]POQSEQ(NE) = [F:PJAVDA]POQSEQ
        [M:POV1]KEYCOD(NE) = [M:POV1]POHNUM(NE)
        [M:POV1]AOBCOD(NE) = "POH"
        [M:POV1]STA(NE)    = [F:PJAVDA]STA
        Case [M:POV1]AOB(NE)
          When 1
            # Purchase orders
            Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]AOB(NE), [M:POV1]POHNUM(NE), [M:POV1]POPLIN(NE),
&                           [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
          When 2
            # Work orders
            Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]AOB(NE), [M:POV1]MFGNUM(NE), [M:POV1]MFGLIN(NE),
&                           [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
          When 3
            # Sub-contracts
            Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]AOB(NE), [M:POV1]SCONUM(NE), [M:POV1]SCILIN(NE),
&                           [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Endcase
        Call SET_AVADATSTA([M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Call CMT_LOAD_TREEVIEW_TAS_ITM_ORDERS(NE)
      Next
      Filter [PJAVDA]
    Endif
    # --------------------------
    If func PJMAVADAT.IS_AVADAT_RECORD_EXIST(GACTX, [F:JTT]OPPNUM, [F:JTT]TASCOD, [F:JTT]ITMREF, 2) = [V]CST_AYES Then
      # Work orders
      SAV_NE = ISAV_NE
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        End
      Endif
      [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~2"
      [M:POV1]OBJDES(NE) = mess(2,7725,1)
      [M:POV1]EXPFLG(NE) = [V]CST_ANO
      [M:POV1]PSDLVL(NE) = [V]CST_AYES
      SAV_NE = NE
      # --------------------------
      Filter [PJAVDA] Where [F:PJAVDA]OPPNUM = [F:JTT]OPPNUM and [F:PJAVDA]TASCOD = [F:JTT]TASCOD and [F:PJAVDA]ITMREF = [F:JTT]ITMREF Order By [F:PJAVDA]DAT Desc
      For [PJAVDA]
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + [F:PJAVDA]MFGNUM
        [M:POV1]OBJDES(NE) = [F:PJAVDA]MFGNUM
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]ICO(NE)    = "produitsoustraite.gif"
        [M:POV1]STATE(NE)  = [F:PJTA]TASSTATE
        [M:POV1]TASCOD(NE) = [F:PJAVDA]TASCOD
        [M:POV1]ITMREF(NE) = [F:PJAVDA]ITMREF
        [M:POV1]QTY(NE)    = [F:PJAVDA]QTY
        [M:POV1]UOM(NE)    = [F:PJAVDA]UOM
        [M:POV1]AVADAT(NE) = [F:PJAVDA]DAT
        [M:POV1]AOB(NE)    = [F:PJAVDA]AOB
        [M:POV1]MFGNUM(NE) = [F:PJAVDA]MFGNUM
        [M:POV1]MFGLIN(NE) = [F:PJAVDA]MFGLIN
        [M:POV1]KEYCOD(NE) = [M:POV1]MFGNUM(NE)
        [M:POV1]AOBCOD(NE) = "MFG"
        [M:POV1]STA(NE)    = [F:PJAVDA]STA
        Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]AOB(NE), [M:POV1]MFGNUM(NE), [M:POV1]MFGLIN(NE),
&                       [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Call SET_AVADATSTA([M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Call CMT_LOAD_TREEVIEW_TAS_ITM_ORDERS(NE)
      Next
      Filter [PJAVDA]
    Endif
    # --------------------------
    If func PJMAVADAT.IS_AVADAT_RECORD_EXIST(GACTX, [F:JTT]OPPNUM, [F:JTT]TASCOD, [F:JTT]ITMREF, 3) = [V]CST_AYES Then
      # Sub-contract orders
      SAV_NE = ISAV_NE
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        End
      Endif
      [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~3"
      [M:POV1]OBJDES(NE) = mess(3,7725,1)
      [M:POV1]EXPFLG(NE) = [V]CST_ANO
      [M:POV1]PSDLVL(NE) = [V]CST_AYES
      SAV_NE = NE
      # --------------------------
      Filter [PJAVDA] Where [F:PJAVDA]OPPNUM = [F:JTT]OPPNUM and [F:PJAVDA]TASCOD = [F:JTT]TASCOD and [F:PJAVDA]ITMREF = [F:JTT]ITMREF Order By [F:PJAVDA]DAT Desc
      For [PJAVDA]
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + [F:PJAVDA]SCONUM
        [M:POV1]OBJDES(NE) = [F:PJAVDA]SCONUM
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]ICO(NE)    = "produitsoustraite.gif"
        [M:POV1]STATE(NE)  = [F:PJTA]TASSTATE
        [M:POV1]TASCOD(NE) = [F:PJAVDA]TASCOD
        [M:POV1]ITMREF(NE) = [F:PJAVDA]ITMREF
        [M:POV1]QTY(NE)    = [F:PJAVDA]QTY
        [M:POV1]UOM(NE)    = [F:PJAVDA]UOM
        [M:POV1]AOB(NE)    = [F:PJAVDA]AOB
        [M:POV1]SCONUM(NE) = [F:PJAVDA]SCONUM
        [M:POV1]SCILIN(NE) = [F:PJAVDA]SCILIN
        [M:POV1]KEYCOD(NE) = [M:POV1]SCONUM(NE)
        [M:POV1]AOBCOD(NE) = "SCO"
        [M:POV1]STA(NE)    = [F:PJAVDA]STA
        Call GET_AVADAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]AOB(NE), [M:POV1]SCONUM(NE), [M:POV1]SCILIN(NE),
&                       [M:POV1]AVADAT(NE), [M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Call SET_AVADATSTA([M:POV1]AVADATSTA(NE)) From PJMAVADAT
        Call CMT_LOAD_TREEVIEW_TAS_ITM_ORDERS(NE)
      Next
      Filter [PJAVDA]
    Endif
  Endif
End

#######################################################################################
Subprog LOAD_TREEVIEW_TAS_OPE(NE, ISAV_NE)
Variable Integer NE
Value Integer ISAV_NE

Local Integer SAV_NE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array
Local Integer IFIRST

  If [M:POV0]OPE = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
    # --------------------------
    Gosub LOCAL_FILE_PJMTSKOPE
    # --------------------------
    IFIRST = [V]CST_AYES
    Filter [PTKO] Where evalue(SFILTER) and [F:PTKO]OPPNUM = [F:PJTA]OPPNUM and [F:PTKO]TASCOD = [F:PJTA]TASCOD
    For [PTKO]
      If IFIRST = [V]CST_AYES Then
        IFIRST = [V]CST_ANO
        SAV_NE = ISAV_NE
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + mess(508,2260,1)
        [M:POV1]OBJDES(NE) = mess(508,2260,1)
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]PSDLVL(NE) = [V]CST_AYES
        SAV_NE = NE
      Endif
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        Break
      Endif
      [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + num$([F:PTKO]OPENUM)
      [M:POV1]OBJDES(NE)    = num$([F:PTKO]OPENUM) - ":" - func PTKO_GET_ROODESAXX([F:PTKO]OPPNUM, [F:PTKO]TASCOD, [F:PTKO]OPENUM, [F:PTKO]OPESPLNUM)
      [M:POV1]EXPFLG(NE)    = [V]CST_ANO
      [M:POV1]TASCOD(NE)    = [F:PTKO]TASCOD
      [M:POV1]OPENUM(NE)    = [F:PTKO]OPENUM
      [M:POV1]STATE(NE)     = [F:PTKO]OPESTA
      [M:POV1]ICO(NE)       = "263.png"
      [M:POV1]OPESPLNUM(NE) = [F:PTKO]OPESPLNUM
      [M:POV1]PIMTYP(NE)    = [F:PIM]PIMTYP
      [M:POV1]CODE(NE)      = "PJMOPE"
      [M:POV1]CLE1(NE)      = [F:PJTA]TASCOD
      [M:POV1]KEYCONCAT(NE) = [F:PJTA]KEYCONCAT
      [M:POV1]FCY(NE)       = [F:PJTA]TASFCY
      [M:POV1]CREDAT(NE)    = [F:PTKO]CREDAT
      Call CMT_LOAD_TREEVIEW_TAS_OPE(NE)
      Call LOAD_TREEVIEW_TAS_OPE_AFF(NE, NE)
    Next
    Filter [PTKO]
  Endif
End

#######################################################################################
Subprog LOAD_TREEVIEW_TAS_OPE_AFF(NE, ISAV_NE)
Variable Integer NE
Variable Integer ISAV_NE

Local Integer SAV_NE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array
Local Integer IFIRST

  If [M:POV0]OPELIN = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
    # --------------------------
    Gosub LOCAL_FILE_PJMOPEAFF
    # --------------------------
    IFIRST = [V]CST_AYES
    Filter [PJOA] Where evalue(SFILTER) and [F:PJOA]OPPNUM = [F:PTKO]OPPNUM and [F:PJOA]TASCOD = [F:PTKO]TASCOD and
&                       [F:PJOA]OPENUM = [F:PTKO]OPENUM and [F:PJOA]OPESPLNUM = [F:PTKO]OPESPLNUM
    For [PJOA]
      If IFIRST = [V]CST_AYES Then
        IFIRST = [V]CST_ANO  # Issue X3-105718 - 2018-08-27 by FGR : Was missing
        SAV_NE = ISAV_NE
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + mess(509,2260,1)
        [M:POV1]OBJDES(NE) = mess(509,2260,1)
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]PSDLVL(NE) = [V]CST_AYES
        SAV_NE = NE
      Endif
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        Break
      Endif
      [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + num$([F:PJOA]POANUM)
      [M:POV1]OBJDES(NE)    = [F:PJOA]POACLB - ":" - func PJOA_GET_POADES([F:PJOA]KEYCONCAT)
      [M:POV1]EXPFLG(NE)    = [V]CST_ANO
      [M:POV1]ICO(NE)       = "141.png"
      [M:POV1]TASCOD(NE)    = [F:PJOA]TASCOD
      [M:POV1]OPENUM(NE)    = [F:PJOA]OPENUM
      [M:POV1]OPESPLNUM(NE) = [F:PJOA]OPESPLNUM
      [M:POV1]POANUM(NE)    = [F:PJOA]POANUM
      #
      Call CMT_LOAD_TREEVIEW_TAS_OPE_AFF(NE)
    Next
  Endif
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  [M:POV1]CMT1(NE)  = mess([F:PIM]OPPSTATE,2249,1)
  [M:POV1]CMT2(NE)  = [F:OPPPJM]STRDAT
  [M:POV1]CMT3(NE)  = [F:OPPPJM]ENDDAT
  [M:POV1]CMT4(NE)  = [F:OPP]SALFCY
  [M:POV1]CMT6(NE)  = func PJMOVE_TOOLS.BUD_COMPUTE_QTYBUD_ALL_BUDGETS([M:POV0]OPPNUM, [M:POV0]TIMUOM)
  [M:POV1]CMT7(NE)  = [M:POV0]TIMUOM
  [M:POV1]CMT8(NE)  = func PJMOVE_TOOLS.BUD_COMPUTE_MNTBUD_ALL_BUDGETS([M:POV0]OPPNUM)
  [M:POV1]CMT9(NE)  = func PJMOVE_TOOLS.TAS_COMPUTE_EXTQTY_ALL_TASKS([M:POV0]OPPNUM, [M:POV0]TIMUOM)
  [M:POV1]CMT10(NE) = func PJMOVE_TOOLS.TAS_COMPUTE_CSMQTY_ALL_TASKS([M:POV0]OPPNUM, [M:POV0]TIMUOM)
  [M:POV1]CMT11(NE) = func PJMOVE_TOOLS.TAS_COMPUTE_RMNQTY_ALL_TASKS([M:POV0]OPPNUM, [M:POV0]TIMUOM)
  [M:POV1]CMT12(NE) = [M:POV0]TIMUOM
  [M:POV1]CMT13(NE) = func PJMOVE_TOOLS.TAS_COMPUTE_EXTAMT_ALL_TASKS([M:POV0]OPPNUM)
  [M:POV1]CMT14(NE) = [F:OPPPJM]CUROPP
  [M:POV1]CMT15(NE) = [F:OPPPJM]OPPDATLV
  [M:POV1]CMT16(NE) = [F:OPPPJM]OPPDATS
  [M:POV1]CMT18(NE) = func PJMOVE_TOOLS.TAS_PROGRESS_ALL_TASKS([M:POV0]OPPNUM, [M:POV0]TIMUOM)
  [M:POV1]CMT20(NE) = [F:OPPPJM]OPPDATLA
  [M:POV1]CMT24(NE) = [F:OPPPJM]OPPDATTH
  [M:POV1]CMT26(NE) = [F:OPPPJM]DUEDAT
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_BUD(NE)
Value Integer NE

Local Integer IRET

  Call RAZ_CMT(NE)
  [M:POV1]CMT1(NE)  = mess([F:PJBU]PBUSTATE,2251,1)
  IRET = func PJMOVE_TOOLS.TAS_START_END_DATE([F:PJBU]OPPNUM, [M:POV1]PBUCOD(NE), [M:POV1]CMT2(NE), [M:POV1]CMT3(NE))
  [M:POV1]CMT4(NE)  = [F:PJBU]PBUFCY
  [M:POV1]CMT6(NE)  = func PJMOVE_TOOLS.BUD_COMPUTE_QTYBUD([F:PJBU]OPPNUM, [M:POV1]PBUCOD(NE), [M:POV0]TIMUOM)
  [M:POV1]CMT7(NE)  = [M:POV0]TIMUOM
  [M:POV1]CMT8(NE)  = func PJMOVE_TOOLS.BUD_COMPUTE_MNTBUD([F:PJBU]OPPNUM, [M:POV1]PBUCOD(NE))
  [M:POV1]CMT12(NE) = [M:POV0]TIMUOM
  [M:POV1]CMT14(NE) = [F:OPP]CUR
  [M:POV1]CMT15(NE) = [F:PJBU]PBUDATO
  [M:POV1]CMT16(NE) = [F:PJBU]PBUDATS
  [M:POV1]CMT18(NE) = func PJMOVE_TOOLS.BUD_PROGRESS([F:PJBU]OPPNUM, [M:POV1]PBUCOD(NE))
  [M:POV1]CMT24(NE) = [F:PJBU]PBUDATH
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_BUDLIG(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  [M:POV1]CMT6(NE)  = [F:PJLB]PLBQTY
  [M:POV1]CMT7(NE)  = [F:PJLB]PLBU
  [M:POV1]CMT8(NE)  = [F:PJLB]PLBAMT
  [M:POV1]CMT14(NE) = [F:PJLB]CUR
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_TAS(SFILE, NE)
Value Char SFILE
Value Integer NE

  If SFILE = "PJTA2" Then
    Gosub LOCAL_FILE_PJMTSK
    [F:PJTA] = [F:PJTA2]
  Endif
  # --------------------------
  Call RAZ_CMT(NE)
  [M:POV1]CMT1(NE)   = mess([F:PJTA]TASSTATE,2250,1)
  [M:POV1]CMT2(NE)   = [F:PJTA]TASSTARTDT
  [M:POV1]CMT3(NE)   = [F:PJTA]TASENDDT
  [M:POV1]CMT4(NE)   = [F:PJTA]TASFCY
  [M:POV1]CMT9(NE)   = func PJMOVE_TOOLS.TAS_COMPUTE_EXTQTY([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE), [M:POV0]TIMUOM)
  [M:POV1]CMT10(NE)  = func PJMOVE_TOOLS.TAS_COMPUTE_CSMQTY([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE), [M:POV0]TIMUOM)
  [M:POV1]CMT11(NE)  = func PJMOVE_TOOLS.TAS_COMPUTE_RMNQTY([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE), [M:POV0]TIMUOM)
  [M:POV1]CMT12(NE)  = [M:POV0]TIMUOM
  [M:POV1]CMT13(NE)  = func PJMOVE_TOOLS.TAS_COMPUTE_EXTAMT([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE))
  [M:POV1]CMT14(NE)  = [F:OPP]CUR
  [M:POV1]CMT16(NE)  = [F:PJTA]TASDATS
  [M:POV1]CMT17(NE)  = [F:PJTA]TCACOD
  [M:POV1]CMT18(NE)  = func PJMOVE_TOOLS.TAS_PROGRESS([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE))
  [M:POV1]CMT19(NE)  = [F:PJTA]TASDATP
  [M:POV1]CMT20(NE)  = [F:PJTA]TASDATL
  [M:POV1]CMT21(NE)  = [F:PJTA]TASDATB
  [M:POV1]CMT24(NE)  = [F:PJTA]TASDATH
  [M:POV1]CMT25(NE)  = [F:PJTA]PRCCPL
  [M:POV1]CMT26(NE)  = [F:PJTA]DUEDAT
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_TAS_ITM(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  [M:POV1]CMT2(NE)  = [F:PJTA]TASSTARTDT
  [M:POV1]CMT3(NE)  = [F:JTT]REQDAT
  [M:POV1]CMT14(NE) = [F:OPP]CUR
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_TAS_ITM_ORDERS(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  Case [M:POV1]AOB(NE)
    When 1
      # Purchase orders
      [M:POV1]CMT1(NE)  = mess(3,17,1) - ":" - mess([M:POV1]STA(NE),1,1)
    When 2
      # Work orders
      [M:POV1]CMT1(NE)  = mess([M:POV1]STA(NE),363,1)
    When 3
      # Sub-contracts
      [M:POV1]CMT1(NE)  = mess([M:POV1]STA(NE),2221,1)
  Endcase
  [M:POV1]CMT3(NE)  = [F:JTT]REQDAT
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_TAS_OPE(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  [M:POV1]CMT1(NE)  = mess([F:PTKO]OPESTA,308,1)
  [M:POV1]CMT2(NE)  = [F:PTKO]OPESTR
  [M:POV1]CMT3(NE)  = [F:PTKO]OPEEND
  If [F:PTKO]EXTLAB <> AVOID.ACHAR Then
    [M:POV1]CMT5(NE) = [F:PTKO]EXTWST + "+" + [F:PTKO]EXTLAB
  Else
    [M:POV1]CMT5(NE) = [F:PTKO]EXTWST
  Endif
  [M:POV1]CMT9(NE)  = [F:PTKO]EXTQTY
  [M:POV1]CMT10(NE) = [F:PTKO]CSMQTY
  [M:POV1]CMT11(NE) = [F:PTKO]RMNQTY
  [M:POV1]CMT12(NE) = [F:PTKO]OPEUOM2
  [M:POV1]CMT13(NE) = func PJMOVE_TOOLS.RTKO_EXTAMT([F:PTKO]EXTQTY, [F:PTKO]OPECST2)
  [M:POV1]CMT14(NE) = [F:PTKO]CUR
  [M:POV1]CMT16(NE) = [F:PTKO]OPEDATS
  [M:POV1]CMT18(NE) = func PJMOVE_TOOLS.RTKO_PROGRESS([F:PTKO]CSMQTY, [F:PTKO]RMNQTY)
  [M:POV1]CMT22(NE) = [F:PTKO]OPESTARTDT
  [M:POV1]CMT23(NE) = [F:PTKO]OPEENDDT
  [M:POV1]CMT24(NE) = [F:PTKO]OPEDATH
End

#######################################################################################
Subprog CMT_LOAD_TREEVIEW_TAS_OPE_AFF(NE)
Value Integer NE

  Call RAZ_CMT(NE)
  [M:POV1]CMT2(NE)  = [F:PJOA]POASTR
  [M:POV1]CMT3(NE)  = [F:PJOA]POAEND
  [M:POV1]CMT9(NE)  = [F:PJOA]POASTDQTY
  [M:POV1]CMT10(NE) = [F:PJOA]POACSMQTY
  [M:POV1]CMT11(NE) = [F:PJOA]POARMNQTY
  [M:POV1]CMT12(NE) = [F:PJOA]POUOM
  [M:POV1]CMT18(NE) = func PJMOVE_TOOLS.PJOA_PROGRESS([F:PJOA]POACSMQTY, [F:PJOA]POARMNQTY)
End

######################################################################################
Subprog RAZ_CMT(NE)
Value Integer NE

  Raz [M:POV1]CMT1(NE)
  Raz [M:POV1]CMT2(NE)
  Raz [M:POV1]CMT3(NE)
  Raz [M:POV1]CMT4(NE)
  Raz [M:POV1]CMT6(NE)
  Raz [M:POV1]CMT7(NE)
  Raz [M:POV1]CMT8(NE)
  Raz [M:POV1]CMT9(NE)
  Raz [M:POV1]CMT10(NE)
  Raz [M:POV1]CMT11(NE)
  Raz [M:POV1]CMT12(NE)
  Raz [M:POV1]CMT13(NE)
  Raz [M:POV1]CMT14(NE)
  Raz [M:POV1]CMT15(NE)
  Raz [M:POV1]CMT16(NE)
  Raz [M:POV1]CMT17(NE)
  Raz [M:POV1]CMT18(NE)
  Raz [M:POV1]CMT19(NE)
  Raz [M:POV1]CMT20(NE)
  Raz [M:POV1]CMT21(NE)
  Raz [M:POV1]CMT22(NE)
  Raz [M:POV1]CMT23(NE)
  Raz [M:POV1]CMT24(NE)
  Raz [M:POV1]CMT25(NE)
  Raz [M:POV1]CMT26(NE)
End

######################################################################################
Subprog DISPLAY_WITH_STYLE()
Local Integer NE
Local Integer ILINEBUD
Local Integer ILINETAS
Local Char SPBUPAE (GLONPBU)
Local Char STASPAE (GLONTAC)
Local Decimal NSUMQTY

  Affzo [M:POV1]5
  For NE = 0 To [M:POV1]NBLIG-1
    # -------------------------
    # 1°)Pseudo levels
    If [M:POV1]PSDLVL(NE) = [V]CST_AYES Then
      [M:POV1]ICO(NE) = "11.png"
      Chgstl [M:POV1]OBJDES(NE) With "PJMWHITEB"
    Endif
    If NE = 0 Then
      # -------------------------
      # 2°)Project
      Call CMT_STYLE(NE)
      # --------------------------
      Case [M:POV1]STATE(NE)
        When 1
          # New
          Chgstl [M:POV1]CMT1(NE) With "PJMNEWB"
        When 2
          # Launched
          Chgstl [M:POV1]CMT1(NE) With "PJMOPENB"
        When 3
          # Delivered
          Chgstl [M:POV1]CMT1(NE) With "PJMDELIVB"
        When 4
          # Closed
          Chgstl [M:POV1]CMT1(NE) With "PJMCLOSEB"
        When 9
          # Suspended
          Chgstl [M:POV1]CMT1(NE) With "PJMHOLDB"
        When Default
          Chgstl [M:POV1]CMT1(NE) With ""
      Endcase
      If [M:POV1]CMT26(NE) <> AVOID.ADATE Then
        If [F:OPPPJM]DUEDAT < [F:OPPPJM]ENDDAT Then
          Chgstl [M:POV1]CMT26(NE) With "PJMWARN1B"
        Endif
      Endif
    Elsif [M:POV1]PBUCOD(NE) <> AVOID.ACHAR Then
      # -------------------------
      # 3°)Budgets
      Raz ILINEBUD
      Raz SPBUPAE
      # --------------------------
      SPBUPAE = func BUD_GET_PBUPAE([M:POV0]OPPNUM, [M:POV1]PBUCOD(NE))
      # --------------------------
      If func BUD_IS_PARENT([M:POV0]OPPNUM, [M:POV1]PBUCOD(NE)) = [V]CST_AYES or
&        (func BUD_IS_PARENT([M:POV0]OPPNUM, [M:POV1]PBUCOD(NE)) = [V]CST_ANO and SPBUPAE = AVOID.ACHAR)
&     Then
        Call CMT_STYLE(NE)
        # --------------------------
        Case [M:POV1]STATE(NE)
          When 1
            # New
            Chgstl [M:POV1]CMT1(NE) With "PJMNEWB"
          When 2
            # Opened
            Chgstl [M:POV1]CMT1(NE) With "PJMOPENB"
          When 3
            # Delivered
            Chgstl [M:POV1]CMT1(NE) With "PJMDELIVB"
          When 4
            # Sold
            Chgstl [M:POV1]CMT1(NE) With "PJMCLOSEB"
          When 9
            # Suspended
            Chgstl [M:POV1]CMT1(NE) With "PJMHOLDB"
          When Default
            Chgstl [M:POV1]CMT1(NE) With ""
        Endcase
      Else
        Case [M:POV1]STATE(NE)
          When 1
            # New
            Chgstl [M:POV1]CMT1(NE) With "PJMNEW"
          When 2
            # Opened
            Chgstl [M:POV1]CMT1(NE) With "PJMOPEN"
          When 3
            # Delivered
            Chgstl [M:POV1]CMT1(NE) With "PJMDELIV"
          When 4
            # Sold
            Chgstl [M:POV1]CMT1(NE) With "PJMCLOSE"
          When 9
            # Suspended
            Chgstl [M:POV1]CMT1(NE) With "PJMHOLD"
          When Default
            Chgstl [M:POV1]CMT1(NE) With ""
        Endcase
      Endif
    Elsif [M:POV1]TASCOD(NE) <> AVOID.ACHAR Then
      If [M:POV1]OPENUM(NE) = 0 Then
        # --------------------------
        # 4°)Tasks
        Raz ILINETAS
        Raz STASPAE
        # --------------------------
        STASPAE = func BUD_GET_PBUPAE([M:POV0]OPPNUM, [M:POV1]TASCOD(NE))
        If func TAS_IS_PARENT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) = [V]CST_AYES or
&          (func TAS_IS_PARENT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) = [V]CST_ANO and STASPAE = AVOID.ACHAR)
&       Then
          Call CMT_STYLE(NE)
          Case [M:POV1]STATE(NE)
            When 1
              # New
              Chgstl [M:POV1]CMT1(NE) With "PJMNEWB"
            When 2
              # Launched
              Chgstl [M:POV1]CMT1(NE) With "PJMOPENB"
            When 3
              # Started
              Chgstl [M:POV1]CMT1(NE) With "PJMSTARTB"
            When 4
              # Closed
              Chgstl [M:POV1]CMT1(NE) With "PJMCLOSEB"
            When 5
              # Plan
              Chgstl [M:POV1]CMT1(NE) With "PJMPLANB"
            When 9
              # Suspended
              Chgstl [M:POV1]CMT1(NE) With "PJMHOLDB"
            When Default
              Chgstl [M:POV1]CMT1(NE) With ""
          Endcase
          If [M:POV1]CMT26(NE) <> AVOID.ADATE Then
            If func TAS_GET_DUEDAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) < func TAS_GET_TASENDDT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) Then
              Chgstl [M:POV1]CMT26(NE) With "PJMWARN1B"
            Endif
          Endif
        Else
          Case [M:POV1]STATE(NE)
            When 1
              # New
              Chgstl [M:POV1]CMT1(NE) With "PJMNEW"
            When 2
              # Launched
              Chgstl [M:POV1]CMT1(NE) With "PJMOPEN"
            When 3
              # Started
              Chgstl [M:POV1]CMT1(NE) With "PJMSTART"
            When 4
              # Closed
              Chgstl [M:POV1]CMT1(NE) With "PJMCLOSE"
            When 5
              # Plan
              Chgstl [M:POV1]CMT1(NE) With "PJMPLAN"
            When 9
              # Suspended
              Chgstl [M:POV1]CMT1(NE) With "PJMHOLD"
            When Default
              Chgstl [M:POV1]CMT1(NE) With ""
          Endcase
          If [M:POV1]CMT26(NE) <> AVOID.ADATE Then
            If func TAS_GET_DUEDAT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) < func TAS_GET_TASENDDT([M:POV0]OPPNUM, [M:POV1]TASCOD(NE)) Then
              Chgstl [M:POV1]CMT26(NE) With "PJMWARN1"
            Endif
          Endif
        Endif
        # --------------------------
        # 5°)Products
        If [M:POV1]ITMREF(NE) <> AVOID.ACHAR
          Chgstl [M:POV1]CMT1(NE) With ""
          If [M:POV0]DISPLAY = [V]CST_AYES Then
            If [M:POV1]STATE(NE) = 4 Then
              Chgstl [M:POV1]AVADAT(NE) With func PJMAVADAT.GET_STYLE_REQDATE([M:POV1]CMT3(NE), [M:POV1]AVADAT(NE), ([M:POV1]STATE(NE) <> 4))
              If [M:POV1]KEYCOD(NE) = AVOID.ACHAR Then
                NSUMQTY = func PJMAVADAT.GET_SUM_QTY([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]UOM(NE))
                Chgstl [M:POV1]QTY(NE) With func PJMAVADAT.GET_STYLE_ITTQTY([M:POV1]AVADAT(NE), [M:POV1]QTY(NE), NSUMQTY, ([M:POV1]STATE(NE) <> 4))
              Endif
            Else
              # [M:POV1]STATE(NE) <> 4
              Chgstl [M:POV1]AVADAT(NE) With func PJMAVADAT.GET_STYLE_REQDATE([M:POV1]CMT3(NE), [M:POV1]AVADAT(NE), ([M:POV1]STATE(NE) = 4))
              If [M:POV1]KEYCOD(NE) = AVOID.ACHAR Then
                NSUMQTY = func PJMAVADAT.GET_SUM_QTY([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]UOM(NE))
                Chgstl [M:POV1]QTY(NE) With func PJMAVADAT.GET_STYLE_ITTQTY([M:POV1]AVADAT(NE), [M:POV1]QTY(NE), NSUMQTY, ([M:POV1]STATE(NE) = 4))
              Endif
            Endif
          Else
            # [M:POV0]DISPLAY = [V]CST_ANO
            If [M:POV1]KEYCOD(NE) = AVOID.ACHAR Then
              Chgstl [M:POV1]AVADAT(NE) With func PJMAVADAT.GET_STYLE_REQDATE([M:POV1]CMT3(NE), [M:POV1]AVADAT(NE), ([M:POV1]STATE(NE) = 4))
              NSUMQTY = func PJMAVADAT.GET_SUM_QTY([M:POV0]OPPNUM, [M:POV1]TASCOD(NE), [M:POV1]ITMREF(NE), [M:POV1]UOM(NE))
              Chgstl [M:POV1]QTY(NE) With func PJMAVADAT.GET_STYLE_ITTQTY([M:POV1]AVADAT(NE), [M:POV1]QTY(NE), NSUMQTY, ([M:POV1]STATE(NE) = 4))
            Else
              Chgstl [M:POV1]AVADAT(NE) With func PJMAVADAT.GET_STYLE_REQDATE([M:POV1]CMT3(NE), [M:POV1]AVADAT(NE), ([M:POV1]AVADATSTA(NE) = [V]CST_AYES or [M:POV1]STATE(NE) = 4))
            Endif
          Endif
        Endif
      Else
        # --------------------------
        # 6°)Operations
        Case [M:POV1]STATE(NE)
          When 1
            # Pending
            Chgstl [M:POV1]CMT1(NE) With "PJMNEW"
          When 4
            # In process
            Chgstl [M:POV1]CMT1(NE) With "PJMOPEN"
          When 5
            # Closed
            Chgstl [M:POV1]CMT1(NE) With "PJMCLOSE"
          When Default
            Chgstl [M:POV1]CMT1(NE) With ""
        Endcase
      Endif
    Endif
  Next NE
End

#######################################################################################
Subprog CMT_STYLE(NE)
Value Integer NE

  Chgstl [M:POV1]CMT2(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT3(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT4(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT5(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT6(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT7(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT8(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT9(NE)  With "PJMWHITEB"
  Chgstl [M:POV1]CMT10(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT11(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT12(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT13(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT14(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT15(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT16(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT17(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT18(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT19(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT20(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT21(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT22(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT23(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT24(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT25(NE) With "PJMWHITEB"
  Chgstl [M:POV1]CMT26(NE) With "PJMWHITEB"
End

#######################################################################################
Subprog LOAD_SCREEN_DEFAULT(SOPPNUM)
Value Char SOPPNUM

Local Char SMESSAGE(type(GMESSAGE)-10)
Local Char SFCY(GLONFCY)

  [M:POV0]OPPNUM = SOPPNUM
  [M:POV0]CUR = func OPPORPJM_CSTD_PROGS.GET_CUROPP_VALUE(GACTX, [M:POV0]OPPNUM, SMESSAGE)
  SFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, [M:POV0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
  [M:POV0]TIMUOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, SFCY, "UNITWORK")
  [M:POV0]BUD = [V]CST_AYES
  [M:POV0]BUDLIN = [V]CST_AYES
  [M:POV0]TAS = [V]CST_AYES
  [M:POV0]OPE = [V]CST_AYES
  [M:POV0]OPELIN = [V]CST_AYES
  [M:POV0]ITMFLG = [V]CST_AYES
  [M:POV0]ITMAVA = [V]CST_AYES
  [M:POV0]DISPLAY = [V]CST_ANO
  Actzo [M:POV0]BUDLIN
  Actzo [M:POV0]OPE
  Actzo [M:POV0]OPELIN
  Actzo [M:POV0]ITMFLG
  Actzo [M:POV0]ITMAVA
  Actzo [M:POV0]DISPLAY
  Affzo [M:POV0]1-99
  If [M:POV0]TIMUOM = AVOID.ACHAR Then
    GMESSAGE = func AFNC.MES1(mess(398,2260,1), SFCY)
    GERR = 1
    End
  Endif
  [M:POV0]TCACOD = AVOID.ACHAR         # Issue X3-91018 - 2018-05-22 by TEJAC
End

#######################################################################################
Funprog FORMAT(SFIELD)
Value Char SFIELD

Local Char SFORMAT(250)
Local Integer ILENGTH

  Raz SFORMAT
  Case SFIELD
    When "CMT8"
       SFORMAT = func TECFINOVE_CSTD_PROGS.GET_FMT_AMT(GACTX, [M:POV0]BUD, [M:POV0]CUR)
    When "CMT6"
       SFORMAT = func TECFINOVE_CSTD_PROGS.GET_FMT_QTY(GACTX, [M:POV0]BUD, [M:POV0]TIMUOM)
    When "CMT7"
       If [M:POV0]BUD = [V]CST_ANO Then
         SFORMAT = "-"
       Endif
       ILENGTH = evalue("type([M:POV1]" + SFIELD + ")") - 10
       SFORMAT += "A:" + num$(ILENGTH) + "A"
    When "CMT5"
       If [M:POV0]TAS = [V]CST_ANO Then
         SFORMAT = "-"
       Endif
       ILENGTH = evalue("type([M:POV1]" + SFIELD + ")") - 10
       SFORMAT += "A:" + num$(ILENGTH) + "A"
    When "CMT17"
       If [M:POV0]TAS = [V]CST_ANO Then
         SFORMAT = "-"
       Endif
       ILENGTH = evalue("type([M:POV1]" + SFIELD + ")") - 10
       SFORMAT += "A:" + num$(ILENGTH) + "A"
    When "QTY"
       SFORMAT = func TECFINOVE_CSTD_PROGS.GET_FMT_QTY(GACTX, [M:POV0]ITMFLG, [M:POV0]TIMUOM)
    When "UOM"
       If [M:POV0]ITMFLG = [V]CST_ANO Then
         SFORMAT = "-"
       Endif
       ILENGTH = evalue("type([M:POV1]" + SFIELD + ")") - 10
       SFORMAT += "A:" + num$(ILENGTH) + "A"
    When "AVADAT"
       If [M:POV0]ITMFLG = [V]CST_ANO Then
         SFORMAT = "-"
       Endif
       ILENGTH = evalue("type([M:POV1]" + SFIELD + ")") - 10
       SFORMAT += "D:" + GFMDAT
  Endcase
End SFORMAT

#######################################################################################
Funprog GET_INDEX_AMK_TASCOD(SCOD, IMAX)
Value Char SCOD
Value Integer IMAX

Local Integer IARENDRE
Local Integer NI

  IARENDRE = 0
  For NI = 0 To IMAX
    If [M:POV1]TASCOD(NI) = SCOD Then
      IARENDRE = NI
      Break
    Endif
  Next NI
End IARENDRE

#######################################################################################
# Get computed information
#######################################################################################
Funprog PIM_GET_PIMDESAXX(PIMNUM)
Value Char PIMNUM

Local Instance TECFINOVE Using C_TECFINOVE
Local Char SARENDRE(GLONDCO)

  Raz SARENDRE
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by FGR/TEJAC
    Call LECTEXTRA_SYR(TECFINOVE, AVOID.ACHAR, SARENDRE, "SNPPIMPL", "PIMDESAXX", [M:POV0]KEYEXT + "~" + PIMNUM, AVOID.ACHAR) From ATEXTRA
  Else
    SARENDRE = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVE, PIMNUM)
  Endif
  FreeGroup TECFINOVE
End SARENDRE

#######################################################################################
Funprog GET_PLBDESAXX(SOPPNUM, SPBUCOD, IPLBSEQ)
Value Char SOPPNUM
Value Char SPBUCOD
Value Integer IPLBSEQ

Local Instance TECFINOVE Using C_TECFINOVE
Local Char SARENDRE(GLONDCO)
Local Char SKEYCONCAT(GLONVPJ)

  Raz SARENDRE
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by FGR/TEJAC
    SKEYCONCAT = func PJMBUDLIG_CSTD_PROGS.GET_KEYCONCAT(TECFINOVE.ACTX, SOPPNUM, SPBUCOD)
    Call LECTEXTRA_SYR(TECFINOVE, AVOID.ACHAR, SARENDRE, "SNPBUDLIG", "PLBDESAXX", [M:POV0]KEYEXT + "~" + SKEYCONCAT, num$(IPLBSEQ)) From ATEXTRA
  Else
    SARENDRE = func PJMBUDLIG_CSTD_PROGS.GET_PLBDESAXX(TECFINOVE, SOPPNUM, SPBUCOD, IPLBSEQ)
  Endif
  FreeGroup TECFINOVE
End SARENDRE

#######################################################################################
Funprog JTT_GET_ITMDES1(SOPPNUM, STASCOD, IITTSEQ)
Value Char SOPPNUM
Value Char STASCOD
Value Integer IITTSEQ

Local Instance TECFINOVE Using C_TECFINOVE
Local Char SARENDRE(GLONDCO)
Local Char SKEYCONCAT(GLONVPJ)

  Raz SARENDRE
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by FGR/TEJAC
    SKEYCONCAT = func PJMTSKITM_CSTD_PROGS.GET_KEYCONCAT(TECFINOVE.ACTX, SOPPNUM, STASCOD, IITTSEQ)
