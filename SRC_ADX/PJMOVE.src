#######################################################################################
Funprog TAS_IS_PARENT(SOPPNUM, STASCOD)
Value Char SOPPNUM
Value Char STASCOD

Local Integer IARENDRE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  IARENDRE = [V]CST_ANO
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by FGR/TEJAC
    Gosub LOCAL_FILE_PJMTSK
    Call LOAD_FILTER(SFILTER)            # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
    Filter [PJTA] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]TASPAE = STASCOD
    For [F:PJTA]
      IARENDRE = [V]CST_AYES
      Break
    Next
    Filter [PJTA]
  Else
    IARENDRE = func PJMTSK_CSTD_PROGS.IS_PARENT(GACTX, SOPPNUM, STASCOD)
  Endif
End IARENDRE

#######################################################################################
Funprog TAS_GET_TASPAE(SOPPNUM, STASCOD)
Value Char SOPPNUM
Value Char STASCOD

Local Char SARENDRE(GLONTAC)
Local Char SMESSAGE(type(GMESSAGE)-10)

  Raz SARENDRE
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by FGR/TEJAC
    Gosub LOCAL_FILE_PJMTSK
    Read [PJTA]PTA0=[M:POV0]KEYEXT;SOPPNUM;STASCOD        # Issue X3-99012 - 2018-07-04 by FGR : not SPJTA0
    If fstat = [V]CST_AOK Then
      SMESSAGE = func AFNC.MES1(mess(591,2260,1), SOPPNUM, STASCOD)
    Else
      SARENDRE = [F:PJTA]TASPAE
    Endif
  Else
    SARENDRE = func PJMTSK_CSTD_PROGS.GET_TASPAE(GACTX, SOPPNUM, STASCOD, SMESSAGE)
  Endif
End SARENDRE

