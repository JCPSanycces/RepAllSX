#######################################################################################
Funprog GET_TASTYP(ITASPIMTYP)
Value Integer ITASPIMTYP
Local Integer IARENDRE

  # Issue X3-91018 - 2018-06-04 by TEJAC
  Case ITASPIMTYP
    When 2
      #1 - MATERIAL
      IARENDRE = 1
    When 3
      #2 - LABOUR
      IARENDRE = 2
    When 4
      #3 - MIXED
      IARENDRE = 3
    When 5
      #4 - MISCELLANEOUS
      IARENDRE = 4
  Endcase
End IARENDRE

#######################################################################################
# Dynamics local files
#######################################################################################
Subprog LOAD_FILTER(SFILTER)
Variable Char SFILTER()(0..)

Local Integer NLIG

  # Issue X3-76891 - 2018-03-26 by TEJAC : START
  NLIG = maxtab(SFILTER) + 1
  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    SFILTER(NLIG) = "SNPVCR = [M:POV0]KEYEXT"
  Else
    SFILTER(NLIG) = "(1=1)"
  Endif
End SFILTER

#######################################################################################
Subprog GET_PJMBUD_FILTER(SFILTER)
Variable Char SFILTER()(0..)

Local Integer NLIG

  # Issue X3-91018 - 2018-05-17 by TEJAC
  NLIG = maxtab(SFILTER) + 1
  If NLIG > 0 Then
    SFILTER(NLIG) -= "&"
  Endif
  Case [M:POV0]PBUSTATE
    When 1
      #1 - ALL BUDGETS
      SFILTER(NLIG) -= "(1=1)"
    When 2
      #2 - NEW
      SFILTER(NLIG) -= "[F:PJBU]PBUSTATE = 1"
    When 3
      #3 - OPEN
      SFILTER(NLIG) -= "[F:PJBU]PBUSTATE = 2"
    When 4
      #4 - DELIVERED
      SFILTER(NLIG) -= "[F:PJBU]PBUSTATE = 3"
    When 5
      #5 - CLOSED
      SFILTER(NLIG) -= "[F:PJBU]PBUSTATE = 4"
    When 6
      #6 - SUSPENDED
      SFILTER(NLIG) -= "[F:PJBU]PBUSTATE = 9"
  Endcase
End

#######################################################################################
Subprog GET_PJMTAS_FILTER(SFILTER)
Variable Char SFILTER()(0..)

Local Integer NLIG

  # Issue X3-91018 - 2018-05-21 by TEJAC
  NLIG = maxtab(SFILTER) + 1
  If NLIG > 0 Then
    SFILTER(NLIG) -= "&"
  Endif
  Case [M:POV0]TASSTATE
    When 1
      #1 - ALL TASKS
      SFILTER(NLIG) -= "(1=1)"
    When 2
      #2 - NOT OPENED (NEW)
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 1"
    When 3
      #3 - OPENED (LAUNCHED-2, STARTED-3, or PLANNED-5)
      SFILTER -= "([F:PJTA]TASSTATE = 2 or [F:PJTA]TASSTATE = 3 or [F:PJTA]TASSTATE = 5)"
    When 4
      #4 - LAUNCHED
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 2"
    When 5
      #5 - STARTED
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 3"
    When 6
      #6 - PLANNED
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 5"
    When 7
      #7 - CLOSED
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 4"
    When 8
      #8 - SUSPENDED
      SFILTER(NLIG) -= "[F:PJTA]TASSTATE = 9"
  Endcase
  If [M:POV0]TASPIMTYP > 1 Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PTC]TASTYP = func PJMOVE.GET_TASTYP([M:POV0]TASPIMTYP)"
  Endif
  If [M:POV0]TCACOD <> AVOID.ACHAR Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]TCACOD = [M:POV0]TCACOD"
  Endif
  If [M:POV0]TASPROGF > 0 Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]PRCCPL >= [M:POV0]TASPROGF"
  Endif
  If [M:POV0]TASPROGT > 0 Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]PRCCPL <= [M:POV0]TASPROGT"
  Endif
  If [M:POV0]DUEDATF <> AVOID.ADATE Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]DUEDAT >= [M:POV0]DUEDATF"
  Endif
  If [M:POV0]DUEDATT <> AVOID.ADATE Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]DUEDAT <= [M:POV0]DUEDATT"
  Endif
  If [M:POV0]TASSTARTDAT <> AVOID.ADATE Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]TASSTARTDT >= [M:POV0]TASSTARTDAT"
  Endif
  If [M:POV0]TASENDDT <> AVOID.ADATE Then
    NLIG += 1
    If NLIG > 0 Then
      SFILTER(NLIG) -= "&"
    Endif
    SFILTER(NLIG) -= "[F:PJTA]TASENDDT <= [M:POV0]TASENDDT"
  Endif
End

#######################################################################################
Funprog INCREASE_LINE(NE)
Variable Integer NE

Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  If NE < dim([M:POV1]OBJDES)-1 Then
    NE += 1
  Else
    IARENDRE = [V]CST_AERROR
    If [M:POV0]MSGDIS = [V]CST_ANO Then
      [M:POV0]MSGDIS = [V]CST_AYES
      Call ERREUR(func AFNC.MES1(mess(1051,2260,1), num$(dim([M:POV1]OBJDES)))) From GESECRAN
    Endif
  Endif
End IARENDRE

