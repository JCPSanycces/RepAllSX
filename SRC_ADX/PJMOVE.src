End

#######################################################################################
## Screen POV1
#######################################################################################
Subprog IB_NBLIG()

  If [M:POV0]KEYEXT <> AVOID.ACHAR Then
    # Issue X3-76891 - 2018-04-04 by TEJAC : START
    # Diable action buttons when called from Project overview
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
    Raz GBOUT5
    Raz GBOUT6
    Raz GBOUT7
    Raz GBOUT8
    Raz GBOUT9
    Raz GBOUT10
    Raz GBOUT11
    Raz GBOUT12
    Raz GBOUT13
    Raz GBOUT14
    Raz GBOUT15
    Raz GBOUT16
  Else
    If nolign-1 = 0 Then
      # Project
      Raz GBOUT2
      Raz GBOUT3
      Raz GBOUT4
      Raz GBOUT5
      Raz GBOUT6
      Raz GBOUT11
      Raz GBOUT12
      Raz GBOUT13
      Raz GBOUT14
      Raz GBOUT15
      Raz GBOUT16
    Elsif [M:POV1]TASCOD(nolign-1) <> AVOID.ACHAR Then
      # Tasks
      Raz GBOUT1
      Raz GBOUT2
      Raz GBOUT5
      Raz GBOUT10
      # ----------------------------------
      If [M:POV1]PIMTYP(nolign-1) <> 6 and [M:POV1]PIMTYP(nolign-1) <> 7 Then
        # Enterprise planning only on tasks of category "Material" or "Mixed"
        Raz GBOUT9
        Raz GBOUT11
        Raz GBOUT15
      Endif
      # ----------------------------------
      If [M:POV1]PIMTYP(nolign-1) <> 5 and [M:POV1]PIMTYP(nolign-1) <> 7 Then
        # Time entry inquiry only on tasks of category "Labor" or "Mixed"
        Raz GBOUT8
      Endif
      # ----------------------------------
      If [M:POV1]STATE(nolign-1) = 1 or ([M:POV1]STATE(nolign-1) <> 1 and [M:POV1]PIMSTA(nolign-1) = [V]CST_ANO) Then
        # Buttons available only on launched tasks
        Raz GBOUT12
        Raz GBOUT13
        Raz GBOUT14
        Raz GBOUT15
      Endif
      # ----------------------------------
      If [M:POV1]OPENUM(nolign-1) <> 0 Then
        # Operations
        Raz GBOUT3
        Raz GBOUT7
        Raz GBOUT9
        Raz GBOUT11
        Raz GBOUT12
        Raz GBOUT13
        Raz GBOUT14
        Raz GBOUT16
        # ----------------------------------
        If [M:POV1]POANUM(nolign-1) <> 0 Then
          # Assignments
          Raz GBOUT4
          Raz GBOUT8
        Endif
      Else
        Raz GBOUT4
        Raz GBOUT6
      Endif
      # ----------------------------------
      If [M:POV1]ITMREF(nolign-1) <> AVOID.ACHAR Then
        # Products
        GBOUT9 = mess(604,2260,1)
        If [M:POV1]STATE(nolign-1) = 1 Then
          Raz GBOUT9
          Raz GBOUT16
        Endif
        Raz GBOUT3
        Raz GBOUT7
        Raz GBOUT8
        # ----------------------------------
        # Enable/disable Buttons depending on the flow type
        Local File ITMMASTER [ITM]
        Read [ITM]ITM0=[M:POV1]ITMREF(nolign-1)
        If [F:ITM]PURFLG <> [V]CST_AYES Then
          Raz GBOUT12
        Endif
        If [F:ITM]MFGFLG <> [V]CST_AYES Then
          Raz GBOUT13
        Endif
        If [F:ITM]SCPFLG <> [V]CST_AYES Then
          Raz GBOUT14
        Endif
        If [M:POV1]AVADAT(nolign-1) = [0/0/0] Then
          Raz GBOUT15
        Endif
        If [M:POV1]KEYCOD(nolign-1) <> AVOID.ACHAR Then
          Raz GBOUT9
        Else
          Raz GBOUT16
        Endif
      Else
        Raz GBOUT11
        Raz GBOUT12
        Raz GBOUT13
        Raz GBOUT14
        Raz GBOUT15
        Raz GBOUT16
      Endif
    Elsif [M:POV1]PBUCOD(nolign-1) <> AVOID.ACHAR Then
      # Budgets
      Raz GBOUT1
      Raz GBOUT3
      Raz GBOUT4
      Raz GBOUT6
      Raz GBOUT11
      Raz GBOUT12
      Raz GBOUT13
      Raz GBOUT14
      Raz GBOUT15
      Raz GBOUT16
      # ----------------------------------
      If [M:POV1]PLBSEQ(nolign-1) <> 0 Then
        # Budget lines
        Raz GBOUT2
        Raz GBOUT7
        Raz GBOUT8
        Raz GBOUT9
        Raz GBOUT10
      Endif
    Else
      # Pseudo levels
      Raz GBOUT1
      Raz GBOUT2
      Raz GBOUT3
      Raz GBOUT4
      Raz GBOUT5
      Raz GBOUT6
      Raz GBOUT7
      Raz GBOUT8
      Raz GBOUT9
      Raz GBOUT10
      Raz GBOUT11
      Raz GBOUT12
      Raz GBOUT13
      Raz GBOUT14
      Raz GBOUT15
      Raz GBOUT16
    Endif
  Endif
  # Issue X3-99928 - 2018-08-23 by FGR : BEGIN
  If GBOUT1 <> AVOID.ACHAR Then
    # Project status change
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("3") = [V]CST_ANO Then
      Raz GBOUT1
    Endif
  Endif
  If GBOUT2 <> AVOID.ACHAR Then
    # Budget status change
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTBUD("2") = [V]CST_ANO Then
      Raz GBOUT2
    Endif
  Endif
  If GBOUT3 <> AVOID.ACHAR Then
    # Task status change
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTTAS("1") = [V]CST_ANO Then
      Raz GBOUT3
    Endif
  Endif
  If GBOUT4 <> AVOID.ACHAR Then
    # Operation status change
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTTAS("O") = [V]CST_ANO Then
      Raz GBOUT4
    Endif
  Endif
  If GBOUT5 <> AVOID.ACHAR Then
    # Budget update
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTBUD("M") = [V]CST_ANO Then
      Raz GBOUT5
    Endif
  Endif
  If GBOUT7 <> AVOID.ACHAR Then
    # Saleable product list
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("6") = [V]CST_ANO Then
      Raz GBOUT7
    Endif
  Endif
  If GBOUT10 <> AVOID.ACHAR Then
    # Financial overview
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
      Raz GBOUT10
    Endif
  Endif
  # Issue X3-99928 - 2018-08-23 by FGR : END
End

#######################################################################################
#######################################################################################
# Subroutines
#######################################################################################
Subprog LOAD_PAGE()

Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  Call LOAD_FILTER(SFILTER)            # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  # ----------------------------------
  Gosub LOCAL_FILE_OPPOR
  Gosub LOCAL_FILE_OPPORPJM
  Gosub LOCAL_FILE_PIMPL
  # ----------------------------------
  Filter [OPP] Where evalue(SFILTER) and [F:OPP]OPPNUM = [M:POV0]OPPNUM
  Filter [OPPPJM] Where evalue(SFILTER) and [F:OPPPJM]OPPNUM = [M:POV0]OPPNUM
  Filter [PIM] Where evalue(SFILTER) and [F:PIM]OPPNUM = [M:POV0]OPPNUM
  #
  Read [OPP]First
  Read [OPPPJM]First
  Read [PIM]First
  # ----------------------------------
  Call LOAD_TREEVIEW()
  Call DISPLAY_WITH_STYLE()
  # ----------------------------------
  Affzo [M:POV1]1-99
End

#######################################################################################
Subprog LOAD_TREEVIEW()

Local Integer NE
Local Integer IRET
Local Char SMESSAGE(type(GMESSAGE)-10)

  Effzo [M:POV1]5
  NE = 0
  [M:POV0]MSGDIS = [V]CST_ANO
  # ----------------------------------
  [M:POV1]KEYC(NE)      = [F:OPP]OPPNUM
  [M:POV1]EXPFLG(NE)    = [V]CST_AYES
  [M:POV1]OBJDES(NE)    = [F:OPP]OPPNUM - func PIM_GET_PIMDESAXX([F:OPP]OPPNUM)
  [M:POV1]STATE(NE)     = [F:PIM]OPPSTATE
  [M:POV1]ICO(NE)       = "Folder.gif"
  [M:POV1]KEYCONCAT(NE) = func PIMPL_CSTD_PROGS.GET_PIMNUM_PJM(GACTX, [M:POV0]OPPNUM)
  [M:POV1]FCY(NE)       = [F:OPP]SALFCY
  [M:POV1]CREDAT(NE)    = [F:OPP]CREDAT
  [M:POV1]CODE(NE)      = "OPPORPJM"
  [M:POV1]ORI(NE)       = "PJM"
  [M:POV1]CLE1(NE)      = [F:OPP]OPPNUM
  Call CMT_LOAD_TREEVIEW(NE)
  Call LOAD_TREEVIEW_BUD(NE)
  Call LOAD_TREEVIEW_TAS(NE)
  Call LOAD_TREEVIEW_NOBUDTAS(NE)
  IRET = func INCREASE_LINE(NE)
  [M:POV1]NBLIG = NE
  Affzo [M:POV1]1-99
  # ----------------------------------
  Filter [OPP]
  Filter [OPPPJM]
  Filter [PIM]
  # ----------------------------------
End

#######################################################################################
# Issue X3-91018 - 2018-05-21 by TEJAC/FGR : BEGIN
Subprog LOAD_TREEVIEW_BUD(NE)
Variable Integer NE

Local Char SFILTER(250)(0..)
Local Char SFILTER1(250)(0..)
Local Integer SAV_NE
Local Integer ILOAD_LINE

  If [M:POV0]BUD = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)
    Call GET_PJMBUD_FILTER(SFILTER1)
    # -------------------------
    Gosub LOCAL_FILE_PJMBUD
    # -------------------------
    Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = [F:OPP]OPPNUM
    For [PJBU]PJBU1          # Issue X3-91330 - 2018-06-19 by FGR : add sorted index
      # --------------------------------------------------------------------------------------
      # BEGIN : To check if line is going to be loaded or not in the grid
      ILOAD_LINE = [V]CST_ANO
      If evalue(SFILTER1) Then
        ILOAD_LINE = [V]CST_AYES
      Else
        # If budget is a parent, we have to check if its children are going to be displayed.
        # If yes, the parent will have to be displayed.
        # If no, the parent will not be displayed.
        # Careful, the parent could be a parent of a parent : so we have to check all the family
        If func BUD_CHECK_IF_FAMILY_DISPLAY([F:PJBU]OPPNUM, [F:PJBU]PBUCOD) = [V]CST_AYES Then
          ILOAD_LINE = [V]CST_AYES
        Endif
      Endif
      # END : To check if line is going to be loaded or not in the grid
      # --------------------------------------------------------------------------------------
      If ILOAD_LINE = [V]CST_AYES Then
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        If [F:PJBU]PBUPAE <> AVOID.ACHAR Then
          [M:POV1]PARKEY(NE) = [F:PJBU]PBUPAE
          [M:POV1]EXPFLG(NE) = [V]CST_ANO
        Else
          [M:POV1]PARKEY(NE) = [M:POV1]KEYC(0)
        Endif
        [M:POV1]KEYC(NE)      = [F:PJBU]PBUCOD
        [M:POV1]OBJDES(NE)    = [F:PJBU]PBUCOD - func PIM_GET_PIMDESAXX([F:PJBU]KEYCONCAT)
        [M:POV1]EXPFLG(NE)    = [V]CST_ANO
        [M:POV1]PBUCOD(NE)    = [F:PJBU]PBUCOD
        [M:POV1]PBUIMP(NE)    = [F:PJBU]PBUIMP
        [M:POV1]STATE(NE)     = [F:PJBU]PBUSTATE
        [M:POV1]KEYCONCAT(NE) = [F:PJBU]KEYCONCAT
        [M:POV1]FCY(NE)       = [F:PJBU]PBUFCY
        [M:POV1]CREDAT(NE)    = [F:PJBU]CREDAT
        [M:POV1]CLE1(NE)      = [F:PJBU]PBUCOD
        [M:POV1]COD(NE)       = [F:PJBU]PBUCOD
        [M:POV1]CODE(NE)      = "PJMBUD"
        [M:POV1]ORI(NE)       = "PJMBUD"
        # --------------------------
        If [F:PJBU]PBUIMP = [V]CST_ANO Then
          [M:POV1]ICO(NE) = "Folder.gif"
        Else
          [M:POV1]ICO(NE) = "Book.gif"
        Endif
        SAV_NE = NE
        Call CMT_LOAD_TREEVIEW_BUD(NE)
        Call LOAD_TREEVIEW_BUDLIG(NE, SAV_NE)
        Call LOAD_TREEVIEW_BUDTAS([F:PJBU]PBUCOD, NE, SAV_NE)
      Endif
    Next
    Filter [PJBU]
  Endif
End

