#######################################################################################
Subprog LOAD_TREEVIEW_BUDLIG(NE, ISAV_NE)
Variable Integer NE
Value Integer ISAV_NE

Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array
Local Integer SAV_NE
Local Integer IFIRST

  If [M:POV0]BUDLIN = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
    # --------------------------
    Gosub LOCAL_FILE_PJMBUDLIG
    # --------------------------
    IFIRST = [V]CST_AYES
    Filter [PJLB] Where evalue(SFILTER) and [F:PJLB]OPPNUM = [F:PJBU]OPPNUM and [F:PJLB]PBUCOD = [F:PJBU]PBUCOD
    For [PJLB]
      If IFIRST = [V]CST_AYES Then
        IFIRST = [V]CST_ANO
        SAV_NE = ISAV_NE
        If func INCREASE_LINE(NE) = [V]CST_AERROR Then
          Break
        Endif
        [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
        [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + mess(505,2260,1)
        [M:POV1]OBJDES(NE) = mess(505,2260,1)
        [M:POV1]EXPFLG(NE) = [V]CST_ANO
        [M:POV1]PSDLVL(NE) = [V]CST_AYES
        SAV_NE = NE
      Endif
      If func INCREASE_LINE(NE) = [V]CST_AERROR Then
        Break
      Endif
      [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
      [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + num$([F:PJLB]PLBSEQ)
      [M:POV1]OBJDES(NE) = num$([F:PJLB]PLBSEQ) - ":" - func GET_PLBDESAXX([F:PJLB]OPPNUM, [F:PJLB]PBUCOD, [F:PJLB]PLBSEQ)
      [M:POV1]EXPFLG(NE) = [V]CST_ANO
      [M:POV1]ICO(NE)    = "287.png"
      [M:POV1]PBUCOD(NE) = [F:PJBU]PBUCOD
      [M:POV1]PLBSEQ(NE) = [F:PJLB]PLBSEQ
      [M:POV1]CLE1(NE)   = [F:PJBU]PBUCOD
      [M:POV1]COD(NE)    = [F:PJBU]PBUCOD
      [M:POV1]CODE(NE)   = "PJMBUD"
      [M:POV1]ORI(NE)    = "PJMBUD"
      Call CMT_LOAD_TREEVIEW_BUDLIG(NE)
    Next
  Endif
End

#######################################################################################
# Issue X3-91018 - 2018-05-21 by TEJAC/FGR : END
Subprog LOAD_TREEVIEW_BUDTAS(SPBUCOD, NE, ISAV_NE)
Value Char SPBUCOD
Variable Integer NE
Value Integer ISAV_NE

Local Char SFILTER(250)(0..)
Local Char SFILTER1(250)(0..)
Local Integer SAV_NE
Local Integer IPARENT_ITM_OPE
Local Integer IEXIST_TASCOD
Local Integer NZ
Local Integer ILINETAS
Local Char STBCOD(GLONTAC)(1..)
Local Integer IRET
Local Char STASCOD(GLONTAC)
Local Integer ILOAD_LINE

  If [M:POV0]TAS = [V]CST_AYES Then
    Call LOAD_FILTER(SFILTER)
    Call GET_PJMTAS_FILTER(SFILTER1)
    # --------------------------
    Gosub LOCAL_FILE_PJMTSK
    Gosub LOCAL_FILE_PJMTSK_2
    Gosub LOCAL_FILE_PIMPL
    #
    Local File PJMTSKCAT [PTC]
    #Link [F:PJTA] With [F:PTC]CTA0=[F:PJTA]TCACOD As [LNK]                    # Issue X3-91330 - 2018-06-19 by FGR : add sorted index
    Link [F:PJTA] With [F:PTC]CTA0=[F:PJTA]TCACOD
&                   As [LNK]
&             Order By Key KEY0=[F:PJTA]OPPNUM;[F:PJTA]TASSOR;[F:PJTA]TASCOD   # Issue X3-91330 - 2018-06-19 by FGR : add sorted index
    # --------------------------
    IFIRST = [V]CST_AYES
    Filter [LNK] Where evalue(SFILTER) and [F:PJTA]OPPNUM = [F:PJBU]OPPNUM and [F:PJTA]PBUCOD = SPBUCOD
    For [LNK]KEY0                                                              # Issue X3-91330 - 2018-06-19 by FGR : add sorted index
      # --------------------------------------------------------------------------------------
      # BEGIN : To check if line is going to be loaded or not in the grid
      ILOAD_LINE = [V]CST_ANO
      If evalue(SFILTER1) Then
        ILOAD_LINE = [V]CST_AYES
      Else
        # If budget is a parent, we have to check if its children are going to be displayed.
        # If yes, the parent will have to be displayed.
        # If no, the parent will not be displayed.
        # Careful, the parent could be a parent of a parent : so we have to check all the family
        If func TAS_CHECK_IF_FAMILY_DISPLAY([F:PJTA]OPPNUM, [F:PJTA]TASCOD) = [V]CST_AYES Then
          ILOAD_LINE = [V]CST_AYES
        Endif
      Endif
      # END : To check if line is going to be loaded or not in the grid
      # --------------------------------------------------------------------------------------
      If ILOAD_LINE = [V]CST_AYES Then
        Filter [PIM] Where evalue(SFILTER) and [F:PIM]PIMNUM = [F:PJTA]KEYCONCAT
        Read [PIM]First
        If IFIRST = [V]CST_AYES Then
          IFIRST = [V]CST_ANO
          SAV_NE = ISAV_NE
          If func INCREASE_LINE(NE) = [V]CST_AERROR Then
            Break
          Endif
          [M:POV1]PARKEY(NE) = [M:POV1]KEYC(SAV_NE)
          [M:POV1]KEYC(NE)   = [M:POV1]PARKEY(NE) + "~" + mess(506,2260,1)
          [M:POV1]OBJDES(NE) = mess(506,2260,1)
          [M:POV1]EXPFLG(NE) = [V]CST_ANO
          [M:POV1]PSDLVL(NE) = [V]CST_AYES
          SAV_NE = NE
        Endif
        # --------------------------
        If [F:PJTA]TASPAE = AVOID.ACHAR Then
          If func INCREASE_LINE(NE) = [V]CST_AERROR Then
            Break
          Endif
          [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(SAV_NE)
          [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + [F:PJTA]TASCOD
          [M:POV1]OBJDES(NE)    = [F:PJTA]TASCOD - func PIM_GET_PIMDESAXX([F:PJTA]KEYCONCAT)
          [M:POV1]EXPFLG(NE)    = [V]CST_ANO
          [M:POV1]TASCOD(NE)    = [F:PJTA]TASCOD
          [M:POV1]TASTYP(NE)    = [F:PJTA]TASTYP
          [M:POV1]STATE(NE)     = [F:PJTA]TASSTATE
          [M:POV1]PIMTYP(NE)    = [F:PIM]PIMTYP
          [M:POV1]PIMSTA(NE)    = [F:PIM]PIMSTA
          [M:POV1]KEYCONCAT(NE) = [F:PJTA]KEYCONCAT
          [M:POV1]FCY(NE)       = [F:PJTA]TASFCY
          [M:POV1]CREDAT(NE)    = [F:PJTA]CREDAT
          [M:POV1]CLE1(NE)      = [F:PJTA]TASCOD
          [M:POV1]COD(NE)       = [F:PJTA]TASCOD
          [M:POV1]ORI(NE)       = "PJMTAS"
          [M:POV1]CODE(NE)      = "PJMTAS"
          If func TAS_IS_PARENT([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE)) = [V]CST_AYES Then
            [M:POV1]ICO(NE) = "Folder.gif"
          Else
            [M:POV1]ICO(NE) = func PJMTSK_CSTD_PROGS.GET_ICON([F:PIM]PIMTYP)
          Endif
          Call CMT_LOAD_TREEVIEW_TAS("", NE)
        Else
          # In this case you have to load in the grid all the parents of the task
          # Careful to not corrupt SAV_NE which is the header of this node
          # To have all the parents you can use the OPPORPJM.TAS_GET_FAMILY method
          ILINETAS = func GET_INDEX_AMK_TASCOD([F:PJTA]TASPAE, NE)
          If ILINETAS = 0 Then
            # Task branch family has not been yet created
            # --------------------------
            # Get all the parents, from the current task
            IRET = func TAS_GET_PARENTS([F:PJTA]OPPNUM, [F:PJTA]TASCOD, STBCOD)
            For NZ = maxtab(STBCOD) To 1 Step -1
              If STBCOD(NZ) <> AVOID.ACHAR Then
                Filter [PJTA2] Where evalue(SFILTER) and [F:PJTA2]OPPNUM = [F:PJTA]OPPNUM and [F:PJTA2]TASCOD = STBCOD(NZ)
                Read [PJTA2]First
                Filter [PIM] Where evalue(SFILTER) and [F:PIM]PIMNUM = [F:PJTA2]KEYCONCAT
                Read [PIM]First
                If func INCREASE_LINE(NE) = [V]CST_AERROR Then
                  Break
                Endif
                [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(SAV_NE)
                SAV_NE = NE
                [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + [F:PJTA2]TASCOD
                [M:POV1]OBJDES(NE)    = [F:PJTA2]TASCOD - func PIM_GET_PIMDESAXX([F:PJTA2]KEYCONCAT)
                [M:POV1]EXPFLG(NE)    = [V]CST_ANO
                [M:POV1]TASCOD(NE)    = [F:PJTA2]TASCOD
                [M:POV1]TASTYP(NE)    = [F:PJTA2]TASTYP
                [M:POV1]STATE(NE)     = [F:PJTA2]TASSTATE
                [M:POV1]PIMTYP(NE)    = [F:PIM]PIMTYP
                [M:POV1]PIMSTA(NE)    = [F:PIM]PIMSTA
                [M:POV1]KEYCONCAT(NE) = [F:PJTA2]KEYCONCAT
                [M:POV1]FCY(NE)       = [F:PJTA2]TASFCY
                [M:POV1]CREDAT(NE)    = [F:PJTA2]CREDAT
                [M:POV1]CLE1(NE)      = [F:PJTA2]TASCOD
                [M:POV1]COD(NE)       = [F:PJTA2]TASCOD
                [M:POV1]ORI(NE)       = "PJMTAS"
                [M:POV1]CODE(NE)      = "PJMTAS"
                If func TAS_IS_PARENT([F:PJTA2]OPPNUM, [M:POV1]TASCOD(NE)) = [V]CST_AYES Then
                  [M:POV1]ICO(NE) = "Folder.gif"
                Else
                  [M:POV1]ICO(NE) = func PJMTSK_CSTD_PROGS.GET_ICON([F:PIM]PIMTYP)
                Endif
                Call CMT_LOAD_TREEVIEW_TAS("PJTA2", NE)
                Filter [PJTA2]
              Endif
            Next NZ
          Else
            # Task branch family has been created : (ILINETAS) is the parent line index
            If func INCREASE_LINE(NE) = [V]CST_AERROR Then
              Break
            Endif
            [M:POV1]PARKEY(NE)    = [M:POV1]KEYC(ILINETAS)
            [M:POV1]KEYC(NE)      = [M:POV1]PARKEY(NE) + "~" + [F:PJTA]TASCOD
            [M:POV1]OBJDES(NE)    = [F:PJTA]TASCOD - func PIM_GET_PIMDESAXX([F:PJTA]KEYCONCAT)
            [M:POV1]EXPFLG(NE)    = [V]CST_ANO
            [M:POV1]TASCOD(NE)    = [F:PJTA]TASCOD
            [M:POV1]TASTYP(NE)    = [F:PJTA]TASTYP
            [M:POV1]STATE(NE)     = [F:PJTA]TASSTATE
            [M:POV1]PIMTYP(NE)    = [F:PIM]PIMTYP
            [M:POV1]PIMSTA(NE)    = [F:PIM]PIMSTA
            [M:POV1]FCY(NE)       = [F:PJTA]TASFCY
            [M:POV1]KEYCONCAT(NE) = [F:PJTA]KEYCONCAT
            [M:POV1]CREDAT(NE)    = [F:PJTA]CREDAT
            [M:POV1]CLE1(NE)      = [F:PJTA]TASCOD
            [M:POV1]COD(NE)       = [F:PJTA]TASCOD
            [M:POV1]ORI(NE)       = "PJMTAS"
            [M:POV1]CODE(NE)      = "PJMTAS"
            If func TAS_IS_PARENT([F:PJTA]OPPNUM, [M:POV1]TASCOD(NE)) = [V]CST_AYES Then
              [M:POV1]ICO(NE) = "Folder.gif"
            Else
              [M:POV1]ICO(NE) = func PJMTSK_CSTD_PROGS.GET_ICON([F:PIM]PIMTYP)
            Endif
            Call CMT_LOAD_TREEVIEW_TAS("", NE)
          Endif
        Endif
        # --------------------------
        # To write it the same way
        IPARENT_ITM_OPE = NE
        Call LOAD_TREEVIEW_TAS_ITM(NE, IPARENT_ITM_OPE)
        Call LOAD_TREEVIEW_TAS_OPE(NE, IPARENT_ITM_OPE)
        # --------------------------
        Filter [PIM]
      Endif
    Next
    Filter [LNK]
  Endif
End

