End

######################################################################################
Subprog AM_TASENDDT(VALEUR)
Variable Date    VALEUR

  # Issue X3-91018 - 2018-05-23 by TEJAC
  If [M:POV0]TASSTARTDAT <> AVOID.ADATE Then
    If [M:POV0]TASSTARTDAT > VALEUR Then
