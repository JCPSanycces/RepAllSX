#<AdxTL>@(#)3.0.0.0 $Revision$
# Classe TABCTL

$ACTION
Case CURPRO
    When ""         : Gosub METHODS
Endcase
Return

###############
# METHODS
###############
$METHODS
Case CURPTH
   When ""
     Case ACTION
       When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
       When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
       When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
       When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
       When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
     Endcase
Endcase
Return

#################### Standard Query Events #########################

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "TCT"
TBTYP(NBPRO) = 7
TBPTH(NBPRO) = "TCT.TCT"
TBFIL(NBPRO) = "[LNK_]TCT"
#
NBPRO += 1
TBPRO(NBPRO) = "TCTDES"
TBTYP(NBPRO) = 7
TBPTH(NBPRO) = "TCT.TCTDES"
TBFIL(NBPRO) = "[LNK_]TCTDES"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]TCT"
Return

$AQUERY_OPEN_AFTER
Local File TABCTL [TCT]
Local Integer I : I=0
Local Char TTCT(8)(1..)
Local Char TTCTDES(30)(1..)
For [TCT]TCT0(1)
 I+=1
 TTCT(I) = [F:TCT]TCT
# TTCTDES(I) = #Lecture de ATEXTRA
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = "TABCTL";"TCTDESAXX";"FRA";[F:TCT]TCT;""
If !fstat
   TTCTDES(I)= [F:AXX]TEXTE
Endif

Next
Local File (Char TCT    (8), Char TCTDES (30)) From Variable TTCT,TTCTDES As [LNK_]
Return

$AQUERY_TRANS_AFTER
this.TCT.TCT    = [LNK_]TCT
this.TCT.TCTDES = [LNK_]TCTDES
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return



$PROPERTIES
Return



#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

