#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################
## Intégration d'une action
###################################################
$ACTION
Read [ACT]ACTION = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ACT
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If dim([F:ACT]CODACT)>0 & [F:ACT]CODACT>="X" & !find([F:ACT]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              Gosub TR_ACT
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          Gosub TR_ACT
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:ACT]
      Gosub TR_ACT
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_ACT
Call DEBTRANS From GLOCK
Trbegin [ACT] , [ATR]
Delete [ATR] Where ACTION=[L]NOMOBJ
Delete [ACT] Curr
If fstat
      GOK = 0 : ER = 99 : ERFIC = "ACTION"-NOMOBJ : Rollback :  Return
Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACT",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------#
#-------------------#
$TR_ACT
Call DEBTRANS From GLOCK

Trbegin [ACT] , [ATR] , [AAR]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ACT"   : Gosub ACT1
     When "ATR"   : Gosub ACT2
     When "AAR"   : Gosub ACT3
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACT",[L]NOMOBJ,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return


$ACT1
FICHIER = "ACTION" : ABR = "ACT"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If find(VARIA,"SPETRT")
    If [F:ACT]SPETRT<>"" & TYPPTC<>3
     OK = 0
    Endif
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ACT]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
# test about code act on header Doesn't apply to a SCM environ. on root folder
# but no need to test ISFULLMOD here because test with GDOSX3 is done.
ACVOBJ = [F:ACT]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
   Read [ACV]CODACT = ACVOBJ
   If fstat | [F:ACV]FLACT<>2
      OKOBJ = 0 : Return
   Endif
Endif
If NEWOBJ
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("ACT") From OBJDIV
   Endif
   Write [ACT]
   If fstat
        Call LOG_ERROR_DETAILS(1, "ACT",num$([F:ACT]ACTION),"") From GLOCK
   Endif
Else
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("ACT") From OBJDIV
  Endif
  Rewrite [ACT]
  If fstat
        Call LOG_ERROR_DETAILS(2, "ACT",num$([F:ACT]ACTION),"") From GLOCK
  Endif
Endif
If fstat
     GOK = 0 : ER = 99 : ERFIC = "ACTION"-NOMOBJ : Return
Endif

## Effacement des paramètres
Delete [ATR] Where ACTION=NOMOBJ
Return

$ACT2
FICHIER = "ACTPAR" : ABR = "ATR"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [ATR]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACTPAR"-NOMOBJ-[F:ATR]CODPAR : Return
Endif
Return

$ACT3
FICHIER = "ACTCODPAR" : ABR = "AAR"
Read [AAR]CODPAR = IDENT
If fstat
 NEWZON = 1
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [AAR]
Else
 Rewrite [AAR]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACTCODPAR"-[F:AAR]CODPAR : Return
Endif
Return

$ABORT
Rollback
Return

