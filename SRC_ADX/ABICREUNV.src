#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABICREUNV","ABICREUNV",3,"") From GTRAITE
End

##############################################################################################################
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return


$TERMINE
If [M:DIA]TEST = 2
 [M:DIA]UNIVERS = ""
 SAI = 1
Endif
Return

$INIT
Return

$INIT_DIA
Raz [M:DIA]
[M:DIA]EXPORT  = 1
[M:DIA]AUTSIT  = 1
[M:DIA]LANGORI = "FRA"
[M:DIA]LANGDES = GLANGUE
If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif
Return

$SEL_LISTE
Case LISTE
 When "ABISELABM" : Gosub SELABM
Endcase
Return

$EXEC
If GINFO
 Call OUVRE_VLC(mess(39,148,1),"","") From GESECRAN : # "Création de l'univers"
 Call AFF_VLC(mess(2,100,1),UNIVERS) From GESECRAN  : #  : Vérification en cours ...
Endif
Local Char APPLI(GLONADS)
APPLI = nomap
If !GSERVEUR
 Call OUVRE_TRACE(mess(39,148,1)-[M:DIA]DATAM) From LECFIC
Endif
Gosub CREA_UNIVERS
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
If GINFO
 Call FERME_VLC From GESECRAN
Endif
TRA = 1
Return

$CREA_UNIVERS
Local Integer   I , J , K , T ,N , NBTRA , IANSI
Local Integer   NBACS , OKACC , NBHIE ,STAT
Local Char      DIMACS(GLONABI)(1..50)
Local Char      CHAINES(255) , CHAMP(20) , LIGNE(255)
Local Integer   NBOBJET : NBOBJET = 2500
Local Integer   NBHIERA   : NBHIERA = 100

GPOINT = "INITMAX" : Gosub ENTREE From EXEFNC : # Init max

Local Char      TCLASSE2(80)(1..NBOBJET),TSCLASSE2(80)(1..NBOBJET),TCLAOBJ(160)(1..NBOBJET),TOBJ2(80)(1..NBOBJET),TSCLASSE2SS(160)(1..NBOBJET)
Local Integer   NBOBJ2,TORD2(1..NBOBJET),NIV(1..NBOBJET)
Local Char      HIERACH(255)(0..NBHIERA),HIERACH2(255)(0..NBHIERA),HIERACH3(255)(0..NBHIERA),HIERACH4(255)(0..NBHIERA)
Global Integer  GLIGNE1000 : GLIGNE1000 = 0
Local  Char     SERVEUR(250)
Local  Char     REPSRV(250)
Local  Char     DOSSIER(30)
Local  Char     DATABASE(10)
Local  Char     UNIVORI(12)
Local  Char     REPWORK(GDIMFIC)
Local  Char     FOLDDES(80)
Local Integer   DUREES,RESULTS
Local Char      TYPBDA(10),SOLBI(100)


If clalev([M:ATV2])=0 : Local Mask ATV2                [ATV2] : Endif

Gosub OUVRE_TABLE

##### Verification hierachie, champ,dim,acces
OK = 1
Read [F:ABW]ABW0 = [M:DIA]DATAW
Read [F:ABM]ABM0 = [M:DIA]DATAM
Call VERIF_INTITULE_VARIABLE([M:DIA]DATAM,[L]APPLI,OK)
If !OK : Return : Endif
Gosub VERIF_HIERARCHIE
If STAT : OK =0 : Return : Endif
For T=1 To [F:ABM]NBRABF
 If func ACTIV([F:ABM]ACTABF(T-1))
  TABLE = [F:ABM]CODABF(T-1)
  Read [ABF]ABF0 = TABLE
  If func ACTIV([F:ABF]CODACT)
   Call ECR_TRACE(mess(48,148,1)-TABLE,0) From GESECRAN
   Gosub VERIF_CHAMP
   Gosub VERIF_DIM
   Gosub VERIF_ACCES
  Endif
 Endif
Next T
If !OK : Return : Endif
### Verif ou creation du repertoire distant
Local Char    CHEMIN(250)
Local Integer EXISTE
Call RECHPROP("component.busobj.servername",[M:DIA]MACHINE,GBIDI1) From INTRUTILA
Call RECHPROP("busobj.adxadmin.port",[M:ATV2]SERV,GBIDI1) From INTRUTILA
Call RECHPROP("busobj.tools.path",[M:DIA]REPERT,GBIDI1)From INTRUTILA
Call VAR_BOWORLD("name","","",[M:DIA]CONNEX,GBIDI1) From ABICREBAS
Call VAR_BOWORLD("dblink","","",[M:ATV2]SERV_ODBC,GBIDI1) From ABICREBAS
[M:DIA]SERVEUR = [M:DIA]MACHINE
[M:DIA]MACHINE += ":"+[M:ATV2]SERV
[M:DIA]REPERT  += +"\BO_GEN"
Call VARADX("ADXDIR",[M:DIA]MACHINE+":"+[M:ATV2]SERV,[M:ATV2]REPADXDIR) From ADXD
Call RECHPROP("component.busobj.name",[M:ATV2]COMPBONAM,GBIDI1) From INTRUTILA

Raz GBIDC1
Call VARADX("ADXDIR",[M:DIA]MACHINE,GBIDC1) From ADXD
If GBIDC1=""
 OK = 0 : Call ECR_TRACE("("+[M:DIA]MACHINE+") busobj.adxadmin not available" ,1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
 Return
 End
Endif

### Verif dossier
Local Char    CHEMIN(250)
Local Integer EXISTE
CHEMIN = [M:DIA]MACHINE+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM

Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME([M:DIA]MACHINE,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM,"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
CHEMIN = [M:DIA]MACHINE+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\BO_GEN'
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME([M:DIA]MACHINE,"ae_mkdir"-[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\BO_GEN',"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If !EXISTE
  OK = 0 : Call ECR_TRACE(mess(221,133,1),1) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  Return
 Endif
Endif
Read [ABW]ABW0 = [M:DIA]DATAW
Read [ABM]ABM0 = [M:DIA]DATAM
If [F:ABM]RESULT = 0
 RESULTS = 5000
Else
 RESULTS = [F:ABM]RESULT
Endif
If [F:ABM]DUREE = 0
 DUREES = 600
Else
 DUREES = [F:ABM]DUREE * 60
Endif
IANSI = [F:ABM]ANSI
[M:ATV2]MACHINE = [M:DIA]MACHINE
[M:DIA]CONNEX   = [M:DIA]CONNEX+"_"+[F:ABW]COD
SERVEUR  = toupper([M:DIA]SERVEUR)
REPSRV   = SERVEUR
REPWORK  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\BO_GEN'
[M:ATV2]LANGORI  = [M:DIA]LANGORI
[M:ATV2]LANGDES  = [M:DIA]LANGDES
[M:ATV2]DATAMORI = [M:DIA]DATAM
If [M:DIA]UNIVERS = "" | ( [M:DIA]EXPORT = 2 & [M:DIA]TEST <> 2 ) : # Création du fichier tool
 Local    Char FICHIER(GDIMFIC)
 [M:ATV2]DATAW = [M:DIA]DATAW
 [M:ATV2]USRBI ="Admin"
 [M:ATV2]DATAMORI = [M:DIA]DATAM
 Gosub INIT_DIA From SUBATV2 : # Creation du fichier tool.xml
 If OK=0 : Return : Endif
 FICHIER = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL
Endif
If [M:DIA]UNIVERS = "" : # Calcul du nom de l'univers
 Call FIND_UNV([F:ABM]ABR,[L]FICHIER,[L]UNIVORI,GBIDC1,GBIDI1) From SUBATV2 : # recup du nouveau nom d'univers
 UNIVORI        = left$(UNIVORI,instr(1,UNIVORI,"&&&")-1)
 [M:DIA]UNIVERS = left$(GBIDC1,instr(1,GBIDC1,"&&&")-1)
Endif
If [M:DIA]EXPORT = 2 & [M:DIA]TEST <> 2 : # Calcul de l
 Gosub LIT_TOOL From ABIMAP
 Gosub FIND_FOLD_UNIV
Endif
##### Recup des données SGBD
Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",[L]TYPBDA,GBIDI1) From ABICREBAS
If [L]TYPBDA="ORACLE"
 DATABASE = "oracle"
 [L]DOSSIER  = [F:ABW]COD
Elsif [L]TYPBDA="SQLSERVER"
 DATABASE = "sql"
 # Nom de la base
 Call VAR_BOWORLD("name",[F:ABW]SOLBI,"database",[L]DOSSIER,GBIDI1) From ABICREBAS
 [L]DOSSIER  += "."+[F:ABW]COD
Endif
#### Creation de l'univers
Call CREATION_UNIVERS(APPLI,[M:DIA]MACHINE,SERVEUR,[M:DIA]REPERT,[L]REPWORK
&                     ,REPSRV,[M:DIA]UNIVERS,[L]DOSSIER,[M:DIA]CONNEX,([M:DIA]EXPORT=2),[M:DIA]DATAM
&                     ,[M:DIA]DATAW,[M:DIA]TEST,[L]HIERACH,[L]HIERACH2,[L]HIERACH3,[L]HIERACH4,[L]NBHIE,[L]DATABASE,[M:ATV2]SERV_ODBC,[L]FOLDDES,[M:DIA]LANGDES,DUREES,RESULTS
&                     , EXPR_CLE,EXPR_ID,EXPR_NOM,EXPR_CND1,EXPR_CND2,EXPR_CND3,EXPR_NB,STAT,[L]SOLBI,IANSI)
If STAT : Return : Endif
If [M:DIA]TEST = 2
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE ("# Fichier description de l'univers "-[M:DIA]UNIVERS,0) From GESECRAN
 Call AJOUT_TRACE([M:DIA]MACHINE+"@"+[L]REPWORK+"\"+[M:DIA]UNIVERS+".txt")
 GBIDC1 = 'ae_rm "'+REPWORK +"\"+[M:DIA]UNIVERS+".txt"+'"'
 Call SYSTEME2([M:DIA]MACHINE,GBIDC1,"",GBIDI1,GBIDC2) From ORDSYS
 Gosub EFF_FICHIER From SUBATV2
Else
 If [M:DIA]EXPORT = 2 & [M:DIA]TRAD = 2
  ## Mapping des etats
  Gosub MAPPING
 Endif
 Gosub EFF_FICHIER From SUBATV2
 [M:DIA]UNIVERS = ""
Endif
Return

$SELABM
Local Integer NBTEX , NUM
Local Char    INTIT(30)
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..3) , TIT(GLONDES)(0..3)
NBTEX = 0
If clalev([F:ABW])=0 : Local File ABIDATWRH [F:ABW] : Endif
If clalev([F:ABM])=0 : Local File ABIDATMRT [F:ABM] : Endif
Read [F:ABW]ABW0 =  PARAM(1)
If !fstat
 For I=0 To [F:ABW]NBRABM-1
  Read [F:ABM]ABM0 = [F:ABW]CODABM(I)
  If !fstat
   NBTEX += 1
   Call TEXTE([F:ABM]INTIT,INTIT) From OBJDIV
   TEX(NBTEX) =[F:ABM]COD
   TEXTE(NBTEX,2) =  [F:ABM]ABR
   TEXTE(NBTEX,3) =  INTIT
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Next I
Endif
TIT(0) = mess(41,127,1)  : # Datamart
TIT(1) = mess(41,127,1)  : # Datamart
TIT(2) = mess(1,16,1)    : # abreviation
TIT(3) = mess(30,109,1)  : # Intitulé
Return

$OUVRE_TABLE
If filinfo(filpath("FIL","ABIDATWRH","fde",[L]APPLI),0)>=0
 If clalev([F:ABW])=0  : Local File =APPLI+".ABIDATWRH" [ABW]  : Endif
Endif
If clalev([F:ABM])=0  : Local File =APPLI+".ABIDATMRT" [ABM]  : Endif
If clalev([F:ABF])=0  : Local File =APPLI+".ABITABDAT" [ABF]  : Endif
If clalev([F:ABZ])=0  : Local File =APPLI+".ABITABFLD" [ABZ]  : Endif
If clalev([F:ABK])=0  : Local File =APPLI+".ABITABLNK" [ABK]  : Endif
If clalev([F:ABE])=0  : Local File =APPLI+".ABITABAGG" [ABE]  : Endif
If clalev([F:ABI])=0  : Local File =APPLI+".ABIDIM"    [ABI]  : Endif
If clalev([F:ABJ])=0  : Local File =APPLI+".ABIDIMFLD" [ABJ]  : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"     [ACV]  : Endif
If clalev([F:AHH])=0  : Local File =APPLI+".ABIHIERA"  [AHH]  : Endif
If clalev([F:ABO])=0  : Local File =APPLI+".ABIREPORT" [ABO]  : Endif
If clalev([F:ATV2])=0 : Local File =APPLI+".ABITRAUNV" [ATV2] : Endif
If clalev([F:ATV])=0  : Local File =APPLI+".ABITRAUNV" [ATV]  : Endif
If clalev([F:AII])=0  : Local File =APPLI+".ABICOND"   [AII]  : Endif
If clalev([F:ATX])=0  : Local File =APPLI+".ATEXTE"    [ATX]  : Endif
If clalev([F:ATX2])=0 : Local File =APPLI+".ATEXTE"    [ATX2] : Endif
If clalev([F:ABZ2])=0 : Local File =APPLI+".ABITABFLD" [ABZ2] : Endif
If clalev([F:ABX])=0  : Local File =APPLI+".ABITABIND" [ABX]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"     [ATY]  : Endif
If clalev([F:TLA])=0  : Local File =APPLI+".TABLAN"    [TLA]  : Endif
Return

$VERIF_HIERARCHIE

Local Integer   NBOBJET : NBOBJET = 2500
Local Integer   NBHIERA   : NBHIERA = 100

GPOINT = "INITMAX" : Gosub ENTREE From EXEFNC : # Init max

Local Char     TABDEF(80)(1..NBOBJET),CHPDEF(80)(1..NBOBJET),TABDEF2(250)(1..NBOBJET)
Local Char     TYPDEF(80)(1..NBOBJET),TABLE(80)(1..NBOBJET),CHAMP(80)(1..NBOBJET)
STAT = 0
Call CRE_CLASS_OBJ_INF(APPLI,[M:DIA]DATAM,TCLASSE2,TSCLASSE2,TSCLASSE2SS,TCLAOBJ,TOBJ2,TORD2,TABDEF,CHPDEF,TABDEF2,TYPDEF,TABLE,CHAMP,NBOBJ2,[M:DIA]LANGDES,STAT) From ABICREDES
If STAT : Return : Endif
Call ECR_TRACE(mess(62,148,1)-[M:DIA]DATAM,0) From GESECRAN
For [F:AHH]AHH0 Where ABM = [M:DIA]DATAM
 If  func ACTIV([F:AHH]ACV)
  HIERACH(NBHIE) =  func ABICREDES.TEXTEBI([F:AHH]DES,[F:AHH]INTEVAL,[M:DIA]LANGDES)
  For I=0 To [F:AHH]NBAHH-1
   CHAINES = [F:AHH]CODABF(I)-[F:AHH]CODFLD(I)-[F:AHH]TYPOPT(I)
   If [F:AHH]CODDIM1(I) <> ""
    CHAINES -= [F:AHH]CODDIM1(I)+";"+[F:AHH]FLDDIM1(I)
    If [F:AHH]CODDIM2(I) <> ""
     CHAINES += ";"+[F:AHH]CODDIM2(I)+";"+[F:AHH]FLDDIM2(I)
     If [F:AHH]CODDIM3(I) <> ""
      CHAINES += ";"+[F:AHH]CODDIM3(I)+";"+[F:AHH]FLDDIM3(I)
      If [F:AHH]CODDIM4(I) <> ""
       CHAINES += ";"+[F:AHH]CODDIM4(I)+";"+[F:AHH]FLDDIM4(I)
       If [F:AHH]CODDIM5(I) <> ""
        CHAINES += ";"+[F:AHH]CODDIM5(I)+";"+[F:AHH]FLDDIM5(I)
        If [F:AHH]CODDIM6(I) <> ""
         CHAINES += ";"+[F:AHH]CODDIM6(I)+";"+[F:AHH]FLDDIM6(I)
         If [F:AHH]CODDIM7(I) <> ""
          CHAINES += ";"+[F:AHH]CODDIM7(I)+";"+[F:AHH]FLDDIM7(I)
          If [F:AHH]CODDIM8(I) <> ""
           CHAINES += ";"+[F:AHH]CODDIM8(I)+";"+[F:AHH]FLDDIM8(I)
           If [F:AHH]CODDIM9(I) <> ""
            CHAINES += ";"+[F:AHH]CODDIM9(I)+";"+[F:AHH]FLDDIM9(I)
           Endif
          Endif
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
   K =0
   For J=1 To NBOBJ2
    If vireblc(CHAINES,2) =  vireblc(TABDEF(J)-CHPDEF(J)-TYPDEF(J)-TABDEF2(J),2)
     K =1 : Break
    Endif
   Next J
   If K=1
    If (len(HIERACH(NBHIE)) + len(','+TCLAOBJ(J)+","+TOBJ2(J))) < 255 & HIERACH2(NBHIE) = ""
     HIERACH(NBHIE) +=   ','+TCLAOBJ(J)+","+TOBJ2(J)
    Elsif (len(HIERACH2(NBHIE)) + len(','+TCLAOBJ(J)+","+TOBJ2(J))) < 255  & HIERACH3(NBHIE) = ""
     HIERACH2(NBHIE) +=   ','+TCLAOBJ(J)+","+TOBJ2(J)
    Elsif (len(HIERACH3(NBHIE)) + len(','+TCLAOBJ(J)+","+TOBJ2(J))) < 255  & HIERACH4(NBHIE) = ""
     HIERACH3(NBHIE) +=   ','+TCLAOBJ(J)+","+TOBJ2(J)
    Else
     HIERACH4(NBHIE) +=   ','+TCLAOBJ(J)+","+TOBJ2(J)
    Endif
   Else
    Call ECR_TRACE(mess(43,127,1)-[F:AHH]COD-"("+func ABICREDES.TEXTEBI([F:AHH]DES,[F:AHH]INTEVAL,[M:DIA]LANGDES)+") :"-mess(161,123,1)-":"-CHAINES,1) From GESECRAN : #  Objet inexistant
    Break
   Endif
  Next I
  If K
   If (NBHIE+1) > NBHIERA
    OK = 0
    Call ECR_TRACE(mess(13,114,1)-":"-mess(43,127,1)-">"-num$(NBHIERA),1) From GESECRAN : #  trop de hierarchie  : Dépassement de compteur
    Break
   Endif
   NBHIE +=1
  Endif
 Endif
Next AHH

$CONDITIONS
#### Tableau des conditions
Local Integer NBCOND : NBCOND = 100
Local Char    EXPR_CND1(250)(0..NBCOND),EXPR_CND2(250)(0..NBCOND),EXPR_CND3(250)(0..NBCOND)
Local Char    EXPR_CLE(80)(0..NBCOND),EXPR_NOM(80)(0..NBCOND),EXPR_ID(80)(0..NBCOND)
Local Integer EXPR_NB,OKCND,FINS ,OKTROP, N , M
Local Char    TEXTE(80) , NOM(80) , INVITE(80) , EXPR2(250)
Local Clbfile EXPR(2)
Local Char    TYPBDA(10)

Call ECR_TRACE(mess(95,148,1)-[M:DIA]DATAM,0) From GESECRAN

For [AII]AII1 Where ABM=[M:DIA]DATAM & ACV<"X"
 Gosub COND1
 If OKTROP : Break : Endif
Next AII

For [AII]AII1 Where ABM=[M:DIA]DATAM & ACV>="X"
 Gosub COND1
 If OKTROP : Break : Endif
Next AII
If OKTROP : OK =0 : Return : Endif
Return

$COND1
OKCND = 1
If [F:AII]ACV<>""
 Read [ACV]CODACT = [F:AII]ACV
 If fstat or [F:ACV]FLACT<>2
  OKCND = 0
 Endif
Endif
If OKCND
 NOM = func ABICREDES.TEXTEBI([F:AII]DES,[F:AII]INTEVAL,[M:DIA]LANGDES)
 N=0
 For M=0 To EXPR_NB-1
  If NOM=EXPR_NOM(M) & [AII]CODABF + "~&" + [AII]CODLNK + "~&" + [AII]EXPLNK = EXPR_CLE(M)
   N=1
   Break
  Endif
 Next M
 If N
  OK=0
  Call ECR_TRACE(NOM-[F:AII]COD-":"-mess(76,148,1),1) From GESECRAN : # Il existe déja une condition ayant le même nom pour cette classe
 Endif
 Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",[L]TYPBDA,GBIDI1) From ABICREBAS
 Case [L]TYPBDA
  When "ORACLE"
   EXPR = [F:AII]CNDORA
   If EXPR="" : EXPR = [F:AII]CNDDEF : Endif
  When "SQLSERVER"
   EXPR = [F:AII]CNDSQL
   If EXPR="" : EXPR = [F:AII]CNDDEF : Endif
 Endcase
 #### TEXTE D'INVITE
 K = instr(1,EXPR,"#txt1")
 While K
  INVITE = func ABICREDES.TEXTEBI([F:AII]TEX,[F:AII]INTVALTEX,[M:DIA]LANGDES)
  If INVITE = "" : EXPR = "" : Break : Endif
  Gosub DOUBLE_APOS
  EXPR = left$(EXPR,K-1)+INVITE+right$(EXPR,K+5)
  K = instr(1,EXPR,"#txt1")
 Wend
 #### OBJ1
 K = instr(1,EXPR,"#obj1")
 While K
  I=0
  Gosub RECUP_NOM_AII
  Gosub AII_NOM
  If INVITE = "" : EXPR = "" : Break : Endif
  Gosub DOUBLE_APOS
  EXPR = left$(EXPR,K-1)+INVITE+right$(EXPR,K+5)
  K = instr(1,EXPR,"#obj1")
 Wend
 #### FLD1
 K = instr(1,EXPR,"#fld1")
 While K
  I=0
  Gosub RECUP_NOM_AII
  Gosub AII_TABLE_CHAMP
  If INVITE = "" : EXPR = "" : Break : Endif
  EXPR = left$(EXPR,K-1)+INVITE+right$(EXPR,K+5)
  K = instr(1,EXPR,"#fld1")
 Wend
 #### OBJ2
 K = instr(1,EXPR,"#obj2")
 While K
  I=1
  Gosub RECUP_NOM_AII
  Gosub AII_NOM
  If INVITE = "" : EXPR = "" : Break : Endif
  Gosub DOUBLE_APOS
  EXPR = left$(EXPR,K-1)+INVITE+right$(EXPR,K+5)
  K = instr(1,EXPR,"#obj2")
 Wend
 #### FLD2
 K = instr(1,EXPR,"#fld2")
 While K
  I=1
  Gosub RECUP_NOM_AII
  Gosub AII_TABLE_CHAMP
  If INVITE = "" : EXPR = "" : Break : Endif
  EXPR = left$(EXPR,K-1)+INVITE+right$(EXPR,K+5)
  K = instr(1,EXPR,"#fld2")
 Wend

 K = instr(1,EXPR,'===')
 If K
  L = instr(K+1,EXPR,'===')
  If L
   EXPR = left$(EXPR,K-1)+evalue(seg$(EXPR,K+3,L-1))+right$(EXPR,L+3)
  Endif
 Endif
 DEB=instr(1,EXPR,"|")
 While DEB
  FINS=instr(DEB+1,EXPR,"|")
  EXPR = left$(EXPR,DEB-1)+evalue(seg$(EXPR,DEB+1,FINS-1))+right$(EXPR,FINS+1)
  DEB=instr(1,EXPR,"|")
 Wend
 If EXPR <> ""
  EXPR_CLE(EXPR_NB) = [AII]CODABF + "~&" + [AII]CODLNK + "~&" + [AII]EXPLNK
  EXPR_ID(EXPR_NB)  = [F:AII]COD
  EXPR_NOM(EXPR_NB) = NOM
  If len(EXPR) <= 250
   EXPR_CND1(EXPR_NB) = EXPR
  Else
   EXPR_CND1(EXPR_NB) = left$(EXPR,250)
   EXPR = right$(EXPR,251)
   If len(EXPR)<= 250
    EXPR_CND2(EXPR_NB) = EXPR
   Else
    EXPR_CND2(EXPR_NB) = left$(EXPR,250)
    EXPR_CND3(EXPR_NB) = right$(EXPR,251)
   Endif
  Endif
  Raz EXPR
  If EXPR_NB+1>NBCOND
   OKTROP = 1
   Call ECR_TRACE(mess(13,114,1)-":"-mess(44,127,1)-">"-num$(NBHIERA),1) From GESECRAN : #  trop de condition  : Dépassement de compteur
   Return
  Endif
  EXPR_NB +=1
 Endif
Endif
Return

$DOUBLE_APOS
I = instr(1,INVITE,"'")
While I
 If mid$(INVITE,I+1,1)<>"'"
  INVITE = left$(INVITE,I)+"'"+right$(INVITE,I+1)
 Endif
 I = instr(I+2,INVITE,"'")
Wend
Return

$RECUP_NOM_AII
Local Integer KK
CHAINES = ""
If [F:AII]CODABF1(I) <> ""
 CHAINES = [F:AII]CODABF1(I)-[F:AII]CODFLD1(I)-[F:AII]TYPOPT(I)
 If [F:AII]CODDIM1(I) <> ""
  CHAINES -= [F:AII]CODDIM1(I)+";"+[F:AII]FLDDIM1(I)
  If [F:AII]CODDIM2(I) <> ""
   CHAINES += ";"+[F:AII]CODDIM2(I)+";"+[F:AII]FLDDIM2(I)
   If [F:AII]CODDIM3(I) <> ""
    CHAINES += ";"+[F:AII]CODDIM3(I)+";"+[F:AII]FLDDIM3(I)
    If [F:AII]CODDIM4(I) <> ""
     CHAINES += ";"+[F:AII]CODDIM4(I)+";"+[F:AII]FLDDIM4(I)
     If [F:AII]CODDIM5(I) <> ""
      CHAINES += ";"+[F:AII]CODDIM5(I)+";"+[F:AII]FLDDIM5(I)
      If [F:AII]CODDIM6(I) <> ""
       CHAINES += ";"+[F:AII]CODDIM6(I)+";"+[F:AII]FLDDIM6(I)
       If [F:AII]CODDIM7(I) <> ""
        CHAINES += ";"+[F:AII]CODDIM7(I)+";"+[F:AII]FLDDIM7(I)
        If [F:AII]CODDIM8(I) <> ""
         CHAINES += ";"+[F:AII]CODDIM8(I)+";"+[F:AII]FLDDIM8(I)
         If [F:AII]CODDIM9(I) <> ""
          CHAINES += ";"+[F:AII]CODDIM9(I)+";"+[F:AII]FLDDIM9(I)
          If [F:AII]CODDIM10(I) <> ""
           CHAINES += ";"+[F:AII]CODDIM10(I)+";"+[F:AII]FLDDIM10(I)
          Endif
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
Return

$AII_TABLE_CHAMP
KK =0
For J=1 To NBOBJ2
 If vireblc(CHAINES,1) =  vireblc(TABDEF(J)-CHPDEF(J)-TYPDEF(J)-TABDEF2(J),1)
  KK =1 : Break
 Endif
Next J
If KK=1
 INVITE = TABLE(J)+"."+CHAMP(J)+"_0"
Else
 Call ECR_TRACE(mess(44,127,1)-[F:AII]COD-"("+func ABICREDES.TEXTEBI([F:AII]DES,[F:AII]INTEVAL,[M:DIA]LANGDES)+") :"-mess(29,141,1)-":"-CHAINES,1) From GESECRAN : #  Objet inexistant
 INVITE = ""
Endif
Return

$AII_NOM
KK =0
For J=1 To NBOBJ2
 If vireblc(CHAINES,1) =  vireblc(TABDEF(J)-CHPDEF(J)-TYPDEF(J)-TABDEF2(J),1)
  KK =1 : Break
 Endif
Next J
If KK=1
 If TSCLASSE2SS(J) <> ""
  If  TABDEF2(J)<>""
    INVITE = TSCLASSE2(J)-TSCLASSE2SS(J)  #  # bug 81712 23/04/2012 INVITE = TSCLASSE2SS(J)
  Else
   INVITE = TSCLASSE2SS(J)
  Endif
 Else
  INVITE = TSCLASSE2(J)
 Endif
 INVITE += "\"+TOBJ2(J)
 KK= instr(1,INVITE,"'")
 While KK
  INVITE = left$(INVITE,KK-1)+"''"+right$(INVITE,KK+1)
  KK = instr(len(left$(INVITE,KK-1)+"''")+1,INVITE,"'")
 Wend
Else
 Call ECR_TRACE(mess(44,127,1)-[F:AII]COD-"("+func ABICREDES.TEXTEBI([F:AII]DES,[F:AII]INTEVAL,[M:DIA]LANGDES)+") :"-mess(29,141,1)-":"-CHAINES,1) From GESECRAN : #  Objet inexistant
 INVITE = ""
Endif
Return

$VERIF_CHAMP
K = 0
For [ABZ] Where CODABF=TABLE
 If func ACTIV([F:ABZ]ACTFLD)
  K += 1 : Break
 Endif
Next
If K=0
 Call ECR_TRACE(mess(54,148,1),1) From GESECRAN : # Aucun champ actif sur la table
 OK = 0
Endif
Return

$VERIF_DIM
For [ABK] Where CODABF=TABLE
 CHAINE = [F:ABK]EXPLNK
 K = 1
 While CHAINE<>""
  I = instr(1,CHAINE,";")
  If I
   CHAMP  = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CHAMP  = CHAINE
   CHAINE = ""
  Endif
  Read [ABZ]ABZ1 = TABLE;CHAMP
  If !func ACTIV([F:ABZ]ACTFLD)
   K = 0 : Break
  Endif
 Wend
 If K
  Read [ABI]ABI0 = [F:ABK]CODLNK
  If !func ACTIV([F:ABI]CODACT)
   Call ECR_TRACE([F:ABI]CODDIM-":"-mess(55,148,1),1) From GESECRAN : # Dimension inactive
  Else
   K = 0
   For [ABJ] Where CODDIM=[F:ABI]CODDIM
    If func ACTIV([F:ABJ]ACTDIM)
     K += 1 : Break
    Endif
   Next
   If K=0
    Call ECR_TRACE(mess(54,148,1)-[F:ABK]CODLNK,1) From GESECRAN : # Aucun champ actif sur la table
    OK = 0
   Endif
  Endif
 Endif
Next
Return

$VERIF_ACCES
NBACS = 0
If [F:ABF]FLDFCY<>""
 NBACS += 1
 DIMACS(NBACS) = [F:ABF]FLDFCY
Endif
For [ABK] Where CODABF=TABLE
 DIMENSION = [F:ABK]CODLNK
 OKACC = 0
 Call ACCES_DIMENSION(DIMENSION,OKACC,APPLI)
 If OKACC
  NBACS += 1
  DIMACS(NBACS) = [F:ABK]EXPLNK
 Endif
Next
For [ABE] Where CODABF=TABLE
 For K=1 To NBACS
  If !find(DIMACS(K),[F:ABE]LNKAGG(0..[F:ABE]NBRAGD-1))
   Call ECR_TRACE(DIMACS(K)-":"-mess(49,148,1)-[F:ABE]CODAGG,1) From GESECRAN : # Champ non présent dans l'agrégat
   OK = 0
  Endif
 Next K
Next
If !OK
 Call ECR_TRACE("",0) From GESECRAN
Endif
Return


Subprog ACCES_DIMENSION(DIMENSION,OKACC,APPLI)
Value    Char    DIMENSION
Variable Integer OKACC
Value    Char    APPLI
Local File =APPLI+".ABIDIM"    [ABI]
Local File =APPLI+".ABIDIMFLD" [ABJ]
Read [ABI]ABI0 = DIMENSION
If func ACTIV([F:ABI]CODACT)
 For [ABJ] Where CODDIM=DIMENSION
  If func ACTIV([F:ABJ]ACTDIM)
   If CODTYP="ACS"
    OKACC = 1 : Break
   Elsif [F:ABJ]TYPFLD=3
    Call ACCES_DIMENSION([F:ABJ]DIMFAT,OKACC,APPLI)
    If OKACC : Break : Endif
   Endif
  Endif
 Next
Endif
End

Funprog ACTIV(ACTIV)
Value Char ACTIV
Local Integer OKACT
OKACT = 1
If ACTIV<>""
 If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
 Read [ACV]CODACT = ACTIV
 If fstat or [F:ACV]FLACT<>2
  OKACT = 0
 Endif
Endif
End OKACT

Subprog AJOUT_TRACE(FICHIER)
Value Char    FICHIER
Local Char LIGNE(250)
Openi FICHIER Using [IN]
Iomode adxifs "" Using [IN]
Iomode adxirs chr$(13)+chr$(10) Using [IN]
Iomode adxium GUCS2 Using [IN]
Local Libelle UCS2
LIGNE = ""
Getseq 1,UCS2 Using [IN]
While !fstat
 If UCS2=10
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE = ""
 Elsif UCS2<>0
  LIGNE += chr$(UCS2)
 Endif
 Getseq 1,UCS2 Using [IN]
Wend
Openi Using [IN]
End

$MAPPING
[M:ATV2]UNIVDESID = ""
[M:ATV2]UNIVDES  = [M:DIA]UNIVERS
[M:ATV2]CHOIX    = 2
[M:ATV2]DATAMORI = [M:DIA]DATAM
[M:ATV2]LANGDES = [M:DIA]LANGDES
[M:ATV2]LANGORI = [M:DIA]LANGORI
NBTRA = 0
For I=0 To [M:ATV2]NBETA-1
 If [M:ATV2]DATAM(I)  = [M:DIA]DATAM
   NBTRA = 1
  [M:ATV2]TRADUC(I)   = 2
 Endif
Next I

If NBTRA
 #Call AFFWIN("toto","ABICHXETA") From GESECRAN
 Gosub MAPPING From SUBATV2
Else
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(140,148,1),-1) From GESECRAN : # Aucun états à mapper
Endif
Return

$FIND_FOLD_UNIV
Local Char    FOLDDES(80)
Local Char    FOLDDESID(20)
Local Char    U_DOSSIER(80)(0..100)
Local Char    U_DOS_ID(20)(0..100)
Local Char    U_DOS_CUID(50)(0..100)
Local Char    U_DOS_P_ID(20)(0..100)
Local Integer U_NBDOS

DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(0,CLOB,'Folder CUID="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 U_DOS_CUID(U_NBDOS) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(FIN,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 U_DOS_ID(U_NBDOS) = seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(FIN,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 U_DOSSIER(U_NBDOS) = seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(FIN,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_DOS_P_ID(U_NBDOS) = seg$(CLOB,DEB+10,FIN-1)

 U_NBDOS +=1
 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend

N=find(GREPBI,U_DOSSIER(0..U_NBDOS))
If N = 0 : Return : Endif

For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GINSTID & U_DOS_P_ID(J) = U_DOS_ID(N-1)
  Break
 Endif
Next J

For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = [M]DATAW & U_DOS_P_ID(I) = U_DOS_ID(J)
  Break
 Endif
Next I

For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = [M]LANGDES & U_DOS_P_ID(K) = U_DOS_ID(I)
  FOLDDES   = U_DOS_CUID(K)
  FOLDDESID = U_DOS_ID(K)
  Break
 Endif
Next K
Return

##############################################################################################################
## Création d'un univers BO
##############################################################################################################
## Subprog CREATION_UNIVERS(APPLI,MACHINE,SERVEUR,REPTMP,REPWORK,REPSRV,UNIVERS,DOSSIER,ODBC,EXPORT,DATW,TEST,TABHIEKO,SAISI_UNV)
##############################################################################################################
###########################################################################################################
Subprog CREATION_UNIVERS(APPLI,MACHINE,SERVEUR,REPTMP,REPWORK,REPSRV,UNIVERS,DOSSIER,ODBC,EXPORT,DATAM,DATAW,TEST,
&                        HIERACH,HIERACH2,HIERACH3,HIERACH4,NBHIE,DATABASE,SERV_ODBC,FOLDDES,LANDES,DUREE,RESULT,
&                        EXPR_CLE,EXPR_ID,EXPR_NOM,EXPR_CND1,EXPR_CND2,EXPR_CND3,EXPR_NB,OK,SOLBI,IANSI)
###########################################################################################################
Value    Char    APPLI         : # Dossier appli
Value    Char    MACHINE       : # Machine (# pour local)
Value    Char    SERVEUR       : # Serveur
Value    Char    REPTMP        : # Répertoire de travail (là où il y a l'exécutable creation_univers.rep)
Value    Char    REPWORK       : # repertoire de travail dans le srep de ladxadmin
Value    Char    REPSRV        : # Répertoire serveur (sans l'@). Facultatif si pas d'export
Value    Char    UNIVERS       : # Nom de l'univers
Value    Char    DOSSIER       : # Nom dossier (préfixe des tables, attention avec sql-server)
Value    Char    ODBC          : # Nom de la connexion ODBC sous BO (et non pas le nom de l'odbc)
Value    Integer EXPORT        : # Exportation de l'univers => CMS (REPSRV doit être renseigné)
Value    Char    DATAM         : # Nom du datamart
Value    Char    DATAW         : # Nom du datawarehouse
Value    Char    TABHIEKO()    : # Tableau des hierarchies KO
Value    Char    HIERACH()     : # Hierarchie partie 1
Value    Char    HIERACH2()    : # Hierarchie partie 2
Value    Char    HIERACH3()    : # Hierarchie partie 3
Value    Char    HIERACH4()    : # Hierarchie partie 3
Value    Integer NBHIE         : # nb hierarchie
Value    Char    DATABASE      : # database : oracle ou sql
Value    Char    SERV_ODBC     : # service exemple : X3V5_AYDAIX06
Value    Char    FOLDDES       : # Cuid du repertoire de destination de l'univers
Value    Char    LANDES        : # Langue des destination
Value    Integer DUREE         : # durée de l'excutiond de la requete
Value    Integer RESULT        : # nombre de ligne rammené
Value    Char    EXPR_CLE      : # Condition predefinies
Value    Char    EXPR_ID       : # Condition predefinies
Value    Char    EXPR_NOM      : # Condition predefinies
Value    Char    EXPR_CND1     : # Condition predefinies
Value    Char    EXPR_CND2     : # Condition predefinies
Value    Char    EXPR_CND3     : # Condition predefinies
Value    Integer EXPR_NB       : # Condition predefinies
Variable Integer OK
Value    Char    SOLBI
Value    Integer IANSI         : #¨Parametre Norma ansi

###########################################################################################################

Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM
Local Char    FICHIER(250)
Local Char    FICBAT(250) , FICVAR(250) , FICTXT(250) , FICREP(250) , FICTRA(250), FICCMD(250)
Local Char    LIGNE(250)
Local Char    EXE(50)
Local Char    EXTVAR(5), EXTTXT(5) , EXTBAT(5) , EXTREP(5) , EXTTRA(5),EXTCMD(5)
Local Char    STAT(250),BOVERSION(80)
Local Integer NOLOGO
Local Char    USRBI(100),PWDBI(100),RETOUR(200),PWDBASE(100),USRBASE(100),MACHINEDATA(100)
Local Integer MODESECBI,ERR,ERREURS

# Options

Call RECHPROP("busobj.files.path",BOFILE,GBIDI1) From INTRUTILA
Call GETBOVERSION(BOVERSION) From INTRUTILA

If BOVERSION="R3"
 EXE    = "Creation_univers_V31.exe"   : # Exécutable
Elsif BOVERSION="R4"
 EXE    = "Creation_univers_V41.exe"   : # Exécutable
Else
 EXE    = "Creation_univers_V3.exe"   : # Exécutable
Endif
EXTVAR = "ini"                    : # Extension du fichier des variables
EXTTXT = "txt"                    : # Extension du fichier de description
EXTTRA = "tra"                    : # Extension du fichier de trace
EXTBAT = "bat"                    : # Extension du fichier de commande
EXTCMD = "cmd"                    : # Extension du ficher cmd a lancer pour le 64bits

# Initialisations

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(13)+chr$(10) : # On est sous windows
adxium = GASCII

FICVAR = REPWORK + "\" + UNIVERS + "." + EXTVAR
FICBAT = REPWORK + "\" + UNIVERS + "." + EXTBAT
FICTXT = REPWORK + "\" + UNIVERS + "." + EXTTXT
FICTRA = REPWORK + "\" + UNIVERS + "." + EXTTRA
FICCMD = REPWORK + "\" + UNIVERS + "." + EXTCMD

# Création du fichier txt
OK = 0
If GINFO
 Call AFF_VLC(mess(134,148,1),UNIVERS) From GESECRAN
Endif
Call CRE_DESCRIPTION(APPLI,MACHINE,FICTXT,DATAM,DATAW,HIERACH,HIERACH2,HIERACH3,HIERACH4,NBHIE,UNIVERS,LANDES,EXPR_CLE,EXPR_ID,EXPR_NOM,EXPR_CND1,EXPR_CND2,EXPR_CND3,EXPR_NB,OK) From ABICREDES
If OK  : End : Endif
If [M:DIA]TEST = 2
 adxifs = SAVIFS
 adxirs = SAVIRS
 adxium = SAVIUM
 End
Endif

# Verification de l'existence du bon creation_univers_V3.exe sur le serveur BO : v6
If filinfo(MACHINE+'@'+REPTMP+"\"+EXE,7) < 0
 Call ECR_TRACE(mess(117,148,1)+"\"+mess(4,95,1)-":"-"|"+MACHINE+'@'+REPTMP+"\"+EXE+"|"+"\"+mess(101,100,1),1) From GESECRAN
 adxifs = SAVIFS
 adxirs = SAVIRS
 adxium = SAVIUM
 End
Endif

# Recuperation mot de passe administrator
Call RECHPROP("busobj.login.adminusr",[L]USRBI,GBIDI1) From INTRUTILA
Call INCRYPT([L]USRBI,RETOUR) From INTRUTILA
[L]USRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[L]PWDBI,GBIDI1) From INTRUTILA

Openo MACHINE+"@"+FICVAR , 0
Wrseq "Auto=1"
Wrseq "Type=X3"
Wrseq "FicTxt="+FICTXT
Wrseq "FicTra="+FICTRA
Wrseq "Serveur="+SERVEUR
Wrseq "Authen=enterprise"
# Wrseq "Authen="+mess(MODESECBI,7835,1) : # pour l'instant on se limite a Entreprise
Wrseq "RepSrv="+REPSRV
Wrseq "Univers="+UNIVERS
Wrseq "Dossier="+DOSSIER
Wrseq "ODBC="+ODBC
Wrseq "Export="+num$(EXPORT)
Wrseq "Separe=,"
Wrseq "Visible=0"
Wrseq "database="+[L]DATABASE
Wrseq "service="+[L]SERV_ODBC
If [L]DATABASE = "oracle"
 If BOVERSION>="R3"
  Wrseq "engine="+mess(160,148,1)  : # "Oracle 11"
 Else
  Wrseq "engine="+mess(79,148,1)  : # "Oracle 10"
 Endif
 Wrseq "network="+mess(82,148,1) : #"Oracle OCI"
 Wrseq "ConnectUsr="+DOSSIER
Elsif [L]DATABASE = "sql"
 If BOVERSION>="R3"
  Wrseq "engine="+mess(161,148,1) : # "MS SQL Server 2008"
 Else
  Wrseq "engine="+mess(80,148,1) : # "MS SQL Server 2005"
 Endif
 Wrseq "network="+mess(81,148,1) : # "ODBC"
 Wrseq "ConnectUsr="+right$(DOSSIER,instr(1,DOSSIER,".")+1)
Endif
Wrseq "datamart="+DATAM
Wrseq "ufolder="+[L]FOLDDES
Wrseq "duree="+num$(DUREE)
Wrseq "resultat="+num$(RESULT)
Read [F:TLA]TLA0 = LANDES
If !fstat
 If left$([F:TLA]LANISO,2) <> ""
  If left$([F:TLA]LANISO,2) = "zh"
   Wrseq  "langdes="+[F:TLA]LANISO
  Else
   Wrseq  "langdes="+left$([F:TLA]LANISO,2)
  Endif
 Endif
Endif
GBIDC1=""
Call MACHINE_BO(SOLBI,MACHINEDATA) From ABICREBAS
Call PASSE(MACHINEDATA+"@"+DATAW,DATABASE,USRBASE,PWDBASE,GBIDC1,GBIDC2) From ORAPASSE
Call INCRYPT([L]PWDBASE,RETOUR) From INTRUTILA
Wrseq "pwdbase=CRYPT:"+[L]RETOUR
Wrseq "ansi="+num$(IANSI)
If dim(GFUSION)>0 & GFUSION>0
 Local Clbfile TOKEN(1)
 Local Char RETOUR(250)(1..)
 Getui RETOUR="" With "GetBoToken"
 Local Integer IDX : IDX = 1
 For IDX=1 To maxtab(RETOUR)
   Append TOKEN, right$(RETOUR(IDX), 13)
 Next IDX
 Wrseq "token="+TOKEN
Else
 Wrseq "User="+USRBI
 Wrseq "Passe="+PWDBI
Endif

 Openo
# Exécution du .bat
If GINFO
 Call AFF_VLC(mess(135,148,1),UNIVERS) From GESECRAN
Endif

Local Integer MAC64
Local Char CMD64(100)
Call VERIF_MAC64(MAC64) From PATCHABI
If MAC64
 CMD64 = "%Windir%\SysWOW64\CMD.exe /c "
Else
 Raz CMD64
Endif

Openo MACHINE+"@"+FICBAT , 0
If mid$(REPTMP,2,1)=":"
 Wrseq "cd \"
 Wrseq left$(REPTMP,2)
 Wrseq 'cd "'+right$(REPTMP,4)+'"'
Else
 Wrseq 'cd "'+REPTMP+'"'
Endif
Wrseq EXE-REPWORK+'\'+UNIVERS+"."+EXTVAR
Openo

If !MAC64
 System STAT = MACHINE+'@"'+FICBAT+'"'
Else
 Openo MACHINE+"@"+FICCMD, 0
 Wrseq CMD64+'"'+right$(FICBAT,instr(1,FICBAT,"@")+1)+'"'
 Openo
 System STAT = MACHINE+'@"'+FICCMD+'"'
Endif

# Trace
If GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(39,148,1)-UNIVERS,0) From GESECRAN : # Création de l'univers
 Call ECR_TRACE("",0) From GESECRAN
 Openi MACHINE+"@"+FICTRA
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   ERREURS = 1
   Call ECR_TRACE(right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
Endif

# Ménage et Fin
If !ERREURS
 System STAT = MACHINE+'@ae_rm "'+FICVAR+'"'
 System STAT = MACHINE+'@ae_rm "'+FICBAT+'"'
 System STAT = MACHINE+'@ae_rm "'+FICTRA+'"'
 System STAT = MACHINE+'@ae_rm "'+FICTXT+'"'
 If MAC64 :  System STAT = MACHINE+'@ae_rm "'+FICCMD+'"' : Endif
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

######################################################################################
## Ecran ABICREUNV
######################################################################################
Subprog C_DATAM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ABW",[M:DIA]DATAW,"") From CONTOBJ
Call LECTURE("ABM",VALEUR,"") From CONTOBJ
If !find(VALEUR,[F:ABW]CODABM(0..[F:ABW]NBRABM-1))
 GMESSAGE = mess(40,148,1) : # Datamart incorrect
 mkstat = 2 : End
Endif
If !func ACTIV([F:ABM]CODACT)
 GMESSAGE = mess(2,126,1) : # Fiche inactive
 mkstat = 2 : End
Endif
End

Subprog C_UNIVERS(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
 [M]TRAD = 0
 Effzo [M]TRAD
 Grizo [M]TRAD
Else
 Actzo [M]TRAD
 Affzo [M]TRAD
Endif
End


Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
Local Integer REPERT
Call EXISTE([M:DIA]MACHINE+"@"+VALEUR,REPERT) From ORDSYS
If REPERT<>2
 GMESSAGE = mess(86,133,1) : # Répertoire inexistant
 mkstat = 2 : End
Endif
Call EXISTE([M:DIA]MACHINE+"@"+VALEUR+"/Creation_univers.exe",REPERT) From ORDSYS
If REPERT<=0
 GMESSAGE = "Creation_univers.exe"-mess(101,100,1) : #  Fichier inexistant
 mkstat = 2 : End
Endif
End

Subprog AV_EXPORT(VALEUR)
Variable Integer VALEUR
If GADONIX <> 2 & [M:DIA]TEST <> 2
 VALEUR =2
 Grizo [M:DIA]EXPORT
Elsif GADONIX <> 2 & [M:DIA]TEST = 2
 VALEUR =0
 Actzo [M:DIA]EXPORT
 Grizo [M:DIA]EXPORT
Elsif GADONIX = 2 & [M:DIA]TEST = 2
 VALEUR = 0
 Grizo [M:DIA]EXPORT
Endif
End


Subprog AM_DATAM(VALEUR)
Variable Char    VALEUR()
Read [ABM]ABM0 = VALEUR
If !fstat & [F:ABM]AUZFCY <> 2
 [M:DIA]AUTSIT = 0
 Grizo [M:DIA]AUTSIT
 Affzo [M:DIA]AUTSIT
Else
 Actzo [M:DIA]AUTSIT
 Affzo [M:DIA]AUTSIT
Endif
End

Subprog AM_TEST(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 [M:DIA]EXPORT= 0
 [M:DIA]TRAD = 0
 Affzo [M:DIA]EXPORT
 Grizo [M:DIA]EXPORT
 Grizo [M:DIA]TRAD
 Grizo [M:DIA]MODDEV
Else
 Actzo [M:DIA]EXPORT
 Actzo [M:DIA]TRAD
 Actzo [M:DIA]MODDEV
Endif
End

Subprog S_DATAM(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(0..50) , INTIT(30) , TEXTE(50)(0..50)
NBTEX = 0
Read [F:ABW]ABW0 = [M:DIA]DATAW
If !fstat
 For I=0 To [F:ABW]NBRABM-1
  Read [F:ABM]ABM0 = [F:ABW]CODABM(I)
  If !fstat
   NBTEX += 1
   Call TEXTE([F:ABM]INTIT,INTIT) From OBJDIV
   TEX(NBTEX) =[F:ABM]COD
   TEXTE(NBTEX) =  format$("K:11X",[F:ABM]COD)-"("-INTIT-")"
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Next I
Endif
If NBTEX
 If NBTEX =1 : VALEUR = TEX(1) : End : Endif
 Call SAITEX(NBTEX,TEXTE,NUM,"Datamart") From GESECRAN
 If NUM<>0 & status<>7
  VALEUR = TEX(NUM)
 Endif
Endif
End

######################################################################################
## Complément pour la ligne 1000
######################################################################################
Subprog LIGNE1000(DATAW,DATAM,APPLI)
Value Char DATAW
Value Char DATAM
Value Char APPLI
If clalev([F:ABM])=0  : Local File ABIDATMRT [ABM]  : Endif
If clalev([F:ABF])=0  : Local File ABITABDAT [ABF]  : Endif
If clalev([F:ABZ])=0  : Local File ABITABFLD [ABZ]  : Endif
If clalev([F:ABZ2])=0 : Local File ABITABFLD [ABZ2] : Endif
If clalev([F:ABE])=0  : Local File ABITABAGG [ABE]  : Endif
If clalev([F:ABI])=0  : Local File ABIDIM    [ABI]  : Endif
If clalev([F:ABJ])=0  : Local File ABIDIMFLD [ABJ]  : Endif
If clalev([F:ABK])=0  : Local File ABITABLNK [ABK]  : Endif
If clalev([F:ABX])=0  : Local File ABITABIND [ABX]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE     [ATY]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE    [ATX]  : Endif
Onerrgo ERR1000
Local Integer I , J , K
Local Char    CHAINE(250) , CHAMP(GLONAVA)
Local Integer NBDIM , NBMEN , NBADI
Local Char    TBDIM(GLONABI)(1..500)
Local Integer TBMEN(1..500)
Local Integer TBADI(1..500)
Local Char    ME1000(250)
Local Integer ER1000
Local Char    TYPKEY(1)
Local Char    IRS(2)
IRS = chr$(10)+chr$(10)
NBDIM = 0
NBMEN = 0
NBADI = 0
Read [ABM]ABM0 = DATAM
For I=0 To [F:ABM]NBRABF-1
 If func ACTIV([F:ABM]ACTABF(I))
  TABLE = [F:ABM]CODABF(I) : Gosub FAIT1000
 Endif
Next I
For J=1 To NBDIM
 Read [ABI]ABI0 = TBDIM(J)
 If GLIGNE1000
  Wrseq "#" ;IRS;
  Wrseq "# Dimension"-TBDIM(J) ;IRS;
  Wrseq "#" ;IRS;
 Endif
 For [ABJ] Where CODDIM=TBDIM(J)
  If func ACTIV([F:ABJ]ACTDIM)
   Call COLONNE_1000("D_"+TBDIM(J),[F:ABJ]FLDDIM,[F:ABJ]INTDIM,[F:ABJ]CODTYP,[F:ABJ]LNG,[F:ABJ]MENLOC
&                  ,[F:ABJ]TABDIV,([F:ABJ]TYPFLD=1),NBMEN,TBMEN,NBADI,TBADI)
  Endif
 Next
 Call INDEX_1000("D_"+TBDIM(J),[F:ABI]ABRDIM+"0",[F:ABI]CLE,"1")
Next J
If GLIGNE1000
 Wrseq "#" ;IRS;
 Wrseq "# Menus locaux" ;IRS;
 Wrseq "#" ;IRS;
Endif
For J=1 To NBMEN
 If GLIGNE1000
  Wrseq "Menu,"+num$(TBMEN(J));
  For K=1 To len(mess(0,TBMEN(J),1))
   Wrseq ","+num$(K)+":"+mess(K,TBMEN(J),1);
  Next K
  Wrseq ;IRS;
 Endif
 Call INDEX_1000("AX3MNL"+num$(TBMEN(J)),"AXMN0","LANNUM","1")
Next J
If GLIGNE1000
 Wrseq "#" ;IRS;
 Wrseq "# Tables diverses" ;IRS;
 Wrseq "#" ;IRS;
Endif
For J=1 To NBADI
 If GLIGNE1000
  Wrseq "Tabdiv,"+num$(TBADI(J)) ;IRS;
 Endif
 Call INDEX_1000("AX3ADI"+num$(TBADI(J)),"AXDI0","CODE","1")
Next J
# Tables spéciales
Call INDEX_1000("AX3DAT","AXDT0","DATDAT","1")
Call INDEX_1000("AX3DOS","AXDS0","CODDOS","1")
Call INDEX_1000("AX3ACC","AXAC0","USR+ACC","1")
Call INDEX_1000("AX3FCTFCY","AXFC0","FCY+USR+REP","1")
Onerrgo
End

$ERR1000
ER1000 = errn
ME1000 = errp+"("+num$(errl)+")"-errm-errmes$(ER1000)
If GTRACE<>""
 Call ECR_TRACE(ME1000,ER1000) From GESECRAN
Endif
Resume

$FAIT1000
Read [ABF]ABF0 = TABLE
If !func ACTIV([F:ABF]CODACT) : Return : Endif
If GLIGNE1000
 Wrseq "#" ;IRS;
 Wrseq "# Table de fait"-TABLE ;IRS;
 Wrseq "#" ;IRS;
Endif
For [ABZ]ABZ0 Where CODABF=TABLE
 If func ACTIV([F:ABZ]ACTFLD)
  Call COLONNE_1000("F_"+TABLE,[F:ABZ]CODFLD,[F:ABZ]INTFLD,[F:ABZ]CODTYP,[F:ABZ]LNGFLD,[F:ABZ]MENLOC
&                  ,[F:ABZ]TABDIV,([F:ABZ]TYPFLD=3),NBMEN,TBMEN,NBADI,TBADI)
 Endif
Next
For [ABX] Where CODABF=TABLE
 If func ACTIV([F:ABX]ACTIND)
  If [F:ABX]NUMIND=1
   TYPKEY = "1"
  Else
   TYPKEY = "2"
  Endif
  Call INDEX_1000("F_"+TABLE,[F:ABF]ABRABF+num$([F:ABX]NUMIND-1),[F:ABX]EXPIND,TYPKEY)
 Endif
Next
For [ABE] Where CODABF=TABLE
 If func ACTIV([F:ABE]ACTAGG)
  If GLIGNE1000
   Wrseq "#" ;IRS;
   Wrseq "# Table d'agrégat"-TABLE+"_"+[F:ABE]CODAGG ;IRS;
   Wrseq "#" ;IRS;
  Endif
  For J=0 To [F:ABE]NBRAGD-1
   CHAINE = [F:ABE]LNKAGG(J)
   While CHAINE<>""
    K = instr(1,CHAINE,";")
    If K
     CHAMP  = left$(CHAINE,K-1)
     CHAINE = right$(CHAINE,K+1)
    Else
     CHAMP  = CHAINE
     CHAINE = ""
    Endif
    Read [ABZ]ABZ1 = TABLE;CHAMP
    If func ACTIV([F:ABZ]ACTFLD)
     Call COLONNE_1000(TABLE+"_"+[F:ABE]CODAGG,[F:ABZ]CODFLD,[F:ABZ]INTFLD,[F:ABZ]CODTYP,[F:ABZ]LNGFLD,[F:ABZ]MENLOC
&                    ,[F:ABZ]TABDIV,0,NBMEN,TBMEN,NBADI,TBADI)
    Endif
   Wend
  Next J
  For [ABZ] Where CODABF=TABLE & TYPFLD=1
   Call COLONNE_1000(TABLE+"_"+[F:ABE]CODAGG,[F:ABZ]CODFLD,[F:ABZ]INTFLD,[F:ABZ]CODTYP,[F:ABZ]LNGFLD,[F:ABZ]MENLOC
&                   ,[F:ABZ]TABDIV,0,NBMEN,TBMEN,NBADI,TBADI)
  Next
  For J=0 To [ABE]NBRAGI-1
   If J=0
    TYPKEY = "1"
   Else
    TYPKEY = "2"
   Endif
   Call INDEX_1000(TABLE+"_"+[F:ABE]CODAGG,[F:ABE]CODAGG+num$(J),[F:ABE]INDAGG(J),TYPKEY)
  Next J
 Endif
Next
For [ABK] Where CODABF=TABLE
 Call DIMPERE(NBDIM,TBDIM,[F:ABK]CODLNK,APPLI)
Next
Return

Subprog DIMPERE(NBDIM,TBDIM,DIMENSION,APPLI)
Variable Integer NBDIM
Variable Char    TBDIM()(1..)
Value    Char    DIMENSION
Value    Char    APPLI
#If clalev([F:ABI])=0  : Local File ABIDIM    [ABI] : Endif
#If clalev([F:ABJ])=0  : Local File ABIDIMFLD [ABJ] : Endif
Local File =APPLI+".ABIDIM"    [ABI]
Local File =APPLI+".ABIDIMFLD" [ABJ]

Read [ABI]ABI0 = DIMENSION
If func ACTIV([F:ABI]CODACT) & !find(DIMENSION,TBDIM(1..NBDIM))
 NBDIM += 1
 TBDIM(NBDIM) = DIMENSION
 For [ABJ] Where CODDIM=DIMENSION & DIMFAT<>""
  If func ACTIV([F:ABJ]ACTDIM)
   Call DIMPERE(NBDIM,TBDIM,[F:ABJ]DIMFAT,APPLI)
  Endif
 Next
Endif
End

Subprog COLONNE_1000(TABLE,CHAMP,INTIT,TYP,LNG,NOLIB,TABDIV,DIME,NBMEN,TBMEN,NBADI,TBADI)
Value    Char    TABLE
Value    Char    CHAMP
Value    Integer INTIT
Value    Char    TYP
Value    Decimal LNG
Value    Integer NOLIB
Value    Integer TABDIV
Value    Integer DIME
Variable Integer NBMEN
Variable Integer TBMEN(1..)
Variable Integer NBADI
Variable Integer TBADI(1..)
Local Char    TEXTE(80)
Local Char    TYPDON(80)
Local Decimal LNGDON
Call TEXTE(INTIT,TEXTE) From OBJDIV
Read [ATY]CODTYP = TYP
If [F:ATY]TYPTYP=1
 If DIME
  TYPDON = "Menu local"
  LNGDON = NOLIB
  If !find(NOLIB,TBMEN(1..NBMEN))
   NBMEN += 1
   TBMEN(NBMEN) = NOLIB
  Endif
 Else
  TYPDON = "Alphanumérique"
  LNGDON = 15
 Endif
Elsif [F:ATY]CODTYP="ADI"
 TYPDON = "Table diverse"
 LNGDON = TABDIV
 If !find(TABDIV,TBADI(1..NBADI))
  NBADI += 1
  TBADI(NBADI) = TABDIV
 Endif
Else
 TYPDON = mess([F:ATY]TYPTYP,30,1)
 If [F:ATY]LNGTYP<>0
  LNGDON = [F:ATY]LNGTYP
 Elsif LNG<>0
  LNGDON = LNG
 Endif
Endif
If GLIGNE1000
 Wrseq "Colonne";
 Wrseq ","+TABLE;
 Wrseq ","+CHAMP;
 Wrseq ","+TEXTE;
 Wrseq ","+TYPDON;
 If LNGDON<>0
  Wrseq ","+num$(LNGDON);
 Endif
 Wrseq chr$(13)+chr$(10);
Endif
End

Subprog INDEX_1000(TABLE,INDEX,CHAMPS,TYPKEY)
Value Char TABLE
Value Char INDEX
Value Char CHAMPS
Value Char TYPKEY
Wrseq "Index";
Wrseq ","+TABLE;
Wrseq ","+INDEX;
Wrseq ","+TYPKEY;
Wrseq ","+ctrans(CHAMPS,"+-",",,");
Wrseq ;chr$(13);chr$(10);
End


$ERREURS_INT
ERN = errn
Resume

Subprog VERIF_INTITULE_VARIABLE(ABM,APPLI,OK)
Value Char       ABM
Value Char       APPLI
Variable Integer OK
Local Integer    ERN,I ,II
Local Char       INTITULE(80),TBFAIT(GLONABF)
If clalev([F:ABM7])=0 : Local File =APPLI+".ABIDATMRT" [ABM7]  : Endif
If clalev([F:ABF7])=0 : Local File =APPLI+".ABITABDAT" [ABF7]  : Endif
If clalev([F:ABZ7])=0 : Local File =APPLI+".ABITABFLD" [ABZ7]  : Endif
If clalev([F:ABI7])=0 : Local File =APPLI+".ABIDIM"    [ABI7]  : Endif
If clalev([F:ABJ7])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ7]  : Endif
If clalev([F:AHH7])=0 : Local File =APPLI+".ABIHIERA"  [AHH7]  : Endif
If clalev([F:AII7])=0 : Local File =APPLI+".ABICOND"   [AII7]  : Endif
If clalev([F:ATX7])=0 : Local File =APPLI+".ATEXTE"    [ATX7]  : Endif
If clalev([F:ABK2])=0 : Local File =APPLI+".ABITABLNK" [ABK2]  : Endif
If clalev([F:ABJ1])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ1] : Endif
If clalev([F:ABJ3])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ3] : Endif
If clalev([F:ABJ4])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ4] : Endif
If clalev([F:ABJ5])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ5] : Endif
If clalev([F:ABJ6])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ6] : Endif
If clalev([F:ABJ7])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ7] : Endif
If clalev([F:ABJ8])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ8] : Endif
If clalev([F:ABJ9])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ9] : Endif

ERN = 0
# Verif intitule table de fait
Read [F:ABM7]ABM0 = ABM
If !fstat
 If GFONCTION <> "GESAHH" & GFONCTION <> "GESAII"
  If GTRACE <> ""
   Call ECR_TRACE(mess(00062,00148,1),0) From GESECRAN : # Vérification des hiérarchies du datamart
  Endif
  Gosub VERIF_AHH
  If GTRACE <> ""
   Call ECR_TRACE(mess(95,148,1),0) From GESECRAN : # Vérification des conditions prédéfinies du datamart
  Endif
  Gosub VERIF_AII
 Endif
 For I=1 To [F:ABM7]NBRABF
  If GTRACE <> ""
   Call ECR_TRACE(mess(57,123,1)-":"-mess(63,148,1)-[F:ABM7]CODABF(I-1),0) From GESECRAN
  Endif
  TBFAIT = [F:ABM7]CODABF(I-1) : Gosub VERIF_ABF
  TBFAIT = [F:ABM7]CODABF(I-1) : Gosub VERIF_ABZ
  TBFAIT = [F:ABM7]CODABF(I-1) : Gosub LISTE_DIMENSION
  If GTRACE <> ""
   Call ECR_TRACE(mess(57,123,1)-mess(24,148,1)-":",0) From GESECRAN
  Endif
  Gosub VERIF_ABI
 Next I
 If GTRACE <> ""
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 If OK =0 : End : Endif
Endif
End

$VERIF_AII
Filter [F:AII7] Where ABM = [L]ABM & ([F:AII7]INTEVAL <> "" | [F:AII7]INTVALTEX <> "")
For [F:AII7]AII0
 Onerrgo ERREURS_INT
  If [F:AII7]INTEVAL<> ""
   INTITULE = evalue([F:AII7]INTEVAL)
  Endif
 Onerrgo
 If ERN
  If GTRACE <> ""
   Call ECR_TRACE(mess(44,127,1)-[F:AII7]COD-":"-mess(65,106,1)-[F:AII7]INTEVAL-":"-errmes$(ERN),1) From GESECRAN
  Endif
  OK = 0
  ERN =0
 Endif
 If instr(1,INTITULE,",")
  If GTRACE <> ""
   Call ECR_TRACE(mess(44,127,1)-[F:AII7]COD-":"-mess(65,106,1)-[F:AII7]INTEVAL-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
  Endif
  OK = 0
  ERN = 0
 Endif
 Onerrgo ERREURS_INT
  If [F:AII7]INTVALTEX <> ""
   INTITULE = evalue([F:AII7]INTVALTEX)
  Endif
 Onerrgo
 If ERN
  If GTRACE <> ""
   Call ECR_TRACE(mess(44,127,1)-[F:AII7]COD-":"-mess(65,106,1)-[F:AII7]INTVALTEX-":"-errmes$(ERN),1) From GESECRAN
  Endif
  OK = 0
  ERN =0
 Endif
 If instr(1,INTITULE,",")
  If GTRACE <> ""
   Call ECR_TRACE(mess(44,127,1)-[F:AII7]COD-":"-mess(65,106,1)-[F:AII7]INTVALTEX-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
  Endif
  OK = 0
  ERN = 0
 Endif
Next AII7
INTITULE = ""
Filter [F:AII7]
Return

$VERIF_ABJ
Filter [F:ABJ7] Where CODDIM = TABDIM(I) & [F:ABJ7]INTVALDIM <> ""
For [F:ABJ7]ABJ0
 Onerrgo ERREURS_INT
 INTITULE = evalue([F:ABJ7]INTVALDIM )
 Onerrgo
 If ERN
  If GTRACE <> ""
   Call ECR_TRACE(mess(24,148,1)-[F:ABJ7]CODDIM-":"-mess(65,106,1)-[F:ABJ7]INTVALDIM -":"-errmes$(ERN),1) From GESECRAN
  Endif
  OK = 0
  ERN = 0
 Endif
 If instr(1,INTITULE,",")
  If GTRACE <> ""
   Call ECR_TRACE(mess(24,148,1)-[F:ABJ7]CODDIM-":"-mess(65,106,1)-[F:ABJ7]INTVALDIM -":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
  Endif
  OK = 0
  ERN = 0
 Endif
Next ABJ7
Filter [F:ABJ7]
INTITULE = ""
Return

$VERIF_ABI
For II=0 To NBDIM-1
 Read [F:ABI7]ABI0 = TABDIM(II)
 If !fstat
  If [F:ABI7]INTEVAL <> ""
   Onerrgo ERREURS_INT
   INTITULE = evalue([F:ABI7]INTEVAL)
   Onerrgo
   If ERN
    If GTRACE <> ""
     Call ECR_TRACE(mess(24,148,1)-[F:ABI7]CODDIM-":"-mess(65,106,1)-[F:ABI7]INTEVAL-":"-errmes$(ERN),1) From GESECRAN
    Endif
    OK = 0
    ERN = 0
   Endif
   If instr(1,INTITULE,",")
    If GTRACE <> ""
     Call ECR_TRACE(mess(24,148,1)-[F:ABI7]CODDIM-":"-mess(65,106,1)-[F:ABI7]INTEVAL-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
    Endif
    OK = 0
    ERN = 0
   Endif
  Endif
 Endif
 Gosub VERIF_ABJ
Next II
INTITULE = ""
Return

$LISTE_DIMENSION
Local Char    TABDIM(30)(0..250)
Local Integer NBDIM
For [ABK2] Where CODABF=TBFAIT
 Gosub DIMENSIONS
Next
Return

$DIMENSIONS
NBDIM +=1
TABDIM(NBDIM) = [F:ABK2]CODLNK
Call DIMREC(NBDIM,TABDIM)
Return

Subprog DIMREC(NBDIM,TABDIM)
Variable Integer NBDIM
Variable Char    TABDIM()(1..)

Local File ABIDIMFLD [ABJ_]

For [ABJ_] Where CODDIM=TABDIM(NBDIM)
 If [F:ABJ_]DIMFAT <> "" & !find([F:ABJ_]DIMFAT,TABDIM(1..NBDIM-1))
  TABDIM(NBDIM) = [F:ABJ_]DIMFAT
  NBDIM +=1
  Call DIMREC(NBDIM,TABDIM)
 Endif
Next
End

$VERIF_AHH
Filter [F:AHH7] Where ABM = [L]ABM & [F:AHH7]INTEVAL <> ""
For [F:AHH7]AHH0
 Onerrgo ERREURS_INT
 INTITULE = evalue([F:AHH7]INTEVAL)
 Onerrgo
 If ERN
  If GTRACE <> ""
   Call ECR_TRACE(mess(43,127,1)-[F:AHH7]COD-":"-mess(65,106,1)-[F:AHH7]INTEVAL-":"-errmes$(ERN),1) From GESECRAN
  Endif
  OK = 0
  ERN =0
 Endif
 If instr(1,INTITULE,",")
  If GTRACE <> ""
   Call ECR_TRACE(mess(43,127,1)-[F:AHH7]COD-":"-mess(65,106,1)-[F:AHH7]INTEVAL-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
  Endif
  OK = 0
  ERN = 0
 Endif
Next AHH7
INTITULE = ""
Filter [F:AHH7]
Return

$VERIF_ABZ
Filter [F:ABZ7] Where CODABF = TBFAIT & [F:ABZ7]INTVALFLD <> ""
For [F:ABZ7]ABZ0
 Onerrgo ERREURS_INT
 INTITULE = evalue([F:ABZ7]INTVALFLD)
 Onerrgo
 If ERN
  If GTRACE <> ""
   Call ECR_TRACE(mess(63,148,1)-[F:ABZ7]CODABF-":"-mess(65,106,1)-[F:ABZ7]INTVALFLD-":"-errmes$(ERN),1) From GESECRAN
  Endif
  OK = 0
  ERN =0
 Endif
 If instr(1,INTITULE,",")
  If GTRACE <> ""
   Call ECR_TRACE(mess(63,148,1)-[F:ABZ7]CODABF-":"-mess(65,106,1)-[F:ABZ7]INTVALFLD-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
  Endif
  OK = 0
  ERN = 0
 Endif
Next ABZ7
INTITULE = ""
Filter [F:ABZ7]
Return

$VERIF_ABF
Read [F:ABF7]ABF0 = TBFAIT
If !fstat
 If [F:ABF7]INTEVAL <> ""
  Onerrgo ERREURS_INT
  INTITULE = evalue([F:ABF7]INTEVAL)
  Onerrgo
  If ERN
   If GTRACE <> ""
    Call ECR_TRACE(mess(63,148,1)-[F:ABF7]CODABF-":"-mess(65,106,1)-[F:ABF7]INTEVAL-":"-errmes$(ERN),1) From GESECRAN
   Endif
   OK = 0
   ERN = 0
  Endif
  If instr(1,INTITULE,",")
   If GTRACE <> ""
    Call ECR_TRACE(mess(63,148,1)-[F:ABF7]CODABF-":"-mess(65,106,1)-[F:ABF7]INTEVAL-":"-","-mess(113,123,1),1) From GESECRAN : # Cacarctère invalide
   Endif
   OK = 0
   ERN = 0
  Endif
 Endif
Endif
INTITULE = ""
Return

