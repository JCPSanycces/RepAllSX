#<AdxTL>@(#)1.0.0.0 $Revision$
# Classe APATCHFOLDER

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



#----------------------#
$LOAD_FOLDERS

Local Char    DOSX3(20)
Local Char    LDOSSIER(30)(1..)
Local Integer I , J , K , LNBDOS , NBDOS
Local Char    DOSSIER(30)(1..) , VERSION(10)(1..) , RELEASE(10)(1..) , PATCH(10)(1..)
Local Char    UPD(20)(1..) , LAN(250)(1..)

DOSX3 = func ASYRFOLDER.DOSX3(nomap)

Local File ADOSSIER [ADS]
For [ADS]
 LNBDOS += 1
 LDOSSIER(LNBDOS) = [F:ADS]DOSSIER
Next ADS
Close Local File [ADS]

Call RANGE(LDOSSIER,LNBDOS,DOSSIER,NBDOS)

For J=1 To NBDOS
 Gosub SET_PROPERTIES
Next J

Return

#----------------------#
$SET_PROPERTIES
Raz UPD(J) , VERSION(J) , PATCH(J)
If filinfo(filpath("FIL","APATCH","fde",DOSSIER(J)),0)>0
 Local File =DOSSIER(J)+".APATCH" [A_PT]
 Filter [A_PT] Where TYP="P"
 Read [A_PT]APT0 Last
 If fstat
  Filter [A_PT]
  Close Local File [A_PT]
  Local File =DOSX3+".APATCH" [A_PT]
  Filter [A_PT] Where TYP="P"
  Read [A_PT]APT0 Last
 Endif
 If !fstat
  If left$(num$([F:A_PT]DAT),5)="00/00"
   UPD(J) = num$(date$)
  Else
   UPD(J) = num$([F:A_PT]DAT)
  Endif
  PATCH(J) = num$([F:A_PT]PATNUM)
  If [F:A_PT]RELEASE<>""
   VERSION(J) = ctrans([F:A_PT]RELEASE,".","")
  Elsif dim(GACTX.AFOLD.AVERSION)>0
   VERSION(J) = num$(GACTX.AFOLD.AVERSION)
  Endif
 Else
  PATCH(J) = "0"
  UPD(J) = num$(date$)
  If dim(GACTX.AFOLD.AVERSION)>0
   VERSION(J) = num$(GACTX.AFOLD.AVERSION)
  Endif
 Endif
 Close Local File [A_PT]
Endif

RELEASE(J) = ""
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER(J)),0)>0
 Local File =DOSSIER(J)+".ADOVAL" [A_DW]
 Read [A_DW]ADW0 = "";"";"RELEASE"
 If !fstat
  RELEASE(J) = num$([F:A_DW]VALEUR)
 Else
  RELEASE(J) = "0"
 Endif
 Close Local File [A_DW]
Endif

LAN(J) = ""
If filinfo(filpath("FIL","ADOSSIER","fde",DOSX3),0)>0
 Local File =DOSX3+".ADOSSIER" [A_DS]
 Read [A_DS]DOSSIER = DOSSIER(J)
 If !fstat
  For I=1 To [F:A_DS]NBRLAN
   If LAN(J)<>""
    LAN(J) += ";"
   Endif
   LAN(J) += [F:A_DS]LAN(I-1)
  Next I
  Close Local File [A_DS]
 Endif
Endif

Return

#-----------------------------------------------------#
Subprog RANGE(LDOSSIER,LNBDOS,DOSSIER,NBDOS)
Value    Char    LDOSSIER()(1..)
Value    Integer LNBDOS
Variable Char    DOSSIER()(1..)
Variable Integer NBDOS

Local Integer I , ER , TYPPRO
Local Char    WDOSSIER(30)(1..) , WDOSSUP(30)(1..)
Local Integer WNBDOS , WNBSUP
Local Integer NBDOS

Onerrgo ER

Local File ADOVAL [ADW_]
Read [ADW_]ADW0 = "";"";"TYPDOS"
TYPPRO = val([F:ADW_]VALEUR)-1
Close Local File [ADW_]

For I=1 To LNBDOS
 Raz ER
 If filinfo(filpath("FIL","ADOVAL","fde",LDOSSIER(I)),0)>0
  Local File =LDOSSIER(I)+".ADOVAL" [ADW_]
  If !ER
   Read [ADW_]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat & val([F:ADW_]VALEUR)-1=[L]TYPPRO
    WNBDOS += 1
    WDOSSIER(WNBDOS) = LDOSSIER(I)
    Read [ADW_]ADW0 = "";"";"SUPDOS"
    If !fstat & [F:ADW_]VALEUR<>"" & !find([F:ADW_]VALEUR,WDOSSUP(1..WNBSUP)) & find([F:ADW_]VALEUR,LDOSSIER)
     WNBSUP += 1
     WDOSSUP(WNBSUP) = [F:ADW_]VALEUR
    Endif
   Endif
   Close Local File [ADW_]
  Endif
 Endif
Next I

For I=1 To WNBSUP
 Raz ER
 If filinfo(filpath("FIL","ADOVAL","fde",WDOSSUP(I)),0)>0
  Local File =WDOSSUP(I)+".ADOVAL" [ADW_]
  If !ER
   Read [ADW_]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat & val([F:ADW_]VALEUR)-1=[L]TYPPRO
    NBDOS += 1
    DOSSIER(NBDOS) = WDOSSUP(I)
   Endif
   Close Local File [ADW_]
  Endif
 Endif
Next I
For I=1 To WNBDOS
 If !find(WDOSSIER(I),WDOSSUP(1..WNBSUP))
  NBDOS += 1
  DOSSIER(NBDOS) = WDOSSIER(I)
 Endif
Next I

Onerrgo

End

#----------#
$ER
ER = errn
Call TRACE("err="+num$(ER)-"mes="+num$(errl)) From ASYRCOM
Resume

