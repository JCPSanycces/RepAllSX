#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_LVEMAXCRE
Onevent BEFORE_INPUT Call AS_LVEMAXCRE(zc) From W2HRTIM1
Onevent CONTROL Call C_LVEMAXCRE(zc) From W2HRTIM1
Return

Subprog AS_LVEMAXCRE(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_LVEMAXCRE(VALEUR) From SUBHRTIM
If mkstat=2
 [M]LVEMAXCRE(INDIC) = VALEUR
 Affzo LVEMAXCRE(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_LVEMAXCRE(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_LVEMAXCRE(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "LVEMAXCRE" : GZNUM = 1001544 : Endif
Gosub _AFF
End

$ON_LVEMAXOPT
Onevent AFTER_CHANGE Gosub AMM_LVEMAXOPT From W2HRTIM1
Onevent INIT_AREA Call D_LVEMAXOPT(zc) From W2HRTIM1
Onevent BEFORE_INPUT Call AS_LVEMAXOPT(zc) From W2HRTIM1
Return

Subprog D_LVEMAXOPT(VALEUR)
Variable Integer VALEUR
If varinit([M]LVEMAXOPT,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_LVEMAXOPT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_LVEMAXOPT
Call AM_LVEMAXOPT(zc)
If !mkstat & GOBJET
 zoncou = "LVEMAXOPT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LVEMAXOPT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_LVEMAXOPT(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "LVEMAXOPT" : GZNUM = 1001543 : Endif
Gosub _AFF
End

$ON_FLGBLC
Onevent CONTROL Call C_FLGBLC(zc) From W2HRTIM1
Onevent INIT_AREA Call D_FLGBLC(zc) From W2HRTIM1
Onevent BEFORE_INPUT Call AS_FLGBLC(zc) From W2HRTIM1
Return

Subprog D_FLGBLC(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGBLC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGBLC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLGBLC(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_FLGBLC(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "FLGBLC" : GZNUM = 49972 : Endif
Gosub _AFF
End

$ON_PLNGRP
Onevent INIT_AREA Call D_PLNGRP(zc) From W2HRTIM1
Onevent BEFORE_INPUT Call AS_PLNGRP(zc) From W2HRTIM1
Return

Subprog D_PLNGRP(VALEUR)
Variable Integer VALEUR
If varinit([M]PLNGRP,indice)=0
 VALEUR = len(mess(0,418,1))
Endif
Gosub _AFF
End

Subprog AS_PLNGRP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_SXPCAT
Onevent INIT_AREA Call D_SXPCAT(zc) From W2HRTIM1
Onevent CONTROL Call C_SXPCAT(zc) From W2HRTIM1
Onevent BEFORE_INPUT Call AS_SXPCAT(zc) From W2HRTIM1
Return

Subprog D_SXPCAT(VALEUR)
Variable Char    VALEUR()
If varinit([M]SXPCAT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10406","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SXPCAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10406") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SXPCAT(zc) From W2HRTIM1
Onkey   2 Titled GBOUTS Call S_SXPCAT(zc) From W2HRTIM1
Onkey 144 Titled GBOUTP Call P_SXPCAT(zc) From W2HRTIM1
Onkey 146 Titled GBOUTA Call SA_SXPCAT(zc) From W2HRTIM1
Gosub _AFF
End

Subprog C_SXPCAT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10406","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SXPCAT" : GZNUM = 1002449 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10406",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SXPCAT" : GZNUM = 1002449 : Endif
Endif
Gosub _AFF
End

Subprog S_SXPCAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10406"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SXPCAT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10406") From GOBJET
Gosub _AFF
End

Subprog SA_SXPCAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10406"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SXPCAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10406"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


