#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier GGRILLE
Close Mask
Raz GPILOBJ
Call OBJET("RIL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "LIENS2"    : Gosub LIENS2
 When "VERIF_CRE" : Gosub VERIF
 When "VERIF_MOD" : Gosub VERIF
 When "INICRE"    : Gosub INICRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEACT"    : Gosub EXEACT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "FERME"      : Gosub FERME
 #JOJAC - 2016-04-29 - REQ114309 US114 - START
 When "FILTRE"    : Gosub FILTRE
 #JOJAC - 2016-04-29 - REQ114309 US114 - END
Endcase
Return

$OUVRE
Local Integer INDCOL :# indice de colonne
Local Char    INTCOMP1(30) , INTCOMP2(30) , INTCOMP3(30)
Local Char    INTVAL1(30) , INTVAL2(30)                   :#pour les intitulés de colonnes
If clalev ([F:GRI])=0 : Local File GRILLE [GRI] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$APRES_MODIF
Case COUZON
 When "CODGRI" : Gosub LIENS2
Endcase
Return

$LIENS
########pour les intitulés de colonne
If nolign=1
 Call LECTURE("GRI",[F:RIL]CODGRI,"") From CONTOBJ
 Gosub SETGRI
Endif
[M]SCMP1(nolign-1) = [F:RIL]CMP1
[M]SCMP2(nolign-1) = [F:RIL]CMP2
[M]SCMP3(nolign-1) = [F:RIL]CMP3
[M]SVAL1(nolign-1) = [F:RIL]VAL1
[M]SVAL2(nolign-1) = [F:RIL]VAL2
Call CHARGE([M]SCMP1(nolign-1),[M]TYP1,0,15,[M]CMP1(nolign-1)) From FMTVAR
If [F:GRI]NBRCMP>=2
 Call CHARGE([M]SCMP2(nolign-1),[M]TYP2,0,15,[M]CMP2(nolign-1)) From FMTVAR
 If [F:GRI]NBRCMP>=3
  Call CHARGE([M]SCMP3(nolign-1),[M]TYP3,0,15,[M]CMP3(nolign-1)) From FMTVAR
 Endif
Endif
Call CHARGE([M]SVAL1(nolign-1),[M]TYP4,0,15,[M]VAL1(nolign-1)) From FMTVAR
If [F:GRI]NBRCOL>=2
 Call CHARGE([M]SVAL2(nolign-1),[M]TYP5,0,15,[M]VAL2(nolign-1)) From FMTVAR
Endif
Return

$LIENS2
If [F:GRI]NBRCMP<3
 Chgfmt [M]SCMP3 With "-K:15X"
 If [F:GRI]NBRCMP<2
  Chgfmt [M]SCMP2 With "-K:15X"
 Else
  Chgfmt [M]SCMP2 With "K:15X"
 Endif
Else
 Chgfmt [M]SCMP3 With "K:15X"
 Chgfmt [M]SCMP2 With "K:15X"        :#85674
Endif
If [F:GRI]NBRCOL<2
 Chgfmt [M]SVAL2 With "-K:15X"
Else
 Chgfmt [M]SVAL2 With "K:15X"
Endif
Return

$SETGRI
#JOJAC - 2016-04-29 - REQ114309 US114 - START
#GCURLEG     = [F:GRI]LEG
#JOJAC - 2016-04-29 - REQ114309 US114 - START
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#JOJAC - 2016-04-29 - REQ114309 US114 - START
#[M]LEG      = GCURLEG
[M]LEG      = [F:GRI]LEG
#JOJAC - 2016-04-29 - REQ114309 US114 - START
[M]INTCOMP1 = [F:GRI]CMPDES(0)
[M]INTCOMP2 = [F:GRI]CMPDES(1)
[M]INTCOMP3 = [F:GRI]CMPDES(2)
[M]INTVAL1  = [F:GRI]COLDES(0)
[M]INTVAL2  = [F:GRI]COLDES(1)
Case [F:GRI]CMPTYP(0)
 When 1 : [M]TYP1 = "A"     : # 42801 [M]TYP1 = "AC"
 When 2 : [M]TYP1 = "DCB"
 When 3 : [M]TYP1 = "D"
Endcase
Case [F:GRI]CMPTYP(1)
 When 1 : [M]TYP2 = "A"     : # 42801 [M]TYP2 = "AC"
 When 2 : [M]TYP2 = "DCB"
 When 3 : [M]TYP2 = "D"
Endcase
Case [F:GRI]CMPTYP(2)
 When 1 : [M]TYP3 = "A"     : # 42801 [M]TYP3 = "AC"
 When 2 : [M]TYP3 = "DCB"
 When 3 : [M]TYP3 = "D"
Endcase
Case [F:GRI]COLTYP(0)
 When 1 : [M]TYP4 = "A"     : # 42801 [M]TYP4 = "AC"
 When 2 : [M]TYP4 = "DCB"
 When 3 : [M]TYP4 = "D"
Endcase
Case [F:GRI]COLTYP(1)
 When 1 : [M]TYP5 = "A"     : # 42801 [M]TYP5 = "AC"
 When 2 : [M]TYP5 = "DCB"
 When 3 : [M]TYP5 = "D"
Endcase
Return

$VERIF
For I=0 To [M]BDP-2
 For J=I+1 To [M]BDP-1
  OK2 = 1
  For K=1 To [F:GRI]NBRCMP
   Case K
    When 1 : If [M]CMP1(I)<>[M]CMP1(J) : OK2 = 0 : Endif
    When 2 : If [M]CMP2(I)<>[M]CMP2(J) : OK2 = 0 : Endif
    When 3 : If [M]CMP3(I)<>[M]CMP3(J) : OK2 = 0 : Endif
   Endcase
  Next K
  If OK2
   GMESSAGE = mess(10,10702,1)-num$(I+1)-num$(J+1) : # Composantes identiques en lignes
   OK = 0 : Break 2
  Endif
 Next J
Next I
Return

#Dans les objets combiné le INICRE est aussi appelé en modif -> pas besoin de INIMOD
$INICRE
For I=1 To [F:GRI]NBRCMP
 If [F:GRI]CMPTYP(I-1)=2
  Case I
   When 1 : [F:RIL]CMP1 = func GPLAN.FMTNUM("N0:10.4#",val([F:RIL]CMP1))
   When 2 : [F:RIL]CMP2 = func GPLAN.FMTNUM("N0:10.4#",val([F:RIL]CMP2))
   When 3 : [F:RIL]CMP3 = func GPLAN.FMTNUM("N0:10.4#",val([F:RIL]CMP3))
  Endcase
 Endif
Next I
Return

# Action ANURIL pour supprimer une fiche car CLECUR a 2 composantes => 3 parties de clé

$SETBOUT
If REP = ""
 CHAINE += "A"
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

$EXEACT
If BOUT="S" : OK = 0 : Endif : # Bouton Suppression
Return

Subprog ANNULE
Local Integer OK
OK = 2
Call OUINON(mess(28,100,1),OK) From GESECRAN
If OK<>2 : End: Endif
Trbegin [RIL]
 Delete [RIL] Where CODGRI=[M]CODGRI & STRDAT=[M]STRDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$GGRILLE" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
End

$ROLL_ANN
Rollback
Call ROLL From GLOCK
#67969
#If GROLL : Return : Else : Goto ANNULE : Endif
If GROLL : Return : Else : Call ANNULE : Endif
Return

$AB_ANN
Rollback
Return

#JOJAC - 2016-04-29 - REQ114309 US114 - START
$FILTRE
If GLEGFIL <> ''
FILTSUP += "[F:GRI]LEG = GLEGFIL"
Else
Endif
Return
#JOJAC - 2016-04-29 - REQ114309 US114 - END

########################################
Subprog C_CODGRI(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GRI",VALEUR,"") From CONTOBJ
Gosub SETGRI
Affzo
#JOJAC - 2016-04-29 - REQ114309 US114 - START
Read [F:GRI]GRI0=VALEUR
  If fstat : Raz [M:RIL0] : Affzo [M:RIL0] :  mkstat=1 : End
  Endif
#JOJAC - 2016-04-29 - REQ114309 US114 - END
End


Subprog AS_SCMP2(VALEUR)
Variable Char    VALEUR()
If [F:GRI]NBRCMP<2 : mkstat = 1 : End : Endif
End

Subprog AS_SCMP3(VALEUR)
Variable Char    VALEUR()
If [F:GRI]NBRCMP<3 : mkstat = 1 : End : Endif
End

Subprog AS_SVAL2(VALEUR)
Variable Char    VALEUR()
If [F:GRI]NBRCOL<2 : mkstat = 1 : End : Endif
End
######################################################################################
## Section automatically added (screen RIL0) 04/29/2016 10:33:47 (JOJAC)
######################################################################################
Subprog AM_CODGRI(VALEUR)
Variable Char    VALEUR()
End


