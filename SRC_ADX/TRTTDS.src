#########################################
# Infos "annualisées" du salarié
#########################################
$LIGNE_S65
NUMSTRUCT="S65."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

[L]NUMSTRUCT_DEB = "S65.G30.00" : [L]NUMSTRUCT_FIN = "S65.G53.99"
Gosub ECRIRE_STRUCTURE

[L]NUMSTRUCT_DEB = "S65.G55.05": [L]NUMSTRUCT_FIN = "S65.G55.05"
For [L]IPAC = 0 To dim([L]TPACTYPCOT) - 1                            #79347 TPACPFLSAL->TPACPLFSAL
    If [L]TPACTYPCOT([L]IPAC) <> 0 & ([L]TPACBRTSAL([L]IPAC) <> 0 or [L]TPACPLFSAL([L]IPAC) <> 0 or [L]TPACNBRDAY([L]IPAC) <> 0)
        Gosub ECRIRE_STRUCTURE
    Endif
Next

[L]NUMSTRUCT_DEB = "S65.G61.00" : [L]NUMSTRUCT_FIN = "S65.G61.00"
Gosub ECRIRE_STRUCTURE

[L]NUMSTRUCT_DEB = "S65.G62.05": [L]NUMSTRUCT_FIN = "S65.G62.05"
For [L]IRAE = 0 To dim([L]TRAETYPSTU) - 1
    #79347 TPAC*-> TRAE*
    If [L]TRAETYPSTU([L]IRAE) <> 0 & ([L]TRAEAMTPS([L]IRAE) <> 0 or [L]TRAEAMTPP([L]IRAE) <> 0)
        Gosub ECRIRE_STRUCTURE
    Endif
Next
Return

#########################################
#Honoraires
#########################################
$LIGNE_S70
NUMSTRUCT="S70."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

For [HLN2]HLN0(2) Where YEA=[M:DIA]YEA & DADFCY=[F:FCY]FCY

    # Pour les enregistrements d'honoraires du site traité.

    [L]NUMSTRUCT_DEB = "S70.G05.00" : [L]NUMSTRUCT_FIN = "S70.G05.00"
    Gosub ECRIRE_STRUCTURE

    For [F:HLN2]HLN0(3)

        # Pour un prestataire donné

        # N4DS - Ventilation des avantages en nature et indemnités

        Raz [L]AMTTVA
        Raz [L]TCODIND, [L]TAMTIND, [L]TCODAVT , [L]TAMTAVT, [L]LASTAVT, [L]LASTIND

        For [HLN]HLN0 Where YEA=[F:HLN2]YEA & DADFCY=[F:HLN2]DADFCY & PRVNUM=[F:HLN2]PRVNUM & AMT>0 & (HON=9 |HON=10 | HON=12)
            Case [F:HLN]HON
                When 9  :
                    [L]CODIND = mid$([F:HLN]VALHON, 1, 1)
                    [L]RANG = find([L]CODIND, [L]TCODIND)
                    [L]RANG -= 1
                    If [L]RANG < 0
                        [L]RANG = [L]LASTIND
                        [L]LASTIND += 1
                    Endif
                    [L]TCODIND([L]RANG) = [L]CODIND
                    [L]TAMTIND([L]RANG) += [F:HLN]AMT
                When 10 :
                    #Recherche des codes avantages en nature déclarés
                    # => VALHON ne devra plus contenir qu'une seule lettre ; par sécurité on prends la premiere
                    [L]CODAVT = mid$([F:HLN]VALHON, 1, 1)
                    [L]RANG = find([L]CODAVT, [L]TCODAVT)
                    [L]RANG -= 1
                    If [L]RANG < 0
                        [L]RANG = [L]LASTAVT
                        [L]LASTAVT += 1
                    Endif
                    [L]TCODAVT([L]RANG) = [L]CODAVT
                    [L]TAMTAVT([L]RANG) += [F:HLN]AMT
                When 12 :
                    #Calcul du montant TVA par prestataire
                    AMTTVA += [F:HLN]AMT
            Endcase
        Next

        #Date cloture ne doit être déclarée que si <> date de fin de déclaration
        If [M:DIA]EXOEND=[M:DIA]REFEND : Raz [M:DIA]EXOEND : Endif

        #Recherche prestataire
        Read [PRV]PRV0=[F:HLN2]PRVNUM
        If fstat<>0
            Call ECR_TRACE(mess(4,10707,1)-"HONPRV [PRV]",1) From GESECRAN
        Endif

        # Avantages en nature

        [L]NUMSTRUCT_DEB = "S70.G10.00" : [L]NUMSTRUCT_FIN = "S70.G10.00"
        Gosub ECRIRE_STRUCTURE

        [L]NUMSTRUCT_DEB = "S70.G10.05" : [L]NUMSTRUCT_FIN = "S70.G10.05"
        For [L]INAT = 0 To dim([L]TCODAVT) - 1
            If [L]TCODAVT([L]INAT) <> "" & [L]TAMTAVT([L]INAT) <> 0
                Gosub ECRIRE_STRUCTURE
            Endif
        Next

        # Indemnités

        [L]NUMSTRUCT_DEB = "S70.G10.10" : [L]NUMSTRUCT_FIN = "S70.G10.10"
        For [L]INAT = 0 To dim([L]TCODIND) - 1
            If [L]TCODIND([L]INAT) <> "" & [L]TAMTIND([L]INAT) <> 0
                Gosub ECRIRE_STRUCTURE
            Endif
        Next

        #Ligne d'honoraires : S70.G10.15

        [L]NUMSTRUCT_DEB = "S70.G10.15" : [L]NUMSTRUCT_FIN = "S70.G10.15"
        For [HLN]HLN0 Where YEA=[F:HLN2]YEA & DADFCY=[F:HLN2]DADFCY & PRVNUM=[F:HLN2]PRVNUM & AMT>0 & HON<12
            Gosub ECRIRE_STRUCTURE
        Next
    Next
Next
Return
#########################################
# Total Site
#########################################
$LIGNE_S80
NUMSTRUCT="S80."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

#Recherche adresse du site
Read [BPA]BPA0=3;[F:FCY2]FCY;[F:FCY2]BPAADD
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPA]",1) From GESECRAN
Endif

If VDNA <> 2
 #Recherche infos DADS du site
 Read [F:DFC]DFC0=[F:FCY2]FCY;[M:DIA]YEA;[M:DIA]REFSTR;[M:DIA]REFEND;VDNA
 If fstat<> 0
  Call ECR_TRACE(mess(4,10707,1)-"DADFCY [DFC]",1) From GESECRAN
  #79048 : Si pas DADFCY on le met pas en S80 (sauf en NEANT) !
  If [M]TYPFIL <>"55" : Return : Endif
 Elsif [F:DFC]DADCRN=""
  #79048 : Si pas de siret on le met pas en S80 !
  Call ECR_TRACE(mess(5,10705,1)-[F:DFC]FCY,1) From GESECRAN   #N° de SIRET non renseigné pour le site :
  Return
 Endif
Else
 Filter [DFC] Where FCY=[F:FCY2]FCY & YEA=[M:DIA]YEA & STRDAT<=[M:DIA]REFEND & ENDDAT>=[M:DIA]REFEND & FLGDNA=VDNA
 Read [F:DFC]DFC0 Last
 Filter [F:DFC]
 If fstat<> 0
   Call ECR_TRACE(mess(4,10707,1)-"DADFCY [DFC]",1) From GESECRAN
 Endif
Endif

Local Char SITSEC (10)

#------------------------------------------------------
# S80.G01.00 : Identification INSEE des établissements
#------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G01.00" : [L]NUMSTRUCT_FIN = "S80.G01.00"
Gosub ECRIRE_STRUCTURE

# NB : dans le cas de l'AED , seule la structure S80.G01.00 est envoyée , on n'a donc pas à se préoccuper des DFP/DFR
# => Pour l'instant on test "en dur" la notion d'AED (VDNA)
# => Quand on aura mis en place le test "structure" cela ne sera plus nécessaire

If VDNA = 2 : Return : Endif

#------------------------------------------------------------------------------------------------------
# S80.G01.01 : Institution de prévoyance ou mutuelle ou société d'assurances avec contrat sans salarié
#              (0, n)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G01.01" : [L]NUMSTRUCT_FIN = "S80.G01.01"
# TEST STRUCTURE PRESENTE => Si oui, on fait le bloc suivant, sinon, non
For [F:DFP]DFP0 Where FCY=[F:DFC]FCY & YEA=[F:DFC]YEA & STRDAT=[M:DIA]REFSTR & ENDDAT=[M:DIA]REFEND & FLGDNA=VDNA
    Gosub ECRIRE_STRUCTURE
Next

#------------------------------------------------------------------------------------------------------
# S80.G01.02 : IRC AGIRC-ARRCO sans salarié concerné
#              (0, n)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G01.02" : [L]NUMSTRUCT_FIN = "S80.G01.02"
For [F:DFR]DFR0 Where FCY=[F:DFC]FCY & YEA=[F:DFC]YEA & STRDAT=[M:DIA]REFSTR & ENDDAT=[M:DIA]REFEND & FLGDNA=VDNA
    Gosub ECRIRE_STRUCTURE
Next

#------------------------------------------------------------------------------------------------------
# S80.G01.03 : BTP
#              (0, n)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G01.03" : [L]NUMSTRUCT_FIN = "S80.G01.03"
Gosub ECRIRE_STRUCTURE

#------------------------------------------------------------------------------------------------------
# S80.G01.05 : Caisse Nationale des Barreaux Français sans salarié concerné
#              (0, 1)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G01.05" : [L]NUMSTRUCT_FIN = "S80.G01.05"
Gosub ECRIRE_STRUCTURE

#------------------------------------------------------------------------------------------------------
# S80.G45.05 : Cotisations établissement pour l'organisme de prévoyance
#              (0, n)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G45.05" : [L]NUMSTRUCT_FIN = "S80.G45.05"
For [F:DFQ]DFQ0 Where FCY=[F:DFC]FCY & YEA=[F:DFC]YEA & STRDAT=[M:DIA]REFSTR & ENDDAT=[M:DIA]REFEND & FLGDNA=VDNA
    Gosub ECRIRE_STRUCTURE
Next

#----------------------
# S80.G52.05 : MSA
#----------------------
[L]NUMSTRUCT_DEB = "S80.G52.05" : [L]NUMSTRUCT_FIN = "S80.G52.05"
Gosub ECRIRE_STRUCTURE

#------------------------------------------------------------------------------------------------------
# S80.G62.05 : Taxe et contribution d'apprentissage
#              (1, 1)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G62.05" : [L]NUMSTRUCT_FIN = "S80.G62.05"
Gosub ECRIRE_STRUCTURE

#------------------------------------------------------------------------------------------------------
# S80.G62.10 : Participation à la formation professionnelle continue
#              (1, 1)
#------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S80.G62.10" : [L]NUMSTRUCT_FIN = "S80.G62.10"
Gosub ECRIRE_STRUCTURE
Return

#########################################
$LIGNE_S90
NUMSTRUCT="S90."
NBRUB=NBLIGNE+2    :#Les 2 rubriques de S90.
Gosub ECRIRE
Return

#########################################
$ECRIRE
GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

For [L]ISTR = 0 To [L]NBSTR - 1
    If mid$([L]TSTR([L]ISTR), 1, 4) = [L]NUMSTRUCT
        [L]TVAL([L]ISTR) = ""
    Endif
Next

For [F:HRFTD]FTD0 Where left$([F:HRFTD]NUMREC,4) = [L]NUMSTRUCT & [F:HRFTD]XPSRES<>""
    [L]ZONE=[F:HRFTD]NUMREC
    Gosub VERIF_FORMULE
    If [L]OK_STRUCTURE
        Raz [L]OK_RESULTAT
        If [F:HRFTD]FLGREC=1    :#Obligatoire
            [L]OK_RESULTAT = 1
        Else
            If [L]RESULTAT<>"''"
                Case [F:HRFTD]TYPREC
                    When 1
                        [L]OK_RESULTAT = 1
                    When 2
                        If val(mid$([L]RESULTAT, 2, len([L]RESULTAT)-2)) <> 0
                            [L]OK_RESULTAT = 1
                        Endif
                    When 3
                        If val(mid$([L]RESULTAT, 2, len([L]RESULTAT)-2)) <> 0
                            [L]OK_RESULTAT = 1
                        Endif
                Endcase
            Endif
        Endif
        If [L]OK_RESULTAT
            Wrseq [L]ZONE, [L]RESULTAT Using [FIC]
            [L]NBLIGNE+=1
            Gosub MEMORISE
        Endif
    Endif
Next
Return

#########################################
$FERME_FICHIER
Openo FICHIER Using [FIC]
adxifs = SAVIFS
adxirs = SAVIRS
If [M:DIA]TYPEXP<2
 Call COPCLI(FICHIER,FICCLI,STAT) From ORDSYS
 If [L]STAT<>0 : [L]TRA = 0 : Endif
Endif
Return

#########################################
# VERIF_FORMULE : Vérification et évaluation de la formule de FILTDS ou FILTDSLIS
#########################################
$VERIF_FORMULE

RESULTAT=""

# Nouveauté N4DS : Vérification que la structure que l'on traite est "autorisée" dans le message que l'on génére et que les conditions s'appliquent

[L]OK_STRUCTURE = 1

# Vérification que la structure existe dans FILTDSLIS : Permet d'éviter tous les tests sur NATFIL dans le programme

Read [F:FTL]FTL0 = [F:HRFTD]YEA ; [L]NATFIL ; [F:HRFTD]NUMREC
If fstat <> 0
    # Structure non prévue dans le message, au revoir :)
    [L]OK_STRUCTURE = 0
    Return
Endif

# Présence d'une condition ?
# On teste le niveau le plus fin ( dans le message ) et à defaut on prends le niveau "général"

If vireblc([F:FTL]CND, 4) <> ""
    # Présence d'une condition au niveau le plus fin, elle remplace la condition générale
    [F:HRFTD]CND = [F:FTL]CND
Endif

If vireblc([F:HRFTD]CND, 4) <> ""

    # => Cas particulier de la pseudo fonction "EVAL" : A la base on voulait gérer chaque structure comme une variable ; malheureusement le nom
    #    de la variable en V5 étant limité on se rabat sur un tableau TSTR / TVAL , on a donc inventé une fonction EVAL qui place dans une variable
    #    STR (nom arbitraire en dur) le résultat de la structure demandée.
    # => On rajoute EVALP version améliorée

    If mid$([F:HRFTD]CND,1,5) = "EVAL(" or mid$([F:HRFTD]CND, 1, 6) = "EVALP("
        [L]EXPSTR = [F:HRFTD]CND
        Gosub EVAL
        If not (val([L]RESULTAT))
            [L]RESULTAT = ""
            [L]OK_STRUCTURE = 0
            Return
        Endif
    Else
        If not evalue([F:HRFTD]CND)
            [L]OK_STRUCTURE = 0
            Return
        Endif
    Endif
Endif

# Cas particulier de la surcharge : la structure que l'on traite est remplie différemment en fonction du message
# A priori ne servira pas mais sait on jamais
# => PAF, l'AED nous demande de remplir certaines zones de manière différente (ex : date de période de référence), du coup la surcharge va nous servir.

If vireblc([F:FTL]OVRLOA, 4) <> ""
    [F:HRFTD]XPSRES = [F:FTL]OVRLOA
Endif

# Interprétation effective

Onerrgo ERREUR

If seg$([F:HRFTD]XPSRES,1,5)="MENU("   :# Plus utiliser en std dans la N4DS
    Gosub INTERPRETE_MENU            :# Plus utiliser en std dans la N4DS

Elsif seg$([F:HRFTD]XPSRES,1,5)="EVAL(" or seg$([F:HRFTD]XPSRES, 1, 5) = "EVALP("
    [L]EXPSTR = [F:HRFTD]XPSRES
    Gosub EVAL
Elsif seg$([F:HRFTD]XPSRES,1,6)="TABLE("
 Gosub INTERPRETE_TABLE
Elsif seg$([F:HRFTD]XPSRES,1,107)="TABLE2("
 Gosub INTERPRETE_TABLE2
Elsif seg$ ([F:HRFTD]XPSRES,1,8)="CHERCHE("
 Gosub INTERPRETE_CHERCHE
Elsif seg$ ([F:HRFTD]XPSRES,1,107)="CONCAT("
 Gosub INTERPRETE_CONCAT
Else
 Gosub INTERPRETE
Endif

Onerrgo

If [L]RESULTAT = space$(len([L]RESULTAT))
    [L]RESULTAT = ""
Endif

# N4DS - Gestion du post-traitement
If vireblc([F:HRFTD]TRT, 4) <> ""
    [L]RESULTAT = evalue([F:HRFTD]TRT)
Endif

If RESULTAT <>"" & RESULTAT<>"0"
    Case [F:HRFTD]TYPREC
        When 1
            If len(RESULTAT)>=[F:HRFTD]LNGREC
                RESULTAT=seg$(RESULTAT,1,[F:HRFTD]LNGREC)
            Endif
        When 2
            # Si pas de post traitement, on formate à X + 2#
            If vireblc([F:HRFTD]TRT,4) = ""
                [L]RESULTAT = num$(val(format$("Nz:"+num$([F:HRFTD]LNGREC)+".2#", val([L]RESULTAT))))
            Endif
            # Sinon le post traitement aura eu pour charge de mettre en forme correctement
        When 3
            If RESULTAT<>"00/00/0000"
                [L]RESULTAT=mid$(RESULTAT,1,2)+mid$(RESULTAT,4,2)+mid$(RESULTAT,7,4)
            Else
                RESULTAT=""
            Endif
        When Default
    Endcase
Endif

# Et au final on encadre le résultat par des '

RESULTAT="'"+RESULTAT+"'"
Return

#------------------------------------------------------------------------------------------------------------------------
# Fonction "EVAL" : Au départ on avait prévu de gérer chaque structure comme une variable ([L]S40_G01_00_003 ...)
#                   Manque de chance la V5 n'admet que 12 caractères significatifs sur un nom de variable
#                   il nous en faudrait au moins 14 pour faire quelque chose de propre
#                   Du coup, on stocke les structures dans un tableau TSTR et en regard le resultat dans un tableau
#                   TVAL.
#                   La pseudo fonction EVAL(numstr,formule) renvoie le resultat de l'évaluation de "formule" en
#                   positionnant au préalable une variable générique STR avec la valeur (TVAL) de la structure "numstr"
#########################################
$EVAL
If mid$([L]EXPSTR, 1, 5) = "EVAL("
    [L]POS1 = instr(1, [L]EXPSTR, '"')
    If [L]POS1 > 0
        [L]POS2 = instr([L]POS1+1, [L]EXPSTR, '"')
        If [L]POS2 > 0
            [L]ZONSTR = seg$([L]EXPSTR, [L]POS1+1, [L]POS2-1)
            [L]POS1 = instr([L]POS2+1, [L]EXPSTR, '"')
            If [L]POS1 > 0
                [L]POS2 = instr([L]POS1+1, [L]EXPSTR, '"')
                [L]FORSTR = seg$([L]EXPSTR, [L]POS1+1, [L]POS2-1)

                # Retrouver la valeur de nomzone

                [L]ISTR = find([L]ZONSTR, [L]TSTR)
                [L]ISTR -= 1
                If [L]ISTR >= 0
                    [L]STR = [L]TVAL([L]ISTR)
                    Onerrgo ERREUR
                    [L]RESULTAT = num$(evalue([L]FORSTR))
                    Onerrgo
                Endif
            Endif
        Endif
    Endif
Elsif mid$([L]EXPSTR, 1, 6) = "EVALP("
    [L]FORSTR  = right$([L]EXPSTR, 8)                    : # EVALP( => 6 + " de début => 7 donc on prends à partir du 8 eme
    [L]FORSTR = left$([L]FORSTR, len([L]FORSTR) - 2)     : # Et on vire le ") de fin
    [L]RESULTAT = func N4DSLIB.EVALP([L]TSTR, [L]TVAL, [L]FORSTR)
Endif
Return

#########################################
# INTERPRETE : Evalue de la chaine XPSRES
#########################################
$INTERPRETE
#On remplace les caractères non autorisée par un espace
If [F:HRFTD]TYPREC=1 :#Alphanumérique
 RESULTAT=toupper(ctrans(num$(evalue([F:HRFTD]XPSRES)),LSTCAR,chr$(32)))
 # On vire les accents...
 RESULTAT=ctrans(RESULTAT)
Else
 RESULTAT=toupper(ctrans(num$(evalue([F:HRFTD]XPSRES))))
Endif

# On vire les espaces en début et fin de chaine+ consécutif
[L]RESULTAT = vireblc([L]RESULTAT,2)
[L]RESULTAT = vireblc([L]RESULTAT,5)
Return

#########################################
$INTERPRETE_CONCAT
Local Char EXPRESSION (100)
Local Char VALZONE (1)
Local Char NOMZONE (50)
Local Integer I,J
I=-1
EXPRESSION=seg$([F:HRFTD]XPSRES,8,len([F:HRFTD]XPSRES)-1)
I=instr(1,EXPRESSION,";")
While I>0
 J=instr(1,EXPRESSION,"[")
 NOMZONE=seg$(EXPRESSION,J,I-1)
 RESULTAT=RESULTAT+toupper(ctrans(num$(evalue(NOMZONE))))
 EXPRESSION=seg$(EXPRESSION,I+1,len(EXPRESSION))
 I=instr(1,EXPRESSION,";")
Wend
#traitement de la dernière zone
If I=0
 RESULTAT=RESULTAT+toupper(ctrans(num$(evalue(EXPRESSION))))
Endif
#On vire les espaces en début et fin de chaine
RESULTAT=vireblc(RESULTAT,2)
RESULTAT=vireblc(RESULTAT,5)
Return

#########################################
$INTERPRETE_CHERCHE
Local Char VALZONE (1)
Local Char NOMZONE (50)
Local Integer I
VALZONE=seg$([F:HRFTD]XPSRES,10,10)
# en position 11 c'est un guillemet et en position 12 c'est la virgule...
NOMZONE=seg$ ([F:HRFTD]XPSRES,13,len([F:HRFTD]XPSRES)-1)
If VALZONE<>""
 I=instr (1,evalue(NOMZONE),VALZONE)
 If I<>0 : RESULTAT=VALZONE : Else RESULTAT="" : Endif
Else      #Erreur de formule à la ligne...
 Call ECR_TRACE(mess(5,10707,1)-[F:HRFTD]NUMREC,0) From GESECRAN
Endif
Return

#########################################
$INTERPRETE_TABLE
Local Char VARIA (20)
Local Char NOMZONE (50)
Local Char VALZONE (50)
Local Integer I,NUMTAB, J
I=instr(1,[F:HRFTD]XPSRES,";")
If I
 VARIA=seg$([F:HRFTD]XPSRES,7,I-1)
 NOMZONE=seg$([F:HRFTD]XPSRES,I+1, len([F:HRFTD]XPSRES)-1)
Else            #Erreur de formule à la ligne...
 Call ECR_TRACE(mess(5,10707,1)-[F:HRFTD]NUMREC,0) From GESECRAN
Endif
NUMTAB = evalue(VARIA)
VALZONE= evalue(NOMZONE)
If VALZONE<>""
 Read [ADI]CODE=NUMTAB;VALZONE
 If fstat<>0
  #Erreur de lecture sur le fichier ATABDIV [ADI] (n°XXX / Code YYY)
  Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI] (n°"+num$(NUMTAB)-"/"-mess(37,100,1)-VALZONE+")",1) From GESECRAN
 Else
  If NUMTAB=10359
   J=instr (1,[F:ADI]A1,"|")
   If J
    If VDNA=2
     # on prend la partie après le |
     RESULTAT=seg$([F:ADI]A1,J+1,len([F:ADI]A1))
    Else
     # on prend la partie avant le |
     RESULTAT=seg$([F:ADI]A1,1,J-1)
    Endif
   Else
    If VDNA=2
     RESULTAT=""
    Else
     RESULTAT=[F:ADI]A1
    Endif
   Endif
  Else
   RESULTAT=[F:ADI]A1
  Endif
 Endif
Endif
Return

#########################################
$INTERPRETE_TABLE2
Local Char VARIA (20)
Local Char NOMZONE (50)
Local Char VALZONE (50)
Local Integer I,NUMTAB, J
I=instr(1,[F:HRFTD]XPSRES,";")
If I
 VARIA=seg$([F:HRFTD]XPSRES,8,I-1)
 NOMZONE=seg$([F:HRFTD]XPSRES,I+1, len([F:HRFTD]XPSRES)-1)
Else            #Erreur de formule à la ligne...
 Call ECR_TRACE(mess(5,10707,1)-[F:HRFTD]NUMREC,0) From GESECRAN
Endif
NUMTAB = evalue(VARIA)
VALZONE= evalue(NOMZONE)
If VALZONE<>""
 Read [ADI]CODE=NUMTAB;VALZONE
 If fstat<>0
  #Erreur de lecture sur le fichier ATABDIV [ADI] (n°XXX / Code YYY)
  Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI] (n°"+num$(NUMTAB)-"/"-mess(37,100,1)-VALZONE+")",1) From GESECRAN
 Else
  If VDNA=2
   RESULTAT=""
  Else
   Case NUMTAB
   When 10386 :
    If ![F:ADI]N1
     RESULTAT=""
    Elsif len(num$([F:ADI]N1))>=3
     RESULTAT=left$(num$([F:ADI]N1),3)
    Else
     RESULTAT=string$(3-len(num$([F:ADI]N1)),"0")+num$([F:ADI]N1)
    Endif
   When Default :
    RESULTAT=left$([F:ADI]A2,[F:HRFTD]LNGREC)
   Endcase
  Endif
 Endif
Endif
Return

#########################################
# Ecriture de la structure dans le fichier texte
# Totalement banalisé : tous les positionnements sont faits en amont ou par le paramétrage dans FILTDSLIS vérifié dans VERIF_FORMULE
#########################################
$ECRIRE_STRUCTURE

For [L]ISTR = 0 To [L]NBSTR - 1
    If mid$([L]TSTR([L]ISTR), 1, 10) >= [L]NUMSTRUCT_DEB & mid$([L]TSTR([L]ISTR), 1, 10) <= [L]NUMSTRUCT_FIN
        Raz [L]TVAL([L]ISTR)
    Endif
Next

For [F:HRFTD]FTD0 Where left$([F:HRFTD]NUMREC, 10) >= [L]NUMSTRUCT_DEB & left$([F:HRFTD]NUMREC, 10) <= [L]NUMSTRUCT_FIN
&                    & [F:HRFTD]XPSRES<>""
    [L]ZONE = [F:HRFTD]NUMREC
    Gosub VERIF_FORMULE
    If [L]OK_STRUCTURE
        Raz [L]OK_RESULTAT
        If [F:HRFTD]FLGREC=1    :#Obligatoire
            [L]OK_RESULTAT = 1
        Else
            If [L]RESULTAT<>"''"
                Case [F:HRFTD]TYPREC
                    When 1
                        [L]OK_RESULTAT = 1
                    When 2
                        If val(mid$([L]RESULTAT, 2, len([L]RESULTAT)-2)) <> 0
                            [L]OK_RESULTAT = 1
                        Endif
                    When 3
                        If val(mid$([L]RESULTAT, 2, len([L]RESULTAT)-2)) <> 0
                            [L]OK_RESULTAT = 1
                        Endif
                Endcase
            Endif
        Endif
        If [L]OK_RESULTAT
            Wrseq [L]ZONE, [L]RESULTAT Using [FIC]
            [L]NBLIGNE+=1
            Gosub MEMORISE
        Endif
    Endif
Next
Return

#########################################
# Mémorisation de la dernière valeur écrite dans cette structure - usage ultérieur pour condition d'activation
#########################################
$MEMORISE
# On mémorise dans le tableau de stockage
[L]ISTR = find([L]ZONE, [L]TSTR)
[L]ISTR -= 1
If [L]ISTR >= 0
    [L]MEMO_RESULTAT = mid$([L]RESULTAT, 2, len([L]RESULTAT)-2)
    [L]TVAL([L]ISTR) = [L]MEMO_RESULTAT
Endif
Return

#########################################
$ERREUR
Call ECR_TRACE(mess(80,10703,1)-[F:DAE]EMPDDS-":",0) From GESECRAN
Call ECR_TRACE([F:HRFTD]NUMREC-mess(93,100,1)-num$(errn)-errmes$(errn),0) From GESECRAN
Resume

################################################### ETIQUETTES ECRAN ##############################################################


################################################################################
# Bloc DECLARATION
################################################################################

########################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If clalev([F:TD0])=0 : Local File PRMTDS0  [TD0] : Endif
Filter [F:TD0] Where LEV=2 & CPY=VALEUR & FLGDNA=val(GFLAG)
Read [F:TD0]TD00 First
Filter [F:TD0]
If !fstat
 [M]NATFIL=[F:TD0]NATFIL
 [M]TYPFIL=[F:TD0]TYPFIL
 [M]OPTFIL=[F:TD0]OPTFIL
 Affzo [M]NATFIL,TYPFIL,OPTFIL
 Call INITREF ([M]NATFIL)
Endif
End

########################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

########################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

########################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From DIVPAYE
End

########################################
Subprog C_NATFIL(VALEUR)
Variable Char    VALEUR()
Call  C_NATFIL(VALEUR) From SUBTDS
If mkstat : End : Endif
Read [F:TD0]TD00=2;[M]CPY;VALEUR;val(GFLAG)
If ! fstat
 #Honoraires
 If VALEUR<>"01" & VALEUR<>"02" & VALEUR<>"12"
  Effzo [M]EXOSTR,EXOEND
  Grizo [M]EXOSTR,EXOEND
 Else
  Actzo [M]EXOSTR,EXOEND
 Endif
Else
 #<Societe> Opération impossible : Paramètres TDS inexistant
 GMESSAGE=[M:DIA]CPY-":"-mess(2,10705,1)
 mkstat=2 : End
Endif
End

########################################
Subprog AM_NATFIL(VALEUR)
Variable Char    VALEUR()
Call INITREF (VALEUR)
End

########################################
Subprog C_TYPFIL(VALEUR)
Variable Char    VALEUR()
Call C_TYPFIL(VALEUR) From SUBTDS
If mkstat : End : Endif
If VALEUR<>"52"
 Effzo [M]RATSTR,RATEND
 Grizo [M]RATSTR,RATEND
Else
 Actzo [M]RATSTR,RATEND
Endif
If VALEUR<>"59" & VALEUR<>"60"
 Effzo [M]REFDNA2
 Grizo [M]REFDNA2
Else
 Actzo [M]REFDNA2
Endif
End

########################################
Subprog C_OPTFIL(VALEUR)
Variable Char    VALEUR()
Call C_OPTFIL(VALEUR) From SUBTDS
End

################################################################################
# Bloc PERIODES
################################################################################
Subprog AM_REFSTR(VALEUR)
Variable Date    VALEUR
If val(GFLAG)=2 :
 [M:DIA]YEA=num$(year(VALEUR))
 [M:DIA]REFEND=eomonth(VALEUR)
Else
 [M:DIA]REFEND=addmonth(VALEUR,12)-1
Endif
End

Subprog AS_REFEND(VALEUR)
Variable Date    VALEUR
If val(GFLAG)=2 : mkstat=2 : End : Endif
End

########################################
Subprog INITREF (VALEUR)
Variable Char    VALEUR()
If VALEUR="04"
 [M:DIA]REFSTR=gdat$(01,04,val([M:DIA]YEA))
 [M:DIA]REFEND=addmonth([M:DIA]REFSTR,12)-1
Else
 If val(GFLAG)=2
  [M:DIA]YEA=num$(year(GMOIPAY))
  [M:DIA]REFSTR=GMOIPAY
  [M:DIA]REFEND=eomonth(GMOIPAY)
 Else
  [M:DIA]REFSTR=gdat$(01,01,val([M:DIA]YEA))
  [M:DIA]REFEND=addmonth([M:DIA]REFSTR,12)-1
 Endif
Endif
Affzo [M:DIA]REFSTR, REFEND
End

########################################
Subprog AS_RATSTR(VALEUR)
Variable Date    VALEUR
If [M]TYPFIL<>"52" & [M]TYPFIL<>"53"  : mkstat=1 : End : Endif
End

########################################
Subprog AS_RATEND(VALEUR)
Variable Date    VALEUR
If [M]TYPFIL<>"52" & [M]TYPFIL<>"53"  : mkstat=1 : End : Endif
End

########################################
Subprog C_RATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 If [M]TYPFIL="52" & (year([M]REFSTR)-year(VALEUR))>10
  #La période de rattachement ne peut pas être < de + de 10 ans à la période de réf.
  GMESSAGE=mess(32,10705,1) : mkstat=2 : End
 Endif
 If [M]TYPFIL="53" & (year([M]REFSTR)-year(VALEUR))>3
  #La période de rattachement ne peut pas être < de + de 3 ans à la période de réf.
  GMESSAGE=mess(46,10705,1) : mkstat=2 : End
 Endif
Endif
End

########################################
Subprog AS_EXOSTR(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M:DIA]REFSTR : Endif
End

########################################
Subprog AS_EXOEND(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M:DIA]REFEND : Endif
End

########################################
Subprog C_EXOEND(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:DIA]REFEND
#Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
End

################################################################################
# Bloc FICHIER
################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & [L]VALEUR<2
 GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat=2 : End
Endif
#Nom du fichier saisissable dans cette ecran uniquement si génération sur serveur
If [L]VALEUR=2 : Actzo [DIA] FILNAM
Else             Grizo [DIA] FILNAM
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Char FICHIER (GDIMFIC)
If [L]VALEUR<2
 #Composition du nom du fichier
 Call AS_FILNAM(FICHIER)
 Call SET_NAMCLI(FICHIER) From ORDSYS
 Gosub EXTENSION
 [M:DIA]FILNAM=FICHIER+"."+EXTFIC
Endif
End


########################################
Subprog AS_FILNAM(VALEUR)
Variable Char    VALEUR()
#Composition du nom du fichier
Local Char VCPY
Local Char VTYPSND
VCPY=[M:DIA]CPY
If [M:DIA]FLGSND=2
 VTYPSND="R"
Else
 VTYPSND="T"
Endif
If val(GFLAG)=2
 If len(num$(month([M:DIA]REFSTR)))<2
  VALEUR+=VCPY+num$(year([M:DIA]REFSTR))+"0"+num$(month([M:DIA]REFSTR))+VTYPSND
 Else
  VALEUR+=VCPY+num$(year([M:DIA]REFSTR))+num$(month([M:DIA]REFSTR))+VTYPSND
 Endif
Else
 VALEUR=VCPY+[M:DIA]YEA+VTYPSND
Endif
Affzo [M:DIA]FILNAM
End

########################################
Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(GDIMFIC)
Local Integer OK
Gosub EXTENSION
Call C_NOMEXP(VALEUR,EXTFIC) From TRTDUE
If mkstat=2 : End : Endif
Call EXISTE(filpath([V]GDIRBQE,[L]VALEUR,EXTFIC,0),[L]OK) From ORDSYS
If [L]OK
 [V]GMESSAGE=mess(132,133,1) : # Fichier déjà existant
 [V]GERR    =3
 End
Endif
End

########################################
Subprog AS_SRV(VALEUR)
Variable Integer VALEUR
If !VALEUR :  VALEUR=1 : Endif
# Certains choix sont réservés aux echanges inter-organismes (50 ; 53 ; 57 ; 58 ; 59 ; 60)
GMENLOC(2)=1
GMENLOC(4)=1
GMENLOC(5)=1
GMENLOC(6)=1
GMENLOC(7)=1
GMENLOC(8)=1
End

########################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
If [M]TYPFIL<>"52" & [M]TYPFIL<>"53"
 Effzo [M]RATSTR,RATEND
 Grizo [M]RATSTR,RATEND
Else
 Actzo [M]RATSTR,RATEND
Endif
If [M]TYPFIL<>"59" & [M]TYPFIL<>"60"
 Effzo [M]REFDNA2
 Grizo [M]REFDNA2
Else
 Actzo [M]REFDNA2
Endif
#Honoraires
If [M]NATFIL<>"01" & [M]NATFIL<>"02" & [M]NATFIL<>"12"
 Effzo [M]EXOSTR,EXOEND
 Grizo [M]EXOSTR,EXOEND
Else
 Actzo [M]EXOSTR,EXOEND
Endif
End

#---------------------------------------------
# Plus utiliser en std dans la N4DS mais bon...
#########################################
$INTERPRETE_MENU
If 1=2
    Local Char NOMZONE (50)
    Local Integer IMESS
    NOMZONE=seg$([F:HRFTD]XPSRES,6,len([F:HRFTD]XPSRES)-1)
    Case NOMZONE
     When "[F:DAE]TYPJOB" :
      Case evalue(NOMZONE)
       When 1,2,4,5 : Gosub VALDEF
       When 9       : RESULTAT="06"
       When 10      : RESULTAT="07"
       When 13      : RESULTAT="08"
       When 14      : RESULTAT="10"
       When 15      : RESULTAT="09"
       When Default : RESULTAT="90"
      Endcase
     When "[F:DAE]WRKSTG" :
      Case evalue(NOMZONE)
       When 1 : RESULTAT="02" :#Etranger
       When 2 : RESULTAT=""
       When 3 : RESULTAT="01" :#Frontalier
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]TIP" :
      Case evalue(NOMZONE)
       When 1 : RESULTAT=""
       When 2 : RESULTAT="P"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]NTIC","[F:PRV]NTIC"
      Case evalue(NOMZONE)
       When 1 : RESULTAT=""
       When 2 : RESULTAT="T"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]OPEDED" :
      Case evalue(NOMZONE)
       When 1 : RESULTAT="R"
       When 2 : RESULTAT="F"
       When Default : RESULTAT=""
      Endcase
     When "[F:DFC]TAXWAG","[F:DFC]FLGAPP","[F:DFC]FLGFOR","[F:DFC]FLGAPPSUP" :
      Case evalue(NOMZONE)
       When 1 : RESULTAT="02"
       When 2 : RESULTAT="01"
       When Default : RESULTAT="02"
      Endcase
     When "[M:DIA]SRV"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="40"
       When 3 : RESULTAT="52"
       When Default : RESULTAT="40"
      Endcase
     When "[F:DAE]CODOFC"
      Case evalue(NOMZONE)
       When 1 : RESULTAT=""
       When 2 : RESULTAT="B"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]UOMTIMWRK"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="01"
       When 2 : RESULTAT="03"
       When 3 : RESULTAT="07"
       When Default : RESULTAT="01"
      Endcase
     When "[F:DFC]REGPRH","[F:DFC]SECPRH"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="03" :#Agricole
       When 2 : RESULTAT="01" :#Industrie
       When 3 : RESULTAT="02" :#Commerce
       When 4 : RESULTAT="04" :#Divers
       When Default : RESULTAT="04"
      Endcase
     When "[F:DPP]CODTYPBAS(IDPP)"
      Case evalue(NOMZONE)
       When 9 : RESULTAT="59"
       When 10 : RESULTAT="60"
       When 11 : RESULTAT="70"
       When 13 : RESULTAT="80"
       When Default :
        RESULTAT=num$(evalue(NOMZONE))
        RESULTAT=num$(val(RESULTAT)+9)
      Endcase
     When "[F:DAE]CODSITFAM","[F:DAE]BUISITFAM"
      Case evalue(NOMZONE)
       When 1,2,3,4,5,6,7 : Gosub VALDEF
       When 8 : RESULTAT="90"
       When 9 : RESULTAT="91"
       When Default : RESULTAT="90"
      Endcase
     When "[F:DAE]BUICODTIM", "[F:DAC]SPETIMEVE"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="01"
       When 2 : RESULTAT="03"
       When 3 : RESULTAT="07"
       When 4 : RESULTAT="09"
       When Default : RESULTAT="07"
      Endcase
     When "[F:DAE]BUICODASS"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="02"
       When 2 : RESULTAT="01"
       When Default : RESULTAT="01"
      Endcase
     When "[F:DAE]BUISTAPAY"
      Case evalue(NOMZONE)
       When 1,2,3   : Gosub VALDEF
       When 4       : RESULTAT="90"
       When Default : RESULTAT="90"
      Endcase
     When "[F:DAE]PRUCTR"
      Case evalue(NOMZONE)
       When 1,2     : Gosub VALDEF
       When Default : RESULTAT="01"
      Endcase
      FLGDRT=val(RESULTAT)
     When "[F:DAE]PRUFLG"
      Case evalue(NOMZONE)
       When 1  : RESULTAT="02"
       When 2  : RESULTAT="01"    :#Présent au 31/12
       When Default : RESULTAT="01"
      Endcase
      FLGCTR=val(RESULTAT)
     When "[F:DAC]OLDSPE"
      Case evalue(NOMZONE)
       When 2        : RESULTAT="01"
       When Default  : RESULTAT=""
      Endcase
     When "[F:DAE]CODCNB"
      Case evalue(NOMZONE)
       When 1,2,3,4 : Gosub VALDEF
       When 5  : RESULTAT=""
      Endcase
     When "[F:DFC]CODCNBFCY","[F:DAE]SYSFLG"
      Case evalue(NOMZONE)
       When 2       : RESULTAT="01"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]AGFFLG"
      Case evalue(NOMZONE)
       When 2       : RESULTAT="01"
       When 3       : RESULTAT="02"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAC]DAYTYP", "[F:DAE]BUIDAYTYP"
      Case evalue(NOMZONE)
       When 2 : Gosub VALDEF
       When Default : RESULTAT="01"
      Endcase
     When "[F:DAE]FLGJNT"
      Case evalue(NOMZONE)
       When 2 : RESULTAT="03"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAE]DEGMAL"
      Case evalue(NOMZONE)
       When 3 : RESULTAT=""
       When Default : Gosub VALDEF
      Endcase
     When "[F:DAI]CODDAI"
      Case evalue(NOMZONE)
       When 2 : RESULTAT="03"
       When 3 : RESULTAT="04"
       When 4 : RESULTAT="05"
       When Default : RESULTAT="01"
      Endcase
     When "[F:DAE]UOMANC(IDPP)"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="01"
       When 3 : RESULTAT="02"
       When 4 : RESULTAT="03"
       When Default : RESULTAT="03"
      Endcase
     When "[F:DAQ]FLGBNF1","[F:DAQ]FLGBNF2","[F:DAQ]FLGBNF3","[F:DAQ]FLGBNF4"
      Case evalue(NOMZONE)
       When 2 : RESULTAT="01"
       When Default : RESULTAT=""
      Endcase
     When "[F:DAG]CODDAG"
      Case evalue([L]NOMZONE)
        When 1 : [L]RESULTAT = "01"
        When 2 : [L]RESULTAT = "02"
        When 3 : [L]RESULTAT = ""
        When 4 : [L]RESULTAT = ""
        When 5 : [L]RESULTAT = ""
        When 6 : [L]RESULTAT = "31"
        When 7 : [L]RESULTAT = "32"
        When 8 : [L]RESULTAT = "33"
        When 9 : [L]RESULTAT = "41"
        When 10 : [L]RESULTAT = "42"
        When 11 : [L]RESULTAT = "43"
        When Default : RESULTAT=""
      Endcase
     When "[F:DAK]CODDAK"
      Case evalue([L]NOMZONE)
        When 1 : [L]RESULTAT = "201"
        When 2 : [L]RESULTAT = "202"
        When 3 : [L]RESULTAT = "203"
        When 4 : [L]RESULTAT = "204"
        When 5 : [L]RESULTAT = "205"
        When 6 : [L]RESULTAT = "206"
        When 7 : [L]RESULTAT = "103"
        When 8 : [L]RESULTAT = "208"
        When 9 : [L]RESULTAT = "209"
        When 10 : [L]RESULTAT = "210"
        When 11 : [L]RESULTAT = "211"
        When 12 : [L]RESULTAT = "212"
        When 13 : [L]RESULTAT = "213"
        When 14 : [L]RESULTAT = "214"
        When 15 : [L]RESULTAT = "215"
        When 16 : [L]RESULTAT = "216"
        When 17 : [L]RESULTAT = "217"
        When 18 : [L]RESULTAT = "218"
        When 19 : [L]RESULTAT = "220"
        When 20 : [L]RESULTAT = "003"
        When 21 : [L]RESULTAT = "004"
        When 22 : [L]RESULTAT = "101"
        When 23 : [L]RESULTAT = "102"
        When 24 : [L]RESULTAT = "104"
        When Default : RESULTAT=""
      Endcase
     When "[F:DAE]WAGPAYPER"
      Case evalue([L]NOMZONE)
        When 1 : [L]RESULTAT = "11"
        When 2 : [L]RESULTAT = "12"
        When 3 : [L]RESULTAT = "13"
        When 4 : [L]RESULTAT = "14"
        When 5 : [L]RESULTAT = "15"
        When 6 : [L]RESULTAT = "16"
        When 7 : [L]RESULTAT = "17"
        When 8 : [L]RESULTAT = "90"
        When Default : [L]RESULTAT = "16"    : # Mensuel
      Endcase
    ###DNA
     When "[F:DNA]DNASITADM"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="10"
       When 2 : RESULTAT="21"
       When 3 : RESULTAT="22"
       When 4 : RESULTAT="23"
       When Default : RESULTAT="10"
      Endcase
     When "[F:DNA]DNACPYSTG"
      Case evalue(NOMZONE)
       When len(mess(0,10963,1)): RESULTAT=""
       When Default : Gosub VALDEF
      Endcase
     When "[F:DNA]DNAACTASS"
      Case evalue(NOMZONE)
       When 1,2 : Gosub VALDEF
       When 3 : RESULTAT="10"
       When Default : RESULTAT="01"
      Endcase
     When "[F:DNA]DNAEXOASS"
      Case evalue(NOMZONE)
       When 1,2 : Gosub VALDEF
       When Default : RESULTAT="90"
      Endcase
     When "[F:DNA]DNAAGS"
      Case evalue(NOMZONE)
       When 1 : Gosub VALDEF
       When Default : RESULTAT="10"
      Endcase
     When "[F:DNA]DNACCP"
      Case evalue(NOMZONE)
       When len(mess(0,10965,1)): RESULTAT=""
       When Default : Gosub VALDEF
      Endcase
     When "[F:DNF]DNACODTIM"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="12"
       When 2 : RESULTAT="14"
       When 3 : RESULTAT="16"
       When 4 : RESULTAT="20"
       When 5 : RESULTAT="21"
       When 6 : RESULTAT="22"
       When 7 : RESULTAT="23"
       When 8 : RESULTAT="24"
       When 9 : RESULTAT="25"
       When Default : RESULTAT="90"
      Endcase
     When "[F:DNA]DNACODHOR"
      Case evalue(NOMZONE)
       When len(mess(0,10967,1)): RESULTAT="90"
       When Default : Gosub VALDEF
      Endcase
     When "[F:DNA]DNACODTPS"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="16"
       When Default : RESULTAT="40"
      Endcase
     When "[F:DNA]DNACLC"
      Case evalue(NOMZONE)
       When 2 : RESULTAT=""
       When Default : RESULTAT="01"
      Endcase
     When "[F:DNA]FLGINDSUP"
      Case evalue(NOMZONE)
       When 1 : RESULTAT="02"
       When 2 : RESULTAT="01"
       When Default : RESULTAT="03"
      Endcase
     When "[F:DND]DNACODPRV"
      Case evalue(NOMZONE)
       When 4 : RESULTAT="90"
       When Default : Gosub VALDEF
      Endcase
     When "[F:DNE]DNACODIND"
      # (C) PROSPER V01X06 - Modification de la valeur renvoyée
      # Case evalue(NOMZONE)
      # When 19 : RESULTAT="20"
      # When 20 : RESULTAT="21"
      # When Default : Gosub VALDEF
      # Endcase
      # (C) PROSPER V01X06 - Dans le cas ou le système de transcodage ne serait pas prêt, conserver un truc qui fonctionne
      Case evalue(NOMZONE)
        When 1 : [L]RESULTAT = "201"
        When 2 : [L]RESULTAT = "202"
        When 3 : [L]RESULTAT = "203"
        When 4 : [L]RESULTAT = "204"
        When 5 : [L]RESULTAT = "205"
        When 6 : [L]RESULTAT = "206"
        When 7 : [L]RESULTAT = "103"
        When 8 : [L]RESULTAT = "208"
        When 9 : [L]RESULTAT = "209"
        When 10 : [L]RESULTAT = "210"
        When 11 : [L]RESULTAT = "211"
        When 12 : [L]RESULTAT = "212"
        When 13 : [L]RESULTAT = "213"
        When 14 : [L]RESULTAT = "214"
        When 15 : [L]RESULTAT = "215"
        When 16 : [L]RESULTAT = "216"
        When 17 : [L]RESULTAT = "217"
        When 18 : [L]RESULTAT = "218"
        When 19 : [L]RESULTAT = "220"
        When 20 : [L]RESULTAT = "003"
        When 21 : [L]RESULTAT = "004"
        When 22 : [L]RESULTAT = "101"
        When 23 : [L]RESULTAT = "102"
        When 24 : [L]RESULTAT = "104"
        When Default : RESULTAT=""
      Endcase
     When "[F:DNA]TYPLNK"
      If [F:DNA]LNK=2
       Gosub VALDEF
      Else
       RESULTAT=""
      Endif
     When Default
      Case evalue(NOMZONE)
       When 0 : RESULTAT="01" :# par sécurité
       When Default : Gosub VALDEF
      Endcase
     Endcase
Endif
Return

#---------------------------------------------
# Plus utiliser en std dans la N4DS mais bon...
#########################################
$VALDEF
If 1=2
 # On complète par des 0 devant
 If len(num$(evalue(NOMZONE)))<[F:HRFTD]LNGREC
  RESULTAT=string$([F:HRFTD]LNGREC-len(num$(evalue(NOMZONE))),"0")+num$(evalue(NOMZONE))
 Else
  RESULTAT=num$(evalue(NOMZONE))
 Endif
Endif
Return

######################################################################################
## 79965
######################################################################################
Subprog AS_REFDNA1(VALEUR)
Variable Char    VALEUR()
Local Integer K,ER
If VALEUR<>"" : End : Endif
K=4
Gosub TRNODNA
If ER
 #Erreur sur compteur
 GMESSAGE=mess(4,10702,1)-'NUMFIL('+num$(K)+')'
 VALEUR=""
Else
 VALEUR=num$([C]NUMFIL(K))
Endif
End

Subprog AS_REFDNA2(VALEUR)
Variable Char    VALEUR()
Local Integer K,ER
If VALEUR<>"" : End : Endif
K=5
Gosub TRNODNA
If ER
 #Erreur sur compteur
 GMESSAGE=mess(4,10702,1)-'NUMFIL('+num$(K)+')'
 VALEUR=""
Else
 VALEUR=num$([C]NUMFIL(K))
Endif
End

#########################################################################
$TRNODNA
ER=0
Lock NUMFIL
If fstat=0
 NUMFIL= [C]NUMFIL(K)
 [C]NUMFIL(K) += 1
 If fstat :  ER = 2 : Endif
Else
 ER = 1
Endif
Return


