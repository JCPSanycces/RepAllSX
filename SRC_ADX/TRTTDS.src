#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque GENTDS
Local Char PARAM(10)(1..2) , VALEUR(10)
GFLAG="2"
GBIDI1=666
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTTDS","GENTDS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTTDS
#########################################
$ACTION
Case ACTION
 When "INIT"       : Gosub OUVRE
 When "EXEC"       : Gosub EXEC
 When "CONTROLE"   : Gosub CONTROLE
 When "DEBUT"      : Affzo [DIA]: Setmok [DIA] With 0
 When "OK"         : FIN = 1 : GOK = 1
 When "END"        : FIN = 1
 When "SORTIE"     : Gosub SORTIE
Endcase
Return

#########################################
$OUVRE
Local Char VALPAR (10)

Gosub OUVFIC
Local Mask GENTDS [DIA]
Raz [M:DIA]

If val(GFLAG)=2
 [M:DIA]YEA=num$(year(GMOIPAY))
Else
 Call PARAM("","DADYEA",VALPAR) From ADOVAL
 [M:DIA]YEA= VALPAR
Endif

Call LECMEMO("STD","[M:DIA]","dad") From GMEMO
Gosub DECLARATION
Gosub AFFECTATION
Return

#########################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#########################################
$OUVFIC
Gosub OUVFIC From EXTRACTION
If clalev([F:FCS])=0 : Local File FACILITY   [FCS] : Endif
If clalev([F:FCD])=0 : Local File FACILITY   [FCD] : Endif
If clalev([F:FCE])=0 : Local File FACILITY   [FCE] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY  [FCY2] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPS])=0 : Local File BPADDRESS  [BPS] : Endif
If clalev([F:BPD])=0 : Local File BPADDRESS  [BPD] : Endif
If clalev([F:CNT])=0 : Local File CONTACT    [CNT] : Endif
If clalev([F:AIN])=0 : Local File CONTACTCRM [AIN] : Endif
If clalev([F:DAE3])=0 : Local File DADEMP    [DAE3] : Endif
If clalev([F:HRFTD])=0 : Local File HRFILTDS     [HRFTD] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
#Destinataire des comptes rendus d'exploitation
If clalev([F:FCX])=0 : Local File FACILITY   [FCX] : Endif
If clalev([F:CNX])=0 : Local File CONTACT    [CNX] : Endif

#Honoraires
If clalev([F:PRV])=0  : Local File HONPRV     [PRV] : Endif # Prestataires d'honoraires
If clalev([F:HLN])=0  : Local File HONLIN     [HLN] : Endif # lignes d'honoraires
If clalev([F:HLN2])=0  : Local File HONLIN     [HLN2] : Endif # lignes d'honoraires
If clalev([F:DAP3])=0 : Local File DADEMP3   [DAP3] : Endif
If clalev([F:DPP3])=0 : Local File DADEMP32  [DPP3] : Endif
If clalev([F:DMU3])=0 : Local File DADEMP33  [DMU3] : Endif
If clalev([F:DMP3])=0 : Local File DADEMP35  [DMP3] : Endif
If clalev([F:DAQ3])=0 : Local File DADEMP12  [DAQ3] : Endif

If not clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
If not clalev([F:FTM]) : Local File FILTDSMSG [FTM] : Endif
If not clalev([F:FTL]) : Local File FILTDSLIS [FTL] : Endif

# Pour l'AED on va avoir besoin de "parcours" supplémentaires pour chimistrer l'ordre de parcours
If not clalev([F:DAES]) : Local File DADEMP [DAES] : Endif
If not clalev([F:DAEP]) : Local File DADEMP [DAEP] : Endif
Return

#########################################
$DECLARATION
Local Char SYMBOLE (80), NUMSTRUCT(10)
Local Char TIT (100)
Local Char RESULTAT (100)

Local Integer STAT
Local Char    FICCLI(GDIMFIC) , FICHIER(GDIMFIC) , URL(GDIMFIC)

Local Integer I, OK
Local Char OLDEMP (GLONMAT)
Local Integer VIRG, DEC, TMP
Local Char CPL (120)
Local Char SAVIFS(5), SAVIRS(5)
Local Char ZONE (250)
Local Integer IDAS
Local Integer IDAE
Local Integer INAT

#Variables pour les totaux finaux
Local Integer NBLIGNE, NBRUB
Local Integer NBST20

#Divers
Local Decimal MTTTMP
Local Integer ANRATT    :#Année de rattachement
Local Char DECPT (2)    :#Décompte point retraite
Local Char CODFINCTR (2)
Local Integer VGENS44  :#Gestion structure S44 Retraite complèmentaire
Local Integer VGENS45  :#Gestion structure S45 Prévoyance

Local Char FLGRC (10)(0..20)
Local Char LSTCAR (250) :#liste des caractères non autorisés
Local Integer ICAR

Local Integer FLGCTR    :# Contrat en vigueur en fin d'année o/n
Local Integer FLGDRT    :# Contrat de droit privé o/n
Local Char CRITFCY (250)

Local Integer VTYPDEC    :#1=Normale & 2=rectificative (3=BTP Normale & 4=BTP rectificative)

Local Char STAPRO  (2)
Local Char REGBASE (3)(1..5)

Local Char VERSION(15), NATFIL(2), NUMSTRUCT_DEB(30), NUMSTRUCT_FIN(30), NOMVAR(250)
Local Integer OK_STRUCTURE, OK_RESULTAT
Local Integer IAVN, IEXS, IAVT, RANG, IPAC, IRAE
Local Char VOIDMSA(250), VOIDPUBLIC(250), MEMO_RESULTAT(250)

Local Integer VDNA, IDNA
Local Char VSOC(GLONCPY)
Local Integer FLG_S41G55

Local Char TABADR (20) (0..49)
Local Integer NBRADR
Local Char TABCOM (20) (0..49)
Local Integer NBRCOM
Local Char TABIDT (20) (0..49)
Local Integer NBRIDT

Local Char LSTIDT (250) :#liste des caractères non autorisés pour les identités
Local Char LSTADR (250) :#liste des caractères non autorisés pour les adresses
Local Char LSTCOM (250) :#liste des caractères non autorisés pour les communes
Local Char LSTCTY (250) :#liste des caractères non autorisés pour les bureaux distributeurs
Local Char LSTNAI (250) : # Liste des caractères interdits sur commune de naissance ...
Local Char TABCTY (20) (0..49)
Local Integer NBRCTY

Local Date SAVDEB, SAVFIN

Local Integer IDPP
Local Char ANCIENNETE (20)

Local Integer IFCY
Local Integer NBRFCY, MAXFCY
MAXFCY=nbrecord([F:FCY])
Local Char LSTFCY (GLONFCY) (0..MAXFCY)
Local Integer FLGPH (0..MAXFCY)

#Honoraires
Local Decimal AMTTVA
# N4DS - on utilise des tableaux car il faut différencier les types d'avantages et de remboursement
Local Char CODAVT(5), TCODAVT (1)(10)
Local Char CODIND(5), TCODIND (1)(10)
Local Decimal TAMTAVT(10), TAMTIND(10)
Local Integer LASTAVT, LASTIND

# S65 - La structure qui fout la m.....
# => Obligation de gérer un cumul d'info des DAE + Choix de certaines valeurs (collège prud'hommale)

Local Decimal FILREDSMC, FILREDSAL, FILREDAMT
Local Integer PRUCOL, PRUACV, PRUFLG
Local Integer YEAWRK, TRMWRK, MTHWRK, TRMWRKFIR, MTHWRKFIR

Local Integer TPACTYPCOT(dim([F:DAE]PACTYPCOT))
Local Decimal TPACBRTSAL(dim([F:DAE]PACBRTSAL))
Local Decimal TPACPLFSAL(dim([F:DAE]PACPLFSAL))
Local Integer TPACNBRDAY(dim([F:DAE]PACNBRDAY))

Local Integer TRAETYPSTU(dim([F:DAE]RAETYPSTU))
Local Decimal TRAEAMTPS(dim([F:DAE]RAEAMTPS))
Local Decimal TRAEAMTPP(dim([F:DAE]RAEAMTPP))

Local Integer LASTPAC, LASTRAE, OK_SALARIE

Local Char TSTR(20)(1000), TVAL(250)(1000), STR(20), EXPSTR(250), ZONSTR(250), FORSTR(250)
Local Char TGRP(10)(1000), GRP(10)
Local Integer ISTR, NBSTR, POS1, POS2, IRGM, NBGRP

Local Date DATINIAED, DATDEBAED, DATFINAED

#80927
Local Integer NUMORD (0..1)

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#########################################
$AFFECTATION
NBLIGNE=0
NBRUB=0
NBST20=0
OLDEMP=""
LSTCAR=""
For ICAR=0 To 31
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(33)
For ICAR=35 To 37
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(42)
For ICAR=59 To 60
 LSTCAR+=chr$(ICAR)
Next
For ICAR=62 To 63
 LSTCAR+=chr$(ICAR)
Next
For ICAR=91 To 94
 LSTCAR+=chr$(ICAR)
Next
For ICAR=123 To 170
 LSTCAR+=chr$(ICAR)
Next
For ICAR=172 To 175
 LSTCAR+=chr$(ICAR)
Next
For ICAR=177 To 186
 LSTCAR+=chr$(ICAR)
Next
For ICAR=188 To 208
 LSTCAR+=chr$(ICAR)
Next
For ICAR=210 To 223
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(225)
LSTCAR+=chr$(227)
For ICAR=229 To 230
 LSTCAR+=chr$(ICAR)
Next
For ICAR=236 To 237
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(240)
For ICAR=242 To 243
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(245)
For ICAR=247 To 248
 LSTCAR+=chr$(ICAR)
Next
LSTCAR+=chr$(250)
For ICAR=253 To 255
 LSTCAR+=chr$(ICAR)
Next

# Caractère interdit sup pour adresse
LSTADR=LSTCAR+chr$(34)+chr$(38)+chr$(40)+chr$(41)+chr$(43)+chr$(44)+chr$(47)+chr$(58)+chr$(61)+chr$(64)
LSTADR+=chr$(95)+chr$(96)+chr$(171)+chr$(176)+chr$(187)+chr$(209)+chr$(241)

# Caractère interdit sup pour identité (idem adresse sauf chiffres + point)
LSTIDT=LSTADR+chr$(46)
For ICAR=48 To 57
 LSTIDT+=chr$(ICAR)
Next

# Caractère interdit sup pour commune (idem adresse sauf caract accentués + tiret + apostrophe + point)
LSTCOM=LSTADR+chr$(39)+chr$(45)+chr$(46)+chr$(224)+chr$(226)+chr$(238)+chr$(239)+chr$(244)+chr$(249)+chr$(251)+chr$(252)
For ICAR=231 To 235
 LSTCOM+=chr$(ICAR)
Next

#Caractère interdit sup pour bureau distributeur (idem commune sauf chiffre et minuscules)
#Nb : Le 'Toupper' s'occupera des minuscules...
LSTCTY=LSTCOM
For ICAR=48 To 57
 LSTCTY+=chr$(ICAR)
Next

# On ajoute un "LSTNAI", caractères autorisés sur la commune de naissance (S30.G01.00.010 )
# C'est la même chose que les communes mais la, par je ne sais quel délire d'énarque, on a le droit d'utiliser l'apostrophe ^^
LSTNAI=LSTADR+chr$(45)+chr$(46)+chr$(224)+chr$(226)+chr$(238)+chr$(239)+chr$(244)+chr$(249)+chr$(251)+chr$(252)
For ICAR=231 To 235
 LSTNAI+=chr$(ICAR)
Next
Return

#########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 GOK=1
 VDNA=val(GFLAG)
 Gosub FILTFCY
 Gosub COMPTEUR
 If GOK=0 : FIN=1 : Return : Endif
 TMP = 1
 TRA = 1
Endif
Return

########################################
$FILTFCY
CRITFCY="1=1"
If [M:DIA]FCY<>""
 CRITFCY -= '& FCY="'+[M:DIA]FCY+'"'
Endif
Return

########################################
$COMPTEUR
Local Integer STAT
Local Char   COMPTEUR(GLONANM)
Local Date DATREF

If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif

Filter [FGR] Where evalue (CRITFCY) & CPY=[M:DIA]CPY
Read [FGR]FGR0 First
Filter [FGR]
If !fstat
 DATREF=[M:DIA]REFSTR
  Call LECTURE("CPY",[F:FGR]CPY,"") From CONTOBJ
  GSOCIETE=[F:CPY]CPY
  If GNBLEG = 1
    GCURLEG = GDOSLEG
  Else
    If dim([F:CPY]LEG)>0
      GCURLEG =[F:CPY]LEG
    Endif
  Endif
  Call LECTCA(15,STAT) From SUBTCA
  If !STAT
    GMESSAGE = mess(12,114,1) : # Compteur inexistant
    GERR=1 : GOK=0 : Return
  Else
    COMPTEUR= [F:TCA]CODNUM(2)
  Endif
 Call NUMERO(COMPTEUR,[F:FGR]FCY,DATREF,"",[M:DIA]REFSND,STAT) From SUBANM
 If STAT
  GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
  GERR=1 : GOK=0 : Return
 Endif
Else
 GMESSAGE = mess(4,10707,1)-"FACGROUP" : # Erreur de lecture sur le fichier
 GERR=1 : GOK=0 : Return
Endif
Return

#########################################
$EXEC
#N4DS
TIT=mess(1,10707,1)-func AFNC.INTCLE("ADI","368~"+[M:DIA]NATFIL)-":"-[M:DIA]REFSND : #Génération du fichier TDS
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70," "),0) From GESECRAN
Call ECR_TRACE(mess(2,45,1)-[M:DIA]CPY-[M:DIA]FCY,0) From GESECRAN
SYMBOLE = [M:DIA]FILNAM
Lock =SYMBOLE
#Opération en cours sur un autre poste
If fstat : GMESSAGE=mess(30,100,1): GERR=1 : Return : Endif

# Filtre Dads-u/Dna
# Filter [F:HRFTD] Where YEA=[M:DIA]YEA & (NATREC=VDNA or NATREC=3)

# Compte tenu des modifs N4DS , on prends tous les enregistrements, l'exclusion sera faite par message dans FILTDSMSG

#78190
#Filter [F:HRFTD] Where YEA=[M:DIA]YEA
#Read [F:HRFTD]FTD0 First

Filter [F:HRFTD] Where YEA<=[M:DIA]YEA
Read [F:HRFTD]FTD0 Last
[L]VERSION = [F:HRFTD]VER
[L]NATFIL =  [M:DIA]NATFIL

# On positionne [L]VERSION et [L]NATFIL pour filtrer FILTDSMSG ; à terme on devrait plutot faire choisir la version dans l'écran
# plutot que l'année

# On se permet de lancer la génération => Fonction en mode mono avec un lock symbole donc on est seul dessus
# Call GENTRT_N4DSVAR(nomap, [M:DIA]YEA, [L]VERSION) From N4DSLIB
# Gosub DECLARE From WN4DSVAR

# On reprends tout à 0 : longueur de variable limité à 12 en V5
Raz [L]TSTR, [L]TVAL, [L]NBSTR
Raz [L]TGRP, [L]NBGRP

#78190
#For [F:HRFTD]FTD0
For [F:HRFTD]FTD0 Where VER=[L]VERSION
    [L]TSTR([L]NBSTR) = [F:HRFTD]NUMREC
    [L]NBSTR += 1

    [L]GRP = mid$([F:HRFTD]NUMREC, 1, 10)
    [L]RANG = find([L]GRP, [L]TGRP)
    [L]RANG -= 1
    If [L]RANG < 0
        [L]TGRP([L]NBGRP) = [L]GRP
        [L]NBGRP += 1
    Endif
Next

If [M]TYPFIL <>"55"

    # Si AED alors le parcours est totalement différent
    # => Un bloc S10
    # => Un ensemble "par salarié" (et contrat pour nous) - notre boucle principale qu'on répète autant de fois que de salariés à déclarer
    #    - 1 bloc S20
    #    - 1 bloc S30
    #    - n S40 pour les périodes "avant" la rupture
    #    - 1 S40 pour la période de rupture
    #    - 1 S48.G55 pour cette période
    #    - n S80
    # => Un bloc S90 pour clore le tout

    If VDNA <> 2
        Gosub TR1
    Else
        Gosub TR_AED
    Endif
Else
 Gosub TRNEANT
Endif
Filter [F:HRFTD]
Call FERME_TRACE From LECFIC
Unlock =SYMBOLE
Return

#########################################
# Parcours pour la DADS-U
#########################################
$TR1
OK=0 : VGENS44=0 : VGENS45=0 : IFCY=0 : VSOC=""
Gosub OUVRE_FICHIER
If OK<>1
    If [M]NATFIL<>"04"
        If [M]TYPFIL="53" : VTYPDEC=2 : Else : VTYPDEC=1 : Endif
    Else
        If [M]TYPFIL="53" : VTYPDEC=4 : Else : VTYPDEC=3 : Endif
    Endif

    #------------------
    # Niveau "SOCIETE"
    #------------------
    Gosub LIGNE_S10

    For [FGR]FGR0 Where CPY=[M:DIA]CPY & evalue (CRITFCY)

        #-------------------------
        # Niveau "SITE" DECLARANT
        #-------------------------

        Read[F:FCY]FCY0 = [F:FGR]FCY
        If !fstat
            Read[F:CPY]CPY0 = [F:FCY]LEGCPY
            If !fstat & VSOC<>[F:CPY]CPY
                VSOC=[F:CPY]CPY

                #Recherche infos DADS du site  pour INTMT en S20
                Read [DFC]DFC0=[F:FCY]FCY;[M:DIA]YEA;[M:DIA]REFSTR;[M:DIA]REFEND;VDNA
                If fstat : Raz [DFC] : Endif

                Gosub LIGNE_S20
                #N4DS : Tous les sites doivent désormais être déclarer  (Dads-u ou pas !)
                For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & evalue (CRITFCY) #& DADFLG=2
                   Call ECR_TRACE(string$(70," "),0) From GESECRAN
                   #Site : XXX
                   Call ECR_TRACE(mess(3,45,1)-":"-[F:FCY]FCY,0) From GESECRAN

                   #79048 : Ajout filtre site coché 'Paye' !
                   If [F:FCY]PAYFLG<>2
                    Call ECR_TRACE([F:FCY]FCY-":"-mess(2,10704,1),-1) From GESECRAN   #n'est pas un site de paie
                   Else
                    [L]FLGPH([L]IFCY) = 0
                    If [M]NATFIL<>"12"
                        For [ID]ID0
                            #------------------
                            # Niveau "SALARIE"
                            #------------------
                            Gosub RAZ_SALARIE
                            [L]OK_SALARIE = 0
                            # Index DAE1 pour être en ordre chrono
                            #N4DS : Tous les sites doivent désormais être déclarer (Dads-u ou pas !)
#                            For [DAE]DAE1 Where YEAEMPDDS=[M:DIA]YEA & DADFCY=[F:FCY]FCY & FLG<>2 & ETRDAT>=[M:DIA]REFSTR & XITDAT<=[M:DIA]REFEND
                            For [DAE]DAE1 Where YEAEMPDDS=[M:DIA]YEA & ETRFCY=[F:FCY]FCY & FLG<>2 & ETRDAT>=[M:DIA]REFSTR & XITDAT<=[M:DIA]REFEND
&                                    & EMPDDS=[ID]REFNUM & TYPDAE=VTYPDEC & FLGDNA=VDNA

                                [L]OK_SALARIE = 1    : # On a trouvé une période d'activité pour notre salarié.

                                [L]FLGPH([L]IFCY) += 1  :#79227

                                # Lecture de la période "DNA" associée
                                Read[DNA]DNA0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
                                If fstat <> 0 : Raz [F:DNA] : Endif    :  # GRAVE

                                # Lecture DNF - On lit le premier car c'est le seul "servi" - Analyse structure à revoir ?
                                Read [F:DNF]DNF0 = [F:DNA]YEAEMPDDS;[F:DNA]EMPDDS;[F:DNA]CTRNUM;[F:DNA]ETRDAT;[F:DNA]TYPDAE;[F:DNA]FLGDNA;1
                                If fstat <> 0 : Raz [F:DNF] : Endif    :  # GRAVE

                                If [L]OLDEMP <> [F:DAE]EMPDDS
                                    Gosub LIGNE_S30
                                    [L]OLDEMP = [F:DAE]EMPDDS
                                Endif

                                #-------------------------
                                # NIVEAU PERIODE ACTIVITE
                                #-------------------------

                                #-----------------------------------------------
                                # Cumuls d'infos pour préparer la structure S65
                                #-----------------------------------------------
                                Gosub CUMUL_SALARIE
                                Gosub LIGNE_S40
                                # Gosub LIGNE_S42        : # Non traité - Secteur public
                                # Gosub LIGNE_S43        : # Non traité - Secteur public
                                Gosub LIGNE_S44
                                Gosub LIGNE_S45
                                # Gosub LIGNE_S47        : # Non traité - Secteur public
                                Gosub LIGNE_S48
                                # Gosub LIGNE_S49        : # Non traité - Secteur public (SNCF ?)
                                # Gosub LIGNE_S53        : # Non traité - MSA
                                # Gosub LIGNE_S54        : # Non traité - Secteur public
                                Gosub LIGNE_S56          : # BTP

                                # ANCIENNE VERSION - VOIR USAGE des VGENS44 si toujours utile ou non
                                # Case [M]NATFIL
                                #    When "01","03" :
                                #        VGENS44=1 : Gosub LIGNE_S44
                                #        VGENS45=1 : Gosub LIGNE_S45
                                #    When "04":
                                #        Gosub LIGNE_S66
                                #    When "07" :
                                #        VGENS44=1 : Gosub LIGNE_S44
                                #    When "08" :
                                #        VGENS45=1 : Gosub LIGNE_S45
                                # Endcase

                            Next

                            # => Retour niveau salarié

                            #-----------------------------
                            # S60 - Périodes d'inactivité
                            #-----------------------------
                            #N4DS : Tous les sites doivent désormais être déclarer (Dads-u ou pas !)
#                            For [DAE]DAE1 Where YEAEMPDDS=[M:DIA]YEA & DADFCY=[F:FCY]FCY & FLG<>2 & ETRDAT>=[M:DIA]REFSTR & XITDAT<=[M:DIA]REFEND
                            For [DAE]DAE1 Where YEAEMPDDS=[M:DIA]YEA & ETRFCY=[F:FCY]FCY & FLG<>2 & ETRDAT>=[M:DIA]REFSTR & XITDAT<=[M:DIA]REFEND
&                                & EMPDDS=[ID]REFNUM & TYPDAE=VTYPDEC & FLGDNA=VDNA

                                For [DAC]DAC0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA
&                                & (ETRDAT>=[F:DAE]ETRDAT | (ETRDAT>=addmonth([F:DAE]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[F:DAE]XITDAT
&                                & XITDAT<=[F:DAE]XITDAT
                                    Gosub LIGNE_S60
                                Next
                                If [M:DIA]FLGSND=2 :#Si c'est une déclaration réelle
                                    Gosub MAJ_DAE
                                Endif
                            Next
                            #-----------------------------
                            # S65 - CUMUL NIVEAU SALARIE
                            #-----------------------------
                            If [L]OK_SALARIE = 1
                                Gosub LIGNE_S65
                            Endif
                        Next
                        If OLDEMP="" :#pas de salarié à déclarer
                            Call ECR_TRACE(mess(8,10707,1),0) From GESECRAN
                        Endif
                    Endif
                   [L]IFCY += 1
                  Endif
                Next FCY

                #N4DS : Tous les sites doivent désormais être déclarer (Dads-u ou pas !)
                For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY  & evalue (CRITFCY) #& DADFLG=2

                   #79048 : Ajout filtre site coché 'Paye' !
                   If[F:FCY]PAYFLG=2
                    If find([M]NATFIL, "01", "02", "12")
                        Gosub LIGNE_S70
                    Endif
                   Endif

                Next FCY

                IFCY=0
                #N4DS : Tous les sites doivent désormais être déclarer en (Dads-u ou pas !)
                For [FCY2]FCY0 Where LEGCPY=[F:CPY]CPY  & evalue (CRITFCY) #& DADFLG=2

                 #79048 : Ajout filtre site coché 'Paye' !
                 If [F:FCY2]PAYFLG=2
                   Gosub LIGNE_S80
                  [L]IFCY+=1
                 Endif

                Next FCY

            Endif
        Endif
    Next FGR
    Gosub LIGNE_S90
    Gosub FERME_FICHIER
Endif

Return

#########################################
# Parcours pour l'AED
#########################################
$TR_AED
OK=0 : VGENS44=0 : VGENS45=0 : IFCY=0 : VSOC=""
Gosub OUVRE_FICHIER
If OK<>1
    If [M]NATFIL<>"04"
        If [M]TYPFIL="53" : VTYPDEC=2 : Else : VTYPDEC=1 : Endif
    Else
        If [M]TYPFIL="53" : VTYPDEC=4 : Else : VTYPDEC=3 : Endif
    Endif
    #------------------
    # Niveau "SOCIETE"
    #------------------
    Gosub LIGNE_S10
    For [FGR]FGR0 Where CPY=[M:DIA]CPY & evalue (CRITFCY)
        #-------------------------
        # Niveau "SITE" DECLARANT
        #-------------------------
        Read[F:FCY]FCY0 = [F:FGR]FCY
        If !fstat
            Read[F:CPY]CPY0 = [F:FCY]LEGCPY
            If !fstat & VSOC<>[F:CPY]CPY
                VSOC=[F:CPY]CPY

                # Recherche infos DADS du site => Inutile en AED on a tout remappé
                # sur les valeurs du site directement via le paramétrage des messages

                # Pour l'AED, on ne le fait pas ici ^^
                # Gosub LIGNE_S20


                For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & evalue (CRITFCY) #& DADFLG=2
                  Call ECR_TRACE(string$(70," "),0) From GESECRAN
                  #Site : XXX
                  Call ECR_TRACE(mess(3,45,1)-":"-[F:FCY]FCY,0) From GESECRAN

                  #79048 : Ajout filtre site coché 'Paye' !
                  If [F:FCY]PAYFLG<>2
                   Call ECR_TRACE([F:FCY]FCY-":"-mess(2,10704,1),-1) From GESECRAN   #n'est pas un site de paie
                  Else
                    [L]FLGPH([L]IFCY) = 0
                    If [M]NATFIL<>"12"
                        For [ID]ID0
                            #------------------
                            # Niveau "SALARIE"
                            #------------------
                            Gosub RAZ_SALARIE
                            [L]OK_SALARIE = 0

                            # Hypothèse de travail : on cherche un enregistrement DADEMP pour lequel on a des S48
                            #   on détermine donc des dates de début et de fin de fiche à prendre en compte : ces fiches vont "ensemble"
                            #   elles délimitent une période d'activité cloturée par un départ définitif.

                            [L]DATINIAED = [M:DIA]REFSTR

                            # DAES : Curseur sur DAE pour balayage "salarié"
                            # DAEP : Curseur sur DAE pour balayage "période"
                            # => dans les deux cas on lira [DAE] pour réutiliser le paramétrage des structures N4DS

                            # NB : on ne prends que les déclarations non validées (FLG <>2) ce qui peut poser problème pour renvoyer une AED car le fichier a merdé ...
                            #      il faudra apprendre aux gens à décocher l'AED pour la renvoyer ce qui risque de poser problème chez bcp de client dont la coordination
                            #      spatiale est défayante ....

                            # Par cohérence on prends les données DADEMP groupées par contrat plutot que par chrono date histoire de déclarer "ensemble" les données d'un contrat
                            # N4DS : Tous les sites doivent désormais être déclarer (Dads-u ou pas !)
                            For [DAES]DAE0 Where YEAEMPDDS=[M:DIA]YEA & ETRFCY=[F:FCY]FCY & XITDAT>=[L]DATINIAED & XITDAT<=[M:DIA]REFEND
&                               & EMPDDS=[F:ID]REFNUM & TYPDAE=VTYPDEC & FLGDNA=VDNA & FLG<>2 & FLGAED = 2

                                # Ok, on est sur une AED non déclarée
                                # On va chercher tous les enregistrements DADEMP qui vont avec cette AED => tous ceux qui sont "avant" jusqu'à trouver une autre AED

                                # Période générale de l'AED, on démarre avec la seule période qu'on connait, celle "déclarative" (S48)

                                [L]DATDEBAED = [F:DAES]ETRDAT : [L]DATFINAED = [F:DAES]XITDAT


                                Filter [F:DAEP] Where YEAEMPDDS=[F:DAES]YEAEMPDDS & EMPDDS=[F:DAES]EMPDDS & CTRNUM=[F:DAES]CTRNUM
&                                   & ETRDAT<[L]DATDEBAED & TYPDAE=[F:DAES]TYPDAE & FLGDNA=[F:DAES]FLGDNA & FLG<>2
&                                   Order By Key PERDESC = [F:DAEP]ETRDAT Desc

                                For [F:DAEP]PERDESC
                                    If [F:DAEP]FLGAED = 2
                                        # Ah, AED précédente, on sort ...
                                        Break
                                    Else
                                        [L]DATDEBAED = [F:DAEP]ETRDAT
                                    Endif
                                Next

                                Filter [F:DAEP]

                                # On va générer notre S20 et notre S30
                                # On positionne donc DAE sur le DAES qu'on traite pour avoir les infos de la "dernière" période dans la structure S30 tel que demandé dans le CDC.

                                Read [F:DAE]DAE0 = [F:DAES]YEAEMPDDS ; [F:DAES]EMPDDS ; [F:DAES]CTRNUM ; [F:DAES]ETRDAT ; [F:DAES]TYPDAE ; [F:DAES]FLGDNA

                                #80927
                                Gosub AED_NUMORD
                                Gosub LIGNE_S20
                                Gosub LIGNE_S30

                                [L]OK_SALARIE = 1    : # On a trouvé une période d'activité pour notre salarié.

                                # Ok, maintenant on va balayer les DAE(P) dans l'ordre chrono normal compris entre le début et la fin de période déclarée
                                # On se permet de tester ETRDAT < DATFINAED car normalement on ne peut pas avoir sur un contrat de période "recouvrantes"


                                For [F:DAEP]DAE0 Where YEAEMPDDS=[F:DAES]YEAEMPDDS & EMPDDS=[F:DAES]EMPDDS & CTRNUM=[F:DAES]CTRNUM
&                               & ETRDAT>=[L]DATDEBAED & ETRDAT<=[L]DATFINAED & TYPDAE=[F:DAES]TYPDAE & FLGDNA=[F:DAES]FLGDNA & FLG<>2

                                    # On positionne DAE sur notre fiche pour que tous les paramétrages fonctionnent
                                    Read [F:DAE]DAE0 = [F:DAEP]YEAEMPDDS ; [F:DAEP]EMPDDS ; [F:DAEP]CTRNUM ; [F:DAEP]ETRDAT ; [F:DAEP]TYPDAE ; [F:DAEP]FLGDNA

                                    # Lecture de la période "DNA" associée
                                    Read[DNA]DNA0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
                                    If fstat <> 0 : Raz [F:DNA] : Endif    :  # GRAVE

                                    # Lecture DNF - On lit le premier car c'est le seul "servi" - Analyse structure à revoir ?
                                    Read [F:DNF]DNF0 = [F:DNA]YEAEMPDDS;[F:DNA]EMPDDS;[F:DNA]CTRNUM;[F:DNA]ETRDAT;[F:DNA]TYPDAE;[F:DNA]FLGDNA;1
                                    If fstat <> 0 : Raz [F:DNF] : Endif    :  # GRAVE


                                    #-------------------------
                                    # NIVEAU PERIODE ACTIVITE
                                    #-------------------------
                                    If !find ([F:DAE]ETRFCY, LSTFCY(0..NBRFCY))
                                      LSTFCY(NBRFCY) = [F:DAE]ETRFCY
                                      NBRFCY+=1
                                    Endif

                                    Gosub LIGNE_S40

                                    # S42,S43,S44,S45,S47,S49,S53,S54,S56  - Non utilisés sur AED

                                    Gosub LIGNE_S48
                                Next

                                # => Retour niveau salarié

                                #-----------------------------
                                # S60 - Périodes d'inactivité => On prends les périodes pour les DAE utilisées pour notre bloc AED
                                #-----------------------------

                                For [F:DAEP]DAE0 Where YEAEMPDDS=[F:DAES]YEAEMPDDS & EMPDDS=[F:DAES]EMPDDS & CTRNUM=[F:DAES]CTRNUM
&                               & ETRDAT>=[L]DATDEBAED & ETRDAT<=[L]DATFINAED & TYPDAE=[F:DAES]TYPDAE & FLGDNA=[F:DAES]FLGDNA & FLG<>2

                                    # Toujours remettre la DAE associée en ligne

                                    Read [F:DAE]DAE0 = [F:DAEP]YEAEMPDDS ; [F:DAEP]EMPDDS ; [F:DAEP]CTRNUM ; [F:DAEP]ETRDAT ; [F:DAEP]TYPDAE ; [F:DAEP]FLGDNA


                                    For [DAC]DAC0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA
&                                    & (ETRDAT>=[F:DAE]ETRDAT | (ETRDAT>=addmonth([F:DAE]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[F:DAE]XITDAT
&                                    & XITDAT<=[F:DAE]XITDAT
                                        Gosub LIGNE_S60
                                    Next

                                    If [M:DIA]FLGSND=2 :#Si c'est une déclaration réelle
                                        Gosub MAJ_DAE
                                    Endif

                                Next

                                # Fin d'un bloc de DADEMP pour une AED - on génére une S80

                                For I=0 To NBRFCY-1
                                  Read[F:FCY2]FCY0=[L]LSTFCY(I)
                                  If !fstat
                                   #79048 : Ajout filtre site coché 'Paye' !
                                   If [FCY2]PAYFLG=2
                                     Gosub LIGNE_S80
                                   Endif
                                  Endif
                                Next

                                [L]DATINIAED = [L]DATFINAED + 1

                            Next

                            # S65 - Non utilisé sur AED

                        Next

                    Endif
                  [L]IFCY += 1
                 Endif
                Next FCY

                # S70 - Non utilisé sur AED

            Endif

        Endif

    Next FGR
    Gosub LIGNE_S90
    Gosub FERME_FICHIER
Endif
Return

#########################################
# RAZ de variable niveau "salarié"
#########################################
$RAZ_SALARIE
NBRFCY=0 : Raz LSTFCY
Raz [L]FILREDSMC, [L]FILREDSAL, [L]FILREDAMT
Raz [L]PRUCOL, [L]PRUACV
Raz [L]YEAWRK, [L]TRMWRK, [L]MTHWRK, [L]TRMWRKFIR, [L]MTHWRKFIR
Raz [L]TPACTYPCOT, [L]TPACBRTSAL, [L]TPACPLFSAL, [L]TPACNBRDAY
Raz [L]TRAETYPSTU, [L]TRAEAMTPS, [L]TRAEAMTPP
Raz [L]LASTPAC, [L]LASTRAE
Return

#########################################
# Cumuls d'infos pour préparer la structure S65
#########################################
$CUMUL_SALARIE
# Infos "cumulées" - le cas le plus simple
[L]FILREDSMC += [F:DAE]FILREDSMC            : # Douteux quand mm, on fait la somme de smic ,
                                              # est ce qu'il ne faudrait pas faire plutot une "moyenne",
                                              # on ne sait pas s'il faut déclarer un total en fait
[L]FILREDSAL += [F:DAE]FILREDSAL
[L]FILREDAMT += [F:DAE]FILREDAMT

For [L]IPAC = 0 To dim([F:DAE]PACTYPCOT) - 1
    If [F:DAE]PACTYPCOT([L]IPAC) <> 0
        [L]RANG = find([F:DAE]PACTYPCOT([L]IPAC), [L]TPACTYPCOT)
        [L]RANG -= 1
        If [L]RANG < 0
            [L]RANG = [L]LASTPAC
            [L]TPACTYPCOT([L]RANG) = [F:DAE]PACTYPCOT([L]IPAC)
            [L]LASTPAC += 1
        Endif
        [L]TPACBRTSAL([L]RANG) += [F:DAE]PACBRTSAL([L]IPAC)
        [L]TPACPLFSAL([L]RANG) += [F:DAE]PACPLFSAL([L]IPAC)
        [L]TPACNBRDAY([L]RANG) += [F:DAE]PACNBRDAY([L]IPAC)
    Endif
Next

For [L]IRAE = 0 To dim([F:DAE]RAETYPSTU) - 1
    If [F:DAE]RAETYPSTU([L]IRAE) <> 0
        [L]RANG = find([F:DAE]RAETYPSTU([L]IRAE), [L]TRAETYPSTU)
        [L]RANG -= 1
        If [L]RANG < 0
            [L]RANG = [L]LASTRAE
            [L]TRAETYPSTU([L]RANG) = [F:DAE]RAETYPSTU([L]IRAE)
            [L]LASTRAE += 1
        Endif
        [L]TRAEAMTPS([L]RANG) += [F:DAE]RAEAMTPS
        [L]TRAEAMTPP([L]RANG) += [F:DAE]RAEAMTPP
    Endif
Next

# Infos "annule et remplace", c'est la dernière lue qui sera envoyée
[L]PRUCOL = [F:DAE]PRUCOL    : # Le dernier
[L]PRUACV = [F:DAE]PRUACV
[L]PRUFLG = [F:DAE]PRUFLG

# Idem "annule et remplace" mais j'ai un gros doute sur la validité en fait
[L]YEAWRK = [F:DAE]YEAWRK
[L]TRMWRK = [F:DAE]TRMWRK
[L]MTHWRK = [F:DAE]MTHWRK
[L]TRMWRKFIR = [F:DAE]TRMWRKFIR
[L]MTHWRKFIR = [F:DAE]MTHWRKFIR
Return

########################################
$MAJ_DAE
Trbegin [DAE3],[DAP3],[DPP3],[DAQ3],[DMU3],[DMP3]
If VGENS45=1 : Gosub MAJ_DAP : Endif
If GOK
 Readlock [F:DAE3]DAE0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
 If !fstat
  [F:DAE3]FLG=2 :#Salarié déclaré
  Rewrite [F:DAE3]
  If fstat<>0
   GOK = 0 : Call FSTA("DAE3") From GLOCK
  Endif
  If GOK=0 : Rollback : Endif
 Endif
Endif
Commit
Return

########################################
$MAJ_DAP
For [DAP3]DAP0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
 [F:DAP3]FLG=2 :#Salarié déclaré
 Rewrite [F:DAP3]
 If fstat<>0
  GOK = 0 : Call FSTA("DAP3") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
For [DPP3]DPP0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
 [F:DPP3]FLG=2 :#Salarié déclaré
 Rewrite [F:DPP3]
 If fstat<>0
  GOK = 0 : Call FSTA("DPP3") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
For [DMU3]DMU0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
 [F:DMU3]FLG=2 :#Salarié déclaré
 Rewrite [F:DMU3]
 If fstat<>0
  GOK = 0 : Call FSTA("DMU3") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
For [DMP3]DMP0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
 [F:DMP3]FLG=2 :#Salarié déclaré
 Rewrite [F:DMP3]
 If fstat<>0
  GOK = 0 : Call FSTA("DMP3") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
For [DAQ3]DAQ0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
 [F:DAQ3]FLG=2 :#Salarié déclaré
 Rewrite [F:DAQ3]
 If fstat<>0
  GOK = 0 : Call FSTA("DAQ3") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
Return

#########################################
$TRNEANT
OK=0
Gosub OUVRE_FICHIER
If OK<>1
 Read[CPY]CPY0=[M:DIA]CPY
 If fstat=0
  Gosub LIGNE_S10
  Gosub LIGNE_S20
  #N4DS : Tous les sites doivent désormais être déclarer  (Dads-u ou pas !)
  For [FCY2]FCY0 Where evalue (CRITFCY) & LEGCPY=[F:CPY]CPY #& DADFLG=2
   #79048 : Ajout filtre site coché 'Paye' !
   If [F:FCY2]PAYFLG=2
    [L]FLGPH([L]IFCY) = 0
     Gosub LIGNE_S80
     IFCY+=1
   Endif
  Next
 Endif
 Gosub LIGNE_S90
 Gosub FERME_FICHIER
Endif
Return

#########################################
$EXTENSION
Local Char EXTFIC(3)
If val(GFLAG)=2
 EXTFIC="dna"
Else
 EXTFIC="tds"
Endif
Return

#########################################
$OUVRE_FICHIER
Gosub EXTENSION

FICHIER=[M:DIA]FILNAM
If [M:DIA]TYPEXP=2
 FICHIER = filpath(GDIRBQE,[M:DIA]FILNAM,EXTFIC,0)
Else
 FICCLI=FICHIER
 Call SET_FICNAM(FICCLI,FICHIER,URL) From ORDSYS
Endif

Openo FICHIER,0 Using [FIC]
#Séparateur de champs
SAVIFS = adxifs
adxifs = ","
#Caractère de fin de ligne
SAVIRS = adxirs
adxirs = chr$(13)+chr$(10)
Return

#########################################
$LIGNE_S10
Read [F:TD0]TD00=2;[F:CPY]CPY;[M]NATFIL;VDNA
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"PRMTDS0 [TD0] :"-[F:CPY]CPY,1) From GESECRAN
Endif
# Recherche site emmeteur
Read [F:FCY]FCY0=[F:TD0]FCY
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"FACILITY [FCY] :"-[F:TD0]FCY,1) From GESECRAN
Endif
#Recherche adresse emetteur
Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPA] :"-[F:FCY]FCY,1) From GESECRAN
Endif
#Recherche contact TDS du site emetteur
If [F:FCY]CNTDDS<>""
 Read [CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTDDS
 If fstat<>0
  Call ECR_TRACE(mess(4,10707,1)-"CONTACT [CNT] :"-[F:FCY]CNTDDS,1) From GESECRAN
 Else
  Read [AIN]AIN0=[F:FCY]CNTDDS
  If fstat<>0
   Call ECR_TRACE(mess(4,10707,1)-"CONTACTCRM [AIN] :"-[F:FCY]CNTDDS,1) From GESECRAN
  Endif
 Endif
Endif
Gosub DESTCRE
NUMSTRUCT="S10."
Gosub ECRIRE
Return

#########################################
$DESTCRE
# Recherche site destinataire CRE
Read [F:FCX]FCY0=[F:TD0]FCYDEN
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"FACILITY [FCX] :"-[F:TD0]FCYDEN,1) From GESECRAN
Endif
If [F:FCX]CNTDDS<>""
 Read [CNX]CNT0=3;[F:FCX]FCY;[F:FCX]CNTDDS
 If fstat<>0
  Call ECR_TRACE(mess(4,10707,1)-"CONTACT [CNX] :"-[F:FCX]CNTDDS,1) From GESECRAN
 Endif
Else
 Raz [F:FCX] : Raz [F:CNX]
Endif
Return


#########################################
#80927 : Incrementation des n° de ref dnas chaque S20 pour l'AED
$AED_NUMORD
If [L]NUMORD(0)=0
 [L]NUMORD(0)=val([M:DIA]REFDNA1)
Else
 K=4
 Gosub TRNODNA
 If ER
  #Erreur sur compteur
  Call ECR_TRACE(mess(4,10702,1)-'NUMFIL('+num$(K)+')',1) From GESECRAN
 Else
   [L]NUMORD(0)=[C]NUMFIL(K)
 Endif
Endif
If ([M:DIA]TYPFIL="59" | [M:DIA]TYPFIL="60")
 If [L]NUMORD(1)=0
  [L]NUMORD(1)=val([M:DIA]REFDNA2)
 Else
  K=5
  Gosub TRNODNA
  If ER
   #Erreur sur compteur
   Call ECR_TRACE(mess(4,10702,1)-'NUMFIL('+num$(K)+')',1) From GESECRAN
  Else
    [L]NUMORD(1)=[C]NUMFIL(K)
  Endif
 Endif
Endif
Return

#########################################
$LIGNE_S20
# Recherche du site siège de la société courante
SIEGE = "" : DECLA = ""
Filter [F:FCS] Where LEGCPY=[F:CPY]CPY
For [F:FCS]FCY0
    If [F:FCY]BPASGE<>""
        SIEGE = [F:FCY]BPASGE : Break
    Endif
Next
Filter [F:FCS]
If SIEGE <> ""
    # Recherche adresse du siege
    Read [F:BPS]BPA0 = 3;[F:FCS]FCY;SIEGE
    If fstat<> 0
        Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPS]",1) From GESECRAN
    Endif
Else
    Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPS]",1) From GESECRAN
Endif
# Recherche du site déclarant de la société courante
Filter [F:FCD] Where LEGCPY=[F:CPY]CPY
For [F:FCD]FCY0
    If [F:FCD]BPADCL<>""
        DECLA=[F:FCD]BPADCL : Break
    Endif
Next
Filter [F:FCD]
If [L]DECLA<>""
    # Recherche adresse du déclarant
    Read [BPD]BPA0=3;[F:FCD]FCY;DECLA
    If fstat<> 0
        Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPD]",1) From GESECRAN
    Endif
Else
    Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPD]",1) From GESECRAN
Endif

Gosub DESTCRE
NUMSTRUCT="S20."

# N4DS - Géré par les conditions sur rubrique
# Si le siège = le déclarant, on ne met pas les infos du déclarant
# If [F:FCS]FCY=[F:FCD]FCY : Raz[F:FCD] : Raz [F:BPD] : Endif

# Si dads-u en décalage de paie -> période de ref doit = année civile !
If VDNA<>2 & val(func AFNC.PARAM("DMA",[F:FCS]FCY))<>12
    # Sauvegarde
    SAVDEB=[M:DIA]REFSTR
    SAVFIN=[M:DIA]REFEND
    [M:DIA]REFSTR=gdat$(01,01,val([M:DIA]YEA))
    [M:DIA]REFEND=gdat$(31,12,val([M:DIA]YEA))
    Gosub ECRIRE
    NBST20+=1
    # Remise en état initial
    [M:DIA]REFSTR=SAVDEB
    [M:DIA]REFEND=SAVFIN
Else
    Gosub ECRIRE
    NBST20+=1
Endif
Return

#########################################
$LIGNE_S30
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Salarié : "-[F:DAE]EMPDDS-"("+[F:DAE]ETRFCY+")",0) From GESECRAN
NUMSTRUCT="S30."
Gosub ECRIRE
Return

#########################################
$LIGNE_S40
Local Char DATE1 (10),DATE2 (10)
#N4DS AED
Local Date DATEDEB
DATEDEB=[F:DAE]ETRDAT
If VDNA=2
 If [F:DAE]XITDAT-[F:DAE]ETRDAT>32 : DATEDEB=gdat$(01,month([F:DAE]XITDAT),year([F:DAE]XITDAT)) : Endif
Endif

DATE1=num$(gdat$([L]DATEDEB))
DATE2=num$(gdat$([F:DAE]XITDAT))
Call ECR_TRACE("Période d'activité du"-DATE1-"au"-DATE2,0) From GESECRAN
NUMSTRUCT="S40."
#Recherche du site d'affectation
Read [F:FCE]FCY0=[F:DAE]ETRFCY
If fstat<> 0
 Call ECR_TRACE(mess(4,10707,1)-"FACILITY [FCE]",1) From GESECRAN
Endif
#Recherche Taux d'AT
#80108
If [F:DAE]RSKWRK<>""
 Read [WAC]WAC0=[F:DAE]RSKWRK
 If fstat<> 0
  Call ECR_TRACE(mess(4,10707,1)-"TRVACC [WAC]",1) From GESECRAN
 Else
  Filter [WAR] Where CODWAC=[F:DAE]RSKWRK & DATWAC<=[F:DAE]XITDAT
  Read [F:WAR]WAR0 Last
  Filter [WAR]
  If fstat<> 0
   Call ECR_TRACE(mess(4,10707,1)-"TRVACCRAT [WAR]",1) From GESECRAN
  Endif
 Endif
Endif
GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

# La structure S40 est mal fichue, elle "contient" des S40, S42, voire S54

For [L]NUMSTRUCT = "S40.", "S42.", "S43.", "S44.", "S45.", "S47.", "S48.", "S49.", "S53.", "S54."
    # Gosub RAZ_STRUCTURE From WN4DSVAR
    For [L]ISTR = 0 To [L]NBSTR - 1
        If mid$([L]TSTR([L]ISTR), 1, 4) = [L]NUMSTRUCT
            [L]TVAL([L]ISTR) = ""
        Endif
    Next
Next

#------------------------------------------------------------------------------------------------------------------
# Version 1 : Les structures sont appelées "via" le programme
#             => Fonctionnement de TRTTDS "original", on a juste fait une revue de code pour simplifier l'écriture
#                et avoir qqchose de fonctionnel rapidement
#------------------------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------------------------------------
# Version 2 : Evolution, un jour, le programme sera généré à partir du paramétrage.
#             => Pour chaque structure de niveau technique ( 10 positions ) , on prévoit un bloc "code à exécuter avant évaluation"
#                qui permet de saisir le "programme" => la "boucle" principale (i.e. ce qu'on a tapé ici en fait)
#                Probleme sur la structure S45 qui admet un sous niveau contrat et un sous niveau période de cotisation
#                => Idée : chaque structure de niveau technique est générée sous forme d'une étiquette $Sxx.xx.xx.xx
#                          de ce fait dans le bloc de code $S45.G05.00 on pourrait écrire une itération principale
#                          For les contrats
#                            ecrire_structure S45.G05.00
#                            gosub S45.G05.10
#                          Next
#-----------------------------------------------------------------------------------------------------------------------------------

#--------------------------------------------------------------------------------------------------------------------
# S40.G01.00 à S40.G28.05 : Informations générales période d'activité, 0,1 ou 1.1
#                           Il semble qu'on puisse traiter directement ces structures compte tenu de la cardinalité

# 80108 : Découpage pour exclure AT si non renseigné
#--------------------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G01.00" : [L]NUMSTRUCT_FIN = "S40.G20.00"
Gosub ECRIRE_STRUCTURE

If [F:DAE]RSKWRK<>""
 [L]NUMSTRUCT_DEB = "S40.G25.00" : [L]NUMSTRUCT_FIN = "S40.G25.00"
 Gosub ECRIRE_STRUCTURE
Endif

[L]NUMSTRUCT_DEB = "S40.G28.05" : [L]NUMSTRUCT_FIN = "S40.G28.05"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G28.10 Primes versées aux salariés de droit privé 0, n => Données dans DNB
#--------------------------------------------------------------------------------------

[L]NUMSTRUCT_DEB = "S40.G28.10" : [L]NUMSTRUCT_FIN = "S40.G28.10"
For [DNB]DNB0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&            & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G28.15 Indemnitées versées en fin de contrat de travail 0, n => Données dans DAK
#            => NON - BUG détecté ASA / On doit prendre les infos de DNACODIND
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G28.15" : [L]NUMSTRUCT_FIN = "S40.G28.15"

For [DNE]DNE0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS
&                      & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G28.20 : Indemnités et primes versées aux agents sous statut public 0, n => non traité
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G28.20" : [L]NUMSTRUCT_FIN = "S40.G28.20"
# Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G28.56 : Indemnité de congés payés BTP 0, 1 => un truc à la con en cardinalité 0,1 oublié au milieu des 0, n
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G28.56": [L]NUMSTRUCT_FIN = "S40.G28.56"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G30.02 : Bases brutes exceptionnelles URSAFF 0, n => Données dans DAS, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.02": [L]NUMSTRUCT_FIN = "S40.G30.02"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    For [L]IDAS = 0 To [F:DAS]NBRURSBBE-1
        If [F:DAS]URSBBECOD([L]IDAS) <> "" & [F:DAS]URSBBEAMT([L]IDAS) <> 0
            Gosub ECRIRE_STRUCTURE
        Endif
    Next [L]IDAS
Endif

#--------------------------------------------------------------------------------------
# S40.G30.03 : Bases plafonnées exceptionnelles URSAFF 0, n => Données dans DAS, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.03": [L]NUMSTRUCT_FIN = "S40.G30.03"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    For [L]IDAS = 0 To [F:DAS]NBRURSBBP-1
        If [F:DAS]URSBBPCOD([L]IDAS) <> "" & [F:DAS]URSBBPAMT([L]IDAS) <> 0
            Gosub ECRIRE_STRUCTURE
        Endif
    Next [L]IDAS
Endif

#--------------------------------------------------------------------------------------
# S40.G30.04 : CSG 1, 1 => Données dans DAE, zone simple
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.04": [L]NUMSTRUCT_FIN = "S40.G30.04"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G30.06 : Bases spécifiques exonérations de cotisations URSSAF => Données dans DAS, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.06": [L]NUMSTRUCT_FIN = "S40.G30.06"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    For [L]IDAS = 0 To [F:DAS]NBRSPEEXO-1
        If [F:DAS]SPEEXOCOD([L]IDAS) <> ""
            Gosub ECRIRE_STRUCTURE
        Endif
    Next
Endif

#--------------------------------------------------------------------------------------
# S40.G30.10 : Epargne salariale 0, n => Données dans DAS
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.10": [L]NUMSTRUCT_FIN = "S40.G30.10"

For [DAG]DAG0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&                     & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
    Gosub ECRIRE_STRUCTURE
Next


#--------------------------------------------------------------------------------------
# S40.G30.11 : Actions gratuites 0, n => Données dans DAH
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.11": [L]NUMSTRUCT_FIN = "S40.G30.11"

For [DAH]DAH0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&                      & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G30.12 : Options sur titres (stock options) 0, n => Données dans DAE, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.12": [L]NUMSTRUCT_FIN = "S40.G30.12"

For [L]IDAE = 0 To dim([F:DAE]NBRSTK)-1
    If [F:DAE]CTXSTK(IDAE) <> 0 & [F:DAE]NBRSTK([L]IDAE) <> 0
        Gosub ECRIRE_STRUCTURE
    Endif
Next

#--------------------------------------------------------------------------------------
# S40.G30.13 : Bons de souscription de parts de créateur d'entreprise (BPCSE) 0, n => Données dans DAE, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.13": [L]NUMSTRUCT_FIN = "S40.G30.13"

For [L]IDAE = 0 To dim([F:DAE]BSPCENBRTI)-1
    If [F:DAE]BSPCENBRTI([L]IDAE) <> 0
        Gosub ECRIRE_STRUCTURE
    Endif
Next

#--------------------------------------------------------------------------------------
# S40.G30.15 : Participation patronale au financement d'avantages particuliers 0, n => DAI
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.15": [L]NUMSTRUCT_FIN = "S40.G30.15"
For [DAI]DAI0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&                     & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G30.20 : Cas particulier des autres sommes exonérées 0, n => DAJ
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.20": [L]NUMSTRUCT_FIN = "S40.G30.20"
For [DAJ]DAJ0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&    & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G30.35 : Allégements loi du 21 août 2007 0, 1 => DAE, zones simples
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.35": [L]NUMSTRUCT_FIN = "S40.G30.35"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G30.36 : Allégements loi du 21 août 2007, rémunérations exonérées 1, n => DAM
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G30.36": [L]NUMSTRUCT_FIN = "S40.G30.36"

For [DAM]DAM0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&                     & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=[F:DAE]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------
# S40.G40.00 : Données fiscales 1,1 => DAE, zones simples
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G40.00": [L]NUMSTRUCT_FIN = "S40.G40.00"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S40.G40.05 : Avantages en nature 0, n => DAE, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G40.05": [L]NUMSTRUCT_FIN = "S40.G40.05"

For [L]IAVN = 0 To dim([F:DAE]AVNNATD) - 1
    If [F:DAE]AVNNATD([L]IAVN) <> 0 & [F:DAE]AMTAVNNATD([L]IAVN) <> 0
        Gosub ECRIRE_STRUCTURE
    Endif
Next

#--------------------------------------------------------------------------------------
# S40.G40.10 : Frais professionnels 0, n => DAE, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S40.G40.10": [L]NUMSTRUCT_FIN = "S40.G40.10"

For [L]IEXS = 0 To dim([F:DAE]EXSPFLD) - 1
    If [F:DAE]EXSPFLD([L]IEXS) <> 0 & [F:DAE]AMTEXSPFLD([L]IEXS) <> 0
        Gosub ECRIRE_STRUCTURE
    Endif
Next
# ------------------------------ FIN S40 ------------------
Return

#########################################
$LIGNE_S44

#--------------------------------------------------------------------------------------
# S44.G03.00 : Modalités de cotisation Agirc - arcco 0,1 => DAE, zones simples
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S44.G03.00": [L]NUMSTRUCT_FIN = "S44.G03.00"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------
# S44.G03.05 : Institutions de Retraite Complémentaire AGIRC ARRCO destinataires 1,3 => DAS, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S44.G03.05": [L]NUMSTRUCT_FIN = "S44.G03.05"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    For [L]IDAS=0 To min([F:DAS]NBRRGM-1, 3)    : # 3 enregistrements maxi ...
        Gosub ECRIRE_STRUCTURE
    Next [L]IDAS
Endif

#--------------------------------------------------------------------------------------
# S44.G10.10 : Bases spécifiques AGIRC ARRCO 0, n : A traiter
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S44.G10.10": [L]NUMSTRUCT_FIN = "S44.G10.10"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    #79748 For [L]IDAS=0 To [F:DAS]NBRSPECLG-1
    For [L]IDAS=0 To [F:DAS]NBRSPEBAS-1
        Gosub ECRIRE_STRUCTURE
    Next [L]IDAS
Endif

#--------------------------------------------------------------------------------------
# S44.G40.05 : Sommes isolées AGIRC ARRCO 0, n => DAS, tableau
#--------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S44.G40.05": [L]NUMSTRUCT_FIN = "S44.G40.05"

Read[DAS]DAS0=[F:DAE]YEAEMPDDS;[F:DAE]EMPDDS;[F:DAE]CTRNUM;[F:DAE]ETRDAT;[F:DAE]TYPDAE;[F:DAE]FLGDNA
If !fstat
    For [L]IDAS = 0 To [F:DAS]NBRALO-1
        Gosub ECRIRE_STRUCTURE
    Next
Endif
Return

#########################################
$LIGNE_S45
NUMSTRUCT="S45."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

# On ne doit générer les S45 que si il ya des prévoyance ou des mutuelles (cas des organisme non adhérent on ne les extrait pas donc..)
If clalev([F:DAP])=0 : Local File DADEMP3    [DAP] : Endif
If clalev([F:DMU])=0 : Local File DADEMP33   [DMU] : Endif

Filter [DAP] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLG<>2
Read [F:DAP]DAP0 First
Filter [DAP]
If fstat
 Filter [DMU] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLG<>2
 Read [F:DMU]DMU0 First
 Filter [DMU]
 If fstat : Return : Endif
Endif

#------------------------------------------------------------------------------------------------------------------------------------------
# S45.G01.00 : Informations salarié destinées à une institution de prévoyance, mutuelle ou société d'assurances 0, 1 => DAE, zones simples
#------------------------------------------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S45.G01.00" : [L]NUMSTRUCT_FIN = "S45.G01.00"
Gosub ECRIRE_STRUCTURE

#---------------------------------------------------------------------------------------------
# S45.G01.05 : Anciennetés du salarié 1, 4 => DAE, tableau
#---------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S45.G01.05" : [L]NUMSTRUCT_FIN = "S45.G01.05"
For [L]IDPP = 0 To dim ([F:DAE]TYPANC)-1
    If ![F:DAE]TYPANC([L]IDPP) : Break : Endif
    Gosub ECRIRE_STRUCTURE
Next IDPP

#---------------------------------------------------------------------------------------------
# Le CDC indique qu'on peut avoir n S45.G05.00 avec les structures S45.G05 qui en découlent
# - dans notre implémentation cela signifie qu'on a un nouveau -
# niveau de structure après la période d'activité S40 : NIVEAU CONTRAT DE PREVOYANCE
#---------------------------------------------------------------------------------------------
# Historiquement les prévoyances sont enregistrées dans les tables DADEMP3 / DADEMP31 / DADEMP32
# et les mutuelles dans DADEMP33 / DADEMP34 / DADEMP35
# On effectue donc deux balayages en changeant les fichiers utilisés à la volée
#---------------------------------------------------------------------------------------------

# Prévoyance
Gosub S45_PRV

# Mutuelle
Gosub S45_MUT

#---------------------------------------
# S45.G10.00 : Ayants droit 0, n => DAQ
#---------------------------------------

For [DAQ]DAQ0 Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
& & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLG<>2

    #---------------------------------------
    # S45.G10.00 : Ayants droit 0, n => DAQ
    #---------------------------------------
    [L]NUMSTRUCT_DEB = "S45.G10.00" : [L]NUMSTRUCT_FIN = "S45.G10.00"
    Gosub ECRIRE_STRUCTURE

    For [DQE]DQE0 Where YEAEMPDDS=[F:DAQ]YEAEMPDDS & EMPDDS=[F:DAQ]EMPDDS
&        & ETRDAT=[F:DAQ]ETRDAT & CTRNUM=[F:DAQ]CTRNUM & TYPDAE=[F:DAQ]TYPDAE & NUMLIG=[F:DAQ]NUMLIG

        # S45.G10.05 : Informations contrats ayant droit 0, n => DQE

        [L]NUMSTRUCT_DEB = "S45.G10.05" : [L]NUMSTRUCT_FIN = "S45.G10.05"
        Gosub ECRIRE_STRUCTURE

    Next
Next
Return

#########################################
# TABLES PREVOYANCE
#########################################
$S45_PRV
If clalev([F:DAP])=0 : Local File DADEMP3   [DAP] : Endif
If clalev([F:DPE])=0 : Local File DADEMP31  [DPE] : Endif
If clalev([F:DPP])=0 : Local File DADEMP32  [DPP] : Endif
Gosub PREV_MUT
Close File [DAP],[DPE],[DPP]
Return

#########################################
# TABLES MUTUELLE
#########################################
$S45_MUT
#Utilistion des même abrevation que précédemment à cause du paramétrage des S45
# La prévoyance & la mutuelle se déclarent dans les mêmes strutures mais séparemment donc...
If clalev([F:DAP])=0 : Local File DADEMP33  [DAP] : Endif    :#Normalement [DMU]
If clalev([F:DPE])=0 : Local File DADEMP34  [DPE] : Endif    :#Normalement [DME]
If clalev([F:DPP])=0 : Local File DADEMP35  [DPP] : Endif    :#Normalement [DMP]
Gosub PREV_MUT
Close File [DAP],[DPE],[DPP]
Return

#########################################
# PREVOYANCE & MUTUELLE
#########################################
$PREV_MUT
#----------------------------------------------------------------------------------------
# S45.G05.00 : Contrat souscrit auprès d'une institution de prévoyance
#----------------------------------------------------------------------------------------
# Ne pas préciser le code index !

For [DAP] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&        & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLG<>2

    #------------------------------
    # NIVEAU CONTRAT DE PREVOYANCE
    #------------------------------
    [L]NUMSTRUCT_DEB = "S45.G05.00" : [L]NUMSTRUCT_FIN = "S45.G05.00"
    Gosub ECRIRE_STRUCTURE

    For [DPE] Where YEAEMPDDS=[F:DAP]YEAEMPDDS & EMPDDS=[F:DAP]EMPDDS
&         & ETRDAT=[F:DAP]ETRDAT & CTRNUM=[F:DAP]CTRNUM & TYPDAE=[F:DAP]TYPDAE & REFCTR=[F:DAP]REFCTR

        # Evénement salariés dans le contrat

        [L]NUMSTRUCT_DEB = "S45.G05.05" : [L]NUMSTRUCT_FIN = "S45.G05.05"
        Gosub ECRIRE_STRUCTURE
    Next

    #------------------------------------------------
    # S45.G05.10 : Période de cotisation 1, n => DPP
    #------------------------------------------------

    For [DPP] Where YEAEMPDDS=[F:DAP]YEAEMPDDS & EMPDDS=[F:DAP]EMPDDS
&       & ETRDAT=[F:DAP]ETRDAT & CTRNUM=[F:DAP]CTRNUM & TYPDAE=[F:DAP]TYPDAE & REFCTR=[F:DAP]REFCTR & FLG<>2

        [L]NUMSTRUCT_DEB = "S45.G05.10" : [L]NUMSTRUCT_FIN = "S45.G05.10"
        Gosub ECRIRE_STRUCTURE

        #---------------------------------------------------------------------------------------
        # S45.G05.15 : Eléments de rémunération 1,1 => DPP sur l'enregistrement que l'on traite
        #---------------------------------------------------------------------------------------

        [L]NUMSTRUCT_DEB = "S45.G05.15" : [L]NUMSTRUCT_FIN = "S45.G05.15"
        Gosub ECRIRE_STRUCTURE

        #--------------------------------------------------------------------------------
        # S45.G05.20 : Bases ou montants spécifiques de cotisations 0, n => DPP, tableau
        #--------------------------------------------------------------------------------
        [L]NUMSTRUCT_DEB = "S45.G05.20" : [L]NUMSTRUCT_FIN = "S45.G05.20"
        For IDPP=0 To dim ([F:DPP]CODTYPBAS)-1
            If ![F:DPP]CODTYPBAS(IDPP) : Break : Endif
            Gosub ECRIRE_STRUCTURE
        Next IDPP

        [L]NUMSTRUCT_DEB = "S45.G05.25" : [L]NUMSTRUCT_FIN = "S45.G05.25"
        Gosub ECRIRE_STRUCTURE
    Next
Next
Return

#########################################
# Situations particulières
#########################################
$LIGNE_S60
Local Char DATE1 (10),DATE2 (10)
DATE1=num$(gdat$([F:DAC]ETRDAT))
DATE2=num$(gdat$([F:DAC]XITDAT))
Call ECR_TRACE(mess(9,10705,1)-"du"-DATE1-"au"-DATE2,0) From GESECRAN    :#Situations particulières
NUMSTRUCT="S60."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

[L]NUMSTRUCT_DEB = "S60.G05.00" : [L]NUMSTRUCT_FIN = "S60.G05.99"
Gosub ECRIRE_STRUCTURE
Return

#########################################
#Assurance chômage
#########################################
$LIGNE_S48
NUMSTRUCT="S48."

GPOINT = "ECR_"+left$(NUMSTRUCT,3) : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

#-------------------------------------------------------------------------------------------------------
# S48.G10.00 : Assurance chomage - Données dans DAE et DNA - On a les enregistrements sous les pieds
#-------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G10.00" : [L]NUMSTRUCT_FIN = "S48.G10.00"
Gosub ECRIRE_STRUCTURE

#-------------------------------------------------------------------------------------------------------
# S48.G10.05 : DNA
#-------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G10.05" : [L]NUMSTRUCT_FIN = "S48.G10.05"
Gosub ECRIRE_STRUCTURE

#-------------------------------------------------------------------------------------------------------
# S48.G16.05 : DNA
#-------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G16.05" : [L]NUMSTRUCT_FIN = "S48.G16.05"
Gosub ECRIRE_STRUCTURE

#-------------------------------------------------------------------------------------------------------
# S48.G16.06 : DNG
#-------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G47.06" : [L]NUMSTRUCT_FIN = "S48.G47.06"
For [DNG]DNG0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&        & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#-------------------------------------------------------------------------------------------------------
# S48.G16.06 : DNC
#-------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G47.15" : [L]NUMSTRUCT_FIN = "S48.G47.15"
For [DNC]DNC0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&        & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#-------------------------------------------------------------------------------------------------------
# S48.G16.06 : DNH
#-------------------------------------------------------------------------------------------------------
# Verrue ... on saute cette rubrique si pas d'intermittents car DNH est liée à GINTMT
# Version 2 : prévoir un paramétrage des "structures" pour ne pas effectuer toute la structure si une condition est réuni.

If [V]GINTMT
    [L]NUMSTRUCT_DEB = "S48.G47.20" : [L]NUMSTRUCT_FIN = "S48.G47.20"
    # TEST DE CONDITION SUR STRUCTURE A FAIRE POUR NE PAS LIRE DNH SI PAS GINTMT
    For [DNH]DNH0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&            & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
        Gosub ECRIRE_STRUCTURE
    Next
Endif
If [F:DAE]FLGAED <> 2 : Return : Endif

#--------------------------------------------------------------------------------------------------------
# S48.G55.00 : DNA 0,1
#--------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G55.00" : [L]NUMSTRUCT_FIN = "S48.G55.00"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------------------------
# S48.G55.05 : DND 1,n
#--------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G55.05" : [L]NUMSTRUCT_FIN = "S48.G55.05"
For [DND]DND0 Where YEAEMPDDS=[F:DNA]YEAEMPDDS & EMPDDS=[F:DNA]EMPDDS & ETRDAT=[F:DNA]ETRDAT & CTRNUM=[F:DNA]CTRNUM
&        & TYPDAE=[F:DNA]TYPDAE & FLGDNA=[F:DNA]FLGDNA
    Gosub ECRIRE_STRUCTURE
Next

#--------------------------------------------------------------------------------------------------------
# S48.G55.10 : DNA 0,1
#--------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G55.10" : [L]NUMSTRUCT_FIN = "S48.G55.10"
Gosub ECRIRE_STRUCTURE

#--------------------------------------------------------------------------------------------------------
# S48.G55.15 : DNA  , RGMCOD dimensionné => 1,n
#--------------------------------------------------------------------------------------------------------
[L]NUMSTRUCT_DEB = "S48.G55.15" : [L]NUMSTRUCT_FIN = "S48.G55.15"
For [L]IRGM = 0 To dim([F:DNA]RGMCOD) - 1
    If [F:DNA]RGMCOD([L]IRGM) <> ""
        Gosub ECRIRE_STRUCTURE
    Endif
Next
Return

