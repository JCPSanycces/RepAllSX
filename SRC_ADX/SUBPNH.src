Subprog C_UNTWEI(VALEUR)
Variable Decimal VALEUR
Local Integer    OK
#101090 - Verify changes if BOL attached
# Issue 122188 - 2017-03-24 by SR : relecture code : il manque NOLign-1
If VALEUR<>[M:PNH1]UNTWEI(nolign-1)
  Call VERIF_BOLMOD(OK) From SUBPNHA
  If OK<>2 : mkstat=2 : Endif
Endif
End

# Issue 71069 - 2016-09-14 by MUARN : pjt
Subprog AM_PJTH(VALEUR)
Variable Char    VALEUR()
If [M:PNH1]NBLIG = 0
  [M:PNH1]PJTH=VALEUR
  If dim([M:PNH1]DIE)>0 & [M:PNH1]NBAXE>0
    Raz [M:PNH1]NBAXE, [M:PNH1]DIE, [M:PNH1]CCE
    Call INIT_CCEH("PNH1","NBAXE","PNH") From TRTX3CPT
  Endif
Endif
End

