$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"PND","[M:PNH1]LINACC",nolign-1) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"[M:PNH1]LINACC","") From TRTX3CPT
# Issue 76502 - 2011-09-27 by VPO : on refait init pour cas sections précedentes
#car PREP_INIT_CCE déjà fait sur comptes
If !mkstat
   If VALEUR=""
      Call INIT_CCE(VALEUR,AXE,"PND","[M:PNH1]LINACC",nolign-1) From TRTX3CPT
   Endif
Endif
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"[M:PNH1]LINACC",GFINRSP,[M:PNH1]RTNDAT) From TRTX3CPT
Return


Subprog D_TRSFAM(VALEUR)
#----------------------------------#
# Initialisation famille mouvement #
#----------------------------------#
Variable Char VALEUR
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
   Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
VALEUR=[F:PTR]TRSFAMDEF
End


