#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion retours fournisseurs
#########################################################################
# SUBPNH : Gestion des retours fournisseurs  SR/15/04/98 - MBT 08/01/03 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "PNH"                         #
# Le traitement des actions "Gosub" se trouvent dans le SUBPNHA         #
#########################################################################

$ACTION
#---------------------------------#
# Actions de l'objet PNH (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBPNHA
 When "VARIANTE"     : Gosub VARIANTE     From SUBPNHA
 When "SETTRANS"     : Gosub SETTRANS     From SUBPNHA
 When "FILTRE"       : Gosub FILTRE       From SUBPNHA
 When "AV_IMPRIME"   : Gosub AV_IMPRIME   From SUBPNHA
 When "AP_IMPRIME"   : Gosub AP_IMPRIME   From SUBPNHA
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE  From SUBPNHA
 When "OUVRE"        : Gosub OUVRE        From SUBPNHA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBPNHA
 When "AFFMASK"      : Gosub AFFMASK      From SUBPNHA
 When "SETBOUT"      : Gosub SETBOUT      From SUBPNHA
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBPNHA
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBPNHA
 When "STATUT"       : Gosub STATUT       From SUBPNHA
 When "HINT"         : Gosub HINTCLE      From SUBPNHA
 When "FILGAUCHE"    : Gosub FILGAUCHE    From SUBPNHA
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE From SUBPNHA
#When "TIROIR"       : Gosub TIROIR       From SUBPNHA
 When "DEB_PICK"     : Gosub DEB_PICK     From SUBPNHA
 When "PICKE"        : Gosub PICKE        From SUBPNHA
 When "DEPICK"       : Gosub DEPICK       From SUBPNHA
 When "FIN_PICK"     : Gosub FIN_PICK     From SUBPNHA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBPNHA
 When "GRISE"        : Gosub GRISE        From SUBPNHA
 When "DEFLIG"       : Gosub DEFLIG       From SUBPNHA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBPNHA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBPNHA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBPNHA
 When "VALLIG"       : Gosub VALLIG       From SUBPNHA
 When "RAZCRE"       : Gosub RAZCRE       From SUBPNHA
 When "RAZDUP"       : Gosub RAZDUP       From SUBPNHA
 When "LIENS"        : Gosub LIENS        From SUBPNHA
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBPNHA
 When "INICRE"       : Gosub INICRE       From SUBPNHA
 When "CREATION"     : Gosub CREATION     From SUBPNHA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBPNHA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBPNHA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBPNHA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBPNHA
 When "INIMOD"       : Gosub INIMOD       From SUBPNHA
 When "MODIF"        : Gosub MODIF        From SUBPNHA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBPNHA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBPNHA
 When "ABANDON"      : Gosub ABANDON      From SUBPNHA
 When "VERF_ANU"     : Gosub VERF_ANU     From SUBPNHA
 When "ANNULE"       : Gosub ANNULE       From SUBPNHA
 When "AP_ANNULE"    : Gosub AP_ANNULE    From SUBPNHA
 When "FIN_ACTION"   : Gosub FIN_ACTION   From SUBPNHA
 When "FERME"        : Gosub FERME        From SUBPNHA
 When "FIN"          : Call  RAZSTOSORW   From STKSOR
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "AB2_BPAADD"   : Gosub AB2_BPAADD
 When "BB2_BPAADD"   : Gosub BB2_BPAADD
 When "AB3_BPAADD"   : Gosub AB3_BPAADD
 When "BB3_BPAADD"   : Gosub BB3_BPAADD
 When "AB1_NBLIG"    : Gosub AB1_NBLIG
 When "AB3_NBLIG"    : Gosub AB3_NBLIG
 When "BB3_NBLIG"    : Gosub BB3_NBLIG
 When "AB6_NBLIG"    : Gosub AB6_NBLIG
 When "BB6_NBLIG"    : Gosub BB6_NBLIG
 When "AB8_NBLIG"    : Gosub AB8_NBLIG

 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG
 When "AB1_ITMDES"   : Gosub AB1_ITMDES
 When "BB1_ITMDES"   : Gosub BB1_ITMDES
 When "AB1_ITMDES1"  : Gosub AB1_ITMDES1
 When "BB1_ITMDES1"  : Gosub BB1_ITMDES1
 When Default
Endcase
Return


Subprog AS_PNHFCY(VALEUR)
#-----------------------------#
# Avant saisie du site retour #
#-----------------------------#
Variable Char     VALEUR
If GREP<>"C" | [M:PNH1]NBLIG<>0 : mkstat=2 : Endif
End


Subprog AM_PNHFCY(VALEUR)
#----------------------------#
# Après modif du site retour #
#----------------------------#
Variable Char    VALEUR()
GFCY=VALEUR
#RMA * 107331
If func AFNC.ACTIV("TRSNE") > 0
  ## Get purchage type
  Local Char WPNHTYP(GLONTPN)
  Gosub PNHTYP From TRTACHRET1
  If WPNHTYP<>"" : [M:PNH1]PNHTYP=WPNHTYP : Affzo [M:PNH1]PNHTYP : Endif
Endif
Gosub CHARG_PARAM From SUBPNHA

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY(VALEUR,"[M:PNH1]PJT") From TRTPJT
Endif

#----- Contrôle et chargement des zones inter-sites -----#
If [M:PNH1]BPSNUM<>"" & [M:PNH1]BETFCY<>0
  Local Char    WBPSNUM(GLONBPS) : [L]WBPSNUM=[M:PNH1]BPSNUM
  # Issue 107136 - 2015-03-26 by SR
  Local Char    WPNHFCY(GLONFCY) : [L]WPNHFCY = VALEUR
  Local Libelle WORI             : [L]WORI=1
  Gosub CTRL_INTERSITE
  If mkstat
    Local Char WMESS(80) : WMESS=GMESSAGE
    GFCY=[M:PNH1]PNHFCY : Gosub CHARG_PARAM From SUBPNHA
    GMESSAGE=WMESS
    GERR=1 : mkstat=1 : End
  Endif
Endif
#----- Effacement tableau des sections entête -----#
# Issue 90239 - 2013-06-03 by SR
If dim([M:PNH1]DIE)>0 & [M:PNH1]NBAXE>0
  [M:PNH1]PNHFCY=VALEUR
  Raz [M:PNH1]NBAXE, [M:PNH1]DIE, [M:PNH1]CCE
  Call INIT_CCEH("PNH1","NBAXE","PNH") From TRTX3CPT
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPNHA
#-----
#--- Bug 65478
If dim([M:PNH1]WRHE)>0
   Call WRHINIT([M:PNH1]WRHE,VALEUR,6) From STKWRH
Endif
#---
# Actzo ou Grizo des dépôts selon le site
[M]PNHFCY=VALEUR
Gosub WRH_ETAT From SUBPNHA

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY(VALEUR,"[M:PNH1]PJT") From TRTPJT
Endif

End

######################################################################################
######################################################################################
Subprog AS_PNHTYP(VALEUR)
Variable Char    VALEUR()

#85785 RMA
If GREP="" & VALEUR=""
    Local Char WPNHTYP(GLONTPN)
    Gosub PNHTYP From TRTACHRET1 : VALEUR=WPNHTYP
Endif

End
######################################################################################
######################################################################################
Subprog C_PNHTYP(VALEUR)
Variable Char    VALEUR()

#85785 RMA
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:TPN]) = 0 : Local File TABPNHTYP [TPN]  : Endif

Local    Char    LEG
Local    Integer CAS   : [L]CAS = 1 : # 1 - Legislation is empty; 2 - Legislation isn't empty

If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
If fstat > 1 : Raz [F:FCY] : Endif

If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Elsif LEG=""
  [L]LEG = [F:FCY]LEG
Endif

If [L]LEG<>""
  Read [TPN]TPN0=VALEUR;[L]LEG
  If fstat
    Read [TPN]TPN0=VALEUR;""
  Else
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Else
  Read [F:TPN]TPN0(1)=[L]VALEUR
  If !fstat
    [L]LEG = [F:TPN]LEG
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Endif

If fstat
  Filter [F:TPN] Where [F:TPN]PNHTYP=VALEUR
  Look [F:TPN]TPN0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    GMESSAGE = VALEUR-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    GMESSAGE = VALEUR-":"-mess(23,100,1)
  Endif
  Filter [F:TPN]
  mkstat = 2 : End
Endif

If [F:TPN]GFY<>""
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
  Read [AGF]AGF0=[F:TPN]GFY
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Company
      If [F:TPN]GFY<>[F:FCY]LEGCPY
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TPN]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Elsif [F:AGF]FLGCPY=2
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      Look [AGC]AGC0 = [F:TPN]GFY;[F:FCY]LEGCPY
      If fstat
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TPN]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Endif
  Endif
Endif

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP(VALEUR,"PNH",GMESSAGE) = 1
    mkstat = 2 : End
  Endif
Endif

End
######################################################################################
######################################################################################
Subprog AM_PNHTYP(VALEUR)
Variable Char    VALEUR()

#85785 RMA
If func AFNC.ACTIV("TRSNE") > 0 : [M:PNH1]PNHTYP=VALEUR : Endif
Gosub REC_CPT_PNH : If GERR=1 : mkstat=2 : Endif

If GMANCOU=1 & [M:PNH1]PNHNUM <> ""
   Effzo [M:PNH1]PNHNUM
Endif

If GREP="C" & GMANCOU<>2
   Diszo [M:PNH1]PNHNUM
Else
   Actzo [M:PNH1]PNHNUM
Endif

End
######################################################################################


Subprog D_RTNDAT(VALEUR)
#-------------------------------#
# Initialisation date du retour #
#-------------------------------#
Variable Date     VALEUR
VALEUR=date$
End


Subprog AS_PNHNUM(VALEUR)
#----------------------------------#
# Avant saisie du numéro de retour #
#----------------------------------#
Variable Char     VALEUR
If (GREP="C" | GREP="D") & GMANCOU<>2  mkstat=2 : Endif
End


Subprog C_PNHNUM(VALEUR)
#-------------------------------#
# Contrôle sur numéro de retour #
#-------------------------------#
Variable Char    VALEUR()
#-------- Compteur manuel, numéro obligatoire ! --------#
# If GMANCOU=2 & VALEUR="" GMESSAGE=mess(182,199,1) : mkstat=1 : End : Endif
#----- Rien d'affiché, vérif si un enregistrement existe -----#
If [M:PNH1]PNHNUM="" & GREP<>"C"
  Look [PNH] PNH0=VALEUR
  If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
#----- En création ou dupli et cteur manuel, contrôle si no existe déja -----#
If (GREP<>"C" & GREP<>"D") | GMANCOU<>2  End : Endif
VALEUR=vireblc(VALEUR,2)
Look [PNH] PNH0=VALEUR
If !fstat  GMESSAGE=mess(22,100,1) : mkstat=1 : End : Endif
End


Subprog AS_BUY(VALEUR)
#-------------------------------#
# Avant saisie du code acheteur #
#-------------------------------#
Variable Char     VALEUR
#If GREP<>"C" | [M:PNH1]NBLIG<>0 : mkstat=2 : End : Endif
End


Subprog AS_BPSNUM(VALEUR)
#-----------------------------#
# Avant saisie du fournisseur #
#-----------------------------#
Variable Char    VALEUR()
#Local Integer NOL,I
#If GREP<>"C" | [M:PNH1]NBLIG<>0 : mkstat=2 : End : Endif
End


Subprog C_BPSNUM(VALEUR)
#----------------------#
# Contrôle fournisseur #
#----------------------#
Variable Char    VALEUR()
If VALEUR<>""
  Read [BPR] BPR0=VALEUR
  If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
End


Subprog AM_BPSNUM(VALEUR)
#-------------------------------------------------------------------#
# Après modification fournisseur : Chargement des zones fournisseur #
#-------------------------------------------------------------------#
Variable Char    VALEUR()
Local    Char     WBPSNUM(GLONBPS) : [L]WBPSNUM=VALEUR
# Issue 107136 - 2015-03-26 by SR
Local    Char     WPNHFCY(GLONFCY) : [L]WPNHFCY = [M:PNH1]PNHFCY
Local    Libelle  WORI             : [L]WORI=2
Local    Shortint I
#-----
[M:PCRW]WBPSNUM=VALEUR
#----- Contrôle et chargement des zones inter-sites -----#
Gosub CTRL_INTERSITE : If mkstat  Raz [M:PNH1]BPSNUM : End : Endif
#----- Get document counter -----#
Gosub REC_CPT_PNH : If GERR=1 : mkstat=2 : End: Endif
#----- Lecture du fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Lecture du business partner si nécessaire -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR : If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE   : Endif
Endif
[M:PNH1]LAN=[F:BPR]LAN
#-----
GCUR=[F:BPS]CUR
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:PNH1]TSSCOD)>0
  For I=0 To dim([M:PNH1]TSSCOD)-1
    [M:PNH1]TSSCOD(I)=[F:BPS]TSSCOD(I)
  Next I
Endif
#----- Chargement du régime taxe du fournisseur -----#
Call INIT_REGIME(VALEUR,[M:PNH1]PNHFCY,"F",[M:PNH1]VACBPR) From CPTSUB
#----- Chargement du type de régime taxe -----#
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PNH1]VACBPR
#  Read [ADI] CODE=1;[M:PNH1]VACBPR : If fstat Raz [F:ADI] : Endif
#Endif
#[M:PNH1]VACTYP=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[M:PNH1]VACBPR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[M:PNH1]VACTYP=[F:TVB]REGVAC
# 71937 : Multilégislation

#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
  #----- Affichage entêtes de colonne variables -----#
  If !GIMPORT & (dim([M:PNH1]DISCRGVAL1)>0 | dim([M:PNH1]CCE1)>0)
    Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE7"+GPTRNUM+"1"
  Endif
Endif
Call FMTREM("PNH1",GCUR) From TRTPRICE
#-----
If [F:BPS]BPRPAY=""
  [M:PNHC]BPRPAY=VALEUR
  [M:PNHC]BPAPAY=[F:BPS]BPAADD
Else
  [M:PNHC]BPRPAY=[F:BPS]BPRPAY
  [M:PNHC]BPAPAY=[F:BPS]BPAPAY
Endif
If [F:BPS]BPSINV=""
  [M:PNHC]BPSINV=VALEUR
  [M:PNHC]BPAINV=[F:BPS]BPAADD
Else
  [M:PNHC]BPSINV=[F:BPS]BPSINV
  [M:PNHC]BPAINV=[F:BPS]BPAINV
Endif
[M:PNHC]MDL    = [F:BPS]MDL
[M:PNHC]BPTNUM = [F:BPS]BPTNUM
#----- Positionnement indicateur CEE -----#
If GACTDEB=2
  If [F:TCY]CRY<>[F:BPR]CRY
    Read [TCY] TCY0=[F:BPR]CRY : If fstat Raz [F:TCY] : Endif
  Endif
  If GPNH_CPYCRY<>[F:BPR]CRY & [F:TCY]EECFLG=2
    GPNH_EECFLG=2
  Else
    GPNH_EECFLG=1
  Endif
Else
  GPNH_EECFLG=0
Endif
#----- Chargement des informations douanières -----#
If GACTDEB=2
  If GPNH_EECFLG=2
    [M:PCEY]EECLOC = [F:BPS]EECLOC : # Lieu de transport CEE
    # [M:PCEY]EECNAT = "21"                     :# CPO 07/2008 - initialisé dans INICRE
    # If GDEBGBR=1  [M:PCEY]EECNAT="20" : Endif :# CPO 07/2008 - initialisé dans INICRE
    # [M:PCEY]EECSCH = "29"                     :# CPO 07/2008 - initialisé dans INICRE
    #----- Lecture table des modes de livraison si nécessaire -----#
    If [F:TMD]MDL<>[F:BPS]MDL
      Read [TMD] TMD0=[F:BPS]MDL : If fstat Raz [F:TMD] : Endif
    Endif
    #-----
    [M:PCEY]EECTRN = [F:TMD]EECTRN : # Mode de transport CEE
    If [F:BPR2]BPRNUM<>[F:BPS]BPSINV
      Read [BPR2] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR2] : Endif
    Endif
    [M:PCEY]EECNUM=[F:BPR2]EECNUM  : # Identification CEE
  Else
    Raz [M:PCEY]
  Endif
Else
  Raz [M:PCEY]
Endif
[M:PCEY]EECICT =[F:BPS]EECICT     : # Incoterm
[M:PCEY]WPOSCOD=""
[M:PCEY]WBPSNUM=VALEUR
[M:PCEY]WBPAADD=[F:BPS]BPAADD
[M:PCEY]WCRY   =""
#----- Alimentation à partir du modèle d'édition du fournisseur retour -----#
Call ALI_PRTMOD("PNH1",10) From TRTX3
#----- Récupération du lien texte entête ou pied -----#
If GPURTEXRTN=1
  [M:PNH1]TEX1=[F:BPS]RTNTEX : Raz [M:PNH1]TEX2
Else
  [M:PNH1]TEX2=[F:BPS]RTNTEX : Raz [M:PNH1]TEX1
Endif
#-----
If [M:AD65]ADBFLG>0 & [M:PNH1]BPSNUM<>""  Raz [M:AD65] : Endif
[M:PNH1]BPSNAM = [F:BPR]BPRNAM(0)
[M:AD65]ADBBPR = VALEUR
[M:AD65]BPAADD = [F:BPS]BPAADD
[M:PNH1]BPAADD = [F:BPS]BPAADD
Affzo [PNH1]BPSNAM, BPAADD
#----- Initialisation des sections analytiques -----#
# Issue 90239 - 2013-06-03 by SR
If dim([M:PNH1]DIE)>0
  Raz [M:PNH1]NBAXE, [M:PNH1]DIE, [M:PNH1]CCE
  Call INIT_CCEH("PNH1","NBAXE","PNH") From TRTX3CPT
Endif
End


Subprog IB_BPAADD
#---------------------------------------------------#
# Initialisation des boutons sur champ code adresse #
#---------------------------------------------------#
Raz GBOUT1, GBOUT4
GBOUT2=mess(27,198,1)  : # Adresse
GBOUT3=mess(13,198,1)  : # Complément
End


Subprog AS_BPAADD(VALEUR)
#---------------------------#
# Avant saisie code adresse #
#---------------------------#
Variable Char    VALEUR()
#If GREP<>"C" | [M:PNH1]BPSNUM=""  mkstat=2 : End : Endif
If GREP="C" & [M:PNH1]BPSNUM=""   mkstat=2 : End : Endif
If GREP="C" & [M:PNH1]BPSNUM<>""
  Affzo [PNH1]1-99
Endif
End


Subprog C_BPAADD(VALEUR)
#-----------------------#
# Contrôle code adresse #
#-----------------------#
Variable Char    VALEUR()
If [M:PNH1]BPSNUM<>""
  Read [BPA] BPA0=1;[M:PNH1]BPSNUM;VALEUR
  If fstat Raz [F:BPA] : mkstat=1 : End : Endif
Endif
End


Subprog AM_BPAADD(VALEUR)
#------------------------------------#
# Après modification du code adresse #
#------------------------------------#
Variable Char    VALEUR()
If VALEUR=[M:PNH1]BPAADD
  VALEUR=[M:AD65]BPAADD
Else
  [M:AD65]BPAADD    = VALEUR
  [M:AD65]ADBBPR    = [M:PNH1]BPSNUM
  #----- Chargement raison sociale si 1ère fois -----#
  If [M:AD65]ADBFLG=0
    #----- Lecture Business Partner si nécessaire -----#
    If [F:BPR]BPRNUM<>[M:PNH1]BPSNUM
      Read [BPR] BPR0=[M:PNH1]BPSNUM : If fstat  Raz [F:BPR] : Endif
    Endif
    [M:AD65]BPRNAM(0) = [F:BPR]BPRNAM(0)
    [M:AD65]BPRNAM(1) = [F:BPR]BPRNAM(1)
  Endif
  #----- Lecture adresse -----#
  Read [BPA] BPA0=1;[M:PNH1]BPSNUM;[M:AD65]BPAADD
  If fstat Raz [F:BPA] : Endif
  [M:AD65]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AD65]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AD65]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AD65]CRY          = [F:BPA]CRY
  [M:AD65]CRYNAM       = [F:BPA]CRYNAM
  [M:AD65]SAT          = [F:BPA]SAT
  [M:AD65]POSCOD       = [F:BPA]POSCOD
  [M:AD65]CTY          = [F:BPA]CTY
  If [M:AD65]ADBFLG=0  [M:AD65]ADBFLG=1 : Endif
Endif
If [M:AD65]ADBFLG=2
  [M:PNH1]BPSNAM=[M:AD65]BPRNAM(0) : Affzo [PNH1]BPSNAM
Endif
End


$AB2_BPAADD
#-------------------------------------------#
# Avant appel action SAIADRBPR par bouton 2 #
#-------------------------------------------#
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
If GREP=""  GCONSULT=1 : Endif
Return


$BB2_BPAADD
#-------------------------------------------#
# Après appel action SAIADRBPR par bouton 2 #
#-------------------------------------------#
GCONSULT=SAV_GCONSULT
Return


$AB3_BPAADD
#-------------------------------------------#
# Avant appel action SAIPNHCOM par bouton 3 #
#-------------------------------------------#
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
If GREP=""  GCONSULT=1 : Endif
Return


$BB3_BPAADD
#-------------------------------------------#
# Après appel action SAIPNHCOM par bouton 3 #
#-------------------------------------------#
GCONSULT=SAV_GCONSULT
Return

Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

Subprog AS_NBLIG
#--------------------#
# Avant saisie NBLIG #
#--------------------#
Local Shortint NOL : NOL=nolign-1
#----- Pas de saisie possible acheteur et fournisseur si des lignes existent -----#
If [M:PNH1]NBLIG=1
  If GNBAUZ>1 Diszo [PNH1]PNHFCY : Endif
  Diszo [PNH1]BUY, BPSNUM
  # BRBAN * 01/04/2015 * #107394
  If func AFNC.ACTIV("TRSNE") > 0 # Issue 115373 - 2016-03-18 by RMA : PNHTYP linked to activity code
    Diszo [PNH1]PNHTYP
  Endif
  # -
Elsif [M:PNH1]NBLIG=0
  If GNBAUZ>1 Actzo [PNH1]PNHFCY : Endif
  Actzo [PNH1]BUY, BPSNUM
  # BRBAN * 01/04/2015 * #107394
  If func AFNC.ACTIV("TRSNE") > 0 # Issue 115373 - 2016-03-18 by RMA : PNHTYP linked to activity code
    Actzo [PNH1]PNHTYP
  Endif
  # -
  #----- Réinitialisation tableau des sections entête -----#
  # Issue 90239 - 2013-06-03 by SR
  If dim([M:PNH1]DIE)>0
    Raz [M:PNH1]NBAXE, [M:PNH1]DIE, [M:PNH1]CCE
    Call INIT_CCEH("PNH1","NBAXE","PNH") From TRTX3CPT
  Endif
  #-----
Endif
#-----
If [M:PNH1]CFMFLG<2
  If [M:PNH1]NBLIG=0 & [M:PNH1]PCLFLG=2
    [M:PNH1]PCLFLG=1
  Endif
Endif
End


Subprog IB_NBLIG
#---------------------------------------------------------#
#       Initialisation des boutons sur champ NBLIG        #
# ------------------------------------------------------- #
# - Bouton 1 : Action GOBJETC6A Tunnel contrôle qualité   #
# - Bouton 2 : Action CONSSFC   Stock par site            #
# - Bouton 3 : Action GOBJETC0  Tunnel vers commandes     #
# - Bouton 4 : Action GOBJETC1  Tunnel vers réceptions    #
# - Bouton 5 : Action ACLOB     Saisie texte ligne        #
# - Bouton 6 : Action SAISTOSOR Saisie détail quantités   #
# - Bouton 7 : Tunnel vers retours client                 #
# - Bouton 8 : Action SAISTOSORM Modification des sorties #
# - Bouton 9 : Explication du prix                        #
# - Bouton 10: Traçabilité pièces                         #
# - Bouton 11: Situation ligne                            #
#---------------------------------------------------------#
Local Integer NOL : NOL=nolign-1
If [M:PNH1]LINTYP(NOL)<3
  GBOUT11 = mess(164,198,1) : # Situation ligne
Endif
Raz GBOUT3, GBOUT4, GBOUT5, GBOUT7, GBOUT9
#----- Maximum ligne atteint ou référence article non renseignée -----#
If dim([M:PNH1]ITMREF)<nolign  | [M:PNH1]ITMREF(NOL)=""
  Raz GBOUT1, GBOUT2, GBOUT6, GBOUT8, GBOUT11 : End
Endif
#-----
If [M:PNH1]STOMGTCOD(NOL)<2 | [M:PNH1]LINTYP(NOL)>2
  Raz GBOUT1, GBOUT2, GBOUT6, GBOUT8
Else
  If [M:PNH1]PTHNUM(NOL)<>""
    Filter [STJ] Where STOFCY=[M:PNH1]PNHFCY
&                    & VCRTYP=6
&                    & VCRNUM=[M:PNH1]PTHNUM(NOL)
&                    & VCRLIN=[M:PNH1]PTDLIN(NOL)
&                    & ITMREF=[M:PNH1]ITMREF(NOL)
&                    & REGFLG<>2
&                    & TRSTYP<>29                : #--- Issue 115206
    Columns [STJ] (QLYCTLDEM)
    Read [STJ] STJ1 First : If fstat  Raz [F:STJ] : Endif
    Filter [STJ]
    Columns [STJ]
    If [F:STJ]QLYCTLDEM<>""
      GBOUT1=mess(8,704,1) : # Contrôle qualité
    Else
      Raz GBOUT1
    Endif
  Else
    Raz GBOUT1
  Endif
  If [M:PNH1]CFMFLG=2 | [M:PNH1]LINTYP(NOL)>2
    Raz GBOUT6
  Endif
Endif
If [M:PNH1]POHNUM(NOL)<>""  GBOUT3=mess(191,198,1)-[M:PNH1]POHNUM(NOL) : Endif : # Commande
If [M:PNH1]PTHNUM(NOL)<>""  GBOUT4=mess(117,198,1)-[M:PNH1]PTHNUM(NOL) : Endif : # Réception
GBOUT5=mess(38,198,1)    : # Texte
If [M:PNH1]LINTYP(NOL)<>2
  GBOUT9=mess(386,198,1) : # Explication du prix
Endif
If [M:PNH1]SRHNUM(NOL)<>""  GBOUT7=mess(458,198,1)-[M:PNH1]SRHNUM(NOL) : Endif : # Retours client
#----- Pas de modif de sorties si retour non validé ou retour client effectué -----#
If [M:PNH1]CFMFLG=1 | [M:PNH1]SRHNUM(NOL)<>"" | [M:PNH1]LINTYP(NOL)>2
  Raz GBOUT8
Endif
#----- Pas de clic droit saisie des sorties si enregistrement verrouillé -----#
If !GPNH_VERROU & !find(GREP,"C","D") Raz GBOUT6 : Endif
#VPO 04/11/10 59662 Modifier Attente d'avoir sur retour validé
If [M:PNH1]CFMFLG=1 | [M:PNH1]INVQTYPUU(NOL)>0 | [M:PNH1]INVQTYSTU(NOL)>0
    #non validée ou déja facturée
    Raz GBOUT12
Endif
# SYMEU 10/12/2008 : branchement traçabilité pièces
If find(GREP,"C","D") or find("CONSPIA",GNAVIG(1..GPILNAV)) Then Raz GBOUT10 Endif

#85785 * RMA * can't change the document values if validated
If [M:PNH1]CFMFLG = 2 & func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY, "")
  Raz GBOUT8
Endif

End

Subprog C_NBLIG
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#------------------------------#
# Controle sur numéro de ligne #
#------------------------------#
If [M:PNH1]NBCRELIG>0
  [M:PNH1]NBLIG+=[M:PNH1]NBCRELIG
  If !GIMPORT Affzo [PNH1]1-99 : Endif
  Raz [M:PNH1]NBCRELIG
Endif
GMODIF=2
Local Integer  WRET
Local Shortint NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65                : # Annulation simple
If WSTATUS=65                : # Annulation simple
  Gosub TEST_ANU
  If !mkstat & [M:PNH1]STOMGTCOD(NOL)>1 & [M:PNH1]LINTYP(NOL)<3
    #----- Suppression des sorties dans l'écran de travail -----#
    Call DELSTOSORW(NOL,NOL,"PNH1",[M:PNH1]PNHFCY,WRET) From STKSOR
    If WRET  mkstat=2 : Endif
  Endif
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#Elsif status=68 | status=83 : # Annulation multiple
Elsif WSTATUS=68 | WSTATUS=83 : # Annulation multiple
  For NOL=nolign-1 To nolign1-1
    Gosub TEST_ANU : If mkstat : Break : Endif
  Next NOL
  If !mkstat & (find(2,[M:PNH1]STOMGTCOD(nolign-1..nolign1-1)) |
&               find(3,[M:PNH1]STOMGTCOD(nolign-1..nolign1-1)) |
&               find(4,[M:PNH1]STOMGTCOD(nolign-1..nolign1-1)))
    #----- Suppression des sorties dans l'écran de travail -----#
    Call DELSTOSORW(nolign-1,nolign1-1,"PNH1",[M:PNH1]PNHFCY,WRET) From STKSOR
    If WRET  mkstat=2 : Endif
  Endif
Endif
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=75                           Gosub TEST_MOD    : Endif
#If status=73 | status=82               Gosub TEST_INSERT : Endif
#If find(status,1,4,5,20,21,26,92,93) |
#&      (status>128 & status<141)       Gosub TEST_VALID  : Endif
If WSTATUS=75                           Gosub TEST_MOD    : Endif
If WSTATUS=73 | WSTATUS=82               Gosub TEST_INSERT : Endif
If find(WSTATUS,1,4,5,20,21,26,92,93) |
&      (WSTATUS>128 & WSTATUS<141)       Gosub TEST_VALID  : Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

$TEST_ANU
#----------------------------------#
# Test pour annulation d'une ligne #
#----------------------------------#
#----- Suppression ligne d'un composant (service) interdite -----#
If [M:PNH1]LINTYP(NOL)>2
  GMESSAGE=mess(386,194,1) : mkstat=1 : GMODIF=1 : Return
Endif
#-----

#101090 - Verify changes if BOL attached
Local Integer OK
Call VERIF_BOLMOD(OK) From SUBPNHA
If OK<>2 : mkstat=1 : Endif

Return

$TEST_MOD
#-----------------------------------------------------------#
# Test pour modification d'une ligne                        #
# GMODIF : Indicateur modification autorisée (1=Non, 2=Oui) #
#-----------------------------------------------------------#
If [M:PNH1]CFMFLG=2
  mkstat=1 : GMODIF=1
Else
  #----- Ligne d'un composant, modification interdite ! -----#
  If [M:PNH1]LINTYP(NOL)>2 & [M:PNH1]CFMFLG<>2
    GMESSAGE=mess(387,194,1) : mkstat=1 : GMODIF=1 : Return
  Endif
  #-----
  GMODIF=2
Endif
Return

$TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
#----- Le fournisseur n'a pas été renseigné ! -----#
If [M:PNH1]BPSNUM=""
  GMESSAGE=mess(196,194,1) : mkstat=1 : GMODIF=1 : Return
Endif
#----- Insertion impossible entre des composants et leur composé -----#
If [M:PNH1]LINTYP(NOL)>2
  GMESSAGE=mess(97,192,1)  : mkstat=1 : GMODIF=1 : Return
Endif

#101090 - Verify changes if BOL attached
Local Integer OK
Call VERIF_BOLMOD(OK) From SUBPNHA
If OK<>2 : mkstat=1 : Endif

Return

$TEST_VALID
#---------------------------------------------------#
# A la sortie du tableau effacement la "status bar" #
#---------------------------------------------------#
If !GIMPORT  Inftxt "" At 2 : Endif
Return


Subprog AM_NBLIG
#---------------------------------------------#
# A chaque fois que le nombre de ligne change #
#---------------------------------------------#
#----- Test si modif ligne existante par saisie ou click droit -----#
If status<>75 & status<>131
  [M:PNH1]PCLFLG=9 : # Pour actualisation éventuelle des listes de picking
Endif
End

######################################################################################
## VPO 04/11/10 ajouter bouton Modifier Attente d'avoir FQ59662
######################################################################################
Subprog B12_NBLIG
Local Integer NOL : NOL=nolign-1
Local Integer  REP  : REP=1
Local Integer WRET
Local Char SYMBOL2(30) : Raz SYMBOL2

REP=1
If [M:PNH1]AVOFLG(NOL)=1
   #Voulez-vous faire une demande d’avoir pour cette ligne de retour
   Call OUINON(func AFNC.MES(mess(418,194,1),"("+num$(NOL+1)+"/"-[M:PNH1]ITMREF(NOL)-[M:PNH1]ITMDES(NOL)+")"),REP) From GESECRAN
Else
   #Voulez-vous annuler la demande d’avoir pour cette ligne de retour
   Call OUINON(func AFNC.MES(mess(419,194,1),"("+num$(NOL+1)+"/"-[M:PNH1]ITMREF(NOL)-[M:PNH1]ITMDES(NOL)+")"),REP) From GESECRAN
Endif

If REP=1
  End
Endif

#----- Contrôle lock logique -----#
Call JELOCKE("PNH"+[M:PNH1]PNHNUM,WRET) From OBJDIV
If [L]WRET=0
    SYMBOL2="PNH"+[M:PNH1]PNHNUM : Lock=SYMBOL2
    If fstat
        Raz SYMBOL2
        OK=0 : GMESSAGE=mess(10,100,1) : GERR=1
        End
    Endif
Endif

Gosub MOD_INVFLG

If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
End

$MOD_INVFLG
#----- Mise à jour de l'entête de retour -----#
Call DEBTRANS From GLOCK
$TR_INVFLG
Trbegin [PNH]
  Readlock [PNH]PNH0=[M:PNH1]PNHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PRETURN"-[M:PNH1]PNHNUM            : Goto ROLL_INVFLG
  Elsif fstat
    GOK=0  : Call RSTA("PNH",[M:PNH1]PNHNUM) From GLOCK : Goto AB_INVFLG
  Endif

  Readlock [PND]PND0=[M:PNH1]PNHNUM;[M:PNH1]PNDLIN(NOL)
  If fstat=1
    GOK=-1 : GLOCK="$PRETURND"-[M:PNH1]PNHNUM            : Goto ROLL_INVFLG
  Elsif fstat
    GOK=0  : Call RSTA("PND",[M:PNH1]PNHNUM) From GLOCK : Goto AB_INVFLG
  Endif

  #on doit gerer le cas ou l'enreg aurait été modifié par autre utilisateur entre temps
  If [F:PNH]CFMFLG=1 | [F:PND]INVQTYPUU>0 | [F:PND]INVQTYSTU>0
        GOK=0 : OK=0 : GMESSAGE=mess(10,100,1) : GERR=1 : Goto AB_INVFLG
  Elsif ([F:PND]LININVFLG=2 & [M:PNH1]AVOFLG(NOL)=2) | ([F:PND]LININVFLG=1 & [M:PNH1]AVOFLG(NOL)=1)
        GOK=0 : OK=0 : GMESSAGE=mess(10,100,1) : GERR=1 : Goto AB_INVFLG
  Endif

  If [M:PNH1]AVOFLG(NOL)=2 : #avoir en attente
      [F:PND]LININVFLG = 2 : #on met déjà facturee donc pas avoir en attente
  Else
      [F:PND]LININVFLG = 1 : #on met pas facturé donc avoir en attente
  Endif
  Rewrite [PND]
  If fstat GOK=0 : Call FSTA("PND") From GLOCK : Goto AB_INVFLG : Endif

  If [M:PNH1]AVOFLG(NOL)=2
      [F:PNH]INVLINNBR+=1
  Else
      [F:PNH]INVLINNBR-=1
  Endif
  If [F:PNH]INVLINNBR=[F:PNH]LINNBR
      [F:PNH]INVFLG=3
  Elsif [F:PNH]INVLINNBR=0
      [F:PNH]INVFLG=1
  Else
      [F:PNH]INVFLG=2
  Endif
  Rewrite [PNH]
  If fstat GOK=0 : Call FSTA("PNH") From GLOCK : Goto AB_INVFLG : Endif
Commit
If [M:PNH1]AVOFLG(NOL)=2
    [M:PNH1]AVOFLG(NOL)=1
Else
    [M:PNH1]AVOFLG(NOL)=2
Endif
Affzo [M:PNH1]AVOFLG(NOL)
[M:PNH1]INVFLG=[F:PNH]INVFLG : Affzo [M:PNH1]INVFLG
[M:PNH1]INVLINNBR = [F:PNH]INVLINNBR
Return
#-----
$ROLL_INVFLG
Rollback : Call ROLL From GLOCK
If GROLL  Return  Else  Goto TR_INVFLG : Endif
#-----
$AB_INVFLG
Rollback
Return

$AB1_NBLIG
#---------------------------------------------------------------------#
# Avant exécution de l'action GOBJETC6A : Tunnel sur contrôle qualité #
#---------------------------------------------------------------------#
Local Char WQLYCTLDEM(GLONVCR)
Filter [STJ] Where STOFCY=[M:PNH1]PNHFCY
&                & VCRTYP=6
&                & VCRNUM=[M:PNH1]PTHNUM(nolign-1)
&                & VCRLIN=[M:PNH1]PTDLIN(nolign-1)
&                & ITMREF=[M:PNH1]ITMREF(nolign-1)
&                & TRSTYP<>29                : #--- Issue 115206
Columns [STJ] (QLYCTLDEM)
Read [STJ] STJ1 First
If !fstat
  [L]WQLYCTLDEM=[F:STJ]QLYCTLDEM
Else
  Raz [L]WQLYCTLDEM
Endif
Filter [STJ]
Columns [STJ]
Infbox [L]WQLYCTLDEM
Return


$AB3_NBLIG
#--------------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A : Tunnel commandes, contrats #
#--------------------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
If [M:PNH1]POHTYP(NOL)=2
  WOBJET="POD"
  WCLE1 =num$([M:PNH1]POPLIN(NOL))
  WCLE2 =[M:PNH1]POHNUM(NOL)
Else
  WOBJET="POH"
  WCLE1 =[M:PNH1]POHNUM(NOL)
  WCLE2 =""
Endif
Return


$BB3_NBLIG
#------------------------------------------------------#
# Après exécution du bouton Tunnel commandes, contrats #
#------------------------------------------------------#
nolign=NOL+1
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PNH1]PNHFCY
  Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
  If fstat Raz [F:ITF] : Endif
Endif
Return


$AB6_NBLIG
#---------------------------------------#
# Avant exécution de l'action SAISTOSOR #
#---------------------------------------#
GOUVSOR=1 : # Pour autoriser la saisie du détail sortie
Call AVANT_NBLIG
Return


$BB6_NBLIG
# Issue 92730 - 2013-09-24 by SR : Sauvegarder mkstat issu du moteur de gestion des stocks
Local Integer WMKSTAT : WMKSTAT = mkstat
#---------------------------------------#
# Après exécution de l'action SAISTOSOR #
#---------------------------------------#
Call APRES_NBLIG
#----- Si composé affichage des composants -----#
If [M:PNH1]LINTYP(nolign-1)=2  Affzo [PNH1]15 : Endif
# Issue 92730 - 2013-09-24 by SR : Restaurer mkstat issu du moteur de gestion des stocks
mkstat = WMKSTAT
#-----
Return


Subprog AVANT_NBLIG
#--------------------------------------------#
# Avant ligne : Soustraction cumuls et bases #
#--------------------------------------------#
Local Shortint NOL  : NOL=nolign-1
Local Shortint SENS
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If [M:PNH1]ITMREF(NOL)=""  [M:PNH1]LINFLG(NOL)=0 : Endif
SENS=-1 : Gosub MAJ_TOTWEI : # Màj totaux poids brut et net
#----- Avant ligne : Si suppression ligne, suppression texte et marquage -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  #----- Suppression du texte ligne si la ligne est créée et supprimée -----#
  If [M:PNH1]CREFLG(nolign-1)=0 & left$([M:PNH1]LINTEX(nolign-1),3)="PND"
    Call SUP_CLOB([M:PNH1]LINTEX(nolign-1),GBIDI1) From TRTX3TEX
  Endif
  #----- Actualisation du marquage dans les listes de picking -----#
  If !GIMPORT
    Local Shortint WPICK, I
    WPICK=1 : I=NOL : Gosub MARQUAGE_LIGNE From SUBPNHA
  Endif
  [M:PNH1]PCLFLG=1
Elsif [M:PNH1]ITMREF(NOL)<>""
  #----- Lecture article et règle de gestion -----#
  #Call LECFICSOR([M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,11,[M:PNH1]TRSCOD,"") From STKECR
  If dim([M:PNH1]LINCAT)>0 & [M:PNH1]LINCAT(NOL)= 2 : # GA 09/2006
     Call INIZONSOR("PNH1",[M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,NOL,32,[M:PNH1]TRSCOD,"") From STKECR
  Else
     Call INIZONSOR("PNH1",[M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,NOL,11,[M:PNH1]TRSCOD,"") From STKECR
  Endif
  #----- Vérification si coefficient UC-US est modifiable -----#
  Call CTLUOM([M:PNH1]ITMREF(NOL),1,[M:PNH1]BPSNUM,[M:PNH1]UOM(NOL),GBIDD1,
&              GBIDC2,GBIDC3,GBIDI2) From STKACT
  If mkstat  Raz mkstat : GBIDI2=1 : Endif
  If GBIDI2=1
    Diszo [PNH1]UOMSTUCOE(NOL)
    [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"2"+right$([M:PNH1]WSTOSAI(NOL),4)
  Else
    Actzo [PNH1]UOMSTUCOE(NOL)
    [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"0"+right$([M:PNH1]WSTOSAI(NOL),4)
  Endif
Endif
#-----
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

$AB8_NBLIG
#---------------------------------------#
# Avant exécution de l'action SAISTOSOR #
#---------------------------------------#
#----- Habilitation Modif mvts stock si on trouve K dans chaine boutons autorisés -----#
GFCY=[M:PNH1]PNHFCY : GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2
  GMESSAGE=mess(2,104,1) : GOUVSOR=0 : Return : # HCB 27842
Else
  GOUVSOR=1
Endif
Return

$AAPRES_NBLIG
#---------------------------------------#
# Avant exécution de l'action SAISTOSOR #
#---------------------------------------#
Local Shortint NOL : NOL=nolign-1
Local Integer  WRET, I
Raz GOUVSOR
If find(status,65,68,83) | adxgtb=1  Return : Endif
If [M:PNH1]STOMGTCOD(NOL)>1 & [M:PNH1]LINTYP(NOL)<3
  If [M:PNH1]CREFLG(NOL)=0 | [M:PNH1]CFMFLG<>2
    #----- Relecture transaction si nécessaire -----#
    If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
    Endif
    #-----
    If [M:PNH1]CREFLG(NOL)<>0 | [M:PNH1]UPDFLG(NOL)<>0  WRET=2  Else  WRET=0 : Endif
    Gosub CHARG_ALLPAR
    Call OUVSOR("PNH1",NOL,[M:PNH1]NBLIG,[M:PNH1]WSTOSEQ(NOL),[F:PTR]STKFLG,[L]WRET) From STKSOR
    If [L]WRET=0
      [M:PNH1]WSTOFLG(NOL)=1 : # Détail stock OK !
      [M:PNH1]QTYSTUACT(NOL)=sigma(I=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(I)*
&                                  ([M:SOW]WSTOSEQ(I)=[M:PNH1]WSTOSEQ(NOL)))
    Else
      [M:PNH1]WSTOFLG(NOL)=0 : # Nécessité de saisir manuellement le détail stock
      [M:PNH1]QTYSTUACT(NOL)=[M:PNH1]QTYSTU(NOL)
    Endif
  Endif
Else
  [M:PNH1]WSTOFLG(NOL)=2   : # Pas géré en stock, jamais de saisie détail
Endif
Affzo [PNH1]ITMREF(NOL)
Return


Subprog APRES_NBLIG
#----------------------------------------#
# Après ligne : Addition cumuls et bases #
#----------------------------------------#
Local Shortint NOL : NOL=nolign-1
Local Shortint I, SENS
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#----- Abandon de la saisie ligne par escape ou click sur listes de gauche -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=6 | status=7 | status=27 | status=28 | [M:PNH1]ITMREF(NOL)=""
If WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28 | [M:PNH1]ITMREF(NOL)=""
  #----- Suppression des sorties dans l'écran de travail -----#
  If [M:PNH1]STOMGTCOD(NOL)>1
&  & [M:PNH1]CREFLG(NOL)=0
&  & [M:PNH1]UPDFLG(NOL)=0
&  & [M:PNH1]LINTYP(NOL)<3
    Call DELSTOSORW(NOL,NOL,"PNH1",[M:PNH1]PNHFCY,GBIDI1) From STKSOR
  Endif
  # Issue X3-102918 - 2018-08-03 by SR : Exploitation WSTATUS et restore status
  #If !find(status,65,68,83)  End : Endif
  If !find(WSTATUS,65,68,83) : status =  WSTATUS : End : Endif
Endif
 #----- Si suppression, on se tire -----#
 # Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If (status=65 | status=68 | status=83)
If (WSTATUS=65 | WSTATUS=68 | WSTATUS=83)
  #----- Suppression des lignes liées au composé (produit fini) -----#
  If NOL<[M:PNH1]NBLIG-1 & [M:PNH1]LINTYP(NOL+1)>2
    I=NOL+1
    While [M:PNH1]LINTYP(I)>2
      nolign=I+1 : Call AVANT_NBLIG From SUBPNH
      Dela I,1,[M:PNH1]NBLIG-1 [M:PNH1]NBLIG : [M:PNH1]NBLIG-=1
    Wend
    Affzo [PNH1]15
    nolign=NOL+1
  Endif
  [M:PNH1]PCLFLG=1
  # Issue X3-102918 - 2018-08-07 by SR : Restore status
  status = WSTATUS
  End
Endif
#----- Si modif du composé, répercution sur les composants -----#
If [M:PNH1]LINTYP(NOL)=2
  Call CALCUL_COMPOSANTS(NOL) From SUBPNHB
Endif
#-----
SENS=+1 : Gosub MAJ_TOTWEI : # Màj totaux poids brut et net
#-----
[M:PNH1]LINFLG(NOL)=1
#----- Si retour direct, il faut charger le prix unitaire net d'achat -----#
If [M:PNH1]PTHNUM(NOL)=""
  [M:PNH1]NETPRIPUU(NOL)=arr([M:PNH1]NETPRI(NOL)/[M:PNH1]UOMPUUCOE(NOL),10^-GDECPRI)
Endif
#----- Calcul Montant ligne HT et TTC-----#
Local Char VAT(GLONVAT)(3)
VAT(0)=[M:PNH1]VAT1(NOL) : VAT(1)=[M:PNH1]VAT2(NOL) : VAT(2)=[M:PNH1]VAT3(NOL)
[M:PNH1]LINAMT(NOL)=[M:PNH1]NETPRI(NOL)*[M:PNH1]QTYUOM(NOL)
Call ARRDEV([M:PNH1]LINAMT(NOL),[M:PNH1]NETCUR(NOL)) From TRTDIV
#Call ALICLCAMT ([M:PNH1]ITMREF(NOL),[M:PNH1]QTYUOM(NOL),NOL,"PNH1",
#&               [M:PNH1]CLCAMT1(NOL),[M:PNH1]CLCAMT2(NOL))   From TRTX3
#Call CLCTAXEMNT([M:PNH1]LINAMT(NOL),VAT,1,GSOCIETE,[M:PNH1]RTNDAT,[M:PNH1]CLCAMT1(NOL),
#&               [M:PNH1]CLCAMT2(NOL),[M:PNH1]LINATIAMT(NOL)) From TRTX3
#Call ARRDEV([M:PNH1]LINATIAMT(NOL),[M:PNH1]NETCUR(NOL)) From TRTDIV
Call MAJ_CALTAX_LIG("PNH1",NOL) From TRTACHDIV1
#----- Actualisation listes gauche -----#
If [M:PNH1]PCLFLG=9
  If !GIMPORT
    Local Shortint WPICK, I
    WPICK=2 : I=NOL : Gosub MARQUAGE_LIGNE From SUBPNHA
  Endif
  [M:PNH1]PCLFLG=1
Endif
#----- Ne rien faire si appel depuis picking (status=0), sera affiché globalement ------#
If !GIMPORT & WSTATUS<>0
  #----- Si composé affichage des composants -----#
  If [M:PNH1]LINTYP(NOL)=2
    Affzo [PNH1]15
  #----- Autrement affichage article, statut, montant ligne, ...etc -----#
  Else
    Affzo [PNH1]ITMREF(NOL),STA(NOL),LINAMT(NOL)
    If dim([M:PNH1]LOC)>0    Affzo [PNH1]LOC(NOL)                 : Endif
    If dim([M:PNH1]BPSLOT)>0 Affzo [PNH1]BPSLOT(NOL),LOT(NOL)     : Endif
    If dim([M:PNH1]SLO)>0    Affzo [PNH1]SLO(NOL)                 : Endif
    If dim([M:PNH1]SERNUM)>0 Affzo [PNH1]SERNUM(NOL),SERNUMF(NOL) : Endif
    If dim([M:PNH1]PALNUM)>0 Affzo [PNH1]PALNUM(NOL),CTRNUM(NOL)  : Endif
  Endif
Endif
#-----

# Issue 71069 - 2013-08-23 by MUARN : PJT
# Si première ligne & pas de code affaire à l'entête on alimente le code affaire à l'entête
# Issue 71069-53 - 2016-08-25 by MUARN : import PJT
If ( [M:PNH1]NBLIG <1  | (GPNH_PICK & [M:PNH1]NBLIG=1) | (GIMPORT & [M:PNH1]NBLIG=1)) & [M:PNH1]PJTH = "" & GPJTSNGDOC = 2
  [M:PNH1]PJTH = [M:PNH1]PJT(NOL)
  Affzo [PNH1]PJTH
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End


Subprog AV_ITMREF(VALEUR)
#------------------------------------------------#
# Avant zone référence article pour colorisation #
#------------------------------------------------#
Variable Char     VALEUR()
Local    Shortint I, NOL : NOL=nolign-1
pcolor=GCOUL(0)       : # Noir
If [M:PNH1]STOMGTCOD(NOL)<2 | [M:PNH1]LINTYP(NOL)>2  End : Endif
#----- Nouvelle ligne article gérée en stock -----#
If [M:PNH1]CREFLG(NOL)=0 | [M:PNH1]UPDFLG(NOL)=1
  #----- Le détail sortie a t-il été saisi correctement ? -----#
  GBIDD1=sigma(I=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=[M:PNH1]WSTOSEQ(NOL)))
  If [M:PNH1]QTYSTU(NOL)<>GBIDD1 | [M:PNH1]QTYSTU(NOL)=0
    [M:PNH1]WSTOFLG(NOL)=0
    pcolor=GCOUL(1)   : # Rouge
  #----- Y a t-il une quantité en rupture ? -----#
  Else
    [M:PNH1]WSTOFLG(NOL)=1
    GBIDD1=sigma(I=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(I)*
&                ([M:SOW]WSTOSEQ(I)=[M:PNH1]WSTOSEQ(NOL) & [M:SOW]WSTOCOU(I)<>0))
    If [M:PNH1]QTYSTU(NOL)<>GBIDD1
      pcolor=GCOUL(2) : # Bleu
    Endif
  Endif
Elsif [M:PNH1]FLGRUP(NOL)=1
  pcolor=GCOUL(2)
Endif
End


Subprog AS_ITMREF(VALEUR)
#--------------------------------------#
# Avant saisie de la référence article #
#--------------------------------------#
Variable Char    VALEUR()
If GMODIF<>2 | VALEUR<>""  mkstat=2 : End : Endif
End


Subprog AM_ITMREF(VALEUR)
#--------------------------------------------#
# Après modification de la référence article #
#--------------------------------------------#
Variable Char    VALEUR()
Local   Shortint NOL : NOL=nolign-1
If [F:ITM]STOMGTCOD>1
  Look [ITF] ITF0=VALEUR;[M:PNH1]PNHFCY
  If fstat
    GERR=1 : GMESSAGE=VALEUR-[M:PNH1]PNHFCY-mess(139,197,1) : mkstat=1 : End
  Endif
Endif
#-----
Local Decimal QTY, QTYUS, WSTUDIS, COEF
#----- Filtre par acheteur -----#
If GBUYFLT=2
  If [F:ITM]STOMGTCOD=1
    If [F:ITM]BUY<>"" & [F:ITM]BUY<>[M:PNH1]BUY
      GERR=1 : GMESSAGE=mess(27,194,1) : mkstat=1 : End
    Endif
  Else
    Read [ITF] ITF0=[F:ITM]ITMREF;[M:PNH1]PNHFCY
    If fstat Raz [F:ITF] : Endif
    If [F:ITF]BUY="" [F:ITF]BUY=[F:ITM]BUY : Endif
    If [F:ITF]BUY<>"" & [F:ITF]BUY<>[M:PNH1]BUY
      GERR=1 : GMESSAGE=mess(27,194,1) : mkstat=1 : End
    Endif
  Endif
Endif
#----- Relecture transaction si nécessaire -----#
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Chargement ligne si le numéro de réception n'est pas saisi à la suite -----#
If [F:PTR]REFORICOD>1 | [F:PTR]REFORIPOS<2
  [M:PNH1]ITMREF(NOL)=VALEUR : Raz [M:PNH1]ITMDES(NOL), [M:PNH1]ITMDES1(NOL)
  Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
Else
  #----- Chargement des désignations article -----#
  #Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PNH1]ITMDES(NOL)) From TRTX3
  #If [M:PNH1]ITMDES(NOL)="" [M:PNH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PNH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  #[M:PNH1]ITMDES1(NOL)=[F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PNH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 112754 - 2017-01-20 by SR : Services
  [M:PNH1]ITMKND(NOL) = 1
  If [F:ITM]SCSFLG = 2 : [M:PNH1]ITMKND(NOL) = 3 : Endif
  If !GIMPORT : Affzo [M:PNH1]ITMKND(NOL) : Endif
  # End issue 112754
Endif
#-----
End


Subprog IB_ITMDES
#------------------------------#
# Activation bouton "Articles" #
#------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End

$AB1_ITMDES
#--------------------------------------#
# Avant exécution du bouton "Articles" #
#--------------------------------------#
Local Shortint NOL : NOL=nolign-1
Return

$BB1_ITMDES
#--------------------------------------#
# Après exécution du bouton "Articles" #
#--------------------------------------#
nolign=NOL+1
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PNH1]PNHFCY
  Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
  If fstat Raz [F:ITF] : Endif
Endif
Return

Subprog IB_ITMDES1
#------------------------------#
# Activation bouton "Articles" #
#------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End

$AB1_ITMDES1
#--------------------------------------#
# Avant exécution du bouton "Articles" #
#--------------------------------------#
Local Shortint NOL : NOL=nolign-1
Return

$BB1_ITMDES1
#--------------------------------------#
# Après exécution du bouton "Articles" #
#--------------------------------------#
nolign=NOL+1
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PNH1]PNHFCY
  Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
  If fstat Raz [F:ITF] : Endif
Endif
Return

Subprog AS_PTHNUM(VALEUR)
#-------------------------------------#
# Avant saisie du numéro de réception #
#-------------------------------------#
Variable Char    VALEUR()
If GMODIF<>2                  |
& [M:PNH1]PTDLIN(nolign-1)<>0 |
& [M:PNH1]CREFLG(nolign-1)<>0 |
& [M:PNH1]UPDFLG(nolign-1)<>0
  mkstat=2
Endif
End


Subprog C_PTHNUM(VALEUR)
#---------------------------------#
# Contrôle du numéro de réception #
#---------------------------------#
Variable Char    VALEUR()
Local   Shortint NOL : NOL=nolign-1
If VALEUR<>""
  #----- contrôle existence de la réception -----#
  Read [PTH] PTH0=VALEUR
  If fstat
    Raz [F:PTH] : GMESSAGE=VALEUR-mess(23,100,1) : mkstat=1 : End
  Endif
  #----- Vérification appartenance à la même société juridique -----#
  Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat Raz [F:FCY] : Endif
  If [F:FCY]LEGCPY<>GSOCIETE
    GMESSAGE=mess(151,194,1) : mkstat=1 : End
  Endif
  #----- Vérification site de réception = site de retour -----#
  #If [F:PTH]PRHFCY<>[M:PNH1]PNHFCY
  #  GMESSAGE=[F:PTH]PRHFCY-mess(103,194,1) : mkstat=1 : End
  #Endif
Elsif GPNHDIR<>2
  GMESSAGE=mess(261,194,1) : mkstat=1 : End : # Retour direct interdit !
Elsif [M:PNH1]CREFLG(NOL)=0 & [M:PNH1]UPDFLG(NOL)=0
  #----- Relecture transaction si nécessaire -----#
  If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
  #----- Chargement ligne si la référence article a été saisie avant -----#
  If [F:PTR]REFORIPOS=3
    [M:PNH1]PTHNUM(NOL)=VALEUR
    Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
  Endif
Endif
End


Subprog AS_PTDLIN(VALEUR)
#----------------------------------------------#
# Avant saisie du numéro de ligne de réception #
#----------------------------------------------#
Variable Decimal VALEUR
If GMODIF<>2                   |
&  [M:PNH1]PTHNUM(nolign-1)="" |
&  [M:PNH1]CREFLG(nolign-1)<>0 |
&  [M:PNH1]UPDFLG(nolign-1)<>0
  # Issue 115504 - 2016-03-24 by SR : Razer les buffers si pas de réception
  If [M:PNH1]PTHNUM(nolign-1)="" : Raz  [F:PTH], [F:PTD] : Endif
  mkstat=2
Endif
End


Subprog C_PTDLIN(VALEUR)
#-------------------------------------------#
# Contrôle sur numéro de ligne de réception #
#-------------------------------------------#
Variable Decimal VALEUR
Local Char WMSG(250) # Issue 71069 - 2016-04-01 by SR : PJT
If [M:PNH1]PTHNUM(nolign-1)<>""
  #----- Contrôle existence de la ligne de réception -----#
  Read [PTD] PTD0=[M:PNH1]PTHNUM(nolign-1);VALEUR
  If fstat
    Raz [F:PTD] : GMESSAGE=mess(23,100,1) : mkstat=1 : End
  Endif
Endif
# Issue 71069 - 2016-04-01 by SR : PJT
# tests backporting : Contrôler aussi la première ligne si PJTH renseigné
If [M:PNH1]NBLIG >0 | [M:PNH1]PJTH <> ""
  If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PNH1]PJT", WMSG) = G_NON Then
     GMESSAGE = WMSG
     mkstat = 1
     End
  Endif
Endif
# End issue 71069
End


Subprog AM_PTDLIN(VALEUR)
#----------------------------------------------------#
# Après modification du numéro de ligne de réception #
#----------------------------------------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
#----- Retour à partir d'une ligne de réception -----#
If [M:PNH1]PTHNUM(nolign-1)<>""
  #----- Lecture ligne de réception si nécessaire -----#
  If ([F:PTD]PTHNUM<>[M:PNH1]PTHNUM(NOL) | [F:PTD]PTDLIN<>VALEUR)
    Read [PTD] PTD0=[M:PNH1]PTHNUM(NOL);VALEUR
    If fstat
      Raz [F:PTD] : GMESSAGE=mess(23,100,1) : GERR=1 : mkstat=1 : End
    Endif
  Endif
  #----- Ligne composant interdite, saisissez le composé ! -----#
  If [F:PTD]LINTYP>2
    GMESSAGE=mess(385,194,1) : mkstat=1 : End
  Endif
  #----- L'article réception doit être identique à l'article ligne retour -----#
  If [M:PNH1]ITMREF(NOL)<>"" & [F:PTD]ITMREF<>[M:PNH1]ITMREF(NOL)
    GMESSAGE="("+[F:PTD]ITMREF-"<>"-[M:PNH1]ITMREF(NOL)+")"-mess(263,194,1)
    GERR=1 : mkstat=1 : End
  Endif
  #----- Filtre par acheteur -----#
  If GBUYFLT=2
    If [F:ITM]ITMREF<>[F:PTD]ITMREF
      Read [ITM] ITM0=[F:PTD]ITMREF : If fstat  Raz [F:ITM] : Endif
    Endif
    If [F:ITM]STOMGTCOD=1
      If [F:ITM]BUY<>"" & [F:ITM]BUY<>[M:PNH1]BUY
        GERR=1 : GMESSAGE=mess(27,194,1) : mkstat=1 : End
      Endif
    Else
      Read [ITF] ITF0=[F:ITM]ITMREF;[M:PNH1]PNHFCY
      If fstat Raz [F:ITF] : Endif
      If [F:ITF]BUY="" [F:ITF]BUY=[F:ITM]BUY : Endif
      If [F:ITF]BUY<>"" & [F:ITF]BUY<>[M:PNH1]BUY
        GERR=1 : GMESSAGE=mess(27,194,1) : mkstat=1 : End
      Endif
    Endif
  Endif
  #----- On vérifie que la ligne de réception n'est pas déjà dans l'écran PNH1 -----#
  Local Integer  WINDICE
  Local Integer  WRETO
  Local Integer  WRECH_IND
  WRETO    =1
  WINDICE  =0
  WRECH_IND=0
  While WINDICE<[M:PNH1]NBLIG
    WRECH_IND=find([M:PNH1]PTHNUM(NOL),[M:PNH1]PTHNUM(WINDICE..[M:PNH1]NBLIG-1))
    If WRECH_IND<>0
      WRECH_IND+=WINDICE
      #----- Attention à ne pas tomber sur la ligne que l'on traite
      If WRECH_IND<>(NOL+1) & [M:PNH1]PTDLIN(WRECH_IND-1)=VALEUR
        WRETO=0
      Else
        WINDICE=WRECH_IND
        WRECH_IND=0
      Endif
    Else
      WRETO=2
    Endif
    If WRETO=0 | WRETO=2 : Break : Endif
  Wend
  If WRETO=0
    GMESSAGE=mess(209,194,1) : GERR=1 : mkstat=1 : Raz [M:PNH1]PTDLIN(NOL), VALEUR : End
  Endif
  #----- On vérifie qu'il n'y a pas déjà un retour non validé sur cette ligne réception -----#
  If clalev ([F:PNHW])<=0  Local File PRETURN  [PNHW] : Endif
  If clalev ([F:PNDW])<=0  Local File PRETURND [PNDW] : Endif
  Raz WINDICE
  Filter [PNDW] Where PTHNUM=[M:PNH1]PTHNUM(NOL) & PTDLIN=VALEUR
  For [PNDW] PND1
    Filter [PNHW] Where PNHNUM=[F:PNDW]PNHNUM & CFMFLG=1 & PNHNUM<>[M:PNH1]PNHNUM
    Look [PNHW] PNH0 First
    If !fstat WINDICE=1 : Break : Endif
  Next
  Filter [PNHW]
  Filter [PNDW]
  If WINDICE=1
    GMESSAGE=mess(211,194,1) : GERR=1 : mkstat=1 : Raz [M:PNH1]PTDLIN(NOL), VALEUR : End
  Endif
  [M:PNH1]PTDLIN(NOL)=VALEUR
  # Issue 115946 - 2016-04-13 by MUARN : ITMREF doit être renseigné pour CAL_QTYMAX
  [M:PNH1]ITMREF(NOL)=[F:PTD]ITMREF
  Gosub CAL_QTEMAX From SUBPNHB
  If [M:PNH1]MAXQTYSTU(NOL)=0
    GMESSAGE=mess(197,194,1) : GERR=1 : mkstat=1 : Raz [M:PNH1]PTDLIN(NOL), VALEUR : End
  Endif
  # Issue 115946 - 2016-04-13 by MUARN : ITMREF doit être renseigné pour CAL_QTYMAX
  #[M:PNH1]ITMREF(NOL)=[F:PTD]ITMREF
#----- Retour direct sans réception -----#
Else
  [M:PNH1]PTDLIN(NOL)=VALEUR
Endif
#-----
If [M:PNH1]ITMREF(NOL)<>""
  Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
Endif
End


Subprog IB_RTNREN
#-----------------------------------------------#
# Initialisation boutons sur champ Motif retour #
#-----------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
End


Subprog AM_RTNREN(VALEUR)
#----------------------------------#
# Après modif du code Motif retour #
#----------------------------------#
Variable Char    VALEUR()
If [F:ADI]NUMTAB<>7 | [F:ADI]CODE<>VALEUR
  Read [ADI] CODE=7;VALEUR : If fstat Raz [F:ADI] : Endif
Endif
If !clalev([F:AXX])  Local File ATEXTRA [AXX] : Endif
Read [AXX] AXX0="ATABDIV";"LNGDES";[M:PNH1]LAN;"7";VALEUR
If fstat
  Read [AXX] AXX0="ATABDIV";"SHODES";[M:PNH1]LAN;"7";VALEUR
  If fstat
    Read [AXX] AXX0="ATABDIV";"LNGDES";GLANGUE;"7";VALEUR
    If fstat
      Read [AXX] AXX0="ATABDIV";"SHODES";GLANGUE;"7";VALEUR
    Endif
  Endif
Endif
If !fstat  [M:PNH1]RTNDES(nolign-1)=[F:AXX]TEXTE : Endif
End


Subprog AS_UOM(VALEUR)
#-----------------------------------#
# Avant saisie de l'unité de retour #
#-----------------------------------#
Variable Char     VALEUR
If GMODIF<>2  mkstat=2 : End : Endif
End


Subprog AM_UOM(VALEUR)
#-------------------------------------------#
# Après modification de l'unité de retour   #
#-------------------------------------------#
Variable Char     VALEUR
Local    Shortint NOL             : NOL   =nolign-1
Local    Char     WUNIT1(GLONUOM) : WUNIT1=[M:PNH1]UOM(NOL)
Local    Decimal  WCOEF1          : WCOEF1=[M:PNH1]UOMSTUCOE(NOL)
Local    Decimal  QTE
Local    Shortint I
#----- Calcul qté en UC et coefficient UC-US -----#
Call PCAL_QTY([M:PNH1]QTYSTU(NOL),[M:PNH1]STU(NOL),[M:PNH1]QTYUOM(NOL),VALEUR,
&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GBIDD1)  From TRTACHQTE1
[M:PNH1]UOMSTUCOE(NOL)=arr(1/GBIDD1,0.000001)
#----- Calcul qté en UA et coefficient UC-UA -----#
Call PCAL_QTY([M:PNH1]QTYUOM(NOL),VALEUR,[M:PNH1]QTYPUU(NOL),[M:PNH1]PUU(NOL),
&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
[M:PNH1]UOMPUUCOE(NOL)=GCOEUOM
#----- Vérification si coefficient UC-US est modifiable -----#
Call CTLUOM([M:PNH1]ITMREF(NOL),1,[M:PNH1]BPSNUM,VALEUR,GBIDD1,
&            GBIDC2,GBIDC3,GBIDI2) From STKACT
If mkstat  Raz mkstat : GBIDI2=1 : Endif
If GBIDI2=1
  Diszo [PNH1]UOMSTUCOE(NOL)
  [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"2"+right$([M:PNH1]WSTOSAI(NOL),4)
Else
  Actzo [PNH1]UOMSTUCOE(NOL)
  [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"0"+right$([M:PNH1]WSTOSAI(NOL),4)
Endif
#-----
If VALEUR=[M:PNH1]PUU(NOL)
  [M:PNH1]UOMFLG(NOL)=1
Else
  [M:PNH1]UOMFLG(NOL)=2
Endif
[M:PNH1]UOM(NOL)=VALEUR
Affzo [PNH1]QTYUOM(NOL), QTYPUU(NOL), UOMSTUCOE(NOL), QTYSTU(NOL)
# Issue 122188 - 2017-03-23 by SR : Recalcul du poids unitaire
If [M:PNH1]LINTYP(NOL)<>3
   #----- Lecture article si nécessaire -----#
   If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
     Read [ITM] ITM0=[M:PNH1]ITMREF(NOL)
     If fstat  Raz [F:ITM] : Endif
   Endif
   [M:PNH1]UNTWEI(NOL)   =[F:ITM]ITMWEI*[M:PNH1]UOMSTUCOE(NOL)
   Call QTEARR ([M:PNH1]UNTWEI(NOL),[M:PNH1]WEU(NOL)) From TRTDIV
   Affzo [PNH1]UNTWEI(NOL)
Endif
# End issue 122188
#----- Retour direct : Recherche tarif ? après modif unité -----#
If [M:PNH1]PTHNUM(NOL)=""
  If [M:PNH1]LINFLG(NOL)=1
    Local Integer OK
    OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
    If OK=2
      Call INI_TARIF(NOL)
    Else
      Call REAJUST_TARIF("PNH1",NOL,WUNIT1,VALEUR,WCOEF1,[M:PNH1]UOMSTUCOE(NOL)) From TRTACHPRI1
    Endif
  Elsif [M:PNH1]LINFLG(NOL)=0
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("PNH1",NOL,WUNIT1,VALEUR,WCOEF1,[M:PNH1]UOMSTUCOE(NOL)) From TRTACHPRI1
  Endif
#----- Retour sur réception : Conversion tarif si coefficients unités différents -----#
Else
  Call REAJUST_TARIF("PNH1",NOL,WUNIT1,VALEUR,WCOEF1,[M:PNH1]UOMSTUCOE(NOL)) From TRTACHPRI1
Endif
End


Subprog AS_QTYUOM(VALEUR)
#----------------------------------------------------#
# Avant saisie quantité retournée en unité de retour #
#----------------------------------------------------#
Variable Decimal  VALEUR
If GMODIF<>2  mkstat=2 : End : Endif
End


Subprog AM_QTYUOM(VALEUR)
#---------------------------------#
# Après modif de la qté retournée #
#---------------------------------#
Variable Decimal  VALEUR
Local Shortint NOL : NOL=nolign-1
Local Decimal  QTEUA, QTEUS, MAXQTYUOM
#----- Calcul qtés en UA et en US -----#
QTEUA=VALEUR*[M:PNH1]UOMPUUCOE(NOL)
Call QTEARR(QTEUA,[M:PNH1]PUU(NOL)) From TRTDIV
QTEUS=VALEUR*[M:PNH1]UOMSTUCOE(NOL)
Call QTEARR(QTEUS,[M:PNH1]STU(NOL)) From TRTDIV
#----- Contrôle si qté supérieure au maxi -----#
If QTEUS>[M:PNH1]MAXQTYSTU(NOL)
  MAXQTYUOM=[M:PNH1]MAXQTYSTU(NOL)/[M:PNH1]UOMSTUCOE(NOL)
  Call QTEARR(MAXQTYUOM,[M:PNH1]UOM(NOL)) From TRTDIV
  GMESSAGE=mess(106,194,1)-num$(MAXQTYUOM)-[M:PNH1]UOM(NOL)
  GERR=1 : mkstat=1 : End
Endif
#-----
[M:PNH1]QTYPUU(NOL)=QTEUA
[M:PNH1]QTYSTU(NOL)=QTEUS
Affzo [PNH1]QTYPUU(NOL), QTYSTU(NOL)
#----- Recherche tarif ? après modif qté -----#
[M:PNH1]QTYUOM(NOL)=VALEUR
If [M:PNH1]LINFLG(NOL)=1 & [M:PNH1]PTHNUM(NOL)=""
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),1,1) From TRTACHPRI1
  Endif
Elsif [M:PNH1]LINFLG(NOL)=0 & [M:PNH1]PTHNUM(NOL)=""
  Call INI_TARIF(NOL)
Else
  Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),1,1) From TRTACHPRI1
Endif
#-----
End


Subprog AS_UOMSTUCOE(VALEUR)
#--------------------------#
# Avant saisie coefficient #
#--------------------------#
Variable Decimal  VALEUR
If [F:ITM]SCSFLG=2 | [M:PNH1]UOM(nolign-1)=[M:PNH1]STU(nolign-1) | GMODIF<>2
  mkstat=2 : End
Endif
End


Subprog AM_UOMSTUCOE(VALEUR)
#---------------------------------#
# Après zone du coefficient UC-US #
#---------------------------------#
Variable Decimal  VALEUR
#-----
Local    Shortint NOL : NOL=nolign-1
Local    Decimal  WQTYPUU    : WQTYPUU   =[M:PNH1]QTYPUU(NOL)
Local    Decimal  WQTYSTU    : WQTYSTU   =[M:PNH1]QTYSTU(NOL)
Local    Decimal  WUOMSTUCOE : WUOMSTUCOE=[M:PNH1]UOMSTUCOE(NOL)
Local    Decimal  QTEUA, QTEUS
#----- Calcul qtée en US et en UA puis coefficient UC-UA -----#
QTEUS=[M:PNH1]QTYUOM(NOL)*VALEUR
Call QTEARR(QTEUS,[M:PNH1]STU(NOL)) From TRTDIV
Call PCAL_QTY(QTEUS,[M:PNH1]STU(NOL),QTEUA,[M:PNH1]PUU(NOL),
&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GBIDD1) From TRTACHQTE1
#----- Contrôle si qté supérieure au maxi -----#
If QTEUS>[M:PNH1]MAXQTYSTU(NOL)
  GMESSAGE=mess(106,194,1)-num$([M:PNH1]MAXQTYSTU(NOL))-[M:PNH1]STU
  GERR=1 : mkstat=1 : End
Endif
#-----
GCOEUOM=VALEUR
[M:PNH1]QTYPUU(NOL)   =QTEUA
[M:PNH1]QTYSTU(NOL)   =QTEUS
[M:PNH1]UOMPUUCOE(NOL)=arr(QTEUA/[M:PNH1]QTYUOM(NOL),0.000001)
Affzo [PNH1]QTYPUU(NOL), QTYSTU(NOL)
#----- Réjustement tarif si ligne issue d'une réception -----#
If [M:PNH1]PTHNUM(NOL)<>""
  If WUOMSTUCOE>max(WQTYPUU,WQTYSTU)
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),
&                       WUOMSTUCOE,VALEUR) From TRTACHPRI1
  Elsif WQTYSTU>WQTYPUU
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),
&                       WQTYSTU,[M:PNH1]QTYSTU(NOL)) From TRTACHPRI1
  Else
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),
&                       WQTYPUU,[M:PNH1]QTYPUU(NOL)) From TRTACHPRI1
  Endif
Endif
End


Subprog AS_PUU(VALEUR)
#----------------------------#
# Avant saisie unité d'achat #
#----------------------------#
Variable Char    VALEUR()
If [M:PNH1]UOMFLG(nolign-1)=1  mkstat=2 : End : Endif
End


Subprog AS_QTYSTU(VALEUR)
#---------------------------------------------#
# Avant saisie de la quantité retournée en US #
#---------------------------------------------#
Variable Decimal  VALEUR
If GMODIF<>2  mkstat=2 : End : Endif
End


Subprog AM_QTYSTU(VALEUR)
#---------------------------------------------------#
# Après modification de la quantité retournée en US #
#---------------------------------------------------#
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign-1
Local Decimal QTEUC, QTEUA, QTE
#----- Contrôle si qté supérieure au maxi -----#
If VALEUR>[M:PNH1]MAXQTYSTU(NOL)
  GMESSAGE=mess(106,194,1)-num$([M:PNH1]MAXQTYSTU(NOL))-[M:PNH1]STU(NOL)
  GERR=1 : mkstat=1 : End
Endif
#----- Calcul qté en UC puis UA -----#
QTEUC=VALEUR/[M:PNH1]UOMSTUCOE(NOL)
Call QTEARR(QTEUC,[M:PNH1]UOM(NOL)) From TRTDIV
QTEUA=QTEUC*[M:PNH1]UOMPUUCOE(NOL)
Call QTEARR(QTEUA,[M:PNH1]PUU(NOL)) From TRTDIV
#----- Quantité en unité de retour nulle ! -----#
If QTEUC=0
  GMESSAGE=mess(197,194,1) : GERR=1 : mkstat=1 : End
Endif
[M:PNH1]QTYUOM(NOL)=QTEUC
[M:PNH1]QTYPUU(NOL)=QTEUA
Affzo [PNH1]QTYUOM(NOL), QTYPUU(NOL)
#----- Recherche tarif ? après modif qté -----#
[M:PNH1]QTYSTU(NOL)=VALEUR
If [M:PNH1]LINFLG(NOL)=1 & [M:PNH1]PTHNUM(NOL)=""
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),1,1) From TRTACHPRI1
  Endif
Elsif [M:PNH1]LINFLG(NOL)=0 & [M:PNH1]PTHNUM(NOL)=""
  Call INI_TARIF(NOL)
Else
  Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),1,1) From TRTACHPRI1
Endif
End

Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
#--- Bug 87811
Local Integer J
If GWRHOBY=2
  VALEUR = [M:PNH1]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:PNH1]WRHE
Endif
#--- Bug 87811
# Si nouvelle ligne et du stock est déjà associé, pas d'accés au dépôt ligne
If [M:PNH1]CREFLG(nolign-1)=0
  If sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WSTOSEQ(J)=[M:PNH1]WSTOSEQ(nolign-1))>0
    mkstat=2
  Endif
Endif
#---
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

Subprog AM_SERNUM(VALEUR)
#--------------------------------------#
# Après modif du numéro de série début #
#--------------------------------------#
Variable Char    VALEUR()
#-----
Local    Integer NOL  : NOL=nolign-1
Local    Decimal WQTE
Local    Integer WRET
#-----
If VALEUR<>""
  WRET=0 : Gosub CHARG_ALLPAR
  Call CTLSORSER("PNH1",NOL,VALEUR,[M:PNH1]QTYSTU(NOL),
&                [M:PNH1]SERNUMF(NOL),WQTE) From STKSOR
  If WQTE=0  Raz VALEUR : Raz [M:PNH1]SERNUMF(NOL) : mkstat=1 : End : Endif : #--- Issue 110327 (raz VALEUR)
Else
  Raz [M:PNH1]SERNUMF(NOL)
Endif
End


Subprog AS_LINCAT(VALEUR)
#----------------------------------------------#
# Champ accessible uniquement en retour direct #
#----------------------------------------------#
Variable Integer VALEUR
# Issue 112754 - 2016-12-05 by SR : ligne directe et article service: Catégorie = "standard" non modifiable
#If [M:PNH1]PTHNUM(nolign-1)<>""
If [M:PNH1]PTHNUM(nolign-1)<>"" | [M:PNH1]ITMKND(nolign-1) = 3
  mkstat=2 : End
Endif
End


Subprog AM_LINCAT(VALEUR)
#-----------------------------------------------#
# Champ accessible uniquement en retour directe #
# Pas de valorisation si LINCAT=2               #
#-----------------------------------------------#
Variable Integer VALEUR
Local Shortint NOL : NOL=nolign-1
#----- Remise à zéro tarif ou initialisation tarif -----#
If [M:PNH1]PTHNUM(NOL)=""
  If VALEUR=2
    #----- Raz éléments ligne tarif -----#
    [M:PNH1]LINCAT(NOL)=VALEUR
    Call REAJUST_TARIF("PNH1",NOL,[M:PNH1]UOM(NOL),[M:PNH1]UOM(NOL),1,1) From TRTACHPRI1
  Elsif [M:PNH1]GROPRI(NOL)=0 & [M:PNH1]NETPRI(NOL)=0
    #----- Recherche tarif si ligne valorisée à zéro -----#
    Call INI_TARIF(NOL)
  Endif
Endif
#-----
End


Subprog AS_ORDFLG(VALEUR)
#--------------------------------------------------------#
# Avant saisie de l'indicateur réintégration en commande #
#--------------------------------------------------------#
Variable Integer VALEUR
Local Integer NOL : NOL=nolign-1
#----- Si retour sur réception sans commande, on ne réintègre pas -----#
If [M:PNH1]POHNUM(NOL)="" VALEUR=1 : mkstat=2 : End : Endif
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
#----------------------------------------------------------#
# Si commande d'origine introuvable on ne peut que :       #
#   - créer une nouvelle cde pour les commandes classiques #
#   - rien faire pour les commandes ouvertes               #
#----------------------------------------------------------#
If [F:POH]POHNUM<>[M:PNH1]POHNUM(NOL)
  Read [POH]POH0=[M:PNH1]POHNUM(NOL)
  If fstat Raz [F:POH] : Endif
Endif
Read [POQ] POQ0=[M:PNH1]POHNUM(NOL);[M:PNH1]POPLIN(NOL);[M:PNH1]POQSEQ(NOL)
If fstat
  GMENLOC(2)=1 : GMENLOC(3)=1
  If [M:PNH1]POQSEQ(NOL)<>1
    GMENLOC(4)=1 : VALEUR = 1
  Elsif VALEUR=2
    VALEUR = 4
  Endif
#----------------------------------------------------------------#
# Si commande d'origine est une cde ouverte, il est impossible : #
#   - de réintégrer sur la même ligne                            #
#   - ni sur autre commande                                      #
#----------------------------------------------------------------#
Elsif [F:POQ]POHTYP=2
  GMENLOC(2)=1 : GMENLOC(4)=1
  If VALEUR<>1  VALEUR=3 : Endif
#----------------------------------------------------------------#
# Si commande classique avec pendant vente, il est impossible :  #
#   - de réintégrer sur la même ligne                            #
#   - de réintégrer sur une autre ligne                          #
#----------------------------------------------------------------#
Elsif [F:POH]SALFCY<>"" & [F:POQ]LINOCNNUM<>"" & [F:POQ]OCNLIN<>0 & [F:POQ]OCNSEQ<>0
  GMENLOC(2)=1 : GMENLOC(3)=1
  If VALEUR<>1  VALEUR=4 : Endif
Endif
#----- Pas de réintégration en commande si sous-traitance -----#
If find([F:POQ]VCRTYPORI,10,36)  VALEUR=1 : mkstat=2 : End : Endif
End


Subprog AP_ORDFLG(VALEUR)
#-------------------------------------------------#
# Après zone indicateur réintégration en commande #
#-------------------------------------------------#
Variable Integer VALEUR
Raz GMENLOC
End

# Issue 113930 - 2016-01-22 by SR : Ajout de ligne interdit si contrat périme
######################################################################################
Subprog C_ORDFLG(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If VALEUR = 3
  Read [POH]POH0=[M:PNH1]POHNUM(NOL)
  If fstat Raz [F:POH] : Endif
 # Issue X3-38307 - 2017-06-08 by SR : Contrôler aussi la date de fin de l'article
 # If [F:POH]POHTYP = 2 & [F:POH]ENDDAT <  date$
  If [F:POH]POHTYP = 2
    If [F:POH]ENDDAT <  date$
      GMESSAGE = mess(236,194,1)
      mkstat = 1
      End
    Else
      Read [F:POC]POC0 = [M:PNH1]POHNUM(NOL);[M:PNH1]POPLIN(NOL)
      If fstat Raz [F:POC] : Endif
      If [F:POC]ENDDAT <  date$
        GMESSAGE = mess(236,194,1)
        mkstat = 1
        End
      Endif
    Endif
  Endif
Endif
End


Subprog AS_AVOFLG(VALEUR)
#------------------------------------------------#
# Avant saisie de l'indicateur "Attente d'avoir" #
#------------------------------------------------#
Variable Integer VALEUR
If [M:PNH1]BETFCY=2 & [M:PNH1]BETCPY<>2
  VALEUR=1 : mkstat=2
Endif
End


Subprog AS_POHFCY(VALEUR)
#----------------------------------#
# Avant saisie du site de commande #
#----------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
# Issue 107136 - 2015-03-26 by SR
Local Char    WPNHFCY(GLONFCY) : [L]WPNHFCY = [M:PNH1]PNHFCY
If [M:PNH1]POHNUM(NOL)<>""
  Read [POH] POH0=[M:PNH1]POHNUM(NOL) : If fstat  Raz [F:POH] : Endif
Else
  Raz [F:POH]
Endif
If [F:POH]POHFCY<>""
  VALEUR=[F:POH]POHFCY : [M:PNH1]POHFCY(NOL)=[F:POH]POHFCY : mkstat=2 : End
Endif
If VALEUR=""
  If GPNH_POHFCY=""  Gosub CHARG_POHFCY : Endif
  VALEUR=GPNH_POHFCY : [M:PNH1]POHFCY(NOL)=GPNH_POHFCY
Endif
If [M:PNH1]ORDFLG(NOL)=1 & [M:PNH1]BETCPY<>2  mkstat=2 : End : Endif
End

Subprog AM_PJT(VALEUR)
#------------------------------------#
# Après modification du code affaire #
#------------------------------------#
Variable Char    VALEUR()
Local   Shortint NOL : NOL=nolign-1
# Issue 71069 - 2016-05-13 by SR : PJT
#----- Recherche tarif ? -----#
[M:PNH1]PJT(NOL)=VALEUR

#----- Recherche tarif ? si retour direct -----#
If [M:PNH1]LINFLG(NOL)=1 & [M:PNH1]PTHNUM(NOL)=""
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Endif
Elsif [M:PNH1]LINFLG(NOL)=0 & [M:PNH1]PTHNUM(NOL)=""
  Call INI_TARIF(NOL)
Endif
End

Subprog IB_GROPRI
#-----------------------------------------------------------------------------------#
# Activation boutons "Tarifs", "Dernier prix", "Réinit.Prix", "Explication du prix" #
#-----------------------------------------------------------------------------------#
Raz GBOUT6 : # GBOUT2 est chargé par l'action SAIPURREN et géré par l'action INIREN
GBOUT1=mess(42,198,1) : GBOUT3=mess(24,198,1)
GBOUT4=mess(52,198,1) : GBOUT5=mess(386,198,1)
End


Subprog B4_GROPRI(VALEUR)
#------------------------#
# Bouton : "Réinit.Prix" #
#------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Call INI_TARIF(NOL)   : VALEUR=[M:PNH1]GROPRI(NOL)
mkstat=99
End


Subprog AP_GROPRI(VALEUR)
#-----------------------------------------------------------------#
# Après saisie du prix brut : Test si prix nul (sauf inter-sites) #
#-----------------------------------------------------------------#
Variable Decimal VALEUR
If VALEUR=0 & ([M:PNH1]BETFCY<>2 | [M:PNH1]BETCPY=2)
  Local Integer OK
  OK=2 : Call AVERTIR(mess(62,194,1),OK) From GESECRAN
  If OK=1  mkstat=1 : End : Endif
Endif
End


