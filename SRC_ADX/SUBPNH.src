Endif
Return


Subprog AM_WEU(VALEUR)
#---------------------------------#
# Après modif de l'unité de poids #
#---------------------------------#
Variable Char    VALEUR()
Local    Decimal QT2,COEF
Local    Integer NOL
NOL = nolign-1
# Conversion poids unitaire si modif unité poids
If VALEUR=""
   [M:PNH1]UNTWEI(NOL)=0
Elsif [M:PNH1]WEU(NOL)<>""
   Call CALCUL_QTY([M:PNH1]UNTWEI(NOL),[M:PNH1]WEU(NOL),QT2,VALEUR,COEF) From TRTX3
   [M:PNH1]UNTWEI(NOL)=QT2
Endif
If [M:PNHC]WEU=""  [M:PNHC]WEU=VALEUR : Endif
Affzo [PNH1]UNTWEI(NOL)
End


Subprog AS_UNTWEI(VALEUR)
#--------------------------------#
# Avant saisie du poids unitaire #
#--------------------------------#
Variable Decimal VALEUR
#----- Si pas d'unité de poids, pas de saisie de poids -----#
If [M:PNH1]WEU(nolign-1)=""  mkstat=2 : End : Endif
End


Subprog PASLINPNH(DISCRGNUM)
#--------------------------------------#
# Avant saisie des remises/frais tarif #
#--------------------------------------#
Value Integer DISCRGNUM
If [M:PNH1]PTHNUM(nolign-1)<>"" |
&  [M:PNH1]LINTYP(nolign-1)=2   |
&  GMODIF<>2
  mkstat=2 : End
Endif
If DISCRGNUM<1 | DISCRGNUM>9  End : Endif
If GCOLREM(DISCRGNUM-1)=""  mkstat=2 : End : Endif
End


Subprog INI_TARIF(NOL)
#-------------------------#
# Initialisation du tarif #
#-------------------------#
Value  Shortint NOL
If [M:PNH1]POHFCY(NOL)=""
  Call AS_POHFCY([M:PNH1]POHFCY(NOL)) : Raz mkstat
Endif
If [M:PNH1]LINFLG(NOL)<>2
  GPUU=[M:PNH1]PUU(NOL) : Call RECH_TARIF ("PNH",NOL) From TRTACHTAR1
Endif
[M:PNH1]LINAMT(NOL)=[M:PNH1]NETPRI(NOL)*[M:PNH1]QTYUOM(NOL)
Call ARRDEV([M:PNH1]LINAMT(NOL),[M:PNH1]NETCUR(NOL)) From TRTDIV
If !GIMPORT
  Affzo [PNH1]GROPRI(NOL)
  If GCOLREM(0)<>""  Affzo [PNH1]DISCRGVAL1(NOL) : Endif
  If GCOLREM(1)<>""  Affzo [PNH1]DISCRGVAL2(NOL) : Endif
  If GCOLREM(2)<>""  Affzo [PNH1]DISCRGVAL3(NOL) : Endif
  If GCOLREM(3)<>""  Affzo [PNH1]DISCRGVAL4(NOL) : Endif
  If GCOLREM(4)<>""  Affzo [PNH1]DISCRGVAL5(NOL) : Endif
  If GCOLREM(5)<>""  Affzo [PNH1]DISCRGVAL6(NOL) : Endif
  If GCOLREM(6)<>""  Affzo [PNH1]DISCRGVAL7(NOL) : Endif
  If GCOLREM(7)<>""  Affzo [PNH1]DISCRGVAL8(NOL) : Endif
  If GCOLREM(8)<>""  Affzo [PNH1]DISCRGVAL9(NOL) : Endif
  Affzo [PNH1]NETPRI(NOL), LINAMT(NOL)
Endif
If [M:PNH1]LINFLG(NOL)=2  [M:PNH1]LINFLG(NOL)=1 : Endif
End


$CHARG_ALLPAR
#-----------------------------------------------------------------------#
# Chargement du masque écran ALLPAR [ALP] pour composants sortie stock  #
# --------------------------------------------------------------------- #
# WRET : Indicateur pour chargement                                     #
#        0 = Création ligne retour                                      #
#        1 = Chargement pour màj des allocations (appelé depuis VALLIG) #
#        2 = Modification ligne retour                                  #
#-----------------------------------------------------------------------#
If dim([M:PNH1]LINCAT)>0 & [M:PNH1]LINCAT(NOL)= 2 : # GA 09/2006
   [M:ALP]TRSTYP = 32                : # Type mouvement (M.704): retour matière pour sous-traitance
   [M:ALP]PECOWNER = [M:PNH1]LINSTOFCY(NOL)  : # Site propriétaire du stock
Else
   [M:ALP]TRSTYP = 11
Endif
[M:ALP]TRSCOD    = [M:PNH1]TRSCOD
If WRET=0
  [M:ALP]VCRTYP    = 6
  [M:ALP]VCRNUM    = [M:PNH1]PTHNUM(NOL)
  [M:ALP]VCRLIN    = [M:PNH1]PTDLIN(NOL)
Elsif WRET=1
  [M:ALP]VCRTYP    = 8
  [M:ALP]VCRNUM    = [F:PND]PNHNUM
  [M:ALP]VCRLIN    = [F:PND]PNDLIN
Else
  [M:ALP]VCRTYP    = 8
  [M:ALP]VCRNUM    = [M:PNH1]PNHNUM
  [M:ALP]VCRLIN    = [M:PNH1]PNDLIN(NOL)
Endif
If WRET=1
  [M:ALP]VCRSEQ    = 0
  [M:ALP]STOFCY    = [F:PND]PNHFCY
  [M:ALP]ITMREF    = [F:PND]ITMREF
  [M:ALP]PCU       = [F:PND]UOM
  [M:ALP]PCUSTUCOE = [F:PND]UOMSTUCOE
  [M:ALP]QTY       = [F:PND]QTYSTU
  [M:ALP]TYPQTY    = 1
  [M:ALP]BESDAT    = [F:PND]RTNDAT
  [M:ALP]DLVDAT    = [F:PND]RTNDAT
  [M:ALP]ALLDAT    = [0/0/0]
  [M:ALP]STOLOC    = ""
  [M:ALP]PECINTLOC = 2
  [M:ALP]PECSCOLOC = 1
  [M:ALP]PECPLFLOC = 2
  [M:ALP]PECCUNLOK = 1
  [M:ALP]FILSTO    = ""
  [M:ALP]PECQLYCTL = 1
  [M:ALP]MVTDES    = [M:PNH1]MVTDES(NOL)
Else
  [M:ALP]VCRSEQ    = 0
  [M:ALP]STOFCY    = [M:PNH1]PNHFCY
  [M:ALP]ITMREF    = [M:PNH1]ITMREF(NOL)
  [M:ALP]PCU       = [M:PNH1]UOM(NOL)
  [M:ALP]PCUSTUCOE = [M:PNH1]UOMSTUCOE(NOL)
  [M:ALP]QTY       = [M:PNH1]QTYSTU(NOL)
  [M:ALP]TYPQTY    = 1
  [M:ALP]BESDAT    = [M:PNH1]RTNDAT
  [M:ALP]DLVDAT    = [M:PNH1]RTNDAT
  [M:ALP]ALLDAT    = [0/0/0]
  [M:ALP]STOLOC    = ""
  [M:ALP]PECINTLOC = 2
  [M:ALP]PECSCOLOC = 1
  [M:ALP]PECPLFLOC = 2
  [M:ALP]PECCUNLOK = 1
  [M:ALP]FILSTO    = ""
  [M:ALP]PECQLYCTL = 1
  [M:ALP]STA       = [M:PNH1]STA(NOL)
  [M:ALP]MVTDES    = [M:PNH1]MVTDES(NOL)
  If dim([M:PNH1]LOT)>0  [M:ALP]LOT = [M:PNH1]LOT(NOL) : Endif
  If dim([M:PNH1]LOC)>0  [M:ALP]LOC = [M:PNH1]LOC(NOL) : Endif
  If dim([M:PNH1]WRH)>0  [M:ALP]WRH = [M:PNH1]WRH(NOL) : Endif
Endif
Return


$CTRL_INTERSITE
#-------------------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites         #
# ------------------------------------------------------------#
# WBPSNUM     : Fournisseur                                   #
# WORI        : Origine de l'appel (1=PNHFCY, 2=BPSNUM)       #
# ----------------------------------------------------------- #
# GPNH_POHFCY : Site de commande par défaut                   #
#-------------------------------------------------------------#
Gosub CHARG_POHFCY
Local Char  WSALFCY(GLONFCY), WSTOFCY(GLONFCY), WINVFCY(GLONFCY)
Local Char  WBPCORD(GLONBPC), WBPCINV(GLONBPC)
GRCPFCY=GFCY
Call CTRL_INTERSITE(GPNH_POHFCY,WBPSNUM,2,[M:PNH1]BETFCY,[M:PNH1]BETCPY,[L]WSALFCY,
&                  [L]WSTOFCY,[L]WBPCORD,[L]WINVFCY,[L]WBPCINV,GBIDI3) From TRTACHCTL1
If mkstat  GERR=1 : Return : Endif
#----- Le site d'expédition n'a pas été trouvé -----#
If [L]WSTOFCY=""
  If [M:PNH1]BETCPY<>2
    Filter [FCY] Where LEGCPY=GSOCIETE & WRHFLG=2 & FCY<>GFCY
  Else
    Filter [FCY] Where LEGCPY=GCPY     & WRHFLG=2 & FCY<>GFCY
  Endif
  Read [FCY] FCY1 First
  If !fstat  [L]WSTOFCY=[F:FCY]FCY  Else  Raz [F:FCY] : Endif
  Filter [FCY]
  GSTOFCY=[L]WSTOFCY
Endif
#----- Récupération du code compteur (normal ou inter-sites) -----#
If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] : Endif
If [F:TCA]MODULE<>6 | [F:TCA]CPY<>GSOCIETE
  If dim(OK)<1  Local Integer OK : Endif
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK  GERR=1 : GMESSAGE=mess(64,199,1) : mkstat=1 : Return : Endif
Endif
If [M:PNH1]BETFCY<>2 | [M:PNH1]BETCPY=2
  GMANCOU=[F:TCA]MANCOU(6)  : GCODNUM=[F:TCA]CODNUM(6)
Else
  GMANCOU=[F:TCA]MANCOU(13) : GCODNUM=[F:TCA]CODNUM(13)
Endif
# Issue 107136 - 2015-03-26 by SR
If !GIMPORT : Affzo [PNH1]BETFCY, BETCPY : Endif
Return


$CHARG_POHFCY
#-------------------------------------------#
# Chargement du site de commande par défaut #
#-------------------------------------------#
Raz GPNH_POHFCY
#----- (1) Recherche site associé au client (client livré associé au site retour) -----#
# Issue 101566 - 2015-01-13 by SR :le client livré(=site d'achat) doit être différent
# du fournisseur(si renseigné)
# Issue 107136 - 2015-03-26 by SR : Utiliser WPNHFCY
If dim(WBPSNUM)>0
   Filter [BPD] Where RCPFCY=WPNHFCY & ENAFLG=2 & BPCNUM <> WBPSNUM
Else
   Filter [BPD] Where RCPFCY=WPNHFCY & ENAFLG=2
Endif
# End issue 101566
Read [BPD] BPD1 First
If !fstat
  Read [BPR] BPR0=[F:BPD]BPCNUM
  If !fstat & [F:BPR]FCY<>""
    Read [FCY] FCY0=[F:BPR]FCY
    If !fstat & [F:FCY]LEGCPY=GSOCIETE & [F:FCY]PURFLG=2
      GPNH_POHFCY=[F:FCY]FCY
    Endif
  Endif
Endif
Filter [BPD]
#----- (2) Site de retour si celui-ci est site d'achat -----#
If GPNH_POHFCY=""
  # Issue 107136 - 2015-03-26 by SR : Utiliser WPNHFCY
  Read [FCY] FCY0=WPNHFCY : If fstat  Raz [F:FCY] : Endif
  If [F:FCY]PURFLG=2
    GPNH_POHFCY=WPNHFCY
  #----- (3) Site d'achat de l'utilisateur si appartient à la même société -----#
  Elsif GFCYDEF(6)<>""
    Read [FCY] FCY0=GFCYDEF(6) : If fstat  Raz [F:FCY] : Endif
    If [F:FCY]LEGCPY=GSOCIETE & [F:FCY]PURFLG=2
      GPNH_POHFCY=GFCYDEF(6)
    Endif
  Endif
Endif
#----- (4) 1er site d'achat appartenant à la même société -----#
If GPNH_POHFCY=""
  Filter [FCY] Where LEGCPY=GSOCIETE & PURFLG=2
  Read [FCY] FCY1 First
  Filter [FCY]
  If fstat
    Raz [F:FCY]
  Else
    GPNH_POHFCY=[F:FCY]FCY
  Endif
Endif
Return


$AFFICH_LINACC
#------------------------------------------#
# Affichage des comptes de la ligne retour #
#------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBCOA
  Case I
    When  1 : Affzo [PNH1]LINACC1 (NOL)
    When  2 : Affzo [PNH1]LINACC2 (NOL)
    When  3 : Affzo [PNH1]LINACC3 (NOL)
    When  4 : Affzo [PNH1]LINACC4 (NOL)
    When  5 : Affzo [PNH1]LINACC5 (NOL)
    When  6 : Affzo [PNH1]LINACC6 (NOL)
    When  7 : Affzo [PNH1]LINACC7 (NOL)
    When  8 : Affzo [PNH1]LINACC8 (NOL)
    When  9 : Affzo [PNH1]LINACC9 (NOL)
    When 10 : Affzo [PNH1]LINACC10(NOL)
  Endcase
Next I
Return


$AFFICH_CCE
#-------------------------------------------------------#
# Affichage des sections analytiques de la ligne retour #
#-------------------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  Case I
    When  1 : Affzo [PNH1]CCE1 (NOL)
    When  2 : Affzo [PNH1]CCE2 (NOL)
    When  3 : Affzo [PNH1]CCE3 (NOL)
    When  4 : Affzo [PNH1]CCE4 (NOL)
    When  5 : Affzo [PNH1]CCE5 (NOL)
    When  6 : Affzo [PNH1]CCE6 (NOL)
    When  7 : Affzo [PNH1]CCE7 (NOL)
    When  8 : Affzo [PNH1]CCE8 (NOL)
    When  9 : Affzo [PNH1]CCE9 (NOL)
    When 10 : Affzo [PNH1]CCE10(NOL)
    When 11 : Affzo [PNH1]CCE11(NOL)
    When 12 : Affzo [PNH1]CCE12(NOL)
    When 13 : Affzo [PNH1]CCE13(NOL)
    When 14 : Affzo [PNH1]CCE14(NOL)
    When 15 : Affzo [PNH1]CCE16(NOL)
    When 16 : Affzo [PNH1]CCE17(NOL)
    When 17 : Affzo [PNH1]CCE17(NOL)
    When 18 : Affzo [PNH1]CCE18(NOL)
    When 19 : Affzo [PNH1]CCE19(NOL)
    When 20 : Affzo [PNH1]CCE20(NOL)
  Endcase
Next I
Return


#----------------------------------------------------#
# Màj totaux poids brut et net de l'écran complément #
# -------------------------------------------------- #
# NOL    = Numéro de la ligne en cours               #
# SENS   = Sens de la mise à jour (+1 ou -1)         #
#----------------------------------------------------#
$MAJ_TOTWEI
If [M:PNH1]ITMREF(NOL)="" | [M:PNH1]LINTYP(NOL)>2  Return : Endif
Local Decimal  WUNTWEI
#----- Calcul poids brut et net -----#
If [M:PNH1]WEU(NOL)<>[M:PNHC]WEU
  If [F:TCO]UOM1<>[M:PNH1]WEU(NOL) | [F:TCO]UOM2<>[M:PNHC]WEU
    Read [TCO] TCO0=[M:PNH1]WEU(NOL);[M:PNHC]WEU
    If fstat
      Read [TCO] TCO0=[M:PNHC]WEU;[M:PNH1]WEU(NOL)
      If fstat
        Raz [F:TCO] : [F:TCO]COEUOM=1
      Endif
    Endif
  Endif
  WUNTWEI=[M:PNH1]UNTWEI(NOL)*[M:PNH1]QTYUOM(NOL)*[F:TCO]COEUOM
Else
  WUNTWEI=[M:PNH1]UNTWEI(NOL)*[M:PNH1]QTYUOM(NOL)
Endif
Call QTEARR (WUNTWEI,[M:PNHC]WEU) From TRTDIV
[M:PNHC]TOTNETWEI+=WUNTWEI*SENS
[M:PNHC]TOTGROWEI+=WUNTWEI*SENS
Return
######################################################################################
######################################################################################
# ---------------------------------- #
# Get the purchase return counter    #
# ---------------------------------- #
$REC_CPT_PNH
#85785
If !clalev([F:TPN]) : Local File TABPNHTYP [TPN] : Endif

Local Integer WDKS       : [L]WDKS       = 0

WDKS = func AFNC.ACTIV("DKS")
Raz GCPT, GMANCOU#, GCPTCOMP#, GCPTENDNBR
If func AFNC.ACTIV("TRSNE") > 0
  If [M:PNH1]PNHTYP<>""
    # 1º the return type
    Local Integer WERR
    Call LEC_TPN_LEG(GCURLEG,[M:PNH1]PNHTYP,WERR) From TRTLECLEG
    If WERR : Raz [F:TPN] : Endif #Call RSTA("TPN", [M:PNH1]PNHTYP) From GLOCK
    #--Counter initialization
    If [F:TPN]PNHTYP<>""
      If    [M:PNH1]BETFCY=2 & [M:PNH1]BETCPY=1       :#-- Return Inter-sites
        GCPT=[F:TPN]CODNUMFCY
        #If WDKS
        #  GCPTCOMP   = [F:TPN]CODNUMCPT
        #Endif
      Elsif [M:PNH1]BETCPY=2                          :#-- Return Inter-sociétés
        GCPT=[F:TPN]CODNUMCPY
        #If WDKS
        #  GCPTCOMP   = [F:TPN]CODNUMCPT
        #Endif
      Else                                            :#-- Return normal
        GCPT=[F:TPN]CODNUM
        #If WDKS
        #  GCPTCOMP   = [F:TPN]CODNUMCPT
        #Endif
      Endif
      GMANCOU=[F:TPN]MANCOU
    Endif
  Endif
Endif

Local Integer WOK
If clalev ([F:TCA]) <= 0 Local File TABCOUAFF [TCA] Endif
Call LECTCA(6,WOK) From SUBTCA
If fstat | !WOK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1) : Return
Endif

If GCPT=""
  If [M:PNH1]BETFCY=2 | [M:PNH1]BETCPY=2
    GMANCOU=[F:TCA]MANCOU(13)  : GCPT=[F:TCA]CODNUM(13)   # Inter-site\Inter-company
  Else
    GMANCOU=[F:TCA]MANCOU(6)  : GCPT=[F:TCA]CODNUM(6)     # Normal
  Endif
Endif

Return

