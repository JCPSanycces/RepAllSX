#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTINCS201810002
# Issue X3-112819 - 2018-10-16 by STWIL : delete obsolete representations for NCS
###################################################################################################
Local Char DOSSIER(30)

    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
        If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
        Read [ADS]DOSSIER=[L]DOSSIER
        If fstat Then
            Raz [F:ADS]
        Endif
        Call TEMPON("O") From GESECRAN
        Call OUVRE_TRACE("Deletion of obsolete representations for NCS") From LECFIC
        # -------------------------
        Call MAJ_UTINCS201810002(DOSSIER)
        # -------------------------
        Call TEMPOFF From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
End

##########################################################################
Subprog MAJ_UTINCS201810002(DOSSIER)
Value Char DOSSIER

    Local File =DOSSIER + ".ASHWFLD" [ASWF]
    Local File =DOSSIER + ".ASHWPAR" [ASWP]
    Local File =DOSSIER + ".ASHWMENU" [ASWMN]
    Local File =DOSSIER + ".ASHWMET" [ASWM]
    Local File =DOSSIER + ".ASHWPARMET" [ASWMP]
    Local File =DOSSIER + ".ASHWOPT" [ASWO]
    Local File =DOSSIER + ".ASHWCOL" [ASWC]
    Local File =DOSSIER + ".ASHWSEC" [ASWS]
    Local File =DOSSIER + ".ASHWBLC" [ASWB]
    Local File =DOSSIER + ".ASHWEXPPRO" [ASWR]
    Local File =DOSSIER + ".ASHWLNK" [ASWK]
    Local File =DOSSIER + ".ASHW" [ASWH]

    Local Char REPNAME(20)(30)
    Local Char CODE(20)
    Local Integer IERR
    Local Integer COMPTEUR
    IERR = 0
    COMPTEUR = 0

    Call ECR_TRACE("MAJ_UTINCS201810002: Process Start on : "+DOSSIER,0) From GESECRAN

    REPNAME(0) = "NCSAUSAPP"
    REPNAME(1) = "NCSAUSPLA"
    REPNAME(2) = "NCSAUSQA"
    REPNAME(3) = "NCSIMPBOH"
    REPNAME(4) = "NCSIMPFOH"
    REPNAME(5) = "NCSIMPITM"
    REPNAME(6) = "NCSIMPMFGH"
    REPNAME(7) = "NCSIMPPOH"
    REPNAME(8) = "NCSIMPPRH"
    REPNAME(9) = "NCSIMPROH"
    REPNAME(10) = "NCSIMPSCH"
    REPNAME(11) = "NCSIMPSOH"
    REPNAME(12) = "NCSIMPSQH"
    REPNAME(13) = "NCSPLABOH"
    REPNAME(14) = "NCSPLAFOH"
    REPNAME(15) = "NCSPLAITM"
    REPNAME(16) = "NCSPLAMFGH"
    REPNAME(17) = "NCSPLANH"
    REPNAME(18) = "NCSPLAPOH"
    REPNAME(19) = "NCSPLAPRH"
    REPNAME(20) = "NCSPLAROH"
    REPNAME(21) = "NCSPLASCH"
    REPNAME(22) = "NCSPLASOH"
    REPNAME(23) = "NCSPLASQH"
    REPNAME(24) = "NCSRECENT"
    REPNAME(25) = "NCSRECENTIA"

    Trbegin [ASWH]
    # Delete obsolete representations for NCS
    For I = 0 To 25
        Read [ASWH]ASW0=REPNAME(I)
        If fstat = 0
            [L]COMPTEUR += 1
            Call ECR_TRACE("MAJ_UTINCS201810002: Deleting representation - " + REPNAME(I), 0) From GESECRAN
            Delete [ASWF] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWF",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWP] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWP",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWMN] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWMN",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWM] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWM",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWMP] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWMP",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWO] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWO",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWC] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWC",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWS] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWS",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWB] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWB",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWR] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWR",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWK] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWK",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ASWH] Where CODREP=REPNAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ASWH",REPNAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
        Endif
    Next I

    If [L]IERR = 0 Then
        Commit
        Call ECR_TRACE("MAJ_UTINCS201810002 :" - num$([L]COMPTEUR) - "records processed",0) From GESECRAN
    Else
        Rollback
        Call ECR_TRACE("MAJ_UTINCS201810002 :" - num$([L]COMPTEUR) - "records processed with error(s).", 0) From GESECRAN
    Endif

    Call ECR_TRACE("MAJ_UTINCS201810002: Process End", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810002(DOSSIER)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810002(DOSSIER)

End

