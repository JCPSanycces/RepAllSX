#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################################
# Recherche collaborateur disponibles                                      Module CRM              1 mars 2010 #
################################################################################################################
###############################################################################
$ACTION
  Case ACTION
    When "DEBUT"        : Gosub DEBUT
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

###############################################################################
$DEBUT
Local Integer IAOB
Local Char SORIVCR(GLONVCR)
Local Integer IORIVCRL
Local Char SZBPL(GLONVCR)
Local Integer NI

  # PARAM(1) : Site
  # PARAM(2) : Date début
  # PARAM(3) : Heure début
  # PARAM(4) : Date fin
  # PARAM(5) : Heure fin
  # PARAM(6) : Objet d'origine
  # PARAM(7) : Référence d'origine
  # PARAM(8) : Ligne d'origine
  # Issue X3-72085 - 2018-04-06 by FGR : BEGIN
  #  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  #  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  #  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  #  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  #  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  Local File FAMPBREP [PBR]
  Local File INTERVEN [ITN]
  Local File SERREQUEST [SRE]
  Local File BAPPOINT [BAP]
  Local File AUTILIS [AUS]
  # Issue X3-72085 - 2018-04-06 by FGR : END
  #
  [M:ITNG]SALFCY = PARAM(1)
  [M:ITNG]DATDEB = PARAM(2)
  [M:ITNG]HOUDEB = PARAM(3)
  [M:ITNG]DATEND = PARAM(4)
  [M:ITNG]HOUEND = PARAM(5)
  IAOB = val(PARAM(6))
  SORIVCR = PARAM(7)
  IORIVCRL = val(PARAM(8))
  Affzo [M:ITNG]5
  # Regarder s'il y a des compétents pour éventuellement griser TYPCOL."Compétents"
  If IAOB = 4 Then
    Read [SRE]SRE0=SORIVCR
    If fstat Then
      [M:ITNG]TYPCOL = 1
      Affzo [M:ITNG]TYPCOL
      Diszo [M:ITNG]TYPCOL
    Else
      SZPBL = [F:SRE]SREPBLGRP
      I = 0
      Filter [PBR] Where [F:PBR]GRPPBLNUM = SZPBL and [F:PBR]STTFLG = 0
      For [PBR]
        I += 1
        Break
      Next
      Filter [PBR]
      If I = 0 Then
        [M:ITNG]TYPCOL = 1
        Affzo [M:ITNG]TYPCOL
        Diszo [M:ITNG]TYPCOL
      Else
        [M:ITNG]TYPCOL = 2
        Affzo [M:ITNG]TYPCOL
        Actzo [M:ITNG]TYPCOL
      Endif
    Endif
  Else
    [M:ITNG]TYPCOL = 1
    Affzo [M:ITNG]TYPCOL
    Diszo [M:ITNG]TYPCOL
  Endif
  # Issue X3-72085 - 2018-04-06 by FGR : BEGIN
  # Bidouille pour avoir une largeur sur la colonne "Nom" du graphique
  #  Effzo [M:ITNG]10
  #  NI = 1
  #  [M:ITNG]AUSNUM(0) = space$(GLONAUS)                        # Code collaborateur
  #  [M:ITNG]AUSNAM(0) = [M:ITNG]AUSNUM(0) - space$(GLONDES)    # Nom      # Issue X3-72085 - 2018-04-06 by FGR
  #  Call AFFICHE_LIGNE (NI, "", date$, "0800", date$, "1800", 3, "", "")
  #  [M:ITNG]NBLIGC = NI
  #  Affzo [M:ITNG]10
  # Issue X3-72085 - 2018-04-06 by FGR : END
  # ------------------------
  Gosub ONLOAD
  # ------------------------
Return

###############################################################################
$TABLEAU_VIDE
  Effzo [M:ITNG]10
  I = 1
  [M:ITNG]AUSNUM(0) = space$(GLONAUS)                        # Code collaborateur
  [M:ITNG]AUSNAM(0) = [M:ITNG]AUSNUM(0) - mess(669,177,1)    # Nom    # Issue X3-72085 - 2018-04-06 by FGR
  Call AFFICHE_LIGNE (I, "", date$, "0800", date$, "1800", 3, "", "")
  [M:ITNG]NBLIGC = I
  Affzo [M:ITNG]10
Return

###############################################################################
$BOUTON
Local Integer ILIGNE
Local Integer I

  Case BOUT
    When "A"
      ILIGNE = nolign-1
      If (ILIGNE) >= 0 Then
        If [M:ITNG]AUSNUM(ILIGNE) <> "" Then
          For I = ILIGNE To [M:ITNG]NBLIGC
            If [M:ITNG]AUSNUM(I) <> [M:ITNG]AUSNUM(ILIGNE) Then
              ILIGNE = -1
              Break
            Endif
            If [M:ITNG]TYPTPS(I) = 2 Then
              ILIGNE = I
              Break
            Endif
          Next
          If ILIGNE <> -1 Then
            VALEUR = [M:ITNG]AUSNUM(ILIGNE)
            PARAM(2) = [M:ITNG]DATDEB
            PARAM(3) = [M:ITNG]HOUDEB
            PARAM(4) = [M:ITNG]DATEND
            PARAM(5) = [M:ITNG]HOUEND
            FIN = 1
          Else
            GMESSAGE = mess(127,184,1)
            FIN = 0
            GERR = 1
          Endif
        Else
          GMESSAGE = mess(127,184,1)
          FIN = 0
          GERR = 1
        Endif
      Endif
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

###############################################################################
$ONLOAD
Local Integer IRESUSED
Local Integer NBLIGRES
Local Integer ILIGHEAD
Local Integer IFIRST
Local Integer ICODRES
Local Char SZHDKREP(GLONREP)
Local Integer IHDKREP
Local Integer IHDKCOMP
Local Char SZLSTEVT(50)(1000)
Local Integer ILSTEVT
Local Date DDEBUT
Local Char SHDEBUT(GLONHM)
Local Date DFIN
Local Char SHFIN(GLONHM)
Local Char STYPE(1)
Local Char SCHRONO(GLONVCR)
Local Integer NI
Local Char SLANGUE(GLONDES)

  NBLIGRES = 0
  Effzo [M:ITNG]10
  For [AUS]CODUSR
    Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
    If SZHDKREP = "" Then
      IHDKREP = 1
    Else
      IHDKREP = val(SZHDKREP)
    Endif
    If IHDKREP = 2 Then
      # On ne retient que ceux faisant parti du "Support client"
      If [M:ITNG]TYPCOL = 2 Then
        # On recherche que parmi ceux compétents
        IHDKCOMP = 0
        Filter [PBR] Where [F:PBR]GRPPBLNUM = SZPBL and [F:PBR]STTFLG = 0 and [F:PBR]REPNUM = [F:AUS]USR
        For [PBR]
          IHDKCOMP = 1
          Break
        Next
        Filter [PBR]
      Else
        # On prend tout le monde
        IHDKCOMP = 1
      Endif
      #
      If NBLIGRES < dim([M:ITNG]AUSNUM) Then     # Issue X3-72085 - 2018-04-06 by FGR
        If IHDKCOMP = 1 Then
          Raz SZLSTEVT
          ILSTEVT = 0
          Raz SZHDKREP
          Call PARAMUTIL("AUSCRMF", SZHDKREP, [F:AUS]USR, "") From SUBAUS
          # Si SZHDKREP <> "" on regardera aussi dans les rendez-vous (BAP)
          #
          [M:ITNG]AUSNUM(NBLIGRES) = [F:AUS]USR                                                                   # Clé
          Call LECTEXTRA([M:ITNG]AUSNAM(NBLIGRES),"AUTILIS","INTUSR",[M:ITNG]AUSNUM(NBLIGRES),"") From ATEXTRA    # Nom
          # Issue X3-72085 - 2018-04-06 by FGR : BEGIN
          If [M:ITNG]AUSNAM(NBLIGRES) = "" Then
            Call LECTEXTRA(SLANGUE, "TABLAN", "INTSHO", GLANGUE, "") From ATEXTRA
            [M:ITNG]AUSNAM(NBLIGRES) = [M:ITNG]AUSNUM(NBLIGRES) - func AFNC.MES1(mess(1203,196,1), SLANGUE)
          Else
            [M:ITNG]AUSNAM(NBLIGRES) = [M:ITNG]AUSNUM(NBLIGRES) - [M:ITNG]AUSNAM(NBLIGRES)
          Endif
          # Issue X3-72085 - 2018-04-06 by FGR : END
          ILIGHEAD = NBLIGRES
          NBLIGRES += 1
          #
          IRESUSED = 0
          IFIRST = 1
          Filter [ITN] Where [F:ITN]REP = [F:AUS]USR and [F:ITN]DON <> 2 and [F:ITN]DAT <= [M:ITNG]DATEND and [F:ITN]DATEND >= [M:ITNG]DATDEB Order By [F:ITN]DATEND; [F:ITN]HOU
          For [ITN]
            IRESUSED = 1
            #--------------------------------------------------------------
            # Traiter cas "Journée entière" cochée
            If [F:ITN]FULDAY = 2 Then
              [F:ITN]HOU = "0800"
              [F:ITN]HOUEND = "1800"
            Endif
            #
            If ILSTEVT < dim(SZLSTEVT) Then
              SZLSTEVT(ILSTEVT) = func TRTCRMAPS.RENDMEMO([F:ITN]DAT, [F:ITN]HOU, [F:ITN]DATEND, [F:ITN]HOUEND, "5", [F:ITN]NUM)
              ILSTEVT += 1
            Endif
          Next
          Filter [ITN]
          #
          If SZHDKREP <> "" Then
            # Ici regarder les rendez-vous
            Filter [BAP] Where ([F:BAP]ATPREPMNA = [F:AUS]USR or find([F:AUS]USR, [F:BAP]APTREPNUM(0..dim([F:BAP]APTREPNUM)-1)) <> 0)
&                          and [F:BAP]APTDON <> 2 and [F:BAP]APTDAT <= [M:ITNG]DATEND and [F:BAP]APTDATEND >= [M:ITNG]DATDEB
&                     Order By [F:BAP]APTDAT; [F:BAP]APTHOU
            For [BAP]
              IRESUSED = 1
              #--------------------------------------------------------------
              # Traiter cas "Journée entière" cochée
              If [F:BAP]FULDAY = 2 Then
                #[F:BAP]HOU = "0800"
                #[F:BAP]HOUEND = "1800"
                [F:BAP]APTHOU = "0800"          # FGR 23/08/2010 : X3SUIVI66826
                [F:BAP]APTHOUEND = "1800"       # FGR 23/08/2010 : X3SUIVI66826
              Endif
              #
              If ILSTEVT < dim(SZLSTEVT) Then
                SZLSTEVT(ILSTEVT) = func TRTCRMAPS.RENDMEMO([F:BAP]APTDAT, [F:BAP]APTHOU, [F:BAP]APTDATEND, [F:BAP]APTHOUEND, "3", [F:BAP]APTNUM)
                ILSTEVT += 1
              Endif
            Next
            Filter [BAP]
          Endif
          #
          If IRESUSED = 1 Then
            #--------------------------------------------------------------
            Sorta ILSTEVT SZLSTEVT
            For NI = 0 To ILSTEVT-1
              Call DECOUPEMEMO(SZLSTEVT(NI), DDEBUT, SHDEBUT, DFIN, SHFIN, STYPE, SCHRONO) From TRTCRMAPS
              If STYPE = "3" Then
                # Rendez-vous
                Read [BAP]APP0=SCHRONO
                [F:BAP]APTDAT = DDEBUT
                [F:BAP]APTHOU = SHDEBUT
                [F:BAP]APTDATEND = DFIN
                [F:BAP]APTHOUEND = SHFIN
                ICODRES = 5 # Occupé ailleurs en Rendez-vous
                Call AFFICHE_OCCUPATION(NBLIGRES, IFIRST, [F:AUS]USR, [F:BAP]APTDAT, [F:BAP]APTHOU, [F:BAP]APTDATEND, [F:BAP]APTHOUEND, ICODRES, "BAP", [F:BAP]APTNUM)
              Elsif STYPE = "5" Then
                # Intervention
                Read [ITN]ITN0=SCHRONO
                [F:ITN]DAT = DDEBUT
                [F:ITN]HOU = SHDEBUT
                [F:ITN]DATEND = DFIN
                [F:ITN]HOUEND = SHFIN
                If IAOB = 4 and [F:ITN]SRVDEMNUM = SORIVCR Then
                  ICODRES = 4 # Occupé sur une intervention sur même SRE
                Else
                  ICODRES = 6 # Occupé ailleurs sur une autre intervention
                Endif
                Call AFFICHE_OCCUPATION(NBLIGRES, IFIRST, [F:AUS]USR, [F:ITN]DAT, [F:ITN]HOU, [F:ITN]DATEND, [F:ITN]HOUEND, ICODRES, "ITN", [F:ITN]NUM)
              Endif
            Next NI
            #--------------------------------------------------------------
            # Si la ressource n'est pas utilisée jusqu'en fin de journée, on note libre la fin de journée
            If [M:ITNG]WDATEND(NBLIGRES-1) <= [M:ITNG]DATEND and [M:ITNG]WHOUEND(NBLIGRES-1) < "1800" Then
              If [M:ITNG]SENDDAT(NBLIGRES-1) <= [M:ITNG]DATDEB + [M:ITNG]HOUDEB and [M:ITNG]DATEND + [M:ITNG]HOUEND < [M:ITNG]DATEND + "1800" Then
                If [M:ITNG]SENDDAT(NBLIGRES-1) < [M:ITNG]DATDEB + [M:ITNG]HOUDEB Then
                  Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]WDATEND(NBLIGRES-1), [M:ITNG]WHOUEND(NBLIGRES-1), [M:ITNG]DATDEB, [M:ITNG]HOUDEB, 1, "", "")
                Endif
                Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]DATDEB, [M:ITNG]HOUDEB, [M:ITNG]DATEND, [M:ITNG]HOUEND, 2, "", "")
                If [M:ITNG]DATEND + [M:ITNG]HOUEND < [M:ITNG]DATEND + "1800" Then
                  Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]WDATEND(NBLIGRES-1), [M:ITNG]WHOUEND(NBLIGRES-1), [M:ITNG]DATEND, "1800", 1, "", "")
                Endif
              Else
                # Il n'y a pas la place du besoin
                Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]WDATEND(NBLIGRES-1), [M:ITNG]WHOUEND(NBLIGRES-1), [M:ITNG]DATEND, "1800", 1, "", "")
              Endif
            Endif
            #--------------------------------------------------------------
            If [M:ITNG]DISCOL = 2 Then
              # ILIGHEAD : Première ligne pour le collaborateur
              # NBLIGRES : Dernière ligne pour le collaborateur
              Call GARDE_SI_DISPO (NBLIGRES, ILIGHEAD)
            Endif
            #--------------------------------------------------------------
          Else
            #--------------------------------------------------------------
            # Si la ressources n'est pas utilisé... c'est qu'elle est libre
            If [M:ITNG]HOUDEB > "0800" Then
              Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]DATDEB, "0800", [M:ITNG]DATDEB, [M:ITNG]HOUDEB, 1, "", "")
            Endif
            Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]DATDEB, [M:ITNG]HOUDEB, [M:ITNG]DATEND, [M:ITNG]HOUEND, 2, "", "")
            If [M:ITNG]HOUEND < "1800" Then
              Call AFFICHE_LIGNE (NBLIGRES, [F:AUS]USR, [M:ITNG]DATEND, [M:ITNG]HOUEND, [M:ITNG]DATEND, "1800", 1, "", "")
            Endif
            #--------------------------------------------------------------
          Endif
        Endif
      Endif
    Endif
  Next
  #
  [M:ITNG]NBLIGC = NBLIGRES
  # FGR 11/02/2013 : X3SUIVI87829 (début)
  If [M:ITNG]NBLIGC = 0 Then
    Gosub TABLEAU_VIDE
  Endif
  # FGR 11/02/2013 : X3SUIVI87829 (fin)
  Affzo [M:ITNG]10
Return

###############################################################################
Subprog GARDE_SI_DISPO (ILIGRES, ILIGHEAD)
Variable Integer ILIGRES
Value Integer ILIGHEAD

Local Integer NI
Local Integer NTROUVE

  NTROUVE = -1
  # 1) on regarde s'il y a une proposition (TYPTPS=2)
  For NI = ILIGHEAD To ILIGRES-1
    #If [M:ITNG]TYPTPS = 2 Then        # Issue X3-72085 - 2018-04-06 by FGR
    If [M:ITNG]TYPTPS(NI) = 2 Then     # Issue X3-72085 - 2018-04-06 by FGR
      NTROUVE = NI
      Break
    Endif
  Next
  # 2) S'il y en a on garde tout
  If NTROUVE = -1 Then
    # 3) s'il n'y en n'a pas on supprime le collaborateur du tableau
    For NI = ILIGHEAD To ILIGRES-1
      Raz [M:ITNG]AUSNUM(NI)
      Raz [M:ITNG]INTDAT(NI)
      Raz [M:ITNG]SENDDAT(NI)
      Raz [M:ITNG]LTIAFF(NI)
      Raz [M:ITNG]TYPTPS(NI)
      Raz [M:ITNG]LTI(NI)
      Raz [M:ITNG]WDATDEB(NI)
      Raz [M:ITNG]WDATEND(NI)
      Raz [M:ITNG]WHOUDEB(NI)
      Raz [M:ITNG]WHOUEND(NI)
      Raz [M:ITNG]WAOB(NI)
      Raz [M:ITNG]WOBJVCR(NI)
    Next
    ILIGRES = ILIGHEAD
  Endif
End

###############################################################################
Subprog AFFICHE_OCCUPATION(ILIGRES, IFIRST, SNUM, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ICODRES, SAOB, SOBJVCR)
Variable Integer ILIGRES
Variable Integer IFIRST
Value Char SNUM
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND
Value Integer ICODRES
Value Char SAOB
Value Char SOBJVCR

  If IFIRST = 1 Then
    # Pour la première fois on regarde si ça commence au début
    If DDATEDEB >= [M:ITNG]DATDEB Then
      If SHOUDEB > "0800" Then
        # Si ça ne commence pas en début de journée, on note libre le début
        Call AFFICHE_LIGNE (ILIGRES, SNUM, [M:ITNG]DATDEB, "0800", DDATEDEB, SHOUDEB, 1, "", "")
      Endif
    Endif
    IFIRST = 0
  Else
    # pour les suivantes on regarde si la réservation qui arrive est consécutive. Sinon on complète
    If [M:ITNG]WDATEND(ILIGRES-1) <> DDATEDEB or [M:ITNG]WHOUEND(ILIGRES-1) <> SHOUDEB Then
      If [M:ITNG]SENDDAT(ILIGRES-1) <= [M:ITNG]DATDEB + [M:ITNG]HOUDEB and DDATEDEB + SHOUDEB >= [M:ITNG]DATEND + [M:ITNG]HOUEND Then
        If [M:ITNG]SENDDAT(ILIGRES-1) < [M:ITNG]DATDEB + [M:ITNG]HOUDEB Then
          Call AFFICHE_LIGNE (ILIGRES, SNUM, [M:ITNG]WDATEND(ILIGRES-1), [M:ITNG]WHOUEND(ILIGRES-1), [M:ITNG]DATDEB, [M:ITNG]HOUDEB, 1, "", "")
        Endif
        Call AFFICHE_LIGNE (ILIGRES, SNUM, [M:ITNG]DATDEB, [M:ITNG]HOUDEB, [M:ITNG]DATEND, [M:ITNG]HOUEND, 2, "", "")
        If DDATEDEB + SHOUDEB > [M:ITNG]WDATEND(ILIGRES-1) + [M:ITNG]WHOUEND(ILIGRES-1) Then
          Call AFFICHE_LIGNE (ILIGRES, SNUM, [M:ITNG]WDATEND(ILIGRES-1), [M:ITNG]WHOUEND(ILIGRES-1), DDATEDEB, SHOUDEB, 1, "", "")
        Endif
      Else
        # Il n'y a pas la place du besoin
        Call AFFICHE_LIGNE (ILIGRES, SNUM, [M:ITNG]WDATEND(ILIGRES-1), [M:ITNG]WHOUEND(ILIGRES-1), DDATEDEB, SHOUDEB, 1, "", "")
      Endif
    Endif
  Endif
  #--------------------------------------------------------------
  # Pour chaque ligne ici, on indique la ressource comme utilisée
  Call AFFICHE_LIGNE (ILIGRES, SNUM, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ICODRES, SAOB, SOBJVCR)
End

###############################################################################
Subprog AFFICHE_LIGNE (ILIGRES, SNUM, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ITYPE, SAOB, SOBJVCR)
Variable Integer ILIGRES
Value Char SNUM
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND
Value Integer ITYPE
Value Char SAOB
Value Char SOBJVCR

Local Decimal LLTI

  If ILIGRES < dim([M:ITNG]AUSNUM) Then     # Issue X3-72085 - 2018-04-06 by FGR
    LLTI = func FUNRRSG.CALCUL_DUREE(DDATEDEB, SHOUDEB, DDATEEND, SHOUEND)
    # Issue X3-72085 - 2018-04-17 by FGR : BEGIN
    #[M:ITNG]AUSNUM(ILIGRES)  = SNUM                # Clé
    #[M:ITNG]INTDAT(ILIGRES)  = DDATEDEB + SHOUDEB  # Date interne
    #[M:ITNG]SENDDAT(ILIGRES) = DDATEEND + SHOUEND
    #[M:ITNG]LTIAFF(ILIGRES)  = LLTI                # Durée affichée
    #[M:ITNG]TYPTPS(ILIGRES)  = ITYPE               # Type : Proposition
    #[M:ITNG]LTI(ILIGRES)     = LLTI                # Durée interne
    #[M:ITNG]WDATDEB(ILIGRES) = DDATEDEB
    #[M:ITNG]WDATEND(ILIGRES) = DDATEEND
    #[M:ITNG]WHOUDEB(ILIGRES) = SHOUDEB
    #[M:ITNG]WHOUEND(ILIGRES) = SHOUEND
    #[M:ITNG]WAOB(ILIGRES)    = SAOB
    #[M:ITNG]WOBJVCR(ILIGRES) = SOBJVCR
    If LLTI < 0 Then
      LLTI = LLTI * (-1)
      [M:ITNG]AUSNUM(ILIGRES)  = SNUM                # Clé
      [M:ITNG]INTDAT(ILIGRES)  = DDATEEND + SHOUEND  # Date interne
      [M:ITNG]SENDDAT(ILIGRES) = DDATEDEB + SHOUDEB
      [M:ITNG]LTIAFF(ILIGRES)  = LLTI                # Durée affichée
      [M:ITNG]TYPTPS(ILIGRES)  = ITYPE               # Type : Proposition
      [M:ITNG]LTI(ILIGRES)     = LLTI                # Durée interne
      [M:ITNG]WDATDEB(ILIGRES) = DDATEEND
      [M:ITNG]WDATEND(ILIGRES) = DDATEDEB
      [M:ITNG]WHOUDEB(ILIGRES) = SHOUEND
      [M:ITNG]WHOUEND(ILIGRES) = SHOUDEB
      [M:ITNG]WAOB(ILIGRES)    = SAOB
      [M:ITNG]WOBJVCR(ILIGRES) = SOBJVCR
    Else
      [M:ITNG]AUSNUM(ILIGRES)  = SNUM                # Clé
      [M:ITNG]INTDAT(ILIGRES)  = DDATEDEB + SHOUDEB  # Date interne
      [M:ITNG]SENDDAT(ILIGRES) = DDATEEND + SHOUEND
      [M:ITNG]LTIAFF(ILIGRES)  = LLTI                # Durée affichée
      [M:ITNG]TYPTPS(ILIGRES)  = ITYPE               # Type : Proposition
      [M:ITNG]LTI(ILIGRES)     = LLTI                # Durée interne
      [M:ITNG]WDATDEB(ILIGRES) = DDATEDEB
      [M:ITNG]WDATEND(ILIGRES) = DDATEEND
      [M:ITNG]WHOUDEB(ILIGRES) = SHOUDEB
      [M:ITNG]WHOUEND(ILIGRES) = SHOUEND
      [M:ITNG]WAOB(ILIGRES)    = SAOB
      [M:ITNG]WOBJVCR(ILIGRES) = SOBJVCR
    Endif
    # Issue X3-72085 - 2018-04-17 by FGR : END
    ILIGRES += 1
  Endif
End

