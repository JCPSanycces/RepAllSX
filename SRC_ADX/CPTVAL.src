#<AdxTL>@(#)7.0.0.0 $Revision$

# Issue X3-102376 - 2018-07-31 by MWA : Import large number of Supplier BP invoices failed on 2018 R4 cloud site

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTVAL","CPTVAL",4,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

$OUVRE
Gosub OUVFIC

Local Mask GACCENT0   [HAE0], GACCENT1   [HAE1]
&        , GACCENT2   [HAE2], VENTILE    [VTL], VENTILE2 [VT2]

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Integer I, J, K, NOL, STAT
Local Char    CRITERE(250), CRITEREJ(250), CRITSUP(250)
Local Integer NBPCE
Local Integer SIGN
Local Integer OKTCA
Local Integer OKMESS
Local Char    TIT(50)
Local Char    MESSA(50)
Local Char    SYMBOLE(50)
Local Char    CHRONO(GLONANM)
Local Integer NBJOU
Local Char    TJOURNAL(20)(1..max(1,nbrecord([F:JOU])))
Local Decimal EXE, PER
Local Char    SOCIETE(GLONCPY)

## Variables pour la localisation italienne KIF (compteur bollato)
Local Char KIF_JOU(GLONJOU)(1..300)
Local Integer KIF_FLG(1..300), KIF_IND
Raz KIF_JOU, KIF_FLG, KIF_IND

Local Integer MAXLIG , MAXVTL
MAXLIG = dim([M]SAC1)
MAXVTL = dim([M:VTL]AMT)
Local Decimal DEBLOC(MAXLIG) , CDTLOC(MAXLIG)
Local Decimal DEBRPT(MAXLIG) , CDTRPT(MAXLIG)
Local Decimal TMPLOC(MAXVTL) , TMPRPT(MAXVTL)
Local Decimal AROLOC , ARORPT
Local Char    VLEG(GLONADI)

Local Integer PSTLEDTYP(10)
Local Char    CHRONO_HAE(GLONANM)
Local Char    PARAM_FNL(2)

# Validation définitive des pièces
TIT = mess(13,107,1)

Local Mask CPTVAL [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp1") From GMEMO
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
Local File GACCOUNT   [GAC],  GAJOUSTA   [JST]
&        , COMPANY    [CPY],  COMPANY    [CPY2]
&        , FACILITY   [FCY],  FACGROUP   [FGR]
&        , TABCUR     [TCU],  TABCHANGE  [TCH]
&        , GDIAENTRY  [GDE],  GDIAENTRYD [GDD]
&        , TABACCLIK  [TCK]
&        , GTYPACCENT [GTE],  CADSP      [DSP]
&        , GACCENTRY  [HAE]
&        , GACCENTRYD [DAE],  GACCENTRYA [DAA]
&        , BALANCE    [BAL],  BALANA     [BLA]
&        , AVALNUM    [AVN],  ACODNUM    [ANM]
&        , FISCALYEAR [FIY],  PERIOD     [PER]
&        , GJOURNAL   [JOU],  TABUNIT    [TUN]
&        , GACCENTRY  [HA2] , TABCOUAFF  [TCA]
&        , GJOURNAL   [JOU2]
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP=1
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,FIN) From CPTDIV2
If FIN : Return : Endif

Local Integer OK
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return

#######################################################
## Exécution silencieuse du traitement
#######################################################
$EXEC
If GSERVEUR
 [M:DIA]TRC = 2
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Reinit de GCURLEG car qd on lance la validation on passe de GSAISE à GTRAITE et
# on perd le GCURLEG initialisé par CPTTRT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

CRITERE = "1=1"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITERE -= '& TYP = "'+[M:DIA]TYP+'"'
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR = "'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR = "" & CREUSR = "'+[M:DIA]USR+'"))'
Endif
CRITERE -= "& (CAT=1 | CAT=4)" : # Réel/Hors-bilan
CRITERE -= "& STA = 1"
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
CRITSUP = ""
GPOINT = "CRITERE" : Gosub ENTREE From EXEFNC
If CRITSUP="" : CRITSUP = "1=1" : Endif

Filter [HA2] Where evalue(CRITERE) & evalue(CRITSUP)

CRITEREJ = "1=1"
If [M:DIA]ALLTYPJOU<>2
 CRITEREJ -= "& TYP ="-num$([M:DIA]TYPJOU)
Endif
If [M:DIA]ALLJOU<>2
 CRITEREJ -= '& JOU = "'+[M:DIA]JOU+'"'
Endif
Filter [JOU] Where evalue(CRITEREJ)

NBJOU = 0
For [JOU]JOU0(1)
 NBJOU += 1
 TJOURNAL(NBJOU) = [F:JOU]JOU
Next

# Boucle sur les sociétés (et aussi pour paramètre BOLLATO)
If [M:DIA]ALLCPY=2
 For [CPY2] Where CPYLEGFLG=2 & LEG=GCURLEG
  SOCIETE = [F:CPY2]CPY
  Gosub TRTSOC
 Next
Else
 SOCIETE = [M:DIA]CPY
 If [F:CPY2]CPY<>SOCIETE
  Read [CPY2]CPY0 = SOCIETE
 Endif
 Gosub TRTSOC
Endif

Filter [JOU]
Filter [HA2]
If !NBPCE
 Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter
Endif
If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif
Return

$TRTSOC
CHRONO = ""
CHRONO_HAE = ""

GSOCIETE = [L]SOCIETE
Call LECTCA(2,OKTCA) From SUBTCA
If OKTCA
 CHRONO = [F:TCA]CODNUM(0)
 CHRONO_HAE = [F:TCA]CODNUM(15)
Endif
If CHRONO="" : CHRONO = "CHR" : Endif

# Issue X3-103268
#If func AFNC.PARAM("ITABOL",SOCIETE)="2"
If func AFNC.ACTIV("KIT") and func AFNC.PARAM("ITABOL",SOCIETE)="2"
 # Validation des pièces par date
 For [HA2]HAE4 Where CPY=SOCIETE & find(JOU,TJOURNAL(1..NBJOU))
  Gosub TRTVALKIF
  If GOK<1 & GTRACE<>""
   Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Rollback
  Endif
 Next
Else
 For [JOU]JOU0(1)
  GOK=1
  VLEG = [F:CPY2]LEG
  Look [JOU2]JOU0=[F:JOU]JOU;VLEG
  If fstat
   Raz VLEG
  Endif
  For [JOU]JOU0(2)
   If [F:JOU]LEG=VLEG
    GOK=1
    Gosub TRTVAL
    If GOK<1 & GTRACE<>""
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Rollback
    Endif
   Endif
  Next
 Next
Endif
Return


#######################################################
## Traitement de fin (lecture trace éventuelle)
#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

#######################################################
## Transaction de validation définitive
#######################################################
$TRTVAL
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat
 Call ECR_TRACE([F:JOU]JOU-GMESSAGE,1) From GESECRAN
 Return
Endif

For [HA2]HAE1 Where CPY=SOCIETE & JOU=[F:JOU]JOU
 OK = 1
 Call CONTFCY([F:HA2]FCY) From CPTSUB
 If mkstat : OK = 0 : Endif
 If [M:DIA]ALLTYP=2
  Call LEC_GTE_LEG(GCURLEG,[F:HA2]TYP) From CPTLEC
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If mkstat : OK = 0 : Endif
 Endif
 If OK
  NBPCE += 1
  SYMBOLE = "HAE"+[F:HA2]NUM+"\"+[F:HA2]TYP
  Lock =SYMBOLE With lockwait=0
  If fstat=1
   If GTRACE<>"" : Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,100,1),1) From GESECRAN : Endif
  Else
   OKMESS = 1
   Call DEBTRANS From GLOCK
   Gosub TR1
   If GOK=1 & !STAT & GTRACE<>"" & OKMESS
    Call ECR_TRACE(mess(12,107,1)-[F:HA2]TYP-[F:HA2]NUM,0) From GESECRAN
   Endif
   Unlock =SYMBOLE
  Endif
 Endif
Next
Return

$TR1
GOK=1
Trbegin  [HAE], [HA2], [DAE], [DAA], [AVN], [BAL], [BLA]
 Readlock [HAE]HAE0 = [F:HA2]TYP ; [F:HA2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRY"+[F:HA2]TYP-[F:HA2]NUM : Goto ROL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("HAE",[F:HA2]TYP-[F:HA2]NUM) From GLOCK : Goto AB_TR1
 Endif
 If [F:HAE]STA<>2
  SIGN = -1
  Gosub MAJSTAT
  If    GOK<0 : Goto ROL_TR1
  Elsif GOK=0 : Goto AB_TR1
  Endif
  [F:HAE]STA = 2 : # Définitif
  If dim([F:HAE]UPDUSR)>0 : [F:HAE]UPDUSR = GUSER : Endif
  If dim([F:HAE]UPDDAT)>0 : [F:HAE]UPDDAT = date$ : Endif
  ## Localisation italienne KIF, compteur BOLLATO

  Call LEC_JOU_LEG(GCURLEG,[F:HAE]JOU)From CPTLEC

  If [F:JOU]BOLLATO<>""
   Call NUMERO([F:JOU]BOLLATO,[F:HAE]FCY,[F:HAE]ACCDAT,[F:HAE]JOU,[F:HAE]BOLLATO,STAT) From SUBANM
   If STAT
    # Problème lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    If GTRACE<>"" : Call ECR_TRACE(mess(60,199,1)-"("+[F:JOU]BOLLATO+") : "+MESSA,1) From GESECRAN : Endif
    GOK = 0 : Goto AB_TR1
   Endif
  Else
   [F:HAE]BOLLATO=[F:HAE]NUM
  Endif
  # Le cas échéant pour faire autre chose (mise à jour du chrono export...)
  GPOINT = "VALID" : Gosub ENTREE From EXEFNC
  Rewrite [HAE]
  If fstat
   GOK=0 : Call FSTA("HAE") From GLOCK : Goto AB_TR1
  Endif
  SIGN = +1
  Gosub MAJSTAT
  If    GOK<0 : Goto ROL_TR1
  Elsif GOK=0 : Goto AB_TR1
  Endif
  ### Création de la dépense dans le module immobilisation
  If GMODU(14)=2 : # Présence du module Immobilisation
   #-----------------------#
   # Dépense immobilisable #
   #-----------------------#
   Local Char MESSA(250)
   Call CREDEP("VAL", MESSA) From SUBLOF2
   If !GOK
    Call ECR_TRACE(MESSA,1) From GESECRAN
    Goto AB_TR1
   Endif
  Endif

  [F:HAE]FNLPSTDAT = date$
  If dim(GUPDFNLPST)>0 & GUPDFNLPST<>2
   Call PARAML("","UPDFNLPST",[L]PARAM_FNL) From ADOVAL
   GUPDFNLPST= val([L]PARAM_FNL)
  Endif
  If dim(GUPDFNLPST)>0 & GUPDFNLPST=2
   For I=0 To dim([L]PSTLEDTYP)-1
    If [L]PSTLEDTYP(I)
    Call NUMERO_FIY(CHRONO_HAE,[F:HAE]FCY,[F:HAE]ACCDAT,num$(I),I+1,[F:HAE]FNLPSTNUM(I),STAT) From SUBANM
    If STAT : Break : Endif
    Endif
   Next
   If STAT
    # Problème lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    If GTRACE<>"" : Call ECR_TRACE(mess(60,199,1)-"("+CHRONO_HAE+") : "+MESSA,1) From GESECRAN : Endif
    GOK = 0  : Goto AB_TR1
   Else

    # X3-86663
    If func FRADSILIB.DSFRA("GAS", [F:HAE]CPY)
      Call SETMAINREF([F:HAE]CPY,GTYPGEN,GTYPANA) From CPTDIV
      If GTYPGEN > 0 & [F:HAE]FNLPSTNUM(GTYPGEN-1) <> ""
        Gosub SIGN_GAS From FRADSILIB
        If GOK = 0 : Goto AB_TR1 : Endif
      Endif
    Endif

    Rewrite [HAE]
    If fstat
     GOK=0 : Call FSTA("HAE") From GLOCK :  : Goto AB_TR1
    Endif
   Endif
  Endif
 Else
  OKMESS = 0
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MAJSTAT
For I=0 To dim([F:HAE]FNLPSTNUM)-1
 [L]PSTLEDTYP(I) = 0
Next
For [DAE]DAE0 Where TYP=[F:HA2]TYP & NUM=[F:HA2]NUM
 Call VALSTA("GAS",SIGN) From SUBPS2
 If GOK<1 : Break : Endif
 If SIGN = 1
  Call NUMERO(CHRONO,[F:HA2]FCY,[F:HA2]ACCDAT,num$([F:DAE]LEDTYP-1),[F:DAE]CHRNUM,STAT) From SUBANM
  If STAT
   # Problème lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   If GTRACE<>"" : Call ECR_TRACE(mess(60,199,1)-"("+CHRONO+") : "+MESSA,1) From GESECRAN : Endif
   GOK = 0 : Break
  Endif
  If [F:HA2]CAT=1 : [L]PSTLEDTYP([F:DAE]LEDTYP-1)=1 : Endif
 Endif
 Rewrite [DAE]
 If fstat
  GOK = 0 : Call FSTA("DAE") From GLOCK : Break
 Endif
Next
Return



####################################################################
## Transaction de validation définitive KIF
####################################################################
## Localisation italienne KIF, compteur BOLLATO
####################################################################
$TRTVALKIF
Local Integer IND

# Contrôle et message pour vérifier les droits d'execution sur le journal.
Call LEC_JOU_LEG(GCURLEG,[F:HA2]JOU)From CPTLEC
IND = find([F:JOU]JOU,KIF_JOU(1..KIF_IND))
If !IND
 KIF_IND+=1
 KIF_JOU(KIF_IND)=[F:JOU]JOU
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat
  Call ECR_TRACE([F:JOU]JOU-GMESSAGE,1) From GESECRAN
  KIF_FLG(KIF_IND)=1 : Return
 Else
  KIF_FLG(KIF_IND)=2
 Endif
Else
 If KIF_FLG(IND) = 1 : Return : Endif
Endif

OK = 1
Call CONTFCY([F:HA2]FCY) From CPTSUB
If mkstat : OK = 0 : Endif
If [M:DIA]ALLTYP=2
 Call LEC_GTE_LEG(GCURLEG,[F:HA2]TYP) From CPTLEC
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat : OK = 0 : Endif
Endif
If OK
 NBPCE += 1
 SYMBOLE = "HAE"+[F:HA2]NUM+"\"+[F:HA2]TYP
 Lock =SYMBOLE With lockwait=0
 If fstat=1
  If GTRACE<>"" : Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,100,1),1) From GESECRAN : Endif
 Else
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK=1 & !STAT & GTRACE<>""
   Call ECR_TRACE(mess(12,107,1)-[F:HA2]TYP-[F:HA2]NUM,0) From GESECRAN
  Endif
  Unlock =SYMBOLE
 Endif
Endif
Return

