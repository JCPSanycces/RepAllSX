#<AdxTL>@(#)11.0.0.0 $Revision$

Call CREPOOLENTRY("SUPERVP1","Pool principal","SUPERV","ASTRAGALE","astragale.sagefr.adinternal.com",18880,3,3)
Call CREPOOLENTRY("SUPERVP2","Pool secondaire","SUPERV","ASTRAGALE","astragale.sagefr.adinternal.com",18880,1,2)
Call CREPOOLENTRY("SUPERVPC","Pool autre","SUPERVH8","INTRADON","intradon.sagefr.adinternal.com",18880,1,2)



Gosub WRITXMLPOOL
End


$WRITXMLPOOL
  Local File APOOLWS [APW]
  Local Char NOMFIC(200),ALIASP(100),FOLCOU

  NOMFIC=filpath("X3_ROOT/GEN","POOLDEF","xml","X3_PUB")
  Openo NOMFIC,0 Using [POO_]
  Iomode adxifs "" Using [POO_]
  Iomode adxirs chr$(10) Using [POO_]
  Iomode adxium GUTF8 Using [POO_]
  Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [POO_]
  Wrseq '<pooldef>' Using [POO_]
 For [APW]
  If [F:APW]DOSSIER<>FOLCOU
    If FOLCOU<>"" :   Wrseq '</folder>' Using [POO_] : Endif
    Wrseq '<folder nam="'+[F:APW]DOSSIER+'">' Using [POO_]
    FOLCOU=[F:APW]DOSSIER
  Endif
  Wrseq '<alias nam="'+[F:APW]POOLALIAS+'">' Using [POO_]
  Wrseq '<lib>'+[F:APW]INTITPOOL+'</lib>' Using [POO_]
  Wrseq '<serveralias>'+[F:APW]SWEBALIAS+'</serveralias>' Using [POO_]
  Wrseq '<serverhostname>'+[F:APW]SERWEB+'</serverhostname>' Using [POO_]
  Wrseq '<serverport>'+num$([F:APW]PORTWEB)+'</serverport>' Using [POO_]
  Wrseq '<initsize>'+num$([F:APW]NBENTRY)+'</initsize>' Using [POO_]
  Wrseq '<maxsize>'+num$([F:APW]MAXENTRY)+'</maxsize>' Using [POO_]
  Wrseq '</alias>' Using [POO_]
 Next
  If FOLCOU<>"" : Wrseq '</folder>' Using [POO_] : Endif
  Wrseq '</pooldef>' Using [POO_]
  Openo Using [POO_]
Return



# --------------------------------------------------------------------------------------------------

Subprog CREPOOLENTRY(POOLALIAS,INTITPOOL,DOSSIER,SWEBALIAS,SERWEB,PORTWEB,NBENTRY,MAXENTRY)
Value Char POOLALIAS
Value Char INTITPOOL
Value Char DOSSIER
Value Char SWEBALIAS
Value Char SERWEB
Value Integer PORTWEB
Value Integer NBENTRY
Value Integer MAXENTRY

Local File APOOLWS [APW]
Local Integer REWR
Read [APW]APW0=DOSSIER;POOLALIAS;SWEBALIAS
If fstat=0 : REWR=1 : Endif
Trbegin [APW]
[F:APW]POOLALIAS=[L]POOLALIAS
[F:APW]INTITPOOL=[L]INTITPOOL
[F:APW]DOSSIER=[L]DOSSIER
[F:APW]SWEBALIAS=[L]SWEBALIAS
[F:APW]SERWEB=[L]SERWEB
[F:APW]PORTWEB=[L]PORTWEB
[F:APW]NBENTRY=[L]NBENTRY
[F:APW]MAXENTRY=[L]MAXENTRY
Local Char ABFIC : ABFIC="APW"
If REWR=1
  Gosub INIMOD From GOBJSUB
  Rewrite [APW]
Else
  Gosub INICRE From GOBJSUB
  Write [APW]
Endif
Commit
End

# --------------------------------------------------------------------------------------------------

Subprog POOLUPDT(DOSSIER,POOLALIAS,INTITPOOL,SWEBALIAS,SERWEB,PORTWEB,NBENTRY,MAXENTRY)
Value Char DOSSIER
Value Char POOLALIAS()(1..)
Value Char INTITPOOL()(1..)
Value Char SWEBALIAS()(1..)
Value Char SERWEB()(1..)
Value Integer PORTWEB(1..)
Value Integer NBENTRY(1..)
Value Integer MAXENTRY(1..)


End

# --------------------------------------------------------------------------------------------------

Subprog POOLCONTR(DOSSIER,POOLALIAS,SWEBALIAS,CRET,MESSAG)  
Value Char DOSS
Value Char POOLALIAS
Value Char SWEBALIAS
Variable Integer CRET
Variable Char MESSAG

#  Controle si le pool "POOLALIAS" est utilisé par Xtend.
#  CRET=0 Pas d'utilisation
#  CRET=1 Pool inconnu
#  CRET=2 Pool utilisé par XTEND 

CRET=0

Local File APOOLWS [APW]
Read [APW]APW0=DOSSIER;POOLALIAS;SWEBALIAS
If fstat<>0 : CRET=1 : End : Endif

#  Voir pour vérifier si le pool est utilisé

End
# --------------------------------------------------------------------------------------------------
