#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char    ACTMAS
Local Integer NUMACT
Local Integer ACTGESPLN

  ACTMAS="TEST"
  ACTGESPLN=1
  TRTACTMAS="TRM"+ACTMAS

  Call OBJET("MPY",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
#    GESTION DES ACTIONS METIER SUR LES OBJETS METIERS / TRAITEMENTS COMMUNS   #
#    ACTIONS MASSIVES - OBJETS MPY de visu/mise à jour du contenu de la table  #
#                       temporaire TRTMASPHY                                   #
#    GBN                                                                       #
#    Création le     : 11/12/2003                                              #
#    Modification V5 : 01/10/2007                                              #
################################################################################
# MDJ   09.02.2015  FQ100398  : Suppression site géographique
# MDJ   12.06.2013  FQ82871   : Adaptations pour Convergence (pcolor)
# GLE   18.05.2010  FQ64478   : Suppression des appels à des étiquettes inexistantes
################################################################################

$ACTION

  Case ACTION
    When "VARIANTE"    : Gosub VARIANTE
    When "OUVRE"       : Gosub OUVRE
    When "LIENS0"      : Gosub LIENS0
    When "LIENS"       : Gosub LIENS
    When "LIENS2"      : Gosub LIENS2
    When "APRES_MODIF" : Gosub APPEL_MODELE
    When "AVANTBOUT"   : Gosub APPEL_MODELE
    When "APRES_CHOI"  : Gosub APRES_CHOI
    When "INICRE"      : Gosub INICRE
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub APPEL_MODELE
    When "APRES_MOD"   : Gosub APPEL_MODELE
    When "SETBOUT"     : Gosub SETBOUT
    When "ABANDON"     : Gosub APPEL_MODELE
    When "FIN"         : Gosub FIN
    When "EXEBOUT"     : Gosub APPEL_MODELE   # Fq-34831
    When Default       : ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
  Endcase
Return


######################################################################################
$VARIANTE

  If [F:AWI]TRN<>ACTMAS Then
    OK=0
  Endif
Return


######################################################################################
$OUVRE
Local Char ORIACT
Return


######################################################################################
$APPEL_MODELE
  ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return


######################################################################################
$LIENS0

  # Ajouter critère pour complément de filtre dans TRTACTMAS
  Filter [MPY] Where (TRTNUM=NUMACT)
  Gosub APPEL_MODELE
Return


######################################################################################
$LIENS


  ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
  Gosub APPEL_MODELE

Return


######################################################################################
$LIENS2

  Gosub APPEL_MODELE
  Filter [MPY]
Return


######################################################################################
$APRES_CHOI

  Case REPONSE
    When GSTAEND
      # GBN - 23/03/2004 - Pour que le message ne pollue plus la V2 du modèle tout en conservant le fonctionnement V1
      #Local Integer POK
      #Call OUINON ("Vous allez abandonner le traitement sans mise à jour.\Voulez-vous continuer ?",POK) From GESECRAN
      #Case POK
      # When 1
      #  REPONSE=0
      #  Return
      # When Default
      #Endcase
      ABANDON_TRT=1
      Return
    When GSTABOU+1
      GOK=1
      REPONSE=GSTAEND
      ABANDON_TRT=0
      Return
    When Default
     Gosub APPEL_MODELE
  Endcase
Return


######################################################################################
$INICRE
Global Char CREAT

  Gosub APPEL_MODELE
  ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS

Return


######################################################################################
$INIMOD

  If dim(CREAT)=0 : Global Char CREAT : Endif
  Gosub APPEL_MODELE
  ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS

Return


######################################################################################
$SETBOUT

  If GREP<>"" | REP<>"" Then
    Call VIREBOUT (CHAINE, "V") From GOBJET                      : # Validation / Fin
    Disable GSTAEND
  Else
    Enable GSTAEND
  Endif
  Gosub APPEL_MODELE
Return


######################################################################################
$FIN
  Gosub APPEL_MODELE
  If dim(CREAT)>0 and CREAT="O" Then
    mkstat=4
    Kill CREAT
  Endif
Return


######################################################################################
# Traitements appelés par Call ou Gosub                                              #
######################################################################################

######################################################################################
#  Ce s/p permet de rendre le nom du premier masque d'une fenêtre passée             #
#  en paramètre.                                                                     #
######################################################################################
Subprog GET_MASQUE(PWIN,RMASK,RCOD)
Value    Char    PWIN
Variable Char    RMASK
Variable Integer RCOD

  Raz RCOD
  If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif

  Read [F:AWI]AWI0=PWIN
  If fstat Then
    RCOD=1
    End
  Endif
  RMASK=[F:AWI]NOMMSK(0)
End

######################################################################################
#  Ce s/p permet de rendre une ligne saisissable ou non saisissable en
#  fonction de la valeur de FLGMOD de l'enregistrement correspondant à la
#  ligne
######################################################################################
Subprog AFFICHE_LIGNE(PTRT,PMASK,PCLASSE,PBLOC,PINDICE,RCOD)
Value    Char    PTRT
Value    Char    PMASK
Value    Char    PCLASSE
Value    Integer PBLOC
Value    Integer PINDICE
Variable Integer RCOD

Local Char    CLASSE           : CLASSE="[M:"+PCLASSE+"]"
Local Char    CHAMP(250)

  If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

  Filter [AMZ] Where (CODMSK=PMASK & NUMBLOC=PBLOC & CODTYP<>"ABS" & SAIAFF=1)
  For [AMZ]
    Raz CHAMP
    CHAMP+=CLASSE+[F:AMZ]CODZON+"("+num$(PINDICE)+")"
    #-> On vérifie d'abord que le champ existe
    If evalue("dim("+CHAMP+")>0") Then
      #-> Puis on modifie son statut
      If PTRT="DISZO"
        Grizo =CHAMP
        Diszo =CHAMP
      Elsif PTRT="ACTZO"
        Actzo =CHAMP
      Endif
     Endif
  Next
  Filter [AMZ]
End

######################################################################################
## Gestion du masque MPY0
######################################################################################

######################################################################################
#  Actions champ sur les zones communes NBOBJ / CPY / OBJREF / AASDES1
######################################################################################

######################################################################################
#-> Tableau par élément physique
######################################################################################
Subprog AV_NBOBJ
  If status=71 Then
    Enable GSTAANU
  Endif

  Case ACTMAS
    When "PHYTRF" : Call AV_NBOBJ From TRTPHYTRF
    When "PHYISS" : Call AV_NBOBJ From TRTPHYISS
    When Default
  Endcase

End

######################################################################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
  If [M:MPY0]FLGERR(nolign-1)=2 Then
     Chgstl NBOBJ(nolign-1)  With "AWARNHIGH"
     pcolor=GCOUL(1)  # Rouge
  Else
    Chgstl NBOBJ(nolign-1)  With ""
    pcolor=GCOUL(0)  # Normal
  Endif
End

######################################################################################
#  Action champ sur les zones spécifiques aux actions massives
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
  Case ACTMAS
    When "PHYTRF"      : Call AM_FCY(VALEUR) From TRTPHYTRF
  Endcase
End
