#<AdxTL>@(#)12.0.0.0 $Revision$
########################################################################
# Traitement TIMANALIB  - Modification des sections analytiques opés   #
#                                                                V140  #
########################################################################
# Action TIMANALIB
# 
########################################################################
$ACTION
#--- Actions liées au traitement standard 
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "SETBOUT"  : Gosub SETBOUT
 When "ENR"      : Gosub ENR
 When "ABA"      : Gosub ABA
 When "FINSAI"   : Gosub FINSAI
Endcase

##########################################################################
$OUVRE
Local Char    LNUM(GLONVCR)
Local Integer LLIN
Local Integer I, WGCONSULT
Local Date    LDAT
WGCONSULT=1

# Récupération des paramètres
LNUM = PARAM(1)
LLIN = val(PARAM(2))
LDAT=PARAM(3)

If clalev([F:MKO]) = 0 :  Local File MFGOPETRK  [MKO] :  Endif
If clalev([F:MWI]) = 0 :  Local File WIPCOST    [MWI] :  Endif
If clalev([F:CAL]) = 0 :  Local File CPTANALIN  [CAL] :  Endif

Return

##########################################################################
$DEBUT
Raz [M:TAM]
Read [MKO]MKO0=LNUM;LLIN
If fstat : FIN = 1 : Return : Endif
Read [F:CAL]CAL0 = "MKO";0;[F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN;0;[F:MKO]CPLWST;1
If fstat : Raz [F:CAL]
Else
    Call CHARG_CCEX("TAM","NBAXE","CAL","DIE","CCE") From TRTX3CPT
Endif
If [F:MKO]CPLLAB <> ""
    Read [F:CAL]CAL0 = "MKO";0;[F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN;0;[F:MKO]CPLLAB;1
    If fstat : Raz [F:CAL]
    Else
        Call CHARG_CCEX("TAM","NBAXE1","CAL","LABDIE","LABCCE") From TRTX3CPT
    Endif
Endif
If GCONSULT : WGCONSULT = 2 : Endif
# si le suivi opératoire a été interfacé, consultation uniquement
For [MWI]MWI1 Where MFGTRKNUM=LNUM & MFGTRKLIN=LLIN & TXNACT<3 & TXNTYP<5
    If [F:MWI]GLPSTA = 2 : WGCONSULT=2 : Break : Endif
Next

# Issue 73226 - 2011-04-13 by CCC : alim de IPTDAT
[M:TAM]IPTDAT = LDAT

# Consultation
If WGCONSULT=2 : Diszo [M:TAM] : Endif
If [F:MKO]CPLLAB = "" : Diszo [M:TAM]15 : Endif
Affzo [M:TAM]1-99

Return

#########################################################################
$SETBOUT

If WGCONSULT<>2 
   If !find("A",CHBOU) CHBOU+="A" Endif
   If !find("E",CHBOU) CHBOU+="E" Endif
Endif

Return

##########################################################################
$ENR

# Transaction de mise à jour
Call DEBTRANS From GLOCK
Trbegin [STJ]

Readlock [MKO]MKO0=LNUM;LLIN
If fstat
    Call RSTA("MKO",LNUM-num$(LLIN)) From GLOCK
    Raz GOK : Goto AB_TRT
Else
    Gosub MAJMKO_CPTANALIN
Endif
If GOK=1
    Commit
Else
    Rollback
Endif

FIN = 1
Return

##########################################################################
$FINSAI
Return

##########################################################################
$ABA
Gosub DEBUT
Return

##########################################################################
$AB_TRT 
Rollback 
Return 


#---------------------------------------------#
# Ecriture des sections de la ligne opération #
#---------------------------------------------#
$MAJMKO_CPTANALIN
#-----
Call ENREG_ACCCCE(0,"","","[M:TAM]CCE(","MKO",
&                 0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLWST,"M") From TRTX3CPT
If GOK<1  Return : Endif
#-----
If [F:MKO]CPLLAB=""  Return : Endif
#-----
Call ENREG_ACCCCE(0,"","","[M:TAM]LABCCE(","MKO",
&                 0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLLAB,"M") From TRTX3CPT
If GOK<1  Return : Endif
#-----
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran TIMANAM) 31/08/2006 10:12:37 (SR)
######################################################################################
Subprog D_CCE(VALEUR)
Variable Char    VALEUR()
Call INIT_CCEX("TAM","NBAXE","MKO","DIE","CCE") From TRTX3CPT
End

Subprog D_LABCCE(VALEUR)
Variable Char    VALEUR()
Call INIT_CCEX("TAM","NBAXE1","MKO","DIELAB","CCELAB") From TRTX3CPT
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran TIMANAM) 31/08/2006 10:30:44 (SR)
######################################################################################
Subprog C_NBAXE
Local Integer I
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif 
#----- Contrôle sections obligatoires -----#
If [M:TAM]NBAXE>0 & varmode([M:TAM]CCE,0)=0
  Local Integer I
  For I=1 To [M:TAM]NBAXE
    If [M:TAM]CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End

####################################
Subprog C_NBAXE1
Local Integer I
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif 
#----- Contrôle sections obligatoires -----#
If [M:TAM]NBAXE1>0 & varmode([M:TAM]LABCCE,0)=0
  Local Integer I
  For I=1 To [M:TAM]NBAXE1
    If [M:TAM]LABCCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End


######################################################################################
