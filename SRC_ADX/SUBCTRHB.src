#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
#                                                                      #
# -------------------------------------------------------------------- #
# Fenêtres de saisie                                                   #
# ------------------                                                   #
# SAICRITLCC : SAICRITLCC   : Fenêtre de saisie des critères pour les  #
#                             landed cost (conteneur et shipment)      #
########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "TITRE"         : Gosub TITLE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "ABA"           : Gosub ABA
 When "APRES_MODIF"   : Gosub APRES_MODIF
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
  When "SAICRITLCC" : Gosub OUV_CRIT
Endcase
Return
#-----------------------------------------------------------------------#
$TITLE
  Case GACTION
   When "SAICRITLCC" : TIT=mess(367,198,1)
  Endcase
Return
#-----------------------------------------------------------------------#
$DEBUT
Case GACTION
 When "SAICRITLCC": Gosub DEB_CRIT
Endcase
Return
#-----------------------------------------------------------------------#
$OK
Case GACTION
 When "SAICRITLCC" : Gosub OK_CRIT
Endcase
Return
#-----------------------------------------------------------------------#
$ABA
Case GACTION
 When "SAICRITLCC" : Gosub ABA_CRIT
                     REP = ""
Endcase
Return
#-----------------------------------------------------------------------#
$APRES_MODIF
Case GACTION
 When "SAICRITLCC" : REP = "M"
Endcase
Return

################################################################################
# SAICRITPTH  Saisie des critères de réceptions                    HN 27/11/00 #
################################################################################
$OUV_CRIT
If clalev ([F:POH]) = 0  Local File PORDER    [POH] : Endif : #commandes
If clalev ([F:POP]) = 0  Local File PORDERP   [POP] : Endif : #commandes achat prix
If clalev ([F:POQ]) = 0  Local File PORDERQ   [POQ] : Endif : #commandes achat qté
If clalev ([F:ITM]) = 0  Local File ITMMASTER [ITM] : Endif : #article
If clalev ([F:ITP]) = 0  Local File ITMBPS    [ITP] : Endif : #article - fournisseur
Return
#------------------------------------------------------------------------------#
$DEB_CRIT
Local Char WABR(10)
If GPILNAV>1
  If GNAVIG(GPILNAV-1)="GESSHIP"
    WABR = "[M:SHIP0]"
     If currbox = GBOXCTRH
      Diszo [M:PLC1]WPOHNUM
      If GREP = "C"
        Diszo [M:PLC1]WEXP
      Endif
    Endif
  Elsif GNAVIG(GPILNAV-1)="GESCTRH"
    WABR = "[M:CTRH2]"
    Chgfmt [M:PLC1]WCTRNUM With "-K:20"
    Chgfmt  [M:PLC1]WEXP With "-K:15X"
  Else
    [M:PLC1]=[M:PLCW]
    Chgfmt [M:PLC1]WCTRNUM With "-K:20"
    Chgfmt  [M:PLC1]WEXP With "-K:15X"
    Affzo [PLC1]1-99
    Return
  Endif
Endif
[M:PLC1]=[M:PLCW]
If evalue(WABR+"FCY")<>"" [M:PLC1]WFCY=evalue(WABR+"FCY") : Endif
If [M:PLC1]WFCY<>""
  If [F:FCY]FCY<>[M:PLC1]WFCY
    Read [FCY] FCY0= VALEUR : If fstat Raz [F:FCY] : Endif
  Endif
  [M:PLC1]WFCYNAM=[F:FCY]FCYNAM
Endif
If evalue(WABR+"BPSNUM")<>"" [M:PLC1]WBPSNUM=evalue(WABR+"BPSNUM") : Endif
If [M:PLC1]WBPSNUM<>""
  If [F:BPS]BPSNUM<>[M:PLC1]WBPSNUM
    Read [BPS] BPS0=[M:PLC1]WBPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  [M:PLC1]WBPSNAM=[F:BPS]BPSNAM
Endif
#Actzo [PLC1]1-99
Affzo [PLC1]1-99
#If evalue(WABR+"NBLIG")>0 Diszo [PLC1]WBPSNUM, WBPSNAM : Endif
Return
#------------------------------------------------------------------------------#
$OK_CRIT
[M:PLC1]WBPSNUM   =vireblc([M:PLC1]WBPSNUM,2)
[M:PLC1]WITMREF   =vireblc([M:PLC1]WITMREF,2)
[M:PLC1]WPOHNUM   =vireblc([M:PLC1]WPOHNUM,2)
[M:PLCW]=[M:PLC1]
Return
#------------------------------------------------------------------------------#
$ABA_CRIT
[M:PLC1]=[M:PLCW]
REP=""
Affzo [PLC1]1-99
Return

