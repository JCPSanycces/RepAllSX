#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# Action ASELOCCRIT : Sélection des Chapitre à traduire avec Critères en entrée
# ---------------------------------------------------------------------- #
# JPGA 19/02/2013                                                        #
# ---------------------------------------------------------------------- #
#   Parametre 1   : Langue de Traduction
#   Parametre 2   : Langue de Référence
# ---------------------------------------------------------------------- #
#   Ecran utilisé : ASELOCCRIT : [M:ALTC]
# ---------------------------------------------------------------------- #
#   Branchement : Action sur Champs : Chapitre de Message                #
#   dans la fonction de Tradution des Menus locaux : ALOCTRAD            #
# =>Cette action permet de lancer une fenêtre de critères permetant ensuite
#   de lancer une action de sélection dans liste donnant les Chapitre à Traduire
##########################################################################
#JPGA 19/02/2013 EXI-87047-2 : Création d'une Sélection des Menus Locaux et Messages A traduire
##########################################################################
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "TIT"      : Gosub TIT
  When "DEBUT"    : Gosub DEBUT
  When "EXEC"     : Gosub EXEC
  When "SORTIE"   : Gosub SORTIE
  When  Default
Endcase
Return

##########################################################################
# ACTIONS DU MODELE : TRAITEMENT STANDARD - BOITE DE DIALOGUE            #
##########################################################################
######################################################################################
$OUVRE
  If !clalev([M:ALTC]) : Local Mask ASELOCCRIT [ALTC] : Endif
Return

######################################################################################
$TIT
Return

######################################################################################
$DEBUT
  If PARAM(1)="" | PARAM(2)=""
    GMESSAGE=mess(232,123,1)  : GERR=1 : Return  # Variable paramètre inexistante
  Else
    Raz [M:ALTC]
    [M:ALTC]LAN       = PARAM(1)
    [M:ALTC]LANREF    = PARAM(2)
    [M:ALTC]ALLMOD    = 2
    [M:ALTC]ALLCHPUSR = 2

    Call AM_ALLMOD([M:ALTC]ALLMOD)
    Call AM_ALLCHPUSR([M:ALTC]ALLCHPUSR)
    Affzo [M:ALTC]ALLMOD, MODULE, ALLCHPUSR, CHPUSR
  Endif
Return

######################################################################################
$EXEC
  # ASELOCTRAD_VALUE est la variable globale Valorisée par l'Action de Sélection dans liste : ASELOCTRAD
  If dim([V]ASELOCTRAD_VALUE)>0
    VALEUR=[V]ASELOCTRAD_VALUE
  Endif
Return

######################################################################################
$SORTIE
Return

#* #######################################################################
#* LISTE DES ETIQUETTES UTILES                                           #
#* #######################################################################
$GRISAGE_MODULE
  If [M:ALTC]ALLMOD = 2
    Raz   [M:ALTC]MODULE
    Grizo [M:ALTC]MODULE
  Else
    Actzo [M:ALTC]MODULE
  Endif
Return

$GRISAGE_OPERATEUR
  If [M:ALTC]ALLCHPUSR = 2
    Raz   [M:ALTC]CHPUSR
    Grizo [M:ALTC]CHPUSR
  Else
    Actzo [M:ALTC]CHPUSR
  Endif
Return
##########################################################################

#* #######################################################################
#* SOUS-PROGRAMMES UTILISES                                              #
#* #######################################################################
#                :                                                       #
##########################################################################
##########################################################################


#* #######################################################################
#* LISTE DES FONCTIONS UTILES                                            #
#* #######################################################################
#                :                                                       #
##########################################################################
##########################################################################

#* #######################################################################
#* ACTIONS SUR CHAMPS UTILES                                             #
#* #######################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ASELOCCRIT) 19/02/2013 08:50:46 (JPGA)
######################################################################################
Subprog AM_ALLMOD(VALEUR)
Variable Integer VALEUR

  [M:ALTC]ALLMOD=VALEUR
  Gosub GRISAGE_MODULE
End

############################################################
Subprog AM_ALLCHPUSR(VALEUR)
Variable Integer VALEUR

  [M:ALTC]ALLCHPUSR=VALEUR
  Gosub GRISAGE_OPERATEUR
End
######################################################################################
