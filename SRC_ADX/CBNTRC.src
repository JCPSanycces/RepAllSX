############################################################
# Routines diverses de trace du CBN/PDP
############################################################
# TRCBUC   Trace détaillée des buckets/périodes CBN/PDP
############################################################

############################################################
# Trace détaillée des buckets/périodes CBN/PDP
# LDAT = Date début traitement
# LCAP = Tableau capacités calendrier
# LBUN = tableau des numéros de bucket
# LBUC = tableau des capacités buckets
# LBUD = Tableau dates début bucket
# LBUF = Tableau dates fin   buckets
# LTYP = Tableau des types de buckets                    # 11.05 33236
# LDAY = Nombre de buckets jours
# LWEE = Nombre de buckets semaines ( 7 jours)
# LMON = Nombre de buckets mois     (30 jours)
Subprog TRCBUC(LDAT,LCAP,LBUN,LBUC,LBUD,LBUF,LTYP,LJOU,LDAY,LWEE,LMON)
Variable Date    LDAT
Variable Decimal LCAP()
Variable Integer LBUN()
Variable Integer LBUC()
Variable Date    LBUD()
Variable Date    LBUF()
Variable Integer LTYP()                                
Variable Integer LJOU
Variable Integer LDAY
Variable Integer LWEE
Variable Integer LMON
#
Local  Char   WMSG(120)
Local Integer WNBBUC : WNBBUC = LDAY+LWEE+LMON
Local Integer K : K=0

While K < WNBBUC 
  WMSG = "Bucket ("+mess(LTYP(K),2226,1)+") "+num$(K+1)+":"
&        - format$("D:",LBUD(K))+" - "+ format$("D:",LBUF(K))
&        - mess(17,190,1)-num$(LBUC(K))
  Call ECR_TRACE(WMSG,0) From GESECRAN

  K += 1
Wend
End
