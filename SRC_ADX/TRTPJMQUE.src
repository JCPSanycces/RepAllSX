#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Traitement lié à l'action DPJMQUEST
# Issue X3-101833 - 2018-08-01 by FGR
###############################################################################
$ACTION
  Case ACTION
    When "INIT"          : Gosub INIT
    When "DEBUT"         : Gosub DEBUT
    When "BOUTON"        : Gosub BOUTON
  Endcase
Return

###############################################################################
$INIT
  Case GACTION
    When "DPJMQUEST"     : Gosub INIT_DPJMQUEST
  Endcase
Return

###############################################################################
$DEBUT
  Case GACTION
    When "DPJMQUEST"     : Gosub DEBUT_DPJMQUEST
  Endcase
Return

###############################################################################
$BOUTON
  Case GACTION
    When "DPJMQUEST"     : Gosub BOUTON_DPJMQUEST
  Endcase
Return

###############################################################################
########################### ACTION DPJMQUEST ##################################
###############################################################################
$INIT_DPJMQUEST
  If GIMPORT or dim(GSPJMMSG) < 0 Then
    # import or message not define : out
    FIN = 1
  Endif
Return

###############################################################################
$DEBUT_DPJMQUEST
  [M:MSG]TEXTE = GSPJMMSG
  Affzo [M:MSG]TEXTE
Return

###############################################################################
$BOUTON_DPJMQUEST
Local Char PJTACTION(GLONDCO)

  PARAM(1) = BOUT
  FIN = 1
Return

###############################################################################
Funprog ASK_QUESTION_MESSAGE(IDEFAULT)
Value Integer IDEFAULT

Local Integer IARENDRE

  If !GWEBSERV Then
    ## Action DPJMQUEST
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    Local Integer IRETBOUT
    Local Date VALEUR

    SAVACT = GACTION : GACTION = "DPJMQUEST"
    PARMSK(1) = num$(IDEFAULT)
    Call TRAITE_DAT(VALEUR,PARMSK,"","TRTPJMQUE","DPJMQUESTION",4,"") From GTRAITE
    IARENDRE = val(PARMSK(1))
    GACTION = SAVACT
  Endif
End IARENDRE

