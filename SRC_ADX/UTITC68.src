#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# Created by : RICAR
# Date       : 14/01/2015
# Tool to feed the field INVPRODTYP in table ITMMASTER and ITMCATEG
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC68: Default values for INVPRODTYP in ITMMASTER and ITMCATEG") From LECFIC
  Call EXE_UTITC68(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog EXE_UTITC68(APPLI)
Value Char APPLI

Local File = APPLI + ".ACTIV" [ACV]
If func AFNC.ACTIV("KPO") <> 1
  End
Endif

#----- Setting global variable GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =APPLI+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#Tool for ITMMASTER - BEGIN
Local File = APPLI + ".ITMMASTER" [ITM]

Call ECR_TRACE("UTITC68 ITM: Process Start on : " + APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC68_ITM
Call ECR_TRACE("UTITC68 ITM: Process End on : " + APPLI,0) From GESECRAN
#Tool for ITMMASTER - END

#Tool for ITMCATEG - BEGIN
Local File = APPLI + ".ITMCATEG" [ITG]

Call ECR_TRACE("UTITC68 ITG: Process Start on : " + APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC68_ITG
Call ECR_TRACE("UTITC68 ITG: Process End on : " + APPLI,0) From GESECRAN
#Tool for ITMMASTER - END

Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE("The tables products and products category were updated."-mess(173,7711,1),0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN

End
########################################
#### Tool ITMMASTER - Begin         ####
########################################
$TR_UTITC68_ITM

Local Shortint RUPD          : RUPD          = 0
Local Shortint NUPD          : NUPD          = 0  #RMA * 111472

Local Shortint STOP
Local Integer  COUNTER
Local Char     KEY1(20), CRITERE(90)

$B_TRT_ITM
If  STOP=1
    CRITERE = '[F:ITM]ITMREF>"'+KEY1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
Raz COUNTER

Trbegin [F:ITM]
  For [F:ITM] Where [F:ITM]INVPRODTYP = 0 &
&            (pat([F:ITM]ACCCOD,"PT_MERCAD*") <>0 | pat([F:ITM]ACCCOD,"MERCAD*")    <>0 |
&             pat([F:ITM]ACCCOD,"PT_MATPRIM*")<>0 | pat([F:ITM]ACCCOD,"MATPRIM*")   <>0 |
&             pat([F:ITM]ACCCOD,'PT_MATDIV*') <>0 | pat([F:ITM]ACCCOD,'MATDIV*')    <>0 |
&             pat([F:ITM]ACCCOD,'PT_MATSUB*') <>0 | pat([F:ITM]ACCCOD,'MATSUB*')    <>0 |
&             pat([F:ITM]ACCCOD,'PT_EMBALAG*')<>0 | pat([F:ITM]ACCCOD,'EMBALAG*')   <>0 |
&             pat([F:ITM]ACCCOD,'PT_MATSUBS*')<>0 | pat([F:ITM]ACCCOD,'MATSUBS*')   <>0 |
&             pat([F:ITM]ACCCOD,'PT_PRDACAB*')<>0 | pat([F:ITM]ACCCOD,'FINPRODUCT*')<>0 |
&             pat([F:ITM]ACCCOD,'PT_REFUGOS*')<>0 | pat([F:ITM]ACCCOD,'REFUGOS*')   <>0 |
&             pat([F:ITM]ACCCOD,'PT_SUBPROD*')<>0 | pat([F:ITM]ACCCOD,'SUBPROD*')   <>0) &
&            evalue(CRITERE)
    # Run update
    RUPD = 0

    If pat([F:ITM]ACCCOD,"PT_MERCAD*")<>0 | pat([F:ITM]ACCCOD,"MERCAD*")<>0
      [F:ITM]INVPRODTYP = 1
      RUPD              = 1
    Elsif pat([F:ITM]ACCCOD,"PT_MATPRIM*")<>0 | pat([F:ITM]ACCCOD,"MATPRIM*")<>0 | pat([F:ITM]ACCCOD,'PT_MATDIV*') <>0 | pat([F:ITM]ACCCOD,'MATDIV*') <>0
&       | pat([F:ITM]ACCCOD,'PT_MATSUB*') <>0 | pat([F:ITM]ACCCOD,'MATSUB*') <>0 | pat([F:ITM]ACCCOD,'PT_EMBALAG*')<>0 | pat([F:ITM]ACCCOD,'EMBALAG*')<>0
&       | pat([F:ITM]ACCCOD,'PT_MATSUBS*')<>0 | pat([F:ITM]ACCCOD,'MATSUBS*')<>0
      [F:ITM]INVPRODTYP = 2
      RUPD              = 1
    Elsif pat([F:ITM]ACCCOD,'PT_PRDACAB*')<>0 | pat([F:ITM]ACCCOD,'FINPRODUCT*')<>0
      [F:ITM]INVPRODTYP = 3
      RUPD              = 1
    Elsif pat([F:ITM]ACCCOD,'PT_REFUGOS*')<>0 | pat([F:ITM]ACCCOD,'REFUGOS*')<>0 | pat([F:ITM]ACCCOD,'PT_SUBPROD*')<>0 | pat([F:ITM]ACCCOD,'SUBPROD*')<>0
      [F:ITM]INVPRODTYP = 4
      RUPD              = 1
    Endif

    If RUPD = 1
      Rewrite [F:ITM]
      If fstat
        Call ECR_TRACE("File ITMMASTER"-[F:ITM]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
      Endif

      COUNTER+=1
      If COUNTER>GMAXUPDTRS : KEY1=[F:ITM]ITMREF : STOP=1 : Break : Endif
    Else
      NUPD = 1 #RMA * 111472
    Endif
  Next
Commit

If STOP Goto B_TRT_ITM : Endif

Return
########################################
#### Tool ITMMASTER - End         ######
########################################

########################################
#### Tool ITMCATEG - Begin          ####
########################################
$TR_UTITC68_ITG

Local Shortint RUPD          : RUPD          = 0
Local Shortint NUPD          : NUPD          = 0   #RMA * 111472

Trbegin [F:ITG]
For [F:ITG] Where [F:ITG]INVPRODTYP = 0 &
&          (pat([F:ITG]ACCCOD,"PT_MERCAD*") <>0 | pat([F:ITG]ACCCOD,"MERCAD*")    <>0 |
&           pat([F:ITG]ACCCOD,"PT_MATPRIM*")<>0 | pat([F:ITG]ACCCOD,"MATPRIM*")   <>0 |
&           pat([F:ITG]ACCCOD,'PT_MATDIV*') <>0 | pat([F:ITG]ACCCOD,'MATDIV*')    <>0 |
&           pat([F:ITG]ACCCOD,'PT_MATSUB*') <>0 | pat([F:ITG]ACCCOD,'MATSUB*')    <>0 |
&           pat([F:ITG]ACCCOD,'PT_EMBALAG*')<>0 | pat([F:ITG]ACCCOD,'EMBALAG*')   <>0 |
&           pat([F:ITG]ACCCOD,'PT_MATSUBS*')<>0 | pat([F:ITG]ACCCOD,'MATSUBS*')   <>0 |
&           pat([F:ITG]ACCCOD,'PT_PRDACAB*')<>0 | pat([F:ITG]ACCCOD,'FINPRODUCT*')<>0 |
&           pat([F:ITG]ACCCOD,'PT_REFUGOS*')<>0 | pat([F:ITG]ACCCOD,'REFUGOS*')   <>0 |
&           pat([F:ITG]ACCCOD,'PT_SUBPROD*')<>0 | pat([F:ITG]ACCCOD,'SUBPROD*')   <>0)
  # Run update
  RUPD = 0

  If pat([F:ITG]ACCCOD,"PT_MERCAD*")<>0 | pat([F:ITG]ACCCOD,"MERCAD*")<>0
    [F:ITG]INVPRODTYP = 1
    RUPD              = 1
  Elsif pat([F:ITG]ACCCOD,"PT_MATPRIM*")   <>0 | pat([F:ITG]ACCCOD,"MATPRIM*")<>0 | pat([F:ITG]ACCCOD,'PT_MATDIV*') <>0| pat([F:ITG]ACCCOD,'MATDIV*') <>0
&     | pat([F:ITG]ACCCOD,'PT_MATSUB*') <>0 | pat([F:ITG]ACCCOD,'MATSUB*') <>0 | pat([F:ITG]ACCCOD,'PT_EMBALAG*')<>0| pat([F:ITG]ACCCOD,'EMBALAG*')<>0
&     | pat([F:ITG]ACCCOD,'PT_MATSUBS*')<>0 | pat([F:ITG]ACCCOD,'MATSUBS*')<>0
    [F:ITG]INVPRODTYP = 2
    RUPD              = 1
  Elsif pat([F:ITG]ACCCOD,'PT_PRDACAB*')<>0 | pat([F:ITG]ACCCOD,'FINPRODUCT*')<>0
    [F:ITG]INVPRODTYP = 3
    RUPD              = 1
  Elsif pat([F:ITG]ACCCOD,'PT_REFUGOS*')<>0 | pat([F:ITG]ACCCOD,'REFUGOS*')<>0 | pat([F:ITG]ACCCOD,'PT_SUBPROD*')<>0 | pat([F:ITG]ACCCOD,'SUBPROD*')<>0
    [F:ITG]INVPRODTYP = 4
    RUPD              = 1
  Endif

  If RUPD = 1
    Rewrite [F:ITG]
    If fstat
      Call ECR_TRACE("File ITMCATEG"-[F:ITG]ITMREF+";"+[F:ITG]STOFCY+", Error ="-num$(fstat),1) From GESECRAN
    Endif
  Else
    NUPD = 1 #RMA * 111472
  Endif
Next
Commit

Return
########################################
#### Tool ITMCATEG - End          ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC68(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier to update
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC68(APPLI)
End

