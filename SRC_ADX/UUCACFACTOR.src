#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
## DEMANDE 51502
##
##  L'utilitaire pour créer les lignes de codes comptables FACTOR
##
##############################################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".GACCCODLIG" [CCL]
Filter [CCL] Where TYP=21
Read [CCL] First
If !fstat : Goto FIN : Endif

Trbegin  [CCL]

Raz [CCL]
[F:CCL]TYP    = 21
[F:CCL]NUMLIG = 1
[F:CCL]OBL    = 2
[F:CCL]TXT    = 132
[F:CCL]TYPCPT = 1
[F:CCL]TYPDES = 21
Write [CCL]
If fstat : Rollback : Goto FIN : Endif

Raz [CCL]
[F:CCL]TYP    = 21
[F:CCL]NUMLIG = 2
[F:CCL]OBL    = 1
[F:CCL]TXT    = 133
[F:CCL]TYPCPT = 3
[F:CCL]TYPDES = 21
Write [CCL]
If fstat : Rollback : Goto FIN : Endif

Raz [CCL]
[F:CCL]TYP    = 21
[F:CCL]NUMLIG = 3
[F:CCL]OBL    = 1
[F:CCL]TXT    = 133
[F:CCL]TYPCPT = 1
[F:CCL]TYPDES = 21
Write [CCL]
If fstat : Rollback : Goto FIN : Endif

Commit 

$FIN
Filter [CCL]
Close Local File
End


