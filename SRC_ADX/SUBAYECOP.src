#<AdxTL>@(#)10.0.0.0 $Revision$
#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Entité
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTENT    [AYE1]
 Local File ATEXTE    [ATX1]
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTENT"     [AYE1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".AYTLINES"   [AYN1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTENT     [AYE2]
 Local File ATEXTE     [ATX2]
 Local File AYTLINES   [AYN2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTENT"     [AYE2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".AYTLINES"   [AYN2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYE1]AYE0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYE1",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYE2]AYE0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYE2]ENTCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYE1], [ATX1], [AYN1], [AXX1]
&              , [AYE2], [ATX2], [AYN2], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYE2] , [ATX2], [AYN2]
 If DES_HASELT
     Delete [AYN2] Where FCYCOD=[L]FCYDES  & LINCODTYP=1 & LINCOD=toupper([L]DES_ELTCOD)
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLIN" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_COP
     Endif
     Delete [AYE2] Where FCYCOD=[L]FCYDES and ENTCOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTENT" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYE2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif
 #
 For [AYE1]AYE0 Where FCYCOD=[L]FCYORG & ENTCOD=[L]ELTCOD
  [F:AYE2] = [F:AYE1]
  [F:AYE2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTENT","INTIT",[F:AYE1]FCYCOD,[F:AYE1]ENTCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYE2]UPDUSR = GUSER
  [F:AYE2]UPDDAT = date$
_  # [F:AYE2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYE2") From AYTCOP # 93575
  [F:AYE2]BRWX3  = [F:AYE2]FCYCOD+"_"+[F:AYE2]ENTCOD
#*  [F:AYE2]CODACT = [L]ELTCODACT
  Write [AYE2]
  If fstat
   GOK=0 : Call FSTA("AYE2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 #
 For [AYN1]AYN0 Where FCYCOD=[L]FCYORG & LINCODTYP=1 & LINCOD=toupper([L]ELTCOD)
  [F:AYN2] = [F:AYN1]
  [F:AYN2]FCYCOD = [L]FCYDES
  Write [AYN2]
  If fstat
   GOK=0 : Call FSTA("AYN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
