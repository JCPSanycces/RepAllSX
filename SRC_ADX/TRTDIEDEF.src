#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("DIE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
 When "CONTROLE" : Gosub CONTROLE
 When "TERMINE"  : Gosub FIN
Endcase
Return


$INIT
Local Char WDIE(GLONDIE) : WDIE =PARAM(1)
Local Char WOBJ(GLONAOB) : WOBJ =PARAM(2)

Local Char    WCCE(GLONCCE)

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30)

If clalev([F:DIE]) = 0 : Local File GDIE                 [DIE] : Endif
If clalev([F:CCE]) = 0 : Local File =GTABCPT+"CACCE"     [CCE] : Endif
Return


$CONTROLE
TMP = 1 : # Pour afficher des tempon/tempoff
Return

$FIN
TRA = 1 : # Pour lire la trace
Return


$EXEC
Call OUVRE_VLC(mess(48,105,1),"","") From GESECRAN # Sections
Call OUVRE_TRACE(mess(48,105,1)) From LECFIC
Gosub STR_TRA
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Call FERME_TRACE From LECFIC
Call FERME_VLC From GESECRAN
Return


$TR_EXEC
Local Char    NOMDOS(20)(1..255)
Local Integer OK, I , NDOS, LG , OKTRT
Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Integer PSUB , PSPE , PSPV , PSTD
Local Char    SVSUPP(250), SAVFONC(GLONAFC) , IDENT(250), OIDENT(250), DEFMSK(250)
Local Char    ABREV(GLONAOB)
Local Char    SUPP(250)(16), SVSUPP(250)
Local Char    PCLE1(250), PCLE2(250) , NEWCOD(250)
Local Integer SILENCE

Call SETPROG(WOBJ,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
I = dim(NOMDOS)
NDOS = 1 : NOMDOS(NDOS) = nomap(0)
If GDOSH<>""
 NDOS += 1 : NOMDOS(NDOS) = GDOSH
Endif

If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif

Local File AOBJET [AOB_] , ATABLE [ATB_] , ATABZON [ATZ_] , ATEXTE [ATX] , ATEXTRA [AXX]

ABREV = WOBJ
Read [AOB_]ABREV = WOBJ
If fstat : FIN=1 : Return : Endif
Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : FIN=1 : Return : Endif

Gosub NOMFIC From =PROGOBJ
Gosub TIT    From =PROGOBJ
Gosub SETCLE From =PROGOBJ

Local File =NOMFIC [CR__]
Gosub OUVFIC From =PROGOBJ

Gosub SET_FIRST From TRTFIRST 
If [M:DIA]DIECRE=2
 Gosub WRIDIE
Endif
If [M:DIA]DIEDEL=2
 Gosub DELDIE
Endif
Gosub UNSET_FIRST From TRTFIRST

# Mise à jour Pyramide
Call MAJ_AXE(WDIE,nomap) From LIENPYRCCE

Return

$AB_EXEC
Rollback
Return

$ROLL_EXEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXEC : Endif
Return

$STR_TRA
Local Char DESIG(GLONAX3)
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call LECTEXTRA([L]DESIG,"GDIE","DESTRA",WDIE,"") From ATEXTRA
Call ECR_TRACE(WDIE-[L]DESIG,0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Onerrgo ERREUR From CONTROLE
 If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0
Else
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Local Char    LIBZON(80)
 Read [AMZ]CODE = "DIEDEF";"DIECRE"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]DIECRE,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Read [AMZ]CODE = "DIEDEF";"DIEDEL"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]DIEDEL,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Call ECR_TRACE(mess(27,107,1)-":"-mess([M]SIM,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return


$WRIDIE

Call LECTURE("DIE",WDIE,"") From CONTOBJ
Call INICCEFMT(WDIE) From SETGLBDIE

Raz STOP

$LOOP_CCE
GOK = 1 
Raz NB
If STOP
 Raz STOP
 CRITERE = CLEPRIM+">'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [CCE]


For [CR__] Where evalue(CRITERE)

 WCCE = evalue("[F:CR__]"+CLEPRIM)
 WCCE = vireblc(format$(GCCEFMT,WCCE),2)
 If WCCE<>""
  Read [F:CCE]CCE0 = [F:DIE]DIE;WCCE
  If fstat
   Call AFF_VLC([F:DIE]DIE,WCCE) From GESECRAN
   Raz [F:CCE]
   [F:CCE]DIE = [F:DIE]DIE
   [F:CCE]CCE = WCCE
   If dim([F:CR__]DES)>0
    [F:CCE]DES = [F:CR__]DES
   Endif
   If dim([F:CR__]DESSHO)>0
    [F:CCE]DESSHO = [F:CR__]DESSHO
   Endif
   If WOBJ="BPR"
    [F:CCE]DES = [F:CR__]BPRNAM
    [F:CCE]DESSHO = [F:CR__]BPRSHO
   Elsif WOBJ="BPS"
    [F:CCE]DES = [F:CR__]BPSNAM
    [F:CCE]DESSHO = [F:CR__]BPSSHO
   Elsif WOBJ="BPC"
    [F:CCE]DES = [F:CR__]BPCNAM
    [F:CCE]DESSHO = [F:CR__]BPCSHO
   Endif
   [F:CCE]ENAFLG = 2
 
   If dim([F:CCE]BUDTRK)>0 : [F:CCE]BUDTRK = 1         : Endif
   If dim([F:CCE]IPT)>0    : [F:CCE]IPT = 2            : Endif
   If dim([F:CCE]CREDAT)>0 : [F:CCE]CREDAT = date$     : Endif
   If dim([F:CCE]CREUSR)>0 : [F:CCE]CREUSR = GUSER     : Endif
   If dim([F:CCE]EXPNUM)>0 : [F:CCE]EXPNUM = [C]EXPORT : Endif
   Write [CCE]
   If fstat
    GOK = 0 : Call FSTA("CCE") From GLOCK : Break
   Else
    NB+=1
    # Création
    Call ECR_TRACE(mess(59,123,1)-[F:CCE]DIE-[F:CCE]CCE,0) From GESECRAN
   Endif
   If    GOK<0 : Goto ROLL_EXEC
   Elsif !GOK  : Goto AB_EXEC
   Endif

   Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
   If GOK<1 : Break : Endif
   Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
   If GOK<1 : Break : Endif
  Endif
 Else
  # Format incorrect - Création impossible
  Call ECR_TRACE(WDIE-evalue("[F:CR__]"+CLEPRIM)-mess(112,123,1)-":"-mess(7,123,1),0) From GESECRAN
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = WCCE
  STOP=1
  Break
 Endif
Next

If [M]SIM=2
 Rollback
Else
 Commit
Endif
If STOP
 Goto LOOP_CCE
Endif
Return


$DELDIE
[G]currind = 1
[G]currlen = 0


Raz STOP
Filter [CCE] Where DIE=WDIE
$LOOP_OBJ
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:CCE]CCE>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CCE]

For [CCE] Where evalue(CRITERE)

 
 Assign "[F:CR__]"+CLEPRIM With [F:CCE]CCE
 Read [F:CR__] = 
 If fstat

  Delete [CCE] Curr
  If fstat
   Call ERREUR([F:CCE]CCE,3) From DOSDIC
  Else
   NB+=1
   # Suppression 
   Call ECR_TRACE(mess(53,123,1)-[F:CCE]DIE-[F:CCE]CCE,0) From GESECRAN
  Endif
 Endif
 If NB>GMAXUPDTRS
  ACLE1 = evalue("[F:CR__]"+CLEPRIM)
  STOP=1
  Break
 Endif
Next

If [M]SIM=2
 Rollback
Else
 Commit
Endif
If STOP
 Goto LOOP_OBJ
Endif
Filter [CCE]
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran DIEDEF) 12/03/2014 14:17:41
######################################################################################
Subprog AS_SIM(VALEUR)
Variable Integer VALEUR
If [M]DIECRE<>2 & [M]DIEDEL<>2
 VALEUR = 1
 mkstat = 2 : End
Endif 
End


######################################################################################

