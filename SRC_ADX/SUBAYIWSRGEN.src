Subprog AS_CODACT(VALEUR)
Variable Char    VALEUR()
If find([M:DIA]TYP,3,21)
 Effzo [M]CODACT
 Grizo [M]CODACT
Else
 Actzo [M]CODACT
Endif
End

Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
If find([M:DIA]TYP,3,21)
 Effzo [M]MODULE
 Grizo [M]MODULE
Else
 Actzo [M]MODULE
Endif
End


Subprog AS_TYPASU(VALEUR)
Variable Integer VALEUR
If find([M:DIA]TYP,3,21)
 Effzo [M:DIA]TYPASU
 Grizo [M:DIA]TYPASU
Else
 Actzo [M:DIA]TYPASU
Endif
End

Subprog AM_RESMAX(VALEUR)
Variable Decimal VALEUR
If find([M:DIA]TYP,1,4)
 Local Integer I
 For I=0 To [M:DIA]NBZONE-1
  [M:DIA]DIME(I) = VALEUR
 Next I
 Affzo [M:DIA]DIME
Endif
End

Subprog AV_NBZONE
If find([M:DIA]TYP,1,4)
 Grizo [M:DIA]DIME
Endif
If find([M:DIA]TYP,1,4,3,21)
 Grizo [M:DIA]CODLNG
Endif
End

Subprog AM_GRP(VALEUR)
Variable Char    VALEUR()
If find([M:DIA]TYP,1,4)
 Local Integer I
 For I=0 To [M:DIA]NBZONE-1
  [M:DIA]GRP(I) = VALEUR
 Next I
 Affzo [M:DIA]GRP
Endif
End

Subprog AM_DIME(VALEUR)
Variable Decimal VALEUR
Local Integer I
For I=0 To [M:DIA]NBZONE-1
 If [M:DIA]GRP(I) = [M:DIA]GRP(nolign-1)
  [M:DIA]DIME(I) = VALEUR
 Endif
Next I
Affzo [M:DIA]DIME
End


