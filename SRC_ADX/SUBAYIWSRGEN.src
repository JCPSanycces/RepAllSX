Subprog AV_SUBPRG(VALEUR)
Variable Char    VALEUR()
If !find([M:DIA]TYP,2,20)
 Local Integer WI
 Call EXISTE_ADX("","",[M:DIA]PRG,WI) From ORDSYS  # En action chp car non possible dans INI_DIA
 If WI
  Diszo [M:DIA]PRG
 Endif
Endif
End

