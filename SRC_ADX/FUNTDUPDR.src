########################################
Subprog C_OPEUOM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=2 : Endif
End

########################################
Subprog AM_OPEUOM(VALEUR)
Variable Char    VALEUR()
Local Decimal WCOEFF

# recherche coefficient US/UO
Read [ITM]ITM0=[M]ITMREF(nolign-1)
If !fstat
    Call RECH_COEFF([F:ITM]STU, VALEUR, WCOEFF) From MFGLIB
    If WCOEFF <> 0
        [M]OPESTUCOE(nolign-1) = WCOEFF
        [M]PACOEF1(nolign-1) = 0
    Else
        [M]OPESTUCOE(nolign-1) = 1
        Call MESSAGE(mess(150,190,1)-"("-VALEUR-","-[F:ITM]STU+")") From GESECRAN
        [M]PACOEF1(nolign-1) = 1
    Endif
Endif
End

########################################
Subprog AV_SCOWST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste de sous-traitance
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
    [M]SCOWCR(nolign-1)=[F:MWS]WCR : [M]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

