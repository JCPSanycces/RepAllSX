End

########################################
Subprog AV_WST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste de charge principal
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
  [M]WCR(nolign-1)=[F:MWS]WCR : [M]WSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

########################################
Subprog AV_LABWST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste main-d'oeuvre
If [M]WSTTYP(nolign-1)=3
    VALEUR="" : [M]LABWCR(nolign-1)="" : [M]LABWSTTYP(nolign-1)=0
Endif
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
    [M]LABWCR(nolign-1)=[F:MWS]WCR : [M]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

########################################
Subprog AV_ROOTIMCOD(VALEUR)
Variable Integer VALEUR
# si type tps opératoire = unitaire, seul le temps opératoire est saisi
# si type tps opératoire = cadence, seule la cadence est saisie
# ici, remise à zéro des tps non saisis
If VALEUR <> 0
   If VALEUR = 2
      [M]OPETIM(nolign-1)=0
   Else
      [M]CAD(nolign-1)=0
   Endif
   If VALEUR<>1
      [M]TIMCOD(nolign-1)=0
      [M]BASQTY(nolign-1)=0
   Endif
Endif
End

########################################
Subprog AS_OPETIM(VALEUR)
Variable Decimal VALEUR
If [M]ROOTIMCOD(nolign-1)=2
    mkstat = 2
Endif
End

########################################
Subprog AS_CAD(VALEUR)
Variable Decimal VALEUR
If [M]ROOTIMCOD(nolign-1)<>2
    mkstat = 2
Endif
End

########################################
# GH 10/01/2014 bug 94924
Subprog C_CAD(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

########################################
Subprog C_WSTNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : End : Endif
If [M]WST(nolign-1) <> ""
    Read [MWS]WST0=[M]WST(nolign-1);[M]MFGFCY
    If VALEUR > [F:MWS]WSTNBR
        GMESSAGE = mess(165,193,1) : mkstat = 2
    Endif
Endif
End

########################################
Subprog AS_LABNBR(VALEUR)
