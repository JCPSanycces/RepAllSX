#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque TDUPDR1
#################################################################################
#                                                                               #
#    MODELISATION E-COMMERCE                                                    #
#                                                                               #
# ACTION  : TRTTDUPDR  : Action traitement modification des opérations          #
#                                                                               #
#################################################################################

########################################################################
#    Détail des actions                                                #
########################################################################
# Issue X3-56992 - 2017-10-13 by BAKHA : block versioned routes from mass update
# Issue X3-60368 - 2017-10-19 by BAKHA : write not selected versioned routes to log

$ACTION
Case ACTION
 When "OUVRE"        : Case GACTION
                           When "SAITDUPDR" : Gosub OUVRE
                       Endcase
 When "SETBOUT"      : Gosub SETBOUT
 When "DEBUT"        : Case GACTION
                           When "SAITDUPDR" : Gosub S_DEBUT
                           When "TRTTDUPDR" : Gosub T_DEBUT
                       Endcase
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "ENR"          : Case GACTION
                           When "TRTTDUPDR" : Gosub ENREGISTRE
                       Endcase
 When "ABA"          : Gosub ABORT
 When "TERMINE"      : Gosub TERMINE
 When "FIN"          : Gosub FIN
Endcase
Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$OUVRE
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING     [ROH] : Endif
If clalev([F:ROO])  = 0 : Local File ROUOPE      [ROO] : Endif
If clalev([F:TRO])  = 0 : Local File TABROUALT   [TRO] : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO] : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM] : Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Return

#######################################################################
$SETBOUT
Raz ETABOU
ETABOU(GVALI) = 1
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
Return

#######################################################################
$S_DEBUT
Raz [M:TUR0]
Raz [M:TUR1]
Raz [M:TUR2]
Raz [M:TUR3]
[M:TUR0]MFGFCY = GFCY
[M:TUR0]REPLACEFLG =1

[M:TUR1]SCOCODDEB = 1
[M:TUR1]SCOCODFIN = 3


Grizo [TUR2]SETTIMF    : Grizo [TUR2]SETTIMV
Grizo [TUR2]OPETIMF    : Grizo [TUR2]OPETIMV
Grizo [TUR2]CADF       : Grizo [TUR2]CADV
Grizo [TUR2]SETLABCOEF : Grizo [TUR2]SETLABCOEV
Grizo [TUR2]OPELABCOEF : Grizo [TUR2]OPELABCOEV
Grizo [TUR2]PRPTIMF    : Grizo [TUR2]PRPTIMV
Grizo [TUR2]WAITIMF    : Grizo [TUR2]WAITIMV
Grizo [TUR2]PSPTIMF    : Grizo [TUR2]PSPTIMV
Grizo [TUR2]WSTNBRF    : Grizo [TUR2]WSTNBRV
Grizo [TUR2]LABNBRF    : Grizo [TUR2]LABNBRV
Grizo [TUR3]OPEUOMV
Grizo [TUR3]EFFF       : Grizo [TUR3]EFFV
Grizo [TUR3]SHRF       : Grizo [TUR3]SHRV

Grizo [TUR0]APPDAT
Affzo [TUR1]1-99
Affzo [TUR2]1-99
Affzo [TUR3]1-99

Return

#########################################################################
$T_DEBUT
Local  Char        CRITERE(250), CRITERE1(250)
Local  Integer     OK, NBOPE, MAJUO, MAJOPE
Local  Date        XAPPDAT
Local  Decimal     WCOEFF
Local  Char        FORMULE1(255), FORMULE2(255)
Local  Integer     WOPENUM, WROUALT
Local  Char        WITMREF(GLONITM)
Local Integer      WMAX

Global Integer WLOGDEL : WLOGDEL = 0 # X3-60368 - Log open ?

Default Mask [TUR4]
WMAX = dim([M:TUR4]WST)     # llc 04.03 17909

Gosub LIRE
If [M:TUR4]NBLIG=0
    GERR=2 : GMESSAGE=mess(147,190,1) : # Aucune opération à traiter
    FIN=1
Else
  # Issue X3-56992 - if routing versioning, the display info message
  If func AFNC.ACTIV("RVM")
    Call MESSAGE(mess(413,193,1)) From GESECRAN
  Endif
  # Issue X3-56992 - end
Endif

Return

#######################################################################
$ENREGISTRE
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN : # Validation de la saisie
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif

Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1) : # Fin de la modification série
Return

#######################################################################
$ABORT
Raz [M:TUR4]
Affzo [TUR4]
Gosub LIRE
Return

#######################################################################
$TERMINE
Call FERME_TRACE From LECFIC
# Issue X3-60368 - view log if any routes processed
If !func AFNC.ACTIV("RVM") | WLOGDEL=1
  Call LEC_TRACE From LECFIC
Endif

Return

#######################################################################
$FIN
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3
Return

#######################################################################
# Selection gammes
$SEL_ROUTING
#--> critères de saisie
CRITERE = ""

If [M:TUR0]MFGFCY <> ""
   CRITERE -= '&FCY="'+[M:TUR0]MFGFCY+'"'
Endif

If [M:TUR1]ROUALTDEB <> 0
   CRITERE -= "&ROUALT>="+num$([M:TUR1]ROUALTDEB)
Endif
If [M:TUR1]ROUALTFIN <> 0
   CRITERE -= "&ROUALT<="+num$([M:TUR1]ROUALTFIN)
Endif

If [M:TUR1]ROUNUMDEB <> ""
   CRITERE -= '&ITMREF>="'+[M:TUR1]ROUNUMDEB+'"'
Endif
If [M:TUR1]ROUNUMFIN <> ""
   CRITERE -= '&ITMREF<="'+[M:TUR1]ROUNUMFIN+'"'
Endif

If [M:TUR1]OPENUMDEB <> 0
   CRITERE -= "&OPENUM>="+num$([M:TUR1]OPENUMDEB)
Endif
If [M:TUR1]OPENUMFIN <> 0
   CRITERE -= "&OPENUM<="+num$([M:TUR1]OPENUMFIN)
Endif

If CRITERE="" : CRITERE="1=1" : Else CRITERE=right$(CRITERE,3) : Endif

CRITERE1 = ""

If [M:TUR1]WSTDEB <> ""
   CRITERE1 -= '&WST>="'+[M:TUR1]WSTDEB+'"'
Endif
If [M:TUR1]WSTFIN <> ""
   CRITERE1 -= '&WST<="'+[M:TUR1]WSTFIN+'"'
Endif

If [M:TUR1]LABWSTDEB <> ""
   CRITERE1 -= '&LABWST>="'+[M:TUR1]LABWSTDEB+'"'
Endif
If [M:TUR1]LABWSTFIN <> ""
   CRITERE1 -= '&LABWST<="'+[M:TUR1]LABWSTFIN+'"'
Endif

If [M:TUR1]SCOCODDEB <> 0
   CRITERE -= "&SCOCOD>="+num$([M:TUR1]SCOCODDEB)
Endif
If [M:TUR1]SCOCODFIN <> 0
   CRITERE -= "&SCOCOD<="+num$([M:TUR1]SCOCODFIN)
Endif

If [M:TUR1]SCOWSTDEB <> ""
   CRITERE1 -= '&SCOWST>="'+[M:TUR1]SCOWSTDEB+'"'
Endif
If [M:TUR1]SCOWSTFIN <> ""
   CRITERE1 -= '&SCOWST<="'+[M:TUR1]SCOWSTFIN+'"'
Endif

If [M:TUR1]SCOITMDEB <> ""
   CRITERE1 -= '&SCOITMREF>="'+[M:TUR1]SCOITMDEB+'"'
Endif
If [M:TUR1]SCOITMFIN <> ""
   CRITERE1 -= '&SCOITMREF<="'+[M:TUR1]SCOITMFIN+'"'
Endif

If CRITERE1="" : CRITERE1="1=1" : Else CRITERE1=right$(CRITERE1,3) : Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

###################################################################################################
## GH 07/05/13 FQ 89280 pour que la formule de sélection s'étende à d'autres tables que ROO et ROH
## Analyse présence formule de sélection

$ANALYSE_FORMULE
Local Integer WITM, WTRO, WITF, WROT, WMWS

If [M:TUR1]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [TFO]TFO0=9;[M:TUR1]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif
If FORMULE1 = "1=1" : Return : Endif

FORMULE2 = vireblc(FORMULE1,4)
Gosub TABLE_FORMULE

# nombre d'exemplaire
If [M:TUR2]FWSTNBR = 2    : FORMULE2 = [M:TUR2]WSTNBRF    : Gosub ANALYSE_FORMULE2 : Endif
# nombre d'exemplaire MO
If [M:TUR2]FLABNBR = 2    : FORMULE2 = [M:TUR2]LABNBRF    : Gosub ANALYSE_FORMULE2 : Endif
# réglage
If [M:TUR2]FSETTIM = 2    : FORMULE2 = [M:TUR2]SETTIMF    : Gosub ANALYSE_FORMULE2 : Endif
# opératoire
If [M:TUR2]FOPETIM = 2    : FORMULE2 = [M:TUR2]OPETIMF    : Gosub ANALYSE_FORMULE2 : Endif
# cadence
If [M:TUR2]FCAD = 2       : FORMULE2 = [M:TUR2]CADF       : Gosub ANALYSE_FORMULE2 : Endif
# coeff. MO réglage
If [M:TUR2]FSETLABCOE = 2 : FORMULE2 = [M:TUR2]SETLABCOEF : Gosub ANALYSE_FORMULE2 : Endif
# coeff. MO opératoire
If [M:TUR2]FOPELABCOE = 2 : FORMULE2 = [M:TUR2]OPELABCOEF : Gosub ANALYSE_FORMULE2 : Endif
# préparation
If [M:TUR2]FPRPTIM = 2    : FORMULE2 = [M:TUR2]PRPTIMF    : Gosub ANALYSE_FORMULE2 : Endif
# attente
If [M:TUR2]FWAITIM = 2    : FORMULE2 = [M:TUR2]WAITIMF    : Gosub ANALYSE_FORMULE2 : Endif
# post-opératoire
If [M:TUR2]FPSPTIM = 2    : FORMULE2 = [M:TUR2]PSPTIMF    : Gosub ANALYSE_FORMULE2 : Endif
# efficience
If [M:TUR3]FEFF = 2       : FORMULE2 = [M:TUR3]EFFF       : Gosub ANALYSE_FORMULE2 : Endif
# perte
If [M:TUR3]FSHR = 2       : FORMULE2 = [M:TUR3]SHRF       : Gosub ANALYSE_FORMULE2 : Endif
Return

$ANALYSE_FORMULE2
If FORMULE2 <>""
   Read [TFO]TFO0 = 9;FORMULE2
   If !fstat
      FORMULE2 = vireblc([F:TFO]FORFOR,4)
      Gosub TABLE_FORMULE
   Endif
Endif
Return

$TABLE_FORMULE
If !WITM & (instr(1,FORMULE2,"[ITM]") | instr(1,FORMULE2,"[F:ITM]"))
   WITM=1
   If !clalev([F:ITM]) : Local File ITMMASTER [ITM]  : Endif
Endif

If !WTRO & (instr(1,FORMULE2,"[TRO]") | instr(1,FORMULE2,"[F:TRO]"))
   WTRO=1
   If !clalev([F:TRO]) : Local File TABROUALT [TRO]  : Endif
Endif

If !WITF & (instr(1,FORMULE2,"[ITF]") | instr(1,FORMULE2,"[F:ITF]"))
   WITF=1
   If !clalev([F:ITF]) : Local File ITMFACILIT [ITF]  : Endif
Endif

If !WROT & (instr(1,FORMULE2,"[ROT]") | instr(1,FORMULE2,"[F:ROT]"))
   WROT=1
   If !clalev([F:ROT]) : Local File ROUOPESTD [ROT]  : Endif
Endif

If !WMWS & (instr(1,FORMULE2,"[MWS]") | instr(1,FORMULE2,"[F:MWS]"))
   WMWS=1
   If !clalev([F:MWS]) : Local File WORKSTATIO [MWS]  : Endif
Endif
Return

###################################################################################################
## GH 07/05/13 FQ 89280 pour que la formule de sélection s'étende à d'autres tables que ROO et ROH

$CONTEXTE_FORMULE
If FORMULE1="1=1" : Return : Endif

If WITM & [F:ITM]ITMREF<>[F:ROO]ITMREF
   Read [ITM]ITM0 = [F:ROO]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

If WITF & ([F:ITF]STOFCY<>[F:ROO]FCY | [F:ITF]ITMREF<>[F:ROO]ITMREF)
   Read [ITF]ITF0 = [F:ROO]ITMREF;[F:ROO]FCY
   If fstat : Raz [F:ITF] : Endif
Endif

If WTRO & [F:TRO]ROUALT<>[F:ROO]ROUALT
   Read [TRO]TBO0 = [F:ROO]ROUALT
   If fstat : Raz [F:TRO] : Endif
Endif

If WROT & ([F:ROT]STDOPENUM<>[F:ROO]STDOPENUM | [F:ROT]FCY<>[F:ROO]FCY)
   Read [ROT]ROT0 = [F:ROO]STDOPENUM;[F:ROO]FCY
   If fstat : Raz [F:ROT] : Endif
Endif

If WMWS & ([F:MWS]WST<>[F:ROO]WST | [F:MWS]WCRFCY<>[F:ROO]FCY)
   Read [MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
   If fstat : Raz [F:MWS] : Endif
Endif
Return

##########################################################################
# Traitement des actions evenementielles
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return

##########################################################################
# Lecture
$LIRE
# Issue X3-56992 - check RVM activity
Local Integer WACTRVM : WACTRVM = func AFNC.ACTIV("RVM")
# Issue X3-56992 - end


REP=""
Raz [M:TUR4]

If GTRACE = ""
    Call OUVRE_TRACE(mess(148,190,1)) From LECFIC : # Modification en série des opérations
Endif

# Issue X3-56992 - if routing versioning, the write info message to log
If WACTRVM # Issue X3-60368
  Call ECR_TRACE(mess(413,193,1) ,0) From GESECRAN
Endif
# Issue X3-56992 - end

[M:TUR4]MFGFCY = [M:TUR0]MFGFCY
Call LECTURE("FCY",[M:TUR4]MFGFCY,"") From CONTOBJ
[M:TUR4]FCYNAM = [F:FCY]FCYNAM

Gosub SEL_ROUTING
If [M:TUR0]REPLACEFLG = 2
   XAPPDAT = [M:TUR0]APPDAT
   Raz WITMREF, WROUALT, WOPENUM
Else
   XAPPDAT = date$
Endif

# --- Positionnement du filtre : # Beryl Site en fin de clé primaire
Link [ROO] With [ROH]ROH0=[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]FCY As [ROX]
&          Where evalue(CRITERE) & evalue(CRITERE1) &
&          (([F:ROH]ROUENDDAT>=XAPPDAT & [F:ROH]ROUENDDAT<>[0/0/0]) |[F:ROH]ROUENDDAT=[0/0/0])
&          Order By Key ROO0


nolign=1
For [ROX]
    If nolign = WMAX : WMAX=-1 : Break : Endif    # llc 04.03 17909

    # Issue X3-56992 - ignore any versioned routes
    If WACTRVM
      If func RVMLIB.NBRCPNROU([F:ROH]ITMREF) > 0
        # Issue X3-60368 - write route to log
        Call ECR_TRACE(mess(63,198,1)-[F:ROH]ITMREF+"/"+num$([F:ROO]OPENUM)+"/"+num$([F:ROO]RPLIND)
&                  -mess(421,193,1), 0) From GESECRAN
        # Issue X3-60368 end
        Goto NXTOPE
      Endif
    Endif
    # Issue X3-56992 - end

    # test si opération issue d'une opération std
    If [F:ROO]STDOPENUM<>0 & [M:TUR1]EFFUPD=1
       Goto NXTOPE
    Endif

    # Test si opération encore valide
    If !(([F:ROO]VALENDDAT >= XAPPDAT & [F:ROO]VALENDDAT<>[0/0/0])| [F:ROO]VALENDDAT=[0/0/0])
       Goto NXTOPE
    Endif

    ## Analyse de la formule de sélection
    Gosub CONTEXTE_FORMULE
    If !evalue(FORMULE1) : Goto NXTOPE : Endif

    [M:TUR4] = [F:ROH]
    [M:TUR4] = [F:ROO]
    If [M:TUR0]REPLACEFLG <> 2
       Gosub MAJ_AFFICH
    Elsif WITMREF<>[M:TUR4]ITMREF(nolign-1)
&       | WROUALT<>[M:TUR4]ROUALT(nolign-1)
&       | WOPENUM<>[M:TUR4]OPENUM(nolign-1)
        WITMREF = [M:TUR4]ITMREF(nolign-1)
        WROUALT = [M:TUR4]ROUALT(nolign-1)
        WOPENUM = [M:TUR4]OPENUM(nolign-1)
       Gosub VARIANTE
    Elsif MAJOPE
       Gosub MAJ_AFFICH
    Endif

    If OK : nolign+=1 : Endif

$NXTOPE
Next

[M:TUR4]NBLIG = nolign - 1
Affzo [TUR4]

# Attention, d'autres enregistrements existent pour ces sélections
If WMAX<0 : Call MESSAGE(mess(168,190,1)) From GESECRAN : WMAX = dim([M:TUR4]WST) : Endif   # llc 04.03 17909

Return

#######################################################################
$VARIANTE
# si l'opération d'indice R est avec DD <= XAPPDAT-1 et DF = vide ou >= XAPPDAT
# on splitte l'opération en 2
# - opération initiale  d'indice R   de DD à XAPPDAT-1 SANS application des modifs
# - nouvelle  opération d'indice R+1 de XAPPDAT à DF   AVEC application des modifs

If [M:TUR4]VALSTRDAT(nolign-1) < XAPPDAT
   Look [ROO]ROO0 = [M:TUR4]MFGFCY;[M:TUR4]ITMREF(nolign-1);[M:TUR4]ROUALT(nolign-1);[M:TUR4]OPENUM(nolign-1);[M:TUR4]RPLIND(nolign-1)+1
   If !fstat
     # Une opération de remplacement existe déjà
     # => On ne peut pas splitter
     # => On affiche les opérations de même no et gamme sans appliquer les modifs
     Call ECR_TRACE(mess(209,197,1)-num$([M:TUR4]OPENUM(nolign-1))+"/"+num$([M:TUR4]RPLIND(nolign-1))+ "/"+
&                  [M:TUR4]ITMREF(nolign-1)-":"-mess(154,190,1), 0) From GESECRAN
     MAJOPE=0
     Return
   Endif
   Gosub MAJ_AFFICH
   [M:TUR4]RPLIND(nolign-1) = [F:ROO]RPLIND+1
   [M:TUR4]VALSTRDAT(nolign-1)= XAPPDAT
   [M:TUR4]CREFLG(nolign-1) = 2
   MAJOPE=1
Else
   Gosub MAJ_AFFICH
   MAJOPE=1
Endif

Return

#######################################################################
$MAJ_AFFICH

# nombre d'exemplaire
If [M:TUR2]FWSTNBR = 2
    If [M:TUR2]WSTNBRF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]WSTNBRF
        If !fstat
            [M:TUR4]WSTNBR(nolign-1) = int(evalue([F:TFO]FORFOR))
        Endif
    Else
        [M:TUR4]WSTNBR(nolign-1) = [M:TUR2]WSTNBRV
    Endif
    If [M:TUR4]WSTNBR(nolign-1) <= 0
       [M:TUR4]WSTNBR(nolign-1) = [F:ROO]WSTNBR
    Elsif [M:TUR4]WST(nolign-1)<>""
       Read [MWS]WST0=[M:TUR4]WST(nolign-1);[F:ROO]FCY
       If [M:TUR4]WSTNBR(nolign-1) >  [F:MWS]WSTNBR : [M:TUR4]WSTNBR(nolign-1) = [F:ROO]WSTNBR : Endif
    Endif
Endif

# nombre d'exemplaire MO
If [M:TUR2]FLABNBR = 2 & [M:TUR4]LABWST(nolign-1) <> ""
    If [M:TUR2]LABNBRF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]LABNBRF
        If !fstat
            [M:TUR4]LABNBR(nolign-1) = int(evalue([F:TFO]FORFOR))
        Endif
    Else
        [M:TUR4]LABNBR(nolign-1) = [M:TUR2]LABNBRV
    Endif
    If [M:TUR4]LABNBR(nolign-1) <= 0
       [M:TUR4]LABNBR(nolign-1) = [F:ROO]LABNBR
    Else
       Read [MWS]WST0=[M:TUR4]LABWST(nolign-1);[F:ROO]FCY
       #If [M:TUR4]LABNBR(nolign-1) >  [F:MWS]WSTNBR : [M:TUR4]LABNBR(nolign-1) = [F:ROO]WSTNBR : Endif : # GH 10/01/2014 bug 94924
       If [M:TUR4]LABNBR(nolign-1) >  [F:MWS]WSTNBR : [M:TUR4]LABNBR(nolign-1) = [F:ROO]LABNBR : Endif
    Endif
Endif

# réglage
If [M:TUR2]FSETTIM = 2
    If [M:TUR2]SETTIMF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]SETTIMF
        If !fstat
            [M:TUR4]SETTIM(nolign-1) = evalue([F:TFO]FORFOR)
        Endif
    Else
        [M:TUR4]SETTIM(nolign-1) = [M:TUR2]SETTIMV
    Endif
    If [M:TUR4]SETTIM(nolign-1) < 0 : [M:TUR4]SETTIM(nolign-1) = [F:ROO]SETTIM : Endif
Endif

# opératoire
If [M:TUR2]FOPETIM = 2 & [M:TUR4]ROOTIMCOD(nolign-1) <> 2
    If [M:TUR2]OPETIMF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]OPETIMF
        If !fstat
            [M:TUR4]OPETIM(nolign-1) = evalue([F:TFO]FORFOR)
        Endif
    Else
        [M:TUR4]OPETIM(nolign-1) = [M:TUR2]OPETIMV
    Endif
    If [M:TUR4]OPETIM(nolign-1) < 0 : [M:TUR4]OPETIM(nolign-1) = [F:ROO]OPETIM : Endif
Endif

# cadence
If [M:TUR2]FCAD = 2 & [M:TUR4]ROOTIMCOD(nolign-1) = 2
    If [M:TUR2]CADF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]CADF
        If !fstat
            [M:TUR4]CAD(nolign-1) = evalue([F:TFO]FORFOR)
            # GH 10/01/2014 bug 94924 déplacée plus bas
            # si la cadence saisie est une constante/formule nulle, il ne faut pas la reprendre
            # If [M:TUR4]CAD(nolign-1) <= 0 : [M:TUR4]CAD(nolign-1) = [F:ROO]CAD : Endif
        Endif
    Else
        [M:TUR4]CAD(nolign-1) = [M:TUR2]CADV
    Endif
    If [M:TUR4]CAD(nolign-1) <= 0 : [M:TUR4]CAD(nolign-1) = [F:ROO]CAD : Endif
Endif

# coeff. MO réglage
If [M:TUR2]FSETLABCOE = 2 & [M:TUR4]LABWST(nolign-1) <> ""
    If [M:TUR2]SETLABCOEF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]SETLABCOEF
        If !fstat
            [M:TUR4]SETLABCOE(nolign-1) = evalue([F:TFO]FORFOR)
            # GH 10/01/2014 bug 94924 déplacée plus bas
            # ce coeff doit pouvoir être remis à zéro via formule
            #If [M:TUR4]SETLABCOE(nolign-1) <= 0 : [M:TUR4]SETLABCOE(nolign-1) = [F:ROO]SETLABCOE : Endif
        Endif
    Else
        [M:TUR4]SETLABCOE(nolign-1) = [M:TUR2]SETLABCOEV
    Endif
    If [M:TUR4]SETLABCOE(nolign-1) < 0 : [M:TUR4]SETLABCOE(nolign-1) = [F:ROO]SETLABCOE : Endif
Endif

# coeff. MO opératoire
If [M:TUR2]FOPELABCOE = 2 & [M:TUR4]LABWST(nolign-1) <> ""
    If [M:TUR2]OPELABCOEF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]OPELABCOEF
        If !fstat
            [M:TUR4]OPELABCOE(nolign-1) = evalue([F:TFO]FORFOR)
        Endif
    Else
        [M:TUR4]OPELABCOE(nolign-1) = [M:TUR2]OPELABCOEV
    Endif
    If [M:TUR4]OPELABCOE(nolign-1) < 0 : [M:TUR4]OPELABCOE(nolign-1) = [F:ROO]OPELABCOE : Endif
Endif

# préparation
If [M:TUR2]FPRPTIM = 2
    If [M:TUR2]PRPTIMF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]PRPTIMF
        If !fstat
            [M:TUR4]PRPTIM(nolign-1) = evalue([F:TFO]FORFOR)
           # GH 10/01/2014 bug 94924 déplacée plus bas
            # ce temps doit pouvoir être remis à zéro via formule
            #If [M:TUR4]PRPTIM(nolign-1) <= 0 : [M:TUR4]PRPTIM(nolign-1) = [F:ROO]PRPTIM : Endif
        Endif
    Else
        [M:TUR4]PRPTIM(nolign-1) = [M:TUR2]PRPTIMV
    Endif
    If [M:TUR4]PRPTIM(nolign-1) < 0 : [M:TUR4]PRPTIM(nolign-1) = [F:ROO]PRPTIM : Endif
Endif

# attente
If [M:TUR2]FWAITIM = 2
    If [M:TUR2]WAITIMF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]WAITIMF
        If !fstat
            [M:TUR4]WAITIM(nolign-1) = evalue([F:TFO]FORFOR)
            # GH 10/01/2014 bug 94924 déplacée plus bas
            # ce temps doit pouvoir être remis à zéro via formule
            # If [M:TUR4]WAITIM(nolign-1) <= 0 : [M:TUR4]WAITIM(nolign-1) = [F:ROO]WAITIM : Endif
        Endif
    Else
        [M:TUR4]WAITIM(nolign-1) = [M:TUR2]WAITIMV
    Endif
    If [M:TUR4]WAITIM(nolign-1) < 0 : [M:TUR4]WAITIM(nolign-1) = [F:ROO]WAITIM : Endif
Endif

# post-opératoire
If [M:TUR2]FPSPTIM = 2
    If [M:TUR2]PSPTIMF <> ""
        Read [TFO]TFO0 = 9;[M:TUR2]PSPTIMF
        If !fstat
            [M:TUR4]PSPTIM(nolign-1) = evalue([F:TFO]FORFOR)
            # GH 10/01/2014 bug 94924 déplacée plus bas
            # ce temps doit pouvoir être remis à zéro via formule
            # If [M:TUR4]PSPTIM(nolign-1) <= 0 : [M:TUR4]PSPTIM(nolign-1) = [F:ROO]PSPTIM : Endif
        Endif
    Else
        [M:TUR4]PSPTIM(nolign-1) = [M:TUR2]PSPTIMV
    Endif
    If [M:TUR4]PSPTIM(nolign-1) < 0 : [M:TUR4]PSPTIM(nolign-1) = [F:ROO]PSPTIM : Endif
Endif

# efficience
If [M:TUR3]FEFF = 2
    If [M:TUR3]EFFF <> ""
        Read [TFO]TFO0 = 9;[M:TUR3]EFFF
        If !fstat
            [M:TUR4]EFF(nolign-1) = evalue([F:TFO]FORFOR)
            # GH 10/01/2014 bug 94924 déplacée plus bas
            # si l'efficience saisie est une constante/formule nulle, il ne faut pas la reprendre
            # If [M:TUR4]EFF(nolign-1) <= 0 : [M:TUR4]EFF(nolign-1) = [F:ROO]EFF : Endif
        Endif
    Else
        [M:TUR4]EFF(nolign-1) = [M:TUR3]EFFV
    Endif
    If [M:TUR4]EFF(nolign-1) <= 0 : [M:TUR4]EFF(nolign-1) = [F:ROO]EFF : Endif
Endif

# perte
If [M:TUR3]FSHR = 2
    If [M:TUR3]SHRF <> ""
        Read [TFO]TFO0 = 9;[M:TUR3]SHRF
        If !fstat
            [M:TUR4]SHR(nolign-1) = evalue([F:TFO]FORFOR)
        Endif
    Else
        [M:TUR4]SHR(nolign-1) = [M:TUR3]SHRV
    Endif
    If [M:TUR4]SHR(nolign-1) < -99 : [M:TUR4]SHR(nolign-1) = [F:ROO]SHR : Endif
Endif

# unité
[M:TUR4]WUO(nolign-1) = [M:TUR4]OPEUOM(nolign-1)
[M:TUR4]PACOEF1(nolign-1) = 0
If [M:TUR3]FOPEUOM = 2
  If [M:TUR3]OPEUOMV <>""
    Read[ITM]ITM0=[M:TUR4]ITMREF(nolign-1)
    If !fstat
        [M:TUR4]OPEUOM(nolign-1) = [M:TUR3]OPEUOMV
        Call RECH_COEFF([F:ITM]STU, [M:TUR3]OPEUOMV, WCOEFF) From MFGLIB
        If WCOEFF <> 0
            [M:TUR4]OPESTUCOE(nolign-1) = WCOEFF
        Else
            [M:TUR4]OPESTUCOE(nolign-1) = 1
            [M:TUR4]PACOEF1(nolign-1) = 1
        Endif
    Endif
  Endif
Endif

If [M:TUR1]EFFUPD2 = 2 &
&  [F:ROO]SETTIM     =  [M:TUR4]SETTIM(nolign-1)    &
&  [F:ROO]OPETIM     =  [M:TUR4]OPETIM(nolign-1)    &
&  [F:ROO]PRPTIM     =  [M:TUR4]PRPTIM(nolign-1)    &
&  [F:ROO]WAITIM     =  [M:TUR4]WAITIM(nolign-1)    &
&  [F:ROO]PSPTIM     =  [M:TUR4]PSPTIM(nolign-1)    &
&  [F:ROO]SETLABCOE  =  [M:TUR4]SETLABCOE(nolign-1) &
&  [F:ROO]OPELABCOE  =  [M:TUR4]OPELABCOE(nolign-1) &
&  [F:ROO]CAD        =  [M:TUR4]CAD(nolign-1)       &
&  [F:ROO]WSTNBR     =  [M:TUR4]WSTNBR(nolign-1)    &
&  [F:ROO]LABNBR     =  [M:TUR4]LABNBR(nolign-1)    &
&  [F:ROO]OPEUOM     =  [M:TUR4]OPEUOM(nolign-1)    &
&  [F:ROO]EFF        =  [M:TUR4]EFF(nolign-1)       &
&  [F:ROO]SHR        =  [M:TUR4]SHR(nolign-1)
  OK=0
Else
  OK=1
Endif
Return

#######################################################################
# Mise à jour/ création des opérations de gamme
$MODIF
Call TEMPON ("V") From GESECRAN

If GTRACE=""
    Call OUVRE_TRACE(mess(148,190,1)) From LECFIC : # Modification en série des opérations
Endif

# Issue X3-56992 - if routing versioning
If func AFNC.ACTIV("RVM")
  WLOGDEL = 1
Endif

NBOPE = 0
MAJUO = 0
Call DEBTRANS From GLOCK
Call ECR_TRACE('',0) From GESECRAN

Trbegin [ROO]
    For nolign = 1 To [M:TUR4]NBLIG
      If [M:TUR4]CREFLG(nolign-1) = 2
         # création de l'opération
        Call ECR_TRACE(mess(155,190,1)-num$([M:TUR4]OPENUM(nolign-1) )+"/"+num$([M:TUR4]RPLIND(nolign-1))+"/"+[M:TUR4]ITMREF(nolign-1),0) From GESECRAN

        # Issue 115901 - 2016-05-31 by GH : by consistency with bug 84175 corrected in script FUNTDUWST
        Read [ROO]ROO0 = [M:TUR4]MFGFCY;[M:TUR4]ITMREF(nolign-1);[M:TUR4]ROUALT(nolign-1);[M:TUR4]OPENUM(nolign-1);[M:TUR4]RPLIND(nolign-1)-1
        If fstat
            GCLE = [M:TUR4]ITMREF(nolign-1)-num$([M:TUR4]ROUALT(nolign-1))-num$([M:TUR4]OPENUM(nolign-1))-num$([M:TUR4]RPLIND(nolign-1)-1)
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif

        Gosub MAJ_WRN

        # ajout de la ligne dupliquée dans la base
        [F:ROO] = [M:TUR4]

        # Issue 115901 - 2016-05-31 by GH : entry point added
        GPOINT = "UPDROO" : Gosub ENTREE From EXEFNC
        If GOK<1 : Break : Endif

        Write [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif

        # modif de la ligne initiale
        Readlock [ROO]ROO0 = [M:TUR4]MFGFCY;[M:TUR4]ITMREF(nolign-1);[M:TUR4]ROUALT(nolign-1);[M:TUR4]OPENUM(nolign-1);[M:TUR4]RPLIND(nolign-1)-1
        If fstat
            GCLE = [M:TUR4]ITMREF(nolign-1)-num$([M:TUR4]ROUALT(nolign-1))-num$([M:TUR4]OPENUM(nolign-1))-num$([M:TUR4]RPLIND(nolign-1)-1)
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif
        [F:ROO]VALENDDAT = XAPPDAT-1
        Rewrite [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif

      Else
         Read [ROO]ROO0 = [M:TUR0]MFGFCY;[M:TUR4]ITMREF(nolign-1);[M:TUR4]ROUALT(nolign-1);[M:TUR4]OPENUM(nolign-1);[M:TUR4]RPLIND(nolign-1)
         If fstat : Goto NXTLIG : Endif

         If [F:ROO]SETTIM     =  [M:TUR4]SETTIM(nolign-1)    &
&           [F:ROO]OPETIM     =  [M:TUR4]OPETIM(nolign-1)    &
&           [F:ROO]PRPTIM     =  [M:TUR4]PRPTIM(nolign-1)    &
&           [F:ROO]WAITIM     =  [M:TUR4]WAITIM(nolign-1)    &
&           [F:ROO]PSPTIM     =  [M:TUR4]PSPTIM(nolign-1)    &
&           [F:ROO]SETLABCOE  =  [M:TUR4]SETLABCOE(nolign-1) &
&           [F:ROO]OPELABCOE  =  [M:TUR4]OPELABCOE(nolign-1) &
&           [F:ROO]CAD        =  [M:TUR4]CAD(nolign-1)       &
&           [F:ROO]WSTNBR     =  [M:TUR4]WSTNBR(nolign-1)    &
&           [F:ROO]LABNBR     =  [M:TUR4]LABNBR(nolign-1)    &
&           [F:ROO]OPEUOM     =  [M:TUR4]OPEUOM(nolign-1)    &
&           [F:ROO]EFF        =  [M:TUR4]EFF(nolign-1)       &
&           [F:ROO]SHR        =  [M:TUR4]SHR(nolign-1)
            Goto NXTLIG
        Endif

        # Modification de l'opération
        Call ECR_TRACE(mess(1,2313,1)-num$([M:TUR4]OPENUM(nolign-1) )+"/"+num$([M:TUR4]RPLIND(nolign-1))+"/"+[M:TUR4]ITMREF(nolign-1),0) From GESECRAN

        Readlock [ROO]ROO0 = [M:TUR4]MFGFCY;[M:TUR4]ITMREF(nolign-1);[M:TUR4]ROUALT(nolign-1);[M:TUR4]OPENUM(nolign-1);[M:TUR4]RPLIND(nolign-1)
        If fstat
            GCLE =[M:TUR4]ITMREF(nolign-1)-num$([M:TUR4]ROUALT(nolign-1))-num$([M:TUR4]OPENUM(nolign-1))-num$([M:TUR4]RPLIND(nolign-1))
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif

        Gosub MAJ_WRN

        [F:ROO]=[M:TUR4]

        # Issue 115901 - 2016-05-31 by GH : entry point added
        GPOINT = "UPDROO" : Gosub ENTREE From EXEFNC
        If GOK<1 : Break : Endif

        Rewrite [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif
       Endif


    NBOPE += 1

$NXTLIG
    Next nolign

If GOK<1
  Rollback
  # Abandon suite à erreur de transaction
  Call ECR_TRACE(mess(17,107,1), 1)From GESECRAN
Else
  Commit
Endif

If NBOPE
   Call ECR_TRACE(" ", 0) From GESECRAN
    # Modification(s) en série effectuée(s)
    Call ECR_TRACE(num$(NBOPE)-mess(362,197,1), 0) From GESECRAN
    If MAJUO
       # Attention, vérifier que les temps (réglage, opératoire, ou cadence) sont encore corrects
       Call ECR_TRACE(mess(23,193,1), 0) From GESECRAN
    Endif
Elsif GOK=1
    # Aucune modification à traiter
    Call ECR_TRACE(mess(371,197,1), 0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN
Return

$MAJ_WRN
If  [M:TUR4]WUO(nolign-1)<>[M:TUR4]OPEUOM(nolign-1)
    # UO initiale
    Call ECR_TRACE ("    "+mess(151,190,1)-[M:TUR4]WUO(nolign-1), 0) From GESECRAN
    MAJUO=1
Endif

If [M:TUR4]PACOEF1(nolign-1)
    # Pas de coefficient trouvé entre UO et US
    Call ECR_TRACE("    "+mess(150,190,1)-"("+[M:TUR4]OPEUOM(nolign-1)-","-[F:ITM]STU+")", 0) From GESECRAN
Endif
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog AM_REPLACEFLG(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M:TUR0]APPDAT = [0/0/0]
               Grizo [TUR0]APPDAT
    When 2:    [M:TUR0]APPDAT = date$
               Actzo [TUR0]APPDAT
Endcase
End

########################################
Subprog C_APPDAT(VALEUR)
Variable Date    VALEUR

If VALEUR< date$ : VALEUR = date$ : Endif
End

########################################
Subprog AM_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ROUALTFIN = VALEUR : Endif
End


########################################
Subprog C_ROUALTDEB(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 : End : Endif

Read [TRO]TRO0=VALEUR
If fstat : mkstat=2
Elsif [F:TRO]FCY <> "" & [F:TRO]FCY <> [M:TUR0]MFGFCY : mkstat = 2
Endif

End

########################################
Subprog C_ROUALTFIN(VALEUR)
Variable Decimal VALEUR

If VALEUR < [M]ROUALTDEB : mkstat = 2 : GMESSAGE = mess(44, 199, 1): End : Endif
If VALEUR = 0 : End : Endif

Read [TRO]TRO0=VALEUR
If fstat : mkstat=2
Elsif [F:TRO]FCY <> "" & [F:TRO]FCY <> [M:TUR0]MFGFCY : mkstat = 2
Endif

End

########################################
Subprog AM_ROUNUMDEB(VALEUR)
Variable Char    VALEUR()
If [M]ROUNUMDEB = ""     : [M]ROUNUMFIN = VALEUR : Endif
If [M]ROUNUMFIN < VALEUR : [M]ROUNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_OPENUMDEB(VALEUR)
Variable Decimal VALEUR
If [M]OPENUMDEB = 0      : [M]OPENUMFIN = VALEUR : Endif
If [M]OPENUMFIN < VALEUR : [M]OPENUMFIN = VALEUR : Endif
End

########################################
Subprog C_OPENUMFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]OPENUMDEB : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]WSTDEB = ""     : [M]WSTFIN = VALEUR : Endif
If [M]WSTFIN < VALEUR : [M]WSTFIN = VALEUR : Endif
End

