########################################
Subprog AM_FSETTIM(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    Grizo [TUR2]SETTIMF : Grizo [TUR2]SETTIMV
    When 2:    Actzo [TUR2]SETTIMF : Actzo [TUR2]SETTIMV
Endcase
End

