#<AdxTL>@(#)1.0.0.0 $Revision$
###########################################################################################################
# Reports 
###########################################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif


Local Char    VALEUR(30) , PARAM(50), FILTRE(250)

Local Char    TYPSTR(GLONGTE), TYPEND(GLONGTE)
Local Date    DATSTR, DATEND

Local Integer K, IFILT, NUMREQ

# Multi_législation-71216
Local Integer INDCPY, NBRLEG
Local Char TABCPY(GLONCPY)(1..GNBSOC)
Local Char TABLEG(GLONADI)(1..GNBSOC)


Call GETPARAM("typdeb",NBPAR,PARAMETRE,VALEUR) From ETAT :  TYPSTR = VALEUR
If TYPSTR<>"" : Call ADDCRIT(FILTRE,IFILT,"TYP",'TYP>="'+TYPSTR+'"'," & ") From GOBJSUB : Endif
Call GETPARAM("typfin",NBPAR,PARAMETRE,VALEUR) From ETAT :  TYPEND = VALEUR
If TYPEND<>"" :    Call ADDCRIT(FILTRE,IFILT,"TYP",'TYP<="'+TYPEND+'"'," & ") From GOBJSUB : Endif

Call GETPARAM("datdeb",NBPAR,PARAMETRE,VALEUR) From ETAT :  DATSTR = gdat$(VALEUR)
Call GETPARAM("datfin",NBPAR,PARAMETRE,VALEUR) From ETAT :  DATEND = gdat$(VALEUR)

Call ADDCRIT(FILTRE,IFILT,"ACCDAT",'ACCDAT>=['+format$(GFMD,DATSTR)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTRE,IFILT,"ACCDAT",'ACCDAT<=['+format$(GFMD,DATEND)+']'," & ") From GOBJSUB


Filter [HAE]  Where evalue(FILTRE) Order By Key CLE = [F:HAE]CPY;[F:HAE]TYP;[F:HAE]NUM

INDCPY = 0 
For [HAE]CLE(1)
 INDCPY += 1
 TABCPY(INDCPY) = [F:HAE]CPY
Next

Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV
Gosub TRTGTE From RPTLEG
Filter [HAE]
End
