End

#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer ERROR : ERROR = [V]CST_AOK
ERROR = func SEARCH(ACTX,PSYR,ARCV,ASND,PSYR.CODCLA)
End ERROR


#------------------------------------------------------------------#
Funprog SEARCH(ACTX,PSYR,ARCV,ASND,ENTITY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance ASND Using C_ASYRSND
Value    Char     ENTITY

Local Integer ERROR : ERROR = [V]CST_AOK

Local Integer     NUMLIN
Local Uuident     UIDINS
Local Char        GRPINS(20)
Local Integer     QCOUNT
Local Char        CLASSNAME(30)        : # Name query class
Local Char        PRGSRH(30)               : # Program contains subprog base access
Local Char        CST_UPDDATTIM(20)  : CST_UPDDATTIM="UPDDATTIM"
Local Char        CST_GT(20) : CST_GT=" GT "
Local Integer    AIN1,AIN2,AIN3
Local Char        QUPDDATTIM(30) : QUPDDATTIM=""

#----------------------------------------------------------------#
# Open file(s) & representation
#----------------------------------------------------------------#
# Init presentation / search
PRGSRH     = func APREFIXTRT.GET_PREFIX_SEARCH + ENTITY : # WMSRH

Local Integer IS_IMPLEMENTED
IS_IMPLEMENTED  = func =PRGSRH +".IS_IMPLEMENTED" With () :#
If !IS_IMPLEMENTED
 Append ASND.DATA , "{}"
 End [V]CST_AOK
Endif

CLASSNAME =  "C_"   + ENTITY: # R_

Local Instance PQRY   Using C_AQUERY   : # Instance containing parameters of query (From, Order; ..)
Local Instance INS    Using =CLASSNAME    : # Instance containing datas query representation

ERROR =  func ASHWVAL._DEFERRED_VALIDATION(ACTX,[L]CLASSNAME)
If ERROR :  Goto END_WITH_ERROR : Endif

INS = null

# Load parameter representation
GRPINS = "SRH"

# Init Instance
PQRY = NewInstance C_AQUERY AllocGroup null

# Max Lines
PQRY.QCOUNT = val(func ASYRMAIN.PARVAL(ARCV,"Count"))

#----------------------------------------------------------------#
# Prepare ASND
#----------------------------------------------------------------#
Raz QCOUNT
Raz ASND.DATA

ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+ENTITY
ASND.CONTTYPE = PSYR.CNTPRE

#----------------------------------------------------------------#
# Open table : Local File XXX
#----------------------------------------------------------------#
Gosub ASEARCH_OPEN From =PRGSRH
If ERROR <> [V]CST_AOK
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(60,149,1),ENTITY))
 Goto END_WITH_ERROR
Endif


#----------------------------------------------------------------#
# Open link
#----------------------------------------------------------------#
PQRY.QWHERE = toupper(func ASYRMAIN.PARVAL(ARCV,"Where"))


AIN1 = instr(1,PQRY.QWHERE,CST_UPDDATTIM)
AIN2 = instr(1,PQRY.QWHERE,CST_GT)
AIN3 = max(instr(1,PQRY.QWHERE,'"'),instr(1,PQRY.QWHERE,"'"))

If AIN1 & (AIN2>AIN1) & (AIN3>AIN2)
 QUPDDATTIM = mid$(PQRY.QWHERE,AIN3+1,19)+"Z"
 #Link for incremental indexing
 Gosub ASEARCH_JOIN_INC From =PRGSRH
Else
 #Link for full indexing
 Gosub ASEARCH_JOIN From =PRGSRH
Endif

If !clalev([LNK_])
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(60,149,1),ENTITY))
 Goto END_WITH_ERROR
Endif

Gosub ASEARCH_CREATEINSTANCE From =PRGSRH

#----------------------------------------------------------------#
# Read data
#----------------------------------------------------------------#
Local Date    DVALUE
Local Clbfile SVALUE

ASND.MODE = 1 : # 1 = First
Append ASND.DATA, "["
Append ASND.DATA, chr$(10)
For [LNK_]
 Gosub ASEARCH_SETINSTANCE From =PRGSRH
 #TODO QCOUNT is updated by the WMSRH* treatment
 If PQRY.QCOUNT > 0 & QCOUNT= PQRY.QCOUNT
  #max lines
  Break
 Endif
 If QCOUNT & mod(QCOUNT,1000) = 0
  Call SYRSND(ASND) From ASYRCOM
  Raz ASND.DATA
 Endif

Next LNK_

Gosub ASEARCH_TO_JSON From =PRGSRH
Append ASND.DATA, chr$(10)
Append ASND.DATA, "]"
Onerrgo

Filter [LNK_]

#FreeInstance INS

Gosub ASEARCH_CLOSE From =PRGSRH

If ASND.MODE = 1
 ASND.MODE = 0
Else
 ASND.MODE = 3 : # 3 = Last
Endif

# Jira 59232 freegroup instances
Gosub AFREE_GROUP

End ERROR

#----------------------------------------------------------------#
# Error response
#----------------------------------------------------------------#
$END_WITH_ERROR
# freegroup instances # jira 59232
Gosub AFREE_GROUP
End ERROR

#----------------------------------------------------------------#
# Freegroup the instances
# jira 59232
#----------------------------------------------------------------#
$AFREE_GROUP
If PQRY<> null
    FreeGroup PQRY
Endif
If INS<> null
    FreeGroup INS
Endif
Return


Funprog DATE_TO_SYR(VALEUR)
Value Date VALEUR
Local Char NEWVAL(20)
NEWVAL = VALEUR
Case VALEUR
 When [0/0/0] : NEWVAL = "null" :#func SYR_NULL
 When Default : NEWVAL = '"'+ left$(VALEUR,4)+"-"+mid$(VALEUR,5,2)+"-"+right$(VALEUR,7) +'"'
Endcase
End NEWVAL

