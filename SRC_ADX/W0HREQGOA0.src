#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREQGOA0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PLNNUM
mkstat = 0
zoncou = "PLNNUM"
indice = 0
If varmode([M]PLNNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PLNNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PLNNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PLNNUM" : GZNUM = 2917 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FCY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]FCY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","",[M]FCY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SCT
mkstat = 0
zoncou = "SCT"
indice = 0
If varmode([M]SCT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SCT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTPOP"
 Call CONTPOP([M]SCT,"ZAF") From SUBPOP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "SCT" : GZNUM = 18419 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("POP","!",[M]SCT,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SCT" : GZNUM = 18419 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WRKPLCE
mkstat = 0
zoncou = "WRKPLCE"
indice = 0
If varmode([M]WRKPLCE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WRKPLCE" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTPOP"
 Call CONTPOP([M]WRKPLCE,"ZAF") From SUBPOP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WRKPLCE" : GZNUM = 46168 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("POP","!",[M]WRKPLCE,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WRKPLCE" : GZNUM = 46168 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CRY
mkstat = 0
zoncou = "CRY"
indice = 0
If varinit([M]CRY,indice)=0
 [M]CRY = GPAYS
Endif
If varmode([M]CRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]CRY,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PRV
mkstat = 0
zoncou = "PRV"
indice = 0
If varmode([M]PRV,indice)=0
 SAVACT = GACTION : GACTION = "SAISAT"
 Call SAISAT(CRY,"") From TRTDIV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PRV : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLSAT"
  PARAM(1) = CRY
  PARAM(2) = ""
  Local Char    VALEUR(250)
  VALEUR = [M]PRV
  Call S_AFF_CHAR(VALEUR,PARAM,"CTLSAT","TRTDIV","") From GACTION
  [M]PRV = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRV" : GZNUM = 13511 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DATDEB
mkstat = 0
zoncou = "DATDEB"
indice = 0
If varmode([M]DATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATDEB" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DATDEB=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DATFIN
mkstat = 0
zoncou = "DATFIN"
indice = 0
If varmode([M]DATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATFIN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DATFIN=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HREQGOA0"
Return

