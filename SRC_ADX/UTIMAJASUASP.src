#<AdxTL>@(#)1.0.0.0 $Revision$
##############################################################################
## Init des champs de la table ASUBPROG dans ASUBPROGD
##############################################################################
Call OUVRE_TRACE("Init des champs de la table ASUBPROG dans ASUBPROGD") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call OUINON("Init des champs de la table ASUBPROG dans ASUBPROGD"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 Call PATCH(nomap)
Else
 Call OUINON("Init des champs de la table ASUBPROG dans ASUBPROGD sur tous les dossiers filles de"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
End

##############################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Call ASUBPROGD(DOSSIER)
End

##############################################################################
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Call ASUBPROGD(DOSSIER)
End

##############################################################################
Subprog ASUBPROGD(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ASUBPROGD","fde",[L]DOSSIER),0)<0  : End : Endif

Local File =DOSSIER+".ASUBPROG"  [ASU]
Local File =DOSSIER+".ASUBPROGD" [ASP]

Local Integer I

# Mise à jour de la table ASUBPROG
Call ECR_TRACE(mess(81,125,1)-"ASUBPROG:"-time$,0) From GESECRAN
Trbegin [ASU]
 For [ASU]
  Read [F:ASP]ASP0 = [F:ASU]PRG;[F:ASU]SUBPRG;0
  If fstat
   For I=0 To [F:ASU]NBRPAR-1
    [F:ASP]PRG       = [F:ASU]PRG
    [F:ASP]SUBPRG    = [F:ASU]SUBPRG
    [F:ASP]LIGNE     = I
    [F:ASP]PARAM     = [F:ASU]PARAM(I)
    [F:ASP]TYPPAR    = [F:ASU]TYPPAR(I)
    [F:ASP]ADRVAL    = [F:ASU]ADRVAL(I)
    [F:ASP]INTITPAR  = [F:ASU]INTITPAR(I)
    [F:ASP]DIME      = [F:ASU]DIME(I)
    [F:ASP]PUBLI     = [F:ASU]PUBLI(I)
    [F:ASP]LONG      = [F:ASU]LONG(I)
    Write [ASP]
    If fstat
     Call ERREUR("ASUBPROGD"-[F:ASU]PRG-[F:ASU]SUBPRG,1) From DOSDIC
     Break
    Endif
   Next I
  Endif
  If dim([F:ASU]PARAM)>0
   Raz [F:ASU]PARAM , [F:ASU]TYPPAR , [F:ASU]ADRVAL , [F:ASU]INTITPAR , [F:ASU]DIME , [F:ASU]PUBLI , [F:ASU]LONG
  Endif
  Rewrite [ASU]
  If fstat
   Call ERREUR("ASUBPROG"-[F:ASU]PRG-[F:ASU]SUBPRG,2) From DOSDIC
  Endif
 Next
Commit

Close Local File [ASU],[ASP]

End
