Subprog AM_CRIT1(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M]CRIT2
 #"Les critères doivent être différents"
 GMESSAGE = mess(104,104,1)
 mkstat   = 2 : End
Endif
If VALEUR<>""
 Case GCURAUZTYP
  When 1 :
   Filter [CCE] Where DIE=VALEUR & AUZ=""
   Fillbox [CAZS] GAU_CHE1
   Filter [CCE]
  When 2 :
   Filter [GAC] Where COA=VALEUR & AUZ=""
   Fillbox [CAZN] GAU_CHE1
   Filter [GAC]
  When 3 :
   Filter [GAC] Where COA=VALEUR & AUZ=""
   Fillbox [CAZC] GAU_CHE1
   Filter [GAC]
 Endcase
 [M]CRIT1=VALEUR
 Affzo [M]CRIT1
 Gosub RAZTAB1
 Gosub SETTAB1
Endif
End

Subprog AM_CRIT2(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M]CRIT1
 #"Les critères doivent être différents"
 GMESSAGE = mess(104,104,1)
 mkstat   = 2 : End
Endif
If VALEUR<>""
 Case GCURAUZTYP
  When 1 :
   Filter [CCE] Where DIE=VALEUR & AUZ=""
   Fillbox [CAZS] GAU_CHE2
   Filter [CCE]
  When 2 :
   Filter [CCE] Where DIE=VALEUR & AUZ=""
   Fillbox [CAZN] GAU_CHE2
   Filter [CCE]
  When 3 :
   Filter [GAC] Where COA=VALEUR & AUZ=""
   Fillbox [CAZC] GAU_CHE2
   Filter [GAC]
 Endcase
 [M]CRIT2=VALEUR
 Affzo [M]CRIT2
 Gosub RAZTAB2
 Gosub SETTAB2
Endif
End

Subprog CL_LINPRE(VALEUR)
Variable Char    VALEUR()
If GCURSELLIN<>1
 If !GENRDONE
  Gosub AREYOUSURE
  Case RES
   When 1 :
   When 2 :
    Call DEBTRANS From GLOCK
    Gosub TR_SAVTABS
  Endcase
 Endif
 GCURSELLIN = GCURSELLIN-1
 Call SETCOLOR(GCURSELLIN)
 Gosub RAZTABS
 Gosub SETTABS
Endif
End

Subprog CL_LINSUI(VALEUR)
Variable Char    VALEUR()
If GCURSELLIN<>[M]NBRAUZ
 If !GENRDONE
  Gosub AREYOUSURE
  Case RES
   When 1 :
   When 2 :
    Call DEBTRANS From GLOCK
    Gosub TR_SAVTABS
  Endcase
 Endif
 GCURSELLIN = GCURSELLIN+1
 Call SETCOLOR(GCURSELLIN)
 Gosub RAZTABS
 Gosub SETTABS
Endif
End

Subprog C_AUZ1(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If VALEUR = ""
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Elsif [M]TYP<>2 & [M]AUZ2(NOL)<>"" & VALEUR = [M]AUZ2(NOL)
 # Les codes interdictions doivent être différents
 GMESSAGE = mess(103,104,1)
 mkstat = 2 : End
Endif
End

Subprog C_AUZ2(VALEUR)
Variable Char    VALEUR()
Local Char    CONCAT(40)
Local Integer EXIST, I, NOL
Gosub SETNOL
If VALEUR = ""
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Elsif [M]TYP<>2 & [M]AUZ1(NOL)<>"" & VALEUR = [M]AUZ1(NOL)
 # Les codes interdiction doivent être différents
 GMESSAGE = mess(103,104,1)
 mkstat = 2 : End
Elsif [M]TYP<>2
 If [M]AUZ1(NOL) < VALEUR
  CONCAT = [M]AUZ1(NOL)+"-"+VALEUR
 Else
  CONCAT = VALEUR+"-"+[M]AUZ1(NOL)
 Endif
 I = find(CONCAT,[M]COMBI(0..NOL-1),[M]COMBI(NOL+1..dim([M]COMBI)-1))
 If I
  If I>NOL
   I += 1
  Endif
  ## Combinaison existante en ligne
  GMESSAGE = mess(19,113,1)-num$(I)
  mkstat=2 : End
 Endif
 Call ALREADYEXIST(VALEUR,EXIST)
 If EXIST
  mkstat = 2 : End
 Endif
Else
 For I=0 To [M]NBRAUZ-1
  If I<>NOL and [M]AUZ1(NOL)=[M]AUZ1(I) & [M]AUZ2(I)= VALEUR
   ## Combinaison existante en ligne
   GMESSAGE = mess(19,113,1)-num$(I+1)
   mkstat=2 : Break
  Endif
 Next
 If mkstat=2 : End : Endif
Endif

If [M]NBRAUZ=0 : Chgstl [M]NBRAUZ(0) With "CAZ" : Endif
[M]AUZ2(NOL) = VALEUR
GCURSELLIN=nolign
Call SETCOLOR(GCURSELLIN)
Gosub RAZTABS
Gosub SETTABS
End


Subprog AP_AUZ1(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Case GCURAUZTYP
 When 1 :
  Call LECTEXTRA([M]LIBAUZ1(NOL),"ATABDIV","LNGDES","322",VALEUR) From ATEXTRA
 When 2,3 :
  Call LECTEXTRA([M]LIBAUZ1(NOL),"ATABDIV","LNGDES","321",VALEUR) From ATEXTRA
Endcase
End

Subprog AP_AUZ2(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Case GCURAUZTYP
 When 1,2 :
  Call LECTEXTRA([M]LIBAUZ2(NOL),"ATABDIV","LNGDES","322",VALEUR) From ATEXTRA
 When 3 :
  Call LECTEXTRA([M]LIBAUZ2(NOL),"ATABDIV","LNGDES","321",VALEUR) From ATEXTRA
Endcase
If [M]TYP=2 | ([M]AUZ1(NOL) < VALEUR)
 [M]COMBI(NOL) = [M]AUZ1(NOL)+"-"+VALEUR
Else
 [M]COMBI(NOL) = VALEUR+"-"+[M]AUZ1(NOL)
Endif
End

Subprog AS_LIBAUZ1(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

Subprog AS_LIBAUZ2(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End


Subprog C_TAB1(VALEUR)
Variable Char    VALEUR()
Local Integer I , JOKER
VALEUR = toupper(VALEUR)
Call UNICITE(VALEUR,[M]TAB1) From OBJDIV
If mkstat : End : Endif
If VALEUR<>""
 JOKER  = 0
 For I=1 To len(VALEUR)
  If instr(1,"!#?*",mid$(VALEUR,I,1))
   #     left$(VALEUR,I-1)+";"+mid$(VALEUR,I,1)
   JOKER = 1 : Break
  Endif
 Next I
 If !JOKER
  Case GCURAUZTYP
   When 1   :
    Call CONTROLE("CCE","",VALEUR,[M]CRIT1,mkstat) From CONTOBJ
   When 2,3 :
    Call CONTROLE("GAC","",VALEUR,[M]CRIT1,mkstat) From CONTOBJ
  Endcase
  If mkstat : End : Endif
  Case GCURAUZTYP
   When 1   :
    Call LECTURE("CCE",VALEUR,[M]CRIT1) From CONTOBJ
    If [F:CCE]AUZ<>"" & [F:CCE]AUZ<>[M]AUZ1(GCURSELLIN-1)
     #Cette section est déjà utilisée pour le code interdiction
     GMESSAGE=mess(105,103,1)-[F:CCE]AUZ
     mkstat=2
    Endif
   When 2,3 :
    Call LECTURE("GAC",VALEUR,[M]CRIT1) From CONTOBJ
    If [F:GAC]AUZ<>"" & [F:GAC]AUZ<>[M]AUZ1(GCURSELLIN-1)
     #Ce compte est déjà utilisé pour le code interdiction
     GMESSAGE=mess(106,103,1)-[F:GAC]AUZ
     mkstat=2
    Endif
  Endcase
 Endif
Endif
End

Subprog C_TAB2(VALEUR)
Variable Char    VALEUR()
Local Integer I , JOKER
VALEUR = toupper(VALEUR)
Call UNICITE(VALEUR,[M]TAB2) From OBJDIV
If mkstat : End : Endif
If VALEUR<>""
 JOKER  = 0
 For I=1 To len(VALEUR)
  If instr(1,"!#?*",mid$(VALEUR,I,1))
   #Infbox left$(VALEUR,I-1)+";"+mid$(VALEUR,I,1)
   JOKER = 1 : Break
  Endif
 Next I
 If !JOKER
  Case GCURAUZTYP
   When 1,2 :
    Call CONTROLE("CCE","",VALEUR,[M]CRIT2,mkstat) From CONTOBJ
   When 3   :
    Call CONTROLE("GAC","",VALEUR,[M]CRIT2,mkstat) From CONTOBJ
  Endcase
  If mkstat : End : Endif
  Case GCURAUZTYP
   When 1,2   :
    Call LECTURE("CCE",VALEUR,[M]CRIT2) From CONTOBJ
    If [F:CCE]AUZ<>"" & [F:CCE]AUZ<>[M]AUZ2(GCURSELLIN-1)
     #Cette section est déjà utilisée pour le code interdiction
     GMESSAGE=mess(105,103,1)-[F:CCE]AUZ
     mkstat=2
    Endif
   When 3 :
    Call LECTURE("GAC",VALEUR,[M]CRIT2) From CONTOBJ
    If [F:GAC]AUZ<>"" & [F:GAC]AUZ<>[M]AUZ2(GCURSELLIN-1)
     #Ce compte est déjà utilisé pour le code interdiction
     GMESSAGE=mess(106,103,1)-[F:GAC]AUZ
     mkstat=2
    Endif
  Endcase
 Endif
Endif
End

Subprog C_NBRTAB1
If status=65 | status=68 | status=83 | status=75 | status=92
 GENRDONE = 0
Endif
End

Subprog C_NBRTAB2
If status=65 | status=68 | status=83 | status=75 | status=92
 GENRDONE = 0
Endif
End

##-------------------   Gestion Transaction   ---------------------------##

$TR_SAVTABS
Trbegin [CCE], [GAC]
 Call SAVAUZTABS(GCURSELLIN)
 If GOK=0    : Goto AB_TR
 Elsif GOK<1 : Goto ROLL_TRSAV
 Endif
Commit
Return

$AB_TR
Rollback
Return

$ROLL_TRSAV
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SAVTABS : Endif
Return


$SETNOL
Local Integer NOL
NOL = nolign-1
Return
