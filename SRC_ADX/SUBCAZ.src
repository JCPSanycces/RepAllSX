#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CAZ",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------#
#               Gestion des codes interdiction                         #
# On gère ici la table CAAUZ par l'objet CAZ                           #
# en fonction des 3 types d'interdiction                               #
#----------------------------------------------------------------------#
#   |            Type                 |   Ecran     |  Fenêtre |       #
#----------------------------------------------------------------------#
#   | 1 interdiction section/section  |   CAZS      |   OCAZS  |       #
#----------------------------------------------------------------------#
#   | 2 interdiction compte/section   |   CAZN      |   OCAZN  |       #
#----------------------------------------------------------------------#
#   | 3 interdiction compte/compte    |   CAZC      |   OCAZC  |       #
#----------------------------------------------------------------------#
# Ainsi que les champs code interdiction sur les table [GAC] & [CCE]   #
# des comptes et/ou sections renseigné dans les tableaux du bas qui    #
# sont remplis par picking sur les listes de gauches prennant elles-   #
# même en critere les champs plan de compte et/ou axe définis en haut  #
# en CRIT1 et CRIT2                                                    #
#----------------------------------------------------------------------#

$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "VARIANTE"    : Gosub VARIANTE
 When "ABANDON"     : Gosub ABANDON
 When "DEFTRANS"    : Gosub DEFTRANS
 When "SETTRANS"    : Gosub SETTRANS
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS0"      : Gosub LIENS0
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FILTRE"      : Gosub FILTRE
 When "GAUCHE"      : Gosub GAUCHE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When Default
Endcase
Return

$AVANT_OUVRE
# Déclaration d'une globale qui aura pour valeur le type d'interdiction courant cf DEFTRANS
Global Integer GCURAUZTYP
Return

$OUVRE
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:CAZ])=0 : Local File CAAUZ    [CAZ] : Endif
If clalev([F:COA2])=0 : Local File GCOA     [COA2] : Endif
Global Integer GCURSELLIN, GENRDONE
GCURSELLIN=1
GENRDONE=1
Return

$VARIANTE
If VARINB<dim(VARIBOI)-2
 VARINB += 1
 VARIBOI(VARINB) = [F:AWI]WIN
 VARICOD(VARINB) = VARCOD
 If dim([F:AWI]LIBEL)>0 & [F:AWI]LIBEL<>""
  VARITEX(VARINB) = [F:AWI]LIBEL
 Else
  Call TEXTE([F:AWI]DES,VARITEX(VARINB)) From OBJDIV
  VARITEX(VARINB) = VARITEX(VARINB)
 Endif
 #???? VARILEG(VARINB) = [F:AWI]LEG
 If GFLAG=VARICOD(VARINB) : VARIREP = VARINB : Endif
Endif
OK = 0
Return

$ABANDON
GCURSELLIN=1
GENRDONE=1
Call SETCOLOR(GCURSELLIN)
Gosub RAZTABS
Gosub SETTABS
Return

$DEFTRANS
#Choisir une transaction d'affichege par défaut
#If GFLAG="" : GFLAG = "CAZS" : Endif
Return

$SETTRANS
# Attribution du type d'interdiction courant en fonction de l'écran(fenêtre) appellé en transaction
Case GFLAG
 When "CAZS" : GCURAUZTYP = 1
 When "CAZN" : GCURAUZTYP = 2
 When "CAZC" : GCURAUZTYP = 3
Endcase
Return

$SETBOUT
#Activation du menu Affichage/Choisir une transaction...
CHAINE+="T"
#Gestion de l'état d'impression/liste
Case GFLAG
 When "CAZS" : REPORT2="INTCCECCE"
 When "CAZN" : REPORT2="INTCPTCCE"
 When "CAZC" : REPORT2="INTCPTCPT"
Endcase
If [L]REPORT2<>""
 If !instr(1,CHAINE,"L") : CHAINE +="L" : Endif
Else
 Call VIREBOUT(CHAINE,"L") From GOBJET
Endif
Return

$LIENS0
If CRITTAB<>""
 #CRITTAB -= "[F:CAZ]TYP=GCURAUZTYP & [F:CAZ]COBIVS<>2" #F54924
 CRITTAB -= "& [F:CAZ]TYP=GCURAUZTYP & [F:CAZ]COBIVS<>2"
Else
 CRITTAB = "[F:CAZ]TYP=GCURAUZTYP & [F:CAZ]COBIVS<>2"
Endif
If FILTSUP<>""
 Filter [F] Where evalue(CRITTAB) & evalue(FILTSUP)
Else
 Filter [F] Where evalue(CRITTAB)
Endif
Return

$LIENS
Case GCURAUZTYP
 When 1   :  Call LECTEXTRA([M]LIBAUZ1(nolign-1),"ATABDIV","LNGDES","322",[F:CAZ]AUZ1) From ATEXTRA
 When 2,3 :  Call LECTEXTRA([M]LIBAUZ1(nolign-1),"ATABDIV","LNGDES","321",[F:CAZ]AUZ1) From ATEXTRA
Endcase
Case GCURAUZTYP
 When 1,2 :  Call LECTEXTRA([M]LIBAUZ2(nolign-1),"ATABDIV","LNGDES","322",[F:CAZ]AUZ2) From ATEXTRA
 When 3   :  Call LECTEXTRA([M]LIBAUZ2(nolign-1),"ATABDIV","LNGDES","321",[F:CAZ]AUZ2) From ATEXTRA
Endcase
If [M]TYP=2 | ([F:CAZ]AUZ1 < [F:CAZ]AUZ2)
 [M]COMBI(nolign-1) = [F:CAZ]AUZ1+"-"+[F:CAZ]AUZ2
Else
 [M]COMBI(nolign-1) = [F:CAZ]AUZ2+"-"+[F:CAZ]AUZ1
Endif
Return

$LIENS2
Case GCURAUZTYP
 When 1 : [M]AUZTYP=mess(1,620,1) : #[M]TYP=1
  If [M]CRIT1=""
   Read [DIE]DIE0 First
   [M]CRIT1=[F:DIE]DIE
  Endif
  Filter [CCE] Where DIE=[M]CRIT1
  Fillbox [CAZS] GAU_CHE1
  Filter [CCE]
  If [M]CRIT2=""
   Read [DIE]DIE0 Next
   [M]CRIT2=[F:DIE]DIE
  Endif
  Filter [CCE] Where DIE=[M]CRIT2
  Fillbox [CAZS] GAU_CHE2
  Filter [CCE]
 When 2 : [M]AUZTYP=mess(2,620,1) : #[M]TYP=2
  If [M]CRIT1=""
   Read [COA]COA0 First
   [M]CRIT1=[F:COA]COA
  Endif
  Filter [GAC] Where COA=[M]CRIT1
  Fillbox [CAZN] GAU_CHE1
  Filter [GAC]
  If [M]CRIT2=""
   Read [DIE]DIE0 First
   [M]CRIT2=[F:DIE]DIE
  Endif
  Filter [CCE] Where DIE=[M]CRIT2
  Fillbox [CAZN] GAU_CHE2
  Filter [CCE]
 When 3 : [M]AUZTYP=mess(3,620,1) : #[M]TYP=3
  If [M]CRIT1=""
   Read [COA]COA0 First
   [M]CRIT1=[F:COA]COA
  Endif
  Filter [GAC] Where COA=[M]CRIT1
  Fillbox [CAZC] GAU_CHE1
  Filter [GAC]
  If [M]CRIT2=""
   Read [COA]COA0 Next
   [M]CRIT2=[F:COA]COA
  Endif
  Filter [GAC] Where COA=[M]CRIT2
  Fillbox [CAZC] GAU_CHE2
  Filter [GAC]
Endcase
Call SETCOLOR(GCURSELLIN)
Gosub RAZTABS
Gosub SETTABS
Return

$FILTRE
# Permet de gérer les enregistrements ds CAAUZ sur le type d'interdiction approprié
CRITERE += 'TYP='+num$(GCURAUZTYP)
Return

$GAUCHE
Local Char INTIT(30)
If REP=""
 If !CLECUR | !VERROU | !ACTMOD | GCONSULT : OK=0 : Return : Endif
Endif
Case currbox
 When "GAU_CHE1"
  # Sélection sur liste picking 1
  If[M]NBRAUZ<>0
   If OK
    mkstat = 0
    nolign = [M]NBRTAB1+1
    Case GCURAUZTYP
     When 1   : Read [CCE]CCE0 = [M]CRIT1;[F:CCE]CCE
     When 2,3 : Read [GAC]GAC0 = [M]CRIT1;[F:GAC]ACC
    Endcase
    If mkstat : OK = 0 : Endif
   Endif
   If OK
    Case GCURAUZTYP
     When 1   :
      If !find([F:CCE]CCE,[M]TAB1(0..[M]NBRTAB1)) & [F:CCE]AUZ=""
       [M]TAB1([M]NBRTAB1)    = [F:CCE]CCE
       [M]NBRTAB1 += 1
       Affzo [M]
       Gosub SETENROK
      Endif
     When 2,3 :
      If  !find([F:GAC]ACC,[M]TAB1(0..[M]NBRTAB1)) & [F:GAC]AUZ=""
       [M]TAB1([M]NBRTAB1)    = [F:GAC]ACC
       [M]NBRTAB1 += 1
       Affzo [M]
       Gosub SETENROK
      Endif
    Endcase
   Endif
  Endif
 When "GAU_CHE2"
  # Sélection sur liste picking 2
  If [M]NBRAUZ<>0
   If OK
    mkstat = 0
    nolign = [M]NBRTAB2+1
    Case GCURAUZTYP
     When 1,2 : Read [CCE]CCE0 = [M]CRIT2;[F:CCE]CCE
     When 3   : Read [GAC]GAC0 = [M]CRIT2;[F:GAC]ACC
    Endcase
    If mkstat : OK = 0 : Endif
   Endif
   If OK
    Case GCURAUZTYP
     When 1,2 :
      If !find([F:CCE]CCE,[M]TAB2(0..[M]NBRTAB2)) & [F:CCE]AUZ=""
       [M]TAB2([M]NBRTAB2)    = [F:CCE]CCE
       [M]NBRTAB2 += 1
       Affzo [M]
       Gosub SETENROK
      Endif
     When 3   :
      If !find([F:GAC]ACC,[M]TAB2(0..[M]NBRTAB2)) & [F:GAC]AUZ=""
       [M]TAB2([M]NBRTAB2)    = [F:GAC]ACC
       [M]NBRTAB2 += 1
       Affzo [M]
       Gosub SETENROK
      Endif
    Endcase
   Endif
  Endif
Endcase
Return

$FILGAUCHE
Case GCURAUZTYP
 When 1:
  Case currbox
   When "GAU_CHE1" : FILGAUSUP(0)='DIE="'+[M]CRIT1+'" & AUZ=""'
   When "GAU_CHE2" : FILGAUSUP(0)='DIE="'+[M]CRIT2+'" & AUZ=""'
  Endcase
 When 2:
  Case currbox
   When "GAU_CHE1" : FILGAUSUP(0)='COA="'+[M]CRIT1+'" & AUZ=""'
   When "GAU_CHE2" : FILGAUSUP(0)='DIE="'+[M]CRIT2+'" & AUZ=""'
  Endcase
 When 3:
  Case currbox
   When "GAU_CHE1" : FILGAUSUP(0)='COA="'+[M]CRIT1+'" & AUZ=""'
   When "GAU_CHE2" : FILGAUSUP(0)='COA="'+[M]CRIT2+'" & AUZ=""'
  Endcase
Endcase
Return


$CREATION
# Création des combinaisons inverses pour la gestion des interdictions comptes/comptes et sections/sections
If [M]TYP<>2
 [F:CAZ]COBIVS = 2
 [F:CAZ]TYP    = [M]TYP(nolign-1)
 [F:CAZ]AUZ1   = [M]AUZ2(nolign-1)
 [F:CAZ]AUZ2   = [M]AUZ1(nolign-1)
 Write [CAZ]
 If fstat
  GOK=0 : Call FSTA("CAZ") From GLOCK : Return
 Endif
Endif
Return

$MODIF
If GENRDONE=0
 Call SAVAUZTABS(GCURSELLIN)
 If GOK<1 : Return : Endif
 GENRDONE=1
Else
 GENRDONE=0
Endif
Return

$APRES_MODIF
#Pour eviter le changement de statut sur le changement des critères, empeche le passage en modif.
If zoncou="CRIT1" | zoncou="CRIT2"
 OK=-1
Endif
Return

$SETENROK
Gosub ENTRE_MODIF From GOBJSUB
GENRDONE=0
Return

###################################################
###----- Some Common Subprog & Etiquettes ------###

Subprog SETCOLOR(LIN)
Variable Integer LIN
Local Integer I
Gosub RAZCOLOR
For I=0 To [M]NBRAUZ
 If I=LIN-1
  Chgstl [M]NBRAUZ(I) With "CAZ"
 Endif
Next
Affzo [M]
End

$RAZCOLOR
For I=0 To [M]NBRAUZ-1
 Chgstl [M]NBRAUZ(I) With ""
Next I
Return

$SETTABS
Local Char INTIT(30)
Gosub SETTAB1
Gosub SETTAB2
GENRDONE=1
Return

$SETTAB1
If [M]NBRAUZ=0 : Return : Endif
# Remplissage du tableau 1 utilisant le code interdiction de la ligne courante
Case GCURAUZTYP
 When 1 :
  For [CCE]CCE0 Where [F]DIE=[M]CRIT1
   If [F:CCE]AUZ=[M]AUZ1(GCURSELLIN-1)
    [M]TAB1([M]NBRTAB1) = [F:CCE]CCE
    [M]NBRTAB1 += 1
    Affzo [M]
   Endif
  Next
 When 2,3 :
  For [GAC]GAC0 Where [F]COA=[M]CRIT1
   If [F:GAC]AUZ=[M]AUZ1(GCURSELLIN-1)
    [M]TAB1([M]NBRTAB1) = [F:GAC]ACC
    [M]NBRTAB1 += 1
    Affzo [M]
   Endif
  Next
Endcase
Return

$SETTAB2
If [M]NBRAUZ=0 : Return : Endif
# Remplissage du tableau 2 utilisant le code interdiction de la ligne courante
Case GCURAUZTYP
 When 1,2 :
  For [CCE]CCE0 Where [F]DIE=[M]CRIT2
   If [F:CCE]AUZ=[M]AUZ2(GCURSELLIN-1)
    [M]TAB2([M]NBRTAB2) = [F:CCE]CCE
    [M]NBRTAB2 += 1
    Affzo [M]
   Endif
  Next
 When 3 :
  For [GAC]GAC0 Where [F]COA=[M]CRIT2
   If [F:GAC]AUZ=[M]AUZ2(GCURSELLIN-1)
    [M]TAB2([M]NBRTAB2) = [F:GAC]ACC
    [M]NBRTAB2 += 1
    Affzo [M]
   Endif
  Next
Endcase
Return

$RAZTABS
Gosub RAZTAB1
Gosub RAZTAB2
Return

$RAZTAB1
# Raz du tableau 1
Local Integer I
For I=0 To [M]NBRTAB1
 [M]TAB1(I)    = ""
Next
[M]NBRTAB1=0
Affzo [M]
Return

$RAZTAB2
# Raz du tableau 2
Local Integer I
For I=0 To [M]NBRTAB2
 [M]TAB2(I)    = ""
Next
[M]NBRTAB2=0
Affzo [M]
Return

Subprog SAVAUZTABS(LIN)
# Sauvegarde le code interdiction de la ligne LIN pour les comptes et sections selectionnés
Variable Integer LIN
Local Integer I,J,JOK
# TAB1
Case GCURAUZTYP
 When 1 :
  #RAZ
  #Raz de AUZ dans la table des sections qd celles ci ont été supprimer de TAB (joker ou pas)
  For [CCE]CCE0 Where DIE=[M]CRIT1 & AUZ=[M]AUZ1(LIN-1)
   JOK = 0
   For I=0 To [M]NBRTAB1-1
    If pat([F:CCE]CCE,[M]TAB1(I)) : JOK=1 : Endif
   Next
   If !JOK
    [F:CCE]AUZ=""
    Rewrite [CCE]
    If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
   Endif
  Next
  If GOK=0 : End : Endif
  #AFFECTATION
  For I=0 To [M]NBRTAB1-1
   #Parcours  de TAB pour affectation de AUZ ds la table des Section
   For J=1 To len([M]TAB1(I))
    If instr(1,"!#?*",mid$([M]TAB1(I),J,1))
     #JOKER
     For [CCE]CCE0 Where DIE=[M]CRIT1 & pat(CCE,[M]TAB1(I))
      If [F:CCE]AUZ=""
       [F:CCE]AUZ=[M]AUZ1(LIN-1)
       Rewrite [CCE]
       If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
      Elsif [F:CCE]AUZ<>[M]AUZ1(LIN-1)
       Local Integer RES
       Local Char TEXTE(250)
       TEXTE=[F:CCE]CCE-":"-mess(107,104,1)-[F:CCE]AUZ-"?"
       Call OUINON(TEXTE,RES) From GESECRAN
       If RES=2
        [F:CCE]AUZ=[M]AUZ1(LIN-1)
        Rewrite [CCE]
        If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
       Endif
      Endif
     Next
    Else
     #NON JOKER
     Readlock [CCE]CCE0 = [M]CRIT1;[M]TAB1(I)
     If fstat=1
      GOK = -1 : GLOCK="$CACCE"-[M]CRIT1-[M]TAB1(I) : Break
     Elsif !fstat
      If [F:CCE]AUZ=""
       [F:CCE]AUZ = [M]AUZ1(LIN-1)
       Rewrite [CCE]
       If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
      Endif
     Endif
    Endif
   Next J
  Next I
 When 2,3 :
  #RAZ
  #Raz de AUZ dans la table des comptes qd ceux ci ont été supprimer de TAB (joker ou pas)
  For [GAC]GAC0 Where COA=[M]CRIT1 & AUZ=[M]AUZ1(LIN-1)
   JOK = 0
   For I=0 To [M]NBRTAB1-1
    If pat([F:GAC]ACC,[M]TAB1(I)) : JOK=1 : Endif
   Next
   If !JOK
    [F:GAC]AUZ=""
    Rewrite [GAC]
    If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
   Endif
  Next
  If GOK=0 : End : Endif
  #AFFECTATION
  For I=0 To [M]NBRTAB1-1
   #Parcours  de TAB pour affectation de AUZ ds la table des comptes
   For J=1 To len([M]TAB1(I))
    If instr(1,"!#?*",mid$([M]TAB1(I),J,1))
     #JOKER
     For [GAC]GAC0 Where COA=[M]CRIT1 & pat(ACC,[M]TAB1(I))
      If [F:GAC]AUZ=""
       [F:GAC]AUZ=[M]AUZ1(LIN-1)
       Rewrite [GAC]
       If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
      Elsif [F:GAC]AUZ<>[M]AUZ1(LIN-1)
       Local Integer RES
       Local Char TEXTE(250)
       TEXTE=[F:GAC]ACC-":"-mess(107,104,1)-[F:GAC]AUZ-"?"
       Call OUINON(TEXTE,RES) From GESECRAN
       If RES=2
        [F:GAC]AUZ=[M]AUZ1(LIN-1)
        Rewrite [GAC]
        If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
       Endif
      Endif
     Next
    Else
     #NON JOKER
     Readlock [GAC]GAC0 = [M]CRIT1;[M]TAB1(I)
     If fstat=1
      GOK = -1 : GLOCK="$GACCOUNT"-[M]CRIT1-[M]TAB1(I) : Break
     Elsif !fstat
      If [F:GAC]AUZ=""
       [F:GAC]AUZ = [M]AUZ1(LIN-1)
       Rewrite [GAC]
       If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
      Endif
     Endif
    Endif
   Next J
  Next I
Endcase
# TAB2
Case GCURAUZTYP
 When 1,2 :
  #RAZ
  #Raz de AUZ dans la table des sections qd celles ci ont été supprimer de TAB (joker ou pas)
  For [CCE]CCE0 Where DIE=[M]CRIT2 & AUZ=[M]AUZ2(LIN-1)
   JOK = 0
   For I=0 To [M]NBRTAB2-1
    If pat([F:CCE]CCE,[M]TAB2(I)) : JOK=1 : Endif
   Next
   If !JOK
    [F:CCE]AUZ=""
    Rewrite [CCE]
    If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
   Endif
  Next
  If GOK=0 : End : Endif
  #AFFECTATION
  For I=0 To [M]NBRTAB2-1
   #Parcours  de TAB pour affectation de AUZ ds la table des Section
   For J=1 To len([M]TAB2(I))
    If instr(1,"!#?*",mid$([M]TAB2(I),J,1))
     #JOKER
     For [CCE]CCE0 Where DIE=[M]CRIT2 & pat(CCE,[M]TAB2(I))
      If [F:CCE]AUZ=""
       [F:CCE]AUZ=[M]AUZ2(LIN-1)
       Rewrite [CCE]
       If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
      Elsif [F:CCE]AUZ<>[M]AUZ2(LIN-1)
       Local Integer RES
       Local Char TEXTE(250)
       TEXTE=[F:CCE]CCE-":"-mess(107,104,1)-[F:CCE]AUZ-"?"
       Call OUINON(TEXTE,RES) From GESECRAN
       If RES=2
        [F:CCE]AUZ=[M]AUZ2(LIN-1)
        Rewrite [CCE]
        If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
       Endif
      Endif
     Next
    Else
     #NON JOKER
     Readlock [CCE]CCE0 = [M]CRIT2;[M]TAB2(I)
     If fstat=1
      GOK = -1 : GLOCK="$CACCE"-[M]CRIT2-[M]TAB2(I) : Break
     Elsif !fstat
      If [F:CCE]AUZ=""
       [F:CCE]AUZ = [M]AUZ2(LIN-1)
       Rewrite [CCE]
       If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
      Endif
     Endif
    Endif
   Next J
  Next I
 When 3 :
  #RAZ
  #Raz de AUZ dans la table des comptes qd ceux ci ont été supprimer de TAB (joker ou pas)
  For [GAC]GAC0 Where COA=[M]CRIT2 & AUZ=[M]AUZ2(LIN-1)
   JOK = 0
   For I=0 To [M]NBRTAB2-1
    If pat([F:GAC]ACC,[M]TAB2(I)) : JOK=1 : Endif
   Next
   If !JOK
    [F:GAC]AUZ=""
    Rewrite [GAC]
    If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
   Endif
  Next
  If GOK=0 : End : Endif
  #AFFECTATION
  For I=0 To [M]NBRTAB2-1
   #Parcours  de TAB pour affectation de AUZ ds la table des comptes
   For J=1 To len([M]TAB2(I))
    If instr(1,"!#?*",mid$([M]TAB2(I),J,1))
     #JOKER
     For [GAC]GAC0 Where COA=[M]CRIT2 & pat(ACC,[M]TAB2(I))
      If [F:GAC]AUZ=""
       [F:GAC]AUZ=[M]AUZ2(LIN-1)
       Rewrite [GAC]
       If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
      Elsif [F:GAC]AUZ<>[M]AUZ2(LIN-1)
       Local Integer RES
       Local Char TEXTE
       TEXTE=[F:GAC]ACC-":"-mess(107,104,1)-[F:GAC]AUZ-"?"
       Call OUINON(TEXTE,RES) From GESECRAN
       If RES=2
        [F:GAC]AUZ=[M]AUZ2(LIN-1)
        Rewrite [GAC]
        If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
       Endif
      Endif
     Next
    Else
     #NON JOKER
     Readlock [GAC]GAC0 = [M]CRIT2;[M]TAB2(I)
     If fstat=1
      GOK = -1 : GLOCK="$GACCOUNT"-[M]CRIT2-[M]TAB2(I) : Break
     Elsif !fstat
      If [F:GAC]AUZ=""
       [F:GAC]AUZ = [M]AUZ2(LIN-1)
       Rewrite [GAC]
       If fstat : GOK = 0 : Call FSTA("GAC") From GLOCK : Break : Endif
      Endif
     Endif
    Endif
   Next J
  Next I
Endcase
GENRDONE=1
End

$AREYOUSURE
Local Integer RES
Local Char TEXTE
TEXTE=mess(97,9138,1)+"?"
Call OUINON(TEXTE,RES) From GESECRAN
Return

Subprog ALREADYEXIST(VALEUR,EXIST)
Value Char VALEUR()
Variable Integer EXIST
Local Integer I
EXIST=0
# si existe dans table CAAUZ
# sens normal ?
For [CAZ]CAZ0 Where TYP=GCURAUZTYP & AUZ2=VALEUR
 If [F:CAZ]AUZ1=[M]AUZ1(nolign-1) : EXIST=1 : Break : Endif
Next
#sens inverse ?
For [CAZ]CAZ0 Where TYP=GCURAUZTYP & AUZ2=[M]AUZ1(nolign-1)
 If [F:CAZ]AUZ1=VALEUR : EXIST=1 : Break : Endif
Next
#si existe dans tableau NBRAUZ , cas ou il n'y a pas eu d'enregistrement
For I=0 To [M]NBRAUZ-1
 If [M]AUZ1(I)=[M]AUZ1(nolign-1) & [M]AUZ2(I)=VALEUR : EXIST=1 : Break : Endif
 If [M]AUZ1(I)=VALEUR & [M]AUZ2(I)=[M]AUZ1(nolign-1) : EXIST=1 : Break : Endif
Next
End

###--------Etiquettes du mask CAZx--------###

Subprog CL_PC1(VALEUR)
Variable Char    VALEUR()
If maskcou="CAZS"
 Read [DIE]DIE0=[M]CRIT1
 Read [DIE]DIE0 Prev
 If !fstat
  If [M]CRIT2=[F:DIE]DIE
   Read [DIE]DIE0 Prev
   If !fstat
    Call AM_CRIT1([F:DIE]DIE)
   Endif
  Else
   Call AM_CRIT1([F:DIE]DIE)
  Endif
 Endif
Elsif (maskcou="CAZN" | maskcou="CAZC")
 Read [COA2]COA0=[M]CRIT1
 Read [COA2]COA0 Prev
 If !fstat & [F:COA2]COA<>""
  If [M]CRIT2=[F:COA2]COA
   Read [COA2]COA0 Prev
   If !fstat
    Call AM_CRIT1([F:COA2]COA)
   Endif
  Else
   Call AM_CRIT1([F:COA2]COA)
  Endif
 Endif
Endif
End

