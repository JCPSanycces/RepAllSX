    Call AM_CRIT1([F:DIE]DIE)
   Endif
  Else
   Call AM_CRIT1([F:DIE]DIE)
  Endif
 Endif
Elsif (maskcou="CAZN" | maskcou="CAZC")
 Read [COA2]COA0=[M]CRIT1
 Read [COA2]COA0 Next
 If !fstat
  If [M]CRIT2=[F:COA2]COA
