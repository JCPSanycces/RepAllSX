#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
# Récupération de sélection Interlocuteur                            Module CRM          26 février 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZPREOPG

  GSZPREOPG = ""
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer IT

  IT = 0
  Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]CNTTTR = "" Order By [F:SEC]SELDAT Desc
  For [SEC]
    If IT >= dim([M:MAZ3]OPGNUM)-1 Then
      Break
    Endif
    [M:MAZ3]OPGNUM(IT) = [F:SEC]OPGNUM
    Case [F:SEC]OPGTYP
      When "OMM"
        Read [OMM]OMM0=[F:SEC]OPGNUM
        If !fstat Then
          [M:MAZ3]OPGDES(IT) = [F:OMM]DES
          Read [CMG]CMG0=[F:OMM]CMGNUM
          If !fstat Then
            [M:MAZ3]CMGTTR(IT) = [F:CMG]TTR
          Endif
        Endif
      When "OMP"
        Read [OMP]OMP0=[F:SEC]OPGNUM
        If !fstat Then
          [M:MAZ3]OPGDES(IT) = [F:OMP]DES
          Read [CMG]CMG0=[F:OMP]CMGNUM
          If !fstat Then
            [M:MAZ3]CMGTTR(IT) = [F:CMG]TTR
          Endif
        Endif
      When Default
    Endcase
    IT += 1
  Next
  Filter [SEC]
  [M:MAZ3]NBOPG = IT
  Affzo [M:MAZ3]
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:MAZ3]
  Kill GSZPREOPG
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
$ONOK
  GSZCCNFILT = [M:MAZ3]SELCRI1 + [M:MAZ3]SELCRI2 + [M:MAZ3]SELCRI3 + [M:MAZ3]SELCRI4 + [M:MAZ3]SELCRI5
  FIN = 1
Return

##########################################################################################################
# Chargement des caractéristiques de la sélection sélectionnée.
#########################################################
Subprog LOADOPGINF(SZOPGNUM, SZTBLTYP)
Value Char SZOPGNUM
Variable Char SZTBLTYP

  Raz [M:MAZ3]SELDAT
  Raz [M:MAZ3]SELREC
  Raz [M:MAZ3]SELCRI1
  Raz [M:MAZ3]SELCRI2
  Raz [M:MAZ3]SELCRI3
  Raz [M:MAZ3]SELCRI4
  Raz [M:MAZ3]SELCRI5
  Filter [SEC] Where [F:SEC]OPGNUM = SZOPGNUM and [F:SEC]SELTBL = "CCN"
  For [SEC]
    [M:MAZ3]SELDAT = [F:SEC]SELDAT
    [M:MAZ3]SELREC = [F:SEC]SELREC
    [M:MAZ3]SELCRI1 = left$([F:SEC]SELCRI, 50)
    [M:MAZ3]SELCRI2 = mid$([F:SEC]SELCRI, 51, 50)
    [M:MAZ3]SELCRI3 = mid$([F:SEC]SELCRI, 101, 50)
    [M:MAZ3]SELCRI4 = mid$([F:SEC]SELCRI, 151, 50)
    [M:MAZ3]SELCRI5 = mid$([F:SEC]SELCRI, 201, 50)
    Break
  Next
  Filter [SEC]
End

##########################################################################################################
# Chargement du contenu de la sélection sélectionnée.
#########################################################
Subprog LOADSEL(SZOPGNUM, SZTBLTYP)
Value Char SZOPGNUM
Value Char SZTBLTYP

Local Integer IR

  IR = 0
  Call TEMPON("R") From GESECRAN
  Raz [M:MAZ3]CCNNUM
  Raz [M:MAZ3]CCNTTL
  Raz [M:MAZ3]CCNFNA
  Raz [M:MAZ3]CCNLNA
  Raz [M:MAZ3]CCNCRY
  Raz [M:MAZ3]CCNTEL
  Raz [M:MAZ3]CCNBIR
  Raz [M:MAZ3]NBBPR
  Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM and [F:SCL]RECTYP = SZTBLTYP
  For [SCL]
    If IR >= dim([M:MAZ3]CCNNUM)-1 Then
      Break
    Endif
    [M:MAZ3]CCNNUM(IR) = [F:SCL]RECNUM
    Read [AIN] AIN0 = [F:SCL]RECNUM
    If !fstat Then
      [M:MAZ3]CCNTTL(IR) = [F:AIN]CNTTTL
      [M:MAZ3]CCNFNA(IR) = [F:AIN]CNTFNA
      [M:MAZ3]CCNLNA(IR) = [F:AIN]CNTLNA
      [M:MAZ3]CCNCRY(IR) = [F:AIN]CRY
      [M:MAZ3]CCNTEL(IR) = [F:AIN]CNTETS
      [M:MAZ3]CCNBIR(IR) = [F:AIN]CNTBIR
    Endif
    IR += 1
  Next
  Filter [SCL]
  [M:MAZ3]NBBPR = IR
  Call TEMPOFF From GESECRAN
End
