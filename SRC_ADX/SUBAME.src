#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AME",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "CREATION"   : Gosub MAJ
 When "MODIF"      : Gosub MAJ
 When "ANNULE"     : Gosub ANNULE
 When "CHANGE"     : Gosub CHANGE
 When Default
Endcase
Return

$MAJ
Call MAJTEXTRA([M]INTMET,"AMETUTI","INTMET",[M]CODMET,"") From ATEXTRA
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

$CHANGE
Update [AXX] Where CODFIC="AMETUTI" & ZONE = "INTMET" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AMETUTI"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

$ANNULE
Delete [AXX] Where CODFIC="AMETUTI" & ZONE = "INTMET"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

$TRTCOP
If [M]DOSORG=nomap
 Local File AMETUTI [AME1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AMETUTI" [AME1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AMETUTI [AME2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AMETUTI" [AME2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [AME2]AME0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AME1] , [AME2]  , [AXX1] , [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [AME2]
 Delete [AME2] Where CODMET=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMETUTI" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AME2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AME1]AME0 Where CODMET=TABLE
  [F:AME2] = [F:AME1]
  Call COPTEXTRA("AMETUTI","INTMET",TABLE,"") From ATEXTRA
  If dim([F:AME2]UPDUSR)>0 : [F:AME2]UPDUSR = GUSER : Endif
  If dim([F:AME2]UPDDAT)>0 : [F:AME2]UPDDAT = date$ : Endif
  If dim([F:AME2]UPDTIM)>0 : [F:AME2]UPDDAT = time : Endif
  Write [AME2]
  If fstat
   GOK=0 : Call FSTA("AME2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call  UPDATE_RIGHTSETAG([M]DOSDES) From ASYRFNC
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
