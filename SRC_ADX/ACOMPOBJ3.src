Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOMPOBJ","ACOMPOBJ",3,"XYACOMPOBJ") From GTRAITE
End
#####################################################################################


########################################################################################
$COMP_AOE                                   #### MODELE D'IMPORT/EXPORT  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(214,142,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AOE)+")",0) From GESECRAN       # modele
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_AOE
   # modele inexistante
   If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
     Call TRACE("AOE","","","","","",mess(30,141,1),EXCEL,-1,DIF) From ACOMPOBJ2
   Endif
   Return
Endif
Raz NBFIC
For COD="AOBJEXT","AEXPV3"
    Gosub TRT_ATABZON  From ACOMPOBJ2
    NBFIC+=1
Next
## Début de la comparaison
CRITERE  = "1=1"
TOUT = 0
If [M:ACMP]AOEDEB="" & [M:ACMP]AOEFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& EXT<'X'"
 Endif
Else
 CRITERE += "& EXT>=[M:ACMP]AOEDEB & EXT<=[M:ACMP]AOEFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:AOE1]AOE0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOE1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_AOE From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AOE1: Endif        #X3PLAT-940 - Filter on activity code

        Filter [F:AOE2] Where [F:AOE2]EXT=[F:AOE1]EXT
        Read [F:AOE2] First
        If fstat
            Call TRACE("AOE",[F:AOE1]EXT,"","","",mess(87,100,1),
&           mess(214,142,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
            # Modele inexistant "
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_AOE
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("AOE",[F:AOE1]EXT,"","","","",mess(227,115,1),EXCEL,0,DIF) From ACOMPOBJ2
                    # modèle identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("AOE",[F:AOE1]EXT,"","","",mess(3,55,1),mess(228,115,1),EXCEL,-1,DIF) From ACOMPOBJ2
                    # modèle différent
                    If PATCH : Call PATCH("AOE",[F:AOE1]COD,"") From ACOMPOBJ2 : Endif
                Endif
            Endif
        Endif
        Filter [F:AOE2]
    Endif
$NEXT_AOE1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AOE2]AOE0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:AOE2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_AOE From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_AOE2: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:AOE1]AOE0=[F:AOE2]EXT
        If fstat
            Call TRACE("AOE",[F:AOE2]EXT,"","","",mess(87,100,1),
&           mess(214,142,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
            # modele inexistante sous
        Endif
    Endif
$NEXT_AOE2  # X3PLAT-940 - Filter on activity code
Next
Return

#############################
$TRT_AOE
Local Char XCODE(250)
If OBJ=1 : AOBJ="AEV" : Endif
If OBJ=0 : AOBJ="AOE" : Endif
For I=1 To NBRZON(OBJ)
    XCODE = ZON(OBJ,I)
    If (OBJ=1 & !find(XCODE,"FILX3","FILV3")) or (OBJ=0 & !find(XCODE,"ENAFLG","CHRNUM","FILEXT","AOWSTA","CODACT","ACS","REPFIN"))
        If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
            K = 1
        Else
            K=DIMZON(OBJ,I)
        Endif
        For J=1 To K
            If TYP(OBJ,I) = "ATX"
                Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1]"+ZON(OBJ,I)+"("+num$(J-1)+")")
                If fstat : [F:OATX]TEXTE="" : Endif
                Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2]"+ZON(OBJ,I)+"("+num$(J-1)+")")
                If fstat : [F:DATX]TEXTE="" : Endif
                If [F:OATX]TEXTE <> [F:DATX]TEXTE
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    If OBJ=0
                     Call TRACE("AOE",[F:AOE1]EXT,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE,
&                    mess(200,115,1),[F:DATX]TEXTE,EXCEL,-1,DIF)  From ACOMPOBJ2
                    Else
                        Call TRACE("AEV",[F:AEV1]CODE,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE,
&                       mess(200,115,1),[F:DATX]TEXTE,EXCEL,-1,DIF)  From ACOMPOBJ2
                        : # Modele & intitulés différents
                    Endif
                Endif
            Elsif find(TYP(OBJ,I),"AXX","AX1","AX2","AX3")
                If OBJ =0
                    XCODE = [F:AOE1]EXT
                    COD   = "AOBJEXT"
                Else
                    XCODE = [F:AEV1]CODE
                    COD   = "AEXPV3"
                Endif
                Read [OAXT]AXX0=COD;ZON(OBJ,I);GLANGUE;XCODE;""
                If fstat : [F:OAXT]TEXTE="" : Endif
                Read [DAXT]AXX0=COD;ZON(OBJ,I);GLANGUE;XCODE;""
                If fstat : [F:DAXT]TEXTE="" : Endif
                If [F:OAXT]TEXTE <> [F:DAXT]TEXTE
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE(AOBJ,XCODE,mess(37,100,1),"",[F:OAXT]TEXTE,mess(200,115,1)
&                   ,mess(37,100,1)-mess(81,126,1)-[F:DAXT]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
                Endif
            Else
                INTERM1 = num$(evalue("[F:"+AOBJ+"1]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
                INTERM2 = num$(evalue("[F:"+AOBJ+"2]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
                If INTERM1 <> INTERM2
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Gosub FORMAT_KT From ACOMPOBJ2
                    If K<>1
                        If OBJ=0
                            Call TRACE("AOE",[F:AOE1]EXT,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",
&                            INTZON(OBJ,I),mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)  From ACOMPOBJ2
                        Else
                            Call TRACE("AEV",[F:AEV1]CODE,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",
&                            INTZON(OBJ,I),mess(201,115,1),mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)  From ACOMPOBJ2
                        Endif
                    Else
                        If OBJ=0
                            Call TRACE("AOE",[F:AOE1]EXT,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1),
&                           mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)  From ACOMPOBJ2
                        Else
                            Call TRACE("AEV",[F:AEV1]CODE,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1),
&                           mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF)  From ACOMPOBJ2
                        Endif
                    Endif
                Endif
            Endif
        Next J
    Endif
Next I
Return


########################################################################################
$COMP_AEV                                   #### MODELE tablau/import  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(229,115,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_AEV)+")",0) From GESECRAN       # modele
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif
DIF = 0
If !NB_AEV
   # modele inexistante
   Call TRACE("AEV","","","","","",mess(230,115,1),EXCEL,-1,DIF) From ACOMPOBJ2
   Return
Endif
Raz NBFIC
For COD="AOBJEXT","AEXPV3"
    Gosub TRT_ATABZON  From ACOMPOBJ2
    NBFIC+=1
Next
## Début de la comparaison
CRITERE  = "1=1"
TOUT = 0
If [M:ACMP]AEVDEB="" & [M:ACMP]AEVFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODE<'X'"
 Endif
Else
 CRITERE += "& CODE>=[M:ACMP]AEVDEB & CODE<=[M:ACMP]AEVFIN"
Endif
For [F:AEV1]AEV0 Where evalue(CRITERE)
    Filter [F:AEV2] Where [F:AEV2]CODE=[F:AEV1]CODE
    Read [F:AEV2] First
    If fstat
        Call TRACE("AEV",[F:AEV1]CODE,"","","",mess(87,100,1),
&       mess(229,115,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
        # Modele inexistant "
    Else
        Raz OK_C
        OBJ=1 : Gosub TRT_AOE
        If [M:ACMP]DETAIL=2
            If !OK_C & !TOUT & !EXCEL
                Call TRACE("AEV",[F:AEV1]CODE,"","","","",mess(227,115,1),EXCEL,0,DIF) From ACOMPOBJ2
                # modèle identique
            Endif
        Else
            If OK_C=1
                Call TRACE("AEV",[F:AEV1]CODE,"","","",mess(3,55,1),mess(228,115,1),EXCEL,-1,DIF) From ACOMPOBJ2
                # modèle différent
                If PATCH : Call PATCH("AOE",[F:AOE1]COD,"") From ACOMPOBJ2 : Endif
            Endif
        Endif
    Endif
    Filter [F:AEV2]
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:AEV2]AEV0 Where evalue(CRITERE)
    Read [F:AEV1]AEV0=[F:AEV2]CODE
    If fstat
        Call TRACE("AEV",[F:AEV2]CODE,"","","",mess(87,100,1),
&       mess(229,115,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
        # modele inexistante sous
    Endif
Next
Return

