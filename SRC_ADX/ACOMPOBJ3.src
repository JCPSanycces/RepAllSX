########################################################################################
$COMP_ACV                                   #### Activity codes ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(24,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ACV)+")",0) From GESECRAN       # modele
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ACV
   If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
    Call TRACE("ACV","","","","","",mess(230,115,1),EXCEL,-1,DIF) From ACOMPOBJ2
   Endif
   Return
Endif
Raz NBFIC
For COD="ACTIV"
    Gosub TRT_ATABZON  From ACOMPOBJ2
    NBFIC+=1
Next
## Début de la comparaison
CRITERE  = "1=1"
TOUT = 0
If [M:ACMP]ACVDEB="" & [M:ACMP]ACVFIN="ZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODACT<'X'"
 Endif
Else
 CRITERE += "& CODACT>=[M:ACMP]ACVDEB & CODACT<=[M:ACMP]ACVFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ACV1]CODACT Where evalue(CRITERE)
    FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ACV From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ACV1: Endif        #X3PLAT-940 - Filter on activity code

    Filter [F:ACV2] Where [F:ACV2]CODACT=[F:ACV1]CODACT
    Read [F:ACV2] First
    If fstat
        Call TRACE("ACV",[F:ACV1]CODACT,"","","",mess(87,100,1),
&       mess(14,115,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
        # Modele inexistant "
    Else
        Raz OK_C
        OBJ=0 : Gosub TRT_ACV
        If [M:ACMP]DETAIL=2
            If !OK_C & !TOUT & !EXCEL
                Call TRACE("ACV",[F:ACV1]CODACT,"","","","",mess(85,126,1),EXCEL,0,DIF) From ACOMPOBJ2
                # modèle identique
            Endif
        Else
            If OK_C=1
                Call TRACE("ACV",[F:ACV1]CODACT,"","","",mess(3,55,1),mess(14,115,1),EXCEL,-1,DIF) From ACOMPOBJ2
                # modèle différent
                If PATCH : Call PATCH("ACV",[F:ACV1]CODACT,"") From ACOMPOBJ2 : Endif
            Endif
        Endif
    Endif
    Filter [F:ACV2]
$NEXT_ACV1                    #X3PLAT-940 - Filter on activity code
Next
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ACV2]CODACT Where evalue(CRITERE)
    FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
    Gosub FILTRE_ACV From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
    If !OK Goto NEXT_ACV2: Endif        #X3PLAT-940 - Filter on activity code

    Read [F:ACV1]CODACT=[F:ACV2]CODACT
    If fstat
        Call TRACE("ACV",[F:ACV2]CODACT,"","","",mess(87,100,1),
&       mess(14,115,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
        # modele inexistante sous
    Endif
$NEXT_ACV2  # X3PLAT-940 - Filter on activity code
Next
Return
#X3PLAT-941 - add activity code comparison - RBU

###################################################################################
Subprog PATCH(OBJET,CODE,INTIT)
Value Char    OBJET , CODE , INTIT
Local Char    FICPATCH(GDIMFIC)
Local Integer EXISTE
If GFILPATH=""
 GFILPATH = filpath("tmp","patch_comp_"+tolower(GUSER),"dat")
Endif
EXISTE = (filinfo(GFILPATH,0)>0)
If !EXISTE & OBJET="" : End : Endif
Openo GFILPATH Using [AFPT]
Iomode adxifs "," Using [AFPT]
Iomode adxirs chr$(10) Using [AFPT]
Iomode adxium GUTF8 Using [AFPT]
If !EXISTE
 # En-tête fichier
 Wrseq '1'; Using [AFPT]
 Wrseq '"'+mess(143,139,1)-"("+format$(GFMD,date$)+")"+'"'; Using [AFPT]
 Wrseq '"'+GLANGUE+'"'; Using [AFPT]
 Wrseq '""'; Using [AFPT]
 Wrseq '""'; Using [AFPT]
 Case GPRODUIT
  When -1 : Wrseq '"SU"'; Using [AFPT]
  When  0 : Wrseq '"X3"'; Using [AFPT]
  When  1 : Wrseq '"GX"'; Using [AFPT]
  When  2 : Wrseq '"PA"'; Using [AFPT]
  When  3 : Wrseq '"AB"'; Using [AFPT]
 Endcase
 Wrseq '"1"' Using [AFPT]
Endif
Case OBJET
 When "" : # Fin fichier
  Wrseq '8';'""' Using [AFPT]
 When "TRT"
  Wrseq '2';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
  Wrseq  string$(10,"*") Using [AFPT]
  Wrseq '7';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
 When "ADX"
  Wrseq '2';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
  Wrseq "0"; Using [AFPT]
  Wrseq  string$(10,"*") Using [AFPT]
  Wrseq '7';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
 When Default
  Wrseq '2';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
  Wrseq '7';'"'+[L]OBJET+'"';'"'+[L]CODE+'"';'"'+[L]INTIT+'"' Using [AFPT]
Endcase
Openo Using [AFPT]
End


######################################################################################
$COMP_ACLA                                           #### CLASSES ########################
########################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-":"-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-":"-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(3,140,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ACLA)+")",0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ACLA
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
  Call TRACE("ACLA","","","","","",mess(4,140,1),EXCEL,-1,DIF) From ACOMPOBJ2 : # Ecran inexistant
 Endif
 Return
Endif
##

Raz NBFIC
For COD="ACLASSE","ACLAFLD","ACLAPARFLD","ACLAOPT","ACLAMETSTD","ACLAMET","ACLAPARDEF","ACLALNK","ACLAMAP","ACLACOL"
    Gosub TRT_ATABZON From ACOMPOBJ2
    NBFIC += 1
Next
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ACLADEB="" & [M:ACMP]ACLAFIN="ZZZZZZZZZZZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODCLA<'X'"
 Endif
Else
 CRITERE += "& CODCLA>=[M:ACMP]ACLADEB & CODCLA<=[M:ACMP]ACLAFIN"
Endif
If left$([M:ACMP]ACLADEB,1)<>"W" & left$([M:ACMP]ACLAFIN,1)<>"W"
 CRITERE += "& left$(CODCLA,1)<>'W'"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

## Début de la comparaison
For [ACLA1]ACLA0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACLA1]MODULE-1,0)) = 2
      FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
      Gosub FILTRE_ACLA From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
      If !OK Goto NEXT_ACLA1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:ACLA2]ACLA0=[F:ACLA1]CODCLA
        If fstat
            DIF = 1
            # Ecran inexistant sous
            Call TRACE("ACLA",[F:ACLA1]CODCLA,"","","",mess(87,100,1),mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_ACLA
            ## Traitement des champs de ORG --> DES
            For [ACLAF1]ACLAF0 Where CODCLA=[ACLA1]CODCLA
                Read [ACLAF2]ACLAF0=[ACLA1]CODCLA;[ACLAF1]FLDCLA
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[F:ACLAF1]INTFLD
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(34,140,1),[F:ACLAF1]FLDCLA,[F:OATX]TEXTE,mess(33,140,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                    # propriété
                Else
                    OBJ=1 : Gosub TRT_ACLA
                    For [ACLFP1]ACLFP0 Where CODCLA=[ACLA1]CODCLA & FLDCLA=[ACLAF1]FLDCLA
                        Read [ACLFP2]ACLFP0=[ACLFP1]CODCLA;[ACLFP1]TYPPAR;[ACLFP1]TYPKEY;[ACLFP1]FLDCLA;[ACLFP1]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ACLA",[ACLA1]CODCLA,mess(34,140,1),[ACLAF1]FLDCLA,[ACLFP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
                        Else
                            OBJ = 2 : Gosub TRT_ACLA
                        Endif
                    Next ACLFP1
                Endif
            Next ACLAF1
            For [ACLAO1]ACLAO0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAO2]ACLAO0=[ACLAO1]CODCLA;[ACLAO1]OPTCOD
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(168,124,1),[ACLAO1]OPTCOD,"",mess(71,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
            Else
              OBJ = 3 : Gosub TRT_ACLA
            Endif
            Next ACLAO1
            For [ACLAT1]ACLAT0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAT2]ACLAT0=[ACLAT1]CODCLA;[ACLAT1]CODMETSTD
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(1,7845,1),[ACLAT1]CODMETSTD,"",mess(172,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
             Else
              OBJ = 4 : Gosub TRT_ACLA

            Endif
            Next ACLAT1
            For [ACLAM1]ACLAM0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAM2]ACLAM0=[ACLAM1]CODCLA;[ACLAM1]CODMET
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(1,7845,1),[ACLAM1]CODMET,"",mess(172,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
             Else
              OBJ = 5 : Gosub TRT_ACLA
              For [ACLPD1]ACLPD0 Where CODCLA=[ACLA1]CODCLA & CODE=[ACLAM1]CODMET
               Read [ACLPD2]ACLPD0=[ACLPD1]CODCLA;[ACLPD1]CODE;[ACLPD1]CODPAR
               If fstat
                OK_C = 1
                Call TRACE ("ACLA",[ACLA1]CODCLA,mess(145,105,1),[ACLPD1]CODE,[ACLPD1]CODPAR,mess(11,133,1)
&                ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
               # Ecran & Paramètre & inexistant sous
              Else
                OBJ = 6 : Gosub TRT_ACLA
               Endif
              Next ACLPD1
            Endif
            Next ACLAM1
            For [ACLAK1]ACLAK0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAK2]ACLAK0=[ACLAK1]CODCLA;[ACLAK1]REFLNK
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(11,16,1),[ACLAK1]REFLNK,"",mess(253,139,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & liens & inexistant sous
             Else
              OBJ = 7: Gosub TRT_ACLA
              For [ACLAKP1]ACLAKP0 Where CODCLA=[ACLA1]CODCLA & REFLNK=[ACLAK1]REFLNK
               Read [ACLAKP2]ACLAKP0=[ACLA1]CODCLA;[ACLAKP1]REFLNK;[ACLAKP1]KEYMAP
               If fstat
                OK_C = 1
                Call TRACE ("ACLA",[ACLA1]CODCLA,mess(75,140,1),[ACLAK1]REFLNK,"",mess(76,140,1)
&                ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
               # Ecran & mapping & inexistant sous
              Else
                OBJ = 8 : Gosub TRT_ACLA
               Endif
              Next ACLAKP1
            Endif
            Next ACLAK1
            For [ACLAC1]ACLAC0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAC2]ACLAC0=[ACLAC1]CODCLA;[ACLAC1]CODCOL
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(3,297,1),[ACLAC1]CODCOL,"",mess(144,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
            Else
              OBJ = 9 : Gosub TRT_ACLA
            Endif
            Next ACLAO1
            ##############################
            ## Traitement des champs de DES --> ORG
            ##############################
            For [ACLAF2]ACLAF0 Where CODCLA=[F:ACLA1]CODCLA
                Read [ACLAF1]ACLAF0 = [ACLAF2]CODCLA;[ACLAF2]FLDCLA
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [DATX]NUMERO=GLANGUE;[ACLAF2]INTFLD
                    If fstat : [F:DATX]TEXTE="" : Endif
                    OK_C = 1
                    Call TRACE("ACLA",[ACLA1]CODCLA,mess(34,140,1),[F:ACLAF2]FLDCLA,[F:DATX]TEXTE,mess(33,140,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2 : # Champs
                Else
                    For [ACLFP2]ACLFP0 Where CODCLA=[ACLA2]CODCLA & FLDCLA=[ACLAF2]FLDCLA
                        Read [ACLFP1]ACLFP0=[ACLFP2]CODCLA;[ACLFP2]TYPPAR;[ACLFP2]TYPKEY;[ACLFP2]FLDCLA;[ACLFP2]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ACLA",[ACLA1]CODCLA,mess(34,140,1),[ACLAF1]FLDCLA,[ACLFP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
                        Endif
                    Next AMP2
                Endif
            Next ACLAF2
            For [ACLAO2]ACLAO0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAO1]ACLAO0=[ACLAO2]CODCLA;[ACLAO2]OPTCOD
             If fstat
              OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(168,124,1),[ACLAO2]OPTCOD,"",mess(71,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & option & inexistant sous
             Endif
            Next ACLAO2
            For [ACLAT2]ACLAT0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAT1]ACLAT0=[ACLAT2]CODCLA;[ACLAT2]CODMETSTD
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(1,7845,1),[ACLAT2]CODMETSTD,"",mess(172,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
             Endif
            Next ACLAT1
            For [ACLAM2]ACLAM0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAM1]ACLAM0=[ACLAM2]CODCLA;[ACLAM2]CODMET
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(1,7845,1),[ACLAM2]CODMET,"",mess(172,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
             Else
              For [ACLPD2]ACLPD0 Where CODCLA=[ACLA2]CODCLA & CODE=[ACLAM2]CODMET
               Read [ACLPD1]ACLPD0=[ACLPD2]CODCLA;[ACLPD2]CODE;[ACLPD2]CODPAR
               If fstat
                OK_C = 1
                Call TRACE ("ACLA",[ACLA1]CODCLA,mess(145,105,1),[ACLPD2]CODE,[ACLPD2]CODPAR,mess(11,133,1)
&                ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
               # Ecran & Paramètre & inexistant sous
               Endif
              Next ACLPD2
            Endif
            Next ACLAM2
            For [ACLAK2]ACLAK0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAK1]ACLAK0=[ACLAK2]CODCLA;[ACLAK2]REFLNK
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(11,16,1),[ACLAK2]REFLNK,"",mess(253,139,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & liens & inexistant sous
             Else
              For [ACLAKP2]ACLAKP0 Where CODCLA=[ACLA1]CODCLA & REFLNK=[ACLAK1]REFLNK
               Read [ACLAKP1]ACLAKP0=[ACLA1]CODCLA;[ACLAKP2]REFLNK;[ACLAKP2]KEYMAP
               If fstat
                OK_C = 1
                Call TRACE ("ACLA",[ACLA1]CODCLA,mess(75,140,1),[ACLAK2]REFLNK,"",mess(76,140,1)
&                ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
               # Ecran & mapping & inexistant sous
               Endif
              Next ACLAKP1
            Endif
            Next ACLAK1
            For [ACLAC2]ACLAC0 Where CODCLA=[ACLA1]CODCLA
             Read [ACLAC1]ACLAC0=[ACLAC2]CODCLA;[ACLAC2]CODCOL
             If fstat
               OK_C = 1
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(3,297,1),[ACLAC2]CODCOL,"",mess(144,143,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
            Endif
            Next ACLAC2
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ACLA",[ACLA1]CODCLA,"","","",mess(69,140,1),"",EXCEL,0,DIF) From ACOMPOBJ2
                    # classe identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ACLA",[ACLA1]CODCLA,"","","",mess(49,124,1),"",EXCEL,-1,DIF) From ACOMPOBJ2
                    # Différent
                    If PATCH : Call PATCH("ACLA",[ACLA1]CODCLA,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_ACLA1                    #X3PLAT-940 - Filter on activity code
Next ACLA1
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [ACLA2]ACLA0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACLA2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ACLA From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ACLA2: Endif        #X3PLAT-940 - Filter on activity code

        Read [ACLA1]ACLA0=[ACLA2]CODCLA
        If fstat
            OK_C = 1
            Call TRACE("ACLA",[ACLA2]CODCLA,"","",[ACLA2]CODCLA,mess(87,100,1),mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
            # Ecran inexistant sous
        Endif
    Endif
$NEXT_ACLA2  # X3PLAT-940 - Filter on activity code
Next ACLA2
Return

#############################
$TRT_ACLA
If OBJ=9 : AOBJ="ACLAC" : Endif
If OBJ=8 : AOBJ="ACLAKP" : Endif
If OBJ=7 : AOBJ="ACLAK" : Endif
If OBJ=6 : AOBJ="ACLPD" : Endif
If OBJ=5 : AOBJ="ACLAM" : Endif
If OBJ=4 : AOBJ="ACLAT" : Endif
If OBJ=3 : AOBJ="ACLAO" : Endif
If OBJ=2 : AOBJ="ACLFP" : Endif
If OBJ=1 : AOBJ="ACLAF" : Endif
If OBJ=0
    AOBJ="ACLA"
Else
    Read [F:OATX]NUMERO=GLANGUE;[ACLAF1]INTFLD
    If fstat : LIBEL="" Else LIBEL=[F:OATX]TEXTE : Endif
Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
    If TYP(OBJ,I) = "ATX" & evalue("dim(["+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
            If OBJ<>0
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(149,123,1),[ACLAF1]FLDCLA,[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
               # classe & Champ & Intitulés différents
            Else
               Call TRACE("ACLA",[ACLA1]CODCLA,mess(82,123,1),"",[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
               # Classe & Intitulés différents
            Endif
        Endif
    Else
        Raz INTERM1 , INTERM2
        If evalue("dim([F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If evalue("dim([F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If INTERM1 <> INTERM2
           OK_C = 1
           If [M:ACMP]DETAIL<>2 : Break 2 : Endif
           Gosub FORMAT_KT From ACOMPOBJ2
           If OBJ = 0 : # classe
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(3,140,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 1 :  # proprietes
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(34,140,1),[ACLAF1]FLDCLA,INTZON(OBJ,I),mess(74,140,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 2 : # parametre propriété
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(34,140,1),[ACLAF1]FLDCLA,LIBEL,mess(203,115,1)
&             ,[ACLFP1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
          Elsif OBJ = 3 : # options
             If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(168,124,1),[ACLAO1]OPTCOD,INTZON(OBJ,I),mess(73,140,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 4 : # methode std
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(1,7845,1),[ACLAT1]CODMETSTD,LIBEL,mess(72,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
          Elsif OBJ = 5 # methodes
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(1,7845,1),[ACLAM1]CODMET,LIBEL,mess(72,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 6 : #parametre méthodes
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(1,7845,1),[ACLAM1]CODMET,LIBEL,mess(203,115,1)
&             ,[ACLPD1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
        Elsif OBJ = 7 : # Liens
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(11,16,1),[ACLAK1]REFLNK,LIBEL,mess(77,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 8 : # mapping
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(75,140,1),[ACLAK1]REFLNK,LIBEL,mess(78,140,1)
&             ,[ACLAKP1]KEYMAP-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 9 # collection
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ACLA",[F:ACLA1]CODCLA,mess(3,297,1),[ACLAC1]CODCOL,LIBEL,mess(80,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
          Endif
        Endif
    Endif
    Next J
Next I
Return


######################################################################################
$COMP_ASW                                           #### REPRESENTATION                         ########################
######################################################################################
## Entete de comparaison
If !EXCEL & GTRACE<>""
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-":"-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-":"-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(23,140,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ASW)+")",0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ASW
 If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
  Call TRACE("ASW","","","","","",mess(15,140,1),EXCEL,-1,DIF) From ACOMPOBJ2 : # Ecran inexistant
 Endif
 Return
Endif
##
Raz NBFIC
For COD="ASHW","ASHWFLD","ASHWPAR","ASHWCOL","ASHWBLC","ASHWSEC","ASHWOPT","ASHWMET","ASHWPARMET","ASHWMENU","ASHWEXPPRO"
&          ,"ASHWLNK","ASHWPAR"
    Gosub TRT_ATABZON From ACOMPOBJ2
    NBFIC += 1
Next
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ACLADEB="" & [M:ACMP]ACLAFIN="ZZZZZZZZZZZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& CODREP<'X'"
 Endif
Else
 CRITERE += "& CODREP>=[M:ACMP]ASWDEB & CODREP<=[M:ACMP]ASWFIN"
Endif
If left$([M:ACMP]ASWDEB,1)<>"W" & left$([M:ACMP]ASWFIN,1)<>"W"
 CRITERE += "& left$(CODREP,1)<>'W'"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

## Début de la comparaison
For [ASW1]ASW0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ASW1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ASW From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ASW1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:ASW2]ASW0=[ASW1]CODREP
        If fstat
            DIF = 1
            # rep inexistant sous
            Call TRACE("ASW",[ASW1]CODREP,"","","",mess(87,100,1),mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_ASW
            ##############################
            ## Traitement des champs de ORG --> DES
            ##############################
            For [ASWF1]ASWF0 Where CODREP=[ASW1]CODREP
                Read [ASWF2]ASWF0=[ASW1]CODREP;[ASWF1]CODFLD
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[F:ASWF1]INTFLD
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[F:ASWF1]CODFLD,[F:OATX]TEXTE,mess(33,140,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                    # propriété
                Else
                    OBJ=1 : Gosub TRT_ASW
                    For [ASWP1]ASWP0 Where CODREP=[ASW1]CODREP & CODFLD=[ASWF1]CODFLD & CODLNK=""
                        Read [ASWP2]ASWP0=[ASWP1]CODREP;[ASWP1]TYPPAR;[ASWP1]TYPKEY;[ASWP1]CODFLD;[ASWP1]CODLNK;[ASWP1]AFFLNK;[ASWP1]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[ASWF1]CODFLD,[ASWP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # rep & Paramètre & inexistant sous
                        Else
                            OBJ = 2 : Gosub TRT_ASW
                        Endif
                    Next ASWP1
                Endif
            Next ASWF1
            For [ASWC1]ASWC0 Where CODREP=[ASW1]CODREP
              Read [ASWC2]ASWC0=[ASW1]CODREP;[ASWC1]CODCOL
              If fstat
                OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(3,297,1),[ASWC1]CODCOL,"",mess(144,143,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & coolection & inexistant sous
             Else
               OBJ = 3 : Gosub TRT_ASW
             Endif
            Next
            For [ASWB1]ASWB0 Where CODREP=[ASW1]CODREP
              Read [ASWB2]ASWB0=[ASW1]CODREP;[ASWB1]CODBLC
              If fstat
                OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(15,115,1),[ASWC1]CODCOL,"",mess(141,123,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & bloc & inexistant sous
             Else
               OBJ = 4 : Gosub TRT_ASW
             Endif
            Next
            For [ASWS1]ASWS0 Where CODREP=[ASW1]CODREP
              Read [ASWS2]ASWS0=[ASW1]CODREP;[ASWS1]CODSEC
              If fstat
                 OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(17,103,1),[ASWS1]CODSEC,"",mess(35,106,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & section & inexistant sous
             Else
               OBJ = 5: Gosub TRT_ASW
             Endif
            Next
            For [ASWO1]ASWO0 Where CODREP=[ASW1]CODREP
             Read [ASWO2]ASWO0=[ASW1]CODREP;[ASWO1]OPTCOD
             If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(168,124,1),[ASWO1]OPTCOD,"",mess(71,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
            Else
              OBJ = 6: Gosub TRT_ASW
            Endif
            Next ASWO1
            For [ASWM1]ASWM0 Where CODREP=[ASW1]CODREP
                Read [ASWM2]ASWM0=[ASW1]CODREP;[ASWM1]CODMET
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[ASWM1]INTMET
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(1,7845,1),[ASWM1]CODMET,[F:OATX]TEXTE,mess(172,143,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                Else
                    OBJ=7 : Gosub TRT_ASW
                    For [ASWMP1]ASWMP0 Where CODREP=[ASW1]CODREP & CODMET=[ASWM1]CODMET
                        Read [ASWMP2]ASWMP0=[ASW1]CODREP;[ASWMP1]CODMET;[ASWMP1]CODPARMET
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(143,105,1),[ASWMP1]CODMET,[ASWMP1]CODPARMET,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                         # rep & Paramètre & inexistant sous
                        Else
                            OBJ = 8 : Gosub TRT_ASW
                        Endif
                    Next ASWMP1
                Endif
            Next ASWM1
            For [ASWMN1]ASWMN0 Where CODREP=[ASW1]CODREP
             Read [ASWMN2]ASWMN0=[ASW1]CODREP;[ASWMN1]CODMENU
             If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(2,88,1),[ASWMN1]CODMENU,"",mess(154,124,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
             Else
               OBJ = 9: Gosub TRT_ASW
             Endif
            Next ASWMN1
            For [ASWR1]ASWR0 Where CODREP=[ASW1]CODREP
             Read [ASWR2]ASWR0=[ASW1]CODREP;[ASWR1]ALIAS
             If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(84,140,1),[ASWR1]ALIAS,"",mess(85,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
             Else
               OBJ = 10 : Gosub TRT_ASW
             Endif
            Next ASWR1
            For [ASWK1]ASWK0 Where CODREP=[ASW1]CODREP
                Read [ASWK2]ASWK0=[ASW1]CODREP;[ASWK1]AFFLNK;[ASWK1]ANCLNK;[ASWK1]CODLNK
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[ASWK1]INTLNK
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),[ASWK1]CODLNK,[F:OATX]TEXTE,mess(253,139,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                Else
                    OBJ= 11 : Gosub TRT_ASW
                    For [ASWP1]ASWP0 Where CODREP=[ASW1]CODREP & CODFLD=[ASWK1]ANCLNK & CODLNK= [ASWK1]CODLNK & AFFLNK=[ASWK1]AFFLNK & TYPPAR=3
                        Read [ASWP2]ASWP0=[ASWP1]CODREP;[ASWP1]TYPPAR;[ASWP1]TYPKEY;[ASWP1]CODFLD;[ASWP1]CODLNK;[ASWP1]AFFLNK;[ASWP1]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),[ASWK1]CODLNK,[ASWP1]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                        Else
                            OBJ = 12 : Gosub TRT_ASW
                        Endif
                    Next ASWP1
                Endif
            Next ASWK1
            ## Traitement des champs de DES --> ORG
            ##############################
            For [ASWF2]ASWF0 Where CODREP=[ASW1]CODREP
                Read [ASWF1]ASWF0=[ASW2]CODREP;[ASWF2]CODFLD
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[F:ASWF2]INTFLD
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[F:ASWF1]CODFLD,[F:OATX]TEXTE,mess(33,140,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                    # propriété
                Else
                    OBJ=1 : Gosub TRT_ASW
                    For [ASWP2]ASWP0 Where CODREP=[ASW1]CODREP & CODFLD=[ASWF2]CODFLD & CODLNK=""
                        Read [ASWP1]ASWP0=[ASWP1]CODREP;[ASWP1]TYPPAR;[ASWP1]TYPKEY;[ASWP1]CODFLD;[ASWP1]CODLNK;[ASWP1]AFFLNK;[ASWP1]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[ASWF2]CODFLD,[ASWP2]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # Ecran & Paramètre & inexistant sous
                        Endif
                    Next ASWP2
                Endif
            Next ASWF2
             For [ASWC1]ASWC0 Where CODREP=[ASW1]CODREP
              Read [ASWC2]ASWC0=[ASW1]CODREP;[ASWC1]CODCOL
              If fstat
                OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(3,297,1),[ASWC1]CODCOL,"",mess(144,143,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & coolection & inexistant sousoa
             Endif
            Next
            For [ASWB2]ASWB0 Where CODREP=[ASW1]CODREP
              Read [ASWB1]ASWB0=[ASW1]CODREP;[ASWB2]CODBLC
              If fstat
                OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(15,115,1),[ASWC2]CODCOL,"",mess(144,143,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & coolection & inexistant sous
             Endif
            Next
            For [ASWS2]ASWS0 Where CODREP=[ASW1]CODREP
              Read [ASWS1]ASWS0=[ASW1]CODREP;[ASWS2]CODSEC
              If fstat
                OK_C = 1
                Call TRACE("ASW",[ASW1]CODREP,mess(17,103,1),[ASWS2]CODSEC,"",mess(35,36,1)
&              ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                # rep & section & inexistant sous
             Endif
            Next
            For [ASWO2]ASWO0 Where CODREP=[ASW1]CODREP
              Read [ASWO1]ASWO0=[ASW1]CODREP;[ASWO2]OPTCOD
              If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(168,124,1),[ASWO2]OPTCOD,"",mess(71,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # option & inexistant sous
            Endif
            Next ASWO1
             For [ASWM2]ASWM0 Where CODREP=[ASW1]CODREP
                Read [ASWM1]ASWM0=[ASW1]CODREP;[ASWM2]CODMET
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[ASWM1]INTMET
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(1,7845,1),[F:ASWF2]CODMET,[F:OATX]TEXTE,mess(172,143,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                Else
                    For [ASWMP2]ASWMP0 Where CODREP=[ASW1]CODREP & CODMET=[ASWM2]CODMET
                        Read [ASWMP1]ASWMP0=[ASW2]CODREP;[ASWMP2]CODMET;[ASWMP2]CODPARMET
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(143,105,1),[ASWMP2]CODMET,[ASWMP2]CODPARMET,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                         # rep & Paramètre & inexistant sous
                        Endif
                    Next ASWMP2
                Endif
            Next ASWM2
            For [ASWMN2]ASWMN0 Where CODREP=[ASW1]CODREP
             Read [ASWMN1]ASWMN0=[ASW1]CODREP;[ASWMN2]CODMENU
             If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(2,88,1),[ASWMN2]CODMENU,"",mess(154,124,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
             Endif
            Next ASWMN2
            For [ASWR2]ASWR0 Where CODREP=[ASW1]CODREP
             Read [ASWR1]ASWR0=[ASW1]CODREP;[ASWR2]ALIAS
             If fstat
               OK_C = 1
               Call TRACE("ASW",[ASW1]CODREP,mess(84,140,1),[ASWR2]ALIAS,"",mess(85,140,1)
&             ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
             Endif
            Next ASWR2
            For [ASWK2]ASWK0 Where CODREP=[ASW1]CODREP
                Read [ASWK1]ASWK0=[ASW1]CODREP;[ASWK2]AFFLNK;[ASWK2]ANCLNK;[ASWK2]CODLNK
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Read [F:OATX]NUMERO=GLANGUE;[ASWK1]INTLNK
                    If fstat : [F:OATX]TEXTE="" : Endif
                    Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),[ASWK1]CODLNK,[F:OATX]TEXTE,mess(253,139,1)
&                   ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                Else
                    For [ASWP2]ASWP0 Where CODREP=[ASW1]CODREP & CODFLD=[ASWK2]ANCLNK  & CODLNK= [ASWK2]CODLNK & AFFLNK=[ASWK2]AFFLNK & TYPPAR=3
                        Read [ASWP1]ASWP0=[ASWP2]CODREP;[ASWP2]TYPPAR;[ASWP2]TYPKEY;[ASWP2]CODFLD;[ASWP2]CODLNK;[ASWP2]AFFLNK;[ASWP2]CODPAR
                        If fstat
                          OK_C = 1
                          Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),[ASWK2]CODLNK,[ASWP2]CODPAR,mess(11,133,1)
&                         ,mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                        Endif
                    Next ASWP2
                Endif
            Next ASWK2
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ASW",[ASW1]CODREP,"","","",mess(70,140,1),"",EXCEL,0,DIF) From ACOMPOBJ2
                    # representation identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ASW",[ASW1]CODREP,"","","",mess(49,124,1),"",EXCEL,-1,DIF) From ACOMPOBJ2
                    # Différent
                    If PATCH : Call PATCH("ASW",[ASW1]CODREP,"") : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_ASW1                    #X3PLAT-940 - Filter on activity code
Next ASW1
## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [ASW2]ASW0 Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([ASW2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ASW From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ASW2: Endif        #X3PLAT-940 - Filter on activity code

        Read [ASW1]ASW0=[ASW2]CODREP
        If fstat
            OK_C = 1
            Call TRACE("ASW",[ASW2]CODREP,"","",[ASW2]CODREP,mess(87,100,1),mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
            # Ecran inexistant sous
        Endif
    Endif
$NEXT_ASW2  # X3PLAT-940 - Filter on activity code
Next ASW2
Return


#############################
$TRT_ASW
If OBJ=12 : AOBJ="ASWP" : Endif
If OBJ=11 : AOBJ="ASWK" : Endif
If OBJ=10 : AOBJ="ASWR" : Endif
If OBJ=9 : AOBJ="ASWMN" : Endif
If OBJ=8 : AOBJ="ASWMP" : Endif
If OBJ=7 : AOBJ="ASWM" : Endif
If OBJ=6 : AOBJ="ASWO" : Endif
If OBJ=5 : AOBJ="ASWS" : Endif
If OBJ=4 : AOBJ="ASWB" : Endif
If OBJ=3 : AOBJ="ASWC" : Endif
If OBJ=2 : AOBJ="ASWP" : Endif
If OBJ=1 : AOBJ="ASWF" : Endif
If OBJ=0
    AOBJ="ASW"
Else
    Read [F:OATX]NUMERO=GLANGUE;[ASWF1]INTFLD
    If fstat : LIBEL="" Else LIBEL=[F:OATX]TEXTE : Endif
Endif

For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    If OBJ=11 and find(ZON(OBJ,I),"NUMLNK") : K=0 : Endif
    If find(OBJ,2,12)>0 and find(ZON(OBJ,I),"AWMAJTYP")>0: K=0 : Endif

    For J=1 To K
    If TYP(OBJ,I) = "ATX" & evalue("dim(["+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
        Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:OATX]TEXTE="" : Endif
        Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
        If fstat : [F:DATX]TEXTE="" : Endif
        If [F:OATX]TEXTE <> [F:DATX]TEXTE
            OK_C = 1
            If [M:ACMP]DETAIL<>2 : Break 2 : Endif
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
            If OBJ<>0
               Call TRACE("ASW",[ASW1]CODREP,mess(149,123,1),[ASWF1]CODFLD,[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
               # classe & Champ & Intitulés différents
            Else
               Call TRACE("ASW",[ASW1]CODREP,mess(82,123,1),"",[F:OATX]TEXTE,mess(200,115,1)
&              ,MESSTECH-[F:OATX]TEXTE-"<>"-[F:DATX]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
               # Classe & Intitulés différents
            Endif
        Endif
    Else
        Raz INTERM1 , INTERM2
        If evalue("dim([F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If evalue("dim([F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
         INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
        Endif
        If INTERM1 <> INTERM2
           OK_C = 1
           If [M:ACMP]DETAIL<>2 : Break 2 : Endif
           Gosub FORMAT_KT From ACOMPOBJ2
           If OBJ = 0 : # Represenation
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Elsif OBJ>0 MESSTECH="["+AOBJ+"]" : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(23,140,1),ZON(OBJ,I),INTZON(OBJ,I),mess(79,140,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 1 : # Propriété
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[ASWF1]CODFLD,INTZON(OBJ,I),mess(74,140,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 2 : # parameter de propriete
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(34,140,1),[ASWF1]CODFLD,LIBEL,mess(203,115,1)
&             ,[ASWP1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 3 : #  Collection
             If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(3,297,1),[ASWC1]CODCOL,INTZON(OBJ,I),mess(80,140,1)
&            ,MESSTECH-INTERM1-"<>"-INTERM2-mess(81,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
           Elsif OBJ = 4 : # Bloc"
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(15,115,1),[ASWB1]CODBLC,LIBEL,mess(81,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
          Elsif OBJ = 5 : # Section
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(48,105,1),[ASWS1]CODSEC,LIBEL,mess(82,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 6 : # Option
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(168,124,1),[ASWO1]OPTCOD,LIBEL,mess(71,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
        Elsif OBJ = 7 : # methode
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(1,7845,1),[ASWM1]CODMET,LIBEL,mess(72,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 8 : # parametre methodes
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(143,105,1),[ASWM1]CODMET,LIBEL,mess(203,115,1)
&             ,[ASWMP1]CODPARMET-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 9 # menu
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(75,140,1),[ASWMN1]CODMENU,LIBEL,mess(83,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 10 # propriete exposée
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(75,140,1),[ASWR1]ALIAS,LIBEL,mess(86,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 11 # lien
            If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
           Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),num$([ASWK2]AFFLNK)-[ASWK2]ANCLNK-[ASWK2]CODLNK,LIBEL,mess(78,140,1)
&             ,MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
         Elsif OBJ = 12 : # parameter de lien
              If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH=" / ["+AOBJ+"]"+ZON(OBJ,I) : Endif
              Call TRACE("ASW",[ASW1]CODREP,mess(11,16,1),num$([ASWK2]AFFLNK)-[ASWK2]ANCLNK-[ASWK2]CODLNK,LIBEL,mess(203,115,1)
&             ,[ASWP1]CODPAR-MESSTECH-INTZON(OBJ,I)-mess(81,126,1)-"'"-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
          Endif
        Endif
    Endif
    Next J
Next I
Return



$TRT_ATY
If OBJ=2 : AOBJ = "ATYRP" : Endif
If OBJ=1 : AOBJ = "ATYR"  : Endif
If OBJ=0 : AOBJ = "ATY" : Endif
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("ATY",[F:ATY1]CODTYP,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE,mess(200,115,1)
&               ,[F:DATX]TEXTE,EXCEL,-1,DIF)From ACOMPOBJ2
                # Type & intitulés différents
            Endif
        Else
            Raz INTERM1 , INTERM2
            If evalue("dim([F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
             INTERM1 = num$(evalue("[F:"+AOBJ+"1"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            Endif
            If evalue("dim([F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+"))")>0
             INTERM2 = num$(evalue("[F:"+AOBJ+"2"+"]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            Endif
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                If [M:ACMP]TECHNI<>2 : Raz MESSTECH : Else MESSTECH="["+AOBJ+"]"+ZON(OBJ,I) : Endif
                If OBJ =0
                    Call TRACE("ATY",[F:ATY1]CODTYP,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
                    # Type & Champ & Différence
                Elsif OBJ =1
                    Call TRACE("ATY",[F:ATY1]CODTYP,mess(149,123,1),num$([ATYR1]TYPRUL)-[ATYR1]PRGRUL-[ATYR1]TRTRUL-ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
                    # Type & Champ & Différence

                Elsif OBJ =2
                    Call TRACE("ATY",[F:ATY1]CODTYP,mess(143,105,1),num$([ATYR1]TYPRUL)-[ATYR1]PRGRUL-[ATYR1]TRTRUL-[ATYRP1]PARCOD-ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
                    # Type & Champ & Différence
                Endif
            Endif
        Endif
    Next J
Next I
Return

########################################################################################
$COMP_ACT                                         #### ACTIONS  ########################
########################################################################################
If !EXCEL & GTRACE<>""
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(3,23,1)-mess(128,124,1)-" : "-[M]DOSORG-mess(3,23,1)-mess(129,124,1)-" : "-[M]DOSDES,0) From GESECRAN
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
 Call ECR_TRACE(mess(20,125,1)-format$("D:"+GFMDAT,date$)-time$-"("+num$(NB_ACT)+")",0) From GESECRAN    # Actions
 Call ECR_TRACE(string$(100,'-'),0) From GESECRAN
Endif

Local Integer FILTRE_STEP   # X3PLAT-940 - Filter on activity code -

DIF = 0
If !NB_ACT
   # Action inexistante
   If [M:ACMP]CODACT = ""   # X3PLAT-940 - Filter on activity code --do not display not existent object if filtering
     Call TRACE("ACT","","","","","",mess(84,133,1),EXCEL,-1,DIF) From ACOMPOBJ2
   Endif
   Return
Endif
Raz NBFIC
For COD="ACTION","ACTPAR"
    Gosub TRT_ATABZON From ACOMPOBJ2
    NBFIC +=1
Next

## Début de la comparaison
CRITERE = "1=1"
TOUT = 0
If [M:ACMP]ACTDEB="" & [M:ACMP]ACTFIN="ZZZZZZZZZZ"
 TOUT = 1
 If GADONIX=2
  CRITERE += "& ACTION<'X'"
 Endif
Else
 CRITERE += "& ACTION>=[M:ACMP]ACTDEB & ACTION<=[M:ACMP]ACTFIN"
Endif
If [M:ACMP]CODACT<>""   # X3PLAT-940 - Filter on activity code - Clear TOUT flag
  TOUT=0
Endif

For [F:ACT1]ACTION Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACT1]MODULE-1,0)) = 2
        FILTRE_STEP = 1                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ACT From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ACT1: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:ACT2]ACTION=[F:ACT1]ACTION
        If fstat
            Call TRACE("ACT",[F:ACT1]ACTION,"","","",mess(87,100,1),mess(30,124,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
            # Action inexistante sous
        Else
            Raz OK_C
            OBJ=0 : Gosub TRT_ACT From ACOMPOBJ2
            ## Traitement des paramètres de ORG --> DES
            For [F:ATR1]NOPAR Where [F:ATR1]ACTION=[F:ACT1]ACTION
                Read [ATR2]NOPAR=[F:ATR1]ACTION;[F:ATR1]NOPAR
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(143,105,1),[F:ATR1]CODPAR,"",mess(11,133,1)
&                   ,mess(81,123,1)-mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSDES),EXCEL,-1,DIF) From ACOMPOBJ2
                    # Action & Paramètre & inexistant sous
                Else
                    OBJ=1 : Gosub TRT_ACT From ACOMPOBJ2
                Endif
            Next
            ## Traitement des paramètres de DES --> ORG
            For [F:ATR2]NOPAR Where [F:ATR2]ACTION=[F:ACT1]ACTION
                Read [ATR1]NOPAR=[F:ATR2]ACTION;[F:ATR2]NOPAR
                If fstat
                    OK_C = 1
                    If [M:ACMP]DETAIL<>2 : Break : Endif
                    Call TRACE("ACT",[F:ACT1]ACTION,mess(143,105,1),[F:ATR2]CODPAR,"",mess(11,133,1)
&                   ,mess(81,123,1)-mess(79,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
                    # Action & Paramètre & inexistant sous
                Endif
            Next
            If [M:ACMP]DETAIL=2
                If !OK_C & !TOUT & !EXCEL
                    Call TRACE("ACT",[F:ACT1]ACTION,"","","","",mess(126,126,1),EXCEL,0,DIF) From ACOMPOBJ2
                    # Action identique
                Endif
            Else
                If OK_C=1
                    Call TRACE("ACT",[F:ACT1]ACTION,"","","",mess(3,55,1),mess(30,124,1)-mess(90,126,1),EXCEL,-1,DIF) From ACOMPOBJ2
                    # Action différente
                    If PATCH : Call PATCH("ACT",[F:ACT1]ACTION,"") From ACOMPOBJ2 : Endif
                Endif
            Endif
        Endif
    Endif
$NEXT_ACT1                    #X3PLAT-940 - Filter on activity code
Next

## Parcours du dossier destination pour rechercher l'inexistance d'un objet dans le dossier source
For [F:ACT2]ACTION Where evalue(CRITERE)
    If [M:ACMP]COPMOD(max([F:ACT2]MODULE-1,0)) = 2
        FILTRE_STEP = 2                     #X3PLAT-940 - Filter on activity code
        Gosub FILTRE_ACT From ACOMPOBJ3     #X3PLAT-940 - Filter on activity code
        If !OK Goto NEXT_ACT2: Endif        #X3PLAT-940 - Filter on activity code

        Read [F:ACT1]ACTION=[F:ACT2]ACTION
        If fstat
            Call TRACE("ACT",[F:ACT2]ACTION,"","","",mess(87,100,1),mess(30,124,1)-mess(82,126,1)-func ACOMPOBJ2.NOMDOS([M]DOSORG),EXCEL,-1,DIF) From ACOMPOBJ2
            # Action inexistante sous "
        Endif
    Endif
$NEXT_ACT2  # X3PLAT-940 - Filter on activity code
Next
Return

#X3PLAT-941 - add activity code comparison - RBU
$TRT_ACV
