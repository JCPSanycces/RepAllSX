                Endif
            Endif
        Endif
    Next J
Next I
Return

$TRT_ADC
OBJ=0
For I=1 To NBRZON(OBJ)
    If DIMZON(OBJ,I) = 0 | DIMZON(OBJ,I) = 1
        K = 1
    Else
        K=DIMZON(OBJ,I)
    Endif
    For J=1 To K
        If TYP(OBJ,I) = "ATX"
            Read [OATX]NUMERO=GLANGUE;evalue("[F:ADC1]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:OATX]TEXTE="" : Endif
            Read [DATX]NUMERO=GLANGUE;evalue("[F:ADC2]"+ZON(OBJ,I)+"("+num$(J-1)+")")
            If fstat : [F:DATX]TEXTE="" : Endif
            If [F:OATX]TEXTE <> [F:DATX]TEXTE
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Call TRACE("ADC",[F:ADC1]COD,mess(149,123,1),ZON(OBJ,I),[F:OATX]TEXTE,mess(200,115,1)
&               ,[F:DATX]TEXTE,EXCEL,-1,DIF) From ACOMPOBJ2
            Endif
        Else
            INTERM1 = num$(evalue("[F:ADC1]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            INTERM2 = num$(evalue("[F:ADC2]"+ZON(OBJ,I)+"("+num$(J-1)+")"))
            If INTERM1 <> INTERM2
                OK_C = 1
                If [M:ACMP]DETAIL<>2 : Break : Endif
                Gosub FORMAT_KT From ACOMPOBJ2
                If K<>1
                    Call TRACE("ADC",[F:ADC1]CODTRT,mess(149,123,1),ZON(OBJ,I)+"("+num$(J-1)+")",INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
                Else
                    Call TRACE("ADC",[F:ADC1]CODTRT,mess(149,123,1),ZON(OBJ,I),INTZON(OBJ,I),mess(201,115,1)
&                   ,mess(81,126,1)-INTERM1-"<>"-INTERM2,EXCEL,-1,DIF) From ACOMPOBJ2
                Endif
            Endif
        Endif
    Next J
Next I
Return
#X3PLAT-941 - add activity code comparison - RBU

#X3PLAT-940 - Filter on activity code
$FILTRE_AMK
# default ok to true
OK=1
# check if activity code filter is specified
If [M:ACMP]CODACT=""
  Return
Endif

If FILTRE_STEP=1
  # source folder tests
  # AMSK table
      If ([F:AMK1]CODACT=[M:ACMP]CODACT) | find([M:ACMP]CODACT,[F:AMK1]ACTBLOC(0..[F:AMK1]NBBLOC-1))<>0
        Return
      Endif
  # AMSKZON table
       Filter [AMZ1] Where CODMSK=[F:AMK1]CODMSK & CODACT=[M:ACMP]CODACT
       Read [AMZ1]First
       Filter [AMZ1]
       If fstat<=2 : Return : Endif

  # source to destination folder tests
  # AMSK table
       Filter [AMK2] Where CODMSK=[F:AMK1]CODMSK & (CODACT=[M:ACMP]CODACT | find([M:ACMP]CODACT,[F:AMK2]ACTBLOC(0..[F:AMK2]NBBLOC-1))<>0)
       Read [AMK2]First
       Filter [AMK2]
       If fstat<=2 : Return : Endif

  # AMSKZON table
       Filter [AMZ2] Where CODMSK=[F:AMK1]CODMSK & CODACT=[M:ACMP]CODACT
       Read [AMZ2]First
       Filter [AMZ2]
       If fstat<=2 : Return : Endif

Elsif FILTRE_STEP=2
  # destination folder tests
  # AMSK table
       If ([F:AMK2]CODACT=[M:ACMP]CODACT | find([M:ACMP]CODACT,[F:AMK2]ACTBLOC(0..[F:AMK2]NBBLOC-1))<>0)
         Return
       Endif

  # AMSKZON table
       Filter [AMZ2] Where CODMSK=[F:AMK2]CODMSK & CODACT=[M:ACMP]CODACT
       Read [AMZ2]First
       Filter [AMZ2]
       If fstat<=2 : Return : Endif
Endif

# Activity code specified and not found on source or destination
OK=0
Return

#X3PLAT-940 - Filter on activity code
$FILTRE_WIN
# default ok to true
OK=1
# check if activity code filter is specified
If [M:ACMP]CODACT=""
  Return
Endif

If FILTRE_STEP=1
# source folder tests
# AWI table
      If ([F:AWI1]CODACT=[M:ACMP]CODACT) | find([M:ACMP]CODACT,[F:AWI1]ACTMSK(0..[F:AWI1]NBMSK-1))<>0
        Return
      Endif

# Activity code on AWINBOUT
       Filter [AWT1] Where WIN=[F:AWI1]WIN & CODACTBOUT=[M:ACMP]CODACT
       Read [AWT1]First
       Filter [AWT1]
       If fstat<=2 : Return : Endif

#  Activity code on AWINBRO
       Filter [AWB1] Where WIN=[F:AWI1]WIN & find([M:ACMP]CODACT,[F:AWB1]ACTLIS(0..[F:AWB1]NBLIS-1))
       Read [AWB1]First
       Filter [AWB1]
       If fstat<=2 : Return : Endif

# source to destination folder tests
# AWI table
       Filter [AWI2] Where WIN=[F:AWI1]WIN & (CODACT=[M:ACMP]CODACT | find([M:ACMP]CODACT,[F:AWI2]ACTMSK(0..[F:AWI2]NBMSK-1))<>0)
       Read [AWI2]First
       Filter [AWI2]
       If fstat<=2 : Return : Endif

#  Activity code on AWINBOUT
       Filter [AWT2] Where WIN=[F:AWI1]WIN & CODACTBOUT=[M:ACMP]CODACT
       Read [AWT2]First
       Filter [AWT2]
       If fstat<=2 : Return : Endif

#  Activity code on AWINBOUT
       Filter [AWB2]  Where WIN=[F:AWI1]WIN & find([M:ACMP]CODACT,[F:AWB2]ACTLIS(0..[F:AWB2]NBLIS-1))
       Read [AWB2]First
       Filter [AWB2]
       If fstat<=2 : Return : Endif
Elsif FILTRE_STEP=2
# destination folder tests
# AWI table
      If ([F:AWI2]CODACT=[M:ACMP]CODACT) | find([M:ACMP]CODACT,[F:AWI2]ACTMSK(0..[F:AWI2]NBMSK-1))<>0
        Return
      Endif

#  Activity code on AWINBOUT
       Filter [AWT2] Where WIN=[F:AWI2]WIN & CODACTBOUT=[M:ACMP]CODACT
       Read [AWT2]First
       Filter [AWT2]
       If fstat<=2 : Return : Endif

#  Activity code on AWINBRO
       Filter [AWB2] Where WIN=[F:AWI2]WIN & find([M:ACMP]CODACT,[F:AWB2]ACTLIS(0..[F:AWB2]NBLIS-1))
       Read [AWB2]First
       Filter [AWB2]
       If fstat<=2 : Return : Endif
Endif
# Activity code specified and not found on source or destination
OK=0
Return

