  If fstat<=2 : Return : Endif

  #  Activity code on ASHWMENU
  Filter [F:ASWMN2] Where CODREP=[F:ASW2]CODREP & ACTMENU=[M:ACMP]CODACT
  Read [F:ASWMN2]First
  Filter [F:ASWMN2]
  If fstat<=2 : Return : Endif

  #  Activity code on ASHWLNK
  Filter [F:ASWK2] Where CODREP=[F:ASW2]CODREP & ACVLNK=[M:ACMP]CODACT
  Read [F:ASWK2]First
  Filter [F:ASWK2]
  If fstat<=2 : Return : Endif

  #  Activity code on ASHWCOL
  Filter [F:ASWC2] Where CODREP=[F:ASW2]CODREP & ACTCOL=[M:ACMP]CODACT
  Read [F:ASWC2]First
  Filter [F:ASWC2]
  If fstat<=2 : Return : Endif
Endif
  # Activity code specified and not found on source or destination
OK=0
Return

$FILTRE_ACV
# default ok to true
OK=1
# check if activity code filter is specified
If [M:ACMP]CODACT=""
  Return
Endif

If FILTRE_STEP=1
# source folder tests
  If [F:ACV1]CODACT=[M:ACMP]CODACT | [F:ACV1]ACTDEP=[M:ACMP]CODACT | (dim([F:ACV1]ACTSUP)>0 & [F:ACV1]ACTSUP=[M:ACMP]CODACT) # 120382 - ACTSUP may not be defined
    Return
  Endif

# source to destination folder test
  If dim([F:ACV2]ACTSUP)>0
    Filter [F:ACV2] Where [F:ACV2]CODACT=[F:ACV1]CODACT & ([F:ACV2]CODACT=[M:ACMP]CODACT | [F:ACV2]ACTDEP=[M:ACMP]CODACT | [F:ACV2]ACTSUP=[M:ACMP]CODACT) # 120382 - ACTSUP may
  Else
    Filter [F:ACV2] Where [F:ACV2]CODACT=[F:ACV1]CODACT & ([F:ACV2]CODACT=[M:ACMP]CODACT | [F:ACV2]ACTDEP=[M:ACMP]CODACT) # 120382
  Endif

  Read [F:ACV2]First
  Filter [F:ACV2]
  If fstat<=2 : Return : Endif
Elsif FILTRE_STEP=2
# destination folder test
  If [F:ACV2]CODACT=[M:ACMP]CODACT |  [F:ACV2]ACTDEP=[M:ACMP]CODACT |  (dim([F:ACV2]ACTSUP)>0 & [F:ACV2]ACTSUP=[M:ACMP]CODACT) # 120382 - ACTSUP may not be defined
     Return
  Endif
Endif
# Activity code specified and not found on source or destination
OK=0
Return


$FILTRE_ADC
# default ok to true
OK=1
# check if activity code filter is specified
If [M:ACMP]CODACT=""
  Return
Endif

If FILTRE_STEP=1
# source folder tests
  If [F:ADC1]CODACT=[M:ACMP]CODACT
    Return
  Endif

# source to destination folder test
  Filter [F:ADC2] Where CODTRT=[F:ADC1]CODTRT & CODACT=[M:ACMP]CODACT
  Read [F:ADC2]First
  Filter [F:ADC2]
  If fstat<=2 : Return : Endif
Elsif FILTRE_STEP=2
# destination folder test
  If [F:ADC2]CODACT=[M:ACMP]CODACT
     Return
  Endif
Endif
# Activity code specified and not found on source or destination
OK=0
Return

