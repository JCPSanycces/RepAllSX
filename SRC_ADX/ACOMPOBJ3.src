Endif

If FILTRE_STEP=1
# source folder tests
# AOB table
      If ([F:AOB1]CODACT=[M:ACMP]CODACT) | find([M:ACMP]CODACT,[F:AOB1]VUEACT(0..[F:AOB1]NBVUE-1))<>0
