#<AdxTL>@(#)0.0.0.0 $Revision$Class Leave reason
# Supervisor
## ATY-ATYPE ## HRLSE
# 2018-11-09 07:14:28 228

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,LEG,COD,AENABLE,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char LEG
Value Char COD
Value Tinyint AENABLE
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File HRLVEREA [HRLSE]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".HRLVEREA" [HRLSE]
Endif

Default File [F:HRLSE]
Read [F:HRLSE]HRLSE0 = [L]LEG;[L]COD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]LEG)+"~"+num$([L]COD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]LEG)+"~"+num$([L]COD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

If dim([F:HRLSE]ENAFLG) & [F:HRLSE]ENAFLG<>2 : # Inactive record
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]LEG)+"~"+num$([L]COD)-":"-mess(2,126,1),[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


