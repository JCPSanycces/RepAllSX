#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer WRET
Local Char    SAV_GTRACE(250)

SAV_GTRACE=GTRACE : Raz GTRACE

WRET = func TABINVCND_LIB_TEST.TEST_CONTINVCND()

If GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

GTRACE=SAV_GTRACE

End
######################################################################################
#--Data type INVCND : multiple-legislation/groups control action
######################################################################################
#***************************************************************************************************
#---------------------------------------------------------------------------------------------------
#  Funprog CONTINVCND
#--Data type INVCND : multiple-legislation/groups control action
#  Input values :
#         CTX,OBJCUR,INVCND,LEG,FCY,GROUPE,CPY
#  Output values :
#         OUT_MESSAGE
#  Returns [v]cst_aok/[v]cst_aerror
#---------------------------------------------------------------------------------------------------
Funprog CONTINVCND (AINSTANCE,APRONAME,AVALUE,INVCND,LEG,FCY,GROUPE,CPY)
Variable Instance AINSTANCE Using OBJECT       : # Référence sur l'instance courante
Value Char        APRONAME
Variable Char     AVALUE
Value    Char     INVCND()
Variable Char     LEG()
Value    Char     FCY
Value    Char     GROUPE
Value    Char     CPY

Local Char    OUT_MESSAGE(255)
Local Integer ASTATUS : ASTATUS = [V]CST_AOK

If INVCND="" : End ASTATUS : Endif

Local Char CURLEG

#--Société ou site en ligne
If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
  Local File TABINVCND  [INVCND]
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]
  Local File AGRPFCY    [AGF]
  Local File AGRPCPY    [AGC]
Else
  Local File =AINSTANCE.ACTX.AFOLDER+".TABINVCND"  [INVCND]
  Local File =AINSTANCE.ACTX.AFOLDER+".COMPANY"    [CPY]
  Local File =AINSTANCE.ACTX.AFOLDER+".FACILITY"   [FCY]
  Local File =AINSTANCE.ACTX.AFOLDER+".AGRPFCY"    [AGF]
  Local File =AINSTANCE.ACTX.AFOLDER+".AGRPCPY"    [AGC]
Endif

If LEG=AVOID.ACHAR and func AFNC.ACTIV("LEG")=0
  LEG = AINSTANCE.ACTX.AFOLD.ALEGCUR
Endif
#-------------------------------------------------------------------#
#--Société ou site en ligne
#-------------------------------------------------------------------#
If ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    Read [F:FCY]FCY0=[L]FCY
    If fstat : Raz [F:FCY] Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    Read [F:CPY]CPY0=[L]CPY
    If fstat : Raz [F:CPY] Endif
    [L]CURLEG=[F:CPY]LEG
  Endif
Endif

If    [L]LEG<>"" and [L]CURLEG<>"" and [L]CURLEG<>[L]LEG
  [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(439,192,1)-"["+[L]CURLEG+"]",[V]CST_AERROR)
  End [L]ASTATUS
Elsif [L]LEG="" and [L]CURLEG<>""
  Read [INVCND]INVCND0=INVCND;[L]CURLEG
  If fstat=0
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(440,192,1)-"["+[L]CURLEG+"]"-":"
&                                                 -num$([L]INVCND)+"~"+num$([L]CURLEG),[V]CST_AERROR)
    End [L]ASTATUS
  Else
    Raz [F:INVCND]
  Endif
Else
  Read [INVCND]INVCND0=INVCND;[L]LEG
  If fstat
    If [L]LEG<>""
      # Fiche inexistante pour la législation courante
      [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(232,107,1)-"["+[L]LEG+"]",[V]CST_AERROR)
      End [L]ASTATUS
    Else
      # Fiche inexistante
      [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(23,100,1),[V]CST_AERROR)
      End [L]ASTATUS
    Endif
  Endif
Endif
#----------------------------------------------------------------------------------------------------------------------#
#--Filtrage par groupe de société3
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABINVCND, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#----------------------------------------------------------------------------------------------------------------------#
If [L]CPY<>"" and [L]FCY=""
  If [F:INVCND]GRP<>""
  Read [AGF]AGF0=[F:INVCND]GRP
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Société
      If [F:INVCND]GRP<>[L]CPY
        # Réservé au groupe de société
        [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(63,127,1)-":"-[F:INVCND]GRP,[V]CST_AERROR)
        End [L]ASTATUS
      Endif
    Elsif [F:AGF]FLGCPY=2
        Look [AGC]AGC0 = [F:INVCND]GRP;[L]CPY
        If fstat
          # Réservé au groupe de société
          [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(63,127,1)-":"-[F:INVCND]GRP,[V]CST_AERROR)
          End [L]ASTATUS
        Endif
      Endif
    Endif
  Endif
Elsif [L]FCY<>"" and [L]CPY=""
  Read [F:FCY]FCY0=[L]FCY
  If fstat : Raz [F:FCY] Endif
  Read [F:CPY]CPY0=[L]CPY
  If fstat : Raz [F:CPY] Endif

  Look [AGC]AGC0 = [F:INVCND]GRP;[F:CPY]CPY
   If fstat
    OUT_MESSAGE = [L]INVCND
    If [F:INVCND]LEG<>""
      OUT_MESSAGE += -"["+[L]LEG+"]"
    Endif
    # Réservé au groupe de société
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-mess(63,127,1)-":"-[F:INVCND]GRP,[V]CST_AERROR)
    End [L]ASTATUS
   Endif
Endif
#--

#--Contrôle de cohérence entre le groupe  et la législation
If [F:INVCND]GRP<>"" and [L]CURLEG<>""
  ASTATUS= func TRTVENCTL_SYRA.CTLGFYLEG(AINSTANCE.ACTX,[F:INVCND]GRP,[L]CURLEG,OUT_MESSAGE)
  If ASTATUS >= [V]CST_AERROR
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-OUT_MESSAGE,[V]CST_AERROR)
    End [L]ASTATUS
  Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:INVCND]LEG<>""
  ASTATUS= func TRTVENCTL_SYRA.CTLGFYLEG(AINSTANCE.ACTX,GROUPE,[F:INVCND]LEG,OUT_MESSAGE)
  If ASTATUS >= [V]CST_AERROR
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-OUT_MESSAGE,[V]CST_AERROR)
    End [L]ASTATUS
  Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe  et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
  If CPY="" & FCY="" & [F:INVCND]GRP<>"" & [F:INVCND]GRP<>GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP
    If ASTATUS >= [V]CST_AERROR : End ASTATUS : Endif
  Endif
Endif

ASTATUS = [V]CST_AOK

End ASTATUS
###############################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:INVCND]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGICNDZGRP"
    Local File =SZVIEW [INVCNDZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:INVCNDZ]ICNDZ0 = [L]GROUPE;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG
  If fstat
    OUT_MESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:INVCND]GRP-":"-mess(178,187,1)
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-OUT_MESSAGE,[V]CST_AERROR)
    Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGICNDYGRP"
    Local File =SZVIEW [INVCNDY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    #-- Si problème, pas de contrôle
    Return
  Endif

  Read [F:INVCNDY]ICNDY0 = [L]GROUPE;[F:INVCND]INVCND;[F:INVCND]GRP;[F:INVCND]LEG #--Clé INVCNDY0 et non pas INVCNDZ0
  If fstat
    OUT_MESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:INVCND]GRP-":"-mess(178,187,1)
    [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]INVCND)+"~"+num$([L]LEG)-":"-OUT_MESSAGE,[V]CST_AERROR)
    Return
  Endif
Endif
Return
################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    #Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

