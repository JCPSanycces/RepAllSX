#<AdxTL>@(#)0.0.0.0 $Revision$Class Spouses (>1)
# Supervisor
## CRUD-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:07 597

Gosub TEST From WMCR_EMPLOJNT : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM,NUMLIG)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOJNT : EMPLOJNT
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOJNT._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOJNT.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOJNT.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOJNT [JNT]
 Local File EMPLOJNT [AAA_]
Else
 Local File =EMPLOJNT.ACTX.AFOLDER+".EMPLOJNT" [JNT]
 Local File =EMPLOJNT.ACTX.AFOLDER+".EMPLOJNT" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [JNT] With
& [AAA_]JNT0 = REFNUM+NUMLIG
& As [LNK_]
Return

############################################################################################
### EMPLOJNT(WJNT)
############################################################################################
Funprog  _MAJSQL_EMPLOJNT(WJNT)
Variable Instance WJNT Using C_EMPLOJNT
Local Integer ASTATUS,A_I,A_J
Default File [F:JNT]
If WJNT.ASTALIN=[V]CST_ANEW
 Call INICRE(WJNT) From ASYRSUB
 SetInstance [F:JNT] With WJNT
 Write [F:JNT]
 If fstat
  Call FSTA("JNT",WJNT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WJNT.updTick = [F:JNT]updTick
Elsif WJNT.ASTALIN=[V]CST_ALL or WJNT.ASTALIN=[V]CST_AUPD
 Call INIUPD(WJNT) From ASYRSUB
 SetInstance [F:JNT] With WJNT
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WJNT,"EMPLOJNT")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:JNT]JNT0 = [F:JNT]REFNUM;[F:JNT]NUMLIG
 If fstat
  Call FSTA("JNT",WJNT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WJNT.updTick = [F:JNT]updTick
Elsif WJNT.ASTALIN=[V]CST_ADEL
 SetInstance [F:JNT] With WJNT
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WJNT,"EMPLOJNT")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:JNT]JNT0 = [F:JNT]REFNUM;[F:JNT]NUMLIG
 If fstat
  Call FSTA("JNT",WJNT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



