$SET_FIRST
Gosub SET_FIRST From TRTFIRST
Return

#------------------------------------------------------------------#
$UNSET_FIRST
Gosub UNSET_FIRST From TRTFIRST
Return

#------------------------------------------------------------------#
# Déf des variables workflow
#------------------------------------------------------------------#

Subprog WRKGLOB(NOMES,IDENT,NOMFIC,NOMINT)
Value Integer NOMES
Value Char    IDENT , NOMFIC , NOMINT
Local Integer I
Local Char    PAR(30) , VALPAR(30) , VALCLE(30)
Local Char    PAR1(30) , PAR2(30) , PAR3(30) , PAR4(30)
Local Char    CODTYP(GLONATY)
GCLE  = IDENT
GOPER = mess(NOMES,75,1) : # Créé, Modifié, supprimé, Fonction, Edition, Tâche (170 à 175)
Onerrgo RIEN
If dim(GINTIT)>0
 GINTIT = ""
 If [L]NOMINT<>""
  If evalue("type([F]"+[L]NOMINT+")")>10
   GINTIT = num$(evalue("[F]"+[L]NOMINT))
  Else
   If evalue("type([F]"+[L]NOMINT+")")>0
    VALCLE = num$(evalue("[F]"+NOMINT))
   Endif
   Call GETTYP(NOMFIC,NOMINT,CODTYP)
   Case [L]CODTYP
    When "ATX"
     Call TEXTE(val(VALCLE),GINTIT) From OBJDIV
    When "AXX","AX1","AX2","AX3"
     Call GETPAR(NOMFIC,NOMINT,PAR1,PAR2,PAR3,PAR4)
     For I=1 To 4
      PAR = evalue("PAR"+num$(I))
      If find(left$(PAR,1),'"',"'")
       [L]VALPAR = evalue(PAR)
      Elsif instr(1,PAR,"+") or instr(1,PAR,"-")
       [L]VALPAR = ""
      Else
       [L]VALPAR = num$(evalue("[F]"+PAR))
      Endif
      Assign "PAR"+num$(I) With [L]VALPAR
     Next I
     Call LECTEXTRA(GINTIT,PAR1,PAR2,PAR3,PAR4) From ATEXTRA
    When Default
     GINTIT = VALCLE
   Endcase
  Endif
 Endif
Endif
Onerrgo
End

Subprog GETTYP(NOMFIC,NOMINT,CODTYP)
Value Char NOMFIC , NOMINT
Variable Char CODTYP
Local File ATABZON [ATZ_]
Read [ATZ_]CODZONE=NOMFIC;NOMINT
[L]CODTYP = [F:ATZ_]CODTYP
Close Local File [ATZ_]
End

Subprog GETPAR(NOMFIC,NOMINT,PAR1,PAR2,PAR3,PAR4)
Value Char NOMFIC , NOMINT
Variable Char  PAR1 , PAR2 , PAR3 , PAR4
Local File AMSKPAR [AMP_]
Local Char PAR(GLONAAR)
Raz PAR1 , PAR2 , PAR3 , PAR4
For PAR="TABLE1","ZONE","CLECUR1","CLECUR2"
 Read [AMP_]CODPAR=2;NOMFIC;NOMINT;PAR
 If fstat : [F:AMP_]VALPAR = "" : Endif
 Case PAR
  When "TABLE1"  : PAR1 = [F:AMP_]VALPAR
  When "ZONE"    : PAR2 = [F:AMP_]VALPAR
  When "CLECUR1" : PAR3 = [F:AMP_]VALPAR
  When "CLECUR2" : PAR4 = [F:AMP_]VALPAR
 Endcase
Next PAR
Close Local File [AMP_]
End

Subprog SAITRANS(NBLIB,TEXTE,VALEUR,TITBOI)
Value Integer NBLIB
Value Char TEXTE()(0..)
Variable Integer VALEUR
Value Char TITBOI
If 1=1
 Call SAITEX(NBLIB,TEXTE,VALEUR,TITBOI) From GESECRAN
 End
Endif
Local Char TBLIB(GLONDES)(1..dim(TEXTE),1..2) , TIT(GLONDES)(0..2)
Local Integer I , K
TIT(0) = TITBOI
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
For I=1 To NBLIB
 K = instr(1,vireblc(TEXTE(I),2)," ")
 TBLIB(I,1) = vireblc(left$(TEXTE(I),K-1),2)
 TBLIB(I,2) = vireblc(right$(TEXTE(I),K+1),2)
Next I
Call SAITEX_COL_MAX(NBLIB,TBLIB,VALEUR,TIT,180,80) From GESECRAN
End

#-----------------------------------------------------#
# Construction du symbole pour le verrou des objets
#-----------------------------------------------------#

Funprog SYMBOLE_VERROU(ABR,CLE)
Value Char ABR : # Abréviation de la table
Value Char CLE : # Clé de l'enregistrement
Local Char SYMBOLE(250)
If len(ABR)<=3
 SYMBOLE = format$("K:3X",ABR)+CLE
Else
 SYMBOLE = ABR+"~"+CLE
Endif
End SYMBOLE

