#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ
GBIDC1 = "ZZM"
Call OBJET(GBIDC1,GBIDC2,GBIDC3) From GOBJET
End

#-------------------------------#
$ACTION
Case ACTION
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

#---------------------#
$SEL_LISTE
Case LISTE
 When "LISARC" : Gosub LISARC
Endcase
Return

#---------------------#
$LISARC
NBTEX += 1 : TEX(NBTEX) = num$(NBTEX) : TEXTE(NBTEX) = mess(118,124,1) : # Pièces jointes
NBTEX += 1 : TEX(NBTEX) = num$(NBTEX) : TEXTE(NBTEX) = mess(53,143,1)  : # Interrogation GED
TIT    = mess(40,100,1) : # Choix
TIT(1) = mess(75,123,1) : # Fonction
Return

#--------------------------------------------------------------------#
# Sous-programmes Appelés par GOBJSUB
#--------------------------------------------------------------------#

Subprog WORKBOUT(ABREV,CLE)
Value Char ABREV, CLE
Local Char PARBOUT(250)(1..4) , VALBOUT(30)
Local Integer OK
If clalev([F:AWA])=0 : Local File AWRKPAR [AWA] : Endif
OK = 0
For [AWA]AWA1
 OK =  ([F:AWA]TYPEVT=1 & [F:AWA]CODEVT="BUT")
 OK += ([F:AWA]TYPEVT=2 & [F:AWA]CODEVT=ABREV & instr(1,[F:AWA]OPERATION,"W"))
 OK *= ([F:AWA]ENAFLG=2 & ([F:AWA]ENAMES=2 | [F:AWA]ENASUI=2 | [F:AWA]ENAACT=2))
 If OK : Break : Endif
Next AWA
If !OK
 Call ERREUR(mess(107,75,1)) From GESECRAN : # Paramètrage workflow inexistant
Else
 PARBOUT(1) = ABREV
 PARBOUT(2) = CLE
 Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SAIWRKMES","",5,"") From GTRAITE
Endif
End

#--------------------------------------------------------------------#
Subprog SIGNATURE(ABREV,CLE1,CLE2,OK)
Value    Char    ABREV , CLE1 , CLE2()(1..)
Variable Integer OK
Local Integer I
Local Char    PARBOUT(250)(1..20) , VALBOUT(GLONVCR)
Local Char    CHRONO(GLONVCR) , CHAINE(250)
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
Call IDENT3(ABREV,PARBOUT(1),CLE1,CLE2) From GOBJTXT
# Liste des suivis à signer
Call S_TAB_CHAR(CHRONO,PARBOUT,"SIGOBJ","SAIWRKSIG","") From GACTION
If CHRONO=""
 OK = 0
Else
 Read [AWS]AWS0 = CHRONO ; GUSER
 PARBOUT(1) = [F:AWS]CHRONO
 PARBOUT(2) = [F:AWS]DEST
 PARBOUT(3) = GUSER
 PARBOUT(4) = [F:AWS]EMAIL
 Call TRTSPE(nomap,"SAIWRKSIG",CHAINE) From SUBACT
 Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SAIWRKSIG","",5,CHAINE) From GTRAITE
 OK = val(PARBOUT(6))
Endif
End

#--------------------------------------------------------------------#
Subprog HISTOSIG(ABREV,CLE1,CLE2)
Value Char ABREV , CLE1 , CLE2()(1..)
Local Integer I , J , K , OK , NBCLE , NBPAR
Local Char    PARBOUT(250)(1..2) , VALBOUT(30)
Local Char    CLEPRIM(GLONID1) , CLESEC(GLONID1)(1..16)
Local Char    CHAINE(250)
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
Call IDENT3(ABREV,PARBOUT(1),CLE1,CLE2) From GOBJTXT
# Historique des signatures d'un objet
Call TRTSPE(nomap,"ASIGCHR",CHAINE) From SUBACT
Call S_TAB_CHAR(VALBOUT,PARBOUT,"SIGCHR","SAIWRKSIG",CHAINE) From GACTION
End

#--------------------------------------------------------------------#
Subprog CIRCUITSIG(ABREV,CLE1,CLE2)
Value Char ABREV , CLE1 , CLE2()(1..)
Local Integer I , J , K , OK , NBCLE , NBPAR
Local Char    PARBOUT(250)(1..2) , VALBOUT(30)
Local Char    CLEPRIM(GLONID1) , CLESEC(GLONID1)(1..16)
Local Char    CHAINE(250)
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
Call IDENT3(ABREV,PARBOUT(1),CLE1,CLE2) From GOBJTXT
# Historique des signatures d'un objet
Call TRTSPE(nomap,"ASIGCIR",CHAINE) From SUBACT
Call S_TAB_CHAR(VALBOUT,PARBOUT,"SIGCIR","SAIWRKSIG",CHAINE) From GACTION
End

#--------------------------------------------------------------------#
Subprog PIECE(OBJET,CLE1,CLE2,AUTOR)
Value Char    OBJET
Value Char    CLE1
Value Char    CLE2()(1..)
Value Char    AUTOR
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
Local Integer I
PARBOUT(1) = OBJET
PARBOUT(2) = CLE1
Call SETCLE(OBJET,PARBOUT(3),CLE2) From GOBJTXT
PARBOUT(4) = AUTOR
Call SAISIE_CHAR(VALBOUT,PARBOUT,"AOBJTXT","GOBJTXT","XWGOBJTXT") From GSAISIE
If GSTATUT<>GSTAESC
 Call IMAGE_PCE(OBJET,CLE1,CLE2)
Endif
End

#--------------------------------------------------------------------#
Subprog ARCURL(OBJET,CLE1,CLE2,ADDURL,AUTOR)
Value Char    OBJET
Value Char    CLE1
Value Char    CLE2()(1..)
Value Char    ADDURL
Value Char    AUTOR
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
Local Integer I
Local Char    WIDENT(250) , CHAINE(250)
PARBOUT(1) = ""
PARBOUT(2) = OBJET
PARBOUT(3) = CLE1
PARBOUT(4) = ADDURL
Call SETCLE(OBJET,WIDENT,CLE2) From GOBJTXT
If WIDENT<>""
 PARBOUT(3) += "~"+WIDENT
Endif
Call S_LIS_CHAR(VALBOUT,PARBOUT,"LISARC","GOBJACT","") From GACTION
Case VALBOUT
 When "1"
  Call PIECE(OBJET,CLE1,CLE2,AUTOR)
 When "2"
  Call TRTSPE(nomap,"ARCVISUOBJ",CHAINE) From SUBACT
  Call TRAITE_CHAR(OBJET,PARBOUT,"ARCVISUOBJ","ARCVISUOBJ","",5,CHAINE) From GTRAITE
Endcase
End

#--------------------------------------------------------------------#
Subprog IMAGE_PCE(OBJET,CLE1,CLE2)
Value Char    OBJET
Value Char    CLE1
Value Char    CLE2()(1..)
Local Char    WIDENT(250)
Call SETCLE(OBJET,WIDENT,CLE2) From GOBJTXT
Look [AOX]AOX0(3) = OBJET;CLE1;WIDENT
If !fstat
 Call SET_IMAGE(2) From GESECRAN
Else
 Call RESET_IMAGE(2) From GESECRAN
Endif
End

#--------------------------------------------------------------------#
Subprog COMMENTAIRE(OBJET,CLE1,CLE2,AUTOR)
Value Char    OBJET
Value Char    CLE1
Value Char    CLE2()(1..)
Value Char    AUTOR
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
Local Integer I
PARBOUT(1) = OBJET
PARBOUT(2) = CLE1
Call SETCLE(OBJET,PARBOUT(3),CLE2) From GOBJTXT
PARBOUT(4) = AUTOR
Call SAISIE_CHAR(VALBOUT,PARBOUT,"AOBJCOM","GOBJTXT","XWGOBJTXT") From GSAISIE
If GSTATUT<>GSTAESC
 Call IMAGE_COM(OBJET,CLE1,CLE2)
Endif
End

#--------------------------------------------------------------------#
Subprog IMAGE_COM(OBJET,CLE1,CLE2)
Value Char    OBJET
Value Char    CLE1
Value Char    CLE2()(1..)
Local Char    WIDENT(250)
Local Integer OK
Call SETCLE(OBJET,WIDENT,CLE2) From GOBJTXT
If clalev([F:ACB])=0 : Local File ACLOB [ACB] : Endif
Gosub SET_COM From GOBJTXT
Look [ACB]ACB0 = CBLOB+OBJET;CLE1;WIDENT;"1"
If !fstat
 Call SET_IMAGE(1) From GESECRAN
Else
 Call RESET_IMAGE(1) From GESECRAN
Endif
End

#--------------------------------------------------------------------#
Subprog PROPRIETE(OBJET,CLE1,CLE2)
Value Char OBJET
Value Char CLE1
Value Char CLE2()(1..)
Local Char VALBOUT(30), PARBOUT(250)(1..3)
PARBOUT(1) = CLE1
PARBOUT(2) = OBJET
Call SETCLE(OBJET,PARBOUT(3),CLE2) From GOBJTXT
Call SAISIE_CHAR(VALBOUT,PARBOUT,"AOPVISU","SUBAOP","SPEAOP") From GSAISIE
End

#--------------------------------------------------------------------#
Subprog ACT_LIAISONS(OBJET,CLE1,CLE2)
Value    Char OBJET
Variable Char CLE1()
Variable Char CLE2()()
Local    Char PARBOUT(250)(1..2) , VALBOUT(1) , WIDENT(40)
Call IDENT3(OBJET,WIDENT,CLE1,CLE2) From GOBJTXT
PARBOUT(1) = OBJET
PARBOUT(2) = WIDENT
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SUBALI","ALINK",3,"SPEALI") From GTRAITE
End

#--------------------------------------------------------------------#
Subprog ANUCOD(OBJET,CLE1,CLE2,OK)
Value    Char OBJET
Value    Char CLE1()
Value    Char CLE2()(1..)
Variable Integer OK
Local Integer I
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
PARBOUT(1) = OBJET
PARBOUT(2) = CLE1
PARBOUT(3) = ""
For I=1 To dim(CLE2)
 If sum(CLE2)="" : Break : Endif
 If I>1 : PARBOUT(3) += "~" : Endif
 PARBOUT(3) += CLE2(I)
Next I
PARBOUT(4) = num$(OK)
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ANUCOD","ANUCOD",3,"XYANUCOD") From GTRAITE
OK = val(PARBOUT(4))
End

#--------------------------------------------------------------------#
Subprog CHGCOD(OBJET,CLE1,CLE2,OK)
Value    Char OBJET
Variable Char CLE1()
Variable Char CLE2()(1..)
Variable Integer OK
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
Local Integer I, J
# Issue X3-59897 - 2017-11-03 by CCC : Change of key mustn't be used in SCM environment
If GADONIX=2
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    Look [F:ADI]CODE=97;OBJET
    If !fstat
        OK=0
        End
    Endif
Endif

PARBOUT(1) = OBJET
PARBOUT(2) = CLE1
PARBOUT(3) = ""
For I=1 To dim(CLE2)
 If sum(CLE2)="" : Break : Endif
 If I>1 : PARBOUT(3) += "~" : Endif
 PARBOUT(3) += CLE2(I)
Next I
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CHGCOD","CHGCOD",3,"XYCHGCOD") From GTRAITE
CLE1 = PARBOUT(2)
Raz CLE2 : J=1
While PARBOUT(3)<>""
 I = instr(1,PARBOUT(3),"~")
 If I
  CLE2(J) = left$(PARBOUT(3),I-1)
  PARBOUT(3) = right$(PARBOUT(3),I+1)
 Else
  CLE2(J) = PARBOUT(3)
  PARBOUT(3) = ""
 Endif
 J+=1
Wend
OK = val(PARBOUT(4))
End

#--------------------------------------------------------------------#
Subprog ACT_SELOBJ(OBJET,FILTRE,MODMEMO,OK)
Value    Char    OBJET
Variable Char    FILTRE()
Variable Integer MODMEMO
Variable Integer OK
Local    Char    PARBOUT(250)(1..4) , VALBOUT(30)
PARBOUT(1) = OBJET
Call SAISIE_CHAR(VALBOUT,PARBOUT,"ASELOBJ","ASELOBJ","XWASELOBJ") From GSAISIE
MODMEMO = val(PARBOUT(4))
OK = val(PARBOUT(3))
If OK : FILTRE = PARBOUT(2) : Endif
End

#--------------------------------------------------------------------#
Subprog SELTXT(ABREV,CRITERE,FILTSUP,OK)
Value    Char    ABREV, CRITERE, FILTSUP
Variable Integer OK
Local    Char    VALBOUT(30), PARBOUT(250)(1..4)
PARBOUT(1) = ABREV
PARBOUT(2) = CRITERE
PARBOUT(3) = FILTSUP
PARBOUT(4) = num$(OK)
Call SAISIE_CHAR(VALBOUT,PARBOUT,"AOBJTXT2","SELOBJTXT","XWGOBJTXT") From GSAISIE
OK = val(PARBOUT(4))
End

#--------------------------------------------------------------------#
Subprog ACT_CHGENV(OK)
Variable Integer OK
Local    Char    VALBOUT(30), SAV_GACTION(20)
Local    Char    PARBOUT(250)(1..1)
Case GPRODUIT
 When 1 : ## GEODE
  Local    Char     SAVFCY(GLONFCY), SAVDEP(GLONDEP) : SAVFCY=GFCY : SAVDEP=GDEP
  SAV_GACTION = GACTION : GACTION = "SAICHGENV"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"FCHGENV","CHGENV","XWCHGENV") From GSAISIE
  GACTION = SAV_GACTION
  If (SAVFCY<>GFCY & GCHGENV) | (SAVDEP<>GDEP & GCHGENV=2)
   OK = 1
  Else
   OK = 0
  Endif
 When 4
  Local Char    SAVBUD(3)
  Local Integer SAVEXO
  SAVBUD = GBUD : SAVEXO = GEXO
  SAV_GACTION = GACTION : GACTION = "CHGBUD"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"FCHGBUD","CHGBUD","XWCHGBUD") From GSAISIE
  GACTION = SAV_GACTION
  If SAVBUD<>GBUD | SAVEXO<>GEXO
   OK = 1
  Else
   OK = 0
  Endif
Endcase
End

#--------------------------------------------------------------------------------------------------------#
Subprog SUIGAUCHE(SENS,OBJET,CLELISTE,SNSLIS,TRELIS,ILIS,OBJLIS,CZ,WINPROG,HINTLIS
&                ,CRITERE,FILTSUP,FILROLE,FILGAUSUP,IFILSUITE,FILSUITE,OK)
Value    Char    SENS
Value    Char    OBJET
Value    Char    CLELISTE
Value    Integer SNSLIS
Value    Integer TRELIS
Value    Integer ILIS
Value    Char    OBJLIS
Value    Char    CZ            : # Sert aux filtres applicatifs
Value    Char    WINPROG
Value    Char    HINTLIS
Value    Char    CRITERE
Value    Char    FILTSUP
Value    Char    FILROLE()()
Value    Char    FILGAUSUP()()
Variable Integer IFILSUITE
Variable Char    FILSUITE()()
Variable Integer OK

If CLELISTE="" or adxmxl=0 : End : Endif

Local Integer I , J , K , T , NBCLE
Local Char    VALC(80)(1..16) , ACTION(20)
Local Char    CLELIS(30)(1..16) , SENSLIS(5)(1..16) , ASCDES(10) , CHAINE(250) , CLELEC(250) # Bug 83169: added SENSLIS
Local Char    ZONCLE(250) , ZONCLE2(250)
Local Char    CLEVAL(250), CLEVALNXT(250)
Local Integer DIFFCLE
Local Integer ICRITBUF , IFILPREV , IFILSAV, DIMS , DIMB , PRE
DIMS = dim(FILSUITE)-1
DIMB = max(dim(FILGAUSUP),dim(FILROLE))
Local Char    CRITBUF(250)(0..DIMB)
Local Char    FILTRE(250)(0..DIMS) , FILSAV(250)(0..DIMS) , FILPREV(250)(0..DIMS)
Local Char    PROGOBJL(GLONADC)
Local Char    L_SENS # Bug 83169

If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub SET_FIRST
Endif

If OBJLIS<>""
 PROGOBJL = "WO"+OBJLIS
 Gosub NOMFIC From =PROGOBJL
 If TYPGES=3
  Gosub SETCLE From =PROGOBJL
 Endif
Endif

Raz CLELIS, SENSLIS, NBCLE, CLELEC
CHAINE = CLELISTE
While CHAINE<>""
 I = instr(1,CHAINE,";")
 If I
  ZONCLE = vireblc(left$(CHAINE,I-1),2)
  CHAINE = right$(CHAINE,I+1)
 Else
  ZONCLE = vireblc(CHAINE,2)
  CHAINE = ""
 Endif
 ZONCLE2 = ZONCLE
 K = instr(1,ZONCLE2," ")
 L_SENS = "asc"
 If K
  For ASCDES = "desc", "asc"
   I = instr(K+1,tolower(ZONCLE2),ASCDES)
   If I
    ZONCLE2 = vireblc(left$(ZONCLE2,I-1),2)
    L_SENS  = ASCDES
    Break
   Endif
  Next ASCDES
 Endif
 If OBJLIS<>"" & TYPGES=3 & CLELIG<>"" & ZONCLE2=CLELIG
  Break
 Else
  NBCLE += 1
  CLELIS(NBCLE) = ZONCLE2
  SENSLIS(NBCLE)= L_SENS # Bug 83169
  If CLELEC<>"" : CLELEC += ";" : Endif
  CLELEC += ZONCLE
 Endif
Wend
If SENS=">"
 IFILSAV = IFILSUITE
 For I=0 To dim(FILSUITE)-1
  FILSAV(I) = FILSUITE(I)
 Next I
Endif
Gosub FILSUITE
Gosub DEFAUT_BRO From =WINPROG
Raz CRITBUF, ICRITBUF
If ILIS=0
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITERE,"&") From GOBJSUB
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILTSUP,"&") From GOBJSUB
 For I=0 To dim(FILROLE)-1
  If I=0
   Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILROLE(I),"&") From GOBJSUB
  Else
   Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILROLE(I),"") From GOBJSUB
  Endif
 Next I
Else
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITERE,"&") From GOBJSUB
 For I=0 To dim(FILGAUSUP)-1
  If I=0
   Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILGAUSUP(I),"&") From GOBJSUB
  Else
   Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILGAUSUP(I),"") From GOBJSUB
  Endif
 Next I
Endif
If CRITBUF="" : CRITBUF = "1=1" : Endif
If SENS="<"
 Call CHANGE_SENS(CLELEC,CHAINE)
 If FILPREV="" : FILPREV = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILPREV) Order With CHAINE
Else
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILSUITE) Order With CLELEC
Endif
K = 0
If OBJLIS<>"" & TYPGES=3
 [G]currlen = NBCLE : # mb 29.7.4 Bug 23856
Endif
PRE = 0
CLEVAL = ""
CLEVALNXT = ""
If HINTLIS<>""
 For [F] Hint Key=HINTLIS
  Gosub CPT_SUIGAUCHE
  If DIFFCLE
    If K>adxmxl
     PRE=1 : Break
    Elsif K=adxmxl & SENS=">"
     Break
    Endif
  Endif
 Next
Elsif dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 For [F] Hint Key=""
  Gosub CPT_SUIGAUCHE
  If DIFFCLE
    If K>adxmxl
     PRE=1 : Break
    Elsif K=adxmxl & SENS=">"
     Break
    Endif
  Endif
 Next
Else
 For [F]
  Gosub CPT_SUIGAUCHE
  If DIFFCLE
    If K>adxmxl
     PRE=1 : Break
    Elsif K=adxmxl & SENS=">"
     Break
    Endif
  Endif
 Next
Endif
OK = 1
If SENS="<"
 If !PRE
  Raz FILSUITE, IFILSUITE
  FILSUITE = "1=1"
 Else
  Gosub FILSUITE
 Endif
Elsif !K : # pas d'enreg suivant
 IFILSUITE = IFILSAV
 For I=0 To dim(FILSUITE)-1
  FILSUITE(I) = FILSAV(I)
 Next I
 OK = 0
Endif
Filter [F]
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub UNSET_FIRST
Endif
End

$ERR_CLEVAL
DIFFCLE=1
Resume

$CPT_SUIGAUCHE
  # Issue 86155 - 2013-01-14 by VPO : gestion liste hierarchisée
  If TRELIS=2 & NBCLE>=1
    DIFFCLE=0
    Onerrgo ERR_CLEVAL
    CLEVALNXT=num$(evalue("[F]"+CLELIS(1)))
    Onerrgo
    If CLEVAL<>CLEVALNXT
      DIFFCLE=1
      CLEVAL=CLEVALNXT
    Endif
  Else
    DIFFCLE=1
  Endif
  K += 1
Return



#**
#* @deprecated
#*!
$FILSUITE_OLD
Raz FILSUITE, FILPREV, IFILSUITE, IFILPREV
NBCLE = 0
For I=1 To dim(CLELIS)
 If CLELIS(I)="" : Break : Endif
 NBCLE += 1
 If instr(1,CLELIS(I),"[")
  ZONCLE = CLELIS(I)
 Elsif dim(ABFIC)>0 & ABFIC<>""
  ZONCLE = "[F:"+ABFIC+"]"+CLELIS(I)
 Else
  ZONCLE = "[F]"+CLELIS(I)
 Endif
 T = evalue("type("+ZONCLE+")")
 Case T
  When 1,2,4,5,6,7,8,9
   VALC(I) = num$(evalue(ZONCLE))
  When 3
   If evalue(ZONCLE)=[0/0/0]
    VALC(I) = '[0/0/0]'
   Else
    VALC(I) = '['+format$(GFMD,evalue(ZONCLE))+']'
   Endif
  When Default
   VALC(I) = evalue(ZONCLE)
   If instr(1,VALC(I),"'") & instr(1,VALC(I),'"')
    VALC(I) = ctrans(VALC(I),"'","&")
    VALC(I) = ctrans(VALC(I),'"',"!")
    VALC(I) = '"'+VALC(I)+'"'
   Elsif instr(1,VALC(I),'"') & !instr(1,VALC(I),"'")
    VALC(I) = "'"+VALC(I)+"'"
   Else
    VALC(I) = '"'+VALC(I)+'"'
   Endif
 Endcase
 If I=1
  FILSUITE = ZONCLE+">"+VALC(I)
  FILPREV  = ZONCLE+"<"+VALC(I)
 Else
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE","| (","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV","| (","") From GOBJSUB
  If FILPREV="" : Break : Endif
  For J=1 To I-1
   If instr(1,CLELIS(J),"[")
    ZONCLE2 = CLELIS(J)
   Elsif dim(ABFIC)>0 & ABFIC<>""
    ZONCLE2 = "[F:"+ABFIC+"]"+CLELIS(J)
   Else
    ZONCLE2 = "[F]"+CLELIS(J)
   Endif
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILSUITE="" : Break 2 : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILPREV="" : Break 2 : Endif
  Next J
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
  If FILPREV="" : Break : Endif
 Endif
Next I
If FILSUITE=""   : Raz FILPREV
Elsif FILPREV="" : Raz FILSUITE
Endif
If SNSLIS=2
 For I=0 To dim(FILSUITE)-1
  FILTRE(0)   = FILSUITE(I)
  FILSUITE(I) = FILPREV(I)
  FILPREV(I)  = FILTRE(0)
 Next I
Endif
Return

$FILSUITE
Raz FILSUITE, FILPREV, IFILSUITE, IFILPREV
NBCLE = 0
For I=1 To dim(CLELIS)
 If CLELIS(I)="" : Break : Endif
 NBCLE += 1
 If instr(1,CLELIS(I),"[")
  ZONCLE = CLELIS(I)
 Elsif dim(ABFIC)>0 & ABFIC<>""
  ZONCLE = "[F:"+ABFIC+"]"+CLELIS(I)
 Else
  ZONCLE = "[F]"+CLELIS(I)
 Endif
 T = evalue("type("+ZONCLE+")")
 Case T
  When 1,2,4,5,6,7,8,9
   VALC(I) = num$(evalue(ZONCLE))
  When 3
   If evalue(ZONCLE)=[0/0/0]
    VALC(I) = '[0/0/0]'
   Else
    VALC(I) = '['+format$(GFMD,evalue(ZONCLE))+']'
   Endif
  When Default
   VALC(I) = evalue(ZONCLE)
   If instr(1,VALC(I),"'") & instr(1,VALC(I),'"')
    VALC(I) = ctrans(VALC(I),"'","&")
    VALC(I) = ctrans(VALC(I),'"',"!")
    VALC(I) = '"'+VALC(I)+'"'
   Elsif instr(1,VALC(I),'"') & !instr(1,VALC(I),"'")
    VALC(I) = "'"+VALC(I)+"'"
   Else
    VALC(I) = '"'+VALC(I)+'"'
   Endif
 Endcase
 If I=1
  Case SENSLIS(I) # Bug 83169
   When "asc":
    FILSUITE = ZONCLE+">"+VALC(I)
    FILPREV  = ZONCLE+"<"+VALC(I)
   When "desc":
    FILSUITE = ZONCLE+"<"+VALC(I)
    FILPREV  = ZONCLE+">"+VALC(I)
  Endcase
 Else
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE","| (","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV","| (","") From GOBJSUB
  If FILPREV="" : Break : Endif
  For J=1 To I-1
   If instr(1,CLELIS(J),"[")
    ZONCLE2 = CLELIS(J)
   Elsif dim(ABFIC)>0 & ABFIC<>""
    ZONCLE2 = "[F:"+ABFIC+"]"+CLELIS(J)
   Else
    ZONCLE2 = "[F]"+CLELIS(J)
   Endif
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILSUITE="" : Break 2 : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILPREV="" : Break 2 : Endif
  Next J
  Case SENSLIS(I) # Bug 83169
   When "asc":
    Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
    If FILSUITE="" : Break : Endif
    Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
    If FILPREV="" : Break : Endif
   When "desc":
    Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
    If FILSUITE="" : Break : Endif
    Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
    If FILPREV="" : Break : Endif
   Endcase
 Endif
Next I
If FILSUITE=""   : Raz FILPREV
Elsif FILPREV="" : Raz FILSUITE
Endif
# Bug 83169 : code below removed since the reverse of direction is already taken into acount in CLELISTE
#If SNSLIS=2
# For I=0 To dim(FILSUITE)-1
#  FILTRE(0)   = FILSUITE(I)
#  FILSUITE(I) = FILPREV(I)
#  FILPREV(I)  = FILTRE(0)
# Next I
#Endif
Return

#---------------------------------#
Subprog CHANGE_SENS(ORDRE,ORDINV)
Value    Char ORDRE
Variable Char ORDINV
Local Char    CLELIS(50) , CHAINE(255)
Local Integer I , J , OK
CHAINE = ORDRE
ORDINV = ""
While CHAINE<>""
 I = instr(1,CHAINE,";")
 If I
  CLELIS = vireblc(left$(CHAINE,I-1),2)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLELIS = vireblc(CHAINE,2)
  CHAINE = ""
 Endif
 OK = 0
 K = instr(1,CLELIS," ")
 If K
  For ASCDES = "desc", "asc"
   I = instr(K+1,tolower(CLELIS),ASCDES)
   If I
    CLELIS = vireblc(left$(CLELIS,I-1),2)
    Case ASCDES
     When "desc" : CLELIS -= "Asc"  : OK = 1 : Break
     When "asc"  : CLELIS -= "Desc" : OK = 1 : Break
    Endcase
   Endif
  Next ASCDES
 Endif
 If !OK
  CLELIS -= "Desc"
 Endif
 If ORDINV<>""
  ORDINV += ";"
 Endif
 ORDINV += CLELIS
Wend
End

#--------------------------------------------------------------------------------------------------------#
$APRES_MODIF
Default [V] , [L] , [S] , [M] , [F]
COUZON = zoncou
If evalue("type([M]"+COUZON+")")=8 or indice>evalue("dim([M]"+COUZON+")-1")
 COUIND = 0
Else
 COUIND = indice
Endif
If !((COUZON=CLEPRIM or find(COUZON,CLESEC)) & (TYPGES<>3 or COUZON<>CLELIG) & TYPGES<>2)
&  & dim([L]ZSITE)>0 & [L]ZSITE<>"" & COUZON=[L]ZSITE & dim([L]CLEVALEUR)<0 & ABREV<>"FCY"
 # Vérification des droits sur le site modifié et le nouveau site saisi, si site hors clé
 If ![L]ACTANU & [L]SITCUR<>"" & [L]SITCUR=evalue("[M]"+[L]ZSITE)
  Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
  zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
  mkstat = 1 : Return
 Elsif zc<>[L]SITCUR
  If zc="" & dim(GUSRVID)>0
   ISITE = instr(1,GUSRVID,"C")
  Elsif zc<>""
   If GUSRFCY(1)<>"\"
    ISITE = find(zc,GUSRFCY(1..GNBAUZ))
    If ISITE<>0
     ISITE = instr(1,GUSRAUZ(ISITE),"C")
    Endif
   Else
    ISITE = 1
   Endif
  Else
   ISITE = 1
  Endif
  If ISITE=0
   Call ERREUR(zc-":"-mess(2,104,1)) From GESECRAN : # Vous n'avez pas les droits pour ce site
   zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
   mkstat = 1 : Return
  Endif
 Endif
Endif
Case type(zc)
 When 3       : CZ = zc
 When 522,523 : CZ = "" : # Blob, Clob
 When Default : CZ = num$(zc)
Endcase
RELIT = 0 : # Pour pouvoir l'affecter en apres modif
OK = 1 : ACTION = "APRES_MODIF" : Gosub ACTION From GOBJSUB
If OK=0
 mkstat = 1
 Return
Elsif OK<0
 If SUIZON<>"" : zonsui = SUIZON : SUIZON = "" : Endif : # 5/11/01 pour ne pas entrer en modif
 Return
Endif
If (COUZON=CLEPRIM or find(COUZON,CLESEC)) & (TYPGES<>3 or COUZON<>CLELIG) & TYPGES<>2
 # C'est une zone de clé
 # on tente une recherche
 If COUZON=CLEPRIM
  NEWCLE1 = CZ
 Elsif dim(CLEFCY)>0 & CLEPRIM=CLEFCY
  NEWCLE1 = GFCY
 Elsif dim(CLEDEP)>0 & CLEPRIM=CLEDEP
  NEWCLE1 = GDEP
 Else
  NEWCLE1 = num$(evalue("[M]"+CLEPRIM))
 Endif
 For CL=0 To dim(CLESEC)-1
  If CLESEC(CL)<>""
   If COUZON=CLESEC(CL)
    NEWCLE2(CL) = CZ
   Elsif dim(CLEFCY)>0 & CLESEC(CL)=CLEFCY
    NEWCLE2(CL) = GFCY
   Elsif dim(CLEDEP)>0 & CLESEC(CL)=CLEDEP
    NEWCLE2(CL) = GDEP
   Else
    NEWCLE2(CL) = num$(evalue("[M]"+CLESEC(CL)))
   Endif
  Endif
 Next CL
 Case REP
  When "","C","D"
   Gosub EXISTE From GOBJSUB
   If fstat : # ça n'existe, pas on passe en création, si on a le droit
    If (ACTCRE and CLECUR=0) or (ACTDUP and CLECUR<>0)
     If VERROU : Gosub DEVERROU From GOBJET : Endif
     If (VERROU_CRE=1 or (VERROU_CRE=2 & CZ<>""))
& & ((dim([L]CLEVALEUR)>0 & COUZON=[L]CLEVALEUR) or(dim([L]CLEVALEUR)<0 & COUZON=[L]CLEPRIM))
      Gosub VERROU_CRE From GOBJSUB
      If !VERROU
       If VERROU_CRE>10
        Call ERREUR(mess(215,100,1)) From GESECRAN
        # Création en cours sur un autre poste
       Endif
       mkstat = 2
      Endif
      If VERROU_CRE>10 : VERROU_CRE -= 10 : Endif
     Endif
    Elsif COUZON=[L]CLECRE
     # Création impossible
     Call ERREUR(mess(7,123,1)) From GESECRAN
     RELIT = 9 : Gosub RELIT : RELIT = 0 : # On peut avoir perdu zc (si zc a une zone de lien)
     If evalue("type([M]"+COUZON+")")<>8 : # Bas de tableau
      zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
     Endif
     mkstat = 1 : Return
    Else
     # Il n'est pas possible de bloquer ici la création si clé multiple
     # Ce cas est géré sur le bouton "Enregistrer"
    Endif
    # Contrôles plages développement
    If ABREV="AOB" & GPRODUIT=-1
     If find(CZ,"AIC","AJM","ASG","ATS")
      Call ERREUR("Objet"-CZ-"déjà utilisé dans un produit") From GESECRAN
      mkstat = 1 : Return
     Else
      Call PLAGE(CZ,1) From CONTOBJ
      If mkstat : Return : Endif
     Endif
    Elsif find(ABREV,"AOB","AMK","ARP","ATB","AVW","ABI","ABF","ATY", "ACTX", "ACLA", "ASW","ACST","AUTI") : # Objets
     Call PLAGE(CZ,1) From CONTOBJ
     If mkstat : Return : Endif
    Elsif ABREV="ADV" : # Tables diverses
     Call PLAGE(CZ,3) From CONTOBJ
     If mkstat : Return : Endif
    Elsif ABREV="AWI" : # Fenêtres
     If !(left$(CZ,1)="O" & len(CZ)=4)
      Call PLAGE(CZ,1) From CONTOBJ
      If mkstat : Return : Endif
     Endif
    Endif
    Gosub SETNOK From GOBJSUB : # mb 29.4.2 bug 14060
    If CLECUR=0 & ACTCRE & REP<>"C"
     REP = "C" : GREP = "C" : [L]SITCUR = ""
     Gosub RAZCRE From GOBJNAV
     ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
    Elsif CLECUR<>0 & ACTDUP & REP<>"D"
     If (TYPGES=1 or TYPGES=3)
      Call RESET_IMAGE(11) From GESECRAN
      Call RESET_IMAGE(3) From GESECRAN
     Endif
     REP = "D" : GREP = "D" : [L]SITCUR = ""
     ACTION = "RAZDUP" : Gosub ACTION From GOBJSUB
    Endif
    Gosub SETBOUT From GOBJSUB
   Else : # Ca existe, on le charge si on a droit
    Gosub DROIT From GOBJSUB
    If !OK
     Call ERREUR(mess(8,123,1)) From GESECRAN : # Accès impossible à cette fiche
     mkstat = 2 : Return
    Endif
    If VERROU : Gosub DEVERROU From GOBJET : Endif
    REP = "" : GREP = ""
    Gosub LECTURE From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    zonsui = COUZON : # Pour ne pas entrer en modif
   Endif
  When "M"
   #  les clés devraient être grisées
 Endcase
Else :  # C'est pas une zone de clé
 Case REP
  When "" : # On tente d'entrer en modif
   If CLECUR<>0
    If !ACTMOD or GCONSULT
     Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
     RELIT=9 : Gosub RELIT : RELIT=0
     zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
     If evalue("varmode([M]"+COUZON+")",COUIND)=0
      mkstat = 1
     Endif
     Gosub SETBOUT From GOBJSUB
     Return
    Elsif !VERROU
     If dim([L]MLOCK)>0 & [L]MLOCK
      Gosub SYMBOLE From GOBJET
      Read [ALK]LCKCLE = SYMBOLE;0
      If !fstat & [F:ALK]LCKPID<>adxuid(2)
       Call RESET_IMAGE(11) From GESECRAN
       Call SET_IMAGE(3) From GESECRAN
       Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
      Else
       # Si le timestamp d'un objet type "Normal" n'a pas bougé, il suffira de tenter le verrou
       Gosub VERF_FIC
       If !K
        Call ERREUR(mess(11,139,1)) From GESECRAN : # Pour modifier la fiche,cliquez sur l'icône de verrouillage
       Else
        Gosub VERROU From GOBJET
        If !VERROU
         Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
        Else
         Gosub VERF_CLE From GOBJSUB
         If !OK : RELIT = 1 : Endif
        Endif
       Endif
      Endif
     Else
      Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
     Endif
     If !VERROU
      RELIT=9 : Gosub RELIT : RELIT=0
      zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
      If evalue("varmode([M]"+COUZON+")",COUIND)=0 : mkstat = 1 : Endif
      Return
     Endif
    Elsif TYPGES<>2
     Gosub VERF_CLE From GOBJSUB
     If !OK : RELIT = 1 : Endif
    Endif
    If RELIT
     RELIT=9 : AFFICHE = 0 : Gosub RELIT : RELIT=0
     Gosub SETBOUT From GOBJSUB
     If !ACTMOD
      If !AFFICHE : AFFICHE = 1 : Gosub AFFZONE : Endif
      Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
      zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
      If evalue("varmode([M]"+COUZON+")",COUIND)=0
       mkstat = 1
      Endif
      Return
     Endif
    Endif
    OK = 1
    ACTION = "AVANT_MOD" : Gosub ACTION From GOBJSUB
    If !OK
     If !AFFICHE : AFFICHE = 1 : Gosub AFFZONE : Endif
     RELIT=9 : Gosub RELIT : RELIT=0 : # mb 26.1.5 demande 28036
     zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
     mkstat = 1 : Return
    Endif
    If evalue("type([M]"+COUZON+")")<>8 : # Bas de tableau
     Assign "[M]"+COUZON+"("+num$(COUIND)+")" With zc
    Endif
    If !AFFICHE : AFFICHE = 1 : Gosub AFFZONE : Endif
    REP = "M" : GREP = "M" : # on y est
    Gosub SETNOK From GOBJSUB
    If SUIZON="" : SUIZON = zonsui : Endif : # mb 25.10.01
    Gosub GRISE_CLE From =WINPROG
    ACTION = "GRISE" : Gosub ACTION From GOBJSUB
    zonsui = SUIZON
    SUIZON = ""
    Gosub SETBOUT From GOBJSUB
    Return
   Endif
 Endcase
Endif
If SUIZON<>"" : zonsui = SUIZON : SUIZON = "" : Endif
Return

#----------------------------#
$RELIT
If dim([L]DEFMSKAPM)<1
 Local Char DEFMSKAPM(250)
Endif
[L]DEFMSKAPM = dbgstr(1)
Gosub RELIT From GOBJSUB
Default Mask [L]DEFMSKAPM
Return

#----------------------------#
$AFFZONE
If dim([L]DEFMSKAPM)<1
 Local Char DEFMSKAPM(250)
Endif
[L]DEFMSKAPM = dbgstr(1)
Gosub AFFZONE From GOBJSUB
Default Mask [L]DEFMSKAPM
Return

#----------------------------#
$VERF_FIC
K = 1
Gosub DEFAUT From =PROGOBJ
If TYPGES<>1 or evalue("dim([F:"+ABFIC+"]UPDDATTIM)")<=0 or dim([L]OBJUPDDATTIM)<=0 or dim([S]adxtrp)<0 or [S]adxtrp=""
 Goto VERF_FIC2
Endif
Gosub AFF_CLE From GOBJSUB
Assign"[G:"+ABFIC+"]currind" With 1
Assign "[G:"+ABFIC+"]currlen" With 0
Filter [F]
Read =
If fstat or [L]OBJUPDDATTIM<>evalue("[F:"+ABFIC+"]UPDDATTIM")
 K = 0 : Return
Endif
Return

#----------------------------#
$VERF_FIC2
If TYPGES<>1 or evalue("dim([F:"+ABFIC+"]UPDSTP)")<=0 or dim([L]OBJUPDSTP)<=0 or dim([S]adxtrp)<0 or [S]adxtrp=""
 K = 0 : Return
Endif
Gosub AFF_CLE From GOBJSUB
Assign"[G:"+ABFIC+"]currind" With 1
Assign "[G:"+ABFIC+"]currlen" With 0
Filter [F]
Read =
If fstat or [L]OBJUPDSTP<>evalue("[F:"+ABFIC+"]UPDSTP")
 K = 0 : Return
Endif
Return

#----------------------------------------------#
Subprog GET_DERLU(VALEUR,ABREV,CRITERE)
Variable Char VALEUR
Value Char ABREV,CRITERE
Onerrgo RIEN
If GLECOBJ<>2 or GNBDERNIER<=0
 End
Endif
Local File ALSTRD [ALS]
Local Char CLE(GLONID1) , PROGOBJ(GLONADC)
PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Local File =NOMFIC [A__]
If CRITERE="" : CRITERE = "1=1" : Endif
Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
For [ALS]ALS0
 CLE = [F:ALS]CLES
 K = instr(1,CLE,"~")
 If K
  CLE = left$(CLE,K-1)
 Endif
 Read [A__] = CLE
 If !fstat & evalue(CRITERE)
  VALEUR = CLE : Break
 Endif
Next ALS
Close Local File [ALS] , [A__]
End

#----------------------------------------------#
Subprog SET_DERLU(ABREV,CLE)
Value Char ABREV,CLE
If GLECOBJ<>2 or GNBDERNIER<=0
 End
Endif
Local File ALSTRD [ALS]
Local Integer I , K , OK
Trbegin [ALS]
 Gosub ECR_DERLU
Commit
Close Local File [ALS]
End

#----------------------------------------------#
$TR_DERLU
Local Char    CLE(min(GLONID1+GLONID2,250))
CLE = ""
J = evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")
Case J
 When 1,2,4,5,6,7,8,9 : CLE += num$(evalue("[F:"+ABFIC+"]"+CLEPRIM))+"~"
 When Default         : CLE += evalue("[F:"+ABFIC+"]"+CLEPRIM)+"~"
Endcase
For I=0 To dim(CLESEC)-1
 If CLESEC(I)="" | (TYPGES=3 & CLESEC(I)=CLELIG) : Break : Endif
 J = evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
 Case J
  When 1,2,4,5,6,7,8,9 : CLE += num$(evalue("[F:"+ABFIC+"]"+CLESEC(I)))+"~"
  When Default         : CLE += evalue("[F:"+ABFIC+"]"+CLESEC(I))+"~"
 Endcase
Next I
Gosub ECR_DERLU
Return

#----------------------------------------------#
$ECR_DERLU
Filter [ALS] Where USR=GUSER & OBJ=ABREV
Read [ALS]ALS0 Last
If fstat<=2
 If [F:ALS]LIG>=32000
  Delete [ALS] Where USR=GUSER & OBJ=ABREV
  K = 1
 Else
  K = [F:ALS]LIG+1
 Endif
Else
 K = 1
Endif
Raz I, OK
For [ALS]ALS0
 If [F:ALS]CLES=CLE : OK = 1 : Break : Endif
 If dim(CLEVALEUR)<0
  I+=1
 Else : ## GEODE
  OK=1
  Local Integer I1, I2, I3
  If CLEFCY<>""
   I2=0
   J=find(CLEFCY,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If I2 & GFCY<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If CLEDEP<>""
   I2=0
   J=find(CLEDEP,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If GDEP<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If OK : I+=1 : OK=0 : Endif
 Endif
Next
Filter [ALS]
If OK
 [F:ALS]LIG = K
 Rewrite [ALS]
Else
 If I>=GNBDERNIER
  Read [ALS]ALS0(2) = GUSER ; ABREV
  If fstat<=2 : OK = 1 : Endif
 Endif
 Raz [F:ALS]
 [F:ALS]USR  = GUSER
 [F:ALS]OBJ  = ABREV
 [F:ALS]LIG  = K
 [F:ALS]CLES = CLE
 If !OK
  Write [ALS]
 Else
  Rewrite [ALS]
 Endif
Endif
Return

#----------------------------------------------#
$REMP_DERLU
Local Integer NBENR
Local Char    CLE(GLONID1)
Gosub OUVRE_LISTE From =PROGOBJ
Gosub DEFAUT  From =PROGOBJ
Gosub CRITERE From GOBJSUB
Assign "[G:"+ABFIC+"]currind" With 1
If TYPGES=3
 Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC)
Else
 Assign "[G:"+ABFIC+"]currlen" With 0
Endif
Raz IFILGAUSUP , FILGAUSUP
ACTION = "FILGAUCHE" : Gosub ACTION From GOBJET
Onerrgo ERR_REMP From GOBJSUB
If CRITERE=""   : CRITERE = "1=1"   : Endif
If FILTSUP=""   : FILTSUP = "1=1"   : Endif
If FILROLE=""   : FILROLE = "1=1"   : Endif
If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
# Issue 82437 - 2012-06-19 by VPO : on deplace les tests plus bas
#Filter [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILGAUSUP)
Onerrgo
If dim([L]DERLU)>0 & [L]DERLU
 Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
 Raz NBENR
 For [ALS]ALS0
  If NBENR>=dim(A_BUF1) | NBENR>=GNBDERNIER : Break : Endif
  CLE = [F:ALS]CLES
  K = instr(1,CLE,"~")
  If K
   J = evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")
   Case J
    When 1,2,4,5,6,7,8,9 : Assign "[F]"+CLEPRIM With val(left$(CLE,K-1))
    When Default         : Assign "[F]"+CLEPRIM With left$(CLE,K-1)
   Endcase
   CLE = right$(CLE,K+1)
  Endif
  For I=0 To dim(CLESEC)-1
   If CLESEC(I)=""
    Break
   Elsif TYPGES=3 & CLESEC(I)=CLELIG
    J = evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
    Case J
     When 1,2,4,5,6,7,8,9 : Assign "[F]"+CLESEC(I) With 0
     When 3               : Assign "[F]"+CLESEC(I) With [0/0/0]
     When Default         : Assign "[F]"+CLESEC(I) With ""
    Endcase
    Break
   Endif
   K = instr(1,CLE,"~")
   If K
    J = evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
    Case J
     When 1,2,4,5,6,7,8,9 : Assign "[F]"+CLESEC(I) With val(left$(CLE,K-1))
     When Default         : Assign "[F]"+CLESEC(I) With left$(CLE,K-1)
    Endcase
    CLE = right$(CLE,K+1)
   Endif
  Next I
  ERR = 0
  Onerrgo ERR_REMP From GOBJSUB
  If TYPGES=1
   Read [F] =
   ERR = fstat
  Else
   Read [F] >=
   If fstat<=2
    CLE = [F:ALS]CLES
    K = instr(1,CLE,"~")
    If K
     J = evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")
     Case J
      When 1,2,4,5,6,7,8,9 : If evalue("[F]"+CLEPRIM)<>val(left$(CLE,K-1)) : ERR = 1 : Endif
      When Default         : If evalue("[F]"+CLEPRIM)<>left$(CLE,K-1) : ERR = 1 : Endif
     Endcase
     CLE = right$(CLE,K+1)
    Endif
    If !ERR
     For I=0 To dim(CLESEC)-1
      If CLESEC(I)="" | (TYPGES=3 & CLESEC(I)=CLELIG) : Break : Endif
      K = instr(1,CLE,"~")
      If K
       J = evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
       Case J
        When 1,2,4,5,6,7,8,9 : If evalue("[F]"+CLESEC(I))<>val(left$(CLE,K-1)) : ERR = 1 : Break : Endif
        When Default         : If evalue("[F]"+CLESEC(I))<>left$(CLE,K-1) : ERR = 1 : Break : Endif
       Endcase
       CLE = right$(CLE,K+1)
      Endif
     Next I
    Endif
   Endif
  Endif
  Onerrgo
  If !ERR
     # Issue 82437 - 2012-06-19 by VPO : CRITERE,FILTSUP,FILROLE testés dans DROIT, il reste FILGAUSUP
     Gosub DROIT From GOBJSUB
     Onerrgo ERR_REMP From GOBJSUB
     If OK & !evalue(FILGAUSUP)
        OK=0
     Endif
     # Issue 82383 - 2012-10-15 by VPO : filtre LEGFIL sur derniers lus
     If OK & FILLEG<>"" & FILLEG<>"1=1" & !evalue(FILLEG)
        OK=0
     Endif
     Onerrgo
  Else
   OK = 0
  Endif
  If OK
   ACTION = "LEC_DERLU" : Gosub ACTION From GOBJET
  Endif
  If OK
   Gosub LEC_DERLU From =PROGOBJ
   NBENR += 1
   For I=1 To [L]NBSEL
    If dim([L]SELEXP)>0 & [L]SELEXP(I)<>""
     Assign "A_BUF"+num$(I)+"("+num$(NBENR-1)+")" With evalue([L]SELEXP(I))
    Else
     Assign "A_BUF"+num$(I)+"("+num$(NBENR-1)+")" With evalue([L]SELZON(I))
    Endif
   Next I
   If dim(A_BUFI)>0
    A_BUFI(NBENR-1) = NBENR : # La clé du VTB
   Endif
   If dim(A_BUFC)>0
    A_BUFC(NBENR-1) = [F:ALS]CLES
   Endif
  Endif
 Next
 Filter [ALS]
 SAVMXL = adxmxl
 adxmxl = NBENR
 ACTION = "REMP_DERLU" : Gosub ACTION From GOBJSUB
 Gosub REMP_DERLU From =PROGOBJ
 adxmxl = SAVMXL
Endif
Gosub DEFAUT From =PROGOBJ
Filter [F]
Return

#----------------------------------------------#
$CLE_DERLU
K = instr(1,CLE,"~")
If K
 J = evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")
 Case J
  When 1,2,4,5,6,7,8,9 : Assign "[F]"+CLEPRIM With val(left$(CLE,K-1))
  When Default         : Assign "[F]"+CLEPRIM With left$(CLE,K-1)
 Endcase
 CLE = right$(CLE,K+1)
Endif
For I=0 To dim(CLESEC)-1
 If CLESEC(I)="" : Break : Endif
 K = instr(1,CLE,"~")
 If K
  J = evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
  Case J
   When 1,2,4,5,6,7,8,9 : Assign "[F]"+CLESEC(I) With val(left$(CLE,K-1))
   When Default         : Assign "[F]"+CLESEC(I) With left$(CLE,K-1)
  Endcase
  CLE = right$(CLE,K+1)
 Endif
Next I
Return

#----------------------------------------------#
$FILROLE
If dim(FILROLE)<=0
 Local Char    FILROLE(250)(0..5)
 Local Integer IFILROLE
Endif
If dim(ABFIC)<=0 or ABFIC=""
 Gosub NOMFIC From ="WO"+ABROL
Endif
Local Char    CHAINE(250)
Local Integer T
I = 1
Raz FILROLE, IFILROLE
While I<=GNBROLUSR
 K = find(GROLUSR(I)-ABROL,GROLE(1..GNBROLE))
 If K
  T = evalue('type([F:'+ABFIC+']'+GFLDROLE(K)+')')
  If I<GNBROLUSR & GROLUSR(I+1)=GROLUSR(I)
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",'find([F:'+ABFIC+']'+GFLDROLE(K),"&") From GOBJSUB
   If FILROLE="" : Break : Endif
   J = I
   While I<=GNBROLUSR & GROLUSR(I)=GROLUSR(J)
    CHAINE = GROLCLE(I)
    If left$(CHAINE,1)="="
     CHAINE = right$(CHAINE,2)
    Elsif !find(T,1,2,4,5,6,7,8) : # mb 16.6.3 bug 18609
     CHAINE = '"'+CHAINE+'"'
    Endif
    Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",','+CHAINE,"") From GOBJSUB
    If FILROLE="" : Break 2 : Endif
    I += 1
   Wend
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",')<>0',"") From GOBJSUB
   If FILROLE="" : Break : Endif
  Else
   CHAINE = GROLCLE(I)
   If left$(CHAINE,1)="="
    CHAINE = right$(CHAINE,2)
   Elsif !find(T,1,2,4,5,6,7,8)
    CHAINE = '"'+CHAINE+'"'
   Endif
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",'[F:'+ABFIC+']'+GFLDROLE(K)+'='+CHAINE,"&") From GOBJSUB
   If FILROLE="" : Break : Endif
   I += 1
  Endif
 Else
  I += 1
 Endif
Wend
If FILROLE="" : FILROLE = "1=1" : Endif
Return

#----------------------------------------------#
Subprog SELRAP(OBJET,SAIRAP,IFILRAP,FILRAP)
Value    Char    OBJET
Value    Char    SAIRAP()(1..)
Variable Integer IFILRAP
Variable Char    FILRAP
Local Integer I , J , K , T , ER , NOLIB
Local Char    RAPCAR(250) , RAPVAR(250) , CRIRAP(250)
Local Char    REFRAP(250) , SIGRAP(2) , CAR(1)
Local Date    RAPDAT
Local Char    PROGOBJ(GLONADC)
If OBJET="" : End : Endif : #109309/109806
PROGOBJ = "WO"+OBJET
Gosub OUVRE_LISTE From =PROGOBJ
Gosub DEFAUT_LISTE From =PROGOBJ
Raz FILRAP, IFILRAP
GPE = 0
GPOINT = "SELRAPOBJ" : Gosub ENTREE From EXEFNC : # mb 28.5.8 demande 47600/47597
If GPE : End : Endif
Onerrgo RIEN
For I=1 To NBSEL
 If [L]SAIRAP(I)<>""
  Raz T, CRIRAP, NOLIB
  If dim([L]SELEXP)>0 & SELEXP(I)<>""
   If left$(SELEXP(I),4) = "mess"
    T = 1
    J = instr(1,SELEXP(I),"(")
    K = instr(1,SELEXP(I),",")
    RAPVAR = seg$(SELEXP(I),J+1,K-1)
    J = instr(K+1,SELEXP(I),",")
    NOLIB = val(seg$(SELEXP(I),K+1,J-1))
   Else
    RAPVAR = SELEXP(I)
    Case SELTYP(I)
     When 1       : T = 0 : # Nolib ?
     When 7       : T = 11
     When 8       : T = 3
     When Default : T = 2
    Endcase
   Endif
  Else
   RAPVAR = SELZON(I)
   Case SELTYP(I)
    When 1       : T = 1 : NOLIB = val(right$(SELFMT(I),3))
    When 7       : T = 11
    When 8       : T = 3
    When Default : T = 2
   Endcase
  Endif
  SIGRAP = ""
  REFRAP = [L]SAIRAP(I)
  For J=1 To 2
   If find(mid$([L]SAIRAP(I),J,1),"=",">","<")
    SIGRAP += mid$([L]SAIRAP(I),J,1)
    REFRAP = right$([L]SAIRAP(I),J+1)
   Endif
  Next J
  Case T
   When 0
   When 1
    If SIGRAP="" : SIGRAP = "=" : Endif
    If num$(val(REFRAP))=REFRAP & REFRAP>="0" & REFRAP<="999"
     CRIRAP = RAPVAR+SIGRAP+REFRAP
    Else
     For J=1 To len(mess(0,NOLIB,1))
      K = 0
      If instr(1,REFRAP,"*") or instr(1,REFRAP,"?")
       If pat(toupper(ctrans(mess(J,NOLIB,1))),toupper(ctrans(REFRAP)))
        K = 1
       Endif
      Else
       If evalue("left$(toupper(ctrans(mess(J,NOLIB,1))),len(REFRAP))"+SIGRAP+"toupper(ctrans(REFRAP))")
        K = 1
       Endif
      Endif
      If K & len(CRIRAP)<200
       If CRIRAP=""
        CRIRAP = "("
       Else
        CRIRAP += "|"
       Endif
       CRIRAP += RAPVAR+"="+num$(J)
      Endif
     Next J
     If CRIRAP<>""
      CRIRAP += ")"
     Else
      CRIRAP = RAPVAR+SIGRAP+"9999" : # Critère incorrect : la sélection ne ramènera rien
     Endif
    Endif
   When 2,4,5,6,7,8,9
    REFRAP = ctrans(REFRAP,",",".")
    If val(REFRAP)<>0
     If SIGRAP="" : SIGRAP = "=" : Endif
     CRIRAP = RAPVAR+SIGRAP+REFRAP
    Endif
   When 3
    Call CHARGE(REFRAP,"D",0,0,RAPCAR) From FMTVAR
    If GERR
     Call ERREUR(GMESSAGE) From GESECRAN
     Raz GMESSAGE
    Else
     Onerrgo RIEN
     RAPDAT = RAPCAR
     Onerrgo
     If RAPDAT<>[0/0/0]
      If SIGRAP="" : SIGRAP = "=" : Endif
      CRIRAP = RAPVAR+SIGRAP+'['+format$(GFMD,RAPDAT)+']'
     Endif
    Endif
   When Default
    RAPCAR = REFRAP
    J = instr(1,RAPVAR,"+")
    K = instr(1,RAPVAR,"-")
    If J=0 & K<>0
     RAPVAR = left$(RAPVAR,K-1)
    Elsif J<>0 & K=0
     RAPVAR = left$(RAPVAR,J-1)
    Elsif J<>0 & K<>0
     RAPVAR = left$(RAPVAR,min(J,K)-1)
    Endif
    If dim([V]GCASSE)>0 & GCASSE=1
     RAPCAR = toupper(RAPCAR)
     RAPVAR = "toupper("+RAPVAR+")"
    Endif
    K = instr(1,RAPCAR,'"')
    J = instr(1,RAPCAR,"'")
    If K & J
     Repeat
      K = instr(1,RAPCAR,'"')
      If K : RAPCAR = left$(RAPCAR,K-1)+right$(RAPCAR,K+1) : Endif
     Until K=0
    Elsif K
     CAR = "'"
    Else
     CAR = '"'
    Endif
    If RAPCAR<>""
     Case left$(SIGRAP,1)
      When ">","<"
       CRIRAP = RAPVAR+SIGRAP+'"'+RAPCAR+'"'
      When Default
       J = instr(1,RAPCAR,"*")
       K = instr(1,RAPCAR,"?")
       If J or K
        If K or J<>len(RAPCAR)
         If instr(1,RAPVAR,"string$") & 1=0 : # mb 5.5.9 bug 54938/mb 10.11.9 bug 59771
          # Erreur sur critère de sélection
          # Du fait du type de cette colonne vous ne pouvez utiliser qu'un seul joker '*' en fin de chaîne
          Call ERREUR(mess(33,100,1)+":\"+mess(275,139,1)) From GESECRAN
          Raz FILRAP , IFILRAP : Break
         Endif
         CRIRAP = 'pat('+RAPVAR
         If !instr(1,RAPVAR,"(") : CRIRAP += '(0)' : Endif
         If CAR='"'
          CRIRAP += ',"'+RAPCAR+'")=1'
         Else
          CRIRAP += ",'"+RAPCAR+"')=1"
         Endif
        Endif
        If     J & K : J = min(J,K)
        Elsif !J & K : J = K
        Endif
        If J>1
         If CRIRAP<>"" : CRIRAP += "&" : Endif
         If CAR='"'
          CRIRAP += RAPVAR+'>="'+left$(RAPCAR,J-1)+'"'
          CRIRAP += "&"
          CRIRAP += RAPVAR+'<"'+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+'"'
         Else
          CRIRAP += RAPVAR+">='"+left$(RAPCAR,J-1)+"'"
          CRIRAP += "&"
          CRIRAP += RAPVAR+"<'"+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+"'"
         Endif
        Endif
       Else
        If CAR='"'
         CRIRAP = RAPVAR+'="'+RAPCAR+'"'
        Else
         CRIRAP = RAPVAR+"='"+RAPCAR+"'"
        Endif
       Endif
     Endcase
    Endif
  Endcase
  Call ADDCRIT(FILRAP,IFILRAP,"FILRAP",CRIRAP,"&") From GOBJSUB
 Endif
Next I
ER = 0
Onerrgo ERR
If FILRAP<>""
 Filter [F] Where evalue(FILRAP)
 Read [F] =
 Filter [F]
 If ER
  # Une des colonnes choisie contient un expression qui n'est pas compatible avec la sélection rapide
  # Veuillez choisir une autre colonne
  Call MESSAGE(mess(324,139,1)+"\"+mess(325,139,1)) From GESECRAN
  #Call ERREUR(mess(33,100,1)+":\"+errmes$(ER)) From GESECRAN : # Erreur sur critère de sélection
  Raz FILRAP, IFILRAP
 Endif
Endif
Onerrgo
End

$RIEN
Resume

$ERR
ER = errn
Resume

#-----------------------------------------------#
Subprog IND_SELRAP(OBJET,RAPVAR,RAPIND)
Value    Char    OBJET
Value    Char    RAPVAR
Variable Integer RAPIND
Local Char    PROGOBJ(GLONADC)
Local Integer I
PROGOBJ = "WO"+OBJET
Gosub OUVRE_LISTE From =PROGOBJ
Raz RAPIND
For I=1 To NBSEL
 If instr(1,SELZON(I),RAPVAR)
  RAPIND = I
  Break
 Endif
Next I
If !RAPIND
 For I=1 To NBSEL
  If instr(1,SELEXP(I),RAPVAR)
   RAPIND = I
   Break
  Endif
 Next I
Endif
End

#-----------------------------------------------#
# Actions sur boutons Documentation
#-----------------------------------------------#

Subprog PARAGRAPHES(ABREV,CLE1,CLE2)
Value    Char    ABREV , CLE1 , CLE2()(1..)
Local Char OBJET(GLONAOB) , CLE(GLONID2)
If GABREV="ADO" : End : Endif
If clalev([F:ADO])=0 : Local File ADOCUMENT [ADO] : Endif
Case ABREV
 When "AFC"
  If clalev([F:AF__])=0 : Local File AFONCTION [AF__] : Endif
  Read [AF__]CODINT = CLE1
  If !fstat & [F:AF__]TYPTRAIT=2
   OBJET = "APM"
  Else
   OBJET = "AFC"
  Endif
  Close Local File [AF__]
  CLE = CLE1
 When Default
  OBJET = ABREV
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find(ABREV, [L]DOC_CLE_MULT)
    CLE = CLE2+[L]WTIRET+CLE1
  Else
    CLE = CLE1
  Endif
Endcase
Read [ADO]ADO0(3) >= GLANGUE;OBJET;CLE
Call OBJET_CHAR([F:ADO]TYP,"ADO",[F:ADO]LAN+"~"+[F:ADO]COD+"~"+num$([F:ADO]LEV)+"~"+num$([F:ADO]SUBLEV))
& From GOBJET
End

Subprog LIENS(ABREV,CLE1,CLE2)
Value    Char    ABREV , CLE1 , CLE2()(1..)
If GABREV="ADF" : End : Endif
If clalev([F:ADF])=0 : Local File ADOCFNC   [ADF] : Endif
Read [ADF]ADF0 = ABREV;CLE1
If fstat
 Read [ADF]ADF0 >= ABREV;CLE1
Endif
Call OBJET_CHAR([F:ADF]COD,"ADF",[F:ADF]TYP) From GOBJET
End

Subprog GENDOC(ABREV,CLE1,CLE2)
Value    Char    ABREV , CLE1 , CLE2()(1..)
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = ABREV
# JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
If find(ABREV, [L]DOC_CLE_MULT)
  PARBOUT(2) = CLE2+[L]WTIRET+CLE1
Else
  PARBOUT(2) = CLE1
Endif
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AGENDOC","AGENDOC",3,"SPEGENDOC") From GTRAITE
End

