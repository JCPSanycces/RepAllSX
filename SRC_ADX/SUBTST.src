#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "SETBOUT" : Gosub SETBOUT
  When "INICRE"   Gosub INICRE
  When "INIMOD"   Gosub INICRE
  When "ANNULE"   Gosub ANNULE
  When "LIENS"    Gosub LIENS     #MAE, bg 82054
  When "CHANGE" : Call CHANGE_AXX ("TABSTASTO", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
 
$INICRE
    #MAE, le 06/02/09, bg 52196, oubli du (nolign-1)
    Call MAJTEXTRA([M:TST1]STAAXX(nolign-1),"TABSTASTO","STAAXX",[M:TST1]STASTO(nolign-1),"") From ATEXTRA
    Call MAJTEXTRA([M:TST1]STASHOAXX(nolign-1),"TABSTASTO","STASHOAXX",[M:TST1]STASTO(nolign-1),"") From ATEXTRA
Return

$LIENS
#MAE, bg 82054
Call LECTEXTRA([M:TST1]STAAXX(nolign-1),"TABSTASTO","STAAXX",[M:TST1]STASTO(nolign-1),"") From ATEXTRA
Call LECTEXTRA([M:TST1]STASHOAXX(nolign-1),"TABSTASTO","STASHOAXX",[M:TST1]STASTO(nolign-1),"") From ATEXTRA
Return

$ANNULE

    #MAE, le 06/02/09, bg 52196
    #Delete [AXX] Where CODFIC="TABSTASTO" & ZONE="STAAXX" & CLE1= [M:TST1]STASTO(nolign-1)
    #Delete [AXX] Where CODFIC="TABSTASTO" & ZONE="STASHOAXX" & CLE1= [M:TST1]STASTO(nolign-1)
    Delete [AXX] Where CODFIC="TABSTASTO" & ZONE="STAAXX" & IDENT1= [M:TST1]STASTO(nolign-1)
    Delete [AXX] Where CODFIC="TABSTASTO" & ZONE="STASHOAXX" & IDENT1= [M:TST1]STASTO(nolign-1)
Return

############################################################
$SETBOUT 
Call VIREBOUT(CHAINE,"DH") From GOBJET  
Return
############################################################
Subprog AS_STASTO(VALEUR)
Variable Char    VALEUR()
If    VALEUR <> ""
      Look [TST]TST0 = VALEUR
      If !fstat : mkstat = 2 : Endif
Endif
End
############################################################
Subprog C_STASTO(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]STASTO) From OBJDIV
If   seg$(VALEUR,1,1) <> "A"
&  & seg$(VALEUR,1,1) <> "Q"
&  & seg$(VALEUR,1,1) <> "R"
     GMESSAGE = mess(21,199,1)
     mkstat = 2
Endif
End
############################################################
Subprog AV_STASHOAXX(VALEUR)
Variable Char     VALEUR
If VALEUR = "" VALEUR = [M]STAAXX(nolign-1) : Endif
End
