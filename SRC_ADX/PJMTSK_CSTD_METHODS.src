#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSK
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  SLEVEL = func AFNC.MES2(mess(941,2260,1), this.OPPNUM, this.TASCOD)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
#   RITT Collection
###################################################################################################
$RITT_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  this.RITT(LIN).OPPCMP = this.OPPCMP
  this.RITT(LIN).TCHTASSTATE = this.TASSTATE
Return

###################################################################################################
$RITT_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
$RITT_GET_EFFECTIVE_DATE
#Variable Date RETDATE
#Local Integer ARET_VALUE

Local Integer IRITTLINE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Raz RETDATE
  RETDATE = date$
  If this.TASSTARTDT <> [0/0/0] Then
    If RETDATE < this.TASSTARTDT Then
      RETDATE = this.TASSTARTDT
    Endif
  Endif
  If this.TASENDDT <> [0/0/0] Then
    If RETDATE > this.TASENDDT Then
      RETDATE = this.TASENDDT
    Endif
  Endif
Return

###################################################################################################
$RITT_GET_INDEX
#Value Integer ITTSEQ
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RITT(NI).ITTSEQ = ITTSEQ Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$RITT_GET_INDEX_ITMREF
#Value Char SITMREF ()
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RITT(NI).ITMREF = SITMREF Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$RITT_EXISTING
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  For NI = 1 To maxtab(this.RITT)
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
$RITT_REPEAT_TASENDDT
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.ASTALIN = [V]CST_AUPD Then
    If (this.TCHANSREQDAT = 1 or this.TCHANSREQDAT = 3) and this.TASENDDT <> this.snapshot.TASENDDT Then
      For NI = 1 To maxtab(this.RITT)
        If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TCHANSREQDAT = 1 or (this.TCHANSREQDAT = 3 and this.RITT(NI).REQDAT = this.snapshot.TASENDDT) Then
            # 1:Yes // 3:Yes if same value before
            this.RITT(NI).REQDAT = this.TASENDDT
          Endif
        Endif
      Next NI
    Endif
  Endif
Return

###################################################################################################
$RITT_CHECK_MANUF_INVENTORY
#Value Char SITMREF ()
#Variable Char SLSTTXT ()
#Local Integer ARET_VALUE

Local Integer IFOUND

  # Issue X3-101833 - 2018-07-30 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File MTOLINK [MLK]
  # -----------------------------
  IFOUND = [V]CST_ANO
  If SITMREF = AVOID.ACHAR Then
    Filter [MLK] Where [F:MLK]DEMTYP = 40 and [F:MLK]DEMNUM = this.TASNUM
  Else
    Filter [MLK] Where [F:MLK]DEMTYP = 40 and [F:MLK]DEMNUM = this.TASNUM and [F:MLK]ITMREF = SITMREF
  Endif
  For [MLK]
    If SLSTTXT <> AVOID.ACHAR Then
      SLSTTXT += ","
    Endif
    SLSTTXT -= this.TASNUM
    IFOUND = [V]CST_AYES
    Break
  Next
  Filter [MLK]
Return

###################################################################################################
#   RTKO Collection
###################################################################################################
$RTKO_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  this.RTKO(LIN).TCHCHGTYP = this.TCHCHGTYP
  this.RTKO(LIN).TCHTCACOD = this.TCACOD
  this.RTKO(LIN).TCHTASSTATE = this.TASSTATE
Return

###################################################################################################
$RTKO_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
$RTKO_GET_INDEX
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RTKO(NI).OPENUM = OPENUM and this.RTKO(NI).OPESPLNUM = OPESPLNUM Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$RTKO_CLOSING
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TCHACTION <> "RTKO_CLOSING" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # ------------------------------------
  If this.TASSTATE = 4 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(302,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.TASTYP = 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(313,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
  # ------------------------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    ILINE = fmet this.RTKO_GET_INDEX(OPENUM, OPESPLNUM)
    If ILINE < 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(247,2260,1), num$(OPENUM), num$(OPESPLNUM)), [V]CST_AERROR))
    Else
      If this.RTKO(ILINE).OPESTA = 5 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(303,2260,1), mess(this.RTKO(ILINE).OPESTA,308,1)), [V]CST_AERROR))
      Endif
      # ------------------------------------
      If [L]ARET_VALUE = [V]CST_AOK Then
        this.RTKO(ILINE).TCHACTION = "CLOSING"
        this.RTKO(ILINE).OPESTA = 5
        this.RTKO(ILINE).RMNQTY = 0
        If TECOPPACT.EVTDAT = [0/0/0] Then
          this.RTKO(ILINE).OPEDATS = date$
        Else
          this.RTKO(ILINE).OPEDATS = TECOPPACT.EVTDAT
        Endif
        this.RTKO(ILINE).OPECOMTEX = TECOPPACT.COMTEX
      Endif
      # ------------------------------------
    Endif
  Endif
  # ------------------------------------
Return

###################################################################################################
$RTKO_SUSPENSION
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TCHACTION <> "RTKO_SUSPENSION" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  If this.TASSTATE = 4 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(302,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.TASTYP = 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(313,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
  If [L]ARET_VALUE = [V]CST_AOK Then
    ILINE = fmet this.RTKO_GET_INDEX(OPENUM, OPESPLNUM)
    If ILINE < 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(247,2260,1), num$(OPENUM), num$(OPESPLNUM)), [V]CST_AERROR))
    Else
      If this.RTKO(ILINE).OPESTA = 5 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(303,2260,1), mess(this.RTKO(ILINE).OPESTA,308,1)), [V]CST_AERROR))
      Endif
      If [L]ARET_VALUE = [V]CST_AOK Then
        this.RTKO(ILINE).TCHACTION = "SUSPENSION"
        this.RTKO(ILINE).OPESTA = 1
        If TECOPPACT.EVTDAT = [0/0/0] Then
          this.RTKO(ILINE).OPEDATH = date$
        Else
          this.RTKO(ILINE).OPEDATH = TECOPPACT.EVTDAT
        Endif
        this.RTKO(ILINE).OPECOMTEX = TECOPPACT.COMTEX
      Endif
    Endif
  Endif
Return

###################################################################################################
$RTKO_REACTIVATE
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT : #
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TCHACTION <> "RTKO_REACTIVATE" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  If this.TASSTATE = 4 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(302,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
  Endif
  If this.TASTYP = 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(313,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
  If [L]ARET_VALUE = [V]CST_AOK Then
    ILINE = fmet this.RTKO_GET_INDEX(OPENUM, OPESPLNUM)
    If ILINE < 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(247,2260,1), num$(OPENUM), num$(OPESPLNUM)), [V]CST_AERROR))
    Else
      If this.RTKO(ILINE).OPESTA <> 1 and this.RTKO(ILINE).OPESTA <> 5 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(303,2260,1), mess(this.RTKO(ILINE).OPESTA,308,1)), [V]CST_AERROR))
      Endif
      If [L]ARET_VALUE = [V]CST_AOK Then
        this.RTKO(ILINE).TCHACTION = "REACTIVATE"
        If this.TASSTATE = 1 or this.TASSTATE = 9 Then
          this.RTKO(ILINE).OPESTA = 1
        Elsif this.TASSTATE = 2 or this.TASSTATE = 3 Then
          this.RTKO(ILINE).OPESTA = 4
        Endif
        #
        If this.RTKO(ILINE).OPEDATH <> [0/0/0] Then
          Raz this.RTKO(ILINE).OPEDATH
          If this.RTKO(ILINE).EXTQTY - this.RTKO(ILINE).CSMQTY > 0 Then
            this.RTKO(ILINE).RMNQTY = this.RTKO(ILINE).EXTQTY - this.RTKO(ILINE).CSMQTY
          Else
            this.RTKO(ILINE).RMNQTY = 0
          Endif
        Endif
        If this.RTKO(ILINE).OPEDATS <> [0/0/0] Then
          Raz this.RTKO(ILINE).OPEDATS
        Endif
        this.RTKO(ILINE).OPECOMTEX = TECOPPACT.COMTEX
      Endif
    Endif
  Endif
Return

####################################################################################################
$RTKO_GET_EFFECTIVE_DATE
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Date RETDATE
#Local Integer ARET_VALUE

Local Integer IRTKOLINE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Raz RETDATE
  IRTKOLINE = fmet this.RTKO_GET_INDEX(OPENUM, OPESPLNUM)
  If IRTKOLINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(246,2260,1), num$(OPENUM), num$(OPESPLNUM)), [V]CST_AERROR))
    Return
  Endif
  # ----------------------------
  RETDATE = date$
  If this.RTKO(IRTKOLINE).OPESTR <> [0/0/0] Then
    If RETDATE < this.RTKO(IRTKOLINE).OPESTR Then
      RETDATE = this.RTKO(IRTKOLINE).OPESTR
    Endif
  Else
    If this.TASSTARTDT <> [0/0/0] Then
      If RETDATE < this.TASSTARTDT Then
        RETDATE = this.TASSTARTDT
      Endif
    Endif
  Endif
  If this.RTKO(IRTKOLINE).OPEEND <> [0/0/0] Then
    If RETDATE > this.RTKO(IRTKOLINE).OPEEND Then
      RETDATE = this.RTKO(IRTKOLINE).OPEEND
    Endif
  Else
    If this.TASENDDT <> [0/0/0] Then
      If RETDATE > this.TASENDDT Then
        RETDATE = this.TASENDDT
      Endif
    Endif
  Endif
  # ----------------------------
Return

###################################################################################################
$RTKO_GET_COST_EFFECTIVE_RATE
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Value Integer ITTSEQ
#Variable Char CUR ()
#Variable Char UOM ()
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Integer IRTKOLINE
Local Integer WRET
Local Char WRKPCCCOD(GLONPJCC)
Local Date EFFDATE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Raz CUR
  Raz UOM
  Raz RATE
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RTKO_GET_COST_TYPE (OPENUM, OPESPLNUM, CUR, UOM, PCCCOD))
  If [L]ARET_VALUE > [V]CST_AWARNING Then
    Return
  Endif
  WRKPCCCOD = PCCCOD
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RTKO_GET_EFFECTIVE_DATE(OPENUM, OPESPLNUM, EFFDATE))
  If [L]ARET_VALUE > [V]CST_AWARNING Then
    Return
  Endif
  If [L]ARET_VALUE = [V]CST_AOK Then
    # Find Cost type effective rate
    Local File PJMCOSTDAT [PCD]
    Filter [PCD] Where [PCD]PCCCOD = WRKPCCCOD and [PCD]PCCDATCST <= EFFDATE Order By [PCD]PCCDATCST Desc
    Read [PCD]First
    If fstat = 0 Then
      RATE = [F:PCD]PCCCST
    Endif
    Filter [PCD]
  Endif
Return

###########################################################################
$RTKO_GET_COST_TYPE
#Value Integer OPENUM
#Value Integer OPESPLNUM
#Variable Char CUR ()
#Variable Char UOM ()
#Variable Char PCCCOD ()
#Local Integer ARET_VALUE

Local Integer IRTKOLINE
Local Char SMESSAGE(250)

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Raz CUR
  Raz UOM
  Raz PCCCOD
  # ----------------------------
  IRTKOLINE = fmet this.RTKO_GET_INDEX(OPENUM, OPESPLNUM)
  If IRTKOLINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(246,2260,1), num$(OPENUM), num$(OPESPLNUM)), [V]CST_AERROR))
    Return
  Endif
  # ----------------------------
  Local File WORKSTATIO [MWS]
  Local File PJMCOSTCTR [PJCC]
  # ----------------------------
  If this.RTKO(IRTKOLINE).EXTWST <> AVOID.ACHAR Then
    Read [MWS]WST0=this.RTKO(IRTKOLINE).EXTWST;this.RTKO(IRTKOLINE).TASFCY
    If fstat > 0 Then
      Read [MWS]WST0=this.RTKO(IRTKOLINE).EXTWST;""
    Endif
    If fstat = 0 Then
      If [F:MWS]PCCCOD <> AVOID.ACHAR Then
        WRKPCCCOD = [F:MWS]PCCCOD
        PCCCOD = [F:MWS]PCCCOD
        # ----------------------------
        Read [PJCC]PCC0=WRKPCCCOD
        If fstat Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(248,2260,1), WRKPCCCOD), [V]CST_AERROR))
        Else
          UOM = [F:PJCC]PCCU
          CUR = [F:PJCC]PCCCUR
        Endif
      Else
        If func PJMTSKCAT_CSTD_PROGS.GET_COST_EFFECTIVE_RATE(this.TCACOD, PCCCOD, UOM, CUR, SMESSAGE) = [V]CST_AERROR Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR))
        Endif
      Endif
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES2(mess(247,2260,1), this.RTKO(IRTKOLINE).EXTWST, this.RTKO(IRTKOLINE).TASFCY), [V]CST_AERROR))
    Endif
  Else
    If func PJMTSKCAT_CSTD_PROGS.GET_COST_EFFECTIVE_RATE(this.TCACOD, PCCCOD, UOM, CUR, SMESSAGE) = [V]CST_AERROR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$RTKO_EXISTING
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
$RTKO_GET_PROGRESS
#Variable Decimal NCSMTOT
#Variable Decimal NRMNTOT
#Local Decimal ARET_VALUE

Local Integer NI
Local Decimal NLCSMTOT
Local Decimal NLRMNTOT
Local Char SCOMUOM(GLONUOM)

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  SCOMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NLCSMTOT = this.RTKO(NI).CSMQTY
      NLRMNTOT = this.RTKO(NI).RMNQTY
      If this.RTKO(NI).OPEUOM2 <> SCOMUOM Then
        Call CONVERT_QTY(this.ACTX, this.RTKO(NI).OPEUOM2, SCOMUOM, NLCSMTOT) From TRTX3_SYRA
        Call CONVERT_QTY(this.ACTX, this.RTKO(NI).OPEUOM2, SCOMUOM, NLRMNTOT) From TRTX3_SYRA
      Endif
      NCSMTOT += NLCSMTOT
      NRMNTOT += NLRMNTOT
    Endif
  Next NI
Return

###################################################################################################
$RTKO_COMPUTE_EXTQTY
#Variable Char UOM ()
#Local Decimal ARET_VALUE
# Issue X3-26843 - 2017-02-21 by SINGC

Local Integer NI
Local Decimal CONQTY

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RTKO)
    If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      CONQTY = this.RTKO(NI).EXTQTY
      If this.RTKO(NI).OPEUOM2 <> UOM Then
        Call CONVERT_QTY(this.ACTX, this.RTKO(NI).OPEUOM2, UOM, CONQTY) From TRTX3_SYRA
      Endif
      [L]ARET_VALUE += CONQTY
    Endif
  Next NI
Return

