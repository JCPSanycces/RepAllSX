###################################################################################################
#   SPLD Collection
###################################################################################################
$SPLD_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.SPLD(LIN) <> null Then
    this.SPLD(LIN).OPPCMP = this.OPPCMP
    this.SPLD(LIN).STOFCY = this.TASFCY
  Endif
Return

###################################################################################################
$SPLD_DEL_ALL_LINES
#Value Integer PARORI

Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TASSTATE <> 4 Then
    For NI = 1 To maxtab(this.SPLD)
      If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.SPLD(NI).ORI = PARORI and this.SPLD(NI).PSONUM = AVOID.ACHAR Then
          [L]ARET_VALUE = fmet this.ADELLINE("SPLD", this.SPLD(NI).AORDER)
          If [L]ARET_VALUE = [V]CST_ANOTDEFINED Then
            Break
          Endif
        Endif
      Endif
    Next NI
  Endif
Return

#######################################################################################
$SPLD_GET_INDEX
#Value Integer SEQNUM
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.SPLD(NI).SEQNUM = SEQNUM Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$SPLD_EXISTING
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
#   PTLNK Collection
###################################################################################################
PTLNK_INIT_TECH_PROP
#Value Integer LIN
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
Return

###################################################################################################
$PTLNK_EXISTING
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  For NI = 1 To maxtab(this.PTLNK)
    If this.PTLNK(NI) <> null and find(this.PTLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Endif
  Next NI
Return

###################################################################################################
#   Task
###################################################################################################
$GET_PIMTYP_FROM_TCACOD
#Value Char TCACOD ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = 0
  # -----------------------------
  Local File PJMTSKCAT [PTC]
  Read [F:PTC]CTA0=TCACOD
  If fstat Then
    [L]ARET_VALUE = -1
  Else
    [L]ARET_VALUE = fmet this.CONV_ML2252_TO_ML2254([F:PTC]TASTYP)
  Endif
Return

###################################################################################################
$CONV_ML2252_TO_ML2254
#Value Shortint TYP
#Local Integer ARET_VALUE

  Case TYP
    When 1
      # Matière
      [L]ARET_VALUE = 6
    When 2
      # MO
      [L]ARET_VALUE = 5
    When 3
      # Mixte
      [L]ARET_VALUE = 7
    When Default
      [L]ARET_VALUE = 8
  Endcase
Return

###################################################################################################
$COPY
#Variable Instance TARGET Using C_PJMTSK
#Variable Instance TECCLA Using C_PJMACOPY
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY
Local Integer NI
Local Integer ILINE
Local Integer INBOPENUM
Local Integer IOPENUM(1..,1..4)
Local Integer IDXOPENUM
Local Integer NE
Local Integer IOPELINEO
Local Integer IOPELINET

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # ---------------------------
  If TECCLA.TASPRL = [V]CST_AYES Then
    For NI = 1 To maxtab(this.RITT)
      If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ILINE = fmet TARGET.ADDLINE("RITT", [V]CST_ALASTPOS)
        If ILINE = [V]CST_ANOTDEFINED Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(975,2260,1), [V]CST_AERROR))
          Break
        Endif
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RITT(NI).COPY(TARGET.RITT(ILINE), TECCLA, TECIDX))
      Endif
    Next NI
  Endif
  # ---------------------------
  If TECCLA.TASOPL = [V]CST_AYES Then
    Raz INBOPENUM
    For NI = 1 To maxtab(this.RTKO)
      If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ILINE = fmet TARGET.ADDLINE("RTKO", [V]CST_ALASTPOS)
        If ILINE = [V]CST_ANOTDEFINED Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(976,2260,1), [V]CST_AERROR))
          Break
        Endif
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RTKO(NI).COPY(TARGET.RTKO(ILINE), TECCLA, TECIDX))
        INBOPENUM += 1
        IOPENUM(INBOPENUM,1) = this.RTKO(NI).OPENUM
        IOPENUM(INBOPENUM,2) = this.RTKO(NI).OPESPLNUM
        IOPENUM(INBOPENUM,3) = TARGET.RTKO(ILINE).OPENUM
        IOPENUM(INBOPENUM,4) = TARGET.RTKO(ILINE).OPESPLNUM
      Endif
    Next NI
    If [L]ARET_VALUE < [V]CST_AERROR Then
      If TECCLA.TASOPLNK = [V]CST_ANO Then
        For NI = 1 To maxtab(this.RTKO)
          If this.RTKO(NI) <> null and find(this.RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            IDXOPENUM = find(this.RTKO(NI).OPENUM, IOPENUM(1..INBOPENUM,1))                        # => IOPENUM(IDXOPENUM,3) give OPENUM in TARGET
            IOPELINEO = fmet TARGET.RTKO_GET_INDEX(IOPENUM(IDXOPENUM,3), IOPENUM(IDXOPENUM,4))     # Only to know if the operation has been copied in TARGET project
            If IOPELINEO > 0 Then
              For NE = 1 To maxtab(this.RTKO(NI).OPLNK)
                If this.RTKO(NI).OPLNK(NE) <> null and find(this.RTKO(NI).OPLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                  IDXOPENUM = find(this.RTKO(NI).OPLNK(NE).OPENUMLNK, IOPENUM(1..INBOPENUM,1))     # => IOPENUM(IDXOPENUM,3) give OPENUM in TARGET
                  IOPELINET = fmet TARGET.RTKO_GET_INDEX(IOPENUM(IDXOPENUM,3), IOPENUM(IDXOPENUM,4))
                  If IOPELINET > 0 Then
                    ILINE = fmet TARGET.RTKO(IOPELINEO).ADDLINE("OPLNK", [V]CST_ALASTPOS)
                    If ILINE = [V]CST_ANOTDEFINED Then
                      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RTKO(NI).OPLNK(NE).SETERROR("", mess(1006,2260,1), [V]CST_AERROR))
                      Break
                    Endif
                    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.RTKO(NI).OPLNK(NE).COPY(TARGET.RTKO(IOPELINEO).OPLNK(ILINE), TECCLA, TARGET.RTKO(IOPELINET).OPENUM))
                  Endif
                Endif
              Next NE
            Endif
          Endif
        Next NI
      Endif
    Endif
  Endif
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY
#Variable Instance TECCLA Using C_PJMACOPY
#Value Integer TECIDX
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TCACOD", AVOID.ACHAR))
  If TECCLA.TASK(TECIDX).TASFCY <> this.TASFCY Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.TASK(TECIDX).TASFCY, "TASFCY"))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASFCY", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#fmet TECCLA.GET_TASK_RECODIFIED(CLAFROM.TASPAE)", "TASPAE"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#fmet TECCLA.GET_TASK_RECODIFIED(CLAFROM.TASCOD)", "TASCOD"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#fmet TECCLA.GET_BUDGET_RECODIFIED(CLAFROM.PBUCOD)", "PBUCOD"))
  If TECCLA.TASK(TECIDX).TASNDES = "" or TECCLA.TASK(TECIDX).TASNDES = this.PIMPL.PIMDESAXX Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAXX", AVOID.ACHAR, "PIMPL", "PIMDESAXX", "KEYCONCAT", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAX1", AVOID.ACHAR, "PIMPL", "PIMDESAX1", "KEYCONCAT", AVOID.ACHAR))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.TASK(TECIDX).TASNDES, "PIMPL.PIMDESAXX"))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASSOR", AVOID.ACHAR))        # Issue X3-91329 - 2018-05-31 by FGR
  If TECCLA.TACDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASSTARTDT", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASENDDT", AVOID.ACHAR))
  Endif
  If TECCLA.TACDUEDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("DUEDAT", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASRESP", AVOID.ACHAR))
  #Copy all descriptions (CLOB)
  If TECCLA.TACDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASDESTEX", AVOID.ACHAR))
  Endif
  #Copy all comments (CLOB)
  If TECCLA.TACCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASCOMTEX", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">COPY", "TCHACTION"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("KEYCONCAT", "ORITAS"))
Return

# Issue X3-69372 - 2018-04-03 by FGR/SNGC : BEGIN
###################################################################################################
$TIMEENTRY
#Variable Instance PJMTIMEMP Using C_PJMTIMEMP
#Variable Instance TECPTETAS Using C_TECPTETAS
#Variable Instance LOGFILE Using C_ALOG
#Local Integer ARET_VALUE

Local Integer ILINERTKO
Local Integer ILINERAFFT
Local Decimal DHOURSRTKO
Local Decimal DHOURSRAFFT
Local Integer INBRAFFT
Local Decimal NSUMPOARMNQTY
Local Date DOPESTARTDT
Local Date DOPEENDDT

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TCHACTION <> "TIMEENTRY" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -----------------------------
  If TECPTETAS.IACTION = [V]CST_ADEL Then
    # When deleted line or when updated a line => this is a delete on the former one.
    If PJMTIMEMP.snapshot.OPENUM > 0 Then
      # Planned, consumed and remaining load
      ILINERTKO = fmet this.RTKO_GET_INDEX(PJMTIMEMP.snapshot.OPENUM, PJMTIMEMP.snapshot.OPESPLNUM)
      If ILINERTKO < 1 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("OPENUM", mess(268,2260,1), [V]CST_AERROR))
      Else
        this.RTKO(ILINERTKO).TCHACTION = "TIMEENTRY"
        this.RTKO(ILINERTKO).TCHOPESTRAN = 1
        INBRAFFT = fmet this.RTKO(ILINERTKO).RAFFT_COUNT()
        ILINERAFFT = fmet this.RTKO(ILINERTKO).RAFFT_GET_INDEX(PJMTIMEMP.CLB)
        DHOURSRTKO = PJMTIMEMP.snapshot.PTEQTY
        If PJMTIMEMP.snapshot.PTEUOM <> this.RTKO(ILINERTKO).OPEUOM2 Then
          Call CONVERT_QTY(PJMTIMEMP.ACTX, PJMTIMEMP.snapshot.PTEUOM, this.RTKO(ILINERTKO).OPEUOM2, DHOURSRTKO) From TRTX3_SYRA
        Endif
        If this.RTKO(ILINERTKO).CSMQTY < DHOURSRTKO Then
          this.RTKO(ILINERTKO).CSMQTY = 0
        Else
          this.RTKO(ILINERTKO).CSMQTY -= DHOURSRTKO
        Endif
        If this.RTKO(ILINERTKO).RMNQTY = 0 and (this.RTKO(ILINERTKO).EXTQTY - this.RTKO(ILINERTKO).CSMQTY) > 0 Then
          this.RTKO(ILINERTKO).RMNQTY = this.RTKO(ILINERTKO).EXTQTY - this.RTKO(ILINERTKO).CSMQTY
        Else
          If ILINERAFFT > 0 or (ILINERAFFT = 0 and this.RTKO(ILINERTKO).RMNQTY > fmet this.RTKO(ILINERTKO).RAFFT_SUM_POARMNQTY()) Then
            this.RTKO(ILINERTKO).RMNQTY += DHOURSRTKO
          Endif
        Endif
        # -----------------------------
        # Same project, same task, same operation, but not the deleted line ([F:PTE]PTESEQ <> PJMTIMEMP.PTESEQ).
        Local File PJMTIMEMP [PTE]
&             Where [F:PTE]OPPNUM = PJMTIMEMP.snapshot.OPPNUM and [F:PTE]PIMTASCOD = PJMTIMEMP.snapshot.PIMTASCOD and
&                   [F:PTE]OPENUM = PJMTIMEMP.OPENUM and [F:PTE]PTESEQ <> PJMTIMEMP.snapshot.PTESEQ
        Raz DOPESTARTDT
        Filter [PTE] Where [F:PTE]PTEDAT <= PJMTIMEMP.snapshot.PTEDAT Order By Key KEY0 = [F:PTE]PTEDAT Asc
        For [PTE]KEY0
          DOPESTARTDT = [F:PTE]PTEDAT
          Break
        Next
        Filter [PTE]
        DOPEENDDT = DOPESTARTDT
        Filter [PTE] Where [F:PTE]PTEDAT >= PJMTIMEMP.snapshot.PTEDAT Order By Key KEY0 = [F:PTE]PTEDAT Desc
        For [PTE]KEY0
          DOPEENDDT = [F:PTE]PTEDAT
          Break
        Next
        Filter [PTE]
        this.RTKO(ILINERTKO).OPESTARTDT = DOPESTARTDT
        this.RTKO(ILINERTKO).OPEENDDT = DOPEENDDT
      Endif
      # -----------------------------
      If ILINERAFFT > 0 Then
        this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).TCHACTION = "TIMEENTRY"
        DHOURSRAFFT = PJMTIMEMP.snapshot.PTEQTY
        If PJMTIMEMP.snapshot.PTEUOM <> this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POUOM Then
          Call CONVERT_QTY(PJMTIMEMP.ACTX, PJMTIMEMP.snapshot.PTEUOM, this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POUOM, DHOURSRAFFT) From TRTX3_SYRA
        Endif
        If this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY < DHOURSRAFFT Then
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY = 0
        Else
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY -= DHOURSRAFFT
        Endif
        If this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY = 0 and
&          (this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POASTDQTY - this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY) > 0
&       Then
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY += this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POASTDQTY - this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY
        Else
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY += DHOURSRAFFT
        Endif
      Endif
    Endif
  Else
    If this.TASDATB = [0/0/0] Then
      this.TASSTATE = 3
    Endif
    If this.TASDATB = [0/0/0] or (this.TASDATB <> [0/0/0] and this.TASDATB > PJMTIMEMP.PTEDAT) Then
      this.TASDATB = PJMTIMEMP.PTEDAT
    Endif
    # -----------------------------
    If PJMTIMEMP.OPENUM > 0 Then
      # Planned, consumed and remaining load
      ILINERTKO = fmet this.RTKO_GET_INDEX(PJMTIMEMP.OPENUM, PJMTIMEMP.OPESPLNUM)
      If ILINERTKO < 1 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("OPENUM", mess(268,2260,1), [V]CST_AERROR))
      Else
        this.RTKO(ILINERTKO).TCHACTION = "TIMEENTRY"
        this.RTKO(ILINERTKO).TCHOPESTRAN = 1
        INBRAFFT = fmet this.RTKO(ILINERTKO).RAFFT_COUNT()
        ILINERAFFT = fmet this.RTKO(ILINERTKO).RAFFT_GET_INDEX(PJMTIMEMP.CLB)
        DHOURSRTKO = PJMTIMEMP.PTEQTY
        If PJMTIMEMP.PTEUOM <> this.RTKO(ILINERTKO).OPEUOM2 Then
          Call CONVERT_QTY(PJMTIMEMP.ACTX, PJMTIMEMP.PTEUOM, this.RTKO(ILINERTKO).OPEUOM2, DHOURSRTKO) From TRTX3_SYRA
        Endif
        this.RTKO(ILINERTKO).CSMQTY += DHOURSRTKO
        If INBRAFFT = 0 or ILINERAFFT > 0 Then
          # If the user assigned
          If this.RTKO(ILINERTKO).RMNQTY < DHOURSRTKO Then
            this.RTKO(ILINERTKO).RMNQTY = 0
          Else
            this.RTKO(ILINERTKO).RMNQTY -= DHOURSRTKO
          Endif
        Else
          # If not
          NSUMPOARMNQTY = fmet this.RTKO(ILINERTKO).RAFFT_SUM_POARMNQTY()
          If (this.RTKO(ILINERTKO).RMNQTY - DHOURSRTKO) < NSUMPOARMNQTY Then
            [L]ARET_VALUE = fmet this.SETERROR("RMNQTY", func AFNC.MES1(mess(498,2260,1), num$(PJMTIMEMP.OPENUM)), [V]CST_AWARNING)
            this.RTKO(ILINERTKO).RMNQTY = NSUMPOARMNQTY
          Else
            If this.RTKO(ILINERTKO).RMNQTY < DHOURSRTKO Then
              this.RTKO(ILINERTKO).RMNQTY = 0
            Else
              this.RTKO(ILINERTKO).RMNQTY -= DHOURSRTKO
            Endif
          Endif
        Endif
        # -----------------------------
        If this.RTKO(ILINERTKO).OPESTARTDT = [0/0/0] or this.RTKO(ILINERTKO).OPESTARTDT > PJMTIMEMP.PTEDAT Then
          this.RTKO(ILINERTKO).OPESTARTDT = PJMTIMEMP.PTEDAT
        Endif
        If this.RTKO(ILINERTKO).OPEENDDT = [0/0/0] or this.RTKO(ILINERTKO).OPEENDDT < PJMTIMEMP.PTEDAT Then
          this.RTKO(ILINERTKO).OPEENDDT = PJMTIMEMP.PTEDAT
        Endif
        # -----------------------------
        If ILINERAFFT > 0 Then
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).TCHACTION = "TIMEENTRY"
          DHOURSRAFFT = PJMTIMEMP.PTEQTY
          If PJMTIMEMP.PTEUOM <> this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POUOM Then
            Call CONVERT_QTY(PJMTIMEMP.ACTX, PJMTIMEMP.PTEUOM, this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POUOM, DHOURSRAFFT) From TRTX3_SYRA
          Endif
          this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POACSMQTY += DHOURSRAFFT
          If this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY < DHOURSRAFFT Then
            this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY = 0
          Else
            this.RTKO(ILINERTKO).RAFFT(ILINERAFFT).POARMNQTY -= DHOURSRAFFT
          Endif
        Endif
      Endif
    Endif
  Endif
Return

#$TIMEENTRY
##Variable Instance PJMTIMEMP Using C_PJMTIMEMP : #
##Variable Instance TECPTETAS Using C_TECPTETAS : #
##Variable Instance LOGFILE Using C_ALOG : #
##Local Integer ARET_VALUE
#
#Local Integer ILINERTKO
#Local Integer ILINERAFFT
#Local Decimal DHOURSRTKO
#Local Decimal DHOURSRAFFT
#Local Integer INBRAFFT
#Local Decimal NSUMPOARMNQTY
#Local Integer IBOOLAUPD
#Local Date DOPESTARTDT
#Local Date DOPEENDDT
#
#  [L]ARET_VALUE = [V]CST_AOK
#  # -----------------------------
#  If this.TCHACTION <> "TIMEENTRY" Then
#    [L]ARET_VALUE = fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR)
#    Return
#  Endif
#  # -----------------------------
#  If this.TASDATB = [0/0/0] Then
#    this.TASSTATE = 3
#  Endif
#  If this.TASDATB = [0/0/0] or (this.TASDATB <> [0/0/0] and this.TASDATB > PJMTIMEMP.PTEDAT) Then
#    this.TASDATB = PJMTIMEMP.PTEDAT
#  Endif
#  # -----------------------------
#  IBOOLAUPD = PJMTIMEMP.ASTALIN = [V]CST_AUPD and (
#&             (PJMTIMEMP.PTEQTY <> PJMTIMEMP.snapshot.PTEQTY or PJMTIMEMP.PIMPBUCOD <> PJMTIMEMP.snapshot.PIMPBUCOD or
