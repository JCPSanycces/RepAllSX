###################################################################################################
$RTKO_COMPUTE_EXTAMT
#Local Decimal ARET_VALUE
# Issue X3-26843 - 2017-02-21 by SINGC

Local Integer NI

  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.RTKO)
