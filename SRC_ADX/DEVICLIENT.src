#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# DEVICLIENT : Devis clients                                            #
# --------------------------------------------------------------------- #
# Chargement des paramètres                                             #
#      Etat DEVICLIENT : Devis clients                                  #
#      Etat DEVTTC     : Devis clients TTC                              #
#########################################################################

$ACTION
Case ACTION
  When "OUVRE"   : Gosub OUVRE2
  When "INIPAR"  : Gosub INIPAR
  When "INIPAR2" : Gosub INIPAR
  When "CONTPRT" : Gosub CONTPRT
Endcase
Return

########################################################################

#-----------------------------------------#
# Contrôle destination (choix imprimante) #
# --------------------------------------- #
#  Préchargement du nombre de copies      #
#  Par défaut provient des destinations   #
#-----------------------------------------#
$CONTPRT
#------ Préchargement si contexte gestion des devis -----#
If GFONCTION="GESSQH" & clalev([M:SQH0])
  If !find([M:RPT]IMPRIME,0,1,3,4)
    # FGR 24/03/2014 : X3SUIVI97819 (début)
    If [M:SQH0]BPCORD <> [F:BPC]BPCNUM Then
     Read [F:BPC]BPC0=[M:SQH0]BPCORD
    Endif
    # FGR 24/03/2014 : X3SUIVI97819 (début)
    #Fq73266-Gbn-uniquement s'il y a un modèle d'impression sur le tiers
    If [F:BPC]TPMCOD<>""
      [M:RPT]NBRCPY=max([M:SQH0]COPNBR,1) : # Nombre de copies
      Affzo [M:RPT]NBRCPY   # FGR 24/03/2014 : X3SUIVI97819
    Endif
  Else
    [M:RPT]NBRCPY=0 : # pas de copie pour prévisu, message, fichier
    Grizo [M:RPT]NBRCPY : Affzo [M:RPT]NBRCPY #Fq73266
  Endif
Endif
#-----
Return

#########################################################################

$OUVRE2
If GAUSCRMF<>"" & GAUSCRMA=2 & (dim(GAUSCRMROL)<1 | (dim(GAUSCRMROL)>0 & GAUSCRMROL<>1))
  GBIDI2=find("REP",[M:RPT]PARTYP)
  If GBIDI2
    [M:RPT]VALEUR1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALEUR2(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT2(GBIDI2-1)=GAUSCRMF
    Affzo [RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
  Endif
Endif
Return

$INIPAR
If GAUSCRMF<>"" & GAUSCRMA=2 & [M:RPT]PARTYP(nolign-1)="REP"  mkstat=2 : Endif
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local Integer IMPR
# -- DEVICLIENT2
Local Date    DATREF

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

If func AFNC.ACTIV('KPO')>0
  CKPO = 1
Endif

[L]CRITERE  = "1=1"
[L]CRITERE2 = "1=1"
[L]CRITERE3 = "1=1"
[L]CRITERE4 = "1=1" :#--CPO 104383 Nouveau : "Type de devis"

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Call GETPARAM ([L]PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
#  [L]VALEUR = right$([L]PARAMETRE(I),J+1)

  Case [L]PARAM
   When "X3ETA"       : [L]ETAT = [L]VALEUR
   When "__REQUETE"   : [L]NUMREQ = val([L]VALEUR)
   When "sitedeb"     : [L]CRITERE -= "& SALFCY>='"+[L]VALEUR+"'"
   When "sitefin"     : [L]CRITERE -= "& SALFCY<='"+[L]VALEUR+"'"
   When "clientdeb"   : [L]CRITERE -= "& BPCORD>='"+[L]VALEUR+"'"
   When "clientfin"   : [L]CRITERE -= "& BPCORD<='"+[L]VALEUR+"'"
   When "devisdeb"    : [L]CRITERE -= "& SQHNUM>='"+[L]VALEUR+"'"
   When "devisfin"    : [L]CRITERE -= "& SQHNUM<='"+[L]VALEUR+"'"

# -- DEVICLIENT2
   When "datedeb"     : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                      val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                        [L]CRITERE -= "& QUODAT >=["+format$(GFMD,[L]DATREF)+']'
   When "datefin"     : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                      val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                        [L]CRITERE -= "& QUODAT <=["+format$(GFMD,[L]DATREF)+']'
   When "devdeb"      : [L]CRITERE -= "& CUR>='"+[L]VALEUR+"'"
   When "devfin"      : [L]CRITERE -= "& CUR<='"+[L]VALEUR+"'"
# -- TROP DE CRITèRES PASSAGE DE CRITERE (250) à (250)(1..2)
   When "datevaldeb"  : If  val(left$([L]VALEUR,4))>1600  # X3-113773_Report_DEVICLIENT2 (JUCON 26/10/18)
                          [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                      val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                          If [L]DATREF > gdat$(01,01,1800)
#                          [L]CRITERE3 -= "& VLYDAT >=["+format$(GFMD,[L]DATREF)+']'
#                          Fiche 47113 - SYMEU
                            [L]CRITERE3 -= "& ((VLYDAT >=["+format$(GFMD,[L]DATREF)+']'
&                                        +" & VLYDAT > [01/01/1800]) | VLYDAT < [01/01/1800])"
                          Endif
                        Endif                        # X3-113773_Report_DEVICLIENT2 (JUCON 26/10/18)
   When "datevalfin"  :   If  val(left$([L]VALEUR,4))>1600  # X3-113773_Report_DEVICLIENT2 (JUCON 26/10/18)
                            [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                      val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE3 -= "& VLYDAT <=["+format$(GFMD,[L]DATREF)+']'
                          Endif                     # X3-113773_Report_DEVICLIENT2 (JUCON 26/10/18)
   When "etatdevisdeb" : [L]CRITERE3 -= "& QUOSTA>="+num$([L]VALEUR)
   When "etatdevisfin" : [L]CRITERE3 -= "& QUOSTA<="+num$([L]VALEUR)

   When "codimp"      : [L]CRITERE -= "& QUOPRN="+num$([L]VALEUR)
                        [L]IMPR = val([L]VALEUR)
   When "numedt"      : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"         : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"        : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "euro"        : [L]PARAMETRE(I) = "euro="+GEURO
   When "repdeb"      : [L]VALDEB=[L]VALEUR
   When "repfin"      : If [L]VALEUR=""  [L]VALEUR="zzzzzzzzzz" : Endif
                       # Bug 48499 V5 SEGAY
                        If [L]VALDEB<=" " Then
                           [L]CRITERE2 -= "& (((REP(0)<=' ' | REP(0)>='"+[L]VALDEB+"') & REP(0)<='"+[L]VALEUR+"')"
                           [L]CRITERE2 -= "|  ((REP(1)<=' ' | REP(1)>='"+[L]VALDEB+"') & REP(1)<='"+[L]VALEUR+"'))"
                        Else
                           [L]CRITERE2 -= "& ((REP(0)>='"+[L]VALDEB+"' & REP(0)<='"+[L]VALEUR+"')"
                           # ACA (2010-04-16) Bug 63058 : Devis sans Rep
                           [L]CRITERE2 -= "|  (REP(1)>='"+[L]VALDEB+"' & REP(1)<='"+[L]VALEUR+"')"
                           [L]CRITERE2 -= "|  (REP(0)<=' ' & REP(1)<=' '))"
                        Endif
   When "_PrinterCopies" : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"
   When "typedeb"        : [L]CRITERE4 -= "& SQHTYP>='"+[L]VALEUR+"'"      :#--CPO 104383 Nouveau : "Type de devis"
   When "typefin"        : If [L]VALEUR=""  [L]VALEUR="zzzzzzzzzz" : Endif :#--CPO 104383 Nouveau : "Type de devis"
                           [L]CRITERE4 -= "& SQHTYP<='"+[L]VALEUR+"'"      :#--CPO 104383 Nouveau : "Type de devis"
   When "avenantdeb"      : [L]CRITERE4 -= "& REVNUM>="+num$([L]VALEUR)
   When "avenantfin"      : [L]CRITERE4 -= "& REVNUM<="+num$([L]VALEUR)
 Endcase
 Endif
Next

  Look [ARM]ARM0=[L]NUMREQ;GUSER;[F:ARP]RPTCOD;1   # FGR 22/10/2015 : X3SUIVI111379
  If fstat Then                                    # FGR 22/10/2015 : X3SUIVI111379
    Filter [F:SQH] Where evalue([L]CRITERE) & evalue([L]CRITERE2) & evalue([L]CRITERE3) & evalue([L]CRITERE4) :#--CPO 104383 Nouveau : "Type de devis"
    Gosub TRT_SQH
  Endif                                            # FGR 22/10/2015 : X3SUIVI111379
End

###################################################################
###################################################################

$TRT_SQH
Raz WNUMLIG
Default File [SQH]

For [F:SQH]SQH0

   Raz WNUMCOP
   Call DEBTRANS From GLOCK
   If [L]IMPR = 1 Gosub TR1
   Else           Gosub TR2
   Endif
Next
If CKPO = 1 & [L]CKPOELEM <> 1 : Call ECR_TRACE(mess(201,7711,1),1) From GESECRAN : GOK = 0  : Endif

Return

##########################################################################

$TR1
Trbegin [SQH] , [ARM], [TRPT]


# Mise à jour table entête devis si demande d'impression
If [L]IMPR = 1
 Readlock [F:SQH]SQH0 Curr
 If fstat = 1 : GOK = -1 : GLOCK = "$SQUOTE" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("SQH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:SQH]QUOPRN = 2
 Rewrite [F:SQH]
 If fstat=1
  GOK=-1 : GLOCK="$SQUOTE"-[F:SQH]SQHNUM
  Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("SQUOTE",[F:SQH]SQHNUM) From GLOCK : Goto AB_TR1
 Endif
Endif

#Création de l'enregistrement dans la table AREPORTM

Local Integer INBCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
 WNUMLIG      += 1
 WNUMCOP      += 1
 Raz [F:ARM]
 [F:ARM]USR     = GUSER
 [F:ARM]RPTCOD  = [F:ARP]RPTCOD
 [F:ARM]NUMREQ  = [L]NUMREQ
 [F:ARM]NUMLIG  = WNUMLIG
 [F:ARM]NUMCOP  = WNUMCOP
 [F:ARM]CLEA1   = [F:SQH]SQHNUM
 [F:ARM]CREDAT  = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
Next INBCOP

#RMA 18/11/2015 - 101785
If CKPO = 1
  Gosub ALIM_TMPSRPT
  If GOK = 0 : Goto AB_TR1 : Endif
Endif

Commit

Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return


##########################
$TR2
Trbegin [ARM], [TRPT]

#Création de l'enregistrement dans la table AREPORTM

Local Integer INBCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
 WNUMLIG      += 1
 WNUMCOP      += 1
 Raz [F:ARM]
 [F:ARM]USR     = GUSER
 [F:ARM]RPTCOD  = [F:ARP]RPTCOD
 [F:ARM]NUMREQ  = [L]NUMREQ
 [F:ARM]NUMLIG  = WNUMLIG
 [F:ARM]NUMCOP  = WNUMCOP
 [F:ARM]CLEA1   = [F:SQH]SQHNUM
 [F:ARM]CREDAT  = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
Next INBCOP

#RMA 18/11/2015 - 101785
If CKPO = 1
  Gosub ALIM_TMPSRPT
  If GOK = 0 : Goto AB_TR2 : Endif
Endif

Commit
Return

$ROLL_TR2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

###########################################################################

$OUVRE
Local File SQUOTE [SQH], AREPORTM [ARM]
Local File TMPSRPT    [TRPT]

Return

$DECLARE
Local Char    CRITERE(255), CRITERE2(255), CRITERE3(255), PARAM(30), VALEUR(30), VALDEB(30), ETAT(15)
Local Char    CRITERE4(255) :#--CPO 104383 Nouveau : "Type de devis"
Local Integer WNUMLIG, WNUMCOP, NUMREQ
Local Integer CKPO     : [L]CKPO     = 0
Local Integer CKPOELEM : [L]CKPOELEM = 0
Return
#########################################################################
#########################################################################
$ALIM_TMPSRPT

Raz [F:TRPT]

[F:TRPT] = [F:ARM]
[F:TRPT]VCRNUM = [F:SQH]SQHNUM

Write [F:TRPT]
If fstat : GOK=0 : Call FSTA("TRPT") From GLOCK : Else : [L]CKPOELEM = 1 Endif

Return
#########################################################################
#########################################################################

