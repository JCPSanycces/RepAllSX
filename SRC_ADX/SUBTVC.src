#Endif

End


########################################
Subprog AS_FLD1(VALEUR)
Variable Char    VALEUR()
If [M]TBL1="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD2(VALEUR)
Variable Char    VALEUR()
If [M]TBL2= "" or [M]FLD1="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD3(VALEUR)
Variable Char    VALEUR()
If [M]TBL3= "" or [M]FLD2="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD4(VALEUR)
Variable Char    VALEUR()
If [M]TBL4= "" or [M]FLD3="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD5(VALEUR)
Variable Char    VALEUR()
If [M]TBL5= "" or [M]FLD4="" : mkstat = 1 : End : Endif
End

##############################################################

Subprog AM_FLD1(VALEUR)
Variable Char    VALEUR()
Local Integer IJL : IJL=1
Goto AM_FLD

Subprog AM_FLD2(VALEUR)
Variable Char    VALEUR()
Local Integer IJL : IJL=2
Goto AM_FLD

Subprog AM_FLD3(VALEUR)
Variable Char    VALEUR()
Local Integer IJL : IJL=3
Goto AM_FLD

Subprog AM_FLD4(VALEUR)
Variable Char    VALEUR()
Local Integer IJL : IJL=4
Goto AM_FLD

Subprog AM_FLD5(VALEUR)
Variable Char    VALEUR()
Local Integer IJL : IJL=5
Goto AM_FLD

$AM_FLD
GJL_NOMFLD=VALEUR
Gosub DES_FLD From SUBTVC
Assign ("[M]DES"+num$(IJL)) With GJL_DESFLD
Case IJL
     When 1   Affzo [M]DES1
     When 2   Affzo [M]DES2
     When 3   Affzo [M]DES3
     When 4   Affzo [M]DES4
     When 5   Affzo [M]DES5
Endcase
If VALEUR="" & IJL<5
  Case IJL
    When 1 : Effzo [TVC1]DES2, DES3, DES4, DES5
    When 2 : Effzo [TVC1]DES3, DES4, DES5
    When 3 : Effzo [TVC1]DES4, DES5
    When 4 : Effzo [TVC1]DES5
  Endcase
Endif
End

##############################################################
Subprog C_FLD1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
Goto C_FLD

Subprog C_FLD2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
Goto C_FLD

Subprog C_FLD3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
Goto C_FLD

Subprog C_FLD4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
Goto C_FLD

Subprog C_FLD5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
Goto C_FLD

$C_FLD
If VALEUR=""
 If [M]NBTBL<>0
  Case I
   When 1 : [M]TBL1 = "" : Affzo TBL1
   When 2 : [M]TBL2 = "" : Affzo TBL2
   When 3 : [M]TBL3 = "" : Affzo TBL3
   When 4 : [M]TBL4 = "" : Affzo TBL4
   When 5 : [M]TBL5 = "" : Affzo TBL5
  Endcase
 Endif
 End
Endif
VALEUR = toupper(VALEUR)
#----- Interdire les champs non significatifs réservés aux formules -----#
If find(VALEUR,"AMTNOTLIN","AMTTAXLIN1","AMTNOT","AMTTAX1","AMTBAS","AMTBAS1","AMTBAS2","QTY","QTYSTU")
  GMESSAGE=mess(555,199,1) : mkstat=1 : End
Endif
#-----
Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)
K = instr(1,VALEUR,"(")
If K
 DIME = val(right$(VALEUR,K+1))
 ZONE = left$(VALEUR,K-1)
Else
 DIME = 0
 ZONE = VALEUR
Endif

Read [ATZ]CODZONE = evalue("[M]TBL"+num$(I));ZONE
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
If [F:ATZ]CODTYP="AXX"
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat & [F:ATY]TYPTYP>8
 GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : End
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
End

