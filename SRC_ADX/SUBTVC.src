# Call LEC_TVT_LEG([M:TVC1]LEG,VALEUR ,WRET)    From TRTLECLEG
# Call LEC_TVB_LEG([M:TVC1]LEG,[M:TVC1]VACBPR,WRET) From TRTLECLEG
# Call LEC_TVI_LEG([M:TVC1]LEG,[M:TVC1]VACITM,WRET) From TRTLECLEG
#
# #-- mess(92,187 : Groupes sociétés/sites différents
# If [F:TVB]SOC<>"" & [F:TVT]GRP<>"" & [F:TVB]SOC<>[F:TVT]GRP
#    GMESSAGE=mess(92,187,1) + ':' - [F:TVT]GRP - '(' + mess(39,105,1) - VALEUR + ')'+ '<>'   : #-- mess 39,105  --> Taxe
#    GMESSAGE+= [F:TVB]SOC -  '(' + mess(272,107,1) - [M:TVC1]VACBPR + ')' : mkstat=2 :  End  : #-- mess 272,107 --> Régime de taxe
# Endif
#
# If [F:TVT]GRP<>"" & [F:TVI]SOC<>"" & [F:TVT]GRP<>[F:TVI]SOC
#    GMESSAGE=mess(92,187,1) + ':' - [F:TVT]GRP - '(' + mess(39,105,1) - VALEUR + ')'+ '<>'   : #-- mess 39,105  --> Taxe
#    GMESSAGE+= [F:TVI]SOC - '(' + mess(210,183,1) - [M:TVC1]VACBPR + ')' : mkstat=2 : End    : #-- mess 210,183  --> Niveau de taxe
