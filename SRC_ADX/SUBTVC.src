## Etiquette ajoutée par le superviseur (écran TVC1) 19/12/2012 15:16:50 (CPO)
######################################################################################
Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
GGRPFCY = VALEUR :#--CPO 71937
End


######################################################################################
######################################################################################
######################################################################################
#--CPO 71937 Il faut un sous-pro de contrôle même si pas de type de donnée
#--Le sous-pro est appelé afin de contrôler la cohérence d'une détermination par rapport aux paramètres renséignés
#--Exp : pour le TRT_RECHVATCOD de TRTX3
# Control
Subprog CONTTVC(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer 	 WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTVC" | COD="" : End : Endif

If clalev([F:TVC]) =0 : Local File TABVAC 	[TVC]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif :#--CPO 71937

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		If [F:FCY]FCY<>[L]FCY
			Read [F:FCY]FCY0=[L]FCY
			If fstat : Raz [F:FCY] Endif
		Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		If [F:CPY]CPY<>[L]CPY
			Read [F:CPY]CPY0=[L]CPY
			If fstat : Raz [F:CPY] Endif
		Endif
		[L]LEG=[F:CPY]LEG
	Endif
Endif
#--/CPO

If LEG<>""
 Read [TVC]TVC0=COD;LEG
 If fstat
  Read [TVC]TVC0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TVC]TVC0(1)=COD
 If !fstat
  LEG = [F:TVC]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TVC] Where COD=[L]COD
 Look [TVC]TVC0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TVC]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVACBPR, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TVC]GRP<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TVC]GRP
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVC]GRP<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TVC]GRP : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TVC]GRP;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TVC]GRP : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVC]GRP<>"" and LEG<>""
	Call CTLGFYLEG([F:TVC]GRP,LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:TVC]LEG<>""
	Call CTLGFYLEG(GROUPE,[F:TVC]LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If GROUPE<>""
  If CPY="" & FCY="" & [F:TVC]GRP<>"" & [F:TVC]GRP<>GROUPE
  		#--Les groupes doivent avoir au moins une société en commun
  		Gosub CTLGFYGRP
			If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TVC",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TVC",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End
#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

Return

##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:TVC1]COD
	WLEG =[M:TVC1]LEG

  Call CTL_ML_CONSISTENCY("TVC", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return

$CHECK_CONSISTENCY
	Local Integer WRET

	If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTVC il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTVC"
    #--Cohérence [TVC] et paramètres
    Call CONTTVC(P_CODE,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVC
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  Endif

  #--Cohérence [TVC]VACBPR et paramètres
  Call CONTTVB([TVC]VACBPR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVB
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

  #--Cohérence [TVC]VACITM et paramètres
  Call CONTTVI([TVC]VACITM,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVI
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

  #--Cohérence [TVC]VAT et paramètres
  Call CONTTVT([TVC]VAT,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVT
  If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	If clalev([F:TVC])=0 : Local File TABVAC    [TVC] : Endif
	If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif
	If clalev([F:TVI])=0 : Local File TABVACITM [TVI] : Endif
	If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif

  Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTVC il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTVC" and ( [F:TVC]COD<>P_CODE | find([F:TVC]LEG,P_LEG,"")=0 )
    If P_LEG<>""
     Read [TVC]TVC0=P_CODE;P_LEG
     If fstat
      Read [TVC]TVC0=P_CODE;""
     Else
      #CAS = 2 : # P_LEGislation isn't empty
     Endif
    Else
     Read [TVC]TVC0(1)=P_CODE
     If !fstat
      P_LEG = [F:TVC]LEG
      #CAS = 2
     Endif
    Endif
    If fstat
     Filter [TVC] Where COD=P_CODE
     Look [TVC]TVC0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = P_CODE-":"-mess(23,100,1)
     Endif
     Filter [TVC]
     VSTATUS=99 : Return
    Endif
	Endif

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:TVC]LEG<>"" and P_LEG<>[F:TVC]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TVC]LEG :# "Législations différentes"
		Return
	Endif

  P_LEG=[F:TVC]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

    If [F:TVC]VACBPR<>""
    	For [TVB] Where VACBPR=[F:TVC]VACBPR
    		If [F:TVB]LEG<>"" and find([F:TVB]LEG,LEGS)=0
    			LEGS(I) = [F:TVB]LEG
    			I += 1
    		Endif
    	Next
    Endif

		If [F:TVC]VACITM<>""
  		For [TVI] Where VACITM=[F:TVC]VACITM
  			If [F:TVI]LEG<>"" and find([F:TVI]LEG,LEGS)=0
  				LEGS(I) = [F:TVI]LEG
  				I += 1
  			Endif
  		Next
  	Endif

		If [F:TVC]VAT<>""
  		For [TVT] Where VAT=[F:TVC]VAT
  			If [F:TVT]LEG<>"" and find([F:TVT]LEG,LEGS)=0
  				LEGS(I) = [F:TVT]LEG
  				I += 1
  			Endif
  		Next
		Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du Régime de taxes
  	If [F:TVC]VACBPR<>""
    	Call LEC_TVB_LEG(LEGS(I),[F:TVC]VACBPR,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TVB] :#--On continue pour les autres et on ne tient pas compte de ce dernier
		Endif

  	#--Lecture de la Nature de taxes
  	If [F:TVC]VACITM<>""
    	Call LEC_TVI_LEG(LEGS(I),[F:TVC]VACITM,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TVI] :#--On continue pour les autres et on ne tient pas compte de ce dernier
    Endif

  	#--Lecture de la Taxe
  	If [F:TVC]VAT<>""
    	Call LEC_TVT_LEG(LEGS(I),[F:TVC]VAT,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TVT] :#--On continue pour les autres et on ne tient pas compte de ce dernier
    Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:TVC]GRP<>"" or [F:TVB]SOC <>"" or [F:TVI]SOC<>"" or [F:TVT]GRP<>""

      GROUPES = NewInstance [GRPTVC] With C_GRPCOLL

      RET= fmet GROUPES.GROUPADD([F:TVC]GRP)
      RET= fmet GROUPES.GROUPADD([F:TVB]SOC)
      RET= fmet GROUPES.GROUPADD([F:TVI]SOC)
      RET= fmet GROUPES.GROUPADD([F:TVT]GRP)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.AllocGrp

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.AllocGrp

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:TVC] Where find(LEG,"",PACTUAL_LEG)>0

	For [F:TVC]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [TVC] et paramètres
    Call CONTTVC([F:TVC]COD,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVC
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

  	If VSTATUS=0
      #--Cohérence [TVC]VACBPR et paramètres
      Call CONTTVB([TVC]VACBPR,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVB
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

  	If VSTATUS=0
      #--Cohérence [TVC]VACITM et paramètres
      Call CONTTVI([TVC]VACITM,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVI
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

  	If VSTATUS=0
      #--Cohérence [TVC]VAT et paramètres
      Call CONTTVT([TVC]VAT,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTVT
      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:TVC]COD
			P_LEG =[F:TVC]LEG
			Break
		Endif

	Next

	Filter [F:TVC]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return
