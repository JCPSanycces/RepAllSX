############################################################
Subprog AV_VAL1(VALEUR)
Variable Char VALEUR
Local Integer I
I = 1
Goto AV_VAL

Subprog AV_VAL2(VALEUR)
Variable Char VALEUR
Local Integer I
I = 2
Goto AV_VAL

Subprog AV_VAL3(VALEUR)
Variable Char VALEUR
Local Integer I
I = 3
Goto AV_VAL

Subprog AV_VAL4(VALEUR)
Variable Char VALEUR
Local Integer I
I = 4
Goto AV_VAL

Subprog AV_VAL5(VALEUR)
Variable Char VALEUR
Local Integer I
I = 5
Goto AV_VAL

$AV_VAL
Local Char    CHAMP(20) , TABLE(GLONATB) , FORMA(30) , CAR(1) , OPTION(10) , ZONE(GLONAVA)
Local Integer NOLIB , K , LONG , TABDIV
Case I
 When 1 : CHAMP = [M]FLD1 : TABLE = [M]TBL1
 When 2 : CHAMP = [M]FLD2 : TABLE = [M]TBL2
 When 3 : CHAMP = [M]FLD3 : TABLE = [M]TBL3
 When 4 : CHAMP = [M]FLD4 : TABLE = [M]TBL4
 When 5 : CHAMP = [M]FLD5 : TABLE = [M]TBL5
Endcase
K = instr(1,CHAMP,"(")
If K
 ZONE = left$(CHAMP,K-1)
Else
 ZONE = CHAMP
Endif

If ZONE=""
 FORMA = "Kf:15X"
Else
 Read [ATZ]CODZONE = TABLE;ZONE
 If [F:ATZ]CODTYP="SAT"
   If func AFNC.ACTIV("KAG") & [M:TVC1]LEG="ARG"
     [F:ATZ]CODTYP="ADI"
   Else
     GFMT="K:"+num$(GLONSAT)+"X"
   Endif
 Endif
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 NOLIB  = 0
 TABDIV = 0
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    NOLIB = [F:ATY]NOLIB
   Else
    NOLIB = [F:ATZ]NOLIB
   Endif
   FORMA = "Nf:2#"
  When 7
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   If LONG>20 : LONG = 20 : Endif
   OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
   If instr(1,OPTION,"C")
    CAR = "d"
   Elsif instr(1,OPTION,"A")
    CAR = "d"
   Else
    CAR = "X"
   Endif
   FORMA = "Kf:"+num$(LONG)+CAR
   If [F:ATY]OBJLIEN="ADI"
    If ZONE="TSICOD"
      TABDIV = 20
    Else
      TABDIV = val([F:ATZ]EXPLIEN)
    Endif
   Endif
  When 8
   FORMA = "Df:"+GFMDAT
  When 2,3
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
  When 4
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:15F"
 Endcase
Endif
Case I
 When 1 : [M]FMT1 = [F:ATY]CODTYP : [M]NOLIB1 = NOLIB
          If TABDIV<>0 : [M]SUPP1 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP1 = "" : Endif
 When 2 : [M]FMT2 = [F:ATY]CODTYP : [M]NOLIB2 = NOLIB
          If TABDIV<>0 : [M]SUPP2 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP2 = "" : Endif
 When 3 : [M]FMT3 = [F:ATY]CODTYP : [M]NOLIB3 = NOLIB
          If TABDIV<>0 : [M]SUPP3 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP3 = "" : Endif
 When 4 : [M]FMT4 = [F:ATY]CODTYP : [M]NOLIB4 = NOLIB
          If TABDIV<>0 : [M]SUPP4 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP4 = "" : Endif
 When 5 : [M]FMT5 = [F:ATY]CODTYP : [M]NOLIB5 = NOLIB
          If TABDIV<>0 : [M]SUPP5 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP5 = "" : Endif
Endcase
End

########################################################################

Subprog C_VAL1(VALEUR)
Variable Char VALEUR
Local Integer I
I = 1
Goto C_VAL

Subprog C_VAL2(VALEUR)
Variable Char VALEUR
Local Integer I
I = 2
Goto C_VAL

Subprog C_VAL3(VALEUR)
Variable Char VALEUR
Local Integer I
I = 3
Goto C_VAL

Subprog C_VAL4(VALEUR)
Variable Char VALEUR
Local Integer I
I = 4
Goto C_VAL

Subprog C_VAL5(VALEUR)
Variable Char VALEUR
Local Integer I
I = 5
Goto C_VAL

$C_VAL
Local Char TYP(3)
Local Char SUPP(10)
Case I
 When 1 : TYP = [M]FMT1 : SUPP=[M]SUPP1
 When 2 : TYP = [M]FMT2 : SUPP=[M]SUPP2
 When 3 : TYP = [M]FMT3 : SUPP=[M]SUPP3
 When 4 : TYP = [M]FMT4 : SUPP=[M]SUPP4
 When 5 : TYP = [M]FMT5 : SUPP=[M]SUPP5
Endcase
Call LECTURE("ATY",TYP,"") From CONTOBJ
If ([F:ATY]TYPTYP<7 or [F:ATY]TYPTYP=8) & VALEUR=""
 GMESSAGE = mess(10,123,1) : mkstat = 2 : End
# Zone obligatoire
Endif
If instr(1,VALEUR,'"')
 GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 : End
#  Caractère interdit
Endif
#-----
If TYP="ADI"
  If !clalev([F:ADI])  Local File ATABDIV [ADI] : Endif
  Local Integer WNUMTAB : WNUMTAB=val(evalue([L]SUPP))
  Read [ADI] CODE=WNUMTAB;VALEUR
  If fstat
    GMESSAGE=mess(2,26,1)-":"-VALEUR-mess(23,100,1) : mkstat=1 : End
  Endif
Endif
End

##############################################################
Subprog C_EXP1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer I , K , ER
 Local Char    CHAINE(80)
 For I=1 To [M]NBTBL
  Local File =[M]TBTBL(I)
 Next I
 Local File =[M]ATB : # Pour l'avoir par défaut
 Default [F] , [V] , [L] , [S]
 Onerrgo ERREXP
 ER = 0
 K = evalue([L]VALEUR)
 Onerrgo
 If ER
  mkstat = 2 : End
 Endif
Endif
End

$ERREXP
ER = errn
GMESSAGE = mess(37,124,1)+"\"+errmes$(ER)+"\"+errm
ER=1
# Expression incorrecte
Resume

#-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

###########################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'une détermination d'une taxe     #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File TABVAC [TVC1]
  Local File ATEXTRA    [AXX1]
Else
  Local File =[M]DOSORG+".TABVAC"   [TVC1]
  Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif

If [M]DOSDES=nomap
  Local File TABVAC     [TVC2]
  Local File ATEXTRA    [AXX2]
  Local File ACTIV      [ACV2]
Else
  Local File =[M]DOSDES+".TABVAC"    [TVC2]
  Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
  Local File =[M]DOSDES+".ATABDIV"   [ADI2]
  Local File =[M]DOSDES+".ACTIV"     [ACV2]
  Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2] : #-- car ADOSSIER uniquement sur dossier mère --#
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TRT_COPIE

Close Local File [TVC1], [TVC2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return


#-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
$TRT_COPIE
#-----------------------------------------------------#
# Transaction de copie d'une détermination d'une taxe #
#-----------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1

#If [M:TVC1]LEG<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; [M:TVC1]LEG
#  If fstat
#   Call MESSAGE ([M:TVC1]LEG - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
#
#  LG = instr(1, [M]DOSDES, "@")
#  If LG = 0 Then
#    SZDOSSIER = [M]DOSDES
#  Else
#    SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#  Endif
#  Read [ADS2]DOSSIER=SZDOSSIER
#    If !fstat Then
#      If !find([M:TVC1]LEG,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#        Call MESSAGE([M:TVC1]LEG - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#  Endif
#
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TVC2]TVC0=[M:TVC1]COD;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TVC2]

  Delete [TVC2] Where COD=[M:TVC1]COD & LEG = LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABVAC"-[M:TVC1]COD  - LEGDES : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TVC2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  If !fstat
    #--- copie des données
      For [TVC1]Where COD=[M:TVC1]COD & LEG = [M:TVC1]LEG
             [F:TVC2]=[F:TVC1]
             [F:TVC2]LEG = LEGDES
             If [M:TVC1]LEG=LEGDES
                 Call COPTEXTRA("TABVAC","DESAXX",[M:TVC1]COD,[M:TVC1]LEG) From ATEXTRA
                 Call COPTEXTRA("TABVAC","SHOAXX",[M:TVC1]COD,[M:TVC1]LEG) From ATEXTRA
             Else
                 Call COPTEXTRA1("TABVAC","DESAXX",[M:TVC1]COD,[M:TVC1]LEG,LEGDES) From TRTX3TEX
                 Call COPTEXTRA1("TABVAC","SHOAXX",[M:TVC1]COD,[M:TVC1]LEG,LEGDES) From TRTX3TEX
             Endif
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             If dim([F:TVC2]UPDUSR)>0 : [F:TVC2]UPDUSR = GUSER : Endif
             If dim([F:TVC2]UPDDAT)>0 : [F:TVC2]UPDDAT = date$ : Endif
             If fstat GOK=0 : Call FSTA("TVC2") From GLOCK : Endif
             Write [TVC2]
             If fstat
                GOK = 0 : Call FSTA("TVC2") From GLOCK : Break
             Endif
         Next
      Endif
      If   GOK<0    : Goto ROLL_COPIE
         Elsif !GOK : Goto AB_COPIE
      Endif
Commit

Return

#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif

Return
###########################################################################

