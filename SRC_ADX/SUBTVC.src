#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# SUBTVC : Gestion de la table de détermination des taxes              #
#          Utilisé par modules : Achats et Ventes                      #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:TVC]TABVAC                                   #
########################################################################

Call OBJET("TVC",GBIDC1,GBIDC2) From GOBJET
End

########################################################################
## Action  Objet
########################################################################

$ACTION

Case ACTION
     When "OUVRE"         : Gosub OUVRE
     When "AFFMASK"       : Gosub AFFMASK
     When "LIENS"         : Gosub LIENS
     When "RAZCRE"        : Gosub RAZCRE
     When "INICRE"        : Gosub INICRE
     When "INIMOD"        : Gosub INIMOD
     When "ANNULE"        : Gosub ANNULE
     When "FERME"         : Gosub FERME
     When "SETBOUT"       : Gosub SETBOUT
     #When "CHANGE"        : Call CHANGE_AXX ("TABVAC", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
     When "CHGCOD"        : Gosub CHGCOD
     When "AP_CHANGE"     : Gosub AP_CHANGE
    When Default
Endcase
Return

########################################################################

$OUVRE
#--CPO 71937
#Local  Char    SAV_GCURLEG(GLONADI)  : SAV_GCURLEG=GCURLEG
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
#--/CPO
#-----
Global Char    GJL_NOMFIC (GLONATB)  : GJL_NOMFIC="TAXLINK"
Global Char    GJL_NOMFLD (GLONAVA)
Global Char    GJL_DESFLD (GLONDES)
If dim(GVATTYP)<1  Global Integer GVATTYP : Endif
#-----
If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
Return

#-----------------------------------------------------------------------

$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [TVC1]LEG
  [M:TVC1]LEG=GDOSLEG(1)
  Affzo [TVC1]LEG : If dim([M:TVC1]ZLEG)>0  Affzo [TVC1]ZLEG : Endif
Endif
GCURLEG=[M:TVC1]LEG
Return

#-----------------------------------------------------------------------

$LIENS
Local Integer IJL
Local Integer IJL1
[M]ATB=GJL_NOMFIC  : [M]ABR="TLK"
[M]TBL1=GJL_NOMFIC : [M]TBL2=GJL_NOMFIC : [M]TBL3=GJL_NOMFIC : [M]TBL4=GJL_NOMFIC : [M]TBL5=GJL_NOMFIC
For IJL=0 To dim([F:TVC]FLD)-1
    If [F:TVC]FLD(IJL)="" : Break : Endif
    If IJL>0
       Assign ("[M]ANDOR"+num$(IJL+1)) With [F:TVC]ANDOR(IJL)
    Endif
    Assign ("[M]FLD"+num$(IJL+1))   With [F:TVC]FLD(IJL)
    Assign ("[M]OPE"+num$(IJL+1))   With [F:TVC]OPE(IJL)
    Assign ("[M]VAL"+num$(IJL+1))   With [F:TVC]VALS(IJL)
    Assign ("[M]VALI"+num$(IJL+1))  With [F:TVC]VALI(IJL)
    GJL_NOMFLD=[F:TVC]FLD(IJL) : Gosub DES_FLD
    Assign ("[M]DES"+num$(IJL+1))   With GJL_DESFLD
Next IJL
#MAE, bg 78739
#[M]EXPRESSION=[F:TVC]EXPTST
#MAE, bg 75444
[M]EXPTOT = [F:TVC]EXPTST
#MAE, bg 78739

Local Char ABR(GLONABR)
Gosub EXPRESSION From ASELOBJ
If [M]EXPRESSION<>""
   If len([M:TVC1]EXPTOT)>0  IJL1=1 : [M:TVC1]EXPTOT += " & ( "  Endif
   [M:TVC1]EXPTOT += [M]EXPRESSION
   If IJL1=1 : [M:TVC1]EXPTOT += " )" : Endif
Endif
#--CPO 80360 Pas la peine car le Gosub EXPRESSION from ASELOBJ
#--          rajoute le [M]EXP1 dans [M]EXPRESSION
#If [F:TVC]EXP1<>""
#   If len([M:TVC1]EXPTOT)>0  IJL1=1 : [M:TVC1]EXPTOT += " & ( "  Endif
#   [M:TVC1]EXPTOT += [F:TVC]EXP1
#   If IJL1=1 : [M:TVC1]EXPTOT += " )" : Endif
#Endif

Affzo [M]EXPTOT
GCURLEG=[M:TVC1]LEG
GVATTYP=[M:TVC1]VATTYP
Return

#-----------------------------------------------------------------------

$RAZCRE
[M]ATB=GJL_NOMFIC  : [M]ABR="TLK"
[M]TBL1=GJL_NOMFIC : [M]TBL2=GJL_NOMFIC : [M]TBL3=GJL_NOMFIC : [M]TBL4=GJL_NOMFIC : [M]TBL5=GJL_NOMFIC
Gosub GRILEG
[M:TVC1]VATTYP=1
GVATTYP=[M:TVC1]VATTYP
Return

#-----------------------------------------------------------------------
$INICRE
Local Integer IJL, IJL1
Local Integer I
Raz [F:TVC]ANDOR, [F:TVC]FLD, [F:TVC]OPE, [F:TVC]VALS, [F:TVC]VALI, [F:TVC]EXPTST
For IJL=0 To dim([F:TVC]FLD)-1
    If evalue("[M]FLD"+num$(IJL+1))="" : Break : Endif
    If IJL>0
       [F:TVC]ANDOR(IJL)= evalue("[M]ANDOR"+num$(IJL+1))
    Endif
    [F:TVC]FLD(IJL)  = evalue("[M]FLD"+num$(IJL+1))
    [F:TVC]OPE(IJL)  = evalue("[M]OPE"+num$(IJL+1))
    [F:TVC]VALS(IJL) = evalue("[M]VAL"+num$(IJL+1))
    [F:TVC]VALI(IJL) = evalue("[M]VALI"+num$(IJL+1))
Next IJL

# --- selection sur champ fixe LEG
If dim([M]LEG)>0 & [M]LEG<>""
   [F:TVC]EXPTST = '[F:TLK]LEG="'+[M]LEG+'"'
Else
   [F:TVC]EXPTST = ''
Endif

# --- selection sur champ fixe GRP
If dim([M]GRP)>0 & [M]GRP<>""
   If len([F:TVC]EXPTST)>0 : [F:TVC]EXPTST += " & " : Endif
   [F:TVC]EXPTST += 'find("'+[M]GRP+'",[F:TLK]GRP(0..[F:TLK]NBGRP-1))<>0'
Endif

# --- selection sur champ fixe VACBPR
If [M]VACBPR<>""
   If len([F:TVC]EXPTST)>0 : [F:TVC]EXPTST += " & " : Endif
   [F:TVC]EXPTST += '[F:TLK]VACBPR="'+[M]VACBPR+'"'
Endif

# --- selection sur champ fixe VACITM
If [M]VACITM<>""
   If len([F:TVC]EXPTST)>0 : [F:TVC]EXPTST += " & " : Endif
   [F:TVC]EXPTST += '[F:TLK]VACITM="'+[M]VACITM+'"'
Endif

#--CPO 80360 On raz le [M]EXP1 avant l'appel et on le remet après
#--[M]EXPRESSION alimenté par le Gosub EXPRESSION contiendra aussi le [M]EXP1
#--Il faut mettre dans [F:TVC]EXP2 uniquement le résultat des critères sur FLD(x)...
#--Donc => Raz EXP1 et restauration après alim de [TVC)EXP2
Local Char WSAVE_EXP1(250) : [L]WSAVE_EXP1 = [M]EXP1
Raz [M]EXP1
#--/CPO

# --- selection sur tableau
Local Char ABR(GLONABR)
Gosub EXPRESSION From ASELOBJ
#MAE, bg 75444, exptst ne contient plus la somme des deux expressions
#If [M]EXPRESSION<>""
#   If len([F:TVC]EXPTST)>0  IJL1=1 : [F:TVC]EXPTST += " & ( "  Endif
#   [F:TVC]EXPTST += [M]EXPRESSION
#   If IJL1=1 : [F:TVC]EXPTST += " )" : Endif
#Endif

#--CPO 80360
Raz [F:TVC]EXP2
If [M]EXPRESSION<>""
  [F:TVC]EXP2= [M]EXPRESSION
Endif
#--On remets le EXP1 et on le rajoute dans [M]EXPRESSION
[M]EXP1 = [L]WSAVE_EXP1
If [M]EXP1<>""
   If len([M]EXPRESSION)>0  IJL1=1 : [M]EXPRESSION += " & ( "  Endif
   [M]EXPRESSION += [M]EXP1
   If IJL1=1 : [M]EXPRESSION += " )" : Endif
Endif
#--/CPO

[M:TVC1]EXPTOT =  [F:TVC]EXPTST
If [M]EXPRESSION<>""
   If len([F:TVC]EXPTST)>0  IJL1=1 : [M:TVC1]EXPTOT += " & ( "  Endif
   [M:TVC1]EXPTOT += [M]EXPRESSION
   If IJL1=1 : [M:TVC1]EXPTOT += " )" : Endif
Endif

[M]EXPTST=[F:TVC]EXPTST

Affzo [M]EXPTST
Affzo [M]EXPTOT
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TVC1]DESAXX,"TABVAC","DESAXX",[M:TVC1]COD,[M:TVC1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TVC1]SHOAXX,"TABVAC","SHOAXX",[M:TVC1]COD,[M:TVC1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TVC]LANDESSHO)>0
   [F:TVC]LANDESSHO=GLANGUE+"~"+[M:TVC1]DESAXX+"~"+[M:TVC1]SHOAXX
Endif

#Gbn-Fq71937-Multileg
Local Integer RCOD
Call FILL_EMPTY_DES(nomap, "TABVAC", "DESAXX", [F:TVC]COD, [F:TVC]LEG, RCOD) From TRTX3TEX
Call FILL_EMPTY_DES(nomap, "TABVAC", "SHOAXX", [F:TVC]COD, [F:TVC]LEG, RCOD) From TRTX3TEX

#--CPO 71937 Contrôle global de cohérence avant enregistrement
Gosub CONTROLE_COHERENCE

Return

######################################################################
$AP_CHANGE
Call CHGTEXTRA("TABVAC","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABVAC","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

#-----------------------------------------------------------------------
$INIMOD
Gosub INICRE
Return

#-----------------------------------------------------------------------
$ANNULE
  # FGR 12/03/2015 : X3SUIVI106903 : IDENT2 is missing
  Delete [AXX]Where CODFIC="TABVAC" & IDENT1=[F:TVC]COD & IDENT2=[F:TVC]LEG
Return

#-----------------------------------------------------------------------
$FERME
#--CPO 71937
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#GCURLEG=SAV_GCURLEG
#--/CPO

If dim(GJL_NOMFIC)>0 : Kill GJL_NOMFIC : Endif
If dim(GJL_NOMFLD)>0 : Kill GJL_NOMFLD : Endif
If dim(GJL_DESFLD)>0 : Kill GJL_DESFLD : Endif
Return



#-----------------------------------------------------------------------
# Recherche du libellé du champ
$DES_FLD
Raz GJL_DESFLD
Read [F:ATZ]CODZONE = GJL_NOMFIC;GJL_NOMFLD
If !fstat
   Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOLONG
   If !fstat
      GJL_DESFLD=[F:ATX]TEXTE
   Endif
Endif
Return
#-----------------------------------------------------------------------
$SETBOUT
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
########################################################################
## Action  Champs
########################################################################

#----------------------------------#
# Après modification du flag actif #
#----------------------------------#
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer WRET:#--CPO 71937 TVT et multi-lég

If VALEUR=2 & [M:TVC1]VAT<>""
#--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG([M:TVC1]LEG,[M:TVC1]VAT,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #If [F:TVT]VAT<>[M:TVC1]VAT
  #  Read [TVT] TVT0=[M:TVC1]VAT : If fstat  Raz [F:TVT] : Endif
  #Endif
  #--/CPO

  #----- Contrôle que le code taxe est cohérent avec le type de taxe -----#
  If [F:TVT]VATTYP>0 & [F:TVT]VATTYP<>[M:TVC1]VATTYP
    GMESSAGE=[M:TVC1]VAT-mess(547,199,1)-mess([M:TVC1]VATTYP,232,1) : GERR=1 : mkstat=1 : End
  Endif
  #----- Contrôle que le code taxe est cohérent avec la législation -----#
  If [M:TVC1]LEG<>"" & [F:TVT]LEG<>"" & [F:TVT]LEG<>[M:TVC1]LEG
    GMESSAGE=[M:TVC1]VAT-mess(545,199,1)-[M:TVC1]LEG    : GERR=1 : mkstat=1 : End
  Endif
  #----- Contrôle que le code taxe est cohérent avec le régime -----#
  If [M:TVC1]VACBPR<>"" & [F:TVT]VATVAC<>"" & [F:TVT]VATVAC<>[M:TVC1]VACBPR
    GMESSAGE=[M:TVC1]VAT-mess(546,199,1)-[M:TVC1]VACBPR : GERR=1 : mkstat=1 : End
  Endif
Endif
#-----
End

#------------------------------------#
# Après modification du type de taxe #
#------------------------------------#
Subprog AM_VATTYP(VALEUR)
Variable Integer VALEUR
Local Integer WRET:#--CPO 71937 TVT et multi-lég

#----- Contrôle que le code taxe est cohérent avec le type de taxe -----#
If [M:TVC1]VAT<>""
#--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG([M:TVC1]LEG,[M:TVC1]VAT,WRET) From TRTLECLEG
  If WRET :  Raz [F:TVT] : Endif
  #If [F:TVT]VAT<>[M:TVC1]VAT
  #  Read [TVT] TVT0=[M:TVC1]VAT : If fstat  Raz [F:TVT] : Endif
  #Endif
  #--/CPO
  If [F:TVT]VATTYP>0 & [F:TVT]VATTYP<>VALEUR
    Local Integer OK
    Local Char    WMSG(80)
    WMSG=[M:TVC1]VAT-mess(547,199,1)-mess(VALEUR,232,1)+","-mess(948,196,1)
    OK=2 : Call AVERTIR(WMSG,OK) From GESECRAN
    If OK=1
      mkstat=1 : End
    Else
      Effzo [TVC1]VAT
    Endif
  Endif
Endif
#-----
GVATTYP=VALEUR
End

#--------------------------------------#
# Après modification de la législation #
#--------------------------------------#
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer WRET:#--CPO 71937 TVT et multi-lég
#----- Contrôle que le code taxe est cohérent avec la législation -----#
If VALEUR<>"" & [M:TVC1]VAT<>""
#--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG(VALEUR,[M:TVC1]VAT,WRET) From TRTLECLEG
  If WRET :  Raz [F:TVT] : Endif
  #If [F:TVT]VAT<>[M:TVC1]VAT
  #  Read [TVT] TVT0=[M:TVC1]VAT : If fstat  Raz [F:TVT] : Endif
  #Endif
  #--/CPO
  If [F:TVT]LEG<>"" & [F:TVT]LEG<>VALEUR
    GMESSAGE=[M:TVC1]VAT-mess(545,199,1)-VALEUR : GERR=1 : mkstat=1 : End
  Endif
Endif
#-----
GCURLEG=VALEUR
End

#-------------------------------------------#
# Après modification du groupe de sociétés  #
#-------------------------------------------#
Subprog AM_GRP(VALEUR)
Variable Char    VALEUR()
Local Integer WRET:#--CPO 71937 TVT et multi-lég
GGRPFCY = VALEUR :#--CPO 71937
If dim([F:TVT]GRP)<1  End : Endif
#----- Contrôle que le code taxe est cohérent avec la législation -----#
If VALEUR<>"" & [M:TVC1]VAT<>""
  #--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG([M:TVC1]LEG,[M:TVC1]VAT,WRET) From TRTLECLEG
  If WRET :  Raz [F:TVT] : Endif
  #If [F:TVT]VAT<>[M:TVC1]VAT
  #  Read [TVT] TVT0=[M:TVC1]VAT : If fstat  Raz [F:TVT] : Endif
  #Endif
  #--/CPO
  If [F:TVT]GRP<>"" & [F:TVT]GRP<>VALEUR
    GMESSAGE=[M:TVC1]VAT-mess(548,199,1)-VALEUR : GERR=1 : mkstat=1 : End
  Endif
Endif
#-----
End

#--------------------------------------#
# Après modification du régime de taxe #
#--------------------------------------#
Subprog AM_VACBPR(VALEUR)
Variable Char    VALEUR()
Local Integer WRET:#--CPO 71937 TVT et multi-lég
#----- Contrôle que le code taxe est cohérent avec le régime -----#
If VALEUR<>"" & [M:TVC1]VAT<>""
  #--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG([M:TVC1]LEG,[M:TVC1]VAT,WRET) From TRTLECLEG
  If WRET :  Raz [F:TVT] : Endif
  #If [F:TVT]VAT<>[M:TVC1]VAT
  #  Read [TVT] TVT0=[M:TVC1]VAT : If fstat  Raz [F:TVT] : Endif
  #Endif
  #--/CPO
  If [F:TVT]VATVAC<>"" & [F:TVT]VATVAC<>VALEUR
    GMESSAGE=[M:TVC1]VAT-mess(546,199,1)-VALEUR : GERR=1 : mkstat=1 : End
  Endif
Endif
#-----
End

#------------------------#
# Contrôle sur code taxe #
#------------------------#
Subprog C_VAT(VALEUR)
Variable Char    VALEUR()
Local Integer WRET:#--CPO 71937 TVT et multi-lég

#--CPO 71937 TVT et multi-lég
If VALEUR<>""
  Call LEC_TVT_LEG([M:TVC1]LEG,VALEUR,WRET) From TRTLECLEG
  If WRET
  	Raz [F:TVT]
  	#Call MESSAGE(VALEUR-mess(609,199,1)+"."-mess(610,199,1)) From GESECRAN
  Endif
  If [F:TVT]VAT<>""
  #--/CPO
    If [M:TVC1]LEG<>"" | [M:TVC1]VACBPR<>""
      #--CPO 71937 TVT et multi-lég
      #If [F:TVT]VAT<>VALEUR
      #  Read [TVT] TVT0=VALEUR : If fstat  Raz [F:TVT] : Endif
      #Endif
      If [F:TVT]VATTYP>0 & [M:TVC1]VATTYP<>[F:TVT]VATTYP
        GMESSAGE=VALEUR-mess(547,199,1)-mess([M:TVC1]VATTYP,232,1) : GERR=1 : mkstat=1 : End
      Endif
      If [M:TVC1]LEG<>"" & [F:TVT]LEG<>"" & [M:TVC1]LEG<>[F:TVT]LEG
        GMESSAGE=VALEUR-mess(545,199,1)-[M:TVC1]LEG    : GERR=1 : mkstat=1 : End
      Endif
      If [M:TVC1]VACBPR<>"" & [F:TVT]VATVAC<>"" & [M:TVC1]VACBPR<>[F:TVT]VATVAC
        GMESSAGE=VALEUR-mess(546,199,1)-[M:TVC1]VACBPR : GERR=1 : mkstat=1 : End
      Endif
    Endif
  Endif
Endif

#--71937 CPO Contrôle de cohérence croisé à revoir (1 soc commune)
#If VALEUR <> ''
# #-- 71937 Coherence de groupe & Multi-lég
# Local Integer WRET
# If !clalev([F:TVT])  Local File TABVAT    [TVT] : Endif
# If !clalev([F:TVB])  Local File TABVACBPR [TVB] : Endif
# If !clalev([F:TVI])  Local File TABVACITM [TVI] : Endif
