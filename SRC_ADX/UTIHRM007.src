#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2018-03-03- US X3-75027- START
##########################################################################
# UTIHRM006 - Delete Tables(ATB), classes(ACL*) & representations(ASW*) linked to PAPI if PAPI is off      #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIHRM007 - Deletion of miscellaneous data for table 10371 and 10372 ") From LECFIC
  Call PATCH(DOSSIER)
  Call MAJ_UTIHRM007(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIHRM007(DOSSIER)
Value Char DOSSIER

If clalev([F:ADI])=0    : Local File =DOSSIER+".ATABDIV"           [ADI]     : Endif

Call DEBTRANS From GLOCK

Trbegin [ADI]


Delete [ADI] Where NUMTAB = 10371 or NUMTAB = 10372
If fstat
 GOK = 0 : Call FSTA("ADI") From GLOCK
 Return
Else
  Call ECR_TRACE("MAJ_UTIHRM007 : Deletetion complete  : "+DOSSIER,0) From GESECRAN
Endif



If !GOK
  Rollback
Else
  Commit
Endif

#Call ECR_TRACE("UTIHRM006: Process completed on : "+DOSSIER,0) From GESECRAN

Close Local File [ADI]


End



########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

Call ECR_TRACE("UTIHRM007 - Deletion of miscellaneous data for table 10371 and 10372 : "+APPLI,0) From GESECRAN

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

If clalev([F:ACVHR])=0 : Local File =APPLI+".ACTIV" [ACVHR] : Endif
Read [ACVHR]CODACT = "KGZA"

If fstat
  Call ECR_TRACE("UTIHRM005: Process aborted as activity code KGZA does not exist on : "+APPLI,0) From GESECRAN
  End
Else
  If [F:ACVHR]FLACT <> 2
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code KGZA is inactive on : "+APPLI,0) From GESECRAN
    End
  Endif
Endif

Filter [F:ACVHR]
Read [ACVHR]CODACT = "HRPAY"

If fstat
  Call ECR_TRACE("UTIHRM005: Process aborted as activity code HRPAY does not exist on : "+APPLI,0) From GESECRAN
  End
Else
  If [F:ACVHR]FLACT <> 2
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code HRPAY is inactive on : "+APPLI,0) From GESECRAN
    End
  Endif
Endif


Filter [F:ACVHR]
Read [ACVHR]CODACT = "HRHRM"

If fstat
  Call ECR_TRACE("UTIHRM005: Process aborted as activity code HRHRM does not exist on : "+APPLI,0) From GESECRAN
  End
Else
  If [F:ACVHR]FLACT <> 2
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code HRHRM is inactive on : "+APPLI,0) From GESECRAN
    End
  Endif
Endif


Call MAJ_UTIHRM007(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

If clalev([F:ACVHR])=0 : Local File =APPLI+".ACTIV" [ACVHR] : Endif
Read [ACVHR]CODACT = "KGZA"


If fstat
  End
Else
  If [F:ACVHR]FLACT <> 2
    End
  Endif
Endif


Filter [F:ACVHR]
Read [ACVHR]CODACT = "HRPAY"


If fstat
  End
Else
  If [F:ACVHR]FLACT <> 2
    End
  Endif
Endif

Filter [F:ACVHR]
Read [ACVHR]CODACT = "HRHRM"


If fstat
  End
Else
  If [F:ACVHR]FLACT <> 2
    End
  Endif
Endif


Call MAJ_UTIHRM007(APPLI)

End

