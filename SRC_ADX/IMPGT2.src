#<AdxTL>@(#)1.0.0.0 $Revision$

$ACTION
 Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 Endcase
Return


$IMP_OUVRE
If clalev([COA]) = 0 : Local File GCOA     [COA] : Endif
If clalev([GTC]) = 0 : Local File GTABACC  [GTC] : Endif

Return


$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
Return


$CONTROLE
#--------- Le champs COA est obligatoire et existant
If [F:GT2]COA=""
 GMESSAGE ="COA"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:GT2]COA
 If fstat
  GMESSAGE = "COA"-mess(83,123,1)-[F:GT2]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs ACCROO est obligatoire
If [F:GT2]ACCROO=""
 GMESSAGE ="ACCROO"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Endif

#--------- Le champs SCECODGEN doit exiter
If [F:GT2]SCECODGEN<>""
 Read [GTC]GTC0 ="CPT";[F:GT2]SCECODGEN
 If fstat
  GMESSAGE = "SCECODGEN"-mess(83,123,1)-[F:GT2]SCECODGEN   # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs SCECODANA doit exiter
If [F:GT2]SCECODANA<>""
 Read [GTC]GTC0 ="NAT";[F:GT2]SCECODANA
 If fstat
  GMESSAGE = "SCECODANA"-mess(83,123,1)-[F:GT2]SCECODANA   # Valeur incorrecte
  OK=0 : Return
 Endif
Endif
Return




