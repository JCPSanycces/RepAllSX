#JOJAC - 2016-06-02 - REQ114309 US215 - START
#FRLAA and JASMI - 2015-02-16 - Requirement 104592 US 3261 - START
$ACTION
Case ACTION
  When "OUVRE"     : Gosub OUVRE
  When "OUVRE_BOITE": Gosub OUVRE_BOITE
  When "LIENS"     : Gosub LIENS
  When "MODIF"     : Gosub MODIF
  When "CREATION"  : Gosub CREATION
  #FRLAA - 2015-06-18 - Requirement 108552 US 1 - START
  When "VERIF_MOD"  : Gosub VERIF_MOD
  When "VERIF_CRE"  : Gosub VERIF_CRE
  #FRLAA - 2015-06-18 - Requirement 108552 US 1 - END
  When "STYLE"         : Gosub STYLE  #FRLAA -2015-08-03 - Requirement 109427 - US 3711
  When "DEGRISE"       : Gosub DEGRISE #FRLAA - 2016-01-19 - Bug 113399
  When "ANNULE"        : Gosub ANNULE
Endcase
Return

$OUVRE
    If clalev([F:CTRAFR]) = 0 : Local File EMPLOCTRAFR    [CTRAFR]         : Endif

Return

$OUVRE_BOITE
