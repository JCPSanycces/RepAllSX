Subprog AM_RETFDSNUM(VALEUR)
Variable Char    VALEUR()

  If clalev([F:ADI]) = 0 : Local File ATABDIV [ADI]         : Endif

  Read [F:ADI]CODE = 11704;VALEUR
  If !fstat
    [M:CTR2]CAICAT = [F:ADI]A1
    [M:CTR2]CAIRATPS = [F:ADI]N1
    [M:CTR2]CAIRATPP = [F:ADI]N2
  Endif

End
#JASMI - 2016-11-07 - X3PEOP-2936 - END
