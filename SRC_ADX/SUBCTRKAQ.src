#FRLAA - 2015-06-15 - Requirement 105882 US 1 - START
Subprog ENABLE_DISABLE_BASED_ON_TAX_STATUS(VALEUR)
Variable Integer VALEUR
#If VALEUR=9
#  Actzo [M:CTR5]DIRNUM
#Else
#  Grizo [M:CTR5]DIRNUM
#  Effzo [M:CTR5]DIRNUM
#Endif
#
#If VALEUR=9
#  Actzo [M:CTR5]DIRPRC
#Else
#  Grizo [M:CTR5]DIRPRC
#  Effzo [M:CTR5]DIRPRC
#Endif
#
##FRLAA  2016-01-21 - Requirement 113796 US 4225 - START
#If func AFNC.ACTIV("KSZ") > 0 Then
#If VALEUR=2
#  Actzo [M:CTR5]DIRNUM
#Elsif VALEUR=9
#  Actzo [M:CTR5]DIRNUM
#Else
#  Grizo [M:CTR5]DIRNUM
#  Effzo [M:CTR5]DIRNUM
#Endif
#Endif
#DEHEN  2016-02-09 - US 4225 - START
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KSZ") > 0 Then
If func DIVPAYE.IS_KSZ_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  If VALEUR = 2 or VALEUR = 9
      Actzo [M:CTR5]DIRNUM
      If VALEUR = 2
          Actzo [M:CTR5]DIRAMT
      Else
          Grizo [M:CTR5]DIRAMT
      Endif
      If VALEUR = 9
          Actzo [M:CTR5]DIRPRC
      Else
          Grizo [M:CTR5]DIRPRC
      Endif
  Else
      Grizo [M:CTR5]DIRPRC
      Grizo [M:CTR5]DIRAMT
      Grizo [M:CTR5]DIRNUM
      Raz   [M:CTR5]DIRNUM
  Endif
Else
    If VALEUR=9
      Actzo [M:CTR5]DIRNUM
    Else
      Grizo [M:CTR5]DIRNUM
      Effzo [M:CTR5]DIRNUM

    Endif

    If VALEUR=9
      Actzo [M:CTR5]DIRPRC
    Else
      Grizo [M:CTR5]DIRPRC
      Effzo [M:CTR5]DIRPRC
    Endif
Endif
#DEHEN  2016-02-09 - US 4225 - END
#FRLAA  2016-01-21 - Requirement 113796 US 4225 - START
Affzo [M:CTR5]70
End
#FRLAA - 2015-06-15 - Requirement 105882 US 1 - END

#FRLAA - 2015-03-23 - Requirement 105849 US 3486 - START
Subprog AS_TAXSTRDAT(VALEUR)
  Variable Date    VALEUR

#JASMI - 2016-02-16 - Issue 114547 - START
#JASMI - 2016-06-02 - REQ 114309 - START
#  If func AFNC.ACTIV("KAO") or func AFNC.ACTIV("KMA")>0
  If func DIVPAYE.IS_KAO_LEG(GCURLEG) or func DIVPAYE.IS_KMA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
    If dim([M:CTR5]TAXSTRDAT)>0 : Chgfmt [M:CTR5]TAXSTRDAT With "-D:"+GFMDAT4 : Raz [M:CTR5]TAXSTRDAT : Endif
    End
  Endif
#JASMI - 2016-02-16 - Issue 114547 - END

  If clalev([F:ADW]) = 0 : Local File ADOVAL    [ADW]         : Endif
  Filter [ADW] Where PARAM = "TAXSTRDAT"
  Read [ADW] First
  If !fstat
    If [F:ADW]VALEUR <> [00/00/00]
      If [M:CTR0]CTRDAT < [F:ADW]VALEUR
        [M:CTR5]TAXSTRDAT = [F:ADW]VALEUR
        Affzo [M:CTR5]TAXSTRDAT
      Elsif [M:CTR0]CTRDAT > [F:ADW]VALEUR
        [M:CTR5]TAXSTRDAT = [M:CTR0]CTRDAT
        Affzo [M:CTR5]TAXSTRDAT
      Endif
    Else
      GMESSAGE = mess(10, 11706, 1)
    Endif
  Endif
End

Subprog C_TAXSTRDAT(VALEUR)
  Variable Date    VALEUR
  If clalev([F:ADW]) = 0 : Local File ADOVAL    [ADW]         : Endif
  Filter [ADW] Where PARAM = "TAXSTRDAT"
  Read [ADW] First
  If !fstat
    If [F:ADW]VALEUR <> [00/00/00]
      If [M:CTR0]CTRDAT < [F:ADW]VALEUR
        If VALEUR <> [F:ADW]VALEUR
          GMESSAGE = mess(9, 11706, 1)
          Return
        Endif
      Elsif [M:CTR0]CTRDAT > [F:ADW]VALEUR
        If VALEUR < [M:CTR0]CTRDAT
          GMESSAGE = mess(7, 11706, 1)
          Return
        Elsif VALEUR > [M:CTR0]CTRDAT
          GMESSAGE = mess(11, 11706, 1)
          Return
        Endif
      Endif
    Else
      GMESSAGE = mess(10, 11706, 1)
    Endif
  Endif
End
#FRLAA - 2015-03-23 - Requirement 105849 US 3486 - END

#FRLAA - 2015-06-15 - Requirement 105882 US 1 - START
Subprog AM_TAXSTAAFR(VALEUR)
Variable Integer VALEUR
Call ENABLE_DISABLE_BASED_ON_TAX_STATUS(VALEUR)
End
#FRLAA - 2015-06-15 - Requirement 105882 US 1 - END

