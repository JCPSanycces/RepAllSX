$LIENS
    Read [CTRAFR]CTRAFR0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
    If fstat = 0
      [M:CTR1] = [F:CTRAFR]
      [M:CTR4] = [F:CTRAFR]
      [M:CTR5] = [F:CTRAFR]
     #LIPET - 2018-01-18 - X3-59215 - START
     #JASMI - 2016-11-07 - X3PEOP-2936 - START
#      If dim([M:CTR2]EMPTYP)>0 : [M:CTR2]EMPTYP = [F:CTRAFR]EMPTYP : Endif # DEHEN - Read for KMA specific field - 2016-08-16
      [M:CTR2] = [F:CTRAFR]
    #JASMI - 2016-11-07 - X3PEOP-2936 - END
    #LIPET - 2018-01-18 - X3-59215 - END
    Endif

 Call ENABLE_DISABLE_BASED_ON_TAX_STATUS ([M:CTR5]TAXSTAAFR) #FRLAA - 2015-06-15 - Requirement 105882 US 1

Return

#FRLAA - 2015-06-18 - Requirement 108552 US 1 - START
$VERIF_MOD
$VERIF_CRE
#JASMI - 2016-06-02 - REQ 114309 - START
#If !func AFNC.ACTIV("KFR")  & !func AFNC.ACTIV("KPO") Then
#JASMI - 2016-06-02 - REQ 114309 - END
  If [M:CTR5]TAXSTAAFR = 9
    If [M:CTR5]DIRNUM =""
      ERR = 2  : GMESSAGE = mess(21, 11706, 1)  :    mkstat = 2 : Return ##Local menu must be used after range allocation!!
    Endif
  Endif
#JASMI - 2016-06-02 - REQ 114309 - START
#Endif
#JASMI - 2016-06-02 - REQ 114309 - END
Return
#FRLAA - 2015-06-18 - Requirement 108552 US 1 - END

$MODIF
$CREATION
  #FRLAA - 2015-03-23 - Requirement 105849 US 3486 - START
#  If clalev([F:ADW]) = 0 : Local File ADOVAL    [ADW]         : Endif
#  Filter [ADW] Where PARAM = "TAXSTRDAT"
#  Read [ADW] First
#  If !fstat
#    If [F:ADW]VALEUR <> [00/00/00]
#      If [M:CTR0]CTRDAT < [F:ADW]VALEUR
#        If [M:CTR5]TAXSTRDAT <> [F:ADW]VALEUR
#          GMESSAGE = mess(9, 11706, 1)
#          Return
#        Endif
#      Elsif [M:CTR0]CTRDAT > [F:ADW]VALEUR
#        If [M:CTR5]TAXSTRDAT < [M:CTR0]CTRDAT
#          GMESSAGE = mess(7, 11706, 1)
#          Return
#        Elsif [M:CTR5]TAXSTRDAT > [M:CTR0]CTRDAT
#          GMESSAGE = mess(11, 11706, 1)
#          Return
#        Endif
#      Endif
#    Else
#      GMESSAGE = mess(10, 11706, 1)
#    Endif
#  Endif
#
#  # Not stopping save procedure(confirm)
  #FRLAA - 2015-03-23 - Requirement 105849 US 3486 - END

    Delete [CTRAFR] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
    If fstat = 1
      GOK = -1
      GLOCK = "$HRFACILITYSA" - [M]CTRNUM - [M]REFNUM - [M]CTRDAT
      Return
    Elsif fstat>5
      GOK = 0
      Call RSTA("CTRAFR", [M]REFNUM - [M]CTRNUM - [M]CTRDAT) From GLOCK
      Return
    Endif

    [F:CTRAFR] = [M:CTR0]
    [F:CTRAFR] = [M:CTR1]
    [F:CTRAFR] = [M:CTR4]
    [F:CTRAFR] = [M:CTR5]
    #LIPET - 2018-01-18 - X3-59215 - START
  #JASMI - 2016-11-07 - X3PEOP-2936 - START
#    If dim([M:CTR2]EMPTYP)>0 : [F:CTRAFR]EMPTYP = [M:CTR2]EMPTYP : Endif # DEHEN - Save for KMA specific field - 2016-08-16
    [F:CTRAFR] = [M:CTR2]
  #JASMI - 2016-11-07 - X3PEOP-2936 - END
  #LIPET - 2018-01-18 - X3-59215 - END
    Write [CTRAFR]
    If fstat
      GOK = 0 : Return
    Endif

#JASMI - 2017-05-17 - START
  If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif
  Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
  #LIPET - 2018-09-19 - X3-106452 - START
  #Read First
  Read [F:HRPEOH] First
  #LIPET - 2018-09-19 - X3-106452 - END
  Filter [F:HRPEOH]
  If !fstat
    If ([M:CTR0]CTRDAT<=[F:HRPEOH]CYCENDDAT and ([M:CTR8]XITDAT >= [F:HRPEOH]CYCSTRDAT | [M:CTR8]XITDAT=[0/0/0]))
      Gosub CREATE_TAX_RECORD
    Endif
  Endif
#JASMI - 2017-05-17 - END

Return
#FRLAA and JASMI - 2015-02-16 - Requirement 104592 US 3261 - END

#JASMI - 2017-06-02 - START
$CREATE_TAX_RECORD
Local Integer THISTAXYEARAFR

#If func DIVPAYE.IS_KNA_LEG(GCURLEG)
# If month([M:CTR5]TAXENDDAT)>2
#    [L]THISTAXYEARAFR=year([M:CTR5]TAXENDDAT)+1
#  Else
#    [L]THISTAXYEARAFR=year([M:CTR5]TAXENDDAT)
#  Endif
#Else
#  [L]THISTAXYEARAFR=year([M:CTR5]TAXENDDAT)
#Endif


Local Date DTAXSTR, DTAXEND


If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]


 [L]THISTAXYEARAFR=year(DTAXEND)


Filter [F:ETA]
Filter [F:ETA] Where REFNUM=[M:CTR0]REFNUM and CTRNUM=[M:CTR0]CTRNUM and TAXYEA=THISTAXYEARAFR
If [M:CTR0]FLGVAR < 2
  Read [F:ETA]ETA0 Last
  If fstat
    Raz [F:ETA]
    [F:ETA]=[M:CTR0]
    [F:ETA]TAXYEA=THISTAXYEARAFR
    [F:ETA]=[M:CTR5]
    Write [F:ETA]
  Else
    Delete [F:ETA] Where REFNUM=[M:CTR0]REFNUM and CTRNUM=[M:CTR0]CTRNUM and TAXYEA=THISTAXYEARAFR
    Raz [F:ETA]
    [F:ETA]=[M:CTR0]
    [F:ETA]TAXYEA=THISTAXYEARAFR
    [F:ETA]=[M:CTR5]
    Write [F:ETA]
  Endif

#Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=THISTAXYEARAFR
#If [HRCTR]FLGVAR < 2
#    Read [F:ETA]ETA0 Last
#
#  If fstat
#     Raz [F:ETA]
#      Filter [F:CTRAFR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
#      Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM
#        [F:ETA]XITDAT=[HRCTR]XITDAT
#        [F:ETA]TAXYEA = THISTAXYEARAFR
#        [F:ETA]=[F:CTRAFR]
#      Write [F:ETA]
#   Else
#      Delete [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=THISTAXYEARAFR
#
#      Filter [F:CTRAFR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
#      Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM
#        [F:ETA]TAXYEA = THISTAXYEARAFR
#        [F:ETA]XITDAT=[HRCTR]XITDAT
#        [F:ETA]=[M:CTR5]
#        Write [F:ETA]
#   Endif
  If fstat
    OK=0
    Call ECR_TRACE("Error creating tax record." ,0) From GESECRAN
    Return
  Endif
Endif
Filter [F:ETA]


Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA > THISTAXYEARAFR

If rowcount([F:ETA]) > 0 Then
  Delete [F:ETA] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM and TAXYEA > THISTAXYEARAFR
Endif


Return
#ADNGO - 2017-06-02 - END

