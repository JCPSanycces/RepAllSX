#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTICPT11   Mise à jour des Exercices/Périodes             Module CPT   #
#            liée au Référentiels Automatiques                           #                     
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT11(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT11(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT11 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".COMPANY"    [CPY]
Local File =DOSSIER+".GACM"       [GCM]
Local File =DOSSIER+".FISCALYEAR" [FIY]
Local File =DOSSIER+".PERIOD"     [PER]
Local File =DOSSIER+".FISCALYEAR" [FIY2]
Local File =DOSSIER+".PERIOD"     [PER2]


# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30)

Call DEBTRANS From GLOCK
$LOOP_CPY
Raz NB
If STOP
 Raz STOP
 CRITERE = " [F:CPY]CPYLEGFLG=2 & [F:CPY]CPY>'"+ACLE1+"'"
Else
 CRITERE = " [F:CPY]CPYLEGFLG=2"
Endif

Trbegin [FIY2],[PER2]
For [CPY] Where evalue(CRITERE)
 Read [GCM]GCM0=[F:CPY]ACM
 # Pour tous les types de référentiels
 For N=1 To len(mess(0,2644,1))
  If [F:GCM]LED(N-1)<>"" & [F:GCM]CFMAUT(N-1) = 2
   # Pour tous les exercices du Référentiel de Référence / d'origine  
   For [FIY]FIY0 Where CPY=[F:CPY]CPY and LEDTYP=[F:GCM]ORILEDTYP(N-1)
    Read [FIY2]FIY0 = [F:FIY]CPY;N;[F:FIY]FIYNUM
    If fstat    
     Raz [FIY2]
     [F:FIY2] = [F:FIY]
     [F:FIY2]LEDTYP = N 
     [F:FIY2]LEDTYPAUT = 2
     [F:FIY2]CREDAT = date$
     [F:FIY2]CREUSR = GUSER
     Write [FIY2]
     If fstat
      Call ECR_TRACE(mess(13,100,1)-"FISCALYEAR"-":"-[F:FIY2]CPY-num$([F:FIY2]LEDTYP)-num$([F:FIY2]FIYNUM),1) From GESECRAN
      GOK = 0 : Break 3
     Endif
     NB+=1
    Else
     [F:FIY2]LEDTYPAUT = 2
     Rewrite [FIY2]
     If fstat
      Call ECR_TRACE(mess(13,100,1)-"FISCALYEAR"-":"-[F:FIY2]CPY-num$([F:FIY2]LEDTYP)-num$([F:FIY2]FIYNUM),1) From GESECRAN
      GOK = 0 : Break 3
     Endif
     NB+=1
    Endif
    # Pour toutes les périodes du Référentiel de Référence / d'origine
    For [PER]PER0 Where CPY=[F:CPY]CPY and LEDTYP=[F:GCM]ORILEDTYP(N-1) and FIYNUM=[F:FIY]FIYNUM
     Read [PER2]PER0 = [F:PER]CPY;N;[F:PER]FIYNUM;[F:PER]PERNUM
     If fstat    
      Raz [PER2]
      [F:PER2] = [F:PER]
      [F:PER2]LEDTYP = N 
      [F:PER2]LEDTYPAUT = 2
      Write [PER2]
      If fstat
       Call ECR_TRACE(mess(13,100,1)-"PERIOD"-":"-[F:PER2]CPY-num$([F:PER2]LEDTYP)-num$([F:PER2]FIYNUM)-num$([F:PER2]PERNUM),1) From GESECRAN
       GOK = 0 : Break 4 
      Endif
      NB+=1
     Else
      [F:PER2]LEDTYPAUT = 2
      Rewrite [PER2]
      If fstat
       Call ECR_TRACE(mess(13,100,1)-"PERIOD"-":"-[F:PER2]CPY-num$([F:PER2]LEDTYP)-num$([F:PER2]FIYNUM)-num$([F:PER2]PERNUM),1) From GESECRAN
       GOK = 0 : Break 4 
      Endif
      NB+=1
     Endif
    Next
   Next
  Endif
 Next N

 If NB>GMAXUPDTRS
  ACLE1 = [F:CPY]CPY
  STOP=1
  Break
 Endif
Next

If GOK<1
 Rollback
Else
 Commit
 If STOP
  Goto LOOP_CPY
 Endif
Endif

Close Local File [CPY],[GCM],[FIY],[PER]

Call ECR_TRACE("UTICPT11 : record processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
Call MAJ_UTICPT11(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 :  End : Endif
Call MAJ_UTICPT11(APPLI)
End

