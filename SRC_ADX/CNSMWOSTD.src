#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation MWO

############################################################################
#                        Consultation                                       #
#                        Situation de pesée                                 #
#                                                                GPAO       #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site        /SITE                                                    #
# 2  = article     /ART                                                     #
# 3  = pièce       /VCRNUM                                                  #
# 4  = date fin    /DATFIN                                                  #
# 5  = date debut  /DATDEB                                                  #
# 6  = affaire     /AFFAIRE                                                 #
# 7  = priorite    /PRIORITE                                                #
# 8  = categorie   /CATEGORIE                                               #
# 9  = tri         /TRI                                                     #
#                      1 - date                                             #
#                      2 - OF                                               #
#                      3 - article                                          #
#############################################################################
Local Char PARAM(20)(1..10)
PARAM(1) = "GAL"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = "1"
Call GCONSULT("SHO","",PARAM) From GCONSULT
End



$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$OUVRE
Local Integer WSRT,WRET
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    FORMULE1(250)


If clalev ([F:ITM])  <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:MFG])  <= 0 : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFM])  <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:MFI])  <= 0 : Local File MFGITM     [MFI] : Endif
If clalev ([F:TFO])  <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TUN])  <= 0 : Local File TABUNIT    [TUN] : Endif

Gosub DEFCRIT
If !find([M:CMWO]TRI,1,2,3) : [M:CMWO]TRI = 1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMWO"
Return

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:MWO1]MFGFCY = PARAM(I) : Endif
                 Endif
        When 2 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:MWO1]ITMREFSTR = PARAM(I)
                         [M:MWO1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 3 : # Pièce
                 If PARAM(I) <> ""
                     [M:MWO1]MFGNUMSTR = PARAM(I)
                     [M:MWO1]MFGNUMEND = PARAM(I)
                 Endif
        When 4 : # date fin
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:MWO1]ENDDATSTR = "["+PARAM(I)+"]"
                         [M:MWO1]ENDDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:MWO1]ENDDATSTR = PARAM(I)
                         [M:MWO1]ENDDATEND = PARAM(I)
                     Endif
                 Endif
        #CHECK UNUSED_BEGIN
        When 5 : # date début
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:MWO1]STRDATSTR = "["+PARAM(I)+"]"
                         [M:MWO1]STRDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:MWO1]STRDATSTR = PARAM(I)
                         [M:MWO1]STRDATEND = PARAM(I)
                     Endif
                 Endif
        When 6 : # Affaire
                 If PARAM(I) <> ""
                     [M:MWO1]PJTSTR = PARAM(I)
                     [M:MWO1]PJTEND = PARAM(I)
                 Endif
        When 7 : # priorite
                 If PARAM(I) <> ""
                     [M:MWO1]MFGPIOSTR = PARAM(I)
                     [M:MWO1]MFGPIOEND = PARAM(I)
                 Endif
        When 8 : # categorie
                 If PARAM(I) <> ""
                     [M:MWO1]TCLCODSTR = PARAM(I)
                     [M:MWO1]TCLCODEND = PARAM(I)
                 Endif
        #CHECK UNUSED_END
        When 9 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 3  : WSRT = 1 : Endif
                     [M:CMWO]TRI = WSRT
                 Endif
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CMWO) vers le masque 0 (MWO1)
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MWO1]MFGFCY = ""  : NBLU = 0 : Return : Endif
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If PARAM(9) = "" : NBLU=0 : PARAM(9) = "1" : Return : Endif

#If PARAM(9) = "" : PARAM(9) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CMWO]TRI
      When 1 : # tri par date
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFI]STRDAT
      When 2 : # tri par OF
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key MFI0
      When 3 : # tri par article
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFI]ITMREF
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CMWO]TRI
      When 1 : # tri par date
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFI]STRDAT Desc
      When 2 : # tri par OF
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key MFI0 Desc
      When 3 : # tri par article
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFI]ITMREF Desc
    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:MWO2] : Endif

# lecture
$BOUCLE

For [MFX]
  If NBLU = 1
     If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWO2] : Endif
     NBLU = 2
  Endif

  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:MFI]MFGNUM
         DEBDAT = [F:MFI]STRDAT
         DEBITM = [F:MFI]ITMREF
     Endif
     FINNUM = [F:MFI]MFGNUM
     FINDAT = [F:MFI]STRDAT
     FINITM = [F:MFI]ITMREF
  Else
     If NOL <= 0 : RETOUR = 2 : Break : Endif
     NOL    -= 1
     If NOL = MAXLIG-1
         FINNUM = [F:MFI]MFGNUM
         FINDAT = [F:MFI]STRDAT
         FINITM = [F:MFI]ITMREF
     Endif
     DEBNUM = [F:MFI]MFGNUM
     DEBDAT = [F:MFI]STRDAT
     DEBITM = [F:MFI]ITMREF
  Endif
  nolign = NOL+1

  Gosub FILLTAB

$SUIV
Next

# Issue 85521 - 2012-11-15 by MM
[M:MWO2]NBLIG = nolign
Gosub HIGHLIGHT

Return

#############################################################################
# Chargements spéciaux
$FILLTAB
[M:MWO2] = [F:MFG]
[M:MWO2] = [F:MFI]

# Lecture ITMMASTER
# 03.09 mm - libellé traduisible
#Call LECTEXTRA ([M:MWO2]ITMDES1(nolign-1),"ITMMASTER","DES1AXX",[M:MWO2]ITMREF(nolign-1),"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:MWO2]ITMREF(nolign-1),[M:MWO2]ITMDES1(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
Return

#############################################################################
# Issue 85521 - 2012-11-15 by MM : coloriser les OFs à réactiver
$HIGHLIGHT
Local Integer I
Affzo [M:MWO2]

# réinitialisation style
Chgstl [M:MWO2]  With ""

For I =0 To [M:MWO2]NBLIG-1
  # application style
  If find ([M:MWO2]WGGFLG(I),4,8)  # en cours de pesée ou en cours de pesée par article
    Chgstl [M:MWO2]NBLIG(I) With "MTOLINKC"
  Endif
Next I

Return
#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

CRITERE1 = "[F:MFG]WGGFLG>1"              # filtre prise en compte plan de pesée

# site
If [M:MWO1]MFGFCY <> ""
   CRITERE = "[F:MFG]MFGFCY=[M:MWO1]MFGFCY"
   Gosub LOAD_CRITERE2
Endif

# ordre
If [M:CMWO]MFGNUMSTR <> ""
   CRITERE = "[F:MFG]MFGNUM>=[M:CMWO]MFGNUMSTR"       # borne début ordre
   Gosub LOAD_CRITERE2
Endif
If [M:CMWO]MFGNUMEND<>""
   CRITERE = "[F:MFG]MFGNUM<=[M:CMWO]MFGNUMEND"       # borne fin   ordre
   Gosub LOAD_CRITERE2
Endif

# date fin
If [M:CMWO]ENDDATSTR <> [0/0/0]
   CRITERE = "[F:MFG]ENDDAT>=[M:CMWO]ENDDATSTR"       # borne debut date fin
   Gosub LOAD_CRITERE2
Endif
If [M:CMWO]ENDDATEND <> [0/0/0]
   CRITERE = "[F:MFG]ENDDAT<=[M:CMWO]ENDDATEND"       # borne fin date fin
   Gosub LOAD_CRITERE2
Endif

# date debut
If [M:CMWO]STRDATSTR <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT>=[M:CMWO]STRDATSTR"       # borne debut date début
   Gosub LOAD_CRITERE2
Endif
If [M:CMWO]STRDATEND <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT<=[M:CMWO]STRDATEND"       # borne fin date debut
   Gosub LOAD_CRITERE2
Endif

# priorite
If [M:CMWO]MFGPIOSTR <> 0
   CRITERE = "[F:MFG]MFGPIO>=[M:CMWO]MFGPIOSTR"       # borne début priorite
   Gosub LOAD_CRITERE2
Endif
If [M:CMWO] MFGPIOEND <> 0
   CRITERE = "[F:MFG]MFGPIO<=[M:CMWO]MFGPIOEND"       # borne fin   priorite
   Gosub LOAD_CRITERE2
Endif


# article
If [M:CMWO]ITMREFSTR <> ""
    CRITERE = "[F:MFI]ITMREF>=[M:CMWO]ITMREFSTR"      # borne début article
    Gosub LOAD_CRITERE3
Endif
If [M:CMWO]ITMREFEND<>""
    CRITERE = "[F:MFI]ITMREF<=[M:CMWO]ITMREFEND"      # borne fin   article
    Gosub LOAD_CRITERE3
Endif
# Affaire
If [M:CMWO]PJTSTR <> ""
    CRITERE = "[F:MFI]PJT>=[M:CMWO]PJTSTR"      # borne début affaire
    Gosub LOAD_CRITERE3
Endif
If [M:CMWO]PJTEND<>""
    CRITERE = "[F:MFI]PJT<=[M:CMWO]PJTEND"      # borne fin   affaire
    Gosub LOAD_CRITERE3
Endif
# categorie
If [M:CMWO]TCLCODSTR <> ""
    CRITERE = "[F:MFI]TCLCOD>=[M:CMWO]TCLCODSTR"      # borne début categorie
    Gosub LOAD_CRITERE3
Endif
If [M:CMWO]TCLCODEND<>""
    CRITERE = "[F:MFI]TCLCOD<=[M:CMWO]TCLCODEND"      # borne fin   categorie
    Gosub LOAD_CRITERE3
Endif

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CMWO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
   When 2 : # suite
     Case [M:CMWO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT>FINDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM>FINNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF>FINITM"
           Gosub LOAD_CRITERE3
     Endcase
   When -2 : # retour
     Case [M:CMWO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT<DEBDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM<DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF<DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
Endcase
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif

# analyse présence formule de sélection
If [M:CMWO]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=12;[M:CMWO]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return



############################################################
# Etiquettes
############################################################


########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:MWO1]ITMREFEND = ""     : [M:MWO1]ITMREFEND = VALEUR : Affzo [M:MWO1]ITMREFEND : Endif
If [M:MWO1]ITMREFEND < VALEUR : [M:MWO1]ITMREFEND = VALEUR : Affzo [M:MWO1]ITMREFEND : Endif

End

########################################
Subprog AS_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

# Article site

GBOUT1 = mess(4,198,1)
End

########################################
Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY : WFCY = [M:MWO1]MFGFCY
Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = ""

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If WFCY <> ""
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
    Endif
Endif




End

########################################
Subprog S_ITMREFSTR(VALEUR)
Variable Char    VALEUR()


End

########################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
# Article site

GBOUT1 = mess(4,198,1)

End

########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog S_ITMREFEND(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:MWO1]MFGNUMEND = ""     : [M:MWO1]MFGNUMEND = VALEUR : Affzo [M:MWO1]MFGNUMEND : Endif
If [M:MWO1]MFGNUMEND < VALEUR : [M:MWO1]MFGNUMEND = VALEUR : Affzo [M:MWO1]MFGNUMEND : Endif

End

########################################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:CMWO]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog C_MFGPIOEND(VALEUR)
Variable Integer VALEUR
If VALEUR < [M:CMWO]MFGPIOSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
End

########################################
# possibilité, selon habilitations fonctionnelles de remettre un OF en cours dans le plan de pesée
Subprog IB_NBLIG
Raz GBOUT5
# mm 05.11 : ajout du cas où le flag = 8
If find([M:MWO2]WGGFLG(nolign-1),4,8) & instr(1,GUSRAUZ(1),"R")<>0
   GBOUT5 = mess(438,198,1)
Endif

End

########################################
# changement de statut d'un OF : On le passe de "en cours de pesée " à "Plan de travail"
# changement de statut de la matière : on passe "en cours de pesée " oui à non
Subprog B5_NBLIG
Local Integer OK
#un petit message de confirmation
OK = 1
Call OUINON(mess(37,2324,1),OK) From GESECRAN
If OK = 2
  For [F:MFM] Where MFGNUM = [M:MWO2]MFGNUM(nolign-1) & WGGBOX = 2
      #  mm 10.10 - WGGBOX = 2 signifie que la matière est physiquement en cours de pesée
      #  au quel cas, on avertit de la situation pour qu'il y ait vérification
      #  avant de remettre ou pas l'OF dans le plan de pesée.
      OK = 1
      Call AVERTIR(mess(214,193,1)-":"-mess(205,100,1),OK) From GESECRAN : Break
   Next
   If OK= 1 : End : Endif
#
   Call DEBTRANS From GLOCK
   Trbegin [MFG],[MFM]
   Call MAJ_FICHIERS ("MFG",3,1,[M:MWO2]MFGNUM(nolign-1),"",0,0) From SCALEXCHAN
   If GOK = 1
       For [F:MFM] Where MFGNUM = [F:MFG]MFGNUM
          If WGGSTA = 2  & [F:MFM]MATSTA = 1     # Issue 85521 - 2012-11-15 by MM
             #  mm 10.10 - WGGSTA = 2 , en cours de pesée , signifie qu'il existe au moins un suivi pour cette matière
             Call MAJ_FICHIERS ("MFM",1,0,[F:MFM]MFGNUM,[F:MFM]ITMREF,[F:MFM]MFGLIN,[F:MFM]BOMSEQ) From SCALEXCHAN
             If GOK <> 1 : Break : Endif
           Endif
           # seulement en cas de pesée par article normalement
           If [F:MFM]WGGBOX = 2
             Call MAJ_FICHIERS ("MFM",0,1,[F:MFM]MFGNUM,[F:MFM]ITMREF,[F:MFM]MFGLIN,[F:MFM]BOMSEQ) From SCALEXCHAN
             If GOK <> 1 : Break : Endif
           Endif
       Next
   Endif
   If GOK = 1
      Commit
      [M:MWO2]WGGFLG(nolign-1) = 3
      Affzo [M:MWO2]WGGFLG(nolign-1)
      Call MESSAGE(mess(38,2324,1)) From GESECRAN
   Else
      Rollback
   Endif
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 16/06/2003 16:06:38 (MM)
##########################################################################
Subprog S_MFGNUMEND(VALEUR)
Variable Char    VALEUR()
End


##########################################################################
# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWO") From SUBGTC

End

