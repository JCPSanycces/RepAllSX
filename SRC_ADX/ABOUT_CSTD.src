#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char SOL , DIR , TRT , APP , VERX3 , VERSUP , VERRUN , REL , NOP
Call ABOUT_CONNECT(SOL,DIR,TRT,APP)
Call ABOUT_X3(nomap,VERX3,VERSUP,VERRUN,REL,NOP)
Infbox SOL,DIR,TRT,APP,VERX3,VERSUP,VERRUN,REL,NOP,func NEWVER(VERX3,NOP)
End

#-------------------------------#
# Classe ABOUT
#-------------------------------#
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
     When "AREAD" : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




#--------------#
$AREAD
Local Char SOL(250) , DIR(250) , TRT(80) , APP(80)
Local Char VERX3(30) , VERSUP(30) , VERRUN(30) , REL(30) , NOP(30)

Call ABOUT_CONNECT(SOL,DIR,TRT,APP) From ABOUT_CSTD
Call ABOUT_X3(nomap,VERX3,VERSUP,VERRUN,REL,NOP) From ABOUT_CSTD

this.SOLUTION    = SOL
this.HTTPADR     = DIR
this.TRTSRV      = TRT
this.APPSRV      = APP
this.FOLDNAM     = nomap
this.PORT        = num$(adxtcp)
this.X3RELEASE   = REL
this.PATCHNUMBER = NOP
this.SUPVERSION  = VERSUP
this.RUNVERSION  = VERRUN
this.NEWVER      = func NEWVER(VERX3,NOP)
#106969
#this.X3VERSION   = VERX3
this.X3VERSION   = func APRODUCT.AGETVERSION()
Return

#----------------------------------------------#
Funprog NEWVER(VERX3,NOP)
Value Char VERX3,NOP
Local Char    NEWVER(50) , POINT(1)
Local Integer I,J
POINT = "."
I = instr(1,VERX3,POINT)
If I
 #106969
 #NEWVER = right$(VERX3,I+1)+POINT+NOP
 J=instr(I+1,VERX3,POINT)
 If J :#1.9.0
  NEWVER = right$(VERX3,I+1)+POINT+NOP
 Else : #R070.000
  NEWVER=VERX3
 Endif
Elsif len(VERX3)>3 : # Todo ??? 1101 (1.10.1) or 1810 (1.8.10)
 NEWVER = mid$(VERX3,2,2)+POINT+right$(VERX3,4)+POINT+NOP
Elsif VERX3<>""
 NEWVER = mid$(VERX3,2,1)+POINT+mid$(VERX3,3,1)+POINT+NOP
Endif
End NEWVER

#-----------------------------------------------------------#
Subprog ABOUT_CONNECT(SOL,DIR,TRT,APP)
Variable Char SOL,DIR,TRT,APP
Local Char    SOLFIC(250) , LIGNE(250) , DOSREF(20)
Local Integer I , J , TYPD
#115753
#TRT = string$(adxmac(0)<>"",adxmac(0))+string$(adxmac(0)="",adxmac(-1))
#APP = adxmac(-1)
APP = string$(adxmac(0)<>"",adxmac(0))+string$(adxmac(0)="",adxmac(-1))
TRT = adxmac(-1)
For I=7 To 0 Step -1
 If adxmother(I)<>""
  DOSREF = adxmother(I)
  Break
 Endif
Next I
SOLFIC = filpath("","","",DOSREF)
SOLFIC = left$(SOLFIC,len(SOLFIC)-len(DOSREF))
SOLFIC += "solution.xml"
If filinfo(SOLFIC,7)>0
 Openi SOLFIC,0 Using [CST_]
 Iomode adxifs ""       Using [CST_]
 Iomode adxirs chr$(10) Using [CST_]
 Iomode adxium GUTF8    Using [CST_]
 fstat=0
 While !fstat
  Rdseq LIGNE Using [CST_]
  If instr(1,LIGNE,"<solution")<>0
   I = instr(1,LIGNE,"name")
   J = instr(I+6,LIGNE,'"')
   If J-I-6>0
    SOL = vireblc(mid$(LIGNE,I+6,J-I-6),2)
   Endif
  Elsif instr(1,LIGNE,"application.http.url")<>0
   I = instr(1,LIGNE,">")
   J = instr(I+1,LIGNE,'<')
   If J-I-1>0
    DIR = "http://"+vireblc(mid$(LIGNE,I+1,J-I-1),2)
   Endif
  Endif
 Wend
 Openi Using [CST_]
Endif
End

#---------------------------------------------------#
Subprog ABOUT_X3(DOSSIER,VERX3,VERSUP,VERRUN,REL,NOP)
Value Char DOSSIER
Variable Char VERX3,VERSUP,VERRUN,REL,NOP
VERSUP  = func APRODUCT.AGETRELEASESUP()
VERRUN  = func AFNC.PARTSEP(ver$(0),2," ")
If DOSSIER=nomap
 Local File ADOVAL [A_DW]
Else
 Local File =DOSSIER+".ADOVAL" [A_DW]
Endif
Read [A_DW]ADW0 = "";"";"RELEASE"
If !fstat
 REL = num$([F:A_DW]VALEUR)
Else
 REL = "0"
Endif
Close Local File [A_DW]

If DOSSIER=nomap
 Local File APATCH [APT]
Else
 Local File =DOSSIER+".APATCH" [APT]
Endif
Filter [APT] Where TYP="P"
Read [APT]APT0 Last
If !fstat
 #If [F:APT]VER<>0 : VERX3 = num$([F:APT]VER) : Endif
 NOP = num$([F:APT]PATNUM)
 If [F:APT]RELEASE<>""
  #106969
  #VERX3 = ctrans([F:APT]RELEASE,".","")
  VERX3 = [F:APT]RELEASE
 Endif
Endif
Close Local File [APT]

End

