####### Ecran RUB2
########################################
Subprog C_BAS(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog C_RAT1(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog C_RAT2(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog C_CUMBAS(VALEUR)
Variable Char    VALEUR()
 If [M:RUB2]REG=2 | VALEUR<>""
  Call C_CUM([M:RUB2]CUMBAS)
 Endif
End

Subprog C_CUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif
Local Integer NOL
NOL = indice
If clalev ([F:CUM])=0 : Local File CUMUL [CUM]: Endif
Call LECTURE("CUM",VALEUR,GCURLEG) From CONTOBJ

If [M:RUB1]TMPCAL=2 & [F:CUM]CUMTMP<>2
 Call ERREUR(mess(8,10708,1)+"\"+mess(9,10708,1)) From GESECRAN
   #Un calcul intermédiaire ne peut mouvementer
   #que des cumuls intermédiares
 mkstat=2
Else
 If [M:RUB1]TYPRUB=5 & [M]REG=2 & [F:CUM]CUMTMP=2
  Call ERREUR(mess(10,10708,1)) From GESECRAN
  mkstat = 2
# Cumul intermédiaires
 Endif
Endif
If VALEUR<>""
 [M:RUB2]CUMPER(NOL) = [F:CUM]CUMPER
Endif
End

Subprog AS_NBRAMT
#Tax Band
#[M]NBRAMT = len(mess(0,10338,1))
 [M]NBRAMT = dim([F:RUB]AMTMAX)
Affzo TRANCHE
End

Subprog C_AMTMAX(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
If mkstat : End : Endif
#Tax Band
#If indice=2 & vireblc([M:RUB2]AMTMAX(0)+[M:RUB2]AMTMAX(1)+VALEUR,4)=""
If indice=dim([F:RUB]AMTMAX)-1
 [M:RUB2]AMTMAX(indice)=VALEUR
 Local Char CRITAXBND (250)
 CRITAXBND="vireblc("
 For I=0 To dim([F:RUB]AMTMAX)-1
  CRITAXBND+="[M:RUB2]AMTMAX("+num$(I)+")"
  If I<dim([F:RUB]AMTMAX)-1: CRITAXBND+="+" : Endif
 Next
 CRITAXBND+=",4)"
 If evalue(CRITAXBND)=""
  Call ERREUR (mess(18,10708,1)) From GESECRAN :#plafond non défini
  mkstat = 2
 Endif
Endif
End

Subprog AS_CUMMAX(VALEUR)
Variable Char VALEUR()
If [M]AMTMAX(nolign-1)="" : mkstat = 1 : End : Endif
End

Subprog AS_CUMAMT(VALEUR)
Variable Char VALEUR()
If [M]AMTMAX(nolign-1)="" : mkstat = 1 : End : Endif
End

Subprog AV_OPTCUM(VALEUR)
Variable Integer VALEUR
If VALEUR = 0 : VALEUR=3 : Endif
End

