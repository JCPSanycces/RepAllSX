####### Ecran RUB3
########################################

Subprog AS_NBRACC
## Calcul intermédiaire ou Assiette ou
## Arrondi de calcul non nul et différent de la devise locale
If [M]TMPCAL=2 | [M]TYPRUB=5 | ([M]DEC<>0 & [M]DEC<GARODEV)
 mkstat=2
Endif
End

Subprog AS_ACC(VALEUR)
Variable Char VALEUR()
If [M]SAC(nolign-1)<>""
 If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
 Read [GAC]GAC1 = [M]SAC(nolign-1)
 VALEUR = [F:GAC]ACC
 mkstat = 2 : End
Endif
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"x") | instr(1,VALEUR,"mm") | instr(1,VALEUR,"MM") | instr(1,VALEUR,"qq")
&                      | instr(1,VALEUR,"QQ")
 End
Endif
If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
Read [GAC]GAC0=VALEUR
If fstat
 GMESSAGE = VALEUR+"\"+mess(23,100,1)
 mkstat = 2
Endif
End

########################################
####### Ecran RUB4
########################################

Subprog C_TBLCOD(VALEUR)
Variable Char    VALEUR()
Read [GRI]GRI0 = VALEUR
Call GRISE_TBLCOD(VALEUR)
Affzo [M:RUB4]INTFRM
End

Subprog GRISE_TBLCOD(VALEUR)
Variable Char    VALEUR()
Raz [M:RUB4]INTFRM
For indice=0 To [F:GRI]NBRCMP-1
 [M:RUB4]INTFRM(indice) = [F:GRI]CMPDES(indice)
 Actzo [M:RUB4]TBLFRM(indice)
Next indice
For indice=[F:GRI]NBRCMP To dim([M:RUB4]TBLFRM)-1
 Grizo [M:RUB4]TBLFRM(indice)
Next indice
End

Subprog AS_TBLFRM(VALEUR)
Variable Char VALEUR()
Call LECTURE("GRI",[M]TBLCOD,"") From CONTOBJ
If indice+1>[F:GRI]NBRCMP
 mkstat = 1 : End
Endif
End

Subprog C_TBLFRM(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog C_TBLCOL(VALEUR)
Variable Decimal VALEUR
Variable Integer NOCOL

Call LECTURE("GRI",[M:RUB4]TBLCOD,"") From CONTOBJ
If VALEUR>[F:GRI]NBRCOL
 # Le numéro de la colonne doit être infèrieur à xxx
 GMESSAGE = mess(13,10708,1)-num$([F:GRI]NBRCOL+1)
 mkstat = 2 : End
Else
 If VALEUR<1
  # Le numéro de la colonne doit être supèrieur à 0
  GMESSAGE = mess(12,10708,1)-"0"
  mkstat = 2 : End
 Endif
Endif
[M:RUB4]COLDES = [F:GRI]COLDES(VALEUR-1)
End

Subprog AV_ITVLIM(VALEUR)
Variable Char VALEUR
If nolign=1 : mkstat = 1 : Endif
End

Subprog C_ITVLIM(VALEUR)
Variable Char VALEUR
If nolign<>1
## 22693
## If VALEUR=0
 If VALEUR="0" | VALEUR=""
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 2 : End
 Endif
Endif
## 22693
If VALEUR<>num$(val(VALEUR))
 VALEUR = toupper(VALEUR)
 Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 If mkstat
  # Il faut saisir un nombre ou une variable
  GMESSAGE = mess(176,10703,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_ITVAMT(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End


########################################
####### Ecran RUB5
########################################
Subprog C_AMTPRN(VALEUR)
Variable Integer VALEUR
Call GRISE_AMTPRN(VALEUR)
End

Subprog GRISE_AMTPRN(VALEUR)
Value Integer VALEUR
If VALEUR<2
 Effzo [M:RUB5]TEXVRI,LFEBEF,LFEAFT,DESPRN,PRNGRP,PRNBAS
 Grizo [M:RUB5]TEXVRI,LFEBEF,LFEAFT,DESPRN,PRNGRP,PRNBAS
Else
 Actzo [M:RUB5]TEXVRI,LFEBEF,LFEAFT,DESPRN,PRNGRP,PRNBAS
Endif
End

Subprog C_PRNBAS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:RUB5]PRNGRP<>""
 #Zone obligatoire
 GMESSAGE= mess(10,123,1)
 mkstat=2 : End
Endif
End

Subprog AM_TEXVRI(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If find(VALEUR,[M]TEXVRI(0..indice-1))
  mkstat = 2 : End
 Endif
 Local File RUBRIQUE [RUB2]
 Filter [RUB2] Where (COD<>[M:RUB0]COD or (COD=[M:RUB0]COD & LEG<>GCURLEG)) & (TEXVRI(0)=VALEUR or TEXVRI(1)=VALEUR)
 Read [RUB2]RUB0 First
 Filter [RUB2]
 If !fstat
  Local Integer OK
  OK = 2 : Call AVERTIR(mess(19,10703,1)-[F:RUB2]COD,OK) From GESECRAN : # Texte déjà défini sur la rubrique
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

##############################################################
########### Sous-programmes de grisage/dégrisage
##############################################################
#valeurs de typrub :
#1-base
#2-base*tx
#3-base*tx /100
#4-intervalle
#5-assiette
#6-cotisation
#7-grille
#8-historique
########################################

Subprog GRISE_TYPRUB(VALEUR)
Value Integer VALEUR
If VALEUR=5
 If [M:RUB1]TMPCAL=2
  Effzo [M:RUB5]15,25,35,45,55,60,70
  Grizo [M:RUB5]15,25,35,45,55,60,70
 Else
  Effzo [M:RUB5]15,25
  Grizo [M:RUB5]15,25
 Endif
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
 Call GRISE_FLGCPT(0)
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Else
 If [M:RUB1]TMPCAL=2
  Effzo [M:RUB5]15,25,35,45,55,60,70
  Grizo [M:RUB5]15,25,35,45,55,60,70
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Call GRISE_FLGCPT(0)
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Else
  Actzo [M:RUB5]15,25,35,45,55,60,70
  #Si rubrique non imprimable -> Grize
  If [M:RUB5]AMTPRN<2
   Effzo [M:RUB5]LFEBEF,LFEAFT,DESPRN,TEXVRI,PRNGRP,PRNBAS
   Grizo [M:RUB5]LFEBEF,LFEAFT,DESPRN,TEXVRI,PRNGRP,PRNBAS
  Endif
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
 Call GRISE_FLGCPT(1)
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
 Endif
Endif

If VALEUR=8
 [M:RUB2]LIBTX0 = mess(2,10702,1) : # Base
Else
 [M:RUB2]LIBTX0 = mess(2,10702,1) : # Base
Endif
If VALEUR=10
 Actzo [M:RUB1]RGL
 Effzo [M:RUB2]5,10,15,20
 Grizo [M:RUB2]5,10,15,20
 Effzo [M:RUB4]
 Grizo [M:RUB4]
Elsif VALEUR=1 | VALEUR=2 | VALEUR=3 | VALEUR=4 | VALEUR=5 | VALEUR=7 | VALEUR=9
 Actzo [M:RUB2]BAS
 If VALEUR<>5 : [M:RUB2]CAI = "0" : Endif
#JASMI - 2017-09-07 - X3-49836 - START
 If VALEUR<>5 : [M:RUB2]CAIVAL = "" : Endif
#JASMI - 2017-09-07 - X3-49836 - END
 [M:RUB2]LIBTX1 = ""
 [M:RUB2]LIBTX2 = ""
 Effzo [M:RUB1]RGL : Grizo [M:RUB1]RGL

 Case VALEUR
  When 1 : # Base
   Effzo [M:RUB2]RAT1,RAT2
   Grizo [M:RUB2]RAT1,RAT2
   Effzo [M:RUB2]10,15,20
   Grizo [M:RUB2]10,15,20
   Effzo [M:RUB4]
   Grizo [M:RUB4]

  When 2,3,9 : # Base * taux
   #45948
   #LIBTX1 = mess(1,10708,1)
   #Actzo [M:RUB2]RAT1
   #Effzo [M:RUB2]RAT2
   #Grizo [M:RUB2]RAT2
   If VALEUR=2
    [M:RUB2]LIBTX1 = mess(1,10326,1)    #Part salariale
    [M:RUB2]LIBTX2 = mess(2,10326,1)    #Part patronale
   Else
    [M:RUB2]LIBTX1 = mess(6,10708,1)    #% salarial
    [M:RUB2]LIBTX2 = mess(7,10708,1)    #% patronal
   Endif
   Actzo [M:RUB2]RAT1
   Actzo [M:RUB2]RAT2
   # fin 45948
   Effzo [M:RUB2]10,15,20
   Grizo [M:RUB2]10,15,20
   Effzo [M:RUB4]
   Grizo [M:RUB4]

  When 4 : # Intervalle
   Effzo [M:RUB2]RAT1,RAT2
   Grizo [M:RUB2]RAT1,RAT2
   Effzo [M:RUB2]10,15,20
   Grizo [M:RUB2]10,15,20
   Effzo [M:RUB4]5
   Grizo [M:RUB4]5
   Actzo [M:RUB4]10

  When 5
   Effzo [M:RUB2]10
   Grizo [M:RUB2]10
   Actzo [M:RUB2]15,20
   Effzo [M:RUB2]RAT1,RAT2
   Grizo [M:RUB2]RAT1,RAT2
   Effzo [M:RUB4]
   Grizo [M:RUB4]

  When 7
   Effzo [M:RUB2]5,10,15,20
   Grizo [M:RUB2]5,10,15,20
   Actzo [M:RUB4]5
   Effzo [M:RUB4]10
   Grizo [M:RUB4]10

 Endcase

Else :     #historique, cotisation

 Effzo [M:RUB1]RGL : Grizo [M:RUB1]RGL
 Actzo [M:RUB2]BAS,RAT1,RAT2
 Effzo [M:RUB4]
 Grizo [M:RUB4]
 Case VALEUR
  When 8                            # historique
   Effzo [M:RUB2]10,15,20
   Grizo [M:RUB2]10,15,20
   [M:RUB2]LIBTX1 = mess(4,10708,1)    #date debut
   [M:RUB2]LIBTX2 = mess(5,10708,1)    #date fin
   Affzo [M:RUB2]LIBTX1 : Affzo [M:RUB2]LIBTX2

  When 6
   [M:RUB2]LIBTX1 = mess(6,10708,1)    #% salarial
   [M:RUB2]LIBTX2 = mess(7,10708,1)    #% patronal
   Actzo [M:RUB2]10
   Effzo [M:RUB2]15,20
   Grizo [M:RUB2]15,20

 Endcase
Endif
Affzo [M:RUB2]LIBTX1,LIBTX2

