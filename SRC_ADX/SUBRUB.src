#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier GRUBRIQ
Raz GPILOBJ
Call OBJET("RUB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "VERF_ANU"    : Gosub VERF_ANU
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "STATUT"      : Gosub STATUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "FILTRE"      : Gosub FILTRE
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "AVANT_MODFIC": Gosub AVANT_MODFIC
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FERME"       : Gosub FERME
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
 When "ANNULE"      : Gosub ANNULE
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "STYLE"       : Gosub STYLE #LIPET - 2017-06-09 - X3-44304
Endcase
Return

$AVANT_OUVRE
#0=inactif...
If func AFNC.ACTIV('TXB')>0 & func AFNC.ACTIV('TXB')<3
 OK=0
 #Code activité TXB : Dimension écran insuffisante (3 minimum)
 GMESSAGE=mess(217,10703,1)
Endif
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
# To disable the management of UPDTICK field (SAM #84719)
Local Integer ANOUPDTICK
[L]ANOUPDTICK=1
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Return


#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:RUB]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:RUB0]LEG)>=0 : [M:RUB0]LEG=[F:RUB]LEG: Endif
 GCURLEG=[F:RUB]LEG
 # Else we need to update GCURLEG because we erased it in $AS_COD
Else
 If dim([M:RUB0]LEG)>=0
  GCURLEG=[M:RUB0]LEG
 Elsif GLEGFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$VERF_ANU
If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
Local Integer K1
Filter [HSP] Where LEG=GCURLEG & RUB=CODE & TYP<>6
Read [HSP] First
Filter [HSP]
If !fstat
 GMESSAGE = mess(22,115,1)-"HISTOPAYE\"+mess(55,123,1)-":"-[F:HSP]EMP+"\"+mess(1,115,1)
 OK = 0 : Return
Endif
For [LPA]LPA0 Where LEG=GCURLEG
 K1 = find(CODE,[F:LPA]RUBCOD(0..[F:LPA]NBRCOL-1))
 If K1 & [F:LPA]TYPAMT(K1-1)<6
  GMESSAGE = mess(22,115,1)-"LIVREPAYE\"+mess(55,123,1)-":"-[F:LPA]COD+"\"+mess(1,115,1)
  OK = 0 : Break
 Endif
Next
Return

$AP_CHANGE
Call CHGTEXTRA("RUBRIQUE","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call CHGTEXTRA("RUBRIQUE","DESSHO",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA

If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP] : Endif
If clalev([F:LPA])=0  : Local File LIVREPAYE [LPA] : Endif
If clalev([F:BCB])=0  : Local File BCLOB     [BCB] : Endif
If clalev([F:BCB2])=0 : Local File BCLOB     [BCB2]: Endif
Local Integer K1 , RW
Call DEBTRANS From GLOCK
Gosub CHG_HSP
If GOK<1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub CHG_LPA
If GOK<1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub CHG_BCB
If GOK<1 : Return : Endif
Call CHANGE(1,OCODE,NCODE) From CHGPLAN
Call SETPAR From GENPLAN
Return

$STYLE

#LIPET - 2017-06-09 - X3-44304 - START
 Gosub DISPLAY_HIDE From SUBRUBLEG
 Affzo [M:RUB5]
#LIPET - 2017-06-09 - X3-44304 - END
Return

$ANNULE
Call SUPTEXTRA("RUBRIQUE","DES",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("RUBRIQUE","DESSHO",SUPP,[L]CODE) From ATEXTRA
Return

$CHG_HSP
GOK = 1
Trbegin [HSP]
 For [HSP]HSP0 Where LEG=GCURLEG & RUB=OCODE & TYP<>6 With Stability
  [F:HSP]RUB=NCODE
  Rewrite [HSP]
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_HSP : Endif
Commit
Return

$AB_HSP
Rollback
Return

$CHG_LPA
GOK = 1
Trbegin [LPA]
 For [LPA]LPA0 Where LEG=GCURLEG
  RW = 0
  For K1=1 To [F:LPA]NBRCOL
   If [F:LPA]TYPAMT(K1-1)<=6 & [F:LPA]RUBCOD(K1-1)=OCODE
    [F:LPA]RUBCOD(K1-1) = NCODE
    RW = 1
   Endif
  Next K1
  If RW
   Rewrite [LPA]
   If fstat
    GOK = 0 : Call FSTA("LPA") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_LPA : Endif
Commit
Return

$AB_LPA
Rollback
Return

$CHG_BCB
GOK = 1
Trbegin [BCB],[BCB2]
 For [BCB]BCB0 Where IDENT4=OCODE &  CODBLB="VARTXT" With Stability
  Raz [F:BCB2]
  [F:BCB2]=[F:BCB]
  [F:BCB2]IDENT4=NCODE
  Write [BCB2]
  If fstat
   GOK = 0 : Call FSTA("BCB2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_BCB : Endif
 Delete [BCB] Where IDENT4=OCODE &  CODBLB="VARTXT"
Commit
Return

$AB_BCB
Rollback
Return

$APRES_MOD
If [L]UTEXVRI
 Call MESSAGE(mess(144,10702,1)) From GESECRAN
 # Suite à la modification du texte associé, des bulletins de paie ont été repassés à l'état Calculé
Endif
UPDROW=0
$APRES_CRE
For I=0 To dim([L]OTEXVRI)-1 : [L]OTEXVRI(I)=[F:RUB]TEXVRI(I) : Next
$AP_ANNULE
Call SETPAR From GENPLAN
Return

$APRES_MODIF
If UPDROW=0 & zoncou="ROW"
  UPDROW=2
Else
  UPDROW=1
Endif
Gosub INIPRF
Return

$OUVRE
If clalev ([F:CUM])=0  : Local File CUMUL    [CUM]  : Endif
If clalev ([F:PRF])=0  : Local File PROFIL   [PRF]  : Endif
If clalev ([F:GRI])=0  : Local File GRILLE   [GRI]  : Endif
If clalev ([F:CRB])=0  : Local File CALRUB   [CRB]  : Endif
If clalev ([F:RUB2])=0 : Local File RUBRIQUE [RUB2] : Endif
If clalev([F:DCH])=0 : Local File DECCHARGE [DCH] : Endif

Local Integer INDIC
Local Char    WRUB(GLONRUB) , WCHAINE(250) , WZONE(10)
Local Char    CRITRUB(250), OTEXVRI([V]GLONVRA)(dim([F:RUB]TEXVRI)), DATPAY(8)
Local Integer DEFILE
Local Integer BROWRG
Local Char    BOXRG(10)
Local Libelle UTEXVRI
#LIPET - 2017-06-09 - X3-44304 - START
Call MANAGE_LOCALISATION("ORUB") From DIVPAYE
#LIPET - 2017-06-09 - X3-44304 - END
#76876 don't add a record in RUBHIS if only row has been updated.
Local Integer  UPDROW :#1 = the field row is not the only updated, 2 = the field row is the only updated.
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# Obsolete since reverse order of main index
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONRUB) : Endif
VCOD = CLE1
Return

$OUVRE_BOITE
BROWRG = find("RU0",OBJLIS(1..8)) : BOXRG = "GAU_CHE"+num$(BROWRG)
If instr(1,GUSRAUZ,"1")
 DEFILE = 2
Else
 DEFILE = 1
Endif
Return

$SETBOUT
Raz ETAMEN
If GREP=""
 CHMEN = "12"
 If WCHAINE<>"" : CHMEN += "3" : Endif
 Gosub SET_BOUT_SPE From GSAISIE
Endif
#39925
# Else
If GREP<>"" | !CLECUR
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
If DEFILE=1
 CHMEN += "5"
Else
 CHMEN += "4"
Endif
If [M:RUB1]TYPRUB=6
 CHMEN +="67"
Else
 Call VIREBOUT(CHAINE,"67") From GOBJET
Endif
# 39925
If GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
 Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
#
Gosub SET_BOUT_SPE From GSAISIE
[M:RUB0]DEFILE = DEFILE
Return

$AVANTBOUT
## Tunnel sur Déclaratif de charges: Pour afficher un code contenant la rubrique
If BOUT="7"
 Raz GBIDC1
 Filter [DCH] Where find([M:RUB0]COD,CODRUB(0..dim([F:DCH]CODRUB)-1))
 Read [DCH]DCH0 First
 If !fstat
  GBIDC1 = [F:DCH]CODDCC
 Endif
 Filter [DCH]
Endif
Return

$FIN_ACTION
If REPONSE=GSTASEL
 Case BROWRG
  When 1 : Gosub REMPLIT_1 From WGORUB
  When 2 : Gosub REMPLIT_2 From WGORUB
  When 3 : Gosub REMPLIT_3 From WGORUB
  When 4 : Gosub REMPLIT_4 From WGORUB
  When 5 : Gosub REMPLIT_5 From WGORUB
  When 6 : Gosub REMPLIT_6 From WGORUB
  When 7 : Gosub REMPLIT_7 From WGORUB
  When 8 : Gosub REMPLIT_8 From WGORUB
 Endcase
 Return
Endif
Case BOUT
 When "1"
  Call SETPAR From GENPLAN
  Gosub RELIT From GOBJSUB
  Gosub REMPLIT_ From WGORUB
 When "2"
  Goto TROUVE
 When "3"
  WRUB = ""
  Call RECHERCHE(WCHAINE,WRUB,WZONE)
  Goto TROUVE
Endcase
Return

$TROUVE
If WRUB<>""
 Read [RUB]RUB0 = GCURLEG;WRUB
 Gosub SET_CLE From GOBJSUB
 If VERROU : Gosub DEVERROU From GOBJET : Endif : #LS Unlock verrou quand expression suivante
 Gosub RELIT From GOBJSUB
 Case WZONE
  When "CNDCAL"    : SUIZON = "[RUB1]CNDCAL"
  When "BAS"       : SUIZON = "[RUB2]BAS"
  When "RAT1"      : SUIZON = "[RUB2]RAT1"
  When "RAT2"      : SUIZON = "[RUB2]RAT2"
  When "AMTMAX(0)" : SUIZON = "[RUB2]AMTMAX(0)"
  When "AMTMAX(1)" : SUIZON = "[RUB2]AMTMAX(1)"
  When "AMTMAX(2)" : SUIZON = "[RUB2]AMTMAX(2)"
 #Tax Band
  When "AMTMAX(3)" : SUIZON = "[RUB2]AMTMAX(3)"
  When "AMTMAX(4)" : SUIZON = "[RUB2]AMTMAX(4)"
  When "AMTMAX(5)" : SUIZON = "[RUB2]AMTMAX(5)"
  When "AMTMAX(6)" : SUIZON = "[RUB2]AMTMAX(6)"
  When "AMTMAX(7)" : SUIZON = "[RUB2]AMTMAX(7)"
  When "AMTMAX(8)" : SUIZON = "[RUB2]AMTMAX(8)"
  When Default     : SUIZON = "[RUB4]"+WZONE
 Endcase
Else
 GERR = 2 : GMESSAGE = WCHAINE+"\"+mess(37,10703,1) : # Chaîne non trouvée
Endif
Return

$RAZCRE
Raz GCURLEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Gosub INIPRF
Return

$RAZDUP
Gosub INIPRF
Return

$INIPRF
If zoncou='LEG'
 Effzo [RUB3]10
 Gosub CHARGE_PROFIL
 Affzo [RUB3]10
Endif
Return

$INICRE
$INIMOD
[F:RUB]PRNFLG(0) = [M:RUB5]PRNFLG1
[F:RUB]PRNFLG(1) = [M:RUB5]PRNFLG2
## LS 20/02/02
If [F:RUB]TMPCAL=2 | [F:RUB]TYPRUB=5 | ([F:RUB]DEC<>0 & [F:RUB]DEC<GARODEV)
  Raz [F:RUB]NBRACC, [F:RUB]SAC, [F:RUB]ACC, [F:RUB]TYPAMT, [F:RUB]SNS, [F:RUB]DETEMP
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
#MASHI - 18-12-2017 X3-63067 - start
#If dim([F:RUB]FLGCPT)>=0 :  [F:RUB]FLGCPT=1 : Endif
If GCURLEG<>'BRI' and dim([F:RUB]FLGCPT)>=0 :  [F:RUB]FLGCPT=1 : Endif
#MASHI - 18-12-2017 X3-63067  - END
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Endif
Call TOKEN([F:RUB]CNDCAL)
Call TOKEN([F:RUB]BAS)
Call TOKEN([F:RUB]RAT1)
Call TOKEN([F:RUB]RAT2)
Call TOKEN([F:RUB]TBLFRM(0))
Call TOKEN([F:RUB]TBLFRM(1))
Call TOKEN([F:RUB]TBLFRM(2))
For I=0 To dim([F:RUB]ITVAMT)-1
 Call TOKEN([F:RUB]ITVAMT(I))
Next I
#Tax Band
#Call TOKEN([F:RUB]AMTMAX(0))
#Call TOKEN([F:RUB]AMTMAX(1))
#Call TOKEN([F:RUB]AMTMAX(2))
For I=0 To dim([F:RUB]AMTMAX)-1
 Call TOKEN([F:RUB]AMTMAX(I))
Next
Call TOKEN([F:RUB]DESPRN)
Return

Subprog TOKEN(CHAINE)
Variable Char    CHAINE()
If CHAINE<>""
 Local Char TOKEN(250)
 TOKEN = vireblc(format$("KT:250X",CHAINE),2)
 If CHAINE<>TOKEN
  CHAINE = TOKEN
 Endif
Endif
End

$FILGAUCHE
I = instr(1,FILRAP,"[F:RUB]ROW=")
If I
 FILRAP = left$(FILRAP,I+9)+">="+right$(FILRAP,I+11)
 J = instr(1,CRITERE,"[F:RUB]ROW=")
 If J
  CRITERE = left$(CRITERE,J+9)+">="+right$(CRITERE,J+11)
 Endif
Endif
If FILTRE<>""
 Call ADDCRIT(FILGAUSUP,IFILGAUSUP,"FILGAUSUP","("+FILTRE+")","&") From GOBJSUB
Endif
Return

$CHARGE_PROFIL
nolign = 0
For [PRF]PRF0 Where LEG=GCURLEG
 nolign += 1
 [M:RUB3]PRFCOD(nolign-1) = [F:PRF]PRFCOD
 Call LECTEXTRA([M:RUB3]PRFLIB(nolign-1),"PROFIL","PRFDES",GCURLEG,[F:PRF]PRFCOD) From ATEXTRA
Next
[M:RUB3]NBRPRF = nolign
Return

$FILTRE
If GFONCTION<>"GESRUB" | dim(REPONSE)<=0 : Return : Endif
If REPONSE<>GSTASUI & REPONSE<>GSTAPRE & REPONSE<>GSTAFIR & REPONSE<>GSTALAS
 Return
Endif
If DEFILE=1
 INDGES =1
Else
 INDGES=2
Endif
Return


$STATUT
Case BOUT
 When "4"
  DEFILE = 1
 When "5"
  DEFILE = 2
Endcase
[M:RUB0]DEFILE = DEFILE
Return



$LIENS
GCURLEG = [F:RUB]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"RUBRIQUE","DES",GCURLEG,[M]COD) From ATEXTRA
Call LECTEXTRA([M]DESSHO,"RUBRIQUE","DESSHO",GCURLEG,[M]COD) From ATEXTRA
UPDROW=0
If [F:RUB]TYPRUB=5
 #Tax Band
 #[M]NBRAMT = len(mess(0,10338,1))
  [M]NBRAMT = dim([F:RUB]AMTMAX)
Else
 [M]NBRAMT = 0
Endif

######### pour charger le profil

Gosub CHARGE_PROFIL
For nolign=1 To [M:RUB3]NBRPRF
 Look [CRB]CRB1 = [M:RUB3]PRFCOD(nolign-1);[F:RUB]LEG;[F:RUB]COD
 If fstat<=2
  [M:RUB3]CALC(nolign-1) = 2 :#oui
 Else
  [M:RUB3]CALC(nolign-1) = 1 :#non
 Endif
#LIPET - 2017-06-09 - X3-44304 - START
 Gosub STYLE
#LIPET - 2017-06-09 - X3-44304 - END
Next

################## mettre les grizos

Call GRISE_TYPRUB([F:RUB]TYPRUB)
Call GRISE_TMPCAL([F:RUB]TMPCAL)
Call GRISE_AMTPRN([F:RUB]AMTPRN)
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Call GRISE_TUNCPT ([F:RUB]FLGCPT)
# JOJAC - 2016-02-24 - Req 114309 US 31 - END

#################### pour charger les cumuls

For indice=0 To dim([F:RUB]CUM)-1
 If [F:RUB]CUM(indice)<>""
  [M:RUB2]CUM(indice) = [F:RUB]CUM(indice)
  Read [F:CUM]CUM0 = GCURLEG;[F:RUB]CUM(indice)
  If !fstat
   [M:RUB2]CUMPER(indice) = [F:CUM]CUMPER
  Else
   Raz [M:RUB2]CUMPER
  Endif
 Endif
Next indice

##############pour charger  les grilles

If [F:RUB]TYPRUB = 7 : # Grille
 Read [GRI]GRI0 = [F:RUB]TBLCOD
 [M:RUB4] = [F:GRI]
 If [F:RUB]TBLCOL<>0 & [F:RUB]TBLCOL<=2
  [M:RUB4]COLDES = [F:GRI]COLDES([F:RUB]TBLCOL-1)
 Endif
 Call GRISE_TBLCOD([F:RUB]TBLCOD)
Endif

#Tax Band
#For I=0 To len(mess(0,10338,1))-1
For I=0 To dim([F:RUB]AMTMAX)-1
 [M:RUB2]AMTMAX(I) = [F:RUB]AMTMAX(I)
 [M:RUB2]CUMMAX(I) = [F:RUB]CUMMAX(I)
 [M:RUB2]CUMAMT(I) = [F:RUB]CUMAMT(I)
Next I

[M:RUB5]PRNFLG1 = [F:RUB]PRNFLG(0)
[M:RUB5]PRNFLG2 = [F:RUB]PRNFLG(1)

###############pour mémoriser TEXVRI

For I=0 To dim([L]OTEXVRI)-1 : [L]OTEXVRI(I)=[F:RUB]TEXVRI(I) : Next

#89241
#JASMI - 2017-09-07 - X3-49836 - START
#If val([M]CAI)>0 & [M]CAILIB>0
#  [M]CAIVAL=mess(val([M]CAI),[M]CAILIB,1)
#Else
#  [M]CAIVAL=""
#Endif
#JASMI - 2017-09-07 - X3-49836 - END
#end 89241
Return

$MODIF
Gosub TEXTRA
Raz [L]DATPAY, [L]UTEXVRI
# SEGAY  US 2331-88174 BULDEM
Gosub INIT_ISDEMAT From SUBVEP
If ![L]WISDEMAT : Columns [VEP] (PYRDAT, EMP, STA, BUL) : Else : Columns [VEP] (PYRDAT, EMP, STA, BUL, FLGDEMAT) : Endif
Columns [VEP] (PYRDAT, EMP, STA)
For I=0 To dim([L]OTEXVRI)-1
 If !find([L]OTEXVRI(I),"",[F:RUB]TEXVRI(I))
  If [L]DATPAY=""
   [L]DATPAY= gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  Endif

  # Bulletins du mois de paye courant calculés ou imprimés et non comptabilisés :
  # -> On met à jour la clef du commentaire et on les passe à l'état Calculé

  Filter [BCB] Where find(CODBLB,"VARTXT","VEPTXT")<>0 & IDENT1=[L]OTEXVRI(I)
&                  & IDENT3=[L]DATPAY & IDENT4=[F:RUB]COD
  If rowcount([BCB])

   For [VEP]VEP4 Where PYRDAT=gdat$([L]DATPAY) & STA>1 & PST<2
    [V]GCLE="[VAR/VEP]TXT"-[L]OTEXVRI(I)-[F:VEP]EMP-[L]DATPAY-[F:RUB]COD
    If [F:RUB]TEXVRI(I)>""
     Update [BCB] Where IDENT2=[F:VEP]BUL With IDENT1=[F:RUB]TEXVRI(I)
     J=adxuprec
    Else
     Delete [BCB] Where IDENT2=[F:VEP]BUL
     J=adxdlrec
    Endif
    If fstat=1
     [V]GOK  =-1
     [V]GLOCK="$BCLOB"-[V]GCLE
     Break 2
    Elsif fstat
     [V]GOK=0
     Call RSTA("BCB",[V]GCLE) From GLOCK
     Break 2
    Endif

    If J & [F:VEP]STA=3
     [F:VEP]STA=2
#JOJAC -    2016-03-08 REQ114309 US31 - START
#     If [L]WISDEMAT : [F:VEP]FLGDEMAT=1 : Endif :#88174 BULDEM
#JOJAC -    2016-03-08 REQ114309 US31 - END
     Rewrite [VEP] Curr
     If fstat=1
      [V]GOK  =-1
      [V]GLOCK="$VALEMP"-[F:VEP]EMP-[L]DATPAY
      Break 2
     Elsif fstat
      [V]GOK=0
      Call FSTA("VEP") From GLOCK
      Break 2
     Endif
     [L]UTEXVRI=1
    Endif
   Next
  Endif
 Endif
Next
Columns [VEP]
Filter  [BCB]
If [V]GOK<1 : Return : Endif
Goto CREATION

$CREATION
Gosub TEXTRA
#################################
#######creation de l'enregistrement dans la table gcalrub pour profil
For indice=0 To [M:RUB3]NBRPRF-1
 Read [CRB]CRB0 = [F:RUB]COD;[M:RUB3]PRFCOD(indice);[F:RUB]LEG
 If fstat
  If [M:RUB3]CALC(indice)=2
   [F:CRB] = [M:RUB0]
   [F:CRB] = [M:RUB3]
   [F:CRB]COD    = [M:RUB0]COD
   [F:CRB]LEG    = GCURLEG
   [F:CRB]PRFCOD = [M:RUB3]PRFCOD(indice)
   Write [CRB]
   If fstat : GOK = 0 : Call FSTA("CRB") From GLOCK : Break : Endif
  Endif
 Else
  If [M:RUB3]CALC(indice)=1
   GCLE = [M:RUB0]COD-[M:RUB3]PRFCOD(indice)-GCURLEG
   Delete [CRB] Where [F:CRB]COD=[M:RUB0]COD & [F:CRB]PRFCOD=[M:RUB3]PRFCOD(indice) & LEG=GCURLEG
   If fstat=1  : GOK = -1 : GLOCK = "$CALRUB"-GCLE : Break
   Elsif fstat : GOK = 0  : Call RSTA("CRB",GCLE) From GLOCK : Break
   Endif
  Elsif [F:CRB]ROW<>[F:RUB]ROW
   [F:CRB]ROW = [F:RUB]ROW
   Rewrite [CRB]
   If fstat : GOK = 0 : Call FSTA("CRB") From GLOCK : Break : Endif
  Endif
 Endif
Next
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("RUBRIQUE","DES",CLECUR1,"","RUBRIQUE","DES",GCURLEG,[F:RUB]COD)  From ATEXTRA
 Call DUPTEXTRA("RUBRIQUE","DESSHO",CLECUR1,"","RUBRIQUE","DESSHO",GCURLEG,[F:RUB]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"RUBRIQUE","DES",GCURLEG,[F:RUB]COD) From ATEXTRA
Call MAJTEXTRA([M]DESSHO,"RUBRIQUE","DESSHO",GCURLEG,[F:RUB]COD) From ATEXTRA
Return


#54868
#################################
$VERIF
If clalev ([F:RUB3])=0 : Local File RUBRIQUE [RUB3] : Endif
If [M:RUB5]ATTHIL<>""
 Filter [F:RUB3] Where ATTHIL=[M:RUB5]ATTHIL and LEG=GCURLEG
 If GNBRUBATT<rowcount([F:RUB3])
  # Trop de rubriques paramétrées sur la zone d'attestation maladie
  GMESSAGE =mess(43,10708,1)-":"-[M:RUB5]ATTHIL
  OK = 0 : Return
 Endif
Endif
If [M:RUB5]ATTAT<>""
 Filter [F:RUB3] Where ATTAT=[M:RUB5]ATTAT and LEG=GCURLEG
 If GNBRUBATT<rowcount([F:RUB3])
  # Trop de rubriques paramétrées sur la zone d'attestation AT
  GMESSAGE =mess(44,10708,1)-":"-[M:RUB5]ATTAT
  OK = 0 : Return
 Endif
Endif
Return

#DBA : historisation des rubriques de paie avant modifications
#Transclass de [M] vers [F] pas encore effectué...
#################################
$AVANT_MODFIC
If UPDROW=2 : Return : Endif :#76876 not usefull to save in RUBHIS if only row has been updated.
If func AFNC.ACTIV("MAS")=0 | GADONIX=2 : Return : Endif
If clalev([F:RUH])=0 : Local File RUBHIS [RUH]    : Endif
If clalev([F:CRH])=0 : Local File CALRUBHIS [CRH] : Endif
GOK=1
Read [F:RUH]RUH0=[F:RUB]LEG;[F:RUB]COD;datesyst
If !fstat
 Delete [CRH] Where LEG=[F:RUH]LEG & COD=[F:RUH]COD & DAT=datesyst
 If fstat<>1
  For [CRB]CRB0 Where COD=[F:RUB]COD & LEG=[F:RUB]LEG
   Raz[F:CRH]
   [F:CRH]=[F:CRB]
   [F:CRH]DAT=datesyst
   Write [F:CRH]
   If fstat : GOK = 0 : Call FSTA("CRH") From GLOCK : Endif
  Next
 Endif
 If GOK
  [F:RUH]=[F:RUB]
  [F:RUH]DAT=datesyst
#JASMI - 2016-08-31 - X3PEOP-1320 - START
#  Call LECTEXTRA([F:RUH]DES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
#  Call LECTEXTRA([F:RUH]DESSHO,"RUBRIQUE","DESSHO",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
#JASMI - 2016-08-31 - X3PEOP-1320 - END
  Rewrite [F:RUH]
  If fstat : GOK = 0 : Call FSTA("RUH") From GLOCK : Endif
 Endif
Else
 For [CRB]CRB0 Where COD=[F:RUB]COD & LEG=[F:RUB]LEG
  Raz[F:CRH]
  [F:CRH]=[F:CRB]
  [F:CRH]DAT=datesyst
  Write [F:CRH]
  If fstat : GOK = 0 : Call FSTA("CRH") From GLOCK : Endif
 Next
 If GOK
  Raz[F:RUH]
  [F:RUH]=[F:RUB]
  [F:RUH]DAT=datesyst
#JASMI - 2016-08-31 - X3PEOP-1320 - START
#  Call LECTEXTRA([F:RUH]DES,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
#  Call LECTEXTRA([F:RUH]DESSHO,"RUBRIQUE","DESSHO",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
#JASMI - 2016-08-31 - X3PEOP-1320 - END
  Write [F:RUH]
  If fstat : GOK = 0 : Call FSTA("RUH") From GLOCK : Endif
 Endif
Endif
Return


########################################
## Sélection cumuls
########################################
$SEL_TABLE
Case TABLE
 When "SELCUMRUB"
  OBJET = "CUM"
  START = "CUMCOD"
  If dim([M:MSR0]COD)>=0
   CRITERE = "CUMTMP<>2"
  Else
   If [M:RUB1]TMPCAL=2
    CRITERE = "CUMTMP=2"
   Else
    If [M:RUB1]TYPRUB=5 & [M:RUB2]REG=2
     CRITERE = "CUMTMP<>2"
    Endif
   Endif
  Endif
  ORDRE = "CUMCOD"
  # Obsolete since reverse order of main index
 When "SELRUB"
    If clalev ([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
#JASMI - START
    Filter [F:RUB]
#JASMI - END
    OBJET="RUB"
    START = "[F:RUB]COD"
    #JASMI - START
    EXPSTART  = "[F:RUB]COD>='"+VALEUR+"'"
    #JASMI - END
    #Filter based on code legislation
    #JASMI - START
#    If PARAM(1)<>""
#     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:RUB]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
#    Endif
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:RUB]LEG="'+GCURLEG+'" | [F:RUB]LEG="")',"&") From GOBJSUB
    #JASMI - END
    If PARAM(2)<>""
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(2),"&") From GOBJSUB
    Endif
#   # Object's Options in selection
#   If GUSER ="DBA"    :#To test
#    If clalev([F:AMZ])=0 :  Local File AMSKZON [AMZ] : Endif
#    Read [F:AMZ]CODE=maskcou;zoncou
#    If !fstat
#     OPTIONS=[F:AMZ]OPTOBJ
#    Else
#     Raz OPTIONS
#    Endif
#    If OPTIONS<>""
#     Gosub OPTIONS From ="WO"+OBJET
#     For I=1 To NBCOND
#      If instr(1,OPTIONS,OPT(I))
#       Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
#      Endif
#     Next I
#    Endif
#   Endif
Endcase
Return

########################################
####### Ecran RUB0
########################################
Subprog C_ROW(VALEUR)
Variable Decimal VALEUR
Read [RUB2]RUB1 = GCURLEG;VALEUR
If !fstat & [F:RUB2]COD<>[M]COD
 GMESSAGE = mess(9,10702,1)-":"-[F:RUB2]COD : # Rang déjà existant
 mkstat = 2 : End
Endif
End

########################################
####### Ecran RUB1
########################################
Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] and VALEUR<[M:RUB1]VLYSTR
 mkstat=2
Endif
End

Subprog C_CNDCAL(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog C_TYPRUB(VALEUR)
Variable Integer    VALEUR()
# 50550 : La longueur d'une varible est de 12 caractères max(TA_xxxxxxxxx)
#53612
#If VALEUR=5 & len([M:RUB0]COD)>9 : # Assiette
If (GREP="C" | GREP="D") & VALEUR=5 & len([M:RUB0]COD)>9 : # Assiette
 # La longueur du code d'une rubrique de type "assiette" ne doit pas dépasser 9 caractères
 GMESSAGE = mess(42,10708,1)
 mkstat=2 : End
Endif
# fin 50550
Call GRISE_TYPRUB(VALEUR)
End

Subprog C_TMPCAL(VALEUR)
Variable Integer VALEUR
Call GRISE_TMPCAL(VALEUR)
End

#79833
Subprog C_DEC(VALEUR)
Variable Decimal VALEUR
If VALEUR=[M]DEC : End : Endif    :# Pas de changement : pas de control
If VALEUR<>0 & VALEUR<GARODEV
 Local Integer OK
 OK = 2
 #Rubrique non traitée en calcul d'OD : Arrondi inférieur à celui de la devise locale
 Call AVERTIR (mess(45,10708,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End

Subprog AS_RGL(VALEUR)
Variable Char    VALEUR()
If [M]TYPRUB<>10 : mkstat = 1 : End : Endif
End

