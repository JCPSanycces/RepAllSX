######################################################################################
## Section automatically added (screen RUB5) 05/26/2017 16:01:58 (THRAM)
######################################################################################
Subprog C_DSYPIO(VALEUR)
Variable Decimal VALEUR

If clalev([F:RUB1])=0 : Local File RUBRIQUE [RUB1] : Endif
#LIPET - 2017-06-09 - X3-44304 - START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
Filter [F:RUB1] Where COD <> [M:RUB0]COD and LEG = GCURLEG and DSYPIO = VALEUR
If rowcount([F:RUB1]) > 0
  GMESSAGE=mess(251,10702,1)-":"-GCURLEG
  mkstat=2
  End
Endif
Endif
#LIPET - 2017-06-09 - X3-44304 - END
End


