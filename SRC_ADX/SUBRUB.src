##############################################################################
## Liste des lignes des déclaratifs de charges qui contiennent la rubrique
##############################################################################
Subprog DECCHARGE(COD)
Value Char    COD()
Local Integer NBDEC
Local Char VTITLE
If clalev([F:DCH])=0 : Local File DECCHARGE [DCH] : Endif
Filter [DCH] Where find([L]COD,CODRUB(0..dim([F:DCH]CODRUB)-1))
For [DCH]
 Call LECTEXTRA([L]VTITLE,"DECCHARGE","DESDCC",GCURLEG,[F:DCH]CODDCC) From ATEXTRA
 # Code : xxx yyyyyyyyyyyyy Caisse : zzz
#JASMI - 2017-09-07 - X3-49836 - START
# Call ECR_TRACE(format$("K:50X",mess(37,100,1)+": "+[F:DCH]CODDCC+space$(1)+[L]VTITLE)
#&               +mess(127,10703,1)+": "+mess([F:DCH]CAI,[F:DCH]CAILIB,1),0) From GESECRAN
 Call ECR_TRACE(format$("K:50X",mess(37,100,1)+": "+[F:DCH]CODDCC+space$(1)+[L]VTITLE)
&               +mess(127,10703,1)+": "+[F:DCH]CAI,0) From GESECRAN
#JASMI - 2017-09-07 - X3-49836 - END
 NBDEC +=1
Next
Filter [DCH]
If NBDEC=0
 # Rubrique non paramétrée dans les lignes des déclaratifs de charges
 Call ECR_TRACE(mess(125,10703,1),0) From GESECRAN
Else
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 # Nombre de lignes contenant la rubrique
 Call ECR_TRACE(mess(126,10703,1)-[L]COD-":"-num$(NBDEC),0) From GESECRAN
Endif
End


