#Affzo [M:RUB2]CAILIB
#JASMI - 2017-09-07 - X3-49836 - END

End

########################################
Subprog GRISE_TMPCAL(VALEUR)
Value Integer VALEUR
If VALEUR=2
 If [M:RUB1]TYPRUB=5
  [M:RUB2]REG = 1
  Affzo [M:RUB2]REG
  Grizo [M:RUB2]REG
 Endif
 Effzo [M:RUB5]15,25,35,45,55,60,65,70
 Grizo [M:RUB5]15,25,35,45,55,60,65,70
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Call GRISE_FLGCPT(0)
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Else
 If [M:RUB1]TYPRUB=5
  Actzo [M:RUB2]REG
  Effzo [M:RUB5]15,25 : Grizo [M:RUB5]15,25
  Actzo [M:RUB5]35,45,55,60,65,70
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Call GRISE_FLGCPT(0)
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Else
  Actzo [M:RUB5]15,25,35,45,55,60,65,70
  #Si rubrique non imprimable -> Grize
  If [M:RUB5]AMTPRN<2
   Effzo [M:RUB5]LFEBEF,LFEAFT,DESPRN,TEXVRI,PRNGRP,PRNBAS
   Grizo [M:RUB5]LFEBEF,LFEAFT,DESPRN,TEXVRI,PRNGRP,PRNBAS
  Endif
# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Call GRISE_FLGCPT(1)
# JOJAC - 2016-02-24 - Req 114309 US 31 - END
Endif
Endif
End

# JOJAC - 2016-02-24 - Req 114309 US 31 - START
Subprog GRISE_FLGCPT(POK)
Value Integer POK
If dim([M:RUB1]FLGCPT)<0 : End : Endif
If POK
 Actzo [M:RUB1]FLGCPT
Else
 [M:RUB1]FLGCPT=1
 Grizo [M:RUB1]FLGCPT
Endif
Affzo [M:RUB1]FLGCPT
End

Subprog AM_FLGCPT(VALEUR)
Variable Integer VALEUR
Call GRISE_TUNCPT (VALEUR)
End

Subprog GRISE_TUNCPT (VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:RUB1]TUNCPT
Else
 Grizo [M:RUB1]TUNCPT
Endif
End
# JOJAC - 2016-02-24 - Req 114309 US 31 - END

################################################
## Renumérotation et recherche
################################################
$CONTROLE
Case GACTION
 When "RUBNUM"
  TMP = 1
 When "RUBRECH"
  TMP = 1
Endcase
Return

$EXEC
Case GACTION
 When "RUBNUM"
  Local Integer STAT
  Call RENUM([M:DIA]ROWDEB,[M:DIA]ROWFIN,[M:DIA]NEWROW,[M:DIA]STP,STAT)
  If STAT
   Call ERREUR(GMESSAGE) From GESECRAN
  Endif
 When "RUBRECH"
  If [M:DIA]EXPR<>""
   PARAM(2) = vireblc(format$("KT:250X",[M:DIA]EXPR),2)
   Call RECHERCHE(PARAM(2),PARAM(1),PARAM(3))
  Endif
 When "LISDECCHG"
  # Lignes des déclaratifs de charges qui contiennent la rubrique
  Call OUVRE_TRACE(mess(124,10703,1)-[M:RUB0]COD) From LECFIC
  Call DECCHARGE([M:RUB0]COD)
  Call FERME_TRACE From LECFIC
  TRA = 1
Endcase
Return

Subprog RECHERCHE(EXPR,RUB,ZONE)
Value    Char EXPR
Variable Char RUB()
Variable Char ZONE()
Local Integer I , OK
RUB = ""
If [M:RUB0]DEFILE=1
 For [RUB]RUB0 Where LEG=GCURLEG and COD>[M:RUB0]COD
  Gosub RECH
  If RUB<>"" : Break : Endif
 Next
 If RUB=""
  For [RUB]RUB0 Where LEG=GCURLEG and COD<=[M:RUB0]COD
   Gosub RECH
   If RUB<>"" : Break : Endif
  Next
 Endif
Else
 For [RUB]RUB1 Where LEG=GCURLEG and ROW>[M:RUB0]ROW
  Gosub RECH
  If RUB<>"" : Break : Endif
 Next
 If RUB=""
  For [RUB]RUB1 Where LEG=GCURLEG and ROW<=[M:RUB0]ROW
   Gosub RECH
   If RUB<>"" : Break : Endif
  Next
 Endif
Endif
End

$RECH
Call RECHEXP(EXPR,[F:RUB]CNDCAL,OK)    : If OK : ZONE = "CNDCAL"    : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]BAS,OK)       : If OK : ZONE = "BAS"       : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]RAT1,OK)      : If OK : ZONE = "RAT1"      : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]RAT2,OK)      : If OK : ZONE = "RAT2"      : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]TBLFRM(0),OK) : If OK : ZONE = "TBLFRM(0)" : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]TBLFRM(1),OK) : If OK : ZONE = "TBLFRM(1)" : RUB = [F:RUB]COD : Return : Endif
Call RECHEXP(EXPR,[F:RUB]TBLFRM(2),OK) : If OK : ZONE = "TBLFRM(2)" : RUB = [F:RUB]COD : Return : Endif
#Tax Band
#Call RECHEXP(EXPR,[F:RUB]AMTMAX(0),OK) : If OK : ZONE = "AMTMAX(0)" : RUB = [F:RUB]COD : Return : Endif
#Call RECHEXP(EXPR,[F:RUB]AMTMAX(1),OK) : If OK : ZONE = "AMTMAX(1)" : RUB = [F:RUB]COD : Return : Endif
#Call RECHEXP(EXPR,[F:RUB]AMTMAX(2),OK) : If OK : ZONE = "AMTMAX(2)" : RUB = [F:RUB]COD : Return : Endif
For I=0 To dim([F:RUB]AMTMAX)-1
 Call RECHEXP(EXPR,[F:RUB]AMTMAX(I),OK) : If OK : ZONE = "AMTMAX("+num$(I)+")" : RUB = [F:RUB]COD : Return : Endif
Next
For I=0 To [F:RUB]ITVNBR-1
 Call RECHEXP(EXPR,[F:RUB]ITVAMT(I),OK) : If OK : ZONE = "ITVAMT("+num$(I)+")" : RUB = [F:RUB]COD : Break : Endif
Next I
Return

Subprog RECHEXP(EXPR,CHAINE,OK)
Value    Char    EXPR
Value    Char    CHAINE
Variable Integer OK
OK = instr(1,vireblc(format$("KT:250X",CHAINE),2),EXPR)
End

Subprog RENUM(RDEB,RFIN,NDEB,PAS,STA)
Value    Integer RDEB : # Rg début
Value    Integer RFIN : # Rg fin
Value    Integer NDEB : # Nouveau numéro début
Value    Integer PAS  : # Pas
Variable Integer STA  : # Statut de retour

If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:CRB])=0 : Local File CALRUB   [CRB] : Endif

Local Integer NUM

## 1ère vérif : est-ce qu'on a la place

STA = 0
NUM = 0
For [RUB]RUB1 Where LEG=GCURLEG & ROW>=RDEB & ROW<=RFIN
 If NUM=0
  NUM = NDEB
 Else
  NUM += PAS
 Endif
Next
#If NUM>9999
If NUM>99999
 STA = 1
 #GMESSAGE = "Dernier numéro > 9999"
 GMESSAGE = "Dernier numéro > 99999"
 End
Endif

## 2ème vérif : est-ce qu'on n'en écrase pas d'autres

For [RUB]RUB1 Where LEG=GCURLEG & ROW>=NDEB & ROW<=NUM
 If [F:RUB]ROW<RDEB or [F:RUB]ROW>RFIN
  STA = 2 : Break
 Endif
Next
If STA
 GMESSAGE = num$(NDEB)+"-"+num$(NUM)-"Plage de rangs déjà utilisée"
 End
Endif

## On y va

Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [RUB]
## Il faut être tout seul
 Lock [RUB]
 If fstat
  GMESSAGE = mess(10,100,1) : # Modification en cours
  GOK = 0 : Goto AB_TR1
 Endif
 Lock [CRB]
 If fstat
  GMESSAGE = mess(10,100,1) : # Modification en cours
  GOK = 0 : Goto AB_TR1
 Endif
 Filter [RUB] Where LEG=GCURLEG
## On commence par renuméroter en <0
 For [RUB]RUB1 Where ROW>=RDEB & ROW<=RFIN
  [F:RUB]ROW = -[F:RUB]ROW
  Rewrite [RUB]
  If fstat
   GOK = 0 : Call FSTA("RUB") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Filter [RUB] : Goto AB_TR1 : Endif
## On remet maintenant le nouveau numéro
 For [RUB]RUB1 Where ROW>=-RFIN & ROW<=-RDEB
  [F:RUB]ROW = NUM
  Rewrite [RUB]
  If fstat
   GOK = 0 : Call FSTA("RUB") From GLOCK : Break
  Endif
  NUM -= PAS
## Il faut renuméroter CALRUB
  For [CRB]CRB0 Where COD=[F:RUB]COD & LEG=[F:RUB]LEG
   [F:CRB]ROW = [F:RUB]ROW
   Rewrite [CRB]
   If fstat
    GOK = 0 : Call FSTA("CRB") From GLOCK : Break 2
   Endif
  Next
 Next
 Filter [RUB]
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
STA = 3
Return

#Tax band
Subprog CONTFRM(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK, LNGFOR : #47239
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0
# 47239
LNGFOR = len(FORMULE)

While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
    When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_": #65041
    Read [RUB]RUB0 = GCURLEG;CODE
    If fstat
     Read [RUB]RUB1 = GCURLEG;val(CODE)
     If !fstat
      FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
      I += len([F:RUB]COD)-len(CODE)
      CODE = [F:RUB]COD
     Else
      GERR = 1 : GMESSAGE = mess(11,10702,1) : Break :  # Rubrique inexistante
     Endif
    Endif
    #65041
    If OP<>"R_" & OP<>"B_"
     If [F:RUB]TYPRUB<>5
      GERR = 1 : GMESSAGE = mess(12,10702,1) : Break : # La rubrique n'est pas de type assiette
     Endif
    Endif
   When "V_"
    Read [VRA]VRA0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(13,10702,1) : Break : # Variable inexistante
    Elsif [F:VRA]FLGEXS=2
     GERR = 1 : GMESSAGE = mess(183,10703,1) : Break : # Variable de note de frais
    Endif
   When "C_"
    Read [CUM]CUM0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(14,10702,1) : Break : # Cumul inexistant
    Endif
   When "[F]"
    OK = 0
    For [ATZ]DICO Where CODZONE=CODE
     If find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB),"TIMEMPDAT","TIMRECAP")
      OK = 1 : Break
     Endif
    Next
    If !OK
     GERR = 1 : GMESSAGE = mess(15,10702,1) : Break : # Champ inexistant dans la base
    Endif
  Endcase
  #47239
  #65041
  If find(OP,"R_","C_","B_") & mid$(FORMULE,I+1,1)<>"("
   LNGFOR +=3
  Endif
  # fin 47239
  I += 1
 Else
  I += 1
 Endif
Wend
If GERR
 GMESSAGE = CODE+"\"+GMESSAGE : mkstat = 2
Endif
#47239
If (GFONCTION="GESRUB" | GFONCTION="GESCUM") & LNGFOR>250
 # Expression trop longue
 # Les codes rubriques et cumuls seront complétés par "(1)" à la génération du plan de paie
 GERR = 1 : GMESSAGE = mess(62,123,1)+"\"+mess(206,10703,1)
 mkstat = 2
Endif
End

#Obsolete since reverse order of main index
#JASMI - START
#Subprog CONTRUB(CODE, LEG)
#Variable Char CODE()
#Value    Char    LEG
Subprog CONTRUB(CODE)
Variable Char CODE()
#JASMI - END

If GFONCTION = "GESRUB" | CODE="" : End : Endif

#35971
If instr(1,CODE,"-")
 GMESSAGE = "- :"-mess(94,123,1)
 mkstat=2 : End
Endif
If instr(1,CODE,"/")
 GMESSAGE = "/ :"-mess(94,123,1)
 mkstat=2 : End
Endif
###

If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif

#JASMI - START
#If func AFNC.ACTIV("LEG")=0
# LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>""
# LEG = GCURLEG
#Elsif LEG=""
# Read [RUB]RUB0(1)=CODE
# If !fstat
#  LEG = [F:RUB]LEG
# Endif
#Endif
#
#If num$(val(CODE))=CODE
# Look [RUB]RUB0 = CODE;LEG
# If fstat
#  Read [RUB]RUB1 = LEG;val(CODE)
#  If !fstat
#   CODE = [F:RUB]COD
#  Endif
# Endif
#Endif
#
#Read [RUB]RUB0 = CODE;LEG
#If fstat
# Filter [RUB] Where COD=CODE
# Look [RUB]RUB0 First
# If !fstat
#  # Fiche inexistante pour la législation courante
#  GMESSAGE = [L]CODE-":"-mess(14,10712,1)-"["+[L]LEG+"]"
# Else
#  # Fiche inexistante
#  GMESSAGE = [L]CODE-":"-mess(23,100,1)
# Endif
# Filter [RUB]
# mkstat = 2 : End
#Endif

If CODE <> ""
  Filter [F:RUB] Where COD=[L]CODE
  Read [F:RUB] First
  If fstat
      GMESSAGE = [L]CODE-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:RUB]
      Read [F:RUB]RUB0 = GCURLEG;[L]CODE
      If fstat
        Filter [F:RUB] Where COD=[L]CODE
        Read [F:RUB] First
        GMESSAGE = [L]CODE-":"-mess(62,127,1)-":"-[F:RUB]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
#MIPEA - 2016-10-11 - X3PEOP-1029 - START
Filter [F:RUB]
#Filter [F:PRF]
#MIPEA - 2016-10-11 - X3PEOP-1029 - END
#JASMI - END

Call CONTROLE("RUB","",CODE,GCURLEG,mkstat) From CONTOBJ

#Acces code
If GUSRACS<>2
 If [F:RUB]CODACC <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:RUB]CODACC
  If fstat or [F:ACC]CONSUL<>2
   GMESSAGE = [F:RUB]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

#Activity code
If [F:RUB]CODACT<>""
 If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
 Read [ACV]CODACT = [F:RUB]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = mess(42,10703,1) : # Variable diseable
  mkstat = 2 : End
 Endif
Endif

