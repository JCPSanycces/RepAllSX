Subprog TUNRUB(COD)
Variable Char    COD()
#JASMI - END
#
#Local Integer TOKILL
#TOKILL = 0
#If dim(VCOD)<1
# Global Char VCOD(GLONRUB)
# TOKILL = 1
#Endif
#
#If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
#
## To update the RUB code after the tunnel order
#VCOD = COD
#If GNBLEG = 1
# LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
# LEG = GCURLEG
#Elsif LEG=""
# Read [F:RUB]RUB0(1)=VCOD
# If !fstat
#  LEG = [F:RUB]LEG
# Endif
#Endif
#
#If VCOD="" & GLECOBJ=2
#  #If no code is specified, it's better to select one of the curent legislation
#  Filter [RUB] Where LEG=[L]LEG
#  Read [F:RUB] First
#  Filter [RUB]
#  If !fstat : VCOD=[F:RUB]COD : Endif
#Else
#  Read [F:RUB]RUB0 = VCOD;LEG
#Endif
#
#If fstat : LEG = "" : Endif
#
#Call OBJET("RUB",LEG,VCOD) From GOBJET
#COD = VCOD
#
#If TOKILL : Kill VCOD : Endif

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONRUB)
 TOKILL = 1
Endif

If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif

# To update the RUB code after the tunnel order
VCOD = [L]COD

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [RUB] Where LEG=GCURLEG
  Read [F:RUB] First
  Filter [RUB]
  If !fstat : VCOD=[F:RUB]COD : Endif
Else
  Read [RUB]RUB0 = GCURLEG;VCOD
Endif

Call OBJET("RUB",VCOD,GCURLEG) From GOBJET

[L]COD = VCOD

If TOKILL : Kill VCOD : Endif

End

######################################################################################
## Section automatically added (screen RUB5) 05/24/2017 16:35:09 (THRAM)
######################################################################################
Subprog C_GRPRUB(VALEUR)
Variable Char    VALEUR()
  If VALEUR="" : End : Endif
  If clalev([F:HRGRB])=0 : Local File HRGRPRUB [HRGRB] : Endif
  Read [F:HRGRB]HRGRB0=GCURLEG;VALEUR
  If !fstat & [F:HRGRB]TYPGRP=2 Then
    GMESSAGE=mess(1,10702,1) : # Valeur incorrecte
    mkstat=2
    End
  Endif
End

Subprog C_DETGRPRUB(VALEUR)
Variable Char    VALEUR()
  If VALEUR="" : End : Endif
  If clalev([F:HRGRB])=0 : Local File HRGRPRUB [HRGRB] : Endif
  Read [F:HRGRB]HRGRB0=GCURLEG;VALEUR
  If !fstat & [F:HRGRB]TYPGRP=1 Then
    GMESSAGE=mess(1,10702,1) : # Valeur incorrecte
    mkstat=2
    End
  Endif

  #If func AFNC.ACTIV("KFR") & [M:RUB5]GRPRUB<>"" & [M:RUB5]GRPRUB<>[F:HRGRB]CODGRP Then
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) & [M:RUB5]GRPRUB<>"" & [M:RUB5]GRPRUB<>[F:HRGRB]CODGRP Then
    GMESSAGE=mess(1,10702,1) : # Valeur incorrecte
    mkstat=2
    End
  Endif
End


