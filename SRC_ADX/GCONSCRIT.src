#<AdxTL>@(#)0.0.0.0 $Revision$ Saisie critères consultation
Local Mask CONSSTA1, CONSSTA2
Local Char PARAM(30)(1..5) , VALEUR(10)
PARAM(1) = "STA"
PARAM(2) = "CNSSTASTD"
Call SAISIE_CHAR(VALEUR,PARAM,"DCNSSTA","GCONSCRIT","") From GSAISIE
End

###########################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "DEBUT"        : Gosub DEBUT
 When "BOUTON"       : Gosub BOUTON 
 When "OK"           : Gosub OK
 When "END"          : Gosub PASOK
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
Endcase
Return

###########################################################
$OUVRE
Local File AMSKZON [AMZ]
Local Integer NBZ , CHANGE , MA , OKTRT
Local Char    ACTION(20) , EXT(10) , MESSAGE(250)
Local Char    CNSCOD(GLONACN), PRGSTD(GLONADC), PRGSPE(GLONADC), PROGCNS(GLONADC), CECRAN(GLONAMK)
CNSCOD = PARAM(1)
PRGSTD = PARAM(2)
PRGSPE = PARAM(3)
CECRAN = PARAM(4)
CHANGE = val(PARAM(5))
PROGCNS = "WWCNS"+CNSCOD
EXT = tolower(CNSCOD)
If PRGSTD<>""
 Call EXISTE_ADX("","",PRGSTD,OKTRT) From ORDSYS
 If !OKTRT : PRGSTD = "" : Endif
Endif
If PRGSPE<>""
 Call EXISTE_ADX("","",PRGSPE,OKTRT) From ORDSYS
 If !OKTRT : PRGSPE = "" : Endif
Endif
Return

###########################################################
$AP_CHOIX
ACTION = "AP_CHOIX2" : Gosub ACTION_CRIT
Return

###########################################################
$DEBUT
Gosub CRITENT From =PROGCNS
MA = -1 : Gosub SETMASK From =PROGCNS
Case GCONSULT
 When 1 : MA = 0 : Gosub GRISE_CLE From =PROGCNS
 When 2 : Gosub GRISE_CRIT From =PROGCNS
Endcase
If CECRAN<>"" & dim([M]ECRAN)>0 : Grizo ECRAN : Endif : # GH 01/02/00 bug 4135

ACTION = "DEB_CRIT" : Gosub ACTION_CRIT

Call ZONMSK(NOMMSK(1),ABMSK(1),J,I,"1") From GCONSULT
Local Char ZONMSK(GLONAVA+5)(1..J+1), VALMSK(I)(1..J+1)

For [AMZ]CODE Where CODMSK=NOMMSK(1) & SAIAFF=1
 For [L]COUIND=0 To evalue("dim([M:"+[L]ABMSK(1)+"]"+[F:AMZ]CODZON+")")-1
  [L]NBZ += 1
  [L]ZONMSK([L]NBZ) = [F:AMZ]CODZON+"~"+num$([L]COUIND)
  Case evalue("type([M:"+[L]ABMSK(1)+"]"+[F:AMZ]CODZON+")")
   When 1,2,4,5,6,7,8,9
    [L]VALMSK([L]NBZ) = num$(evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"("+num$([L]COUIND)+")")) 
   When Default 
    [L]VALMSK([L]NBZ) = evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"("+num$([L]COUIND)+")")
  Endcase
 Next [L]COUIND
Next AMZ
If evalue("dim([M:"+ABMSK(1)+"]MEMO)")>0 & !find("MEMO~0",[L]ZONMSK(1..[L]NBZ))
 [L]NBZ += 1
 [L]ZONMSK([L]NBZ) = "MEMO~0"
 [L]VALMSK([L]NBZ) = evalue("[M:"+ABMSK(1)+"]MEMO")
Endif
Affzo
Return

###########################################################
$OK
[L]CHANGE = 0
If dim([L]ZONMSK)>0
 Gosub CRITAFF From =PROGCNS
 For I=1 To [L]NBZ
  J = instr(1,[L]ZONMSK(I),"~")
  [L]COUZON = left$([L]ZONMSK(I),J-1)
  [L]COUIND = val(right$([L]ZONMSK(I),J+1))
  Case evalue("type([M:"+[L]ABMSK(1)+"]"+[L]COUZON+")")
   When 1,2,4,5,6,7,8,9 
    If evalue("[M:"+[L]ABMSK(1)+"]"+[L]COUZON+"("+num$([L]COUIND)+")")<>val([L]VALMSK(I))
     If !find([L]COUZON,"ECRAN",CRITAFF(1..NBCA))
      [L]CHANGE = 2 : Break 
     Else
      [L]CHANGE = 1
     Endif
    Endif 
   When Default
    If evalue("[M:"+[L]ABMSK(1)+"]"+[L]COUZON+"("+num$([L]COUIND)+")")<>[L]VALMSK(I)
     If !find([L]COUZON,"ECRAN",CRITAFF(1..NBCA))
      [L]CHANGE = 2 : Break
     Else
      [L]CHANGE = 1
     Endif
    Endif       
  Endcase
 Next I
Endif
Return

###########################################################
$PASOK
[L]CHANGE = 0 
If dim([L]ZONMSK)>0
 For I=1 To [L]NBZ
  J = instr(1,[L]ZONMSK(I),"~")
  [L]COUZON = left$([L]ZONMSK(I),J-1)
  [L]COUIND = val(right$([L]ZONMSK(I),J+1))
  If [L]COUZON="MEMO" 
   If filinfo(filpath("ETM",GUSER+"_"+[L]VALMSK(I),EXT,0),0)<0
    [L]VALMSK(I) = ""
   Endif
  Endif
  Case evalue("type([M:"+[L]ABMSK(1)+"]"+[L]COUZON+")")
   When 1,2,4,5,6,7,8,9 
    Assign "[M:"+[L]ABMSK(1)+"]"+[L]COUZON+"("+num$([L]COUIND)+")" With val([L]VALMSK(I)) 
   When Default
    Assign "[M:"+[L]ABMSK(1)+"]"+[L]COUZON+"("+num$([L]COUIND)+")" With [L]VALMSK(I) 
  Endcase
 Next I
Endif
Return

###########################################################
$FIN
ACTION = "FIN_CRIT" : Gosub ACTION_CRIT
PARAM(5) = num$([L]CHANGE) 
Return

###########################################################
$APRES_MODIF
If zoncou="ECRAN" & zc<>""
 Call VERFGTC(CNSCOD,zc,"",MESSAGE,OK) From GCONSULT
 If !OK
  Call ERREUR(MESSAGE) From GESECRAN
  mkstat=2 : Return
 Endif
Endif
If zoncou<>"MEMO" & dim([M]MEMO)>0 & [M]MEMO<>""
 I = indice
 J = nolign
 [M]MEMO = "" : Affzo MEMO 
 indice = I
 nolign = J
Endif
Return

###########################################################
$BOUTON
GNBAFF = 0
ACTION = "EXEBOUT2" : Gosub ACTION_CRIT
If GNBAFF : Affzo : Endif 
Return

###########################################################
$ACTION_CRIT
GPE = 0
If PRGSPE<>""
 Gosub ACTION From =PRGSPE
Endif
If PRGSTD<>"" & !GPE
 Gosub ACTION From =PRGSTD
Endif
Return




