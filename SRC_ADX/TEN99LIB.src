#<AdxTL>@(#)9.0.0.0 $Revision$
####################################################################
#
# TEN99LIB  - # 1099 Enhancement RXS/JB                 July 20 2011
# Handles the opening of 1099 files  BOX1099    [BX9]
# and the display of controls FRM1099 and BOX1099
# and display of related controls DAS2 or DADFLG
# for maintenance and transactional screens
#
# We pass in the process to determine the controls to use
# Maintenance screens BPS (SUBBPS),BSG (SUBBSG) use DADFLG for the DAS2 control
# Transaction screens BIS1(SUBBIS), PIH1(SUBBIS) use the standard DAS2
#
#Called from SUBBSG, SUBBPS, SUBPIH and SUBBIS, SUBBIS2, SUBPIHA
# Mod :  RxS     consolidat & fixes to screens     Sept.22.2011
##################################################################
#
#
# $OUVRE CALLED from SUBBSG, SUBBPS, SUBBIS
#    Verify 1099 are enabled (via KUS) before opening 1099 table
#
# $SUB_GRIZE_LIENS
#    Called from SUBBSG/SUBBPS GRIZE_LIENS (LIENS/RAZCRE/RAZDUP) [$APRES_MOD$FINMODIF]
#    If 1099 enabled,  set 1099 related controls and possibly DAS2
#
# Screen Actions
#
##################################################################
# Issue 90269, August 2nd, 2013 - when creating intercompany invoices
##################################################################

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION

  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
    When "SEL_LISTE" : Gosub SEL_LISTE
  Endcase

Return

################################################################################
$OUVRE
#---------------------------------------------------------------------------#
# $OUVRE  : Open 1099 Form Box table for value population                   #
#---------------------------------------------------------------------------#
# Called from SUBBSG, SUBBPS, SUBBICS                                       #
#                                                                           #
#---------------------------------------------------------------------------#
 Global Integer GS1099

 #Verify 1099 are enabled before opening 1099 table
 If func AFNC.ACTIV("S1099")
  If !clalev([F:BX9]) Local File BOX1099 [BX9] : Endif
  GS1099 = 1 #AFNC.ACTIV("S1099") is Activated
 Endif

Return


###################################################################
$CALC_AMTSUBJ1099

If dim(CURDIF) > 0 & CURDIF=1 : Return : Endif # Non-Company currency  ######  #1099.n

#79176.sn
If dim([M:PIH1]AMTSUBJ1099) > 0
    [M:PIH1]AMTSUBJ1099 = 0

    If [M:PIH1]FRM1099 > 1    #Skips line calc if FRM1099 is 'None'
        For I = 0 To [M:PIH3]NBLIG
            If [M:PIH3]FLG1099(I) <> 1
                [M:PIH1]AMTSUBJ1099 += [M:PIH3]AMTNOTLIN(I)
            Endif
        Next
        Affzo [M:PIH1]AMTSUBJ1099
    Endif

Elsif dim([M:BIS1]AMTSUBJ1099) > 0
    [M:BIS1]AMTSUBJ1099 = 0

    If [M:BIS1]FRM1099 > 1    #Skips line calc if FRM1099 is 'None'
        For I = 0 To [M:BIS3]NBLIG
            If [M:BIS3]FLG1099(I) <> 1
                [M:BIS1]AMTSUBJ1099 += [M:BIS3]AMTNOTLIN(I)
            Endif
        Next
        Affzo [M:BIS1]AMTSUBJ1099
    Endif
Endif
#79176.en

Return

###################################################################
$CURR_CHECK #1099.n
If !clalev([F:CPY2]) Local File COMPANY [CPY2] : Endif
Local Integer CURDIF
If GFONCTION="GESPIH" : Default Mask [PIH1] : Endif
If dim([M]FRM1099) > 0 #81035.n
  If [M]FRM1099 <=1 : Return : Endif
  If [M]CURLED <> [M]CUR
   CURDIF=1
  Endif
Endif

Return

###################################################################
$PICKE
If GS1099 = 1 #1099.sn
 Gosub CURR_CHECK From TEN99LIB
 If CURDIF=1 & !XMESS & dim([M:PIH1]AMTSUBJ1099) > 0 #81035.n
   Actzo [M:PIH1]AMTSUBJ1099
   Raz [M:PIH1]AMTSUBJ1099
   Affzo [M:PIH1]AMTSUBJ1099
   Call MESSAGE(mess(83,122,1)) From GESECRAN
   XMESS=1
 Endif
 If dim([M:PIH1]AMTSUBJ1099) > 0 #81035.n
   If !CURDIF
    Gosub CALC_AMTSUBJ1099 From TEN99LIB # re-calc if going back to company currency
    Else
      Raz [M:PIH1]AMTSUBJ1099
      Affzo [M:PIH1]AMTSUBJ1099
   Endif
 Endif
Endif  #1099.en

Return
###################################################################
$VERIF
If GS1099 = 1 & dim([M]FRM1099) > 0 & [M]FRM1099>1 #81035.n
  #If [M]AMTSUBJ1099=0 & !GSERVEUR #CATUA X3-107812.o
  If [M]AMTSUBJ1099=0 & !GSERVEUR & !GIMPORT #CATUA X3-107812.n Zero amount for 1099 prompt is not needed during import
      Call OUINON(mess(85,122,1),XOK) From GESECRAN # Amount subject to 1099 set to zero
      If XOK<>2
       GERR=1
       ERR=1
       OK=0
       zonsui = "[M]AMTSUBJ1099"
       GOK=0
      Endif
  Endif
Endif
Return

###################################################################
Subprog AM_FCY(VALEUR, WABMSK)
Variable Char    VALEUR()
Value  Char    WABMSK()
#----------------------------------------------------------------#
# After modifying Site in invoices PIH1, BIS1
#----------------------------------------------------------------#

Call SHOWHIDE_DAS1099(WABMSK)

End


###################################################################
Subprog SHOWHIDE_DAS1099(WABMSK)
#----------------------------------------------------------------#
# Based the DCLFEES param by company GSOCIETE
# Typically driven by the selected Site
# Display or Hide the "FEE" controls DAS2/1099, on the transaction screen
#
#
# Called by AM_FCY and Liens in SUBBIS/SUBPIHA
#----------------------------------------------------------------#
Value Char WABMSK()
Local Char CPYDCLFEES

HIDE = 2
SHOW = 1
If  func AFNC.ACTIV("FEE")  # Issue X3-107197
  CPYDCLFEES = func AFNC.PARAM("DCLFEES", GSOCIETE)
Endif  # End Issue X3-107197
#
# If adding other Legislational XXxxxxxx please do it here.
#
# One can have not have both DAS and 1099
Case CPYDCLFEES

    When "2","4":          # DAS2 or 281.5
     Call SHOWHIDE_DAS (SHOW, WABMSK)
     Call SHOWHIDE_1099(HIDE, WABMSK)

    When "3":            # 1099
     Call SHOWHIDE_1099 (SHOW, WABMSK)
     Call SHOWHIDE_DAS (HIDE, WABMSK)

    When Default:            # None or undefined
     Call SHOWHIDE_DAS (HIDE, WABMSK)
     Call SHOWHIDE_1099 (HIDE, WABMSK)

Endcase

End

###################################################################
Subprog SHOWHIDE_DAS(FLGHIDE, WABMSK)
#----------------------------------------------------------------#
# FLGHIDE Detemine if to show or hide 2 = Yes , # 1 = No
# Set a variable KSET for the dynamic display/hide that Chgfmt with K provides
#----------------------------------------------------------------#
Value Integer FLGHIDE
Value Char    WABMSK()
Local Char    DISPLAYONLY     # Set by PIH EntryTransaction if Display only.

Gosub SETDISPLAY_FLG

If WABMSK = "PIH1"
    Chgfmt [M:PIH1]DAS2  With KSET+"LA"+DISPLAYONLY +":1" # Hide or display
Else
    Chgfmt [M:BIS1]DAS2  With KSET+"LA:1"                 # Hide or display
Endif

End

###################################################################
Subprog SHOWHIDE_1099(FLGHIDE, WABMSK)
#----------------------------------------------------------------#
# Set a variable KSET for the dynamic Display/Hide that Chgfmt with K provides
# Instead of using Actzo, Dizo, Grizo
# Parameters:
#   FLGHIDE Detemine if to show or hide
#         - Values:  2 = Yes ,  1 = No
#   WABMSK - Calling Screen
#         - Values:  BIS1/PIH1 expected
#----------------------------------------------------------------#
Value Integer FLGHIDE
Value Char    WABMSK()
Local Char    DISPLAYONLY     # Set by PIH EntryTransaction if Display only.

Gosub SETDISPLAY_FLG
Local Char CPYDCLFEES

If WABMSK = "PIH1" and dim([M:PIH1]FRM1099) > 0
    Chgfmt [M:PIH1]FRM1099      With KSET+"K"+DISPLAYONLY +":10X" # Hide or show
    Chgfmt [M:PIH1]BOX1099      With KSET+"K"+DISPLAYONLY +":10X"
    Chgfmt [M:PIH1]AMTSUBJ1099  With KSET+"KP:10X"            # This field is always display only
    Chgfmt [M:PIH3]FLG1099      With KSET+"K"+DISPLAYONLY +":10X"
Elsif WABMSK = "BIS1" and dim([M:BIS1]FRM1099) > 0
    Chgfmt [M:BIS1]FRM1099      With KSET+"K:10X"                 # Hide or show
    Chgfmt [M:BIS1]BOX1099      With KSET+"K:10X"
    Chgfmt [M:BIS1]AMTSUBJ1099  With KSET+"K:10X"
    Chgfmt [M:BIS3]FLG1099      With KSET+"K:10X"
Endif

End

###################################################################
$SETDISPLAY_FLG
#----------------------------------------------------------------#
# Set a variables KSET and DISPLAYONLY
#
#----------------------------------------------------------------#

DISPLAYONLY = ""

If FLGHIDE= 2      # Yes: 2 1099 Business Logic (not system/tran entry flag)
    KSET = "-"     # Hide: minus
Else
    KSET = ""      # Show: empty

    If WABMSK = "PIH1"
        #PIH Transaction Entry that controls all 1099 fields.
        If [F:PTR]DAS2COD = 2    # Displayed: 2; Entered: 1; Hidden: 3
            DISPLAYONLY = "P"    # Displayed (Grizo)
        Else
            DISPLAYONLY = ""     # Entered
        Endif
    Endif

Endif

Return

###################################################################
Subprog AM_BPR(VALEUR, WABMSK)
#----------------------------------------------------------------#
# After modifying Supplier on Invoice
# Default Supplier's  FRM1099 , then  BOX1099, and display
# Use [M] vs WABMSK since BPR calls from main screen SUBPIH,SUBBIS
#     1099 fields are on sub-screens
#----------------------------------------------------------------#
Variable Char VALEUR()
Value    Char WABMSK() # BIS1/PIH1 expected

If func AFNC.ACTIV("FEE") and func AFNC.PARAM("DCLFEES", GSOCIETE) = "3" and dim([M]FRM1099) > 0  # Issue X3-107197
    #First set 1099FRM from BPR
    [M]FRM1099 = [F:BPS]FRM1099

    # Let the FRM control know we just set it.
    Call AM_FRM1099([M]FRM1099, WABMSK) # Change clears 1099BOX

    #Now set 1099BOX from BPR
    [M]BOX1099 = [F:BPS]BOX1099

    If WABMSK = "BIS1"
      Affzo [M:BIS1]FRM1099
      Affzo [M:BIS1]BOX1099
    Else
      Affzo [M:PIH1]FRM1099
      Affzo [M:PIH1]BOX1099
    Endif
Elsif dim([M]FRM1099) > 0
    [M]FRM1099 = 1
    Raz [M]BOX1099
Endif

End


###################################################################
Subprog SUB_GRIZE_LIENS(WABMSK)
#---------------------------------------------------------------------------#
# SUB_GRIZE_LIENS: Set 1099 Related Controls                                #
#---------------------------------------------------------------------------#
# Entree                                                                    #
#         WABMSK    : Type alimentation                                     #
#                     BSG2:category , BPS2:supplier, BIS1:invoice, PIH0:purch inv  #
#                                                                           #
# Called from SUBBSG/SUBBPS
#        from GRIZE_LIENS (LIENS/RAZCRE/RAZDUP) [$APRES_MOD$FINMODIF]       #
# SUBBPS/SUBBSG - have not AMT1099 field and need no DAS2 disabling         #
#
# Called from SUBBIS
#
#---------------------------------------------------------------------------#
Value    Char    WABMSK()
#If 1099 enabled,  set 1099 related controls
If dim([M]FRM1099) > 0
  #pass Screen and manual change (always 1(no) from record changes)
  Call ENABLEDISABLE_1099([M]FRM1099, WABMSK, 1)

Endif

End

Subprog ENABLEDISABLE_1099(VALEUR, WABMSK, USRCHG)
#-----------------------------------------------------------------------------#
# ENABLEDISABLE_1099: Set 1099 Related Fields                                 #
#-----------------------------------------------------------------------------#
# Entree                                                                      #
#        VALEUR : Is from [M]FRM1099 to drive behavior of dependant fields    #
#        WABMSK : Type alimentation                                           #
#               BSG2:category , BPS2:supplier, BIS1:invoice, PIH1:purch inv   #
#        USRCHG:Type alimentation                                             #
#               1 =Yes 2 = No                                                 #
#                                                                             #
# Called from local SUB_GRIZE_LIENS and AM_FRM1099                            #
#                                                                             #
#  WABMSK   - note SUBBPS/SUBBSG - dont have AMT1099 or FLG1099 field         #
#  USRCHG   - Yes -a manual change made and need to clear depending values    #
#           - No  -a record change made and values will be set by DB          #
#                                                                             #
#  1099 cannot be used in combination with DAS2 for one invoice, but          #
#  display of the DAS2/1099 is done in SHOW_HIDE based on the Site(company)   #
#-----------------------------------------------------------------------------#
Variable Integer VALEUR() #[M]FRM1099
Value    Char    WABMSK()
Value    Integer USRCHG
Local    Integer LINE

#When we have a Form Value allow entry of Box, and disable the DAS2
If VALEUR > 1

  #For a Maintenance record
  Case WABMSK
    When "BSG2"  : Actzo [M:BSG2]BOX1099
    When "BPS2"  : Actzo [M:BPS2]BOX1099
  Endcase
  #For a Transaction record
  #  enable 1099 : box, AMT, line 1099 (dont set FLG1099 )
  #   1099 amt and lines FLG1099 is only on transaction screens
  Case WABMSK
    When "BIS1"
      If [M:BIS1]STA <> 3 #1099 Information cannot be modified on Validated invoices.
        Actzo  [M:BIS1]BOX1099
        Actzo  [M:BIS3]FLG1099
      Else
        Grizo  [M:BIS1]BOX1099
        Grizo  [M:BIS3]FLG1099
      Endif

    When "PIH1"
      If [M:PIH1]STA <> 3 #1099 Information cannot be modified on Validated invoices.
        Actzo  [M:PIH1]BOX1099
        Actzo  [M:PIH3]FLG1099
      Else
        Grizo  [M:PIH1]BOX1099
        Grizo  [M:PIH3]FLG1099
        Affzo  [M:PIH1]AMTSUBJ1099
      Endif

  Endcase

Else
  # None #
  #      disable 1099 controls:
  #      if maintenance disable: box
  #      if transaction disable: box, AMT, line 1099 selections

  #For a Maintenance record
  Case WABMSK
    When "BSG2"  : Grizo [M:BSG2]BOX1099
    When "BPS2"  : Grizo [M:BPS2]BOX1099
  Endcase

  #For a Transaction record
  #    - AMTSUBJ1099/FLG1099 are only on transaction screens
  Case WABMSK
    When "BIS1"
      #box
      Grizo [M:BIS1]BOX1099 #None - just disable Box, clearing at bottom

      #line - Lines subject to 1099 (clear them if 1099 'None)
      If USRCHG = 2
        For LINE = 0 To [M:BIS3]NBLIG - 1
          [M:BIS3]FLG1099(LINE) = 1
          # [M:BIS3]UPDFLG(LINE) = 1 #Not needed and does not exist
        Next
      Endif

      Grizo [M:BIS3]FLG1099
      Affzo [M:BIS3]FLG1099

      #amt
      If USRCHG = 2
        Raz   [M:BIS1]AMTSUBJ1099 #None - just clear, it is non-enterable.
        Affzo [M:BIS1]AMTSUBJ1099
      Endif

    When "PIH1"
      #box
      Grizo [M:PIH1]BOX1099 #None - just disable Box, clearing at bottom

      #line - Lines subject to 1099 (clear them if 1099 'None)
      If USRCHG = 2
        For LINE = 0 To [M:PIH3]NBLIG - 1
          [M:PIH3]FLG1099(LINE) = 1
          [M:PIH3]UPDFLG(LINE) = 1
        Next
      Endif

      Grizo [M:PIH3]FLG1099
      Affzo [M:PIH3]FLG1099

      #amt
      If USRCHG = 2
        Raz   [M:PIH1]AMTSUBJ1099 #None - just clear, it is non-enterable.
        Affzo [M:PIH1]AMTSUBJ1099
      Endif
  Endcase

Endif


# Clear box on any FRM1099 change since Box values have diff meaning
If USRCHG = 2 # If user action driven
 Case WABMSK
    When "BSG2"  : Raz [M:BSG2]BOX1099 : Affzo [M:BSG2]BOX1099
    When "BPS2"  : Raz [M:BPS2]BOX1099 : Affzo [M:BPS2]BOX1099
    When "BIS1"  : Raz [M:BIS1]BOX1099 : Affzo [M:BIS1]BOX1099
    When "PIH1"  : Raz [M:PIH1]BOX1099 : Affzo [M:PIH1]BOX1099
  Endcase
Endif

End

######################################################################################
Subprog C_BOX1099(VALEUR, WABMSK)
#--------------------------------------------------------------------#
# BOX1099 controls called from C_BOX1099 in SUBBPIH,SUBBIS2 and SUBBPS,SUBBSG
#   Verify the selected Box along with Form combination exists
#            do not allow inactive or textonly boxes
#
#     VALEUR - Pass in new value for BOX1099field
#     WABMSK - Pass in the main Screen we are comming from
#--------------------------------------------------------------------#
Variable Char  VALEUR()
Value    Char  WABMSK()

#1099 Verify the selected Box along with Form combination exists
Read [F:BX9]BX90 = evalue("[M:"+WABMSK+"]FRM1099") ; VALEUR
If fstat
  GMESSAGE = mess(23,100,1)  : mkstat = 2 : End   #Record does not exist.
Endif

# Do not allow inactive boxes or box types other than amount boxes
If [F:BX9]ENAFLG <> 2 or [F:BX9]BOXTYP > 1
  GMESSAGE = mess(78,122,1) : mkstat = 2 : End    # Invalid 1099 box

Endif
End

######################################################################################
Subprog AM_FRM1099(VALEUR, WABMSK) #ruedi.new replace in SUBBPIH,SUBBIS and SUBBPS,SUBBSG
#--------------------------------------------------------------------#
# 1099 controls called from AM_FRM1099 in SUBBPIH,SUBBIS and SUBBPS,SUBBSG
# When Form Value (other than None) allow entry of Box,
# None - disable and clear Box and Amt and subject to 1099 Flag
#
#     VALEUR - Pass in new value for FRM1099 field
#     WABMSK - Pass in the main Screen we are comming from
#--------------------------------------------------------------------#
Variable Integer VALEUR()
Value    Char    WABMSK()

  #pass screen and manual change (always 2 (yes) from AM_Xxxx or Field actions)
  Call ENABLEDISABLE_1099(VALEUR, WABMSK, 2)

End

################################################################################
$SEL_TABLE

Case TABLE
    When "SELBX9": Gosub SELBX9
    When "SELBPS1099" : Gosub SELBPS1099
Endcase

Return
################################################################################
$SEL_LISTE

Case LISTE
    When "SELCPY1099": Gosub SELCPY1099
    When "SELYR1099" : Gosub SELYR1099
Endcase

Return

################################################################################
$SELBX9

# For  Selecting 1099 Boxes

If !clalev([BX9]) : Local File BOX1099 [BX9] : Endif

#Display the 1099 Box Table
OBJET = "BX9"

CRITERE = "FRM1099= "+  PARAM(1)
CRITERE -= "& ENAFLG=2 & BOXTYP =1"

Return
################################################################################
$SELBPS1099

# For  Selecting 1099 Suppliers

OBJET = "BPS"

CRITERE = "FRM1099>1"

Return
################################################################################
$SELCPY1099

Local Integer NBTEX, GPHYNUM
Local Char    LPARAM
Local Char    TEXTE(80)(1..200,1..3)

NBTEX = 0

TIT(0) = mess( 2, 45,1)                  : # Company
TIT(1) = mess( 2, 45,1)                  : # Company
TIT(2) = mess(38,100,1)                  : # Name
TIT(3) = mess( 3,675,1)                  : # Short name

If clalev([F:WCPY])=0 : Local File COMPANY  [WCPY] : Endif
If  func AFNC.ACTIV("FEE")  # Issue X3-107197
  For [F:WCPY]

    If func AFNC.PARAM("DCLFEES",[F:WCPY]CPY) = "3"
      NBTEX         += 1
      TEX(NBTEX)     = [F:WCPY]CPY
      TEXTE(NBTEX,1) = [F:WCPY]CPY
      TEXTE(NBTEX,2) = [F:WCPY]CPYNAM
      TEXTE(NBTEX,3) = [F:WCPY]CPYSHO
    Endif

  Next
Endif  # End Issue X3-107197

If NBTEX=0
   GERR=2
   GMESSAGE=""
   mkstat=2
Endif

Return

################################################################################
$SELYR1099

Local Integer NBTEX, FIRSTYEAR, TYEAR
Local Char    LPARAM
Local Char    TEXTE(80)(1..200,1)

NBTEX = 0

TIT(0) = mess(2,47,1) # Year
TIT(1) = mess(2,47,1) # Year

If clalev([F:WFIY])=0 : Local File FISCALYEAR  [WFIY] : Endif
Read [F:WFIY] First
If fstat = 0
    FIRSTYEAR = year([F:WFIY]FIYSTR)
Else
    FIRSTYEAR = year(date$) - 10
Endif

For TYEAR = year(date$) To FIRSTYEAR Step -1

    NBTEX         += 1
    TEX(NBTEX)     = num$(TYEAR)
    TEXTE(NBTEX,0) = num$(TYEAR)

Next

Return
###############################################################################
Subprog CNTBOX1099(IBOX1099,IFRM1099)
Value Char    IBOX1099
Value Integer IFRM1099

If IFRM1099 > 1 and IBOX1099 = ""
  GMESSAGE = mess(532,177,1)  : mkstat = 2 : End   # Mandatory field
Endif

If IFRM1099 > 1                                                                #90269.n
    #1099 Verify the selected Box along with Form combination exists

    Read [F:BX9]BX90 = IFRM1099;IBOX1099
    If fstat
      GMESSAGE = mess(23,100,1)  : mkstat = 2 : End    # Record does not exist.
    Endif

    If [F:BX9]ENAFLG <> 2
      GMESSAGE = mess(2,126,1): mkstat = 2 : End       # Inactive record
    Endif

    If [F:BX9]BOXTYP > 1
      GMESSAGE = mess(78,122,1) : mkstat = 2 : End     # Invalid 1099 box
    Endif
Endif                                                                          #90269.n

End

###############################################################################
Subprog CNTBPS1099(AZC)
#################################################################
#  called by Action: CNTBPS1099
#  Validates a Supplier can be used for 1099 by evaluating
#  [F:BPS]FRM1099 = 1 is "None" and means Supplier not set up for 1099
#  Alert user if Supplier is not for 1099, and disallow use.
#################################################################
Value    Char    AZC

Read [F:BPS]BPS0 = AZC
If fstat = 0
  If [F:BPS]FRM1099 <= 1
    GMESSAGE = mess(76,122,1)    # Invalid 1099 supplier
      mkstat = 2
  Endif
Endif

End

###############################################################################
Subprog CNTCPY1099(AZC)
#################################################################
#  called by Action: CNTCPY1099
#  Validates a Company can be used for 1099 by evaluating
#  DCLFEES param by company GSOCIETE
#  "3" - is 1099 (1 - None, 2 - DAS2 )
#  Alert if company is not set for 1099, and disallow use
#################################################################
Value    Char    AZC

If AZC<> "" and
& func AFNC.PARAM("DCLFEES",AZC) <> "3"
  GMESSAGE = mess(77,122,1)     # Company not defined to process 1099s
  mkstat = 2
Endif

End

