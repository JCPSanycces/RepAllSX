#<AdxTL>@(#)10.0.0.0 $Revision$
###########################################################################
# MWMSELLIB TRAITEMENTS DE SELECTION   centrales de pesées   MODULE GPAO  #
# ----------------------------------------------------------------------- #
# ACTIONS SUR CHAMPS                                                      #
#   - SELSBX   : Sélection Lieux-Box                                      #
#   - SELRSY   : Sélection Phrases                                        #
###########################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return
#
#######################################################################
# Actions sur la sélection dans une table (GACTION)                   #
# ------------------------------------------------------------------- #
# SELBOX     : Sélection des lieux et box                             #
#######################################################################
#--------------------------------------------#
# Avant ouverture de la fenêtre de sélection #
#--------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELSBX"     : Gosub SEL_SELSBX
 When "SELRSY"     : Gosub SEL_SELRSY
 When "SELMFGRCL"  : Gosub SEL_MFGRCL     # 102152 mm 06.2015

Endcase
Return

#######################################################################
#--------------------------------------------#
# Après sélection enregistrement             #
#--------------------------------------------#
$VERF_TABLE
Case TABLE
 When "SELSBX"     : Gosub VERF_SELSBX
 When "SELRSY"     : Gosub VERF_SELRSY

Endcase
Return


#######################################################################
#--------------------------------------------#
# A la fermeture   de la fenêtre de sélection#
#--------------------------------------------#
$FIN_TABLE
Case TABLE
 When "SELSBX"     : Gosub FIN_SELSBX
 When "SELRSY"     : Gosub FIN_SELRSY

Endcase
Return

########################################Selection    BOX  ###########


$SEL_SELSBX
Local Char WFCY : WFCY = PARAM(1)
Gosub FENETRE
Return

$FENETRE
If clalev([F:SBX]) = 0 : Local File STATIONBOX  [SBX] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON     [ATZ] : Endif
#
TIT(0) = mess(416,198,1) # Sélection lieu et box

NBCOL  += 1 : COL(NBCOL) = "FCY"
Call TEXTFIC("SBX",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "BOX"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "STI"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "DES"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

SIZLIG  = 140
SIZCOL  = 180
If WFCY <> ""
  CRITERE = "FCY = WFCY"
Endif
Default File [SBX]
Return

#######################################################################

$VERF_SELSBX
PARAM(1) = [F:SBX]FCY
Return

#######################################################################
$FIN_SELSBX
VALEUR = [F:SBX]BOX
Return

########################################Selection    PHRASES ##########


$SEL_SELRSY
Local Char    WLAN : WLAN = PARAM(1)
Local Char CODFIC(30) # 101362 mm 09.2014
Gosub FENETRERSY
Return

# 101362 mm 09.2014
$FENETRERSY
If clalev([F:RSY]) = 0 : Local File SENTENCES [RSY] : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
#
CODFIC  ="SENTENCES"
Link [RSY] With [AXX]AXX0="SENTENCES";"DESAXX";GLANGUE;[F:RSY]RSY;"" As [NEW]
Default File [NEW]

If WTYP <> 0
  CRITERE = "RSYTYP = WTYP"
   If CRITERE <> ""
      CRITERE += "&"
   Endif
  CRITERE += CRITERE1
Endif
START="RSY"

TIT(0) = mess(425,198,1) # Sélection phrases
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "RSY"       : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "DESAXX"    : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"


SIZLIG  = 140
SIZCOL  = 180
Default File [NEW]
Return


###################################################################
$TEXTE
Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return

#######################################################################

$VERF_SELRSY
PARAM(1) = num$([F:RSY]RSYTYP)
Return

#######################################################################
$FIN_SELRSY
VALEUR = [F:RSY]RSY
Return

###################################################################
# SELMFGRCL sélection des OFs éligibles à l'annulation de réconciliation
###################################################################
$SEL_MFGRCL
If clalev([F:MFG]) = 0 : Local File MFGHEAD  [MFG] : Endif
If clalev([F:MFM]) = 0 : Local File MFGMAT   [MFM] : Endif


Local Char    WFCY(GLONFCY)     : WFCY    = PARAM(1)
Local Char    CODFIC(GLONATB)
Local Char    WMFGNUM(GLONVCR)   : WMFGNUM  = ""

