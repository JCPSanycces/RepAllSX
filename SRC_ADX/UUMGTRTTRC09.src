#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC09   Migration de la table BPCARRIER       Module TC        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC09") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC09(DOSSIER)
  Call MAJ_UUMGTRTTRC09(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC09(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 By TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---
##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Integer ERR
Local Char WNAMBPTM
Call MIGTABNAME (DOSSIER,"BPCARRIER",WNAMBPTM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPTM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",7,ERR) From TRTMIG : #7=Erreur
  End
Endif


Local Integer NBLUS, ERR, NBCOMMIT
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
#Local Char WTAB_BPT (100) (adxwrb)
#Local Shortint WCPT_BPT

Call ECR_TIME("UUMGTRTTRC09 tables BPT Process : Update BPT") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC09 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BPCARRIER",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:BPT])  = 0 : Local File =DOSSIER+".BPCARRIER"    [BPT]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPTM]) = 0 : Local File =DOSSIER+"."+WNAMBPTM   [BPTM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:BPR]) = 0 : Local File =DOSSIER+".BPARTNER"   [BPR] : Endif   # Tiers

#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
Local Char WTAB_BPT (100) (adxwrb)
Local Shortint WCPT_BPT
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J


#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC09",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC09" : FILTRELIN=0 : Raz CRITERESPE : Raz HINTSPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPT00
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:BPTM]BPTNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [BPT]
GOK = 1

For [BPTM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC09" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BPT
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_BPT
  Endif
  [F:BPT] = [F:BPTM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_BPT
    If GOK<1 : Break : Endif
  Endif
  # version < V7, maj des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_BPT
    If GOK<1 : Break : Endif
  Endif
  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub BPT_STK : # pour stocker ref
  #    WriteB [F:BPT]
  #Else
  #    Write [F:BPT]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File BPCARRIER, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub BPT_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File BPCARRIER(BPTNUM)"-[F:BPT]BPTNUM+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub BPT_STK : # pour stocker ref
  WriteB [F:BPT]
  If fstat
    Call ECR_TRACE("File BPCARRIER, Error ="-num$(fstat),1) From GESECRAN
    Gosub BPT_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:BPTM]BPTNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC09",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:BPT]
    If fstat
        Call ECR_TRACE("File BPCARRIER, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPT_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC09",NBMIGKEY,TABMIGKEY,NBLUS,NB+NBCOMMIT,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC09",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_BPT00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPT]
Close Local File [BPTM]
Close Local File [BPR]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPCARRIER",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC09") From TRTMIG
Call ECR_TIME("UUMGTRTTRC09 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$MAJV6_BPT
Gosub RECUP_BPR
Return
################################################
$MAJV7_BPT
Return
################################################
$RAZV6_BPT
Raz [F:BPT]BPAADD
Raz [F:BPT]CFY
If dim([F:BPT]CRESTP)>0 Raz [F:BPT]CRESTP Endif
Raz [F:BPT]CUR
Raz [F:BPT]CNTNAM
If dim([F:BPT]IDTSGL)>0 Raz [F:BPT]IDTSGL : Endif
If dim([F:BPT]UPDSTP)>0 Raz [F:BPT]UPDSTP : Endif
Return
################################################
$RAZV7_BPT
Return
################################################
$RECUP_BPR

If [F:BPR]BPRNUM<>[F:BPT]BPTNUM
   Read [BPR]BPR0=[F:BPT]BPTNUM : If fstat Raz [F:BPR] Endif
Endif
If [F:BPT]CUR=""    [F:BPT]CUR=[F:BPR]CUR : Endif
If [F:BPT]BPAADD="" [F:BPT]BPAADD=[F:BPR]BPAADD : Endif
If [F:BPT]CNTNAM="" [F:BPT]CNTNAM=[F:BPR]CNTNAM : Endif

Return


################################################
$BPT_STK
Call STK (WTAB_BPT,WCPT_BPT,[F:BPT]BPTNUM) From TRTMIG
Return
##############################################################################################
$BPT_ERRTRA
Call ERRTRA (WTAB_BPT,WCPT_BPT,"File BPCARRIER(BPTNUM)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC09(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC09(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC09(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMBPTM
Call MIGTABNAME (DOSSIER,"BPCARRIER",WNAMBPTM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPTM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"BPCARRIER",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC09",ERR) From TRTMIG

End

