If varinit([M]TAXCOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TAXCOD,"11800","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TAXCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TAXCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]TAXCOD,"11800","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]TAXCOD,"11800",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]TAXCOD or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_TAXCOD([M]TAXCOD) From SUBHRENT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

