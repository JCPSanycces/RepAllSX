Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRUKI
mkstat = 0
zoncou = "NBRUKI"
indice = 0
status = 1
zoncou = "NBRUKI"
If varmode([M]NBRUKI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRUKI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRUKI
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRUKI = nolign
   status = 75
   Call SAI_NBRUKI(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

