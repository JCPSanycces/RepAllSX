#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECOBJTXT","RECOBJTXT",3,"") From GTRAITE
End

#-------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 PSUBB = (filinfo(filpath("TRT","RECOBJTXTB","adx"),0)>=0)
Endif
Case ACTION
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
Endcase
If PSUBB
 Gosub ACTION From RECOBJTXTB
Endif
Return

#--------------------#
$INIT
Local Mask RECOBJTXT [DIA]
Raz [M:DIA]
Return

#--------------------#
$AVANT_PAR
Local Integer TEST
TEST = 0    # 0:mise à jour - 1:test
Gosub SET_TYPX3 From GOBJTXT
[M]NBLIG = 0
I = [M]NBLIG-1
I += 1 : [M]TYP(I) = "PHO" : [M]REC(I) = 2 : [M]OPT(I) = 0 : [M]OBJ(I) = mess(174,115,1)             : # Photos
I += 1 : [M]TYP(I) = "COM" : [M]REC(I) = 2 : [M]OPT(I) = 2 : [M]OBJ(I) = mess(172,115,1)             : # Commentaires
I += 1 : [M]TYP(I) = "PJC" : [M]REC(I) = 2 : [M]OPT(I) = 2 : [M]OBJ(I) = mess(118,124,1)             : # Pièces jointes
                                                             [M]OBJ(I) -= "("+CLOBX3+","+CLOBXT+")"
I += 1 : [M]TYP(I) = "PJB" : [M]REC(I) = 2 : [M]OPT(I) = 0 : [M]OBJ(I) = mess(118,124,1)             : # Pièces jointes
                                                             [M]OBJ(I) -= "("+BLOBX3+")"
If GADONIX=2
 I +=1 : [M]TYP(I) = "ASU" : [M]REC(I) = 2 : [M]OPT(I) = 0 : [M]OBJ(I) = "File ASUBPROG"
Endif

[M]NBLIG = I+1
Return

#--------------------#
$CONTROLE
OK = 1
Call OUINON(mess(171,115,1),OK) From GESECRAN : # Récupération des fichiers textes
If OK<>2 : SAI = 1 : Return : Endif
Return

#--------------------#
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(171,115,1)) From LECFIC : # Récupération des fichiers textes
Endif
For I=1 To [M]NBLIG
 If [M]REC(I-1)=2
  Case [M]TYP(I-1)
   When "PHO" : Call BLOB_PHOTO_UTIL([M]DOSSIER,[M]TRACE,TEST)                              : # Photos
   When "COM" : Call CLOB_COMMENT([M]DOSSIER,[M]DATDEB,[M]DATFIN,[M]OPT(I-1),[M]TRACE,TEST) : # Commentaires
   When "PJC" : Call CLOB_PIECE([M]DOSSIER,[M]DATDEB,[M]DATFIN,[M]OPT(I-1),[M]TRACE,TEST)   : # Pièces jointes clob
   When "PJB" : Call BLOB_PIECE([M]DOSSIER,[M]DATDEB,[M]DATFIN,[M]TRACE,TEST)               : # Pièces jointes blob
   When "ASU" : Call CLOB_SUBPROG([M]DOSSIER,[M]TRACE,TEST)                                 : # Récup textes ASUBPROG (Interne)
  Endcase
 Endif
Next I
TRA = 1
Return

#----------------------------------------------------------------------------------------------------#
# Moulinette de transformation des images utilisateur en blob
#----------------------------------------------------------------------------------------------------#

Subprog BLOB_PHOTO_UTIL(APPLI,TRACE,TEST)
Value Char    APPLI
Value Integer TRACE, TEST

Local Integer I, J, K, T, OK, INTE
Local Char    PHOTO(50), FICHIER(GDIMFIC), SUF(10), TEXTE(250)
Local Integer SAVIUM
Local Char    SAVIRS(5), SAVIFS(5)
Local Char    OBJET(10), BID(10)

Local File =APPLI+".AUTILIS" [AUS], =APPLI+".ABLOB" [ABB], =APPLI+".ABLOB" [ABB2]

OBJET = "AUSPIC"

SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

# Recupération Photos
TEXTE = mess(173,115,1)-mess(174,115,1)
Call ECR_TRACE("****"-TEXTE-num$(nbrecord([F:AUS]))-"****",0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:AUS])) From GESECRAN

T = 0
For [AUS]
 T += 1
 Call AFF_BOITE("",T,INTE) From GESECRAN
 PHOTO = "AUS_"+[F:AUS]USR
 For SUF="jpg","bmp"
  FICHIER = filpath("PIC",PHOTO,SUF,APPLI)
  If filinfo(FICHIER,0)>0
   Gosub TRT_PHOTO
   Break
  Endif
 Next SUF
Next AUS

Call FERME_BOITE From GESECRAN

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS

End

#-----------------------------#
$TRT_PHOTO
Openi FICHIER Using [FIC]
Getseq 1,[F:ABB2]BLOB Using [FIC]
If fstat
 OK = -1
Else
 Getseq 1,BID Using [FIC]
 If fstat
  OK = 1 : # On a tout lu
 Else
  OK = 0
 Endif
Endif
Openi Using [FIC]
If !OK
 Call ERREUR("|"+FICHIER-":"-mess(175,115,1),4) From DOSDIC : # Taille du fichier trop grande
Elsif OK=1
 Gosub TR_PHOTO
 If GOK=1
  If TRACE=2
   Call ECR_TRACE(PHOTO-"->"-[F:ABB]CODBLB-[F:ABB]IDENT1,0) From GESECRAN
  Endif
  If !TEST
   Call EFFACE(FICHIER,OK) From ORDSYS
  Endif
 Endif
Endif
Return

#-----------------------------#
$TR_PHOTO
GOK=1
Trbegin [ABB]
 If TEST
  Delete [ABB]ABB0 = OBJET;[F:AUS]USR;"";""
 Endif
 Raz [F:ABB]
 [F:ABB]BLOB = [F:ABB2]BLOB
 [F:ABB]CODBLB = OBJET
 [F:ABB]NAMBLB = [F:AUS]NOMUSR
 [F:ABB]IDENT1 = [F:AUS]USR
 [F:ABB]IDENT2 = ""
 [F:ABB]IDENT3 = ""
 If dim([F:ABB]CREUSR)>0 : [F:ABB]CREUSR = GUSER : Endif
 If dim([F:ABB]CREDAT)>0 : [F:ABB]CREDAT = date$ : Endif
 If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM = time  : Endif
 Write [ABB]
 If fstat
  Call ERREUR("ABLOB"-OBJET-[F:AUS]USR-"|"+FICHIER,1) From DOSDIC
  GOK=0 : Goto ROLL_PHOTO
 Endif
Commit
Return

$ROLL_PHOTO
Rollback
Return

#----------------------------------------------------------------------------------------------------#
# Moulinette de transformation des commentaires en clob
#----------------------------------------------------------------------------------------------------#

Subprog CLOB_COMMENT(APPLI,DATDEB,DATFIN,OPT,TRACE,TEST)
Value Char    APPLI
Value Date    DATDEB , DATFIN
Value Integer OPT, TRACE, TEST

Local Integer I, J, K, T, OK, INTE
Local Char    NOMFIC(GDIMFIC) , FICHIER(GDIMFIC) , FICBIS(GDIMFIC) , FILTRE(250) , TEXTE(250)
Local Char    CLE1(GLONID1) , CLEBIS(GLONID2)
Local Char    OBJET(10) , ABREV(GLONAOB), BID(10)
Local Integer SAVIUM
Local Char    TRAIT(50)(1..30000)
Local Integer NBTRAIT , MAXTRAIT , FIN
Local Char    SAVIRS(5), SAVIFS(5)

Local File =APPLI+".AOBJET"  [AOB]
&        , =APPLI+".ACLOB"   [ACB], =APPLI+".ACLOB"   [ACB2]

SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

Gosub SET_COM From GOBJTXT
Gosub SET_TYPX3 From GOBJTXT

Case OPT
 When 2 : FILTRE = "C_*.rtf"
 When 3 : FILTRE = "C_*.txt"
Endcase

# Récupération Commentaires
TEXTE = mess(173,115,1)-mess(172,115,1)

While 1=1 & !FIN
 Call TEMPON("R") From GESECRAN
 Call SYSTEME2(adxmac(0),'lsadx -a '+APPLI+' TXT "'+FILTRE+'"','',NBTRAIT,TRAIT) From ORDSYS
 Call TEMPOFF From GESECRAN
 If MAXTRAIT=0
  MAXTRAIT = NBTRAIT
  Call ECR_TRACE("\****"-TEXTE-num$(MAXTRAIT)-"****",0) From GESECRAN
 Endif
 NBTRAIT = max(0,min(NBTRAIT,dim(TRAIT)))
 If NBTRAIT=0
  Break
 Elsif NBTRAIT<>dim(TRAIT)
  FIN = 1 : # Pour éviter de boucler
 Endif
 Call OUVRE_BOITE(TEXTE,100) From GESECRAN
 Call SET_BOITE(TEXTE,NBTRAIT) From GESECRAN
 For T=1 To NBTRAIT
  Call AFF_BOITE("",T,INTE) From GESECRAN
  K = instr(1,TRAIT(T),".")
  If K
   NOMFIC = left$(TRAIT(T),K-1)
  Else
   NOMFIC = TRAIT(T)
  Endif
  Gosub TRT_COM
 Next T
 Call FERME_BOITE From GESECRAN
Wend

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS

End

#--------------------------#
$TRT_COM
I = instr(1,NOMFIC,"_")
J = instr(I+1,NOMFIC,"_")
If J=0 : Return : Endif
ABREV = seg$(NOMFIC,I+1,J-1)
Read [AOB]ABREV = ABREV
If fstat : Return : Endif
CHAINE = right$(NOMFIC,J+1)
Raz CLE1, CLEBIS
K = instr(1,CHAINE,"_")
If !K
 CLE1 = CHAINE
Else
 CLE1 = left$(CHAINE,K-1)
 CLEBIS = right$(CHAINE,K+1)
 I = 0
 K = instr(1,CLEBIS,"_")
 While K<>0
  I += 1
  CLEBIS = left$(CLEBIS,K-1)+"~"+right$(CLEBIS,K+1)
  K = instr(1,CLEBIS,"_")
 Wend
Endif
OBJET = CBLOB+ABREV
Case OPT
 When 2 : FICHIER = filpath("TXT",NOMFIC,"rtf",APPLI) : FICBIS = filpath("TXT",NOMFIC,"txt",APPLI)
 When 3 : FICHIER = filpath("TXT",NOMFIC,"txt",APPLI) : FICBIS = filpath("TXT",NOMFIC,"rtf",APPLI)
Endcase
K = 1
If filinfo(FICHIER,0)<=0
 K = 0
Elsif DATDEB<>[0/0/0] or DATFIN<>[0/0/0]
 Gosub DATFIC
 If DATFIN<>[0/0/0] & DATFIC>DATFIN
  K = 0
 Elsif DATDEB<>[0/0/0] & DATFIC<DATDEB
  K = 0
 Endif
Endif
If K
 Openi FICHIER Using [FIC]
 Rdseq [F:ACB2]CLOB Using [FIC]
 Case OPT
  When 2 : # rtf
   If fstat
    OK = -1
   Else
    Rdseq BID Using [FIC]
    If fstat
     OK = 1 : # On a tout lu
    Else
     OK = 0
    Endif
   Endif
  When 3 : # txt
   If fstat
    OK = 1 : # On a tout lu
   Else
    OK = 0
   Endif
 Endcase
 Openi Using [FIC]
 If !OK
  Call ERREUR("|"+FICHIER-":"-mess(175,115,1),4) From DOSDIC
 Elsif OK=1
  Gosub TR_COM
  If GOK=1
   If TRACE=2
    Call ECR_TRACE(NOMFIC,0) From GESECRAN
   Endif
   If !TEST
    Call EFFACE(FICHIER,OK) From ORDSYS
    If FICBIS<>"" & filinfo(FICBIS,0)>0
     Call EFFACE(FICBIS,OK) From ORDSYS
    Endif
   Endif
  Endif
 Endif
Endif
Return

#-----------------------------#
$DATFIC
Local Integer T , J , H , M , S
Local Date    DATFIC
T = filinfo(FICHIER,9)
J = int(T/(3600*24))
H = int(mod(T,3600*24)/3600)
M = int(mod(T,3600)/60)
S = mod(T,60)
DATFIC  = [01/01/1970]+J
Return

#-----------------------------#
$TR_COM
GOK=1
Trbegin [ACB]
 If TEST
  Delete [ACB]ACB0 = OBJET;CLE1;CLEBIS;"1"
 Endif
 Raz [F:ACB]
 [F:ACB]CLOB = [F:ACB2]CLOB
 [F:ACB]CODBLB = OBJET
 Case OPT
  When 2 : [F:ACB]TYPDOC = CLOBX3 : # rtf
  When 3 : [F:ACB]TYPDOC = CLOBXT : # txt
 Endcase
 [F:ACB]NAMBLB = NOMFIC
 [F:ACB]IDENT1 = CLE1
 [F:ACB]IDENT2 = CLEBIS
 [F:ACB]IDENT3 = "1"
 If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
 If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
 If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
 If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
 Write [ACB]
 If fstat
  Call ERREUR("ACLOB"-OBJET-CLE1-CLEBIS-"|"+FICHIER,1) From DOSDIC
  GOK=0 : Goto ROLL_COM
 Endif
Commit
Return

$ROLL_COM
Rollback
Return

#----------------------------------------------------------------------------------------------------#
# Moulinette de transformation des pièces jointes en clob
#----------------------------------------------------------------------------------------------------#

Subprog CLOB_PIECE(APPLI,DATDEB,DATFIN,OPT,TRACE,TEST)
Value Char    APPLI
Value Date    DATDEB , DATFIN
Value Integer OPT, TRACE, TEST

Local Integer I, J, K, T, OK, INTE
Local Char    NOMFIC(250), FICHIER(250), FICBIS(250) , TEXTE(250)
Local Char    OS(20) , SUF(10)
Local Char    OBJET(10) , BID(10)
Local Integer SAVIUM
Local Char    SAVIRS(5), SAVIFS(5)

Local File =APPLI+".ACLOB"   [ACB],  =APPLI+".ACLOB"   [ACB2]
&        , =APPLI+".AOBJTXT" [AOX],  =APPLI+".ADOVAL"  [ADW]

SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

Gosub SET_PCE From GOBJTXT
Gosub SET_TYPX3 From GOBJTXT

# Récupération Pièces jointes
TEXTE = mess(173,115,1)-mess(118,124,1)-"("+CLOBX3+","+CLOBXT+")"
Call ECR_TRACE("\****"-TEXTE-num$(nbrecord([F:AOX]))-"****",0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:AOX])) From GESECRAN

T = 0
For [AOX] Where find(TYPDOC,CLOBX3,CLOBXT)<>0
 T += 1
 Call AFF_BOITE("",T,INTE) From GESECRAN
 OBJET = CBLOB+[F:AOX]ABREV
 NOMFIC = [F:AOX]NAM
 Case OPT
  When 2 : FICHIER = filpath("TXT",NOMFIC,"rtf",APPLI) : FICBIS = filpath("TXT",NOMFIC,"txt",APPLI)
  When 3 : FICHIER = filpath("TXT",NOMFIC,"txt",APPLI) : FICBIS = filpath("TXT",NOMFIC,"rtf",APPLI)
 Endcase
 K = 1
 If filinfo(FICHIER,0)<=0
  K = 0
 Elsif DATDEB<>[0/0/0] or DATFIN<>[0/0/0]
  Gosub DATFIC
  If DATFIN<>[0/0/0] & DATFIC>DATFIN
   K = 0
  Elsif DATDEB<>[0/0/0] & DATFIC<DATDEB
   K = 0
  Endif
 Endif
 If K
  Openi FICHIER Using [FIC]
  Rdseq [F:ACB2]CLOB Using [FIC]
  Case OPT
   When 2 : # rtf
    If fstat
     OK = -1
    Else
     Rdseq BID Using [FIC]
     If fstat
      OK = 1 : # On a tout lu
     Else
      OK = 0
     Endif
    Endif
   When 3 : # txt
    If fstat
     OK = 1 : # On a tout lu
    Else
     OK = 0
    Endif
  Endcase
  Openi Using [FIC]
  If !OK
   Call ERREUR("|"+FICHIER-":"-mess(175,115,1),4) From DOSDIC
  Elsif OK=1
   Gosub TR_CLOB
   If GOK=1
    If TRACE=2
     Call ECR_TRACE(NOMFIC,0) From GESECRAN
    Endif
    If !TEST
     Call EFFACE(FICHIER,OK) From ORDSYS
     If FICBIS<>"" & filinfo(FICBIS,0)>0
      Call EFFACE(FICBIS,OK) From ORDSYS
     Endif
    Endif
   Endif
  Endif
 Endif
Next AOX

Call FERME_BOITE From GESECRAN

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS
End

#-----------------------------#
$TR_CLOB
GOK=1
Trbegin [ACB]
 [F:AOX]NAM = NOMFIC
 Rewrite [AOX]
 If fstat
  Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]IDENT1-[F:AOX]IDENT2-[F:AOX]IDENT3-NOMFIC,2) From DOSDIC
  GOK=0 : Goto ROLL_CLOB
 Endif
 If TEST
  Delete [ACB]ACB0 = OBJET;[F:AOX]IDENT1;[F:AOX]IDENT2;[F:AOX]IDENT3
 Endif
 Raz [F:ACB]
 [F:ACB]CLOB = [F:ACB2]CLOB
 [F:ACB]CODBLB = OBJET
 Case OPT
  When 2 : [F:ACB]TYPDOC = CLOBX3 : # rtf
  When 3 : [F:ACB]TYPDOC = CLOBXT : # txt
 Endcase
 [F:ACB]NAMBLB = NOMFIC
 [F:ACB]IDENT1 = [F:AOX]IDENT1
 [F:ACB]IDENT2 = [F:AOX]IDENT2
 [F:ACB]IDENT3 = [F:AOX]IDENT3
 If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
 If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
 If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
 If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
 Write [ACB]
 If fstat
  Call ERREUR("ACLOB"-OBJET-[F:AOX]IDENT1-[F:AOX]IDENT2-[F:AOX]IDENT3-"|"+FICHIER,1) From DOSDIC
  GOK=0 : Goto ROLL_CLOB
 Endif
Commit
Return

$ROLL_CLOB
Rollback
Return

#----------------------------------------------------------------------------------------------------#
# Moulinette de transformation des pièces jointes en blob
#----------------------------------------------------------------------------------------------------#

Subprog BLOB_PIECE(APPLI,DATDEB,DATFIN,TRACE,TEST)
Value Char    APPLI
Value Date    DATDEB , DATFIN
Value Integer TRACE, TEST

Local Integer I, J, K, T, OK, INTE
Local Char    NOMFIC(250), FICHIER(250), FICBIS(250) , TEXTE(250)
Local Char    OS(20), REPERT(250) , REP1(20), REP2(20) , SUF(10)
Local Char    OBJET(10) , BID(10)
Local Integer SAVIUM
Local Char    SAVIRS(5), SAVIFS(5)

Local File =APPLI+".ABLOB"   [ABB],  =APPLI+".ABLOB"   [ABB2]
&        , =APPLI+".AOBJTXT" [AOX],  =APPLI+".ADOVAL"  [ADW]

SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

Gosub SET_PCE From GOBJTXT
Gosub SET_TYPX3 From GOBJTXT
Call GET_OS("",OS) From ORDSYS
Call PARAM("","DIRPCE1",REP1) From ADOVAL
Call PARAM("","DIRPCE2",REP2) From ADOVAL
If left$(REP1,1)="%"
 REPERT = filpath(right$(REP1+REP2,2),"","",0)
Else
 REPERT = REP1+REP2
Endif
If OS="unix" & right$(REPERT,len(REPERT))<>"/"
 REPERT += "/"
Elsif OS<>"unix" & right$(REPERT,len(REPERT))<>"\"
 REPERT += "\"
Endif

# Récupération Pièces jointes
TEXTE = mess(173,115,1)-mess(118,124,1)-"("+BLOBX3+")"
Call ECR_TRACE("\****"-TEXTE-num$(nbrecord([F:AOX]))-"****",0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:AOX])) From GESECRAN

T = 0
For [AOX] Where find(TYPDOC,BLOBX3)<>0
 T += 1
 Call AFF_BOITE("",T,INTE) From GESECRAN
 OBJET = CBLOB+[F:AOX]ABREV
 FICHIER = [F:AOX]NAM
 If left$(FICHIER,1)="%" & REPERT<>""
  If find(mid$(FICHIER,2,1),"/","\")
   FICHIER = REPERT+right$(CHEMIN,3)
  Else
   FICHIER = REPERT+right$(CHEMIN,2)
  Endif
 Endif
 Call SETNAM(FICHIER,NOMFIC,SUF) From GOBJTXT
 K = 1
 If filinfo(FICHIER,0)<=0
  K = 0
 Elsif DATDEB<>[0/0/0] or DATFIN<>[0/0/0]
  Gosub DATFIC
  If DATFIN<>[0/0/0] & DATFIC>DATFIN
   K = 0
  Elsif DATDEB<>[0/0/0] & DATFIC<DATDEB
   K = 0
  Endif
 Endif
 If K
  Openi FICHIER Using [FIC]
  Getseq 1,[F:ABB2]BLOB Using [FIC]
  If fstat
   OK = -1
  Else
   Getseq 1,BID Using [FIC]
   If fstat
    OK = 1 : # On a tout lu
   Else
    OK = 0
   Endif
  Endif
  Openi Using [FIC]
  If !OK
   Call ERREUR("|"+FICHIER-":"-mess(175,115,1),4) From DOSDIC : # Taille du fichier trop grande
  Elsif OK=1
   Gosub TR_BLOB
   If GOK=1 & TRACE=2
    Call ECR_TRACE(mess(2,938,1)-NOMFIC,0) From GESECRAN : # Blob
   Endif
  Endif
 Endif
Next AOX

Call FERME_BOITE From GESECRAN

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS
End

#-----------------------------#
$TR_BLOB
GOK=1
Trbegin [ABB]
 [F:AOX]NAM = NOMFIC
 Rewrite [AOX]
 If fstat
  Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]IDENT1-[F:AOX]IDENT2-[F:AOX]IDENT3-NOMFIC,2) From DOSDIC
  GOK=0 : Goto ROLL_BLOB
 Endif
 If TEST
  Delete [ABB]ABB0 = OBJET;[F:AOX]IDENT1;[F:AOX]IDENT2;[F:AOX]IDENT3
 Endif
 Raz [F:ABB]
 [F:ABB]BLOB = [F:ABB2]BLOB
 [F:ABB]CODBLB = OBJET
 [F:ABB]NAMBLB = NOMFIC
 [F:ABB]TYPBLB = 3
 [F:ABB]IDENT1 = [F:AOX]IDENT1
 [F:ABB]IDENT2 = [F:AOX]IDENT2
 [F:ABB]IDENT3 = [F:AOX]IDENT3
 If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
 If dim([F:ABB]CREUSR)>0 : [F:ABB]CREUSR = GUSER : Endif
 If dim([F:ABB]CREDAT)>0 : [F:ABB]CREDAT = date$ : Endif
 If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM = time  : Endif
 Write [ABB]
 If fstat
  Call ERREUR("ABLOB"-OBJET-[F:AOX]IDENT1-[F:AOX]IDENT2-[F:AOX]IDENT3-"|"+FICHIER,1) From DOSDIC
  GOK=0 : Goto ROLL_BLOB
 Endif
Commit
Return

$ROLL_BLOB
Rollback
Return

#----------------------------------------------------------------------------------------------------#
# Moulinette de récupération des commentaires dans ASUBPROG (interne)
#----------------------------------------------------------------------------------------------------#

Subprog CLOB_SUBPROG(APPLI,TRACE,TEST)
Value Char    APPLI
Value Integer TRACE, TEST

Local Char AIDE(80)(1..10) , TEXTE(250)
Local Integer I , J , K , L , T , INTE

Local File =APPLI+".ASUBPROG" [ASU]

If dim([F:ASU]COMMENT)<=0 : End : Endif

TEXTE = mess(173,115,1)-"Asubprog"
Call ECR_TRACE("****"-TEXTE-num$(nbrecord([F:ASU]))-"****",0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:ASU])) From GESECRAN

K = dim([F:ASU]COMMENT)-1
L = type(AIDE)-10
T = 0

GOK = 1
Trbegin [ASU]
 For [ASU]
  T += 1
  Call AFF_BOITE("",T,INTE) From GESECRAN
  If sum([F:ASU]COMMENT)<>""
   Setlob AIDE With [F:ASU]TEX
   If sum(AIDE)=""
    Gosub AIDE
    Setlob [F:ASU]TEX With AIDE(1..J)
    If !TEST
     Raz [F:ASU]COMMENT
    Endif
    Rewrite [ASU]
    If fstat
     Call ERREUR("ASUBPROG"-[F:ASU]PRG-[F:ASU]SUBPRG,2) From DOSDIC
    Elsif TRACE=2
     Call ECR_TRACE("Subprog"-[F:ASU]SUBPRG-"From"-[F:ASU]PRG,0) From GESECRAN
    Endif
   Endif
  Endif
 Next ASU
Commit

Call FERME_BOITE From GESECRAN

End

#-----------------------------#

$AIDE
Raz AIDE
J = 1
For I=0 To dim([F:ASU]COMMENT)-1
 If [F:ASU]COMMENT(I)<>""
  K = len(AIDE(J))+1+len([F:ASU]COMMENT(I))
  If K<=L
   If AIDE(J)<>""
    AIDE(J) += " "
   Endif
   AIDE(J) += [F:ASU]COMMENT(I)
  Else
   J += 1
   AIDE(J) = chr$(10)+[F:ASU]COMMENT(I)
  Endif
 Endif
Next I
Return

#---------------------------------------------------------------#
# Etiquette du masque RECOBJTXT
#---------------------------------------------------------------#

Subprog AS_OPT(VALEUR)
Variable Integer VALEUR
If find([M]TYP(nolign-1),"PHO","PJB","ASU")
 mkstat = 1 : End
Endif
GMENLOC(1) = 1
End
