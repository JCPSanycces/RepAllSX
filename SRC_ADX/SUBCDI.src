#<AdxTL>@(#)5.0.0.0 $Revision$
#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CDI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"   :  Gosub OUVRE
 When "SETBOUT" :  Gosub SETBOUT
 #JOJAC - 2017-01-18 - START
 When "FILGAUCHE" :  Gosub FILGAUCHE
 #JOJAC - 2017-01-18 - END
Endcase
Return

$OUVRE
If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif
Return


$SETBOUT
Call VIREBOUT(CHAINE,"A") From GOBJET
Return

#JOJAC - 2017-01-18 - START
$FILGAUCHE
If GMODU(15)<>2 #Module PAYROLL inactive
  FILGAUCHE ="OBJ<18 | OBJ>25" : ##
Else
  If GMODU(2)<>2
    #JOJAC - 2017-02-09 - START
    #FILGAUCHE ="(OBJ>=18 & OBJ<=25)"
    FILGAUCHE ="(OBJ>=18 & OBJ<=25 | OBJ=5 | OBJ=8)"
    #JOJAC - 2017-02-09 - END
  Endif
Endif
Return
#JOJAC - 2017-01-18 - END

####################################################################################
## Etiquettes du masques [CDI1]
####################################################################################
Subprog AS_OBJ(VALEUR)
Variable Integer VALEUR

#GMENLOC(12) = 1 # SAM 88426 - 2015-06-22 by LUCUE : Factoring Management
GMENLOC(13) = 1
GMENLOC(15) = 1

If GMODU(3)<>2 :  GMENLOC(7)  = 1 : Endif
If GMODU(5)<>2 :  GMENLOC(10) = 1 : Endif
If GMODU(6)<>2 :  GMENLOC(14) = 1 : Endif
If GMODU(8)<>2 :  GMENLOC(16) = 1 : Endif

#JOJAC - 2017-01-20 - START
If GMODU(15)<>2 #Module PAYROLL inactive
  DEB=18 : FIN=25
  For I=DEB To FIN
    GMENLOC(I)=1
  Next
Else
  If GMODU(2)<>2 #Module FINANCIALS inactive
    DEB=1 : FIN=17
    For I=DEB To FIN
    #JOJAC - 2017-03-01 - START
    If I <> 5 & I <> 8
    #JOJAC - 2017-03-01 - END
      GMENLOC(I)=1
    #JOJAC - 2017-03-01 - START
    Endif
    #JOJAC - 2017-03-01 - END
    Next
  Endif
Endif
#JOJAC - 2017-01-20 - END
End

Subprog AS_DIE(VALEUR)
Variable Char    VALEUR()
# Pas de modification... uniquement de l'insertion.
If VALEUR<>"" : mkstat = 2 : Endif
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
End

######################################################################################
Subprog C_NBRDIE
Local Integer J
Local Integer OKDIE, INDDIE
Local Char DIE(GLONDIE), MESSCLE(50),MESSTAB(50), MESSFCT(50), TIT(50)
Raz MESSCLE, MESSTAB, MESSFCT, TIT

If status>=65 & status<=90
 Case status
  When 65,68,83 : # Annulation ligne
   If status=65
    Raz OKDIE
    [L]DIE = [M:CDI1]DIE(nolign-1)
    Gosub VERIF
    If OKDIE
     # Suppression impossible
     Call TITFNC(MESSFCT,TIT) From CONTOBJ
     # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
     GMESSAGE = mess(101,126,1)-MESSCLE-mess(198,133,1)-MESSTAB-"("+TIT+")\"-mess(176,115,1)
     mkstat = 2 : End
    Endif
   Else
    For I=nolign To nolign1
     Raz OKDIE
     [L]DIE = [M:CDI1]DIE(I-1)
     Gosub VERIF
     If OKDIE
      # Suppression impossible
      Call TITFNC(MESSFCT,TIT) From CONTOBJ
      # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
      GMESSAGE = mess(101,126,1)-MESSCLE-mess(198,133,1)-MESSTAB-"("+TIT+")\"-mess(176,115,1)
      mkstat = 2 : End
     Endif
    Next I
   Endif
 Endcase
Endif
End


######################################################################################
$VERIF

Case [M:CDI1]OBJ

 When  1 : # Article
    If filinfo(filpath("FIL","ITMMASTER","fde",""),0) < 0 : Return : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
    Read [ITM] First
    If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:ITM]DIE)-1
       If [L]DIE=[F:ITM]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [ITM]
        If [F:ITM]CCE(INDDIE)<>"" & [F:ITM]DIE(INDDIE)=[L]DIE
         MESSTAB = "ITMMASTER" : MESSCLE = [F:ITM]ITMREF : MESSFCT="GESITM" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif
  When  2 : # Client
     If filinfo(filpath("FIL","BPCUSTOMER","fde",""),0) < 0 : Return : Endif
     If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
     Read [BPC] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:BPC]DIE)-1
       If [L]DIE=[F:BPC]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [BPC]
        If [F:BPC]CCE(INDDIE)<>"" & [F:BPC]DIE(INDDIE)=[L]DIE
         MESSTAB = "BPCUSTOMER" : MESSCLE = [F:BPC]BPCNUM : MESSFCT="GESBPC" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif
  When  3 : # Fournisseur
     If filinfo(filpath("FIL","BPSUPPLIER","fde",""),0) < 0 : Return : Endif
     If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
     Read [BPS] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:BPS]DIE)-1
       If [L]DIE=[F:BPS]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [BPS]
        If [F:BPS]CCE(INDDIE)<>"" & [F:BPS]DIE(INDDIE)=[L]DIE
         MESSTAB = "BPSUPPLIER" : MESSCLE = [F:BPS]BPSNUM : MESSFCT="GESBPS" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When  4 : # Commercial
     If filinfo(filpath("FIL","SALESREP","fde",""),0) < 0 : Return : Endif
     If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
     Read [REP] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:REP]DIE)-1
       If [L]DIE=[F:REP]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [REP]
        If [F:REP]CCE(INDDIE)<>"" & [F:REP]DIE(INDDIE)=[L]DIE
         MESSTAB = "SALESREP" : MESSCLE = [F:REP]REPNUM : MESSFCT="GESREP" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When  5 : # Utilisateur
     If filinfo(filpath("FIL","AUTILIS","fde",""),0) < 0 : Return : Endif
     If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
     Read [AUS] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:AUS]DIE)-1
       If [L]DIE=[F:AUS]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [AUS]
        If [F:AUS]CCE(INDDIE)<>"" & [F:AUS]DIE(INDDIE)=[L]DIE
         MESSTAB = "AUTILIS" : MESSCLE = [F:AUS]USR : MESSFCT="GESAUS" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif
     If OKDIE=1 : Return : Endif
     #JOJAC - US X3-22764  TASK X3-25127 - 2017-03-15 - START
     #If filinfo(filpath("FIL","EXPENSES","fde",""),0) < 0 : Return : Endif
     If filinfo(filpath("FIL","EXPENSES","fde",nomap),0) < 0 : Return : Endif
     #JOJAC - US X3-22764  TASK X3-25127 - 2017-03-15 - END
     If clalev([F:EXS])=0 : Local File EXPENSES [EXS] : Endif
     Local Integer NBANA
     NBANA = func AFNC.ACTIV("ANA")
     Filter [EXS] Where find([L]DIE,[F:EXS]DIE(0..NBANA))<>0
     Read [EXS]First
     Filter [EXS]
     If !fstat
      MESSTAB = "EXPENSES" : MESSCLE = [F:EXS]CLB : MESSFCT="GESEXS" : OKDIE = 1 : Return
     Endif

  When  6 : # Frais généraux
     If filinfo(filpath("FIL","OVENAT","fde",""),0) < 0 : Return : Endif
     If clalev([F:ONA])=0 : Local File OVENAT [ONA] : Endif
     Read [ONA] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:ONA]DIE)-1
       If [L]DIE=[F:ONA]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [ONA]
        If [F:ONA]CCE(INDDIE)<>"" & [F:ONA]DIE(INDDIE)=[L]DIE
         MESSTAB = "OVENAT" : MESSCLE = [F:ONA]OVENAT : MESSFCT="GESONA" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When  7 : # Frais pour notes de frais
#JASMI - 2017-06-07 - X3-42325 - START
#     If filinfo(filpath("FIL","TABEXPENS","fde",""),0) < 0 : Return : Endif
     If filinfo(filpath("FIL","TABEXPENS","fde",nomap),0) < 0 : Return : Endif
#JASMI - 2017-06-07 - X3-42325 - END
     If clalev([F:TES])=0 : Local File TABEXPENS [TES] : Endif
     Read [TES] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:TES]DIE)-1
       If [L]DIE=[F:TES]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [TES]
        If [F:TES]CCE(INDDIE)<>"" & [F:TES]DIE(INDDIE)=[L]DIE
         MESSTAB = "TABEXPENS" : MESSCLE = [F:TES]CODEXP : MESSFCT="GESTES" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif
 When  8 : # Devise
     If filinfo(filpath("FIL","TABCUR","fde",""),0) < 0 : Return : Endif
     If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
     Read [TCU] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:TCU]DIE)-1
       If [L]DIE=[F:TCU]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [TCU]
        If [F:TCU]CCE(INDDIE)<>"" & [F:TCU]DIE(INDDIE)=[L]DIE
         MESSTAB = "TABCUR" : MESSCLE = [F:TCU]CUR : MESSFCT="GESTCU" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

 When  9 : # Taxe
     If filinfo(filpath("FIL","TABVAT","fde",""),0) < 0 : Return : Endif
     If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
     Read [TVT] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:TVT]DIE)-1
       If [L]DIE=[F:TVT]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [TVT]
        If [F:TVT]CCE(INDDIE)<>"" & [F:TVT]DIE(INDDIE)=[L]DIE
         MESSTAB = "TABVAT" : MESSCLE = [F:TVT]VAT : MESSFCT="GESTVT" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

 When 10 : # Pied de facture vente
     If filinfo(filpath("FIL","SFOOTINV","fde",""),0) < 0 : Return : Endif
     If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif
     Read [SFI] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:SFI]DIE)-1
       If [L]DIE=[F:SFI]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [SFI]
        If [F:SFI]CCE(INDDIE)<>"" & [F:SFI]DIE(INDDIE)=[L]DIE
         MESSTAB = "SFOOTINV" : MESSCLE = num$([F:SFI]SFINUM) : MESSFCT="GESSFI" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

 When 11 : # Escompte/Agio
     If filinfo(filpath("FIL","TABDEPAGIO","fde",""),0) < 0 : Return : Endif
     If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
     Read [TDA] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:TDA]DIE)-1
       If [L]DIE=[F:TDA]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [TDA]
        If [F:TDA]CCE(INDDIE)<>"" & [F:TDA]DIE(INDDIE)=[L]DIE
         MESSTAB = "TABDEPAGIO" : MESSCLE = [F:TDA]DEP : MESSFCT="GESTDA" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When 12 : # Banque

  When 13 : # Destination comptable

  When 14 : # Pied de facture achat
     If filinfo(filpath("FIL","PFOOTINV","fde",""),0) < 0 : Return : Endif
     If clalev([F:PFI])=0 : Local File PFOOTINV [PFI] : Endif
     Read [PFI] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:PFI]DIE)-1
       If [L]DIE=[F:PFI]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [PFI]
        If [F:PFI]CCE(INDDIE)<>"" & [F:PFI]DIE(INDDIE)=[L]DIE
         MESSTAB = "PFOOTINV" : MESSCLE = num$([F:PFI]PFINUM) : MESSFCT="GESPFI" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When 15 : # Tiers divers

  When 16 : # Sections de valorisation
     If filinfo(filpath("FIL","WORKCOST","fde",""),0) < 0 : Return : Endif
     If clalev([F:MWC])=0 : Local File WORKCOST [MWC] : Endif
     Read [MWC] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:MWC]DIE)-1
       If [L]DIE=[F:MWC]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [MWC]
        If [F:MWC]CCE(INDDIE)<>"" & [F:MWC]DIE(INDDIE)=[L]DIE
         MESSTAB = "WORKCOST" : MESSCLE = [F:MWC]VLTCCE : MESSFCT="GESMWC" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When 101 : # Catégorie Article
     If filinfo(filpath("FIL","ITMCATEG","fde",""),0) < 0 : Return : Endif
     If clalev([F:ITG])=0 : Local File ITMCATEG [ITG] : Endif
     Read [ITG] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:ITG]DIE)-1
       If [L]DIE=[F:ITG]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [ITG]
        If [F:ITG]CCE(INDDIE)<>"" & [F:ITG]DIE(INDDIE)=[L]DIE
         MESSTAB = "ITMCATEG" : MESSCLE = [F:ITG]TCLCOD: MESSFCT="GESITG" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When 102 : # Catégorie Client
     If filinfo(filpath("FIL","BPCCATEG","fde",""),0) < 0 : Return : Endif
     If clalev([F:BCG])=0 : Local File BPCCATEG [BCG] : Endif
     Read [BCG] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:BCG]DIE)-1
       If [L]DIE=[F:BCG]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [BCG]
        If [F:BCG]CCE(INDDIE)<>"" & [F:BCG]DIE(INDDIE)=[L]DIE
         MESSTAB = "BPCCATEG" : MESSCLE = [F:BCG]BCGCOD : MESSFCT="GESBCG" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif

  When 103 : # Catégorie Fournisseur
     If filinfo(filpath("FIL","BPSCATEG","fde",""),0) < 0 : Return : Endif
     If clalev([F:BSG])=0 : Local File BPSCATEG [BSG] : Endif
     Read [BSG] First
     If !fstat
      INDDIE = -1
      For [L]J=0 To dim([F:BSG]DIE)-1
       If [L]DIE=[F:BSG]DIE([L]J)
        INDDIE=J : Break
       Endif
      Next
      If INDDIE>=0
       For [BSG]
        If [F:BSG]CCE(INDDIE)<>"" & [F:BSG]DIE(INDDIE)=[L]DIE
         MESSTAB = "BPSCATEG" : MESSCLE = [F:BSG]BSGCOD : MESSFCT="GESBSG" : OKDIE = 1 : Break
        Endif
       Next
      Endif
     Endif
  Endcase

Return

