#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################
## Gestion des objets "simples"                           ##
############################################################
$CREATION
OK =1
ACTION = "VERIF_CRE" : Gosub ACTION From GOBJSUB
If !OK : GOK = 0 : Return : Endif

# Vérif du nb maximum de fiches

GOK = 1

If func ARECAUO.APPDEM(nomap)                    : # Dossier démo
 MAXFICHE = 0
 If PROGOBJ<>"WO"+ABREV
  PROGOBJ = "WO"+ABREV
 Endif
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 Local File ATABLE [ATBB]
 Read [ATBB]CODFIC=NOMFIC
 If fstat or [F:ATBB]MODULE<>1                   : # Pas de limite sur les tables superviseur
  If ZSITE<>""
   MAXFICHE = 30000                              : # Limite nombre de fiches mouvements
  Elsif dim(CLESEC)>0 & CLESEC<>""
   MAXFICHE = 15000                              : # Limite nombre de fiches avec clés plus de 2 parties
  Else
   MAXFICHE = 3000                               : # Limite nombre de fiches pour les autres
  Endif
 Endif
 Close Local File [ATBB]
 Gosub DEFAUT From =PROGOBJ
 If MAXFICHE<>0 & nbrecord([F])>=MAXFICHE
  GMESSAGE = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE)  : # Dossier de démonstration\Nb maximum de fiches
  GOK = 0 : Return
 Endif
Endif

Case GPRODUIT
 When 0 : # X3
  MAXFICHE = 0
  If PROGOBJ<>"WO"+ABREV
   PROGOBJ = "WO"+ABREV                           : # Faudrait peut être planter...
  Endif
  Gosub NOMFIC From =PROGOBJ                      : # Pour les petits malins
  If find(NOMFIC,"FIXASSET")
   Case NOMFIC
    When "FIXASSET"
     #Call NOMBRE(1,MAXFICHE) From GLOCK           : # No à préciser
     #87108
     Local Char VALMAX(30)
     If fmet GACTX.AGETLICPAR("MAXFIXEDASSETS",VALMAX)=[V]CST_ATRUE
      MAXFICHE=val(VALMAX)
     Endif
   Endcase
   Gosub DEFAUT From =PROGOBJ                     : # Pour les gros malins
   If MAXFICHE<>0 & nbrecord([F])>=MAXFICHE
    GMESSAGE = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE) : # Dossier de démonstration\Nb maximum de fiches
    GOK = 0 : Return
   Endif
  Endif

 When 1 : # Géode
  MAXFICHE = -1
  If PROGOBJ<>"WO"+ABREV
   PROGOBJ = "WO"+ABREV
  Endif
  Gosub NOMFIC From =PROGOBJ
  Case NOMFIC
   When "FACILITY"
    #Call NOMBRE(2,MAXFICHE) From GLOCK
    #87108
    Local Char VALMAX(30)
    If fmet GACTX.AGETLICPAR("MAX"+NOMFIC,VALMAX)=[V]CST_ATRUE
     MAXFICHE=val(VALMAX)
    Endif
   When "DEPOSITOR"
    Read [DEP]DEP0 = [V]GFCY;[L]NEWCLE1
    If fstat
     #Call NOMBRE(3,MAXFICHE) From GLOCK
     #87108
     Local Char VALMAX(30)
     If fmet GACTX.AGETLICPAR("MAX"+NOMFIC,VALMAX)=[V]CST_ATRUE
      MAXFICHE=val(VALMAX)
     Endif
    Endif
  Endcase
  If MAXFICHE>0
   Gosub DEFAUT From =PROGOBJ
   If nbrecord([F])>=MAXFICHE
    GMESSAGE = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE) : # Dossier de démonstration\Nb maximum de fiches
    GOK = 0 : Return
   Endif
  Endif

 When 3 : # Biens
  Gosub CTLNBR From TRTLIC
Endcase
If GOK<1
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK>=1
 CLECUR = 1
 ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS : Endif
 If OPTENA & !AUTENA & ABRENA<>"" & evalue("[M:"+ABRENA+"]ENAFLG")<>1
  Assign "[M:"+ABRENA+"]ENAFLG" With 1
  Gosub AFF_ENAFLG From =WINPROG
  Call MESSAGE(mess(108,75,1)) From GESECRAN : # Le flag actif ne peut pas être passé à Oui
 Endif
 Call ESPION(NOMFIC,1,IDENT,"") From ESPION
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"C") From GOBJET : Endif
Else
 If GRPDEB<>""
  Call VIRE_GROUPE(GRPDEB) From AWRK
  GOK = 0
 Endif
 Gosub RSTCLE From GOBJSUB
Endif
Return

$TR1
GOK = 1
GRPDEB = ""
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 For IMA=0 To NBMASK
  Gosub CHARGEFIC From =WINPROG
 Next IMA
 Gosub INICRE From GOBJSUB
 If OPTENA & !AUTENA & dim([F]ENAFLG)>0 & [F]ENAFLG<>1
  [F]ENAFLG = 1
 Endif
 ACTION = "INICRE" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
# Vérification du rôle
 Onerrgo RIEN
 ER = 0
 OK = evalue(FILROLE)
 Onerrgo
 If !ER & !OK
  Call ERREUR(mess(97,126,1)) From GESECRAN : # Vous n'avez pas les droits pour créer cette fiche
  GOK = 0 : Goto AB_TR1
 Endif
 If dim(ANOWRITE)<=0 or !ANOWRITE
  Write
  If fstat
   GOK=0 : Call FSTA(ABFIC) From GLOCK
   Goto AB_TR1
  Endif
 Endif
 If dim(OBJUPDDATTIM)>0 & dim([F]UPDDATTIM)>0
  [L]OBJUPDDATTIM = [F]UPDDATTIM
 Endif
 If dim(OBJUPDSTP)>0 & dim([F]UPDSTP)>0
  [L]OBJUPDSTP = [F]UPDSTP
 Endif

 ACTION = "CREATION" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Gosub SET_CLE From GOBJSUB
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 Call WRKGLOB(170,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"C",IDENT,"",0,1,0,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return


$AB_TR1
Rollback
ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL
 ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
 Return
Else
 Goto TR1
Endif

####################################################
$MODIF
If GADONIX=2
 Call VERIF_GRP(ABREV,CLECUR1,CLECUR2,OK) From GOBJET
 If !OK : GOK = 0 : Return : Endif
Endif
OK = 1
ACTION = "VERIF_MOD" : Gosub ACTION From GOBJSUB
If !OK : GOK = 0 : Return : Endif

Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
Call DEBTRANS From GLOCK
Gosub TR2
If GOK>=1
 ACTION = "APRES_MOD" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS : Endif
 If SAVENA<>0
  Assign "[M:"+ABRENA+"]ENAFLG" With SAVENA
  Gosub AFF_ENAFLG From =WINPROG
  Call MESSAGE(mess(109,75,1)) From GESECRAN : # Le flag actif ne peut pas être modifié
 Endif
 Call ESPION(NOMFIC,2,IDENT,"") From ESPION
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"M") From GOBJET : Endif
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
 ACTION = "FIN_MOD" : Gosub ACTION From GOBJSUB
Elsif GRPDEB<>""
 Call VIRE_GROUPE(GRPDEB) From AWRK
 GOK = 0
Endif
Return

$TR2
GOK=1
GRPDEB = ""
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Gosub AFF_CLE From GOBJSUB
 Assign "[G:"+ABFIC+"]currind" With 1
 Assign "[G:"+ABFIC+"]currlen" With 0
 Readlock =
 If fstat=1
  GOK=-1 : GLOCK="$"+NOMFIC-CLECUR1 : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
# Issue 84719 - 2012-09-27 by VPO : Possibilité de ne pas gérer ctrl UPDTICK
# If dim([L]AUPDTICK)>0 & dim([F]updTick)>0 & [L]AUPDTICK<>[F]updTick
 If dim([L]AUPDTICK)>0 & dim([F]updTick)>0 & dim([L]ANOUPDTICK)>0 &
&   !ANOUPDTICK & [L]AUPDTICK<>[F]updTick
  fstat = 6 : GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 Gosub SAV_LIAISONS
 ACTION = "AVANT_MODFIC" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Call WRKGLOB(171,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,1,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

 nolign = 1
 SAVENA = 0
 If OPTENA & !AUTENA & ABRENA<>""
& & evalue("dim([F:"+ABFIC+"]ENAFLG)")>0 & evalue("dim([M:"+ABRENA+"]ENAFLG)")>0
& & evalue("[F:"+ABFIC+"]ENAFLG")<>evalue("[M:"+ABRENA+"]ENAFLG")
  SAVENA = evalue("[F:"+ABFIC+"]ENAFLG")
 Endif
 For IMA=0 To NBMASK
  Gosub CHARGEFIC From =WINPROG
 Next IMA
 If SAVENA
  Assign "[F:"+ABFIC+"]ENAFLG" With SAVENA
 Endif
 Gosub INIMOD From GOBJSUB
 ACTION = "INIMOD" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub DEFAUT From =PROGOBJ
# Vérification du rôle
 Onerrgo RIEN
 ER = 0
 OK = evalue(FILROLE)
 Onerrgo
 If !ER & !OK
  Call ERREUR(mess(97,126,1)) From GESECRAN : # Vous n'avez pas les droits pour créer cette fiche
  GOK = 0 : Goto AB_TR1
 Endif
 If dim(ANOWRITE)<=0 or !ANOWRITE
  Rewrite
  If fstat
   GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
  Endif
 Endif
 If dim(OBJUPDDATTIM)>0 & dim([F]UPDDATTIM)>0
  [L]OBJUPDDATTIM = [F]UPDDATTIM
 Endif
 If dim(OBJUPDSTP)>0 & dim([F]UPDSTP)>0
  [L]OBJUPDSTP = [F]UPDSTP
 Endif

 If dim([L]AUPDTICK)>0 & dim([F]updTick)>0
  # Issue 84684  - 2012-09-21 by VPO : pb "enreg obsolete" si rollback apres rewrite
  [L]AUPDTICKCHGT = 1
  [L]AUPDTICKSAV= [L]AUPDTICK
  [L]AUPDTICK = [F]updTick
 Endif

 ACTION = "MODIF" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,2,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

Commit
If dim([L]AUPDTICKCHGT )>0 & [L]AUPDTICKCHGT=1
   # Issue 84684  - 2012-09-21 by VPO : pb "enreg obsolete" si rollback apres rewrite
   [L]AUPDTICKCHGT = 0
Endif
Return

$AB_TR2
Rollback
If dim([L]AUPDTICKCHGT )>0 & [L]AUPDTICKCHGT=1
   # Issue 84684  - 2012-09-21 by VPO : pb "enreg obsolete" si rollback apres rewrite
   [L]AUPDTICK= [L]AUPDTICKSAV
   [L]AUPDTICKCHGT = 0
Endif
ACTION = "AB_MODIF" : Gosub ACTION From GOBJSUB
Return

$ROLL_TR2
Rollback
If dim([L]AUPDTICKCHGT )>0 & [L]AUPDTICKCHGT=1
   # Issue 84684  - 2012-09-21 by VPO : pb "enreg obsolete" si rollback apres rewrite
   [L]AUPDTICK= [L]AUPDTICKSAV
   [L]AUPDTICKCHGT = 0
Endif
Call ROLL From GLOCK
If GROLL
 ACTION = "AB_MODIF" : Gosub ACTION From GOBJSUB
 Return
Else
 Goto TR2
Endif

#########################################
$CHARGE
nolign = 1
For IMA=0 To NBMASK
 Gosub CHARGEMSK From =WINPROG
Next IMA
Return

#############################################
## Mise à jour de l'explorateur de liaisons
#############################################
$SAV_LIAISONS
If dim(NBLNK)>0 & NBLNK>0
 Gosub LIAISONS From =PROGOBJ
 For I=1 To NBLNK
  If NUMLNK(I)=0
   Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK(I),TBDST)
  Else
   For J=1 To min(300,LIGLNK(I))
    indice = J-1
    Case NUMLNK(I)
     When 1 : Gosub LIAISONS_1 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK1(J),TBDST)
     When 2 : Gosub LIAISONS_2 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK2(J),TBDST)
     When 3 : Gosub LIAISONS_3 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK3(J),TBDST)
     When 4 : Gosub LIAISONS_4 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK4(J),TBDST)
     When 5 : Gosub LIAISONS_5 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK5(J),TBDST)
     When 6 : Gosub LIAISONS_6 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK6(J),TBDST)
     When 7 : Gosub LIAISONS_7 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK7(J),TBDST)
     When 8 : Gosub LIAISONS_8 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK8(J),TBDST)
     When 9 : Gosub LIAISONS_9 From =PROGOBJ : Call IDDST(OBJLNK(I),ABRLNK(I),CLELNK9(J),TBDST)
    Endcase
   Next J
  Endif
 Next I
Endif
Return

$LIAISONS
Local Char LIAISON(10)
If dim(GLIAISON)>1
 LIAISON = GLIAISON(1)
Else
 LIAISON = GLIAISON(0)
Endif
If LIAISON<>"" & NBLNK<>0
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
 Call DEBTRANS From GLOCK
 Gosub TR3
Endif
Return

$TR3
Call IDENT3(ABREV,IDLNK,CLECUR1,CLECUR2) From GOBJTXT
GOK = 1
Gosub LIAISONS From =PROGOBJ
Trbegin [ALI]
 For I=1 To NBLNK
  If NUMLNK(I)<>0
   For J=1 To min(300,LIGLNK(I))
    indice = J-1
    Case NUMLNK(I)
     When 1 : Gosub LIAISONS_1 From =PROGOBJ : CLELNK(I) = CLELNK1(J)
     When 2 : Gosub LIAISONS_2 From =PROGOBJ : CLELNK(I) = CLELNK2(J)
     When 3 : Gosub LIAISONS_3 From =PROGOBJ : CLELNK(I) = CLELNK3(J)
     When 4 : Gosub LIAISONS_4 From =PROGOBJ : CLELNK(I) = CLELNK4(J)
     When 5 : Gosub LIAISONS_5 From =PROGOBJ : CLELNK(I) = CLELNK5(J)
     When 6 : Gosub LIAISONS_6 From =PROGOBJ : CLELNK(I) = CLELNK6(J)
     When 7 : Gosub LIAISONS_7 From =PROGOBJ : CLELNK(I) = CLELNK7(J)
     When 8 : Gosub LIAISONS_8 From =PROGOBJ : CLELNK(I) = CLELNK8(J)
     When 9 : Gosub LIAISONS_9 From =PROGOBJ : CLELNK(I) = CLELNK9(J)
    Endcase
    Gosub SET_LIAISON
    If GOK<1 : Break : Endif
   Next J
  Else
   Gosub SET_LIAISON
  Endif
  If GOK<1 : Break : Endif
 Next I
 If   GOK<0 : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR3
 Endif
Commit
Return

$SET_LIAISON
Call IDDST(OBJLNK(I),ABRLNK(I),IDDST,TBDST)

If REP="M" & CLELNK(I)<>"" & CLELNK(I)<>IDDST
 Delete [ALI] Where USRCOD=LIAISON & DSTOBJ=ABREV & DSTKEY=IDLNK & SRCOBJ=OBJLNK(I) & SRCKEY=CLELNK(I)
 K = find(CODLNK(I),GCODLNK(1..GNBLNK))
 If K & GINVLNK(K)<>""
  Delete [ALI] Where USRCOD=LIAISON & SRCOBJ=ABREV & SRCKEY=IDLNK & DSTOBJ=OBJLNK(I) & DSTKEY=CLELNK(I)
 Endif
Endif

If IDDST<>""

# Création en priorité du lien inverse
 Read [ALI]ALI0 = LIAISON;OBJLNK(I);IDDST;ABREV;IDLNK
 If fstat
  Raz [F:ALI]
  [F:ALI]USRCOD = LIAISON
  [F:ALI]SRCOBJ = OBJLNK(I)
  [F:ALI]SRCKEY = IDDST
  [F:ALI]DSTOBJ = ABREV
  [F:ALI]DSTTIT = TITOBJ
  [F:ALI]DSTKEY = IDLNK
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  If NOMINT<>""
   If evalue("dim([F:"+ABFIC+"]"+NOMINT+")")<=0
    N = instr(1,IDLNK,"~")
    If N
     Call LECTEXTRA([F:ALI]DSTDES,NOMFIC,NOMINT,left$(IDLNK,N-1),right$(IDLNK,N+1)) From ATEXTRA
    Else
     Call LECTEXTRA([F:ALI]DSTDES,NOMFIC,NOMINT,IDLNK,"") From ATEXTRA
    Endif
   Elsif evalue("type([F:"+ABFIC+"]"+NOMINT+")")>10
    [F:ALI]DSTDES = evalue("[F:"+ABFIC+"]"+NOMINT)
   Else
    N = evalue("[F:"+ABFIC+"]"+NOMINT)
    Call TEXTE(N,[F:ALI]DSTDES) From OBJDIV
   Endif
  Endif
  [F:ALI]LNK    = CODLNK(I)
  [F:ALI]ENAFLG = 2
  [F:ALI]AUTFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time : Endif
  Write [ALI]
  If fstat
   GOK = 0 : Call FSTA("ALI") From GLOCK : Return
  Endif
 Endif

# Création du lien direct si pointeur dans table diverse
 K = find(CODLNK(I),GCODLNK(1..GNBLNK))
 If K & GINVLNK(K)<>""
  Read [ALI]ALI0 = LIAISON;ABREV;IDLNK;OBJLNK(I);IDDST
  If fstat
   Raz [F:ALI]
   [F:ALI]USRCOD = LIAISON
   [F:ALI]SRCOBJ = ABREV
   [F:ALI]SRCKEY = IDLNK
   [F:ALI]DSTOBJ = OBJLNK(I)
   [F:ALI]DSTTIT = TITLNK(I)
   [F:ALI]DSTKEY = IDDST
   [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
   If DESLNK(I)<>""
    If evalue("dim("+DESLNK(I)+")")<=0
     N = instr(1,IDDST,"~")
     If N
      Call LECTEXTRA([F:ALI]DSTDES,TBDST,DESLNK(I),left$(IDDST,N-1),right$(IDDST,N+1)) From ATEXTRA
     Else
      Call LECTEXTRA([F:ALI]DSTDES,TBDST,DESLNK(I),IDDST,"") From ATEXTRA
     Endif
    Elsif evalue("type("+DESLNK(I)+")")>10
     [F:ALI]DSTDES = evalue(DESLNK(I))
    Else
     N = evalue(DESLNK(I))
     Call TEXTE(N,[F:ALI]DSTDES) From OBJDIV
    Endif
   Endif
   [F:ALI]LNK    = GINVLNK(K)
   [F:ALI]ENAFLG = 2
   [F:ALI]AUTFLG = 2
   [F:ALI]CREDAT = date$
   [F:ALI]CREUSR = GUSER
   If dim([F:ALI]CRETIM)>0 : [F:ALI]CRETIM = time : Endif
   Write [ALI]
   If fstat
    GOK = 0 : Call FSTA("ALI") From GLOCK : Return
   Endif
  Endif
 Endif
Endif
Return

$AB_TR3
Rollback
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

#######################################
Subprog IDDST(OBJET,ABREV,IDENT,TABLE)
#######################################
Value    Char OBJET
Value    Char ABREV
Variable Char IDENT()
Variable Char TABLE
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(1..16)
Local Integer I , ER
Gosub NOMFIC From ="WO"+OBJET
Gosub SETCLE From ="WO"+OBJET
Onerrgo RIEN
TABLE = NOMFIC
CLECUR1 = num$(evalue("[F:"+ABREV+"]"+CLEPRIM))
Raz CLECUR2
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  CLECUR2(I+1) = num$(evalue("[F:"+ABREV+"]"+CLESEC(I)))
 Endif
Next I
Onerrgo
If CLECUR1<>""
 Call IDENT3(OBJET,IDENT,CLECUR1,CLECUR2) From GOBJTXT
Else
 IDENT = ""
Endif
End

$RIEN
ER = errn
Resume

