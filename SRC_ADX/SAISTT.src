#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "FINSAI"  : Gosub FINSAI
 When "OK"      : Gosub ENREG   
 When Default
Endcase
Return

$OUVRE
Local Integer NOL
NOL = nolign-1
Local Mask SAISTT [STT]
# sort si positionnement derniere ligne du tableau
If dim([M:HAE0]NBLIG) >0
    If nolign>[M:HAE0]NBLIG : mkstat=2 : FIN = 1 : Endif  
Elsif dim([M:HAE1]NBLIG)>0 
    If nolign>[M:HAE1]NBLIG : mkstat=2 : FIN = 1 : Endif  
Elsif dim([M:HAE2]NBLIG)>0
    If nolign>[M:HAE2]NBLIG : mkstat=2 : FIN = 1 : Endif  
Elsif dim([M:BIC3]NBLIG)>0 
    If nolign>[M:BIC3]NBLIG : mkstat=2 : FIN = 1 : Endif  
Elsif dim([M:BIS3]NBLIG)>0
    If nolign>[M:BIS3]NBLIG : mkstat=2 : FIN = 1 : Endif  
Endif
Return

$DEBUT
nolign=NOL+1    # Bug 8951 (CP : 26/07/01)
If dim([M:HAE0]STT1)>0 
    [M:STT] = [M:HAE0]
Elsif dim([M:HAE1]STT1)>0 
    [M:STT] = [M:HAE1]
Elsif dim([M:HAE2]STT1)>0
    [M:STT] = [M:HAE2]
Elsif dim([M:BIC3]STT1)>0
    [M:STT] = [M:BIC3]
Elsif dim([M:BIS3]STT1)>0
    [M:STT] = [M:BIS3]
Endif
Affzo [M:STT]
Return

$ENREG
nolign=NOL+1    # Bug 8951 (CP : 26/07/01)
If dim([M:HAE0]STT1)>0 
    [M:HAE0] = [M:STT] 
Elsif dim([M:HAE1]STT1)>0 
    [M:HAE1] = [M:STT] 
Elsif dim([M:HAE2]STT1)>0
    [M:HAE2] = [M:STT] 
Elsif dim([M:BIC3]STT1)>0
    [M:BIC3] = [M:STT] 
Elsif dim([M:BIS3]STT1)>0
    [M:BIS3] = [M:STT] 
Endif
FIN = 1  ## sort de la fenetre
Return

$FINSAI
If dim([M:HAE0]STT1)>0 
  Affzo [M:HAE0]STT1(NOL),STT2(NOL),STT3(NOL) #CHECK IGNORE_LINE
Elsif dim([M:HAE1]STT1)>0 
 Affzo [M:HAE1]STT1(NOL),STT2(NOL),STT3(NOL) #CHECK IGNORE_LINE
Elsif dim([M:HAE2]STT1)>0
 Affzo [M:HAE2]STT1(NOL),STT2(NOL),STT3(NOL) #CHECK IGNORE_LINE
Endif
mkstat = 4
Return
