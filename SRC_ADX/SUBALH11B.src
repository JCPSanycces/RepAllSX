#<AdxTL>@(#)0.0.0.0 $Revision$
# Process to write the generated process

$CORPS_DATA
  DEB_UG=0
  OK = 1
  AOBFNC=[F:ALH]FCTLNK
  # Added Sept 22, 2014 by Dom Bug if no role
  AOBAOB=""
  If [F:ALH]OBJLNK<>""
    Read [AOB]ABREV = [F:ALH]OBJLNK
    If !fstat
      If [F:AOB]ZSITE<>"" : AOBSIT = [F:AOB]ZSITE : Endif
      If [F:AOB]ZACC<>""  : AOBACC = [F:AOB]ZACC  : Endif
      Read [AVWT]CODFIC = [F:AOB]NOMFIC
      If !fstat
       AOBFIC = [F:AVWT]ABRFIC
      Endif
      AOBAOB=[F:ALH]OBJLNK : # Added for security filters End of January 2014
   Endif
  Endif

  FACET="$query"

# How many nesting levels and where are the breaking levels ?
# the breaking level are the first ones ! Because the request HAS to be sorted first on tyhe breaking levels
  NBLEV=0 : NBSRT=0
  Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1
  For [ALD]
    NBSRT+=1
    If [ALD]GRP=2
      NBLEV+=1
      BRKLEV(NBLEV)=NBSRT
    Endif
  Next
  Filter [ALD]

#  Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2
#  NBLEV=rowcount([ALD])
#  Filter [ALD]



# Do we have formula with Func ? -- Fmet added Sept 3, 2014
  NBFORMFUNC=0
  For I=1 To dim([ALH]SEL)
    NBFORMFUNC+=(pat(toupper([ALH]SEL(I-1)),"*FUNC *")<>0) or (pat(toupper([ALH]SEL(I-1)),"*FMET *")<>0)
  Next I

# User and language definition (should disappear in the future as soon as environment setting is ok)
  Wrseq Using [SSS_]
  Wrseq "# Language and user variables declaration and assignment" Using [SSS_]
  Wrseq "$DECL_USR_LAN" Using [SSS_]
  Wrseq "Local Char USER(20),LANGUE(20)" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "# Set the language code" Using [SSS_]
  Wrseq "  USER=ACTX.USER" Using [SSS_]
  Wrseq "  LANGUE=ACTX.LAN" Using [SSS_]
  Wrseq "  If LANGUE='' : LANGUE=GACTX.LAN : Endif" Using [SSS_]
  Wrseq "  If USER='' : USER=GACTX.USER : Endif" Using [SSS_]
  Wrseq "  If LANGUE='' : LANGUE='ENG' : Endif" Using [SSS_]
  Wrseq "Return" Using [SSS_]
  Wrseq Using [SSS_]

# Modification done October 22, 2014 : addition of a service used to map the fields when a calendar widget is used
  Wrseq "Subprog FIELDS(FIELDS,NBFIELDS)" Using [SSS_]
  Wrseq "Variable Char FIELDS()(1..)" Using [SSS_]
  Wrseq "Variable Integer NBFIELDS" Using [SSS_]
  For I=1 To NBFIELDS
  Wrseq "  FIELDS("+num$(I)+")='"+FIELDS(I)+"'" Using [SSS_]
  Next I
  Wrseq "  NBFIELDS="+num$(NBFIELDS) Using [SSS_]
  Wrseq "End" Using [SSS_]
  Wrseq Using [SSS_]
# No more used
#  Wrseq "Subprog HEAD_RQT(ACTX,VALBEG,VALEND,STRICTBEG,STRICTEND,REQUID,UUIREQ)" Using [SSS_]
#  Wrseq "Variable Instance ACTX Using "+[V]CST_C_NAME_CLASS_CONTEXT Using [SSS_]
#  Wrseq "Value Char VALBEG()(1..),VALEND()(1..)" Using [SSS_]
#  Wrseq "Value Libelle STRICTBEG(1..),STRICTEND(1..)" Using [SSS_]
#  Wrseq "Variable Char REQUID()" Using [SSS_]
#  Wrseq "Value Char UUIREQ()" Using [SSS_]
#  Wrseq Using [SSS_]
#  Wrseq "# Miscellaneous variables needed for header generation" Using [SSS_]
#  Wrseq "Local Char CRITERE(250)(1..100)" Using [SSS_]
#  Wrseq "Local Integer NBCRIT" Using [SSS_]
#  Wrseq "Local Char HEADER(250)" Using [SSS_]
#  Wrseq "Local Integer I,J,LINE_SEEK" Using [SSS_]
#  Wrseq Using [SSS_]
#  Wrseq "# Users and language assignment" Using [SSS_]
#  Wrseq "  Gosub DECL_USR_LAN" Using [SSS_]
#  Wrseq Using [SSS_]
#  Wrseq "# Call the common header generator subroutine" Using [SSS_]
#  Wrseq "  Gosub HEADRQT" Using [SSS_]
#  Wrseq "End" Using [SSS_]
#  Wrseq Using [SSS_]
  Wrseq "# Header files generator (data only)" Using [SSS_]
  Wrseq "$HEADRQT" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Build the CRITERE array by analysing VALBEG/VALEND/STRICTBEG/STRICTEND array" Using [SSS_]
  Wrseq "  Gosub EVAL_CRIT" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Assign the request ID if not forced" Using [SSS_]
  Wrseq "  If UUIREQ<>''" Using [SSS_]
  Wrseq "    REQUID=UUIREQ" Using [SSS_]
  Wrseq "  Else" Using [SSS_]
  Wrseq "    REQUID=num$(uuid$)" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq Using [SSS_]


  If [ALH]ALLUSR<>2
    Wrseq '  HEADER=USER-func AJSONLIB.DATEWEB(val(timestamp$))' Using [SSS_]
  Else
    Wrseq '  HEADER=func AJSONLIB.DATEWEB(val(timestamp$))' Using [SSS_]
  Endif

  Wrseq Using[SSS_]
  Wrseq "# Write the data file headers" Using [SSS_]

  Wrseq "# Open the data file" Using [SSS_]
  Wrseq "Local Char PATH_RQT(250)(1.."+num$(NBLEV+1)+"), PATH_IDX(250)(1.."+num$(NBLEV+1)+"), FILE_BASE(250)"Using [SSS_]
  Wrseq "  FILEBASE='"+LISTE+"_'"+string$([F:ALH]ALLUSR<>2,"+USER+'_'") Using [SSS_]
  Wrseq "  For I=1 To "+num$(NBLEV+1) Using [SSS_]
  Wrseq "    PATH_RQT(I)=func FILP(IF_CLOUD,FILEBASE+num$(I),'req')" Using [SSS_]
  Wrseq "    PATH_IDX(I)=func FILP(IF_CLOUD,FILEBASE+num$(I),'idx')" Using [SSS_]
  Wrseq "    Openo PATH_RQT(I),0 Using [LEV]" Using [SSS_]
  Wrseq "    Iomode adxifs '' Using [LEV]" Using [SSS_]
  Wrseq "    Iomode adxirs chr$(10) Using [LEV]" Using [SSS_]
  Wrseq "    Iomode adxium 0 Using [LEV] : # Corresponds to UTF8 format" Using [SSS_]
  Wrseq '    Wrseq "Request'-LISTE-'Level"-format$("N0:2",I) Using [LEV]' Using [SSS_]
  Wrseq '    Wrseq HEADER Using [LEV]' Using [SSS_]
  Wrseq '    If I=1 : LINE_SEEK=adxseek("LEV") : Endif' Using [SSS_]
  Wrseq '    Wrseq "00000000"-REQUID-format$("N0:8#",adxuid(1))-"00000000.000 00000000.000 00000000 00000000" Using [LEV]' Using [SSS_]
  Wrseq '    Wrseq num$(K-1) Using [LEV]' Using [SSS_] : # Replace I by K : bug fix not registered in SAM
  Wrseq '    For J=1 To K-1' Using [SSS_]                       : # The additional parameter list is wrongly counted and depends from the level !! Any display on level >1 is recomputed !
  Wrseq '      Wrseq CRITERE(J) Using [LEV]' Using [SSS_]
  Wrseq '    Next J' Using [SSS_]
  Wrseq '    Openo Using [LEV]' Using [SSS_]
  Wrseq '  Next I' Using [SSS_]
  Wrseq Using [SSS_]
  For I=max(NBLEV-2,1) To NBLEV+1
    Wrseq "  Openo PATH_RQT("+num$(I)+"),-1 Using [LEV"+num$(I)+"]" Using [SSS_]
  Next I

  Wrseq "Return" Using [SSS_]
  Wrseq Using [SSS_]

  #SAM 109275 {
  Wrseq '$RQT_ERROR' Using [SSS_]
  Wrseq 'Local Integer ERROR' Using [SSS_]
  Wrseq 'Local Char MESSAGE(250)' Using [SSS_]
  Wrseq '  MESSAGE = errmes$(errn) - "(error nÂ°"-num$(errn) -") in script"-errp-" ("+num$(errl)+")"' Using [SSS_]
  Wrseq '  ERROR = fmet ACTX.ASETERROR("",MESSAGE,[V]CST_AERROR)' Using [SSS_]
  Wrseq 'End' Using [SSS_]
  Wrseq Using [SSS_]
   #SAM 109275 {

  Wrseq "Subprog EXEC_RQT(ACTX,VALBEG,VALEND,STRICTBEG,STRICTEND,LIMITS,NBLIG,REQUID,UUIREQ)" Using [SSS_]
  Wrseq "Variable Instance ACTX Using "+[V]CST_C_NAME_CLASS_CONTEXT Using [SSS_]
  Wrseq "Value Char VALBEG()(1..),VALEND()(1..)" Using [SSS_]
  Wrseq "Value Libelle STRICTBEG(1..),STRICTEND(1..)" Using [SSS_]
  Wrseq "Variable Integer NBLIG(1..)" Using [SSS_]
  Wrseq "Value    Integer LIMITS(1..)" Using [SSS_]
  Wrseq "Variable Char REQUID()" Using [SSS_]
  Wrseq "Value Char UUIREQ()" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Criteria array ([ALH]SEL fields)" Using [SSS_]
  Wrseq "Local Char    CRITERE(250)(1..100)" Using [SSS_]
  Wrseq "Local Char    CRITSUP(250)(1..5)" Using [SSS_]

# Moved ahead to fix issue X3-50115
  Wrseq "# Handle execution errors"  Using [SSS_] :#SAM 109275
  Wrseq "  Onerrgo RQT_ERROR"  Using [SSS_] :#SAM 109275
  Wrseq Using [SSS_] :#SAM 109275

  # Added Sept 22, 2014 by Dom Bug if no role
  If AOBAOB<>""
    Wrseq "Local Char    CRITROL(250)(1..)" Using [SSS_] : # Added End of January 2014 Security filters
  Endif

  Wrseq "Local Char USER(20),LANGUE(20)" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Time and line limit values (set to 0 if not reached)" Using [SSS_]
  Wrseq "Local Integer LIM(1..2)" Using [SSS_]
  Wrseq "  LIM(1)=LIMITS(1) : LIM(2)=LIMITS(2)" Using [SSS_]
  Wrseq Using [SSS_]
# Declare the other variables
  Wrseq "# Other variables" Using [SSS_]
  Wrseq "Local Integer NBHEAD : NBHEAD="+num$(NBHEAD) Using [SSS_]
  Wrseq "Local Integer "+sigma(1,NBLEV+1,"PAGES"+num$(indcum)+"(1..NBHEAD)"+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  Wrseq "Local Integer "+sigma(1,NBLEV+1,"RECORD"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  If NBFORMFUNC
    Wrseq "Local Integer "+sigma(1,NBLEV+2,"NBLIG"+num$(indcum)+string$(indcum<NBLEV+2,", ")) Using [SSS_]
  Endif
  Wrseq "Local Integer "+sigma(1,NBLEV+1,"ZM"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  If NBLEV
    Wrseq "Local Integer "+sigma(2,NBLEV+1,"ZP"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  Endif
  Wrseq "Local Integer SIZHEA" Using [SSS_]
  Wrseq "Local Char HEADER(250)" Using [SSS_]
  Wrseq "Local Clbfile WRBUF(4)" Using [SSS_]
  Wrseq "Local Char    TRUFAL(10),SQ(1),DQ(1)" Using [SSS_]
  Wrseq "Local Integer I,J,LINE_SEEK" Using [SSS_]
  Wrseq "Local Decimal TIME0,TIME1,TIME2" Using [SSS_]
  Wrseq "Local Integer TESTLIM" Using [SSS_]
  Wrseq 'Local Integer IF_CLOUD' Using [SSS_]
  Wrseq "Local Clbfile LCLBVAL      # Temporary string/clob value" Using [SSS_]

  Wrseq Using [SSS_]

  Wrseq '# Determine if we are in Cloud release or not' Using [SSS_]
  Wrseq '  IF_CLOUD=(getenv$("PUBLICCLOUD")<>"")' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "SQ=chr$(39) : DQ=chr$(34)" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Set the language code" Using [SSS_]
  Wrseq "  Gosub DECL_USR_LAN" Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq "# Set enough opened channels for the data files" Using [SSS_]
  Wrseq "Local Integer SVG_MSO" Using [SSS_]
  Wrseq "  SVG_MSO=adxmso : adxmso="+num$(min(16,11+NBLEV)) Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Open the tables" Using [SSS_]
    For I=1 To NBFIC2
    Read [AVWT]CODFIC = TBFIC(I)
    If !fstat
      ABFIC(I) = [F:AVWT]ABRFIC
      Wrseq "  Local File "+TBFIC(I)+" ["+ABFIC(I)+"]" Using [SSS_]
    Endif
  Next I
  Wrseq "  Local File ALISTEH [ALH]" Using [SSS_]

# Modified end of January 2014 security filters
  If AOBACC<>""
    Wrseq "  Local File ACCES [Z_ACC]" Using [SSS_]
  Endif

  If AOBFNC<>""
    Wrseq "  Local File AFCTFCY [Z_AFY]" Using [SSS_]
  Endif
# End of modification End of January 2014

  For I=1 To NBTXT
    Case TYPTXT(I)
      When 1
        TEMPCH="[AX"+num$(LIGTXT(I)+10)+"]"
        Wrseq "  Local File ATEXTE "+TEMPCH  Using [SSS_]
      When 2,3
        TEMPCH="[AY"+num$(LIGTXT(I)+10)+"]"
        Wrseq "  Local File ATEXTRA "+TEMPCH  Using [SSS_]
    Endcase
  Next I

# Not transferred fields, table must be opened bug 61550
  Raz TBFIC3,NBFIC3
  For [ALD]ALD0 Where COD=LISTE & STREND=3
    If !find([F:ALD]TBL,TBFIC) & !find([F:ALD]TBL,TBFIC3)
      Read [AVWT]CODFIC = [F:ALD]TBL
      If !fstat
        NBFIC3 +=1
        TBFIC3(NBFIC3) = [F:ALD]TBL
        Wrseq "  Local File "+[F:ALD]TBL+" ["+[F:AVWT]ABRFIC+"]" Using [SSS_]
      Endif
    Endif
  Next
  Wrseq Using [SSS_]

  Wrseq "# Default files" Using [SSS_]
  For I=1 To NBFIC2
    If AFILOPE<>"" : AFILOPE += "," : Endif
    AFILOPE += '['+ABFIC(I)+']'
  Next I
  For I=1 To NBFIC3
    Read [AVWT]CODFIC = TBFIC3(I)
    If AFILOPE<>"" : AFILOPE += "," : Endif
    AFILOPE += '['+[F:AVWT]ABRFIC+']'
  Next I
  Wrseq '  Default File "'+AFILOPE+'"' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "# Open the data file and fill them with the right header" Using [SSS_]
  Wrseq "  Gosub HEADRQT" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  # Create a .lock file with UUID (always in the final and persistent folder)" Using [SSS_]
  Wrseq "  Openo filpath('RQT',REQUID,'lck') Using [LCK] : Openo Using [LCK]" Using [SSS_]
  Wrseq Using [SSS_]

  KK=0
  For JJ=0 To dim([F:ALH]SEL)-1
    CHAINE = vireblc(format$("KT:255X",[F:ALH]SEL(JJ)),2)
    If CHAINE<>"" and pat(toupper(CHAINE),"*FUNC *")=0
      KK+=1
      If KK=1
        Wrseq "# Assign the additional criteria" Using [SSS_]
        CHAINE="("+CHAINE+")"
      Else
        CHAINE="&("+CHAINE+")"
      Endif
      Wrseq '  CRITSUP('+num$(KK)+')='+func SUBALH11A.TRCHAINE(CHAINE) Using [SSS_]
    Endif
  Next JJ
  If KK : Wrseq Using [SSS_] : Endif

# Added End of January 2014
# Fix Added Sept 22, 2014 by Dom Bug if no role
 If AOBAOB<>""
    Wrseq "# Get the role filter" Using [SSS_]
    Wrseq " J = fmet GACTX.AGETCRITROLE(GACTX,'"+AOBAOB+"','"+AOBFIC+"',CRITROL,[V]CST_AFALSE)" Using [SSS_]
    Wrseq Using [SSS_]
 Endif
# End of addition End of January 2014

# Don't add EP as it's called from Syracuse => no global variable
## Add an entry point
#  Wrseq "# Entry point" Using [SSS_]
#  Wrseq "Local Char RQT_CODE(20)" Using [SSS_]
#  Wrseq "" Using [SSS_]
#  Wrseq "  RQT_CODE='"+LISTE+"'" Using [SSS_]
#  Wrseq "  Gosub EXERQT From SUBALH11" Using [SSS_]
#  Wrseq "" Using [SSS_]

  Wrseq "# Now let's declare the request (Link) and the fields expected (Columns)" Using [SSS_]
  If ABFIC(F)<>"" & (NBFIC2>1 | (NBTXT>0 & (find(1,TYPTXT(1..NBTXT)) | find(2,TYPTXT(1..NBTXT)))) | AOBACC<>"")
    Case [F:ALH]TYP
      When 1 : Gosub LINK1 From SUBALH11
      When 3 : Gosub LINK3 From SUBALH11
    Endcase
  Else : # Cas trivial oĂą il n'y a qu'un seul fichier
# Multiple modifications End of January 2014 to handle security filters
    Gosub LINK0 From SUBALH11
  Endif
  LINK_ACCES=string$(AOBACC<>"","[Z_ACC]CODACC ~= USER ; [F:"+AOBFIC+"]"+AOBACC)

  If AOBFNC<>""
    # Added November 20, 2014
    # The filtering link must be added only if the function has a filter by site
    # Otherwise, the filter is done before (in ASYRREQ)
    Read [AFC]CODINT=AOBFNC
    If [AFC]FCYAUZ=2
      LINK_SITE="[Z_AFY]AFF0 ~="+string$(AOBSIT<>"","[F:"+AOBFIC+"]"+AOBSIT)+string$(AOBSIT="","''")
      LINK_SITE+=";GACTX.APRFCOD; '"+AOBFNC+"'"
    Else
      LINK_SITE=""
    Endif
  Else
    LINK_SITE=""
  Endif

  If LINK_ACCES<>""
    IF_ACCESS=0
    Wrseq " If GACTX.ALLACS=2" Using [SSS_]
  Endif
  IF_ACCESS=0
  Gosub GENELINK From SUBALH11
  If LINK_ACCES<>""
    Wrseq " Else" Using [SSS_]
    IF_ACCESS=1
    Gosub GENELINK From SUBALH11
    Wrseq " Endif" Using [SSS_]
  Endif

# Search the fields present in formulas
  NBCHP = 0
  NBCOL = 0
  For [ALD] Where COD=LISTE & STREND<=2
    NBCOL += 1
    K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
    If [F:ALD]FLD<>"" & find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")=0
      ZONE = [F:ALD]FLD
      I = instr(1,ZONE,"(")
      If I
        ZONE = left$(ZONE,I-1)
      Endif
      ZONE = "[F:"+ABFIC(K)+"]"+ZONE
      If !find(ZONE,TBCHP(1..NBCHP))
        NBCHP += 1
        TBCHP(NBCHP) = ZONE
      Endif
    Else
      CHAINE = vireblc(format$("KT:250X",[F:ALD]CLC),2)
      I = 0
      Repeat
        I = instr(I+1,CHAINE,"[")
        If I
          J = instr(I+1,CHAINE,"]")
          If J
            Repeat
              J += 1
            Until J>len(CHAINE) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(CHAINE,J,1))
            ZONE = seg$(CHAINE,I,J-1)
            If !find(ZONE,TBCHP(1..NBCHP)) & !instr(1,ZONE,"\") &  !instr(1,ZONE,"/") : # 65035 Cas champ date[0/0/0] dnas la formule
              NBCHP += 1
              TBCHP(NBCHP) = ZONE
            Endif
          Endif
          I = J-1
        Endif
      Until I=0
    Endif
  Next

# Search the fields present in selection criteria "func"
  For KK=1 To dim([F:ALH]SEL)
    CHAINE = vireblc(format$("KT:250X",[F:ALH]SEL(KK-1)),2)
    Gosub REC_CLOB From SUBALH11
    If instr(1,CHAINE,"func ") or FLCLOB
      I = 0
      Repeat
        I = instr(I+1,CHAINE,"[")
        If I
          J = instr(I+1,CHAINE,"]")
          If J
            Repeat
              J += 1
            Until J>len(CHAINE) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(CHAINE,J,1))
            ZONE = seg$(CHAINE,I,J-1)
            If !find(ZONE,TBCHP(1..NBCHP))
              NBCHP += 1
              TBCHP(NBCHP) = ZONE
            Endif
          Endif
          I = J-1
        Endif
      Until I=0
    Endif
  Next KK

# Add the fields from the primary key
  Read [AVWI]NUMLIG(2) = TBFIC(F);1
  # Bug 111192
  If fstat<>0 :Raz [F:AVWI]DESCRIPT : Endif
  NBCLE = 0
  CHAINE = [F:AVWI]DESCRIPT
  While CHAINE<>""
    I = instr(1,CHAINE,"+")
    J = instr(1,CHAINE,"-")
    If    I & J  : I = min(I,J)
    Elsif J & !I : I = J
    Endif
    If I
      ZONE   = left$(CHAINE,I-1)
      CHAINE = right$(CHAINE,I+1)
    Else
      ZONE   = CHAINE
      CHAINE = ""
    Endif
    NBCLE += 1
    CLE(NBCLE) = ZONE
    ZONE = "[F:"+ABFIC(F)+"]"+ZONE
    If !find(ZONE,TBCHP(1..NBCHP))
      NBCHP += 1
      TBCHP(NBCHP) = ZONE
    Endif
  Wend

## Add the field texts
  For I=1 To NBTXT
    Case TYPTXT(I)
      When 1 : NBCHP += 1 : TBCHP(NBCHP) = "[F:AX"+num$(LIGTXT(I)+10)+"]TEXTE"
      When 2 : NBCHP += 1 : TBCHP(NBCHP) = "[F:AY"+num$(LIGTXT(I)+10)+"]TEXTE"
      When 3 : # bug 58058 CCL
        Read [AVWI]NUMLIG(2) = TBTXT(I);1
        CHAINE = [F:AVWI]DESCRIPT
        Gosub SETCLE From SUBALH11
        For J=1 To NBCLE
          ZONE = "[F:"+ABTXT(I)+"]"+CLE(J)
          If !find(ZONE,TBCHP(1..NBCHP))
            NBCHP += 1
            TBCHP(NBCHP) = ZONE
          Endif
        Next J
    Endcase
  Next I

  Wrseq Using [SSS_]

# A Column will  be generated except if there is a clob
  FLCLOB = 0
  For JJ=0 To dim([F:ALH]SEL)-1
    CHAINE = vireblc(format$("KT:255X",[F:ALH]SEL(JJ)),2)
    If CHAINE<>""
      Gosub REC_CLOB From SUBALH11
      If FLCLOB : Break : Endif
    Endif
  Next JJ
  # Issue X3-44426 - 2017-06-14 by CCC : Add instruction Columns only if possible
  If NBCHP>0
      If (!FLCLOB or func AFNC.PARTSEP(ver$(0),2," ")>"16r.212") and func SUBALH11A.MAXCOLSIZ(LNKTBL,TBCHP,NBCHP) <=255 :#SAM 120181
        Wrseq "  Columns [LNK] ("; Using [SSS_]
        L = 0
        For I=1 To NBCHP
          ZONE = TBCHP(I)
          J = instr(1,ZONE,":")
          K = instr(1,ZONE,"]")
          ABREV = seg$(ZONE,J+1,K-1)
          ZONE  = right$(ZONE,K+1)
          DIME  = 1
          Read [AVWT]CODFIC = func SUBALH11A.TABLE(LISTE,ABREV)
          If !fstat
            Read [AVWF]CODZONE = [F:AVWT]CODFIC;ZONE
            If !fstat
              DIME = [F:AVWF]DIME
              Call REPTAB([F:AVWF]CODACT,DIME) From DOSSUB
            Endif
          Endif
          DIME = abs(DIME)
          For J=1 To DIME
            L += 1
            If mod(L,5)=0
              Wrseq Using [SSS_]
              Wrseq "& "; Using [SSS_]
            Endif
            Wrseq TBCHP(I); Using [SSS_]
            If DIME>1
              Wrseq "(";num$(J-1);")"; Using [SSS_]
            Endif
            If I<>NBCHP or J<>DIME : Wrseq ","; Using [SSS_] : Endif
          Next J
        Next I
        Wrseq ")" Using [SSS_]
        Wrseq Using [SSS_]
      Endif
  Endif
# Generate the file

# How many accumulators ?
  Filter [ALD] Where COD=LISTE & CUM=2 & STREND<=2
  NBAC=rowcount([ALD])
  Filter [ALD]

# Declare the accumulators
  If NBAC
    Wrseq "# Accumulators" Using [SSS_]
    For I=1 To NBLEV+2
      Wrseq "  Local Decimal "+sigma(1,NBAC,"CUMUL"+num$(I)+"_"+num$(indcum)+string$(indcum<NBAC,", ")) Using [SSS_]
    Next I
    Wrseq Using [SSS_]
  Elsif NBLEV
      # If no accumulator and at least a nesting level, add a line counter to support the zoom
      Wrseq "  Local Decimal "+sigma(1,NBLEV+1,"CUMUL1_"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
      Wrseq Using [SSS_]
  Endif

# Declare the Fields buffers
  Wrseq "# Fields buffers" Using [SSS_]
  For K=1 To NBLEV+1
    J=0
    For I=1 To NBFIELDS
      If FCUM(I)=0
        If FNIV(I)=K
          If J=0
            Wrseq "  Local Clbfile "; Using [SSS_]
            J=1
          Else
            Wrseq ", "; Using [SSS_]
          Endif
          # Bug fix Sept 16,2014: a generated report line field could not exceed 512 characters because Rdseq doesn't extend the clobs
          Wrseq "BUF"+num$(I)+"_"+num$(K)+"(1)"; Using [SSS_]
        Endif
      Endif
    Next I
    If J=1 : Wrseq Using [SSS_] : Endif
  Next K

  Wrseq Using [SSS_]
  Wrseq "# Miscellaneous initializations" Using [SSS_]
  Wrseq "  TIME0=val(timestamp$)" Using [SSS_]
  Wrseq "  Raz "+sigma(1,NBLEV+1,"PAGES"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  Wrseq "  Raz "+sigma(1,NBLEV+1,"RECORD"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  Raz "+sigma(1,NBLEV+1,"ZM"+num$(indcum)+string$(indcum<NBLEV+1,", ")) Using [SSS_]
  If NBLEV
    Wrseq "  Raz "+sigma(2,NBLEV+1,"ZP"+num$(indcum)+string$(indcum<=NBLEV,", ")) Using [SSS_]
  Endif

# For loop nesting
  For I=1 To NBLEV+1
#   Wrseq "## 001 I="+num$(I)-"NBLEV="+num$(NBLEV) Using [SSS_]
    If NBAC
#     Wrseq "## 002 I="+num$(I)-"NBLEV="+num$(NBLEV)-"NBAC="+num$(NBAC) Using [SSS_]
      Wrseq Using [SSS_]
      Wrseq "#"+space$(I*2-1)+"Loop accumulators init" Using [SSS_]
      Wrseq space$(I*2);"Raz "+sigma(1,NBAC,"CUMUL"+num$(I)+"_"+num$(indcum)+string$(indcum<NBAC,", ")) Using [SSS_]
    Endif

    If (NBFORMFUNC<>0)
      Wrseq space$(I*2);"Raz NBLIG"+num$(I) Using [SSS_]
      Wrseq Using [SSS_]
    Elsif NBAC
      Wrseq Using [SSS_]
    Endif

    Wrseq "#"+space$(I*2-1)+"Level "+num$(I)+" of grouping" Using [SSS_]
    Wrseq space$(I*2);"For [LNK]CLE";string$(I<>NBLEV+1,"("+num$(I)+")") Using [SSS_]
#   Wrseq space$(I*2);"For [LNK]CLE";string$(I<>NBLEV+1,"("+num$(BRKLEV(I))+")") Using [SSS_] : # NO !!!
    Wrseq Using [SSS_]

    SHIFT_IF=0

    Wrseq "#"+space$((I)*2+1+SHIFT_IF);"Record counts" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"ZM"+num$(I)+"+=1" Using [SSS_]
    Wrseq Using [SSS_]

    If I=NBLEV+1
      K=0
      If NBFORMFUNC
        Wrseq "#"+space$((I+1)*2-1)+"If a formula including func exists, compute it now" Using [SSS_]
        For J=1 To dim([ALH]SEL)
          If pat(toupper([ALH]SEL(J-1)),"*FUNC *") or pat(toupper([ALH]SEL(J-1)),"*FMET *")
            K+=1
            If K>1
              Wrseq space$((I+1)*2)+"If NBLIG"+num$(NBLEV+2)+" : NBLIG"+num$(NBLEV+2)+"="+[ALH]SEL(J-1)+" : Endif" Using [SSS_]
            Else
              Wrseq space$((I+1)*2)+"NBLIG"+num$(NBLEV+2)+"="+[ALH]SEL(J-1) Using [SSS_]
            Endif
          Endif
        Next J
        Wrseq Using [SSS_]
        Wrseq space$((I+1)*2)+"If NBLIG"+num$(I+1)+"<>0" Using [SSS_]
        SHIFT_IF=2
        Wrseq Using [SSS_]
      Endif
    Endif

    If I<=NBLEV
#     Wrseq "## 003 I="+num$(I)-"<=NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq space$((I+1)*2);"ZP"+num$(I+1)+"=ZM"+num$(I+1)+"+1" Using [SSS_]
    Endif
    Wrseq Using [SSS_]

    If I=1
#     Wrseq "## 004 I="+num$(I)-"NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq "#"+space$((I+1)*2-2+SHIFT_IF)+"Manage time computation" Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"If RECORD1=0 : TIME1=val(timestamp$) : Endif" Using [SSS_]
      Wrseq Using [SSS_]
    Endif

    If I=NBLEV+1
#     Wrseq "## 005 I="+num$(I)-"NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq "#"+space$((I+1)*2-1+SHIFT_IF)+"Manage time (every 1,000 lines) and line limits" Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"If LIM(1)+LIM(2)" Using [SSS_]
      Wrseq space$((I+2)*2+SHIFT_IF)+"TESTLIM=1" Using [SSS_]
      Wrseq space$((I+2)*2+SHIFT_IF)+"Break (LIM(1)>0)*(LIM(1)<RECORD"+num$(I)+")*"+num$(NBLEV+1) Using [SSS_]
      Wrseq space$((I+2)*2+SHIFT_IF)+"If LIM(2)>0 and mod(RECORD"+num$(I)+"+1,1000)=0" Using [SSS_]
      Wrseq space$((I+3)*2+SHIFT_IF)+"TESTLIM=2" Using [SSS_]
      Wrseq space$((I+3)*2+SHIFT_IF)+"Break (val(timestamp$)-TIME1>(LIM(2)*1000))*"+num$(NBLEV+1) Using [SSS_]
      Wrseq space$((I+2)*2+SHIFT_IF)+"Endif" Using [SSS_]
      Wrseq space$((I+2)*2+SHIFT_IF)+"TESTLIM=0" Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"Endif" Using [SSS_]
      Wrseq Using [SSS_]
    Endif

    NOCOM=0

# Bug fixing on scale of grouped infos, questionable but reproduces V6 behavior (Sept 20,2013)
# Bug fixing : replace func B by escjson (tab in string not escaped)
    For J=1 To NBFIELDS
      If FCUM(J)=0 and FNIV(J)<=I : # Previously FNIV(J)=I (Sept 20,2013)
        I0=FNIV(J) : # Previously I0=I (Sept 20,2013)

        # Issue X3-53628 - 2017-09-20 by CCC
        # If the value comes from ATEXTRA which has not been read thanks to the link (link too complex) => read it
        If left$(COMPFORM(J),5)="[F:AY"
            L = find(FIELDS(J),CHTXT)
            If L>0 & TYPTXT(L)=3    # TYPTXT=3 <=> link too complex
                Wrseq space$((I+1)*2+SHIFT_IF);"Raz "+left$(COMPFORM(J),8) Using [SSS_]
                Wrseq space$((I+1)*2+SHIFT_IF);"Read "+left$(COMPFORM(J),8)+'AXX0 = "'+TBTXT(L)+'";"'+CHTXT(L)+'";LANGUE'; Using [SSS_]
                For GBIDC1="CLECUR1","CLECUR2"
                  Read [AMP]CODPAR=2;TBTXT(L);CHTXT(L);GBIDC1
                  If !fstat
                    Read [AVWF]CODZONE = TBTXT(L);[AMP]VALPAR
                    If !fstat
                      CHAINE = "[F:"+ABTXT(L)+"]"+[AMP]VALPAR
                    Else
                      CHAINE = [AMP]VALPAR
                    Endif
                  Else
                    CHAINE = '""'
                  Endif
                  Wrseq ";"+CHAINE; Using [SSS_]
                Next GBIDC1
                Wrseq Using [SSS_]
            Endif
        Endif

        If NOCOM=0 : NOCOM=1 : Wrseq "#"+space$((I+1)*2-1+SHIFT_IF)+"Buffer the fields for the accumulated record" Using [SSS_] : Endif
        If FTYPE(J)=func AJSONLIB.TYPZON(1,1)
          # Fix on bug 102119  -- Dominique BOPP Sept 1,2014
          Wrseq space$((I+1)*2+SHIFT_IF);"TRUFAL=string$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+">=2,'true')" Using [SSS_]
          Wrseq space$((I+1)*2+SHIFT_IF);'TRUFAL+=string$(TRUFAL="","false")' Using [SSS_]
          Wrseq space$((I+1)*2+SHIFT_IF);"BUF"+num$(J)+"_"+num$(I0)+"="+"'"+'"'
&               +FIELDS(J)+'":'+"'"+'+TRUFAL+""' Using [SSS_]
        Else
          # Issue X3-75664 - 2018-07-05 by CCC : Try to format the value. If not possible, get the value without formatting
          If len(FFORTYP(J))
&          & ( FTYPE(J)=func AJSONLIB.TYPZON(7,0)
&            | FTYPE(J)=func AJSONLIB.TYPZON(10,0))
            Wrseq space$((I+1)*2+SHIFT_IF);"Raz LCLBVAL : Append LCLBVAL,vireblc(escJson(format$(string$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+ '<>"",' +'"' + FFORTYP(J) + '"' + "),"
&            +COMPFORM(J)+string$(COMPFORM(J)="", FIELDS(J))+")),1)" Using [SSS_]
            Wrseq space$((I+1)*2+SHIFT_IF);"If LCLBVAL='' & "+COMPFORM(J)+"<>''     # Test if format$ was able to return a value" Using [SSS_]
            Wrseq space$((I+2)*2+SHIFT_IF);"Raz LCLBVAL : Append LCLBVAL,"+COMPFORM(J) Using [SSS_]
            Wrseq space$((I+1)*2+SHIFT_IF);"Endif" Using [SSS_]
          Endif
          Wrseq space$((I+1)*2+SHIFT_IF);"BUF"+num$(J)+"_"+num$(I0)+"="; Using [SSS_]
          Case FTYPE(J)
            When func AJSONLIB.TYPZON(1,2),func AJSONLIB.TYPZON(2,0),func AJSONLIB.TYPZON(4,0)
              Wrseq "'"+'"'+FIELDS(J)+'":'+"'+num$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+")+'"+"'" Using [SSS_]
            When func AJSONLIB.TYPZON(7,0), func AJSONLIB.TYPZON(10,0)
             If len(FFORTYP(J)) #SAM 109290 / SAM 110364 consequence of previous fix)
#             Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+escjson(format$(string$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+ '<>"",' +'"' + FFORTYP(J) + '"' + ")," +COMPFORM(J)+string$(COMPFORM(J)="",
# & FIELDS(J))+"))+'"+'"'+"'" Using [SSS_]
#             # Modification done SAM 111929 October 21,2015 to avoid sending spaces at the end of the fields that might support links

# Issue X3-75664 - 2018-07-05 by CCC : if format was defined, the value is now in LCLBVAL
##{SAM 117765
#              If FFORTYP(J) <> "=GFMT"
#               Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+vireblc(escjson(format$(string$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+ '<>"",' +'"' + FFORTYP(J) + '"' + "),"
#& +COMPFORM(J)+string$(COMPFORM(J)="", FIELDS(J))+")),1)+'"+'"'+"'" Using [SSS_]
#              Else
#               Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+vireblc(escjson("+COMPFORM(J)+"),1)+'"+'"'+"'" Using [SSS_]
#              Endif
##SAM 117765}
               Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+LCLBVAL+'"+'"'+"'" Using [SSS_]
             Else
              Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+escJson("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+")+'"+'"'+"'" Using [SSS_]
             Endif
            When func AJSONLIB.TYPZON(8,0)
              Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+format$('D:YYYY[-]MM[-]DD',"+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+')+'+"'"+'"'+"'" Using [SSS_]
            When func AJSONLIB.TYPZON(12,0)
              Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+num$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+")+'"+'"'+"'" Using [SSS_]
            When func AJSONLIB.TYPZON(11,0) : # Addition October 22,2010 : manage the uuid fields in a request
              Wrseq "'"+'"'+FIELDS(J)+'":"'+"'+num$("+COMPFORM(J)+string$(COMPFORM(J)="",FIELDS(J))+")+'"+'"'+"'" Using [SSS_]
          Endcase
        Endif
      Endif
    Next J
  Next I

  If NBAC
#   Wrseq "## 008 NBAC="+num$(NBAC) Using [SSS_]
    For I=1 To NBFIELDS
      If FCUM(I)
        Wrseq space$((NBLEV+2)*2+SHIFT_IF)+"CUMUL"+num$(NBLEV+2)+"_"+num$(FCUM(I))+"="+COMPFORM(I)+string$(COMPFORM(I)="",FIELDS(I)) Using [SSS_]
      Endif
    Next I
  Endif

# Now perform the accumulations in the different loops, and fill the data
  For I=NBLEV+1 To 1 Step -1

    If I<=NBLEV
#     Wrseq "## 009 I="+num$(I)-"J="+num$(J)-"NBLEV="+num$(NBLEV)-num$(max(FCUM(1..NBFIELDS))) Using [SSS_]
      If max(FCUM(1..NBFIELDS))<>0
        Wrseq "#";space$((I+1)*2+SHIFT_IF);"Accumulators update" Using [SSS_]
      Endif
      For J=1 To NBFIELDS
        If FCUM(J)
          Wrseq space$((I+2)*2+SHIFT_IF);"CUMUL"+num$(I+1)+"_"+num$(FCUM(J))+"+=CUMUL"+num$(I+2)+"_"+num$(FCUM(J)) Using [SSS_]
        Endif
      Next J
      If NBCUM=0
        Wrseq "#";space$((I+1)*2+SHIFT_IF);"Accumulators update" Using [SSS_]
        Wrseq space$((I+2)*2+SHIFT_IF);"CUMUL1_"+num$(I)+"+=1" Using [SSS_]
      Endif
      If NBFORMFUNC
        Wrseq space$((I+1)*2+SHIFT_IF);"Else" Using [SSS_]
        Wrseq space$((I+2)*2+SHIFT_IF);"ZM"+num$(I+1)+"-=1" Using [SSS_]
        Wrseq space$((I+1)*2+SHIFT_IF);"Endif" Using [SSS_]
      Endif

      Wrseq Using [SSS_]
      Wrseq space$((I+1)*2);"Next" Using [SSS_]
    Endif

    Wrseq Using [SSS_]
#   Wrseq "## 010 I="+num$(I) Using [SSS_]


    Wrseq "#"+space$(I*2)+"Pointers computation" Using [SSS_]
    If I<=NBLEV and NBFORMFUNC
      SHIFT_IF=2
      Wrseq space$((I+1)*2)+"If NBLIG"+num$(I+1)+"<>0" Using [SSS_]
    Endif

    Wrseq space$((I+1)*2+SHIFT_IF);"If mod(RECORD"+num$(I)+",NBHEAD)=0 and RECORD"+num$(I)+">0" Using [SSS_]
#   Wrseq space$((I+2)*2+SHIFT_IF);"Openo Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq space$((I+2)*2+SHIFT_IF);"Openo PATH_IDX("+num$(I)+"),(RECORD"+num$(I)+"<=NBHEAD)-1 Using [IDX]" Using [SSS_]
    Wrseq space$((I+2)*2+SHIFT_IF);"Putseq NBHEAD,PAGES"+num$(I)+" Using [IDX]" Using [SSS_]
    Wrseq space$((I+2)*2+SHIFT_IF);"Raz PAGES"+num$(I) Using [SSS_]
    Wrseq space$((I+2)*2+SHIFT_IF);"Openo Using [IDX]" Using [SSS_]
#    Wrseq space$((I+2)*2+SHIFT_IF);"Openo PATH_RQT("+num$(I)+"),-1 Using [LEV"+num$(I)+"]" Using [SSS_]
#    Wrseq space$((I+2)*2+SHIFT_IF);"Iomode adxifs '' Using [LEV"+num$(I)+"]" Using [SSS_]
#    Wrseq space$((I+2)*2+SHIFT_IF);"Iomode adxirs chr$(10) Using [LEV"+num$(I)+"]" Using [SSS_]
#    Wrseq space$((I+2)*2+SHIFT_IF);"Iomode adxium 0 Using [LEV"+num$(I)+"] : # Corresponds to UTF8 format" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"Endif" Using [SSS_]
    Wrseq Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"RECORD"+num$(I)+"+=1" Using [SSS_]
    If NBFORMFUNC and I<>1 : Wrseq space$((I+1)*2+SHIFT_IF);"NBLIG"+num$(I)+"+=1" Using [SSS_] : Endif
    Wrseq Using [SSS_]
    Wrseq "#"+space$(I*2+SHIFT_IF)+"Update the record" Using [SSS_]

    # Optimisation des ouvertures
    If I<NBLEV-2
      Wrseq space$((I+1)*2+SHIFT_IF)+"Openo PATH_RQT("+num$(I)+"),-1 Using [LEV"+num$(I)+"]"  Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF);"Iomode adxifs '' Using [LEV"+num$(I)+"]" Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF);"Iomode adxirs chr$(10) Using [LEV"+num$(I)+"]" Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF);"Iomode adxium 0 Using [LEV"+num$(I)+"] : # Corresponds to UTF8 format" Using [SSS_]
    Endif

    Wrseq space$((I+1)*2+SHIFT_IF)+"WRBUF='{'" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,'"+'"$uuid":"' + "'+num$(uuid$)+'"+'"'+"'" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"line_no":'+"'+num$(RECORD"+num$(I)+")" Using [SSS_]
    If I<=NBLEV
#     Wrseq "## 011 I="+num$(I)-"J="+num$(J)-"NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"z_p":'+"'+num$(ZP"+num$(I+1)+")" Using [SSS_]
    Elsif NBLEV
#     Wrseq "## 012 I="+num$(I)-"J="+num$(J)-"NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"z_p":'+"'+num$(ZP"+num$(I)+")" Using [SSS_]
    Endif
    If I>1
#     Wrseq "## 013 I="+num$(I)-"J="+num$(J)-"NBLEV="+num$(NBLEV) Using [SSS_]
      Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"z_m":'+"'+num$(ZM"+num$(I-1)+")" Using [SSS_]
    Endif

#   Loop that generates the append of data : CHL has been added to handle null dates (a little bit tricky)
    K=0 : CHL=""
    For J=1 To NBFIELDS
      If FCUM(J)
        K+=1
#       If K>1 : Wrseq "+','"+string$(CHL<>"",")") Using [SSS_] : Endif
        CHL=""
#       Wrseq "## 014 I="+num$(I)-"J="+num$(J)-"NBFIELDS="+num$(NBFIELDS) Using [SSS_]
        Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"'+FIELDS(J)+'":'+"'+num$(CUMUL"+num$(I+1)+"_"+num$(FCUM(J))+")" Using [SSS_]
      Elsif FNIV(J)<=I
        K+=1
#       If K>1 : Wrseq "+','"+string$(CHL<>"",")") Using [SSS_] : Endif
        CHL=string$(FTYPE(J)=func AJSONLIB.TYPZON(8,0),"string$(instr(5,BUF"+num$(J)+"_"+num$(FNIV(J))+",'"+'"'+'    -  -  "'+"')=0,")
#       Wrseq "## 015 I="+num$(I)-"J="+num$(J)-"NBFIELDS="+num$(NBFIELDS) Using [SSS_]
        Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,"+CHL+"','+BUF"+num$(J)+"_"+num$(FNIV(J))+string$(CHL<>"",")") Using [SSS_]
      Endif
    Next J
# Line_no at the end
#   Wrseq space$((I+1)*2+SHIFT_IF)+"Append WRBUF,',"+'"line_no":'+"'+num$(RECORD"+num$(I)+")" Using [SSS_]

#   Wrseq string$(CHL<>"",")") Using [SSS_]
#   Wrseq "## 015 I="+num$(I)-"NBFIELDS="+num$(NBFIELDS) Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF)+"Wrseq WRBUF+'}' Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq Using [SSS_]

    Wrseq "#"+space$(I*2+SHIFT_IF)+"Pointers update" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"PAGES"+num$(I)+'(mod(RECORD'+num$(I)+'-1,NBHEAD)+1)=adxseek("LEV'+num$(I)+'")' Using [SSS_]
    If I<NBLEV-2
      Wrseq space$((I+1)*2+SHIFT_IF)+"Openo Using [LEV"+num$(I)+"]"  Using [SSS_]
    Endif
    Wrseq Using [SSS_]

  Next I

# Wrseq "## 016" Using [SSS_]
  If NBFORMFUNC
    Wrseq Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"Else" Using [SSS_]
    Wrseq space$((I+2)*2+SHIFT_IF);"ZM1-=1" Using [SSS_]
    Wrseq space$((I+1)*2+SHIFT_IF);"Endif" Using [SSS_]
  Endif
  Wrseq space$((I+1)*2);"Next" Using [SSS_]
  Wrseq Using [SSS_]

# Wrseq "## 017" Using [SSS_]
  Wrseq '# Set the "break on exit" variables' Using [SSS_]
  Wrseq "  If TESTLIM<>1" Using [SSS_]
  Wrseq "    LIM(1)=0" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "  If TESTLIM<>2" Using [SSS_]
  Wrseq "    LIM(2)=0" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Perform the final flush of the header, then close the file" Using [SSS_]
  Wrseq "  TIME2=val(timestamp$)" Using [SSS_]
  Wrseq '  HEADER=format$("N0:8",int((TIME1-TIME0)/1000))+"."+format$("N0:3",mod(TIME1-TIME0,1000))' Using [SSS_]
  Wrseq '&       -format$("N0:8",int((TIME2-TIME1)/1000))+"."+format$("N0:3",mod(TIME2-TIME1,1000))' Using [SSS_]
  Wrseq '&       -format$("N0:8",LIM(1))-format$("N0:8",LIM(2))' Using [SSS_]
  For I=1 To NBLEV+1
    Wrseq Using [SSS_]
#   Wrseq "## 018 I="+num$(I)-"NBLEV="+num$(NBLEV) Using [SSS_]
    If I<NBLEV-2
      Wrseq "# Update the last header, write the number of lines" Using [SSS_]
    Else
      Wrseq "# Update the last header, write the number of lines, and close file for level"-num$(I) Using [SSS_]
      Wrseq "  Openo Using [LEV"+num$(I)+"]" Using [SSS_]
    Endif
    Wrseq "  Openio PATH_RQT("+num$(I)+") Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Iomode adxifs '' Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Iomode adxirs chr$(10) Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Iomode adxium 0 Using [LEV"+num$(I)+"] : # Corresponds to UTF8 format" Using [SSS_]
    Wrseq "  Seek First+LINE_SEEK Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Wrseq format$('N0:8#',RECORD"+num$(I)+")-REQUID-format$('N0:8#',0)-HEADER Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Openio Using [LEV"+num$(I)+"]" Using [SSS_]
    Wrseq "  Openo PATH_IDX("+num$(I)+"),(RECORD"+num$(I)+"<=NBHEAD)-1 Using [IDX"+num$(I)+"]" Using [SSS_]
    Wrseq "  Putseq NBHEAD,PAGES"+num$(I)+" Using [IDX"+num$(I)+"]" Using [SSS_]
    Wrseq "  Openo Using [IDX"+num$(I)+"]" Using [SSS_]
  Next I
  Wrseq Using [SSS_]

  Wrseq "# Return the number of computed lines" Using [SSS_]
  For I=1 To NBLEV+1
    Wrseq "  NBLIG("+num$(NBLEV+2-I)+")=RECORD"+num$(I) Using [SSS_]
  Next I
  Wrseq Using [SSS_]

  Wrseq "# Restore the initial value of adxmso" Using [SSS_]
  Wrseq "  adxmso=SVG_MSO" Using [SSS_]
  Wrseq Using [SSS_]

# Lines changed (Cloud adaptation)
  Wrseq "# Final transferring of file (Cloud adaptation)" Using [SSS_]
  Wrseq "  If IF_CLOUD : Gosub CLEANFILE From SUBALH11A : Endif" Using [SSS_]
  Wrseq "  stat1=Delfile(filpath('RQT',REQUID,'lck'))" Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "End" Using [SSS_]

# Compute the criteria associated to the ranges on the fields
  Wrseq Using [SSS_]
  Wrseq "# Subprogram to compute the criteria according to VALBEG/VALEND/STRICTBEG/STRICTEND arrays" Using [SSS_]
  Wrseq "$EVAL_CRIT" Using [SSS_]
  Wrseq "Local Integer K" Using [SSS_]
  DIMBEG=0
  For [ALD] Where COD=LISTE & STREND=2
    DIMBEG+=1
  Next
  I=0
  Wrseq "  Raz CRITERE" Using [SSS_]
  Wrseq "  K=1" Using [SSS_]
  For [ALD] Where COD=LISTE & STREND>=2
    I+=1
    Read [ATY]CODTYP=[ALD]CODTYP
    CHAINE="("+num$(I)+")"
    ZONE="[F:"+ABFIC(find([ALD]TBL,TBFIC))+"]"+[ALD]FLD
    Case [ATY]TYPTYP
      When 1,2,3,4,5,6
        Wrseq "  If STRICTBEG"+CHAINE Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+">'+string$(STRICTBEG"+CHAINE+"=1,'=')+num$(val("+
&       "VALBEG("+num$(I)+")))" Using [SSS_]
        Wrseq "    If STRICTEND"+CHAINE Using [SSS_]
        Wrseq "       CRITERE(K)+=' & "+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+num$(val("+
&       "VALBEG("+num$(I)+")))" Using [SSS_]
        Wrseq "    Endif" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Elsif STRICTEND"+CHAINE+"" Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+num$(val("+
&       "VALBEG("+num$(I)+")))" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Endif" Using [SSS_]
      When 8
        Wrseq "  If STRICTBEG"+CHAINE Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+">'+string$(STRICTBEG"+CHAINE+"=1,'=')+'gdat$('+"+
&       "num$(val(mid$(VALBEG("+num$(I)+"),9,2)))+','+num$(val(mid$(VALBEG("+num$(I)+"),6,2)))+','+"
&       +"num$(val(mid$(VALBEG("+num$(I)+"),1,4)))+')'" Using [SSS_]
        Wrseq "    If STRICTEND"+CHAINE Using [SSS_]
        Wrseq "       CRITERE(K)+=' & "+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+'gdat$('+"+
&       "num$(val(mid$(VALEND("+num$(I)+"),9,2)))+','+num$(val(mid$(VALEND("+num$(I)+"),6,2)))+','+"
&       +"num$(val(mid$(VALEND("+num$(I)+"),1,4)))+')'" Using [SSS_]
        Wrseq "    Endif" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Elsif STRICTEND"+CHAINE+"" Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+'gdat$('+"+
&       "num$(val(mid$(VALEND("+num$(I)+"),9,2)))+','+num$(val(mid$(VALEND("+num$(I)+"),6,2)))+','+"
&       +"num$(val(mid$(VALEND("+num$(I)+"),1,4)))+')'" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Endif" Using [SSS_]
      When 12
        Wrseq "  If STRICTBEG"+CHAINE Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+">'+string$(STRICTBEG"+CHAINE+"=1,'=')+'gdatetime$("+'"'+"'+"+
&       "VALBEG("+num$(I)+")+"+"'"+'")'+"'" Using [SSS_]
        Wrseq "    If STRICTEND"+CHAINE Using [SSS_]
        Wrseq "    CRITERE(K)+='& "+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+'gdatetime$("+'"'+"'+"+
&       "VALEND("+num$(I)+")+"+"'"+'")'+"'" Using [SSS_]
        Wrseq "    Endif" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Elsif STRICTEND"+CHAINE+"" Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+'gdatetime$("+'"'+"'+"+
&       "VALEND("+num$(I)+")+"+"'"+'")'+"'" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Endif" Using [SSS_]
      When Default
        Wrseq "  If STRICTBEG"+CHAINE Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+">'+string$(STRICTBEG"+CHAINE+"=1,'=')+func ASYRREQ.S("+
&       "VALBEG("+num$(I)+"))" Using [SSS_]
        Wrseq "    If STRICTEND"+CHAINE Using [SSS_]
        Wrseq "       CRITERE(K)+=' & "+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+func ASYRREQ.S("+
&       "VALEND("+num$(I)+"))" Using [SSS_]
        Wrseq "    Endif" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Elsif STRICTEND"+CHAINE+"" Using [SSS_]
        Wrseq "    CRITERE(K)=string$(K>1,'& ')+'"+ZONE+"<'+string$(STRICTEND"+CHAINE+"=1,'=')+func ASYRREQ.S("+
&       "VALEND("+num$(I)+"))" Using [SSS_]
        Wrseq "    K+=1" Using [SSS_]
        Wrseq "  Endif" Using [SSS_]
    Endcase
  Next
  Wrseq "  If K=1 : CRITERE(1)='(1=1)' : K+=1 : Endif" Using [SSS_]
  Wrseq "Return" Using [SSS_]
  Wrseq "" Using [SSS_]

# Subprograms to handle batch task management
  I=0
  Wrseq "# Writes the criteria in the batch parameter table" Using [SSS_]
  Wrseq "# Returns 0 if OK, fstat value otherwise" Using [SSS_]
  Wrseq "$WRITE_ABL" Using [SSS_]
  Wrseq "  NUMPAR+=1" Using [SSS_]
  Wrseq "  [ABL]NUM=NUMPAR" Using [SSS_]
  Wrseq "  [ABL]NUMREQ=[ABR]NUMREQ" Using [SSS_]
  Wrseq "  [ABL]CREUSR=GACTX.USER" Using [SSS_]
  Wrseq "  [ABL]UPDUSR=''" Using [SSS_]
  Wrseq "  [ABL]CREDATTIM=datetime$" Using [SSS_]
  Wrseq "  Write [ABL]" Using [SSS_]
  Wrseq "Return" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Funprog WR_CRIT(STRICTBEG,STRICTEND,VALBEG,VALEND,UUIREQ)" Using [SSS_]
  Wrseq "Value Char VALBEG()(1..)  : # The first value of range" Using [SSS_]
  Wrseq "Value Char VALEND()(1..)  : # The last value of range" Using [SSS_]
  Wrseq "Value Libelle STRICTBEG(1..),STRICTEND(1..):# Strict=2, or equal=1, no value=0" Using [SSS_]
  Wrseq "Value Char UUIREQ()       :# Unique ID for request" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  Local Integer NUMPAR" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  [ABL]PARAM='TRTNAM'" Using [SSS_]
  Wrseq "  [ABL]VALEUR='"+NOMTRT+"'" Using [SSS_]
  Wrseq "  Gosub WRITE_ABL" Using [SSS_]
  Wrseq "  If fstat : End fstat : Endif" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  If UUIREQ<>''" Using [SSS_]
  Wrseq "    [ABL]PARAM='UUIREQ'-left$(UUIREQ,6)" Using [SSS_]
  Wrseq "    [ABL]VALEUR=right$(UUIREQ,7)" Using [SSS_]
  Wrseq "    Gosub WRITE_ABL" Using [SSS_]
  Wrseq "    If fstat : End fstat : Endif" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "" Using [SSS_]

  For [ALD] Where COD=LISTE & STREND>=2
    I+=1
    Wrseq "  If STRICTBEG("+num$(I)+")" Using [SSS_]
    Wrseq "    [ABL]PARAM='STRICTBEG("+num$(I)+")'" Using [SSS_]
    Wrseq "    [ABL]VALEUR=num$(STRICTBEG("+num$(I)+"))" Using [SSS_]
    Wrseq "    Gosub WRITE_ABL" Using [SSS_]
    Wrseq "    If fstat : End fstat : Endif" Using [SSS_]
    Wrseq "    [ABL]PARAM='VALBEG("+num$(I)+")'" Using [SSS_]
    Wrseq "    [ABL]VALEUR=VALBEG("+num$(I)+")" Using [SSS_]
    Wrseq "    Gosub WRITE_ABL" Using [SSS_]
    Wrseq "    If fstat : End fstat : Endif" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If STRICTEND("+num$(I)+")" Using [SSS_]
    Wrseq "    [ABL]PARAM='STRICTEND("+num$(I)+")'" Using [SSS_]
    Wrseq "    [ABL]VALEUR=num$(STRICTEND("+num$(I)+"))" Using [SSS_]
    Wrseq "    Gosub WRITE_ABL" Using [SSS_]
    Wrseq "    If fstat : End fstat : Endif" Using [SSS_]
    Wrseq "    [ABL]PARAM='VALEND("+num$(I)+")'" Using [SSS_]
    Wrseq "    [ABL]VALEUR=VALEND("+num$(I)+")" Using [SSS_]
    Wrseq "    Gosub WRITE_ABL" Using [SSS_]
    Wrseq "    If fstat : End fstat : Endif" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
  Next
  Wrseq "End 0" Using [SSS_]
  Wrseq "" Using [SSS_]

  Wrseq "# Reads the criteria in the batch parameter table" Using [SSS_]
  Wrseq "# Returns the number of values found" Using [SSS_]
  Wrseq "Funprog RD_CRIT(STRICTBEG,STRICTEND,VALBEG,VALEND,UUIREQ)" Using [SSS_]
  Wrseq "Variable Char VALBEG()(1..)  : # The first value of range" Using [SSS_]
  Wrseq "Variable Char VALEND()(1..)  : # The last value of range" Using [SSS_]
  Wrseq "Variable Libelle STRICTBEG(1..),STRICTEND(1..):# Strict=2, or equal=1, no value=0" Using [SSS_]
  Wrseq "Value Char UUIREQ()       :# Unique ID for request" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  For [ABL]NUMREQ Where NUMREQ=[ABR]NUMREQ" Using [SSS_]
  Wrseq "    Case [ABL]PARAM" Using [SSS_]
  I=0

  For [ALD] Where COD=LISTE & STREND>=2
    I+=1
    Wrseq "      When 'STRICTBEG("+num$(I)+")' : STRICTBEG("+num$(I)+")=val([ABL]VALEUR)" Using [SSS_]
    Wrseq "      When 'STRICTEND("+num$(I)+")' : STRICTEND("+num$(I)+")=val([ABL]VALEUR)" Using [SSS_]
    Wrseq "      When 'VALBEG("+num$(I)+")' : VALBEG("+num$(I)+")=[ABL]VALEUR" Using [SSS_]
    Wrseq "      When 'VALEND("+num$(I)+")' : VALEND("+num$(I)+")=[ABL]VALEUR" Using [SSS_]
  Next
  Wrseq "      When Default : If left$([ABL]PARAM,7)='UUIREQ '" Using [SSS_]
  Wrseq "                       UUIREQ=right$([ABL]PARAM,8)+[ABL]VALEUR" Using [SSS_]
  Wrseq "                     Endif" Using [SSS_]
  Wrseq "    Endcase" Using [SSS_]
  Wrseq "  Next" Using [SSS_]
  Wrseq "End [ABL]NUM" Using [SSS_]

# Get the data
# Modification October 22,2014: add an entry point for calendar display
  Wrseq  Using [SSS_]
  Wrseq  "# The main function that gets the data from an already computed request" Using [SSS_]
  Wrseq  "# Parameters are sent but ignored if REQUID corresponds to the unique ID assigned during computation" Using [SSS_]
  Wrseq  "# A hack has been done : IFLINE can now have a second index if IFLINE(2)=1, noHeader parameter has been used" Using [SSS_]
# Issue X3-58749 - 2018-02-08 by CCC
# Bug 110848 : PORTVIEW added
# SAM 119892 : FRQ added
  Wrseq 'Subprog GET_CAL(ACTX,LEVEL,REQUID,QWHERE,VALBEG,VALEND,STRICTBEG,STRICTEND,FIRSTLINE,NBLINES,COMPDATETIME,IFLINE,IFBULK,IFCUBE,STARTIND,ASND,CALEND,PORTVIEW,FRQ,OK)' Using [SSS_]
  Wrseq 'Variable Instance ACTX Using '+[V]CST_C_NAME_CLASS_CONTEXT Using [SSS_]
  Wrseq 'Value Integer LEVEL       : # The level of inquiry' Using [SSS_]
  Wrseq 'Value Char    REQUID()    : # If not empty, corresponds to the current request uuid' Using [SSS_]
  Wrseq 'Variable Clbfile QWHERE   : # Where clause in SDATA format' Using [SSS_]
  Wrseq 'Value Char VALBEG()(1..)  : # The first value of range' Using [SSS_]
  Wrseq 'Value Char VALEND()(1..)  : # The last value of range' Using [SSS_]
  Wrseq "Value Libelle STRICTBEG(1..),STRICTEND(1..):# Strict=2, or equal=1, no value=0" Using [SSS_]
  Wrseq 'Value Integer FIRSTLINE   : # The number of first line (1 by default)' Using [SSS_]
  Wrseq 'Value Integer NBLINES     : # Number of lines required (20 by default)' Using [SSS_]
  Wrseq 'Variable Decimal COMPDATETIME    : # Expected computation datetime' Using [SSS_]
  Wrseq 'Variable Libelle IFLINE(1..): # True if line number must be displayed' Using [SSS_]
  Wrseq 'Variable Libelle IFBULK   : # True if bulk mode is activated' Using [SSS_]
  Wrseq 'Variable Integer IFCUBE   : # Not null if cube mode is activated' Using [SSS_]
  Wrseq 'Value Integer STARTIND    : # Shift page value' Using [SSS_]
  Wrseq 'Variable Instance ASND Using C_ASYRSND : # Sending structure' Using [SSS_]
  # Bug 110848
  Wrseq 'Value Char PORTVIEW()     : # The portal view to be sent back for refresh link' Using [SSS_]
  # End Bug 110848
  # Bug found by Dom Nov 18, 2016
  Wrseq 'Value Integer FRQ' Using [SSS_]
 # End bug Dom

  Wrseq 'Variable Integer OK       : # Returns 0 if OK, error codes otherwise' Using [SSS_]
  Wrseq 'Value Clbfile CALEND      : # Calendar (hack)' Using [SSS_]
  Wrseq 'Goto CALEND' Using [SSS_]

  Wrseq Using [SSS_]

# Issue X3-58749 - 2018-02-08 by CCC
# Bug 110848 : PORTVIEW added
  Wrseq 'Subprog GET_RQT(ACTX,LEVEL,REQUID,QWHERE,VALBEG,VALEND,STRICTBEG,STRICTEND,FIRSTLINE,NBLINES,COMPDATETIME,IFLINE,IFBULK,IFCUBE,STARTIND,ASND,PORTVIEW,FRQ,OK)' Using [SSS_] :#SAM 114121
  Wrseq 'Variable Instance ACTX Using '+[V]CST_C_NAME_CLASS_CONTEXT Using [SSS_]
  Wrseq 'Value Integer LEVEL       : # The level of inquiry' Using [SSS_]
  Wrseq 'Value Char    REQUID()    : # If not empty, corresponds to the current request uuid' Using [SSS_]
  Wrseq 'Variable Clbfile QWHERE   : # Where clause in SDATA format' Using [SSS_]
  Wrseq 'Value Char VALBEG()(1..)  : # The first value of range' Using [SSS_]
  Wrseq 'Value Char VALEND()(1..)  : # The last value of range' Using [SSS_]
  Wrseq "Value Libelle STRICTBEG(1..),STRICTEND(1..):# Strict=2, or equal=1, no value=0" Using [SSS_]
  Wrseq 'Value Integer FIRSTLINE   : # The number of first line (1 by default)' Using [SSS_]
  Wrseq 'Value Integer NBLINES     : # Number of lines required (20 by default)' Using [SSS_]
  Wrseq 'Variable Decimal COMPDATETIME    : # Expected computation datetime' Using [SSS_]
  Wrseq 'Variable Libelle IFLINE(1..): # True if line number must be displayed' Using [SSS_]
  Wrseq 'Variable Libelle IFBULK   : # True if bulk mode is activated' Using [SSS_]
  Wrseq 'Variable Integer IFCUBE   : # Not null if cube mode is activated' Using [SSS_]
  Wrseq 'Value Integer STARTIND    : # Shift page value' Using [SSS_]
  Wrseq 'Variable Instance ASND Using C_ASYRSND : # Sending structure' Using [SSS_]
  #{SAM 110848
  Wrseq 'Value Char PORTVIEW()     : # The portal view to be sent back for refresh link' Using [SSS_]
  #SAM  110848}
  Wrseq 'Value Integer FRQ: # Frequency' Using [SSS_] :#SAM 114121
  Wrseq 'Variable Integer OK       : # Returns 0 if OK, error codes otherwise' Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq 'Local Clbfile CALEND      : # Hack for calendar' Using [SSS_]
  Wrseq "$CALEND" Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Local variables' Using [SSS_]
  Wrseq 'Local Integer PR,NX,LS : # /Next / Last index computed for links (0 if no such link)' Using [SSS_]
  Wrseq 'Local Integer MAXLEVEL,MAXLINES' Using [SSS_]
  Wrseq 'Local Char CHEMIDX(250),CHEMIDXPRE(250),CHEMDATA(250),CHEMDATAPRE(250)' Using [SSS_]
  Wrseq 'Local Integer NOACCESS' Using [SSS_]
  Wrseq "Local Integer NBHEAD : NBHEAD="+num$(NBHEAD) Using [SSS_]
  Wrseq "Local Clbfile BUFFER(3)" Using [SSS_]
  Wrseq "Local Char CRITERE(250)(1..100)" Using [SSS_]
  Wrseq 'Local Integer I,J,K' Using [SSS_]
  # Bug fix Sept 16,2014: a generated report line could not exceed 512 characters because Rdseq doesn't extend the clobs
  Wrseq 'Local Clbfile BUF(3)' Using [SSS_]
  Wrseq 'Local Date COMPDATE' Using [SSS_]
  Wrseq 'Local Char LISTE(20)      : # The Request code' Using [SSS_]
  Wrseq 'Local Char USER(20)       : # User code' Using [SSS_]
  Wrseq 'Local Char LAN(10)        : # User code' Using [SSS_]
  Wrseq 'Local Decimal TIME1,TIME2 : # Timing information' Using [SSS_]
  Wrseq 'Local Char COMPTIME(10)' Using [SSS_]
  Wrseq "Local Integer PAGE, NBDET" Using [SSS_]
  Wrseq "Local Integer LIM(1..2)" Using [SSS_]
  Wrseq "Local Integer PROCESS_ID" Using [SSS_]
  Wrseq 'Local Integer FIRST_RECORD, LAST_RECORD: # First and last record in the structure' Using [SSS_]
  If NBLEV>0
    Wrseq 'Local Char VALUE_ZOOM(100)(1..'+num$(NBLEV)+'): # Values for level break in header' Using [SSS_]
  Endif
  Wrseq 'Local Integer START_SEEK,FIRST_SEEK' Using [SSS_]
  Wrseq 'Local Date BUF_DATE' Using [SSS_]
  Wrseq 'Local Integer IF_CLOUD' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Get the maximum level' Using [SSS_]
  Wrseq '  MAXLEVEL='+num$(NBLEV+1) Using [SSS_]
  Wrseq '  LEVEL=min(LEVEL,MAXLEVEL) : # Avoid a message if level is too big' Using [SSS_]
  Wrseq '  LISTE="'+LISTE+'"' Using [SSS_]
  Wrseq '  If FRQ=0 : FRQ=6 : Endif' Using [SSS_] :#114121
  Wrseq Using [SSS_]

  Wrseq '# Determine if we are in Cloud release or not' Using [SSS_]
   Wrseq '  IF_CLOUD=(getenv$("PUBLICCLOUD")<>"")' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Generation timestamp to force the reexecution' Using [SSS_]
  Wrseq 'Local Decimal TIME_UPD' Using [SSS_]
  Wrseq "  TIME_UPD="+num$(val(timestamp$)) Using [SSS_]
  Wrseq Using [SSS_]

# If the request is shared, no user code is given
  If [ALH]ALLUSR=2
    Wrseq '  USER=""' Using [SSS_]
    Wrseq Using [SSS_]
  Else
    Wrseq '  USER=ACTX.USER' Using [SSS_]
  Endif
  Wrseq "  LAN=ACTX.LAN : If LAN='' : LAN=ACTX.LAN : If LAN='' : LAN='ENG' : Endif : Endif" Using [SSS_]
  If DEB_UG
    Wrseq '  Call TRACE(" in WFTESTREQ1 USER="+USER) From ASYRCOM' Using [SSS_]
    Wrseq '  Call TRACE("               LEVEL="+num$(LEVEL)) From ASYRCOM' Using [SSS_]
    Wrseq '  Call TRACE("               REQUID="+REQUID) From ASYRCOM' Using [SSS_]
    Wrseq '  If dim(VALBEG)>=1' Using [SSS_]
    Wrseq '  Call TRACE("               VALBEG="+sigma(1,dim(VALBEG),chr$(34)+VALBEG(indcum)+chr$(34)+string$(indcum<dim(VALBEG),",")))From ASYRCOM' Using [SSS_]
    Wrseq '  Else' Using [SSS_]
    Wrseq '    Call TRACE("               dim(VALBEG)="+num$(dim(VALBEG))) From ASYRCOM' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq '  If dim(VALEND)>=1' Using [SSS_]
    Wrseq '    Call TRACE("               VALEND="+sigma(1,dim(VALEND),chr$(34)+VALEND(indcum)+chr$(34)+string$(indcum<dim(VALEND),","))) From ASYRCOM' Using [SSS_]
    Wrseq '  Else' Using [SSS_]
    Wrseq '    Call TRACE("               dim(VALEND)="+num$(dim(VALEND))) From ASYRCOM' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq Using [SSS_]
    Wrseq '  Call TRACE("               STRICTBEG="+sigma(1,dim(STRICTBEG),num$(STRICTBEG(indcum))+string$(indcum<dim(STRICTBEG),","))) From ASYRCOM' Using [SSS_]
    Wrseq '  Call TRACE("               STRICTEND="+sigma(1,dim(STRICTEND),num$(STRICTEND(indcum))+string$(indcum<dim(STRICTEND),","))) From ASYRCOM' Using [SSS_]
    Wrseq '  Call TRACE("               FIRSTLINE="+num$(FIRSTLINE)) From ASYRCOM' Using [SSS_]
    Wrseq '  Call TRACE("               NBLINES="+num$(NBLINES)) From ASYRCOM' Using [SSS_]
    Wrseq Using [SSS_]
  Endif
  Wrseq Using [SSS_]
  Wrseq '# Check if a data files exist' Using [SSS_]
  Wrseq '# Check also if index files exist, and if at least a header is inside' Using [SSS_]
# Cloud adaptation replace RQT by RQF
  Wrseq "  OK=0" Using [SSS_]
  Wrseq "  CHEMDATA=filpath('RQT',LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL),'req')" Using [SSS_]
  Wrseq '  If filinfo(CHEMDATA,7)<0' Using [SSS_]
  Wrseq '    OK=3 : # No result available' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
# Cloud adaptation replace RQT by RQF
  Wrseq "  CHEMIDX=filpath('RQT',LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL),'idx')" Using [SSS_]
  Wrseq '  If filinfo(CHEMIDX,7)<2*NBHEAD' Using [SSS_]
  Wrseq '    OK=3 : # No result available' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq Using [SSS_]
  If NBLEV>0
    Wrseq '# Perform the same check on the previous level if it exists' Using [SSS_]
    Wrseq '  If LEVEL>1 and IFCUBE=1' Using [SSS_]
# Cloud adaptation replace RQT by RQF
    Wrseq "    CHEMDATAPRE=filpath('RQT',LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL-1),'req')" Using [SSS_]
    Wrseq '    If filinfo(CHEMDATAPRE,7)<0' Using [SSS_]
    Wrseq '      OK=3 :  # No result available' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
# Cloud adaptation replace RQT by RQF
    Wrseq "    CHEMIDXPRE=filpath('RQT',LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL-1),'idx')" Using [SSS_]
    Wrseq '    If filinfo(CHEMIDXPRE,7)<2*NBHEAD' Using [SSS_]
    Wrseq '      OK=3 :  # No result available' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq Using [SSS_]
  Endif
  Wrseq "# If the files don't exist, access temporary file if they exist to get the right error code, then stop" Using [SSS_]
  Wrseq "  If OK=3" Using [SSS_]
  Wrseq "    If IF_CLOUD=0 : End : Endif : # Stop if files don't exist and we are not on the Cloud" Using [SSS_]
  Wrseq "    CHEMDATA=func FILP(1,LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL),'req')" Using [SSS_]
  Wrseq "    If filinfo(CHEMDATA,7)<0" Using [SSS_]
  Wrseq "       End : # No result available and no computation in progress" Using [SSS_]
  Wrseq "    Else   : # A computation is in progress, let's read the information" Using [SSS_]
  Wrseq "      CHEMIDX=func FILP(1,LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL),'idx')" Using [SSS_]
  If NBLEV>0
    Wrseq "      If LEVEL>1 and IFCUBE=1" Using [SSS_]
    Wrseq "        CHEMDATAPRE=func FILP(1,LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL-1),'req')" Using [SSS_]
    Wrseq "        If filinfo(CHEMDATAPRE,7)<0" Using [SSS_]
    Wrseq "          OK=3" Using [SSS_]
    Wrseq "          End" Using [SSS_]
    Wrseq "        Endif" Using [SSS_]
    Wrseq "        CHEMIDXPRE=func FILP(1,LISTE+'_'+string$(USER<>'',USER+'_')+num$(LEVEL-1),'idx')" Using [SSS_]
    Wrseq "        If filinfo(CHEMIDXPRE,7)<2*NBHEAD" Using [SSS_]
    Wrseq "          OK=3" Using [SSS_]
    Wrseq "          End" Using [SSS_]
    Wrseq "        Endif" Using [SSS_]
    Wrseq "      Endif" Using [SSS_]
    Endif
  Wrseq "      Gosub READ_HEADER" Using [SSS_]
  Wrseq "      End" Using [SSS_]
  Wrseq "    Endif" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "# Now read the data" Using [SSS_]
  Wrseq "  Gosub READ_HEADER" Using [SSS_]
  Wrseq "  If OK<>0 : End : Endif" Using [SSS_]
  Wrseq "" Using [SSS_]

# Go to the right place for the index and the data
  Wrseq '  FIRST_SEEK=adxseek("STA")' Using [SSS_]
  Wrseq '  FIRSTLINE=max(FIRSTLINE,1)' Using [SSS_]
  Wrseq '  If FIRSTLINE>1' Using [SSS_]
  Wrseq '    Getseq 1,PAGE Using [STI]' Using [SSS_]
  Wrseq '    If FIRSTLINE>2' Using [SSS_]
  Wrseq '      Seek Curr + (FIRSTLINE-3)*adxseek("STI") Using [STI]' Using [SSS_]
  Wrseq '      Getseq 1,PAGE Using [STI]' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '    Seek First+PAGE Using [STA]' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq Using [SSS_]

  If NBLEV>0
    Wrseq '# If the previous level exists, compute the number of lines of the current level' Using [SSS_]
    If NBLEV>1
      Wrseq '# Compute also the value of the fields at the breaking level' Using [SSS_]
    Endif

    Wrseq '  START_SEEK=adxseek("STA")' Using [SSS_]
    Wrseq '  If LEVEL>1 and IFCUBE=1' Using [SSS_]
    Wrseq '    Rdseq BUFFER Using [STA]' Using [SSS_]
    Wrseq '    Seek First+START_SEEK Using [STA]' Using [SSS_]
    Wrseq '    I=val(func ASYRREQ.GET_PTVAL(BUFFER,"z_m"))' Using [SSS_]
    Wrseq '    If I>=0' Using [SSS_]
    Wrseq '      Rdseq BUFFER Using [STP] : Rdseq BUFFER Using [STP]' Using [SSS_]
    Wrseq '      Rdseq BUFFER Using [STP] : Rdseq BUFFER Using [STP]' Using [SSS_]
    Wrseq '      K=val(BUFFER) : For J=1 To K : Rdseq BUFFER Using [STP] : Next J' Using [SSS_]
    Wrseq '      If I>1' Using [SSS_]
    Wrseq '        Getseq 1,PAGE Using [STJ]' Using [SSS_]
    Wrseq '        If I>2' Using [SSS_]
    Wrseq '          Seek Curr + (I-3)*adxseek("STJ") Using [STJ]' Using [SSS_]
    Wrseq '          Getseq 1,PAGE Using [STJ]' Using [SSS_]
    Wrseq '        Endif' Using [SSS_]
    Wrseq '        Seek First+PAGE Using [STP]' Using [SSS_]
    Wrseq '      Endif' Using [SSS_]
    Wrseq '      # The first line is the starting of the group' Using [SSS_]
    Wrseq '      Rdseq BUFFER Using [STP]' Using [SSS_]
    Wrseq '      FIRST_RECORD=val(func ASYRREQ.GET_PTVAL(BUFFER,"z_p"))' Using [SSS_]
    Wrseq '      # Compute the group value' Using [SSS_]
    Wrseq '      For K=2 To LEVEL' Using [SSS_]
    Wrseq '        Case K' Using [SSS_]
    Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
    I=1
    For [ALD]CLE
      I+=1
      Wrseq '          When '+num$(I) Using [SSS_]
      Wrseq '            VALUE_ZOOM(K-1)=func ASYRREQ.GET_PTVAL(BUFFER,"'+FIELDS([ALD]LIG)+'")' Using [SSS_]
    Next
    Filter [ALD]
    Wrseq '        Endcase' Using [SSS_]
    Wrseq '      Next K' Using [SSS_]
    Wrseq '      Rdseq BUFFER Using [STP]' Using [SSS_]
    Wrseq '      If fstat=0' Using [SSS_]
    Wrseq '        LAST_RECORD=val(func ASYRREQ.GET_PTVAL(BUFFER,"z_p"))-1' Using [SSS_]
    Wrseq '      Else' Using [SSS_]
    Wrseq '        LAST_RECORD=MAXLINES' Using [SSS_]
    Wrseq '      Endif' Using [SSS_]
    Wrseq '    Else' Using [SSS_]
    Wrseq '      OK=7 : End : # Inconsistent data record (no z_p pointer found)' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
    Wrseq '  Else' Using [SSS_]
    Wrseq '    FIRST_RECORD=1 : LAST_RECORD=MAXLINES' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq Using [SSS_]
  Else
    Wrseq '  FIRST_RECORD=1 : LAST_RECORD=MAXLINES' Using [SSS_]
  Endif
  If NBLEV>0
    Wrseq Using [SSS_]
    Wrseq '# If the cube mode is activated, return to the beginning of the page by changing FIRSTLINE' Using [SSS_]
    Wrseq '# Return either to the page from where the zoom was made (STARTIND is null) or to a given page' Using [SSS_]
    Wrseq '  If IFCUBE=1 and ((FIRSTLINE<>FIRST_RECORD) or STARTIND<>0)' Using [SSS_]
    Wrseq '    If STARTIND' Using [SSS_]
    Wrseq '      FIRSTLINE=FIRST_RECORD+(STARTIND-1)' Using [SSS_]
    Wrseq '    Else' Using [SSS_]
    Wrseq '      FIRSTLINE=FIRST_RECORD+int((FIRSTLINE-FIRST_RECORD)/NBLINES)*NBLINES' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
    Wrseq '    Seek First Using [STI]' Using [SSS_]
    Wrseq '    If FIRSTLINE>1' Using [SSS_]
    Wrseq '      Getseq 1,PAGE Using [STI]' Using [SSS_]
    Wrseq '      If FIRSTLINE>2' Using [SSS_]
    Wrseq '        Seek Curr + (FIRSTLINE-3)*adxseek("STI") Using [STI]' Using [SSS_]
    Wrseq '        Getseq 1,PAGE Using [STI]' Using [SSS_]
    Wrseq '      Endif' Using [SSS_]
    Wrseq '      Seek First+PAGE Using [STA]' Using [SSS_]
    Wrseq '    Else' Using [SSS_]
    Wrseq '      Seek First+FIRST_SEEK Using [STA]' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
    Wrseq '  Elsif STARTIND' Using [SSS_]
    Wrseq '    FIRSTLINE=STARTIND' Using [SSS_]
    Wrseq '    Seek First Using [STI]' Using [SSS_]
    Wrseq '    If FIRSTLINE>1' Using [SSS_]
    Wrseq '      Getseq 1,PAGE Using [STI]' Using [SSS_]
    Wrseq '      If FIRSTLINE>2' Using [SSS_]
    Wrseq '        Seek Curr + (FIRSTLINE-3)*adxseek("STI") Using [STI]' Using [SSS_]
    Wrseq '        Getseq 1,PAGE Using [STI]' Using [SSS_]
    Wrseq '      Endif' Using [SSS_]
    Wrseq '      Seek First+PAGE Using [STA]' Using [SSS_]
    Wrseq '    Else' Using [SSS_]
    Wrseq '      Seek First+FIRST_SEEK Using [STA]' Using [SSS_]
    Wrseq '    Endif' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq Using [SSS_]
  Endif
  Wrseq '# Can a previous page be found ?' Using [SSS_]
  Wrseq '  PR=(FIRSTLINE>FIRST_RECORD)*max(FIRST_RECORD,FIRSTLINE-NBLINES)' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Can a next page be found ?' Using [SSS_]
  Wrseq '  NX=(FIRSTLINE+NBLINES<=LAST_RECORD)*(FIRSTLINE+NBLINES)' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Pointer on the last page' Using [SSS_]
  Wrseq '  LS=FIRST_RECORD+NBLINES*int((LAST_RECORD-FIRST_RECORD)/NBLINES)' Using [SSS_]
  Wrseq '  LS*=(LS>FIRSTLINE)' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Complement the prototype and expose parameter values' Using [SSS_]
  Wrseq '  ASND.DATA='+"'"+'{"recordsPerPage":'+"'+num$(NBLINES)+','" Using [SSS_]
  Wrseq '  If PROCESS_ID' Using [SSS_]
  Wrseq '    If filinfo(filpath("RQT",REQUID,"lck"),7)>0' Using [SSS_]
  Wrseq '      BUFFER=func AFNC.MES2(func ASYRREQ.M(LAN,146,25),LISTE,num$(PROCESS_ID))' Using [SSS_]
  Wrseq '    Else' Using [SSS_]
  Wrseq '      BUFFER=func AFNC.MES1(func ASYRREQ.M(LAN,146,26),LISTE)' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    BUFFER=func AFNC.MES5(func ASYRREQ.M(LAN,146,3),LISTE,format$("D:YYYY[-]MM[-]DD",COMPDATE),COMPTIME,' Using [SSS_]
  Wrseq '&   num$(MAXLINES),num$(TIME1+TIME2)-"("+num$(TIME1)+"+"+num$(TIME2)+")")' Using [SSS_]
  Wrseq '    If LIM(1)' Using [SSS_]
  Wrseq '      BUFFER+=", "+func AFNC.MES1(func ASYRREQ.M(LAN,146,22),num$(LIM(1)))' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '    If LIM(2)' Using [SSS_]
  Wrseq '      BUFFER+=", "+func AFNC.MES1(func ASYRREQ.M(LAN,146,23),num$(LIM(2)))' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq Using [SSS_]


  If DEB_UG
    Wrseq "# For debugging purposes" Using [SSS_]
    Wrseq 'BUFFER+=" FIRST_RECORD="+num$(FIRST_RECORD)+" LAST_RECORD="+num$(LAST_RECORD)+" FIRSTLINE="+num$(FIRSTLINE)+" NBLINES="+num$(NBLINES)+" MAXLINES="+num$(MAXLINES)' Using [SSS_]
  Endif

  Wrseq '  If dim(IFLINE)>1 and IFLINE(2)=1 : BUFFER="" : Endif' Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"headerMessage":"'+"'+BUFFER+"+"'"+'",'+"'" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"refreshLink":"'+"'+func ASYRREQ.M(LAN,100,52)+"+"'"+'",'+"'" Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq "  BUFFER=num$(LEVEL)+' / "+num$(NBLEV+1)+"'" Using [SSS_]
  I=0
  Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
  For [ALD]CLE
    I+=1
    Wrseq '  If LEVEL>'+num$(I)+" and IFCUBE=1" Using [SSS_]
    Wrseq '    BUFFER+=" >'+string$(I=1,'>'); Using [SSS_]
    J=find([ALD]LIG,FNUMF(1..NBFIELDS))
    If J=0
      Wrseq ' "+VALUE_ZOOM('+num$(I)+')' Using [SSS_]
    Else
      If FTYPE(J)= func AJSONLIB.TYPZON(8,0)
        Wrseq ' "' Using [SSS_]
        Wrseq '    BUF_DATE=gdat$(val(seg$(VALUE_ZOOM('+num$(I)+'),9,10)),val(seg$(VALUE_ZOOM('
&             +num$(I)+'),6,7)),val(seg$(VALUE_ZOOM('+num$(I)+'),1,4)))' Using [SSS_]
        Wrseq '    BUFFER+="["+format$("DD2",BUF_DATE)+"]"' Using [SSS_]
      Elsif find(FTYPE(J),func AJSONLIB.TYPZON(8,1),func AJSONLIB.TYPZON(8,2))
        Wrseq ' "+func ASYRREQ.M(LAN,'+num$(MENL(J))+',val(VALUE_ZOOM('+num$(I)+')))' Using [SSS_]
      Else
        Wrseq ' "+VALUE_ZOOM('+num$(I)+')' Using [SSS_]
      Endif
    Endif
    Wrseq '  Endif' Using [SSS_]
  Next
  Filter [ALD]

  Wrseq '  Append ASND.DATA,'+"'"+'"levelMessage":"'+"'+escJson(BUFFER)+"+"'"+'",'+"'" Using [SSS_] :#SAM 117767
  Wrseq '  Append ASND.DATA,'+"'"+'"$properties":{"$resources":{"$item":{"$properties":{'+"'" Using [SSS_]

  J=0
  If NBLEV>1
    Wrseq Using [SSS_]
    Wrseq '# Hide the fields according to the level (prototype complement)' Using [SSS_]
    For I=2 To (NBLEV+1) :#SAM 118476
      For K=1 To NBFIELDS
        If FNIV(K)=I & FCUM(K)=0    # Issue X3-46773 - 2017-07-31 by CCC : add FCUM=0 to display accumulations at all levels
          Wrseq "  Append ASND.DATA,'"+string$(J>0,",")+'"'+FIELDS(K)+'":{"$isHidden":'+"'+string$(LEVEL<"+num$(FNIV(K))+",'true')+"; Using [SSS_]
          Wrseq "string$(LEVEL>="+num$(FNIV(K))+",'false')+'}'" Using [SSS_]
          J+=1
        Endif
      Next K
    Next I
  Endif

  Wrseq Using [SSS_]
  Wrseq '# Hide the line_no field according to the options' Using [SSS_]
  Wrseq "  If IFLINE=0" Using [SSS_]
  Wrseq "    Append ASND.DATA,'"+string$(J>0,",")+'"line_no":{"$isHidden":true}'+"'" Using [SSS_]
  Wrseq "  Else" Using [SSS_]
  Wrseq "    Append ASND.DATA,'"+string$(J>0,",")+'"line_no":{"$isHidden":false}'+"'" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]

  Wrseq Using [SSS_]
  If NBLEV>0
    Wrseq '# Add the zooming links' Using [SSS_]
    Wrseq "  Append ASND.DATA,'}'+chr$(10)+'"+',"$links":{'+"'" Using [SSS_]

#{SAM 114121
    Wrseq "  Append ASND.DATA,chr$(10)+'"+'"$refresh":{"url":"'+"'" Using [SSS_]
    Wrseq "  Append ASND.DATA,'"+'{$baseUrl}/QUERY(\"'+LISTE+'\")?representation=QUERY~'+LISTE+'~{level_c}.$query' + "'" Using [SSS_]
    Wrseq "  Append ASND.DATA,'"+
& '&level={level_c}&role={$role}&cube={ifCube}&startRecord={first_record}&view={$clink}&portview={$portview}&recordsPerPage={$itemsPerPage}&forcedExecution=true'+ "'" Using [SSS_]
    Wrseq "  Append ASND.DATA,'"+'&frequency=' +"'+num$(FRQ)+'"+ '"'+ "'" Using [SSS_]
    Wrseq "  Append ASND.DATA,'}," +"'" Using [SSS_]
#SAM 114121}

    Wrseq "  If LEVEL<"+num$(NBLEV+1) Using [SSS_]
    #{SAM 114121  Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillDown":{"$isHidden":false},'+"'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillDown":{"$isHidden":false,' + "'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$type":"application/json;vnd.sage=syracuse",' +"'"  Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$title":"'+"'+func ASYRREQ.M(LAN,146,1)+'"+'",' +"'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"'"+'"'+"+'"+")?representation=QUERY~"+LISTE+"'" Using [SSS_]
    Wrseq "    If LEVEL" Using [SSS_]
    Wrseq "     Append ASND.DATA, "+'"~"+num$(LEVEL+1)' Using [SSS_]:#SAM 118476
    Wrseq "    Endif" Using [SSS_]
    Wrseq "    Append ASND.DATA, "+'".'+FACET+"&startRecord={z_p}"+'"' Using [SSS_]
    Wrseq "    Append ASND.DATA,'&count='+num$(NBLINES)+'&requestID='+"+'"'+"'"+'"+'+"REQUID+"+'"'+"'"+'"' Using [SSS_]
    Wrseq "    Append ASND.DATA,'&displayLineNum='+string$(IFLINE<>0,'true')+string$(IFLINE=0,'false')" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&cube='+string$(IFCUBE<>0,'true')+string$(IFCUBE=0,'false')" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&level='+num$(LEVEL+1)" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&frequency='+num$(FRQ)" Using [SSS_]
    Wrseq "    Append ASND.DATA,'"+'"'+"},'" Using [SSS_]
    #SAM 114121}
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillDown":{"$isHidden":true},'+"'" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If LEVEL>1" Using [SSS_]
    #{SAM 114121 Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillUp":{"$isHidden":false}'+"'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillUp":{"$isHidden":false,' + "'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$type":"application/json;vnd.sage=syracuse",' +"'"  Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$title":"'+"'+func ASYRREQ.M(LAN,146,2)+'"+'",' +"'" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"'"+'"'+"+'"+")?representation=QUERY~"+LISTE+"'" Using [SSS_]
    Wrseq "    If LEVEL" Using [SSS_]
    Wrseq "     Append ASND.DATA, "+'"~"+num$(LEVEL-1)' Using [SSS_]:#SAM 118476
    Wrseq "    Endif" Using [SSS_]
    Wrseq "    Append ASND.DATA, "+'".'+FACET+"&startRecord={z_m}"+'"' Using [SSS_]
    Wrseq "    Append ASND.DATA,'&count='+num$(NBLINES)+'&requestID='+"+'"'+"'"+'"+'+"REQUID+"+'"'+"'"+'"' Using [SSS_]
    Wrseq "    Append ASND.DATA,'&displayLineNum='+string$(IFLINE<>0,'true')+string$(IFLINE=0,'false')" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&cube='+string$(IFCUBE<>0,'true')+string$(IFCUBE=0,'false')" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&level='+num$(LEVEL-1)" Using [SSS_]
    Wrseq "    Append ASND.DATA,'&frequency='+num$(FRQ)" Using [SSS_]
    Wrseq "    Append ASND.DATA,'"+'"'+"}'" Using [SSS_]
    #SAM 114121}
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"$drillUp":{"$isHidden":true}'+"'" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  Append ASND.DATA,'}'" Using [SSS_]
  Else
    Wrseq "  Append ASND.DATA,'}'" Using [SSS_]
  Endif
  Wrseq '  Append ASND.DATA,"}}},"' Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq '# Set the values used for links' Using [SSS_]
# Bug 110848
  Wrseq '  Append ASND.DATA,'+"'"+'"$clink":"'+"'+string$(CALEND<>'','calendar')+"+"'"+'",'+"'" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"$portview":"'+"'+PORTVIEW+"+"'"+'",'+"'" Using [SSS_]
# End bug 110848

# Issue X3-58749 - 2018-02-07 by CCC : add where clause in order to be able to reuse it in refresh
  Wrseq '  Append ASND.DATA,'+"'"+'"$where":"'+"'"+' :  Append ASND.DATA, QWHERE : Append ASND.DATA,'+"'"+'",'+"'" Using [SSS_]

  Wrseq '  Append ASND.DATA,'+"'"+'"req_id":"'+"'+REQUID+"+"'"+'",'+"'" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"level_p":'+"'+num$(min(LEVEL+1,"+num$(NBLEV+1)+"))+','" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"level_c":'+"'+num$(LEVEL)+','" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"level_m":'+"'+num$(max(LEVEL-1,0))+','" Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"first_record":'+"'+num$(FIRST_RECORD)+','" Using [SSS_]
  Wrseq '  If IFLINE' Using [SSS_]
  Wrseq '    Append ASND.DATA,'+"'"+'"displayLineNum":true'+",'" Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    Append ASND.DATA,'+"'"+'"displayLineNum":false'+",'" Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If IFCUBE' Using [SSS_]
  Wrseq '    Append ASND.DATA,'+"'"+'"ifCube":true'+",'" Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    Append ASND.DATA,'+"'"+'"ifCube":false'+",'" Using [SSS_]
  Wrseq '  Endif' Using [SSS_]

  Wrseq Using [SSS_]
# Modification October 22,2014 : calendar prototype insertion
  Wrseq '# Add the calendar prototype if needed' Using [SSS_]
  Wrseq '  If CALEND<>"" : Append ASND.DATA,'+"'"+'"$calendar":{'+"'+CALEND+'},' : Endif" Using [SSS_]
  Wrseq Using [SSS_]
# Modifications done in the management for ASND.MODE for bulk (now done by the send program)
  Wrseq '# Now read the lines' Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"$resources":['+"'" Using [SSS_]
  Wrseq "  If FIRSTLINE<=LAST_RECORD" Using [SSS_]
  Wrseq "    If IFBULK=1" Using [SSS_]
  Wrseq '      For J=1 To min(NBLINES,LAST_RECORD-FIRSTLINE+1)' Using [SSS_]
  Wrseq '        Rdseq BUF Using [STA]' Using [SSS_]
  Wrseq '        Break (fstat<>0)' Using [SSS_]
  Wrseq '        Append ASND.DATA,string$(J>1,",")+chr$(10)' Using [SSS_]
  Wrseq '        Append ASND.DATA,BUF' Using [SSS_]
  Wrseq '        If mod(J,2000)=1 and J>1' Using [SSS_]
  Wrseq '          If ASND.MODE=0 : ASND.MODE=1 :Endif' Using [SSS_]
  Wrseq '          Call SYRSND(ASND) From ASYRCOM' Using [SSS_]
  Wrseq '        Endif' Using [SSS_]
  Wrseq '      Next J' Using [SSS_]
  Wrseq '    Else' Using [SSS_]
  Wrseq '      For J=1 To min(NBLINES,LAST_RECORD-FIRSTLINE+1)' Using [SSS_]
  Wrseq '        Rdseq BUF Using [STA]' Using [SSS_]
  Wrseq '        Break (fstat<>0)' Using [SSS_]
  Wrseq '        Append ASND.DATA,string$(J>1,",")+chr$(10)' Using [SSS_]
  Wrseq '        Append ASND.DATA,BUF' Using [SSS_]
  Wrseq '      Next J' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq '  Append ASND.DATA,"],"' Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq '# Add information for pager' Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"$totalResults":'+"'"+'+num$(LAST_RECORD-FIRST_RECORD+1)+","' Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"$itemsPerPage":'+"'"+'+num$(NBLINES)+","' Using [SSS_]
  Wrseq '  Append ASND.DATA,'+"'"+'"$startIndex":'+"'"+'+num$(FIRSTLINE-FIRST_RECORD+1)+","' Using [SSS_]

# Add the navigation link section according to the lines got
  Wrseq Using [SSS_]
  Wrseq "# Add the navigation link section according to the lines got" Using [SSS_]
  Wrseq "  Append ASND.DATA,chr$(10)+'"+'"$links":{'+"'" Using [SSS_]
  Wrseq "  J=0" Using [SSS_]
  Wrseq '  If CALEND<>"" : Append ASND.DATA,'+"'"+'"Excel":{"$isHidden":true}'+"': J=1 : Endif" Using [SSS_]
  Wrseq '  If NX' Using [SSS_]
  Wrseq "    Append ASND.DATA,string$(J<>0,',')+chr$(10)+'"+'"$next":{"$url":"{$baseUrl}/QUERY'+"'"+'+"'+"('"+LISTE+"')"+'"' Using [SSS_]
  Wrseq "    J=NX" Using [SSS_]
  Gosub WR_URL_LINK From SUBALH11
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If PR' Using [SSS_]
  Wrseq "    Append ASND.DATA,string$(J<>0,',')+chr$(10)+'"+'"$previous":{"$url":"{$baseUrl}/QUERY'+"'"+'+"'+"('"+LISTE+"')"+'"' Using [SSS_]
  Wrseq "    J=PR" Using [SSS_]
  Gosub WR_URL_LINK From SUBALH11
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If LS' Using [SSS_]
  Wrseq "    Append ASND.DATA,string$(J<>0,',')+chr$(10)+'"+'"$last":{"$url":"{$baseUrl}/QUERY'+"'"+'+"'+"('"+LISTE+"')"+'"' Using [SSS_]
  Wrseq "    J=LS" Using [SSS_]
  Gosub WR_URL_LINK From SUBALH11
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If FIRSTLINE>FIRST_RECORD' Using [SSS_]
  Wrseq "    Append ASND.DATA,string$(J<>0,',')+chr$(10)+'"+'"$first":{"$url":"{$baseUrl}/QUERY'+"'"+'+"'+"('"+LISTE+"')"+'"' Using [SSS_]
  Wrseq "    J=FIRST_RECORD" Using [SSS_]
  Gosub WR_URL_LINK From SUBALH11
  Wrseq '  Endif' Using [SSS_]
  Wrseq "  Append ASND.DATA,'}}'" Using [SSS_]
  Wrseq "  Gosub CLOSE_FILES" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '  If ASND.MODE=2 : ASND.MODE=3 : Endif' Using [SSS_]
  Wrseq 'End' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '$NOACCESS:NOACCESS=1:Resume' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Close the files' Using [SSS_]
  Wrseq '$CLOSE_FILES' Using [SSS_]
  Wrseq '  Openi Using [STI]' Using [SSS_]
  Wrseq "  Openi Using [STA]" Using [SSS_]
  If NBLEV>0
    Wrseq "  If LEVEL>1 and IFCUBE=1" Using [SSS_]
    Wrseq "    Openi Using [STP]" Using [SSS_]
    Wrseq "    Openi Using [STJ]" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
  Endif
  Wrseq "Return" Using [SSS_]
  Wrseq Using [SSS_]
    Wrseq Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "# Read the inquiry lines" Using [SSS_]
  Wrseq "# Parameters are the level (LEVEL) and the line number (NUMLIG)" Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "$GET" Using [SSS_]
  Wrseq "Return" Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "#" Using [SSS_]
  Wrseq "# Get the param value types" Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "Subprog GET_PARAMS(PARAM,PARTYPE,MAXLEVEL,IFSHARED)" Using [SSS_]
  Wrseq "Variable Char PARAM()(1..)" Using [SSS_]
  Wrseq "Variable Libelle PARTYPE(1..)" Using [SSS_]
  Wrseq "Variable Integer MAXLEVEL" Using [SSS_]
  Wrseq "Variable Libelle IFSHARED" Using [SSS_]
  I=1
  For [ALD]ALD0 Where COD=LISTE & STREND>=2
    Read [ATY]CODTYP=[ALD]CODTYP
    Wrseq "  PARAM("+num$(I)+")='"+[ALD]FLD+"'" Using [SSS_]
    If [ALD]CODTYP='M' and [ALD]NOLIB=1
      Wrseq "  PARTYPE("+num$(I)+")=13" Using [SSS_]
    Else
      Wrseq "  PARTYPE("+num$(I)+")="+num$([ATY]TYPTYP) Using [SSS_]
    Endif
    I+=1
  Next
  Wrseq "  MAXLEVEL="+num$(NBLEV+1) Using [SSS_]
  Wrseq "  IFSHARED="+num$([F:ALH]ALLUSR) Using [SSS_]
  Wrseq "End" Using [SSS_]
  Wrseq Using[SSS_]

  Wrseq '# Get a pointer value in a buffer' Using [SSS_]
  Wrseq '' Using [SSS_]
  Wrseq 'Subprog PARSE_PARAM(ARCV,VALBEG,VALEND,STRICTBEG,STRICTEND)' Using [SSS_]
  Wrseq 'Variable Instance ARCV Using C_ASYRRCV' Using [SSS_]
  Wrseq 'Variable Char VALBEG()(1..),VALEND()(1..)' Using [SSS_]
  Wrseq 'Variable Libelle STRICTBEG(1..),STRICTEND(1..)' Using [SSS_]
  Wrseq 'Local Integer I' Using [SSS_]
  Wrseq 'Local Char CHAINE1(250),CHAINE2(250)' Using [SSS_]
  I=0
  For [ALD] Where COD=LISTE & STREND>=2
    I+=1
    Read [ATY]CODTYP=[ALD]CODTYP
    If find([ATY]TYPTYP,8,12)
      Wrseq '  CHAINE1=ctrans(func ASYRMAIN.PARVAL(ARCV,"first_'+[ALD]FLD+'"),"@","")' Using [SSS_]
      Wrseq '  CHAINE2=ctrans(func ASYRMAIN.PARVAL(ARCV,"last_'+[ALD]FLD+'"),"@","")' Using [SSS_]
    Else
      Wrseq '  CHAINE1=func ASYRMAIN.PARVAL(ARCV,"first_'+[ALD]FLD+'")' Using [SSS_]
      Wrseq '  CHAINE2=func ASYRMAIN.PARVAL(ARCV,"last_'+[ALD]FLD+'")' Using [SSS_]
    Endif
    Wrseq '  If CHAINE1<>"" : VALBEG('+num$(I)+')=CHAINE1 : STRICTBEG('+num$(I)+')=1 : Endif' Using [SSS_]
    Wrseq '  If CHAINE2<>"" : VALEND('+num$(I)+')=CHAINE2 : STRICTEND('+num$(I)+')=1 : Endif' Using [SSS_]
  Next
  Wrseq 'End' Using [SSS_]

  Wrseq "" Using [SSS_]
  Wrseq 'Funprog GET_MAINTABLE()' Using [SSS_]
  Wrseq 'End "' + LNKTBL +'"' Using [SSS_]
  Wrseq "" Using [SSS_]

  Wrseq '# Sub-program used to read the header on the final or temporary file (Cloud adaptation)' Using [SSS_]
  Wrseq '$READ_HEADER' Using [SSS_]
  Wrseq '# Open the files' Using [SSS_]
  Wrseq '  Onerrgo NOACCESS' Using [SSS_]
  Wrseq '  Openi CHEMIDX,0 Using [STI]' Using [SSS_]
  Wrseq '  If NOACCESS : OK=4 : Return : Endif : # Access error' Using [SSS_]
  Wrseq "  Openi CHEMDATA Using [STA]" Using [SSS_]
  Wrseq '  If NOACCESS : OK=4 : Openi Using [STI] : Return : Endif : # Access error' Using [SSS_]
  If NBLEV>0
    Wrseq Using [SSS_]
    Wrseq '# Open the previous level files' Using [SSS_]
    Wrseq "  If LEVEL>1 and IFCUBE=1" Using [SSS_]
    Wrseq "    Openi CHEMDATAPRE Using [STP]" Using [SSS_]
    Wrseq '    If NOACCESS : OK=4 : Openi Using [STI] : Openi Using [STA] : Return : Endif : # Access error' Using [SSS_]
    Wrseq "    Openi CHEMIDXPRE Using [STJ]" Using [SSS_]
    Wrseq '    If NOACCESS : OK=4 : Openi Using [STI] : Openi Using [STA] : Openi Using [STP] : Return : Endif : # Access error' Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
  Endif
  Wrseq '  Onerrgo' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Set the right separators for reading the data' Using [SSS_]
  Wrseq "  Iomode adxifs '' Using [STA]" Using [SSS_]
  Wrseq "  Iomode adxirs chr$(10) Using [STA]" Using [SSS_]
  Wrseq "  Iomode adxium 0 Using [STA] : # Corresponds to UTF8 format" Using [SSS_]
  If NBLEV>0
    Wrseq "  If LEVEL>1 and IFCUBE=1" Using [SSS_]
    Wrseq "    Iomode adxifs '' Using [STP]" Using [SSS_]
    Wrseq "    Iomode adxirs chr$(10) Using [STP]" Using [SSS_]
    Wrseq "    Iomode adxium 0 Using [STP] : # Corresponds to UTF8 format" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
  Endif
  Wrseq Using [SSS_]
  Wrseq '# Read the header' Using [SSS_]
  Wrseq '  Rdseq BUFFER Using [STA]' Using [SSS_]
  Wrseq '  Rdseq BUFFER Using [STA]' Using [SSS_]
  If [ALH]ALLUSR<>2
    Wrseq '  BUFFER=right$(BUFFER,2+len(vireblc(BUFFER,3)))' Using [SSS_]
  Endif
  Wrseq Using [SSS_]
  Wrseq '# Date and time of computation' Using [SSS_]
  Wrseq '  COMPDATE=gdat$(val(mid$(BUFFER,6,2)),find(mid$(BUFFER,9,3),"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"),val(mid$(BUFFER,13,4)))' Using [SSS_]
  Wrseq '  COMPTIME=mid$(BUFFER,18,8)' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# COMPDATETIME is now always set at minimum with the timestamp of validation' Using [SSS_]
  Wrseq '# Return an error if computation must be reexecuted' Using [SSS_]
  Wrseq '  COMPDATETIME=max(COMPDATETIME,TIME_UPD)' Using [SSS_]
  Wrseq '  If ((((((COMPDATE-[1/1/1970])*24+val(mid$(COMPTIME,1,2)))*60)+val(mid$(COMPTIME,4,2)))*60)+val(mid$(COMPTIME,7,2)))*1000 < COMPDATETIME' Using [SSS_]
  Wrseq '    OK=3 : # No result available' Using [SSS_]
  Wrseq '    Gosub CLOSE_FILES' Using [SSS_]
  Wrseq '    Return' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq '# Check the criteria value' Using [SSS_]
  Wrseq '  Rdseq BUFFER Using [STA]' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Compute the number of lines of the level' Using [SSS_]
  Wrseq '  MAXLINES=val(left$(BUFFER,8))' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Get the timing information' Using [SSS_]
  Wrseq '  TIME1=val(mid$(BUFFER,56,12))' Using [SSS_]
  Wrseq '  TIME2=val(mid$(BUFFER,69,12))' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Get the limit information' Using [SSS_]
  Wrseq '  LIM(1)=val(mid$(BUFFER,82,8))' Using [SSS_]
  Wrseq '  LIM(2)=val(mid$(BUFFER,90,8))' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Get the process id (if not null, the request is still running)' Using [SSS_]
  Wrseq '  PROCESS_ID=val(mid$(BUFFER,47,8))' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Check the parameter values' Using [SSS_]
  Wrseq '  If REQUID<>""' Using [SSS_]
  Wrseq '    If REQUID<>mid$(BUFFER,10,36)' Using [SSS_]
  Wrseq '      Gosub CLOSE_FILES' Using [SSS_]
  Wrseq '      OK=6 : Return : # The last request was required, but it has been recomputed since the last time' Using [SSS_]
  Wrseq '    Else' Using [SSS_]
  Wrseq '      Rdseq BUFFER Using [STA]' Using [SSS_]
  Wrseq '      K=val(BUFFER)' Using [SSS_]
  Wrseq '      For I=1 To K : Rdseq BUFFER Using  [STA] : Next I' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    REQUID=mid$(BUFFER,10,36)' Using [SSS_]
  Wrseq '    Gosub EVAL_CRIT' Using [SSS_]
  Wrseq '    Rdseq BUFFER Using [STA]' Using [SSS_]
  Wrseq '    # If the number of lines of criteria value does not fit, stop' Using [SSS_]
  Wrseq '    If val(BUFFER)<>K-1' Using [SSS_]
  Wrseq '      Gosub CLOSE_FILES' Using [SSS_]
  Wrseq '      OK=5 : Return : # The criteria don'+"'"+'t fit, see later how to bring the right error message' Using [SSS_]
  Wrseq '    Endif' Using [SSS_]
  Wrseq '    For I=1 To K-1' Using [SSS_]
  Wrseq '      Rdseq BUFFER Using [STA]' Using [SSS_]
  Wrseq '      If BUFFER<>CRITERE(I)' Using [SSS_]
  Wrseq '      Gosub CLOSE_FILES' Using [SSS_]
  Wrseq '        OK=5 : Return : # The criteria don'+"'"+'t fit, see later how to bring the right error message' Using [SSS_]
  Wrseq '      Endif' Using [SSS_]
  Wrseq '    Next I' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  Return' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "Funprog FILP(IF_CLOUD,FILEN,EXTENS)" Using [SSS_]
  Wrseq "Value Integer IF_CLOUD" Using [SSS_]
  Wrseq "Value Char FILEN(),EXTENS()" Using [SSS_]
  Wrseq "Local Integer I" Using [SSS_]
  Wrseq "Local Char X3FOLDER(100)" Using [SSS_]
  Wrseq '   I = func ASYRFNC.CREATE_DIRECTORY(filpath("RQT","",""))' Using [SSS_]    # X3-49112 : In case of RQT directory doesn't exist
  Wrseq '   I = 0' Using [SSS_]
  Wrseq '   If IF_CLOUD=0 : End filpath("RQT",FILEN,EXTENS) : Endif' Using [SSS_]
  Wrseq "   Repeat X3FOLDER=nomap(I) : I+=1 : Until nomap(I)=''" Using [SSS_]
  Wrseq "End filpath('RQT',nomap+'_'+FILEN,EXTENS,X3FOLDER)" Using [SSS_]
  Wrseq Using [SSS_]

Return

$CORPS_PROTO
# PROTO JSON subprog generation
  Gosub JPRO_HEAD_GEN From AJSONLIB

# Miscellaneous declaration
  Wrseq Using [SSS_]
  Wrseq "# Miscellaneous declarations" Using [SSS_]
  Wrseq "Local Char LISTE1(20) : LISTE1="+'"'+LISTE+'"' Using [SSS_]
  Wrseq "Local Char LISTE2(20) : LISTE2="+'"'+"'"+LISTE+"'"+'"' Using [SSS_]
  Wrseq "Local Char L(10) : L=ACTX.LAN : L+=string$(L='',GACTX.LAN) : L+=string$(L='','ENG')" Using [SSS_]
  Wrseq "Local Char DOL_KEY(10)(1..2) : DOL_KEY(1)="+'"'+"'{"+'" : DOL_KEY(2)='+'"'+"}'"+'"' Using [SSS_]
  Wrseq "Local Integer NB_FLD, NUMLEVEL, IML" Using [SSS_]
  Wrseq "Local Char SEPRES(1)" Using [SSS_] :#SAM 119246

  Wrseq Using [SSS_]
  Wrseq "  NUMLEVEL=min(val(LEVEL_NUM),"+num$(NBLEV+1)+")" Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "# Fixing a bug related to base url for classic page Sept 22, 2014" Using [SSS_]
  Wrseq 'Local Char TRANSURL(250)' Using [SSS_]
  Wrseq 'Local Integer I' Using [SSS_]
  Wrseq '  I=instr(1,PSYR.PREFIX,"/sdata/")' Using [SSS_]
  Wrseq '  If I' Using [SSS_]
  Wrseq '    TRANSURL=left$(PSYR.PREFIX,I-1)+"/trans/"+right$(PSYR.PREFIX,8)' Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    TRANSURL=PSYR.PREFIX : # What else ?' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq '' Using [SSS_]

# Init
  NBP=-1 : Gosub PRO_GEN From AJSONLIB

# Base URL and computed formula because simple quotes are nested in double quotes
  PRF="{"
  #SAM 110141 NBP+=1 : PRO(NBP)="$baseUrl" : TYP(NBP)=4 : VLE(NBP)="PSYR.PREFIX"
  NBP+=1 : PRO(NBP)="$baseUrl" : TYP(NBP)=4 : VLE(NBP)="baseUrl"
  NBP+=1 : PRO(NBP)="$baseTrans" : TYP(NBP)=4 : VLE(NBP)="TRANSURL"
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/QUERY("+toupper(LISTE2)+")?representation=QUERY~"+LISTE1+".'+FACET+'&role={$role}"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

# Title and type
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"ALISTEH","'+LISTE+'","INTIT",0)'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$type" : TYP(NBP)=4
  VLE(NBP)='"application/json; vnd.sage=syracuse.representation={$baseUrl}/QUERY("+toupper(LISTE1)+")"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$methods" : TYP(NBP)=3 : VLE(NBP)="GET"
  NBP+=1 : PRO(NBP)="codeRequest" : VLE(NBP)=LISTE
  NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="Excel" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$title" : VLE(NBP)="Excel"
  POF=","
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="$type"
  VLE(NBP)='application/syracuse-excel-worksheet'
  POF=","
  Gosub PRO_GEN From AJSONLIB
  #{ SAM  10966
  NBP+=1 : PRO(NBP) = '$confirm'
  VLE(NBP) = mess(236,124,1)
  POF=","
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP) = '$officeAddinSetup'
  VLE(NBP) = "/msoffice/lib/general/addIn/SyracuseOfficeAddinsSetup.EXE"
  POF=","
  Gosub PRO_GEN From AJSONLIB
  #SAM 10966 }
  Wrseq " If NUMLEVEL" Using [SSS_]
  APWCB="  "+APWCB : # Let's indent
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/QUERY("+toupper(LISTE2)+")?representation=QUERY~"+LISTE1+"~"+num$(NUMLEVEL)+".'+"$bulk"+
& '&level="+num$(NUMLEVEL)+"&role={$role}&cube={ifCube}&startRecord={first_record}&excelReportMode={excelReportMode}"'
 POF="," : # should not be a comment if PDF printing is present :#SAM 107682/114121
#SAM 107682/114121  POF="}}," : # should be a comment if PDF printing is present
  Gosub PRO_GEN From AJSONLIB
  Wrseq " Else" Using [SSS_]
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/QUERY("+toupper(LISTE2)+")?representation=QUERY~"+LISTE1+".'+"$bulk"+
& '&role={$role}&cube={ifCube}&startRecord={first_record}&excelReportMode={excelReportMode}"'
  POF="," : # should not be a comment if PDF printing is present :#SAM 107682/114121
  #SAM 107682/114121 POF="}}," : # should be a comment if PDF printing is present
  Gosub PRO_GEN From AJSONLIB
  Wrseq " Endif" Using [SSS_]


  NBP+=1 : PRO(NBP)="$parameters" : TYP(NBP)=5
  # Issue X3-53685 - 2017-09-19 by CCC : change "$query" by "$edit"
  #NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='collaborationBaseUrl+"/msoExcelReportModes/$template/$workingCopies?representation=msoExcelReportMode.$query'
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='collaborationBaseUrl+"/msoExcelReportModes/$template/$workingCopies?representation=msoExcelReportMode.$edit'
&  + '&role={$role}&where={$where}&filter={$filter}&excelReportMode={excelReportMode}&doc_uuid={document}"'

 NBP+=1 : PRO(NBP)="$method" : VLE(NBP)="POST"
 NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5
 NBP+=1 : PRO(NBP)="$title" : VLE(NBP)="dummy"
 NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
  POF="}}},"
  Gosub PRO_GEN From AJSONLIB

  APWCB=right$(APWCB,3) : # End of indentation

  #{SAM 107682/114121
  # Refresh action :
  NBP+=1 : PRO(NBP)="$refresh" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB
  #114799 : mess(36,146,1)
  NBP+=1 : PRO(NBP)="$title" : VLE(NBP)=mess(37,146,1)

  # Modification done SAM 110848 : refresh URL must take in account portview and view values
  # Modification done SAM 111929 : add a recordsPerPage option in the link by using$itemsPerPage value
  # AJSONLIB cannot be used because the url is too long
 Wrseq APWCB+'"$url":"'+  "'" Using [SSS_]
 Wrseq APWCB+'{$baseUrl}/QUERY('+"'+toupper(LISTE2)+'"+')?representation=QUERY~'+"'+LISTE1+'"+'~{level_c}.$query' + "'" Using [SSS_]
 Wrseq APWCB+'&level={level_c}&role={$role}&cube={ifCube}&startRecord={first_record}&view={$clink}&portview={$portview}&recordsPerPage={$itemsPerPage}&forcedExecution=true&where={$where}'+ "'"
&  Using [SSS_]
 Wrseq APWCB+'",' + "'" Using [SSS_]

  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
  POF="}}," : Gosub PRO_GEN From AJSONLIB
  #SAM 107682/114121}

  # All the following lines should not be a comment if PDF printing is present
  # For the moment, print is no more a choice
  # NBP+=1 : PRO(NBP)="Print" : TYP(NBP)=5
  # NBP+=1 : PRO(NBP)="$title" : VLE(NBP)="Print"
  # NBP+=1 : PRO(NBP)="$type" : VLE(NBP)='application/pdf'
  # POF=","
  # Gosub PRO_GEN From AJSONLIB

  # Wrseq " If NUMLEVEL" Using [SSS_]
  # APWCB="  "+APWCB : # Let's indent
  # NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/QUERY("+toupper(LISTE2)+")?representation=QUERY~"+LISTE1+"~"+num$(NUMLEVEL)+".'+FACET+'&level="+num$(NUMLEVEL)+"&role={$role}"'
  # POF="}},"
  # Gosub PRO_GEN From AJSONLIB
  # Wrseq " Else" Using [SSS_]
  # NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/QUERY("+toupper(LISTE2)+")?representation=QUERY~"+LISTE1+".'+FACET+'&role={$role}"'
  # POF="}},"
  # Gosub PRO_GEN From AJSONLIB
  # Wrseq " Endif" Using [SSS_]
  # APWCB=right$(APWCB,3) : # End of indentation
  # End of PDF printing comments

  NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$criteria" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-filter"
  NBP+=1 : PRO(NBP)="$item" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

# Parameters
  J=0
  For I=1 To NBFIELDS
    If FRANGE(I)
      J+=1
      PRF=string$(J>1,",")
      NBP+=1 : PRO(NBP)=FIELDS(I) : TYP(NBP)=5
      POF="}"
      Gosub PRO_GEN From AJSONLIB
    Endif
  Next I

  For CHAINE="displayLineNum","recordsPerPage","req_id","ifCube"
    PRF=string$(J<>0,",")
    J+=1
    NBP+=1 : PRO(NBP)=CHAINE : TYP(NBP)=5
    POF="}"
    Gosub PRO_GEN From AJSONLIB
  Next

# Fix October 8, 2015 to enhance the space occupation when a graph is sent
  POF="}}," : # Replace the next line
# POF="}}}," : # Line
  Gosub PRO_GEN From AJSONLIB

# Add isExcluded(Fix October 8, 2015)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
# End of fix October 8, 2015

# Header line
  NBP+=1 : PRO(NBP)="headerMessage" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func ASYRREQ.M(L,146,4)"
  NBP+=1 : PRO(NBP)="$isAdvanced" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Header line
  NBP+=1 : PRO(NBP)="levelMessage" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func ASYRREQ.M(L,146,29)"
  NBP+=1 : PRO(NBP)="$isAdvanced" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Hidden parameters for links
  NBP+=1 : PRO(NBP)="displayLineNum" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(1,1)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="recordsPerPage" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(3,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="req_id" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="first_record" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(3,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="ifCube" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(1,1)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="level_p" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="level_c" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="level_m" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Addition in prototypes for portal views and calendars
  NBP+=1 : PRO(NBP)="$portview" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="$calendar" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="$clink" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(7,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB


# Grid of results
  NBP+=1 : PRO(NBP)="$resources" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-array"
  NBP+=1 : PRO(NBP)="$item" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

# The technical fields : line_no first with links
# Bug fixed March 27 2014: line_no must not be excluded from authoring
  Wrseq ' If TYPE_REPRES<>"$bulk"' Using [SSS_]
  APWCB="  "+APWCB : # Let's indent
  NBP+=1 : PRO(NBP)="line_no" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func ASYRREQ.M(L,146,5)"
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(3,0)
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Technical fields for the links
  NBP+=1 : PRO(NBP)="z_p" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(3,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="z_m" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.TYPZON(3,0)
  NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
  #{SAM 112022
  POF="}"
  #}SAM  112022
  Gosub PRO_GEN From AJSONLIB
  Wrseq '  SEPRES=","' Using [SSS_] :#SAM 119246
  Wrseq ' Endif' Using [SSS_]
  APWCB=right$(APWCB,3) : # End of indentation

# The fields
 Local Char IDENTRES(3) :#SAM 119246
  #SAM 119246 Wrseq " NB_FLD=0" Using [SSS_]
  For I=1 To NBFIELDS
    If FNIV(I)>1 and FCUM(I)=0
      Wrseq " If NUMLEVEL=0 or NUMLEVEL>="+num$(FNIV(I)) Using [SSS_]:#SAM 118476
      #Wrseq " If NUMLEVEL=0 or NUMLEVEL<"+num$(FNIV(I)) Using [SSS_] :#SAM 114121
      APWCB="  "+APWCB : # Let's indent
      IDENTRES = "  ":#SAM 119246
    Endif
    #{SAM 112022
#    SAM 119246 If I>1
#     Wrseq space$(2*(FNIV(I)>1 and FCUM(I)=0))+" If NB_FLD : Append WCLOB,',' : Endif" Using [SSS_]
#    Else
#     Wrseq ' If TYPE_REPRES<>"$bulk"' Using [SSS_]
#     Wrseq " Append WCLOB,','" Using [SSS_]
#     Wrseq ' Endif' Using [SSS_]
#    Endif
#   Wrseq space$(2*(FNIV(I)>1 and FCUM(I)=0))+" NB_FLD += 1" Using [SSS_]
    #}SAM  112022
    Wrseq IDENTRES+' Append WCLOB,SEPRES: SEPRES="," '  Using [SSS_] :#SAM 119246
    Raz IDENTRES:#SAM 119246
    NBP+=1 : PRO(NBP)=FIELDS(I) : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"ALISTED","'+LISTE+'","INTITLIG",'+num$(FTEX(I))+')'
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=FTYPE(I)
    If FTYPE(I)="application/x-string"
      NBP+=1 : PRO(NBP)="$maxLength" : TYP(NBP)=2 : VLE(NBP)=num$(FLEN(I))

      # Modification done SAM 111929 October 21,2015 to handle special formats (email, phones)
      If FFIELDS(I)>1
        NBP+=1 : PRO(NBP)="$format" : VLE(NBP)=mess(FFIELDS(I),7880,1)
        If VLE(NBP) = "TT" : VLE(NBP)="application/x-time" : Endif :#SAM 118859
      Endif

      POF=""
#   Modification October 22,2014 : handle the uuid data type in a query as a 36 character string
    Elsif FTYPE(I)="application/x-uuid"
      VLE(NBP)="application/x-string"
      NBP+=1 : PRO(NBP)="$maxLength" : TYP(NBP)=2 : VLE(NBP)="36"
      POF=""
    Elsif FTYPE(I)="application/x-decimal"
      # Fix on precision and scale for requests where the length and type is not defined in type Sept 16, 2014
      Call LNG3(FTYPA(I),FLEN(I),FORM,SCALE,PRECISION) From SUBALH11A
      NBP+=1 : PRO(NBP)="$format" : VLE(NBP)=FORM
      NBP+=1 : PRO(NBP)="$precision" : VLE(NBP)=num$(PRECISION) : TYP(NBP)=2
      NBP+=1 : PRO(NBP)="$scale" : VLE(NBP)=num$(SCALE) : TYP(NBP)=2
    Elsif FTYPE(I)="application/x-integer"
      NBP+=1 : PRO(NBP)="$format" : VLE(NBP)="#,###"
      NBP+=1 : PRO(NBP)="$precision" : VLE(NBP)=num$(int(FLEN(I))) : TYP(NBP)=2
    Elsif FTYPE(I)="application/x-choice"
      NUMLOC=MENL(I)
      Gosub MEN_GEN From AJSONLIB
    Endif
    If FTUN(I)<>""
      POF+=","
      Gosub PRO_GEN From AJSONLIB
      NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.M(L,124,31)'
      NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
      NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4
 #    Fixes on Classic pages links with $baseTrans variable sent back from prototype (Dom, Sept 22, 2014)
      If left$(FTUN(I),1)="~"
        #VLE(NBP)='"{$baseTrans}/$sessions?f='+right$(FTUN(I),2)+'/2//M/{'+FIELDS(I)+string$(FTUN1(I)<>"","}~{"+FTUN1(I))+'}"'
        VLE(NBP)='"{$baseTrans}/$sessions?f='+right$(FTUN(I),2)+'/2//M/'+FNCKEY(I)+string$(FTUN1(I)<>"","~{"+FTUN1(I)+'}')+'"' :#SAM 116052
      Else
        VLE(NBP)='"{$baseUrl}/'+FTUN(I)+'("+DOL_KEY(1)+"'+string$(FTUN1(I)<>"",FTUN1(I)+"~")+FIELDS(I)+'"+DOL_KEY(2)+")?representation='+FTUN(I)+'.$details"'
      Endif
      NBP+=1 : PRO(NBP)="$target" : TYP(NBP)=4 : VLE(NBP)='"main"'
      POF="}}"
    Endif
    POF+="}": # +string$(I<NBFIELDS,",")
    Gosub PRO_GEN From AJSONLIB
    If FNIV(I)>1 and FCUM(I)=0
      Wrseq " Endif" Using [SSS_]
      APWCB=right$(APWCB,3) : # End of indentation
    Endif
  Next I
  POF="}" : Gosub PRO_GEN From AJSONLIB

  If NBLEV>0
    PRF=","
    NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB

    Wrseq " If NUMLEVEL=0 or val(LEVEL_NUM)=99" Using [SSS_]
    APWCB="  "+APWCB
    NBP+=1 : PRO(NBP)="$drillDown" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"')?representation=QUERY~"+LISTE+'"+string$(val(LEVEL_NUM)=99,"~99")+".'+FACET+"&startRecord={z_p}"+'"' Using [SSS_]
    Wrseq " Elsif NUMLEVEL<"+num$(NBLEV+1) Using [SSS_]
    NBP+=1 : PRO(NBP)="$drillDown" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"')?representation=QUERY~"+LISTE+"~"+'"+num$(NUMLEVEL+1)+".'+FACET+"&startRecord={z_p}"+'"' Using [SSS_]
    Wrseq " Endif" Using [SSS_]
    Wrseq " If NUMLEVEL=0 or NUMLEVEL<"+num$(NBLEV+1)+" or val(LEVEL_NUM)=99" Using [SSS_]
    Wrseq APWCB+'&displayLineNum={displayLineNum}&cube={ifCube}'+"'" Using [SSS_]
    Wrseq APWCB+'&count={recordsPerPage}&requestID='+"'"+'+"'+"'{req_id}'"+'"'+"+'&level={level_p}'"+'+'+"'"+'",'+"'" Using [SSS_]
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func ASYRREQ.M(L,146,1)"
    POF="}"
    Gosub PRO_GEN From AJSONLIB
    Wrseq '    Append WCLOB,string$(NUMLEVEL<>1,",")' Using [SSS_]
    Wrseq "  Endif" Using [SSS_]

    Wrseq " If NUMLEVEL=0" Using [SSS_]
    NBP+=1 : PRO(NBP)="$drillUp" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"')?representation=QUERY~"+LISTE+"."+FACET+"&startRecord={z_m}"+'"' Using [SSS_]
    Wrseq " Elsif NUMLEVEL>1" Using [SSS_]
    NBP+=1 : PRO(NBP)="$drillUp" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    Wrseq "   If val(LEVEL_NUM)=99" Using [SSS_]
    Wrseq "  "+APWCB+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"')?representation=QUERY~"+LISTE+"~99."+FACET+"&startRecord={z_m}"+'"' Using [SSS_]
    Wrseq "   Else" Using [SSS_]
    Wrseq "  "+APWCB+'"$url":"{$baseUrl}/QUERY('+"'+"+'"'+"'"+LISTE+"')?representation=QUERY~"+LISTE+"~"+'"+num$(NUMLEVEL-1)+".'+FACET+"&startRecord={z_m}"+'"' Using [SSS_]
    Wrseq "   Endif" Using [SSS_]
    Wrseq " Endif" Using [SSS_]
    Wrseq " If NUMLEVEL<>1" Using [SSS_]
    Wrseq APWCB+'&displayLineNum={displayLineNum}&cube={ifCube}'+"'" Using [SSS_]
    Wrseq APWCB+'&count={recordsPerPage}&requestID='+"'"+'+"'+"'{req_id}'"+'"'+"+'&level={level_m}'"+'+'+"'"+'",'+"'" Using [SSS_]
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func ASYRREQ.M(L,146,2)"
    POF="}"
    Gosub PRO_GEN From AJSONLIB
    Wrseq " Endif" Using [SSS_]
    APWCB=right$(APWCB,3) : # End of indentation
    POF="}"
    Gosub PRO_GEN From AJSONLIB
  Endif

  POF="}"
  Gosub PRO_GEN From AJSONLIB

# A cube is generated only if the condition occurs:
# at least one cumulated value must exist
# The cube is sent only if level is not equal to 0
#SAM 114026 : [F:ALH]REPGRA must be different to 1 (text)
  Filter [ALD] Where COD=LISTE & CUM=2
  If rowcount([ALD])<>0
    Wrseq " If NUMLEVEL and"-num$([F:ALH]REPGRA )-"<> 1" Using [SSS_] #SAM 114026
    APWCB=space$(2)+APWCB
    PRF=","
    NBP+=1 : PRO(NBP)="$cube" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$mode" : VLE(NBP)="table"
#   NBP+=1 : PRO(NBP)="$title" : VLE(NBP)=escJson(DESAX)
    NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.T(L,"ALISTEH","'+[ALH]COD+'","INTIT",0)' : TYP(NBP)=4
    NBP+=1 : PRO(NBP)="$hierarchies" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB

    I=0
#    CODE DEACTIVATED : SEE IF THIS CAN BE DONE LATER (MANAGEMENT OF TITLE DEFINED IN GRAPHICAL SERIES) BUT MUST ALSO BE DONE FOR AXES !!!
#    If [ALH]REPGRA>=2
#      Filter [ALD] Where GRA=3
#      Wrseq " Case NUMLEVEL" Using [SSS_]
#      APWCB=space$(4)+APWCB
#      For [ALD]
#        I+=1
#        Wrseq "   When "+string$(I=1,"0,")+num$(I) Using [SSS_]
#        NBP+=1 : PRO(NBP)=FIELDS([ALD]LIG) : TYP(NBP)=5
#        NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.T(L,"ALISTED","'+[ALH]COD+'","INTITLIG",'+num$([ALD]LIG)+')' : TYP(NBP)=4
#        NBP+=1 : PRO(NBP)="$properties" : VLE(NBP)='[' : TYP(NBP)=5
#        Gosub PRO_GEN From AJSONLIB
#        Wrseq APWCB+'"'+FIELDS([ALD]LIG)+'"]}'+"'" Using [SSS_]
#        Break
#      Next
#    Endif
    If I=0
      Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
      Wrseq "   Case NUMLEVEL" Using [SSS_]
      APWCB=space$(4)+APWCB
#     I=0
      For [ALD]CLE
        I+=1
        Wrseq "     When "+string$(I=1,"0,")+num$(I) Using [SSS_]
        NBP+=1 : PRO(NBP)=FIELDS([ALD]LIG) : TYP(NBP)=5
        NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.T(L,"ALISTED","'+[ALH]COD+'","INTITLIG",'+num$([ALD]LIG)+')' : TYP(NBP)=4
        NBP+=1 : PRO(NBP)="$properties" : VLE(NBP)='[' : TYP(NBP)=5
        Gosub PRO_GEN From AJSONLIB
        Wrseq APWCB+'"'+FIELDS([ALD]LIG)+'"]}'+"'" Using [SSS_]
      Next
      Filter [ALD]

      Wrseq "     When "+num$(NBLEV+1) Using [SSS_]
      NBP+=1 : PRO(NBP)="line_no" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.M(L,146,5)' : TYP(NBP)=4
      NBP+=1 : PRO(NBP)="$properties" : VLE(NBP)='[' : TYP(NBP)=5
      Gosub PRO_GEN From AJSONLIB
      Wrseq APWCB+'"line_no"]}'+"'" Using [SSS_]
    Endif
    Wrseq "   Endcase" Using [SSS_]
    APWCB=right$(APWCB,5)
    PRF="},"
    NBP+=1 : PRO(NBP)="$measures" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB

    Filter [ALD] Where COD=LISTE & CUM=2 Order By Key CLE=COD;NIV;LIG
    I=0
    For [ALD]CLE
      Wrseq APWCB+string$(I,",")+'"'+FIELDS([ALD]LIG)+'":{}'+"'" Using [SSS_]
      I=1
    Next
    Filter [ALD]

    PRF="}},"
    NBP+=1 : PRO(NBP)="$axes" : VLE(NBP)='[' : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB

    Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
    Wrseq "   Case NUMLEVEL" Using [SSS_]
    APWCB=space$(4)+APWCB
    I=0
    For [ALD]CLE
      I+=1
      Wrseq "     When "+string$(I=1,"0,")+num$(I) Using [SSS_]
      PRF="{"
      NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.T(L,"ALISTED","'+[ALH]COD+'","INTITLIG",'+num$([ALD]LIG)+')' : TYP(NBP)=4
      NBP+=1 : PRO(NBP)="$hierarchies" : VLE(NBP)='[[' : TYP(NBP)=5
      Gosub PRO_GEN From AJSONLIB
      POF='"'+FIELDS([ALD]LIG)+'"'+"]]}"
      Gosub PRO_GEN From AJSONLIB
    Next
    Filter [ALD]
    Wrseq "     When "+num$(NBLEV+1) Using [SSS_]
    PRF="{"
    NBP+=1 : PRO(NBP)="$title" : VLE(NBP)='func ASYRREQ.M(L,146,5)' : TYP(NBP)=4
    NBP+=1 : PRO(NBP)="$hierarchies" : VLE(NBP)='[[' : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    POF='"line_no"'+"]]}"
    Gosub PRO_GEN From AJSONLIB
    Wrseq "   Endcase" Using [SSS_]
    APWCB=right$(APWCB,5)
    PRF=",{"
    NBP+=1 : PRO(NBP)="$title" : VLE(NBP)="$measures"
    NBP+=1 : PRO(NBP)="$hierarchies" : VLE(NBP)="[[" : TYP(NBP)=5
    Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB+'"$measures"]]}]'+"'" Using [SSS_]
    Wrseq " Endif" Using [SSS_]
  Endif
  APWCB=right$(APWCB,3)
  Filter [ALD]

  Wrseq " Append WCLOB,'}}}'" Using [SSS_]
  Wrseq "End" Using [SSS_]

Return

