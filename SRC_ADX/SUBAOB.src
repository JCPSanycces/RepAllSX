#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AOB",GBIDC1,GBIDC2) From GOBJET
End

############################################################
$ACTION
Case GACTION
 When "AOBVER"
  Case ACTION
   When "DEBUT"        : Gosub DEBUT
   When "OUVRE"        : Gosub OUVRE
  Endcase
 When  Default
  If dim([L]PSUBAOB)<=0
   Local Integer PSUBAOB
   Call EXISTE_ADX("","","SUBAOBB",PSUBAOB) From ORDSYS
  Endif
  Case ACTION
   When "FERME"        : Gosub FERME
   When "LIENS"        : Gosub LIENS
   When "INICRE"       : Gosub INICRE
   When "INIMOD"       : Gosub INIMOD
   When "SETBOUT"      : Gosub SETBOUT
   When "EXEBOUT"      : Gosub EXEBOUT
   When "VERIF_CRE"    : Gosub VERIF
   When "VERIF_MOD"    : Gosub VERIF
   When "ANNULE"       : Gosub ANNULE
   When "AP_ANNULE"    : Gosub AP_ANNULE
   When "AVANT_MODFIC" : Gosub AVANT_MODFIC
   When "MODIF"        : Gosub MODIF
   When "CREATION"     : Gosub CREATION
   When "RAZCRE"       : Gosub RAZCRE
   When "RAZDUP"       : Gosub RAZDUP
  Endcase
  If PSUBAOB
   Gosub ACTION From SUBAOBB
  Endif
Endcase
Return

############################################################
$FERME
Gosub FERME_BOITE From =WINPROG
Close Local Mask : # "flush" des masques
OK = 0
Return

########################################################
$OUVRE
Local Char    TRTOBJ(30)
Local Integer EXISTE , TROUVE , NB
If PARAM(1)="" : FIN = 1 : Return : Endif
TRTOBJ = "SPV"+PARAM(1)
Call EXISTE_ADX("","",TRTOBJ,EXISTE) From ORDSYS
NB = 0
For I=1 To dim(GENTOBJ)
 If PARAM(1)=GENTOBJ(I)
  NB += 1
  If EXISTE & GENTSPE(I)=TRTOBJ
   TROUVE = 1
  Endif
 Endif
Next I
If EXISTE & !TROUVE
 NB += 1
Endif
If NB=0 : FIN = 1 : Endif
Return

#################################################
$DEBUT
Local Char    TRTOBJ(30)
Local Integer EXISTE , TROUVE , ORD(1..200) , NUM(1..200) , NB
If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif
TRTOBJ = "SPV"+PARAM(1)
Call EXISTE_ADX("","",TRTOBJ,EXISTE) From ORDSYS
NB = 0
For I=1 To dim(GENTOBJ)
 If PARAM(1)=GENTOBJ(I)
  NB += 1
  ORD(NB) = GENTRNG(I)
  NUM(NB) = I
  If EXISTE & GENTSPE(I)=TRTOBJ
   TROUVE = 1
  Endif
 Endif
Next I
If EXISTE & !TROUVE
 NB += 1
 ORD(NB) = 0
 NUM(NB) = 999
Endif
Sorta NB ORD,NUM Order By ORD(indice+1)
[M:AOB9]NBRPRG = 0
For I=1 To NB
 [M:AOB9]NBRPRG += 1
 If NUM(I)=999
  [M:AOB9]TRTVER([M:AOB9]NBRPRG-1) = TRTOBJ
 Else
  [M:AOB9]ORDRE([M:AOB9]NBRPRG-1) = GENTRNG(NUM(I))
  [M:AOB9]TRTVER([M:AOB9]NBRPRG-1) = GENTSPE(NUM(I))
 Endif
 Read [ADC]ADC0 = [M:AOB9]TRTVER([M:AOB9]NBRPRG-1)
 If !fstat & [F:ADC]DES<>""
  [M:AOB9]INTIT([M:AOB9]NBRPRG-1) = [F:ADC]DES
 Else
  Read [AOB]ABREV = PARAM(1)
  If !fstat
   Call TEXTE([F:AOB]LIBEL,[M:AOB9]INTIT([M:AOB9]NBRPRG-1)) From OBJDIV
  Endif
 Endif
Next I
Affzo [AOB9]
Return

############################################################
$LIENS
Call TEXTE([M:AOB0]LIBEL,[M:AOB0]ZLIBEL) From OBJDIV
If dim([F:AOB]LIBSHO)>0
 Call TEXTE([M:AOB0]LIBSHO,[M:AOB0]ZLIBSHO) From OBJDIV
Endif
Call TEXTE([M]LIBPAR,[M]ZLIBPAR) From OBJDIV
nolign = 0
For [AOT]ABREV Where ABREV=[F:AOB]ABREV
 nolign += 1
 [M:AOB3] = [F:AOT]
Next AOT
[M:AOB3]NBFIC = nolign
If nolign>dim([M:AOB3]TABFIC)
 # Trop de tables dans la gestion de cet objet (#)
 Call ERREUR(func AFNC.MES(mess(202,125,1),num$(nolign))) From GESECRAN
Endif
Read [AOL]AOL0 = [F:AOB]ABREV
If !fstat
 [M:AOB1] = [F:AOL]
 [M:AOB2] = [F:AOL]
 [M:AOB3] = [F:AOL]
Endif
For I=0 To [M]NBOPT-1
 Call TEXTE([M]OPTLIB(I),[M]ZOPTLIB(I)) From OBJDIV
 Call TEXTE([M]OPTERR(I),[M]ZOPTERR(I)) From OBJDIV
Next I
For I=0 To [M]NBSEL-1
 If [M]SELINT(I)=0
  Call TEXTFIC([M]SELFIC(I),[M]SELZON(I),3,[M]ZSELINT(I)) From OBJDIV
 Else
  Call TEXTE([M]SELINT(I),[M]ZSELINT(I)) From OBJDIV
 Endif
Next I
[M:AOB1]TRTSTD = "SUB"+CLECUR1
[M:AOB1]TRTSPE = "SPE"+CLECUR1
[M:AOB1]TRTSPV = "SPV"+CLECUR1
Call EXISTE_ADX("","",[M:AOB1]TRTSPE,K) From ORDSYS
If !K : [M:AOB1]TRTSPE = "" : Endif
Call EXISTE_ADX("","",[M:AOB1]TRTSPV,K) From ORDSYS
If !K : [M:AOB1]TRTSPV = "" : Endif
If K or (dim(GENTOBJ)>0 & find(CLECUR1,GENTOBJ(1..GNBENTREE)))
 [M:AOB1]CTLSPV = 2
Else
 [M:AOB1]CTLSPV = 1
Endif
Gosub GRISE_GES
Gosub GRISE_TRT
Gosub GRISE_FIC
Gosub GRISE_PAR
Gosub GRISE_PCK
Gosub GRISE_STA
Gosub GRISE_RQT
Return

############################################################
$RAZDUP
[M:AOB1]TRTSTD = "SUB"+CZ
[M:AOB1]TRTSPE = "SPE"+CZ
[M:AOB1]TRTSPV = "SPV"+CZ
Call EXISTE_ADX("","",[M:AOB1]TRTSPE,K) From ORDSYS
If !K : [M:AOB1]TRTSPE = "" : Endif
Call EXISTE_ADX("","",[M:AOB1]TRTSPV,K) From ORDSYS
If !K : [M:AOB1]TRTSPV = "" : Endif
If K or (dim(GENTOBJ)>0 & find(CLECUR1,GENTOBJ(1..GNBENTREE)))
 [M:AOB1]CTLSPV = 2
Else
 [M:AOB1]CTLSPV = 1
Endif
Affzo [AOB1]TRTSTD,TRTSPE,TRTSPV,CTLSPV
Gosub GRISE_TRT
Read [AFC]CODINT = "GES"+CZ
If !fstat
 [M:AOB1]MENU = [F:AFC]MENU
 [M:AOB1]RANG = [F:AFC]RANG
 Affzo [AOB1]MENU , RANG
 Grizo [AOB1]MENU , RANG
Else
 Actzo [AOB1]MENU , RANG
Endif
If dim([M:AOB1]ACRURL)>0
 Raz [M:AOB1]ARCURL
Endif
Return

############################################################
$RAZCRE
Raz [AOB1]TRTSTD,TRTSPE,TRTSPV,CTLSPV,MENU,RANG
If dim([M:AOB1]ARCURL)>0
 Raz [M:AOB1]ARCURL
Endif
Gosub GRISE_TRT
Actzo [AOB1]MENU , RANG
Return

$GRISE_GES
Case [M]TYPGES
 When 2 : # Tableau
  Effzo [M:AOB1]ZACC
  Grizo [M:AOB1]ZACC
  Actzo [M:AOB1]20, 25
  Actzo [M:AOB3]20, 25
  Read [AFC]CODINT = "GES"+[M]ABREV
  If !fstat
   Grizo [M:AOB1]MENU, RANG
  Else
   Actzo [M:AOB1]MENU, RANG
  Endif
 When 4 : # Browser
  If dim([M:AOB1]DSYPAR)>0 : I=[M:AOB1]DSYPAR : Endif
  If dim([M:AOB1]FCYDEP)>0 : J=[M:AOB1]FCYDEP : Endif
  Effzo [M:AOB1]MENU, RANG, 20, 25
  Effzo [M:AOB3]20, 25
  Grizo [M:AOB1]MENU, RANG, 20, 25
  Grizo [M:AOB3]20, 25
  Actzo [M:AOB1]ZACC
  If dim([M:AOB1]DSYPAR)>0 : [M:AOB1]DSYPAR=I : Actzo [M:AOB1]DSYPAR : Endif
  If dim([M:AOB1]FCYDEP)>0 : [M:AOB1]FCYDEP=J : Actzo [M:AOB1]FCYDEP : Endif
 When Default
  Actzo [M:AOB1]ZACC, 20, 25
  Actzo [M:AOB3]20, 25
  Read [AFC]CODINT = "GES"+[M]ABREV
  If !fstat
   Grizo [M:AOB1]MENU, RANG
  Else
   Actzo [M:AOB1]MENU, RANG
  Endif
Endcase
Return

$GRISE_TRT
Diszo [M:AOB1]TRTSTD,TRTSPE,TRTSPV
Return

$GRISE_FIC
If dim([M:AOB0]ABRFIC)>0
 If [M]NOMFIC="" or GPRODUIT<>0
  Grizo [AOB0]ABRFIC
 Else
  Actzo [AOB0]ABRFIC
 Endif
Endif
If dim([M:AOB0]MODELE)>0
 If [M]NOMFIC=""
  Actzo [AOB0]MODELE
 Else
  [M:AOB0]MODELE = ""
  Affzo [AOB0]MODELE
  Grizo [AOB0]MODELE
 Endif
Endif
Return

$GRISE_PAR
If dim([M:AOB1]DSYPAR)>0
 If [M]ZLIBPAR<>"" & [M]TYPGES<>4
  Actzo [AOB1]DSYPAR
 Else
  [M]DSYPAR = 1
  Affzo [AOB1]DSYPAR
  Grizo [AOB1]DSYPAR
 Endif
Endif
Return

$GRISE_PCK
If dim([M:AOB1]SELPCK)>0 & [M]TYPGES<>4
 If [M]TYPGES<>4
  [M]SELPCK = 1
  Affzo [AOB1]SELPCK
  Grizo [AOB1]SELPCK
 Else
  Actzo [AOB1]SELPCK
 Endif
Endif
Return

$GRISE_STA
If [M]TYPGES<>1 & [M]TYPGES<>3
 [M]STA = 1
 Affzo [AOB1]STA
 Grizo [AOB1]STA
Else
 Actzo [AOB1]STA
Endif
Return

$GRISE_RQT
If dim([M:AOB1]RQT)>0 & [M]TYPGES<>4
 If [M]RPT2<>""
  [M]RQT = ""
  Affzo [AOB1]RQT
  Grizo [AOB1]RQT
 Else
  Actzo [AOB1]RQT
 Endif
Endif
Return

############################################################
$CREATION
Call TEMPON("E") From GESECRAN
For nolign=1 To [M:AOB3]NBFIC
 Raz [F:AOT]
 [F:AOT] = [M:AOB3]
 [F:AOT]NUMLIG = nolign
 [F:AOT]ABREV = [M]ABREV
 Write [AOT]
 If fstat
  GOK=0 : Call FSTA("AOT") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Raz [F:AOL]
[F:AOL] = [M:AOB1]
[F:AOL] = [M:AOB2]
[F:AOL] = [M:AOB3]
[F:AOL]ABREV = [M]ABREV
Write [AOL]
If fstat
 GOK=0 : Call FSTA("AOL") From GLOCK : Return
Endif
If [M:AOB1]TYPGES<>4
 Readlock [AFC]CODINT = "GES"+[M]ABREV
 If fstat=1
  GOK=-1 : Call RSTA("AFC","GES"+[M]ABREV) From GLOCK : Return
 Elsif !fstat
  If dim([F:AFC]UPDDAT)>0 : [F:AFC]UPDDAT = date$ : Endif
  If dim([F:AFC]UPDUSR)>0 : [F:AFC]UPDUSR = GUSER : Endif
  If dim([F:AFC]UPDTIM)>0 : [F:AFC]UPDTIM = time  : Endif
  [F:AFC]RPT1 = [F:AOB]RPT1
  [F:AFC]RPT2 = [F:AOB]RPT2
  Rewrite [AFC]
  If fstat
   GOK=0 : Call FSTA("AFC") From GLOCK : Return
  Endif
 Endif
Endif
Call TEMPOFF From GESECRAN
Return

############################################################
$AVANT_MODFIC
If [M]NOMFIC<>[F]NOMFIC
 For [ATY]CODTYP Where OBJLIEN=[M]ABREV
  Lock ="ATY"+[F:ATY]CODTYP With lockwait=0
  If fstat
   GLOCK = "%ATY"+[F:ATY]CODTYP : GOK=-1 : Break
  Endif
  Readlock [ATY] Curr
  If fstat=1
   GOK=-1 : Call RSTA("ATY",[F:ATY]CODTYP) From GLOCK : Break
  Else
   [F:ATY]FICLIEN = [M]NOMFIC
   Rewrite [ATY]
   If fstat
    GOK=0 : Call FSTA("ATY") From GLOCK : Break
   Endif
  Endif
  Unlock ="ATY"+[F:ATY]CODTYP
 Next ATY
Endif
Return

############################################################
$MODIF
Delete [AOT] Where ABREV=[M]ABREV
If fstat=1
 GOK=-1 : Call RSTA("AOT",[M]ABREV) From GLOCK : Return
Endif
Delete [AOL] Where ABREV=[M]ABREV
If fstat=1
 GOK=-1 : Call RSTA("AOL",[M]ABREV) From GLOCK : Return
Endif
Gosub CREATION
Return

############################################################
$INICRE
$INIMOD
[F:AOB]UPDFLG = 0
Return

############################################################
$VERIF
If [M]NBSEL=0
 Call AVERTIR(mess(156,123,1),OK) From GESECRAN : # Le nombre de zones de sélection est nul
 If OK<>2 : OK = 0 : Return : Endif
Endif
For I=0 To [M]NBSEL-1
 Call C_SELFIC([M]SELFIC(I))
 If mkstat : OK = 0 : Break : Endif
Next I
If !OK : Return : Endif
If [M]NOMFIC="" & [M]TYPGES<4
 GMESSAGE = mess(55,133,1) : # Il faut une table liée pour ce type d'objet
 OK = 0 : Return
Endif
If [M]NOMFIC<>"" & [M]ABREV<>"ALI"
 Local Char    TCLE(200), FCLE(GLONAVA+5)(1..16)
 Local Integer NCLE
 If [M]SELCLE<>""
  Read [ATI]CODIND = [M]NOMFIC;[M]SELCLE
  If !fstat
   TCLE = [F:ATI]DESCRIPT
  Else
   Read [ANX]ANX2 = [M]NOMFIC;[M]SELCLE
   TCLE = [F:ANX]DESCRIPT
  Endif
 Else
  Read [ATI]NUMLIG(2) = [M]NOMFIC;1
  TCLE = [F:ATI]DESCRIPT
 Endif
 Raz NCLE, FCLE
 While TCLE<>""
  NCLE += 1
  I = instr(1,TCLE,"+")
  J = instr(1,TCLE,"-")
  If I & J : I = min(I,J)
  Elsif !I : I = J
  Endif
  If I
   FCLE(NCLE) = left$(TCLE,I-1)
   TCLE = right$(TCLE,I+1)
  Else
   FCLE(NCLE) = TCLE
   TCLE = ""
  Endif
 Wend
 K = 1
 If [M]SELTREE=2 & NCLE>[M]NBSEL
  K = 0
 Endif
 If !K
  GMESSAGE = mess(73,126,1) : # Champs de sélection incompatibles avec l'index
  OK = 0 : Return
 Endif
Endif
If dim([M]NBVUE)>0
 Local Char    AVF(GLONABR)(1..99) , CVF(max(GLONATB,GLONAVW))(1..99)
 Local Integer NVF
 Raz AVF , NVF
 For I=0 To [M]NBFIC-1
  CHAINE = ""
  If [M]TABABR(I)<>""
   CHAINE = [M]TABABR(I)
  Else
   Read [ATB]CODFIC=[M]TABFIC(I)
   If !fstat
    CHAINE = [F:ATB]ABRFIC
   Endif
  Endif
  If CHAINE<>""
   NVF += 1
   If NVF>dim(AVF) : Break : Endif
   AVF(NVF) = CHAINE
   CVF(NVF) = [M]TABFIC(I)
  Endif
 Next I
 J = NVF
 For I=0 To [M]NBVUE-1
  CHAINE = ""
  If [M]VUEABR(I)<>""
   CHAINE = [M]VUEABR(I)
  Else
   Read [AVW]AVW0=[M]VUECOD(I)
   If !fstat
    CHAINE = [F:AVW]ABRVUE
   Endif
  Endif
  If CHAINE<>""
   K = find(CHAINE,AVF)
   If K
    GMESSAGE = CHAINE-":"-mess(17,176,1) : # Abréviation déjà existante
    If K>NVF
     GMESSAGE += "\"+mess(77,139,1)-":"-CVF(K) : # vue
    Else
     GMESSAGE += "\"+mess(56,123,1)-":"-CVF(K) : # Table
    Endif
    OK = 0 : Break
   Else
    J += 1
    If J>dim(AVF) : Break : Endif
    AVF(J) = CHAINE
    CVF(J) = [M]VUECOD(I)
   Endif
  Endif
 Next I
Endif
If !OK : Return : Endif
Return

############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, Copie
Endif
If CLECUR
 CHMEN += "1" : # Infos
Endif
Return

############################################################
$ANNULE
Local Char    TRTANU(GLONAFC)
TRTANU = "GES"+[L]CODE
# On efface la fonction et ses liens (connus)
If clalev([F:ARV])=0 : Local File AREPORTV [ARV] : Endif
Delete [ARV] Where FONCTION=TRTANU
If fstat=1 : GOK = -1 : GLOCK = "$AREPORTV"-TRTANU : Return : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY [AFF] : Endif
Delete [AFF] Where FNC=TRTANU
If fstat=1 : GOK = -1 : GLOCK = "$AFCTFCY"-TRTANU : Return : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF [AFP] : Endif
Delete [AFP] Where FNC=TRTANU
If fstat=1 : GOK = -1 : GLOCK = "$AFCTPRF"-TRTANU : Return : Endif
If clalev([F:ABT])=0 : Local File ABATTAC [ABT] : Endif
Delete [ABT] Where FONCTION=TRTANU
If fstat=1 : GOK = -1 : GLOCK = "$ABATTAC"-TRTANU : Return : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
Delete [AFC] Where CODINT=TRTANU
If fstat=1 : GOK = -1 : GLOCK = "$AFONCTION"-TRTANU : Return : Endif
Delete [AOT] Where ABREV=[L]CODE
If fstat=1 : GOK = -1 : GLOCK = "$AOBJTAB"-[L]CODE : Return : Endif
Delete [AOL] Where ABREV=[L]CODE
If fstat=1 : GOK = -1 : GLOCK = "$AOBJLST"-[L]CODE : Return : Endif
Return

############################################################
$AP_ANNULE
Call DEL_TRTAOB([L]CODE,nomap)
Return

############################################################
Subprog DEL_TRTAOB(OBJET,APPLI)
Value Char OBJET , APPLI
Local Char    PROGOBJ(GLONADC) , FICHIER(GDIMFIC)
Local Integer STAT
PROGOBJ = "WO"+OBJET
FICHIER = filpath("TRT",PROGOBJ,"src",APPLI)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
Call EFFACE_ADX("",APPLI,PROGOBJ,STAT) From ORDSYS
Call SUPOBJT(APPLI,OBJET) From INTRUTILB
End

############################################################
$EXEBOUT
Case REP
 When "V"
  OK = 1
  Gosub VERIF
  If !OK
   Call ERREUR(GMESSAGE) From GESECRAN
   Return
  Endif
  Call GENERE(CLECUR1)
  Read [AOB]ABREV = CLECUR1
Endcase
Return

###########################################################################
Subprog GENERE(CLECUR)
Value Char CLECUR

Local Integer OK , I , FLWEB , EXISTE
Local Char    NEWFONC(GLONAFC)

OK=2 : Call OUINON(mess(13,124,1)-CLECUR,OK) From GESECRAN : # Validation objet
If OK<>2 : End : Endif

# Traitement WOxxx, SUBxxx et SPExxx
Call VALID(CLECUR,nomap,0,OK) From VALOBJ
If !OK : End : Endif

# Fonction
## Il ne faut pas générer la fonction, si dans le superviseur
## elle est définie avec un code activité non présent dans le dossier
## (cas de l'objet GAC pour les américains)

NEWFONC = "GES"+CLECUR

If [F:AOB]TYPGES<>4 & adxmother(1)<>"" : # Pas de fonction pour les objets spéciaux
 OK = 1
 Local File =adxmother(1)+".AFONCTION" [AF2]
 Read [AF2]CODINT = NEWFONC
 If !fstat & [F:AF2]CODACT<>""
  Read [ACV]CODACT = [F:AF2]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
 If OK
  Look [AFC]CODINT=NEWFONC
  EXISTE = !fstat
  Call GENFONC(nomap,CLECUR) From OBJFNC
  If [F:AOB]ZSITE<>"" & !EXISTE
   Trbegin [AF2]
    Read [AFC]CODINT=NEWFONC
    Call CREATIONFONCTION(NEWFONC,[F:AFC]TYP,[F:AFC]NBOPT,[F:AFC]FLAG) From SUBAFP2
   Commit
  Endif
 Endif
 Close Local File [AF2]
Endif

# Raz du fichier derniers lus
If clalev([F:ALS])=0 : Local File ALSTRD [ALS] : Endif
Trbegin [ALS]
 Delete [ALS] Where OBJ=CLECUR
Commit

# Quand on valide un objet à variante ou de type browser, il faut revalider les fenêtres...
Call VALFEN(nomap,CLECUR)

End


##################################################
Subprog VALFEN(APPLI,OBJET)
Value Char APPLI , OBJET
Local Integer OK
If APPLI="" or APPLI=nomap
 Local File ACTIV   [ACV]
 Local File ATEXTE  [ATX]
 Local File ATEXTRA [AXX]
Else
 Local File =APPLI+".ACTIV"   [ACV]
 Local File =APPLI+".ATEXTE"  [ATX]
 Local File =APPLI+".ATEXTRA" [AXX]
Endif
If clalev([F:AWI])=0
 If APPLI="" or APPLI=nomap
  Local File AWINDOW [AWI]
 Else
  Local File =APPLI+".AWINDOW" [AWI]
 Endif
Endif
If clalev([F:AOB])=0
 If APPLI="" or APPLI=nomap
  Local File AOBJET [AOB]
 Else
  Local File =APPLI+".AOBJET" [AOB]
 Endif
Endif
If clalev([F:AWB])=0
 If APPLI="" or APPLI=nomap
  Local File AWINBRO [AWB]
 Else
  Local File =APPLI+".AWINBRO" [AWB]
 Endif
Endif
Read [AOB]ABREV=OBJET
If fstat : End : Endif
#If [F:AOB]TYPGES<>4
# For [AWI]AWI1 Where OBJ=OBJET
#  Call VALID([F:AWI]WIN,APPLI,0,OK) From VALWIN
# Next
#Else
 For [AWI]AWI1
  If [F:AWI]OBJ=OBJET
   Call VALID([F:AWI]WIN,APPLI,0,OK) From VALWIN
  Else
   Read [AWB]AWB0 = [F:AWI]WIN
   If !fstat & find(OBJET,[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
    Call VALID([F:AWI]WIN,APPLI,0,OK) From VALWIN
   Endif
  Endif
 Next
#Endif
Close Local File
End

Subprog MAJFLAG(COD)
Value Char COD
If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
Call DEBTRANS From GLOCK
Gosub TR_MAJ
End

$TR_MAJ
GOK=1
Trbegin [AOB]
 Update [AOB] Where ABREV=COD With UPDFLG=0, TRFDAT=[0/0/0]
 If fstat=1
  GOK=-1 : GLOCK="$AOBJET"-COD : Goto ROLL_TR_MAJ
 Elsif fstat=3 | fstat>5
  GOK=0  : Call FSTA("AOB") From GLOCK : Goto AB_TR_MAJ
 Endif
Commit
Return

$ROLL_TR_MAJ
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJ : Endif

$AB_TR_MAJ
Rollback : Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AOBJET  [AOB1]
 Local File AOBJTAB [AOT1]
 Local File AOBJLST [AOL1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AOBJET"  [AOB1]
 Local File =[M]DOSORG+".AOBJTAB" [AOT1]
 Local File =[M]DOSORG+".AOBJLST" [AOL1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AOBJET  [AOB2]
 Local File AOBJTAB [AOT2]
 Local File AOBJLST [AOL2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".AOBJET"  [AOB2]
 Local File =[M]DOSDES+".AOBJTAB" [AOT2]
 Local File =[M]DOSDES+".AOBJLST" [AOL2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AOB1], [AOT1], [AOL1], [ATX1], [AOB2], [AOT2], [AOL2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AOB2] , [AOT2], [AOL2], [ATX2]
 Delete [AOB2] Where ABREV=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AOB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AOT2] Where ABREV=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJTAB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AOT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AOL2] Where ABREV=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJLST" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AOL2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AOB1]ABREV Where ABREV=TABLE
  [F:AOB2] = [F:AOB1]
  Call COPTEXTE([F:AOB1]LIBEL,[F:AOB2]LIBEL) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AOB1]LIBPAR,[F:AOB2]LIBPAR) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AOB1]NBOPT-1
   Call COPTEXTE([F:AOB1]OPTLIB(I),[F:AOB2]OPTLIB(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
   Call COPTEXTE([F:AOB1]OPTERR(I),[F:AOB2]OPTERR(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AOB2]UPDUSR)>0 : [F:AOB2]UPDUSR = GUSER : Endif
  If dim([F:AOB2]UPDDAT)>0 : [F:AOB2]UPDDAT = date$ : Endif
  If dim([F:AOB2]UPDTIM)>0 : [F:AOB2]UPDTIM = time  : Endif
  Write [AOB2]
  If fstat
   GOK=0 : Call FSTA("AOB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AOT1]ABREV Where ABREV=TABLE
  [F:AOT2] = [F:AOT1]
  Write [AOT2]
  If fstat
   GOK=0 : Call FSTA("AOT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AOL1]AOL0 Where ABREV=TABLE
  [F:AOL2] = [F:AOL1]
  For I=0 To [F:AOL1]NBSEL-1
   Call COPTEXTE([F:AOL1]SELINT(I),[F:AOL2]SELINT(I)) From OBJDIV
  Next I
  Write [AOL2]
  If fstat
   GOK=0 : Call FSTA("AOL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
# Etiquettes du masque AOB0
##########################################################################
Subprog AM_ABREV(VALEUR)
Variable Char VALEUR
End

Subprog C_ZLIBEL(VALEUR)
Variable Char VALEUR
Call C_QUOTE(VALEUR)
End

Subprog C_NOMFIC(VALEUR)
Variable Char     VALEUR
End

Subprog AP_NOMFIC(VALEUR)
Variable Char    VALEUR()
[M]NOMFIC = VALEUR
Gosub GRISE_FIC
End

Subprog AM_NOMFIC(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" or !find([M]TYPGES,1,4)
 End
Endif
Gosub AJOUT_AXX
End

##########################################################################
# Etiquettes du masque AOB1
##########################################################################
Subprog AM_TYPGES(VALEUR)
Variable Integer VALEUR()
[M]TYPGES = VALEUR
Case [M]TYPGES
 When 2
  Raz [M:AOB1]ZACC
 When 4
  Raz [M:AOB1]MENU, [M:AOB1]RANG
  Effzo [M:AOB3]20, 30
Endcase
Gosub GRISE_GES
[M:AOB1]TRTSTD = "SUB"+[M:AOB0]ABREV
[M:AOB1]TRTSPE = "SPE"+[M:AOB0]ABREV
[M:AOB1]TRTSPV = "SPV"+[M:AOB0]ABREV
Gosub GRISE_TRT
Gosub GRISE_PAR
Gosub GRISE_PCK
Gosub GRISE_STA
Gosub GRISE_RQT
End

Subprog AS_ZLIBPAR(VALEUR)
Variable Char VALEUR()
If [M]NBCLE=1 : mkstat=1 : End : Endif
End

Subprog C_ZLIBPAR(VALEUR)
Variable Char VALEUR()
Call C_QUOTE(VALEUR)
If mkstat : End : Endif
End

Subprog AM_ZLIBPAR(VALEUR)
Variable Char    VALEUR()
[M]ZLIBPAR = VALEUR
Gosub GRISE_PAR
End

Subprog AM_IMPORT(VALEUR)
Variable Integer    VALEUR()
If VALEUR<>2
 If clalev([F:AOE])=0 : Local File AOBJEXT [AOE] : Endif
 Filter [AOE] Where OBJ=[M]ABREV
 For [AOE]AOE1
  If [F:AOE]IMPORT=2
   Call ERREUR(mess(107,141,1)-[F:AOE]EXT) From GESECRAN : # Objet déclaré dans le modèle import
   mkstat = 2 : Break
  Endif
 Next
 Filter [AOE]
Endif
End

Subprog AS_RANG(VALEUR)
Variable Decimal VALEUR
If [M]MENU="" : mkstat=1 : End : Endif
End

Subprog S_RANG(VALEUR)
Variable Decimal VALEUR
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
Local Integer CHX , NBTEX , VALINT
Local Char    TEX(50)(50) , LIBEL(30)
NBTEX=0
For [AFC]MENU Where MENU=[M]MENU
 NBTEX += 1
 Call TEXTE([F:AFC]LIBMENU,LIBEL) From OBJDIV
 TEX(NBTEX)=format$("N:3#",[F:AFC]RANG)-[F:AFC]CODINT-LIBEL
 If [F:AFC]RANG=VALEUR : VALINT=NBTEX : Endif
Next
If NBTEX<>0
 Call SAITEX(NBTEX,TEX,VALINT,[M]MENU) From GESECRAN
 If status<>7 & VALINT<>0
  VALEUR = val(TEX(VALINT))
 Endif
Endif
mkstat = 2
End

Subprog C_ZSITE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Read [ATZ]CODZONE = [M]NOMFIC;VALEUR
If fstat
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
End

Subprog C_ZACC(VALEUR)
Variable Char    VALEUR()
Call C_ZSITE(VALEUR)
End

Subprog AS_STA(VALEUR)
Variable Integer VALEUR
If [M]TYPGES<>1 & [M]TYPGES<>3 : VALEUR = 1 : mkstat = 2 : Endif
End

Subprog C_QUOTE(CHAINE)
Variable Char CHAINE()
If instr(1,CHAINE,'"')
 GMESSAGE = '"'-":"-mess(94,123,1) : # Caractère interdit
 mkstat=2 : End
Endif
End

Subprog AS_RQT(VALEUR)
Variable Char VALEUR
If [M]RPT2<>"" : mkstat=1 : End : Endif
End

#########################################################################
# Etiquettes du masque AOB2
#########################################################################

Subprog C_ZOPTLIB(VALEUR)
Variable Char VALEUR
Call C_QUOTE(VALEUR)
End

Subprog D_OPTCOD(VALEUR)
Variable Char VALEUR
If nolign=1
 VALEUR="A"
Else
 VALEUR=chr$(ascii([M]OPTCOD(nolign-2))+1)
Endif
End

Subprog C_OPTCOD(VALEUR)
Variable Char VALEUR()
Call UNICITE(VALEUR,[M]OPTCOD) From OBJDIV
End

Subprog AM_OPTCOD(VALEUR)
Variable Char     VALEUR
Local Integer OK
If GADONIX=2 & (VALEUR<"A" | VALEUR>"Z")
 Call AVERTIR(mess(230,133,1),OK) From GESECRAN : # Code réservé spécifique
 If OK<>2 : mkstat = 1 : Endif
Endif
End

Subprog C_OPTCND(VALEUR)
Variable Char VALEUR()
Local Integer E
E = abs(parse(VALEUR))
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E)+"\"+errm : # Expression incorrecte
 mkstat = 2 : End
Endif
Call C_QUOTE(VALEUR)
End

Subprog C_ZOPTERR(VALEUR)
Variable Char VALEUR
Call C_QUOTE(VALEUR)
End

Subprog AS_SELOPT(VALEUR)
Variable Char    VALEUR()
If [M]NBOPT=0 : VALEUR="" : mkstat=2 : End : Endif
End

Subprog S_SELOPT(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , I , VALINT
Local Char    TEX(50)(dim([M]OPTCOD)+1)
NBTEX = 0
For I=0 To [M]NBOPT-1
 NBTEX += 1
 TEX(NBTEX) = [M]OPTCOD(I)-[M]ZOPTLIB(I)
Next I
If NBTEX
 Call SAITEX(NBTEX,TEX,VALINT,mess(100,123,1)) From GESECRAN
# Choix options
 If VALINT<>0 & status<>7 & !instr(1,VALEUR,[M]OPTCOD(VALINT-1))
  VALEUR += [M]OPTCOD(VALINT-1)
 Endif
Endif
mkstat = 2
End

Subprog C_SELOPT(VALEUR)
Variable Char VALEUR()
Local Integer I
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),[M]OPTCOD(0..[M]NBOPT-1))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
End

Subprog AS_SELFIC(VALEUR)
Variable Char    VALEUR()
Local Integer I , NB
If VALEUR="" & [M]SELEXP(nolign-1)=""
 VALEUR = [M]NOMFIC
Endif
Raz [M:AOB3]TABFIL , ABRFIL
[M:AOB3]TABFIL = [M]NOMFIC
Read [ATB]CODFIC=[M:AOB3]TABFIL
[M:AOB3]ABRFIL = [F:ATB]ABRFIC
For I=0 To [M:AOB3]NBFIC-1
 If [M:AOB3]TABLIEN(I)<>""
  NB += 1
  [M:AOB3]TABFIL(NB) = [M:AOB3]TABFIC(I)
  If [M:AOB3]TABABR(I)<>""
   [M:AOB3]ABRFIL(NB) = [M:AOB3]TABABR(I)
  Else
   Read [ATB]CODFIC=[M:AOB3]TABFIL(NB)
   [M:AOB3]ABRFIL(NB) = [F:ATB]ABRFIC
  Endif
 Endif
Next I
End

Subprog C_SELFIC(VALEUR)
Variable Char    VALEUR()
Local    Integer I, OK
Local    Char    LIEN(50)
If VALEUR="" : End : Endif
If VALEUR=[M]NOMFIC : End : Endif
I = find(VALEUR,[M]TABFIC(0..dim([M]TABFIC)-1))
If !I
 GMESSAGE = mess(17,123,1) : # Table non définie
 mkstat = 2 : End
Elsif [M]NOMFIC<>"" & [M]TABLIEN(I-1)=""
 GMESSAGE = mess(162,115,1) : # Lien incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_SELZON(VALEUR)
Variable Char VALEUR()
If [M]SELFIC(nolign-1)="" : mkstat = 1 : End : Endif
End

Subprog C_SELZON(VALEUR)
Variable Char VALEUR()
If VALEUR=""
 [M]SELFIC(nolign-1) = ""
 Affzo [M]SELFIC(nolign-1)
 End
Endif
Read [ATZ]CODZONE = [M]SELFIC(nolign-1);VALEUR
If fstat or (!fstat & !func AFNC.ACTIV([F:ATZ]CODACT))
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Elsif find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 GMESSAGE = mess(106,133,1) : # Zone correspondant à un texte traduisible, utiliser un lien
 mkstat = 2 : End
Else
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP>=9
  GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de données incorrect
  mkstat = 2 : End
 Endif
Endif
Call UNICITE(VALEUR,[M]SELZON) From OBJDIV
End

Subprog AM_SELZON(VALEUR)
Variable Char VALEUR()
If [M]SELFIC(nolign-1)<>""
 [M]SELINT(nolign-1) = [F:ATZ]NOABREG
 Call TEXTE([M]SELINT(nolign-1),[M]ZSELINT(nolign-1)) From OBJDIV
Endif
End

Subprog AS_SELTYP(VALEUR)
Variable Char VALEUR()
If [M]SELFIC(nolign-1)<>"" : mkstat = 1 : End : Endif
End

Subprog C_SELTYP(VALEUR)
Variable Char VALEUR()
If find(VALEUR,"AXX","AX1","AX2","AX3")
 GMESSAGE = VALEUR-":"-mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = VALEUR
If !fstat & [F:ATY]TYPTYP>=9
 GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_ZSELINT(VALEUR)
Variable Char VALEUR()
#If [M]SELFIC(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog AS_SELEXP(VALEUR)
Variable Char    VALEUR()
If [M]SELFIC(nolign-1)<>"" : mkstat = 1 : End : Endif
End

Subprog C_SELEXP(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,'"')
 GMESSAGE = '" :'-mess(94,123,1) : # Caractère interdit
 mkstat = 2 : End
Endif
End

Subprog AS_SELCLE(VALEUR)
Variable Char     VALEUR
If find([M]TYPGES,3) : # Combiné
 mkstat=1
Endif
End

Subprog AS_SELSAI(VALEUR)
Variable Char    VALEUR()
If [M]SELFIC(nolign-1)<>"" : mkstat = 1 : End : Endif
End

Subprog C_SELSAI(VALEUR)
Variable Char    VALEUR()
Local Integer I
Gosub DEF_OPTFMT From SELAMK
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),TEX(1..NBTEX))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
End

Subprog D_SELLNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]SELTYP(nolign-1),"") From CONTOBJ
If !fstat & [F:ATY]FORTYP="" & [F:ATY]LNGTYP=0 : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1  : VALEUR = 15  : # Libellé
  When 2  : VALEUR = 4   : # Entier Court
  When 3  : VALEUR = 8   : # Entier Long
  When 4  : VALEUR = 9.2 : # Décimal
  When 7  : VALEUR = 10  : # Alphanumérique
  When 9  : VALEUR = 1   : # Blob
  When 10 : VALEUR = 1   : # Clob
 Endcase
Endif
End

Subprog AS_SELLNG(VALEUR)
Variable Decimal VALEUR
If [M]SELFIC(nolign-1)<>"" : mkstat = 1 : End : Endif
If [M]SELTYP(nolign-1)="" : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]SELTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | find([F:ATY]TYPTYP,8)
 mkstat=1 : End
Endif
End

Subprog C_SELLNG(VALEUR)
Variable Decimal VALEUR
Local Decimal ENTIER , DECIM
If VALEUR=0 : End : Endif
Call LECTURE("ATY",[M]SELTYP(nolign-1),"") From CONTOBJ
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1  : If DECIM<>0 | ENTIER>50             : mkstat = 1 : Endif : # Libellé
 When 2  : If DECIM<>0 | ENTIER>4              : mkstat = 1 : Endif : # Entier court
 When 3  : If DECIM<>0 | ENTIER>8              : mkstat = 1 : Endif : # Entier long
 When 4  : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat = 1 : Endif : # DCB
 When 7  : If DECIM<>0 | ENTIER>255            : mkstat = 1 : Endif : # Char
 When 8  : If DECIM<>0 | !find(ENTIER,4,6,8)   : mkstat = 1 : Endif : # Date
 When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
 When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

#########################################################################
# Etiquettes du masque AOB3
#########################################################################
Subprog C_TABFIC(VALEUR)
Variable Char VALEUR()
Local Integer OK
If VALEUR=[M]NOMFIC
 Call AVERTIR(mess(150,126,1),OK) From GESECRAN : # La table est déjà référencée dans l'objet
 If OK<>2 : mkstat = 2 : End : Endif
Endif
Call UNICITE(VALEUR,[M]TABFIC) From OBJDIV
If mkstat
 Call AVERTIR(GMESSAGE,OK) From GESECRAN
 Raz GERR , GMESSAGE , mkstat
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog C_TABCLE(VALEUR)
Variable Char    VALEUR()
Local Integer K , OK
If VALEUR="" : End : Endif
OK = 0
Read [ATI]CODIND = [M]TABFIC(nolign-1) ; VALEUR
If !fstat
 If [F:ATI]HOMONYM<>1
  # La clé primaire de cette table accepte des homonymes\Il peut y avoir des problèmes d'affichage
  Call AVERTIR(VALEUR-":"-mess(168,115,1),K) From GESECRAN
  If K<>2
   mkstat = 1 : End
  Endif
 Endif
 OK = 1
Else
 Read [ANX]ANX2 = [M]TABFIC(nolign-1) ; VALEUR
 If !fstat
  If [F:ANX]FLACT<>2
   Call ERREUR(VALEUR-":"-mess(99,139,1)) From GESECRAN : # Index inactif
   mkstat = 1 : End
  Endif
  OK = 1
 Endif
Endif
If !OK
 Call ERREUR(VALEUR-":"-mess(43,150,1)) From GESECRAN : # Index non défini
 mkstat = 1 : End
Endif
End

Subprog AS_TABLIEN(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TAB
End

Subprog D_TABLIEN(VALEUR)
Variable Char VALEUR()
Local Integer OK , K
Local Char    CHAINE(80) , ZONE(80)
If [M]TABCLE(nolign-1)<>""
 Read [ATI]NUMLIG = [M]TABFIC(nolign-1) ; 1
 If [F:ATI]CODIND<>[M]TABCLE(nolign-1) : End : Endif
Endif
Gosub CHARGE_TAB
If VALEUR<>"" | [M]TABFIC(nolign-1)="" : End : Endif
Filter [ATZ] Where LIEN=[M]TABFIC(nolign-1) & CODFIC=[M]NOMFIC
Read [ATZ]LIEN First
Filter [ATZ]
If !fstat
 Read [ATB]CODFIC = [M]NOMFIC
 If [F:ATZ]EXPLIEN<>""
  CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
  VALEUR = ""
  Repeat
   K = instr(K,CHAINE,";")
   If K
    ZONE   = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    ZONE   = CHAINE
    CHAINE = ""
   Endif
   If VALEUR<>"" : VALEUR += ";" : Endif
   If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
    VALEUR += "[F:"+[F:ATB]ABRFIC+"]"+ZONE
   Else
    VALEUR += ZONE
   Endif
  Until CHAINE = ""
 Else
  VALEUR = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
 Endif
Endif
End

$CHARGE_TAB
Local Integer NB , I
Raz [M]TABFIL, NB
[M]TABFIL(0) = [M]NOMFIC
Read [ATB]CODFIC = [M]NOMFIC
[M]ABRFIL(0) = [F:ATB]ABRFIC
For I=0 To nolign-2
 NB += 1
 [M]TABFIL(NB) = [M]TABFIC(I)
 If [M]TABABR(I)<>""
  [M]ABRFIL(NB) = [M]TABABR(I)
 Else
  Read [ATB]CODFIC = [M]TABFIC(I)
  [M]ABRFIL(NB) = [F:ATB]ABRFIC
 Endif
Next I
Return

Subprog C_TABLIEN(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Call CONTROLE_ABR([M]TABFIL,[M]ABRFIL,"",[M]TABFIC(nolign-1),[M]TABCLE(nolign-1),1,VALEUR) From LNKSUB
Endif
End

Subprog AS_DSYPAR(VALEUR)
Variable Integer VALEUR
If [M]ZLIBPAR="" : mkstat=1 : Endif
End

Subprog AS_SELPCK(VALEUR)
Variable Decimal VALEUR
If [M]TYPGES<>4 :  mkstat=1 : Endif : # GEODE
End

#########################################################################
# Etiquettes du masque AOB4
#########################################################################
Subprog C_VUECOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VUECOD) From OBJDIV
If mkstat
 Call AVERTIR(GMESSAGE,OK) From GESECRAN
 Raz GERR , GMESSAGE , mkstat
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog C_VUEABR(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK
If VALEUR="" : End : Endif
Call UNICITE(VALEUR,[M]VUEABR) From OBJDIV
If mkstat : End : Endif
I = find(VALEUR,[M]TABABR)
If I
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(56,123,1)-":"-[M]TABFIC(I-1) : # Table
Endif
End

Subprog AM_RPT2(VALEUR)
Variable Char    VALEUR()
[M]RPT2 = VALEUR
Gosub GRISE_RQT
End

Subprog B1_NBFIC
Local Char VALEUR
Local Integer OLNBFIC
OLNBFIC =  [M:AOB3]NBFIC
VALEUR  =  [M]NOMFIC
If VALEUR <> ""
 Gosub AJOUT_AXX
 If [M:AOB3]NBFIC<>OLNBFIC
  mkstat = 4
 Endif
Endif
End

#######################################################################
# Ajout des liens ATEXTRA pour les champs avec un type de données AXX
#######################################################################

$AJOUT_AXX
If !clalev([F:AOT])  : Local File AOBJTAB [AOT]   : Endif
If !clalev([F:ATB])  : Local File ATABLE  [ATB]   : Endif
If !clalev([F:ATZ])  : Local File ATABZON [ATZ]   : Endif
If !clalev([F:ATY])  : Local File ATYPE   [ATY]   : Endif
If !clalev([F:AMP])  : Local File AMSKPAR [AMP]   : Endif
If !clalev([F:ATZ2]) : Local File ATABZON [ATZ2]  : Endif

Local Char    TABLE(GLONATB)
Local Char    FLDAXX(GLONAVA)(0..20),LIENAXX(250)(0..20)
Local Char    CLECUR1(250),CLECUR2(250),ZONE(250),TABLE1(250)
Local Integer NBAXX,I,OKAXX,OK,NBAXX,NBLIG,NBLIEN
Local Char    ABRTAB(GLONABR)(0..20),WCLECUR(250),VERSION(20)
Local Integer NBABR,J,JJ

TABLE = VALEUR
VERSION = func AFNC.PARTSEP(ver$(0),2," ")
Read [F:ATB]CODFIC = TABLE
Raz NBAXX,FLDAXX,LIENAXX
For [ATZ] Where CODFIC =TABLE & find(CODTYP,"AXX","AX1","AX2","AX3") & DIME=1
 OK=0
 For [AMP] Where TYPAFF =2 & CODAFF=TABLE & CODZON=[F:ATZ]CODZONE
  OK =1
  Case [AMP]CODPAR
    When "CLECUR1"  : CLECUR1 = [AMP]VALPAR
    When "CLECUR2"  : CLECUR2 = [AMP]VALPAR
    When "ZONE"     : ZONE    = [AMP]VALPAR
    When "TABLE1"   : TABLE1  = [AMP]VALPAR
  Endcase
 Next AMP
 If OK
  LIENAXX(NBAXX) = TABLE1+';'+ZONE+';GLANGUE;'
  #### Verif clecur1
  If instr(1,CLECUR1,"(")
   WCLECUR = left$(CLECUR1,instr(1,CLECUR1,"(")-1)
  Else
   WCLECUR = CLECUR1
  Endif
  Read [F:ATZ2]CODZONE = [F:ATZ]CODFIC;toupper(WCLECUR)
  If !fstat
   If VERSION>="16r.113"
    LIENAXX(NBAXX) += "Num$([F:"+[F:ATB]ABRFIC+"]"+CLECUR1+");"
   Else
    LIENAXX(NBAXX) += "[F:"+[F:ATB]ABRFIC+"]"+CLECUR1+";"
   Endif
  Else
   If VERSION>="16r.113" & !instr(1,CLECUR1,"um$(")
    LIENAXX(NBAXX) += "Num$("+CLECUR1+');'
   Else
    LIENAXX(NBAXX) += CLECUR1+';'
   Endif
  Endif
  #### Verif clecur2
  If instr(1,CLECUR2,"(")
   WCLECUR = left$(CLECUR2,instr(1,CLECUR2,"(")-1)
  Else
   WCLECUR = CLECUR2
  Endif
  Read [F:ATZ2]CODZONE = [F:ATZ]CODFIC;toupper(WCLECUR)
  If !fstat
   If VERSION>="16r.113"
    LIENAXX(NBAXX) += "Num$([F:"+[F:ATB]ABRFIC+"]"+CLECUR2+")"
   Else
    LIENAXX(NBAXX) += "[F:"+[F:ATB]ABRFIC+"]"+CLECUR2+""
   Endif
  Else
   If VERSION>="16r.113" & !instr(1,CLECUR2,"um$(")
    LIENAXX(NBAXX) += "Num$("+CLECUR2+')'
   Else
    LIENAXX(NBAXX) += CLECUR2
   Endif
  Endif
  FLDAXX(NBAXX)  = [F:ATZ]CODZONE
  NBAXX +=1
 Endif
Next ATZ
NBLIG = [M:AOB3]NBFIC
Raz ABRTAB,NBABR,NBLIEN
For I=0 To [M:AOB3]NBFIC-1
 If [M]TABABR(I) <>"" &  [M]TABFIC(I) ="ATEXTRA"
  ABRTAB(NBABR) = [M]TABABR(I)
  NBABR += 1
 Endif
 NBLIEN += 1
Next I
JJ=3 :
For I=0 To NBAXX-1
 OKAXX = 0
 For J=0 To [M:AOB3]NBFIC-1
  If  [M]TABFIC(J) ="ATEXTRA" & instr(1,[M]TABLIEN(J),TABLE) & instr(1,[M]TABLIEN(J),FLDAXX(I))
   OKAXX =1
   Break
  Endif
 Next I
 If !OKAXX & TABLE=evalue(TABLE1)
  If NBLIEN < 13
   [M:AOB3]TABFIC(NBLIG)   = "ATEXTRA"
   [M:AOB3]TABCLE(NBLIG)   = ""
   [M:AOB3]TABLIEN(NBLIG)  = LIENAXX(I)
   While find("AX"+num$(JJ),[L]ABRTAB(0..NBABR-1))
    JJ+=1
   Wend
   [M:AOB3]TABABR(NBLIG)   = "AX"+num$(JJ) : [L]ABRTAB(NBABR) =   "AX"+num$(JJ) : NBABR+=1
   [M:AOB3]TABACT(NBLIG)   = ""
   NBLIG += 1
   NBLIEN += 1
  Endif
 Endif
Next I
[M:AOB3]NBFIC   = NBLIG
Affzo [AOB3]15
Return

Subprog C_MLOCK(VALEUR)
Variable Integer VALEUR
Local Integer OK
If VALEUR = 2
 # Vous devez modifier les traitements associés à cet objet pour supporter cette option.
 # Voulez-vous activer cette option quand-même?
 Call AVERTIR(mess(102,143,1)-mess(103,143,1),OK) From GESECRAN
 If OK=1 : mkstat = 2 : End : Endif
Endif
End

