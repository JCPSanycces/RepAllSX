#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Local Char    LIN_STR(GDIMFIC), LIN_END(GDIMFIC), ZONE(10)
Local Integer COL, NOL, IL, IC, COL1
Local Char    STRAC(5) , STYLE(GLONASY) , STYL0(5) , STYL1(5) , FMT(50)
STRAC    = "TDB"
LIN_STR  = ctrans(mess(83,111,1),":","")  : # "De la colonne"
LIN_END  = ctrans(mess(84,111,1),":","")  : # "A la colonne"
ZONE     = zoncou   :# NBLIG ou AMTVAL,1,2...
NOL      = nolign
Return

$DEBUT
Call LECTURE("TXS",[M:TXM0]TXSNAM,"") From CONTOBJ
Raz [M:DIA]
[M:DIA]NOLIG  = NOL
[M:DIA]LIGNAM = '  "'+[M:TXM1]INTIT(NOL-1)+'"'
Case ZONE
 When "NBLIG" 
  COL = 0
  Actzo [M:DIA]LINSTR, LINEND
  [M:DIA]LINSTR = 0
  [M:DIA]LINEND = [F:TXS]NBRCOL
  [M:DIA]FMTPRN = 0
  [M:DIA]EFFPRN = 0
  For [TXD]TXD0 Where TXSNAM=[F:TXS]TXSNAM & LIG=NOL
   If [M:DIA]FMTPRN=0
    [M:DIA]FMTPRN = [F:TXD]FMTPRN
   Elsif [M:DIA]FMTPRN<>[F:TXD]FMTPRN
    [M:DIA]FMTPRN = 1
   Endif
   If [M:DIA]EFFPRN=0
    [M:DIA]EFFPRN = [F:TXD]EFFPRN
   Elsif [M:DIA]EFFPRN<>[F:TXD]EFFPRN
    [M:DIA]EFFPRN = 1
   Endif
  Next
  Grizo [M:DIA]DECCOL
 When Default
  COL = val(right$(ZONE,7))
  [M:DIA]LINSTR = COL
  [M:DIA]LINEND = COL
  Read [TXD]TXD0 = [F:TXS]TXSNAM;NOL;COL
  [M:DIA]FMTPRN = [F:TXD]FMTPRN
  [M:DIA]EFFPRN = [F:TXD]EFFPRN
  [M:DIA]DECCOL = [F:TXD]DECCOL
  Grizo [M:DIA]LINSTR, LINEND
  Actzo [M:DIA]DECCOL
Endcase
Call C_LINSTR([M:DIA]LINSTR)
Call C_LINEND([M:DIA]LINEND)
Affzo [M]
Return

$OK
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 STYL1 = num$([M:DIA]FMTPRN-1)+num$([M:DIA]EFFPRN-1)
 If COL=0
  For COL1=[M:DIA]LINSTR To [M:DIA]LINEND
   IC = COL1
   IL = NOL-1
   Gosub STYLE_CELLULE From SUBTXW
  Next COL1
 Else
  IC = COL
  IL = NOL-1
  Gosub STYLE_CELLULE From SUBTXW
  FMT = "Nz:14."+num$([M:DIA]DECCOL)+"#"
  Gosub FORMAT_CELLULE From SUBTXW
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin [TXD]
 If COL=0
  For COL1=[M:DIA]LINSTR To [M:DIA]LINEND
   Gosub MAJPRN
   If GOK<1 : Break : Endif
  Next COL1
 Else
  COL1 = COL
  Gosub MAJPRN
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$MAJPRN
Readlock [TXD]TXD0 = [F:TXS]TXSNAM;NOL;COL1
If fstat=1
 GOK = -1 : GLOCK = "$TXSD"-[F:TXS]TXSNAM-num$(NOL)-num$(COL1) : Return
Elsif fstat
 GOK = 0 : Call RSTA("TXD",[F:TXS]TXSNAM-num$(NOL)-num$(COL1)) From GLOCK : Return
Endif
[F:TXD]FMTPRN = [M:DIA]FMTPRN
[F:TXD]EFFPRN = [M:DIA]EFFPRN
If varmode([M:DIA]DECCOL)=0
 [F:TXD]DECCOL = [M:DIA]DECCOL
Endif
Rewrite [TXD]
If fstat
 GOK = 0 : Call FSTA("TXD") From GLOCK : Return
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##########################################################################
## Ecran TXSAFMTC
##########################################################################
Subprog AS_LINSTR(VALEUR)
Variable Decimal VALEUR
End

Subprog C_LINSTR(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>[F:TXS]NBRCOL
 mkstat=1 : End
Endif
If VALEUR=0
 [M]STRNAM = '  "'+mess(30,109,1)+'"'
Else
 [M]STRNAM = '  "'+[M:TXM1]NAMCOL(VALEUR-1)+'"'
Endif
End

Subprog AS_LINEND(VALEUR)
Variable Decimal VALEUR
End

Subprog C_LINEND(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR<[M]LINSTR | VALEUR >[F:TXS]NBRCOL
 mkstat = 2 : End
Endif
If VALEUR=0
 [M]ENDNAM = '  "'+mess(30,109,1)+'"'
Else
 [M]ENDNAM = '  "'+[M:TXM1]NAMCOL(VALEUR-1)+'"'
Endif
End


