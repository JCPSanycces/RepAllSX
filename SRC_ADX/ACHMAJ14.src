#<AdxTL>@(#)11.0.0.0 $Revision$
#################################################################################
# ACHMAJ14 : Mises à jour à effectuer lors du passage à la v140   Module achats #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#                                                                               #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#   - PURTRS Table des transactions de saisie achats                            #
#     Initialisation des nouveaux champs                                        #
#     AOF (PTRTYP=1) PSDBUT,SELAVBUT,SELITFBUT,PSHFLG,PSHSCR,RSPFLG,RSPSCR,     #
#            FUPFLG,FUPSCR,FUPDATFLG,FUPDATSCR,PRNFLG,PRNSCR,ADDCOD,ADDSCR      #
#                                                                               #
#   - PORDER, PORDERQ, PORDERC                                                  #
#     Pour les contrats inter-sites existants uniquement                        #
#     Fichier PORDER                                                            #
#             BETCPY  : # Inter-sociétés                                        #
#             OCNNUM  : # numéro de commande vente                              #
#             OCNDAT  : # date de commande de vente                             #
#             OCNREM  : # libelle                                               #
#             STOFCY  : # Site d'expé                                           #
#             BPCORD  : # Client commande                                       #
#             SOHCAT  : # Catégorie commande vente                              #
#             DME     : # Livraison partielle                                   #
#     Fichier PORDERQ                                                           #
#             LINSTOFCY, LINOCNNUM,LINOCNDAT,OCNLIN,OCNSEQ                      #
#             Raz SOHNUM, SOPLIN, SOQSEQ                                        #
#     Fichier PORDERC                                                           #
#             STOFCY                                                            #
#                                                                               #
#   - UPORDER, UPORDERQ, UPORDERC                                               #
#     Pour les contrats inter-sites existants uniquement                        #
#     Fichier UPORDER                                                           #
#             BETFCY, BETCPY, STOFCY, SALFCY, OCNNUM, OCNDAT, OCNDAT            #
#     Fichier UPORDERQ                                                          #
#             LINSTOFCY, LINOCNNUM, LINOCNDAT, OCNLIN, OCNSEQ                   #
#             Raz SOHNUM, SOPLIN, SOQSEQ                                        #
#     Fichier UPORDERC                                                          #
#             BETFCY,STOFCY                                                     #
#                                                                               #
#   - PRECEIPT  Table entête réception fournisseur                              #
#     Initialisation du nouveau champ INVLINCTR et màj INVFLG                   #
#                                                                               #
#   - PRECEIPTD Table ligne de réception d'achat                                #
#     GROPRI, PRIREN, DISCRGVAL1 à 9, DISCRGREN1 à 9, SDHNUM, SDDLIN, MFGITM    #
#     OPENUM, MFGNUM, OPESPLNUM, QUAFLG, NETPRI, NETCUR, LINAMT, LINATIAMT      #
#     LINSTOFCY, RRRQTYPUU,RRRQTYSTU, CPRCOE, CLCAMT1, CLCAMT2                  #
#     STOMGTCOD, LINACC, LINCNA, UOMSTUCOE                                      #
#                                                                               #
#   - PRETURN  Table entête retour fournisseur                                  #
#     Initialisation des nouveaux champs BETCPY et BETFCY                       #
#                                                                               #
#   - PRETURND Table ligne retours fournisseurs                                 #
#     Suppression des champs UPDSTO et UPDORD                                   #
#     RTNREN devient le code de la table divers no 7                            #
#     RTNDES récupère le libellé motif retour contenu initialement dans RTNREN  #
#     UOMSTUCOE chargement du coefficient UC-US                                 #
#     GROPRI, PRIREN, DISCRGVAL1-9, DISCRGREN1-9, STOMGTCOD                     #
#                                                                               #
#   - PINVOICEV Table complément entête facture d'achat                         #
#     Initialisation du nouveau champ BETCPY                                    #
#                                                                               #
#   - PINVOICED Table ligne factures d'achat                                    #
#     POHNUM, POPLIN et POQSEQ sont chargés lorsque le type origine de la ligne #
#                              (TYPORI) est réception (2) ou retour (3)         #
#                                                                               #
#################################################################################


#################################################################################
# Moulinette Avant mise à jour concernant le module Achat                       #
#################################################################################
Subprog AACHMAJ14
End


#################################################################################
# Moulinette Après mise à jour concernant le module Achat                       #
#################################################################################
Subprog ACHMAJ14
If filinfo(filpath("FIL","PURTRS",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRETURND",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PINVOICED",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRECEIPTD",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRECEIPT",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDER",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERQ",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERC",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERP",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","ITMMASTER",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","ITMBPS",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","BPARTNER",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDER",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDERQ",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDERC",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRETURN",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","BPSUPPLIER",  "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","ATABIND",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GACCCODE",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","CACNA",       "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GACCOUNT",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GAUTACE",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GAUTACED",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","TABVAT",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","TABRATVAT",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","TABCUR",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If [F:ADS]MODULE(7)=2 : # si module GP présent
  If filinfo(filpath("FIL","OPERATIONS","fde",[F:ADS]DOSSIER),0) < 0  End : Endif
Endif
If [F:ADS]MODULE(5)=2 : # Si module vente présent
  If filinfo(filpath("FIL","BPDLVCUST", "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
  If filinfo(filpath("FIL","SORDER"   , "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
Endif
#-----
Gosub SET_FIRST   From TRTFIRST
Gosub AP_TRS : # Transactions de saisie
Gosub AP_POH : # Commandes d'achat
Gosub AP_UOH : # Historiques commandes d'achat
Gosub AP_PTH : # Entêtes réception
Gosub AP_PTD : # Lignes  réception
Gosub AP_PNH : # Entêtes retour
Gosub AP_PND : # Lignes  retour
Gosub AP_PIV : # Entêtes complémentaires factures d'achat
Gosub AP_PID : # Lignes factures d'achat
Gosub UNSET_FIRST From TRTFIRST
#-----
End


#---------------------------------------------------------------------#
# Initialisation transactions achats (initialisation nouveaux champs) #
#---------------------------------------------------------------------#
$AP_TRS
Local File =[F:ADS]DOSSIER+".PURTRS"     [PTR]
Local Libelle INDIC
#----- Transactions de saisie des appels d'offre -----#
Call ECR_TIME("DOSMAJ14 Purchase Transactions Process 1 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=1
    Raz INDIC
    If [F:PTR]PSHFLG   <1  | [F:PTR]PSHFLG>2     [F:PTR]PSHFLG=1    : INDIC=1 : Endif
    If [F:PTR]PSHSCR   <1  | [F:PTR]PSHSCR>3     [F:PTR]PSHSCR=1    : INDIC=1 : Endif
    If [F:PTR]QTYPICFLG<1  | [F:PTR]QTYPICFLG>2  [F:PTR]QTYPICFLG=1 : INDIC=1 : Endif
    If [F:PTR]QTYPICSCR<1  | [F:PTR]QTYPICSCR>3  [F:PTR]QTYPICSCR=1 : INDIC=1 : Endif
    If [F:PTR]RSPFLG   <1  | [F:PTR]RSPFLG>2     [F:PTR]RSPFLG=1    : INDIC=1 : Endif
    If [F:PTR]RSPSCR   <1  | [F:PTR]RSPSCR>3     [F:PTR]RSPSCR=1    : INDIC=1 : Endif
    If [F:PTR]FUPFLG   <1  | [F:PTR]FUPFLG>2     [F:PTR]FUPFLG=1    : INDIC=1 : Endif
    If [F:PTR]FUPSCR   <1  | [F:PTR]FUPSCR>3     [F:PTR]FUPSCR=1    : INDIC=1 : Endif
    If [F:PTR]FUPDATFLG<1  | [F:PTR]FUPDATFLG>2  [F:PTR]FUPDATFLG=1 : INDIC=1 : Endif
    If [F:PTR]FUPDATSCR<1  | [F:PTR]FUPDATSCR>3  [F:PTR]FUPDATSCR=1 : INDIC=1 : Endif
    If [F:PTR]PRNFLG   <1  | [F:PTR]PRNFLG>2     [F:PTR]PRNFLG=1    : INDIC=1 : Endif
    If [F:PTR]PRNSCR   <1  | [F:PTR]PRNSCR>3     [F:PTR]PRNSCR=1    : INDIC=1 : Endif
    If [F:PTR]NBRCOL   <1  | [F:PTR]NBRCOL>9     [F:PTR]NBRCOL =1   : INDIC=1 : Endif
    If [F:PTR]REQCOD   <1  | [F:PTR]REQCOD>3     [F:PTR]REQCOD=1    : INDIC=1 : Endif
    If [F:PTR]ORDREFCOD<1  | [F:PTR]ORDREFCOD>3  [F:PTR]ORDREFCOD=1 : INDIC=1 : Endif
    If [F:PTR]ITMDESCOD<1  | [F:PTR]ITMDESCOD>3  [F:PTR]ITMDESCOD=1 : INDIC=1 : Endif
    If [F:PTR]ITMDESSCR<1  | [F:PTR]ITMDESSCR>3  [F:PTR]ITMDESSCR=1 : INDIC=1 : Endif
    If [F:PTR]ITMDES1COD<1 | [F:PTR]ITMDES1COD>3 [F:PTR]ITMDES1COD=1: INDIC=1 : Endif
    If [F:PTR]ITMDES1SCR<1 | [F:PTR]ITMDES1SCR>3 [F:PTR]ITMDES1SCR=1: INDIC=1 : Endif
    If [F:PTR]PJTCOD   <1  | [F:PTR]PJTCOD>3     [F:PTR]PJTCOD=1    : INDIC=1 : Endif
    If [F:PTR]PJTSCR   <1  | [F:PTR]PJTSCR>3     [F:PTR]ADDSCR=1    : INDIC=1 : Endif
    If [F:PTR]ADDCOD   <1  | [F:PTR]ADDCOD>3     [F:PTR]ADDCOD=1    : INDIC=1 : Endif
    If [F:PTR]ADDSCR   <1  | [F:PTR]ADDSCR>3     [F:PTR]ADDSCR=1    : INDIC=1 : Endif
    If INDIC=1
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
#----- Transactions de saisie des commandes -----#
Call ECR_TIME("DOSMAJ14 Purchase Transactions Process 2 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=3
    Raz INDIC
    If [F:PTR]STOFCYCOD<1  | [F:PTR]STOFCYCOD>3  [F:PTR]STOFCYCOD=3 : INDIC=1 : Endif
    If [F:PTR]STOFCYSCR<1  | [F:PTR]STOFCYSCR>3  [F:PTR]STOFCYSCR=1 : INDIC=1 : Endif
    If [F:PTR]SCOADDCOD<1  | [F:PTR]SCOADDCOD>3  [F:PTR]SCOADDCOD=3 : INDIC=1 : Endif
    If [F:PTR]SCOADDSCR<1  | [F:PTR]SCOADDSCR>3  [F:PTR]SCOADDSCR=1 : INDIC=1 : Endif
    If INDIC=1
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
#----- Transactions de saisie des contrats -----#
Call ECR_TIME("DOSMAJ14 Purchase Transactions Process 3 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=5
    Raz INDIC
    If [F:PTR]STOFCYCOD<1  | [F:PTR]STOFCYCOD>3  [F:PTR]STOFCYCOD=1 : INDIC=1 : Endif
    If INDIC=1
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
Close Local File [PTR]
Return


#-------------------------------------------------------------------------#
# Alimentation des nouvelles zones du PORDER, PORDERQ, PORDERC            #
# ----------------------------------------------------------------------- #
# Fichier PORDER                                                          #
#         OCNNUM  : # numéro de commande vente  issu de ORDREF            #
#         OCNDAT  : # date de commande de vente issu de ORDDAT            #
#         OCNREM  : # libelle                                             #
#         BETCPY  : # inter-société                                       #
#         STOFCY  : # Site d'expé                                         #
#         BPCORD  : # Client commande issu de la commande                 #
#         DME     : # Livraison partielle                                 #
#         SOHCAT  : # Type commande vente                                 #
# Fichier PORDERQ                                                         #
#         LINSTOFCY : # Site d'expé. issu du site de vente SALFCY         #
#         LINOCNNUM : # Numéro de commande de vente issu de SOHNUM        #
#         LINOCNDAT : # Date de commande de vente issu date de commande   #
#         OCNLIN    : # Numéro de lg cde de vente issu SOPLIN             #
#         OCNSEQ    : # Numéro de seq cde de vente issu SOQSEQ            #
#         Raz SOHNUM, SOPLIN, SOQSEQ : zones réservées contremarque       #
# Fichier PORDERC                                                         #
#         LINSTOFCY : # Site d'expé. issu du site de vente de l'entête    #
#-------------------------------------------------------------------------#
$AP_POH
Local File =[F:ADS]DOSSIER+".PORDER"   [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"  [POQ]
Local File =[F:ADS]DOSSIER+".PORDERC"  [POC]
Local File =[F:ADS]DOSSIER+".BPARTNER" [BPR]
If [F:ADS]MODULE(5)=2
  Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR2]
  Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
  Local File =[F:ADS]DOSSIER+".SORDER"     [SOH]
Endif
#-----
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPOH), CRITERE(90)
#-----
Call ECR_TIME("DOSMAJ14 Purchase Order Process 1 : Update PORDER-Q-C") From DOSSUB
Raz CLE1, STOP
#-----
$BOUCLE_POH
If  STOP=1
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [POH],[POQ],[POC]
  For [POH] POH0 Where evalue(CRITERE)
    If [F:POH]BETFCY=0  [F:POH]BETFCY=1 : Endif
    If [F:POH]BETCPY=0  [F:POH]BETCPY=1 : Endif
    If [F:POH]POHTYP=2 & [F:POH]BETFCY=2
      If [F:POH]STOFCY=""
        [F:POH]STOFCY=[F:POH]SALFCY
      Endif
      If [F:POH]OCNNUM=""
        [F:POH]OCNNUM=[F:POH]ORDREF   : # Numéro de commande vente
      Endif
      [F:POH]OCNDAT=[F:POH]ORDDAT     : # Date de commande de vente
      [F:POH]OCNREM=mess(74,187,1)    : # Libelle
      If [F:SOH]SOHNUM<>[F:POH]OCNNUM
        Read [SOH] SOH0=[F:POH]OCNNUM : If fstat  Raz [F:SOH] : Endif
      Endif
      [F:POH]SOHCAT=[F:SOH]SOHCAT
      [F:POH]BPCORD=[F:SOH]BPCORD
      [F:POH]DME   =[F:SOH]DME
      If [F:POH]BETFCY=2 & [F:POH]POHTYP=2
        For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
          If [F:POQ]LINSTOFCY=""
            [F:POQ]LINSTOFCY=[F:POH]SALFCY
          Endif
          If [F:POQ]SOHNUM<>""
            [F:POQ]LINOCNNUM=[F:POQ]SOHNUM
          Endif
          [F:POQ]LINOCNDAT=[F:POQ]ORDDAT
          If [F:POQ]SOPLIN<>0
            [F:POQ]OCNLIN=[F:POQ]SOPLIN
          Endif
          If [F:POQ]SOQSEQ<>0
            [F:POQ]OCNSEQ=[F:POQ]SOQSEQ
          Endif
          Raz [F:POQ]SOHNUM, [F:POQ]SOPLIN, [F:POQ]SOQSEQ
          COMPTEUR+=1
          Rewrite [POQ]
          If fstat
            Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
          Endif
        Next 
        #----- Si les désignations article ou l'adresse site ne sont pas initialisées -----#
        For [POC] POC0 Where POHNUM=[F:POH]POHNUM
          [F:POC]STOFCY=[F:POH]SALFCY
          COMPTEUR+=1
          Rewrite [POC]
          If fstat
            Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
          Endif
        Next
      Elsif [F:POH]POHTYP=1
        Raz WNBR
        For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
          If [F:POQ]LINCLEFLG=2  WNBR+=1 : Endif   
        Next
        [F:POH]CLELINNBR=WNBR
        If [F:POH]CLELINNBR>=[F:POH]LINNBR 
          [F:POH]CLEFLG=2
        Else
          [F:POH]CLEFLG=1
        Endif
      Endif
    Endif
    COMPTEUR+=1
    Rewrite [POH]
    If fstat
      Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:POH]POHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP  Goto BOUCLE_POH : Endif
#-----
Close Local File [POH], [POQ], [POC], [BPR]
If [F:ADS]MODULE(5)=2
  Close Local File  [BPR2], [BPD], [SOH]
Endif
Return


#-------------------------------------------------------------------------#
# Alimentation des nouvelles zones du UPORDER, UPORDERQ, UPORDERC         #
# Pour les contrats inter-sites existants uniquement                      #
# ----------------------------------------------------------------------- #
# Fichier UPORDER                                                         #
#         OCNNUM  : # numéro de commande vente  issu de ORDREF            #
#         OCNDAT  : # date de commande de vente issu de ORDDAT            #
#         OCNREM  : # libelle                                             #
#         BETCPY  : # inter-société                                       #
#         BETFCY  : # inter-sites                                         #
#         STOFCY  : # site d'expé                                         #
#         SALFCY  : # site de vente                                       #
#         BPCORD  : # Client commande issu de la commande                 #
#         DME     : # Livraison partielle                                 #
#         SOHCAT  : # Type commande vente                                 #
# Fichier UPORDERQ                                                        #
#         LINSTOFCY : # Site d'expé. issu du site de vente SALFCY         #
#         LINOCNNUM : # Numéro de commande de vente issu de SOHNUM        #
#         LINOCNDAT : # Date de commande de vente issu date de commande   #
#         OCNLIN    : # Numéro de lg cde de vente issu SOPLIN             #
#         OCNSEQ    : # Numéro de seq cde de vente issu SOQSEQ            #
#         Raz SOHNUM, SOPLIN, SOQSEQ : zones réservées contremarque       #
# Fichier UPORDERC                                                        #
#         LINSTOFCY : # Site d'expé. issu du site de vente de l'entête    #
#-------------------------------------------------------------------------#
$AP_UOH
Local File =[F:ADS]DOSSIER+".PORDER"   [POH]
Local File =[F:ADS]DOSSIER+".UPORDER"  [UOH]
Local File =[F:ADS]DOSSIER+".UPORDERQ" [UOQ]
Local File =[F:ADS]DOSSIER+".UPORDERC" [UOC]
Local File =[F:ADS]DOSSIER+".BPARTNER" [BPR]
If [F:ADS]MODULE(5)=2
  Local File =[F:ADS]DOSSIER+".SORDER"     [SOH]
Endif
#-----
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONPOH), CRITERE(90)
Local Integer  CLE2
#-----
Call ECR_TIME("DOSMAJ14 Purchase Order Process 2 : Update UPORDER-Q-C") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_UOH
If  STOP=1
  CRITERE = 'POHNUM="'+CLE1+'" & REVNUM>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [UOH],[UOQ],[UOC]
  For [UOH] POH0 Where evalue (CRITERE)
    If [F:POH]POHNUM<>[F:UOH]POHNUM
      Read [POH]POH0=[F:UOH]POHNUM : If fstat  Raz [F:POH] : Endif
    Endif
    If [F:POH]POHNUM<>""
      If [F:UOH]BETFCY<>[F:POH]BETFCY | [F:UOH]BETCPY<>[F:POH]BETCPY
        [F:UOH]BETFCY=[F:POH]BETFCY
        [F:UOH]BETCPY=[F:POH]BETCPY
      Endif
      If [F:UOH]BETFCY=2 & [F:UOH]POHTYP=2
        [F:UOH]BPCORD=[F:POH]BPCORD
        [F:UOH]SOHCAT=[F:POH]SOHCAT
        [F:UOH]DME   =[F:POH]DME
        If [F:UOH]STOFCY=""
          [F:UOH]STOFCY=[F:POH]STOFCY
        Endif
        If [F:UOH]SALFCY=""
          [F:UOH]SALFCY=[F:POH]SALFCY
        Endif
        [F:UOH]OCNNUM=[F:UOH]ORDREF   : # Numéro de commande vente
        [F:UOH]OCNDAT=[F:UOH]ORDDAT   : # Date de commande de vente
        [F:UOH]OCNREM=mess(74,187,1)  : # Libelle
        For [UOQ] POQ0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
          If [F:UOQ]LINSTOFCY=""
            [F:UOQ]LINSTOFCY=[F:POH]SALFCY
          Endif
          If [F:UOQ]SOHNUM<>""
            [F:UOQ]LINOCNNUM=[F:UOQ]SOHNUM
          Endif
          [F:UOQ]LINOCNDAT=[F:UOQ]ORDDAT
          If [F:UOQ]SOPLIN<>0
            [F:UOQ]OCNLIN=[F:UOQ]SOPLIN
          Endif
          If [F:UOQ]SOQSEQ<>0
            [F:UOQ]OCNSEQ=[F:UOQ]SOQSEQ
          Endif
          Raz [F:UOQ]SOHNUM, [F:UOQ]SOPLIN, [F:UOQ]SOQSEQ
          COMPTEUR+=1
          Rewrite [UOQ]
          If fstat
            Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
          Endif
        Next 
        #----- Si les désignations article ou l'adresse site ne sont pas initialisées -----#
        For [UOC] POC0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
          If [F:UOC]BETFCY=0
            [F:UOC]BETFCY=[F:UOH]BETFCY
          Endif
          If [F:UOC]STOFCY=""
            [F:UOC]STOFCY=[F:UOH]SALFCY
          Endif
          COMPTEUR+=1
          Rewrite [UOC]
          If fstat
            Call ECR_TRACE("File UPORDERC, Error ="-num$(fstat),1) From GESECRAN
          Endif
        Next
      Endif
    Endif
    COMPTEUR+=1
    Rewrite [UOH]
    If fstat
      Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:UOH]POHNUM : CLE2=[F:UOH]REVNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_UOH : Endif
#-----
Close Local File [POH], [UOH], [UOQ], [UOC], [BPR]
If [F:ADS]MODULE(5)=2
  Close Local File [SOH]
Endif
Return


#---------------------------------------------------------------------------#
# Chargement du nombre de lignes facturées INVLINCTR dans la table PRECEIPT #
# Mise à jour de l'indicateur "Facturée"   INVFLG    dans la table PRECEIPT #
#---------------------------------------------------------------------------#
$AP_PTH
Local File =[F:ADS]DOSSIER+".PRECEIPT"   [PTH]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
#-----
Local Char     CLE1(GLONPTH)
Local Integer  COMPTEUR
Local Libelle  STOP
#-----
Call ECR_TIME("DOSMAJ14 Purchase Receipt Process 1 : Update PRECEIPT") From DOSSUB
Raz CLE1, STOP
#-----
$BOUCLE_PTH
If STOP=1
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PTH]
  For [PTH] PTH0 Where evalue(CRITERE)
    If [F:PTH]BETFCY=0  [F:PTH]BETFCY=1 : Endif
    If [F:PTH]BETCPY=0  [F:PTH]BETCPY=1 : Endif
    Raz [F:PTH]INVLINCTR
    For [PTD] Where PTHNUM=[F:PTH]PTHNUM & INVQTYPUU<>0
      [F:PTH]INVLINCTR+=1
    Next
    #----- Ne pas modifier l'indicateur si valeur = totalement facturé ! -----#
    If [F:PTH]INVFLG<>3
      If [F:PTH]LINNBR<=[F:PTH]INVLINNBR
        [F:PTH]INVFLG=3
      Elsif [F:PTH]INVLINNBR<>0 | [F:PTH]INVLINCTR<>0
        [F:PTH]INVFLG=2
      Else
        [F:PTH]INVFLG=1
      Endif
    Endif
    #----- Réécriture de l'entête de réception -----#
    COMPTEUR+=1
    Rewrite [PTH]
    If fstat
      Call ECR_TRACE("File PRECEIPT, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTH]PTHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PTH : Endif
#-----
Close Local File [PTH], [PTD]
Return


#-------------------------------------------------------------------------#
# Alimentation des nouvelles zones table PRECEIPTD                        #
# ----------------------------------------------------------------------- #
# GROPRI         : Prix brut   Repris de la commande si on en a un POP    #
# PRIREN         : Motif prix  Repris de la commande si on en a un POP    #
# DISCRGVAL1 à 9               Repris de la commande si on en a un POP    #
# DISCRGREN1 à 9               Repris de la commande si on en a un POP    #
# SDHNUM         : N.Livraison Issu de la commande POQ                    #
# SDDLIN         : Lg Livrais  Issu de la commande POQ                    #
# MFGITM         : Art lancé   Issu de la commande POQ                    #
# OPENUM         : Opération   Issu de la commande POQ                    #
# MFGNUM         : No ordre    Issu de la commande POQ                    #
# OPESPLNUM      : Frac opé    Issu de l'opération OPS                    #
# UOMSTUCOE      : Coeff       UOM-STU                                    #
# QUAFLG         : Soumis CTL  Issu de la commande POP,si pas de commande #
#                              issu de l'article fourni ou article        #
# NETPRI                       Calculé à partir du NETPRIPUU de la récept #
#                              et du coeff UOMPUUCOE de la réception      #
# NETCUR         : Devise      Si non renseigné issu de la commande POQ   #
#                              ou de l'entête de réception                #
# LINAMT         : Montant HT  Calculé                                    #
# LINATIAMT      : Montant TTC Calculé                                    #
# LINSTOFCY      : Site d'exp  Pour intersite seulement                   #
#                              Reprise du site lié au fournisseur         #
# RRRQTYPUU      : Raz pour les articles gérés en stock                   #
# RRRQTYSTU      : Raz pour les articles gérés en stock                   #
# CPRCOE         : Initialisation à 1 si on a 0                           #
# CLCAMT1        : Base taxe1 Issu de la commande POQ                     #
# CLCAMT2        : Base taxe2 Issu de la commande POQ                     #
# STOMGTCOD      : Issu de ITM                                            #
# LINACC         : Issu de POQ                                            #
# LINCNA         : Issu de POQ                                            #
#-------------------------------------------------------------------------#
$AP_PTD
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
Local File =[F:ADS]DOSSIER+".PRECEIPT"    [PTH]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"     [POP]
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
Local File =[F:ADS]DOSSIER+".ITMBPS"      [ITP]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR]
Local File =[F:ADS]DOSSIER+".PORDER"      [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [TB1]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
#-----  Pour Call COMPTE sinon on ouvre pas les bons ! -----#
Local File =[F:ADS]DOSSIER+".ATABIND"     [ATI]
Local File =[F:ADS]DOSSIER+".GACCCODE"    [CAC]
Local File =[F:ADS]DOSSIER+".CACNA"       [CNA]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
Local File =[F:ADS]DOSSIER+".GAUTACE"     [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"    [GAD]
#----- Pour Call CLCTAXEMNT et ARRDEV -----#
Local File =[F:ADS]DOSSIER+".TABVAT"      [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"   [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
#-----
If [F:ADS]MODULE(7)=2 : # si GP
  Local File =[F:ADS]DOSSIER+".OPERATIONS"  [OPS]
Endif
#-----
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONPTH), CRITERE(90)
Local Integer  CLE2
Local Decimal  WCOEFF
Local Char     VAT(GLONVAT)(3) # FGR 12/11/2009 : X3SUIVI59766 : plus (3)
Local Char     WCOMPTE(GLONGAC)
Local Char     WNATURE(GLONCNA)
Local Char     WID1(20)(1..1)
Local Char     WID2(20)(1..3)
Local Integer  WRET, I
#-----
Call ECR_TIME("DOSMAJ14 Purchase Receipt Process 2 : Update PRECEIPTD") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_PTD
If STOP=1
  CRITERE='PTHNUM="'+CLE1+'" & PTDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PTD]
  For [PTD] PTD0 Where evalue(CRITERE)
    #----- Calcul du coefficient UOM/STU -----#
    If [F:PTD]QTYUOM<>0 & [F:PTD]UOMSTUCOE=0
      [F:PTD]UOMSTUCOE=arr([F:PTD]QTYSTU/[F:PTD]QTYUOM,0.000001)
    Endif
    If [F:PTD]PRHFCY<>GFCY
      GFCY=[F:PTD]PRHFCY
      Call DEFSITE(GFCY)  From TRTACHDEF1
    Endif   
    #----- Lecture entête commande si nécessaire -----# 
    If [F:POH]POHNUM<>[F:PTD]POHNUM & [F:PTD]POHNUM<>""
      Raz [F:POQ] : Raz [F:POP]
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat
        Raz [F:POH]
        Call ECR_TRACE("File PORDER"-[F:PTD]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif 
    #----- Lecture ligne commande quantités si nécessaire -----#
    If [F:POH]POHNUM<>"" & [F:PTD]POPLIN<>0
      If [F:POH]BETFCY<>2
        If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&          [F:POQ]POPLIN<>[F:PTD]POPLIN |
&          [F:POQ]POQSEQ<>[F:PTD]POQSEQ
          Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
          If fstat
            Raz [F:POQ]
            Call ECR_TRACE("File PORDERQ"-[F:POH]POHNUM-num$([F:PTD]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Endif
      Else
        If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&          [F:POQ]POPLIN<>[F:PTD]POPLIN |
&          [F:POQ]PTHNUM<>[F:PTD]PTHNUM |
&          [F:POQ]PTDLIN<>[F:PTD]PTDLIN |
&          [F:POQ]ITMREF<>[F:PTD]ITMREF
          Raz [F:POQ]
          For [POQ] POQ0 Where POHNUM=[F:PTD]POHNUM
&                            & POPLIN=[F:PTD]POPLIN
&                            & PTHNUM=[F:PTD]PTHNUM
&                            & PTDLIN=[F:PTD]PTDLIN
&                            & ITMREF=[F:PTD]ITMREF
            Break
          Next
        Endif
      Endif
    Endif
    If [F:POH]POHNUM<>"" & [F:POQ]POHNUM<>""
      #----- Lecture ligne commande prix si nécessaire -----#
      If [F:POH]POHTYP<>2
        If [F:POP]POHNUM<>[F:PTD]POHNUM | [F:POP]POPLIN<>[F:PTD]POPLIN
&        | [F:POP]POPSEQ<>1
         Read [POP] POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;1
         If fstat  Raz [F:POP] : Endif
        Endif
      Else
         Filter [POP] Where POHNUM =[F:PTD]POHNUM
&                         & POPLIN =[F:PTD]POPLIN
&                         & POPDAT>=[F:POQ]DEMRCPDAT
         Read [POP] POP1 First
         Filter [POP] 
         If fstat  Raz [F:POP]  : Endif
      Endif
    Else 
      Raz [F:POP]
    Endif
    If [F:ITM]ITMREF<>[F:PTD]ITMREF
      Read [ITM] ITM0=[F:PTD]ITMREF
      If fstat
        Raz [F:ITM]
        Call ECR_TRACE("File ITMMASTER"-[F:PTD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
      Endif 
    Endif
    If [F:ITP]ITMREF<>[F:PTD]ITMREF | [F:ITP]BPSNUM<>[F:PTH]BPSNUM
      Read [ITP] ITP0=[F:PTD]ITMREF;[F:PTH]BPSNUM
      If fstat  Raz [F:ITP] : Endif
    Endif 
    #----- On a une commande -----#
    If [F:PTD]POHNUM<>""
      #----- On a un POP récupération des prix -----#
      If [F:POP]POHNUM<>""
        [F:PTD]PRIREN    =[F:POP]PRIREN
        [F:PTD]DISCRGVAL1=[F:POP]DISCRGVAL1
        [F:PTD]DISCRGVAL2=[F:POP]DISCRGVAL2
        [F:PTD]DISCRGVAL3=[F:POP]DISCRGVAL3
        [F:PTD]DISCRGVAL4=[F:POP]DISCRGVAL4
        [F:PTD]DISCRGVAL5=[F:POP]DISCRGVAL5
        [F:PTD]DISCRGVAL6=[F:POP]DISCRGVAL6
        [F:PTD]DISCRGVAL7=[F:POP]DISCRGVAL7
        [F:PTD]DISCRGVAL8=[F:POP]DISCRGVAL8
        [F:PTD]DISCRGVAL9=[F:POP]DISCRGVAL9
        [F:PTD]DISCRGREN1=[F:POP]DISCRGREN1
        [F:PTD]DISCRGREN2=[F:POP]DISCRGREN2
        [F:PTD]DISCRGREN3=[F:POP]DISCRGREN3
        [F:PTD]DISCRGREN4=[F:POP]DISCRGREN4
        [F:PTD]DISCRGREN5=[F:POP]DISCRGREN5
        [F:PTD]DISCRGREN6=[F:POP]DISCRGREN6
        [F:PTD]DISCRGREN7=[F:POP]DISCRGREN7
        [F:PTD]DISCRGREN8=[F:POP]DISCRGREN8
        [F:PTD]DISCRGREN9=[F:POP]DISCRGREN9
        If [F:ITP]ITMREF<>""
          [F:PTD]QUAFLG=[F:ITP]QUAFLG
        Else
          [F:PTD]QUAFLG=[F:ITM]QUAFLG
        Endif
        If [F:PTD]QUAFLG<>2
          If [F:POP]QUAFLG=2  [F:PTD]QUAFLG=3  Else  [F:PTD]QUAFLG=1 : Endif
        Endif
        [F:PTD]NETPRI    =[F:POP]NETPRI
        If [F:POQ]QTYUOM<>0
          WCOEFF=arr([F:POQ]QTYSTU/[F:POQ]QTYUOM,0.000001)
        Else
          [F:POQ]QTYUOM=[F:POQ]QTYSTU
          WCOEFF=1
        Endif
        If WCOEFF=0            WCOEFF=1           : Endif
        If [F:PTD]UOMSTUCOE=0  [F:PTD]UOMSTUCOE=1 : Endif
        If WCOEFF=[F:PTD]UOMSTUCOE
          [F:PTD]GROPRI=arr([F:POP]GROPRI,10^-GDECPRI)
        Else
          [F:PTD]GROPRI=arr([F:POP]GROPRI/WCOEFF*[F:PTD]UOMSTUCOE,10^-GDECPRI)
          [F:PTD]NETPRI=[F:PTD]GROPRI   
          If [F:BPS]BPSNUM<>[F:PTD]BPSNUM
            Read [BPS] BPS0=[F:PTD]BPSNUM : If fstat  Raz [F:BPS] : Endif
          Endif
          Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
          For I=0 To 8
            If GNPRNOTFLG(I)=2
              Assign "[F:PTD]DISCRGVAL"+num$(I+1) With 0
            Endif
          Next I
        Endif
      Endif
      #----- Récupération des numéros livraison (inter-sites) -----#
      [F:PTD]SDHNUM   =[F:POQ]SDHNUM
      [F:PTD]SDDLIN   =[F:POQ]SDDLIN
      If [F:POQ]SDHNUM<>"" & [F:POQ]SDDLIN<>0
        If [F:BPR]BPRNUM<>[F:PTD]BPSNUM
          Read [BPR] BPR0=[F:PTD]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:PTD]LINSTOFCY=[F:BPR]FCY
      Endif
      [F:PTD]MFGITM   =[F:POQ]MFGITM
      [F:PTD]OPENUM   =[F:POQ]OPENUM
      [F:PTD]MFGNUM   =[F:POQ]MFGNUM
      [F:PTD]CLCAMT1  =[F:POQ]CLCAMT1
      [F:PTD]CLCAMT2  =[F:POQ]CLCAMT2
      [F:PTD]LINCNA   =[F:POQ]LINCNA
      [F:PTD]LINACC   =[F:POQ]LINACC
      [F:PTD]LINPURTYP=[F:POQ]LINPURTYP
      #------ Lecture de l'opération -----#
      If [F:PTD]MFGNUM<>"" & [F:PTD]OPENUM<>0
        Read [OPS] OPS2=[F:PTD]POHNUM;[F:PTD]POPLIN;1 : If fstat  Raz [F:OPS] : Endif
        [F:PTD]OPESPLNUM=[F:OPS]OPESPLNUM
      Endif
    Endif
    If [F:PTD]QUAFLG=0
      If [F:ITP]ITMREF<>""
        [F:PTD]QUAFLG=[F:ITP]QUAFLG
      Else
        [F:PTD]QUAFLG=[F:ITM]QUAFLG
      Endif
    Endif
    [F:PTD]STOMGTCOD=[F:ITM]STOMGTCOD
    If [F:PTD]NETPRIPUU<>0
      If [F:PTD]NETCUR="" & [F:POH]POHNUM<>""
        [F:PTD]NETCUR=[F:POH]CUR
      Else
        If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
          Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
        Endif
        [F:PTD]NETCUR=[F:PTH]CUR
      Endif
      [F:PTD]NETPRI=arr([F:PTD]NETPRIPUU*[F:PTD]UOMPUUCOE,10^-GDECPRI)
      [F:PTD]LINAMT=[F:PTD]NETPRI*[F:PTD]QTYUOM
      VAT(0)=[F:PTD]VAT(0) : VAT(1)=[F:PTD]VAT(1) : VAT(2)=[F:PTD]VAT(2)
      [F:PTD]LINAMT=[F:PTD]NETPRI*[F:PTD]QTYUOM
      Call ARRDEV([F:PTD]LINAMT,[F:PTD]NETCUR) From TRTDIV
      If GSOCIETE<>""
        Call CLCTAXEMNT([F:PTD]LINAMT,VAT,1,GSOCIETE,[F:PTD]RCPDAT,[F:PTD]CLCAMT1,
&                       [F:PTD]CLCAMT2,[F:PTD]LINATIAMT) From TRTX3
        Call ARRDEV([F:PTD]LINATIAMT,[F:PTD]NETCUR) From TRTDIV
      Endif
    Endif
    If [F:PTD]RRRQTYPUU<>0
      If [F:ITM]STOMGTCOD<2
        Call PCAL_QTY([F:PTD]RRRQTYPUU,[F:PTD]PUU,[F:PTD]RRRQTYSTU,[F:ITM]STU,
&                     [F:ITM]ITMREF,[F:PTD]BPSNUM,1,GBIDD3) From TRTACHQTE1
      Else
        Raz [F:PTD]RRRQTYPUU
        Raz [F:PTD]RRRQTYSTU
      Endif
    Endif
    If [F:PTD]CPRCOE=0  [F:PTD]CPRCOE=1         : Endif
    #----- Récupération compte et nature si nécessaire -----#
    If [F:PTD]LINACC="" | [F:PTD]LINPURTYP=0
      If [F:PTD]LINPURTYP=0  [F:PTD]LINPURTYP=1 : Endif
      #----- Récupération uniquement si le traitement pièce auto existe -----#
      #If filinfo(filpath("TRT","WMGAUPORD","adx",[F:ADS]DOSSIER),0)>0
      #  If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
      #    Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz  [F:PTH] : Endif
      #  Endif
      #  [F:TB0]=[F:PTH]
      #  [F:TB1]=[F:PTD]
      #  Raz [F:POP]
      #  [F:POP]=[F:PTD]
      #  Raz WID1,WID2
      #  Raz  WCOMPTE, WNATURE
      #  Call COMPTE("PORD",1,WID1,WID2,WCOMPTE,WNATURE,WRET) From CPTCOD
      #  If !WRET
      #    If WCOMPTE<>""
      #      [F:PTD]LINACC=WCOMPTE
      #      [F:PTD]LINCNA=WNATURE
      #    Endif
      #    If [F:GAC]ACC<>[F:PTD]LINACC
      #      Read [GAC] GAC0=[F:PTD]LINACC : If fstat Raz [F:GAC] : Endif
      #    Endif
      #    If [F:GAC]VATIPT=5
      #      [F:PTD]LINPURTYP=3
      #    Elsif [F:GAC]VATIPT=4
      #      [F:PTD]LINPURTYP=2
      #    Else
      #      [F:PTD]LINPURTYP=1
      #    Endif
      #  Endif
      #Endif
    Endif
    COMPTEUR+=1
    Rewrite [PTD]
    If fstat
      Call ECR_TRACE("File PRECEITPD"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)+
&                    ", Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTD]PTHNUM : CLE2=[F:PTD]PTDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PTD : Endif
#-----
Close Local File [PTD], [PTH], [POH], [POQ], [POP], [ITM], [ITP], [TB0], [TB1], [BPS]
Close Local File [ATI], [CAC], [CNA], [GAC], [GAU], [GAD], [TVT], [TRA], [TCU]
If [F:ADS]MODULE(7)=2 : # si GP
  Close Local File [OPS]
Endif
Return


#----------------------------------------------------------------#
# Initialisation des zone BETCPY et BETFCY dans la table PRETURN #
#----------------------------------------------------------------#
$AP_PNH
Local File =[F:ADS]DOSSIER+".PRETURN"   [PNH]
#-----
Local Char     CLE1(GLONPNH)
Local Integer  CLE2, COMPTEUR
Local Libelle  STOP
#-----
Call ECR_TIME("DOSMAJ14 Purchase Return Process 1 : Update PRETURN") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_PNH
If STOP=1
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE+=' & (BETFCY=0 | BETCPY=0)'
Raz COMPTEUR
Trbegin [PNH]
  For [PNH] PNH0 Where evalue(CRITERE)
    If [F:PNH]BETFCY=0  [F:PNH]BETFCY=1 : Endif
    If [F:PNH]BETCPY=0  [F:PNH]BETCPY=1 : Endif
    #----- Réécriture de la ligne de retour fournisseur -----#
    COMPTEUR+=1
    Rewrite [PNH]
    If fstat
      Call ECR_TRACE("File PRETURN, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PNH]PNHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PNH : Endif
#-----
Close Local File [PNH]
Return


#---------------------------------------------------------------#
# Mise à jour lignes retours fournisseurs, table PRETURND       #
# ------------------------------------------------------------- #
# - Récupération du libellé motif retour                        #
#   RTNDES       : Libellé du motif     Récupéré de RTNREN      #
# - Alimentation des nouveaux champs                            #
#   UOMSTUCOE    : Coef UOM/US          Calculé                 #
#   GROPRI       : Prix unitaire        Repris de la réception  #
#   PRIREN       : Motif prix           Repris de la réception  #
#   DISCRGVAL1-9 : Frais/remises        Repris de la réception  #
#   DISCRGREN1-9 : Motif frais/remises  Repris de la réception  #
#   NETPRI       : Prix unitaire net    Repris de la réception  #
#   LINAMT       : Mt ligne HT          Calculé                 #
#   LINATIAMT    : Mt ligne TTC         Calculé                 #
#   CLCAMT1      : Base 1 calcul taxe   Aucune action           #
#   CLCAMT2      : Base 2 calcul taxe   Aucune action           #
#   LINACC       : Compte général       Repris de la réception  #
#   LINCNA       : Nature analytique    Repris de la réception  #
#   LINPURTYP    : Type d'achat         Repris de la réception  #
#   STOMGTCOD    : Gestion stock        Repris de l'article     #
#---------------------------------------------------------------#
$AP_PND
Local File =[F:ADS]DOSSIER+".PRETURN"    [PNH]
Local File =[F:ADS]DOSSIER+".PRETURND"   [PND]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".PORDER"     [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [TB1]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local File =[F:ADS]DOSSIER+".GACCOUNT"   [GAC]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
#-----  Pour Call COMPTE -----#
Local File =[F:ADS]DOSSIER+".ATABIND"    [ATI]
Local File =[F:ADS]DOSSIER+".GACCCODE"   [CAC]
Local File =[F:ADS]DOSSIER+".CACNA"      [CNA]
Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
#----- Pour Call CLCTAXEMNT et ARRDEV -----#
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
#-----
Local Char     CLE1(GLONPNH)
Local Integer  CLE2, COMPTEUR, I
Local Libelle  STOP
Local Char     WCOMPTE(GLONGAC)
Local Char     WNATURE(GLONCNA)
Local Char     WID1(20)(1..1)
Local Char     WID2(20)(1..3)
Local Integer  WRET, I
#-----
Call ECR_TIME("DOSMAJ14 Purchase Return Process 2 : Update PRETURND") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_PND
If STOP=1
  CRITERE='PNHNUM="'+CLE1+'" & PNDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PND]
  For [PND] PND0 Where evalue(CRITERE) & ((RTNREN<>"" & RTNDES="") | UOMSTUCOE=0)
    #----- Récupération libellé du motif de retour -----#
    If [F:PND]RTNREN<>""  [F:PND]RTNDES=[F:PND]RTNREN : Endif
    Raz [F:PND]RTNREN
    #----- Calcul du coefficient UOM/STU -----#
    If [F:PND]QTYUOM<>0
      [F:PND]UOMSTUCOE=arr([F:PND]QTYSTU/[F:PND]QTYUOM,0.000001)
    Else
      [F:PND]UOMSTUCOE=1
    Endif
    #----- Si retour sur réception, récupération valeurs de la réception -----#
    If [F:PND]PTHNUM<>""
      If [F:PTD]PTHNUM<>[F:PND]PTHNUM | [F:PTD]PTDLIN<>[F:PND]PTDLIN
        Read [PTD] PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN : If fstat  Raz [F:PTD] : Endif
      Endif
      [F:PND]GROPRI    =[F:PTD]GROPRI
      [F:PND]PRIREN    =[F:PTD]PRIREN
      [F:PND]DISCRGVAL1=[F:PTD]DISCRGVAL1
      [F:PND]DISCRGVAL2=[F:PTD]DISCRGVAL2
      [F:PND]DISCRGVAL3=[F:PTD]DISCRGVAL3
      [F:PND]DISCRGVAL4=[F:PTD]DISCRGVAL4
      [F:PND]DISCRGVAL5=[F:PTD]DISCRGVAL5
      [F:PND]DISCRGVAL6=[F:PTD]DISCRGVAL6
      [F:PND]DISCRGVAL7=[F:PTD]DISCRGVAL7
      [F:PND]DISCRGVAL8=[F:PTD]DISCRGVAL8
      [F:PND]DISCRGVAL9=[F:PTD]DISCRGVAL9
      [F:PND]DISCRGREN1=[F:PTD]DISCRGREN1
      [F:PND]DISCRGREN2=[F:PTD]DISCRGREN2
      [F:PND]DISCRGREN3=[F:PTD]DISCRGREN3
      [F:PND]DISCRGREN4=[F:PTD]DISCRGREN4
      [F:PND]DISCRGREN5=[F:PTD]DISCRGREN5
      [F:PND]DISCRGREN6=[F:PTD]DISCRGREN6
      [F:PND]DISCRGREN7=[F:PTD]DISCRGREN7
      [F:PND]DISCRGREN8=[F:PTD]DISCRGREN8
      [F:PND]DISCRGREN9=[F:PTD]DISCRGREN9
      [F:PND]NETPRI    =[F:PTD]NETPRI
      [F:PND]LINACC    =[F:PTD]LINACC
      [F:PND]LINCNA    =[F:PTD]LINCNA
      [F:PND]LINPURTYP =[F:PTD]LINPURTYP
      #----- Conversion tarif si coefficients unités différents -----#
      If [F:PND]UOMSTUCOE<>[F:PTD]UOMSTUCOE
        #VPO 17/01/11 70790
        If [F:PND]UOMPUUCOE=0 
            #----- Calcul du coefficient UOM/PUU -----#
            If [F:PND]QTYPUU<>0
              [F:PND]UOMPUUCOE=arr([F:PND]QTYPUU/[F:PND]QTYUOM,0.000001)
            Else
              [F:PND]UOMPUUCOE=1
            Endif
        Endif
        [F:PND]NETPRI=arr([F:PND]NETPRI*[F:PTD]UOMPUUCOE/[F:PND]UOMPUUCOE,10^-GDECPRI)
        [F:PND]GROPRI=[F:PND]NETPRI
        If [F:BPS]BPSNUM<>[F:PND]BPSNUM
          Read [BPS] BPS0=[F:PND]BPSNUM : If fstat  Raz [F:BPS] : Endif
        Endif
        Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
        For I=0 To 8
          If GNPRNOTFLG(I)=2
            Assign "[F:PND]DISCRGVAL"+num$(I+1) With 0
          Endif
        Next I
      Endif
      #----- Calcul montant ligne HT et TTC -----#
      [F:PND]LINAMT=[F:PND]NETPRI*[F:PND]QTYUOM
      Call ARRDEV([F:PND]LINAMT,[F:PND]NETCUR)   From TRTDIV
      Call GETSOC([F:PND]PNHFCY) From DEVSUB
      Call CLCTAXEMNT([F:PND]LINAMT,[F:PND]VAT,1,GSOCIETE,[F:PND]RTNDAT,[F:PND]CLCAMT1,
&                     [F:PND]CLCAMT2,[F:PND]LINATIAMT) From TRTX3
      Call ARRDEV([F:PND]LINATIAMT,[F:PND]NETCUR) From TRTDIV
    Endif
    #----- Récupération compte et nature si nécessaire -----#
    If [F:PND]LINACC="" | [F:PND]LINPURTYP=0
      If [F:PTD]LINPURTYP=0  [F:PTD]LINPURTYP=1 : Endif
      #----- Récupération uniquement si le traitement pièce auto existe -----#
      #If filinfo(filpath("TRT","WMGAUPORD","adx",[F:ADS]DOSSIER),0)>0
      #  If [F:PNH]PNHNUM<>[F:PND]PNHNUM
      #    Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz  [F:PNH] : Endif
      #  Endif
      #  [F:TB0]=[F:PNH]
      #  [F:TB1]=[F:PND]
      #  [F:POP]=[F:PND]
      #  WID1(1)=[F:PND]POHNUM
      #  WID2(1)=[F:PND]POHNUM
      #  WID2(2)=num$([F:PND]POPLIN)
      #  WID2(3)=num$([F:PND]POQSEQ)
      #  Call COMPTE("PORD",1,WID1,WID2,WCOMPTE,WNATURE,WRET) From CPTCOD
      #  If !WRET
      #    If WCOMPTE<>""
      #      [F:PND]LINACC=WCOMPTE
      #      [F:PND]LINCNA=WNATURE
      #    Endif
      #    If [F:GAC]ACC<>[F:PND]LINACC
      #      Read [GAC] GAC0=[F:PND]LINACC : If fstat Raz [F:GAC] : Endif
      #    Endif
      #    If [F:GAC]VATIPT=5
      #      [F:PND]LINPURTYP=3
      #    Elsif [F:GAC]VATIPT=4
      #      [F:PND]LINPURTYP=2
      #    Else
      #      [F:PND]LINPURTYP=1
      #    Endif
      #  Endif
      #Endif
    Endif
    #----- Récupération code gestion stock -----#
    If [F:ITM]ITMREF<>[F:PND]ITMREF
      Read [ITM] ITM0=[F:PND]ITMREF : If fstat  Raz [F:ITM] : Endif
    Endif
    [F:PND]STOMGTCOD=[F:ITM]STOMGTCOD
    #----- Réécriture de la ligne de retour fournisseur -----#
    COMPTEUR+=1
    Rewrite [PND]
    If fstat
      Call ECR_TRACE("File PRETURND, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PND]PNHNUM : CLE2=[F:PND]PNDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PND : Endif
#-----
Close Local File [PNH], [PND], [PTD], [BPS], [TB0], [TB1], [POP], [ITM]
Close Local File [ATI], [CAC], [CNA], [GAC], [GAU], [GAD], [TVT], [TRA], [TCU]
Return


#----------------------------------------------------------#
# Initialisation de la zone BETCPY dans la table PINVOICEV #
#----------------------------------------------------------#
$AP_PIV
Local File =[F:ADS]DOSSIER+".PINVOICEV"   [PIV]
#-----
Local Char     CLE1(GLONPIH)
Local Integer  CLE2, COMPTEUR
Local Libelle  STOP
Call ECR_TIME("DOSMAJ14 Purchase Invoice Process 1 : Update PINVOICEV") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_PIV
If STOP=1
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE+=' & (BETCPY=0)'
Raz COMPTEUR
Trbegin [PIV]
  For [PIV] PIV0 Where evalue(CRITERE)
    If [F:PIV]BETCPY=0 : [F:PIV]BETCPY=1 : Endif
    #----- Réécriture de la ligne de retour fournisseur -----#
    COMPTEUR+=1
    Rewrite [PIV]
    If fstat
      Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PIV]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PIV : Endif
#-----
Close Local File [PIV]
Return


#-------------------------------------------------------------------------------------#
# Chargement des champs POHNUM, POPLIN et POQSEQ si origine ligne réception ou retour #
#-------------------------------------------------------------------------------------#
$AP_PID
Local File =[F:ADS]DOSSIER+".PINVOICED"   [PID]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
Local File =[F:ADS]DOSSIER+".PRETURND"    [PND]
#-----
Call ECR_TIME("DOSMAJ14 Purchase Invoice Process 2 : Update PINVOICED") From DOSSUB
Raz CLE1, CLE2, STOP
#-----
$BOUCLE_PID
If STOP=1
  CRITERE='NUM="'+CLE1+'" & PIDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PID]
  For [PID] PID0 Where evalue(CRITERE) & TYPORI>1 & TYPORI<4
    Case [F:PID]TYPORI
      When 2
        Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
        If fstat  Raz [F:PTD] : Endif
        [F:PID]POHNUM=[F:PTD]POHNUM : [F:PID]POPLIN=[F:PTD]POPLIN
        [F:PID]POQSEQ=[F:PTD]POQSEQ
      When 3
        Read [PND] PND0=[F:PID]PNHNUM;[F:PID]PNDLIN
        If fstat  Raz [F:PND] : Endif
        [F:PID]PTHNUM=[F:PND]PTHNUM : [F:PID]PTDLIN=[F:PND]PTDLIN
        [F:PID]POHNUM=[F:PND]POHNUM : [F:PID]POPLIN=[F:PND]POPLIN
        [F:PID]POQSEQ=[F:PND]POQSEQ
    Endcase
    #----- Réécriture de la ligne de facture d'achat -----#
    COMPTEUR+=1
    Rewrite [PID]
    If fstat
      Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PID : Endif
#-----
Close Local File [PID], [PTD], [PND]
Return
