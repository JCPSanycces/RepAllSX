  If !clalev([F:FCY])    Local File FACILITY   [FCY]  : Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END
Return

# TTD - 95997 Text review
$TITLE
  Case GFONCTION
    When "GESRCC"
          Call TEXTE (51045,TIT) From OBJDIV # RECURRING CUSTOMER INVOICES
    When "GESRCS"
          Call TEXTE (50956,TIT) From OBJDIV  # RECURRING SUPPLIER INVOICES
    When Default
  Endcase
Return

$AVANT_OUVRE
# Check specific function access (GESRCC versus GESRCS)
# 98587.sn
Local Char OFONCTION(10)

OFONCTION = GFONCTION

If  MENFON = "GESRCS" or MENFON = "GESRCC"
    GFONCTION  = MENFON
    Call AUTORIS From EXEFNC
    Raz CRE, MODI, SUPPR
    If GNBAUZ=0
     If GNBSITE=0
      GMESSAGE = mess(33,104,1)  # You must first create a site in the folder
      OK = 0
      Return
     Else
      GMESSAGE = mess(1,123,1)  # Unauthorized function
      OK = 0
      Return
     Endif
    Elsif GUSRFCY(1)="\"
     CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
     MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
     SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
    Endif
Endif

GFONCTION = OFONCTION
# 98587.en

Return

$SETBOUT
  If [M:RCR1]RCRSTA > 1
    Diszo [M:RCR0]FCY
    Diszo [M:RCR0]NUM
  Else
    Actzo [M:RCR0]NUM
  Endif
Return

$LIENS
## After reading a record
  Diszo [M:RCR1]LASINV
  Diszo [M:RCR2]INVNUM
  Call DISPLAYINV([M:RCR0]NUM)
  Call DISPLAYRCR()
  Call LOADGRID()
Return

$PICKE
## After an element has been selected in the pick list
  Call DISPLAYINV([M:RCR0]NUM)
  Call DISPLAYRCR()
Return

$INICRE
## During the creation transaction, just before the write
  Local Date CURDAT
  Local Integer STAT
  Local Char RCRNUM

  ## Retrieve sequence parameter definition
  ## For Module (3) AP/AR Accounting and document Type (14-AP Recurring, 15-AR Recurring)
  GSOCIETE = [M:RCR0]CPY
  Call LECTCA(3,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(3,14,1)-mess(250,199,1) : Return
  Endif

  If GFONC1 = "GESRCC"
    GMANCOU=[F:TCA]MANCOU(15) : GCODNUM=[F:TCA]CODNUM(15)
  Elsif GFONC1 = "GESRCS"
    GMANCOU=[F:TCA]MANCOU(14) : GCODNUM=[F:TCA]CODNUM(14)
  Endif

  CURDAT = date$

  ## Verify manual entry global variable defined in seq number definition
  If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:RCR0]RCRNUM,2)="")
    Call NUMERO(GCODNUM,[M:RCR0]FCY,CURDAT,"",[M:RCR0]RCRNUM,STAT) From SUBANM
    If GOK<0
      Return
    Elsif GOK<1 | STAT<>0
      GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
      Return
    Endif
    [F:RCH]RCRNUM=[M:RCR0]RCRNUM
    Affzo [M:RCR0]RCRNUM
  Endif

  ## Validate that there are no links to another recurrence record.
  ## Eventhough this validation logic already exist at the control level, it needs to be revalidated at creation
  ## Display error message if a link exists.
  Raz RCRNUM
  If GFONC1 = "GESRCC"
    Read [SIH]SIH0 = [M:RCR0]NUM
    If !fstat :RCRNUM = [F:SIH]RCRNUM : Endif
  Elsif GFONC1 = "GESRCS"
    Read [PIH]PIH0 = [M:RCR0]NUM
    If !fstat :RCRNUM = [F:PIH]RCRNUM : Endif
  Endif

  If RCRNUM<>""
    ##The invoice number is referenced in another recurring document
    GMESSAGE = mess(95,119,1)
    GOK = 0 : Return
  Endif

  If [M:RCR0]NUM<>""
    ##Change status from 'Pending' to 'In process'
    ##Disable site/invoice number
    [M:RCR1]RCRSTA = 2
    [F:RCH]RCRSTA = [M:RCR1]RCRSTA
  Endif
  Affzo [M:RCR1]RCRSTA
Return

$CREATION
## During creation transaction
  If [M:RCR0]NUM<>""
    If GFONC1 = "GESRCC"
      Update [F:SIH] Where NUM = [M:RCR0]NUM With RCRNUM = [M:RCR0]RCRNUM , RCRDAT = [M:RCR1]STRDAT
    Elsif GFONC1 = "GESRCS"
      Update [F:PIH] Where NUM = [M:RCR0]NUM With RCRNUM = [M:RCR0]RCRNUM , RCRDAT = [M:RCR1]STRDAT
    Endif
  Endif
Return

$INIMOD
## During modification transaction, just before the rewrite
  Local Char RCRNUM

  If [M:RCR0]NUM<>""
    If [M:RCR1]RCRSTA = 1
      ## Validate that there are no links to another recurrence record.
      ## Eventhough this validation logic already exist at the control level, it needs to be revalidated at creation
      ## Display error message if a link exists.
      Raz RCRNUM
      If GFONC1 = "GESRCC"
        Read [SIH]SIH0 = [M:RCR0]NUM
        If !fstat :RCRNUM = [F:SIH]RCRNUM : Endif
      Elsif GFONC1 = "GESRCS"
        Read [PIH]PIH0 = [M:RCR0]NUM
        If !fstat :RCRNUM = [F:PIH]RCRNUM : Endif
      Endif

      If RCRNUM<>""
        ##The invoice number is referenced in another recurring document
        GMESSAGE = mess(95,119,2)
        GOK = 0 : Return
      Endif

      If GFONC1 = "GESRCC"
        Update [F:SIH] Where NUM = [M:RCR0]NUM With RCRNUM = [M:RCR0]RCRNUM , RCRDAT = [M:RCR1]STRDAT
      Elsif GFONC1 = "GESRCS"
        Update [F:PIH] Where NUM = [M:RCR0]NUM With RCRNUM = [M:RCR0]RCRNUM , RCRDAT = [M:RCR1]STRDAT
      Endif

      ##Change status from 'Pending' to 'In process'
      ##Disable site/invoice number
      [M:RCR1]RCRSTA = 2
      [F:RCH]RCRSTA = [M:RCR1]RCRSTA
      Affzo [M:RCR1]RCRSTA

    Elsif [M:RCR1]RCRSTA > 1
      If GFONC1 = "GESRCC"
        Update [F:SIH] Where NUM = [M:RCR0]NUM With RCRDAT = [M:RCR1]STRDAT
      Elsif GFONC1 = "GESRCS"
        Update [F:PIH] Where NUM = [M:RCR0]NUM With RCRDAT = [M:RCR1]STRDAT
      Endif
    Endif
  Endif



Return

$FILTRE
## Definition of the criteria to be used as a filter on the main table

If currbox="GAU_CHE"
  If GFONC1="GESRCC"
    FILTRE="RCRTYP=1 & RCRSTA<3"
  Else
    FILTRE="RCRTYP=2 & RCRSTA<3"
  Endif
Endif
If currbox="GAU_CHE1"
  If GFONC1="GESRCC"
    FILTSUP="RCRTYP=1 & RCRSTA>=3"
  Else
    FILTSUP="RCRTYP=2 & RCRSTA>=3"
  Endif
Endif

Return

$FILGAUCHE

If currbox="GAU_CHE"
  If GFONC1="GESRCC"
    FILGAUCHE="RCRTYP=1 & RCRSTA<3"
  Else
    FILGAUCHE="RCRTYP=2 & RCRSTA<3"
  Endif
Endif
If currbox="GAU_CHE1"
  If GFONC1="GESRCC"
    FILGAUSUP="RCRTYP=1 & RCRSTA>=3"
  Else
    FILGAUSUP="RCRTYP=2 & RCRSTA>=3"
  Endif
Endif

Return

$RAZCRE
## When a new record is about to be created
  [M:RCR1]RCRSTA = 1
  Affzo [M:RCR1]RCRSTA
  Diszo [M:RCR1]LASINV
  Diszo [M:RCR2]INVNUM

  Call INITRCRTYP
  Call INITPATTERN(0,0)
Return

$RAZDUP
## When a new record is about to be copied
  [M:RCR1]RCRSTA = 1
  Affzo [M:RCR1]RCRSTA
  Diszo [M:RCR1]LASINV
  Diszo [M:RCR2]INVNUM

  Call INITRCRTYP

  Raz[M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
  Actzo [M:RCR0]NUM,FCY
  Affzo[M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI

  Raz[M:RCR1]LASINV, LASACCDAT, LASRCRDAT, NUMINV, NUMPST, AMTPST
  Affzo[M:RCR1]LASINV, LASACCDAT, LASRCRDAT, NUMINV, NUMPST, AMTPST
Return

$ANNULE
## During record cancellation
  If GFONC1 = "GESRCC"
    Update [F:SIH] Where RCRNUM = [M:RCR0]RCRNUM With RCRNUM = "", RCRDAT = [0/0/0]
  Elsif GFONC1 = "GESRCS"
    Update [F:PIH] Where RCRNUM = [M:RCR0]RCRNUM With RCRNUM = "", RCRDAT = [0/0/0]
  Endif
Return


Subprog LOADGRID()
  Raz [M:RCR2]
  NOL = 0
  If [M:RCR0]RCRNUM <> ""
    If GFONC1 = "GESRCC"
      Filter [F:SIH] Where RCRNUM = [M:RCR0]RCRNUM Order By RCRDAT Desc
      ##For [F:SIH]SIH0 Where RCRNUM = [M:RCR0]RCRNUM
      For [F:SIH]
        If NOL >= dim([M:RCR2]INVNUM)
            Call MESSAGE(mess(26,100,1)) From GESECRAN
            Break
        Endif
        nolign = NOL + 1
        [M:RCR2]INVNUM(NOL) = [F:SIH]NUM
        [M:RCR2]INVACCDAT(NOL) = [F:SIH]ACCDAT
        [M:RCR2]INVRCRDAT(NOL) = [F:SIH]RCRDAT
        ##Display string literal due to different status local menu for Customer/Supplier BP Invoice
        [M:RCR2]INVSTA(NOL) = mess([F:SIH]STA,2261,1)
        [M:RCR2]INVAMTATI(NOL) = [F:SIH]AMTATI
        [M:RCR2]INVCUR(NOL) = [F:SIH]CUR
        [M:RCR2]INVPTE(NOL) = [F:SIH]PTE
        NOL += 1
      Next
      Filter [F:SIH]
    Elsif GFONC1 = "GESRCS"
      Filter [F:PIH] Where RCRNUM = [M:RCR0]RCRNUM Order By RCRDAT Desc
      ##For [F:PIH]PIH0 Where RCRNUM = [M:RCR0]RCRNUM
      For [F:PIH]
        If NOL >= dim([M:RCR2]INVNUM)
            Call MESSAGE(mess(26,100,1)) From GESECRAN
            Break
        Endif
        nolign = NOL + 1
        [M:RCR2]INVNUM(NOL) = [F:PIH]NUM
        [M:RCR2]INVACCDAT(NOL) = [F:PIH]ACCDAT
        [M:RCR2]INVRCRDAT(NOL) = [F:PIH]RCRDAT
        ##Display string literal due to different status local menu for Customer/Supplier BP Invoice
        [M:RCR2]INVSTA(NOL) = mess([F:PIH]STA,509,1)
        [M:RCR2]INVAMTATI(NOL) = [F:PIH]AMTATI
        [M:RCR2]INVCUR(NOL) = [F:PIH]CUR
        [M:RCR2]INVPTE(NOL) = [F:PIH]PTE
        NOL += 1
      Next
      Filter [F:PIH]
    Endif
    [M:RCR2]NBLIG = NOL
    Affzo [M:RCR2]1-99
  Endif
End


Subprog INITRCRTYP()
  If GFONC1 = "GESRCC"
    [M:RCR0]RCRTYP = 1
  Elsif GFONC1 = "GESRCS"
    [M:RCR0]RCRTYP = 2
  Endif
End

Subprog INITPATTERN(RCRPAN,SETDFLTS)
Value Integer RCRPAN
Value Integer SETDFLTS

  Case RCRPAN
    When 0 : ## None
      Grizo [M:RCR1]DLY, WEEDAY, WEEIRT, MONDAY, MONIRT
      Effzo [M:RCR1]DLY, WEEDAY, WEEIRT, MONDAY, MONIRT
    When 1 : ## Daily
      Actzo [M:RCR1]DLY
      If SETDFLTS = 1
        [M:RCR1]DLY = 1
      Endif
      Grizo [M:RCR1]WEEDAY, WEEIRT, MONDAY, MONIRT
      Effzo [M:RCR1]WEEDAY, WEEIRT, MONDAY, MONIRT
    When 2 : ## Weekly
      Actzo [M:RCR1]WEEDAY, WEEIRT
      If SETDFLTS = 1
        [M:RCR1]WEEDAY = 1
        [M:RCR1]WEEIRT = 1
      Endif
      Grizo [M:RCR1]DLY, MONDAY, MONIRT
      Effzo [M:RCR1]DLY, MONDAY, MONIRT
    When 3 : ## Monthly
      Actzo [M:RCR1]MONDAY, MONIRT
      If SETDFLTS = 1
        [M:RCR1]MONDAY = 1
        [M:RCR1]MONIRT = 1
      Endif
      Grizo [M:RCR1]DLY, WEEDAY, WEEIRT
      Effzo [M:RCR1]DLY, WEEDAY, WEEIRT
  Endcase

  #Affzo [M:RCR1]DLY, WEEDAY, WEEIRT, MONDAY, MONIRT #100453.o

  #100453.sn
  Affzo [M:RCR1] WEEDAY, WEEIRT, MONDAY, MONIRT

  If RCRPAN = 1 ## Daily
    Affzo [M:RCR1]DLY
  Else
    [M:RCR1]DLY = -1 #Clears out all the radio buttons
    Affzo [M:RCR1]DLY
    [M:RCR1]DLY = 0
  Endif
  #100453.en
End

Subprog DISPLAYINV(INVTRANNO)
Value Char INVTRANNO

  If INVTRANNO<>""
    If GFONC1 = "GESRCC"
      Read [F:SIH]SIH0 = INVTRANNO
      If !fstat
        [M:RCR0]INVTYP = [F:SIH]SIVTYP
        [M:RCR0]BPR = [F:SIH]BPR
        [M:RCR0]BPAINV = [F:SIH]BPAINV
        [M:RCR0]BPRNAM = [F:SIH]BPRNAM(0)
        [M:RCR0]CUR = [F:SIH]CUR
        [M:RCR0]AMTATI = [F:SIH]AMTATI
        Affzo [M:RCR0]INVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
      Endif
    Elsif GFONC1 = "GESRCS"
      Read [F:PIH]PIH0 = INVTRANNO
      If !fstat
        [M:RCR0]INVTYP = [F:PIH]PIVTYP
        [M:RCR0]BPR = [F:PIH]BPR
        [M:RCR0]BPAINV = [F:PIH]BPAINV
        [M:RCR0]BPRNAM = [F:PIH]BPRNAM(0)
        [M:RCR0]CUR = [F:PIH]CUR
        [M:RCR0]AMTATI = [F:PIH]AMTATI
        Affzo [M:RCR0]INVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
      Endif
    Endif
  Endif
End


Subprog DISPLAYRCR()
Local Integer CNT
Local Char    INVTRANNO
Local Integer POSTEDCNT
Local Decimal POSTEDAMT
Local Integer CLRAMT
Local Date    ACCDAT
Local Date    RCRDAT
Local Integer RAZFLAG

  If [M:RCR0]RCRNUM <> ""
    If GFONC1 = "GESRCC"
      Filter [F:SIH] Where RCRNUM = [M:RCR0]RCRNUM Order By RCRDAT

      Raz CNT
      Raz POSTEDCNT
      Raz POSTEDAMT
      Raz CLRAMT
      Raz [M:RCR1]LASINV
      Raz [M:RCR1]LASACCDAT
      Raz [M:RCR1]LASRCRDAT

      For [F:SIH]
        ## count the number of invoices generated
        CNT += 1

        INVTRANNO = [F:SIH]NUM
        ACCDAT = [F:SIH]ACCDAT
        RCRDAT = [F:SIH]RCRDAT
        [M:RCR1]LASINV = INVTRANNO
        [M:RCR1]LASACCDAT = ACCDAT
        [M:RCR1]LASRCRDAT = RCRDAT

        If [F:SIH]STA = 3
          ## count the number of posted invoices generated
          POSTEDCNT += 1
          ## add amount of posted invoices generated
          POSTEDAMT += [F:SIH]AMTATI
          [M:RCR1]CURPST = [F:SIH]CUR

          If [M:RCR0]CUR <> ""
            If [M:RCR0]CUR <> [F:SIH]CUR : CLRAMT = 1: Endif
          Endif
        Endif
      Next

      [M:RCR1]NUMINV = CNT
      [M:RCR1]NUMPST = POSTEDCNT

      ## clear out total amount if there is a change in currency
      If CLRAMT
        [M:RCR1]AMTPST = 0
        [M:RCR1]CURPST = ""
      Else
        [M:RCR1]AMTPST = POSTEDAMT
      Endif

      Affzo [M:RCR1]LASINV, LASACCDAT, LASRCRDAT, NUMINV, NUMPST, AMTPST, CURPST

      Filter [F:SIH]

    Elsif GFONC1 = "GESRCS"
      Filter [F:PIH] Where RCRNUM = [M:RCR0]RCRNUM Order By RCRDAT

      Raz CNT
      Raz POSTEDCNT
      Raz POSTEDAMT
      Raz CLRAMT
      Raz [M:RCR1]LASINV
      Raz [M:RCR1]LASACCDAT
      Raz [M:RCR1]LASRCRDAT

      For [F:PIH]
        ## count the number of invoices generated
        CNT += 1

        INVTRANNO = [F:PIH]NUM
        ACCDAT = [F:PIH]ACCDAT
        RCRDAT = [F:PIH]RCRDAT
        [M:RCR1]LASINV = INVTRANNO
        [M:RCR1]LASACCDAT = ACCDAT
        [M:RCR1]LASRCRDAT = RCRDAT

        If [F:PIH]STA = 3
          ## count the number of posted invoices generated
          POSTEDCNT += 1
          ## add amount of posted invoices generated
          POSTEDAMT += [F:PIH]AMTATI
          [M:RCR1]CURPST = [F:PIH]CUR

          If [M:RCR0]CUR <> ""
            If [M:RCR0]CUR <> [F:PIH]CUR : CLRAMT = 1: Endif
          Endif
        Endif
      Next

      [M:RCR1]NUMINV = CNT
      [M:RCR1]NUMPST = POSTEDCNT

      ## clear out total amount if there is a change in currency
      If CLRAMT
        [M:RCR1]AMTPST = 0
        [M:RCR1]CURPST = ""
      Else
        [M:RCR1]AMTPST = POSTEDAMT
      Endif

      Affzo [M:RCR1]LASINV, LASACCDAT, LASRCRDAT, NUMINV, NUMPST, AMTPST, CURPST

      Filter [F:PIH]
    Endif
  Endif
End

Subprog CHECKRCR(VCRNUM, WABMSK, RCRNUM)
Value Char VCRNUM
Value Char WABMSK
Variable Char RCRNUM

  RCRNUM = ""

  If !clalev([F:RCH]) Local File RCRINVOICE [RCH] : Endif
  If WABMSK = "BIC0"
    Read [RCH]RCH1 = 1;VCRNUM
    If !fstat
      RCRNUM = [RCH]RCRNUM
    Endif
  Elsif WABMSK = "BIS0"
    Read [RCH]RCH1 = 2;VCRNUM
    If !fstat
      RCRNUM = [RCH]RCRNUM
    Endif
  Endif
End

## Loads CPY,CPYNAM - Company, Company Name
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" or [M]CPY=""
 Call INIFCY(VALEUR,[M]CPY) From CPTSUB
 If VALEUR<>""
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  #Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  [M]CPY    = [F:FCY]LEGCPY
  ##[M]CPYNAM = [F:CPY]CPYSHO
  Affzo CPY
 Endif
Endif
End

## Loads CPY,CPYNAM - Company, Company Name
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  [M]CPY = [F:FCY]LEGCPY
  #Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
  #Call GETSOC(VALEUR) From DEVSUB
  ##[M]CPYNAM = [F:CPY]CPYSHO
  Affzo CPY

  #Verify if invoice number has the same site, if not clear it all out
  If [M:RCR0]NUM<>""
    If GFONC1 = "GESRCC"
      Read [SIH]SIH0 = [M:RCR0]NUM
      If !fstat
        If [F:SIH]FCY <> VALEUR
          Raz[M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
          Affzo [M:RCR0]NUM, INVTYP, ZINVTYP, BPR,  BPAINV, BPRNAM, CUR, AMTATI
        Endif
      Endif
    Elsif GFONC1 = "GESRCS"
      Read [PIH]PIH0 = [M:RCR0]NUM
      If !fstat
        If [F:PIH]FCY <> VALEUR
          Raz[M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
          Affzo [M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
        Endif
      Endif
    Endif
  Endif
End

Subprog C_RCRNUM(VALEUR)
Variable Char    VALEUR()
End

# 100499.sn
Subprog AS_NUM (VALUER)
Variable Char   VALUER()
  Call INITRCRTYP
End
# 100499.en

Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
  Local Integer INVEXISTS
  Local Integer INVTYP
  Local Integer ORIMOD
  Local Integer STA
  Local Char    RCRNUM
  Local Char    FCY
  Local Integer BPTYP

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
  Local Integer WRET
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

  Raz INVEXISTS

  If VALEUR<>""
    If GFONC1 = "GESRCC"
      Read [SIH]SIH0 = VALEUR
      If !fstat
        INVEXISTS = 1
        FCY = [F:SIH]FCY
        ORIMOD = [F:SIH]ORIMOD
        INVTYP = [F:SIH]INVTYP
        STA = [F:SIH]STA
        RCRNUM = [F:SIH]RCRNUM

        If STA = 2
          ##The invoice status must be either Not Posted or Posted
          GMESSAGE = mess(91,119,1)
          mkstat=2:End
        Endif

        If ORIMOD = 5
          ##The invoice cannot be a sales invoice
          GMESSAGE = mess(100,119,1)
          mkstat=2:End
        Endif

        Read [BPC]BPC0 = [F:SIH]BPR
        If !fstat
          BPTYP = [F:BPC]BPCTYP
          If BPTYP<>1
            ##The business partner type must be Normal
            GMESSAGE = mess(94,119,1)
            mkstat=2:End
          Endif
        Endif
      Else
        ##The customer invoice number entered is invalid
        GMESSAGE = mess(87,119,1)
        mkstat=2:End
      Endif

      #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
      If [F:FCY]FCY <> [M:RCR0]FCY
        Read [F:FCY]FCY0 = [M:RCR0]FCY
        If fstat : Raz [F:FCY] : Endif
      Endif

      Call LEC_TSV_LEG([F:FCY]LEG,[M:RCR0]INVTYP,WRET) From TRTLECLEG
      If WRET Raz [F:TSV] Endif

      #Read [F:TSV]TSV0 = [M:RCR0]INVTYP
      If !fstat
        If [F:TSV]SAFTINVTYP = 2
          GMESSAGE = mess(79,7711,1)
          mkstat = 2 : End
        Endif
      Endif
      #85803 RICAR 2014/05/20 - Portuguese legal requirements - END

    Elsif GFONC1 = "GESRCS"
      Read [PIH]PIH0 = VALEUR
      If !fstat
        INVEXISTS = 1
        FCY = [F:PIH]FCY
        ORIMOD = [F:PIH]ORIMOD
        INVTYP = [F:PIH]INVTYP
        STA = [F:PIH]STA
        RCRNUM = [F:PIH]RCRNUM

        If STA = 1
          ##The invoice status must be either To validate or Validated
          GMESSAGE = mess(105,119,1)
          mkstat=2:End
        Endif

        If ORIMOD = 6
          ##The invoice cannot be a purchase invoice
          GMESSAGE = mess(93,119,1)
          mkstat=2:End
        Endif

        Read [BPS]BPS0 = [F:PIH]BPR
        If !fstat
          BPTYP = [F:BPS]BPSTYP
          If BPTYP<>1
            ##The business partner type must be Normal
            GMESSAGE = mess(94,119,1)
            mkstat=2:End
          Endif
        Endif
      Else
        ##The supplier invoice number entered is invalid
        GMESSAGE = mess(88,119,1)
        mkstat=2:End
      Endif
    Endif

    If INVEXISTS = 1
      If FCY<>[M:RCR0]FCY
        ##The invoice site does not match the recurring document
        GMESSAGE = mess(89,119,1)
        mkstat=2:End
      Endif

      If INVTYP<>1
        ##The invoice category must be Invoice
        GMESSAGE = mess(90,119,1)
        mkstat=2:End
      Endif

      If RCRNUM<>""
        ##The invoice number is referenced in another recurring document
        GMESSAGE = mess(95,119,1)
        mkstat=2:End
      Endif

      Call DISPLAYINV(VALEUR)
    Endif
  Endif
End

Subprog AM_NUM(VALEUR)
Variable Char   VALEUR()
Local Date      INVDAT
Local Integer   SETDAT ## 0 - Do nothing, 1 - Update Start Date, 2 - Update Start and End Date
Local Integer   OK

  Raz SETDAT

  If VALEUR<>""
    If GFONC1 = "GESRCC"
      Read [SIH]SIH0 = VALEUR
      If !fstat
        INVDAT = [F:SIH]ACCDAT
      Endif
    Elsif GFONC1 = "GESRCS"
      Read [PIH]PIH0 = VALEUR
      If !fstat
        INVDAT = [F:PIH]ACCDAT
      Endif
    Endif

    If [M:RCR1]STRDAT<>[0/0/0]
      If [M:RCR1]STRDAT < INVDAT
        SETDAT = 2
      Else
        OK = 1
        ##Do you want to reset the start/end date based on invoice accounting date?
        Call OUINON(mess(97,119,1),OK) From GESECRAN
        If OK = 2 : SETDAT = 2 : Endif
      Endif
    Else
      SETDAT = 1
    Endif
  Else
    Raz[M:RCR0]NUM, INVTYP, ZINVTYP, BPR, BPAINV, BPRNAM, CUR, AMTATI
  Endif

  If SETDAT <> 0
    [M:RCR1]STRDAT = INVDAT
    Affzo [M:RCR1]STRDAT
    If SETDAT=2 : [M:RCR1]ENDDAT = INVDAT + 366 : Affzo [M:RCR1]ENDDAT : Endif
  Endif
End

######################################################################################
## Section automatically added (screen RCR1) 04/25/2013 01:14:18 (CATUA)
######################################################################################
Subprog AV_RCRPAN(VALEUR)
Variable Integer VALEUR
  Call INITPATTERN(VALEUR,0)
End

Subprog AM_RCRPAN(VALEUR)
Variable Integer VALEUR
  Call INITPATTERN(VALEUR,1)
End

Subprog C_STRDAT(VALEUR)
Variable Date   VALEUR
   Local Date      ACCDAT
   If VALEUR <> [0/0/0]
    If [M:RCR1]ENDDAT <> [0/0/0]
      If VALEUR > [M:RCR1]ENDDAT
        ##The start date must be less than the end date
        GMESSAGE = mess(104,119,1)
        mkstat=2:End
      Endif
    Endif

    If [M:RCR0]NUM<>""
      If GFONC1 = "GESRCC"
        Read [SIH]SIH0 = [M:RCR0]NUM
        If !fstat
          ##The start date cannot be earlier than the invoice accounting date of $1$
          If VALEUR < [F:SIH]ACCDAT
            GMESSAGE = func AFNC.MES1(mess(102,119,1),format$("DD2",[F:SIH]ACCDAT))
            Effzo [M:RCR1]ENDDAT
            mkstat=2:End
          Endif
        Endif
      Elsif GFONC1 = "GESRCS"
        Read [PIH]PIH0 = [M:RCR0]NUM
        If !fstat
          ##The start date cannot be earlier than the invoice accounting date of $1$
          If VALEUR < [F:PIH]ACCDAT
            GMESSAGE = func AFNC.MES1(mess(102,119,1),format$("DD2",[F:PIH]ACCDAT))
            Effzo [M:RCR1]ENDDAT
            mkstat=2:End
          Endif
        Endif
      Endif
    Endif
  Endif
End

Subprog AS_RCRSTA(VALEUR)
Variable Integer VALEUR
    Case [M:RCR1]RCRSTA
      When 1
        GMENLOC(2) = 1
        GMENLOC(3) = 1
        GMENLOC(4) = 1
      When 2 : # In process
        GMENLOC(1) = 1
        GMENLOC(3) = 1
      When 3 : # Completed
        GMENLOC(1) = 1
      When 4 : # Cancelled
        GMENLOC(1) = 1
        GMENLOC(3) = 1
    Endcase
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR <> [0/0/0] & [M:RCR1]STRDAT <> [0/0/0]
    If VALEUR < [M:RCR1]STRDAT
      ##The end date must be greater than the start date
      GMESSAGE = mess(3,7770,1)
      mkstat=2:End
    Endif
  Endif
End

Subprog C_WEEIRT(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 1 | VALEUR > 52
    ##The weekly interval must be between 1 and 52
    GMESSAGE = mess(84,119,1)
    mkstat=2:End
  Endif
End

Subprog C_MONDAY(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 1 | VALEUR > 31
    ##The day of the month must be between 1 and 31
    GMESSAGE = mess(85,119,1)
    mkstat=2:End
  Endif
End

Subprog C_MONIRT(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 1 | VALEUR > 12
    ##The monthly interval must be between 1 and 12."
    GMESSAGE = mess(86,119,1)
    mkstat=2:End
  Endif
End

Subprog IB_NUM
  Call SETCONTEXT([M:RCR0]NUM)
End

Subprog B2_NUM(VALEUR)
Variable Char    VALEUR()
  Call TUNL_INTRCO(VALEUR)
End

Subprog IB_LASINV
  If [M]LASINV = ""
    Raz GBOUT1
    Raz GBOUT2
  Else
    Call SETCONTEXT([M:RCR1]LASINV)
  Endif
End

Subprog B2_LASINV(VALEUR)
Variable Char    VALEUR()
  Call TUNL_INTRCO(VALEUR)
End

Subprog IB_NBLIG
  Call SETCONTEXT([M:RCR2]INVNUM(nolign-1))
End

Subprog B2_NBLIG
  Call TUNL_INTRCO([M:RCR2]INVNUM(nolign-1))
End

Subprog SETCONTEXT(INVNUM)
Variable Char INVNUM()
  Local Integer NUMEXIST
  Local Integer INTCPY
  Raz NUMEXIST
  Raz GBOUT1
  Raz GBOUT2
  Raz INTCPY

  ## Check intercompany activity code and parameter
  If func AFNC.ACTIV("INTCO")
    If func AFNC.PARAM("INTCPYINV",[M:RCR0]CPY)="2"
      INTCPY = 1
    Endif
  Endif

  If GFONC1 = "GESRCC"
    GBIDC1 = "BIC"
    If INVNUM <> "" & [M:RCR1]RCRSTA > 1
      Read [SIH]SIH0 = INVNUM
      If !fstat
        NUMEXIST = 1
        If [F:SIH]NBRCPY > 1
          Call TEXTE (51089,GBOUT2) From OBJDIV
        Else
          Call TEXTE (37478,GBOUT1) From OBJDIV
        Endif
      Endif
    Endif

    If NUMEXIST<>1
      Call TEXTE (37478,GBOUT1) From OBJDIV
      If INTCPY
        Call TEXTE (51089,GBOUT2) From OBJDIV
      Endif
    Endif

  Elsif GFONC1 = "GESRCS"
    GBIDC1 = "BIS"
    If INVNUM <> "" & [M:RCR1]RCRSTA > 1
      Read [PIH]PIH0 = INVNUM
      If !fstat
        NUMEXIST = 1
        If [F:PIH]NBRCPY > 1
          Call TEXTE (51085,GBOUT2) From OBJDIV
        Else
          Call TEXTE (37479,GBOUT1) From OBJDIV
        Endif
      Endif
    Endif

    If NUMEXIST<>1
      Call TEXTE (37479,GBOUT1) From OBJDIV
      If INTCPY
        Call TEXTE (51085,GBOUT2) From OBJDIV
      Endif
    Endif
  Endif
End

Subprog TUNL_INTRCO(INVNUM)
Variable Char INVNUM()
  Local Char SAVFONC(20)
  ## Action GOBJET
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "GOBJET"
  SAVFONC = GFONC1
  If GFONC1="GESRCC"
    GFONC1="GESBICX"
  Elsif GFONC1="GESRCS"
    GFONC1="GESBISX"
  Endif
  Call OBJET_CHAR(INVNUM,GBIDC1,"") From GOBJET
  GACTION = SAVACT
  GFONC1  = SAVFONC
End
