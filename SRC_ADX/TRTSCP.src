#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Routage de l'exécution d'un script d'appel                          Module CRM          3 janvier 2000 #
##########################################################################################################
$ACTION
  Case GSCPCASE
    When "SELSCRIPT"
      Gosub SELSCRIPT
    When "RUNSCRIPT"
      Gosub RUNSCRIPT
    When Default
  Endcase
Return

##########################################################################################################
$RUNSCRIPT
  Case ACTION
    When "CONTROLE"     : BOITE = "FSCP1"
    When Default        : Gosub ACTION From TRTSCP1
  Endcase
Return

##########################################################################################################
$SELSCRIPT
  Case ACTION
    When "CONTROLE"     : BOITE = "FSCP2"
    When Default        : Gosub ACTION From TRTSCP2
  Endcase
Return
