#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TRANSPORT_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE  From TRANSPORT_CMET
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER   From TRANSPORT_CMET
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER   From TRANSPORT_CMET
        When "AINSERT_BEFORE"         : Gosub AINSERT_BEFORE          From TRANSPORT_CMET
        When "AUPDATE_AFTER"          : Gosub AUPDATE_AFTER           From TRANSPORT_CMET
        When "ADELETE_BEFORE"         : Gosub ADELETE_BEFORE          From TRANSPORT_CMET
      Endcase
    When "EVT"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EVT_ADDLINE_AFTER       From TRANSPORT_CMET
      Endcase
      When "SHIPT"
      Case [L]AEVENT
        When "ADELLINE_AFTER"         : Gosub SHIPT_ADELLINE_AFTER       From TRANSPORT_CMET
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SEARCHARVEXPDAT"            : Gosub SEARCHARVEXPDAT         From TRANSPORT_CMET
    When "SHIPT_GET_INDEX"            : Gosub SHIPT_GET_INDEX         From TRANSPORT_CMET
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Case CURPRO
  When "TRNMOD" :
      Case [L]ARULE
        When "INIT" : Gosub TRNMOD_INIT From TRANSPORT_CPRO
      Endcase
Endcase
Return

