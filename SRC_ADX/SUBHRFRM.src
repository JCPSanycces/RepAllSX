 Gosub REMPLIT
#Endif

# A quoi ça sert ?
#Read [ADI]CODE=365;[M]TYPPAY(nolign-1)
#If !fstat=0
# GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
# mkstat=2 : End
Endif

Affzo [M]CRY(nolign-1), BIDNUM(nolign-1), PAB1(nolign-1), PAB2(nolign-1), BNF(nolign-1)
Affzo [M]FCY(nolign-1), AMT(nolign-1)
Affzo [M]WBNF

