#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRFRM
######################################################################################
# Modification :
#FQ79702 - SEGAY 27/01/12 - ouverture de RIB1 au lieu de RIB
# Pouvait changer le filtre dans les boucles For qui appelle SRC_ACCOUNT
######################################################################################

Raz GPILOBJ
Raz GBIDC1

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Call OBJET("HRFRM",GBIDC1,"") From GOBJET
#Call OBJET("FRM",GBIDC1,"") From GOBJET
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END

End

########################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "EXEC"         : Gosub EXEC
 When "EXEBOUT"      : Gosub EXEBOUT
 When "CONTROLE"     : Gosub CONTROLE
 When "LIENS"        : Gosub LIENS
 When "CREATION"     : Gosub CREATION
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "ANNULE"       : Gosub ANNULE
 When "SETBOUT"      : Gosub SETBOUT
 When "FIN_ACTION"   : Gosub FIN_ACTION
 When "ABANDON"      : Gosub ABANDON
 When "AP_IMPRIME"   : Gosub REAFFICHE
 When "AP_LISTE"     : Gosub REAFFICHE
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 When "RAZCRE"       : [M:HRFRM1]STA=1 : Affzo [M:HRFRM1]STA :  Actzo[M]5
 When "RAZDUP"       : [M:HRFRM1]STA=1 : Affzo [M:HRFRM1]STA :  Actzo[M]5 : Raz [M]OLDAMT :# 64623
# When "RAZCRE"       : [M:FRM1]STA=1 : Affzo [M:FRM1]STA :  Actzo[M]5
# When "RAZDUP"       : [M:FRM1]STA=1 : Affzo [M:FRM1]STA :  Actzo[M]5 : Raz [M]OLDAMT :# 64623
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 When "AFFMASK"      : [L]DROIT=1
 When "EFFMASK"      : [L]DROIT=1
 When "FIN"          : Kill GMODFRM        :#61759
Endcase
Return

########################################
$OUVRE
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:HRSDP])=0  : Local File SOLDPAY  [HRSDP] : Endif
#If clalev([F:SDP])=0  : Local File SOLDPAY  [SDP] : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If clalev([F:CPY])=0  : Local File COMPANY  [CPY] : Endif
If clalev([F:BAN])=0  : Local File BANK     [BAN] : Endif
If clalev([F:ID]) =0  : Local File EMPLOID  [ID]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
#If clalev([F:CTR])=0  : Local File EMPLOCTR [CTR] : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If clalev([F:RIB])=0  : Local File EMPLORIB [RIB] : Endif
If clalev([F:CPT])=0  : Local File EMPLOCPT [CPT] : Endif
If clalev([F:ACC])=0  : Local File ACCES    [ACC] : Endif
If clalev([F:ECT])=0  : Local File EMPCTR   [ECT] : Endif

# (C) PROSPER 23/07/10 - Prise en compte des infos comptables au contrat
If clalev([F:CPR])=0  : Local File EMPLOCTRCPT  [CPR]  : Endif

Local Integer DROIT
#61759 : Remplacement de GMODIF (superviseur) par GMODFRM à cause d'effect de bord si GMODIF=1 à l'entrée dans GESFRM
Global Integer GMODFRM
Return

########################################
$VERIF_CRE
$VERIF_MOD
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10387;[M:HRFRM1]MODPAY
#Read [ADI]CODE=387;[M:FRM1]MODPAY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
For I=0 To [M:HRFRM1]BPAG-1
 If [M:HRFRM1]CRY(I)=""
  [V]GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(164,100,1)
  #           lign no : Pays obligatoire
  [L]OK      =0
  Break
 Elsif [M:HRFRM1]BNF(I)="" & [F:ADI]N1=1 : # Chèque
  [V]GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(16,10704,1)
  #           ligne no : Bénéficiaire obligatoire
  [L]OK      =0
  Break
 Endif
Next
#For I=0 To [M:FRM1]BPAG-1
# If [M:FRM1]CRY(I)=""
#  [V]GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(164,100,1)
#  #           lign no : Pays obligatoire
#  [L]OK      =0
#  Break
# Elsif [M:FRM1]BNF(I)="" & [F:ADI]N1=1 : # Chèque
#  [V]GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(16,704,1)
#  #           ligne no : Bénéficiaire obligatoire
#  [L]OK      =0
#  Break
# Endif
#Next
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If ![L]OK : Return : Endif
Return

########################################
$INICRE
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If [F:HRFRM]NUMFRM=""
#If [F:FRM]NUMFRM=""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 Local Char    COMPTEUR(5)
 Local Integer STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#JASMI - 2017-03-23 - START
# Read [TCA]TCA0 = 15;"";[M:HRFRM1]CPY : # Module paye
## Read [TCA]TCA0 = 2 : # Module paye
##MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
# COMPTEUR = [F:TCA]CODNUM(0)
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(3,10702,1) : # Compteur matricule non dÚfini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(0)
 Endif
#JASMI - 2017-03-23 - END
 If COMPTEUR=""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(1,10704,1) : # Compteur bordereau non défini
#  GMESSAGE = mess(1,704,1) : # Compteur bordereau non défini
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  GOK = 0 : Return
 Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Read [F:CPY]CPY0=[F:HRFRM]CPY
# Read [F:CPY]CPY0=[F:FRM]CPY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat=0
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Call NUMERO(COMPTEUR,[F:CPY]MAIFCY,[M]DAT,"",[F:HRFRM]NUMFRM,STAT) From SUBANM
#  Call NUMERO(COMPTEUR,[F:CPY]MAIFCY,[M]DAT,"",[F:FRM]NUMFRM,STAT) From SUBANM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
#   GMESSAGE = mess(4,702,1)-COMPTEUR : # "Erreur sur compteur"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   GOK = 0 : Return
  Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  [M]NUMFRM=[F:HRFRM]NUMFRM
#  [M]NUMFRM=[F:FRM]NUMFRM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  Affzo[M]NUMFRM
 Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(81,116,1)-[F:HRFRM]CPY : # "Société incorrecte"
#  GMESSAGE = mess(81,116,1)-[F:FRM]CPY : # "Société incorrecte"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  GOK = 0 : Return
 Endif
Endif
Gosub RECALCUL_TOT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
[F:HRFRM]TOT=[M]TOT
#[F:FRM]TOT=[M]TOT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Return

########################################
$INIMOD
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
[M]STA=1 : [F:HRFRM]STA=1
Gosub RECALCUL_TOT
[F:HRFRM]TOT=[M]TOT
#[M]STA=1 : [F:FRM]STA=1
#Gosub RECALCUL_TOT
#[F:FRM]TOT=[M]TOT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Return

########################################
$CREATION
$MODIF
Gosub MAJ_SOLDE
If [V]GOK<1 : Return : Endif
Call SAUVE_STL([M]NUMFRM)
Call CHARGE_STL([M]NUMFRM,[L]DROIT)
Return

########################################
$LIENS
Grizo[M]5 : Actzo [M]NUMFRM
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
[M]CURBAN=[F:HRFRM]CUR
#[M]CURBAN=[F:FRM]CUR
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
Call CHARGE_STL([M]NUMFRM,[L]DROIT)
Return

########################################
$MAJ_SOLDE
Local Integer IND
Local Decimal MONTANT, OLDMONT
Local Char DEVSOC (GLONCUR)
Local Integer TYPCOURS
Local Char VALPAR (50)
Local Integer STAT

#GOK=1

#Devise société
Read[CPY]CPY0=[M]CPY
If fstat=0
 DEVSOC=[F:CPY]ACCCUR
Else
 GMESSAGE = mess(81,116,1)-[M]CPY : # "Société incorrecte"
 GOK = 0 : Return
Endif

#Type de cours
Call PARAM("","TYPCOURS",VALPAR)From ADOVAL
TYPCOURS=val(VALPAR)

#Mise à jour des soldes pour les lignes supprimées
If [M]DELIND > 0
For IND=0 To [M]DELIND
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Readlock[HRSDP]SDP0=[M]DELREFNUM(IND);[M]DELCTRNUM(IND)
# Readlock[SDP]SDP0=[M]DELREFNUM(IND);[M]DELCTRNUM(IND)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat=0 & [M]DELCTRNUM(IND)<>""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M]DELTYPPAY(IND)
#  Read [ADI]CODE=10365;[M]DELTYPPAY(IND) :#security
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#  Read [ADI]CODE=365;[M]DELTYPPAY(IND) :#security
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If fstat=0
   #Conversion en monnaie société...
   Call CONVERT ([M]CURBAN,DEVSOC,DEVSOC,TYPCOURS,datesyst,[M]DELAMT(IND),MONTANT,STAT) From TRTDEV
   If !STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    Call ADDSOLDE([F:ADI]N1,[L]MONTANT) From SUBHRSLD
#    Call ADDSOLDE([F:ADI]N1,[L]MONTANT) From SUBSLD
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   Else
    GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
    GOK = 0 : Break
   Endif
  Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   GMESSAGE = mess(17,10704,1)-"10365" : # "Erreur sur la table diverse no:"
#   GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   GOK = 0 : Break
  Endif
  Read[ID]ID0=[M]DELREFNUM(IND)
  If !fstat
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   [F:HRSDP]CODACS = [F:ID]CODACS
#   [F:SDP]CODACS = [F:ID]CODACS
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  Endif
  Read[ECT]ECT0=[M]DELREFNUM(IND);[M]DELCTRNUM(IND)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  If !fstat
   [F:HRSDP]FCY    = [F:ECT]FCY
   [F:HRSDP]SRV    = [F:ECT]SRV
  Endif
  Rewrite [HRSDP]
#  If !fstat
#   [F:SDP]FCY    = [F:ECT]FCY
#   [F:SDP]SRV    = [F:ECT]SRV
#  Endif
#  Rewrite [SDP]
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If fstat<>0
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   GOK = 0 : Call FSTA("HRSDP") From GLOCK : Break
#   GOK = 0 : Call FSTA("SDP") From GLOCK : Break
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  Endif
 Elsif fstat<>5
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(4,10707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
#  GMESSAGE = mess(4,707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  GOK = 0 : Break
 Endif
Next
If GOK<1 : Return : Endif
Endif
#Mise à jour des soldes pour les lignes du bordereau
For nolign=1 To [M]BPAG
 # MAJ que si le montant a changé...
 If[M]OLDAMT(nolign-1)<>[M]AMT (nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Readlock[HRSDP]SDP0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
#  Readlock[SDP]SDP0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If !fstat
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M]TYPPAY(nolign-1)
#   Read [ADI]CODE=10365;[M]TYPPAY(nolign-1)
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#   Read [ADI]CODE=365;[M]TYPPAY(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   If ! fstat
    #Conversion en monnaie société...
    Call CONVERT ([M]CURBAN,DEVSOC,DEVSOC,TYPCOURS,datesyst,[M]AMT(nolign-1),MONTANT,STAT) From TRTDEV
    If !STAT
     Call CONVERT ([M]CURBAN,DEVSOC,DEVSOC,TYPCOURS,datesyst,[M]OLDAMT(nolign-1),OLDMONT,STAT) From TRTDEV
     If !STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
      Call ADDSOLDE([F:ADI]N1,OLDMONT-MONTANT) From SUBHRSLD
#      Call ADDSOLDE([F:ADI]N1,OLDMONT-MONTANT) From SUBSLD
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
     Else
      GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
      GOK = 0 : Break
     Endif
    Else
     GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
     GOK = 0 : Break
    Endif
   Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    GMESSAGE = mess(17,10704,1)-"10365" : # "Erreur sur la table diverse no:"
#    GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    GOK = 0 : Break
   Endif
   Read[ID]ID0=[M]REFNUM(nolign-1)
   If !fstat
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    [F:HRSDP]CODACS = [F:ID]CODACS
#    [F:SDP]CODACS = [F:ID]CODACS
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   Endif
   Read[ECT]ECT0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   If !fstat
    [F:HRSDP]FCY    = [F:ECT]FCY
    [F:HRSDP]SRV    = [F:ECT]SRV
   Endif
   Rewrite [HRSDP]
   If fstat<>0
    GOK = 0 : Call FSTA("HRSDP") From GLOCK : Break
   Endif
  Elsif fstat=5
   Raz [F:HRSDP]
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M]TYPPAY(nolign-1)
#   Read [ADI]CODE=10365;[M]TYPPAY(nolign-1)
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#   If !fstat
#    [F:SDP]FCY    = [F:ECT]FCY
#    [F:SDP]SRV    = [F:ECT]SRV
#   Endif
#   Rewrite [SDP]
#   If fstat<>0
#    GOK = 0 : Call FSTA("SDP") From GLOCK : Break
#   Endif
#  Elsif fstat=5
#   Raz [F:SDP]
#   Read [ADI]CODE=365;[M]TYPPAY(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   If ! fstat
    #Conversion en monnaie société...
    Call CONVERT ([M]CURBAN,DEVSOC,DEVSOC,TYPCOURS,datesyst,[M]AMT(nolign-1),MONTANT,STAT) From TRTDEV
    If !STAT
     #TIVAN - 06/06/2017 - X3-43826 - Start
     Call ADDSOLDE([F:ADI]N1,-[L]MONTANT) From SUBHRSLD
#     Call ADDSOLDE([F:ADI]N1,-[L]MONTANT) From SUBSLD
     #TIVAN - 06/06/2017 - X3-43826 - End
    Else
     GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
     GOK = 0 : Break
    Endif
   Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    GMESSAGE = mess(17,10704,1)-"10365" : # "Erreur sur la table diverse no:"
#    GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    GOK = 0 : Break
   Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   [F:HRSDP]EMP    = [M]REFNUM(nolign-1)
   [F:HRSDP]CTRNUM = [M]CTRNUM(nolign-1)
   Read[ID]ID0=[M]REFNUM(nolign-1)
   If !fstat
    [F:HRSDP]CODACS = [F:ID]CODACS
   Endif
   Read[ECT]ECT0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
   If !fstat
    [F:HRSDP]FCY    = [F:ECT]FCY
    [F:HRSDP]SRV    = [F:ECT]SRV
   Endif
   Write [HRSDP]
   If fstat<>0
    GOK = 0 : Call FSTA("HRSDP") From GLOCK : Break
   Endif
  Else
   GMESSAGE = mess(4,10707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
#   [F:SDP]EMP    = [M]REFNUM(nolign-1)
#   [F:SDP]CTRNUM = [M]CTRNUM(nolign-1)
#   Read[ID]ID0=[M]REFNUM(nolign-1)
#   If !fstat
#    [F:SDP]CODACS = [F:ID]CODACS
#   Endif
#   Read[ECT]ECT0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
#   If !fstat
#    [F:SDP]FCY    = [F:ECT]FCY
#    [F:SDP]SRV    = [F:ECT]SRV
#   Endif
#   Write [SDP]
#   If fstat<>0
#    GOK = 0 : Call FSTA("SDP") From GLOCK : Break
#   Endif
#  Else
#   GMESSAGE = mess(4,707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   GOK = 0 : Break
  Endif
 Endif
Next

If GOK<1 : Return : Endif

# Mise à jour détail acomptes
Gosub ACOMPTES
If GOK<1 : Return : Endif
#On vide la sauvegarde des lignes supprimées...
[M]DELIND=0
Effzo[M]30
Return

########################################
$ABANDON
#On vide la sauvegarde des lignes supprimées...
[M]DELIND=0
Effzo[M]30
Return

########################################
$ANNULE
GOK=1
Local Decimal OLDMONT
Local Char DEVSOC (GLONCUR)
Local Integer TYPCOURS
Local Char VALPAR (50)
Local Integer STAT

#Devise société
Read[CPY]CPY0=[M]CPY
If fstat=0
 DEVSOC=[F:CPY]ACCCUR
Else
 GMESSAGE = mess(81,116,1)-[M]CPY : # "Société incorrecte"
 GOK = 0 : Return
Endif

#Type de cours
Call PARAM("","TYPCOURS",VALPAR)From ADOVAL
TYPCOURS=val(VALPAR)

#Mise à jour du fichier SOLDE avec l'ancien solde
For nolign=1 To [M]BPAG
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Readlock[HRSDP]SDP0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
 If !fstat
  Read[ID]ID0=[M]REFNUM(nolign-1)
  If !fstat
   [F:HRSDP]CODACS = [F:ID]CODACS
  Endif
  Read[ECT]ECT0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1)
  If !fstat
   [F:HRSDP]FCY    = [F:ECT]FCY
   [F:HRSDP]SRV    = [F:ECT]SRV
  Endif
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
