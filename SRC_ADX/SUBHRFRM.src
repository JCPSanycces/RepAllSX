Return

#Programme entièrement repris de GRHBUG
Subprog NUMEROTE_PIECE(OLD,NEW)
Variable Char OLD ()
Variable Char NEW ()

Local Integer I, J, LG
Local Char NUMERO (30), NEWNUM(30)
I=len(OLD)
While I>0 & instr(1,"0123456789",mid$(OLD,I,1))=0
 I-=1
Wend
If I=0 : NEW=OLD : End : Endif
J=I
While J>0 & instr(1,"0123456789",mid$(OLD,J,1))<>0
 J-=1
Wend
J+=1
NUMERO=seg$(OLD,J,I): LG=len(NUMERO)

########################################
$INC2
NEWNUM=format$("No:"+num$(LG),val(NUMERO)+1)
If instr(1,NEWNUM,"*"): LG+=1: Goto INC2 : Endif
NEW=left$(OLD,J-1)+NEWNUM+right$(OLD,I+1)
End

########################################
#Pour simuler une modif lors d'une demande de numérotation automatique des pièces
$FIN_ACTION
 If GMODFRM=1 : REP="M" : GREP=REP : GMODFRM=0 : Endif
Return

########################################
# Chargement du tableau contenant les règlements
# Si pas les droits sur un des matricules contenu dans ce tableau -> affichage incomplet + modif interdite
Subprog CHARGE_STL(VALEUR,DROIT)
Variable Char    VALEUR() #contient le bordereau courant
Variable Integer DROIT
nolign   = 0
[L]DROIT = 1
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
For [F:HRSTL]STL0 Where [F:HRSTL]NUMFRM=VALEUR
 OK=1
 Gosub DROIT
 If OK
  nolign += 1
  [M]=[F:HRSTL]
  [M]OLDAMT(nolign-1)=[F:HRSTL]AMT
 Else
  [L]DROIT=0
 Endif
Next
#For [F:STL]STL0 Where [F:STL]NUMFRM=VALEUR
# OK=1
# Gosub DROIT
# If OK
#  nolign += 1
#  [M]=[F:STL]
#  [M]OLDAMT(nolign-1)=[F:STL]AMT
# Else
#  [L]DROIT=0
# Endif
#Next
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
[M]BPAG = nolign
If [L]DROIT=0
 #Droits insuffisants pour visualiser la totalité de ce bordereau
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE=mess(24,10704,1) : End
# GMESSAGE=mess(24,704,1) : End
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Endif
End

########################################
# Sauve le tableau contenant les règlements
Subprog SAUVE_STL(VALEUR)
Variable Char    VALEUR()
GOK=1
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
Delete [F:HRSTL] Where NUMFRM=[M]NUMFRM
If fstat=1
 GOK =-1 : GLOCK = "$STLPAY" : End
Endif
For nolign=1 To [M]BPAG
 [F:HRSTL]NUMFRM=[M]NUMFRM
 [F:HRSTL]NUMLIG=nolign
 [F:HRSTL]=[M]
 Write [HRSTL]
If fstat<>0
 GOK = 0 : Call FSTA("HRSTL") From GLOCK : Break
Endif
Next
#Delete [F:STL] Where NUMFRM=[M]NUMFRM
#If fstat=1
# GOK =-1 : GLOCK = "$STLPAY" : End
#Endif
#For nolign=1 To [M]BPAG
# [F:STL]NUMFRM=[M]NUMFRM
# [F:STL]NUMLIG=nolign
# [F:STL]=[M]
# Write [STL]
#If fstat<>0
# GOK = 0 : Call FSTA("STL") From GLOCK : Break
#Endif
#Next
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
If GOK<1 : End : Endif
End

