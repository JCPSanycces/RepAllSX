 Call CHERCHE_CTR(VALEUR, [M:HRFRM1]PYRDAT(nolign-1),[M]CTRNUM(nolign-1)) From DIVPAYE
 If [M:HRFRM1]CTRNUM(nolign-1)<>""
  Affzo [HRFRM1]CTRNUM(nolign-1)
 Else
  # Pas de contrat de travail pour ce salarié
  GMESSAGE = mess(150,10702,1)
  mkstat = 2 : End
 Endif
 MATRI = VALEUR
 CTR = [M:HRFRM1]CTRNUM(nolign-1)
# Call CHERCHE_CTR(VALEUR, [M:FRM1]PYRDAT(nolign-1),[M]CTRNUM(nolign-1)) From DIVPAYE
