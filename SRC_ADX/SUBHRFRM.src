########################################
Subprog AVANT_BPAG
End

########################################
Subprog APRES_BPAG
Gosub RECALCUL_TOT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If [M:HRFRM1]RIBFLG
 If adxgtb=1 : # Abandon => on efface les init de AM_REFNUM
  Dela nolign, [M:HRFRM1]RIBFLG-1 [M:HRFRM1]BPAG
 Else : # Affichage des autres lignes créées dans AM_REFNUM
  [M:HRFRM1]BPAG+=[M:HRFRM1]RIBFLG
  Affzo 10
 Endif
 [M:HRFRM1]RIBFLG=0
Endif
#If [M:FRM1]RIBFLG
# If adxgtb=1 : # Abandon => on efface les init de AM_REFNUM
#  Dela nolign, [M:FRM1]RIBFLG-1 [M:FRM1]BPAG
# Else : # Affichage des autres lignes créées dans AM_REFNUM
#  [M:FRM1]BPAG+=[M:FRM1]RIBFLG
#  Affzo 10
# Endif
# [M:FRM1]RIBFLG=0
#Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- SEND
End

########################################
Subprog AS_BPAG
If [M]FLGTOT=1
  Gosub RECALCUL_TOT
 [M]FLGTOT=0
Endif
[M]WBNF=[M]BNF(nolign-1)
Affzo[M]WBNF
End

########################################
$RECALCUL_TOT
Local Integer I
Raz[M]TOT
For I=0 To [M]BPAG-1
 [M]TOT=[M]TOT+[M]AMT(I)
Next
Affzo[M]TOT
Return

########################################
Subprog C_BPAG

Local Integer ISUPP,JSUPP,KSUPP,XSUPP
If [M]STA=3 & (status=65 or status=68 or status=73 or status=75 or status=82 or status=83)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE=mess(18,10704,1) #Opération impossible, ce bordereau est validé.
# GMESSAGE=mess(18,704,1) #Opération impossible, ce bordereau est validé.
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat=2 : End
Else
#Remplit les zones dimensionnées par les lignes supprimées
If status=65 or status=68 or status=83
 If status=65
  ISUPP = nolign
  JSUPP = nolign
 Else
  ISUPP = nolign
  JSUPP = nolign1
 Endif
 If [M]DELIND+(JSUPP-ISUPP)+1<=dim([M]DELAMT)
  For KSUPP=ISUPP To JSUPP
   # 55103
   If [M]OLDAMT(KSUPP-1)<>0
    XSUPP = [M]DELIND
    [M]DELIND += 1
    [M]DELAMT(XSUPP)    = [M]AMT(KSUPP-1)
    [M]DELREFNUM(XSUPP) = [M]REFNUM(KSUPP-1)
    [M]DELCTRNUM(XSUPP) = [M]CTRNUM(KSUPP-1)
    [M]DELTYPPAY(XSUPP) = [M]TYPPAY(KSUPP-1)
   Endif
  Next KSUPP
 Else
  #Suppression supplémentaire impossible.
  #Veuillez enregistrer votre bordereau pour continuer...
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Call ERREUR(mess(15,10704,1)) From GESECRAN
#  Call ERREUR(mess(15,704,1)) From GESECRAN
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  mkstat=2 : End
 Endif
# Modification....
Elsif status=75
 REP="M"
 GREP=REP
Endif
#Mise à jour d'un flag pour lancer le recalcul du total...
[M]FLGTOT=1
Endif
End


#Verif droit sur les matricules
########################################
$DROIT
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
Read[F:ID]ID0=[F:HRSTL]REFNUM
#Read[F:ID]ID0=[F:STL]REFNUM
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
## Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]CONSUL<>2
  OK=0 : Return
 Endif
Endif

## Autorisations par site
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
Read [ECT]ECT0=[F:HRSTL]REFNUM;[F:HRSTL]CTRNUM
#Read [ECT]ECT0=[F:STL]REFNUM;[F:STL]CTRNUM
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
If !fstat
 If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
  If !find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))
   OK=0 : Return
  Endif
 Endif
 ## Autorisations par service
 If GUSRACS<>2 & !find([F:ECT]SRV,GAUTSRV(1..GNBSERV))
  OK=0 : Return
 Endif
Endif
Return

# Recherche des infos sur le compte
Subprog SRC_ACCOUNT(MAT, BID, BAN, CUR, NR, EEC)
Value    Char    MAT, BID, BAN
Variable Char    CUR
Variable Integer NR, EEC
Local    Integer I
#FQ79702 - SEGAY 27/01/12 - ouverture de RIB1 au lieu de RIB
# Pouvait changer le filtre dans les boucles For qui appelle SRC_ACCOUNT
#  If clalev([F:RIB])=0 : Local File EMPLORIB [RIB] : Endif
  If clalev([F:RIB1])=0 : Local File EMPLORIB [RIB1] : Endif
  If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

  CUR = "" : NR = 1

  Filter [F:RIB1] Where REFNUM=MAT & BIDNUM=BID #& CPYBAN=BAN : #89883
  Read [F:RIB1] First
  If !fstat Then
    If find([F:RIB1]ACCNONREI,0,2) Then
      NR=2
    Endif

    Read [F:TCY]TCY0=[F:RIB1]BIDCRY
    If !fstat Then
      CUR = [F:TCY]CUR
      EEC = [F:TCY]EECFLG
    Endif
  Endif
  Filter [F:RIB1]
End

######################################################################################
# MABON - FQ65412 - 18/08/10 - Si code activité VII à Oui,
# on renseigne le code motif économique, selon certaines conditions :
#      Devise transaction='EUR' + Pays banque dest dans zone Euro + Compte non résident + AMTCUR>GAMTVIR1
#   OU Devise transaction='EUR' + Pays banque dest pas dans zone Euro + AMTCUR>GAMTVIR2
#   OU Devise transaction<>'EUR' + AMTCUR>GAMTVIR3
Subprog CALC_BDFECOCOD(MAT, BIDNUM, BAN, AMTCUR, CURPAY, ACCDAT, CPY, BDFECOCOD, STAT)
Value Char       MAT, BIDNUM, BAN, CURPAY, CPY
Value Decimal    AMTCUR
Value Date       ACCDAT
Variable Char    BDFECOCOD
Variable Integer STAT
Local Integer    OK, ACCNR, STAT2, EEC
Local Char       CURBANK
Local Decimal    AMTCUR_D
#Local Char       PARAM(250)
#Local Decimal    GAMTVIR1, GAMTVIR2, GAMTVIR3
##
#  Call PARAM([M]FCYFRM,"AMTVIR1",PARAM) From ADOVAL : GAMTVIR1=val(PARAM)
#  Call PARAM([M]FCYFRM,"AMTVIR2",PARAM) From ADOVAL : GAMTVIR2=val(PARAM)
#  Call PARAM([M]FCYFRM,"AMTVIR3",PARAM) From ADOVAL : GAMTVIR3=val(PARAM)

  STAT=0
  #LIPET - 2018-09-12 - X3-86695 - START
  #Call ACTIV("VII",OK) From SUBACV
  Call ACTIV("HRVII",OK) From SUBACV
  #LIPET - 2018-09-12 - X3-86695 - END
  If OK Then
    STAT=OK
    BDFECOCOD=""
    Call SRC_ACCOUNT(MAT, BIDNUM, BAN, CURBANK, ACCNR, EEC)
    If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
    Read [F:ID]ID0=MAT
    If !fstat and [F:ID]BDFECOCOD<>"" Then
      Call CONVERT(CURPAY,GCURSHR,CURBANK,1,ACCDAT,AMTCUR,AMTCUR_D, STAT2) From TRTDEV
      If STAT2<>0 Then AMTCUR_D=AMTCUR Endif

       #89883 : SAISIE_BDFE n'existe pas en V6... c'est un mauvais report de GX3APP
#      If (CURPAY=GCURSHR and EEC=2 and ACCNR=2 and AMTCUR_D>=GAMTVIR1)
#&       or (CURPAY=GCURSHR and EEC<>2 and ACCNR=2 and AMTCUR_D>=GAMTVIR2)
#&       or (CURPAY<>GCURSHR and AMTCUR_D>=GAMTVIR3)
#&       or (BIDNUM="" and AMTCUR=0 and SAISIE_BDFE=1) Then
If (CURPAY=GCURSHR and EEC=2 and ACCNR=2 and AMTCUR_D>=GAMTVIR1)
&       or (CURPAY=GCURSHR and EEC<>2 and ACCNR=2 and AMTCUR_D>=GAMTVIR2)
&       or (CURPAY<>GCURSHR and AMTCUR_D>=GAMTVIR3)
&       or (BIDNUM="" and AMTCUR=0) Then
        BDFECOCOD = [F:ID]BDFECOCOD
        #
      Endif
    Endif
  Endif
End

######################################################################################
# MABON - FQ65412 - 18/08/10 - Si société déclarante, seul le code 060 est autorisé
Subprog C_BDFECOCOD(VALEUR)
Variable Char    VALEUR()

End
