$EXEBOUT
Case BOUT
 When "O"
  Gosub RELIT From GOBJSUB : GMODFRM=0
 When "Q"
  # Déverrouille le bordereau à partir duquel on a fait la proposition
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  Gosub LECTURE From GOBJSUB : GMODFRM=0
 Endcase
Return

########################################
$SETBOUT
If [L]DROIT=0
 Call VIREBOUT (CHAINE,"MAOPQ") From GOBJET
 Return
Endif
ETAMEN(1)=0
If REP<>""
 Call VIREBOUT (CHAINE,"AOPQ") From GOBJET  :#Bouton Suppr+Valid+Num+Proposition
Endif
[M]CURBAN=[M]CUR
If [M]NUMFRM=""
 Call VIREBOUT (CHAINE,"AOP") From GOBJET  :#Bouton Suppr+Valid+Num
Endif
#Impossible de modifier certaines zones du tableau suivant l'état du
#bordereau (Saisi, Imprimé, Validé)
Case [M]STA
 When 1 : Call VIREBOUT (CHAINE,"O") From GOBJET     :#Bouton Validation
 When 3 : Call VIREBOUT (CHAINE,"MAOP") From GOBJET  :#Bouton Suppr+Valid+Num
Endcase
If[M]BPAG=0
 Call VIREBOUT (CHAINE,"P") From GOBJET    :#Bouton Numérotation
Endif
#Proposition de l'édition en liste adapté au mode de règlement...
If CLECUR & [M]MODPAY<>""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Read [ADI]CODE=10387;[M]MODPAY
# Read [ADI]CODE=387;[M]MODPAY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat=0
  # 34258
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Case [F:ADI]N1
   When 1 : # Chèque
    REPORT1 = "LIST"+[M]MODPAY
    CHAINE += "E"
   When 2   : # Espece
    Call VIREBOUT (CHAINE,"E") From GOBJET    :#Bouton Edition
   When 3 : # Virement
    If [F:HRFRM]TFBFIL<>""
     REPORT1 = "LETVIR"
    Else
     REPORT1 = "LIST"+[M]MODPAY
    Endif
    CHAINE += "E"
   When 4 : # Virement internationaux
    If [F:HRFRM]TFBFIL<>""
     REPORT1 = "LETVIR"
    Else
     REPORT1 = "LISTVIR"
    Endif
    CHAINE += "E"
  Endcase
#  Case [F:ADI]N1
#   When 1 : # Chèque
#    REPORT1 = "LIST"+[M]MODPAY
#    CHAINE += "E"
#   When 2   : # Espece
#    Call VIREBOUT (CHAINE,"E") From GOBJET    :#Bouton Edition
#   When 3 : # Virement
#    If [F:FRM]TFBFIL<>""
