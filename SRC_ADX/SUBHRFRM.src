Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()
Call LECTURE(GBIDC2,VALEUR,"") From CONTOBJ
Gosub DROITS_BAN
If mkstat : End : Endif
If dim([M]CURBAN)>=0
 [M]CURBAN = [F:BAN]CUR
 Affzo CURBAN
Endif
[M]CUR    = [F:BAN]CUR
Affzo [M]CUR
End

$DROITS_BAN
mkstat=0
If [F:BAN]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:BAN]ACS
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(4,104,1)-":"-[F:BAN]BAN        : #  Vous n'avez pas les droits pour ce code
  mkstat = 2 : Return
 Endif
Endif
Return

