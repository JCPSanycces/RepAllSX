$FRMNUM
GMODFRM=1
Local Char OLD (30)
Local Char NEW (30)
OLD=[M:DIA]VRCNUM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
For I=[M:DIA]LIGNUM-1 To [M:HRFRM1]BPAG-1
 [M:HRFRM1]NBRVRC(I)= OLD
 Affzo [M:HRFRM1]NBRVRC(I)
 Call NUMEROTE_PIECE(OLD, NEW)
 OLD=NEW
Next
#For I=[M:DIA]LIGNUM-1 To [M:FRM1]BPAG-1
