#    Else
#     REPORT1 = "LISTVIR"
#    Endif
#    CHAINE += "E"
#  Endcase
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If VERROU & [M]STA=3 & ([F:ADI]N1=3 | [F:ADI]N1=4) :#Virement ou virement internationaux validé => Bouton Fichier banque
   CHMEN +="1"
  Endif


    #MAPAD Add simulation button - START
  If VERROU & [M]STA<>3  & ([F:ADI]N1=3 | [F:ADI]N1=4)
    CHMEN +="2"
  Endif
  #MAPAD Add simulation button - END

 Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(17,10704,1)-"10387" : # "Erreur sur la table diverse no:"
#  GMESSAGE = mess(17,704,1)-"387" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  GOK = 0 : Return
 Endif
Endif
#39925
If GHISTO=1
 Call VIREBOUT(CHAINE,"AOPQ") From GOBJET
 CHMEN=""
Endif
Return

########################################
$ACOMPTES
GOK=1
# DBA le 20/07/04 : Bug
#Suppression de l'historique des acomptes du bordereau courant et recréation
Delete [HIP] Where FRM=[M]NUMFRM
If fstat=1
 GOK = -1 : GLOCK = "$HISPOA"-[M]NUMFRM : Return
Endif
For nolign=1 To [M]BPAG
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M]TYPPAY(nolign-1)
# Read [ADI]CODE = 10365;[M]TYPPAY(nolign-1)
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat=0
  If [F:ADI]N1<2
   #Conversion en monnaie société...
   Call CONVERT ([M]CURBAN,DEVSOC,DEVSOC,TYPCOURS,datesyst,[M]AMT(nolign-1),MONTANT,STAT) From TRTDEV
   If !STAT
    Read [HIP]HIP0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1);[M]PYRDAT(nolign-1);[M]NUMFRM;1
    If fstat
     Raz [F:HIP]
     [F:HIP]EMP    = [M]REFNUM(nolign-1)
     [F:HIP]CTRNUM = [M]CTRNUM(nolign-1)
     [F:HIP]DAT    = [M]PYRDAT(nolign-1)
     [F:HIP]FRM    = [M]NUMFRM
     [F:HIP]POA    = MONTANT
     [F:HIP]MODDAC = 1 :#Manuel
     If [F:ADI]N1=1
      [F:HIP]TYPPOA=1 :#Acompte standard
     Else
      [F:HIP]TYPPOA=-1 :#Acompte 13° mois
     Endif
     Write [HIP]
    Else
     [F:HIP]POA+=[L]MONTANT
     Rewrite [HIP] Curr
    Endif
    If fstat
     GOK = 0 : Call FSTA("HIP") From GLOCK : Break
    Endif
   Else
    GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
    GOK = 0 : Break
   Endif
  Endif
 Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(17,10704,1)-"10365" : # "Erreur sur la table diverse no:"
#  GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GOK = 0 : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

