Subprog C_BIDNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAYS(GLONCRY)
PAYS=[M]CRY(nolign-1)
If VALEUR <>""
 Call CONTRIB(VALEUR,PAYS)From CONTNUM
Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Read [ADI]CODE=10387;[M]MODPAY
# Read [ADI]CODE=387;[M]MODPAY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat=0
  If ([F:ADI]N1=3 | [F:ADI]N1=4) :#Virement ou virement internationaux (34388)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   GMESSAGE=mess(12,10704,1)
#   GMESSAGE=mess(12,704,1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   mkstat=2 : End
  Endif
 Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(17,10704,1)-"10387" : # "Erreur sur la table diverse no:"
#  GMESSAGE = mess(17,704,1)-"387" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  mkstat=2 : End
 Endif
Endif

#FQ70222 - MABON 27/12/10 - Ajout du champ IBAN
If dim([M]IBAN)>0 Then
 Call IBAN(PAYS,VALEUR,[M]IBAN(nolign-1)) From TRTBPA
 Affzo IBAN(nolign-1)
Endif
End

# MABON - FQ65412- 18/08/10 - Calcul du code motif économique
Subprog AM_BIDNUM(VALEUR)
Variable Char VALEUR
Local Char    ECOCOD
Local Integer STAT

  Call CALC_BDFECOCOD([M]REFNUM(nolign-1),VALEUR,[M]BAN,[M]AMT(nolign-1),[M]CURBAN,[M]PYRDAT(nolign-1),[M]CPY,ECOCOD,STAT)
  If STAT>0 Then
    If ECOCOD="" or [M]BDFECOCOD(nolign-1)="" Then
      [M]BDFECOCOD(nolign-1) = ECOCOD
      Affzo [M]BDFECOCOD(nolign-1)
    Endif
  Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Filter [F:RIB] Where REFNUM=[M]REFNUM(nolign-1) & TYPPAY=[M:HRFRM1]TYPPAY(nolign-1) & MODSTL=[M:HRFRM1]MODPAY
&                & BIDNUM=VALEUR
#  Filter [F:RIB] Where REFNUM=[M]REFNUM(nolign-1) & TYPPAY=[M:FRM1]TYPPAY(nolign-1) & MODSTL=[M:FRM1]MODPAY
#&                & BIDNUM=VALEUR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  For [F:RIB]
    [M]BICCOD(nolign-1)=[F:RIB]BICCOD
    Break
  Next
  Filter [F:RIB]
End

