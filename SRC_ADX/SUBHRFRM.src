Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
OK=1
#Verif appartenance société
If VALEUR<>""
 Read [F:ID]ID0=VALEUR
 If !fstat & [F:ID]FLGMULCTR<>2
  Read [FCY]FCY0=[F:ID]FCY
  If !fstat
   If [FCY]LEGCPY<>[M]CPY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    Call AVERTIR(VALEUR-mess(10,10704,1)-[FCY]LEGCPY,OK) From GESECRAN
#    Call AVERTIR(VALEUR-mess(10,704,1)-[FCY]LEGCPY,OK) From GESECRAN
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    #MAT est rattaché à la société...
   Endif
  Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    GMESSAGE = mess(4,10707,1)-"FACILITY" : # "Erreur de lecture sur le fichier"
#   GMESSAGE = mess(4,707,1)-"FACILITY" : # "Erreur de lecture sur le fichier"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   mkstat=2 : End
  Endif
 Endif
 #Verif infos comptable
 Read [F:CPT]CPT0=VALEUR
 If fstat
    # (C) PROSPER 23/07/10 - Prise en compte des infos comptable contrat - contrôle complémentaire
    # Rien au niveau salarié ce qui en soi n'est pas normal ... on vérifie cependant un CPR
    # éventuel ... Peu probable que cela puisse fonctionner correctement en "création" car CTRNUM
    # CTRDAT ne sont pas connu ....
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    If [M]CTRNUM(nolign-1) <> "" & [M]CTRDAT(nolign-1) <> [0/0/0]
        Read [F:CPR]CPR0 = [L]VALEUR ; [M]CTRNUM ; [F:HRCTR]CTRDAT
        If fstat
            Call AVERTIR(VALEUR-mess(5,10704,1),OK) From GESECRAN
            # MAT Aucune information comptable
        Endif
    Else
       Call AVERTIR(VALEUR-mess(5,10704,1),OK) From GESECRAN
       # MAT Aucune information comptable
    Endif
 Endif
#    If [M]CTRNUM(nolign-1) <> "" & [M]CTRDAT(nolign-1) <> [0/0/0]
#        Read [F:CPR]CPR0 = [L]VALEUR ; [M]CTRNUM ; [F:CTR]CTRDAT
#        If fstat
#            Call AVERTIR(VALEUR-mess(5,704,1),OK) From GESECRAN
#            # MAT Aucune information comptable
#        Endif
#    Else
#       Call AVERTIR(VALEUR-mess(5,704,1),OK) From GESECRAN
#       # MAT Aucune information comptable
#    Endif
# Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Endif
End

