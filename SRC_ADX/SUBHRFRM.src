############################# ETIQUETTES DE [M:FRM1] #################################

Subprog AS_PYRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[00/00/0000]
 If nolign>1
  VALEUR=[M]PYRDAT(nolign-2)    : # date ligne précédente
 Else
  VALEUR=[M]DAT    : # date du bordereau
 Endif
Endif
End

########################################
Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
#27788
If left$([M]TYPPAY(nolign-1),2)="AC" & [M]REFNUM(nolign-1)<>""
 Call UNICITE(VALEUR,[M]REFNUM(nolign-1),[M]TYPPAY(nolign-1),[M]CTRNUM(nolign-1))
 If mkstat : End : Endif
Endif
End

###########################################################################
## Fichier HISPOA : Index sur matricule + date + bordereau + type acompte
## 27788
###########################################################################
Subprog UNICITE(DAT,EMP,TYP,CTR)
Value Date DAT
Value Char EMP, TYP, CTR
Local Integer I, J, NOL

NOL = nolign-1


## On regarde avant nolign
J = 0
I = find(EMP,[M]REFNUM(J..NOL-1))
While I<>0
 J +=I
 If [M]PYRDAT(J-1)=DAT & [M]TYPPAY(J-1)=TYP & [M]CTRNUM(J-1)=CTR
  GERR=1
  GMESSAGE = mess(24,123,1)-num$(J) : # Code déjà existant en ligne
  mkstat=2 : Break
 Endif
 I = find(EMP,[M]REFNUM(J..NOL-1))
Wend
If mkstat : End : Endif

## On regarde après nolign
J = NOL+1
I = find(EMP,[M]REFNUM(J..dim([M]REFNUM)-1))
While I<>0
 J +=I
 If [M]PYRDAT(J-1)=DAT & [M]TYPPAY(J-1)=TYP  & [M]CTRNUM(J-1)=CTR
  GERR=1
  GMESSAGE = mess(24,123,1)-num$(J) : # Code déjà existant en ligne
  mkstat=2 : Break
 Endif
 I = find(EMP,[M]REFNUM(J..dim([M]REFNUM)-1))
Wend
End

########################################
Subprog AS_TYPPAY(VALEUR)
Variable Char    VALEUR()
#50690
If [M]NUMFRM<>"" & VALEUR<>""
 mkstat=2
Endif
If VALEUR=""
 If nolign>1
  VALEUR=[M]TYPPAY(nolign-2)
 Else
#PEVAN - 2018-09-20 - X3-109409 - START
  If GCURLEG = ""
    If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
    Filter [CPY] Where [F:CPY]CPY=[M]CPY
    Read [CPY] First
    If !fstat
      If [F:CPY]LEG <> ""
        GCURLEG = [F:CPY]LEG
      Endif
    Endif
    Filter [CPY]
  Endif
#PEVAN - 2018-09-20 - X3-109409 - END
  # 36772
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
  Filter [F:ADI] Where NUMTAB=10365 & DEFVAL=2 & LEG=GCURLEG
#  Filter [F:ADI] Where NUMTAB=10365 & DEFVAL=2
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#  Filter [F:ADI] Where NUMTAB=365 & DEFVAL=2
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  Read [F:ADI] First
  If !fstat
   VALEUR = [F:ADI]CODE
  Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
   Filter [F:ADI] Where NUMTAB=10365 & LEG=GCURLEG
#   Filter [F:ADI] Where NUMTAB=10365
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#   Filter [F:ADI] Where NUMTAB=365
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   Read [F:ADI] First
   If !fstat
    VALEUR = [F:ADI]CODE
   Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    GMESSAGE = mess(17,10704,1)-"10365" : # "Erreur sur la table diverse no:"
#    GMESSAGE = mess(17,704,1)-"365" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    mkstat=2: End
   Endif
  Endif
  Filter [F:ADI]
 Endif
Endif
End

########################################
Subprog AM_TYPPAY(VALEUR)
Variable Char    VALEUR()

Local Shortint I, J

# 27788
If left$(VALEUR,2)="AC" & [M]REFNUM(nolign-1)<>"" & [M]PYRDAT(nolign-1)<>[0/0/0]
 Call UNICITE([M]PYRDAT(nolign-1),[M]REFNUM(nolign-1),VALEUR,[M]CTRNUM(nolign-1))
 If mkstat : End : Endif
Endif

J=[F:ADI]N1
For I=0 To [M]BPAG-1
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M]TYPPAY(I)
# Read [ADI]CODE=10365;[M]TYPPAY(I)
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
# Read [ADI]CODE=365;[M]TYPPAY(I)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If I<>nolign-1
  If (!find([F:ADI]N1,7,8) & find(J,7,8)) | (find([F:ADI]N1,7,8) & !find(J,7,8))
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   [V]GMESSAGE=mess(18,10718,1)
#   [V]GMESSAGE=mess(18,718,1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   #           Les règlements des notes de frais ne peuvent être sur le même
   #           bordereau que d'autres règlements
   mkstat     =2
   Break
  Endif
 Endif
Next
If mkstat : End : Endif

End


