 If GNBSOC<>0
  VALEUR=GDEFSOC
 Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
If [F:CPY]MAIFCY=""
 #Pas de site principal rattaché à la société
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE=mess(68,107,1)-VALEUR
# GMESSAGE=mess(68,107,1)-VALEUR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat=2 : End
Endif
#MIPEA - 2017-03-23- US X3-11264 ST X3-25377- START
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & GCURLEG <> [F:CPY]LEG Then
     mkstat=2
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
   Endif
Endif
Filter [CPY]
#MIPEA - 2017-03-23- US X3-11264 ST X3-25377- END
End

