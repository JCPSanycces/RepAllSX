# MABON - FQ65412- 18/08/10 - Calcul du code motif économique
Subprog AM_AMT(VALEUR)
Variable Decimal VALEUR
Local Char    ECOCOD
Local Integer STAT
  Call CALC_BDFECOCOD([M]REFNUM(nolign-1),[M]BIDNUM(nolign-1),[M]BAN,VALEUR,[M]CURBAN,[M]PYRDAT(nolign-1),[M]CPY,ECOCOD,STAT)
  If STAT>0 Then
    If ECOCOD="" or [M]BDFECOCOD(nolign-1)="" Then
      [M]BDFECOCOD(nolign-1) = ECOCOD
      Affzo [M]BDFECOCOD(nolign-1)
    Endif
  Endif
End

