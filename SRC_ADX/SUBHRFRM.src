Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
OK=1
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=VALEUR & CTRDAT<=[M]PYRDAT(nolign-1)
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  If [FCY]LEGCPY<>[M]CPY
   Call AVERTIR(VALEUR-mess(10,10704,1)-[FCY]LEGCPY,OK) From GESECRAN
   #MAT est rattaché à la société...
  Endif
 Else
  GMESSAGE = mess(4,10707,1)-"FACILITY" : # "Erreur de lecture sur le fichier"
  mkstat=2 : End
 Endif
Endif
#Filter [CTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=VALEUR & CTRDAT<=[M]PYRDAT(nolign-1)
#Read [CTR]CTR0 Last
#Filter [CTR]
#If !fstat
# Read [FCY]FCY0=[F:CTR]ETRFCY
# If !fstat
#  If [FCY]LEGCPY<>[M]CPY
#   Call AVERTIR(VALEUR-mess(10,704,1)-[FCY]LEGCPY,OK) From GESECRAN
#   #MAT est rattaché à la société...
#  Endif
# Else
#  GMESSAGE = mess(4,707,1)-"FACILITY" : # "Erreur de lecture sur le fichier"
#  mkstat=2 : End
# Endif
#Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2017-05-19- US X3-11287- START
Local Decimal MONTANT, MTRESTE, PCTMAT, CURRND, AMTMAT
#Local Decimal MONTANT, MTRESTE, PCTMAT, CURRND
#MIPEA - 2017-05-19- US X3-11287- END
Local Char DEVSOC (GLONCUR)
Local Integer TYPCOURS
Local Char VALPAR (50)
Local Integer STAT, NBRIB
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Local Char MATRI (GLONEML), CTR(GLONHRCTR)
#Local Char MATRI (GLONMAT), CTR(GLONCTR)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Local Date DATMAT
Local Shortint I
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
MATRI = [M:HRFRM1]REFNUM(nolign-1)
#MATRI = [M:FRM1]REFNUM(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
CTR = VALEUR
Gosub REMPLIT
Affzo [M]CRY(nolign-1), BIDNUM(nolign-1), PAB1(nolign-1), PAB2(nolign-1), BNF(nolign-1)
Affzo [M]FCY(nolign-1), AMT(nolign-1)
Affzo [M]WBNF
End

$REMPLIT
# Proposition d'un site
If [M]FCY(nolign-1)=""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[M]PYRDAT(nolign-1)
 Read [HRCTR]CTR1 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY(nolign-1)=[F:HRCTR]ETRFCY
# Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[M]PYRDAT(nolign-1)
# Read [CTR]CTR1 Last
# Filter [CTR]
# If !fstat
#  [M]FCY(nolign-1)=[F:CTR]ETRFCY
  #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 Endif
Endif
# Proposition d'un montant
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read[HRSDP]SDP0=MATRI;CTR
#Read[SDP]SDP0=MATRI;CTR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If !fstat
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 [L]MONTANT=func SUBHRSLD.GETSOLDE([F:ADI]N1)
# [L]MONTANT=func SUBSLD.GETSOLDE([F:ADI]N1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Elsif fstat<>5
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE = mess(4,10707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
# GMESSAGE = mess(4,707,1)-"SOLDPAY" : # "Erreur de lecture sur le fichier"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat=2 : End
Endif

# DBA le 02/09/04 : Bug 24391 et 22697
# Conversion en monnaie entête...
# Type de cours
Call PARAM("","TYPCOURS",VALPAR)From ADOVAL
TYPCOURS=val(VALPAR)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read[CPY]CPY0=[M:HRFRM1]CPY
#Read[CPY]CPY0=[M:FRM1]CPY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
DEVSOC=[F:CPY]ACCCUR

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Call CONVERT(DEVSOC,[M:HRFRM1]CURBAN,DEVSOC,TYPCOURS,datesyst,[L]MONTANT,[L]MONTANT,STAT) From TRTDEV
#Call CONVERT(DEVSOC,[M:FRM1]CURBAN,DEVSOC,TYPCOURS,datesyst,[L]MONTANT,[L]MONTANT,STAT) From TRTDEV
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE = mess(34,110,1)-[M:HRFRM1]CURBAN : # "Erreur de conversion en devise"
# GMESSAGE = mess(34,110,1)-[M:FRM1]CURBAN : # "Erreur de conversion en devise"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat=2 : End
Endif

# Salarié déjà saisi dans le tableau : on prend le solde sans s'occuper de le ventiler
[L]STAT=0
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
For I=0 To [M:HRFRM1]BPAG-1
 If I<>nolign-1 & [M:HRFRM1]TYPPAY(I)=[M:HRFRM1]TYPPAY(nolign-1) & [M:HRFRM1]REFNUM(I)=MATRI & [M:HRFRM1]CTRNUM(I)=CTR
  #78365
  #[L]MONTANT-=[M:FRM1]AMT(I)
  [L]MONTANT-=[M:HRFRM1]AMT(I)-[M:HRFRM1]OLDAMT(I)
  [L]STAT    =1
 Endif
Next
#For I=0 To [M:FRM1]BPAG-1
# If I<>nolign-1 & [M:FRM1]TYPPAY(I)=[M:FRM1]TYPPAY(nolign-1) & [M:FRM1]REFNUM(I)=MATRI & [M:FRM1]CTRNUM(I)=CTR
#  #78365
#  #[L]MONTANT-=[M:FRM1]AMT(I)
#  [L]MONTANT-=[M:FRM1]AMT(I)-[M:FRM1]OLDAMT(I)
#  [L]STAT    =1
# Endif
#Next
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-05-19- US X3-11287- START
Filter [RIB] Where REFNUM=MATRI & TYPPAY=[M:HRFRM1]TYPPAY(nolign-1)
&                & MODSTL=[M:HRFRM1]MODPAY
&     Order By Key CLE=PAYPCT;PAYAMT Desc
#Filter [RIB] Where REFNUM=MATRI & TYPPAY=[M:HRFRM1]TYPPAY(nolign-1)
#&                & MODSTL=[M:HRFRM1]MODPAY
#&     Order By Key CLE=PAYPCT Desc
#MIPEA - 2017-05-19- US X3-11287- END
#Filter [RIB] Where REFNUM=MATRI & TYPPAY=[M:FRM1]TYPPAY(nolign-1)
#&                & MODSTL=[M:FRM1]MODPAY
#&     Order By Key CLE=PAYPCT Desc
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
[L]NBRIB=rowcount([RIB])
If ![L]NBRIB
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-05-19- US X3-11287- START
 Filter [RIB] Where REFNUM=MATRI & TYPPAY="" & MODSTL=[M:HRFRM1]MODPAY
&     Order By Key CLE=PAYPCT;PAYAMT Desc
# Filter [RIB] Where REFNUM=MATRI & TYPPAY="" & MODSTL=[M:HRFRM1]MODPAY
#&     Order By Key CLE=PAYPCT Desc
#MIPEA - 2017-05-19- US X3-11287- END
# Filter [RIB] Where REFNUM=MATRI & TYPPAY="" & MODSTL=[M:FRM1]MODPAY
#&     Order By Key CLE=PAYPCT Desc
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 [L]NBRIB=rowcount([RIB])
Endif
Case [L]NBRIB
 When 0
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  [M:HRFRM1]AMT(nolign-1)=[L]MONTANT
  Affzo [HRFRM1] AMT(nolign-1)
#  [M:FRM1]AMT(nolign-1)=[L]MONTANT
#  Affzo [FRM1] AMT(nolign-1)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  Filter [RIB]
  End
 When 1
 When Default
  If [L]STAT
   [L]NBRIB=1
  Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   Call OUINON(func AFNC.MES1(mess(25,10704,1),num$([L]NBRIB)),[L]STAT) From GESECRAN
#   Call OUINON(func AFNC.MES1(mess(25,704,1),num$([L]NBRIB)),[L]STAT) From GESECRAN
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   # Respecter le paramétrage de la fiche salarié en ventilant le montant sur $1$ comptes
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   If [L]STAT=2 & [M:HRFRM1]BPAG+[L]NBRIB>dim([M:HRFRM1]REFNUM)
#   If [L]STAT=2 & [M:FRM1]BPAG+[L]NBRIB>dim([M:FRM1]REFNUM)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    [V]GMESSAGE=mess(85,100,1) : # Pas assez de lignes
    mkstat     =2
    Filter [RIB]
    End
   Elsif [L]STAT<>2
    [L]NBRIB=1
   Endif
  Endif
Endcase

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10387;[M]MODPAY
If fstat
 GMESSAGE = mess(17,10704,1)-"10387" : # "Erreur sur la table diverse no:"
#Read [ADI]CODE=387;[M]MODPAY
#If fstat
# GMESSAGE = mess(17,704,1)-"387" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat   =2
 Filter [RIB]
 End
Endif

# Devise du bordereau
If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Call LECTURE("TCU",[M:HRFRM1]CUR,"") From CONTOBJ
#Call LECTURE("TCU",[M:FRM1]CUR,"") From CONTOBJ
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
[L]CURRND=[F:TCU]CURRND

[L]STAT   =nolign-1
[L]MTRESTE=[L]MONTANT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If [L]NBRIB>1 : Insa [L]STAT+1, [L]NBRIB-1 [M:HRFRM1]BPAG : [M:HRFRM1]RIBFLG=[L]NBRIB : Endif
#If [L]NBRIB>1 : Insa [L]STAT+1, [L]NBRIB-1 [M:FRM1]BPAG : [M:FRM1]RIBFLG=[L]NBRIB : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
For [RIB]CLE
 If ([F:ADI]N1=3 | [F:ADI]N1=4) : # Virement ou virement internationaux (34388)
  [M]CRY   ([L]STAT)=[F:RIB]BIDCRY
  [M]BIDNUM([L]STAT)=[F:RIB]BIDNUM
  #FQ70222 - MABON 27/12/10 - Ajout du champ BICCOD
  [M]BICCOD([L]STAT)=[F:RIB]BICCOD
  [M]PAB1  ([L]STAT)=[F:RIB]PAB1
  [M]PAB2  ([L]STAT)=[F:RIB]PAB2
  #FLNEL 23/6/2014 added next line to default bank account type and bank branc number
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  If func AFNC.ACTIV("KGZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    [M]BANBRCNUM  ([L]STAT)=[F:RIB]BANBRCNUM
    [M]BANACCTYP  ([L]STAT)=[F:RIB]BANACCTYP
  Endif

 Endif
 [M]BNF([L]STAT)=[F:RIB]BNF
 If [L]STAT=nolign-1 : [M]WBNF=[F:RIB]BNF : Endif
 If [L]NBRIB=1
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  [M:HRFRM1]AMT([L]STAT)=[L]MONTANT
  Break
 Elsif [L]STAT>=nolign
  [M:HRFRM1]REFNUM([L]STAT)= MATRI
  [M:HRFRM1]CTRNUM()= CTR
  [M:HRFRM1]PYRDAT([L]STAT)=[M:HRFRM1]PYRDAT(nolign-1)
  [M:HRFRM1]TYPPAY([L]STAT)=[M:HRFRM1]TYPPAY(nolign-1)
  [M:HRFRM1]FCY   ([L]STAT)=[M:HRFRM1]FCY   (nolign-1)
 Endif
#MIPEA - 2017-05-19- US X3-11287- START
If [F:RIB]PAYPST<2
   [M:HRFRM1]AMT([L]STAT)=arr([L]MONTANT*[F:RIB]PAYPCT*0.01,[L]CURRND)
   [L]PCTMAT+=[F:RIB]PAYPCT
   If [M:HRFRM1]AMT([L]STAT)>[L]MTRESTE | [L]PCTMAT=100
    [M:HRFRM1]AMT([L]STAT)=[L]MTRESTE
   Endif
   [L]MTRESTE-=[M:HRFRM1]AMT([L]STAT)
Else
   [M:HRFRM1]AMT([L]STAT)=arr([L]MONTANT,[L]CURRND)
   [L]AMTMAT+=[F:RIB]PAYPCT
   If [M:HRFRM1]AMT([L]STAT)>[L]MTRESTE | [L]AMTMAT=[L]MTRESTE
    [M:HRFRM1]AMT([L]STAT)=[L]MTRESTE
   Endif
   [L]MTRESTE-=[M:HRFRM1]AMT([L]STAT)
Endif
# [M:HRFRM1]AMT([L]STAT)=arr([L]MONTANT*[F:RIB]PAYPCT*0.01,[L]CURRND)
# [L]PCTMAT+=[F:RIB]PAYPCT
# If [M:HRFRM1]AMT([L]STAT)>[L]MTRESTE | [L]PCTMAT=100
#  [M:HRFRM1]AMT([L]STAT)=[L]MTRESTE
# Endif
# [L]MTRESTE-=[M:HRFRM1]AMT([L]STAT)
#MIPEA - 2017-05-19- US X3-11287- END
#  [M:FRM1]AMT([L]STAT)=[L]MONTANT
#  Break
# Elsif [L]STAT>=nolign
#  [M:FRM1]REFNUM([L]STAT)= MATRI
#  [M:FRM1]CTRNUM()= CTR
#  [M:FRM1]PYRDAT([L]STAT)=[M:FRM1]PYRDAT(nolign-1)
#  [M:FRM1]TYPPAY([L]STAT)=[M:FRM1]TYPPAY(nolign-1)
#  [M:FRM1]FCY   ([L]STAT)=[M:FRM1]FCY   (nolign-1)
# Endif
# [M:FRM1]AMT([L]STAT)=arr([L]MONTANT*[F:RIB]PAYPCT*0.01,[L]CURRND)
# [L]PCTMAT+=[F:RIB]PAYPCT
# If [M:FRM1]AMT([L]STAT)>[L]MTRESTE | [L]PCTMAT=100
#  [M:FRM1]AMT([L]STAT)=[L]MTRESTE
# Endif
# [L]MTRESTE-=[M:FRM1]AMT([L]STAT)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 [L]STAT   +=1
Next
Filter [RIB]

#89883
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If [M:HRFRM1]CTRNUM([L]STAT)<>""
#If [M:FRM1]CTRNUM([L]STAT)<>""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 Local Char    ECOCOD
 Local Integer WSTAT
 Call CALC_BDFECOCOD(MATRI,[M]BIDNUM([L]STAT),[M]BAN,[M]AMT([L]STAT),[M]CURBAN,[M]PYRDAT([L]STAT),[M]CPY,ECOCOD,WSTAT)
 If WSTAT>0 Then
  If ECOCOD="" or [M]BDFECOCOD(nolign-1)="" Then
    [M]BDFECOCOD(nolign-1) = ECOCOD
    Affzo [M]BDFECOCOD(nolign-1)
  Endif
 Endif
Endif
#
Return

########################################
Subprog AS_BIDNUM(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10387;[M]MODPAY
#Read [ADI]CODE=387;[M]MODPAY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If fstat=0
 If [F:ADI]N1<>3 & [F:ADI]N1<>4 :#Virement ou virement internationaux (34388)
  mkstat=2
 Endif
Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE = mess(17,10704,1)-"10387" : # "Erreur sur la table diverse no:"
# GMESSAGE = mess(17,704,1)-"387" : # "Erreur sur la table diverse no:"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat=2 : End
Endif
End

