#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################################################
# Traitement d'appel des points d'entrées du module CRM             Module CRM          25 Novembre 2003
#########################################################################################################

#########################################################################################################
#
# Partie 1 : Points d'entrée transversaux
#
# AOBEXP      : Modification de la présentation XML et HTML des objets du module CRM
# XMLTAG      : Modification du nom des tags XML utilisés pour les extractions XML des objets X3.
# PRECUSMGG   : Préalable à la génération d'un ciblage avancé.
# CUSMGG      : Compléments à la génération d'un ciblage avancé.
# MGGCOLXSL   : Modifications des couleurs de la feuille XSL des extractions XML des ciblages avancés
# LSTBPRCRM9  : Acceptation ou non d'un élément de la liste des tiers dans CRM9
#
#########################################################################################################

#########################################################################################################
#
# Partie 2 : Module Action commerciale
#
# CRMTRS      : Transactions de saisie du module Action commerciale.
# CLLOBJ      : Définition de l'objet d'un appel généré par campagne d'appels.
# OMMXML      : Compléments XML spécifiques à un publipostage XML.
# MGCDEDIT    : Définition états spécifiques pour impression des données d'un ciblage

# MSKTSK      : Alimentation des champs mask TSK en création/modification/suppression de tache mode batch
#
#########################################################################################################

#########################################################################################################
#
# Partie 3 : Module Support client
#
# HDKTRS      : Transactions de saisie du module Support client.
# MAINSREFLT  : Prise en charge complète de la liste gauche d'une demande de service
# SREFLT      : Filtre complexe sur browsers complémentaires des demandes de service
# MAINITNFLT  : Prise en charge complète de la liste gauche d'une intervention
# ITNFLT      : Filtre complexe sur browsers complémentaires des interventions
# MAINMACFLT  : Prise en charge complète de la liste gauche d'un parc client
# MACFLT      : Filtre complexe sur browsers complémentaires du parc client
# RVACON      : Réévaluation d'un contrat de service selon formule.
# SIHCON      : Calcul du montant d'une échéance de contrat de service sur facture de vente.
# CUSRUL      : Règle d'intégration du parc client personnalisée.
# ESCCND      : Permet de tester la condition d'exécution d'une escalade.
# ESCACT      : Exécution d'une action d'escalade
# AUTINVCFIL  : Ajout d'un filtre complémentaire en facturation automatique des contrats des service
# AUTINVSFIL  : Ajout d'un filtre complémentaire en facturation automatique des demandes des service
# SAVEUDE     : Gestion des champs spécifiques dans l'enregistrement d'un suivi des suppressions des demandes de service
# LOADUDE     : Gestion des champs spécifiques dans l'affichage d'un suivi des suppressions des demandes de service
# MACMCC      : Agrégation spécifique de la consultation du parc
# FEEDHDI     : Retouche ou complément des lignes de demandes de service facturables.

# MACAUTO     : Alimentation des zones lors de la création ou modification automatique d'une fiche parc

#
#########################################################################################################

#########################################################################################################
# CRMTRS : Transactions de saisie du module CRM. Action commerciale
#########################################################################################################
$PE_CRMTRS
GPOINT = "CRMTRS"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# HDKTRS : Transactions de saisie du module HDK. Support client
#########################################################################################################
$PE_HDKTRS
GPOINT = "HDKTRS"  #CHECK IGNORE_LINE
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MAINSREFLT  : Prise en charge complète de la liste gauche d'une demande de service
#########################################################################################################
$PE_MAINSREFLT
GPOINT = "MAINSREFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# SREFLT : Filtre complexe sur browsers complémentaires des demandes de service
#########################################################################################################
$PE_SREFLT
GPOINT = "SREFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MAINITNFLT  : Prise en charge complète de la liste gauche d'une intervention
#########################################################################################################
$PE_MAINITNFLT
GPOINT = "MAINITNFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# ITNFLT : Filtre complexe sur browsers complémentaires des interventions
#########################################################################################################
$PE_ITNFLT
GPOINT = "ITNFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MAINMACFLT  : Prise en charge complète de la liste gauche d'un parc client
#########################################################################################################
$PE_MAINMACFLT
GPOINT = "MAINMACFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MACFLT : Filtre complexe sur browsers complémentaires d'un parc client
#########################################################################################################
$PE_MACFLT
GPOINT = "MACFLT"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# RVACON : Réévaluation d'un contrat de service selon formule.
#########################################################################################################
$PE_RVACON
#Variable disponible
#IRVACONPRI : Cette variable doit contenir la nouvelle base de redevance annuelle après calcul par le point d'entrée.
GPOINT = "RVACON_" + [F:CON]CONBASFOR
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# SIHCON      : Calcul du montant d'une échéance de contrat de service sur facture de vente.
#########################################################################################################
$PE_SIHCON
#Variable disponible
#IOLDCONAMT : Cette variable doit contenir le montant de l'échéance à facturer après calcul par le point d'entrée.
GPOINT = "SIHCON"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# CUSRUL : Règle d'intégration du parc client personnalisée.
#########################################################################################################
$PE_CUSRUL
GPOINT = "CUSRUL"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# ESCCND : Permet de tester la condition d'exécution d'une escalade.
#########################################################################################################
$PE_ESCCND
#IEXECESC = 0 L'escalade n'est pas declenchée
#IEXECESC = 1 L'escalade est declenchée
GPOINT = "ESCCND_" + [F:PEC]ESCCND
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# ESCACT : Exécution d'une action d'escalade
#########################################################################################################
$PE_ESCACT
#SZSRENUM contient le code de la demande de service concernée.
GPOINT = "ESCACT_" + [F:PEC]ESCACTNUM(ITER)
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# AUTINVCFIL : Ajout d'un filtre complémentaire en facturation automatique des contrats des service
#########################################################################################################
$PE_AUTINVCFIL
GPOINT = "AUTINVCFIL"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# AUTINVSFIL : Ajout d'un filtre complémentaire en facturation automatique des demandes des service
#########################################################################################################
$PE_AUTINVSFIL
GPOINT = "AUTINVSFIL"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# SAVEUDE   : Gestion des champs spécifiques dans l'enregistrement d'un suivi des suppressions des demandes de service
#########################################################################################################
$PE_SAVEUDE
GPOINT = "SAVEUDE"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# LOADUDE   : Gestion des champs spécifiques dans l'affichage d'un suivi des suppressions des demandes de service
#########################################################################################################
$PE_LOADUDE
GPOINT = "LOADUDE"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MACMCC      : Agrégation spécifique de la consultation du parc
#########################################################################################################
$PE_MACMCC
GPOINT = "MACMCC"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# FEEDHDI     : Retouche ou complément des lignes de demandes de service facturables.
#########################################################################################################
$PE_FEEDHDI
#Variable disponibles
# SZSRENUM = Code de la demande de service en cours de traitement.
GPOINT = "FEEDHDI"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MACAUTO     : Alimentation des zones lors de la création ou modification automatique d'une fiche parc
#########################################################################################################
$PE_MACAUTO
#Variable disponibles
# SZPEMAC_ACTION  : type action en cours C : création
#                                        M : modification
# SZPEMAC_ORIGINE : origine (menu local 2971)

GPOINT = "MACAUTO"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MACAUTOYES  : Permet de débrayer la création automatique du parc client
#########################################################################################################
$PE_MACAUTOYES
  # FGR 26/11/2009 : X3SUIVI60333

  IMACAUTOYES = 1   # Par défaut IMACAUTOYES=1 veut dire qu'on crée le parc client.
                    # Positionner IMACAUTOYES=0 pour ne pas créer le parc client.
  GPOINT = "MACAUTOYES"
  Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# ITNFORCEHOU  : Permet de donner la main pour l'heure de début d'une intervention et sa durée
#########################################################################################################
$PE_ITNFORCEHOU
  # FGR 25/08/2016 : X3SUIVI114897

  IPEFORCEHOU = 0   # Par défaut IPEFORCEHOU = 0 fonctionnement standard.
                    # Positionner IPEFORCEHOU = 1 fonctionnement remplacé par le spécifique.
  GPOINT = "ITNFORCEHOU"
  Gosub ENTREE From EXEFNC
Return


#########################################################################################################
# CLLOBJ      : Définition de l'objet d'un appel généré par campagne d'appels
#########################################################################################################
$PE_CLLOBJ
#Variable disponibles
# IFULOBJBYPE = Renvoyer 0 si on n'altère pas le fonctionnement standard. Renvoyer 1 pour déclencher l'affectation du clob.
# CLBCLLFULOBJ  = Clob contenant l'objet de l'appel à renseigner
# SZSUMUP = Synthèse de l'objet de l'appel à renseigner (Alpha 235)
# GSZOPGNUM = Code de la campagne d'appel en cours de création
# SZBPRNUM = Code du tiers destinataire de l'appel
# SZCCNNUM = Code de l'interlocuteur destinataire de l'appel

GPOINT = "CLLOBJ_" + SZPHX5PECODE  #CHECK IGNORE_LINE
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# OMMXML      : Compléments XML spécifiques à un publipostage XML.
#########################################################################################################
$PE_OMMXML
#Variable disponibles
# SZBUFFTOFILL = Buffer d'écriture
# FXML : Nom du fichier ouvert
# SZOPGNUM = Code du publipostage en cours de création
# SZMXL = Code du paramétrage de publipostage XML utilisé pour la génération

GPOINT = "OMMXML"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# AOBEXP      : Modification de la présentation XML et HTML des objets du module CRM
#########################################################################################################
$PE_AOBEXP
#Variable disponibles
# SZSCREENTYPE = Type de périphérique : PALM ou PC.
# SZPECONTEXT = Contexte d'exécution du point d'entréé.
# SZAOBEXPTAB = Nom de la table dont la présentation peut être modifiée.
# SZTAGXXX = Liste des tags XML dédoublonnés
# SZFIEXXX = Liste des champs composant la table
# SZLABELXXX = Nom de l'étiquette des champs composant la table
# IHIDEXXX = Flag d'affichage du champ dans le résultat de la génération
# ISORTXXX = Tri des champs dans la présentation
# IDISPLAYXXX = Affichage d'une table liée. 1 = Affichage. 0 = Pas d'affichage. Par défaut = 1.

#XXX est l'abrévation de la table à traiter

GPOINT = "AOBEXP"
Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# XMLTAG      : Modification du nom des tags XML utilisés pour les extractions XML des objets X3.
#########################################################################################################
$PE_XMLTAG
#Tags pouvant être changés
#SZXROOT
#SZXUTILITY
#SZXTITLE
#SZXRECORD
#SZXAOB
#SZXAOBTITLE
#SZXAOBNUM
#SZXLEVEL
#SZXPARENTAOB
#SZXPARENTNUM
#SZXAOBDATA
#SZXSORT
#SZXLABEL
#SZXFIELD

GPOINT = "XMLTAG"
Gosub ENTREE From EXEFNC
Return

