#########################################################################################################
$PE_SRELOADCPN
  # FGR 04/08/2010 : X3SUIVI65845 : Permet de prendre la main pendant la boucle LOADCPN de SRE
  GPOINT = "SRELOADCPN" : Gosub ENTREE From EXEFNC
