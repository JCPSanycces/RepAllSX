#########################################################################################################
# SRETRSWIN
# Point d'entrée SRETRSWIN permet d'intervenir sur la fenêtre générée avant le Write
# Le buffer [F:AWI] est chargé
#########################################################################################################
$PE_SRETRSWIN
  # FGR 31/07/2009 : X3SUIVI56881 Pour ajout d'un point d'entrée
  GPOINT = "SRETRSWIN" : Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MAIAUTO1  : Compléter la classe [F:MAI] avant qu'elle ne soit écrite
#########################################################################################################
$PE_MAIAUTO1
  # FGR 25/09/2009 : X3SUIVI57808
  # On est dans une boucle sur [M:MAC4]. ZI est l'indice courant
  # Si GERR est positionné à 1 dans le point d'entrée, la boucle s'arrêtera avec une erreur.
  # Si on souhaite un message, le charger dans GMESSAGE
  GPOINT = "MAIAUTO1" : Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MAIAUTO2  : Compléter la classe [F:MAI] avant qu'elle ne soit écrite
#########################################################################################################
$PE_MAIAUTO2
  # FGR 25/09/2009 : X3SUIVI57808
  # SZCMMAIAUTO = "[MAID]" ou SZCMMAIAUTO = "[MAIV]" contient le nom de la classe [F] de la table MACITN
  #        "[MAID]" : Duplication de parc
  #        "[MAIV]" : Création d'un historique d'implantation
  # On est dans une boucle sur [M:MAC4]. ZI est l'indice courant
  # Si GERR est positionné à 1 dans le point d'entrée, la boucle s'arrêtera avec une erreur.
  # Si on souhaite un message, le charger dans GMESSAGE
  GPOINT = "MAIAUTO2" : Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# MACWAUTO  : Compléter la classe [M:MACW] Après que la partie standard ait été alimentée
#########################################################################################################
$PE_MACWAUTO
  # FGR 12/11/2009 : X3SUIVI56282
  #   SZMACWCNT : Contexte d'appelle (TRTVENLIVV, TRTVENFACV, SUBSRS, SUBSRL, SUBSRH, SUBSIHA)
  #   SZMACWPRE : Présision sur le contexte d'appel
  #                 (alimentée uniquement avec "MOD" ou "" pour SZMACWCNT= "SUBSRH", "SUBSRL", "SUBSRS")
  #                 (alimentée uniquement avec "MOD", "DOC" ou "" pour SZMACWCNT= "SUBSRH")
  GPOINT = "MACWAUTO" : Gosub ENTREE From EXEFNC
Return

#########################################################################################################
