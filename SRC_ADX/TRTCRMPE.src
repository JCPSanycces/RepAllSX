#########################################################################################################
# GETREPBPR  : Permet d'alimenter les rubriques spécifiques de [F:MRE]
#########################################################################################################
$PE_GETREPBPR
  # FGR 19/11/2012 : X3SUIVI84278 : Permet de définir des champs représentant supplémentaires
  #                  par rapport à REP(0) et REP(1) standard
  # INBREPSPE       : nombre de champs supplémentaires : -1 si aucun, 0 le premier du tableau
  # SFIEREPSPE(0..) : Champs représentants supplémentaires, sous la forme [F:BPC]CHAMP...
  # Ensuite ce tableau sera exploité à la suite des deux champs standards, et appliquera
  # les mêmes règles d'attributions que celles standards.
  # -----------------------------------------------------
  GPOINT = "GETREPBPR" : Gosub ENTREE From EXEFNC
Return

#########################################################################################################
# CRITCON  : Permet d'appliquer des règles supplémentaires dans les critères de sélection d'un contrat de service dans TRTCOVER
#########################################################################################################
PE_CRITCON
Local Char SSPECRITCON(250)(0..10)

  # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
  Raz SSPECRITCON
  SSPESPCALLER = "CHKNBCON"
  GPOINT = "CRITCON" : Gosub ENTREE From EXEFNC
  If [L]SSPECRITCON = "" Then
    [L]SSPECRITCON(0) = "(1=1)"
  Endif
Return

