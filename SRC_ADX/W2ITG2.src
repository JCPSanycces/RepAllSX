$ON_LOCDES
Onevent BEFORE_INPUT Call AS_LOCDES(zc) From W2ITG2
Onevent CONTROL Call C_LOCDES(zc) From W2ITG2
Onevent AFTER_CHANGE Gosub AMM_LOCDES From W2ITG2
Onevent INIT_AREA Call D_LOCDES(zc) From W2ITG2
Return

Subprog D_LOCDES(VALEUR)
Variable Integer VALEUR
If varinit([M]LOCDES,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LOCDES(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2707) From COMBOS
## Action STD
Call AS_LOCDES(VALEUR) From SUBITG
If mkstat=2
 [M]LOCDES(INDIC) = VALEUR
 Affzo LOCDES(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2707,1))))
Endif
If !mkstat
 Discombo 0 From LOCDES(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From LOCDES(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_LOCDES(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LOCDES(VALEUR) From SUBITG
If mkstat : GERR = 1 : GZONE = "LOCDES" : GZNUM = 18828 : Endif
Gosub _AFF
End

$AMM_LOCDES
Call AM_LOCDES(zc)
If !mkstat & GOBJET
 zoncou = "LOCDES" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LOCDES(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_LOCDES(VALEUR) From SUBITG
If mkstat : GERR = 1 : GZONE = "LOCDES" : GZNUM = 18828 : Endif
Gosub _AFF
End

$ON_DEFLOCTYP
Onevent CONTROL Call C_DEFLOCTYP(zc) From W2ITG2
Onevent BEFORE_INPUT Call AS_DEFLOCTYP(zc) From W2ITG2
Return

Subprog AS_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(735,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_DEFLOCTYP(VALEUR) From SUBITG
If mkstat=2
 [M]DEFLOCTYP(INDIC) = VALEUR
 Affzo DEFLOCTYP(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_DEFLOCTYP(zc) From W2ITG2
Onkey   2 Titled GBOUTS Call S_DEFLOCTYP(zc) From W2ITG2
Gosub _AFF
End

Subprog C_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
## Action CTLTEMFMT
Call CTLTEMFMT(VALEUR,"*?#!") From STKACT
If mkstat : GERR = 1 : GZONE = "DEFLOCTYP" : GZNUM = 19115 : Endif
If !mkstat
 ## Action STD
 Call C_DEFLOCTYP(VALEUR) From SUBITG
 If mkstat : GERR = 1 : GZONE = "DEFLOCTYP" : GZNUM = 19115 : Endif
Endif
Gosub _AFF
End

Subprog S_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STKSELTLO
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "STKSELTLO"
 PARMSK(1) = [M:ITG0]STOFCY
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"STKSELTLO","STKLOC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJET1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJET1"
 Call OBJET_CHAR(VALEUR,"TLO",[M:ITG0]STOFCY) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DEFLOC
Onevent CONTROL Call C_DEFLOC(zc) From W2ITG2
Onevent BEFORE_INPUT Call AS_DEFLOC(zc) From W2ITG2
Return

Subprog AS_DEFLOC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3623,GBOUT1) From OBJDIV
Call TEXTE(6426,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_DEFLOC(VALEUR) From SUBITG
If mkstat=2
 [M]DEFLOC(INDIC) = VALEUR
 Affzo DEFLOC(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_DEFLOC(zc) From W2ITG2
Onkey 130 Titled GBOUT2 Call B2_DEFLOC(zc) From W2ITG2
Onkey   2 Titled GBOUTS Call S_DEFLOC(zc) From W2ITG2
Gosub _AFF
End

Subprog C_DEFLOC(VALEUR)
Variable Char    VALEUR()
## Action CTLEMPFMT
Call CTLEMPFMT(VALEUR,"*?#!") From STKACT
If mkstat : GERR = 1 : GZONE = "DEFLOC" : GZNUM = 18861 : Endif
If !mkstat
 ## Action STD
 Call C_DEFLOC(VALEUR) From SUBITG
 If mkstat : GERR = 1 : GZONE = "DEFLOC" : GZNUM = 18861 : Endif
Endif
Gosub _AFF
End

Subprog S_DEFLOC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STKSELEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "STKSELEMP"
 PARMSK(1) = [M:ITG0]STOFCY
 PARMSK(2) = [M:ITG2]DEFLOCTYP(nolign-1)
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"STKSELEMP","STKLOC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DEFLOC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJETA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DEFLOC" : PROGSUB = "SUBITG" : PROGSPE = "SPEITG" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 Call OBJET_CHAR(VALEUR,"LOC",[M:ITG0]STOFCY) From GOBJET
 ACTION = "BB1_DEFLOC" : PROGSUB = "SUBITG" : PROGSPE = "SPEITG" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_DEFLOC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONSSEA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONSSEA"
 PARMSK(1) = "1"
 PARMSK(2) = [M:ITG0]STOFCY
 PARMSK(3) = VALEUR
 PARMSK(4) = [M:ITG2]DEFLOCTYP(nolign-1)
 PARMSK(5) = ""
 PARMSK(6) = "3"
 PARMSK(7) = "1"
 PARMSK(8) = ""
 PARMSK(9) = VALEUR
 Call CONSULT_CHAR(VALEUR,"SEA",PARMSK) From GCONSULT
 VALEUR = PARMSK(9)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


