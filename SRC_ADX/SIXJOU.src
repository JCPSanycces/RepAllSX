#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################################
#  SIXJOU : pour traitements de bascule Integrale --> X3                             #
######################################################################################
#                                                                                    #
# Subprog SIXJOU                                                                     #
#     Création des journaux comptables                                               #
#                                                                                    #
#     Initialisation des Etats des journaux par société                              #
#                                                                                    #
#     Initialisation du journal sous les Types de Pièces                             #
#                                                                                    #
#                                                                                    #
# ---------------------------------------------------------------------------------- #
# PRE-REQUIS :                                                                       #
# ---------------------------------------------------------------------------------- #
#                                                                                    #
#     1 - Migrations précédentes : Périodes comptables , Société, Comptes généraux   #
#                                                                                    #
#####################################################################################

# Supp...
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU] : Endif   # Journaux comtpables
If !clalev([F:JST])  : Local File GAJOUSTA   [JST] : Endif   # Etats des Journaux

If !clalev([F:XJRN]) : Local File XIJRN      [XJRN]: Endif   # Journaux comptables Intégrale

Trbegin [JOU], [JST] , [XJRN]
Delete [JOU] Where 1=1
Delete [JST] Where 1=1
Update [XJRN] Where 1=1 With FLGREP=1
Commit 
# Fin Supp
End
Gosub SI_CONTEXT From SIXFONCTION
Global Integer X_NB
Call OUVRE_BOITE("XIJRN",nbrecord([XJRN])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB
End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXJOU : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des journaux : GJOURNAL  ------#
Call ECR_TIME("SIXJOU : "+SI_MES(51)+" GJOURNAL") From DOSSUB

Call SI_GJOURNAL
If GOK<>1 : Goto FIN_JOU : Endif

#----  Creation Etat du Journal par société (GAJOUSTA)
Call SI_GAJOUSTA
If GOK<>1 : Goto FIN_JOU : Endif

#----  RAZ Journaux sous Type Facture : TABPIVTYP / TABSIVTYP  ------#
Call SI_TABTYP
If GOK<>1 : Goto FIN_JOU : Endif

$FIN_JOU
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Création des journaux comptables
#########################################################################
Subprog SI_GJOURNAL

Local Integer STOP, NB
Local Char LREPRISE(50)

If !clalev([F:XJRN]) : Local File =SI_DOSSIER+".XIJRN"      [XJRN] : Endif   # Journaux comptables
If !clalev([F:XJRQ]) : Local File =SI_DOSSIER+".XIJRNCTATQ" [XJRQ] : Endif   # Journaux : Comptes automatiques
If !clalev([F:XJRS]) : Local File =SI_DOSSIER+".XIJRNCTRFS" [XJRS] : Endif   # Journaux : Comptes refusés
If !clalev([F:XBAN]) : Local File =SI_DOSSIER+".XIBQE"      [XBQE] : Endif   # Banque Intégrale

If !clalev([F:JOU])  : Local File =SI_DOSSIER+".GJOURNAL"   [JOU]  : Endif   # Journaux
If !clalev([F:JCO])  : Local File =SI_DOSSIER+".GJOUCOA"    [JCO]  : Endif   # Journaux - Plan de compte
If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"       [COA]  : Endif   # Code plan
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC]  : Endif   # Comptes
      
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Local Integer NBR
Local Char    COAGEN(GLONCOA), COAANA(GLONCOA)

Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

SI_SUBPRG = "SIXJOU"
SI_TABLE  = "XIJNR"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_JOU
Raz NB

If STOP=1
 CRITERE = "CODJRN>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [JOU], [JCO], [XJRN]

# Traitement des comptes généraux
For [XJRN] Where left$(CODJRN,2)<>"$$" and FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1
 Call AFFBOITE([F:XJRN]CODJRN) From SUBSIM

 # creation Journal (GJOURNAL)
 Gosub CRE_JOU
 If GOK<=0 : Break :  Endif

 # creation Journal par code plan (GAJOUCOA)
 Gosub CRE_JCO
 If GOK<=0 : Break :  Endif


 Readlock [XJRN] Curr
 [F:XJRN]FLGREP = 2
 Rewrite [XJRN]

 # NB alimenté dans CRE_JOU
 If NB>1000
  LREPRISE = [F:XJRN]CODJRN
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_JOU
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_JOU
Raz [F:JOU]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("JOU",[F:XJRN]X3CLE,"XIJRN ("+[F:XJRN]CODJRN+")")
 GOK=0 : Return
Else
 [F:JOU]JOU = [F:XJRN]X3CLE
Endif

# Législation
If func AFNC.ACTIV("LEG")=0 : [F:JOU]LEG = GDOSLEG(1) : Endif

# Intitulé de compte
[F:JOU]DESSHO = [F:XJRN]ITTJRN 
[F:JOU]DES    = [F:XJRN]ITTJRN
Call MAJTEXTRA([F:JOU]DES,"GJOURNAL","DESTRA",[F:JOU]JOU,[F:JOU]LEG) From ATEXTRA
Call MAJTEXTRA([F:JOU]DESSHO,"GJOURNAL","SHOTRA",[F:JOU]JOU,[F:JOU]LEG) From ATEXTRA

# Flags
#-------------------------------------------------
[F:JOU]ENAFLG = 2

# Type de journal
#-------------------------------------------------
Case [F:XJRN]TYPJRN
 When "V" : [F:JOU]TYP=1  # Intégrale "Ventes"             => X3 "Ventes"
 When "A" : [F:JOU]TYP=2  # Intégrale "Achats"             => X3 "Achats"
 When "T" : [F:JOU]TYP=3  # Intégrale "Trésorerie"         => X3 "Trésorerie"
 When "O" : [F:JOU]TYP=4  # Intégrale "Opération diverses" => X3 "OD 1"
 When "D" : [F:JOU]TYP=5  # Intégrale "Déductible"         => X3 "OD 2"        
 When "C" : [F:JOU]TYP=6  # Intégrale "Collectée"          => X3 "OD 3"        
 When "L" : [F:JOU]TYP=8  # Intégrale "Analytique"         => X3 "OD Ana 1 "        
 When "E" : [F:JOU]TYP=4  # Intégrale "Extourne"           => X3 "OD 1 "        
#------------------------ # RQ:Dans la doc. intégrale, il est écrit : 
#                             "Cette option sera disponible dans une version ultérieure du programme"
Endcase


# Dates et utilisateurs
#-------------------------------------------------
[F:JOU]CREDAT   = date$
[F:JOU]CREUSR   = GUSER              
[F:JOU]UPDDAT   = date$   
[F:JOU]UPDUSR   = GUSER   

SI_TABLE = "GJOURNAL"
Gosub SI_BEFWRI From SIXFONCTION

Write [JOU]
If fstat
 # Journal... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(13,105,1)-[F:JOU]JOU-"("+[F:XJRN]CODJRN+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif
Return

#########################################################################
$CRE_JCO

 Raz [F:JCO]
 [F:JCO]COA = [L]COAGEN
 [F:JCO]JOU = [F:JOU]JOU
 [F:JCO]LEG = [F:JOU]LEG
 If [F:JOU]TYP = 3 : # Journal de Trésorerie
  # Comptes X3
  #-------------------------------------------------
  # Compte X3 est accessible et obligatorie uniquement pour le type de journal Trésorerie.
  # Sous l'intégrale, la notion de "contrepartie" est associée à tous les types de journal et n'est pas obligatoire.
  # RQ: Que faire si un journal de type trésorerie n'a pas de compte associé ?
  [F:JCO]ACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XJRN]CPTCTP,"GACCOUNT","")
  If [F:JCO]ACC="" :
   Filter [XBQE] Where CODJRN = [F:XJRN]CODJRN
   Read [XBQE]First
   If !fstat
    [F:JCO]ACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XBQE]NUMCPTCTB,"GACCOUNT","")
   Else
    Filter [GAC] Where COA=[L]COAGEN & SAC<>2 & CLSCOD="5" 
    Read [GAC] First
    If !fstat
     [F:JCO]ACC = [F:GAC]ACC
     # Champ compte de trésorerie obligatoire
     Call ECR_TRACE(mess(77,104,1)-":"-[F:JCO]JOU-"("+[F:XJRN]CODJRN+")"-mess(10,123,1),-1) From GESECRAN   
    Else
     # Compte de trésorerie ... (...) zone obligatoire
     Call ECR_TRACE(mess(108,121,1)-[F:JCO]JOU-"("+[F:XJRN]CODJRN+")"-mess(10,123,1),-1) From GESECRAN
    Endif
    Filter [GAC]
   Endif
   Filter [XBQE]
  Endif 
 Endif

 # Comptes fréquents X3
 #-------------------------------------------------
 # Sous X3, les comptes fréquents sont limités à 20 enregsitrements
 # Sous Integrale, les comptes autoamtiques sont enregistrés dans une table à part limités à 80.
 Raz NBR 
 For [XJRQ] Where [F:XJRQ]CODJRN = [F:XJRN]CODJRN
  [F:JCO]FRQACC(NBR) = [F:XJRQ]CPTATQ
  [F:JCO]FRQCOD(NBR) = chr$(65+NBR)
  NBR+=1
  If NBR>= dim([F:JOU]FRQACC) : Break : Endif
 Next 
 [F:JCO]FRQNBR=NBR

 # Comptes interdits
 #-------------------------------------------------
 # Sous X3, les comptes interdits sont limités à 20 enregsitrements
 # Sous Integrale, les comptes refusés sont enregistrés dans une table à part limités à 10.
 Raz NBR
 For [XJRS] Where [F:XJRS]CODJRN = [F:XJRN]CODJRN
  [F:JCO]FBDACC(NBR) = [F:XJRS]CPTRFS
  NBR +=1
 Next 
 [F:JCO]FBDNBR=NBR
 
 [F:JCO]CREDAT = [F:JOU]CREDAT
 [F:JCO]CREUSR = [F:JOU]CREUSR
 [F:JCO]UPDUSR = GUSER
 [F:JCO]UPDDAT = date$
 Write [JCO]
 If fstat
  # Journal... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(134,107,1)-[L]COAGEN-mess(13,105,1)-[F:JCO]JOU-"("+[F:XJRN]CODJRN+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0  : Return
 Else
  NB+=1
 Endif

 If [L]COAGEN<>[L]COAANA
  Raz [F:JCO]
  [F:JCO]COA = [L]COAANA
  [F:JCO]JOU = [F:JOU]JOU
  [F:JCO]LEG = [F:JOU]LEG

  [F:JCO]CREDAT = [F:JOU]CREDAT
  [F:JCO]CREUSR = [F:JOU]CREUSR
  [F:JCO]UPDUSR = GUSER
  [F:JCO]UPDDAT = date$
  Write [JCO]
  If fstat
   # Code Plan ... Journal... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(134,107,1)-[L]COAANA-mess(13,105,1)-[F:JOU]JOU-"("+[F:XJRN]CODJRN+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0  : Return
  Else
   NB+=1
  Endif
 Endif
Return

#########################################################################
Subprog SI_GAJOUSTA
#########################################################################
# En création d'un journal, on va créer pour chaque société et chaque
# période les enregistrements dans GAJOUSTA (Etat journal)
If !clalev([F:JST])  : Local File =SI_DOSSIER+".GAJOUSTA"   [JST]  : Endif   # Etats des Journaux
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
If !clalev([F:JOU])  : Local File =SI_DOSSIER+".GJOURNAL"   [JOU]  : Endif   # Journaux

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [JST]
 
Delete [JST] Where 1=1
If fstat
 # Etat d'un journal : Erreur d'écriture
 Call ECR_TRACE(mess(9,104,1)-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : End
Endif

Raz [F:JST]

For [JOU]JOU0(1)
 [F:JST]CPY = [F:SPX]CPY
 [F:JST]JOU = [F:JOU]JOU
 [F:JST]OPGSTRDAT = [0/0/0]
 [F:JST]OPGENDDAT = [0/0/0]
 [F:JST]CREDAT = [F:JOU]CREDAT
 [F:JST]CREUSR = [F:JOU]CREUSR
 [F:JST]UPDUSR = GUSER
 [F:JST]UPDDAT = date$

 Write [JST]
 If fstat
  # Journal... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(13,105,1)-[F:JOU]JOU-"("+[F:XJRN]CODJRN+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif
End

#########################################################################
Subprog SI_TABTYP  
Local Integer NBRTYP
If !clalev([F:TPV]) : Local File =SI_DOSSIER+".TABPIVTYP"    [TPV] : Endif   # Types de pièces
If !clalev([F:TSV]) : Local File =SI_DOSSIER+".TABSIVTYP"    [TSV] : Endif   # Journaux

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [TPV], [TSV]

# Raz du journal
Update [TPV] With JOU=""
If fstat
 # Journal... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(13,105,1)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0

Else

 # Raz du journal
 Update [TSV] With JOU=""
 If fstat
  # Journal... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(13,105,1)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 
 Endif
Endif

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif
End





