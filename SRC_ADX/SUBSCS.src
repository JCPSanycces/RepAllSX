#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
If ACTION <> "DEFTRANS" & ACTION <> "VARIANTE"  & ACTION <> "SETTRANS" & ACTION <> "L_VARIANTE" & ACTION <> "P_VARIANTE"
#Infbox ACTION
Endif
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBSCSA
 When "VARIANTE"     : Gosub VARIANTE     From SUBSCSA
 When "SETTRANS"     : Gosub SETTRANS     From SUBSCSA
 When "OUVRE"        : Gosub OUVRE        From SUBSCSA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBSCSA

 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE  From SUBSCSA


 When "AFFMASK"      : [M:SCS1]ALLSTO   =2
                       [M:SCS1]NOTALLSTO=2
                       Gosub AFFMASK      From SUBSCSA #85785
 When "FILTRE"       : Gosub FILTRE       From SUBSCSA
 When "LIENS"        : Gosub LIENS        From SUBSCSA
 When "DEFLIG"       : Gosub DEFLIG       From SUBSCSA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBSCSA

 When "SETBOUT"      : Gosub SETBOUT      From SUBSCSA
 When "EXEBOUT"      : Case BOUT
                            When "1" : If [M:SCS1]SIHNUM=""
                                        Call SUPSCS From SUBSCSA
                                        Gosub RELIT From GOBJSUB
                                       Else
                                        Call ERREUR(mess(54,123,1)-":"-mess(122,197,1)) From GESECRAN
                                       Endif
                            When "2" : #MAE, bg 78442, tout est fait dans APRES_MODIF_ITMREFSEL pour betfcycod>1
                                       If [M:SCS1]BETFCYCOD = 1
                                        Raz WCRITSTO4
                                        Call CREE_FORMULE([M:SCS1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                                        Gosub TIROIR From SUBSCSP
                                       Else
                                        Gosub APRES_MODIF_ITMREFSEL From SUBSCSA
                                       Endif
                            When "3" : CLECUR1 = [M:SCS1]VCRNUM : Gosub RELIT From GOBJSUB #85785
                       Endcase

 When "RAZCRE"       : Gosub RAZCRE       From SUBSCSA
 When "RAZDUP"       : Gosub RAZDUP       From SUBSCSA

 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBSCSA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBSCSA
 When "INICRE"       : Gosub INICRE       From SUBSCSA
 When "INIMOD"       : Gosub INIMOD       From SUBSCSA
 When "CREATION"     : Gosub CREATION     From SUBSCSA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBSCSA
 When "VALLIG"       : Gosub VALLIG       From SUBSCSA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBSCSA
 When "MODIF"        : Gosub MODIF        From SUBSCSA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBSCSA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBSCSA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBSCSA

 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBSCS
 When "ABANDON"      : Gosub ABANDON      From SUBSCSA
 When "FIN"          : Gosub ABANDON      From SUBSCSA
 When "FERME"        : Gosub FERME        From SUBSCSA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBSCSA
 When "STATUT"       : Gosub STATUT       From SUBSCSA
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBSCSA #85785

 When "TIROIR"           : Gosub TIROIR       From SUBSCSP
 When "REMP_DERLU"       : Gosub REMP_DERLU   From SUBSCSP
 When "FILGAUCHE"        : Gosub FILGAUCHE    From SUBSCSP
 When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE From SUBSCSP
 When "HINT"             : Gosub HINT_KEY     From SUBSCSP
 When "DEB_PICK"         : Gosub DEB_PICK     From SUBSCSP
 When "PICKE"            : Gosub PICKE        From SUBSCSP
 When "DEPICK"           : Gosub DEPICK       From SUBSCSP
 When "FIN_PICK"         : Gosub FIN_PICK     From SUBSCSP
 When "CLE_GAUCHE"       : Gosub CLE_GAUCHE   From SUBSCSP                 # hcb X3-108627
 When Default
Endcase

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
Case ACTION
 When "BB3_ITMREFSEL"    : VALEUR=[M:SCS1]ITMREFSEL
 When Default
Endcase

Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

