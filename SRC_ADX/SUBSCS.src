$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE  Return : Endif
# Issue 59774 - 2017-10-24 by MAE : ajout du test sur [M:SCS1]BETFCYCOD=2
If [M:SCS1]BETFCYCOD=2
  If [M:SCS1]BETCPY=2
    Call INIT_CCE(VALEUR,AXE,"ICOD","",0) From TRTX3CPT
  Else
    Call INIT_CCE(VALEUR,AXE,"TRSD","",0) From TRTX3CPT
  Endif
Endif
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SCS1]IPTDAT) From TRTX3CPT
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SCS1) 31/03/2011 15:23:45 (TS)
######################################################################################
#--- Bug 72649
Subprog C_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
If [M:SCS1]LOCTYPDES(nolign-1)<>VALEUR
   Call RAZLOC([M:SCS1]LOCDES(nolign-1),[M:SCS1]WLOCSEQ(nolign-1)) From STKACT
Endif

End
#---

#                                                                 # hcb 110327 deb
Subprog B4_NBLIG
GOUVCHGS = 2
End

Subprog APRES_NBLIG
Local Integer LRET
Local Integer LSEQIND
If [F:ITM]SERMGTCOD = 4
   Call WSTOSEQIND ("",nolign-1+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SCS1]WSTOSEQIND(nolign-1) = LSEQIND
Endif

#                                                                 # hcb 110327 end

End

#                                                                        # hcb 51677 deb
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
Local Char    LSEC
Local Integer I

If [M:SCS1]NBLIG=0 & [F:SRT]BETFCYCOD = 2
   [M:SCS1]PJT=VALEUR
   For I=1 To GNBDIE
       If dim([M:SCS1]CCE)>0
          Raz [M:SCS1]CCE(I-1)
          If [M:SCS1]BETCPY=2
             Call INISEC (LSEC, "ICOH", I) From TRTX3CPT
          Else
             Call INISEC (LSEC, "TRSH", I) From TRTX3CPT
          Endif
          [M:SCS1]CCE(I-1) = LSEC
       Else
          Break
       Endif
    Next
Endif
End
#                                                                        # hcb 51677 fin

