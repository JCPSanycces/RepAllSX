########################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
    [M:SCS1]VCRTYP = 29
End

########################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()


If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif


    #-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
    If (VALEUR="" &  GSTKCPT(14)="")
        mkstat = 2
        End
    Endif
    #-- Si on est en création , n° saisi vide et un compteur est présent on sort
    If (GREP="C" & VALEUR="" &  GSTKCPT(14)<>"")
        End
    Endif

    #-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
    If [M:SCS1]VCRNUM="" & GREP<>"C"
        Look [F:SGH]SGH0=VALEUR
        If fstat
            GMESSAGE=mess(178,199,1)
            mkstat=2
            End
        Endif
    Endif

    If VALEUR<>"" & GSTKCPTMAN(14)<>2
        Look [F:SGH]SGH0=VALEUR
        If fstat
            Raz VALEUR
            End
        Endif
    Endif
End

##########################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ligne déjà saisie, plus d'accés au site de stock
If [M:SCS1]NBLIG<>0 mkstat=2 Endif
End

# Etiquette ajoutée par hcb 31190
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

#--- Issue 101295 by TS
#If [M:SCS1]FCYDES="" | [F:SRT]BETFCYCOD<>2
If [F:SRT]BETFCYCOD<>2
#---
   [M:SCS1]FCYDES = VALEUR
   [M:SGW]FCYDES = VALEUR
   [M:SCS1]CURDES = GLOCALDEV                     # hcb 93518 deb
Endif

End

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

#--- Bug 67961
GFCY=VALEUR : Gosub CHARG_PARAM From SUBSCSA

#--- Issue 101295 by TS
#If [M:SCS1]FCYDES="" | [F:SRT]BETFCYCOD<>2
If [F:SRT]BETFCYCOD<>2
#---
    [M:SCS1]FCYDES = VALEUR
#    [M:SCS1]PURFCY = VALEUR                 # hcb 28638
    [M:SGW]FCYDES = VALEUR
   [M:SCS1]CURDES = GLOCALDEV                     # hcb 93518 deb
Endif
# Si modif site stockage, on raz l'emplacement sous-traitant
#MAE, RET_SSTRT
#If [F:SRT]BETFCYCOD=4 Raz [M:SCS1]SCOLOC Endif
If find([F:SRT]BETFCYCOD,4,5) Raz [M:SCS1]SCOLOC Endif

#FQ 68364
Gosub AFF_TITCOL From SUBSCSA
#fin FQ 68364

# Actzo ou Diszo du dépôt
[M:SCS1]STOFCY=VALEUR
Gosub WRH_ETAT From SUBSCSA

End
######################################################################################
## Section automatically added (screen SCS1) 05/08/2014 11:59:32 (RMA)
######################################################################################
Subprog AS_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM
  Read [F:SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

If GREP="" & VALEUR=""
    Local Char WSGHTYP(GLONTSG)
    Gosub SGHTYP From TRTSTKSGH1 : VALEUR=WSGHTYP
Endif

End

######################################################################################
Subprog C_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:TSG]) = 0 : Local File TABSGHTYP [TSG]  : Endif
If clalev([F:SRT]) = 0 : Local File STKTRS    [SRT]  : Endif

Local    Char    LEG
Local    Integer CAS   : [L]CAS = 1 : # 1 - Legislation is empty; 2 - Legislation isn't empty

If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
If fstat > 1 : Raz [F:FCY] : Endif

If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM
  Read [F:SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Elsif LEG=""
  [L]LEG = [F:FCY]LEG
Endif

If [L]LEG<>""
  Read [TSG]TSG0=VALEUR;[L]LEG
  If fstat
    Read [TSG]TSG0=VALEUR;""
  Else
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Else
  Read [F:TSG]TSG0(1)=[L]VALEUR
  If !fstat
    [L]LEG = [F:TSG]LEG
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Endif

If fstat
  Filter [F:TSG] Where [F:TSG]SGHTYP=VALEUR
  Look [F:TSG]TSG0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    GMESSAGE = VALEUR-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    GMESSAGE = VALEUR-":"-mess(23,100,1)
  Endif
  Filter [F:TSG]
  mkstat = 2 : End
Endif

If [F:TSG]GFY<>""
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
  Read [AGF]AGF0=[F:TSG]GFY
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Company
      If [F:TSG]GFY<>[F:FCY]LEGCPY
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TSG]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Elsif [F:AGF]FLGCPY=2
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      Look [AGC]AGC0 = [F:TSG]GFY;[F:FCY]LEGCPY
      If fstat
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TSG]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Endif
  Endif
Endif

If [F:TSG]BETFCYCOD <> [F:SRT]BETFCYCOD
  GMESSAGE = VALEUR+":"+ mess(51,139,1) - "("+mess([F:TSG]BETFCYCOD,792,1)+")"
  mkstat = 2 : End
Endif

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP(VALEUR,"SGH",GMESSAGE) = 1
    mkstat = 2 : End
  Endif
Endif

End
######################################################################################
Subprog AM_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
[M:SCS1]SGHTYP=VALEUR
Gosub CHARG_PARAM From SUBSCSA
If GSTKCPTMAN(14)<>2 & [M:SCS1]VCRNUM <> ""
   Effzo [M:SCS1]VCRNUM
Endif

If GREP="C" & GSTKCPTMAN(14)<>2
   Diszo [M:SCS1]VCRNUM
Else
   Actzo [M:SCS1]VCRNUM
Endif

End
######################################################################################
Subprog C_FCYDES(VALEUR)
Variable Char    VALEUR()
Local Char WLIB(30)
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

If [F:SRT]BETFCYCOD = 2                                 # hcb 28638
   If VALEUR=""                                         # hcb 28638
      GMESSAGE = mess(10,123,1)                         # hcb 28638
      mkstat = 2                                        # hcb 28638
      End                                               # hcb 28638
   Endif                                                # hcb 28638
# Le site destination doit être différent du site expédition
   If VALEUR=[M:SCS1]STOFCY : mkstat=2 : End : Endif
   If clalev([F:FCY1])=0 : Local File FACILITY [FCY1] : Endif
   Read [FCY1]FCY1 = [F:FCY]LEGCPY;[M:SCS1]STOFCY
# Inter-société
   If fstat
      Local Char WFINFCY(GLONFCY)
      Local Char WLEGFCY(GLONCPY)
      [M:SCS1]BETCPY = 2
      Raz [F:FCY1]
      Read [FCY1]FCY0 = [M:SCS1]STOFCY
      If !fstat & [F:FCY1]SALFLG<>2
          WLEGCPY = [F:FCY1]LEGCPY
          Read [FCY1]FCY0 = [F:FCY1]FINRSPFCY
          If !fstat & [F:FCY1]SALFLG<>2
             WFINFCY=[F:FCY1]FCY
             Filter [FCY1] Where FINRSPFCY=WFINFCY & SALFLG=2
             Read [FCY1]FCY0 First
             Filter [FCY1]
             If fstat
                Filter [FCY1] Where LEGCPY=WLEGCPY & SALFLG=2
                Read [FCY1]FCY1 First
                Filter [FCY1]
             Endif
          Endif
      Endif
      If fstat
    # Pas de site de vente dans cette société
      Call TEXTE(1720,WLIB) From OBJDIV
      GMESSAGE=WLIB-":"-[M:SCS1]STOFCY-"\"+mess(132,184,1)-":"-WLEGCPY
      mkstat=2 : End
   Else
    # Alimentation site de vente
      [M:SCS1]SALFCY = [F:FCY1]FCY
      [M:SCS1]INVSGH = 2
    # Alimentation site d'achat
      If [F:FCY]PURFLG=2
         [M:SCS1]PURFCY=VALEUR
      Else
         Filter [FCY1] Where LEGCPY=[F:FCY]LEGCPY & PURFLG=2
         Read [FCY1]FCY1 First
         Filter [FCY1]
         If fstat
        # Pas de site d'achat dans cette société
            Call TEXTE(18038,WLIB) From OBJDIV
            GMESSAGE=WLIB-":"-VALEUR-"\"+mess(133,184,1)-":"-[F:FCY]LEGCPY
            mkstat=2 : End
         Else
           [M:SCS1]PURFCY=[F:FCY1]FCY
         Endif
      Endif
      Actzo [M:SCS1]SALFCY,PURFCY,INVSGH
   Endif
# Intra-société
  Else
    [M:SCS1]BETCPY = 1
    Raz [M:SCS1]SALFCY,PURFCY
    [M:SCS1]INVSGH = 1
    Grizo [M:SCS1]SALFCY,PURFCY,INVSGH
  Endif
  [M:SGW]FCYDES = VALEUR
   Affzo [M:SCS1]SALFCY,PURFCY,BETCPY,INVSGH
Else                                               # hcb 28638
   [M:SCS1]BETCPY = 1                              # hcb 28638
Endif                                              # hcb 28638

End

Subprog AM_FCYDES(VALEUR)
Variable Char    VALEUR()

Local Char    LSEC
Local Integer I

[M:SCS1]FCYADD = [F:FCY]BPAADD

# Récupération de la société
[M:SCS1]CPYDES = [F:FCY]LEGCPY
# Récupération des devises
Call GETDEV(VALEUR) From DEVSUB
[M:SCS1]CURDES = GLOCALDEV
Call GETDEV([M:SCS1]STOFCY) From DEVSUB    # Pour positionner glocaldev
If [M:SCS1]BETCPY=2
    Actzo [M:SCS1]PRI
Else
    Raz [M:SCS1]PRI
    Grizo [M:SCS1]PRI
Endif

# Initialisation des sections ana
# doit être fait en am_fcydes car des sections peuvent être fonction du site
[M:SCS1]FCYDES=VALEUR
    For I=1 To GNBDIE
    If dim([M:SCS1]CCE)>0
        Raz [M:SCS1]CCE(I-1)
        If [M:SCS1]BETCPY=2
            Call INISEC (LSEC, "ICOH", I) From TRTX3CPT
        Else
            Call INISEC (LSEC, "TRSH", I) From TRTX3CPT
        Endif
#        Assign "[M:SCS1]CCE"+num$(I) With LSEC        # hcb 51677
        [M:SCS1]CCE(I-1) = LSEC                        # hcb 51677
    Else
        Break
    Endif
    Next

# Actzo ou Diszo du dépôt
Gosub WRH_ETAT From SUBSCSA

End

##########################################################################
Subprog C_PURFCY(VALEUR)
Variable Char    VALEUR()
Local Integer OK
# Si pas inter-société
If [M:SCS1]BETCPY<>2 End Endif

# La société du site d'achat doit être la même que celle du site de destination
If [F:FCY]LEGCPY<>[M:SCS1]CPYDES
   GMESSAGE=mess(412,199,1)-":"-[M:SCS1]CPYDES : mkstat=2
Endif

Filter [BPR] Where BETFCY=2 & FCY=VALEUR & BPCFLG=2
Read [BPR]BPR2 First
If fstat
  # Il n'y a pas de client (pour la facturation) associé à ce site d'achat
  Raz [F:BPR]
  OK=2 : Call AVERTIR(mess(128,184,1),OK) From GESECRAN
  If OK<>2 mkstat=2 Endif
Else
  Read [BPC]BPC0=[F:BPR]BPRNUM
  If fstat Raz [F:BPC] Endif
  Filter [BPD] Where BPCNUM=[F:BPR]BPRNUM & RCPFCY=[M:SCS1]FCYDES
  Read [BPD]BPD0 First
  If fstat
     # Le client associé à ce site d'achat n'a pas d'adresse de livraison
     # référençant le site destination
     Raz [F:BPD]
     OK=2 : Call AVERTIR(mess(129,184,1),OK) From GESECRAN
     If OK<>2 mkstat=2 Endif
  Endif
Endif
Filter [BPR]
Filter [BPD]

# Alimentation du client associé au site d'achat
[M:SCS1]BPCNUM=[F:BPR]BPRNUM
[M:SCS1]CUR   =[F:BPC]CUR
[M:SCS1]VACBPR=[F:BPC]VACBPR
[M:SCS1]CHGTYP=[F:BPC]CHGTYP
[M:SCS1]PRITYP=[F:BPC]PRITYP
# Alimentation de l'adresse de livraison correspondante au site destination
[M:SCS1]FCYADD=[F:BPD]BPAADD
Affzo [M:SCS1]FCYADD

End

##########################################################################
Subprog C_FCYADD(VALEUR)
Variable Char    VALEUR()

If [M:SCS1]BETCPY=2 & [M:SCS1]BPCNUM<>""
   Read [F:BPD]BPD0=[M:SCS1]BPCNUM;VALEUR
   If fstat
      GMESSAGE=mess(16,199,1) : mkstat=2 : End
   Elsif [F:BPD]RCPFCY<>"" & [F:BPD]RCPFCY<>[M:SCS1]FCYDES
      GMESSAGE=mess(130,184,1) : mkstat=2 : End
   Endif
Else
   Read [F:BPA]BPA0=3;[M:SCS1]FCYDES;VALEUR
   If fstat
      GMESSAGE=mess(16,199,1) : mkstat=2 : End
   Endif
Endif

End

##########################################################################
## Etiquette ajoutée par hcb 28638
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

# Si pas sous traitance  (transfert ou retour)
#MAE, RET_SSTRT
If ([M:SCS1]BETFCYCOD<>4 & [M:SCS1]BETFCYCOD<>5)  End Endif   # hcb 28638
If VALEUR=""                        # hcb 28638
   GMESSAGE = mess(10,123,1)        # hcb 28638
   mkstat = 2                       # hcb 28638
   End                              # hcb 28638
Endif                               # hcb 28638

# Le tiers sous-traitant ne doit pas être inter-site
Read [F:BPR]BPR0=VALEUR
If fstat
   GMESSAGE=mess(445,177,1)
   mkstat=2 : End
Elsif [F:BPR]BETFCY=2
   GMESSAGE=mess(285,184,1)
   mkstat=2 : End
Endif

End

Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

[M:SCS1]BPSADD = [F:BPS]BPAADD
If [F:BPS]BPAADD<>""
    [M:SCS1]BPSNUM = VALEUR
    #Call C_BPSADD([M:SCS1]BPSADD)
    Read [F:BPA]BPA0=1;[M:SCS1]BPSNUM;[M:SCS1]BPSADD
    If fstat
        GMESSAGE=mess(16,199,1)
        mkstat=2
        End
    Endif
    Call SCOLOC([M:SCS1]BPSNUM,[M:SCS1]BPSADD) From SUBSCSB
Endif
End

##########################################################################
Subprog C_BPSADD(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"" & VALEUR<>[M:SCS1]BPSADD
    Read [F:BPA]BPA0=1;[M:SCS1]BPSNUM;VALEUR
    If fstat
        GMESSAGE=mess(16,199,1)
        mkstat=2
        End
    Endif
    Call SCOLOC([M:SCS1]BPSNUM, VALEUR) From SUBSCSB
Endif
If [M:SCS1]SCOLOC="" | VALEUR = ""
    Actzo [M:SCS1]SCOLOC
Else
    Diszo [M:SCS1]SCOLOC
Endif
End

##########################################################################
Subprog C_SCOLOC(VALEUR)
Variable Char    VALEUR()
# Si pas sous traitance  (transfert ou  retour)
#MAE, RET_SSTRT
If ([M:SCS1]BETFCYCOD<>4 & [M:SCS1]BETFCYCOD<>5) End Endif   # hcb 28638

If VALEUR=""
   GMESSAGE = mess(10,123,1)
   mkstat = 2
   End
Endif

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCS1]SCOLOC
   Read [F:STC]STC0=[M:SCS1]STOFCY;VALEUR
   If fstat
      GMESSAGE = mess(125,184,1)
      mkstat=2
      End
   Elsif [F:STC]LOCCAT<>4
      GMESSAGE = mess(244,192,1)
      mkstat=2
      End
   Elsif [F:STC]OCPCOD=3
      GMESSAGE = mess(140,184,1)
      mkstat=2
      End
   Endif
   [M:SCS1]SCOLOCTYP = [F:STC]LOCTYP
Endif
End

##########################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

# Si pas inter-société
If [M:SCS1]BETCPY<>2 End Endif      # hcb 28638

Read [FCY]FCY0 = VALEUR
Read [FCY]FCY1 = [F:FCY]LEGCPY;[M:SCS1]STOFCY
If fstat
   GMESSAGE=mess(2,194,1) : mkstat=2
Endif
End

##########################################################################
Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
Local Integer  LRET
Local Shortint WRET
If VALEUR=""
  [M:SCS1]ITMREFSEL = VALEUR
  GSCSAUZSST = "A*,Q*,R*"
  End
Endif
#Raz [M:SCS1]AUZSST,FORSTA,LOTSTR,LOTEND,LOCSTR,LOCEND,WRHSTR,WRHEND             # hcb X3-67989
Raz [M:SCS1]AUZSST,FORSTA,LOTSTR,LOTEND,WRHSTR,WRHEND                            # hcb X3-67989
Raz [M:SCS1]SERNUMSTR,SERNUMEND,NBUOM,UOM
Call LECITM([M:SCS1]FCYDES,VALEUR,"",3,"",LRET) From STKLIB
If LRET
  mkstat=2 : End
Endif
If [F:ITF]STOFCY <>[M:SCS1]STOFCY | [F:ITF]ITMREF <> VALEUR
   Read [ITF]ITF0 = VALEUR;[M:SCS1]STOFCY
   If fstat
      GMESSAGE=VALEUR-[M:SCS1]STOFCY-":"-mess(139,197,1)
      mkstat=2 : End
   Else
# Article non géré en stock
      If [F:ITF]STOMGTCOD = 1
         GMESSAGE = VALEUR-":"-mess(2,196,1)-[M:SCS1]STOFCY
         mkstat=2 : End
      Endif
      If [F:ITFD]STOFCY <>[M:SCS1]FCYDES| [F:ITFD]ITMREF <> VALEUR
         Read [ITFD]ITF0 = VALEUR;[M:SCS1]FCYDES
         If fstat
            GMESSAGE=VALEUR-[M:SCS1]FCYDES-":"-mess(139,197,1)
            mkstat=2: End
         Endif
      Endif
   Endif
Else
   If [F:ITFD]STOFCY <>[M:SCS1]FCYDES| [F:ITFD]ITMREF <> VALEUR
      Read [ITFD]ITF0 = VALEUR;[M:SCS1]FCYDES
      If fstat
         GMESSAGE=VALEUR-[M:SCS1]FCYDES-":"-mess(139,197,1)
         mkstat=2: End
      Endif
   Endif
Endif
#MAE, RET_SSTRT
If [ITF]LOCMGTCOD<>2 & ([M:SCS1]BETFCYCOD=4 | [M:SCS1]BETFCYCOD=5)
  GERR=1   : GMESSAGE=mess(149,199,1)
  mkstat=2 : End
Endif

#--- Bug 65411
# Si dépôt destination entête renseigné et dépôt destination ligne non saisissable
# Contrôle existence article dépôt
If dim([M:SCS1]WRHDESH)>0 & [M:SCS1]WRHDESH<>"" & varmode([M:SCS1]WRHDES)<>0
   Read [ITW]ITW0=VALEUR;[M:SCS1]WRHDESH
   If fstat
      GERR=1 : GMESSAGE=mess(978,196,1)-[M:SCS1]WRHDESH
      mkstat=2 : End
   Endif
Endif
#---

#Raz [M:SCS1]AUZSST,FORSTA,LOTSTR,LOTEND,LOCSTR,LOCEND
#Raz [M:SCS1]SERNUMSTR,SERNUMEND,NBUOM,UOM
#Call LECITM([M:SCS1]FCYDES,VALEUR,"",3,"",LRET) From STKLIB
#If LRET
#  mkstat=2 : End
#Endif

#----------------------------
# Non géré pour l'instant
#----------------------------
# Si transfert inter-site ou tiers, lecture règle d'allocation
# pour filtrer la liste de picking et contrôler le picking
#Raz GTRUCOD
#If [M:SCS1]BETFCYCOD>1
#  If [M:SCS1]BETFCYCOD=4
#    GTRUCOD=[F:ITG]ALLRULSCO
#  Else
#    GTRUCOD=[F:ITG]ALLRULTRF
#  Endif
#  If GTRUCOD<>""
#    Read [TRU]TRU0=GTRUCOD
#    If fstat Raz GTRUCOD Endif
#  Endif
#Endif

# Si transfert inter-site ou tiers, lecture règle de gestion
# pour filtrer la liste de picking et contrôler le picking
#MAE, RET_SSTRT
#If [M:SCS1]BETFCYCOD>1
If find([M:SCS1]BETFCYCOD,2,3,4)
  Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,27,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET=0
    [F:SRU1] = [F:SRU]
    #--- Bug 74952
    #Raz [F:SRU]
  Else
    mkstat=2 : End
  Endif
Endif

# Si changement stock, lecture règle de gestion pour flux d'entrée
If [M:SCS1]BETFCYCOD=1
  Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET<>0 mkstat=2 : End Endif
  GSCSAUZSST = [F:SRU]AUZSST
# Si transfert inter-site ou retour sous-traitant, lecture règle de gestion pour flux d'entrée
#MAE, RET_SSTRT
Elsif find([M:SCS1]BETFCYCOD,2,5)
  Call LECSRU([M:SCS1]FCYDES,[F:ITM]TCLCOD,28,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET<>0 mkstat=2 : End Endif
  GSCSAUZSST = [F:SRU]AUZSST
Endif

# Contrôle emplacement dédié ou mono-article
If ([M:SCS1]BETFCYCOD=4)
  GBIDD1=-1
  Call STKCTREMP(GBIDD1,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M:SCS1]FCYDES,VALEUR,
&                "",1,"",[M:SCS1]SCOLOCTYP,[M:SCS1]SCOLOC,"",0,WRET,
&                GBIDD2,"UQS","","") From STKLOC
  If WRET
    mkstat=2 : End
  Endif
Endif

[M:SCS1]ITMREFSEL = VALEUR

End

##########################################################################
#--- TS 106217
Subprog C_ECSSEL(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET

If VALEUR="" : End : Endif
If [M:SCS1]ITMREFSEL="" : VALEUR="" : End : Endif

# Si trf interne ou retour sous-traitant, test d'existence
If find([M:SCS1]BETFCYCOD,1,5)
  Read [ECS]ECS0=[M:SCS1]ITMREFSEL;VALEUR
  If fstat
    mkstat=2 : GMESSAGE=mess(406,184,1) : End
  Endif
# Contrôle version / à règle de gestion uniquement si trf inter-sites, client ou sst
Else
  Call CTLECCVALMAJ([M:SCS1]ITMREFSEL,"",VALEUR,[M:SCS1]IPTDAT,"SRU1",LRET) From STKSOR
  If LRET>0 mkstat=2 Endif
Endif
End
#---

##########################################################################
Subprog AM_WRHSEL(VALEUR)
Variable Char    VALEUR()

#--- Bug 65411 suite
If VALEUR<>"" & [M:SCS1]ITMREFSEL<>"" & varmode([M:SCS1]WRHDES)<>0
   Read [ITW]ITW0=[M:SCS1]ITMREFSEL;VALEUR
   If fstat
      GERR=1 : GMESSAGE=[M:SCS1]ITMREFSEL-":"-mess(343,184,1)
      mkstat=2 : End
   Endif
Endif
#---
[M:SCS1]WRHSEL = VALEUR
[M:SCS1]WRHSTR = VALEUR
[M:SCS1]WRHEND = VALEUR

End

##########################################################################
Subprog C_LOCSEL(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCS1]LOCSEL
  If VALEUR<>""
    Read [STC]STC0=[M:SCS1]STOFCY;VALEUR
    If fstat
      GMESSAGE = mess(125,184,1)
      mkstat=2 : End
    Elsif dim([M:SCS1]WRHSEL)>0 & [M:SCS1]WRHSEL<>""
      If [F:STC]WRH<>[M:SCS1]WRHSEL
        GMESSAGE = mess(341,184,1)
        mkstat=2 : End
      Endif
    Endif
  Endif
  [M:SCS1]LOCSTR = VALEUR
  [M:SCS1]LOCEND = VALEUR
Endif

[M:SCS1]LOCSEL = VALEUR

End

##########################################################################
Subprog AM_STADESH(VALEUR)
Variable Char    VALEUR()

Local Shortint W_K : Raz W_K

If dim([M:SCS1]LOCDESH)>0 & [M:SCS1]LOCDESH<>"" & VALEUR<>""
  If [M:SCS1]LOCDESH<>[F:STC]LOC
    Read [STC]STC0=[M:SCS1]FCYDES;[M:SCS1]LOCDESH
    # Raz emplacement saisi s'il n'accepte pas ce statut
    Call STKCTRSTA(VALEUR,[F:STC]AUZSST,0,0,0,W_K) From STKACT
    If W_K <> 0
      Raz [M:SCS1]LOCDESH
      Raz [M:SCS1]LOCTYPDESH
      Affzo [M:SCS1]LOCDESH
    Endif
  Endif
Endif

End

##########################################################################
Subprog C_LOCDESH(VALEUR)
Variable Char    VALEUR()

Local Shortint W_K

VALEUR = toupper(VALEUR)
If !find(VALEUR,"",[M:SCS1]LOCDESH)
  Read [STC]STC0=[M:SCS1]FCYDES;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Elsif dim([M:SCS1]WRHDESH)>0 & [M:SCS1]WRHDESH<>""
    If [F:STC]WRH<>[M:SCS1]WRHDESH
      GMESSAGE = mess(341,184,1)
      mkstat=2 : End
    Endif
  Endif
Endif

If VALEUR<>""
  # Test statut autorisé pour l'emplacement saisi
  If [M:SCS1]STADESH<>""
    Call STKCTRSTA([M:SCS1]STADESH,[F:STC]AUZSST,0,0,0,W_K) From STKACT
  Else
    W_K=0
  Endif
  If W_K <> 0
    mkstat=2
    If GMESSAGE<>"" : GMESSAGE += chr$(13) : Endif
    GMESSAGE += VALEUR-mess(832,196,1)-"("+[M:SCS1]STADESH+")"
    End
  Endif
  [M:SCS1]LOCTYPDESH = [F:STC]LOCTYP
Endif

End

#---------------------------------------------------------------------------#
#                                                                           #
#                                Ecran SCS1 - Détail                        #
#                                                                           #
#---------------------------------------------------------------------------#

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
    If [M:SCS1]ITMREF(nolign-1)<>""

# hcb 33564 deb
       If GREP = "M"
          If dim(GCTRDATSCS) <= 0
             If [M:SCS1]IPTDAT < date$
                Global Integer GCTRDATSCS
                # Attention ! la date d imputation est antérieure à la date du jour
                Call MESSAGE(mess(162,184,1)) From GESECRAN
             Endif
          Endif
       Endif
# hcb 33564 fin

        Call LECITM2( [M:SCS1]FCYDES, [M:SCS1]ITMREF(nolign-1), "", LRET )
&                     From STKLIB

        # Si changement stock, lecture règle de gestion pour flux d'entrée
        If [M:SCS1]BETFCYCOD=1
          Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET)
&                     From STKLIB
          If LRET<>0 mkstat=2 : End Endif
        # Si transfert inter-site, lecture règle de gestion pour flux d'entrée
        Elsif [M:SCS1]BETFCYCOD=2
          Call LECSRU([M:SCS1]FCYDES,[F:ITM]TCLCOD,28,[M:SCS1]TRSCOD,"",LRET)
&                     From STKLIB
          If LRET<>0 mkstat=2 : End Endif
        Endif
       If [M:SCS1]QLYCTLDEM(nolign-1)<>""     # hcb 95103
          Diszo [M:SCS1]STADES(nolign-1)      # hcb 95103
       Endif                                  # hcb 95103
       If [F:SRT]CHGPCUCOD = 2 & [F:ITM]SERMGTCOD = 4                  # hcb X3-90572
          Diszo [M:SCS1]PCUDES(nolign-1)                               # hcb X3-90572
       Endif                                                           # hcb X3-90572


#                                                                   # hcb X3-67989 deb
# pour les mvts "inter-sites" et "Retour sous-traitant" LPN destination est saisissable
# si l article site n est pas geré en LPN il faut faire un Diszo
       If find([M:SCS1]BETFCYCOD,2,5)
          If dim([M:SCS1]LPNNUMDES)>0
             If [F:ITF]STOFCY <>[M:SCS1]FCYDES | [F:ITF]ITMREF <>[M:SCS1]ITMREF(nolign-1)
                Read [ITF]ITF0 = [M:SCS1]ITMREF(nolign-1);[M:SCS1]FCYDES
                If fstat
                   Raz [F:LPN]
                Endif
             Endif
             If [F:ITF]LPNMGTCOD <> 2
                Raz   [M:SCS1]LPNNUMDES(nolign-1)
                Diszo [M:SCS1]LPNNUMDES(nolign-1)
             Endif
          Endif
       Else
          If dim([M:SCS1]LPNNUM)>0
             If [M:SCS1]LPNNUM         (nolign-1)<>""
                If dim([M:SCS1]WRHDES)> 0
                   Diszo [M:SCS1]WRHDES(nolign-1)
                Endif
                Diszo [M:SCS1]LOCDES   (nolign-1)
                Diszo [M:SCS1]LOCTYPDES(nolign-1)
             Endif
          Endif
       Endif
#                                                                   # hcb X3-67989 fin
       If [F:SRT]CHGPCUCOD = 2 & [F:ITM]SERMGTCOD = 4                  # hcb X3-90572
          Diszo [M:SCS1]PCUDES(nolign-1)                               # hcb X3-90572
       Endif                                                           # hcb X3-90572

    Endif
End

##########################################################################
Subprog IB_NBLIG
    Local Integer LRET
    If [M:SCS1]ITMREF(nolign-1)<>""
        Call LECITM2( [M:SCS1]FCYDES, [M:SCS1]ITMREF(nolign-1), "", LRET )
&                     From STKLIB
        GOUVENT = 1
    Endif
    If [M:SCS1]CREFLG(nolign-1)>0
        GBOUT1 = mess(463, 198, 1)
    Endif
If [M:SCS1]SIHNUM = ""
    Raz GBOUT2
Endif

#85785 * RMA * can't change the document values if validated
If func PORLEGLIB.DIGSIGN([M:SCS1]STOFCY, "") & [M:SCS1]CFMFLG = 2
  Raz GBOUT1
Endif
#                                                           # hcb 110327 deb
# Btn 4 = saisie serie globales         110327 #
# No séries concernés
GBOUT4 = mess(655,199,1)

# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If GBOUT1 = "" | [F:ITM]SERMGTCOD <> 4 | [M:SCS1]WSTOCOU (nolign-1)= 0 | [M:SCS1]QTYSTUDES (nolign-1)= 0
   Raz GBOUT4
Endif

#                                                           # hcb 110327 end

End

##########################################################################
$AAPRES_NBLIG
Local Integer LRET
    Call OUVCHG("SCS1", nolign-1, [M:SCS1]STOFCY) From SUBSCSB
    If [M:SCS1]BETCPY=2
# Issue 120553 - 2017-01-16 by CCC : No need of overhead calculation
#        Call SETNEWPRIOVE([M:SCS1]ITMREF(nolign-1),"","",[M:SCS1]FCYDES,[M:SCS1]IPTDAT,
#&                         [M:SCS1]WSTOSEQ(nolign-1),[M:SCS1]PRI(nolign-1),
#&                         [M:SCS1]TRSTYP,[M:SCS1]QTYSTUDES(nolign-1),"",LRET) From STKVAL
        Call SETNEWPRI([M:SCS1]ITMREF(nolign-1),"","",[M:SCS1]FCYDES,[M:SCS1]IPTDAT,
&                      [M:SCS1]WSTOSEQ(nolign-1),[M:SCS1]PRI(nolign-1),"") From STKVAL
    Endif
Return

##########################################################################
Subprog C_NBLIG
Local Integer LRET

If find(status,65,68,83) & [M:SCS1]LPNNUM(nolign-1)<>"" & [F:SRT]CHGEMPCOD=2      # hcb 107548/X3-38236
   Call ERREUR(mess(539,184,1)) From GESECRAN  # Suppression interdite : stock associé à un contenant et changement d'emplacment autorisé
   mkstat= 2
   End
Endif

    Case status
        When 65     :                       # Suppression d'une ligne
            If [M:SCS1]CREFLG(nolign-1)=0
                Call DELSTOCHGW("SCS1", [M:SCS1]STOFCY, nolign-1, nolign-1,
&                               1, LRET) From SUBSCSB
            Else
                mkstat = 2
            Endif

        When 68, 83 :                       # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                If [M:SCS1]CREFLG(I)<>0
                    mkstat=2
                    Break
                Endif
            Next
            If !mkstat
                Call DELSTOCHGW("SCS1", [M:SCS1]STOFCY, nolign-1, nolign1-1,
&                               1, LRET) From SUBSCSB
            Endif

        When 75     :
            If [M:SCS1]CREFLG(nolign-1)<>0
                mkstat=2
            Endif
    Endcase

    If LRET
        mkstat=2
    Endif

    If find(status,73,75)
        If [M:SGW]NBLIG+sigma(0,[M:SGW]NBLIG-1,[M:SGW]WSTOSEQ(indcum)=[M:SCS1]WSTOSEQ(nolign-1))>=dim([M:SGW]WSTOSEQ)
            Call ERREUR(mess(36,184,1)) From GESECRAN
            mkstat=2
            End
        Endif
    Endif

End

##########################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local Decimal WQTE
Local Integer LRET, NOL
NOL=nolign-1

Call MAJQTY(1,VALEUR,LRET) From SUBSCSB
If LRET
   mkstat=2 : End
Endif

# Calcul des montants base calcul taxe
If [M:SCS1]BETCPY=2
   Call ALICLCAMT([M:SCS1]ITMREF(NOL),[M:SCS1]QTYSTUDES(NOL),NOL,"SCS1",
&                 [M:SCS1]CLCAMT1(NOL),[M:SCS1]CLCAMT2(NOL)) From TRTX3
Endif

# Recherche tarif si module vente et inter-société
# avec client connu et article vente existant
If GMODU(5) & [M:SCS1]BETCPY=2 & [M:SCS1]BPCNUM<>""
   Read [ITS]ITS0=[M:SCS1]ITMREF(NOL)
   If !fstat
      WQTE = [M:SCS1]QTYSTUDES(NOL)
      Gosub RECH_PRIX  From SUBSCSB
   Endif
Endif

End

##########################################################################
Subprog AM_QTYSTUDES(VALEUR)
Variable Decimal VALEUR
Local Decimal WQTE, WQTYARR
Local Integer LRET, NOL
NOL=nolign-1

Call MAJQTY(2,VALEUR,LRET) From SUBSCSB
If LRET
   mkstat=2 : End
Endif

# Calcul des montants base calcul taxe
If [M:SCS1]BETCPY=2
   Call ALICLCAMT([M:SCS1]ITMREF(NOL),VALEUR,NOL,"SCS1",
&                 [M:SCS1]CLCAMT1(NOL),[M:SCS1]CLCAMT2(NOL)) From TRTX3
Endif

Call CALCSAIZON( VALEUR>0, "QTYSTUDES") From SUBSCSB

# Recherche tarif si module vente et inter-société
# avec client connu et article vente existant
If GMODU(5) & [M:SCS1]BETCPY=2 & [M:SCS1]BPCNUM<>""
   Read [ITS]ITS0=[M:SCS1]ITMREF(NOL)
   If !fstat
      WQTE = VALEUR
      Gosub RECH_PRIX From SUBSCSB
   Endif
Endif

#--- Contrôle cohérence Qté US, UC et coeff UC/US
If [M:SCS1]PCUDES(NOL)<>[M:SCS1]STU(NOL)
   Call CTRQTYPCU([M:SCS1]PCUDES(NOL),[M:SCS1]COEDES(NOL),VALEUR,WQTYARR) From STKLIB
   If WQTYARR<>VALEUR
      Call MESSAGE(mess(160,184,1)-"("+[M:SCS1]PCUDES(NOL)+")\"+mess(161,184,1)-":"-num$(WQTYARR)) From GESECRAN
   Endif
Endif

End

##########################################################################
Subprog AM_PCUDES(VALEUR)
Variable Char    VALEUR()
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Decimal LCOE, WQTYARR

Gosub SET_NOL

Call CTLUOM ([M:SCS1]ITMREF(NOL),3,"", VALEUR,LCOE, LUSCAV,
&            LFMT, LMODIF) From STKACT
If LUSCAV <> "S" & LUSCAV <> "C"
   mkstat = 2 : End
Endif

If LMODIF=2
    Actzo [M:SCS1]COEDES(NOL)
Else
    Diszo [M:SCS1]COEDES(NOL)
Endif
[M:SCS1]COEDES(NOL) = LCOE
[M:SCS1]QTYPCUDES(NOL) = [M:SCS1]QTYSTUDES(NOL) / [M:SCS1]COEDES(NOL)
Call QTEARR([M:SCS1]QTYPCUDES(NOL),VALEUR) From TRTDIV
Affzo [M:SCS1]COEDES(NOL),QTYPCUDES(NOL)

Call CALCSAIZON( VALEUR<>"", "PCUDES") From SUBSCSB

#--- Contrôle cohérence Qté US, UC et coeff UC/US
If VALEUR<>[M:SCS1]STU(NOL)
   Call CTRQTYPCU(VALEUR,[M:SCS1]COEDES(NOL),[M:SCS1]QTYSTUDES(NOL),WQTYARR) From STKLIB
   If WQTYARR<>[M:SCS1]QTYSTUDES(NOL)
      Call MESSAGE(mess(160,184,1)-"("+VALEUR+")\"+mess(161,184,1)-":"-num$(WQTYARR)) From GESECRAN
   Endif
Endif

End

##########################################################################
Subprog AM_COEDES(VALEUR)
Variable Decimal VALEUR

Local Decimal WQTYARR

Gosub SET_NOL
If VALEUR>0
    [M:SCS1]QTYPCUDES(NOL) = [M:SCS1]QTYSTUDES(NOL) / VALEUR
Else
    [M:SCS1]QTYPCUDES(NOL) = 0
Endif
Affzo QTYPCUDES(NOL)

Call CALCSAIZON( VALEUR<>0, "COEDES") From SUBSCSB

#--- Contrôle cohérence Qté US, UC et coeff UC/US
If [M:SCS1]PCUDES(NOL)<>[M:SCS1]STU(NOL)
   Call CTRQTYPCU([M:SCS1]PCUDES(NOL),VALEUR,[M:SCS1]QTYSTUDES(NOL),WQTYARR) From STKLIB
   If WQTYARR<>[M:SCS1]QTYSTUDES(NOL)
      Call MESSAGE(mess(160,184,1)-"("+[M:SCS1]PCUDES(NOL)+")\"+mess(161,184,1)-":"-num$(WQTYARR)) From GESECRAN
   Endif
Endif

End

##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
    If [F:ITM]SERMGTCOD=2 & VALEUR<>""
        Call STKCTRSER(VALEUR,[M:SCS1]ITMREF(nolign-1),nolign-1,[M:SCS1]NBLIG,
&                      [M:SCS1]WSTOSEQ(nolign-1),[M:SCS1]TRSTYP,[M:SCS1]VCRTYP,
&                      [M:SCS1]VCRNUM,[M:SCS1]VCRLIN(nolign-1),0,"",0,0,0,"" )
&            From STKACT
    Endif
End

##########################################################################
Subprog C_STADES(VALEUR)
Variable Char    VALEUR()
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

Case [M:SCS1]BETFCYCOD
 When 1 : If VALEUR = [M:SCS1]STA(nolign-1)
            GSCSAUZSST = "A*,Q*,R*"
          # Si statut destination <> statut origine, on le contrôle
          Else
            GSCSAUZSST = [F:SRU]AUZSST
            # Si changement de stock sans chgt d'emplacement, on vérifie
            # les statuts autorisés par l'emplacement
            If [F:SRT]CHGEMPCOD<>2 & [F:ITF]LOCMGTCOD=2
              If [F:STC]LOC<>[M:SCS1]LOC(nolign-1)
                Read [STC]STC0=[M:SCS1]STOFCY;[M:SCS1]LOC(nolign-1)
                If fstat End Endif
              Endif
              Call STKCTRSTA(VALEUR,[F:STC]AUZSST,1,2,0,mkstat) From STKACT
            Endif
          Endif
 When 2 : GSCSAUZSST = [F:SRU]AUZSST : # Trf inter-sites
 When 3 : GSCSAUZSST = "A*,Q*,R*"    : # Inactif
 When 4 : GSCSAUZSST = "A*,Q*,R*"    : # Trf sous-traitant --> pas de restriction
#MAE, RET_SSTRT
 When 5 : GSCSAUZSST = "A*,Q*,R*"    : # Retour sous-traitant --> pas de restriction
Endcase
End

##########################################################################
Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
Local    Char    WWRH(GLONWRH)
Gosub SET_NOL

Case [M:SCS1]BETFCYCOD
 When 1 : If left$(VALEUR,1)="Q"    # hcb 44028
            [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
            Actzo [M:SCS1]QLYCTLFLG(NOL)
          Else
            [M:SCS1]QLYCTLFLG(NOL) = 1
            Diszo [M:SCS1]QLYCTLFLG(NOL)
          Endif
 When 2 : If left$(VALEUR,1)="Q" : # Inter-site
            [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
            Actzo [M:SCS1]QLYCTLFLG(NOL)
          Else
            [M:SCS1]QLYCTLFLG(NOL) = 1
            Diszo [M:SCS1]QLYCTLFLG(NOL)
          Endif
 When 3 : [M:SCS1]QLYCTLFLG(NOL)=1 : # Inactif
          Diszo [M:SCS1]QLYCTLFLG(NOL)
 When 4 : [M:SCS1]QLYCTLFLG(NOL)=1 : # Trf sous-traitant
          Diszo [M:SCS1]QLYCTLFLG(NOL)
#MAE, RET_SSTRT

 When 5 : If left$(VALEUR,1)="Q"    # Retour sous-traitant    # hcb 65523
            [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
            Actzo [M:SCS1]QLYCTLFLG(NOL)
          Else
            [M:SCS1]QLYCTLFLG(NOL) = 1
            Diszo [M:SCS1]QLYCTLFLG(NOL)
          Endif
Endcase

Affzo [M:SCS1]QLYCTLFLG(NOL)
Call CALCSAIZON( VALEUR<>"", "STADES") From SUBSCSB

#-- Si article géré en emplacement, et contrôle non ok,
#-- on raz emplacement et type d'emplacement
If [F:ITF]ITMREF<>[M:SCS1]ITMREF | [F:ITF]STOFCY<>[M:SCS1]STOFCY
  Read [ITF]ITF0 = [M:SCS1]ITMREF; [M:SCS1]STOFCY
  If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]LOCMGTCOD=2 & [M:SCS1]LOCTYPDES(NOL)<>""
  If dim([M:SCS1]WRHDES) > 0
    WWRH=[M:SCS1]WRHDES(NOL)
  Else
    WWRH=""
  Endif
  Call STKCTRTLO([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                [M:SCS1]STOFCY,[M:SCS1]ITMREF,[M:SCS1]PCUDES(NOL),
&                [M:SCS1]QTYPCUDES(NOL),VALEUR,0,[M:SCS1]LOCTYPDES(NOL),
&                mkstat,"QU","",WWRH) From STKLOC
  If mkstat
    Raz [M:SCS1]LOCTYPDES(NOL), [M:SCS1]LOCDES(NOL), mkstat, GMESSAGE
    Affzo [M:SCS1]LOCTYPDES(NOL), LOCDES(NOL)
  Elsif [M:SCS1]LOCDES(NOL)<>""
    Call STKCTREMP([M:SCS1]WLOCSEQ(NOL),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                  [M:SCS1]STOFCY,[M:SCS1]ITMREF,[M:SCS1]PCUDES(NOL),
&                  [M:SCS1]QTYPCUDES(NOL),VALEUR,[M:SCS1]LOCTYPDES(NOL),
&                  [M:SCS1]LOCDES(NOL),"",0,mkstat,GBIDD1,"","",WWRH) From STKLOC
    If mkstat
      Raz [M:SCS1]LOCTYPDES(NOL), [M:SCS1]LOCDES(NOL), mkstat
      Affzo [M:SCS1]LOCTYPDES(NOL), LOCDES(NOL)
    Endif
  Endif
Endif

#--- Issue 99815
# Si mouvement interne et changement de statut, contrôle disponibilité stock
Local Integer WSTA
Local Decimal WDISPO
If [M:SCS1]BETFCYCOD=1 & left$(VALEUR,1)<>left$([M:SCS1]STA(NOL),1)
  WSTA=0
  WDISPO=0
  If [F:ITG]GLOAAAFLG = 2   WSTA += 1  Endif
  If [F:ITG]GLOQQQFLG = 2   WSTA += 2  Endif
  If [F:ITG]GLORRRFLG = 2   WSTA += 4  Endif
   Call STODISTOT("",1,WSTA,"",WDISPO) From STKLIB
  # Le stock dispo a été calculé selon la valeur de WSTA (prise en compte de 'A' et/ou 'Q' et/ou 'R')
  # On diminue donc ce disponible si la ligne stock était dispo de part son statut
  # alors qu'elle ne le sera plus, de part son nouveau statut.
  # Les cas d'augmentation du stock disponible ne sont pas calculés car sans intérêt
  Case WSTA
    When 0,1 : If left$([M:SCS1]STA(NOL),1)="A" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
    When 2   : If left$([M:SCS1]STA(NOL),1)="Q" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
    When 3   : If find(left$([M:SCS1]STA(NOL),1),"A","Q") & left$(VALEUR,1)="R"
                 WDISPO-=[M:SCS1]QTYSTUDES(NOL)
               Endif
    When 4   : If left$([M:SCS1]STA(NOL),1)="R" WDISPO-=[M:SCS1]QTYSTUDES(NOL) Endif
    When 5   : If find(left$([M:SCS1]STA(NOL),1),"A","R") & left$(VALEUR,1)="Q"
                 WDISPO-=[M:SCS1]QTYSTUDES(NOL)
               Endif
    When 6   : If find(left$([M:SCS1]STA(NOL),1),"Q","R") & left$(VALEUR,1)="A"
                 WDISPO-=[M:SCS1]QTYSTUDES(NOL)
               Endif
    When 7   :
  Endcase
  If WDISPO<0                                                  # hcb X3-56049
    Call MESSAGE(mess(421,184,1)) From GESECRAN
  Endif
Endif
#---

End

#########################################################################
Subprog C_WRHDES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SCS1]WRHDES(nolign-1)<>""
   Raz [M:SCS1]LOC(nolign-1)
Endif
End

#########################################################################
Subprog AM_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
#                                                                  # hcb X3-67989 deb
Local Char    WLOCTYP(GLONTEM)
Local Char    WLOC   (GLONLOC)
Local Char    WLPN   (GLONLPN)
Local Char    WWRH   (GLONWRH)
Local Integer I
If [M:SCS1]LPNNUM(nolign-1) <> ""
   WLOCTYP = VALEUR
   WLOC    = [M:SCS1]LOCDES(nolign-1)
   WLPN    = [M:SCS1]LPNNUM(nolign-1)
 #                                 # premiere passe pour verifier si le nouvel emplecement est possible sur toutes les lignes
   For I = 0 To [M:SCS1]NBLIG-1
       If [M:SCS1]LPNNUM   (I) =  WLPN
          If dim([M:SCS1]WRHDES) > 0
             WWRH=[M:SCS1]WRHDES(I)
          Else
             WWRH=""
          Endif
          Call STKCTREMP([M:SCS1]WLOCSEQ(I),[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M:SCS1]STOFCY,
&                        [M:SCS1]ITMREF(I),[M:SCS1]PCUDES(I),[M:SCS1]QTYPCUDES(I),
&                        [M:SCS1]STADES(I),WLOCTYP,WLOC,"",
&                        0,mkstat,GBIDD1,"",GFILLOCENT,WWRH) From STKLOC
            If mkstat<>0
               mkstat = 2
               Break
            Endif
       Endif
   Next
   If mkstat = 2
      End
   Else
#                                 # deuxieme passe pour verifier pour affecter le nouvel emplacement
      For I = 0 To [M:SCS1]NBLIG-1
          If [M:SCS1]LPNNUM   (I) =  WLPN
             [M:SCS1]LOCTYPDES(I) =  WLOCTYP
             [M:SCS1]LOCDES   (I) =  WLOC
          Endif
       Next
   Endif
   Affzo [M:SCS1]30
Endif
#                                                                  # hcb X3-67989 fin
Call CALCSAIZON( VALEUR<>"", "LOCTYPDES") From SUBSCSB
End
################################################################################                # hcb X3-67989
#  Tout inclure                                                                                 # hcb X3-67989
#########################################################################
Subprog CL_ALLINC(VALEUR)
Variable Char    VALEUR()

Global Integer  GSTOPRET
Global Libelle  GALLINCEXC
Local  Char     FILGAUSUP(240)(0..3), WMESSAGE(240)
Local  Char     WCRITSTO4(90)
Local  Integer  WINSLIG         : # Indique que l'on a pické des lignes
Local  Integer  I, J, LRET, LSEQ
Local  Integer  LNEW            : # Indique s'il faut ajouter une ligne au document
Local  Char     LSER(GLONSER)
Local  Decimal  LQTY, LSTOCOU
Local Integer   WBREAK

Raz WINSLIG, WBREAK


If [M:SCS1]LOCSEL="" | [M:SCS1]LOCDESH=""
  Call MESSAGE(mess(165,184,1)) From GESECRAN   # L'emplacement de selection et l emplecement destination doivent etre renseignés
  End
Endif

GALLINCEXC=1

Call OUVRE_TRACE(mess(145,198,1)) From LECFIC   # selection stock

If dim(LSAVNOL)<=0
  Local Integer LSAVNOL
  LSAVNOL=-1
Endif

Link [STO] With
& [STL]STL0=ITMREF;LOT;SLO,
& [STS]STS0=ITMREF;SERNUM
& As [STOL]
& Order By Key STO0

Raz WCRITSTO4
Call CREE_FORMULE([M:SCS1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG

Gosub FILGAUCHE From SUBSCSP

Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO0

#                                                                              # hcb X3-67989 deb
Case currbox
 When GBOXSTO  : Gosub ALLINC_STO
 When GBOXLPN  : Gosub ALLINC_LPN
 When Default  :
Endcase
#If currbox<>GBOXSTO  Return Endif
#Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO0

#If pat(FILGAUSUP(0),"*ITMREFSEL*")
#  For [STOL] Hint Key STO3
#    Gosub PIC_STOL
#    If WBREAK=1 Break Endif
#  Next
#Else
#  For [STOL] Hint Key STO4
#    Gosub PIC_STOL
#    If WBREAK=1 Break Endif
#  Next
#Endif
#Filter [STOL]
#                                                                              # hcb X3-67989 fin

If GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

GALLINCEXC=0

# Pour déclencher l'action générale 'APRES_MODIF'
If WINSLIG>0
  Affzo [M:SCS1]30
  mkstat=4
Endif
If dim(GSTOPRET)>0
   Kill GSTOPRET
Endif
End
#                                                                              # hcb X3-67989 deb

################################################################################
#  Tout inclure lignes de stock
################################################################################
$ALLINC_STO

#If currbox<>GBOXSTO  Return Endif
Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO0

If pat(FILGAUSUP(0),"*ITMREFSEL*")
   For [STOL] Hint Key STO3
       Gosub PIC_STOL
       If WBREAK=1 Break Endif
   Next
Else
   For [STOL] Hint Key STO4
       Gosub PIC_STOL
       If WBREAK=1 Break Endif
   Next
Endif

Filter [STOL]

Return
#                                                                              # hcb X3-67989 deb
#########################################################################
$PIC_STOL


# Le chrono stock a t-il déjà été chargé au cours de cette saisie ?
If [M:SGW]NBLIG>0
  J=0
  $LOOP_WSTOCOU
  I=find([F:STO]STOCOU,[M:SGW]WSTOCOU(J..[M:SGW]NBLIG-1))
  If I<>0
    If [M:SGW]WSTOSEQ(I-1)=0
      J=I
      If J<[M:SGW]NBLIG Goto LOOP_WSTOCOU Endif
    Else
      Return
    Endif
  Endif
Endif

Raz LRET

If [F:STO]ITMREF<>[F:ITM]ITMREF
  Call LECITM([M:SCS1]FCYDES,[F:STO]ITMREF,"",3,[F:STO]WRH,LRET) From STKLIB
  If LRET<>0 Return Endif
  # Lecture règle de gestion pour flux d'entrée
  Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET) From STKLIB
  If LRET<>0 Return Endif
Endif

# Emplacement en attente de rangement
If [F:STO]LOCCAT=2
  Raz LRET
  # Contrôle que la ligne de stock en attente de rangement est complète
  Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
  If LRET<>0
    GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-[F:STO]STA-":"-mess(378,199,1)
    GMESSAGE+="\"+mess(377,199,1)-": "
    Case LRET
      When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
      When 2 : GMESSAGE+=mess(453,197,1)
      When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
    Endcase
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Return
  Endif
Endif

# Ligne de stock avec demande d'analyse
If [F:STO]QLYCTLDEM<>""
  # Recherche de la ligne de demande d'analyse pour vérifier
  # que celle-ci n'a pas déjà été partiellement contrôlée
  LRET=0
  For [QLD]QLD1 Where ITMREF=[F:STO]ITMREF & STOFCY=[F:STO]STOFCY
&                   & VCRTYP=28 & VCRNUM=[F:STO]QLYCTLDEM
    If [F:QLD]LOT      =[F:STO]LOT
&    & [F:QLD]SLO      =[F:STO]SLO
&    & [F:QLD]SERNUM   =[F:STO]SERNUM
&    & [F:QLD]STA      =[F:STO]STA
&    & [F:QLD]LOC      =[F:STO]LOC
&    & [F:QLD]PCU      =[F:STO]PCU
&    & [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
&    & [F:QLD]PALNUM   =[F:STO]PALNUM
&    & [F:QLD]CTRNUM   =[F:STO]CTRNUM
&    & [F:QLD]OWNER    =[F:STO]OWNER
&    & [F:QLD]STOFLD1  =[F:STO]STOFLD1
&    & [F:QLD]STOFLD2  =[F:STO]STOFLD2
      If [F:QLD]QTYSTU=[F:STO]QTYSTU
        LRET=1
      Endif
      Break
    Endif
  Next
  If LRET=0
    GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC
    If [F:STO]SERNUM<>""
      GMESSAGE+=" "+[F:STO]SERNUM-":"
    Else
      If [F:STO]LOT<>""
        GMESSAGE+=" "+[F:STO]LOT
        If [F:STO]SLO<>"" GMESSAGE+=" "+[F:STO]SLO Endif
      Endif
      GMESSAGE+=" "+[F:STO]STA-":"
    Endif
    GMESSAGE+=" "+mess(163,184,1)+"\"+mess(164,184,1)
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Return
  Endif
Endif

If !clalev([F:STA]) : Local File STOALL [STA] : Endif
Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
[G:STA]currlen=0
If !fstat
  If dim(GALLSTO)=0 : Global Integer GALLSTO : Endif
  GALLSTO = 1
Endif

If [F:STO]QTYSTU-[F:STO]CUMWIPQTY>0
  # Ecran SCS1 plein
  If [M:SCS1]NBLIG >= dim([M:SCS1]ITMREF)
    Call ECR_TRACE(mess(203,184,1),1) From GESECRAN
    WBREAK=1 : Return
  Endif

  Call STKWSTOSEQ ("SCS1", [M:SCS1]NBLIG, [M:SCS1]NBLIG, 2, LSEQ, LRET) From STKECR
  Gosub ALI_DOC From SUBSCSB

  # Ecran STOCHGW plein
  If GSTOPRET<>0
    Call ECR_TRACE(mess(36,184,1),1) From GESECRAN
    WBREAK=1 : Return
  Endif

  # Statut destination non initialisé : statut non autorisé
  If WPBSTA=1
    WMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC
    If [F:STO]SERNUM<>""
      WMESSAGE+=" "+[F:STO]SERNUM-":"
    Else
      If [F:STO]LOT<>""
        WMESSAGE+=" "+[F:STO]LOT
        If [F:STO]SLO<>"" WMESSAGE+=" "+[F:STO]SLO Endif
      Endif
      WMESSAGE+=" "+[F:STO]STA-":"
    Endif
    WMESSAGE+=" "+mess(178,184,1)+"\"+mess(127,184,1)
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
    Call ECR_TRACE("--------------------",0) From GESECRAN
  Endif
  # Emplacement destination non renseigné : .... erreur emplacement ....
  If WPBLOC=1
    If right$(GMESSAGE,len(GMESSAGE))=":"
      GMESSAGE=mid$(GMESSAGE,1,len(GMESSAGE)-1)
    Endif
    WMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC
    If [F:STO]SERNUM<>""
       # Issue 101335 - 2014-07-08 by SR
      WMESSAGE+=" "+[F:STO]SERNUM-":"
    Else
      If [F:STO]LOT<>""
        WMESSAGE+=" "+[F:STO]LOT
        If [F:STO]SLO<>"" WMESSAGE+=" "+[F:STO]SLO Endif
      Endif
      WMESSAGE+=" "+[F:STO]STA-":"
    Endif
    WMESSAGE+=" "+mess(187,184,1)+"\"+GMESSAGE
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
    Call ECR_TRACE("--------------------",0) From GESECRAN
    Raz GMESSAGE
  Endif

  If LSAVNOL<0
    LSAVNOL = nolign-1
  Endif
  WINSLIG += 1
Else
  GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC
  If [F:STO]SERNUM<>""
    GMESSAGE+=" "+[F:STO]SERNUM-":"
  Else
    If [F:STO]LOT<>""
      GMESSAGE+=" "+[F:STO]LOT
      If [F:STO]SLO<>"" GMESSAGE+=" "+[F:STO]SLO Endif
    Endif
    GMESSAGE+=" "+[F:STO]STA-":"
  Endif
  GMESSAGE+=" "+mess(57,184,1)
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Return
Endif

Return

################################################################################                # hcb X3-67989
#  Tout exclure                                                                                 # hcb X3-67989
################################################################################
Subprog CL_ALLEXC(VALEUR)
Variable Char    VALEUR()

Global Libelle  GALLINCEXC
Local  Char     FILGAUSUP(240)(0..3)
Local  Char     WCRITSTO4(90)
Local  Integer  WDELLIG         : # Indique que l'on a depické des lignes
Local  Integer  I, J, LRET

Raz WDELLIG

# If currbox<>GBOXSTO End Endif                                     # hcb X3-67989
If [M:SGW]NBLIG=0   End Endif

If [M:SCS1]LOCSEL=""
  Call MESSAGE(mess(166,184,1)) From GESECRAN
  End
Endif

GALLINCEXC=1


Link [STO] With
& [STL]STL0=ITMREF;LOT;SLO,
& [STS]STS0=ITMREF;SERNUM
& As [STOL]
& Order By Key STO0

Raz WCRITSTO4
Call CREE_FORMULE([M:SCS1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG

Gosub FILGAUCHE From SUBSCSP

#                                                                              # hcb X3-67989 deb
Case currbox
 When GBOXSTO  : Gosub ALLEXC_STO
 When GBOXLPN  : Gosub ALLEXC_LPN
 When Default  :
Endcase

#If find("ITMREFSEL",FILGAUSUP(0))
#  Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO3
#Else
#  Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO4
#Endif
#For [STOL]
#  J=0
#  $LOOP_WSTOCOU2
#  I=find([F:STO]STOCOU,[M:SGW]WSTOCOU(J..[M:SGW]NBLIG-1))
#  If I<>0
#    If [M:SGW]WSTOSEQ(I-1)=0
#      J=I
#      If J<[M:SGW]NBLIG
#         Goto LOOP_WSTOCOU2
#      Else
#         Goto NEXT_STOL2
#      Endif
#    Endif
#  Else
#    Goto NEXT_STOL2
#  Endif
#  # Pour indiquer au sous-prog qu'il ne faut pas raz [M:SGW]WSTOCOU()
#  # Sinon on ne peut pas débleuir les boules
#  #LRET=99
#  # Dépick de la ligne
#  Call DEPICK([F:STO]STOFCY,[F:STO]STOCOU,"SCS1",LRET) From SUBSCSB
#  WDELLIG=1
#  $NEXT_STOL2
#Next

#Filter [STOL]
#                                                                              # hcb X3-67989 fin

GALLINCEXC=0

# Pour déclencher l'action générale 'APRES_MODIF'
If WDELLIG>0
  Affzo [M:SCS1]30
  Kill WDELLIG                                                                 # hcb X3-67989
  mkstat=4
Endif

End

#                                                                              # hcb X3-67989 deb
################################################################################
#  Tout exclure ligne de stock
################################################################################
$ALLEXC_STO

If find("ITMREFSEL",FILGAUSUP(0))
  Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO3
Else
  Filter [STOL]  Where evalue(FILGAUSUP) Order By Key STO4
Endif
For [STOL]
  J=0
  $LOOP_WSTOCOU2
  I=find([F:STO]STOCOU,[M:SGW]WSTOCOU(J..[M:SGW]NBLIG-1))
  If I<>0
    If [M:SGW]WSTOSEQ(I-1)=0
      J=I
      If J<[M:SGW]NBLIG
         Goto LOOP_WSTOCOU2
      Else
         Goto NEXT_STOL2
      Endif
    Endif
  Else
    Goto NEXT_STOL2
  Endif
  # Pour indiquer au sous-prog qu'il ne faut pas raz [M:SGW]WSTOCOU()
  # Sinon on ne peut pas débleuir les boules
  #LRET=99
  # Dépick de la ligne
  Call DEPICK([F:STO]STOFCY,[F:STO]STOCOU,"SCS1",LRET) From SUBSCSB
  WDELLIG=1
  $NEXT_STOL2
Next

Filter [STOL]
Return

################################################################################
#  Tout inclure contenant
################################################################################
$ALLINC_LPN

Filter [LPN]  Where evalue(FILGAUSUP) Order By Key LPN0
   For [LPN] Hint Key LPN0
       Gosub PICKE_LPN   From SUBSCSP
       If GERR= 1
          Break
       Endif
   Next
Filter [LPN]
Return
################################################################################
#  Tout exclure contenant
################################################################################
$ALLEXC_LPN
Local Integer OK
Filter [LPN]  Where evalue(FILGAUSUP) Order By Key LPN0
   For [LPN] Hint Key LPN0
        Gosub DEPICK From SUBSCSP
   Next
Filter [LPN]
Kill OK
Return
#                                                                              # hcb X3-67989 fin

