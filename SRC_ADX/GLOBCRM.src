########################################################################
# GLOBCRM : Définition des variables globales                          #
#               utilisées par le module CRM                            #
# pas besoin d'init les variables puisque fait dans chaque programme   #
# les autres sont init par le WWGLOBCRM                                #
# -------------------------------------------------------------------- #
# DEFVAR : Définitition des variables globales                         #
########################################################################


########################################################################
#         Définition des variables globales du module CRM              #
########################################################################
Subprog DEFVAR

Call DEFVAR From WWAGLOBCRM

End

########################################################################
#       Initialisation des variables globales du module CRM            #
########################################################################
Subprog INIVAR

End
