#<AdxTL>@(#)10.0.0.0 $Revision$
##############################################################################
## Champ navigation = "Non autorisée" si MENU est vide
##############################################################################
Call OUVRE_TRACE("Update AFC") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local File =DOSSIER+".AFONCTION" [AFC]
Trbegin [AFC]
 For [AFC] Where MENU="" & NAVIG<>4
  [F:AFC]NAVIG = 4
  Rewrite [AFC]
  Call ECR_TRACE("Update"-[F:AFC]CODINT,0) From GESECRAN
 Next AFC
Commit
Return
