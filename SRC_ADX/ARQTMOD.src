#<AdxTL>@(#)7.0.0.0 $Revision$

####################################################################### 
##  Modification d'une requête  
####################################################################### 

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , IRQT , NUMERO , REQUETE
REQUETE = val(PARAM(1))
If REQUETE=0 : FIN = 1 : Return : Endif
Read [ABR]NUMREQ = REQUETE
If fstat : FIN = 1 : Return : Endif
IRQT = find(REQUETE,[M:ABR1]NUMREQ(0..[M:ABR1]NBLIG-1))-1
If IRQT<0 : FIN = 1 : Return : Endif
If [M:ABR1]FLAG(IRQT)<>1 : FIN = 1 : Return : Endif
Return

$INIT_DIA
nolign = IRQT+1
[M:DIA] = [F:ABR]
Return

$EXEC
Call DEBTRANS From GLOCK 
Gosub TR_MODIF 
If GOK<1 
 Affzo [M:ABR1]FLAG(IRQT) 
Else 
 For I=IRQT+1 To 1 Step -1
  Read [ABR]NUMREQ = [M:ABR1]NUMREQ(I-1)
  nolign = I
  [M:ABR1] = [F:ABR]
  Affzo [M:ABR1]DAT(I-1),HEURE(I-1),PRIO(I-1)
  If NUMERO=0 | I=[M:ABR1]NBLIG | [M:ABR1]NUMGRP(I-1)<>NUMERO
   Break
  Endif
 Next I
Endif 
If NUMERO>0
 Call MESSAGE(mess(57,139,1)-[F:ABR]GRP-num$(NUMERO)) From GESECRAN : # Modification des tâches du groupe x
Endif
Return 
 
$TR_MODIF 
GOK = 1
Trbegin [ABR]
 Readlock [ABR]NUMREQ = REQUETE
 If fstat=1 
  GOK=-1 : GLOCK="$ABATRQT"-num$(REQUETE)
  Goto ROLL_MODIF 
 Elsif fstat>=5 
  GOK=0 : Call RSTA("ABR",num$(REQUETE)) From GLOCK 
  Goto AB_MODIF 
 Elsif [F:ABR]FLAG<>1 
  GOK=0 : Goto AB_MODIF 
 Endif
 NUMERO = [F:ABR]NUMGRP
 If NUMERO>0
  For [ABR] Where NUMREQ>=REQUETE & GRP<>"" & NUMGRP=NUMERO
   If !find([F:ABR]FLAG,1,4) : # En attente ou bloquée
    NUMERO = 0 : Break
   Else
    Readlock [ABR] Curr
    If fstat=1 
     GOK=-1 : GLOCK="$ABATRQT"-num$([F:ABR]NUMREQ) : Break
    Elsif fstat>=5 
     GOK=0 : Call RSTA("ABR",num$([F:ABR]NUMREQ)) From GLOCK : Break
    Endif 
   Endif
  Next ABR
 Endif
 If GOK=-1   : Goto ROLL_MODIF
 Elsif GOK=0 : Goto AB_MODIF
 Endif
 If NUMERO>0
  Update [ABR] 
& Where NUMREQ>=REQUETE
&     & NUMGRP=NUMERO & GRP<>""
& With  DAT   = [M:DIA]DAT 
&    ,  HEURE = [M:DIA]HEURE 
&    ,  PRIO  = [M:DIA]PRIO 
 Else
  Update [ABR] 
& Where NUMREQ=REQUETE
& With  DAT   = [M:DIA]DAT 
&    ,  HEURE = [M:DIA]HEURE 
&    ,  PRIO  = [M:DIA]PRIO 
 Endif
 If fstat 
  GOK=0 : Call RSTA("ABR",num$(REQUETE)) From GLOCK 
  Goto AB_MODIF 
 Endif
Commit 
Return 
 
$AB_MODIF 
Rollback 
Return 
 
$ROLL_MODIF 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_MODIF : Endif  
 
#######################################################################
## Ecran ABRMODIF
#######################################################################
Subprog C_PRIO(VALEUR) 
Variable Decimal VALEUR 
If VALEUR>39   
 mkstat = 1   
Endif   
End 

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
Local Char    HOR(GLONABH)
Call CTLDAT(HOR,[M]GRP,[M]TACHE,VALEUR,OK) From ARQTSUB
If !OK : mkstat = 2 : Endif
End

Subprog C_HEURE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char    HOR(GLONABH)
Call CTLHOR(HOR,[M]GRP,[M]TACHE,[M]DAT,VALEUR,OK) From ARQTSUB
If !OK : mkstat = 2 : Endif
End
