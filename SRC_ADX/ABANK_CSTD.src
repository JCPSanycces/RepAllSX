#<AdxTL>@(#)0.0.0.0 $Revision$ Banques (guichets)
# Structure ABANK

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case CURPTH
  When ""
    Case [L]AEVENT
      When "AUPDATE_AFTER"                    : Gosub AUPDATE_AFTER
      When "ADELETE_CONTROL_BEFORE"           : Gosub ADELETE_CONTROL_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CRY"     : Gosub CRY
  When "BAN"     : Gosub BAN
  When "VLYEND"  : Gosub VLYEND
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


##########################################################################################################
$AUPDATE_AFTER
Local Integer BANLNG,MY_STATUS
Local File BID [BID]

If this.snapshot.VLYSTR<>this.VLYSTR or this.snapshot.VLYEND<>this.VLYEND
  [L]BANLNG = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BANLNG")
  For [F:BID] Where CRY=this.CRY & left$([F:BID]BIDNUM,[L]BANLNG)=this.BAN
    BID = NewInstance C_BID AllocGroup null
    [L]ASTATUS = fmet BID.AREAD([F:BID]BPATYP,[F:BID]BPDNUM,[F:BID]BIDNUM,[F:BID]BPAADD)
    If [L]ASTATUS <> [V]CST_AOK
      # not found
      [L]ASTATUS = this.ASETERROR("BID",[F:BID]BPDNUM-[F:BID]BIDNUM-mess(42,9003,1),[L]MY_STATUS)
    Else
      If BID.VLYSTR<this.VLYSTR
        BID.VLYSTR = this.VLYSTR
      Endif
      If BID.VLYEND > this.VLYEND | BID.VLYEND=AVOID.ADATE
        BID.VLYEND = this.VLYEND
      Endif
      If BID.ASTALIN = [V]CST_AUPD
        [L]ASTATUS = fmet BID.AUPDATE()
        If [L]ASTATUS<>[V]CST_AOK
          # Error during update
          [L]ASTATUS=fmet this.ASETERROR("BID",[F:BID]BPDNUM-[F:BID]BIDNUM-mess(50,176,1),[L]ASTATUS)
        Endif
      Endif
     Endif
    FreeGroup BID
  Next
Endif
Return

##########################################################################################################
$ADELETE_CONTROL_BEFORE
Local Integer BANLNG
Local File BID [BID]

[L]BANLNG = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BANLNG")
For [BID] Where CRY=this.CRY & left$([F:BID]BIDNUM,[L]BANLNG)=this.BAN
  # Bank Id numbers exist with payment bank
  [L]ASTATUS = fmet this.ASETERROR("ABN",mess(174,133,1),[V]CST_AERROR)
  Break
Next

Return



##########################################################################################################
$CRY
Case [L]ARULE
 When "CONTROL"   :  Gosub CRY_CONTROL
 Endcase
Return

$CRY_CONTROL
If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BANLNG")<1 | fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BIDCTL")<>[V]CST_AYES
  # Bank control not active
  [L]ASTATUS = fmet this.ASETERROR("CRY",this.CRY-mess(172,133,1),[V]CST_AERROR)
Endif
Return

##########################################################################################################
$BAN
Case [L]ARULE
  When "CONTROL"   : Gosub BAN_CONTROL   : # Control method attached to BAN
Endcase
Return

$BAN_CONTROL
Local Integer BANLNG

[L]BANLNG=fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"BANLNG")
If len(this.BAN) <> [L]BANLNG
  # Invalid length
  [L]ASTATUS = fmet this.ASETERROR("BAN",mess(111,123,1)-this.CRY-"("+num$([L]BANLNG)+")",[V]CST_AERROR)
Endif

Return

##########################################################################################################
$VLYEND
Case [L]ARULE
    When "CONTROL"   : Gosub VLYEND_CONTROL
Endcase

$VLYEND_CONTROL
If this.VLYEND<>AVOID.ADATE & this.VLYSTR<>AVOID.ADATE & this.VLYEND<this.VLYSTR
    # Start date > end date
    [L]ASTATUS = fmet this.ASETERROR("VLYEND",mess(90,121,1),[V]CST_AERROR)
Endif
Return

