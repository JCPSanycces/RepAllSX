#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

########################################################################################################
##
## Historisation / Epuration pièces comptables  HQ"-   Module Accounting                               #
########################################################################################################
#   - CHQNUM    : Historisation / Epuration des factures client                                        #
########################################################################################################
# HISTO = 1 => Historisation
#
#              Les données passent d'APPLI vers HISAPL
#              Les données historisées sont supprimées d'APPLI  
#              Uniquement des contrôles liés au dossier APPLI
#
#
# EPUR  = 1 => Epuration
#
#    Soit Epuration seule (EPUR=1 et HISTO=0) 
#         Les données sont supprimées d'APPLI
#         Uniquement des contrôles liés au dossier APPLI.
#
#    Soit Epuration suite à l'historisation (EPUR=1 et HISTO=1) 
#                    L'historisation a fait les vérifications nécessaires (cf HISTO=1)
#                    L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier.
#
########################################################################################################

$ACTION
Case ACTION

   When "HISTO"
            Case [F:AHI]COD
                 When "BPS1099"   : Gosub HISTO_BPS1099
            Endcase

  When "EPURE"
            Case [F:AHI]COD
                 When "BPS1099"   : Gosub EPURE_BPS1099
            Endcase

Endcase
Return




#######################################################################################
# Historation / Epuration des règlements                                              #
# Formule d'épuration :   [F1]YR1099 < year(date$-[F:AHI]TIMx)                        #
#######################################################################################

$HISTO_BPS1099


    
Case TABLE
   When "BPS1099GEN" 

        If [F:F1]YR1099>=year(date$-[F:AHI]TIM1)
           Raz [L]OKHIS 
        Endif
   When "BPS1099PAY"  
        If [F:F1]YR1099>=year(date$-[F:AHI]TIM1) 
           Raz [L]OKHIS 
        Endif
   When "BP1099BEGBAL"  
        If [F:F1]YR1099>=year(date$-[F:AHI]TIM1) 
           Raz [L]OKHIS 
        Endif

Endcase

Return

$EPURE_BPS1099
Case TABLE
   When "BPS1099GEN" 
    # If [F:F1]YR1099>2004
    #   Dbgaff #rs 2/1/2012 test
    # Endif   
        If [F:F1]YR1099>=year(date$-[F:AHI]TIM2)
           Raz [L]OKEPU 
        Endif
   When "BPS1099PAY" 
        If [F:F1]YR1099>=year(date$-[F:AHI]TIM2)
           Raz [L]OKEPU 
        Endif
   When "BP1099BEGBAL" 
        If [F:F1]YR1099>=year(date$-[F:AHI]TIM2)
           Raz [L]OKEPU 
        Endif

Endcase

Return






