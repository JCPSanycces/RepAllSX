##########################################################################################################
$OUVRE_BOITE
Local Char LTI_AFFAIRES(30)
Local Char LTI_OPPENC(30)
Local Char LTI_OPPWIN(30)
Local Char LTI_OPPLOS(30)
Local Char LTI_OPPFOR(30)

  #---------------------------------------------------#
  LTI_AFFAIRES = 'GAU_CHE'+num$(find('OPP', OBJLIS(1..10)))  # Affaires
  LTI_OPPENC   = 'GAU_CHE'+num$(find('OP4', OBJLIS(1..10)))  # Affaires en cours
  LTI_OPPWIN   = 'GAU_CHE'+num$(find('OP5', OBJLIS(1..10)))  # Affaires gagnées
  LTI_OPPLOS   = 'GAU_CHE'+num$(find('OP6', OBJLIS(1..10)))  # Affaires perdues
  LTI_OPPFOR   = 'GAU_CHE'+num$(find('OP7', OBJLIS(1..10)))  # Affaires abandonnées
Return

##########################################################################################################
$FILTRE
  # Issue X3-15720/120479 - 2016-12-19 by FGR : BEGIN
  If !clalev([F:OPP_]) Then
    Gosub OUVFIC_LISTE From WOOPP
  Endif
  # Issue X3-15720/120479 - 2016-12-19 by FGR : END
  Default File [OPP_]
  FILTSUP += "([F:PIM]PIMTYP = 1 or [F:PIM]PIMTYP = 3)"
Return

##########################################################################################################
$FILGAUCHE
Local Char SCRITCRM(250)

  If dim(LTI_OPPWIN) = -1 Then
    Return
  Endif
  SCRITCRM = "([F:PIM]PIMTYP = 1 or [F:PIM]PIMTYP = 3)"
  If currbox = LTI_OPPENC Then
    # Affaires en cours
    #-------------------------------------------
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:OPPCRM]OPPSTEA2 <> 'WIN' and [F:OPPCRM]OPPSTEA2 <> 'LOS' and [F:OPPCRM]OPPSTEA2 <> 'FOR'", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", SCRITCRM, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OPP") From CRMUTIL150
  Elsif currbox = LTI_OPPWIN Then
    # Affaires gagnées
    #-------------------------------------------
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:OPPCRM]OPPSTEA2 = 'WIN'", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", SCRITCRM, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OPP") From CRMUTIL150
  Elsif currbox = LTI_OPPLOS Then
    # Affaires gagnées
    #-------------------------------------------
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:OPPCRM]OPPSTEA2 = 'LOS'", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", SCRITCRM, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OPP") From CRMUTIL150
  Elsif currbox = LTI_OPPFOR Then
    # Affaires gagnées
    #-------------------------------------------
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:OPPCRM]OPPSTEA2 = 'FOR'", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", SCRITCRM, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OPP") From CRMUTIL150
  Endif
Return

##########################################################################################################
$SETBOUT
Local Integer IBLEAD
Local Integer IDEVIS

  # Menu Actions   Module Action Co
  # B : Devis
  # Z : Affaire PJM
  # } : Enregistrer un rendez-vous
  # { : Enregistrer un appel
  # ~ : Enregistrer une tâche
  # % : Enregistrer une demande de service
  #---------------------------------------
  IBLEAD = [V]CST_AFALSE
  # Cas des LEADs pas de création de devis possible ni demande de service
  If [M:OPP0]OPPCMP = "" Then
    If [M:OPP0]CCNTYP = 2 Then
      IBLEAD = [V]CST_ATRUE
    Endif
  Endif
  Case GREP
    When ""
      If func ASYRFNC.ACTIV("PJM") = [V]CST_AFALSE Then
        Call VIREBOUT(CHAINE,"Z") From GOBJET
      #Elsif GZINSOPP.PIMPL.PIMTYP <> 3 Then                                             # Issue X3-44586 - 2017-06-14 by FGR
      Elsif GZINSOPP = null or (GZINSOPP <> null and GZINSOPP.PIMPL.PIMTYP <> 3) Then    # Issue X3-44586 - 2017-06-14 by FGR
        Call VIREBOUT(CHAINE,"Z") From GOBJET
      Endif
      If [M:OPP0]OPPCMP <> "" Then
        # Devis autorisé pour les prospects
        If [M:OPP0]BPRINFO < 1 Then
          Call VIREBOUT(CHAINE,"B") From GOBJET
        Endif
      Endif
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"Z") From GOBJET
      Call VIREBOUT(CHAINE,"B") From GOBJET
    When Default
  Endcase
  If IBLEAD = [V]CST_ATRUE Then
    Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
  If [M:OPP1]OPPCLO = [V]CST_AYES Then
    Call VIREBOUT(CHAINE,"B") From GOBJET
    IDEVIS = [V]CST_AFALSE
    Filter [SQH] Where [F:SQH]SALFCY = [M:OPP0]SALFCY and [F:SQH]PJT = [M:OPP0]OPPNUM
    For [SQH]
      IDEVIS = [V]CST_ATRUE
      Break
    Next
    Filter [SQH]
  Endif
  #
  If GREP = "" Then
    CHMEN += "{}~"
  Endif
  If IBLEAD = [V]CST_AFALSE Then
    If GREP = "" and GMODU(12) = [V]CST_AYES and [M:OPP0]BPRINFO > 1 Then
      CHMEN += "%"
    Endif
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  [M:OPP0]NVGCOD = BOUT
  Case BOUT
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer Tache
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$EXEBOUT
  Case BOUT
    When "B"
      # Tunnel sur DEVIS
      Gosub RELIT From GOBJSUB
    When Default
  Endcase
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCRE
Local Integer NI                                 # Hybrid part
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSOPP <> null Then
    FreeGroup GZINSOPP
  Endif
  GZINSOPP = NewInstance C_OPPOR AllocGroup null
  [L]MY_STATUS = fmet GZINSOPP.AINIT()
  GZINSOPP.TCHTOREAD = "CRM"
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
    GOK = 0
    GERR = 1
    Return
  Endif
  [L]MY_STATUS = fmet GZINSOPP.COM_PROMOTE_CRM()
  # -------------------------------
  If [M:OPP0]OPPCMP <> "" Then
    GZINSOPP.OPPCMP = [M:OPP0]OPPCMP
  Endif
#  If [M:OPP0]OPPSRENUM <> "" Then    ### FLORENT VOIR ICI
#    Call SETSREINF From SUBOPPB
#  Endif
  # -------------------------------
  # Take back init values
  Call DISPLAY_CRM_PROJECT()
  # Hybrid part (end)
  # ----------------------------------------------------------
  [M:OPP1]OPPPRPTYP = GZINSOPP.PIMPL.PIMTYP
  #Définition du type de pièce
  Gosub DEFOBJORI From SUBOPPB
  #On initialise le site
  GFCY = [M:OPP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  If [M:OPP0]OPPCMP <> "" Then
    #Définit l'interlocuteur par défaut de l'affaire
    Read [BPR]BPR0=[M:OPP0]OPPCMP
    If fstat Then
      #Affiche le nom en clair du tiers sélectionné.
      [M:OPP0]BPRINFO = 0
    Else
      #Affiche le nom en clair du tiers sélectionné.
      If [F:BPR]BPCFLG = [V]CST_AYES Then
        # Client
        [M:OPP0]BPRINFO = 2
      Elsif [F:BPR]PPTFLG = [V]CST_AYES Then
        # Prospect
        [M:OPP0]BPRINFO = 1
      Else
        [M:OPP0]BPRINFO = 0
      Endif
    Endif
    #Affiche le type du tiers sélectionné.
    Call AFFICHE_BCK_TIERS([M:OPP0]OPPCMP) From SUBOPPB
  Else
    [M:OPP0]BPRINFO = 0
  Endif
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBOPPB
  #Affichage background OPPMCN
  Gosub DISPBKGCCN From SUBOPPB
  Affzo [M:OPP0]1-99
  Affzo [M:OPP1]1-99
  Affzo [M:OPP2]1-99
  Affzo [M:OPP3]1-99
  Affzo [M:OPP4]1-99
Return

##########################################################################################################
$RAZDUP
  # ----------------------------------------------------------
  # Hybrid part (begin)
  GMESSAGE = mess(1182,196,1)
  GOK = 0
  GERR = 1
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$CREATION
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSOPP.AINSERT()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1180,196,1)
    Endif
    Return
  Endif
  # ----------------------------------
  # Issue X3-41562 - 2017-07-25 by FGR : BEGIN
  SetInstance [F:OPP] With GZINSOPP    # IMPORTANT TO NO LOST THE CURRENT RECORD IN OBJECT GESTION
  [M:OPP0] = [F:OPP]
  #[M:OPP0]OPPNUM = GZINSOPP.OPPNUM
  #Affzo [M:OPP0]OPPNUM
  # Issue X3-41562 - 2017-07-25 by FGR : END
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$APRES_CRE
  # Issue X3-41562 - 2017-07-25 by FGR : BEGIN
  #Sauvegarde données courant
  #  [M:OPP0]SALFCYINI = [M:OPP0]SALFCY
  #  [M:OPP0]OPPCMPINI = [M:OPP0]OPPCMP
  #  [M:OPP1]OPPDATOPNI = [M:OPP1]OPPDATOPN
  #  Diszo [M:OPP1]OPPORIVCR
  #  Diszo [M:OPP1]OPPORITXT
  #  [M:OPP1]CREHOU = [F:OPP]CREHOU
  #  Gosub GEREECRAN From SUBOPPB
  #  Affzo [M:OPP1]1-99
  Gosub RELIT From GOBJSUB
  # Issue X3-41562 - 2017-07-25 by FGR : END
Return

##########################################################################################################
$MODIF
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSOPP.AUPDATE()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1181,196,1)
    Endif
    Return
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
  #Sauvegarde données courant
  [M:OPP0]SALFCYINI = [M:OPP0]SALFCY
  [M:OPP0]OPPCMPINI = [M:OPP0]OPPCMP
  [M:OPP1]OPPDATOPNI = [M:OPP1]OPPDATOPN
  Diszo [M:OPP1]OPPORIVCR
  Diszo [M:OPP1]OPPORITXT
  Gosub GEREECRAN From SUBOPPB
Return

##########################################################################################################
$AV_ANNULE
Local Integer ANOWRITE

  ANOWRITE = 1
Return

##########################################################################################################
$ANNULE
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSOPP.ADELETE()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1181,196,1)
    Endif
    Return
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer NI                                 # Hybrid part
Local Integer ILINE                              # Hybrid part
Local Integer ASTATUS                            # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  # [M:OPP2] ----------------------------------
  For NI = 1 To maxtab(GZINSOPP.CPP)
    If GZINSOPP.CPP(NI) <> null and find(GZINSOPP.CPP(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSOPP.CPP(NI).AUUID), [M:OPP2]AUUID(0..[M:OPP2]NBOPP2-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:OPP2]COLLIN(0..[M:OPP2]NBOPP2-1))
      Endif
      If ILINE = 0 Then
        #[L]ASTATUS = fmet GZINSOPP.ADELLINE("CPP",NI)                                             # Issue X3-96497 - 2018-06-27 by FGR
        [L]ASTATUS = fmet GZINSOPP.ADELLINE("CPP", GZINSOPP.CPP(NI).AORDER)                        # Issue X3-96497 - 2018-06-27 by FGR
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then                                                    # Issue X3-96497 - 2018-06-27 by FGR : not >= [V]CST_AERROR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # [M:OPP3] ----------------------------------
  For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTB)
    If GZINSOPP.CRM(1).STPSTB(NI) <> null and find(GZINSOPP.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSOPP.CRM(1).STPSTB(NI).AUUID), [M:OPP3]AUUID(0..[M:OPP3]NBOPP3-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:OPP3]COLLIN(0..[M:OPP3]NBOPP3-1))
      Endif
      If ILINE = 0 Then
        #[L]ASTATUS = fmet GZINSOPP.CRM(1).ADELLINE("STPSTB",NI)                                   # Issue X3-96497 - 2018-06-27 by FGR
        [L]ASTATUS = fmet GZINSOPP.CRM(1).ADELLINE("STPSTB", GZINSOPP.CRM(1).STPSTB(NI).AORDER)    # Issue X3-96497 - 2018-06-27 by FGR
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then                                                    # Issue X3-96497 - 2018-06-27 by FGR : not >= [V]CST_AERROR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # [M:OPP4] ----------------------------------
  For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTA)
    If GZINSOPP.CRM(1).STPSTA(NI) <> null and find(GZINSOPP.CRM(1).STPSTA(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSOPP.CRM(1).STPSTA(NI).AUUID), [M:OPP4]AUUID(0..[M:OPP4]NBOPP4-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:OPP4]COLLIN(0..[M:OPP4]NBOPP4-1))
      Endif
      If ILINE = 0 Then
        #[L]ASTATUS = fmet GZINSOPP.CRM(1).ADELLINE("STPSTA",NI)                                   # Issue X3-96497 - 2018-06-27 by FGR
        [L]ASTATUS = fmet GZINSOPP.CRM(1).ADELLINE("STPSTA", GZINSOPP.CRM(1).STPSTA(NI).AORDER)    # Issue X3-96497 - 2018-06-27 by FGR
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then                                                    # Issue X3-96497 - 2018-06-27 by FGR : not >= [V]CST_AERROR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # [M:OPP5] ----------------------------------
  For NI = 1 To maxtab(GZINSOPP.SBB)
    If GZINSOPP.SBB(NI) <> null and find(GZINSOPP.SBB(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSOPP.SBB(NI).AUUID), [M:OPP5]AUUID(0..[M:OPP5]NBOPP5-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:OPP5]COLLIN(0..[M:OPP5]NBOPP5-1))
      Endif
      If ILINE = 0 Then
        #[L]ASTATUS = fmet GZINSOPP.ADELLINE("SBB",NI)                                             # Issue X3-96497 - 2018-06-27 by FGR
        [L]ASTATUS = fmet GZINSOPP.ADELLINE("SBB", GZINSOPP.SBB(NI).AORDER)                        # Issue X3-96497 - 2018-06-27 by FGR
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then                                                    # Issue X3-96497 - 2018-06-27 by FGR : not >= [V]CST_AERROR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # Hybrid part (end)
End

##########################################################################################################
Subprog DISPLAY_CRM_PROJECT()

Local Integer NI

  Call SHOW_OPPOR_HEADER()
  # ---------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSOPP.CPP)
    # ------------------------------------
    If GZINSOPP.CPP(NI) <> null and find(GZINSOPP.CPP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_OPPOR_OPP2(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:OPP2]NBOPP2 = nolign
  Affzo [M:OPP2]1-99
  # ---------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTB)
    # ------------------------------------
    If GZINSOPP.CRM(1).STPSTB(NI) <> null and find(GZINSOPP.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_OPPOR_OPP3(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:OPP3]NBOPP3 = nolign
  Affzo [M:OPP3]1-99
  # ---------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSOPP.CRM(1).STPSTA)
    # ------------------------------------
    If GZINSOPP.CRM(1).STPSTA(NI) <> null and find(GZINSOPP.CRM(1).STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_OPPOR_OPP4(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:OPP4]NBOPP4 = nolign
  Affzo [M:OPP4]1-99
  # ---------------------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSOPP.SBB)
    # ------------------------------------
    If GZINSOPP.SBB(NI) <> null and find(GZINSOPP.SBB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_OPPOR_OPP5(NI)
    Endif
    # ------------------------------------
  Next NI
  [M:OPP5]NBOPP5 = nolign
  Affzo [M:OPP5]1-99
  # ---------------------------------------
End

##########################################################################################################
Subprog SHOW_OPPOR_HEADER()
Local Integer IRET

  IRET = fmet GZINSOPP.CRM(1).COMPUTE_AMT()
  # ---------------------------------------
  SetInstance [M:OPP0] With GZINSOPP
  SetInstance [M:OPP1] With GZINSOPP
  SetInstance [M:OPP1] With GZINSOPP.CRM(1)
  [M:OPP0]OPPDESAXX = GZINSOPP.PIMPL.PIMDESAXX
  # ---------------------------------------
  [M:OPP0]SALFCYINI = [M:OPP0]SALFCY
  [M:OPP0]OPPCMPINI = [M:OPP0]OPPCMP
  [M:OPP1]OPPDATOPNI = [M:OPP1]OPPDATOPN
  # ---------------------------------------
  If GFCY <> [M:OPP0]SALFCY Then
    GFCY = [M:OPP0]SALFCY
    Call GETDEV(GFCY) From DEVSUB
    #---- Chargement de GCUR
    Call CHARGE_GCUR() From TRTX3
  Endif
  # ---------------------------------------
  Affzo [M:OPP0]1-99
  Affzo [M:OPP1]1-99
End

##########################################################################################################
Subprog SHOW_OPPOR_OPP2(VNLINE)
Value Integer VNLINE

  SetInstance [M:OPP2]5 With GZINSOPP.CPP(VNLINE)
  [M:OPP2]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_OPPOR_OPP3(VNLINE)
Value Integer VNLINE

  SetInstance [M:OPP3]5 With GZINSOPP.CRM(1).STPSTB(VNLINE)
  [M:OPP3]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_OPPOR_OPP4(VNLINE)
Value Integer VNLINE

  SetInstance [M:OPP4]5 With GZINSOPP.CRM(1).STPSTA(VNLINE)
  [M:OPP4]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_OPPOR_OPP5(VNLINE)
Value Integer VNLINE

  SetInstance [M:OPP5]5 With GZINSOPP.SBB(VNLINE)
  [M:OPP5]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSOPP)
Variable Instance GZINSOPP Using C_OPPOR

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE    # Issue X3-67352

  # ----------------------------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSOPP, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
  # To help debug process : write a classic log file with all errors in class.
  If GERR <> 0 Then                    # Issue X3-67352 - 2017-12-11 by FGR
    # Issue X3-67352 - 2017-12-11 by FGR : BEGIN
    #Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_ANO
    If GTRACE = AVOID.ACHAR Then
      Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
      IOPEN_TRACE = [V]CST_AYES
    Endif
    # Issue X3-67352 - 2017-12-11 by FGR : END
    Call ECR_TRACE("->", 0) From GESECRAN
    Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GZINSOPP) From SYRSTACKTOOLS
    # Issue X3-67352 - 2017-12-11 by FGR : BEGIN
    #Call FERME_TRACE From LECFIC
    If IOPEN_TRACE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
    Endif
    # Issue X3-67352 - 2017-12-11 by FGR : END
  Endif
  # ----------------------------------------------------------
  # Issue X3-96497 - 2018-06-28 by FGR : BEGIN
  #If GZINSOPP.PIMPL.PIMTYP = 3 Then
  #  [L]MY_STATUS = fmet GZINSOPP.PJM_RESET_ERRORS()
  #Endif
  [L]MY_STATUS = fmet GZINSOPP.RESET_ERRORS()
  # Issue X3-96497 - 2018-06-28 by FGR : END
End

