#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Objet OPP
##########################################################################################################
##########################################################################################################
$OUVRE
Global Instance GZINSOPP Using C_OPPOR           # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  ANOWRITE = 1
  # Hybrid part (end)
  # ----------------------------------------------------------
  Gosub SAUV_GLOB From TRTX3GLOB
  # ----------------------------------------------------------
  #Ouverture de la table Table diverses
  # Issue X3-84652 - 2018-04-18 by FGR : BEGIN
  #If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  #If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  #If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  Local File FACILITY [FCY]
  Local File ATABDIV [ADI]
  Local File TABCOUAFF [TCA]
  # Issue X3-84652 - 2018-04-18 by FGR : END
  # ----------------------------------------------------------
  Gosub DISPBKGCCN From SUBOPPB  #Affichage background OPPMCN
Return

##########################################################################################################
$FERME
  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSOPP <> null Then
    FreeGroup GZINSOPP
  Endif
  Kill GZINSOPP
  # Hybrid part (end)
  # ----------------------------------------------------------
  Gosub REST_GLOB From TRTX3GLOB
  # ----------------------------------------------------------
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSQH" Then
      Affzo [M:SQH1]PJT
    Elsif GNAVIG(GPILNAV-1) = "GESSOH" Then
      Affzo [M:SOH1]PJT
    Elsif GNAVIG(GPILNAV-1) = "GESSIH" Then
      Affzo [M:SIH1]PJT
    Elsif GNAVIG(GPILNAV-1) = "GESSRE" Then
      [M:SRE8]PJTFLT = ""
      Affzo [M:SRE8]SREPJT
    Elsif GNAVIG(GPILNAV-1) = "GESCON" Then
      Affzo [M:CONG]CONPJT
    Endif
  Endif
  # ----------------------------------------------------------
Return

##########################################################################################################
$LIENS
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSOPP <> null Then
    FreeGroup GZINSOPP
  Endif
  GZINSOPP = NewInstance C_OPPOR AllocGroup null
  GZINSOPP.TCHTOREAD = "CRM"
  [L]MY_STATUS = fmet GZINSOPP.AREAD([M:OPP0]OPPNUM)
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
    GOK = 0
    GERR = 1
    Return
  Endif
  Read [F:OPPCRM]OPPCRM0=[M:OPP0]OPPNUM
  Call DISPLAY_CRM_PROJECT()
  # Hybrid part (end)
  # ----------------------------------------------------------
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  [M:OPP1]OPPPRPTYP = GZINSOPP.PIMPL.PIMTYP
  # Sauvegarde données courant
  [M:OPP0]SALFCYINI = [M:OPP0]SALFCY
  [M:OPP0]OPPCMPINI = [M:OPP0]OPPCMP
  [M:OPP1]OPPDATOPNI = [M:OPP1]OPPDATOPN
  GFCY = [M:OPP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  # ----------------------------------------------------------------------------------------
  If [M:OPP1]CREUSR <> "" Then
    Read [AUS]CODUSR=[M:OPP1]CREUSR
    [M:OPP1]FULNAMUSR = [F:AUS]NOMUSR
    Affzo [M:OPP1]FULNAMUSR
  Endif
  [M:OPP1]OPPORILIB = mess([M:OPP1]OPPORITYP,3037,1)
  If [M:OPP1]OPPORI = 1 Then
    [M:OPP1]OPPORITXT = ""
  Else
    [M:OPP1]OPPORITXT = mess([M:OPP1]OPPORI,2995,1)
  Endif
  #Définition du type de pièce
  Gosub DEFOBJORI From SUBOPPB
  Diszo [M:OPP1]OPPORIVCR
  Diszo [M:OPP1]OPPORITXT
  Call LIEN_OBJ_DYNAMIC([M:OPP1]OPPORIVCR,[M:OPP1]OPPORIOBC,[M:OPP1]OPPORIAVA,"","","[M:OPP1]OPPORIVCRD") From CRMUTIL140
  Call SETAFFVALCUR ([M:OPP0]CUR) From SUBOPPB
  #Affiche le nom en clair du tiers sélectionné.
  Read [BPR]BPR0=[M:OPP0]OPPCMP
  If !fstat Then
    If [F:BPR]BPCFLG = [V]CST_AYES Then
      # Client
      [M:OPP0]BPRINFO = 2
    Elsif [F:BPR]PPTFLG = [V]CST_AYES Then
      # Prospect
      [M:OPP0]BPRINFO = 1
    Else
      [M:OPP0]BPRINFO = 0
    Endif
  Else
    [M:OPP0]BPRINFO = 0
  Endif
  #Affiche le type du tiers sélectionné.
  Call AFFICHE_BCK_TIERS([M:OPP0]OPPCMP) From SUBOPPB
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBOPPB
  #Affichage background OPPMCN
  Gosub DISPBKGCCN From SUBOPPB
  Gosub GEREECRAN From SUBOPPB
  Affzo [M:OPP0]1-99
  Affzo [M:OPP1]1-99
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  STRTSUB = "SUBOPPA"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
# Issue X3-84652 - 2018-04-18 by FGR : BEGIN
$REDEFINE_LINK
  If dim(SPELNK) > 0 or dim(SPVLNK) > 0 Then
    # Dans ce cas c'est que les browsers ont été redéfinis en SPE/SPV. On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  # Issue X3-84652 - 2018-04-18 by FGR : END
  #---------------------------------------------------#
  Link [OPP] With [AFF]AFF0~=[F:OPP]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OPP]SALFCY,
&                 [OPPCRM]OPPCRM0=[F:OPP]OPPNUM,
&                 [PIM]PIM0=[F:OPP]OPPNUM,
&                 [AX3]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:OPP]OPPNUM;""
&              As [OP4]
  Link [OPP] With [AFF]AFF0~=[F:OPP]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OPP]SALFCY,
&                 [OPPCRM]OPPCRM0=[F:OPP]OPPNUM,
&                 [PIM]PIM0=[F:OPP]OPPNUM,
&                 [AX3]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:OPP]OPPNUM;""
&              As [OP5]
  Link [OPP] With [AFF]AFF0~=[F:OPP]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OPP]SALFCY,
&                 [OPPCRM]OPPCRM0=[F:OPP]OPPNUM,
&                 [PIM]PIM0=[F:OPP]OPPNUM,
&                 [AX3]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:OPP]OPPNUM;""
&              As [OP6]
  Link [OPP] With [AFF]AFF0~=[F:OPP]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OPP]SALFCY,
&                 [OPPCRM]OPPCRM0=[F:OPP]OPPNUM,
&                 [PIM]PIM0=[F:OPP]OPPNUM,
&                 [AX3]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:OPP]OPPNUM;""
&              As [OP7]
Return

