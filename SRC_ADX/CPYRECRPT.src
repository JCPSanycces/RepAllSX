#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("SA-COMP-REC","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250), CRITERE1(250)
Local Char    CPY(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    PRF(GLONPRF), SRV(GLONSRV)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML),POP(GLONPOP)
Local Char TAXYEAR(4), TAXMON(2)
Local Char PRNTRUB(30)
Local Integer CNTFT
Local Integer CNTNW
Local Integer CNTAT
Local Integer CNTNT
Local Integer CNTCT
Local Integer CNTOT
Local Char PAYMENTTYP(10)

If clalev([F:CPYREC])=0    : Local File HRCPYREC  [CPYREC]  : Endif
If clalev([F:CPYRECT])=0    : Local File HRCPYRECTERM  [CPYRECT]  : Endif
If clalev([F:CPYRECM])=0    : Local File HRCPYRECPM  [CPYRECM]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]: Endif
If clalev([F:VEP])=0    : Local File VALEMP  [VEP]  : Endif
If clalev([F:HRPEOD])=0    : Local File HRPEODET  [HRPEOD]  : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]  : Endif
If clalev([F:RGTQ])=0    : Local File RUBGRPRPT  [RGTQ]  : Endif
If clalev([F:HRSDP])=0    : Local File SOLDPAY  [HRSDP]  : Endif
If clalev([F:RIB])=0    : Local File EMPLORIB  [RIB]  : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpy",NBPAR,PARAMETRE,CPY)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("srv",NBPAR,PARAMETRE,SRV)
Call GETPARAM("year",NBPAR,PARAMETRE,TAXYEAR)
Call GETPARAM("mon",NBPAR,PARAMETRE,TAXMON)
Call GETPARAM("prf",NBPAR,PARAMETRE,PRF)
Call GETPARAM("pop",NBPAR,PARAMETRE,POP)
Call GETPARAM("prntrub",NBPAR,PARAMETRE,PRNTRUB)

CRITERE = "1=1"
If CPY<>"" : CRITERE -= "& [F:FGR]CPY='"+CPY+"'"    : Endif
If FCYDEB<>"" : CRITERE -= "& [F:HRCTR]ETRFCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE -= "& [F:HRCTR]ETRFCY<='"+FCYFIN+"'"    : Endif
If PRF<>"" : CRITERE -= "& [F:HRCTR]PROPRF='"+PRF+"'"    : Endif
If MATDEB<>"" : CRITERE -= "& [F:HRCTR]REFNUM>='"+MATDEB+"'" : Endif
If MATFIN<>"" : CRITERE -= "& [F:HRCTR]REFNUM<='"+MATFIN+"'" : Endif
If SRV<>"" : CRITERE -= "& [F:HRCTR]ETRSRV='"+SRV+"'"    : Endif



Gosub CLEARTABLE
Gosub HEAD_COUNT
Gosub PAYSLIP_STATUS
Gosub TERMINATION_REASON
Gosub NEG_NET_PAY
Gosub PAYMENTS
End

$CLEARTABLE
Trbegin [CPYREC]
 Delete [CPYREC] Where USR=GUSER
Commit
Trbegin [CPYRECT]
 Delete [CPYRECT] Where USR=GUSER
Commit
Trbegin [CPYRECM]
 Delete [CPYRECM] Where USR=GUSER
Commit
Return

$HEAD_COUNT
Trbegin [CPYREC]
  Local Integer HCNT
  Local Date STRDAT, ENDDAT
  Local Date THIS_STRDAT,THIS_ENDDAT
  Local Char RESULT_VALUE(2)
  Local Integer ITAXYEAR
  Local Integer ITAXMON
  Local Char CTRNUM(30)
  Local Char CTRNUMTMP(30)
#initialize
  RESULT_VALUE=''
  HCNT = 0
  CNTFT = 0
  CNTNW = 0
  CNTAT = 0
  CNTNT = 0
  CNTCT = 0
  CNTOT = 0

  ITAXYEAR = val(TAXYEAR)
  ITAXMON = val(TAXMON)
  STRDAT = [0/0/0] : ENDDAT = [0/0/0]
  THIS_STRDAT = [0/0/0] : THIS_ENDDAT = [0/0/0]

  CRITERE1 = ""
  If TAXYEAR<>"" : CRITERE1 -= " [F:HRPEOD]PERYEA="+TAXYEAR    : Endif
  If TAXMON<>"" : CRITERE1 -= "& [F:HRPEOD]TAXMON="+TAXMON    : Endif


If [L]POP<>""
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif

  For [LNK]
    RESULT_VALUE = ''
    If CTRNUM <> [F:HRCTR]CTRNUM & [F:HRCTR]FLGVAR <> 2
      If [F:HRCTR]DATANC >[F:HRCTR]DATCRE
        STRDAT =gdat$(day([F:HRCTR]DATANC),month([F:HRCTR]DATANC),year([F:HRCTR]DATANC))
      Else
        If [F:HRCTR]DATANC <=[F:HRCTR]DATCRE
          STRDAT =gdat$(day([F:HRCTR]DATCRE),month([F:HRCTR]DATCRE),year([F:HRCTR]DATCRE))
        Endif
      Endif

      If [F:HRCTR]XITFNL = 2 & [F:HRCTR]XITDAT >[F:HRCTR]DATXITFNL
        ENDDAT =gdat$(day([F:HRCTR]XITDAT),month([F:HRCTR]XITDAT),year([F:HRCTR]XITDAT))
      Else
        ENDDAT = gdat$(day([F:HRCTR]DATXITFNL),month([F:HRCTR]DATXITFNL),year([F:HRCTR]DATXITFNL))
      Endif

      Filter [HRPEOD] Where evalue(CRITERE1) & PERCOD = [VEP]PERCOD
      For [HRPEOD]
        If [HRPEOD]PERMON = 1
          THIS_STRDAT = gdat$(day([HRPEOD]PERSTR(1)),month([HRPEOD]PERSTR(1)),year([HRPEOD]PERSTR(1)))
        Endif
        If [HRPEOD]PERMON = [HRPEOD]PERMON2
          THIS_ENDDAT = gdat$(day([HRPEOD]PEREND(1)),month([HRPEOD]PEREND(1)),year([HRPEOD]PEREND(1)))
        Endif
      Next

      If (STRDAT < THIS_STRDAT & ENDDAT =[0/0/0])| (STRDAT < THIS_STRDAT & ENDDAT >= THIS_STRDAT)
        RESULT_VALUE ='AT'
        CNTAT+=1
      Endif

      If STRDAT > THIS_ENDDAT
        CNTFT+=1
      Endif

      If (STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT) & ((ENDDAT > THIS_ENDDAT)| (ENDDAT =[0/0/0]))
        RESULT_VALUE ='NW'
        CNTNW+=1
      Endif

      If STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
        RESULT_VALUE ='NT'
        CNTNT+=1
      Endif

      If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
        RESULT_VALUE ='CT'
        CNTCT+=1
      Endif

      If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT < THIS_STRDAT
        RESULT_VALUE ='OT'
        CNTOT+=1
      Endif

#      If STRDAT > THIS_ENDDAT
#        CNTFT+=1
#      Else
#        If (STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT) & ((ENDDAT > THIS_ENDDAT)| (ENDDAT =[0/0/0]))
#          RESULT_VALUE ='NW'
#          CNTNW+=1
#        Else
#          If (STRDAT < THIS_STRDAT & ENDDAT =[0/0/0])| (STRDAT < THIS_STRDAT & ENDDAT >= THIS_STRDAT)
#            RESULT_VALUE ='AT'
#            CNTAT+=1
#          Else
#            If STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
#              RESULT_VALUE ='NT'
#              CNTNT+=1
#            Else
#              If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
#                RESULT_VALUE ='CT'
#                CNTCT+=1
#              Else
#                If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT < THIS_STRDAT
#                  RESULT_VALUE ='OT'
#                  CNTOT+=1
#                Endif
#              Endif
#            Endif
#          Endif
#        Endif
#      Endif
    Endif
    If RESULT_VALUE <> ''
      HCNT+=1
    Endif
    CTRNUM = [F:HRCTR]CTRNUM
  Next

  Raz [F:CPYREC]
  [F:CPYREC]CPY = [F:FGR]CPY
  [F:CPYREC]USR = GUSER
  [F:CPYREC]HCNT = HCNT
  [F:CPYREC]CNTFT = CNTFT
  [F:CPYREC]CNTNW = CNTNW
  [F:CPYREC]CNTAT = CNTAT
  [F:CPYREC]CNTNT = CNTNT
  [F:CPYREC]CNTCT = CNTCT
  [F:CPYREC]CNTOT = CNTOT
  Write [CPYREC]
  If fstat
   GOK = 0 : Call FSTA("CPYREC") From GLOCK : Break 2
  Endif

 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return

$PAYSLIP_STATUS
Trbegin [CPYREC]
  Local Integer CNTENTERED
  Local Integer CNTCALC
  Local Integer CNTPRINT
  Local Integer CNTUNDERPROG
  Local Integer CNTPOSTED
#initialize
  CRITERE1 = ""
  CTRNUM = ''
  CNTENTERED = 0
  CNTCALC = 0
  CNTPRINT = 0
  CNTUNDERPROG = 0
  CNTPOSTED = 0

  If TAXYEAR<>"" : CRITERE1 -= " [F:HRPEOD]PERYEA="+TAXYEAR    : Endif
  If TAXMON<>"" : CRITERE1 -= "& [F:HRPEOD]TAXMON="+TAXMON    : Endif

If [L]POP<>""
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA  & [F:HRPOA]REFNUM<>""
Else
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA
Endif

  For [LNK]
      If [F:VEP]PST=1 and [F:VEP]STA=1
          CNTENTERED+=1
      Endif
      If  [F:VEP]PST=1 and [F:VEP]STA=2
        CNTCALC+=1
      Endif
      If  [F:VEP]PST=1 and [F:VEP]STA=3
        CNTPRINT+=1
      Endif
      If [F:VEP]PST=2 Then
        CNTUNDERPROG+=1
      Endif
      If  [F:VEP]PST=3  Then
        CNTPOSTED+=1
      Endif
  Next

  Read [F:CPYREC]CPYREC0 = [F:FGR]CPY;GUSER
  If !fstat
    [F:CPYREC]PSCALC = CNTCALC
    [F:CPYREC]PSENTERED = CNTENTERED
    [F:CPYREC]PSPOSTED = CNTPOSTED
    [F:CPYREC]PSPRINT = CNTPRINT
    [F:CPYREC]PSUNDPROG = CNTUNDERPROG
    Rewrite [F:CPYREC]
  Endif

 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return

$TERMINATION_REASON
Trbegin [CPYRECT]
#initialize
  CNTNT = 0
  CNTCT = 0
  CTRNUM = ''
  CRITERE1 = ""
  If TAXYEAR<>"" : CRITERE1 -= " [F:HRPEOD]PERYEA="+TAXYEAR    : Endif
  If TAXMON<>"" : CRITERE1 -= "& [F:HRPEOD]TAXMON="+TAXMON    : Endif


If [L]POP<>""
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif



  For [LNK]

    RESULT_VALUE = ''
    CNTCT = 0
    CNTNT = 0
    If CTRNUM <> [F:HRCTR]CTRNUM

      If [F:HRCTR]DATANC >[F:HRCTR]DATCRE
        STRDAT =gdat$(day([F:HRCTR]DATANC),month([F:HRCTR]DATANC),year([F:HRCTR]DATANC))
      Else
        If [F:HRCTR]DATANC <=[F:HRCTR]DATCRE
          STRDAT =gdat$(day([F:HRCTR]DATCRE),month([F:HRCTR]DATCRE),year([F:HRCTR]DATCRE))
        Endif
      Endif

      If [F:HRCTR]XITFNL = 2 & [F:HRCTR]XITDAT >[F:HRCTR]DATXITFNL
        ENDDAT =gdat$(day([F:HRCTR]XITDAT),month([F:HRCTR]XITDAT),year([F:HRCTR]XITDAT))
      Else
        ENDDAT = gdat$(day([F:HRCTR]DATXITFNL),month([F:HRCTR]DATXITFNL),year([F:HRCTR]DATXITFNL))
      Endif


      Filter [HRPEOD] Where evalue(CRITERE1) & PERCOD = [VEP]PERCOD
      For [HRPEOD]
        If [HRPEOD]PERMON = 1
          THIS_STRDAT = gdat$(day([HRPEOD]PERSTR(1)),month([HRPEOD]PERSTR(1)),year([HRPEOD]PERSTR(1)))
        Endif
        If [HRPEOD]PERMON = [HRPEOD]PERMON2
          THIS_ENDDAT = gdat$(day([HRPEOD]PEREND(1)),month([HRPEOD]PEREND(1)),year([HRPEOD]PEREND(1)))
        Endif
      Next

#    Infbox num$(STRDAT) + " >= " + num$(THIS_STRDAT) + " &  " + num$(STRDAT) + " <=  " + num$(THIS_ENDDAT) + " & " + num$(ENDDAT) + " <> [0/0/0] &  " + num$(ENDDAT) + " >=  " + num$(THIS_STRDAT) +
#& " &  " + num$(ENDDAT) + " <=  " + num$(THIS_ENDDAT)

      If STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
        RESULT_VALUE ='NT'
        CNTNT+=1
      Else
        If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
          RESULT_VALUE ='CT'
          CNTCT+=1
        Endif
      Endif

      If RESULT_VALUE <> ''
        Filter [F:CPYRECT] Where CPY=[F:FGR]CPY & USR = GUSER & XITGRD = [F:HRCTR]XITGRD
        Read [F:CPYRECT]CPYRECT0 Last

        If rowcount([F:CPYRECT])>0 Then
          Local Integer TERMCNT
          TERMCNT = [F:CPYRECT]TERMCNT
          [F:CPYRECT]TERMCNT = TERMCNT+CNTCT+CNTNT
          Rewrite [F:CPYRECT]
          If fstat
           GOK = 0 : Call FSTA("CPYRECT") From GLOCK : Break 2
          Endif
        Else
          Raz [F:CPYRECT]
          [F:CPYRECT]CPY = [F:FGR]CPY
          [F:CPYRECT]USR = GUSER
          [F:CPYRECT]TERMCNT = CNTCT+CNTNT
          [F:CPYRECT]XITGRD = [F:HRCTR]XITGRD
          Call LECTEXTRA([F:CPYRECT]TERMRSN, "HRXITGRD","DESAXX",[F:HRCTR]XITGRD,[F:VEP]LEG) From ATEXTRA
          Write [F:CPYRECT]
        Endif
      Endif
    Endif
        CTRNUM = [F:HRCTR]CTRNUM
  Next

 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return

$NEG_NET_PAY
Trbegin [CPYREC]
    Local Decimal RUBEAR
  Local Decimal RUBDED
  Local Decimal NETPAYAMT
  Local Decimal PAYOUTAMT
  Local Date STRDAT, ENDDAT
  Local Date THIS_STRDAT,THIS_ENDDAT
  Local Char RESULT_VALUE(2)
  Local Integer ITAXYEAR
  Local Integer ITAXMON
  Local Char CTRNUM(30)
  Local Char CTRNUMTMP(30)

  Local Integer NEGNW
  Local Integer NEGAT
  Local Integer NEGNT
  Local Integer NEGCT
  Local Integer NEGOT

  Local Integer POSNW
  Local Integer POSAT
  Local Integer POSNT
  Local Integer POSCT
  Local Integer POSOT

  Local Integer PAYOUTNW
  Local Integer PAYOUTAT
  Local Integer PAYOUTNT
  Local Integer PAYOUTCT
  Local Integer PAYOUTOT

  Local Integer PZNW
  Local Integer PZAT
  Local Integer PZNT
  Local Integer PZCT
  Local Integer PZOT

#initialize
  RESULT_VALUE=''
  RUBEAR = 0
  RUBDED = 0
  NETPAYAMT = 0
  PAYOUTAMT = 0
  NEGNW = 0
  NEGAT = 0
  NEGNT = 0
  NEGCT = 0
  NEGOT = 0
  POSNW = 0
  POSAT = 0
  POSNT = 0
  POSCT = 0
  POSOT = 0
  PAYOUTNW = 0
  PAYOUTAT = 0
  PAYOUTNT = 0
  PAYOUTCT = 0
  PAYOUTOT = 0
  PZNW = 0
  PZAT = 0
  PZNT = 0
  PZCT = 0
  PZOT = 0
  CTRNUM = ''
  ITAXYEAR = val(TAXYEAR)
  ITAXMON = val(TAXMON)
  STRDAT = [0/0/0] : ENDDAT = [0/0/0]
  THIS_STRDAT = [0/0/0] : THIS_ENDDAT = [0/0/0]

  CRITERE1 = ""
  If TAXYEAR<>"" : CRITERE1 -= " [F:HRPEOD]PERYEA="+TAXYEAR    : Endif
  If TAXMON<>"" : CRITERE1 -= "& [F:HRPEOD]TAXMON="+TAXMON    : Endif


If [L]POP<>""
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif

  For [LNK]
    RESULT_VALUE = ''

    If CTRNUM <> [F:HRCTR]CTRNUM
#      Link [HSP] With
#&       [RGTQ]RUB = [HSP]RUB
#&     As [LNKRUB]
#&     Where [F:HSP]CTRNUM =[F:HRCTR]CTRNUM & [F:HSP]EMP =[F:HRCTR]REFNUM & [F:HSP]BUL = [F:VEP]BUL & ([F:RGTQ]RPTGRP = 'EAR' | [F:RGTQ]RPTGRP = 'DED')
#&     Order By [F:HSP]BUL;[F:RGTQ]RPTGRP Asc

    Link [HSP] With
&     [RGTQ]RUB = [HSP]RUB
&     ,[RIB]RIB0(1) = [HSP]EMP
&   As [LNKRUB]
&   Where [F:HSP]CTRNUM =[F:HRCTR]CTRNUM & [F:HSP]EMP =[F:HRCTR]REFNUM & [F:HSP]BUL = [F:VEP]BUL & [F:RGTQ]LEG = [F:VEP]LEG  & ([F:RGTQ]RPTGRP = 'EAR' | [F:RGTQ]RPTGRP = 'DED')
&   Order By [F:HSP]CTRNUM;[F:HSP]BUL;[F:RGTQ]RPTGRP Asc

      RUBEAR = 0
      RUBDED = 0

      For [LNKRUB]
        If [F:RGTQ]RPTGRP = 'EAR' & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2))
          RUBEAR+=[F:HSP]AMT
        Endif

        If [F:RGTQ]RPTGRP = 'DED' &  (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2))
          RUBDED+=[F:HSP]AMT
        Endif
      Next

      NETPAYAMT = (RUBEAR-RUBDED)

      PAYOUTAMT = 0
      Read [F:HRSDP]SDP0 = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM
      If !fstat
        PAYOUTAMT = [F:HRSDP]BNC1
      Endif



      If [F:HRCTR]DATANC >[F:HRCTR]DATCRE
        STRDAT =gdat$(day([F:HRCTR]DATANC),month([F:HRCTR]DATANC),year([F:HRCTR]DATANC))
      Else
        If [F:HRCTR]DATANC <=[F:HRCTR]DATCRE
          STRDAT =gdat$(day([F:HRCTR]DATCRE),month([F:HRCTR]DATCRE),year([F:HRCTR]DATCRE))
        Endif
      Endif

      If [F:HRCTR]XITFNL = 2 & [F:HRCTR]XITDAT >[F:HRCTR]DATXITFNL
        ENDDAT =gdat$(day([F:HRCTR]XITDAT),month([F:HRCTR]XITDAT),year([F:HRCTR]XITDAT))
      Else
        ENDDAT = gdat$(day([F:HRCTR]DATXITFNL),month([F:HRCTR]DATXITFNL),year([F:HRCTR]DATXITFNL))
      Endif

      Filter [HRPEOD] Where evalue(CRITERE1) & PERCOD = [VEP]PERCOD
      For [HRPEOD]
        If [HRPEOD]PERMON = 1
          THIS_STRDAT = gdat$(day([HRPEOD]PERSTR(1)),month([HRPEOD]PERSTR(1)),year([HRPEOD]PERSTR(1)))
        Endif
        If [HRPEOD]PERMON = [HRPEOD]PERMON2
          THIS_ENDDAT = gdat$(day([HRPEOD]PEREND(1)),month([HRPEOD]PEREND(1)),year([HRPEOD]PEREND(1)))
        Endif
      Next

        If (STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT) & ((ENDDAT > THIS_ENDDAT)| (ENDDAT =[0/0/0]))
          If NETPAYAMT < 0
            NEGNW+=1
          Endif
          If NETPAYAMT > 0
            POSNW+=1
          Endif
          If NETPAYAMT = 0
            PZNW+=1
          Endif
          If PAYOUTAMT <> 0
            PAYOUTNW+=1
          Endif
        Else
          If (STRDAT < THIS_STRDAT & ENDDAT =[0/0/0])| (STRDAT < THIS_STRDAT & ENDDAT > THIS_ENDDAT)
            If NETPAYAMT < 0
              NEGAT+=1
            Endif
            If NETPAYAMT > 0
              POSAT+=1
            Endif
            If NETPAYAMT = 0
              PZAT+=1
            Endif
            If PAYOUTAMT <> 0
              PAYOUTAT+=1
            Endif
          Else
            If STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
              If NETPAYAMT < 0
                NEGNT+=1
              Endif
              If NETPAYAMT > 0
                POSNT+=1
              Endif
              If NETPAYAMT = 0
                PZNT+=1
              Endif
              If PAYOUTAMT <> 0
                PAYOUTNT+=1
              Endif
            Else
              If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
                If NETPAYAMT < 0
                  NEGCT+=1
                Endif
                If NETPAYAMT > 0
                  POSCT+=1
                Endif
                If NETPAYAMT = 0
                  PZCT+=1
                Endif
                If PAYOUTAMT <> 0
                  PAYOUTCT+=1
                Endif
              Else
                If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT < THIS_STRDAT
                  If NETPAYAMT < 0
                    NEGOT+=1
                  Endif
                  If NETPAYAMT > 0
                    POSOT+=1
                  Endif
                  If NETPAYAMT = 0
                    PZOT+=1
                  Endif
                  If PAYOUTAMT <> 0
                    PAYOUTOT+=1
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
    Endif
    CTRNUM = [F:HRCTR]CTRNUM
  Next

  Read [F:CPYREC]CPYREC0 = [F:FGR]CPY;GUSER
  If !fstat
    [F:CPYREC]NEGNW = NEGNW
    [F:CPYREC]NEGAT = NEGAT
    [F:CPYREC]NEGNT = NEGNT
    [F:CPYREC]NEGCT = NEGCT
    [F:CPYREC]NEGOT = NEGOT

    [F:CPYREC]POSNW = POSNW
    [F:CPYREC]POSAT = POSAT
    [F:CPYREC]POSNT = POSNT
    [F:CPYREC]POSCT = POSCT
    [F:CPYREC]POSOT = POSOT

    [F:CPYREC]PZNW = PZNW
    [F:CPYREC]PZAT = PZAT
    [F:CPYREC]PZNT = PZNT
    [F:CPYREC]PZCT = PZCT
    [F:CPYREC]PZOT = PZOT

    [F:CPYREC]PAYOUTNW = PAYOUTNW
    [F:CPYREC]PAYOUTAT = PAYOUTAT
    [F:CPYREC]PAYOUTNT = PAYOUTNT
    [F:CPYREC]PAYOUTCT = PAYOUTCT
    [F:CPYREC]PAYOUTOT = PAYOUTOT
    Rewrite [F:CPYREC]
  Endif




 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$PAYMENTS
Trbegin [CPYREC]
  Local Decimal PAYCCS
  Local Decimal PAYEAR
  Local Decimal PAYDED
  Local Decimal PAYRPT
  Local Date STRDAT, ENDDAT
  Local Date THIS_STRDAT,THIS_ENDDAT
  Local Integer ITAXYEAR
  Local Integer ITAXMON
  Local Char BULNUM(30)
  Local Char CTRNUM(30)

#initialize
  PAYCCS = 0
  PAYEAR = 0
  PAYDED = 0
  PAYRPT = 0
  CTRNUM = ''
  BULNUM = ''
  ITAXYEAR = val(TAXYEAR)
  ITAXMON = val(TAXMON)
  STRDAT = [0/0/0] : ENDDAT = [0/0/0]
  THIS_STRDAT = [0/0/0] : THIS_ENDDAT = [0/0/0]

  CRITERE1 = ""
  If TAXYEAR<>"" : CRITERE1 -= " [F:HRPEOD]PERYEA="+TAXYEAR    : Endif
  If TAXMON<>"" : CRITERE1 -= "& [F:HRPEOD]TAXMON="+TAXMON    : Endif


If [L]POP<>""
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA  & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
  Link [HRCTR] With
&   [VEP]VEP0(1) = [F:HRCTR]REFNUM
& , [HRPEOD]HRPEOD1 = [VEP]PERCOD;[VEP]PYRDAT
& , [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:VEP]CTRNUM =[F:HRCTR]CTRNUM & [F:VEP]CTRDAT =[F:HRCTR]CTRDAT & [F:VEP]PERYEA = [F:HRPEOD]PERYEA
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif

PAYMENTTYP = func AFNC.PARAM("NPPAYTP",[F:VEP]LEG)

  For [LNK]
    PAYEAR = 0
    PAYDED = 0
    PAYCCS = 0
    PAYRPT = 0
    Link [HSP] With
&     [RGTQ]RUB = [HSP]RUB
&     ,[RIB]RIB0(1) = [HSP]EMP
&   As [LNKRUB]
&   Where [F:HSP]CTRNUM =[F:HRCTR]CTRNUM & [F:HSP]EMP =[F:HRCTR]REFNUM & [F:HSP]BUL = [F:VEP]BUL & [F:RGTQ]LEG = [F:VEP]LEG  & [F:RIB]TYPPAY = PAYMENTTYP
&   Order By [F:HSP]CTRNUM;[F:HSP]BUL;[F:RGTQ]RPTGRP Asc
#& ([F:RGTQ]RPTGRP = 'EAR' | [F:RGTQ]RPTGRP = 'DED' | [F:RGTQ]RPTGRP = 'CCS')


      RUBEAR = 0
      RUBDED = 0

      For [LNKRUB]
        If [F:RGTQ]RPTGRP = 'EAR' & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2))
          RUBEAR+=[F:HSP]AMT
        Endif

        If [F:RGTQ]RPTGRP = 'DED' &  (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2))
          RUBDED+=[F:HSP]AMT
        Endif
      Next

      NETPAYAMT = (RUBEAR-RUBDED)

    For [LNKRUB]
      If NETPAYAMT <> 0 Then
        If CTRNUM <> [F:HSP]CTRNUM Then
          If BULNUM <> [F:HSP]BUL Then
            Filter [F:CPYRECM] Where CPY=[F:FGR]CPY & USR = GUSER & MODSTL = [F:RIB]MODSTL
            Read [F:CPYRECM]CPYRECM0 Last
            If rowcount([F:CPYRECM])>0 Then
              PAYCNT = [F:CPYRECM]MODCNT
              PAYCNT+=1
              [F:CPYRECM]MODCNT = PAYCNT
              Rewrite [F:CPYRECM]
              If fstat
                GOK = 0 : Call FSTA("CPYRECM") From GLOCK : Break 2
              Endif
            Else
              PAYCNT=1
              Raz [F:CPYRECM]
              [F:CPYRECM]CPY = [F:FGR]CPY
              [F:CPYRECM]USR = GUSER
              [F:CPYRECM]MODCNT = PAYCNT
              [F:CPYRECM]MODSTL = [F:RIB]MODSTL
              Call LECTEXTRA([F:CPYRECM]MODDESC, "ATABDIV","SHODES",'10387',[F:RIB]MODSTL) From ATEXTRA
              Write [F:CPYRECM]
            Endif
            BULNUM = [F:HSP]BUL
          Endif
          CTRNUM = [F:HSP]CTRNUM
        Endif
      Endif

      If [F:RGTQ]RPTGRP = 'EAR' & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2)) Then
        Filter [F:CPYRECM] Where CPY=[F:FGR]CPY & USR = GUSER & MODSTL = [F:RIB]MODSTL
        Read [F:CPYRECM]CPYRECM0 Last
        If rowcount([F:CPYRECM])>0 Then

          PAYEAR = [F:CPYRECM]MODEAR + [F:HSP]AMT
          [F:CPYRECM]MODEAR = PAYEAR
          Rewrite [F:CPYRECM]
          If fstat
            GOK = 0 : Call FSTA("CPYRECM") From GLOCK : Break 2
          Endif
        Else
          Raz [F:CPYRECM]
          [F:CPYRECM]CPY = [F:FGR]CPY
          [F:CPYRECM]USR = GUSER
          [F:CPYRECM]MODEAR = [F:HSP]AMT
          [F:CPYRECM]MODSTL = [F:RIB]MODSTL
          Call LECTEXTRA([F:CPYRECM]MODDESC, "ATABDIV","SHODES",'10387',[F:RIB]MODSTL) From ATEXTRA
          Write [F:CPYRECM]
        Endif
      Endif
      If [F:RGTQ]RPTGRP = 'DED' & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2)) Then
        Filter [F:CPYRECM] Where CPY=[F:FGR]CPY & USR = GUSER & MODSTL = [F:RIB]MODSTL
        Read [F:CPYRECM]CPYRECM0 Last
        If rowcount([F:CPYRECM])>0 Then
          PAYDED = [F:CPYRECM]MODDED + [F:HSP]AMT
          [F:CPYRECM]MODDED = PAYDED
          Rewrite [F:CPYRECM]
          If fstat
            GOK = 0 : Call FSTA("CPYRECM") From GLOCK : Break 2
          Endif
        Else
          Raz [F:CPYRECM]
          [F:CPYRECM]CPY = [F:FGR]CPY
          [F:CPYRECM]USR = GUSER
          [F:CPYRECM]MODDED = [F:HSP]AMT
          [F:CPYRECM]MODSTL = [F:RIB]MODSTL
          Call LECTEXTRA([F:CPYRECM]MODDESC, "ATABDIV","SHODES",'10387',[F:RIB]MODSTL) From ATEXTRA
          Write [F:CPYRECM]
        Endif
      Endif
      If [F:RGTQ]RPTGRP = 'CCS' & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2)) Then
        Filter [F:CPYRECM] Where CPY=[F:FGR]CPY & USR = GUSER & MODSTL = [F:RIB]MODSTL
        Read [F:CPYRECM]CPYRECM0 Last
        If rowcount([F:CPYRECM])>0 Then
          PAYCCS = [F:CPYRECM]MODCCS + [F:HSP]AMT
          [F:CPYRECM]MODCCS = PAYCCS
          Rewrite [F:CPYRECM]
          If fstat
            GOK = 0 : Call FSTA("CPYRECM") From GLOCK : Break 2
          Endif
        Else
          Raz [F:CPYRECM]
          [F:CPYRECM]CPY = [F:FGR]CPY
          [F:CPYRECM]USR = GUSER
          [F:CPYRECM]MODCCS = [F:HSP]AMT
          [F:CPYRECM]MODSTL = [F:RIB]MODSTL
          Call LECTEXTRA([F:CPYRECM]MODDESC, "ATABDIV","SHODES",'10387',[F:RIB]MODSTL) From ATEXTRA
          Write [F:CPYRECM]
        Endif
      Endif
      If [F:RGTQ]RUB = PRNTRUB & (([F:RGTQ]AMTIND ='1' & [F:HSP]TYP = 1) or ([F:RGTQ]AMTIND ='2' & [F:HSP]TYP = 2)) Then
        Filter [F:CPYRECM] Where CPY=[F:FGR]CPY & USR = GUSER & MODSTL = [F:RIB]MODSTL
        Read [F:CPYRECM]CPYRECM0 Last
        If rowcount([F:CPYRECM])>0 Then
          PAYRPT = [F:CPYRECM]MODRPT + [F:HSP]AMT
          [F:CPYRECM]MODRPT = PAYRPT
          Rewrite [F:CPYRECM]
          If fstat
            GOK = 0 : Call FSTA("CPYRECM") From GLOCK : Break 2
          Endif
        Else
          Raz [F:CPYRECM]
          [F:CPYRECM]CPY = [F:FGR]CPY
          [F:CPYRECM]USR = GUSER
          [F:CPYRECM]MODRPT = [F:HSP]AMT
          [F:CPYRECM]MODSTL = [F:RIB]MODSTL
          Call LECTEXTRA([F:CPYRECM]MODDESC, "ATABDIV","SHODES",'10387',[F:RIB]MODSTL) From ATEXTRA
          Write [F:CPYRECM]
        Endif
      Endif

    Next
  Next


 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return



$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto PAYSLIP_STATUS : Endif
Return

$AB_TR2
Rollback
Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

