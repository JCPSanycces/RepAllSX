#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SITSIG","SITINTEGR",3,"") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
Endcase
Return

######################################################################################
$INIT
Gosub SI_CONTEXT From SIXFONCTION
Return

######################################################################################
$EXEC
If !clalev([F:ADS]) : Local File ADOSSIER  [ADS] : Endif
Global Decimal GCOEFTAB : GCOEFTAB = 0.5

Local Char    ORDSYS(250), REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Integer K
Local Integer NBFIC, NBFIC2, NFIC
Local Integer MAXFIC
Local Integer NBCHAMP
Local Integer NBINDEX
Local Char    SAVIFS(5), SAVIRS(5)
Local Integer SAVIUM
Local Integer NBCHPBIN, FLGINDEX
Local Char    CHPBIN(60)(0..100)
Local Integer NBFICXI : Raz NBFICXI

MAXFIC  = 500
Local Char    LISFIC(100)(1..MAXFIC)
Local Char    FICINT(100)                                    : # Nom table intégrale
Local Char    FICX3(GLONATB)                                 : # Nom table X3
Local Char    CODFLD(50), TYPFLD(10), LNGFLD(10), DIMFLD(10) : # Champs fichiers ascii .srf
Local Char    INDEX(10), CMPIND(150), HOMONY(10)             : # Champs fichiers ascii .ind 
Local Char    XXX(10)
Local Char    TIT(250)

Local Char    REPERTOIRE(GDIMFIC) : REPERTOIRE = [M:SIG]FIC
Local Integer OPTION              : OPTION     = [M:SIG]OPT
Local Char    EXTENSION(10)       : EXTENSION  = "srf"

Call MACHINE(REPERTOIRE,MACHINE,REPERT) From ORDSYS
ORDSYS = 'lsadx "'+REPERT+'"'-EXTENSION

Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS
 
If NBFIC<=0 : End : Endif

# Automatisation du type de données AVA à 12
GOK=1
Gosub TYPAVA
If !GOK : Return : Endif

# Création d'un code activité spécifique XXI
GOK=1
Gosub ACTXXI
If !GOK : Return : Endif

If !clalev([F:ATB]) : Local File =SI_DOSSIER+".ATABLE"    [ATB] : Endif 
If !clalev([F:ATZ]) : Local File =SI_DOSSIER+".ATABZON"   [ATZ] : Endif 
If !clalev([F:ATI]) : Local File =SI_DOSSIER+".ATABIND"   [ATI] : Endif 
If !clalev([F:ATY]) : Local File =SI_DOSSIER+".ATYPE"     [ATY] : Endif
If !clalev([F:ANX]) : Local File =SI_DOSSIER+".AINDEX"    [ANX] : Endif

# Migration Intégrale => X3 : Création des tables X3
TIT = SI_MES(140)-"=>"-mess(SI_PRODUIT,2902,1)-":"-SI_MES(141)-mess(SI_PRODUIT,2902,1)

Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 

#Ddm47307 -
Raz [L]NBFIC2
# nombre de tables trouvées
Call ECR_TRACE(SI_MES(259)-":"-num$(NBFIC),0) From GESECRAN


# Migration Intégrale => X3
Call OUVRE_VLC(SI_MES(140)-"=>"-mess(SI_PRODUIT,2902,1),"","") From GESECRAN 

GOK=1
Read [ADS]DOSSIER = SI_DOSSIER
If OPTION=2
 For NFIC = 1 To NBFIC
  Gosub NOMFIC
  If filinfo(filpath("FIL",[L]FICX3,"fde",SI_DOSSIER),0)>0
   Call SUPP([L]FICX3,GOK)
   If !GOK : Break : Endif
   # Reprise des données
   Call AFF_VLC(SI_MES(144),LISFIC(NFIC)-"("+FICX3+")") From GESECRAN
   Call MAJDDB([L]FICX3,REPERTOIRE,LISFIC(NFIC))
   # Mise à jour X3CAT
   Case [L]FICX3
    When "XIPLACBANA" : Gosub INI_X3CAT1 From SIXCCE
    When "XIHISANA"   : Gosub INI_X3CAT2 From SIXCCE
    When "XIBROCBANA" : Gosub INI_X3CAT3 From SIXCCE
    When "XIPLACBGNR" : Gosub INI_X3CLE
    When "XIMODRGL"   : Gosub INI_X3RGL
    When "XIJRN"      : Gosub INI_X3JRN
   Endcase
  Endif
 Next
Else
 # Création des tables
 Gosub TR_CR_ATBX3
 If GOK
  Call DEBTRANS From GLOCK
  For NFIC = 1 To NBFIC
   Gosub NOMFIC
   If !find(FICX3,"XILAAFMCAL","XILAVFMCAL") #Ddm47176
    # Validation des tables
    Call AFF_VLC(SI_MES(142),LISFIC(NFIC)-"("+FICX3+")") From GESECRAN
    Call MAJTAB([L]FICX3,1) From DOSTAB
    # Suppression des données
    Call AFF_VLC(SI_MES(143),FICX3) From GESECRAN
    Call SUPP([L]FICX3,GOK)
    If !GOK : Break : Endif
    # Reprise des données
    Call AFF_VLC(SI_MES(144),LISFIC(NFIC)-"("+FICX3+")") From GESECRAN
    Call MAJDDB([L]FICX3,REPERTOIRE,LISFIC(NFIC))
   Endif
  Next
  # Mise à jour X3CAT
  For NFIC = 1 To NBFIC
   Gosub NOMFIC
   Case [L]FICX3
    When "XIPLACBANA" : Gosub INI_X3CAT1 From SIXCCE
    When "XIHISANA"   : Gosub INI_X3CAT2 From SIXCCE
    When "XIBROCBANA" : Gosub INI_X3CAT3 From SIXCCE
    When "XIPLACBGNR" : Gosub INI_X3CLE
    When "XIMODRGL"   : Gosub INI_X3RGL
    When "XIJRN"      : Gosub INI_X3JRN
   Endcase
  Next
 Endif
Endif
Gosub VERIF

Call FERME_VLC From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return


######################################################################################
$TR_CR_ATBX3
Trbegin [ATB], [ATZ], [ATI]

 ## 1) On efface les tables Intégrales créées dans X3 au cas où elles existeraient déjà...
 ## Les tables intégrale ont toutes le préfixe 'XI'
 For NFIC=1 To NBFIC
  Gosub NOMFIC
  # Suppression table
  Call AFF_VLC(mess(53,125,1),LISFIC(NFIC)-"("+FICX3+")") From GESECRAN
  Delete [ATB] Where [F:ATB]CODFIC=[L]FICX3
  If fstat
   # Erreur en suppression table
   GOK = 0 : Call ECR_TRACE(SI_MES(145)-FICX3,1) From GESECRAN : Break
  Endif
  Delete [ATZ] Where [F:ATZ]CODFIC=[L]FICX3
  If fstat
   # Erreur en suppression table
   GOK = 0 : Call ECR_TRACE(SI_MES(145)-FICX3,1) From GESECRAN : Break
  Endif
  Delete [ATI] Where [F:ATI]CODFIC=[L]FICX3
  If fstat
   # Erreur en suppression table
   GOK = 0 : Call ECR_TRACE(SI_MES(145)-FICX3,1) From GESECRAN : Break
  Endif
 Next
 If GOK<0   : Goto ROLL_TR_ATBX3
 Elsif !GOK : Goto AB_TR_ATBX3
 Endif

 # Si test de migration partielle consécutive, attention à l'abréviation de la table
 Filter [ATB] Where left$([F:ATB]CODFIC,2)="XI"
 For [ATB]
  If  val([F:ATB]ABRFIC)>[L]NBFICXI : [L]NBFICXI=val([F:ATB]ABRFIC) : Endif
 Next
 Filter [ATB]
 #
  
 If [L]NBFICXI+NBFIC>999
  # Importation impossible
  GOK = 0 : Call ECR_TRACE(SI_MES(147)-"("+num$([L]NBFICXI+NBFIC)-mess(1,16,1)+")",1) From GESECRAN : Goto AB_TR_ATBX3
 Endif
  
 ## 2) On crée les tables Intégrale dans X3
 ## Nom de tables : XI + les 4 premiers caractères du nom de table Intégrale + les 4 derniers 
 For NFIC=1 To NBFIC
  Gosub NOMFIC
  If !find(FICX3,"XILAAFMCAL","XILAVFMCAL")  #Ddm47176
   # Création des tables
   Call AFF_VLC(SI_MES(141),LISFIC(NFIC)-"("+FICX3+")") From GESECRAN
   ## 1) On s'occupe de la création de l'en-tête de table (ATABLE)
   Raz [F:ATB]
   [F:ATB]ABRFIC = num$(NFIC+[L]NBFICXI)
   [F:ATB]CODFIC = [L]FICX3
   [F:ATB]CODACT = "XXI"
   [F:ATB]MODULE = 16
   [F:ATB]TYPFIC = 1
   [F:ATB]CRE    = 1
   [F:ATB]TYPDLV = 1
   [F:ATB]NBENREG = 10000
   Write [ATB]
   If fstat
    # Erreur en création table
    GOK = 0 : Call ECR_TRACE(SI_MES(146)-FICX3-"("+LISFIC(NFIC)+")",1) From GESECRAN : Break
   Else
    # Création table
    Call ECR_TRACE(right$(SI_MES(146),11)-FICX3-"("+LISFIC(NFIC)+")",0) From GESECRAN
    [L]NBFIC2 +=1
   Endif
   ## 3) On s'occupe maintenant des champs de la table (ATABZON)
   FICHIER = REPERTOIRE+"/"+LISFIC(NFIC)+".srf"
   Openi FICHIER
   adxifs = ";"
   adxirs = chr$(13)+chr$(10)
   adxium = GUTF8
   NBCHAMP = 0  : NBCHPBIN = 0
   Repeat
    Rdseq CODFLD, TYPFLD, LNGFLD, DIMFLD, XXX
    If CODFLD<>""
     NBCHAMP += 1
     Raz [F:ATZ]
     [F:ATZ]CODFIC  = [L]FICX3
     [F:ATZ]NUMLIG  = NBCHAMP
     [F:ATZ]CODZONE = ctrans([L]CODFLD,"_","")
     If find([F:ATZ]CODZONE,"PRD","EXP","NAP","REB","VAR") :  [F:ATZ]CODZONE+="9" : Endif  # Mots réservés X3
     [F:ATZ]CODTYP  = [L]TYPFLD
     ## Pb NUMSIRET
     If [F:ATZ]CODZONE="NUMSIRET"
      [F:ATZ]CODTYP = "A"
     Endif
     If [F:ATZ]CODTYP = "DCB"
      K = instr(1,LNGFLD,",")
      If K
       #LNGFLD = left$(LNGFLD,K-1)+"."+right$(LNGFLD,K+1)
      [F:ATZ]LONG    = val(left$(LNGFLD,K-1)+"."+right$(LNGFLD,K+1))
      Endif
     ## Voir avec l'équipe Intégrale...
     Elsif [F:ATZ]CODTYP = "B"
      [F:ATZ]CODTYP  = "A"
      [F:ATZ]LONG    = val([L]LNGFLD)*2
      CHPBIN(NBCHPBIN) =  [L]CODFLD
      If NBCHPBIN<100 : NBCHPBIN+=1 : Endif
     Elsif [F:ATZ]CODTYP = "D" & val([L]LNGFLD)<>8
      [F:ATZ]CODTYP  = "L"
      [F:ATZ]LONG    = val([L]LNGFLD)
     ##
     Elsif [F:ATZ]CODTYP<>"D"
      [F:ATZ]LONG    = val([L]LNGFLD)
     Endif
     If [L]DIMFLD = ""
      [F:ATZ]DIME = 1
     Else
      [F:ATZ]DIME = val([L]DIMFLD)
     Endif
     [F:ATZ]NUMLIG = NBCHAMP
     If [L]FICX3="XIMODRGL" & [F:ATZ]CODZONE="CLERGL"     :  [F:ATZ]LONG+=1 : Endif
     If [L]FICX3="XILIGOF"  & [F:ATZ]CODZONE="DAT1NUMNMC" :  [F:ATZ]CODTYP="L" : [F:ATZ]LONG=8 : Endif    #DdM48013
     Write [ATZ]
     If fstat
      # Erreur en création champ
      GOK = 0 : Call ECR_TRACE(SI_MES(148)-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
     Endif
    Endif  
   Until fstat<>0
   ## On rajoute à la fin de chaque table un flag 'Repris'
   NBCHAMP += 1
   Raz [F:ATZ]
   [F:ATZ]CODFIC  = [L]FICX3
   [F:ATZ]NUMLIG  = NBCHAMP
   [F:ATZ]CODZONE = "FLGREP"
   [F:ATZ]CODTYP  = "M"
   [F:ATZ]NOLIB   = 1  
   [F:ATZ]LONG    = 4
   [F:ATZ]DIME    = 1
   [F:ATZ]NUMLIG = NBCHAMP
   Write [ATZ]
   If fstat
    # Erreur en création champ
    GOK = 0 : Call ECR_TRACE(SI_MES(148)-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
   Endif
   ## Rajout également d'un champ X3CLE (servira pour traiter les problèmes de clés liés à la codification)
   NBCHAMP += 1
   Raz [F:ATZ]
   [F:ATZ]CODFIC  = [L]FICX3
   [F:ATZ]NUMLIG  = NBCHAMP
   [F:ATZ]CODZONE = "X3CLE"
   [F:ATZ]CODTYP  = "A"
   [F:ATZ]LONG    = 30
   [F:ATZ]DIME    = 1
   [F:ATZ]NUMLIG = NBCHAMP
   Write [ATZ]
   If fstat
    # Erreur en création champ
    GOK = 0 : Call ECR_TRACE(SI_MES(148)-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
   Endif
   ## & d'un champ X3DAT (servira uniquement pour les tables XIHISCBGNR, XIHISANA, XIBROCBGNR, XIBROCBANA)
   If [L]FICX3="XIHISCBGNR" | [L]FICX3="XIHISANA" | [L]FICX3="XIBROCBGNR" | [L]FICX3="XIBROCBANA"
    NBCHAMP += 1
    Raz [F:ATZ]
    [F:ATZ]CODFIC  = [L]FICX3
    [F:ATZ]NUMLIG  = NBCHAMP
    [F:ATZ]CODZONE = "X3DAT"
    [F:ATZ]CODTYP  = "D"
    [F:ATZ]DIME    = 1
    [F:ATZ]NUMLIG = NBCHAMP
    Write [ATZ]
    If fstat
     GOK = 0 : Call ECR_TRACE("Erreur en création champ"-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
    Endif
   Endif
   ## & d'un champ X3CAT (servira uniquement pour les tables XIPLACBANA & XIHISANA)
   If [L]FICX3="XIPLACBANA" | [L]FICX3="XIHISANA" | [L]FICX3="XIBROCBANA"
    NBCHAMP += 1
    Raz [F:ATZ]
    [F:ATZ]CODFIC  = [L]FICX3
    [F:ATZ]NUMLIG  = NBCHAMP
    [F:ATZ]CODZONE = "X3CAT"
    [F:ATZ]CODTYP  = "L"
    [F:ATZ]LONG    = 1
    [F:ATZ]DIME    = 1
    [F:ATZ]NUMLIG = NBCHAMP
    Write [ATZ]
    If fstat
     # Erreur en création champ
     GOK = 0 : Call ECR_TRACE(SI_MES(148)-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
    Endif
   Endif

   ## 3) Enfin, on s'occupe des index de table (ATABIND)
   FICHIER = REPERTOIRE+"/"+LISFIC(NFIC)+".ind"
   Openi FICHIER
   adxifs = ";"
   adxirs = chr$(13)
   adxium = GUTF8
   NBINDEX = 0 : FLGINDEX = 0 
 
   Repeat
    Rdseq INDEX, CMPIND, HOMONY, XXX
    If INDEX<>""
      NBINDEX += 1
     # Tous les index ne sont pas crées.
     If NBINDEX=1 or
&      (NBINDEX=2 and find([L]FICX3,"XIHISCBGNR","XIHISANA","XIECH","XIBROCBGNR","XIBROCBANA","XIMVTSKHIS","XIARTDPO")) or
&      (NBINDEX=5 and [L]FICX3="XIMVTSRLOT") or
&      (NBINDEX=10 and [L]FICX3="XIART")
  
      Raz [F:ATI]
 
      # Condition pour supprimer les index contenant des champs binaire.
     If !NBCHPBIN
       FLGINDEX = 1
      Else
       FLGINDEX = 1
       For I=0 To NBCHPBIN-1
        If instr(1,[L]CMPIND,"+"+CHPBIN(I)+"+") : FLGINDEX = 0 : Break : Endif
        If instr(1,[L]CMPIND,"+"+CHPBIN(I))     : FLGINDEX = 0 : Break : Endif
        If instr(1,[L]CMPIND,CHPBIN(I)+"+")     : FLGINDEX = 0 : Break : Endif
       Next
      Endif
      If FLGINDEX
       [F:ATI]CODFIC   = [L]FICX3
       [F:ATI]NUMLIG   = NBINDEX
       [F:ATI]CODIND   = "IND"+num$(NBINDEX-1)
       [F:ATI]DESCRIPT = ctrans([L]CMPIND,"_","")
       # Mots réservés X3
       If find(left$([F:ATI]DESCRIPT,4),"PRD+","EXP+","NAP+","REB+","VAR+")
        [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,3)+"9"+right$([F:ATI]DESCRIPT,len([F:ATI]DESCRIPT)+2)
       Elsif find(right$([F:ATI]DESCRIPT,len([F:ATI]DESCRIPT)-3),"+PRD","+EXP","+NAP","+REB","+VAR")
        [F:ATI]DESCRIPT += "9"
       Else 
        For WRDX3 = "PRD","EXP","NAP","REB","VAR"
         I = instr(1,[F:ATI]DESCRIPT,"+"+WRDX3+"+") 
         If I
          [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,I)+WRDX3+"9+"+right$([F:ATI]DESCRIPT,I+5)
         Endif
        Next
       Endif
       # Suppresion du champs COMPTEURSAGE (champ=12 caractères)
       I = instr(1,[F:ATI]DESCRIPT,"COMPTEURSAGE") 
       If I>0
        If I=1
         # Champs COMPTEURSAGE est en début de zone
         [F:ATI]DESCRIPT = right$([F:ATI]DESCRIPT,14)
        Elsif len([F:ATI]DESCRIPT)-11=I
         # Champs COMPTEURSAGE est en fin de zone
         [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,I-2)
        Else
         # Champs COMPTEURSAGE est en mileu de zone
         [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,I-2)+right$([F:ATI]DESCRIPT,I+12)
        Endif
       Endif
      
       [F:ATI]HOMONYM  = val([L]HOMONY)
       Write [ATI]
       If fstat
        # Erreur en création index
        GOK = 0 : Call ECR_TRACE(SI_MES(149)-"IND"+num$(NBINDEX-1)-"("+FICX3+")",1) From GESECRAN : Break 2
       Endif
      Endif
     Endif
    Endif
   Until fstat<>0

   # Cas particulier pour XIMVTSRLOT
   If [L]FICX3="XIMVTSRLOT"
     Raz [F:ATI]
     [F:ATI]CODFIC   = [L]FICX3
     [F:ATI]NUMLIG   = 2
     [F:ATI]CODIND   = "IND12"
     [F:ATI]DESCRIPT = "CODART+NUMSERLOT+PFX+X3CLE+SENMVT+SLDQTE"
     [F:ATI]HOMONYM  = 2
     Write [ATI]
     If fstat
      # Erreur en création index
      GOK = 0 : Call ECR_TRACE(SI_MES(149)-"IND"+num$(NBINDEX-1)-"("+FICX3+")",1) From GESECRAN : Break 2
     Endif
   Endif
  Endif

 Next

 If GOK<0   : Goto ROLL_TR_ATBX3
 Elsif !GOK : Goto AB_TR_ATBX3
 Endif
  
 Call ECR_TRACE("",0) From GESECRAN 
 # nombre de tables créees
 Call ECR_TRACE(SI_MES(150)-":"-num$([L]NBFIC2),0) From GESECRAN

Commit
Return

$AB_TR_ATBX3
Rollback
Return

$ROLL_TR_ATBX3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CR_ATBX3 : Endif

$NOMFIC  
FICINT = ctrans(LISFIC(NFIC),"_","")
FICX3 = "XI"+left$(FICINT,4)
FICX3+= string$(len(FICINT)>7,right$(FICINT,len(FICINT)-3))+string$(len(FICINT)=7,right$(FICINT,len(FICINT)-2))
&       +string$(len(FICINT)=6,right$(FICINT,len(FICINT)-1))+string$(len(FICINT)=5,right$(FICINT,len(FICINT)))
Return


######################################################################################
Subprog MAJDDB(TBL,RPT,FIC)
Value Char TBL()
Value Char RPT()
Value Char FIC()
Local Integer NBSEQ, LONG, LNGCHP, FLGEND, NBENR, FLGOK, VIDE
Local Char    FICHIER(GDIMFIC), CTLX3(250)

If !clalev([F:ATZ])  : Local File ATABZON   [ATZ]  : Endif 
If !clalev([F:SIT])  : Local File SITRACOD  [SIT]  : Endif
If !clalev([F:XTBL]) : Local File =[L]TBL   [XTBL] : Endif 

Raz FLGEND, NBENR, LONG

# Longueur d'un enregsitrement
For [ATZ]NUMLIG Where CODFIC=[L]TBL
 If [ATZ]CODZONE="FLGREP" : Break: Endif
  Case  [F:ATZ]CODTYP
   When "D"     :     LONG += 8
   When "DCB"   :     LONG += fix([F:ATZ]LONG)+1+val(right$(num$([F:ATZ]LONG),len(num$([F:ATZ]LONG))))
   When Default :     LONG += [F:ATZ]LONG
  Endcase
Next
If [L]TBL="XIMODRGL" : LONG-=1 : Endif
If !LONG
 # Aucune donnée reprise
 Call ECR_TRACE(SI_MES(151)-":"-TBL,0) From GESECRAN : End
Endif

adxifs = ""
adxirs = chr$(13)+chr$(10)
adxium = GASCII

LONG = LONG + 2        # Ajout de 2 cractères pour la fin d'enregistrement (adxirs)
Local Schar BUFFER(1)(1..LONG)

FICHIER = RPT+"/"+FIC+".dta"
GOK = 1
Trbegin [XTBL]
Openi FICHIER
Getseq LONG,BUFFER
While !fstat
 Gosub TRT1
 Getseq LONG,BUFFER
 If !GOK : Break : Endif
Wend
If !GOK : Rollback : End : Endif
FLGEND = 1 : Gosub TRT1
If !GOK : Rollback : End : Endif
Commit
# Données reprises... enregistrements crées
Call ECR_TRACE(SI_MES(152)-":"-TBL-"("+num$(NBENR)-mess(103,141,1)+")",0) From GESECRAN
End

$TRT1
#If !FLGEND & ascii([L]BUFFER(LONG))<>10
# Call ECR_TRACE("Problème de longueur d'enregistrement : "-TBL-"("+num$(LONG)+")",0) From GESECRAN 
# GOK=0 : Return
#Endif
NBSEQ=1 : GOK=1
Raz [F:XTBL]
Raz FLGOK, CTLX3, VIDE
For [ATZ]NUMLIG Where CODFIC=[L]TBL
 If [ATZ]CODZONE="FLGREP" : Break: Endif
 Case  [F:ATZ]CODTYP
  When "A"   :    
   Onerrgo ERR_A
    [L]LNGCHP = [F:ATZ]LONG
    If [L]TBL="XIMODRGL" & [ATZ]CODZONE="CLERGL" [L]LNGCHP-=1 : Endif
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With vireblc(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)),1)
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When "D"   :  
   [L]LNGCHP = 8
   Onerrgo ERR_D
    If len(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))=8
     Assign "[F:XTBL]"+[F:ATZ]CODZONE With sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))
     If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
    Endif
   Onerrgo
  When "DCB" :  
   Onerrgo ERR_DCB
    [L]LNGCHP = fix([F:ATZ]LONG)+1+val(right$(num$([F:ATZ]LONG),len(num$([F:ATZ]LONG))))
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With val(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When "L"  :
   [L]LNGCHP = [F:ATZ]LONG
   Onerrgo ERR_L
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With val(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When Default
   [L]LNGCHP = [F:ATZ]LONG
   Onerrgo ERR
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo ERR
 Endcase
 NBSEQ += [L]LNGCHP
Next
# Contrôle de l'enregistrement et Initialisation du champs X3CLE
Onerrgo ERR_X3CLE
 If func SUBSIT.CTLCOD([L]TBL,"XTBL",[L]CTLX3)
  [F:XTBL]X3CLE = [L]CTLX3
 Else
  FLGOK=1
 Endif 
Onerrgo
If !FLGOK & VIDE
 Write [XTBL]
 If fstat
  # Erreur en reprise de données
  GOK = 0 : Call ECR_TRACE(SI_MES(153)-"("+TBL+")"-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 Endif
 NBENR+=1
Endif
Return

######################################################################################
Subprog SUPP(TBL,OK)
Value    Char TBL()
Variable Integer OK
OK = 1

If clalev([F:XTBL])=0 : Local File =[L]TBL  [XTBL] : Endif 

Trbegin [XTBL]
Delete [XTBL] Where 1=1
If fstat
 # Erreur en suppression de données
 OK = 0 : Call ECR_TRACE(SI_MES(154)-TBL,1) From GESECRAN : Rollback
Endif
Commit 
End

######################################################################################
$ERR_A
If GTRACE<>""
 # Erreur en récupération (A) 
 Call ECR_TRACE(SI_MES(155)-"(A) :"-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),-1) From GESECRAN
Endif
Resume

$ERR_D
If GTRACE<>""  # & !([F:ATZ]CODZONE="DAT1NUMNMC" & TBL="XILIGOF")
 # Erreur en récupération (D)
 Call ECR_TRACE(SI_MES(155)-"(D) :"-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),-1) From GESECRAN
Endif
Resume

$ERR_DCB
If GTRACE<>""
 # Erreur en récupération (DCB)
 Call ECR_TRACE(SI_MES(155)-"(DCB) :"-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),-1) From GESECRAN
Endif
Resume

$ERR_L
If GTRACE<>""
 # Erreur en récupération (N)
 Call ECR_TRACE(SI_MES(155)-"(N) :"-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),-1) From GESECRAN
Endif
Resume

$ERR
If GTRACE<>""
 # Erreur en récupération
 Call ECR_TRACE(SI_MES(155)-": "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),-1) From GESECRAN
Endif
Resume

$ERR_X3CLE
If GTRACE<>""
 # Erreur en récupération X3CLE
 Call ECR_TRACE(SI_MES(155)-"(X3CLE) :"-TBL,0) From GESECRAN : FLGOK=1
Endif
Resume

######################################################################################
$TYPAVA
If !clalev([F:ATY]) : Local File =SI_DOSSIER+".ATYPE"     [ATY] : Endif
Read [ADS]DOSSIER = SI_DOSSIER
If !clalev([F:AT2]) : Local File =[F:ADS]DOSREF+".ATYPE"   [AT2] : Endif

Read [ATY]CODTYP = "AVA"
If !fstat & [F:ATY]LNGTYP<12

 Local File =SI_DOSSIER+".ATABLE"    [ATB]
 Local File =SI_DOSSIER+".ATABZON"   [ATZ]
 Local File =SI_DOSSIER+".ATABIND"   [ATI]
 Local File =SI_DOSSIER+".AINDEX"    [ANX]

 Trbegin [ATY], [AT2]
 Update [ATY] Where CODTYP="AVA" With LNGTYP=12, FORTYP="A11u"
 If fstat
  # Type de donnée ... : Erreur d'écriture
  Call ECR_TRACE(mess(21,115,1)-"AVA : "-SI_DOSSIER-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Gosub TR_AVA : Return
 Endif
 Read [AT2]CODTYP = "AVA"
 If !fstat & [F:AT2]LNGTYP<12
  Update [AT2] Where CODTYP="AVA" With LNGTYP=12, FORTYP="A11u"
  If fstat
   # Type de donnée ... : Erreur d'écriture
   Call ECR_TRACE(mess(21,115,1)-"AVA : "-[F:ADS]DOSREF-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Gosub TR_AVA : Return
  Endif
 Endif

 Commit
 
 Call TEMPON("V") From GESECRAN
 Call VALIDATION(SI_DOSSIER) From SUBATY
 Call MAJFIC("ATABZON",SI_DOSSIER,1) From VALDIC
 Call MAJFIC("AMSKZON",SI_DOSSIER,1) From VALDIC
 Call MAJFIC("AMSKACT",SI_DOSSIER,1) From VALDIC
 Call MAJFIC("AMSKPAR",SI_DOSSIER,1) From VALDIC
 Call VALID("ATB2",SI_DOSSIER,1,GLANGUE,1,GOK) From VALMSK
 Call VALID("AMK2",SI_DOSSIER,1,GLANGUE,1,GOK) From VALMSK
 Call TEMPOFF From GESECRAN

 If clalev([F:ATB]) : Close Local File   [ATB] : Endif
 If clalev([F:ATZ]) : Close Local File   [ATZ] : Endif
 If clalev([F:ATI]) : Close Local File   [ATI] : Endif
 If clalev([F:ATY]) : Close Local File   [ATY] : Endif
 If clalev([F:AT2]) : Close Local File   [AT2] : Endif
 If clalev([F:ANX]) : Close Local File   [ANX] : Endif

Endif
Return

$TR_AVA
Rollback
Return

######################################################################################
$ACTXXI
If !clalev([F:ACV]) : Local File =SI_DOSSIER+".ACTIV"     [ACV] : Endif
If !clalev([F:ADA]) : Local File ADOSACT                  [ADA] : Endif

Local Integer WRI_OK

Read [ACV]CODACT = "XXI"
If !fstat
 WRI_OK=0
Else
 WRI_OK=1
Endif


Trbegin [ACV], [ADA]

[F:ACV]CODACT = "XXI"
[F:ACV]TYP    = 1 
[F:ACV]DEP    = 1 
[F:ACV]FLACT  = 2
[F:ACV]MODULE = 9

If WRI_OK
 Write [ACV]
Else
 Rewrite [ACV]
Endif
If fstat
 # Code activité ... : Erreur d'écriture
 Call ECR_TRACE(mess(14,115,1)-"XXI (ACTIV) : "-SI_DOSSIER-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Gosub TR_XXI : Return
Endif


Read [ADA]ADA0 = SI_DOSSIER;"XXI"
If !fstat
 WRI_OK=0
Else
 WRI_OK=1
Endif

[F:ADA]CODACT = "XXI"
[F:ADA]DOSSIER = SI_DOSSIER
[F:ADA]FLACT  = 2
[F:ADA]MODULE = 9

If WRI_OK
 Write [ADA]
Else
 Rewrite [ADA]
Endif
If fstat
 # Code activité ... : Erreur d'écriture
 Call ECR_TRACE(mess(14,115,1)-"XXI (ADOSACT) : "-SI_DOSSIER-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Gosub TR_XXI : Return
Endif

Commit
Return

$TR_XXI
Rollback
Return

######################################################################################
Subprog C_FIC(VALEUR)
Variable Char    VALEUR()

#-- Contrôle d'un répertoire
Local Integer OK : Raz OK
Call CTLFIC(2,VALEUR,GMESSAGE,OK)
If OK : mkstat=2 : End : Endif

#-- Est ce le bon répertoire...
Local Char    FICHIER(GDIMFIC) , FIC(GDIMFIC), REPERT(GDIMFIC), MACHINE(30)

Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS

Local Integer NBFIC  : Raz NBFIC
Local Integer MAXFIC : MAXFIC  = 500
Local Char    LISFIC(100)(1..MAXFIC)

Local Char    ORDSYS(250)
Local Char    EXTENSION(10) : EXTENSION = "srf"

ORDSYS = 'lsadx "'+REPERT+'"'-EXTENSION
Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS

If NBFIC<=0
 # Aucun fichier ASCII
 Call ERREUR(SI_MES(156)) From GESECRAN : mkstat=2 : End
Else
 OK = 2
 # Importation des tables Intégrale : xxx Tables
 Call OUINON(SI_MES(158)-" : "-num$(NBFIC)-mess(16,125,1),OK) From GESECRAN  
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End


Subprog CTLFIC(FLG,VLR,MES,GOK)
Value    Integer FLG      : # FLG=1 Fichier, FLG=2 Répertoire
Value    Char VLR()       : # Valeur saisie
Variable Char MES()       : # Message d'erreur 
Variable Integer GOK      : # Statut d'erreur

Local Integer TYPFIC, OK
Local Char    FICHIER(GDIMFIC) , FIC(GDIMFIC), REPERT(GDIMFIC), MACHINE(GDIMFIC) , OS(10)

If VLR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 GOK = 2  : End
Elsif instr(1,VLR,"#@") 
 If GBROWS or GBATCH
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  GOK = 2 : End
 Endif
 If dim([M]TYPEXP)>0 & [M]TYPEXP=2
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  GOK = 2  : End
 Endif
Endif

Call MACHINE(VLR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 # Machine inexistante
 GMESSAGE = MACHINE-mess(90,141,1)
 GOK = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  GOK = 2  : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  GOK = 2  : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  GOK = 2  : End
 Endif
Endif

Call EXISTE(VLR,TYPFIC) From ORDSYS

# TYPFIC vaut :
#  0 => Inexistant
#  1 => Fichier
#  2 => Répertoire

Case TYPFIC
 When 0 :
  Case num$(FLG)
   When "1" :
    # Fichier inexistant
    GMESSAGE = mess(101,100,1) : GOK=2 : End
   When "2" :
    # Répertoire inexistant
    GMESSAGE = "|"+REPERT-"|:"-mess(9,141,1) : GOK=2 : End
  Endcase
 When 1 : 
  Case num$(FLG)
   When "1" :
    OK = 2
    # Fichier existant, souhaitez-vous l'écraser ?
    Call OUINON(mess(127,105,1),OK) From GESECRAN  
    If OK<>2 : GOK = 2 : End : Endif
   When "2" :
    # Répertoire inexistant
    GMESSAGE = "|"+REPERT-"|:"-mess(9,141,1) : GOK=2 : End
   Endcase
 When 2 : 
   If FLG=1
    GMESSAGE = mess(55,141,1)   :# Ce fichier est un répertoire
    GOK = 2 : End
   Endif
Endcase
End

########################################################################################
#  Initialisation XIPLACBGNR
########################################################################################
$INI_X3CLE

If !clalev([F:ADW])  : Local File =SI_DOSSIER+".ADOVAL"     [ADW]  : Endif   # Variable globale

If !clalev([F:XPCG]) : Local File =SI_DOSSIER+".XIPLACBGNR" [XPCG] : Endif   # Comptes généraux
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
Read [XSOC]First

Call DEBTRANS From GLOCK
Trbegin [ADW], [XPCG] 

#--- Mise à jour des paramètres analytiques (Demande 45254)
Gosub PARAM_ANA
If !GOK : Goto FIN_INI : Endif

# V6 : la variable GLNGCPT est obsolète... la longueur du compte est associé maintenant au paramètrage du Code Plan.
# A ce stade, le Code plan n'est pas connu, il est déduit du Modèle comptable qui sera sous la fiche PARAMETRAGE.
# Demande de Fabienne, dans le cas "SI ET SEULEMENT SI un seul modèle comptable est présent dans le dossier", faire comme en V5 !
If GGCMNBR=1
 If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"     [COA]  : Endif   # Plan de comptes
 Local Integer ILED
 Local Char PLAN(GLONCOA)

 #--- Mise à jour du Code Plan Générale Principal
 ILED = find(GLEDGEN(1),GLED(1..GLEDNBR))
 If ILED : PLAN = GLEDCOA(ILED) : Endif
 Readlock [COA]COA0 =  PLAN
 If !fstat
  [F:COA]FXDLEN = 2
  [F:COA]ACCLEN = GLONGAC
  [F:COA]ACCFMT = num$(GLONGAC)+'c'
  Rewrite [COA]
 Endif
 If fstat
  # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(137,107,1)-PLAN-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif

 #--- Mise à jour du Code Plan Générale Principal
 ILED = find(GLEDANA(1),GLED(1..GLEDNBR))
 If ILED : PLAN = GLEDCOA(ILED) : Endif
 Readlock [COA]COA0 =  PLAN
 If !fstat
  [F:COA]FXDLEN = 2
  [F:COA]ACCLEN = GLONGAC
  [F:COA]ACCFMT = num$(GLONGAC)+'c'
  Rewrite [COA]
 Endif
 If fstat
  # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(137,107,1)-PLAN-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif

 Call GLOBVAR From SETGLBCOA
Endif

For [XPCG] 
 GOK = 1
 If  len([F:XPCG]X3CLE)>0 & len([F:XPCG]X3CLE)<>GLONGAC
  [F:XPCG]X3CLE = left$([F:XPCG]X3CLE+string$(GLONGAC,"0"),GLONGAC)

  Rewrite [XPCG]
  If fstat
   Call ECR_TRACE("X3CLE "-[F:XPCG]CPTGNR-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Break
  Endif
 Endif
Next

$FIN_INI
If GOK>0
 Commit
Else
 Rollback
Endif
Return

$PARAM_ANA
#
#--- Mise à jour du paramètre FRWGAC
Readlock [ADW]ADW0 = "";"";"FRWGAC"
If !fstat
 [F:ADW]VALEUR = "2"
 Rewrite [ADW]
Endif
If fstat
 # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(28,71,1)-"FRWGAC"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
GRAN = val([F:ADW]VALEUR)

#--- Mise à jour du paramètre FRWANA
Readlock [ADW]ADW0 = "";"";"FRWANA"
If !fstat
 [F:ADW]VALEUR = "2"
 Rewrite [ADW]
Endif
If fstat
 # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(28,71,1)-"FRWANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
GRANA = val([F:ADW]VALEUR)

Return

########################################################################################
#  Initialisation XIMODRGL
########################################################################################
$INI_X3RGL

If !clalev([F:XMR1]) : Local File =SI_DOSSIER+".XIMODRGL"   [XMR1] : Endif    # Mode de règlement
If !clalev([F:XMR2]) : Local File =SI_DOSSIER+".XIMODRGL"   [XMR2] : Endif    # Mode de règlement

Call DEBTRANS From GLOCK
Trbegin [XMR2]

For [XMR1]IND0(1)

 GOK = 1

 [F:XMR2] = [F:XMR1]

 Case [F:XMR1]CLERGL
  When "LA","TA"      : [F:XMR2]X3CLE="TAC"
  When "BO","BM"      : [F:XMR2]X3CLE="BOR"
  When "CH","CP"      : [F:XMR2]X3CLE="CHQ"
  When "CC"           : [F:XMR2]X3CLE="CB"
  When "LD","TD","LM" : [F:XMR2]X3CLE="TNA"
  When "ES"           : [F:XMR2]X3CLE="ESP"
  When "PR"           : [F:XMR2]X3CLE="PRE"
  When "VI"           : [F:XMR2]X3CLE="VIR"
  When Default        : GOK=0
 Endcase

 [F:XMR2]NUMORD = "~"

 If GOK
  Write [XMR2]
  If fstat
   Call ECR_TRACE("MOD_RGL"-[F:XMR2]CLERGL-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Break
  Endif
 Endif

Next

If GOK>0
 Commit
Else
 Rollback
Endif
Return


########################################################################################
#  Initialisation XIJRN... paramètres 
########################################################################################
$INI_X3JRN

If !clalev([F:SPJ])  : Local File =SI_DOSSIER+".SIPARJOU"    [SPJ]   : Endif  # Paramétrage migration

Call DEBTRANS From GLOCK
Trbegin [SPJ]
GOK = 1

Delete [SPJ] Where 1=1
If GOK>0
 Commit
Else
 Rollback
Endif
Return

########################################################################################
#  Vérification présence Société/site
########################################################################################
$VERIF

Local Integer OK

Raz OK 
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
Read [CPY] First
If !fstat : OK+=1 : Endif
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY]  : Endif   # Sites   X3
Read [FCY] First
If !fstat : OK+=1 : Endif

If OK=2 : Return : Endif


If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
Read [XSOC]First
If !clalev([F:XDPO]) : Local File =SI_DOSSIER+".XIDPO"      [XDPO] : Endif   # Sites
Read [XDPO]First

Call DEBTRANS From GLOCK
Trbegin [CPY], [FCY]
GOK = 1

Read [CPY] First
If fstat
 Gosub CRE_CPY
Endif

Read [FCY] First
If fstat
 Gosub CRE_FCY
Endif

If GOK>0
 Commit
Else
 Rollback
Endif
Return

$CRE_CPY
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable

# Lecture du modèle comptable du dossier de copie ayant la législation identique.
Filter [GCM] Where LEG=GDOSLEG
Read [GCM] First 
Filter [GCM]
If fstat
 Read [GCM] First 
Endif

Raz [CPY]
[F:CPY]CPY       = num$([F:XSOC]CODSOC)
[F:CPY]MAIFCY    = [F:XSOC]DPOIPC
[F:CPY]CPYLEGFLG = 2
[F:FCY]CRY       = GPAYS
Call INITACCCOD_LED([F:CPY]ACCCOD,[F:GCM]LED([F:GCM]GENLEDTYP-1),[V]GCACCPY) From SITSIG
[F:CPY]STRPER    = date$
[F:CPY]ACM       = [F:GCM]GCM
[F:CPY]LEG       = [F:GCM]LEG
Write [CPY]
If fstat
 # Société... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
Return

$CRE_FCY
Raz [FCY]
Read [CPY] First

[F:FCY]FCY       = [F:CPY]MAIFCY
[F:FCY]LEGCPY    = [F:CPY]CPY
[F:FCY]FINFLG    = 2
[F:FCY]FINRSPFCY = [F:FCY]FCY 
[F:FCY]DADFLG    = 2
[F:FCY]DADFCY    = [F:FCY]FCY 
[F:FCY]CRY       = GPAYS
Call INITACCCOD([F:FCY]ACCCOD,[F:FCY]LEGCPY,[V]GCACFCY) From SITSIG
Write [FCY]
If fstat
 # Site ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(3,45,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
Return


Subprog INITACCCOD_LED(VALEUR,LED,TYPCOD)
Variable Char    VALEUR()
Value    Char    LED
Value    Integer TYPCOD

If !clalev([F:LED])  : Local File =SI_DOSSIER+".GLED"       [LED]  : Endif   # Référentiel
Local Char    COAGEN(GLONCOA)

Read [LED]LED0 = [L]LED
If !fstat
 [L]COAGEN =  [F:LED]COA
Endif

Goto ACCCOD


Subprog INITACCCOD(VALEUR,CPY,TYPCOD)
Variable Char    VALEUR()
Value    Char    CPY
Value    Integer TYPCOD

Local Char    COAGEN(GLONCOA)
Call LEC_COA(1,[L]CPY,[L]COAGEN) From SIXCPY

Goto ACCCOD

$ACCCOD
Raz VALEUR
Local    Char     ACCCOD
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif

Filter [CAC] Where TYP=[L]TYPCOD & COA=[L]COAGEN
If rowcount([F:CAC])=1
 Read [CAC]CAC0 First
 If !fstat
  VALEUR = [F:CAC]ACCCOD
 Endif
Endif
Filter [CAC]
If VALEUR=""
 Read [CAC]CAC0 = [L]TYPCOD ; "STD" ; [L]COAGEN
 If !fstat
  VALEUR = [F:CAC]ACCCOD
 Endif
Endif
If VALEUR=""
 Filter [CAC] Where TYP=[L]TYPCOD & COA=[L]COAGEN
 Read [CAC]CAC0 First
 If !fstat
  VALEUR = [F:CAC]ACCCOD
 Endif
 Filter [CAC]
Endif
End

######################################################################################
Subprog S_FIC(VALEUR)
Variable Char    VALEUR()
Local Char SVG_FIC
Raz SVG_FIC
If left$(VALEUR,2)="#@"
 SVG_FIC = "#@"
Endif
Call SELFICREP(VALEUR) From SELFICREP
If SVG_FIC<>""
 VALEUR = SVG_FIC+VALEUR
Endif
End


