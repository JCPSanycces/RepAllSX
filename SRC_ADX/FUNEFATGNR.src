#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
 Case ACTION
  When "INIT"     : Gosub INIT
  When "CONTROLE" : Gosub CONTROLE
  When "EXEC"     : Gosub EXEC
  When "SORTIE"   : Gosub SORTIE
 Endcase
Return
####################################################################################
#
####################################################################################
$INIT

Local Integer CHGPAG
CHGPAG = 0

Gosub OUVRE From CNSCEISTD

Return
####################################################################################
#
####################################################################################
$CONTROLE

Call OUVRE_TRACE(mess(219,7711,1)) From LECFIC

Return
####################################################################################
#
####################################################################################
$EXEC

Gosub LOAD_FILTER From CNSCEISTD

Gosub LNK_PAR_NUM_ASC

#Gosub GEST_INVOICE

Call OUVRE_TRACE (mess(202,7711,1)) From LECFIC

For [LNK] With Stability
  Call SEND_INV_TO_EFAT([F:EFSIH]NUM,0,0,[L]STAT) From PORLEGEFATLIB
Next

Call ECR_TRACE (mess(103,7711,1),0)   From GESECRAN
Call FERME_TRACE     From LECFIC
If !GSERVEUR
   Call LEC_TRACE    From LECFIC
Endif

Return
####################################################################################
#
####################################################################################
$SORTIE


Return
####################################################################################
#
####################################################################################
$LNK_PAR_NUM_ASC
#Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and [F:EFDKD]BPEI > 1 and [F:EFCPY]LEG = "POR"
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
#& Order By  NUM Asc
Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
& [F:EFCPY]CPY0 = [F:EFSIH]CPY
& As [LNK]
& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
& and max([F:EFDKD]ATEI,[F:EFDKD]BPEI) = 1 and [F:EFCPY]LEG = "POR"
& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
& Order By  NUM Asc

Return

###################################################################################################
###################################################################################################
$GEST_INVOICE
If !clalev([F:DKD1]) : Local File DKSDATA     [DKD1]    : Endif
If !clalev([F:BPC1]) : Local File BPCUSTOMER  [BPC1] : Endif
If !clalev([F:SIH1]) : Local File SINVOICE    [SIH1]   : Endif

Filter [F:SIH1] Where [F:SIH1]ACCDAT >= date$ & [F:SIH1]STA = 3 & ([F:SIH1]INVTYP = 1 or [F:SIH1]INVTYP = 2 or [F:SIH1]INVTYP = 3 or [F:SIH1]INVTYP = 4)

For [F:SIH1]
  Read [F:BPC]BPC0 = [F:SIH1]BPR
  If !fstat
    If [F:BPC]ELECTINV = 2
      ELECTINV = 2
    Else
      ELECTINV = 1
    Endif
  Endif
  Read [F:DKD]DKD0 = "SAFT-PT";[F:SIH1]SIVTYP;[F:SIH1]NUM
  If !fstat & [F:DKD]BPEI = 0
    [F:DKD]BPEI = ELECTINV
    Rewrite [F:DKD]
  Endif
Next

Filter [F:SIH1]

Return

