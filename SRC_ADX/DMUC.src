#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"DMU",GBIDC2) From GOBJET
End

## Etiquette ajoutée par le superviseur (Objet DMU) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "BS_WEMP"     : Gosub BS_WEMP From DAPC
Endcase
Return

#######################################################################################################################################
# BOITE DE DIALOGUE + BOUTON NOUVEAU
#######################################################################################################################################
###################################

###################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]WYEA=[F]YEAEMPDDS
[M:DIA]WEMP=[F]EMPDDS
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
If GFONCTION="GESDMP"
 [M:DIA]WREFCTR=[F]REFCTR
 Read [DMU2]DMU0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
 If !fstat
  [M:DIA]WNUMDCS=[F:DMU2]NUMDCS
 Endif
Endif
Return

###################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

###################################
$EXEC
If GFONCTION="GESDMP"
 Gosub NEWDMP
Else
 Gosub NEWDMU
Endif
Return

###################################
$NEWDMU
# Vérif existance fiche DADS-U
Read [DAE2]DAE0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;1
If fstat
 #Période d'activité salarié dads-u inexistante
 GMESSAGE = mess(80,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche mutuelle DADS-U
Read [DMU2]DMU0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If !fstat
 #Ce contrat de mutuelle dads-u existe déjà
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(87,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche mutuelle DADS-U
Read [DMP2]DMP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif

SYMBOLE = "DMU"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR

Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
Return

###################################
$TR1
GOK=1
Trbegin [DMU2],[DMP2]
Raz[F:DMU2]
Gosub TR_DMU
If GOK : Gosub TR_DMP : Endif
If GOK<0    : Goto ROL_TR1
Elsif GOK=0 : Goto AB_TR1
Endif
Commit
Return

###################################
$TR_DMU
[F:DMU2]=[F:DAE2]
[F:DMU2]REFCTR=[M:DIA]WREFCTR
[F:DMU2]NUMDCS=[M:DIA]WNUMDCS
Write [DMU2]
If fstat<>0
 GOK = 0 : Call FSTA("DMU") From GLOCK
Endif
Return

###################################
$AB_TR1
Rollback
Return

###################################
$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##################################
$NEWDMP
# Vérif existance fiche mutuelle DADS-U
Read [DMU2]DMU0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If fstat
 #Contrat de mutuelle dads-u inexistant
 GMESSAGE = mess(88,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche mutuelle DADS-U
Read [DMP2]DMP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif
SYMBOLE = "DMP"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR+"\"+num$([M:DIA]WDATDEB)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR2
Unlock =SYMBOLE
Return

###################################
$TR2
GOK=1
Trbegin[DMP2]
Gosub TR_DMP
If GOK<0    : Goto ROL_TR2
Elsif GOK=0 : Goto AB_TR2
Endif
Commit
Return

###################################
$TR_DMP
GOK=1
Raz[F:DMP2]
[F:DMP2]=[F:DMU2]
[F:DMP2]STRDATCTR=[M:DIA]WDATDEB
[F:DMP2]ENDDATCTR=[M:DIA]WDATFIN
Write [DMP2]
If fstat<>0
 GOK = 0 : Call FSTA("DMP") From GLOCK
Endif
Return

###################################
$AB_TR2
Rollback
Return

###################################
$ROL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

