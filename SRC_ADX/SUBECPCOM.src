#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque ECP4 pour les différentes fenêtres

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$SET_MASK_DEF
If dim([L]W_AMK)=-1
  Local Char W_AMK(10)
  [L]W_AMK="ECP4"
Endif
Return

$SET_FLDS_TAB
If(!clalev([F:WAM_])) : Local File AMSKZON [WAM_] : Endif
If(!clalev([F:WAM1_])) : Local File AMSKZON [WAM1_] : Endif
Local Integer WI
Local Integer NBELTS
Gosub SET_MASK_DEF
Filter [WAM_] Where CODMSK=[L]W_AMK and NUMBLOC=1and NOZONE>1
Local Char TAB_FIELDS(20)(0..1,0..rowcount([WAM_]))

For [WAM_]
   Read [WAM1_]CODE=W_AMK;left$("W"+[F:WAM_]CODZON,12)
   If!fstat
    TAB_FIELDS(0,WI)=[F:WAM_]CODZON   : #CHPS Table
    TAB_FIELDS(1,WI)=[F:WAM1_]CODZON  : #CHPS W saisissable
    WI+=1
   Endif
Next
NBELTS=WI
Return

$SET_LINE_FICT
If [F:EVE]EVAVAL=10
  [M:ECP4]EVADATFIC(nolign-1)=[M:ECP4]EVADAT(nolign-1)
  [M:ECP4]EVADAT(nolign-1)=[0/0/0]
  [M:ECP4]EVADATSTR(nolign-1)=[0/0/0]
  [M:ECP4]EVADATEND(nolign-1)=[0/0/0]
Endif
Return

$AFF_DETAIL
Gosub SETNOL
Gosub SET_FLDS_TAB
For WI=0 To dim(TAB_FIELDS,2)-1
  If TAB_FIELDS(0,WI)="" : Break : Endif
  If evalue("dim([M:"+W_AMK+"]"+TAB_FIELDS(1,WI)+")")<>-1
    Assign "[M:"+W_AMK+"]"+TAB_FIELDS(1,WI) With evalue("[M:"+W_AMK+"]"+TAB_FIELDS(0,WI)+"(NOL)")
  Endif
Next
If GFONCTION<>"GESECP"
    If evalue("[M:"+W_AMK+"]EVAVAL(NOL)=10")
      Diszo [M:ECP4]10
    Else
      Actzo [M:ECP4]10
      Gosub GEST_MOBI
      Gosub GEST_EVAMAT
    Endif
Else
  Gosub SET_READONLY
Endif

 Affzo  [M:ECP4]
Return


$SET_READONLY
  Diszo [M:ECP4]
Return

$SET_STYLE
If dim([M:ECP4]NBREVA)<>-1
  Local Integer WI
  # clean styles
  Chgstl [M:ECP4]NBREVA With ""
  For WI=0 To [M:ECP4]NBREVA-1
    If([M:ECP4]EVAVAL(WI)=10)
      Chgstl [M:ECP4]NBREVA(WI) With "INITPLAGE"
      For COL="EVATYP","EVADATSTR","EVADATEND","EVADAT","NEXEVA"
        Diszo ="[M:ECP4]"+COL+"("+num$(WI)+")"
      Next
    Endif
  Next
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur
######################################################################################
Subprog AM_WFLGMOB(VALEUR)
Variable Integer VALEUR
Gosub SET_MASK_DEF
Local Integer MOBI
MOBI=VALEUR
Gosub GEST_MOBI
End


Subprog AM_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char TYP(20)
TYP=VALEUR
Gosub CTRL_UNI
If !mkstat
  Local Char WSIT(GLONFCY)
  If [M]EVAFCY(NOL)<>""
    WSIT=[M]EVAFCY(NOL)
  Else
    WSIT=[M:MECP0]ETRFCY
  Endif
  [M]FLGPRO(NOL)=func DIVPAYE.GET_VALTYPEVA("PRO",WSIT,VALEUR)
  [M]FLGBIL(NOL)=func DIVPAYE.GET_VALTYPEVA("BIL",WSIT,VALEUR)
  [M]FLGYEA(NOL)=func DIVPAYE.GET_VALTYPEVA("YEA",WSIT,VALEUR)
  [M]NEXEVA(NOL)=func DIVPAYE.DATE_NEXTINTERVIEW(VALEUR,[M]EVADAT(NOL))
  [M]EVATYP(NOL)=VALEUR

  Gosub AFF_DETAIL
Endif
End

Subprog AM_EVADAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
[M]NEXEVA(NOL)=func DIVPAYE.DATE_NEXTINTERVIEW([M]EVATYP(NOL),VALEUR)
[M]EVADAT(NOL)=VALEUR
Gosub AFF_DETAIL
End


Subprog AM_EVADATSTR(VALEUR)
Variable Date    VALEUR

Local Date STR_D
STR_D=VALEUR
Gosub CTRL_UNI

End

Subprog AM_EVADATEND(VALEUR)
Variable Date    VALEUR
Local Date END_D
END_D=VALEUR
Gosub CTRL_UNI

End


Subprog AM_WEVAMAT(VALEUR)
Variable Char    VALEUR()
Local Char MAT(GLONEML)
[L]MAT=VALEUR
Infbox (num$([L]MAT))
[M]WEVAMATLIB=[L]MAT
Gosub GEST_EVAMAT
End

Subprog AS_NBREVA
  Gosub AFF_DETAIL
End


######################################################################################


$GEST_EVAMAT

Gosub SET_VAR_MAT
# on force le recalcul
If MAT<>""
  Assign "[M:"+W_AMK+"]WEVAMATLIB" With func SUBECPCOM.GET_NAME([L]MAT)
Endif
Gosub GEST_EVANAM
Return

$SET_VAR_MAT
Gosub SET_MASK_DEF
If dim(MAT)=-1
  Local Char MAT(GLONEML)
  MAT=evalue("[M:"+W_AMK+"]WEVAMAT")
Endif
Return

$GEST_EVANAM
If [L]MAT=""
  Actzo ="[M:"+W_AMK+"]WEVAMATLIB"
Else
  Grizo ="[M:"+W_AMK+"]WEVAMATLIB"
Endif
Affzo ="[M:"+W_AMK+"]WEVAMATLIB"
Return

$GEST_MOBI
If dim([L]MOBI)=-1
  Local Integer MOBI
  If evalue("dim([M:"+W_AMK+"]WFLGMOB)")<>-1
    [L]MOBI=evalue("[M:"+W_AMK+"]WFLGMOB")
  Else
    Return
  Endif
Endif
For WC="WAREDAT","WARE","WEVAFCY"
  If evalue("dim([M:"+W_AMK+"]"+WC+")")<>-1
    If [L]MOBI<>2
      Actzo ="[M:"+W_AMK+"]"+WC
    Else
      Diszo ="[M:"+W_AMK+"]"+WC
    Endif
      Affzo ="[M:"+W_AMK+"]"+WC
  Endif
Next

Return


$CTRL_UNI
Gosub SETNOL
Gosub SET_VARIABLE_UNICITE
If(STR_D=[0/0/0] or END_D=[0/0/0] )
  Return
Endif
Local Integer I
For I=0 To [M]NBREVA-1
  If I<>NOL
    If([L]TYP=EVATYP(I) & [L]STR_D=EVADATSTR(I) & [L]END_D=EVADATEND(I))
      mkstat=2
      GMESSAGE=mess(24,123,1)-num$(I+1)
      Return
    Endif
  Endif

Next
Return


$SET_VARIABLE_UNICITE

If dim(TYP)=-1
  Local Char TYP(0)
  TYP=EVATYP(NOL)
Endif
If dim(STR_D)=-1
  Local Date BD
  STR_D=EVADATSTR(NOL)
Endif
If dim(END_D)=-1
  Local Date END_D
  END_D=EVADATEND(NOL)
Endif

Return


Funprog GET_NAME(MAT)
Variable Char MAT()
Local Char RES(50)
If !clalev ([F:ID2])   : Local File EMPLOID    [ID2]   : Endif
If fstat | [F:ID2]REFNUM<>MAT
  Read [ID2]ID0=MAT
Endif
If fstat
  RES=MAT
Else
  RES=[F:ID2]NAM - [F:ID2]SRN
Endif

End RES

