#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#      Case [L]AEVENT
#         When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
#         When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
#         When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
#         When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
#         When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
#      Endcase
#Endcase
Return


 # SAM # 111399 $METHODS outcommented content is now implemented in $EVENT
$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
         When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
         When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
         When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
         When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
         When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      Endcase
Endcase
Return


$PROPERTIES
Case CURPRO
   Endcase

Return


$AQUERY_DECODE_CRITERIA_AFTER
  Raz NBPRO
  NBPRO += 1
  TBPRO(NBPRO) = "LEG" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "PBDECODITMH.LEG" : TBFIL(NBPRO) = "[LNK_]LEG"
Return

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = "[LNK_]LEG"
Return

#fill temp table
$AQUERY_OPEN_AFTER
  Local File PBDECODITM [QRY_EIT]
  Local Integer I : I=0
  Local Integer J : J=0
  Local Char TYLEG(12)(1..)
  Local Char TEMPLEG(12)
  For [QRY_EIT]PBDEIT0
    J = find([QRY_EIT]LEG, TYLEG(1..I))
    If J = 0
      I+=1
      TYLEG(I) = [QRY_EIT]LEG
    Endif
  Next
  #LSE SAM 110398
  If I<>0
   Local File (Char LEG(100)) From Variable TYLEG As [LNK_]
  Else
   Local File PBDECODITM  [LNK_]
  Endif
Return

#set legislation
$AQUERY_TRANS_AFTER
  this.PBDECIT.LEG = [LNK_]LEG
Return

#close temp table
$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

