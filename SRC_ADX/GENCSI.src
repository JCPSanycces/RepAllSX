######################################################################################
# Creation :
#     SEGAY - 12/04/11 - FQ72136 - GÃĐnÃĐration parcours
# Modification :
#     SEGAY - 06/09/11 - FQ75536 - SÃĐlectionner/DÃĐselectionner Nom-PrÃĐnom
#     SEGAY - 07/09/11 - 75372
#         UOMTIM= jour/semaine/mois/annÃĐe ML 313
#     MABOS - 07/11/12 - FQ 81085-US925 - Add Legislation
#                      - Modify HRPOA index
#     MABOS - 22/04/2013  - FQ 86015 - US 1531 - improvement traces in mass processing
######################################################################################
$ACTION

  Case ACTION
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "DEBUT"      : Gosub DEBUT
    When "BOUTON"     : Gosub BOUTON
    When "OK"         : Gosub OK
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
  Endcase
Return

#**#####################################################################################
#*
#*!
$INIT_DIA
Local Char SYMBOLE (80)
Local Char VALCPT (GLONCSI)

  If clalev([F:ID])=0     : Local File EMPLOID       [ID]     : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA        [HRPOA]  : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR      [HRCTR]  : Endif

  If clalev([F:CSIX])=0   : Local File COURSEI       [CSIX]   : Endif
  If clalev([F:TCS])=0    : Local File TYPCOURSE     [TCS]    : Endif
  If clalev([F:TCL])=0    : Local File TCOURLIG      [TCL]    : Endif
  If clalev([F:CSI])=0    : Local File COURSEI       [CSI]    : Endif
  If clalev([F:CIL])=0    : Local File COURISLIG     [CIL]    : Endif
  If clalev([F:CIC])=0    : Local File CSICPC        [CIC]    : Endif

  If clalev([F:FCY])=0    : Local File FACILITY      [FCY]    : Endif
  If clalev([F:POT])=0    : Local File POSTE         [POT]    : Endif
  If clalev([F:JOT])=0    : Local File JOBTYP        [JOT]    : Endif
  If clalev([F:STG])=0    : Local File STAGE         [STG]    : Endif
  If clalev([F:ADI])=0    : Local File ATABDIV       [ADI]    : Endif
  If clalev([F:HRSCA])=0  : Local File SCALE         [HRSCA]  : Endif
  If clalev([F:CPC])=0    : Local File COMPETENCE    [CPC]    : Endif

  If clalev([F:AGC])=0    : Local File AGRPCPY       [AGC]    : Endif
  If clalev([F:AGF])=0    : Local File AGRPFCY       [AGF]    : Endif
  If clalev([F:ACC])=0    : Local File ACCES         [ACC]    : Endif

  Raz [M:DIA]
#  [M:DIA]DATSTR = gdat$(1, 1, year(date$))
  If GFONCTION="GESTCS" and clalev([M:TCS1])>0 Then
    [M:DIA]TCS    = [M:TCS1]COD
    [M:DIA]JOBPOT = [M:TCS1]JOBPOT
    [M:DIA]POT    = [M:TCS1]POT
    [M:DIA]DUREE  = [M:TCS1]DUREE
    [M:DIA]UOMTIM = [M:TCS1]UOMTIM
    #MABOS-07/11/12-FQ 81085-US925- Add legislation
    If [M:TCS1]CPY <>""
      [M:DIA]ALLCPY = 1
      [M:DIA]CPY    = [M:TCS1]CPY
    Endif
    [M:DIA]LEG    = GCURLEG
    If [M:DIA]LEG="" :  Call AM_CPY([M:DIA]CPY) From DIVPAYE :    Endif
  Else
    Raz [M:DIA]
  Endif
  If [M:DIA]LEG="" Then [M:DIA]LEG=GLEGFIL : Endif
  GCURLEG=[M:DIA]LEG
    #end-MABOS-07/11/12-FQ 81085-US925


  [M:DIA]SIMUL=1 # SEGAY 31/07/12 FQ83568

Return


#####################################
$CONTROLE
#MABOS-07/11/12-FQ 81085-US925-Add LEG
# Control same LEG between Population, Poste, Emploi Type, Parcours Type
#Local Char WLEGPOP(GLONADI)
#Local Char WLEGPOT(GLONADI)
#Local Char WLEGJOBPOT(GLONADI)
#Local Char WLEGTCS(GLONADI)
Local Integer WOK
Local Char WECR(50)
Local Char WLIBCOUR(50)
Local Char WMESSAGE(250)
Local Char WFIELD(30) (1..4)
Local Char WLEG(GLONADI) (1..4)
  If [M]LEG ="" Then
    WOK=0
    Call GET_LEGPOP([M]POP,WOK, WLEG(1), 0)  From TOOLSHRLEG        :# Population
    Call GET_LEGPOT([M]POT,WOK, WLEG(2), 0)  From TOOLSHRLEG         :# Poste
    Call GET_LEGJOBPOT([M]JOBPOT,WOK, WLEG(3), 0)  From TOOLSHRLEG   :# Emploi type
    Call GET_LEGTCS([M]TCS,WOK, WLEG(4), 0)   From TOOLSHRLEG        :# Parcours type

    WECR="GENCSI"
    WFIELD(1)="POP"
    WFIELD(2)="POT"
    WFIELD(3)="JOBPOT"
    WFIELD(4)="TCS"
    For I =1 To 4
       WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,WFIELD(I))
    Next

    If  WOK Then

      # Population
      WLIBCOUR = WFIELD(1)
      WLEGCOUR = WLEG(1)
      #
      For I =2 To 4
        Call LEGOK(WLIBCOUR,WLEGCOUR,WFIELD(I),WLEG(I) , WOK,WMESSAGE,0) From TOOLSHRLEG
        If !WOK Then  Break :  Endif
      Next

      If !WOK
        GMESSAGE = WMESSAGE:  GERR=1 : SAI=1 : Return
      Endif
    Endif
  Endif

  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else

    TMP = 1
    TRA = 1
  Endif
Return

#**
#* Affichage de la fenÃŠtre de sÃĐlection des parcours
#*!
$DEBUT
Local Char    CRITERE1(255), CRITERE2(255), CRITAUT(80)
Local Char    CRITID (250)
Local Char    CRITCTR (250)
Local Char    CRITCTR2 (250)
Local Char    CRITERE_LEG(GDIMFIC) # MABOS-07/11/12-FQ 81085-US925-Add LEG
Local Char    CRITTCS (250)
Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY)
Local Integer I
Raz CRITCTR, CRITID

Gosub CALC_CRIT

  I=0
  Raz [M:LCSI]
  For [F:CT_]
  #  - Prise en compte date d'effet
#   If ([F:HRCTR]CTRDAT<=[M:DIA]STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:DIA]STRDAT))
   If ([F:HRCTR]CTRDAT<=[M:DIA]STRDAT )
&                      & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>[M:DIA]STRDAT)
&         & (GUSRACS = 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))) )

    # DÃĐtermination des donnÃĐes relatives au matricule du parcours, afin d'ÃĐvaluer CRITAUT
    WFCY=[F:HRCTR]ETRFCY
    Call LECTURE("FCY", WFCY, "") From CONTOBJ
    If !fstat Then WCPY = [F:FCY]LEGCPY : Endif
    fstat=0
    If [M:DIA]POP<>"" Then
      # MABOS-07/11/12-FQ 81085-US925-Modify HRPOA index
      Read [F:HRPOA]POA0=[M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
    Endif
#SEGAY-10/12/2012 US 1045 81085
#    If evalue(CRITAUT)>0 Then
    If evalue(CRITTCS)>0 & evalue(CRITAUT)>0 Then
       If evalue(CRITERE_LEG)>0 Then
          If I<dim([M:LCSI]SELFLG) Then
            [M:LCSI]SELFLG(I) = 2
            [M:LCSI]TCS(I)    = [M:DIA]TCS
            [M:LCSI]REFNUM(I) = [F:HRCTR]REFNUM
  #segay 06/09/11 75536
            [M:LCSI]NAM(I)    = [F:ID]NAM-[F:ID]SRN
  #END 06/09/11 75536
            [M:LCSI]CTRNUM(I) = [F:HRCTR]CTRNUM
            [M:LCSI]CTRDAT(I) = [F:HRCTR]CTRDAT
            [M:LCSI]JOBPOT(I) = [F:HRCTR]JOBPOT
            [M:LCSI]POT(I)    = [F:HRCTR]POT
            [M:LCSI]KEYFRT(I) = ""
            fstat=0

            I += 1
          Endif
        Endif
      Endif
    Endif
  Next
  [M:LCSI]NBCSI=I
  Affzo [M:LCSI]


Return

#**
#* Calcul des critÃĻres de sÃĐlection
#*!
$CALC_CRIT
Local Integer ONE_CRIT, I
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Char    LIS_CPY_TCS(GLONCPY)(0..100) #SEGAY-10/12/2012 US 1045 81085

  CRITAUT="1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITAUT -= "& find(WCPY,"
      For K=0 To I-1
        CRITAUT += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITAUT += "," : Endif
      Next
      CRITAUT += ")>0"
    Endif
  Endif
  If [M:DIA]ALLFCY<>2       Then CRITAUT  -= "& WFCY='"+[M:DIA]FCY+"'"                                     : Endif
  If [M:DIA]POP<>""         Then CRITAUT  -= "& [F:HRPOA]COD='"+[M:DIA]POP+"'"                               : Endif
#MABOS-07/11/12-FQ 81085-US925-ADD LEG
  CRITERE_LEG= "1=1"
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
    CRITERE_LEG += "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)"
  Endif
#end-MABOS-07/11/12-FQ 81085-US925-ADD LEG
  CRITID ="([F:ID]ENAFLG=2 | [F:ID]FLGNEWSAL=2)" :# SalariÃĐ Actif ou nouvel embauchÃĐ
  If [M:DIA]MATSTR<>"" #borne dÃĐbut matricule
   CRITID -= '& [F:ID]REFNUM>="'+[M:DIA]MATSTR+'"'
  Endif
  If [M:DIA]MATEND<>"" #borne fin du matricule
   CRITID -= '& [F:ID]REFNUM<="'+[M:DIA]MATEND+'"'
  Endif

#SEGAY-10/12/2012 US 1045 81085
  CRITTCS="1=1"
  If [M:DIA]TCS<>"" Then
    Call LECTURE("TCS",[M:DIA]TCS,"") From CONTOBJ

    I=0 : Call CALC_GRPCPY([F:TCS]CPY, LIS_CPY_TCS, I) From TOOLSVAR
    If I>0 Then
      CRITTCS -= "& find(WCPY,"
      For K=0 To I-1
        CRITTCS += "'"+LIS_CPY_TCS(K)+"'"
        If K<I-1 Then CRITTCS += "," : Endif
      Next
      CRITTCS += ")>0"
    Endif
  Endif
#END SEGAY-10/12/2012 US 1045 81085

  CRITCTR = "1=1"
  If [M:DIA]CTRSTR<>"" #borne dÃĐbut contrat
   CRITCTR -= '& [F:HRCTR]CTRNUM>="'+[M:DIA]CTRSTR+'"'
  Endif
  If [M:DIA]CTREND<>"" #borne fin contrat
   CRITCTR -= '& [F:HRCTR]CTRNUM<="'+[M:DIA]CTREND+'"'
  Endif

  If [M:DIA]DATSTR<>[0/0/0] Then
    CRITCTR -= "& [F:HRCTR]CTRDAT>=["+format$("D:"+GFMDAT4,[M:DIA]DATSTR)+"]"
    CRITCTR -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$("D:"+GFMDAT4,[M:DIA]DATSTR)+"])"

  Endif
  If [M:DIA]DATEND<>[0/0/0] Then
    CRITCTR -= "& [F:HRCTR]CTRDAT<=["+format$("D:"+GFMDAT4,[M:DIA]DATEND)+"]"
  Endif
  CRITCTR2 = "1=1"
  If [M:DIA]MATSTR<>""      Then CRITCTR2 -= "& [F:HRCTR]REFNUM>='"+[M:DIA]MATSTR+"'"                        : Endif
  If [M:DIA]MATEND<>""      Then CRITCTR2 -= "& [F:HRCTR]REFNUM<='"+[M:DIA]MATEND+"'"                        : Endif
  If [M:DIA]JOBPOT<>"" &  [M:DIA]POT=""    Then CRITCTR2 -= "& [F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"'"          : Endif
  If [M:DIA]POT<>"" &  [M:DIA]JOBPOT=""    Then CRITCTR2 -= "& [F:HRCTR]POT='"+[M:DIA]POT+"'"                : Endif
  If [M:DIA]POT<>"" &  [M:DIA]JOBPOT<>""    Then CRITCTR2 -= "& ([F:HRCTR]POT='"+[M:DIA]POT+"' | [F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"')" : Endif
#MABOS-07/11/12-FQ 81085-US925-Modify index [HRPOA]POA0 ...";[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT"
  If [M:DIA]POP<>""
   Link [HRCTR] With
&  [ID]ID0 = [F:HRCTR]REFNUM,
&  [F:ACC]CODACC = GUSER;[F:ID]CODACS,
&  [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&   As [CT_]
&   Where evalue(CRITID)& evalue(CRITCTR) & evalue(CRITCTR2) & [F:HRPOA]REFNUM<>""
  Else
   Link [HRCTR] With
&  [ID]ID0 = [F:HRCTR]REFNUM,
&  [F:ACC]CODACC = GUSER;[F:ID]CODACS
&   As [CT_]
&   Where evalue(CRITID)& evalue(CRITCTR) & evalue(CRITCTR2)
  Endif

Return

#segay 06/09/11 75536
#**
#* Boutons "Tout cocher" et "Tout dÃĐcocher"
#*!
$BOUTON

  Case BOUT
    When "C" : For I=0 To [M:LCSI]NBCSI-1 : [M:LCSI]SELFLG(I)=2 : Next
    When "D" : For I=0 To [M:LCSI]NBCSI-1 : [M:LCSI]SELFLG(I)=1 : Next
  Endcase
  Affzo [M:LCSI]
Return
#END 06/09/11 75536


#**#####################################################################################
#* ExÃĐcution de l'action
#*!
$OK
Local  Integer LOK, NBENREG_CSI
Local Integer ICSI
Local Char    MATRI  (GLONEML)
Local Char    CONTRAT(GLONHRCTR)
Local Char    VALCPT (GLONCSI)
Local Date    L_CTRDAT
Local Date    L_DATDEB
Local Date    L_DATFIN
Local Char    SAV_GMESSAGE(250)
Local Char    L_MESSAGE(250)
Local Integer SAV_GOK
Local Char    WSHOAXX
Local Char    L_DESAXX
Local Char    L_SHOAXX
Local Integer L_TYP        : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
Local Integer L_NBLIG
# SEGAY 31/07/12 FQ83568
#  If [M:DIA]SIMUL=1 Then
#    Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement rÃĐel. Confirmez-vous ?
#    If LOK = 1 Then Return : Endif
#  Endif
# END 31/07/12 FQ83568

  SYMBOLE = "GENCSI"
  Lock =SYMBOLE
  If fstat
    GMESSAGE = mess(30,100,1) : # OpÃĐration en cours sur autre poste
    Unlock =SYMBOLE
    GERR = 1 : SAI = 1 : Return
  Endif


  TIT=mess(241,10717,1) : # GÃĐnÃĐration de parcours individualisÃĐ
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#MABOS-22/04/13-FQ86015-US1531
Call LIB_CRIT("[M:DIA]","GENCSI")From DIVPAYE

#  If [M:DIA]SIMUL=2 Then
#    Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
#    Call ECR_TRACE("------------------------------------",0) From GESECRAN
#  Endif
#MABOS-22/04/13-FQ86015-US1531

  For ICSI=0 To [M:LCSI]NBCSI-1
    If [M:LCSI]SELFLG(ICSI)=2 Then : # On ne traite que les lignes sÃĐlectionnÃĐes dans la fenÃŠtre principale
      MATRI = [M:LCSI]REFNUM(ICSI)
      CONTRAT  = [M:LCSI]CTRNUM(ICSI)
      L_CTRDAT = [M:LCSI]CTRDAT(ICSI)
      L_DATDEB = [M:DIA]STRDAT
      L_DATFIN = [M:DIA]ENDDAT
      Call DEBTRANS From GLOCK
      Gosub TR1
    Endif
  Next
  Unlock =SYMBOLE

  # Gestion de la trace
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If NBENREG_CSI>0  Then
    Call ECR_TRACE(mess(242,10717,1)-":"-num$(NBENREG_CSI),0) From GESECRAN : # Nombre de parcours individualisÃĐ mise Ã  jour
  Else
    Call ECR_TRACE(mess(243,10717,1),0) From GESECRAN : # Aucun parcours individualisÃĐ Ã  traiter
  Endif
  Call FERME_TRACE From LECFIC
  # Lecture de la trace, sinon avec la nouvelle ÃĐtiquette EXEC, on ne la voit pas
  Call LEC_TRACE From LECFIC
  GMESSAGE=""
Return

#  - On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
# en rÃĐel aprÃĻs l'avoir lancÃĐ en simulation)
$EXEC

  SAI=1
Return

#####################################
$TR1
Local Integer AUZCFY
Local Char CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)

GOK = 1
 Read [F:ID]ID0=MATRI
 If fstat : OK=0 : Return : Endif
 AUZCFY = func SUBHRSES.GET_AUZ([F:ID]CPY, [F:ID]FCY, "GENCSI")
 ## Recherche des infos du salariÃĐ/contrat
 Call INFOS_SAL(MATRI,CONTRAT,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
 If AUZCFY=2 Then
   Trbegin [CSI],[CIL],[CIC],[AXX]
   OK=0
   # ContrÃīle que le matricule est prÃĐsent
   Gosub VERIFEMP
   If OK>0
    Gosub CRECSI
    If !GOK  or [M:DIA]SIMUL<>1 : Goto AB_TR1 : Endif
   Endif
   Commit
Endif
Return

$AB_TR1
Rollback
Return

$FIN
Return


$VERIFEMP
Read[F:ID]ID0=MATRI
If fstat : OK=0 : Return : Endif

#SalariÃĐ inactif
If [F:ID]ENAFLG<>2
 #SalariÃĐ inactif
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(33,10702,1),1) From GESECRAN
 OK=0 : Return
Endif

# Code d'accÃĻs
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  #Vous n'avez pas les droits pour ce salariÃĐ
  #MABOS-22/04/13-FQ86015-US1531
  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(31,10702,1),1) From GESECRAN
  OK=0 : Return
  Endif
Endif

Filter [HRCTR]
If CTR<>"" Then
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CONTRAT
Else
  Filter [HRCTR] Where REFNUM=MATRI
Endif
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat : OK=0 : Return : Endif

# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))
  #Vous n'avez pas les droits pour ce site
  #MABOS-22/04/13-FQ86015-US1531
#  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(32,10702,1),1) From GESECRAN
# FQ94656
  Call ECR_TRACE(space$(5)+[F:HRCTR]ETRFCY-":"-mess(32,10702,1),1) From GESECRAN
  OK=0 : Return
 Endif
Endif

# Droits par service
If GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
 #Vous n'avez pas les droits pour ce service
 #MABOS-22/04/13-FQ86015-US1531
# Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(73,10702,1),1) From GESECRAN
# FQ94656
 Call ECR_TRACE(space$(5)+[F:HRCTR]ETRSRV-":"-mess(73,10702,1),1) From GESECRAN
 OK=0 : Return
Endif

# PrÃĐsent sur la pÃĐriode
Call PRESEMPCTR(MATRI,L_DATDEB,L_DATFIN,CONTRAT,OK) From INSPRO
If !OK
 #Session xxx : XXX EmployÃĐ non prÃĐsent sur la pÃĐriode
 #MABOS-22/04/13-FQ86015-US1531
# Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(9,10709,1),1) From GESECRAN
# FQ94656
 Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-"("+mess(6,10506,1)-CONTRAT+") :"-mess(9,10709,1)-format$(GFMD,L_DATDEB)-mess(41,101,1)-format$(GFMD,L_DATFIN),1) From GESECRAN

 OK=0 : Return
Endif
Filter [F:CSIX]
Filter [F:CSIX] Where [F:CSIX]REFNUM = MATRI & [F:CSIX]CTR = CONTRAT & [F:CSIX]STRDAT = L_DATDEB
If rowcount ([F:CSIX]) > 0
  Filter [F:CSIX]
  mkstat = 2
  # Il existe dÃĐjÃ   un parcours pour ce salariÃĐ commenÃ§ant Ã  cette date
  #MABOS-22/04/13-FQ86015-US1531
#  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(165,10717,1),1) From GESECRAN
# FQ94656
  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-"("+mess(6,10506,1)-CONTRAT+") :"-mess(165,10717,1)-format$(GFMD,L_DATDEB),1) From GESECRAN
  OK=0 : Return
Endif
Filter [F:CSIX]
OK = 1
Return

$CRECSI
 SAV_GMESSAGE=GMESSAGE
 SAV_GOK=GOK
 Raz VALCPT
 Raz [F:CSI]
 [F:CSI]TCS=[M:DIA]TCS
 Call CPT_CSI(VALCPT,[F:CSI]TCS) From SUBCSI
 If GOK
  [F:CSI]COD  = VALCPT
  #Lecture du parcours type
  Call LECTURE("TCS",[F:CSI]TCS,"") From CONTOBJ
  If [F:CSI]TCS <>""
    [F:CSI]POT=[F:TCS]POT
    [F:CSI]JOBPOT=[F:TCS]JOBPOT
    [F:CSI]DESJOB=[F:TCS]DESJOB
  #Chargement des stages du parcours type
    Gosub REMTAB_CIL
    If !GOK : Return : Endif

  #Chargement du suivi par dÃĐfaut
    Gosub REMTAB_ACN
    If !GOK : Return : Endif

  #Chargement des compÃĐtences du poste type
    If func SUBCSI.IS_CAR
       Gosub REMTAB_CPC
       If !GOK : Return : Endif
    Endif

  Endif
  [F:CSI]CTR=CONTRAT
  [F:CSI]REFNUM=MATRI
  [F:CSI]CTRDAT=L_CTRDAT
  [F:CSI]STRDAT=L_DATDEB
  [F:CSI]ENDDAT=L_DATFIN

  [F:CSI]DUREE=[M:DIA]DUREE
  [F:CSI]UOMTIM=[M:DIA]UOMTIM
  [F:CSI]FLGPRO=[M:DIA]FLGPRO
  #ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#  If GMODU(4)=2 & GPAYE
#    Call SOLDE_DIF(MATRI,CONTRAT,L_DATDEB,[F:CSI]NBRHOUDIF) From DIVPAYE
#  Endif
  If GMODU(4)=2 & GPAYE
    Call SOLDE_DIF(MATRI,CONTRAT,L_DATDEB,[F:CSI]NBRHOUDIF) From DIVPAYE
  Endif
   #ADNGO - 2017-02-15 - END
  Call LECTEXTRA(WSHOAXX,"TYPCOURSE","DESAXX",[F:CSI]TCS,"") From ATEXTRA
  L_DESAXX="" # US 2323 94656 if [F:TCS]COD ="" designation is empty
  If WSHOAXX<>""
   L_DESAXX=mess(138,10717,1)-WSHOAXX :#Parcours
  Elsif [F:TCS]COD <> "" # US 2323 94656
   L_DESAXX=mess(138,10717,1)-[F:TCS]COD :#Parcours
  Endif
  L_SHOAXX=""
  If [M:DIA]SIMUL=1 Then
    Call MAJTEXTRA(L_DESAXX,"COURSEI","DESAXX",[F:CSI]COD,"") From ATEXTRA
    If !GOK : Return : Endif
    Call MAJTEXTRA(L_SHOAXX,"COURSEI","SHOAXX",[F:CSI]COD,"") From ATEXTRA
    If !GOK : Return : Endif
    If dim([F:CSI]CREDAT)>0 : [F:CSI]CREDAT = date$     : Endif
    If dim([F:CSI]CRETIM)>0 : [F:CSI]CRETIM = time      : Endif
    If dim([F:CSI]CREUSR)>0 : [F:CSI]CREUSR = GUSER     : Endif
    If dim([F:CSI]EXPNUM)>0 : [F:CSI]EXPNUM = [C]EXPORT : Endif
    Write [F:CSI]
    If fstat
      GOK = 0 : Call FSTA("CSI") From GLOCK : Return
    Endif
  Endif
  NBENREG_CSI+=1
  If [M:DIA]SIMUL=1 Then
   #MABOS-22/04/13-FQ86015-US1531
   L_MESSAGE = space$(5)+mess(138,10717,1)-[F:CSI]COD-":"-mess(5,10935,1)-MATRI-[F:ID]NAM-[F:ID]SRN-"/"-mess(72,10720,1)-CONTRAT-"/"-mess(59,116,1)-format$("D:"+GFMDAT,[F:CSI]STRDAT)-format$("D:"+
& GFMDAT,[F:CSI]ENDDAT)
   Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Parcours : Matricule / Contrat / PÃĐriode
  Else
   #MABOS-22/04/13-FQ86015-US1531
   L_MESSAGE = space$(5)+mess(138,10717,1)-" "-":"-mess(5,10935,1)-MATRI-[F:ID]NAM-[F:ID]SRN-"/"-mess(72,10720,1)-CONTRAT-"/"-mess(59,116,1)-format$("D:"+GFMDAT,[F:CSI]STRDAT)-format$("D:"+GFMDAT,[F:
& CSI]ENDDAT)
   Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Parcours : Matricule / Contrat / PÃĐriode
  Endif
 Else
  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-GMESSAGE,1) From GESECRAN
  GMESSAGE=SAV_GMESSAGE
  GOK=SAV_GOK
  OK=0 : Return
 Endif
Return
#**
#* Alimentation des champs des stages
#* Venants du parcours type
#* SEGAY
#*!
$REMTAB_CIL
L_NBLIG=0
Filter [F:TCL] Where COD=[F:CSI]TCS Order By Key TCL0
For [F:TCL]
# If (func AV_NO_DATE_STG ([F:TCL]STG,[M:CSI1]STRDAT,[M:CSI1]ENDDAT,1)) <> 1 Then
   Raz [F:CIL]
   L_NBLIG+=1000
   [F:CIL]COD = [F:CSI]COD
   [F:CIL]CILLIG = L_NBLIG
   [F:CIL]STG=[F:TCL]STG
   [F:CIL]ORDRE=[F:TCL]ORDRE
   [F:CIL]FLGOBG=[F:TCL]FLGOBG
   [F:CIL]STA=1
   Raz [F:STG]
   Call LECTURE("STG",[F:CIL]STG,"") From CONTOBJ
   [F:CIL]DOM=[F:STG]DOM
   [F:CIL]THM=[F:STG]THM
  # 29/12/10 SEGAY Bug 70244 le nbre de jour est repris si type <> autre stage
   If [F:STG]TYPSTG <> 2
    [F:CIL]NBRDAY=[F:STG]NBRDAY
   Endif
   [F:CIL]NBRHOUIPT=[F:STG]NBRHOUIPT

   [F:CIL]NATFIS=[F:STG]NATFIS
   [F:CIL]CATACN=[F:STG]CATACN
   [F:CIL]TYPFRT=[F:STG]TYPFRT

#   Maj par inscription
#      [F:CIL]STA         # Statut
#      [F:CIL]STRDATR     # Date dÃĐbut
#      [F:CIL]ENDDATR     # Date fin
#      [F:CIL]NBRDAYREA   # Nombre de jours
#      [F:CIL]NBRHOUREA   # Nombre d'heures
#      [F:CIL]NBRHOUIPT2  # Nombre d'heures HTT

   If dim([F:CIL]CREDAT)>0 : [F:CIL]CREDAT = date$     : Endif
   If dim([F:CIL]CRETIM)>0 : [F:CIL]CRETIM = time      : Endif
   If dim([F:CIL]CREUSR)>0 : [F:CIL]CREUSR = GUSER     : Endif
   If dim([F:CIL]EXPNUM)>0 : [F:CIL]EXPNUM = [C]EXPORT : Endif
   If [M:DIA]SIMUL=1 Then
     Write [CIL]
     If fstat
        GOK = 0 : Call FSTA("CIL") From GLOCK : Break
     Endif
   Endif
   [F:CSI]NBRHOUMAX += [F:STG]NBRHOUIPT
Next
Filter [F:TCL]
Return

#**
#* Alimentation des champs du suivi
#* par dÃĐfaut
#* SEGAY
#*!
$REMTAB_ACN
L_NBLIG=0
  For [F:ADI] Where NUMTAB=10468 and N1=2
    [F:CSI]SUIACN(L_NBLIG)=[F:ADI]CODE
    Raz [F:CSI]SUIDAT(L_NBLIG)
    Raz [F:CSI]SUICMT(L_NBLIG)
    L_NBLIG += 1
  Next

Return

#**
#* Alimentation des champs des compÃĐtences requises CPC
#* Venants du poste et emploi type
#* SEGAY
#*!
$REMTAB_CPC
#################################################################################
# On charge toutes les compÃĐtences, avec leurs derniers niveaux
If !func SUBCSI.IS_CAR
  Return
Endif
Call LECTURE("POT",[F:CSI]POT,"") From CONTOBJ
If [F:CSI]POT<>"" & [F:POT]JOBPOT=[F:CSI]JOBPOT
  L_TYP = 1       : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
  For J=0 To dim([F:POT]CPC)-1
   If [F:POT]CPC(J)="" : Break : Endif
   Gosub SAUVE_CIC
   If !GOK : Break : Endif
  Next J
Elsif [F:CSI]JOBPOT<>""
  Call LECTURE("JOT",[F:CSI]JOBPOT,"") From CONTOBJ
  L_TYP = 2       : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
  For J=0 To dim([F:JOT]CPC)-1
   If [F:JOT]CPC(J)="" : Break : Endif
   Gosub SAUVE_CIC
   If !GOK : Break : Endif
  Next J
Endif
#################################################################################
Return

#**
#* Sauvegarde des compÃĐtences requises et acquises
#*!
$SAUVE_CIC
  Raz [F:CIC]
  [F:CIC]COD = [F:CSI]COD
  [F:CIC]CPCDAT = [0/0/0]
  If L_TYP = 1       : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
    [F:CIC]CPC    = [F:POT]CPC(J)
    [F:CIC]LEVCPC = [F:POT]NIV(J)
    [F:CIC]LEVREFVAL = func SUBECP.CPC_LEVREF([F:POT]CPC(J),[F:POT]NIV(J))

    If [F:POT]ORI(J)<>4 & [F:POT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compÃĐtence ou manuelle
      [F:CIC]ORICPC = [F:POT]ORI(J)
    Else
      # Si =4 ML 2400 Groupe de compÃĐtence
      [F:CIC]ORICPC = 5 : # ML 2400 Emploi type
    Endif
  Else
    [F:CIC]CPC    = [F:JOT]CPC(J)
    [F:CIC]LEVCPC = [F:JOT]NIV(J)
    [F:CIC]LEVREFVAL = func SUBECP.CPC_LEVREF([F:JOT]CPC(J),[F:JOT]NIV(J))

    If [F:JOT]ORI(J)<>4 & [F:JOT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compÃĐtence ou manuelle
      [F:CIC]ORICPC = [F:JOT]ORI(J)
    Else
      # Si =4 ML 2400 Groupe de compÃĐtence
      [F:CIC]ORICPC = 5 : # ML 2400 Emploi type
    Endif
  Endif
  [F:CIC]FLGGPEC = 2
  If dim([F:CIC]CREDAT)>0 : [F:CIC]CREDAT = date$     : Endif
  If dim([F:CIC]CRETIM)>0 : [F:CIC]CRETIM = time      : Endif
  If dim([F:CIC]CREUSR)>0 : [F:CIC]CREUSR = GUSER     : Endif
  If dim([F:CIC]EXPNUM)>0 : [F:CIC]EXPNUM = [C]EXPORT : Endif
  If [M:DIA]SIMUL=1 Then
    Write [CIC]
    If fstat
     GOK = 0 : Call FSTA("CIC") From GLOCK : Return
    Endif
  Endif
Return

