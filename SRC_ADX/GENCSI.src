#**#####################################################################################
#* ContrÃīle sur les champs de mise Ã  jour
#*!
Subprog AM_TCS(VALEUR)
Variable Char    VALEUR()
#Chargement des champs du parcours type
Call LECTURE("TCS",VALEUR,"") From CONTOBJ
If VALEUR <>""
  [M]POT=[F:TCS]POT
  [M]JOBPOT=[F:TCS]JOBPOT
  [M]DUREE=[F:TCS]DUREE
  [M]UOMTIM=[F:TCS]UOMTIM
  Affzo[M:DIA]
Endif
End

Subprog C_TCS(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
Local Char WLEG(GLONADI)  : # LEG
Local Char WFIELD(50)     : # LibellÃĐ du champ

  If [M:DIA]LEG <> "" Then
   WLEG = ""
    Call GET_LEGTCS(VALEUR,WOK, WLEG, 0)  From TOOLSHRLEG        :# Leg du Parcours type
    If WOK Then
      If WLEG <> "" & WLEG <> [M:DIA]LEG  Then
  #    mess(00062,00127,1) : RÃĐservÃĐ Ã  la lÃĐgislation
        WFIELD =func TOOLSHRLEG.LIB_FIELD("GENCSI","TCS")
        GMESSAGE = WFIELD-":"-VALEUR+"\"+ mess(00062,00127,1)-":"-WLEG
        mkstat = 2
      Endif
    Endif
  Endif
End


Subprog AS_UOMTIM(VALEUR)
Variable Integer VALEUR
  Call AS_UOMTIM(VALEUR) From SUBCSI

End


Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If [M]ENDDAT =[0/0/0]
   [M]ENDDAT = VALEUR
Endif
#segay 07/09/11 75372
#UOMTIM= jour/semaine/mois/annÃĐe ML 313
#Mois
#If [M]UOMTIM = 3
#  [M]ENDDAT=addmonth(VALEUR,[M]DUREE)
#  Affzo [M]ENDDAT
#Endif
##Jours
#If [M]UOMTIM = 1
#  If [M]DUREE > 0
#    [M]ENDDAT=VALEUR+[M]DUREE - 1
#    Affzo [M]ENDDAT
#  Endif
#Endif
If [M]DUREE > 0
  Case [M]UOMTIM
   When 1 : [M]ENDDAT = VALEUR+[M]DUREE-1              : # Jour
   When 2 : [M]ENDDAT = VALEUR+([M]DUREE*7)-1          : #Semaine
   When 3 : [M]ENDDAT = addmonth(VALEUR,[M]DUREE)-1    : #Mois
   When 4 : [M]ENDDAT = addmonth(VALEUR,[M]DUREE*12)-1 : #AnnÃĐe
  Endcase
Else
  [M]ENDDAT = VALEUR
Endif
Affzo [M]ENDDAT
#END 07/09/11 75372

If [M]ENDDAT =[0/0/0]
   [M]ENDDAT = VALEUR
   Affzo [M]ENDDAT
Endif

End



######################################################################################
# MABOS-07/11/12-FQ 81085-US925-Add LEG

#US 1835 : 91298 : suppression des champs dans init_byleg commum.
Subprog INIT_BYLEG(VALEUR)
Variable Char VALEUR
# call by DIVPAYE
# Raz all fields after Leg, if leg is modified
Raz [M]MATSTR,[M]MATEND,[M]CTRSTR,[M]CTREND #,[M]DATSTR,[M]DATEND,[M]POP,[M]POT,[M]JOBPOT
Raz [M]TCS ,[M]DUREE #,[M]STRDAT,[M]ENDDAT
#Raz [M]ZPOP,[M]ZPOT,[M]ZJOBPOT
[M]UOMTIM=1
[M]SIMUL=1
Affzo [M]MATSTR,MATEND,CTRSTR,CTREND #,DATSTR,DATEND,POP,POT,JOBPOT
Affzo [M]TCS,DUREE #,STRDAT,ENDDAT
#Affzo [M]ZPOP,ZPOT,ZJOBPOT,ZTCS
Affzo [M]UOMTIM, SIMUL
End


#end-MABOS-07/11/12-FQ 81085-US925-Add LEG
