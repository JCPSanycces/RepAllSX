#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
# Regénérer le plan de paye
################################################################################
Local Char DOSSIER(30)
[L]DOSSIER = nomap
If [L]DOSSIER="PAIE" : End : Endif
Call SAIDOS([L]DOSSIER,"") From SAIDOS
If [L]DOSSIER>""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=DOSSIER
 If fstat : Raz [F:ADS] : Endif
 ## Moulinette uniquement si module paye
 If [F:ADS]MODULE(1) <> 2 : End : Endif
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIGENPLAN : Génération du plan de paye") From LECFIC
 Call EXE_UTIGENPLAN([L]DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif

End

#########################
Subprog EXE_UTIGENPLAN(APPLI)
Value Char APPLI

Call ECR_TRACE("UTIGENPLAN : Process Start on : "+[L]APPLI,0) From GESECRAN

#### Corps de la moulinette - début

Local Integer I
I=adxlog

Call GENPLAN([L]APPLI,I) From GENPLAN

#### Corps de la moulinette - fin 

Call ECR_TRACE("UTIGENPLAN : Process End on : "+[L]APPLI,0) From GESECRAN

End

###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="PAIE" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(1) <> 2 : End : Endif: # Module paye inactif

Call EXE_UTIGENPLAN([L]APPLI)

End
