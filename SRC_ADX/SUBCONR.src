#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque CONA
##########################################################################################################
Subprog AM_RREWFRY(VALEUR)
Variable Decimal VALEUR

Local Decimal TMPVAL

  TMPVAL = VALEUR
  Call SETENDDAT([M:CONR]RCONSTRDAT, TMPVAL, [M:CONR]RREWFRYBAS, [M:CONR]RCONENDDAT) From SUBCOND
  Affzo [M:CONR]RCONENDDAT
End

##########################################################################################################
Subprog AM_RREWFRYBAS(VALEUR)
Variable Integer VALEUR

Local Integer TMPVAL

  TMPVAL = VALEUR
  Call SETENDDAT([M:CONR]RCONSTRDAT, [M:CONR]RREWFRY, TMPVAL, [M:CONR]RCONENDDAT) From SUBCOND
  Affzo [M:CONR]RCONENDDAT
End

##########################################################################################################
Subprog AM_RCONSTRDAT(VALEUR)
Variable Date    VALEUR

Local Date TMPVAL

  TMPVAL = VALEUR
  Call SETENDDAT(TMPVAL, [M:CONR]RREWFRY, [M:CONR]RREWFRYBAS, [M:CONR]RCONENDDAT) From SUBCOND
  Affzo [M:CONR]RCONENDDAT
End
