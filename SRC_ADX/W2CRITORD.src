#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CRITORD 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_MWFFLG
Onevent INIT_AREA Call D_MWFFLG(zc) From W2CRITORD
Onevent BEFORE_INPUT Call AS_MWFFLG(zc) From W2CRITORD
Return

Subprog D_MWFFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]MWFFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MWFFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

