#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet PTO) 16/01/2006 10:32:49 (LLCX)
######################################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "LIENS"       : Gosub LIENS
    When "INICRE"      : Gosub INICRE
    When "INIMOD"      : Gosub INICRE
    When "ANNULE"      : Gosub ANNULE
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "CHANGE"      : Call CHANGE_AXX ("PARMTO", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
    When Default
Endcase
Return

#############################################################
$OUVRE
Local Integer I
Return

#############################################################
$LIENS
[M:PTO1]NBLIG = find(0,[M:PTO1]UNTFLT(0..dim([M:PTO1]UNTFLT)-1))
If [M:PTO1]NBLIG = 0
   [M:PTO1]NBLIG = dim([M:PTO1]UNTFLT)
Else
   [M:PTO1]NBLIG -= 1
Endif

# Affichage pour que les grizo soient effectifs
If AFFICHE
   Gosub AFFZONE From GOBJSUB
Endif

If [M:PTO1]PIOMOD  <> 2  : Diszo [M:PTO1]PIOFCT : Else : Actzo [M:PTO1]PIOFCT : Endif
If [M:PTO1]SHTMOD  <> 2  : Diszo [M:PTO1]SHTFCT : Else : Actzo [M:PTO1]SHTFCT : Endif
If [M:PTO1]DEMMOD  <> 2  : Diszo [M:PTO1]DEMFCT : Else : Actzo [M:PTO1]DEMFCT : Endif
If [M:PTO1]DEMMOD  <> 2  : Diszo [M:PTO1]DEMCAT : Else : Actzo [M:PTO1]DEMCAT : Endif
If [M:PTO1]PTOHORFLG = 1 : Diszo [M:PTO1]PTOHOR : Else : Actzo [M:PTO1]PTOHOR : Endif
If [M:PTO1]PTOREAL <> 2
    Diszo [M:PTO1]25
Else 
    Actzo [M:PTO1]25
Endif

If [M:PTO1]PTOREAL <> 2 & [M:PTO1]PTOAUT <> 2
    Diszo [M:PTO1]20
Else 
    Actzo [M:PTO1]20
Endif
For I=0 To [M:PTO1]NBLIG-1
   Actzo [M:PTO1]QTYPCTUP(I)
   Actzo [M:PTO1]QTYPCTDOWN(I)
   Actzo [M:PTO1]DATMARUP(I)
   Actzo [M:PTO1]DATMARDOWN(I)
   If [M:PTO1]QTYFLT(I)=1 
      Grizo [M:PTO1]QTYPCTUP(I)
      Grizo [M:PTO1]QTYPCTDOWN(I)
   Endif
   If [M:PTO1]DATFLT(I)=1 
      Grizo [M:PTO1]DATMARUP(I)
      Grizo [M:PTO1]DATMARDOWN(I)
   Endif
Next I

Return

#############################################################
$INICRE
# a désactiver si on réactive la saisie du paramètre DIRALL (allocation auto des entrées)
If [M:PTO1]DIRALL = 0 : [M:PTO1]DIRALL = 2 : Endif
Return

#############################################################
$INIMOD
Return

#############################################################
$ANNULE
Delete [AXX] Where CODFIC="PARMTO" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]PTODESAXX,"PARMTO","PTODESAXX",[M]PTOCOD,"") From ATEXTRA
Call MAJTEXTRA([M]PTOSHOAXX,"PARMTO","PTOSHOAXX",[M]PTOCOD,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]PTODESAXX,"PARMTO","PTODESAXX",[M]PTOCOD,"") From ATEXTRA
Call MAJTEXTRA([M]PTOSHOAXX,"PARMTO","PTOSHOAXX",[M]PTOCOD,"") From ATEXTRA

Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 10/02/2006 10:43:15 (LLCX)
######################################################################################
Subprog AS_QTYPCTUP(VALEUR)
Variable Decimal VALEUR
If [M:PTO1]QTYFLT(nolign-1) <> 2 : VALEUR = 0 : mkstat = 2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 10/02/2006 10:43:15 (LLCX)
######################################################################################
Subprog AS_QTYPCTDOWN(VALEUR)
Variable Decimal VALEUR
If [M:PTO1]QTYFLT(nolign-1) <> 2 : VALEUR = 0 : mkstat = 2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 10/02/2006 10:43:15 (LLCX)
######################################################################################
Subprog AS_DATMARUP(VALEUR)
Variable Decimal VALEUR
If [M:PTO1]DATFLT(nolign-1) <> 2 : VALEUR = 0 : mkstat = 2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 10/02/2006 10:43:15 (LLCX)
######################################################################################
Subprog AS_DATMARDOWN(VALEUR)
Variable Decimal VALEUR
If [M:PTO1]DATFLT(nolign-1) <> 2 : VALEUR = 0 : mkstat = 2 : Endif
End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 13/02/2006 14:53:56 (LLCX)
######################################################################################
Subprog AM_PIOMOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : Actzo [M:PTO1]PIOFCT : Else : Diszo [M:PTO1]PIOFCT : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 14/02/2006 11:10:46 (LLCX)
######################################################################################
Subprog AP_QTYFLT(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    Grizo [M:PTO1]QTYPCTUP(nolign-1)
    Grizo [M:PTO1]QTYPCTDOWN(nolign-1)
Else 
    Actzo [M:PTO1]QTYPCTUP(nolign-1)
    Actzo [M:PTO1]QTYPCTDOWN(nolign-1)
Endif
Affzo [M:PTO1]QTYPCTUP(nolign-1)
Affzo [M:PTO1]QTYPCTDOWN(nolign-1)
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 14/02/2006 11:10:46 (LLCX)
######################################################################################
Subprog AP_DATFLT(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    Grizo [M:PTO1]DATMARUP(nolign-1)
    Grizo [M:PTO1]DATMARDOWN(nolign-1)
Else 
    Actzo [M:PTO1]DATMARUP(nolign-1)
    Actzo [M:PTO1]DATMARDOWN(nolign-1)
Endif
Affzo [M:PTO1]DATMARUP(nolign-1)
Affzo [M:PTO1]DATMARDOWN(nolign-1)
End


######################################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 01/06/2006 13:47:35 (LLCX)
######################################################################################
Subprog AM_PTOREAL(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 
    Actzo [M:PTO1]20-25
Else
    Diszo [M:PTO1]25
    If [M:PTO1]PTOAUT = 1 : Diszo [M:PTO1]20 : Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 15/06/2006 16:17:15 (LLCX)
######################################################################################
Subprog AM_PTOHORFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : Actzo [M:PTO1]PTOHOR : Else : Diszo [M:PTO1]PTOHOR : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 15/06/2006 16:23:13 (LLCX)
######################################################################################
Subprog AM_PTOAUT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 
    Actzo [M:PTO1]20
Else
    If [M:PTO1]PTOREAL = 1 : Diszo [M:PTO1]20 : Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 29/12/2008 17:17:06 (LLC)
######################################################################################
Subprog AM_SHTMOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : Actzo [M:PTO1]SHTFCT : Else : Diszo [M:PTO1]SHTFCT : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 19/03/2010 13:53:29 (LLC)
######################################################################################
Subprog AS_DEMCAT(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
GMENLOC(4) = 1
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PTO1) 19/03/2010 14:02:15 (LLC)
######################################################################################
Subprog AM_DEMMOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : Actzo [M:PTO1]DEMFCT : Actzo [M:PTO1]DEMCAT : Else : Diszo [M:PTO1]DEMFCT : Diszo [M:PTO1]DEMCAT : Endif
End


######################################################################################
