#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet ADO
Raz GPILOBJ,GBIDC1,GBIDC2,GNBMASKOUV,GTEST
Call OBJET("ADO",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "AFFMASK"     : Gosub AFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "VERF_ANU"    : Gosub VERF_ANU
 When "ANNULE"      : Gosub ANNULE
 When "FIN"         : Gosub FIN
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "STATUT"      : Gosub STATUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "TRT_DIV"     : Gosub TRT_DIV
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "STYLE"       : Gosub STYLE
 When "DEGRISE"     : Gosub DEGRISE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "FERME"       : Gosub FERME
Endcase
Return

# Pour éviter de perdre la saisie du clob (EN V5)
$DEGRISE
# Aztuze pour rendre l'écran invalide après création ou modif
$STYLE
# Aztuze pour rendre l'écran invalide après la lecture
Gosub VERDOC From AGENDOCA
If IF_DOCV5
   Setmok [M] With 0
Endif
Return

#----------------------------------------------------------#
$OUVRE
Local Char    DOSX3(GLONADS) , MESSA(255)
Local Integer LOCCLB
Local Integer ICOPCE , ICOCLB
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
Local File =DOSX3+".ADOCCLB" [ADHX]
Local File =DOSX3+".ADOCBLB" [ADBX]
ICOPCE = 175
ICOCLB = 251
Gosub BLOCAGE_CONSULT From SUBADO
Return
#------------------------------#
$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return

#------------------------------#
$APRES_MODIF
  #JPGA 07/01/2010 BUG-69982 : Dans un dossier fille bloqué en consultation, le focus sur le champs HTML entre en modif à tord: on le bloquer
  Gosub BLOCAGE_CONSULT From SUBADO
Return

$BLOCAGE_CONSULT
  #JPGA 26/03/2010 BUG-54686 : Ne pas permettre la MAJ de documentation si on est en interne dans un dossier Fille (REF)
  #---- Appelé depuis SUBADO et SUBADZ et SUBADF
  If GSOPHIA | filinfo(filpath("","sophia_gaillard","",adxmother(1)),0)>0 | filinfo(filpath("","sophia_gaillard","",adxmother(0)),0)>0
    #JPGA 08/11/2011 BUG-77673 : Cibler plus les environnements de Référence de TRAD pour le contrôle de MAJ dans un dossier Fille
    # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
    If nomap <> GDOSX3 & func AGENREM.IS_ENVINDUS_DOC("")
      Case ACTION
        When "OUVRE"       : GCONSULT=1                # Blocage global de la fonction en Consultation
        When "FIN"         : Raz GCONSULT
        When "APRES_MODIF" : OK = -1                   # Blocage de tout champs modifié en Consultation
      Endcase
    Endif
  Endif
Return

#----------------------------------------------------------#
$OUVRE_BOITE
Local Char    BOXDOC(10) , BOXTYP(10) , BOXSPE(10)
BOXDOC = "GAU_CHE"+num$(find("AD0",OBJLIS(1..dim(OBJLIS)-1)))
BOXTYP = "GAU_CHE"+num$(find("AD1",OBJLIS(1..dim(OBJLIS)-1)))
BOXSPE = "GAU_CHE"+num$(find("AD7",OBJLIS(1..dim(OBJLIS)-1)))
Return

#----------------------------------------------------------#
$AFFMASK
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call AFFMASK_GROUPE("[M]CREGRP") From AGENLIBA
Return

#----------------------------------------------------------#
$RAZCRE
LOCCLB = 0
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Gosub INIT_GROUPE    From AGENLIBA
Return

#----------------------------------------------------------#
$LIENS
LOCCLB = 0
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call ALIMENT_GROUPE("ADO", [ADO]LAN, [ADO]TYP, [ADO]COD, "[M]CREGRP")  From AGENLIBA

Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
If !fstat
 [M:ADO1]TEXTE = [F:ADH]TEXTE
 If nomap<>DOSX3 : LOCCLB = 1 : Endif
Elsif nomap<>DOSX3
 Read [ADHX]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If !fstat
  [M:ADO1]TEXTE = [F:ADHX]TEXTE
 Endif
Endif
#[M]VLDFLG=1
# VPO 10/01/08 39714
Call GRISE_MSK([F:ADO]PAR)
Return

#----------------------------------------------------------#
$VERIF_CRE
$AVANT_MOD
#VPO 27/10/08 49955 ajout AT3: différences de tables 130
If [M]TYP="ATD" | [M]TYP="AT3"
    GERR=1
    GMESSAGE=mess(82,176,1)
    OK=0
    Return
Endif
Return

#----------------------------------------------------------#
$APRES_MOD
$APRES_CRE
LOCCLB = 1

If !func AGENREM.IS_ENVINDUS_DOC("") # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
##VPO 21/11/07 BUG44225 ne pas proposer validation si doc jamais validée
If clalev([ADO3])=0 : Local File ADOCUMENT [ADO3] : Endif
For [ADO3] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & VLDFLG=2 & VLDDAT<>date$
    #s'il existe un paragraphe validé à une autre date que aujourd'hui
    ##VPO 16/11/07 bug43240 ajouter proposition de validation
    MESSA  = 'LAN = "'+[M]LAN+'"'
    MESSA -= 'TYP = "'+[M]TYP+'"'
    MESSA -= 'COD = "'+[M]COD+'"'
    OK=1 : Call OUINON(MESSA+"\"+mess(80,176,1),OK) From GESECRAN
    If OK=2
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      PARBOUT(1) = [M]LAN
      PARBOUT(2) = [M]TYP
      PARBOUT(3) = [M]COD
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ADOCVAL","ADOCVAL",3,"") From GTRAITE
    Endif
    #VPO 21/11/07 BUG44236 ajout relecture
    Gosub RELIT From GOBJSUB
    Break
Next
Endif


Trbegin [ADO]
Call MAJ_ENVINDUS_DOC ([M]LAN,[M]TYP,[M]COD,2) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Commit
Return

#----------------------------------------------------------#
$MODIF
$CREATION
Readlock [ADH]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
If fstat=1
 GOK=-1 : GLOCK="$ADOCCLB"-[M]LAN-[M]TYP-[M]COD-num$([M]LEV)-num$([M]SUBLEV) : Return
Elsif !fstat
 [F:ADH]TEXTE = [M]TEXTE
 If dim([F:ADH]UPDUSR)>0    : [F:ADH]UPDUSR    = GUSER                                        : Endif
 If dim([F:ADH]UPDDATTIM)>0 : [F:ADH]UPDDATTIM = datetime$
   If dim([F:ADH]UPDDAT)>0  : [F:ADH]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADH]UPDDATTIM)   : Endif
 Else
   If dim([F:ADH]UPDDAT)>0  : [F:ADH]UPDDAT    = date$                                        : Endif
   If dim([F:ADH]UPDTIM)>0  : [F:ADH]UPDTIM    = time                                         : Endif
 Endif
 Rewrite [ADH]
 If fstat
  GOK=0 : Call FSTA("ADH") From GLOCK : Return
 Endif
Else
 Read [ADHX]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
 If !fstat
  If [F:ADHX]TEXTE<>[M]TEXTE
   [F:ADH] = [M:ADO1]
   If dim([F:ADH]CREUSR)>0    : [F:ADH]CREUSR    = GUSER                                      : Endif
   If dim([F:ADH]CREDATTIM)>0 : [F:ADH]CREDATTIM = datetime$
     If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = func SUBADC.DAT_DATETIME([F:ADH]CREDATTIM) : Endif
   Else
     If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = date$                                      : Endif
     If dim([F:ADH]CRETIM)>0  : [F:ADH]CRETIM    = time                                       : Endif
   Endif
   If dim([F:ADH]UPDUSR)>0    : Raz [F:ADH]UPDUSR     :  Endif
   If dim([F:ADH]UPDDAT)>0    : Raz [F:ADH]UPDDAT     :  Endif
   If dim([F:ADH]UPDTIM)>0    : Raz [F:ADH]UPDTIM     :  Endif
   If dim([F:ADH]UPDDATTIM)>0 : Raz [F:ADH]UPDDATTIM  :  Endif
   Write [ADH]
   If fstat
    GOK=0 : Call FSTA("ADH") From GLOCK : Return
   Endif
  Endif
 Else
  [F:ADH] = [M:ADO1]
  If dim([F:ADH]CREUSR)>0    : [F:ADH]CREUSR    = GUSER                                       : Endif
  If dim([F:ADH]CREDATTIM)>0 : [F:ADH]CREDATTIM = datetime$
    If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = func SUBADC.DAT_DATETIME([F:ADH]CREDATTIM)  : Endif
  Else
    If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = date$                                       : Endif
    If dim([F:ADH]CRETIM)>0  : [F:ADH]CRETIM    = time                                        : Endif
  Endif
  If dim([F:ADH]UPDUSR)>0    : Raz [F:ADH]UPDUSR      :  Endif
  If dim([F:ADH]UPDDAT)>0    : Raz [F:ADH]UPDDAT      :  Endif
  If dim([F:ADH]UPDTIM)>0    : Raz [F:ADH]UPDTIM      :  Endif
  If dim([F:ADH]UPDDATTIM)>0 : Raz [F:ADH]UPDDATTIM   :  Endif
  Write [ADH]
  If fstat
   GOK=0 : Call FSTA("ADH") From GLOCK : Return
  Endif
 Endif
Endif
Return

#----------------------------------------------------------#
$FIN
Call RESET_IMAGE(ICOPCE) From GESECRAN
Call RESET_IMAGE(ICOCLB) From GESECRAN
Gosub BLOCAGE_CONSULT From SUBADO
Return

#----------------------------------------------------------#
$SETBOUT
If CLECUR & REP="" & VERROU
#VPO 27/10/08 49955 ajout AT3: différences de tables 130
 If [M]TYP<>"ATD" & [M]TYP<>"AT3"
     If !func AGENREM.IS_ENVINDUS_DOC("") # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
       #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Bouton B ajouté lancant ADOCPRIO
       CHMEN += "6789BA03C" : # Images/Copie globale/Extraction/Validation/Priorisation/Liens/Vérif/Epuration
     Else
       CHMEN += "678A03C"   : # Images/Copie globale/Extraction//Liens/Vérif/Epuration
     Endif
     CHAINE += "A"          : # Suppression
     If DOSX3=nomap
       CHMEN += "145"        : # Renumérotation/Annulation de masse
     Endif
 Endif
Else
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Génération/Copie
Endif
K = 0
Filter [ADB] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
Read [ADB] First
Filter [ADB]
If !fstat
 K = 1
Elsif nomap<>DOSX3
 Filter [ADBX] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
 Read [ADBX] First
 Filter [ADBX]
 If !fstat : K = 1 : Endif
Endif
If K
 Call SET_IMAGE(ICOPCE) From GESECRAN
Else
 Call RESET_IMAGE(ICOPCE) From GESECRAN
Endif
If LOCCLB
 Call SET_IMAGE(ICOCLB) From GESECRAN
Else
 Call RESET_IMAGE(ICOCLB) From GESECRAN
Endif
Return

#----------------------------------------------------------#
$APRES_CHOI
Case REPONSE
 When GSTACLK+ICOPCE
  Local Char PARMSK(250)(1..10) , VALMSK(10)
  PARMSK(1) = [M]LAN
  PARMSK(2) = [M]TYP
  PARMSK(3) = [M]COD
  PARMSK(4) = num$([M]LEV)
  PARMSK(5) = num$([M]SUBLEV)
  Call SAISIE_CHAR(VALMSK,PARMSK,"ADOCPIC","ADOCPIC","") From GSAISIE
  REPONSE = 0
  #VPO 02/10/08 49500 proposer validation sur AD et AM
  Gosub RELIT From GOBJSUB
Endcase
Return

#----------------------------------------------------------#
$STATUT
Case BOUT
 When "0"
#VPO 23/09/08 45300
#  Call DOCNUT(0) From ADOCVER
   Gosub RELIT From GOBJSUB
 When "3"
#VPO 23/09/08 45300
#  Call DOCNUT(1) From ADOCVER
   Gosub RELIT From GOBJSUB
 When "5"
  Filter [ADO] Where [F]LAN=[M]LAN & [F]TYP=[M]TYP & [F]COD=[M]COD
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  Read [ADO]ADO0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
  If ![S]fstat
    #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    If !func AGENLIBA.CONTROLE_GROUPE_OK("ADO", [M]LAN, [M]TYP, [M]COD)
      GERR=1 :  FIN=1  :  Return
    Endif
  Endif
  Filter [ADO]
  Gosub TRTSUP_OPT
  #Gosub RELIT From GOBJSUB
 When "9"
   #VPO 21/11/07 BUG44236 ajout relecture
   Gosub RELIT From GOBJSUB
Endcase
Return

$TRTSUP_OPT
Local Integer I , J , OK, NBPAR
Local Char    CRITLAN(30), CRITCOD(200), FILTERSUP(250), LISTLAN(250), CLE1(250), SAVDEFMSK(100), DOCNAME(130)
Local Char    DOC_TYP(20),DOC_LAN(5),DOC_COD(100)

Raz LISTLAN
[L]SAVDEFMSK=dbgstr(1)

Local Mask ADOCSUP [DIA2]
If dim(WTILD)<=0        : Local Char  WTILD(1)  : [L]WTILD="~" : Endif

#init des variables de travail
[L]DOC_TYP  =[M:ADO1]TYP
[L]DOC_LAN  =[M:ADO1]LAN
[L]DOC_COD  =[M:ADO1]COD
[L]DOCNAME  =[L]DOC_TYP+[L]WTILD+[L]DOC_COD
[L]CLE1     =[L]DOC_LAN+[L]WTILD+[L]DOC_TYP+[L]WTILD+[L]DOC_COD

If clalev([F:ADO2])=0 : Local File ADOCUMENT  [ADO2] : Endif
Filter [ADO2] Where [F:ADO2]LAN=DOC_LAN & [F:ADO2]TYP=DOC_TYP & [F:ADO2]COD=DOC_COD
[L]NBPAR = rowcount([F:ADO2])
Filter [ADO2]
#création de la liste des langues existantes
For [ADO2]ADO0(1) Where [F:ADO2]TYP=DOC_TYP & [F:ADO2]COD=DOC_COD
  If [L]LISTLAN="" : [L]LISTLAN+=[F:ADO2]LAN
  Else : [L]LISTLAN+=", "+[F:ADO2]LAN : Endif
Next
#Paramètres de la fenêtre
[M:DIA2]TYPSUP=1
[M:DIA2]CLE1=[L]CLE1-" ("+num$(NBPAR)+"§)"
[M:DIA2]LISTLAN=[L]LISTLAN

Call DIALWIN(OK,mess(118,176,1)-[L]DOCNAME,"ADOCSUP") From GESECRAN : # Options de suppression
If OK=2
   # Contrôle option de suppression
   Raz CRITCOD,CRITLAN,FILTERSUP
   [L]CRITLAN = 'LAN = "'+[L]DOC_LAN+'"'
   [L]CRITCOD = 'TYP = "'+[L]DOC_TYP+'"'+' & COD = "'+[L]DOC_COD+'"'
   # suppression suivant saisie fenetre
   If [M:DIA2]TYPSUP = 2
     #toutes langues
     # Voulez-vous supprimer la documentation MOTCLE dans toutes les langues existantes ?
     MESSA = func AFNC.MES1(mess(115,176,1),[L]DOCNAME)+"\"+[L]LISTLAN
     Call AVERTIR(MESSA,OK) From GESECRAN
     If OK<>2 : Goto ABORT : Endif
     For [ADO2]ADO0(1) Where evalue([L]CRITCOD)
       FILTERSUP=[L]CRITCOD+' & LAN="'+[F:ADO2]LAN+'"'
       If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
       [L]DOC_CLE1=[F:ADO2]TYP  :  [L]DOC_CLE2(0)=[F:ADO2]LAN  :  [L]DOC_CLE2(1)=[F:ADO2]COD
       Call ANNU2(FILTERSUP,[L]DOC_CLE1,[L]DOC_CLE2,"A")
     Next
   Elsif [M:DIA2]TYPSUP = 1
     # Voulez-vous supprimer tous les paragraphes de la documentation ?
     MESSA = mess(30,176,1)-[M:DIA2]CLE1
     Call AVERTIR(MESSA,OK) From GESECRAN
     If OK<>2 : Goto ABORT : Endif
     #tous les paragraphes
     FILTERSUP=[L]CRITCOD-"&"-[L]CRITLAN
     Call ANNU2(FILTERSUP,CLECUR1,CLECUR2,"A")
   Endif
   If GOK=1
     Raz CLECUR , CLECUR1 , CLECUR2
     Gosub DEVERROU From GOBJET
     Gosub RELIT From GOBJSUB
   Endif
Endif
ABORT:
Close File    [ADO2]
Close Mask    [DIA2]
Default Mask  [L]SAVDEFMSK
Return

Subprog ANNU2(FILTREDEL,CLE1,CLE2,TRACECOR_OPT)
Value Char FILTREDEL, CLE1, CLE2, TRACECOR_OPT
If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADB])=0 : Local File ADOCBLB    [ADB] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif
Call DEBTRANS From GLOCK
Gosub TR_ANNU2
If GOK=1
 Gosub VERDOC From AGENDOCA
 Call TRACE_COR("ADO",CLE1,CLE2,TRACECOR_OPT) From AGENLIBA
 Call ANNULE("ADO",CLE1,CLE2) From GOBJTXT
 Call ANNULE("ADO",CLE1,CLE2) From SUBALI
Endif
End

#----------------------------------------------------------#
Subprog ANNU(WLAN,WTYP,WCOD,MESSA)
Value Char WLAN , WTYP , WCOD
Variable Char MESSA
If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADB])=0 : Local File ADOCBLB    [ADB] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif
Filter [ADO] Where [F]LAN=WLAN & [F]TYP=WTYP & [F]COD=WCOD
# Tous les paragraphes de la documentation suivante ont étés supprimés
MESSA = mess(83,176,1)-"("+num$(rowcount([F:ADO]))+")"
MESSA += "\"+mess(11,151,1)+'="'+WLAN+'"' : # Langue
MESSA -= mess(94,151,1)+'="'+WTYP+'"' : # Type
MESSA -= mess(37,100,1)+'="'+WCOD+'"' : # Code
Call DEBTRANS From GLOCK
Gosub TR_ANNU
End

$TR_ANNU
Trbegin [ADO]
 Delete [ADO] Where [F]LAN=WLAN & [F]TYP=WTYP & [F]COD=WCOD
 If fstat=1
  GOK=-1 : Call FSTA("ADO") From GLOCK : Goto ROLL_ANNU
 Endif
 Delete [ADB] Where [F]LAN=WLAN & [F]TYP=WTYP & [F]COD=WCOD
 If fstat=1
  GOK=-1 : Call FSTA("ADB") From GLOCK : Goto ROLL_ANNU
 Endif
 Delete [ADH] Where [F]LAN=WLAN & [F]TYP=WTYP & [F]COD=WCOD
 If fstat=1
  GOK=-1 : Call FSTA("ADH") From GLOCK : Goto ROLL_ANNU
 Endif
Commit
Return

$ROLL_ANNU
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNU : Endif
Return

$TR_ANNU2
Trbegin [ADO]
 Delete [ADO] Where evalue(FILTREDEL)
 If fstat=1
  GOK=-1 : Call FSTA("ADO") From GLOCK : Goto ROLL_ANNU2
 Endif
 Delete [ADB] Where evalue(FILTREDEL)
 If fstat=1
  GOK=-1 : Call FSTA("ADB") From GLOCK : Goto ROLL_ANNU2
 Endif
 Delete [ADH] Where evalue(FILTREDEL)
 If fstat=1
  GOK=-1 : Call FSTA("ADH") From GLOCK : Goto ROLL_ANNU2
 Endif
Commit
Return

$ROLL_ANNU2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNU2 : Endif
Return

#----------------------------------------------------------#
$ANNULE
Delete [ADB] Where LAN=[L]SUPP(0) & TYP=[L]CODE & COD=[L]SUPP(1) & LEV=val([L]SUPP(2)) & SUBLEV=val([L]SUPP(3))
If fstat=1
 GOK=-1 : Call RSTA("ADB",[L]CODE-[L]SUPP(1)) From GLOCK : Return
Endif
Delete [ADH] Where LAN=[L]SUPP(0) & TYP=[L]CODE & COD=[L]SUPP(1) & LEV=val([L]SUPP(2)) & SUBLEV=val([L]SUPP(3))
If fstat=1
 GOK=-1 : Call RSTA("ADH",[L]CODE-[L]SUPP(1)) From GLOCK : Return
Endif
Return

#----------------------------------------------------------#
$VERF_ANU
#VPO 27/10/08 49955 ajout AT3: différences de tables 130
If [L]CODE="ATD" | [L]CODE="AT3"
    GERR=1
    GMESSAGE=mess(82,176,1)
    OK=0
    Return
Endif
Local Char DOSX3(GLONADS)
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If nomap<>DOSX3
# Read [ADH]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
# If !fstat
#  Gosub TR_ANUSPE
# Endif
 Read [ADHX]ADH0=[L]SUPP(0);[L]CODE;[L]SUPP(1);val([L]SUPP(2));val([L]SUPP(3))
 If !fstat
  Read [ADH]ADH0=[L]SUPP(0);[L]CODE;[L]SUPP(1);val([L]SUPP(2));val([L]SUPP(3))
  If !fstat
   Gosub TR_ANUSPE
  Endif
  OK = 0 : Return
 Endif
Endif
Return

$TR_ANUSPE
Trbegin [ADH]
 Delete [ADH] Where LAN=[L]SUPP(0) & TYP=[L]CODE & COD=[L]SUPP(1) & LEV=val([L]SUPP(2)) & SUBLEV=val([L]SUPP(3))
 If fstat=1
  GOK=-1 : Call RSTA("ADH",[L]CODE-[L]SUPP(1)) From GLOCK : Goto ROLL_ANUSPE
 Endif
 Delete [ADB] Where LAN=[L]SUPP(0) & TYP=[L]CODE & COD=[L]SUPP(1) & LEV=val([L]SUPP(2)) & SUBLEV=val([L]SUPP(3))
 If fstat=1
  GOK=-1 : Call RSTA("ADB",[L]CODE-[L]SUPP(1)) From GLOCK : Goto ROLL_ANUSPE
 Endif
# Delete [ADH] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
# If fstat=1
#  GOK=-1 : Call RSTA("ADH",[M]TYP-[M]COD) From GLOCK : Goto ROLL_ANUSPE
# Endif
# Delete [ADB] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
# If fstat=1
#  GOK=-1 : Call RSTA("ADB",[M]TYP-[M]COD) From GLOCK : Goto ROLL_ANUSPE
# Endif
Commit
Return

$ROLL_ANUSPE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANUSPE : Endif
Return

#----------------------------------------------------------#
$FILGAUCHE
Case currbox
 When BOXDOC
  FILGAUSUP = 'LAN="'+[M]LAN+'" & TYP="'+[M]TYP+'" & COD="'+[M]COD+'"'
 When BOXTYP
  FILGAUSUP = 'LAN="'+[M]LAN+'" & TYP="'+[M]TYP+'"'
 When BOXSPE
  If nomap=DOSX3 : FILGAUSUP = '1=0' : Else : FILGAUSUP = '[F:ADB]LAN<>"" or [F:ADH]LAN<>""' : Endif
Endcase
Return

#----------------------------------------------------------#
$SEL_TABLE
Local Char    DOC_CODE(30), DOC_TYPE(GLONADI)
# JPGA 19/08/2009 Bug-52238
# Selection dans table pour les documentations ayant une clé multiples à plusieurs champs Clé1_Clé2_Clé3_Clé4 (ASU ou CDE)
Case TABLE
  When "ASELDOCNK"
    OBJET    = PARAM(1)
    DOC_TYPE = PARAM(1)
    DOC_CODE = VALEUR
    Gosub  DOC_RECH_CLE_MULTIPLE  From AGENLIBA
    If IF_DOC_TABLE
      Gosub DOC_SEL_CLE_MULTIPLE  From AGENLIBA
      [L]EXPSTART = [L]DOC_EXPR
    Endif
Endcase
Return

#----------------------------------------------------------#
$FIN_TABLE
Local Char    DOC_CODE(30), DOC_TYPE(GLONADI)
# JPGA 19/08/2009 Bug-52238 : Selection dans table pour les documentations ayant une clé multiples à plusieurs champs
Case TABLE
  When "ASELDOCNK"
    DOC_TYPE = OBJET
    DOC_CODE = VALEUR
    Gosub  DOC_RECH_CLE_MULTIPLE  From AGENLIBA
    If IF_DOC_TABLE
      # Clé multiples : Si la valeur n'est pas sous la forme : Cle1_Cle2_Cle3_Cle3, on la reconstitue pour qu'elle soit ainsi
      Gosub DOC_FIN_CLE_MULTIPLE  From AGENLIBA
      If [L]DOC_EXPR <> ""
        VALEUR = [L]DOC_EXPR
      Endif
    Endif
Endcase
Return

#----------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "ASELDOC" : Gosub SELDOC
 When "ATUNDOC" : Gosub TUNDOC
Endcase
Return

#----------------------------------------------------------#
$SELDOC
Local Char    PARMSK(250)(1..16)
Local Decimal PARNUM
Local Char    TYPDOC(GLONADI)
TYPDOC = PARAM(1)
Raz PARMSK
Case TYPDOC
 When "AML"
  PARNUM = val(VALEUR)
  Call S_TAB_NUM(PARNUM,PARMSK,"SELASTMEN","APLSTD","") From GACTION
  VALEUR = num$(PARNUM)
 When "AST"
  Call TRAITE_CHAR(VALEUR,PARMSK,"AFFMESS","RECHMESS","RECHMESS",3,"") From GTRAITE
  mkstat = 2
 When "AT2"
  PARMSK(1) = "ATB"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 When Default
  PARMSK(1) = TYPDOC
  # JPGA 19/08/2009 Bug-52238 : Utilisation de l'action de sélection sur clé Multiple si besoin : ASELDOCNK
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find(PARMSK(1), [L]DOC_CLE_MULT)
    # Action de sélection sur une table avec une clé à N champs : Clé1_Clé2_Clé3_Clé4
    Call S_TAB_CHAR(VALEUR,PARMSK,"ASELDOCNK","SUBADO","") From GACTION
  Else
    Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
  Endif
Endcase
Return

#----------------------------------------------------------#
$TUNDOC
Local Decimal PARNUM
Local Char    DOC_CODE(30), DOC_TYPE(GLONADI)
DOC_TYPE = PARAM(1)
Case [L]DOC_TYPE
 When "AML"
  PARNUM = val(VALEUR)
  Call MESSAGE(PARNUM) From APLSTD
  VALEUR = num$(PARNUM)
 When "AT2"
  Call OBJET_CHAR(VALEUR,"ATB","") From GOBJET
 When Default
  DOC_CODE = VALEUR
  # JPGA 19/08/2009 Bug-52238 : Alimentation de champs sur clé multiples
  Gosub DOC_CONT_CLE_MULTIPLE  From AGENLIBA
  # Recherche des clés pour alimenter l'action de controle sur une table avec une clé à N champs : Clé1_Clé2_Clé3_Clé4
  If !mkstat
    Gosub DOC_ACT_CLE_MULTIPLE   From AGENLIBA
    Call OBJET_CHAR([L]DOC_EXPR,[L]DOC_TYPE,[L]DOC_EXPR2) From GOBJET
  Endif
Endcase
Return

#----------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELAMKAFC" : Gosub AMKAFC
Endcase
Return

$AMKAFC
If clalev([AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([ACN])=0 : Local File ACONSULT  [ACN] : Endif
If clalev([ACT])=0 : Local File ACTION    [ACT] : Endif
If clalev([AWI])=0 : Local File AWINDOW   [AWI] : Endif
If clalev([AMK])=0 : Local File AMSK      [AMK] : Endif
Local Char FEN(GLONFEN) , TEXTE(50)(1..dim(TEX),1..3)
FORCE = 1
Read [AFC]CODINT = PARAM(1)
If !fstat
 If [F:AFC]TYP=2
  I = find("OBJET",[F:AFC]CODPAR)
  If I
   FEN = "O"+evalue([F:AFC]VALPAR(I-1))
   Gosub CHARGE_LIS
  Endif
 Else
  Read [ACT]ACTION = [F:AFC]ACTION
  If !fstat
   If [F:ACT]PARAM1<>""
    Read [ACN]ACN0 = [F:ACT]PARAM1
    If !fstat
     FEN = [F:ACN]WND1
     Gosub CHARGE_LIS
     FEN = [F:ACN]WND0
     Gosub CHARGE_LIS
    Endif
   Else
    FEN = [F:ACT]PARAM4
    Gosub CHARGE_LIS
    FEN = [F:ACT]PARAM2
    Gosub CHARGE_LIS
   Endif
  Endif
 Endif
 TIT(0) = mess(111,139,1) : # Sélection d'un écran
 TIT(1) = mess(37,100,1)  : # Code
 TIT(2) = mess(30,109,1)  : # Intitulé
 TIT(3) = mess(14,126,1)  : # Fenêtre
Endif
Return

$CHARGE_LIS
If FEN<>""
 Read [AWI]AWI0 = FEN
 If !fstat
  If [F:AWI]MSKENT<>""
   NBTEX += 1
   TEX(NBTEX) = [F:AWI]MSKENT
   Call TEXTE([F:AWI]DES,TEXTE(NBTEX,2)) From OBJDIV
   TEXTE(NBTEX,3) = [F:AWI]WIN
  Endif
  For I=1 To [F:AWI]NBMSK
   If [F:AWI]NOMMSK(I-1)<>""
    Read [AMK]CODMSK = [F:AWI]NOMMSK(I-1)
    If !fstat
     NBTEX += 1
     TEX(NBTEX) = [F:AWI]NOMMSK(I-1)
     Call TEXTE([F:AWI]DES,TEXTE(NBTEX,2)) From OBJDIV
     TEXTE(NBTEX,3) = [F:AWI]WIN
    Endif
   Endif
  Next I
 Endif
Endif
Return
#----------------------------------------------------------#
Subprog AFFICHE_DOC(TIT,TYP,COD)
Value Char TIT , TYP , COD
Local Integer OK
Local Char    DOSX3(GLONADS) , PAR(GLONADI)
Local Clbfile TEX(GLONACB)
[L]PAR = "PRE"
OK = 0
For [ADO] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & [F]PAR=[L]PAR
 Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If !fstat
  [L]TEX = [F:ADH]TEXTE
  OK = 1
 Else
  Call PARAM("","SUPDOS",DOSX3) From ADOVAL
  If nomap<>DOSX3
   Local File =DOSX3+".ADOCCLB" [ADHX]
   Read [ADHX]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    [L]TEX = [F:ADHX]TEXTE
    OK = 1
   Endif
   Close Local File [ADHX]
  Endif
 Endif
 Break
Next ADO
If OK
 Local Mask ADOCINFO [ADOF]
 [M:ADOF]TEXTE = [L]TEX
 Call AFFWIN(TIT-COD,"ADOCINFO") From GESECRAN
 Close Local Mask [ADOF]
Endif
End

#----------------------------------------------------------#
Subprog LECTURE_DOC(TYP,COD,TEX,OK)
Value Char TYP , COD
Variable Clbfile TEX
Variable Integer OK
Local Char DOSX3(GLONADS) , PAR(GLONADI)
[L]PAR = "PRE"
OK = 0
For [ADO] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & [F]PAR=[L]PAR
 Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If !fstat
  [L]TEX = [F:ADH]TEXTE
  OK = 1
 Else
  Call PARAM("","SUPDOS",DOSX3) From ADOVAL
  If nomap<>DOSX3
   Local File =DOSX3+".ADOCCLB" [ADHX]
   Read [ADHX]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    [L]TEX = [F:ADHX]TEXTE
    OK = 1
   Endif
   Close Local File [ADHX]
  Endif
 Endif
 Break
Next ADO
End

#----------------------------------------------------------#
Subprog MODIF_DOC(TYP,COD,OK)
Value Char TYP , COD
Variable Integer OK
Local Char DOSX3(GLONADS) , PAR(GLONADI)
[L]PAR = "PRE"
OK = 1
For [ADO] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & [F]PAR=[L]PAR
 Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If fstat
  Call PARAM("","SUPDOS",DOSX3) From ADOVAL
  If nomap<>DOSX3
   Local File =DOSX3+".ADOCCLB" [ADHX]
   Read [ADHX]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    Call AVERTIR(mess(132,139,1),OK) From GESECRAN : # Voulez-vous modifier cette aide standard
    OK = (OK=2)
   Endif
   Close Local File [ADHX]
  Endif
 Endif
 Break
Next ADO
End

#----------------------------------------------------------#
Subprog EFFACE_DOC(TYP,COD)
Value Char TYP , COD
Delete [ADO] Where [F]TYP=[L]TYP & [F]COD=[L]COD
If fstat=1
 GOK=-1 : Call FSTA("ADO") From GLOCK : End
Endif
Delete [ADH] Where [F]TYP=[L]TYP & [F]COD=[L]COD
If fstat=1
 GOK=-1 : Call FSTA("ADH") From GLOCK : End
Endif
#If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
#[L]DOC_CLE1=[L]TYP  :  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=[L]COD
#Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "A") From AGENLIBA
End

#----------------------------------------------------------#
# PROCEDURE CREANT AUTOMATIQUEMENT UNE DOCUMENTATION 10-20 POUR DES OBJETS
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
#----------------------------------------------------------#
Subprog ECRIRE_DOC(TYP, COD, TEX, TIT, MODU, ACTI)
Value Char TYP, COD, TIT, ACTI
Value Clbfile TEX
Value Integer MODU

Local Integer DOC , CLB , MODIF
Local Integer LEV , SUBLEV
Local Char    DOSX3(GLONADS) , PAR(GLONADI) , TEXTE(10)

Setlob [L]TEXTE With [L]TEX

Raz DOC , CLB , MODIF , LEV , SUBLEV
[L]PAR = "PRE"

For [ADO] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & [F]PAR=[L]PAR
 DOC = 1
 [L]LEV    = [F:ADO]LEV
 [L]SUBLEV = [F:ADO]SUBLEV
 Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If !fstat
  CLB = 1
  If [F:ADH]TEXTE<>[L]TEX
   MODIF = 1
  Endif
 Else
  Call PARAM("","SUPDOS",DOSX3) From ADOVAL
  If nomap<>DOSX3
   Local File =DOSX3+".ADOCCLB" [ADHX]
   Read [ADHX]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat & [F:ADHX]TEXTE=[L]TEX
    CLB = 1
   Endif
   Close Local File [ADHX]
  Endif
 Endif
 Break
Next ADO

# Modification de la doc

If MODIF
 Readlock [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
 If fstat=1
  GOK = -1 : GLOCK = "$ADOCCLB" : End
 Else
  [F:ADH]TEXTE = [L]TEX
  If dim([F:ADH]UPDUSR)>0    : [F:ADH]UPDUSR    = GUSER                                       : Endif
  If dim([F:ADH]UPDDATTIM)>0 : [F:ADH]UPDDATTIM = datetime$
    If dim([F:ADH]UPDDAT)>0  : [F:ADH]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADH]UPDDATTIM)  : Endif
  Else
    If dim([F:ADH]UPDDAT)>0  : [F:ADH]UPDDAT    = date$                                       : Endif
    If dim([F:ADH]UPDTIM)>0  : [F:ADH]UPDTIM    = time                                        : Endif
  Endif
  Rewrite [ADH]
  If fstat
   GOK = 0 : Call FSTA("ADH") From GLOCK : End
  Endif
  #If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
  #[L]DOC_CLE1=[L]TYP  :  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=[L]COD
  #Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "M") From AGENLIBA
 Endif

# Création de la doc

Elsif !CLB & !find([L]TEXTE,"","<P/>")
 If [L]LEV=0 and [L]SUBLEV=0
  [L]LEV    = 10
  [L]SUBLEV = 20
 Endif

 # Création du chapitre PRE

 If !DOC
  Raz [F:ADO]
  [F:ADO]LAN    = GLANGUE
  [F:ADO]TYP    = [L]TYP
  [F:ADO]COD    = [L]COD
  [F:ADO]LEV    = [L]LEV
  [F:ADO]SUBLEV = [L]SUBLEV
  [F:ADO]PAR    = [L]PAR
  [F:ADO]TIT    = mess(2,142,1) : # Présentation

  # JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
  If MODU>0   : [F:ADO]MODULE = MODU : Endif
  If ACTI<>"" : [F:ADO]CODACT = ACTI : Endif

  If dim([F:ADO]CREUSR)>0    : [F:ADO]CREUSR    = GUSER                                       : Endif
  If dim([F:ADO]CREDATTIM)>0 : [F:ADO]CREDATTIM = datetime$
    If dim([F:ADO]CREDAT)>0  : [F:ADO]CREDAT    = func SUBADC.DAT_DATETIME([F:ADO]CREDATTIM)  : Endif
  Else
    If dim([F:ADO]CREDAT)>0  : [F:ADO]CREDAT    = date$                                       : Endif
    If dim([F:ADO]CRETIM)>0  : [F:ADO]CRETIM    = time                                        : Endif
  Endif
  Write [ADO]
  If fstat
   GOK = 0 : Call FSTA("ADO") From GLOCK : End
  Endif
  #If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
  #[L]DOC_CLE1=[L]TYP  :  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=[L]COD
  #Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "C") From AGENLIBA
 Endif

 # Mise à jour du texte d'aide

 Raz [F:ADH]
 [F:ADH] = [F:ADO]
 [F:ADH]TEXTE = [L]TEX
 If dim([F:ADH]CREUSR)>0    : [F:ADH]CREUSR    = GUSER                                       : Endif
 If dim([F:ADH]CREDATTIM)>0 : [F:ADH]CREDATTIM = datetime$
   If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = func SUBADC.DAT_DATETIME([F:ADH]CREDATTIM)  : Endif
 Else
   If dim([F:ADH]CREDAT)>0  : [F:ADH]CREDAT    = date$                                       : Endif
   If dim([F:ADH]CRETIM)>0  : [F:ADH]CRETIM    = time                                        : Endif
 Endif
 Write [ADH]
 If fstat
  GOK = 0 : Call FSTA("ADH") From GLOCK : End
 Endif

Endif
End


#----------------------------------------------------------#
Subprog COPIE_DOC(TYP,COD,DOSORG,DOSDES)
Value Char TYP , COD , DOSORG, DOSDES
Local Integer DOC1 , DOC2 , CLB , MODIF
Local Clbfile TEX(9)
Local Integer LEV , SUBLEV
Local Char    APPLI(GLONADS) , DOSX3(GLONADS) , MACHINE(250) , TEXTE(250)
Raz [L]TEX , DOC1
For [ADO1] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & PAR="PRE"
 DOC1 = 1
 [L]LEV = [F:ADO1]LEV
 [L]SUBLEV = [F:ADO1]SUBLEV
 Read [ADH1]ADH0=[F:ADO1]LAN;[F:ADO1]TYP;[F:ADO1]COD;[F:ADO1]LEV;[F:ADO1]SUBLEV
 If !fstat
  [L]TEX = [F:ADH1]TEXTE
 Else
  Local File =DOSORG+".ADOVAL" [AD__]
  Read [AD__]ADW0="";"";"SUPDOS"
  If !fstat & [F:AD__]VALEUR<>""
   DOSX3 = [F:AD__]VALEUR
   Call MACHINE(DOSORG,MACHINE,APPLI) From ORDSYS
   If APPLI<>DOSX3
    Local File =MACHINE+"@"+DOSX3+".ADOCCLB" [ADH3]
    Read [ADH3]ADH0=[F:ADO1]LAN;[F:ADO1]TYP;[F:ADO1]COD;[F:ADO1]LEV;[F:ADO1]SUBLEV
    If !fstat
     [L]TEX = [F:ADH3]TEXTE
    Endif
    Close Local File [ADH3]
   Endif
  Endif
  Close Local File [AD__]
 Endif
 Break
Next ADO1
Setlob [L]TEXTE With [L]TEX
Raz DOC2 , CLB
For [ADO2] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & PAR="PRE"
 DOC2 = 1
 [L]LEV = [F:ADO2]LEV
 [L]SUBLEV = [F:ADO2]SUBLEV
 Read [ADH2]ADH0=[F:ADO2]LAN;[F:ADO2]TYP;[F:ADO2]COD;[F:ADO2]LEV;[F:ADO2]SUBLEV
 If !fstat
  CLB = 1
  If [F:ADH2]TEXTE<>[L]TEX
   MODIF = 1
  Endif
 Else
  Local File =DOSDES+".ADOVAL" [AD__]
  Read [AD__]ADW0="";"";"SUPDOS"
  If !fstat & [F:AD__]VALEUR<>""
   DOSX3 = [F:AD__]VALEUR
   Call MACHINE(DOSDES,MACHINE,APPLI) From ORDSYS
   If APPLI<>DOSX3
    Local File =MACHINE+"@"+DOSX3+".ADOCCLB" [ADH3]
    Read [ADH3]ADH0=[F:ADO1]LAN;[F:ADO1]TYP;[F:ADO1]COD;[F:ADO1]LEV;[F:ADO1]SUBLEV
    If !fstat & [F:ADH3]TEXTE=[L]TEX
     CLB = 1
    Endif
    Close Local File [ADH3]
   Endif
  Endif
  Close Local File [AD__]
 Endif
 Break
Next ADO
If !DOC2 & DOC1
 # par sécurité, on vire le clob
 Delete [ADH2] Where LAN=GLANGUE & [F]TYP=[L]TYP & [F]COD=[L]COD & [F]LEV=[L]LEV & [F]SUBLEV=[L]SUBLEV
 If fstat=1
  GOK=-1 : GLOCK = "$ADOCCLB" : End
 Elsif fstat>5
  GOK = 0 : Call FSTA("ADH2") From GLOCK : End
 Endif
Endif
If MODIF
 Readlock [ADH2]ADH0=[F:ADO2]LAN;[F:ADO2]TYP;[F:ADO2]COD;[F:ADO2]LEV;[F:ADO2]SUBLEV
 If fstat=1
  GOK = -1 : GLOCK = "$ADOCCLB" : End
 Else
  [F:ADH2]TEXTE = [L]TEX
  If dim([F:ADH2]UPDUSR)>0    : [F:ADH2]UPDUSR    = GUSER                                        : Endif
  If dim([F:ADH2]UPDDATTIM)>0 : [F:ADH2]UPDDATTIM = datetime$
    If dim([F:ADH2]UPDDAT)>0  : [F:ADH2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADH2]UPDDATTIM)  : Endif
  Else
    If dim([F:ADH2]UPDDAT)>0  : [F:ADH2]UPDDAT    = date$                                        : Endif
    If dim([F:ADH2]UPDTIM)>0  : [F:ADH2]UPDTIM    = time                                         : Endif
  Endif
  Rewrite [ADH2]
  If fstat
   GOK = 0 : Call FSTA("ADH2") From GLOCK : End
  Endif
 Endif
Elsif !CLB & !find([L]TEXTE,"","<P/>")
 If [L]LEV=0 and [L]SUBLEV=0
  [L]LEV    = 10
  [L]SUBLEV = 20
 Endif
 If !DOC2
  If DOC1
   [F:ADO2] = [F:ADO1]
  Else
   [F:ADO2]LAN = GLANGUE
   [F:ADO2]TYP = [L]TYP
   [F:ADO2]COD = [L]COD
   [F:ADO2]LEV = [L]LEV
   [F:ADO2]SUBLEV = [L]SUBLEV
   [F:ADO2]PAR = "PRE"
  Endif
  If dim([F:ADO2]CREUSR)>0    : [F:ADO2]CREUSR    = GUSER                                        : Endif
  If dim([F:ADO2]CREDATTIM)>0 : [F:ADO2]CREDATTIM = datetime$
    If dim([F:ADO2]CREDAT)>0  : [F:ADO2]CREDAT    = func SUBADC.DAT_DATETIME([F:ADO2]CREDATTIM)  : Endif
  Else
    If dim([F:ADO2]CREDAT)>0  : [F:ADO2]CREDAT    = date$                                        : Endif
    If dim([F:ADO2]CRETIM)>0  : [F:ADO2]CRETIM    = time                                         : Endif
  Endif
  Write [ADO2]
  If fstat
   GOK = 0 : Call FSTA("ADO2") From GLOCK : End
  Endif
 Endif
 Local File =DOSDES+".ADOVAL" [AD__]
 Read [AD__]ADW0="";"";"SUPDOS"
 If !fstat & [F:AD__]VALEUR<>""
  DOSX3 = [F:AD__]VALEUR
  Call MACHINE(DOSDES,MACHINE,APPLI) From ORDSYS
  If APPLI<>DOSX3
   Local File =MACHINE+"@"+DOSX3+".ADOCCLB" [ADH3]
   Read [ADH3]ADH0=GLANGUE;[L]TYP;[L]COD;[L]LEV;[L]SUBLEV
   If !fstat & [F:ADH3]TEXTE=[L]TEX
    CLB = 1
   Endif
   Close Local File [ADH3]
  Endif
 Endif
 Close Local File [AD__]
 If !CLB
  [F:ADH2]LAN = GLANGUE
  [F:ADH2]TYP = [L]TYP
  [F:ADH2]COD = [L]COD
  [F:ADH2]LEV = [L]LEV
  [F:ADH2]SUBLEV = [L]SUBLEV
  [F:ADH2]TEXTE  = [L]TEX
  If dim([F:ADH2]CREUSR)>0    : [F:ADH2]CREUSR    = GUSER                                        : Endif
  If dim([F:ADH2]CREDATTIM)>0 : [F:ADH2]CREDATTIM = datetime$
    If dim([F:ADH2]CREDAT)>0  : [F:ADH2]CREDAT    = func SUBADC.DAT_DATETIME([F:ADH2]CREDATTIM)  : Endif
  Else
    If dim([F:ADH2]CREDAT)>0  : [F:ADH2]CREDAT    = date$                                        : Endif
    If dim([F:ADH2]CRETIM)>0  : [F:ADH2]CRETIM    = time                                         : Endif
  Endif
  Write [ADH2]
  If fstat
   GOK = 0 : Call FSTA("ADH2") From GLOCK : End
  Endif
 Endif
Endif
End

#----------------------------------------------------------#
$TRTCOP
Local Char DOS_DES(250)  :  [L]DOS_DES=[M]DOSDES
If [M]DOSORG=nomap
 Local File ADOCUMENT [ADO1]
 Local File ADOCBLB   [ADB1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCBLB"   [ADB1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [L]DOS_DES=nomap
 Local File ADOCUMENT [ADO2]
 Local File ADOCBLB   [ADB2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[L]DOS_DES+".ADOCUMENT" [ADO2]
 Local File =[L]DOS_DES+".ADOCBLB"   [ADB2]
 Local File =[L]DOS_DES+".ADOCCLB"   [ADH2]
Endif
Local Integer I , J , OK
Local Char    CRITLAN(250) , CRITCOD(250) , MESSA(250), CRITLEV(250)
Local Char    OLD_LAN(GLONLAN), OLD_TYP(GLONADI), OLD_COD(50)

Raz CRITLAN , CRITCOD, CRITLEV
If TABLE<>""  : CRITLAN = 'LAN = "'+TABLE+'"' : Endif
If TABLE2<>"" : CRITCOD = 'TYP = "'+TABLE2+'"' : Endif
If TABLE3<>""
 If CRITCOD<>"" : CRITCOD -= "&" : Endif
 CRITCOD -= 'COD = "'+TABLE3+'"'
Endif
MESSA = CRITLAN-CRITCOD
If CRITLAN="" : CRITLAN = "1=1" : Endif
If CRITCOD="" : CRITCOD = "1=1" : Endif
If CRITLEV="" : CRITLEV = "1=1" : Endif
OK = 1
If GTRACE=""
 # Voulez-copier tous les paragraphes de la documentation
 Gosub TRTCOP_OPT
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ADO1], [ADB1], [ADH1]
&              , [ADO2], [ADB2], [ADH2]
Return

$TRTCOP_OPT
 #JPGA 27/05/2010 BUG-56629 : Implementaton du choix de Copie : Tous les Paragraphes ou 1 seul
 Local Mask ADOCCOP [DIA2]
 If dim([V]DIA2_CLE2)<=0 : Global Char DIA2_CLE2(30) : Endif
 If dim(WTILD)<=0        : Local Char  WTILD(1)  : [L]WTILD="~" : Endif
 [M:DIA2]TYPCOP=1
 [M:DIA2]CLE1=TABLE+[L]WTILD+TABLE2+[L]WTILD+TABLE3
 [M:DIA2]CLE2=TABLE4
 [V]DIA2_CLE2=TABLE4
 Filter [ADO1] Where evalue(CRITLAN) & evalue(CRITCOD)
 I = rowcount([F:ADO1])
 Filter [ADO1]

 Call DIALWIN(OK,mess(27,75,1)-MESSA-"("+num$(I)-"§)","ADOCCOP") From GESECRAN : # Options de copie
 #OK=1 : Call AVERTIR(MESSA+"\"+mess(32,176,1)-"("+num$(I)+")",OK) From GESECRAN
 If OK<>2
    OK = 0
 Else
    # Copie de tous les paragraphes si TYPCOP<>2  sinon Copie de 1 seul paragraphe
    If [M:DIA2]TYPCOP = 2
       I = instr(1,[M:DIA2]CLE2,[L]WTILD)
       If I
          [L]CRITLEV='LEV='+left$([M:DIA2]CLE2,I-1)+' & SUBLEV='+right$([M:DIA2]CLE2,I+1)
       Endif
    Else
       [L]CRITLEV = "1=1"
    Endif
 Endif
 Close Mask [DIA2]
 Kill [V]DIA2_CLE2
Return

$TR_COP
GOK = 1
 Trbegin [ADO2] , [ADB2] , [ADH2]
 Delete [ADO2] Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOS_DES+".ADOCUMENT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADO2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ADB2] Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOS_DES+".ADOCBLB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ADH2] Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOS_DES+".ADOCCLB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADH2","") From GLOCK : Goto AB_TR_COP
 Endif

 [L]OLD_LAN="" : [L]OLD_TYP="" : [L]OLD_COD=""
 For [ADO1]ADO0 Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
  [F:ADO2] = [F:ADO1]
  If dim([F:ADO2]UPDUSR)>0    : [F:ADO2]UPDUSR    = GUSER                                        : Endif
  If dim([F:ADO2]UPDDATTIM)>0 : [F:ADO2]UPDDATTIM = datetime$
    If dim([F:ADO2]UPDDAT)>0  : [F:ADO2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADO2]UPDDATTIM)  : Endif
  Else
    If dim([F:ADO2]UPDDAT)>0  : [F:ADO2]UPDDAT    = date$                                        : Endif
    If dim([F:ADO2]UPDTIM)>0  : [F:ADO2]UPDTIM    = time                                         : Endif
  Endif
  Write [ADO2]
  If fstat
   GOK=0 : Call FSTA("ADO2") From GLOCK : Break
  Endif
  #JPGA 01/08/2012 EXI-79953-8 : Cas de Copie vers dossier de type SUPERV : Lancement du marquage pour pouvoir ensuite Pousser
  If  [ADO1]LAN<>[L]OLD_LAN | [ADO1]TYP<>[L]OLD_TYP | [ADO1]COD<>[L]OLD_COD
    If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
    [L]DOC_CLE1=[ADO2]TYP  :  [L]DOC_CLE2(0)=[ADO2]LAN  :  [L]DOC_CLE2(1)=[ADO2]COD
    Call MARQUAGE_SUPERV([L]DOS_DES, "ADO", [L]DOC_CLE1, [L]DOC_CLE2, [L]ACOPMARQFLG) From AGENLIBA
  Endif
  [L]OLD_LAN=[ADO1]LAN : [L]OLD_TYP=[ADO1]TYP : [L]OLD_COD=[ADO1]COD
 Next ADO1
 If GOK<1 : Goto AB_TR_COP : Endif
 For [ADB1]ADB0 Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
  [F:ADB2] = [F:ADB1]
  If dim([F:ADB2]UPDUSR)>0    : [F:ADB2]UPDUSR    = GUSER                                        : Endif
  If dim([F:ADB2]UPDDATTIM)>0 : [F:ADB2]UPDDATTIM = datetime$
    If dim([F:ADB2]UPDDAT)>0  : [F:ADB2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADB2]UPDDATTIM)  : Endif
  Else
    If dim([F:ADB2]UPDDAT)>0  : [F:ADB2]UPDDAT    = date$                                        : Endif
    If dim([F:ADB2]UPDTIM)>0  : [F:ADB2]UPDTIM    = time                                         : Endif
  Endif
  Write [ADB2]
  If fstat
   GOK=0 : Call FSTA("ADB2") From GLOCK : Break
  Endif
 Next ADB1
 If GOK<1 : Goto AB_TR_COP : Endif
 For [ADH1]ADH0 Where evalue(CRITLAN) & evalue(CRITCOD) & evalue(CRITLEV)
  [F:ADH2] = [F:ADH1]
  If dim([F:ADH2]UPDUSR)>0    : [F:ADH2]UPDUSR    = GUSER                                        : Endif
  If dim([F:ADH2]UPDDATTIM)>0 : [F:ADH2]UPDDATTIM = datetime$
    If dim([F:ADH2]UPDDAT)>0  : [F:ADH2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADH2]UPDDATTIM)  : Endif
  Else
    If dim([F:ADH2]UPDDAT)>0  : [F:ADH2]UPDDAT    = date$                                        : Endif
    If dim([F:ADH2]UPDTIM)>0  : [F:ADH2]UPDTIM    = time                                         : Endif
  Endif
  Write [ADH2]
  If fstat
   GOK=0 : Call FSTA("ADH2") From GLOCK : Break
  Endif
 Next ADH1
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#----------------------------------------------------------#
## Etiquettes ADO1
#----------------------------------------------------------#

Subprog D_TIT(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"ATABDIV","LNGDES","911",[M]PAR) From ATEXTRA
End

Subprog S_MSK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
Case [M]TYP
 When "AFC"
  PARMSK(1) = [M]COD
  Call S_LIS_CHAR(VALEUR,PARMSK,"SELAMKAFC","SUBADO","") From GACTION
 When Default
  PARMSK(1) = "AMK"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Endcase
End

Subprog C_MODULE(VALEUR)
Variable Integer VALEUR
Gosub VERDOC From AGENDOCA
If IF_DOCV5
   Look [ADH]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
   If !fstat : mkstat = 4 : Endif
Endif
End

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Char TEXTE1(80)(1..10000)
Local Char CH1,CH2,CH3,CH4,CH5
Local Integer IMOD , OK
[M]TEXTE = VALEUR
Look [ADH]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
If fstat
 Look [ADHX]ADH0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
 If !fstat
  Call AVERTIR(mess(132,139,1),OK) From GESECRAN : # Voulez-vous modifier cette aide standard
  If OK<>2
   [M]TEXTE = [F:ADHX]TEXTE
   VALEUR = [F:ADHX]TEXTE
   Affzo TEXTE
   End
  Endif
 Endif
Endif
CH1=[M]TYP : CH2=[M]COD : CH3=""
Gosub REP_NOM_FIC From AGENADO
Call MAJ_LIENS([M]TEXTE,[M]TYP,CH4,GERR,GMESSAGE,TEXTE1,IMOD) From AGENDOCA
If IMOD
 Setlob [M]TEXTE With TEXTE1(1..10000)
Endif
VALEUR = [M]TEXTE
End

Subprog C_TIT(VALEUR)
Variable Char    VALEUR()
If pat(VALEUR,"*<*")
 GMESSAGE="< :"-mess(94,123,1)
 mkstat=2
Elsif pat(VALEUR,"*>*")
 GMESSAGE="> :"-mess(94,123,1)
 mkstat=2
Elsif pat(VALEUR,'*"*')
 GMESSAGE='" :'-mess(94,123,1)
 mkstat=2
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ADO1) 10/01/2008 16:38:44 (VPO)
######################################################################################
# VPO 10/01/08 39714
Subprog GRISE_MSK(PAR)
Variable Char    PAR()
#If find(PAR,"TIT","PRE","LNK","MIS","MIN")
#VPO 31/07/08 48608 autoriser ecran sur MIS ou MIN
If find(PAR,"TIT","PRE","LNK")
Effzo [M:ADO1]MSK
Grizo [M:ADO1]MSK
Else
Actzo [M:ADO1]MSK
Endif
End

Subprog AP_PAR(VALEUR)
Variable Char    VALEUR()
Call GRISE_MSK(VALEUR)
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Char       DOC_CODE(30), DOC_TYPE(GLONADI)

  DOC_CODE = VALEUR
  DOC_TYPE = [M]TYP

  # JPGA 29/09/2010 Bug-67745 : Controle pour les doc de TYPE DI qui vont dans le répertoire FCT : Nécessité d'avoir _ dedans pour ne pas écraser une fonction
  # Des docs ont déjà été créées sans _ et existent déjà =>GREP n'étant pas encore initialisé, Test sur la présence de l'enreg plutot aus Création/Duplication
  #If GREP="C" or GREP="D"
  Look [ADO]ADO0(3)=[M]LAN;[M]TYP;[L]DOC_CODE
  If fstat
     Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
     If find([L]DOC_TYPE, "DI")  &  !instr(0, [L]DOC_CODE, [L]WTIRET)
        GMESSAGE=mess(42,0,1)-[L]DOC_TYPE-':'-mess(117,141,1)-[L]WTIRET
        mkstat=2  :  End
     Endif
  Endif

  # JPGA 19/08/2009 Bug-52238 : Controle sur clé multiple si c'est le cas
  Gosub DOC_CONT_CLE_MULTIPLE  From AGENLIBA
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCCOP) 27/05/2010 10:15:21 (JPGA)
######################################################################################
Subprog AS_TYPCOP(VALEUR)
Variable Integer VALEUR
  Gosub GRISE_TYPCOR
End

Subprog AM_TYPCOP(VALEUR)
Variable Integer VALEUR
  Gosub GRISE_TYPCOR
End

$GRISE_TYPCOR
   If VALEUR<2
      Effzo [M:DIA2]CLE2
      Grizo [M:DIA2]CLE2
   Else
     [M:DIA2]CLE2=[V]DIA2_CLE2
      Actzo [M:DIA2]CLE2
   Endif
Return
