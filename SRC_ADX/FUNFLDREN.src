#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "DEBUT" : Gosub DEBUT
  When "OK"    : Gosub OK
  When Default
Endcase

Return
######################################################################################
######################################################################################
$DEBUT

Raz   [M:DIA]
Affzo [M:DIA]

Return
######################################################################################
######################################################################################
$OK

If [M:DIA]VCRNUM = "" : Return : Endif

Local Char SYMBOLE

SYMBOLE = [M:DIA]VCRNUM
Lock = SYMBOLE
If fstat
  # Opération en cours sur autre poste
  Call ECR_TRACE([M:DIA]VCRNUM - mess(69,7775,1),1) From GESECRAN
  Return
Endif

If [M:DIA]BPRTYP=1
    If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
    Read [F:SIH] SIH0 = [M:DIA]VCRNUM
    If !fstat
        Trbegin [F:SIH]
        If [M:DIA]FLD40REN <> ''
            [F:SIH]FLD40REN = [M:DIA]FLD40REN
        Endif
        If [M:DIA]FLD41REN <> ''
            [F:SIH]FLD41REN= [M:DIA]FLD41REN
        Endif
        Rewrite [F:SIH]
        If !fstat : Commit : Call ECR_TRACE(mess(12,107,1)-tolower(mess(1,718,1)),0) From GESECRAN : Else : Rollback : Endif
    Endif
Elsif [M:DIA]BPRTYP=2
    If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
    Read [F:PIH] PIH0 = [M:DIA]VCRNUM
    If !fstat
        Trbegin [F:PIH]
        If [M:DIA]FLD40REN <> ''
            [F:PIH]FLD40REN = [M:DIA]FLD40REN
        Endif
        If [M:DIA]FLD41REN <> ''
            [F:PIH]FLD41REN= [M:DIA]FLD41REN
        Endif
        Rewrite [F:PIH]
        If !fstat : Commit : Call ECR_TRACE(mess(12,107,1)-tolower(mess(1,718,1)),0) From GESECRAN : Else : Rollback : Endif
    Endif
Endif

Unlock =SYMBOLE

Return
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

Raz   [M]VCRNUM
Affzo [M]VCRNUM

End
######################################################################################
######################################################################################
Subprog AM_BPRTYP(VALEUR)
Variable Integer VALEUR

Raz   [M]VCRNUM, [M]BPR
Affzo [M]VCRNUM, BPR

Call DEF_OBJ([M]MODULE,VALEUR)

End
######################################################################################
######################################################################################
Subprog C_BPR(VALEUR)
Variable Char    VALEUR()

#Raz   [M]VCRNUM
#Affzo [M]VCRNUM

End
######################################################################################
######################################################################################
Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()

Raz   [M]VCRNUM
Affzo [M]VCRNUM

End
######################################################################################
######################################################################################
Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR

Raz GMENLOC
Local Integer I
Local Shortint DISP(2)
[L]DISP(0) = 3
If [M]BPRTYP = 1
  [L]DISP(1) = 5
Else
  [L]DISP(1) = 6
Endif

For I = 0 To dim(GMENLOC)-1
  If !find(I,DISP)
    GMENLOC(I)=1
    GMENLOC(I)=1
  Endif
Next

End
######################################################################################
######################################################################################
Subprog AM_MODULE(VALEUR)
Variable Integer VALEUR

Call DEF_OBJ(VALEUR, [M]BPRTYP)

End
######################################################################################
######################################################################################
Subprog C_VCRTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif

If !clalev([CPY]) : Local File COMPANY [CPY] : Endif
Local Integer RETVAL(1)
Local Char DOSLEG

Read[F:CPY]CPY0 = [M:DIA]CPY
If !fstat
  [L]DOSLEG = [F:CPY]LEG
Endif

Case [M]BPRTYP
  When 1
    If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
    #Verify Customer invoice type table
    Call LEC_TSV_LEG([L]DOSLEG,VALEUR,RETVAL) From TRTLECLEG
  When 2
    If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif
    #Verify Supp invoice type table
    Call LEC_TPV_LEG([L]DOSLEG,VALEUR,RETVAL) From TRTLECLEG
Endcase

If [L]RETVAL
    mkstat = 2
    Call ECR_TRACE(VALEUR - ":" - mess(17,114,1) , 1) From GESECRAN
Endif

End
######################################################################################
######################################################################################
Subprog AM_VCRTYP(VALEUR)
Variable Char    VALEUR()

Raz   [M]VCRNUM
Affzo [M]VCRNUM

End
######################################################################################
######################################################################################
Subprog AS_VCRNUM(VALEUR)
Variable Char    VALEUR()

[M]VCRCRIT = 'CPY="'+[M]CPY+'"'

Case [M]BPRTYP
  When 1
    If [M]VCRTYP <> ''
      [M]VCRCRIT += ' & SIVTYP="'+[M]VCRTYP+'"'
    Endif
    Case [M]MODULE
      When 3
        If [M]BPR <> ''
          [M]VCRCRIT += ' & BPR="'+[M]BPR+'"'
        Endif
        If [M]STRDAT <> [0/0/0]
          [M]VCRCRIT += '& ACCDAT>=['+format$(GFMD,[M]STRDAT)+']'
        Endif
        If [M]ENDDAT <> [0/0/0]
          [M]VCRCRIT += '& ACCDAT<=['+format$(GFMD,[M]ENDDAT)+']'
        Endif
      When 5
        If [M]BPR <> ''
          [M]VCRCRIT += ' & BPCINV="'+[M]BPR+'"'
        Endif
        If [M]STRDAT <> [0/0/0]
          [M]VCRCRIT += '& INVDAT>=['+format$(GFMD,[M]STRDAT)+']'
        Endif
        If [M]ENDDAT <> [0/0/0]
          [M]VCRCRIT += '& INVDAT<=['+format$(GFMD,[M]ENDDAT)+']'
        Endif
    Endcase
  When 2
    If [M]VCRTYP <> ''
      [M]VCRCRIT += ' & PIVTYP="'+[M]VCRTYP+'"'
    Endif
    If [M]STRDAT <> [0/0/0]
      [M]VCRCRIT += '& ACCDAT>=['+format$(GFMD,[M]STRDAT)+']'
    Endif
    If [M]ENDDAT <> [0/0/0]
      [M]VCRCRIT += '& ACCDAT<=['+format$(GFMD,[M]ENDDAT)+']'
    Endif
    If [M]BPR <> ''
      [M]VCRCRIT += ' & BPR="'+[M]BPR+'"'
    Endif
Endcase

End
######################################################################################
######################################################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Read [F:CPY]CPY0 = [M]CPY
If fstat : Raz [F:CPY] : Endif

If [M:DIA]BPRTYP=1
    If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
    Read [F:SIH] SIH0 = VALEUR
    If !fstat
      Local Char HS(1)
# Issue 115715 - 2016-04-22 by RICAR : POR Leg.: debit notes without reference period
# Issue 115715
#      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:SIH]VAC,1,[F:SIH]INVTYP,40)
      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:SIH]VAC,1,[F:SIH]SIVTYP,40)
      If [L]HS = "-" : Raz [M]FLD40REN : Endif
      Chgfmt [M]FLD40REN With [L]HS+"K:5X"
#      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:SIH]VAC,1,[F:SIH]INVTYP,41)
      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:SIH]VAC,1,[F:SIH]SIVTYP,41)
# End issue 115715
      If [L]HS = "-" : Raz [M]FLD41REN : Endif
      Chgfmt [M]FLD41REN With [L]HS+"K:5X"
    Endif
Elsif [M:DIA]BPRTYP=2
    If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
    Read [F:PIH] PIH0 = VALEUR
    If !fstat
      Local Char HS(1)
# Issue 115715
#      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:PIH]VAC,2,[F:PIH]INVTYP,40)
      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:PIH]VAC,2,[F:PIH]PIVTYP,40)
      If [L]HS = "-" : Raz [M]FLD40REN : Endif
      Chgfmt [M]FLD40REN With [L]HS+"K:5X"
#      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:PIH]VAC,2,[F:PIH]INVTYP,41)
      [L]HS = func PORLEGLIB.SHWHID4041([F:CPY]LEG,[F:PIH]VAC,2,[F:PIH]PIVTYP,41)
# End issue 115715
      If [L]HS = "-" : Raz [M]FLD41REN : Endif
      Chgfmt [M]FLD41REN With [L]HS+"K:5X"
    Endif
Endif

End
######################################################################################
######################################################################################
Subprog DEF_OBJ (A_MODULE, A_BRPTYP)
Value Integer A_MODULE
Value Integer A_BRPTYP

Raz [M]OBJ

Case A_BRPTYP
  When 1
    Case A_MODULE
      When 3
        [M]OBJ = "BIC"
      When 5
        [M]OBJ = "SIH"
    Endcase
  When 2
    Case A_MODULE
      When 3
        [M]OBJ = "BIS"
      When 6
        [M]OBJ = "PIH"
    Endcase
Endcase

End
######################################################################################
######################################################################################

