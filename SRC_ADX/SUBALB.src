#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ALB",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "LIENS0"    : Gosub LIENS0
 When "LIENS"     : Gosub LIENS
 When "LIENS2"    : Gosub LIENS2
Endcase
Return

$LIENS0
[M]CRYTYP = [F]CRY+"~"+num$([F]TYP)
Return

$LIENS
Call LECTEXTRA([M]INTIT(nolign-1),"TABSUBDIV","INTIT",[M]CRYTYP,[M]COD(nolign-1)) From ATEXTRA
Return

$LIENS2
Call INTIT_COL([M]CRY,[M]TYP,[M]INTCOD,[M]INTINT)
Return

Subprog INTIT_COL(CRY,TYP,INTCOD,INTINT)
Value Char CRY
Value Integer TYP
Variable Char INTCOD , INTINT
Local Char    INTIT(80)
If [F:TCY]CRY<>CRY
 Call LECTURE("TCY",CRY,"") From CONTOBJ
Endif
If [F:TCY]CRY=CRY
 Case TYP
  When 2
   Call LECTEXTRA(INTIT,"TABCOUNTRY","ETATNAM",CRY,"") From ATEXTRA
  When 3
   Call LECTEXTRA(INTIT,"TABCOUNTRY","ETATNAM2",CRY,"") From ATEXTRA
 Endcase
 INTCOD = func AFNC.MES(mess(211,139,1),INTIT)
 INTINT = func AFNC.MES(mess(212,139,1),INTIT)
Endif
End

######################################################################################
Funprog CODSDV1(CRY,POS)
Value Char CRY , POS
Gosub SDV1
End CODSDV

$SDV1
Local Integer TYP
TYP = 2

If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ALB1])=0 : Local File ALNKSUB [ALB1] : Endif
Local Char CODSDV(10)
If [F:TCY]CRY<>CRY
    Read [TCY]TCY0 = CRY
Endif
If [F:TCY]CRY=CRY & ((TYP=2 & [F:TCY]ETATFLG=2) or (TYP=3 & [F:TCY]ETATFLG2=2))
 If [F:ALB1]CRY=[L]CRY & [F:ALB1]TYP=[L]TYP & pat([L]POS,[F:ALB1]POS)
       CODSDV = [F:ALB1]COD
 Else
     For [ALB1] Where [F]CRY=[L]CRY & [F]TYP=[L]TYP
      If pat([L]POS,[F:ALB1]POS)
       CODSDV = [F:ALB1]COD : Break
      Endif
     Next ALB1
 Endif
Endif
Return

Funprog CODSDV2(CRY,POS)
Value Char CRY , POS
Gosub SDV2
End CODSDV

$SDV2
Local Integer TYP
TYP = 3

If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ALB2])=0 : Local File ALNKSUB [ALB2] : Endif
Local Char CODSDV(10)
If [F:TCY]CRY<>CRY
    Read [TCY]TCY0 = CRY
Endif
If [F:TCY]CRY=CRY & ((TYP=2 & [F:TCY]ETATFLG=2) or (TYP=3 & [F:TCY]ETATFLG2=2))
 If [F:ALB2]CRY=[L]CRY & [F:ALB2]TYP=[L]TYP & pat([L]POS,[F:ALB2]POS)
       CODSDV = [F:ALB2]COD
 Else
     For [ALB2] Where [F]CRY=[L]CRY & [F]TYP=[L]TYP
      If pat([L]POS,[F:ALB2]POS)
       CODSDV = [F:ALB2]COD : Break
      Endif
     Next ALB2
 Endif
Endif
Return

Funprog NAMSDV1(CRY,POS)
Value Char CRY , POS
Local Char COD(10) , NAMSDV(80)
##COD = func CODSDV1(CRY,POS)
Gosub SDV1
If CODSDV <>""
 Call LECTEXTRA(NAMSDV,"TABSUBDIV","INTIT",CRY+"~2",CODSDV ) From ATEXTRA
Endif
End NAMSDV

Funprog NAMSDV2(CRY,POS)
Value Char CRY , POS
Local Char COD(10) , NAMSDV(80)
##COD = func CODSDV2(CRY,POS)
Gosub SDV2
If CODSDV <>""
 Call LECTEXTRA(NAMSDV,"TABSUBDIV","INTIT",CRY+"~3",CODSDV ) From ATEXTRA
Endif
End NAMSDV

######################################################################################
Subprog AS_TYP(VALEUR)
Variable Integer  VALEUR
GMENLOC(1) = 1
If [F:TCY]CRY<>[M]CRY
 Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
Endif
If [F:TCY]ETATFLG<>2 : GMENLOC(2) = 1 : Endif
If [F:TCY]ETATFLG2<>2 : GMENLOC(3) = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
[M]CRYTYP = [M]CRY+"~"+num$([M]TYP)
Call INTIT_COL([M]CRY,VALEUR,[M]INTCOD,[M]INTINT)
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
If [F:TCY]CRY<>VALEUR
 Call LECTURE("TCY",VALEUR,"") From CONTOBJ
Endif
If [F:TCY]ETATFLG<>2 & [F:TCY]ETATFLG2<>2
 GMESSAGE = VALEUR-":"-mess(213,139,1) : # Ce pays ne permet pas de gérer les subdivisions
 mkstat = 2 : End
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Read [ATU]ATU0=[M]CRY;[M]TYP;VALEUR
If !fstat
 Call LECTEXTRA([M]INTIT(nolign-1),"TABSUBDIV","INTIT",[M]CRYTYP,VALEUR) From ATEXTRA
Endif
End

