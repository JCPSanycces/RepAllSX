# Gestion du masque MWANL

##########################################################################
## Etiquette ajoutée par le superviseur 04/09/2003 10:14:42 (MM)
##########################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM From FUNWANL
Endif            
End

Subprog AM_CLCANA(VALEUR)
Variable Integer VALEUR
Local Date    LASTMONTH 

Case VALEUR
    When 1: [M:DIA]STRANA = [0/0/0]
    When 2: LASTMONTH = addmonth(date$,-1)
            [M:DIA]STRANA = gdat$(1,month(LASTMONTH),year(LASTMONTH))
Endcase
Affzo [M:DIA]STRANA
End

Subprog AM_WCRDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]WCRFIN = VALEUR : Endif
End

Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]WSTFIN = VALEUR : Endif
End

Subprog C_STRANA(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]MSTDAT : mkstat = 2 : Endif
End



