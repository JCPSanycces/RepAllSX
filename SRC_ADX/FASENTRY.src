#<AdxTL>@(#)0.0.0.0 $Revision$
#** ####################################################################################################################
#*
#* Label      : action
#* Purpose    : standard entry point
#*
#####################################################################################################################
$ACTION
  Case ACTION
    When "FIN"   : Gosub FIN
    When Default :
  Endcase
Return

#** ####################################################################################################################
#*
#* Label      : fin
#* Purpose    : will unlock the FASENTRY object
#*
#*! ####################################################################################################################
$FIN
  Unlock FASENTRY
Return

#** ####################################################################################################################
#*
#* SubProg    : IMPRIME
#* Purpose    : called just before the printing of the document by Crystal Reports
#*
#* Parameters :
#*   @param count  : value integer          - number of parameters
#*   @param params : variable char()(1 .. ) - parameters grid
#*
#*! ####################################################################################################################
Subprog IMPRIME(COUNT, PARAMS)
  Value Integer COUNT
  Variable Char PARAMS()(1 .. )
  Local Char PARAM(255)
  Local Char CPY(GLONCPY) : # FQ102999 5->GLONCPY
  Local Char FCY(GLONFCY) : # FQ102999 5->GLONFCY
  Local Date DATSTR
  Local Date DATEND
  Local Integer PLAN
  Local Integer N

  GOK = 0

  # lock the FASENTRY object
  Lock FASENTRY With lockwait = 3
  If fstat Then
    # message: Required resource is locked by another process
    Call ECR_TRACE(mess(00206,09137,1), 1) From GESECRAN
    End
  Endif

  CPY    = func GET_PARAM("cpy", PARAMS, COUNT)
  PARAM  = func GET_PARAM("datstr", PARAMS, COUNT)
  DATSTR = gdat$(PARAM)
  PARAM  = func GET_PARAM("datend", PARAMS, COUNT)
  DATEND = gdat$(PARAM)

  # open tables
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS]) = 0 Then : Local File FISCYEAR [FIS] : Endif

  Link [CNX] With [FIS]FIY0 = [F:CNX]CPY;[F:CNX]CNX
&   As [LNK]
&   Where [F:CNX]CPY = [L]CPY
&   Order By [F:FIS]DATSTRFIY
  For [LNK]
    # fiscal year
    If [L]DATSTR = [F:FIS]DATSTRFIY and [L]DATEND = [F:FIS]DATENDFIY Then
      GOK = 1
    Endif
  Next

  # close tables
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif
  If clalev([F:FIS]) <> 0 Then : Close Local File [FIS] : Endif

  If GOK = 0 Then
    Call ECR_TRACE(mess(1010,2299,1), 1) From GESECRAN
  Else
    # check number of records
    FCY   = func GET_PARAM("fcy",  PARAMS, COUNT)
    PARAM = func GET_PARAM("plan", PARAMS, COUNT)
    PLAN = val(PARAM)
    N = func GET_RECORDS_COUNT(CPY, FCY, PLAN, DATSTR, DATEND)
    If N = 0 Then
      Call ECR_TRACE(mess(1009,2299,1), 1) From GESECRAN
      GOK = 0
    Endif
  Endif
End

#** ####################################################################################################################
#*
#* FunProg    : get_param
#* Purpose    : obtain the value of a parameter
#* Return     : char() - empty if the parameter is missing
#*
#* Parameters :
#*   @param name   : value char()           - parameter name
#*   @param params : variable char()(1 .. ) - parameters grid
#*   @param count  : value integer          - number of parameters
#*
#*! ####################################################################################################################
Funprog GET_PARAM(NAME, PARAMS, COUNT)
  Value Char NAME()
  Variable Char PARAMS()(1 .. )
  Value Integer COUNT
  Local Integer N
  Local Integer I

  N = len(NAME)
  For I = 1 To COUNT
    If left$(PARAMS(I), N + 1) = (NAME + "=") Then
      End right$(PARAMS(I), N + 2)
    Endif
  Next
End ""

#** ####################################################################################################################
#*
#* FunProg    : get_records_count
#* Purpose    : obtain the records count based on the current selection criteria
#* Return     : integer - records count
#*
#* Parameters :
#*   @param company : value char()  - company name
#*   @param site    : value char()  - company site
#*   @param plan    : value integer - depreciation plan
#*   @param datstr  : value date    - start date
#*   @param datend  : value date    - end date
#*
#*! ####################################################################################################################
Funprog GET_RECORDS_COUNT(COMPANY, SITE, PLAN, DATSTR, DATEND)
  Value Char COMPANY()
  Value Char SITE()
  Value Integer PLAN
  Value Date DATSTR
  Value Date DATEND
  Local Integer RESULT

  # open tables
  If clalev([F:FLU]) = 0 Then : Local File FXDLIFL   [FLU] : Endif
  If clalev([F:FAS]) = 0 Then : Local File FXDASSETS [FAS] : Endif

  If SITE = "" Then
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  ""
&       and [F:FLU]STRDPRDAT >= DATSTR
&       and [F:FLU]STRDPRDAT <= DATEND
&       and [F:FLU]FIYSTRDAT =  DATSTR
&       and [F:FLU]FIYENDDAT =  DATEND
&       and [F:FLU]PERSTRDAT =  [0/0/0]
&       and [F:FLU]PERENDDAT =  [0/0/0]
&     Order By [F:FLU]GAC;[F:FLU]AASREF
  Else
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  ""
&       and [F:FLU]STRDPRDAT >= DATSTR
&       and [F:FLU]STRDPRDAT <= DATEND
&       and [F:FLU]FIYSTRDAT =  DATSTR
&       and [F:FLU]FIYENDDAT =  DATEND
&       and [F:FLU]PERSTRDAT =  [0/0/0]
&       and [F:FLU]PERENDDAT =  [0/0/0]
&     Order By [F:FLU]GAC;[F:FLU]AASREF
  Endif

  RESULT = rowcount([LNK])

  # close tables
  If clalev([F:FLU]) <> 0 Then : Close Local File [FLU] : Endif
  If clalev([F:FAS]) <> 0 Then : Close Local File [FAS] : Endif
End RESULT
