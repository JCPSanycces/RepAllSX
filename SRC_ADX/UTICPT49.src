#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTICPT49   For Bug file N°75140                             Module CPT #
# Recover of the text traduction data for the Group Description field in #
# the Financial data extraction's fonction                               #                                                 
##########################################################################

Local Char DOSSIER(30) : 
#DOSSIER = nomap

If DOSSIER = ""
 Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Recover ATEXTRA datas for the GRPDES field of TXSA table") From LECFIC
  Call MAJ_UTICPT49(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT49(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR,CPTDEL

Call ECR_TRACE("UTICPT49 : Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#

Local File =DOSSIER+".TXSA"    [TXS]
Local File =DOSSIER+".TXSA"    [TX2]
Local File =DOSSIER+".ATEXTRA" [AXX]
Local File =DOSSIER+".ATEXTRA" [AX2]
Local File =DOSSIER+".TABLAN"  [TLA]

Trbegin [AX2]

#Récupération/Ecriture des ATEXTRAs pour et avec les noms de groupe
#Recover/Write of ATEXTRAs for & with group names
For [TLA]TLA0 
 For [TXS]TXS0(1) Where LSTGRP<>""
  Readlock [AXX]AXX0 = "TXSA";"GRPDES";[F:TLA]LAN;[F:TXS]TXSNAM;""
  If !fstat
   Look [AX2]AXX0 = "TXSA";"GRPDES";[F:TLA]LAN;[F:TXS]LSTGRP;""
   If fstat
    Raz [AX2]
    [F:AX2]=[F:AXX]
    [F:AX2]UPDDAT = date$
    [F:AX2]UPDTIM = time
    [F:AX2]UPDUSR = GUSER
    [F:AX2]IDENT1=[F:TXS]LSTGRP
    Write [AX2]
    If !fstat
     COMPTEUR +=1
    Else
     GOK = 0 
     #Erreur d'écriture
     Call ECR_TRACE(mess(26,125,1)-"ATEXTRA : TXSA GRPDES"-[F:TLA]LAN-[F:TXS]LSTGRP,-1) From GESECRAN
     Goto AB_UTICPT49
    Endif
   Endif
  Endif
 Next
Next

#Suppresion des ATEXTRAs inutiles / Delete unusfull old ATEXTRAs
For [TXS]
 Look [TX2]TXS0(1) = [F:TXS]TXSNAM
 If fstat
  Call SUPTEXTRA("TXSA","GRPDES",[F:TXS]TXSNAM,"") From ATEXTRA
 Endif
Next

Commit
Call ECR_TRACE("UTICPT49 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End


$AB_UTICPT49
Rollback
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TXSA","fde",APPLI),0)<=0    : End : Endif
If filinfo(filpath("FIL","TABLAN","fde",APPLI),0)<=0  : End : Endif          
Call MAJ_UTICPT49(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif   
If filinfo(filpath("FIL","TXSA","fde",APPLI),0)<=0    : End : Endif
If filinfo(filpath("FIL","TABLAN","fde",APPLI),0)<=0  : End : Endif
Call MAJ_UTICPT49(APPLI)
End

