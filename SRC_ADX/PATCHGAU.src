#<AdxTL>@(#)2.0.0.0 $Revision$
#############################################
##  Intégration d'une pièce automatique
#############################################

$PIECE
#############################################
## On ne l'intègre que dans le superviseur
#############################################
Gosub TSTSUP
If !OK
 Gosub FIN_OBJ From PATCH
 Goto FIN_GAU
Endif

Read [GAU]GAU0 = NOMOBJ
If fstat
 NEWOBJ = 1
 Raz [F:GAU]
Elsif [F:GAU]CODACT>="X" & !find([F:GAU]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Goto FIN_GAU
Else
 NEWOBJ = 0
Endif
Call DEBTRANS From GLOCK
Gosub TR_GAU

FIN_GAU
Close Local File [GAU],[GAD],[GAG]
If clalev([GVV]) : Close Local File [GVV] : Endif
Return

$TSTSUP
OK = 0
If filinfo(filpath("FIL","GAUTACE","fde",APPLI),0)>=0
 Local File =APPLI+".GAUTACE"   [GAU]
 Local File =APPLI+".GAUTACED"  [GAD]
 Local File =APPLI+".GAUTACEF"  [GAG]
Endif
If filinfo(filpath("FIL","GVARPARVAL","fde",APPLI),0)>=0
 Local File =APPLI+".GVARPARVAL"[GVV]
Endif
# Dans le dossier X3, on intègre toujours
If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>=0
 OK = 1 : Return
Endif
# Dans un dossier "test" aussi
Read [ADW]ADW0 = "";"";"TEST"
If !fstat & val([F:ADW]VALEUR)=2
 OK = 1 : Return
Endif
# Si le nom du patch commence par src, aussi
If pat(toupper(TRAIT(P)),"SRC*")
 OK = 1 : Return
Endif
# Si l'objet est spécifique et qu'il existe ou que c'est un dossier spécif, aussi
If find(left$(NOMOBJ,1),"X","Y","Z")
 Read [GAU]GAU0 = NOMOBJ
 If !fstat
  OK = 1 : Return
 Else
  Read [ADW]ADW0 = "";"";"SPECIF"
  If !fstat & val([F:ADW]VALEUR)=2
   OK = 1 : Return
  Endif
 Endif
Endif
Return

$TR_GAU
Trbegin [GAU] , [GAD] , [GAG]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout de pièce
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "GAU"   : Gosub GAU1
     When "GAD"   : Gosub GAU2
     When "GAG"   : Gosub GAU3
     When "GVV"   : Gosub GAU4
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

Commit
Gosub SAV_OPENI From PATCH
If func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:GAU]CODACT,[F:GAU]MODULE) : # Issue 120223 - 2017-03-02 by GLE : check the automatic journal is enabled before validate it
 Call VALIDATION(NOMOBJ,APPLI) From SUBGAU
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Endif
Gosub REST_OPENI From PATCH
Return

$ABORT
Rollback
Return

## En-tête de pièce

$GAU1
FICHIER = "GAUTACE" : ABR = "GAU"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = [F:GAU]MODULE
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:GAU]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 [F:GAU]CREDAT = date$
 [F:GAU]CREUSR = GUSER
 If dim([F:GAU]CRETIM)>0 : [F:GAU]CRETIM = time  : Endif
 [F:GAU]UPDDAT = date$
 [F:GAU]UPDUSR = GUSER
 If dim([F:GAU]UPDTIM)>0 : [F:GAU]UPDTIM = time  : Endif
 Write [GAU]
Else
 [F:GAU]UPDDAT = date$
 [F:GAU]UPDUSR = GUSER
 If dim([F:GAU]UPDTIM)>0 : [F:GAU]UPDTIM = time  : Endif
 Rewrite [GAU]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "GAUTACE"-[F:GAU]COD : Return
Endif
Delete [GAD] Where COD=[F:GAU]COD
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "GAUTACED"-[F:GAU]COD : Return
Endif
Delete [GAG] Where COD=[F:GAU]COD
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "GAUTACEF"-[F:GAU]COD : Return
Endif
If clalev([F:GVV])>0
 Delete [GVV] Where COD=[F:GAU]COD
 If fstat=1
  GOK = 0 : ER = 99 : ERFIC = "GVARPARVAL"-[F:GAU]COD : Return
 Endif
Endif
Return

## Ligne de pièce

$GAU2
FICHIER = "GAUTACED" : ABR = "GAD"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [GAD]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "GAUTACED"-[F:GAD]COD-num$([F:GAD]LINNUM) : Return
Endif
Return

## Formule

$GAU3
FICHIER = "GAUTACEF" : ABR = "GAG"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [GAG]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "GAUTACEF"-[F:GAG]COD-num$([F:GAG]LINNUM) : Return
Endif
Return

## Valeur paramètres

$GAU4
If clalev([F:GVV])>0
 FICHIER = "GVARPARVAL" : ABR = "GVV"
 Repeat
  Gosub LIRE_ZONE From PATCH
  If ER : Break : Endif
  If DIME>0 & IND+1<=DIME
   OK = 1
   If OK
    Gosub AFF_ZONE From PATCH
    If GOK<1 : ER = 99 : Break : Endif
   Endif
  Endif
 Until TYPENR=6
 If ER : Return : Endif
 Write [GVV]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "GVARPARVAL"-[F:GVV]COD-num$([F:GVV]LINNUM) : Return
 Endif
Endif
Return

