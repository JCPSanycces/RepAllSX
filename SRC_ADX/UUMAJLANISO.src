#<AdxTL>@(#)6.0.0.0 $Revision$
Call LANISO
End

#-------------------------------------------------------------#
# Mise à jour fichier ISO dans adxdir/runtime/lan
# Sous la forme -> Code langue iso:Code langue X3
# Exemple -> en-GB:BRI
#-------------------------------------------------------------#

Subprog LANISO
Local Integer ER
Local Char    APPLI(GLONADS) , FICHIER(GDIMFIC)
Onerrgo ER
APPLI = nomap
If APPLI<>GDOSX3
 Local File ADOSSIER [ADS]
 Read [ADS]DOSSIER=GDOSX3
 If fstat : End : Endif
 APPLI = [F:ADS]DOSSIER
 Close Local File [ADS]
Endif
If APPLI=nomap
 Local File TABLAN [TLA]
Else
 Local File =APPLI+".TABLAN" [TLA]
Endif
FICHIER = filpath("lan","ISO","","!")
Openo FICHIER,0 Using [FIC]
If ER=27
 Call ERREUR("|"+FICHIER+"|\Droits d'accès insuffisant") From GESECRAN
Else
 Iomode adxifs "" Using [FIC]
 Iomode adxirs chr$(10) Using [FIC]
 Iomode adxium GUTF8 Using [FIC]
 For [TLA] Where LANISO<>""
  Wrseq ctrans([F:TLA]LANISO,"_","-")+":"+[F:TLA]LAN Using [FIC]
 Next TLA
 Openo Using [FIC]
 Call ECR_TRACE('Fichier |"'+FICHIER+'" mis à jour',0) From GESECRAN
Endif
Close Local File
Onerrgo
End

$ER
ER = errn
Resume
