#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Composants technique de gestion de parc                   Module CRM       1 Avril 2003
#
# CREPARC    : Sous-programme de création d'une fiche parc.
# UPDPARC    : Sous-programme de mise à jour d'une fiche parc.
# DELPARC    : Sous-programme de suppression d'une fiche parc.
# DUPLIPARC  : Sous-programme de duplication d'une fiche parc.
# CREMAI     : Sous-programme de création d'un historique d'implantation d'une fiche parc
# DELMAI     : Sous-programme de suppression d'un historique d'implantation d'une fiche parc
# GESMAI     : Sous-programme de gestion d'un historique d'implantation d'une fiche parc
#              (suppression d'un historique et mise à jour fiche parc)
##########################################################################################################
##########################################################################################################
# Sous-programme de création d'une fiche parc.
##########################################################
Subprog CREPARC(SZMACNUM, IERRINF)
Variable Char SZMACNUM
Variable Integer IERRINF

Local Integer MACFOUND
Local Integer IBTRANSAC
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOUNTER(GLONANM)

  IERRINF = 0
  SZMACNUM = ""
  #---------------------------------------------------#
  # Etape 1
  # Ouverture des tables nécessaires
  #---------------------------------------------------#
  If !clalev([F:MACV]) : Local File MACHINES [MACV] : Endif
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif #Gbn-Plantage en validation de livraison. # FGR 28/02/2013 (suite X3SUIVI71937)
  #---------------------------------------------------#
  # Etape 2
  # Contrôle des informations obligatoires
  #---------------------------------------------------#
  #Code article
  If [M:MACW]MACPDTCOD = "" Then
    #Le champ obligatoire CODE ARTICLE n'est pas qualifié.
    IERRINF = 58
    End
  Else
    If [F:ITM]ITMREF <> [M:MACW]MACPDTCOD Then   # FGR 28/10/2015 : X3SUIVI112034
      Read [ITM]ITM0=[M:MACW]MACPDTCOD
      If fstat Then
        #Le code article indiqué sur la fiche parc est incorrect.
        IERRINF = 59
        End
      Endif
    Endif                                        # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Type d'implantation
  If [M:MACW]MACITNTYP < 1 Then
    #Le champ obligatoire TYPE D'IMPLANTATION n'est pas qualifié.
    IERRINF = 60
    End
  Else
    If [M:MACW]MACITNTYP > 5 Then
      #Le type d'implantation indiqué sur la fiche parc est incorrect.
      IERRINF = 61
      End
    Endif
  Endif
  #Origine
  If [M:MACW]MACORI < 1 Then
    #L'origine de la fiche parc n'est pas précisée.
    IERRINF = 62
    End
  Elsif [M:MACW]MACORI > 6 Then
    #L'origine de la fiche parc est incorrecte.
    IERRINF = 63
    End
  Endif
  # FGR 03/03/2010 : X3SUIVI63009
  #If [M:MACW]MACORIVCR = "" Then
  If [M:MACW]MACORIVCR = "" and [M:MACW]MACORI > 1 Then
    #Le numéro de pièce origine n'est pas précisé.
    IERRINF = 64
    End
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Contrôle des informations facultatives
  #---------------------------------------------------#
  #Code tiers
  If [M:MACW]BPCNUM <> "" Then
    If [F:BPR]BPRNUM <> [M:MACW]BPCNUM Then      # FGR 28/10/2015 : X3SUIVI112034
      Read [BPR]BPR0=[M:MACW]BPCNUM
      If fstat Then
        #L'utilisateur final de type Tiers est incorrect.
        IERRINF = 65
        End
      Endif
    Endif                                        # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Site d'installation
  If [M:MACW]BPCNUM <> "" Then
    If [M:MACW]FCYITN = "" Then
      #Le site d'installation du tiers n'est pas précisé.
      IERRINF = 67
      End
    Else
      If [F:BPA]BPATYP <> 1 or [F:BPA]BPANUM <> [M:MACW]BPCNUM or [F:BPA]BPAADD <> [M:MACW]FCYITN Then       # FGR 28/10/2015 : X3SUIVI112034
        Read [BPA]BPA0=1;[M:MACW]BPCNUM;[M:MACW]FCYITN
        If fstat Then
          #Le site d'installation du tiers est incorrect.
          IERRINF = 68
          End
        Endif
      Endif                                                                                                  # FGR 28/10/2015 : X3SUIVI112034
    Endif
  Endif
  #Code interlocuteur
  If [M:MACW]CCNNUM <> "" Then
    If [F:AIN]CNTNUM <> [M:MACW]CCNNUM Then      # FGR 28/10/2015 : X3SUIVI112034
      Read [AIN]AIN0=[M:MACW]CCNNUM
      If fstat Then
        #L'utilisateur final de type Interlocuteur est incorrect.
        IERRINF = 66
        End
      Endif
    Endif                                        # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Revendeur
  If [M:MACW]MACRSL <> "" Then
    If [F:BPR]BPRNUM <> [M:MACW]MACRSL Then      # FGR 28/10/2015 : X3SUIVI112034
      Read [BPR]BPR0=[M:MACW]MACRSL
      If fstat Then
        #Le revendeur indiqué est incorrect.
        IERRINF = 116
        End
      Endif
    Endif                                        # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Prix de vente
  If [M:MACW]MACSALPRI > 0 Then
    If [M:MACW]CUR = "" Then
      #La devise de vente n'est pas indiquée.
      IERRINF = 69
      End
    Else
      If [F:TCU]CUR <> [M:MACW]CUR Then          # FGR 28/10/2015 : X3SUIVI112034
        Read [TCU]TCU0=[M:MACW]CUR
        If fstat Then
          #La devise de vente est incorrecte.
          IERRINF = 72
          End
        Endif
      Endif                                      # FGR 28/10/2015 : X3SUIVI112034
    Endif
  Endif
  #Prix d'achat
  If [M:MACW]MACBPCPRI > 0 Then
    If [M:MACW]MACBPCCUR = "" Then
      #La devise d'achat n'est pas indiquée.
      IERRINF = 70
      End
    Else
      If [F:TCU]CUR <> [M:MACW]MACBPCCUR Then    # FGR 28/10/2015 : X3SUIVI112034
        Read [TCU]TCU0=[M:MACW]MACBPCCUR
        If fstat Then
          #La devise d'achat est incorrecte.
          IERRINF = 73
          End
        Endif
      Endif                                      # FGR 28/10/2015 : X3SUIVI112034
    Endif
  Endif
  #Marque
  If [M:MACW]MACBRA <> "" Then
    If [F:ADI]NUMTAB <> 408 or [F:ADI]CODE <> [M:MACW]MACBRA Then    # FGR 28/10/2015 : X3SUIVI112034
      Read [ADI]CODE=408;[M:MACW]MACBRA
      If fstat Then
        #La marque indiquée est incorrecte.
        IERRINF = 71
        End
      Endif
    Endif                                                            # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Site de vente
  If [M:MACW]SALFCY <> "" Then
    If [F:FCY]FCY <> [M:MACW]SALFCY Then         # FGR 28/10/2015 : X3SUIVI112034
      Read [FCY]FCY0=[M:MACW]SALFCY
      If fstat Then
        #Le site de vente indiqué est incorrect.
        IERRINF = 74
        End
      Endif
    Endif                                        # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #Vérifie que le numero de serie est unique pour l'article
  MACFOUND = 0
  If [M:MACW]MACPDTCOD <> "" Then
    If [M:MACW]MACSERNUM <> "" Then
      MACFOUND = 0
      Filter [MACV] Where [F:MACV]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACV]MACSERNUM = [M:MACW]MACSERNUM
      For [MACV]MAC5
        MACFOUND = 1
        Break
      Next
      Filter [MACV]
      If MACFOUND = 1 Then
        #On a trouve le même artice avec le même numero de serie
        If [F:MACV]MACNUM <> [M:MACW]MACNUM Then
          #Un parc existe déjà avec même code article et même numéro de série.
          #Message 57 car il faut chapitre 182
          #ECHEC de la transaction de création de la fiche PARC.
          IERRINF = 57
          End
        Endif
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Calcul d'une clé primaire
  #---------------------------------------------------#
  #---------------------------------------------------#
  # --> Récupération du code compteur
  #---------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    #Aucun compteur n'a pu être identifié pour la création du parc.
  #    IERRINF = 55
  #    End
  #  Endif
  #  SZCOUNTER = [F:TCA]CODNUM(2)
  If [F:FCY]FCY <> [M:MACW]SALFCY Then           # FGR 28/10/2015 : X3SUIVI112034
    Read [F:FCY]FCY0=[M:MACW]SALFCY
  Endif                                          # FGR 28/10/2015 : X3SUIVI112034
  If [F:CPY]CPY <> [F:FCY]LEGCPY Then            # FGR 28/10/2015 : X3SUIVI112034
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
  Endif                                          # FGR 28/10/2015 : X3SUIVI112034
  GSOCIETE = [F:CPY]CPY
  GCURLEG = [F:CPY]LEG
  Call READ_COUNTER([M:MACW]SALFCY, 12, 2, GSOCIETE, GCURLEG, SZCOUNTER, GMANCOU) From CRM_UTIL
  GMANCOU = 1
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # FGR 16/03/2008 : X2SUIVI47649 Pour ajout d'un point d'entrée
  Gosub PE_CREMACCOU From TRTCRMPE
  #---------------------------------------------------#
  # --> Calcul du code compteur
  #---------------------------------------------------#
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", [M:MACW]SALFCY, SZCOUNTER, date$, "", [M:MACW]MACNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      #GMESSAGE = mess(IERRINF,ICHAPTER,1)
      #Erreur lors de la génération du compteur d'identification séquentielle.
      IERRINF = 56
      End
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 5
  # On traite les cas particuliers
  #---------------------------------------------------#
  If [M:MACW]BPCNUM = "" Then
    If [M:MACW]CCNNUM <> "" Then
      [M:MACW]MACCUTBPC = [M:MACW]CCNNUM
    Endif
  Else
    [M:MACW]MACCUTBPC = [M:MACW]BPCNUM
  Endif
  If [M:MACW]BPCNUM = "" and [M:MACW]CCNNUM = "" Then
    [M:MACW]MACCUTBPC = ""
  Endif
  If [M:MACW]MACSERNUM = "" Then
    If [M:MACW]MACQTY < 1 Then
      [M:MACW]MACQTY = 1
    Endif
  Else
    [M:MACW]MACQTY = 1
  Endif
  If [M:MACW]MACBRA = "" Then
    [M:MACW]MACBRACLA = ""
  Else
    Call GET_LIB(408, [M:MACW]MACBRA, [M:MACW]MACBRACLA) From CRM_UTIL
  Endif
  If [M:MACW]MACPDTCOD = "" Then
    [M:MACW]MACDES = ""
  Else
    If [F:ITM]ITMREF <> [M:MACW]MACPDTCOD Then                                                      # FGR 28/10/2015 : X3SUIVI112034
      Read [ITM]ITM0=[M:MACW]MACPDTCOD
      If fstat Then
        [M:MACW]MACDES = ""
      Else
        #[M:MACW]MACDES = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MACW]MACDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      Endif
    Else                                                                                            # FGR 28/10/2015 : X3SUIVI112034
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MACW]MACDES, "[F:ITM]") From TRTX3   # FGR 28/10/2015 : X3SUIVI112034
    Endif                                                                                           # FGR 28/10/2015 : X3SUIVI112034
  Endif
  #---------------------------------------------------#
  # Dernière étape
  # On crée
  #---------------------------------------------------#
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MACV]
    IBTRANSAC = 1
  Endif
  Raz [F:MACV]
  [F:MACV] = [M:MACW]
  [F:MACV]CREUSR = GUSER
  [F:MACV]CREDAT = date$
  #LSE 06/06/2006 FQ 36247
  #Point entrée pour alimenté champs spécifique de la fiche parc
  #On est en création
  SZPEMAC_ACTION = "C"
  SZPEMAC_ORIGINE = [F:MACV]PREORI
  Gosub PE_MACAUTO From TRTCRMPE
  Write [MACV]
  If fstat Then
    #Echec de la transaction de création de la fiche parc.
    IERRINF = 57
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    End
  Else
    If IBTRANSAC = 1 Then
      Commit
    Endif
  Endif
  SZMACNUM = [M:MACW]MACNUM
  If GTRACE <> "" Then
    # FGR 04/01/2011 : X3SUIVI70100
    If [F:MACV]MACSERNUM <> "" Then
      Call ECR_TRACE(mess(272,196,1) - [F:MACV]MACNUM - "(" + [F:MACV]MACSERNUM + ")" - ":" - mess(42,187,1), 0) From GESECRAN
    Else
      Call ECR_TRACE(mess(272,196,1) - [F:MACV]MACNUM - ":" - mess(42,187,1), 0) From GESECRAN
    Endif
    If dim(NBUTICRMMAC) > 0 Then
      NBUTICRMMAC += 1
    Endif
  Endif
End

##########################################################################################################
# Sous-programme de mise à jour d'une fiche parc.
##########################################################
Subprog UPDPARC(SZMACNUM, SZFIELD, IERRINF)
Value Char SZMACNUM
Variable Char SZFIELD()(0..)
Variable Integer IERRINF

Local Integer ITER
Local Char SZASSIGN
Local Char SZEVAL
Local Integer IBTRANSAC
Local Integer FINDMACPDTCOD
Local Integer FINDMACSERNUM
Local Integer MACFOUND
#Local Char SZMACNUM(GLONMAC)  # FGR 30/04/2010 : X3SUIVI64463 : Même nom que le paramètre !
Local Char SZMACDOU(GLONMAC)   # FGR 30/04/2010 : X3SUIVI64463 : Même nom que le paramètre du coup c'est vide

  IERRINF = 0
  SZASSIGN = ""
  SZEVAL = ""
  #---------------------------------------------------#
  # Etape 1
  # Ouverture des tables nécessaires
  #---------------------------------------------------#
  If !clalev([F:MACV]) : Local File MACHINES [MACV] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Local Mask MACW [MACV]
  #---------------------------------------------------#
  # Etape 2
  # Contrôle des noms de champs
  #---------------------------------------------------#
  For ITER = 0 To dim(SZFIELD)-1
    If SZFIELD(ITER) <> "" Then  # FGR 26/04/2010 : X3SUIVI64206 le tableau n'est pas dimensionné exactement. Tester si non vide
      Read [ATZ]CODZONE="MACHINES";SZFIELD(ITER)
      If fstat Then
        #L'un des champs à mettre à jour ne fait pas partie de la table Parc client.
        IERRINF = 128
        Break
      Endif
    Endif
  Next
  If IERRINF Then
    Close Local Mask [MACV]
    End
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Mise à jour de la fiche parc
  #---------------------------------------------------#
  If SZMACNUM = "" Then
    #Le code de la fiche parc à mettre à jour n'est pas fourni.
    IERRINF = 129
    Close Local Mask [MACV]
    End
  Endif
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MACV]
    IBTRANSAC = 1
  Endif
  Read [MACV]MAC0=SZMACNUM
  If fstat Then
    #Le code de la fiche parc à mettre à jour est incorrect.
    IERRINF = 130
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    Close Local Mask [MACV]
    End
  Endif
  #Chargement des informations
  [M:MACV] = [F:MACV]
  #Chargement des modifications
  For ITER = 0 To dim(SZFIELD)-1
    If SZFIELD(ITER) <> "" Then  # FGR 26/04/2010 : X3SUIVI64206 le tableau n'est pas dimensionné exactement. Tester si non vide
      SZEVAL = "[M:MACW]" + SZFIELD(ITER)
      SZASSIGN = "[M:MACV]" + SZFIELD(ITER)
      Assign SZASSIGN With evalue(SZEVAL)
    Endif
  Next
  #Vérifie que le numero de serie est unique pour l'article
  If [M:MACW]MACPDTCOD <> "" Then
    If [M:MACW]MACSERNUM <> "" Then
      FINDMACPDTCOD = find ("MACPDTCOD", SZFIELD)
      FINDMACSERNUM = find ("MACSERNUM", SZFIELD)
      If FINDMACPDTCOD <> 0 or FINDMACSERNUM <> 0 Then
        MACFOUND = 0
        Raz SZMACDOU  # FGR 30/04/2010 : X3SUIVI64463
        Filter [MACV] Where [F:MACV]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACV]MACSERNUM = [M:MACW]MACSERNUM and [F:MACV]MACNUM <> [M:MACW]MACNUM
        For [MACV]MAC5
          MACFOUND = 1
          SZMACDOU = [F:MACV]MACNUM     # FGR 30/04/2010 : X3SUIVI64463
          Break
        Next
        Filter [MACV]
        If MACFOUND = 1 Then
          #On a trouve le même artice avec le même numero de serie
          If SZMACDOU <> [M:MACW]MACNUM Then     # FGR 30/04/2010 : X3SUIVI64463
            #Message 57 car if faut chapitre 182
            #ECHEC de la transaction de création de la fiche PARC.
            #Un parc existe déjà avec même code article et même numéro de série.
            IERRINF = 57
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  [F:MACV] = [M:MACV]
  #---------------------------------------------------#
  # Etape 4
  # On traite les cas particuliers
  #---------------------------------------------------#
  If [F:MACV]BPCNUM = "" Then
    If [F:MACV]CCNNUM <> "" Then
      [F:MACV]MACCUTBPC = [F:MACV]CCNNUM
    Endif
  Else
    [F:MACV]MACCUTBPC = [F:MACV]BPCNUM
  Endif
  If [F:MACV]BPCNUM = "" and [F:MACV]CCNNUM = "" Then
    [F:MACV]MACCUTBPC = ""
  Endif
  If [F:MACV]MACSERNUM = "" Then
    If [F:MACV]MACQTY < 1 Then
      [F:MACV]MACQTY = 1
    Endif
  Else
    [F:MACV]MACQTY = 1
  Endif
  If [F:MACV]MACBRA = "" Then
    [F:MACV]MACBRACLA = ""
  Else
    Call GET_LIB(408, [F:MACV]MACBRA, [F:MACV]MACBRACLA) From CRM_UTIL
  Endif
  If [F:MACV]MACPDTCOD = "" Then
    [F:MACV]MACDES = ""
  Else
    Read [ITM]ITM0=[F:MACV]MACPDTCOD
    If fstat Then
      [F:MACV]MACDES = ""
    Else
      #[F:MACV]MACDES = [F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:MACV]MACDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
  Endif
  #LSE 06/06/2006 FQ 36247
  #Point entrée pour alimenté champs spécifique de la fiche parc
  #On est en modification
  SZPEMAC_ACTION = "M"
  SZPEMAC_ORIGINE = [F:MACV]MACORI
  Gosub PE_MACAUTO From TRTCRMPE
  #---------------------------------------------------#
  # Dernière étape
  # On met à jour
  #---------------------------------------------------#
  Rewrite [MACV]
  If fstat Then
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    #La mise à jour de la fiche parc a échoué.
    IERRINF = 131
    Close Local Mask [MACV]
    End
  Else
    If IBTRANSAC = 1 Then
      Commit
    Endif
  Endif
  Close Local Mask [MACV]
End

##########################################################################################################
# Sous-programme de suppression d'une fiche parc.
##########################################################
Subprog DELPARC(SZMACNUM, IDELMAC, IERRINF)
Variable Char SZMACNUM
Value Integer IDELMAC
Variable Integer IERRINF

Local Integer IBTRANSAC

  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:MAI]) : Local File MACITN [MAI] : Endif
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  IERRINF = 0
  Call DEBTRANS From GLOCK
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MAC], [MAI], [CCV]
    IBTRANSAC = 1
  Endif
  Filter [MAC] Where [F:MAC]MACNUM = SZMACNUM
  For [MAC]
    #Suppression de la couverture appliquée simple
    #Parc
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = [F:MAC]MACNUM and [F:CCV]PAEKEY(0) = ""
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Composants
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]SBBRECTYP = "" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) = "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Couverture financière parc
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) = "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Couverture financière composant
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) = "" and [F:CCV]PAEKEY(2) <> "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
          Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Suppression de la couverture appliquée croisée avec compétences
    #Parc
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = [F:MAC]MACNUM and [F:CCV]PAEKEY(0) <> ""
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Composants
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]SBBRECTYP = "" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) <> "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Couverture financière parc
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) <> "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Couverture financière composant
    Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) <> "" and [F:CCV]PAEKEY(2) <> "" and [F:CCV]PAEKEYTYP(1) = "MAC"
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
    #Suppression des historiques d'implantation
    Delete [MAI] Where [F:MAI]MACNUM = [F:MAC]MACNUM
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      # FGR 09/02/2010 : X3SUIVI60986
      #End
      Break
    Endif
  Next
  Filter [MAC]
  # FGR 09/02/2010 : X3SUIVI60986
  If IERRINF Then
    End
  Endif
  If IDELMAC Then
    Delete [MAC] Where [F:MAC]MACNUM = SZMACNUM
    If fstat Then
      IERRINF = 394
      If IBTRANSAC = 1 Then
        Rollback
      Endif
      End
    Endif
  Endif
  If IBTRANSAC = 1 Then
    Commit
  Endif
End

##########################################################################################################
# Sous-programme de duplication d'une fiche parc.
##########################################################
Subprog DUPLIPARC(SZMACNUM, SZDUPMAC, SZMESSAGE, INOERROR)
Value Char SZMACNUM
Variable Char SZDUPMAC
Variable Char SZMESSAGE
Variable Integer INOERROR

Local Integer IERR
Local Char SZCOUNTER(GLONANM)
Local Integer IBDEBTRANSFLG
Local Char SZCMMAIAUTO # FGR 25/09/2009 : X3SUIVI57808

  INOERROR = 1
  SZMESSAGE = ""
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  #
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  #Duplication de la fiche parc
  Local File MACHINES [MACD]
  Local File MACHINES [MACE]
  Local File MACWARREQ [MWRD]
  Local File MACWARREQ [MWRE]
  Local File MACITN [MAID]
  Local File MACITN [MAIE]
  Local File CONTCOV [CCVE]
  If IBDEBTRANSFLG = 0 Then
    Trbegin [MACD]
  Endif
  Raz [F:MACD]
  Read [MACE]MAC0=SZMACNUM
  If fstat Then
    #Erreur lors de la lecture de la fiche parc à dupliquer.
    INOERROR = 0
    SZMESSAGE = mess(98,182,1) - SZMACNUM
    If IBDEBTRANSFLG = 0 Then  # FGR 04/01/2011 : X3SUIVI70100 : ça manque un peu
      Rollback
    Endif
    End
  Endif
  [F:MACD] = [F:MACE]
  #---------------------------------------------------#
  # Calcul d'une nouvelle clé primaire
  #---------------------------------------------------#
  Read [TCA]TCA0=12
  If fstat Then
    #Aucun compteur n'a pu être identifié pour la création du parc.
    INOERROR = 0
    SZMESSAGE = mess(55,182,1)
  Endif
  If INOERROR = 1 Then
    SZCOUNTER = [F:TCA]CODNUM(2)
    IERR = 0
    Call NUMERO (SZCOUNTER, [F:MACD]SALFCY, date$, "", SZDUPMAC, IERR) From SUBANM
    If IERR Then
      #Erreur lors du calcul du numéro de chrono de la fiche parc.
      INOERROR = 0
      SZMESSAGE = mess(56,182,1)
    Endif
    #---------------------------------------------------#
    If INOERROR = 1 Then
      [F:MACD]MACNUM = SZDUPMAC
      Write [MACD]
      If fstat Then
        #Erreur en duplication de fiche parc.
        INOERROR = 0
        SZMESSAGE = mess(99,182,1) - SZMACNUM
      Endif
      #Duplication de l'historique des demandes de service
      Filter [MWRE] Where [F:MWRE]MACNUM = SZMACNUM
      For [MWRE]
        Raz [F:MWRD]
        [F:MWRD] = [F:MWRE]
        [F:MWRD]MACNUM = SZDUPMAC
        Write [MWRD]
        If fstat Then
          #Erreur en duplication de l'historique des demandes de garantie.
          INOERROR = 0
          SZMESSAGE = mess(100,182,1) - SZMACNUM
          Break
        Endif
      Next
      Filter [MWRE]
      If INOERROR = 1 Then
        #Duplication de l'historique des implantations
        Filter [MAIE] Where [F:MAIE]MACNUM = SZMACNUM
        For [MAIE]
          Raz [F:MAID]
          [F:MAID] = [F:MAIE]
          [F:MAID]MACNUM = SZDUPMAC
          SZCMMAIAUTO = "[MAID]"          # FGR 25/09/2009 : X3SUIVI57808
          Gosub PE_MAIAUTO2 From TRTCRMPE # FGR 25/09/2009 : X3SUIVI57808
          Write [MAID]
          If fstat Then
            #Erreur en duplication de l'historique des implantations du parc.
            INOERROR = 0
            SZMESSAGE = mess(135,182,1) - SZMACNUM
            Break
          Endif
        Next
        Filter [MAIE]
        If INOERROR = 1 Then
          #Duplication de la couverture appliquée
          #Duplication de la couverture parc simple
          Filter [CCVE] Where [F:CCVE]TPL <> 2 and [F:CCVE]RECTYP = "MAC" and [F:CCVE]SBBRECTYP = "MAC" and [F:CCVE]CMT = SZMACNUM and [F:CCVE]PAEKEY(0) = ""
          For [CCVE]CCV0
            Call DUPLICOV([F:CCVE]CONNUM, SZMACNUM, SZDUPMAC, 0, "", SZMESSAGE, INOERROR)
            If INOERROR = 0 Then
              Break
            Endif
          Next
          Filter [CCVE]
          If INOERROR = 1 Then
            #Duplication de la couverture parc croisée avec compétences
            Filter [CCVE] Where [F:CCVE]TPL <> 2 and [F:CCVE]RECTYP = "MAC" and [F:CCVE]SBBRECTYP = "MAC" and [F:CCVE]CMT = SZMACNUM and [F:CCVE]PAEKEY(0) <> ""
            For [CCVE]CCV0
              Call DUPLICOV([F:CCVE]CONNUM, SZMACNUM, SZDUPMAC, 1, [F:CCVE]PAEKEY(0), SZMESSAGE, INOERROR)
              If INOERROR = 0 Then
                Break
              Endif
            Next
            Filter [CCVE]
          Endif
        Endif
      Endif
    Endif
  Endif
  # FGR 12/04/2011 : X3SUIVI72107 (début)
  If INOERROR = 1 Then
    Gosub PE_DUPLIMAC From TRTCRMPE
  Endif
  # FGR 12/04/2011 : X3SUIVI72107 (fin)
  If INOERROR = 1 Then
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Endif
  Close Local File [MACD]
  Close Local File [MACE]
  Close Local File [MWRD]
  Close Local File [MWRE]
  Close Local File [MAID]
  Close Local File [MAIE]
  Close Local File [CCVE]
End

##########################################################################################################
# Duplication de la couverture appliquée d'une fiche parc
#########################################################################
Subprog DUPLICOV(SZCONNUM, SZMACNUM, SZDUPMAC, ICRSFLG, SZCRSPBL, SZMESSAGE, INOERROR)
Value Char SZCONNUM
Value Char SZMACNUM
Value Char SZDUPMAC
Value Integer ICRSFLG
Value Char SZCRSPBL
Variable Char SZMESSAGE
Variable Integer INOERROR

Local Char SZCOTRECNUM
Local Integer IRECNUM
Local Char SZRECNUM
Local Integer IBDEBTRANSFLG

  INOERROR = 1
  SZMESSAGE = ""
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  #
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  Local File CONTCOV [CCV2]
  If IBDEBTRANSFLG = 0 Then
    Trbegin [CCV]
  Endif
  #Calcul le dernier RECNUM
  SZRECNUM = ""
  IRECNUM = 0
  If ICRSFLG Then
    Call CPTCOVNUM(SZCONNUM, 1, SZCRSPBL, SZRECNUM, IRECNUM) From SUBMACB
  Else
    Call CPTCOVNUM(SZCONNUM, 0, "", SZRECNUM, IRECNUM) From SUBMACB
  Endif
  #Couverture parc
  If ICRSFLG Then
    Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP = "MAC" and [F:CCV2]SBBRECTYP = "MAC" and [F:CCV2]CMT = SZMACNUM and [F:CCV2]PAEKEY(0) = SZCRSPBL
  Else
    Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP = "MAC" and [F:CCV2]SBBRECTYP = "MAC" and [F:CCV2]CMT = SZMACNUM and [F:CCV2]PAEKEY(0) = ""
  Endif
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]RECNUM = num$(IRECNUM)
    [F:CCV]CMT = SZDUPMAC
    SZCOTRECNUM = [F:CCV2]RECNUM
    Write [CCV]
    If fstat Then
      #Erreur en duplication de la couverture appliquée du parc.
      INOERROR = 0
      SZMESSAGE = mess(420,182,1) - "(a)"
      Break
    Endif
    Break  # ATTENTION : ici on ne passe qu'une fois dans la boucle
  Next
  Filter [CCV2]
  If INOERROR = 1 Then
    #Couverture composant
    If ICRSFLG Then
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                     and [F:CCV2]TPL <> 2
&                     and [F:CCV2]RECTYP = "CPN"
&                     and [F:CCV2]SBBRECTYP = ""
&                     and [F:CCV2]CMT = SZMACNUM
&                     and [F:CCV2]PAEKEY(0) = SZCRSPBL
&                     and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                     and [F:CCV2]PAEKEYTYP(1) = "MAC"
    Else
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                     and [F:CCV2]TPL <> 2
&                     and [F:CCV2]RECTYP = "CPN"
&                     and [F:CCV2]SBBRECTYP = ""
&                     and [F:CCV2]CMT = SZMACNUM
&                     and [F:CCV2]PAEKEY(0) = ""
&                     and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                     and [F:CCV2]PAEKEYTYP(1) = "MAC"
    Endif
    For [CCV2]
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]CMT = SZDUPMAC
      [F:CCV]PAEKEY(1) = num$(IRECNUM)
      Write [CCV]
      If fstat Then
        #Erreur en duplication de la couverture appliquée du parc.
        INOERROR = 0
        SZMESSAGE = mess(420,182,1) - "(b)"
        Break
      Endif
    Next
    Filter [CCV2]
    If INOERROR = 1 Then
      #Couverture financière d'une référence article
      If ICRSFLG Then
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                       and [F:CCV2]TPL <> 2
&                       and [F:CCV2]RECTYP = "AAA"
&                       and [F:CCV2]CMT = SZMACNUM
&                       and [F:CCV2]PAEKEY(0) = SZCRSPBL
&                       and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                       and [F:CCV2]PAEKEYTYP(1) = "MAC"
      Else
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                       and [F:CCV2]TPL <> 2
&                       and [F:CCV2]RECTYP = "AAA"
&                       and [F:CCV2]CMT = SZMACNUM
&                       and [F:CCV2]PAEKEY(0) = ""
&                       and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                       and [F:CCV2]PAEKEYTYP(1) = "MAC"
      Endif
      For [CCV2]
        Raz [F:CCV]
        [F:CCV] = [F:CCV2]
        [F:CCV]CMT = SZDUPMAC
        [F:CCV]PAEKEY(1) = num$(IRECNUM)
        Write [CCV]
        If fstat Then
          #Erreur en duplication de la couverture appliquée du parc.
          INOERROR = 0
          SZMESSAGE = mess(420,182,1) - "(c)"
          Break
        Endif
      Next
      Filter [CCV2]
      If INOERROR = 1 Then
        #Couverture financière d'un composant
        If ICRSFLG Then
          Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                         and [F:CCV2]TPL <> 2
&                         and [F:CCV2]RECTYP = "AAA"
&                         and [F:CCV2]CMT = SZMACNUM
&                         and [F:CCV2]PAEKEY(0) <> ""
&                         and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                         and [F:CCV2]PAEKEY(2) = SZCRSPBL
&                         and [F:CCV2]PAEKEYTYP(1) = "MAC"
        Else
          Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM
&                         and [F:CCV2]TPL <> 2
&                         and [F:CCV2]RECTYP = "AAA"
&                         and [F:CCV2]CMT = SZMACNUM
&                         and [F:CCV2]PAEKEY(0) = ""
&                         and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                         and [F:CCV2]PAEKEY(2) <> ""
&                         and [F:CCV2]PAEKEYTYP(1) = "MAC"
        Endif
        For [CCV2]
          Raz [F:CCV]
          [F:CCV] = [F:CCV2]
          [F:CCV]CMT = SZDUPMAC
          [F:CCV]PAEKEY(1) = num$(IRECNUM)
          Write [CCV]
          If fstat Then
            #Erreur en duplication de la couverture appliquée du parc.
            INOERROR = 0
            SZMESSAGE = mess(420,182,1) - "(d)"
            Break
          Endif
        Next
        Filter [CCV2]
      Endif
    Endif
  Endif
  If INOERROR = 1 Then
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Endif
  Close Local File [CCV2]
End

##########################################################################################################
# Sous-programme de création d'un historique d'implantation d'une fiche parc
##########################################################
Subprog CREMAI(ICLSNUM, IERRINF)
Variable Integer ICLSNUM
Variable Integer IERRINF

Local Integer IBTRANSAC
Local Char SZCMMAIAUTO # FGR 25/09/2009 : X3SUIVI57808

  ICLSNUM = 0
  IERRINF = 0
  #---------------------------------------------------#
  # Etape 1
  # Ouverture des tables nécessaires
  #---------------------------------------------------#
  If !clalev([F:MAIV]) : Local File MACITN [MAIV] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  #---------------------------------------------------#
  # Etape 2
  # Contrôle des informations obligatoires
  #---------------------------------------------------#
  #Code article
  If [M:MAC7]MACNUM = "" Then
    #Le champ obligatoire CHRONO PARC n'est pas qualifié.
    IERRINF = 109
    End
  Else
    Read [MAC]MAC0=[M:MAC7]MACNUM
    If fstat Then
      #L'identifiant de la fiche parc est incorrect.
      IERRINF = 109
      End
    Endif
  Endif
  #Type d'implantation
  If [M:MAC7]ITNTYP < 1 Then
    #Le champ obligatoire TYPE D'IMPLANTATION n'est pas qualifié.
    IERRINF = 60
    End
  Else
    If [M:MAC7]ITNTYP > 5 Then
      #Le type d'implantation indiqué sur la fiche parc est incorrect.
      IERRINF = 61
      End
    Endif
  Endif
  #Cohérence entre type d'implantation et UF
  Case [M:MAC7]ITNTYP
    When 1
      If [M:MAC7]BPCNUM = "" Then
        If [M:MAC7]CCNNUM = "" Then
          #L'utilisateur final n'est pas indiqué.
          IERRINF = 119
          End
        Endif
      Else
        If [M:MAC7]ITNFCY = "" Then
          #Le site d'installation n'est pas indiqué.
          IERRINF = 120
          End
        Endif
      Endif
    When 2
      If [M:MAC7]RSL = "" Then
        #Le revendeur n'est pas indiqué.
        IERRINF = 121
        End
      Endif
    When 3
      If [M:MAC7]RSL = "" Then
        #Le grossiste n'est pas indiqué.
        IERRINF = 122
        End
      Endif
    When 4
      If [M:MAC7]RSL <> "" Then
        #Le parc est déclaré en stock. Aucun revendeur ne doit donc être précisé.
        IERRINF = 123
        End
      Else
        If [M:MAC7]BPCNUM <> "" Then
          #Le parc est déclaré en stock. Aucun utilisateur final ne doit donc être précisé.
          IERRINF = 124
          End
        Endif
        If [M:MAC7]CCNNUM <> "" Then
          #Le parc est déclaré en stock. Aucun utilisateur final ne doit donc être précisé.
          IERRINF = 124
          End
        Endif
      Endif
    When 5
      If [M:MAC7]RSL <> "" Then
        #Le parc est déclaré comme mis au rebut. Aucun revendeur ne doit donc être précisé.
        IERRINF = 125
        End
      Else
        If [M:MAC7]BPCNUM <> "" Then
          #Le parc est déclaré comme mis au rebut. Aucun utilisateur final ne doit donc être précisé.
          IERRINF = 126
          End
        Endif
        If [M:MAC7]CCNNUM <> "" Then
          #Le parc est déclaré comme mis au rebut. Aucun utilisateur final ne doit donc être précisé.
          IERRINF = 126
          End
        Endif
      Endif
    When Default
  Endcase
  #Code tiers
  If [M:MAC7]BPCNUM <> "" Then
    Read [BPR]BPR0=[M:MAC7]BPCNUM
    If fstat Then
      #L'utilisateur final de type Tiers est incorrect.
      IERRINF = 65
      End
    Endif
  Endif
  #Site d'installation
  If [M:MAC7]BPCNUM <> "" Then
    If [M:MAC7]ITNFCY = "" Then
      #Le site d'installation du tiers n'est pas précisé.
      IERRINF = 67
      End
    Else
      Read [BPA]BPA0=1;[M:MAC7]BPCNUM;[M:MAC7]ITNFCY
      If fstat Then
        #Le site d'installation du tiers est incorrect.
        IERRINF = 68
        End
      Endif
    Endif
  Endif
  #Code interlocuteur
  If [M:MAC7]CCNNUM <> "" Then
    Read [AIN]AIN0=[M:MAC7]CCNNUM
    If fstat Then
      #L'utilisateur final de type Interlocuteur est incorrect.
      IERRINF = 66
      End
    Endif
  Endif
  #Détermination du type d'utilisateur final
  If [M:MAC7]BPCNUM <> "" Then
    If [M:MAC7]CCNNUM <> "" Then
      #Le type d'utilisateur final ne peut pas être déterminé.
      IERRINF = 115
      End
    Endif
  Endif
  If [M:MAC7]BPCNUM = "" Then
    If [M:MAC7]CCNNUM = "" Then
      If [M:MAC7]ITNTYP = 1 Then
        #Le type d'utilisateur final ne peut pas être déterminé.
        IERRINF = 115
        End
      Endif
    Endif
  Endif
  #Revendeur
  If [M:MAC7]RSL <> "" Then
    Read [BPR]BPR0=[M:MAC7]RSL
    If fstat Then
      #Le revendeur indiqué est incorrect.
      IERRINF = 116
      End
    Endif
  Endif
  #Origine
  If [M:MAC7]ORI < 1 Then
    #L'origine de la fiche parc n'est pas précisée.
    IERRINF = 62
    End
  #Elsif [M:MAC7]ORI > 6 Then                      # FGR 20/04/2011 : X3SUIVI73393 pas lieu d'être ici
  #  #L'origine de la fiche parc est incorrecte.   # FGR 20/04/2011 : X3SUIVI73393 pas lieu d'être ici
  #  IERRINF = 63                                  # FGR 20/04/2011 : X3SUIVI73393 pas lieu d'être ici
  #  End                                           # FGR 20/04/2011 : X3SUIVI73393 pas lieu d'être ici
  Endif
  # FGR 03/03/2010 : X3SUIVI63009
  #If [M:MAC7]ORIVCR = "" Then
  If [M:MAC7]ORIVCR = "" and [M:MAC7]ORI > 1 Then
    #Le numéro de pièce origine n'est pas précisé.
    IERRINF = 64
    End
  Endif
  #Prix de vente
  If [M:MAC7]SALPRI > 0 Then
    If [M:MAC7]CUR = "" Then
      #La devise de vente n'est pas indiquée.
      IERRINF = 69
      End
    Else
      Read [TCU]TCU0=[M:MAC7]CUR
      If fstat Then
        #La devise de vente est incorrecte.
        IERRINF = 72
        End
      Endif
    Endif
  Endif
  #Prix d'achat
  If [M:MAC7]BPCPRI > 0 Then
    If [M:MAC7]BPCCUR = "" Then
      #La devise d'achat n'est pas indiquée.
      IERRINF = 70
      End
    Else
      Read [TCU]TCU0=[M:MAC7]BPCCUR
      If fstat Then
        #La devise d'achat est incorrecte.
        IERRINF = 73
        End
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Contrôle des informations facultatives
  #---------------------------------------------------#
  #Prix de reprise
  If [M:MAC7]SECPRI > 0 Then
    If [M:MAC7]SECCUR = "" Then
      #La devise de reprise n'est pas indiquée.
      IERRINF = 117
      End
    Else
      Read [TCU]TCU0=[M:MAC7]SECCUR
      If fstat Then
        #La devise de reprise est incorrecte.
        IERRINF = 118
        End
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Calcul de la clé secondaire
  #---------------------------------------------------#
  Filter [F:MAIV] Where [F:MAIV]MACNUM = [M:MAC7]MACNUM Order By [F:MAIV]CLSNUM Desc
  For [F:MAIV] Hint Key MAI1
    ICLSNUM = [F:MAIV]CLSNUM + 1
    Break
  Next
  Filter [F:MAIV]
  ##########################################################################################################
  # Etape 5
  # On traite les cas particuliers
  ##############################################
  If [M:MAC7]ENDITN = [00/00/00] Then
    [M:MAC7]ENDITN = date$
  Endif
  #Gestion des champs BPC et BPCTYP
  If [M:MAC7]BPCNUM = "" Then
    If [M:MAC7]CCNNUM <> "" Then
      [M:MAC7]BPC = [M:MAC7]CCNNUM
      [M:MAC7]BPCTYP = "CCN"
    Endif
  Else
    If [M:MAC7]CCNNUM = "" Then
      [M:MAC7]BPC = [M:MAC7]BPCNUM
      [M:MAC7]BPCTYP = "BPC"
    Endif
  Endif
  #On essaie d'avoir un site d'installation pour une implantation de type Revendeur.
  If [M:MAC7]ITNTYP = 2 Then
    #Site d'installation
    If [M:MAC7]ITNFCY = "" Then
      If [M:MAC7]RSL <> "" Then
        Read [BPR]BPR0=[M:MAC7]RSL
        If !fstat Then
          If [F:BPR]BPAADD <> "" Then
            [M:MAC7]ITNFCY = [F:BPR]BPAADD
          Endif
        Endif
      Endif
    Endif
  Endif
  #Date de début d'implantation
  If [M:MAC7]ITNDAT = [00/00/00] Then
    If [M:MAC7]PURDAT = [00/00/00] Then
      If [M:MAC7]BPCDAT <> [00/00/00] Then
        [M:MAC7]ITNDAT = [M:MAC7]BPCDAT
      Endif
    Else
      [M:MAC7]ITNDAT = [M:MAC7]PURDAT
    Endif
  Endif
  #---------------------------------------------------#
  # Dernière étape
  # On crée
  #---------------------------------------------------#
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MAIV]
    IBTRANSAC = 1
  Endif
  Raz [F:MAIV]
  [F:MAIV] = [M:MAC7]
  [F:MAIV]CLSNUM = ICLSNUM
  SZCMMAIAUTO = "[MAIV]"          # FGR 25/09/2009 : X3SUIVI57808
  Gosub PE_MAIAUTO2 From TRTCRMPE # FGR 25/09/2009 : X3SUIVI57808
  Write [MAIV]
  If fstat Then
    #Echec de la transaction de création de l'historique d'implantation.
    IERRINF = 108
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    End
  Else
    If IBTRANSAC = 1 Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Sous-programme de suppression d'une implantation de parc
##########################################################
Subprog DELMAI(SZMACNUM, ICLSNUM, IERRINF)
Value Char SZMACNUM
Value Integer ICLSNUM
Variable Integer IERRINF

Local Integer IBTRANSAC

  IERRINF = 0
  #---------------------------------------------------#
  # Etape 1
  # Ouverture des tables nécessaires
  #---------------------------------------------------#
  If !clalev([F:MAIV]) : Local File MACITN [MAIV] : Endif
  #---------------------------------------------------#
  # Etape 2
  # Contrôle des composantes de clés
  #---------------------------------------------------#
  Read [MAIV]MAI1=SZMACNUM;ICLSNUM
  If fstat Then
    #Les composantes de clés de l'implantation à supprimer sont erronées.
    IERRINF = 132
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Suppression physique
  #---------------------------------------------------#
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MAIV]
    IBTRANSAC = 1
  Endif
  Delete [MAIV] Where [F:MAIV]MACNUM = SZMACNUM and [F:MAIV]CLSNUM = ICLSNUM
  If fstat Then
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    #La suppression de l'historique d'implantation du parc a échoué.
    IERRINF = 133
  Else
    If IBTRANSAC = 1 Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Sous-programme de gestion d'un historique d'implantation d'une fiche parc
# (suppression d'un historique et mise à jour fiche parc)
##########################################################
Subprog GESMAI(ICLSNUM, IERRINF)
Variable Integer ICLSNUM
Variable Integer IERRINF
ICLSNUM = 0
IERRINF = 0

Local Integer IBTRANSAC
Local Integer IBNBLIGNE
Local Char SZMACNUM
Local Integer IBTRANSAC

  IBNBLIGNE = 0
  SZMACNUM = ""
  #---------------------------------------------------#
  # Etape 1
  # Ouverture des tables nécessaires
  #---------------------------------------------------#
  If !clalev([F:MAIV]) : Local File MACITN [MAIV] : Endif
  #---------------------------------------------------#
  # Etape 2
  # Suppression des fiches liès à l'origine
  #---------------------------------------------------#
  IBTRANSAC = 0
  If not adxlog Then
    Trbegin [MAIV]
    IBTRANSAC = 1
  Endif
  Delete [MAIV] Where [F:MAIV]MACNUM=[M:MAC7]MACNUM and [M:MAC7]ORI=[M:MAC7]ORI and [F:MAIV]ORIVCR = [M:MAC7]ORIVCR and [F:MAIV]ORIVCRL = [M:MAC7]ORIVCRL
  If fstat Then
    If IBTRANSAC Then
      Rollback
    Endif
    #La suppression de l'historique d'implantation du parc a échoué.
    IERRINF = 133
    End
  Endif
  #---------------------------------------------------#
  # Etape 3
  # recherche de la dernière implantation
  #---------------------------------------------------#
  Filter [F:MAIV] Where [F:MAIV]MACNUM = [M:MAC7]MACNUM Order By [F:MAIV]CLSNUM Desc
  For [F:MAIV] Hint Key MAI1
    IBNBLIGNE = 1
    Break
  Next
  Filter [F:MAIV]
  #---------------------------------------------------#
  # Etape 4
  # Mise à jour de la fiche parc
  #---------------------------------------------------#
  If IBNBLIGNE = 0 Then
    #pas de ligne d'implantation précédente
    Raz [M:MAC7]ORI
    [M:MAC7]ORIVCR = ""
    [M:MAC7]ORIVCRL = 0
    End
  Endif
  SZMACNUM = [M:MAC7]MACNUM
  [M:MAC7] = [F:MAIV]
  # FGR 19/02/2008 : X3SUIVI45571 : DEBUT le transclasse n'est pas suffisant !
  [M:MAC7]BPCNUM = [F:MAIV]BPC
  # FGR 19/02/2008 : X3SUIVI45571 : FIN le transclasse n'est pas suffisant !
  ICLSNUM = [F:MAIV]CLSNUM
  [M:MACW]MACITNTYP = [M:MAC7]ITNTYP
  [M:MACW]BPCNUM = [M:MAC7]BPCNUM
  [M:MACW]FCYITN =[M:MAC7]ITNFCY
  [M:MACW]PLE = [M:MAC7]PLE
  [M:MACW]CCNNUM = [M:MAC7]CCNNUM
  [M:MACW]MACRSL = [M:MAC7]RSL
  [M:MACW]MACITNLND = [M:MAC7]LND
  [M:MACW]MACITNDAT = [M:MAC7]ITNDAT
  [M:MACW]MACORI = [M:MAC7]ORI
  [M:MACW]MACORIVCR = [M:MAC7]ORIVCR
  [M:MACW]MACORIVCRL = [M:MAC7]ORIVCRL
  [M:MACW]MACPURDAT = [M:MAC7]PURDAT
  [M:MACW]MACSALPRI = [M:MAC7]SALPRI
  [M:MACW]CUR = [M:MAC7]CUR
  [M:MACW]MACBPCDAT = [M:MAC7]BPCDAT
  [M:MACW]MACBPCPRI = [M:MAC7]BPCPRI
  [M:MACW]MACBPCCUR = [M:MAC7]BPCCUR
  [M:MACW]MACBPCDAT = [M:MAC7]ENDITN
  #---------------------------------------------------#
  # Etape 4
  # Suppression de cette implantation
  #---------------------------------------------------#
  Delete [MAIV] Where [F:MAIV]MACNUM = [M:MAC7]MACNUM and [F:MAIV]CLSNUM = ICLSNUM
  If fstat Then
    If IBTRANSAC = 1 Then
      Rollback
    Endif
    #La suppression de l'historique d'implantation du parc a échoué.
    IERRINF = 133
  Else
    If IBTRANSAC = 1 Then
      Commit
    Endif
  Endif
End

