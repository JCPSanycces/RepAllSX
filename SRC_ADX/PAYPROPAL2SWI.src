#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Swiss Localization
# File          : PAYPROPAL2SWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 19.05.15
######################################################################################################
# Module        : Accounting
# Description   : Swiss specific initializations for payment proposal
######################################################################################################
 # Updates :
 # Date     |Author|Description
 # 03.08.15 |Bader |CRE_REG_INIT: use [F:PYH]BID instead of [F:PIH]BID
 # 25.01.16 |Bader |CRE_REG_INIT: use [F:PIH]BVRBID instead of [F:PYH]BID
 # 2018-07-25|Bader |X3-99013: CRE_REG_INIT: support QR codes
 # 29.08.18 |Bader |X3-104610: check against [F:PIH]BPRPAY instead of [F:PIH]BPR, try to find BID for BPR first, if not found second try with BPRPAY
######################################################################################################

$CRE_REG_INIT
If [F:PYH]BID = "" and ((dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2) or (dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2)) Then # parameter "Swiss ISR/QR checks in payments" = yes?
    If !clalev([F:PIH])  Then : Local File PINVOICE [PIH]  : Endif
    If !clalev([F:XQRC]) Then : Local File SWIQRC   [XQRC] : Endif

    [F:PYH]SWISUP3 = int(val(func AFNC.PARAM("DEFBANCRG", "")))
    [F:PYH]SWISUP2 = 1                 # None

    #---- init BID with BID from SWIQRC/PINVOICE ----#
    Call LEC_TPY_LEG(GCURLEG, [F:PYH]PAYTYP) From CPTLEC  # read payment entry type
      # X3-29237
    If find([F:TPY]SWIPAYTYP, 2, 3, 4) Then   # DTA/EZAG/ISO payment?
        If [F:PIH]BPRPAY = [F:PYH]BPR Then
            Local Integer FOUND : Raz FOUND
            Local Char ACTBID(GLONBID)
            If !clalev([F:XBID]) Then : Local File BID [XBID] : Endif

            # first step: try to find ISR bill information
            If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2
                ACTBID = [F:PIH]BVRBID
                Gosub FINDBID
                If FOUND : Return : Endif
            Endif
            # no ISR bill information found > try to find QR bank ID in SWIQRC
            If dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2
                Read [F:XQRC]SWIQRC0 = [F:PIH]NUM;6           # try to find QR bill infomation
                If !fstat
                    #---- read BID with value from SWIQRC ----#
                    ACTBID = right$([F:XQRC]IBACOD,5)
                    Gosub FINDBID
                Endif
            Endif
        Endif
    Endif
Endif
Return


$FINDBID
Read [F:XBID]BID0 = 1;[F:PIH]BPR;ACTBID       # first try to find BID for supplier (manually selected)
If fstat = 0 Then
    FOUND = 1
Else
    Read [F:XBID]BID0=1;[F:PIH]BPRPAY;ACTBID  # second try to find BID for pay-to supplier (ISR)
    If fstat=0
        FOUND = 1
    Endif
Endif
If FOUND
    Gosub FILLPYH
Endif
Return


$FILLPYH
[F:PYH]BIDCRY = [F:XBID]CRY
[F:PYH]BID    = [F:XBID]BIDNUM
[F:PYH]PAB1   = [F:XBID]PAB1
[F:PYH]PAB2   = [F:XBID]PAB2
[F:PYH]PAB3   = [F:XBID]PAB3
[F:PYH]PAB4   = [F:XBID]PAB4
[F:PYH]BICCOD = [F:XBID]BICCOD
If dim([F:PYH]MIDPAB1) > 0   Then : [F:PYH]MIDPAB1   = [F:XBID]MIDPAB1  : Endif
If dim([F:PYH]MIDPAB2) > 0   Then : [F:PYH]MIDPAB2   = [F:XBID]MIDPAB2  : Endif
If dim([F:PYH]MIDPAB3) > 0   Then : [F:PYH]MIDPAB3   = [F:XBID]MIDPAB3  : Endif
If dim([F:PYH]MIDPAB4) > 0   Then : [F:PYH]MIDPAB4   = [F:XBID]MIDPAB4  : Endif
If dim([F:PYH]MIDBICCOD) > 0 Then : [F:PYH]MIDBICCOD = [F:PYH]MIDBICCOD : Endif
If dim([F:PYH]MIDCRY) > 0    Then : [F:PYH]MIDCRY    = [F:XBID]MIDCRY   : Endif
Return


# called from D_BIDNUM (_READ_DFLT_BIDNUM) in SUBPAYC
# We try to read the BID from the QR bill data or if these don't exist from the ISR info in the invoice
$D_BIDNUM
Local Integer INV_TYP
Gosub IS_ISR_QR_INVOICE
If INV_TYP <> 0             # ISR or QR invoice
   Gosub FILLBID
Endif
Return


$IS_ISR_QR_INVOICE
Raz INV_TYP
If (dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2) or (dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2) Then # parameter "Swiss ISR/QR checks in payments" = yes?
    If !clalev([F:XPIH]) Then : Local File PINVOICE [XPIH]  : Endif
    If !clalev([F:XQRC]) Then : Local File SWIQRC   [XQRC] : Endif

    #---- init BID with BID from SWIQRC/PINVOICE ----#
    Call LEC_TPY_LEG([F:CPY]LEG,[M:PCL]PAYTYP(nolign-1)) From CPTLEC  # read payment entry type
    If find([F:TPY]SWIPAYTYP, 2, 3, 4) Then   # DTA/EZAG/ISO payment?
        If !clalev([F:XBID]) Then : Local File BID [XBID] : Endif

        # first step: try to find ISR bill information
        If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2
            Read [F:XPIH]PIH0 = [M:PCL]NUM(nolign-1)    # read invoice header
            If !fstat
                Read [F:XBID]BID0 = 1;[F:XPIH]BPRPAY;[F:XPIH]BVRBID
                If !fstat Then
                    INV_TYP = 1           # ISR invoice
                    Return
                Endif
            Endif
        Endif
        # no ISR bill information found > try to find QR bank ID in SWIQRC
        If dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2
            Read [F:XQRC]SWIQRC0 = [M:PCL]NUM(nolign-1);6     # try to find QR bill infomation
            If !fstat
                #---- read BID with value from SWIQRC ----#
                Read [F:XBID]BID0 = 1;[M:PCL]BPRPAY(nolign-1);right$([F:XQRC]IBACOD,5)
                If fstat = 0 Then
                    INV_TYP = 2           # QR invoice
                Endif
            Endif
        Endif
    Endif
Endif
Return

$FILLBID
[M:PCL]BIDCRY(nolign-1) = [F:XBID]CRY
VALEUR = [F:XBID]BIDNUM
Call IBAN([M:PCL]BIDCRY(nolign-1), VALEUR, [M:PCL]IBAN(nolign-1)) From TRTBPA
Affzo [M:PCL]BIDCRY(nolign-1), IBAN(nolign-1)
Return


$AM_BIDNUM
Local Integer INV_TYP
Gosub IS_ISR_QR_INVOICE
If INV_TYP <> 0             # ISR or QR invoice
    If INV_TYP = 1
        GMESSAGE = mess(105,3648,1)  # Bank ID may not be changed for ISR invoice"
    Elsif INV_TYP = 2
        GMESSAGE = mess(106,3648,1)  # Bank ID may not be changed for QR invoice"
    Endif
    mkstat = 2
Endif
Return

