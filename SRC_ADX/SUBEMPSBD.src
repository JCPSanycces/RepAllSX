$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When Default
Endcase
Return


$SEL_TABLE
Case TABLE
  When "SELEMPSBD"
    If clalev ([F:ESB])=0 : Local File EMPSBD [ESB] : Endif
    Filter [F:ESB]
    OBJET     = "EMPSBD"
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ESB]CHEF=[M]CHEF)',"&") From GOBJSUB
Endcase
Return

