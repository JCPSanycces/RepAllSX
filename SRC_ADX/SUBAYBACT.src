#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion champs bloc
## Actions
#  Version 0001
#
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "TRT_DIV"          : Gosub TRT_DIV
 When "SEL_LISTE"        : Gosub SEL_LISTE
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYBBLCSEL     BLCSEL        Sélection d'un champ bloc 
#      AYBBLCCTL     BLCCTL        Controle d'un champ bloc (appeler par après modif. sur le type AYB)
#      AYBFIESEL     FIESEL        Sélection d'un champ bloc 
#      AYBFIECTL     FIECTL        Controle d'un champ bloc 
######################################################################################
$TRT_DIV
Case TRAIT
When "FIESEL"
     Gosub SEL_FIE
When "FIECTL"
     Gosub CTL_FIE
When "BLCCTL"
     Gosub CTL_BLC
Endcase
Return

$SEL_LISTE
Case LISTE
When "BLCSEL"
     Gosub SEL_BLC
Endcase
Return


#    AYBFIESEL  Sélection d'un champ bloc 
######################################################################################
# VALEUR        Adresse       Code champ    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code Bloc     
#          3    Valeur        Options       "I": Chps avec lien interface
#          4    Valeur        Code entité   Facultatif: code entité pour bloc en-cours de création  (Utilisée en création AYB)
#               
$SEL_FIE
#---------------------------------------------------------------#
Local Char FCYWRK(GLONAYG), BLCCOD(GLONAYB), BLCENTCOD(GLONAYE), OPTION, WSTR, WOPT
Local Integer WI
[L]FCYWRK    = PARAM(1)   # Site 
[L]BLCCOD    = PARAM(2)   # Bloc
[L]OPTION    = PARAM(3)   # Option: I Champs uniquement liés à l'interface
                          #         S Champ pour sélection (menu 7931 - pas de 6(image))
[L]BLCENTCOD = PARAM(4)   # Facultatif: entité du bloc 

# Lecture du blocs
If [L]BLCENTCOD=""
    If !clalev([F:AYB]) : Local File AYTELTBLC [AYB] : Endif
    Read [AYB]AYB0 = [L]FCYWRK;[L]BLCCOD
    If fstat
        mkstat=2 : GMESSAGE="Xtend-Internal error (Action AYBFIECTL): No Bloc record"-[L]BLCCOD
        Return
    Endif
    [L]BLCENTCOD=[F:AYB]ENTCOD
Endif

If [L]BLCENTCOD = ""                                            # Blocs code réservé sans entité
    WOPT=""
    If instr(1,OPTION,"S") : WOPT +="S" : Endif                 # Champ pour sélection 
    Call SELECT("AYF",WOPT,VALEUR,[L]FCYWRK) From SELOBJ 
    # Code équivalent
    # Local Char PARMSK(250)(1..16)
    # PARMSK(1) = "AYF"
    # PARMSK(2) = ""
    # PARMSK(3) = 
    # Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION

Else                                                  # Bloc classique
    ## Action AYEFIESEL
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "AYEFIESEL"
    PARMSK(1) = [L]FCYWRK
    PARMSK(2) = [L]BLCENTCOD
    PARMSK(3) = "EL"    # ts les chps 
    If instr(1,OPTION,"I") : PARMSK(3) +="I" : Endif   # Avec lien avec l'interface
    If instr(1,OPTION,"S") : PARMSK(3) +="S" : Endif                 # Champ pour sélection 
    Call S_LIS_CHAR(VALEUR,PARMSK,"FIESEL","SUBAYEACT","") From GACTION
    GACTION = SAVACT
Endif
Return

#    AYBFIECTL  Controle d'un champ entité 
######################################################################################
# VALEUR        Adresse       Code champ    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code Bloc     
#          3    Valeur        Options       "I": Chps avec lien interface
#                                           "S": Champ pour sélection (menu 7931 - pas de 6)
#          4    Valeur        Code entité   Facultatif: code entité pour bloc en-cours de création (Utilisée en création AYB)
#
$CTL_FIE
Local Char FCYWRK(GLONAYG), BLCCOD(GLONAYE), BLCENTCOD(GLONAYE), OPTION, WSTR, WOPT
Local Integer WI
[L]FCYWRK    = PARAM(1)   # Site 
[L]BLCCOD    = PARAM(2)   # Bloc
[L]OPTION    = PARAM(3)   # Option
[L]BLCENTCOD = PARAM(4)   # Option: entité du bloc (Utilisée en création AYB)

# Lecture du blocs
If [L]BLCENTCOD=""
    If !clalev([F:AYB]) : Local File AYTELTBLC [AYB] : Endif
    Read [AYB]AYB0 = [L]FCYWRK;[L]BLCCOD
    If fstat
        mkstat=2 : GMESSAGE="Xtend-Internal error (Action AYBFIECTL): No Bloc record"-[L]BLCCOD
        Return
    Endif
    [L]BLCENTCOD=[F:AYB]ENTCOD
Endif

If [L]BLCENTCOD = ""             # Blocs code réservé sans entité
    WOPT=""
    ## Ctl std
    If instr(1,OPTION,"S") : WOPT +="S" : Endif                 # Champ pour sélection 
    Call CONTROLE("AYF",WOPT ,VALEUR,[L]FCYWRK,mkstat) From CONTOBJ
Else                                                            # Bloc classique
    ## Action AYEFIECTL
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "AYEFIECTL"
    PARMSK(1) = [M]FCYCOD
    PARMSK(2) = [L]BLCENTCOD
    PARMSK(3) = "EL"
    If instr(1,OPTION,"I") : PARMSK(3) +="I" : Endif            # Avec lien avec l'interface
    If instr(1,OPTION,"S") : PARMSK(3) +="S" : Endif                 # Champ pour sélection 
    Call S_AFF_CHAR(VALEUR,PARMSK,"FIECTL","SUBAYEACT","") From GACTION
    GACTION = SAVACT
Endif
Return


#    AYBBLCL  Sélection d'un bloc 
######################################################################################
# VALEUR        Adresse       Code Bloc     
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Options       "!X" sans Blocs spéciaux (aMain...)   (utilisation par mask AYG1)
#                               " "         "!C" Blocs sans sélection avec bloc aCurrent 
#
$SEL_BLC
#---------------------------------------------------------------#
If !(dim(SAVACT)<0) and SAVACT="AFMTLIB" : Return : Endif        # Contournement Type AVV et sélection sur type AYB
#
Local Char FCYWRK(GLONAYG), OPTION, BLCCOD(GLONAYB)
Local Integer WI, WFLG
If clalev([F:AYB])=0 : Local File AYTELTBLC [AYB] : Endif
If clalev([F:AYN])=0 : Local File AYTLINES [AYN] : Endif

[L]BLCCOD    = VALEUR     # Bloc
[L]FCYWRK    = PARAM(1)   # Site 
[L]OPTION    = PARAM(2)   # Option

Filter [AYB] Where FCYCOD=[L]FCYWRK
WI = rowcount([AYB])
Local Char     TEX(50)(1..WI) , TEXTE(80)(1..WI,1..3)
Local Integer NBTEX
If !WI : Goto SEL_BLC_E : Endif

TIT(0)=mess(95,7900,1)
# TIT(1)=mess(7,7910,1)
TIT(1)=mess(15,115,1)
TIT(2)=mess(82,123,1)
TIT(3)=mess(6,7910,1)

For [AYB]
  WFLG=1
  If instr(1,OPTION,"!X")  # sans Blocs spéciaux
    WFLG = (func SUBAYB.BLCSPEXT([AYB]BLCCOD,[AYB]ENTCOD)=0)    # Pas un bloc spécial
  Endif
  If WFLG=1 & instr(1,OPTION,"!C")  # Blocs sans sélection avec bloc aCurrent
     Filter [AYN] Where  FCYCOD=[L]FCYWRK and LINCODTYP=2 and 
&                        LINCOD=toupper([AYB]BLCCOD) and LINTYP=30 and VALBLCCOD="aCurrent"
     WFLG = (rowcount([AYN]) = 0)
  Endif
  If WFLG    # eligible
     NBTEX+=1
     TEX(NBTEX)=[AYB]BLCCOD
     TEXTE(NBTEX,1)=[AYB]BLCCOD
     Call LECTEXTRA( TEXTE(NBTEX,2),"AYTELTBLC","INTIT",[F:AYB]FCYCOD,[F:AYB]BLCCOD) From ATEXTRA
     TEXTE(NBTEX,3)=[AYB]ENTCOD
  Endif
Next

$SEL_BLC_E
Filter [AYB]
Filter [AYN]

If NBTEX=0
    GERR=2 : GMESSAGE =mess(99,100,1) : mkstat=2
Endif
Return

#    AYBBLCCTL  Controle d'un bloc (appeler par ctl sur le type AYB)
######################################################################################
# VALEUR        Adresse       Code Bloc     
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Options       "!X" sans Blocs spéciaux (aMain...)   (utilisation par mask AYG1)
#                               " "         "!C" Blocs sans sélection avec bloc aCurrent 
#
$CTL_BLC
Local Char FCYWRK(GLONAYG), OPTION, BLCCOD(GLONAYB)
Local Integer WI, WFLG
If clalev([F:AYB])=0 : Local File AYTELTBLC [AYB] : Endif
If clalev([F:AYN])=0 : Local File AYTLINES [AYN] : Endif

[L]BLCCOD    = VALEUR     # Bloc
[L]FCYWRK    = PARAM(1)   # Site 
[L]OPTION    = PARAM(2)   # Option

# Vide = ctl par chps oblig dans paramètrage écran
If VALEUR="" : Return : Endif

# Ctl classique
If ([L]FCYWRK<>[AYB]FCYCOD or [L]BLCCOD <> [AYB]BLCCOD)   # Test pour limiter les lectures
    Read [AYB]AYB0=[L]FCYWRK;[L]BLCCOD
    If fstat    # Fiche inexistante (gérer par le std)
      Return
    Endif
Endif

# sans Blocs spéciaux
If instr(1,OPTION,"!X")  
  If func SUBAYB.BLCSPEXT([AYB]BLCCOD,[AYB]ENTCOD) 
    GMESSAGE=mess(97, 7900,1) : mkstat=2 : Return
  Endif
Endif
# Blocs sans sélection avec bloc aCurrent
If instr(1,OPTION,"!C")  
    Filter [AYN] Where  FCYCOD=[L]FCYWRK and LINCODTYP=2 and 
&                        LINCOD=toupper([AYB]BLCCOD) and LINTYP=30 and VALBLCCOD="aCurrent"
    If !(rowcount([AYN]) = 0)
        GMESSAGE=mess(96, 7900,1) : mkstat=2
    Endif
Endif
Return

