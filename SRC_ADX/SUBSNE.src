#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# SUBSNE                                         JL - Septembre 2000   #
#                                                                      #
#    REVISION DES TARIFS VENTE : PARAMETRAGE                           #
#                                                                      #
#    - Action e_commerce : GOBJET                                      #
#----------------------------------------------------------------------#
#    La gestion des lignes du paramétrage est effectuée par            #
#    l'action GOBJET "SND" qui est appelée par le bouton "Lignes"      #
#----------------------------------------------------------------------#
# Table mise à jour  : SINCENT [F:SNE]                                 #
#                      SINCDET [F:SND]                                 #
# Attention : Ce traitement contient aussi les actions sur champ       #
#             de l'écran SPCINCRE [M:SPIE]                             #
########################################################################
Call OBJET("SNE",GBIDC1,GBIDC2) From GOBJET
End
########################################################################

$ACTION
Local Char W_ACTION (GLONACT) : W_ACTION=ACTION
Case ACTION
 When "OUVRE"                : Gosub OUVRE
 When "RAZCRE"               : Gosub RAZCRE
 When "INICRE"               : Gosub INICREMOD
 When "INIMOD"               : Gosub INICREMOD
 When "LIENS"                : Gosub LIENS
 When "SETBOUT"              : Gosub SETBOUT
 When "AVANTBOUT"            : Gosub AVANTBOUT
 When "CREATION"             : Call VALID([F:SNE]COD,nomap)
                               Default File [SNE]
 When "MODIF"                : Call VALID([F:SNE]COD,nomap)
                               Default File [SNE]
 When "ANNULE"               : Gosub ANNULE

#--- Actions de la sélection des variables

 When "SEL_TABLE"            : Gosub SEL_TABLE
 When "FIN_TABLE"            : Gosub FIN_TABLE

#---

 When Default
Endcase
Return


#######################################################################
$OUVRE
Local Char     CLESNE (20), CLESND (20)
Local  Char    APPLI    : # nom du dossier (pour generer ecrans et traitements)
APPLI=nomap

If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif
If clalev([F:AXX])=0 : Local File =APPLI+".ATEXTRA"     [AXX] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"     [ATI] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"     [ATZ] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"       [ATY] : Endif
If clalev([F:SPI])=0 : Local File =APPLI+".SPRICINCR"   [SPI] : Endif

Return

#######################################################################
$RAZCRE
[M:SPIE]RLGTBL="SPRICINCR"
Return

#######################################################################
$LIENS
[M:SPIE]RLGTBL="SPRICINCR"
#Read [F:PRS]PRS0=1;""
Read [F:PRS]PRS0=1;[M:SPIE]PLISTC
Read [SPC]SPC0=[F:SNE]PLI
If fstat : Raz [F:SPC] : Endif
Raz [M:SPIE]XXPRS
For I=0 To dim([F:PRS]INVDTA)-1
  If [F:SPC]DISCRGPRO(I)=1
    Read [AXX]AXX0 = "PRICSTRUCT";"DESAXX("+num$(I)+")";GLANGUE;num$([F:PRS]BPCBPS);[F:PRS]PLISTC
    If !fstat : [M:SPIE]XXPRS(I) = [F:AXX]TEXTE : Endif
  Endif
Next I
If [M:SPIE]TYP<>3
  Raz [M:SPIE]CUROLD, [M]CURNEW, [M]CHGTYP
  Grizo CUROLD, CURNEW, CHGTYP
Else
  Actzo CUROLD, CURNEW, CHGTYP
Endif
GFLTPLI=[F:SNE]PLI

Return

#######################################################################
$SETBOUT
#--- les boutons
#     "1" = Lignes         mess(7,105,1)
#     "2" = Exécuter       mess(52,100,1)
#     "3" = Copie          mess(91,123,1)

#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET
#---
If CLECUR1="" or REP<>""
 Call VIREBOUT(CHAINE,"123") From GOBJET
Endif
#--- impossible d'executer si pas super utilisateur
#If [M]ACS<>"" & GPROFIL<>GSUPER
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC=GUSER;[M]ACS
  If fstat | [F:ACC]EXEC<>2
    Call VIREBOUT(CHAINE,"2") From GOBJET
  Endif
#Endif
Return

#######################################################################
$AVANTBOUT
Case BOUT
  When "1" : # Lignes
    If !VERROU
      # Modification en cours sur un autre poste
      GERR=1 : GMESSAGE=mess(10,100,1)
      Return
    Endif
Endcase
Return

#######################################################################
$ANNULE
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif

# suppression des lignes du paramétrage
Delete [F:SND]Where COD=[M:SPIE]COD
If fstat
  If fstat<4 GOK=1 : Return : Endif
Endif

## Suppression des traitements générés
#Local Char    NOMTRT(GDIMFIC), FICTRT(GDIMFIC), EXT(4)
#Local Integer STAT
#NOMTRT="WBI"+num$([M:SPIE]COD)
#For EXT = "adx", "src"
#  FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#  While filinfo(FICTRT,0)>=0
#    Call EFFACE(FICTRT,STAT) From ORDSYS
#    FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#  Wend
#Next EXT

## Suppression des traitements générés
Local Char    NOMTRT(GDIMFIC), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT
NOMTRT="WBI"+num$([M:SPIE]COD)

# Suppression "src"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
# Suppression "adx"
Call EXISTE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
If STAT = 1
     Call EFFACE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
Endif

# ACA - Suppression du texte traduisible
Delete [AXX] Where CODFIC="SINCENT" and IDENT1=[F:SNE]COD
Delete [AXX] Where CODFIC="SINCDET" and IDENT1=[F:SNE]COD

Return


$INICREMOD
# ACA
Call MAJTEXTRA([M:SPIE]DESAXX, "SINCENT","DESAXX",[M:SPIE]COD,"") From ATEXTRA
# SOS libellés
If dim([F:SNE]LANDESSHO)>0
    [F:SNE]LANDESSHO=GLANGUE+"~"+[M:SPIE]DESAXX
Endif
# TODO ACA - Libellés des variables
Local Integer I
For I = 0 To dim ( [M:SPIE]VARDESAXX ) -1
  Call MAJTEXTRA([M:SPIE]VARDESAXX(I), "SINCENT","VARDESAXX",[M:SPIE]COD,[M:SPIE]VARCOD(I)) From ATEXTRA
Next I

Return

#######################################################################

$CRIT_TARIF
Local Char    TEX (250)
Local Integer NBTEX, I, OK
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    NBTEX += 1
    If NBTEX > 1 : TEX += "\" : Endif
    TEX +="CRIT"+num$(I+1)+"  "+format$("K:20X",[F:SPC]CRIDES(I))+"  "+[F:SPC]FLDTYP(I)
  Endif
Next I
Call AVERTIR (TEX,OK) From GESECRAN

Return

#######################################################################
# Actions de sélection GSELECT
#######################################################################
$SEL_TABLE
# mettre valeur correctement (enlever les ")
If [F:ATY]CODTYP<>[M]VARTYP(nolign-1)
   Read [ATY]CODTYP = [M]VARTYP(nolign-1)
   If fstat : Raz [F:ATY] : Endif
Endif

If [F:ATY]OBJLIEN<>""
   OBJET=[F:ATY]OBJLIEN
   W_TABLE=TABLE
   If find ((mid$(VALEUR,1,1)),"'",'"') & find((mid$(VALEUR,len(VALEUR),1)),"'",'"')
      VALEUR=right$(VALEUR,2)
      VALEUR=left$(VALEUR,len(VALEUR)-1)
   Endif
   Gosub ACTION From SELOBJ
   TABLE=W_TABLE
Endif
Return

$FIN_TABLE
# mettre valeur correctement (mettre les ")
If [F:ATY]TYPTYP=7
   VALEUR=vireblc(VALEUR,2)
   If !find ((mid$(VALEUR,1,1)),"'",'"') & !find((mid$(VALEUR,len(VALEUR),1)),"'",'"')
      VALEUR='"'+VALEUR+'"'
   Endif
Endif

Return


#######################################################################
# Génération traitements liés au paramétrage
#######################################################################
Subprog VALID(CODE,APPLI)
Value Char CODE
Value Char APPLI

Local Integer I, I1
Local Integer OK
Local Char    NOMTRT (GDIMFIC), FICSRC (GDIMFIC)

Local Char    TBL_CODFIC (15) (0..15)  : # Tables liees Code table
# Issue 108342 - 2015-11-06 by MAE : Passage de ABRFIC de 3 à 8
#Local Char    TBL_ABRFIC (5)  (0..15)  : # Tables liees Abreviation table
Local Char    TBL_ABRFIC (GLONABR)  (0..15)  : # Tables liees Abreviation table
Local Char    TBL_CODIND (15) (0..15)  : # Tables liees Nom index 0 de la table
Local Char    TBL_EXPLNK (60) (0..15)  : # tables liess Expression lien

If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"       [ATY] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"     [ATI] : Endif
If clalev([F:SPC])=0 : Local File =APPLI+".SPRICCONF"   [SPC] : Endif
If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif

#Read [F:PRS]PRS0=1;""
Read [F:PRS]PRS0=1;[F:SNE]PLISTC

NOMTRT="WBI"+[F:SNE]COD
FICSRC = filpath("TRT",NOMTRT,"src",APPLI)
Openo FICSRC,0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WBI";[F:SNE]COD;"                                            ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"

# --- Définition de chargement des variables traitement

Wrseq "$VARIABLES"
Wrseq "Gosub VAR_DEF"
Wrseq "Gosub VAR_AFF"
Wrseq "Return"
Wrseq

Wrseq "$VAR_DEF"
For I=1 To [F:SNE]NBVAR
  Read [ATY]CODTYP = [F:SNE]VARTYP(I-1)
  Case [F:ATY]TYPTYP
    When 1 : Wrseq "Local Libelle  ";
    When 2 : Wrseq "Local Shortint ";
    When 3 : Wrseq "Local Integer  ";
    When 4 : Wrseq "Local Decimal  ";
    When 5 : Wrseq "Local Decimal  ";
    When 6 : Wrseq "Local Decimal  ";
    When 7 : Wrseq "Local Char     ";
    When 8 : Wrseq "Local Date     ";
  Endcase
  Wrseq num$([F:SNE]VARCOD(I-1));
  If [F:ATY]TYPTYP=7
    Wrseq " (250)";
  Endif
  Wrseq
Next I
Wrseq "Return"
Wrseq

Wrseq "$VAR_AFF"
Wrseq "Local Char WJ_VAR (250)"
For I=1 To [F:SNE]NBVAR
  Read [ATY]CODTYP = [F:SNE]VARTYP(I-1)
  Case [F:ATY]TYPTYP
    When 1,2,3,4,5,6
         Wrseq num$([F:SNE]VARCOD(I-1))+" = val([M:SPCI]VARVAL("+num$(I-1)+"))"
    When 7
         Wrseq "Raz WJ_VAR"
         Wrseq "WJ_VAR = [M:SPCI]VARVAL("+num$(I-1)+")"
         Wrseq "If find ((mid$(WJ_VAR,1,1)),";
         Wrseq chr$(34)+chr$(39)+chr$(34)+","+chr$(39)+chr$(34)+chr$(39)+") &"
         Wrseq "& find((mid$(WJ_VAR,len(WJ_VAR),1)),";
         Wrseq chr$(34)+chr$(39)+chr$(34)+","+chr$(39)+chr$(34)+chr$(39)+")"
         Wrseq "   "+num$([F:SNE]VARCOD(I-1))+" = evalue(WJ_VAR)"
         Wrseq "Else"
         Wrseq "   "+num$([F:SNE]VARCOD(I-1))+" = WJ_VAR"
         Wrseq "Endif"
    When 8
         Wrseq num$([F:SNE]VARCOD(I-1))+" = evalue('['+[M:SPCI]VARVAL("+num$(I-1)+")+']')"
  Endcase
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

# --- Si changement devise

If [F:SNE]TYP=3
  Wrseq "$CHGDEV_LIGNE"
  Wrseq "Local Decimal MNTDEV"
  If [F:SPC]CRICURNUM>0
    Wrseq "[F:SPI]CRIT"+num$([F:SPC]CRICURNUM)+"=[M:SPCI]CURNEW"
  Endif
  If [F:SPC]CRICURNUM=1
    Wrseq "[F:SPI]PLICRI1=[M:SPCI]CURNEW"
  Endif
  If [F:SPC]CRICURNUM=2
    Wrseq "[F:SPI]PLICRI2=[M:SPCI]CURNEW"
  Endif
  If [F:SPC]CRICURNUM=3
    Wrseq "[F:SPI]PLICRI3=[M:SPCI]CURNEW"
  Endif
  If [F:SPC]CRICURNUM=4
    Wrseq "[F:SPI]PLICRI4=[M:SPCI]CURNEW"
  Endif
  If [F:SPC]CRICURNUM=5
    Wrseq "[F:SPI]PLICRI5=[M:SPCI]CURNEW"
  Endif
  Wrseq "[F:SPI]CUR=[M:SPCI]CURNEW"
  If [F:SPC]PRIPRO=2 | [F:SPC]PRIPRO=3
    Wrseq "Call CONVERT2([M:SPCI]CUROLD,[M:SPCI]CURNEW,GLOCALDEV,[M:SPCI]CHGTYP,datesyst,"
    Wrseq "&             [F:SPI]PRI,[F:SPI]PRI,GBIDI3) From TRTDEV"
    Wrseq "[F:SPI]PRI=arr([F:SPI]PRI,0.0001)"
  Endif
  Wrseq "MNTDEV=[F:SPI]MINAMT : Gosub DEV_CONV : [F:SPI]MINAMT=MNTDEV"
  Wrseq "MNTDEV=[F:SPI]MAXAMT : Gosub DEV_CONV : [F:SPI]MAXAMT=MNTDEV"
  For I=0 To dim([F:SPI]DCGVAL)-1
    If [F:PRS]VALTYP(I)=1
      Wrseq "MNTDEV=[F:SPI]DCGVAL("+num$(I)+") : ";
      Wrseq "Gosub DEV_CONV : ";
      Wrseq "[F:SPI]DCGVAL("+num$(I)+")=MNTDEV"
    Endif
  Next I
  Wrseq "Return"
  Wrseq
  Wrseq "$DEV_CONV"
  Wrseq "Call CONVERT([M:SPCI]CUROLD,[M:SPCI]CURNEW,GLOCALDEV,[M:SPCI]CHGTYP,datesyst,"
  Wrseq "&             MNTDEV,MNTDEV,GBIDI3) From TRTDEV"

  Wrseq "Return"
  Wrseq
  Wrseq "#-----------------------------------------------------------------"
Endif

# --- Traitements generes pour les tables liees

Raz TBL_CODFIC, TBL_ABRFIC, TBL_CODIND, TBL_EXPLNK

For I=0 To dim([F:SNE]TBL)-1
  If [F:SNE]TBL(I)<>""
    Read [F:ATB]CODFIC=[F:SNE]TBL(I)
    If !fstat
      Filter [ATI] Where CODFIC=[F:SNE]TBL(I) & NUMLIG=1
      Read [ATI]NUMLIG First
      If !fstat
        TBL_CODFIC(I1)=[F:SNE]TBL(I)
        TBL_ABRFIC(I1)=[F:ATB]ABRFIC
        TBL_CODIND(I1)=[F:ATI]CODIND
        TBL_EXPLNK(I1)=[F:SNE]EXPLNK(I)
        I1 +=1
      Endif
      Filter [ATI]
    Endif
  Endif
Next I

# --- Ouverture des tables liees

Wrseq
Wrseq "$OPEN_TBL"
For I=0 To dim(TBL_CODFIC)-1
  If TBL_CODFIC(I)<>""
    Wrseq "If clalev([F:"+vireblc(TBL_ABRFIC(I),2)+"])=0 : ",
    Wrseq "Local File '"+vireblc(TBL_CODFIC(I),2)+"' ["+vireblc(TBL_ABRFIC(I),2)+"] : Endif"
  Endif
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

# --- Lecture des tables liees

Wrseq
Wrseq "$LECT_TBL"
For I=0 To dim(TBL_CODFIC)-1
  If TBL_CODFIC(I)<>""
    Wrseq "Read ["+TBL_ABRFIC(I)+"]"+TBL_CODIND(I)+"="+TBL_EXPLNK(I)
    Wrseq "If fstat : Raz [F:"+TBL_ABRFIC(I)+"] : Endif"
  Endif
Next I
Wrseq "Return"
Wrseq
Wrseq "#-----------------------------------------------------------------"

Openo
#Call VALID(NOMTRT,APPLI) From GRVALMSK2
Call VALID("TRT", NOMTRT,APPLI,OK) From VALMSKSUB
  If OK=0 GOK=0 : Endif

End

#########################################################################
# Traitement de la copie paramétrage tarif transaction de saisie
# TABLE = Clé de l'enregistrement à copier
#         (si la cle est numerique val(TABLE)
#########################################################################
$TRTCOP
If [M]DOSORG=nomap
  Local File SINCENT [SNE1]
  Local File SINCDET [SND1]
  Local File ATEXTRA [AXX1] #gbn-88556
Else
  Local File =[M]DOSORG+".SINCENT" [SNE1]
  Local File =[M]DOSORG+".SINCDET" [SND1]
  Local File =[M]DOSORG+".ATEXTRA" [AXX1] #gbn-88556
Endif
If [M]DOSDES=nomap
  Local File SINCENT [SNE2]
  Local File SINCDET [SND2]
  Local File ATEXTRA [AXX2] #gbn-88556
Else
  Local File =[M]DOSDES+".SINCENT" [SNE2]
  Local File =[M]DOSDES+".SINCDET" [SND2]
  Local File =[M]DOSDES+".ATEXTRA" [AXX2] #gbn-88556
Endif
Look [SNE2] SNE0=TABLE
If !fstat
   OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK=1 : Return : Endif
Endif

Call DEBTRANS From GLOCK
 Gosub TR_COP
Return

#------------------------------------------------------------------------
$TR_COP
GOK=1

Trbegin [SNE2] , [SND2]

  Delete [SNE2] Where COD=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".SINCENT"-TABLE  : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("SNE2",TABLE) From GLOCK         : Goto AB_TR_COP
  Endif

  Delete [SND2] Where COD=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".SINCDET"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("SND2",TABLE) From GLOCK        : Goto AB_TR_COP
  Endif

  For [SND1]SND0 Where COD=TABLE
    [F:SND2]=[F:SND1]
    Write [SND2]
    If fstat
      GOK=0 : Call FSTA("SND2") From GLOCK : Break
    Endif
  Next
  If    GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK  : Goto AB_TR_COP
  Endif

  For [SNE1]SNE0 Where COD=TABLE
    [F:SNE2]=[F:SNE1]
    #gbn-88556
    Call COPTEXTRA("SINCENT", "DESAXX", TABLE, "") From ATEXTRA
    If dim([F:SNE2]UPDUSR) > 0 Then
      [F:SNE2]UPDUSR = GUSER
    Endif
    If dim([F:SNE2]UPDDAT) > 0 Then
      [F:SNE2]UPDDAT = date$
    Endif
    If fstat Then
      GOK = 0
      Call FSTA("SNE2") From GLOCK
    Endif
    #---------
    Write [SNE2]
    If fstat
      GOK=0 : Call FSTA("SNE2") From GLOCK : Break
    Endif
  Next
  If    GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK  : Goto AB_TR_COP
  Endif

Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return


#########################################################################
# Pour éxécution valid. définitions révisons tarifs en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation définitions révisions tarifs depuis génération des patchs
Call GENPATCH(APPLI) From SUBSNE

End

#########################################################################

Subprog GENPATCH(APPLI)
Value Char APPLI

If clalev([F:SNE])=0 : Local File =APPLI+".SINCENT"     [SNE] : Endif

If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"       [ATY] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"      [ATB] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"     [ATI] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"     [ATZ] : Endif
If clalev([F:SPC])=0 : Local File =APPLI+".SPRICCONF"   [SPC] : Endif
If clalev([F:PRS])=0 : Local File =APPLI+".PRICSTRUCT"  [PRS] : Endif

For [SNE]
    Call VALID([F:SNE]COD, APPLI) From SUBSNE
Next
End

#######################################################################
#     Actions champs ecran SPINCRE
#######################################################################

######################################## Code tarif
Subprog AS_PLI(VALEUR)
Variable Char    VALEUR()
If GREP<>"C" : mkstat=2 : Endif
End

#---------------------------------------
Subprog AM_PLI(VALEUR)
Variable Char    VALEUR()

[M]PLISTC=[F:SPC]PLISTC
Raz [M]PLISTRCRD, PLIENDCRD, UPDCRDFLG, VLYDAT
Affzo PLISTRCRD, PLIENDCRD, UPDCRDFLG, VLYDAT
GFLTPLI=VALEUR
End

######################################## No fiche début
Subprog IB_PLISTRCRD
Raz GBOUT1
If [M]PLI<>"" & [M]PLISTRCRD<>"" : GBOUT1=mess(9,432,1) : Endif
End

#---------------------------------------
Subprog AM_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : [M:SPIE]PLIENDCRD=VALEUR : Affzo [M:SPIE]PLIENDCRD : Endif
End

