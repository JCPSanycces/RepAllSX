Subprog C_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
#Look [SPF] SPF0=[M]PLI;VALEUR
#If fstat
#  GERR=2 : GMESSAGE=mess(129,192,1) : # la fiche n'appartient pas au tarif
#Endif
End

######################################## No fiche fin
Subprog IB_PLIENDCRD
Raz GBOUT1
If [M]PLI<>"" & [M]PLIENDCRD<>"" : GBOUT1=mess(9,432,1) : Endif
End

#---------------------------------------
Subprog C_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
#Look [SPF] SPF0=[M]PLI;VALEUR
#If fstat
#  GERR=2: GMESSAGE=mess(129,192,1) : # la fiche n'appartient pas au tarif
#Endif
End

######################################## Type de traitement
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>3
  Raz [M]CUROLD, [M]CURNEW, [M]CHGTYP
  Affzo [M]CUROLD, CURNEW, CHGTYP
  Grizo CUROLD, CURNEW, CHGTYP
Else
  Actzo CUROLD, CURNEW, CHGTYP
Endif
End

######################################## Ancienne devise
Subprog AS_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CURNEW : mkstat=2 : End : Endif
End

######################################## Nouvelle devise
Subprog AS_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CUROLD : mkstat=2 : End : Endif
End

######################################## Type de cours
Subprog AS_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP=3 & VALEUR=0 : mkstat=2 : End :  Endif
End

######################################## Tableau des tables liees
Subprog B1_NBTBL
Gosub CRIT_TARIF
End

######################################## Table liée
Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL , I
NOL = nolign-1
# --- la table de base de la m.a.j SPRICINCR ne peut être une table liee
If VALEUR=[M:SPIE]RLGTBL : mkstat = 1 : End : Endif
If VALEUR="" : mkstat = 1 : End : Endif
Call C_TBL(VALEUR) From SUBPS1          : # appel du traitement de parametrage des stats
End


######################################## Expression de lien
Subprog AS_EXPLNK(VALEUR)
Variable Char    VALEUR()
Call AS_EXPLNK (VALEUR) From SUBPS1     : # appel du traitement de parametrage des stats
End

#---------------------------------------
Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
Call C_EXPLNK(VALEUR) From SUBPS1       : # appel du traitement de parametrage des stats
End


######################################## Tableau des variables
Subprog B1_NBVAR
Gosub CRIT_TARIF
End

######################################## Nom de variable
Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VARCOD) From OBJDIV
End

######################################## Type de la variable
Subprog C_VARTYP(VALEUR)
Variable Char    VALEUR()
If !find (VALEUR,"A","C","DCB","RAT","ITM","ITS","BPR","BPC","BPD","BPT",
&                "CUR","D","L","REP","UOM","AFF","STI","STC","FCY","CPY")
  mkstat=2
Endif
End

#--------------------------------------- ajout 25/11/2003 (JL)
Subprog AM_VARTYP(VALEUR)
Variable Char    VALEUR()
Read [ATY]CODTYP=VALEUR
If fstat : mkstat=2 : Endif

End

######################################## Valeur par défaut de la variable
Subprog AS_VARDEF(VALEUR)
Variable Char    VALEUR()
Local    Integer IJ
Raz [M:SPIE]FLTTAB, XXCONV, XXVAR
[M:SPIE]FLTTAB="find(ABRFIC,'SPI')"
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    [M:SPIE]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","+[F:SPC]CRIDES(I)
    IJ += 1
    [M:SPIE]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","+[F:SPC]CRIDES(I)  : # 07/08/03
    IJ += 1                                                               : # 07/08/03
  Else
    [M:SPIE]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1
    [M:SPIE]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","                   : # 07/08/03
    IJ += 1                                                               : # 07/08/03
  Endif
Next I
For I=0 To dim([F:PRS]INVDTA)-1
  If [M:SPIE]XXPRS(I)<>""
    [M:SPIE]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"+[M:SPIE]XXPRS(I)
    IJ += 1
  Else
    [M:SPIE]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif
Next I
End

#--------------------------------------- ajout 07/08/03 (JL)
Subprog IB_VARDEF
# si type de donnee liee à un objet : bouton "Selection"
Raz GBOUT2
If [F:ATY]CODTYP<>[M]VARTYP(nolign-1)
   Read [ATY]CODTYP = [M]VARTYP(nolign-1)
   If fstat : Raz [F:ATY] : Endif
Endif

If [F:ATY]OBJLIEN<>""
   GBOUT2=mess(18,100,1)
Endif

# si type de donnee <>"AFF" : suppression du bouton "Editeur de formule"
If [M]VARTYP(nolign-1)<>"AFF"
   Raz GBOUT1
Endif

End

#--------------------------------------- ajout 07/08/03 (JL)
Subprog C_VARDEF(VALEUR)
Variable Char    VALEUR()       : # VALEUR est toujours alpha (type donnee = AFF)
Local    Char    WJ_VALCHR

If [F:ATY]CODTYP<>[M]VARTYP(nolign-1)
   Read [ATY]CODTYP = [M]VARTYP(nolign-1)
   If fstat : Raz [F:ATY] : mkstat=2 : End : Endif
Endif

Case [F:ATY]TYPTYP
     When 1         : Local Libelle  WJ_VAL
     When 2         : Local Shortint WJ_VAL
     When 3         : Local Integer  WJ_VAL
     When 4,5,6     : Local Decimal  WJ_VAL
     When 7         : Local Char     WJ_VAL (250)
     When 8         : Local Date     WJ_VAL

     When Default   : End
Endcase

If VALEUR <>""

   If [F:ATY]OBJLIEN<>""                        : # si type donnee avec lien --> majuscule
      VALEUR = vireblc(toupper(VALEUR),2)
   Endif

   If find([F:ATY]TYPTYP,1,2,3,4,5,6)           : # Controle valeur numerique
      WJ_VAL=val(VALEUR)
      If num$(WJ_VAL)<>VALEUR
         mkstat=2 : End
      Endif
   Endif

   If [F:ATY]TYPTYP=7                           : # Controle valeur alpha
      WJ_VAL=vireblc(VALEUR,2)   :              : #   enlever guillemets
      If find ((mid$(WJ_VAL,1,1)),"'",'"') & find((mid$(WJ_VAL,len(WJ_VAL),1)),"'",'"')
         WJ_VAL=right$(WJ_VAL,2)
         WJ_VAL=left$(WJ_VAL,len(WJ_VAL)-1)
      Endif
   Endif

   If [F:ATY]OBJLIEN<>""                        : # Controle par objet
      WJ_VALCHR=num$(WJ_VAL)
      Call CONTROLE ([F:ATY]OBJLIEN,"",WJ_VALCHR,"",mkstat) From CONTOBJ
      If mkstat : End : Endif
   Endif

   If [F:ATY]TYPTYP=8                  : # Controle valeur date
      Call CONTROLE(VALEUR,"D",0,0,WJ_VALCHR) From FMTVAR
      If mkstat : GERR=1 : GZONE="VARDEF" : GZNUM=0 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      WJ_VAL=WJ_VALCHR
   Endif

   If [M]VARCTL(nolign-1)<>""                   : # Controle avec Table de controle
      Case [F:ATY]TYPTYP
           When 1         :  Call CONTACL_LIB ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 2,3,4,5,6 :  Call CONTACL_NUM ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 7         :  Call CONTACL_CHAR([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 8         :  Call CONTACL_DAT ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
      Endcase
      If mkstat : End : Endif
   Endif
Endif

End

######################################## ajout 28/11/2003 (JL)
Subprog C_VARCTL(VALEUR)
Variable Char    VALEUR()

If VALEUR="" | vireblc([M]VARDEF(nolign-1),2)="" : End : Endif

If [F:ATY]CODTYP<>[M]VARTYP(nolign-1)
   Read [ATY]CODTYP = [M]VARTYP(nolign-1)
   If fstat : Raz [F:ATY] : mkstat=2 : End : Endif
Endif

Case [F:ATY]TYPTYP
     When 1         : Local Libelle  WJ_VAL
     When 2         : Local Shortint WJ_VAL
     When 3         : Local Integer  WJ_VAL
     When 4,5,6     : Local Decimal  WJ_VAL
     When 7         : Local Char     WJ_VAL (250)
     When 8         : Local Date     WJ_VAL

     When Default   : End
Endcase

If find([F:ATY]TYPTYP,1,2,3,4,5,6)           : # Controle valeur numerique
   WJ_VAL=val([M]VARDEF(nolign-1))
Endif

If [F:ATY]TYPTYP=7                           : # Controle valeur alpha
   WJ_VAL=vireblc([M]VARDEF(nolign-1),2)   :              : #   enlever guillemets
   If find ((mid$(WJ_VAL,1,1)),"'",'"') & find((mid$(WJ_VAL,len(WJ_VAL),1)),"'",'"')
      WJ_VAL=right$(WJ_VAL,2)
      WJ_VAL=left$(WJ_VAL,len(WJ_VAL)-1)
   Endif
Endif

If [F:ATY]TYPTYP=8                  : # Controle valeur date
   WJ_VAL=evalue("["+[M]VARDEF(nolign-1)+"]")
Endif

Case [F:ATY]TYPTYP
     When 1         :  Call CONTACL_LIB (VALEUR,"",WJ_VAL) From SUBACL
     When 2,3,4,5,6 :  Call CONTACL_NUM (VALEUR,"",WJ_VAL) From SUBACL
     When 7         :  Call CONTACL_CHAR(VALEUR,"",WJ_VAL) From SUBACL
     When 8         :  Call CONTACL_DAT (VALEUR,"",WJ_VAL) From SUBACL
Endcase

End

