##########################################################################
## Etiquette ajoutée par le superviseur 17/05/2004 14:09:01 (JL)
##########################################################################
Subprog AM_TBL(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

Raz [M]ABRLNK(nolign-1)
Read [ATB]CODFIC = VALEUR
If !fstat : [M]ABRLNK(nolign-1)=[F:ATB]ABRFIC : Endif

Raz [M]CLELNK(nolign-1)
Read [ATI]NUMLIG(2) = VALEUR ; 1
If !fstat : [M]CLELNK(nolign-1)=[F:ATI]CODIND Endif
End



