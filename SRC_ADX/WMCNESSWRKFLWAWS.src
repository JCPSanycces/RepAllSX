####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_CHRONO From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CHRONO2 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_UID From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_STA From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_FLDNAM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_FLDTYP From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_NEWVAL From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_OLDVAL From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CODFIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_ABRFIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_REFNUM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_TCH_NAM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_USR From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_TCH_SRN From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CHEF From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_TCH_LEG From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CLA From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_EMPPIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_ALPKEY1 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_ALPKEY2 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_ALPKEY3 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_INTKEY1 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_INTKEY2 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_INTKEY3 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_DATKEY1 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_DATKEY2 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_DATKEY3 From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CHEFUSR From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_FLGSIG From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_WRK From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CTRNUM From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_MSG From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_MAIREC From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub AINIT From WMC0ESSWRKFLWAWS : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
Gosub _ALOADATTRIBUTE_UID From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_STA From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FLDNAM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FLDTYP From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CODFIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_ABRFIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_REFNUM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
Gosub LNKPRO_REFNUM From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_USR From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_TCH_LEG From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_EMPPIC From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_CHEFUSR From WMC1ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC2ESSWRKFLWAWS : Gosub TESTALLSTAT
For AINDCLA=1 To maxtab(this.ESSWRKEMP)
 If this.ESSWRKEMP(AINDCLA)<>null& find(this.ESSWRKEMP(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKEMP(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKSA)
 If this.ESSWRKSA(AINDCLA)<>null& find(this.ESSWRKSA(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKSA(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKCHD)
 If this.ESSWRKCHD(AINDCLA)<>null& find(this.ESSWRKCHD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKCHD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



