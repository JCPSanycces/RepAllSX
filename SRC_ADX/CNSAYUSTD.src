#---------------------------------------------------------------#
# Usage Sélection, action, ...   AYTLINES [AYN]
#---------------------------------------------------------------#
Subprog USG_AYN(FCYXT, TYP, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, TYP, COD           # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     

# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)

Local Clbfile     WFIL(1)                   # Filtre
Local Char        WFILFCY(20)
Local File AYTLINES [AYN]                   # Obligatoire suite recursif
Local Char        WMSG(40)

WFILFCY    = 'FCYCOD="' + FCYXT + '"'
# AYTLINES ne contient que les types suivants pour usage
Case TYP
When "AYF"
    Gosub USG_AYN_F : Gosub USG_AYN_LOAD : If USG_NB = USG_NBMAX: End : Endif
When "AYE"
    Gosub USG_AYN_E : Gosub USG_AYN_LOAD : If USG_NB = USG_NBMAX: End : Endif
When "AYB"
    Gosub USG_AYN_B : Gosub USG_AYN_LOAD : If USG_NB = USG_NBMAX: End : Endif
When "AYL"
    Gosub USG_AYN_L : Gosub USG_AYN_LOAD : If USG_NB = USG_NBMAX: End : Endif
Endcase
End

#-- Recherche usage Champs  --
$USG_AYN_F                           
WFIL=    WFILFCY 
WFIL+=   ' & ( FIECOD="'   +COD+ '"'
WFIL+=   ' | PARCOD="'     +COD+ '"'
WFIL+=   ' | VALFIECOD="'  +COD+ '"'
#WFIL+=   ' | BLCFIECOD="' +COD+ '"'
WFIL+=   ' | VA2FIECOD="'  +COD+ '" )'
Return

#-- Recherche usage Entité  --
$USG_AYN_E   
WFIL=    WFILFCY 
WFIL+=   ' & ( VALENTCOD="' +COD+ '"'
WFIL+=   ' | VALFIELNKE="'  +COD+ '"'
#WFIL+=   ' | BLCFIELNKE="' +COD+ '"'
WFIL+=   ' | VA2FIELNKE="'  +COD+ '"'
WFIL+=   ' | ENTCOD="'      +COD+ '"'
WFIL+=   ' | FIELNKENT="'   +COD+ '" )'
Return

#-- Recherche usage Bloc  --
$USG_AYN_B                           
WFIL=    WFILFCY 
WFIL+=   ' & ( VALBLCCOD="' +COD+ '"'
WFIL+=   ' | VA2BLCCOD="'   +COD+ '" )'
Return

#-- Recherche usage Lien dynamique  --
$USG_AYN_L                           
WFIL=    WFILFCY 
WFIL+=   ' & ( DLKCOD="'    +COD+ '" )'
Return

#-- Routine Chgt tableau    --
#-----------------------------
$USG_AYN_LOAD 
Filter [AYN] Where evalue(WFIL) Order By Key AYN0
For [AYN]
    Gosub USGTAB_GETNB : If USG_NB = USG_NBMAX : Break : Endif
    #
    USG_AYTNIV(USG_NB)= USG_NIV
    USG_AYTCOD(USG_NB)=[AYN]LINCODSTD 
    USG_AYTTYPX3(USG_NB)=func AYTUTIA.GETAYN_X3COD([AYN]LINCODTYP) 
    Case [AYN]LINTYP
    When 10   
        Case [AYN]LINCODTYP
        When 1          :     WMSG = mess(100,7900,1)
        When 7          :     WMSG = mess(199,7900,1)
        When Default    :     WMSG="LINTYP 10-LINCODTYP unknown: "+num$([AYN]LINCODTYP)
        Endcase
    When 11             :     WMSG = mess(102,7900,1)
    When 12             :     WMSG = mess(101,7900,1)
    When 20             :     WMSG = mess(103,7900,1)
    When 21
        Case [AYN]LINCODTYP
        When 1,3        :     WMSG = mess(104,7900,1)
        When Default    :     WMSG="LINTYP 21-LINCODTYP unknown: "+num$([AYN]LINCODTYP)
        Endcase
    When 30
        Case [AYN]LINCODTYP
        When 1          :     WMSG = mess(98,7900,1)
        When 2,3,4      :     WMSG = mess(99,7900,1)
        When Default    :     WMSG="LINTYP 30-LINCODTYP unknown: "+num$([AYN]LINCODTYP)
        Endcase
    When 31             :     WMSG = mess(105,7900,1)
    When 40             :     WMSG = mess(106,7900,1)
    When 41             :     WMSG = mess(107,7900,1)
    When 42             :     WMSG = mess(211,7900,1)
    When 50             :     WMSG = mess(108,7900,1)
    When 60             :     WMSG = mess(208,7900,1)
    When Default        :     WMSG="[AYN]LINTYP unknown: "+num$([AYN]LINTYP)
    Endcase
    #
    USG_AYTINF(USG_NB)= WMSG
    #
    Gosub $USGTAB_FIND  # Recherche usage récursif
Next
Filter [AYN]
If USG_NB = USG_NBMAX : Return : Endif
Return

# Numero de ligne usage suivant
$USGTAB_GETNB
    If USG_NB = USG_NBMAX : Return : Endif
    USG_NB+=1
    # Nb maxi de liens
    If USG_NB = USG_NBMAX 
        USG_AYTNIV(USG_NB)= 1
        USG_AYTCOD(USG_NB)=""
        USG_AYTTYPX3(USG_NB)="$$$"
        USG_AYTINF(USG_NB)= mess(109,7900,1)
    Endif
Return

# Recherche usage pour nouvelle ligne
$USGTAB_FIND
#        Call USAGE(FCYXT, USG_AYTTYPX3(USG_NB), USG_AYTCOD(USG_NB), 
#&              USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
#Return

# Faire recherche d'usage si non déjà faite
# Nota: test de niveau pour la présentation (des niveaux 1 peuvent apparaitre après des 2,3)
    If !find(USG_AYTCOD(USG_NB), USG_AYTCOD(1..USG_NB-1)) | 
&      !find(USG_AYTNIV(USG_NB), USG_AYTNIV(1..USG_NB-1)) |
&      !find(USG_AYTTYPX3(USG_NB), USG_AYTTYPX3(1..USG_NB-1))
        Call USAGE(FCYXT, USG_AYTTYPX3(USG_NB), USG_AYTCOD(USG_NB), 
&              USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
    Endif
Return

######################################################################################
## Ecran CONSAYU1
######################################################################################
Subprog AS_OBJMNL(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1  # Aucun
GMENLOC(2)=1  # Site
GMENLOC(14)=1  # Par. avancé
End

Subprog AM_OBJMNL(VALEUR )
Variable Integer VALEUR
[M]OBJX3COD = func AYTUTIA.GETX3COD(VALEUR)
Raz [AYU2] : Affzo [AYU2]
End

Subprog AM_CODSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR > [M]CODEND
  [M]CODEND=""
Endif
End

Subprog C_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]CODSTR
  GMESSAGE=mess(8,135,1) : mkstat=2
Endif
End

######################################################################################
## Ecran CONSAYU2
######################################################################################
Subprog B1_NBLIG
Local Integer FLGSEL : FLGSEL=2
Gosub SEL_NBLIG
End

Subprog B2_NBLIG
Local Integer FLGSEL : FLGSEL=1
Gosub SEL_NBLIG
End

$SEL_NBLIG
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
Local Integer WNEW
For WI=SAVNOL-1 To [M:AYU2]NBLIG-1
  # If [M:AYU2]COD(WI)<>"" & [M:AYU2]CODXT1(WI)=""  # Test modifier pour copie de masse
  If [M:AYU2]COD(WI)<>""
    WNEW=1
    [M:AYU2]WSEL(WI)=FLGSEL : nolign=WI+1
  Endif
Next
nolign=SAVNOL

If WNEW
 Affzo [M:AYU2]WSEL
Endif
Return

#
Subprog IB_COD
GBOUTS=""  # enlever sélection format avv
# Pas de suppression: affichage niv.1, site ou usage
If [M:AYU1]OBJMNL=2 | [M:AYU2]MNLXT1(nolign-1)<>0 : GBOUT3="" : Endif
End

Subprog B3_COD(VALEUR)
Variable Char    VALEUR()
Local Char    OBJX3COD : OBJX3COD=[M:AYU1]OBJX3COD
Gosub SUP_COD
End

#
Subprog IB_CODXT1
GBOUTS="" # pas de sél
# Pas de suppression: affichage niv.1, site ou usage
If [M:AYU2]MNLXT1(nolign-1)=2 | [M:AYU2]MNLXT2(nolign-1)<>0 | [M:AYU1]MNL7929=1 : GBOUT3="" : Endif
End
#
Subprog IB_CODXT2
GBOUTS=""
# Pas de suppression: affichage niv.2, site ou usage
If [M:AYU2]MNLXT1(nolign-1)=2 | [M:AYU2]MNLXT2(nolign-1)<>0 | [M:AYU1]MNL7929=2 : GBOUT3="" : Endif
End
#
Subprog IB_CODXT3
GBOUTS=""
End

#-- Suppression
Subprog B3_CODXT1(VALEUR)
Variable Char    VALEUR()
Local Char    OBJX3COD : OBJX3COD=[M:AYU2]OBJX3COD1(nolign-1)
Gosub SUP_COD
End
#
Subprog B3_CODXT2(VALEUR)
Variable Char    VALEUR()
Local Char    OBJX3COD : OBJX3COD=[M:AYU2]OBJX3COD2(nolign-1)
Gosub SUP_COD
End

$SUP_COD
Local Integer W_USG
# Verif au cas où
Call USG_SUPP([M:AYU1]FCYCOD,OBJX3COD,VALEUR, W_USG) From CNSAYUSTD
If W_USG: Return : Endif

Local Integer OKANU
Call OUVRE_TRACE(mess(111,7900,1)-[M:AYU1]FCYCOD) From LECFIC
Call SUP_AYT([M:AYU1]FCYCOD,OBJX3COD,VALEUR,OKANU)
If OKANU
    Call FERME_TRACE From LECFIC
    Call SUPFIL_TRACE(GTRACE) From AYTUTIA : GTRACE=""
    Call MESSAGE(mess(60,126,1)-":"- mess(func AYTUTIA.GETMNL7910(OBJX3COD),7910,1)-"-"-VALEUR) From GESECRAN
Else
    Call ECR_TRACE(mess(114,7900,1)- mess(func AYTUTIA.GETMNL7910(OBJX3COD ),7910,1)-"-"-VALEUR,1) From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE  From LECFIC
Endif
Return

