#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation AYU
######################################################################################
## Xtend:  Gestion des cas d'emploi Xtend
#
#  Version 0001
#  
#    Utilitaires
#        subprog USG_SUPP
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AUTORIS"       :    Gosub AUTORIS
 When "APRES_MODIF"   :    Gosub APRES_MODIF
 When "FERME"         :    Gosub FERME
 When "OUVRE"         :    Gosub OUVRE
 When "LECTURE"       :    Gosub LECTURE
 When "EXEBOUT"       :    Gosub EXEBOUT
 When "SETBOUT"       :    Gosub SETBOUT
 When default
Endcase
Return

$AUTORIS
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), WNLG(10)
Local Integer OKANU, WNBSUP
Local Integer FLG_FIRST : FLG_FIRST=1     # 1 en ouverture (gestion diszo)
Local Integer FLG_OVRFLWNX                # 1 si trop de donnée en suite (next)
Local Integer FLG_OVRFLWPR                # 1 si trop de donnée en précédent (previous)
Local Integer FLG_OVRFLWNOL               # 1 si mask plein
Local Char CNSCODSTR(GLONAYF), CNSCODEND(GLONAYF)    # Sauvegarde pour pagination
Local Clbfile WFIL(1)                     # Filtre table principal
#
Local Char WCODXT(GLONAYF)                #  Code courant Xtend table principal
Local Char MNL_FILNAM(GLONATB), MNL_FILCOD(GLONAVA)   # Infos table suivant type xtend
# Info sur l'utilisation
Local Integer USG_NBMAX  : USG_NBMAX=10     # recherche maxi (recalculer en fct du nb de ligne mask)
Local Integer USG_NIVMAX : USG_NIVMAX=3     # nb de niveau maxi
Local Integer USG_NB, USG_NIV               # Nombre et niveau courant
Local Integer USG_FLGUSGNO                  # 1: Recherche sans cas d'emploi 
#
Default Mask [M:AYU1]
Gosub DSYFCY From SUBAYS     # Infos site
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$SETBOUT
# position curseur FD
If [M:AYU2]NBLIG<>0 : ZONS="CODSTR" : Endif
Return

$APRES_MODIF
#---------------------------------------------------------------#
If COUZON="OBJMNL"
    If clalev([F:AYU_]) : Close Local File [AYU_] : Endif
    Call FILEINFO([M:AYU1]OBJMNL,MNL_FILNAM, MNL_FILCOD)
    If MNL_FILNAM="" : Return : Endif
    Local File =MNL_FILNAM [AYU_] Where FCYCOD=[M:AYU1]FCYCOD
Endif
Return

$EXEBOUT
#---------------------------------------------------------------#
Case BOUT
When "A"        # Validation
  If find(2,  [M:AYU2]WSEL)
    Call OUVRE_TRACE(mess(111,7900,1)-[M:AYU1]FCYCOD) From LECFIC
    WNBSUP=0
    For WI=0 To [M:AYU2]NBLIG-1
      If [M:AYU2]WSEL(WI)=2
        WNBSUP+=1
        If [M:AYU2]MNLXT1(WI)=0  # sél et pas d'usage
            Call SUP_AYT([M:AYU1]FCYCOD,[M:AYU1]OBJX3COD,[M:AYU2]COD(WI),OKANU)
            If OKANU : [M:AYU2]WSEL(WI)=1 : Affzo [M:AYU2]WSEL(WI) : Endif
        Else
            Call ECR_TRACE(mess(114,7900,1)- mess(func AYTUTIA.GETMNL7910([M:AYU1]OBJX3COD),7910,1)-"-"-[M:AYU2]COD(WI),1) From GESECRAN
        Endif
      Endif
    Next
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE  From LECFIC
  Else
    Call MESSAGE(mess(116,7900,1)) From GESECRAN
  Endif
When "B"        # Copie (Action AYTCOPUSG)
Endcase
Return

$LECTURE
#---------------------------------------------------------------#
# Gestion diszo et USG_NBMAX
If FLG_FIRST
    Diszo [M:AYU2]COD : Diszo [M:AYU2]CODXT1: Diszo [M:AYU2]CODXT2: Diszo [M:AYU2]CODXT3 
    FLG_FIRST=0
    If dim(WSEL)/4 > USG_NBMAX 
        USG_NBMAX = dim(WSEL)/4
        # Infos d'un cas d'emploi
        Local Char    USG_AYTTYPX3(GLONAOB)(1..USG_NBMAX), USG_AYTCOD(GLONAYF)(1..USG_NBMAX), USG_AYTINF(30)(1..USG_NBMAX) 
        Local Integer USG_AYTNIV(1..USG_NBMAX)                      
    Endif  
Endif
# Choix menu local invalide
If MNL_FILNAM="" : Return : Endif
# Niveau demandé
USG_NIVMAX=[M:AYU1]MNL7929
# Restriction sans emploi
USG_FLGUSGNO=([M:AYU1]WUSGNO=2)
If USG_FLGUSGNO : USG_NIVMAX=1 : Endif

#-- Positionnement des Filtres
If CHGPAG<0 : NOL = MAXLIG : Endif    # sinon initialisé à -1 par std
Gosub LOAD_FILTER
#-- dans les traitements standards uniquement : appel au spécifique
If PROGSPE<>""
ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

#-- Application des Filtres et tri des enregistrements
If CHGPAG > 0
    SUITE=1
    If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Filter [AYU_] Where evalue(WFIL) Order With MNL_FILCOD+"  Asc"
Else
    RETOUR=1
    If CHGPAG = -1 : SUITE = 1 : Else SUITE = 2 : Endif
    Filter [AYU_] Where evalue(WFIL) Order With MNL_FILCOD+"  Desc"
Endif
#-- raz du masque si 1ere ou dernière page
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:AYU2] : Endif

#-- boucle de lecture 
$BOUCLE
Raz FLG_OVRFLWNX , FLG_OVRFLWPR, FLG_OVRFLWNOL
For [AYU_]
    #-- recherche utilisation
    WCODXT = evalue("[F:AYU_]"+MNL_FILCOD)    # 
    Call USAGETOP ( [M:AYU1]FCYCOD, [M:AYU1]OBJX3COD, WCODXT, 
&                    USG_NIVMAX, USG_NBMAX, 
&                    USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB) From CNSAYUSTD
    #-- chargement du masque
    If USG_NB=0 # pas d'usage
        Gosub GETNOL : If FLG_OVRFLWNOL : Break : Endif
        [M:AYU2]COD(NOL) = WCODXT 
        If dim([F:AYU_]DES)>0 : Call TEXTE([F:AYU_]DES,[M]DES(NOL)) From OBJDIV : Endif
    Else
      # Uniquement si tous demandés
      If !USG_FLGUSGNO
        #-- Chgt tableau
        If CHGPAG > 0
            If NOL >= MAXLIG-1-USG_NBMAX : SUITE=2 : Break : Endif    # USG_NBMAX (réservé usage)
            For WI=1 To USG_NB   
                If WI=1  or (USG_AYTNIV(WI) <= USG_AYTNIV(WI-1))        # 1er ligne ou niveau plus petit ou égal 
                    Gosub GETNOL : If FLG_OVRFLWNOL: Break 2 : Endif
                Endif
                WNLG="("+num$(NOL)+")"
                If WI=1 
                        [M:AYU2]COD(NOL) = WCODXT 
                        If dim([F:AYU_]DES)>0 : Call TEXTE([F:AYU_]DES,[M]DES(NOL)) From OBJDIV : Endif
                Endif
                Assign  "CODXT"+num$(USG_AYTNIV(WI))+WNLG    With USG_AYTCOD(WI)               
                Assign "OBJX3COD"+num$(USG_AYTNIV(WI))+WNLG  With USG_AYTTYPX3(WI)               
                Assign "MNLXT"+num$(USG_AYTNIV(WI))+WNLG     With func AYTUTIA.GETMNL7910(USG_AYTTYPX3(WI))              
                Assign "DES"+num$(USG_AYTNIV(WI))+WNLG       With USG_AYTINF(WI)               
            Next
        Else
            If NOL <= USG_NBMAX : RETOUR=2 : Break : Endif    # USG_NBMAX (réservé usage)
            For WI=USG_NB To 1 Step -1 
                If WI=USG_NB or USG_AYTNIV(WI) >= USG_AYTNIV(WI+1)
                    Gosub GETNOL : If FLG_OVRFLWNOL : Break 2 : Endif
                Endif
                WNLG="("+num$(NOL)+")"
                If WI=1 
                    [M:AYU2]COD(NOL) = WCODXT 
                    If dim([F:AYU_]DES)>0 : Call TEXTE([F:AYU_]DES,[M]DES(NOL)) From OBJDIV : Endif
                Endif
                Assign "CODXT"+num$(USG_AYTNIV(WI))+WNLG     With USG_AYTCOD(WI)               
                Assign "OBJX3COD"+num$(USG_AYTNIV(WI))+WNLG  With USG_AYTTYPX3(WI)               
                Assign "MNLXT"+num$(USG_AYTNIV(WI))+WNLG     With func AYTUTIA.GETMNL7910(USG_AYTTYPX3(WI))              
                Assign "DES"+num$(USG_AYTNIV(WI))+WNLG       With USG_AYTINF(WI)               
            Next
        Endif
      Endif     # --USG_FLGUSGNO
    Endif
    #
Next
Filter [AYU_]

Return

#--- Numéro de ligne + info pagination #
$GETNOL
    If NBLU = 1
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:AYU2] : Endif
        NBLU = 2
    Endif
    #-- stockage des bornes début et fin d'enregistrement pour l'écran
    If CHGPAG > 0
        If NOL >= MAXLIG-1 : SUITE=2 : FLG_OVRFLWNOL=1 : Return : Endif 
        NOL += 1
        If NOL=0
            CNSCODSTR = WCODXT 
        Endif
        CNSCODEND = WCODXT 
    Else
        If NOL <= 0 : RETOUR=2 : FLG_OVRFLWNOL=1 :Return : Endif

        NOL -= 1
        If NOL=MAXLIG-1
            CNSCODEND = WCODXT 
        Endif
        CNSCODSTR = WCODXT 
    Endif
Return

#--- Préparation du filtre #
$LOAD_FILTER
WFIL = "1=1"  
Case CHGPAG
When 1,3 : # recherche, rafraichissement
    WFIL= MNL_FILCOD + ' >= "' +[M:AYU1]CODSTR+ '"'
    If [M:AYU1]CODEND<>"" : WFIL+= ' & ' +MNL_FILCOD+ ' <= "' +[M:AYU1]CODEND+ '"' : Endif
When 2 : # suite
    WFIL= MNL_FILCOD 
    If FLG_OVRFLWNX : WFIL+= ' >= "' : Else : WFIL+= ' > "' : Endif
    WFIL += [L]CNSCODEND+ '"'
    If [M:AYU1]CODEND<>"" : WFIL+= ' & ' +MNL_FILCOD+ ' <= "' +[M:AYU1]CODEND+ '"' : Endif
When -2 : # retour
    WFIL= MNL_FILCOD 
    If FLG_OVRFLWPR : WFIL+= ' <= "' : Else : WFIL+= ' < "' : Endif
    WFIL += [L]CNSCODSTR+ '"'
    If [M:AYU1]CODSTR<>"" : WFIL+= ' & ' +MNL_FILCOD + ' >= "' +[M:AYU1]CODSTR+ '"' : Endif
When -1 : # dernier
    If [M:AYU1]CODEND<>"" : WFIL= MNL_FILCOD+ ' <= "' +[M:AYU1]CODEND+ '"' : Endif
Endcase
Return

######################################################################################
#
# Utilitaires 
#
######################################################################################
# Information sur Table principale
Subprog FILEINFO(MNL7910,FILNAM, FILXTCOD)        
Value Integer     MNL7910
Variable Char     FILNAM            # Nom table
Variable Char     FILXTCOD          # Rubrique principale (tri)
Raz FILNAM, FILXTCOD
Case MNL7910
When 3
    FILNAM="AYTPAG"    : FILXTCOD="PAGCOD" 
When 4
    FILNAM="AYTPRF"    : FILXTCOD="PRFCOD" 
When 5
    FILNAM="AYTELTFLD" : FILXTCOD="FIECOD" 
When 6
    FILNAM="AYTENT"    : FILXTCOD="ENTCOD" 
When 7
    FILNAM="AYTELTBLC" : FILXTCOD="BLCCOD" 
When 8
    FILNAM="AYTELTBLCW": FILXTCOD="BLCWHNCOD" 
When 9
    FILNAM="AYTACT"    : FILXTCOD="ACTCOD"
When 10
    FILNAM="AYTELTDLK" : FILXTCOD="DLKCOD" 
When 11
    FILNAM="AYTELTSPE" : FILXTCOD="SPXCOD" 
When 12
    FILNAM="AYTMES"    : FILXTCOD="MESCOD" 
When 13
    FILNAM="AYTINT"    : FILXTCOD="INTCOD" 
When 15
    FILNAM="AYTMEN"    : FILXTCOD="MENCOD" 
When Default
    Infbox "Internal error - Type Xtend unknown: "+num$(MNL7910)
Endcase
End 

# Suppression d'une fiche
# $$$    Nota: Utilisation de la suppression std objet
#---------------------------------------------------------------#
Subprog SUP_AYT(FCYCOD,OBJX3COD,XTCOD,OKANU)
Value Char FCYCOD        # Site
Value Char OBJX3COD      # Type objet X3
Value Char XTCOD         # Code Xtend
Variable Integer OKANU   # Retour
Call ECR_TRACE(mess(113,7900,1)- mess(func AYTUTIA.GETMNL7910(OBJX3COD),7910,1)-"-"-XTCOD,0) From GESECRAN
Local Char SAVPROG
SAVPROG=GPROGRAMME : GPROGRAMME="" # Pour un objet X3...
Local File AOBJET [A_OB]
Call SUPPRIME(OBJX3COD,XTCOD,FCYCOD,OKANU) From ADELETE
GMESSAGE=""
GPROGRAMME=SAVPROG
End
#---------------------------------------------------------------#
# Recherche Usage
#---------------------------------------------------------------#
#--  Test avant suppression de fiche (AYG, AYA...)
Subprog USG_SUPP(FCYXT, TYP, COD, USG_NB)
Value Char        FCYXT, TYP, COD           # Site, type X3 et code
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
#
Local Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
USG_NIVMAX=1 : USG_NBMAX=5
# infos usage
Local Char     USG_AYTTYPX3(GLONAOB)(1..USG_NBMAX), USG_AYTCOD(GLONAYF)(1..USG_NBMAX), USG_AYTINF(30)(1..USG_NBMAX)    
Local Integer  USG_AYTNIV(1..USG_NBMAX)
Local Char     WMSG(250), WTMP(200)
  Call USAGETOP (  FCYXT, TYP, COD, 
&                    USG_NIVMAX, USG_NBMAX, 
&                    USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB )
&                From CNSAYUSTD
  If USG_NB
    WMSG=mess(114,7900,1)
    For WI=1 To USG_NB
        WTMP="\"-mess(func AYTUTIA.GETMNL7910(USG_AYTTYPX3(WI)),7910,1)-USG_AYTCOD(WI)-"("+USG_AYTINF(WI)-")"
        If len(WMSG)+len(WTMP) >=250 : Break : Endif
        WMSG+=WTMP
    Next
    Call MESSAGE(WMSG)From GESECRAN
  Endif
End

#--  Appel niveau 0
Subprog USAGETOP(FCYXT, TYP, COD, USG_NIVMAX, USG_NBMAX, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, TYP, COD           # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
Local Integer WNIV : WNIV=0
    Raz USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB
    Call USAGE(FCYXT, TYP, COD, USG_NIVMAX, USG_NBMAX, WNIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)

End

#-- Appel récursif
Subprog USAGE(FCYXT, TYP, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, TYP, COD           # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    If USG_NIV=USG_NIVMAX : End : Endif
    If find(TYP,"AYW","AYX","AYM","AYS") #  Type sans emploi dans la base
        End
    Endif
    USG_NIV+=1
    #Onerrgo $USG_ERR

    Call ="USG_"+TYP With FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, 
&                USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB            From CNSAYUSTD
    #Onerrgo
    USG_NIV-=1
End
$USG_ERR
Infbox "No subprg:"-"USG_"+TYP
Resume

#-- Usage d'un Champ
Subprog USG_AYF(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site,  code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    Call USG_AYN(FCYXT, "AYF",COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
End

#-- Usage d'une Entité
Subprog USG_AYE(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site,  code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Bloc
    WFIL=    'FCYCOD = "' + FCYXT + '" &  ENTCOD = "' +COD+ '"'
    Gosub USF_AYB_R
    If USG_NB = USG_NBMAX : End : Endif
    # Action
    WFIL=    'FCYCOD = "' + FCYXT + '" &  find("' +COD+ '",ENTSUPCOD)'
    Gosub USF_AYA_R
    If USG_NB = USG_NBMAX : End : Endif
    # Lien dyn.
    WFIL=    'FCYCOD = "' + FCYXT + '" &  ENTCOD = "' +COD+ '"'
    Gosub USF_AYL_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    Call USG_AYN(FCYXT, "AYE",COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
End

#-- Usage d'un Bloc
Subprog USG_AYB(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Blc conditionné
    WFIL=    'FCYCOD = "' + FCYXT + '" &  BLCCOD = "' +COD+ '"'
    Gosub USF_AYW_R
    If USG_NB = USG_NBMAX : End : Endif
    # Alias de page
    WFIL=    'FCYCOD = "' + FCYXT + '" & ( BLCBCK = "' +COD+ '" | BLCBCK = "' +COD+ '" )' 
    Gosub USF_AYG_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    Call USG_AYN(FCYXT, "AYB",COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
End

#-- Usage d'une Action
Subprog USG_AYA(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Lien dyn.
    WFIL=    'FCYCOD = "' + FCYXT + '" &  ACTCOD = "' +COD+ '"'
    Gosub USF_AYL_R
    If USG_NB = USG_NBMAX : End : Endif
    # Action
    WFIL=    'FCYCOD = "' + FCYXT + '" &  ACTMAPRET = "' +COD+ '"'
    Gosub USF_AYA_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Nota: pas d'usage AYN
End

# Usage d'un Lien dynamique
Subprog USG_AYL(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Bloc conditionné
    WFIL=    'FCYCOD = "' + FCYXT + '" &  DLKCOD = "' +COD+ '"'
    Gosub USF_AYW_R
    If USG_NB = USG_NBMAX : End : Endif
    # modif sb flash    
    # Champ xtend
    WFIL=    'FCYCOD = "' + FCYXT + '" &  FLADLK = "' +COD+ '"'
    Gosub USF_AYF_R
    If USG_NB = USG_NBMAX : End : Endif
    # fin modif sb flash

    # 
    Call USG_AYN(FCYXT, "AYL",COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
End

#-- Usage d'un Alias de page
Subprog USG_AYG(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Site
    WFIL=    'FCYCOD = "' + FCYXT +'"'
    WFIL+= ' &  ( PAGSTR    = "' +COD+'" | '
    WFIL+=       'PAGLOG    = "' +COD+'" | '
    WFIL+=       'PAGERR    = "' +COD+'" ) '
    Gosub USF_AYS_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Bloc conditionné
    WFIL=    'FCYCOD = "' + FCYXT + '" &  PAGCOD = "' +COD+ '"'
    Gosub USF_AYW_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Lien dyn.
    WFIL=    'FCYCOD = "' + FCYXT + '" &  PAGCOD = "' +COD+ '"'
    Gosub USF_AYL_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Profil
    WFIL=    'FCYCOD = "' + FCYXT  +'"'
#    WFIL+= ' &  ( PAGCOD = "' +COD+'" | '
    WFIL+= ' &  ( find("' +COD+'",PAGCOD) | '
    WFIL+=       'PAGERR    = "' +COD+'" ) '
    Gosub USF_AYD_R
    If USG_NB = USG_NBMAX : End : Endif

    # Nota: pas d'usage AYN
End

#-- Usage d'une Interface
Subprog USG_AYI(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Entité
    WFIL=    'FCYCOD = "' + FCYXT + '" &  INTCOD = "' +COD+ '"'
    Gosub USF_AYE_R
    If USG_NB = USG_NBMAX : End : Endif
    # Action
    WFIL=    'FCYCOD = "' + FCYXT + '" &  INTCOD = "' +COD+ '"'
    Gosub USF_AYA_R
    If USG_NB = USG_NBMAX : End : Endif
    # Champ
    # modif sb flash
    WFIL=    'FCYCOD = "' + FCYXT + '" &  FLAINT = "' +COD+ '"'
    # fin modif sb flash
    Gosub USF_AYF_R
    # modif sb interface protégée vérifier dans profil
    WFIL=    'FCYCOD = "' + FCYXT + '" &  INTCOD = "' +COD+ '"'
    Gosub USF_AYD_R
 # fin modif sb flash

    If USG_NB = USG_NBMAX : End : Endif
End

#-- Usage d'un Profil
Subprog USG_AYD(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Profil
    WFIL=    'FCYCOD = "' + FCYXT + '" &  find("' +COD+ '",PRFCOD)'
    Gosub USF_AYW_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Nota: pas d'usage AYN
End

#-- Usage d'un Pool web
Subprog USG_AYO(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # POOL WEB
    WFIL= 'find("' +COD+ '",LNKADS)'
    Gosub USF_AYS_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Nota: pas d'usage AYN
End


#-- Usage d'un menu
Subprog USG_AYC(FCYXT, COD, USG_NIVMAX, USG_NBMAX, USG_NIV, USG_AYTNIV, USG_AYTTYPX3, USG_AYTCOD, USG_AYTINF, USG_NB)
Value Char        FCYXT, COD                # Site, type X3 et code
Value Integer     USG_NIVMAX, USG_NBMAX     # max niveau, max de ligne à charger
Variable Integer  USG_NB                    # Indice courant tableau USG_AYTxxx
Variable Integer  USG_NIV                   # Niveau courant     
# infos usage
Variable Char     USG_AYTTYPX3()(1..), USG_AYTCOD()(1..), USG_AYTINF()(1..)    
Variable Integer  USG_AYTNIV(1..)
    # Champ
    WFIL=    'FCYCOD = "' + FCYXT + '" &  LSTMEN = "' +COD+ '"'
    Gosub USF_AYF_R
    If USG_NB = USG_NBMAX : End : Endif
    #
    # Nota: pas d'usage AYN
End


#---- Boucles de recherches  ---------------#
#-- Bloc champ
$USF_AYF_R
Local File AYTELTFLD [AYF]
Filter [AYF] Where evalue(WFIL) Order By Key AYF0
For [AYF]
    Gosub USGTAB_GETNB : If USG_NB = USG_NBMAX : Break : Endif
    #
    USG_AYTNIV(USG_NB)= USG_NIV
    USG_AYTCOD(USG_NB)=[AYF]FIECOD
    USG_AYTTYPX3(USG_NB)="AYF" 
    USG_AYTINF(USG_NB)= mess(110,7900,1)
    #
    Gosub $USGTAB_FIND  # Recherche usage récursif
Next
Filter [AYF] : Close Local File [AYF]
Return

