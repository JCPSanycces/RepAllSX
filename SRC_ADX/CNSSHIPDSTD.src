#<AdxTL>@(#)0.0.0.0 $Revision$ Lignes d'expéditions
#########################################################################
# CNSSHIPD : Consultation des lignes d'expéditions  MAE    29/05/15     #
# ECRAN 1   : CONSSHIPD1                                                #
# ECRAN 2   : CONSSHIPD2                                                #
# ECRAN CRIT: CRITSHIPD                                                 #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("SHIPD","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
    When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSSHIPD"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250),WFIL4(250)
Local Char    DEBNUM(GLONTRNP), FINNUM(GLONTRNP)
Local Char    SDEBNUM(GLONVCR), SFINNUM(GLONVCR)
Local Char    CDEBNUM(GLONVCR), CFINNUM(GLONVCR)
Local Char    CTRDNUMSAV(GLONVCR)
Local Date    DEBDAT, FINDAT

Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(1)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:SHD1]FCY = PARAM(I)
          Call GETDEV([M:SHD1]FCY) From DEVSUB
          [M:SHD1]LEGCPY = GSOCIETE
        Endif
      Endif
    When 2 :    : # Parametre expédition
      If PARAM(I) <> ""
        [M:SHD1]SHIPNUMSTR = PARAM(I)
        [M:SHD1]SHIPNUMEND = PARAM(I)
      Endif
    When 3 :    : # Parametre conteneur
      If PARAM(I) <> ""
        [M:SHD1]CTRNUMSTR = PARAM(I)
        [M:SHD1]CTRNUMEND = PARAM(I)
      Endif
  Endcase
Next I

If !find([M:SHD1]SHIPSTAT,1,2,3) : [M:SHD1]SHIPSTAT= 1 : Endif
If !find([M:CSDH]TRI,1,2)     : [M:CSDH]TRI = 1   : Endif

#----- Copie du masque 1 (SHIP1) vers l'écran critères (CSDH) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE

Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT


Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

 Link [SHD] With [POQ]POQ0=[F:SHD]POHNUM; [F:SHD]POPLIN;[F:SHD]POQSEQ, [SHH]SHH0=[F:SHD]SHIPNUM,
&                          [POH]POH0=[F:SHD]POHNUM, [POP]POP0=[F:SHD]POHNUM; [F:SHD]POPLIN;[F:SHD]POQSEQ
&             As    [LNK]

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CSDH]TRI
        When 1 : # tri par numéro
          Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SHD0
        When 2 : # tri par date
            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SHD]EXTRCPDAT Desc
      Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CSDH]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SHD0 Desc
      When 2 : # tri par date
            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SHD]EXTRCPDAT Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SHD2] : Endif

#-- lecture
$BOUCLE
For [LNK]
  If [F:SHH]TRNNUM <> AVOID.ACHAR
    Read [TRNP] TRNP0=[F:SHH]TRNNUM : If fstat Raz [F:TRNP] : Endif
  Endif
  Gosub REMP_ECR

$SUIV
Next
Filter [LNK]
Return

$REMP_ECR
If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:SHD2] : Endif
     NBLU = 2
Endif
If CHGPAG > 0
  If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
  NOL    += 1
  If NOL=0
    DEBNUM = [F:SHD]SHIPNUM
    DEBDAT = [F:SHD]EXTRCPDAT
  Endif
   FINNUM = [F:SHD]SHIPNUM
   FINDAT = [F:SHD]EXTRCPDAT
Else
   If NOL <= 0 : RETOUR=2 : Return : Endif
   NOL    -= 1
   If NOL=MAXLIG-1
    FINNUM = [F:SHD]SHIPNUM
    FINDAT = [F:SHD]EXTRCPDAT
   Endif
   DEBNUM = [F:SHD]SHIPNUM
   DEBDAT = [F:SHD]EXTRCPDAT
 Endif
  nolign = NOL+1
  [M:SHD2] = [F:POH]
  [M:SHD2] = [F:POQ]
  [M:SHD2] = [F:POP]
  [M:SHD2] = [F:TRNP]
  [M:SHD2] = [F:SHD]
  If [M:SHD2]PRCPQTY(NOL) <> AVOID.ADEC
    [M:SHD2]PRCPUOM(NOL) = [M:SHD2]UOM(NOL)
    [M:SHD2]PRCPPUU(NOL) = [M:SHD2]PUU(NOL)
    [M:SHD2]PRCPSTU(NOL) = [M:SHD2]STU(NOL)
  Endif

# Issue 4759 - 2016-12-12 by MAE : statuts des lignes : expédié ou receptionné
If [F:SHD]RCPQTYSTU = 0
     [M:SHD2]RECEIPT(NOL) = 1
  Elsif [F:SHD]RCPQTYSTU < [F:POQ]QTYSTU
     [M:SHD2]RECEIPT(NOL) = 2
  Else
     [M:SHD2]RECEIPT(NOL) = 3
  Endif
If [F:SHH]SHIPSTAT <> 1
  If [F:SHD]SHIQTYSTU = 0
     [M:SHD2]SHIPP(NOL) = 1
  Elsif [F:SHD]SHIQTYSTU < [F:POQ]QTYSTU
     [M:SHD2]SHIPP(NOL) = 2
  Else
     [M:SHD2]SHIPP(NOL) = 3
  Endif
Else
  [M:SHD2]SHIPP(NOL) = 1
Endif
# End issue 4759



Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER

WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

#société
If [M:SHD1]LEGCPY <> ""
  WFIL1 += "&[F:SHD]LEGCPY=[M:SHD1]LEGCPY"
Endif
#site
If [M:SHD1]FCY <> ""
  WFIL1 += "&[F:SHH]FCY=[M:SHD1]FCY"
Endif

# Expéditions
If [M:SHD1]SHIPNUMSTR <> ""
   WFIL1 += "&[F:SHD]SHIPNUM>=[M:SHD1]SHIPNUMSTR"
Endif
If [M:SHD1]SHIPNUMEND <> ""
   WFIL1 += "&[F:SHD]SHIPNUM<=[M:SHD1]SHIPNUMEND"
Endif
# Conteneurs
If [M:SHD1]CTRNUMSTR <> ""
   WFIL2 += "&[F:SHD]CTRNUM>=[M:SHD1]CTRNUMSTR"
Endif
If [M:SHD1]CTRNUMEND <> ""
   WFIL2 += "&[F:SHD]CTRNUM<=[M:SHD1]CTRNUMEND"
Endif
# Issue 110713 US 21
# Commandes
If [M:SHD1]POHNUMSTR <> ""
   WFIL2 += "&[F:SHD]POHNUM>=[M:SHD1]POHNUMSTR"
Endif
If [M:SHD1]POHNUMEND <> ""
   WFIL2 += "&[F:SHD]POHNUM<=[M:SHD1]POHNUMEND"
Endif
# End issue 110713 US 21
# Issue 4759 - 2016-12-14 by MAE : Gestion des statuts
#Case [M]SHIPSTAT
#  When 1
#    WFIL1 += "&[F:SHD]PRCPQTY=0 & [F:SHD]CLEFLG<>2"
#  When 2
#    WFIL1 += "&[F:SHD]PRCPQTY<> 0"
#  When 3
#    WFIL1 += "&[F:SHD]CLEFLG=2"
#  When Default
#   WFIL1 += "&[F:SHD]PRCPQTY=0 & [F:SHD]CLEFLG<>2"
#Endcase

WFIL2 = "1=2"
If [M:SHD1]CRESFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:SHH]SHIPSTAT,1"
  Else
    WFIL2 += ",1"
  Endif
Endif
If [M:SHD1]SHIPFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:SHH]SHIPSTAT,2"
  Else
    WFIL2 += ",2"
  Endif
Endif
If [M:SHD1]PRECFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:SHH]SHIPSTAT,3"
  Else
    WFIL2 += ",3"
  Endif
Endif
If [M:SHD1]RECPFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:SHH]SHIPSTAT,4"
  Else
    WFIL2 += ",4"
  Endif
Endif
If [M:SHD1]SOLDFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:SHH]SHIPSTAT,5"
  Else
    WFIL2 += ",5"
  Endif
Endif
If WFIL2 <> "1=2"
  WFIL2 += ")"
Endif

# End Issue 4759 - 2016-12-14 by MAE : Gestion des statuts



If [M]EXTRCPDATSTR <> [0/0/0]
  WFIL += "&[F:SHD]EXTRCPDAT>=[M:SHD1]EXTRCPDATSTR"
Endif
If [M]EXTRCPDATEND <> [0/0/0]
  WFIL += "&[F:SHD]EXTRCPDAT<=[M:SHD1]EXTRCPDATEND"
Endif

If [M:SHD1]BPSNUM <> ""
  WFIL2 += "&[F:POH]BPSNUM = [M:SHD1]BPSNUM"
Endif

#Issue 4759 - 2016-12-14 by MAE : ajout des critéres
If [M]BPTNUM <> ""
  WFIL += "&[F:SHH]BPTNUM=[M:SHD1]BPTNUM"
Endif
If [M]SHIPUID <> ""
  WFIL += "&[F:SHH]SHIPUID=[M:SHD1]SHIPUID"
Endif
If [M]ITMREF <> ""
  WFIL += "&[F:SHD]ITMREF=[M:SHD1]ITMREF"
Endif
If [M]BPRNUM <> ""
  WFIL += "&[F:SHH]BPRNUM=[M:SHD1]BPRNUM"
Endif
#End Issue 4759 - 2016-12-14 by MAE : ajout des critéres



Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CSDH]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SHD]SHIPNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:SHD]EXTRCPDAT>DEBDAT | ([F:SHD]EXTRCPDAT=DEBDAT & [F:SHD]SHIPNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CSDH]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SHD]SHIPNUM>FINNUM"
       When 2 : # tri par date
           WFIL += "&([F:SHD]EXTRCPDAT>FINDAT | ([F:SHD]EXTRCPDAT=FINDAT & [F:SHD]SHIPNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CSDH]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SHD]SHIPNUM<DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:SHD]EXTRCPDAT<DEBDAT | ([F:SHD]EXTRCPDAT=DEBDAT & [F:SHD]SHIPNUM<DEBNUM))"
     Endcase
Endcase

Return
############################################
#    Avant d'ouvrir la fenetre critère     #
############################################
$DEB_CRIT

Return
############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return



#############################################################
##     Etiquettes masques CONSCPO1 & CONSCPO2 & CRITCPO    ##
#############################################################
Subprog AV_LEGCPY(VALEUR)
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]LEGCPY : Endif
End

Subprog C_LEGCPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
    GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]FCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_LEGCPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo CUR                      : # Utilisé par 2 écrans
Raz [M]FCY
Affzo FCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CSDH])  : [M:CSDH]CPY = VALEUR : Raz [M:CSDH]FCY : Endif
End

Subprog C_FCY(VALEUR)
#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]LEGCPY = GSOCIETE
Elsif [M]LEGCPY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]LEGCPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo LEGCPY
Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CSDH]) : [M:CSDH]FCY = VALEUR : Endif
End

#---------------------------------------------------#
#      Actions sur expédition                       #
# ------------------------------------------------- #
Subprog AS_SHIPNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]SHIPNUMSTR
Endif
End
#---------------------------------------------------#
Subprog C_SHIPNUMEND(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]SHIPNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#---------------------------------------------------#
#      Actions sur conteneur                        #
# ------------------------------------------------- #
Subprog AS_CTRNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]CTRNUMSTR
Endif
End
#---------------------------------------------------#
Subprog C_CTRNUMEND(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]CTRNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"SHIPD") From SUBGTC
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSTRN2) 28/05/2015 11:03:48 (MAE)
######################################################################################
Subprog IB_NBLIG
Local Char WTEXTE(50)
Raz GBOUT1,GBOUT2, GBOUT3, GBOUT4
If [M:SHD2]NBLIG<>0
   If [M:SHD2]SHIPNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(16408, WTEXTE) From OBJDIV
    GBOUT1=WTEXTE
   Endif
   If [M:SHD2]CTRNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(52463, WTEXTE) From OBJDIV
    GBOUT2=WTEXTE
   Endif
   If [M:SHD2]POHNUM(nolign-1)<> AVOID.ACHAR
    GBOUT3=mess(10,159,1)
   Endif
   If [M:SHD2]BPSNUM(nolign-1)<> AVOID.ACHAR
    GBOUT4=mess(17,7,1)
   Endif
Endif
End

######################################################################################
# Issue 110713 US 21
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSHIPD1) 12/02/2016 15:09:29 (MAE)
######################################################################################
Subprog AS_POHNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]POHNUMSTR
Endif
End

Subprog C_POHNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]POHNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

# End issue 110713 US 21


######################################################################################




