#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMOPEAFF
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PJMOPEAFF_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PJMOPEAFF_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PJMOPEAFF_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PJMOPEAFF_CSTD_EVENTS
        When "AINSERT_AFTER"           : Gosub AINSERT_AFTER                   From PJMOPEAFF_CSTD_EVENTS
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER                   From PJMOPEAFF_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PJMOPEAFF_CSTD_METHODS # Issue X3-51863 - 2017-08-07 by FGR
    When "COPY"                        : Gosub COPY                            From PJMOPEAFF_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"        : Gosub COPY_LOAD_PROPERTIES            From PJMOPEAFF_CSTD_METHODS # Issue X3-29531 - 2017-04-21 by FGR
    When "LOAD_POACST_POACSTLAB"       : Gosub LOAD_POACST_POACSTLAB           From PJMOPEAFF_CSTD_METHODS # Issue X3-17556/120812 - 2017-01-10 by FGR
    When "PROGRESS"                    : Gosub PROGRESS                        From PJMOPEAFF_CSTD_METHODS # Issue X3-29489 - 2017-04-05 by SINGC
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "KEYCONCAT"                   : Gosub KEYCONCAT                       From PJMOPEAFF_CSTD_PROPERTIES
    When "POACLB"                      : Gosub POACLB                          From PJMOPEAFF_CSTD_PROPERTIES # Issue X3-5414/119279 - 2016-11-02 by TEJAC : comment
    When "POASTDQTY"                   : Gosub POASTDQTY                       From PJMOPEAFF_CSTD_PROPERTIES
    When "POACSMQTY"                   : Gosub POACSMQTY                       From PJMOPEAFF_CSTD_PROPERTIES # Issue X3-6415/119493 - 2016-10-31 by SINGC
    When "POARMNQTY"                   : Gosub POARMNQTY                       From PJMOPEAFF_CSTD_PROPERTIES
    # Issue X3-47483 - 2017-08-21 by SINGC : START
    #When "POASTR"                      : Gosub POASTR                          From PJMOPEAFF_CSTD_PROPERTIES # Issue X3-5010/119554 - 2016-11-18 by EUHAV/FGR
    #When "POAEND"                      : Gosub POAEND                          From PJMOPEAFF_CSTD_PROPERTIES # Issue X3-5010/119554 - 2016-11-18 by EUHAV/FGR
    # Issue X3-47483 - 2017-08-21 by SINGC : END
  Endcase
Return

