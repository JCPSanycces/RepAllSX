## Etiquette ajoutée par le superviseur (écran SFI1501) 02/05/2005 10:28:03 (LD)
######################################################################################
############################
Subprog AM_ACTCLCBAS(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    [M]PRGCLCBAS="" : Diszo [M]PRGCLCBAS
Else
    Actzo [M]PRGCLCBAS
Endif
Affzo [M]PRGCLCBAS

End
######################################## traitement
Subprog C_PRGCLCBAS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ACTCLCBAS<>"" GMESSAGE=mess(10,123,1) : mkstat=2 Endif
End
######################################## tableau des règles d'affectation
Subprog AVANT_NBREG

# Le flag de regroupement ne s'applique que pour les éléments en %
# Si élément en montant, il est forcé à "oui" et non modifiable
If [M]AMTCOD=2
    [M]GRUFLG(nolign-1)=1 : Diszo [M]GRUFLG(nolign-1)
Else
    Actzo [M]GRUFLG(nolign-1)
Endif

If [M]ORIVCR(nolign-1)=2
    [M]BRDRUL(nolign-1)=3 : Diszo [M]BRDRUL(nolign-1)
Else
    Actzo [M]BRDRUL(nolign-1)
Endif
End
######################################## règle éclatement
Subprog AS_BRDRUL(VALEUR)
Variable Integer VALEUR

# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=4
  mkstat=2 : End
Endif

Case [M:SFI1]ORIVCR(nolign-1)
    When 1 :  # Devis
        For I=2 To 4 GMENLOC(I)=1 : Next
        For I=6 To 8 GMENLOC(I)=1 : Next
    When 12 : # Commande à facturation diverse
        For I=1 To 2 GMENLOC(I)=1 : Next
        For I=4 To 6 GMENLOC(I)=1 : Next
        GMENLOC(8)=1
    When 10 : # Commande
        # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
        #GMENLOC(1)=1
        #For I=3 To 5 GMENLOC(I)=1 : Next
        #For I=7 To 8 GMENLOC(I)=1 : Next
        If [M:SFI1]DESVCR(nolign-1)=2
          #--Normal order to Delivery
          GMENLOC(1)=1
          For I=3 To 5 GMENLOC(I)=1 : Next
          For I=7 To 8 GMENLOC(I)=1 : Next
        Else
          #--Normal order to Invoice
          For I=1 To 2 GMENLOC(I)=1 : Next
          For I=4 To 6 GMENLOC(I)=1 : Next
          GMENLOC(8)=1
        Endif
        # End issue 107888
    When 2 : # Livraison : Forcément 1ère facture
        mkstat=2
    When 4 : # Facture
        For I=1 To 3 GMENLOC(I)=1 : Next
        For I=5 To 7 GMENLOC(I)=1 : Next
    When 3 : # Retour
        #--CPO 79550 Nouvelles règles de transfert : Retours -> Avoirs
        For I=1 To 3 GMENLOC(I)=1 : Next
        For I=5 To 7 GMENLOC(I)=1 : Next
    When 23 : # Contrat de service
        #--CPO 79550 Nouvelles règles de transfert : Contrats de service -> Factures
        If GMODU(12)=2
          For I=1 To 2 GMENLOC(I)=1 : Next
          GMENLOC(4)=1
          For I=5 To 6 GMENLOC(I)=1 : Next
          GMENLOC(8)=1
          For I=10 To 12 GMENLOC(I)=1 : Next
        Else
           #--Afin d'anticiper des futures règles de transfert : on ne peut pas avoir de trou dans les tableaux
           #--Il faut laisser toutes les règles, y compris les "contrats de services"
           #--Mais si GMODU(12)<>2 : il ne seront pas saisissables...
          mkstat = 2
        Endif
    When Default :
Endcase
# ACA - Pas de prorata montant pour les taux (car équivalent à "tous")
If [M]AMTCOD=1
    GMENLOC(9)=2
Endif
End
######################################## règle regroupement
Subprog AS_GRURUL(VALEUR)
Variable Integer VALEUR

# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=4
  mkstat=2 : End
Endif

Case [M]AMTCOD
    When 1 : # Elément en %
        For I=5  To 10 GMENLOC(I)=1 : Next
        GMENLOC(15)=1 #--CPO 79550
        GMENLOC(17)=1 #--CPO 79550
    When 2 : # Elément en montant
        #For I=11 To 15 GMENLOC(I)=1 : Next
        For I=11 To 13 GMENLOC(I)=1 : Next #--CPO 79550
    When Default :
Endcase
Case [M]ORIVCR(nolign-1)
    When 1     :  # Devis
        For I=2  To 4  GMENLOC(I)=1 : Next
        For I=6  To 8  GMENLOC(I)=1 : Next
        For I=14 To 17 GMENLOC(I)=1 : Next #--CPO 79550
    When 12,10 : # Commande à facturation diverse et Commande
        GMENLOC(1)=1
        For I=3  To 5  GMENLOC(I)=1 : Next
        For I=7  To 8  GMENLOC(I)=1 : Next
        For I=14 To 17 GMENLOC(I)=1 : Next #--CPO 79550
    When 2 : # Livraison
        For I=1  To 2  GMENLOC(I)=1 : Next
        For I=4  To 6  GMENLOC(I)=1 : Next
        For I=14 To 17 GMENLOC(I)=1 : Next #--CPO 79550
        GMENLOC(8)=1
    When 4 : # Facture
        For I=1  To 3  GMENLOC(I)=1 : Next
        For I=5  To 7  GMENLOC(I)=1 : Next
        For I=14 To 17 GMENLOC(I)=1 : Next #--CPO 79550
    When 3 : # Retour
        #--CPO 79550 Nouvelles règles de transfert : Retours -> Avoirs
        For I=1  To 4  GMENLOC(I)=1 : Next
        For I=5  To 8  GMENLOC(I)=1 : Next
        For I=16 To 17 GMENLOC(I)=1 : Next
    When 23: # Contrats de service
        #--CPO 79550 Nouvelles règles de transfert : Contrats de service -> Factures
        If GMODU(12)=2
          For I=1  To 4  GMENLOC(I)=1 : Next
          For I=5  To 8  GMENLOC(I)=1 : Next
          For I=14 To 15 GMENLOC(I)=1 : Next
        Else
           #--Afin d'anticiper des futures règles de transfert : on ne peut pas avoir de trou dans les tableaux
           #--Il faut laisser toutes les règles, y compris les "contrats de services"
           #--Mais si GMODU(12)<>2 : il ne seront pas saisissables...
          mkstat = 2
        Endif
    When Default :
Endcase

End

######################################################################
# Traitement de la copie un élément de facturation                   #
# TABLE = Clé de l'enregistrement à copier                           #
#         (si la cle est numerique val(TABLE)                        #
######################################################################
#                                                                    #
#           INCOMPATIBLE AVEC LA STRUCTURE MULTI-SOCIETES            #
#                                                                    #
######################################################################
$TRTCOP
If [M]DOSORG=nomap
  Local File SFOOTINV [SFI1]
  Local File ATEXTRA  [AXX1]
Else
  Local File =[M]DOSORG+".SFOOTINV" [SFI1]
  Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
  Local File SFOOTINV [SFI2]
  Local File ATEXTRA  [AXX2]
Else
  Local File =[M]DOSDES+".SFOOTINV" [SFI2]
  Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Look [SFI2] SFI0=val(TABLE)
If !fstat
   OK= 1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK=1 : Return : Endif
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Return

#---------------------------------------------------------------------
$TR_COP

GOK=1
Trbegin [SFI2]
  Delete [SFI2] Where SFINUM=val(TABLE)
  If fstat=1  GOK=-1 : GLOCK="$"+[M]DOSDES+".SFOOTINV"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("SFI2",TABLE) From GLOCK          : Goto AB_TR_COP
  Endif
  Read [SFI1] SFI0=val(TABLE)
  If !fstat
    [F:SFI2]=[F:SFI1]
    Call COPTEXTRA("SFOOTINV","DESAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
    Call COPTEXTRA("SFOOTINV","SHOAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
    Write [SFI2]
    If fstat GOK=0 : Call FSTA("SFI2") From GLOCK : Goto AB_TR_COP : Endif
  Endif
Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return

######################################################################
#--- Controle si enr.de pied pour tarif transporteur et colisage
#    - GFRENUM : Elément de facturation port pour tarif transporteur
#    - GPCKNUM : Elément de facturation pour colisage
#--- Controle si le éléments de pied regroupement sont crees
#--- Controle cohérence de l'ordre des éléments (client, cde, liv, fac)
######################################################################
$EXEC_TRTCTRSFI
Local Char    MESGLOB (255)
Local Integer COMPTEUR, NONTROUVE (1..10)

TRA=0

#--- recherche du pied recepteur port (si gestion du tarif transporteur)
If GFRENUM<>0                 : # gestion du tarif transporteur
#  Read [F:SFI]SFI0=GSOCIETE;GFRENUM
  Read [F:SFI]SFI0=GFRENUM
  If fstat
    MESGLOB=mess(4,191,1)+num$(GFRENUM)
#   Absence d'élément pied pour le tarif transporteur
#   Paramètre FRENUM=
    Gosub LA_TRACE
  Endif
Endif

#--- recherche des pieds de regroupement non crees
Raz MESGLOB, NONTROUVE
Filter [SFI] Where INVFOOGRU>0 : #  WCPY=GSOCIETE &
For [SFI]
  If COMPTEUR < 11
    COMPTEUR +=1
    NONTROUVE (COMPTEUR) = [F:SFI]INVFOOGRU
  Endif
Next
Filter [SFI]
For COMPTEUR = 1 To 10
  If NONTROUVE(COMPTEUR) <> 0
#    Look [SFI]SFI0=GSOCIETE;NONTROUVE (COMPTEUR)
    Look [SFI]SFI0=NONTROUVE (COMPTEUR)
    If fstat
      MESGLOB=MESGLOB+"  "+num$(NONTROUVE(COMPTEUR))
    Endif
  Endif
Next COMPTEUR
If MESGLOB <> ""
  MESGLOB = mess(23,191,1)+MESGLOB
#  Créer le(s) élément(s) de pied de regroupement
  Gosub LA_TRACE
Endif

#--- recherche des pieds à eclater non crees
#    un pied réception d'eclatement fait reference à un pied inexistant
Raz MESGLOB, NONTROUVE, COMPTEUR
Filter [SFI] Where INVFOOBRD>0 : # WCPY=GSOCIETE &
For [SFI]
  If COMPTEUR < 11
    If !find([F:SFI]INVFOOBRD,NONTROUVE)
      COMPTEUR +=1
      NONTROUVE (COMPTEUR) = [F:SFI]INVFOOBRD
    Endif
  Endif
Next
Filter [SFI]
For COMPTEUR = 1 To 10
  If NONTROUVE(COMPTEUR) <> 0
#    Look [SFI]SFI0=GSOCIETE;NONTROUVE (COMPTEUR)
    Look [SFI]SFI0=NONTROUVE (COMPTEUR)
    If fstat
      MESGLOB=MESGLOB+"  "+num$(NONTROUVE(COMPTEUR))
    Endif
  Endif
Next COMPTEUR
If MESGLOB <> ""
  MESGLOB = mess(68,191,1)+MESGLOB
#  Créer le(s) élément(s) à ventiler par taxe
  Gosub LA_TRACE
Endif

#--- le pied à éclater doit être de règle taxe ventilation
For COMPTEUR = 1 To 10
  If NONTROUVE(COMPTEUR) <> 0
#    Read [SFI]SFI0=GSOCIETE;NONTROUVE (COMPTEUR)
    Read [SFI]SFI0=NONTROUVE (COMPTEUR)
    If !fstat
      If [F:SFI]VATRUL<>5
        MESGLOB=mess(69,191,1)+"  "+num$(NONTROUVE(COMPTEUR))+"  "+mess(70,191,1)
        Gosub LA_TRACE
      Endif
    Endif
    Raz MESGLOB
  Endif
Next COMPTEUR

#--- le pied est de règle taxe ventilation sans pied récepteur
Filter [SFI] Where VATRUL=5 : # WCPY=GSOCIETE &
For [SFI]
  If !find([F:SFI]SFINUM,NONTROUVE)
    MESGLOB=mess(69,191,1)+"  "+num$([F:SFI]SFINUM)+"  "+mess(71,191,1)
    Gosub LA_TRACE
  Endif
Next
Filter [SFI]

#--- Pas de position de saisie si element inactif ou non modifiable
Filter [SFI]
For [SFI]
  If [F:SFI]PROCOD<>1     : # element inactif ou non modifiable
    If [F:SFI]DACBPC<>0 | [F:SFI]DACORD<>0 | [F:SFI]DACDLV<>0 | [F:SFI]DACINV<>0
      # 105193 : Vérification des élts dont la règle de taxe est "ventilation"
      #MESGLOB=mess(48,191,1)-num$([F:SFI]SFINUM)
      MESGLOB=num$([F:SFI]SFINUM)-":"-mess(48,191,1)
      # 105193
      Gosub LA_TRACE
    Endif
  Endif
Next

Filter [SFI]

If TRA=1
  Call FERME_TRACE From LECFIC
Endif
JGCONTROLE=0

Return

#---------------------------------------------------------------------
$LA_TRACE
If TRA=0
   Call OUVRE_TRACE (mess(82,197,1)) From LECFIC
Endif
TRA=1
Call ECR_TRACE (MESGLOB,1) From GESECRAN
Return

