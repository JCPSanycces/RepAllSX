#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################
# SUBSFI : Gestion des éléments de facturation vente                 #
#--------------------------------------------------------------------#
# Bouton "Position elements": Action SAISFIPOS                       #
#    - Fenêtre ISFIPOS - Masque SSFIPOS - Traitement TRTSFIPOS       #
######################################################################
#Local File SFOOTINV [SFI]
#Trbegin [SFI]
#
#Update [F:SFI] With
#&  [SFI]ORIVCR(5)=3,
#&  [SFI]DESVCR(5)=5,
#&  [SFI]BRDRUL(5)=4,
#&  [SFI]GRUFLG(5)=1,
#&  [SFI]GRURUL(5)=14
#
##[M:SFI1]ORIVCR(6)=23:[M:SFI1]DESVCR(6)=4:[M:SFI1]BRDRUL(6)=3:[M:SFI1]GRUFLG(6)=1:[M:SFI1]GRURUL(6)=16
#Update [F:SFI] With
#&  [SFI]ORIVCR(6)=23,
#&  [SFI]DESVCR(6)=4,
#&  [SFI]BRDRUL(6)=3,
#&  [SFI]GRUFLG(6)=1,
#&  [SFI]GRURUL(6)=16
#If fstat=0
#  Commit
#Else
#  Rollback
#Endif
#
#Infbox "Nb records updated :"-num$([S]adxuprec)
#
#End
#----------------------------------
Call OBJET ("SFI",GBIDC1,GBIDC2) From GOBJET
End
######################################################################
$ACTION

# Pour gestion multi-société
# Gosub ACTION From GSOCIETE

#--- Actions liées à l'objet
Case ACTION
  When "OUVRE"       : Gosub OUVRE        : # lecture devise dossier
  When "SETBOUT"     : Gosub SETBOUT
  When "APRES_MODIF" : Gosub APRES_MODIF  : # traitement des grizo
  When "LIENS"       : Gosub LIENS        : # pour format valeur défaut
  When "RAZCRE"      : Gosub RAZCRE       : # pour sections analytiques
  When "VERIF_MOD"   : Gosub VERIF_MOD    : # 105815 : SST document discount
  When "INICRE"      : Gosub INICRE
  When "INIMOD"      : Gosub INIMOD       : # 102423 : Belgium Early discounts
  When "ANNULE"      : Gosub ANNULE
  When "FIN"         : Gosub FIN          : # pour test transp. colisage
  When "AFFMASK"     : Gosub AFFMASK      : # 102423 : Belgium Early discounts
  When Default
Endcase

#--- Actions liées au traitement de contrôle de cohérence
Case ACTION
  When "EXEC"        : Case GACTION
                         When "TRTCTRSFI" : Gosub EXEC_TRTCTRSFI
                       Endcase
  When Default
Endcase

Return

######################################################################
$OUVRE
Global Integer JGCONTROLE  : # temoin de passage dans le controle de cohérence
JGCONTROLE=1               : # le controle peut être effectué une fois sans modif
Global Integer JG_VDTLONG  : # longueur d affichage de VALTYP
Local  Integer SPSTAT

If clalev ([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev ([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
If clalev ([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev ([F:CDI])=0 : Local File CADIEDEF [CDI] : Endif
If clalev ([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif   : # 102423 : Belgium Early discounts
If clalev ([F:CPY2])=0 : Local File COMPANY [CPY2] : Endif   # 106867.n

#---- Chargement de GCUR
Call CHARGE_GCUR() From TRTX3
Call LECDEV (GCUR) From TRTDIV

#---- Stockage longueur affichage du champ VALTYP ( pour chgfmt )
JG_VDTLONG=8                   : # par defaut
Read [AMZ]CODE="SFI1";"VALTYP"
If !fstat : JG_VDTLONG=[F:AMZ]LONG : Endif

Global Char GSFI_DEVFMT(10) : # 102423 : Belgium Early discounts

Return

######################################################################
$SETBOUT
#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET

#--- désactivation bouton "Controle" et "Positions Elts"
# 102423 : Belgium Early discounts
#If GREP <>""            Call VIREBOUT(CHAINE,"13") From GOBJET : Endif
If GREP <>"" | GMODU(5)<>2 Call VIREBOUT(CHAINE,"13") From GOBJET : Endif
# 102423

#--CPO 77002 - uniquement pour les versions ultérieures
##--- désactivation bouton "Copie"
#Call VIREBOUT(CHAINE,"2") From GOBJET      : # Incompatible avec structure multi-societes
#--/CPO
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
Return

######################################################################
$APRES_MODIF
JGCONTROLE=1        : # si modif on positionne le temoin de controle
Case COUZON
  When "INVFOOGRU"  : Gosub G_INVFOOGRU
  When "VATRUL"     : Gosub G_VATRUL
  When "INVFOOBRD"  : Gosub G_INVFOOBRD
  When "MISRULSTD"  : Gosub G_MISRULSTD
  When "CLCBAS"     : Gosub G_CLCBAS
  When "AMTCOD"     : Gosub G_AMTCOD
  When "DSP"        : Gosub G_DSP
  When Default
Endcase
Return

#-- No du pied de regroupement ---------------------------------------
$G_INVFOOGRU
If val(CZ) <> 0
    Gosub GRIZO_TAXES
    Gosub GRIZO_COMPTA
  Else
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
    Gosub ACTZO_COMPTA
Endif
Return

#--- Regle de taxe ---------------------------------------------------
#    1=produit  2=taux maxi  3=taux mini  4=taux fixe  5=ventilation
$G_VATRUL
If val(CZ) <> 4
   Gosub GRIZO_VAC
 Else
   Gosub ACTZO_VAC
Endif
Return

#-- No du pied recepteur de ventilation ------------------------------
$G_INVFOOBRD
If val(CZ) <> 0
  [M:SFI1]EXCTAXRUL=1 : [M:SFI1]SPETAXRUL=1
  Affzo EXCTAXRUL, SPETAXRUL
  Grizo EXCTAXRUL, SPETAXRUL
Else
  Actzo [M:SFI1]EXCTAXRUL, SPETAXRUL
Endif
Return

#-- Regles Diverses --------------------------------------------------
#    1=Non  2=Remise taxe
$G_MISRULSTD
If val(CZ) = 2
    Gosub GRIZO_TAXES
    Gosub GRIZO_COMPTA
    Gosub GRIZO_CALCUL
    # VPO 26/03/10 V6.2:60763 Settlements Discounts
    [M:SFI1]PROCOD=2
    [M:SFI1]AMTCOD=1
    [M:SFI1]INCDCR=2
    Raz [M:SFI1]BPCORI,DEFVAL
    [M:SFI1]DEPFLG=1
    Affzo [M:SFI1]PROCOD,AMTCOD,INCDCR,BPCORI,DEFVAL,DEPFLG
    Gosub GRIZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub GRIZO_TRF : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub GRIZO_ACTION : # VPO 26/03/10 V6.2:60763 Settlements Discounts
  Else
    Gosub ACTZO_CALCUL
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
    Gosub ACTZO_COMPTA
    Gosub ACTZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub ACTZO_TRF : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub ACTZO_ACTION : # VPO 26/03/10 V6.2:60763 Settlements Discounts
Endif
Return

#-- Base de calcul ---------------------------------------------------
#    1=HT  2=TTC
$G_CLCBAS
If val(CZ) = 2
    Gosub GRIZO_TAXES
  Else
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
Endif
Return

#-- Type de valeur ---------------------------------------------------
#    1=Taux  2=Montant
$G_AMTCOD
If val(CZ) = 2
    Gosub GRIZO_ACTION
  Else
    Gosub ACTZO_ACTION
Endif
Return

#-- Clé Répartition --------------------------------------------------
$G_DSP
If CZ <> ""
    Gosub GRIZO_CCE
  Else
    Gosub ACTZO_CCE
Endif
Return

#---------------------------------------------------------------------
#   grizo et actzo des blocs calcul taxes et cce
#---------------------------------------------------------------------

#-- bloc règles calcul --
$GRIZO_CALCUL
[M:SFI1]CLCBAS=1 : Raz [M:SFI1]CLCVACITM, TSDMIN, TSDMAX
Affzo [M:SFI1]CLCBAS, CLCVACITM, TSDMIN, TSDMAX
Grizo [M:SFI1]CLCBAS, CLCVACITM, TSDMIN, TSDMAX
Return

$ACTZO_CALCUL
Actzo [M:SFI1]CLCBAS, CLCVACITM, TSDMIN, TSDMAX
Return

#-- tout le bloc des taxes --
$GRIZO_TAXES
[M:SFI1]VATRUL=1 : [M:SFI1]EXCTAXRUL=1 : [M:SFI1]SPETAXRUL=1
Raz [M:SFI1]VACITM
Affzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL, VACITM
Grizo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL, VACITM
If dim([M:SFI1]ZVACITM)>0
   Affzo [M:SFI1]ZVACITM : Grizo [M:SFI1]ZVACITM
Endif
Return

$ACTZO_TAXES
Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL, VACITM
If dim([M:SFI1]ZVACITM)>0
   Actzo [M:SFI1]ZVACITM
Endif
Return

#-- le regime de taxe --
$GRIZO_VAC
Raz [M:SFI1]VACITM
Affzo [M:SFI1]VACITM
Grizo [M:SFI1]VACITM
If dim([M:SFI1]ZVACITM)>0
   Affzo [M:SFI1]ZVACITM : Grizo [M:SFI1]ZVACITM
Endif
Return

$ACTZO_VAC
Actzo [M:SFI1]VACITM
If dim([M:SFI1]ZVACITM)>0
   Actzo [M:SFI1]ZVACITM
Endif
Return

#-- toute la compta --
$GRIZO_COMPTA
Raz [M:SFI1]ACCCOD : Affzo [M:SFI1]ACCCOD : Grizo [M:SFI1]ACCCOD
Raz [M:SFI1]DSP    : Affzo [M:SFI1]DSP    : Grizo [M:SFI1]DSP
If dim([M:SFI1]NBAXE)>0 : Raz [M:SFI1]CCE : Affzo [M:SFI1]CCE : Grizo [M:SFI1]CCE : Endif
Return

$ACTZO_COMPTA
Actzo [M:SFI1]ACCCOD
Actzo [M:SFI1]DSP
If [M:SFI1]DSP<>""  Gosub GRIZO_CCE  Else  Gosub ACTZO_CCE  Endif
Return

#-- le bloc analytique --
$GRIZO_CCE
If dim([M:SFI1]NBAXE)>0 : Raz [M:SFI1]CCE : Affzo [M:SFI1]CCE : Grizo [M:SFI1]CCE : Endif
Return

$ACTZO_CCE
If dim([M:SFI1]NBAXE)>0 : Actzo [M:SFI1]CCE : Endif
Return


#-- Action pour calcul de la base --
$ACTZO_ACTION
Actzo [M:SFI1]ACTCLCBAS, PRGCLCBAS
Return

$GRIZO_ACTION
Raz [M:SFI1]ACTCLCBAS, PRGCLCBAS
Grizo [M:SFI1]ACTCLCBAS, PRGCLCBAS
Return

# VPO 26/03/10 V6.2:60763 Settlements Discounts
$ACTZO_GENE
Actzo [M:SFI1]PROCOD,AMTCOD,INCDCR,BPCORI,DEFVAL,DEPFLG
Return

$GRIZO_GENE
Grizo [M:SFI1]PROCOD,AMTCOD,INCDCR,BPCORI,DEFVAL,DEPFLG
Return

$ACTZO_TRF
Actzo [M:SFI1]40
Return

$GRIZO_TRF
Grizo [M:SFI1]40
Return

######################################################################
$LIENS

Call LECDEV (GCUR) From TRTDIV

# Alimentation des mnts stockés en dev dossier dans [F] pour saisie en dev soc dans [M]

Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:SFI]TSDMIN,[M:SFI1]TSDMIN,SPSTAT) From TRTDEV
Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:SFI]TSDMAX,[M:SFI1]TSDMAX,SPSTAT) From TRTDEV

[M:SFI1]TSDMINCUR = GCUR
If [F:SFI]AMTCOD = 2
   Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:SFI]DEFVAL,[M:SFI1]DEFVAL,SPSTAT) From TRTDEV
Endif

[M:SFI1]DEFVALCUR = string$([M:SFI1]AMTCOD=2,GCUR)

#--- Chargement tableau des axes
If dim([M:SFI1]NBAXE)>0
   If dim([M:SFI1]SOC)>0 & [M:SFI1]SOC<>""
      Call CHARG_DIE(10,[M:SFI1]SOC,"SFI1","NBAXE") From TRTX3CPT
    Else
      Call CHARG_DIE(10,"","SFI1","NBAXE") From TRTX3CPT
   Endif
Endif

If dim([M:SFI1]ORIVCR)>0            : # 102423 : Belgium Early discounts
    #--- Nbre de règles d'affectations
    #If GMODU(12)=2    :#--CPO 79550 Module "Support client" pour le transfert des contrats de services
    #--Afin d'anticiper des futures règles de transfert : on ne peut pas avoir de trou dans les tableaux
    #--Il faut laisser toutes les règles, y compris les "contrats de services"
    #--Mais si GMODU(12)<>2 : il ne seront pas saisissables...
    # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
    #[M:SFI1]NBREG=7 :#--CPO 79550 Nouvelles règles de transfert : Retours -> Avoirs
    [M:SFI1]NBREG=8 :#--New tranfer rule : Normal order -> Invoices
    # End issue 107888
    If sum([M:SFI1]GRUFLG)=0 Gosub INITABREG Endif
Endif                               : # 102423 : Belgium Early discounts

#--- Si element "Taux" ne pas afficher le champ VALTYP
If [M:SFI1]AMTCOD=1 | GMODU(5)<>2   : # 102423 : Belgium Early discounts
#If [M:SFI1]AMTCOD=1                : # 102423 : Belgium Early discounts
   Chgfmt [M:SFI1]VALTYP With "-K:"+num$(JG_VDTLONG)+"X"
Else
   Chgfmt [M:SFI1]VALTYP With "K:"+num$(JG_VDTLONG)+"X"
Endif
Affzo [M:SFI1]VALTYP

#--- grizo actzo
Gosub ACTZO_TAXES
Gosub ACTZO_COMPTA
Gosub ACTZO_CALCUL
Gosub ACTZO_ACTION
Gosub ACTZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
Gosub ACTZO_TRF  : # VPO 26/03/10 V6.2:60763 Settlements Discounts

If dim([M:SFI1]ORIVCR)>0            : # 102423 : Belgium Early discounts
    Local Integer IG # ACA
    For IG=0 To [M:SFI1]NBREG-1
        If [M:SFI1]GRUFLG(IG)=2
            Diszo [M:SFI1]GRURUL(IG)
            Effzo [M:SFI1]GRURUL(IG) #Gbn-82561
        Else
            Actzo [M:SFI1]GRURUL(IG)
        Endif
        Affzo [M:SFI1]GRURUL(IG) #Gbn-82561
    Next I
Endif                               : # 102423 : Belgium Early discounts

If [M:SFI1]AMTCOD=2
   Gosub GRIZO_ACTION
Endif

# 102423 : Belgium Early discounts
Actzo [M:SFI1]MISRULSTD
# If Rebate on vat and used in early discount, Rebate on vat can't be modified
If [M:SFI1]MISRULSTD=2
  Filter [TDA] Where SFINUM=[M:SFI1]SFINUM
  Read [TDA] First
  If !fstat
    Diszo [M:SFI1]MISRULSTD
  Endif
  Filter [TDA]
Endif

If [M:SFI1]INCDCR=2
    # If Decrease : always subject to discount : The field musn't appear
    Chgfmt [M:SFI1]DEPFLG With "-LA:1"
Else
    # If Increase : can be both
    Chgfmt [M:SFI1]DEPFLG With "LA:1"
Endif
# 102423

# ACA (2010-02-23) Bug 49021 : Griser les bases taxe si éclatement
If [M:SFI1]INVFOOBRD<>0
    [M:SFI1]EXCTAXRUL=1 : [M:SFI1]SPETAXRUL=1
    Affzo EXCTAXRUL, SPETAXRUL
    Grizo EXCTAXRUL, SPETAXRUL
Endif

If [M:SFI1]INVFOOGRU<>0
    Gosub GRIZO_TAXES
    Gosub GRIZO_COMPTA
    Goto F_LIENS
Endif

If dim([M:SFI1]MISRULSTD)>0
    If [M:SFI1]MISRULSTD=2
        Gosub GRIZO_TAXES
        Gosub GRIZO_COMPTA
        Gosub GRIZO_CALCUL
        Gosub GRIZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
        Gosub GRIZO_TRF : # VPO 26/03/10 V6.2:60763 Settlements Discounts
        Gosub GRIZO_ACTION : # VPO 26/03/10 V6.2:60763 Settlements Discounts
        Goto F_LIENS
    Endif
Endif

#If [M:SFI1]CLCBAS<>3
#    Gosub GRIZO_ACTION
#Endif
If [M:SFI1]CLCBAS=2
    Gosub GRIZO_TAXES
    Goto F_LIENS
Endif

If [M:SFI1]VATRUL<>4
   Gosub GRIZO_VAC
   Goto F_LIENS
Endif

$F_LIENS

Return

######################################################################
$RAZCRE
#--- Initialisation tableau des axes
If dim([M:SFI1]NBAXE)>0
   If dim([M:SFI1]SOC)>0 & [M:SFI1]SOC<>""
      Call INIT_DIE(10,[M:SFI1]SOC,"SFI1","NBAXE") From TRTX3CPT
    Else
      Call INIT_DIE(10,"","SFI1","NBAXE") From TRTX3CPT
   Endif
Endif

If dim([M:SFI1]ORIVCR)>0            : # 102423 : Belgium Early discounts
    # Initialisation du tableau des règles de regroupement
    Gosub INITABREG
Endif                               : # 102423 : Belgium Early discounts

[M:SFI1]INCDCR = 1                  : # 102423 : Belgium Early discounts
Chgfmt [M:SFI1]DEPFLG With "LA:1"   : # 102423 : Belgium Early discounts

[M:SFI1]DEFVALCUR = string$([M:SFI1]AMTCOD=2,GCUR)
[M:SFI1]TSDMINCUR = GCUR

[M:SFI1]AMTCOD=1
Chgfmt [M:SFI1]VALTYP With "-K:"+num$(JG_VDTLONG)+"X"
[M:SFI1]VALTYP=3
[M:SFI1]DEPFLG=2
Gosub ACTZO_TAXES
Gosub ACTZO_COMPTA
Gosub ACTZO_CALCUL
Gosub ACTZO_ACTION

Affzo [M]1-99

Return

######################################################################
# Initialisation du tableau des règles de regroupement               #
# Actuellement 5 postes :                                            #
#     Devis, Commande fac directe, Commande, Livraison, Facture      #
######################################################################
$INITABREG

[M:SFI1]NBREG=5
# Devis                           --> Commande
[M:SFI1]ORIVCR(0)=1 :[M:SFI1]DESVCR(0)=10:[M:SFI1]BRDRUL(0)=1:[M:SFI1]GRUFLG(0)=1:[M:SFI1]GRURUL(0)=1
# Commande à facturation directe  --> Facture
[M:SFI1]ORIVCR(1)=12:[M:SFI1]DESVCR(1)=18:[M:SFI1]BRDRUL(1)=3:[M:SFI1]GRUFLG(1)=1:[M:SFI1]GRURUL(1)=2
# Commande                        --> Livraison
[M:SFI1]ORIVCR(2)=10:[M:SFI1]DESVCR(2) =2:[M:SFI1]BRDRUL(2)=2:[M:SFI1]GRUFLG(2)=1:[M:SFI1]GRURUL(2)=2
# Livraison                       --> Facture
[M:SFI1]ORIVCR(3)=2 :[M:SFI1]DESVCR(3)=19:[M:SFI1]BRDRUL(3)=3:[M:SFI1]GRUFLG(3)=1:[M:SFI1]GRURUL(3)=3
# Facture                         --> Avoir
[M:SFI1]ORIVCR(4)=4 :[M:SFI1]DESVCR(4)=5 :[M:SFI1]BRDRUL(4)=4:[M:SFI1]GRUFLG(4)=1:[M:SFI1]GRURUL(4)=4
#--CPO 79550 Nouvelles règles de transfert : Retours -> Avoirs, Contrats de service -> Factures
# Retour                          --> Avoir
[M:SFI1]NBREG+=1
[M:SFI1]ORIVCR(5)=3 :[M:SFI1]DESVCR(5)=5 :[M:SFI1]BRDRUL(5)=4:[M:SFI1]GRUFLG(5)=1:[M:SFI1]GRURUL(5)=14
# Contrats de services            --> facture
  #--Afin d'anticiper des futures règles de transfert : on ne peut pas avoir de trou dans les tableaux
  #--Il faut laisser toutes les règles, y compris les "contrats de services"
  #--Mais si GMODU(12)<>2 : il ne seront pas saisissables...
[M:SFI1]NBREG+=1
[M:SFI1]ORIVCR(6)=23:[M:SFI1]DESVCR(6)=4:[M:SFI1]BRDRUL(6)=3:[M:SFI1]GRUFLG(6)=1:[M:SFI1]GRURUL(6)=16
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
# Normal order                    --> Invoice
# Same as the rule Normal order to Delivery
[M:SFI1]NBREG+=1
# 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)
#   ORIVCR(7) : entry 10 "Normal order"         of local menu 476 - 'Type de document ventes'        #
#   DESVCR(7) : entry  4 "Invoice"              of local menu 476 - 'Type de document ventes'        #
#   same as the value existing for Normal order to Delivery :
#   BRDRUL(7) : 3 : 1rst invoice
#   GRUFLG(7) : 1 : Yes
#   GRURUL(7) : 2 : 1rst order
#[M:SFI1]ORIVCR(7)=10:[M:SFI1]DESVCR(7)=2 :[M:SFI1]BRDRUL(7)=2:[M:SFI1]GRUFLG(7)=1:[M:SFI1]GRURUL(7)=2
[M:SFI1]ORIVCR(7)=10:[M:SFI1]DESVCR(7)=4 :[M:SFI1]BRDRUL(7)=3:[M:SFI1]GRUFLG(7)=1:[M:SFI1]GRURUL(7)=2
# 107888 : Scheduled invoices : Backporting - X3-16063 (LD:25/01/17)

# End issue 107888

Return

######################################################################
# 105815.sn : SST document discount
######################################################################
$VERIF_MOD

If func AFNC.ACTIV("LTA")
#  If !clalev([F:LTP])  Local File LTAPAR  [LTP]  Endif   # 106867.so
#  Read [F:LTP]LTP0=nomap
#  If find ([M:SFI1]SFINUM,[F:LTP]VCRDISDTA(0..dim([F:LTP]VCRDISDTA)-1))
#    Call CHECK_VALID_SFI ([M:SFI1]VATRUL,[M:SFI1]CLCBAS,[M:SFI1]CLCVACITM,[M:SFI1]SSTCOD) From SUBLTP   # 106867.eo
  Filter [F:CPY2] Where SFINUM=[M:SFI1]SFINUM   # 106867.sn
    Read [F:CPY2] First
    If !fstat
      Call CHECK_VALID_SFI ([M:SFI1]VATRUL,[M:SFI1]CLCBAS,[M:SFI1]CLCVACITM,[M:SFI1]SSTCOD) From TRTDCP
      If GERR : OK = 0 : Return : Endif
    Endif
  Filter [F:CPY2]   # 106867.en
#  Endif   # 106867.o
Endif

Return
# 105815.en

######################################################################
# 102423 : Belgium Early discounts
######################################################################
$INIMOD

Gosub INICRE

# If Decrease : always subject to discount (The field doesn't appear)
If [M:SFI1]INCDCR=2 [M:SFI1]DEPFLG=2 Endif

Return
# 102423

######################################################################
$INICRE

#--- Réalimentation mnts saisis en dev soc dans [M] pour stockage en dev dossier dans [F]
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,[M:SFI1]TSDMIN,[F:SFI]TSDMIN,SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,[M:SFI1]TSDMAX,[F:SFI]TSDMAX,SPSTAT) From TRTDEV

If [F:SFI]AMTCOD = 2
   Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,[F:SFI]DEFVAL,[F:SFI]DEFVAL,SPSTAT) From TRTDEV
Endif

#--- Garnissage libelle du pied en langue utilisateur (GLANGUE)
#    pour affichage de la désignation dans écrans de sélection
#Call LECTURE([F:SFI]FOODES,[M:SFI1]DES) From TEXTE

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:SFI1]DESAXX,"SFOOTINV","DESAXX",num$([M:SFI1]SFINUM),"") From ATEXTRA
Call MAJTEXTRA ([M:SFI1]SHOAXX,"SFOOTINV","SHOAXX",num$([M:SFI1]SFINUM),"") From ATEXTRA

#    Cle en alpha
[F:SFI]SFINUMCAR=num$([F:SFI]SFINUM)
#    SOS libellés
If dim([F:SFI]LANDESSHO)>0
   [F:SFI]LANDESSHO=GLANGUE+"~"+[M:SFI1]DESAXX+"~"+[M:SFI1]SHOAXX
Endif

# 85879 : Valeur par défaut non convertie car devise non alimentée dans SFOOTINV
[F:SFI]CUR=GSYSCUR

# 105193 : Un élt non modifiable ne doit pas être accessible
# mise à 0 de ses positions
If [F:SFI]PROCOD = 2
  Raz [F:SFI]DACBPC, [F:SFI]DACDLV, [F:SFI]DACINV, [F:SFI]DACORD
Endif
# 105193

Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="SFOOTINV" & IDENT1=num$([F:SFI]SFINUM)
Return

######################################################################
$FIN
Local Integer OK
#  message pour indiquer que le controle de coherence n'est pas effectué

#If dim(JGCONTROLE)>0 & JGCONTROLE=1              : # 102423 : Belgium Early discounts
If dim(JGCONTROLE)>0 & JGCONTROLE=1 & GMODU(5)=2  : # 102423 : Belgium Early discounts
  Call AVERTIR (mess(92,191,1),OK) From GESECRAN
Else
  OK=1
Endif
If dim(JGCONTROLE)>0 : Kill JGCONTROLE : Endif
If dim(JG_VDTLONG)>0 : Kill JG_VDTLONG : Endif

Return

# 102423 : Belgium Early discounts
######################################################################
$AFFMASK

# To desactivate TSDMIN and TSDMAX fields, we use GSFI_DEVFMT format
# By default GSFI_DEVFMT format is equal to GDEVFMT format
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find(GCUR,GDEVISE(1..GNBDEV)),1))
GSFI_DEVFMT="Nz3:"+GDEVFMT

# If sales module is not present we need to desactivate the following fields
If GMODU(5)<>2  : # Sales module inactive
#If GUSER="LD"
    GSFI_DEVFMT="-N:11.2"
    Chgfmt [M:SFI1]PROCOD     With "-LA:271"
    Chgfmt [M:SFI1]BPCORI     With "-LA:2218"
    Chgfmt [M:SFI1]DEFVAL     With "-N:11.4"
    Chgfmt [M:SFI1]DEFVALCUR  With "-K:3"
    Chgfmt [M:SFI1]VALTYP     With "-LA:2227"

    Chgfmt [M:SFI1]VATRUL     With "-LA:283"
    Chgfmt [M:SFI1]VACITM     With "-K:"+num$(GLONTVI)
    If dim([M:SFI1]ZVACITM)>0
      Chgfmt [M:SFI1]ZVACITM With "-K:"+num$(type([M:SFI1]ZVACITM)-10)+"X"
    Endif
    Chgfmt [M:SFI1]EXCTAXRUL  With "-LA:1"
    Chgfmt [M:SFI1]SPETAXRUL  With "-LA:1"
    Chgfmt [M:SFI1]SSTCOD     With "-K:"+num$(GLONADI)
    If dim([M:SFI1]ZSSTCOD)>0
      Chgfmt [M:SFI1]ZSSTCOD With "-K:"+num$(type([M:SFI1]ZSSTCOD)-10)+"X"
    Endif

    Chgfmt [M:SFI1]CLCBAS     With "-LA:2219"
    Chgfmt [M:SFI1]ACTCLCBAS  With "-K:10"
    Chgfmt [M:SFI1]PRGCLCBAS  With "-K:10"
    Chgfmt [M:SFI1]CLCORD     With "-N:2"
    Chgfmt [M:SFI1]CLCVACITM  With "-K:"+num$(GLONTVI)
    If dim([M:SFI1]ZCLCVACITM)>0
      Chgfmt [M:SFI1]ZCLCVACITM With "-K:"+num$(type([M:SFI1]ZCLCVACITM)-10)+"X"
    Endif
    Chgfmt [M:SFI1]TSDMINCUR  With "-K:3"

    Chgfmt [M:SFI1]DSPLIN     With "-LA:475"
    Chgfmt [M:SFI1]CLCDEB     With "-LA:2208"
    Chgfmt [M:SFI1]INVFOOGRU  With "-N:3"
    Chgfmt [M:SFI1]INVFOOBRD  With "-N:3"

#    Chgfmt [M:SFI1]NBREG      With "-N:3"
#    Chgfmt [M:SFI1]ORIVCR     With "-LA:476"
#    Chgfmt [M:SFI1]DESVCR     With "-LA:476"
#    Chgfmt [M:SFI1]BRDRUL     With "-LA:473"
#    Chgfmt [M:SFI1]GRUFLG     With "-LA:474"
#    Chgfmt [M:SFI1]GRURUL     With "-LA:472"
Endif

Return
# 102423

######################################################################
#                 ACTIONS  SUR  CHAMPS
######################################################################
 ######################################## no. élément
Subprog C_SFINUM(VALEUR)
Variable Decimal  VALEUR
If VALEUR=0 : GERR=1 : GMESSAGE=mess(6,199,1) : mkstat=1 : Endif
End

######################################## code montant
Subprog AM_AMTCOD(VALEUR)
Variable Integer VALEUR
Local Integer IJL0

[M:SFI1]DEFVALCUR = string$(VALEUR=2,GCUR)
Affzo [M:SFI1]DEFVAL, DEFVALCUR

If VALEUR=1 | GMODU(5)<>2   : # 102423 : Belgium Early discounts
#If VALEUR=1                : # 102423 : Belgium Early discounts
    # Taux
   Chgfmt [M:SFI1]VALTYP With "-K:"+num$(JG_VDTLONG)+"X"
   [M]VALTYP=3
Else
   Chgfmt [M:SFI1]VALTYP With "K:"+num$(JG_VDTLONG)+"X"
   [M]VALTYP=1
Endif

#--CPO 108395 Warning message if sales documents using this element and init of transfer rules
#--Only done if changing the value, not reversing it and only while modifying the record
If find(GREP,"C","D")=0
  fstat=0
  If [F:SFI]SFINUM<>[M:SFI1]SFINUM
    Read [F:SFI]SFI0=[M:SFI1]SFINUM
  Endif
  If !fstat and [F:SFI]AMTCOD<>VALEUR
    #--Warning message
    Local Integer WWARN_ALREADYPOSTED : WWARN_ALREADYPOSTED=0
    Local Integer WOK : WOK=2
    #--Searching SVCRFOOT only for Sales module
    If GMODU(5)=2
      Local File SVCRFOOT
      Filter [SVF] Where DTA=[M:SFI1]SFINUM
      Look [SVF] First
      If !fstat
        # 'Il existe des documents vente qui utilisent cet élément de facturation en'
        Call AVERTIR(mess(428,192,1)-":"-mess([M:SFI1]AMTCOD,269,1),WOK) From GESECRAN
        WWARN_ALREADYPOSTED=1
      Endif
      Filter [SVF]
    Endif
    #--Also searching Service contracts if needed (Help-desk module and no previous message posted)
    If GMODU(12)=2 and WWARN_ALREADYPOSTED=0
      Local File CONTSERV [CON]
      Local Integer IJK,WDIMDTA : WDIMDTA=dim([F:CON]INVDTA)
      If WDIMDTA>0
        WWARN_ALREADYPOSTED=0
        Filter [CON] Where find([M:SFI1]SFINUM,INVDTA(0..WDIMDTA-1))>0 and sum(INVDTAAMT(0..WDIMDTA-1))>0
        For [CON]
          IJK=find([M:SFI1]SFINUM,[F:CON]INVDTA(0..WDIMDTA-1))
          If IJK>0
            If [F:CON]INVDTAAMT(IJK-1)>0
              WWARN_ALREADYPOSTED=1
              Break
            Endif
          Endif
        Next
        Filter [CON]
        If WWARN_ALREADYPOSTED=1
          Call AVERTIR(mess(429,192,1)-":"-mess([M:SFI1]AMTCOD,269,1),WOK) From GESECRAN
        Endif
      Endif
    Endif
    #--Init of transfer rules
    If WOK=2
      Call MESSAGE(mess(430,192,1)) From GESECRAN
      Gosub INITABREG
      Affzo [M]1-99
    Else
      mkstat=2
    Endif
  Endif
Endif
#--/
End

# 102423 : Belgium Early discounts
######################################## Sens
Subprog AM_INCDCR(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  # If Decrease : always subject to discount : The field musn't appear
  [M:SFI1]DEPFLG=2
  Chgfmt [M:SFI1]DEPFLG With "-LA:1"
Else
  # If Increase : can be both
  Chgfmt [M:SFI1]DEPFLG With "LA:1"
  Affzo [M:SFI1]DEPFLG
Endif
End
# 102423

######################################## no. regroupement
Subprog AM_INVFOOGRU(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
    Gosub GRIZO_TAXES
    Gosub GRIZO_COMPTA
  Else
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
    Gosub ACTZO_COMPTA
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran SFI1) 05/11/2007 14:20:52 (LD)
######################################################################################
Subprog AS_VALTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End
########################################
Subprog AS_MISRULSTD(VALEUR)
Variable Integer VALEUR
#Read [ACV]CODACT="KGB"
#If fstat | [F:ACV]FLACT<>2 : GMENLOC(2)=1 : Endif
End

#---------------------------------------
Subprog AP_MISRULSTD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End

#---------------------------------------
Subprog AM_MISRULSTD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Gosub GRIZO_TAXES
    Gosub GRIZO_COMPTA
    Gosub GRIZO_CALCUL
    # VPO 26/03/10 V6.2:60763 Settlements Discounts
    [M:SFI1]PROCOD=2
    [M:SFI1]AMTCOD=1
    [M:SFI1]INCDCR=2
    Raz [M:SFI1]BPCORI,DEFVAL
    [M:SFI1]DEPFLG=1
    Affzo [M:SFI1]PROCOD,AMTCOD,INCDCR,BPCORI,DEFVAL,DEPFLG
    Gosub GRIZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub GRIZO_TRF : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub GRIZO_ACTION : # VPO 26/03/10 V6.2:60763 Settlements Discounts
Else
    Gosub ACTZO_CALCUL
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
    Gosub ACTZO_COMPTA
    Gosub ACTZO_GENE : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub ACTZO_TRF : # VPO 26/03/10 V6.2:60763 Settlements Discounts
    Gosub ACTZO_ACTION : # VPO 26/03/10 V6.2:60763 Settlements Discounts
Endif
End

######################################## base calcul
Subprog AS_CLCBAS(VALEUR)
Variable Integer VALEUR
# La valeur 3 (Action) est désactivée
# L'action est tjs saisissable que l'on soit en base de calcul HT ou TTC
GMENLOC(3)=1
End
#---------------------------------------
Subprog AM_CLCBAS(VALEUR)
Variable Integer VALEUR
# L'action est tjs saisissable que l'on soit en base de calcul HT ou TTC
If VALEUR=2 : # Après calcul taxe
    Gosub GRIZO_TAXES
#    Gosub GRIZO_ACTION
Elsif VALEUR=1 : # Avant calcul taxe
    Actzo [M:SFI1]VATRUL, EXCTAXRUL, SPETAXRUL
    If [M:SFI1]VATRUL <> 4
        Gosub GRIZO_VAC
      Else
        Gosub ACTZO_VAC
    Endif
#    Gosub GRIZO_ACTION
#Elsif VALEUR=3 : # ACTION
#    Gosub ACTZO_ACTION
Endif
End

######################################## règle taxe
Subprog AM_VATRUL(VALEUR)
Variable Integer VALEUR
If VALEUR<>4
   Gosub GRIZO_VAC
 Else
   Gosub ACTZO_VAC
Endif
End

######################################## clé répartition
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
If dim([M:SFI1]NBAXE)>0
  If VALEUR<>""
    Gosub GRIZO_CCE
  Else
    If dim([M:SFI1]SOC)>0 & [M:SFI1]SOC<>""
      Call INIT_DIE(10,[M:SFI1]SOC,"SFI1","NBAXE") From TRTX3CPT
    Else
      Call INIT_DIE(10,"","SFI1","NBAXE") From TRTX3CPT
    Endif
    Gosub ACTZO_CCE
  Endif
Endif
End

######################################## sections analytiques
Subprog AS_NBAXE
If [M:SFI1]INVFOOGRU<>0 : mkstat=2 : Endif
End

