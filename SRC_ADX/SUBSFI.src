# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
Subprog AM_BRDRUL(VALEUR)
Variable Integer VALEUR

# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
Local Integer I,WFOUND
If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=2
  WFOUND=[V]CST_ANO
  For I=0 To [M:SFI1]NBREG-1
    If [M:SFI1]ORIVCR(I)=10 and [M:SFI1]DESVCR(I)=4
      WFOUND=[V]CST_AYES
      Break
    Endif
  Next
  If WFOUND=[V]CST_AYES
    If    VALEUR=2 #--1st Invoice instead of 1st Delivery
      [M:SFI1]BRDRUL(I)=3
    Elsif VALEUR=6 #--All Invoices instead of All Deliveries
      [M:SFI1]BRDRUL(I)=7
    Else
      [M:SFI1]BRDRUL(I)=VALEUR
    Endif
    [M:SFI1]GRUFLG(I)=[M:SFI1]GRUFLG(nolign-1)
    [M:SFI1]GRURUL(I)=[M:SFI1]GRURUL(nolign-1)

  Endif
Endif

End
######################################################################################
Subprog AS_GRUFLG(VALEUR)
Variable Integer VALEUR

  If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=4
    mkstat=2
  Endif

End
######################################################################################
Subprog AM_GRURUL(VALEUR)
Variable Integer VALEUR

# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
Local Integer I,WFOUND
If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=2
  WFOUND=[V]CST_ANO
  For I=0 To [M:SFI1]NBREG-1
    If [M:SFI1]ORIVCR(I)=10 and [M:SFI1]DESVCR(I)=4
      WFOUND=[V]CST_AYES
      Break
    Endif
  Next
  If WFOUND=[V]CST_AYES
    If    [M:SFI1]BRDRUL(nolign-1)=2 #--1st Invoice instead of 1st Delivery
      [M:SFI1]BRDRUL(I)=3
    Elsif [M:SFI1]BRDRUL(nolign-1)=6 #--All Invoices instead of All Deliveries
      [M:SFI1]BRDRUL(I)=7
    Else
      [M:SFI1]BRDRUL(I)=[M:SFI1]BRDRUL(nolign-1)
    Endif
    [M:SFI1]GRUFLG(I)=[M:SFI1]GRUFLG(nolign-1)
    [M:SFI1]GRURUL(I)=VALEUR

  Endif
Endif

End
######################################################################################
Subprog APRES_NBREG

  Affzo [M:SFI1]BRDRUL,GRUFLG,GRURUL

End
