## Etiquette ajoutée par le superviseur (écran SFI1) 10/07/2006 15:53:54 (JL)
######################################################################################
Subprog AM_SOC(VALEUR)
Variable Char    VALEUR()
[M:SFI1]SOC=VALEUR
#--- Initialisation tableau des axes
If dim([M:SFI1]NBAXE)>0
   If dim([M:SFI1]SOC)>0 & [M:SFI1]SOC<>""
      Call CHARG_DIE(10,[M:SFI1]SOC,"SFI1","NBAXE") From TRTX3CPT
    Else
      Call CHARG_DIE(10,"","SFI1","NBAXE") From TRTX3CPT
   Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SFI1) 17/11/2008 11:20:46 (ACA)
######################################################################################
Subprog AM_GRUFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=1
    Actzo GRURUL(nolign-1)
Else
    Diszo GRURUL(nolign-1)
    Effzo GRURUL(nolign-1) #Gbn-82561
Endif

# Issue 107890 - 2016-08-01 by CPO : US111 : Scheduling invoices;
#--Only the rules concerning Normal order to delivery is accessible.
#--The other one Normal order to invoice is not acessible
Local Integer I,WFOUND
If [M:SFI1]ORIVCR(nolign-1)=10 and [M:SFI1]DESVCR(nolign-1)=2
  WFOUND=[V]CST_ANO
  For I=0 To [M:SFI1]NBREG-1
    If [M:SFI1]ORIVCR(I)=10 and [M:SFI1]DESVCR(I)=4
      WFOUND=[V]CST_AYES
      Break
    Endif
  Next
  If WFOUND=[V]CST_AYES
    If    [M:SFI1]BRDRUL(nolign-1)=2 #--1st Invoice instead of 1st Delivery
      [M:SFI1]BRDRUL(I)=3
    Elsif [M:SFI1]BRDRUL(nolign-1)=6 #--All Invoices instead of All Deliveries
      [M:SFI1]BRDRUL(I)=7
    Else
      [M:SFI1]BRDRUL(I)=[M:SFI1]BRDRUL(nolign-1)
    Endif
    [M:SFI1]GRUFLG(I)=VALEUR
    [M:SFI1]GRURUL(I)=[M:SFI1]GRURUL(nolign-1)
  Endif
Endif

End
