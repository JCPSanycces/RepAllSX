$EMPESSSA_RSAID_CONTROL
#Do not use the code in EMPLOID_CSTD_PRO
Local Char BIRTHYEAR(4),BIRTHMONTH(2),BIRTHDAY(2),IDYEAR(4),IDMONTH(2),IDDAY(2)

If this.APARENT.EMPESS.DATBRN <> [0/0/0] and len(num$(this.RSAID)) > 6
#get birthday elements
  BIRTHYEAR = mid$(num$(year(this.APARENT.EMPESS.DATBRN)),3,2)
  BIRTHMONTH = format$("N0:2",num$(month(this.APARENT.EMPESS.DATBRN)))
  BIRTHDAY= format$("N0:2",num$(day(this.APARENT.EMPESS.DATBRN)))

#get ID number elements
  IDYEAR = num$(mid$(this.RSAID,1,2))
  IDMONTH =mid$(this.RSAID,3,2)
  IDDAY =mid$(this.RSAID,5,2)

#compare elements
  If BIRTHYEAR<>IDYEAR or BIRTHMONTH<>IDMONTH or BIRTHDAY<>IDDAY
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(46,11662,1),[V]CST_AERROR)
  Endif
Endif
Return

