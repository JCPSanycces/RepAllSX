Subprog GRISE_OLDNAM(VALEUR)
Variable Integer VALEUR
Local Char WNAM(40)
Local Char ZONE(10) : ZONE = "NAM"
#Gosub SET_ZONE
If MA
   WNAM=NAM
Endif
Local Char ZONE(10) : ZONE = "OLDNAM"
#Gosub SET_ZONE
If MA
  If OLDNAM =""
    OLDNAM=WNAM
    Affzo OLDNAM
  Endif
Endif
End

$CAL_NCKNAM
Local Char SURNAM, NAM ,ZONE(10)
ZONE = "NCKNAM"
SURNAM = this.SRN
NAM = this.OLDNAM

#Gosub SET_ZONE
#If MA
 # Réinit des initiales que si vide ou si en création \duplication
 #If [M]NCKNAM="" | GREP="C" | GREP="D"
 If this.NCKNAM="" |  this.ASTALIN <> [V]CST_ANEW
  this.NCKNAM=toupper(left$(vireblc(SURNAM,4),2)+left$(vireblc(NAM,4),3))
  If func AFNC.ACTIV("KZA") &
&   !func AFNC.ACTIV("KFR") & !func AFNC.ACTIV("KPO") Then    :#Necessary for PAIEV6 folder where all activity codes are activated !
    MYLEN = len(SURNAM)
    INIT=toupper(left$(vireblc(SURNAM,4),1))
    For I = 2 To MYLEN
      If mid$(SURNAM,I,1) = " " Then
        INIT+=mid$(SURNAM,I+1,1)
      Endif
    Next

    INIT=toupper(vireblc(INIT,4))
    this.NCKNAM=INIT

  #append initials from second name
#    If this.SECNAM<>""
#      MYLEN = len(this.SECNAM)
#      INIT=toupper(left$(vireblc(this.SECNAM,4),1))
#      For I = 2 To MYLEN
#        If mid$(this.SECNAM,I,1) = " " Then
#          INIT+=mid$(this.SECNAM,I+1,1)
#        Endif
#      Next
#      INIT=toupper(vireblc(INIT,4))
#      this.NCKNAM+=INIT
#    Endif
  Endif
 Else
  If instr(1,this.NCKNAM,"")>0
    this.NCKNAM=vireblc(this.NCKNAM,4)
  Endif
 Endif
#Endif
Return

