#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque PATCHP
###################################################################
## Intégration de patch de paye
## SBA - 18/09/13 - FQ92041 - US1927  Extraction fichier
###################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"PATCHS","PATCHP","PATCHP",3,"") From GTRAITE
End

###################################################################
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC

 When Default     : Gosub ACTION From PATCHS
Endcase
Return

$INIT_DIA
Raz [M:DIA]
[M:DIA]TYPEXP=2 : # SBA FQ92041 - US1927
[M:DIA]FICHIER = ""
[M:DIA]INTEG = 1
[M:DIA]NBDOS = 1
[M:DIA]INTSEL= 1
#52239
[M:DIA]MAJPRF= 1
[M:DIA]DOSSIER(0) = nomap
#JOJAC - 2016-03-22 - REQ114309 US78 - START
Call AM_TYPEXP([M:DIA]TYPEXP):# FQ92896-Convergence
#JOJAC - 2016-03-22 - REQ114309 US78 - END
Return

$CONTROLE
#Pour ne pas passer dans PATCHS si non demandé...
If [M:DIA]INTSEL<>2 : BOITE="" : Endif

If GSTATUT<>GSTAOK
 FIN = 1
Else
 # SBA FQ92041 - US1927
 # TMP =1
 # SBA fin
 TRA = 1
Endif
Return

$EXEC
If GSTATUT<>GSTAOK : Return : Endif
Local Char TEXTE(80)

# SBA FQ92041 - US1927
Gosub VAR_LOCALFILE
If(BOITE<>"PATCHS")
  Gosub GET_LOCALFILE
  # laisser cette ligne ici.
  If STAT : Return : Endif
Else
  # sur retour de PATCHS, il faut récupérer les infos mais ne pas exécuter la fonction de sélection de fichier
  WFICHIER = [M:DIA]FICHIER
  If [M:DIA]TYPEXP=1
     WFICHIER=func TOOLSHRLEG.GET_DEFNAMFIL("pay")
    WFICCLI = [M:DIA]FICHIER
#JOJAC - 2016-03-22 - REQ114309 US78 - START
    WFICHIER=[M:DIA]VOLFIL
#    Call SET_FICNAM(WFICHIER,WFICHIER,URL) From ORDSYS
#JOJAC - 2016-03-22 - REQ114309 US78 - END
  Endif
Endif
#52239 : ajout passage en param de [M:DIA]MAJPRF
# SBA FQ92041 - US1927
#Call PATCH([M:DIA]FICHIER,[M:DIA]INTEG,[M:DIA]NBDOS,[M:DIA]DOSSIER,TEXTE
#&         ,[M:DIA]INTSEL,[M:DIA]NBOBJ,[M:DIA]OBJET,[M:DIA]MAJPRF)
Call PATCH(WFICHIER,WFICCLI,[M:DIA]INTEG,[M:DIA]NBDOS,[M:DIA]DOSSIER,TEXTE
&         ,[M:DIA]INTSEL,[M:DIA]NBOBJ,[M:DIA]OBJET,[M:DIA]MAJPRF)

If !GSERVEUR
 TRA = 1
Endif
If !GSERVEUR & TEXTE<>""
 Call LECFIC("TXT",TEXTE,"txt") From LECFIC
Endif
Return

##*****************************************************************#
# SBA FQ92041 - US1927

$VAR_LOCALFILE
Local Char    WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(10)
Local Integer STAT
Return

$GET_LOCALFILE
WFICHIER = [M:DIA]FICHIER
If [M:DIA]TYPEXP=1
 WFICCLI =func TOOLSHRLEG.GET_DEFNAMFIL("pay")
 Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
 Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
 [M:DIA]FICHIER = WFICCLI
#JOJAC - 2016-03-22 - REQ114309 US78 - START
 [M:DIA]VOLFIL = WFICHIER
#JOJAC - 2016-03-22 - REQ114309 US78 - END
 If STAT : FIN = 1 : Endif
 #GFICPATH = WFICCLI
Else
 WFICCLI = ""
Endif

Return

#JOJAC - 2016-03-22 - REQ114309 US78 - START
# Attention utilisé dans APATCHP
Funprog GET_DEFNAMFIL(EXT)
Value Char EXT
Gosub SET_FICDEF From ORDSYS
If !instr(1,FICDEF,".")
 FICDEF+="."+EXT
Else
  FICDEF=left$(FICDEF,instr(1,FICDEF,"."))+EXT
Endif
End FICDEF

# SBA fin
#JOJAC - 2016-03-22 - REQ114309 US78 - END

##*****************************************************************#
# SBA FQ92041 - US1927
# Ajout FICCLI
####################################################################
#Subprog PATCH(FICBASE,INTEG,NBDOS,DOSSIER,README,INTSEL,NBOBJ,TBOBJ,MAJPRF)
Subprog PATCH(FICBASE,FICCLI,INTEG,NBDOS,DOSSIER,README,INTSEL,NBOBJ,TBOBJ,MAJPRF)
####################################################################
Value    Char    FICBASE
Value    Char    FICCLI
Value    Integer INTEG
Value    Integer NBDOS
Value    Char    DOSSIER()(1..)
Variable Char    README()
Value    Integer INTSEL
Value    Integer NBOBJ
Value    Char    TBOBJ()(1..)
Value    Integer MAJPRF

Gosub DECLARE
Local File ADOSSIER [ADS]

If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE = left$(FICBASE,len(FICBASE)-1)
Endif

Call MACHINE(FICBASE,MACHINE,MACFIC) From ORDSYS
Call EXISTE(FICBASE,TYPFIC) From ORDSYS

Case TYPFIC
 When 2       : # C'est un répertoire
  EXT = "pay"
  If MACHINE="#"
   Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+MACFIC+'\*.'+EXT+'"' As [FTR_]
   NBTRAIT = 0
   For [FTR_]
    If pat([F:FTR_]LISFIC,'*.'+EXT)
     NBTRAIT += 1
     If NBTRAIT<=dim(TRAIT)
      K = instr(1,[F:FTR_]LISFIC,'.'+EXT)
      If K
       TRAIT(NBTRAIT) = left$([FTR_]LISFIC,K-1)
      Endif
     Endif
    Endif
   Next FTR_
   Close Local File [FTR_]
  Else
   Call SYSTEME2('','lsadx -a'-nomap-'"'+FICBASE+'"'-EXT,'',NBTRAIT,TRAIT) From ORDSYS
  Endif
 When 1       : # C'est un fichier normal
  NBTRAIT  = 1
  # SBA FQ92041 - US1927
  #Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT) From PATCH
  # ajout
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
    Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT) From PATCH
  Endif
 When Default : # Ca n'existe pas
  Return
Endcase

If INTEG=2
 Gosub VERIF
 If !OK : End : Endif
Endif

If !GSERVEUR
 Call TEMPON("L") From GESECRAN
 Call OUVRE_TRACE(mess(138,10703,1)-ctrans(FIC_TRACE,"\","/")) From LECFIC : # Intégration mise à jour
Endif
SAVSERV = GSERVEUR
GSERVEUR = 1 : # Pour ne pas avoir les messages de validation
Onerrgo ERREUR

If NBTRAIT=1
 FIC_TRACE = TRAIT(1)
Elsif NBTRAIT>0
 FIC_TRACE = "fic_"+mid$(TRAIT(1),07,04)+"_"+mid$(TRAIT(NBTRAIT),07,04)
Else
 Call ECR_TRACE("|"+mess(139,10703,1)-FICBASE,0) From GESECRAN
# Pas de mise à jour dans le répertoire
Endif

For P=1 To NBTRAIT

 PROGRAMME = ""
 NBCOM     = 0
 # SBA FQ92041 - US1927
# On ajoute le cas ou le fichier provient du poste client
 If(FICCLI<>"")
   FICPATCH = FICBASE
 Else
  If left$(FICBASE,2)="#@"
    FICPATCH = filpath(right$(FICBASE,3),TRAIT(P),EXT,"","","#")
  Else
    FICPATCH = filpath(FICBASE,TRAIT(P),EXT)
  Endif
 Endif
 If filinfo(FICPATCH,0)<0 : # Il aurait pu disparaître!!
   Call ECR_TRACE("|"+ctrans(FICPATCH,"\","/")+"|"-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 Else
    Gosub INTEGRE
 Endif
 Close Local File
Next P

Openi
Onerrgo
GSERVEUR = SAVSERV
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
End

$DECLARE
Local Shortint MAXFIL : MAXFIL = 1000
Local Integer D , I , J , K , L , OK , TYPENR
Local Char    CHAMP(255)(1..50)
Local Integer ER , STAT
Local Char    ERFIC(250)
Local Char    TYPOBJ(5) , NOMOBJ(80) , IDENT(50) , APPLI(10)
Local Char    VARIA(10) , VALEUR(250) , LAN(GLONLAN)
Local Integer DIME , TYP , IND , NEWOBJ , NEWZON , NUMACT , NBENR
Local Integer NBLAN , NUMERO , PREM
Local Char    LANGUE(GLONLAN)(1..50) , TEXTE(250)(1..50)
Local Char    SAVLAN(GLONLAN)
Local Integer NBZ , NBI
Local Char    ZONE(10)(1..200) , INDEX(10)(1..30)
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVPOS , SAVSERV
Local Integer NLANP
Local Char    LANPATCH(GLONLAN)(1..50)
Local Integer OKLAN(1..50)
Local Integer NBACT
Local Char    ACTIV(GLONACV)(1..50)
Local Integer NBCLE , I1 , I2
Local Char    CLE(10)(1..8) , CHAINE(250) , SCHAINE(250)
Local Char    FICSRC(250) , FICOLD(250)
Local Libelle LIBEL
Local Char    REP(10) , EXT1(10) , EXT2(10)
Local Integer VERSION
Local Integer TYPFIC , NBTRAIT
Local Char    FICPATCH(250) , FIC_TRACE(250)
Local Char    TRAIT(200)(1..500), PATH(80) , EXT(3)
Local Integer P , PNUM
Local Char    PROGRAMME(GLONADC)
Local Integer NBPROG
Local Char    COMMENT(80)
Local Integer NB , NOCT
Local Libelle BUFFER(1..1000)
Local Integer NUMTXT
Local Integer OKOBJ , MODOBJ
Local Char    OLDACT(GLONACV)
Local Integer LONG
Local Char    CHAP(5)
Local Char    FIC(20)

Local Char    FICPATNAM(250), WPAT(4),WSEP(1),WCOMMENT(50)
Local Char    TTXT(20) (1..20)
Local Integer WPATNUML, IPAT , NBTXT , WI , MINPAT, MAXPAT
Local Integer PATNUML (1..20)
Local Integer PATMNTD (1..20)
Local Integer PATMNTF (1..20)

Local Integer RANG , RANG1 , RANG2
Local Char    RUBAVT(GLONRUB) , RUBAPR(GLONRUB)
Local Integer EXISTE
Local Char    ACTION(20) , MESSA(80)
Local Integer NBLIG , NBCOM
Local Char    LIG64(64)
Local Integer OKINT

Global Decimal GCOEFTAB : GCOEFTAB = 0.5

Local Char     MACHINE(GDIMFIC) , MACFIC(GDIMFIC)

Return

###################################################################
## Intégration d'un fichier
###################################################################
##*****************************************************************#
# SBA FQ92041 - US1927
# Modification de la trace pour prendre en compte le bon nom de fichier
$INTEGRE
# SBA FQ92041 - US1927
# récupération du nom de fichier pour l'affichage de la trace
Local Char W_FICTRA(GDIMFIC)
If(FICCLI<>"")
  W_FICTRA=FICCLI
Else
  W_FICTRA=FICPATCH
Endif
# SBA fin
ER = 0
For D=1 To NBDOS
 APPLI = DOSSIER(D)
 If INTEG=2
  # SBA FQ92041 - US1927
  #Call ECR_TRACE(mess(38,115,1)-"|"+ctrans(FICPATCH,"\","/")+"|",0) From GESECRAN : # Lecture du fichier
  Call ECR_TRACE(mess(38,115,1)-"|"+W_FICTRA+"|",0) From GESECRAN : # Lecture du fichier
  Call ECR_TRACE(mess(31,115,1)-":"-APPLI,0) From GESECRAN : # Intégration dans le dossier
 Else
   # SBA FQ92041 - US1927
  #Call ECR_TRACE(mess(38,115,1)-"|"+ctrans(FICPATCH,"\","/")+"|",0) From GESECRAN : # Lecture du fichier
  Call ECR_TRACE(mess(38,115,1)-"|"+W_FICTRA+"|",0) From GESECRAN : # Lecture du fichier
 Endif
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER = APPLI
 If fstat
  Call ECR_TRACE(APPLI-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
  Goto SUIV_DOS
 Endif
 Gosub OUVFIC

 Openi FICPATCH
 adxifs = ","
 adxirs = chr$(10)

# En-tête
 Gosub LIRE
 If fstat        : ER = 1  : Break
 Elsif TYPENR<>1 : ER = 21 : Break
 Endif
#JASMI - 2017-02-15 - START
  GCURLEG=CHAMP(2)
#JASMI - 2017-02-15 - END
 VERSION = val(CHAMP(3))
 Call ECR_TRACE(mess(40,115,1)-num$(VERSION),0) From GESECRAN : # Version minimum
 NLANP = 0
 While CHAMP(2)<>""
  NLANP += 1
  K = instr(1,CHAMP(2),"/")
  If K
   LANPATCH(NLANP) = left$(CHAMP(2),K-1)
   CHAMP(2)        = right$(CHAMP(2),K+1)
  Else
   LANPATCH(NLANP) = CHAMP(2)
   CHAMP(2)        = ""
  Endif
 Wend
 NBACT = 0
 While CHAMP(4)<>""
  NBACT += 1
  K = instr(1,CHAMP(4),"/")
  If K
   ACTIV(NBACT) = left$(CHAMP(4),K-1)
   CHAMP(4)     = right$(CHAMP(4),K+1)
  Else
   ACTIV(NBACT) = CHAMP(4)
   CHAMP(4)     = ""
  Endif
 Wend
 If INTEG=2

  Read [ADW]ADW0 = "";"";"RELEASE"
  If fstat or val([F:ADW]VALEUR)<VERSION
   Call ECR_TRACE(mess(39,115,1)-":"-num$(VERSION)-"("+[F:ADW]VALEUR+")",1) From GESECRAN
#  Il faut la version...
   Goto SUIV_DOS
  Endif
 Endif

$OBJET
 Gosub LIRE
 If fstat        : ER = 1 : Break
 Elsif TYPENR=8
   # SBA FQ92041 - US1927
  #Call ECR_TRACE(mess(32,115,1)-":"-"|"+FICPATCH+"|",0) From GESECRAN : # Fin de fichier
  Call ECR_TRACE(mess(32,115,1)-":"-"|"+W_FICTRA+"|",0) From GESECRAN : # Fin de fichier
  Call ECR_TRACE("",0) From GESECRAN
  Openi
  ACTION = "FIN" : Gosub ACTPROG
 Elsif TYPENR=2
  TYPOBJ = CHAMP(1)
  NOMOBJ = vireblc(format$("K:80c",CHAMP(2)),2)
  OKOBJ = 1
  If INTEG=2 & TYPOBJ="TXT" : README = NOMOBJ : Endif
  If TYPOBJ="CMT"
   Gosub COMMENT From PATCHPAY
  Else
   Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ,0) From GESECRAN
   If INTEG=2
    OKINT = 1
    #47822
    If INTSEL=2 & !find(num$(P)-TYPOBJ-NOMOBJ,TBOBJ(1..NBOBJ)) & TYPOBJ<>"TRT"
      OKINT = 0
    Endif
    If OKINT
     Gosub CHAMP_SPE From PATCHS
     Case TYPOBJ
      When "RUB"   : Gosub RUBRIQUE   From PATCHPAY
      When "VRA"   : Gosub VARIA      From PATCHPAY
      When "CUM"   : Gosub CUMUL      From PATCHPAY
#      When "VLA"   : Gosub VALEUR     From PATCHPAY
      When "EXO"   : Gosub EXO        From PATCHPAY
      When "DCH"   : Gosub CHARGES    From PATCHPAY
      When "FTD"   : Gosub TDS        From PATCHPAY
      When "ADV"   : Gosub TABDIV     From PATCHPAY
      When "ADP"   : Gosub PARAM      From PATCHPAY
      When "TIM"   : If dim(GTPS)>0 and GTPS
                      Gosub TEMPS      From PATCHPAY
                     Else
                      Gosub FIN_OBJ
                     Endif
      When "TRT"   : Gosub TRAITEMENT From PATCHPAY
                      ACTION = "DEBUT" : Gosub ACTPROG
     Endcase
    Else
     Call ECR_TRACE("---"-mess(153,10703,1),0) From GESECRAN : # Objet non sélectionné
     Gosub FIN_OBJ
    Endif
    If !OKOBJ
     Call ECR_TRACE("---"-mess(MODOBJ,14,1)-":"-mess(58,125,1),0) From GESECRAN
     Gosub FIN_OBJ
    Endif
   Else
    Gosub FIN_OBJ
   Endif
  Endif
  #60727
  #If ER : Break : Endif
  #Goto OBJET
  If ER
   Gosub AFF_ERR
   Raz ER
  Else
   Goto OBJET
  Endif
  # fin 60727
 Else
  ER = 22 : Break
 Endif
 If INTEG=2
  Gosub SUIVI
  Call SETPAR From GENPLAN
 Endif

$SUIV_DOS
 Close Local File
 If INTEG<>2 : Break : Endif
Next D

#60727
Gosub AFF_ERR

#If ER
# Case ER
#  When 1
#   Call ECR_TRACE(mess(35,115,1),1) From GESECRAN : # Fin de fichier anormale
#  When 99
#   Call ECR_TRACE(mess(35,100,1)-":"-ERFIC,1) From GESECRAN : # Erreur transactionnelle
#  When Default
#   Call ECR_TRACE(mess(36,115,1)-"("+num$(ER)+")",1) From GESECRAN : # Structure incorrecte
# Endcase
#Endif

#fin 60727

Openi
Close Local File
Return

#60727
$AFF_ERR
If ER
 Case ER
  When 1
   Call ECR_TRACE(mess(35,115,1),1) From GESECRAN : # Fin de fichier anormale
  When 99
   Call ECR_TRACE(mess(35,100,1)-":"-ERFIC,1) From GESECRAN : # Erreur transactionnelle
  When Default
   Call ECR_TRACE(mess(36,115,1)-"("+num$(ER)+")",1) From GESECRAN : # Structure incorrecte
 Endcase
Endif
Return
# fin 60727

$ACTPROG
If PROGRAMME<>""
 Gosub ACTION From =PROGRAMME
Endif
Return

$OUVFIC
Local File =APPLI+".RUBRIQUE"   [RUB]
Local File =APPLI+".RUBRIQUE"   [RUB2]
Local File =APPLI+".RUBRIQUE"   [RUB3]
Local File =APPLI+".VARIA"      [VRA]
Local File =APPLI+".VARIA"      [VRA2]
Local File =APPLI+".CUMUL"      [CUM]
Local File =APPLI+".CUMUL"      [CUM2]
Local File =APPLI+".VALEUR"     [VLA]
Local File =APPLI+".VALEUR"     [VLA2]
Local File =APPLI+".VALFDR"     [VFD]
Local File =APPLI+".ADOVAL"     [ADW]
Local File =APPLI+".PROFIL"     [PRF]
Local File =APPLI+".CALRUB"     [CRB]
Local File =APPLI+".EXOPAY"     [EXO]
Local File =APPLI+".EXOPAY"     [EXO2]
Local File =APPLI+".DECCHARGE"  [DCH]
Local File =APPLI+".DECCHARGE"  [DCH2]
#JOJAC - 2016-03-22 - REQ114309 US78 - START
# FQ103991 - FILTDS est soumise au code activité KFR
# If func AFNC.ACTIV("KFR")  Then
#Local File =APPLI+".HRFILTDS"     [FTD]
#Local File =APPLI+".HRFILTDS"     [FTD2]
#Endif
#JOJAC - 2016-03-22 - REQ114309 US78 - END
Local File =APPLI+".ATABTAB"    [ADV]
Local File =APPLI+".ATABTAB"    [ADV2]
Local File =APPLI+".ATABDIV"    [ADI]
Local File =APPLI+".ATABDIV"    [ADI2]
Local File =APPLI+".ADOPAR"     [ADP]
Local File =APPLI+".ADOPAR"     [ADP2]
Local File =APPLI+".ADOVAL"     [ADW2]
Local File =APPLI+".ATEXTE"     [ATX]
Local File =APPLI+".ATEXTRA"    [AXX]
Local File =APPLI+".ATABZON"    [ATZ]
If dim(GTPS)>0 and GTPS
 Local File =APPLI+".TIMCOD"     [TIM]
 Local File =APPLI+".TIMCOD"     [TIM2]
Endif
Return

$VERIF
## Vérif de séquentialité pour les patchs standard
Local Char    PTYP(1) , TRAITE(200) , ZTYP(1) , EXTTXT(3)
Local Integer PNUM , PVER , NBTYP , PSTD
Local Char    WWIFS(10) , WWIRS(10) , PLAN(GLONLAN)
Local Char    TTYP(1)(1..MAXFIL)
Local Integer TVER(1..MAXFIL) , DNUM(1..MAXFIL) , FNUM(1..MAXFIL)
Local Integer ERR , ERR2 , MINI , I1_ , I2_ , I3_
ERR = 0 : ERR2 = 0 : OK = 1

Sorta NBTRAIT TRAIT
If !GSERVEUR
 Call OUVRE_TRACE(mess(30,115,1)) From LECFIC : # Intégration de patch
Else
 Call ECR_TRACE(mess(30,115,1),0) From GESECRAN
Endif
PSTD=0
For P=1 To NBTRAIT
 TRAITE = TRAIT(P)
 Raz ZTYP
 I1_ = instr(1,TRAITE,"_")
 If I1_<>0 & left$(TRAITE,3) = "PDP"
  PTYP    = left$(TRAITE,1)           : # premier caractère
  PNUM    = val(seg$(TRAITE,4,I1_-1)) : # caractères 4 à underscore
  PVER    = val(right$(TRAITE,I1_+2)) : # caractères après l'underscore
  PLAN    = ""
  K = find(PTYP,TTYP(1..NBTYP))
  If !K
   NBTYP += 1
   TTYP(NBTYP) = PTYP
   TVER(NBTYP) = PVER
   DNUM(NBTYP) = PNUM
   FNUM(NBTYP) = PNUM
  Else
   If PVER<>TVER(K)
    Call ECR_TRACE(PTYP-":"-mess(55,115,1),1) From GESECRAN
    #  Mélange de patchs de versions différentes
    ERR2 = 1
   Endif
   If PNUM<>FNUM(K)+1
     ########## Il manque des patches dans la tranche
      Call ECR_TRACE(PTYP-":"-mess(56,115,1)-PTYP+ZTYP+"_"+format$("N0:5#",FNUM(K))+"_"
&         +format$("N0:3#",PVER)+"..."+TRAITE,-1) From GESECRAN
      ERR = 1
   Endif
   FNUM(K) = PNUM
  Endif
 Endif
Next P

## Pour tous les patchs, vérif de non intégration précédente
NBTYP = 0
For D=1 To NBDOS
 APPLI = DOSSIER(D)
 Local File =APPLI+".PATCHPDP" [HRPPP]
 MINI = 1
 For P=1 To NBTRAIT
  TRAITE = TRAIT(P)
# A-t-on déjà intégré ce patch ?
  Read [HRPPP]PPP1 = TRAITE
  If !fstat
   Call ECR_TRACE(APPLI-":"-TRAITE-mess(57,115,1),-1) From GESECRAN : # patch déjà intégré
   ERR = 1
  Endif

# Pour les patchs standard
# vérifs complémentaires pour le premier
  I1_ = instr(1,TRAITE,"_")
  If I1_<>0 & left$(TRAITE,3) = "PDP"
   PTYP    = left$(TRAITE,1)           : # premier caractère
   PNUM    = val(seg$(TRAITE,4,I1_-1)) : # caractères 4 à underscore
   PVER    = val(right$(TRAITE,I1_+2)) : # caractères après l'underscore
   PLAN    = ""

   If !find(PTYP,TTYP(1..NBTYP))
    NBTYP += 1
    TTYP(NBTYP) = PTYP
# A-t-on intégré un patch de numéro supérieur ?
    Filter [HRPPP] Where TYP=PTYP & VER=PVER & NUMP>PNUM
    Read [HRPPP]PPP2 First
    If fstat<=2
     Call ECR_TRACE(APPLI-":"-mess(58,115,1)-":"-[F:HRPPP]FIC,-1) From GESECRAN
#     Patch plus récent déjà intégré
     ERR = 1
    Endif
# Y-a-t-il un trou ?
    Filter [HRPPP] Where TYP=PTYP & VER=PVER & NUMP<PNUM
    Read [HRPPP]PPP2 Last
    If fstat<=2 & [F:HRPPP]NUMP<PNUM-1
     Call ECR_TRACE(APPLI-":"-mess(59,115,1)-[F:HRPPP]FIC,0) From GESECRAN
#     Il manque des patchs, le dernier patch intégré est
     ERR = 1
    Endif
# Il faut encore vérifier qu'on n'intègre pas un patch plus ancien que la release
    If PTYP="P" & PNUM<MINI
     Call ECR_TRACE(APPLI-":"-mess(60,115,1)-TRAITE,-1) From GESECRAN
#     Patch normalement inclus dans la version du dossier
     ERR = 1
    Endif
   Endif
  Endif
#  GPOINT = "PPDPVERIF" : Gosub ENTREE From EXEFNC
 Next P
 Close Local File [HRPPP]
Next D

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 If ERR or ERR2
  Call LEC_TRACE From LECFIC
 Endif
Endif
If ERR2
 OK = 0
Elsif ERR
 OK = 1
 If !GSERVEUR
  Call OUINON(mess(61,115,1),OK) From GESECRAN : # Voulez-vous continuer malgré les erreurs
 Endif
 If OK<>2 : OK = 0 : Endif
Else
 OK = 1
Endif
Return

$ERREUR
Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)+"\"+errm) From GESECRAN
Resume

$SUIVI
Local File =APPLI+".PATCHPDP"    [HRPPP]
Local File =APPLI+".PATCHPDPOBJ" [PPO]
Read [HRPPP]PPP0 Last
If fstat>2
 PNUM = 1
Else
 PNUM = [F:HRPPP]NUM+1
Endif
Trbegin [HRPPP] , [PPO]
 Raz [F:HRPPP]
 [F:HRPPP]NUM     = PNUM
 [F:HRPPP]FIC     = TRAIT(P)
 [F:HRPPP]DAT     = date$
 [F:HRPPP]USR     = GUSER
 [F:HRPPP]RELEASE = GVERSION

 I1_ = instr(1,TRAIT(P),"_")
 If I1_<>0 & left$(TRAIT(P),3) = "PDP"
  [F:HRPPP]TYP    = left$(TRAIT(P),1)           : # premier caractère
  [F:HRPPP]NUMP   = val(seg$(TRAIT(P),4,I1_-1)) : # caractères 4 à underscore
  [F:HRPPP]PATNUM = val(seg$(TRAIT(P),4,I1_-1)) : # caractères 4 à underscore
  [F:HRPPP]VER    = val(right$(TRAIT(P),I1_+2)) : # caractères après l'underscore
 Endif
 [F:HRPPP]COMMENT = COMMENT
 Write [HRPPP]
 If fstat
  Call FSTA("HRPPP") From GLOCK
 Else
 #Alimentation détail
  I=1
  If INTSEL = 1
   Raz [F:PPO]
   [F:PPO]NUM     = PNUM
   [F:PPO]LIG     = I
   [F:PPO]DAT     = date$
   [F:PPO]USR     = GUSER
   [F:PPO]ALLOBJ  = 2
   [F:PPO]PATNUM  = [F:HRPPP]PATNUM
   Write [PPO]
   If fstat
    Call FSTA("PPO") From GLOCK
   Endif
  Else
   While TBOBJ(I) <> ""
    Raz [F:PPO]
    [F:PPO]NUM     = PNUM
    [F:PPO]LIG     = I
    [F:PPO]DAT     = date$
    [F:PPO]USR     = GUSER
    [F:PPO]ALLOBJ  = 1
    I1_ = instr(1,TBOBJ(I)," ")
    I2_ = instr(I1_+1,TBOBJ(I)," ")
    [F:PPO]OBJ     = seg$(TBOBJ(I),I1_+1,I2_-1) : # caractères après 1er espace et avant 2e espace
    [F:PPO]COD     = right$(TBOBJ(I),I2_+1)     : # caractères après 2e espace
    [F:PPO]PATNUM  = [F:HRPPP]PATNUM
    Write [PPO]
    If fstat
     Call FSTA("PPO") From GLOCK
     Break
    Endif
    I+=1
   Wend
  Endif
 Endif
Commit
Close Local File [HRPPP] , [PPO]
Return

##################################################
## Sous-programmes généraux
##################################################

$LIRE
Raz CHAMP, TYPENR
Rdseq TYPENR,CHAMP
Call DELIMITE(CHAMP) From PATCH
#Infbox num$(TYPENR)+chr$(13)+CHAMP(1)+chr$(13)+CHAMP(2)+chr$(13)+CHAMP(3)
Return

$LIRE_ZONE
Gosub LIRE
Raz VARIA, IND, VALEUR, LAN, DIME, TYP
Case TYPENR
 When 6  : # Fin de fichier
  Return
 When 4  : # Zone normale
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  VALEUR = CHAMP(3)
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  TYP    = evalue("type([F:"+ABR+"]"+VARIA+")")
 When 5 : # Zone texte
  NBLAN = 0
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  TYP    = evalue("type([F:"+ABR+"]"+VARIA+")")
  NUMTXT = val(CHAMP(5))
  CHAP   = CHAMP(6)
  LONG   = val(CHAMP(7))
  While CHAMP(4)<>"***"
   NBLAN += 1
   TEXTE(NBLAN)  = CHAMP(3)
   LANGUE(NBLAN) = CHAMP(4)
   Gosub LIRE
   If fstat
    ER = 1  : Break
   Elsif TYPENR<>5 & TYPENR<>9
    ER = 23 : Break
   Endif
  Wend
 When 9 : # Zone texte AXX
  NBLAN = 0
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = IND+1
  ID1    = CHAMP(5)
  ID2    = CHAMP(6)
  While CHAMP(4)<>"***"
   NBLAN += 1
   TEXTE(NBLAN)  = CHAMP(3)
   LANGUE(NBLAN) = CHAMP(4)
   Gosub LIRE
   If fstat
    ER = 1  : Break
   Elsif TYPENR<>5 & TYPENR<>9
    ER = 23 : Break
   Endif
  Wend
 When Default
  ER = 24 : Return
Endcase
Return

$AFF_ZONE
If TYPENR=4
 Case TYP
  When 1,2,4,5,6,7,8,9
   Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With val(VALEUR)
#JOJAC - 2016-03-22 - REQ114309 US78 - START
  When 525 :# AUUID :  Uuident non importé - FQ103512
#JOJAC - 2016-03-22 - REQ114309 US78 - END
  When Default
   Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With VALEUR
 Endcase
Elsif TYPENR=5
 NUMERO = 0
# On essaye désormais de conserver le même numéro
 L = find([F:ADS]LAN(0),LANGUE(1..NBLAN))
 If L & TEXTE(L)<>"" & NUMTXT<>0
  Read [ATX]NUMERO = [F:ADS]LAN(0);NUMTXT
  If fstat or [F:ATX]TEXTE=TEXTE(L)
   NUMERO = NUMTXT
  Endif
 Endif
 For LL=0 To [F:ADS]NBRLAN-1
  L = find([F:ADS]LAN(LL),LANGUE(1..NBLAN))
  If L
   If NUMERO=0 & TEXTE(L)<>"" : # La première langue qui se présente
    If NUMTXT<>0 & NUMTXT<50000
     Filter [ATX] Where NUMERO<50000
    Elsif NUMTXT<>0 & NUMTXT>=50000
     Filter [ATX] Where NUMERO>=50000
    Endif
    Read [ATX]TEXTE = LANGUE(L);TEXTE(L)
    Filter [ATX]
    If fstat
# On patche dans la zone 0..50000 si le texte d'origine est <50000
     If NUMTXT<>0 & NUMTXT<50000
      Filter [ATX] Where LAN=LANGUE(L) & NUMERO<50000
      Read [ATX]NUMERO Last
      Filter [ATX]
      If fstat>2 : NUMERO = 1 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
# On patche au-delà de 50000 si le texte d'origine est >50000
     Else
      Filter [ATX] Where LAN=LANGUE(L) & NUMERO>50000
      Read [ATX]NUMERO Last
      Filter [ATX]
      If fstat>2 : NUMERO = 50001 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
     Endif
     Raz [F:ATX]
     [F:ATX]LAN    = LANGUE(L)
     [F:ATX]NUMERO = NUMERO
     [F:ATX]TEXTE  = TEXTE(L)
     Gosub INITEXTE
     Write [ATX]
     If fstat
      GOK = 0 : ERFIC = "ATEXTE"-LANGUE(L)-num$(NUMERO) : Break
     Endif
    Else
     NUMERO = [F:ATX]NUMERO
    Endif
   Elsif NUMERO<>0 : # On a déjà attribué un numéro, il faut le respecter
    Read [ATX]NUMERO = LANGUE(L);NUMERO
    If fstat
     Raz [F:ATX]
     [F:ATX]LAN    = LANGUE(L)
     [F:ATX]NUMERO = NUMERO
     [F:ATX]TEXTE  = TEXTE(L)
     Gosub INITEXTE
     Write [ATX]
    Else
     [F:ATX]TEXTE = TEXTE(L)
     Gosub INITEXTE
     Rewrite [ATX]
    Endif
    If fstat
     GOK = 0 : ERFIC = "ATEXTE"-LANGUE(L)-num$(NUMERO) : Break
    Endif
   Endif
  Endif
 Next LL
 Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With NUMERO
Elsif TYPENR=9
 For LL=0 To [F:ADS]NBRLAN-1
  L = find([F:ADS]LAN(LL),[L]LANGUE(1..NBLAN))
  If L
   Read [AXX]AXX0 = FICHIER;VARIA;[L]LANGUE(L);ID1;ID2
   If fstat
    Raz [F:AXX]
    [F:AXX]CODFIC = FICHIER
    [F:AXX]ZONE   = VARIA
    [F:AXX]LANGUE = [L]LANGUE(L)
    [F:AXX]TEXTE  = [L]TEXTE(L)
    [F:AXX]IDENT1 = ID1
    [F:AXX]IDENT2 = ID2
    Write [AXX]
#JASMI - 2017-02-15 - START
#    If fstat
#     GOK = 0 : ERFIC = "ATEXTRA"-[L]LANGUE(L)-num$([L]NUMERO) : Break
#    Endif
   Else
    [F:AXX]TEXTE  = [L]TEXTE(L)
    Rewrite [AXX]
#JASMI - 2017-02-15 - END
   Endif
#JASMI - 2017-02-15 - START
   If fstat
    GOK = 0 : ERFIC = "ATEXTRA"-[L]LANGUE(L)-num$([L]NUMERO) : Break
   Endif
#JASMI - 2017-02-15 - END
  Endif
 Next LL
Endif
Return

$INITEXTE
[F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
If dim([F:ATX]UPDDAT)>0 : [F:ATX]UPDDAT = date$ : Endif
Return

$FIN_OBJ
If find(TYPOBJ,"ADX","TRT","ETA")
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif find(TYPOBJ,"ADB","ETB")
 Rdseq NOCT
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif TYPOBJ="TAB"
 Repeat
  Gosub LIRE
  If TYPENR=3
   Repeat
   Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Break : Endif
  Endif
 Until TYPENR<>3
 If ER : Return : Endif
Endif
If TYPOBJ<>"TAB"
 Repeat
  Gosub LIRE
 Until fstat or TYPENR=7
 If fstat : ER = 25 : Endif
Endif
Return

$FIN_FIC
Repeat
 Gosub LIRE
Until fstat or TYPENR=6
If fstat : ER = 26 : Endif
Return

$SAV_OPENI
SAVIFS = adxifs
SAVIRS = adxirs
SAVPOS = adxseek(0)
Return

$REST_OPENI
adxifs = SAVIFS
adxirs = SAVIRS
Openi FICPATCH , SAVPOS
Return

###################################################################
## Ecran PATCHP
###################################################################
Subprog C_FICHIER(NOMFIC)
Variable Char NOMFIC()

If NOMFIC="" : mkstat=1 : End : Endif
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(30) , OS(10)

Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat=2 : End
Endif
#Call EXISTE(NOMFIC,ER) From ORDSYS
Call EXISTE(REPERT,ER) From ORDSYS
If ER=0
 Call EXISTE(REPERT+".pay",ER) From ORDSYS
 If ER=1
  NOMFIC += ".pay"
 Else
  ER = 0
 Endif
Endif

If ER=0
 GMESSAGE = "|"+REPERT-":"-mess(09,141,1) : # Repertoire inexistant
 mkstat = 2 : End
Endif
End

Subprog S_FICHIER(VALEUR)
Variable Char VALEUR()
#JOJAC - 2016-03-22 - REQ114309 US78 - START
#Call SELFICREP(VALEUR) From SELFICREP
#mkstat = 2
#JOJAC - 2016-03-22 - REQ114309 US78 - END
End

Subprog C_INTEG(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 [M]INTSEL = 0 : Effzo INTSEL : Grizo INTSEL
 #52239
 [M]MAJPRF = 0 : Effzo MAJPRF : Grizo MAJPRF
Else
 If [M]INTEG=1
  [M]INTSEL = 2 : Affzo INTSEL
  #52239
  [M]MAJPRF = 1 : Affzo MAJPRF    :# On ne demande pas la maj des profils par défaut
 Endif
 #52239
 Actzo INTSEL, MAJPRF
Endif
End
