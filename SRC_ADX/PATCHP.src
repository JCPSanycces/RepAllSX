 Call LECFIC("TXT",TEXTE,"txt") From LECFIC
Endif
Return


####################################################################
Subprog PATCH_OLD(FICBASE,INTEG,NBDOS,DOSSIER,README,INTSEL,NBOBJ,TBOBJ,MAJPRF)
####################################################################
Value    Char    FICBASE
Value    Integer INTEG
Value    Integer NBDOS
Value    Char    DOSSIER()(1..)
Variable Char    README()
Value    Integer INTSEL
Value    Integer NBOBJ
Value    Char    TBOBJ()(1..)
Value    Integer MAJPRF

Gosub DECLARE
Local File ADOSSIER [ADS]

If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE = left$(FICBASE,len(FICBASE)-1)
Endif

Call MACHINE(FICBASE,MACHINE,MACFIC) From ORDSYS
Call EXISTE(FICBASE,TYPFIC) From ORDSYS

Case TYPFIC
 When 2       : # C'est un répertoire
  EXT = "pay"
  If MACHINE="#"
   Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+MACFIC+'\*.'+EXT+'"' As [FTR_]
   NBTRAIT = 0
   For [FTR_]
    If pat([F:FTR_]LISFIC,'*.'+EXT)
     NBTRAIT += 1
     If NBTRAIT<=dim(TRAIT)
      K = instr(1,[F:FTR_]LISFIC,'.'+EXT)
      If K
       TRAIT(NBTRAIT) = left$([FTR_]LISFIC,K-1)
      Endif
     Endif
    Endif
   Next FTR_
   Close Local File [FTR_]
  Else
   Call SYSTEME2('','lsadx -a'-nomap-'"'+FICBASE+'"'-EXT,'',NBTRAIT,TRAIT) From ORDSYS
  Endif
 When 1       : # C'est un fichier normal
  NBTRAIT  = 1
  Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT) From PATCH
 When Default : # Ca n'existe pas
  Return
Endcase

If INTEG=2
 Gosub VERIF
 If !OK : End : Endif
Endif

If !GSERVEUR
 Call TEMPON("L") From GESECRAN
 Call OUVRE_TRACE(mess(138,703,1)-ctrans(FIC_TRACE,"\","/")) From LECFIC : # Intégration mise à jour
Endif
SAVSERV = GSERVEUR
GSERVEUR = 1 : # Pour ne pas avoir les messages de validation
Onerrgo ERREUR

If NBTRAIT=1
 FIC_TRACE = TRAIT(1)
Elsif NBTRAIT>0
 FIC_TRACE = "fic_"+mid$(TRAIT(1),07,04)+"_"+mid$(TRAIT(NBTRAIT),07,04)
Else
 Call ECR_TRACE("|"+mess(139,703,1)-FICBASE,0) From GESECRAN
# Pas de mise à jour dans le répertoire
Endif

For P=1 To NBTRAIT

 PROGRAMME = ""
 NBCOM     = 0
 If left$(FICBASE,2)="#@"
  FICPATCH = filpath(right$(FICBASE,3),TRAIT(P),EXT,"","","#")
 Else
  FICPATCH = filpath(FICBASE,TRAIT(P),EXT)
 Endif
 If filinfo(FICPATCH,0)<0 : # Il aurait pu disparaître!!
  Call ECR_TRACE("|"+ctrans(FICPATCH,"\","/")+"|"-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 Else
  Gosub INTEGRE
 Endif
 Close Local File
Next P

Openi
Onerrgo
GSERVEUR = SAVSERV
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
End


# fin sauvegarde réference.

##*****************************************************************#
# SBA FQ92041 - US1927
# sauvegarde référence
#
# Etiquette renommée en _old



$INTEGRE_OLD
ER = 0
For D=1 To NBDOS
 APPLI = DOSSIER(D)
 If INTEG=2
  Call ECR_TRACE(mess(38,115,1)-"|"+ctrans(FICPATCH,"\","/")+"|",0) From GESECRAN : # Lecture du fichier
  Call ECR_TRACE(mess(31,115,1)-":"-APPLI,0) From GESECRAN : # Intégration dans le dossier
 Else
  Call ECR_TRACE(mess(38,115,1)-"|"+ctrans(FICPATCH,"\","/")+"|",0) From GESECRAN : # Lecture du fichier
 Endif
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER = APPLI
 If fstat
  Call ECR_TRACE(APPLI-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
  Goto SUIV_DOS
 Endif
 Gosub OUVFIC

 Openi FICPATCH
 adxifs = ","
 adxirs = chr$(10)

# En-tête
 Gosub LIRE
 If fstat        : ER = 1  : Break
 Elsif TYPENR<>1 : ER = 21 : Break
 Endif
 VERSION = val(CHAMP(3))
 Call ECR_TRACE(mess(40,115,1)-num$(VERSION),0) From GESECRAN : # Version minimum
 NLANP = 0
 While CHAMP(2)<>""
  NLANP += 1
  K = instr(1,CHAMP(2),"/")
  If K
   LANPATCH(NLANP) = left$(CHAMP(2),K-1)
   CHAMP(2)        = right$(CHAMP(2),K+1)
  Else
   LANPATCH(NLANP) = CHAMP(2)
   CHAMP(2)        = ""
  Endif
 Wend
 NBACT = 0
 While CHAMP(4)<>""
  NBACT += 1
  K = instr(1,CHAMP(4),"/")
  If K
   ACTIV(NBACT) = left$(CHAMP(4),K-1)
   CHAMP(4)     = right$(CHAMP(4),K+1)
  Else
   ACTIV(NBACT) = CHAMP(4)
   CHAMP(4)     = ""
  Endif
 Wend
 If INTEG=2

  Read [ADW]ADW0 = "";"";"RELEASE"
  If fstat or val([F:ADW]VALEUR)<VERSION
   Call ECR_TRACE(mess(39,115,1)-":"-num$(VERSION)-"("+[F:ADW]VALEUR+")",1) From GESECRAN
#  Il faut la version...
   Goto SUIV_DOS
  Endif
 Endif

$OBJET_OLD
 Gosub LIRE
 If fstat        : ER = 1 : Break
 Elsif TYPENR=8
  Call ECR_TRACE(mess(32,115,1)-":"-"|"+FICPATCH+"|",0) From GESECRAN : # Fin de fichier
  Call ECR_TRACE("",0) From GESECRAN
  Openi
  ACTION = "FIN" : Gosub ACTPROG
 Elsif TYPENR=2
  TYPOBJ = CHAMP(1)
  #43436
  #NOMOBJ = vireblc(format$("KT:80X",CHAMP(2)),2)
  NOMOBJ = vireblc(format$("K:80c",CHAMP(2)),2)
  OKOBJ = 1
  If INTEG=2 & TYPOBJ="TXT" : README = NOMOBJ : Endif
  If TYPOBJ="CMT"
   Gosub COMMENT From PATCHPAY
  Else
   Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ,0) From GESECRAN
   If INTEG=2
    OKINT = 1
    #47822
    If INTSEL=2 & !find(num$(P)-TYPOBJ-NOMOBJ,TBOBJ(1..NBOBJ)) & TYPOBJ<>"TRT"
      OKINT = 0
    Endif
    If OKINT
     Gosub CHAMP_SPE From PATCHS
     Case TYPOBJ
      When "RUB"   : Gosub RUBRIQUE   From PATCHPAY
      When "VRA"   : Gosub VARIA      From PATCHPAY
      When "CUM"   : Gosub CUMUL      From PATCHPAY
#      When "VLA"   : Gosub VALEUR     From PATCHPAY
      When "EXO"   : Gosub EXO        From PATCHPAY
      When "DCH"   : Gosub CHARGES    From PATCHPAY
      #When "FTD"   : Gosub TDS        From PATCHPAY    ##**Possibilité retirer en V7**#
      When "ADV"   : Gosub TABDIV     From PATCHPAY
      When "ADP"   : Gosub PARAM      From PATCHPAY
      When "TIM"   : If GTPS
                      Gosub TEMPS      From PATCHPAY
                     Else
                      Gosub FIN_OBJ
                     Endif
      When "TRT"   : Gosub TRAITEMENT From PATCHPAY
                      ACTION = "DEBUT" : Gosub ACTPROG
     Endcase
    Else
     Call ECR_TRACE("---"-mess(153,703,1),0) From GESECRAN : # Objet non sélectionné
     Gosub FIN_OBJ
    Endif
    If !OKOBJ
     Call ECR_TRACE("---"-mess(MODOBJ,14,1)-":"-mess(58,125,1),0) From GESECRAN
     Gosub FIN_OBJ
    Endif
   Else
    Gosub FIN_OBJ
   Endif
  Endif
  #60727
  #If ER : Break : Endif
  #Goto OBJET
  If ER
   Gosub AFF_ERR
   Raz ER
  Else
   Goto OBJET
  Endif
  # fin 60727
 Else
  ER = 22 : Break
 Endif
 If INTEG=2
  Gosub SUIVI
  Call SETPAR From GENPLAN
 Endif

$SUIV_DOS_OLD
 Close Local File
 If INTEG<>2 : Break : Endif
Next D

#60727
Gosub AFF_ERR

#If ER
# Case ER
#  When 1
#   Call ECR_TRACE(mess(35,115,1),1) From GESECRAN : # Fin de fichier anormale
#  When 99
#   Call ECR_TRACE(mess(35,100,1)-":"-ERFIC,1) From GESECRAN : # Erreur transactionnelle
#  When Default
#   Call ECR_TRACE(mess(36,115,1)-"("+num$(ER)+")",1) From GESECRAN : # Structure incorrecte
# Endcase
#Endif

#fin 60727

Openi
Close Local File
Return

# fin sauvegarde réference.
