#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------Standard Events-------------------
#---------------------------------------------------------------
$AREAD_BEFORE

#  #--Because AREAD triggers propagate accessors
#  #  if used as a collection of other class and called throught a method other then AREAD from that class
#  this.setAccessorEnabled = 0

Return
#---------------------------------------------------------------
$AREAD_AFTER
Local File TABUNIT      [TUNSAU]
Local File TABCUR       [TCU]

  Gosub SET_CURLEG From SVCRINVCND_PROPERTIES

  this.CUR_DECNBR = 0
  Read [F:TCU]TCU0=this.CUR
  If fstat : Raz [F:TCU] : Endif
  this.CUR_DECNBR = [F:TCU]DECNBR

  this.SAU_UOMDEC = 0
  Read [TUNSAU]TUN0=this.SAU
  If fstat : Raz [F:TUNSAU] : Endif
  this.SAU_UOMDEC = [F:TUNSAU]UOMDEC

  Case this.VCRTYP
    When 10 : #--Normal orders
              Local File SORDER [SOH]

              Read [F:SOH]SOH0=this.VCRNUMORI
              If fstat : Raz [F:SOH] : Endif

              this.DOCDAT = [F:SOH]ORDDAT
  Endcase

#  #--Because AREAD triggers propagate accessors
#  #  if used as a collection of other class and called throught a method other then AREAD from that class
#  this.setAccessorEnabled = 1

Return
#---------------------------------------------------------------
$AINSERT_CONTROL_BEFORE

  #--Eventually dispatch the total percentage
  Gosub _DISPATCH_TOTALLINES_INVPERCENT From SVCRINVCND_METHODS
  #--Make sure that all header and lines propeties are having the same values
  #--Only for those located the header interface class
  #TODO CPO

Return
#---------------------------------------------------------------
$AUPDATE_CONTROL_BEFORE

  #--Eventually dispatch the total percentage
  Gosub _DISPATCH_TOTALLINES_INVPERCENT From SVCRINVCND_METHODS
  #--Make sure that all header and lines propeties are having the same values
  #--Only for those located the header interface class
  #TODO

Return
#---------------------------------------------------------------
$ACONTROL

  Gosub ACONTROL_EXIST_DOCORI
  #--
  Gosub ACONTROL_CHECK_TOTALLINES_INVPERCENT
  Gosub ACONTROL_CHECK_TOTALLINES

Return
#-----------------------
$ACONTROL_EXIST_DOCORI

  #--The class can be used for a document line during creation
  #--Throught the SAISVC classic action, the user can modify the schedule before creation
  If this.NOCTL_NUMORI=[V]CST_AYES : Return : Endif

  If this.VCRNUMORI<>AVOID.ACHAR and this.VCRLINORI>0 and
&       ((find(this.VCRTYP,10)>0 and this.VCRSEQORI>0) | (this.VCRTYP<>10 and this.VCRSEQORI=0))
    Case this.VCRTYP
      When 10 : #--Sales Orders
               Gosub ACONTROL_EXIST_SOQ
      When Default
    Endcase
  Endif
Return
#-----------------------
$ACONTROL_EXIST_SOQ
Local File SORDERQ [SOQ]

  Read [SOQ]SOQ0=this.VCRNUMORI;this.VCRLINORI;this.VCRSEQORI
  If fstat<>[V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("VCRNUMORI",mess(461,192,1),[V]CST_AERROR)
    Return
  Endif
Return
#-----------------------
$ACONTROL_CHECK_TOTALLINES_INVPERCENT
Local Decimal WTOTPERCENT
Local Integer ILINE

  #--Sum(%lines)=100%
  For ILINE= 1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(ILINE)<>null and find(this.VCRINVCNDLIN(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTPERCENT += this.VCRINVCNDLIN(ILINE).INVPERCENT
    Endif
  Next
  If WTOTPERCENT<>100
    [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES1(mess(446,192,1),"100")+"<>"+num$(WTOTPERCENT),[V]CST_AERROR)
  Endif

Return
#-----------------------
$ACONTROL_CHECK_TOTALLINES
Local Integer IJL,WEXIST_LINE_OTHER_THEN_TOBEINVOICED,WEXIST_LINE_DIFFERENT_PRICE,WEXIST_LINE_CREDITNOTE
Local Decimal WTOTQTY, WTOTAMTNOT, WTOTAMTATI,WLINE_PRICE
Local Integer WMAXAERROR

#If GUSER="LD" Dbgaff Endif

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  WEXIST_LINE_OTHER_THEN_TOBEINVOICED = [V]CST_ANO
  WEXIST_LINE_DIFFERENT_PRICE         = [V]CST_ANO
  WEXIST_LINE_CREDITNOTE              = [V]CST_ANO
  WPRICE = 0
  For IJL=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTQTY        += this.VCRINVCNDLIN(IJL).INVCNDQTY
      # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
      #WTOTAMTNOT     += this.VCRINVCNDLIN(IJL).INVCNDAMTNOT
      If find(this.VCRINVCNDLIN(IJL).INVCNDSTA, 0,1,4)
          WTOTAMTNOT     += this.VCRINVCNDLIN(IJL).INVCNDAMTNOT
      Endif
      #WTOTAMTATI     += this.VCRINVCNDLIN(IJL).INVCNDAMTATI
      If find(this.VCRINVCNDLIN(IJL).INVCNDSTA, 0,1,4)
          WTOTAMTATI     += this.VCRINVCNDLIN(IJL).INVCNDAMTATI
      Endif
      # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
      If this.PRITYP=2
        If WPRICE<>0 and WPRICE <> this.VCRINVCNDLIN(IJL).DNETPRIATI
          WEXIST_LINE_DIFFERENT_PRICE = [V]CST_AYES
        Else
          WPRICE          = this.VCRINVCNDLIN(IJL).DNETPRIATI
        Endif
      Else
        If WPRICE<>0 and WPRICE <> this.VCRINVCNDLIN(IJL).DNETPRINOT
          WEXIST_LINE_DIFFERENT_PRICE = [V]CST_AYES
        Else
          WPRICE          = this.VCRINVCNDLIN(IJL).DNETPRINOT
        Endif
      Endif
      If this.VCRINVCNDLIN(IJL).INVCNDSTA>1
        WEXIST_LINE_OTHER_THEN_TOBEINVOICED = [V]CST_AYES
      Endif
      If find(this.VCRINVCNDLIN(IJL).INVCNDSTA,3,6)>1
        WEXIST_LINE_CREDITNOTE = [V]CST_AYES
      Endif
    Endif
  Next

  If WTOTQTY<>this.QTY
    [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES2(mess(462,192,1),num$(WTOTQTY),num$(this.QTY)),[V]CST_AERROR)
  Endif
  #--This control can only be done in case of not invoiced/closed lines or if all lines have the same price !

  # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)
  # Si aucune ligne facturée ou si il y a des lignes facturées et aucune différence de prix
  # On contrôle que la somme des montants HT des lignes est bien égale au montant HT de l'entête
  # Il ne faut contrôler que le reste à facturer
  # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)
  If WEXIST_LINE_OTHER_THEN_TOBEINVOICED<>[V]CST_AYES or
&   (WEXIST_LINE_OTHER_THEN_TOBEINVOICED =[V]CST_AYES and WEXIST_LINE_DIFFERENT_PRICE = [V]CST_ANO)
    Case this.PRITYP
      When 1 :#--To update when implementing the report of document modifications
              #--If exist at least on line that is invoiced, this control does not have to be done as it is

              # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)
#              # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#              #WTOTAMT = this.AMTNOT
#              WTOTAMT = this.AMTNOT-arr(this.TOT_INV_QTY*this.NETPRINOT,10^(-this.CUR_DECNBR))
#              # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#              If WTOTAMT = 0
#                WTOTAMT = arr(this.QTY*this.NETPRINOT,10^(-this.CUR_DECNBR))
#              Endif
              # Calcul montant non facturé
              WTOTAMT = this.AMTNOT-arr(this.TOT_INV_QTY*this.NETPRINOT,10^(-this.CUR_DECNBR))
              # Si montant non facturé = 0 et rien n'est facturé on force montant non facturé avec montant total des lignes
              # Pourquoi ??
              If WEXIST_LINE_OTHER_THEN_TOBEINVOICED<>[V]CST_AYES & WTOTAMT = 0
                WTOTAMT = arr(this.QTY*this.NETPRINOT,10^(-this.CUR_DECNBR))
              Endif
              # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)

            #--CPO 06/04/2016 After exchanges with CH and LD
              #If WTOTAMTNOT<> WTOTAMT
              #  [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES2(mess(463,192,1),num$(WTOTAMTNOT),num$(WTOTAMT)),[V]CST_AERROR)
              #Endif
              If abs(WTOTAMTNOT-WTOTAMT)<>0 and abs(WTOTAMTNOT-WTOTAMT)>= 10^(-this.CUR_DECNBR)
                WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
                [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES2(mess(463,192,1),num$(WTOTAMTNOT),num$(WTOTAMT)),[V]CST_AWARNING))
              Endif
              #--
      When 2 :#--To update when implementing the report of document modifications
              #--If exist at least on line that is invoiced, this control does not have to be done as it is

              # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)
#              # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#              #WTOTAMT = this.AMTATI
#              WTOTAMT = this.AMTATI-arr(this.TOT_INV_QTY*this.NETPRIATI,10^(-this.CUR_DECNBR))
#              # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#              If WTOTAMT = 0
#                WTOTAMT = arr(this.QTY*this.NETPRIATI,10^(-this.CUR_DECNBR))
#              Endif
              # Calcul montant non facturé
              WTOTAMT = this.AMTATI-arr(this.TOT_INV_QTY*this.NETPRIATI,10^(-this.CUR_DECNBR))
              # Si montant non facturé = 0 et rien n'est facturé on force montant non facturé avec montant total des lignes
              # Pourquoi ??
              If WEXIST_LINE_OTHER_THEN_TOBEINVOICED<>[V]CST_AYES & WTOTAMT = 0
                WTOTAMT = arr(this.QTY*this.NETPRIATI,10^(-this.CUR_DECNBR))
              Endif
              # 107888 : Scheduled invoices : X3-6337 (LD:27/10/16)

              #--CPO 06/04/2016 After exchanges with CH and LD
              #If WTOTAMTATI<>WTOTAMT
              #  [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES2(mess(464,192,1),num$(WTOTAMTATI),num$(WTOTAMT)),[V]CST_AERROR)
              #Endif
              If abs(WTOTAMTNOT-WTOTAMT)<>0 and abs(WTOTAMTATI-WTOTAMT)>= 10^(-this.CUR_DECNBR)
                WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
                [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES2(mess(463,192,1),num$(WTOTAMTATI),num$(WTOTAMT)),[V]CST_AWARNING))
              Endif
              #--
    Endcase
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
#----------------------- EVENTS : COLLECTIONS
$VCRINVCNDLIN_AREAD_BEFORE

  #--In order to prevent executing the propagates if instance part of another class and read throught aread from a different method
  this.IS_PROP_CHG=[V]CST_AYES

Return
#-----------------------
$VCRINVCNDLIN_AREAD_AFTER
  #--To prevent using the subclass TABINVCND stand alone
  this.HASRIGHTHEAD=[V]CST_AYES

  #--In order to prevent executing the propagates if instance part of another class and read throught aread from a different method
  this.IS_PROP_CHG=[V]CST_ANO

  #--No modification on lines having a status different than "To be invoiced"
  If this.INVCNDSTA>1 : Return : Endif

Return
#-----------------------
$VCRINVCNDLIN_ACONTROL

  #--The line has to have the same values for the key
  If this.VCRTYP<>this.APARENT.VCRTYP or this.VCRNUMORI<>this.APARENT.VCRNUMORI
& or this.VCRLINORI<>this.APARENT.VCRLINORI or this.VCRSEQORI<>this.APARENT.VCRSEQORI
    [L]ASTATUS = this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(450,192,1),num$(this.VCRINVCNDLIN))-":"-mess(451,192,1),[V]CST_AERROR)
  Endif

  Gosub VCRINVCNDLIN_CONTROL_QTY
  Gosub VCRINVCNDLIN_CONTROL_AMOUNT
Return
#---------------------------------------------------------------
$VCRINVCNDLIN_CONTROL_QTY
  #--No control if invoice schedule without quantity
  If this.APARENT.QTY = 0 : Return : Endif
  #--Quantities have to be filled in case of 'Facturation avancement'
  Case this.INVCNDSTA
    When 0,1 : #--"Not invoiced"
      If this.INVCNDQTY<=0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDQTY",mess(465,192,1),[V]CST_AERROR)
      Endif
    When 2,3,4 :
    When 5 : #TODO #--'On invoice'
    When 6 : #TODO #--'On credit note'
    When Default :
  Endcase
Return
#---------------------------------------------------------------
$VCRINVCNDLIN_CONTROL_AMOUNT
  #--At least one value has to be filled

# 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#  If this.APARENT.PRITYP=2
#    #-- '+Vat prices/amount have to be filled'
#    If this.APARENT.AMTATI<>0 and this.DNETPRIATI=0 and this.INVCNDAMTATI=0
#      [L]ASTATUS = fmet this.ASETERROR("",mess(466,192,1),[V]CST_AERROR)
#    Endif
#    #--For "To be invoiced" schedule lines, the amount has ot equal the quantity*price
#    If arr(this.INVCNDQTY*this.DNETPRIATI,10^-this.APARENT.CUR_DECNBR)<>this.INVCNDAMTATI
#      [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTATI",mess(468,192,1),[V]CST_AERROR)
#    Endif
#  Else
#    #-- -Vat prices/amount have to be filled
#    If this.APARENT.AMTNOT<>0 and this.DNETPRINOT=0 and this.INVCNDAMTNOT=0
#      [L]ASTATUS = fmet this.ASETERROR("",mess(467,192,1),[V]CST_AERROR)
#    Endif
#    #--For "To be invoiced" schedule lines, the amount has ot equal the quantity*price
#    If arr(this.INVCNDQTY*this.DNETPRINOT,10^-this.APARENT.CUR_DECNBR)<>this.INVCNDAMTNOT
#      [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTNOT",mess(469,192,1),[V]CST_AERROR)
#    Endif
#  Endif
  Case this.INVCNDSTA
    When 0,1 : #--"Not invoiced"
      If this.APARENT.PRITYP=2
        #-- '+Vat prices/amount have to be filled'
        If this.APARENT.AMTATI<>0 and this.DNETPRIATI=0 and this.INVCNDAMTATI=0
          [L]ASTATUS = fmet this.ASETERROR("",mess(466,192,1),[V]CST_AERROR)
        Endif
        #--For "To be invoiced" schedule lines, the amount has ot equal the quantity*price
        If arr(this.INVCNDQTY*this.DNETPRIATI,10^-this.APARENT.CUR_DECNBR)<>this.INVCNDAMTATI
          [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTATI",mess(468,192,1),[V]CST_AERROR)
        Endif
      Else
        #-- -Vat prices/amount have to be filled
        If this.APARENT.AMTNOT<>0 and this.DNETPRINOT=0 and this.INVCNDAMTNOT=0
          [L]ASTATUS = fmet this.ASETERROR("",mess(467,192,1),[V]CST_AERROR)
        Endif
        #--For "To be invoiced" schedule lines, the amount has ot equal the quantity*price
        If arr(this.INVCNDQTY*this.DNETPRINOT,10^-this.APARENT.CUR_DECNBR)<>this.INVCNDAMTNOT
          [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTNOT",mess(469,192,1),[V]CST_AERROR)
        Endif
      Endif
    When 2,3,4 : #TODO #-- Invoiced/Credit note/Closed
    When 5 : #TODO #--'On invoice'
    When 6 : #TODO #--'On credit note'
    When Default :
  Endcase
# 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)

Return
#---------------------------------------------------------------
$VCRINVCNDLIN_ADELLINE_BEFORE
Local Integer LCONTROL, POSCONTROL

 If ALINE<>[V]CST_ALASTPOS
   If ALINE=[V]CST_AFIRSTPOS
     LCONTROL=1
   Else
     LCONTROL=ALINE
   Endif
   POSCONTROL=fmet this.AGETINDBYLINE("VCRINVCNDLIN",LCONTROL)
   If POSCONTROL>0
     # Here you can control the properties of this.COLLECT(POSCONTROL) to decide if the insertion can be done
     #--Deletion is forbidden if status is "Invoiced"/"Invoiced by credit note"/"Closed"
     #--Also if 'On invoice'/'On credit note'
     # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)
     # Deletion is possible when status is "Closed"
     #If find(this.VCRINVCNDLIN(POSCONTROL).INVCNDSTA,2,3,4,5,6)>0
     If find(this.VCRINVCNDLIN(POSCONTROL).INVCNDSTA,2,3,5,6)>0
     # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)
       [L]ASTATUS = fmet this.ASETERROR("INVCNDSTA",func AFNC.MES1(mess(470,192,1),mess(1,2419,1)),[V]CST_AERROR)
     Endif
   Else
     # The position sent is not valid, raise an error or ignore
   Endif
 Else
     # This case is not possible because this position refers to a position for a line addition
 Endif

Return
#-----------------------
$VCRINVCNDLIN_ADELLINE_AFTER

  #--Deleting is forbidden if status is "Invoiced"/"Invoiced by credit note"/"Closed"
  If   this.snapshot<>null
    If this.snapshot.INVCNDSTA>1 or (this.INVCNDSTA=this.snapshot.INVCNDSTA and find(this.INVCNDSTA, 2,3,4)>0)
      [L]ASTATUS = fmet this.APARENT.ASETERROR("INVCNDSTA",func AFNC.MES1(mess(470,192,1),mess(1,2419,1)),[V]CST_AERROR)
    Endif
  Elsif this.INVCNDSTA>1
      [L]ASTATUS = fmet this.APARENT.ASETERROR("INVCNDSTA",func AFNC.MES1(mess(470,192,1),mess(1,2419,1)),[V]CST_AERROR)
  Endif

Return
#-----------------------
$VCRINVCNDLIN_ADDLINE_AFTER
  #--To prevent using the subclass TABINVCND stand alone
  this.HASRIGHTHEAD=[V]CST_AYES
  # To initialize properties of the header
  this.INVCNDSTA = 1 #--'To be invoiced'
  this.MODFLG    = 1 #--'No'
  this.MODDAT    = [0/0/0]
  #VCRTYP+VCRNUMORI+VCRLINORI+VCRSEQORI
  this.VCRTYP       = this.APARENT.VCRTYP
  this.VCRNUMORI    = this.APARENT.VCRNUMORI
  this.VCRLINORI    = this.APARENT.VCRLINORI
  this.VCRSEQORI    = this.APARENT.VCRSEQORI

  this.VCRINVCNDDAT = this.APARENT.VCRINVCNDDAT
  #--Copying all other properties that need to be persisted at line level from the header to the new line
  this.CUR          = this.APARENT.CUR
  this.SAU          = this.APARENT.SAU
  this.DNETPRINOT   = this.APARENT.NETPRINOT
  this.DNETPRIATI   = this.APARENT.NETPRIATI
  #--
  this.VCRINVCNDLIN = max(this.APARENT.VCRINVCNDLIN(1..maxtab(this.APARENT.VCRINVCNDLIN)).VCRINVCNDLIN,0)+1

  Gosub VCRINVCNDLIN_INVPERCENT_INIT
Return
#---------------------------------------------------------------
$VCRINVCNDLIN_INVPERCENT_INIT
Local Decimal WTOTPERCENT
Local Integer ILINE
Local Tinyint WFOUND_UPDLINE

  WFOUND_UPDLINE = [V]CST_AFALSE
  #--Sum(%lines)=100%
  For ILINE= 1 To maxtab(this.APARENT.VCRINVCNDLIN)
    If this.APARENT.VCRINVCNDLIN(ILINE)<>null and find(this.APARENT.VCRINVCNDLIN(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTPERCENT += this.APARENT.VCRINVCNDLIN(ILINE).INVPERCENT
      If this.APARENT.VCRINVCNDLIN(ILINE).ASTALIN=[V]CST_AUPD
        WFOUND_UPDLINE = [V]CST_ATRUE
      Endif
    Endif
  Next
  #--Only in case of existing updated lines
  #--If no such lines, we are in creation mode and this is done elsewhere
  If WFOUND_UPDLINE=[V]CST_ATRUE and WTOTPERCENT>0 and WTOTPERCENT<100
    this.INVPERCENT = 100-WTOTPERCENT #--this should trigger the propagate
  Endif

Return
#---------------------------------------------------------------
$VCRINVCNDLIN_AUPDATE_BEFORE

  #--Update the flag "MODFLG" and the MODDAT properties
  If find(this.APARENT.ASTALIN, [V]CST_ANEW)=0 and this.snapshot<>null
    If    this.snapshot.INVCNDQTY<>this.INVCNDQTY
      this.MODFLG = 3 #--'Quantity'
      this.MODDAT = date$
    Elsif this.APARENT.PRITYP=2 and
&       ((this.snapshot.DNETPRIATI  <> this.DNETPRIATI  ) or
&        (this.snapshot.INVCNDAMTATI<> this.INVCNDAMTATI))
        this.MODFLG = 2 #--'Price/Amount'
        this.MODDAT = date$
    Elsif this.APARENT.PRITYP<>2 and
&       ((this.snapshot.DNETPRINOT  <> this.DNETPRINOT  ) or
&        (this.snapshot.INVCNDAMTNOT<> this.INVCNDAMTNOT))
        this.MODFLG = 2 #--'Price/Amount'
        this.MODDAT = date$
    Endif
  Endif

Return

