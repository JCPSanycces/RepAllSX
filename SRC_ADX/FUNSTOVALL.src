#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# Fonction d'interrogation des allocations matières GPAO - OF (GBIDC1 = "1")
# Fonction d'interrogation des allocations articles VENTES    (GBIDC1 = "2")
# GA 07/09/2005:
# Fonction d'interrogation des allocations matières OrdreSsTr (GBIDC1 = "3")
# le second paramètre est le numéro de pièce
############################################################################
#Call FUNSTOVALL(GBIDC1,"")
Call FUNSTOVALL("1","GAL00061952")
Call IMPSCR From ATRTX3
End
###########################################################################
# FUNSTOVALL  : Interrogation des allocations            LLC - DEC   1998 #
###########################################################################
Subprog FUNSTOVALL(ACTION, WVCRNUM)
Value Char ACTION() 
Value Char WVCRNUM
 
Local Integer L,I 
Local Integer REPONSE 
Local Integer ACTFLG : ACTFLG = 0

If clalev ([F:STA]) <= 0 : Local File STOALL     [STA] : Endif 
If clalev ([F:STO]) <= 0 : Local File STOCK      [STO] : Endif 
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif 
If clalev ([F:SOH]) <= 0 : Local File SORDER     [SOH] : Endif 
If clalev ([F:SCO]) <= 0 : Local File SCOHEAD    [SCO] : Endif : # GA 07/09/2005
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif 
 
Local Mask   STOVALL [STVA]
 
Local Inpbox Mask [STVA]
&     Button mess(248, 198,1), mess(65,123,1)
&     With left$(mess(248,198,1),1), left$(mess(65,123,1),1)
&     Coded GSTABOU+1, GSTAFIN   
&     Titled mess(109,195,1) As [STVA]
#
Local Integer REPONSE, ETABOU(1..GNBBOU) , SAVGOBJET
SAVGOBJET = GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
#
Boxact [STVA] 
#
$SAI_STVA 
Affzo  [STVA] 
Grizo  [M:STVA]10
Grizo  [M:STVA]15

If WVCRNUM <> "" & ACTFLG = 0
    Case ACTION
        When "1":  Read [MFG]MFG0 = WVCRNUM
                   If !fstat 
                       [M:STVA]ORIFCY = [F:MFG]MFGFCY
                       [M:STVA]VCRNUM = [F:MFG]MFGNUM
                       [M:STVA]VCRTYP = 10
                       ACTFLG = 1
                   Endif
        When "2":  Read [SOH]SOH0 = WVCRNUM
                   If !fstat
                       [M:STVA]ORIFCY = [F:SOH]SALFCY
                       [M:STVA]VCRNUM = [F:SOH]SOHNUM
                       [M:STVA]VCRTYP = 2
                       ACTFLG = 1
                   Endif
        When "3":  Read [SCO]SCO0 = WVCRNUM          : # GA 07/09/2005
                   If !fstat
                       [M:STVA]ORIFCY = [F:SCO]POHFCY
                       [M:STVA]VCRNUM = [F:SCO]SCONUM
                       [M:STVA]VCRTYP = 36
                       ACTFLG = 1
                   Endif
    Endcase
    If ACTFLG = 1
        Gosub CHARGE_STVA
    Endif
Endif
ETABOU(GSPE1) = 1 : # Trier
ETABOU(GABAN) = 1 : # Fin
Call SETBOUT(ETABOU) From GESECRAN
#
Boxinp [STVA] Using REPONSE 
Case REPONSE
    When GSTAEDI :   Call PRTSCR("STOVALL","",mess(109,195,1),0,0) From ATRTX3
                     Disable GSTAEDI
                     Goto SAI_STVA
    When GSTABOU+1 : [M:STVA]CURTRI += 1
                     If [M:STVA]CURTRI = 6 : [M:STVA]CURTRI = 1 : Endif
                     Case [M:STVA]CURTRI
                      When 1: Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]ITMREF(indice),
&                                                                        [M:STVA]ALLTYP(indice)
                      When 2: Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]ALLTYP(indice),
&                                                                        [M:STVA]ITMREF(indice)
                      When 3: Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]LOT(indice),
&                                                                        [M:STVA]ITMREF(indice)
                      When 4: Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]LOC(indice),
&                                                                        [M:STVA]ITMREF(indice)
                      When 5: Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]STA(indice),
&                                                                        [M:STVA]ITMREF(indice)
                     Endcase
                     Enable GSTAEDI
                     Goto SAI_STVA
    When GSTAFIN, GSTAESC   : # ben on sort ...   
    When Default   : Goto SAI_STVA
Endcase
#
Boxclr [STVA]
Call RESTBOUT From GESECRAN
OBJET = SAVGOBJET
Close Local Mask [STVA] 
#
End 

###########################################################################
# Chargement du masque de détail des allocations
$CHARGE_STVA

Filter [STA] Where VCRTYP=[M:STVA]VCRTYP & VCRNUM=[M:STVA]VCRNUM
&            Order By Key STA1 
nolign=1 
For [STA] 
   [M:STVA]STOFCY(nolign-1) = [F:STA]STOFCY
   [M:STVA]ITMREF(nolign-1) = [F:STA]ITMREF
   If [F:ITM]ITMREF <> [F:STA]ITMREF : Read [ITM]ITM0=[F:STA]ITMREF : Endif
   #[M:STVA]ITMDES1(nolign-1) = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STVA]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   [M:STVA]STU(nolign-1) = [F:ITM]STU
   Case [F:STA]ALLTYP 
    When 1,4,5 : Case [F:STA]ALLTYP
                       When 1: [M:STVA]ALLTYP(nolign-1) = 2
                       When 4: [M:STVA]ALLTYP(nolign-1) = 3
                       When 5: [M:STVA]ALLTYP(nolign-1) = 1
                   Endcase
                   [M:STVA]ALLQTY(nolign-1) = [F:STA]QTYSTUACT   
                   nolign += 1  
    When 2       : Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU 
                   If fstat = 0                     
                      [M:STVA]ALLTYP(nolign-1) = 4
                      [M:STVA]ALLQTY(nolign-1) = [F:STA]QTYSTUACT                    
                      [M:STVA]LOT(nolign-1)    = [F:STO]LOT 
                      [M:STVA]LOC(nolign-1)    = [F:STO]LOC  
                      [M:STVA]STA(nolign-1)    = [F:STO]STA  
                      nolign += 1 
                   Endif 
   Endcase 
   If nolign = 200 : Break : Endif  
Next 
Filter [STA] 
 
L=nolign 
[M:STVA]NBLIG  = L-1 
[M:STVA]CURTRI = 1
Sorta [M:STVA]NBLIG [M:STVA]NBLIG Order By [M:STVA]ITMREF(indice), [M:STVA]ALLTYP(indice)
Enable GSTAEDI
Affzo [M:STVA]
#
Return

###########################################################################
# ETIQUETTES                                                              #
###########################################################################

########################################
Subprog AV_VCRTYP(VALEUR)
Variable Integer VALEUR
Case GBIDC1
    When "1","MFG":  VALEUR = 10
    When "2","SOH":  VALEUR = 2
    When "3","SCO":  VALEUR = 36   : # GA 07/09/2005
Endcase
End

########################################
Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()
#
Case GBIDC1
    When "1","MFG": Filter [MFG] Where [F:MFG]MFGSTA=1 & [F:MFG]ALLSTA>1 & 
&                                      [F:MFG]MFGTRKFLG < 5 
                    Call SELECT("MFG","",VALEUR,"") From SELOBJ
                    Filter [MFG] 
    When "2","SOH":  GORDCAT = 4
                     Filter [SOH] Where [F:SOH]ORDSTA<>2 & [F:SOH]ALLSTA<>1 &
&                                       [F:SOH]DLVSTA<>3 & [F:SOH]INVSTA<>3
# Les cdes doivent être non soldées, allouées, non livrées ou facturées totalement
                     Call SELECT("SOH","",VALEUR,"") From SELOBJ 
                     Filter [SOH]     
# GA 07/09/2005
    When "3","SCO": Filter [SCO] Where [F:SCO]SCOSTA=1 & [F:SCO]ALLSTA>1 & 
&                                      [F:SCO]SCOTRKFLG < 5 
                    Call SELECT("SCO","",VALEUR,"") From SELOBJ
                    Filter [SCO] 
Endcase
#
End

########################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
#
Case GBIDC1
    When "1","MFG":  If [F:MFG]MFGNUM <> VALEUR
                         Read [MFG]MFG0 = VALEUR
                         If fstat : mkstat = 2 : Endif
                     Endif
                     [M:STVA]ORIFCY = [F:MFG]MFGFCY
    When "2","SOH":  If [F:SOH]SOHNUM <> VALEUR
                         Read [SOH]SOH0 = VALEUR
                         If fstat : mkstat = 2 : Endif
                     Endif
                    [M:STVA]ORIFCY = [F:SOH]SALFCY
# GA 07/09/2005
    When "3","SCO":  If [F:SCO]SCONUM <> VALEUR
                         Read [SCO]SCO0 = VALEUR
                         If fstat : mkstat = 2 : Endif
                     Endif
                     [M:STVA]ORIFCY = [F:SCO]POHFCY
Endcase
[M:STVA]VCRNUM = VALEUR
Affzo [M:STVA]ORIFCY
Gosub CHARGE_STVA
#
End


