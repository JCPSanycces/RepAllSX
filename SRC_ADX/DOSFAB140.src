#<AdxTL>@(#)8.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
$ACTION
Case ACTION
 When "SAISIE"      : Gosub SAISIE
 When "DESTINATION" : Gosub DESTINATION
 When "IMPRIMANTE"  : Gosub IMPRIMANTE
 When "EXEC"        : Gosub EXEC
Endcase
Return


##################################
$SAISIE
If GFONC1 = "FUNMAUT" : [M:RPT]IMPRIME = 2 : OK = 0 : Endif
Return

##################################
$DESTINATION
Return

######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local Integer I,J,WOK
Local Char    WOLDETAT, WNOMETAT, WETAT
Local Char    CHART  :  CHART=chr$(1)

# le dossier de fabrication ne peut être lancé que depuis une fonction de création d'OF et donc avec
# une transaction d' OF en ligne
# chaque état appartenant au dossier de fabrication peut par contre être lancé depuis le menu impression
If !clalev([F:MTS]) : GOK = 0 : End : Endif

#On sauvegarde le nom de l'état principal (normalement ce doit être DOSFAB)
WOLDETAT = [F:ARP]RPTCOD

#il faut retrouver le paramètre porteur du nom de l'état à lancer
Raz WOK
For I = 0 To NBPAR-1
    If left$(PARAMETRE(I),9)="__REPORT="
         J=instr(1,PARAMETRE(I),"=")
         If J
            If mid$(PARAMETRE(I),J+1,1)=CHART
              WETAT = right$(PARAMETRE(I),J+2)
            Else
              WETAT = right$(PARAMETRE(I),J+1)
            Endif
            WOK = 1
         Endif
         Break 
    Endif
Next I
If ! WOK : GOK = 0 : End : Endif
Raz WNOMETAT
J=instr(1,WETAT,".")
If J
   WNOMETAT = left$(WETAT,J-1)
Endif
Gosub EXEC
Read [F:ARP]ARP0 = WOLDETAT
If fstat : Raz [F:ARP] : GOK = 0 : End : Endif
End



####################################
$IMPRIMANTE
If GFONC1 <> "FUNMAUT" : Return : Endif

#il faut retrouver le paramètre porteur du nom de l'imprimante pour le surcharger
Local Integer I,WOK
Raz WOK
For I = 1 To NBPAR
    If left$(PARAMETRE(I),13)="_PrinterName="
       PARAMETRE(I) = "_PrinterName="+chr$(1)+GDEFIMP
       WOK = 1 
       Break 
    Endif
Next I
# llc 11.02 il n'y a plus ce paramètre
# sr Si on n' a pas trouvé le paramètre on le rajoute
If  !WOK 
    NBPAR += 1
    PARAMETRE(I) = "_PrinterName="+chr$(1)+GDEFIMP
Endif

#sr Il faut retouver le paramètyre porteur de novisible
Raz WOK
For I = 1 To NBPAR
    If left$(PARAMETRE(I),13)="_NoVisible="
       PARAMETRE(I) = "_NoVisible="+chr$(1)+"1"
       WOK = 1 
       Break 
    Endif
Next I
# sr Si on n' a pas trouvé le paramètre on le rajoute
If  !WOK 
    NBPAR += 1
    PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
Endif


[M:RPT]IMPRIMANTE = GDEFIMP
Return

######################################
$EXEC
Local Integer WNBR, I, J,WOK

If clalev([F:TFO])=0 : Local File TABFOR   [TFO] : Endif 

Raz WOK
Case WNOMETAT
      When "BONTRV" : If [F:MTS]LABTIK = 2 
                             If [F:MTS]LABTIKNBR <> ""  
                                  Read [F:TFO]TFO0 = 8;[F:MTS]LABTIKNBR
                                  If fstat WNBR = 1
                                  Else  WNBR = int(evalue([F:TFO]FORFOR))
                                  Endif
                              Else WNBR = 1
                              Endif    
                              WOK = 1
                          Else : GOK = 0 
                          Endif
      When  "BSM"  :  If [F:MTS]PICLIS = 2 
                              If [F:MTS]PICLISNBR <> ""  
                                  Read [F:TFO]TFO0 = 8;[F:MTS]PICLISNBR
                                  If fstat WNBR = 1
                                  Else  WNBR = int(evalue([F:TFO]FORFOR))
                                      Endif
                                  Else WNBR = 1
                              Endif    
                              WOK = 1
                          Else : GOK = 0 
                          Endif
      When "FICHSUI" : If [F:MTS]ROUSHE = 2
                               If [F:MTS]ROUSHENBR <> ""  
                                  Read [F:TFO]TFO0 = 8;[F:MTS]ROUSHENBR
                                  If fstat WNBR = 1
                                  Else  WNBR = int(evalue([F:TFO]FORFOR))
                                  Endif
                              Else WNBR = 1
                              Endif    
                              WOK = 1
                           Else : GOK = 0 
                           Endif
      When "RECETTE" : If [F:MTS]MFGTIK = 2 
                              If [F:MTS]MFGTIKNBR <> ""  
                                  Read [F:TFO]TFO0 = 8;[F:MTS]MFGTIKNBR
                                  If fstat WNBR = 1
                                  Else  WNBR = int(evalue([F:TFO]FORFOR))
                                  Endif
                              Else WNBR = 1
                              Endif    
                              WOK = 1
                           Else : GOK = 0 
                           Endif
      When "FICHTEC" : If [F:MTS]TECCRD = 2 
                              If [F:MTS]TECCRDNBR <> ""  
                                  Read [F:TFO]TFO0 = 8;[F:MTS]TECCRDNBR
                                  If fstat WNBR = 1
                                  Else  WNBR = int(evalue([F:TFO]FORFOR))
                                  Endif
                              Else WNBR = 1
                              Endif    
                              WOK = 1
                           Else : GOK = 0 
                           Endif
Endcase
If GOK & WOK
   Read [F:ARP]ARP0 = WNOMETAT
   If fstat : GOK = 0 : Return : Endif 
   [M:RPT]RPTCOD = WNOMETAT
   [M:RPT]ETAT   = WNOMETAT
   #il faut retrouver le paramètre porteur du nom de X3ETA
   For I = 1 To NBPAR
       If left$(PARAMETRE(I),6)="X3ETA="
          PARAMETRE(I) = "X3ETA="+[F:ARP]RPTCOD
          Break 
       Endif
   Next I
  #il faut retrouver le paramètre porteur du nom de X3TIT
   For I = 1 To NBPAR
       If left$(PARAMETRE(I),6)="X3TIT="
          PARAMETRE(I) = "X3TIT="+[F:ARP]DES 
          Break 
       Endif
   Next I
  #il faut retrouver le paramètre porteur du nom de etat
   For I = 1 To NBPAR
       If left$(PARAMETRE(I),5)="etat="
          PARAMETRE(I) = "etat="+[F:ARP]RPTCOD 
          Break 
       Endif
   Next I
    
   If [F:ARP]PRTDEF <> ""
       Read [F:AIM]AIM0 = [F:ARP]PRTDEF
       If !fstat  
           #il faut retrouver le paramètre porteur du nom de l'imprimante
           For I = 1 To NBPAR
               If left$(PARAMETRE(I),13)="_PrinterName=" 
                  PARAMETRE(I) = "_PrinterName="+chr$(1)+[F:AIM]PRTNAM
                  Break 
               Endif
           Next I
          #il faut retrouver le paramètre porteur du nom du driver
           For I = 1 To NBPAR
               If left$(PARAMETRE(I),15)="_PrinterDriver="
                  PARAMETRE(I) = "_PrinterDriver="+chr$(1)+[F:AIM]PRTDRV
                  Break 
               Endif
           Next I
          #il faut retrouver le paramètre porteur du nom du port
           For I = 1 To NBPAR
               If left$(PARAMETRE(I),13)="_PrinterPort="
                  PARAMETRE(I) = "_PrinterPort="+chr$(1)+[F:AIM]PRTPOR
                  Break 
               Endif
           Next I
        Endif
    Endif
    If [F:ARP]PRTSRV<>""
       Raz WOK 
      #il faut retrouver le paramètre porteur du nom du serveur
       For I = 1 To NBPAR
           If left$(PARAMETRE(I),15)="_PrinterServer="
              PARAMETRE(I) = "_PrinterServer="+chr$(1)+[F:ARP]PRTSRV
              WOK = 1  
              Break 
           Endif
       Next I
       # on n'a pas trouvé le praramètre, on le créé 
       If !WOK
         NBPAR += 1
         PARAMETRE(NBPAR) = "_PrinterServer="+chr$(1)+[F:ARP]PRTSRV
       Endif 
   Endif
  #il faut retrouver le paramètre porteur de l'orientation
   For I = 1 To NBPAR
       If left$(PARAMETRE(I),13)="_Orientation="
            If [F:ARP]ORIENT=2
              PARAMETRE(I) = "_Orientation="+chr$(1)+"1"
           Else
              PARAMETRE(I) = "_Orientation="+chr$(1)+"0"
           Endif
           Break 
       Endif
   Next I
   If WNBR>1
       Raz WOK 
      #il faut retrouver le paramètre porteur du nombre de copies
       For I = 1 To NBPAR
           If left$(PARAMETRE(I),15)="_PrinterCopies="
              PARAMETRE(I) = "_PrinterCopies="+chr$(1)+num$(WNBR)
              WOK = 1  
              Break 
           Endif
       Next I
       # on n'a pas trouvé le praramètre, on le créé 
       If !WOK
         NBPAR += 1
         PARAMETRE(NBPAR) = "_PrinterCopies="+chr$(1)+num$(WNBR)
       Endif 
   Endif

# Traitement d'init
   If [F:ARP]TRTINI<>"" & filinfo(filpath("TRT",[F:ARP]TRTINI,"adx"),0)>=0
      GOK = 1
      Call IMPRIME(NBPAR,PARAMETRE) From =[F:ARP]TRTINI
      If GOK<1 : Return: Endif
   Endif 
   
Endif   
Return
