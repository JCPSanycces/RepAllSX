#<AdxTL>@(#)12.0.0.0 $Revision$
###################################################
## Intégration d'un état
###################################################
$ETAT
Local File =DOSSIER(D)+".AREPORT"   [ARP]
Local File =DOSSIER(D)+".AREPORTD"  [ARD]
Local File =DOSSIER(D)+".AREPORTS"  [ARO]
Read [ARP]ARP0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
 Elsif dim([F:ARP]CODACT)>0 & [F:ARP]CODACT>="X" & !find([F:ARP]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_ARP
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ARP
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ARP
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Gosub FIN_ARP
Return

$DEL_ARP
Trbegin [ARP]
 Delete [ARD] Where RPTCOD=[L]NOMOBJ
 Delete [ARO] Where RPTCOD=[L]NOMOBJ
 Delete [ARP] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AREPORT"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ARP",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$FIN_ARP
Close Local File [ARP],[ARD],[ARO]
Return

$TR_ARP
Local Integer ONBPAR , NEWARO
Local Char    OPAR(15)(1..100) , OACS(GLONACS)(1..100)
ONBPAR = 0
Trbegin [ARP] , [ARD] , [ARO]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ARP"   : Gosub ARP1
     When "ARD"   : Gosub ARP2
     When "ARO"   : Gosub ARP3
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ARP",[F:ARP]RPTCOD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$ARP1
FICHIER = "AREPORT" : ABR = "ARP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If find(VARIA,"GRP","ACS","PRTNAT","PRTDEF","PRTOBL","PRTFRM","ENAFLG","PARSEG","EXEBAT","HOR","IMPLIE") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Elsif VARIA="CODZPL" & [F:ARP]CODZPL<>"" and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Elsif VARIA="TRTSPE" & TYPPTC<>3
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ARP]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ARP]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If dim([F:ARP]CODZPL)>0 & [F:ARP]CODZPL<>""
 [F:ARP]GESZPL = 2
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ARP]CREDAT = date$
  [F:ARP]CREUSR = GUSER
  If dim([F:ARP]CRETIM)>0 : [F:ARP]CRETIM = time  : Endif
  [F:ARP]UPDDAT = date$
  [F:ARP]UPDUSR = GUSER
  If dim([F:ARP]UPDTIM)>0 : [F:ARP]UPDTIM = time  : Endif
 Endif
 Write [ARP]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ARP]UPDDAT = date$
  [F:ARP]UPDUSR = GUSER
  If dim([F:ARP]UPDTIM)>0 : [F:ARP]UPDTIM = time  : Endif
 Endif
 Rewrite [ARP]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AREPORT"-NOMOBJ : Return
Endif
# Effacement des paramètres
For [ARD]ARD0 Where RPTCOD=NOMOBJ & PARACS<>""
 ONBPAR += 1
 OPAR(ONBPAR) = [F:ARD]PARCOD
 OACS(ONBPAR) = [F:ARD]PARACS
Next
Delete [ARD] Where RPTCOD=NOMOBJ
If fstat : GOK = 0 : ER = 99 : ERFIC = "AREPORTD"-NOMOBJ : Endif
Return

$ARP2
FICHIER = "AREPORTD" : ABR = "ARD"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If VARIA="PARCOD"
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
  K = find(VALEUR,OPAR(1..ONBPAR))
  If K
   [F:ARD]PARACS = OACS(K)
  Else
   [F:ARD]PARACS = ""
  Endif
 Elsif DIME>0 & IND+1<=DIME
  If VARIA<>"PARACS" or (VARIA="PARACS" and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0))
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [ARD]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AREPORTD"-NOMOBJ-[F:ARD]PARCOD : Return
Endif
Return

$ARP3
FICHIER = "AREPORTS" : ABR = "ARO"
Read [ARO]ARO0 = NOMOBJ
If fstat
 Raz [F:ARO] : NEWARO = 1
Else
 NEWARO = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  If (VARIA<>"DOSSIER" or [F:ARO]DOSSIER(IND)="")
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWARO
 Write [ARO]
Else
 Rewrite [ARO]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AREPORTS"-NOMOBJ : Return
Endif
Return

$ABORT
Rollback
Return

