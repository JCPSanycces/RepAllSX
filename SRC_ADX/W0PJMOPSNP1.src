#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPSNP1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG From SUBPJMOPSNP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG From SUBPJMOPSNP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BTCMT
mkstat = 0
zoncou = "BTCMT"
If varmode([M]BTCMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTCMT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DDESAXX
mkstat = 0
zoncou = "DDESAXX"
If varinit([M]DDESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DDESAXX(indice),"PJMOPSNPD","DDESAXX",[M:PJSNP0]SNPCOD,num$([M:PJSNP1]SNPSEQ(nolign-1))) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DDESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DDESAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone DEFBAS
mkstat = 0
zoncou = "DEFBAS"
IMPENT = [M]DEFBAS(indice)
WNUM = IMPENT
If varinit([M]DEFBAS,indice)=0
 IMPENT = [V]CST_ANO
Endif
If varmode([M]DEFBAS,indice)=0
 [M]DEFBAS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFBAS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFBAS(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DEFBAS" : GZNUM = 1003764 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DEFBAS(IMPENT) From SUBPJMOPSNP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DEFBAS" : GZNUM = 1003764 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]DEFBAS(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMOPSNP1"
Return

