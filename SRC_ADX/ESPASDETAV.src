#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$SETBOUT

If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return


$OUVRE
Gosub OUVRE_OUT

#Manage Localisations
Call MANAGE_LOCALISATION("ESSPASDETAV") From DIVPAYE

Return

$OUVRE_OUT
#Opening tables and declaring an instance of the main class
If clalev([F:EWID1])      = 0 : Local File ESSWRKEMP    [EWID1]     : Endif
If clalev([F:ESWD2])      = 0 : Local File ESSWRKFLWDET     [ESWD2]     : Endif
Return


$DEBUT
Gosub DEBUT_OUT

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPASDETAVHIDE
Call SHOW_LEGACTCALLS From WESSPASDETAVSHOW

Return

$DEBUT_OUT
Local Char GLOBEML(GLONEML)
nolign = 0

Raz [M:ESPDT]
Read [EWID1]EWID0 = val(PARAM(2))
If fstat : Return : Endif


GLOBEML   = [F:EWID1]REFNUM
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1)

nolign = 1
[M:ESPDT] = [F:EWID1]
[M:ESPDT]NBRPAS = nolign

[M:ESPDT]DEST = PARAM(3)
[M:ESPDT]CHRONO = PARAM(4)

#Style
Gosub DECLARE_EMPSTYLE From ESS_FUNCTIONS

WFILENAME = "WESSEMPPASDETSTYLE_"+GUSER

 Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
  #Indicate changed fields
  If [F:EWID1]WRK = "M"
    WSTYLECODE = "ECCBODC"
    [M:ESPDT]WRKREQ = 2
    Chgstl [M:ESPDT]WRKREQ With "ECCBODC"
    Filter [F:ESWD2] Where UID = [F:EWID1]UID and WRK = "M" and MAIREC <> 2
    For [F:ESWD2]
      If evalue("dim([M:ESPDT]"+[F:ESWD2]FLDNAM+")")>0
        WFIELDNAME = "[M:ESPDT]"+[F:ESWD2]FLDNAM+"(nolign-1)"
        #WFIELDNAME = [F:ESWD2]FLDNAM+"nolign(-1)"
        STYLESTAT+=1
        Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
      Endif
    Next
    Filter [F:ESWD2]
  Elsif [F:EWID1]WRK = "D"
    WSTYLECODE = "ECCBODA"
    [M:ESPDT]WRKREQ = 3
    Chgstl [M:ESPDT]WRKREQ With "ECCBODA"
    Chgstl NBRPAS(nolign-1) With "ECCBODA"
  Elsif [F:EWID1]WRK = "C"
    WSTYLECODE = "ECCBODC"
    [M:ESPDT]WRKREQ = 1
    Chgstl [M:ESPDT]WRKREQ With "ECCBODC"
    Chgstl NBRPAS(nolign-1) With "ECCBODC"
  Endif
  #Close script
  Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

  If STYLESTAT
    #Run script
    Call STYLE_FIELDS() From =WFILENAME
  Endif

Affzo [M:ESPDT]1-99
Return

End
######################################################################################

######################################################################################
## Section automatically added (screen ESSPASDETAV) 07/31/2018 13:05:19 (FRLAA)
######################################################################################
Subprog AM_NBRPAS
End


