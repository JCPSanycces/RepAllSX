 [F:EVT0]CCE20      = [F:GRT]CCE(19)
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:GRT]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:GRT]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:GRT]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:GRT]USRFLDD4
 [F:EVT0]CASHDAT    = [F:CAS]CASHDAT
Return

$ECLATE_NBFLD
 LNBFLD=2
Return

$ECLATE_STATUS
  T_INTNOMZON(0)    = "CASHAMT"
  T_INTNOMZON(1)    = "GRAAMT"
Return

$INFO_EVTINT
 EVT = "GRTCASH"
 LPLN= 6
Return

