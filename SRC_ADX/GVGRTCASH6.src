#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 22 Décembre  2017 14:35:27

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EGRTCASH" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EGRTCASH" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub GRTCASH6
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$GRTCASH6
 #--> Désignation
 [F:EVT0]DES        = [F:GRT]DES
 #--> Menus locaux
 [F:EVT0]GRATYP     = [F:GRT]GRATYP
 [F:EVT0]GRASTA     = [F:GRT]GRASTA
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:GRT]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:GRT]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:GRT]USRFLDM3
