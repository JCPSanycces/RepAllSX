#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# Outils d'archivage d'un plan d'amortissement :
# ============================================
#
# Traitements contenant les utilitaires d'alimentation et d'exploitation de l'archivage d'un plan d'amortissement
# Demande certification NF : pouvoir conserver l'état prospectif d'un plan d'amortissement avant une action
#                            susceptible de le modifier.
#
# @ver        1.0.0
# @date       26/07/2010
# @user       GBO
# @modif      26/07/2010 
#
########################################################################################################################
# Modifications :
# -------------
# 
# - USR - DD.MM.YYYY - FQnnnnn - Comment
#
# - GBO - 26.07.2010 - FQnnnnn - Création du traitement
#
########################################################################################################################
End

################################################################
# name : description
################################################################
# Parameters E : PAASREF  - Référence bien
#                PDPRPLN  - Plan d'amortissement
#                PDATMIN  - Date minimum de sélection des enregistrements
#                PDATMAX  - Date maximum de sélection des enregistrements
#                PCRITSUP - Critère supplémentaire
#                PEVT     - Type événement
#                PTIMSTP  - Horodatage événement
#                PNUMTRT  - N° de traitement
#                PFICTRA  - Fichier trace du traitement
#            S : RERR     - Erreur du sous-programme
#                                0     - Pas d'erreur
#                                1 à 5 - Erreur d'écriture sur DEPRECARC
################################################################
Subprog ARCH_DPRPLN(PAASREF, PDPRPLN, PDATMIN, PDATMAX, PCRITSUP,PEVT, PTIMSTP, PNUMTRT, PFICTRA, RERR)
Value    Char    PAASREF
Value    Integer PDPRPLN
Value    Date    PDATMIN
Value    Date    PDATMAX
Value    Char    PCRITSUP()
Value    Char    PEVT
Value    Char    PTIMSTP
Value    Integer PNUMTRT
Value    Char    PFICTRA
Variable Integer RERR

#> Contrôle des paramètres



#> Variables et tables

Local Integer LDEBUG
Local Integer LTRACE
Local Char    LCRITERE(255)

If !clalev([F:DEPS]) : Local File DEPREC    [DEPS] : Endif
If !clalev([F:DEA])  : Local File DEPRECARC [DEA]  : Endif

#> Transaction en cours ?

If !adxlog
 Trbegin [F:DEA]
 Local Integer LTRS
Endif

#> Préparation des critères

LCRITERE="AASREF=PAASREF & DPRPLN=PDPRPLN"
If PDATMIN<>[0/0/0] : LCRITERE+="&PERSTRDAT>=PDATMIN" : Endif
If PDATMAX<>[0/0/0] : LCRITERE+="&PERENDDAT<=PDATMAX" : Endif
If PCRITSUP="" : PCRITSUP="1=1" : Endif

#> Alimentation de la table archive

Filter [F:DEPS] Where evalue(LCRITERE) & evalue(PCRITSUP)
GOK            = 1
For [F:DEPS]
 [F:DEA]       = [F:DEPS]
 [F:DEA]EVT    = PEVT
 [F:DEA]TIMSTP = PTIMSTP
 Write [F:DEA]
 If fstat
  RERR=fstat : GOK=0 : Break
 Endif
Next
Filter [F:DEPS]

If dim(LTRS)>0
 If GOK
  Commit
 Else
  Rollback
 Endif
Endif
  
End


