###############################################################################
# Representation EDIPTC                                                       #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub AREAD_AFTER
      Endcase
    When "EPT"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EPT_AREAD_AFTER
      Endcase
    When "EPT.EPTD"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EPT_EPTD_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "EPT.PTCTYP"
      Case [L]ARULE
        When 'PROPAGATE' : Gosub EPT_PTCTYP_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$EPT_PTCTYP_PROPAGATE
  Call EPT_DISPLAY(this)
#  Local Integer I
#  For I = 1 To maxtab(this.EPTD)
#    Call EPT_EPTD_DISPLAY(this.EPTD(I))
#  Next I
Return

####################################################################

$EPT_AREAD_AFTER
  Local Integer WPOS
  If this.PTCTYP <>0 # X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
    Local Char WLBLTAB(50)(1..)
    Local Char WMLBLTAB(50)(1..)
    Local Integer I
# Issue 113994 by CJ
    WLBLTAB(1) = mess(1,2007,1) #"Issue volume"
    WLBLTAB(2) = mess(2,2007,1) #"Receipt volume"
    WLBLTAB(3) = mess(3,2007,1) #"Archive volume"
    WLBLTAB(4) = mess(4,2007,1) #"Error volume"
    WLBLTAB(5) = mess(5,2007,1) #"Import volume"
    WLBLTAB(6) = mess(61,2007,1) #"Issue test volume"
    WLBLTAB(7) = mess(62,2007,1) #"Import test volume"
    WLBLTAB(8) = mess(63,2007,1) #"Signed documents volume"
    WLBLTAB(9) = mess(95,2007,1) #"Attached documents volume" # #Epic X3-64474 _ US X3-85220 (JUCON 04/06/2018)
    WLBLTAB(10)= mess(104,2007,1) #"'Print server volume"

#/ Issue 113994 by CJ
    For I = 1 To maxtab(WLBLTAB)
      If maxtab(WLBLTAB)>maxtab(this.EPTD) and I=8    # Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
        If this.EPTD(I)=null
          WPOS = fmet this.ADDLINE('EPTD',[V]CST_ALASTPOS)
          this.EPTD(WPOS).PTCLINCOD="DIRSIGNATURE"
          this.EPTD(WPOS).PTCLINVALTYP="FIC"
        Endif
      Endif
      If maxtab(WLBLTAB)>maxtab(this.EPTD) and I=9    # Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
        If this.EPTD(I)=null
          WPOS = fmet this.ADDLINE('EPTD',[V]CST_ALASTPOS)
          this.EPTD(WPOS).PTCLINCOD="DIRATTACHMENT"
          this.EPTD(WPOS).PTCLINVALTYP="FIC"
        Endif
      Endif
      If maxtab(WLBLTAB)>maxtab(this.EPTD) and I=10
        If this.EPTD(I)=null
          WPOS = fmet this.ADDLINE('EPTD',[V]CST_ALASTPOS)
          this.EPTD(WPOS).PTCLINCOD="DIRPRINTSERVER"
          this.EPTD(WPOS).PTCLINVALTYP="FIC"
        Endif
      Endif
      this.EPTD(I).PTCLINDES    = WLBLTAB(I)
    Next I
  Endif
  If this.PTCTYP =1
    WMLBLTAB(1) = mess(96,2007,1) #"Issue volume"
    WMLBLTAB(2) = mess(97,2007,1) #"Receipt volume"
    WMLBLTAB(3) = mess(98,2007,1)-"1" #"Archive volume"
    WMLBLTAB(4) = mess(98,2007,1)-"2" #"Error volume"
    WMLBLTAB(5) = mess(99,2007,1) #"Import volume"
    WMLBLTAB(6) = mess(100,2007,1) #"Issue test volume"
    WMLBLTAB(7) = mess(101,2007,1) #"Import test volume"
    WMLBLTAB(8) = mess(102,2007,1) #"Signed documents volume"
    WMLBLTAB(9) = mess(103,2007,1) #"Mail signature"

    For I = 1 To maxtab(WMLBLTAB)
      this.EPTM(I).PTCMLINDES    = WMLBLTAB(I)
    Next
  Endif
  Call EPT_DISPLAY(this)

Return

####################################################################

$EPT_EPTD_AREAD_AFTER
  Call EPT_EPTD_DISPLAY(this)
Return

####################################################################

$AREAD_AFTER
  Local Integer WPOS, WNB
#  #display EDI partners using the current protocol
  WPOS = 0
  WNB = 0
  Local File EDIPARTNERD [EPRD]
  Local File EDIPARTNER [EPR]

  Link [EPR] With [EPRD]EPRD0 = [EPR]PARCOD As [LNK] Where [EPRD]PTCCOD = this.EPT.PTCCOD Order By [EPR]PARCOD
  For [LNK]
    WNB = WNB + 1
    If WNB = 1
      WPOS = fmet this.ADDLINE('EPTP', [V]CST_ALASTPOS)
      this.EPTP(WPOS).PARCOD = [EPRD]PARCOD
      this.EPTP(WPOS).PARDES = [EPR]PARDES
      this.EPTP(WPOS).PARFLGACT = [EPR]FLGACT
    Elsif WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      If not (this.EPTP(WPOS).PARCOD = [EPRD]PARCOD)
        WPOS = fmet this.ADDLINE('EPTP', [V]CST_ALASTPOS)
        this.EPTP(WPOS).PARCOD = [EPRD]PARCOD
        this.EPTP(WPOS).PARDES = [EPR]PARDES
        this.EPTP(WPOS).PARFLGACT = [EPR]FLGACT
      Endif
    Endif
  Next
  LogicClose File [EPR]
  LogicClose File [EPRD]


  #display flows using the current protocol
  WPOS = 0
  WNB = 0
  Local File EDIFLO [EFL], EDIFLOD [EFLD]
  Link [EFL] With [EFLD]EFLD0 = [EFL]FLOCOD; [EFL]FLOREL As [LNK] Where [EFLD]PTCCOD = this.EPT.PTCCOD Order By [EFLD]FLOCOD;[EFLD]FLOREL;[EFLD]NUMLIN
  For [LNK]
    WNB = WNB + 1
    If WNB = 1
      WPOS = fmet this.ADDLINE('EPTF', [V]CST_ALASTPOS)
      this.EPTF(WPOS).FLOCOD = [EFL]FLOCOD
      this.EPTF(WPOS).FLOREL = [EFL]FLOREL
      this.EPTF(WPOS).FLODES = [EFL]FLODES
      this.EPTF(WPOS).FLOFLGACT = [EFL]FLGACT
      this.EPTF(WPOS).FLOVALID =  [EFL]VALID
    Elsif WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      If not (this.EPTF(WPOS).FLOCOD = [EFL]FLOCOD and this.EPTF(WPOS).FLOREL = [EFL]FLOREL)
        WPOS = fmet this.ADDLINE('EPTF', [V]CST_ALASTPOS)
        this.EPTF(WPOS).FLOCOD = [EFL]FLOCOD
        this.EPTF(WPOS).FLOREL = [EFL]FLOREL
        this.EPTF(WPOS).FLODES = [EFL]FLODES
        this.EPTF(WPOS).FLOFLGACT = [EFL]FLGACT
        this.EPTF(WPOS).FLOVALID =  [EFL]VALID
      Endif
    Endif
  Next
  LogicClose File [EFL]
  LogicClose File [EFLD]
Return

#####################################################################

#********************************************************************
# Subprog DISPLAY
#********************************************************************
#
#* Switch the display according to PTCTYP
#* @param WOBJECT
#*!
Subprog EPT_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer I, WOK

  If WOBJECT.VALID=2: WOK=fmet WOBJECT.ASETATTRIBUTE("PTCTYP", "$isDisabled", "true")
  Else              : WOK=fmet WOBJECT.ASETATTRIBUTE("PTCTYP", "$isDisabled", "false")
  Endif

  Case WOBJECT.PTCTYP
    When 1: If WOBJECT.snapshot = null
#              WOK = fmet WOBJECT.ASETATTRIBUTE("PTCTYP", "$isDisabled", "false")
              WOK = fmet WOBJECT.ASETATTRIBUTE("PTCDES", "$isDisabled", "true")
            Endif
    When 2: WOK = fmet WOBJECT.ASETATTRIBUTE("PTCLINDES", "$isDisabled", "true")
    When Default
#      WOK = fmet WOBJECT.ASETATTRIBUTE("PTCTYP",    "$isDisabled", "false")
      WOK = fmet WOBJECT.ASETATTRIBUTE("PTCDES",    "$isDisabled", "false")
  Endcase
End

