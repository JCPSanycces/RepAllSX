#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Historique interlocuteur                                          Module CRM          13 novembre 2000 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZCCNNUM
Global Char GSZHBPREC
Global Char GSZHBPTYP
Global Integer GIDONE
Global Integer GIFILLDONE
Global Integer GIFILLTODO
Global Integer GIHCC1BD

  #PARAM(1) = Code interlocuteur.
  #Si aucun interlocuteur n'est mentionné, on ne fait rien.
  If PARAM(1) = "" Then
    FIN = 1
    GIHCC1BD = 0
    Return
  Endif
  GSZCCNNUM = PARAM(1)
  GIDONE = 1
  GSZHBPREC = ""
  GSZHBPTYP = ""
  GIFILLDONE = 0
  GIFILLTODO = 0
  If !clalev([F:HST]) : Local File HISTOCRM [HST] : Endif
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:OPPCRM]) : Local File OPPORCRM [OPPCRM] : Endif      # Issue X3-101789 - 2018-07-23 by FGR
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:HIM]) : Local File HISTOOMM [HIM] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
Return

##########################################################################################################
$PREMIER
Local Integer IPBL

  IPBL = 0
  Call RAZHCC
  If GIDONE Then
    Call LOADHCC(0, 0, IPBL)
  Else
    Call LOADHCC(0, 1, IPBL)
  Endif
Return

##########################################################################################################
$PRECEDENT
Return

##########################################################################################################
$SUIVANT
Return

##########################################################################################################
$DERNIER
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GIDONE Then
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
  Else
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer IPBL

  IPBL = 0
  Raz [M:HCC1]
  Read [AIN]AIN0=GSZCCNNUM
  If fstat Then
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  [M:HCC1]CCNNUM = GSZCCNNUM
  Call BUILDFULNAM("AIN", [M:HCC1]CCN) From CRMUTIL140
  [M:HCC1]TTR = mess(349,196,1) #Liste des actions effectuées.
  Call FILLHST(0, IPBL)
  Call LOADHCC(0, 0, IPBL)
  GSZHBPREC = [M:HCC1]NUM(0)
  GSZHBPTYP = [M:HCC1]TYP(0)
  GIHCC1BD = 1
  Call TEMPOFF From GESECRAN
  Affzo [M:HCC1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Local Integer IPBL

  IPBL = 0
  If BOUT = "1" Then
    If !GIFILLTODO Then
      Call TEMPON("F") From GESECRAN
      Call FILLHST(1, IPBL)
      Call TEMPOFF From GESECRAN
    Endif
  Endif
Return

##########################################################################################################
$FINSAI
  If GIHCC1BD Then
    Call RAZ_HST
    Raz [M:HCC1]
    Kill GSZCCNNUM
    Kill GIDONE
    Kill GSZHBPREC
    Kill GSZHBPTYP
    Kill GIFILLDONE
    Kill GIFILLTODO
  Endif
  Kill GIHCC1BD
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "B"
      Gosub ONDONE
    When "C"
      Gosub ONTODO
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Chargement de l'historique
#########################################################
Subprog FILLHST(ITODO, ITRB)
Value Integer ITODO
Variable Integer ITRB

Local Integer UU
Local Integer ICLSNUM
Local Integer ICOUNTLNS

  ICLSNUM = 0
  UU = 0
  ICOUNTLNS = 0
  #---------------------------------------------------#
  #Alimentation des Affaires
  #---------------------------------------------------#
  # Issue X3-101789 - 2018-07-23 by FGR : BEGIN
  #If ITODO Then
  #  Filter [OPP] Where [F:OPP]OPPMCN = GSZCCNNUM and [F:OPP]OPPCLO <> 2 Order By [F:OPP]OPPCDA Asc
  #Else
  #  Filter [OPP] Where [F:OPP]OPPMCN = GSZCCNNUM and [F:OPP]OPPCLO = 2 Order By [F:OPP]OPPREACDA Desc
  #Endif
  Link [OPP] With [OPPCRM]OPPCRM0=[F:OPP]OPPNUM
&              As [LOPP]
  If ITODO Then
    Filter [LOPP] Where [F:OPP]OPPMCN = GSZCCNNUM and [F:OPP]OPPCLO <> 2 Order By [F:OPPCRM]OPPCDA Asc
  Else
    Filter [LOPP] Where [F:OPP]OPPMCN = GSZCCNNUM and [F:OPP]OPPCLO = 2 Order By [F:OPPCRM]OPPREACDA Desc
  Endif
  # Issue X3-101789 - 2018-07-23 by FGR : END
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  #For [OPP] Hint Key OPP5                       # Issue X3-101789 - 2018-07-23 by FGR
  For [LOPP]                                     # Issue X3-101789 - 2018-07-23 by FGR
    If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:OPP]OPPNUM
    If ITODO Then
      [F:HST]RECDAT = [F:OPPCRM]OPPCDA           # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      [F:HST]RECHOU = [F:OPP]CREHOU
    Else
      [F:HST]RECDAT = [F:OPPCRM]OPPREACDA        # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      [F:HST]RECHOU = "0000"
    Endif
    [F:HST]RECTYP = "OPP"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [LOPP]                                  # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des rendez-vous
  #---------------------------------------------------#
  ICOUNTLNS = 0
  For UU = 0 To dim([F:BAP]APTCCNNUM)-1
    If ITODO Then
      Filter [BAP] Where [F:BAP]APTCCNNUM(UU) = GSZCCNNUM and [F:BAP]APTDON <> 2 Order By [F:BAP]APTDATX Asc
    Else
      Filter [BAP] Where [F:BAP]APTCCNNUM(UU) = GSZCCNNUM and [F:BAP]APTDON = 2 Order By [F:BAP]APTDATX Desc
    Endif
    Call DEBTRANS From GLOCK
    Trbegin [HST]
    For [BAP]
      If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
        Break
      Endif
      [F:HST]CLSNUM = 0
      If ITODO Then
        [F:HST]DON = 1
      Else
        [F:HST]DON = 2
      Endif
      [F:HST]SSS = GIDENT
      [F:HST]RECNUM = [F:BAP]APTNUM
      [F:HST]RECDAT = [F:BAP]APTDATX
      [F:HST]RECHOU = [F:BAP]APTHOU
      [F:HST]RECTYP = "BAP"
      Write [HST]
      If fstat Then
        ITRB = 1
        Break
      Endif
      ICOUNTLNS += 1
    Next
    Filter [BAP]
    #Si une écriture a échoué. On arrête tout.
    If ITRB Then
      GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Next
  #---------------------------------------------------#
  #Alimentation des appels
  #---------------------------------------------------#
  If ITODO Then
    Filter [CLL] Where [F:CLL]CLLCCN = GSZCCNNUM and [F:CLL]CLLDON <> 2 Order By [F:CLL]CLLDATX Asc
  Else
    Filter [CLL] Where [F:CLL]CLLCCN = GSZCCNNUM and [F:CLL]CLLDON = 2 Order By [F:CLL]CLLDATX Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [CLL] Hint Key CLL3
    If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:CLL]CLLNUM
    [F:HST]RECDAT = [F:CLL]CLLDATX
    [F:HST]RECHOU = [F:CLL]CLLHOU
    [F:HST]RECTYP = "CLL"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [CLL]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des tâches
  #---------------------------------------------------#
  If ITODO Then
    Filter [TSK] Where [F:TSK]TSKCCN = GSZCCNNUM and [F:TSK]TSKDON <> 2 Order By [F:TSK]TSKDAT Asc
  Else
    Filter [TSK] Where [F:TSK]TSKCCN = GSZCCNNUM and [F:TSK]TSKDON = 2 Order By [F:TSK]TSKDAT Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [TSK] Hint Key TSK3
    If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:TSK]TSKNUM
    [F:HST]RECDAT = [F:TSK]TSKDAT
    [F:HST]RECHOU = [F:TSK]CREHOU
    [F:HST]RECTYP = "TSK"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [TSK]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des Demandes de services
  #---------------------------------------------------#
  If ITODO Then
    Filter [SRE] Where [F:SRE]SRECCN = GSZCCNNUM and [F:SRE]SREASS <> 5 Order By [F:SRE]SREDATASS Asc; [F:SRE]SREHOUASS Asc
  Else
    Filter [SRE] Where [F:SRE]SRECCN = GSZCCNNUM and [F:SRE]SREASS = 5 Order By [F:SRE]SREDATASS Desc; [F:SRE]SREHOUASS Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [SRE] Hint Key SRE4
    If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:SRE]SRENUM
    [F:HST]RECDAT = [F:SRE]SREDATASS
    [F:HST]RECHOU = [F:SRE]SREHOUASS
    [F:HST]RECTYP = "SRE"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [SRE]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des interventions
  #---------------------------------------------------#
  If ITODO Then
    Filter [ITN] Where [F:ITN]CCN = GSZCCNNUM and [F:ITN]DON <> 2 Order By [F:ITN]DAT Asc
  Else
    Filter [ITN] Where [F:ITN]CCN = GSZCCNNUM and [F:ITN]DON = 2 Order By [F:ITN]DAT Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [ITN] Hint Key ITN3
    If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:ITN]NUM
    [F:HST]RECDAT = [F:ITN]DAT
    [F:HST]RECHOU = [F:ITN]HOU
    [F:HST]RECTYP = "ITN"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [ITN]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des historique mailing
  #---------------------------------------------------#
  If !ITODO Then
    Filter [HIM] Where [F:HIM]CCNNUM = GSZCCNNUM Order By [F:HIM]DATSND Desc
    Call DEBTRANS From GLOCK
    Trbegin [HST]
    ICOUNTLNS = 0
    For [HIM] Hint Key HIM5
      If ICOUNTLNS >= dim([M:HCC1]TYPCLA) Then
        Break
      Endif
      [F:HST]CLSNUM = 0
      [F:HST]DON = 2
      [F:HST]SSS = GIDENT
      [F:HST]RECNUM = [F:HIM]HIMNUM
      [F:HST]RECDAT = [F:HIM]DATSND
      [F:HST]RECHOU = "0000"
      [F:HST]RECTYP = "OMM"
      Write [HST]
      If fstat Then
        ITRB = 1
        Break
      Endif
      ICOUNTLNS += 1
    Next
    Filter [HIM]
    #Si une écriture a échoué. On arrête tout.
    If ITRB Then
      GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Endif
  #---------------------------------------------------#
  # Affecte les numéros d'ordre
  #---------------------------------------------------#
  If ITODO Then
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON <> 2 Order By [F:HST]RECDAT Asc; [F:HST]RECHOU Asc
  Else
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON = 2  Order By [F:HST]RECDAT Desc; [F:HST]RECHOU Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICLSNUM = 0
  For [HST] Hint Key HST2
    [F:HST]CLSNUM = ICLSNUM
    Rewrite [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICLSNUM += 1
  Next
  Filter [HST]
  #Si une réécriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  If ITODO Then
    GIFILLTODO = 1
  Else
    GIFILLDONE = 1
  Endif
End

##########################################################################################################
Subprog LOADHCC(ICLS, ITODO, ITRB)
Value Integer ICLS
Value Integer ITODO
Variable Integer ITRB

Local Integer I

  I = 0
  If ITODO Then
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON <> 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
  Else
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON = 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
  Endif
  For [HST] Hint Key HST2
    If I >= dim([M:HCC1]TYPCLA) Then
      Break
    Endif
    [M:HCC1]NUM(I) = [F:HST]RECNUM
    [M:HCC1]CLSNUM(I) = [F:HST]CLSNUM
    [M:HCC1]TYP(I) = [F:HST]RECTYP
    If [M:HCC1]TYP(I) = "OPP" Then
      [M:HCC1]TYPCLA(I) = mess(1,967,1)
      Read [OPP]OPP0=[M:HCC1]NUM(I)
      Read [OPPCRM]OPPCRM0=[M:HCC1]NUM(I)        # Issue X3-101789 - 2018-07-23 by FGR
      If !fstat Then
        If [F:OPP]OPPTYP = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(434, [F:OPP]OPPTYP, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        If ITODO Then
          [M:HCC1]DAT(I) = [F:OPPCRM]OPPCDA      # Issue X3-101789 - 2018-07-23 by FGR
          [M:HCC1]HOU(I) = "0000"
        Else
          [M:HCC1]DAT(I) = [F:OPPCRM]OPPREACDA   # Issue X3-101789 - 2018-07-23 by FGR
          [M:HCC1]HOU(I) = "0000"
        Endif
        Read [REP]REP0=[F:OPP]OPPREP
        If !fstat Then
          [M:HCC1]REP(I) = [F:REP]REPNAM
        Endif
        If [F:OPP]OPPCMP <> "" Then
          Read [BPR]BPR0=[F:OPP]OPPCMP
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        [M:HCC1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
      Endif
    Elsif [M:HCC1]TYP(I) = "BAP" Then
      [M:HCC1]TYPCLA(I) = mess(2,967,1)
      Read [BAP]APP0=[M:HCC1]NUM(I)
      If !fstat Then
        If [F:BAP]APTTYP = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(433, [F:BAP]APTTYP, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HCC1]DAT(I) = [F:BAP]APTDATX
        [M:HCC1]HOU(I) = [F:BAP]APTHOU
        Read [REP]REP0=[F:BAP]APTREPNUM(0)
        If !fstat Then
          [M:HCC1]REP(I) = [F:REP]REPNAM
        Endif
        If [F:BAP]APTCMP <> "" Then
          Read [BPR]BPR0=[F:BAP]APTCMP
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        If [F:BAP]APTPJT <> "" Then
          Read [OPP]OPP0=[F:BAP]APTPJT
          If !fstat Then
            [M:HCC1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM)   # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
          Endif
        Endif
      Endif
    Elsif [M:HCC1]TYP(I) = "CLL" Then
      Read [CLL]CLL0=[M:HCC1]NUM(I)
      If !fstat Then
        If [F:CLL]CLLCAT = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(432, [F:CLL]CLLCAT, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        If [F:CLL]CLLTYP = 1 Then
          [M:HCC1]TYPCLA(I) = mess(1,956,1)
        Elsif [F:CLL]CLLTYP = 2 Then
          [M:HCC1]TYPCLA(I) = mess(2,956,1)
        Endif
        [M:HCC1]DAT(I) = [F:CLL]CLLDATX
        [M:HCC1]HOU(I) = [F:CLL]CLLHOU
        If [F:CLL]CLLTYP = 1 Then
          If [F:CLL]CREUSR <> "" Then
            Read [AUS]CODUSR=[F:CLL]CREUSR
            If !fstat Then
              [M:HCC1]REP(I) = [F:AUS]NOMUSR
            Endif
          Endif
        Elsif [F:CLL]CLLTYP = 2 Then
          Read [REP]REP0=[F:CLL]CLLREP
          If !fstat Then
            [M:HCC1]REP(I) = [F:REP]REPNAM
          Endif
        Endif
        If [F:CLL]CLLCMP <> "" Then
          Read [BPR]BPR0=[F:CLL]CLLCMP
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        If [F:CLL]CLLOPP <> "" Then
          Read [OPP]OPP0=[F:CLL]CLLOPP
          If !fstat Then
            [M:HCC1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM)   # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
          Endif
        Endif
      Endif
    Elsif [M:HCC1]TYP(I) = "TSK" Then
      [M:HCC1]TYPCLA(I) = mess(4,967,1)
      Read [TSK]TSK0=[M:HCC1]NUM(I)
      If !fstat Then
        If [F:TSK]TSKTYP = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(431, [F:TSK]TSKTYP, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HCC1]DAT(I) = [F:TSK]TSKDAT
        [M:HCC1]HOU(I) = "0000"
        Read [REP]REP0=[F:TSK]TSKREP
        If !fstat Then
          [M:HCC1]REP(I) = [F:REP]REPNAM
        Endif
        If [F:TSK]TSKCMP <> "" Then
          Read [BPR]BPR0=[F:TSK]TSKCMP
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        If [F:TSK]TSKPJT <> "" Then
          Read [OPP]OPP0=[F:TSK]TSKPJT
          If !fstat Then
            [M:HCC1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM)   # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
          Endif
        Endif
      Endif
    Elsif [M:HCC1]TYP(I) = "SRE" Then
      [M:HCC1]TYPCLA(I) = mess(5,967,1)
      Read [SRE]SRE0=[M:HCC1]NUM(I)
      If !fstat Then
        If [F:SRE]SREGRALEV = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(428, [F:SRE]SREGRALEV, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        If [F:SRE]SREDATASS = [00/00/00] Then
          [M:HCC1]DAT(I) = [F:SRE]CREDAT
          [M:HCC1]HOU(I) = [F:SRE]CREHOU
        Else
          [M:HCC1]DAT(I) = [F:SRE]SREDATASS
          [M:HCC1]HOU(I) = [F:SRE]SREHOUASS
        Endif
        If ITODO Then
          If [F:SRE]SREASS = 2 Then
            Read [AUS]CODUSR=[F:SRE]SREDET
            If !fstat Then
              [M:HCC1]REP(I) = [F:AUS]NOMUSR
            Endif
          Elsif [F:SRE]SREASS = 1 Then
            [M:HCC1]REP(I) = mess(1,975,1) #Dispatching
          Elsif [F:SRE]SREASS = 3 Then
            [M:HCC1]REP(I) = mess(3,975,1) #Queue
          Endif
          If [F:SRE]SREASS = 4 Then
            [M:HCC1]REP(I) = mess(352,196,1) #Service commercial
          Endif
        Else
          If [F:SRE]REP <> "" Then
            Read [AUS]CODUSR=[F:SRE]REP
            If !fstat Then
              [M:HCC1]REP(I) = [F:AUS]NOMUSR
            Endif
          Endif
        Endif
        If [F:SRE]SREBPC <> "" Then
          Read [BPR]BPR0=[F:SRE]SREBPC
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        [M:HCC1]OPP(I) = ""
      Endif
    Elsif [M:HCC1]TYP(I) = "ITN" Then
      [M:HCC1]TYPCLA(I) = mess(6,967,1)
      Read [ITN]ITN0=[M:HCC1]NUM(I)
      If !fstat Then
        If [F:ITN]TYP = "" Then
          [M:HCC1]CATCLA(I) = ""
        Else
          Call GET_LIB(407, [F:ITN]TYP, [M:HCC1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HCC1]DAT(I) = [F:ITN]DAT
        [M:HCC1]HOU(I) = [F:ITN]HOU
        Read [AUS]CODUSR=[F:ITN]REP
        If !fstat Then
          [M:HCC1]REP(I) = [F:AUS]NOMUSR
        Endif
        If [F:ITN]BPC <> "" Then
          Read [BPR]BPR0=[F:ITN]BPC
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        [M:HCC1]OPP(I) = ""
      Endif
    Elsif [M:HCC1]TYP(I) = "OMM" Then
      [M:HCC1]TYPCLA(I) = mess(7,967,1)
      Read [HIM]HIM0=[M:HCC1]NUM(I)
      If !fstat Then
        Read [OMM]OMM0=[F:HIM]OMMNUM
        If !fstat Then
          [M:HCC1]CATCLA(I) = mess([F:OMM]SHIMOD,963,1)
        Endif
        If [F:HIM]BPRNUM <> "" Then
          Read [BPR]BPR0=[F:HIM]BPRNUM
          If !fstat Then
            [M:HCC1]BPR(I) = [F:BPR]BPRNAM
          Endif
        Endif
        [M:HCC1]NUM(I) = [F:HIM]OMMNUM
        [M:HCC1]DAT(I) = [F:HIM]DATSND
        [M:HCC1]HOU(I) = "0000"
        [M:HCC1]REP(I) = ""
        [M:HCC1]OPP(I) = ""
      Endif
    Endif
    I += 1
  Next
  Filter [HST]
  [M:HCC1]NBHCC = I
  Affzo [M:HCC1]1-99
End

##########################################################################################################
$ONDONE
Local Integer IPBL

  IPBL = 0
  Call RAZHCC
  [M:HCC1]TTR = mess(349,196,1) #Liste des actions effectuées.
  If !GIFILLDONE Then
    Call FILLHST(0, IPBL)
  Endif
  Call LOADHCC(0, 0, IPBL)
  GIDONE = 1
  GSZHBPREC = [M:HCC1]NUM(0)
  GSZHBPTYP = [M:HCC1]TYP(0)
Return

##########################################################################################################
$ONTODO
Local Integer IPBL

  IPBL = 0
  Call RAZHCC
  [M:HCC1]TTR = mess(350,196,1) #Liste des actions à effectuer.
  If !GIFILLTODO Then
    Call FILLHST(1, IPBL)
  Endif
  Call LOADHCC(0, 1, IPBL)
  GIDONE = 0
  GSZHBPREC = [M:HCC1]NUM(0)
  GSZHBPTYP = [M:HCC1]TYP(0)
Return

##########################################################################################################
# Vide la table de gestion associées à l'historique
#########################################################
Subprog RAZ_HST
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  Delete [HST] Where [F:HST]SSS = GIDENT
  If fstat Then
    Rollback
    End
  Endif
  Commit
End

##########################################################################################################
# Vide le tableau d'historique
#########################################################
Subprog RAZHCC
  Raz [M:HCC1]NBHCC
  Raz [M:HCC1]CATCLA
  Raz [M:HCC1]TYPCLA
  Raz [M:HCC1]DAT
  Raz [M:HCC1]HOU
  Raz [M:HCC1]REP
  Raz [M:HCC1]BPR
  Raz [M:HCC1]OPP
  Raz [M:HCC1]TYP
  Raz [M:HCC1]NUM
  Raz [M:HCC1]CLSNUM
End

