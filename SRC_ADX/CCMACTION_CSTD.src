#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-64604 2017-11-23 : Redevelop Non Conformance Actions for corrective plans in Hybrid mode
# Class CCMACTION

$METHODS
Case CURPTH
   When ""
      Case ACTION
        When "AINSERT_CONTROL_AFTER" :
          Gosub VALIDATE
        When "AUPDATE_CONTROL_AFTER" :
          Gosub VALIDATE
      Endcase
Endcase
Return

$VALIDATE
# Issue 110863/4 - 2015-11-11 by JUSYN : Prevent duplicate trantype/tranaction combination
  Local File CCMACTION [CCMACT]
  Local Integer WFLG(1)

  If (this.TRANTYPE = 1)
    ASTATUS = fmet this.ASETERROR("TRANTYPE", mess(18,2038,1), CST_AERROR)
  Endif
  If (this.TRANACTION = 1)
    ASTATUS = fmet this.ASETERROR("TRANACTION", mess(19,2038,1), CST_AERROR)
  Endif

# Issue 110863/4 - 2015-11-11 by JUSYN : Prevent duplicate trantype/tranaction combination
  # Check whether original values have been changed
  WFLG = 0
  # Issue X3-64604 2017-11-23 : ncs actions, gives null error during create/update
  If this.snapshot <> null
    If this.TRANTYPE = this.snapshot.TRANTYPE and this.TRANACTION = this.snapshot.TRANACTION
      WFLG = 1
    Endif
  Endif
  # End issue X3-64604

  If WFLG = 0
    Filter [CCMACT] Where [F:CCMACT]TRANTYPE = this.TRANTYPE and [F:CCMACT]TRANACTION = this.TRANACTION
    Read [CCMACT] First
    If (fstat = 0)
      ASTATUS = fmet this.ASETERROR("" , mess(80,2038,1) , CST_AERROR)
    Endif
  Endif
  LogicClose File [CCMACT]
Return

$PROPERTIES
  Case CURPRO
  Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

