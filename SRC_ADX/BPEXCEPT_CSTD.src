###################################################################################################
$DEPBPS_PROPAGATE
Local Integer IRET
Local Char LEG(GLONADI)

  If this.DEPBPS = "" Then
    Return
  Endif

  # ------------------------
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, AVOID.ACHAR, this.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEPBPS, this.CPY, AVOID.ACHAR, this.LEG, this.DEPBPS_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  # ------------------------

Return
