  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTEBPC, this.CPY, AVOID.ACHAR, this.LEG, this.PTEBPC_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
