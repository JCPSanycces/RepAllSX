#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe BPEXCEPT
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER" : Gosub AREAD_AFTER # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  Case [L]CURPRO
    When "VACBPR" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub VACBPR_PROPAGATE
      Endcase
    When "VACBPC" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub VACBPC_PROPAGATE
      Endcase
    When "VACBPS" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub VACBPS_PROPAGATE
      Endcase
    When "PTEBPC" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PTEBPC_PROPAGATE
      Endcase
    When "PTEBPS" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PTEBPS_PROPAGATE
      Endcase
    When "DEPBPC" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub DEPBPC_PROPAGATE
      Endcase
    When "DEPBPS" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub DEPBPS_PROPAGATE
      Endcase
  Endcase

Return
###################################################################################################
$AREAD_AFTER

  # ------------------------
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, AVOID.ACHAR, this.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, AVOID.ACHAR, this.LEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPC, this.CPY, AVOID.ACHAR, this.LEG, this.VACBPC_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPS, this.CPY, AVOID.ACHAR, this.LEG, this.VACBPS_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTEBPC, this.CPY, AVOID.ACHAR, this.LEG, this.PTEBPC_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTEBPS, this.CPY, AVOID.ACHAR, this.LEG, this.PTEBPS_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEPBPC, this.CPY, AVOID.ACHAR, this.LEG, this.DEPBPC_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEPBPS, this.CPY, AVOID.ACHAR, this.LEG, this.DEPBPS_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
###################################################################################################
$VACBPR_PROPAGATE

  If this.VACBPR = "" Then
    Return
  Endif

  # ------------------------
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, AVOID.ACHAR, this.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, AVOID.ACHAR, this.LEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  # ------------------------

Return

