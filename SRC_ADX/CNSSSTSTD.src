#<AdxTL>@(#)7.0.0.0 $Revision$ Consultation SST
##################################################
#                                                #
#    Consultation des  ST                        #
#                                    MM   03/02  #
##################################################


########################################################
#                                                      
# Parametres de consultation via PARAM()               
#                                                      
#
#1 = site
#
#2 = N° OF
#
#3 = Poste de charge
#
#4 = Article ST
#
#5 = N° commande
#
#6 = Fournisseur
#
#7 = Date commande
#
#8 = TRI
#
#       1- par N° OF
#       2- par poste
#       3- par article
#       4- par N° de commande
#       5- par date commande               
#
########################################################

Local Char PARAM(20)(1..8)
PARAM(1)="GAL"
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)=""
PARAM(6)=""
PARAM(7)=""
PARAM(8)=""

Call GCONSULT("SST", "",PARAM) From GCONSULT
End


##################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LECTURE"  : Gosub LECTURE
 When default
Endcase
Return


##################################################
$OUVRE

Integer I
Local Char CRITERE(255),CRITERE1(255), CRITERE2(255), CRITERE3(255)
Local Char DEBNUM , FINNUM
Local Char DEBMFGNUM(GLONVCR) , FINMFGNUM(GLONVCR)
Local Char DEBWST(GLONWST) , FINWST(GLONWST)
Local Char DEBSCOITM , FINSCOITM
Local Date DEBDAT, FINDAT
Local Integer WSRT


If clalev ([F:POQ]) <= 0 : Local File PORDERQ [POQ] : Endif
If clalev ([F:MFO]) <= 0 : Local File MFGOPE  [MFO] : Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO  [MWS] : Endif

Gosub DEFCRIT
If !find ([M:CSST]OLDCMD, 1,2) : [M:CSST]OLDCMD =1 : Endif
If !find ([M:CSST]TRI,1,2,3,4,5) : [M:CSST]TRI=1 : Endif


# Mail TS du 18/03/08
NAVIG="CONSSST"
Return

##################################################
$DEFCRIT
#chargement par defaut : en fonction du site + date du jour
# + exclusion des commandes soldées


For I= 1 To dim(PARAM)
  Case I
    When 1 :     #site
            If  PARAM(I)<> ""   
                 Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                 If !fstat : [M:SST1]MFGFCY = PARAM(I): Endif
            Endif
    When 2 :     # N° OF
             If  PARAM(I)<> ""  
                    [M:SST1]MFGNUMDEB =  PARAM(I)
                    [M:SST1]MFGNUMFIN =  PARAM(I)
             Endif
    When 3 :     # Poste de charge
             If  PARAM(I)<> ""   
                Read [MWS]WST0 = PARAM(I);[M:SST1]MFGFCY       
                If !fstat
                   [M:SST1]EXTWSTDEB = PARAM(I)
                   [M:SST1]EXTWSTFIN = PARAM(I)
                Endif
             Endif
    When 4 :     #  Article ST
             If  PARAM(I)<> ""   
                [M:SST1]ITMREFDEB = PARAM(I)
                [M:SST1]ITMREFFIN = PARAM(I)
             Endif
    When 5 :     # N° commande
            If  PARAM(I)<> ""  
                  [M:SST1]POHNUMDEB = PARAM(I)
                  [M:SST1]POHNUMFIN = PARAM(I) 
            Endif            
    When 6 :    #fournisseur
            If PARAM(I)<>""
                  [M:SST1]BPSNUMDEB = PARAM(I)
                  [M:SST1]BPSNUMFIN = PARAM(I)
           Endif
    When 7 :    # date commande
          If PARAM(I)<>""
                If instr(1, PARAM(I),"/")
                    [M:SST1]ORDDATDEB = "["+PARAM(I)+"]"
                    [M:SST1]ORDDATFIN = "["+PARAM(I)+"]"
                Else
                    [M:SST1]ORDDATDEB = PARAM(I)
                    [M:SST1]ORDDATFIN = PARAM(I)
                Endif
          Endif
          If   [M:SST1]ORDDATDEB =[0/0/0]
                [M:SST1]ORDDATDEB = date$ : [M:SST1]ORDDATFIN = date$
          Endif
   When 8 :    # tri
          If PARAM(I)<>""
              WSRT = val(PARAM(I))
              If WSRT<0 | WSRT > 5 : WSRT = 1 : Endif
             [M:CSST]TRI = WSRT
          Endif
   When Default : Break

  Endcase
Next I


# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS

Return

##################################################
$LECTURE
#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################
#-- Application du filtre et positionnement des boutons, classé par N° OF
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1       #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif 

  Case [M:CSST]TRI
    When 1:    # tri par N° OF
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]MFGNUM 

    When 2:    # tri par poste
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]EXTWST 

    When 3:    # tri par article
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]SCOITMREF

    When 4:    # tri par n° de commande
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:POQ]POHNUM 
    
    When 5:    # tri par date commande
   Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:POQ]ORDDAT 

  Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

  Case [M:CSST]TRI
    When 1 :    # tri par N° OF
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]MFGNUM Desc 
 
    When 2:    # tri par poste
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]EXTWST Desc

    When 3:    # tri par article
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:MFO]SCOITMREF Desc

    When 4 :   # tri par n° de commande
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:POQ]POHNUM Desc 

    When 5 :   # tri par date commande
    Link [POQ] With [MFO]MFO1=POHNUM;POPLIN;POQSEQ As [NEW] Where evalue (CRITERE1)& evalue (CRITERE2)& evalue (CRITERE3)
&         Order By Key CLE =[F:POQ]ORDDAT Desc 

  Endcase

Endif
 

# RAZ du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SST2] : Endif

For[NEW]
    If NBLU=1 
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:SST2] : Endif
        NBLU =2
    Endif

    If CHGPAG >0
        If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
        NOL +=1
        If NOL = 0 
            DEBMFGNUM = [F:MFO]MFGNUM
            DEBWST = [F:MFO]EXTWST
            DEBSCOITM =[F:MFO]SCOITMREF
            DEBNUM = [F:POQ]POHNUM
            DEBDAT = [F:POQ]ORDDAT
        Endif
        FINMFGNUM = [F:MFO]MFGNUM
        FINWST = [F:MFO]EXTWST
        FINSCOITM =[F:MFO]SCOITMREF
        FINNUM = [F:POQ]POHNUM
        FINDAT = [F:POQ]ORDDAT
    Else
        If NOL <=0 : RETOUR = 2 : Break : Endif
        NOL -=1
        If NOL = MAXLIG -1 
            FINMFGNUM = [F:MFO]MFGNUM
            FINWST = [F:MFO]EXTWST
            FINSCOITM =[F:MFO]SCOITMREF
            FINNUM =  [F:POQ]POHNUM
            FINDAT = [F:POQ]ORDDAT
        Endif
        DEBMFGNUM =  [F:MFO]MFGNUM
        DEBWST = [F:MFO]EXTWST
        DEBSCOITM =[F:MFO]SCOITMREF
        DEBNUM = [F:POQ]POHNUM
        DEBDAT = [F:POQ]ORDDAT
    Endif

    nolign = NOL+1
    [M:SST2]MFGNUM(nolign-1)    = [F:MFO]MFGNUM 
    [M:SST2]SCOITMREF(nolign-1) = [F:MFO]SCOITMREF
    [M:SST2]BPSNUM(nolign-1)    = [F:MFO]BPRNUM
    [M:SST2]ORDDAT(nolign-1)    = [F:POQ]ORDDAT
    [M:SST2]POHNUM(nolign-1)    = [F:POQ]POHNUM
    [M:SST2]OPESTA(nolign-1)    = [F:MFO]OPESTA
    [M:SST2]EXTRCPDAT(nolign-1) = [F:POQ]EXTRCPDAT
    [M:SST2]EXTQTY(nolign-1)    = [F:MFO]EXTQTY
    [M:SST2]OPEUOM(nolign-1)    = [F:MFO]OPEUOM
    [M:SST2]CPLQTY(nolign-1)    = [F:MFO]CPLQTY
    [M:SST2]REJCPLQTY(nolign-1) = [F:MFO]REJCPLQTY
    [M:SST2]RCPQTYSTU(nolign-1) = [F:POQ]RCPQTYSTU
    [M:SST2]STU(nolign-1)       = [F:POQ]STU
    [M:SST2]EXTWST(nolign-1)    = [F:MFO]EXTWST

Next 


Return

##################################################
$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

#site
If [M:SST1]MFGFCY <> ""
    CRITERE = "[F:MFO]MFGFCY=[M:SST1]MFGFCY"
    Gosub LOAD_CRITERE1
Endif

#N°  OF
If [M:SST1]MFGNUMDEB <> ""
      CRITERE ="[F:MFO]MFGNUM>=[M:SST1]MFGNUMDEB"
      Gosub LOAD_CRITERE1
Endif

If [M:SST1]MFGNUMFIN <> ""
    CRITERE ="[F:MFO]MFGNUM <= [M:SST1]MFGNUMFIN"
    Gosub LOAD_CRITERE1
Endif

# Poste de charge
If [M:SST1]EXTWSTDEB<>""
    CRITERE ="[F:MFO]EXTWST >=[M:SST1]EXTWSTDEB"
    Gosub LOAD_CRITERE1 
Endif

If [M:SST1]EXTWSTFIN <>""
    CRITERE = "[F:MFO]EXTWST <= [M:SST1]EXTWSTFIN"
    Gosub LOAD_CRITERE1 
Endif

# Article ss-traitance
If [M:SST1]ITMREFDEB<>""
    CRITERE ="[F:MFO]SCOITMREF >= [M:SST1]ITMREFDEB"
    Gosub LOAD_CRITERE1 
Endif

If [M:SST1]ITMREFFIN<>""
    CRITERE = "[F:MFO]SCOITMREF <= [M:SST1]ITMREFFIN"
   Gosub LOAD_CRITERE2 
Endif

#Fournisseur
If [M:SST1]BPSNUMDEB<>""
    CRITERE = "[F:POQ]BPSNUM >=[M:SST1]BPSNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:SST1]BPSNUMFIN<>""
   CRITERE = "[F:POQ]BPSNUM <=[M:SST1]BPSNUMFIN"
   Gosub LOAD_CRITERE2
Endif

#N° commande
If [M:SST1]POHNUMDEB<>""
    CRITERE ="[F:POQ]POHNUM >=[M:SST1]POHNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:SST1]POHNUMFIN<>""
    CRITERE ="[F:POQ]POHNUM <=[M:SST1]POHNUMFIN"
    Gosub LOAD_CRITERE2
Endif

# Date commande
If [M:SST1]ORDDATDEB<>[0/0/0]
   CRITERE = "[F:POQ]ORDDAT >= [M:SST1]ORDDATDEB"
   Gosub LOAD_CRITERE2
Endif

If [M:SST1]ORDDATFIN<>[0/0/0]
   CRITERE = "[F:POQ]ORDDAT <= [M:SST1]ORDDATFIN"
   Gosub LOAD_CRITERE2
Endif

# Si case non cochée , on exclut les commandes soldées
If [M:CSST]OLDCMD=1 
   CRITERE ="[F:MFO]OPESTA <>5"
   Gosub LOAD_CRITERE3   
Endif


Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CSST]TRI
            When 1 :
                CRITERE = "[F:MFO]MFGNUM >=DEBMFGNUM"
                Gosub LOAD_CRITERE3
            When 2 :
                CRITERE = "[F:MFO]EXTWST >=DEBWST"
                Gosub LOAD_CRITERE3
            When 3 :
                CRITERE = "[F:MFO]SCOITMREF >= DEBSCOITM" 
                Gosub LOAD_CRITERE3
            When 4 :
                CRITERE = "[F:POQ]POHNUM >=DEBNUM"
                Gosub LOAD_CRITERE3
            When 5 :
                CRITERE= "[F:POQ]ORDDAT >= DEBDAT"
                Gosub LOAD_CRITERE3
        Endcase
    When 2 : #suite
        Case [M:CSST]TRI
            When 1: 
                CRITERE = "[F:MFO]MFGNUM >FINMFGNUM"
                Gosub LOAD_CRITERE3
            When 2:
                CRITERE = "[F:MFO]EXTWST >FINWST"
                Gosub LOAD_CRITERE3
            When 3:
                CRITERE = "[F:MFO]SCOITMREF >FINSCOITM"
                Gosub LOAD_CRITERE3
            When 4:    
                CRITERE = "[F:POQ]POHNUM >FINNUM"
                Gosub LOAD_CRITERE3
            When 5:
                CRITERE= "[F:POQ]ORDDAT > FINDAT"
                Gosub LOAD_CRITERE3
            Endcase
    When -2: # retour
        Case [M:CSST]TRI
            When 1: 
                CRITERE = "[F:MFO]MFGNUM < DEBMFGNUM"
                Gosub LOAD_CRITERE3
            When 2 :
                CRITERE = "[F:MFO]EXTWST < DEBWST"
                Gosub LOAD_CRITERE3
            When 3 :
                CRITERE= "[F:MFO]SCOITMREF < DEBSCOITM"
                Gosub LOAD_CRITERE3
            When 4:
                CRITERE = "[F:POQ]POHNUM < DEBNUM"
                Gosub LOAD_CRITERE3
            When 5:
                CRITERE="[F:POQ]ORDDAT < DEBDAT"
                Gosub LOAD_CRITERE3
        Endcase
Endcase 

If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif

Return


#############################################################################
$LOAD_CRITERE1
If len(CRITERE1)<>0 : CRITERE1 += "&" : Endif
CRITERE1 += CRITERE 
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE  
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE  
Return


###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################

########################################
Subprog AM_POHNUMDEB(VALEUR)
Variable Char    VALEUR()
  If [M]POHNUMDEB = "": [M]POHNUMFIN = VALEUR : Endif
  If [M]POHNUMFIN < VALEUR :[M]POHNUMFIN = VALEUR : Endif
End

########################################
Subprog C_POHNUMFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]POHNUMDEB : GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_BPSNUMDEB(VALEUR)
Variable Char    VALEUR()
    If [M]BPSNUMDEB="" : [M]BPSNUMFIN = VALEUR : Endif
    If [M]BPSNUMFIN< VALEUR : [M]BPSNUMFIN = VALEUR : Endif
End

########################################
Subprog C_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
   If VALEUR <[M]BPSNUMDEB : : GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End



########################################
Subprog AM_EXTWSTDEB(VALEUR)
Variable Char    VALEUR()
    If [M]EXTWSTDEB ="" : [M]EXTWSTFIN=VALEUR : Endif
    If [M]EXTWSTFIN < VALEUR :  [M]EXTWSTFIN=VALEUR : Endif  
End

########################################
Subprog C_EXTWSTFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]EXTWSTDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
    If [M]MFGNUMDEB= "": [M]MFGNUMFIN = VALEUR: Endif
    If [M]MFGNUMFIN < VALEUR :  [M]MFGNUMFIN = VALEUR: Endif
End

########################################
Subprog C_MFGNUMFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]MFGNUMDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
    If [M]ITMREFDEB ="" : [M]ITMREFFIN = VALEUR : Endif    
    If [M]ITMREFFIN < VALEUR : [M]ITMREFFIN = VALEUR : Endif    
End

########################################
Subprog C_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]ITMREFDEB: GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_ORDDATDEB(VALEUR)
Variable Date    VALEUR
    If [M]ORDDATDEB =[0/0/0] : [M]ORDDATFIN = VALEUR : Endif
    If [M]ORDDATFIN < VALEUR : [M]ORDDATFIN = VALEUR : Endif
End

########################################
Subprog C_ORDDATFIN(VALEUR)
Variable Date    VALEUR
    If VALEUR <[M]ORDDATDEB : GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif

End

########################################
Subprog IB_NBLIG
GBOUT1=mess(10,159,1)    # commande
GBOUT2=mess(166,198,1)   # ordre de fabrication
End


# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"SST") From SUBGTC

End
