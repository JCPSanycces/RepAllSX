#<AdxTL>@(#)12.0.0.0 $Revision$
Call MAJARCHIVE_HISTO("TEST2")
End

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
#X3-76171
If dim(GMAXSPEACV)>=0 & GMAXSPEACV>0
  Global Char    GSPE(GLONACV)(1..GMAXSPEACV)
Else
  Global Char    GSPE(GLONACV)(1..300)
Endif
#X3-76171
Global Integer GNBSPE
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "TEST2"
If fstat : End : Endif
#GCOEF = 0.5
DOSVAL = [F:ADS]DOSSIER
DOSREF  = [F:ADS]DOSREF
DOSCOP  = [F:ADS]DOSCOP
Local File ADOSACT [ADA]
GNBSPE = 0
For [ADA]ADA0 Where [F]DOSSIER=[L]DOSVAL & CODACT>="X"
 GNBSPE += 1
 GSPE(GNBSPE) = [F:ADA]CODACT
Next ADA
Close Local File [ADA]
Call OUVRE_TRACE("") From LECFIC
Gosub AMAJSUP
Gosub MAJSUP
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

################################################################################################
#
#  Moulinettes superviseur pour la v7
#
#  Ces moulinettes sont réexécutables :
#  si elles sont été déjà lancées elles sont effet si on les lance une deuxième fois
#
################################################################################################


######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..300)
Local Integer NBSPE , NBACTS , NBFLD , DIME , VERCUR

VERCUR = 170
DETAIL = 0
APPLI = [F:ADS]DOSSIER

If val(DOSVERS)<30 : End : Endif : # C'est que la mise à jour 30 a déjà été faite

#107271
If func DOSVUE.ISVIEW(APPLI,"ATYPE")=0
 MESSA = "Update Data Types"
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Call MAJ_ATYATY
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Gosub DOSMAJATY From DOSMAJATY
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ACTIV")=0
 MESSA = "Update Activity Codes"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Gosub DOSMAJACV From DOSMAJACV
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ATABLE")=0
 MESSA = "Update tables"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 If func DOSSUB.ISHISTFOLD(APPLI)=0
  Gosub DOSMAJATB From DOSMAJATB
 Else
  Gosub DOSMAJATBHIS From DOSMAJATB
 Endif
Endif

# Pour forcer la validation des vues parce que l'intégration d'une sauvegarde
# d'un dossier d'une version différente de la version courante ne revalide pas les vues

MESSA = "Update views"
If GINFO
 Call AFF_VLC("Dictionnary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
If dim(GVALIDE)>=11
 GVALIDE(11) = 1
Endif

End

######################################################################
Subprog AMAJ

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
Local Integer STAT
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub AMAJSUP
#cf 91420
#Read [ADS]DOSSIER Curr
#107271
#Read [ADS]DOSSIER=DOSVAL
STAT=func DOSSUB.FILL_ADS([L]DOSVAL)
End

##################################
$AMAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
If func DOSSUB.ISHISTFOLD(DOSVAL)=0
 Call ARCHIVEADX(DOSVAL)                : # Génération de l'archive v7
 Call MAJARCHIVE_HISTO(DOSVAL)                  : # Mise à jour archive dossiers historisés
 Call UTIFLDAWM2(DOSVAL)                        : # Mise a jour de la nouvelle table AWRKTAB 2
 Call UTIFLDAWM3(DOSVAL)                        : # Mise a jour flag flgadlv si 0
 If func AFNC.ACTIVDOS(DOSVAL,"ASD")
 Call UTIASDCNT(DOSVAL)                         : # Suppresion des tables Contarts dans les dossiers suite passage type dossier à système
 Endif
 Call UTIMAJTABLNK(DOSVAL)                      : # Mise a jour de la nouvelle table AWRKTAB
 Call UTIMAJADVCOL(DOSVAL)                      : # Ajout de champ A1 et A2 ..; supplementaires
 Call UTIMAJAML(DOSVAL)                         : # Mise à jour table nouveau champ "NONTRA" dans la table AMENLOC
 Call UTIMAJSEPA(DOSVAL)                        : # Initialisation du champ FLGSEPA dans la table TABCOUNTRY
Else
 Call MAJARCHIVE_HISTO(DOSREF)                  : # Mise à jour archive dossiers historisés
Endif
Call UTIADDFLDTAB(DOSVAL)                      : # Rajout des champs timestamp et uid dans toutes les tables
##trop long
##Call UTIMAJFLDTAB(DOSVAL)                    : # Mise à jour des champs timestamp et uid dans les tables (superviseur)
Call UTIMAJFLDTAB2(DOSVAL)                     : # Mise à jour des champs timestamp dans les tables (autres)
Call UTIDELFLDTAB(DOSVAL)                      : # Suppression des champs obsolètes dans toutes les tables
If func DOSSUB.ISHISTFOLD(DOSVAL)=0
 Call UTIMAJAMOTCLE(DOSVAL)                     : # Alimentation de la table AMOTCLE
 Call UTIMAJACCES(DOSVAL)                       : # Suppression des doublons PRFCOD+CODACC+USR dans la table ACCES
 Call UTIMAJINTAPO(DOSVAL)                      : # Ajout champ traduisible et leg
 Call UTIMAJASW1(DOSVAL)                      : # Modif AFCRIGHT
 Call UTIMAJASWK(DOSVAL)                      : # delete AFFLNK=3
 Call UTIAPL(DOSVAL)                      : # Modif APL.ini
 Call PATCH([L]DOSVAL) From UTIDELDEMSRV  :#deletion of DEMSRV parameter 107748
Endif
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
Subprog MAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub MAJSUP
End

$MAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call UTIMAJMODULEABI(DOSVAL)                      : #  Mise a jour module pour les tables ABI
Call UTIMAJAMKSAT(DOSVAL)                         : #  Invalidation des écrans ayant le type de données SAT et/ou ADL
Call UTIMAJIMPNOW(DOSVAL)                         : #  Mise à jour champ IMPNOW dans la table AREPORTX
Call UTIMAJHOMVUE(DOSVAL)                         : #  Mise à jour champ KEYDUP dans la table AVIEWC
Call UTIMAJPARDGI(DOSVAL)                         : #  Mise à jour paramètres ASIGMNT et ACLRLOG dans le dossier X3
Call UTIMAJALOB(DOSVAL)                      : #  Mise a jour CNTTYP tables ABLOB/ACLOB
Call UTIMAJADV901(DOSVAL)                      : # Correction intitulé
Call UTIMAJTABLAN(DOSVAL)                      : # langues iso
Call UTIMAJLANISO(DOSVAL)                      : # langues iso
Call UTIMAJATY([L]DOSVAL)
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

####################################################################################
# Mise à jour archive v7
####################################################################################
Subprog ARCHIVEADX(DOSSIER)
Value Char DOSSIER

Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , COMMAND(250)
Local Char    TRAIT(GLONADC)(30000)
Local Integer I , NBTRAIT , STAT

Call ECR_TRACE("Update process"-time$,0) From GESECRAN

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

# Suppression de l'archive
Call EFFACE(filpath("","archive","atx",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","atx","ind",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","vers","atx",APPLI,"",MACHINE),STAT) From ORDSYS

# Création version de l'archive
System COMMAND=MACHINE+'@archive -n -f -d'-APPLI

# Création de l'archive TRT
System COMMAND=MACHINE+'@archive -d'-APPLI-'-t'-'-c "*"'

# Création de l'archive STC
System COMMAND=MACHINE+'@archive -d'-APPLI-'-o'-'-c "*"'

End

####################################################################################
# Mise à jour archive dossiers historisés
####################################################################################

Subprog MAJARCHIVE_HISTO(DOSSIER)
Value Char DOSSIER

Local Integer STAT
Local Char    HISAPP(250) , MACHINE(80) , APPLI(50) , DOSHIS(250)
Local Char    CHEMIN(250) , REPERT(250) , ORDSYS(250)(1..2) , COMMAND(250) , REP(10)

# Présence d'un dossier histo
HISAPP = ""
Local File =DOSSIER+".ADOVAL" [ADWX_]
Read [ADWX_]ADW0 = "";"";"HISDOS"
If !fstat
 HISAPP  = [F:ADWX_]VALEUR
Endif
If HISAPP=""
 End
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
If MACHINE<>""
 DOSHIS = MACHINE+"@"+HISAPP
Else
 DOSHIS = HISAPP
Endif

#  Création du répertoire STC si inexistant
For REP="STC","RQT"
 CHEMIN = filpath(REP,"","",DOSHIS)
 If filinfo(CHEMIN,0)<=0
  Call MACHINE(CHEMIN,MACHINE,REPERT) From ORDSYS
  If MACHINE<>""
   ORDSYS = MACHINE+"@"
  Else
   ORDSYS = ""
  Endif
  ORDSYS += 'ae_mkdir'-'"'+REPERT+'"'
  System COMMAND=ORDSYS
  If filinfo(CHEMIN,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+CHEMIN,1) From GESECRAN
  Else
   Call ECR_TRACE(mess(11,125,1)-"|"+CHEMIN,0) From GESECRAN : # Création du répertoire
  Endif
 Endif
Next REP

# Création version de l'archive
CHEMIN = filpath("","vers","atx",DOSHIS)
If filinfo(CHEMIN,0)<=0
 ORDSYS(1) = 'archive -n -f -d'-HISAPP
 Call EFFACE(ORDSYS(2),STAT) From ORDSYS
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
Endif

End

####################################################################################
##  Mise a jour type de données ATY
####################################################################################

Subprog MAJ_ATYATY

Local File =[F:ADS]DOSREF+".ATYPE"     [SATY]
Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]

Local Char    TABLE(30)
Local Integer OK

OK = 0
Read [SATY]CODTYP = "ATY"
If !fstat
 Read [ATY]CODTYP = "ATY"
 If !fstat & [F:ATY]LNGTYP>0 & [F:ATY]LNGTYP<[F:SATY]LNGTYP
    OK = 1
    Trbegin [ATY]
        [F:ATY]LNGTYP=[F:SATY]LNGTYP
        Rewrite [F:ATY]
        If fstat
          GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif

Read [SATY]CODTYP = "ABR"
If !fstat
 Read [ATY]CODTYP = "ABR"
 If !fstat & [F:ATY]LNGTYP>0 & [F:ATY]LNGTYP<[F:SATY]LNGTYP
    OK = 1
    Trbegin [ATY]
        [F:ATY]LNGTYP=[F:SATY]LNGTYP
        Rewrite [F:ATY]
        If fstat
          GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif

Close Local File [SATY]
Close Local File [ATY]

Local File =[F:ADS]DOSSIER+".ATABZON"  [ATZ]
Read [ATZ]CODZONE="ATABLE";"ABRFIC"
If !fstat & [F:ATZ]CODTYP="A"
 If [F:ATZ]LONG<8
    OK = 1
    Trbegin [ATZ]
        [F:ATZ]CODTYP="ABR"
        Raz [F:ATZ]LONG
        Rewrite [F:ATZ]
        If fstat
          GOK = 0 : Call FSTA("ATZ") From GLOCK : Goto AB_TR1
        Endif
    Commit
 Endif
Endif
Close Local File [ATZ]


If OK
 Local File =[F:ADS]DOSSIER+".ATABLE"   [ATB]
 Local File =[F:ADS]DOSSIER+".ATABZON"  [ATZ]
 Local File =[F:ADS]DOSSIER+".ATABIND"  [ATI]
 Local File =[F:ADS]DOSSIER+".AINDEX"   [ANX]
 Local File =[F:ADS]DOSSIER+".AMSKPAR"  [AMP]
 Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
 Local File =[F:ADS]DOSSIER+".ATEXTE"   [ATX]
 Local File =[F:ADS]DOSSIER+".ACTIV"    [ACV]
 For TABLE="ATYPE","ATABZON","AMSKZON","ATABLE"
  Call MAJTAB(TABLE,0) From DOSTAB
 Next TABLE
 Close Local File [ATB] , [ATZ] , [ATI] , [ANX] , [AMP] , [ATY] , [ATX] , [ACV]
 Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
 Local File =[F:ADS]DOSREF+".ATYPE"     [SATY]
 Trbegin [ATY]
  For TABLE="AUUID","ADATIM"
   Read [SATY]CODTYP=TABLE
   If !fstat
    Read [ATY]CODTYP=TABLE
    If fstat
     [F:ATY] = [F:SATY]
     Write [ATY]
     If fstat
      GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
     Endif
    Endif
   Endif
  Next TABLE
 Commit
 Close Local File [ATY] , [SATY]
 Call ECR_TRACE("Update data type ATY",0) From GESECRAN
Endif

End

$AB_TR1
Rollback
Return

