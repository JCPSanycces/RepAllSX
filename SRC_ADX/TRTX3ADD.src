#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SAIADRCOM    : Generic address entry                   RMA 04/10/16 #
# ------------------------------------------------------------------- #
#   ABREV: Address screen abreviation                                 #
#   MSG   : Message number for the window title                       #
#           0 = Default title    (4,195,1="Address Entry")            #
#   CHAP  : Chapter number of the message for the window title        #
#           0 = Default title    (4,195,1="Address Entry")            #
# ------------------------------------------------------------------- #
# Output                                                              #
#               ADBFLG = 0 --> Address not modified                   #
#                        1 --> Adresse charged by user from an        #
#                              address code, but not modified         #
#                        2 --> Adresse modified                       #
#######################################################################
$OUV_SAIADRCOM

Local Char     ABREV(GLONAMK)  : ABREV  = PARAM(3)
Local Integer  MSG             : MSG    = val(PARAM(1))
Local Integer  CHAP            : CHAP   = val(PARAM(2))
Local Integer  BPATYP          : BPATYP = val(PARAM(4))
Local Char     BPANUM(GLONBPA) : BPANUM = PARAM(5)
#------ Open files if needed ------#
If !clalev([F:BPA])  Local File BPADDRESS  [BPA] : Endif
If !clalev([F:BPR])  Local File BPARTNER   [BPR] : Endif
If !clalev([F:CPY])  Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
#----- Local variables -----#
Local Char     SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Shortint FLGSAI
#----- Local variables to register the screen initial values -----#
Local Char     NAM(GLONNAM)(2)
Local Char     BPAADD(GLONADR)
Local Char     BPAADDLIG(GLONADL)(3)
Local Char     CRY(GLONCRY)
Local Char     CRYNAM(GLONNCY)
Local Char     SAT(GLONSAT)
Local Char     POSCOD(GLONPOS)
Local Char     CTY(GLONCTY)
#------ Parameter values validation and control ------#
If ABREV="" : FIN=1 : Return : Endif
If MSG=0 | CHAP=0  MSG=4 : CHAP=195 : Endif
Return
#-------------------------------------------#
# Window title #
#-------------------------------------------#
$TIT_SAIADRCOM
TIT=mess(MSG,CHAP,1)
Return
#---------------------------------#
# Window initialization #
#---------------------------------#
$DEB_SAIADRCOM
Raz [M:ADR]
Default Mask "["+ABREV+"]"
[M:ADR]=[M]
[M:ADR]BPATYP = [L]BPATYP
#----- Read tables is needed -----#
If [M:ADR]BPANUM<>[L]BPANUM  Raz [M:ADR] : Endif
Case [M:ADR]BPATYP
  When 1
    If [F:BPR]BPRNUM<>[L]BPANUM
      Read [F:BPR]BPR0=[L]BPANUM : If fstat : Raz [F:BPR] : Endif
    Endif
    If [M:ADR]BPAADD="" : [M:ADR]BPAADD=[F:BPR]BPAADD : Endif
    [M:ADR]BPANUM       = [F:BPR]BPRNUM
  When 2
    If [F:CPY]CPY<>[L]BPANUM
      Read [F:CPY]CPY0=[L]BPANUM : If fstat : Raz [F:CPY] : Endif
    Endif
    If [M:ADR]BPAADD="" : [M:ADR]BPAADD=[F:CPY]BPAADD : Endif
    [M:ADR]BPANUM       = [F:CPY]CPY
  When 3
    If [F:FCY]FCY<>[L]BPANUM
      Read [F:FCY]FCY0=[L]BPANUM : If fstat : Raz [F:FCY] : Endif
    Endif
    If [M:ADR]BPAADD="" : [M:ADR]BPAADD=[F:FCY]BPAADD : Endif
    [M:ADR]BPANUM       = [F:FCY]FCY
  #More can be added when needed
Endcase
[M:ADR]BPANUM=[L]BPANUM
#----- Read the address if necessary -----#
If [M:ADR]ADBFLG=0
  Read [F:BPA]BPA0=[L]BPATYP;[L]BPANUM;[M:ADR]BPAADD
  If fstat : Raz [F:BPA] : Endif
  Case [L]BPATYP
    When 1
      [M:ADR]NAM(0)    = [F:BPR]BPRNAM(0)
      [M:ADR]NAM(1)    = [F:BPR]BPRNAM(1)
    When 2
      [M:ADR]NAM(0)    = [F:CPY]CPYNAM
      [M:ADR]NAM(1)    = ""#[F:CPY]BPRNAM(1)
    When 3
      [M:ADR]NAM(0)    = [F:FCY]FCYNAM
      [M:ADR]NAM(1)    = ""#[F:FCY]BPRNAM(1)
    #More can be added when needed
  Endcase
  [M:ADR]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:ADR]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:ADR]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:ADR]CRY          = [F:BPA]CRY
  [M:ADR]CRYNAM       = [F:BPA]CRYNAM
  [M:ADR]SAT          = [F:BPA]SAT
  [M:ADR]POSCOD       = [F:BPA]POSCOD
  [M:ADR]CTY          = [F:BPA]CTY
  [M:ADR]ADBFLG       = 1
Endif
#----- Backup of the address initial values -----#
[L]=[M:ADR]
#----- Disable field if modification is not authorized -----#
Actzo [ADR]1-99 : FLGSAI=1
If GCONSULT>0
  Diszo [ADR]1-99 : FLGSAI=0
Elsif GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Diszo [ADR]1-99 : FLGSAI=0 : Endif
Endif
Affzo [ADR]1-99
Return
#--------------------------------------#
# Button Enable/Disable                #
#--------------------------------------#
$SETB_SAIADRCOM
If FLGSAI=0
  Call VIREBOUT(CHBOU,"OA") From GOBJET
Endif
Return
#--------------------------------#
# Button OK                      #
#--------------------------------#
$OK_SAIADRCOM
If FLGSAI=0  FIN=1 : Return : Endif

#----- Test if address was modified -----#
If [M:ADR]NAM(0)       <> [L]NAM(0)       |
&  [M:ADR]NAM(1)       <> [L]NAM(1)       |
&  [M:ADR]BPAADDLIG(0) <> [L]BPAADDLIG(0) |
&  [M:ADR]BPAADDLIG(1) <> [L]BPAADDLIG(1) |
&  [M:ADR]BPAADDLIG(2) <> [L]BPAADDLIG(2) |
&  [M:ADR]CRY          <> [L]CRY          |
&  [M:ADR]CRYNAM       <> [L]CRYNAM       |
&  [M:ADR]SAT          <> [L]SAT          |
&  [M:ADR]POSCOD       <> [L]POSCOD       |
&  [M:ADR]CTY          <> [L]CTY
  [M:ADR]ADBFLG=2 : mkstat=4
Endif
#----- Copy the address fields to the calling address screen -----#
If [M:ADR]ADBFLG>0
  Default Mask "["+ABREV+"]"
  [M]=[M:ADR]
Endif
Return
#-------------------------------------#
# Button ABANDON                      #
#-------------------------------------#
$ABA_SAIADRCOM
[M:ADR]=[L] : REP=""
Affzo [ADR]1-99
Return
#------------------------------------------#
# End                                      #
#------------------------------------------#
$FSA_SAIADRCOM
Default Mask SAV_DEFMSK
Return

