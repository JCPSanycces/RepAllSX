######################################################################################

######################################################################################
Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()

Local Integer  L_NOL, OK
L_NOL = nolign - 1
OK=1

Case [M:PRF4]CODTYP(L_NOL)
When "ADI"
 Call CONTSEL("ADI","!",VALEUR,[M:PRF4]VALPAR(L_NOL),mkstat) From CONTOBJ
 If mkstat : End : Endif
When "HRCGD","HRCLV","HRCSP","HRMDP","HRMDT","HRNCT","HRXGD","HRCLC":
 Call CONTSEL(VALEUR,GCURLEG,"") From ="SUB"+[M:PRF4]CODTYP(L_NOL)
 If mkstat : End : Endif
When "ORG"
 Call CONTSEL([M:PRF4]CODOBJ(L_NOL),"I",VALEUR,GCURLEG,mkstat) From CONTOBJ
 If mkstat : End : Endif
When "RUB","CUM","PRF"    :#"VRA" later !
 Call CONTSEL([M:PRF4]CODOBJ(L_NOL),"",VALEUR,GCURLEG,mkstat) From CONTOBJ
 If mkstat : End : Endif
When "VRA"
 Call CONTVRA(VALEUR,GCURLEG) From SUBVRA
 If mkstat : End : Endif
When "EML"
#JASMI - 2016-03-04 - Req 114309 - START
# Call DROIT(VALEUR,"","","","") From DIVPAYE
 Call DROIT(VALEUR,"","","") From DIVPAYE
#JASMI - 2016-03-04 - Req 114309 - END
 If !OK : mkstat=2 : End : Endif
When "FCY"
 If clalev ([F:FCY])=0  : Local File FACILITY  [FCY] : Endif
 Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 Call CONTCPYLEG([F:FCY]LEGCPY,GCURLEG) From TRTX3
 If mkstat : End : Endif
When Default
 If [M:PRF4]CODOBJ(L_NOL)<>"" & !find([M:PRF4]CODOBJ(L_NOL),"PLN")
  Call CONTSEL([M:PRF4]CODOBJ(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
 Elsif [M:PRF4]CODTYP(L_NOL)<>"" & !find([M:PRF4]CODTYP(L_NOL),"PLN")
  Call CONTSEL([M:PRF4]CODTYP(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
 Endif
Endcase

If GPAYE
  [M:PRF4]UNQ(L_NOL) = [M:PRF4]FLD(L_NOL)+"~"+[M:PRF4]CPY(L_NOL)+"~"+[M:PRF4]FCY(L_NOL)+"~"+[M:PRF4]CLLCVT(L_NOL)+"~"+[M:PRF4]POP(L_NOL)
Else
  [M:PRF4]UNQ(L_NOL) = [M:PRF4]FLD(L_NOL)+"~"+[M:PRF4]CPY(L_NOL)+"~"+[M:PRF4]FCY(L_NOL)+"~"+[M:PRF4]POP(L_NOL)
Endif
Call UNICITE([M:PRF4]UNQ(L_NOL),[M:PRF4]UNQ(0..[M:PRF4]NBRDIC-1)) From OBJDIV
If mkstat : GMESSAGE = [M:PRF4]FLD(L_NOL) - GMESSAGE : End : Endif
End

######################################################################################
$CHARGE_DICO
[M:PRF4]LEV(nolign-1) = 2
Read [ATZ]CODZONE="EMPLOCTR";[F:DIC]FLD
If !fstat
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  [M:PRF4]CODTYP(nolign-1) = [F:ATZ]CODTYP
  [M:PRF4]NOLIB(nolign-1)  = [F:ATZ]NOLIB
  L_LONG = [F:ATZ]LONG
  If !L_LONG
   L_LONG = [F:ATY]LNGTYP
  Endif
  [M:PRF4]LONG(nolign-1)   = L_LONG
  [M:PRF4]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
 Else
  Raz [F:ATY]
 Endif : # If !fstat ATY
Else
 Raz [F:ATZ]
Endif
Case [F:ATZ]CODTYP
 When "ADI":
  Read [AMP]CODPAR=2;"EMPLOCTR";[F:DIC]FLD;[F:ATZ]CODTYP
  If !fstat
   # Certains paramètres ADI ont des " ou des '
   [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,'"','')
   [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,"'","")
   [M:PRF4]VALPAR(nolign-1) = [F:AMP]VALPAR
  Endif
 When"ORG","RUB","CUM","PRF" #,"VRA", in the futur :)
  [M:PRF4]VALPAR(nolign-1) ="GCURLEG"
Endcase
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran PRF0) 18/05/2012 12:48:53 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
  Look [PRF]PRF0=VALEUR;[M:PRF0]PRFCOD
  If fstat>1
    Effzo [M:PRF1]EMPMDL
  Endif
Endif

GCURLEG=VALEUR
End


