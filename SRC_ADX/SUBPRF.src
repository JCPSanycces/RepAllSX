Subprog B1_ENAFLG3(VALEUR)
Variable Integer VALEUR
Local Integer L_IJ
For L_IJ = nolign-1 To [M:PRF3]TBL2-1
    [M:PRF3]ENAFLG3(L_IJ)=VALEUR
    Affzo [M:PRF3]ENAFLG3(L_IJ)
Next L_IJ
End
