#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management PRF
#GX3APP
######################################################################################
# SEGAY - 11/09/13 - Bug 92482  test du maxi des tableaux écran
######################################################################################

Raz GPILOBJ
Call OBJET("PRF",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "EXEC"         : Gosub EXEC
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "ANNULE"       : Gosub ANNULE
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "FERME"        : Gosub FERME
 When "AS_PRFCOD"    : Gosub AS_PRFCOD
 When "BS_PRFCOD"    : Gosub BS_PRFCOD
 # JOJAC
 When "SEL_TABLE"    : Gosub SEL_TABLE
 # JOJAC
Endcase
Return

#Before selection on field COD
#############
$AS_PRFCOD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_PRFCOD
# To do nothing if the user doesn't select a record
If [F:PRF]PRFCOD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:PRF0]LEG)>=0 : [M:PRF0]LEG=[F:PRF]LEG: Endif
 GCURLEG=[F:PRF]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:PRF0]LEG)>=0
  GCURLEG=[M:PRF0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
# JOJAC - 2016-02-24 - Req 114309 US 29 - START
  If GNBLEG=1
# JOJAC - 2016-02-24 - Req 114309 US 29 - END
    GCURLEG=GDOSLEG
  Endif

 Endif
Endif
Return

########################################
$OUVRE
Local Integer RUBD,RUBF
If clalev ([F:PRF])=0 : Local File PROFIL   [PRF] : Endif
If clalev ([F:ID])=0  : Local File EMPLOID  [ID] : Endif
If clalev ([F:AD])=0  : Local File EMPLOAD  [AD] : Endif
If !clalev([F:ATZ]) : Local File ATABZON     [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE       [ATY] : Endif
If !clalev([F:AMP]) : Local File AMSKPAR     [AMP] : Endif
If GPAYE=1
 If clalev ([F:CRB])=0 : Local File CALRUB   [CRB] : Endif
 If clalev ([F:CVR])=0 : Local File CALVAR   [CVR] : Endif
 If clalev ([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
 If clalev ([F:VRA])=0 : Local File VARIA    [VRA] : Endif

Endif

# JOJAC - 2016-02-24 - Req 114309 US 29 - START
INTRUBD = mess(16,10708,1) :# De la rubrique de rang
INTRUBF = mess(17,10708,1) :# A la rubrique de rang
# JOJAC - 2016-02-24 - Req 114309 US 29 - START

# JOJAC - 2016-02-24 - Req 114309 US 29 - START
#92876 US2584 Codes comptables si on nouvre pas ici il le fait au SELCAC du au type CAC aprés le CONTCAC
# ce qui réinitialise l'enregistrement et on a une erreur d'enregistrement inexistant.
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - END

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################################
$LIENS
#Multi_leg
GCURLEG=[F:PRF]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]PRFDES,"PROFIL","PRFDES",GCURLEG,[M]PRFCOD) From ATEXTRA
Call LECTEXTRA([M]PRFSHO,"PROFIL","PRFSHO",GCURLEG,[M]PRFCOD) From ATEXTRA
If GPAYE=1
 Gosub CHARGE_RUB
 Gosub CHARGE_VRA
Endif
#[DBA] 24\05\12 :  Waiting new link with accouting module
#If GOPTCANA>0
# [M:PRF1]NBRCCE = GOPTCANA
#Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - START
#If GOPTCANA>0
# [M:PRF1]NBRCCE = GOPTCANA
#Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - END

# JOJAC - 2016-02-24 - Req 114309 US 29 - START
If dim([M:PRF1]DIE)>0
   # Rang 3 dans le menu 2230 Profil
  #JASMI - 2016-02-23 - Req 114309 - START
#   Call CHARG_DIE(3,"","PRF1","NBRCCE","PRF","DIE","CCE","DIE","CCE") From TRTHRCPT
   Call CHARG_DIE(20,"","PRF1","NBRCCE","PRF","DIE","CCE","DIE","CCE") From TRTHRCPT
  #JASMI - 2016-02-23 - Req 114309 - END
   Affzo [PRF1]20
Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - END


#JASMI - 2016-02-23 - Req 114309 - START
#Effzo [M:PRF1]ACCCOD : Grizo [M:PRF1]ACCCOD
#JASMI - 2016-02-23 - Req 114309 - END
#
# JOJAC - 2016-02-24 - Req 114309 US 29 - START
If [F:PRF]FLGSUP=2
 Raz [M:PRF4] : Grizo [M:PRF4]
Else
 Raz [M:PRF4] : Actzo [M:PRF4]
 For [F:HRPFD]PFD0 Where [F:HRPFD]PRFCOD=[M:PRF0]PRFCOD
  nolign = [M:PRF4]NBRDIC+1
    If nolign>=dim([M:PRF4]FLD) : Break : Endif
    [M:PRF4] = [F:HRPFD]
    #83971
    Read [ATY]CODTYP=[F:HRPFD]CODTYP
      If !fstat
      [M:PRF4]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
# JOJAC - 2016-02-24 - Req 114309 US 29 - END

      Endif
    [M:PRF4]NBRDIC += 1
 Next : # [HRPFD]
Endif


Return


########################################
$EXEC
Case GACTION
 When "PRFRUB"
  If GPAYE=1
   If [M:PRF2]TBL=0 : Gosub FIRST_CHARGE : Endif
   For I=0 To [M:PRF2]TBL-1
     If [M:PRF2]RG(I)>=[M:DIA]ROWDEB & [M:PRF2]RG(I)<=[M:DIA]ROWFIN
      [M:PRF2]CALCUL(I) = [M:DIA]OPT
     Endif
   Next I
   Affzo [PRF2]
   mkstat = 4
  Endif
Endcase
Return

########################################
$CHARGE_RUB
nolign = 0
For [F:RUB]RUB1 Where LEG=GCURLEG
 # 92482
 If nolign>=dim([M:PRF2]CODE)
     Call ERREUR(mess(146,10703,1)-":"-mess(26,100,1)) From GESECRAN   # Trop de rubriques : Tableau plein
     Break
 Endif
 nolign += 1
 [M:PRF2]CODE(nolign-1)   = [F:RUB]COD
 [M:PRF2]RG(nolign-1)     = [F:RUB]ROW
 [M:PRF2]TYPRUB(nolign-1)= [F:RUB]TYPRUB
 Look [CRB]CRB0 = [M:PRF2]CODE(nolign-1);[M]PRFCOD;GCURLEG
 If fstat<=2
  [M:PRF2]CALCUL(nolign-1) = 2 :#oui
 Else
  [M:PRF2]CALCUL(nolign-1) = 1 :#non
 Endif
Next
[M:PRF2]TBL = nolign
Return

########################################
$CHARGE_VRA
nolign=0
For [F:CVR]CVR1 Where PRFCOD=[M:PRF0]PRFCOD & LEG = GCURLEG
 # 92482
 If nolign>=dim([M:PRF3]CODVRA)
     Call ERREUR(mess(147,10703,1)-":"-mess(26,100,1)) From GESECRAN   # Trop de variables : Tableau plein
     Break
 Endif
 nolign += 1
 [M:PRF3]CODVRA(nolign-1) = [F:CVR]COD
 [M:PRF3]ENAFLG3(nolign-1) = [F:CVR]ENAFLG
Next
[M:PRF3]TBL2 = nolign
Return

########################################
$CHARGE_ADM
 For [HRPFD]PFD0 Where [F:HRPFD]PRFCOD=[M:PRF0]PRFCOD & LEG = GCURLEG
  nolign = [M:PRF4]NBRDIC+1
  If nolign>=dim([M:PRF4]FLD) : Break : Endif
  [M:PRF4] = [F:HRPFD]
  #83971
  Read [ATY]CODTYP=[F:HRPFD]CODTYP
  If !fstat
   [M:PRF4]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
  Endif
  [M:PRF4]NBRDIC += 1
 Next
Return

########################################
$FIRST_CHARGE
Local Integer IND
IND=0
For [F:RUB]RUB1 Where LEG = GCURLEG
 # 92482
 If IND>=dim([M:PRF2]CODE)
     Call ERREUR(mess(146,10703,1)-":"-mess(26,100,1)) From GESECRAN   # Trop de rubriques : Tableau plein
     Break
 Endif
 [M:PRF2]CODE(IND)   = [F:RUB]COD
 [M:PRF2]RG(IND)     = [F:RUB]ROW
 [M:PRF2]TYPRUB(IND) = [F:RUB]TYPRUB
 IND+=1
Next
[M:PRF2]TBL = IND
Return

########################################
$RAZCRE
#[DBA] 24\05\12 :  Waiting new link with accouting module
#If GOPTCANA>0
# [M:PRF1]NBRCCE = GOPTCANA
# Affzo [PRF1]20
#Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - START
#If GOPTCANA>0
# [M:PRF1]NBRCCE = GOPTCANA
# Affzo [PRF1]20
#Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - end

# JOJAC - 2016-02-24 - Req 114309 US 29 - START
If dim([M:PRF1]DIE)>0
   # Rang 3 dans le menu 2230 Profil
#JASMI - 2016-02-23 - Req 114309 - START
#  Call INIT_DIE(3,"","PRF1","NBRCCE","PRF","DIE","CCE","DIE","CCE") From TRTHRCPT
  Call INIT_DIE(20,"","PRF1","NBRCCE","PRF","DIE","CCE","DIE","CCE") From TRTHRCPT
  Affzo [PRF1]20
#JASMI - 2016-02-23 - Req 114309 - START
Endif
# JOJAC - 2016-02-24 - Req 114309 US 29 - END

Raz GCURLEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Gosub INIRUB

#JASMI - 2016-02-23 - Req 114309 - START
#Effzo [M:PRF1]ACCCOD : Grizo [M:PRF1]ACCCOD
#JASMI - 2016-02-23 - Req 114309 - END
Return

########################################
$RAZDUP
Gosub INIRUB
#ADNGO - 2017-06-13 - US X3-23110 - START
#Raz [M:PRF3] : Affzo [M:PRF3]
#Raz [M:PRF4] : Affzo [M:PRF4]
#ADNGO - 2017-06-13 - US X3-23110 - END
Return

########################################
$APRES_MODIF
Gosub INIRUB
Return

########################################
$INIRUB
If zoncou='LEG'
 Effzo [M:PRF2] : Effzo [M:PRF3]
 Gosub CHARGE_RUB
 Gosub CHARGE_VRA
 Affzo [M:PRF2] : Affzo [M:PRF3]
Endif
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
If GPAYE=1
 Gosub CALRUB
 Gosub CALVRA
Endif
If GOK<1 : Return : Endif
Gosub SUPP_PFD
If GOK<1 : Return : Endif
For nolign=1 To [M:PRF4]NBRDIC
 Raz [F:HRPFD]
 [F:HRPFD] = [M:PRF0]
 [F:HRPFD] = [M:PRF4]
 [F:HRPFD]LEG= GCURLEG
 Write [HRPFD]
 If fstat
  GOK = 0 : Call FSTA("HRPFD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("PROFIL","PRFDES",CLECUR1,"","PROFIL","PRFDES",GCURLEG,[F:PRF]PRFCOD)  From ATEXTRA
 Call DUPTEXTRA("PROFIL","PRFSHO",CLECUR1,"","PROFIL","PRFSHO",GCURLEG,[F:PRF]PRFCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]PRFDES,"PROFIL","PRFDES",GCURLEG,[F:PRF]PRFCOD) From ATEXTRA
Call MAJTEXTRA([M]PRFSHO,"PROFIL","PRFSHO",GCURLEG,[F:PRF]PRFCOD) From ATEXTRA
Return

########################################
$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("PROFIL","PRFDES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call CHGTEXTRA("PROFIL","PRFSHO",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call SETPAR From GENPLAN
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
# JOJAC - 2016-02-24 - Req 114309 US 29 - START
#JASMI - 2017-11-23 - X3-65551 - START
#  Delete [HRPFD] Where [F:HRPFD]PRFCOD=[M:PRF0]PRFCOD
#  If fstat=1
#    GOK=-1 : Call RSTA("PFD",[M:PRF0]PRFCOD) From GLOCK
#    Return
#  Endif
#JASMI - 2017-11-23 - X3-65551 - END
# JOJAC - 2016-02-24 - Req 114309 US 29 - END

  Call SUPTEXTRA("PROFIL","PRFDES",[L]CODE,SUPP) From ATEXTRA
  Call SUPTEXTRA("PROFIL","PRFSHO",[L]CODE,SUPP) From ATEXTRA
  Gosub SUPP_PFD
Return

########################################
$SUPP_PFD
Delete [HRPFD] Where [F:HRPFD]PRFCOD=[M:PRF0]PRFCOD  & LEG = GCURLEG
If fstat=1 : GOK=-1 : Call RSTA("PFD",[M:PRF0]PRFCOD) From GLOCK : Return : Endif
Return

########################################
$CALRUB
# JOJAC - 2016-02-24 - REQ 114309 US 29 - START
Local Integer EXIST
If [M:PRF2]TBL=0
# JOJAC - 2016-02-24 - REQ 114309 US 29 - END
  Delete [CRB] Where PRFCOD=[M]PRFCOD & LEG = GCURLEG
  If fstat=1
    GOK = -1 : GLOCK = "$CALRUB" : Return
  Endif
# JOJAC - 2016-02-24 - REQ 114309 US 29 - START
Endif
# JOJAC - 2016-02-24 - REQ 114309 US 29 - END
For nolign=1 To [M:PRF2]TBL
# JOJAC - 2016-02-24 - REQ 114309 US 29 - START
#JASMI - 2017-11-23 - X3-65551 - START
# Look [CRB]CRB0 = [M:PRF2]CODE(nolign-1);[M:PRF0]PRFCOD
 Look [CRB]CRB0 = [M:PRF2]CODE(nolign-1);[M:PRF0]PRFCOD;GCURLEG
#JASMI - 2017-11-23 - X3-65551 - END
 If !fstat : EXIST=1 : Else EXIST=0 : Endif
# JOJAC - 2016-02-24 - REQ 114309 US 29 - END
 If [M:PRF2]CALCUL(nolign-1) = 2 & !EXIST
  Raz [F:CRB]
  [F:CRB]PRFCOD = [M]PRFCOD
  [F:CRB]COD    = [M:PRF2]CODE(nolign-1)
  [F:CRB]ROW    = [M:PRF2]RG(nolign-1)
  [F:CRB]LEG    = GCURLEG
  Write [CRB]
  If fstat
   GOK = 0 : Call FSTA("CRB") From GLOCK : Break
  Endif
# JOJAC - 2016-02-24 - REQ 114309 US 29 - START
 Elsif [M:PRF2]CALCUL(nolign-1) <>2 & EXIST
#JASMI - 2017-11-23 - X3-65551 - START
#  Delete [CRB] Where COD=[M:PRF2]CODE(nolign-1) & PRFCOD=[M:PRF0]PRFCOD
  Delete [CRB] Where COD=[M:PRF2]CODE(nolign-1) & PRFCOD=[M:PRF0]PRFCOD & LEG=GCURLEG
#JASMI - 2017-11-23 - X3-65551 - END
 # JOJAC - 2016-02-24 - REQ 114309 US 29 - END
 Endif
Next nolign
Return

########################################
$CALVRA
If [M:PRF3]TBL2=0
 Delete [F:CVR]Where PRFCOD=[M:PRF0]PRFCOD & LEG = GCURLEG
 Return
Endif
For nolign=1 To [M:PRF3]TBL2
 Read [CVR]CVR0 = [M:PRF3]CODVRA(nolign-1);[M:PRF0]PRFCOD;GCURLEG
 If !fstat
  [F:CVR]ENAFLG =[M:PRF3]ENAFLG3(nolign-1)
  Rewrite [CVR]
  If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif
 Else
  Raz[F:CVR]
  [F:CVR]COD=[M:PRF3]CODVRA(nolign-1)
  [F:CVR]PRFCOD=[M:PRF0]PRFCOD
  [F:CVR]ENAFLG =[M:PRF3]ENAFLG3(nolign-1)
  [F:CVR]LEG    = GCURLEG
  Write [CVR]
  If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif
 Endif
Next
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# Obsolete since reverse order of main index
## To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONPRF) : Endif
VCOD = CLE1
Return

######################################################################################
## Actions linked to data type PRF
######################################################################################

# Obsolete since reverse order of main index
########################################
#$SEL_TABLE
#Case TABLE
#  When "SELPRF"
#    If clalev ([F:PRF])=0 : Local File PROFIL   [PRF] : Endif
#    OBJET="PRF"
#    START = "[F:PRF]PRFCOD"
#    #Filter based on code legislation
#    If PARAM(1)<>""
#     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:PRF]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
#    Endif
#Endcase
#Return
# JOJAC - 2016-04-22 - REQ 114309 US153 - START


$SEL_TABLE
Case TABLE
  When "SELPRF"
    If clalev ([F:PRF])=0 : Local File PROFIL [PRF] : Endif
    Filter [F:PRF]
    OBJET     = "PRF"
    #START     = "[F:PRF]PRFCOD"
    #EXPSTART  = "[F:PRF]PRFCOD>='"+VALEUR+"'"
    #JASMI - START
#    OPTIONS = "|"
#    SUPP    = VALEUR
    #JASMI - END
    #Filter based on code legislation
    #JASMI - START
    #ADNGO - 2016-11-25 - START
    #If PARAM(1)<>""
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:PRF]LEG="'+PARAM(1)+'" | [F:PRF]LEG="")',"&") From GOBJSUB

      #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:PRF]LEG="'+PARAM(1)+'" | [F:PRF]LEG="")',"&") From GOBJSUB
      If GCURLEG<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:PRF]LEG="'+GCURLEG+'" | [F:PRF]LEG="")',"&") From GOBJSUB
      #ADNGO - 2016-11-25 - END
    Endif
    #CRITERE='[F:PRF]LEG="'+GCURLEG+'"'
    #JASMI - END
Endcase
Return
# JOJAC - 2016-04-22 - REQ 114309 US153 - END

# Obsolete since reverse order of main index
########################################
Subprog CONTPRF(COD)
Variable Char    COD()

If GFONCTION = "GESPRF" | COD="" : End : Endif

#If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif

#If func AFNC.ACTIV("LEG")=0
# LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
# LEG = GCURLEG
#Elsif LEG=""
# Read [F:PRF]PRF0(2)=COD
# If !fstat
#  LEG = [F:PRF]LEG
# Endif
#Endif

#MAPAD RE-Write
#Read [F:PRF]PRF0=LEG;COD
#
#If fstat
# Filter [PRF] Where PRFCOD=COD
# Look [PRF]PRF0 First
# If !fstat
#   # Fiche inexistante pour la législation courante
# GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
# Else  # Fiche inexistante
#    GMESSAGE = [L]COD-":"-mess(23,100,1)
# Endif
# Filter [PRF]
# mkstat = 2 : End
#Endif

#MAPAD - START
If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif

If COD <> ""
  Filter [F:PRF] Where PRFCOD=[L]COD
  Read [F:PRF] First
  Filter [F:PRF]
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:PRF]
      Read [F:PRF]PRF0 = GCURLEG;[L]COD
      If fstat
        Filter [F:PRF] Where PRFCOD=[L]COD
        #Filter [F:PRF] Where PRFCOD=[L]COD & LEG=GCURLEG
        Read [F:PRF] First
        Filter [F:PRF]
        GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:PRF]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:PRF]


#Call CONTROLE("PRF","",COD,GCURLEG,mkstat) From CONTOBJ
#MAPAD-END
End

# Obsolete since reverse order of main index
##################################################
Subprog TUNPRF(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONPRF)
 TOKILL = 1
Endif

If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif

# To update the PRF code after the tunnel order
VCOD = COD

#JASMI - START
#If GNBLEG = 1
# LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
# LEG = GCURLEG
#Elsif LEG=""
# Read [PRF]PRF0 = LEG;VCOD
# If fstat
#  Read [PRF]PRF0(2)=VCOD
#   If !fstat
#     LEG = [F:PRF]LEG
#   Endif
# Endif
#Endif
#JASMI - END

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
#JASMI - START
#  Filter [PRF] Where LEG=[L]LEG
  Filter [PRF] Where LEG=GCURLEG
#JASMI - START
  Read [F:PRF] First
  Filter [PRF]
  If !fstat : VCOD=[F:PRF]PRFCOD : Endif
Else
#JASMI - START
#  Read [PRF]PRF0 = LEG;VCOD
  Read [PRF]PRF0 = GCURLEG;VCOD
#JASMI - START
Endif

#JASMI - START
#If fstat : LEG = "" : Endif
#JASMI - END

#JASMI - START
#Call OBJET("PRF",VCOD,LEG) From GOBJET
Call OBJET("PRF",VCOD,GCURLEG) From GOBJET
#JASMI - START

COD = VCOD

If TOKILL : Kill VCOD : Endif
End


######################################################################################
## Screen PRF
######################################################################################
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 For nolign=1 To [M:PRF2]TBL
  [M:PRF2]CALCUL(nolign-1) = 1
 Next
 For nolign=1 To [M:PRF3]TBL2
  [M:PRF3]ENAFLG3(nolign-1) = 1
 Next
 Raz [M:PRF4]
Endif
End

######################################################################################
## Screen PRF2
######################################################################################
Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODE(0..[M]TBL-1)) From OBJDIV
If mkstat : End : Endif
Call LECTURE("RUB",VALEUR,GCURLEG) From CONTOBJ
[M]RG(nolign-1)    = [F:RUB]ROW
[M]TYPRUB(nolign-1) = [F:RUB]TYPRUB
End

########################################
Subprog C_ROWFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]ROWDEB : mkstat = 1 : Endif
End

########################################
Subprog B2_TBL
Sorta [M:PRF2]TBL [M:PRF2]TBL Order By ((-1)*[M:PRF2]CALCUL([S]indice)), [M:PRF2]RG([S]indice)
Affzo[M:PRF2]
End

######################################################################################
## Screen PRF3
######################################################################################
#Préchargement des variables
Subprog B1_TBL2
Local Integer NBVAR
NBVAR=0
For [VRA]VRA0 Where FLGEMP=2 & LEG=GCURLEG
 OK=1
 If [F:VRA]CODACT<>""
  Read [ACV]CODACT = [F:VRA]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK=0 :   Endif
 Endif
 If OK &  !find([F:VRA]COD,[M:PRF3]CODVRA(0..[M:PRF3]TBL2-1))
  # 92482
  If [M:PRF3]TBL2>=dim([M:PRF3]CODVRA)
      Call ERREUR(mess(147,10703,1)-":"-mess(26,100,1)) From GESECRAN   # Trop de variables : Tableau plein
      Break
  Endif
  [M:PRF3]CODVRA([M:PRF3]TBL2) = [F:VRA]COD
  [M:PRF3]ENAFLG3([M:PRF3]TBL2) = 2
  [M:PRF3]TBL2 += 1
  NBVAR += 1
 Endif
Next
If NBVAR=0
 # Aucune variable a précharger
 Call MESSAGE(mess(90,10702,1)) From GESECRAN
Else
 Sorta [M]TBL2 [M]TBL2 Order By [M:PRF3]CODVRA(indice)
 Affzo 15
 mkstat = 4
Endif
End

########################################
Subprog C_CODVRA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODVRA(0..[M]TBL2-1)) From OBJDIV
If mkstat : End : Endif
End

########################################
Subprog B2_TBL2
Sorta [M:PRF3]TBL2 [M:PRF3]TBL2 Order By
& ([M:PRF3]ENAFLG3(nolign-1)*-1), [M:PRF3]CODVRA(nolign-1)
Affzo[M:PRF3]
End

######################################################################################
## Screen PRF4
######################################################################################
Subprog B1_NBRDIC
Local Integer NB_LIG
Local Decimal L_LONG
Filter [DIC] Where [F:DIC]TBL="EMPLOCTR" & [F:DIC]POTFLG=2
Raz NB_LIG
For [DIC]DIC3
 If [M]NBRDIC>=dim([M:PRF4]FLD)
     # Tableau plein
    Call ERREUR(mess(26,100,1)) From GESECRAN
    Break
 Endif
 If !find([F:DIC]FLD,[M]FLD(0..[M]NBRDIC-1))
  [M]NBRDIC += 1
  nolign = [M]NBRDIC
  [M] = [F:DIC]
  Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
  Gosub CHARGE_DICO
  If GPAYE
    [M:PRF4]UNQ(nolign-1) = [M:PRF4]FLD(nolign-1)+"~"+[M:PRF4]CPY(nolign-1)+"~"+[M:PRF4]FCY(nolign-1)
&                        +"~"+[M:PRF4]CLLCVT(nolign-1)+"~"+[M:PRF4]POP(nolign-1)
  Else
    [M:PRF4]UNQ(nolign-1) = [M:PRF4]FLD(nolign-1)+"~"+[M:PRF4]CPY(nolign-1)+"~"+[M:PRF4]FCY(nolign-1)
&                        +"~"+[M:PRF4]POP(nolign-1)
  Endif
  NB_LIG += 1
 Endif
Next
Filter [DIC]
Affzo [PRF4]
If NB_LIG
 mkstat = 4
Endif
End

#########################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
Read [DIC]DIC0 = VALEUR
If fstat
 GMESSAGE = VALEUR - mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Elsif [F:DIC]ENAFLG=1
 GMESSAGE = VALEUR - mess(106,10702,1) : # Champ inactif
 mkstat = 2 : End
Elsif [F:DIC]TBL<>"EMPLOCTR"
 GMESSAGE = mess(14,10715,1) : # Seule la table EMPLOCTR est utilisable
 mkstat = 2 : End
Endif
If VALEUR<>[M]FLD(nolign-1)
 Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
 [M]TBL(nolign-1) = [F:DIC]TBL
 [M]FRM(nolign-1) = ""
 #83971 : In the If !
 Gosub CHARGE_DICO
Endif
End

######################################################################################
Subprog S_FLD(VALEUR)
Variable Char    VALEUR()

If !GWEBSERV
 Filter [DIC] Where [DIC]TBL="EMPLOCTR"
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "DIC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [DIC]
Endif
Gosub AFF From GSAISIE
End

######################################################################################
Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1)=1 : # ML 10508 Folder
GMENLOC(6)=1 : # ML 10508 Employee
GMENLOC(7)=1 : # ML 10508 Contract
GMENLOC(8)=1 : # ML 10508 Department
GMENLOC(10)=1 : # ML 10508 Profile
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran PRF4) 23/08/2010 15:17:40 (JML)
######################################################################################
Subprog C_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR=9 & [M]FLD(nolign-1)="CLLCVT"
 GMESSAGE = mess(172,10702,1) : # Paramétrage interdit
 mkstat = 2 : End
Endif
End

######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>4 : mkstat=1 : End : Endif
End

######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>5 : mkstat=1 : End : Endif
End

######################################################################################
Subprog AS_CLLCVT(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>9 : mkstat=1 : End : Endif
End

