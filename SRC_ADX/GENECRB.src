#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When "GENECR" : Call AMSK_SPE(APPLI,ECRORI,ECRDES)
Endcase
Return

###########################################################
# Sous-programme permettant d'intervenir
# sur les tables écrans générées
###########################################################
Subprog AMSK_SPE(APPLI,ECRORI,ECRDES)
Value  Char  APPLI
Value  Char  ECRORI
Value  Char  ECRDES

Case ECRORI
 When "SIH4"  : Gosub AMSK_SIH4 From SUBSLX
 When Default
Endcase

End

