#<AdxTL>@(#)5.0.0.0 $Revision$
## Action SOLDNAT
Local Char PARBOUT(30)(1..10)
Local Char VALBOUT(30)
PARBOUT(1) = "VENTEDIV"
PARBOUT(5) = "APN"
PARBOUT(6) = "ASN"
PARBOUT(7) = "20090101"
PARBOUT(8) = "20091231"
PARBOUT(9) = "EUR"
PARBOUT(10) = "2"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"DSOLDNAT","SOLDNAT","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE" : Gosub VERIF
 When "DEBUT" : Gosub SOLDE
Endcase
Return

$VERIF
Local Integer OK, LEDTYP
Local Date    DATDEB, DATFIN
Local Char    CPY (GLONCPY)

CPY    = PARAM(5)
DATDEB = PARAM(7)
DATFIN = PARAM(8)
LEDTYP = val(PARAM(10))
Call CONTEXE(CPY,LEDTYP,DATDEB,DATFIN,OK) From CONSSUB
If !OK : # Période incompatibles sur la société
 GERR=1 : GMESSAGE = mess(11,101,1)-CPY : FIN=1 : Return
Endif

Onerrgo ERREUR From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:BAL])=0 : Local File BALANA     [BLA] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Endif
Return

$SOLDE
Local Char    NAT(GLONCNA), PLAN(GLONCOA), SAC(GLONSAC), GRPSAC(GLONGSC), BPR(GLONBPR)
Local Char    CPY(GLONCPY), FCY(GLONFCY), DEVISE(GLONCUR), DEVLED(GLONCUR)
Local Date    DATDEB, DATFIN,DDEB, DFIN
Local Integer EDEB, EFIN, NBSITE, OK, LEDTYP
Local Decimal EXERCICE, PERIODE
# GH 02/02/00 bug 4189
NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE)
NBSITE = 0

NAT    = PARAM(1)
SAC    = PARAM(2)
GRPSAC = PARAM(3)
BPR    = PARAM(4)
CPY    = PARAM(5)
FCY    = PARAM(6)
DATDEB = PARAM(7)
DATFIN = PARAM(8)
DEVISE = PARAM(9)
LEDTYP = val(PARAM(10))

Call LECLED(CPY,LEDTYP,PLAN,DEVLED) From CPTDIV
Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
Call LECPLAN(CPY,LEDTYP,PLAN) From CPTDIV
If [F:CPY]CPYLEGFLG=2 : # Société Juridique
 Call GETPERSOC(CPY,LEDTYP,DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 Call GETPERSOC(CPY,LEDTYP,DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 #Call SOLDNAT(NAT,CPY,FCY,LEDTYP,DEVLED,DEVISE,EDEB,EFIN,GERR)
 Call SOLDNAT(LEDTYP,PLAN,GRPSAC,SAC,NAT,BPR,CPY,FCY,DEVLED,DEVISE,EDEB,EFIN,GERR)
Else
 For [FGR]FGR0 Where CPY = [L]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  Filter [FIY] Where CPY=[F:FCY]LEGCPY and LEDTYP=[L]LEDTYP
  Read [FIY]FIY0 First
  If DATDEB>=[F:FIY]FIYSTR : DDEB=DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If DATFIN<=[F:FIY]FIYEND : DFIN=DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
  Filter [FIY]
  If DDEB<=DFIN
   NBSITE+=1
   TSITE(NBSITE) = [F:FGR]FCY
  Endif
 Next : # [FGR]
 #Call SOLDNAT2(NAT,NBSITE,TSITE,LEDTYP,DEVLED,DEVISE,DATDEB,DATFIN,GERR)
 Call SOLDNAT2(LEDTYP,PLAN,GRPSAC,SAC,NAT,BPR,NBSITE,TSITE,DEVLED,DEVISE,DATDEB,DATFIN,GERR)
Endif
Affzo
Return

#Subprog SOLDNAT(NATURE,SOCIETE,SITE,LEDTYP,DEVLED,DEVSEL,EXEDEB,EXEFIN,ERR)
Subprog SOLDNAT(LEDTYP,PLAN,GROUPE,COLLEC,NATURE,TIERS,SOCIETE,SITE,DEVLED,DEVSEL,EXEDEB,EXEFIN,ERR)
Value Integer   LEDTYP
Value Char      PLAN
Value Char      GROUPE
Value Char      COLLEC
Value Char      NATURE
Value Char      TIERS
Value Char      SOCIETE
Value Char      SITE
Value Char      DEVLED
Value Char      DEVSEL
Value Integer   EXEDEB
Value Integer   EXEFIN
Variable Integer ERR
Local Integer II , REPONSE
Raz [M:SOL2]
Gosub SOL_NAT
For II=0 To [M:SOL2]NBLIG-1
 [M:SOL2]SOLDEB(II) = SOL_DEB(II)
 [M:SOL2]SOLCRE(II) = SOL_CRE(II)
 [M:SOL2]TOTDEB(II) = TOT_DEB(II)
 [M:SOL2]TOTCRE(II) = TOT_CRE(II)
Next
End

#Subprog SOLDNAT2(NATURE,NBSITE,TSITE,LEDTYP,DEVLED,DEVSEL,DATDEB,DATFIN,ERR)
Subprog SOLDNAT2(LEDTYP,PLAN,GROUPE,COLLEC,NATURE,TIERS,NBSITE,TSITE,DEVLED,DEVSEL,DATDEB,DATFIN,ERR)
Value Integer  LEDTYP
Value Char     PLAN
Value Char     GROUPE
Value Char     COLLEC
Value Char     NATURE
Value Char     TIERS
Value Integer  NBSITE
Value Char     TSITE()(1..)
Value Char     DEVLED
Value Char     DEVSEL
Value Date     DATDEB, DATFIN
Variable Integer ERR
Local Char    SITE(GLONFCY), SOCIETE(GLONCPY)
Local Integer JJ, II , REPONSE
Local Decimal EXEDEB, EXEFIN
Local Decimal EXER, PERIO
Raz [M:SOL2]
For JJ=1 To NBSITE
 SITE = TSITE(JJ)
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE = [F:FCY]LEGCPY
 Call GETPERSOC(SOCIETE,LEDTYP,DATDEB,EXER,PERIO) From CPTSUB
 EXEDEB = EXER
 Call GETPERSOC(SOCIETE,LEDTYP,DATFIN,EXER,PERIO) From CPTSUB
 EXEFIN = EXER
 Gosub SOL_NAT
 For II=0 To [M:SOL2]NBLIG-1
  [M:SOL2]SOLDEB(II) += SOL_DEB(II)
  [M:SOL2]SOLCRE(II) += SOL_CRE(II)
  [M:SOL2]TOTDEB(II) += TOT_DEB(II)
  [M:SOL2]TOTCRE(II) += TOT_CRE(II)
 Next
Next
End

$SOL_NAT
Local Integer I , J , K , SPSTAT , REPONSE , EXERCICE , LIGDEB, GRP
Local Char    BLASIT(GLONFCY) , BLACNA(GLONGAC), BLABPR(GLONBPR), DEVLEC(GLONCUR)
Local Decimal SOLDINI
Local Decimal SOL_DEB(0..dim([M:SOL2]DAT)-1)
Local Decimal SOL_CRE(0..dim([M:SOL2]DAT)-1)
Local Decimal TOT_DEB(0..dim([M:SOL2]DAT)-1)
Local Decimal TOT_CRE(0..dim([M:SOL2]DAT)-1)
Local Integer PMAX

BLABPR = TIERS
BLASIT = SITE

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
DEVLEC = [F:CPY]ACCCUR
GRP=([F:CPY]CPYLEGFLG=1)

Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EXEDEB = 0 : EXEDEB = 1 : Endif : # PP 15/03/02 Idem bug 10413 sur la consultation des comptes
If EXEDEB<EDEB : EDEB = EXEDEB : Endif
EFIN = EXEFIN
PMAX = dim([F:BLA]DEB)-1

SOLDINI = 0
[M:SOL2]NBLIG = 0
Raz SOL_DEB, SOL_CRE, TOT_DEB, TOT_CRE

Call LEC_COA(PLAN) From CPTLEC
For EXERCICE=EDEB To EFIN

 If EXERCICE>=EXEDEB
  LIGDEB = [M:SOL2]NBLIG
  For [PER]PER0 Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FIYNUM=EXERCICE
   [M:SOL2]DAT([M:SOL2]NBLIG)= [F:PER]PEREND
   [M:SOL2]NBLIG += 1
  Next
 Endif

 If EXERCICE>EXEDEB
  For I=LIGDEB To [M:SOL2]NBLIG-1
   SOL_DEB(I) = SOL_DEB(LIGDEB-1)
  Next I
 Elsif EXERCICE=EXEDEB
  For I=LIGDEB To [M:SOL2]NBLIG-1
   SOL_DEB(I) = SOLDINI
  Next I
 Endif

 If NATURE<>""
  Call LEC_GAC(NATURE, PLAN) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
  If [F:CLS]ERA=2 or EXERCICE=EFIN
   BLACNA=NATURE : Raz BLABPR : Gosub CALBLA
  Endif
 Else
  If COLLEC<>""
   Read [GAC]GAC1 = PLAN;COLLEC
   Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
   If [F:CLS]ERA=2 or EXERCICE=EFIN
    BLACNA=[F:GAC]ACC : BLABPR=TIERS : Gosub CALBLA
   Endif
  Elsif GROUPE<>""
   For [GSC]GSC0 Where COA=PLAN & GRU=GROUPE
    Read [GAC]GAC1 = PLAN;[F:GSC]SAC
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BLACNA=[F:GAC]ACC : BLABPR=TIERS : Gosub CALBLA
    Endif
   Next
  Else
   For [GAC]GAC1 Where COA=PLAN & ACCSHO>""
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BLACNA=[F:GAC]ACC : BLABPR=TIERS : Gosub CALBLA
    Endif
   Next
  Endif
 Endif
Next EXERCICE
Return


$CALBLA
 If DEVSEL<>"" & !GRP
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BLASIT & ACC=BLACNA & BPR=BLABPR
&                   & FIY=EXERCICE & CUR=DEVSEL
 Else
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BLASIT & ACC=BLACNA & BPR=BLABPR
&                   & FIY=EXERCICE
 Endif
 For [BLA]BLA0
  Gosub CUMSOLDE
 Next
Filter [BLA]
Return

$CUMSOLDE
If EXERCICE<EXEDEB
 If EXERCICE=EDEB
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BLA]DEB(0..PMAX))-sum([F:BLA]CDT(0..PMAX))
  Else
   SOLDINI += sum([F:BLA]DEBLED(0..PMAX))-sum([F:BLA]CDTLED(0..PMAX))
  Endif
 Else
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BLA]DEB(1..PMAX))-sum([F:BLA]CDT(1..PMAX))
  Else
   SOLDINI += sum([F:BLA]DEBLED(1..PMAX))-sum([F:BLA]CDTLED(1..PMAX))
  Endif
 Endif
Else
 For I=LIGDEB To [M:SOL2]NBLIG-1
  J = I-LIGDEB+1
  If EXERCICE=EDEB
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BLA]DEB(0..J))-sum([F:BLA]CDT(0..J))
   Else
    SOL_DEB(I) += sum([F:BLA]DEBLED(0..J))-sum([F:BLA]CDTLED(0..J))
   Endif
  Else
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BLA]DEB(1..J))-sum([F:BLA]CDT(1..J))
   Else
    SOL_DEB(I) += sum([F:BLA]DEBLED(1..J))-sum([F:BLA]CDTLED(1..J))
   Endif
  Endif
  If DEVSEL<>"" & !GRP
   TOT_DEB(I) += [F:BLA]DEB(J)
   TOT_CRE(I) += [F:BLA]CDT(J)
  Else
   TOT_DEB(I) += [F:BLA]DEBLED(J)
   TOT_CRE(I) += [F:BLA]CDTLED(J)
  Endif
 Next I
Endif
Return

