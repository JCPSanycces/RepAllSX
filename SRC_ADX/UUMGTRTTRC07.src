#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC07   Migration de la table BPCUSTOMER       Module TC        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC07") From LECFIC
  Endif
  #Call RAZ_UUMGTRTTRC07(DOSSIER)
  Call MAJ_UUMGTRTTRC07(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC07(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---
Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMBPCM, WNAMBPDM
Call MIGTABNAME (DOSSIER,"BPCUSTOMER",WNAMBPCM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"BPDLVCUST",WNAMBPDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPCM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMBPDM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif


Local Integer ERR, NBCOMMIT
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
#Local Char WTAB_BPC (100) (adxwrb)
#Local Char WTAB_BPD (100) (adxwrb)
#Local Shortint WCPT_BPC, WCPT_BPD

Call ECR_TIME("UUMGTRTTRC07 tables BPC Process : Update BPC") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC07 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BPCUSTOMER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"BPDLVCUST",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"    [BPC]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPCM]) = 0 : Local File =DOSSIER+"."+WNAMBPCM   [BPCM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"    [BPD]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPDM])  = 0 : Local File =DOSSIER+"."+WNAMBPDM    [BPDM]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPR]) = 0 : Local File =DOSSIER+".BPARTNER"   [BPR] : Endif   # Tiers
If clalev([F:BPR0]) = 0 : Local File =DOSSIER+".BPARTNER"   [BPR0] : Endif   # Tiers

# FGR 16/07/2015 : X3SUIVI106944 (début)
If clalev([F:NTS]) = 0 : Local File =DOSSIER+".NOTE"      [NTS] : Endif
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"   [AXX] : Endif
Local File =DOSSIER+".ATEXTRA"   [AXX]   # Note FGR : ouvrir en local la table est déjà ouverte sur le dossier racine
If clalev([F:NTG]) = 0 : Local File =DOSSIER+".NOTCATEG"  [NTG] : Endif
If clalev([F:ATI]) = 0 : Local File =DOSSIER+".ATABIND"   [ATI] : Endif
If clalev([F:AST]) = 0 : Local File =DOSSIER+".APLSTD"    [AST] : Endif
# FGR 16/07/2015 : X3SUIVI106944 (fin)

#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
Local Char WTAB_BPC (100) (adxwrb)
Local Char WTAB_BPD (100) (adxwrb)
Local Shortint WCPT_BPC, WCPT_BPD
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID,NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT
Local Char WBPDADD

# Déclaration des variables communes de travail
Local Integer I, J

#Lecture de la table CADIEDEF
Local File =[F:ADS]DOSSIER+".CADIEDEF"     [CDI]
Local Integer NBCDI : NBCDI=nbrecord([CDI])
Local Char WDIE(GLONDIE)(0..20)
Local Integer WNBRDIE
Local Integer WI
Raz WI
Read [CDI]CDI0 = 2
  If !fstat
    WNBRDIE = [F:CDI]NBRDIE
    For WI=0 To [F:CDI]NBRDIE-1
      WDIE(WI)=[F:CDI]DIE(WI)
    Next
  Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

  # --------------------------------------
  # FGR 16/07/2015 : X3SUIVI106944 (début)
  # version < V7, maj des champs v7
  If val(VERSION)<GMIGX3VER70 Then
    # On regardes si les catégories CLIENT et PROSPECT existent.
    # Si l'une ou l'autre n'existent pas on ne traitera pas la partie correspondante ici. On pourra lancer à la main UTITC44.
    Local Char WNOTA(250)
    Local Integer INTGIDX
    Local Char SNTGCOD_BPC(type([F:NTG]NTGCOD)-10)   # Client
    Local Char SNTGCOD_BPP(type([F:NTG]NTGCOD)-10)   # Prospect

    SNTGCOD_BPC = left$(toupper(ctrans(mess(78,117,1))),  type([F:NTG]NTGCOD)-10)    # Client
    SNTGCOD_BPP = left$(toupper(ctrans(mess(240,196,1))), type([F:NTG]NTGCOD)-10)    # Prospe
    # ------------------------------
    INTGIDX = 0
    Read [ATI]CODIND="NOTCATEG";"NTG0"
    If fstat Then
      Raz [F:ATI]
    Endif
    If [F:ATI]DESCRIPT = "NTGCOD+NTGTYP" Then
      INTGIDX = 1  # Nouvel index
    Elsif [F:ATI]DESCRIPT = "NTGTYP+NTGCOD" Then
      INTGIDX = 2  # Ancien index
    Endif
    If INTGIDX = 0 Then
      # Cas où ça ne serait aucun index : on ne saurait pas lire ! Donc on sort
      Raz SNTGCOD_BPC
      Raz SNTGCOD_BPP
    Endif
    # ------------------------------
    If SNTGCOD_BPC <> "" Then
      If INTGIDX = 1 Then
        Read [F:NTG]NTG0=SNTGCOD_BPC;2
      Else
        Read [F:NTG]NTG0=2;SNTGCOD_BPC
      Endif
      If fstat Then
        Raz SNTGCOD_BPC
      Endif
    Endif
    # ------------------------------
    If SNTGCOD_BPP <> "" Then
      If INTGIDX = 1 Then
        Read [F:NTG]NTG0=SNTGCOD_BPP;2
      Else
        Read [F:NTG]NTG0=2;SNTGCOD_BPP
      Endif
      If fstat Then
        Raz SNTGCOD_BPP
      Endif
    Endif
    # ------------------------------
  Endif
  # FGR 16/07/2015 : X3SUIVI106944 (fin)
  # --------------------------------------

#-----  Lien des tables clients et clients livrés-----#
Link [BPCM] With [BPR]BPR0~=[F:BPCM]BPCNUM
&    As [LNK]
&    Order By Key CLE = [F:BPCM]BPCPYR;[F:BPCM]BPCNUM


# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC07" : FILTRELIN=0 : Raz CRITERESPE :Raz HINTSPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPC00
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:BPCM]BPCPYR=TABMIGKEY(1) & [F:BPCM]BPCNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:BPCM]BPCPYR>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [BPC],[BPD]
GOK = 1

For [LNK ]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC07" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BPC
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_BPC
  Endif

  [F:BPC] = [F:BPCM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_BPC
    If GOK<1 : Break : Endif
  Endif
  # version < V7, maj des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_BPC
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  Raz WBPDADD
  For [BPDM] Where [F:BPDM]BPCNUM = [F:BPCM]BPCNUM
    #rupture par ligne de facture
    # version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BPD
    Endif
    # version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_BPD
    Endif
    [F:BPD] = [F:BPDM]

    #Appel proc de migration sur detail
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_BPD  # FGR 17/04/2014 : X3SUIVI97099 : pas MAJV7_BPD
    Endif
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_BPD
    Endif
    #--- Issue 108760 by TS
    #If NEWMOTEUR
    #    Gosub BPD_STK : # pour stocker ref
    #    WriteB [F:BPD]
    #Else
    #    Write [BPD]
    #Endif
    #If fstat
    #    If NEWMOTEUR & adxwrb>1
    #      Call ECR_TRACE("File BPDLVCUST, Error ="-num$(fstat),1) From GESECRAN
    #      Gosub BPD_ERRTRA : # pour afficher les ref
    #    Else
    #      Call ECR_TRACE("File BPDLVCUST(BPCNUM/BPAADD)"-[F:BPD]BPCNUM-[F:BPD]BPAADD+", Error ="-num$(fstat),1) From GESECRAN
    #    Endif
    #    GOK=0 : Break
    #Endif
    Gosub BPD_STK : # pour stocker ref
    WriteB [F:BPD]
    If fstat
        Call ECR_TRACE("File BPDLVCUST, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    #---
  Next
  [F:BPC]BPDADD=WBPDADD

  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub BPC_STK : # pour stocker ref
  #    WriteB [F:BPC]
  #Else
  #    Write [F:BPC]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub BPC_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File BPCUSTOMER(BPCNUM)"-[F:BPC]BPCNUM+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub BPC_STK : # pour stocker ref
  WriteB [F:BPC]
  If fstat
    Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
    Gosub BPC_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:BPCM]BPCPYR
    TABMIGKEY(2) = [F:BPCM]BPCNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC07",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:BPC]
    If fstat
        Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:BPD]
    If fstat
        Call ECR_TRACE("File BPDLVCUST, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPD_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    # FGR 03/11/2015 : X3SUIVI112252 (début)
    #    # --------------------------------------
    #    # FGR 16/07/2015 : X3SUIVI106944 (début)
    #    # version < V7, maj des champs v7
    #    If val(VERSION)<GMIGX3VER70 Then
    #      Flush [F:NTS]
    #      If fstat
    #          Call ECR_TRACE("File NOTE, Error ="-num$(fstat),1) From GESECRAN
    #          Gosub BPC_ERRTRA : # pour afficher les ref
    #          GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    #      Endif
    #    Endif
    #    # FGR 16/07/2015 : X3SUIVI106944 (fin)
    #    # --------------------------------------
    # FGR 03/11/2015 : X3SUIVI112252 (début)
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(3)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC07",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_BPC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPC]
Close Local File [BPCM]
Close Local File [BPD]
Close Local File [BPDM]
Close Local File [BPR]
# FGR 16/07/2015 : X3SUIVI106944 (début)
Close Local File [NTS]
Close Local File [AXX]
Close Local File [NTG]
Close Local File [ATI]
Close Local File [AST]
# FGR 16/07/2015 : X3SUIVI106944 (fin)

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPCUSTOMER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"BPDLVCUST",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC07") From TRTMIG
Call ECR_TIME("UUMGTRTTRC07 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$RAZV6_BPC
Raz [F:BPC]BPAADD
Raz [F:BPC]BPAPYR
Raz [F:BPC]BPCRSK
Raz [F:BPC]BPCSNCDAT
Raz [F:BPC]BPDADD
Raz [F:BPC]CNTNAM
If dim([F:BPC]CRESTP)>0 Raz [F:BPC]CRESTP Endif
Raz [F:BPC]CUR
Raz [F:BPC]DIE
If dim([F:BPC]IDTSGL)>0 Raz [F:BPC]IDTSGL : Endif
If dim([F:BPC]UPDSTP)>0 Raz [F:BPC]UPDSTP : Endif
Return
################################################
$RAZV7_BPC
If dim([F:BPC]DAYMON1)>0 Raz [F:BPC]DAYMON1 Endif
If dim([F:BPC]DAYMON2)>0 Raz [F:BPC]DAYMON2 Endif
If dim([F:BPC]DAYMON3)>0 Raz [F:BPC]DAYMON3 Endif
If dim([F:BPC]DAYMON4)>0 Raz [F:BPC]DAYMON4 Endif
If dim([F:BPC]DAYMON5)>0 Raz [F:BPC]DAYMON5 Endif
If dim([F:BPC]DAYMON6)>0 Raz [F:BPC]DAYMON6 Endif
If dim([F:BPC]UVYCOD2)>0 Raz [F:BPC]UVYCOD2 Endif
Return
################################################
$RAZV6_BPD
If dim([F:BPD]CRESTP)>0 Raz [F:BPD]CRESTP Endif
Raz [F:BPD]EECNUM
Raz [F:BPD]ENAFLG
Raz [F:BPD]FFWADD
Raz [F:BPD]FFWNUM
Raz [F:BPD]ICTCTY
If dim([F:BPD]IDTSGL)>0 Raz [F:BPD]IDTSGL : Endif
If dim([F:BPD]UPDSTP)>0 Raz [F:BPD]UPDSTP : Endif
Raz [F:BPD]VACBPR
Return
################################################
$RAZV7_BPD
Return
################################################
$MAJV6_BPC
Gosub RECUP_BPR
Return
################################################
$MAJV7_BPC
If dim([F:BPC]YFDIA1)>0  [F:BPC]DAYMON(0) = [F:BPC]YFDIA1 Endif
If dim([F:BPC]YFDIA2)>0  [F:BPC]DAYMON(1) = [F:BPC]YFDIA2 Endif
If dim([F:BPC]YFDIA3)>0  [F:BPC]DAYMON(2) = [F:BPC]YFDIA3 Endif
If dim([F:BPC]YFDIA4)>0  [F:BPC]DAYMON(3) = [F:BPC]YFDIA4 Endif
If dim([F:BPC]UVYCOD2)>0 [F:BPC]UVYCOD2   = [F:BPC]UVYCOD2 Endif

  # --------------------------------------
  # FGR 16/07/2015 : X3SUIVI106944 (début)
  If [F:BPC]BPCREM <> "" and (([F:BPC]BPCTYP < 4 and SNTGCOD_BPC <> "") or ([F:BPC]BPCTYP = 4 and SNTGCOD_BPP <> "")) Then
  # -----------------------------------
    WNOTA = left$([F:BPC]BPCNUM,type([F:NTS]NTSCOD)-10)
    # ----------------------
    If [F:BPC]BPCTYP < 4 Then
      SKEY2 = WNOTA + "~" + "2" + "~" + "" + "~" + SNTGCOD_BPC
      Read [F:NTS]NTS0=[F:BPC]BPCNUM;SKEY2
    Else
      SKEY2 = WNOTA + "~" + "2" + "~" + "" + "~" + SNTGCOD_BPP
      Read [F:NTS]NTS0=[F:BPC]BPCNUM;SKEY2
    Endif
    If fstat Then
      Raz [F:NTS]
      #--------------------------
      [F:NTS]CODE = [F:BPC]BPCNUM
      [F:NTS]NTSCOD = WNOTA
      [F:NTS]NTGTYP = 2
      If [F:BPC]BPCTYP < 4 Then
        [F:NTS]NTGCOD = SNTGCOD_BPC                                        # Customer
      Else
        [F:NTS]NTGCOD = SNTGCOD_BPP                                        # Prospect
      Endif
      [F:NTS]AUTODISP = 2                                                  # Auto display
      [F:NTS]BPCNUM = [F:BPC]BPCNUM
      If [F:BPC]BPCTYP < 4 Then
        [F:NTS]EFFDAT = [F:BPC]BPCSNCDAT
      Else
        [F:NTS]EFFDAT = [F:BPC]CREDAT
      Endif
      [F:NTS]ENDDAT = gdat$(day(date$),month(date$),year(date$)+10)        # Valable 10 ans par défaut (?)
      [F:NTS]PRIORITY = 1
      [F:NTS]NOTE = [F:BPC]BPCREM
      #
      If dim([F:NTS]NTSCOD2) >= 0 Then
        [F:NTS]NTSCOD2 = [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD
      Endif
      Write [F:NTS]
      If fstat Then
        # FGR 03/11/2015 : X3SUIVI112252 (début)
        #        #--- Issue 108760 by TS
        #        #If NEWMOTEUR & adxwrb>1
        #          Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
        #          Gosub BPC_ERRTRA : # pour afficher les ref
        #        #--- Issue 108760 by TS
        #        #Else
        #        #  Call ECR_TRACE("File BPCUSTOMER(BPCNUM)"-[F:BPC]BPCNUM+", Error ="-num$(fstat),1) From GESECRAN
        #        #Endif
        #        #---
        Call ECR_TRACE("File BPCUSTOMER(BPCNUM)"-[F:BPC]BPCNUM+", Error ="-num$(fstat),1) From GESECRAN
        # FGR 03/11/2015 : X3SUIVI112252 (fin)
        GOK = 0
        Return     ### S'il y a une erreur on part d'ici donc BPCREM reste différent de ""
      Else
        If [F:BPC]BPCTYP < 4 Then
          Call TRANSLATED_FIELD(78, 117, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
          Call TRANSLATED_FIELD(78, 117, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
        Else
          Call TRANSLATED_FIELD(240, 196, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
          Call TRANSLATED_FIELD(240, 196, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
        Endif
      Endif
    Endif
    # -----------------------------------
    [F:BPC]BPCREM = ""
    # -----------------------------------
  Endif
  # FGR 16/07/2015 : X3SUIVI106944 (fin)
  # --------------------------------------
Return
################################################
$MAJV6_BPD
If [F:BPC]BPCSTA=2 [F:BPD]ENAFLG=2 Else [F:BPD]ENAFLG=1 Endif
If [F:BPD]ENAFLG=2
  If WBPDADD="" WBPDADD=[F:BPD]BPAADD Endif
  If [F:BPD]BPAADD=[F:BPC]BPAADD WBPDADD=[F:BPD]BPAADD Endif
Endif
Return
################################################
$MAJV7_BPD
Return
################################################
$RECUP_BPR
If [F:BPC]BPCPYR<>"" & [F:BPC]BPAPYR=""
  If [F:BPR]BPRNUM<>[F:BPC]BPCPYR
    If  [F:BPR0]BPRNUM<>[F:BPC]BPCPYR
      Read [BPR0]BPR0=[F:BPC]BPCPYR : If fstat Raz [F:BPR0] Endif
      [F:BPC]BPAPYR=[F:BPR0]BPAADD
    Endif
  Else
    [F:BPC]BPAPYR=[F:BPR]BPAADD
  Endif
Endif
# Issue 84263 - 2013-04-30 by MAE : initialisation de la date "Client depuis le"
If [F:BPC]BPCPYR<>"4" and [F:BPC]BPCSNCDAT = [0/0/0] and [F:BPC]CREDAT <> [0/0/0]
  [F:BPC]BPCSNCDAT = [F:BPC]CREDAT
Endif
# Init. tiers risque avec le client facture car jusqu'à présent le ctrl encours est fait sur le client facture
If [F:BPC]BPCRSK="" [F:BPC]BPCRSK=[F:BPC]BPCINV Endif
If [F:BPC]CUR="" | [F:BPC]BPAADD="" | [F:BPC]CNTNAM=""
  If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
    Read [BPR]BPR0=[F:BPC]BPCNUM : If fstat Raz [F:BPR] Endif
  Endif
  If [F:BPC]CUR=""    [F:BPC]CUR=[F:BPR]CUR : Endif
  If [F:BPC]BPAADD="" [F:BPC]BPAADD=[F:BPR]BPAADD : Endif
  If [F:BPC]CNTNAM="" [F:BPC]CNTNAM=[F:BPR]CNTNAM : Endif
Endif
#mise à jour des sections analytiques
For WI=0 To WNBRDIE -1
  If WI<dim([F:BPC]DIE)
     If [F:BPC]DIE(WI)="" [F:BPC]DIE(WI)=WDIE(WI) : Endif
  Else
     Break
  Endif
Next
Return


################################################
$BPC_STK
Call STK (WTAB_BPC,WCPT_BPC,[F:BPC]BPCNUM) From TRTMIG
Return
$BPD_STK
Call STK (WTAB_BPD,WCPT_BPD,[F:BPD]BPCNUM-'/'-[F:BPD]BPAADD) From TRTMIG
Return
##############################################################################################
$BPC_ERRTRA
Call ERRTRA (WTAB_BPC,WCPT_BPC,"File BPCUSTOMER(BPCNUM)=") From TRTMIG
Return
$BPD_ERRTRA
Call ERRTRA (WTAB_BPD,WCPT_BPD,"File BPDLVCUST(BPCNUM/BPAADD)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC07(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC07(APPLI)
End
#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC07(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMBPCM,WNAMBPDM
Call MIGTABNAME (DOSSIER,"BPCUSTOMER",WNAMBPCM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"BPDLVCUST",WNAMBPDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPCM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif
If filinfo(filpath("FIL",WNAMBPDM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"BPCUSTOMER",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"BPDLVCUST",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC07",ERR) From TRTMIG

End

