#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTINCS201810003
# Issue X3-112819 - 2018-10-17 by BAKHA : delete obsolete class for NCS
###################################################################################################
Local Char DOSSIER(30)

    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
        If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
        Read [ADS]DOSSIER=[L]DOSSIER
        If fstat Then
            Raz [F:ADS]
        Endif
        Call TEMPON("O") From GESECRAN
        Call OUVRE_TRACE("Deletion of obsolete class for NCS") From LECFIC
        # -------------------------
        Call MAJ_UTINCS201810003(DOSSIER)
        # -------------------------
        Call TEMPOFF From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
End

##########################################################################
Subprog MAJ_UTINCS201810003(DOSSIER)
Value Char DOSSIER

    Local File =DOSSIER + ".ACLASSE" [ACLAS]
    Local File =DOSSIER + ".ACLAFLD" [ACLAF]
    Local File =DOSSIER + ".ACLAPARFLD" [ACLFP]
    Local File =DOSSIER + ".ACLAMET" [ACLAM]
    Local File =DOSSIER + ".ACLAPARDEF" [ACLPD]
    Local File =DOSSIER + ".ACLAMETSTD" [ACLAT]
    Local File =DOSSIER + ".ACLALNK" [ACLAK]
    Local File =DOSSIER + ".ACLAMAP" [ACLAKP]
    Local File =DOSSIER + ".ACLAOPT" [ACLAO]
    Local File =DOSSIER + ".ACLACOL" [ACLAC]
    Local File =DOSSIER + ".ACLASSE" [ACLA]

    Local Char CLANAME(20)(30)
    Local Char CODE(20)
    Local Integer IERR
    Local Integer COMPTEUR
    IERR = 0
    COMPTEUR = 0

    Call ECR_TRACE("MAJ_UTINCS201810003: Process Start on : "+DOSSIER,0) From GESECRAN

    CLANAME(0) = "CCMNCSDOC"

    Trbegin [ACLA]
    # Delete obsolete classes for NCS
    For I = 0 To 0
        Read [ACLA]ACLA0=CLANAME(I)
        If fstat = 0
            [L]COMPTEUR += 1
            Call ECR_TRACE("MAJ_UTINCS201810003: Deleting class - " + CLANAME(I), 0) From GESECRAN
            Delete [ACLAO] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAO",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAC] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAC",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAM] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAM",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAF] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAF",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLPD] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLPD",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAT] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAT",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAK] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAK",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLAKP] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLAKP",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLFP] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLFP",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif
            Delete [ACLA] Where CODCLA=CLANAME(I)
            If fstat=1  : GOK=-1 : Call RSTA("ACLA",CLANAME(I)) From GLOCK : [L]IERR = 1 : Break : Endif

        Endif
    Next I

    If [L]IERR = 0 Then
        Commit
        Call ECR_TRACE("MAJ_UTINCS201810003 :" - num$([L]COMPTEUR) - "records processed",0) From GESECRAN
    Else
        Rollback
        Call ECR_TRACE("MAJ_UTINCS201810003 :" - num$([L]COMPTEUR) - "records processed with error(s).", 0) From GESECRAN
    Endif

    Call ECR_TRACE("MAJ_UTINCS201810003: Process End", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810003(DOSSIER)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810003(DOSSIER)

End

