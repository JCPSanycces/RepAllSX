########################################################################
# Traitement des ordres
$TRT_OF
#Call TRT_WST('ORO',[M:DIA]MFGFCY,[M:DIA]MFGFCY,[F:ORO]TWCPIT,[F:ORO]MWSPIT,[F:ORO]WSTPIT ,[F:ORO]RPLPIT,"ZOPTCPV2",OK) From PITWST
Call TRT_WST('ORO',[M:DIA]MFGFCY,[M:DIA]MFGFCY,[F:ORO]TWCPIT,[F:ORO]MWSPIT,[F:ORO]WSTPIT ,[F:ORO]RPLPIT,"",OK) From PITWST
Call TRT_OF('ORO',[M:DIA]MFGFCY,"",[F:ORO]OPEPIT,"",[F:ORO]ITMPIT,
&                [F:ORO]BPCPIT,[F:ORO]PJTPIT,[F:ORO]ORDPIT,
&                [F:ORO]BOMPIT,[F:ORO]GRUBOMFLG,[F:ORO]POFPIT,[F:ORO]STOPIT,
&                [F:ORO]RSSPIT,
&                CRITERE1,CRITERE2,[M:DIA]FORMULE,
&               [M:DIA]TRACE1,[M:DIA]TRTMOD,[M:DIA]CALSTRDAT,WENDDAT,NBOF,OK) From PITMFG
Return


########################################################################
# Contrôle horizon sélectionné (dépassement)
$CHK_DATE
  Local Integer WCALDAYNBR
# si dates incohérentes, on force ...
  # calcul horizon en fonction des marges amont/aval
  [M:DIA]CALSTRDAT = [M:DIA]STRDAT - (GOPTAMMAR * 7)
  WCALDAYNBR = ((GOPTAVMAR*7) + [M:DIA]ENDDAT) - [M:DIA]CALSTRDAT

  WENDDAT = [M:DIA]CALSTRDAT + WCALDAYNBR

  # calcul date maximum pour un horizon limite de 2 ans
  WENDDATMAX = gdat$(day([M:DIA]CALSTRDAT),month([M:DIA]CALSTRDAT),year([M:DIA]CALSTRDAT)+2)

  # 03.06 35472
  If WENDDAT > WENDDATMAX
    # si dépassement, on force 2 ans et on écrit une trace
    WCALDAYNBR = WENDDATMAX - [M:DIA]CALSTRDAT
    [M:DIA]STRDAT = [M:DIA]CALSTRDAT + (GOPTAMMAR * 7)
    [M:DIA]ENDDAT = [M:DIA]CALSTRDAT + WCALDAYNBR
    WENDDAT       = [M:DIA]ENDDAT
    If [M:DIA]TRACE1 = 2
      WMESS = mess(139,193,1)
      Call ECR_TRACE(WMESS,2) From GESECRAN
      WMESS = mess(306,197,1)-tolower(mess(94,100,1))-format$(GFMD,[M:DIA]CALSTRDAT)-
&             tolower(mess(95,100,1))-format$(GFMD,WENDDATMAX)
      Call ECR_TRACE(WMESS,1) From GESECRAN
      Raz WMESS
    Endif
  Endif
Return

########################################################################
# Préparation du filtre sur la table encours (WOx)
$SEL_OF
  Raz CRITERE
  Raz CRITERE1
  Raz CRITERE2

  If [M:DIA]WOSFLG = 2
    Case [M:DIA]MRPFLG
      When 1:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=2"
      When 2:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=1"
      When 3:     CRITERE  = "[F:OPS]OPSSTA=3"
    Endcase
    Gosub LOAD_CRITERE
  Endif

  If [M:DIA]WOPFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=2"
    Gosub LOAD_CRITERE
  Endif

  If [M:DIA]WOFFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=1"
    Gosub LOAD_CRITERE
  Endif

  # fin de la première partie
  CRITERE1 += ")"

  #----------------------------------------------------------------------------------------------
  GPOINT = "OPTDATSEL"
  Gosub  ENTREE From EXEFNC
  If !GPE
    CRITERE = "[F:OPS]OPESTR>=[M:DIA]CALSTRDAT"
    Gosub LOAD_CRITERE2
    CRITERE = "[F:OPS]OPEEND<=[M:DIA]ENDDAT"
    Gosub LOAD_CRITERE2
    CRITERE  = "[F:OPS]MFGFCY = [M:DIA]MFGFCY"
    Gosub LOAD_CRITERE2
  Endif
Return

########################################################################
$LOAD_CRITERE
  If len(CRITERE1)=0
    CRITERE1 += "("
  Else
    CRITERE1 += "|"
  Endif
  CRITERE1 += CRITERE
Return

########################################################################
$LOAD_CRITERE2
  If len(CRITERE)+len(CRITERE1)+1 < 225
    CRITERE1 += "&"
    CRITERE1 += CRITERE
  Else
    If CRITERE2 <> ""
      CRITERE2 += "&"
    Endif
    CRITERE2 += CRITERE
  Endif
Return

########################################################################
# transfert fichiers serveur vers client
$TRF_FILES
  Local Char PATH (GDIMFIC)
  Local Char WFICHIER (GDIMFIC)
  Local Integer STAT

  Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
  Call MACHINE([M:DIA]DRTISS,MACHINE,MACFIC) From ORDSYS

  #on doit basculer le fichier dans le repertoire des fichiers destination
  Gosub TRF_TEC
  Gosub TRF_WO
Return

###############################################################################

$TRF_TEC
  # centres de charge
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilcdc")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPWCR","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  #postes de charge
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilwst")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPWST","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  #postes par centre de charge
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilcwst")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPWSTWCR","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # postes de remplacement
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilrpw")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPWSTALT","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif
Return

########################################################################
# transfert fichiers serveur vers client -> WO
$TRF_WO
  # articles
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilitm")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPITM","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # opérations
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilope")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPOF","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # clients
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilbpc")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPBPC","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # affaires
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilpjt")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPPJT","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # commandes
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilord")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPSOH","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # commandes
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilbom")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPBOM","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # commandes
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilach")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPPUR","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # commandes
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilsto")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPSTO","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  # ressources secondaires
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilrss")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPRSS","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif

  #######################################
  #ilcpv
  PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilcpv")
  WFICHIER = filpath([M:DIA]DRTISS,"EXPCPV","csv","","",MACHINE)
  If [M:DIA]TYPEXP=1
      Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
  Elsif [M:DIA]TYPEXP=2
      Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
  Endif
  #######################################
Return

########################################################################
# Mise à jour des OF optimisés
$OPTIMX3
  OK=1
  Call OUINON(mess(103,190,1),OK) From GESECRAN
  If OK=2
    ###[M:OPTK]TRACE2 = WTRACE2
    ###[M:OPTK]SEPCHR = WSEPCHR
    ###[M:OPTK]TRTMOD = WTRTMOD
    # transfert fichiers résultats du client vers le serveur (E pour client vers serveur)
    Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
    Call MACHINE([M:DIA]DRTRCP,MACHINE,MACFIC) From ORDSYS
    PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilres")
    WFICHIER = filpath([M:DIA]DRTRCP,"OrdersOut","csv","","",MACHINE)
    If [M:DIA]TYPEXP=1
      Call COPSRV(WFICHIER ,PATH ,STAT) From ORDSYS
    Else
      Call COPIE_EMPTY(WFICHIER ,PATH ,STAT) From ORDSYS
      #on doit basculer le fichier dans le repertoire des fichiers traites ssi sur serveur
      WDATBAS=format$("D:YYYYMMDDhhmmss",date$)
      WFICHIER = filpath([M:DIA]DRTRCP,"OrdersOut","csv","","",MACHINE)
      PATH = filpath([M:DIA]DRTSTO,"OrdersOut"+WDATBAS,"csv","","",MACHINE)
      Call MOVE_EMPTY(WFICHIER ,PATH ,STAT) From ORDSYS
      Call ECR_TRACE(string$(20,"="),0) From GESECRAN
      Call ECR_TRACE(mess(324,197,1)-":"-ctrans(PATH,"\","/"),0) From GESECRAN
      Call ECR_TRACE(string$(20,"="),0) From GESECRAN
    Endif
    If STAT : Return : Endif
    # récupération des donnees
    Call OPTRES('ORO',[M:DIA]MFGFCY,[M:DIA]MFGFCY,[M:DIA]TRACE2,OK) From PITMFGRES
  Endif
Return

######################################################################################
## ETIQUETTES
######################################################################################
Subprog AP_ID(VALEUR)
Variable Char    VALEUR()
  Read [ORO]ORO0=VALEUR
  If !fstat
    If [M:DIA]ID<>VALEUR
        [M]ENDDAT=[M]STRDAT+[F:ORO]ORTLTI
    Endif
    [M:DIA]=[F:ORO]
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
    #    If [M:DIA]DRTISS<>""
    #        If (GOS(1)="unix" & pat(left$([M:DIA]DRTISS,3),"!:\")) or left$([M:DIA]DRTISS,1)="#"
    #         [M:DIA]TYPEXP = 1
    #        Elsif GOS(1)<>"unix" & pat(left$([M:DIA]DRTISS,3),"!:\") & filinfo([M:DIA]DRTISS,0)<=0
    #         [M:DIA]TYPEXP = 1
    #        Else
    #         [M:DIA]TYPEXP = 2
    #        Endif
    #    Elsif [M:DIA]DRTRCP<>""
    #        If (GOS(1)="unix" & pat(left$([M:DIA]DRTRCP,3),"!:\")) or left$([M:DIA]DRTRCP,1)="#"
    #         [M:DIA]TYPEXP = 1
    #        Elsif GOS(1)<>"unix" & pat(left$([M:DIA]DRTRCP,3),"!:\") & filinfo([M:DIA]DRTRCP,0)<=0
    #         [M:DIA]TYPEXP = 1
    #        Else
    #         [M:DIA]TYPEXP = 2
    #        Endif
    #    Else
    #        [M:DIA]TYPEXP = 1
    #    Endif
    If [M:DIA]VOLFILISS<>"" & left$([M:DIA]VOLFILISS,1)="["
      [M:DIA]TYPEXP = 2 : # Server
     Else
      If GBATCH
       [M:DIA]TYPEXP = 2
      Else
       [M:DIA]TYPEXP = 1
      Endif
     Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations

    Call AM_TYPEXP([M:DIA]TYPEXP)
    Call AM_OPTION([M:DIA]OPTION)
    Call AM_STRDAYFLG([M:DIA]STRDAYFLG)
    Affzo [M:DIA]
    Call SET_DERLU("ORO",VALEUR)
  Endif
End


#----------------------------------------------#
Subprog GET_DERLU(VALEUR,ABREV,CRITERE)
Variable Char VALEUR
Value Char ABREV,CRITERE
  Onerrgo RIEN
  Local File ALSTRD [ALS]
  Local Char CLE(GLONID1) , PROGOBJ(GLONADC)
  PROGOBJ = "WO"+ABREV
  Gosub NOMFIC From =PROGOBJ
  Local File =NOMFIC [A__]
  If CRITERE="" : CRITERE = "1=1" : Endif
  Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
  For [ALS]ALS0
    CLE = [F:ALS]CLES
    K = instr(1,CLE,"~")
    If K
      CLE = left$(CLE,K-1)
    Endif
    Read [A__] = CLE
    If !fstat & evalue(CRITERE)
      VALEUR = CLE : Break
    Endif
  Next ALS
  Close Local File [ALS] , [A__]
End

#----------------------------------------------#
Subprog SET_DERLU(ABREV,CLE)
Value Char ABREV,CLE
  Local File ALSTRD [ALS]
  Local Integer I , K , OK
  Trbegin [ALS]
    Gosub ECR_DERLU
  Commit
  Close Local File [ALS]
End

#----------------------------------------------#
$ECR_DERLU
  Filter [ALS] Where USR=GUSER & OBJ=ABREV
  Read [ALS]ALS0 Last
  If fstat<=2
    If [F:ALS]LIG>=32000
      Delete [ALS] Where USR=GUSER & OBJ=ABREV
      K = 1
    Else
      K = [F:ALS]LIG+1
    Endif
  Else
    K = 1
  Endif

  Raz I, OK
  For [ALS]ALS0
    If [F:ALS]CLES=CLE : OK = 1 : Break : Endif
    If dim(CLEVALEUR)<0
      I+=1
    Else : ## GEODE
      OK=1
      Local Integer I1, I2, I3
      If CLEFCY<>""
        I2=0
        J=find(CLEFCY,CLEPRIM,CLESEC)
        For I3=1 To J
          I1 = I2+1
          I2 = instr(I1,[F:ALS]CLES,"~")
        Next I3
        If I2 & GFCY<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
      Endif
      If CLEDEP<>""
        I2=0
        J=find(CLEDEP,CLEPRIM,CLESEC)
        For I3=1 To J
          I1 = I2+1
          I2 = instr(I1,[F:ALS]CLES,"~")
        Next I3
        If GDEP<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
      Endif
      If OK : I+=1 : OK=0 : Endif
    Endif
  Next
  Filter [ALS]
  If OK
    [F:ALS]LIG = K
    Rewrite [ALS]
  Else
    If I>=GNBDERNIER
      Read [ALS]ALS0(2) = GUSER ; ABREV
      If fstat<=2 : OK = 1 : Endif
    Endif
    Raz [F:ALS]
    [F:ALS]USR  = GUSER
    [F:ALS]OBJ  = ABREV
    [F:ALS]LIG  = K
    [F:ALS]CLES = CLE
    If !OK
      Write [ALS]
    Else
      Rewrite [ALS]
    Endif
  Endif
Return

$RIEN
Resume

######################################################################################
# Textes du dictionnaire (ATEXTE)
Funprog RDT(I)
Value Integer I
  If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
  Read [ZATX]NUMERO=GLANGUE;I
  If fstat<>0
    If [V]GLANGUE<>"FRA"
      Read [ZATX]NUMERO="FRA";I
      If fstat
        Raz [ZATX]
      Endif
    Else
      Raz [ZATX]
    Endif
  Endif
End [ZATX]TEXTE

