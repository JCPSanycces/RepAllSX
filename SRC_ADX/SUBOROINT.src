###################################################################################################
$SUPTRA
Local Char    COMMANDE(250)
If filinfo(MACHINE+"@"+FICTRA,0)>0
    System COMMANDE = MACHINE+'@ae_rm'-'"'+FICTRA+'"'
Endif
Return

########################################################################
$READ_TRA
Local Char    SAVIFS(5) , SAVIRS(5) , IRS(2),LIGNE(255)
Local Integer SAVIUM

If OS="unix"
    IRS = chr$(10)
Else
    IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
If filinfo(MACHINE+"@"+FICTRA,0)>0
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(string$(100,"="),0) From GESECRAN
   Call ECR_TRACE("|"+FICTRA,0) From GESECRAN
   Call ECR_TRACE(string$(len(FICTRA),"="),0) From GESECRAN
   Openi MACHINE+"@"+FICTRA
   Rdseq LIGNE
   While fstat=0
      ERR=1
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      Rdseq LIGNE
   Wend
   Openi
   Call ECR_TRACE(string$(100,"="),0) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
Endif
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

