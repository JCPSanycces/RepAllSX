######################################################################################
Subprog CONTREP(NAMEREP)
Variable Char NAMEREP()
  Local Integer ER
  Local Char    REPERT(GDIMFIC)
  Local Char    MACHINE(GDIMFIC) , OS(10)
  If left$(NAMEREP,1)="#"
    GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
    mkstat   = 2
    End
  Endif
  Call MACHINE(NAMEREP,MACHINE,REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS="" Then
    GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
    mkstat=2 : End
  Endif
  Call EXISTE(NAMEREP,ER) From ORDSYS
  If ER<>2 Then
    GERR=1
    GMESSAGE = mess(9,141,1) :  # Répertoire inexistant
    mkstat = 2 : End
  Endif
End


######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  #If GBATCH & VALEUR=1
  # GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
  # mkstat = 2 : End
  #Endif
  If VALEUR=1
   If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
   Else
     Raz [M]VOLFILISS : Grizo [M]VOLFILISS : Raz [M]DRTISS
     Raz [M]VOLFILSTO : Grizo [M]VOLFILSTO : Raz [M]DRTSTO
     Raz [M]VOLFILRCP : Grizo [M]VOLFILRCP : Raz [M]DRTRCP
   Endif
  Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#  Call SET_NOMFIC("DRTRCP",[M:DIA]DRTRCP,VALEUR)
#  Call SET_NOMFIC("DRTSTO",[M:DIA]DRTSTO,VALEUR)
#  Call SET_NOMFIC("DRTISS",[M:DIA]DRTISS,VALEUR)
#  Affzo [M:DIA]DRTRCP
#  Affzo [M:DIA]DRTSTO
#  Affzo [M:DIA]DRTISS
#  If VALEUR=1
#     Grizo [M:DIA]DRTRCP
#     Grizo [M:DIA]DRTSTO
#     Grizo [M:DIA]DRTISS
#  Else
#     Actzo [M:DIA]DRTRCP
#     Actzo [M:DIA]DRTSTO
#     Actzo [M:DIA]DRTISS
#  Endif
  If VALEUR=1
    Raz [M]VOLFILISS
    Raz [M]DRTISS
    Grizo [M]VOLFILISS
    Raz [M]VOLFILRCP
    Raz [M]DRTRCP
    Grizo [M]VOLFILRCP
    Raz [M]VOLFILSTO
    Raz [M]DRTSTO
    Grizo [M]VOLFILSTO
  Else
    Actzo [M:DIA]VOLFILISS
    Actzo [M:DIA]VOLFILSTO
    Actzo [M:DIA]VOLFILRCP
  Endif
  Affzo [M:DIA]VOLFILISS
  Affzo [M:DIA]VOLFILSTO
  Affzo [M:DIA]VOLFILRCP
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
End

######################################################################################
Subprog SET_NOMFIC(COLREP,NOMIMP,TYPEXP)
Value Char COLREP()
Variable Char NOMIMP()
Value Integer TYPEXP
  Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
  Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)

  Read [ORO]ORO0=[M:DIA]ID
  If !fstat
    If (GOS(1)="unix" & pat(left$([F:ORO]DRTISS,3),"!:\")) or left$([F:ORO]DRTISS,1)="#"
      If TYPEXP=1
        NOMIMP=evalue("[F:ORO]"+COLREP)
      Endif
    Elsif GOS(1)<>"unix" & pat(left$([F:ORO]DRTISS,3),"!:\") & filinfo([F:ORO]DRTISS,0)<=0
      If TYPEXP=1
        NOMIMP=evalue("[F:ORO]"+COLREP)
      Endif
    Else
      If TYPEXP=2
        NOMIMP=evalue("[F:ORO]"+COLREP)
      Else
        Call SET_NAMCLI(NOMIMP) From ORDSYS
      Endif
    Endif
  Else
    If TYPEXP=1
      Call SET_NAMCLI(NOMIMP) From ORDSYS
    Endif
  Endif
End

######################################################################################
Subprog AM_OPTION(VALEUR)
Variable Integer VALEUR
  If VALEUR=3
  ##Gantt
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  #    [M:DIA]ORTFLG=1 : Affzo [M:DIA]ORTFLG
  #    [M:DIA]ORTPLNFLG=2 : Affzo [M:DIA]ORTPLNFLG
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
    Grizo [M:DIA]TRTMOD
    Grizo [M:DIA]MFGFCY
    Grizo [M:DIA]STRDAT
    Grizo [M:DIA]STRDAYFLG
    Grizo [M:DIA]ENDDAT
    Grizo [M:DIA]FORMULE
    Grizo [M:DIA]20
    Grizo [M:DIA]22
    Grizo [M:DIA]25
    Grizo [M:DIA]35
    Actzo [M:DIA]TRACE
    Grizo [M:DIA]TRACE1
    Grizo [M:DIA]TRACE2
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  #    Grizo [M:DIA]ORTFLG
  #    Grizo [M:DIA]ORTPLNFLG
  #    # Issue 78720 - 2011-12-15 by VPO
  #    Grizo [M:DIA]ORTDRTBIN
  #    Actzo [M:DIA]ORTCLIBIN
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  Elsif VALEUR=4
##Mise à jour des résultats
    [M:DIA]TRTMOD=1
    Grizo [M:DIA]TRTMOD
    Actzo [M:DIA]MFGFCY
    Grizo [M:DIA]STRDAT
    Grizo [M:DIA]STRDAYFLG
    Grizo [M:DIA]ENDDAT
    Grizo [M:DIA]FORMULE
    Grizo [M:DIA]20
    Grizo [M:DIA]22
    Grizo [M:DIA]25
    Actzo [M:DIA]35
    Actzo [M:DIA]TRACE
    Grizo [M:DIA]TRACE1
    Actzo [M:DIA]TRACE2
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  #    Actzo [M:DIA]ORTFLG
  #    [M:DIA]ORTPLNFLG=1 : Affzo [M:DIA]ORTPLNFLG
  #    Grizo [M:DIA]ORTPLNFLG
  #    # Issue 78720 - 2011-12-15 by VPO
  #    Grizo [M:DIA]ORTCLIBIN
  #    Actzo [M:DIA]ORTDRTBIN
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  Else
  ##Préparation des données
    If VALEUR<>[M:DIA]OPTION
      [M:DIA]TRTMOD=2
    Endif
    Actzo [M:DIA]TRTMOD
    Actzo [M:DIA]MFGFCY
    Actzo [M:DIA]STRDAT
    Actzo [M:DIA]STRDAYFLG
    Actzo [M:DIA]ENDDAT
    Actzo [M:DIA]FORMULE
    Actzo [M:DIA]20
    Actzo [M:DIA]22
    Actzo [M:DIA]25
    Actzo [M:DIA]35
    Actzo [M:DIA]TRACE
    Actzo [M:DIA]TRACE1
    Grizo [M:DIA]TRACE2
    Call AM_STRDAYFLG([M]STRDAYFLG)
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  #    Actzo [M:DIA]ORTFLG
  #    Actzo [M:DIA]ORTPLNFLG
  #    # Issue 78720 - 2011-12-15 by VPO
  #    Actzo [M:DIA]ORTCLIBIN
  #    Actzo [M:DIA]ORTDRTBIN
  #    Call AM_ORTFLG([M:DIA]ORTFLG)
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  Endif
End

