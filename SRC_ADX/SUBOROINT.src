###############################################################
$TERMINE
  TRA=0
  If !GSERVEUR & [M:DIA]TRACE=2
    TRA = 1
  Endif
  Kill GOROBATCH
Return

######################################################################################
$EXEC
  Local Char     WMESS(150)
  Local Char     CRITERE(255)
  Local Char     CRITERE1(255)
  Local Char     CRITERE2(255)
  Local Date     WENDDAT, WENDDATMAX
  Local Integer  WHDEB,WHFIN, WHWRK
  Local Integer  NBOF
  Local Integer NBERR : NBERR=0
  TIT  = mess(81,7710,1)          # FQ 65461 GA 06/2010 avant 53,7710
  # lecture site
  Call LECTURE ("FCY", [M:DIA]MFGFCY, "") From CONTOBJ

  If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  ##Call PRTSCR("OROINT","DIA","",0,1) From ATRTX3
  Call TRACE_MASQUE("OROINT","DIA",nomap) From GTRAITE
  Call ECR_TRACE(string$(100,"="),0) From GESECRAN
  WHDEB = time

  If [M]STRDAYFLG=2
      [M]STRDAT=date$
      [M]ENDDAT=[M]STRDAT+[M]ORTLTI
  Endif

  Gosub CHK_DATE

  If [M]OPTION=2
    # GA 30/06/2010 63219 : ajout point d'entree
    GPOINT = "BEFORE_EXP" : Gosub ENTREE From EXEFNC

    # lecture en cours
    Call TEMPON(mess(3,100,1)) From GESECRAN
    # préparation des critères de filtre
    Gosub SEL_OF
    # traitement des OF
    Gosub TRT_OF
    Gosub TRF_FILES
    Call TEMPOFF From GESECRAN

    If [M:DIA]TRACE1 = 2
      WHFIN = time
      WHWRK = WHFIN-WHDEB
      J = mod(WHWRK,60)
      K = WHWRK/60
      K = int(K)
      WMESS=mess(106,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif

    # aucun OF extrait
    If !NBOF : Call MESSAGE(mess(88,193,1)) From GESECRAN : Endif

    #VPO 12/03/10 63219 : ajout point d'entree
    GPOINT = "AFTER_EXP" : Gosub ENTREE From EXEFNC

# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#    If NBOF>0 & [M:DIA]ORTFLG=2 & [M:DIA]ORTPLNFLG=1
#        Gosub ORTIMPSSPLN
#    Elsif NBOF>0 & [M:DIA]ORTFLG=2 & [M:DIA]ORTPLNFLG=2
#        Gosub ORTIMP
#    Elsif !GSERVEUR & [M:DIA]ORTFLG=1 & [M:DIA]ORTPLNFLG=2
#        Gosub ORTPLN
#    Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  Endif

# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#  If [M]OPTION=3
#    If !GSERVEUR & [M:DIA]ORTPLNFLG=2
#        Gosub ORTPLN
#    Endif
#  Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations

  If [M]OPTION=4

# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#    If [M:DIA]ORTFLG=2
#        Gosub ORTEXP
#    Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations

    # GA 30/06/2010 63219 : ajout point d'entree
    GPOINT = "BEFORE_IMP" : Gosub ENTREE From EXEFNC

    # ecriture en cours
    Call TEMPON(mess(4,100,1)) From GESECRAN
    Gosub OPTIMX3
    Call TEMPOFF From GESECRAN

    #VPO 12/03/10 63219 : ajout point d'entree
    GPOINT = "AFTER_IMP" : Gosub ENTREE From EXEFNC

  Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

