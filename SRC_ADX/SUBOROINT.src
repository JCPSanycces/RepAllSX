#Gestion du masque OROINT
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBOROINT","OROINT",4,"SPEOROINT") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE_BATCH : #entrée en Batch
 When "INIT"         : Gosub OUVRE_INTER : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONT_BATCH"   : Gosub CONTROLE
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

######################################################################################
$OUVRE_INTER
Global Integer GOROBATCH
GOROBATCH=0
Goto OUVRE

$OUVRE_BATCH
Global Integer GOROBATCH
GOROBATCH=1
Goto OUVRE

$OUVRE
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations and V7 adaptations
# désactivation en Web
#If GBROWS : GMESSAGE = mess(85,150,1) : GERR = 2 : FIN = 1 : Return : Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations and V7 adaptations
  Local Integer OK , STAT
  Local Mask OROINT [DIA] : # Saisie paramètres
  Raz [M:DIA]
  [M]STRDAT=date$
  If clalev ([F:ORO]) = 0 : Local File ORDOOPAR [ORO] : Endif
  Call GET_DERLU([M:DIA]ID,"ORO","")
  If [M:DIA]ID<>""
      VAL_ID=[M:DIA]ID
      [M:DIA]ID=""
      Call AP_ID(VAL_ID)
  Endif
  [M:DIA]TRACE=2
  If !pat(GVERSION,"1.5.*")
      Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
  Endif
  Gosub CHARG_PARAM From FUNMOPT
Return

$DEBUT
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  If [M:DIA]ID<>""
   Call AM_TYPEXP([M:DIA]TYPEXP)
  Endif
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
  Call AM_OPTION([M:DIA]OPTION)
  Call AM_STRDAYFLG([M:DIA]STRDAYFLG)
  Affzo [M:DIA]
Return

#######################################################
$CONTROLE
  If GSTATUT=7
    FIN = 1 : # Sortie du GSAISIE par la touche FIN
    Return
  Endif

  If [M:DIA]MFGFCY="" & find([M]OPTION,2,4)>0
    GERR=1
    SAI=1
    GMESSAGE=mess(5,180,1)
    Return
  Endif

  If [M:DIA]OPTION=2 : #preparation des données
    If vireblc([M:DIA]DRTISS,2)="" & [M:DIA]TYPEXP=2
      GERR=1
      SAI=1
      GMESSAGE=mess(55,7710,1)
      Return
    Endif
    If [M]STRDAYFLG=2
      [M]STRDAT=date$
      [M]ENDDAT=[M]STRDAT+[M]ORTLTI
    Else
      If [M]ENDDAT < [M:DIA]STRDAT
        GERR=1
        SAI=1
        GMESSAGE= mess(44,199,1)
        Return
      Endif
    Endif
  Endif
  If [M:DIA]OPTION=4 : #récupération des données
    If vireblc([M:DIA]DRTRCP,2)="" & [M:DIA]TYPEXP=2
      GERR=1
      SAI=1
      GMESSAGE=mess(56,7710,1)
      Return
    Endif
    If vireblc([M]DRTSTO,2)="" & [M:DIA]TYPEXP=2
      GMESSAGE=""
      Call TEXTFIC("ORDOOPAR","DRTSTO",1,GMESSAGE) From OBJDIV
      #Call TEXTE(39111,GMESSAGE) From OBJDIV
      GMESSAGE -= ":"-mess(10,123,1)
      GERR=1
      SAI=1
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#        GZONE = "DRTSTO"
      GZONE = "VOLFILSTO"
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
      Return
    Endif
  Endif

