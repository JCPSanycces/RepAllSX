######################################################################################
Subprog AM_STRDAYFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    [M]STRDAT=date$ : Affzo [M]STRDAT
    [M]ENDDAT=[M]STRDAT+[M]ORTLTI : Affzo [M]ENDDAT
    Grizo [M]STRDAT
    Grizo [M]ENDDAT
  Else
    Actzo [M]STRDAT
    Actzo [M]ENDDAT
  Endif
End

