#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("APW",GBIDC1,GBIDC2) From GOBJET
End

# Gestion du masque APW0

######################################################################################
# Gestion du masque APW0
#
# La clé de l'objet est Cle : Champ invisible
# La clé est composé des champs SOLUTION,DOSSIER,SWEBALIAS,POOLALIAS
######################################################################################
$ACTION
Case ACTION
 When "GRISE"            :  Grizo [M:APW0]SOLUTION,DOSSIER,SWEBALIAS,POOLALIAS   
 When "DEGRISE"          :  Actzo [M:APW0]SOLUTION,DOSSIER,SWEBALIAS,POOLALIAS  
 When "APRES_MODIF"      : If find (COUZON,"SOLUTION","DOSSIER","SWEBALIAS","POOLALIAS") : COUZON="CLE" : Endif
 When "VERIF_CRE"        : Gosub VERIF_CRE
 When "VERIF_MOD"        : Gosub VERIF_MOD
 When "LIENS"            : Gosub LIENS
 When "OUVRE"            : Gosub OUVRE
 When "MODIF"            : Gosub MODIF
 When "CREATION"         : Gosub CREATION
 When "EXEBOUT"          : Gosub EXEBOUT
 When "SEL_LISTE"        : Gosub SELAUSP 
 When default
Endcase
Return


################################################################################################

$VERIF_CRE
$VERIF_MOD
 Call CREERCLE()
Return 

$OUVRE
If func AFNC.ACTIV("AYT")
 Local File AYTPOOWEB [AYO]
Endif
Return

#Call USG_SUPP("", GABREV, [M:AYO1]POOCOD, WI) From CNSAYUSTD
#If WI : OK=0 : Endif

$LIENS
Grizo [M:APW0]
Grizo 10,15
If func AFNC.ACTIV("AYT")
 [M]NBPOOL = 0
 For [AYO]AYO0 Where POOX3 = [M]CLE
  [M]POOCOD(NBPOOL)    = [F:AYO]POOCOD
  [M]POODES(NBPOOL)    = [F:AYO]POODES
  [M]POOSEC(NBPOOL)    = [F:AYO]POOSEC
  [M]POOTIMOUT(NBPOOL) = [F:AYO]POOTIMOUT
  [M]POOUSER(NBPOOL)   = [F:AYO]USR
  [M]POOLAN(NBPOOL)    = [F:AYO]USRLAN
  [M]POOPWD(NBPOOL)    = [F:AYO]USRMDP
  [M]NBPOOL +=1
 Next
Endif
Return

$MODIF
If func AFNC.ACTIV("AYT")
 Delete [AYO] Where POOX3=CLECUR1
 If fstat=1
  GOK=-1 : Call RSTA("AYO",CLECUR1) From GLOCK : Return
 Else
  Gosub ECRIRE
 Endif
Endif
Return

$CREATION
If func AFNC.ACTIV("AYT")
 Gosub ECRIRE
Endif
Return

$ECRIRE
For I=1 To [M:APW1]NBPOOL
 [F:AYO]POOCOD     = [M:APW1]POOCOD(I-1)
 [F:AYO]POODES     = [M:APW1]POODES(I-1)
 [F:AYO]POOX3      = [M:APW0]CLE
 [F:AYO]USR        = [M:APW1]POOUSER(I-1)
 [F:AYO]USRMDP     = [M:APW1]POOPWD(I-1)
 [F:AYO]USRLAN     = [M:APW1]POOLAN(I-1)
 [F:AYO]POOSEC     = [M:APW1]POOSEC(I-1)
 [F:AYO]POOTIMOUT  = [M:APW1]POOTIMOUT(I-1)
 Write [AYO]
 If fstat
  GOK=0 : Call FSTA("AYO") From GLOCK : Break
 Endif
Next 
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE,I
SAVACT = GACTION
Case BOUT
 When "V"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  For I=1 To [M:APW1]NBPOOL
   PARBOUT(1) = nomap
   PARBOUT(2) = ""
   PARBOUT(3) = "AYO"
   PARBOUT(4) = [M]POOCOD(I-1)
   PARBOUT(5) = num$("0")
   FLGEXE = 1
   GACTION = "AYTGEN"
   Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AYTGEN","",1,"") From GTRAITE
  Next I
Endcase
GACTION = SAVACT
Return
######################################################################################

Subprog CREERCLE()
Local Char STRCLE(200)
Call MAJCLE(0,"")
End

Subprog MAJCLE(IND,VALEUR)
Local Char VALPARAM(200)(1..4)
Local Char SEP(2)
SEP="_"
VALPARAM(1)=[M:APW0]SOLUTION
VALPARAM(2)=[M:APW0]DOSSIER
VALPARAM(3)=[M:APW0]SWEBALIAS
VALPARAM(4)=[M:APW0]POOLALIAS
 If IND>0 
     VALPARAM(IND)=VALEUR 
 Endif
 [M:APW0]CLE=VALPARAM(1)+SEP+VALPARAM(2)+SEP+VALPARAM(3)+SEP+VALPARAM(4)
 Affzo [M:APW0]CLE 
End

######################################################################################

Subprog AM_POOLALIAS(VALEUR)
Variable Char    VALEUR()
Call MAJCLE(4,VALEUR)
End

Subprog AM_SOLUTION(VALEUR)
Variable Char    VALEUR()
Call MAJCLE(1,VALEUR)
End

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()
Call MAJCLE(2,VALEUR)
End

Subprog AM_SWEBALIAS(VALEUR)
Variable Char    VALEUR()
Call MAJCLE(3,VALEUR)
End

Subprog C_POOCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]POOCOD(0..[M]NBPOOL-1)) From OBJDIV
If mkstat : End : Endif
For [AYO] Where POOX3 <> [M]CLE
 If [AYO]POOCOD= VALEUR
  GMESSAGE = mess(222,7900,1)-[M]CLE
  mkstat = 2
  Break
 Endif
Next 
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran APW1) 11/08/2010 08:25:27 (CCORA)
######################################################################################
Subprog C_POOUSER(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSSIER+".AUTILIS" [A_US] 
Read [A_US]CODUSR=VALEUR
If fstat<>0
  mkstat=2
  GMESSAGE=mess(141,100,1) : # Utilisateur inexistant 
Elsif [F:A_US]ENAFLG<>2 or [F:A_US]USRCONXTD<>2
  mkstat=2
  GMESSAGE=mess(279,123,1) : # Code utilisateur non autorisé pour ce type de connexion
Endif
End

$SELAUSP
Local Char TEXTE(80)(1..GNBSEL,1..2) , TEX(80)(1..GNBSEL) , TIT(80)(0..2)
Local Integer  NBTEX
TIT = mess(48,125,1)-":"-[M]DOSSIER : # Utilisateurs sur ce dossier
TIT(1) = mess(103,124,1) : # Code utilisateur
TIT(2) = mess(175,124,1) : # Nom utilisateur
Local File =[M]DOSSIER+".AUTILIS" [A_US] 
Filter [A_US] Where USR>=VALEUR and ENAFLG=2 and USRCONXTD=2
For [A_US]
   NBTEX += 1
   TEXTE(NBTEX,1) = [F:A_US]USR
   TEXTE(NBTEX,2) = [F:A_US]NOMUSR
   TEX(NBTEX) = [F:A_US]USR
   If NBTEX>=GNBSEL : Break 1 : Endif
Next 
Return


######################################################################################

