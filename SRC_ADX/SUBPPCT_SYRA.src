#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------------------
# SUBPPCT_SYRA
# --- generation of the search process this price WATxxxxxx_SY
#------------------------------------------------------------------------
# Rate Type 1 = Normal / 2 = Group / 3 = Prohibited / 4 = Component
#------------------------------------------------------------------------
# Issue 122499 - 20170505 by LD : Grouped price list priority in a modification context

$GEN_TRT
Local Char NOMTRT(GLONAVA),FICTRT(GDIMFIC),TEX(100)(0..3),INDN
Local Char    ABR_XPL  (5)              : # Int-societe : Abr. table lignes tarifs (SPL ou PPL)
Local Integer IX, PASSAGE
Local Integer TESTUOM
Local Integer ATYOPEN, AMZOPEN, ACVOPEN, NBRCOLONNE
Local Char    FORMULEPRI (250)
Local Char    AMZ_CODTYP  (5) (0..10)   : # type donnees prix et frais/remises
Local Char    ATY_FORTYP (50) (0..10)   : # format dur type de donnee

Local Char    WPPCFIL(GLONAVA) : Raz WPPCFIL :

NOMTRT="WAT"+num$([F:PPC]PLI)+"_SY"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)

If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : ATYOPEN=1 : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : AMZOPEN=1 : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : ACVOPEN=1 : Endif

# Issue 121765 - 2017-03-24 by SR : Retrieving the dimension of PPR data type
Local Shortint WLONPPR
Read [ATY] CODTYP="PPR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=2 : Endif
WLONPPR=[F:ATY]LNGTYP
# End issue 121765

#-- - Inter-companies: rates table lines
If [F:PPC]PLIBPRCNR=2
       ABR_XPL="SPL"
  Else ABR_XPL="PPL"
Endif

#--- Find the number of active lines per activity code PPR
Read [ACV]CODACT="PPR"
NBRCOLONNE=[F:ACV]DIME
If fstat : NBRCOLONNE=0 : Endif
If ACVOPEN=1 : Close Local File [ACV] : Endif

#--- Research data type and format of the price and columns costs / delivery
# - Data type default MD5
For IX=0 To dim(AMZ_CODTYP)-1 : AMZ_CODTYP(IX)="MD5" : Next IX
#-   datatype price
Read [AMZ]CODE="WA1"+num$([F:PPC]PLI)+"1";"PRI"
If !fstat
   AMZ_CODTYP(0)=[F:AMZ]CODTYP
   If [F:AMZ]LONG>0 : ATY_FORTYP(0)=num$([F:AMZ]LONG) : Endif
Endif
#-   type of cost data / discounts
For IX=1 To 9
    Read [AMZ]CODE="WA1"+num$([F:PPC]PLI)+"1";"XFRAREM"+num$(IX)
    If !fstat
       AMZ_CODTYP(IX)=[F:AMZ]CODTYP
       If [F:AMZ]LONG>0 : ATY_FORTYP(IX)=num$([F:AMZ]LONG) : Endif
    Endif
Next IX
#-   storage format (or variable containing the format)
For IX=0 To dim(AMZ_CODTYP)-1
    If ATY_FORTYP(IX)=""
       Read [ATY] CODTYP=AMZ_CODTYP(IX)
       If !fstat : ATY_FORTYP(IX)=[F:ATY]FORTYP : Else : ATY_FORTYP(IX)="12.4#" : Endif
       If instr(1,ATY_FORTYP(IX),"GDEVFMT") : ATY_FORTYP(IX)="=[F:TCU]CURFMT1" : Endif
    Endif
Next IX

Openo FICTRT,0
adxifs=""
adxirs=chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%|%","Gén.traitement tarif "+[F:PPC]PLI
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WAT";[F:PPC]PLI;"_SY                                            ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"
Wrseq "Subprog TARIF(PARAM,PLINEDOC, RESULT, WERR, WMESSAGE)"
Wrseq "Value    Instance PARAM  Using  C_PFINDPRICE   : # instance des paramètres en entrée de recherche tarif"
Wrseq "Value    Integer  PLINEDOC                     : # no ligne courante (C_LINE associé à la ligne courante)"
Wrseq "Variable Instance RESULT Using  C_RESULTPRICE  : # instance des paramètres en sortie de recherche tarif"
Wrseq "Variable Integer  WERR                         : # si erreur => positionné avec [V]CST_Axxx selon erreur"
Wrseq "Variable Char     WMESSAGE()                   : # le contenu du message"
Wrseq ""
Wrseq "If PLINEDOC < 1 : End : Endif : # Pas la peine d'aller plus loin.."
Wrseq ""
Wrseq "If PARAM.C_LINE(PLINEDOC) = null : End : Endif : # Pas la peine d'aller plus loin.."
Wrseq "Local    Char     CODENTPNT (3)      : # Code point entree"
#--CPO ajout
Wrseq "Local    Integer WLINE"
Wrseq "Local    Integer WBIDI               : # Remplacer l'ancienne GBIDI3"
Wrseq "Local    Decimal WBIDD               : # Remplacer l'ancienne GBIDD3"
Wrseq "Local    Char    WBPAADD(GLONADR)    : # adresse à entête ou ligne"
Wrseq "Local    Char    WPOHFCY(GLONFCY)    : # site    à entête ou ligne"
#--/


Case [F:PPC]PLITYP
  When 1,4   #Wrseq "Local    Shortint TACHE (0..11)      : # traitements a effectuer ?"
  Wrseq "#--CPO Afin de séparer le prix net des frais/remises et des commisions"
             Wrseq "#Local    Shortint TACHE (0..11)      : # traitements a effectuer ?"
             Wrseq "#--DOTASK_PRICE          => TACHE(0)"
             Wrseq "#--DOTASK_DISCRG   (1..) => TACHE(1-9)"
             Wrseq "#--DOTASK_REPCOE         => TACHE(10)"
             Wrseq "#--DOTASK_FOC            => TACHE(11)"
             Wrseq "Local    Shortint DOTASK_PRICE               : # traitements prix a effectuer ?"
             Wrseq "Local    Shortint DOTASK_DISCRG   (1..)      : # traitements frais/remises a effectuer ?"
             Wrseq "Local    Shortint DOTASK_REPCOE              : # traitements commisions représentants a effectuer ?"
             Wrseq "Local    Shortint DOTASK_FOC                 : # traitements des gratuits a effectuer ?"
Endcase
# Issue 121765 - 2017-03-27 by SR : Dimension XPRIREN according to PPR data type
Case [F:PPC]PLITYP
  When 1,2,4 Wrseq "local    Char     XPRIREN ("+num$(WLONPPR)+")"  : # recup. motif"
             #Wrseq "Local    Char     XPRIREN (2)        : # recup. motif"
             Wrseq "Local    Integer  WPRIREN            : # recup. motif"
             Wrseq "Local    Char     XPRITYP (1)        : # recup. type prix"
             Wrseq "Local    Integer  WPRITYP            : # recup. type prix"
             Wrseq "Local    Integer  WMODULE            : # module"
             Wrseq "Local    Char     WPLI    (10)       : # code tarif"
             Wrseq "Local    Decimal  COEFDEVISE         : # coef.conv. devise"
             Wrseq "Local    Decimal  COEFUNITE          : # coef.conv. unite"
             Wrseq "Local    Decimal  COEFPOURN          : # coef. si tarif pour n"
             Wrseq "Local    Decimal  WFOCQTYMIN         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCQTYBKT         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCAMTMIN         : # calcul gratuits : tranche prix"
             Wrseq "Local    Decimal  WFOCAMTBKT         : # calcul gratuits : tranche prix"
             Wrseq "Local    Decimal  WMANDEC            : # manoeuvre decimal"
             Wrseq "Local    Integer  WRET               : # code retour"
             Wrseq "Local    decimal  CLCAMT(1..7)       : # Montants 1-7 pour taxe suivant formule"
             Wrseq "Local    Char     APDC_CUR (5)       : # Arrondi : Code devise"
             Wrseq "Local    Char     APDC_FMT (50)      : # Arrondi : Format sous forme 12.4#"
             Wrseq "Local    Decimal  APDC_RND           : # Arrondi : Code arrondi pour instruction arr"
Endcase
Case [F:PPC]PLITYP
  When 2     Wrseq "Local    Shortint SELGRP (0..[M]NBLIG) : # flag sélection de la ligne"
             Wrseq "Local    Shortint UPDGRP (0..[M]NBLIG) : # flag maj ligne par ce tarif"
             Wrseq "Local    Shortint NLD                : # = nolign boucle primaire (A)"
             Wrseq "Local    Shortint NLG                : # = nolign boucle secondaire (B)"
             Wrseq "                                       #   (recherche lignes de meme criteres que NLD)"
             Wrseq "Local    Char     FOCUPDTST (50) (0..dim(FOCITMREF)) : # pour m.a.j. des gratuits "
# - CPO => need for the class parameter contains an array of parameters already loaded associated with each line
             # Wrseq "Local    Integer  SAVNOLIGN          : # sauvegarde de nolign"
             Wrseq "local    Decimal  CUMQTY             : # cumul qté des lignes"
             Wrseq "local    Decimal  CONVQTY            : # qté après les coeff"
             Wrseq "local    Decimal  CUMAMT             : # cumul mt des lignes"
             Wrseq "local    Decimal  CONVPRI            : # prix après coeff"
             Wrseq "Local    Char     WCRIT (GLONPPX)    : # concaténation critères"
             Wrseq "Local    Integer  UPDNULPRI          : # groupes : flag modif prix nul"
Endcase
If [F:PPC]PLITYP=2
  Wrseq "If dim(GPPLXGRP)<0 : Global Shortint GPPLXGRP : Endif"
  Wrseq "UPDNULPRI="+num$([F:PPC]UPDNULPRI)
Endif
Case [F:PPC]PLITYP
  When 1,2,4 Wrseq "#           initialisations"
             Wrseq "XPRIREN='"+num$([F:PPC]PRIREN)+"' : WPRIREN=val(XPRIREN)"
             Wrseq "XPRITYP='"+num$([F:PPC]PRITYP)+"' : WPRITYP=val(XPRITYP)"
             Wrseq "WMODULE=4                            : # Module Achat"
             Wrseq "WPLI='"+[F:PPC]PLI+"'"
             Wrseq "COEFDEVISE=1 : COEFUNITE=1 : COEFPOURN=1"
Endcase
Wrseq "RESULT.INTERDIT=0"
Wrseq "# Les critères existent ?"
#--CPO ajout
Wrseq "#Local File ITMMASTER [ITM]"
Wrseq "Local File TABCUR    [TCU]"
Wrseq ""
Wrseq "Read [F:ITM]ITM0=PARAM.C_LINE(PLINEDOC).ITMREF"
Wrseq "If fstat : Raz [F:ITM] : End :Endif"
Wrseq ""
#--/
Wrseq "#--Ouverture et chargement systématique de SPRICLINK"
Wrseq "#--Utilisé surtout pour les formules..."
Wrseq "Local File PPRICLINK [PPK]" # 98525.n
Wrseq "#--Transclasse [F:PPK] with PARAM.C_PPKH(1) et PARAM.C_LINE(NLD).C_PPKD(1)"
Wrseq "If PARAM.C_PPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'Error call : fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(PLINEDOC).C_PPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(PLINEDOC).C_PPKD(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'Error call : PARAM.C_LINE(PLINEDOC).C_PPKD(1).LOAD_TO_PPK_FILE()', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Wrseq "# Les critères existent ?"

If [F:PPC]ABB(0)<>""
  If [F:PPC]FIL(0)<> "PPRICLINK" & [F:PPC]FIL(0)<> "ITMMASTER"
    Wrseq "Local File ";[F:PPC]FIL(0);" [";[F:PPC]ABB(0);"]"
  WPPCFIL = [F:PPC]FIL(0)
  Gosub READFIL
  Endif
Endif

For I=1 To 4 # 0  2/21/2014
  If [F:PPC]ABB(I)<>""
    # - CPO must also open other tables used in the parameterization ...
    # - Please do not try to open the same 2x present on several lines of parameterization
    If !find([F:PPC]FIL(I),[F:PPC]FIL(0..I-1))  #### 0..I to 0..I-1  02/20/2014
      If [F:PPC]FIL(I)<> "PPRICLINK" & [F:PPC]FIL(I)<> "ITMMASTER"
      Wrseq "Local File ";[F:PPC]FIL(I);" [";[F:PPC]ABB(I);"]"
      WPPCFIL = [F:PPC]FIL(I)
      Gosub READFIL
      Endif
    Endif
    #--/
    Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : End : Endif"
  Endif
Next I


Wrseq ""
Wrseq "# Application des tarifs Hors groupe / Groupe"
Wrseq "If PARAM.C_LINE(PLINEDOC) <> null and PARAM.C_LINE(PLINEDOC).C_PPKD(1) <> null"
Wrseq "  # Si PARAM.C_LINE().C_PPKD(1).PLIBPRCNR=3 application de tous les tarifs (Hors groupe et Groupe)"
Wrseq "  If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).PLIBPRCNR)<=0 | PARAM.C_LINE(PLINEDOC).C_PPKD(1).PLIBPRCNR<>3"
Wrseq "    # Application des tarifs Hors groupe ou Groupe en fonction des flags intersociété et intersite"
Wrseq "    # Tarif concernant les tiers ( ";
Wrseq mess([F:PPC]PLIBPRCNR,2210,1);
Wrseq " )"
Wrseq "    If PARAM.C_PPKH(1) <> null" ###
Wrseq "      If dim(PARAM.C_PPKH(1).BETCPY)>0 & dim(PARAM.C_PPKH(1).BETFCY)>0"
If [F:PPC]PLIBPRCNR=1
   Wrseq "        If PARAM.C_PPKH(1).BETCPY=[V]CST_AYES | PARAM.C_PPKH(1).BETFCY=[V]CST_AYES : End : Endif"
Endif
If [F:PPC]PLIBPRCNR=2
   Wrseq "        If PARAM.C_PPKH(1).BETCPY<>[V]CST_AYES & PARAM.C_PPKH(1).BETFCY<>[V]CST_AYES : End : Endif"
Endif
Wrseq "      Endif"
Wrseq "    Endif"
Wrseq "  Endif"
Wrseq "Endif"

Wrseq ""

If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : ouverture autres fichers"
Wrseq "#Local File PPRICLINK [PPK]"
Wrseq ""
Wrseq "#--Transclasse [F:PPK] with PARAM.C_PPKH(1) et PARAM.C_LINE(PLINEDOC).C_PPKD(1)"
Wrseq "If PARAM.C_PPKH(1)<>null"
Wrseq "  SetInstance [F:PPK] With PARAM.C_PPKH(1)"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(PLINEDOC).C_PPKD(1)<>null"
Wrseq "  SetInstance [F:PPK] With PARAM.C_LINE(PLINEDOC).C_PPKD(1)"
Wrseq "Endif"
Wrseq ""
Wrseq "Local File ITMMVT [ITV]"
Wrseq "Local File ITMCOST [ITC]"
Endif

Wrseq ""
Wrseq "# Faut-il ouvrir le fichier tarif ?"
If [F:PPC]PLIBPRCNR=2
        Wrseq "Local File SPRICLIST [SPL]"
  Else  Wrseq "Local File PPRICLIST [PPL]"
Endif

Wrseq ""
Wrseq "#If PLI(0)='*SIMU*'    : # Pour simulation chgt toutes les lignes utilisable"
Wrseq "If PARAM.PLI(1)<>null and PARAM.PLI(1).PLI ='*SIMU*'    : # Pour simulation chgt toutes les lignes utilisable"
Wrseq "  Gosub CONSULTATION"
Wrseq "  End"
Wrseq "Endif"
Wrseq ""

Case [F:PPC]PLITYP
  When 1 : Gosub TR_NORMAL   : # Price normal
  When 2 : Gosub TR_GROUPE   : # Price group
  When 3 : Gosub TR_INTERDIT : # Price prohibited
  When 4 : Gosub TR_NORMAL   : # Price component (idem normal)
Endcase
Wrseq "#-----------------------------------------------------------------"

# Generation processing line group rate
If [F:PPC]PLITYP=2 : Gosub TR_GRPLIG : Endif
# Generation error handling if price coefficient
If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
  Wrseq ""
  Wrseq "$ERR_PRI"
  #Wrseq "GERR=2"
  Wrseq "WERR=[V]CST_AERROR"
  Wrseq "WMESSAGE = mess(15,197,1)+': '+[F:";ABR_XPL;"]PLI+'  '+";
  If [F:PPC]PRIPRO=4
    Wrseq "mess(16,197,1)+'\'+";
  Endif
  If [F:PPC]PRIPRO=5
    Wrseq "mess(17,197,1)+'\'+";
  Endif
  Wrseq "mess(65,106,1)"
  If [F:PPC]PRIPRO=4
    Wrseq "[F:";ABR_XPL;"]PRI=0"
  Endif
  If [F:PPC]PRIPRO=5
    Wrseq "CONVPRI=0"
  Endif
  Wrseq "Resume"
Endif

Gosub FORMAT_ARRONDI    : # constitution de l'arrondi pour l'instruction arr
Gosub TYPE_CRITERES     : # Saisie des tarif : savoir si type de donnée interne est alpha ou num
Gosub FILTRE_CRITERES   : # consultation tarif : filtre complementaire des lignes d'une fiche
Gosub CONSULTATION      : # consultation tarif
Gosub INI_IMPORT        : # traitement d'init de la classe F lors de l'import

Wrseq "#-----------------------------------------------------------------"

Openo

#--- Validation du traitement généré
Call VALID("TRT", NOMTRT,APPLI,OK) From VALMSKSUB
If !OK  GOK=0 : Endif

#--- Fermeture
If ATYOPEN=1 : Close Local File [ATY] : Endif
If AMZOPEN=1 : Close Local File [AMZ] : Endif

Return

#------------------------------------------------------------------------
# Génération de l'instruction Filter (suivant critères et conditions)
#------------------------------------------------------------------------
$LE_FILTRE
Gosub LE_FILTRE_BIS : Return

Wrseq ""
#--CPO Problème des Points d'entrée
Wrseq "#CODENTPNT='T01_SY' : Gosub PE_TARIFS From TRTPRICE_SYRA"
Wrseq ""

Wrseq "# Lecture des tarifs"
Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
Wrseq "&  & PARAM.DOCDAT>=PLISTRDAT & [L]DAT<=PLIENDDAT"
If [F:PPC]UOMCNVFLG=[V]CST_ANO & ZZ(8)=1
  Wrseq "&  & UOM=PARAM.C_LINE(PLINEDOC).PUU"  # UOM
  If ZZ(9)=1
    Wrseq "&  & PARAM.C_LINE(PLINEDOC).QTY>=MINQTY & PARAM.C_LINE(PLINEDOC).QTY<=MAXQTY"
  Endif
Endif
If [F:PPC]CURCNVFLG=[V]CST_ANO & SAISIEDEV=1
  Wrseq "&  & CUR=PARAM.CUR"
Endif
Wrseq "&    Order by Key ";ABR_XPL;"1"
Return

#------------------------------------------------------------------------
$LE_FILTRE_BIS

Wrseq "Local Char CRITERE (250)"
Wrseq "Local Char CRITSUP (250)"
Wrseq "CRITSUP='1=1'"
Wrseq ""

Wrseq "CRITERE = 'PLICRI="+chr$(34)+"'"
For I=0 To 4
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "CRITERE += num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'"
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "CRITERE += num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'"
     Else
        Wrseq "CRITERE += num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'"
     Endif
  Else
     Wrseq "CRITERE +='~'"
  Endif
Next
Wrseq "CRITERE += '"+chr$(34)+"'"
Wrseq "CRITERE -= '& PARAM.DOCDAT>=PLISTRDAT & PARAM.DOCDAT<=PLIENDDAT'"

If [F:PPC]UOMCNVFLG=[V]CST_ANO & ZZ(8)=1
  Wrseq "CRITERE -=  '& UOM=PARAM.C_LINE(PLINEDOC).PUU'"
  If ZZ(9)=1
    Wrseq "CRITERE -= '& PARAM.C_LINE(PLINEDOC).QTY>=MINQTY & PARAM.C_LINE(PLINEDOC).QTY<=MAXQTY'"
  Endif
Endif
If [F:PPC]CURCNVFLG=[V]CST_ANO & SAISIEDEV=1
  Wrseq "CRITERE -= '& CUR=PARAM.C_LINE(PLINEDOC).CUR'"
Endif

Wrseq ""
#--CPO Problème des Points d'entrée
Wrseq "#CODENTPNT='T01_SY' : Gosub PE_TARIFS From TRTPRICE_SYRA"
#--/
Wrseq ""

Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"+" & evalue(CRITERE) & evalue(CRITSUP)"
Wrseq "&    Order by Key ";ABR_XPL;"1"

Return

#------------------------------------------------------------------------
# Tarif normal : génération du traitement (utilisé pour composants)
#------------------------------------------------------------------------
$TR_NORMAL
If [F:PPC]ATICNVFLG=[V]CST_ANO # 1
  Wrseq "# Si le tarif n'est pas bon (HT/TTC), on s'arrête"
  Wrseq "If PARAM.PRITYP<>WPRITYP : End : Endif"
Endif

Wrseq "# On teste le remplissage effectue"
Wrseq "#Raz TACHE"
Wrseq "Raz DOTASK_PRICE"
Wrseq "Raz DOTASK_DISCRG"
Wrseq "Raz DOTASK_REPCOE"
Wrseq "Raz DOTASK_FOC"

# Price
If [F:PPC]PRIPRO>1
  Wrseq "DOTASK_PRICE=(RESULT.C_PRICE(1).MOTIF=0 | RESULT.C_PRICE(1).PRIORITE=PARAM.PIO)"
Endif
# Discounts
For I=0 To NBRCOLONNE-1
  If find([F:PPC]DISCRGPRO(I),1,3)
    INDN=num$(I+1)
    Wrseq "If RESULT.C_DISCRG("+INDN+")<>null"
    Wrseq "  DOTASK_DISCRG("+INDN+")=(RESULT.C_DISCRG("+INDN+").MOTIF=0 | RESULT.C_DISCRG("+INDN+").PRIORITE=PARAM.PIO)"
    Wrseq "Endif"
  Endif
Next I

# Coeff comm nonexistent for purchases

# Free
If [F:PPC]FOCPRO=2 | [F:PPC]FOCPRO=3
#--CPO ajout
Wrseq "If RESULT.C_FOC(1)=null"
Wrseq "  WLINE = fmet RESULT.ADDLINE('C_FOC',[V]CST_AFIRSTPOS)"
Wrseq "  If WLINE = [V]CST_ANOTDEFINED"
Wrseq "    #--The insertion was not possible"
Wrseq "    [L]WERR = fmet RESULT.ASETERROR('', 'Data Class PPRICESEARCH : Method call LOADPARAMFROMDOC result error for MYPARAM.ADDLINE:', [V]CST_AERROR)"
Wrseq "    Return"
Wrseq "  Endif"
Wrseq "Endif"
#--/
Wrseq "DOTASK_FOC=(RESULT.C_FOC(1).FOCQTY=0)"
Endif

Wrseq "# Toutes les colonnes sont garnies ?"
Wrseq "#If sum(TACHE)=0 : End : Endif"
Wrseq "IF DOTASK_PRICE+sum(DOTASK_DISCRG)+DOTASK_REPCOE+DOTASK_FOC=0 : End : Endif"

# Filter
Gosub LE_FILTRE

#The loop of records read
Wrseq "If PARAM.C_LINE(PLINEDOC)=null or PARAM.C_LINE(PLINEDOC).C_PPKD(1)=null : Filter [F:";ABR_XPL;"] : End : Endif"
Wrseq "For [";ABR_XPL;"]"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
If ABR_XPL="SPL"
   Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
Else
   Wrseq "  If [F:PPL]UOM='*' : [F:PPL]UOM=[F:ITM]PUU : Endif"
Endif
Wrseq "  WFOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN"
Wrseq "  WFOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT"

# The conversions were determined (units / currency / to n)
Raz TEX
ICONV=0
If [F:PPC]PRIPRO=3
  Wrseq "# Prix pour N articles"
  Wrseq "  If [F:";ABR_XPL;"]PRIDIV<>0 : COEFPOURN=[F:";ABR_XPL;"]PRIDIV : Endif"
  TEX(2)="/COEFPOURN" : ICONV=1
Endif
If [F:PPC]UOMCNVFLG=[V]CST_AYES #2
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:";ABR_XPL;"]UOM<>PARAM.C_LINE(PLINEDOC).PUU"
  Wrseq "    WMANDEC=[F:";ABR_XPL;"]MINQTY"
  Wrseq "    Call PCAL_QTY (WMANDEC,[F:";ABR_XPL;"]UOM,WMANDEC,PARAM.C_LINE(PLINEDOC).PUU,[F:ITM]ITMREF,[F:BPS]BPSNUM,2,"
  Wrseq "&                 COEFUNITE) From TRTACHQTE1_SYRA"
  Wrseq "    If COEFUNITE=0 : COEFUNITE=1 : Endif"
  Wrseq "    [F:";ABR_XPL;"]MINQTY=[F:";ABR_XPL;"]MINQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]MAXQTY=[F:";ABR_XPL;"]MAXQTY/COEFUNITE"
  If [F:PPC]FOCPRO>1
    Wrseq "# Tarif normal mini et seuil toujours en qte"
    Wrseq "# Conversion conditions gratuité (pas d'arrondi)"
    Wrseq "    [F:";ABR_XPL;"]FOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN/COEFUNITE"
    Wrseq "    [F:";ABR_XPL;"]FOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT/COEFUNITE"
  Endif
  If [F:PPC]FOCPRO=2
    Wrseq "# Conversion qte gratuite sur le meme article (arrondi)"
    Wrseq "    [F:";ABR_XPL;"]FOCQTY=[F:";ABR_XPL;"]FOCQTY/COEFUNITE"
    Wrseq "    Call QTEARR ([F:";ABR_XPL;"]FOCQTY,PARAM.C_LINE(PLINEDOC).PUU) From TRTDIV_SYRA"
  Endif
  TEX(1)="*COEFUNITE" : ICONV=1
Wrseq "  Endif"
  If ZZ(9)=1
    Wrseq "  If [F:";ABR_XPL;"]MINQTY>PARAM.C_LINE(PLINEDOC).QTY  | [F:";ABR_XPL;"]MAXQTY<PARAM.C_LINE(PLINEDOC).QTY : Goto TAR_SUIVANT : Endif"
  Endif
#--- Issue  105410
Else
  If ZZ(9)=1
    Wrseq "  If [F:";ABR_XPL;"]UOM=PARAM.C_LINE(PLINEDOC).PUU"
    Wrseq "    If [F:";ABR_XPL;"]MINQTY>PARAM.C_LINE(PLINEDOC).QTY | [F:";ABR_XPL;"]MAXQTY<PARAM.C_LINE(PLINEDOC).QTY : Goto TAR_SUIVANT : Endif"
    Wrseq "  Else"
    Wrseq "    Goto TAR_SUIVANT"
    Wrseq "  Endif"
  Endif
#---
Endif

If [F:PPC]CURCNVFLG=[V]CST_AYES  # 2
  Wrseq "# Conversion devise"
  Wrseq "  If [F:";ABR_XPL;"]CUR<>PARAM.CUR"
  Wrseq "    Call CONVERT(PARAM.ACTX,[F:";ABR_XPL;"]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI)";
  Wrseq " From TRTDEV_SYRA"
  Wrseq "    If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "  Endif"
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif

# Price column
If [F:PPC]PRIPRO>1
Wrseq "  If DOTASK_PRICE"
  If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : lecture ITP et ITV"
Wrseq "#   Articles-Fournisseurs ITMBPS"
Wrseq "If [F:ITP]ITMREF<>[F:ITM]ITMREF | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
Wrseq "  Read [ITP]ITP0 = [F:ITM]ITMREF;[F:BPS]BPSNUM"
Wrseq "  If fstat : Raz [F:ITP] : Endif"
Wrseq "Endif"
Wrseq "#   Cumuls Mouvements Articles-Sites ITMMVT"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>PARAM.C_LINE(PLINEDOC).C_PPKD(1).PRHFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; PARAM.C_LINE(PLINEDOC).C_PPKD(1).PRHFCY"
Wrseq "  If fstat : raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP)>0"
Wrseq "   If find(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CSTTYP,1,2,99) : [L]CSTTYP=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CSTTYP    : Endif"
Wrseq "   If find(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CSTTYP,3,4)    : [L]CSTTYP=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CSTTYP*-1 : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>PARAM.C_LINE(PLINEDOC).C_PPKD(1).PRHFCY| [F:ITC]ITMREF<>[F:ITM]ITMREF |"
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| ITCSTRDAT>PARAM.DOCDAT | PARAM.DOCDAT>ITCENDDAT"
Wrseq "       Raz [F:ITC]"
Wrseq "       Call GETPRI([F:ITM]ITMREF,'','',PARAM.C_LINE(PLINEDOC).C_PPKD(1).PRHFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:PPC]PRIPRO=4
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "Local Decimal SAVPRI"
Wrseq "Local Char EXPNUM(40)"
Wrseq "SAVPRI=[F:";ABR_XPL;"]PRI"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "If find([L]CSTTYP,1,2) > 0"
Wrseq "  Gosub ITCREAD From STKVAL_SYRA"
Wrseq "Endif"
Wrseq "    [F:";ABR_XPL;"]PRI=[F:";ABR_XPL;"]PRI*(";FORMULEPRI;")"
Wrseq "EXPNUM=num$([F:";ABR_XPL;"]PRI)"
Wrseq "If instr(1,EXPNUM,'e')>0"
Wrseq "  WERR=[V]CST_AERROR"
Wrseq "  WMESSAGE = mess(15,197,1)+': '+[F:PPL]PLI+'  '+mess(16,197,1)+'\'+mess(65,106,1)"
Wrseq "  [F:";ABR_XPL;"]PRI=0"
Wrseq "Endif"
Wrseq "    Onerrgo"
  Endif
  If [F:PPC]PRIPRO=5
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "    [F:";ABR_XPL;"]PRI=(";FORMULEPRI;")"
Wrseq "    Onerrgo"
  Endif
  If ICONV<> 0
Wrseq "    [F:";ABR_XPL;"]PRI=[F:";ABR_XPL;"]PRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:PPC]ATICNVFLG<>[V]CST_ANO # 1
Wrseq "# Possibilité conversion ht/ttc"
Wrseq "    If PARAM.PRITYP<>WPRITYP"
Wrseq "      Raz CLCAMT"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT1)>0 : CLCAMT1=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT1 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT2)>0 : CLCAMT2=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT2 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT3)>0 : CLCAMT3=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT3 : Endif"

Wrseq ""
Wrseq "#      Local Integer ICPO"
Wrseq "#      Local Char WVAT(GLONVAT)(1..), WVAT_LEG(GLONADI)(1..)"
Wrseq "#      For ICPO=1 To maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)"
Wrseq "#        If PARAM.C_LINE(PLINEDOC).C_VAT(ICPO)<>null"
Wrseq "#          WVAT(ICPO)     = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT"
Wrseq "#          WVAT_LEG(ICPO) = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT_LEG"
Wrseq "#        Else"
Wrseq "#          WVAT(ICPO)     = ''"
Wrseq "#          WVAT_LEG(ICPO) = ''"
Wrseq "#        Endif"
Wrseq "#      Next ICPO"
Wrseq "#"
Wrseq "      Call CLCTAXEPRI2_ADAPTER(PARAM.ACTX,[F:";ABR_XPL;"]PRI,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT))"
Wrseq "&     ,WPRITYP,PARAM.CPY,PARAM.DOCDAT,PARAM.C_LINE(PLINEDOC).QTY,";
Wrseq "PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT,[F:";ABR_XPL;"]PRI) From TRTX3_SYRA"  # Bug 84596

Wrseq "    Endif"
  Endif
Wrseq "    If (RESULT.C_PRICE(1).MONTANT=0 & RESULT.C_PRICE(1).MOTIF=0) | RESULT.C_PRICE(1).MONTANT>[F:";ABR_XPL;"]PRI"
Wrseq "      RESULT.C_PRICE(1).MONTANT=arr([F:";ABR_XPL;"]PRI,10^-PARAM.GDECPRI)"
Wrseq "      RESULT.C_PRICE(1).MOTIF=WPRIREN"
Wrseq "      RESULT.C_PRICE(1).PRIORITE=PARAM.PIO"
Wrseq "     # PLI(0)=[F:";ABR_XPL;"]PLI : PLICRD(0)=[F:";ABR_XPL;"]PLICRD : PLILIN(0)=[F:";ABR_XPL;"]PLILIN"
Wrseq "      RESULT.C_PRICE(1).PLI=[F:";ABR_XPL;"]PLI : RESULT.C_PRICE(1).PLICRD=[F:";ABR_XPL;"]PLICRD : RESULT.C_PRICE(1).PLILIN=[F:";ABR_XPL;"]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
Endif

# treating the 9 columns fees / rebates
For I=0 To NBRCOLONNE-1
  If find ([F:PPC]DISCRGPRO(I),1,3)
     INDR=num$(I)
     INDN=num$(I+1)
    If [F:PPC]DISCRGPRO(I)=1
      If [F:PRS]VALTYP(I)=1
Wrseq "# frais/rem en montant"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
        If ICONV<>0
Wrseq "    [F:";ABR_XPL;"]DCGVAL(";INDR;")=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(3);
          If [F:PRS]CLCRUL(I)=1
Wrseq TEX(1);TEX(2);
          Endif
Wrseq

#   rounded following type data entry screen rates if treated uniteon amount by 9 columns fees / rebates
          If [F:PRS]CLCRUL=1
Wrseq "    Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
          Endif

#     rounded following type data entry screen rates if the amount per line
          If [F:PRS]CLCRUL=2
Wrseq "    Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
          Endif
        Endif

        If [F:PPC]ATICNVFLG<>[V]CST_ANO & [F:PRS]NPRNOTFLG=2  # 1
Wrseq "    If PARAM.PRITYP<>WPRITYP"
Wrseq "      Raz CLCAMT"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT1)>0 : CLCAMT1=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT1 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT2)>0 : CLCAMT2=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT2 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT3)>0 : CLCAMT3=PARAM.C_LINE(PLINEDOC).C_PPKD(1).CLCAMT3 : Endif"
Wrseq ""
Wrseq "      Call CLCTAXEPRI2_ADAPTER(PARAM.ACTX,[F:";ABR_XPL;"]DCGVAL(";INDR;"),PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT))"
Wrseq "&     ,WPRITYP,PARAM.CPY,PARAM.DOCDAT,PARAM.C_LINE(PLINEDOC).QTY,";
Wrseq "PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT,[F:";ABR_XPL;"]DCGVAL(";INDR;")) From TRTX3_SYRA"  # Bug 84596


Wrseq "      Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
             I1=instr(1,ATY_FORTYP(I+1),"=")
             If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
             Else
#Gbn-78037
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
             Endif
Wrseq "      Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
Wrseq "    Endif"
        Endif

        Else
Wrseq "# frais/rem en %"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
      Endif
      If [F:PRS]INCDCR(I)=1
#       this is an increase
Wrseq "    If (RESULT.C_DISCRG(";INDN;").MONTANT=0 & RESULT.C_DISCRG(";INDN;").MOTIF=0) | RESULT.C_DISCRG(";INDN;").MONTANT>[F:";ABR_XPL;"]DCGVAL(";INDR;")"
      Else
#       this is a reduction
Wrseq "    If (RESULT.C_DISCRG(";INDN;").MONTANT=0 & RESULT.C_DISCRG(";INDN;").MOTIF=0) | RESULT.C_DISCRG(";INDN;").MONTANT<[F:";ABR_XPL;"]DCGVAL(";INDR;")"
      Endif
Wrseq "      RESULT.C_DISCRG(";INDN;").MONTANT=[F:";ABR_XPL;"]DCGVAL(";INDR;") : RESULT.C_DISCRG(";INDN;").MOTIF=WPRIREN : RESULT.C_DISCRG(";INDN;").PRIORITE=PARAM.PIO"
Wrseq "      RESULT.C_DISCRG(";INDN;").PLI=[F:";ABR_XPL;"]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:";ABR_XPL;"]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:";ABR_XPL;"]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
    Endif
    If [F:PPC]DISCRGPRO(I)=3
Wrseq "# frais/rem initialisation"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
Wrseq "    RESULT.C_DISCRG(";INDN;").MONTANT=0 : RESULT.C_DISCRG(";INDN;").MOTIF=WPRIREN"
Wrseq "    RESULT.C_DISCRG(";INDN;").PLI=[F:";ABR_XPL;"]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:";ABR_XPL;"]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:";ABR_XPL;"]PLILIN"
Wrseq "  Endif"
    Endif
  Endif
Next I

# we do not treat the coef commission in shopping

#Free treatment
If [F:PPC]FOCPRO=2 | [F:PPC]FOCPRO=3
Wrseq "# les gratuits"
Wrseq "  If DOTASK_FOC"
Wrseq "    If [F:",ABR_XPL;"]FOCQTYMIN<=PARAM.C_LINE(PLINEDOC).QTY"
#--CPO ajout
Wrseq "      If RESULT.C_FOC(1)=null"
Wrseq "        WLINE = fmet RESULT.ADDLINE('C_FOC',[V]CST_AFIRSTPOS)"
Wrseq "        If WLINE = [V]CST_ANOTDEFINED"
Wrseq "          #--The insertion was not possible"
Wrseq "          [L]WERR = fmet RESULT.ASETERROR('', 'Data Class PPRICESEARCH : Method call LOADPARAMFROMDOC result error for MYPARAM.ADDLINE:', [V]CST_AERROR)"
Wrseq "          Return"
Wrseq "        Endif"
Wrseq "      Endif"
#--/
#    threshold
  If [F:PPC]FOCTYP=1
Wrseq "      RESULT.C_FOC(1).FOCQTY=[F:";ABR_XPL;"]FOCQTY"
Wrseq "      RESULT.C_FOC(1).FOCMOTIF=WPRIREN"
  Endif
#    multiple
  If [F:PPC]FOCTYP=2
Wrseq "      If WFOCQTYBKT=0 WFOCQTYBKT=1 Endif"
Wrseq "      RESULT.C_FOC(1).FOCQTY  = fix (((PARAM.C_LINE(PLINEDOC).QTY*COEFUNITE)-WFOCQTYMIN)/WFOCQTYBKT)*[F:";ABR_XPL;"]FOCQTY"
Wrseq "      RESULT.C_FOC(1).FOCMOTIF= WPRIREN"
  Endif
  If [F:PPC]FOCPRO=3
Wrseq "      If FOCQTY<>0"
Wrseq "        RESULT.C_FOC(1).FOCITMREF= [F:";ABR_XPL;"]FOCITMREF"
Wrseq "        RESULT.C_FOC(1).FOCUOM   = [F:";ABR_XPL;"]FOCUOM"
Wrseq "      Endif"
  Endif

Wrseq "    Endif"
Wrseq "  Endif"
Endif

Wrseq "  RESULT.PLISTRDAT = [F:";ABR_XPL;"]PLISTRDAT"
Wrseq "  RESULT.PLIENDDAT = [F:";ABR_XPL;"]PLIENDDAT"
# For purchases greater recovery time in VALUE (10)
Wrseq "#Récupération du plus grand délai"
Wrseq "  If DOTASK_REPCOE < [F:";ABR_XPL;"]LTI"
Wrseq "      DOTASK_REPCOE = [F:";ABR_XPL;"]LTI"
Wrseq "  Endif"
Wrseq "$TAR_SUIVANT"
Wrseq "Next"
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "End"
Return


#------------------------------------------------------------------------
# group rate: generation treatment
#------------------------------------------------------------------------
$TR_GROUPE
Local Shortint ILK            : # pour ne pas generer Call ALIPLK
#--- pas d'appel à ALIPLK si : absence de PPRICLINK dans les critères
#                              si traitement du prix ( par formule ou coefficient)
#                              si maj des prix nul ( pour test de [F:PPK]FOCITM )
#

# - CPO => need for the class parameter contains an array of parameters already loaded associated with each line
#ILK= find("PPK",[F:PPC]ABB) + find([F:PPC]PRIPRO,4,5) + ([F:PPC]UPDNULPRI=2)

Wrseq "Raz UPDGRP"
Wrseq "If !PARAM.GPPLXGRP           : # pour faire une recherche multiple des groupes"
Wrseq "  If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : End : Endif"
Wrseq "Endif"

#------------------------------------------------------------------------
#     Generating primary loop (A: NLD) on the lines of the document

Wrseq ""
Wrseq "#--- Boucle (A:NLD) sur les lignes du document -------------------"
Wrseq "For NLD=1 To maxtab(PARAM.C_LINE)"
Wrseq "  If !PARAM.GPPLXGRP"
Wrseq "    If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : Break : Endif"
Wrseq "  Endif"
Wrseq "  If (PARAM.C_LINE(NLD).GRPFLG=0 | PARAM.GPPLXGRP) & UPDGRP(NLD-1)=0"

#--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne

If find("ITM",[F:PPC]ABB)                    : # read ITMMASTER if present in the criteria
  Wrseq "    If [F:ITM]ITMREF<>PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      Read [ITM]ITM0=PARAM.C_LINE(NLD).ITMREF"
  Wrseq "      If fstat : Raz [F:ITM] : Endif"
  Wrseq "    Endif"
Endif
If find("ITP",[F:PPC]ABB)                    : # read ITMBPS if present in the criteria
  Wrseq "      If [F:ITP]ITMREF<>PARAM.C_LINE(NLD) | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
  Wrseq "        Read [ITP]ITP0=PARAM.C_LINE(NLD);[F:BPS]BPSNUM"
  Wrseq "        If fstat : Raz [F:ITP] : Endif"
  Wrseq "      Endif"
Endif

#- New below
If find("PPK",[F:PPC]ABB)                    : # read PPRICELINK if present in the criteria
Wrseq "#--Transclasse [F:PPK] with PARAM.C_PPKH(1) et PARAM.C_LINE(NLD).C_PPKD(1)"
Wrseq "If PARAM.C_PPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR > [V]CST_AINFO"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()', [V]CST_AERROR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(NLD).C_PPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(NLD).C_PPKD(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR > [V]CST_AINFO"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'fmet PARAM.C_LINE(NLD).C_PPKD(1).LOAD_TO_PPK_FILE()', [V]CST_AERROR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Endif
#- New above

Wrseq "      WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
    Case [F:PPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "    Gosub CRIT_IDEM_NLD"
Wrseq "  Endif"
Wrseq "Next"
Wrseq "End"
Wrseq ""

#------------------------------------------------------------------------
# Generation secondary loop (B: PPL) on tariff lines with:
# - Criteria for the current line of the loop (A: NLD)
# - Valid on the date the document
# - The same currency (currency conversion only if No)
# - No filter units (selection effected on the lines)

Gosub TR_GRP_CI_NLD

Return

$TR_GRP_CI_NLD
Wrseq "#-----------------------------------------------------------------"
Wrseq "#--- Pour chaque ligne de la Boucle (A:NLD) en cours -------------"
Wrseq "#--- Boucle (B:PPL) : lignes tarifs ayant criteres ligne NLD -----"
Wrseq ""
Wrseq "$CRIT_IDEM_NLD"
#--CPO ajout
Wrseq "IGR=1"
Wrseq ""
#--/
Wrseq "For [";ABR_XPL;"]";ABR_XPL;"1 Where [F:";ABR_XPL;"]PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=WCRIT"
Wrseq "&  & PARAM.DOCDAT>=[F:";ABR_XPL;"]PLISTRDAT & PARAM.DOCDAT<=[F:";ABR_XPL;"]PLIENDDAT"
If [F:PPC]CURCNVFLG=[V]CST_ANO & SAISIEDEV=1          : # si tarif sans conversion devise (filtre devise identique)
  Wrseq "&  & [F:";ABR_XPL;"]CUR=PARAM.CUR"
Endif

Wrseq "  If !PARAM.GPPLXGRP"
Wrseq "    If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : break : Endif"
Wrseq "  Endif"
Wrseq "  Raz CUMQTY, CUMAMT, SELGRP"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
Raz TEX : ICONV=0
If [F:PPC]CURCNVFLG=[V]CST_AYES # 2                        : # si tarif avec conversion devise
Wrseq "  If [F:";ABR_XPL;"]CUR<>PARAM.CUR"
Wrseq "    Call CONVERT(PARAM.ACTX,[F:";ABR_XPL;"]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI) From TRTDEV_SYRA"
Wrseq "    If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"

Wrseq "  Endif"
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif
Wrseq "#--- Pour chaque ligne tarif de la Boucle (B:PPL) ----------------"
Wrseq "#--- Boucle (C:NLG) : lignes du documents ------------------------"
Wrseq "  For NLG=1 to maxtab(PARAM.C_LINE)"
Wrseq "    If (PARAM.C_LINE(NLG).GRPFLG=0 | PARAM.GPPLXGRP) & UPDGRP(NLG-1)=0"

#--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne

If find("ITM",[F:PPC]ABB)                    : # lecture ITMMASTER si present dans les criteres
  Wrseq "      If [F:ITM]ITMREF<>PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        Read [ITM]ITM0=PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        If fstat : Raz [F:ITM] : Endif"
  Wrseq "      Endif"
Endif

If find("ITP",[F:PPC]ABB)                    : # lecture ITMBPS si present dans les criteres
  Wrseq "      If [F:ITP]ITMREF<>PARAM.C_LINE(NLG).ITMREF | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
  Wrseq "        Read [ITP]ITP0=PARAM.C_LINE(NLG).ITMREF;[F:BPS]BPSNUM"
  Wrseq "        If fstat : Raz [F:ITP] : Endif"
  Wrseq "      Endif"
Endif

#- New below
If find("PPK",[F:PPC]ABB)                    : # lecture PPRICELINK si present dans les criteres
Wrseq "#--Transclasse [F:PPK] with PARAM.C_PPKH(1) et PARAM.C_LINE(NLG).C_PPKD(1)"
Wrseq "If PARAM.C_PPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR > [V]CST_AINFO"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'fmet PARAM.C_PPKH(1).LOAD_TO_PPK_FILE()', [V]CST_AERROR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(NLG).C_PPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(NLG).C_PPKD(1).LOAD_TO_PPK_FILE()"
Wrseq "  If WERR > [V]CST_AINFO"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', 'fmet PARAM.C_LINE(NLG).C_PPKD(1).LOAD_TO_PPK_FILE()', [V]CST_AERROR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Endif
#-New above
Wrseq "      WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
    Case [F:PPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "      If WCRIT=[F:";ABR_XPL;"]PLICRI"
Wrseq "        CONVQTY=PARAM.C_LINE(NLG).QTYUOM"
If [F:PPC]PRIQTYFLG=5                        : # si tranches tarifs sur prix nets
Wrseq "        CONVQTY=PARAM.C_LINE(NLG).NETPRI"
  Else                                       : # si tranches tarifs sur prix bruts
Wrseq "        CONVQTY=PARAM.C_LINE(NLG).GROPRI"
Endif
Wrseq "        NONSEL=0"
Wrseq "        COEFUNITE=1"

If [F:PPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites
  If [F:PPC]UOMCNVFLG=[V]CST_AYES #2         : # si tarif avec conversion unites
Wrseq "        If [F:";ABR_XPL;"]UOM<>PARAM.C_LINE(NLG).PUU"
Wrseq "          Call PCAL_QTY(CONVQTY,PARAM.C_LINE(NLG).PUU,CONVQTY,[F:";ABR_XPL;"]UOM,"
Wrseq "&                       PARAM.C_LINE(NLG).ITMREF,[F:BPS]BPSNUM,1,COEFUNITE) From TRTACHQTE1_SYRA"
Wrseq "          If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "#         en sortie de PCAL_QTY, CONVQTY est en unite du tarif"
Wrseq "        Endif"
  Else                                       : # si tarif sans conversion unites
Wrseq "        If [F:";ABR_XPL;"]UOM<>PARAM.C_LINE(NLG).PUU : NONSEL=1 : CONVQTY=0 : Endif"
  Endif
Endif

Wrseq "        If NONSEL=0"
Wrseq "          CUMQTY += CONVQTY"
Wrseq "#         attention on reste dans devise tarif (donc /coefdevise)"
Wrseq "          If COEFDEVISE=0 : COEFDEVISE=1 : Endif"
Wrseq "          CUMAMT += (CONVPRI*PARAM.C_LINE(NLG).QTYUOM/COEFDEVISE)"
Wrseq "          SELGRP(NLG-1)=1"
Wrseq "        Endif"
Wrseq "      Endif"
Wrseq "    Endif"
Wrseq "  Next NLG"
Wrseq ""
Wrseq "  If sum(SELGRP)>0"
If [F:PPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites
    Wrseq "    If CUMQTY>=[F:";ABR_XPL;"]MINQTY & CUMQTY<=[F:";ABR_XPL;"]MAXQTY"
    Wrseq "      CUMALL=CUMQTY"
  Else                                       : # si tranches tarifs sur prix bruts ou nets
    Wrseq "    If CUMAMT>=[F:";ABR_XPL;"]MINAMT & CUMAMT<=[F:";ABR_XPL;"]MAXAMT"
    Wrseq "      CUMALL=CUMAMT"
Endif

Wrseq "      COEFUNITE=1 : COEFPOURN=1 "

Wrseq "      LIGMAJ=0 : # pour tester si 1ere ligne en m.a.j."
Wrseq "#           boucle des lignes de cde .."
Wrseq "      For NLG=1 to maxtab(PARAM.C_LINE)"
Wrseq "        If SELGRP(NLG-1)<>0"
Wrseq "          UPDGRP(NLG-1)=1"
Wrseq "          LIGMAJ +=1"
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLI      = AVOID.ACHAR"
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLICRD   = AVOID.ACHAR"
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLILIN   = AVOID.AINT"

Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLI    = AVOID.ACHAR"
Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLICRD = AVOID.ACHAR"
Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLILIN = AVOID.AINT"

Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLI    = AVOID.ACHAR"
Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLICRD = AVOID.ACHAR"
Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLILIN = AVOID.AINT"
Wrseq "          Gosub TR_GRPLIG : # Traitement 1 ligne"
Wrseq ""
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLI      = AVOID.ACHAR"
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLICRD   = AVOID.ACHAR"
Wrseq "          RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLILIN   = AVOID.AINT"

Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLI    = AVOID.ACHAR"
Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLICRD = AVOID.ACHAR"
Wrseq "          RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLILIN = AVOID.AINT"

Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLI    = AVOID.ACHAR"
Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLICRD = AVOID.ACHAR"
Wrseq "          RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLILIN = AVOID.AINT"
Wrseq "        Endif"
Wrseq "      Next NLG"

If [F:PPC]FOCPRO=4                           : # attribution art. gratuits sur total document
Wrseq "#           les gratuits"
  If [F:PPC]PRIQTYFLG=3                      : # test sur quantite
Wrseq "      If [F:";ABR_XPL;"]FOCITMREF<>'' & [F:";ABR_XPL;"]FOCQTYMIN<=CUMQTY"
  Endif
  If find([F:PPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net
Wrseq "      If [F:";ABR_XPL;"]FOCITMREF<>'' & [F:";ABR_XPL;"]FOCAMTMIN<=CUMALL"
  Endif
Wrseq "        If !find([F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN),FOCUPDTST)"
#--CPO ajout
Wrseq "            If RESULT.C_FOC(IGR) = null"
Wrseq "              IGR = fmet RESULT.ADDLINE('C_FOC',IGR)"
Wrseq "              If IGR = [V]CST_ANOTDEFINED"
Wrseq "                #--The insertion was not possible"
Wrseq "                [L]WERR = fmet RESULT.ASETERROR('', 'Subprog SUBPPCT_SYRA : Method call TARIF result error for RESULT.ADDLINE:', [V]CST_AERROR)"
Wrseq "                Break"
Wrseq "              Endif"
Wrseq "            Endif"
#--/
Wrseq "            RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLI      = AVOID.ACHAR"
Wrseq "            RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLICRD   = AVOID.ACHAR"
Wrseq "            RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLILIN   = AVOID.AINT"

Wrseq "            RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLI    = AVOID.ACHAR"
Wrseq "            RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLICRD = AVOID.ACHAR"
Wrseq "            RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLILIN = AVOID.AINT"

Wrseq "            RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLI    = AVOID.ACHAR"
Wrseq "            RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLICRD = AVOID.ACHAR"
Wrseq "            RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLILIN = AVOID.AINT"

  If [F:PPC]FOCTYP=1                         : # type de gratuite : seuil
Wrseq "            FOCUPDTST(IGR)=[F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN)"
Wrseq "            RESULT.C_FOC(IGR).FOCITMREF=[F:";ABR_XPL;"]FOCITMREF"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY   =[F:";ABR_XPL;"]FOCQTY"
Wrseq "            RESULT.C_FOC(IGR).FOCUOM   =[F:";ABR_XPL;"]UOM"
Wrseq "            RESULT.C_FOC(IGR).FOCMOTIF =WPRIREN"
Wrseq "          Endif"

  Elsif [F:PPC]FOCTYP=2                      : # type de gratuite : multiple
Wrseq "            FOCUPDTST(IGR)=[F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN)"
Wrseq "            RESULT.C_FOC(IGR).FOCITMREF = [F:";ABR_XPL;"]FOCITMREF"
    If [F:PPC]PRIQTYFLG=3                      : # test sur quantite
Wrseq "            If [F:";ABR_XPL;"]FOCQTYBKT=0 [F:";ABR_XPL;"]FOCQTYBKT=1 Endif"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY  = fix ((CUMALL-[F:";ABR_XPL;"]FOCQTYMIN)/[F:";ABR_XPL;"]FOCQTYBKT)*[F:";ABR_XPL;"]FOCQTY"
    Endif
    If find([F:PPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net
Wrseq "            If  [F:";ABR_XPL;"]FOCAMTBKT=0  [F:";ABR_XPL;"]FOCAMTBKT=1 Endif"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY    = fix ((CUMALL- [F:";ABR_XPL;"]FOCAMTMIN)/ [F:";ABR_XPL;"]FOCAMTBKT)* [F:";ABR_XPL;"]FOCQTY"
    Endif
Wrseq "            RESULT.C_FOC(IGR).FOCUOM    = [F:";ABR_XPL;"]FOCUOM"
Wrseq "            RESULT.C_FOC(IGR).FOCMOTIF  = WPRIREN"
Wrseq "          Endif"

  Else
Wrseq "          Endif"
  Endif

Wrseq "        Endif"
Wrseq "      Endif"
Endif

Wrseq "    Endif"
Wrseq "  Endif"

Wrseq "Next"
Wrseq "Return"
Return


$TR_GRPLIG
# --- Mise a jour une ligne (devis, cde, etc..) suivant tarif groupé
Wrseq ""
Wrseq "$TR_GRPLIG"
Wrseq "COEFUNITE=1"
# On détermine la conversion unité
If [F:PPC]UOMCNVFLG=[V]CST_AYES # 2              : # si tarif avec conversion unites
  Raz TESTUOM
  TESTUOM=find(1,[F:PRS]VALTYP(0..NBRCOLONNE-1)) : # si une colonne de tarif est en montant
  If [F:PPC]PRIPRO>1 : TESTUOM=1 : Endif         : # si le tarif gere le prix
  If TESTUOM>0
Wrseq "# Conversion unite"
Wrseq "If [F:";ABR_XPL;"]UOM<>PARAM.C_LINE(NLG).PUU"
Wrseq "  Call PCAL_QTY(CONVQTY,PARAM.C_LINE(NLG).PUU,CONVQTY,[F:";ABR_XPL;"]UOM,"
Wrseq "&               PARAM.C_LINE(NLG).ITMREF,[F:BPS]BPSNUM,1,COEFUNITE) From TRTACHQTE1_SYRA"
Wrseq "  If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "Endif"
    TEX(1)="*COEFUNITE"
    ICONV=1
  Endif
Endif

# On traite la colonne prix
If [F:PPC]PRIPRO>1                           : # si le tarif gere les prix

  If [F:PPC]PRIPRO=2                         : # prix en valeur
Wrseq "# Prix en valeur"
Wrseq "CONVPRI=[F:";ABR_XPL;"]PRI"
  Endif
  If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5       : # prix par coefficient ou par calcul (formule)
Wrseq "# Prix par coeff. ou calcul : lecture ITP et ITV"
Wrseq "If [F:ITP]ITMREF<>[F:ITM]ITMREF | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
Wrseq "  Read [ITP]ITP0 = [F:ITM]ITMREF;[F:BPS]BPSNUM"
Wrseq "  If fstat : Raz [F:ITP] : Endif"
Wrseq "Endif"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>PARAM.C_LINE(NLG).C_PPKD(1).PRHFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; PARAM.C_LINE(NLG).C_PPKD(1).PRHFCY"
Wrseq "  If fstat : raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim(PARAM.C_LINE(NLG).C_PPKD(1).CSTTYP)>0"
Wrseq "   If find(PARAM.C_LINE(NLG).C_PPKD(1).CSTTYP,1,2,99) : [L]CSTTYP=PARAM.C_LINE(NLG).C_PPKD(1).CSTTYP    : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>PARAM.C_LINE(NLG).C_PPKD(1).PRHFCY | [F:ITC]ITMREF<>[F:ITM]ITMREF |"
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| [F:ITC]ITCSTRDAT>PARAM.DOCDAT | PARAM.DOCDAT>[F:ITC]ITCENDDAT"
Wrseq "       Raz [F:ITC]"
Wrseq "       Call GETPRI([F:ITM]ITMREF,'','',PARAM.C_LINE(NLG).C_PPKD(1).PRHFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:PPC]PRIPRO=4                         : # prix par coefficient (formule)
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "Onerrgo ERR_PRI"
Wrseq "If find([L]CSTTYP,1,2) > 0"
Wrseq "  Gosub ITCREAD From STKVAL_SYRA"
Wrseq "Endif"
Wrseq "CONVPRI=[F:";ABR_XPL;"]PRI*(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If [F:PPC]PRIPRO=5                         : # prix par calcul (formule)
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "Onerrgo ERR_PRI"
Wrseq "CONVPRI=(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If ICONV<>0
Wrseq "CONVPRI=CONVPRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:PPC]ATICNVFLG<>[V]CST_ANO # 1                  : # si tarif avec conversion de prix HT<-->TTC
Wrseq "#   Possibilité conversion ht/ttc"
#--CPO ajout => pas besoin car existe dans la classe paramètres (il faut par contre s'assurer que le pointeurs <> null
Wrseq "If PRITYP<>WPRITYP"
Wrseq "      Call CLCTAXEPRI2_ADAPTER(PARAM.ACTX,[F:";ABR_XPL;"]PRI,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT))"
Wrseq "&     ,WPRITYP,PARAM.CPY,PARAM.DOCDAT,PARAM.C_LINE(PLINEDOC).QTY,";
Wrseq "PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT,[F:";ABR_XPL;"]PRI) From TRTX3_SYRA"  # Bug 84596

Wrseq "Endif"
  Endif
Wrseq "If CONVPRI<>0"
# Issue 122499
# En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "   If CONVPRI<PARAM.C_LINE(NLG).GROPRI | PARAM.C_LINE(NLG).PRIREN=0 | (PARAM.C_LINE(NLG).GROPRI=0 & UPDNULPRI=[V]CST_AYES)"
Wrseq "   If CONVPRI<=PARAM.C_LINE(NLG).GROPRI | PARAM.C_LINE(NLG).PRIREN=0 | (PARAM.C_LINE(NLG).GROPRI=0 & UPDNULPRI=[V]CST_AYES)"
# End issue 122499
Wrseq "      PARAM.C_LINE(NLG).GROPRI=arr(CONVPRI,10^-PARAM.GDECPRI) : PARAM.C_LINE(NLG).PRIREN=WPRIREN"
Wrseq "      PARAM.C_LINE(NLG).GRPFLG=[V]CST_ANO"  #1"
Wrseq "   Endif"
Wrseq "Endif"
Endif

# On traite les 9 colonnes frais/remises
For I=0 To NBRCOLONNE-1
  If find ([F:PPC]DISCRGPRO(I),1,3)          : # si colonne tarif geree ou initialisee
    INDR=num$(I)
    INDN=num$(I+1)
# Génération du libelle
    Wrseq ""
    Wrseq "# ";
    If [F:PRS]INCDCR(I)=1 : Wrseq "Frais-"; : Endif
    If [F:PRS]INCDCR(I)=2 : Wrseq "Remise-"; : Endif
    Wrseq INDN;" ";
    If [F:PRS]VALTYP(I)=1 : Wrseq "en Montant "; : Endif
    If [F:PRS]VALTYP(I)=2 : Wrseq "en %Cumul "; : Endif
    If [F:PRS]VALTYP(I)=3 : Wrseq "en %Cascade "; : Endif
    If [F:PRS]CLCRUL(I)=1 : Wrseq "par Unité "; : Endif
    If [F:PRS]CLCRUL(I)=2 : Wrseq "par Ligne "; : Endif
    If [F:PRS]CLCRUL(I)=3 : Wrseq "par Document "; : Endif
    If [F:PPC]DISCRGPRO(I)=3 : Wrseq "(Initialisation)"; : Endif
    Wrseq

    If [F:PPC]DISCRGPRO(I)=1                 : # si colonne tarif geree

#                Montant à la ligne ou unité

      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)<>3      : # si colonne montant par unite
Wrseq "CONVPRI=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(1);TEX(3)
        If ICONV<>0
Wrseq "If [F:";ABR_XPL;"]CUR<>PARAM.CUR | PARAM.C_LINE(NLG).PUU<>[F:";ABR_XPL;"]UOM"
Wrseq "  Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
         I1=instr(1,ATY_FORTYP(I+1),"=")
         If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
         Else
#Gbn-78037
Wrseq "  If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
         Endif
Wrseq "  Gosub ARRFMT : CONVPRI=arr(CONVPRI,APDC_RND)"
Wrseq "Endif"
        Endif

        If [F:PRS]INCDCR(I)=1                : # c est une majoration
#         c est une majoration
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL = 0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL>=CONVPRI"
# Bug 73486
        Else                                 : # c est une minoration
#         c est une minoration
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL<=CONVPRI"
        Endif

Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=CONVPRI"
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=WPRIREN"
Wrseq "  PARAM.C_LINE(NLG).GRPFLG=[V]CST_ANO"  #1"
Wrseq "Endif"
      Endif
#                Montant au document (trt sur 1ere ligne)
      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)=3       : # si colonne montant par document
Wrseq "If LIGMAJ=1"
Wrseq "  CONVPRI=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(3)
        If ICONV<>0
Wrseq "  If [F:";ABR_XPL;"]CUR<>PARAM.CUR"
#               la valeur va dans le pied (arrondi devise obligatoire)
Wrseq "    Call ARRDEV(CONVPRI, PARAM.CUR, PARAM.CPY) From TRTDIV_SYRA"
Wrseq "  Endif"
        Endif
#        on met la remise montant dans la rubrique d'appel
Wrseq "  RESULT.C_DISCRG(";INDN;").MONTANT= RESULT.C_DISCRG(";INDN;").MONTANT+CONVPRI"
Wrseq "  RESULT.C_DISCRG(";INDN;").MOTIF  = [F:PRS]INVDTA(";INDR;")"

Wrseq "Endif"
      Endif

#                % line

      If [F:PRS]VALTYP(I)>1                  : # colonne en pourcentage
        If [F:PRS]INCDCR(I)=1                : # c est une majoration
#         c est une majoration
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL>=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
# Bug 73486
        Else                                 : # c est une minoration
#         c est une minoration
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL<=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
# Bug 73486
        Endif
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=WPRIREN"
Wrseq "  PARAM.C_LINE(NLG).GRPFLG=[V]CST_ANO" # 1"
Wrseq "Endif"
      Endif
    Endif

#               Fresh / rem Initialization

    If [F:PPC]DISCRGPRO(I)=3                 : # colonne tarif a initialiser
      If [F:PRS]CLCRUL(I)=3                  : # colonne par document
Wrseq "RESULT.C_DISCRG(";INDN;").MONTANT=0"
Wrseq "RESULT.C_DISCRG(";INDN;").MOTIF=0"
      Else                                   : # colonne par unite ou par ligne
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=0"
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=0"
Wrseq "PARAM.C_LINE(NLG).GRPFLG=[V]CST_ANO" # 1"
      Endif

    Endif
  Endif
Next I

Wrseq "Return"

Return

#------------------------------------------------------------------------
# Price prohibited: generation treatment
#------------------------------------------------------------------------
$TR_INTERDIT
Gosub LE_FILTRE
Wrseq "For [";ABR_XPL;"]"
Wrseq "RESULT.INTERDIT=1 : Break"
Wrseq "Next"
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "End"
Return

#------------------------------------------------------------------------
# Constitution de l'arrondi en fonction d'un format
# (utilise pour les arrondis des colonnes frais/remises
#------------------------------------------------------------------------
$FORMAT_ARRONDI
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Constitution de l'arrondi en fonction d'un format"
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Utilisé notamment dans la recherche tarif pour les colonnes frais/rem"
Wrseq "# Entree : APDC_CUR = Code devise"
Wrseq "# Entrée : APDC_FMT = Format sous la forme 12.4#"
Wrseq "# Sortie : APDC_RND = Arrondi sous la forme 0.0001 (pour instruction arr)"
Wrseq "#------------------------------------------------------------------------"
Wrseq "$LECTCU"
Wrseq "If APDC_CUR='' : APDC_CUR=PARAM.GLOCALDEV : Endif"
Wrseq "If APDC_CUR<>[F:TCU]CUR"
Wrseq "   Read [TCU]TCU0=APDC_CUR"
Wrseq "Endif"
Wrseq "Return"
Wrseq "$ARRFMT"
Wrseq "APDC_RND=min([F:TCU]CURRND,10^-(mod(val(APDC_FMT),1)*10))"
Wrseq "Return"
Wrseq "#------------------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Filtre sur les critères:
#   pour lecture des lignes de la fiche qui répondent aux critères
#   Utilisé si objet utilisé à partir de la recherche tarif FUNACHPPSI
#------------------------------------------------------------------------
$FILTRE_CRITERES
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour visualiser uniquement les lignes de la fiche répondant"
Wrseq "# aux critères ( utilisé dans la simulation )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$FILTRE_CRITERES"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:PPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I
Wrseq 'CRIT += " & PLICRI=';
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq '"'
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Type de donnée des critères:
#   pour permettre la gestion correcte de tous les types de données
#   ( y compris ceux définis par l'utilisateur )
#------------------------------------------------------------------------
$TYPE_CRITERES
Local Char WFLDTYPINT (3)
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour connaitre le type de donnée des critères "
Wrseq "# Fournir le type de donnée dans FLDTYPEXT  ( ex : BPC, ADI, ...)"
Wrseq "# Pour récuperer FLDTYPINT ( M, C, L, DCB, A, D )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$TYPE_CRITERES"
Wrseq "Local char    TFLDTYPEXT (3) (0..5)"
Wrseq "Local char    TFLDTYPINT (3) (0..5)"
Wrseq "Local Integer IJLS"
Wrseq "If dim(FLDTYPEXT)>0 & dim(FLDTYPINT)>0"

For I=0 To 4
 If [F:PPC]ABB(I)<>""
   Read [ATY] CODTYP=[F:PPC]FLDTYP(I)
   If fstat
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:PPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='A'"
   Else
     Case [F:ATY]TYPTYP
       When 1      : WFLDTYPINT="M"    : # Menu local
       When 2      : WFLDTYPINT="C"    : # Entier court
       When 3      : WFLDTYPINT="L"    : # Entier long
       When 4,5,6  : WFLDTYPINT="DCB"  : # Decimal, Flottant, Double
       When 7      : WFLDTYPINT="A"    : # Alpha
       When 8      : WFLDTYPINT="D"    : # Date
     Endcase
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:PPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='";WFLDTYPINT;"'"
   Endif
 Endif
Next I

Wrseq "  IJLS = find (FLDTYPEXT,TFLDTYPEXT)"
Wrseq "  If IJLS : FLDTYPINT=TFLDTYPINT(IJLS-1) : Endif"
Wrseq "Endif"
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Extraction des lignes de tarif pour la consultation dans FUNACHPPSI
#   stockage dans le masque PPSIMUL0
#------------------------------------------------------------------------
$CONSULTATION
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour extraction et stockage des lignes de toutes les fiches"
Wrseq "# stockage dans le masque PPSIMUL0 ( utilisé dans FUNACHPPSI )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$CONSULTATION"
Wrseq "Local Date DATPLUS     : # date borne de simulation des tarifs (+1mois par défaut)"
Wrseq "Local Decimal QTYPLUS  : # qté  borne de simulation des tarifs (+100% si PARAM.C_LINE(PLINEDOC).QTY<>0)"
Wrseq "Local Decimal QTYMOINS : # qté  borne de simulation des tarifs (-50%  si PARAM.C_LINE(PLINEDOC).QTY<>0)"
Wrseq "Local Integer ONPREND,JLV,ILINE, IRETLINE"
Wrseq "If dim(PARAM.MOIS)>0 DATPLUS=addmonth(PARAM.DOCDAT,PARAM.MOIS) Else DATPLUS=addmonth(PARAM.DOCDAT,1) Endif"
Wrseq "If PARAM.C_LINE(PLINEDOC).QTY<>0 : QTYMOINS=PARAM.C_LINE(PLINEDOC).QTY*0.5 : QTYPLUS=PARAM.C_LINE(PLINEDOC).QTY*2 : Endif"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:PPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I

Wrseq "# Lecture des tarifs"
Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
Wrseq "&  & PLISTRDAT<=[L]DATPLUS"
Wrseq "&  & PLIENDDAT>=PARAM.DOCDAT"
If [F:PPC]UOMCNVFLG=[V]CST_ANO & ZZ(8)=1
  Wrseq "&  & UOM=PARAM.C_LINE(PLINEDOC).PUU"
Endif
If [F:PPC]CURCNVFLG=[V]CST_ANO & SAISIEDEV=1
  Wrseq "&  & CUR=PARAM.CUR"
Endif
Wrseq "&    Order by PLI; PLICRI; PLISTRDAT; MAXQTY"

Wrseq "For [";ABR_XPL;"]"
If [F:PPC]PRIQTYFLG=2
  Wrseq "Raz ONPREND"
Else
  Wrseq "ONPREND=1"
Endif
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
If ABR_XPL="SPL"
   Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
Else
   Wrseq "  If [F:PPL]UOM='*' : [F:PPL]UOM=[F:ITM]PUU : Endif"
Endif
If [F:PPC]PRIPRO<4
  Wrseq "  If [F:";ABR_XPL;"]PRIDIV<>0 : COEFPOURN=[F:";ABR_XPL;"]PRIDIV : Endif"
Endif
If [F:PPC]CURCNVFLG=[V]CST_AYES # 2
  Wrseq "  If [F:";ABR_XPL;"]CUR<>PARAM.CUR"
  Wrseq "      Call CONVERT(PARAM.ACTX,[F:";ABR_XPL;"]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI) From TRTDEV_SYRA"
  Wrseq "      If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "  Endif"
Endif
If [F:PPC]UOMCNVFLG=[V]CST_AYES # 2 : # si conversion unité acceptée
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:";ABR_XPL;"]UOM<>PARAM.C_LINE(PLINEDOC).PUU"
  Wrseq "    WMANDEC=[F:";ABR_XPL,"]MINQTY"
  Wrseq "    Call PCAL_QTY (WMANDEC,[F:";ABR_XPL;"]UOM,WMANDEC,PARAM.C_LINE(PLINEDOC).PUU,[F:ITM]ITMREF,[F:BPS]BPSNUM,2,"
  Wrseq "&                 COEFUNITE) From TRTACHQTE1_SYRA"
  Wrseq "    If COEFUNITE=0 : COEFUNITE=1 : Endif"
  Wrseq "    [F:";ABR_XPL;"]MINQTY=[F:";ABR_XPL;"]MINQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]MAXQTY=[F:";ABR_XPL;"]MAXQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]FOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]FOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT/COEFUNITE"
  If [F:PPC]FOCPRO=2 : # si qté gratuite sur meme article
  Wrseq "    [F:";ABR_XPL;"]FOCQTY=[F:";ABR_XPL;"]FOCQTY/COEFUNITE"
  Wrseq "    Call QTEARR ([F:";ABR_XPL;"]FOCQTY,PARAM.C_LINE(PLINEDOC).PUU) From TRTDIV_SYRA"
  Endif
  Wrseq "  Endif"
Endif
If [F:PPC]PRIQTYFLG=2
  Wrseq "  If    PARAM.C_LINE(PLINEDOC).QTY=0"
  Wrseq "    ONPREND=1"
  Wrseq "  Elsif QTYPLUS>=[F:";ABR_XPL;"]MINQTY & QTYMOINS<=[F:";ABR_XPL;"]MAXQTY"
  Wrseq "    ONPREND=1"
  Wrseq "  Endif"
Endif
Wrseq "  If ONPREND=1"
#--CPO ajout => il faut instancier les éléments de la collection
Wrseq "  JLV = fmet RESULT.ADDLINE('C_PRICEINQ',JLV)" #11)"
Wrseq "  If JLV = [V]CST_ANOTDEFINED"
Wrseq "    #--The insertion was not possible"
Wrseq "    [L]WERR = fmet RESULT.ASETERROR('', 'Data Class PPRICESEARCH : Method call LOADDOCFROMRESULT result error for RESULT.ADDLINE:', [V]CST_AERROR)"
Wrseq "    Return"
Wrseq "  Endif"
#--
Wrseq "    RESULT.C_PRICEINQ(JLV).DATDEB   = [F:";ABR_XPL;"]PLISTRDAT"
Wrseq "    RESULT.C_PRICEINQ(JLV).DATFIN   = [F:";ABR_XPL;"]PLIENDDAT"
Wrseq "    RESULT.C_PRICEINQ(JLV).MINQTY   = [F:";ABR_XPL;"]MINQTY"
Wrseq "    RESULT.C_PRICEINQ(JLV).MAXQTY   = [F:";ABR_XPL;"]MAXQTY"
Wrseq "    RESULT.C_PRICEINQ(JLV).MINAMT   = [F:";ABR_XPL;"]MINAMT"
Wrseq "    RESULT.C_PRICEINQ(JLV).MAXAMT   = [F:";ABR_XPL;"]MAXAMT"
Wrseq "    RESULT.C_PRICEINQ(JLV).CUR      = [F:";ABR_XPL;"]CUR"
Wrseq "    If [F:";ABR_XPL;"]UOM<>''"
Wrseq "    RESULT.C_PRICEINQ(JLV).UOM    = PARAM.C_LINE(PLINEDOC).PUU"
Wrseq "    Endif"
Wrseq "    RESULT.C_PRICEINQ(JLV).LTI      = [F:";ABR_XPL;"]LTI"
Wrseq "    RESULT.C_PRICEINQ(JLV).PRIDIV   = [F:";ABR_XPL;"]PRIDIV"

If [F:PPC]PRIPRO=4
    Wrseq "    RESULT.C_PRICEINQ(JLV).COE      = [F:";ABR_XPL;"]PRI"          : # coefficient
  Else
    Wrseq "    RESULT.C_PRICEINQ(JLV).PRI      = [F:";ABR_XPL;"]PRI"          : # prix

Endif

If [F:PPC]PRIPRO<4
  Wrseq "    If [F:";ABR_XPL;"]PRIDIV<>0 : RESULT.C_PRICEINQ(JLV).PRI=[F:";ABR_XPL;"]PRI/[F:";ABR_XPL;"]PRIDIV : Endif"
  Wrseq "    RESULT.C_PRICEINQ(JLV).PRI=RESULT.C_PRICEINQ(JLV).PRI*COEFUNITE"
Endif

For I=1 To 9
  #--CPO ajout => il faut instancier les éléments de la collection
  Wrseq "  If RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;") = null"
  Wrseq "    WLINE = fmet RESULT.C_PRICEINQ(JLV).ADDLINE('C_FRAREM',";I;")"
  Wrseq "    If WLINE = [V]CST_ANOTDEFINED"
  Wrseq "      #--The insertion was not possible"
  Wrseq "      [L]WERR = fmet RESULT.ASETERROR('', 'Data Class SPRICESEARCH : Method call LOADDOCFROMRESULT result error for RESULT.C_PRICEINQ(JLV).ADDLINE:', [V]CST_AERROR)"
  Wrseq "      Return"
  Wrseq "    Endif"
  Wrseq "  Endif"
  #--
  Wrseq "    If dim(RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;").FRAREM)>0"
  Wrseq "      RESULT.C_PRICEINQ(JLV).C_FRAREM(";I;").FRAREM=[F:";ABR_XPL;"]DCGVAL(";I-1;")";
#           si colonne en montant et par unité
  If [F:PRS]VALTYP(I-1)=1 & [F:PRS]CLCRUL(I-1)=1
    Wrseq "/COEFPOURN*COEFUNITE"
  Else
    Wrseq ""
  Endif
  Wrseq "    Endif"
Next I

Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTYMIN = [F:";ABR_XPL;"]FOCQTYMIN"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTYBKT = [F:";ABR_XPL;"]FOCQTYBKT"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCUOM    = [F:";ABR_XPL;"]FOCUOM"
Wrseq "    RESULT.C_PRICEINQ(JLV).FOCQTY    = [F:";ABR_XPL;"]FOCQTY"
Wrseq "    If dim(RESULT.C_PRICEINQ(JLV).PLISEA)>0"
Wrseq "        RESULT.C_PRICEINQ(JLV).PLISEA = ";num$([F:PPC]PLISEA)
Wrseq "    Endif"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLI       = [F:";ABR_XPL;"]PLI"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLICRD    = [F:";ABR_XPL;"]PLICRD"
Wrseq "    RESULT.C_PRICEINQ(JLV).PLILIN    = [F:";ABR_XPL;"]PLILIN"
Wrseq "    RESULT.C_PRICEINQ(JLV).VPPLSPL   ='";ABR_XPL;"'"

Wrseq "    Gosub PE_SIMTARIF From TRTPRICE_SYRA"
Wrseq "    RESULT.NBPRICEINQ += 1"
Wrseq "  Endif"

Wrseq "Next"
Wrseq ""
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "Return"

Return

#------------------------------------------------------------------------
# Import de tarif: Raz des zones non accessibles lors du paramétrage mais
#                  qui ont pu être alimentées par le paramétrage du modèle
#                  d'import
#------------------------------------------------------------------------
$INI_IMPORT
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Traitment appelé par Gosub dans l'import de tarif"
Wrseq "# init. de la classe F des zones non saisissables pour ce tarif"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$INI_IMPORT"
Wrseq "Raz [F:";ABR_XPL;"]PLICRI1, [F:";ABR_XPL;"]PLICRI2, ",
Wrseq "[F:";ABR_XPL;"]PLICRI3, [F:";ABR_XPL;"]PLICRI4, [F:";ABR_XPL;"]PLICRI5"
Wrseq "Raz [F:";ABR_XPL;"]CPNITMREF"
For I=1 To 5
  If [F:PPC]FLD(I-1)=""
    Wrseq "Raz GIMP("+num$(I)+")          : # Critere "+num$(I)
  Endif
Next
If ZZ(7)=0  : Wrseq "Raz [F:";ABR_XPL;"]CUR       : # Devise"              : Endif
If ZZ(8)=0  : Wrseq "Raz [F:";ABR_XPL;"]UOM       : # Unite"               : Endif
If ZZ(9)=0  : Wrseq "Raz [F:";ABR_XPL;"]MINQTY    : # Qte mini"            : Endif
If ZZ(10)=0 : Wrseq "Raz [F:";ABR_XPL;"]MAXQTY    : # Qte maxi"            : Endif
If ZZ(11)=0 : Wrseq "Raz [F:";ABR_XPL;"]LTI       : # Delai"               : Endif
If ZZ(12)=0 : Wrseq "Raz [F:";ABR_XPL;"]PRIDIV    : # Diviseur prix"       : Endif
If ZZ(13)=0 : Wrseq "Raz [F:";ABR_XPL;"]PRI       : # Prix"                : Endif
If ZZ(14)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(0) : # Frais/remise 1"      : Endif
If ZZ(15)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(1) : # Frais/remise 2"      : Endif
If ZZ(16)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(2) : # Frais/remise 3"      : Endif
If ZZ(17)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(3) : # Frais/remise 4"      : Endif
If ZZ(18)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(4) : # Frais/remise 5"      : Endif
If ZZ(19)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(5) : # Frais/remise 6"      : Endif
If ZZ(20)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(6) : # Frais/remise 7"      : Endif
If ZZ(21)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(7) : # Frais/remise 8"      : Endif
If ZZ(22)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(8) : # Frais/remise 9"      : Endif
If ZZ(23)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTYMIN : # Qte mini gratuite"   : Endif
#If ZZ(24)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCBKT   : # Seuil gratuite"      : Endif
If ZZ(25)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCITMREF : # Article gratuit"     : Endif
If ZZ(27)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTY    : # Qte gratuite"        : Endif
If ZZ(28)=0 : Wrseq "Raz [F:";ABR_XPL;"]COMCOE    : # Coef. commission"    : Endif
If ZZ(29)=0 : Wrseq "Raz [F:";ABR_XPL;"]MINAMT    : # Montant mini"        : Endif
If ZZ(30)=0 : Wrseq "Raz [F:";ABR_XPL;"]MAXAMT    : # montant maxi"        : Endif
If ZZ(31)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCAMTMIN : # Prix mini gratuite"  : Endif
If ZZ(32)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTYBKT : # Qte seuil gratuite"  : Endif
If ZZ(33)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCAMTBKT : # Prix seuil gratuite" : Endif

Wrseq "Return"

Return
#------------------------------------------------------------------------
#------------------------------------------------------------------------
$READFIL

Case WPPCFIL

  When "ITMMASTER" :
                    Wrseq "Read [F:ITM]ITM0=PARAM.C_LINE(PLINEDOC).ITMREF"
                    Wrseq "If fstat : Raz [F:ITM] : Endif"
                    Wrseq ""
  When "BPCUSTOMER":
                    Wrseq "Read [F:BPC]BPC0=PARAM.BPSNUM"
                    Wrseq "If fstat : Raz [F:BPC] : Endif"
                    Wrseq ""
  When "BPSUPPLIER":
                    Wrseq "Read [F:BPS]BPS0=PARAM.BPSNUM"
                    Wrseq "If fstat : Raz [F:BPS] : Endif"
                    Wrseq ""
  When "ITMSALES"  :
                    Wrseq "Read [ITS]ITS0=PARAM.C_LINE(PLINEDOC).ITMREF"
                    Wrseq "If fstat : Raz [F:ITS] : Endif"
                    Wrseq ""
  When "ITMBPS"    :
                    Wrseq "Read [ITP]ITP0=PARAM.C_LINE(PLINEDOC).ITMREF;PARAM.BPSNUM"
                    Wrseq "If fstat : Raz [F:ITP] : Endif"
                    Wrseq ""
  When "ITMFACILIT"
                    Wrseq "Raz WPOHFCY"
                    #Wrseq "If dim(PARAM.C_LINE(PLINEDOC).POHFCY)>0   [L]WPOHFCY=PARAM.C_LINE(PLINEDOC).POHFCY"  98402.o
                    Wrseq "If dim(PARAM.C_LINE(PLINEDOC).POHFCY)>0  and PARAM.C_LINE(PLINEDOC).POHFCY<>''"      #98402.n
                    Wrseq "[L]WPOHFCY=PARAM.C_LINE(PLINEDOC).POHFCY"
                    Wrseq "Elsif dim(PARAM.FCY)>0                    [L]WPOHFCY=PARAM.FCY"
                    Wrseq "Endif"
                    Wrseq ""
                    Wrseq "Read [ITF]ITF0=PARAM.C_LINE(PLINEDOC).ITMREF;[L]WPOHFCY"
                    Wrseq "If fstat : Raz [F:ITF] : Endif"
                    Wrseq ""
  When "BPARTNER"
                    Wrseq "Read [F:BPR]BPR0=PARAM.BPSNUM"
                    Wrseq "If fstat : Raz [F:BPR] : Endif"
                    Wrseq ""
  When "BPCUSTMVT"

  When "BPDLVCUST"
                    Wrseq "Raz WBPAADD"
                    # Wrseq "If dim(PARAM.C_LINE(PLINEDOC).BPAADD)>0 98402.o
                    Wrseq "If dim(PARAM.C_LINE(PLINEDOC).BPAADD)>0 and PARAM.C_LINE(PLINEDOC).BPAADD<>''"  # 98402.n
                    Wrseq "[L]WBPAADD=PARAM.C_LINE(PLINEDOC).BPAADD"
                    Wrseq "Elsif dim(PARAM.BPAADD)>0                 [L]WBPAADD=PARAM.BPAADD"
                    Wrseq "Endif"
                    Wrseq ""
                    Wrseq "Read [BPD]BPD0=PARAM.BPCNUM;[L]WBPAADD"
                    Wrseq "If fstat : Raz [F:BPD] : Endif"
                    Wrseq ""
  When "SALESREP"
                    Wrseq "If PARAM.C_LINE(PLINEDOC).C_REP(1)<>null "
                    Wrseq "  Read [REP]REP0=PARAM.C_LINE(PLINEDOC).C_REP(1).REP"
                    Wrseq "  If fstat : Raz [F:REP] : Endif"
                    Wrseq "Endif"
  When "PPRICLINK" :#--Ne rien mettre ici car lecture systématique plus haut...
  When Default : GOK=0 :
Endcase

Return

