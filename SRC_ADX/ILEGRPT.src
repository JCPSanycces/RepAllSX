#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "CONT1"    : Gosub CONT1
  When "INIPAR"   : Gosub INIPAR
  When "FINAIMP1" : Gosub FINAIMP1
Endcase
Return

# To manage filter by legislation on selections
$CONT1
Local Integer I
Local Char    VALCPY(GLONCPY)

  Case toupper([M]PARCOD(nolign-1))
    When "CPY" :
      If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
      Call LECTURE("CPY",VALEUR,"") From CONTOBJ
      Gosub SAVE_GCURLEG From TOOLSHRLEG : GCURLEG=[F:CPY]LEG
      Gosub SAVE_GLEGFIL From TOOLSHRLEG : GLEGFIL=[F:CPY]LEG
  Endcase
Return

$INIPAR
Local Integer I
Local Char    VALCPY(GLONCPY)

  Case toupper([M]PARCOD(nolign-1))
    When "CPY" :
      If dim(SAVS_GCURLEG)>0 Then Gosub RESTAURE_GCURLEG From TOOLSHRLEG : Endif
      If dim(SAV_GLEGFIL)>0  Then Gosub RESTAURE_GLEGFIL From TOOLSHRLEG : Endif
    When "PRF" :
      For I=0 To dim([M]PARCOD)
        If toupper([M]PARCOD(I))="CPY" Then
          VALCPY=[M]VALEUR1(I)
          Break
        Endif
      Next
      If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
      Call LECTURE("CPY",VALCPY,"") From CONTOBJ
      Gosub SAVE_GCURLEG From TOOLSHRLEG : GCURLEG=[F:CPY]LEG
      Gosub SAVE_GLEGFIL From TOOLSHRLEG : GLEGFIL=[F:CPY]LEG
  Endcase
Return

$FINAIMP1
  Gosub RESTAURE_GCURLEG From TOOLSHRLEG
  Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

