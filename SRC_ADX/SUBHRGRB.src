$CREATION
$MODIF
#THRAM - 2017-05-25 - START

If GREP="D"
 ## In duplication mode we want to keep all translated texts
 #ADNGO - 2016-11-29 - X3PEOP-1240 - START
 #Call DUPTEXTRA("NATACTIV","DES",CLECUR1,"","NATACTIV","DES",[F:NAT]COD,GCURLEG)  From ATEXTRA
 #Call DUPTEXTRA("NATACTIV","SHO",CLECUR1,"","NATACTIV","SHO",[F:NAT]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRGRPRUB","DESAXX",CLECUR1,"","HRGRPRUB","DESAXX",GCURLEG,[F:HRGRB]COD)  From ATEXTRA
 Call DUPTEXTRA("HRGRPRUB","SHOAXX",CLECUR1,"","HRGRPRUB","SHOAXX",GCURLEG,[F:HRGRB]COD)  From ATEXTRA
Endif

#Call MAJTEXTRA([M]DESAXX,"HRGRPRUB","DESAXX",[M]COD,"") From ATEXTRA
#Call MAJTEXTRA([M]SHOAXX,"HRGRPRUB","SHOAXX",[M]COD,"") From ATEXTRA
