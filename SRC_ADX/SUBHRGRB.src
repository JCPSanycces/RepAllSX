Call MAJTEXTRA([M]SHOAXX,"HRGRPRUB","SHOAXX",GCURLEG,[M]COD) From ATEXTRA
#THRAM - 2017-05-25 - END
Return

$RAZDUP
  [M:HRGRB1]NBRUB=0
  Effzo [M:HRGRB1]CODRUB, ROWRUB, GRPRUB
  Actzo [M:HRGRB0]TYPGRP
#MIPEA - 2017-03-15- US X3-27509ST X3-29513- START
#THRAM - 2017-05-25 - START
#If func AFNC.ACTIV("KSA")>0
#PEVAN 2017-11-27 X3-59439 START
#If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#PEVAN 2017-11-27 X3-59439 END
#THRAM - 2017-05-25 - END
[M:HRGRB0]TYPGRP = 2
Affzo [M:HRGRB0]TYPGRP
Grizo [M:HRGRB0]TYPGRP
#PEVAN 2017-11-27 X3-59439 START
#Endif
#PEVAN 2017-11-27 X3-59439 END
