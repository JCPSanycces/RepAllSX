######################################################################################
$OUVRE
If clalev([F:HRGRB2])=0 : Local File HRGRPRUB [HRGRB2] : Endif
If clalev([F:RUB])=0    : Local File RUBRIQUE [RUB]    : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$FILGAUCHE
I = instr(1,FILRAP,"[F:HRGRB]ROW=")
If I
 FILRAP = left$(FILRAP,I+9)+">="+right$(FILRAP,I+11)
 J = instr(1,CRITERE,"[F:HRGRB]ROW=")
 If J
  CRITERE = left$(CRITERE,J+9)+">="+right$(CRITERE,J+11)
 Endif
Endif
If FILTRE<>""
 Call ADDCRIT(FILGAUSUP,IFILGAUSUP,"FILGAUSUP","("+FILTRE+")","&") From GOBJSUB
Endif
Return

$ANNULE
#Delete [AXX] Where CODFIC="HRGRPRUB" & IDENT1=[L]CODE
  Call SUPTEXTRA("HRGRPRUB","DESAXX",[L]CODE,SUPP) From ATEXTRA
  Call SUPTEXTRA("HRGRPRUB","SHOAXX",[L]CODE,SUPP) From ATEXTRA
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$AP_CHANGE
#THRAM - 2017-05-25 - START
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("HRGRPRUB","DESAXX",OCODE,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("HRGRPRUB","SHOAXX",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("HRGRPRUB","DESAXX",GCURLEG,OCODE,GCURLEG,NCODE) From ATEXTRA
Call CHGTEXTRA("HRGRPRUB","SHOAXX",GCURLEG,OCODE,GCURLEG,NCODE) From ATEXTRA

#Read [HRGRB]HRGRB0 = NCODE
Read [HRGRB]HRGRB0 = GCURLEG;NCODE
