Return

$LIENS

If dim([M:HRGRB0]LEG)>0 : GCURLEG=[M:HRGRB0]LEG : Endif

#PEVAN 2017-11-28 X3-66217 START
#Filter [F:RUB] Where [F:RUB]GRPRUB=[M:HRGRB0]COD | [F:RUB]DETGRPRUB=[M:HRGRB0]COD
Filter [F:RUB] Where [F:RUB]LEG=GCURLEG & ([F:RUB]GRPRUB=[M:HRGRB0]COD | [F:RUB]DETGRPRUB=[M:HRGRB0]COD)
#PEVAN 2017-11-28 X3-66217 END
If rowcount([F:RUB])>0 Then
  For [F:RUB]
    [M:HRGRB1]ROWRUB(nolign-1)=[F:RUB]ROW
    [M:HRGRB1]CODRUB(nolign-1)=[F:RUB]COD
    [M:HRGRB1]GRPRUB(nolign-1)=[F:RUB]GRPRUB
    nolign+=1
  Next
  [M:HRGRB1]NBRUB=nolign-1
Else
  [M:HRGRB1]NBRUB=0
Endif
Filter [F:RUB]

If [M:HRGRB1]NBRUB>0
 Grizo [M:HRGRB0]TYPGRP
Else
 Actzo [M:HRGRB0]TYPGRP
Endif
Affzo [M:HRGRB0]TYPGRP
Call AFF_TYPGRP([M:HRGRB0]TYPGRP)


Call LECTEXTRA([M]DESAXX,"HRGRPRUB","DESAXX",GCURLEG,[M]COD) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRGRPRUB","SHOAXX",GCURLEG,[M]COD) From ATEXTRA
#PEVAN 2017-11-28 X3-65698 START
Gosub TOGGLE_MAIN_FIELDS
#PEVAN 2017-11-28 X3-65698 END


Return

#THRAM - X3PEOP-21996 - 26-05-2017 - START
$FERME
  If dim(SAV_GCURLEG) > 0 : GCURLEG = SAV_GCURLEG : Endif

  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONGRB) : Endif
  #ADNGO - X3PEOP-1240 - 09-02-2017 - START
  VCOD = CLE1
Return
#THRAM - X3PEOP-21996 - 26-05-2017 - END
#---------------------------------------------
# TRTCOP : Bouton copie vers un autre dossier
#---------------------------------------------
$TRTCOP
Local File =[M]DOSORG+".HRGRPRUB" [GRB1]
Local File =[M]DOSDES+".HRGRPRUB" [GRB2]
Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Local File =[M]DOSDES+".ATEXTRA"  [AXX2]

Local Char    CRIGRB(250),CRIAXL(250),CRIAXS(250)
Local Integer COPIECOMPLETE
[L]CRIGRB = "COD=TABLE"
[L]CRIAXL = "CODFIC='HRGRPRUB' & ZONE='DESAXX' & LANGUE='"+GLANGUE+"' & IDENT1=TABLE"
[L]CRIAXS = "CODFIC='HRGRPRUB' & ZONE='SHOAXX' & LANGUE='"+GLANGUE+"' & IDENT1=TABLE"

Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GRB1], [GRB2]
Return

########################################
$TR_COP
GOK = 1
Trbegin [GRB2],[AXX2]
Delete [GRB2] Where evalue(CRIGRB)
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRGRPRUB" : Gosub ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("GRB2","") From GLOCK : Gosub AB_TR_COP
Endif
For [GRB1] Where evalue(CRIGRB)
 [F:GRB2] = [F:GRB1]
 If dim([F:GRB2]UPDUSR)>0 : [F:GRB2]UPDUSR = GUSER : Endif
 If dim([F:GRB2]UPDDAT)>0 : [F:GRB2]UPDDAT = date$ : Endif
 If dim([F:GRB2]UPDTIM)>0 : [F:GRB2]UPDTIM = time : Endif
 Write [GRB2]
 If fstat
  GOK = 0 : Call FSTA("GRB2") From GLOCK : Break
 Endif
Next
If GOK Then
  For [AXX1] Where evalue(CRIAXL)
   [F:AXX2] = [F:AXX1]
   If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = GUSER : Endif
   If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = date$ : Endif
   If dim([F:AXX2]UPDTIM)>0 : [F:AXX2]UPDTIM = time : Endif
   Write [AXX2]
   If fstat
    GOK = 0 : Call FSTA("AXX2") From GLOCK : Break
   Endif
  Next
Endif
If GOK Then
  For [AXX1] Where evalue(CRIAXS)
   [F:AXX2] = [F:AXX1]
   If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = GUSER : Endif
   If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = date$ : Endif
   If dim([F:AXX2]UPDTIM)>0 : [F:AXX2]UPDTIM = time : Endif
   Write [AXX2]
   If fstat
    GOK = 0 : Call FSTA("AXX2") From GLOCK : Break
   Endif
  Next
Endif

If     GOK<0 : Gosub ROLL_TR_COP
Elsif !GOK   : Gosub AB_TR_COP
Endif
Commit
Return

########################################
$AB_TR_COP
Rollback
Return

########################################
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Gosub TR_COP : Endif
Return

######################################################################################
Subprog C_ROW(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
  Read [HRGRB2]HRGRB1 = VALEUR
  If !fstat & [F:HRGRB2]COD<>[M]COD
   GMESSAGE = mess(9,10702,1)-":"-[F:HRGRB2]COD : # Rang déjà existant
   mkstat = 2 : End
  Endif
Endif
End
######################################################################################
Subprog AM_TYPGRP(VALEUR)
Variable Integer VALEUR

  If [M]NBRUB>0
     GMESSAGE=mess(247,10703,1)  :# Ce regroupement est utilisé dans une rubrique
     mkstat=2
     End
  Endif

  If VALEUR=2
    # Test if Grouping is already used as a Grouping Parent in a Grouping
    If clalev([F:HRGRB2])=0 : Local File HRGRPRUB [HRGRB2] : Endif
    Filter [F:HRGRB2] Where CODGRP=[M]COD
    If rowcount([F:HRGRB2])
     GMESSAGE=mess(248,10703,1)  :# Ce regroupement est utilisé dans un lien de regroupement
     mkstat=2
     Filter [F:HRGRB2]
     End
    Endif
    Filter [F:HRGRB2]
  Endif

  Call AFF_TYPGRP(VALEUR)
End

Subprog AFF_TYPGRP(VALEUR)
Variable Integer VALEUR
  Case VALEUR
    When 1 : Actzo [M:HRGRB0]TYPTIT
             Effzo [M:HRGRB0]CODGRP : Grizo [M:HRGRB0]CODGRP

    When 2 : Effzo [M:HRGRB0]TYPTIT : Grizo [M:HRGRB0]TYPTIT
             Actzo [M:HRGRB0]CODGRP
  Endcase
  Affzo [M:HRGRB0]TYPTIT, CODGRP
End

######################################################################################
Subprog AM_CODGRP(VALEUR)
Variable Char    VALEUR()
  If VALEUR=[M:HRGRB0]COD Then
    GMESSAGE=mess(245,10703,1) : # Le code regroupement doit être différent du code de la fiche
    mkstat=2
    End
  Endif

  If VALEUR<>"" Then
    If clalev([F:HRGRB2])=0 : Local File HRGRPRUB [HRGRB2] : Endif
    #THRAM - 2017-05-25 - START
    #Read [F:HRGRB2]HRGRB0=VALEUR
    Read [F:HRGRB2]HRGRB0=GCURLEG;VALEUR
    #THRAM - 2017-05-25 - END
    If fstat Then
      GMESSAGE=mess(1,10702,1)  :#"Valeur incorrecte"
      mkstat=2
      End
    Elsif [F:HRGRB2]TYPGRP<>1
      GMESSAGE=mess(1,10702,1)  :#"Valeur incorrecte"
      mkstat=2
      End
    Endif
  #THRAM - 2017-05-25 - START
  #Elsif func AFNC.ACTIV("KFR") Then
  Elsif func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #THRAM - 2017-05-25 - END
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
    mkstat=2
    End
  Endif

  #THRAM - 2017-05-25 - START
  #If func AFNC.ACTIV("KFR") & VALEUR<>"" & VALEUR<>[M:HRGRB0]CODGRP Then
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) & VALEUR<>"" & VALEUR<>[M:HRGRB0]CODGRP Then
  #THRAM - 2017-05-25 - END
   For I=0 To [M:HRGRB1]NBRUB-1
     If [M:HRGRB1]GRPRUB(I)<>"" & [M:HRGRB1]GRPRUB(I)<>VALEUR
       Call MESSAGE(mess(249,10703,1)) From GESECRAN
       # Attention vous devez également modifier le paramétrage des rubriques
       Break
     Endif
   Next
  Endif
End

$SEL_TABLE

  Case TABLE
    When "SELHRGRB"  : Gosub SELHRGRB
  Endcase
Return



Return

$SELHRGRB
Local Char  COD(20)
Local Char  TYPCOD(1),CODGRP(20),CRITSEL(250)

  If clalev([F:HRGRB])=0 : Local File HRGRPRUB [HRGRB] : Endif
  If clalev([F:AXC])=0   : Local File ATEXTRA  [AXC]   : Endif

  TYPCOD=PARAM(1)
  CODGRP=PARAM(2)
  CRITSEL=PARAM(3)

  COL(1) = "[F:HRGRB]COD"
  COL(2) = "[F:AXC]TEXTE"
  COL(3) = "[F:HRGRB]ROW"
  COL(4) = "[F:HRGRB]LEG"

  TIT(1) = mess(37,100,1)   : # Code
  TIT(2) = mess(82,123,1)   : # Intitulé
  TIT(3) = mess(2,16,1)     : # Rang
  TIT(4) = mess(218,107,1)
  TIT(0) = mess(1,10764,1)    : # Regroupement

  NBCOL = 4
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRGRB]COD>="'+VALEUR+'"',"&") From GOBJSUB
  If TYPCOD>"0" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRGRB]TYPGRP='+num$(TYPCOD),"&") From GOBJSUB
  Endif
  If CODGRP<>"" & func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRGRB]CODGRP="'+CODGRP+'"',"&") From GOBJSUB
  Endif

  #THRAM - 2017-05-25 - START
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRGRB]LEG="'+GCURLEG+'")',"&") From GOBJSUB
  #THRAM - 2017-05-25 - END

  #THRAM - 2017-05-25 - START
  #Link [F:HRGRB] With [F:AXC]AXX0="HRGRPRUB";"DESAXX";GLANGUE;[F:HRGRB]COD;"" As [HRGRB_]
  Link [F:HRGRB] With [F:AXC]AXX0="HRGRPRUB";"DESAXX";GLANGUE;[F:HRGRB]LEG;[F:HRGRB]COD As [HRGRB_]
  #THRAM - 2017-05-25 - END
  Default File [F:HRGRB_]

  [L]START="[F:HRGRB]COD"
  [L]ORDRE="[F:HRGRB]COD" : # For haven't [F:AXC]TEXTE in key because field null is possible
Return

$FIN_TABLE
Default File [F:HRGRB]
Return

