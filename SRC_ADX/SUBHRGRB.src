######################################################################################
## Section automatically added (screen HRGRB0) 05/25/2017 10:24:30 (ADNGO)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End


######################################################################################


##################################################
Subprog CONTHRGRB(COD)
Variable Char    COD()

  If GFONCTION = "GESHRGRB" | COD="" : End : Endif

  If clalev([F:HRGRB])=0 : Local File HRGRPRUB [HRGRB] : Endif

  If COD <> ""
    Filter [F:HRGRB] Where COD=[L]COD
    Read [F:HRGRB] First
    Filter [F:HRGRB]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Read [F:HRGRB]HRGRB0 = GCURLEG;[L]COD
        If fstat
          Filter [F:HRGRB] Where COD=[L]COD & LEG=GCURLEG
          Read [F:HRGRB] First
          Filter [F:HRGRB]
          If [F:HRGRB]LEG<>""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRGRB]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:HRGRB]


End


##################################################
Subprog TUNHRGRB(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONNAT)
   TOKILL = 1
  Endif

  If clalev([F:HRGRB])=0 : Local File HRGRPRUB [HRGRB] : Endif

  VCOD = COD
  If VCOD="" & GLECOBJ=2

  #If no code is specified, it's better to select one of the curent legislation
    Filter [HRGRB] Where LEG=GCURLEG
    Read [F:HRGRB] First
    Filter [HRGRB]
    If !fstat : VCOD=[F:HRGRB]COD : Endif
  Else
    Read [HRGRB]HRGRB0 = GCURLEG;VCOD
  Endif

  Raz GLEGFIL
  Call OBJET("HRGRB",VCOD,GCURLEG) From GOBJET
  COD = VCOD

  If TOKILL : Kill VCOD : Endif


End

#PEVAN 2017-11-28 X3-65698 START
$TOGGLE_MAIN_FIELDS
  If [M:HRGRB0]TYPGRP=1
    Grizo [M:HRGRB0]COD, LEG, ROW
  Else
    Actzo [M:HRGRB0]COD, LEG, ROW
  Endif
  Affzo [M:HRGRB0]COD, LEG, ROW
Return
#PEVAN 2017-11-28 X3-65698 END

