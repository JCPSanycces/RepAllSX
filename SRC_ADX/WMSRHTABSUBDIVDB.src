$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 31745: RES='Subdivisions géographiques'
   When 263: RES='Pays'
   When 31744: RES='Subdivision'
   When 5296: RES='Code'
  Endcase
 When "ENG":
  Case _ID
   When 31745: RES='Geographic subdivisions'
   When 263: RES='Country'
   When 31744: RES='Subdivision'
   When 5296: RES='Code'
  Endcase
