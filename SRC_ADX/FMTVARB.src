#<AdxTL>@(#)9.0.0.0 $Revision$
End

$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "CHX_TABLE"   : Gosub CHX_TABLE
 When "TRT_DIV"     : Gosub TRT_DIV
 When "AFMTB1"      : Gosub AFMTB1
Endcase
Return

$SEL_TABLE
Case [F:ATY]CODTYP
   When "MWS" : OPTIONS+="|"
   When "CDA" : Gosub RAZPAR : Gosub SELCDA From SELCDA
   When "JOU" : Gosub RAZPAR : Gosub SELJOU From SELJOU
   When "GTE" : Gosub RAZPAR : Gosub SELGTE From SELGTE
   When "TAM" : Gosub RAZPAR : Gosub SELTAM From SELTAM
   When "TPY" : Gosub RAZPAR : Gosub SELTPY From SELTPY
   When "SAT" : # FGR 17/04/2012 : X3SUIVI79830 (début)
                 Gosub RAZPAR
                 PARAM(1) = ""
                 PARAM(2) = "2"
                 Raz CRITERE
                 Gosub SEL_SAT From TRTDIV
                 # FGR 17/04/2012 : X3SUIVI79830 (fin)
    When "TSD" : Gosub RAZPAR : Gosub SELTSD From SUBTSD:#--CPO 71937
    When "TRE" : Gosub RAZPAR : Gosub SELTRE From SUBTRE:#--CPO 71937
    When "VAT" : Gosub RAZPAR : Gosub SELTVT From SUBTVT:#--CPO 71937
    When "TVI" : Gosub RAZPAR : Gosub SELTVI From SUBTVI:#--JDE 71937
    When "TSV" : Gosub RAZPAR : Gosub SELTSV From SUBTSV:#--JDE 71937
    When "TPT"  : Gosub RAZPAR : Gosub SELTPT From SUBTPT:#--JDE 71937
    When "TDA" : Gosub RAZPAR : Gosub SELTDA From SUBTDA:#--CPO 71937 TABDEPAGIO
    When "TSO" : Gosub RAZPAR : Gosub SELTSOLEG2 From SUBTSO  :# FGR 13/11/2012 : X3SUIVI71937
    When "TPV"  : Gosub RAZPAR : Gosub SELTPVLEG From SUBTPV  :# FGR 11/12/2012 : X3SUIVI71937
    When "TEC"  : Gosub RAZPAR : Gosub SELTECLEG From SUBTEC  :# FGR 14/01/2013 : X3SUIVI71937
    When "TSC"  : Gosub RAZPAR : Gosub SELTSCLEG From SUBTSC  :# FGR 17/01/2013 : X3SUIVI71937
    When "TSQ"  : Gosub RAZPAR : Gosub SELTSQ From SUBTSQ      # FGR 19/02/2015 : X3SUIVI104383
    When "TSO"  : Gosub RAZPAR : Gosub SELTSOLEG2 From SUBTSO  # FGR 20/02/2015 : X3SUIVI104383
    When "TVB"  : Gosub RAZPAR : Gosub SELTVB From SUBTVB      # Issue X3-60846 - 2017-11-07 by CPO : TVB datatype selection returns LEG value instead of VACBPR value
Endcase
Return

$RAZPAR
# FGR 17/04/2012 : X3SUIVI79830
If dim(PARAM)>0 : Raz PARAM : Endif
Return

$FIN_TABLE
If dim([M:RPT]RPTCOD)>0
 If [F:ATY]CODTYP="GAC" : Gosub INIPAR From CPTRPT : Endif
Endif
Return

$CHX_TABLE
Case [F:ATY]CODTYP
 When "SAC" : CRITCAR="1=1"
Endcase
Return

$TRT_DIV
If dim(VCOD)>0
 VALEUR = VCOD
 Kill VCOD
Endif
Return

$AFMTB1
Case [L]TYP
 When "CDA" : Gosub PARLEG : Call TUNCDA(VALEUR,"") From SUBCDA : OK=0
 When "JOU" : Gosub PARLEG : Call TUNJOU(VALEUR,"") From SUBJOU : OK=0
 When "GTE" : Gosub PARLEG : Call TUNGTE(VALEUR,"") From SUBGTE : OK=0
 When "TAM" : Gosub PARLEG : Call TUNTAM(VALEUR,"") From SUBTAM : OK=0
 When "TPY" : Gosub PARLEG : Call TUNTPY(VALEUR,"") From SUBTPY : OK=0
 When "TSD" : Gosub PARLEG : Call TUNTSD(VALEUR,"") From SUBTSD: OK=0 :#--CPO 71937
 When "TRE" : Gosub PARLEG : Call TUNTRE(VALEUR,"") From SUBTRE: OK=0 :#--CPO 71937
 When "VAT" : Gosub PARLEG : Call TUNTVT(VALEUR,"") From SUBTVT: OK=0 :#--CPO 71937
 When "TVI" : Gosub PARLEG : Call TUNTVI(VALEUR,"") From SUBTVI: OK=0 :#--JDE 71937
 When "TDA" : Gosub PARLEG : Call TUNTDA(VALEUR,"") From SUBTDA: OK=0 :#--CPO 71937 TABDEPAGIO
 When "TSO" : Gosub PARLEG : Call TUNTSO(VALEUR,"") From SUBTSO: OK=0 :# FGR 11/12/2012 : X3SUIVI71937
 When "TPV" : Gosub PARLEG : Call TUNTPV(VALEUR,"") From SUBTPV: OK=0 :# FGR 11/12/2012 : X3SUIVI71937
 When "TEC" : Gosub PARLEG : Call TUNTEC(VALEUR,"") From SUBTEC: OK=0 :# FGR 14/01/2013 : X3SUIVI71937
 When "TSC" : Gosub PARLEG : Call TUNTSC(VALEUR,"") From SUBTSC: OK=0 :# FGR 14/01/2013 : X3SUIVI71937
 When "TVB" : Gosub PARLEG : Call TUNTVB(VALEUR,"") From SUBTVB: OK=0 :# Issue X3-60846 - 2017-11-07 by CPO : TVB datatype selection returns LEG value instead of VACBPR value
Endcase
Return

$PARLEG
If dim([M:RPT]RPTCOD)>0
 I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If I
  If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
  Call LEC_CPY([M:RPT]VALINT1(I-1)) From CPTLEC
  If !fstat : GCURLEG = [F:CPY]LEG : Endif
 Endif
Endif
Return

