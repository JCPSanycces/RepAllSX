#** #############################################################################################################
#*
#*Procedure:   GET_CPYDATA
#*
#* Purpose:    Loads some fields from company/company group configuration.
#*
#*
#* Parameters:
#*
#* @param PCPY           Value Char       Company
#* @param PGRP           Value Char       Company group
#* @param PCRN           Value Char       Tax ID
#* @param RLEG           Variable Char    Returns the legislation
#* @param RCRN           Variable Char    Returns the tax identifier
#*
#*! #############################################################################################################

Subprog GET_CPYDATA( PCPY, PGRP, PCRN, RLEG, RCRN )
Value Char PCPY
Value Char PGRP
Value Char PCRN
Variable Char RLEG()
Variable Char RCRN()

    Local Char CPY(GLONCPY) # Holds the company/company group

    # If there is no company and no company group given do nothing.
    If PCPY = "" & PGRP = "" Then
        End
    Endif

    # If a company is provided in PCPY CPY is set to the given company.
    If PCPY <> "" Then
        CPY = PCPY
    # Else if a company group is provided in PGRP CPY is set to the given company groupy.
    Elsif  PGRP <> ""
        CPY = PGRP
    Endif

    # Look up in the company table for the company's legislation and tax identifier.
    RCRN = ""
    Read [F:CPY]CPY0 = CPY
    If !fstat
        RLEG = [F:CPY]LEG
        If PCRN <> ""
            For I = 0 To dim([CPY]GERTAXIDT) - 1
                If PCRN = [CPY]GERTAXIDT(I)
                    RCRN = PCRN
                    Break
                Endif
            Next
        Else
            For I = 0 To dim([CPY]GERTAXIDT) - 1
                If [CPY]GERDEFVAL(I) - 1
                    RCRN = [CPY]GERTAXIDT(I)
                    Break
                Endif
            Next
        Endif
    Endif
End



# ###############################################################################################################
# ##########
# ########## Screen/Window handling
# ##########
# ##########
# ##########
# ###############################################################################################################

#################################################################################################################
#
#    Event: Validate the company group entry.
#    Does:  Consistency checks for the company group (see code comments).
#
#################################################################################################################

Subprog C_GRP(VALEUR)
Variable Char VALEUR()
    Local Char CRN(20), LEG(10)
    Local Char CUR(GLONCUR) : CUR = ""
    Local Integer COUNTER : COUNTER = 0

    If VALEUR <> ""
        # Check consistency of parameter DCLVATDAT and currency between the company group and
        # its member companies.
        Local Integer IS_DOCDATE : IS_DOCDATE = func CNSRSGSTDLIB.IS_DCLVATDAT_OF_CPY_DOCDATE( VALEUR )

        # Check parameter consistency for group members.
        For [F:AGC] Where GRP = VALEUR
            # Check parameter consistency for group members.
            If IS_DOCDATE <> func CNSRSGSTDLIB.IS_DCLVATDAT_OF_CPY_DOCDATE( [F:AGC]CPY )
                GMESSAGE = mess(284,107,1) - [F:AGC]CPY + "." # "Inconsistent parameter DCLVATDAT for company"
                mkstat = 2
                End
            Endif

            # Check currency consistency for group members.
            Read [F:CPY]CPY0 = [F:AGC]CPY
            If !fstat
                If COUNTER = 0
                    CUR = [F:CPY]ACCCUR
                Elsif CUR <> [F:CPY]ACCCUR
                    GMESSAGE = mess(319,107,1) # "Inconsistent currencies upon group."
                    mkstat = 2
                    End
                Endif
            Endif

            COUNTER += 1
        Next

        # Check if the given value is a group of companies.
        If COUNTER < 1
            GMESSAGE = mess(283,107,1) # "This is not a group of companies."
            mkstat = 2
            End
        Endif

        # Check if the company group has a tax identifier.
        Call GET_CPYDATA( [M:RSG0]CPY, VALEUR, "", LEG, CRN )
        If CRN = ""
            GMESSAGE = mess(299,107,1) + "\" + mess(300,107,1) # "Tax identifier missing. Please check the company's legal data settings."
            mkstat = 2
            End
        Endif
    Endif
End



#################################################################################################################
#
#    Event: After company group field has changed.
#    Does:  Greys out company and site fields and loads some data from the company group's legal data
#           parameterization.
#
#################################################################################################################

Subprog AM_GRP(VALEUR)
Variable Char VALEUR()

    # If company group is given gray out company and side.
    If VALEUR <> "" Then
        [M:RSG0]CPY = ""
        [M:RSG0]FCYLIN = ""
        Affzo [M:RSG0]
        Grizo [M:RSG0]CPY
        Grizo [M:RSG0]FCYLIN
    Else
        Actzo [M:RSG0]
    Endif

    # Set EU VAT ID,  participant code and tax identifier
    Call GET_CPYDATA( [M:RSG0]CPY, VALEUR, "", [M:RSG0]LEG, [M:RSG0]CRN )

    # Set currency.
    Read [F:AGC]AGC0(1) = VALEUR
    If !fstat
        Read [F:CPY]CPY0 = [F:AGC]CPY
        If !fstat
            [M:RSG0]CUR = [F:CPY]ACCCUR
        Endif
    Endif

    # SAM #95245 (DNE)
    # Enable or disable FLGVALIDONLY according to setting of paramter XEGERRSEXT.
    Call SET_FLGVALIDONLY( VALEUR ) From CNSRSGSTD

    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: Validate the company entry.
#    Does:  Consistency checks for the company (see code comments).
#
#################################################################################################################

Subprog C_CPY(VALEUR)
Variable Char VALEUR()

    Local Char CRN(20), LEG(10)

    If VALEUR = ""
        If [M:RSG0]GRP = ""
            GMESSAGE = mess(256,107,1) # "Please enter company or company group."
            mkstat = 2
        Endif
    Else
        Call GET_CPYDATA( VALEUR, [M:RSG0]GRP, "", LEG, CRN )
        If CRN = ""
            GMESSAGE = mess(299,107,1) + "\" + mess(300,107,1) # "Tax identifier missing. Please check the company's legal data settings."
            mkstat = 2
        Endif
    Endif
End



#################################################################################################################
#
#    Event: After company field has changed.
#    Does:  Greys out company group field and loads some data from the company's legal data parameterization.
#
#################################################################################################################

Subprog AM_CPY(VALEUR)
Variable Char VALEUR()

    # Set legislation, EU VAT ID,  participant code and tax identifier.
    Call GET_CPYDATA( VALEUR, [M:RSG0]GRP, "", [M:RSG0]LEG, [M:RSG0]CRN )

    # Set currency.
    Read [F:CPY]CPY0 = VALEUR
    If !fstat
        [M:RSG0]CUR = [F:CPY]ACCCUR
    Endif

    # SAM #95245 (DNE)
    # Enable or disable FLGVALIDONLY according to setting of paramter XEGERRSEXT.
    Call SET_FLGVALIDONLY( VALEUR ) From CNSRSGSTD

    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: While changing the legislation.
#    Does:  Checks if the given legislation is part of the RS parameterization in table VDGERRSP.
#
#################################################################################################################

Subprog C_LEG(VALEUR)
Variable Char VALEUR()

    Call C_LEG(VALEUR) From CNSRSGSTD
End



#################################################################################################################
#
#    Event: While entering/changing the site field
#    Does:  Checks if the given site corresponds to the company/company group field.
#
#################################################################################################################

Subprog C_FCYLIN(VALEUR)
Variable Char VALEUR()

    Call C_FCYLIN(VALEUR) From CNSRSGSTD
End



#################################################################################################################
#
#    Event: While changing the tax identifier (to another tax identifier of the company).
#    Does:  Checks that the tax identifier corresponds to the company/company group parameterization
#           and that an RS particpant number exists ind the company legal data settings.
#
#################################################################################################################

Subprog C_CRN(VALEUR)
Variable Char VALEUR()

    # If company and group are empty we cannot do anything. So we just leave.
    If [M:RSG0]CPY = "" & [M:RSG0]GRP = "" Then
        End
    Endif

    Local Char CRN(20), LEG(10)

    If VALEUR <> ""
        Call GET_CPYDATA( [M:RSG0]CPY, [M:RSG0]GRP, VALEUR, LEG, CRN )
        If VALEUR <> CRN
            GMESSAGE = mess(285,107,1) # "Incorrect tax identifier."
            mkstat = 2
            End
        Endif
    Endif
End



#################################################################################################################
#
#    Event: After tax identifier field has changed.
#    Does:  Fill the member number field.
#
#################################################################################################################

Subprog AM_CRN(VALEUR)
Variable Char VALEUR()

    # Set legislation and tax identifier.
    Call GET_CPYDATA( [M:RSG0]CPY, [M:RSG0]GRP, VALEUR, [M:RSG0]LEG, VALEUR )
    Affzo [M:RSG0]1-99
End



#################################################################################################################
#
#    Event: While changing the end date.
#    Does:  Checks it we use a correct date range (monthly, quarterly etc.)
#
#################################################################################################################

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR

   Call C_DATFIN(VALEUR) From CNSRSGSTD
End
