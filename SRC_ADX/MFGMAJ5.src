#<AdxTL>@(#)9.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
##################################################################################
# MFGMAJ5 : Mises à jour à effectuer lors du passage à la version 130 (Release 5) 
##################################################################################
#   GPAO  :                                                      
#   Dans Liens de nomenclature   (BOMD)                                              
#       - Sous-produits, nouvelles zones              (CPNTYP, CSTFLG)
#   Dans articles lancés         (MFGITM)
#       - Sous-produits, date de cloture, nouvelles zones (ITMTYP,CLODAT)
#   Dans opérations OF           (MFGOPE + OPERATIONS)
#       - nombre de postes MO    (STDLABNBR, EXTLABNBR, CPLLABNBR)
#       - passage en temps prévu total si multi-exemplaire
#   Dans transactions plans      (BENCHTRS)
#       - Nouveau mode de paramétrage                 (NBRLIG, NBRCOL, FLD, NBRFLD, DAC)
#   Dans postes de charge        (WORKSTATIO)
#       - révision calendriers + multi-exmplaire      (WSTNBR, TWD)
#   Dans encours article         (ORDERS)
#       - Nouveau flag optimisation                   (OPTFLG)
#   Dans paramètres PDP/CBN      (PARMRP)
#       - remplacement calendrier par schéma          (MPSTWD, MRPTWD)
#   Dans article/site            (ITMFACILIT)
#       - récupération acheteur de la fiche article   (BUY)
#   Dans opération standard      (ROUOPESTD)
#       - Initialisation du site par récupération du site du poste (FCY)
#       - Initialisation nombre de poste MO           (LABNBR)
#   Dans opération               (ROUOPE)
#       - Initialisation du site par récupération du site du poste (FCY)
#       - Initialisation nombre de poste MO           (LABNBR)
#   Dans gamme                   (ROUTING)
#       - Initialisation du site par récupération du site de la première opération (FCY)
#   Dans suivi des opérations    (MFGOPETRK)
#       - Initialisation du coefficient de conversion UN-UO à 1 (OPEWORCOE)
#       - Initialisation du type de suivi             (TIMTYP)
#         et de la première occurence du tableau des quantités rejetées(TABREJQTY)
#   Dans déclaration de prod.    (MFGITMTRK)
#       - Initialisation du type de suivi             (PRODTYP) 
#   Dans suivi des matières      (MFGMATTRK)
#       - Initialisation du type de suivi             (MATTYP) 
#   Dans section de valorisation (WORKCOST)
#       - Initialisation du mode de saisie sections   (CCECOD) 
#   Dans ordres de fabrication   (MFGHEAD )
#       - Initialisation status allocation         
#       - Vérification date de cloture                (CLODAT)   
#   Dans centres de charge       (TABWRKCTR)
#       - Initialisation niveau affichage             (DSPLEV) 
#   Dans allocations et matières (STOALL et MFGMAT)
#       - Suppression des allocations erronées       
##################################################################################
#---------------------------------------------------------------------------------#
#    Moulinette Après mise à jour concernant le module GPAO                       #
#---------------------------------------------------------------------------------#

Local Shortint COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(250)
Local Integer  CLE2, CLE4, CLE5

Local File ADOSSIER [ADS]

If filinfo(filpath("FIL","BOMD","fde",[F:ADS]DOSSIER),0)       < 0    : End : Endif
If filinfo(filpath("FIL","TABBOMALT","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","TABWRKCTR","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","TABROUALT","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","MFGITM","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif
If filinfo(filpath("FIL","MFGOPE","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif
If filinfo(filpath("FIL","OPERATIONS","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif
If filinfo(filpath("FIL","BENCHTRS","fde",[F:ADS]DOSSIER),0)   < 0    : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif
If filinfo(filpath("FIL","ROUOPESTD","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","WORKSTATIO","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif
If filinfo(filpath("FIL","CALENDAR","fde",[F:ADS]DOSSIER),0)   < 0    : End : Endif
If filinfo(filpath("FIL","ROUOPE","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif
If filinfo(filpath("FIL","ROUTING","fde",[F:ADS]DOSSIER),0)    < 0    : End : Endif
If filinfo(filpath("FIL","MFGOPETRK","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","MFGITMTRK","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","MFGMATTRK","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","ITMMASTER","fde",[F:ADS]DOSSIER),0)  < 0    : End : Endif
If filinfo(filpath("FIL","ITMFACILIT","fde",[F:ADS]DOSSIER),0) < 0    : End : Endif
If filinfo(filpath("FIL","MFGHEAD","fde",[F:ADS]DOSSIER),0)    < 0    : End : Endif
If filinfo(filpath("FIL","MFGMAT","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif
If filinfo(filpath("FIL","WORKCOST","fde",[F:ADS]DOSSIER),0)   < 0    : End : Endif
If filinfo(filpath("FIL","STOALL","fde",[F:ADS]DOSSIER),0)     < 0    : End : Endif

#-------------------------------------------------#
# Initialisation liens de nomenclature BOMD       #
#-------------------------------------------------#
Local File BOMD        [BOD]
Local File TABBOMALT   [TBO]

Call TEMPON("Manufacturing Bills of material Process") From GESECRAN

Link [BOD] With [TBO]TBO0=2;[F:BOD]BOMALT As [NOM] 
&            Order By Key BOD0  

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_BOD
If STOP=1
  STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+' & CPNITMREF>"'+CLE3+'"'
Elsif STOP=2
  STOP=3 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT='+num$(CLE2)+' & BOMSEQ>'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT>'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [BOD]
  For [NOM] Where evalue(CRITERE)
    Readlock [BOD] Curr    
    If fstat
        Call ECR_TRACE("File BOMD, Error ="-num$(fstat),1) From GESECRAN
    Else
        If !find([F:BOD]CPNTYP,1,4)
            [F:BOD]CPNTYP = 1
        Endif
        If [F:BOD]CPNTYP = 1 & [F:BOD]CSTFLG <> 2
            [F:BOD]CSTFLG = 2
        Endif
        Rewrite [F:BOD]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:BOD]ITMREF 
        CLE2 = [F:BOD]BOMALT
        CLE3 = [F:BOD]CPNITMREF
        CLE4 = [F:BOD]BOMSEQ
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_BOD : Endif
Close Local File [BOD]
Close Local File [TBO]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation articles lancés  MFGITM          #
#-------------------------------------------------#
Local File MFGITM   [MFI]
Local File MFGHEAD  [MFG]

Call TEMPON("Manufacturing Released Products Process") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFI
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MFI]
For [MFI]MFI0 Where evalue(CRITERE)
    Readlock [MFI] Curr    
    If fstat
        Call ECR_TRACE("File MFGITM, Error ="-num$(fstat),1) From GESECRAN
    Else
        If !find([F:MFI]ITMTYP,1,2)
            [F:MFI]ITMTYP = 1
        Endif
        If !find([F:MFI]CSTFLG,1,2)
            [F:MFI]CSTFLG = 1
        Endif
        If [F:MFI]MFGSTA = 4 
            Read [F:MFG]MFG0 = [F:MFI]MFGNUM
            If !fstat & [F:MFG]CLODAT <> [0/0/0] 
                   [F:MFI]CLODAT = [F:MFG]CLODAT
            Else 
                   [F:MFI]CLODAT = [F:MFI]TRKLAST 
            Endif 
        Endif    
        Rewrite [F:MFI]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MFI]MFGNUM 
        CLE2 = [F:MFI]MFGLIN
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MFI : Endif
Close Local File [MFI]
Close Local File [MFG]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation opération   MFGOPE               #
#-------------------------------------------------#
Local File MFGOPE  [MFO]

Call TEMPON("Manufacturing Operations Process") From GESECRAN

Raz CLE1,CLE2, STOP
$BOUCLE_MFO
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM='+num$(CLE2)+' & OPESPLNUM>'+num$(CLE4)
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MFO]

For [MFO]MFO0 Where evalue(CRITERE)
    Readlock [MFO] Curr    
    If fstat
        Call ECR_TRACE("File MFGOPE, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:MFO]EXTLAB <> ""
            If [F:MFO]STDLABNBR = 0 : [F:MFO]STDLABNBR = 1 : Endif
            If [F:MFO]EXTLABNBR = 0 : [F:MFO]EXTLABNBR = 1 : Endif
            If find([F:MFO]OPESTA, 4,5) & [F:MFO]CPLLABNBR = 0 : [F:MFO]CPLLABNBR = 1 : Endif 
        Endif
        If [F:MFO]EXTWSTNBR > 1 & [F:MFO]OPENUMLEV <> 9
             # temps opératoire = temps total
             [F:MFO]EXTOPETIM = [F:MFO]EXTOPETIM * [F:MFO]EXTWSTNBR 
             # recalcul temps unitaire
             If [F:MFO]EXTQTY <> 0
                 [F:MFO]EXTUNTTIM = [F:MFO]EXTOPETIM / [F:MFO]EXTQTY
             Endif
             [F:MFO]EXTOPETIM = arr([F:MFO]EXTOPETIM, 0.0001)
             [F:MFO]EXTUNTTIM = arr([F:MFO]EXTUNTTIM, 0.0001)
             [F:MFO]STDOPETIM = [F:MFO]EXTOPETIM
             [F:MFO]STDUNTTIM = [F:MFO]EXTUNTTIM
             If find([F:MFO]OPESTA, 4,5) : [F:MFO]CPLWSTNBR = [F:MFO]EXTWSTNBR : Endif
             [F:MFO]OPENUMLEV = 9        # pour mémoriser le fait que la moulinette est déjà passée
        Endif
        Rewrite [F:MFO]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MFO]MFGNUM
        CLE2 = [F:MFO]OPENUM
        CLE4 = [F:MFO]OPESPLNUM
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MFO : Endif
Filter [MFO]
Close Local File [MFO]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation encours opération   OPERATIONS   #
#-------------------------------------------------#
Local File OPERATIONS  [OPS]

Call TEMPON("Operations In Progress Process") From GESECRAN

Raz CLE1,CLE2, STOP
$BOUCLE_OPS
If STOP=1
  STOP=0 : CRITERE='OPSNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [OPS]

For [OPS]OPS0 Where evalue(CRITERE)
    Readlock [OPS] Curr    
    If fstat
        Call ECR_TRACE("File OPERATIONS, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:OPS]EXTLAB <> ""
            If [F:OPS]EXTLABNBR = 0 : [F:OPS]EXTLABNBR = 1 : Endif
            If [F:OPS]OPESTA = 4 & [F:OPS]CPLLABNBR = 0 : [F:OPS]CPLLABNBR = 1 : Endif 
        Endif
        If [F:OPS]EXTWSTNBR > 1 & [F:OPS]ABBFIL <> "130"
             # temps opératoire = temps total
             [F:OPS]EXTOPETIM = [F:OPS]EXTOPETIM * [F:OPS]EXTWSTNBR 
             # recalcul temps unitaire
             [F:OPS]EXTOPETIM = arr([F:OPS]EXTOPETIM, 0.0001)
             If find([F:OPS]OPESTA, 4,5) : [F:OPS]CPLWSTNBR = [F:OPS]EXTWSTNBR : Endif
             [F:OPS]ABBFIL = "130"    # pour mémoriser le fait que la moulinette est déjà passée
         Endif
 
        Rewrite [F:OPS]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:OPS]OPSNUM            # llc 01.02 
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_OPS : Endif
Filter [OPS]
Close Local File [OPS]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation plans travail     BENCHTRS       #
#-------------------------------------------------#
Local File BENCHTRS   [BTS]
If clalev ([F:AMZ]) <= 0  : Local File AMSKZON [AMZ] : Endif
If clalev ([F:AMK])  = 0  : Local File AMSK    [AMK] : Endif
If clalev ([F:AMA])  = 0  : Local File AMSKACT [AMA] : Endif
If clalev ([F:AMP])  = 0  : Local File AMSKPAR [AMP] : Endif
If clalev ([F:ADS])  = 0  : Local File ADOSSIER[ADS] : Endif
Local Char    LIBEL(30) , MASKREF(10), MASKDES(10)
Local Integer ER
Local Integer I, J, OK, OFFSET
Local Integer INC


Call TEMPON("Planning Tools Process") From GESECRAN
Raz CLE1,CLE2

Trbegin [BTS]

For [BTS]BTS0
    Readlock [BTS] Curr    
    If fstat
        Call ECR_TRACE("File BENCHTRS, Error ="-num$(fstat),1) From GESECRAN
    Else
        Case [F:BTS]BTSTYP
            When 51:    If [F:BTS]GESAFF = 0 : [F:BTS]GESAFF     = 1 : Endif
                        If [F:BTS]BUYER   = 2
                            [F:BTS]SUG(1) = 2
                            [F:BTS]SUG(5) = 2
                            [F:BTS]PLN(1) = 2
                            [F:BTS]LAN(1) = 2
                            [F:BTS]CRIT(1)= 2
                            [F:BTS]PLN(5) = 2
                            [F:BTS]LAN(5) = 2
                            [F:BTS]CRIT(5)= 2
                            [F:BTS]LAN(6) = 2
                            [F:BTS]RES    = 2                           
                        Else
                            [F:BTS]SUG(1) = 1
                            [F:BTS]PLN(1) = 1
                            [F:BTS]LAN(1) = 1
                            [F:BTS]CRIT(1)= 1
                            [F:BTS]SUG(5) = 1
                            [F:BTS]PLN(5) = 1
                            [F:BTS]LAN(5) = 1
                            [F:BTS]CRIT(5)= 1
                            [F:BTS]LAN(6) = 1
                        Endif
                        If [F:BTS]PLANNER = 2
                            [F:BTS]SUG(3) = 2
                            [F:BTS]PLN(3) = 2
                            [F:BTS]LAN(3) = 2
                            [F:BTS]CRIT(3)= 2
                            [F:BTS]RES    = 2
                        Else
                            [F:BTS]SUG(3) = 1
                            [F:BTS]PLN(3) = 1
                            [F:BTS]LAN(3) = 1
                            [F:BTS]CRIT(3)= 1
                        Endif
                        MASKREF = "MFGBENCH"
                        [F:BTS]NBRLIG = 301
                        [F:BTS]NBRCOL = 4
            When 52:    If [F:BTS]GESAFF = 0 : [F:BTS]GESAFF     = 1 : Endif
                        MASKREF = "MFGBENCHD"
                        [F:BTS]NBRLIG = 301
                        [F:BTS]NBRCOL = 3
            When 53:    If [F:BTS]GESAFF = 0 : [F:BTS]GESAFF     = 1 : Endif
                        If [F:BTS]BUYER = 2
                            [F:BTS]APPBUY = 2
                            [F:BTS]BUYER  = 1 
                            MASKREF = "MFGPICKA"
                        Else
                            [F:BTS]APPBUY = 1
                            MASKREF = "MFGPICK"
                        Endif
                        [F:BTS]NBRLIG = 51
                        [F:BTS]NBRCOL = 3
        Endcase
        # chargement des zones
        [F:BTS]NBRFLD = 0
        # dans quel bloc se situe le tableau ?
        Read [AMZ]CODE = MASKREF;"NBLIG"
        If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif

        For [AMZ]CODZON Where CODMSK=MASKREF
            OK = 1
            If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
                OK = 0
            Endif
            If OK & !find([F:AMZ]CODZON,[F:BTS]FLD(0..[F:BTS]NBRFLD-1))
                I = [F:BTS]NBRFLD
                [F:BTS]FLD(I) = [F:AMZ]CODZON
                [F:BTS]NBRFLD += 1 
            Endif 
        Next 

        # activation des champs 
        INC = 0
        For I = 0 To [F:BTS]NBRFLD - 1
            INC += 5
            [F:BTS]DAC(I) = INC
        Next I


        Rewrite [F:BTS]
    Endif
  Next
Commit
Close Local File [BTS]
Call TEMPOFF From GESECRAN

$S_MWS
#-------------------------------------------------#
# Initialisation postes de charge WORKSTATIO      #
#-------------------------------------------------#
Local File WORKSTATIO   [MWS]
Local File CALENDAR     [CAL]

Local Char     WLAST
Local Integer  WNBR

Call TEMPON("Workstations Process") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MWS
If STOP=1
  STOP=2 : CRITERE='WST="'+CLE1+'"'+' & WCRFCY>"'+CLE3+'"'
Elsif STOP=2
  STOP=0 : CRITERE='WST>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MWS]
For [MWS]WST0 Where evalue(CRITERE)
    Readlock [MWS] Curr    
    If fstat
        Call ECR_TRACE("File WORKSTATIO, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:MWS]TWD = ""
            WLAST = ""
            For [CAL] Where CAL = [F:MWS]CAL
                If fstat : Break : Endif
                WLAST = [F:CAL]TWD
                WNBR  = int([F:CAL]CAPFCT)
                If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
            Next
            [F:MWS]TWD    = WLAST
            [F:MWS]WSTNBR = WNBR
            If [F:MWS]WSTNBR = 0 : [F:MWS]WSTNBR = 1 : Endif
        Endif
        If [F:MWS]DSPLEV = 0 :  [F:MWS]DSPLEV = 1 : Endif
        Rewrite [F:MWS]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MWS]WST
        CLE3 = [F:MWS]WCRFCY
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MWS : Endif
Close Local File [MWS]
Close Local File [CAL]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation articles sites   ITMFACILIT      #
#-------------------------------------------------#
Local File ITMFACILIT   [ITF]
Local File ITMMASTER    [ITM]

Call TEMPON("Item by Facility Process") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_ITF
If STOP=1
  STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & STOFCY>"'+CLE3+'"'
Elsif STOP=2
  STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ITF]
For [ITF]ITF0 Where evalue(CRITERE)
    Readlock [ITF] Curr    
    If fstat
        Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:ITF]BUY = ""
            Read [ITM]ITM0=[F:ITF]ITMREF
            If !fstat 
                If [F:ITM]BUY <> ""    
                    [F:ITF]BUY = [F:ITM]BUY
                Endif
            Endif
        Endif
        If [F:ITF]RELSCATIA = 0 : [F:ITF]RELSCATIA = 2 : Endif
        Rewrite [F:ITF]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:ITF]ITMREF
        CLE3 = [F:ITF]STOFCY
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_ITF : Endif
Close Local File [ITF]
Close Local File [ITM]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation encours          ORDERS          #
#-------------------------------------------------#
Local File ORDERS       [ORD]
Local File MFGHEAD      [MFG]

Call TEMPON("Work In Progress Process") From GESECRAN

Filter [ORD] Where WIPTYP = 5 &
&                  find(WIPSTA, 1,2)

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_ORD
If STOP=1
  STOP=2 : CRITERE='WIPTYP='+num$(CLE2)+' & WIPNUM="'+CLE1+'"'+' & ITMREF>"'+CLE3+'"'
Elsif STOP=2
  STOP=3 : CRITERE='WIPTYP='+num$(CLE2)+' & WIPNUM>"'+CLE1+'"'
Elsif STOP=3
  STOP=0 : CRITERE='WIPTYP>'+num$(CLE2)
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ORD]
For [ORD]ORD0 Where evalue(CRITERE)
    Readlock [ORD] Curr    
    If fstat
        Call ECR_TRACE("File ORDERS, Error ="-num$(fstat),1) From GESECRAN
    Else
        If !find([F:ORD]OPTFLG,1,2)
            Read [MFG]MFG0=[F:ORD]VCRNUM
            If !fstat 
                If [F:MFG]SCDFLG = 4
                    [F:ORD]OPTFLG = 2
                Else
                    [F:ORD]OPTFLG = 1
                Endif
            Endif
        Endif
        Rewrite [F:ORD]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:ORD]WIPNUM
        CLE2 = [F:ORD]WIPTYP
        CLE3 = [F:ORD]ITMREF
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_ORD : Endif
Filter [ORD]
Close Local File [ORD]
Close Local File [MFG]

Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation opération standard   ROUOPESTD   #
#-------------------------------------------------#
Local File WORKSTATIO [MWS]
Local File ROUOPESTD  [ROT]

Call TEMPON("Standard Operation Process") From GESECRAN
Raz CLE2

$BOUCLE_ROT
Raz COMPTEUR, STOP
Trbegin [ROT]

For [ROT]ROT0 Where STDOPENUM > CLE2
    Readlock [ROT] Curr    
    If fstat
        Call ECR_TRACE("File ROUOPESTD, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:ROT]FCY = ""
           Filter [F:MWS] Where WST = [F:ROT]WST
           Read [F:MWS]WST0 First
           If !fstat [F:ROT]FCY = [F:MWS]WCRFCY : Endif
           Filter [MWS]
        Endif
        If [F:ROT]LABWST <> "" & [F:ROT]LABNBR = 0 : [F:ROT]LABNBR = 1 : Endif
        Rewrite [F:ROT]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE2 = [F:ROT]STDOPENUM
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_ROT : Endif
Filter [ROT]
Close Local File [ROT]
Close Local File [MWS]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation opération            ROUOPE      #
#-------------------------------------------------#
Local File WORKSTATIO [MWS]
Local File ROUOPE     [ROO]

Call TEMPON("Operation Process") From GESECRAN
Raz CLE1,CLE2,CLE4,CLE5,STOP
$BOUCLE_ROO
If STOP=1
  STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & ROUALT='+num$(CLE2)+' & OPENUM='+num$(CLE4)+' & RPLIND>'+num$(CLE5)
Elsif STOP=2
  STOP=3 : CRITERE='ITMREF="'+CLE1+'"'+' & ROUALT='+num$(CLE2)+' & OPENUM>'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='ITMREF="'+CLE1+'"'+' & ROUALT>'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ROO]

For [ROO]ROO0 Where evalue(CRITERE)
    Readlock [ROO] Curr    
    If fstat
        Call ECR_TRACE("File ROUOPE, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:ROO]FCY = ""
            Filter [F:MWS] Where WST = [F:ROO]WST
            Read [F:MWS]WST0 First
            If !fstat [F:ROO]FCY = [F:MWS]WCRFCY : Endif
            Filter [MWS]
        Endif
        If [F:ROO]LABWST <> "" & [F:ROO]LABNBR = 0 : [F:ROO]LABNBR = 1 : Endif
        Rewrite [F:ROO]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:ROO]ITMREF
        CLE2 = [F:ROO]ROUALT 
        CLE4 = [F:ROO]OPENUM
        CLE5 = [F:ROO]RPLIND
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_ROO : Endif
Filter [ROO]
Close Local File [ROO]
Close Local File [MWS]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation gamme                ROUTING     #
#-------------------------------------------------#
Local File ROUOPE     [ROO]
Local File ROUTING    [ROH]
Local File TABROUALT  [TRO]

Call TEMPON("Routing Process") From GESECRAN

Raz  CLE1, CLE2, STOP
$BOUCLE_ROH
If STOP=1
  STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & ROUALT>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ROH]

For [ROH]ROH1 Where evalue(CRITERE)
    Readlock [ROH] Curr    
    If fstat
        Call ECR_TRACE("File ROUTING, Error ="-num$(fstat),1) From GESECRAN
    Else
        Filter [F:ROO] Where ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT    # llc 06.01
        Read [F:ROO]ROO0 First
        If !fstat [F:ROH]FCY = [F:ROO]FCY : Endif

        Read [TRO]TRO0 = [F:ROH]ROUALT  
        [F:ROH]ACSCOD = [F:TRO]ACSCOD  # code accès en redondance (TB bug 6336)
        Rewrite [F:ROH]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:ROH]ITMREF
        CLE2 = [F:ROH]ROUALT
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_ROH : Endif
Filter [ROH]
Close Local File [ROH]
Close Local File [ROO]
Close Local File [TRO]

Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation suivi opération   MFGOPETRK      #
#-------------------------------------------------#
Local File MFGOPETRK  [MKO]

Call TEMPON("Operation Tracking Process") From GESECRAN

Raz CLE1,CLE2, STOP
$BOUCLE_MKO
If STOP=1
  STOP=2 : CRITERE='MFGTRKNUM="'+CLE1+'"'+' & OPETRKLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='MFGTRKNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MKO]

For [MKO]MKO0 Where evalue(CRITERE)
    Readlock [MKO] Curr    
    If fstat
        Call ECR_TRACE("File MFGOPETRK, Error ="-num$(fstat),1) From GESECRAN
    Else
        [F:MKO]OPEWORCOE = 1
        If [F:MKO]REJCPLQTY <> 0 & [F:MKO]TABREJQTY(0) = 0
           [F:MKO]TABREJQTY(0) = [F:MKO]REJCPLQTY
        Endif
        If [F:MKO]TIMTYP = 0 : [F:MKO]TIMTYP = 1 : Endif
        Rewrite [F:MKO]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MKO]MFGTRKNUM
        CLE2 = [F:MKO]OPETRKLIN 
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MKO : Endif
Filter [MKO]
Close Local File [MKO]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation declaration prod  MFGITMTRK      #
#-------------------------------------------------#
Local File MFGITMTRK  [MKI]

Call TEMPON("Manufacturing Products tracking Process") From GESECRAN

Raz CLE1,CLE2, STOP
$BOUCLE_MKI
If STOP=1
  STOP=2 : CRITERE='MFGTRKNUM="'+CLE1+'"'+' & ITMTRKLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='MFGTRKNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MKI]

For [MKI]MKI0 Where MFGTRKNUM  > CLE1 &
&                   ITMTRKLIN  > CLE2  
    Readlock [MKI] Curr    
    If fstat
        Call ECR_TRACE("File MFGITMTRK, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:MKI]PRODTYP = 0 : [F:MKI]PRODTYP = 1 : Endif
        Rewrite [F:MKI]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MKI]MFGTRKNUM
        CLE2 = [F:MKI]ITMTRKLIN 
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MKI : Endif
Filter [MKI]
Close Local File [MKI]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation suivi matière     MFGMATTRK      #
#-------------------------------------------------#
Local File MFGMATTRK  [MKM]

Call TEMPON("Material Tracking Process") From GESECRAN

Raz CLE1,CLE2, STOP
$BOUCLE_MKM
Raz COMPTEUR
If STOP=1
  STOP=2 : CRITERE='MFGTRKNUM="'+CLE1+'"'+' & MATTRKLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='MFGTRKNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Trbegin [MKM]

For [MKM]MKM0 Where MFGTRKNUM  > CLE1 &
&                   MATTRKLIN  > CLE2  
    Readlock [MKM] Curr    
    If fstat
        Call ECR_TRACE("File MFGMATTRK, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:MKM]MATTYP = 0 : [F:MKM]MATTYP = 1 : Endif
        Rewrite [F:MKM]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MKM]MFGTRKNUM
        CLE2 = [F:MKM]MATTRKLIN 
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MKM : Endif
Filter [MKM]
Close Local File [MKM]
Call TEMPOFF From GESECRAN

#-------------------------------------------------#
# Initialisation sections valorisation WORKCOST   #
#-------------------------------------------------#
Local File WORKCOST     [MWC]
Local Integer I

Call TEMPON("Workcosts Process") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MWC
If STOP=1
  STOP=2 : CRITERE='VLTCCE="'+CLE1+'"'+' & VLTFCY>"'+CLE3+'"'
Elsif STOP=2
  STOP=0 : CRITERE='VLTCCE>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MWC]
For [MWC]WCT0 Where evalue(CRITERE)
    Readlock [MWC] Curr    
    If fstat
        Call ECR_TRACE("File WORKCOST, Error ="-num$(fstat),1) From GESECRAN
    Else
        For I = 0 To dim([F:MWC]CCECOD) - 1
            [F:MWC]CCECOD(I) = 1
        Next I
        Rewrite [F:MWC]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MWC]VLTCCE
        CLE3 = [F:MWC]VLTFCY
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_MWC : Endif
Close Local File [MWC]
Call TEMPOFF From GESECRAN



#-------------------------------------------------#
# Initialisation OF                    MFGHEAD    #
#-------------------------------------------------#

Local Integer XTOT
Local Integer I, GOK
Local File MFGHEAD [MFG]
Local File MFGMAT  [MFM]

Call TEMPON("Work Orders Header") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFG
If STOP=1
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MFG]
For [MFG] Where evalue(CRITERE) 
    Readlock [F:MFG]MFG0 Curr
    If fstat
        Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
    Else
        Raz [F:MFG]OVRALLNBR, DETALLNBR, SHTMATNBR

        For [F:MFM] Where MFGNUM = [F:MFG]MFGNUM
            Case [F:MFM]ALLSTA    # évaluation nouveaux totaux en fonction de l'évolution du statut
                  When 2:  [F:MFG]OVRALLNBR += 1
                           [F:MFG]SHTMATNBR += 1 
                  When 3:  [F:MFG]OVRALLNBR += 1
                  When 4:  [F:MFG]DETALLNBR += 1
                           [F:MFG]SHTMATNBR += 1
                  When 5:  [F:MFG]DETALLNBR += 1
            Endcase
        Next

        Gosub MAJSTATUT
        If [F:MFG]MFGSTA = 4 & [F:MFG]CLODAT = [0/0/0] 
           [F:MFG]CLODAT = [F:MFG]TRKLAST
        Endif 
        Rewrite [MFG]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:MFG]MFGNUM
        STOP = 1 
        Break 
    Endif
Next
Commit
If STOP : Goto BOUCLE_MFG : Endif
Close Local File [MFG]
Close Local File [MFM]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation centres de charge    TABWRKCTR   #
#-------------------------------------------------#
Local File TABWRKCTR  [TWC]

Call TEMPON("Work Centers Process") From GESECRAN
Raz CLE1

$BOUCLE_TWC
Raz COMPTEUR, STOP
Trbegin [TWC]

For [TWC]TWC0 Where WCR > CLE1
    Readlock [TWC] Curr    
    If fstat
        Call ECR_TRACE("File TABWRKCTR, Error ="-num$(fstat),1) From GESECRAN
    Else
        [F:TWC]DSPLEV = 1
        Rewrite [F:TWC]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:TWC]WCR
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_TWC : Endif
Close Local File [TWC]
Call TEMPOFF From GESECRAN


#-------------------------------------------------#
# Initialisation paramétrages PDP/MRP             #
#-------------------------------------------------#
Local File PARMRP       [PCB]
Local File CALENDAR     [CAL]

Local Char     WLAST

Call TEMPON("MRP Parameters Process") From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_PCB
If STOP=1
  STOP=0 : CRITERE='STOFCY>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [PCB]
For [PCB]PCB0 Where evalue(CRITERE)
    Readlock [PCB] Curr    
    If fstat
        Call ECR_TRACE("File PARMRP, Error ="-num$(fstat),1) From GESECRAN
    Else
        WLAST = ""
        For [CAL] Where CAL = [F:PCB]MPSCAL
            If fstat : Break : Endif
            WLAST = [F:CAL]TWD
            If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
        Next
        [F:PCB]MPSTWD = WLAST
        For [CAL] Where CAL = [F:PCB]MRPCAL
            If fstat : Break : Endif
            WLAST = [F:CAL]TWD
            If [F:CAL]STRDAT <= date$ & [F:CAL]ENDDAT >= date$ : Break : Endif
        Next
        [F:PCB]MRPTWD = WLAST
        Rewrite [F:PCB]
    Endif
    COMPTEUR += 1
    If COMPTEUR > 499 
        CLE1 = [F:PCB]STOFCY
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_PCB : Endif
Close Local File [PCB]
Close Local File [CAL]
Call TEMPOFF From GESECRAN

#-----------------------------------------------------------------------#
# Suppression des allocations intempestives
#-----------------------------------------------------------------------#
Local File MFGMAT     [MFM]  
Local File MFGMAT     [MFM2] 
Local File STOALL     [STA]
Local File STOALL     [STA1]
Local File STOALL     [STA2]
Local File MFGITM     [MFI]
Local File ITMMASTER  [ITM]
Local File ITMFACILIT [ITF]
Local File ORDERS     [ORD]
Local File ITMMVT     [ITV]
Local File STOCK      [STO] 
#----- masque encours
Local Mask ORDK [ORDK]
#----- masque STOCK
Local Mask STOK [STOK]
#----- variables locales
Local Integer  WALLOC
Local Char     WFCY
Local Integer  WTYP 
Local Char     WNUM 
Local Decimal  WLIN 
Local Decimal  WSEQ 
Local Char     WITM 
Local Integer  WOPT 
Local Decimal  WQTY 
Local Decimal  WSHT 
Local Integer  WRET 
#----------------------------------------------------------------#
# Première boucle : on part des matières
#----------------------------------------------------------------#

Call ECR_TRACE("DOSMAJ5 : stock allocations Process",0) From GESECRAN
Call ECR_TRACE("UTIGPA01: begin phase 1  ",0) From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFM
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+ 
&                                      ' & ITMREF >"'+CLE3+'"'                      
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ >'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN >'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
CRITERE -="& (MFMTRKFLG = 5 | ([F:MFM2]RETQTY - [F:MFM2]USEQTY <= 0))"

Raz COMPTEUR
Trbegin [MFM]
#----------------------------------------------------------------#
For [F:MFM2] Where evalue(CRITERE)
    Filter [F:STA2] Where VCRTYP = 10 & VCRNUM = [F:MFM2]MFGNUM & VCRLIN = [F:MFM2]MFGLIN &
&                        VCRSEQ = [F:MFM2]BOMSEQ & ITMREF = [F:MFM2]ITMREF  
    Raz WALLOC
    Read [F:STA2]STA0 First
    If !fstat : WALLOC = 2 : Else WALLOC = 1: Endif
    Filter [F:STA2]
    If WALLOC = 2 | [F:MFM]ALLQTY <> 0 | [F:MFM]SHTQTY <> 0
       Readlock [F:MFM]MFM0 =[F:MFM2]MFGNUM;[F:MFM2]MFGLIN;[F:MFM2]BOMSEQ;[F:MFM2]ITMREF  
       If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MFM2]ITMREF : Break
       Elsif fstat GOK=0  : Call RSTA("MFM",[F:MFM2]ITMREF) From GLOCK : Break
       Endif
       If WALLOC = 2 
           Gosub SUPALL_OF From SUBMTKC 
           If GOK < 1 
              Call ECR_TRACE("Erreur allocations du composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF,1) From GESECRAN
              Break 
           Endif    
       Endif 
       Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
       Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
       Read [F:MFI]MFI0 First
       If fstat : GOK=0: Call RSTA("MFI",[F:MFM]MFGLIN) From GLOCK 
           Filter [F:MFI]
           Break
       Endif    
       Filter [F:MFI] 
       Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
       Rewrite [F:MFM]
       If fstat
          GOK = 0 : Call FSTA("MFM") From GLOCK 
          Call ECR_TRACE("Erreur="+num$(fstat)+" sur composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF,1) From GESECRAN
          Break
       Endif
       Call ECR_TRACE("Composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF +" traité ",0) From GESECRAN
       $SUITE_UTIGPA01
    Endif
    COMPTEUR += 1
    If COMPTEUR > 49
        CLE1 = [F:MFM2]MFGNUM
        CLE2 = [F:MFM2]MFGLIN
        CLE4 = [F:MFM2]BOMSEQ
        CLE3 = [F:MFM2]ITMREF
        STOP = 1 
        Break 
    Endif
Next
If GOK <= 0 : Rollback : Else : Commit : Endif
If STOP : Goto BOUCLE_MFM : Endif
Filter [MFM]
Call ECR_TRACE("UTIGPA01: end phase 1  ",0) From GESECRAN
#----------------------------------------------------------------#
# Deuxième boucle : on part des allocations
# On supprime les allocations sans matière
#----------------------------------------------------------------#
Call ECR_TRACE("UTIGPA01 : begin phase 2 ",0) From GESECRAN
Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFM_2
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+ 
&                                      ' & ITMREF >"'+CLE3+'"'                      
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ >'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN >'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
CRITERE -="& VCRTYP = 10)"
Raz COMPTEUR
Trbegin [MFM]
#
For [F:STA2] Where evalue(CRITERE)
    Read [F:MFM2]MFM0 = [F:STA2]VCRNUM;[F:STA2]VCRLIN;[F:STA2]VCRSEQ;[F:STA2]ITMREF
    If fstat
       GOK=1  
       WFCY = [F:STA2]STOFCY
       WNUM = [F:STA2]VCRNUM
       WLIN = [F:STA2]VCRLIN      
       WTYP = 10 
       WSEQ = [F:STA2]VCRSEQ
       WITM = [F:STA2]ITMREF
       WOPT = 0  
       WRET = 0
       Case [F:STA2]ALLTYP :
            When 1,5 : 
                Call DELGLO(WTYP,WNUM,WLIN,WSEQ,WITM,WOPT,WQTY,WSHT,WRET) From ALLLIB
            When 2,4 : 
                Call DELALL(WTYP,WNUM,WLIN,WSEQ,WITM,WOPT,WQTY,WSHT,WRET) From ALLLIB
       Endcase 
       If WRET <> 0 : Break : Endif 
       Call ECR_TRACE("Allocation sur Composant "+[F:STA2]VCRNUM - [F:STA2]ITMREF +" supprimée ",0) From GESECRAN
     Endif
     COMPTEUR += 1
     If COMPTEUR > 49 
        CLE1 = [F:MFM]MFGNUM
        CLE2 = [F:MFM]MFGLIN
        CLE4 = [F:MFM]BOMSEQ
        CLE3 = [F:MFM]ITMREF
        STOP = 1 
        Break 
     Endif
Next
If GOK <= 0 
   Rollback 
Else 
 Commit 
Endif
If STOP : Goto BOUCLE_MFM_2 : Endif
Filter [MFM]
Call ECR_TRACE("UTIGPA01: end phase 2  ",0) From GESECRAN
#
Call TEMPOFF From GESECRAN


End

#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:MFG]OVRALLNBR + [F:MFG]DETALLNBR
If (XTOT = 0)                     
    [F:MFG]ALLSTA = 1 
Else 
    If (XTOT < [F:MFG]MATLINNBR)      
        [F:MFG]ALLSTA = 2 
    Else 
        If (XTOT = [F:MFG]MATLINNBR)         
            [F:MFG]ALLSTA = 3 
        Endif 
    Endif 
Endif

# si des ruptures existent, statut allocation + 2
If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif
Return

