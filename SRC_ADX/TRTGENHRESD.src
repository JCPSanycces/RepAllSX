######################################################################################
## Section automatically added (screen GENHRESD0) 01/07/2016 13:53:59 (DEHEN)
######################################################################################
Subprog C_EMP(VALEUR)

Variable Integer    VALEUR()
  Raz  [M]DATFIL
  If VALEUR=1
    Call SET_NAMCLI([M]DATFIL) From ORDSYS
    Grizo [M]DATFIL
  Else
    [M]DATFIL = filpath("tmp","","",nomap,"","")
    Actzo [M]DATFIL
  Endif
Affzo [M]DATFIL

End


Subprog C_DATFIL(VALEUR)
Variable Char VALEUR()

Local Integer TYPFIC
Local Char    FICHIER(GDIMFIC)

  #-- Pas d'enregistrement en local lors de l'extraction en Batch ou en Web. DdM40522
  If instr(1,VALEUR,"#@") and (GBROWS or GBATCH) : mkstat=2 : End : Endif

  If left$(VALEUR,1)="#"
   GMESSAGE = mess(162,141,1) : # Le rÃ©pertoire doit Ãªtre indiquÃ© sur un serveur
   mkstat = 2 : End
  Endif

  FICHIER = VALEUR

  Call EXISTE(FICHIER,TYPFIC) From ORDSYS
  Case TYPFIC
   When 0,1 : GMESSAGE = mess(9,141,1) : mkstat = 2 : End : # RÃ©pertoire inexistant
  Endcase

End


