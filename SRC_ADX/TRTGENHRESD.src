######################################################################################
Subprog AM_EMPLOC(VALEUR)
Variable Integer VALEUR
  Raz  [HRESD0]DATFIL
  If VALEUR=1
   Call SET_NAMCLI([HRESD0]DATFIL) From ORDSYS
   Grizo [HRESD0]DATFIL
  Else
   [HRESD0]DATFIL = filpath("tmp","","",nomap,"","")
   Actzo [HRESD0]DATFIL
  Endif
  Affzo [HRESD0]DATFIL
End


