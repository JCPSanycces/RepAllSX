#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End
Local Char VALEUR(10), PARAM(30)(1..4)
VALEUR = "GB"
PARAM(1) = "GB"
PARAM(2) = "1"
PARAM(3) = "1"
PARAM(4) = "10"
Call TRAITE_CHAR(VALEUR,PARAM,"","TXSGRAPH","ALHG",3,"") From GTRAITE
End

########################################################################
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

########################################################################
$INIT
Local Integer I, J, N
Local Char    WNAM(15)  : # Nom graphe de référence   
Local Char    WTIT(30)  : # Texte titre
Local Char    WFOO(80)  : # Texte pied
Local Integer WCOL      : # Nombre de colonnes
Local Integer WROW      : # Nb lignes (on ne prend pas la ligne 'total')
If [F:TXS]GRPCOD<>""
 BCRIT = ""
 Local Mask TXSGRAPH [DIA]
 [M:DIA]TYPGRA = [F:TXS]GRPCOD
Endif
Return

########################################################################
$INIT_DIA
[M:DIA]TYPGRA = "CHART_STAT1"
Call GRAPHDES([M:DIA]TYPGRA,[M:DIA]GRAPHDES) From ATRTX3
Return

########################################################################
$EXEC
WNAM = [M:DIA]TYPGRA
WTIT = [F:TXS]TXSDES

WROW = [M:TXM1]NBLIG
Read [TXS]TXS1 = [M:TXM0]TXSNAM
WCOL = [F:TXS]NBRCOL

Local Char    WABS(20)(1..WROW), WORD(20)(1..WCOL+1)
Local Decimal WAMT(1..WROW)     : # Tableau des valeurs 
Local Decimal TAMT(1..WROW,1..WCOL)

# Intitulé colonne, montants
Raz I, N, WAMT, TAMT, WABS
Filter [TXM] Where TXSNAM=[M:TXM0]TXSNAM & VERSION=[M:TXM0]VERSION & IND=0
For [TXM]TXM0
 If [F:TXM]COL=0
  I += 1
  WABS(I) = [F:TXM]AMTVAL
 Else
  If [F:TXM]UPDVAL<>""
   TAMT([F:TXM]LIG,[F:TXM]COL) = val([F:TXM]UPDVAL)/[M:TXM1]DIVCOL([F:TXM]COL-1)
  Else
   TAMT([F:TXM]LIG,[F:TXM]COL) = val([F:TXM]AMTVAL)/[M:TXM1]DIVCOL([F:TXM]COL-1)
  Endif
 Endif
Next
Filter [TXM]
For I=1 To [F:TXS]NBRCOL
 WORD(I) = [F:TXS]NAMCOL(I-1)
Next I

# Ouverture du graphe
Call OPEN_CHART(WNAM,10,5,340,200,WCOL,1,WROW,1,WTIT,WFOO,0) From ATRTX3
# Chargement des données
For I=1 To WCOL
 For J=1 To WROW
  WAMT(J) = TAMT(J,I)
 Next J
 Call DATA_CHART(I,1,WAMT(1..WROW),0,0) From ATRTX3
Next I
# Chargement labels abscisse et légende
Call LABELX_CHART(1,1,WABS(1..WROW),0) From ATRTX3
Call LABELC_CHART(1,1,WORD(1..WCOL),0) From ATRTX3
# Ouverture fenêtre et affichage
Call DISPLAY_CHART(1,1,1,0,0,0) From ATRTX3
Call SAI_CHART From ATRTX3
Return


Subprog AP_TYPGRA(VALEUR)
Variable Char VALEUR()
Call GRAPHDES(VALEUR,[M:DIA]GRAPHDES) From ATRTX3
Affzo [DIA]GRAPHDES
End

Subprog C_TYPGRA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & filinfo(filpath("GRAPH",VALEUR,"vtc"),0)<0
 GMESSAGE = mess(101,100,1) : mkstat=2 : End # Fichier inexistant
Endif
End

#CHECK UNUSED_BEGIN
Subprog C_NOLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0 | VALEUR>[M:TXM1]NBLIG
 mkstat=2
Else
 Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;VALEUR;0;0
 [M:DIA]LIBLIG = [F:TXM]AMTVAL
Endif
End
#CHECK UNUSED_END


