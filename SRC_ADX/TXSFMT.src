#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXS",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Local Char  LIN_STR(GDIMFIC), LIN_END(GDIMFIC), ZONE(10)
Local Integer COL, NOL
LIN_STR  = ctrans(mess(83,111,1),":","")  : # "De la colonne"
LIN_END  = ctrans(mess(84,111,1),":","")  : # "A la colonne"
ZONE = zoncou   :# NBLIG ou FRM0,1,2...
NOL = nolign
Return

$DEBUT
[M:DIA]NOLIG = NOL
[M:DIA]LIGNAM = '  "'+[M:TXA2]FRM0(NOL-1)+'"'
Case ZONE
 When "NBLIG" 
  If [M:DIA]LINSTR=0 : [M:DIA]LINSTR = 1 : Endif
  If [M:DIA]LINEND=0 : [M:DIA]LINEND = [M:TXA1]NBRCOL : Endif
  COL = 1
  [M:DIA]DECCOL = 0
  Grizo [M:DIA]DECCOL
  If [M:TXA2]FMTPRN(NOL-1)=string$([M:TXA1]NBRCOL,left$([M:TXA2]FMTPRN(NOL-1),1))
   [M:DIA]FMTPRN = val(left$([M:TXA2]FMTPRN(NOL-1),1))
  Else
   [M:DIA]FMTPRN = 1
  Endif
  If [M:TXA2]EFFPRN(NOL-1)=string$([M:TXA1]NBRCOL,left$([M:TXA2]EFFPRN(NOL-1),1))
   [M:DIA]EFFPRN = val(left$([M:TXA2]EFFPRN(NOL-1),1))
  Else
   [M:DIA]EFFPRN = 1
  Endif
 When Default
  COL = val(right$(ZONE,4))
  [M:DIA]LINSTR = COL
  [M:DIA]LINEND = [M:DIA]LINSTR
  If COL
   [M:DIA]FMTPRN = val(mid$([M:TXA2]FMTPRN(NOL-1),COL,1))
   [M:DIA]EFFPRN = val(mid$([M:TXA2]EFFPRN(NOL-1),COL,1))
   [M:DIA]DECCOL = val(mid$([M:TXA2]DEC(NOL-1),COL,1))
  Else
   [M:DIA]FMTPRN = [M:TXA2]FMTPRN0(NOL-1)
   [M:DIA]EFFPRN = [M:TXA2]EFFPRN0(NOL-1)
   [M:DIA]DECCOL = 0
   Grizo [M:DIA]DECCOL
  Endif
  Grizo [M:DIA]LINSTR, LINEND
Endcase
If [M:DIA]LINSTR<>0
 [M:DIA]STRNAM = '  "'+[M:TXA1]NAMCOL([M:DIA]LINSTR-1)+'"'
 [M:DIA]ENDNAM = '  "'+[M:TXA1]NAMCOL([M:DIA]LINEND-1)+'"'
Else
 [M:DIA]STRNAM = '  "'+mess(30,109,1)+'"'
 [M:DIA]ENDNAM = '  "'+mess(30,109,1)+'"'
Endif
Affzo [M]
Return

$OK
If COL
 For COL=[M:DIA]LINSTR To [M:DIA]LINEND
  [M:TXA2]FMTPRN(NOL-1) = left$([M:TXA2]FMTPRN(NOL-1),COL-1) + num$([M:DIA]FMTPRN)
&                     + right$([M:TXA2]FMTPRN(NOL-1),COL+1)
  [M:TXA2]EFFPRN(NOL-1) = left$([M:TXA2]EFFPRN(NOL-1),COL-1) + num$([M:DIA]EFFPRN)
&                     + right$([M:TXA2]EFFPRN(NOL-1),COL+1)
  If varmode([M:DIA]DECCOL)=0
   [M:TXA2]DEC(NOL-1) = left$([M:TXA2]DEC(NOL-1),COL-1) + num$([M:DIA]DECCOL)
&                   + right$([M:TXA2]DEC(NOL-1),COL+1)
  Endif
 Next COL
Else
 [M:TXA2]FMTPRN0(NOL-1) = [M:DIA]FMTPRN
 [M:TXA2]EFFPRN0(NOL-1) = [M:DIA]EFFPRN
Endif
[M:TXA2]MODIF=2
mkstat=4   :# on force l'après modif
Return

#########################
# Masque TXSAFMT
#########################
Subprog AS_LINSTR(VALEUR)
Variable Decimal VALEUR
End

Subprog C_LINSTR(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>[M:TXA1]NBRCOL
 mkstat=1 : End
Endif
[M]STRNAM = '  "'+[M:TXA1]NAMCOL(VALEUR-1)+'"'
End

Subprog AS_LINEND(VALEUR)
Variable Decimal VALEUR
End

Subprog C_LINEND(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR<[M]LINSTR | VALEUR >[M:TXA1]NBRCOL
 mkstat = 2 : End
Endif
[M]ENDNAM = '  "'+[M:TXA1]NAMCOL(VALEUR-1)+'"'
End

