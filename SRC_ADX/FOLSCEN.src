#<AdxTL>@(#)2.0.0.0 $Revision$
#
# Sous-programme pour gestion de scénarios
# 

Subprog LEC_ACT(FOLD,ACTIV,VALEUR,NOM)
Value Char FOLD(), ACTIV()
Variable Char NOM()
Variable Integer VALEUR

Local File ADOSACT,ACTIV,ATEXTE
Read [ADA]ADA0=FOLD;ACTIV
If fstat
    VALEUR=-1
    End
Else
    If [ADA]DIME>0 & [ADA]FLACT=2
        VALEUR=[ADA]DIME
    Else
        VALEUR=[ADA]FLACT
    Endif
Endif
Read [ACV]CODACT=ACTIV
If fstat
    NOM=""
    End
Endif
Read [ATX]NUMERO=GLANGUE;[ACV]LIBACT
If fstat
    NOM=""
    End
Endif
NOM=[ATX]TEXTE
End


Subprog LEC2_ACT(FOLD,ACTIV,FLACT)
Value Char FOLD(), ACTIV()
Variable Shortint FLACT

Local File ADOSACT
Read [ADA]ADA0=FOLD;ACTIV
If fstat
    VALEUR=-1
    End
Else
    FLACT=[ADA]FLACT
Endif
End


Subprog ECR_ACT(FOLD,ACTIV,VALEUR)
Value Char FOLD(), ACTIV()
Variable Integer VALEUR

Local File ADOSACT,ACTIV
Trbegin [ADA]
Read [ADA]ADA0=FOLD;ACTIV
If fstat : End : Endif
[ADA]DIME=VALEUR
Rewrite [ADA]
Commit
End

Subprog LEC_DIM(FOLD,CODEDIM,VALEUR)
Value Char FOLD(), CODEDIM()
Variable Integer VALEUR

Local File ADOSDIM
Read [ADE]ADE0=FOLD;CODEDIM
VALEUR=[ADE]NBR
End



Subprog ECR_DIM(FOLD,CODEDIM,VALEUR)
Value Char FOLD(), CODEDIM()
Variable Integer VALEUR

Local File ADOSDIM
Trbegin [ADE]
Read [ADE]ADE0=FOLD;CODEDIM
If fstat : End : Endif
[ADE]NBR=VALEUR
Rewrite [ADE]
Commit
End


Subprog LEC_FOL(FOLD,REF,BDD,DEV,DAT,LAN,CPT,TRS,IMM,VEN,HH,STO,PRO)
Value Char FOLD()
Variable Char REF,DEV,DAT,LAN
Variable Shortint BDD
Variable Integer CPT,TRS,IMM,VEN
Variable Integer HH,STO,PRO
Local File ADOSSIER
Read [ADS]DOSSIER=FOLD
REF=[ADS]DOSREF
BDD=[ADS]TYPDBA
DEV=[ADS]RPTCUR
DAT=[ADS]STRDAT
LAN=[ADS]LAN(0)+" "+[ADS]LAN(1)+" "+[ADS]LAN(2)+" "+[ADS]LAN(3)+" "+[ADS]LAN(4)
CPT=[ADS]MODULE(1)
TRS=[ADS]MODULE(2)
IMM=[ADS]MODULE(3)
VEN=[ADS]MODULE(4)
HH=[ADS]MODULE(5)
STO=[ADS]MODULE(6)
PRO=[ADS]MODULE(7)
End

Subprog LEC_PAR(PARAM,LIB,NIV)
Value Char PARAM
Variable Char LIB()
Variable Shortint NIV

Local File ADOPAR,ATEXTE
Read [ADP]ADP1=PARAM
Read [ATX]NUMERO=GLANGUE;[ADP]NAM
LIB=[ATX]TEXTE
NIV=[ADP]NIVDEF

End


