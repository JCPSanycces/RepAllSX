#<AdxTL>@(#)8.0.0.0 $Revision$
#*********************************************************************
#
#                AVENANTS A UN CONTRAT DE DE CONCESSION
#
#*********************************************************************
#    Création
#    MWA - 15.09.2009 (V5)
#
#*********************************************************************
#    Modification
#  MWA - 16.05.2018  X3-89794 Wrong definition of the site length
#  MWA - 12.04.2013 - FQ88613   Forcer le recalcul des amortissements
#  CBO - 12.03.2012 - FQ80246   GFMDAT4 au lieu de DD[/]MM[/]YYYY
#  MWA - 27.08.2010 - FQ66599   Après maj du coef.,les biens sortis dans Exe cour ou suiv ne sont plus à recalculer
#  GBO - 15.02.2010 - FQ62307   Ajout "Fin normale sur trace"
#
#*********************************************************************
#

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTCCNREV","CCNREV",3,"") From GTRAITE
End

#=================================================================================
$ACTION

 #  Infbox 'ACTION='-num$(ACTION)

Case ACTION

  When "INIT"        : Gosub INIT
  When "INIT_DIA"    : Gosub INIT_DIA
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH
  When "DEBUT"       : Gosub DEBUT
  When "CONT_BATCH"  : Gosub CONTROLE
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "END"         : ABANDON= G_OUI
  When "SORTIE"      : Gosub SORTIE
  When "TERMINE"     : Gosub TERMINE

  When "APRES_MODIF" : Gosub APRES_MODIF
  When "SETBOUT"     : Gosub SETBOUT

  When "OK"          : Gosub OK

Endcase

Return

#=============================
$INIT
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If !clalev([F:CCN])   : Local File CONCESSION  [CCN]  : Endif
 If !clalev([F:FAS])   : Local File FXDASSETS   [FAS]  : Endif
 If !clalev([F:DEP])   : Local File DEPREC      [DEP]  : Endif
 If !clalev([F:CNX])   : Local File CONTEXT     [CNX]  : Endif

 If !clalev([M:DIA])   : Local Mask CCNREV  [DIA]      : Endif
 If !clalev([M:DIA2])  : Local Mask CCNREV  [DIA2]     : Endif
 Raz [M:DIA]
 Raz [M:DIA2]
 # Valeurs par défaut
 [M:DIA2]FLGSIM=G_OUI
 [M:DIA2]FLGCAL=G_NON

 Global Integer ACTSILENCE
 Global Char    TRTFILMSK
 # Récupération des paramètres de l'action
 Gosub GET_PARAMETRES From TRTCCNREV

Return

#=============================
$INIT_DIA
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If !clalev([F:CCN])   : Local File CONCESSION  [CCN]  : Endif
 If !clalev([F:FAS])   : Local File FXDASSETS   [FAS]  : Endif
 If !clalev([F:DEP])   : Local File DEPREC      [DEP]  : Endif
 If !clalev([F:CNX])   : Local File CONTEXT     [CNX]  : Endif

 If !clalev([M:DIA])   : Local Mask CCNREV  [DIA]      : Endif
 If !clalev([M:DIA2])  : Local Mask CCNREV  [DIA2]     : Endif
 Raz [M:DIA]
 Raz [M:DIA2]
 # Valeurs par défaut
 [M:DIA2]FLGSIM=G_OUI
 [M:DIA2]FLGCAL=G_NON

 Global Integer ACTSILENCE
 Global Char    TRTFILMSK
 # Récupération des paramètres de l'action
 Gosub GET_PARAMETRES From TRTCCNREV

Return

#=============================
$AVANT_PAR
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If ( ACTSILENCE = G_OUI and TRTFILMSK <> "" ) Then
  # Pas d'affiage du masque en silencieux
  TYPPRG=0
  # Chargement du masque
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return

#=============================
$OUVRE_BATCH
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
Return

#=============================
$DEBUT
 If !GBATCH
   # Restauration avant affichage fenêtre
   Transmask [M:DIA2] To [M:DIA]
   # Conditionnement
   If ( [M:DIA]FLGCAL=G_NON ) Then : Grizo [M:DIA]FLGCAL : Affzo [M:DIA]FLGCAL : Endif
   Affzo [M:DIA]
 Endif
Return

#=============================
$OK
 # Sauveagarde écran suite à OK
 If !GBATCH  :  Transmask [M:DIA] To [M:DIA2] :  Endif
Return

#=============================
$CONTROLE

#
#                   GSERVEUR  GBATCH
# Interactif           0        0
# Saisie param.        0        1
# Lancement trt        1        0

  #-------------

  If ABANDON = G_OUI : Return : Endif

  # Exécution silencieuse : Création des variables globales pour intercepter les erreurs suite à contrôle
  #                         Dimensionnement à 1 une seule errur possible
  If ( ACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI

    # Contrat de contession sur lequel porte l'avenant
    If dim(GT_OBJ_REF)>0      : Kill GT_OBJ_REF : Endif
    Global Char  GT_OBJ_REF(20)(1) : GT_OBJ_REF (0) = [M:DIA]CCNREF
    If dim(GT_OBJ_DES)>0 :      Kill GT_OBJ_DES : Endif
    Global Char  GT_OBJ_DES(20)(1) : GT_OBJ_DES (0) = [M:DIA]CCNDES1
    # Liste erreur ( un seul poste)
    Global Char  GT_LIS_ERR(100)(1)
  Endif

  #-------------
  If (GSERVEUR or ACTSILENCE = G_OUI) Then
    If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
    Read [F:CCN]CCN0=[M:DIA]CCNREF
    If (!fstat) Then
      If ( [F:CCN]CCNSTA <> GVML_CSACTI ) Then
        # Référence concession invalide
        If (ACTSILENCE = G_OUI) Then
          ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(271,7773,1)
        Else
          GERR= 1 : GMESSAGE = mess(271,7773,1)
        Endif
        Return
      Endif
    Else
      # Référence concession invalide
      If (ACTSILENCE = G_OUI) Then
          ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(271,7773,1)
      Else
        GERR= 1 : GMESSAGE = mess(271,7773,1)
      Endif
      Return
    Endif
  Endif

  # Récupération date début période courante contexte fiscale & comptable
  Local Date    RDATE(1..5)
  Local Integer RRET
  Call GET_CNX_DAT([M:DIA]CPY, G300CPFI, RDATE, RRET) From GLOBIENS
  If (  [M:DIA]ENDCCNDAT < RDATE(3) ) Then
    # La date de fin de concession doit être supérieure ou égale au début de la période courante du contexte fiscale & comptable
    If (ACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(704,7773,1)
    Else
      If (!GSERVEUR and ACTSILENCE <> G_OUI) Then : SAI = 1 : Endif
      GERR= 1 : GMESSAGE = mess(704,7773,1)
    Endif
    Return
  Endif

  If ( func TRTCCNEND.IS_FAS_OUTSIDE_CCN ([M:DIA]CCNREF, [M:DIA]ENDCCNDAT) = G_OUI ) Then
    # Opération interdite : Au moins un bien en concession en dehors des nouvelles limites de la concession
    If (ACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(746,7773,1)
    Else
      GERR= 1 : GMESSAGE = mess(746,7773,1)
    Endif
    Return
  Endif

  If ( func TRTCCNEND.IS_ISSDAT_OUTSIDE_CCN ([M:DIA]CCNREF, [M:DIA]ENDCCNDAT) = G_OUI ) Then
    # Opération interdite : Au moins un bien en concession ayant une date de sortie au delà des nouvelles limites de la concession
    If (ACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(748,7773,1)
    Else
      GERR= 1 : GMESSAGE = mess(748,7773,1)
    Endif
    Return
  Endif

  If ( ACTSILENCE = G_OUI ) Then
    # Contrôle de l'interactif à effectuer en mode silencieux
    If ( [M:DIA]ENDCCNDAT = [M:DIA]ENDCCNDATO ) Then
      # Valeur invalide
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(83, 123, 1)
      Return
    Endif
    If ( [M:DIA]ENDCCNDAT <= [M:DIA]STRCCNDAT) Then
      # La date de fin doit être > à la date de début de la concession
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(253,7773,1)
      Return
    Endif
  Endif


Return
#=============================
$EXEC

  Local Integer LNBTOT
  Local Integer LNBTRT

  If ABANDON = G_OUI : Return : Endif

  If dim(G_REVREN)>0       : Kill G_REVREN     : Endif  : Global Char G_REVREN
  If dim(G_ENDCCNDATO)>0   : Kill G_ENDCCNDATO : Endif  : Global Char G_ENDCCNDATO
  If dim(G_ENDCCNDATN)>0   : Kill G_ENDCCNDATN : Endif  : Global Char G_ENDCCNDATN

  # Chargement de l'environnement global de la société
  If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif
  GSOCIETE=[M:DIA]CPY
  Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY

  # Récupération des plans du contexte Fiscal & comptable
  Local Integer TBPLN(1..G301MAX)
  Read [CNX]CNX0=[M:DIA]CPY; G300CPFI
  Local Integer I_PLN, LNBPLN
  LNBPLN = [F:CNX]NBPLC
  For I_PLN = 1 To LNBPLN
    TBPLN(I_PLN) = [F:CNX]PLNCAA(I_PLN-1)
  Next I_PLN

  # Ouverture de la trace
  If (ACTSILENCE <> G_OUI ) Then
    If !GSERVEUR : Call OUVRE_TRACE (mess(739,7773,1)) From LECFIC : Endif :   # "AVENANT A CONTRAT DE CONCESSION"
  Endif

  If ( ACTSILENCE = G_OUI ) Then
    # Auto correction pour traitement silencieux
    # En silence : Pas de trace détaillée pas de calcul
    [M:DIA]FLGDET    = G_NON
    [M:DIA]FLGCAL    = G_NON
  Endif

  Gosub ECR_PARM From TRTCCNREV

  # Exécution silencieuse : Création des variables globales : pour intercepter les erreurs dans le traitement.
  If ( ACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI
    # Contrat de contession sur lequel porte l'avenant
    If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
    If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
    Global Char    GT_OBJ_REF(20)(1) : GT_OBJ_REF (0) = [M:DIA]CCNREF
    Global Char    GT_OBJ_DES(20)(1) : GT_OBJ_DES (0) = [M:DIA]CCNDES1
  Endif

  # Verrouillage Contrat
  If ( func GLOBIENS.LOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF, 0) = 0 ) Then
      # "Le contrat de concession n'a pas pu être verrouillé"
    If (ACTSILENCE <> G_OUI) Then
      Call ECR_TRACE(mess(790,7773,1),1) From GESECRAN
     #If !GSERVEUR : Call LEC_TRACE() From LECFIC : Endif #fq62307
      If !GSERVEUR : Call FERME_TRACE() From LECFIC : TRA=1 : Endif
      Return
    Else
      ABANDON = G_OUI
      If dim(I_OBJ)>0        : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      Global Char    GT_LIS_ERR(100)(1)
      GT_LIS_ERR(I_OBJ) = mess(790,7773,1)
      G_MAJOK    = G_NON
      Return
    Endif
  Endif
  # Verrouillage Biens
  Local Integer LERR
  Call CCN_LOCK_FAS ([M:DIA]CCNREF, "", LERR) From GLOCCN
  If (LERR) Then
    # Déverrouillage Contrat
    Call UNLOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF) From GLOBIENS
    # "Les biens n'ont pas pu être verrouillés"
    If (ACTSILENCE <> G_OUI) Then
      Call ECR_TRACE(mess(728,7773,1),1) From GESECRAN
     #If !GSERVEUR : Call LEC_TRACE() From LECFIC : Endif #fq62307
      If !GSERVEUR : Call FERME_TRACE() From LECFIC : TRA=1 : Endif
      Return
    Else
      ABANDON = G_OUI
      If dim(I_OBJ)>0        : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      Global Char    GT_LIS_ERR(100)(1)
      GT_LIS_ERR(I_OBJ) = mess(728,7773,1)
      G_MAJOK    = G_NON
      Return
    Endif
  Endif

  #========================
  # Début Commitment control
  #========================
  If ( [M:DIA]FLGSIM <> G_OUI ) Then
    # Traitement en réel
    Local Integer BCMTEXT
    If ( ACTSILENCE = G_OUI ) Then
      # Traitement silencieux
      BCMTEXT = adxlog
    Else
      BCMTEXT = 0
    Endif
    If ( !BCMTEXT) Then
      Trbegin [CCN], [FAS], [DEP]
    Else
      # Si un commitment control a été initialisé on considère que c'est l'appelant qui le gère
    Endif
  Endif

  #=====================================
  # Mise à jour des biens de la concession
  #=====================================

  Gosub ECR_ENTETE From TRTCCNREV

  Filter [FAS] Where CCNREF = [M:DIA]CCNREF and OWNTYP = GVML_TDCONCE and( ISSDAT = [0/0/0] or ISSDAT >= GDEBEXECPF )
  LNBTOT = rowcount([FAS])
  Filter [FAS]

  #> Exécution interactive : jauge - barre de progression
  If ( !GSERVEUR and ACTSILENCE <> G_OUI ) Then
    Call OUVRE_BOITE(mess(739,7773,1),LNBTOT) From GESECRAN
    Call SET_BOITE(mess(739,7773,1),LNBTOT) From GESECRAN
  Endif

  # Exécution silencieuse : Création des variables globales
  #                         Dimensionnement selon le nombre de biens concernés
  If ( ACTSILENCE = G_OUI ) Then
    # Dimensionnement de G_LIS_ERR
    If ( LNBTOT > 0 ) Then
      If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      If dim(G_LIS_ERR)>0  : Kill G_LIS_ERR  : Endif
      Global Char    GT_LIS_ERR(100)(LNBTOT+10)
    Endif
  Endif

  #>>>>>>>>>>>>>>>>>>>>>>>>>>
  # FQ66599 For [FAS] Where CCNREF = [M:DIA]CCNREF and OWNTYP = GVML_TDCONCE and( ISSDAT = [0/0/0] or ISSDAT >= GDEBEXECPF )
  For [FAS] Where CCNREF = [M:DIA]CCNREF and OWNTYP = GVML_TDCONCE and ISSDAT = [0/0/0]

    NB_LUS +=1

    #> Exécution interactive : jauge - barre de progression
    If ( !GSERVEUR and ACTSILENCE <> G_OUI ) Then
      LNBTRT+=1
      Call AFF_BOITE([F:FAS]AASREF-+"("+num$(LNBTRT)+"/"+num$(LNBTOT)+")",LNBTRT,GOK) From GESECRAN
    Endif

    If ( G_CCNRPR = GVML_GCRNW ) Then
      Local Integer LRNWFLGO : LRNWFLGO = [F:FAS]RNWFLG
      # Détermination du flag OER
      Local Integer LRNWFLG
      Call CAL_DETERM_FLAG_OER ( "CCNREV",
&          [F:FAS]OWNTYP, G_CCNRPR, [F:FAS]OBYRNWCON, [F:FAS]TPAFLG, [M:DIA]ENDCCNDAT, [F:FAS]RNWDAT, LRNWFLG ) From GLOBB7
    Endif

    #-1 ---------------
    If ( [M:DIA]FLGSIM <> G_OUI ) Then

      Local Integer BMAJFAS : BMAJFAS = 0
      For I_PLN = 1 To LNBPLN
        # Lecture de la période courante d'un plan du contexte Fiscal & Comptable
        Read [DEP]DEP0=[F:FAS]AASREF; TBPLN(I_PLN); GFINEXECPF; GFINPERCPF
        If (fstat) Then
          GOK = 0
          If ( ACTSILENCE <> G_OUI ) Then
            # Erreur entrée/sortie --> Fichier :
            Call ECR_TRACE(mess(728,7773,1)-" DEPREC" - num$([F:FAS]AASREF),1) From GESECRAN
          Else
            ABANDON    = G_OUI
            G_MAJOK    = G_NON
            GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" DEPREC" - num$([F:FAS]AASREF)
            I_OBJ += 1
            Break  : # Une seule écriture par bien dans GT_LIS_ERR
          Endif
        Endif
        #  Mise à jour DEPSTA de la période courante du plan du bien ( Si mode "CA" ou "RA")
        If ( [F:DEP]DEPSTA <> GVML_SCNOCAL and ( [F:DEP]DPM = G_DPMCA or [F:DEP]DPM = G_DPMRA ) ) Then
          BMAJFAS = 1
          [F:DEP]DEPSTA = GVML_SCNOCAL
          Rewrite [DEP]
          If (fstat) Then
            GOK = 0
            If ( ACTSILENCE <> G_OUI ) Then
              Call ECR_TRACE(mess(728,7773,1)-" DEPREC" - num$([F:FAS]AASREF),1) From GESECRAN
            Else
              ABANDON    = G_OUI
              G_MAJOK    = G_NON
              GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" DEPREC" - num$([F:FAS]AASREF)
              I_OBJ += 1
              Break : # Une seule écriture par bien dans GT_LIS_ERR
            Endif
          Endif
        Endif
      Next I_PLN


      # Mise à jour du bien ( RNWFLG, FLGRPRCLC, FLGCNXCLC, FLGCLC )
      If ( G_CCNRPR = GVML_GCRNW and LRNWFLG <> LRNWFLGO ) Then
        [F:FAS]RNWFLG                 = LRNWFLG
        [F:FAS]FLGRPRCLC              = G_OUI
        BMAJFAS = 1
      Endif
      If ( BMAJFAS and !fstat ) Then
        [F:FAS]FLGCNXCLC(G300CPFI-1) = G_OUI
        [F:FAS]FLGCLC                = G_OUI
        Rewrite [FAS]
        If (fstat) Then
          NB_ERR +=1
          GOK = 0
          If ( ACTSILENCE <> G_OUI ) Then
            Call ECR_TRACE(mess(728,7773,1)-" FXDASSETS " - num$([F:FAS]AASREF),1) From GESECRAN
          Else
            ABANDON    = G_OUI
            G_MAJOK    = G_NON
            GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" FXDASSETS " - num$([F:FAS]AASREF)
            I_OBJ += 1
          Endif
        Else
          NB_MAJ +=1
        Endif
      Endif
    Endif
    #-1 ---------------

    # Ecriture trace
    Gosub ECR_LIGNE From TRTCCNREV
  Next
  #<<<<<<<<<<<<<<<<<<<<<<<<

  #> Exécution interactive : jauge - barre de progression
  If ( !GSERVEUR and ACTSILENCE <> G_OUI ) Then
    Call FERME_BOITE From GESECRAN
  Endif

  #=====================================
  # Mise à jour du contrat de concession
  #=====================================
  Read [F:CCN]CCN0=[M:DIA]CCNREF
  If (fstat) Then
    GOK = 0
    If ( ACTSILENCE <> G_OUI ) Then
      Call ECR_TRACE(mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF),1) From GESECRAN
    Else
      ABANDON  = G_OUI
      G_MAJOK  = G_NON
      GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF)
      I_OBJ += 1
    Endif
  Else
    If ( [M:DIA]FLGSIM <> G_OUI ) Then
      [F:CCN]ENDCCNDAT = [M:DIA]ENDCCNDAT
      Rewrite [CCN]
      If (fstat) Then
        GOK = 0
        If ( ACTSILENCE <> G_OUI ) Then
          Call ECR_TRACE(mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF),1) From GESECRAN
        Else
          ABANDON    = G_OUI
          G_MAJOK    = G_NON
          GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF)
          I_OBJ += 1
        Endif
      Endif
    Endif
  Endif

  #=====================================
  # Génération d'un événement CCNREV
  #=====================================
  Local Char    LCDINT :  LCDINT= "CCNREV"
  Local Integer LCDRET

  If ( [M:DIA]FLGSIM <> G_OUI ) Then
    G_REVREN     = [M:DIA]REVREN
    G_ENDCCNDATO = [M:DIA]ENDCCNDATO
    G_ENDCCNDATN = [M:DIA]ENDCCNDAT

    Call GENER_EVE ( GVML_OMCCN, [M:DIA]CPY, [M:DIA]FCY, [M:DIA]CCNREF, 0, LCDINT, date$, [0/0/0], LCDRET ) From GENEVE
    If (LCDRET > 20) Then
      GOK = 0
      If ( ACTSILENCE <> G_OUI ) Then
        Call ECR_TRACE(mess(104,7773,1)-" ECCNREV "  - num$([M:DIA]CCNREF),1) From GESECRAN
      Else
        ABANDON = G_OUI
        G_MAJOK    = G_NON
        GT_LIS_ERR(I_OBJ) = mess(104,7773,1)-" ECCNREV "  - num$([M:DIA]CCNREF)
        I_OBJ += 1
      Endif
    Endif
  Endif

  #========================
  # Fin Commitment control
  #========================
  If ( [M:DIA]FLGSIM <> G_OUI and !BCMTEXT ) Then
    # Si traitement en réel et commitment control à gérer
    If ( GOK ) Then
      Commit
    Else
      Rollback
    Endif
  Endif

  # Déverrouillage Contrat
  Call UNLOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF) From GLOBIENS
  # Déverrouillage Biens
  Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS

  # Ecriture statistiques
  Gosub ECR_STAT From TRTCCNREV

  #=====================================
  # Calcul des biens de la société
  #=====================================
  If ( GOK = 1 and [M:DIA]FLGSIM <> G_OUI and [M:DIA]FLGCAL = G_OUI and ACTSILENCE <> G_OUI ) Then
    # Si traitement en réel et pas en mode silencieux
    Local Integer TBCNX(1..GMAXCNXC)
    # Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
    Local Char    TBFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
    Local Decimal RERROR
    # Site à calculer
    TBFCY(1) = [M:DIA]FCY
    # Contexte à calculer
    TBCNX(1) = G300CPFI
    # Calcul FQ88613
    Global Integer G_CLCTRC : G_CLCTRC = 1   # 0 : pas de trace/1 : trace
    Gosub AVANT_CALCULER_SOCIETE From GLOBB0
    Call  CALCULER_SOCIETE([M:DIA]CPY, TBFCY, TBCNX, G_NON, RERROR) From GLOBB
    Gosub APRES_CALCULER_SOCIETE  From GLOBB0
  Endif

  # Fermeture de la trace
 #If !GSERVEUR and ACTSILENCE <> G_OUI : Call LEC_TRACE() From LECFIC : Endif
  If !GSERVEUR and ACTSILENCE <> G_OUI : Call FERME_TRACE() From LECFIC : TRA=1 : Endif

Return

#=============================
$TERMINE
  If dim(ABANDON)>0    : Kill ABANDON    : Endif
Return

#=============================
$SORTIE
  If dim(ACTSILENCE)>0     : Kill ACTSILENCE     : Endif
  If dim(TRTFILMSK)>0      : Kill TRTFILMSK      : Endif
Return


#=============================
$APRES_MODIF
Return

#=============================
$SETBOUT
  If ( [M:DIA]CCNREF = "" or [M:DIA]ENDCCNDAT = [0/0/0] or [M:DIA]ENDCCNDAT=[M:DIA]ENDCCNDATO ) Then
    Call VIREBOUT (CHBOU,"O") From GOBJET
  Endif

Return




######################################################################################
#    ECRAN   : CCNREV   [M:DIA]
######################################################################################

#=============================
Subprog AM_FLGSIM(VALEUR)
Variable Integer VALEUR

 If ( VALEUR = G_OUI ) Then
   # Par défaut traitement simulé => pas de calcul
   [M:DIA]FLGCAL = G_NON
   Affzo [M:DIA]FLGCAL
   Diszo [M:DIA]FLGCAL
 Else
   Actzo [M:DIA]FLGCAL
 Endif

End


#=============================
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 Read [F:FCY]FCY0=VALEUR
 If (!fstat) Then
   [M:DIA]CPY = [F:FCY]LEGCPY
 Else
   [M:DIA]CPY = ""
 Endif
 [M:DIA]CCNREF     = ""
 [M:DIA]CCNDES1    = ""
 [M:DIA]CCNDES2    = ""
 [M:DIA]STRCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDATO = [0/0/0]
 Affzo [M:DIA]CPY
 Affzo [M:DIA]ZCPY
 Affzo [M:DIA]CCNREF
 Affzo [M:DIA]CCNDES1
 Affzo [M:DIA]CCNDES2
 Affzo [M:DIA]STRCCNDAT
 Affzo [M:DIA]ENDCCNDAT

End


#=============================
Subprog AM_CCNUSR(VALEUR)
Variable Char    VALEUR()
 [M:DIA]CCNREF     = ""
 [M:DIA]CCNDES1    = ""
 [M:DIA]CCNDES2    = ""
 [M:DIA]STRCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDATO = [0/0/0]
 Affzo [M:DIA]CCNREF
 Affzo [M:DIA]CCNDES1
 Affzo [M:DIA]CCNDES2
 Affzo [M:DIA]STRCCNDAT
 Affzo [M:DIA]ENDCCNDAT

End

#=============================
Subprog AM_CCNREF(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
 Read [F:CCN]CCN0=VALEUR
 If (!fstat) Then
   If ( [F:CCN]CCNSTA <> GVML_CSACTI ) Then
     # Référence concession invalide
     GERR= 1: GMESSAGE = mess(271,7773,1)
     mkstat = 2 : End
   Endif
   [M:DIA]CPY        = [F:CCN]CPY
   [M:DIA]FCY        = [F:CCN]FCY
   [M:DIA]CCNDES1    = [F:CCN]CCNDES1
   [M:DIA]CCNDES2    = [F:CCN]CCNDES2
   [M:DIA]CCNUSR     = [F:CCN]CCNUSR
   [M:DIA]STRCCNDAT  = [F:CCN]STRCCNDAT
   [M:DIA]ENDCCNDAT  = [F:CCN]ENDCCNDAT
   [M:DIA]ENDCCNDATO = [F:CCN]ENDCCNDAT
    Affzo [M:DIA]CPY
    Affzo [M:DIA]ZCPY
    Affzo [M:DIA]FCY
    Affzo [M:DIA]ZFCY
    Affzo [M:DIA]CCNDES1
    Affzo [M:DIA]CCNDES2
    Affzo [M:DIA]CCNUSR
    Affzo [M:DIA]ZCCNUSR
    Affzo [M:DIA]STRCCNDAT
    Affzo [M:DIA]ENDCCNDAT
 Endif

End


#=============================
Subprog AM_ENDCCNDAT(VALEUR)
Variable Date    VALEUR()


  If ( VALEUR = [M:DIA]ENDCCNDATO) Then
    # Valeur incorrecte
    GERR= 1 : GMESSAGE= mess(83, 123, 1)
    mkstat = 2 : End
  Endif

  If ( VALEUR <= [M:DIA]STRCCNDAT) Then
    # La date de fin doit être > à la date de début de la concession
    GERR= 1 : GMESSAGE= mess(253,7773,1)
    mkstat = 2 : End
  Endif

  [M:DIA]ENDCCNDAT = VALEUR
End

######################################################################################


#======================
$GET_PARAMETRES

 #-> PARAM(1) - Mode silencieux oui / non
 #-> PARAM(2) - En silencieux : Traitement de remplissage du masque de saisie


 If ( PARAM(1)<>"" and PARAM(2)<>"" ) Then
   ACTSILENCE = val(PARAM(1))
   TRTFILMSK  = PARAM(2)
 Else
   ACTSILENCE = G_NON
   TRTFILMSK  = "....."
 Endif

Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
#==============================
$ECR_PARM

  Local Integer NB_LUS  : NB_LUS=0
  Local Integer NB_MAJ  : NB_MAJ=0
  Local Integer NB_ERR  : NB_ERR=0

  If ( ACTSILENCE = G_OUI      ) Then : Return : Endif

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Options"
  Call ECR_TRACE("", 0,mess(705,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Traitement simulé    :"
  Call ECR_TRACE("", 0,mess(706,7773,1)-mess([M:DIA]FLGSIM,1,1),0,1) From TRACEABX3
  # "Trace détaillée      :"
  Call ECR_TRACE("", 0,mess(707,7773,1)-mess([M:DIA]FLGDET,1,1),0,1) From TRACEABX3
  # "Calcul amortissement :"
  Call ECR_TRACE("", 0,mess(708,7773,1)-mess([M:DIA]FLGCAL,1,1),0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Critères de sélection"
  Call ECR_TRACE("", 0,mess(709,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Société              :"
  Call ECR_TRACE("", 0,mess(710,7773,1)-[M:DIA]CPY-[M:DIA]ZCPY,0,1) From TRACEABX3
  # "Site                 :"
  Call ECR_TRACE("", 0,mess(711,7773,1)-[M:DIA]FCY-[M:DIA]ZFCY,0,1) From TRACEABX3
  # "Concédant            :"
  Call ECR_TRACE("", 0,mess(712,7773,1)-[M:DIA]CCNUSR-[M:DIA]ZCCNUSR,0,1) From TRACEABX3
  # "Contrat concession   :"
  Call ECR_TRACE("", 0,mess(713,7773,1)-[M:DIA]CCNREF-[M:DIA]CCNDES1,0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Paramètres"
  Call ECR_TRACE("", 0,mess(714,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Date fin concession  :"
  Call ECR_TRACE("", 0,mess(715,7773,1)-format$("D:" + GFMDAT4,[M:DIA]ENDCCNDAT),0,1) From TRACEABX3
  # "Motif                :"
  Call ECR_TRACE("", 0,mess(716,7773,1)-[M:DIA]REVREN,0,1) From TRACEABX3

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTECRPARM              E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  GOK = 1
  GPOINT = "AFTECRPARM"
  Gosub ENTREE From EXEFNC
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

Return

#===============================
$ECR_ENTETE
Local    Char    LINE(115)

  If ( [M:DIA]FLGDET <> G_OUI ) Then : Return : Endif
  If ( ACTSILENCE = G_OUI     ) Then : Return : Endif

  # Entête

  LINE = ""
  Call ECR_TRACE("", 0, LINE, 0,1)                  From TRACEABX3
  # "Trace détaillée"
  Call ECR_TRACE("", 0,mess(717,7773,1),0,1)       From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "PRISE EN COMPTE DE LA NOUVELLE DATE DE FIN DE CONCESSION SUR LES BIENS"
  LINE = mess(718,7773,1)
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  LINE = ""
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  LINE = string$(115,"*")
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  # "Réf. Bien"
  LINE =      left$( mess(719,7773,1)  + string$(20,' '), 20)+"!"
  # "Désignation"
  LINE +=     left$( mess(720,7773,1)  + string$(55,' '), 55)+"!"

  If ( G_CCNRPR = GVML_GCFIR ) Then
    # "Obligation effective de renouvellement"
    LINE +=     left$( mess(721,7773,1)  + string$(40,' '), 40)+'!'
    Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
    LINE =      left$( ""               + string$(20,' '), 20)+"!"
    LINE +=     left$( ""               + string$(55,' '), 55)+"!"
    LINE +=     left$( ""               + string$( 5,' '),  5)
    # "Avant"
    LINE +=     left$( mess(722,7773,1)  + string$(15,' '), 15)+'!'
    LINE +=     left$( ""               + string$( 5,' '),  5)
    # "Après"
    LINE +=     left$( mess(723,7773,1)          + string$(15,' '), 15)+'!'
  Endif

  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  LINE = string$(115,"*")
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

#===============================
$ECR_LIGNE
Local    Char    LINE(115)

  If ( [M:DIA]FLGDET <> G_OUI ) Then : Return : Endif
  If ( ACTSILENCE = G_OUI     ) Then : Return : Endif

  LINE =  left$( [F:FAS]AASREF                          + string$(20,' '), 20)+"!"
  LINE += left$( [F:FAS]AASDES1                         + string$(55,' '), 55)+"!"

  If ( G_CCNRPR = GVML_GCFIR ) Then
    LINE +=     left$( ""               + string$( 6,' '),  6)
    LINE += left$( mess(LRNWFLGO,1,1)                     + string$(14,' '), 14)+'!'
    LINE +=     left$( ""               + string$( 6,' '),  6)
    LINE += left$( mess(LRNWFLG,1,1)                + string$(14,' '), 14)+'!'
  Endif

  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

#==============================
$ECR_STAT

  If ACTSILENCE=G_OUI : Return : Endif

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Statistiques"
  Call ECR_TRACE("", 0,mess(724,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Biens"
  Call ECR_TRACE("", 0,mess(725,7773,1),0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
  # "Sélectionnés     Mis à jour      En erreur"
  Call ECR_TRACE("", 0,mess(726,7773,1),0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
  LINE  = left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_LUS)                         + string$(10,' '), 10)+"!"
  LINE += left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_MAJ)                         + string$(10,' '), 10)+"!"
  LINE += left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_ERR)                         + string$(10,' '), 10)
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

