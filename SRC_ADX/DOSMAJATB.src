#<AdxTL>@(#)10.0.0.0 $Revision$
#######################################################################
# Mise à jour de la structure des tables
#######################################################################

$DOSMAJATB

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Update Tables",0) From GESECRAN

NBSPE = 0
NBSPE += 1 : TABSPE(NBSPE) = "ATYPE"
NBSPE += 1 : TABSPE(NBSPE) = "ACTIV"
NBSPE += 1 : TABSPE(NBSPE) = "ATEXTE"
NBSPE += 1 : TABSPE(NBSPE) = "ATABLE"
NBSPE += 1 : TABSPE(NBSPE) = "ATABIND"
NBSPE += 1 : TABSPE(NBSPE) = "ATABZON"
NBSPE += 1 : TABSPE(NBSPE) = "AMSKPAR"
NBSPE += 1 : TABSPE(NBSPE) = "AINDEX"

Gosub OUVTAB
OUVFIC = 1

For I=3 To NBSPE
 OBJET = TABSPE(I) : Gosub COPIE
Next I

Gosub OUVFIC
OUVFIC = 0

#For [SAT2]CODFIC Where find(TYPFIC,1,2,4)<>0 & CODFIC<GXX : # On ne touche pas aux tables systèmes
For [SAT2]CODFIC Where find(TYPFIC,1,2,4)<>0 & CODACT<>"MIG" & CODFIC<GXX : # On ne touche pas aux tables systèmes
 OBJET = [F:SAT2]CODFIC
 Call OKCOP([F:SAT2]MODULE,[F:SAT2]CODACT,OKCOP) From DOSMAJSUB
 If find(OBJET,TABSPE(1..NBSPE))
  OKCOP = 0
 Endif
 If OKCOP
  Gosub DIFF
 Endif
 If OKCOP
  Gosub COPIE
 Endif
Next SAT2

# Suppression des tables inexistantes dans le dico du dossier migré
Call PURGE_TABLES(APPLI)

# valdiation trigger si lmodif sur AUDITH ou AUDITBI
Local Integer OKTRIG
Read [ATB]CODFIC="AUDITH"
If !fstat and [F:ATB]UPDFLG=1
 OKTRIG = 1
Endif
If !OKTRIG
 Read [ATB]CODFIC="AUDITBI"
 If !fstat and [F:ATB]UPDFLG=1
  OKTRIG = 1
 Endif
Endif
If OKTRIG = 1
 Call TRIGGER_ALL From DOSTAB
Endif

# Raz de la table AREFTXT
Call RAZ_TABLE(APPLI,"AREFTXT")

Gosub FERFIC
Gosub FERTAB

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN

Return

#######################################################################
$DOSMAJATBHIS
Local Integer DOSMAJATBHIS : DOSMAJATBHIS=1
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Update Tables",0) From GESECRAN

NBSPE = 0
NBSPE += 1 : TABSPE(NBSPE) = "ATYPE"
NBSPE += 1 : TABSPE(NBSPE) = "ACTIV"
NBSPE += 1 : TABSPE(NBSPE) = "ATEXTE"
NBSPE += 1 : TABSPE(NBSPE) = "ATABLE"
NBSPE += 1 : TABSPE(NBSPE) = "ATABIND"
NBSPE += 1 : TABSPE(NBSPE) = "ATABZON"
NBSPE += 1 : TABSPE(NBSPE) = "AMSKPAR"
NBSPE += 1 : TABSPE(NBSPE) = "AINDEX"

Gosub OUVTAB
OUVFIC = 1

For I=4 To 6
 OBJET = TABSPE(I) : Gosub COPIEHIS
Next I

Gosub OUVFIC0
OUVFIC = 0

#For [SAT2]CODFIC Where find(TYPFIC,1,2,4)<>0 & CODFIC<GXX : # On ne touche pas aux tables systèmes
For [SAT2]CODFIC Where find(TYPFIC,1,2,4)<>0 & CODACT<>"MIG" & CODFIC<GXX : # On ne touche pas aux tables systèmes
 OBJET = [F:SAT2]CODFIC
 Call OKCOP([F:SAT2]MODULE,[F:SAT2]CODACT,OKCOP) From DOSMAJSUB
 If find(OBJET,TABSPE(1..NBSPE))
  OKCOP = 0
 Endif
 If OKCOP
  Gosub DIFF
 Endif
 If OKCOP
  Gosub COPIEHIS
 Endif
Next SAT2

# Suppression des tables inexistantes dans le dico du dossier migré

Call PURGE_TABLES(APPLI)

# Raz de la table AREFTXT
#Call RAZ_TABLE(APPLI,"AREFTXT")

Gosub FERFIC0
Gosub FERTAB

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN

Return
####################################################################
Subprog PURGE_TABLES(DOSSIER)
Value Char DOSSIER
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , COMMAND(250) , SUF(10)
Local Char    TABLE(30)(3000) , HISAPL(GLONADS) , FICHIER(GDIMFIC)
Local Integer I , NBTAB , STAT , OUVATB , OUVAVW , OUVADW
#If clalev([F:ATB])=0 : OUVATB = 1 : Local File =DOSSIER+".ATABLE" [ATB] : Endif
#If clalev([F:AVW])=0 : OUVAVW = 1 : Local File =DOSSIER+".AVIEW"  [AVW] : Endif
#If clalev([F:ADW])=0 : OUVADW = 1 : Local File =DOSSIER+".ADOVAL" [ADW] : Endif
Local File =DOSSIER+".ATABLE" [ATB]
Local File =DOSSIER+".AVIEW"  [AVW]
Local File =DOSSIER+".ADOVAL" [ADW]
Call ECR_TRACE("Delete old files"-time$,0) From GESECRAN
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
#107271 on ne cherche pas dossier histo sur dossier histo
If func DOSSUB.ISHISTFOLD(DOSSIER)=0
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat
  HISAPL = [F:ADW]VALEUR
 Endif
Endif
Call SYSTEME2(MACHINE,"lsadx -a "+APPLI+" FIL fde","",NBTAB,TABLE) From ORDSYS
For I=0 To NBTAB
 If len(TABLE(I))>GLONATB
  Call ECR_TRACE(TABLE(I)-":"-mess(35,126,1),-1) From GESECRAN : # Nom de fichier incorrect
 Elsif TABLE(I)<>""
  Look [ATB]CODFIC=TABLE(I)
  If fstat
   Look [AVW]AVW0=TABLE(I)
   If fstat
    Call ECR_TRACE(TABLE(I)-" : file deleted on"-APPLI,0) From GESECRAN
    System COMMAND=MACHINE+'@valfil -n'-APPLI-TABLE(I)
    System COMMAND=MACHINE+'@valfil -d'-APPLI-TABLE(I)
    For SUF = "srf", "fde", "dat", "idx" , "cfg" , "viw"
     FICHIER = filpath("FIL",TABLE(I),SUF,APPLI,"",MACHINE)
     If filinfo(FICHIER,0)>=0
      Call EFFACE(FICHIER,STAT) From ORDSYS
     Endif
    Next SUF
    #107271 uniquement pour GEODE
    If HISAPL<>"" GPRODUIT=1 & filinfo(filpath("FIL",TABLE(I),"fde",HISAPL,"",MACHINE),0)>0
     System COMMAND=MACHINE+'@valfil -n'-HISAPL-TABLE(I)
     System COMMAND=MACHINE+'@valfil -d'-HISAPL-TABLE(I)
     For SUF = "srf", "fde", "dat", "idx" , "cfg" , "viw"
      FICHIER = filpath("FIL",TABLE(I),SUF,HISAPL,"",MACHINE)
      If filinfo(FICHIER,0)>=0
       Call EFFACE(FICHIER,STAT) From ORDSYS
      Endif
     Next SUF
    Endif
   Endif
  Endif
 Endif
Next I
#If OUVATB : Close Local File [ATB] : Endif
#If OUVAVW : Close Local File [AVW] : Endif
#If OUVADW : Close Local File [ADW] : Endif
Close Local File
End

####################################################################
Subprog RAZ_TABLE(DOSSIER,TABLE)
Value Char DOSSIER , TABLE
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , COMMAND(250)
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0
 Call ECR_TRACE("Purge"-TABLE-"files"-time$,0) From GESECRAN
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
 System COMMAND=MACHINE+'@valfil -z'-APPLI-TABLE
Endif
End

####################################################################
$OUVTAB
Local File =[F:ADS]DOSREF+".ATABLE"  [SATB]
Local File =[F:ADS]DOSREF+".ATABLE"  [SAT2]
Local File =[F:ADS]DOSREF+".ATABZON" [SATZ]
Local File =[F:ADS]DOSREF+".ATABIND" [SATI]
Local File =[F:ADS]DOSREF+".AMSKPAR" [SAMP]
Local File =[F:ADS]DOSREF+".ATEXTE"  [SATX]
Local File =[F:ADS]DOSREF+".ACTIV"   [SACV]
Local File =[F:ADS]DOSREF+".ATYPE"   [SATY]
Local File =[F:ADS]DOSREF+".AINDEX"  [SANX]
Return

$FERTAB
Close Local File [SATB] , [SAT2] , [SATZ] , [SATI] , [SAMP] , [SATX] , [SACV] , [SATY] , [SANX]
Return

####################################################################
$OUVFIC0
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABLE"   [AT2]
Local File =APPLI+".ATABZON"  [ATZ]
Local File =APPLI+".ATABIND"  [ATI]
Local File =APPLI+".AINDEX"   [ANX]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ACTIV"    [ACV]
Return
$OUVFIC
Gosub OUVFIC0
If dim([L]DOSMAJATBHIS)<0 | [L]DOSMAJATBHIS=0
Local File ADOSSIER           [ADS]
Read [ADS]DOSSIER = APPLI
Endif
Return

$FERFIC0
Close Local File [ATB] , [AT2] , [ATZ] , [ATI] , [ANX] , [AMP] , [ATY] , [ATX] , [ACV]
Return
$FERFIC
Gosub FERFIC0
If dim([L]DOSMAJATBHIS)<0 | [L]DOSMAJATBHIS=0
Close Local File [ADS]
Endif
Return

####################################################################
$COPIEHIS
If OUVFIC : Gosub OUVFIC0 : Endif
Local Integer RAZTAB
Call DEBTRANS From GLOCK
If func DOSVUE.ISVIEW(APPLI,OBJET)
 Gosub TR0H
 Call MAJTAB(OBJET,0) From DOSTAB
Else
 Gosub TR1H
 If GOK=1 and find([F:ATB]TYPFIC,1,2,4) : # Applicatif/Superviseur/Dictionnaire
  Call MAJTAB(OBJET,0) From DOSTAB
 Endif
Endif
If OUVFIC : Gosub FERFIC0 : Endif
Return

####################################################################
$COPIE
If OUVFIC : Gosub OUVFIC : Endif
Local Integer RAZTAB
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1 and find([F:ATB]TYPFIC,1,2,4) : # Applicatif/Superviseur/Dictionnaire
 Call MAJTAB(OBJET,0) From DOSTAB
Endif
If OUVFIC : Gosub FERFIC : Endif
Return

####################
$TR1
Raz [F:AT2] :#116968
GOK = 1
Trbegin [ATB]

 EXISTE = 0
 Read [SATB]CODFIC = OBJET
 Read [ATB]CODFIC  = OBJET
 If !fstat & [F:ATB]CODACT<>"" & find([F:ATB]CODACT,TABACTS(1..NBACTS)) : # mb 11.2.9 bug 52491
  Call ECR_TRACE("*** Protected Table"-OBJET,0) From GESECRAN
 Else
  If !fstat
   Call ECR_TRACE("*** Update Table"-OBJET,0) From GESECRAN
   EXISTE = 1
   [F:AT2] = [F:ATB]
   Gosub TETE
   [F:ATB]NBENREG = [F:AT2]NBENREG
   Rewrite [ATB]
   If fstat
    GOK = 0 : Call FSTA("ATB") From GLOCK : Goto AB_TR1
   Endif
  Else
   Call ECR_TRACE("*** Create table"-OBJET,0) From GESECRAN
   Gosub TETE
   Write [ATB]
   If fstat
    GOK = 0 : Call FSTA("ATB") From GLOCK : Goto AB_TR1
   Endif
  Endif

  RAZTAB = 0
  While 1=1
   For [SATZ]NUMLIG Where CODFIC=OBJET
    OKCOP = 1
    If dim(VERCUR)>0 & [F:SATZ]CODFIC="AMSK"
     If find(VERCUR,140,150) & left$([F:SATZ]CODZONE,4)="BLOC" : # Pour éviter d'avoir trop de champs
      OKCOP = 0
     Endif
    Endif
    If OKCOP
     OK = 0
     Read [ATZ]CODZONE = OBJET;[F:SATZ]CODZONE
     If fstat
      Raz [F:ATZ]
      OK = 1
      If DETAIL : Call ECR_TRACE("Create field"-[F:SATZ]CODZONE,0) From GESECRAN : Endif
      Gosub LIGNE
      Write [ATZ]
     Elsif !find([F:ATZ]CODACT,TABACTS(1..NBACTS))
      OK = 0
      If [F:SATZ]CODACT   <>  [F:ATZ]CODACT    : OK = 1 : Endif
      If [F:SATZ]CODTYP   <>  [F:ATZ]CODTYP    : OK = 1 : Endif
      If [F:SATZ]DIME     <>  [F:ATZ]DIME      : OK = 1 : Endif
      If [F:SATZ]LONG     <>  [F:ATZ]LONG      : OK = 1 : Endif
      If [F:SATZ]NOLIB    <>  [F:ATZ]NOLIB     : OK = 1 : Endif
      If [F:SATZ]NUMLIG   <>  [F:ATZ]NUMLIG    : OK = 1 : Endif
      If OK
       If DETAIL : Call ECR_TRACE("Update field"-[F:SATZ]CODZONE,0) From GESECRAN : Endif
       Gosub LIGNE
       Rewrite [ATZ]
      Endif
     Endif
     If OK
      If fstat
       GOK = 0 : Call FSTA("ATZ") From GLOCK : Break 2
      Endif
      Delete [AMP] Where TYPAFF=2 & CODAFF=OBJET & CODZON=[F:ATZ]CODZONE
      If fstat=1
       GOK = -1 : GLOCK = "AMSKPAR"-OBJET-[F:ATZ]CODZONE : Break 2
      Endif
      For [SAMP]CODPAR Where TYPAFF=2 & CODAFF=OBJET & CODZON=[F:ATZ]CODZONE
       [F:AMP] = [F:SAMP]
       Write [AMP]
       If fstat
        GOK = 0 : Call FSTA("AMP") From GLOCK : Break 3
       Endif
      Next SAMP
     Endif
    Endif
   Next SATZ
   NBFLD = 0
   For [ATZ] Where CODFIC=OBJET
    If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0
     [L]DIME = [F:ATZ]DIME
     If [F:ATZ]CODACT<>""
      Read [ACV]CODACT = [F:ATZ]CODACT
      If !fstat & ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
       [L]DIME = max([F:ACV]DIMFIL,[F:ACV]DIME)
      Endif
      [L]DIME = max([L]DIME,1)
     Endif
     NBFLD += [L]DIME
    Endif
   Next ATZ
   If NBFLD<=512 : Break : Endif : # C'est bon
   If RAZTAB
    Call ECR_TRACE(OBJET-": Too many fields ("+num$(NBFLD)+")\File not updated",1) From GESECRAN
    GOK = 0 : Break : # C'est sans espoir
   Endif
   Call ECR_TRACE(OBJET-": Too many fields ("+num$(NBFLD)+")\Previous fields deleted",-1) From GESECRAN
   Delete [ATZ] Where CODFIC=OBJET
   If fstat=1
    GOK = -1 : GLOCK = "ATABZON"-OBJET : Break
   Endif
   Delete [AMP] Where TYPAFF=2 & CODAFF=OBJET
   If fstat=1
    GOK = -1 : GLOCK = "AMSKPAR"-OBJET : Break
   Endif
   RAZTAB = 1
  Wend
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  If EXISTE
   For [ATI]CODIND Where CODFIC=OBJET
    Read [SATI]CODIND = OBJET;[F:ATI]CODIND
    If fstat
     OK = 1
    Else
     OK = 0
     If [F:SATI]DESCRIPT  <>  [F:ATI]DESCRIPT  : OK = 1 : Endif
     If [F:SATI]HOMONYM   <>  [F:ATI]HOMONYM   : OK = 1 : Endif
    Endif
    If OK
     If DETAIL : Call ECR_TRACE("Update index"-[F:SATI]CODIND,0) From GESECRAN : Endif
    Endif
    Call VERF_INDEX(OBJET,[F:ATI]DESCRIPT,OK)
    If !OK
     If DETAIL : Call ECR_TRACE("Delete index"-[F:ATI]CODIND,0) From GESECRAN : Endif
     Delete [ATI]
     If fstat
      GOK = 0 : Call FSTA("ATI") From GLOCK : Break
     Endif
    Else
     [F:ATI]HOMONYM = 2
     If DETAIL : Call ECR_TRACE("Homonymous index"-[F:SATI]CODIND,0) From GESECRAN : Endif
     Rewrite [ATI]
     If fstat
      GOK = 0 : Call FSTA("ATI") From GLOCK : Break
     Endif
    Endif
   Next ATI
  Else
   For [SATI]CODIND Where CODFIC=OBJET
    If DETAIL : Call ECR_TRACE("Create index"-[F:SATI]CODIND,0) From GESECRAN : Endif
    [F:ATI] = [F:SATI]
    Write [ATI]
    If fstat
     GOK = 0 : Call FSTA("ATI") From GLOCK : Break
    Endif
   Next SATI
  Endif
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  Call DESACTIVE_INDEX(OBJET)
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif

Commit
Return

####################
$TR1H
Raz [F:AT2] :#116968
GOK = 1
Trbegin [ATB]

 EXISTE = 0
 Read [SATB]CODFIC = OBJET
 Read [ATB]CODFIC  = OBJET
 If !fstat & [F:ATB]CODACT<>"" & find([F:ATB]CODACT,TABACTS(1..NBACTS)) : # mb 11.2.9 bug 52491
  Call ECR_TRACE("*** Protected Table"-OBJET,0) From GESECRAN
 Else
  If !fstat
   Call ECR_TRACE("*** Update Table"-OBJET,0) From GESECRAN
   EXISTE = 1
   [F:AT2] = [F:ATB]
   Gosub TETE
   [F:ATB]NBENREG = [F:AT2]NBENREG
   Rewrite [ATB]
   If fstat
    GOK = 0 : Call FSTA("ATB") From GLOCK : Goto AB_TR1
   Endif
  Else
   Call ECR_TRACE("*** Create table"-OBJET,0) From GESECRAN
   Gosub TETE
   Write [ATB]
   If fstat
    GOK = 0 : Call FSTA("ATB") From GLOCK : Goto AB_TR1
   Endif
  Endif

  RAZTAB = 0
  While 1=1
   For [SATZ]NUMLIG Where CODFIC=OBJET
    OKCOP = 1
    If dim(VERCUR)>0 & [F:SATZ]CODFIC="AMSK"
     If find(VERCUR,140,150) & left$([F:SATZ]CODZONE,4)="BLOC" : # Pour éviter d'avoir trop de champs
      OKCOP = 0
     Endif
    Endif
    If OKCOP
     OK = 0
     Read [ATZ]CODZONE = OBJET;[F:SATZ]CODZONE
     If fstat
      Raz [F:ATZ]
      OK = 1
      If DETAIL : Call ECR_TRACE("Create field"-[F:SATZ]CODZONE,0) From GESECRAN : Endif
      Gosub LIGNE
      Write [ATZ]
     Elsif !find([F:ATZ]CODACT,TABACTS(1..NBACTS))
      OK = 0
      If [F:SATZ]CODACT   <>  [F:ATZ]CODACT    : OK = 1 : Endif
      If [F:SATZ]CODTYP   <>  [F:ATZ]CODTYP    : OK = 1 : Endif
      If [F:SATZ]DIME     <>  [F:ATZ]DIME      : OK = 1 : Endif
      If [F:SATZ]LONG     <>  [F:ATZ]LONG      : OK = 1 : Endif
      If [F:SATZ]NOLIB    <>  [F:ATZ]NOLIB     : OK = 1 : Endif
      If [F:SATZ]NUMLIG   <>  [F:ATZ]NUMLIG    : OK = 1 : Endif
      If OK
       If DETAIL : Call ECR_TRACE("Update field"-[F:SATZ]CODZONE,0) From GESECRAN : Endif
       Gosub LIGNE
       Rewrite [ATZ]
      Endif
     Endif
     If OK
      If fstat
       GOK = 0 : Call FSTA("ATZ") From GLOCK : Break 2
      Endif
     Endif
    Endif
   Next SATZ
   NBFLD = 0
   For [ATZ] Where CODFIC=OBJET
    If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0
     [L]DIME = [F:ATZ]DIME
     If [F:ATZ]CODACT<>""
      Read [ACV]CODACT = [F:ATZ]CODACT
      If !fstat & ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
       [L]DIME = max([F:ACV]DIMFIL,[F:ACV]DIME)
      Endif
      [L]DIME = max([L]DIME,1)
     Endif
     NBFLD += [L]DIME
    Endif
   Next ATZ
   If NBFLD<=512 : Break : Endif : # C'est bon
   If RAZTAB
    Call ECR_TRACE(OBJET-": Too many fields ("+num$(NBFLD)+")\File not updated",1) From GESECRAN
    GOK = 0 : Break : # C'est sans espoir
   Endif
   Call ECR_TRACE(OBJET-": Too many fields ("+num$(NBFLD)+")\Previous fields deleted",-1) From GESECRAN
   Delete [ATZ] Where CODFIC=OBJET
   If fstat=1
    GOK = -1 : GLOCK = "ATABZON"-OBJET : Break
   Endif
   RAZTAB = 1
  Wend
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  If EXISTE
   For [ATI]CODIND Where CODFIC=OBJET
    Read [SATI]CODIND = OBJET;[F:ATI]CODIND
    If fstat
     OK = 1
    Else
     OK = 0
     If [F:SATI]DESCRIPT  <>  [F:ATI]DESCRIPT  : OK = 1 : Endif
     If [F:SATI]HOMONYM   <>  [F:ATI]HOMONYM   : OK = 1 : Endif
    Endif
    If OK
     If DETAIL : Call ECR_TRACE("Update index"-[F:SATI]CODIND,0) From GESECRAN : Endif
    Endif
    Call VERF_INDEX(OBJET,[F:ATI]DESCRIPT,OK)
    If !OK
     If DETAIL : Call ECR_TRACE("Delete index"-[F:ATI]CODIND,0) From GESECRAN : Endif
     Delete [ATI]
     If fstat
      GOK = 0 : Call FSTA("ATI") From GLOCK : Break
     Endif
    Else
     [F:ATI]HOMONYM = 2
     If DETAIL : Call ECR_TRACE("Homonymous index"-[F:SATI]CODIND,0) From GESECRAN : Endif
     Rewrite [ATI]
     If fstat
      GOK = 0 : Call FSTA("ATI") From GLOCK : Break
     Endif
    Endif
   Next ATI
  Else
   For [SATI]CODIND Where CODFIC=OBJET
    If DETAIL : Call ECR_TRACE("Create index"-[F:SATI]CODIND,0) From GESECRAN : Endif
    [F:ATI] = [F:SATI]
    Write [ATI]
    If fstat
     GOK = 0 : Call FSTA("ATI") From GLOCK : Break
    Endif
   Next SATI
  Endif
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif

Commit
Return

