$TR0H
GOK = 1
Trbegin [ATB]
Delete [ATB] Where CODFIC=OBJET
Delete [ATZ] Where CODFIC=OBJET
Delete [ATI] Where CODFIC=OBJET
Commit
Gosub TR1H
Return
######################
$TETE
#116968
Local Integer AUD1 , AUD2 , AUD3 , AUD4 , AUD5 , AUD6
Local Char    AUDC(GLONANX)
If dim([F:AT2]AUDCRE)>0 : AUD1 = [F:AT2]AUDCRE : Endif
If dim([F:AT2]AUDUPD)>0 : AUD2 = [F:AT2]AUDUPD : Endif
If dim([F:AT2]AUDDEL)>0 : AUD3 = [F:AT2]AUDDEL : Endif
If dim([F:AT2]AUDWRK)>0 : AUD4 = [F:AT2]AUDWRK : Endif
If dim([F:AT2]AUDBI)>0  : AUD5 = [F:AT2]AUDBI  : Endif
If dim([F:AT2]AUDSDA)>0 : AUD6 = [F:AT2]AUDSDA : Endif
If dim([F:AT2]ASDCLE)>0 : AUDC = [F:AT2]ASDCLE : Endif

[F:ATB] = [F:SATB]
[F:ATB]UPDFLG = 1
[F:ATB]UPDDAT = date$
[F:ATB]UPDUSR = GUSER
If dim([F:ATB]UPDTIM)>0 : [F:ATB]UPDTIM = time : Endif

#116968
If dim([F:ATB]AUDCRE)>0 : [F:ATB]AUDCRE = max(1,AUD1) : Endif
If dim([F:ATB]AUDUPD)>0 : [F:ATB]AUDUPD = max(1,AUD2) : Endif
If dim([F:ATB]AUDDEL)>0 : [F:ATB]AUDDEL = max(1,AUD3) : Endif
If dim([F:ATB]AUDWRK)>0 : [F:ATB]AUDWRK = max(1,AUD4) : Endif
If dim([F:ATB]AUDBI)>0  : [F:ATB]AUDBI  = max(1,AUD5) : Endif
If dim([F:ATB]AUDSDA)>0 : [F:ATB]AUDSDA = max(1,AUD6) : Endif
If dim([F:ATB]ASDCLE)>0 : [F:ATB]ASDCLE = AUDC        : Endif

Call ACTIV([F:ATB]CODACT) From DOSMAJSUB
If func DOSSUB.ISHISTFOLD(APPLI)=0 : #111054
 Call TEXTE([F:ATB]INTITFIC) From DOSMAJSUB
Endif
Return

$LIGNE
[L]DIME = [F:ATZ]DIME
[F:ATZ] = [F:SATZ]
[F:ATZ]DIME = max([L]DIME,[F:ATZ]DIME) : # mb 4.2.8
Call ACTIV([F:ATZ]CODACT) From DOSMAJSUB
Read [ATY]CODTYP = [F:ATZ]CODTYP
If fstat
 Read [SATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  Case [F:SATY]TYPTYP
   When 1,2
    [F:ATZ]CODTYP = "C"
    [F:ATZ]LONG = 4
   When 2,3,4,5,6
    [F:ATZ]CODTYP = "DCB"
    [F:ATZ]LONG = 19.8
   When 8
    [F:ATZ]CODTYP = "D"
    [F:ATZ]LONG = 0
   When 9
    [F:ATZ]CODTYP = "ABB"
    [F:ATZ]LONG = 0
   When 10
    [F:ATZ]CODTYP = "ACB"
    [F:ATZ]LONG = 0
   When 11
    [F:ATZ]CODTYP = "AUUID"
    [F:ATZ]LONG = 0
   When 12
    [F:ATZ]CODTYP = "ADATIM"
    [F:ATZ]LONG = 0
   When Default
    [F:ATZ]CODTYP = "A"
    [F:ATZ]LONG = 10
  Endcase
 Else
  [F:ATZ]CODTYP = "A"
  [F:ATZ]LONG = 1
 Endif
Endif
If func DOSSUB.ISHISTFOLD(APPLI)=0 : #111054
 Call TEXTE([F:ATZ]NOABREG) From DOSMAJSUB
 Call TEXTE([F:ATZ]NOCOURT) From DOSMAJSUB
 Call TEXTE([F:ATZ]NOLONG) From DOSMAJSUB
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$DIFF
OKCOP = 0
Read [SATB]CODFIC  = OBJET
Read [ATB]CODFIC  = OBJET
If fstat
 OKCOP = 1 : Return
Endif
OK = 0
If [F:SATB]ABRFIC <> [F:ATB]ABRFIC : OK = 1 : Endif
If [F:SATB]CODACT <> [F:ATB]CODACT : OK = 1 : Endif
If [F:SATB]MODULE <> [F:ATB]MODULE : OK = 1 : Endif
If [F:SATB]INTIT  <> [F:ATB]INTIT  : OK = 1 : Endif
If [F:SATB]INTITC <> [F:ATB]INTITC : OK = 1 : Endif
If OK
 OKCOP = 1 : Return
Endif
For [SATZ]NUMLIG Where CODFIC=OBJET
 Call OKCOP([F:SATB]MODULE,[F:SATZ]CODACT,OK) From DOSMAJSUB
 If OK
  Read [ATZ]CODZONE = OBJET;[F:SATZ]CODZONE
  If fstat
   OKCOP = 1 : Break
  Elsif !find([F:ATZ]CODACT,TABACTS(1..NBACTS))
   OK = 0
   If [F:SATZ]CODACT <> [F:ATZ]CODACT : OK = 1 : Endif
   If [F:SATZ]CODTYP <> [F:ATZ]CODTYP : OK = 1 : Endif
   If [F:SATZ]DIME   <> [F:ATZ]DIME   : OK = 1 : Endif
   If [F:SATZ]LONG   <> [F:ATZ]LONG   : OK = 1 : Endif
   If [F:SATZ]NOLIB  <> [F:ATZ]NOLIB  : OK = 1 : Endif
   If [F:SATZ]NUMLIG <> [F:ATZ]NUMLIG : OK = 1 : Endif
   If OK
    OKCOP = 1 : Break
   Endif
  Endif
 Endif
Next SATZ
If OKCOP : Return : Endif
For [SATI]CODIND Where CODFIC=OBJET
 Read [ATI]CODIND = OBJET;[F:ATI]CODIND
 If !fstat
  OK = 0
  If [F:SATI]DESCRIPT <> [F:ATI]DESCRIPT : OK = 1 : Endif
  If [F:SATI]HOMONYM  <> [F:ATI]HOMONYM  : OK = 1 : Endif
  If OK
   OKCOP = 1 : Break
  Endif
 Endif
Next SATI
Return

Subprog DESACTIVE_INDEX(OBJET)
Value Char OBJET
Local Integer OK
For [ANX] Where TABLE=OBJET & FLACT=2
 OK = 1
 For [ATI] Where CODFIC=OBJET
  If [F:ANX]DESCRIPT=[F:ATI]DESCRIPT
   OK = 0 : Break
  Endif
 Next ATI
 If OK
  Call VERF_INDEX(OBJET,[F:ANX]DESCRIPT,OK)
 Endif
 If !OK
  [F:ANX]FLACT=1
  Rewrite [ANX]
  If fstat
   GOK = 0 : Call FSTA("ANX") From GLOCK : Break 2
  Endif
  Call ECR_TRACE([F:ANX]CODIND-mess(166,139,1),-1) From GESECRAN : # Index optimisation désactivé
 Endif
Next ANX
End

Subprog VERF_INDEX(TABLE,INDEX,OK)
Value Char TABLE , INDEX
Variable Integer OK
Local Integer I , J
Local Char ZONE(GLONAVA)
OK = 1
While INDEX<>""
 I = instr(1,INDEX,"+")
 J = instr(1,INDEX,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  ZONE = left$(INDEX,I-1)
  INDEX = right$(INDEX,I+1)
 Else
  ZONE = INDEX
  INDEX = ""
 Endif
 Read [ATZ]CODZONE = TABLE;ZONE
 If fstat
  OK = 0 : Break
 Endif
Wend
End

