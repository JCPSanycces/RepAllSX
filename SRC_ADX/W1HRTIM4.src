#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:14:05"
A_USER  = "DOC"
A_STAMP = "20181109231405"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "LVESUBNR"
  If [M]LVESUBNR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRTIM4 [HRTIM4]
Gosub HORODAT
Local Inpbox "HRTIM4" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRTIM4] As [SIM_]
Grizo [HRTIM4]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRTIM4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_LVESUBTYP
Onevent CONTROL Call C_LVESUBTYP(zc) From W1HRTIM4
Onevent AFTER_CHANGE Gosub AMM_LVESUBTYP From W1HRTIM4
Onevent BEFORE_INPUT Call AS_LVESUBTYP(zc) From W1HRTIM4
Return

Subprog AS_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1001385,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LVESUBTYP(zc) From W1HRTIM4
Onkey   2 Titled GBOUTS Call S_LVESUBTYP(zc) From W1HRTIM4
Onkey 144 Titled GBOUTP Call P_LVESUBTYP(zc) From W1HRTIM4
Onkey 146 Titled GBOUTA Call SA_LVESUBTYP(zc) From W1HRTIM4
Gosub _AFF
End

Subprog C_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
If !mkstat
 ## Action CONTHRLST
 Call CONTHRLST(VALEUR) From SUBHRLST
 If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
  If !mkstat
   ## Action STD
   Call C_LVESUBTYP(VALEUR) From SUBHRTIM
   If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LVESUBTYP
Call AM_LVESUBTYP(zc)
If !mkstat & GOBJET
 zoncou = "LVESUBTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LVESUBTYP(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLVESUBTYP)")>indice
 [M]LVESUBTYP(indice) = VALEUR
 Affzo ZLVESUBTYP(indice)
Endif
Gosub _AFF
End

Subprog S_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRLST
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRLST"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRLST","SUBHRLST","SPEHRLST") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
Call OBJET("HRLST",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRLST"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("HRLST",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLVESUBTYP
Onevent BEFORE_AREA Gosub AV_ZLVESUBTYP From W1HRTIM4
Return

$AV_ZLVESUBTYP
Call LECTEXTRA(zc,"HRLVESUBHEA","DES",num$(GCURLEG),num$([M]LVESUBTYP(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_LVESUBPRI
Return

$CHG_STY
Return


