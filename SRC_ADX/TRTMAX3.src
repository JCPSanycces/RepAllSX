##########################################################################################################
#   Ajout d'un destinataire                                         Module CRM         01 décembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIBMAX3MODIF

  GIBMAX3MODIF = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:MAX3]CRITPST = 1
  Affzo [M:MAX3]CRITPST
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIBMAX3MODIF = 1 Then
    Call LOADRESULT(1,1) From TRTMAI4
    Affzo [M:MAI4]1-99
  Endif
  #Nettoie l'écran avant de partir.
  Raz [M:MAX3]
  Kill GIBMAX3MODIF
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Integer ICURLIGNE

  ICURLIGNE = nolign-1
  Case BOUT
    When "B"
      Gosub ONADD
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONADD
Local Integer INBBPR
Local Integer IBSELMASTER
Local Integer IBERROR
Local Integer IBCREATE

  FIN = 0
  INBBPR = 0
  IBSELMASTER = 0
  IBERROR = 0
  IBCREATE = 0
  If ICURLIGNE < 0 Then
    Return
  Endif
  GIBMAX3MODIF = 1
  #Test tout d'abord si le contact n'est pas déjà inclus dans la sélection.
  Read [SCL]SCL1=GSZOPGNUM;"CCN";[M:MAX3]CCNNUM(ICURLIGNE)
  If !fstat Then
    GMESSAGE = mess(357,196,1) #Cet interlocuteur est déjà inclus dans la sélection.
    GERR = 2
    Return
  Endif
  #Teste si une sélection maitre a été définie précédemment.
  Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  For [SEC]
    IBSELMASTER = 1
    Break
  Next
  Filter [SEC]
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  If IBSELMASTER = 1 Then
    Filter [CNT] Where [F:CNT]CCNCRM = [M:MAX3]CCNNUM(ICURLIGNE)
    For [CNT] CNT2
      INBBPR += 1
      [F:SCL]OPGNUM = GSZOPGNUM
      [F:SCL]RECTYP = "CCN"
      [F:SCL]RECNUM = [M:MAX3]CCNNUM(ICURLIGNE)
      [F:SCL]BPAADD = ""
      If [F:CNT]BPATYP = 1 Then
        [F:SCL]BPRNUM = [F:CNT]BPANUM
        If GIDEFADD <> 2 Then
          If [F:SCL]BPRNUM <> "" Then
            Read [BPR]BPR0=[F:SCL]BPRNUM
            If fstat = 0 Then
              [F:SCL]BPAADD = [F:BPR]BPAADD
            Endif
          Endif
        Endif
      Endif
      Write [SCL]
      If fstat <> 0 Then
        IBERROR = 1
        Break
      Endif
    Next
    Filter [CNT]
  Endif
  If IBSELMASTER = 0 and IBERROR = 0 Then
    IBCREATE = 1
  Else
    If INBBPR = 0 and IBERROR = 0 Then
      IBCREATE = 1
    Endif
  Endif
  #Aucun tiers associé à l'interlocuteur. Il faut l'ajouter avec son adresse perso.
  If IBCREATE = 1 and IBERROR = 0 Then
    #Pas de sélection maitre
    [F:SCL]OPGNUM = GSZOPGNUM
    [F:SCL]RECTYP = "CCN"
    [F:SCL]RECNUM = [M:MAX3]CCNNUM(ICURLIGNE)
    [F:SCL]BPRNUM = ""
    [F:SCL]BPAADD = ""
    Write [SCL]
    If fstat <> 0 Then
      IBERROR = 1
    Endif   
  Endif
  If IBERROR = 1 Then
    GMESSAGE = mess(100,141,1) #Erreur création
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  FIN = 1
Return

##########################################################################################################
$ONLOAD
Local Char SZWHERE (250)
Local Char SZAND
Local Char SZVALEUR (100)
Local Char SZRECHERCHE (100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo[M:MAX3]20
  [M:MAX3]NBREC = 0
  If !clalev([F:AIN]) : Local File "CONTACTCRM" [AIN] : Endif
  If [M:MAX3]CCNLNA <> "" Then
    SZVALEUR = [M:MAX3]CCNLNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = " pat(toupper([F:AIN]CNTLNA)," + SZRECHERCHE + ")<>0 "
    SZAND = " AND "
  Endif
  If [M:MAX3]CCNFNA <> "" Then
    SZVALEUR=[M:MAX3]CCNFNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE = SZWHERE - SZAND - "pat(toupper([F:AIN]CNTFNA)," +SZRECHERCHE+")<>0 "
    SZAND = " AND "
  Endif
  If [M:MAX3]CRITPST = 2 Then
    SZWHERE = SZWHERE - SZAND - "[F:AIN]CNTTYP=1"
    SZAND = " AND "
  Endif
  If [M:MAX3]CRITPST = 3 Then
    SZWHERE = SZWHERE - SZAND - "[F:AIN]CNTTYP=2"
    SZAND = " AND "
  Endif
  If SZWHERE <> "" Then
    Filter [AIN] Where evalue (SZWHERE) Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Else
    Filter [AIN] Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Endif
  INBLIGNETOTAL = rowcount([AIN])
  For [AIN]
    If ILIGNE >= dim([M:MAX3]NAM)-1 Then
      Break
    Endif
    [M:MAX3]CNTTYP(ILIGNE) = [F:AIN]CNTTYP
    If [M:MAX3]CNTTYP(ILIGNE) = 2 Then
      [M:MAX3]OBJ(ILIGNE) = "LDS"
    Else
      [M:MAX3]OBJ(ILIGNE) = "AIN"
    Endif
    Call BUILDFULNAM("AIN", [M:MAX3]NAM(ILIGNE)) From CRMUTIL140
    [M:MAX3]CCNNUM(ILIGNE) = [F:AIN]CNTNUM
    [M:MAX3]ZIP(ILIGNE) = [F:AIN]ZIP
    [M:MAX3]CTY(ILIGNE) = [F:AIN]CTY
    [M:MAX3]TEL(ILIGNE) = [F:AIN]CNTETS
    [M:MAX3]CRY(ILIGNE) = [F:AIN]CRY
    ILIGNE += 1
  Next
  Filter [AIN]
  [M:MAX3]NBREC = ILIGNE
  Affzo [M:MAX3]1-99
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return
