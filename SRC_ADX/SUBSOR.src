######################################################################################
Subprog AV_SFISSTCOD(VALEUR)
Variable Char    VALEUR()
# 101380 -Do not alow updating of SST code for certain cases.
# See SUBSFIT for setting of override flag.
If [M:SOR1]SFISSTOVRFLG(nolign-1)=1 : mkstat=2 : Endif
End

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

# The company record is getting reset incorrectly when coming back from the PRODUCT button
# 106867.sn
If func AFNC.ACTIV("LTA") & GSOCIETE<>[F:CPY]CPY
  Gosub GET_CPY_SSTTAXACT From TRTTAXSST
Endif
# 106867.en

# If GLOCUSATAX & dim([M:SOR1]SFISSTCOD)>0   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & dim([M:SOR1]SFISSTCOD)>0   # 106867.n
  Chgfmt [M:SOR1]SFISSTCOD  With "K:"   + num$(type([M:SOR1]SFISSTCOD)-10)  + "B"     # Show enterable
Else
  Chgfmt [M:SOR1]SFISSTCOD  With "-K:"  + num$(type([M:SOR1]SFISSTCOD)-10)  + "B"     # Hide
Endif

End
