#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
# GESTION DES COMMANDES OUVERTES (CONTRATS)                      SUBSOR #
#-----------------------------------------------------------------------#
# NOVEMBRE 1997                                                      TS #
#########################################################################
# Issue X3-83551 - 20180409 by LD : Blocking in creation of sales contract
# Issue X3-98052 - 20180803 by LD : Cost price on line of Sales Order is rounding for currency conversion

#########################################################################
# SECTION CONTENANT LES ACTIONS SUR L'OBJET                             #
#########################################################################
$ACTION
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS
 When "VARIANTE"     : Gosub VARIANTE
 When "SETTRANS"     : Gosub SETTRANS
 When "OUVRE"        : Gosub OUVRE
 When "FILTRE"       : Gosub FILTRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "STATUT"       : Gosub STATUT
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "AFFMASK"      : Gosub AFFMASK
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "LIENS"        : Gosub LIENS
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "VERF_ANU"     : Gosub VERF_ANU
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "MODIF"        : Gosub MODIF           # FGR 19/12/2011 : X3SUIVI71065
 When "ANNULE"       : Gosub ANNULE
 When "ABANDON"      : Gosub ABANDON
 When "FERME"        : Gosub FERME
 When Default
Endcase
Return

#########################################################################
$DEFTRANS
#Local Integer NBACS
#Local Char    TABACS(10)(100)

# Si on ne vient pas de la gestion des contrats
If GFONC1 <> "GESSOR" Raz GFLAG Endif

# Chargement des codes accés du profil utilisateur qui ont 'éxécution à NON'
#Call CHARGE_ACC(NBACS,TABACS) From SELTRS

Return
#########################################################################
$VARIANTE

# La transaction lu est elle utilisable ?
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=3;[F:AWI]TRN
If fstat
   OK = 0
Elsif [F:SLT]ENAFLG<>2
   OK = 0
#Elsif [F:SLT]ACSCOD<>"" & NBACS>0
#   Le code accés de la transaction autorise t-il son éxécution
#   Call VERIF_ACC(NBACS,TABACS,[F:SLT]ACSCOD,OK) From SELTRS
Endif

Return

#########################################################################
$SETTRANS
Local Shortint  WSLTDOCFLG
Local Char      WSLTDOCNAM(GLONARP), WSLTSTRNUM(GLONTRS)

If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=3;GFLAG
If clalev ([F:DTR])=0 Local File DIETRS [DTR] Endif
Read [DTR]DTR0="SLT";3;GFLAG;0;0

WSLTSTRNUM = [F:SLT]STRNUM
WSLTDOCFLG = [F:SLT]DOCFLG
WSLTDOCNAM = [F:SLT]DOCNAM

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SLT]GFY


Close Local File [SLT], [DTR]

Return

#########################################################################
$OUVRE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Global Char     GNUM(GLONVCR)
Global Shortint GREV    : # 0=question non posée / 1=sans avenant / 2=avec avenant
Local  Integer  STAT

Raz GREV

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif
If !clalev([F:FGR])  Local File FACGROUP   [FGR] Endif

If !clalev([F:GCM])  Local File GACM       [GCM] Endif
If !clalev([F:BPA])  Local File BPADDRESS  [BPA] Endif

Raz GSOC_ACTIVE
GFCY = GFCYDEF (5)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2") From TRTX3
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM : : If GERR=1 OK=0 : Return Endif
# Récupération de la structure des frais/remises
Call COLREM ("C",1,"") From TRTPRICE
# RéCUPéRATION DES TYPES DE FRAIS/REMISES ET DES NO éLéMENTS DE FACTURATION ASSOCIéS
Call TYPREM(1,"") From TRTPRICE

# A cause de l'INISEC "SOH" qui peut être paramétré avec [F:POH]
If GMODU(6)=2 & GOPTCANA>0 If clalev([F:POH])=0 : Local File PORDER [POH] : Endif : Raz [F:POH] : Endif

# -- ACA -- Ouverture du tableau de stockage des éléments facture
Local Char SFIT_OBJ : SFIT_OBJ="SOR"
Gosub INIT_SFIT From SUBSFIT

Return

#########################################################################
$FILTRE

Default File [SOH]
# On accède qu'aux commandes ouvertes non inter-site
#FILTSUP = "[F:SOH]SOHCAT = 4 & [F:SOH]BETFCY<2"
FILTSUP = "[F:SOH]SOHCAT = 4"
Return

#########################################################################
$SETBOUT

# ------------------------------------------------------------------------------------- #
# Suppression des boutons                                                               #
# ------------------------------------------------------------------------------------- #
#     A : Suppression : Si contrat inter-site                                           #
#     D : Duplication                                                                   #
#     H : Changement de code                                                            #
#     1 : Article     : Si aucun contrat                                                #
# ------------------------------------------------------------------------------------- #
If [M:SOR1]BETFCY=2 Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Call VIREBOUT(CHAINE,"DH") From GOBJET
#--CPO 71065 Suite aux tests - désactiver le bt "Article" si on est en modification
#If !CLECUR  Call VIREBOUT(CHAINE,"1") From GOBJET : Endif
If !CLECUR or GREP="M" : Call VIREBOUT(CHAINE,"1") From GOBJET : Endif

# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#   D,E : Texte              : Actif si contrat en ligne ou création                    #
#     F : Transaction                                                                   #
# ------------------------------------------------------------------------------------- #
If GREP="C" | CLECUR
    CHMEN += "DE"
Endif
CHMEN += "F"
#----- Menu "Traçabilité" -----#
If !find("CONSPIV",GNAVIG(1..GPILNAV)) Then
  CHMEN += "T"
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

#########################################################################
# Avant éxécution des boutons et menus
#########################################################################
$AVANTBOUT
Local Char    WFONC1(30)
Local Integer I, WLIG, WCOD, WMODULE
Local Char    WTYP(4), WTEX(12), WANCTEX(12)

  # FGR 19/05/2015 : X3SUIVI106158 (début)
  If find(BOUT, "D", "E") Then
    If [M:SOR1]BPCORD = "" Then
      GERR = 1
      GMESSAGE = mess(427,192,1)
      Return
    Endif
  Endif
  # FGR 19/05/2015 : X3SUIVI106158 (fin)

WMODULE = 5
Case BOUT
 When "D" : If [M]SOHNUM = "" & GREP <> "C" & GREP <> "D"
               GERR = 1 : GMESSAGE= "" : Return
            Endif
# A SUPPRIMER
#            WCOD = 1 : WTYP = "SOH1"            : # Saisie du texte entete contrat
#            WTEX = [M]SOHTEX1
#            WANCTEX = [M]ANCSOHTEX1
#            Gosub AVTBOUT_TEX
 When "E" : If [M]SOHNUM = "" & GREP <> "C" & GREP <> "D"
               GERR = 1 : GMESSAGE= "" : Return
            Endif
# A SUPPRIMER
#            WCOD = 2 : WTYP = "SOH2"            : # Saisie du texte pied contrat
#            WTEX = [M]SOHTEX2
#            WANCTEX = [M]ANCSOHTEX2
#            Gosub AVTBOUT_TEX
Endcase
Return

###########################################################################################
#$AVTBOUT_TEX
#-------------------------------------------------#
# OPTION : Gestion des textes entete et pied      #
#-------------------------------------------------#
#Local Integer WRETOUR
#Local Char    WNUMTEX(12)

#WRETOUR = 0
#WNUMTEX = WTEX
## Si duplication, récupération du texte du contrat que l'on dupplique
## ("D" : duplication sans saisie)
#If GREP = "D"
#   If WANCTEX = WTEX & WNUMTEX <> ""
#      Call TEX(5,WTYP,"","","",WNUMTEX,"X",WRETOUR) From TRTX3TEX
#   Endif
#Elsif GREP <> "C"
#   WCLE1 = [M]SOHNUM
#Endif

#Return

#########################################################################
# Après éxécution des boutons
#########################################################################
$EXEBOUT
If BOUT = "1"
   If !GIMPORT
      # Impression ARC client
      Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
      If  WSLTDOCFLG = 2 & [F:SOH]OCNPRN <> 2
         If [M:SOR1]DOCNAM<>""
            [L]REPORT1=[M:SOR1]DOCNAM
         Elsif WSLTDOCNAM<>""
            [L]REPORT1=WSLTDOCNAM
         Endif
         Call ETAT([L]REPORT1,"GESSOR",TBPAR,TBVAL) From ETAT
      Endif
   Endif
   Gosub RELIT From GOBJSUB
Endif
Return

#########################################################################
# Après éxécution des menus
#########################################################################
$STATUT

Case BOUT
 When "D" : If mkstat=4 & GREP=""                    : # Texte entete contrat
#                GREP="M" : REP="M"
#                Gosub SETBOUT From GOBJSUB
                 Gosub ENTRE_MODIF From GOBJSUB
            Endif
            If [M]SOHTEX1 <> "" & !GIMPORT
               Call SET_IMAGE (4) From GESECRAN
            Elsif !GIMPORT
               Call RESET_IMAGE (4) From GESECRAN
            Endif
 When "E" : If mkstat=4 & GREP=""                    : # Texte pied contrat
#                GREP="M" : REP="M"
#                Gosub SETBOUT From GOBJSUB
                 Gosub ENTRE_MODIF From GOBJSUB
            Endif
            If [M]SOHTEX2 <> "" & !GIMPORT
               Call SET_IMAGE (4) From GESECRAN
            Elsif !GIMPORT
               Call RESET_IMAGE (4) From GESECRAN
            Endif
Endcase
Return

########################################################################
$RAZCRE

#------------------------------------------------------------------------#
# Chargement site par défaut                                             #
# Chargement globales référenciels, comptes et sections de la société    #
# Récupération des paramètres vente du site / de la société              #
# Réalimentation du cours devise dossier/devise cde                      #
# -----------------------------------------------------------------------#
GFCY = GFCYDEF(5)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2") From TRTX3
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
Call GLOBVAR(GFCY,"VEN") From TRTX3
[M:SOR1]SALFCY=GFCY

# Init du type de commande
#Filter [TSO] Where [TSO]SOHCAT = 4
#Read [TSO]TSO0 First

  # FGR 24/02/2015 : X3SUIVI104383 (début)
  #Link [TSO] With [FGR]FGR0=[F:TSO]GFY;GCURFCY As [KTSO]
  #
  #Filter [KTSO] Where [TSO]SOHCAT=4 & ([TSO]GFY="" | [FGR]FCY=GCURFCY)
  #Read [KTSO]TSO0 First
  #If fstat=0
  #   [M:SOR1]SOHTYP = [F:TSO]SOHTYP
  #   [M:SOR1]SOHCAT = [F:TSO]SOHCAT
  #   [M:SOR1]SDHTYP = [F:TSO]SDHTYP : #--CPO 75115 Type de livraison
  #Endif
  #Filter [TSO]
  [M:SOR1]SOHTYP = GSOHTYPOPN
  If [M:SOR1]SOHTYP <> "" Then
    Local Integer IRET

    Call LEC_TSO_LEG(GCURLEG, [M:SOR1]SOHTYP, IRET) From TRTLECLEG
    [M:SOR1]SOHCAT = [F:TSO]SOHCAT : #--- 1-Normale 2-Pret 3-Facture.directe 4-Cde ouverte ---#
    [M:SOR1]SDHTYP = [F:TSO]SDHTYP : #--CPO 75115 Type de livraison
  Else
    Link [TSO] With [FGR]FGR0=[F:TSO]GFY;GCURFCY As [KTSO]
    Filter [KTSO] Where [TSO]SOHCAT=4 & ([TSO]GFY="" | [FGR]FCY=GCURFCY) & ([TSO]LEG=GCURLEG | [TSO]LEG="")
&                 Order By Key CLE=[F:TSO]SOHTYP Asc; [F:TSO]LEG Desc
    Read [KTSO]CLE First
    If fstat=0
      [M:SOR1]SOHTYP = [F:TSO]SOHTYP
      [M:SOR1]SOHCAT = [F:TSO]SOHCAT : #--- 1-Normale 2-Pret 3-Facture.directe 4-Cde ouverte ---#
      [M:SOR1]SDHTYP = [F:TSO]SDHTYP : #--CPO 75115 Type de livraison
    Endif
    Filter [KTSO]
  Endif
  # FGR 24/02/2015 : X3SUIVI104383 (fin)

GMANCOU = 1

[M:SOR1]ALLTYP=GALLTYP

# --> Gestion des signatures : Positionnement flag modif signature
[M:SOR1]APPFLG = 1  : GUPDAPPFLG=1

# Issue X3-83551
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SOR1]PLISTC=[F:CPY]PLISTC
# End issue X3-83551

# -- gestion des textes
Call RAZ_CLOB From ACLOB
Raz [M:SOR1]SOHTEX1, [M:SOR1]SOHTEX2

Call RESET_IMAGE (4) From GESECRAN

## Alimentation nb axes analytiques
#If dim([M]NBAXE) > 0 [M]NBAXE = GOPTCANA : Endif

[M:SOR1]ORDDAT=date$

Gosub GRIZE_LIENS

Affzo [M:SOR1]SALFCY, SOHTYP, SOHCAT, ALLTYP

Return
########################################################################
$RAZDUP

#------------------------------------------------------------------------#
# Chargement globales référenciels, comptes et sections de la société    #
# Récupération des paramètres vente du site / de la société              #
# -----------------------------------------------------------------------#
GFCY = [M:SOR1]SALFCY
#Call GETDEV(GFCY) From DEVSUB
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
Call GLOBVAR(GFCY,"VEN") From TRTX3

[M:SOR1]ALLTYP=GALLTYP

Call RAZ_CLOB From ACLOB
If left$([M:SOR1]SOHTEX1,3)="SOH"
   Call DUP_CLOB("SOH",[M:SOR1]SOHTEX1,WRET) From TRTX3TEX
   If WRET<1 Raz [M:SOR1]SOHTEX1 Endif
Endif
If left$([M:SOR1]SOHTEX2,3)="SOH"
   Call DUP_CLOB("SOH",[M:SOR1]SOHTEX2,WRET) From TRTX3TEX
   If WRET<1 Raz [M:SOR1]SOHTEX2 Endif
Endif

Raz [M]SOHNUM,[M]ORDDAT,[M]REVNUM
Raz [M]CDTSTA
#If dim([M]NBAXE)>0 : Raz [M]NBAXE : Endif

# Rechargement du code compteur
#--CPO 71937 T757 Contrôle de cohérence
#Read [TSO]TSO0=[M]SOHTYP
#If fstat Call RSTA ("TSO",[M]SOHTYP) From GLOCK Endif
Local Integer WERR
Call LEC_TSO_LEG(GCURLEG,[M]SOHTYP,WERR) From TRTLECLEG
If WERR Raz [F:TSO] : Call RSTA("TSO", [M]SOHTYP) From GLOCK : Endif
#--/
[M:SOR1]SDHTYP = [F:TSO]SDHTYP :#--CPO 75115 Type de livraison
GCPT = [F:TSO]CODNUM
If [F:TSO]CODNUM <> ""
   GMANCOU=[F:TSO]MANCOU : GCPT=[F:TSO]CODNUM
Else
    # Aucun compteur associé au type de commande
    Call LECTCA(5,WRET) From SUBTCA
    If fstat | !WRET
        GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
    Endif
   # Compteur : Cde ouvertes (12)
   GMANCOU = [F:TCA]MANCOU([F:TSO]SOHCAT+8) : GCPT = [F:TCA]CODNUM([F:TSO]SOHCAT+8)
Endif

[M:SOR1]ORDDAT=date$

# --> Gestion des signatures : Positionnement flag modif signature
[M:SOR1]APPFLG = 1  : GUPDAPPFLG=1

Gosub GRIZE_LIENS
Affzo [M:SOR1]1-99

Return
#########################################################################
$AFFMASK

If GREP = "C"
   Filter [TSO] Where [TSO]SOHCAT = 4
   Read [TSO]TSO0 First
   If fstat = 0
      [M]SOHTYP = [F:TSO]SOHTYP
      [M]SOHCAT = [F:TSO]SOHCAT
      GCPT = [F:TSO]CODNUM
   Endif
   Filter [TSO]
Endif
Return

#########################################################################
$VERIF_CRE

Gosub VERIF
If OK=0 Return Endif

Gosub CTL_NBAXE
Return

#########################################################################
$INICRE

If GAPPSOC>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

If dim([F:SOH]CPY)>0 : [F:SOH]CPY=GSOCIETE : Endif

Local Integer I
# Récopération du compteur commandes ouvertes
If [M]SOHNUM = ""
   Call NUMERO(GCPT,[F:SOH]SALFCY,[F:SOH]ORDDAT,"",GNUM,STAT) From SUBANM
   If GOK<0 Return Endif
   If STAT = 0
      [F:SOH]SOHNUM  = GNUM
      [M]SOHNUM = GNUM
      Affzo [M]SOHNUM
   Else
      GERR=1 : GMESSAGE=mess(60,199,1) : GOK=0
   Endif
Endif
# Type allocation = paramêtre GALLTYP
#[F:SOH]ALLTYP = GALLTYP
# Inter-site = non
[F:SOH]BETFCY = 1

# Alimentation des types de frais/remises et des no d'éléments de facturation associés
For I = 1 To dim([F:SOH]DISCRGTYP)
   [F:SOH]DISCRGTYP(I-1) = GDISCRGTYP(I-1)
   [F:SOH]INVDTALIN(I-1) = GINVDTALIN(I-1)
Next I

Gosub INITXC

Return

#########################################################################
$INIMOD

# --> Gestion des signatures  : La modification repasse le contrat a un statut non signé
If [M:SOR1]SOQSEQ=0 & (GUPDAPPFLG=2 | [F:SOH]APPFLG=1)
  If GAPPSOC>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif
Endif

Gosub INITXC
Return
#########################################################################
$INITXC

If [M:SOR1]SOHTEX1<>""
   If left$([M:SOR1]SOHTEX1,3)="SOH"
      Call CRE_CLOB([M:SOR1]SOHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SOR1]SOHTEX1,3)<>"BPC"
      Call DUP_CLOB("SOH",[M:SOR1]SOHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SOH]SOHTEX1 = [M:SOR1]SOHTEX1
Endif
If [M:SOR1]SOHTEX2<>""
   If left$([M:SOR1]SOHTEX2,3)="SOH"
      Call CRE_CLOB([M:SOR1]SOHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SOR1]SOHTEX2,3)<>"BPC"
      Call DUP_CLOB("SOH",[M:SOR1]SOHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SOH]SOHTEX2 = [M:SOR1]SOHTEX2
Endif

# ACA - Init adresses
Read [BPC]BPC0=[F:SOH]BPCORD
If fstat Raz [F:BPC] Endif
[F:SOH]BPAORD=[F:BPC]BPAADD
# Bug 69373 : Récup adresse clt facture
Local Char WBPCPYR(GLONBPR), WBPAPYR(GLONADR)
WBPCPYR=[F:BPC]BPCPYR : WBPAPYR=[F:BPC]BPAPYR
#[F:SOH]BPAINV=[F:BPC]BPAINV
If [F:SOH]BPCINV=[F:BPC]BPCINV
    # Si clt facture du contrat est le clt facture de la fiche client, prendre l'adresse de facturation
    [F:SOH]BPAINV=[F:BPC]BPAINV
Else
    # Si clt facture du contrat n'est pas le clt facture de la fiche client, prendre l'adresse par défaut du clt facture
    If [F:BPC]BPCNUM<>[F:SOH]BPCINV
        Read [BPC]BPC0=[F:SOH]BPCINV
        If fstat Raz [F:BPC] Endif
    Endif
    [F:SOH]BPAINV=[F:BPC]BPAADD
Endif
#[F:SOH]BPAPYR=[F:BPC]BPAPYR
If [F:SOH]BPCPYR=WBPCPYR
    # Si clt payeur du contrat est le clt payeur de la fiche client, prendre l'adresse clt payeur
    [F:SOH]BPAPYR=WBPAPYR
Else
    # Si clt payeur du contrat n'est pas le clt payeur de la fiche client, prendre l'adresse par défaut du clt payeur
    If [F:BPC]BPCNUM<>[F:SOH]BPCPYR
        Read [BPC]BPC0=[F:SOH]BPCPYR
        If fstat Raz [F:BPC] Endif
    Endif
    [F:SOH]BPAPYR=[F:BPC]BPAADD
Endif
# Bug 69373

# ACA (2009-06-19) Bug 54870 : Remplir les BPCNAM si code act SAD actif
If GACTSAD=2
  Read [BPR]BPR0=[F:SOH]BPCORD
  [F:SOH]BPCNAM(0)    = [F:BPR]BPRNAM(0)
  [F:SOH]BPCNAM(1)    = [F:BPR]BPRNAM(1)
  Read [BPA]BPA0= 1 ; [F:SOH]BPCORD ; [F:SOH]BPAORD
  [F:SOH]BPCADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:SOH]BPCADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:SOH]BPCADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:SOH]BPCPOSCOD    = [F:BPA]POSCOD
  [F:SOH]BPCCTY       = [F:BPA]CTY
  [F:SOH]BPCSAT       = [F:BPA]SAT
  [F:SOH]BPCCRY       = [F:BPA]CRY
  [F:SOH]BPCCRYNAM    = [F:BPA]CRYNAM
  Read [BPR]BPR0=[F:SOH]BPCINV
  [F:SOH]BPINAM(0)    = [F:BPR]BPRNAM(0)
  [F:SOH]BPINAM(1)    = [F:BPR]BPRNAM(1)
  Read [BPA]BPA0= 1 ; [F:SOH]BPCINV ; [F:SOH]BPAINV
  [F:SOH]BPIADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:SOH]BPIADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:SOH]BPIADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:SOH]BPIPOSCOD    = [F:BPA]POSCOD
  [F:SOH]BPICTY       = [F:BPA]CTY
  [F:SOH]BPISAT       = [F:BPA]SAT
  [F:SOH]BPICRY       = [F:BPA]CRY
  [F:SOH]BPICRYNAM    = [F:BPA]CRYNAM
Endif

Return
#########################################################################
$LIENS
  [M:SOR1]PJTSAV = [M:SOR1]PJT  # FGR 19/12/2011 : X3SUIVI71065

Raz GREV
If [F:SOH]SALFCY <> GFCY
   GFCY = [F:SOH]SALFCY
   #------------------------------------------------------------------------#
   # Chargement globales référenciels, comptes et sections de la société    #
   # Récupération des paramètres vente du site / de la société              #
   # Réalimentation du cours devise dossier/devise cde                      #
   # -----------------------------------------------------------------------#
   #Call GETDEV(GFCY)  From DEVSUB
   Gosub CHARG_PARAM : Raz GERR : Raz GMESSAGE
   # Récupération des paramètres vente
   Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif
# Chargement des sections analytiques entête du document
Call CHARG_CCEH("SOR1","NBAXE","SOH") From TRTX3CPT

If [F:BPR]BPRNUM<>[M]BPCINV
    Read [BPR]BPR0=[M]BPCINV
    If fstat Call RSTA("BPR",[M]BPCINV) From GLOCK : Raz [F:BPR] : Endif
Endif
Read [BPC]BPC0 = [M]BPCINV
If fstat
   Call RSTA("BPC",[F:SOH]BPCINV) From GLOCK : Raz [F:BPC] : [F:BPC]CUR = GLOCALDEV
Endif
# Init tableau éléments de facturation
Local Integer NBPOSTE
NBPOSTE=dim([M:SOR1]INVDTA)
Call STRUFOOT (3,"SOR1",NBPOSTE,[F:SOH]CHGTYP,[F:BPC]CUR,[F:SOH]CUR,"NON") From SUBSFIT
[M]NBFAC = NBPOSTE

Read [BPC]BPC0 = [F:SOH]BPCORD
If fstat
   Raz [F:BPC]
   Call RSTA("BPC",[F:SOH]BPCORD) From GLOCK
Endif

# Alimentation à partir du modèle d'édition
Call ALI_PRTMOD("SOR1",3) From TRTX3
If [M:SOR1]COPNBR=0 [M:SOR1]COPNBR=1 Endif

If GFONC1="GESSOR"  Call RAZ_CLOB From ACLOB : Endif : # MBT 25/06/2004 à vérifier !!!!!

# --> Gestion des signatures
# Recherche s'il existe des lignes de DL : Si oui, le circuit de signature ne bouge plus
Raz [M:SOR1]SOQSEQ
If GAPPSOC>1 & find([M:SOR1]APPFLG, 2,3)
    Filter [SOQ] Where [SOQ]SOHNUM = [F:SOH]SOHNUM
    Read [SOQ]SOQ0 First
    If !fstat [M:SOR1]SOQSEQ=[F:SOQ]SOQSEQ Endif
    Filter [SOQ]
Endif

GUPDAPPFLG=1

If GIMPORT Return : Endif
#------------------------#
# affichage icone texte  #
#------------------------#
If [M:SOR1]SOHTEX1 <> "" | [M:SOR1]SOHTEX2 <> ""
    Call SET_IMAGE (4) From GESECRAN
Else
    Call RESET_IMAGE (4) From GESECRAN
Endif

# Gestion de l'état des zones
Local Char    WSVGGREP(1)
WSVGGREP = GREP : Raz GREP
Gosub GRIZE_LIENS
GREP = WSVGGREP
Return

####################################################################
$GRIZE_LIENS
#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#

If [M:SOR1]BETFCY=2 & [M:SOR1]BETCPY=1
    Affzo [M:SOR1]1-99
    Diszo [M:SOR1]5,10,15,20,25,35
    Actzo [M:SOR1]SOHNUM : # Bug 63733
    If dim ([M:SOR1]CCE) > 0
        Diszo [M:SOR1]CCE
    Endif
Elsif [M:SOR1]BETFCY=2
    # Dde 22779 : Si contrat inter-site pouvoir accéder à certains champs
    Actzo [M:SOR1]1-99
    Affzo [M:SOR1]1-99
#    Diszo [M:SOR1]5,10,25
    Diszo [M:SOR1]5,10
    Actzo [M:SOR1]SOHNUM : # Bug 63733
    Diszo [M:SOR1]VLYDATCON
Else
    Actzo [M:SOR1]1-99
Endif

If find(GREP,"C","D") & GMANCOU=1 Diszo [M:SOR1]SOHNUM Endif
If GREP<>"C" Diszo [M:SOR1]SOHTYP,SALFCY Endif
If GNOTATI <> 2 Diszo [M:SOR1]PRITYP : Endif

# Les clients commande et facture sont modifiables
# s'il n'y a pas d'article sur le contrat
If find(GREP, "", "M")
    Filter [SOC] Where [SOC]SOHNUM = [M]SOHNUM
    Read [SOC]SOC0 First
#    If fstat = 0 Diszo [M:SOR1]BPCORD, BPCINV, CUSORDREF Endif
    If fstat = 0 Diszo [M:SOR1]BPCORD, BPCINV Endif
    Filter [SOC]
Endif

  # 101380 - Hide SST related fields as needed
  Call SETUP_SSTFIELDS
Return

#########################################################################
$AVANT_MOD
# --> Demande de modification avec ou sans avenant
If GREV= 0
   Gosub DEM_AVENANT
   If GREV=2
      Affzo [M:SOR1]REVNUM
   Endif
Endif

# --> Gestion des signatures
# Contrat signé, modification ?
#If [M:SOR1]SOQSEQ=0 & find([F:SOH]APPFLG, 2,3)
If find([F:SOH]APPFLG, 2,3)
    OK=2 : Call AVERTIR(mess(233,191,1)+"\"+mess(60,123,1)-"?",OK) From GESECRAN
    If OK=1 OK=0 : Return Else OK=1 : Endif
Endif

Return
#########################################################################
$APRES_MOD
If !GIMPORT
    # Maintenant on fait toujours un gosub RELIT
    Gosub RELIT From GOBJSUB
    [M:SOR1]SOHNUM = [F:SOH]SOHNUM
Endif
Return
#########################################################################
$APRES_CRE
If !GIMPORT
    # Maintenant on fait toujours un gosub RELIT
    Gosub RELIT From GOBJSUB
    [M:SOR1]SOHNUM = [F:SOH]SOHNUM
Endif
Return

#########################################################################
$MODIF
  # FGR 19/12/2011 : X3SUIVI71065
  If [M:SOR1]PJTSAV <> [M:SOR1]PJT Then
    If func REPERCUTE_PJT_SORSOC([M:SOR1]SOHNUM, [M:SOR1]PJTSAV, [M:SOR1]PJT) <> 0 Then
      GOK = 0
      Return
    Endif
  Endif
Return

#########################################################################
Funprog REPERCUTE_PJT_SORSOC(SSOHNUM, SPJTORI, SPJTNEW)
Value Char SSOHNUM
Value Char SPJTORI
Value Char SPJTNEW

Local Integer NERROR
Local Integer NADXLOG
Local Integer NROWCOUNT
Local Integer NBOSSE
Local Char SACTION(1)
Local Char SSAVPJT(GLONPJT)

  # FGR 19/12/2011 : X3SUIVI71065
  # ---------------------------------------------------
  If !clalev ([F:SOC]) : Local File SORDERC [SOC] Endif
  If !clalev ([F:SOQ]) : Local File SORDERQ [SOQ] Endif
  # ---------------------------------------------------
  NERROR = 0
  If adxlog = 1 Then
    NADXLOG = 1  # Transaction en cours
  Else
    NADXLOG = 0  # Pas de transaction en cours
  Endif
  # ---------------------------------------------------
  Filter [F:SOC] Where [F:SOC]SOHNUM = SSOHNUM
  NROWCOUNT = rowcount([F:SOC])
  If NROWCOUNT > 0 Then
    # ---------------------
    If GPJTSNGDOC = G_OUI Then
      SACTION = "1"
    Else
      Call ACTION_PJTQUESTIO(SACTION, 5) From TRTPJT
    Endif
    If SACTION <> "2" Then
      # Si pas "Non"
      # ---------------------
      If NADXLOG = 0 Then
        Trbegin [F:SOC]
      Endif
      # ---------------------
      For [F:SOC]SOC0
        Case SACTION
          When "1"
            # Oui
            NBOSSE = 1
          When "3"
            # Oui si même valeur
            If [F:SOC]PJT = SPJTORI Then
              NBOSSE = 1
            Else
              NBOSSE = 0
            Endif
          When Default
            NBOSSE = 0
        Endcase
        If NBOSSE = 1 Then
          SSAVPJT = [F:SOC]PJT
          [F:SOC]PJT = SPJTNEW
          Rewrite [F:SOC]
          If fstat Then
            NERROR = 1
            GMESSAGE = mess(1048,196,1) - ":" - num$([F:SOC]SOPLIN)
            Break
          Endif
          NERROR = func REPERCUTE_PJT_SOCSOQ([F:SOC]SOHNUM, [F:SOC]SOPLIN, SSAVPJT, [F:SOC]PJT, "1")
          If NERROR <> 0 Then
            Break
          Endif
          # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 09/01/17)
          # Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
          # Initialization of the dimension managed by project on the price lines
          NERROR = func PJT_INIT_CCE_CAL("SOP", 0, [F:SOC]SOHNUM, [F:SOC]SOPLIN, 0, "", "1")
          If NERROR <> 0 Then
            Break
          Endif
          # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 09/01/17)
        Endif
      Next
      # ---------------------
      If NADXLOG = 0 Then
        If NERROR <> 0 Then
          # Cas d'erreur
          Rollback
        Else
          # C'est tout bon
          Commit
        Endif
      Endif
    Endif
    # ---------------------
  Endif
  Filter [F:SOC]
  # ---------------------------------------------------
End NERROR

#########################################################################
Funprog REPERCUTE_PJT_SOCSOQ(SSOHNUM, ISOPLIN, SPJTORI, SPJTNEW, SACTION)
Value Char    SSOHNUM
Value Integer ISOPLIN
Value Char    SPJTORI
Value Char    SPJTNEW
Value Char    SACTION

Local Integer NERROR
Local Integer NADXLOG
Local Integer NROWCOUNT
Local Integer NBOSSE

  # FGR 19/12/2011 : X3SUIVI71065
  # Note : Prévu pour que SACTION puisse être saisi ici. Mais pas géré pour le moment. Il vaut toujours "BOUT=1=>Oui".
  SACTION = "1"
  # ---------------------------------------------------
  If !clalev ([F:SOQ]) : Local File SORDERQ [SOQ] Endif
  # ---------------------------------------------------
  NERROR = 0
  If adxlog = 1 Then
    NADXLOG = 1  # Transaction en cours
  Else
    NADXLOG = 0  # Pas de transaction en cours
  Endif
  # ---------------------------------------------------
  Filter [F:SOQ] Where [F:SOQ]SOHNUM = SSOHNUM and [F:SOQ]SOPLIN = ISOPLIN and [F:SOQ]SOQSTA <> 3
  NROWCOUNT = rowcount([F:SOQ])
  If NROWCOUNT > 0 Then
    If SACTION <> "1" and SACTION <> "2" and SACTION <> "3" Then
      If GPJTSNGDOC = G_OUI Then
        SACTION = "1"
      Else
        Call ACTION_PJTQUESTIO(SACTION) From TRTPJT
      Endif
    Endif
    If SACTION <> "2" Then
      # Si pas "Non"
      # ---------------------
      If NADXLOG = 0 Then
        Trbegin [F:SOQ]
      Endif
      # ---------------------
      For [F:SOQ]SOQ0
        Case SACTION
          When "1"
            # Oui
            NBOSSE = 1
          When "3"
            # Oui si même valeur
            If [F:SOQ]PJT = SPJTORI Then
              NBOSSE = 1
            Else
              NBOSSE = 0
            Endif
          When Default
            NBOSSE = 0
        Endcase
        If NBOSSE = 1 Then
          [F:SOQ]PJT = SPJTNEW
          Rewrite [F:SOQ]
          If fstat Then
            NERROR = 1
            GMESSAGE = mess(1049,196,1) - ":" - num$([F:SOQ]SOPLIN) + "/" + num$([F:SOQ]SOQSEQ)
            Break
          Endif
        Endif
      Next
      # ---------------------
      If NADXLOG = 0 Then
        If NERROR <> 0 Then
          # Cas d'erreur
          Rollback
        Else
          # C'est tout bon
          Commit
        Endif
      Endif
    Endif
    # ---------------------
  Endif
  Filter [F:SOQ]
  # ---------------------------------------------------
End NERROR


# X3-3808  : Update project dimension on sales documents / X3-46226 (LD 09/01/17)
#########################################################################
#**
#* Initialisation de la section analytique gérée à l'affaire sur les lignes de prix
#* Utilisé par REPERCUTE_PJT_SORSOC
#* Boucle de lecture des lignes de prix SORDERP, pour chaque ligne lecture CPTANALIN pour init de la section et maj
#* Initialization of the dimension managed by project on the price lines
#* Used by REPERCUTE_PJT_SORSOC
#* Used when the field PJT is not on the lines (if field PJT on the lines init is done with EXEC_PJTREPEAT_OUI or EXEC_PJTREPEAT_OUISI)
#* Lopp on the price lines SORDERP, for each line read CPTANALIN for init and dimension update
#*
#* @param WABRFIC  Abréviation table des lignes du document/Abbreviation table for document lines
#* @param WVCRTYP  Type de pièce/Entry type
#* @param WVCRNUM  N° de pièce/Entry Number
#* @param WVCRLIN  Numéro de ligne de la pièce/Entry line number
#* @param WVCRSEQ  Numéro de séquence de la pièce / /Entry sequence number
#*                 si 0 concerne toutes les lignes de prix d'une ligne article/if 0 concerns all the price lines for the product line
#* @param WCPLCLE  Complément clé/Complement key
#* @param SACTION  Valeur action repeat (1 Oui/2 Non/3 Oui si) Toujours à 1/Value for repeat action (1 Yes/2 No/3 Yes if) Always = 1
#*
#*!
Funprog PJT_INIT_CCE_CAL(WABRFIC, WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE, SACTION)
Value Char    WABRFIC
Value Integer WVCRTYP
Value Char    WVCRNUM
Value Integer WVCRLIN
Value Integer WVCRSEQ
Value Char    WCPLCLE
Value Char    SACTION

Local Integer NERROR
Local Integer NADXLOG

# Utilisé par GET_PARAM_CCEH de TRTPJTSAL pour connaître le contexte/ Used by GET_PARAM_CCEH from TRTPJTSAL to know the context
Local Char    CODMSK : CODMSK = "SOR1SOC"

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

Call TRAITEMENT_MODULE(5, STRTMODULE, ITRTMODULE) From TRTPJT

#Infbox "PJT_INIT_CCE_CAL"

  # FGR 19/12/2011 : X3SUIVI71065
  # Note : Prévu pour que SACTION puisse être saisi ici. Mais pas géré pour le moment. Il vaut toujours "BOUT=1=>Oui".
  SACTION = "1"
  # ---------------------------------------------------
  If !clalev ([F:SOP]) : Local File SORDERP   [SOP] Endif
  If !clalev ([F:CAL]) : Local File CPTANALIN [CAL] Endif
  # ---------------------------------------------------
  NERROR = 0
  If adxlog = 1 Then
    NADXLOG = 1  # Transaction en cours
  Else
    NADXLOG = 0  # Pas de transaction en cours
  Endif

  If WVCRSEQ<>0
    Filter [F:SOP] Where [F:SOP]SOHNUM=WVCRNUM and [F:SOP]SOPLIN=WVCRLIN and [F:SOP]SOPSEQ=WVCRSEQ
  Else
    Filter [F:SOP] Where [F:SOP]SOHNUM=WVCRNUM and [F:SOP]SOPLIN=WVCRLIN
  Endif
  For [F:SOP]SOP0
      Readlock [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;[F:SOP]SOPSEQ;WCPLCLE;1
      If fstat=1
        GOK=-1 : GLOCK="$CPTANALIN"-WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$([F:SOP]SOPSEQ)
        NERROR = 1 : Break
      Elsif fstat
        GOK=0  : Call RSTA("CAL",WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$([F:SOP]SOPSEQ)) From GLOCK
        NERROR = 1 : Break
      Endif

#Infbox "PJT_INIT_CCE_CAL"

      # Initialisation de la section anaylitique
      # Dimension initialization
      Gosub PJT_INIT_CCEH From TRTPJT

      Rewrite [F:CAL]
      If fstat Then
          NERROR = 1
          ##### message à changer #################
          GMESSAGE = mess(1049,196,1) - ":" - num$([F:SOP]SOPLIN) + "/" + num$([F:SOP]SOPSEQ)
          Break
      Endif
  Next
  # ---------------------
  If NADXLOG = 0 Then
    If NERROR <> 0 Then
      # Cas d'erreur
      Rollback
    Else
      # C'est tout bon
      Commit
    Endif
  Endif
  # ---------------------
  Filter [F:SOP]
  # ---------------------------------------------------
End NERROR

#########################################################################
$APRES_MODIF

# --> Gestion des signatures : Positionnement du flag modif signatures
If [M:SOR1]SOQSEQ<>0 Return Endif
If find(COUZON,"BPCINV","BPCPYR","BPCGRU","VLYDATCON","PTE","VACBPR","INVDTAAMT")
    GUPDAPPFLG=2
Endif

Return
####################################################################
$DEM_AVENANT
Local Integer WOK
If find(GREP,"C","D") Return Endif
# --> Demande de modification avec ou sans avenant
GREV = 1
If GSALREV = 2
   WOK=1
   If !GIMPORT Call OUINON(mess(51,194,1),WOK) From GESECRAN Endif
   If WOK=2
      GREV=2
      [M:SOR1]REVNUM+=1
   Endif
Endif
Return

####################################################################
$AVANT_MODFIC
Local Decimal WMONTORG, WMONTDES
Local Integer SPSTAT, LOK, WNATPRI
Local Char    WVACITM(GLONTVI)(3), WVAT(GLONVAT)(3)
Local Decimal COUTHT, COUTHTC, COEF, WQTY

# Cas particulier où on modifie le texte en le supprimant
Local Integer WRET
If [M:SOR1]SOHTEX1="" & left$([F:SOH]SOHTEX1,3)="SOH"
    Call SUP_CLOB([F:SOH]SOHTEX1,WRET) From TRTX3TEX
Endif
If [M:SOR1]SOHTEX2="" & left$([F:SOH]SOHTEX2,3)="SOH"
    Call SUP_CLOB([F:SOH]SOHTEX2,WRET) From TRTX3TEX
Endif

# Si la devise a évolué recalcul des enregistrements SOC
# Si le régime de taxe a évolué, réalimentation des codes taxe, recalcul des prix et marge

If [M:SOR1]CUR <> [F:SOH]CUR | [M:SOR1]VACBPR <> [F:SOH]VACBPR
   Local Char WCRITERE(30) : WCRITERE="1=1"
   If [M:SOR1]CUR=[F:SOH]CUR WCRITERE-="& VACBPR=[F:SOH]VACBPR" Endif
   For [SOC]SOC0 Where SOHNUM=[F:SOH]SOHNUM & evalue(WCRITERE)
      Readlock [SOC]SOC0=[F:SOC]SOHNUM;[F:SOC]SOPLIN
      If fstat
         GOK=0 : Call RSTA("SOC",[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)) From GLOCK
         Break
      Else
         If [M:SOR1]CUR <> [F:SOH]CUR
             Call CONVERT([F:SOH]CUR, [M:SOR1]CUR, GLOCALDEV, [M:SOR1]CHGTYP, date$,
&                         [F:SOC]EXTAMT, WMONTDES, SPSTAT) From TRTDEV
             [F:SOC]EXTAMT = WMONTDES
             Call CONVERT([F:SOH]CUR, [M:SOR1]CUR, GLOCALDEV, [M:SOR1]CHGTYP, date$,
&                         [F:SOC]CPLAMT, WMONTDES, SPSTAT) From TRTDEV
             [F:SOC]CPLAMT = WMONTDES
         Endif
         If [M:SOR1]VACBPR <> [F:SOH]VACBPR & [F:SOC]VACBPR=[F:SOH]VACBPR
             If clalev ([F:ITS])=0 Local File ITMSALES  [ITS] Endif
             If clalev ([F:ITM])=0 Local File ITMMASTER [ITM] Endif
             If [F:ITS]ITMREF <> [F:SOC]ITMREF
                 Read [F:ITS]ITS0 = [F:SOC]ITMREF
                 If fstat  Raz [F:ITS]  Endif
             Endif
             If [F:ITM]ITMREF <> [F:SOC]ITMREF
                 Read [F:ITM]ITM0 = [F:SOC]ITMREF
                 If fstat  Raz [F:ITM]  Endif
             Endif
             #WVACITM(0) = [F:SOC]VACITM(0)
             #WVACITM(1) = [F:SOC]VACITM(1)
             #WVACITM(2) = [F:SOC]VACITM(2)
             #Call ALITAXEV([M:SOR1]VACBPR,WVACITM,WVAT) From TRTX3
             Call RECHVATCOD(1,1,[M]BPCORD,[F:SOC]ITMREF,"SOC",0,WVAT) From TRTX3
             [F:SOC]VAT(0) = WVAT(0)
             [F:SOC]VAT(1) = WVAT(1)
             [F:SOC]VAT(2) = WVAT(2)
         Endif

         If [F:SOC]PLI=""
            For [SOP]SOP0 Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN
               Readlock [SOP]SOP0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
               If fstat
                  GOK=0
                  Call RSTA("SOP",[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)) From GLOCK
                  Break
               Else
                  If [M:SOR1]CUR <> [F:SOH]CUR
                      Call CONVERT2([F:SOH]CUR,[M:SOR1]CUR,GLOCALDEV,[M:SOR1]CHGTYP,date$,
&                                  [F:SOP]GROPRI,WMONTDES,SPSTAT) From TRTDEV
                      [F:SOP]GROPRI = arr(WMONTDES, 10^-GDECPRI)

                      For I = 0 To 8
                         If GFMTREM(I)="M"
                            WMONTORG = evalue("[F:SOP]DISCRGVAL"+num$(I+1))
                            Call CONVERT([F:SOH]CUR, [M:SOR1]CUR, GLOCALDEV, [M:SOR1]CHGTYP, date$,
&                                        WMONTORG, WMONTDES, SPSTAT) From TRTDEV
                            Assign "[F:SOP]DISCRGVAL"+num$(I+1) With WMONTDES
                         Endif
                      Next I

                      Call CONVERT([F:SOH]CUR,[M:SOR1]CUR,GLOCALDEV,[M:SOR1]CHGTYP,date$,
&                                  [F:SOP]PFM,WMONTDES,SPSTAT) From TRTDEV
                      [F:SOP]PFM = WMONTDES

                      Gosub PRIXNET
                  Endif
                  If [F:SOH]PRITYP=1
                      [F:SOP]NETPRINOT = [F:SOP]NETPRI
                      Call CLCTAXEPRIV([F:SOP]NETPRI,[F:SOC]VAT,[F:SOH]PRITYP,GSOCIETE,
&                                     [F:SOP]STRDAT,0,[M:SOR1]VACBPR,0,0,[F:SOP]NETPRIATI) From TRTX3
                  Else
                      [F:SOP]NETPRIATI = [F:SOP]NETPRI
                      Call CLCTAXEPRIV([F:SOP]NETPRI,[F:SOC]VAT,[F:SOH]PRITYP,GSOCIETE,
&                                     [F:SOP]STRDAT,0,[M:SOR1]VACBPR,0,0,[F:SOP]NETPRINOT) From TRTX3
                  Endif
                  If [M:SOR1]VACBPR <> [F:SOH]VACBPR & [F:SOC]VACBPR=[F:SOH]VACBPR
                      # Recalcul de la marge
                      If [F:SOP]NETPRI <> 0
# Bug 80451 : PE CALPFM1 non appelé
#                        WQTY = 0
#                        Call DEFCPR([F:SOC]ITMREF,[F:SOP]STOFCY,2,[F:SOC]SOHNUM,
#&                                   [F:SOC]SOPLIN,0,[F:SOP]STRDAT,WQTY,COUTHT,LOK) From STKVAL
#                        If LOK=0
#                           # Si devise document <> devise base calcul marge (société du site expé)
#                           If [M:SOR1]CUR <> GLOCALDEV & COUTHT <> 0
#                              Call CONVERT (GLOCALDEV,[M:SOR1]CUR,GLOCALDEV,
#&                                [M:SOR1]CHGTYP, date$, COUTHT, COUTHTC, SPSTAT)
#&                                From TRTDEV
#                              COUTHT=COUTHTC
#                           Endif
#                           # Le prix de revient est exprimé en US : Le convertir en UV
#                           #COUTHT=COUTHT*COEF
#                           COUTHT=COUTHT*[F:SOP]SAUSTUCOE
#                        Endif
#                        Gosub CALSPEPFM From TRTVENPRI
#                        If GSALRND = 2
#                            Call ARRDEV(COUTHT,[M:SOR1]CUR) From TRTDIV
#                        Else
#                            COUTHT=arr(COUTHT,10^-GDECPRI)
#                        Endif
#                        # --> Calcul de la marge
##                        [F:SOP]PFM = [F:SOP]NETPRINOT - arr(COUTHT,10^-GDECPRI)
#                        [F:SOP]PFM = [F:SOP]NETPRINOT - COUTHT
                        Gosub MARGE
# Bug 80451
                      Endif
                      [F:SOP]VAT(0) = WVAT(0)
                      [F:SOP]VAT(1) = WVAT(1)
                      [F:SOP]VAT(2) = WVAT(2)
                  Endif
                  Rewrite [SOP]
                  If fstat GOK=0 : Call FSTA("SOP") From GLOCK Endif
               Endif
            Next
            If GOK<1 Break Endif
         Endif
         [F:SOC]VACBPR=[M:SOR1]VACBPR
         Rewrite [SOC]
         If fstat GOK=0 : Call FSTA("SOC") From GLOCK Endif
      Endif
   Next
   If GOK<1 Return Endif
Endif

# Historisation si modif avec avenant
If GREV = 2 Call HISTO_REV ("SOH", "M") From TRTVENMAJ : Endif

# --> Gestion des signatures
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0 & (GUPDAPPFLG=2 | [F:SOH]APPFLG=1)
  Call ANNULE_SUIVI("SOR",mess(652,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
Endif

Return

# Bug 80451 : PE CALPFM1 non appelé
# --------------------------- #
# Recalcul de la marge        #
# --------------------------- #
$MARGE
#Local Decimal XCRPPRI, XPFM : # 88298
Local Decimal XPFM           : # 88298
Local Decimal PHTNET         : # 95792 : Variable inexistante dans PE CALPFM

# Cas particulier des commandes ouvertes :
# Le prix de revient n'est pas modifiable et pas stocké
# Uniquement la marge est stockée
XPFM     = [F:SOP]PFM
PHTNET   = [F:SOP]NETPRINOT  : # 95792 : Variable inexistante dans PE CALPFM

WQTY = 0
Call DEFCPR([F:SOC]ITMREF,[F:SOP]STOFCY,2,[F:SOC]SOHNUM,
&           [F:SOC]SOPLIN,0,[F:SOP]STRDAT,WQTY,COUTHT,LOK) From STKVAL
If LOK=0
    # Si devise document <> devise base calcul marge (société du site expé)
    If [M:SOR1]CUR <> GLOCALDEV & COUTHT <> 0
        # Issue X3-98052
        # No rounding, to be consistent with what is done in TRTVENPRI
#        Call CONVERT (GLOCALDEV,[M:SOR1]CUR,GLOCALDEV,
#&                     [M:SOR1]CHGTYP, date$, COUTHT, COUTHTC, SPSTAT) From TRTDEV
        Call CONVERT2 (GLOCALDEV,[M:SOR1]CUR,GLOCALDEV,
&                     [M:SOR1]CHGTYP, date$, COUTHT, COUTHTC, SPSTAT) From TRTDEV
        # End issue X3-98052
        COUTHT=COUTHTC
    Endif
# 88298
#    If COUTHT = 0 & XCPRPRI <> 0
#        # On ne touche pas au prix revient s'il était renseigné et qu'on récupère 0
#        COUTHT=XCPRPRI
#    Else
#        # Le prix de revient est exprimé en US : Le convertir en UV
#        COUTHT=COUTHT*[F:SOP]SAUSTUCOE
#    Endif
#Elsif XCPRPRI = 0 & XPFM = 0
##   On conserve l'ancien prix de revient s'il était renseigné
##   et on recalcule la marge ssi elle était renseignée
#Else
#    COUTHT = XCPRPRI
    COUTHT=COUTHT*[F:SOP]SAUSTUCOE
# 88298
Endif

#  Point d'entree calcul d'un cout supplémentaire pour le calcul de la marge
Gosub CALSPEPFM From TRTVENPRI

If GSALRND = 2
    Call ARRDEV(COUTHT,[M:SOR1]CUR) From TRTDIV
#    XCPRPRI=COUTHT   : # 88298
Else
#    XCPRPRI=arr(COUTHT,10^-GDECPRI) : # 88298
    COUTHT=arr(COUTHT,10^-GDECPRI)   : # 88298
Endif

# Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & [F:SOP]NETPRINOT<>0)
    # --> Calcul de la marge
    # 88298
    #XPFM = [F:SOP]NETPRINOT - XCPRPRI    : # Le calcul doit repartir du prix de revient que l'on va afficher et stocker
    XPFM = [F:SOP]NETPRINOT - COUTHT      : # Le calcul doit repartir du prix de revient que l'on va afficher et stocker
    # 88298
Endif

# Point d'entree pour recalcul de la marge
Gosub CALSPEPFM1 From TRTVENPRI

[F:SOP]PFM   = XPFM

Return
# Bug 80451

########################################
$PRIXNET
# Calcul prix net
Local Decimal NET
Local Decimal MAJREM(0..8)
Local Integer I
# Chargement des valeurs frais/remises
For I = 0 To 8
   MAJREM(I) = evalue("[F:SOP]DISCRGVAL"+num$(I+1))
Next I
# Calcul du prix net
NET = [F:SOP]NETPRI
#Call CALNET (1,"",[F:SOP]GROPRI,MAJREM,1,NET,[M:SOR1]CUR) From TRTPRICE
If dim(GCALNETABR)>0 : GCALNETABR="[F:SOP]" : Endif
Call CALNET (1,[M]PLISTC,[F:SOP]GROPRI,MAJREM,1,NET,[M:SOR1]CUR) From TRTPRICE
[F:SOP]NETPRI = NET
Return

#########################################################################
$VERIF_MOD

Gosub VERIF
If OK=0 Return Endif
Gosub CTL_NBAXE

# --> Gestion des signatures
# Modification de champs : Annulation des signatures existantes
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0 & find([F:SOH]APPFLG, 2,3) & GUPDAPPFLG=2
   OK=2 : Call AVERTIR(mess(230,191,1),OK) From GESECRAN
   If OK=1 OK=0 : Return Else OK=1 : Endif
Endif

Return

###############################################################
$VERIF
Local Shortint RES

# VPO 07/12/10 68435 verifier valeur Condition de paiement, Code escompte, Regime de taxe
# VPO 01/03/11 71999 ameliorer message d'erreur
If [M:SOR1]PTE<>""
    #Call CONTROLE("TPT","",[M:SOR1]PTE,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~PTE")+'"\'+GMESSAGE : Return : Endif
    #-- X3Suivi 71937 : Données par législation pour le Conditions de paiement
    #--CPO 71937 01/08/2013 Suite dev review
    Call CONTTPT([M:SOR1]PTE,GCURLEG,'','',[M:SOR1]SALFCY,'','') From SUBTPT
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~PTE")+'"\'+GMESSAGE : Return : Endif
    # FGR 22/07/2013 : X3SUIVI87923 (début)
    Call CTRL_PTE_SEPA_SDD([M:SOR1]PTE, GSOCIETE, [M:SOR1]BPCPYR) From TRTVENSDD
    If mkstat Then
      GERR = 1
      OK = 0
      GMESSAGE = mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~PTE")+'"\'+GMESSAGE
      Return
    Endif
    # FGR 22/07/2013 : X3SUIVI87923 (fin)
Endif
If [M:SOR1]DEP<>""
#--CPO 71937 TABDEPAGIO
    #Call CONTROLE("TDA","!",[M:SOR1]DEP,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~DEP")+'"\'+GMESSAGE : Return : Endif
    Call CONTTDA([M:SOR1]DEP,GCURLEG,"SOR1","DEP",[M:SOR1]SALFCY,"","") From SUBTDA
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~DEP")+'"\'+GMESSAGE : Return : Endif
#--/CPO
Endif
If [M:SOR1]VACBPR<>""
    mkstat=0
    # 71937 : Multilégislation
    #Call CONTADI([M:SOR1]VACBPR,"1","") From SUBADI
    #If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    #Call CONTROLE("ADI","",[M:SOR1]VACBPR,"1",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    Call CONTTVB([M:SOR1]VACBPR,GCURLEG,"SOR1","VACBPR",[M:SOR1]SALFCY,"","") From SUBTVB
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SOR1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    # 71937 : Multilégislation
# 101874 : V9 : Taxe code control
Else
    #  Régime de taxe non renseigné
    GERR=1 : OK=0 : GMESSAGE = mess(620,197,1)-mess(841,197,1)
# 101874
Endif
Return

#########################################################################
$VERF_ANU

# Un contrat est supprimable s'il ne contient pas de demandes de livraisons
Filter [SOQ] Where [SOQ]SOHNUM = [F:SOH]SOHNUM
Read [SOQ]SOQ0 First
If !fstat
   GERR=1 : GMESSAGE = mess(11,192,1) : OK=0
Endif
Filter [SOQ]

# --> Gestion des signatures
# Contrat signé : Annulation des signatures existantes ?
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0 & find([F:SOH]APPFLG, 2,3)
   OK=2 : Call AVERTIR(mess(233,191,1)+"\"+mess(53,123,1)-"?",OK) From GESECRAN
   If OK=1 OK=0 : Return : Endif
Endif

Return

#########################################################################
$ANNULE
Local Integer WRET

#------------------------------------#
# suppression des textes associées   #
#------------------------------------#
If left$([F:SOH]SOHTEX1,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX1,WRET) From TRTX3TEX
Endif
If left$([F:SOH]SOHTEX2,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX2,WRET) From TRTX3TEX
Endif

# --> Gestion des signatures
#------------------------------------------------------------------------#
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow #
#------------------------------------------------------------------------#
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
  Call ANNULE_SUIVI("SOR",mess(653,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
Endif

# SUPPRESSION DES ENREGISTREMENTS SORDERC ET SORDERP CORRESPONDANTS AU CONTRAT
Delete [SOP] Where [SOP]SOHNUM = [SOH]SOHNUM
If fstat = 1 GOK = -1 : Return : Endif
Delete [SOC] Where [SOC]SOHNUM = [SOH]SOHNUM
If fstat = 1 GOK = -1 : Return : Endif

Return

#########################################################################
$ABANDON

# A SUPPRIMER
#----- suppression des textes si abandon en dupli ou creation --#
#Local Integer WRETOUR : WRETOUR = 0
#Local Char    WNUMTEX (12)

#If GREP = "D"
#     If [M]ANCSOHTEX1 <> [M]SOHTEX1
#         WNUMTEX = [M]SOHTEX1
#         Call TEX(5,"SOH1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#     Endif
#     If [M]ANCSOHTEX2 <> [M]SOHTEX2
#         WNUMTEX = [M]SOHTEX2
#         Call TEX(5,"SOH2","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#     Endif
#Elsif GREP ="C"
#    WNUMTEX = [M]SOHTEX1
#    Call TEX(5,"SOH1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#    WNUMTEX = [M]SOHTEX2
#    Call TEX(5,"SOH2","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#Endif

Local Integer WRET

If GREP="D"
   If left$([M:SOR1]SOHTEX1,3)="SOH"
      Call SUP_CLOB([M:SOR1]SOHTEX1,WRET) From TRTX3TEX
   Endif
   If left$([M:SOR1]SOHTEX2,3)="SOH"
      Call SUP_CLOB([M:SOR1]SOHTEX2,WRET) From TRTX3TEX
   Endif
Endif

Call RAZ_CLOB From ACLOB

Return

#########################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-- effacement icone texte
Call RESET_IMAGE (4) From GESECRAN
Return

########################################################################
$CTL_NBAXE

#--> Vérification que tous les axes entête ont bien été saisis (s'ils sont saisissables)
If GHEADIE = 1 : # Axes entêtes saisissables (Initialisé par GETCPY)
   If dim([M]NBAXE)>0
      For nolign = 1 To GNBDIE
          If [M]CCE(nolign-1)="" & GOBLDIE(nolign)=2
             GERR = 1 : GMESSAGE = mess(177,199,1) : OK = 0 : Break
          Endif
      Next nolign
   Endif
   If OK = 0 Return Endif
Endif

Return
