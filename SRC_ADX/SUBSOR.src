# 71065 : PJT
######################################## Obligatoire
Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()

# La devise est modifiable s'il s'agit d'une devise in et pas de l'euro
If [F:TCU]CUR<>VALEUR  Read [TCU]TCU0=VALEUR  Endif
If [F:TCU]EURFLG=2 & [F:TCU]CUR<>GEURO  End   Endif

If GUPDCUR <> 2 mkstat = 2 : End Endif

# La devise est modifiable s'il n'y a pas d'article sur le contrat
If GREP <> "C" & GREP <> "D"
   Filter [SOC] Where [SOC]SOHNUM = [M]SOHNUM
   Read [SOC]SOC0 First
   If fstat = 0 mkstat = 2 Endif
   Filter [SOC]
Endif
End

######################################## Obligatoire
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Local    Char    WNUM(GLONVCR)(10)
Local    Integer I, J

If VALEUR <> [M:SOR1]CUR & GREP <> "C"

   Filter [SOC] Where [SOC]SOHNUM = [M]SOHNUM
   Read [SOC]SOC0 First
   If fstat=0 & [F:TCU]CUR<>GEURO
      mkstat=2 : GMESSAGE=mess(229,192,1)
      Filter [SOC] : End
   Endif
   Filter [SOC]

   If clalev ([F:SDH])=0 Local File SDELIVERY  [SDH] Endif
   If clalev ([F:SDD])=0 Local File SDELIVERYD [SDD] Endif
   For [SDD]SDD1 Where SOHNUM=[M:SOR1]SOHNUM
      Read [SDH]SDH0=[F:SDD]SDHNUM
      If !fstat & [F:SDH]CFMFLG<>2
         If !find([F:SDH]SDHNUM,WNUM(0..I))
            WNUM(I)=[F:SDH]SDHNUM
            If I<9
               I+=1
            Else
               Break
            Endif
         Endif
      Endif
   Next
   If WNUM(0)<>""
      mkstat=2
      GMESSAGE=mess(225,192,1)
      For J=0 To I-1
         GMESSAGE-="\"-WNUM(J)
      Next J
   Endif
Endif

End

######################################## Obligatoire
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local    Integer SPSTAT
Local    Decimal MONTANT

# Recalcul des montants de facturation si changement de devise
If [M]NBFAC <> 0
   For I = 0 To [M]NBFAC-1
      If [M]AMTCOD(I) = 2
         [M]FORMAT(I) = "NZ:"+[F:TCU]CURFMT1
         Call CONVERT([M]CUR, VALEUR, GLOCALDEV, [M:SOR1]CHGTYP, date$, [M]INVDTAAMT(I),MONTANT,SPSTAT)
&                    From TRTDEV
         [M]INVDTAAMT(I) = MONTANT
      Endif
   Next I
Affzo 30
Endif
End
########################################
Subprog C_NBAXE
#If !find(status,1,4,5,20,21,26,92,93) End : Endif
##----- Contrôle sections obligatoires -----#
#If GCCECOD=1
#  For nolign=1 To GOPTCANA
#    If [M]CCE(nolign-1)="" & evalue("GANASAI"+num$(nolign))=2
#       mkstat=2 : GMESSAGE= mess(177,199,1) : Break
#    Endif
#  Next nolign
#Endif
#----------------#
# Contrôle NBAXE #
#----------------#
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
If [M:SOR1]NBAXE>0 & GHEADIE=1
  Local Integer I
  For I=1 To [M:SOR1]NBAXE
    If CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End
