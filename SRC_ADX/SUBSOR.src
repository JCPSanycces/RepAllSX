######################################## Obligatoire
Subprog AP_SOHTYP(VALEUR)
Variable Char    VALEUR()
[M]SOHCAT = [F:TSO]SOHCAT

If [F:TSO]CODNUM <> ""
    GMANCOU=[F:TSO]MANCOU : GCPT=[F:TSO]CODNUM
Else
#-- Aucun compteur associé au type de commande
    Local Integer WRET
    Call LECTCA(5,WRET) From SUBTCA
    If fstat | !WRET
        GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : End
    Endif
#   Compteur : Cde ouvertes (12)
    GMANCOU = [F:TCA]MANCOU([F:TSO]SOHCAT+8) : GCPT = [F:TCA]CODNUM([F:TSO]SOHCAT+8)
Endif
If GREP="C" & GMANCOU=1
   Diszo [M:SOR1]SOHNUM
Else
   Actzo [M:SOR1]SOHNUM
Endif

End

######################################## Facultatif
Subprog AM_SOHTYP(VALEUR)
Variable Char    VALEUR()
If GMANCOU=1 & [M:SOR1]SOHNUM <> ""
   Effzo [M:SOR1]SOHNUM
Endif
#--CPO 75115 Type de livraison
[M:SOR1]SDHTYP=[F:TSO]SDHTYP
Affzo [M:SOR1]SDHTYP
#--/CPO
End

######################################## Facultatif
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SOR1]PLISTC=[F:CPY]PLISTC
# Chargement des globales référenciels, comptes et sections de la société
GFCY=VALEUR : Gosub CHARG_PARAM : If GERR=1 mkstat=2 : End Endif
# Effacement tableau des sections entête si changement société
If GSOC_UPDFLG & dim([M:SOR1]NBAXE)>0 & [M:SOR1]NBAXE>0
  Effzo [SOR1]30 : Affzo [SOR1]30
Endif
If GNOTATI=2
    Actzo [M:SOR1]PRITYP
Else
    Diszo [M:SOR1]PRITYP
Endif

# JPGA : Traitement des exceptions Société : MAJ des informations au cas ou on changerait de Société
If [M:SOR1]BPCORD <> ""
    If dim([M:SOR1]VACBPR) > 0
        # JPGA : Initialisation du Régime taxe
        Call INIT_REGIME([M:SOR1]BPCORD, GSOCIETE, "C", [M:SOR1]VACBPR) From CPTSUB
        Affzo [M:SOR1]VACBPR
    Endif
    If dim([M:SOR1]PTE) > 0
        # JPGA : Initialisation du code condition de paiement
        Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SOR1]PTE) From TRTX3
        Affzo [M:SOR1]PTE
    Endif
Endif

# 101380 - Hide SST related fields as needed
Call SETUP_SSTFIELDS

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SOR1) 14/09/2004 14:17:30 (LD)
######################################################################################
Subprog IB_CUSORDREF
If [M]CUSORDREF="" | [M]BETFCY<>2 | [M]ORIFCY="" Raz GBOUT1 Endif
End
########################################
Subprog AM_CUSORDREF(VALEUR)
Variable Char    VALEUR()
# Demande de Cyrille --> msg même si la référence contrat client est vide
#If VALEUR = "" | [M:SOR1]BPCORD = "" End : Endif
If [M:SOR1]BPCORD = "" End : Endif
Look [SOH] SOH1=[M:SOR1]BPCORD;VALEUR
If !fstat
   Local Integer OK:OK=2
   Call AVERTIR (mess(80,191,1),OK) From GESECRAN :
   If OK=1 mkstat=2 : End Endif
Endif
# s'il existe des articles pour ce contrat avec l'ancienne référence, msg d'avertissement
If GREP<>"C" & [M]CUSORDREF<>""
    Filter [SOC] Where [SOC]SOHNUM=[M]SOHNUM & [SOC]CUSORDREF=[M]CUSORDREF
    Read [SOC]SOC0 First
    If fstat = 0
        Local Integer WOK : WOK=1
        Call AVERTIR (mess(214,191,1), WOK) From GESECRAN
        Raz GMESSAGE : If WOK=1 mkstat=2 : Filter [SOC] : End : Endif
    Endif
    Filter [SOC]
Endif
End
######################################## Facultatif
Subprog C_ORDDAT(VALEUR)
Variable Date    VALEUR
# Date commande doit être <= Date du jour
If VALEUR > date$
   mkstat = 2
Endif
End

######################################## Obligatoire
Subprog C_BPCORD(VALEUR)
Variable Char    VALEUR()
# CONTRôLE DU CLIENT COMMANDE
Call C_BPCORD(VALEUR) From TRTVENCDE
# Contrôle si le tiers risque est bloqué
If (find(GREP, "C", "D") | [M]BPCORD <> VALEUR)
    Local Integer WOSTCTL
    If [F:BPC]BPCRSK<>VALEUR
        Local File BPCUSTOMER [BPC1] : # Lecture du tiers risque ss une autre abrev pour ne pas casser [F:BPC] du clt cde
        If [F:BPC1]BPCNUM<>[F:BPC]BPCRSK
            Read [F:BPC1]BPC0 = [F:BPC]BPCRSK
            If fstat Raz [F:BPC1] : Endif
        Endif
        WOSTCTL=[F:BPC1]OSTCTL
    Else
        WOSTCTL=[F:BPC]OSTCTL
    Endif
    If WOSTCTL = 3
        Local Integer WOK : WOK=1
        Call AVERTIR (mess(151,199,1), WOK) From GESECRAN
        If WOK=1 mkstat=2 : End : Endif
    Endif
Endif
# Controle existence référence client
If [M:SOR1]CUSORDREF = "" End : Endif
If !find (GREP, "C","D")  End : Endif
Look [SOH] SOH1=VALEUR;[M:SOR1]CUSORDREF
If !fstat GERR=3:GMESSAGE = mess(80,191,1) : Endif
End

######################################## Obligatoire
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

Call ALICDE (2,"C",VALEUR) From TRTVENCDE
GFLTBPC = [F:SOH]BPCORD

# --> Affichage des observations du client commande
If !GIMPORT
   If len(vireblc([F:BPC]BPCREM,2)) & GERR=0 GMESSAGE = [F:BPC]BPCREM : GERR=2 : Endif
Endif

Call NEW_SFIT ("M","SOR1",[M:SOR1]CUR,[M:SOR1]BPCINV,VALEUR,[M:SOR1]ORDDAT) From SUBSFIT

End

######################################## Obligatoire
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
Local    Integer I

If GREP = "C"
   Call ALICDE (2,"F",VALEUR) From TRTVENCDE
Endif

# --> Affichage des observations du client facture
If !GIMPORT & VALEUR <> [M:SOR1]BPCORD
   If len(vireblc([F:BPC]BPCREM,2)) & GERR=0 GMESSAGE = [F:BPC]BPCREM : GERR=2 : Endif
Endif

Call NEW_SFIT ("M","SOR1",[M:SOR1]CUR,VALEUR,[M:SOR1]BPCORD,[M:SOR1]ORDDAT) From SUBSFIT

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SOR1) 27/09/2004 17:48:08 (LD)
######################################################################################
Subprog AM_BPCPYR(VALEUR)
Variable Char    VALEUR()
If GREP = "C"
    Call INIPTE (VALEUR, [M:SOR1]BPCINV, "C", [M:SOR1]PTE) From TRTX3
    Affzo [M:SOR1]PTE
Endif
End
######################################## Facultatif
Subprog C_VLYDATCON(VALEUR)
Variable Date    VALEUR
# Date validité doit être >= Date du jour
If VALEUR < date$ mkstat = 2 : End : Endif
# On vérifie que les lignes articles ont une date validité <= nouvelle date saisie
If VALEUR < [M:SOR1]VLYDATCON & GREP <> "C"
   Filter [SOC] Where [SOC]SOHNUM=[M]SOHNUM Order By Key NEWCLE=VLYDATITM
   Read [SOC]NEWCLE Last
   If fstat=0 & [F:SOC]VLYDATITM > VALEUR
      mkstat=2 : GMESSAGE=mess(325,192,1)
   Endif
   Filter [SOC]
Endif

End
