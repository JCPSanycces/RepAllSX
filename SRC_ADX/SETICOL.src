#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################
# SETICOL : Impression : Etiquettes de colisage    
######################################################################

$ACTION
Case ACTION
 When "DESTINATION" : Gosub DESTINATION
 When "EXEC"        : Gosub EXEC_AUT
Endcase

Return

########################################################################### 
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

End
######################################################################
$DECLARE 
Local  Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15) 
Local  Integer WNUMLIG, NUMREQ 
Return 

########################################################################### 
$DESTINATION

# Dans les traitements automatiques
# --> On ne veut pas la fenêtre de sélection 
# --> On sort obligatoirement le document sur l'imprimante 
OK=0 : [M:RPT]IMPRIME = 2
If clalev([M:PCL1])>0 & dim([M:PCL1]LBLSRV)>0 & dim([M:PCL1]LBLIMP)>0
    [M:RPT]SERVEUR    = [M:PCL1]LBLSRV
    [M:RPT]IMPRIMANTE = [M:PCL1]LBLIMP
Endif
Return
##################################################################### 
$EXEC_AUT
Local Integer I,J

Gosub DECLARE 

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Call GETPARAM ([L]PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
#  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = num$([V]GWNUMREQ)
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([V]GWNUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next I
Return

