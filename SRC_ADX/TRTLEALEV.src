#<AdxTL>@(#)1.0.0.0 $Revision$
#
#***********************************************************************************
#        SAISIE FENETRE SUR CONTRAT DE LOCATION-FINANCEMENT (LEA)
#
#      LEALEV0  :  Entête  Levée de l'option d'achat (OAC0)
#      LEALEV   :  Levée de l'option d'achat (LEAL)
#      CMPLEV   :  Maj des biens et des plans d'amortisssement rattachés  (OCP)
#
#***********************************************************************************
#    Création
#    MDR - 08.10.2003
#
#**************************************************************************************
#    Modification
# MDJ   10.17.2017 X3-39795   Manage ORIGIN and ORICOD fields in GL Entry
# MDJ - 21.03.2011 (FQ 72347) Base BSEVAL non renseignée
# MDJ - 22.12.2009 (FQ 61084) Contrat location-financement sans plan IAS
# GLE - 01.07.2009 (FQ 56255) Ajout de points d'entrée
# MDR - 08.10.2008            Adaptations V6
#
#**************************************************************************************
#
ACTION
 Case ACTION
  When "OUVRE"               : Gosub OUVRE
  When "DEBUT"               : Gosub DEBUT
  When "APRES_MODIF"         : Gosub APRES_MODIF
  When "AVANT_MODFIC"        : Gosub AVANT_MODFIC
  When "OK"                  : Gosub OK
  When "ABA"                 : Gosub ABA
  When "FIN"                 : Gosub FIN
  When Default
 Endcase

Return
#---------------------------------#
# OUVRE                           #
#---------------------------------#
$OUVRE

# Récupération des informations des biens liés au contrat
 If !(clalev([F:FAS])) : Local File FXDASSETS [FAS] : Endif
 If !(clalev([F:DEP])) : Local File DEPREC [DEP] : Endif
 Filter [FAS] Where LEAREF=[M:LEA0]LEAREF
 Raz nolign
 For [FAS]
    nolign+=1
    [M:OCP]OBJREF(nolign-1)  = [F:FAS]AASREF
    [M:OCP]OBJDES(nolign-1)  = [F:FAS]AASDES1
    [M:OCP]OBJCPY(nolign-1)  = [F:FAS]CPY
    [M:OCP]OBJTYP(nolign-1)  = PARAM(2)
    If GCNXPROIAS = G_OUI    #*Fq-61084
       #   Récupération de la valeur d'entrée IAS du bien considéré
       [M:OCP]IASBSE (nolign-1)  =  [F:FAS]IASETRNOT + [F:FAS]IVCVATAMTI - [F:FAS]DEDVATAMTI
       [M:OCP]IASBSETOT  +=    [M:OCP]IASBSE (nolign-1)
    Endif    #*Fq-61084
    [M:OCP]TAXBAS (nolign-1)  =  [F:FAS]TAXBAS      #FQ-61084
    [M:OCP]TAXBASTOT  +=    [M:OCP]TAXBAS (nolign-1)#FQ-61084
 Next
 Filter [FAS]

 [M:OCP]NBOBJ=nolign

Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$DEBUT


Global Integer NUMACT
Global Decimal GRPUVAL

# Récupération des informations du contrat

  GRPUVAL        = [M:LEA1]RPUVAL
  [M:LEAL]RPUDAT = [M:LEA1]RPUDAT
  [M:LEAL]RPUVAL = [M:LEA1]RPUVAL
  [M:LEAL]CUR    = [M:LEA0]CUR
  [M:LEAL]LEACUR = [M:LEA1]LEACUR
  Actzo [M:LEAL]

  Affzo [M:LEAL]

 Affzo [M:OCP]

 #=> Détermination / alimentation du numéro de traitement

 NUMACT+=1

#==> Appel du traitement d'init commun à toutes les actions

 Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$APRES_MODIF
  REP="M"
Return
#
#-------------------------------------------------------------------------------
$AVANT_MODFIC

Local  Integer LCDRET
Local  Char    LCDINT
Local  Date    WDATEFF
Local  Date    WDATCPTINT
Local Integer  L_RET, I
Local Date     L_CNXDAT(1..5)
Local Char     LPIECE

  GREASON = mess(92,7771,1)
  WDATEFF= [M:LEAL]RPUDAT


 # Issue X3-83749
 If GCNXPROIAS = G_OUI & ([M:LEA0]LEATYP = GVML_CREBAIL or [M:LEA0]LEATYP = GVML_LOCATION )
    # Génération d'un évènement de type "LEARPU" plan IAS
    LCDINT = "LEARPU"+num$(G301IAS)
    LPIECE = "0LRPU"
    WDATCPTINT=max([M:LEAL]RPUDAT, [M:LEA0]PERENDIAS)
    Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET) From GENEVE
    If (LCDRET > 20 )
      GOK = 0
      Call FSTA("ELEARPU") From GLOCK : Return
    Endif
    # Gosub CPTLEA
 Endif

Return
#==========================================================
# Comptabilisation actualisation du contrat

$CPTLEA
 If !clalev([F:E45]) : Local File ELEARPU[E45] : Endif

 Local Char    IDENT(20)(7)
 Local Integer STAT
 Local Char    MESSA(255)
 #*X3-39795 Local Char    TZONE(10)(1..1)   # Tableau des noms des zones à forcer
 #*X3-39795 Local Char    TVAL (10)(1..1)   # Tableau des valeurs des zones à forcer
 Local Char     TZONE(10)(1..10) : # Table des zones à forcer (Ex: type de pièce)
 Local Char     TVAL(30)(1..10)  : # Table des valeurs des zones à forcer

 If GCNXPROIAS = G_OUI  #*Fq-61084
    IDENT(0) = [M:LEA0]CPY
    IDENT(1) = "LEARPU"
    IDENT(2) = num$(G301IAS)
    IDENT(3) = [M:LEA0]FCY
    IDENT(4) = [M:LEA0]LEAREF
    IDENT(5) = func GENEVE.BUILD_TIMSTP(date$, time)
    IDENT(6) = GUSER

    TZONE(1) = "REFINT"    : TVAL(1) = "D-"+num$(NUMACT)
    TZONE(2) = "ORIGIN"    : TVAL(2) = "2"        :#Automatic loading  #*X3-39795
    TZONE(3) = "ORICOD"    : TVAL(3) = LPIECE                          #*X3-39795
    Call VALPCE3(LPIECE,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

    If STAT
       Infbox num$(STAT)-MESSA
    Else
       Update [E45] Where (CPY    = IDENT(0) &
&                          EVT    = IDENT(1) &
&                          PLN    = IDENT(2) &
&                          FCY    = IDENT(3) &
&                          REF    = IDENT(4) &
&                          TIMSTP = IDENT(5) &
&                          CREUSR = IDENT(6)) With CPTFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
          If fstat
             GOK=0 : Return
          Else
             # Infbox "enregistrements modifiés"-num$(adxuprec)
          Endif
      Endif
 Endif   #*Fq-61084

Return
#====================================================
#
$OK

  # Affectation pour mise à jour en sortie
  [M:LEA0]LEASTA = GVML_STRACHA     :  Affzo   [M:LEA0]LEASTA
  [M:LEA1]RPUDAT = [M:LEAL]RPUDAT   :  Affzo   [M:LEA1]RPUDAT
  [M:LEA1]RPUVAL = [M:LEAL]RPUVAL   :  Affzo   [M:LEA1]RPUVAL
  GRPUVAL        = [M:LEA1]RPUVAL
  Diszo [M:LEA0]
  Diszo [M:LEA1]
  Diszo [M:LEA2]
  G_ACT_MOD=1
  mkstat = 4
  FIN=1
Affzo   [M:LEAL]

 If G_ACT_MOD & !([M:OCP]NBOBJ=0) # S'il y a des modifs à reporter et si il y a des objets liés
  Global Char G_ACT_NAM           # On crée la variable G_ACt_NAM
  G_ACT_NAM="LEALEV"              # On l'alimente avec le nom de l'action en cours
 Endif

 Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$ABA

 Gosub DEBUT # Clic sur abandon, on recharge toutes les valeurs d'origine

Return
#
#====================================================
#
$FIN
 Gosub ACTION From TRTOBJACT
Return
#
#====================================================
#
#==============================================================#
# Traitement de mise à jour et de génération d'événement       #
# des biens liés lors d'un transfert                           #
#==============================================================#
$ACTMET
 Case ACTMET
  When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
  When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zone spé à l'action de l'en-tête [OAC0]
  When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise à jour et alimentation des objets liés
  When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables à mettre à jour dans MAJ_LNK
  When Default
 Endcase
Return
#==============================================================
$CRITMEN
 # Permet d'alimenter la variable CRITMEN, condition d'activation du menu
 CRITMEN='REP="" & [M:LEA0]LEASTA = GVML_STENCOU & [M:LEA0]LEATYP = GVML_CREBAIL'
Return
#==============================================================
$FILL_HEA
 # Permet d'alimenter d'autre élément de l'en-tête
Return
#==============================================================
$INIT_OBJ_DIV
Return
#==============================================================
$MAJ_LNK

Local Integer LCDRET
Local Integer LOK
Local Integer I_PLN
Local Integer STAT
Local Date    DPEREND
Local Date    DFIYEND
Local Decimal WACGETRNOT
Local Decimal WIASETRNOT
Local Decimal WDPRBAS
Local Decimal MTDES
Local Integer STAT

  If !(clalev([F:FAS])) : Local File FXDASSETS    [FAS]    : Endif
  If !(clalev([F:FIS])) : Local File FISCYEAR     [FIS]    : Endif
  If !(clalev([F:CNX])) : Local File CONTEXT      [CNX]    : Endif
  If !(clalev([F:EFS])) : Local File EFASCRT      [EFS]    : Endif
  If !(clalev([F:CAC])) : Local File GACCCODE     [CAC]    : Endif

For I_OBJ=0 To [M:OCP]NBOBJ-1          # Boucle sur les biens rattachés
  Read [FAS]FAS0=[M:OCP]OBJREF(I_OBJ)
  # Maj Type de détention du bien et nature d'entrée
  [F:FAS]OWNTYP      = GVML_TDPROPR           # en propriété
  [F:FAS]ETRNAT      = GVML_NERACHA           # rachat de crédit-bail
  #FQ-61084--- Calcul valeur entrée PCG
  #*1) si nombre de biens = 1 ==> Valeur entrée PCG = valeur rachat
  If [M:OCP]NBOBJ = 1
     [F:FAS]ACGETRNOT  =  [M:LEA1]RPUVALDEV
  Else
     #*2) si IAS géré et nombre de biens > 1 ==> Valeur entrée PCG = prorata de la Valeur entrée IAS
     If GCNXPROIAS = G_OUI
        If [M:OCP]IASBSETOT > 0 and [M:OCP]NBOBJ > 1
           WACGETRNOT= [M:LEA1]RPUVALDEV *([M:OCP]IASBSE(I_OBJ) /[M:OCP]IASBSETOT)
           Call GET_MNT_ARRONDI (WACGETRNOT, [M:LEA1]CUR, MTDES) From GLOBIENS
           [F:FAS]ACGETRNOT = MTDES
        Else
           #*3)Prorata de la base de taxe
           If   [M:OCP]TAXBASTOT > 0
              WACGETRNOT= [M:LEA1]RPUVALDEV *([M:OCP]TAXBAS(I_OBJ) /[M:OCP]TAXBASTOT)
              Call GET_MNT_ARRONDI (WACGETRNOT, [M:LEA1]CUR, MTDES) From GLOBIENS
              [F:FAS]ACGETRNOT = MTDES
           Endif
         Endif
     Else
        #*3)Prorata de la base de taxe
        If   [M:OCP]TAXBASTOT > 0
           WACGETRNOT= [M:LEA1]RPUVALDEV *([M:OCP]TAXBAS(I_OBJ) /[M:OCP]TAXBASTOT)
           Call GET_MNT_ARRONDI (WACGETRNOT, [M:LEA1]CUR, MTDES) From GLOBIENS
           [F:FAS]ACGETRNOT = MTDES
        Else #*4) Valeur entrée = 0
           [F:FAS]ACGETRNOT = 0
        Endif
     Endif
  Endif

  [F:FAS]IVCVATAMT =[F:FAS]ACGETRNOT * ([F:FAS]IVCVATRAT / 100 )
  Call GET_MNT_ARRONDI ([F:FAS]IVCVATAMT, [F:FAS]ACGCUR, [F:FAS]IVCVATAMT ) From GLOBIENS
  [F:FAS]DEDVATAMT =[F:FAS]IVCVATAMT * ([F:FAS]DEDVATRAT / 100 )
  Call GET_MNT_ARRONDI ([F:FAS]DEDVATAMT, [F:FAS]ACGCUR, [F:FAS]DEDVATAMT ) From GLOBIENS


  Read [CAC]CAC0=15; [M:LEA1]ACCCOD ; "SOC"
  If fstat=0
     [F:FAS]GAC    = [F:CAC]ACCCOD
  Else
     [F:FAS]GAC    = [F:FAS]IASACC        # = compte IAS
  Endif
  # Maj du compte PCG et de la nature PCG
  [F:FAS]GACACN = [F:FAS]IASACN     # = nature IAS
  #  sauvegarde du lien bien/contrat avant détachement
  [F:FAS]LEAREFORI=[M:LEA0]LEAREF
  [F:FAS]LEAREF=""                  #* détachement du bien

  # FQ56255
  # Point d'entrée avant mise à jour des biens rattachés
  # ----------------------------------------------------
  GPOINT="RW_FAS" : Gosub ENTREE From EXEFNC
  #* Fq-61084 Contexte, Bien à recalculer
  [F:FAS]FLGCLC          = G_OUI
  [F:FAS]FLGCNXCLC(0)    = G_OUI
  Rewrite [FAS]
  If fstat
    GOK=0 :   Break
  Endif

  If GOK=0 : Return : Endif

   Filter [FIS] Where (CPY=[M:LEA0]CPY & CNX=G300CPFI & STAFIY=GVML_TECOURA)
     Read[FIS]First
     DPEREND=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
   Filter [FIS]

  Read[CNX]CNX0= [M:LEA0]CPY; G300CPFI
  For I_PLN=1 To [F:CNX]NBPLC
    If  [F:CNX]ORIBASDPR(I_PLN-1) =   GVML_OBPCG
      Read [DEP]DEP0=[M:OCP]OBJREF(I_OBJ);[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;DPEREND
      If fstat <> 0
       GOK=0 :  Break
      Endif
      Read [FAS]FAS0=[M:OCP]OBJREF(I_OBJ)   #*Fq-61084
      #*-Fq-61084If  [M:OCP]IASBSETOT > 0
      #*-Fq-61084   WDPRBAS =  [M:LEA1]RPUVALDEV *([M:OCP]IASBSE(I_OBJ) /[M:OCP]IASBSETOT)
      #*-Fq-61084  Call GET_MNT_ARRONDI (WDPRBAS, [M:LEA1]CUR, MTDES) From GLOBIENS
      #*-Fq-61084   [F:DEP]DPRBAS = MTDES
      #*-Fq-61084Else
      #*-Fq-61084  [F:DEP]DPRBAS =  [M:LEA1]RPUVALDEV/[M:OCP]NBOBJ
      #*-Fq-61084Endif
      [F:DEP]DPRBAS = [F:FAS]ACGETRNOT #* Fq-61084
      [F:DEP]DEPSTA = GVML_SCNOCAL     #* Fq-61084
      [F:DEP]BSEVAL =  [F:DEP]DPRBAS #*FQ-72347
      [F:DEP]DPM =  "SA"
      [F:DEP]STRDPRDAT =  [M:LEA1]RPUDAT
      [F:DEP]DPRDUR =  0

      # FQ56255
      # Point d'entrée avant mise à jour des paramètres d'amortissement des rattachés
      # -----------------------------------------------------------------------------
      GPOINT="RW_DEP" : Gosub ENTREE From EXEFNC

      Rewrite [DEP]
      If fstat
        GOK=0 : Break
      Endif
    Endif

    If GOK=0 : Return : Endif

    #* Génération d'un événement d'acquisition pour chaque plan du contexte comptable et fiscal
    # des biens rattachés au contrat
    If [F:CNX]PLNCAA(I_PLN-1) < 6
       LCDINT= "FASCRT"+num$(I_PLN)
       Call GENER_EVE
&          (GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCDINT,[M:LEA1]RPUDAT,[0/0/0],LCDRET)
&      From GENEVE
       If (LCDRET > 20 )
          GOK = 0
          Call FSTA("EFASCRT") From GLOCK
          Break : Return
       Endif
       #=== fin ajout
    Endif
  Next I_PLN
Next I_OBJ


Return
#==========================================================
$CPTFAS

#-> Variables diverses

 Local Char    IDENT(20)(8)
 Local Integer STAT
 Local Char    MESSA(255)
 Local Char    TZONE(10)(1..1)   # Tableau des noms des zones à forcer
 Local Char    TVAL (10)(1..1)   # Tableau des valeurs des zones à forcer
 Local Char    LPIECE
 Local Char    LCDINT
 Local Date    WDATCPTINT

 LCDINT = "FASCRT"+num$(I_PLN)
 LPIECE = "CSRPU"

 WDATCPTINT = max([M:LEAL]RPUDAT,  [M:LEA0]PERENDCPT)

 IDENT(0) = [M:LEA0]CPY
 IDENT(1) = "FASCRT"
 IDENT(2) = num$(I_PLN)
 IDENT(3) = [M:LEA0]FCY
 IDENT(4) = [F:FAS]AASREF
 IDENT(5) = func GENEVE.BUILD_TIMSTP(date$, time)
 IDENT(6) = GUSER

 TZONE(1) ="REFINT"   : TVAL(1)= "D-"+num$(NUMACT)
 Call VALPCE3(LPIECE,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

 If STAT
    Infbox num$(STAT)-MESSA
 Else

     Update [EFS] Where (CPY   = IDENT(0) &
&                       EVT    = IDENT(1) &
&                       PLN    = IDENT(2) &
&                       FCY    = IDENT(3) &
&                       REF    = IDENT(4) &
&                       TIMSTP = IDENT(5) &
&                       CREUSR = IDENT(6) &
&                       EVTDAT = WDATCPTINT) With CPTFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
    If fstat
        GOK=0 : Return
    Else
      # Infbox "enregistrements modifiés"-num$(adxuprec)
    Endif
 Endif

Return
#====================================================
# C_date de levée d'option d'achat :
#====================================================
Subprog C_RPUDAT(VALEUR)
Variable Date    VALEUR

#
#  la date de levée d'option  doit être >= à la date de début de l'exercice
#  courant du contexte CPF
#
Local Date    RCNXDAT(1..5)
Local Integer RCRET

Call GET_CNX_DAT([M:LEA0]CPY,G300CPFI,RCNXDAT,RCRET) From GLOBIENS

If VALEUR < RCNXDAT(1)
  GERR= 1
  GMESSAGE= mess(51, 7771, 1)
  mkstat = 2
  End
Endif

End

#====================================================
# AM_date de levée d'option d'achat :
#====================================================
Subprog AM_RPUDAT(VALEUR)
Variable Date    VALEUR


#
#  la date de levée d'option  doit être >= à la date de début de l'exercice
#  courant du contexte CPF
#
Local Date    RCNXDAT(1..5)
Local Integer RCRET

Call GET_CNX_DAT([M:LEA0]CPY,G300CPFI,RCNXDAT,RCRET) From GLOBIENS

If VALEUR < RCNXDAT(1)
  GERR= 1
  GMESSAGE= mess(51, 7771, 1)
  mkstat = 2
  End
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LEALEV) 06/06/2007 11:38:02 (MDR)
######################################################################################
Subprog AM_RPUVAL(VALEUR)
Variable Decimal VALEUR
Local Decimal MTDES
Local Integer STAT

If VALEUR <> GRPUVAL
   [M:LEA1]RPUVAL = VALEUR : Affzo [M:LEA1]RPUVAL
   GRPUVAL = VALEUR
Endif

If VALEUR <> 0
    # ------------- Conversion en devise société
    Call CONVERT3([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP, [M:LEA1]STRLEADAT,
&                  VALEUR, MTDES, [M:LEA1]RATCUR, STAT) From CPTSUB
    If STAT = 0 Then
      Call GET_MNT_ARRONDI (MTDES, [M:LEA1]CUR, MTDES) From GLOBIENS
      [M:LEA1]RPUVALDEV = MTDES : Affzo [M:LEA1]RPUVALDEV
      [M:LEAL]RPUVALDEV = MTDES : Affzo [M:LEAL]RPUVALDEV
    Else
      GMESSAGE = mess(18,7773,1)
      GERR=1
      mkstat = 2
      End
    Endif

  If ( GCNXPROIAS = G_OUI )
    # ------------- Conversion en devise IAS
    Call CONVERT3([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP, [M:LEA1]STRLEADAT,
&                  VALEUR, MTDES, [M:LEA1]IASRATCUR, STAT) From CPTSUB
    If STAT = 0
      Call GET_MNT_ARRONDI (MTDES, [M:LEA1]IASCUR, MTDES) From GLOBIENS
      [M:LEA1]RPUVALIAS = MTDES : Affzo [M:LEA1]RPUVALIAS
    Else
      GMESSAGE = mess(18,7773,1)
      GERR=1
      mkstat = 2
      End
    Endif
   Endif
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LEALEV) 27/06/2007 15:35:51 (MDR)
######################################################################################
Subprog AP_RPUVAL(VALEUR)
Variable Decimal VALEUR

Call AM_RPUVAL(VALEUR)

End

