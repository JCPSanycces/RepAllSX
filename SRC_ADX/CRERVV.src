#<AdxTL>@(#)2.0.0.0 $Revision$
# Mask Management CRERVV
# Issue X3-40395 - 2017-05-24 by BAKHA : allow to create old versions during import

$ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "INIT_DIA"    : Gosub INIT_DIA
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE

  When "IMPZON"      : Gosub IMPZON
  When "CREATION"    : Gosub CREATION
Endcase
Return

############################################################################################
## Generate a new route version in development from the last one available to use
############################################################################################

$INIT
Local Char    ITM([V]GLONITM)
Local Char    FCY([V]GLONFCY)
Local Integer TRC, TYPREV

ITM = [L]PARAM(1)
FCY = [L]PARAM(2)
[L]PARAM(3)="0"

Gosub VERIF
If GERR=-1
   GMESSAGE=mess(63,198,1)-[L]ITM-[L]FCY+"\"+GMESSAGE : # Item
   GERR=1
Endif
If GERR : FIN=1 : Endif
Return

$VERIF
If !clalev([F:RVV])  : Local File RVMVAL    [RVV]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
If !clalev([F:TRO])  : Local File TABROUALT [TRO]  : Endif

Local Integer SEQ, ALT1, ALT2, NIV
Local Char    FCY1(GLONFCY)
Local Char    SAVFONCION([V]GLONAFC)

SAVFONCTION = GFONCTION

Read [ITM]ITM0 = [L]ITM
If !fstat
   NIV = func RVMLIB.NBRCPNROU([L]ITM)
Endif
If NIV<1
   GERR=1 : GMESSAGE = mess(153,187,1)-[L]ITM : # Versions not managed on this product
   Return
Endif
ALT1 =  [F:ITM]ECCROUALT(0)
If ALT1=0
   GERR=-1 : GMESSAGE = mess(340,193,1)-"("+mess(1,240,1)+")" : # Versioned routing code not defined
   Return
Endif

Filter [RVV] Where ITMREF=[L]ITM & FCY=[L]FCY
Read [RVV]RVV0 Last
Filter [RVV]
If fstat>2
   GERR=-1 : GMESSAGE = mess(308,193,1) : # Non existing version
   Return
Elsif [F:RVV]USESTA=1
   # Last version ... In development
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN-":"-mess(1,240,1)
   Return
Elsif [F:RVV]ENDDAT<>[0/0/0]
   Call TEXTFIC("RVMVAL","ENDDAT",1,GMESSAGE) From OBJDIV
   # Last version ... Ending date
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN-":"-GMESSAGE-"="-format$("D:"+GFMDAT4,[F:RVV]ENDDAT)+")"
   Return
Endif
[L]SEQ  = [F:RVV]ECCSEQ
[L]ALT2 = [F:RVV]ROUALT

If [L]ALT1=[L]ALT2
   GERR=-1 : GMESSAGE = mess(314,193,1)-"("+num$([L]ALT1)+")"-":"-mess(1,240,1)-","-mess(2,240,1) :  # Same BOM codes
   Return
Endif

Read [TRO]TRO0 = [L]ALT1
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT1)-":"-mess(152,193,1) : # Non existing routing code
   Return
Endif
[L]FCY1 =[F:TRO]FCY

Read [TRO]TRO0 = [L]ALT2
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT2)-":"-mess(152,193,1) : # Non existing routing code
   Return
Endif
If [L]FCY1<>[F:TRO]FCY
   GERR=-1 : GMESSAGE = func AFNC.MES2(mess(331,193,1),num$([L]ALT1),num$([L]ALT2)) : # Sites of routing codes $1$ and $2$ are not compatible
   Return
Endif

GFONCTION="CRERVV"
Call AUTORIS From EXEFNC
If GNBAUZ=0
  GERR=1
Elsif GUSRFCY(1)<>"\"
  If [L]FCY1<>""
     If !find([L]FCY1,GUSRFCY(1..GNBAUZ)) : GERR=1 : Endif
  Else
     # At least one authorized production site
     GERR=1
     Local File FACILITY [FCY]
     For [FCY]FCY0 Where MFGFLG=2
         If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ)) : GERR=0 : Break : Endif
     Next
  Endif
Endif
If GERR
   GMESSAGE=mess(1,123,1) : # Unauthorized function
   Return
Endif

# Lock management
If !func RVMLIB.LCKROH([L]FCY,[L]ITM,[L]ALT2)
   GERR=1 : GMESSAGE=[L]FCY-[L]ITM-num$([L]ALT2)+"\"+mess(10,100,1) : Return
Endif
Return

#############################################################

$SORTIE
GFONCTION=SAVFONCTION
Call AUTORIS From EXEFNC

Call DELOCK("ROH") From GLOCK : # Call DELOCK("ROH\") From GLOCK # Issue 118592 GH 20/09/2016
Return

#############################################################

$AVANT_PAR
If SAI : Raz [M:RVVB]INV : Endif : # to redo diszo instructions
Return

#############################################################

$INIT_DIA
Raz [M:RVVB]
[M:RVVB]FCY    = [L]FCY
[M:RVVB]ITMREF = [L]ITM
[M:RVVB]NIV    = [L]NIV

Read [RVV]RVV0 = [L]ITM;[L]FCY;[L]SEQ
If fstat : Raz [F:RVV] : Endif
[M:RVVB]ECCVALMAJ = [F:RVV]ECCVALMAJ
[M:RVVB]ECCVALMIN = [F:RVV]ECCVALMIN
[M:RVVB]STRDAT    = [F:RVV]STRDAT
[M:RVVB]ENDDAT    = [F:RVV]ENDDAT
[M:RVVB]ROUALT    = [F:RVV]ROUALT
[M:RVVB]DATCRE=max(date$,[M:RVVB]STRDAT)+1
[M:RVVB]TYPCRE    = [L]NIV
Call AM_TYPCRE([M:RVVB]TYPCRE)
Return

#############################################################

$CONTROLE
If [M:RVVB]NEWVALMAJ="" | ([M:RVVB]TYPCRE=2 & [M:RVVB]NEWVALMIN="")
   Call LIENS("AMK","AMSK","CRERVV","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
   Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
   GERR=1 : GMESSAGE+="\"+mess(141,143,1)
   SAI=1
Else
   Look [RVV]RVV1 = [L]ITM;[L]FCY;[M:RVVB]NEWVALMAJ;[M:RVVB]NEWVALMIN
   If !fstat
      Call LIENS("AMK","AMSK","CRERVV","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
      Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
      GERR=1 : GMESSAGE+="\"+mess(61,127,1)
      SAI=1
   Endif
Endif
Return

#############################################################

$EXEC
GOK=1
[L]TYPREV = 2-([M:RVVB]ECCVALMAJ<>[M:RVVB]NEWVALMAJ) : # 1 = major / 2=minor

If ![V]GSERVEUR & GTRACE=""
   Call OUVRE_TRACE(TITCRIT) From LECFIC
   TRC=1
Endif

Call TR_EXEC1([L]ITM,[L]FCY,[M:RVVB]DATCRE,[M:RVVB]NEWVALMAJ,[M:RVVB]NEWVALMIN,[L]ALT1,[L]ALT2,[L]SEQ,[L]TYPREV,"CRERVV")
If GOK<1 or GERR=1 : SAI=1 : Endif
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
If SAI=1 : Return : Endif

[L]PARAM(3) = num$([L]SEQ+1)
Return

#############################################################
## Duplication (header + lines + text) of the last route available to use into a new one in development
## + Setting of a new version associated with this route in development

Subprog TR_EXEC1(ITM,FCY,DATCRE,VMAJ,VMIN,ALT1,ALT2,SEQ,TYPREV,TRTSUI)
Value Char    ITM()
Value Char    FCY
Value Date    DATCRE
Value Char    VMAJ(), VMIN()
Value Integer ALT1, ALT2
Value Integer SEQ, TYPREV
Value Char    TRTSUI()

Local Char ABREV(GLONAOB), TRTGBM(GLONADC)

[L]TRTGBM="CRERVV"
[L]ABREV="ROU"

If dim([V]GDATEREF)=1
   Local Date SAVDATEREF
   [L]SAVDATEREF = [V]GDATEREF
Endif

Gosub DEFVAR From OBJSIM

Gosub TR

Gosub RESTGLO From OBJSIM

If dim([V]GDATEREF)=1 & dim([L]SAVDATEREF)=1
   [V]GDATEREF=[L]SAVDATEREF
Endif
End

$TR
Read [ROH]ROH0 = [L]ITM;[L]ALT2;[L]FCY
If fstat
   GOK=0 : Call RSTA("ROH",[L]ITM-num$([L]ALT2)-[L]FCY) From GLOCK : Return
Endif

GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[V]GREP="D" : [M:ROU0]NEWALT = [L]ALT1
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
[L]ACTION="RAZDUP" : Gosub ACTION From GOBJSUB
For [L]MA=0 To [L]NBMASK
  Gosub SETMASK From =[L]WINPROG
  Call SAIMSK("","IMPZON","CRERVV") From ="W0"+[L]NOMMSK([L]MA)
  If mkstat : [V]GOK=0 : Break : Endif
Next

If [V]GOK>0
   If !adxlog
     Gosub CREATION From GOBJET1
   Else
     Gosub CREATION From OBJSIM
   Endif
Endif
Setmode

If GOK>0 & [L]TRTSUI<>""
   ACTION = "APRES_REV" : Gosub ACTION From =[L]TRTSUI
Endif
Return

$IMPZON
Case IMPZON
   When "ROUALT" : [M]ROUALT = [M:ROU0]NEWALT
Endcase
Return

$CREATION
Call DUPTEXTRA("ROUTING","ROUDESAXX",[M:ROU0]ITMREF+"~"+num$([L]ALT2),[L]FCY
&             ,"ROUTING","ROUDESAXX",[M:ROU0]ITMREF+"~"+num$([M:ROU0]ROUALT),[L]FCY) From ATEXTRA

Raz [F:RVV]
[F:RVV] = [F:ROH]
[F:RVV]ECCSEQ    = [L]SEQ+1
[F:RVV]STRDAT    = [L]DATCRE
[F:RVV]ECCVALMAJ = [L]VMAJ
[F:RVV]ECCVALMIN = [L]VMIN
[F:RVV]EXNFLG    = 1

Write [RVV]
If fstat
   GOK=0 : Call FSTA("RVV") From GLOCK : Return
Endif
Return

#**----------------------------------------------------------------<br/>
#* Generate of a new route version in development from the last one available to use
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM    = Product
#* @param FCY    = Site
#* @param DATCRE = Start date of new version in development
#* @param VMAJ   = New major version number
#* @param VMIN   = New minor version number
#**<br/>----------------------------------------------------------------
#*!

Subprog TR_EXEC2(ITM,FCY,DATCRE,VMAJ,VMIN,TRTSUI, OPT)
Value Char    ITM()
Value Char    FCY     # Issue X3-40395 - changed to char instead of integer
Value Date    DATCRE
Value Char    VMAJ(), VMIN()
Value Char    TRTSUI()
Value Char    OPT()     # Issue X3-40395 : allow to create old versions during import

Local Integer TRC, TYPREV

# INIT
GERR=0 : GMESSAGE="" : GOK=1
Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Item
   GERR=1
Endif
If GERR : Goto FIN2 : Endif

# C_DATCRE
Read [RVV]RVV0 = [L]ITM;[L]FCY;[L]SEQ
If fstat
   GERR=1 : GMESSAGE = mess(308,193,1) : # Non existing version
Elsif [L]DATCRE <= [F:RVV]STRDAT
   GERR=1 : GMESSAGE = mess(312,193,1) : # Date <= starting validity of the last version
Elsif [L]DATCRE <= date$
&   & instr(1,OPT,"D")=0    # Issue X3-40395 - allow to create old versions during import
   GERR=1 : GMESSAGE = mess(72,199,1) : # Date must be after current date
Endif
If GERR : Goto FIN2 : Endif

# CONTROLE
If [L]VMAJ="" | ([L]NIV=2 & [L]VMIN="")
   Call LIENS("AMK","AMSK","CRERVV","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
   Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
   GERR=1 : GMESSAGE-=":"-mess(141,143,1)
Else
   Look [RVV]RVV1 = [L]ITM;[L]FCY;[L]VMAJ;[L]VMIN
   If !fstat
      Call LIENS("AMK","AMSK","CRERVV","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
      Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
      GERR=1 : GMESSAGE-=[L]VMAJ-[L]VMIN-":"-mess(61,127,1)
   Endif
Endif
If GERR : Goto FIN2 : Endif

[L]TYPREV = 2-([F:RVV]ECCVALMAJ<>[L]VMAJ) : # 1 = major / 2=minor

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

If ![V]GSERVEUR & GTRACE=""
   Local Char TIT([V]GLONDES)
   Call TITAWI("DCRERVV",TIT) From OBJDIV
   Call OUVRE_TRACE(TIT) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]FCY,[L]DATCRE,[L]VMAJ,[L]VMIN,[L]ALT1,[L]ALT2,[L]SEQ,[L]TYPREV,[L]TRTSUI)
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

$FIN2
Gosub SORTIE
End

######################################################################################
## Labels for screen CRERVV  16/02/2015 15:18:25 (GH)
######################################################################################

Subprog D_INV(VALEUR)
Variable Char    VALEUR

If [M:RVVB]NIV=1
   [M:RVVB]TYPCRE=1 : Affzo [RVVB]TYPCRE : Diszo [RVVB]TYPCRE
Else
   Actzo [RVVB]TYPCRE
Endif
End

######################################################################################

Subprog C_DATCRE(VALEUR)
Variable Date    VALEUR

If [M:RVVB]ECCVALMAJ=""
   GMESSAGE = mess(311,193,1)+"\"+mess(10,123,1) : mkstat=2 : # Last version\Mandatory field
Elsif VALEUR <= [M:RVVB]STRDAT
   GMESSAGE = mess(312,193,1) : mkstat=2 : # Date <= starting validity of the last  version
Elsif VALEUR <= date$
   GMESSAGE = mess(72,199,1) : mkstat=2 : # Date must be after current date
Endif
End

######################################################################################

Subprog AM_TYPCRE(VALEUR)
Variable Integer VALEUR

If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
Local Integer STAT
Local Char    MSG(250)

If [F:ITM]ITMREF<>[M:RVVB]ITMREF
   Read [ITM]ITM0 = [M:RVVB]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

Raz [M:RVVB] NEWVALMAJ, NEWVALMIN
Case VALEUR
  When 1 : # major revision
    Call CALCUL([F:ITM]ECCMAJ,[M:RVVB]ECCVALMAJ,[M:RVVB]NEWVALMAJ,MSG,STAT) From SUBICV
    If [M:RVVB]ECCVALMIN<>"" & [L]STAT=0
       Call CALCUL([F:ITM]ECCMIN,"",[M:RVVB]NEWVALMIN,MSG,STAT) From SUBICV
    Endif
  When 2 : # minor revision
    [M:RVVB]NEWVALMAJ = [M:RVVB]ECCVALMAJ
    Call CALCUL([F:ITM]ECCMIN,[M:RVVB]ECCVALMIN,[M:RVVB]NEWVALMIN,MSG,STAT) From SUBICV
Endcase
If STAT
   Raz [M:RVVB] NEWVALMAJ, NEWVALMIN
Endif
Affzo [RVVB] NEWVALMAJ, NEWVALMIN
End

