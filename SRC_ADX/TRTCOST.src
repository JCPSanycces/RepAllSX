#<AdxTL>@(#)6.0.0.0 $Revision$
#<gen>
# ECR_TRACE : Pour redirection erreurs dans configurateur
# DESCEND : Descente de nomenclature récursive
# SAVITC : Enregistrement du calcul de coût dans le fichier ITMCOST [ITC] avec n° de process
# SAVICN : Enregistrement des natures de FG
# SAVICC : Enregistrement du détail des matières et sous-produits
# SAVIWC : Enregistrement du détail des opérations (machine, main d'oeuvre et sous-traitance)
#</gen>

##################################################################
# Pour redirection erreurs dans configurateur
Subprog ECR_TRACE(TEX,ERR)
Value    Char    TEX() : # Texte du message
Value    Integer ERR   : # 0=Information, <>0=Erreur
If clalev([M:CFV4]) > 0
  Call CFG_CSTERR(TEX,ERR) From CFGLIBD
Else
  Call ECR_TRACE(TEX,ERR) From GESECRAN
Endif
End

####################################
# Descente de nomenclature récursive
####################################
Subprog DESCEND(PITM,PECCMAJ,PECCMIN,PFCY,PDAT,PALT,PALTTYP, PLLC,PFXDDSP, PARRQTYCPN,PRET)
Value    Char    PITM
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Char    PFCY
Value    Date    PDAT
Value    Integer PALT
Value    Integer PALTTYP
Value    Integer PLLC
Value    Integer PFXDDSP
Value    Integer PARRQTYCPN
Variable Integer PRET

Local Decimal LQTN, LQTNA, LQTB, LQTBA, WPRIX
Local Decimal SQTY : # pour sauvegarder les qtés aux noeuds de l'arborescence
Local Integer J
Local Char    ERR_TRA(132)
Local Integer LBODTYP

LBODTYP=PALTTYP
PRET = 1
# UN NIVEAU DE LOCALITÉ à CHAQUE APPEL
Local File BOMD [BOD] Where ITMREF = PITM & BOMALT = PALT & BOMALTTYP = LBODTYP
&          & BOMSTRDAT<= PDAT & (BOMENDDAT>=PDAT | BOMENDDAT=[0/0/0])
&          & CPNTYP <> 5
Read [BOD] First
# Si l'on trouve un composant, on incrémente le niveau
# Attention BOMEXIFLG ne tient pas compte de la validité, on peut ne trouver aucun lien
If fstat
    LBODTYP=5-PALTTYP
    Close Local File [BOD]
    Local File BOMD [BOD] Where ITMREF = PITM & BOMALT = PALT & BOMALTTYP = LBODTYP
&              & BOMSTRDAT<= PDAT & (BOMENDDAT>=PDAT | BOMENDDAT=[0/0/0])
&              & CPNTYP <> 5
    Read [BOD] First
Endif
If !fstat
    J = 1  : # il existe au moins un lien
    GNIV += 1
Endif

While !fstat
    SQTY = GQTY
#  CALCUL de la qté pour ce lien
#  La qté calculée deviendra la qté multiplicatrice pour le niveau inférieur
    Read [ITM]ITM0=[F:BOD]CPNITMREF
    Read [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;LBODTYP # BOH perdu par la récursivité !
    If [F:BOD]LIKQTY <> 0
        # Issue 115910 - 2016-04-25 by ERMIL : Use COEF from BOM line to convert service item.  Also convert to STU if applicable
        If [F:BOD]CPNTYP = 7 & [F:BOD]BOMSTUCOE<>0
            GQTY /= [F:BOD]BOMSTUCOE
            Call CONVERT_QTY ([F:BOD]BOMUOM,[F:ITM]STU,GQTY) From TRTX3
        Endif
        # 115910.en
        Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,
&               [F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
        If dim(GSCAMAJ)>0 & GSCAMAJ = 1    # Issue 88918 GA 05/2013 ajout du dim()
            If LQTNA<>0 & PARRQTYCPN=2
                GQTY = LQTNA
            Else
                GQTY = LQTN
            Endif
        Else
            If LQTBA<>0 & PARRQTYCPN=2
                GQTY = LQTBA
            Else
                GQTY = LQTB
            Endif
        Endif
    Else
        GQTY = 0
    Endif

    If [F:ITM]STOMGTCOD=3 & [F:ITM]DEFPOT<>0
       # Issue 83670 GA 07/2012 voir aussi FUNMFGS
       # GQTY = GQTY / [F:ITM]DEFPOT/100
        GQTY = GQTY * 100 / [F:ITM]DEFPOT
    Endif

   # CCC (01/08/05) Bug 31245
    If [F:BOD]LIKQTYCOD=2 & PFXDDSP=1
        Local Decimal COE_PRO
        Read [ITF]=PITM;PFCY
        # calcul du coeff pour répartir les cout fixes au prorata:
        If [F:ITF]REOMINQTY <> 0
             COE_PRO = SQTY / [F:ITF]REOMINQTY
        Elsif [F:ITF]MFGLOTQTY <> 0
             COE_PRO = SQTY / [F:ITF]MFGLOTQTY
        Else
             COE_PRO = 1
        Endif
        GQTY *= COE_PRO
    Endif

   GPE=0
   GPOINT = "APQTYDES" : Gosub ENTREE From EXEFNC # (13328)      25/03/02

#  Si l'enreg Article-site n'existe pas : erreur bloquante
   Read [ITF]ITF0 = [F:BOD]CPNITMREF;PFCY
   If fstat
      If [F:BOD]SCOFLG<>3   # Dans le cas d'un article founi par un sous-traitant, l'article-site n'existe pas forcément
          ERR_TRA = mess(4,198,1)-mess(23,100,1)-[F:BOD]CPNITMREF - PFCY
          Call ECR_TRACE(ERR_TRA,1)
          PRET = 0
          Break
      Endif
   Else
      If GPE>0 | [F:BOD]CSTFLG=2 & GQTY<>0 & evalue("[F:ITF]"+[M:DIA]CSTTYPA+"CSTUPD") <> 2
         Read [F:ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;2
         Gosub ECRMAW : # ecrire tous niveaux dans le fichier de travail avant de descendre
         If GOK < 1
            PRET = 0 : Break
         Endif
         If GPE=2 | [F:ITB]BOMEXIFLG = 2
             # Issue 104223 - 2015-03-27 by CCC : add LLC in parameters because [F:ITB]LLC=0 for by-products but
             # in [F:MAW] they have to be considered as components to be calculated before main product
             #Call DESCEND ([F:BOD]CPNITMREF,PFCY,PDAT,PALT,PALTTYP,PFXDDSP,PARRQTYCPN,PRET)
             Call DESCEND ([F:BOD]CPNITMREF,[F:BOD]ECCVALMAJ,[F:BOD]ECCVALMIN,PFCY,PDAT,PALT,PALTTYP,[F:MAW]LLC,PFXDDSP,PARRQTYCPN,PRET)
             If PRET = 0 : Break : Endif
         Endif
      Endif
   Endif

   GQTY = SQTY
   Read [BOD] Next
Wend
# retour du sous-pro = remontée d'un niveau
If J = 1 : GNIV -= 1 : Endif
Close Local File              # 28/01/02 pour libérer la mémoire
End

$ECRMAW
#------#  Ecriture du fichier de travail. La transaction est dans SUBICC !
# CCC (06/10/04) Bug 25480 : Distinction de la matière et du sous-produit avec même code article
Readlock [MAW]MAW0 = adxuid(1);PFCY;[F:BOD]CPNITMREF;[F:BOD]ECCVALMAJ;[F:BOD]ECCVALMIN;[F:BOD]CPNTYP
If fstat = 1
   GOK = -1 : GLOCK = "$MATCSTW"+num$(adxuid(1))+[F:BOD]CPNITMREF
Elsif fstat = 0
  If dim(GITCSHR) > 0
      If GITCSHR = 1 : GQTY *= (1+[F:ITF]SHR/100) : Endif
  Endif
#  réecrire l'enreg en ajoutant la quantité
  If GNIV = 1
    [F:MAW]MATQTYTOP += GQTY
  Elsif GNIV > 1
    [F:MAW]MATQTYSSE += GQTY
  Endif
  # Issue 104223 - 2015-03-26 by CCC : LLC of pure by-product is 0 so we have to set a LLC as components
  [F:MAW]LLC    = max([F:MAW]LLC,PLLC+1)
  # Issue 117352 - 2016-07-01 by CCC : need to cumulate quantities => optimization can't be done like this
  #[F:ITB]BOMEXIFLG = 1 # Avoid to go trough its BOM again

  Rewrite [MAW]
  If fstat
    # erreur d'écriture sur le fichier MAW (bloquante)     (20/08/01)
    ERR_TRA = mess(13,100,1)-"MATCSTW :"- [F:BOD]CPNITMREF
    Call ECR_TRACE(ERR_TRA,1)
    GOK = 0
  Endif
Elsif fstat = 5
#  CREATION DE l'Enreg en alimentant la quantité...
  Raz [F:MAW]
  [F:MAW]CSTUPD = evalue("[F:ITF]"+[M:DIA]CSTTYPA+"CSTUPD")
  [F:MAW]MAWUID = adxuid(1)
  [F:MAW]ITMREF = [F:BOD]CPNITMREF
  [F:MAW]ECCVALMAJ = [F:BOD]ECCVALMAJ
  [F:MAW]ECCVALMIN = [F:BOD]ECCVALMIN
  [F:MAW]CPNTYP = [F:BOD]CPNTYP
  [F:MAW]ROUOPE = [F:BOD]CPNOPE
  [F:MAW]STU    = [F:ITM]STU
  [F:MAW]STOFCY = PFCY
  # Issue 104223 - 2015-03-26 by CCC : LLC of pure by-product is 0 so we have to set a LLC value as components
  #[F:MAW]LLC    = max([F:ITB]LLC)
  [F:MAW]LLC    = max([F:ITB]LLC,PLLC+1)
  [F:MAW]BRDCOD = [F:ITM]BRDCOD
  [F:MAW]OVECOD = [F:ITF]OVECOD
  If dim(GITCSHR) > 0
      If GITCSHR = 1 : GQTY *= (1+[F:ITF]SHR/100) : Endif
  Endif
  If GNIV = 1
   [F:MAW]MATQTYTOP = GQTY
  Elsif GNIV > 1
   [F:MAW]MATQTYSSE = GQTY
  Endif
  [F:MAW]CREDAT = date$
  [F:MAW]CREUSR = GUSER
  Write [MAW]
  If fstat
    # erreur d'écriture sur le fichier MAW (bloquante)     (20/08/01)
    ERR_TRA = mess(13,100,1)-"MATCSTW :"- [F:BOD]CPNITMREF
    Call ECR_TRACE(ERR_TRA,1)
    GOK = 0
  Endif
Endif
# CCC 22/06/04 : Demande PE 22340 reportée en 140 au cas où
GPOINT = "APECRMAW" : Gosub ENTREE From EXEFNC

Return

###############################################################################
# Enregistrement du calcul de coût dans le fichier ITMCOST [ITC] avec n° de process
###############################################################################
Subprog SAVITC(PCSTTYP,PFIYNUM,PSTRDAT,PENDDAT,PUPDFLG,PSLTMAT,PVLTCCE,PDESC,PRET)
Value Integer PCSTTYP
Value Shortint PFIYNUM
Value Date    PSTRDAT
Value Date    PENDDAT
Value Integer PUPDFLG
Value Integer PSLTMAT
Value Integer PVLTCCE
Value Integer PDESC
Variable Integer PRET

Local Integer IT_BRD, LEXI, LTRANS, I

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif

Gosub PART1

Raz PRET
# Il ne faut pas effacer ce qu'on vient de lire car si on est à NIV=2 alors on vient de lire les valeurs de NIV=0
#Raz [F:ITC]

# si le parametre Màj=OUI l'écriture de ITC se fait globalement à la fin (SUBICC)
If adxlog=0
    Trbegin [ITC]
    LTRANS = 1
Endif

Gosub PART2

Gosub PART3

If LEXI
    Gosub REWRITE_ITC
Else
    Gosub WRITE_ITC
Endif

#  traiter erreur en écriture
If fstat
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1)-"(re)write [ITC] fstat="+num$(fstat) - [M:CTP]ITMREF
    Call ECR_TRACE(ERR_TRA,1)
    PRET=1
    Raz GOK
Else
    If LTRANS
        Commit
    Endif
Endif

$FIN

End

$PART1
Filter [ITC] Where ITMREF = [M:CTP]ITMREF
&                & STOFCY = [M:CST0]STOFCY
&                & CSTTYP = PCSTTYP
&                & ITCSTRDAT = PSTRDAT
&                & ITCENDDAT = PENDDAT
&                & UID    = adxuid(1)
&                & ECCVALMAJ = [M:CTP]ECCVALMAJ
&                & ECCVALMIN = [M:CTP]ECCVALMIN
Readlock [ITC]ITC0 First
Filter [ITC]
If fstat = 1
    ERR_TRA = mess(14,100,1)-"fstat="+num$(fstat) - [M:CTP]ITMREF
    Call ECR_TRACE(ERR_TRA,1)
    LRET=1
    Return
Elsif !fstat
    LEXI = 1
    LSEQ = [F:ITC]ITCSEQ
Elsif fstat
    Raz [F:ITC]
    Filter [ITC] Where ITMREF = [M:CTP]ITMREF
&                    & STOFCY = [M:CST0]STOFCY
&                    & CSTTYP = PCSTTYP
    Read [ITC]ITC0 First
    Filter [ITC]
    LEXI = 0
    LSEQ = [F:ITC]ITCSEQ+1
Endif
Return

$PART2
[F:ITC] = [M:CTP]    #  Récupération de paramètres
[F:ITC]STOFCY = [M:CST0]STOFCY
[F:ITC]CSTTYP = PCSTTYP
[F:ITC]ITCSEQ = LSEQ
[F:ITC]UID    = adxuid(1)
## GH 19/03/2014 bug 86229
#[F:ITC]PRNUID = adxuid(1)   # Issue 72002 - 2011-03-01 by CCC
If [M:CTP]PRNNUM=0
   [M:CTP]PRNNUM = uniqid([F:ITC])
Endif
[F:ITC]PRNUID  = [M:CTP]PRNNUM
##
[F:ITC]FIYNUM = PFIYNUM
[F:ITC]CLCQTY = [M:CTP]QTYCLC
[F:ITC]ITCDAT = [M:CTP]CLCDAT   # Issue 84066 - 2014-07-03 by CCC : before it was date$
[F:ITC]ITCSTRDAT = PSTRDAT
[F:ITC]ITCENDDAT = PENDDAT
[F:ITC]SLTMATCST = PSLTMAT
[F:ITC]VLTCCERAT = PVLTCCE
[F:ITC]DESCEND   = PDESC

# ramener au cout unitaire, affecter les couts totaux ...xxxCST = coût dont coût niveau=xxxLEV
# méthode après mail du 29/10 :
# ajouter les FIXES AVANT la division (comme dans P2),
# ramener les fixes à l'unitaire car ils ont été calculés pour la quantité QTE_CAL

If [M:CTP]NIV=1
    Raz [F:ITC]MATLEV0, [F:ITC]FXDMATLEV0
Endif

For IT_BRD = 0 To GACTMAT-1
    If [M:CTP]NIV=2
# Issue 78111 - 2011-12-23 by CCC
#        [F:ITC]MATCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFMATCST(I*GACTMAT+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]MATCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)
&                                                       *([M:CST]IMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFMATCST(I*GACTMAT+IT_BRD)
&                                                        +[M:CST]ISMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFSMATCST(I*GACTMAT+IT_BRD))
&                                    )/ [M:CTP]QTYCLC
        [F:ITC]FXDMATCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFMATCST(I*GACTMAT+IT_BRD)))/ [M:CTP]QTYCLC

# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]MATCST(IT_BRD) = arr([F:ITC]MATCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDMATCST(IT_BRD) = arr([F:ITC]FXDMATCST(IT_BRD),10^-GDECPRI)
    Else
# Issue 78111 - 2011-12-23 by CCC
#        [F:ITC]MATLEVCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*( [M:CST]IMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFMATCST(I*GACTMAT+IT_BRD) ))/ [M:CTP]QTYCLC
        [F:ITC]MATLEVCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)
&                                                       *([M:CST]IMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFMATCST(I*GACTMAT+IT_BRD)
&                                                        +[M:CST]ISMATCST(I*GACTMAT+IT_BRD) + [M:CST]IFSMATCST(I*GACTMAT+IT_BRD))
&                                    )/ [M:CTP]QTYCLC
        [F:ITC]FXDMATLEV(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFMATCST(I*GACTMAT+IT_BRD)))/ [M:CTP]QTYCLC

        [F:ITC]MATLEV0 += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IMATLEV0(I*GACTMAT+IT_BRD)+[M:CST]IFMATLEV0(I*GACTMAT+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]FXDMATLEV0 += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFMATLEV0(I*GACTMAT+IT_BRD)))/ [M:CTP]QTYCLC

# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]MATLEVCST(IT_BRD) = arr([F:ITC]MATLEVCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDMATLEV(IT_BRD) = arr([F:ITC]FXDMATLEV(IT_BRD),10^-GDECPRI)
    Endif
Next

# Les éléments de facture sont mis dans le coût matière pour les coûts standard
# Issue 79521 - 2012-03-22 by CCC : famille de coût de l'article au lieu de la 1ère
If [F:ITM]ITMREF<>[F:ITC]ITMREF
    Read [F:ITM]ITM0=[F:ITC]ITMREF
Endif
IT_BRD = max(0,[F:ITM]BRDCOD-1)
If [M:CTP]NIV=2
    [F:ITC]MATCST(IT_BRD) += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IINVDTA(I) + [M:CST]IFINVDTA(I)))/ [M:CTP]QTYCLC
    [F:ITC]FXDMATCST(IT_BRD) += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFINVDTA(I)))/ [M:CTP]QTYCLC
Else
    [F:ITC]MATLEVCST(IT_BRD) += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IINVDTA(I) + [M:CST]IFINVDTA(I)))/ [M:CTP]QTYCLC
    [F:ITC]FXDMATLEV(IT_BRD) += sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFINVDTA(I)))/ [M:CTP]QTYCLC
Endif

For IT_BRD = 0 To GACTMAC-1
    If [M:CTP]NIV=2
        [F:ITC]MACCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IMACCST(I*GACTMAC+IT_BRD) + [M:CST]IFMACCST(I*GACTMAC+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]FXDMACCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFMACCST(I*GACTMAC+IT_BRD)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]MACCST(IT_BRD) = arr([F:ITC]MACCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDMACCST(IT_BRD) = arr([F:ITC]FXDMACCST(IT_BRD),10^-GDECPRI)
    Else
        [F:ITC]MACLEVCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IMACCST(I*GACTMAC+IT_BRD) + [M:CST]IFMACCST(I*GACTMAC+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]FXDMACLEV(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFMACCST(I*GACTMAC+IT_BRD)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]MACLEVCST(IT_BRD) = arr([F:ITC]MACLEVCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDMACLEV(IT_BRD) = arr([F:ITC]FXDMACLEV(IT_BRD),10^-GDECPRI)
    Endif
Next
For IT_BRD = 0 To GACTLAB-1
    If [M:CTP]NIV=2
        [F:ITC]LABCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]ILABCST(I*GACTLAB+IT_BRD) + [M:CST]IFLABCST(I*GACTLAB+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]FXDLABCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFLABCST(I*GACTLAB+IT_BRD)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]LABCST(IT_BRD) = arr([F:ITC]LABCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDLABCST(IT_BRD) = arr([F:ITC]FXDLABCST(IT_BRD),10^-GDECPRI)
    Else
        [F:ITC]LABLEVCST(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]ILABCST(I*GACTLAB+IT_BRD) + [M:CST]IFLABCST(I*GACTLAB+IT_BRD)))/ [M:CTP]QTYCLC
        [F:ITC]FXDLABLEV(IT_BRD) = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFLABCST(I*GACTLAB+IT_BRD)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        [F:ITC]LABLEVCST(IT_BRD) = arr([F:ITC]LABLEVCST(IT_BRD),10^-GDECPRI)
#        [F:ITC]FXDLABLEV(IT_BRD) = arr([F:ITC]FXDLABLEV(IT_BRD),10^-GDECPRI)
    Endif
Next
Return

$PART3

If [M:CTP]NIV=2
    [F:ITC]SCOCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]ISCOCST(I) + [M:CST]IFSCOCST(I)))/ [M:CTP]QTYCLC
    [F:ITC]FXDSCOCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFSCOCST(I)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    [F:ITC]SCOCST = arr([F:ITC]SCOCST,10^-GDECPRI)
#    [F:ITC]FXDSCOCST = arr([F:ITC]FXDSCOCST,10^-GDECPRI)
Else
    [F:ITC]SCOLEVCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]ISCOCST(I) + [M:CST]IFSCOCST(I)))/ [M:CTP]QTYCLC
    [F:ITC]FXDSCOLEV = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IFSCOCST(I)))/ [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    [F:ITC]SCOLEVCST = arr([F:ITC]SCOLEVCST,10^-GDECPRI)
#    [F:ITC]FXDSCOLEV = arr([F:ITC]FXDSCOLEV,10^-GDECPRI)
Endif

If [M:CTP]NIV=2
    [F:ITC]OVEMATCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVEMATCST(I) + [M:CST]IFOMATCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVEMAT = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOMATCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVEMACCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVEMACCST(I) + [M:CST]IFOMACCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVEMAC = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOMACCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVELABCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVELABCST(I) + [M:CST]IFOLABCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVELAB = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOLABCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVESCOCST = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVESCOCST(I) + [M:CST]IFOSCOCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVESCO = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOSCOCST(I)) / [M:CTP]QTYCLC

# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    [F:ITC]OVEMATCST = arr([F:ITC]OVEMATCST,10^-GDECPRI)
#    [F:ITC]OVEMACCST = arr([F:ITC]OVEMACCST,10^-GDECPRI)
#    [F:ITC]OVELABCST = arr([F:ITC]OVELABCST,10^-GDECPRI)
#    [F:ITC]OVESCOCST = arr([F:ITC]OVESCOCST,10^-GDECPRI)
#    [F:ITC]FXDOVEMAT = arr([F:ITC]FXDOVEMAT,10^-GDECPRI)
#    [F:ITC]FXDOVEMAC = arr([F:ITC]FXDOVEMAC,10^-GDECPRI)
#    [F:ITC]FXDOVELAB = arr([F:ITC]FXDOVELAB,10^-GDECPRI)
#    [F:ITC]FXDOVESCO = arr([F:ITC]FXDOVESCO,10^-GDECPRI)

    [F:ITC]OVEPRD = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*(func TRTCST.SUMOVE("P",0,[M:CST]ILNK(I)))) / [M:CTP]QTYCLC

    [F:ITC]OVETOT = [F:ITC]OVEMATCST+[F:ITC]OVEMACCST+[F:ITC]OVELABCST+[F:ITC]OVESCOCST
Else
    [F:ITC]OVEMATLEV  = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVEMATCST(I) + [M:CST]IFOMATCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVEMATL = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOMATCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVEMACLEV  = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVEMACCST(I) + [M:CST]IFOMACCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVEMACL = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOMACCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVELABLEV  = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVELABCST(I) + [M:CST]IFOLABCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVELABL = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOLABCST(I)) / [M:CTP]QTYCLC
    [F:ITC]OVESCOLEV  = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*([M:CST]IOVESCOCST(I) + [M:CST]IFOSCOCST(I))) / [M:CTP]QTYCLC
    [F:ITC]FXDOVESCOL = sigma(I=0,[M:CST]NBITM-1,([M:CST]ITMREF(I)=[M:CTP]ITMREF)*[M:CST]IFOSCOCST(I)) / [M:CTP]QTYCLC

    [F:ITC]OVELEVCST = ([F:ITC]OVEMATLEV + [F:ITC]OVEMACLEV+[F:ITC]OVELABLEV + [F:ITC]OVESCOLEV)
    [F:ITC]FXDOVELEV = ([F:ITC]FXDOVEMATL + [F:ITC]FXDOVEMACL+[F:ITC]FXDOVELABL + [F:ITC]FXDOVESCOL)

# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    [F:ITC]OVEMATLEV = arr([F:ITC]OVEMATLEV,10^-GDECPRI)
#    [F:ITC]OVEMACLEV = arr([F:ITC]OVEMACLEV,10^-GDECPRI)
#    [F:ITC]OVELABLEV = arr([F:ITC]OVELABLEV,10^-GDECPRI)
#    [F:ITC]OVESCOLEV = arr([F:ITC]OVESCOLEV,10^-GDECPRI)
#    [F:ITC]FXDOVEMATL = arr([F:ITC]FXDOVEMATL,10^-GDECPRI)
#    [F:ITC]FXDOVEMACL = arr([F:ITC]FXDOVEMACL,10^-GDECPRI)
#    [F:ITC]FXDOVELABL = arr([F:ITC]FXDOVELABL,10^-GDECPRI)
#    [F:ITC]FXDOVESCOL = arr([F:ITC]FXDOVESCOL,10^-GDECPRI)
#
#    [F:ITC]OVELEVCST = arr([F:ITC]OVELEVCST,10^-GDECPRI)
#    [F:ITC]FXDOVELEV = arr([F:ITC]FXDOVELEV,10^-GDECPRI)

Endif

If [M:CTP]NIV=2
    [F:ITC]MATTOT = sum([F:ITC]MATCST)
    [F:ITC]MACTOT = sum([F:ITC]MACCST)
    [F:ITC]LABTOT = sum([F:ITC]LABCST)
    [F:ITC]SCOTOT = [F:ITC]SCOCST
    [F:ITC]CSTTOT = [F:ITC]MATTOT+[F:ITC]MACTOT+[F:ITC]LABTOT+[F:ITC]SCOTOT
    [F:ITC]VLTTOT = [F:ITC]CSTTOT + [F:ITC]OVETOT

    If GSTOTRACE=4
        Call ECR_TRACE([F:ITC]ITMREF-[F:ITC]ECCVALMAJ-[F:ITC]ECCVALMIN-"("+num$([F:ITC]ITCSEQ)+") : MATTOT="+num$([F:ITC]MATTOT)+"MACTOT="+num$([F:ITC]MACTOT)+"LABTOT="+num$([F:ITC]LABTOT)
&                     +"SCOTOT="+num$([F:ITC]SCOTOT)+"CSTTOT="+num$([F:ITC]CSTTOT)+"VLTTOT="+num$([F:ITC]VLTTOT),0) From GESECRAN
    Endif
Endif

[F:ITC]EXPNUM = [C]EXPORT
[F:ITC]UPDFLG = PUPDFLG    : # pour la mise à jour directe en fin de traitement
Return

###############################################################################
# Enregistrement des natures de FG
###############################################################################
Subprog SAVICN(PRET)
Variable Integer PRET

Raz PRET

Local Integer I, LEXI, LTRANS
Local Decimal LVAL, LVALFXD
Local Decimal LCUMNAT : LCUMNAT=0
Local Decimal LVALMAX
Local Char    LNATMAX(GLONONA)
If !clalev([F:ICN]) : Local File ITCNAT [ICN] : Endif

If adxlog=0
    Trbegin [ICN]
    LTRANS=1
Endif

# Il n'y a pas besoin de récupérer les natures des niveaux inférieurs directement dans le fichier
# car les natures ont été récupérées dans [M:CST]

For I=0 To [M:CST]NBFGMAT-1
    Raz [F:ICN]
    Readlock [F:ICN]ICN0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]NATMAT(I);adxuid(1)
    If !fstat
        LEXI = 1
    Else
        LEXI = 0
        [F:ICN]STOFCY = [M:CST0]STOFCY
        [F:ICN]ITMREF = [M:CTP]ITMREF
        [F:ICN]CSTTYP = [F:ITC]CSTTYP
        [F:ICN]ITCSEQ = [F:ITC]ITCSEQ
        [F:ICN]OVENAT = [M:CST]NATMAT(I)
        [F:ICN]UID    = adxuid(1)
    Endif
    LVAL = ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / [M:CTP]QTYCLC
    LVALFXD = [M:CST]MFXDAMT(I) / [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    LVAL = arr(LVAL,10^-GDECPRI)
#    LVALFXD = arr(LVALFXD,10^-GDECPRI)
    If [M:CST]CLCLEV(I)=1
        [F:ICN]NATAMTSSE(0) += LVAL
        [F:ICN]FXDAMTSSE(0) += LVALFXD
        If [M:CST]MOVETYP(I)=2
            [F:ICN]NATAMTSSE(6) += LVAL
            [F:ICN]FXDAMTSSE(6) += LVALFXD
        Else
            [F:ICN]NATAMTSSE([M:CST]MOVETYP(I)) += LVAL
            [F:ICN]FXDAMTSSE([M:CST]MOVETYP(I)) += LVALFXD
        Endif
    Else
        [F:ICN]NATAMTLEV(0) += LVAL
        [F:ICN]FXDAMTLEV(0) += LVALFXD
        [F:ICN]NATAMTLEV([M:CST]MOVETYP(I)) += LVAL
        [F:ICN]FXDAMTLEV([M:CST]MOVETYP(I)) += LVALFXD
    Endif
    If LEXI
        Gosub REWRITE_ICN
    Else
        Gosub WRITE_ICN
    Endif
    If fstat
        PRET=1 : Break
    Endif
    LCUMNAT += LVAL
    If abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))>LVALMAX
        LNATMAX = [F:ICN]OVENAT
        LVALMAX = abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))
    Endif
Next
For I=0 To [M:CST]NBFGITM-1
    Raz [F:ICN]
    Readlock [F:ICN]ICN0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]NATITM(I);adxuid(1)
    If !fstat
        LEXI = 1
    Else
        LEXI = 0
        [F:ICN]STOFCY = [M:CST0]STOFCY
        [F:ICN]ITMREF = [M:CTP]ITMREF
        [F:ICN]CSTTYP = [F:ITC]CSTTYP
        [F:ICN]ITCSEQ = [F:ITC]ITCSEQ
        [F:ICN]OVENAT = [M:CST]NATITM(I)
        [F:ICN]UID    = adxuid(1)
    Endif
    LVAL = ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / [M:CTP]QTYCLC
    LVALFXD = [M:CST]IFXDAMT(I) / [M:CTP]QTYCLC
# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    LVAL = arr(LVAL,10^-GDECPRI)
#    LVALFXD = arr(LVALFXD,10^-GDECPRI)
    [F:ICN]NATAMTLEV(0) += LVAL
    [F:ICN]FXDAMTLEV(0) += LVALFXD
    J = [M:CST]IOVETYP(I)
    If J=2 : J=1 : Endif    # Si FG type matière(2), alors mettre dans FG produit(1)
    [F:ICN]NATAMTLEV(J) += LVAL
    [F:ICN]FXDAMTLEV(J) += LVALFXD
    If LEXI
        Gosub REWRITE_ICN
    Else
        Gosub WRITE_ICN
    Endif
    If fstat
        PRET=1 : Break
    Endif
    LCUMNAT += LVAL
    If abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))>LVALMAX
        LNATMAX = [F:ICN]OVENAT
        LVALMAX = abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))
    Endif
Next
For I=0 To [M:CST]NBFGWST-1
    If [M:CST]NATWST(I)<>""    # NATWST(I)="" dans le cas d'un import
        Raz [F:ICN]
        Readlock [F:ICN]ICN0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]NATWST(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            [F:ICN]STOFCY = [M:CST0]STOFCY
            [F:ICN]ITMREF = [M:CTP]ITMREF
            [F:ICN]CSTTYP = [F:ITC]CSTTYP
            [F:ICN]ITCSEQ = [F:ITC]ITCSEQ
            [F:ICN]OVENAT = [M:CST]NATWST(I)
            [F:ICN]UID    = adxuid(1)
        Endif
        LVAL = ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / [M:CTP]QTYCLC
        LVALFXD = [M:CST]WFXDAMT(I) / [M:CTP]QTYCLC
#        LVAL = arr(LVAL,10^-GDECPRI)
#        LVALFXD = arr(LVALFXD,10^-GDECPRI)
        [F:ICN]NATAMTLEV(0) += LVAL
        [F:ICN]FXDAMTLEV(0) += LVALFXD
        [F:ICN]NATAMTLEV([M:CST]WOVETYP(I)) += LVAL
        [F:ICN]FXDAMTLEV([M:CST]WOVETYP(I)) += LVALFXD
        If LEXI
            Gosub REWRITE_ICN
        Else
            Gosub WRITE_ICN
        Endif
        If fstat
            PRET=1 : Break
        Endif
        LCUMNAT += LVAL
        If abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))>LVALMAX
            LNATMAX = [F:ICN]OVENAT
            LVALMAX = abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))
        Endif
    Endif
Next
For I=0 To [M:CST]NBFGSCO-1
    If [M:CST]NATSCO(I)<>""
        Raz [F:ICN]
        Readlock [F:ICN]ICN0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]NATSCO(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            [F:ICN]STOFCY = [M:CST0]STOFCY
            [F:ICN]ITMREF = [M:CTP]ITMREF
            [F:ICN]CSTTYP = [F:ITC]CSTTYP
            [F:ICN]ITCSEQ = [F:ITC]ITCSEQ
            [F:ICN]OVENAT = [M:CST]NATSCO(I)
            [F:ICN]UID    = adxuid(1)
        Endif
        LVAL = ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / [M:CTP]QTYCLC
        LVALFXD = [M:CST]SFXDAMT(I) / [M:CTP]QTYCLC
#        LVAL = arr(LVAL,10^-GDECPRI)
#        LVALFXD = arr(LVALFXD,10^-GDECPRI)
        [F:ICN]NATAMTLEV(0) += LVAL
        [F:ICN]FXDAMTLEV(0) += LVALFXD
        [F:ICN]NATAMTLEV([M:CST]SOVETYP(I)) += LVAL
        [F:ICN]FXDAMTLEV([M:CST]SOVETYP(I)) += LVALFXD
        If LEXI
            Gosub REWRITE_ICN
        Else
            Gosub WRITE_ICN
        Endif
        If fstat
            PRET=1 : Break
        Endif
        LCUMNAT += LVAL
        If abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))>LVALMAX
            LNATMAX = [F:ICN]OVENAT
            LVALMAX = abs([F:ICN]NATAMTSSE(0)+[F:ICN]NATAMTLEV(0))
        Endif
    Endif
Next

If LCUMNAT<>[F:ITC]OVETOT & LNATMAX<>""
    Read [F:ICN]ICN0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;LNATMAX;adxuid(1)
    If !fstat
        If [F:ICN]NATAMTLEV(0)<>0
            [F:ICN]NATAMTLEV(0) += [F:ITC]OVETOT - LCUMNAT
        Else
            [F:ICN]NATAMTSSE(0) += [F:ITC]OVETOT - LCUMNAT
        Endif
        Rewrite [ICN]
    Endif
Endif
If PRET
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1) - [F:ICN]ITMREF - mess(309,197,1)-":"-[F:ICN]OVENAT
    Call ECR_TRACE(ERR_TRA,1)
    Raz GOK
Else
    If LTRANS
        Commit
    Endif
Endif

End

###############################################################################
# Enregistrement du détail des matières et sous-produits
###############################################################################
Subprog SAVICC(PRET)
Variable Integer PRET

If !clalev([F:ICC]) : Local File ITCMAT [ICC] : Endif
If !clalev([F:ITCS]) : Local File ITMCOST [ITCS] : Endif
If !clalev([F:ITB]) : Local File ITMBOM [ITB] : Endif
If !clalev([F:ICC2]) : Local File ITCMAT  [ICC2] : Endif
If !clalev([F:IWC]) : Local File ITCWST [IWC] : Endif
If !clalev([F:IWC2]) : Local File ITCWST [IWC2] : Endif

Local Integer I, J, LEXI, LTRANS, LRET
Local Integer LMATFLG # Indique si le composant en cours d'enregistrement est une matière ou non
Local Decimal LPRI, Q1, Q2

Raz PRET

If adxlog=0
    LTRANS=1
    Trbegin [ICC]
Endif
For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)=2
# Issue 67578 - 2010-10-15 by CCC : C'est le fait de trouver des composants dans ICC (ou ICW) qui va permettre de déterminer si c'est une matière
#                                   Sinon, en édition, un article peut ne pas apparaitre dans les composants alors qu'il n'a pas de ICC
#        Raz [F:ITB]
#        Read [F:ITB]ITB0 = [M:CST]ITMREF(I);[M:CTP]BOMALT;2
#        If fstat | [F:ITB]BOMEXIFLG <> 2
#            LMATFLG = 1
#        Else
            LMATFLG = 2   # C'est seulement si on trouve un composant que l'on va considérer que ce n'est pas une matière
#        Endif
        # Issue 66961 - 2010-08-31 by CCC : Recherche du coût sous-produit utilisé
        [F:ITCS] = [F:ITC]
        Raz [F:ITC2], [F:ITC]
        Call GETPRI([M:CST]ICSTCOD(I)-1,[M:CST]ITMREF(I),[M:CST]IECCVALMAJ(I),[M:CST]IECCVALMIN(I),[M:CST0]STOFCY,[M:CTP]CLCDAT,[M:CST]IQTYSTU(I),LPRI,LRET) From TRTCST
        If !LRET
            Read [ITC2]ITC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID
        Endif
        Read [ITC]ITC0=[F:ITCS]STOFCY;[F:ITCS]ITMREF;[F:ITCS]CSTTYP;[F:ITCS]ITCSEQ;[F:ITCS]UID
        If fstat
            [F:ITC]=[F:ITCS]
        Endif

        # Récupération du détail des matières des sous-produits
        For [ICC2] Where STOFCY = [F:ITC2]STOFCY
&                      & ITMREF = [F:ITC2]ITMREF
&                      & CSTTYP = [F:ITC2]CSTTYP
&                      & ITCSEQ = [F:ITC2]ITCSEQ
&                      & UID    = [F:ITC2]UID
&                      & MATFLG = 2
            LMATFLG = 1
            Readlock [ICC]ICC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ICC2]MATREF;[F:ICC2]ECCVALMAJ;[F:ICC2]ECCVALMIN;[F:ICC2]CPNTYP;[F:ITC]UID
            If !fstat
                [F:ICC]QTYSTU += [M:CST]IQTYSTU(I)*[F:ICC2]QTYSTU/[F:ITC2]CLCQTY
                Gosub REWRITE_ICC
            Else
                [F:ICC] = [F:ICC2]
                [F:ICC]CPNTYP = 4   # Issue 65831 - 2010-09-09 by CCC
                [F:ICC]ITMREF = [M:CTP]ITMREF
                [F:ICC]ITCSEQ = [F:ITC]ITCSEQ
                [F:ICC]UID = [F:ITC]UID
                [F:ICC]QTYTOP = 0
                [F:ICC]QTYSTU = [M:CST]IQTYSTU(I)*[F:ICC2]QTYSTU/[F:ITC2]CLCQTY
                Gosub WRITE_ICC
            Endif
        Next

        # Récupération du détail des opérations des sous-produits
        For [IWC2] Where STOFCY = [F:ITC2]STOFCY
&                      & ITMREF = [F:ITC2]ITMREF
&                      & CSTTYP = [F:ITC2]CSTTYP
&                      & ITCSEQ = [F:ITC2]ITCSEQ
&                      & UID    = [F:ITC2]UID
            LMATFLG = 1
            Readlock [F:IWC]IWC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:IWC2]WST;[F:IWC2]SCOITMREF;[F:ITC]UID
            If !fstat
                [F:IWC]SETTIM -= abs([F:IWC2]SETTIM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OPETIM -= abs([F:IWC2]OPETIM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]SETAMT -= abs([F:IWC2]SETAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OPEAMT -= abs([F:IWC2]OPEAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OVEAMT -= abs([F:IWC2]OVEAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]QTYSCOITM -= abs([F:IWC2]QTYSCOITM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                Gosub REWRITE_IWC
            Else
                [F:IWC] = [F:IWC2]
                [F:IWC]ITMREF = [F:ITC]ITMREF
                [F:IWC]ITCSEQ = [F:ITC]ITCSEQ
                [F:IWC]UID    = [F:ITC]UID
                [F:IWC]SETTIM =-abs([F:IWC2]SETTIM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OPETIM =-abs([F:IWC2]OPETIM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]SETTIMTOP = 0
                [F:IWC]OPETIMTOP = 0
                [F:IWC]SETAMT =-abs([F:IWC2]SETAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OPEAMT =-abs([F:IWC2]OPEAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]OVEAMT =-abs([F:IWC2]OVEAMT * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]QTYSCOITM =-abs([F:IWC2]QTYSCOITM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY)
                [F:IWC]QTYSCOTOP = 0
                Gosub WRITE_IWC
            Endif
        Next

        Raz [F:ICC]
        Readlock [F:ICC]ICC0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]ITMREF(I);[M:CST]IECCVALMAJ(I);[M:CST]IECCVALMIN(I);4;adxuid(1)
        If !fstat
            LEXI=1
        Else
            LEXI=0  # Issue 72221 - 2011-03-10 by CCC
            [F:ICC]STOFCY = [M:CST0]STOFCY
            [F:ICC]ITMREF = [M:CTP]ITMREF
            [F:ICC]CSTTYP = [F:ITC]CSTTYP
            [F:ICC]ITCSEQ = [F:ITC]ITCSEQ
            [F:ICC]MATREF = [M:CST]ITMREF(I)
            [F:ICC]ECCVALMAJ = [M:CST]MECCVALMAJ(I)
            [F:ICC]ECCVALMIN = [M:CST]MECCVALMIN(I)
            [F:ICC]CPNTYP = 4    # Sous-produit
            [F:ICC]UID    = adxuid(1)
        Endif
        Q1 = [F:ICC]QTYSTU
        Q2 = [M:CST]IQTYSTU(I)
        [F:ICC]QTYSTU += [M:CST]IQTYSTU(I)
        [F:ICC]QTYTOP += [M:CST]IQTYSTU(I)
        [F:ICC]STU    = [M:CST]ISTU(I)
        [F:ICC]MATFLG = LMATFLG
        [F:ICC]BRDCOD = [M:CST]IBRDCOD(I)
        [F:ICC]CSTCOD = [M:CST]ICSTCOD(I)
        For J=0 To GACTMAT-1
            [F:ICC]MATCST(J) = ([F:ICC]MATCST(J)*Q1 + [M:CST]IMATCST(I*GACTMAT+J)+[M:CST]IFMATCST(I*GACTMAT+J)) / (Q1+ Q2)
        Next
        For J=0 To GACTMAC-1
            [F:ICC]MACCST(J) = ([F:ICC]MACCST(J)*Q1 + [M:CST]IMACCST(I*GACTMAC+J)+[M:CST]IFMACCST(I*GACTMAC+J)) / (Q1+ Q2)
        Next
        For J=0 To GACTLAB-1
            [F:ICC]LABCST(J) = ([M:CST]ILABCST(I*GACTLAB+J)+[M:CST]IFLABCST(I*GACTLAB+J)) / (Q1+ Q2)
        Next
        [F:ICC]SCOCST    = ([F:ICC]SCOCST*Q1 + [M:CST]ISCOCST(I)) / (Q1+ Q2)
        [F:ICC]INVDTACST = ([F:ICC]INVDTACST*Q1 + [M:CST]IINVDTA(I)) / (Q1+ Q2)
        [F:ICC]OVEMATCST = ([F:ICC]OVEMATCST*Q1 + [M:CST]IOVEMATCST(I)) / (Q1+ Q2)
        [F:ICC]OVEMACCST = ([F:ICC]OVEMACCST*Q1 + [M:CST]IOVEMACCST(I)) / (Q1+ Q2)
        [F:ICC]OVELABCST = ([F:ICC]OVELABCST*Q1 + [M:CST]IOVELABCST(I)) / (Q1+ Q2)
        [F:ICC]OVESCOCST = ([F:ICC]OVESCOCST*Q1 + [M:CST]IOVESCOCST(I)) / (Q1+ Q2)

# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#        For J=0 To GACTMAT-1
#            [F:ICC]MATCST(J) = arr([F:ICC]MATCST(J), 10^-GDECPRI)
#        Next
#
#        For J=0 To GACTMAC-1
#            [F:ICC]MACCST(J) = arr([F:ICC]MACCST(J), 10^-GDECPRI)
#        Next
#        For J=0 To GACTLAB-1
#            [F:ICC]LABCST(J) = arr([F:ICC]LABCST(J), 10^-GDECPRI)
#        Next
#        [F:ICC]SCOCST    = arr([F:ICC]SCOCST, 10^-GDECPRI)
#        [F:ICC]INVDTACST = arr([F:ICC]INVDTACST, 10^-GDECPRI)
#        [F:ICC]OVEMATCST = arr([F:ICC]OVEMATCST, 10^-GDECPRI)
#        [F:ICC]OVEMACCST = arr([F:ICC]OVEMACCST, 10^-GDECPRI)
#        [F:ICC]OVELABCST = arr([F:ICC]OVELABCST, 10^-GDECPRI)
#        [F:ICC]OVESCOCST = arr([F:ICC]OVESCOCST, 10^-GDECPRI)

        If LEXI
            Gosub REWRITE_ICC
        Else
            Gosub WRITE_ICC
        Endif
        If fstat
            PRET=1 : Break
        Endif

    Endif
Next
If PRET
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1) - [F:ICC]ITMREF - mess(4,438,1)+":"+[F:ICC]MATREF
    Call ECR_TRACE(ERR_TRA,1)
    Raz GOK
    End
Endif

For I=0 To [M:CST]NBMAT-1
    Raz [F:ITB]
# Issue 67578 - 2010-10-15 by CCC : C'est le fait de trouver des composants dans ICC (ou ICW) qui va permettre de déterminer si c'est une matière
#                                   Sinon, en édition, un article peut ne pas apparaitre dans les composants alors qu'il n'a pas de ICC
#    Read [F:ITB]ITB0 = [M:CST]MATREF(I);[M:CTP]BOMALT;2
#    If !fstat & [F:ITB]BOMEXIFLG = 2
#        LMATFLG = 1
#    Else
        LMATFLG = 2
#    Endif
    # Issue 66961 - 2010-08-31 by CCC : Recherche du coût composant utilisé pour récupérer le détail
    [F:ITCS] = [F:ITC]
    Raz [F:ITC2], [F:ITC]
    Call GETPRI([M:CST]MCSTCOD(I),[M:CST]MATREF(I),[M:CST]MECCVALMAJ(I),[M:CST]MECCVALMIN(I),[M:CST0]STOFCY,[M:CTP]CLCDAT,[M:CST]MQTYSTU(I),LPRI,LRET) From TRTCST
    If !LRET
        Read [ITC2]ITC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID
    Endif
    Read [ITC]ITC0=[F:ITCS]STOFCY;[F:ITCS]ITMREF;[F:ITCS]CSTTYP;[F:ITCS]ITCSEQ;[F:ITCS]UID
    If fstat
        [F:ITC]=[F:ITCS]
    Endif

    # Récupération du détail des matières des composants
    For [ICC2] Where STOFCY = [F:ITC2]STOFCY
&                  & ITMREF = [F:ITC2]ITMREF
&                  & CSTTYP = [F:ITC2]CSTTYP
&                  & ITCSEQ = [F:ITC2]ITCSEQ
&                  & UID    = [F:ITC2]UID
&                  & MATFLG = 2
        LMATFLG = 1
        Readlock [ICC]ICC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ICC2]MATREF;[F:ICC2]ECCVALMAJ;[F:ICC2]ECCVALMIN;[F:ICC2]CPNTYP;[F:ITC]UID
        If !fstat
            [F:ICC]QTYSTU += [M:CST]MQTYSTU(I)*[F:ICC2]QTYSTU/[F:ITC2]CLCQTY
            Gosub REWRITE_ICC
        Else
            [F:ICC] = [F:ICC2]
            [F:ICC]ITMREF = [F:ITC]ITMREF
            [F:ICC]ITCSEQ = [F:ITC]ITCSEQ
            [F:ICC]UID = [F:ITC]UID   # Issue 74153 - 2011-06-08 by CCC
            [F:ICC]QTYTOP = 0
            [F:ICC]QTYSTU = [M:CST]MQTYSTU(I)*[F:ICC2]QTYSTU/[F:ITC2]CLCQTY
            Gosub WRITE_ICC
        Endif
    Next

    # Récupération du détail des opérations des composants
    For [IWC2] Where STOFCY = [F:ITC2]STOFCY
&                  & ITMREF = [F:ITC2]ITMREF
&                  & CSTTYP = [F:ITC2]CSTTYP
&                  & ITCSEQ = [F:ITC2]ITCSEQ
&                  & UID    = [F:ITC2]UID
        LMATFLG = 1
        Readlock [F:IWC]IWC0=[F:ITC]STOFCY;[F:ITC]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:IWC2]WST;[F:IWC2]SCOITMREF;[F:ITC]UID
        If !fstat
            [F:IWC]SETTIM += [F:IWC2]SETTIM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OPETIM += [F:IWC2]OPETIM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]SETAMT += [F:IWC2]SETAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OPEAMT += [F:IWC2]OPEAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OVEAMT += [F:IWC2]OVEAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]PRISCO = ([F:IWC]PRISCO*[F:IWC]QTYSCOITM + [F:IWC2]PRISCO*[F:IWC2]QTYSCOITM* [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY)
            # Issue 104760 - 2015-02-03 by CCC
            #[F:IWC]QTYSCOITM += [F:IWC2]QTYSCOITM * [M:CST]IQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]QTYSCOITM += [F:IWC2]QTYSCOITM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            If [F:IWC]QTYSCOITM<>0
                [F:IWC]PRISCO /= [F:IWC]QTYSCOITM
            Endif
            Gosub REWRITE_IWC
        Else
            [F:IWC] = [F:IWC2]
            [F:IWC]ITMREF = [F:ITC]ITMREF
            [F:IWC]ITCSEQ = [F:ITC]ITCSEQ
            [F:IWC]UID    = [F:ITC]UID
            [F:IWC]SETTIM = [F:IWC2]SETTIM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OPETIM = [F:IWC2]OPETIM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]SETAMT = [F:IWC2]SETAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OPEAMT = [F:IWC2]OPEAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OVEAMT = [F:IWC2]OVEAMT * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]OVEAMTTOP = 0
            [F:IWC]SETTIMTOP = 0
            [F:IWC]OPETIMTOP = 0
            [F:IWC]QTYSCOITM = [F:IWC2]QTYSCOITM * [M:CST]MQTYSTU(I) / [F:ITC2]CLCQTY
            [F:IWC]QTYSCOTOP = 0
            Gosub WRITE_IWC
        Endif
    Next

    Raz [F:ICC]
    Readlock [F:ICC]ICC0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]MATREF(I);[M:CST]MECCVALMAJ(I);[M:CST]MECCVALMIN(I);1;adxuid(1)
    If !fstat
        LEXI=1
    Else
        LEXI=0  # Issue 72221 - 2011-03-10 by CCC
        [F:ICC]STOFCY = [M:CST0]STOFCY
        [F:ICC]ITMREF = [M:CTP]ITMREF
        [F:ICC]CSTTYP = [F:ITC]CSTTYP
        [F:ICC]ITCSEQ = [F:ITC]ITCSEQ
        [F:ICC]MATREF = [M:CST]MATREF(I)
        [F:ICC]ECCVALMAJ = [M:CST]MECCVALMAJ(I)
        [F:ICC]ECCVALMIN = [M:CST]MECCVALMIN(I)
        [F:ICC]CPNTYP = 1    # matière
        [F:ICC]UID    = adxuid(1)
    Endif
    [F:ICC]SCOFLG = [M:CST]SCOFLG(I)
    Q1 = [F:ICC]QTYSTU
    Q2 = [M:CST]MQTYSTU(I)
    [F:ICC]QTYSTU += [M:CST]MQTYSTU(I)
    [F:ICC]QTYTOP += [M:CST]MQTYSTU(I)
    [F:ICC]STU    = [M:CST]MSTU(I)
    [F:ICC]MATFLG = LMATFLG
    [F:ICC]BRDCOD = [M:CST]MBRDCOD(I)
    [F:ICC]CSTCOD = [M:CST]MCSTCOD(I)

    For J=0 To GACTMAT-1
        [F:ICC]MATCST(J) = [F:ICC]MATCST(J)*Q1 + [M:CST]MMATCST(I*GACTMAT+J)
        If J=max(0,[F:ICC]BRDCOD-1)
            # Les éléments de facture sont mis dans le coût matière
            [F:ICC]MATCST(J) += [M:CST]MINVDTA(I)
        Endif
        [F:ICC]MATCST(J) /= (Q1+Q2)
    Next

    For J=0 To GACTMAC-1
        [F:ICC]MACCST(J) = ([F:ICC]MACCST(J)*Q1 + [M:CST]MMACCST(I*GACTMAC+J)) / (Q1+Q2)
    Next
    For J=0 To GACTLAB-1
        [F:ICC]LABCST(J) = ([F:ICC]LABCST(J)*Q1 + [M:CST]MLABCST(I*GACTLAB+J)) / (Q1+Q2)
    Next
    [F:ICC]SCOCST    = ([F:ICC]SCOCST*Q1 + [M:CST]MSCOCST(I)) / (Q1+Q2)
    [F:ICC]INVDTACST = ([F:ICC]INVDTACST*Q1 + [M:CST]MINVDTA(I)) / (Q1+Q2)
    [F:ICC]OVEMATCST = ([F:ICC]OVEMATCST*Q1 + [M:CST]MOVEMATCST(I)) / (Q1+Q2)
    [F:ICC]OVEMACCST = ([F:ICC]OVEMACCST*Q1 + [M:CST]MOVEMACCST(I)) / (Q1+Q2)
    [F:ICC]OVELABCST = ([F:ICC]OVELABCST*Q1 + [M:CST]MOVELABCST(I)) / (Q1+Q2)
    [F:ICC]OVESCOCST = ([F:ICC]OVESCOCST*Q1 + [M:CST]MOVESCOCST(I)) / (Q1+Q2)


# Issue 45128 & 73264 - 2011-09-06 by CCC : Les arrondis ne sont plus faits par défaut => utiliser le PE
#    For J=0 To GACTMAT-1
#        [F:ICC]MATCST(J) = arr([F:ICC]MATCST(J), 10^-GDECPRI)
#    Next
#
#    For J=0 To GACTMAC-1
#        [F:ICC]MACCST(J) = arr([F:ICC]MACCST(J), 10^-GDECPRI)
#    Next
#    For J=0 To GACTLAB-1
#        [F:ICC]LABCST(J) = arr([F:ICC]LABCST(J), 10^-GDECPRI)
#    Next
#    [F:ICC]SCOCST    = arr([F:ICC]SCOCST, 10^-GDECPRI)
#    [F:ICC]INVDTACST = arr([F:ICC]INVDTACST, 10^-GDECPRI)
#    [F:ICC]OVEMATCST = arr([F:ICC]OVEMATCST, 10^-GDECPRI)
#    [F:ICC]OVEMACCST = arr([F:ICC]OVEMACCST, 10^-GDECPRI)
#    [F:ICC]OVELABCST = arr([F:ICC]OVELABCST, 10^-GDECPRI)
#    [F:ICC]OVESCOCST = arr([F:ICC]OVESCOCST, 10^-GDECPRI)

    If LEXI
        Gosub REWRITE_ICC
    Else
        Gosub WRITE_ICC
    Endif
    If fstat
        PRET=1 : Break
    Endif

Next
If PRET
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1) - [F:ICC]ITMREF - mess(35,197,1)+":"+[F:ICC]MATREF
    Call ECR_TRACE(ERR_TRA,1)
    Raz GOK
    End
Else
    If LTRANS
        Commit
    Endif
Endif

End

###############################################################################
# Enregistrement du détail des opérations (machine, main d'oeuvre et sous-traitance)
###############################################################################
Subprog SAVIWC(PRET)
Variable Integer PRET

Raz PRET

If !clalev([F:IWC]) : Local File ITCWST [IWC] : Endif
If !clalev([F:IWC2]) : Local File ITCWST [IWC2] : Endif

Local Integer I, LEXI, LTRANS

If adxlog=0
    Trbegin [IWC]
    LTRANS=1
Endif

For I=0 To [M:CST]NBWST-1
    Raz LEXI, [F:IWC]
    Readlock [F:IWC]IWC0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]WST(I);"";adxuid(1)
    If !fstat
        LEXI=1
    Else
        [F:IWC]STOFCY = [M:CST0]STOFCY
        [F:IWC]ITMREF = [M:CTP]ITMREF
        [F:IWC]CSTTYP = [F:ITC]CSTTYP
        [F:IWC]ITCSEQ = [F:ITC]ITCSEQ
        [F:IWC]WST    = [M:CST]WST(I)
        [F:IWC]UID    = adxuid(1)
    Endif
    [F:IWC]WSTTYP = [M:CST]WSTTYP(I)
    [F:IWC]BRDCOD = [M:CST]WBRDCOD(I)
    [F:IWC]WCSTTYP = [M:CST]WCSTTYP(I)
    [F:IWC]RATCOD = [M:CST]WRATCOD(I)
    [F:IWC]SETCST = [M:CST]WSETCST(I)
    [F:IWC]SETTIM += [M:CST]WSETTIM(I)
    [F:IWC]OPECST = [M:CST]WOPECST(I)
    [F:IWC]OPETIM += [M:CST]WOPETIM(I)
    [F:IWC]SETAMT += [M:CST]WSETAMT(I)
    [F:IWC]OPEAMT += [M:CST]WOPEAMT(I)
    [F:IWC]SETTIMTOP += [M:CST]WSETTIM(I)
    [F:IWC]OPETIMTOP += [M:CST]WOPETIM(I)
    # !!! On n'enregistre les FG d'une même opération qu'une fois
    If !find([M:CST]WST(I),[M:CST]WST(0..I-1))
        [F:IWC]OVEAMTTOP = sigma(0,[M:CST]NBFGWST-1,([M:CST]WFXDAMT(indcum)+[M:CST]WVARAMT(indcum))
&                                           *([M:CST]OWST(indcum)=[M:CST]WST(I)) )
        [F:IWC]OVEAMT += [F:IWC]OVEAMTTOP
    Endif

    If LEXI
        Gosub REWRITE_IWC
    Else
        Gosub WRITE_IWC
    Endif
    If fstat
        PRET=1 : Break
    Endif
Next
If PRET
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1) - [F:IWC]ITMREF - mess(570,197,1)+":"+[F:IWC]WST
    Call ECR_TRACE(ERR_TRA,1)
    Raz GOK
    End
Endif

For I=0 To [M:CST]NBSCO-1
    Raz LEXI, [F:IWC]
    Readlock [F:IWC]IWC0=[M:CST0]STOFCY;[M:CTP]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[M:CST]SCOWST(I);[M:CST]SCOITMREF(I);adxuid(1)
    If !fstat
        LEXI=1
    Else
        [F:IWC]STOFCY = [M:CST0]STOFCY
        [F:IWC]ITMREF = [M:CTP]ITMREF
        [F:IWC]CSTTYP = [F:ITC]CSTTYP
        [F:IWC]ITCSEQ = [F:ITC]ITCSEQ
        [F:IWC]WST    = [M:CST]SCOWST(I)
        [F:IWC]UID    = adxuid(1)
    Endif
    [F:IWC]WSTTYP = 3    # Sous-traitance
    [F:IWC]BRDCOD = [M:CST]SBRDCOD(I)
    [F:IWC]WCSTTYP = [M:CST]SCSTTYP(I)
    [F:IWC]RATCOD = [M:CST]SRATCOD(I)
    [F:IWC]SETCST = [M:CST]SSETCST(I)
    [F:IWC]SETTIM += [M:CST]SSETTIM(I)
    [F:IWC]OPECST = [M:CST]SOPECST(I)
    [F:IWC]OPETIM += [M:CST]SOPETIM(I)
    [F:IWC]SETAMT += [M:CST]SSETAMT(I)
    [F:IWC]OPEAMT += [M:CST]SOPEAMT(I)
    [F:IWC]SCOITMREF = [M:CST]SCOITMREF(I)
    [F:IWC]CSTCOD = [M:CST]SCSTCOD(I)
    [F:IWC]PRISCO = [M:CST]PRISCO(I)
    [F:IWC]UOMSCOITM = [M:CST]SUOMSCOITM(I)
    [F:IWC]QTYSCOITM = [M:CST]SQTYSCOITM(I)
    [F:IWC]SETTIMTOP += [M:CST]SSETTIM(I)
    [F:IWC]OPETIMTOP += [M:CST]SOPETIM(I)
    [F:IWC]QTYSCOTOP += [M:CST]SQTYSCOITM(I)
    # !!! On n'enregistre les FG d'une même opération qu'une fois
    If !find([M:CST]SCOWST(I),[M:CST]SCOWST(0..I-1))
        [F:IWC]OVEAMTTOP = sigma(0,[M:CST]NBFGSCO-1,([M:CST]SFXDAMT(indcum)+[M:CST]SVARAMT(indcum))
&                                           *([M:CST]OSCOWST(indcum)=[M:CST]SCOWST(I)) )
        [F:IWC]OVEAMT += [F:IWC]OVEAMTTOP
    Endif

    If LEXI
        Gosub REWRITE_IWC
    Else
        Gosub WRITE_IWC
    Endif
    If fstat
        PRET=1 : Break
    Endif
Next
If PRET
    If LTRANS
        Rollback
    Endif
    ERR_TRA = mess(14,100,1) - [F:IWC]ITMREF - mess(570,197,1)+":"+[F:IWC]WST
    Call ECR_TRACE(ERR_TRA,1)
    Raz GOK
    End
Else
    If LTRANS
        Commit
    Endif
Endif

End

##########################################################################
# Maj réutilisée par les fonctions ci-dessus
$REWRITE_ITC
# Issue 73264 - 2011-09-06 by CCC : Plus d'arrondis par défaut mais possibilité de le faire simplement par PE
If dim(LARRONDI)<=0
    Local Integer LARRONDI
Endif
Raz GPE, LARRONDI
#point d'entrée  pour récup infos supplémentaires avant ré écriture ligne
GPOINT = "BEFREWITC" : Gosub ENTREE From EXEFNC

If GPE=1 & LARRONDI>0
    Call ARRITC(LARRONDI) From TRTCOST
Endif
#
[F:ITC]UPDDAT = date$
[F:ITC]UPDUSR = GUSER
Rewrite [ITC]
#
Return

