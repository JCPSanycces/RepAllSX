##########################################################################
# Arrondi de la classe [F:ITC]
Subprog ARRITC(PARRONDI)
Value Decimal PARRONDI

Local Integer I
Local Decimal LARR

If PARRONDI>=1
    LARR=10^-PARRONDI
Else
    LARR = PARRONDI
Endif

[F:ITC]MATTOT = arr([F:ITC]MATTOT,LARR)
[F:ITC]MACTOT = arr([F:ITC]MACTOT,LARR)
[F:ITC]LABTOT = arr([F:ITC]LABTOT,LARR)
[F:ITC]SCOTOT = arr([F:ITC]SCOTOT,LARR)
[F:ITC]OVETOT = arr([F:ITC]OVETOT,LARR)
[F:ITC]CSTTOT = arr([F:ITC]CSTTOT,LARR)
[F:ITC]VLTTOT = arr([F:ITC]VLTTOT,LARR)

For I=0 To dim([F:ITC]MATCST)-1
    [F:ITC]MATCST(I) = arr([F:ITC]MATCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDMATCST)-1
    [F:ITC]FXDMATCST(I) = arr([F:ITC]FXDMATCST(I),LARR)
Next

For I=0 To dim([F:ITC]MACCST)-1
    [F:ITC]MACCST(I) = arr([F:ITC]MACCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDMACCST)-1
    [F:ITC]FXDMACCST(I) = arr([F:ITC]FXDMACCST(I),LARR)
Next

For I=0 To dim([F:ITC]LABCST)-1
    [F:ITC]LABCST(I) = arr([F:ITC]LABCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDLABCST)-1
    [F:ITC]FXDLABCST(I) = arr([F:ITC]FXDLABCST(I),LARR)
Next

For I=0 To dim([F:ITC]SCOCST)-1
    [F:ITC]SCOCST(I) = arr([F:ITC]SCOCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDSCOCST)-1
    [F:ITC]FXDSCOCST(I) = arr([F:ITC]FXDSCOCST(I),LARR)
Next

For I=0 To dim([F:ITC]OVEPRD)-1
    [F:ITC]OVEPRD(I) = arr([F:ITC]OVEPRD(I),LARR)
Next

For I=0 To dim([F:ITC]OVEMATCST)-1
    [F:ITC]OVEMATCST(I) = arr([F:ITC]OVEMATCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVEMAT)-1
    [F:ITC]FXDOVEMAT(I) = arr([F:ITC]FXDOVEMAT(I),LARR)
Next

For I=0 To dim([F:ITC]OVEMACCST)-1
    [F:ITC]OVEMACCST(I) = arr([F:ITC]OVEMACCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVEMAC)-1
    [F:ITC]FXDOVEMAC(I) = arr([F:ITC]FXDOVEMAC(I),LARR)
Next

For I=0 To dim([F:ITC]OVELABCST)-1
    [F:ITC]OVELABCST(I) = arr([F:ITC]OVELABCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVELAB)-1
    [F:ITC]FXDOVELAB(I) = arr([F:ITC]FXDOVELAB(I),LARR)
Next

For I=0 To dim([F:ITC]OVESCOCST)-1
    [F:ITC]OVESCOCST(I) = arr([F:ITC]OVESCOCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVESCO)-1
    [F:ITC]FXDOVESCO(I) = arr([F:ITC]FXDOVESCO(I),LARR)
Next

For I=0 To dim([F:ITC]MATLEVCST)-1
    [F:ITC]MATLEVCST(I) = arr([F:ITC]MATLEVCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDMATLEV)-1
    [F:ITC]FXDMATLEV(I) = arr([F:ITC]FXDMATLEV(I),LARR)
Next

For I=0 To dim([F:ITC]MACLEVCST)-1
    [F:ITC]MACLEVCST(I) = arr([F:ITC]MACLEVCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDMACLEV)-1
    [F:ITC]FXDMACLEV(I) = arr([F:ITC]FXDMACLEV(I),LARR)
Next

For I=0 To dim([F:ITC]LABLEVCST)-1
    [F:ITC]LABLEVCST(I) = arr([F:ITC]LABLEVCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDLABLEV)-1
    [F:ITC]FXDLABLEV(I) = arr([F:ITC]FXDLABLEV(I),LARR)
Next

For I=0 To dim([F:ITC]OVELEVCST)-1
    [F:ITC]OVELEVCST(I) = arr([F:ITC]OVELEVCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVELEV)-1
    [F:ITC]FXDOVELEV(I) = arr([F:ITC]FXDOVELEV(I),LARR)
Next

For I=0 To dim([F:ITC]SCOLEVCST)-1
    [F:ITC]SCOLEVCST(I) = arr([F:ITC]SCOLEVCST(I),LARR)
Next

For I=0 To dim([F:ITC]FXDSCOLEV)-1
    [F:ITC]FXDSCOLEV(I) = arr([F:ITC]FXDSCOLEV(I),LARR)
Next

For I=0 To dim([F:ITC]OVEMATLEV)-1
    [F:ITC]OVEMATLEV(I) = arr([F:ITC]OVEMATLEV(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVEMATL)-1
    [F:ITC]FXDOVEMATL(I) = arr([F:ITC]FXDOVEMATL(I),LARR)
Next

For I=0 To dim([F:ITC]OVELABLEV)-1
    [F:ITC]OVELABLEV(I) = arr([F:ITC]OVELABLEV(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVELABL)-1
    [F:ITC]FXDOVELABL(I) = arr([F:ITC]FXDOVELABL(I),LARR)
Next

For I=0 To dim([F:ITC]OVEMACLEV)-1
    [F:ITC]OVEMACLEV(I) = arr([F:ITC]OVEMACLEV(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVEMACL)-1
    [F:ITC]FXDOVEMACL(I) = arr([F:ITC]FXDOVEMACL(I),LARR)
Next

For I=0 To dim([F:ITC]OVESCOLEV)-1
    [F:ITC]OVESCOLEV(I) = arr([F:ITC]OVESCOLEV(I),LARR)
Next

For I=0 To dim([F:ITC]FXDOVESCOL)-1
    [F:ITC]FXDOVESCOL(I) = arr([F:ITC]FXDOVESCOL(I),LARR)
Next
End


