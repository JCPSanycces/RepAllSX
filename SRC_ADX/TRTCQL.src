#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CQL",GBIDC1,GBIDC2) From GOBJET
End
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTCQL","TRTCQL",4,"TRTCQL") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SORTIE"    : Gosub SORTIE
 When "DEBUT"     : Gosub DEBUT                 :#81085
 When "BOUTON"    : Gosub BOUTON From EXTRCQL    :#81085
Endcase
Return


###################################
$INIT
If clalev([F:CQH])=0   : Local File CHQDEJHEA [CQH]   : Endif
If clalev([F:HRCQL])=0 : Local File CHQDEJLIG [HRCQL] : Endif
If clalev([F:CPY])=0   : Local File COMPANY   [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY  [FCY]   : Endif
If clalev([F:FEH])=0   : Local File FILEDIH   [FEH]   : Endif
If clalev([F:FEL])=0   : Local File FILEDIL   [FEL]   : Endif
If clalev([F:CPY2])=0  : Local File COMPANY   [CPY2]  : Endif
If clalev([F:CQH2])=0  : Local File CHQDEJHEA [CQH2]  : Endif
Local Char SYMBOLE(30)
Local Char CRITCQH (250)
Local Mask GENCQL [DIA]

#83271
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG="FRA"
Raz [DIA]
If dim([M:DIA]LEG)>0 : [M:DIA]LEG=GCURLEG : Endif
Call LECMEMO("STD","[M:DIA]","cqh2") From GMEMO
Call AFF_MEMO From DIVPAYE
If GFONCTION="GESCQL" & dim([M:CQL0]NUMTRE)>=1
 Raz [M:DIA]DATFRMD, DATFRMF
 [M:DIA]NUMSTR=[M:CQL0]NUMTRE
 [M:DIA]NUMEND=[M:CQL0]NUMTRE
 [M:DIA]DATSTR=[M:CQL0]DATTRE
 [M:DIA]DATEND=[M:CQL0]DATTRE
 [M:DIA]ALLCPY=1
 [M:DIA]CPY=[M:CQL0]CPY
Endif
Return

#81085
######################################################
$DEBUT
Affzo [DIA]
Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE
Return

##################################
#83271
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP=1
 TRA=1
Endif
Return

###################################
$EXEC
# Génération de commande de chèques déjeuner
[L]TIT=mess(203,10703,1)

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  Link [HRCQL] With
&    [CQH]CQH0   = [F:HRCQL]NUMTRE
&,   [CPY]CPY0   = [F:HRCQL]CPY
&,   [FCY]FCY0   = [F:HRCQL]FCY
&    As [LNK]

CRITCQH = '[F:CQH2]FLGTRE<>2'
If [M:DIA]DATSTR<>[0/0/0]
 CRITCQH -= '& [F:CQH2]DATTRE>=['+format$(GFMD,[M:DIA]DATSTR)+']'
 CRITCQH -= '& [F:CQH2]DATTRE<=['+format$(GFMD,[M:DIA]DATEND)+']'
Endif
If [M:DIA]NUMSTR<>""
 CRITCQH -= '& [F:CQH2]NUMTRE>="'+[M:DIA]NUMSTR+'"'
 CRITCQH -= '& [F:CQH2]NUMTRE<="'+[M:DIA]NUMEND+'"'
Endif


If [M:DIA]ALLCPY<>2  : CRITCQH -= '& [F:CQH2]CPY="'+[M:DIA]CPY+'"'        : Endif

OK = 1
For [CQH2]CQH0 Where evalue (CRITCQH)
 [L]SYMBOLE="CQH"+[F:CQH2]NUMTRE
 Lock =[L]SYMBOLE
 If fstat
  Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
  Call ECR_TRACE([F:CQH2]NUMTRE+"\"+GMESSAGE,1) From GESECRAN
  Raz GMESSAGE
  OK = 0
 Endif
Next

If !OK
 Call DELOCK("CQH") From GLOCK
 If !TRA : GERR=1 : SAI=1 : Endif
 Return
Endif

Call EMISSION([L]TRA,CRITCQH)
Return

################################################################################
#
# Routines
#
################################################################################

Subprog EMISSION(TRA, P_CRITCQH)
Variable Integer TRA
Value Char P_CRITCQH ()

Local Integer STAT, NBERR, I, NBLIG, TOTTRE, ER
Local Char    FEH([V]GLONADI), FICHIER (GDIMFIC), FICCLI(GDIMFIC), URL (GDIMFIC)
Local Char    FILENAM (GDIMFIC)
[L]FEH="CQL"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
Gosub DEFVAR

[L]EMISSION=1

Call DEBTRANS From GLOCK

$TR_EMISSION
[V]GOK=1
Trbegin [HRCQL],[CQH2]
 Gosub ECRITURE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN : Else Goto TR_EMISSION : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN
 Endif
Commit

#-------------------------------------------------------------------------------
$FIN
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM
End

#-------------------------------------------------------------------------------
$DEFVAR
Local Char    DATFMT(8), SAVIRS(2), SAVIFS(1)
Local Libelle SAVIUM

[L]DATFMT  ="DDMMYYYY"
[L]SAVIRS  =adxirs
[L]SAVIFS  =adxifs
[L]SAVIUM  =adxium
adxirs     =chr$(13)+chr$(10)
adxifs     =""
adxium     =[V]GASCII
Return

#-------------------------------------------------------------------------------
$ECRITURE
Columns [FEH] (LOC,LNG,ZON,TYP)
For [CQH2]CQH0 Where evalue(P_CRITCQH)
 Read[F:CPY2]CPY0=[F:CQH2]CPY
 If !fstat & [F:CPY2]TRECPY2<>""
  # Construction des nom de fichier si n génération
  # Commande :
  Call ECR_TRACE(mess(98,197,1)-":"-[F:CQH2]NUMTRE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  If [M:DIA]FILNAM<>"" & [M:DIA]TYPEXP=2
   FICHIER=[M:DIA]FILNAM
  Else
   Gosub TRNO
   If ER
    #Erreur Nom de fichier
    Call ECR_TRACE(mess(6,10719,1),1) From GESECRAN
    Break
   Endif

   FICHIER=[F:CQH2]TRECPY+'_'+num$(year([F:CQH2]DATTRE))+num$(month([F:CQH2]DATTRE))+'_'+num$([C]NUMFIL(3))
  Endif

  If [M:DIA]TYPEXP=2
   #92896 - US2135
   FICHIER=filpath([V]GDIRBQR,FICHIER,"prn",0)
  Else
   FICCLI=FICHIER+'.prn'
   FILENAM=FICCLI
   Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]URL) From ORDSYS
  Endif
  Openo FICHIER, 0 Using [OPO]
  Raz NBLIG, TOTTRE
  #83271 : Ajout de la legislation
  Filter[F:LNK] Where NUMTRE=[F:CQH2]NUMTRE & [F:CPY]LEG=GCURLEG Order By Key CLE=[CPY]CPYNAM;[FCY]FCYNAM;[HRCQL]NAMSRN
  For [F:LNK]CLE
   If [F:HRCQL]NBRTRE>0 :#80519
     Gosub EMISSION From =[L]FEHTRT
     Call ECR_TRACE([F:HRCQL]REFNUM-[F:HRCQL]NAMSRN-num$([F:HRCQL]NBRTRE),0) From GESECRAN
     [L]NBERR=0
     Onerrgo ERREURWW
     Gosub CONTROLE From =[L]FEHTRT
     Onerrgo
     If ![L]NBERR
      I=adxseek("OPO")
      For [FEH]FEH0 Where FEH=[L]FEH
       If [F:FEH]ZON=""
        Case [F:FEH]TYP
         When 3
          Wrseq string$([F:FEH]LNG,"0"); Using [OPO]
         When Default
          Wrseq space$([F:FEH]LNG); Using [OPO]
        Endcase
       Else
        # Matricule cadré à droite...
        If [F:FEH]ZON="EMP"
         Wrseq space$([F:FEH]LNG-len(evalue("[L]"+[F:FEH]ZON)))+left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG); Using [OPO]
        Elsif [F:FEH]ZON="NBRTRE"
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
         TOTTRE+=evalue("[L]"+[F:FEH]ZON)
        Elsif [F:FEH]ZON="NBRMTHVLY"
         # Si validité annuelle alors "00"
         If evalue("[L]"+[F:FEH]ZON)=12
          Wrseq "00"; Using [OPO]
         Else
          Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
         Endif
        Elsif find([F:FEH]ZON,"VALTRE","CHQ")
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)*100); Using [OPO]
        Else
         Case evalue("type([L]"+[F:FEH]ZON+")")
          When 1,2,4,5,6,7,8,9
           Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
          When 3
           Wrseq format$("D:"+[L]DATFMT,evalue("[L]"+[F:FEH]ZON)); Using [OPO]
          When Default
           Wrseq left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG); Using [OPO]
          Endcase
          Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
        Endif
       Endif
      Next
      Wrseq Using [OPO]
      Gosub MAJFIC From =[L]FEHTRT
      NBLIG+=1
      ##**82073
      Call MAJPRV([F:HRCQL]REFNUM,[F:HRCQL]DATTRE,[F:HRCQL]NBRTRE,[F:HRCQL]NUMTRE,[F:HRCQL]CTRNUM, [F:HRCQL]CTRDAT,time$)From TRTTRL
     Else
      #Ligne de commande incorrecte
      Call ECR_TRACE(mess(6,10719,1),1) From GESECRAN
      NBLIG=0 : Break
     Endif
   #80519
   Else
    Call ECR_TRACE([F:HRCQL]REFNUM-[F:HRCQL]NAMSRN-num$([F:HRCQL]NBRTRE),-1) From GESECRAN
   Endif
  Next
  Filter[F:LNK]
  Openo Using [OPO]
  If NBLIG
   [F:CQH2]FLGTRE=2 : # Commandé
   Rewrite [CQH2]
   If fstat
    GOK=0 : Call FSTA("CQH") From GLOCK
    Break
   Endif
   If [M:DIA]FLGWRK=2
    GWRK = FICHIER
    GBIDC1=[F:CQH2]TRECPY
    GBIDI1=TOTTRE
    Call WORKFLOW(1,"EDI","","") From AWRK
    Call ECR_TRACE(mess(205,10703,1),0) From GESECRAN : # Fichier envoyé par le workflow
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   Endif
   Call ECR_TRACE("",0) From GESECRAN
   If [M:DIA]TYPEXP<2
    # Init nom du fichier
    FICCLI=FILENAM
    Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
    If [L]STAT<>0 : [L]TRA = 0 : GOK=0 : Break : Endif
    #Fichier généré xxxxx (Astuce du "|" pour ne pas écrire de retour charriot dans le chemin)
    Call ECR_TRACE("|"+mess(104,121,1)-FICCLI,0) From GESECRAN
   Else
    #Fichier généré xxxxx
    Call ECR_TRACE(mess(104,121,1)-FICHIER,0) From GESECRAN
   Endif
   #
  Endif
 Endif
Next
Columns [FEH]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Openo Using [OPO]
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Goto FIN


###################################
$SEL_TABLE
OBJET="CQL"
SUPP="1"
CRITERE='FLGTRE<>2 & DATTRE>=['+format$(GFMD,[M:DIA]DATSTR)+'] & DATTRE<=['+format$(GFMD,[M:DIA]DATEND)+']'
If [M]CPY<>"" : CRITERE -= "& CPY='"+[M]CPY+"'" : Endif
Return

#########################################################################
$TRNO
ER=0
Lock NUMFIL
If fstat=0
 NUMFIL= [C]NUMFIL(3)
 [C]NUMFIL(3) += 1
 If fstat :  ER = 2 : Endif
Else
 ER = 1
Endif
Return

