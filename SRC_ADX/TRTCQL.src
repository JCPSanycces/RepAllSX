######################################################################################
#92896 - US2135
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#Control that the file exists :
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M:DIA]TYPEXP,VALEUR,[M:DIA]FILNAM,E_TYPE_FILEWRITE,GMESSAGE)
End

Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char NAMFIC
 Read[F:CPY]CPY0=[M:DIA]CPY
 If !fstat & [F:CPY]TRECPY2<>""
  If len(num$(month([M:DIA]DATEND)))<2
   NAMFIC=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+'0'+num$(month([M:DIA]DATEND))
  Else
   NAMFIC=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+num$(month([M:DIA]DATEND))
  Endif
 Endif
 If [M]TYPEXP=2
  VALEUR='['+[V]GDIRBQR+']/'+NAMFIC
 Else
  VALEUR=NAMFIC
 Endif
End
