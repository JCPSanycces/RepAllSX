Subprog AS_FILNAM(VALEUR)
Variable Char    VALEUR()
#If VALEUR<>"" | [M]CPY="" | [M]NUMSTR<>[M]NUMEND
# mkstat=1 : End
#Endif
If VALEUR=""
 Read[F:CPY]CPY0=[M:DIA]CPY
 If !fstat & [F:CPY]TRECPY2<>""
  If len(num$(month([M:DIA]DATEND)))<2
   VALEUR=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+'0'+num$(month([M:DIA]DATEND))
  Else
   VALEUR=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+num$(month([M:DIA]DATEND))
  Endif
 Endif
Endif
End

Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(250)
Local Integer OK
Call C_NOMEXP(VALEUR,"prn") From TRTDUE
If mkstat=2 : End : Endif
#92896 - US2135
Call EXISTE(filpath([V]GDIRBQR,[L]VALEUR,"prn",0),[L]OK) From ORDSYS
If [L]OK
 [V]GMESSAGE = mess(132,133,1) : # Fichier déjà existant
 [V]GERR     = 3
 End
Endif
End

