# Else
#  GCOMPTA = 2
#  ## Schéma standard de saisie
#  GSCHSTD(1) = "STD"
#  GSCHSTD(2) = "STDA"
#  GSCHSTD(3) = "STDL"
# Endif
#
# GNBTABCPT += 1 : GABRCPT(GNBTABCPT) = "GAC"
