  Call PARAM(GDOSLEG(ILEG),"PLAN",VALPAR)   From ADOVAL : GPLANOK(ILEG) = val(VALPAR)
 Next
Endif

If GMAS
 Local Integer ILEG
 For ILEG=1 To GNBLEG
  Call PARAM(GDOSLEG(ILEG),"PLANMS",VALPAR)   From ADOVAL : GPLANMSOK(ILEG) = val(VALPAR)
 Next
Endif

K = 0
For [ADI]CODE Where NUMTAB=10337
#81824
 If K<dim(GDECVAR)-1
  K += 1
  GDECVAR(K) = [F:ADI]N1
 Else
  Break
 Endif
Next

Call EMPTAB

# Nb Plage horaire
Read [ACV]CODACT = "HOR"
If !fstat & [F:ACV]FLACT=2
 GNBHOR = max(0,min([F:ACV]DIME ,9))
Else
 GNBHOR=0
Endif
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If GTPS=0
#** GNBHOR = 0
#**Endif
#**
If GTPS=0
 GNBHOR = 0
Endif
#ADNGO - 2017-05-20 - END
#
# Types de classes
Read [ADW]ADW0 = "";"";"CPTTYP"
If !fstat
 VALPAR = [F:ADW]VALEUR
Else
 VALPAR = string$(9,"1")
Endif
For I=1 To len(VALPAR)
 If dim(GCPTCLAS)>=I
  GCPTCLAS(I) = val(mid$(VALPAR,I,1))
 Endif
Next I
Read [ADW]ADW0 = "";"";"CPTCLAS"
If !fstat
 VALPAR = [F:ADW]VALEUR
Else
 VALPAR = "111112222"
Endif
For I=1 To len(VALPAR)
 If dim(GCPTRAZ)>=I
  GCPTRAZ(I) = val(mid$(VALPAR,I,1))
 Endif
Next I

End

############################################################

Subprog EMPTAB
Local File ATABLE  [ATB]
Local File ATABIND [ATI]
GNBEMPTAB = 0
For [ATB]CODFIC Where left$(CODFIC,5)="EMPLO"
 GNBEMPTAB += 1
 GEMPTAB(GNBEMPTAB) = [F:ATB]CODFIC
 Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
 Case [F:ATI]DESCRIPT
  When "REFNUM"        : GTYPTAB(GNBEMPTAB) = 1
  When "REFNUM+NUMLIG" : GTYPTAB(GNBEMPTAB) = 2
  When Default         : GTYPTAB(GNBEMPTAB) = 3
 Endcase
Next
Sorta GNBEMPTAB GEMPTAB,GTYPTAB Order By GTYPTAB(indice+1)
End

############################################################

Subprog AUTSRV
Local Integer OK
GNBSERV = 0

If !clalev([F:SRV]) : Local File SERVICE [SRV] : Endif
If !clalev([F:ACC]) : Local File ACCES   [ACC] : Endif

For [SRV]SRV0
 OK = 1
 If [F:SRV]CODACC<>""
  Read [ACC]CODACC = GUSER;[F:SRV]CODACC
  If fstat or [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  GNBSERV += 1
  GAUTSRV(GNBSERV) = [F:SRV]COD
 Endif
Next
GNBSERV += 1
GAUTSRV(GNBSERV) = ""
End

########################################################################################
## VARUSR de GLOBPAY
########################################################################################
Subprog VARUSR
# Mise à jour de la variable GAUTSRV
Call AUTSRV

If GPAYE
 GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
 If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif
 GDEBANN  = gdat$(func DIVPAYE.INIPARUSR("DEBANNPAY","",""))
 If GDEBANN=[0/0/0] : GDEBANN=gdat$(01,01,year(date$)) : Endif
 GFINANN  = gdat$(func DIVPAYE.INIPARUSR("FINANNPAY","",""))
 If GFINANN=[0/0/0] : GFINANN=gdat$(31,12,year(date$)) : Endif
 GJMAX  = val(func DIVPAYE.INIPARUSR("JMAX","",""))
Else
 GMOIPAY=gdat$(01,month(date$),year(date$))
Endif
End

## Version commerciale
Subprog VERCOM(VERSION)
Variable Char VERSION

VERSION="V8"

End

