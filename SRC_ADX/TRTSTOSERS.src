#<AdxTL>@(#)10.0.0.0 $Revision$
########################################################################
# Traitement TRTSTOSERS - Saisie des numéros de série en sortie   V140 #
#                                                                      #
########################################################################
# Action SAISTOSERS
#    Paramètres     - LABR    Abréviation masque : "SOR" ou "SOM"
#                   - LNOL    No ligne écran (nolign-1)
#
########################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FINSAI"        : Gosub FINSAI
Endcase

Return

#########################################################################
$OUVRE
Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Integer I, OK
Local Decimal WDISPO
#--- Issue 110327
Local Integer WRET
Local Char    WNUMFIN(GLONSER)
#---
If clalev([F:STS])=0  Local File STOSER [STS]  Endif
If clalev([M:SSS1])=0  Local Mask STOSERS [SSS1]  Endif            # hcb 117083

# Récupération des paramètres
LABR    = PARAM(1)
LNOL    = val(PARAM(2))

Return

#########################################################################
$DEBUT

#--- Issue 110327
Effzo [M:SSS]1-99
#---

[M:SSS]LABR      = LABR
[M:SSS]LNOL      = LNOL                               : #--- Issue 110327
[M:SSS]ITMREF    = evalue("[M:"+LABR+"]ITMREF")
[M:SSS]STU       = evalue("[M:"+LABR+"]STU")
[M:SSS]QTY       = evalue("[M:"+LABR+"]QTYSTU(LNOL)")
[M:SSS]QTYSTUACT = evalue("[M:"+LABR+"]QTYSTUACT(LNOL)")
[M:SSS]QTYPCU    = evalue("[M:"+LABR+"]QTYPCU(LNOL)")
[M:SSS]AVAQTYSTU = evalue("[M:"+LABR+"]AVAQTYSTU(LNOL)")
[M:SSS]AVAQTYPCU = evalue("[M:"+LABR+"]AVAQTYPCU(LNOL)")
#--- Issue 110327
[M:SSS]STOCOU    = evalue("[M:"+LABR+"]STOCOU(LNOL)")
#---

If evalue("[M:"+LABR+"]SERNUM(LNOL)")<>""
   [M:SSS]SERNUM(0)  = evalue("[M:"+LABR+"]SERNUM(LNOL)")
   [M:SSS]SERNUMF(0) = evalue("[M:"+LABR+"]SERNUMF(LNOL)")
   [M:SSS]QTYSTU(0)  = evalue("[M:"+LABR+"]QTYSTU(LNOL)")
   [M:SSS]NBLIG = 1
#--- Issue 110327
Elsif LABR="SOR" & [M:SSS]QTY=[M:SSS]AVAQTYSTU
   Filter [STS] Where [F:STS]ITMREF=[M:SSS]ITMREF & [F:STS]STOCOU=[M:SSS]STOCOU
&                   & [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM=""
&    Order By Key STS3
   If rowcount([F:STS])=[M:SSS]QTY
      # Remplissage de l'écran avec les séries
      I=0
      For [STS]
         If [M:SSS]SERNUM(I)=""
            [M:SSS]SERNUM(I)  = [F:STS]SERNUM
            [M:SSS]SERNUMF(I) = [F:STS]SERNUM
            [M:SSS]QTYSTU(I)  = 1
            [M:SSS]NBLIG      = 1
         Else
            Call PLUS_UN([M:SSS]SERNUMF(I),WNUMFIN,WRET) From STKLIB
            If WRET=0
               If [F:STS]SERNUM=WNUMFIN
                  [M:SSS]SERNUMF(I) = [F:STS]SERNUM
                  [M:SSS]QTYSTU(I) += 1
               Else
                  I += 1
                  [M:SSS]SERNUM(I)  = [F:STS]SERNUM
                  [M:SSS]SERNUMF(I) = [F:STS]SERNUM
                  [M:SSS]QTYSTU(I)  = 1
                  [M:SSS]NBLIG     += 1
               Endif
            Else
               Break
            Endif
         Endif
      Next
   Else
      [M:SSS]NBLIG = 0
   Endif
   Filter [STS]
#--- End issue 110327
Else
   [M:SSS]NBLIG = 0
Endif

Affzo [M:SSS]1-99

Return

#########################################################################
$SETBOUT

If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

#########################################################################
$AVANT_ENR

If [M:SSS]NBLIG=0
   # Pas de no série saisi, confirmez-vous l'enregistrement ?
   GMESSAGE = mess(72,184,1)
   # Oui par défaut
   OK=1
   Call OUINON(GMESSAGE,OK) From GESECRAN
   Raz GMESSAGE
   If OK=2
      Return
   Else
      FOK=0 : Return
   Endif
Elsif [M:SSS]NBLIG<>0 & sigma(I=0,[M:SSS]NBLIG-1,[M:SSS]QTYSTU(I))<>[M:SSS]QTY
   # Le nb de no série ne correspond pas à la qté à traiter
   GMESSAGE = mess(246,199,1)
   GERR=1 : FOK=0 : Return
Elsif [M:SSS]NBLIG>1
      Raz [M:SSS1]                    # hcb 117083
      Transmask [M:SSS] To [M:SSS1] # Issue 25606 [M:SSS1] = [M:SSS]              # hcb 117083
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:SSS1]NBLIG [M:SSS1]NBLIG Order By [M:SSS1]SERNUM([S]indice)     # hcb 117083
   For I=1 To [M:SSS1]NBLIG-1                                               # hcb 117083
      If [M:SSS1]SERNUM(I) <= [M:SSS1]SERNUMF(I-1)                          # hcb 117083
         GMESSAGE = mess(464,199,1)
         GERR=1 : FOK=0 : Break
      Endif
   Next I
Endif

Return

#########################################################################
$ENR

If LABR="SOR"
   Default Mask [M:SOR]
Elsif LABR="SOM"
   Default Mask [M:SOM]
Else
   FIN=1 : Return
Endif

If [M:SSS]NBLIG=0
   Raz [M]SERNUM(LNOL)
   Raz [M]SERNUMF(LNOL)
Elsif [M:SSS]NBLIG=1
   [M]SERNUM(LNOL)  = [M:SSS]SERNUM(0)
   [M]SERNUMF(LNOL) = [M:SSS]SERNUMF(0)
Else
   # Sauvegarde du disponible
   WDISPO = [M]AVAQTYSTU(LNOL)-[M]QTYSTU(LNOL)
   # Sauvegarde du déjà alloué
   If LABR="SOR"
      WALLSTU    = [M]ALLSTU(LNOL)
      WALLSTUACT = [M]ALLSTUACT(LNOL)
   Endif

   [M]SERNUM(LNOL)    = [M:SSS]SERNUM(0)
   [M]SERNUMF(LNOL)   = [M:SSS]SERNUMF(0)
   [M]QTYSTU(LNOL)    = [M:SSS]QTYSTU(0)

   [M]QTYSTUACT(LNOL) = [M:SSS]QTYSTUACT*[M]QTYSTU(LNOL)/[M:SSS]QTY
   [M]QTYPCU(LNOL)    = [M:SSS]QTYPCU*[M]QTYSTU(LNOL)/[M:SSS]QTY

   #--- Issue 110327
   #[M]AVAQTYSTU(LNOL) = WDISPO+[M]QTYSTU(LNOL)
   #[M]AVAQTYPCU(LNOL) = [M:SSS]AVAQTYPCU*[M]AVAQTYSTU(LNOL)/[M:SSS]AVAQTYSTU
   #---

   # Calcul de la nouvelle qté déjà allouée
   If LABR="SOR"
      [M]ALLSTU(LNOL)    = min(WALLSTU,[M]QTYSTU(LNOL))
      [M]ALLSTUACT(LNOL) = min(WALLSTUACT,[M]QTYSTUACT(LNOL))
      WALLSTU    -= [M]ALLSTU(LNOL)
      WALLSTUACT -= [M]ALLSTUACT(LNOL)
   Endif

   For I=1 To [M:SSS]NBLIG-1

      # Ouverture de la ligne
      nolign = [M]NBLIG
      Insa nolign,1,[M]NBLIG [M]NBLIG
      [M]NBLIG += 1
      nolign = [M]NBLIG
      NOL = nolign-1
      status = 0

      [M]SERNUM(NOL)  = [M:SSS]SERNUM(I)
      [M]SERNUMF(NOL) = [M:SSS]SERNUMF(I)
      [M]QTYSTU(NOL)  = [M:SSS]QTYSTU(I)

      If dim([M]LOT)    >0    [M]LOT(NOL)   =[M]LOT(LNOL)    Endif
      If dim([M]SLO)    >0    [M]SLO(NOL)   =[M]SLO(LNOL)    Endif
      If dim([M]LOC)    >0    [M]LOC(NOL)   =[M]LOC(LNOL)    Endif
      If dim([M]SHLDAT) >0    [M]SHLDAT(NOL)=[M]SHLDAT(LNOL) Endif
      If dim([M]POT)    >0    [M]POT(NOL)   =[M]POT(LNOL)    Endif

      #--- Issue 110327
      If dim([M]ECCVALMAJ)>0   [M]ECCVALMAJ(NOL)=[M]ECCVALMAJ(LNOL)  Endif
      If dim([M]ECCVALMIN)>0   [M]ECCVALMIN(NOL)=[M]ECCVALMIN(LNOL)  Endif
      If dim([M]WRH)      >0   [M]WRH(NOL)      =[M]WRH(LNOL)        Endif
      If dim([M]PALNUM)   >0   [M]PALNUM(NOL)   =[M]PALNUM(LNOL)     Endif
      If dim([M]CTRNUM)   >0   [M]CTRNUM(NOL)   =[M]CTRNUM(LNOL)     Endif
      If dim([M]STOFLD1)  >0   [M]STOFLD1(NOL)  =[M]STOFLD1(LNOL)    Endif
      If dim([M]STOFLD2)  >0   [M]STOFLD2(NOL)  =[M]STOFLD2(LNOL)    Endif
      [M]OWNER(NOL)     = [M]OWNER(LNOL)
      #--- End issue 110327

      [M]STA(NOL)       = [M]STA(LNOL)
      [M]SERNUMFLG(NOL) = 0
      [M]XPCU(NOL)      = [M]XPCU(LNOL)
      [M]XPCUSTUCOE(NOL)= [M]XPCUSTUCOE(LNOL)
      [M]STOCOU(NOL)    = [M]STOCOU(LNOL)
      [M]TOTQTYSTU(NOL) = [M]TOTQTYSTU(LNOL)
      [M]QTYSTUORI(NOL) = 0
      [M]QTYSTUACT(NOL) = [M]QTYSTUACT(LNOL)*[M]QTYSTU(NOL)/[M]QTYSTU(LNOL)
      [M]QTYPCU(NOL)    = [M]QTYPCU(LNOL)*[M]QTYSTU(NOL)/[M]QTYSTU(LNOL)
      #--- Issue 110327
      #[M]AVAQTYSTU(NOL) = WDISPO+[M]QTYSTU(NOL)
      #[M]AVAQTYPCU(NOL) = [M]AVAQTYPCU(LNOL)*[M]AVAQTYSTU(NOL)/[M]AVAQTYSTU(LNOL)
      [M]AVAQTYSTU(NOL) = [M]AVAQTYSTU(LNOL)
      [M]AVAQTYPCU(NOL) = [M]AVAQTYPCU(LNOL)
      #---

      If LABR="SOR"
         # Calcul de la nouvelle qté déjà allouée
         [M]ALLSTU(NOL)    = min(WALLSTU,[M]QTYSTU(NOL))
         [M]ALLSTUACT(NOL) = min(WALLSTUACT,[M]QTYSTUACT(NOL))
         WALLSTU    -= [M]ALLSTU(NOL)
         WALLSTUACT -= [M]ALLSTUACT(NOL)
      Elsif LABR="SOM"
         [M]WAIFLG(NOL) = [M]WAIFLG(LNOL)
         [M]MVTSEQ(NOL) = 0
         [M]MVTIND(NOL) = 0
      Endif
   Next I
Endif

#--- Issue 110327
# Pour forcer le raffraichissement du picking
GSAISERIE=1
#---
Default Mask [M:SSS]

FIN=1

Return

#########################################################################
$ABA

Gosub DEBUT

Return

#########################################################################
$FINSAI

If LABR="SOR"
   Default Mask [M:SOR]
Elsif LABR="SOM"
   Default Mask [M:SOM]
Else
   Return
Endif

Affzo [M]15

#--- Issue 110327
# Pour forcer le raffraichissement du picking
If GSAISERIE=1 mkstat=4 Endif
#---

Return

#--- Issue 110327
##########################################################################
Subprog IB_SERNUM
If [F:ITM]SERMGTCOD<>4 Raz GBOUT1 Endif
End
#---

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
#--- Issue 110327
Local    Integer OK : OK=1
Local    Integer WOK
Local    Integer WCTLSER   : # Contrôle no série : 0=bloquant, 1=non bloquant (information)
WCTLSER=0
#---
NOL = nolign-1

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  If [F:STO]STOCOU<>[M:SSS]STOCOU
    Read [STO]=evalue("[M:"+[M:SSS]LABR+"]STOFCY");[M:SSS]STOCOU
  Endif
  Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WCTLSER) From STKLIB
  If WCTLSER = 2
     WCTLSER=1
  Endif
Endif
#---

If [M:SSS]LABR="SOR"
  Read [STS]STS0=[M:SSS]ITMREF;VALEUR
  #--- Issue 110327
  # Si no série existe, erreur
  #If !fstat
  #   mkstat=2 : GMESSAGE=mess(3,187,1) : End
  #Endif
  Case [F:ITM]SERMGTCOD
   When 2 : If !fstat
              mkstat=2 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
            Endif
   When 4 : If fstat
              mkstat=2 : GMESSAGE=VALEUR-":"-mess(43,196,1) : End
            Elsif [F:STS]ISSDAT<>[0/0/0]
              mkstat=2 : GMESSAGE=VALEUR-":"-mess(37,184,1) : End
            Elsif [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
              mkstat=2 : GMESSAGE=VALEUR-":"-mess(443,184,1) : End
            Elsif [F:STS]STOCOU<>[M:SSS]STOCOU
              If WCTLSER=1
                Read [STO]=evalue("[M:"+[M:SSS]LABR+"]STOFCY");[F:STS]STOCOU
                Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WOK) From STKLIB
                If WOK = 2
                  WOK=1
                  Call AVERTIR (VALEUR,mess(486,184,1), WOK)From GESECRAN
                  If WOK=1 mkstat=2 : End : Endif
                Endif
              Else
                mkstat=2 : GMESSAGE=VALEUR-":"-mess(447,184,1) : End
              Endif
            Endif

            If [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
              If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                If OK=1  mkstat=2 : End  Endif
              Endif
            Endif

            If VALEUR<[M:SOR]SERNUM([M:SSS]LNOL) | VALEUR>[M:SOR]SERNUMF([M:SSS]LNOL)
              #--- Contrôle no série en cours de traitement ?
              If func STKLIB.REC_STOSERW_UID([M:SSS]ITMREF,VALEUR,adxuid(1))<>0
                mkstat=2 : GMESSAGE=VALEUR-":"-mess(449,184,1) : End
              Endif
            Endif
  Endcase
  #--- End issue 110327

  If [M:SSS]QTYSTU(NOL)=0
    If NOL=0
      [M:SSS]QTYSTU(NOL) = [M:SSS]QTY
    Else
      [M:SSS]QTYSTU(NOL) = [M:SSS]QTY-sigma(I=0,NOL-1,[M:SSS]QTYSTU(I))
    Endif
  Endif

  If [M:SSS]QTYSTU(NOL)=1
    [M:SSS]SERNUMF(NOL) = VALEUR
  Else
    # Vérification que les no série n'existent pas
    # et alimentation du no série fin
    WNBSERIE = [M:SSS]QTYSTU(NOL)
    WNUMDEB  = VALEUR
    For J=2 To WNBSERIE
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
        Read [STS]STS0=[M:SSS]ITMREF;WNUMFIN
        #--- Issue 110327
        #If fstat
        #   WNUMDEB = WNUMFIN
        #Else
        #   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #Endif
        Case [F:ITM]SERMGTCOD
         When 2 : If !fstat
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
                  Else
                    WNUMDEB = WNUMFIN
                  Endif
         When 4 : If fstat
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
                  Elsif [F:STS]ISSDAT<>[0/0/0]
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
                  Elsif [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
                  Elsif [F:STS]STOCOU<>[M:SSS]STOCOU
                    If WCTLSER=1
                      Read [STO]=evalue("[M:"+[M:SSS]LABR+"]STOFCY");[F:STS]STOCOU
                      Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WOK) From STKLIB
                      If WOK = 2
                        WOK=1
                        Call AVERTIR (WNUMFIN,mess(486,184,1), WOK)From GESECRAN
                        If WOK=1 mkstat=2 : Break : Endif
                      Endif
                    Else
                      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
                    Endif
                  Endif

                  If OK=1 & [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
                    If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                      OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                      If OK=1  mkstat=2 : Break  Endif
                    Endif
                  Endif

                  If WNUMFIN<[M:SOR]SERNUM([M:SSS]LNOL) | WNUMFIN>[M:SOR]SERNUMF([M:SSS]LNOL)
                    #--- Contrôle no série en cours de traitement ?
                    If func STKLIB.REC_STOSERW_UID([M:SSS]ITMREF,WNUMFIN,adxuid(1))<>0
                      mkstat=2 : GMESSAGE=VALEUR-":"-mess(449,184,1) : Break
                    Endif
                  Endif
                  WNUMDEB = WNUMFIN
        Endcase
        #--- End issue 110327
      Else
        mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
      Endif
    Next J
    If mkstat=2 End Endif
    [M:SSS]SERNUMF(NOL) = WNUMFIN
  Endif
  Affzo [M]SERNUMF(NOL)
  End
Endif

If [M:SSS]LABR="SOM"
  Read [STS]STS0=[M:SSS]ITMREF;VALEUR
  #--- Issue 110327
  ## Le no série existe
  #If !fstat
  #   # S'il n'a pas été sortie par cette pièce --> erreur
  #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&      | [F:STS]SDDLIN<>[M:SOM]VCRLIN
  #      mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
  #   # S'il a une pièce entrée --> erreur
  #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
  #      mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
  #   Endif
  #Endif
  # Si séries en E/S globale
  If [F:ITM]SERMGTCOD=4
    If fstat
      mkstat=2 : GMESSAGE=VALEUR-":"-mess(43,196,1) : End
    Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
      mkstat=2 : GMESSAGE=VALEUR-":"-mess(37,184,1) : End
    Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOM]VCRLIN,[M:SOM]VCRLINORI))
      mkstat=2 : GMESSAGE=VALEUR-":"-mess(443,184,1) : End
    Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SSS]STOCOU
      If WCTLSER=1
        Read [STO]=evalue("[M:"+[M:SSS]LABR+"]STOFCY");[F:STS]STOCOU
        Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WOK) From STKLIB
        If WOK = 2
          WOK=1
          Call AVERTIR (VALEUR,mess(486,184,1), WOK)From GESECRAN
          If WOK=1 mkstat=2 : End : Endif
        Endif
      Else
        mkstat=2 : GMESSAGE=VALEUR-":"-mess(447,184,1) : End
      Endif
    Endif

    If [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
      If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
        OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
        If OK=1  mkstat=2 : End  Endif
      Endif
    Endif

    #--- No série en cours de traitement?
    If func STKLIB.REC_STOSERW([M:SSS]ITMREF,VALEUR)<>0
      mkstat=2 : GMESSAGE=VALEUR-":"-mess(449,184,1) : End
    Endif
    # No série en sortie qui existe
  Elsif !fstat
    # S'il n'a pas été sortie par cette pièce --> erreur
    If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&    | [F:STS]SDDLIN<>[M:SOM]VCRLIN
      mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
    # S'il a une pièce entrée --> erreur
    Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
      mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
    Endif
  Endif
  #--- End issue 110327

  # Si qté =1, alimentation no série fin
  If [M:SSS]QTYSTU(NOL)=1
    [M:SSS]SERNUMF(NOL) = VALEUR
  Else
    # Vérification que les no série n'existent pas
    # et alimentation du no série fin
    WNBSERIE = [M:SSS]QTYSTU(NOL)
    WNUMDEB  = VALEUR
    For J=2 To WNBSERIE
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
        Read [STS]STS0=[M:SSS]ITMREF;WNUMFIN
        #--- Issue 110327
        #If fstat
        #   WNUMDEB = WNUMFIN
        ## Le no série existe
        #Else
        #   # S'il n'a pas été sortie par cette pièce --> erreur
        #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&           | [F:STS]SDDLIN<>[M:SOM]VCRLIN
        #      mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #   # S'il a une pièce entrée --> erreur
        #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
        #      mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #   Else
        #      WNUMDEB = WNUMFIN
        #   Endif
        #Endif
        # Si séries en E/S globale
        If [F:ITM]SERMGTCOD=4
          If fstat
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
          Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
          Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOM]VCRLIN,[M:SOM]VCRLINORI))
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
          Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SSS]STOCOU
            If WCTLSER=1
              Read [STO]=evalue("[M:"+[M:SSS]LABR+"]STOFCY");[F:STS]STOCOU
              Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WOK) From STKLIB
              If WOK = 2
                WOK=1
                Call AVERTIR (WNUMFIN,mess(486,184,1), WOK)From GESECRAN
                If WOK=1 mkstat=2 : Break : Endif
              Endif
            Else
              mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
            Endif
          Endif

          If OK=1 & [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
            If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
              OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
              If OK=1  mkstat=2 : Break  Endif
            Endif
          Endif

          #--- No série en cours de traitement?
          If func STKLIB.REC_STOSERW([M:SSS]ITMREF,WNUMFIN)<>0
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
          Endif
          # No série en sortie qui existe
        Elsif !fstat
          # S'il n'a pas été sortie par cette pièce --> erreur
          If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&          | [F:STS]SDDLIN<>[M:SOM]VCRLIN
            mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
          # S'il a une pièce entrée --> erreur
          Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
            mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
          Endif
        Endif
        WNUMDEB = WNUMFIN
        #--- End issue 110327

      Else
        mkstat=1 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
      Endif
    Next J
    If mkstat<>0 End Endif
    [M:SSS]SERNUMF(NOL) = WNUMFIN
  Endif
  Affzo [M]SERNUMF(NOL)
Endif

End

##########################################################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL=nolign-1

# Si la quantité était nulle
If [M:SSS]QTYSTU(NOL)=0 End Endif

# La quantité a diminué
If VALEUR < [M:SSS]QTYSTU(NOL)
   If [M:SSS]SERNUM(NOL)<>""             : #--- Issue 110327
      WNBSER  = VALEUR
      WNUMDEB = [M:SSS]SERNUM(NOL)
      If WNBSER=1
         [M:SSS]SERNUMF(NOL) = WNUMDEB
      Else
         Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
         If WRET=0
            [M:SSS]SERNUMF(NOL) = WNUMFIN
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
         Endif
      Endif
      Affzo [M:SSS]SERNUM(NOL), SERNUMF(NOL)
   Endif                                 : #--- Issue 110327
   End
Endif

If [M:SSS]LABR="SOR"
  # La quantité a augmenté
  If VALEUR > [M:SSS]QTYSTU(NOL)
    # Vérification que les no série n'existent pas
    # pour le surplus et alimentation du no série fin
    WNBSER  = VALEUR-[M:SSS]QTYSTU(NOL)
    WNUMDEB = [M:SSS]SERNUMF(NOL)
    For J=1 To WNBSER
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
        Read [STS]STS0=[M:SSS]ITMREF;WNUMFIN
        #--- Issue 110327
        #If fstat
        #   WNUMDEB = WNUMFIN
        #Else
        #   mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #Endif
        Case [F:ITM]SERMGTCOD
         When 2 : If !fstat
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
                  Else
                    WNUMDEB = WNUMFIN
                  Endif
         When 4 : If fstat
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
                  Elsif [F:STS]STOCOU<>[M:SSS]STOCOU
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
                  Elsif [F:STS]ISSDAT<>[0/0/0]
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
                  Elsif [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOR]VCRNUM,[M:SOR]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOR]VCRLIN,[M:SOR]VCRLINORI))
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
                  Endif

                  If OK=1 & [M:SOR]VCRTYP=8 & [M:SOR]VCRNUMORI<>""
                    If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOR]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOR]VCRLINORI
                      OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                      If OK=1  mkstat=2 : Break  Endif
                    Endif
                  Endif

                  #--- Contrôle no série en cours de traitement ?
                  If func STKLIB.REC_STOSERW_UID([M:SSS]ITMREF,WNUMFIN,adxuid(1))<>0
                    mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
                  Endif
                  WNUMDEB = WNUMFIN
        Endcase
        #--- End issue 110327

      Else
        mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
      Endif
    Next J
    If mkstat=2 End Endif
    [M:SSS]SERNUMF(NOL) = WNUMFIN
    Affzo [M:SSS]SERNUM(NOL), SERNUMF(NOL)
    End
  Endif
Endif

If [M:SSS]LABR="SOM"
  # La quantité a augmenté
  If VALEUR > [M:SSS]QTYSTU(NOL)
    # Vérification que les no série n'existent pas
    # pour le surplus et alimentation du no série fin
    WNBSER  = VALEUR-[M:SOM]QTYSTU(NOL)
    WNUMDEB = [M:SOM]SERNUMF(NOL)

    For J=1 To WNBSER
      Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
      If WRET=0
        Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
        #--- Issue 110327
        #If fstat
        #   WNUMDEB = WNUMFIN
        ## Le no série existe
        #Else
        #   # S'il n'a pas été sortie par cette pièce --> erreur
        #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&           | [F:STS]SDDLIN<>[M:SOM]VCRLIN
        #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #   # S'il a une pièce entrée --> erreur
        #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
        #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
        #   Endif
        #Endif
        # Si séries en E/S globale
        If [F:ITM]SERMGTCOD=4
          If fstat
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
          Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SSS]STOCOU
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
          Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
          Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & (!find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)|!find([F:STS]SDDLIN,[M:SOM]VCRLIN,[M:SOM]VCRLINORI))
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
          Endif

          If OK=1 & [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
            If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
              OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
              If OK=1  mkstat=2 : Break  Endif
            Endif
          Endif

          #--- No série en cours de traitement?
          If func STKLIB.REC_STOSERW([M:SSS]ITMREF,WNUMFIN)<>0
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(449,184,1) : Break
          Endif
          # Si série en sortie qui existe
        Elsif !fstat
          # S'il n'a pas été sortie par cette pièce --> erreur
          If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&          | [F:STS]SDDLIN<>[M:SOM]VCRLIN
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            # S'il a une pièce entrée --> erreur
          Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
            mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
          Endif
        Endif
        WNUMDEB = WNUMFIN
        #--- End issue 110327

      Else
        mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
      Endif
    Next J
    If mkstat=2 End Endif
    #--- Issue 110327
    #[M:SOM]SERNUMF(NOL) = WNUMFIN
    [M:SSS]SERNUMF(NOL) = WNUMFIN
    #---
    Affzo [M:SSS]SERNUM(NOL), SERNUMF(NOL)
  Endif
Endif

End

######################################################################################

