 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TCTR","A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
Endif
Gosub _AFF
End

$AMM_TCTRNUM
Call AM_TCTRNUM(zc)
If !mkstat & GOBJET
