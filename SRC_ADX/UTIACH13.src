#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIACH13      Utilitaire de récupération du bug 45593     Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Vérifier et remettre si nécessaire :                                 #
#    - PRECEIPT                                                          #
#        INVLINNBR : Nbre lignes totalement facturées                    #
#        INVLINCTR : Nbre lignes facturées (partiellement ou totalement) #
#        INVFLG    : Indicateur réception facturée                       #
#    - PRECEIPTD                                                         #
#        INVQTYPUU : Qté facturée en UA                                  #
#        INVQTYSTU : Qté facturée en US                                  #
#        LININVFLG : Indicateur ligne facturée                           #
#    - PORDERQ                                                           #
#        INVRCPNBR : Nbre de réceptions facturées                        #
##########################################################################

Call MAJ_UTIACH13
End

Subprog MAJ_UTIACH13
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH13 - Récup. Bug 45593") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH13 : Utilitaire réajustement indicateurs réceptions facturées") From LECFIC
  Call EXE_UTIACH13(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH13(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), WMSG2(90), CRITERE(150)
Local Char     CLE1(GLONPOH)
Local Integer COMPTEUR, STOP
Local Integer  NBENR, NBCOR, CLE2, CLE3
Local Decimal  WINVQTYPUU
Local Decimal  WINVQTYSTU
Local Libelle  WFLAG_INVRCPNBR
Local Libelle  WFLAG_INVLINCTR
Local Char     WPOHNUM(GLONPOH)
Local Integer  WPOPLIN
Local Integer  WPOQSEQ
#-----
Call ECR_TIME("UTIACH13 : Début traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ] : Endif
If !clalev([F:PTH])  Local File =DOSSIER+".PRECEIPT"  [PTH] : Endif
If !clalev([F:PTD])  Local File =DOSSIER+".PRECEIPTD" [PTD] : Endif
If !clalev([F:PID])  Local File =DOSSIER+".PINVOICED" [PID] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR, STOP
Raz WPOHNUM
#-----
$BOUCLE_POQ
If STOP=1
  STOP=2 : CRITERE ='POHNUM="'+CLE1+'"'+' & POPLIN='+num$(CLE2)+' & POQSEQ>'+num$(CLE3)
Elsif STOP=2
  STOP=3 : CRITERE ='POHNUM="'+CLE1+'"'+' & POPLIN>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE ='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POQ], [PTH], [PTD]
  For [POQ] POQ0 Where evalue(CRITERE) & LINRCPNBR>0 & (LININVFLG>1 | INVQTYSTU<>0)
    NBENR+=1
    WPOHNUM=[F:POQ]POHNUM
    WPOPLIN=[F:POQ]POPLIN
    WPOQSEQ=[F:POQ]POQSEQ
    WINVQTYPUU=[F:POQ]INVQTYPUU
    WINVQTYSTU=[F:POQ]INVQTYSTU
    #-----
    For [PTD] PTD2 Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
      NBENR+=1
      WINVQTYPUU-=[F:PTD]INVQTYPUU
      WINVQTYSTU-=[F:PTD]INVQTYSTU
      Look [PID] PID1(3)=2;[F:PTD]PTHNUM;[F:PTD]PTDLIN
      If fstat & [F:PTD]LININVFLG<>2 & [F:PTD]INVQTYSTU<[F:PTD]QTYSTU & (WINVQTYPUU<>0 | WINVQTYSTU<>0)
        Readlock [PTD] Curr
        If fstat
          Call ECR_TRACE("Readlock PRECEIPTD"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
          GOK=0 : Break 2
        Endif
        #-----
        If [F:PTD]INVQTYPUU<>0 | [F:PTD]INVQTYSTU<>0
          WFLAG_INVLINCTR=0
        Else
          WFLAG_INVLINCTR=1
        Endif
        #-----
        WMSG="Rcp"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"Quantité facturée :"-num$([F:PTD]INVQTYSTU)
        If WINVQTYSTU>=[F:PTD]QTYSTU-[F:PTD]INVQTYSTU
          WINVQTYPUU-=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
          WINVQTYSTU-=([F:PTD]QTYSTU-[F:PTD]INVQTYSTU)
          [F:PTD]INVQTYPUU=[F:PTD]QTYPUU
          [F:PTD]INVQTYSTU=[F:PTD]QTYSTU
          [F:PTD]LININVFLG=2
          WFLAG_INVRCPNBR=1
          WMSG2="Rcp"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"Indicateur ligne facturée : 1 (Non) --> 2 (Oui)"
        Else
          [F:PTD]INVQTYPUU+=WINVQTYPUU
          [F:PTD]INVQTYSTU+=WINVQTYSTU
          Raz WINVQTYPUU
          Raz WINVQTYSTU
          WFLAG_INVRCPNBR=0
          WMSG2=""
        Endif
        WMSG-="-->"-num$([F:PTD]INVQTYSTU)
        #----- Mise à jour ligne réception -----#
        COMPTEUR+=1
        Rewrite [PTD]
        If fstat
          Call ECR_TRACE("Rewrite PRECEIPTD"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
          GOK=0 : Break 2
        Else
          Call ECR_TRACE(WMSG,0) From GESECRAN
          If WMSG2<>""  Call ECR_TRACE(WMSG2,0) From GESECRAN : Endif
          NBCOR+=1
        Endif
        #----- Mise à jour entête réception -----#
        Readlock [PTH] PTH0=[F:PTD]PTHNUM
        If fstat
          Call ECR_TRACE("Readlock PRECEIPT"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
          GOK=0 : Break 2
        Endif
        Raz WMSG, WMSG2
        If WFLAG_INVLINCTR
          WMSG ="Rcp"-[F:PTH]PTHNUM-"Nbre de lignes facturées :"-num$([F:PTH]INVLINCTR)
          WMSG-="-->"-num$([F:PTH]INVLINCTR+1)
          [F:PTH]INVLINCTR+=1
        Endif
        If [F:PTD]LININVFLG=2
          WMSG ="Rcp"-[F:PTH]PTHNUM-"Nbre de lignes totalement facturées :"-num$([F:PTH]INVLINNBR)
          WMSG-="-->"-num$([F:PTH]INVLINNBR+1)
          [F:PTH]INVLINNBR+=1
        Endif
        If [F:PTH]INVLINNBR>=[F:PTH]LINNBR & [F:PTH]INVFLG<>3
          WMSG2 ="Rcp"-[F:PTH]PTHNUM-"Indicateur réception facturée :"-num$([F:PTH]INVFLG)
          WMSG2-="("+mess([F:PTH]INVFLG,280,1)+")"-"--> 3 ("+mess(3,280,1)+")"
          [F:PTH]INVFLG=3
        Elsif WFLAG_INVLINCTR & [F:PTH]INVFLG<>2
          WMSG2 ="Rcp"-[F:PTH]PTHNUM-"Iindicateur réception facturée :"-num$([F:PTH]INVFLG)
          WMSG2-="("+mess([F:PTH]INVFLG,280,1)+")"-"--> 2 ("+mess(2,280,1)+")"
          [F:PTH]INVFLG=2
        Endif
        COMPTEUR+=1
        Rewrite [PTH]
        If fstat
          Call ECR_TRACE("Rewrite PRECEIPT"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
          GOK=0 : Break 2
        Else
          If WMSG<>""   Call ECR_TRACE(WMSG,0)  From GESECRAN : Endif
          If WMSG2<>""  Call ECR_TRACE(WMSG2,0) From GESECRAN : Endif
        Endif
        #----- Mise à jour de la ligne de commande -----#
        If WFLAG_INVRCPNBR
          NBENR+=1
          COMPTEUR+=1
          Update [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ
&                      With  INVRCPNBR+=1
          If fstat
            Call ECR_TRACE("Update PORDERQ"-WPOHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
            GOK=0 : Break 2
          Else
            WMSG ="Cde"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-"Nbre de réceptions facturées :"-num$([F:POQ]INVRCPNBR)
            WMSG-="-->"-num$([F:POQ]INVRCPNBR+1)
            Call ECR_TRACE(WMSG,0)  From GESECRAN
            NBCOR+=1
          Endif
        Endif
      Endif
      If WINVQTYSTU=0  Break : Endif
    Next
    #-----
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POQ]POHNUM : CLE2=[F:POQ]POPLIN : CLE3=[F:POQ]POQSEQ
      STOP=1 : Break
    Endif
  Next
  If GOK<1  Rollback : Goto FIN_UTIACH13 : Endif
Commit
If STOP  Goto BOUCLE_POQ : Endif
#----- Fin du traitement -----#
$FIN_UTIACH13
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH13 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [POQ], [PTH], [PTD], [PID]
End
