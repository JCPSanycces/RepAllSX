#<AdxTL>@(#)2.0.0.0 $Revision$
Call IMPORTATION("CODPOS") From GIMPOBJ
End

$ACTION
Case ACTION
 When "IMPORT"    : Gosub IMPORT
 When "AP_IMPORT" : Gosub AP_IMPORT
Endcase
Return


$IMPORT
If [F]POSCTYCOD="00000"
 GREP = ""
 OK = -1
Endif
#79830
If [M:POS1]POSCTY=""
 [M:POS1]POSCTY = [F:POS]POSCTY
Endif
If [M:POS1]POSCTYCOD=""
 [M:POS1]POSCTYCOD = [F:POS]POSCTYCOD
Endif
Return

#42738
$AP_IMPORT
If [F:POS]CRY=""
 [F:POS]CRY = GPAYS
Endif
#79830
If [F:POS]POSCTYCOD=""
 [F:POS]POSCTYCOD = [F:POS]POSCOD
Endif
Return
