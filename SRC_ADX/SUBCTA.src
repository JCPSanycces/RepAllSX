#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE               From SUBCTAA
    When "FERME"        : Gosub FERME               From SUBCTAA
    When "LIENS"        : Gosub LIENS               From SUBCTAA
    When "RAZCRE"       : Gosub RAZCRE              From SUBCTAA
    When "RAZDUP"       : Gosub RAZDUP              From SUBCTAA
    When "CREATION"     : Gosub CREATION            From SUBCTAA
    When "APRES_CRE"    : Gosub APRES_CRE           From SUBCTAA
    When "MODIF"        : Gosub MODIF               From SUBCTAA
    When "APRES_MOD"    : Gosub APRES_MOD           From SUBCTAA
    When "AV_ANNULE"    : Gosub AV_ANNULE           From SUBCTAA
    When "ANNULE"       : Gosub ANNULE              From SUBCTAA
    When Default
  Endcase
Return

##########################################################################################################
##########################################################################################################
# Screens fields
##########################################################################################################
# CTA0
##########################################################################################################
##########################################################################################################
Subprog AM_TCACOD(VALEUR)
Variable Char    VALEUR()

  GZINSCATTSK.TCACOD = VALEUR
  # ---------------------------
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSCATTSK) From SUBCTAA
  If GERR = 1 Then
    mkstat = 2
    End
  Else
    Call SHOW_RECORD(GZINSCATTSK) From SUBCTAA
  Endif
End

