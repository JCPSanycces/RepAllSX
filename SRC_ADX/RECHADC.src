#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHADC","RECHADC",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "DEBUT"       : Gosub DEBUT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

$INIT
Local Mask    RECHADC [DIA]
Local Integer TROUVE
Raz [M:DIA]
Gosub OUVRE
Return

$OUVRE_BATCH
$OUVRE
Local File ATABLE [ATB] , ATABZON [ATZ] , ATABZON [ATZ2] , ATABIND [ATI] , AOBJET [AOB] , ATYPE [ATY]
Return

$DEBUT
If [M:DIA]TYP<>""
 Call C_TYP([M:DIA]TYP)
 If mkstat
  FIN = 1 : Return
 Endif
 zonsui = "COD"
Endif
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1 : Return
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(43,100,1)-[M:DIA]TYP-":"-[M:DIA]COD) From LECFIC
Endif
TROUVE = 0
Call RECHERCHE([M:DIA]TYP,[M:DIA]COD,TROUVE)
If TROUVE
 Call ECR_TRACE("\"+string$(40,"-"),0) From GESECRAN
Endif
Call ECR_TRACE(mess(9,127,1)-":"-num$(TROUVE),0) From GESECRAN : # Nombre de ligne
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return

Subprog RECHERCHE(TYP,COD,TROUVE)
Value Char TYP , COD
Variable Integer TROUVE
Local Integer I , J , K , L , INTE , DIME , JOKER , ER , ENT
Local Char    CLE(GLONAVA)(1..16) , NOMCLE(250) , CODCLE(GLONID) , CHAINE(250)
Local Integer NBCLE
Local Char    TABCUR(GLONATB) , TABLE(GLONATB) , TEXTE(250)
Local Char    TYPREC(GLONATY) , TABREC(GLONATB) , CODREC(250) , TEXREC(250) , INTREC(250)
Local Char    TRTSRC(GLONADC+2)(1..32000) , ORDSYS(250)
Local Integer STAT , NBSRC
Local Char    FICSRC(GDIMFIC) , LIGNE(250)
Local Char    TAB(GLONATB) , OBJ(GLONAOB)
Gosub OUVRE
TYPREC = toupper([L]TYP)
CODREC = [L]COD
JOKER  = (instr(1,CODREC,"?") | instr(1,CODREC,"*"))
If find(TYPREC,"TEX","TRT")
 If left$(CODREC,1)<>"*"            : CODREC = "*"+CODREC : Endif
 If right$(CODREC,len(CODREC))<>"*" : CODREC = CODREC+"*" : Endif
Endif
Call CONTTYP(TYPREC,TAB,OBJ)
If mkstat : End Endif
TABREC = toupper([L]TAB)
TEXREC = '"'+CODREC+'"'
If find(TYPREC,"TEX","TRT")
 INTREC = mess(2,89,1) : # Expression
Else
 Read [ATY]CODTYP = TYPREC
 Call TEXTE([F:ATY]INTITTYP,INTREC) From OBJDIV
 INTREC = TYPREC-INTREC
Endif
If TABREC<>""
 Local File =TABREC [BBB_]
 Read [ATI]NUMLIG(2) = TABREC;1
 CHAINE = [F:ATI]DESCRIPT
 If !instr(1,CHAINE,"+") & !instr(1,CHAINE,"-")
  Case evalue("type([F:BBB_]"+CHAINE+")")
   When 1,2,4,5,6,7 : Assign "[F:BBB_]"+CHAINE With val(CODREC)
   When Default     : Assign "[F:BBB_]"+CHAINE With CODREC
  Endcase
  Read [F:BBB_] =
  If !fstat
   Read [ATZ]CODZONE = TABREC ; [F:ATB]INTIT
   If !fstat
    Case [F:ATZ]CODTYP
     When "ATX"
      Call TEXTE(evalue("[F:BBB_]"+[F:ATB]INTIT),TEXTE) From OBJDIV
      TEXREC -= "("+TEXTE+")"
     When "AXX","AX1","AX2","AX3"
     When Default
      TEXREC -= "("+num$(evalue("[F:BBB_]"+[F:ATB]INTIT))+")"
    Endcase
   Endif
  Endif
 Endif
Endif
If !GSERVEUR
 Call OUVRE_BOITE(mess(43,100,1)-INTREC-'"'+CODREC+'"',100) From GESECRAN : # Recherche
Endif
Case TYPREC
 When "TEX","TRT" : Gosub CHERCHE_SRC
 When "ADC","ASU" : Gosub CHERCHE : Gosub CHERCHE_SRC
 When Default     : Gosub CHERCHE
Endcase
If !GSERVEUR
 Call FERME_BOITE From GESECRAN
Endif
End

$CHERCHE
If !GSERVEUR
 Call SET_BOITE(INTREC,nbrecord([F:ATB])) From GESECRAN
Endif
Raz K , TABLE , TABCUR , ENT
For [ATB]CODFIC Where CODFIC<>TABREC
 TABLE = [F:ATB]CODFIC
 K += 1
 If !GSERVEUR
  Call AFF_BOITE("",K,INTE) From GESECRAN
 Endif
 For [ATZ]NUMLIG Where CODFIC=[F:ATB]CODFIC & [F:ATZ]CODTYP=TYPREC
  If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",nomap),0)>0
   ER = 0
   Onerrgo ERRFIC
   Local File =[F:ATB]CODFIC [AAA_]
   Read [AAA_] First
   Onerrgo
   If !ER
    For [AAA_]
     DIME = evalue("dim([F:AAA_]"+[F:ATZ]CODZONE+")")
     OK = 0
     If DIME=1
      Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
       When 1,2,4,5,6,7 : OK = (evalue("[F:AAA_]"+[F:ATZ]CODZONE) = val(CODREC))
       When Default
        If JOKER
         OK = (evalue("pat([F:AAA_]"+[F:ATZ]CODZONE+",'"+CODREC+"')"))
        Else
         OK = (evalue("[F:AAA_]"+[F:ATZ]CODZONE) = CODREC)
        Endif
      Endcase
     Elsif DIME>1
      For I=0 To DIME-1
       Case evalue("type([F:AAA_]"+[F:ATZ]CODZONE+")")
        When 1,2,4,5,6,7 : OK = (evalue("[F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+")") = val(CODREC))
        When Default
        If JOKER
         OK = (evalue("pat([F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+"),'"+CODREC+"')"))
        Else
         OK = (evalue("[F:AAA_]"+[F:ATZ]CODZONE+"("+num$(I)+")") = CODREC)
        Endif
       Endcase
       If OK : Break : Endif
      Next I
     Endif
     If OK
      Gosub TRACE
     Endif
    Next AAA_
    Close Local File [AAA_]
   Endif
  Endif
 Next ATZ
Next ATB
Return

$ERRFIC
ER = errn
Resume

$TRACE
If !ENT
 Call ECR_TRACE(mess(43,100,1)-INTREC-":"-TEXREC+"\"+string$(80,"="),0) From GESECRAN
 ENT = 1
Endif
If TABLE<>TABCUR
 If TABCUR<>""
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 OK = 0
 For [AOB]NOMFIC Where NOMFIC=TABLE & TYPGES<>4
  For [ATY] Where OBJLIEN=[F:AOB]ABREV
   OK = 1 : Break 2
  Next ATY
 Next AOB
 If !OK
  For [AOB]NOMFIC Where NOMFIC=TABLE & TYPGES<>4
   OK = 1 : Break
  Next AOB
 Endif
 If OK
  Call TEXTE([F:AOB]LIBEL,TEXTE) From OBJDIV
  Call ECR_TRACE(mess(33,115,1)-[F:AOB]ABREV-TEXTE,0) From GESECRAN : # Objet
 Else
  Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
  Call ECR_TRACE(mess(56,123,1)-TABLE-TEXTE,0) From GESECRAN : # Table
 Endif
 TABCUR = TABLE
 Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
 Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
 CHAINE = [F:ATI]DESCRIPT
 Raz CLE, NBCLE
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLE += 1
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
 If [F:ATI]DESCRIPT=CLE(1)
  Read [ATZ2]CODZONE = [F:ATB]CODFIC ; CLE(1)
  Call TEXTE([F:ATZ2]NOLONG,NOMCLE) From OBJDIV
 Else
  NOMCLE = mess(55,123,1)-"(" : # Clé
  For I=1 To NBCLE
   If I>1 : NOMCLE += "+" : Endif
   Read [ATZ2]CODZONE = [F:ATB]CODFIC ; CLE(I)
   Call TEXTE([F:ATZ2]NOLONG,CHAINE) From OBJDIV
   NOMCLE += CHAINE
  Next I
  NOMCLE += ")"
 Endif
Endif
CODCLE = ""
For I=1 To NBCLE
 If CODCLE<>"" : CODCLE += "+" : Endif
 CODCLE += num$(evalue("[F:AAA_]"+CLE(I)))
Next I
Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
Call ECR_TRACE(NOMCLE-":"-CODCLE-","-mess(17,115,1)-[F:ATZ]CODZONE-"("+TEXTE+")",0) From GESECRAN : # Zone
TROUVE += 1
Return

$CHERCHE_SRC
Local File ADICTRT [ADC] , ASUBPROG [ASU]
ORDSYS = 'lsadx -a'-nomap-'TRT src'
Call SYSTEME2(adxmac(0),ORDSYS,"",NBSRC,TRTSRC) From ORDSYS
NBSRC = min(NBSRC,dim([L]TRTSRC))
If !GSERVEUR
 Call SET_BOITE(mess(43,115,1),NBSRC) From GESECRAN : # Traitements (src)
Endif
For I=1 To NBSRC
 CODCLE = TRTSRC(I)
 If !GSERVEUR
  Call AFF_BOITE("",I,INTE) From GESECRAN
 Endif
 If left$(CODCLE,1)<>"W"
  FICSRC = filpath("TRT",CODCLE,"src")
  If filinfo(FICSRC,0)>0
   Onerrgo ERSEQ
   Openi FICSRC Using [SRC_]
   Iomode adxifs "" Using [SRC_]
   Iomode adxirs chr$(10) Using [SRC_]
   Iomode adxium GUTF8 Using [SRC_]
   Rdseq LIGNE Using [SRC_] : # Entête
   If left$(LIGNE,6)="#<AdxT" & mid$(LIGNE,7,1)<="K" : # 130
    Iomode adxium GASCII Using [SRC_]
   Endif
   L = 0
   Rdseq LIGNE Using [SRC_]
   While !fstat
    L += 1
    K = 0
    Case TYPREC
     When "ADC"
      For J = instr(1,LIGNE,"From") , instr(1,LIGNE,"func")
       If J
        K = left$(vireblc(right$(LIGNE,J+5),2),len(CODREC))=CODREC
        K += (JOKER * pat(right$(LIGNE,J+5),CODREC))
       Endif
       If K : Break : Endif  
      Next J  
     When "ASU"
      J = instr(1,LIGNE,"Call")
      If J
       K = left$(vireblc(right$(LIGNE,J+5),2),len(CODREC))=CODREC
       K += (JOKER * pat(right$(LIGNE,J+5),CODREC))
      Endif
      If !K
       J = instr(1,LIGNE,"func")
       If J 
        J = instr(J,LIGNE,".")
        If J
         K = left$(vireblc(right$(LIGNE,J+1),2),len(CODREC))=CODREC
         K += (JOKER * pat(right$(LIGNE,J+1),CODREC))
        Endif
       Endif
      Endif 
     When "TEX","TRT"
      K = pat(LIGNE,CODREC)
    Endcase
    If K : Gosub TRACE_SRC : Endif
    Rdseq LIGNE Using [SRC_]
   Wend
   Openi Using [SRC_]
   Onerrgo
  Endif
 Endif
Next I
Close Local File [ADC] , [ASU]
Return

$ERSEQ
# Erreur de lecture
Call ECR_TRACE(mess(49,125,1)-CODCLE+".src("+num$(L)+")",1) From GESECRAN
Resume

$TRACE_SRC
If !ENT
 Call ECR_TRACE(mess(43,100,1)-INTREC-":"-TEXREC+"\"+string$(80,"="),0) From GESECRAN
 ENT = 1
Endif
If !TROUVE
 Call ECR_TRACE("\"+mess(43,115,1),0) From GESECRAN : # Traitements (src)
 Call ECR_TRACE(string$(40,"-"),0) From GESECRAN
Endif
TEXTE = mess(19,123,1)-":"-CODCLE+"("+num$(L)+")" : # Traitement
Read [ADC]ADC0 = CODCLE
If !fstat : TEXTE -= [F:ADC]DES-"("+mess([F:ADC]MODULE,14,1)+")" : Endif
Call ECR_TRACE(TEXTE,0) From GESECRAN
Call ECR_TRACE("---"-LIGNE,-1) From GESECRAN
TROUVE += 1
Return

Subprog AV_TEX(VALEUR)
Variable Char    VALEUR()
Case [M]TYP
 When "TRT","TEX"
  VALEUR = mess(2,89,1) : # Expression
 When Default
  Read [ATY]CODTYP = [M]TYP
  Call TEXTE([F:ATY]INTITTYP,VALEUR) From OBJDIV
Endcase
Chgtzn [M:DIA]COD With VALEUR
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
Local Char TABLE(GLONATB) , OBJET(GLONAOB)
Call CONTTYP(VALEUR,TABLE,OBJET)
If mkstat : End Endif
[M]TAB = TABLE
[M]OBJ = OBJET
If OBJET=""
 [M]FMT = "K:30X>70X"
Else
 Case [F:ATY]TYPTYP
  When 7       : [M]FMT = "K:20c"
  When 8       : [M]FMT = GFMD
  When Default : [M]FMT = "K:20#"
 Endcase
Endif
End

Subprog CONTTYP(TYP,TABLE,OBJET)
Value Char TYP
Variable Char TABLE , OBJET
Local Integer OK
If TYP="" : End : Endif
OK = 1
Read [ATY]CODTYP = TYP
If fstat : OK = 0 : Endif
Case TYP
 When "ADC"       : OBJET = TYP : TABLE = "ADICTRT"
 When "ASU"       : OBJET = TYP : TABLE = "ASUBPROG"
 When "TEX","TRT" : OBJET = ""  : TABLE = "" : End
 When Default
  If !OK
   mkstat = 2 : End
  Else
   If [ATY]OBJLIEN<>""
    OBJET = [F:ATY]OBJLIEN
    Read [AOB]ABREV = [F:ATY]OBJLIEN
    TABLE = [F:AOB]NOMFIC
   Else
    TABLE = ""
   Endif
  Endif
Endcase
OK = 1
If find([F:ATY]TYPTYP,9,10)
 OK = 0
Elsif OBJET<>""
 Read [AOB]ABREV  = OBJET
 If fstat : OK = 0 : Endif
Endif
If !OK
 Call ERREUR(TYP-":"-mess(30,139,1)) From GESECRAN : # Type de donnée non géré
 mkstat = 2 : End
Endif
If TABLE<>""
 Read [ATB]CODFIC = TABLE
 If fstat
  Call ERREUR(TABLE-":"-mess(124,124,1)) From GESECRAN : # Table inexistante
  mkstat = 2 : End
 Elsif filinfo(filpath("FIL",TABLE,"fde"),0)<=0
  Call ERREUR(TABLE-":"-mess(17,123,1)) From GESECRAN : # Table non définie
  mkstat = 2 : End
 Endif
Endif
End

Subprog IB_COD
If [M]OBJ=""
 GBOUTS = ""
Endif
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(30)(1..4)
PARAM(1) = [M]OBJ
Call S_TAB_CHAR(VALEUR,PARAM,"SELCOD","RECHADC","") From GACTION
End

$SEL_TABLE
OBJET = PARAM(1)
Return
