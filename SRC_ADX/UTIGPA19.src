#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTIGPA19   Mise à jour champs dans PARMTO                              #
# ---------------------------------------------------------------------- #
##########################################################################

#################################
Call MAJ_UTIGPA19
End

#################################
Subprog MAJ_UTIGPA19
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call OUVRE_TRACE("UTIGPA19: Update fields of PARMTO table") From LECFIC
Call TEMPON("O") From GESECRAN
If DOSSIER<>"" Call EXE_UTIGPA19(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


#################################
Subprog EXE_UTIGPA19(DOSSIER)
Value Char DOSSIER
Local Integer IUTI
Call ECR_TRACE("UTIGPA19: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:PTO])=0  Local File =DOSSIER+".PARMTO"  [PTO] : Endif

Call DEBTRANS From GLOCK
Trbegin [PTO]
For [PTO] 
    Readlock [PTO] Curr
    If [F:PTO]DEMMOD = 0    : [F:PTO]DEMMOD = 1 : Endif
    For IUTI = 0 To 4
        If [F:PTO]PJTFLT(IUTI) = 0 : [F:PTO]PJTFLT(IUTI) = 1 : Endif
    Next I
    Rewrite [PTO]
    If fstat
        Call ECR_TRACE("File PARMTO"-[F:PTO]PTOCOD+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
Next

Commit

Call ECR_TRACE("UTIGPA19 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTIGPA19(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If filinfo(filpath("FIL","PARMTO","fde",APPLI),0) < 0 : End : Endif
Call EXE_UTIGPA19(APPLI)       
End



