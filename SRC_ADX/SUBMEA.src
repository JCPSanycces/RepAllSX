#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet MEA
Raz [V]GPILOBJ, [V]GBIDC1, [V]GBIDC2, [V]GPILNAV, [V]GNBMASKOUV
Call OBJET("MEA",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
#-------------------------------------------------------------------------------
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "LIENS"       : Gosub LIENS
#-------------------------------------------------------------------------------
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "EXEBOUT"     : If [L]BOUT="B" : Call CHGTZON([L]FEH,[L]LIBFLG) From GENFEH : Endif
 When "ABANDON"     : Gosub DEGRISE_CLE From =[L]WINPROG
#-------------------------------------------------------------------------------
 When "INICRE"      : Gosub INICRE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "INIMOD"      : Gosub INIMOD
 When "APRES_MOD"   : Gosub APRES_MOD
 When "FILTRE"      : Gosub FILTRE
Endcase
Return

################################################################################
#
# GOBJET1 simple
#
################################################################################
$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Else
 FILTSUP = "1=1"
Endif
Return

$OUVRE
Local Libelle LIBFLG
Local Char    FEH([V]GLONADI), NUMAEM([V]GLONMEA), AEMNUM([V]GLONMEA), COULEUR([V]GLONASY)
If !clalev([F:ID3])  : Local File EMPLOID   [ID3]  : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom

[L]COULEUR="AERROR"
[L]FEH    ="AEM"
Gosub GENVAR From GENFEH
Return

################################################################################
#
# Affichage
#
################################################################################

$RAZCRE
Call SETSTYLE([L]FEH,[L]COULEUR) From GENFEH
[M:MEA1]ASSCOP=1 : # Incorrect
[M:MEA1]EMPCOP=1 : # incorrect
Actzo [MEA0] FCY
Return

#-------------------------------------------------------------------------------
$RAZDUP
If !find(func AFNC.PARAM("AGTAEM",[M:MEA0]FCY),"","ZZZ")
 Gosub GRISE_CLE From =[L]WINPROG
Endif
Return

#-------------------------------------------------------------------------------
$LIENS
nolign=0
For [VEP]VEP0 Where REFNUM=[M:MEA1]REFNUM & AEMNUM=[M:MEA0]AEMNUM
 nolign+=1
 [M:MEA1]=[F:VEP]
Next
[M:MEA1]NBLIG=nolign
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([M:MEA1]REFNUM,"[M:MEA1]","NAM","SRN2",0,0) From DIVPAYE
Gosub LIENS From =[L]FEHTRT
Call SETSTYLE([L]FEH,[L]COULEUR) From GENFEH
Diszo [MEA0] FCY
Return

################################################################################
#
# Evènements
#
################################################################################

$SETBOUT
[L]CHAINE=ctrans([L]CHAINE,"H","")
If [M:MEA1]ASSCOP>2 : [L]CHAINE=ctrans([L]CHAINE,"AM","") : Endif
Return

#-------------------------------------------------------------------------------
$APRES_MODIF
Case [L]COUZON
When "FCY"
 Gosub RAZDUP
When Default
 Call CONTZON([L]FEH,[L]COULEUR,[L]COUZON,[L]CZ,[L]OK) From GENFEH
Endcase
Return

################################################################################
#
# Transactions
#
################################################################################

$INICRE
If [M:MEA0]AEMNUM=""
 Read [FCY]FCY0=[M:MEA0]FCY
 Read [FCYA]FCY0=[F:FCY]AEMFCY
 Gosub D_AEMNUM From =[L]FEHTRT
 Gosub C_AEMNUM From =[L]FEHTRT
 If [V]GERR : [L]OK=0 : Return : Endif
 [F:MEA]AEMNUM=[L]AEMNUM
Endif
Goto INIMOD

#-------------------------------------------------------------------------------
$INIMOD
Call SETSTA([L]FEH,[F:MEA]ASSCOP)
If !([F:MEA]EMPCOP=3 & [F:MEA]ASSCOP=2) : [F:MEA]EMPCOP=[F:MEA]ASSCOP : Endif
Return

#-------------------------------------------------------------------------------
$APRES_CRE
[M:MEA0]AEMNUM=[F:MEA]AEMNUM
If ![V]GIMPORT : Affzo [MEA0] AEMNUM : Endif
Gosub DEGRISE_CLE From =[L]WINPROG
Goto APRES_MOD

#-------------------------------------------------------------------------------
$APRES_MOD
[M:MEA1]ASSCOP=[F:MEA]ASSCOP
[M:MEA1]EMPCOP=[F:MEA]EMPCOP
Affzo [MEA1] ASSCOP, EMPCOP
Return

################################################################################
#
# Routines
#
################################################################################

Subprog SETSTA(FEH,STA)
Value    Char    FEH()
Variable Libelle STA

Local Libelle NBERR

Gosub GENVAR From GENFEH
Gosub DEFVAR From GENFEH

Gosub DEFVAR From =[L]FEHTRT
Gosub LECMASQ From =[L]FEHTRT

Onerrgo ERREURSTA
Gosub CONTROLE From =[L]FEHTRT
Onerrgo

If [L]NBERR
 If [L]STA=2 : [L]STA=1 : Endif # Saisi -> Incorrect
Elsif [L]STA=1
 [L]STA=2 : # Incorrect -> Saisi
Endif

End

#-------------------------------------------------------------------------------
$ERREURSTA
Call ERREUR(errp-num$(errl)-errmes$(errn)-errm) From GESECRAN
[L]NBERR+=1
Resume

#-------------------------------------------------------------------------------
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    CRITERE(255), PARAM(255)
Local Integer I
Local Date    DAT
Local Libelle COP

If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
If !clalev([F:MEA]) : Local File MEAEMP   [MEA] : Endif

Call GETPARAM("cpydeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM>" " : [L]CRITERE-='& [FGR]CPY>="'+[L]PARAM+'"' : Endif
Call GETPARAM("cpyfin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM<"z": [L]CRITERE-='& [FGR]CPY<="'+[L]PARAM+'"' : Endif
Call GETPARAM("fcydeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM>" " : [L]CRITERE-='& FCY>="'+[L]PARAM+'"' : Endif
Call GETPARAM("fcyfin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM<"z" : [L]CRITERE-='& FCY<="'+[L]PARAM+'"' : Endif
Call GETPARAM("matdeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM>" " : [L]CRITERE-='& REFNUM>="'+[L]PARAM+'"' : Endif
Call GETPARAM("matfin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM<"z" : [L]CRITERE-='& REFNUM<="'+[L]PARAM+'"' : Endif
Call GETPARAM("meadeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM>" " : [L]CRITERE-='& AEMNUM>="'+[L]PARAM+'"' : Endif
Call GETPARAM("meafin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
If [L]PARAM<"z" : [L]CRITERE-='& AEMNUM<="'+[L]PARAM+'"' : Endif
Call GETPARAM("datdeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
[L]DAT=[L]PARAM
If [L]DAT>[0/0/0]
 [L]CRITERE-='& (YEA>'+format$("D:YYYY",[L]DAT)-'| (YEA='+format$("D:YYYY",[L]DAT)
&          - '& MTH>="'+format$("D:MM",[L]DAT)+'"))'
Endif
Call GETPARAM("datfin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
[L]DAT=[L]PARAM
If [L]DAT>[0/0/0]
 [L]CRITERE-='& (YEA<'+format$("D:YYYY",[L]DAT)-'| (YEA='+format$("D:YYYY",[L]DAT)
&          - '& MTH<="'+format$("D:MM",[L]DAT)+'"))'
Endif
If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

Call GETPARAM("cop",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
[L]COP=val([L]PARAM)

Link [MEA] With [FGR]FGR1(1)=FCY
&            As [LNK]
&         Where evalue([L]CRITERE)

$TR_ETAT
Call DEBTRANS From GLOCK
[V]GOK=1
Trbegin [MEA]
 Gosub ETAT
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : End : Else Goto TR_ETAT : Endif
 Elsif ![V]GOK
  Rollback
  End
 Endif
Commit

End

#-------------------------------------------------------------------------------
$ETAT
# ne faudrait-il pas appeler EMISSION From =[L]FEHTRT ?
Columns [MEA] (AEMNUM, ASSCOP, EMPCOP)
For [LNK]MEA0(1)
 I=0
 Case [L]COP
 When 1
  If [F:MEA]ASSCOP=2 & left$([F:MEA]AEMNUM,1)<>"E" : [F:MEA]ASSCOP=3 : I=1 : Endif
 When 2
  If [F:MEA]EMPCOP=2 : [F:MEA]EMPCOP=3 : I=1 : Endif
 Endcase
 If I
  Rewrite [MEA] Curr
  If fstat
   [V]GOK=0
   Call FSTA("MEA") From GLOCK
   Break
  Endif
 Endif
Next
Columns [MEA]
Return

################################################################################
#
# Etiquettes du masque MEA0
#
################################################################################

########################################
Subprog C_AEMNUM(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR="" | left$([L]VALEUR,4)="BZZZ" : End : Endif

Look [MEA]MEA0=[L]VALEUR
If fstat : Raz [L]VALEUR : Endif

End

########################################
Subprog AP_AEMNUM(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR="" & ![V]GIMPORT : mkstat=4 : Endif

End

################################################################################
#
# Etiquettes du masque MEA3
#
################################################################################

########################################
Subprog AS_GROCOT(VALEUR)
Variable Decimal VALEUR

[L]VALEUR=arr([M:MEA3]GRORAT*[M:MEA3]GRODED*0.01,1)

End

########################################
Subprog AS_PAYCOT(VALEUR)
Variable Decimal VALEUR

[L]VALEUR=arr([M:MEA3]PAYRAT*[M:MEA3]PAY*0.01,1)

End

########################################
Subprog AS_TOT(VALEUR)
Variable Decimal VALEUR

[L]VALEUR=[M:MEA3]GROCOT+[M:MEA3]PAYCOT

End

######################################################################################
