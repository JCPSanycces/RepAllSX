#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("TLA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT" : Gosub SETBOUT
 When "MODIF"   : Gosub MODIF
 When "ANNULE"  : Gosub ANNULE
 When "CHANGE"  : Gosub CHANGE
Endcase
Return

$SETBOUT
#----------------------------------------#
# suppression du bouton #code            #
# on ne doit pas pouvoir modifier la clé #
# cg le 25/08/99  bug numero             #
#----------------------------------------#
Call VIREBOUT (CHAINE,"H") From GOBJET
Return

$MODIF
Delete [AXX] Where CODFIC="TABLAN" & LANGUE=GLANGUE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX","*") From GLOCK : Return
Endif
For nolign=1 To [M]BASTAB
 Call MAJTEXTRA([M]INTDES(nolign-1),"TABLAN","INTDES",[M]LAN(nolign-1),"") From ATEXTRA
 If GOK<1 : Break : Endif
 Call MAJTEXTRA([M]INTSHO(nolign-1),"TABLAN","INTSHO",[M]LAN(nolign-1),"") From ATEXTRA
 If GOK<1 : Break : Endif
Next nolign
Return

$ANNULE
Delete [AXX] Where CODFIC="TABLAN" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="TABLAN" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABLAN"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

Subprog STDREPLI(LANGUE,STD,REPLI)
Value Char       LANGUE
Variable Integer STD
Variable Char    REPLI
If !clalev([F:TLA]) : Local File TABLAN [TLA] : Endif
STD =0
REPLI = ""
Read [TLA]TLA0 = LANGUE
If !fstat
 STD   = [F:TLA]LANSTD
 If dim([F:TLA]LANRPL)>0
  REPLI = [F:TLA]LANRPL
 Endif
Endif
End

###################################################################################
################ ACTIONS CHAMPS ###################################################
###################################################################################

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
If   VALEUR <> ""
 Look [TLA]TLA0 = VALEUR
 If   !fstat : mkstat = 2 : Endif
Endif
End

Subprog C_LAN(VALEUR)
Variable Char     VALEUR
If VALEUR="ALL"
  GMESSAGE=mess(129,133,1) : # Code réservé
  mkstat=2
Endif
Call UNICITE(VALEUR,[M]LAN) From OBJDIV
End

Subprog AS_LANCNV(VALEUR)
Variable Integer VALEUR
End

Subprog B1_LAN(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_LANSHO(VALEUR)
Variable Char     VALEUR
End

Subprog D_LANCON(VALEUR)
Variable Integer VALEUR
If [M]LANSTD(nolign-1)=2
  VALEUR=2
Endif
End

Subprog C_LANISO(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If pat(VALEUR,"!!-!!")=0
  GMESSAGE = mess(149,100,1)-" : xx-XX"
  mkstat = 2 : End
 Endif
 Local Char VARMIN(2)
 Local Char VARMAJ(2)
 Local Integer I
 I = instr(1,VALEUR,"-")
 If I >0
  VARMIN = left$(VALEUR,I-1)
  VARMAJ = right$(VALEUR,I+1)
  If VARMIN<>tolower(VARMIN) or(VARMAJ<> toupper(VARMAJ) )
   GMESSAGE = mess(149,100,1)
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = mess(149,100,1)
  mkstat = 2 : End
 Endif
Endif
End


Subprog C_LANRPL(VALEUR)
Variable Char    VALEUR()
## Vérificatiopn quela langue de repli est bien une langue standard
Local Integer I
I = find(VALEUR,LAN(0..[M]BASTAB-1))
If I & [M]LANSTD(I-1) <> 2
 GMESSAGE = VALEUR-":"-mess(235,100,1)
 mkstat =2 : End
Endif
End

Subprog S_LANRPL(VALEUR)
Variable Char    VALEUR()
Local Integer NBLAN,I
Local Integer RETOUR
Local Char    LAN(GLONAVA)(0..30) , LIBLAN(50)(0..30)
NBLAN = 0
For I=0 To [M]BASTAB-1
 If [M]LANSTD(I) = 2
  NBLAN += 1
  LAN(NBLAN)    = [M]LAN(I)
  Call LECTEXTRA(LIBLAN(NBLAN),"TABLAN","INTDES",[M]LAN(I),"") From ATEXTRA
 Endif
Next I
If NBLAN
 Call SAITEX(NBLAN,LIBLAN,RETOUR,mess(18,100,1)) From GESECRAN : # Sélection
 If RETOUR
  VALEUR = LAN(RETOUR) : mkstat = 2
 Endif
Endif
End

Subprog AS_LANRPL(VALEUR)
Variable Char    VALEUR()
If [M]LANSTD(nolign-1) = 2
 mkstat = 1
Endif
End

Subprog AM_LANSTD(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 & dim([M]LANRPL)>0
 [M]LANRPL(nolign-1) = ""
 Affzo [M]LANRPL
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran TLA1) 11/01/2016 14:26:01 (CCL)
######################################################################################
Subprog AS_LANMAIN(VALEUR)
Variable Char    VALEUR()
If [M]LANSTD(nolign-1)=2
  mkstat = 1
Endif
End

Subprog C_LANMAIN(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TLA]) : Local File TABLAN [TLA] : Endif
Read [TLA]TLA0 = VALEUR
If !fstat & [TLA]LANSTD<>2
 GMESSAGE = mess(144,127,1) : # La langue $1$ n'est pas une langue standard.
 mkstat =2 : End
Endif
End

Subprog S_LANMAIN(VALEUR)
Variable Char    VALEUR()
Call S_LANRPL(VALEUR)
End


