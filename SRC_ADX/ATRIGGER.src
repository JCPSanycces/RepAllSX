#<AdxTL>@(#)4.0.0.0 $Revision$
$TEST2

Call OUVRE_TRACE("") From LECFIC
Trbegin ADOVAL
 Call TRIGGER(nomap,"AUTILIS","U") From ATRIGGER
 #Call TRIGGER(nomap,"ZZCCL","U") From ATRIGGER
 #Call TRIGGER(nomap,"AMSK","D") From ATRIGGER
Commit
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##############################################################################
$TEST
Local Char    FLDNAM(GLONAVA)(1..10)
Local Char    FLDVAL(30)(1..10)
Local Integer FLDDIM(1..10)
Local Integer FLDTYP(1..10)
Local Integer FLDOPE(1..10)
Local Integer NBCLE , NBC , WRKFLG , BIFLG
Local Char    CLENAM(GLONAVA)(1..8)
Local Integer CLETYP(1..8)
Local Char    RQT(250)(1..500)
Local Integer NBRQT

If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif
If clalev([F:ATB])=0 : Local File =nomap+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =nomap+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =nomap+".ATABIND"  [ATI] : Endif
If clalev([F:ATY])=0 : Local File =nomap+".ATYPE"    [ATY] : Endif
If clalev([F:ACV])=0 : Local File =nomap+".ACTIV"    [ACV] : Endif

NBC = 0
NBC+=1 : FLDNAM(NBC)="CHAMP1" : FLDTYP(NBC)=7 : FLDOPE(NBC)=8 : FLDDIM(NBC)=1 : FLDVAL(NBC)="*A?"
NBC+=1 : FLDNAM(NBC)="CHAMP2" : FLDTYP(NBC)=8 : FLDOPE(NBC)=3 : FLDDIM(NBC)=1 : FLDVAL(NBC)="20050101"
NBC+=1 : FLDNAM(NBC)="CHAMP3" : FLDTYP(NBC)=1 : FLDOPE(NBC)=4 : FLDDIM(NBC)=2 : FLDVAL(NBC)="33"

NBCLE=0
NBCLE += 1 : CLENAM(NBCLE) = "CLE" : CLETYP(NBCLE) = 7
NBCLE += 1 : CLENAM(NBCLE) = "NUM" : CLETYP(NBCLE) = 2
NBCLE += 1 : CLENAM(NBCLE) = "DAT" : CLETYP(NBCLE) = 8

WRKFLG = 1
BIFLG = 1

Call OUVRE_TRACE("") From LECFIC
#Call DEFTRIG(0,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
#&            ,NBCLE,CLENAM,CLETYP,WRKFLG,STDFLG,BIFLG,NBRQT,RQT)

Call DEFTRIG(1,2,nomap,"TABLE","U",NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
&              ,NBCLE,CLENAM,CLETYP,WRKFLG,1,0,NBRQT,RQT)
For I=1 To NBRQT
 Call ECR_TRACE(RQT(I),0) From GESECRAN
Next I

Call LEC_TRACE From LECFIC
Call FERME_TRACE From LECFIC
End

##############################################################################
Subprog TRIGGER(APPLI,TABLE,OPT)
Value Char APPLI
Value Char TABLE
Value Char OPT

Local Shortint MAXFLD
MAXFLD = 300
Local Char     FLDNAM(GLONAVA)(1..MAXFLD)
Local Char     FLDVAL(30)(1..MAXFLD)
Local Integer  FLDDIM(1..MAXFLD)
Local Integer  FLDTYP(1..MAXFLD)
Local Integer  FLDOPE(1..MAXFLD)
Local Integer  NBCLE , NBC , BASE , WRKFLG , BIFLG
Local Char     CLENAM(GLONAVA)(1..16)
Local Integer  CLETYP(1..16)
Local Integer  OKTRIG,OKTRIGBI
Local Char     CHAINE(250)
Local Integer  I1 , I2

If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"  [ATI] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif

Read [ADS]DOSSIER = APPLI
BASE = [F:ADS]TYPDBA
Read [ATB]CODFIC = TABLE
If dim([F:ATB]AUDCRE)<=0
 OKTRIG = 0
Else
 Case OPT
  When "I" :
   OKTRIGBI = (dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI=2)
   OKTRIG    = ([F:ATB]AUDCRE=2)
  When "U" :
   OKTRIGBI = (dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI=2)
   OKTRIG   = ([F:ATB]AUDUPD=2)
  When "D" :
   OKTRIGBI =  (dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI=2)
   OKTRIG   = ([F:ATB]AUDDEL=2)
 Endcase
Endif
NBC = 0
If OKTRIG
 OKTRIG = (filinfo(filpath("FIL","ATABAUD","fde",APPLI),0)>0)
 If OKTRIG
  If clalev([F:ATA])=0 : Local File =APPLI+".ATABAUD"  [ATA] : Endif
  For [ATA]ATA0 Where CODFIC=TABLE
   If NBC>=dim(FLDNAM) : Break : Endif
   NBC += 1
   Read [ATZ]CODZONE = TABLE;[F:ATA]FLD
   FLDNAM(NBC) = [F:ATA]FLD
   FLDVAL(NBC) = [F:ATA]VALEUR
   FLDDIM(NBC) = [F:ATZ]DIME
   If [F:ATZ]CODACT<>""
    Call REPTAB([F:ATZ]CODACT,FLDDIM(NBC)) From DOSSUB
   Endif
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   FLDTYP(NBC) = [F:ATY]TYPTYP
   FLDOPE(NBC) = [F:ATA]OPE
  Next ATA
 Endif
Endif
If dim([F:ATB]AUDCLE)>0 & [F:ATB]AUDCLE<>""
 Read [ATI]CODIND = TABLE;[F:ATB]AUDCLE
Else
 Read [ATI]NUMLIG(2) = TABLE;1
Endif
CHAINE = [F:ATI]DESCRIPT
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I1 = instr(1,CHAINE,"+")
 I2 = instr(1,CHAINE,"-")
 If    I1 & I2  : I1 = min(I1,I2)
 Elsif I2 & !I1 : I1 = I2
 Endif
 If I1
  CLENAM(NBCLE) = left$(CHAINE,I1-1)
  CHAINE        = right$(CHAINE,I1+1)
 Else
  CLENAM(NBCLE) = CHAINE
  CHAINE        = ""
 Endif
 Read [ATZ]CODZONE = TABLE;CLENAM(NBCLE)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 CLETYP(NBCLE) = [F:ATY]TYPTYP
Wend
If dim([F:ATB]AUDWRK)<=0
 WRKFLG = 0
Else
 WRKFLG = [F:ATB]AUDWRK
Endif
## CCL si le trigger ne se crée pas car [F:ATB]AUDBI vaut 0 !! Du coup en dure c’est mieux
#If dim([F:ATB]AUDBI)<=0
# BIFLG = 0
#Else
# BIFLG = [F:ATB]AUDBI
#Endif
Call VALTRIG(OKTRIG,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE,NBCLE,CLENAM,CLETYP,WRKFLG,0,0)
Call VALTRIG(OKTRIGBI,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE,NBCLE,CLENAM,CLETYP,WRKFLG,0,2)
End

#---------------------------#
$RIEN
Resume


$DEF_MAXFIELDS
Local Integer MAXFIELDS : MAXFIELDS=9
If dim(APPLI)>0
 Local File =APPLI+".ATABZON" [ATZ_]
Else
 Local File ATABZON [ATZ_]
Endif
Read [F:ATZ_]CODZONE="AUDITH";"NUM10"
If !fstat
 MAXFIELDS=16
Endif
Return

##############################################################################
Subprog VALTRIG(CAS,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
&              ,NBCLE,CLENAM,CLETYP,WRKFLG,STDFLG,BIFLG)
Value Integer CAS
Value Integer BASE
Value Char    APPLI
Value Char    TABLE
Value Char    OPT
Value Integer NBC
Value Char    FLDNAM()(1..)
Value Char    FLDVAL()(1..)
Value Integer FLDDIM(1..)
Value Integer FLDTYP(1..)
Value Integer FLDOPE(1..)
Value Integer NBCLE
Value Char    CLENAM()(1..)
Value Integer CLETYP(1..)
Value Integer WRKFLG
Value Integer STDFLG
Value Integer BIFLG

Local Integer NBRQT , EFFACE
#114816 Local Char    RQT(250)(1..2000)
Local Char    RQT(250)(1..5000)

Call DEFTRIG(0,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
&            ,NBCLE,CLENAM,CLETYP,WRKFLG,STDFLG,BIFLG,NBRQT,RQT)
EFFACE = 1
Gosub EXEC
If CAS=1
 Call DEFTRIG(1,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
&             ,NBCLE,CLENAM,CLETYP,WRKFLG,STDFLG,BIFLG,NBRQT,RQT)
 If NBRQT=0
  Call ECR_TRACE(mess(89,127,1),1) From GESECRAN : # Erreur en création des triggers : trop de champs
  End
 Endif
 EFFACE = 0
 Gosub EXEC
Endif
End

$EXEC
If GTRACE<>"" & GUSER="CCL "
 For I=1 To NBRQT
   Call ECR_TRACE(RQT(I),0) From GESECRAN
 Next I
Endif
Onerrgo ERREUR

Case BASE
 When 1 : Execsql From "3" Sql RQT(1..NBRQT)
 When 2 : Execsql From "5" Sql RQT(1..NBRQT)
Endcase

Onerrgo
Return

$ERREUR
If !EFFACE
 Call ECR_TRACE(TABLE-":"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,1) From GESECRAN : # Erreur
Endif
Resume

##############################################################################
Subprog DEFTRIG(CAS,BASE,APPLI,TABLE,OPT,NBC,FLDNAM,FLDVAL,FLDDIM,FLDTYP,FLDOPE
&              ,NBCLE,CLENAM,CLETYP,WRKFLG,STDFLG,BIFLG,NBRQT,RQT)
Value    Integer CAS
Value    Integer BASE
Value    Char    APPLI
Value    Char    TABLE
Value    Char    OPT
Value    Integer NBC
Value    Char    FLDNAM()(1..)
Value    Char    FLDVAL()(1..)
Value    Integer FLDDIM(1..)
Value    Integer FLDTYP(1..)
Value    Integer FLDOPE(1..)
Value    Integer NBCLE
Value    Char    CLENAM()(1..)
Value    Integer CLETYP(1..)
Value    Integer WRKFLG
Value    Integer STDFLG
Value    Integer BIFLG
Variable Integer NBRQT
Variable Char    RQT()(1..)

Local Integer I , J , K , I1 , I2 , J1 , J2 , ER
Local Integer II , JJ , KK , IC
Local Integer NLIG , NTRI , NREMP , OKLIG , NCRI , NCOL
Local Integer PSPE
Local Char    TEXTE(250)(1..300)
Local Char    CRLF(2)
Local Char    LIGNE(250) , CHAMP(250) , CHAINE(250)
Local Char    REMPLACE(250)(1..300)
Local Char    CRITERE(250)(1..10)
Local Char    CND(30) , ACTION(20)

CRLF = " "+chr$(10)
Call EXISTE_ADX("","","SPETRIGGER",PSPE) From ORDSYS

ER = 0

NCOL = sum(FLDDIM(1..NBC))
NCRI = 0
Raz RQT
NBRQT = 0
If OPT="U"
 For I1=1 To NBC
  For I2=1 To FLDDIM(I1)
   If FLDOPE(I1)>1
    LIGNE = ""
    Call NOMCHAMP(BASE,2,FLDNAM(I1),I2,0,CHAINE)
    LIGNE += CHAINE
    Call OPER(BASE,FLDOPE(I1)-1,CHAINE)
    LIGNE += CHAINE
    Call CONSTANTE(BASE,FLDTYP(I1),FLDVAL(I1),CHAINE)
    If FLDOPE(I1)=8
     Call LIKE(BASE,CHAINE)
    Endif
    LIGNE += CHAINE
    If CRITERE(1)<>""
     Call OPER(BASE,11,CHAINE)
    Else
     CHAINE = ""
    Endif
    If NCRI=0 : NCRI = 1 : Endif
    If len(CRITERE(NCRI))+len(LIGNE)+len(CHAINE)<=250
     CRITERE(NCRI) += CHAINE+LIGNE
    Else
     NCRI += 1
     CRITERE(NCRI) = CHAINE+LIGNE
    Endif
   Endif
  Next I2
 Next I1
Endif

If CAS=1
 Call CRETRI(APPLI,BASE,OPT,STDFLG,BIFLG,NLIG,TEXTE)
Else
 Call SUPTRI(BASE,NLIG,TEXTE)
Endif

K = 1
I = 1

While I<=NLIG
 LIGNE = TEXTE(I)
 If LIGNE="&&<NBCOL>&&"
  J = I : Repeat : J += 1 : Until J>NLIG or TEXTE(J)="&&"
  IC = 0
  For II=1 To NBC
   For JJ=1 To FLDDIM(II)
    IC += 1
    For KK=I+1 To J-1
     LIGNE = TEXTE(KK)
     Gosub TRT_LIGNE : If ER : Break 4 : Endif
    Next KK
   Next JJ
  Next II
  I = J+1
 Else
  II = 1 : JJ = 1 : KK = 1
  Gosub TRT_LIGNE : If ER : Break : Endif
  I += 1
 Endif
Wend
If ER
 NBRQT = 0
Else
 NBRQT = K-1
Endif
End

$TRT_LIGNE
OKLIG = 1
If left$(LIGNE,2)="!!"
 I1 = instr(3,LIGNE,"!!")
 If I1
  CND   = seg$(LIGNE,3,I1-1)
  LIGNE = right$(LIGNE,I1+2)
  Gosub CONDITION
 Endif
Endif
If OKLIG
 While LIGNE<>""
  I1 = instr(1,LIGNE,"#<")
  I2 = instr(1,LIGNE,">#")
  If I1 & I2 & I2>I1
   CHAMP = left$(LIGNE,I1-1)
   Gosub STOCKE
   CHAMP = seg$(LIGNE,I1+2,I2-1)
   Gosub REMPLACE
   For J1=1 To NREMP
    CHAMP = REMPLACE(J1)
    Gosub STOCKE
   Next J1
   LIGNE = right$(LIGNE,I2+2)
  Else
   CHAMP = LIGNE
   Gosub STOCKE : If ER : Break : Endif
   LIGNE = ""
  Endif
 Wend
 CHAMP = CRLF
 Gosub STOCKE
 If ER
  Return
 Elsif K>=dim(RQT)
  ER = 1
 Else
  K += 1
 Endif
Endif
Return

$STOCKE
If len(RQT(K))+len(CHAMP)<=250
 RQT(K) += CHAMP
Elsif K<dim(RQT)
 K += 1
 RQT(K) = CHAMP
Else
 ER = 1
Endif
Return

$REMPLACE
NREMP = 1
Case toupper(CHAMP)
 When "DOSSIER"
  REMPLACE(1) = APPLI
 When "TABLE"
  REMPLACE(1) = TABLE
 When "NOMTRIG"
  Case OPT
   When "I" : REMPLACE(1) = "INS"
   When "U" : REMPLACE(1) = "UPD"
   When "D" : REMPLACE(1) = "DEL"
  Endcase
  If BIFLG>0 : REMPLACE(1)+= "_BI" : Endif
 When "ACTION"
  Case OPT
   When "I" : REMPLACE(1) = "INSERT"
   When "U" : REMPLACE(1) = "UPDATE"
   When "D" : REMPLACE(1) = "DELETE"
  Endcase
 When "NBCOL"
  REMPLACE(1) = num$(NCOL)
 When "LISCOL"
  REMPLACE(1) = ""
  For J1=1 To NBC
   For J2=1 To FLDDIM(J1)
    If len(REMPLACE(NREMP))+len(FLDNAM(J1))+4>250
     NREMP += 1
    Endif
    If J1>1 or J2>1 : REMPLACE(NREMP) += "," : Endif
    REMPLACE(NREMP) += FLDNAM(J1)+"_"+num$(J2-1)
   Next J2
  Next J1
 When "CONDITION"
  For J1=1 To NCRI
   REMPLACE(J1) = CRITERE(J1)
  Next J1
  NREMP = NCRI
 When "TABLOGIN"
  REMPLACE(1) = "ALOGIN"
 When "TABAUDITH"
  REMPLACE(1) = "AUDITH"
 When "TABAUDITBI"
  REMPLACE(1) = "AUDITBI"
 When "TABAUDITL"
  REMPLACE(1) = "AUDITL"
 When "OLDCLE1","NEWCLE1"
  If toupper(CHAMP)="OLDCLE1"
   J2 = 1
  Else
   J2 = 2
  Endif
  Call NOMCHAMP(BASE,J2,CLENAM(1),1,1,CHAINE)
  Call TOCHAR(BASE,CLETYP(1),CHAINE,CHAINE)
  REMPLACE(1) = CHAINE
 When "OLDCLE2","NEWCLE2"
  If toupper(CHAMP)="OLDCLE2"
   J2 = 1
  Else
   J2 = 2
  Endif
  I1 = 1
  REMPLACE(I1) = ""
  REMPLACE(I1+1) = ""
  If NBCLE>=2
   For J1=2 To NBCLE
    If J1>2
     If len(REMPLACE(I1))>200 : I1 = 2 : NREMP=2 : Endif
     Call OPER(BASE,12,CHAINE)
     REMPLACE(I1) += CHAINE
     Call CONSTANTE(BASE,7,"~",CHAINE)
     REMPLACE(I1) += CHAINE
     Call OPER(BASE,12,CHAINE)
     REMPLACE(I1) += CHAINE
    Endif
    Call NOMCHAMP(BASE,J2,CLENAM(J1),1,1,CHAINE)
    Call TOCHAR(BASE,CLETYP(J1),CHAINE,CHAINE)
    REMPLACE(I1) += CHAINE
   Next J1
  Else
   Call CONSTANTE(BASE,7," ",CHAINE)
   REMPLACE(I1) = CHAINE
  Endif
 When "NEWCHAR1","OLDCHAR1","NEWNUM1","OLDNUM1"
  If toupper(CHAMP)="OLDCHAR1" or toupper(CHAMP)="OLDNUM1"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 1 : Gosub SET_IDENT
 When "NEWCHAR2","OLDCHAR2","NEWNUM2","OLDNUM2"
  If toupper(CHAMP)="OLDCHAR2" or toupper(CHAMP)="OLDNUM2"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 2 : Gosub SET_IDENT
 When "NEWCHAR3","OLDCHAR3","NEWNUM3","OLDNUM3"
  If toupper(CHAMP)="OLDCHAR3" or toupper(CHAMP)="OLDNUM3"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 3 : Gosub SET_IDENT
 When "NEWCHAR4","OLDCHAR4","NEWNUM4","OLDNUM4"
  If toupper(CHAMP)="OLDCHAR4" or toupper(CHAMP)="OLDNUM4"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 4: Gosub SET_IDENT
 When "NEWCHAR5","OLDCHAR5","NEWNUM5","OLDNUM5"
  If toupper(CHAMP)="OLDCHAR5" or toupper(CHAMP)="OLDNUM5"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 5 : Gosub SET_IDENT
 When "NEWCHAR6","OLDCHAR6","NEWNUM6","OLDNUM6"
  If toupper(CHAMP)="OLDCHAR6" or toupper(CHAMP)="OLDNUM6"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 6 : Gosub SET_IDENT
 When "NEWCHAR7","OLDCHAR7","NEWNUM7","OLDNUM7"
  If toupper(CHAMP)="OLDCHAR7" or toupper(CHAMP)="OLDNUM7"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 7 : Gosub SET_IDENT
 When "NEWCHAR8","OLDCHAR8","NEWNUM8","OLDNUM8"
  If toupper(CHAMP)="OLDCHAR8" or toupper(CHAMP)="OLDNUM8"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 8 : Gosub SET_IDENT
 When "NEWCHAR9","OLDCHAR9","NEWNUM9","OLDNUM9"
  If toupper(CHAMP)="OLDCHAR9" or toupper(CHAMP)="OLDNUM9"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 9 : Gosub SET_IDENT
 When "NEWCHAR10","OLDCHAR10","NEWNUM10","OLDNUM10"
  If toupper(CHAMP)="OLDCHAR10" or toupper(CHAMP)="OLDNUM10"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 10 : Gosub SET_IDENT
 When "NEWCHAR11","OLDCHAR11","NEWNUM11","OLDNUM11"
  If toupper(CHAMP)="OLDCHAR11" or toupper(CHAMP)="OLDNUM11"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 11 : Gosub SET_IDENT
 When "NEWCHAR12","OLDCHAR12","NEWNUM12","OLDNUM12"
  If toupper(CHAMP)="OLDCHAR12" or toupper(CHAMP)="OLDNUM12"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 12 : Gosub SET_IDENT
 When "NEWCHAR13","OLDCHAR13","NEWNUM13","OLDNUM13"
  If toupper(CHAMP)="OLDCHAR13" or toupper(CHAMP)="OLDNUM13"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 13 : Gosub SET_IDENT
 When "NEWCHAR14","OLDCHAR14","NEWNUM14","OLDNUM14"
  If toupper(CHAMP)="OLDCHAR14" or toupper(CHAMP)="OLDNUM14"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 14 : Gosub SET_IDENT
 When "NEWCHAR15","OLDCHAR15","NEWNUM15","OLDNUM15"
  If toupper(CHAMP)="OLDCHAR15" or toupper(CHAMP)="OLDNUM15"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 15 : Gosub SET_IDENT
 When "NEWCHAR16","OLDCHAR16","NEWNUM16","OLDNUM16"
  If toupper(CHAMP)="OLDCHAR16" or toupper(CHAMP)="OLDNUM16"
   J2 = 1
  Else
   J2 = 2
  Endif
  J1 = 16 : Gosub SET_IDENT
 When "INDICE"
  REMPLACE(1) = num$(IC)
 When "VIRGULE"
  If IC>1
   REMPLACE(1) = ","
  Else
   REMPLACE(1) = " "
  Endif
 When "ADOCHAMP"
  REMPLACE(1) = FLDNAM(II)
  If FLDDIM(II)>1
   REMPLACE(1) += "("+num$(JJ-1)+")"
  Endif
 When "OLDCHAMP"
  Call NOMCHAMP(BASE,1,FLDNAM(II),JJ,1,CHAINE)
  Call TOCHAR(BASE,FLDTYP(II),CHAINE,CHAINE)
  REMPLACE(1) = CHAINE
 When "NEWCHAMP"
  Call NOMCHAMP(BASE,2,FLDNAM(II),JJ,1,CHAINE)
  Call TOCHAR(BASE,FLDTYP(II),CHAINE,CHAINE)
  REMPLACE(1) = CHAINE
 When "WORKFLOW"
  REMPLACE(1) = num$(WRKFLG)
 When "BI"
  REMPLACE(1) = num$(BIFLG)
 When Default
  REMPLACE(1) = "#<"+CHAMP+">#"
Endcase
If PSPE
 ACTION = "REMPLACE"
 Gosub ACTION From SPETRIGGER
Endif
Return

$CONDITION
Case toupper(CND)
 When "NBCOL>0"
  OKLIG = (OPT="U" & NBC>0)
 When "NBVAL>0"
  OKLIG = (OPT="U" & NCRI>0) & BIFLG=0
Endcase
Return

$SET_IDENT
If J1>NBCLE
 If instr(1,toupper(CHAMP),'NUM')   : REMPLACE(1) = "0"      : Return : Endif
 If instr(1,toupper(CHAMP),'CHAR')  : REMPLACE(1) = "' '"    : Return : Endif
Endif
If CLETYP(J1)>6 & !instr(1,toupper(CHAMP),'CHAR') : REMPLACE(1) = "0" : Return : Endif
If CLETYP(J1)<7 & !instr(1,toupper(CHAMP),'NUM')  : REMPLACE(1) = "' '"   : Return : Endif
Call NOMCHAMP(BASE,J2,CLENAM(J1),1,1,CHAINE)
If CLETYP(J1)>6
 Call TOCHAR(BASE,CLETYP(J1),CHAINE,CHAINE)
Endif
REMPLACE(1) = CHAINE
Return

Subprog CRETRI(APPLI,BASE,OPT,STDFLG,BIFLG,NLIG,TEXTE)
Value    Char    APPLI
Value    Integer BASE
Value    Char    OPT
Value    Integer STDFLG
Value    Integer BIFLG
Variable Integer NLIG
Variable Char    TEXTE()(1..)
Local Integer I , J , K , NTRI
Local Char    TRIG(250)(1..300)
NLIG = 0
Case BASE
 When 1 : Gosub CRETRI_ORA : # Oracle
 When 2 : Gosub CRETRI_SQL : # Sql
Endcase
If !BIFLG
 Call DEFTRI(APPLI,BASE,OPT,STDFLG,BIFLG,NTRI,TRIG) From SUBTRIGGER
Else
 Call DEFTRI(APPLI,BASE,OPT,STDFLG,BIFLG,NTRI,TRIG) From SUBTRIGGERBI
Endif
For I=1 To NTRI
 NLIG += 1 : TEXTE(NLIG) = TRIG(I)
Next I
End

Subprog SUPTRI(BASE,NLIG,TEXTE)
Value    Integer BASE
Variable Integer NLIG
Variable Char    TEXTE()(1..)
NLIG = 0
Case BASE
 When 1 : Gosub SUPTRI_ORA : # Oracle
 When 2 : Gosub SUPTRI_SQL : # Sql
Endcase
End

#################################################################
## Syntaxes pour créer un trigger
#################################################################

$CRETRI_ORA
NLIG += 1 : TEXTE(NLIG) = "Create or Replace Trigger"
NLIG += 1 : TEXTE(NLIG) = " #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
NLIG += 1 : TEXTE(NLIG) = " After #<ACTION>#"
#NLIG += 1 : TEXTE(NLIG) = "!!nbcol>0!! Of #<LISCOL>#"
NLIG += 1 : TEXTE(NLIG) = " On #<DOSSIER>#.#<TABLE>#"
NLIG += 1 : TEXTE(NLIG) = " For Each Row"
NLIG += 1 : TEXTE(NLIG) = "!!nbval>0!! When (#<CONDITION>#)"
Return

$CRETRI_SQL
NLIG += 1 : TEXTE(NLIG) = "Create Trigger "
NLIG += 1 : TEXTE(NLIG) = " #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
NLIG += 1 : TEXTE(NLIG) = " On #<DOSSIER>#.#<TABLE>#"
NLIG += 1 : TEXTE(NLIG) = " After #<ACTION>#"
NLIG += 1 : TEXTE(NLIG) = " As"
Return

#################################################################
## Syntaxes pour supprimer un trigger
#################################################################
$SUPTRI_ORA
NLIG += 1 : TEXTE(NLIG) = "Drop Trigger #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
Return

$SUPTRI_SQL
NLIG += 1 : TEXTE(NLIG) = "Drop Trigger #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
Return

#################################################################
## Syntaxes diverses
#################################################################
Subprog NOMCHAMP(BASE,OLDNEW,CHAMP,INDIC,FLG2,CHAINE)
Value    Integer BASE
Value    Integer OLDNEW
Value    Char    CHAMP
Value    Integer INDIC
Value    Integer FLG2
Variable Char    CHAINE()
Case BASE
 When 1
  If FLG2
   CHAINE = ":"
  Else
   CHAINE = ""
  Endif
  If OLDNEW=1
   CHAINE += "OLD."
  Else
   CHAINE += "NEW."
  Endif
  CHAINE += CHAMP+"_"+num$(INDIC-1)
 When 2
  CHAINE = ""
  If OLDNEW=1
   CHAINE += "Deleted."
  Else
   CHAINE += "Inserted."
  Endif
  CHAINE += CHAMP+"_"+num$(INDIC-1)
Endcase
End

Subprog OPER(BASE,OPER,CHAINE)
Value    Integer BASE
Value    Integer OPER
Variable Char    CHAINE()
Case BASE
 When 1
  Case OPER
   When  1 : CHAINE = "="
   When  2 : CHAINE = "!="
   When  3 : CHAINE = ">"
   When  4 : CHAINE = ">="
   When  5 : CHAINE = "<"
   When  6 : CHAINE = "<="
   When  7 : CHAINE = " like "
   When 11 : CHAINE = " or "
   When 12 : CHAINE = " || "
  Endcase
 When 2
  Case OPER
   When  1 : CHAINE = "="
   When  2 : CHAINE = "!="
   When  3 : CHAINE = ">"
   When  4 : CHAINE = ">="
   When  5 : CHAINE = "<"
   When  6 : CHAINE = "<="
   When  7 : CHAINE = " like "
   When 11 : CHAINE = " or "
   When 12 : CHAINE = " + "
  Endcase
Endcase
End

Subprog CONSTANTE(BASE,TYP,VALEUR,CHAINE)
Value    Integer BASE
Value    Integer TYP
Value    Char    VALEUR
Variable Char    CHAINE()
Case BASE
 When 1
  Case TYP
   When 7
    CHAINE = "'"+VALEUR+"'"
   When 8
    CHAINE = "to_date('"+VALEUR+"','YYYYMMDD')"
   When Default
    CHAINE = VALEUR
  Endcase
 When 2
  Case TYP
   When 7
    CHAINE = "'"+VALEUR+"'"
   When 8
    CHAINE = "CONVERT(DATETIME,'"+VALEUR+"')"
   When Default
    CHAINE = VALEUR
  Endcase
Endcase
End

Subprog TOCHAR(BASE,TYP,VALEUR,CHAINE)
Value    Integer BASE
Value    Integer TYP
Value    Char    VALEUR
Variable Char    CHAINE()
Case BASE
 When 1
  Case TYP
   When 7       : CHAINE = VALEUR
   When 8       : CHAINE = "to_char("+VALEUR+",'DDMMYYYY')"
   When Default : CHAINE = "to_char("+VALEUR+")"
  Endcase
 When 2
  Case TYP
   When 7       : CHAINE = VALEUR
   When 8       : CHAINE = "CONVERT(VARCHAR,"+VALEUR+",103)"
   When Default : CHAINE = "CONVERT(VARCHAR,"+VALEUR+")"
  Endcase
Endcase
End

Subprog LIKE(BASE,CHAINE)
Value    Integer BASE
Variable Char    CHAINE()
Case BASE
 When 1 : CHAINE = ctrans(CHAINE,"*?","%_")
 When 2 : CHAINE = ctrans(CHAINE,"*?","%_")
Endcase
End

