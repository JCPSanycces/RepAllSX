######################################################################################
## Ecrans SIPAR5 et SIPAR7 - Comptabilité
######################################################################################

Subprog D_STRPER(VALEUR)
Variable Date    VALEUR
If !clalev([F:XSOC]) : Local File XISOC [XSOC] : Endif   # Société Intégrale
Read [XSOC]  First
If [F:XSOC]DEBEXCN2<>[0/0/0] & [F:XSOC]ETAEXCN2='O'
 VALEUR  = [F:XSOC]DEBEXCN2
Elsif [F:XSOC]DEBEXCN1<>[0/0/0] & [F:XSOC]ETAEXCN1='O'
 VALEUR  = [F:XSOC]DEBEXCN1
Elsif [F:XSOC]DEBEXCN<>[0/0/0] &  [F:XSOC]ETAEXCN='O'
 VALEUR  = [F:XSOC]DEBEXCN
Endif
End

Subprog C_STRPER(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : End : Endif
Call C_STRPER(VALEUR) From SIXCPY
End

Subprog IB_STRPER
Raz GBOUT1
If !clalev([F:XSOC]) : Local File XISOC [XSOC] : Endif   # Société Intégrale
Read [XSOC]  First
If !fstat & [F:XSOC]FLGREP=2
 GBOUT1 = SI_MES(269)
Endif
End

Subprog B1_STRPER(VALEUR)
Variable Date    VALEUR
Local Integer OK : OK = 0
Call AVERTIR(SI_MES(268),OK) From GESECRAN
If OK=2
 Gosub INI_X3DAT From SIXCPY
Endif
End

Subprog D_ACM(VALEUR)
Variable Char    VALEUR()
If [F:SPX]ACM <>"" 
 VALEUR = [F:SPX]ACM
Else
 If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"     [CPY]   : Endif  # Société
 Read [CPY]CPY0 = [M:SIP0]CPY 
 If !fstat
  VALEUR= [F:CPY]ACM
 Endif
Endif
If VALEUR="" : End : Endif
Local Char COAGEN(GLONCOA)
Call INI_COA(VALEUR,COAGEN) From SIXCPY
[M:SIP5]COA = [L]COAGEN
End

Subprog AV_ACM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
Read [XSOC]  First
If !fstat & [F:XSOC]FLGREP=2
  Grizo [M]ACM 
Else 
  Actzo [M]ACM
Endif
End

Subprog C_ACM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif #65061
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"     [GCM]   : Endif  # Modèle comptable
Call LECTURE("GCM",VALEUR,"") From CONTOBJ
# Référentiel Générale principal <> Référentiel Générale Analytique
# Mono-Référentiel 6.x : Suppression du contrôle
#If [F:GCM]LED([F:GCM]GENLEDTYP-1)= [F:GCM]LED([F:GCM]ANALEDTYP-1)
 # Valeur incorrecte
# GMESSAGE = mess(83,123,1) : mkstat=2 : End
#Endif
# Référentiel dit non automatique => uniquement Générale principal et l'analytique principal
For I=1 To len(mess(0,2644,1))
 If  I<>[F:GCM]GENLEDTYP & I<>[F:GCM]ANALEDTYP & [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2
  # Valeur incorrecte
  GMESSAGE = mess(83,123,1) : mkstat=2 : Break 
 Endif
Next 
If mkstat : End : Endif
Local Char COAGEN(GLONCOA)
Call INI_COA(VALEUR,COAGEN) From SIXCPY
[M:SIP5]COA = [L]COAGEN
End

Subprog AS_NBJOU
If [M:SIP5]NBJOU = 0
 Gosub INI_JOU
Endif
Affzo [M:SIP5]
End

Subprog IB_NBJOU
GBOUT1 = SI_MES(269)
End

Subprog B1_NBJOU
Local Integer OK : OK = 0
Call AVERTIR(SI_MES(267),OK) From GESECRAN
If OK=2
 Raz [M:SIP5]NBJOU
 Raz [M:SIP5]JOU
 Raz [M:SIP5]GTE
 Gosub INI_JOU
 Affzo [M:SIP5]
Endif
End

$INI_JOU
 Local Char WJOU(GLONJOU)
 Call TEMPON("L") From GESECRAN
 If !clalev([F:XGAS]) : Local File =SI_DOSSIER+".XIHISCBGNR" [XGAS] : Endif
 If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIHISANA"   [XGAA] : Endif
 If !clalev([F:XGBS]) : Local File =SI_DOSSIER+".XIBROCBGNR" [XGBS] : Endif
 If !clalev([F:XGBA]) : Local File =SI_DOSSIER+".XIBROCBANA" [XGBA] : Endif
 For [XGAS]IND0(1)
  WJOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGAS]CODJRN,"GJOURNAL","")
  If !find(WJOU,[M:SIP5]JOU(0..dim([M:SIP5]JOU)-1))
   If [M:SIP5]NBJOU>=dim([M:SIP5]JOU) : Break : Endif
   [M:SIP5]NBJOU += 1
   [M:SIP5]JOU([M:SIP5]NBJOU-1) = WJOU
  Endif 
 Next
 For [XGAA]IND0(1)
  WJOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGAA]CODJRN,"GJOURNAL","")
  If !find(WJOU,[M:SIP5]JOU(0..dim([M:SIP5]JOU)-1))
   If [M:SIP5]NBJOU>=dim([M:SIP5]JOU) : Break : Endif
   [M:SIP5]NBJOU += 1
   [M:SIP5]JOU([M:SIP5]NBJOU-1) = WJOU
  Endif 
 Next
 For [XGBS]IND1(1)
  WJOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGBS]CODJRN,"GJOURNAL","")
  If !find(WJOU,[M:SIP5]JOU(0..dim([M:SIP5]JOU)-1))
   If [M:SIP5]NBJOU>=dim([M:SIP5]JOU) : Break : Endif
   [M:SIP5]NBJOU += 1
   [M:SIP5]JOU([M:SIP5]NBJOU-1) = WJOU
  Endif 
 Next
 For [XGBA]IND1(1)
  WJOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGBA]CODJRN,"GJOURNAL","")
  If !find(WJOU,[M:SIP5]JOU(0..dim([M:SIP5]JOU)-1))
   If [M:SIP5]NBJOU>=dim([M:SIP5]JOU) : Break : Endif
   [M:SIP5]NBJOU += 1
   [M:SIP5]JOU([M:SIP5]NBJOU-1) = WJOU 
  Endif 
 Next
 Call TEMPOFF From GESECRAN
Return

Subprog C_GTE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif  
If !clalev([F:JOU])  : Local File =SI_DOSSIER+".GJOURNAL"   [JOU]  : Endif 
If !clalev([F:GTE])  : Local File =SI_DOSSIER+".GTYPACCENT" [GTE]  : Endif 

Call LEC_CPY([M:SIP0]CPY) From CPTLEC
Call LEC_JOU_LEG([F:CPY]LEG,[M:SIP5]JOU(nolign-1)) From CPTLEC
Call LEC_GTE_LEG([F:CPY]LEG,VALEUR) From CPTLEC
If [F:JOU]TYP>0 & [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = [F:JOU]JOU-mess(8,106,1) : # Journal non autorisé sur ce type de pièce
 mkstat = 2 : End
Endif
# Le journal n'est pas encore crée sous X3
If !clalev([F:XJOU])  : Local File =SI_DOSSIER+".XIJRN"     [XJOU]   : Endif  # Journaux Intégrale
Local Integer WTYP
If [XJOU]X3CLE <> [M:SIP5]JOU(nolign-1)
 Filter [XJOU] Where X3CLE=[M:SIP5]JOU(nolign-1)
 Read [XJOU]First
Endif
Case [F:XJOU]TYPJRN
 When "V" : [L]WTYP=1  # Intégrale "Ventes"             => X3 "Ventes"
 When "A" : [L]WTYP=2  # Intégrale "Achats"             => X3 "Achats"
 When "T" : [L]WTYP=3  # Intégrale "Trésorerie"         => X3 "Trésorerie"
 When "O" : [L]WTYP=4  # Intégrale "Opération diverses" => X3 "OD 1"
 When "D" : [L]WTYP=5  # Intégrale "Déductible"         => X3 "OD 2"        
 When "C" : [L]WTYP=6  # Intégrale "Collectée"          => X3 "OD 3"        
 When "L" : [L]WTYP=8  # Intégrale "Analytique"         => X3 "OD Ana 1 "        
 When "E" : [L]WTYP=4  # Intégrale "Extourne"           => X3 "OD 1 "        
Endcase
If [L]WTYP>0 & [F:GTE]AUZJOU([L]WTYP-1)<>2
 GMESSAGE = [F:XJOU]X3CLE-mess(8,106,1) : # Journal non autorisé sur ce type de pièce
 mkstat = 2 : End
Endif
End

Subprog C_OPTANA(VALEUR)
Variable Integer VALEUR
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif  # Modèle comptable
Call LECTURE("GCM",[M:SIP5]ACM,"") From CONTOBJ
If VALEUR = 2
 Raz [M:SIP5]CCEDEF : Grizo CCEDEF
 If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP : Actzo [M:SIP5]DACDIAANA : Else  [M:SIP5]DACDIAANA=[M:SIP5]DACDIAGEN : Grizo [M:SIP5]DACDIAANA : Endif
Else
 Actzo CCEDEF
 Raz [M:SIP5]DACDIAANA : Affzo DACDIAANA : Grizo DACDIAANA
Endif
End

Subprog D_ACCTMP(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif   # Valeurs paramètres
If !clalev([F:COA]) : Local File GCOA   [COA] : Endif   # Code Plan

Local Char PLAN(GLONCOA)
Local Char CPTATT(GLONGAC)

Call LECMAINPLAN(1,[M:SIP0]CPY,[L]PLAN) From CPTDIV
Call LECTURE("COA",PLAN,"") From CONTOBJ
CPTATT = [F:COA]ACCMIS(1)
If CPTATT<>""  
 Call LECTURE("GAC",CPTATT,[L]PLAN) From CONTOBJ
 If !fstat
  VALEUR = [L]CPTATT
 Endif
Endif
End

Subprog C_DACDIAGEN(VALEUR)
Variable Char    VALEUR()
If !clalev([F:GDE])  : Local File =SI_DOSSIER+".GDIAENTRY"  [GDE]  : Endif  # Transactions de saisie
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif  # Modèle comptable
Call LECTURE("GCM",[M:SIP5]ACM,"") From CONTOBJ
Call LECTURE("GDE",VALEUR,"") From CONTOBJ
# Référentiel Générale principal <> Référentiel Générale Analytique
# Mono-Référentiel 6.x : Nouveaucontrôle
If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP
 If [F:GDE]TYPENT<>1 or [F:GDE]NBRLED<>2 or [F:GDE]LEDTYP(0)<>[F:GCM]GENLEDTYP or [F:GDE]LEDTYP(1)<>[F:GCM]ANALEDTYP
  # Valeur incorrecte
  GMESSAGE = mess(83,123,1) : mkstat=2 : End
 Endif
 If [M:SIP5]OPTANA=2 : Actzo [M]DACDIAANA : Endif
Else
 If [F:GDE]TYPENT<>1 or [F:GDE]LEDTYP(0)<>[F:GCM]GENLEDTYP
  # Valeur incorrecte
  GMESSAGE = mess(83,123,1) : mkstat=2 : End
 Endif
 # Mono-Référentiel 6.x : Nouveaucontrôle
 If [M:SIP5]OPTANA=2 : [M]DACDIAANA=VALEUR Else Raz [M]DACDIAANA : Endif
 Affzo [M]DACDIAANA : Grizo DACDIAANA
Endif
End

Subprog C_DACDIAANA(VALEUR)
Variable Char    VALEUR()
If !clalev([F:GDE])  : Local File =SI_DOSSIER+".GDIAENTRY"  [GDE]  : Endif  # Transactions de saisie
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif  # Modèle comptable
Call LECTURE("GCM",[M:SIP5]ACM,"") From CONTOBJ
Call LECTURE("GDE",VALEUR,"") From CONTOBJ
# Référentiel Générale principal <> Référentiel Générale Analytique
# Mono-Référentiel 6.x : Nouveaucontrôle
If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP
 If [F:GDE]TYPENT=3 or [F:GDE]NBRLED<>1 or [F:GDE]LEDTYP(0)<>[F:GCM]ANALEDTYP
  # Valeur incorrecte
  GMESSAGE = mess(83,123,1) : mkstat=2 : End
 Endif
Endif
End

Subprog C_OPTDEV(VALEUR)
Variable Integer VALEUR
If !clalev([F:XSO3]) : Local File XISOCDIV3 [XSO3] : Endif   # Paramètres divers 3 société Intégrale
If VALEUR<>2
 [M:SIP7]AMTDIF=0 : Raz [M:SIP7]ACCRNDDEB : Raz [M:SIP7]ACCRNDCDT
 [M:SIP7]OPTMULDEV=1
 Affzo OPTMULDEV, AMTDIF, OPTDIF, ACCRNDDEB, ACCRNDCDT
 Grizo OPTMULDEV, AMTDIF, OPTDIF, ACCRNDDEB, ACCRNDCDT
Else
 Gosub INIDEV
 Actzo OPTMULDEV, AMTDIF, OPTDIF, ACCRNDDEB, ACCRNDCDT
 If [M]OPTDEV<>VALEUR
  Read [XSO3] First
  If !fstat
   [M:SIP7]ACCRNDDEB = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO3]CPTDBTECADVS,"","")
   [M:SIP7]ACCRNDCDT = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO3]CPTCRDECADVS,"","")
   Affzo [M:SIP7]ACCRNDDEB : Affzo [M:SIP7]ACCRNDCDT
  Endif
 Endif
Endif 
End

$INIDEV
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif
Read [XSOC]  First
[M:SIP7]CURCPY = func SIXFONCTION.SI_COR("XIDVS",[F:XSOC]DVSIPC,"TABCUR",mess(2,45,1)-num$([F:XSOC]CODSOC))
Affzo [M:SIP7]CURCPY
Return

######################################################################################
## Ecran SIPAR6 - Achats 
######################################################################################

#--------------------------------------------------#
# Positionnement filtre élément facturation achats #
#--------------------------------------------------#
Subprog IB_PFINUM
Case nolign
  When 1,2,3,4,7,8 : #----- Frais en montant -----#
    [M:SIP6]PFIFILTRE="ENAFLG=2 & AMTCOD=2 & INCDCR=1 & DACLIN=1"
  When 5           : #----- Remise en montant -----#
    [M:SIP6]PFIFILTRE="ENAFLG=2 & AMTCOD=2 & INCDCR=2 & DACLIN=1"
  When 6           : #----- Escompte en % -----#
    [M:SIP6]PFIFILTRE="ENAFLG=2 & AMTCOD=1 & INCDCR=2 & DACORD=2"
Endcase
End


#----------------------------------------#
# Contrôle élément de facturation achats #
#----------------------------------------#
Subprog C_PFINUM(VALEUR)
Variable Decimal VALEUR
#----- Zone obligatoire pour l'escompte en pourcentage -----#
If nolign=6 & VALEUR=0
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
#-----
If VALEUR=0  End : Endif
Filter [PFI] Where evalue([M:SIP6]PFIFILTRE)
Look [PFI] PFI0=VALEUR
Filter [PFI]
If fstat  GMESSAGE=SI_MES(107) : mkstat=1 : End : Endif
End


#-----------------------------------------------#
# Positionnement filtre élément écarts positifs #
#-----------------------------------------------#
Subprog IB_PFINUM1
[M:SIP6]PFIFILTRE="ENAFLG=2 & AMTCOD=2 & INCDCR=1 & DACLIN=1 & DACORD=1"
End


#----------------------------------#
# Contrôle élément écarts positifs #
#----------------------------------#
Subprog C_PFINUM1(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
    End
Endif
#-----
Filter [PFI] Where evalue([M:SIP6]PFIFILTRE)
Look [PFI] PFI0=VALEUR
Filter [PFI]
If fstat  GMESSAGE=SI_MES(107) : mkstat=1 : End : Endif
End


#-----------------------------------------------#
# Positionnement filtre élément écarts négatifs #
#-----------------------------------------------#
Subprog IB_PFINUM2
[M:SIP6]PFIFILTRE="ENAFLG=2 & AMTCOD=2 & INCDCR=2 & DACLIN=1 & DACORD=1"
End


#----------------------------------#
# Contrôle élément écarts négatifs #
#----------------------------------#
Subprog C_PFINUM2(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
    End
Endif
#-----
Filter [PFI] Where evalue([M:SIP6]PFIFILTRE)
Look [PFI] PFI0=VALEUR
Filter [PFI]
If fstat  GMESSAGE=SI_MES(107) : mkstat=1 : End : Endif
End


