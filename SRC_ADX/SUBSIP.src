######################################################################################
# Renvoie le type de base sous la forme utilisable par "For From Sql"
######################################################################################
Funprog TYPBAS
Local Char LTYP
Case GTYPDBA
    When 1 : LTYP = "3" : # Oracle
    When 2 : LTYP = "5" : # Sql
    When 3 : LTYP = "2" : # Cisam
    When 4 : LTYP = "4" : # DB2
Endcase

End LTYP
######################################################################################

