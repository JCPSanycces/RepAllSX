#<AdxTL>@(#)8.0.0.0 $Revision$

######################################################################################
## Etiquette ajoutée par le superviseur (Objet SIP) 16/02/2007 10:56:54 (JL)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"            : Gosub OUVRE     
 When "RAZCRE"           : Gosub RAZCRE     
 When "LIENS"            : Gosub LIENS    
 When "CREATION"         : Gosub CREATION
 When "MODIF"            : Gosub MODIF
 When "ANNULE"           : Gosub ANNULE
 When "OUVRE_BOITE"      : Gosub OUVRE_BOITE

 When "SEL_LISTE"        : Gosub SELFCY

 When Default
Endcase
Return


######################################################################################
$OUVRE
Gosub SI_CONTEXT From SIXFONCTION

If  filinfo(filpath("FIL","XITVAVEN","fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XITVAACH","fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XITAXPFC","fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XICLT",   "fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XIFOU",   "fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XIART",   "fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XISOC",   "fde",SI_DOSSIER),0) < 0
& | filinfo(filpath("FIL","XIDPO",   "fde",SI_DOSSIER),0) < 0
    GMESSAGE=SI_MES(209)
    OK=0
    Return
Endif

If !clalev([F:XTV])  : Local File =SI_DOSSIER+".XITVAVEN"   [XTV]  : Endif
If !clalev([F:XTA])  : Local File =SI_DOSSIER+".XITVAACH"   [XTA]  : Endif
If !clalev([F:XTP])  : Local File =SI_DOSSIER+".XITAXPFC"   [XTP]  : Endif
If !clalev([F:XCLT]) : Local File =SI_DOSSIER+".XICLT"      [XCLT] : Endif
If !clalev([F:XFOU]) : Local File =SI_DOSSIER+".XIFOU"      [XFOU] : Endif
If !clalev([F:XART]) : Local File =SI_DOSSIER+".XIART"      [XART] : Endif
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY]  : Endif
If !clalev([F:TSV])  : Local File =SI_DOSSIER+".TABSIVTYP"  [TSV]  : Endif
If !clalev([F:PFI])  : Local File =SI_DOSSIER+".PFOOTINV"   [PFI]  : Endif
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif
If !clalev([F:XSD1]) : Local File =SI_DOSSIER+".XISOCDIV1"  [XSD1] : Endif
If !clalev([F:XDPO]) : Local File =SI_DOSSIER+".XIDPO"      [XDPO] : Endif
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX]  : Endif
If !clalev([F:PRS])  : Local File =SI_DOSSIER+".PRICSTRUCT" [PRS]  : Endif
If !clalev([F:SFI])  : Local File =SI_DOSSIER+".SFOOTINV"   [SFI]  : Endif

Read [TCA]TCA0=5
Read [ACV]CODACT="SPL"
GORDCAT=1 : # Catégorie de commande de vente autorisée : 1=Normale (pr sélection type de commande)

#Affzo [M:SIP0]CPY
Read [SPX] First
If fstat
    Trbegin [SPX]
    Read [XSOC] First
    [F:SPX]CPY = func SIXFONCTION.SI_COR("XISOC",num$([F:XSOC]CODSOC),"","")
    Write [SPX]
    Commit
Endif

Return

######################################################################################
$OUVRE_BOITE
Default File [SPX]
Read [SPX] First
CLE1=num$([F:SPX]CLE)
NEWCLE1 = CLE1
For CL=0 To dim(CLESEC)-1 : NEWCLE2(CL) = CLE2(CL) : Next CL
Gosub LECTURE From GOBJSUB
Return

######################################################################################
$RAZCRE
[M:SIP2]FIL0=[F:ACV]DIME
[M:SIP2]FIL1=[F:TCA]CODNUM(8)
Affzo [M:SIP2] 
Return

######################################################################################
$LIENS
Local Integer I,J, LIND, LTYPBAS, LEXI
Local Char LTVA(1), LTPF(1), LADD(1), LDEBENC(1)
Local Integer LCLTEXI

Diszo [M:SIP0]CPY

Read [XSOC] First
[M:SIP0]CPY = func SIXFONCTION.SI_COR("XISOC",num$([F:XSOC]CODSOC),"","")
If [M:SIP0]FCY<>""
    Filter [XDPO] Where X3CLE = [M:SIP0]FCY
    If rowcount([F:XDPO])=0
        [M:SIP0]FCY = func SIXFONCTION.SI_COR("XIDPO",[F:XSOC]DPOIPC,"","")
    Endif
    Filter [XDPO]
Else
    [M:SIP0]FCY = func SIXFONCTION.SI_COR("XIDPO",[F:XSOC]DPOIPC,"","")
Endif

Call GETSOC([M:SIP0]FCY) From DEVSUB  # Récupération de la législation...

[M:SIP0]CUR = func SIXFONCTION.SI_COR("XIDVS",[F:XSOC]DVSIPC,"","")

# Si pas de taxe additionnelle => on cache la colonne dans les régimes...
Read [XSD1]IND0=[XSOC]CODSOC
If [F:XSD1]TAXADD="N"
    Chgfmt [M:SIP4]VACADD With "-K:1X"
    # .. et on grise la zone du 3ème niveau de taxe
    Grizo [M:SIP4]VACITM3
Endif

Trbegin [SPX]
[F:SPX]CPY = [M:SIP0]CPY
[F:SPX]FCY = [M:SIP0]FCY
[F:SPX]CUR = [M:SIP0]CUR
[F:SPX]LAN = func SIXFONCTION.SI_COR("XILAN",[F:XSOC]CODLAN,"","")
If dim([F:SPX]SPLACT)>0
    [F:SPX]SPLACT=2
    [F:SPX]SPLCPT=2
Endif
Rewrite [SPX]
Commit

#---- Récupération des niveaux de taxe ----#
If !clalev([F:XART]) : Local File XIART [XART] : Endif
# Toutes les valeurs devront être renseignées même la 0/0 car le champ dans l'article est obligatoire
Local Char REQ(250)
REQ="Select Distinct CODTVAVEN_0, CODTVAACH_0, TVADBTENC_0 From XIART Order by CODTVAVEN_0, CODTVAACH_0, TVADBTENC_0"
For (Integer XCV, Integer XCA, Char XDBTENC) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    [M:SIP4]INTVACVEN([M:SIP4]NBVAC1) = [XXX]XCV
    [M:SIP4]INTVACACH([M:SIP4]NBVAC1) = [XXX]XCA
    [M:SIP4]DEBENC([M:SIP4]NBVAC1) = XDBTENC
    Read [SPV]SPV0=[F:SPX]CLE;[XXX]XCV;[XXX]XCA;XDBTENC;0
    If !fstat
        [M:SIP4]VACITM1([M:SIP4]NBVAC1)   = [F:SPV]VACITM1
    Endif
    [M:SIP4]NBVAC1+=1
Next

REQ="Select Distinct CODTPF_0 From XIART Order by CODTPF_0"
For (Integer XTPF) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    # S'il n'y a pas de TPF sur Intégrale, il n'y a pas de raison qu'il y en ait une sur X3
    If [XXX]XTPF>0
        [M:SIP4]INTTPF([M:SIP4]NBVAC2) = [XXX]XTPF
        Read [SPV]SPV0=[F:SPX]CLE;0;0;"";[XXX]XTPF
        If !fstat
            [M:SIP4]VACITM2([M:SIP4]NBVAC2)   = [F:SPV]VACITM2
        Endif
        [M:SIP4]NBVAC2+=1
    Endif
Next

Raz LIND

Local Char REQ(250)

Local Integer LNBPAYACH, LNBPAYVEN
REQ = "Select count(distinct XIPAY.CODPAY_0) From XITVAACH,XIPAY Where XITVAACH.CODPAY_0=XIPAY.CODPAY_0"
For (Integer NBPAY) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    LNBPAYACH = [XXX]NBPAY
    Break
Next

REQ = "Select count(distinct XIPAY.CODPAY_0) From XITVAVEN,XIPAY,TABCOUNTRY Where XITVAVEN.CODPAY_0=XIPAY.CODPAY_0"
For (Integer NBPAY) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    LNBPAYVEN = [XXX]NBPAY
    Break
Next
Local Char LPAYACH(GLONPAY)(LNBPAYACH+1)
Local Char LPAYVEN(GLONPAY)(LNBPAYVEN+1)

REQ = "Select distinct XIPAY.CODPAY_0 From XITVAACH,XIPAY Where XITVAACH.CODPAY_0=XIPAY.CODPAY_0 order by XIPAY.CODPAY_0"
I=0
For (Char PAY) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    LPAYACH(I) = [F:XXX]PAY
    I+=1
Next
LPAYACH(I) = ""

REQ = "Select distinct XIPAY.CODPAY_0 From XITVAVEN,XIPAY Where XITVAVEN.CODPAY_0=XIPAY.CODPAY_0 order by XIPAY.CODPAY_0"
I=0
For (Char PAY) From func SUBSIP.TYPBAS Sql REQ As [XXX]
    LPAYVEN(I) = [F:XXX]PAY
    I+=1
Next
LPAYVEN(I) = ""

Gosub ALI_VACBPS
Gosub ALI_VACBPC

[M:SIP2]FIL0=[F:ACV]DIME
[M:SIP2]FIL1=[F:TCA]CODNUM(8)

# Devise de société (présente sous l'entête)
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif  # Modèle comptable
Call LECTURE("GCM",[M:SIP5]ACM,"") From CONTOBJ
[M:SIP7]CURCPY = [M:SIP0]CUR
If [M:SIP7]OPTDEV<1 
 [M:SIP7]OPTDEV = 2
 [M:SIP7]OPTMULDEV = 1
 [M:SIP7]OPTDIF = 1
Endif
If [M:SIP7]OPTDEV<>2
 Grizo [M:SIP7]OPTMULDEV : Grizo [M:SIP7]AMTDIF : Grizo [M:SIP7]OPTDIF : Grizo [M:SIP7]ACCRNDDEB : Grizo [M:SIP7]ACCRNDCDT
Else
 Actzo [M:SIP7]OPTMULDEV : Actzo [M:SIP7]AMTDIF : Actzo [M:SIP7]OPTDIF : Actzo [M:SIP7]ACCRNDDEB : Actzo [M:SIP7]ACCRNDCDT
Endif
If [M:SIP5]OPTANA=2 
 Grizo [M:SIP5]CCEDEF
 If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP : Actzo [M:SIP5]DACDIAANA : Else  Grizo [M:SIP5]DACDIAANA : Endif
Else 
 Actzo [M:SIP5]CCEDEF
 Grizo [M:SIP5]DACDIAANA  
Endif

Gosub ALI_JOU

# hcb 43467
If [M:SIP1]IPTDATSTK = [0/0/0]
   [M:SIP1]IPTDATSTK = date$
Endif


Affzo [M:SIP1] 
Affzo [M:SIP4] 
Affzo [M:SIP2]
Affzo [M:SIP5] 
Return


######################################################################################
$ALI_VACBPS
For I=0 To LNBPAYACH
    For LTVA="O","N","C","I"
        Filter [XFOU] Where ASJTVA=LTVA
        LEXI = (rowcount([XFOU])>0)+1
        Filter [XFOU]
        Raz REQ
        Case LTVA
            When "O" : [M:SIP4]VACINTBPS([M:SIP4]NBVACS) = SI_MES(55)
            When "N" : [M:SIP4]VACINTBPS([M:SIP4]NBVACS) = SI_MES(56)
            When "C" : [M:SIP4]VACINTBPS([M:SIP4]NBVACS) = SI_MES(58)
            When "I" : [M:SIP4]VACINTBPS([M:SIP4]NBVACS) = SI_MES(61)
        Endcase
        [M:SIP4]TVAB([M:SIP4]NBVACS) = LTVA
        [M:SIP4]PAYS([M:SIP4]NBVACS)=LPAYACH(I)+string$(LPAYACH(I)="",mess(4,24,1))
        Read [SVB]SVB0=[F:SPX]CLE;"S";LTVA;"";"";LPAYACH(I)
        If fstat
            [M:SIP4]VACBPS([M:SIP4]NBVACS)=""
        Else
            [M:SIP4]VACBPS([M:SIP4]NBVACS)=[F:SVB]VACBPR
        Endif
        [M:SIP4]FOUEXI([M:SIP4]NBVACS) = LEXI
        [M:SIP4]NBVACS+=1
    Next
Next
Return

######################################################################################
$ALI_VACBPC
For I=0 To LNBPAYVEN
    For LTVA="O","N","C","E"
        For LTPF="O","N"
            For LADD="O","N"
                If LADD="N" | [F:XSD1]TAXADD="O"
                    Filter [XCLT] Where REGTVA=LTVA & REGTPF=LTPF & TAXADD=LADD
                    LEXI = (rowcount([XCLT])>0)+1
                    Filter [XCLT]
                    Case LTVA
                        When "O" : [M:SIP4]VACINT([M:SIP4]NBVACC) = SI_MES(55)
                        When "N" : [M:SIP4]VACINT([M:SIP4]NBVACC) = SI_MES(56)
                        When "C" : [M:SIP4]VACINT([M:SIP4]NBVACC) = SI_MES(58)
                        When "E" : [M:SIP4]VACINT([M:SIP4]NBVACC) = SI_MES(57)
                    Endcase
                    [M:SIP4]TVAC([M:SIP4]NBVACC) = LTVA
                    Case LTPF
                        When "O" : [M:SIP4]VACTPF([M:SIP4]NBVACC) = 2
                        When "N" : [M:SIP4]VACTPF([M:SIP4]NBVACC) = 1
                    Endcase
                    [M:SIP4]TPF([M:SIP4]NBVACC) = LTPF
                    Case LADD
                        When "O" : [M:SIP4]VACADD([M:SIP4]NBVACC) = 2
                        When "N" : [M:SIP4]VACADD([M:SIP4]NBVACC) = 1
                    Endcase
                    [M:SIP4]TAXADD([M:SIP4]NBVACC) = LADD

                    [M:SIP4]PAYC([M:SIP4]NBVACC)=LPAYVEN(I)+string$(LPAYVEN(I)="",mess(4,24,1))
                    Read [SVB]SVB0=[F:SPX]CLE;"C";LTVA;LTPF;LADD;LPAYVEN(I)
                    If fstat
                        [M:SIP4]VACBPC([M:SIP4]NBVACC)=""
                    Else
                        [M:SIP4]VACBPC([M:SIP4]NBVACC)=[F:SVB]VACBPR
                    Endif
                    [M:SIP4]CLTEXI(LIND) = LEXI
                    [M:SIP4]NBVACC+=1
                Endif
            Next
        Next
    Next
Next
Return

######################################################################################
$ALI_JOU
Raz [M:SIP5]JOU
Raz [M:SIP5]GTE

I = 0 
For [F:SPJ]SPJ0 Where CLE = [F:SPX]CLE
 [M:SIP5]JOU(I) = [F:SPJ]JOU
 [M:SIP5]GTE(I) = [F:SPJ]GTE
 I+=1
Next
[M:SIP5]NBJOU=I
Return

######################################################################################
$CREATION
    Gosub MAJ_VAC
    Gosub MAJ_JOU
Return

######################################################################################
$MODIF
    Gosub MAJ_VAC
    Gosub MAJ_JOU
Return

$MAJ_VAC
Local Integer I
Delete [SPV] Where CLE=[F:SPX]CLE

Raz [SPV]
For I=0 To [M:SIP4]NBVAC1-1
    [F:SPV]CLE = [F:SPX]CLE
    [F:SPV]INTVACVEN = [M:SIP4]INTVACVEN(I)
    [F:SPV]INTVACACH = [M:SIP4]INTVACACH(I)
    [F:SPV]DEBENC    = [M:SIP4]DEBENC(I)
    [F:SPV]VACITM1   = [M:SIP4]VACITM1(I)
    Write [F:SPV]
    If fstat
        Call FSTA("SPV") From GLOCK
        GOK=0
        Break
    Endif
Next
Raz [SPV]
For I=0 To [M:SIP4]NBVAC2-1
    [F:SPV]CLE = [F:SPX]CLE
    [F:SPV]INTTPF  = [M:SIP4]INTTPF(I)
    [F:SPV]VACITM2 = [M:SIP4]VACITM2(I)
    Write [F:SPV]
    If fstat
        Call FSTA("SPV") From GLOCK
        GOK=0
        Break
    Endif
Next

# Régimes tiers
Delete [F:SVB] Where CLE=[F:SPX]CLE
Raz [F:SVB]
For I=0 To [M:SIP4]NBVACC-1
    [F:SVB]CLE = [F:SPX]CLE
    [F:SVB]TYPBPR = "C"
    [F:SVB]TVA    = [M:SIP4]TVAC(I)
    [F:SVB]TPF    = [M:SIP4]TPF(I)
    [F:SVB]TAXADD = [M:SIP4]TAXADD(I)
    If [M:SIP4]PAYC(I) = mess(4,24,1)
        [F:SVB]PAY    = ""
    Else
        [F:SVB]PAY    = [M:SIP4]PAYC(I)
    Endif
    [F:SVB]VACBPR = [M:SIP4]VACBPC(I)
    Write [SVB]
Next
Raz [F:SVB]
For I=0 To [M:SIP4]NBVACS-1
    [F:SVB]CLE = [F:SPX]CLE
    [F:SVB]TYPBPR = "S"
    [F:SVB]TVA    = [M:SIP4]TVAB(I)
    If [M:SIP4]PAYS(I) = mess(4,24,1)
        [F:SVB]PAY    = ""
    Else
        [F:SVB]PAY    = [M:SIP4]PAYS(I)
    Endif
    [F:SVB]VACBPR = [M:SIP4]VACBPS(I)
    Write [SVB]
Next
Return

$MAJ_JOU
Delete [SPJ] Where CLE=[F:SPX]CLE

Raz [SPJ]
[F:SPJ]CLE = [F:SPX]CLE

For I=0 To [M:SIP5]NBJOU-1
 [F:SPJ]JOU = [M:SIP5]JOU(I)
 [F:SPJ]GTE = [M:SIP5]GTE(I)
 Write [F:SPJ]
 If fstat
  Call FSTA("SPJ") From GLOCK
  GOK=0 : Break
 Endif
Next
Return

######################################################################################
$ANNULE
Delete [SPV] Where CLE = [L]CODE
Return

######################################################################################
##
## ACTIONS CHAMPS DES ECRANS
##
######################################################################################

######################################################################################
## Ecran SIPAR0
######################################################################################

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Filter [XDPO] Where X3CLE = VALEUR
If rowcount([F:XDPO])=0
    mkstat=2
Endif
Filter [XDPO]
End

#-------------------------------------------------------------------------------------

$SELFCY
Raz NBTEX
For [XDPO] Where X3CLE<>""
    TEXTE(NBTEX) = [F:XDPO]X3CLE
    NBTEX+=1
Next
Return

######################################################################################
## Ecran SIPAR1 - Gestion  
######################################################################################

Subprog C_PRXFLD1(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>""
        If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
        Look [ATZ]CODZONE="XIART";VALEUR
        If fstat
            mkstat=2
        Endif
    Endif
End

Subprog C_PRXFLD2(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>""
        If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
        Look [ATZ]CODZONE="XIART";VALEUR
        If fstat
            mkstat=2
        Endif
    Endif
End


######################################################################################
## Ecran SIPAR2 - Tarifs
######################################################################################

Subprog AS_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog AM_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
If find([M]SPLCRIHT2,1,2) : [M]SPLCRIHT2=VALEUR : Affzo [M]SPLCRIHT2 : Endif
End

Subprog AS_SPLCRIHT2(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog AS_SPLCRITTC1(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog AM_SPLCRITTC1(VALEUR)
Variable Integer VALEUR
If find([M]SPLCRITTC2,1,2) : [M]SPLCRITTC2=VALEUR : Affzo [M]SPLCRITTC2 : Endif
End

Subprog AS_SPLCRITTC2(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog C_SPLFINDEV(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]SPLDEBDEV : mkstat=2 : Endif
End

Subprog AM_SPLDEBQAF(VALEUR)
Variable Date    VALEUR
If [M]SPLDEBQAS=[0/0/0] : [M]SPLDEBQAS=VALEUR : Affzo [M]SPLDEBQAS : Endif
If [M]SPLDEBQAR=[0/0/0] : [M]SPLDEBQAR=VALEUR : Affzo [M]SPLDEBQAR : Endif
End

Subprog C_SPLFINQAF(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]SPLDEBQAF : mkstat=2 : Endif
End

Subprog AS_SPLCRIQAF(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog C_SPLFINQAS(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]SPLDEBQAS : mkstat=2 : Endif
End

Subprog AS_SPLCRIQAS(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog C_SPLFINQAR(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]SPLDEBQAR : mkstat=2 : Endif
End

Subprog AS_SPLCRIQAR(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog C_SPLFINCPN(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]SPLDEBCPN : mkstat=2 : Endif
End

Subprog AS_SPLCRICPN(VALEUR)
Variable Integer VALEUR
GMENLOC(4)=1 : GMENLOC(5)=1
End

Subprog C_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : End : Endif
If VALEUR<0 | VALEUR>dim([F:PRS]INCDCR) : mkstat=2 : End : Endif
Read [PRS]PRS0=1;""
If fstat : mkstat=2 : End : Endif
Case nolign
  When 1  # -- Rem.art.% positive   
          If [F:PRS]INCDCR(VALEUR-1)=2 & find([F:PRS]VALTYP(VALEUR-1),2,3) : End : Endif
  When 2  # -- Rem.art.% negative  
          If [F:PRS]INCDCR(VALEUR-1)=1 & find([F:PRS]VALTYP(VALEUR-1),2,3) : End : Endif
  When 3  # Rem.art.mnt positive  
          If [F:PRS]INCDCR(VALEUR-1)=2 & [F:PRS]VALTYP(VALEUR-1)=1         : End : Endif
  When 4  # Rem.art.mnt positive 
          If [F:PRS]INCDCR(VALEUR-1)=1 & [F:PRS]VALTYP(VALEUR-1)=1         : End : Endif
  When 5  # Rem.cli.% positive   
          If [F:PRS]INCDCR(VALEUR-1)=2 & find([F:PRS]VALTYP(VALEUR-1),2,3) : End : Endif
  When 6  # Rem.cli.% negative  
          If [F:PRS]INCDCR(VALEUR-1)=1 & find([F:PRS]VALTYP(VALEUR-1),2,3) : End : Endif
Endcase
GMESSAGE=SI_MES(182) : mkstat=1  
End

Subprog AM_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
Case VALEUR
  When 0  : [M:SIP2]DISCRGVENL(nolign-1)=""
  When 1,2,3,4,5,6,7,8,9
       Call LECTEXTRA ([M:SIP2]DISCRGVENL(nolign-1),"PRICSTRUCT","DESAXX("+num$(VALEUR-1)+")","1","") From ATEXTRA
Endcase
Affzo [M:SIP2]DISCRGVENL(nolign-1)
End

Subprog C_DISCRGACH(VALEUR)
Variable Decimal VALEUR
If VALEUR=0  End : Endif
If VALEUR<0 | VALEUR>dim([F:PRS]INCDCR)        mkstat=1 : End : Endif
Read [PRS] PRS0=2;"" : If fstat  Raz [F:PRS] : mkstat=1 : End : Endif
If find([F:PRS]VALTYP(VALEUR-1),2,3) & [F:PRS]CLCRUL(VALEUR-1)=1 & [F:PRS]NPRNOTFLG(VALEUR-1)=2
  Case nolign
    When 1,2 : If [F:PRS]INCDCR(VALEUR-1)=2  End : Endif
    When 3,4 : If [F:PRS]INCDCR(VALEUR-1)=1  End : Endif
  Endcase
Endif
GMESSAGE=SI_MES(182) : mkstat=1  
End

Subprog AM_DISCRGACH(VALEUR)
Variable Decimal VALEUR
Raz [M:SIP2]DISCRGACHL(nolign-1)
If VALEUR>0 & VALEUR<10
  Call LECTEXTRA ([M:SIP2]DISCRGACHL(nolign-1),"PRICSTRUCT","DESAXX("+num$(VALEUR-1)+")","2","") From ATEXTRA
Endif
Affzo [SIP2]DISCRGACHL(nolign-1)
End

