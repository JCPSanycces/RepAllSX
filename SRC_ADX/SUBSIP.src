Subprog IB_CNOTYP
GFACTYP=2
End

Subprog C_CNOTYP(VALEUR)
Variable Char    VALEUR()
If [F:TSV]INVTYP <> 2      
    GMESSAGE=mess(51,139,1) : mkstat = 2 : End
Endif

End

Subprog IB_CNVTYP
GFACTYP=2
End

Subprog C_CNVTYP(VALEUR)
Variable Char    VALEUR()
If [F:TSV]INVTYP <> 2      
    GMESSAGE=mess(51,139,1) : mkstat = 2 : End
Endif
End

Subprog C_CODART(VALEUR)
Variable Char    VALEUR()
Read [XART]IND0=VALEUR
If fstat : Raz [F:XART] : mkstat=2 : End : Endif
Case [M:SIP3]TYP(nolign-1)
  When 1    : #----- Doit etre un article port Integrale 
            If [F:XART]NAT<>"PO" : GMESSAGE=SI_MES(183) : mkstat=2 : End : Endif       
  When 2,3  : #----- Doit etre un article frais Integrale 
            If [F:XART]NAT<>"FR" : GMESSAGE=SI_MES(184) : mkstat=2 : End : Endif       
Endcase 
End

Subprog IB_SFINUM
[M:SIP3]SFIFILTRE="DACORD<>0"   
End

Subprog C_SFINUM(VALEUR)
