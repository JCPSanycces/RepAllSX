# Supervisor
## CRUD-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:18 229


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub _AVARIABLES From WMC00EDIXMLFIL

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EDIXMLFIL

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDIXMLFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EDIXMLFIL.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EDIXMLFIL
Else
 Gosub AUPDATE_EDIXMLFIL
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EDIXMLFIL.freeSnapshot
EDIXMLFIL.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EDIXMLFIL.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIXMLFIL.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EDIXMLFIL.ASTALIN)<>""
 [L]A_ASTALIN = EDIXMLFIL.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]A_ASTALIN = EDIXMLFIL.EXFN([L]A_I).ASTALIN
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEW & EDIXMLFIL.ASTALIN=[V]CST_ADEL
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ANEW & find(EDIXMLFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIXMLFIL.EXFD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXFD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEW & EDIXMLFIL.ASTALIN=[V]CST_ADEL
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ANEW & find(EDIXMLFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIXMLFIL.EXSD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXSD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEW & EDIXMLFIL.ASTALIN=[V]CST_ADEL
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ANEW & find(EDIXMLFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(EDIXMLFIL.EXFF(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXFF(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIXMLFIL.EXFD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXFD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIXMLFIL.EXSD(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXSD(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(EDIXMLFIL.EXFF(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = EDIXMLFIL.EXFF(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]A_ASTALIN = EDIXMLFIL.EXFN([L]A_I).ASTALIN
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [V]CST_ASTALIN(EDIXMLFIL.ASTALIN)<>""
 [L]A_ASTALIN = EDIXMLFIL.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EDIXMLFIL
Trbegin [F:EXF]
 Gosub AUPDATE_EDIXMLFIL
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EDIXMLFIL
[L]A_ASTALIN = EDIXMLFIL.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIXMLFIL._MAJSQL_EDIXMLFIL(EDIXMLFIL))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW
 #-----------------------#
 For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
  If EDIXMLFIL.EXFD(A_N2) <> null and
& (EDIXMLFIL.EXFD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ALL)
   If EDIXMLFIL.EXFD(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIXMLFIL.EXFD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXFD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILD(EDIXMLFIL.EXFD(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIXMLFIL.EXFD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXFD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
 #-----------------------#
 For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
  If EDIXMLFIL.EXSD(A_N2) <> null and
& (EDIXMLFIL.EXSD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ALL)
   If EDIXMLFIL.EXSD(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIXMLFIL.EXSD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXSD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILXSD(EDIXMLFIL.EXSD(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIXMLFIL.EXSD(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXSD(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
 #-----------------------#
 For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
  If EDIXMLFIL.EXFF(A_N2) <> null and
& (EDIXMLFIL.EXFF(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ALL)
   If EDIXMLFIL.EXFF(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(EDIXMLFIL.EXFF(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXFF(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILF(EDIXMLFIL.EXFF(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(EDIXMLFIL.EXFF(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = EDIXMLFIL.EXFF(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = EDIXMLFIL.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EDIXMLFIL.snapshotEnabled=1
 [L]A_RETIK = EDIXMLFIL.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
 If EDIXMLFIL.EXFD(A_N2) <> null
  If EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
 If EDIXMLFIL.EXSD(A_N2) <> null
  If EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
 If EDIXMLFIL.EXFF(A_N2) <> null
  If EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ANEWDEL
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet EDIXMLFIL.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EDIXMLFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIXMLFIL.ASTALIN = [V]CST_ALL
Endif
For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  If EDIXMLFIL.EXFN([L]A_I).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFN([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFN([L]A_I)
   EDIXMLFIL.EXFN([L]A_I) = null
  Elsif EDIXMLFIL.EXFN([L]A_I).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFN([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
 If EDIXMLFIL.EXFD(A_N2) <> null
  If EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFD(A_N2)
   EDIXMLFIL.EXFD(A_N2) = null
  Elsif EDIXMLFIL.EXFD(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
 If EDIXMLFIL.EXSD(A_N2) <> null
  If EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXSD(A_N2)
   EDIXMLFIL.EXSD(A_N2) = null
  Elsif EDIXMLFIL.EXSD(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
 If EDIXMLFIL.EXFF(A_N2) <> null
  If EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFF(A_N2)
   EDIXMLFIL.EXFF(A_N2) = null
  Elsif EDIXMLFIL.EXFF(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



