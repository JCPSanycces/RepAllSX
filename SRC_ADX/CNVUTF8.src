#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(80)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CNVUTF8","CNVUTF8",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "EXEC"    : Gosub EXEC
Endcase
Return

$EXEC
Call UTF8([M:DIA]REP,[M:DIA]FIC,[M:DIA]EXT,[M:DIA]APPLI,[M:DIA]SNS) From MAJUTF8
Return

Subprog C_EXT(VALEUR)
Variable Char    VALEUR()
If filinfo(filpath([M]REP,[M]FIC,VALEUR,[M]APPLI),0)<0
 GMESSAGE = mess(101,100,1)
 mkstat = 2
 End
Endif
End

