# Classe SOCSIGHIS
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#        Case [L]AEVENT
#        Endcase
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  Case [L]CURPRO
    When "RCHRONO"
      Case [L]ARULE
        When "GET"
          this.RCHRONO = this.AWS.CHRONO
        When Default
      Endcase
    When "DEVTTC"
      Case [L]ARULE
        When "GET"
          this.DEVTTC = this.AWS.VALCTX6
        When Default
      Endcase
    When "RCLEDEC"
      Case [L]ARULE
        When "GET"
          this.RCLEDEC = this.AWS.CLEDEC
        When Default
      Endcase
    When "RVALCTX7"
      Case [L]ARULE
        When "GET"
          Local Integer IDAY
          Local Integer IMONTH
          Local Integer IYEAR

          IDAY = val(left$(this.AWS.VALCTX7,2))
          IMONTH = val(mid$(this.AWS.VALCTX7,4,2))
          IYEAR = val(mid$(this.AWS.VALCTX7,7,4))
          this.RVALCTX7 = gdat$(IDAY, IMONTH, IYEAR)
        When Default
      Endcase
    When "RVALCTX2"
      Case [L]ARULE
        When "GET"
          this.RVALCTX2 = this.AWS.VALCTX2
        When Default
      Endcase
    When "RVALCTX3"
      Case [L]ARULE
        When "GET"
          this.RVALCTX3 = this.AWS.VALCTX3
        When Default
      Endcase
    When "RVALCTX1"
      Case [L]ARULE
        When "GET"
          this.RVALCTX1 = this.AWS.VALCTX1
        When Default
      Endcase
    When "RVALCTX4"
      Case [L]ARULE
        When "GET"
          this.RVALCTX4 = val(this.AWS.VALCTX4)
        When Default
      Endcase
    When "RVALCTX6"
      Case [L]ARULE
        When "GET"
          this.RVALCTX6 = this.AWS.VALCTX6
        When Default
      Endcase
    When "RVALCTX5"
      Case [L]ARULE
        When "GET"
          this.RVALCTX5 = val(this.AWS.VALCTX5)
        When Default
      Endcase
    When "RVALCTX8"
      Case [L]ARULE
        When "GET"
          this.RVALCTX8 = this.AWS.VALCTX8
        When Default
      Endcase
    When "RVALCTX9"
      Case [L]ARULE
        When "GET"
          this.RVALCTX9 = this.AWS.VALCTX9
        When Default
      Endcase
    When Default
  Endcase
Return

