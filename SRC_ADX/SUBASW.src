$ANNULE
Delete [ASWF] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWF",[L]CODE) From GLOCK : Return : Endif
Delete [ASWP] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWP",[L]CODE) From GLOCK : Return : Endif
Delete [ASWMN] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWMN",[L]CODE) From GLOCK : Return : Endif
Delete [ASWM] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWM",[L]CODE) From GLOCK : Return : Endif
Delete [ASWMP] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWMP",[L]CODE) From GLOCK : Return : Endif
Delete [ASWO] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWO",[L]CODE) From GLOCK : Return : Endif
Delete [ASWC] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWC",[L]CODE) From GLOCK : Return : Endif
Delete [ASWS] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWS",[L]CODE) From GLOCK : Return : Endif
Delete [ASWB] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWB",[L]CODE) From GLOCK : Return : Endif
Delete [ASWR] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWR",[L]CODE) From GLOCK : Return : Endif
Delete [ASWK] Where CODREP=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ASWK",[L]CODE) From GLOCK : Return : Endif
Return

##--------------------------------------------#
#$AV_VERF_ANU
## Réécriture enreg ASWK si rep identique pour ne pas rencontrer de lien bloquant
#Trbegin [ASWK]
#For [ASWK] Where [F:ASWK]CODREP=[L]CODE & [F:ASWK]REPLNK=[L]CODE
#      [F:ASWK]REPLNK=num$(adxuid(1))
#      Rewrite [ASWK]
#Next
#Commit
#Return

#--------------------------------------------#
$VERF_ANU
Local Char L_ERR_MSG(250)
For [ASWK] Where [F:ASWK]CODREP<>[L]CODE & [F:ASWK]REPLNK=[L]CODE & [F:ASWK]FLGSTDLNK<>2
 #120917
 If GSERVEUR & find([M:ASW1]MODULE,9,11)<>0
   L_ERR_MSG = func AFNC.MES1(mess(210,143,1),[F:ASWK]CODREP)
   L_ERR_MSG += "\"+func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)
   Call MESSAGE(L_ERR_MSG) From GESECRAN
 Else
   L_ERR_MSG = func AFNC.MES1(mess(210,143,1),[F:ASWK]CODREP)
   L_ERR_MSG += "\"+func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)
   L_ERR_MSG += "\"+mess(176,115,1)
   Call ERREUR(L_ERR_MSG) From GESECRAN
   OK = 0 :  Break
 Endif
Next
If OK=0 : Return : Endif

If [M:ASW1]FLGSYSTEM = 2
 #120917 #On autorise suppression batch des rep systèmes interne
 If GSERVEUR & find([M:ASW1]MODULE,9,11)<>0 : OK=2 : Endif
 # C'est une classe Système, voulez-vous vraiment la supprimer ?
 Call AVERTIR(mess(108,143,1),OK) From GESECRAN
 If OK=1 : OK = 0 :  Return : Endif
Endif

For [ASWK] Where [F:ASWK]CODREP<>[L]CODE & [F:ASWK]REPLNK=[L]CODE & [F:ASWK]FLGSTDLNK=2
   L_ERR_MSG = func AFNC.MES1(mess(211,143,1),[L]CODE)
   Call MESSAGE(L_ERR_MSG) From GESECRAN
   Break
Next

Return

