$LNK_RESERVED
Local Char CODLNK_RESERVED(20)(1..16)
CODLNK_RESERVED(1)="ACREATE"
CODLNK_RESERVED(2)="ADETAILS"
CODLNK_RESERVED(3)="AEDIT"
CODLNK_RESERVED(4)="ADELETE"
CODLNK_RESERVED(5)="AQUERY"
CODLNK_RESERVED(6)="ALOOKUP"
CODLNK_RESERVED(7)="ASUMMARY"
CODLNK_RESERVED(8)="APDF"
CODLNK_RESERVED(9)="AEXCEL"
CODLNK_RESERVED(10)="AWORD"
CODLNK_RESERVED(11)="AMAILMERGE"
CODLNK_RESERVED(12)="AABORT"
CODLNK_RESERVED(13)="ASAVE"
CODLNK_RESERVED(14)="ADUPLICATE"
CODLNK_RESERVED(15)="ALOB"
CODLNK_RESERVED(16)="AHELP"
