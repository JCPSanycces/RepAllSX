If !clalev([F:ASW2])    : Local File ASHW        [F:ASW2]    : Endif
If !clalev([F:ASWA])    : Local File ASHW        [ASWA]    : Endif
If !clalev([F:L_ASW])    : Local File ASHW       [L_ASW]    : Endif
If !clalev([F:ASWP])    : Local File ASHWPAR     [ASWP]    : Endif
If !clalev([F:ASWMN])   : Local File ASHWMENU    [ASWMN]   : Endif

# Classe
If !clalev([F:ACLAF])   : Local File ACLAFLD     [ACLAF]   : Endif
If !clalev([F:ACLAF2])  : Local File ACLAFLD     [ACLAF2]  : Endif
If !clalev([F:ACLAM])   : Local File ACLAMET     [ACLAM]   : Endif
If !clalev([F:ACLA])    : Local File ACLASSE     [ACLA]    : Endif
If !clalev([F:ACLA1])   : Local File ACLASSE     [ACLA1]   : Endif
If !clalev([F:ACLA2])   : Local File ACLASSE     [ACLA2]   : Endif
If !clalev([F:ACLA8])   : Local File ACLASSE     [ACLA8]   : Endif
