Subprog DEFLNKFAC(AFAC,ASHW,ASWFAC)
Value Integer AFAC
Variable Instance ASHW Using C_ASW
Variable Instance ASWFAC Using C_ASWFAC
If ASWFAC.DEFLNKFAC=2
 Case AFAC
  When 1 : ASWFAC.AFFLNKFAC=5 : ASWFAC.LNKMENFAC="AEDIT"
  When 2 : ASWFAC.AFFLNKFAC=4 : ASWFAC.LNKMENFAC="ASAVE"
  When 3 : ASWFAC.AFFLNKFAC=4
           If ASHW.FONCTION<>"" : #Convergence PAGE/Liens sur fonction dans tous les cas
            ASWFAC.LNKMENFAC="AEDIT"
           Else
            ASWFAC.LNKMENFAC="ACREATE"
           Endif
  When 4 :
  When 5 :
 Endcase
Endif
End

#--------------------------------#
$FERME
#FreeInstance [ASWA]
#FreeInstance [ACLA]
Return

#--------------------------------#
$SETBOUT

Local Integer WMODIFLNK
Gosub CLA_RESERVE_MB

If [M:ASW0]MODIFLNK=2
  MES_OK=2
  Call OUINON(mess(191,143,1)+"\"+mess(193,143,1),MES_OK) From GESECRAN
  If MES_OK<>2
    WMODIFLNK=0
  Else
    WMODIFLNK=1
  Endif
Elsif [M:ASW0]MODIFPAR=2
  MES_OK=2
  Call OUINON(mess(192,143,1)+"\"+mess(193,143,1),MES_OK) From GESECRAN
  If MES_OK<>2
    WMODIFLNK=0
  Else
    WMODIFLNK=1
  Endif
Endif

# Désactiver la modification/suppression si c'est une classe SYSTEM
If ([M:ASW1]FLGSYSTEM=2 & GADONIX<>2) or find([M:ASW0]CODREP,TBCLAMB(1..NBCLAMB))
 Call VIREBOUT(CHAINE,"MA") From GOBJET
Elsif [M:ASW0]CODREP<>"" & WMODIFLNK=1
  If !VERROU : Gosub VERROU From GOBJET : Endif
  If !VERROU
   Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
  Else
    REP="M" : #Activation bouton enregistrer
    Grizo [M:ASW0]CODREP
  Endif
  WMODIFLNK=0
  [M:ASW0]MODIFPAR=0
  [M:ASW0]MODIFLNK=0
Endif

If CLECUR=0 or REP="M" or (!VERROU & (dim([L]MLOCK)<=0 or ![L]MLOCK)) or find([M:ASW0]CODREP,TBCLAMB(1..NBCLAMB))
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, Copie
Else
 CHMEN += "13"
Endif

If CLECUR=0 | REP<>"" | [M:ASW0]CODREP=""
 Call VIREBOUT(CHAINE,"6") From GOBJET : # Menus
 Call VIREBOUT(CHAINE,"7") From GOBJET : # Classes liées (Arborescence)
Endif

If CLECUR=0 | [M:ASW0]CODREP="" | find(2,[M:ASW6]INVLNK)=0
 Call VIREBOUT(CHAINE,"5") From GOBJET : # Liens invalides
Endif

Read [ACLA]ACLA0 = [M:ASW1]CODCLA
If !fstat & [F:ACLA]TYPCLA = 2
 Local Char  MACHINE(GDIMFIC), APPLI(GDIMFIC),FICLCK(GDIMFIC), NOMTRT(GLONADC)
 Call MACHINE(nomap,MACHINE,APPLI) From ORDSYS
 NOMTRT = func ACLAVALCRUD.GET_PREFIX_REP_READ+[M:ASW0]CODREP
 FICLCK = filpath("TRT",NOMTRT ,"src",APPLI,"",MACHINE)

 # check if trt WMLxxx exists
 If filinfo(FICLCK,0)>=0
  CHMEN += "4"
 Endif
Endif

Return

#--------------------------------#
$APRES_MODIF
#Ajout pour forcer RAZDUP
If COUZON="CODREP" : REP="" : Endif
Return

#--------------------------------#
$RAZDUP
Raz WAFCRIGHT
Local Integer I
[M]NBRFAC= len(mess(0,7964,1))
For I=0 To [M]NBRFAC-1
   [M:ASW1]CODFAC(I)=I+1
Next
Affzo [M:ASW1]CODFAC
[M]NBRCOM= len(mess(0,7968,1))
For I=0 To [M]NBRCOM-1
   [M:ASW1]CODCOM(I)=I+1
   If [M:ASW1]CODCOM(I)=4 & [M:ASW1]ENACOM(I)=2
    [M:ASW1]ENACOM(I)=1
   Endif
   If [M:ASW1]ENACOM(I)=0
    [M:ASW1]ENACOM(I)=1
   Endif
Next
Affzo [M:ASW1]CODCOM
Affzo [M:ASW1]ENACOM
#
[M:ASW0]MODIFLNK=0
[M:ASW0]MODIFPAR=0
[M:ASW1]DEFREP=1
Affzo [M:ASW1]DEFREP
[M:ASW0]CODREP=CZ
Gosub MAJ_STDLNK_FCT_1
For I=0 To [M:ASW1]NBRTRT
 If [M:ASW1]TYPTRT(I)=1
  Dela I,1 [M:ASW1]NBRTRT
  [M:ASW1]NBRTRT -=1
  I-=1
 Endif
Next I
Affzo [M:ASW1]50
If GADONIX<>2
 Grizo [M:ASW1]FLGSYSTEM
Else
 Actzo [M:ASW1]FLGSYSTEM
 Affzo [M:ASW1]FLGSYSTEM
Endif
Return

#--------------------------------#
$MAJ_STDLNK_FCT_1
Call MAJ_STDLNK_ASW6(0,0,nomap,[M:ASW0]CODREP,1) From SUBASWLNK
[M:ASW0]MODIFPAR=0
[M:ASW0]MODIFLNK=0
Return

#--------------------------------#
$MAJ_STDLNK_FCT_2
Call MAJ_STDLNK_ASW6(0,0,nomap,[M:ASW0]CODREP,2) From SUBASWLNK
[M:ASW0]MODIFPAR=0
[M:ASW0]MODIFLNK=0
Return
#--------------------------------#
$RAZCRE
Raz WAFCRIGHT
Local Integer I
[M]NBRFAC= len(mess(0,7964,1))
For I=0 To [M]NBRFAC-1
   [M:ASW1]CODFAC(I)=I+1
Next
Affzo [M:ASW1]CODFAC
[M]NBRCOM= len(mess(0,7968,1))
For I=0 To [M]NBRCOM-1
   [M:ASW1]CODCOM(I)=I+1
#   If [M:ASW1]CODCOM(I)=4 & [M:ASW1]ENACOM(I)=2
#    [M:ASW1]ENACOM(I)=1
#   Endif
  [M:ASW1]ENACOM(I)=1
Next
Affzo [M:ASW1]CODCOM
Affzo [M:ASW1]ENACOM
[M]NBCONFIG= len(mess(0,7964,1))
For I=0 To [M]NBCONFIG-1
   [M:ASW8]DEFLNKFAC(I)=2
Next
Affzo [M:ASW8]FACCETTE
Affzo [M:ASW8]DEFLNKFAC
Actzo [M:ASW2]NBROPT
[M:ASW0]MODIFLNK=0
[M:ASW0]MODIFPAR=0
If GADONIX<>2
 Grizo [M:ASW1]FLGSYSTEM
Endif
Return

#--------------------------------#
$EXEBOUT
Case REP
 When "V"
  OK = 2 :
  Call OUINON(mess(48,140,1) -CLECUR1,OK) From GESECRAN : # : VALIDATION representation
  If OK<>2 : Return : Endif
  Call VALIDATION(0,nomap,CLECUR1)
Endcase
Return

#----------------------------------------#
$STATUT
Local Integer  TYPAGE
Local Integer  OK
Case BOUT
 When "1" : Call VALIDATION_ALL(nomap,[M:ASW0]CODREP)
 When "3" : #Call VALIDATION(1,[M:ASW0]CODREP,nomap,0,1,0,TYPAGE,OK) From ASHWVAL
            Call VALIDATION(1,nomap,[M:ASW0]CODREP)
 When "4" : Gosub TEST From =func ACLAVALCRUD.GET_PREFIX_REP_READ+[M:ASW0]CODREP
Endcase
Return

#--------------------------------#
$CLA_RESERVE_MB
Local Char TBCLAMB(GLONASW)(1..50)
Local Integer NBCLAMB
If nomap="SUPERV"
 If !find(GUSER,"MB")
  #NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "TABCOUNTRY "
 Endif
 If GUSER<>"ERB"
  NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "ZTRACE"
 Endif
Endif
Return


#----------------------------------------#
Subprog GENDOS(APPLI)
Value Char APPLI
If clalev([F:ASW_])=0     : Local File =APPLI+".ASHW"    [ASW_]   : Endif
For [ASW_]
 Call VALIDATION(0,APPLI,[ASW_]CODREP)
Next ASW_
End

#----------------------------------------#
Subprog VALIDATION(TEST,DOSSIER,CODREP)
Value Integer TEST
Value Char DOSSIER,CODREP

If DOSSIER=nomap
 If clalev([F:ASW])=0 : Local File ASHW    [ASW] : Endif
Else
 If clalev([F:ASW])=0 : Local File =DOSSIER+".ASHW"    [ASW] : Endif
Endif
Read [ASW]ASW0=CODREP
If fstat : End : Endif

Gosub DOSS_CODREP_VALIDATION
End

$DOSS_CODREP_VALIDATION
Local Integer OK,TYPAGE,STAT
If dim(TEST)<=0: Local Integer TEST : Endif
#Validation différée (à la volée)
If dim(GVALIDDIFF)>0 & GVALIDDIFF=3
  Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

  If GTRACE<>""
    Call ECR_TRACE(mess(52,140,1)-CODREP,0) From GESECRAN : # Validation différée de la représentation
  Endif
  #90822
  #Call EFFACE_STC(MACHINE,APPLI,func PREFIX_REP+CODREP,STAT) From ORDSYS
  Call INVALID_STC(MACHINE,APPLI,func PREFIX_REP+CODREP,STAT) From ORDSYS
  OK = pullObject(MACHINE,APPLI,func PREFIX_REP+CODREP )
  If [L]TEST & GTRACE<>""
   If OK<0
   Call ECR_TRACE(" -"-CODREP-"INVALID_STC="+num$(STAT)-"PULLOBJECT="+num$(OK),-1) From GESECRAN
   Else
   Call ECR_TRACE(" -"-CODREP-"INVALID_STC="+num$(STAT)-"PULLOBJECT="+num$(OK),0) From GESECRAN
   Endif
  Endif
Else
  Call VALIDATION([L]TEST,CODREP,DOSSIER,0,1,0,TYPAGE,OK) From ASHWVAL
Endif
Return

Subprog VALIDATION_ALL(DOSSIER,CODREP)
Value Char DOSSIER
Value Char    CODREP
Local Integer OK ,I,TYPAGE
Local Char TBCLA(GLONACLA)(1..)

If DOSSIER=nomap
 If clalev([F:ASW])=0 : Local File ASHW    [ASW] : Endif
 If clalev([F:ACLAF])=0 : Local File ACLAFLD    [ACLAF] : Endif
Else
 If clalev([F:ASW])=0 : Local File =DOSSIER+".ASHW"    [ASW] : Endif
 If clalev([F:ACLAF])=0 : Local File =DOSSIER+".ACLAFLD"    [ACLAF] : Endif
Endif

Read [ASW]ASW0=CODREP
If fstat : End : Endif

TBCLA(1) = [F:ASW]CODCLA
For [ACLAF]ACLAF0 Where CODCLA=TBCLA(1) & [ACLAF]LNKCLA<>""
 If !find([ACLAF]LNKCLA,TBCLA)
  Call CHARGE_TBCLA(nomap,[ACLAF]LNKCLA,TBCLA)
 Endif
Next

Call OUVRE_TRACE(mess(14,140,1)-CODREP) From LECFIC
For I=1 To maxtab([L]TBCLA)
 #Call VALIDATION(0,[L]TBCLA(I),DOSSIER,0,1,0,[L]TYPAGE,OK) From ACLAVAL
 Call VALIDATION(0,DOSSIER,[L]TBCLA(I)) From SUBACLA
Next
#Call VALIDATION(0,[F:ASW]CODREP,DOSSIER,0,1,0,TYPAGE,OK) From ASHWVAL
Call VALIDATION(0,DOSSIER,[F:ASW]CODREP)

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

#--------------------------------#
Subprog CHARGE_TBCLA(APPLI,WCLA,TBCLA)
Value Char APPLI
Value Char WCLA
Variable Char TBCLA()(1..)

Local File =APPLI+".ACLAFLD" [ACLAF9]

TBCLA(maxtab(TBCLA)+1) = WCLA

For [ACLAF9]ACLAF0 Where CODCLA = WCLA & [ACLAF9]LNKCLA<>""
 If !find([ACLAF9]LNKCLA,TBCLA)
  Call CHARGE_TBCLA(nomap,[ACLAF9]LNKCLA,TBCLA)
 Endif
Next

Close Local File [ACLAF9]
End


#--------------------------------#
$STYLE
Local Integer NOL,I
For NOL=0 To [M:ASW9]NBRFLD-1
 Chgstl [ASW9]CODTYP(NOL) With ""
 Chgstl [ASW9]LOBTAB(NOL) With ""
 Chgstl [ASW9]LOBFLD(NOL) With ""
 Chgstl [ASW9]LOBCNT(NOL) With ""
 For I=0 To [M:ASW5]NBRPAR-1
  If [M:ASW9]CODFLD(NOL)=[M:ASW5]CODFLD(I) & [M:ASW5]TYPPAR(I)=1
   Chgstl [ASW9]CODTYP(NOL) With "AMKACT"
   If [ASW9]LOBTAB(NOL)<>""
    Chgstl [ASW9]LOBTAB(NOL) With "AMKACT"
   Endif
   If [ASW9]LOBFLD(NOL)<>""
    Chgstl [ASW9]LOBFLD(NOL) With "AMKACT"
   Endif
   If [ASW9]LOBCNT(NOL)<>""
    Chgstl [ASW9]LOBCNT(NOL) With "AMKACT"
   Endif
   Break
  Endif
 Next I
Next NOL
For NOL=0 To [M:ASW2]NBROPT-1
  If [M:ASW2]OPTFLGCLA(NOL)=2
    Grizo [M:ASW2]AZOPTLIB(NOL)
    Grizo [M:ASW2]OPTACT(NOL)
    Grizo [M:ASW2]OPTCND(NOL)
    Grizo [M:ASW2]AZOPTERR(NOL)
  Else
    Actzo [M:ASW2]AZOPTLIB(NOL)
    Actzo [M:ASW2]OPTACT(NOL)
    Actzo [M:ASW2]OPTCND(NOL)
    Actzo [M:ASW2]AZOPTERR(NOL)
  Endif
Next NOL
Return

#------------------------------#
$LOAD_ASWC
Local Integer I
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
[M:ASW1]NBRCOL = 0
Gosub L_LOAD_ASWC_FLGCOLCLA
nolign=0
For [ASWC]ASWC0 Where CODREP=[M:ASW0]CODREP
  nolign+=1
 [M:ASW1] = [F:ASWC]
 Call TEXTE([M:ASW1]INTCOL(nolign-1),[M:ASW1]INTITCOL(nolign-1)) From OBJDIV
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0
  I = find([M:ASW1]CODCOL(nolign-1), TAB_COD) # need the "Gosub L_LOAD_ASWC_FLGCOLCLA" above to be able to use the lists TAB_XXX
  If I>0
   [M:ASW1]FLGINSCOLCLA(nolign-1) = TAB_INS(I)
   [M:ASW1]FLGSUPCOLCLA(nolign-1) = TAB_SUP(I)
   [M:ASW1]FLGTRICOLCLA(nolign-1) = TAB_TRI(I)
   [M:ASW1]FLGAPDCOLCLA(nolign-1) = TAB_APD(I)
  Endif
 Endif
Next
[M:ASW1]NBRCOL=nolign
nolign=SAVNOLIGN
Return

#------- $LOAD_ASWC internal use only -------#
$L_LOAD_ASWC_FLGCOLCLA
 Local Char    WABR(80)
 Local Char TAB_COD(250)(1..100)
 Local Char TAB_LIB(80)(1..100)
 Local Integer TAB_MIN(1..100)
 Local Char TAB_ACT(80)(1..100)
 Local Integer TAB_MAX(1..100)
 Local Char TAB_COM(80)(1..100)
 Local Integer TAB_INS(1..100)
 Local Integer TAB_SUP(1..100)
 Local Integer TAB_TRI(1..100)
 Local Integer TAB_APD(1..100)
 Local Char TAB_CLA(GLONACLA)(1..100)
 Local Integer TAB_NB
 WABR = [M:ASW1]ABRCLA
 Call LOAD_FLDGRP_COMPLETE([M:ASW1]CODCLA,WABR,TAB_COD,TAB_LIB,TAB_MIN,TAB_ACT,TAB_MAX,TAB_COM,TAB_INS,TAB_SUP,TAB_TRI,TAB_APD,TAB_CLA,TAB_NB) From SUBASW_TOOL
Return

#------------------------------#
$LOAD_ASWO
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
[M:ASW2]NBROPT=0
nolign = 0
Actzo [M:ASW2]NBROPT
For [ASWO] Where CODREP=[M:ASW0]CODREP
  nolign += 1
  [M:ASW2] = [F:ASWO]
  If [F:ASWO]OPTFLGCLA=2
    Read [ACLAO]ACLAO0=[M:ASW1]CODCLA;[F:ASWO]OPTCOD
    If !fstat
      [M:ASW2] = [F:ACLAO]
      Call TEXTE([F:ACLAO]OPTLIB,[M:ASW2]AZOPTLIB(nolign-1)) From OBJDIV
      Call TEXTE([F:ACLAO]OPTERR,[M:ASW2]AZOPTERR(nolign-1)) From OBJDIV
    Else
      Call ERREUR(func AFNC.MES2(mess(147,143,1), [F:ASWO]OPTCOD, [M:ASW1]CODCLA )) From GESECRAN
    Endif
  Else
    Call TEXTE([F:ASWO]OPTLIB,[M:ASW2]AZOPTLIB(nolign-1)) From OBJDIV
    Call TEXTE([F:ASWO]OPTERR,[M:ASW2]AZOPTERR(nolign-1)) From OBJDIV
  Endif
Next
[M:ASW2]NBROPT=nolign

Local Char VALEUR(GLONACLA)
[L]VALEUR=[M:ASW1]CODCLA
Gosub CHARGE_TABREF

[M:ASW2]CODIND=[F:ASW]CODIND
If [M:ASW2]CODIND<>""
 Read [ATI]CODIND=[M]TABREF;[M:ASW2]CODIND
 If !fstat
  [M:ASW2]ADESIND=[ATI]DESCRIPT
  Affzo [M:ASW2]ADESIND
 Endif
Else
 [M:ASW2]DESCRIPT=[F:ASW]DESCRIPT
Endif
If [M:ASW2]CODIND<>""
 Grizo [M:ASW2]DESCRIPT
Else
 If [M:ASW2]DESCRIPT<>""
  Grizo [M:ASW2]CODIND
 Else
  Actzo [M:ASW2]CODIND
 Endif
 Actzo [M:ASW2]DESCRIPT
Endif

nolign=SAVNOLIGN
Return

$CHARGE_TABREF
Local Integer I
[M:ASW2]TABREF=""
Read [F:ACLA1]ACLA0 = [L]VALEUR
If !fstat
  [M:ASW2]TABREF=[F:ACLA1]TABREF
  Gosub GRISE_ASWO
Endif
Effzo [M:ASW2]35
I = 0
For [ACLAK]ACLAK0 Where [M:ASW1]CODCLA
  [M:ASW2]TABORI(I) = [F:ACLAK]TABORI
  [M:ASW2]TABLNK(I) = [F:ACLAK]TABLNK
  I += 1
Next
[M:ASW2]NBRTAB=I
Return

$GRISE_ASWO
Actzo [M:ASW2]NBROPT
If [F:ACLA1]FLGBUFFER=2
 Effzo [M:ASW2]30
 Grizo [M:ASW2]NBROPT
 Return
Endif
If [F:ACLA1]TYPCLA<>2
 Effzo [M:ASW2]30
 Grizo [M:ASW2]NBROPT
Endif
Return

#------------------------------#
$LOAD_ASWM
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
# Méthodes
nolign = 0
For [ASWM]ASWM1 Where CODREP=[M:ASW0]CODREP
 nolign += 1
 [M:ASW3] = [ASWM]
 Call TEXTE([F:ASWM]INTMET,[M:ASW3]INTITMET(nolign-1)) From OBJDIV
Next
[M:ASW3]NBRMET = nolign
# parametres methodes
I=0
For [ASWMP] Where CODREP=[M:ASW0]CODREP
 [M:ASW3]WCODMET(I)    = [ASWMP]CODMET
 [M:ASW3]WCODPARMET(I) = [ASWMP]CODPARMET
 [M:ASW3]WTYPPARMET(I) = [ASWMP]TYPPARMET
 [M:ASW3]WMODPARMET(I) = [ASWMP]MODPARMET
 [M:ASW3]WINTPARMET(I) = [ASWMP]INTPARMET
 [M:ASW3]WCLAPARMET(I) = [ASWMP]CLAPARMET
 [M:ASW3]WNOPARMET(I)  = [ASWMP]NOPARMET
 [M:ASW3]WDIMPARMET(I) = [ASWMP]DIMPARMET
 I +=1
Next
[M:ASW3]WNBRPARMET = I
Gosub SORTA_ASW3
nolign=SAVNOLIGN
Call AS_NBRMET From SUBASW2
Return

#------------------------------#
$LOAD_ASWR
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Char MESSERR(250)
nolign = 0
For [ASWR]ASWR0 Where CODREP=[M:ASW0]CODREP

 If nolign=dim([M]ABLCPRO) : GMESSAGE = func AFNC.MES1(mess(27,146,1),num$(dim([M]ABLCPRO))) : Break  : Endif

 nolign += 1
 [M:ASW4] = [ASWR]

 Call CONTROLE_CODPRO(1,[M:ASW4]CODPRO(nolign-1),nolign-1,0,0,MESSERR ) From SUBASW2

 Call TEXTE([F:ASWR]INTPRO,[M:ASW4]AZINTPRO(nolign-1)) From OBJDIV
 Call TEXTE([F:ASWR]INTSHTPRO,[M:ASW4]AZINTSHTPRO(nolign-1)) From OBJDIV

 [M:ASW4]FLDGRPPRO(nolign-1) =  func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(nolign-1),1)

 If find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))>0
  [M]ABLCPRO(nolign-1) = [M]NIVBLC(find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))-1)
 Endif

 If (find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))-1)>0
  If find([M]SECBLC(find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))-1),[M]CODSEC(0..[M]NBRSEC-1))>0
   [M]ASECPRO(nolign-1) = [M]NIVSEC(find([M]SECBLC(find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))-1),[M]CODSEC(0..[M]NBRSEC-1))-1)
  Else
   #Call ERREUR(mess(35,106,1)-":"- [M]SECBLC(find([M]BLCPRO(nolign-1),[M]CODBLC(0..[M]NBRBLC-1))-1)) From GESECRAN  : # SECTION inexistante
  Endif
 Else
  #Call ERREUR(mess(35,106,1)-":"- [M]BLCPRO(nolign-1)) From GESECRAN :#  Bloc inexistant
 Endif
 #[M:ASW4]CODCUR =  [ASWR]ALIAS

 #109787
 If find([M:ASW4]PARFILPRO(nolign-1),1,2)=0 : [M:ASW4]PARFILPRO(nolign-1)=1 : Endif
 If find([M:ASW4]PARENTPRO(nolign-1),1,2)=0 : [M:ASW4]PARENTPRO(nolign-1)=1 : Endif
 If find([M:ASW4]QRYPRO(nolign-1),1,2)=0 : [M:ASW4]QRYPRO(nolign-1)=1 : Endif
 If find([M:ASW4]DETPRO(nolign-1),1,2)=0 : [M:ASW4]DETPRO(nolign-1)=1 : Endif
 If find([M:ASW4]EDIPRO(nolign-1),1,2)=0 : [M:ASW4]EDIPRO(nolign-1)=1 : Endif
 If find([M:ASW4]TYPAFFPRO(nolign-1),1,2)=0 : [M:ASW4]TYPAFFPRO(nolign-1)=1 : Endif
 If find([M:ASW4]LOKPRO(nolign-1),1,2)=0 : [M:ASW4]LOKPRO(nolign-1)=1 : Endif
 If find([M:ASW4]SUMPRO(nolign-1),1,2)=0 : [M:ASW4]SUMPRO(nolign-1)=1 : Endif

Next
[M:ASW4]NBRPRO = nolign
Gosub SORTA_ASW4
nolign=SAVNOLIGN
Return

#------------------------------#
$LOAD_ASWK
Local Integer MES_OK
Local Integer MODIFSTDLNK : MODIFSTDLNK=0
If !VERROU : Gosub VERROU From GOBJET : Endif
If !VERROU
  [L]MODIFSTDLNK=-1
Endif
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
# links (ASHW6)
For [ASWK]ASWK0 Where CODREP=[M:ASW0]CODREP
   I=[M:ASW6]NBRLNK
   [M:ASW6]NBRLNK+=1
   nolign = [M:ASW6]NBRLNK
   [M:ASW6] = [ASWK]
   [M:ASW6]STDNEW(I)=1
   [M:ASW6]METLNK(I) = [F:ASWK]CODMETLNK+[F:ASWK]CODOPELNK
   [M:ASW6]IDENT2(I) = func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I))
   Call TEXTE([M:ASW6]INTLNK(I),[M:ASW6]INTITLNK(I)) From OBJDIV
   # load all link parameters/keys
   Call LOAD_PARLNK_ASW5(1,nomap,[M:ASW0]CODREP,[M:ASW1]CODCLA,[F:ASWK]CMPLNK,[F:ASWK]AFFLNK,[F:ASWK]ANCLNK,[F:ASWK]CODLNK, [F:ASWK]TYPLNK,
&         [F:ASWK]CLALNK, [F:ASWK]REPLNK, [F:ASWK]CLAPTRLNK, [F:ASWK]CODMETLNK+[F:ASWK]CODOPELNK+[F:ASWK]RPTCOD,
&         [F:ASWK]CODFNCLNK) From SUBASW_TOOL
Next

# In tab "Links", load only the link of anchor type "Proprerty" at first time since Anchor type "Property" is preselected
#GBIDI1=[M:ASW7]OPTINVLNK
#GBIDI2=[M:ASW7]OPTSTDLNK
#GBIDI3=[M:ASW7]TYPANCLNK
#GBIDC3=[M:ASW7]CODANCLNK
#GBIDC2=[M:ASW0]CODREP

If GBIDI3>0 & GBIDI3<6 : [M:ASW7]TYPANCLNK = GBIDI3 : Endif
If GBIDI2>0 & GBIDI2<3 : [M:ASW7]OPTSTDLNK = GBIDI2 : Endif
If GBIDI1>0 & GBIDI1<3 : [M:ASW7]OPTINVLNK = GBIDI1 : Endif
If GBIDC2=[M:ASW0]CODREP & [M:ASW7]CODANCLNK="" : [M:ASW7]CODANCLNK=GBIDC3 : Endif

If [M:ASW7]TYPANCLNK=0 : [M:ASW7]TYPANCLNK=1 : Endif
If [M:ASW7]OPTSTDLNK=0 : [M:ASW7]OPTSTDLNK=1 : Endif
If [M:ASW7]OPTINVLNK=0 : [M:ASW7]OPTINVLNK=1 : Endif
If find([M:ASW7]TYPANCLNK,1,2,3)
    Actzo [M:ASW7]CODANCLNK
Else
    Raz [M:ASW7]CODANCLNK
Endif

[M:ASW0]MODIFLNK=1
[M:ASW0]MODIFPAR=1

If [L]MODIFSTDLNK<>-1
  #On doit garder les [M:ASW0]MODIFPAR et [M:ASW0]MODIFLNK avant MAJ_STDLNK_ASW6
  If [L]MODIFSTDLNK=0 & [M:ASW0]MODIFLNK<>2
    If find(2,[M:ASW6]STDNEW)
      [L]MODIFSTDLNK=1
      [M:ASW0]MODIFLNK=2
    Endif
  Endif
  If [L]MODIFSTDLNK=0 & [M:ASW0]MODIFPAR<>2
    If find(2,[M:ASW5]STDNEW)
      [L]MODIFSTDLNK=1
      [M:ASW0]MODIFPAR=2
    Endif
  Endif
  Call TEMPON(mess(202,143,1)-[M:ASW0]CODREP) From GESECRAN
  Call MAJ_STDLNK_ASW6(0,1,nomap,[M:ASW0]CODREP,2) From SUBASWLNK
  Call TEMPOFF From GESECRAN
Else
  Call DISPLAY_LNK_ASW7(0,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK, [M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
Endif

nolign=SAVNOLIGN

If [L]MODIFSTDLNK=0 & [M:ASW0]MODIFLNK<>2
  If find(2,[M:ASW6]STDNEW)
    [L]MODIFSTDLNK=1
    [M:ASW0]MODIFLNK=2
  Endif
Endif
If [L]MODIFSTDLNK=0 & [M:ASW0]MODIFPAR<>2
  If find(2,[M:ASW5]STDNEW)
    [L]MODIFSTDLNK=1
    [M:ASW0]MODIFPAR=2
  Endif
Endif

Call AS_WNBLNK From SUBASW3
Return

#------------------------------#
$LOAD_ASWF
Local Integer I,J,K
Local Integer SAVNOLIGN : SAVNOLIGN=nolign

# Champ rep
nolign = 0 : I=0
For [ASWF]ASWF1 Where CODREP=[M:ASW0]CODREP
 nolign += 1
 [M:ASW9] = [F:ASWF]
 Call TEXTE([F:ASWF]INTFLD,[M:ASW9]AZINTFLD(nolign-1)) From OBJDIV
 Call TEXTE([F:ASWF]INTSHTFLD,[M:ASW9]AZINTSHTFLD(nolign-1)) From OBJDIV
# Call TEXTE([F:ASWF]INFBUL,[M:ASW9]INTITBUL(nolign-1)) From OBJDIV
 Read [ATY]CODTYP = [F:ASWF]CODTYP
 If !fstat
  [M:ASW9]FLDCUR = [ASWF]CODFLD
  If [ASWF]LOBTAB=""
   [M:ASW9]CODTYPCUR = [ASWF]CODTYP
  Else
   [M:ASW9]CODTYPCUR  = [ASWF]CODTYP + "." + [ASWF]LOBTAB + "." + [ASWF]LOBFLD
  Endif
  For [ASWP]ASWP0 Where CODREP=[M:ASW0]CODREP & TYPPAR=2 & TYPKEY=1 & CODFLD=[F:ASWF]CODFLD
   J=[M:ASW5]NBRPAR
   [M:ASW5]NBRPAR  +=1
   [M:ASW5]STDNEW(J)    = 1
   [M:ASW5]CODTYP(J)    = [F:ASWF]CODTYP
   [M:ASW5]CODPAR(J)    = [F:ASWP]CODPAR
   [M:ASW5]TYPPAR(J)    = [F:ASWP]TYPPAR
   [M:ASW5]CODFLD(J)    = [F:ASWP]CODFLD
   [M:ASW5]CODLNK(J)    = [F:ASWP]CODLNK
   [M:ASW5]AFFLNK(J)    = [F:ASWP]AFFLNK
   [M:ASW5]TYPKEY(J)    = [F:ASWP]TYPKEY
   [M:ASW5]VALEUR(J)    = [F:ASWP]VALEUR
   [M:ASW5]NUMPAR(J)    = [F:ASWP]NUMPAR
   [M:ASW5]TYPINTPAR(J) = [F:ASWP]TYPINT
   [M:ASW5]IDENT2(J)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(J),[M:ASW5]AFFLNK(J),[M:ASW5]TYPKEY(J),[M:ASW5]CODLNK(J),[M:ASW5]CODFLD(J),[M:ASW5]CODPAR(J))
  Next
  Call L_LOAD_PARAM_ATY(nomap, [M:ASW0]CODREP, [F:ATY]CODTYP, [ASW9]FLDCUR, 1, 1) From SUBASW2
  If [ATY]CODCLA<>""
   Gosub L_LOAD_KEY From SUBASW2
  Endif
  #97530
  J=0
  For I=0 To [M:ASW5]NBRPAR-1
   If [M:ASW5]CODFLD(I)=[M:ASW9]FLDCUR & [M:ASW5]TYPKEY(I)=2 & [M:ASW5]CODTYP(I)=[M:ASW9]CODTYPCUR
    J+=1
    K=I
   Endif
  Next
  If J=1 & [M:ASW5]VALEUR(K)=""
   [M:ASW5]VALEUR(K) = [M:ASW9]FLDGRP(nolign-1)+string$([M:ASW9]FLDGRP(nolign-1)<>"",".")+[M:ASW9]FLDCUR
#    [M:ASW9]VALCLE(0) = [M:ASW5]VALEUR(K)
#    Affzo [M:ASW9]VALCLE(0)
  Endif
  #
  If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   Gosub L_LOAD_MEDIA From SUBASW2
  Endif
  [M:ASW9]FLDCUR = ""
  [M:ASW9]CODTYPCUR = ""
 Endif
Next ASF
[M:ASW9]NBRFLD = nolign

nolign=SAVNOLIGN
Call AS_NBRFLD From SUBASW2
Return

#------------------------------#
$LOAD_ORG
Local Integer SAVNOLIGN : SAVNOLIGN=nolign

[M:ASW2]NBRSEC=0
nolign = 0
For [ASWS] Where CODREP=[M:ASW0]CODREP
  nolign += 1
  [M:ASW2] = [F:ASWS]
  Call TEXTE([M:ASW2]INTSEC(nolign-1),[M:ASW2]AZINTSEC(nolign-1)) From OBJDIV
Next
[M:ASW2]NBRSEC=nolign

[M:ASW2]NBRBLC=0
nolign = 0
For [ASWB] Where CODREP=[M:ASW0]CODREP
  nolign += 1
  [M:ASW2] = [F:ASWB]
  Call TEXTE([M:ASW2]INTBLC(nolign-1),[M:ASW2]AZINTBLC(nolign-1)) From OBJDIV
  If find([M]SECBLC(nolign-1),[M]CODSEC(0..[M]NBRSEC-1))>0
   [M]ANIVSEC(nolign-1) = [M]NIVSEC(find([M]SECBLC(nolign-1),[M]CODSEC(0..[M]NBRSEC-1))-1)
  Endif
Next
[M:ASW2]NBRBLC=nolign

# On met dans le bon ordre
Gosub SORTA_ASW2
nolign=SAVNOLIGN


Return


#--------------------------------#
$LOAD_ASWMN
 Local Integer SAVNOLIGN : SAVNOLIGN=nolign
 # Menus
 nolign = 0
 For [ASWMN] Where CODREP=[M:ASW0]CODREP
  nolign += 1
  [M:ASW8] = [ASWMN]
  Call TEXTE([F:ASWMN]LIBMENU,[M:ASW8]ZLIBMENU(nolign-1)) From OBJDIV
 Next
 [M:ASW8]NBMENU = nolign
 nolign=SAVNOLIGN
Return

#--------------------------------#
$LOAD_CONFIG
Local Integer I,J
For I=0 To [M]NBCONFIG-1
  If [M:ASW8]DEFLNKFAC(I)<>2
   [M:ASW8]DEFLNKFAC(I)=1
  Endif
  If [M:ASW8]AFFLNKFAC(I)=0
   Effzo [M:ASW8]LIBAFFLNK(I)
   J = find([M:ASW8]LNKMENFAC(I), [M:ASW8]CODMENU)
   If J>0
    [M:ASW8]LIBLNKMEN(I) = [M:ASW8]ZLIBMENU(J-1)
    Affzo [M:ASW8]LIBLNKMEN(I)
   Endif
  Else
   [M:ASW8]LIBAFFLNK(I)=mess([M:ASW8]AFFLNKFAC(I),7965,1)
   Affzo [M:ASW8]LIBAFFLNK(I)
   J = find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW8]AFFLNKFAC(I),"",[M:ASW8]LNKMENFAC(I)),[M:ASW6]IDENT2)
   If J>0
    [M:ASW8]LIBLNKMEN(I) = [M:ASW6]INTITLNK(J-1)
    Affzo [M:ASW8]LIBLNKMEN(I)
   Endif
  Endif
Next I
Return

#--------------------------------#
$LIENS
# case where ATB was closed by the jump in GESATB or GESAVW
If !clalev([F:ATB]) : Local File AVIEWTAB [ATB] : Endif
If !clalev([F:ATZ]) : Local File AVIEWFLD [ATZ] : Endif
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif

Local Integer I,J
Raz GFLAG
WAFCRIGHT=[F:ASW]AFCRIGHT
Call TEXTE([F:ASW]INTREP,[M:ASW0]AZINTREP) From OBJDIV
Local Integer I
[M]NBRFAC= len(mess(0,7964,1))
For I=0 To [M]NBRFAC-1
   [M:ASW1]CODFAC(I)=I+1
Next
[M]NBRCOM= len(mess(0,7968,1))
For I=0 To [M]NBRCOM-1
   [M:ASW1]CODCOM(I)=I+1
   If [M:ASW1]CODCOM(I)=4 & [M:ASW1]ENACOM(I)=2
    [M:ASW1]ENACOM(I)=1
   Endif
   If [M:ASW1]ENACOM(I)=0
    [M:ASW1]ENACOM(I)=1
   Endif
Next
[M]NBCONFIG= len(mess(0,7964,1))

If [M:ASW1]TYPMSKREP<>1
 Effzo [M:ASW1]FONCTION : Grizo [M:ASW1]FONCTION
Else
 Actzo [M:ASW1]FONCTION
Endif

Read [F:ACLA]ACLA0 = [M:ASW1]CODCLA
If !fstat
 Read [ATB]CODFIC = [F:ACLA]TABREF
 If !fstat
  If [F:ATB]ISTABLE=2
   [M:ASW1]ISTABLE = 2
  Else
   [M:ASW1]ISTABLE = 1
  Endif
 Endif
 If [F:ACLA]TYPCLA=5 : [M:ASW1]ISTABLE = 3 : Endif
Endif

If GADONIX<>2
 Grizo [M:ASW1]FLGSYSTEM
Else
 Actzo [M:ASW1]FLGSYSTEM
 Affzo [M:ASW1]FLGSYSTEM
Endif


# Collections
Gosub LOAD_ASWC
# Options
Gosub LOAD_ASWO
# Sections+Bloc
Gosub LOAD_ORG
# Méthodes
Gosub LOAD_ASWM
# Propriétés
Gosub LOAD_ASWF
# Propriétés exposées
Gosub LOAD_ASWR
# Liens
Gosub LOAD_ASWK
# Menus
Gosub LOAD_ASWMN
# CONFIG après menus/lnk
Gosub LOAD_CONFIG

Return


#--------------------------------#
$MODIF
Delete [ASWF] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWFLD"-CLECUR1 : Return
Endif
Delete [ASWP] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWPAR"-CLECUR1 : Return
Endif
Delete [ASWM] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWMET"-CLECUR1 : Return
Endif
Delete [ASWMP] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWPARMET"-CLECUR1 : Return
Endif
Delete [ASWO] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWOPT"-CLECUR1 : Return
Endif
Delete [ASWC] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWCOL"-CLECUR1 : Return
Endif
Delete [ASWS] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWSEC"-CLECUR1 : Return
Endif
Delete [ASWB] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWBLC"-CLECUR1 : Return
Endif
Delete [ASWR] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWEXPPRO"-CLECUR1 : Return
Endif
Delete [ASWK] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWLNK"-CLECUR1 : Return
Endif
Delete [ASWMN] Where CODREP=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ASHWMENU"-CLECUR1 : Return
Endif
Gosub CREATION
Return

#--------------------------------#
$CREATION
Gosub SORTA_ASW2
Gosub SORTA_ASW3
Gosub SORTA_ASW4
Gosub SORTA_ASW5
Gosub SORTA_ASW6
Gosub CRE_ASWO
If GOK<1 : Return : Endif
Gosub CRE_ASWC
If GOK<1 : Return : Endif
Gosub CRE_ASWF
If GOK<1 : Return : Endif
Gosub CRE_ASWM
If GOK<1 : Return : Endif
Gosub CRE_ORG
If GOK<1 : Return : Endif
Gosub CRE_ASWR
If GOK<1 : Return : Endif
Gosub CRE_ASWK
If GOK<1 : Return : Endif
Gosub CRE_ASWMN
If GOK<1 : Return : Endif
Return

#------------------------------#
$CRE_ASWC
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
For nolign=1 To [M:ASW1]NBRCOL
 Raz [F:ASWC]
 [F:ASWC]CODREP  = [M:ASW0]CODREP
 [F:ASWC]        = [M:ASW1]
 Write [F:ASWC]
 If fstat
  GOK = 0 : Call FSTA("ASWC") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
Return

$CRE_ASWO
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
For nolign=1 To [M:ASW2]NBROPT
  Raz [F:ASWO]
  [F:ASWO]CODREP = [M:ASW0]CODREP
  If [M:ASW2]OPTFLGCLA(nolign-1)=2
    [F:ASWO]OPTFLGCLA = [M:ASW2]OPTFLGCLA(nolign-1)
    [F:ASWO]OPTCOD = [M:ASW2]OPTCOD(nolign-1)
  Else
    [F:ASWO] = [M:ASW2]
  Endif
  [F:ASWO]OPTOBY = [M:ASW2]OPTOBY(nolign-1)
  [F:ASWO]OPTDEF = [M:ASW2]OPTDEF(nolign-1)
  Write [ASWO]
  If fstat
   GOK=0 : Call FSTA("ASWO") From GLOCK : Break
  Endif
Next
nolign=SAVNOLIGN
Return

$CRE_ASWF
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer NOLPAR,J,WCPT
Local Integer OKLIS
# Champs rep
For J=0 To [M:ASW9]NBRFLD-1
  Raz [F:ASWF]
  nolign=J+1
  [F:ASWF] = [M:ASW9]
  [F:ASWF]CODREP = [M:ASW0]CODREP
  Write [ASWF]
  If fstat
   GOK = 0 : Call FSTA("ASWF") From GLOCK : Break
  Endif
  [L]WCPT=0
  [L]OKLIS=0
  Read [ATY]CODTYP=[F:ASWF]CODTYP
  If !fstat & [F:ATY]TYPPROSYR<>""
   Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
   If !fstat & [F:ATYP]LISFLG=2
    [L]OKLIS=1
   Endif
  Endif
  For NOLPAR=0 To [M:ASW5]NBRPAR-1
   If [M:ASW5]TYPPAR(NOLPAR)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]ISKEY(NOLPAR)<>2
    Raz [F:ASWP]
    [L]WCPT+=1
    nolign=NOLPAR+1
    [F:ASWP]       = [M:ASW5]
    [F:ASWP]CODREP = [M:ASW0]CODREP
    [F:ASWP]NUMPAR = [L]WCPT
    [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(NOLPAR)
    If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
    If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
    Write [F:ASWP]
    If fstat
     GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
    Endif
   Elsif [L]OKLIS & [M:ASW5]TYPPAR(NOLPAR)=2 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]CODTYP(NOLPAR)=[F:ASWF]CODTYP
    Raz [F:ASWP]
    nolign=NOLPAR+1
    [F:ASWP]       = [M:ASW5]
    [F:ASWP]CODREP = [M:ASW0]CODREP
    [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(NOLPAR)
    Write [F:ASWP]
    If fstat
     GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
    Endif
   Endif
  Next
  For NOLPAR=0 To [M:ASW5]NBRPAR-1
   If [M:ASW5]TYPPAR(NOLPAR)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]ISKEY(NOLPAR)=2
    Raz N
    For M=0 To [M:ASW5]NBRPAR-1
     If [M:ASW5]TYPPAR(M)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(M) & [M:ASW5]TYPKEY(M)=2
&     &  [M:ASW5]CODPAR(NOLPAR) = [M:ASW5]CODPAR(M)
      N = M
     Endif
    Next
    If N>0
     Raz [F:ASWP]
     [L]WCPT+=1
     nolign=N+1
     [F:ASWP]       = [M:ASW5]
     [F:ASWP]CODREP = [M:ASW0]CODREP
     [F:ASWP]TYPKEY = 1
     [F:ASWP]NUMPAR = [L]WCPT
     [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(N)
     If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
     If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
     Write [F:ASWP]
     If fstat
      GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Next
Next nolign
nolign=SAVNOLIGN
Return

$CRE_ASWM
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer I
# methodes /parametres
For nolign=1 To [M:ASW3]NBRMET
 Raz [F:ASWM]
 [F:ASWM]CODREP  = [M:ASW0]CODREP
 [F:ASWM]NOMET   = nolign
 [F:ASWM]        = [M:ASW3]
 Write [ASWM]
 If fstat
  GOK = 0 : Call FSTA("ASWM") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
If GOK<1 : Return : Endif
For I=0 To [M]WNBRPARMET-1
 If [M:ASW3]WCODMET(I) = "" : Break : Endif
 Raz [ASWMP]
 [ASWMP]CODREP     = [M:ASW0]CODREP
 [ASWMP]CODMET     = [M]WCODMET(I)
 [ASWMP]CODPARMET  = [M]WCODPARMET(I)
 [ASWMP]NOPARMET   = [M]WNOPARMET(I)
 [ASWMP]DIMPARMET  = [M]WDIMPARMET(I)
 [ASWMP]TYPPARMET  = [M]WTYPPARMET(I)
 [ASWMP]INTPARMET  = [M]WINTPARMET(I)
 [ASWMP]CLAPARMET  = [M]WCLAPARMET(I)
 [ASWMP]MODPARMET  = [M]WMODPARMET(I)
 Write [ASWMP]
 If fstat
  GOK = 0 : Call FSTA("ASWMP") From GLOCK : Break
 Endif
Next I
Return

$CRE_ORG
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
# Champ Organisation

 For nolign=1 To [M:ASW2]NBRSEC
  Raz [F:ASWS]
  [F:ASWS] = [M:ASW0]
  [F:ASWS] = [M:ASW2]
  Write [F:ASWS]
  If fstat
   GOK=0 : Call FSTA("ASWS") From GLOCK : Break
  Endif
 Next

nolign=SAVNOLIGN
If GOK<1 : Return : Endif

 For nolign=1 To [M:ASW2]NBRBLC
  Raz [F:ASWB]
  [F:ASWB] = [M:ASW0]
  [F:ASWB] = [M:ASW2]
  Write [F:ASWB]
  If fstat
   GOK=0 : Call FSTA("ASWB") From GLOCK : Break
  Endif
 Next
nolign=SAVNOLIGN
Return

$CRE_ASWR
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
# Propriété visible

For nolign=1 To [M:ASW4]NBRPRO
 Raz [F:ASWR]
 [F:ASWR]CODREP  = [M:ASW0]CODREP
 [F:ASWR]        = [M:ASW4]
 #X3-100791
 If dim([F:ASWR]ISMASKABLE)>0 and [F:ASWR]ISMASKABLE=0
  [F:ASWR]ISMASKABLE=1
 Endif
 #End X3-100791
 # Issue X3-110075 - 2018-10-02 by ALSHE : to avoid issue when updating integration branch (see X3-100791)
 If dim([F:AMZ]BREAKAFTER)>0 and [F:AMZ]BREAKAFTER=0
  [F:AMZ]BREAKAFTER=1
 Endif
 # End issue X3-110075
 [F:ASWR]NUMPRO  = nolign
 Write [ASWR]
 If fstat
  GOK = 0 : Call FSTA("ASWR") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
Return

$CRE_ASWK
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer NOLPAR,J,WCPT
# links (screen ASW6)
For J=0 To [M:ASW6]NBRLNK-1
 Raz [F:ASWK]
 [F:ASWK]CODREP    = [M:ASW0]CODREP
 nolign=J+1
 [F:ASWK]          = [M:ASW6]
 [F:ASWK]NUMLNK    = J+1
 Case [F:ASWK]TYPLNK
  When 2 : [F:ASWK]CODMETLNK = [M:ASW6]METLNK(J)  : # Méthode
  When 3 : [F:ASWK]CODOPELNK = [M:ASW6]METLNK(J)  : # Opération
 Endcase
 [F:ASWK]ORDTECLNK=func SUBASW_TOOL.BUILD_ASWK_ORDTECLNK
 Write [ASWK]
 If fstat
  GOK = 0 : Call FSTA("ASWK") From GLOCK : Break
 Endif
 [L]WCPT=0
For NOLPAR=0 To [M:ASW5]NBRPAR-1
   If [M:ASW5]TYPPAR(NOLPAR)=3 & [F:ASWK]AFFLNK=[M:ASW5]AFFLNK(NOLPAR) & [F:ASWK]CODLNK=[M:ASW5]CODLNK(NOLPAR) & [F:ASWK]ANCLNK=[M:ASW5]CODFLD(NOLPAR)
    Raz [F:ASWP]
    [L]WCPT+=1
    nolign=NOLPAR+1
    [F:ASWP]       = [M:ASW5]
    [F:ASWP]CODREP = [M:ASW0]CODREP
    [F:ASWP]NUMPAR = [L]WCPT
    [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(NOLPAR)
    If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
    If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
    Write [F:ASWP]
    If fstat
     GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
    Endif
   Endif
 Next NOLPAR
Next J
nolign=SAVNOLIGN
Return

$CRE_ASWMN
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
For nolign=1 To [M:ASW8]NBMENU
 Raz [F:ASWMN]
 [F:ASWMN]CODREP  = [M:ASW0]CODREP
 [F:ASWMN]        = [M:ASW8]
 Write [F:ASWMN]
 If fstat
  GOK = 0 : Call FSTA("ASWMN") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
Return

#--------------------------------------------#
$AP_ANNULE
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Call DELETE_ALLSTC([L]APPLI,[L]CODE) From ASHWVALSUB
Return


#----------------------------------------#
$APRES_CRE
  Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
  WAFCRIGHT=[M:ASW1]AFCRIGHT
$APRES_MOD
  If WAFCRIGHT<>[M:ASW1]AFCRIGHT
   Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
  Endif
# On affiche tout bien à la fin
  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS
  Endif
  If !GIMPORT
    Affzo [ASW1]
    Affzo [ASW3]
    Affzo [ASW9]
    Affzo [ASW2]
    Affzo [ASW4]
    Affzo [ASW7]
  Endif
Return

#----------------------------------------#
$VERIF_FACETTE
Local Char L_ERR_MSG(250)
Local Integer L_OK,I,J,K,FAC_OK,MAJ_STDLNK
# Warning: At least, one facette must be activated
If find(2,[M:ASW1]ENAFAC)=0
   Call ERREUR(mess(219,143,1),-1,[L]ERRMES,[L]ERRFLG)
Endif
# Check that when a facette is activated for the representation,
# there's at least one Property enabled for this facette
For I = 0 To [M:ASW1]NBRFAC-1
 If [M:ASW1]ENAFAC(I)=2
  L_OK = 0
  Case [M:ASW1]CODFAC(I)
   When 1 :    # Detail
     L_OK=find(2,[M:ASW4]DETPRO)
#     If L_OK>0
#      Read [ACLAT]ACLAT0 = [M:ASW1]CODCLA;"R"
#      If fstat or (!fstat & [F:ACLAT]ENAMETSTD<>2)
#       [M:ASW1]ENAFAC(I) =1
#       MAJ_STDLNK = 1
#       L_OK = 1
#      Endif
#     Endif
   When 2 :    # Edit
     L_OK=find(2,[M:ASW4]EDIPRO)
#     If L_OK>0
#      Read [ACLAT]ACLAT0 = [M:ASW1]CODCLA;"C"
#      If fstat or (!fstat & [F:ACLAT]ENAMETSTD<>2)
#       [M:ASW1]ENACOM(0) =1
#       MAJ_STDLNK = 1
#       L_OK = 1
#      Endif
#      Read [ACLAT]ACLAT0 = [M:ASW1]CODCLA;"R"
#      If fstat or (!fstat & [F:ACLAT]ENAMETSTD<>2)
#       [M:ASW1]ENACOM(1) =1
#       [M:ASW1]ENACOM(2) =1
#       MAJ_STDLNK = 1
#       L_OK = 1
#      Endif
#       Read [ACLAT]ACLAT0 = [M:ASW1]CODCLA;"U"
#      If fstat or (!fstat & [F:ACLAT]ENAMETSTD<>2)
#       [M:ASW1]ENACOM(1) =1
#       [M:ASW1]ENACOM(2) =1
#       MAJ_STDLNK = 1
#       L_OK = 1
#      Endif
#     Endif
   When 3 :   # Query
     L_OK=find(2,[M:ASW4]QRYPRO)
   When 4 :    # Lookup
     L_OK=find(2,[M:ASW4]LOKPRO)
   When 5 :    # Summary
     L_OK=find(2,[M:ASW4]SUMPRO)
#     If L_OK>0
#      Read [ACLAT]ACLAT0 = [M:ASW1]CODCLA;"R"
#      If fstat or (!fstat & [F:ACLAT]ENAMETSTD<>2)
#       [M:ASW1]ENAFAC(I) =1
#       MAJ_STDLNK = 1
#       L_OK = 1
#      Endif
#     Endif
  Endcase
  If L_OK = 0
   # Pour activer la facette $1$, il faut au moins une propriété exposée cochée $2$
   Call ERREUR(func AFNC.MES2(mess(109,143,1), mess([M:ASW1]CODFAC(I),7964,1),mess([M:ASW1]CODFAC(I),7964,1)),1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif
Next
#If MAJ_STDLNK
# Gosub MAJ_STDLNK_FCT_2 From SUBASW
#Endif

For K = 0 To [M:ASW8]NBCONFIG-1
 FAC_OK=0
 I=0 : OK_LNK=0
 If [M:ASW8]LNKMENFAC(K) <> ""
  # Check if it's a Menu
  If [M:ASW8]AFFLNKFAC(K)=0
   I = find([M:ASW8]LNKMENFAC(K), [M:ASW8]CODMENU)
   If I>0 & [M:ASW8]PARMENU(I-1)=""
    FAC_OK = 1
   Endif
  Endif
  If !FAC_OK & I=0
   # Check if it's a Page link
   If [M:ASW8]AFFLNKFAC(K)<>0
     J = find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW8]AFFLNKFAC(K),"",[M:ASW8]LNKMENFAC(K)),[M:ASW6]IDENT2)
     If J>0
      FAC_OK=func SUBASW3.IS_LNKMENFAC_OK(K+1,J-1)
     Endif
   Endif
  Endif

  If !FAC_OK
   L_ERR_MSG = func AFNC.MES1(mess(230,143,1), mess(K+1,7964,1))-":"-mess(227,143,1) :# Il faut indiquer un code lien valide pour la facette ou un code menu
   Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif
Next
Return

#----------------------------------------#
$VERIF_ASWC
Local Integer ICOL
# check that there's no same code for collection and property
For ICOL=0 To [M:ASW1]NBRCOL-1
 If find([M:ASW1]CODCOL(ICOL), [M:ASW9]CODFLD)
  # Code déjà utilisé pour une propriété ou une collection.
  Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP")-[M:ASW1]CODCOL(ICOL)-":"-mess(146,143,1),1,[L]ERRMES,[L]ERRFLG)
 Endif

 If [M:ASW1]ALIASCOL(ICOL)=""
  # Alias obligatoire
  Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP")-[M:ASW1]CODCOL(ICOL)-":"-mess(169,143,1),1,[L]ERRMES,[L]ERRFLG)
 Endif

 #verification collection existante
 If instr(1,[M:ASW1]CODCOL(ICOL),".")<>0
  Gosub CHARGE_GRP2 From SUBASW2
  If !find([M:ASW1]CODCOL(ICOL),TEX)
   # # Collection inexistante
   Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP")-[M:ASW1]CODCOL(ICOL)-":"-mess(144,143,1),1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif
Next
Return

#----------------------------------------#
$VERIF_ASWO
Local Integer I
Local Char L_ERR_MSG(250)
# check options
For I=0 To [M:ASW2]NBROPT-1
 If [M:ASW2]OPTFLGCLA(I)=2
  Read [ACLAO]ACLAO0=[M:ASW1]CODCLA;[M:ASW2]OPTCOD(I)
  If fstat
    Call ERREUR(func AFNC.MES2(mess(147,143,1), [M:ASW2]OPTCOD(I), [M:ASW1]CODCLA ),1,[L]ERRMES,[L]ERRFLG)
  ELSEASHWQRTY
    If [F:ACLAO]OPTCND=""
      # Filtre xxx Erreur zone "" : Zone obligatoire
      L_ERR_MSG=mess(245,143,1)-[M:ASW2]OPTCOD(I)-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW2","OPTCND")+'"'
      Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
    Elsif func SUBASW2.CONTROL_SDATA([F:ACLAO]OPTCND,L_ERR_MSG)=0
     Call ERREUR(mess(245,143,1)-[F:ACLAO]OPTCOD-":"-L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
  Endif
 Else
  If [M:ASW2]OPTCND(I)=""
    # Filtre xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(245,143,1)-[M:ASW2]OPTCOD(I)-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW2","OPTCND")+'"'
    Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
  Elsif func SUBASW2.CONTROL_SDATA([M:ASW2]OPTCND(I),L_ERR_MSG)=0
   Call ERREUR(mess(245,143,1)-[M:ASW2]OPTCOD(I)-":"-L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif
Next

# Verification que chaque element de l'index est bien présent en query
# 115234 CCL Representation sort order control validation
Local Char WCODIND(250),WDESCRIPT(250)
Raz CHAINE
If [M:ASW2]CODIND="" and [M:ASW2]DESCRIPT=""
 Read [F:ACLA]ACLA0 = [M:ASW1]CODCLA
 If !fstat
  If [M:ASW2]CODIND=""
   WCODIND = [F:ACLA]TABREF
  Endif
  If WCODIND = "" and [M:ASW2]DESCRIPT<>""
   WDESCRIPT = [F:ACLA]KEYINT
  Endif
 Endif
Else
 WCODIND = [M:ASW2]CODIND
 WDESCRIPT = [M:ASW2]DESCRIPT
Endif
If [L]WCODIND<>"" or WDESCRIPT<>""
 If [L]WCODIND<>""
  If [M:ASW2]ADESIND<>""
   CHAINE = [M:ASW2]ADESIND
  Else
   Read [ATI]CODIND=[M]TABREF;[M:ASW2]CODIND
   If !fstat
    CHAINE=[ATI]DESCRIPT
   Endif
  Endif
 Else
  CHAINE = [L]WDESCRIPT
 Endif
 Local Integer NBKEYS
 Local Char    KEYS(GLONAVB)(1..),ORDS(5)(1..),CHAINE(250),WPRO(80)
 If [L]WCODIND<>""
  CHAINE = [M:ASW2]ADESIND
 Else
  CHAINE = [L]WDESCRIPT
 Endif
 Call SETCLEORDER([L]NBKEYS,[L]KEYS,[L]ORDS,CHAINE) From LNKSUB
 For J=1 To [L]NBKEYS
  WPRO = [M:ASW1]ABRCLA+"."+[L]KEYS(J)
  K = find(WPRO,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
  If K<1 or  [M:ASW4]QRYPRO(K-1)<>2
   Call ERREUR(func AFNC.MES2(mess(273,143,1),WPRO,CHAINE),1,[L]ERRMES,[L]ERRFLG)
  Endif
 Next
Endif

Return

#----------------------------------------#
$VERIF_ASWP
Call VERIF_PARAM_ASW5(1,[M:ASW0]CODREP,1,1,ERRMES,ERRFLG) From SUBASW_TOOL
Return

#----------------------------------------#
$VERIF_REP
# verify that there's no more than one representation defined as "Search" for the same class
#If [M:ASW1]TYPMSKREP<>1 : [M:ASW1]DEFREP=1 : Endif
Read [F:ACLAT]ACLAT0=[M:ASW1]CODCLA;"R"
If fstat or (!fstat and [F:ACLAT]ENAMETSTD<>2)
 Call ERREUR(func AFNC.MES1(mess(92,140,1),[M:ASW1]CODCLA) ,1,[L]ERRMES,[L]ERRFLG)
Endif
If [M:ASW1]TYPMSKREP<>1 & [M:ASW1]FONCTION<>""
   Call ERREUR(func AFNC.MES1(mess(252,143,1), mess([M:ASW1]TYPMSKREP,7963,1))-":"-mess(253,143,1),1,[L]ERRMES,[L]ERRFLG)
Endif
If [M:ASW1]DEFREP = 2
 Filter [L_ASW] Where CODCLA = [M:ASW1]CODCLA & CODREP <> [M:ASW0]CODREP
 For [L_ASW]
  If [L_ASW]DEFREP = 2 & [L_ASW]TYPMSKREP = [M:ASW1]TYPMSKREP & [L_ASW]TYPREP = [M:ASW1]TYPREP
   Call ERREUR(func AFNC.MES2(mess(139,143,1), [L_ASW]CODCLA, [L_ASW]CODREP),1,[L]ERRMES,[L]ERRFLG)
  Endif
 Next
 Filter [L_ASW]
Endif
#100106 For non system representations, the authorization function is now mandatory
#101282 Make the authorization function not mandatory
#If [M:ASW1]FLGSYSTEM<>2 & [M:ASW1]AFCRIGHT=""
# Call ERREUR(mess(282,143,1),1,[L]ERRMES,[L]ERRFLG)
#Endif
If [M]INTREP=0
 Call ERREUR(mess(30,109,1)-":"-mess(10,123,1) ,1,[L]ERRMES,[L]ERRFLG) From SUBASW
Endif
Return

#----------------------------------------#
$VERIF_ASWR
Local Integer I,J,FLG_OK,FLG_HAS_ERROR
Local Char L_ERR_MSG(250)
Local Char L_BLC_STD(250), L_COL_CUR(250),L_COL_CUR2(250), L_COL_PRO(250)
Local Char    TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50)
Local Integer NBCLA,ISACTX,WTYPCLA
If !clalev([F:ATB]) : Local File AVIEWTAB [ATB] : Endif

Read [F:ACLA]ACLA0 = [M:ASW1]CODCLA
If !fstat
 WTYPCLA = [F:ACLA]TYPCLA
Endif

For I=0 To [M:ASW4]NBRPRO-1

 Call DECODE_PRO([M:ASW4]CODPRO(I),2,"PRO",nomap,[M:ASW0]CODREP,[M:ASW1]ABRCLA,[M:ASW1]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA<=0
   #Propriété ou collection inexistante
   L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(56,140,1)-[M:ASW4]CODPRO(I)
   Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
 Endif

 #90233
 If I>0
  For J=0 To I-1
   If [M:ASW4]CODPRO(I)=[M:ASW4]CODPRO(J)
    L_ERR_MSG = func AFNC.MES1( mess(239,143,1),[M:ASW4]ALIAS(J)) : # Le code propriété est déjà utilisé sur l'alias "$1$"
    L_ERR_MSG = mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-"/"-[M:ASW4]CODPRO(I)-":"-L_ERR_MSG
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
   Endif
  Next
 Endif

 If [M:ASW4]INTPRO(I)=0
    # Propriété exposée xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW4","AZINTPRO")+'"'
    Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
 Endif
 If [M:ASW4]INTSHTPRO(I)=0
    # Propriété exposée xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW4","AZINTSHTPRO")+'"'
    Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
 Endif

 #Check UOMPRO
 If [M:ASW4]UOMPRO(I)<>""
  If find([M:ASW4]CODPROTYP(I),2,3,4,5,6)=0
    # Propriété exposée xxx : La propriété unité doit être indiquée uniquement sur les propriétés numériques
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(242,143,1)
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
  Endif
  J=find([M:ASW4]UOMPRO(I),[M:ASW4]CODPRO)
  If J>0
   If func SUBASW.IS_ATY_UNIT([M:ASW4]CODPROATY(J-1))=0
    # Propriété exposée xxx : La propriété "$1$" ne correspond pas à une unité
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-func AFNC.MES1(mess(241,143,1), [M:ASW4]UOMPRO(I))
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
   Elsif ([M:ASW4]QRYPRO(I)=2 & [M:ASW4]QRYPRO(J-1)<>2)
&      | ([M:ASW4]DETPRO(I)=2 & [M:ASW4]DETPRO(J-1)<>2)
&      | ([M:ASW4]EDIPRO(I)=2 & [M:ASW4]EDIPRO(J-1)<>2)
&      | ([M:ASW4]LOKPRO(I)=2 & [M:ASW4]LOKPRO(J-1)<>2)
&      | ([M:ASW4]SUMPRO(I)=2 & [M:ASW4]SUMPRO(J-1)<>2)
    # Propriété exposée xxx : La propriété unité doit être présente sur les mêmes facettes
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(243,143,1)
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
   Endif
  Else
    # Propriété exposée xxx : YYY Veuillez indiquer une propriété exposée
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-[M:ASW4]UOMPRO(I)-mess(170,143,1)
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif

 If [M:ASW4]TYPAFFPRO(I)=2
  If [M:ASW4]CODPROATY(I)<>""
   Read [ATY]CODTYP=[M:ASW4]CODPROATY(I)
   If !fstat & [F:ATY]FMTPROSYR=6
    # Propriété exposée xxx : YYY Ce type de données ne peut pas être saisissable
    L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-[M:ASW4]CODPROATY(I)-mess(251,143,1)
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
   Endif
  Endif
 Endif

 #Check QRYPRO
 L_COL_CUR=[M:ASW4]FLDGRPPRO(I)
 If L_COL_CUR<>"" & [M:ASW4]QRYPRO(I)=2
    FLG_OK=1
    Call CONTROLE_QRYPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(I),[M:ASW4]CODPRO(I),L_COL_CUR,[M:ASW1]CODCLA,[M]ABRCLA,FLG_OK,L_ERR_MSG) From SUBASW2
    If !FLG_OK
      # PROPRIÉTÉ EXPOSÉE XXX / YYY
       # Collection de dimensionnement non autorisée en query
       # Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en query
      L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-"/"-[M:ASW4]CODPRO(I)-":"-L_ERR_MSG
      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
    Endif
 Endif

 #Check LOKPRO
 L_COL_CUR=[M:ASW4]FLDGRPPRO(I)
 If L_COL_CUR<>"" & [M:ASW4]LOKPRO(I)=2
    FLG_OK=1
    Call CONTROLE_LOKPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(I),[M:ASW4]CODPRO(I),L_COL_CUR,[M:ASW1]CODCLA,[M]ABRCLA,FLG_OK,L_ERR_MSG) From SUBASW2
    If !FLG_OK
      # PROPRIÉTÉ EXPOSÉE XXX / YYY
       # Collection de dimensionnement non autorisée en lookup
       # Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en lookup
      L_ERR_MSG=mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-"/"-[M:ASW4]CODPRO(I)-":"-L_ERR_MSG
      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
    Endif
 Endif


 #Check EDIPRO if classe based on a view
 If [M:ASW4]EDIPRO(I)=2 & WTYPCLA=2 & [M:ASW1]ISTABLE<>2
  L_ERR_MSG = mess(95,140,1) : # Facette Edit non compatible avec l'utilisation d'une vue.
  L_ERR_MSG = mess(35,140,1)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"-"/"-[M:ASW4]CODPRO(I)-":"-L_ERR_MSG
  Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
 Endif

 # check that the properties of the same collection are in the same block
 FLG_HAS_ERROR=0
 L_COL_CUR=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(I),0)
 L_BLC_STD = [M:ASW4]BLCPRO(I)
 If L_COL_CUR<>""
   For J=I+1 To [M:ASW4]NBRPRO-1
    If instr(1,[M:ASW4]CODPRO(J),".")
     [L]L_COL_CUR2=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(J),0)
     If [L]L_COL_CUR=[L]L_COL_CUR2
        If [M:ASW4]BLCPRO(J) <> L_BLC_STD
          # Les propriétés exposées appartenant à la même collection $1$ doivent être définies dans le même bloc
          L_ERR_MSG=func AFNC.MES1( mess(165,143,1),L_COL_CUR)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"+"/"+[M:ASW4]BLCPRO(I)-[M:ASW4]ALIAS(J)+"/"+[M:ASW4]BLCPRO(J)
          Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
        Endif
     Elsif pat([L]L_COL_CUR2,[L]L_COL_CUR+'.*')<>0
        If [M:ASW4]BLCPRO(J) <> L_BLC_STD
          # Les propriétés exposées appartenant à la même collection $1$ doivent être définies dans le même bloc
          L_ERR_MSG=func AFNC.MES1( mess(165,143,1),L_COL_CUR)-[M:ASW4]ALIAS(I)-"("+mess(3,40,1)-num$(I+1)+")"+"/"+[M:ASW4]BLCPRO(I)-[M:ASW4]ALIAS(J)+"/"+[M:ASW4]BLCPRO(J)
          Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
        Endif
     Endif
    Endif
   Next
 Endif

Next
Return


#----------------------------------------#
$VERIF_ASWF
Local Char L_ERR_MSG(250)
Local Integer I
# 1 loop on each property and check
For I=0 To [M:ASW9]NBRFLD-1
 If [M:ASW9]INTFLD(I)=0
    # Propriété xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW9","AZINTFLD")+'"'
    Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
 Endif
  If find([M:ASW9]CODFLD(I), [M:ASW3]CODMET)
  # Code déjà utilisé pour une méthode ou une opération
  Call ERREUR(mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(290,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif
 If [M:ASW9]INTSHTFLD(I)=0
    # Propriété xxx Erreur zone "" : Zone obligatoire
    L_ERR_MSG=mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ASHW9","AZINTSHTFLD")+'"'
    Call ERREUR(L_ERR_MSG-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG)
 Endif
 #Check ATYPE & LOBTAB+LOBFLD
 Read [ATY]CODTYP=[M:ASW9]CODTYP(I)
 If [F:ATY]TYPSELSYR=3 & [F:ATY]TYPPROSYR=""
    #Le prototype est obligatoire pour utiliser un type de données Rich media
    Call ERREUR(mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(249,143,1),1,[L]ERRMES,[L]ERRFLG)
 Elsif [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   If [M:ASW9]LOBTAB(I)="" | [M:ASW9]LOBFLD(I)=""
    #La table et le champ du lob sont obligatoires pour un type de données Rich media avec gestion superviseur
    Call ERREUR(mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(180,143,1),1,[L]ERRMES,[L]ERRFLG)
   Endif
# Elsif [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=1
#   For J=6 To 9
#    Read [ATYR]ATYR0=[M:ASW9]CODTYP(I);J
#    If fstat
#      # Les règles $1$ \sont obligatoires pour le type "$2$" sans gestion superviseur
#      Call ERREUR(mess(34,140,1)-[M:ASW9]CODFLD(I)-":"-func AFNC.MES2(mess(163,143,1),
#&             mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1),
#&             mess(3,7881,1)),1,[L]ERRMES,[L]ERRFLG)
#    Endif
#   Next J
 Endif

 If [M:ASW9]FLDGRP(I)<>"" & instr(1,[M:ASW9]FLDGRP(I),".")
  #La définition de propriété de représentation sur la collection $1$ n'est pas autorisée
  Call ERREUR(mess(34,140,1)-[M:ASW9]CODFLD(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-func AFNC.MES1(mess(223,143,1), [M:ASW9]FLDGRP(I)),1,[L]ERRMES,[L]ERRFLG)
 Endif

Next
Return

#----------------------------------------#
$VERIF_ASWK
Local Integer OK_TARGET
Local Char L_ERR_MSG(250)
Local Integer I,J
# Check Links
For I=0 To [M:ASW6]NBRLNK-1
 #Contrôle ancre des liens
 If [M:ASW6]ANCLNK(I)<>""
   If [M:ASW6]AFFLNK(I)=1 : #propriété
    If find([M:ASW6]ANCLNK(I),[M:ASW4]CODPRO)=0
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1))+' : '+mess(56,140,1)-'"'+[M:ASW6]ANCLNK(I)+'"'
      # Propriété ou collection inexistante
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Elsif find([M:ASW6]AFFLNK(I),2,3)<>0 : #collection/ligne de collection
    If find([M:ASW6]ANCLNK(I),[M:ASW1]CODCOL)=0
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1))+' : '+mess(56,140,1)-'"'+[M:ASW6]ANCLNK(I)+'"'
      # Propriété ou collection inexistante
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Endif
 Endif
 If [M:ASW6]REMSTDLNK(I)<>""
  J=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]REMSTDLNK(I)),[M:ASW6]IDENT2)
  If J=0
    # Code inexistant
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+[M:ASW6]REMSTDLNK(I)-mess(84,141,1)
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Elsif [M:ASW6]FLGSTDLNK(J-1)=2
    # Le lien de remplacement $1$ doit être non standard
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES1(mess(204,143,1),[M:ASW6]REMSTDLNK(I))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Elsif !(([M:ASW6]TYPLNK(J-1)=[M:ASW6]TYPLNK(I) & [M:ASW6]CMPLNK(J-1)=[M:ASW6]CMPLNK(I))
&        |([M:ASW6]TYPLNK(I)=1 & [M:ASW6]TYPLNK(J-1)=4)
&        |([M:ASW6]TYPLNK(I)=4 & [M:ASW6]TYPLNK(J-1)=1))
    #Le lien de remplacement $1$ doit correspondre aux type et action du lien $2$
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES2(mess(203,143,1),[M:ASW6]REMSTDLNK(I),[M:ASW6]CODLNK(I))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Elsif [M:ASW6]TARLNK(J-1)=3
    #Le lien $1$ avec une cible $2$ ne peut pas être utilisé comme lien de remplacement
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES2(mess(283,143,1),[M:ASW6]REMSTDLNK(I),mess([M:ASW6]TARLNK(J-1),
& 7975,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Elsif [M:ASW6]ENALNK(I)=2 & [M:ASW6]ENALNK(J-1)<>2
    # Le lien de remplacement $1$ doit être actif
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES1(mess(195,143,1),[M:ASW6]REMSTDLNK(I))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
  Endif
 Endif
 If [M:ASW6]MENLNK(I) <> "" & !find([M:ASW6]AFFLNK(I),4,5)
  [M:ASW6]MENLNK(I)=""
 Elsif [M:ASW6]MENLNK(I) <> "" & !find([M:ASW6]MENLNK(I),[M:ASW8]CODMENU)
  L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+mess(84,141,1)-[M:ASW6]MENLNK(I)
  Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
 Elsif [M:ASW6]MENLNK(I)<>"" & [M:ASW6]TARLNK(I)=3
    #Un lien avec une cible $1$ ne peut pas avoir de menu
    L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&             func AFNC.MES1(mess(285,143,1), mess([M:ASW6]TARLNK(I),7975,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
 Endif
 If [M:ASW6]REPLNK(I)<>""
  Read [ASW2]ASW0 = [M:ASW6]REPLNK(I)
  If !fstat
   If [M:ASW1]TYPMSKREP<>[F:ASW2]TYPMSKREP
    L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&             func AFNC.MES1(mess(252,143,1), mess([M:ASW1]TYPMSKREP,7963,1))-":"-func AFNC.MES1(mess(255,143,1), mess([F:ASW2]TYPMSKREP,7963,1))-[M:ASW6]REPLNK(I)
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
  Endif
 Endif
 If [M:ASW1]TYPMSKREP<>1 & [M:ASW6]TYPLNK(I)=4
  L_ERR_MSG=func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&           func AFNC.MES1(mess(252,143,1), mess([M:ASW1]TYPMSKREP,7963,1))-":"-mess(254,143,1)
  Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
 Endif
 If [M:ASW6]ENALNK(I)=2
   If [M:ASW6]AFFLNK(I)=1 & [M:ASW6]CMPLNK(I)=9 & [M:ASW6]EDILNK(I)=2
    #si prop clé de la classe principale, pas de lookup
    If func SUBASW_TOOL.IS_CLA_KEY([M:ASW6]ANCLNK(I),func SUBASW_TOOL.GET_TYP_FROM_PRO_PATH_SCREEN([M:ASW6]ANCLNK(I)),[M:ASW1]CODCLA,[M:ASW1]ABRCLA)
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([M:ASW6]CMPLNK(I),7971,1),mess(2,7964,1))+' : '+
&                   func AFNC.MES1(mess(218,143,1),[M:ASW6]ANCLNK(I))
       Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Endif
   # Type de lien Représentation/"Dupliquer fiche" non autorisé
   If [M:ASW6]CMPLNK(I)=6
    #Lien de type $1$ non autorisé. Ce lien doit être inactif ou supprimé
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES1(mess(216,143,1),mess([M:ASW6]TYPLNK(I),7974,1)+'/"'+mess(6,7971,1)+'"')
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
   # On autorise les opérations uniquement sur AFFLNK=5/4
   If [M:ASW6]TYPLNK(I)=3 & !find([M:ASW6]AFFLNK(I),4,5)
    #Lien de type $1$ non autorisé sur ce type d'ancre. Ce lien doit être inactif ou supprimé
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES1(mess(267,143,1),mess(3,7974,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
   #101877/99183 #Method on property not allowed
   If [M:ASW6]TYPLNK(I)=2 & [M:ASW6]AFFLNK(I)=1
    #Lien de type $1$ non autorisé sur ce type d'ancre. Ce lien doit être inactif ou supprimé
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES1(mess(267,143,1),mess(2,7974,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
   #Sur Lookup, pas de méthode ni X3 Convergence
   If find([M:ASW6]TYPLNK(I),2,4) & [M:ASW6]LOKLNK(I)=2
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES2(mess(215,143,1),mess([M:ASW6]TYPLNK(I),7974,1),mess(4,7964,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Elsif [M:ASW6]LOKLNK(I)=2 & [M:ASW6]TARLNK(I)>1
    #Lien avec une cible "$1$" non autorisé sur facette $2$
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES2(mess(286,143,1),mess([M:ASW6]TARLNK(I),7975,1),mess(4,7964,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
   #Sur Summary, pas de méthode ni X3 Convergence
   If find([M:ASW6]TYPLNK(I),2,4) & [M:ASW6]SUMLNK(I)=2
    L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&               func AFNC.MES2(mess(215,143,1),mess([M:ASW6]TYPLNK(I),7974,1),mess(5,7964,1))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
   Endif
   #Sur Edit, uniquement Rep(1)/9-10 ou methode(2) ou Libre(5)
   If [M:ASW6]FLGSTDLNK(I)<>2 & [M:ASW6]EDILNK(I)=2
    If [M:ASW6]TYPLNK(I)=1
      If !find([M:ASW6]CMPLNK(I),9,10)
        L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([M:ASW6]CMPLNK(I),7971,1),mess(2,7964,1))
        Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
      Elsif [M:ASW6]TARLNK(I)>1
        #Lien avec une cible "$1$" non autorisé sur facette $2$
        L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES2(mess(286,143,1),mess([M:ASW6]TARLNK(I),7975,1),mess(2,7964,1))
        Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
      Endif
    Elsif !find([M:ASW6]TYPLNK(I),2,5)
        L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES2(mess(215,143,1),mess([M:ASW6]TYPLNK(I),7974,1),mess(2,7964,1))
        Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Elsif [M:ASW6]TARLNK(I)>1
        #Lien avec une cible "$1$" non autorisé sur facette $2$
        L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES2(mess(286,143,1),mess([M:ASW6]TARLNK(I),7975,1),mess(2,7964,1))
        Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Endif
   #101876
   If [M:ASW6]TYPLNK(I)=2
    If find([M:ASW6]AFFLNK(I),2,3) & [M:ASW6]CLAPTRLNK(I)<>[M:ASW6]ANCLNK(I)
     # Chemin de la classe incorrect
     L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   mess(57,140,1)-":"-[M:ASW6]CLAPTRLNK(I)
     Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Elsif find([M:ASW6]AFFLNK(I),4,5) & ([M:ASW6]CLAPTRLNK(I)<>"" & [M:ASW6]CLAPTRLNK(I)<>[M:ASW1]ABRCLA)
     # Chemin de la classe incorrect
     L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   mess(57,140,1)-":"-[M:ASW6]CLAPTRLNK(I)
     Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Elsif [M:ASW6]AFFLNK(I)=1
     If pat([M:ASW6]ANCLNK(I),[M:ASW6]CLAPTRLNK(I)+".*")=0
      # Chemin de la classe incorrect
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   mess(57,140,1)-":"-[M:ASW6]CLAPTRLNK(I)
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
     Elsif instr(0,right$([M:ASW6]ANCLNK(I),len([M:ASW6]CLAPTRLNK(I))+2),".")>0
      # Chemin de la classe incorrect
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   mess(57,140,1)-":"-[M:ASW6]CLAPTRLNK(I)
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
     Endif
    Endif
   Endif
   #102203/5
   If [M:ASW6]TARLNK(I)>1
    # to be able to set the target on a page link (a free link or a representation link on query, details, or summary facet).
    OK_TARGET=0
    If [M:ASW6]AFFLNK(I)=4 & [M:ASW6]TYPLNK(I)=5 : OK_TARGET=1 : Endif
    If [M:ASW6]AFFLNK(I)=4 & [M:ASW6]TYPLNK(I)=1 & find([M:ASW6]CMPLNK(I),2,5,10)>0 : OK_TARGET=1 : Endif
    If !OK_TARGET
      # Cible $1$ non autorisée sur ce type de lien
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES1(mess(284,143,1),mess([M:ASW6]TARLNK(I),7975,1))
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
    If [M:ASW6]TARLNK(I)=3 & [M:ASW6]TYPLNK(I)=1 & [M:ASW6]REPLNK(I)=[M:ASW0]CODREP
      #un lien avec une cible "$1$" ne peut pas pointer sur la représentation courante
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+
&                   func AFNC.MES1(mess(289,143,1),mess([M:ASW6]TARLNK(I),7975,1))
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Endif
Endif
 If [M:ASW6]METLNK(I)<>""
   If [M:ASW6]CLALNK(I)<>""
    Read [ACLAM]ACLAM0 = [M:ASW6]CLALNK(I);[M:ASW6]METLNK(I)
    If !fstat
     If [M:ASW6]TYPLNK(I) = 2 & [F:ACLAM]FLGOPE = 2
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+[M:ASW6]METLNK(I)+":"-mess(173,143,1)  # Cette méthode est une opération
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
     Elsif [M:ASW6]TYPLNK(I) = 3 & [F:ACLAM]FLGOPE <> 2
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+[M:ASW6]METLNK(I)+":"-mess(174,143,1)  # Cette méthode n'est pas une
# opération
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
     Endif
      If func VERIF_METCLA([M:ASW6]CLALNK(I),[M:ASW6]TYPLNK(I),[M:ASW6]METLNK(I))=0
        #La méthode $1$ ne peut pas être utilisée dans un lien
        L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES1(mess(214,143,1),[M:ASW6]METLNK(I))
        Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
      Endif
    Else
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+[M:ASW6]METLNK(I)+":"-mess(172,143,1)  # Méthode inexistante
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Else
    If !find([M:ASW6]METLNK(I), [M:ASW3]CODMET)
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+[M:ASW6]METLNK(I)+":"-mess(172,143,1)  # Méthode inexistante
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
    If func VERIF_METREP([M:ASW0]CODREP,[M:ASW6]METLNK(I))=0
      #La méthode $1$ ne peut pas être utilisée dans un lien
      L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))+' : '+func AFNC.MES1(mess(214,143,1),[M:ASW6]METLNK(I))
      Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    Endif
   Endif
 Endif
Next
Return

#----------------------------------------#
Funprog VERIF_METCLA(CLA_COD,SEL_MOD,METH)
Value Char CLA_COD
Value Integer SEL_MOD
Value Char METH
  Gosub DEFLIST_METH From SUBACLA_TOOL
  Gosub LIST_METH From SUBACLA_TOOL
  If !find(METH, TEX(1..NBTEX,1))
   End 0
  Endif
End 1
#----------------------------------------#
Funprog VERIF_METREP(REP_COD,METH)
Value Char REP_COD
Value Char METH
  Gosub DEFLIST_METH From SUBACLA_TOOL
  Gosub LIST_METH From SUBASW_TOOL
  If !find(METH, TEX(1..NBTEX,1))
   End 0
  Endif
End 1
#----------------------------------------#
$VERIF_ASWMN
Local Integer NOMEN
Local Char L_ERR_MSG(250)

Local Char WPARENT(GLONAVA),WMENU(GLONAVA)
Local Integer I

For NOMEN=0 To [M:ASW8]NBMENU-1
 WPARENT=[M:ASW8]PARMENU(NOMEN)
 WMENU=[M:ASW8]CODMENU(NOMEN)
 While WPARENT<>""
  If WPARENT=WMENU
    #Code parent "$1$" non autorisé pour le menu "$2$"
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    WPARENT=""
  Else
   I=find(WPARENT,[M:ASW8]CODMENU)
   If I=0
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    WPARENT=""
   Elsif [M:ASW8]PARMENU(I-1)=[M:ASW8]CODMENU(NOMEN)
    L_ERR_MSG = func AFNC.MES2(mess(226,143,1), [M:ASW8]PARMENU(NOMEN), [M:ASW8]CODMENU(NOMEN))
    Call ERREUR(L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG)
    WPARENT=""
   Else
    WPARENT=[M:ASW8]PARMENU(I-1)
    WMENU=[M:ASW8]CODMENU(I-1)
   Endif
  Endif
 Wend
Next
Return

#----------------------------------------#
$VERIF_CRE
$VERIF_MOD
Gosub OUVRE_ATAB From SUBACLA :#117403
Local Integer I,J
Local Char ERRMES(250)(1..)
Local Integer ERRFLG (1..)
Local Integer MES_OK
Gosub VERIF_REP

Gosub VERIF_FACETTE

Gosub VERIF_ASWC

Gosub VERIF_ASWO

Gosub VERIF_ASWF

Gosub VERIF_ASWR

Gosub VERIF_ASWK

Gosub VERIF_ASWP

Gosub VERIF_ASWMN

#Liens invalides
If find(2,[M:ASW6]INVLNK)<>0
  Call ERREUR(func AFNC.MES1(mess(225,143,1),[M]CODREP),-1,[L]ERRMES,[L]ERRFLG) From SUBASW
Endif

If maxtab([L]ERRMES)=1
 If [L]ERRFLG(1)=-1
   MES_OK=1
   Call AVERTIR([L]ERRMES(1),MES_OK) From GESECRAN
   If MES_OK<>2
     OK=0 : Return
   Endif
 Else
   Call ERREUR([L]ERRMES(1)) From GESECRAN
   OK=0 : Return
 Endif
Elsif maxtab([L]ERRMES)>1
 Call OUVRE_TRACE(mess(23,140,1)-[M]CODREP) From LECFIC
 For I=1 To maxtab([L]ERRMES)
  Call ECR_TRACE([L]ERRMES(I),[L]ERRFLG(I)) From GESECRAN
 Next
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
 If find(1,[L]ERRFLG(1..maxtab([L]ERRFLG)))
   OK=0 : Return
 Endif
Endif

Return


#----------------------------------------#
Subprog ERREUR(MES,FLG,ERRMES,ERRFLG)
Value Char MES
Value Integer FLG
Variable Char ERRMES()(1..)
Variable Integer ERRFLG (1..)

Local Integer NBMES

[L]NBMES = maxtab([L]ERRMES)

[L]ERRMES(NBMES+1) = [L]MES
[L]ERRFLG(NBMES+1) = [L]FLG
End


