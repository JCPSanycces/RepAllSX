#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet ASW
If adxmac(-2)="pc018948.sagefr.adinternal.com" : Gosub TEST From ASHWVAL :  : End :Endif
Raz GPILCOD ,GNBMASKOUV
GBIDC1 ="AOBJEXT"
Call OBJET("ASW",GBIDC1,GBIDC2) From GOBJET
End


#----------------------------------------------------------------------------#
$ACTION
ACTION = ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "SETBOUT"   : Gosub SETBOUT
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "STYLE"     : Gosub STYLE
 When "EXEBOUT"   : Gosub EXEBOUT
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
# When "AV_VERF_ANU" : Gosub AV_VERF_ANU
# When "AP_VERF_ANU" : Gosub AP_VERF_ANU
 When "VERF_ANU"  : Gosub VERF_ANU
 When "ANNULE"    : Gosub ANNULE
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "STATUT"    : Gosub STATUT
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

#--------------------------------#
$OUVRE
GBIDI1=0
#If GUSER<>'VPO' : GMESSAGE="The access to the classes and representations and data type functions are forbidden during update" : OK=0 : Return : Endif
#Infbox "Modif en cours, Aucun lien généré pour le moment sur la validation des représentations (VPO)"
Local Integer L , M

# Representation
If !clalev([F:ASWM])    : Local File ASHWMET     [ASWM]    : Endif
If !clalev([F:ASWMP])   : Local File ASHWPARMET  [ASWMP]   : Endif
If !clalev([F:ASWF])    : Local File ASHWFLD     [ASWF]    : Endif
If !clalev([F:ASWF2])    : Local File ASHWFLD     [ASWF2]    : Endif
