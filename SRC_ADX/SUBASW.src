If !clalev([F:ACLAC2])  : Local File ACLACOL     [ACLAC2]  : Endif
If !clalev([F:ACLFP])   : Local File ACLAPARFLD  [ACLFP]   : Endif
If !clalev([F:ACLPD])   : Local File ACLAPARDEF  [ACLPD]   : Endif


# Annexes
If !clalev([F:AFC])     : Local File AFONCTION    [AFC]    : Endif
If !clalev([F:ACT])     : Local File ACTION       [ACT]    : Endif
If !clalev([F:ATR])     : Local File ACTPAR       [ATR]    : Endif
