$OUVRE_COP
If [M]DOSORG=nomap
 Local File ASHW       [ASW1]
 Local File ASHWFLD    [ASWF1]
 Local File ASHWPAR    [ASWP1]
 Local File ASHWMENU   [ASWMN1]
 Local File ASHWMET    [ASWM1]
 Local File ASHWPARMET [ASWMP1]
 Local File ASHWOPT    [ASWO1]
 Local File ASHWCOL    [ASWC1]
 Local File ASHWSEC    [ASWS1]
 Local File ASHWBLC    [ASWB1]
 Local File ASHWEXPPRO [ASWR1]
 Local File ASHWLNK    [ASWK1]
 Local File ATEXTE     [ATX1]
 Local File ACTIV      [ACV1]
Else
 Local File =[M]DOSORG+".ASHW"       [ASW1]
 Local File =[M]DOSORG+".ASHWFLD"    [ASWF1]
 Local File =[M]DOSORG+".ASHWPAR"    [ASWP1]
 Local File =[M]DOSORG+".ASHWMENU"   [ASWMN1]
 Local File =[M]DOSORG+".ASHWMET"    [ASWM1]
 Local File =[M]DOSORG+".ASHWPARMET" [ASWMP1]
 Local File =[M]DOSORG+".ASHWOPT"    [ASWO1]
 Local File =[M]DOSORG+".ASHWCOL"    [ASWC1]
 Local File =[M]DOSORG+".ASHWSEC"    [ASWS1]
 Local File =[M]DOSORG+".ASHWBLC"    [ASWB1]
 Local File =[M]DOSORG+".ASHWEXPPRO" [ASWR1]
 Local File =[M]DOSORG+".ASHWLNK"    [ASWK1]
 Local File =[M]DOSORG+".ATEXTE"     [ATX1]
 Local File =[M]DOSORG+".ACTIV"      [ACV1]
Endif
If [M]DOSDES=nomap
 Local File ASHW       [ASW2]
 Local File ASHWFLD    [ASWF2]
 Local File ASHWPAR    [ASWP2]
 Local File ASHWMENU   [ASWMN2]
 Local File ASHWMET    [ASWM2]
 Local File ASHWPARMET [ASWMP2]
 Local File ASHWOPT    [ASWO2]
 Local File ASHWCOL    [ASWC2]
 Local File ASHWSEC    [ASWS2]
 Local File ASHWBLC    [ASWB2]
 Local File ASHWEXPPRO [ASWR2]
 Local File ASHWLNK    [ASWK2]
 Local File ATEXTE     [ATX2]
 Local File ACTIV      [ACV2]
 Local File ADOVAL     [ADW2]
Else
 Local File =[M]DOSDES+".ASHW"       [ASW2]
 Local File =[M]DOSDES+".ASHWFLD"    [ASWF2]
 Local File =[M]DOSDES+".ASHWPAR"    [ASWP2]
 Local File =[M]DOSDES+".ASHWMENU"   [ASWMN2]
 Local File =[M]DOSDES+".ASHWMET"    [ASWM2]
 Local File =[M]DOSDES+".ASHWPARMET" [ASWMP2]
 Local File =[M]DOSDES+".ASHWOPT"    [ASWO2]
 Local File =[M]DOSDES+".ASHWCOL"    [ASWC2]
 Local File =[M]DOSDES+".ASHWSEC"    [ASWS2]
 Local File =[M]DOSDES+".ASHWBLC"    [ASWB2]
 Local File =[M]DOSDES+".ASHWEXPPRO" [ASWR2]
 Local File =[M]DOSDES+".ASHWLNK"    [ASWK2]
 Local File =[M]DOSDES+".ATEXTE"     [ATX2]
 Local File =[M]DOSDES+".ACTIV"      [ACV2]
 Local File =[M]DOSDES+".ADOVAL"     [ADW2]
Endif
Return
$TRTCOP
Gosub OUVRE_COP
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ASW1], [ASWF1], [ASWP1], [ASWMN1],[ASWM1], [ASWMP1], [ASWO1],[ASWC1],[ASWS1],[ASWB1], [ASWR1] , [ASWK1] , [ATX1], [ACV1]
Close Local File [ASW2], [ASWF2], [ASWP2], [ASWMN2],[ASWM2], [ASWMP2], [ASWO2],[ASWC2],[ASWS2],[ASWB2], [ASWR2] , [ASWK2] , [ATX2], [ACV2] , [ADW2]
Return

$TR_COP
GOK = 1
Trbegin [ASW2]
 Delete [ASW2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHW" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASW2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWF2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWP2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWMN2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWMENU" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWMN2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWM2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWMET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWM2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWMP2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWPARMET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWMP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWO2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWOPT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWO2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWC2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWCOL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWC2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWS2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWSEC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWS2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWB2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWBLC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWR2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWEXPPRO" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWR2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASWK2] Where CODREP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASHWLNK" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASWK2","") From GLOCK : Goto AB_TR_COP
 Endif

 Local Integer ISDOSX3DES
 Local  Char ADOSDES(GLONADS),MACDES(250)
 Read [ADW2]ADW0 = "";"";"SUPDOS"
 If !fstat
  Call MACHINE(DOSDES,MACDES,ADOSDES) From ORDSYS
  If ADOSDES=[F:ADW2]VALEUR
   ISDOSX3DES = 1
  Endif
 Endif

 For [ASW1] Where CODREP=TABLE
  [F:ASW2] = [F:ASW1]
  Call COPTEXTE([F:ASW1]INTREP,[F:ASW2]INTREP) From OBJDIV
  If GOK<1 : Break : Endif

  If dim([F:ASW2]UPDUSR)>0 : [F:ASW2]UPDUSR = GUSER : Endif
  If dim([F:ASW2]UPDDAT)>0 : [F:ASW2]UPDDAT = date$ : Endif
  If dim([F:ASW2]UPDTIM)>0 : [F:ASW2]UPDTIM = time  : Endif
  Write [ASW2]
  If fstat
   GOK=0 : Call FSTA("ASW2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWF1] Where CODREP=TABLE
  If [F:ASWF1]ACTFLD<>""
   Read [ACV2]CODACT = [F:ASWF1]ACTFLD
  Endif
   If [F:ASWF1]ACTFLD="" or ISDOSX3DES or (!fstat and [ACV2]FLACT=2)
   [F:ASWF2] = [F:ASWF1]
   Call COPTEXTE([F:ASWF1]INTFLD,[F:ASWF2]INTFLD) From OBJDIV
   If GOK<1 : Break : Endif
   Call COPTEXTE([F:ASWF1]INTSHTFLD,[F:ASWF2]INTSHTFLD) From OBJDIV
   If GOK<1 : Break : Endif
   Write [ASWF2]
   If fstat
    GOK=0 : Call FSTA("ASWF2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWP1] Where CODREP=TABLE
  [F:ASWP2] = [F:ASWP1]
  Write [ASWP2]
  If fstat
   GOK=0 : Call FSTA("ASWP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWMN1] Where CODREP=TABLE
  [F:ASWMN2] = [F:ASWMN1]
  Call COPTEXTE([F:ASWMN1]LIBMENU,[F:ASWMN2]LIBMENU) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWMN2]
  If fstat
   GOK=0 : Call FSTA("ASWMN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWM1] Where CODREP=TABLE
  [F:ASWM2] = [F:ASWM1]
  Call COPTEXTE([F:ASWM1]INTMET,[F:ASWM2]INTMET) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWM2]
  If fstat
   GOK=0 : Call FSTA("ASWM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWMP1] Where CODREP=TABLE
  [F:ASWMP2] = [F:ASWMP1]
  Call COPTEXTE([F:ASWMP1]INTPARMET,[F:ASWMP2]INTPARMET) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWMP2]
  If fstat
   GOK=0 : Call FSTA("ASWMP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWO1] Where CODREP=TABLE
  [F:ASWO2] = [F:ASWO1]
  Call COPTEXTE([F:ASWO1]OPTLIB,[F:ASWO2]OPTLIB) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ASWO1]OPTERR,[F:ASWO2]OPTERR) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWO2]
  If fstat
   GOK=0 : Call FSTA("ASWO2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWC1] Where CODREP=TABLE
  [F:ASWC2] = [F:ASWC1]
  Call COPTEXTE([F:ASWC1]INTCOL,[F:ASWC2]INTCOL) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWC2]
  If fstat
   GOK=0 : Call FSTA("ASWC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWS1] Where CODREP=TABLE
  [F:ASWS2] = [F:ASWS1]
  Call COPTEXTE([F:ASWS1]INTSEC,[F:ASWS2]INTSEC) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWS2]
  If fstat
   GOK=0 : Call FSTA("ASWS2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWB1] Where CODREP=TABLE
  [F:ASWB2] = [F:ASWB1]
  Call COPTEXTE([F:ASWB1]INTBLC,[F:ASWB2]INTBLC) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWB2]
  If fstat
   GOK=0 : Call FSTA("ASWB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWR1] Where CODREP=TABLE
  If ISDOSX3DES or
&  func SUBASW_TOOL.OK_DECODEPRO(DOSDES,[F:ASW2]CODREP,[F:ASW2]ABRCLA,[F:ASW2]CODCLA,[F:ASWR1]CODPRO)
   [F:ASWR2] = [F:ASWR1]
   Call COPTEXTE([F:ASWR1]INTPRO,[F:ASWR2]INTPRO) From OBJDIV
   If GOK<1 : Break : Endif
   Call COPTEXTE([F:ASWR1]INTSHTPRO,[F:ASWR2]INTSHTPRO) From OBJDIV
   If GOK<1 : Break : Endif
   Write [ASWR2]
   If fstat
    GOK=0 : Call FSTA("ASWR2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ASWK1] Where CODREP=TABLE
  [F:ASWK2] = [F:ASWK1]
  Call COPTEXTE([F:ASWK1]INTLNK,[F:ASWK2]INTLNK) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ASWK2]
  If fstat
   GOK=0 : Call FSTA("ASWK2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#####################################################################################################################
#####################################################################################################################
Funprog IS_AFC_OBJ_GES3(DOSSIER,CODFNC)
Value Char    DOSSIER
Value Char    CODFNC

Local Char CHAINE(250),P1(250)
Local Integer WNUM,I

Local File =DOSSIER+".AFONCTION"    [AFC]
Local File =DOSSIER+".AOBJET"    [AOB]

Read [AFC]CODINT = [L]CODFNC
If !fstat &  [F:AFC]ACTION="GOBJET"
 For I=0 To 19
  If left$([F:AFC]CODPAR(I),5)="OBJET" & [F:AFC]VALPAR(I)<>""
    Onerrgo ERR_EVAL
    [L]P1=evalue([F:AFC]VALPAR(I))
    Onerrgo
    Break
  Endif
 Next I
 If [L]P1="" : End 0 : Endif : #pas d'objet
 Filter [AOB]
 Read [AOB]ABREV=[L]P1
 If !fstat & [F:AOB]TYPGES=3
  End 1
 Endif
Endif

LogicClose File [AFC],[AOB]

End 0

#####################################################################################################################
Subprog CHARGE_AFC_CLE(DOSSIER,CODFNC,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,
& WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WPARFIL,WPARENT,WVALPAR,WNBRPARALL)
Value Char    DOSSIER
Value Char    CODFNC
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WPARFIL(0..)
Variable Integer WPARENT(0..)
Variable Char    WVALPAR()(0..)
Variable Integer WNBRPARALL

Local Char CHAINE(250),P1(250)
Local Integer WNUM,I

Read [AFC]CODINT = [L]CODFNC
If !fstat &  [F:AFC]ACTION="GOBJET"
 For I=0 To 19
  If left$([F:AFC]CODPAR(I),5)="OBJET" & [F:AFC]VALPAR(I)<>""
    Onerrgo ERR_EVAL
    [L]P1=evalue([F:AFC]VALPAR(I))
    Onerrgo
    Break
  Endif
 Next I
 If [L]P1="" : End : Endif : #pas d'objet
 Filter [AOB]
 Read [AOB]ABREV=[L]P1
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATI]NUMLIG=[F:AOB]NOMFIC;1
  If !fstat
   [L]CHAINE = [ATI]DESCRIPT
   Call CHARGE_CLE([F:AOB]NOMFIC,[L]CHAINE,[L]DOSSIER,"",[L]FLDCUR,[L]TYPPAR,[L]WCODPAR,
&             [L]WCODCUR,[L]WTYPPAR,[L]WFLDCLE,[L]WINTITPAR,[L]WTYPINTPAR,[L]WADRVAL,[L]WTYPKEY,
&             [L]WCODCLAPAR,[L]WNUMPAR,[L]WNOLIB,[L]WLNG,[L]WTYPAFF,[L]WNBRPARALL) From SUBACLA
  Endif
 Endif
Elsif !fstat
  Read [ACT]ACTION=[F:AFC]ACTION
  If !fstat
    For [ATR]NOPAR Where ACTION=[F:AFC]ACTION
        WNUM+=1
        [L]WCODPAR([L]WNBRPARALL) = [F:ATR]CODPAR
        [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
      #  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
        [L]WINTITPAR([L]WNBRPARALL) = func ASYRFNC.TEXTE([F:ATR]INTITPAR)
        [L]WTYPINTPAR([L]WNBRPARALL) = func AFNC.TYP33_10030([F:ATR]TYPPAR)
        #[L]WADRVAL([L]WNBRPARALL)    = [F:ATR]ADRVAL
        [L]WADRVAL([L]WNBRPARALL)    = 2 : #par valeur
        [L]WTYPKEY([L]WNBRPARALL)    = 1
        [L]WCODCLAPAR([L]WNBRPARALL) = ""
        [L]WTYPPAR([L]WNBRPARALL)    = [L]TYPPAR
        [L]WNUMPAR([L]WNBRPARALL)    = WNUM
        #[L]WPARENT([L]WNBRPARALL)    = 2
        I=find([F:ATR]CODPAR,[F:AFC]CODPAR)
        If I>0
          [L]WVALPAR([L]WNBRPARALL) = [F:AFC]VALPAR(I-1)
        Else
          [L]WVALPAR([L]WNBRPARALL) = ""
        Endif
        [L]WNBRPARALL+=1
    Next
  Endif
Endif

End


#####################################################################################################################
#104754/3
Subprog CHARGE_ARP_PARAM(DOSSIER,CODRPT,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,
& WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WPARFIL,WPARENT,WVALPAR,WNBRPARALL)
Value Char    DOSSIER
Value Char    CODRPT
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WPARFIL(0..)
Variable Integer WPARENT(0..)
Variable Char    WVALPAR()(0..)
Variable Integer WNBRPARALL

Local Char CHAINE(250),P1(250)
Local Integer WNUM,I
Local File AREPORTD [ARD]

For [ARD]ARD0 Where RPTCOD=[L]CODRPT
    WNUM+=1
    [L]WCODPAR([L]WNBRPARALL) = [F:ARD]PARCOD
    [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
  #  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
    [L]WINTITPAR([L]WNBRPARALL) = func ASYRFNC.TEXTE([F:ARD]PARNAM)
    [L]WTYPINTPAR([L]WNBRPARALL) = func ATY_TOOL.GET_INTERNAL_TYP_LM30([F:ARD]PARTYP)
    #[L]WADRVAL([L]WNBRPARALL)    = [F:ATR]ADRVAL
    [L]WADRVAL([L]WNBRPARALL)    = 2 : #par valeur
    [L]WTYPAFF([L]WNBRPARALL)    = 1 : #Saisie:Non
    [L]WNOLIB([L]WNBRPARALL)    = [F:ARD]PARNOLIB
    [L]WLNG([L]WNBRPARALL)    = [F:ARD]PARLNG
    [L]WTYPKEY([L]WNBRPARALL)    = 1
    [L]WCODCLAPAR([L]WNBRPARALL) = ""
    [L]WTYPPAR([L]WNBRPARALL)    = [L]TYPPAR
    [L]WNUMPAR([L]WNBRPARALL)    = WNUM
    #[L]WPARENT([L]WNBRPARALL)    = 2
    If [F:ARD]PARDEF1<>""
     [L]WVALPAR([L]WNBRPARALL) = [F:ARD]PARDEF1
    Else
     [L]WVALPAR([L]WNBRPARALL) = ""
    Endif

    If [F:ARD]PARSTREND=2 : #Borne (voir si gestion multiple)
     [L]WTYPAFF([L]WNBRPARALL)    = 2 : #Saisie:Oui
     [L]WNBRPARALL+=1
     WNUM+=1

     [L]WCODPAR([L]WNBRPARALL) = [F:ARD]PARCOD
     [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
   #  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
     [L]WINTITPAR([L]WNBRPARALL) = [L]WINTITPAR([L]WNBRPARALL-1)
     [L]WTYPINTPAR([L]WNBRPARALL) = [L]WTYPINTPAR([L]WNBRPARALL-1)
     #[L]WADRVAL([L]WNBRPARALL)    = [F:ATR]ADRVAL
     [L]WADRVAL([L]WNBRPARALL)    = 2 : #par valeur
     [L]WTYPAFF([L]WNBRPARALL)    = 2 : #Saisie:Oui
     [L]WNOLIB([L]WNBRPARALL)    = [F:ARD]PARNOLIB
     [L]WLNG([L]WNBRPARALL)    = [F:ARD]PARLNG
     [L]WTYPKEY([L]WNBRPARALL)    = 3
     [L]WCODCLAPAR([L]WNBRPARALL) = ""
     [L]WTYPPAR([L]WNBRPARALL)    = [L]TYPPAR
     [L]WNUMPAR([L]WNBRPARALL)    = WNUM
     #[L]WPARENT([L]WNBRPARALL)    = 2
     If [F:ARD]PARDEF2<>""
      [L]WVALPAR([L]WNBRPARALL) = [F:ARD]PARDEF2
     Else
      [L]WVALPAR([L]WNBRPARALL) = ""
     Endif

    Endif

    [L]WNBRPARALL+=1
Next

End

$ERR_EVAL
Resume

#############################################################################################
Subprog CHARGE_PARAM_MET(DOSSIER,ACLAPTR,ALNKCLA,AMETHOD,CODREP1,CODCLA1,FLDCUR,TYPPAR,WCODPAR,WCODCUR,
& WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Value Char    DOSSIER
Value Char    ACLAPTR
Value Char    ALNKCLA
Value Char    AMETHOD
Value Char    CODREP1
Value Char    CODCLA1
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WNBRPARALL

Local Char TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50),TABREF(GLONAVB)(1..)
Local Integer NBCLA,WNUM,ISACTX,J

If [L]ACLAPTR<>""  : #method of a class of the representation (base)

 If clalev([M:ASW0])>0 & clalev([M:ASW3])>0 & [M:ASW0]CODREP=[L]CODREP1
 Call DECODE_PRO([L]ACLAPTR,2,"PTR",[L]DOSSIER,[L]CODREP1,"",[L]CODCLA1,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 Else
 Call DECODE_PRO([L]ACLAPTR,0,"PTR",[L]DOSSIER,[L]CODREP1,"",[L]CODCLA1,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 Endif
 If NBCLA>0
  For [ACLPD]ACLPD1 Where CODCLA=TABCLA(NBCLA) & CODE=[L]AMETHOD
   WNUM+=1
   [L]WCODPAR([L]WNBRPARALL) = [F:ACLPD]CODPAR
   [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
   [L]WTYPPAR([L]WNBRPARALL) = [L]TYPPAR
#   [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
   [L]WINTITPAR([L]WNBRPARALL)= func ASYRFNC.TEXTE([F:ACLPD]INTPAR)
   [L]WTYPINTPAR([L]WNBRPARALL) = [F:ACLPD]TYPINTPAR
   [L]WADRVAL([L]WNBRPARALL) = [F:ACLPD]MODPAR
   [L]WTYPKEY([L]WNBRPARALL) = [F:ACLPD]TYPKEY
   [L]WCODCLAPAR([L]WNBRPARALL) = [F:ACLPD]CLAPAR
   [L]WNUMPAR([L]WNBRPARALL)    = WNUM
   [L]WNBRPARALL+=1
  Next
 Endif
Elsif [L]ALNKCLA="" & clalev([M:ASW0])>0 & clalev([M:ASW3])>0 & [M:ASW0]CODREP=[L]CODREP1  : #method of representation (screen)
  For J=0 To [M:ASW3]WNBRPARMET-1
   If [M:ASW3]WCODMET(J) = [L]AMETHOD
    WNUM+=1
    [L]WCODPAR([L]WNBRPARALL) = [M:ASW3]WCODPARMET(J)
    [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
    [L]WTYPPAR([L]WNBRPARALL) = [L]TYPPAR
  #  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
    [L]WINTITPAR([L]WNBRPARALL)= func ASYRFNC.TEXTE([M:ASW3]WINTPARMET(J))
    [L]WTYPINTPAR([L]WNBRPARALL) = [M:ASW3]WTYPPARMET(J)
    [L]WADRVAL([L]WNBRPARALL) = [M:ASW3]WMODPARMET(J)
    [L]WTYPKEY([L]WNBRPARALL) = 1
    [L]WCODCLAPAR([L]WNBRPARALL) = [M:ASW3]WCLAPARMET(J)
    [L]WNUMPAR([L]WNBRPARALL)    = WNUM
    [L]WNBRPARALL+=1
   Endif
  Next
Elsif [L]ALNKCLA="" : #method of representation (base)
 For [ASWMP]ASWMP1 Where CODREP=[L]CODREP1 & CODMET=[L]AMETHOD
  WNUM+=1
  [L]WCODPAR([L]WNBRPARALL) = [F:ASWMP]CODPARMET
  [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
  [L]WTYPPAR([L]WNBRPARALL) = [L]TYPPAR
#  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
  [L]WINTITPAR([L]WNBRPARALL)= func ASYRFNC.TEXTE([F:ASWMP]INTPARMET)
  [L]WTYPINTPAR([L]WNBRPARALL) = [F:ASWMP]TYPPARMET
  [L]WADRVAL([L]WNBRPARALL) = [F:ASWMP]MODPARMET
  [L]WTYPKEY([L]WNBRPARALL) = 1
  [L]WCODCLAPAR([L]WNBRPARALL) = [F:ASWMP]CLAPARMET
  [L]WNUMPAR([L]WNBRPARALL)    = WNUM
  [L]WNBRPARALL+=1
 Next
Elsif [L]ALNKCLA<>"" : #Operation from another class (base)
  For [ACLPD]ACLPD1 Where CODCLA=[L]ALNKCLA & CODE=[L]AMETHOD
   WNUM+=1
   [L]WCODPAR([L]WNBRPARALL) = [F:ACLPD]CODPAR
   [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
   [L]WTYPPAR([L]WNBRPARALL) = [L]TYPPAR
#   [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
   [L]WINTITPAR([L]WNBRPARALL)= func ASYRFNC.TEXTE([F:ACLPD]INTPAR)
   [L]WTYPINTPAR([L]WNBRPARALL) = [F:ACLPD]TYPINTPAR
   [L]WADRVAL([L]WNBRPARALL) = [F:ACLPD]MODPAR
   [L]WTYPKEY([L]WNBRPARALL) = [F:ACLPD]TYPKEY
   [L]WCODCLAPAR([L]WNBRPARALL) = [F:ACLPD]CLAPAR
   [L]WNUMPAR([L]WNBRPARALL)    = WNUM
   [L]WNBRPARALL+=1
  Next
Endif

End

##########################################################################
Funprog IS_ATY_UNIT(WATY)
Value Char WATY
 Read [ATY]CODTYP=WATY
 If !fstat & [F:ATY]CODCLA<>""
  Read [ACLA]ACLA0=[F:ATY]CODCLA
  If !fstat & [F:ACLA]TABREF<>""
   Read [ATB]CODFIC=[F:ACLA]TABREF
   If !fstat & [ATB]SYMBOL<>""
    End 1
   Endif
  Endif
 Endif
End 0
##########################################################################
# ABR.pt1.ptr2.grp ou pro
Subprog DECODE_PRO(VALEUR,AFCASW,TYPPRO,DOSSIER,CODREP,ABRCLA,CODCLA1,TABPTR,TABCLA,OBJ,ISACTX,NBCLA)
Value Char VALEUR
Value Integer AFCASW
Value Char DOSSIER
Value Char TYPPRO
Value Char CODREP
Value Char ABRCLA
Value Char CODCLA1
Variable Char TABPTR()(1..)
Variable Char TABCLA()(1..)
Variable Char OBJ
Variable Integer ISACTX
Variable Integer NBCLA

#Locale
Local Char    CHAINE(250)
Local Integer I,J,ERREUR

# Decode valeur
Raz TABPTR,TABCLA,OBJ,NBCLA,ISACTX

If [L]VALEUR="" : End : Endif

# Open table
#If [L]DOSSIER<>""
# Local File =[L]DOSSIER+".ACLAFLD"      [ACLAF]
# Local File =[L]DOSSIER+".ASHW"           [ASW]
# Local File =[L]DOSSIER+".ACLASSE"       [ACLA]
# Local File =[L]DOSSIER+".ACLACOL"       [ACLAC]
#Else
# Local File ACLAFLD         [ACLAF]
# Local File ASHW            [ASW]
# Local File ACLASSE         [ACLA]
# Local File ACLACOL         [ACLAC]
#Endif
#
#If [L]DOSSIER<>""
# Local File =[L]DOSSIER+".ACONTEXT"     [ACTX2]
#Else
# Local File ACONTEXT       [ACTX2]
#Endif

If !AFCASW
 If [L]CODREP<>"" & [L]ABRCLA=""
  Read [ASW]ASW0  = [L]CODREP
  If !fstat
   [L]ABRCLA = [F:ASW]ABRCLA
  Endif
 Endif
Elsif AFCASW=2 &  dim([M]ABRCLA)>0
 [L]ABRCLA = [M]ABRCLA
Endif

If [L]ABRCLA<>""
 I = instr(1,[L]VALEUR,".")
 If I>0 &  [L]ABRCLA=left$([L]VALEUR,I-1)
  CHAINE = right$([L]VALEUR,I+1)
 Else
  CHAINE = [L]VALEUR
 Endif
Else
 CHAINE = [L]VALEUR
Endif

I=instr(1,CHAINE,".")
While I>0
 NBCLA += 1
 TABPTR(NBCLA) = left$(CHAINE,I-1)
 CHAINE = right$(CHAINE,I+1)
 I=instr(1,CHAINE,".")
Wend

Case [L]TYPPRO
 When "GRP","PRO" : OBJ = CHAINE
 When "PTR" :
  TABCLA(1) = CODCLA1
  NBCLA += 1 :  TABPTR(NBCLA)= CHAINE
  If NBCLA=1  & !instr(1,[L]VALEUR,".")  & AFCASW<>1 : End : Endif : # cas particlier de la selection de pointeur dans les liens...
Endcase

If instr(1,[L]VALEUR,"ACTX.")>0
 Gosub DECOD_ACTX
Elsif [L]ABRCLA<>"" & (!instr(1,[L]VALEUR,".") or (instr(1,[L]VALEUR,".")>0  & left$([L]VALEUR,instr(1,[L]VALEUR,".")-1)<>[L]ABRCLA)): # Propriete propre representation
 Gosub DECOD_FLDREP
Else
 Gosub DECOD_FLDCLA
Endif

#Close Local File
End

$DECOD_ACTX
Read [ACTX2]ACTX0 = OBJ
If !fstat & (func AFNC.ACTIVDOS([L]DOSSIER,[ACTX2]CODACT)>0 | AFCASW<>0)
 ISACTX =2
 NBCLA =1
 Raz TABPTR,TABCLA
Elsif !fstat
 Raz TABCLA,TABPTR
 NBCLA = -1
Else
 Raz TABCLA,TABPTR,NBCLA
Endif
Return

$DECOD_FLDCLA
If NBCLA
 If !AFCASW or AFCASW=2
  Read [ACLA]ACLA0 = [L]CODCLA1
  If !fstat
   Read [ACLAF]ACLAF0  = [L]CODCLA1;TABPTR(1)
   If !fstat & (func AFNC.ACTIVDOS([L]DOSSIER,[ACLAF]ACTFLD)>0 | AFCASW<>0)
    Read [ACLAC]ACLAC0=[L]CODCLA1;TABPTR(1)
    If !fstat & [F:ACLAF]LNKCLA=""
     Dela 1,1 TABCLA,TABPTR
     NBCLA -= 1
    Else
     If [F:ACLAF]LNKCLA="" & [F:ACLAF]FLDGRP<>""
      Raz TABCLA,TABPTR,NBCLA
      ERREUR = 1
     Endif
     If [F:ACLAF]LNKCLA<>"" : TABCLA(1) = [F:ACLAF]LNKCLA : Endif
    Endif
   Elsif !fstat
    Raz TABCLA,TABPTR
    NBCLA = -1
   Else
    Read [ACLAC]ACLAC0=[L]CODCLA1;TABPTR(1)
    If fstat
     Raz TABCLA,TABPTR,NBCLA
     ERREUR = 1
    Else
     For [ACLAF] Where FLDGRP=[ACLAC]CODCOL & CODCLA=[L]CODCLA1
      If [ACLAF]LNKCLA=""
       Dela 1,1 TABCLA,TABPTR
       NBCLA -= 1
       Break
      Else
       Raz TABCLA,TABPTR,NBCLA
       ERREUR = 1
       Break
      Endif
     Next
    Endif
   Endif
  Endif
 Elsif AFCASW=1
  J=find(TABPTR(1),[M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
  If !J
   Raz NBCLA
   ERREUR = 1
  Else
   TABCLA(1) = [M:ACLA6]LNKCLA(J-1)
  Endif
 Endif
 For I=2 To NBCLA
  Read [ACLA]ACLA0 = TABCLA(I-1)
  If !fstat
   Read [F:ACLAF]ACLAF0 = TABCLA(I-1);TABPTR(I)
   If !fstat & (func AFNC.ACTIVDOS([L]DOSSIER,[ACLAF]ACTFLD)>0 | AFCASW<>0)
    Read [ACLAC]ACLAC0=TABCLA(I-1);TABPTR(1)
    If !fstat  & [F:ACLAF]LNKCLA=""
     Dela I,1 TABCLA,TABPTR
     NBCLA -= 1
     Break
    Else
     If [F:ACLAF]LNKCLA="" & [F:ACLAF]FLDGRP<>""
      Raz TABCLA,TABPTR,NBCLA
      ERREUR = 1
      Break
     Endif
     If [F:ACLAF]LNKCLA<>"" : TABCLA(I) = [F:ACLAF]LNKCLA : Endif
    Endif
   Elsif !fstat
    Raz TABCLA,TABPTR
    NBCLA = -1
   Else
    Read [ACLAC]ACLAC0=TABCLA(I-1);TABPTR(I)
    If fstat
     Raz TABCLA,TABPTR,NBCLA
     ERREUR = 1
    Else
     For [ACLAF] Where FLDGRP=[ACLAC]CODCOL & CODCLA=TABCLA(I-1)
      If [ACLAF]LNKCLA=""
       Dela I,1 TABCLA,TABPTR
       NBCLA -= 1
       Break
      Else
       Raz TABCLA,TABPTR,NBCLA
       ERREUR = 1
       Break
      Endif
     Next
    Endif
   Endif
  Endif
 Next
Endif
If ERREUR : Return : Endif
If NBCLA<=0 & [L]TYPPRO="PRO"
 NBCLA = 1
 TABCLA(NBCLA) = [L]CODCLA1
Endif
If [L]TYPPRO="GRP"
 NBCLA = 1
 TABCLA(NBCLA) = [L]CODCLA1
 Read [ACLA]ACLA0 = TABCLA(NBCLA)
 If !fstat
  Read [ACLAC]ACLAC0=TABCLA(NBCLA);OBJ
  If fstat
   Raz TABCLA,TABPTR,NBCLA
  Endif
 Elsif [F:ACLAF]LNKCLA<>""
  Raz TABCLA,TABPTR,NBCLA
 Endif
Elsif [L]TYPPRO="PRO"
 Read [F:ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
 If !fstat & (func AFNC.ACTIVDOS([L]DOSSIER,[F:ACLAF]ACTFLD)>0 | AFCASW<>0)
  If [F:ACLAF]FLDGRP<>"" & [F:ACLAF]LNKCLA=""
   If (len([L]VALEUR)-(len([F:ACLAF]FLDGRP)+len(OBJ))<0) or (right$([L]VALEUR,len([L]VALEUR)-(len([F:ACLAF]FLDGRP)+len(OBJ)))<> [F:ACLAF]FLDGRP+"."+OBJ) : # len( COl.obj ) +1
    Raz TABCLA,TABPTR,NBCLA
   Endif
  Endif
 Elsif !fstat
  Raz TABCLA,TABPTR
  NBCLA = -1
 Else
 Raz TABCLA,TABPTR,NBCLA
 Endif
Endif
Return

$DECOD_FLDREP
NBCLA = 1
TABCLA(NBCLA)= ""
If !AFCASW or AFCASW=1
 Read [ASWF]ASWF0 = [L]CODREP;OBJ
 If !fstat & (func AFNC.ACTIVDOS([L]DOSSIER,[ASWF]ACTFLD)>0 | AFCASW<>0)
  If [ASWF]FLDGRP<>""
   If (len([L]VALEUR)-(len([ASWF]FLDGRP)+len(OBJ))<0) or (right$([L]VALEUR,len([L]VALEUR)-(len([ASWF]FLDGRP)+len(OBJ)))<> [ASWF]FLDGRP+"."+OBJ) : # len( COl.obj ) +1
    Raz TABCLA,TABPTR,NBCLA
   Endif
  Endif
 Elsif !fstat
  Raz TABCLA,TABPTR
  NBCLA = -1
 Else
  Raz TABCLA,TABPTR,NBCLA
 Endif
Elsif AFCASW=2
 J=find(OBJ,[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
 If J>0
  If [M:ASW9]FLDGRP(J-1)<>"" & TABPTR(1)<> [M:ASW9]FLDGRP(J-1)
   Raz TABCLA,TABPTR,NBCLA
  Endif
 Elsif !J
  Raz TABCLA,TABPTR,NBCLA
 Endif
Endif
Return

#---------------------------------
$AFFZO_ASW5
If dim(AMA)<1 : Gosub DEFVAR From WGOASW : Endif
Local Integer L_ASW5 : L_ASW5=find("ASHW5",NOMMSK)
 If L_ASW5>0 & AMA(L_ASW5-1)>0
  Affzo [M:ASW5]10
 Endif
Return
#---------------------------------
$AFFZO_ASW6
If dim(AMA)<1 : Gosub DEFVAR From WGOASW : Endif
Local Integer L_ASW6 : L_ASW6=find("ASHW6",NOMMSK)
 If L_ASW6>0 & AMA(L_ASW6-1)>0
  Affzo [M:ASW6]5
 Endif
Return

#---------------------------------
$SORTA_ASW2
Sorta [M]NBRSEC [M]NBRSEC Order By [M]NIVSEC([S]indice)
Sorta [M]NBRBLC [M]NBRBLC Order By [M]ANIVSEC([S]indice),[M]NIVBLC([S]indice)
Return
#---------------------------------
$SORTA_ASW3
Sorta  [M:ASW3]WNBRPARMET  [M:ASW3]WNBRPARMET
& Order By [M:ASW3]WCODMET(indice),[M:ASW3]WNOPARMET(indice),[M:ASW3]WCODPARMET(indice)
Return
#---------------------------------
$SORTA_ASW4
Sorta [M:ASW4]NBRPRO [M:ASW4]NBRPRO
& Order By [M:ASW4]ASECPRO([S]indice),[M:ASW4]ABLCPRO([S]indice),[M:ASW4]ORDPRO([S]indice)
Return
#---------------------------------
$SORTA_ASW5
Sorta [M:ASW5]NBRPAR [M:ASW5]NBRPAR
& Order By [M:ASW5]TYPPAR([S]indice),[M:ASW5]AFFLNK([S]indice),[M:ASW5]CODFLD([S]indice),
&      [M:ASW5]CODLNK([S]indice),[M:ASW5]TYPKEY([S]indice),[M:ASW5]NUMPAR([S]indice),[M:ASW5]CODPAR(indice)
Return
#---------------------------------
$SORTA_ASW6
Sorta  [M:ASW6]NBRLNK [M:ASW6]NBRLNK
& Order By [M:ASW6]AFFLNK([S]indice),[M:ASW6]ANCLNK([S]indice),[M:ASW6]MENLNK([S]indice),[M:ASW6]ORDLNK([S]indice),[M:ASW6]CODLNK([S]indice)
Return
#---------------------------------

