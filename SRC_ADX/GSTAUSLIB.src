#** #############################################################################################
#*  Check if a given company or all companies of a given legislation are members of an active GST-Group
#*
#*  @param LEGISLATION      Variable Char     Companies of this legislation will be checked
#*
#*  @param Currency         Variable Char     Companies with this accounting currency will be checked
#*
#*  @param COMPANY          Variable Char     Company to check
#*
#*  @param FLGALLCPY        Value Tinyint  If this flag is set, all companies of the given legislation will be checked
#*
#*  @param FLGLOG           Value Tinyint  If this flag is set, a log file will be written and displayed in case of error
#*
#*  @param ERRCOD           Variable Tinyint  Error code in case of error
#*
#*! #############################################################################################
Subprog CHECKGSTGROUPCOMPANYMEMBER(LEGISLATION, CURRENCY, COMPANY, FLGALLCPY, FLGLOG, ERRCOD)
Variable Char LEGISLATION
Variable Char CURRENCY
Variable Char COMPANY
Value Integer FLGALLCPY
Value Integer FLGLOG
Variable Tinyint ERRCOD

  If clalev([F:CPY])=0   : Local File COMPANY    [CPY] : Endif
  If clalev([F:GSTGD])=0 : Local File GSTGRPD  [GSTGD] : Endif
  If clalev([F:GSTGH])=0 : Local File GSTGRP   [GSTGH] : Endif

  #open logfile if FLGLOG is true
  If  FLGLOG = 1
    Call OUVRE_TRACE("") From LECFIC
  Endif

  Local Char NOMEMBERCPY(255)
  #check for a specific company
  If FLGALLCPY = 0
# 2018-03-02 DNE INSERT BEGIN (X3-78886)
      # .. but only if the company has AUSVAT parameter set to YES!
      If func AFNC.PARAM( "AUSVAT", COMPANY ) = "2"
# 2018-03-02 DNE INSERT END
          # Check if company is a member of an active group
          Link [F:GSTGD] With
&             [F:CPY]CPY0 = [F:GSTGD]CPY
&           ,[F:GSTGH]GSTGH0  = [F:GSTGD]CODGSTGRP
&         As [LNK]
&         Where [F:GSTGH]ENAFLG = 2
&           and [F:GSTGD]CPY = COMPANY

          If rowcount([LNK]) = 0 #if company is not a member of an active group write logifile or show error message
              ERRCOD = 1
              If FLGLOG = 1
                  Call ECR_TRACE(func AFNC.MES1( mess(27,7704,1), COMPANY), 1 )  From GESECRAN #'Company '$1$' not assigned to a GST group.'
              Else
                  Call ERREURT(func AFNC.MES1( mess(27,7704,1), COMPANY) , 1 ) From GESECRAN #'Company '$1$' not assigned to a GST group.'
                  End
              Endif
          Endif
# 2018-03-02 DNE INSERT BEGIN (X3-78886)
      Endif
# 2018-03-02 DNE INSERT END
  Else # Check for all companies of a given legislation and currency
      Filter [F:CPY] Where [F:CPY]LEG = LEGISLATION and [F:CPY]ACCCUR = CURRENCY # X3-75779 Accounting currency of company must be 'AUD'.
        For [F:CPY] #loop over companies and check if the company is a member of an active group.
# 2018-03-02 DNE INSERT BEGIN (X3-78886)
            # .. but only if the company has AUSVAT parameter set to YES!
            If func AFNC.PARAM( "AUSVAT", [F:CPY]CPY ) = "2"
# 2018-03-02 DNE INSERT END
                Link [F:GSTGD] With
&                 [F:GSTGH]GSTGH0  = [F:GSTGD]CODGSTGRP
&                 As [LNK]
&                 Where [F:GSTGH]ENAFLG = 2
&                 and [F:GSTGD]CPY = [F:CPY]CPY

                # if company not member of an active group write to logfile or to errormessage
                If rowcount([LNK]) = 0
                  ERRCOD = 1
                  If FLGLOG = 1
                    Call ECR_TRACE(func AFNC.MES1( mess(27,7704,1), [F:CPY]CPY), 1 )  From GESECRAN #'Company '$1$' not assigned to a GST group.'
                  Else
                    If [L]NOMEMBERCPY = ""
                      [L]NOMEMBERCPY = [L]NOMEMBERCPY + [F:CPY]CPY
                    Else
                      [L]NOMEMBERCPY = [L]NOMEMBERCPY + "," - [F:CPY]CPY
                    Endif
                  Endif
                Endif
# 2018-03-02 DNE INSERT BEGIN (X3-78886)
            Endif
# 2018-03-02 DNE INSERT END
        Next
        # if no log, show errormessage
# 2018-03-02 DNE MODIF BEGIN
        If ERRCOD <> 0 and FLGLOG = 0
# 2018-03-02 DNE MODIF ORIG
#        If FLGLOG = 0
# 2018-03-02 DNE MODIF END
          Call ERREURT(func AFNC.MES1( mess(27,7704,1), [L]NOMEMBERCPY) , 1 ) From GESECRAN #'Company '$1$' not assigned to a GST group.'
        Endif
    Filter [F:CPY]
  Endif
  #close and display logfile
  If FLGLOG = 1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End



#** #############################################################################################
#*  Check if a given GST-Group or all GST-Groups has one member company marked as head entity
#*
#*
#*  @param GSTGROUP          Variable Char  GST-Group to check
#*
#*  @param FLGALLCPY        Value Tinyint  If this flag is set, all companies of the given legislation will be checked
#*
#*  @param FLGLOG           Value Tinyint  If this flag is set, a log file will be written and displayed in case of error
#*
#*  @param ERRCOD           Variable Tinyint  Error code in case of error
#*
#*! #############################################################################################
Subprog CHECKHEADENTITY(GSTGROUP, FLGALLCPY, FLGLOG, ERRCOD)
Variable Char GSTGROUP
Value Tinyint FLGALLCPY
Value Tinyint FLGLOG
Variable Tinyint ERRCOD

  If clalev([F:GSTGD])=0 : Local File GSTGRPD  [GSTGD] : Endif
  If clalev([F:GSTGH])=0 : Local File GSTGRP   [GSTGH] : Endif

  #open logfile if FLGLOG is true
  If FLGLOG
    Call OUVRE_TRACE("") From LECFIC
  Endif

  Local Char NOHEADGRP(255)

  If !FLGALLCPY #check for a specific GST-GROUP
    Filter [F:GSTGD] Where [F:GSTGD]CODGSTGRP = GSTGROUP and [F:GSTGD]GSTHEA = 2
    Read [F:GSTGD]GSTGD0 First
    #If rowcount([F:GSTGD]) = 0
    If fstat #if GST-Group has no head-entity write logfile or show error message
      ERRCOD = 1
      If FLGLOG
        Call ECR_TRACE(func AFNC.MES1( mess(28,7704,1), GSTGROUP), 1 )  From GESECRAN #'GST group '$1$' has no head entitiy assigned'
      Else
        Call ERREURT(func AFNC.MES1( mess(28,7704,1), GSTGROUP) , 1 ) From GESECRAN #'GST group '$1$' has no head entitiy assigned'
        End
      Endif
    Endif
  Else
    For [F:GSTGH]
      Filter [F:GSTGD] Where [F:GSTGD]CODGSTGRP = [F:GSTGH]CODGSTGRP and [F:GSTGD]GSTHEA = 2
      Read [F:GSTGD]GSTGD0 First
      If fstat #if GST-Group has no head-entity write logfile or show error message
        If FLGLOG
          Call ECR_TRACE(func AFNC.MES1( mess(28,7704,1), [F:GSTGH]CODGSTGRP), 1 )  From GESECRAN #'GST group '$1$' has no head entitiy assigned'
        Else
          If NOHEADGRP = ""
            [L]NOHEADGRP = [L]NOHEADGRP + [F:GSTGH]CODGSTGRP
          Else
            [L]NOHEADGRP = [L]NOHEADGRP + "," - [F:GSTGH]CODGSTGRP
          Endif
       Endif
    Endif
    Next
    If !FLGLOG
      Call ERREURT(func AFNC.MES1( mess(28,7704,1), [L]NOHEADGRP) , 1 ) From GESECRAN #'GST group '$1$' has no head entitiy assigned'
    Endif
    Filter [F:GSTGD]
  Endif
  #close and display logfile
  If FLGLOG
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

End

#** #############################################################################################
#*  Check if a given GST-Group or all GST-Groups has duplicated group members
#*
#*
#*  @param GSTGROUP          Variable Char  GST-Group to check
#*
#*  @param FLGALLCPY        Value Tinyint  If this flag is set, all GST-Groups will be checked
#*
#*  @param FLGLOG           Value Tinyint  If this flag is set, a log file will be written and displayed in case of error
#*
#*  @param ERRCOD           Variable Tinyint  Error code in case of error
#*
#*! #############################################################################################
Subprog CHECKDUPLICATEGROUPMEMBER(GSTGROUP, FLGALLCPY, FLGLOG, ERRCOD)
Variable Char GSTGROUP
Value Tinyint FLGALLCPY
Value Tinyint FLGLOG
Variable Tinyint ERRCOD

  If clalev([F:GSTGD])=0 : Local File GSTGRPD  [GSTGD] : Endif
  If clalev([F:GSTGD2])=0 : Local File GSTGRPD [GSTGD2] : Endif
  If clalev([F:GSTGH])=0 : Local File GSTGRP   [GSTGH] : Endif

  #open logfile if FLGLOG is true
  If FLGLOG
    Call OUVRE_TRACE("") From LECFIC
  Endif

  Local Char DUPLICATEDMEM(255)

  If !FLGALLCPY #check for a specific GST-GROU
    Filter [F:GSTGD] Where [F:GSTGD]CODGSTGRP = GSTGROUP
    For [F:GSTGD]
      Filter [F:GSTGD2] Where [F:GSTGD2]CPY = [F:GSTGD]CPY
      If rowcount([F:GSTGD2]) > 1
        ERRCOD = 1
        If FLGLOG
          Call ECR_TRACE(func AFNC.MES2( mess(29,7704,1),[F:GSTGD]CPY ,GSTGROUP), 1 )  From GESECRAN #'Company '$1$' must only be assigned once in GST group '$2$''
        Else
          Call ERREURT(func AFNC.MES2( mess(29,7704,1),[F:GSTGD]CPY, GSTGROUP) , 1 ) From GESECRAN #'Company '$1$' must only be assigned once in GST group '$2$''
        Endif
        Break
      Endif
    Next
  Else
    For [F:GSTGH]
      Filter [F:GSTGD]
      Filter [F:GSTGD] Where [F:GSTGD]CODGSTGRP = [F:GSTGH]CODGSTGRP
      For [F:GSTGD]
        Filter [F:GSTGD2]
        Filter [F:GSTGD2] Where [F:GSTGD2]CPY = [F:GSTGD]CPY and [F:GSTGD2]CODGSTGRP = [F:GSTGH]CODGSTGRP
        If rowcount([F:GSTGD2]) > 1
          ERRCOD = 1
          If FLGLOG
            Call ECR_TRACE(func AFNC.MES2( mess(29,7704,1),[F:GSTGD]CPY ,[F:GSTGH]CODGSTGRP), 1 )  From GESECRAN #'Company '$1$' must only be assigned once in GST group '$2$''
          Else
            If DUPLICATEDMEM = ""
              [L]DUPLICATEDMEM = [L]DUPLICATEDMEM + [F:GSTGH]CODGSTGRP
            Else
              [L]DUPLICATEDMEM = [L]DUPLICATEDMEM + "," - [F:GSTGH]CODGSTGRP
            Endif
          Endif
          Break
        Endif
      Next
    Next
    If !FLGLOG
      Call ERREURT(func AFNC.MES1( mess(30,7704,1), [L]DUPLICATEDMEM) , 1 ) From GESECRAN
    Endif
    Filter [F:GSTGD]
    Filter [F:GSTGD2]
    Filter [F:GSTGH]
  Endif
  #close and display logfile
  If FLGLOG
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End


#** #############################################################################################
#*  Cleans up data for a given GST-Period
#*
#*
#*  @param GSTPERIOD          Variable Integer  GST-Period
#*
#*  @param GSTGRP             Variable Char  GST-GROUP
#*
#*  @param ERRCOD             Variable Tinyint  Error code in case of error
#*
#*! #############################################################################################
Subprog CLEANPERIODDATA(GSTPERIOD, GSTGRP, ERRCOD)
Variable Integer GSTPERIOD
Variable Char GSTGRP
Variable Tinyint ERRCOD

  If !clalev([F:DLVB])   : Local File DCLVATBOXH   [DLVB]   : Endif
  If !clalev([F:DLVBD])  : Local File DCLVATBOXDBD [DLVBD]  : Endif
  If !clalev([F:GSTGRPD]): Local File GSTGRPD[GSTGRPD] : Endif
  If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif
  If !clalev([F:DAE])    : Local File GACCENTRYD   [DAE]    : Endif
  Delete [F:DLVB] Where [F:DLVB]NUMRPT = GSTPERIOD and [F:DLVB]VATFNC = "DCLVATAUS"
  If fstat
    GOK = 0 : FIN = 0 : ERRCOD = 1 : Call FSTA("DLVB") From GLOCK
  Else
    For [F:GSTGRPD] Where [F:GSTGRPD]CODGSTGRP = GSTGRP
      Delete [F:DLVBD] Where [F:DLVBD]NUMRPT = GSTPERIOD and [F:DLVBD]CPY = [F:GSTGRPD]CPY
      If fstat
        GOK = 0 : FIN = 0 : ERRCOD = 2 : Call FSTA("DLVBD") From GLOCK
      Else
        For [HAE] Where NUMDCL = GSTPERIOD and CPY = [F:GSTGRPD]CPY
          Raz [F:HAE]NUMDCL
          Rewrite [F:HAE]
          If fstat
           GOK  = 0 : FIN = 0 : ERRCOD = 3 :Call FSTA("HAE") From GLOCK
           Break
          Endif
          Update [F:DAE] Where [F:DAE]NUM = [F:HAE]NUM  With [F:DAE]AMTVAT = 0 # angre US X3-82831
          If fstat
           GOK  = 0 : FIN = 0 : ERRCOD = 4 :Call FSTA("DAE") From GLOCK
           Break
          Endif
        Next
      Endif
    Next
  Endif
End

