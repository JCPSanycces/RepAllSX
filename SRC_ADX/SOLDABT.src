#<AdxTL>@(#)6.0.0.0 $Revision$
# Issue X3-86594 - 2018-06-19 by FHA : Recurring entry - Currency rates not handled in other ledgers

Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","SOLDABT","SOLDABT",4,"") From GTRAITE
End
#X3-39795  MDJ   Manage ORIGIN and ORICOD fields in GL Entry
#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

##############################################################################
$OUVRE
Local Integer OK , AX , K , NOL , PTVENT , STAT
Local Char    CRITCPT(250) , CRITABT(250) , CRITECT(250)
Local Decimal SOLDEB, SOLDEBLED
Local Decimal MTANA , QTANA , NMONT , OMONT , COEFF , TOTAL , TOTQT
Local Integer LIGANA , MAXPER
Local Decimal EXERCICE , PERIODE
Local Decimal EDEB , EFIN , PDEB , PFIN
Local Integer E , PD , PF , TRA
Local Char    MESSA(80)
Local Char    SOCIETE(GLONCPY) , JOURNAL(GLONJOU), TYPEPCE(GLONGTE),DEVISE(GLONCUR),ACCOUNT(GLONGAC),BPR(GLONBPR)
Local Date    DAT
Local Char    TIT(30)
Local Integer STAECT
Local Char    LCCE(GLONCCE), LDIE(GLONDIE)
Local Integer LINSUBACC
Local Char    WDSP(10)
Local Integer TYPLED
Local Char    TZONE(10)(1..10)    : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)     : # Table of values for zones to be forced         #*X3-39795
Local Integer WTYPRAT             : # Issue X3-86594

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG =1  : GCURLEG = GDOSLEG : Endif

Gosub OUVFIC

Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]
Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1] , GACCENT2 [HAE2]
&        , VENTILE [VTL] , VENTILE2 [VT2] , SOLDABT [DIA]

TIT = mess(42,107,1) : # Solde des abonnements

Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp5") From GMEMO
Return


$OUVFIC
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
If clalev([F:GAF])=0  : Local File GACCFIX    [GAF]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
If clalev([F:HAE2])=0 : Local File GACCENTRY  [HAE2] : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif
If clalev([F:DAA2])=0 : Local File GACCENTRYA [DAA2] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:ANM])=0  : Local File ACODNUM    [ANM]  : Endif
If clalev([F:AVN])=0  : Local File AVALNUM    [AVN]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:TUN])=0  : Local File TABUNIT    [TUN]  : Endif
If clalev([F:DSP])=0  : Local File CADSP      [DSP]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
If clalev([F:BAL2])=0  : Local File BALANCE   [BAL2] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:GDE])=0  : Local File GDIAENTRY  [GDE]  : Endif
Return

##############################################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]TOUSOC,[M:DIA]CPY,[M:DIA]TYPGEN,SAI) From CPTDIV2
If SAI : Return : Endif

Local Integer OK
If [M:DIA]TOUSOC=2
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return


##############################################################################
$EXEC

If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
 Call TRACE_MASQUE("SOLDABT","DIA",nomap) From GTRAITE
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

# Loop of Recurring entries
CRITABT = 'COD>="'+[M:DIA]ABTDEB+'"'
If [M:DIA]ABTFIN<>""
 CRITABT -= '& COD<="'+[M:DIA]ABTFIN+'"'
Endif
If [M:DIA]TOUUSR<>2
 CRITABT -= '& (UPDUSR="'+[M:DIA]USER+'" | (UPDUSR="" & CREUSR="'+[M:DIA]USER+'"))'
Endif
For [GAF]GAF0 Where evalue(CRITABT)
 TRA = 0
 # Take back template journal
 If [F:HAE2]TYP<>[F:GAF]REFTYP or [F:HAE2]NUM<>[F:GAF]REFNUM
  Read [HAE2]HAE0 = [F:GAF]REFTYP;[F:GAF]REFNUM
 Endif
 OK = 1
 If [M:DIA]TOUSOC<>2 & [M:DIA]CPY<>[F:HAE2]CPY : OK = 0  : Endif
 If [M:DIA]TOUSIT<>2 & [M:DIA]FCY<>[F:HAE2]FCY : OK = 0  : Endif
 # If all cpy, take into account the legislation filled in : leg cpy = screen leg
 If OK=1 & [M:DIA]TOUSOC=2
  Call LEC_CPY([F:HAE2]CPY) From CPTLEC
  OK *= ([F:CPY]LEG = GCURLEG)
 Endif
 If OK
  For [HAE1] Where REFSIM="AS"+[F:GAF]COD
&  & ACCDAT>=[M:DIA]DATDEB & ACCDAT<=[M:DIA]DATFIN
   If GTRACE<>""
    Call ECR_TRACE([F:GAF]COD-mess(43,107,1),1) From GESECRAN
   Endif
   TRA = 1 : OK = 0 : Break
  Next
 Endif
 If OK
  Gosub DELABT
  If GOK>0
   TYPLED  = [M:DIA]LEDTYP
   # Look through the line of the template journal
   For [DAE2]DAE0 Where LEDTYP=[M:DIA]LEDTYP & TYP=[F:HAE2]TYP & NUM=[F:HAE2]NUM
    Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
    If [F:GAC]SUBACC<>""
     Gosub TRT_COMPTE
    Endif
   Next
  Endif
 Endif
 If TRA
  If GTRACE<>"" : Call ECR_TRACE(string$(70,"-"),0) From GESECRAN : Endif
 Endif
Next

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

#######################################################
# Traitement d'un couple compte*abonnement
#######################################################
$TRT_COMPTE
# Solde du compte
Call SETMAINREF([F:HAE2]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call GETPERSOC([F:HAE2]CPY,GTYPGEN,[M:DIA]DATDEB,EDEB,PDEB) From CPTSUB
If PDEB=0 | EDEB=0
 If GTRACE<>""
  Call ECR_TRACE([F:HAE2]CPY-format$("D:"+GFMDAT4,[M:DIA]DATDEB)
&  -mess(1,104,1),1) From GESECRAN
 Endif
 TRA = 1
 Return
Endif
Call GETPERSOC([F:HAE2]CPY,GTYPGEN,[M:DIA]DATFIN,EFIN,PFIN) From CPTSUB
If PFIN=0 | EFIN=0
 If GTRACE<>""
  Call ECR_TRACE([F:HAE2]CPY-format$("D:"+GFMDAT4,[M:DIA]DATFIN)
&  -mess(1,104,1),1) From GESECRAN
 Endif
 TRA = 1
 Return
Endif
Gosub DEVISE
Return

$DEVISE
For [BAL2]BAL2(2) Where CPY=[F:HAE2]CPY & FCY=[F:DAE2]FCYLIN & LEDTYP=[F:DAE2]LEDTYP & ACC=[F:GAC]SUBACC
&                      & BPR=[F:GAC]SUBBPR
 DEVISE   = [F:BAL2]CUR
 ACCOUNT  = [F:BAL2]ACC
 BPR      = [F:BAL2]BPR
 SOLDEB   = 0
 SOLDEBLED= 0
 For E=EDEB To EFIN
  Filter [PER] Where CPY=[F:HAE2]CPY & LEDTYP=[F:DAE2]LEDTYP & FIYNUM=E
  Read [PER]PER0 Last
  Filter [PER]
  MAXPER = [F:PER]PERNUM
  Read [BAL]BAL0 = [F:DAE2]LEDTYP;[F:DAE2]CPY;[F:DAE2]FCYLIN;E;ACCOUNT;BPR;DEVISE
  If !fstat
   PD = 1 : PF = MAXPER
   If E=EDEB
    PD = PDEB
    If PD=1 : PD = 0 : Endif
   Endif
   If E=EFIN
    PF = PFIN
   Endif
   SOLDEB += sum([F:BAL]DEB(PD..PF))-sum([F:BAL]CDT(PD..PF))
   SOLDEBLED += sum([F:BAL]DEBLED(PD..PF))-sum([F:BAL]CDTLED(PD..PF))
  Endif
 Next E
 If SOLDEB<>0
  If GTRACE<>""
   Call ECR_TRACE(mess(8,104,1)-[F:GAC]ACC-mess(14,104,1)-[F:GAF]COD,0) From GESECRAN
  Endif
  TRA = 1
  Gosub GEN_PIECE
 Endif
Next
Return

## Génération de la pièce de solde
$GEN_PIECE
Raz [M:HAE0] , [M:HAE1] , [M:HAE2]
Raz STAT
[M:HAE0] = [F:HAE2]
[M:HAE1] = [F:HAE2]

Call LEC_GDE([M:HAE0]DACDIA) From CPTLEC
[M:HAEF]TYPENT = [F:GDE]TYPENT # Type de saisie : En colonne, En ligne, En onglet

## Initialisation masque de référence [HAEF]
Call INIMSKFMT3([M]FCY,[M:HAEF]TYPENT,[M]DACDIA,[M:DIA]TYPPCE,[M:DIA]DATPCE,STAT) From SUBGASA

# Add Legislation in the trace
SOCIETE = [M:HAE0]CPY
JOURNAL = [M:DIA]JOU
DAT     = [M:DIA]DATPCE
TYPEPCE = [M:DIA]TYPPCE
mkstat  = 0
Gosub VERFDAT
If mkstat
 If GTRACE<>""
  Call ECR_TRACE(SOCIETE-GCURLEG-JOURNAL-format$("D:"+GFMDAT4,DAT)-GMESSAGE,1) From GESECRAN
 Endif
 TRA = 1
 Return
Endif
[M:HAE0]NUM = ""
[M:HAE0]TYP = [M:DIA]TYPPCE
[M:HAE0]ACCDAT = [M:DIA]DATPCE
[M:HAE0]JOU = [M:DIA]JOU
Call GETPERSOC([M:HAE0]CPY,GTYPGEN,[M:DIA]DATPCE,EXERCICE,PERIODE) From CPTSUB
[M:HAE0]FIY = EXERCICE
[M:HAE0]PER = PERIODE
[M:HAE0]FCY = [F:DAE2]FCYLIN
[M:HAE1]CUR = DEVISE
[M:HAE1]ENTDAT = [M:HAE0]ACCDAT
[M:HAE1]DUDDAT = [M:HAE0]ACCDAT
[M:HAE1]VALDAT = [M:HAE0]ACCDAT
[M:HAE1]RVS = 1
If [M:DIA]TYPGEN=1   : # Réél
 [M:HAE0]CAT = 1

 If [M:DIA]TOUSOC=2 & func AFNC.PARAM("FRADGI",[M:HAE0]CPY)="2"
  STAECT = 2
 Else
  STAECT = [M:DIA]ECTSTA
 Endif
 [M:HAE0]STA = STAECT : # Provisoire/définitif

Else
 [M:HAE1]REFSIM = "SS"+[F:GAF]COD
 [M:HAE0]CAT    = [M:DIA]TYPGEN   : # Simulation active ou non
Endif
[M:HAE1]DESVCR = mess(44,107,1)-[F:GAF]COD-[F:GAC]ACC

# La propagation sera effectuée via le VALPCE
#  => Propagation automatique des référentiels via les règles de saisie de pièces comptables.
[M:HAE1]FLGGEN = 3

# Solde abonnement: Ligne compte de charge  (NOL à 0 la 1éré fois)
NOL = 0
PTVENT = 1

# Issue X3-86594
# Init of the currency rate vars using $INIT_COURS_LED from TRTPCE
# Init of RATDAT (Currency rate date), BPRDATVCR (Document Date), TYPRAT (Currency rate type), BANDAT (italian law)
Raz [M:HAE1]RATDIV
Raz [M:HAE1]RATMLT
[M:HAE1]RATDAT    = [M:HAE0]ACCDAT
[M:HAE1]BPRDATVCR = [M:HAE0]ACCDAT
[M:HAE1]BANDAT    = [M:HAE0]ACCDAT
Call INIT_RAT_SOLABT([M:DIA]TYPPCE,[M:HAE0]CPY)
# End issue X3-86594

nolign = NOL+1
[M:HAE2] = [F:DAE2]

If [M:HAEF]TYPENT=2  # saisie ligne
 [M:HAE2]ACC1(NOL) = [F:DAE2]ACC
Else
 #on recherche les comptes sur tous les référentiels de la pièce modèle
 I = find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 Assign "[M:HAE2]ACC"+num$(I)+"(NOL)" With [F:DAE2]ACC
 For [DAE3]DAE0 Where LEDTYP<>[F:DAE2]LEDTYP & TYP=[F:DAE2]TYP & NUM=[F:DAE2]NUM &  LIN=[F:DAE2]LIN
  I = find([F:DAE3]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If I>0 : Assign "[M:HAE2]ACC"+num$(I)+"(NOL)" With [F:DAE3]ACC : Endif
  If [F:DAE3]DSP<>"" : WDSP=[F:DAE3]DSP : Endif
  ## Pour la ligne du compte de charge, le code flux & partenaire sont initialisés via le transclasse [M:HAE2] = [F:DAE2]
  ## ssi le référentiel sur lequel est lancé l'abonnement est coché 'Consolisation'. Dans le cas contraire, il faut
  ## prévoir la reprise sur le référentiel qui porte ces informations
  If [M:HAE2]CSLFLO(NOL)="" & [F:DAE3]CSLFLO<>"" : [M:HAE2]CSLFLO(NOL) = [F:DAE3]CSLFLO :  Endif
  If [M:HAE2]CSLBPR(NOL)="" & [F:DAE3]CSLBPR<>"" : [M:HAE2]CSLBPR(NOL) = [F:DAE3]CSLBPR :  Endif
 Next
Endif

Raz [M:HAE2]ACCNUM
[M:HAE2]DES(NOL) = mess(44,107,1)-[F:GAF]COD
OMONT = [F:DAE2]AMTCUR

If SOLDEB>0
 [M:HAE2]DEB(NOL) = SOLDEB       : [M:HAE2]CDT(NOL) = 0
Else
 [M:HAE2]DEB(NOL) = 0   : [M:HAE2]CDT(NOL) = -SOLDEB
Endif

NMONT = abs(SOLDEB)
COEFF = NMONT/OMONT
TOTAL = 0 : TOTQT = 0
Call LEC_GAC([F:DAE2]ACC,[F:DAE2]COA) From CPTLEC
If [F:GAC]UOM<>""
 Call LEC_TUN([F:GAC]UOM) From CPTLEC
 [M:HAE2]QTY(NOL) = arr([M:HAE2]QTY(NOL)*COEFF,10^-[F:TUN]UOMDEC)
Endif

If SOLDEBLED >0
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLDEBLED
Else
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLDEBLED
Endif

If sgn(SOLDEB)=sgn(SOLDEBLED)
 Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLDEBLED)
Else
 Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLDEBLED
Endif
Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

[M:HAE2]FCYLIN(NOL) = [F:DAE2]FCYLIN
LIGANA = 0
If WDSP<>"" : [M:HAE2]DSP(NOL)=WDSP : Endif

# Selon la répartition et le type de réf , on remplit le mask des ventilations [M:VT2]
If [M:HAE2]DSP(NOL)=""
 If [F:GDE]TYPENT=1
  # Saisie en colonne
  FILTDAA =  "LIN="+num$([F:DAE2]LIN)+"& find([F:DAA2]LEDTYP,GTYPLED(1..GNBTYPLED))"
 Else
  #saisie en ligne
  If find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   FILTDAA = "LIN="+num$([F:DAE2]LIN)+"& find([F:DAA2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))"
  Endif
 Endif

 INDAXE = 0
 AXE = 0
 For [DAA2]DAA2(3) Where TYP=[F:DAE2]TYP & NUM=[F:DAE2]NUM & evalue(FILTDAA)
  For [DAA2]DAA2(4)
   LIGANA += 1
   # Flag de présence d'analytique sur la ligne de pièce comptable
   If !INDAXE : INDAXE = LIGANA  : Endif
   For [DAA2]DAA2
    MTANA = arr(COEFF*([F:DAA2]AMTCUR+TOTAL),[F:TCU]CURRND)
&          -arr(COEFF*TOTAL,[F:TCU]CURRND)
    TOTAL += [F:DAA2]AMTCUR

    [M:VT2]TBAMT(LIGANA) = MTANA

    QTANA = arr(COEFF*([F:DAA2]QTY+TOTQT),[F:TCU]CURRND)
&         -arr(COEFF*TOTQT,[F:TCU]CURRND)
    TOTQT += [F:DAA2]QTY
    [M:VT2]TBQTY(PTVENT) = QTANA

    For I=1 To dim([F:DAA2]CCE)
     AXE = find(evalue("[F:DAA2]DIE"+"("+num$(I-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
     If AXE>0
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:DAA2]CCE(I-1)
     Endif
    Next I
   Next
  Next
  If LIGANA
   If [M:HAE2]PTV(NOL)=0 : [M]PTV(NOL) = INDAXE : Endif
   If [M:HAE2]PTF(NOL)=0 : [M]PTF(NOL) = LIGANA : Endif
   [M:HAE2]DSP(NOL) = "$"
  Else
   [M:HAE2]PTV(NOL) = 0 : [M:HAE2]PTF(NOL) = 0
  Endif
 Next
Endif

[M:VT2]PTVENT = max([M:VT2]PTVENT,LIGANA+1)

If [M:HAEF]TYPENT = 2 : # Saisie ligne
 [M:HAE2]CPA1(NOL) = [F:GAC]SUBACC
Else
 I = find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 Assign "[M:HAE2]CPA"+num$(I)+"(NOL)" With [F:GAC]SUBACC
Endif

#On passe sur la ligne suivante (NOL=2) où il y a le compte d'abonnement
NOL += 1

# Ligne sur le compte d'abonnement
If [M:HAEF]TYPENT = 2 : # Saisie ligne
 [M:HAE2]LEDTYP(NOL) = [F:DAE2]LEDTYP
 [M:HAE2]ACC1(NOL) = [F:GAC]SUBACC
Else
 I = find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 Assign "[M:HAE2]ACC"+num$(I)+"(NOL)" With [F:GAC]SUBACC
 # On récupère le numéro de la ligne sur laquelle se trouve sur le compte
 # et la répartition pour le compte d'abonnement
 Filter [DAE3] Where LEDTYP=[F:DAE2]LEDTYP & TYP=[F:DAE2]TYP & NUM=[F:DAE2]NUM &  ACC=[F:GAC]SUBACC
 Read [DAE3]First
 LINSUBACC = [F:DAE3]LIN
 [M:HAE2]DSP(NOL) = [F:DAE3]DSP
 [M:HAE2]CSLFLO(NOL) = [F:DAE3]CSLFLO
 [M:HAE2]CSLBPR(NOL) = [F:DAE3]CSLBPR
 Filter [DAE3]
 #on recherche les comptes sur tous les référentiels de la pièce modèle
 If !fstat
  For [DAE3]DAE0 Where LEDTYP<>[F:DAE2]LEDTYP & TYP=[F:DAE2]TYP & NUM=[F:DAE2]NUM &  LIN=LINSUBACC
   I = find([F:DAE3]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If I>0 : Assign "[M:HAE2]ACC"+num$(I)+"(NOL)" With [F:DAE3]ACC : Endif
   If [F:DAE3]DSP<>"" : WDSP=[F:DAE3]DSP : Endif
   If [M:HAE2]CSLFLO(NOL) ="" & [F:DAE3]CSLFLO<>"" : [M:HAE2]CSLFLO(NOL) = [F:DAE3]CSLFLO :  Endif
   If [M:HAE2]CSLBPR(NOL) ="" & [F:DAE3]CSLBPR<>"" : [M:HAE2]CSLBPR(NOL) = [F:DAE3]CSLBPR :  Endif
  Next
 Endif
Endif

[M:HAE2]BPR(NOL) = [F:GAC]SUBBPR
Read [GAC2]GAC0 = [F:GAC]COA;[F:GAC]SUBACC
If [F:GAC]SUBBPR<>""
 If [M:HAEF]TYPENT = 2 : # Saisie ligne
  [M:HAE2]SAC1(NOL) = [F:GAC2]ACCSHO
 Else
  I = find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  Assign "[M:HAE2]SAC"+num$(I)+"(NOL)" With [F:GAC2]ACCSHO
 Endif
Endif

If [F:GAC2]FLGVAT<>1
 [M:HAE2]TAX(NOL) = [F:GAC2]VAT
Endif
[M:HAE2]DES(NOL) = mess(44,107,1)-[F:GAC]ACC
If SOLDEB>0
 [M:HAE2]CDT(NOL) = SOLDEB : [M:HAE2]DEB(NOL) = 0
Else
 [M:HAE2]CDT(NOL) = 0 : [M:HAE2]DEB(NOL) = -SOLDEB
Endif

If SOLDEBLED >0
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLDEBLED
Else
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLDEBLED
Endif

If sgn(SOLDEB)=sgn(SOLDEBLED)
 Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLDEBLED)
Else
 Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLDEBLED
Endif
Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

[M:HAE2]FCYLIN(NOL) = [F:DAE2]FCYLIN

If [M:HAEF]TYPENT = 2 : # Saisie ligne
 [M:HAE2]CPA1(NOL) = [F:GAC]ACC
Else
 I = find([F:DAE2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 Assign "[M:HAE2]CPA"+num$(I)+"(NOL)" With [F:GAC]ACC
Endif

If WDSP<>"" : [M:HAE2]DSP(NOL) = WDSP : Endif

#Selon la répartition et le type de réf , on remplit le mask des ventilations [M:VT2]
If [M:HAE2]DSP(NOL)=""
 If [F:GDE]TYPENT=1
  # Saisie en colonne
  FILTDAA =  "LIN="+num$([F:DAE3]LIN)+"& find([F:DAA2]LEDTYP,GTYPLED(1..GNBTYPLED))"
 Else
  # Saisie en ligne
  If find([F:DAE3]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   FILTDAA = "LIN="+num$([F:DAE3]LIN)+"& find([F:DAA2]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))"
  Endif
 Endif

 INDAXE = 0
 AXE = 0
 For [DAA2]DAA2(3) Where TYP=[F:DAE3]TYP & NUM=[F:DAE3]NUM & evalue(FILTDAA)
  For [DAA2]DAA2(4)
   LIGANA += 1
   If !INDAXE : INDAXE = LIGANA  : Endif   # Flag de présence d'analytique sur la ligne de pièce comptable
   For [DAA2]DAA2
    MTANA = arr(COEFF*([F:DAA2]AMTCUR+TOTAL),[F:TCU]CURRND)
&         -arr(COEFF*TOTAL,[F:TCU]CURRND)
    TOTAL += [F:DAA2]AMTCUR

    [M:VT2]TBAMT(LIGANA) = MTANA

    QTANA = arr(COEFF*([F:DAA2]QTY+TOTQT),[F:TCU]CURRND)
&         -arr(COEFF*TOTQT,[F:TCU]CURRND)
    TOTQT += [F:DAA2]QTY
    [M:VT2]TBQTY(PTVENT) = QTANA
    #Assigner les sections de la ventilation pour le mask [M:VT2]
    For I=1 To dim([F:DAA2]CCE)
     AXE = find(evalue("[F:DAA2]DIE"+"("+num$(I-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
     If AXE>0
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(LIGANA)+")" With [F:DAA2]CCE(I-1)
     Endif
    Next I
   Next
  Next
  If LIGANA
   If [M:HAE2]PTV(NOL)=0 : [M]PTV(NOL) = INDAXE : Endif
   If [M:HAE2]PTF(NOL)=0 : [M]PTF(NOL) = LIGANA : Endif
   [M:HAE2]DSP(NOL) = "$"
  Else
   [M:HAE2]PTV(NOL) = 0 : [M:HAE2]PTF(NOL) = 0
  Endif
 Next
Endif

[M:VT2]PTVENT = max([M:VT2]PTVENT,LIGANA+1)

NOL += 1
[M:HAE2]NBLIG = NOL
If dim([M]DOEPTR)>0 : [M]DOEPTR([M:HAE2]NBLIG-1) = 1 : Endif

Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
 Gosub MESSAGE From CPTAUTO
 Call ECR_TRACE(MESSA,1) From GESECRAN
Else
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
Return

$TR1
GOK = 1
Trbegin [HAE]
 #*X3-39795 Call VALPIECER(STAT,MESSA) From CPTBATCH
 #*X3-39795  Validation with imposed values
 Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)
 Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced
 #TZONE(5)= "ORIGIN" : TVAL(5) = "3"        :# Import MWA
 TZONE(5)= "ORIGIN" : TVAL(5) = "2"         :# MWA
 TZONE(6)= "ORICOD" : TVAL(6) = "SOLABT"
 Call VALPIECER2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
 If STAT
  If GTRACE<>"" : Call ECR_TRACE(MESSA,1) From GESECRAN : Endif
  TRA = 1
 Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 If GTRACE<>""
  # Création pièce
  If [M:DIA]TYPGEN=1 & STAECT=2 & [M:DIA]ECTSTA<>STAECT
   Call ECR_TRACE(mess(40,107,1)-[F:HAE]TYP-[F:HAE]NUM
&    -format$("D:"+GFMDAT4,[F:HAE]ACCDAT)-"("+tolower(mess(192,107,1))+")",0) From GESECRAN
  Else
   Call ECR_TRACE(mess(40,107,1)-[F:HAE]TYP-[F:HAE]NUM
&    -format$("D:"+GFMDAT4,[F:HAE]ACCDAT),0) From GESECRAN
  Endif
 Endif
 TRA = 1
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$DELABT
GOK = 1
For [HAE1] Where REFSIM="SS"+[F:GAF]COD
 If GTRACE<>""
  # Annulation pièce
  Call ECR_TRACE([F:GAF]COD-mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
 Endif
 TRA = 1
 Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
 If GOK<1 : Break : Endif
Next
Return


########################################
Subprog AS_TOUSOC(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo TOUSOC
 Actzo CPY,TOUSIT
 mkstat = 1 : End
Endif
End

Subprog C_TOUSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]TOUSIT=2 : Affzo TOUSIT : Grizo TOUSIT
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo CPY,TOUSIT
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR)From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG(VALEUR)From CPTTRT
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]LEG
 [M]TYPPCE=""
 [M]JOU=""
Endif
End

Subprog AS_TOUSIT(VALEUR)
Variable Integer  VALEUR
If [M]TOUSOC=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2 : Effzo FCY : Grizo FCY : Else : Actzo FCY : Endif
End

Subprog C_TOUSIT(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR)From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]TOUSIT=2 : mkstat = 1 : End : Endif
End

Subprog C_FCY(VALEUR)
Variable Char VALEUR
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_TOUUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]USER="" : Affzo USER : Grizo USER : Else : Actzo USER : Endif
End

Subprog AS_USER(VALEUR)
Variable Char     VALEUR
If [M]TOUUSR = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GUSER : Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
If [M]TOUSOC=2
 OPTION=6 : # # Type de Référentiels non automatique selon le paramètre GLEDTYPAUT
 Call LEDTYP_CHOICE("",OPTION) From CPTDIV
Else
 #OPTION=6 : # # Référentiels flagués non automatique                    # X3-86594
 OPTION=7  : # # Référentiels flagués non automatique & flagué 'Général' # X3-86594
 Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
Endif
End

Subprog D_DATDEB(VALEUR)
Variable Date    VALEUR
Local Decimal EXE , PER
Local Char    CPY(GLONCPY)
If [M]TOUSOC=2
 [L]CPY = GDEFSOC
Else
 [L]CPY = [M]CPY
Endif
Call SETMAINREF([L]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call GETPERSOC([L]CPY,GTYPGEN,datesyst,EXE,PER) From CPTSUB
Read [FIY]FIY0 = [L]CPY;GTYPGEN;EXE
VALEUR = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End


Subprog C_DATPCE(VALEUR)
Variable Date    VALEUR
If [M]CPY<>""
 Local Decimal EXERCICE , PERIODE
 Local Char    SOCIETE(GLONCPY) , JOURNAL(GLONJOU), TYPEPCE(GLONGTE)
 Local Date    DAT
 SOCIETE = [M]CPY
 JOURNAL = [M]JOU
 TYPEPCE = [M]TYPPCE
 DAT = VALEUR
 Gosub VERFDAT
Endif
End

$VERFDAT
mkstat = 0
Call LEC_GTE_LEG(GCURLEG,TYPEPCE) From CPTLEC
Call CTLVLYDAT(DAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
If mkstat = 2 : Return : Endif
Return

Subprog AS_ECTSTA(VALEUR)
Variable Integer VALEUR
If [M]TYPGEN<>1 : VALEUR = 0 : mkstat = 2 : End : Endif
If [M]CPY<>""
 If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
  VALEUR = 2 : mkstat = 2 : End
 Endif
Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog AS_TYPPCE(VALEUR)
Variable Char    VALEUR()
If [M]TYPGEN=1 : VALPAR = "GAFTYPACC"
Else             VALPAR = "TYPACC"
Endif
If VALEUR=""
 If [M]FCY<>""
  Call PARAM([M]FCY,VALPAR,VALEUR) From ADOVAL
 Elsif [M]CPY<>""
  Call PARAM([M]CPY,VALPAR,VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,VALPAR,VALEUR) From CPTLEC
 Endif
Endif
End

Subprog C_TYPPCE(VALEUR)
Variable Char    VALEUR()
Local Integer RES
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat : End : Endif
If TYPGEN=1 & [F:GTE]VCRREA<>2
 GMESSAGE = mess(33,107,1)
 mkstat = 2 : End
Elsif TYPGEN>=2 & [F:GTE]VCRSIM<>2
 GMESSAGE = mess(32,107,1)
 mkstat = 2 : End
Endif
If [F:GTE]AUZLED([M]LEDTYP-1)=1
 GMESSAGE = mess(200,105,1)
 mkstat = 2 : End
Endif
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYPPCE<>""
 Call LEC_GTE_LEG(GCURLEG,[M]TYPPCE) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Local Integer RES
Call LEC_JOU_LEG(GCURLEG,VALEUR) From CPTLEC
Call CONTEXE([F:JOU]ACS) From CPTSUB : If mkstat : End : Endif
Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE) From CPTLEC
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = mess(51,106,1) : mkstat = 2 : End
Elsif [M:DIA]CPY <>"" & [F:JOU]FCY <>""
 Call VERSOC([F:JOU]FCY,[M:DIA]CPY,[M:DIA]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif
End

Subprog AS_DATPCE(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M:DIA]DATFIN
Endif
End

Subprog AM_TYPGEN(VALEUR)
Variable Integer VALEUR
[M:DIA]TYPPCE = ""
[M:DIA]JOU = ""
If VALEUR=1 : Actzo ECTSTA
Else : Grizo ECTSTA
Endif
If !GIMPORT : Affzo [M]TYPPCE, JOU : Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End

$GRISE
If [M]TOUSOC=2
 Grizo CPY
 [M]TOUSIT=2 : Affzo TOUSIT : Grizo TOUSIT
Else
 Actzo CPY,TOUSIT
Endif
If [M]TOUSIT=2 : Grizo FCY : Else : Actzo FCY : Endif
If [M]TOUUSR=2 : [M]USER="" : Affzo USER : Grizo USER : Else : Actzo USER : Endif
If [M]TYPGEN=1 : Actzo ECTSTA
Else           : Grizo ECTSTA
Endif
Return


Subprog AS_ABTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]ABTDEB : VALEUR=[M]ABTDEB : Endif
End

Subprog C_ABTDEB(VALEUR)
Variable Char    VALEUR()
Call C_ABTDEB(VALEUR)From VALGAF
End

Subprog C_ABTFIN(VALEUR)
Variable Char    VALEUR()
Call C_ABTFIN(VALEUR) From VALGAF
End

# Issue X3-86594
Subprog INIT_RAT_SOLABT(LTYP,LCPY)
Value Char LTYP
Value Char LCPY
# Getting TYPRAT From F:GTE
Call LEC_GTE_LEG(GCURLEG,LTYP) From CPTLEC
If [F:GTE]TYPRAT<>0
  [M:HAE1]TYPRAT = [F:GTE]TYPRAT
Endif
# $INIT_COURS_LED from TRTPCE adapted to the context of X3-86594
# Init Rates of non autorized leds
Call LEC_CPY(LCPY) From CPTLEC
If [F:CPY]ACM<>""
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Local Integer J,STAT
  Default Mask [M:HAE1] # For $INIT_COURS_LED
  For J=1 To len(mess(0,2644,1))
   If [M]CURLED(J-1)<>"" and [F:GTE]AUZLED(J-1)<2 and [M:HAEF]AUTC(J-1)<>2
    Gosub INIT_COURS_LED From TRTPCE
   Endif
  Next
Endif
End
# End issue X3-86594

