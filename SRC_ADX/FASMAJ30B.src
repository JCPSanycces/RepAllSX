#<AdxTL>@(#)7.0.0.0 $Revision$
#######################################################################################################
# FASMAJ30B  : Outil de miss à jour des biens comptables                                             ##
#             Alimentation des comptes à partir du code comptable                                     #
#                                                                                                     #
#######################################################################################################
# MDJ - 17-06-2010  FQ-64731 : Après migration X3V5-V6==> dans le cas où le
#                   compte PCG n'est pas alimenté sur les biens comptables
#######################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIFASACC(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIFASACC(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("FASMAJ30B: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#

  Local Char  LCOMPTE
  Local Char  RCOA
  Global Char G_COA

  If clalev([F:CAC]) : Close File  [CAC] : Endif 
  Local File =[F:ADS]DOSSIER+".GACCCODE" [CAC]

  If clalev([F:GAC]) : Close File  [GAC] : Endif   
  Local File =[F:ADS]DOSSIER+".GACCOUNT"  [GAC]  
          
  If clalev([F:CPY]) : Close File  [CPY] : Endif   
  Local File =[F:ADS]DOSSIER+".COMPANY"  [CPY] 

  If clalev([F:FAS]) : Close File  [FAS] : Endif 
  Local File =[F:ADS]DOSSIER+".FXDASSETS" [FAS]

   Trbegin [FAS]
   #************
   For [FAS]FAS0 Where (( GAC="" )  and ( OWNTYP= GVML_TDPROPR ))  With Stability
      Call LECMAINPLAN(1,[F:FAS]CPY,RCOA) From CPTDIV
      G_COA=RCOA
      If G_COA ="" : G_COA="FRA" : Endif
      #########################################################
      # - Objet  : Mise à jour de la tables des biens comptables
      # mise à jour du compte comptable PCG 
      #########################################################
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;G_COA
      If fstat=0 
         LCOMPTE = [F:CAC]ACC(0)
         If LCOMPTE <> ""
            [F:FAS]GAC = LCOMPTE
            Call ECR_TRACE("LCOMPTE="-num$(LCOMPTE),0) From GESECRAN
            Local Integer LGACACN
            For [GAC] Where ACC=LCOMPTE and COA=G_COA
               Read [GAC]GAC0 First
               If fstat = 0
                  [F:FAS]GACACN = [F:GAC]GACACN
               Else
                  [F:FAS]GACACN = 1
               Endif
               Break
            Next
            # Ecriture FAS 
            Rewrite[FAS]
            If (fstat) 
               Call ECR_TRACE("FXDASSETS, Level 14 - File Error ="-num$(fstat),1) From GESECRAN
               GERRDOS = 1
            Endif
         Endif
      Endif
   Next   # Immo
   Commit
   Close File [FAS]

  Call ECR_TRACE("FASMAJ30B : finish",0) From GESECRAN
End



