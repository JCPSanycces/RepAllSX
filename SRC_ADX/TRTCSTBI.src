#<AdxTL>@(#)9.0.0.0 $Revision$
#############################################################################
# TRTCSTBI      Fonctions pour la Business Intelligence       Coût - Cost   #
#############################################################################
# GETVLTTOT  Renvoie le Coût total          de la période                   #
# GETMATTOT  Renvoie le Coût matière        de la période                   #
# GETMACTOT  Renvoie le Coût machine        de la période                   #
# GETLABTOT  Renvoie le Coût main d'oeuvre  de la période                   #
# GETSCOTOT  Renvoie le Coût sous-traitance de la période                   #
# GETOVETOT  Renvoie le Coût frais généraux de la période                   #
# Paramètres :                                                              #
#            GETxxxTOT (STOFCY,ITMREF,TYPCST,DATREF)                        #
#                                                                           #
# GETVLTTOTR Renvoie le Coût total          de la période - devise reporting#
# GETMATTOTR Renvoie le Coût matière        de la période - devise reporting#
# GETMACTOTR Renvoie le Coût machine        de la période - devise reporting#
# GETLABTOTR Renvoie le Coût main d'oeuvre  de la période - devise reporting#
# GETSCOTOTR Renvoie le Coût sous-traitance de la période - devise reporting#
# GETOVETOTR Renvoie le Coût frais généraux de la période - devise reporting#
# Paramètres :                                                              #
#            GETxxxTOTR(STOFCY,ITMREF,TYPCST,DATREF)                        #
#############################################################################


#############################################################################
# GETVLTTOT  Renvoie le Coût total          de la période                   #
#############################################################################
Funprog GETVLTTOT (STOFCY,ITMREF,TYPCST,DATREF)
Value    Char     STOFCY
Value    Char     ITMREF
Value    Integer  TYPCST : # Type de coût 1=Std,2=Std actu,3=Std budget,4=Simulé  
Value    Date     DATREF

Local    Decimal  WCOST  : # Coût

# Positionnement sur la ligne [F:ITC]
  Gosub READ_ITC

  If [F:ITC]ITMREF = ITMREF & [F:ITC]STOFCY = STOFCY
     WCOST = [F:ITC]VLTTOT
  Else
     WCOST = 0
  Endif


End WCOST  

