     WCOST = [F:ITC]OVETOT
  Else
     WCOST = 0
  Endif


End WCOST  





#####################################################################
# Clé d'accès à ITMCOST 
# en V5 ITC0 STOFCY+ITMREF+CSTTYP+YEA+CSTSEQ
# en V6 ITC0 STOFCY+ITMREF+CSTTYP-ITCSEQ+UID
#####################################################################
$READ_ITC
Local    Integer  WFIYNUM : WFIYNUM=0
Local    Integer  WPERNUM : WPERNUM=0

  If dim(GDOSSIER)>0 & GDOSSIER<>""
      If !clalev([F:ITC]) : Local File =GDOSSIER+".ITMCOST" [ITC] : Endif
  Else
      If !clalev([F:ITC]) : Local File ITMCOST [ITC] : Endif
  Endif

  WFIYNUM = func TRTX3BI.GETEXE(STOFCY,DATREF)
  WPERNUM = func TRTX3BI.GETPER(STOFCY,DATREF)

  If [F:ITC]ITMREF <> ITMREF | [F:ITC]STOFCY <> STOFCY | [F:ITC]YEA <> WFIYNUM
     Read [F:ITC] ITC0=STOFCY;ITMREF;TYPCST;WFIYNUM;WPERNUM
     If fstat 
       Read [F:ITC] ITC0=STOFCY;ITMREF;TYPCST;WFIYNUM;0
       If fstat Raz [F:ITC] Endif
     Endif
  Endif


Return


#############################################################################
# GETVLTTOTR Renvoie le Coût total          de la période - devise reporting#
#############################################################################
Funprog GETVLTTOTR (STOFCY,ITMREF,TYPCST,DATREF)
Value    Char     STOFCY
Value    Char     ITMREF
Value    Integer  TYPCST : # Type de coût 1=Std,2=Std actu,3=Std budget,4=Simulé  
Value    Date     DATREF

Local    Decimal  WCOST1, WCOST2  : # Coût converti en devise reporting

  WCOST1 = func TRTCSTBI.GETVLTTOT(STOFCY,ITMREF,TYPCST,DATREF)
  # Conversion en devise reporting
  WCOST2 = func TRTX3BI.CNVCPYRPT(STOFCY,DATREF,WCOST1)

End WCOST2 


