#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Champ commentaire de la table AINDEX en texte traduisible
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update AINDEX table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub GESANX
End

#-------------------#
$GESANX

Local Integer K
Local Char    DES(80)
Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

Local File =DOSSIER+".AINDEX"   [ANX]
Local File =DOSSIER+".ATEXTE"   [ATX]
Local File =DOSSIER+".ATEXTRA"  [AXX]

If dim([F:ANX]COMMENT)<=0 : Return : Endif

# Mise à jour de la table AINDEX
Call ECR_TRACE(mess(81,125,1)-"AINDEX:"-time$,0) From GESECRAN

Trbegin [ANX] , [AXX]
 For [ANX]
  K = 0
  If [F:ANX]COMMENT<>""
   Call MAJTEXTRA([F:ANX]COMMENT,"AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND) From ATEXTRA
   [F:ANX]COMMENT = ""
   K = 1
  Elsif dim([F:ANX]COM)>0 & [F:ANX]COM<>0
   Call TEXTE([F:ANX]COM,[L]DES) From OBJDIV
   Call MAJTEXTRA([L]DES,"AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND) From ATEXTRA
   [F:ANX]COM = 0
   K = 1
  Else
   Call LECTEXTRA([L]DES,"AINDEX","COMDES",[F:ANX]CODIND,"") From ATEXTRA
   If [L]DES<>""
    Call MAJTEXTRA([L]DES,"AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND) From ATEXTRA
    Call SUPTEXTRA("AINDEX","COMDES",[F:ANX]CODIND,"") From ATEXTRA
   Endif
  Endif
  If K
   Rewrite [ANX]
   If fstat
    Call ERREUR("AINDEX"-[F:ANX]TABLE-num$([F:ANX]LIG),2) From DOSDIC
   Endif
  Endif
 Next ANX
Commit

Close Local File [ANX] , [ATX] , [AXX]

# Validation de l'écran ANX1

If GADONIX=2
# Call VALID_TRT(DOSSIER,0,"","","","","","","ANX1","ANX1","","","","","","","","",VALMOD) From VALDICO
 Call VALID_TRT(DOSSIER,0,"","","","","","","ANX1","ANX1","","","","","","","","","","","","",VALMOD) From VALDICO
Endif

Return
