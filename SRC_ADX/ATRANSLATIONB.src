#<AdxTL>@(#)4.0.0.0 $Revision$ 
############################################################
## Globales pour traductions  ATRANSLATIONB
# programme spe en fct des dossiers indus /  n existe pas sur superv
# si les valeur des poste 0 sont vide attention pas de remonter de trad
############################################################
$CHARG_TRANSLATE

# nbr de sessions XID max
# Si necessaire on peut  augmenter le tableau ici 
Local Integer WNBOUVFIC
WNBOUVFIC = 50
# avec contenant la liste des dossiers et machine en fct de XID indusprd
Global Char    GFOLDER_INDUS   (250)(1..WNBOUVFIC)
Global Integer GFOLDER_VERSION (1..WNBOUVFIC)
Global Integer GFOLDER_PRODUIT (1..WNBOUVFIC)

Global Integer GNBLANSTD
Global Char    GLANSTD(GLONLAN)(1..WNBOUVFIC) , GREFER(10)(1..WNBOUVFIC) , GUSRLAN(GLONAUS)(1..WNBOUVFIC)
# ici car depend de la version du dossier indus
# voir peut etre plus tard a recup dans indusprd et une nouvelle table lie à xid 
# pas pour instant 
If GPRODUIT = -1
    # produit superviseur, pas de trad possible dans un dossier superviseur
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "SUPTRANS"   : GUSRLAN(GNBLANSTD) = "XFRA" 
Elsif GPRODUIT = 3
    # produit abel , n existe plus depuis la v5
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "X3REFV7"    : GUSRLAN(GNBLANSTD) = "XFRA" 
Elsif GPRODUIT = 1
    # produit geode
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XFRA" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XSPA" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XBRI" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XENG" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XPOR" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "GEOREFAVEN"  : GUSRLAN(GNBLANSTD) = "XITA" 
Elsif GPRODUIT = 2
    # produit paye
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "PAYREFFRA"   : GUSRLAN(GNBLANSTD) = "XFRA" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "PAYREFPOR"   : GUSRLAN(GNBLANSTD) = "XPOR" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "PAYREFZAF"   : GUSRLAN(GNBLANSTD) = "XENG" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "PAYREFSPA"   : GUSRLAN(GNBLANSTD) = "XSPA" 
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ARB" : GREFER(GNBLANSTD) = "PAYREFZAF"   : GUSRLAN(GNBLANSTD) = "XARB" 
Else
    # produit x3
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "FRA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XFRA"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "SPA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XSPA"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "BRI" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XBRI"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ENG" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XENG"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POR" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XPOR"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ITA" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XITA"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "CHI" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XCHI"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "GER" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XGER"  
    # rus n est plus une langue std depuis la 2018R01 sur vcloud uniquement
    #GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "RUS" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XRUS"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "POL" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XPOL"  
    GNBLANSTD += 1 : GLANSTD(GNBLANSTD) = "ARB" : GREFER(GNBLANSTD) = "X3REFCLOUD"  : GUSRLAN(GNBLANSTD) = "XARB"  
Endif
Return

#############################################
$VERIF_DOSSIER
Local Integer WIND_TRAD
Local Char   WMAGIC(100)    : # Fichier de développement
Local Integer ILAN
Local Integer WIND_TRAD

WMAGIC   = "sophia_gaillard"
WIND_TRAD = 0

If filinfo(filpath("",WMAGIC,""),0)>=0
    For ILAN=1 To GNBLANSTD
       If GUSER=GUSRLAN(ILAN) and nomap=GREFER(ILAN)
            # on est sur un dossier indus pour trad
            # ici on ne peut pas tester code langue car classe M  pas ouverte
            WIND_TRAD = 1
      Endif
    Next ILAN
Endif
# init var une seule fois ici pour opadx
If WIND_TRAD = 1
    Local Char WRUNPRD(250)
    Local Char WAPPLI(250)
    Local Integer WERROR
    Local Char WXUSER
    Local Char WXPWD
    Local Char WXFRA

    WRUNPRD = "AWS-X3-INDUS:16001"
    WAPPLI  = "INDUSPRD"
    WERROR = 0
    WXUSER = "XSAM"
    WXPWD  = "XSAM74"
    WXFRA  = "FRA"
Endif


Return

#############################################
$ERR_OPADXD
  # erreur 126 : canal en cours utilisation il faut fermer 
  If errn=126 
    Opadxd Using [EXT]
    OPADXD WRUNPRD With WAPPLI, "FRA", WXUSER , WXPWD Using [EXT]
  Else
    RWERROR = 1 : GMESSAGE=errmes$(errn)-string$(errm<>errmes$(errn),errm)+"\"+errp+"("+num$(errl)+")"
  Endif
Resume


###################################################################################
Subprog OUVRE_FIC (RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,RWERROR)
Variable Char     RFOLDER_INDUS() (1..)
Variable Integer  RFOLDER_VERSION
Variable Integer  RFOLDER_PRODUIT
Variable Integer  RNBRFOLDER
Variable Integer  RWERROR

RWERROR =0

# PAS de remonter si ce fichier n existe pas
Gosub VERIF_DOSSIER

# ici tout est ok on devrait pouvoir remonter
If WIND_TRAD = 1
    #
    Onerrgo ERR_OPADXD
    OPADXD WRUNPRD With WAPPLI, WXFRA, WXUSER , WXPWD Using [EXT]
    Onerrgo
    If RWERROR : End : Endif

    Onerrgo ERR_OPADXD
    # ------- Appel du sous-pro dans le dossier indusprd
    CALLIU = "XTOOLS_ATRANSLATIONB:OUVRE_FIC" With GPRODUIT,GUSER,nomap,adxmother(0),num$(adxmac(-1)),num$(adxtcp),RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,WERROR   Using [EXT]
    If RWERROR : End : Endif
    Onerrgo

    # on ferme
    OPADXD Using [EXT]
    # on passe erreur de indusprd  au cas ou mais on affiche ici
    RWERROR = WERROR
    # mais on affiche erreur ici 
    If WERROR <> 0
       # affichage de l erreur mais on laisse faire la suite il n y aura pas alors de remonter
       GMESSAGE = "CAUTION : No recovery for translation will be available in INDUS folder, due to a settings problem" 
       Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Endif
Endif


End

##################################################################################################################
Subprog MAJ_TRAD (RCHAPITRE,RLAN,RSYRACUSE,RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,RTRACE,RWERROR)
Value    Integer RCHAPITRE
Value    Char    RLAN
Value    Integer RSYRACUSE
Value    Char    RFOLDER_INDUS() (1..)
Value    Integer RFOLDER_VERSION
Value    Integer RFOLDER_PRODUIT
Value    Integer RNBRFOLDER
Variable Char    RTRACE
Variable Integer RWERROR

RWERROR =0
Raz RTRACE

If RNBRFOLDER = 0
    End
Endif


# PAS de remonter si fichier magic n existe pas
Gosub VERIF_DOSSIER

If WIND_TRAD = 1
    # mais ici il faut aussi test du code langue......
    WIND_TRAD = 0
    For ILAN=1 To GNBLANSTD
       If GUSER=GUSRLAN(ILAN) and RLAN=GLANSTD(ILAN) and nomap=GREFER(ILAN)
            # on est sur un dossier indus pour trad
            # ici on ne peut pas tester code langue car classe M  pas ouverte
            WIND_TRAD = 1
       Endif
    Next ILAN
Endif

# ici tout est ok on devrait pouvoir remonter
If WIND_TRAD = 1
    Call ECR_TRACE("Start : Recovery in indus folder - phase 1 ",0) From GESECRAN

    If RSYRACUSE = 2
        WLANORI = "ENG"
    Else
        WLANORI = GFRA
    Endif
    If RLAN = WLANORI
        End
    Endif


    Onerrgo ERR_OPADXD
    OPADXD WRUNPRD With WAPPLI, WXFRA, WXUSER , WXPWD Using [EXT]
    Onerrgo
    If RWERROR : End : Endif

    Onerrgo ERR_OPADXD
    # ------- Appel du sous-pro dans le dossier indusprd
    CALLIU = "XTOOLS_ATRANSLATIONB:MAJTRAD" With RCHAPITRE,GPRODUIT,GUSER,nomap,num$(adxmac(-1)),num$(adxtcp),RLAN,WLANORI,RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,RTRACE,WERROR   Using [EXT]
    If RWERROR : End : Endif
    Onerrgo

    # on ferme
    OPADXD Using [EXT]
    # on passe erreur de indusprd 
    RWERROR = WERROR
    If WERROR = 2
          If RTRACE <> ""
              GMESSAGE = "Translation ERRORS : no recovery in some INDUS folders ,you can read log in INDUSPRD "+RTRACE
          Else
              GMESSAGE = "Translation ERRORS : no recovery in some INDUS folders and no log in INDUSPRD " 
          Endif
          Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Else
          If RTRACE <> ""
              GMESSAGE = "TRANSLATION phase for INDUS folders, you can read log in INDUSPRD "+RTRACE
          Else
              GMESSAGE = "TRANSLATION phase for INDUS folders, no log in INDUSPRD" 
          Endif
          Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Endif
    Raz GMESSAGE
    Call ECR_TRACE("END : Recovery in indus folder - phase 1 ",0) From GESECRAN

Endif

End
##################################################################################################################
Subprog MAJ_TRADTEX (RNUMERO,RLAN,RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,RTRACE,RWERROR)
 
Value    Integer RNUMERO
Value    Char    RLAN
Value    Char    RFOLDER_INDUS() (1..)
Value    Integer RFOLDER_VERSION
Value    Integer RFOLDER_PRODUIT
Value    Integer RNBRFOLDER
Variable Char    RTRACE
Variable Integer RWERROR
RWERROR =0

If RNBRFOLDER = 0
    End
Endif
Raz RTRACE

# PAS de remonter si fichier magic n existe pas
Gosub VERIF_DOSSIER
If WIND_TRAD = 1
    # mais ici il faut aussi test du code langue......
    WIND_TRAD = 0
    For ILAN=1 To GNBLANSTD
       If GUSER=GUSRLAN(ILAN) and RLAN=GLANSTD(ILAN) and nomap=GREFER(ILAN)
            # on est sur un dossier indus pour trad
            # ici on ne peut pas tester code langue car classe M  pas ouverte
            WIND_TRAD = 1
       Endif
    Next ILAN
Endif

# ici tout est ok on devrait pouvoir remonter
If WIND_TRAD = 1
    Call ECR_TRACE("Start : Recovery in indus folder - phase 1 ",0) From GESECRAN

    # voir le code lan si idem on sort
    WLANORI = GFRA
    If RLAN = WLANORI
        End
    Endif

    Onerrgo ERR_OPADXD
    OPADXD WRUNPRD With WAPPLI, WXFRA, WXUSER , WXPWD Using [EXT]
    Onerrgo
    If RWERROR : End : Endif

    Onerrgo ERR_OPADXD
    # ------- Appel du sous-pro dans le dossier indusprd
    CALLIU = "XTOOLS_ATRANSLATIONB:MAJTRADTEX" With RNUMERO,GPRODUIT,GUSER,nomap,num$(adxmac(-1)),num$(adxtcp),RLAN,WLANORI,RFOLDER_INDUS,RFOLDER_VERSION,RFOLDER_PRODUIT,RNBRFOLDER,RTRACE,WERROR   Using [EXT]
    If RWERROR : End : Endif
    Onerrgo

    # on ferme
    OPADXD Using [EXT]
    # on passe erreur de indusprd 
    RWERROR = WERROR
    If WERROR = 2
          If RTRACE <> ""
              GMESSAGE = "Translation ERRORS : no recovery in some INDUS folders ,you can read log in INDUSPRD "+RTRACE
          Else
              GMESSAGE = "Translation ERRORS : no recovery in some INDUS folders and no log in INDUSPRD " 
          Endif
          Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Else
          If RTRACE <> ""
              GMESSAGE = "TRANSLATION phase for INDUS folders, you can read log in INDUSPRD "+RTRACE
          Else
              GMESSAGE = "TRANSLATION phase for INDUS folders, no log in INDUSPRD" 
          Endif
          Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Endif
    Raz GMESSAGE
    Call ECR_TRACE("END : Recovery in indus folder - phase 1 ",0) From GESECRAN
Endif

End









