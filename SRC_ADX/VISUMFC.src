#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case GACTION
  When "VISUMFC"  :
    Case ACTION
      When "TRT_DIV"   :  Gosub TRT_VISUMFC
    Endcase
  When "VISUMFCP" :
    Case ACTION
      When "TRT_DIV"   :  Gosub TRT_VISUMFCP
    Endcase
Endcase
Return
############################################################
# Action VISUMFC Consultation prix de revient OF
############################################################
$TRT_VISUMFC
If PARAM(3) = ""  # Pas de MFGNUM transmis ... on ressort
  FIN = 1
Else
  If clalev([F:MFC]) = 0 : Local File MFGCOST    [MFC] : Endif
  If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
  If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
  If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
  If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
Endif
GFONC1="VISUMFC"
GFLTFCY=PARAM(1)
GFLTITM=PARAM(2)
Global Char GFLTMFGNUM(GLONVCR) : GFLTMFGNUM=PARAM(3)
# Issue 101696 - 2014-11-13 by JUSYN : interchanged key. Call to Production cost displayed no data.
#    Call OBJET("MFC",GFLTFCY,GFLTITM) From GOBJET
# Call OBJET("MFC",GFLTITM,GFLTFCY) From GOBJET
Local Char LCLESEC(250)(0..5)
LCLESEC(0)=PARAM(1)       # Site
Call OBJET("MFC",PARAM(2),LCLESEC) From GOBJET

Raz GFLTFCY : Raz GFLTITM  # FQ 73566 GA 05/2011
Kill GFLTMFGNUM
Return
############################################################

############################################################
# Action VISUMFCP Consultation cout prévisionnel OF
############################################################
$TRT_VISUMFCP
If PARAM(3) = ""  # Pas de MFGNUM transmis ... on ressort
  FIN = 1
Else
  If clalev([F:MFC]) = 0 : Local File MFGCOST    [MFC] : Endif
  If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
  If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
  If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
  If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
Endif
GFONC1="VISUMFCP"
# FQ 73566 GA 05/2011 ne pas détruire les globales du tronc commun
#Global Char GFLTFCY(GLONFCY) : GFLTFCY=PARAM(1)
#Global Char GFLTITM(GLONITM) : GFLTITM=PARAM(2)
GFLTFCY=PARAM(1)
GFLTITM=PARAM(2)
Global Char GFLTMFGNUM(GLONVCR) : GFLTMFGNUM=PARAM(3)
# Issue number - 2014-11-13 by JUSYN : interchanged key. Call to Provisional cost displayed no data.
# Call OBJET("MFC",GFLTFCY,GFLTITM) From GOBJET
Local Char LCLESEC(250)(0..5)
LCLESEC(0)=PARAM(1)       # Site
Call OBJET("MFC",PARAM(2),LCLESEC) From GOBJET

# FQ 73566 GA 05/2011 ne pas détruire les globales du tronc commun
#Kill GFLTFCY : Kill GFLTITM : Kill GFLTMFGNUM
Raz GFLTFCY : Raz GFLTITM
Kill GFLTMFGNUM
Return
