#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

#---------------------#
$PATCH
CLEOBJ = NOMOBJ
ABROBJ = TYPOBJ
L1 = instr(1,CLEOBJ,"~")
L2 = instr(L1+1,CLEOBJ,"~")
L3 = instr(L2+1,CLEOBJ,"~")
If !L1 or !L2 or !L3
 Gosub FIN_OBJ From PATCH : Return
Else
 [L]MODDON  = left$(CLEOBJ,L1-1)
 [L]CODLEG  = seg$(CLEOBJ,L1+1,L2-1)
 [L]TRANSAC = seg$(CLEOBJ,L2+1,L3-1)
 [L]CLEMOD = right$(CLEOBJ,L3+1)
Endif

#---------------------#
$LIRE
NOMPROG = ""
Repeat
 Gosub LIRE From PATCH
 Case TYPENR
  When 12 : # DÃĐbut objet d'un modÃĻle de patch
   TYPOBJ   = CHAMP(1)
   NOMOBJ = vireblc(CHAMP(2),2)
   Case TYPOBJ
    When "AWM"
     MESSA = "-"-mess(9,140,1)-":"-TYPOBJ-NOMOBJ : # ModÃĻle de donnÃĐes
     Gosub TRACE
     Gosub MODELE_WRK From PATCHWRK
     Read [AWM_]AWM0=[L]MODDON
     If fstat : ER = 94 : Gosub FIN_OBJ From PATCH : Break : Endif
    When "ATN"
     MESSA = "-"-mess(5,126,1)-":"-TYPOBJ-NOMOBJ : # Transaction
     Gosub TRACE
     Gosub TRANSAC From PATCHDIV
    When Default
     MESSA = "-"-mess(33,115,1)-":"-TYPOBJ-NOMOBJ : # Objet
     Gosub TRACE
     If NOMPROG=""
      NOMPROG = "WWPATCH"+"_"+GUSER+"_"+num$(adxuid(2))
      Gosub SAV_OPENI From PATCH
      Call VALID(CLEOBJ,DOSSIER(D),NOMPROG,1,STAT)
      Gosub REST_OPENI From PATCH
      If !STAT
       ER = 93 : Gosub FIN_OBJ From PATCH : Break
      Else
       MESSA = "-"-mess(19,123,1)-":"-NOMPROG : # Traitement
       Gosub TRACE
      Endif
     Endif
     OKENT = 1
     # Cas particuliers
     Case TYPOBJ
      When "TFO"
       Local Integer SAVOKOBJ
       SAVOKOBJ = OKOBJ
       OKOBJ = OKENT
       Gosub TABFOR From PATCHDIV
       OKENT = OKOBJ
       OKOBJ = SAVOKOBJ
      When Default
       Gosub PATCH From =DOSSIER(D)+"."+NOMPROG
     Endcase
     If !OKENT
      Gosub FIN_OBJ
     Else
      Gosub SAV_OPENI From PATCH
      Call VALTRANS(DOSSIER(D),TRANSAC,NOMOBJ) From =DOSSIER(D)+"."+NOMPROG
      Gosub REST_OPENI From PATCH
     Endif
   Endcase
   If !OKOBJ or ER
    Gosub FIN_OBJ From PATCH
    Break
   Endif
  When 7,13 : # Fin normale/Fin objet d'un modÃĻle de patch
   Break
  When Default
   ER = 32 : Break
 Endcase
Until 1=0
If NOMPROG<>""
 Call EFFACE_ADX(MACHINE,APPLI,NOMPROG,STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"adx",DOSSIER(D)),STAT) From ORDSYS
 #Call EFFACE(filpath("TRT",NOMPROG,"src",DOSSIER(D)),STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"xrc",DOSSIER(D)),STAT) From ORDSYS
Endif
Return

#---------------------------------------------#
$FIN_OBJ
If find(TYPOBJ,"TRT")
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
 Repeat
  Gosub LIRE From PATCH
 Until TYPENR=13 or ER
Elsif find(TYPOBJ,"ADX","ELT","BIA","ELX")
 Rdseq NOCT
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
 Repeat
  Gosub LIRE From PATCH
 Until TYPENR=13 or ER
Elsif TYPOBJ="ETA"
 Repeat
  Gosub LIRE From PATCH
  If TYPENR=3
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Endif
  Endif
 Until TYPENR=13 or ER
Elsif TYPOBJ="TAB"
 Repeat
  Gosub LIRE From PATCH
  If TYPENR=3
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Break : Endif
  Endif
 Until TYPENR=13 or ER
 If ER : Return : Endif
Endif
If !find(TYPOBJ,"TAB","ETA")
 Repeat
  Gosub LIRE From PATCH
  If find(TYPENR,22,24,23,25) : # Blob , Clob
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat
    ER = 33 : Break
   Endif
  Endif
 Until fstat or TYPENR=13
 If fstat : ER = 25 : Endif
Endif
Return

#--------------------------------------#
$TRACE
Gosub SAV_OPENI From PATCH
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub REST_OPENI From PATCH
Return

#----------------------------------------------------------------------------#
Subprog VALID(CODE,DOSSIER,NOMPROG,SILENCE,OK)
Value    Char    CODE
Value    Char    DOSSIER
Value    Char    NOMPROG
Value    Integer SILENCE
Variable Integer OK

Local Char     FICSRC(GDIMFIC) , IDENT(20)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CHAINE(250) , MAGIC(80) , BUF(250)
Local Integer  I , J , K , L , M , N , OK , SPA
Local Shortint DIME : DIME = 20
Local Char     TBORI(GLONATB+GLONABR+1)(1..DIME) , TBLNK(GLONATB+GLONABR+1)(1..DIME) , TBCLE(GLONANX)(1..DIME)
Local Char     TBEXP(80)(1..DIME) , TBSEL(80)(1..DIME)
Local Integer  NBTB , TBTRI(1..DIME)
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX) , TAB(GLONATB+GLONABR+1)(1..DIME)
Local Char     MODDON(GLONAWM) , TRANSAC(GLONATN) , CODLEG(GLONADI) , FLDLEG(GLONAVA)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

MAGIC   = mess(77,133,1) : # Superviseur Adonix
IDENT   = "## WM-PATCH ##"

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

OK = 1
Gosub SETPAR From APATCHMOD
If [L]MODDON=""
 Call ECR_TRACE(mess(134,141,1),1) From GESECRAN : # Erreur de syntaxe
 OK = 0
Endif

Read [AWM_]AWM0=[L]MODDON
If fstat
 Call ECR_TRACE([L]MODDON-":"-mess(7,140,1),1) From GESECRAN : # ModÃĻle de donnÃĐes inexistant
 OK = 0
Else
 Look [ATB_]CODFIC=[F:AWM_]TABREF
 If fstat
  Call ECR_TRACE([F:AWM_]TABREF-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
  OK = 0
 Else
  For [AWK_]AWK0 Where MODELE = [AWM_]MODELE & TYPTAB<1
   If [F:AWK_]TABLNK<>""
    Look [ATB_]CODFIC=[F:AWK_]TABLNK
    If fstat
     Call ECR_TRACE([F:AWK_]TABLNK-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
     OK = 0 : Break
    Endif
   Endif
  Next I
 Endif
Endif

If OK
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If !OK
  # Ce traitement est dÃĐjÃ  utilisÃĐ par un autre paramÃĻtrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(1,143,1)-MODDON-'('+format$("D:",date$)-time$+')' : # ModÃĻle de patch
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "$PATCH"
Wrseq
Wrseq "Local Integer TBOPE(0.."+num$(DIME)+") , DETAIL"
Wrseq

Wrseq "DETAIL = 0"

# Chargement des tables liÃĐes
NBTB = 0
For [AWK_]AWK0 Where MODELE = [AWM_]MODELE & TYPTAB<1
 If [F:AWK_]TABLNK<>""
  NBTB += 1
  TBLNK(NBTB) = [F:AWK_]TABLNK
  TBORI(NBTB) = [F:AWK_]TABORI
  TBCLE(NBTB) = [F:AWK_]CLELNK
  TBEXP(NBTB) = [F:AWK_]EXPLNK
  TBSEL(NBTB) = [F:AWK_]EXPSEL
  If [F:AWK_]ABRLNK<>""
   TBLNK(NBTB) += "~"+[F:AWK_]ABRLNK
  Else
   Read [ATB_]CODFIC=[F:AWK_]TABLNK
   TBLNK(NBTB) += "~"+[F:ATB_]ABRFIC
  Endif
  If [F:AWK_]ABRORI<>""
   TBORI(NBTB) += "~"+[F:AWK_]ABRORI
  Else
   Read [ATB_]CODFIC=[F:AWK_]TABORI
   TBORI(NBTB) += "~"+[F:ATB_]ABRFIC
  Endif
 Endif
Next I

# Table principale
REFTAB = [F:AWM_]TABREF
Read [ATB_]CODFIC=[F:AWM_]TABREF
ABRREF = [F:ATB_]ABRFIC
Read [ATI_]NUMLIG(2)=[F:AWM_]TABREF;1
CLEREF = [F:ATI_]CODIND
FLDLEG = [F:AWM_]FLDLEG
I = instr(1,FLDLEG,"]")
If I : FLDLEG = right$(FLDLEG,I+1) : Endif

# Tri pour les "delete" : il faut d'abord supprimer le dÃĐtail avec l'entÃŠte
For I=0 To 10
 For J=1 To NBTB
  If TBTRI(J)=0
   If I=0
    If TBORI(J)=REFTAB+"~"+ABRREF
     TBTRI(J) = 1
    Endif
   Else
    K = find(TBORI(J),TBLNK)
    If TBTRI(K)
     TBTRI(J) = TBTRI(K)+1
    Endif
   Endif
  Endif
 Next J
Next I
Sorta NBTB TBORI,TBLNK,TBCLE,TBEXP,TBSEL,TBTRI Order By TBTRI(indice+1) Desc

Wrseq 'If clalev([F:'+ABRREF+'])=0 : Local File =DOSSIER(D)+".'+REFTAB+'" ['+ABRREF+'] : TBOPE(0) = 1 : Endif'
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq 'If clalev([F:'+right$(TBLNK(I),K+1)+'])=0 : Local File =DOSSIER(D)+".'+left$(TBLNK(I),K-1)+'" ['+right$(TBLNK(I),K+1)+']';
 Wrseq ' : TBOPE('+num$(I)+') = 1 : Endif'
Next I

Wrseq

# Lecture de la table principale
Read [ATB_]CODFIC=REFTAB
Read [ATI_]NUMLIG(2)=REFTAB;1
Gosub SETCLE From APATCHMOD
Wrseq "Gosub SETVAL"

If REFTAB="ADOVAL"
 Wrseq 'If VALCLE(1)="*"'
 Wrseq ' If !find(VALCLE(2),LEGREF(1..NBLEGREF))'
 Wrseq '  Gosub FIN_OBJ From PATCHMOD'
 Wrseq '  Return'
 Wrseq ' Elsif !MULTILEG'
 Wrseq '  VALCLE(1) = ""'
 Wrseq '  VALCLE(2) = ""'
 Wrseq ' Endif'
 Wrseq 'Endif'
Endif

For I=1 To NBCLE
 Wrseq "[F:"+ABRREF+"]"+CLE(I)+" = ";
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'val(VALCLE('+num$(I)+'))'
  When 8           : Wrseq 'evalue("["+VALCLE('+num$(I)+')+"]")' : # 117863
  When Default     : Wrseq 'VALCLE('+num$(I)+')'
 Endcase
Next I
Wrseq "Read ["+ABRREF+"] = "

# DÃĐbut du patch
Look [ATZ_]CODZONE=REFTAB;"CODACT"
If !fstat
 Wrseq 'If !fstat & [F:'+ABRREF+']CODACT>="X" & !find([F:'+ABRREF+']CODACT,ACTIV(1..NBACT))'
 Wrseq ' Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spÃĐcifique'
 Wrseq ' Gosub FIN_OBJ From PATCHMOD'
 Wrseq 'Else'
 SPA = 1
Endif
Wrseq space$(SPA);'If fstat'
Wrseq space$(SPA);' NEWOBJ = 1'
Wrseq space$(SPA);' Raz [F:'+ABRREF+']'
Wrseq space$(SPA);'Else'
Wrseq space$(SPA);' NEWOBJ = 0'
If [L]FLDLEG<>""
 Wrseq space$(SPA);' If dim([F:'+ABRREF+']'+[L]FLDLEG+')>0'
 Wrseq space$(SPA);'  OLDLEG = [F:'+ABRREF+']'+[L]FLDLEG
 Wrseq space$(SPA);' Endif'
Endif
Wrseq space$(SPA);'Endif'
Wrseq space$(SPA);'Call DEBTRANS From GLOCK'
Wrseq space$(SPA);'Gosub TR'
If SPA
 Wrseq 'Endif'
Endif
Wrseq
Wrseq "If TBOPE(0) : Close local File ["+ABRREF+"] : Endif"
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq "If TBOPE("+num$(I)+") : Close local File ["+right$(TBLNK(I),K+1)+"] : Endif"
Next I
Wrseq
Wrseq "Return"
Wrseq

# Transaction
Wrseq '$TR'
Wrseq 'GOK = 1'
Wrseq 'Trbegin ['+ABRREF+']'
Wrseq ' NBZ = 0'
Wrseq ' Repeat'
Wrseq '  Gosub LIRE From PATCH'
Wrseq '  Case TYPENR'
Wrseq '   When 13 : # Fin normale'
Wrseq '    Break'
Wrseq '   When 3 : # La transaction'
Wrseq '    IDENT = CHAMP(2)'
Wrseq '    Case CHAMP(1)'
Wrseq '     When "'+ABRREF+'"   : Gosub TR_'+ABRREF
For L=1 To NBTB
 K = instr(1,TBLNK(L),"~")
 Wrseq '     When "'+right$(TBLNK(L),K+1)+'"   : Gosub TR_'+right$(TBLNK(L),K+1)
Next L
If REFTAB="AOBJSEL"
 Wrseq '     When "sel","glo"'
 Wrseq '      FIC = [F:'+ABRREF+']USR+"_"+[F:'+ABRREF+']CODE+"_"+[F:'+ABRREF+']MEMO'
 Wrseq '      If [F:'+ABRREF+']ALL=2'
 Wrseq '       FIC += ".glo"'
 Wrseq '      Else'
 Wrseq '       FIC += ".sel"'
 Wrseq '      Endif'
 Wrseq '      Gosub MEMOS From PATCHDIV'
Endif
Wrseq '     When Default : ER = 31'
Wrseq '    Endcase'
Wrseq '   When Default'
Wrseq '    ER = 32'
Wrseq '  Endcase'
Wrseq '  If ER or !OKENT : Break : Endif'
Wrseq ' Until 1=0'
Wrseq ' If ER or !OKENT : Goto ABORT : Endif'
Wrseq 'Commit'
Wrseq 'Return'
Wrseq
Wrseq '$ABORT'
Wrseq 'Rollback'
Wrseq 'Return'
Wrseq

# Ecriture entÃŠte
Wrseq '$TR_'+ABRREF
Wrseq 'FICHIER = "'+REFTAB+'"'
Wrseq 'ABR = "'+ABRREF+'"'
Wrseq 'Repeat'
Wrseq ' Gosub LIRE_ZONE From PATCH'
Wrseq ' If ER : Break : Endif'
Wrseq ' If DIME>0 & IND+1<=DIME'
Wrseq '  OK = 1'
Wrseq '  If OK'
Wrseq '   Gosub AFF_ZONE From PATCH'
Wrseq '   If GOK<1 : ER = 99 : Break : Endif'
Wrseq '  Endif'
Wrseq ' Endif'
Wrseq 'Until TYPENR=6'
Wrseq 'If ER : Return : Endif'
If REFTAB="ADOVAL"
 Wrseq 'If [F:ADW]CMP="*" & !MULTILEG'
 Wrseq ' [F:ADW]CMP = ""'
 Wrseq ' [F:ADW]FCY = ""'
 Wrseq 'Endif'
Endif
Read [ATB_]CODFIC=REFTAB
Read [ATI_]NUMLIG(2)=REFTAB;1
Gosub SETCLE From APATCHMOD
Wrseq 'CHAINE = ';
For I=1 To NBCLE
 If I>1 : Wrseq '-'; : Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When 8           : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When Default     : Wrseq '[F:'+ABRREF+']'+CLE(I);
 Endcase
Next I
Wrseq
If [L]FLDLEG<>""
 Wrseq 'If dim([F:'+ABRREF+']'+[L]FLDLEG+')>0'
 Wrseq ' NEWLEG = [F:'+ABRREF+']'+[L]FLDLEG
 Wrseq ' If NEWLEG<>"" & !find(NEWLEG,LEGREF(1..NBLEGREF))'
 Wrseq '  # LÃĐgislation non gÃĐrÃĐe par le dossier'
 Wrseq '  Call ECR_TRACE("---"-CHAINE-"("+NEWLEG+")"-":"-mess(249,133,1)-DOSSIER(D),0) From GESECRAN'
 Wrseq '  OKENT = 0 : Return'
 Wrseq ' Endif'
 Wrseq ' If OLDLEG<>NEWLEG & !NEWOBJ'
 Wrseq '  # $1$ : LÃĐgislation origine $2$ diffÃĐrente lÃĐgislation destination $3$'
 Wrseq '  Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),"---"-CHAINE,NEWLEG,OLDLEG),-1) From GESECRAN'
 Wrseq '  OKENT = 0 : Return'
 Wrseq ' Endif'
 Wrseq 'Endif'
Endif
Look [ATZ_]CODZONE=REFTAB;"MODULE"
If !fstat
 Wrseq 'MODOBJ = max(1,[F:'+ABRREF+']MODULE)'
 Wrseq 'If [F:ADS]MODULE(MODOBJ-1)<>2'
 Wrseq ' OKENT = 0 : Return'
 Wrseq 'Endif'
Endif
Look [ATZ_]CODZONE=REFTAB;"CODACT"
If !fstat
 Wrseq 'ACVOBJ = [F:'+ABRREF+']CODACT'
 Wrseq 'If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3'
 Wrseq ' Read [ACV]CODACT = ACVOBJ'
 Wrseq ' If fstat or [F:ACV]FLACT<>2'
 Wrseq '  OKENT = 0 : Return'
 Wrseq ' Endif'
 Wrseq 'Endif'
Endif
Wrseq 'If NEWOBJ'
Look [ATZ_]CODZONE=REFTAB;"CREDAT"
If !fstat : Wrseq ' [F:'+ABRREF+']CREDAT = date$' : Endif
Look [ATZ_]CODZONE=REFTAB;"CREUSR"
If !fstat : Wrseq ' [F:'+ABRREF+']CREUSR = GUSER' : Endif
Look [ATZ_]CODZONE=REFTAB;"CRETIM"
If !fstat : Wrseq ' [F:'+ABRREF+']CRETIM = time' : Endif
Look [ATZ_]CODZONE=REFTAB;"UPDDAT"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDDAT = date$' : Endif
Look [ATZ_]CODZONE=REFTAB;"UPDUSR"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDUSR = GUSER' : Endif
Look [ATZ_]CODZONE=REFTAB;"UPDTIM"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDTIM = time' : Endif
Wrseq ' Write ['+ABRREF+']'
Wrseq 'Else'
Look [ATZ_]CODZONE=REFTAB;"UPDDAT"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDDAT = date$' : Endif
Look [ATZ_]CODZONE=REFTAB;"UPDUSR"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDUSR = GUSER' : Endif
Look [ATZ_]CODZONE=REFTAB;"UPDTIM"
If !fstat : Wrseq ' [F:'+ABRREF+']UPDTIM = time' : Endif
Wrseq ' Rewrite ['+ABRREF+']'
Wrseq 'Endif'
Wrseq 'If fstat'
Wrseq ' GOK = 0 : ER = 99 : ERFIC = "'+REFTAB+'"-CHAINE : Return'
Wrseq 'Else'
Wrseq ' # Table/ClÃĐ'
Wrseq ' MESSA = "- "+mess(56,123,1)-": '+REFTAB+'"-mess(257,142,1)-CHAINE'
Wrseq ' Gosub TRACE from PATCHMOD'
Wrseq 'Endif'

# Suppression des lignes de dÃĐtail
For L=1 To NBTB
 K = instr(1,TBLNK(L),"~")
 Wrseq
 Wrseq 'Local File =DOSSIER(D)+".'+left$(TBLNK(L),K-1)+'" [ADEL]'
 N = 1
 M = L
 TAB(1) = REFTAB+"~"+ABRREF
 While 1=1
  N += 1
  If TBORI(M)=REFTAB+"~"+ABRREF
   TAB(N) = TBLNK(L)
   Break
  Endif
  TAB(N) = TBORI(M)
  M = find(TBORI(M),TBLNK)
 Wend
 For I=1 To N
  If I=1
   Wrseq "Link ["+ABRREF+"] With"
  Else
   If I>2 : Wrseq "," : Endif
   M = find(TAB(I),TBLNK)
   K = instr(1,TBLNK(M),"~")
   Wrseq "& ["+right$(TBLNK(M),K+1)+"]"+TBCLE(M)+"~="+TBEXP(M);
  Endif
 Next I
 Wrseq
 Wrseq "& As [LNK_]"
 K = 0
 For I=2 To N
  M = find(TAB(I),TBLNK)
  If TBSEL(M)<>""
   If K=0
    K = 1
    Wrseq "& Where ";
   Else
    Wrseq "&     & ";
   Endif
   Wrseq TBSEL(M)
  Endif
 Next I
 Read [ATB_]CODFIC=REFTAB
 Read [ATI_]CODIND=REFTAB;CLEREF
 Gosub SETCLE From APATCHMOD
 Wrseq 'For [LNK_]'+CLEREF;
 K = 0
 For I=1 To NBCLE
  If K=0
   K = 1
   Wrseq " Where ";
  Else
   Wrseq " & ";
  Endif
  Wrseq CLE(I)+"=";
  Case TYP(I)
   When 1,2,3,4,5,6 : Wrseq 'val(VALCLE('+num$(I)+'))';
   When 8           : Wrseq 'evalue("["+VALCLE('+num$(I)+')+"]")' : # 117863
   When Default     : Wrseq 'VALCLE('+num$(I)+')';
  Endcase
 Next I
 Wrseq
 Wrseq ' Delete [ADEL] Where ';
 K = instr(1,TBLNK(L),"~")
 Read [ATB_]CODFIC=left$(TBLNK(L),K-1)
 Read [ATI_]NUMLIG(2)=left$(TBLNK(L),K-1);1
 Gosub SETCLE From APATCHMOD
 For I=1 To NBCLE
  If I>1
   Wrseq ' & ';
  Endif
  Wrseq '[F:ADEL]'+CLE(I)+'='+'[F:'+right$(TBLNK(L),K+1)+']'+CLE(I);
 Next I
 Wrseq
 Wrseq ' If fstat'
 Wrseq '  GOK = 0 : ER = 99 : ERFIC = "'+left$(TBLNK(L),K-1)+'"';
 Read [ATB_]CODFIC=left$(TBLNK(L),K-1)
 Read [ATI_]CODIND=left$(TBLNK(L),K-1);TBCLE(L)
 Gosub SETCLE From APATCHMOD
 For I=1 To NBCLE
  Wrseq '-';
  Case TYP(I)
   When 1,2,3,4,5,6 : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When 8           : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When Default     : Wrseq '[F:'+right$(TBLNK(L),K+1)+']'+CLE(I);
  Endcase
 Next I
 Wrseq ' : Break'
 Wrseq ' Endif'
 Wrseq 'Next LNK_'
 Wrseq 'Close Local File [ADEL]'
Next L
Wrseq 'Return'

# Ecriture tables de dÃĐtail
For L=1 To NBTB
 Wrseq
 K = instr(1,TBLNK(L),"~")
 Wrseq '$TR_'+right$(TBLNK(L),K+1)
 Wrseq 'FICHIER = "'+left$(TBLNK(L),K-1)+'"'
 Wrseq 'ABR = "'+right$(TBLNK(L),K+1)+'"'
 Wrseq 'Repeat'
 Wrseq ' Gosub LIRE_ZONE From PATCH'
 Wrseq ' If ER : Break : Endif'
 Wrseq ' If DIME>0 & IND+1<=DIME'
 Wrseq '  OK = 1'
 Wrseq '  If OK'
 Wrseq '   Gosub AFF_ZONE From PATCH'
 Wrseq '   If GOK<1 : ER = 99 : Break : Endif'
 Wrseq '  Endif'
 Wrseq ' Endif'
 Wrseq 'Until TYPENR=6'
 Wrseq 'If ER : Return : Endif'
 Wrseq 'Write ['+right$(TBLNK(L),K+1)+']'
 Read [ATB_]CODFIC=left$(TBLNK(L),K-1)
 Read [ATI_]CODIND=left$(TBLNK(L),K-1);TBCLE(L)
 Gosub SETCLE From APATCHMOD
 Wrseq 'CHAINE = ';
 For I=1 To NBCLE
  If I>1 : Wrseq '-'; : Endif
  Case TYP(I)
   When 1,2,3,4,5,6 : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When 8           : Wrseq 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')';
   When Default     : Wrseq '[F:'+right$(TBLNK(L),K+1)+']'+CLE(I);
  Endcase
 Next I
 Wrseq
 Wrseq 'If fstat=3'
 Wrseq ' # Table/Enregistrement existant'
 Wrseq ' MESSA = "- "+mess(56,123,1)-": '+left$(TBLNK(L),K-1)+'"-mess(224,115,1)-CHAINE'
 Wrseq ' If DETAIL : Gosub TRACE from PATCHMOD : Endif'
 Wrseq 'Elsif fstat'
 Wrseq ' GOK = 0 : ER = 99 : ERFIC = "'+left$(TBLNK(L),K-1)+'"-CHAINE : Return'
 Wrseq 'Else'
 Wrseq ' # Table/ClÃĐ'
 Wrseq ' MESSA = "- "+mess(56,123,1)-": '+left$(TBLNK(L),K-1)+'"-mess(257,142,1)-CHAINE'
 Wrseq ' If DETAIL : Gosub TRACE from PATCHMOD : Endif'
 Wrseq 'Endif'
 Wrseq 'Return'
Next L
Wrseq
Wrseq '#--------------------------------------------------#'
Wrseq 'Subprog VALTRANS(DOSSIER,TRANSAC,NOMOBJ)'
Wrseq 'Value Char DOSSIER , TRANSAC , NOMOBJ'
Wrseq 'Local Integer OKTRT , ER'
Wrseq 'Local Char    MACHINE(GLONAMC) , APPLI(GLONADS)'
Wrseq 'Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS'
Wrseq 'If clalev([F:'+ABRREF+'])=0 : Local File =DOSSIER+".'+REFTAB+'" ['+ABRREF+'] : Endif'
Wrseq 'If clalev([F:ATN])=0 : Local File =DOSSIER+".ATRANSAC" [ATN] : Endif'
Wrseq 'Read [ATN]ATN0 = "'+[L]TRANSAC+'"'
Wrseq 'If !fstat & [F:ATN]ENAFLG=2 & [F:ATN]CODTRT<>""'
Wrseq ' Call EXISTE_ADX(MACHINE,APPLI,[F:ATN]CODTRT,OKTRT) From ORDSYS'
Wrseq ' If !OKTRT'
Wrseq '  Call EXISTE_ADX(MACHINE,"",[F:ATN]CODTRT,OKTRT) From ORDSYS'
Wrseq ' Endif'
Wrseq ' If OKTRT'
Wrseq '  Gosub SETVAL'

Read [ATB_]CODFIC=REFTAB
Read [ATI_]NUMLIG(2)=REFTAB;1
Gosub SETCLE From APATCHMOD

Wrseq '  # Validation des transactions'
Wrseq '  Call ECR_TRACE("-"-mess(69,133,1)-[F:ATN]COD-"("+func AFNC.TEXTE([F:ATN]DES)+")"-"-"-mess(33,115,1)-VALCLE,0) From GESECRAN'
Wrseq '  Onerrgo ER'

For I=1 To NBCLE
 Wrseq '  [F:'+ABRREF+']'+CLE(I)+' = ';
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'val(VALCLE('+num$(I)+'))'
  When 8           : Wrseq 'evalue("["+VALCLE('+num$(I)+')+"]")' : # 117863
  When Default     : Wrseq 'VALCLE('+num$(I)+')'
 Endcase
Next I
Wrseq '  Read ['+ABRREF+'] ='
Wrseq '  If !fstat'
Wrseq '   Call PATCHMOD(DOSSIER,';
For I=1 To NBCLE
 If I>1 : Wrseq '+"~"+'; : Endif
 Case TYP(I)
  When 1,2,3,4,5,6,8 : Wrseq 'num$([F:'+ABRREF+']'+CLE(I)+')';
  When Default       : Wrseq '[F:'+ABRREF+']'+CLE(I);
 Endcase
Next I
Wrseq ') From =[F:ATN]CODTRT'
Wrseq '   If ER=39 : # Traitement ou S/P inexistant'
Wrseq '    Call PATCH(DOSSIER) From =[F:ATN]CODTRT'
Wrseq '   Endif'
Wrseq '  Endif'
Wrseq '  Onerrgo'
Wrseq ' Endif'
Wrseq 'Endif'
Wrseq 'Close Local File'
Wrseq 'End'
Wrseq
Wrseq '$ER'
Wrseq 'ER = errn'
Wrseq 'Resume'
Wrseq
Wrseq '#-----------------------#'
Wrseq '$SETVAL'
Wrseq 'Local Char    VALCLE(GLONID1)(1..16) , CHAINE(250)'
Wrseq 'Local Integer NBCLE , POS'
Wrseq 'Raz NBCLE , VALCLE'
Wrseq 'CHAINE = NOMOBJ'
Wrseq 'While CHAINE<>""'
Wrseq ' NBCLE += 1'
Wrseq ' POS = instr(1,CHAINE,"~")'
Wrseq ' If POS'
Wrseq '  VALCLE(NBCLE) = left$(CHAINE,POS-1)'
Wrseq '  CHAINE = right$(CHAINE,POS+1)'
Wrseq ' Else'
Wrseq '  VALCLE(NBCLE) = CHAINE'
Wrseq '  CHAINE = ""'
Wrseq ' Endif'
Wrseq 'Wend'
Wrseq 'Return'

Return

