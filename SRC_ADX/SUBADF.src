#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet ADF
Raz GPILCOD , GNBMASKOUV
Call OBJET("ADF",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "APRES_CRE"   : Gosub APRES_CRE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "STATUT"      : Gosub STATUT
 When "INIT_DIA"    : Gosub INITVER
 When "EXEC"        : Gosub EXECVER
 When "SORTIE"      : Gosub TERMINEVER
 When "FIN"         : Gosub FIN
 When "FERME"       : Gosub FERME
Endcase
Return

#----------------------------------------------------------------------------#
$OUVRE
Gosub BLOCAGE_CONSULT From SUBADO
Return

$FIN
Gosub BLOCAGE_CONSULT From SUBADO
Return

$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return



$APRES_MODIF
#JPGA 07/01/2010 BUG-69982 : Dans un dossier fille bloqué en consultation, le focus sur le champs HTML entre en modif à tord: on le bloquer
Gosub BLOCAGE_CONSULT From SUBADO
Return

#----------------------------------------------------------------------------#
$SETBOUT
If CLECUR & REP<>"M" & VERROU
 CHAINE += "A" : # Suppression
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Else
 CHMEN += "09" : # Vérification/Epuration
Endif
Return

#----------------------------------------------------------------------------#
$STATUT
Case BOUT
 When "9" : Call LNKNUT(1)
 # When "0" : Call LNKNUT(0)
Endcase
Return

#----------------------------------------------------------------------------#
$APRES_MOD
Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"M") From AGENLIBA
# si besoin on met à jour la doc
Trbegin [ADF]
Call MAJ_ENVINDUS_ADF ([M]TYP,[M]COD) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Commit
Return

#----------------------------------------------------------------------------#
$APRES_CRE
Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"C") From AGENLIBA
# si besoin on met à jour la doc
Trbegin [ADF]
Call MAJ_ENVINDUS_ADF ([M]TYP,[M]COD) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Commit
Return

#----------------------------------------------------------------------------#
$LIENS
[M]CONCAT(nolign-1) = [M]TYPLNK(nolign-1)+"~"+[M]CLELNK(nolign-1)
Return

$ANNULE
Gosub TR1
If GOK<>1 : Return : Endif
GREP = ""
Gosub DEVERROU From GOBJET
Raz CLECUR1 , CLECUR2
Gosub RELIT From GOBJSUB
Return

$TR1
Call DEBTRANS From GLOCK
Trbegin [ADF]
 Delete [ADF] Where TYP=[M]TYP & COD=[M]COD
 If fstat=1
  GOK=-1 : Call FSTA("ADF") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

#----------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELTYPLNK" : Gosub TYPLNK
Endcase
Return

#----------------------------------------------------------#
$FIN_TABLE
Return

#------------------------------------#
$TYPLNK
Gosub LISCOD
Raz CRITERE , ICRITERE
Call ADDCRIT(CRITERE,ICRITERE,"NUMTAB",'NUMTAB=913',"") From GOBJSUB
If NBCOD<>MAXCOD
 For I=1 To NBCOD
  If I=1
   CHAINE = "&("
  Else
   CHAINE = "|"
  Endif
  Call ADDCRIT(CRITERE,ICRITERE,"CODE",'CODE="'+COD(I)+'"',CHAINE) From GOBJSUB
 Next I
 If NBCOD>0
  Call ADDCRIT(CRITERE,ICRITERE,"CODE",')','') From GOBJSUB
 Endif
Endif
Local File ATABDIV [ADI]
OBJET   = "ADI"
START   = "[F:ADI]CODE"
Return

#------------------------------------#
$INITVER
[M:DIA]ALLTYP  = 1
[M:DIA]ALLCOD  = 1
[M:DIA]TYP     = PARAM(2)
[M:DIA]CODDEB  = PARAM(3)
[M:DIA]CODFIN  = PARAM(3)
[M:DIA]MODVER=2
[M:DIA]ACTVER=2
Return

#------------------------------------#
$EXECVER
Call LNKNUT(0)
Return

#------------------------------------#
$TERMINEVER
Return

#----------------------------------------------------------------------------#
Subprog LNKNUT(EPUR)
Value Integer EPUR
Local Char    TIT(250) , MESSA(250)
Local Char    TBTYP(GLONADI)(1..150) , TBOBJ(GLONAOB)(1..150)
Local Char    TBCLE(2*GLONAVA)(1..150), TBCLE2(2*GLONAVA)(1..150), TBCLE3(2*GLONAVA)(1..150), TBCLE4(2*GLONAVA)(1..150)
Local Char    DOC_CODE(30), DOC_TYPE(GLONADI)
Local Integer I , J , K , OK , NBOBJ , OKEPU_LIG , OKEPU_ENT
Local Char    EV(200)

If EPUR
 TIT = mess(227,139,1) : # Epuration liens documentation
Else
 TIT = mess(228,139,1) : # Anomalies liens documentation
Endif
If EPUR
 Call AVERTIR(TIT+"\"+mess(205,100,1),OK) From GESECRAN : # Voulez-vous continuer ?
 If OK<>2 : End : Endif
Endif
Call OUVRE_TRACE(TIT) From LECFIC
Call TEMPON(TIT) From GESECRAN
Local File ATABDIV [ADI], ADOCFNC [ADF] , ADOCUMENT [ADO]
Raz NBOBJ
For [ADI] Where NUMTAB=910
 Case [F:ADI]CODE
  When "AT2"
   NBOBJ += 1
   TBTYP(NBOBJ) = "AT2"
   TBOBJ(NBOBJ) = "ATB"
   TBCLE(NBOBJ) = "CODFIC"
  When Default
   # JPGA 19/08/2009 Bug-52238 : Recherche dynamique des Cles multiples d'index (4 au max)
   DOC_TYPE=[F:ADI]CODE
   Gosub DOC_RECH_CLE_MULTIPLE From AGENLIBA
   If IF_DOC_TABLE
     NBOBJ += 1
     TBTYP(NBOBJ) = [F:ADI]CODE
     TBOBJ(NBOBJ) = [F:ADI]CODE
     TBCLE(NBOBJ) = DOC_CLE1  :  TBCLE2(NBOBJ)=DOC_CLE2  :  TBCLE3(NBOBJ)=DOC_CLE3  :  TBCLE4(NBOBJ)=DOC_CLE4
   Endif
 Endcase
Next ADI

GOK = 1
Trbegin [ADF]
 EV= string$( [M:DIA]ALLTYP=1, "([ADF]TYP=[M:DIA]TYP)" )
 EV+=string$( [M:DIA]ALLCOD=1, string$(EV<>""," & ")+"([ADF]COD>=[M:DIA]CODDEB)&([ADF]COD<=[M:DIA]CODFIN)" )
 EV+=string$( EV="","1=1" )
 For [ADF]ADF0(2) Where evalue(EV)
  Call ECR_TRACE([F:ADF]TYP+"~"+[F:ADF]COD,0) From GESECRAN
  OKEPU_ENT = 0
  K = find([F:ADF]TYP,TBTYP(1..NBOBJ))
  If K
   Case [F:ADF]TYP
    When "ADP"
     Default File [ADP]
     Read [ADP]ADP1 = [F:ADF]COD
    When "APM"
     Default File [AFC]
     Read [AFC]CODINT = [F:ADF]COD
     If !fstat & [F:AFC]TYPTRAIT<>2 : fstat = 3 : Endif
    When Default
     Gosub DEFAUT From ="WO"+TBOBJ(K)
     # JPGA 19/08/2009 Bug-52238 : Alimentation dynamique des éléments de clé multiples d'index (4 au max)
     DOC_TYPE=[F:ADF]TYP : DOC_CODE=[F:ADF]COD : DOC_CLE1=TBCLE(K) : DOC_CLE2=TBCLE2(K) : DOC_CLE3=TBCLE3(K) : DOC_CLE4=TBCLE4(K)
     Gosub DOC_ALIM_CLE_MULTIPLE From AGENLIBA
     Read [F] =
   Endcase
   MESSA = ""
   If fstat
    MESSA = [F:ADF]TYP-[F:ADF]COD-":"-mess(161,123,1) : # Objet inexistant
    OKEPU_ENT = 1
   Elsif dim([F]MODULE)>0 & [F]MODULE<>[F:ADF]MODULE & dim([M:DIA]MODVER)>0 & [M:DIA]MODVER=2
    MESSA = [F:ADF]TYP-[F:ADF]COD-":"-mess(132,124,1)-"("+mess([F]MODULE,14,1)+")" : # Module incorrect
   Elsif dim([F]CODACT)>0 & [F]CODACT<>[F:ADF]CODACT & dim([M:DIA]ACTVER)>0 & [M:DIA]ACTVER=2 & [F:ADF]CODACT<>"FAL"
    MESSA = [F:ADF]TYP-[F:ADF]COD-":"-mess(224,139,1)-"("+[F]CODACT+")" : # Code activité incorrect
   Endif
   If MESSA<>""
    If !EPUR
     Call ECR_TRACE("***"-MESSA,1) From GESECRAN
    Elsif EPUR & OKEPU_ENT
     Call ECR_TRACE("***"-MESSA,0) From GESECRAN
    Endif
   Endif
  Endif
  K = 0
  For [ADO]ADO3 Where TYP=[F:ADF]TYP & COD=[F:ADF]COD
   K = 1 : Break
  Next ADO
  If !K
   OKEPU_ENT = 1
   MESSA = [F:ADF]TYP-[F:ADF]COD-":"-mess(262,139,1) : # Documentation inexistante
   If !EPUR
    Call ECR_TRACE("***"-MESSA,1) From GESECRAN
   Elsif EPUR & OKEPU_ENT
    Call ECR_TRACE("***"-MESSA,0) From GESECRAN
   Endif
  Endif
  For [ADF]ADF0
   OKEPU_LIG = 0
   K = find([F:ADF]TYPLNK,TBTYP(1..NBOBJ))
   If K
    Case [F:ADF]TYPLNK
     When "ADP"
      Default File [ADP]
      Read [ADP]ADP1 = [F:ADF]CLELNK
     When "APM"
      Default File [AFC]
      Read [AFC]CODINT = [F:ADF]CLELNK
      If !fstat & [F:AFC]TYPTRAIT<>2 : fstat = 3 : Endif
     When Default
      Gosub DEFAUT From ="WO"+TBOBJ(K)
      # JPGA 19/08/2009 Bug-52238 : Alimentation dynamique des éléments de clé multiples d'index (4 au max)
      DOC_TYPE=[F:ADF]TYPLNK : DOC_CODE=[F:ADF]CLELNK : DOC_CLE1=TBCLE(K) : DOC_CLE2=TBCLE2(K) : DOC_CLE3=TBCLE3(K) : DOC_CLE4=TBCLE4(K)
      Gosub DOC_ALIM_CLE_MULTIPLE From AGENLIBA
      Read [F] =
    Endcase
    MESSA = ""
    If fstat
     MESSA = [F:ADF]TYPLNK-[F:ADF]CLELNK-":"-mess(161,123,1) : # Objet inexistant
     OKEPU_LIG = 1
    Endif
    If MESSA<>""
     If !EPUR
      Call ECR_TRACE(MESSA,1) From GESECRAN
     Elsif EPUR & OKEPU_LIG & !OKEPU_ENT
      Call ECR_TRACE(MESSA,0) From GESECRAN
     Endif
    Endif
   Endif
   If EPUR & (OKEPU_ENT or OKEPU_LIG)
    Delete [ADF]ADF0 Curr
    If fstat
     GOK=-1 : Call RSTA("ADF",[F:ADF]TYP-[F:ADF]COD-num$([F:ADF]NUM)) From GLOCK : Break 2
    Endif
   Endif
  Next ADF
 Next ADF(2)
If GOK<1
 Rollback
Else
 Commit
Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ADOCFNC   [ADF1]
Else
 Local File =[M]DOSORG+".ADOCFNC"   [ADF1]
Endif
If [M]DOSDES=nomap
 Local File ADOCFNC   [ADF2]
Else
 Local File =[M]DOSDES+".ADOCFNC"   [ADF2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ADF1], [ADF2]
Return

$TR_COP
GOK = 1
Trbegin [ADF2]
 Delete [ADF2] Where TYP=TABLE & COD=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ADOCFNC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADF2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ADF1]ADF0 Where TYP=TABLE & COD=TABLE2
  [F:ADF2] = [F:ADF1]
  If dim([F:ADF2]UPDUSR)>0    : [F:ADF2]UPDUSR    = GUSER                                         : Endif
  If dim([F:ADF2]UPDDATTIM)>0 : [F:ADF2]UPDDATTIM = datetime$
    If dim([F:ADF2]UPDDAT)>0  : [F:ADF2]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADF2]UPDDATTIM)   : Endif
  Else
    If dim([F:ADF2]UPDDAT)>0  : [F:ADF2]UPDDAT    = date$                                         : Endif
    If dim([F:ADF2]UPDTIM)>0  : [F:ADF2]UPDTIM    = time                                          : Endif
  Endif
  Write [ADF2]
  If fstat
   GOK=0 : Call FSTA("ADF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#----------------------------------------------------------------------------#
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Integer K
K = 0
For [ADO]ADO2 Where COD=VALEUR & TYP=[M]TYP
 K = 1 : Break
Next
If !K
 GMESSAGE = [M]TYP-VALEUR-":"-mess(262,139,1) : # Documentation inexistante
 mkstat = 2 : End
Endif
End

Subprog C_TYPLNK(VALEUR)
Variable Char    VALEUR()
Gosub LISCOD
If NBCOD<>MAXCOD & !find(VALEUR,COD)
 GMESSAGE = mess(98,139,1) : # Type de lien incorrect
 mkstat = 2 : End
Endif
End

#---------------------------------------------------------#
# Types de liens autorisés suivant le type de document
#---------------------------------------------------------#

$LISCOD
Local Integer  NBCOD
Local Shortint MAXCOD
Filter [ADI] Where NUMTAB=913
MAXCOD = rowcount([F:ADI])
Local Char     COD(GLONADI)(1..MAXCOD)
Raz NBCOD
Case [M]TYP
 When "AFC"
  NBCOD += 1 : COD(NBCOD) = "ACV"
  NBCOD += 1 : COD(NBCOD) = "ADP"
  NBCOD += 1 : COD(NBCOD) = "ANM"
  NBCOD += 1 : COD(NBCOD) = "GAU"
  NBCOD += 1 : COD(NBCOD) = "CDE"
  NBCOD += 1 : COD(NBCOD) = "TRS"
  NBCOD += 1 : COD(NBCOD) = "ADI"
  NBCOD += 1 : COD(NBCOD) = "AT2"
  NBCOD += 1 : COD(NBCOD) = "AML"
  NBCOD += 1 : COD(NBCOD) = "ARP"
  NBCOD += 1 : COD(NBCOD) = "ABT"
  NBCOD += 1 : COD(NBCOD) = "ATB"
 When "ADP"
  NBCOD += 1 : COD(NBCOD) = "AFC"
  NBCOD += 1 : COD(NBCOD) = "ADP"
  NBCOD += 1 : COD(NBCOD) = "ACV"
  NBCOD += 1 : COD(NBCOD) = "AOE"
  NBCOD += 1 : COD(NBCOD) = "AT2"
 When "ADM"
  NBCOD += 1 : COD(NBCOD) = "ATB"
 When "AOE"
  NBCOD += 1 : COD(NBCOD) = "ADP"
  NBCOD += 1 : COD(NBCOD) = "AT2"
  NBCOD += 1 : COD(NBCOD) = "ATB"
 When "ARP"
  NBCOD += 1 : COD(NBCOD) = "ATB"
 When "AWA"
  NBCOD += 1 : COD(NBCOD) = "ATB"
  NBCOD += 1 : COD(NBCOD) = "AWA"
 When "ACT"
  NBCOD += 1 : COD(NBCOD) = "ACT"
 When "PS1"
  NBCOD += 1 : COD(NBCOD) = "ATB"
 When "ADC"
  NBCOD += 1 : COD(NBCOD) = "APE"
  NBCOD += 1 : COD(NBCOD) = "ATB"
  NBCOD += 1 : COD(NBCOD) = "AT2"
  NBCOD += 1 : COD(NBCOD) = "TRS"
  NBCOD += 1 : COD(NBCOD) = "TRA"
 When Default
  NBCOD = 0
Endcase
Filter [ADI]
Return

Subprog S_TYPLNK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "910"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELTYPLNK","SUBADF","") From GACTION
End

Subprog IB_CLELNK
Raz GBOUT1
Case [M]TYPLNK(nolign-1)
 When "AML"         : GBOUT1 = mess(23,125,1)
 When "ADO" , "APE", "TRS", "TRA"
 When "AT2" , "ATB" : GBOUT1 = mess(16,125,1)
 When Default       : GBOUT1 = mess(191,124,1)
Endcase
End

Subprog S_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Char    PARMSK(250)(1..16) , VALMSK(250)
Local Decimal VALNUM
Raz PARMSK
Case [M]TYPLNK(nolign-1)
 When "AML"
  VALNUM = val(VALEUR)
  Call S_TAB_NUM(VALNUM,PARMSK,"SELASTMEN","APLSTD","") From GACTION
  VALEUR = num$(VALNUM)
 When "ADI"
  VALNUM = val(VALEUR)
  Call S_TAB_NUM(VALNUM,PARMSK,"SELADII","SUBADI","") From GACTION
  VALEUR = num$(VALNUM)
 When "AST"
  Call TRAITE_CHAR(VALEUR,PARMSK,"AFFMESS","RECHMESS","RECHMESS",3,"") From GTRAITE
  mkstat = 2
 When "APE" , "TRS", "TRA"
 When "AT2" , "ATB"
  PARMSK(1) = "ATB"
  VALMSK = VALEUR
  K = instr(1,VALMSK,"[")
  If K
   VALMSK = vireblc(left$(VALMSK,K-1),2)
  Endif
  Call S_TAB_CHAR(VALMSK,PARMSK,"SELOBJ","SELOBJ","") From GACTION
  If K
   VALEUR = VALMSK-right$(VALEUR,K)
  Else
   VALEUR = VALMSK
  Endif
 When Default
  PARMSK(1) = [M]TYPLNK(nolign-1)
  # JPGA 19/08/2009 Bug-52238 : Utilisation de l'action de sélection sur clé Multiple si besoin : ASELDOCNK
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find(PARMSK(1), [L]DOC_CLE_MULT)
     # Action de sélection sur une table avec une clé à N champs : Clé1_Clé2_Clé3_Clé4
     Call S_TAB_CHAR(VALEUR,PARMSK,"ASELDOCNK","SUBADO","") From GACTION
  Else
     Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
  Endif
Endcase
End

Subprog B1_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Char    PARMSK(250)(1..16) , VALMSK(250)
Local Decimal VALNUM
Raz PARMSK
Case [M]TYPLNK(nolign-1)
 When "AML"
  VALNUM = val(VALEUR)
  Call SAISIE_NUM(VALNUM,PARMSK,"FAPLSTD","APLSTD","") From GSAISIE
  VALEUR = num$(VALNUM)
 When "ADI"
  Call OBJET([M]TYPLNK(nolign-1),VALMSK,num$(VALEUR)) From GOBJET
 When "AST" , "ADO" , "APE", "TRS", "TRA"
 When "AT2","ATB"
  VALMSK = VALEUR
  K = instr(1,VALMSK,"[")
  If K
   VALMSK = vireblc(left$(VALMSK,K-1),2)
  Endif
  Call OBJET("ATB",VALMSK,"") From GOBJET
  If K
   VALEUR = VALMSK-right$(VALEUR,K)
  Endif
 When Default
  Call OBJET([M]TYPLNK(nolign-1),VALEUR,"") From GOBJET
Endcase
End

Subprog AM_CLELNK(VALEUR)
Variable Char    VALEUR()
[M]CONCAT(nolign-1) = [M]TYPLNK(nolign-1)+"~"+vireblc(toupper(VALEUR),2)
End

Subprog C_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Decimal  VALNUM
Local Char     VALMSK(250)
Local Char     DOC_CODE(30), DOC_TYPE(GLONADI)
Local Integer  K
VALEUR = vireblc(toupper(VALEUR),2)
Case [M]TYPLNK(nolign-1)
 When "ADP"
  Read [ADP]ADP1 = VALEUR
  If fstat : Raz [F:ADP] : Endif
  Call CONTROLE("ADP","",VALEUR,[F:ADP]CHAPITRE,mkstat) From CONTOBJ
 When "ADI"
  Call CONTROLE("ADV","",VALEUR,"",mkstat) From CONTOBJ
 When "AML"
  VALNUM = val(VALEUR)
  Call CONTMNL(VALNUM) From APLSTD
 When "AST" , "ADO" , "CCE" , "APE", "TRS", "TRA"
 When "AT2","ATB"
  K = instr(1,VALEUR,"[")
  If K
   VALEUR = vireblc(left$(VALEUR,K-1),2)
  Endif
  Call CONTROLE("ATB","",VALEUR,"",mkstat) From CONTOBJ
 When Default
  DOC_CODE = VALEUR
  DOC_TYPE = [M]TYPLNK(nolign-1)
  # JPGA 19/08/2009 Bug-52238 : Alimentation de champs sur clé multiples
  Gosub DOC_CONT_CLE_MULTIPLE  From AGENLIBA
  # Recherche des clés pour alimenter l'action de controle sur une table avec une clé à N champs : Clé1_Clé2_Clé3_Clé4
  If !mkstat
    Gosub DOC_ACT_CLE_MULTIPLE   From AGENLIBA
    Call CONTROLE([M]TYPLNK(nolign-1),"",[L]DOC_EXPR,[L]DOC_EXPR2,mkstat) From CONTOBJ
    # Call CONTROLE([M]TYPLNK(nolign-1),"",VALEUR,"",mkstat) From CONTOBJ
  Endif
Endcase
If mkstat : End : Endif
#VPO 23/01/08 45440 Supp contrôle unicité si doc ADC sauf pour les APE
If [M]TYP<>"ADC" or [M]TYPLNK(nolign-1)="APE"
Call UNICITE([M]TYPLNK(nolign-1)+"~"+VALEUR,[M]CONCAT(0..[M]NBLIG-1)) From OBJDIV
Endif
End

Subprog AV_INTLNK(VALEUR)
Variable Char    VALEUR()
Local Char       DOC_CODE(30), DOC_TYPE(GLONADI)

If [M]CLELNK(nolign-1)=""
 VALEUR = "" : End
Endif
Case [M]TYPLNK(nolign-1)
 When "ADP"
  Read [ADP]ADP1 = [M]CLELNK(nolign-1)
  If fstat : Raz [F:ADP] : Endif
  Call TEXTE([F:ADP]NAM,VALEUR) From OBJDIV
 When "ADI"
  Call LECTURE("ADV",[M]CLELNK(nolign-1),"") From CONTOBJ
  Call LECTEXTRA(VALEUR,"ATABTAB","LNGDES",[M]CLELNK(nolign-1),"") From ATEXTRA
 When "AML"
  VALNUM = val([M]CLELNK(nolign-1))
  Read [AML]MENLOC = VALNUM
  If fstat : VALEUR = "" : End : Endif
  If [F:AML]MENLOCAL=2
   If VALNUM<100
    Read [AST]CLE = 0;VALNUM;GLANGUE
   Else
    Read [AST]CLE = 200;VALNUM-200;GLANGUE
   Endif
  Else
   Read [AST]CLE = VALNUM;0;GLANGUE
  Endif
  VALEUR = [F:AST]LANMES
 When "AST" , "ADO" , "CCE" , "APE", "TRS", "TRA"
 When "AT2" , "ATB"
  Call LECTURE("ATB",[M]CLELNK(nolign-1),"") From CONTOBJ
  Call TEXTE([F:ATB]INTITFIC,VALEUR) From OBJDIV
 When Default
  Gosub NOMFIC From ="WO"+[M]TYPLNK(nolign-1)
  Gosub OUVFIC From ="WO"+[M]TYPLNK(nolign-1)

  DOC_CODE = [M]CLELNK(nolign-1)
  DOC_TYPE = [M]TYPLNK(nolign-1)

  # JPGA 19/08/2009 Bug-52238 : Alimentation de champs sur clé multiples
  Gosub DOC_CONT_CLE_MULTIPLE  From AGENLIBA
  # Recherche des clés pour alimenter la lecture sur une table avec une clé à N champs : Clé1_Clé2_Clé3_Clé4
  If !mkstat
    Gosub DOC_ACT_CLE_MULTIPLE   From AGENLIBA
    Call LECTURE([M]TYPLNK(nolign-1),[L]DOC_EXPR,[L]DOC_EXPR2) From CONTOBJ
    Read [ATZ]CODZONE = NOMFIC;NOMINT
    Case [F:ATZ]CODTYP
     When "AXX","AX1","AX2","AX3"
       If find([L]DOC_TYPE, [L]DOC_CLE_MULT)
          Gosub DOC_AXX_CLE_MULTIPLE From AGENLIBA
          Call LECTEXTRA(VALEUR,NOMFIC,NOMINT,[L]DOC_EXPR,[L]DOC_EXPR2) From ATEXTRA
       Else
          Call LECTEXTRA(VALEUR,NOMFIC,NOMINT,[L]DOC_CODE,"") From ATEXTRA
       Endif
     When "ATX"                   : Call TEXTE(val(num$(evalue("[F:"+ABFIC+"]"+NOMINT))),VALEUR) From OBJDIV
     When Default                 : VALEUR = evalue("[F:"+ABFIC+"]"+NOMINT)
    Endcase
  Endif
Endcase
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOFVER) 19/08/2009 09:42:38 (JPGA)
######################################################################################
Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]TYP = "" : Affzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CODDEB = "" : Affzo CODDEB : Grizo CODDEB
 [M]CODFIN = "" : Affzo CODFIN : Grizo CODFIN
Else
 Actzo CODDEB
 Actzo CODFIN
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]CODFIN=""
    [M]CODFIN=VALEUR : Affzo [M]CODFIN
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]CODDEB
   If VALEUR=""
       VALEUR="X"
   Endif
Endif
End

