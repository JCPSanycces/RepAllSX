#<AdxTL>@(#)144.0.0.0 $Revision$
# Calcul classe ABC
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH_CALABC
  When "INIT"           : Gosub INIT_CALABC
  When "CONTROLE"       : Gosub CONTROLE_CALABC
  When "EXEC"           : Gosub EXEC_CALABC
  When "TERMINE"        : Gosub TERMINE_CALABC
  When "INIT_DIA"       : Gosub INIT_DIA_CALABC
  When "OK"             : Gosub OK_CALABC
  When "END"            : Gosub END_CALABC
Endcase
Return
#############################################################
$OUVRE_BATCH_CALABC
Gosub OPEN_FILE
Return
#############################################################
$INIT_CALABC
Gosub OPEN_FILE
Local Mask STKA [DIA]
Return
#############################################################
$CONTROLE_CALABC
Return
#############################################################
$EXEC_CALABC
If [M:DIA]STOFCY <> ""
  Gosub TRAITEMENT
Endif
Return
#############################################################
$TERMINE_CALABC
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_CALABC
[M:DIA]STOFCY = GFCYDEF(0)
Return
#############################################################
$OK_CALABC
FIN  = 1
Return
#############################################################
$END_CALABC
Raz [M:DIA]
FIN = 1
Return
#############################################################
$TRAITEMENT
If GSERVEUR
  Onerrgo ERRBATCH
Endif
Gosub TRT_INI
# Traitement batch ou direct
WFCY = [M:DIA]STOFCY
WTRT = [M:DIA]CLCCOD
WFOR = [M:DIA]FORCOD
WTRA = [M:DIA]AAABKT
WTRB = [M:DIA]BBBBKT
WTRC = [M:DIA]CCCBKT
WMES = 1
WMSG = mess(90,196,1)+" : "+WFCY
If !GSERVEUR
  Call OUVRE_TRACE(WMSG) From LECFIC
Else
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Call CALABC(WFCY,WTRT,WFOR,WTRA,WTRB,WTRC,WMES,WNBR,WRET) From FUNSTKA
If WRET = 0
  [M:DIA]AAABKTNBR = WNBR(1)
  [M:DIA]BBBBKTNBR = WNBR(2)
  [M:DIA]CCCBKTNBR = WNBR(3)
  [M:DIA]DDDBKTNBR = WNBR(4)
  [M:DIA]AAABKTPRC = WNBR(5)
  [M:DIA]BBBBKTPRC = WNBR(6)
  [M:DIA]CCCBKTPRC = WNBR(7)
  [M:DIA]DDDBKTPRC = WNBR(8)
  [M:DIA]ITMPRONBR = WNBR(0)
  [M:DIA]TOTPRC    = 100
  [M:DIA]ITMPROPRC = 100
Endif
If !GSERVEUR
  Affzo [M:DIA]
Endif
Return
############################################################
$TRT_INI
Local Char    WINT1(15)
Local Char    WINT2(15)
#
Local Char    WFCY
Local Integer WTRT
Local Decimal WTRA
Local Decimal WTRB
Local Decimal WTRC
Local Char    WFOR
Local Integer WMES
Local Decimal WNBR(9)
Local Integer WRET
Local Char    WMSG(120)
Local Integer WBAT
Local Integer I
Return
###########################################################
Subprog CALABC(LFCY,LTRT,LFOR,LTRA,LTRB,LTRC,LMSG,LNBR,LRET)
Variable Char    LFCY
Variable Integer LTRT
Variable Char    LFOR
Variable Decimal LTRA
Variable Decimal LTRB
Variable Decimal LTRC
Variable Integer LMSG
Variable Decimal LNBR()
Variable Integer LRET
#
Local Integer WCOM
Local Integer WCOMMAX : WCOMMAX = 100 : # Nombre de delete dans 1 transactions
#
Local Char    WMSG(120)
Local Decimal WBAS
Local Decimal WBASA
Local Decimal WBASB
Local Decimal WTOT
Local Decimal WNBR
Local Decimal WNBRA
Local Decimal WNBRB
Local Decimal WNBRC
Local Decimal WNBRD
Local Decimal WPRC
Local Decimal WREP
Local Integer WERR
Local Integer WFSTAT
Local Char    WOLD(1), WNEW(1), WINT1(20), WINT2(20)
#
Call TEMPON("C") From GESECRAN
#Ouverture fichiers
Gosub OPEN_FILE

#Mise a jour traitement précedent
If LTRT = 3
  Goto MAJ_CALABC
Endif
###########################################################
#Lecture enregistrement Formule
Read [TFO]TFO0= 6;LFOR
  If fstat
    LRET = 90
    Goto FIN_CALABC
  Endif
#Effacement dernier calcul
Filter [ITK] Where STOFCY = LFCY
#
Trbegin [ITK]
WCOM = 0
For [ITK]
  Delete [ITK]
    If fstat
      LRET = 91
      Call FSTA("ITK") From GLOCK
      Break
    Endif
  WCOM += 1
  If WCOM >= WCOMMAX
    WCOM = 0
    Commit
    Trbegin [ITK]
  Endif
Next
Filter [ITK]
If LRET = 0
  Commit
Else
  Rollback
  Goto FIN_CALABC
Endif

#Selection enregistrements à lire
Raz WERR, WTOT, WNBR, WNBRA, WNBRB, WNBRC, WNBRD
Filter [ITF] Where STOFCY = LFCY
&            Order By Key ITF1

GPOINT = "STKABCHISTO"         #MAE pe 94099
GPE    = 0                     #MAE pe 94099
Gosub  ENTREE From EXEFNC      #MAE pe 94099
If GPE = 0                     #MAE pe 94099
  For [ITF]
    WFSTAT = fstat
    Read [ITM]ITM0=[F:ITF]ITMREF
      If fstat = 0
        Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
        If fstat
          Raz [F:ITV]
        Endif

        Raz [F:ITH]
        Filter [ITH] Where ITMREF=[F:ITF]ITMREF &
&                        STOFCY=[F:ITF]STOFCY
&                  Order By Key ITH0 Desc
        For [ITH]
          Break
        Next

        Raz [F:ITC]
        Filter [ITC] Where STOFCY=[F:ITF]STOFCY
&                      & ITMREF=[F:ITF]ITMREF
&                      & CSTTYP=1
&                      & ITCSTRDAT<=date$
&                      & ITCENDDAT>=date$
&                      & UID=0
        For [ITC]ITC0
          Break
        Next

        GPOINT = "STKABCITM"           #hcb 020305  28367
        GPE    = 0                     #hcb 020305  28367
        Gosub  ENTREE From EXEFNC      #hcb 020305  28367
        If GPE = 0                     #hcb 020305  28367
         Raz [F:ITK]
         [F:ITK]STOFCY = [F:ITF]STOFCY
         [F:ITK]ITMREF = [F:ITF]ITMREF
         [F:ITK]ABCCLS = [F:ITF]ABCCLS
         Onerrgo PB_FORMULE
         [F:ITK]FORERR = 0
         WBAS = evalue([F:TFO]FORFOR)
         If GSERVEUR
           Onerrgo ERRBATCH
         Else
           Onerrgo
         Endif
         If [F:ITK]FORERR = 0
            [F:ITK]ABCBAS = WBAS
         Else
            WERR          = 1
            [F:ITK]ABCBAS = 0
            Break
         Endif
         WTOT += WBAS
         [F:ITK]CREDAT = date$
         [F:ITK]CREUSR = GUSER
         [F:ITK]EXPNUM = [C]EXPORT
         Write [ITK]
         If fstat
            LRET = fstat
            Call FSTA("ITK") From GLOCK
            Break
         Endif
      Endif                           #hcb 020305  28367
    Endif
  fstat = WFSTAT
  Next
Endif           #FIN MAE pe 94099
Filter [ITF]
#Formule incorrecte
If WERR <> 0
  Call ERREUR([F:ITF]ITMREF+" "+mess(65,106,1)) From GESECRAN
  LRET = 99
Endif
#Erreur E/S ou formule
If LRET <> 0
  Goto FIN_CALABC
Endif
#Calcul classes ABC
WBASA = (WTOT*LTRA)/100
WBASB = (WTOT*(LTRA+LTRB))/100
Trbegin [ITK]
WREP  = 0
Filter [ITK] Where STOFCY = LFCY
&            Order By Key ITK1
For [ITK]
  If [F:ITK]FORERR = 0
    If [F:ITK]ABCBAS = 0
      [F:ITK]ABCCLSNEW   = 4
    Else
      [F:ITK]ABCCLSNEW   = 3
      If WREP <= WBASB
        [F:ITK]ABCCLSNEW = 2
      Endif
      If WREP <= WBASA
        [F:ITK]ABCCLSNEW = 1
      Endif
    Endif
    If WTOT = 0
      [F:ITK]ABCBASPRC = 0
    Else
      [F:ITK]ABCBASPRC = ([F:ITK]ABCBAS/WTOT)*100
    Endif
    Rewrite [ITK]
      If fstat
        LRET = fstat
        Call FSTA("ITK") From GLOCK
        Break
      Endif
    WREP += [F:ITK]ABCBAS
    WNBR += 1
    Case [F:ITK]ABCCLSNEW
      When 1       : WNBRA += 1
      When 2       : WNBRB += 1
      When 3       : WNBRC += 1
      When Default : WNBRD += 1
    Endcase
  Endif
Next
Filter [ITK]
#
LNBR(0) = WNBR
LNBR(1) = WNBRA
LNBR(2) = WNBRB
LNBR(3) = WNBRC
LNBR(4) = WNBRD
If WNBR <> 0
  LNBR(5) = (WNBRA/WNBR)*100
  LNBR(6) = (WNBRB/WNBR)*100
  LNBR(7) = (WNBRC/WNBR)*100
  LNBR(8) = (WNBRD/WNBR)*100
Endif
If LRET <>  0
  Rollback
  Goto FIN_CALABC
Endif
Commit
If LMSG <> 0
  [M:DIA]AAABKTNBR = LNBR(1)
  [M:DIA]BBBBKTNBR = LNBR(2)
  [M:DIA]CCCBKTNBR = LNBR(3)
  [M:DIA]DDDBKTNBR = LNBR(4)
  [M:DIA]AAABKTPRC = LNBR(5)
  [M:DIA]BBBBKTPRC = LNBR(6)
  [M:DIA]CCCBKTPRC = LNBR(7)
  [M:DIA]DDDBKTPRC = LNBR(8)
  [M:DIA]ITMPRONBR = LNBR(0)
  [M:DIA]TOTPRC    = 100
  [M:DIA]ITMPROPRC = 100
  Call PRTSCR("STKA","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(" ",0) From GESECRAN
Endif
#Traitement de mise à jour
$MAJ_CALABC
Call TEMPOFF     From GESECRAN
Call TEMPON("E") From GESECRAN
WPRC = 0
Trbegin [ITF]
Filter [ITK] Where STOFCY = LFCY
&            Order By Key ITK1
For [ITK]
  If LTRT <> 1
    Readlock [ITF]ITF1=[F:ITK]STOFCY;[F:ITK]ITMREF
  Else
    Read     [ITF]ITF1=[F:ITK]STOFCY;[F:ITK]ITMREF
  Endif
  If fstat = 1
    LRET = fstat
    WMSG = format$("K:4X",[F:ITK]STOFCY)+format$("K:20X",[F:ITK]ITMREF)+
&   " : "+mess(60,100,1)
    WMSG = [F:ITK]STOFCY+" "+[F:ITK]ITMREF+mess(60,100,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
    Goto MAJ_CALABC1
  Endif
  If fstat
    LRET = fstat
    Call FSTA("ITF") From GLOCK
    Break
  Endif
  Case [F:ITF]ABCCLS
    When 1 : WOLD = "A"
    When 2 : WOLD = "B"
    When 3 : WOLD = "C"
    When 4 : WOLD = "D"
  Endcase
  Case [F:ITK]ABCCLSNEW
    When 1 : WNEW = "A"
    When 2 : WNEW = "B"
    When 3 : WNEW = "C"
    When 4 : WNEW = "D"
  Endcase
  WPRC += [F:ITK]ABCBASPRC
  WMSG = format$("K:4X",[F:ITK]STOFCY)+format$("K:20X",[F:ITK]ITMREF)+
& " : "+WNEW+" ("+WOLD+") "+mess(337,200,1)+" : "+format$("N:12.2",[F:ITK]ABCBAS)+
& " "+format$("N:3.3",WPRC)
  [F:ITF]ABCCLS = [F:ITK]ABCCLSNEW

  #--- Dem 58501
  GPOINT="MAJABCITF" : Gosub ENTREE From EXEFNC

  If LTRT <> 1
    Rewrite [ITF]
      If fstat
        LRET = fstat
        Call FSTA("ITF") From GLOCK
        Break
      Endif
  Endif
  If LMSG <> 0
    Call ECR_TRACE(WMSG,0) From  GESECRAN
  Endif
$MAJ_CALABC1
  fstat = 0
Next
Filter [ITK]
#
If LRET = 0
  Commit
Else
  Rollback
Endif
#Effacement si mise a jour
If LTRT <> 1 & LRET = 0
  Trbegin [ITK]
  Delete [ITK] Where STOFCY = LFCY
    If fstat
      LRET = 91
      Call FSTA("ITK") From GLOCK
      Rollback
      Goto FIN_CALABC
    Endif
  Commit
Endif
#Fin
$FIN_CALABC
Call TEMPOFF From GESECRAN
End
###########################################################
$PB_FORMULE
[F:ITK]FORERR = 1
Resume
###########################################################
$OPEN_FILE
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITH]) = 0 : Local File ITMMVTHIS  [ITH] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITC]) = 0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:ITK]) = 0 : Local File ITMABCWRK  [ITK] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
Return
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
