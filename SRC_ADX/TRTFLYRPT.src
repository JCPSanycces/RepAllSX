###########################################################################
# Test de la saisie du code paramètre WARFLYRPT
#
# Module CRM                                              22 Septembre 2003
############################################################################

Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value Char PARAM
Value Char TSTVALEUR
Variable Integer OK

If PARAM <> "WARFLYRPT"
    #Erreur dans le code paramètre
    GMESSAGE = mess(204, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If TSTVALEUR = "" : End : Endif

If !clalev([F:ARP]) : Local File AREPORT [ARP] : Endif

Read [ARP] ARP0 = TSTVALEUR
If fstat
    #La valeur saisie pour ce paramètre ne correspond pas à un état Crystal Report.
    GMESSAGE = mess(462, 182, 2)
    GERR = 1
    OK = 0
    End
Endif

OK = 1
End





