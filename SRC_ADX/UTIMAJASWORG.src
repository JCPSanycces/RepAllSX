#<AdxTL>@(#)4.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Copy data from table ASHWORG to ASHWSEC, ASHWBLC
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Copy data from table ASHWORG to ASHWSEC and ASHWBLC") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#
$ERRFILE
ERR=1
Resume
#----------------------------------------------------------------------------------------#

$MAJTAB
Local Integer ERR : ERR=0
Onerrgo ERRFILE
If DOSSIER=nomap
 Local File ASHWORG [ASWG]
Else
 Local File =DOSSIER+".ASHWORG" [ASWG]
Endif
Onerrgo
If ERR : Return : Endif

If DOSSIER=nomap
 Local File ASHWSEC [ASWS]
 Local File ASHWBLC [ASWB]
Else
 Local File =DOSSIER+".ASHWSEC" [ASWS]
 Local File =DOSSIER+".ASHWBLC" [ASWB]
Endif

Local Integer I

Trbegin [ASWG]
 For [ASWG]

  #Blocs
  For I=1 To 50
   If [F:ASWG]CODBLC(I-1)<>""
    Read [ASWB]ASWB0=[F:ASWG]CODREP;[F:ASWG]CODBLC(I-1)
    If fstat
      Raz [F:ASWB]
      [F:ASWB]=[F:ASWG]

      [F:ASWB]CODBLC=[F:ASWG]CODBLC(I-1)
      [F:ASWB]SECBLC=[F:ASWG]SECBLC(I-1)
      [F:ASWB]ACTBLC=[F:ASWG]ACTBLC(I-1)
      [F:ASWB]INTBLC=[F:ASWG]INTBLC(I-1)
      [F:ASWB]NIVBLC=[F:ASWG]NIVBLC(I-1)
      Write [ASWB]
      If fstat
       Call ERREUR("ASHWBLC"-[F:ASWG]CODREP-[F:ASWB]CODBLC,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

  #Sections
  For I=1 To 20
   If [F:ASWG]CODSEC(I-1)<>""
    Read [ASWS]ASWS0=[F:ASWG]CODREP;[F:ASWG]CODSEC(I-1)
    If fstat
      Raz [F:ASWS]
      [F:ASWS]=[F:ASWG]

      [F:ASWS]CODSEC=[F:ASWG]CODSEC(I-1)
      [F:ASWS]INTSEC=[F:ASWG]INTSEC(I-1)
      [F:ASWS]ACTSEC=[F:ASWG]ACTSEC(I-1)
      [F:ASWS]NIVSEC=[F:ASWG]NIVSEC(I-1)
      Write [ASWS]
      If fstat
       Call ERREUR("ASHWSEC"-[F:ASWG]CODREP-[F:ASWS]CODSEC,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

 Next
Commit

Close Local File [ASWG],[ASWB],[ASWS]

Return
