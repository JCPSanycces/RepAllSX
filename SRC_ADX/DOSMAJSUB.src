#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
## DOSMAJSUB  sous-programmes
#######################################################################
Subprog TEXTE(NUMTEX)
Variable Integer NUMTEX
Local Integer ASTATUS
Local Char MESSAGE(250)
If NUMTEX=0 : End : Endif
Read [SATX]NUMERO = GLANGUE;NUMTEX
If fstat : End : Endif
Read [ATX]TEXTE = GLANGUE;[F:SATX]TEXTE
If !fstat
 NUMTEX = [F:ATX]NUMERO
Else
 #115210 ici on ne s'occupe pas du serveur de texte
 Filter [ATX] Where NUMERO<GMAXTXTSTD Order By Key DERNUM=NUMERO;LAN
 Read [ATX]DERNUM Last
 Filter [ATX]
 If fstat>2
  NUMTEX = 1
 Else
  NUMTEX = [F:ATX]NUMERO+1
 Endif
 [F:ATX] = [F:SATX]
 [F:ATX]NUMERO = NUMTEX
 Write [ATX]
 If fstat
  GOK = 0 : Call FSTA("ATX") From GLOCK : End
 Endif
Endif
End

Subprog OKCOP(MODULE,ACTIV,OK)
Value    Integer MODULE
Value    Char    ACTIV
Variable Integer OK
If MODULE<1
 OK = 0
 Call ECR_TRACE("Module=0",1) From GESECRAN
 End
Endif
OK = ([F:ADS]MODULE(MODULE-1)=2)
If OK
 If ACTIV<>""
  Read [ADA]ADA0 = [F:ADS]DOSSIER ; ACTIV
  If fstat | [F:ADA]FLACT<>2
   OK = 0
  Endif
 Endif
Endif
End

Subprog ACTIV(ACTIV)
Variable Char    ACTIV()
If ACTIV<>""
 Read [ADA]ADA0 = [F:ADS]DOSSIER ; ACTIV
 If fstat | [F:ADA]FLACT<>2
  ACTIV = ""
 Endif
Endif
End

Subprog TEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2
Read [SAXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat : End : Endif
Readlock [AXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA" : End
Elsif !fstat
 [F:AXX]TEXTE = [F:SAXX]TEXTE
 If dim([F:AXX]UPDDAT)>0 : [F:AXX]UPDDAT = date$ : Endif
 If dim([F:AXX]UPDUSR)>0 : [F:AXX]UPDUSR = GUSER : Endif
 Rewrite [AXX]
 If fstat
  GOK=0 : Call FSTA("AXX") From GLOCK : End
 Endif
Else
 [F:AXX] = [F:SAXX]
 If dim([F:AXX]CREDAT)>0 : [F:AXX]CREDAT = date$ : Endif
 If dim([F:AXX]CREUSR)>0 : [F:AXX]CREUSR = GUSER : Endif
 If dim([F:AXX]UPDDAT)>0 : [F:AXX]UPDDAT = [0/0/0] : Endif
 If dim([F:AXX]UPDUSR)>0 : [F:AXX]UPDUSR = "" : Endif
 Write [AXX]
 If fstat
  GOK=0 : Call FSTA("AXX") From GLOCK : End
 Endif
Endif
End

