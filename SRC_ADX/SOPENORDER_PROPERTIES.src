End
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - deleted all _LEG properties call
# ----------------------- CPYCUR --------------------------------------
$CPYCUR
  Case [L]ARULE
    When "GET"       : Gosub GET_CPYCUR
    When Default     : Return
  Endcase
Return

$GET_CPYCUR
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.CPYCUR = [F:CPY]ACCCUR
  Endif
Return
# ----------------------- INVDTA --------------------------------------
$INVDTA
  Case [L]ARULE
    When "PROPAGATE" : Gosub PROPAGATE_INVDTA
    When Default     : Return
  Endcase
Return


$PROPAGATE_INVDTA
  this.INVCDTA = num$(this.INVDTA)
Return

# ----------------------- INVCDTA --------------------------------------
$INVCDTA
  Case [L]ARULE
    When "GET"       : Gosub GET_INVCDTA
    When Default     : Return
  Endcase
Return

$GET_INVCDTA
  this.INVCDTA = num$(this.INVDTA)
Return

