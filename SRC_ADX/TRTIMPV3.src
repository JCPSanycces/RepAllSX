#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GBIDC1 = "ZBPC"
PARAM(1) = GBIDC1
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIMPV3","DIMPV3",4,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$INIT
Local Integer  IMPSTA
Local Char     TIT(50)
TIT = mess(119,141,1) : # Import v3
Gosub OUVRE
Local Mask IMPV3 [DIA]
Raz [M:IMP2]
Raz [M:DIA]
[M:DIA]CODCNV = PARAM(1)
Return

$DEBUT
If [M:DIA]CODCNV<>""
 Call C_CODCNV([M:DIA]CODCNV)
 If mkstat
  GERR = 1 : FIN = 1 : Return
 Else
  Default Mask [DIA]
  Call AM_CODCNV([M:DIA]CODCNV)
  If mkstat : FIN = 1 : Return : Endif
 Endif
 Grizo [DIA]CODCNV
Else
 Actzo CODCNV
Endif
Return

#######################################################
$OUVRE
If clalev([F:AEV])=0  : Local File AEXPV3     [AEV]  : Endif
If clalev([F:AED])=0  : Local File AEXPV3D    [AED]  : Endif
If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE     [ATX]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif

If clalev([M:AEV0])=0 : Local Mask AEV0       [AEV0] : Endif
If clalev([M:AEV1])=0 : Local Mask AEV1       [AEV1] : Endif
If clalev([M:AEV2])=0 : Local Mask AEV2       [AEV2] : Endif
If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
Return

#######################################################
$CONTROLE
If GSTATUT=GSTAESC
 FIN = 1 : Return
Endif
TIT -= [M:DIA]CODCNV
Call CONTROLE("AEV","",[M:DIA]CODCNV,"",mkstat) From CONTOBJ
If mkstat
 GMESSAGE = mess(120,141,1)-GMESSAGE : # Code paramètrage import v3
 GERR = 1 : FIN = 1 : Return
Endif
If !GSERVEUR : TMP = 1 : Endif
Return

#######################################################
$EXEC
If !GSERVEUR
     Call OUVRE_TRACE(TIT) From LECFIC
Endif

[M:AEV0] = [F:AEV]
[M:AEV1] = [F:AEV]
[M:AEV2] = [F:AEV]
Gosub LIENS From SUBAEV

Local Char    FV3CNV(GDIMFIC), FX3CNV(GDIMFIC)
Local Char    FV3STO(GDIMFIC) , FX3STO(GDIMFIC)
Local Integer TV3CNV , TX3CNV
Local Integer WERROR

[L] = [M:DIA]

# commun avec SUBAEV et TRTIMPV3
Call IMPORT_SUBAEV (TV3CNV,TX3CNV,FV3STO,FX3STO,[M:DIA]CODCNV,[M:AEV1]CODDBA,WERROR) From SUBAEV
If WERROR <> 0
    If GMESSAGE <> ""
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Endif
    IMPSTA = WERROR
Endif

If GTRACE<>"" & ([L]TV3CNV=1 or [L]TX3CNV=1)
     Call ECR_TRACE("|"+[L]FV3CNV-"->"-[L]FX3CNV,0) From GESECRAN
Endif

$FIN_EXEC
If !IMPSTA & [M:DIA]IMPORT=2
     [M:IMP2]MODIMP = [F:AEV]MODELE
     [M:IMP2]TYPEXP = [M:DIA]TX3CNV
     [M:IMP2]NOMIMP = [M:DIA]FX3CNV
     Call LECTURE("AOE",[F:AEV]MODELE,"") From CONTOBJ
     [M:IMP2]AOWSTA = [F:AOE]AOWSTA
     Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
     IMPSTA = [M:IMP2]STAT
     If IMPSTA <> 0
        Call ERR_IMPORT(IMPSTA,GMESSAGE) From GIMPOBJ
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
     Endif
Endif
If !GSERVEUR
     Call FERME_TRACE From LECFIC
Endif
Return



#######################################################
$TERMINE
If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

###########################################################################################
#  Conversion d'un fichier export v3 en fichier importable x3
###########################################################################################
Subprog  CONV3(CODE,FIC_TO_CONVERT,FIC_CONVERT,IMPSTA)
Value    Char     CODE
Value    Char     FIC_TO_CONVERT
Value    Char     FIC_CONVERT
Variable Integer  IMPSTA
Local    Shortint DIME : DIME = 200
Local    Char     VALEUR(250), LEC(250)(1..DIME), REF(250)(1..DIME)
Local    Char     CPT(20)(1..3), SEPENR(10), SEPCHP(10)
Local    Integer  ZONLIEN(1..8,1..10)
Local    Integer  I, J, K, OK, L, NOZON, NBLIEN, ENREG
Local    Integer  NOZON, NBLIEN, PREM, NORUPT, ZONIND, NUMSEC
Local    Char     CODRUPT(10), COND(30), FLGRUPT(10), CHAINE(250)
Local    Decimal  CUMUL(10), TYPRUPT(10)
Local    Char     IMPIRS(10) , IMPIFS(10)
Local    Integer  IMPIUM , V3IUM
Local    Char     ACTION(20)

If GTRACE<>""
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 CHAINE = mess(120,141,1)-CODE-mess(126,141,1) : # Code paramètrage import v3, Conversion fichier
 CHAINE -= "|"+FIC_TO_CONVERT
 CHAINE -= "->"-FIC_CONVERT
 Call ECR_TRACE(CHAINE,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

NBLIEN = [M:AEV1]NBRFLG
Raz ZONLIEN, CODRUPT, FLGRUPT, NORUPT, TYPRUPT
If [M:AEV1]NBRFLG>1
 NORUPT = [M:AEV1]NBRFLG
 FLGRUPT = [M:AEV1]FLGREC([M:AEV1]NBRFLG-1)
 For I=0 To [M:AEV2]NBRLIG-1
  If find([M:AEV2]FLD(I),"CCE","CCE(0)","CCE(1)","CCE(2)","CCE(3)"
&                       ,"CCE(4)","CCE(5)","CCE(6)","CCE(7)","CCE(8)")
   K = find([M:AEV2]TYP(I),[M:AEV1]FLGREC(0..[M:AEV1]NBRFLG-1))
   If K
    TYPRUPT(K-1) = 1 : # Type compta
   Endif
  Endif
  If [M:AEV2]TYP(I)=[M:AEV1]FLGREC([M:AEV1]NBRFLG-1) & [M:AEV2]FLD(I)="/" & CODRUPT=""
   CODRUPT = [M:AEV2]ZON(I)
  Endif
 Next I
 For I=1 To NBLIEN
  VALEUR = [M:AEV1]FLGV3(I-1)
  K = 0
  While VALEUR<>""
   J = instr(1,VALEUR,";")
   K += 1
   If J
    ZONLIEN(I,K) = val(left$(VALEUR,J-1))
    VALEUR = right$(VALEUR,J+1)
   Else
    ZONLIEN(I,K) = val(VALEUR)
    VALEUR = ""
   Endif
  Wend
 Next I
 For I=1 To 3
  Call PARAM("","CCEDSPOBL"+num$(I),CPT(I)) From ADOVAL : # Sections ana par axe obligatoire
 Next I
Endif

Call LECTURE("AOE",[M:AEV1]MODELE,"") From CONTOBJ
SEPCHP = [F:AOE]SEPFLD
SEPENR = [F:AOE]SEPREC

I = 1
$SEP1
I = instr(I,SEPCHP,"\")
If I
 SEPCHP = left$(SEPCHP,I-1)+chr$(val(mid$(SEPCHP,I+1,3)))+right$(SEPCHP,I+4)
 I += 1
 Goto SEP1
Endif

I = 1
$SEP2
I = instr(I,SEPENR,"\")
If I
 SEPENR = left$(SEPENR,I-1)+chr$(val(mid$(SEPENR,I+1,3)))+right$(SEPENR,I+4)
 I += 1
 Goto SEP2
Endif

Case [F:AOE]TYPFIL
 When 1 : IMPIRS = SEPCHP : IMPIFS = ""
 When 2 : IMPIRS = SEPENR : IMPIFS = SEPCHP
 When 3 : IMPIRS = SEPENR : IMPIFS = SEPCHP
 When 4 : IMPIRS = SEPENR : IMPIFS = ""
 When 5 : IMPIRS = SEPENR : IMPIFS = ""
 When 6 : IMPIRS = SEPENR : IMPIFS = SEPCHP
Endcase

Case [F:AOE]CODDBA
 When 1 : IMPIUM = GASCII
 When 2 : IMPIUM = GUTF8
 When 3 : IMPIUM = GUCS2
Endcase

If dim([F:AEV]CODDBA)>0
 Case [F:AEV]CODDBA
  When 0,1 : V3IUM = GASCII
  When 2   : V3IUM = GUTF8
  When 3   : V3IUM = GUCS2
 Endcase
Else
 V3IUM = GASCII
Endif

Openi FIC_TO_CONVERT,0 Using [V3]
Iomode adxirs IMPIRS Using [V3]
Iomode adxifs IMPIFS Using [V3]
Iomode adxium V3IUM  Using [V3]
Openo FIC_CONVERT,0 Using [V3_]
Iomode adxirs IMPIRS Using [V3_]
Iomode adxifs IMPIFS Using [V3_]
Iomode adxium IMPIUM Using [V3_]

Raz CUMUL, ENREG, IMPSTA
DEBUT = 1
While fstat=0
 Rdseq LEC Using [V3]
 If fstat : Break : Endif
 ENREG += 1
 If NORUPT>1
  If LEC(1)=CODRUPT
   Gosub WR_CUMUL
   Raz CUMUL
   DEBUT = 1
  Elsif DEBUT | CODRUPT=""
   RUPT = 0
   For I=1 To NORUPT-1 + (CODRUPT="")
    For J=1 To 10
     If ZONLIEN(I,J)<>0
      If LEC(ZONLIEN(I,J))<>REF(ZONLIEN(I,J))
       RUPT = I : Break 2
      Endif
     Endif
    Next J
   Next I
   If RUPT=0
    GBIDC3 = FIC_TO_CONVERT : IMPSTA = 17 : Break
   Endif
   Gosub REF
   For I=RUPT To NORUPT-1 + (CODRUPT="")
    NIV = I
    Gosub WR_X3
   Next I
   DEBUT = 0
  Else
   For I=NORUPT To NBLIEN
    NIV = I
    Gosub WR_X3
   Next I
  Endif
 Else
  NIV = 1
  Gosub WR_X3
 Endif
Wend
Openi Using [V3]
Openo Using [V3_]
Call ECR_TRACE(num$(ENREG)-mess(124,141,1),0) From GESECRAN : # lignes converties
End

$REF
For I=1 To dim(LEC)
 REF(I) = LEC(I)
Next I
Return

$WR_X3
GPE = 0
GPOINT = "FILTER_WR" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif
Raz K , L
For J=0 To [M:AEV2]NBRLIG-1
 If val([M:AEV2]ZON(J))<>0 & [M:AEV2]TYP(J)=[M:AEV1]FLGREC(NIV-1)
  If [M:AEV2]OBLIG(J)=2
   L += 1
   If vireblc(LEC(val([M:AEV2]ZON(J))),4)<>""
    K = 1
   Endif
  Endif
 Endif
Next J
If L & !K
 Return
Endif
Raz PREM
Iomode adxifs "" Using [V3_]
For J=0 To [M:AEV2]NBRLIG-1
 If [M:AEV2]TYP(J)=[M:AEV1]FLGREC(NIV-1)
  If !PREM
   PREM = 1
  Else
   Wrseq IMPIFS; Using [V3_]
  Endif
  Case left$([M:AEV2]FLD(J),1)
   When "/"
    Wrseq [M:AEV1]FLGREC(NIV-1); Using [V3_]
   When Default
    NOZON = val([M:AEV2]ZON(J))
    If NOZON
     VALEUR = LEC(NOZON)
     If [M:AEV2]NUMTAB(J)<>0
      Call TRANSCODE([M:AEV2]FIL(J),[M:AEV2]FLD(J),[M:AEV2]NUMTAB(J),VALEUR)
     Endif
     ACTION = "IMPORTV3" : Gosub ACTIONG
     fstat = 0 : # Pour éviter une fin de fichier prématurée
     If [M:AEV2]TYP(J)=FLGRUPT
      K = find([M:AEV2]TYP(J),[M:AEV1]FLGREC(0..[M:AEV1]NBRFLG-1))
      If K & TYPRUPT(K-1)=1
       Case [M:AEV2]FLD(J)
        When "CCE","CCE(0)","CCE(1)","CCE(2)","CCE(3)","CCE(4)","CCE(5)","CCE(6)","CCE(7)","CCE(8)"
         If [M:AEV2]COND(J)<>""
          K = instr(1,[M:AEV2]COND(J),"=")
          If K
           NUMSEC = val(right$([M:AEV2]COND(J),K+1))
           ZONIND = val([M:AEV2]COND(J))
           If LEC(ZONIND)>"" & evalue(LEC(ZONIND))<>NUMSEC
            VALEUR = CPT(NUMSEC)
           Endif
          Endif
         Endif
        When "AMTCUR"
         CUMUL(1) += val(VALEUR)
        When "QTY"
         CUMUL(2) += val(VALEUR)
       Endcase
      Endif
     Endif
    Else
     VALEUR =""
    Endif
    If [M:AEV2]COND(J)<>"" & !find([M:AEV2]FLD(J),"CCE"   ,"CCE(0)","CCE(1)","CCE(2)","CCE(3)")
&                          & !find([M:AEV2]FLD(J),"CCE(4)","CCE(5)","CCE(6)","CCE(7)","CCE(8)")
     If !evalue([M:AEV2]COND(J))
      VALEUR = ""
     Endif
    Elsif [M:AEV2]INIT(J)<>""
     VALEUR = num$(evalue([M:AEV2]INIT(J)))
    Endif
    Wrseq VALEUR; Using [V3_]
  Endcase
 Endif
Next J
Wrseq Using [V3_]
Iomode adxifs IMPIFS Using [V3_]
Return

$WR_CUMUL
If sum(CUMUL)=0 : Return : Endif
Iomode adxifs "" Using [V3_]
Raz PREM
For J=0 To [M:AEV2]NBRLIG-1
 If [M:AEV2]TYP(J)=FLGRUPT
  If !PREM
   PREM = 1
  Else
   Wrseq IMPIFS; Using [V3_]
  Endif
  Case left$([M:AEV2]FLD(J),1)
   When "/"
    Wrseq FLGRUPT; Using [V3_]
   When Default
    NOZON = val([M:AEV2]ZON(J))
    If NOZON
     Case [M:AEV2]FLD(J)
       When "CCE","CCE(0)","CCE(1)","CCE(2)","CCE(3)","CCE(4)","CCE(5)","CCE(6)","CCE(7)","CCE(8)"
        If [M:AEV2]COND(J)<>""
         K = instr(1,[M:AEV2]COND(J),"=")
         If K
          NUMSEC = val(right$([M:AEV2]COND(J),K+1))
          VALEUR = CPT(NUMSEC)
         Else
          VALEUR = ""
         Endif
        Else
         VALEUR = ""
        Endif
      When "AMTCUR"
       VALEUR = num$((CUMUL(1)*-2)/3)
      When "QTY"
       VALEUR = num$((CUMUL(2)*-2)/3)
      When Default
       VALEUR = ""
     Endcase
    Else
     VALEUR = ""
    Endif
    If [M:AEV2]COND(J)<>"" & !find([M:AEV2]FLD(J),"CCE"   ,"CCE(0)","CCE(1)","CCE(2)","CCE(3)")
&                          & !find([M:AEV2]FLD(J),"CCE(4)","CCE(5)","CCE(6)","CCE(7)","CCE(8)")
     If !evalue([M:AEV2]COND(J))
      VALEUR = ""
     Endif
    Elsif [M:AEV2]INIT(J)<>""
     VALEUR = num$(evalue([M:AEV2]INIT(J)))
    Endif
    Wrseq VALEUR; Using [V3_]
  Endcase
 Endif
Next J
Wrseq Using [V3_]
Iomode adxifs IMPIFS Using [V3_]
Return

########################################################
$ACTIONG
GPE = 0
If [F:AOE]SPEIMP<>""
 If GTEST : Infbox [F:AOE]SPEIMP+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =[F:AOE]SPEIMP
Endif
If [F:AOE]TRTIMP<>"" & !GPE
 If GTEST : Infbox [F:AOE]TRTIMP+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =[F:AOE]TRTIMP
Endif
Return

########################################################
Subprog TRANSCODE(TABLE,ZONE,NUMTAB,VALEUR)
Value Char TABLE , ZONE
Value Integer NUMTAB
Variable Char VALEUR
If clalev([ATY])=0 : Local File ATYPE [ATY] : Endif
Local Integer TYPFMT , K
K = instr(1,ZONE,"(")
If K : ZONE = left$(ZONE,K-1) : Endif
Read [ATZ]CODZONE = TABLE ; ZONE
If fstat : End : Endif
Read [ATY]CODTYP  = [F:ATZ]CODTYP
If fstat : End : Endif
Case [F:ATY]TYPTYP
 When 1         : TYPFMT = 4 : # Menu local
 When 2,3,4,5,6 : TYPFMT = 2 : # Numérique
 When 7         : TYPFMT = 1 : # Alpha
 When 8         : TYPFMT = 3 : # Date
 When 9         : TYPFMT = 7 : # Blob
 When 10        : TYPFMT = 8 : # Clob
Endcase
Call TRANSCODE([L]NUMTAB,VALEUR,TYPFMT) From SUBIMPOBJ
End

########################################################
Subprog C_CODCNV(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 Call CONTROLE("AEV","",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog AM_CODCNV(VALEUR)
Variable Char     VALEUR
[M]CODCNV = VALEUR
Call LECTURE("AEV",VALEUR,"") From CONTOBJ
[M]TV3CNV = [F:AEV]TYPV3
Call AM_TV3CNV([M]TV3CNV)
[M]TX3CNV = [F:AEV]TYPX3
Call AM_TX3CNV([M]TX3CNV)
Affzo TV3CNV , TX3CNV , FV3CNV , FX3CNV
End

Subprog C_TV3CNV(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TV3CNV(VALEUR)
Variable Integer VALEUR
Call LECTURE("AEV",[M]CODCNV,"") From CONTOBJ

If VALEUR=1
 [M]FV3STO=""
 [M]FV3CNV=""
 Grizo [M]FV3STO
 Affzo [M]FV3STO
Else
 Actzo [M]FV3STO
 [M]FV3STO = [F:AEV]FILV3
 [M]FV3CNV = [F:AEV]FILV3
 Affzo [M]FV3STO
Endif
End

Subprog C_FV3CNV(VALEUR)
Variable Char     VALEUR
Local Char NOMFIC(GDIMFIC)
NOMFIC = VALEUR
Gosub CONTFIC From GIMPOBJ
End

Subprog C_TX3CNV(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TX3CNV(VALEUR)
Variable Integer VALEUR
Call LECTURE("AEV",[M]CODCNV,"") From CONTOBJ

[M]FX3CNV = [F:AEV]FILX3
[M]FX3STO = [F:AEV]FILX3
If VALEUR=1
 [M]FX3STO = ""
 [M]FX3CNV= ""
 Grizo [M]FX3STO
 Affzo [M]FX3STO
Else
 Actzo [M]FX3STO
 Affzo [M]FX3STO
Endif
End

Subprog C_FX3CNV(VALEUR)
Variable Char     VALEUR
Call C_NOMEXP(VALEUR) From GEXPOBJ
If mkstat : End : Endif
If VALEUR<>"" & VALEUR=[M]FV3CNV
 GMESSAGE = mess(125,141,1) : # les noms des fichiers doivent être différents
 mkstat = 2
Endif
End

Subprog AP_FX3CNV(VALEUR)
Variable Char     VALEUR
Local    Integer  OK
If [M]TX3CNV=2 & filinfo(VALEUR,0)>=0
 OK =2 : Call OUINON(mess(7,141,1),OK) From GESECRAN : # Fichier destination présent, effacement ?
 If OK<>2 : mkstat=2 : End : Endif
Endif
End


######################################################################################
## Ajout ASTO : # CCL
######################################################################################
Subprog C_FV3STO(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
# en saisie requete batch pas de controle . controle fait plus loin
If GBATCH
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TV3CNV, VALEUR,[M]FV3CNV,E_TYPE_FILEOVERWRITE,GMESSAGE)
Else
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TV3CNV, VALEUR,[M]FV3CNV,E_TYPE_FILEREAD,GMESSAGE)
Endif
If mkstat : End : Endif
If VALEUR<>"" & VALEUR=[M]FX3STO
 GMESSAGE = mess(125,141,1) : # les noms des fichiers doivent être différents
 mkstat = 2
Endif
End

Subprog AM_FV3STO(VALEUR)
Variable Char    VALEUR()
 [M]FV3CNV = VALEUR
End

Subprog C_FX3STO(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TX3CNV, VALEUR,[M]FX3CNV,E_TYPE_FILEOVERWRITE,GMESSAGE)
If mkstat : End : Endif
If VALEUR<>"" & VALEUR=[M]FV3STO
 GMESSAGE = mess(125,141,1) : # les noms des fichiers doivent être différents
 mkstat = 2
Endif
End

Subprog AP_FX3STO(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_FX3STO(VALEUR)
Variable Char    VALEUR()
[M]FX3CNV = VALEUR
End

######################################################################################

