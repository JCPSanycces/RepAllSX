#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
# CLASS COMPANY
##########################################################################################################

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_BEFORE"               : Gosub AINSERT_BEFORE
      When "AUPDATE_BEFORE"               : Gosub AUPDATE_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "AVALDIC"                      : Gosub AVALDIC
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return






##########################################################################################################
$AINSERT_BEFORE
Gosub ATZ_NUMLIG
Return

##########################################################################################################
$AUPDATE_BEFORE
Gosub ATZ_NUMLIG
Return

$AVALDIC
 Gosub VERIF
  If OK
   # C'est obligatoire pour les tables Superviseur ... mais on perd les listes de gauche !!!
   If TABSUP
    Close File : # Le Close Local File ne ferme les tables 'non fermées' des trt appelant
    FERME_TABSUP = 1
   Endif
   Call VALDIC From VALDIC
   Gosub EXE_TRTINI From SUBATB
   If nomap=GDOSX3 & find(CLECUR1,"ADOSSIER","ADOSDIM","ADOSACT","ADOSSOL")
    If clalev([F:ADS])>0 : Close Local File [ADS] : Endif
    If clalev([F:ADD])>0 : Close Local File [ADD] : Endif
    If clalev([F:ADA])>0 : Close Local File [ADA] : Endif
    If clalev([F:ADE])>0 : Close Local File [ADE] : Endif
    Local File ADOSSIER [ADS] , ADOSACT [ADA] , ADOSDIM [ADE] , ADOSSOL [ADD]
    For [ADS]
     If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
      Onerrgo RIEN
      Call CREPAR From DOSDIV : # Régénération des fichiers PARAM.ini
      Onerrgo
     Endif
    Next ADS
    Close Local File [ADS] , [ADA] , [ADE] , [ADD]
   Endif
   If TABSUP
    Gosub OUVRE_FIC From SUBATB
    REAFF_BOITE = 1
    REPONSE = GSTAEND
   Endif
   Read [ATB]CODFIC = CLECUR1
   Call OUVRE_TRACE("") From LECFIC
   Call GENVUE(nomap) From DOSVUE
   Call FERME_TRACE From LECFIC
   Call EFFACE(filpath("TRA",GTRACE,"tra"),STAT) From ORDSYS
   Raz GTRACE , GERRTRACE
  Endif
Return


##########################################################################################################
$ATZ_NUMLIG
Local Integer I
For I=1 To maxtab(this.ATZ)
 If this.ATZ(I) <> null and !find(this.ATZ(I).ASTALIN,[V]CST_ANEWDEL, [V]CST_ADEL)
  this.ATZ(I).NUMLIG = this.ATZ(I).AORDER
 Endif
Next I
Return

##########################################################################################################
$VERIF
Local Integer FOUND
FOUND=[V]CST_AFALSE
For I=1 To maxtab(this.ATZ)
    If find(this.ATZ(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      FOUND=[V]CST_ATRUE
      Break
    Endif
 Next
 If FOUND=[V]CST_AFALSE
   # Table does not have fields
   [L]ASTATUS = fmet this.ASETERROR("ATABLE",mess(28,176,1),[V]CST_AERROR)
 Endif

FOUND=[V]CST_AFALSE
For I=1 To maxtab(this.ATI)
    If find(this.ATI(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      FOUND=[V]CST_ATRUE
      Break
    Endif
 Next
 If FOUND=[V]CST_AFALSE
  # Table does not have a primary index
  [L]ASTATUS = fmet this.ASETERROR("ATABLE",mess(23,176,1),[V]CST_AERROR)
 Endif

FOUND=[V]CST_AFALSE
If this.INTIT <>""
  For I=1 To maxtab(this.ATZ)
    If find(this.ATZ(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      If this.INTIT = this.ATZ(I).CODZONE
        FOUND=[V]CST_ATRUE
        Break
      Endif
    Endif
  Next
  If FOUND=[V]CST_AFALSE
    # The title field is not referenced (in the columns)
    [L]ASTATUS = fmet this.ASETERROR("ATABLE",mess(23,176,1),[V]CST_AERROR)
  Endif
Endif

FOUND=[V]CST_AFALSE
If this.INTITC <>""
  For I=1 To maxtab(this.ATZ)
    If find(this.ATZ(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      If this.INTITC = this.ATZ(I).CODZONE
        FOUND=[V]CST_ATRUE
        Break
      Endif
    Endif
  Next
  If FOUND=[V]CST_AFALSE
    # The short title field is not referenced (in the columns)
    [L]ASTATUS = fmet this.ASETERROR("ATABLE",mess(210,123,1),[V]CST_AERROR)
  Endif
Endif

FOUND=[V]CST_AFALSE
If dim([M:ATB1]FLGLEG)>0 & [M:ATB1]FLGLEG=2
  For I=1 To maxtab(this.ATZ)
    If find(this.ATZ(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
      If this.ATZ(I).CHPLEG = [V]CST_AYES
        FOUND=[V]CST_ATRUE
        Break
      Endif
    Endif
  Next
  If FOUND=[V]CST_AFALSE
    # The table does  not contain any field by legislation
    [L]ASTATUS = fmet this.ASETERROR("ATABLE",mess(210,123,1),[V]CST_AERROR)
  Endif
Endif

FOUND=[V]CST_AFALSE
If dim(this.FLGLEG)>0 & this.FLGLEG<>[V]CST_AYES
  Local Instance MY_LEG Using C_ATABLE
  For [ATB2] Where FLGLEG=[V]CST_AYES
    MY_LEG = NewInstance With C_ATABLE
    [L]ASTATUS = fmet MY_LEG.AREAD([F:ATB2]CODFIC)
    If [L]ASTATUS = [V]CST_AOK
      For I = 1 To maxtab(MY_LEG.ATZ)
        If MY_LEG.ATZ(I).CHPLEG=[V]CST_AYES & MY_LEG.ATZ(I).LIEN=this.CODFIC & MY_LEG.ATZ(I).LIEN<>"ATABDIV"
          FOUND = [V]CST_ATRUE
          Break 2
        Endif
      Next
    Endif
  Next
  If FOUND = [V]CST_ATRUE
    # Table utilized as a link for the legislation management table
    [L]ASTATUS = fmet  this.ASETERROR("ATABLE",mess(247,133,1)-":"-MY_LEG.CODFIC-"("-mess(36,124,1)-MY_LEG.ATZ(I).CODZONE-")",[V]CST_AERROR)
  Endif
Endif

FOUND=[V]CST_ANO
For I=1 To maxtab(this.ATI)
 Call VERF_INDEX(this.ATI(I).DESCRIPT,I,MESSA,ERR)
 Case ERR
  When 1 : Call ERREUR(MESSA) From GESECRAN : OK = 0 : Break
  When 2 : Call AVERTIR(MESSA,OK) From GESECRAN : If OK<>2 : OK = 0 : Break : Endif
 Endcase
Next I
If !OK : Return : Endif
For [ATI] Where CODFIC=[M:ATB0]CODFIC
 If !find([F:ATI]CODIND,[M:ATB3]CODIND)
  For [AOB] Where NOMFIC=[M:ATB0]CODFIC
   If [F:AOB]SELCLE=[F:ATI]CODIND
    Call ERREUR([F:AOB]SELCLE-":"-mess(130,126,1)-[F:AOB]ABREV) From GESECRAN
    # Index utilisé par l'objet
    OK = 0 : Break 2
   Endif
   For [AWI]AWI1 Where OBJ=[F:AOB]ABREV
    Read [AWB]AWB0 = [F:AWI]WIN
     For I=0 To [F:AWB]NBLIS-1
      If [F:AWB]CLELIS(I)=[F:ATI]CODIND
       Call ERREUR([F:AWB]CLELIS(I)-":"-mess(105,133,1)-[F:AWI]WIN) From GESECRAN
       # Index utilisé par la fenêtre
       OK = 0 : Break 3
      Endif
     Next I
   Next AWI
  Next AOB
 Endif
Next ATI
If !OK : Return : Endif
Call VERF_DESCRIPT(OK) From SUBATB
If !OK : Return : Endif
If [M:ATB1]GENTRA=2 & !find("AXX",[M:ATB2]CODTYP) & !find("AX1",[M:ATB2]CODTYP)
&                   & !find("AX2",[M:ATB2]CODTYP) & !find("AX3",[M:ATB2]CODTYP)
 Call ERREUR(mess(11,127,1)) From GESECRAN : # Pas de texte traduisible dans cette table
 OK = 0 : zonsui = "[ATB1]GENTRA" : Return
Endif
Return

Subprog VERF_INDEX(INDEX,NOL,MESSA,ERR)
Variable Char    INDEX()
Value    Integer NOL
Variable Char    MESSA
Variable Integer ERR
Local Integer I , J , K , NB
Local Char    DESCRIPTEUR(120), ZINDEX(120), ZCLE(GLONAVA+5)(1..16) , ERRIND(250) , ZONE(GLONAVA)
Local Decimal LNGZON , LNGCLE , DIME , DIMAX
Gosub SET_CDBA From SUBATB
Raz ERR, NB
DESCRIPTEUR = INDEX
LNGCLE = 1
While DESCRIPTEUR<>""
 ERR = 0
 NB += 1
 If NB>dim(ZCLE) : Break : Endif
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  ZINDEX = left$(DESCRIPTEUR,I-1)
# CC    14/02/2013   ----   Pour autoriser des index avec - sur la première colonne
  If J=1 and ZINDEX=""
    I = instr(2,DESCRIPTEUR,"+")
    J = instr(2,DESCRIPTEUR,"-")
    If I<>0 or J<>0
      ZINDEX=mid$(DESCRIPTEUR,2,max(I,J)-1)
    Else
      ZINDEX=right$(DESCRIPTEUR,2)
      DESCRIPTEUR=""
    Endif
    I=J
  Endif
  DESCRIPTEUR = right$(DESCRIPTEUR,I+1)
 Else
  ZINDEX = DESCRIPTEUR
  DESCRIPTEUR = ""
 Endif
 If ZINDEX<>""
  I = instr(1,ZINDEX,"(")
  If I
   ZONE = left$(ZINDEX,I-1)
   DIME = val(right$(ZINDEX,I+1))+1
  Else
   ZONE = ZINDEX
   DIME = 1
  Endif
 Endif
 For I=1 To maxtab(this.ATZ)
  If this.ATZ(I)<>null & find(this.ATZ(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]ACST_AFALSE
    If ZONE=this.ATZ(I).CODZONE
      K=[V]ACST_ATRUE
      Break
    Endif
  Endif
 Next

 If K=0
  # Index on non-existant field
  MESSA = mess(10,176,1)-INDEX+"\"+ZONE-mess(11,176,1)
  ERR = 1 : Break
 Elsif find([M:ATB2]CODTYP(K-1),"AXX","AX1","AX2","AX3","AUUID")
  # This type of field is prohibited on indices
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)

  ERR = 1 : Break
 Elsif find(ZINDEX,ZCLE(1..NB-1))
  # Index already exists
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(278,123,1)
  ERR = 1 : Break
 Else
  DIMAX = [M:ATB2]DIME(K-1)
  If [M:ATB2]CODACT(K-1)<>""
   Read [ACV]CODACT = [M:ATB2]CODACT(K-1)
   If fstat or [F:ACV]FLACT<>2
    ERRIND -= ZINDEX
    ERR = 2
   Else
    If [F:ACV]DIME<>0
     #DIMAX = [F:ACV]DIME
    Endif
   Endif
  Endif
  If DIMAX>1 or DIME>1
   # Index/Zone dimensionnée
   MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-":"-mess(105,123,1)
   ERR = 1 : Break
  Endif
  If !ERR
   LNGCLE += 2
   Read [ATY]CODTYP=[M:ATB2]CODTYP(K-1)     # todo: switch to class
   Case [F:ATY]TYPTYP
    When 1,2,3,5
     LNGZON = 4
    When 4,6
     LNGZON = 8
    When 7
     If [F:ATY]LNGTYP<>0
      LNGZON = ([F:ATY]LNGTYP+1)*2
     Else
      LNGZON = ([M:ATB2]LONG(K-1)+1)*2
     Endif
    When 8
     LNGZON = 3
    When 9,10
     # This type of field not permitted  in index
     MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
     ERR = 1 : Break
   Endcase
   LNGCLE += LNGZON
  Endif
 Endif
 ZCLE(NB) = ZINDEX
Wend

#---------------------------------------------------------------------------------------#
# The key length is limited to 500 bytes (adonix limit)
# The maximum number of indices is 19. (One index  is reserved in the event of a link)
# An index can be composed of up to 15 fields
#---------------------------------------------------------------------------------------#

If LNGCLE>500
 # Key to long
 MESSA = INDEX-":"-mess(33,126,1)-num$(LNGCLE)+"(500)" : # Clé trop longue
 ERR = 1
Elsif NB>dim(ZCLE)
 #Too many components in the key (maximum #)
 MESSA = INDEX-":"-mess(29,176,1) : # Trop de composantes de clé (maximum #)
 K = instr(1,MESSA,"#")
 If K : MESSA = left$(MESSA,K-1)+num$(dim(ZCLE))+right$(MESSA,K+1) : Endif
 ERR = 1
Elsif NB=0
 # There are no active fields in the index
 MESSA = INDEX-":"-mess(158,133,1) : # Aucune zones actives sur cet index
 ERR = 2
Elsif ERRIND<>""
 # Field with an Inactive Activity Code
 MESSA = mess(10,176,1)-INDEX+"\"+ERRIND-mess(22,176,1)
 ERR = 2
Endif
End

$RIEN
Resume

