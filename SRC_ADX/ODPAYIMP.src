#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 04/06/13 - FQ89155 US1609 -
#       Rajout infos analytiques sur BULODPAY et CPTODPAY
#       nouvelle table temporaire TMPODPREP pour mettre les 9 sections analytiques
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Integer NUMREQ, WNUMLIG,J
Local Decimal TOTCOE
Local Char    CRITERE(255),CRITERE2(255),PARAM(30)
Local Date    DATEDEB, DATEFIN
Local Char    MATDEB(GLONMAT), MATFIN(GLONMAT), SITEDEB(GLONFCY), SITEFIN(GLONFCY)
Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), PROFIL(GLONPRF), SERVICE(GLONSRV), POPULATION(GLONPOP)
Local Char    ODPDEB(GLONVCR), ODPFIN(GLONVCR), ETAT(GLONARP)
Local Char    CRITERE1(255),CRITERE3(255),CRITERE4(255),CRITERE5(255)
Local Char    SEC1DEB(GLONCCE), SEC1FIN(GLONCCE)
Local Char    SEC2DEB(GLONCCE), SEC2FIN(GLONCCE)
Local Char    SEC3DEB(GLONCCE), SEC3FIN(GLONCCE)
Local Char    SEC4DEB(GLONCCE), SEC4FIN(GLONCCE)
Local Char    SEC5DEB(GLONCCE), SEC5FIN(GLONCCE)
Local Char    SEC6DEB(GLONCCE), SEC6FIN(GLONCCE)
Local Char    SEC7DEB(GLONCCE), SEC7FIN(GLONCCE)
Local Char    SEC8DEB(GLONCCE), SEC8FIN(GLONCCE)
Local Char    SEC9DEB(GLONCCE), SEC9FIN(GLONCCE)

If clalev([F:DSP])=0  : Local File =GTABCPT+"CADSP"      [DSP] : Endif
If clalev([F:ODP])=0  : Local File ODPAY                 [ODP] : Endif
#If clalev([F:ARM])=0  : Local File AREPORTM              [ARM] : Endif
If clalev([F:TOR])=0  : Local File TMPODPREP              [TOR] : Endif : # FQ89155
If clalev([F:ID])=0   : Local File EMPLOID               [ID]  : Endif
If clalev([F:POA])=0  : Local File POPULA                [POA] : Endif


CRITERE  = "1=1" : CRITERE2 = "1=1"
CRITERE1 = "1=1" : CRITERE3 = "1=1" : CRITERE4 = "1=1" : CRITERE5 = "1=1"
Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB) From ETAT
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN) From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN) From ETAT
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) From ETAT : DATEFIN = PARAM
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB) From ETAT
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN) From ETAT
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION) From ETAT
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE) From ETAT
Call GETPARAM("odpaynumdeb",NBPAR,PARAMETRE,ODPDEB) From ETAT
Call GETPARAM("odpaynumfin",NBPAR,PARAMETRE,ODPFIN) From ETAT
Call GETPARAM("sec1deb",NBPAR,PARAMETRE,SEC1DEB) From ODPAYIMP
Call GETPARAM("sec1fin",NBPAR,PARAMETRE,SEC1FIN) From ODPAYIMP
Call GETPARAM("sec2deb",NBPAR,PARAMETRE,SEC2DEB) From ODPAYIMP
Call GETPARAM("sec2fin",NBPAR,PARAMETRE,SEC2FIN) From ODPAYIMP
Call GETPARAM("sec3deb",NBPAR,PARAMETRE,SEC3DEB) From ODPAYIMP
Call GETPARAM("sec3fin",NBPAR,PARAMETRE,SEC3FIN) From ODPAYIMP
Call GETPARAM("sec4deb",NBPAR,PARAMETRE,SEC4DEB) From ODPAYIMP
Call GETPARAM("sec4fin",NBPAR,PARAMETRE,SEC4FIN) From ODPAYIMP
Call GETPARAM("sec5deb",NBPAR,PARAMETRE,SEC5DEB) From ODPAYIMP
Call GETPARAM("sec5fin",NBPAR,PARAMETRE,SEC5FIN) From ODPAYIMP
Call GETPARAM("sec6deb",NBPAR,PARAMETRE,SEC6DEB) From ODPAYIMP
Call GETPARAM("sec6fin",NBPAR,PARAMETRE,SEC6FIN) From ODPAYIMP
Call GETPARAM("sec7deb",NBPAR,PARAMETRE,SEC7DEB) From ODPAYIMP
Call GETPARAM("sec7fin",NBPAR,PARAMETRE,SEC7FIN) From ODPAYIMP
Call GETPARAM("sec8deb",NBPAR,PARAMETRE,SEC8DEB) From ODPAYIMP
Call GETPARAM("sec8fin",NBPAR,PARAMETRE,SEC8FIN) From ODPAYIMP
Call GETPARAM("sec9deb",NBPAR,PARAMETRE,SEC9DEB) From ODPAYIMP
Call GETPARAM("sec9fin",NBPAR,PARAMETRE,SEC9FIN) From ODPAYIMP

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]ETAT) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

If MATDEB<>""       : CRITERE -= '& [F:ODP]EMP>="'+MATDEB+'"'                   : Endif
If MATFIN<>""       : CRITERE -= '& [F:ODP]EMP<="'+MATFIN+'"'                   : Endif
If CPYDEB<>""       : CRITERE -= '& [F:ODP]CPY>="'+CPYDEB+'"'                   : Endif
If CPYFIN<>""       : CRITERE -= '& [F:ODP]CPY<="'+CPYFIN+'"'                   : Endif
If SITEDEB<>""      : CRITERE -= '& [F:ODP]FCY>="'+SITEDEB+'"'                  : Endif
If SITEFIN<>""      : CRITERE -= '& [F:ODP]FCY<="'+SITEFIN+'"'                  : Endif
If DATEDEB<>[0/0/0] : CRITERE1 -= '& [F:ODP]PYRDAT>=['+format$(GFMD,DATEDEB)+']' : Endif
If DATEFIN<>[0/0/0] : CRITERE1 -= '& [F:ODP]PYRDAT<=['+format$(GFMD,DATEFIN)+']' : Endif
If ODPDEB<>""       : CRITERE1 -= '& [F:ODP]ODPNUM>="'+ODPDEB+'"'                : Endif
If ODPFIN<>""       : CRITERE1 -= '& [F:ODP]ODPNUM<="'+ODPFIN+'"'                : Endif
If SERVICE<>""      : CRITERE2 -= '& [F:ODP]SRV="'+SERVICE+'"'                   : Endif
If PROFIL<>""       : CRITERE2 -= '& [F:ODP]PRF="'+PROFIL+'"'                    : Endif
If SEC1DEB<>""      : CRITERE3 -= '& [F:DSP]CCE1>="'+SEC1DEB+'"'                 : Endif
If SEC1FIN<>""      : CRITERE3 -= '& [F:DSP]CCE1<="'+SEC1FIN+'"'                 : Endif
If SEC2DEB<>""      : CRITERE3 -= '& [F:DSP]CCE2>="'+SEC2DEB+'"'                 : Endif
If SEC2FIN<>""      : CRITERE3 -= '& [F:DSP]CCE2<="'+SEC2FIN+'"'                 : Endif
If SEC3DEB<>""      : CRITERE3 -= '& [F:DSP]CCE3>="'+SEC3DEB+'"'                 : Endif
If SEC3FIN<>""      : CRITERE3 -= '& [F:DSP]CCE3<="'+SEC3FIN+'"'                 : Endif
If SEC4DEB<>""      : CRITERE3 -= '& [F:DSP]CCE4>="'+SEC4DEB+'"'                 : Endif
If SEC4FIN<>""      : CRITERE3 -= '& [F:DSP]CCE4<="'+SEC4FIN+'"'                 : Endif
If SEC5DEB<>""      : CRITERE4 -= '& [F:DSP]CCE5>="'+SEC5DEB+'"'                 : Endif
If SEC5FIN<>""      : CRITERE4 -= '& [F:DSP]CCE5<="'+SEC5FIN+'"'                 : Endif
If SEC6DEB<>""      : CRITERE4 -= '& [F:DSP]CCE6>="'+SEC6DEB+'"'                 : Endif
If SEC6FIN<>""      : CRITERE4 -= '& [F:DSP]CCE6<="'+SEC6FIN+'"'                 : Endif
If SEC7DEB<>""      : CRITERE4 -= '& [F:DSP]CCE7>="'+SEC7DEB+'"'                 : Endif
If SEC7FIN<>""      : CRITERE4 -= '& [F:DSP]CCE7<="'+SEC7FIN+'"'                 : Endif
If SEC8DEB<>""      : CRITERE5 -= '& [F:DSP]CCE8>="'+SEC8DEB+'"'                 : Endif
If SEC8FIN<>""      : CRITERE5 -= '& [F:DSP]CCE8<="'+SEC8FIN+'"'                 : Endif
If SEC9DEB<>""      : CRITERE5 -= '& [F:DSP]CCE9>="'+SEC9DEB+'"'                 : Endif
If SEC9FIN<>""      : CRITERE5 -= '& [F:DSP]CCE9<="'+SEC9FIN+'"'                 : Endif

Call DEBTRANS From GLOCK
Gosub TR1
If [L]POPULATION<>""
 Link [ID] With [POA]POA0=[L]POPULATION;[F:ID]REFNUM
&             , [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID]
& Where evalue(CRITERE2) & [F:POA]REFNUM<>"" & evalue(CRITERE) & evalue(CRITERE1) & [F:ODP]DSP<>""
& Order By Key CLE1=[ODP]DSP
Else
 Link [ID] With [ODP]ODP1(1)=[F:ID]REFNUM
& As [LID]
& Where evalue(CRITERE2) & evalue(CRITERE) & evalue(CRITERE1) & [F:ODP]DSP<>""
& Order By Key CLE1=[ODP]DSP
Endif

Raz WNUMLIG

For [LID]CLE1(1)
 Gosub TR2
Next

End

$TR1
GOK = 1
Trbegin [TOR]
 Delete [TOR] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
Commit
Return


$TR2
GOK=1
Trbegin [TOR]
 Raz [L]TOTCOE, J
 For [DSP] Where DSP=[F:ODP]DSP
  [L]TOTCOE     += [F:DSP]COE
  If evalue(CRITERE3) & evalue(CRITERE4)  & evalue(CRITERE5)

  J -=1
  [F:TOR]CREDAT  = date$
  [F:TOR]USR     = GUSER
  [F:TOR]RPTCOD  = [L]ETAT
  [F:TOR]NUMREQ  = [L]NUMREQ
  [F:TOR]NUMLIG  = J
  [F:TOR]CLEA1   = "DSP"
  [F:TOR]CLEA2   = [F:DSP]DSP
  [F:TOR]CLEA3   = [F:DSP]CCE1
  [F:TOR]CLEA4   = [F:DSP]CCE2
  [F:TOR]CLEA5   = [F:DSP]CCE3
  [F:TOR]CLEA6   = [F:DSP]CCE4
  [F:TOR]CLEA7   = [F:DSP]CCE5
  [F:TOR]CLEA8   = [F:DSP]CCE6
  [F:TOR]CLEA9   = [F:DSP]CCE7
  [F:TOR]CLEA10   = [F:DSP]CCE8
  [F:TOR]CLEA11   = [F:DSP]CCE9
  #[F:TOR]CLEN1   = [F:DSP]COE :#81282
  [F:TOR]CLEMD1  = [F:DSP]COE
#  [L]TOTCOE     += [F:DSP]COE
  Write [F:TOR]
  If fstat : GOK = 0 : Call FSTA("TOR") From GLOCK : Goto AB_TR : Endif
  Endif
 Next
 For [TOR] Where NUMLIG<0 & USR=GUSER & RPTCOD=[L]ETAT & NUMREQ=[L]NUMREQ
  [L]WNUMLIG +=1
  [F:TOR]NUMLIG = [L]WNUMLIG
  #[F:TOR]CLEN2  = [L]TOTCOE :#81282
  [F:TOR]CLEMD2  = [L]TOTCOE
  Rewrite [F:TOR]
  If fstat
   GOK = 0 : Call FSTA("TOR") From GLOCK : Goto AB_TR
  Endif
 Next
Commit
Return

$AB_TR
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End






