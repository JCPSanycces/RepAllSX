#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MWA
# LE          : 30 Juin 2011 
# Moulinette pour alimenter HRZEXE HRZPER de la table CONTEXTE selon NBEXESTO
# FQ74517
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM033: Initialisation horizon de calcul selon NBEXESTO") From LECFIC
  Call EXE_UTIIMM033(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM033(APPLI)
 Value Char APPLI
 
  If clalev([F:CNX]) : Close Local File [CNX]  : Endif        : # Contextes
  Local File =APPLI+".CONTEXT" [CNX]
     
  Call ECR_TRACE("UTIIMM033: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM033
  Call ECR_TRACE("UTIIMM033: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM033
  Trbegin [CNX]

  Local Integer L_HRZEXE
  Local Char    L_PARAM
      
  # Nombre d'exercices à calculer
  Call PARAM("","NBEXESTO",L_PARAM) From ADOVAL
  If (L_PARAM = "" ) Then 
    L_HRZEXE = 2
    L_HRZPER = 2
  Else
    L_HRZEXE = val(L_PARAM)
    If ( L_HRZEXE > 3 ) Then : L_HRZPER = 3 : Else : L_HRZPER = L_HRZEXE : Endif     
  Endif
  
  # Contextes
  For [CNX]CNX0
    If ([F:CNX]HRZEXE = 0 and [F:CNX]HRZPER = 0) Then
    [F:CNX]HRZEXE = L_HRZEXE
    [F:CNX]HRZPER = L_HRZPER    
    Rewrite [CNX]
    If (fstat) Then
      GOK=0
      Call ECR_TRACE("UTIIMM033 - "-" CONTEXT  => Rewrite Error - FSTAT="-num$(fstat), 1) From GESECRAN
      Break
    Endif      
    Endif  
  Next CNX0

  If !GOK Then
    Goto AB_UTIIMM033
  Else
    Commit
  Endif
Return

$AB_UTIIMM033
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","CONTEXT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM033(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","CONTEXT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM033(APPLI)
End


