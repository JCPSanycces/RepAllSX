######################################################################################

$ACTION
 Case ACTION
  When "OUVRE"   : Gosub OUVRE
  When "DEBUT"   : Gosub DEBUT
  When "BOUTON"  : Gosub BOUTON
  When "FERME"   : Gosub FERME
  When Default
 Endcase
Return

#================================================
$OUVRE
  Global Char GVATCUR
  If clalev([F:HIS]) =0  : Local File VATHIS [HIS] : Endif  : # historique Régul. TVA
Return

#================================================
$DEBUT
 Raz [M:VAT9]
 Transmask [M:FAS0] To [M:VAT9]
Return

#================================================
$BOUTON
 If BOUT="R"
  Call TEMPON("R") From GESECRAN
  Raz [M:VAT9]NBHIS
  Gosub ALIM_VATLIST
  Call TEMPOFF() From GESECRAN
 Endif
Return

#================================================
$FERME
  If dim(GVATCUR)>0  : Kill GVATCUR : Endif
Return


#================================================
$ALIM_VATLIST
 Local Char LCRIT(255)

Local Integer I_LIGN

 # Sélection
 LCRIT="AASREF=PARAM(1)"
 LCRIT += " and DPRPLN=[M:VAT9]DPRPLN"

 If ( [M:VAT9]DPRPLN = G301CPT ) Then
   GVATCUR = [M:FAS1]ACGCUR
 Else
   GVATCUR = [M:FAS1]IASCUR
 Endif
 Filter [F:HIS] Where evalue(LCRIT) Order By TIMSTP
 I_LIGN = 0
 For [F:HIS]
  I_LIGN+=1 : nolign = I_LIGN
  [M:VAT9] = [F:HIS]
  [M:VAT9]VATREG(I_LIGN-1) =  [F:HIS]VATREGDED - [F:HIS]VATREGAMT
 Next
 [M:VAT9]NBHIS = nolign
 Filter [F:HIS]

 Affzo [M:VAT9]

Return




#-------------------------------------------------------------------------------------
# Gestion du masque VATHIS


#-------------------------------------------------------------------------------------
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

  GMENLOC(G301FIS)=1
  GMENLOC(G301MIN)=1
  GMENLOC(G301ORI)=1
  GMENLOC(G301R76)=1
  GMENLOC(G301TEC)=1
  GMENLOC(G301RET)=1
  GMENLOC(G301SUB)=1
  GMENLOC(G301LI1)=1
  GMENLOC(G301LI2)=1
  GMENLOC(G301LI3)=1
  GMENLOC(G301LI4)=1
  GMENLOC(G301LI5)=1
  GMENLOC(G301LI6)=1
  GMENLOC(G301AUC)=1
  If ( GCNXPROIAS <> G_OUI ) Then
    GMENLOC(G301IAS)=1
  Endif

End


#-------------------------------------------------------------------------------------
Subprog AM_DPRPLN(VALEUR)
Variable Integer VALEUR

  [M:VAT9]DPRPLN = VALEUR
  Raz [M:VAT9]NBHIS
  Affzo [M:VAT9]

End

#-------------------------------------------------------------------------------------
Subprog AV_DATVATREG(VALEUR)
Variable Date    VALEUR

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 If ( [M:VAT9]VATREGTYP(nolign-1) = GVML_TRCREAT or
&     [M:VAT9]VATREGTYP(nolign-1) = GVML_TRPRDEF ) Then
  Chgstl NBHIS(nolign-1)  With "AWARNLOW"
  pcolor = GCOUL(3) : # Bleu
 Else
  Chgstl NBHIS(nolign-1)  With ""
  pcolor = GCOUL(0) : # Normal
 Endif
End
