## Etiquette ajoutée par le superviseur (écran SRL1) 24/02/2006 14:48:16 (LD)
######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer IRETOUR  # FGR 11/08/2014 : X3SUIVI102048

#Gbn-100166
# Chargement des globales référenciels, comptes et sections de la société
GFCY=VALEUR : Gosub CHARG_PARAM From SUBSRL : If GERR=1 mkstat=2 : End Endif

# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SRL0]PLISTC=[F:CPY]PLISTC

# Chargement des globales référenciels, comptes et sections de la société
#GFCY=VALEUR : Gosub CHARG_PARAM From SUBSRL : If GERR=1 mkstat=2 : End Endif #Gbn-100166-Deplacement en début de sous-pro

#--CPO 75115 Init et recherche du compteur en fonction du SRHTYP
# ------------------------------------
# FGR 11/08/2014 : X3SUIVI102048 (début) : Si SRHTYP n'existe pas dans la nouvelle législation on l'efface pour en chercher un qui ira.
If [M:SRL0]SRHTYP<>""
  Call LEC_TRE_LEG(GCURLEG, [M:SRL0]SRHTYP, IRETOUR) From TRTLECLEG
  If IRETOUR <> 0 Then
    Raz [M:SRL0]SRHTYP
  Endif
Endif
# FGR 11/08/2014 : X3SUIVI102048 (fin)
# ------------------------------------
If [M:SRL0]SRHTYP=""
  Local Char WSRHTYP(GLONTRE) : Local Integer  WSRHCAT
  Gosub SRHTYP From SUBSRH
  [M:SRL0]SRHTYP=WSRHTYP : [M:SRL0]SRHCAT=WSRHCAT
  Affzo [M:SRL0]SRHTYP,SRHCAT
Endif
Gosub REC_CPT_RET From SUBSRL :     # Recherche du compteur retour
#--

# Affichage entêtes colonnes variables (sections analytiques) en cas de changement de société
Gosub AFF_TITCOL From SUBSRL
# Effacement tableau des sections entête si changement société
If dim([M:SRL2]NBAXE)>0 & [M:SRL2]NBAXE>0
  [M:SRL0]STOFCY=VALEUR
  Effzo [SRL2]15 : Affzo [SRL2]15
Endif
#--- Bug 65478
If dim([M:SRL1]WRHE)>0
   Call WRHINIT([M:SRL1]WRHE,VALEUR,4) From STKWRH
Endif
#---
# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT

#RMA * 85785
If func PORLEGLIB.DIGSIGN(VALEUR,"") = 1
  Chgfmt [M:SRL0]SRHCFMFLG   With "LA1:15X"
Else
  If dim([M:SRL0]SRHCFMFLG) > 0
    Chgfmt [M:SRL0]SRHCFMFLG   With "-LA1:15X"
  Endif
Endif

End
######################################################################################
Subprog C_SRHTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : mkstat=2 : End : Endif
#--Contrôle que le type de retour pointe sur une catégorie acceptée par la transaction
# X3-1152 : Non invoiceable deliveries
#If GDLVTYP<4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
If GDLVTYP<>4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
# X3-1152 : Non invoiceable deliveries

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRL0]WSRHCAT = mess(8,105,1) - ':' - mess([F:TRE]SRHCAT,493,1)
Affzo [M:SRL0]WSRHCAT

# BRBAN 23-07-2014 SAM 93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([M:SRL0]STOFCY,'')=1
    Actzo  [M:SRL2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRL2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
Endif
#-

End

Subprog AM_SRHTYP(VALEUR)
Variable Char    VALEUR()

#--Init de la catégorie de retour
[M:SRL0]SRHCAT = [F:TRE]SRHCAT
Affzo [M:SRL0]SRHCAT

#--Init du compteur en fonction du type de retour
#--Afin d'avoir la bonne valeur dans le sous-pro REC_CPT_RET
[M:SRL0]SRHTYP=VALEUR
Gosub REC_CPT_RET From SUBSRL : If GERR=1 : mkstat=2 : Endif

If GMANCOU=1 & [M:SRL0]SRHNUM <> ""
   Effzo [M:SRL0]SRHNUM
Endif

If GREP="C" & GMANCOU<>2
   Diszo [M:SRL0]SRHNUM
Else
   Actzo [M:SRL0]SRHNUM
Endif

End
########################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

GBPCNUM = VALEUR
#Raz [M]BPAADD, BPDNAM
# Recherche du client livré par défaut
Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
If fstat=0 & [F:BPD]ENAFLG=2 & ([F:BPD]BPCLOC<>"" or [F:BPC]BPCTYP=2) [M:SRL0]BPAADD = [F:BPD]BPAADD : Endif
If [M:SRL0]BPAADD = ""
   Filter [BPD] Where [BPD]BPCNUM=VALEUR & BPCLOC<>"" & ENAFLG=2
   Read [BPD]BPD0 First
   If fstat = 0 [M:SRL0]BPAADD = [F:BPD]BPAADD Endif
   Filter [BPD]
Endif
If [M:SRL0]BPAADD<>""
    Local Char WBPCORD(GLONBPC), WBPAADD(GLONBPD)  : WBPCORD=VALEUR : WBPAADD=[M:SRL0]BPAADD
    Gosub CLILIV
Endif
Affzo [M]BPAADD, BPDNAM
End
