$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SRLD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SRL0]RTNDAT) From TRTX3CPT
Return

######################################################################################
########################################
#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
$TEST_MOD_ANU

# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
If [M:SRL1]DETSDHNUM(NOL)<>"" & [M:SRL1]CREFLG(NOL)=0
   GMESSAGE=mess(223,192,1) : mkstat=2 : Return
Endif

Return

#######################################################################

#########################################################################
# TRAITEMENTS LIES AU PICKING                                           #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$HINT_KEY
Case currbox
 When GBOXSD2  : HINTLIS(val(right$(GBOXSD2,8)))="SDD3"
 When Default  : Return
Endcase
Return

#########################################################################
$TIROIR

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$FILGAUCHE

If !find(currbox,GBOXSD2) Return Endif

If (GREP="" & !CLECUR)
   FILGAUSUP(0)='[F:SDD]BPCORD=""&[F:SDD]BPAADD=""&[F:SDD]ITMREF=""'
   Return
Endif

# Pour optimiser, on filtre sur le client même si celui-ci n'est pas renseigné
# --> on ne pourra picker un retour que lorsque le client aura été saisi
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON = "BPCORD"
##   FILGAUSUP(0) ='[F:SDD]BPCORD=CZ'
##Else
##   FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRL0]BPCORD'
##Endif
FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRL0]BPCORD'

# Pb : Bien que COUZON="BPAADD" CZ contient toujours la valeur du dernier champs saisi
#      BPAADD est chargé directement à partir du client, s'il n'est pas modifié CZ=[M:SRL0]BPCORD
#      CZ n'est bon que si on saisit BPAADD
#If COUZON = "BPAADD"
#   If CZ <> ""              FILGAUSUP(0)+='&[F:SDD]BPAADD=CZ'                Endif
#Else
#   If [M:SRL0]BPAADD <> ""  FILGAUSUP(0)+='&[F:SDD]BPAADD=[M:SRL0]BPAADD'    Endif
#Endif
# Particularité pour [M]BPAADD : On le charge dans l'action APRES_MODIF
If [M:SRL0]BPAADD <> ""  FILGAUSUP(0)+='&[F:SDD]BPAADD=[M:SRL0]BPAADD'    Endif

#If COUZON = "ITMREFSEL"
#   If CZ <> ""              FILGAUSUP(0)+='&[F:SDD]ITMREF=CZ'                Endif
#Else
#   If [M:SRL1]ITMREFSEL<>"" FILGAUSUP(0)+='&[F:SDD]ITMREF=[M:SRL1]ITMREFSEL' Endif
#Endif

# Les livraisons doivent être validées et de prêts
FILGAUSUP(1) ='&[F:SDH]CFMFLG=2&[F:SDH]LND=2&[F:SDH]INVFLG<>2'
FILGAUSUP(1)+='&[F:SDD]QTY>[F:SDD]RTNQTY'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SRL0]CRIITMREF<>""      FILGAUSUP(1)+=' & [F:SDD]ITMREF =[M:SRL0]CRIITMREF' Endif
If [M:SRL0]CRISDHNUM<>""      FILGAUSUP(1)+=' & [F:SDH]SDHNUM =[M:SRL0]CRISDHNUM' Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON = "STOFCY"
##   If CZ <> ""             FILGAUSUP(1)+='&[F:SDH]STOFCY=CZ'              Endif
##Else
##   If [M:SRL0]STOFCY <> "" FILGAUSUP(1)+='&[F:SDH]STOFCY=[M:SRL0]STOFCY'  Endif
##Endif
If [M:SRL0]STOFCY <> "" FILGAUSUP(1)+='&[F:SDH]STOFCY=[M:SRL0]STOFCY'  Endif

If [M:SRL0]BPCINV <> ""    FILGAUSUP(1)+='&[F:SDH]BPCINV=[M:SRL0]BPCINV'  Endif
If [M:SRL0]SALFCY <> ""    FILGAUSUP(1)+='&[F:SDH]SALFCY=[M:SRL0]SALFCY'  Endif


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SDH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SDH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
  If GPJTSNGDOC = G_OUI Then
    FILGAUSUP(2)+='&[F:SDH]PJT=[M]PJT'
  Endif
Endif
#--/CPO
#--CPO 75115 Nouveaux champs SRHTYP et SRHCAT
If  [M]SRHCAT>0 & [M]SRHCAT<4
    FILGAUSUP(2)+='& [F:SDH]SDHCAT=[M]SRHCAT'
Endif
#--/CPO

Return

#########################################################################
$AP_FILGAUCHE
If currbox = GBOXSD2
   WPICK=2 : Gosub RAFFRAICHI
Endif
Return

#########################################################################
$DEB_PICK
Local Integer I, J, NOL
Local Char    SYMBOLE2(50)
Return

#########################################################################
$PICKE
If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
      Return
   Endif
Endif

If currbox = GBOXSD2
   Gosub SEL1
#   Gosub ATT_ECRAN
Endif
Return

#########################################################################
$DEPICK
If currbox = GBOXSD2
   Gosub DESEL1
#   Gosub ATT_ECRAN
Endif
Return

#########################################################################
$FIN_PICK

#--CPO 71065 Code affaire
Call PJT_INFO_MSG From TRTPJT

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

#If dim(I)<0 Local Shortint I : Endif
#Local Integer WRET
#For I=0 To [M:SRL1]NBLIG-1
#    If [M:SRL1]STOMGTCOD(I)>1 & [M:SRL1]WSTOFLG(I)=0
#        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=7;GFLAG
#                                If fstat Raz [F:SLT] Endif
#                                Endif
#        # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
#        Call STJSTOENTW("SRL1",18,13,[M:SRL0]RTNDAT,I,[M:SRL1]NBLIG,"SLT",3,WRET) From STKENT
#        If WRET=1 GERR=1 : OK=0 : Return : Endif
#        If GMESSAGE <> "" Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : Endif
#    Endif
#Next I

If currbox = GBOXSD2
   Affzo [M:SRL0]1-99 : Affzo [M:SRL1]1-99 : Affzo [M:SRL2]1-99
   Gosub ATT_ECRAN
   zonsui = "[M:SRL1]NBLIG("+num$(NOL)+")"
Endif
Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$ATT_ECRAN
If [M:SRL1]NBLIG = 0
   Actzo [M:SRL0]STOFCY, BPCORD, BPAADD
   Actzo [M:SRL0]SRHTYP                   :#--CPO 75115
Else
   Diszo [M:SRL0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRL0]SRHTYP                   :#--CPO 75115
Endif
Return

#########################################################################
$REMPBOX

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB

Return

#########################################################################
#$REMPLIT
#Case IBOX
# When 1  : Gosub REMPLIT_1 From GESSRL
# When 2  : Gosub REMPLIT_2 From GESSRL
# When 3  : Gosub REMPLIT_3 From GESSRL
# When 4  : Gosub REMPLIT_4 From GESSRL
# When 5  : Gosub REMPLIT_5 From GESSRL
# When 6  : Gosub REMPLIT_6 From GESSRL
# When 7  : Gosub REMPLIT_7 From GESSRL
# When 8  : Gosub REMPLIT_8 From GESSRL
# When Default
#Endcase
#Return

#########################################################################
$SEL1
Local Decimal WQTYSAU, LQTYSTU
Local Char SECTION (GLONCDE)
#--- Bug 78668
Local Char WWRH(GLONWRH)
Local Char SWPJTMSG(250)    : # 71065 : PJT

Read [SDD]SDD0=[F:SDD]SDHNUM;[F:SDD]SDDLIN
If fstat
   Call RSTA("RSTA",[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été retournée depuis le dernier raffraichissement de la liste de picking
If [F:SDD]QTY <= [F:SDD]RTNQTY
    GMESSAGE = [F:SDD]SDHNUM-":"-mess(27,159,1)-[F:SDD]ITMREF-":"-mess(251,192,1) : OK=0 : Return
Endif
Read [SDH]SDH0=[F:SDD]SDHNUM
If fstat
   Call RSTA("RSTA",[F:SDD]SDHNUM) From GLOCK : OK=0 : Return
Endif

# Date de livraison > date de retour
If [F:SDH]SHIDAT > [M]RTNDAT  : # ACA - 48197 - date liv->date expé
   GMESSAGE = mess(328,192,1) : OK=0 : Return
Endif

# Si 1ère ligne, alimentation des zones d'entête
If [M]NBLIG = 0
#--- Alimentation des paramètres
   If [M:SRL0]STOFCY = ""
      #Call GETDEV([F:SDH]STOFCY) From DEVSUB
      # Chargement globales référenciels, comptes et sections de la société
      GFCY=[F:SDH]STOFCY : Gosub CHARG_PARAM From SUBSRL : If GERR=1 OK=0 : Return Endif
      Call GLOBSTOFCY([F:SDH]STOFCY) From TRTVENGLOB
      [M]STOFCY     = [F:SDH]STOFCY
   Endif
   Read [FCY]FCY0=[F:SDH]SALFCY
   If [F:FCY]LEGCPY <> GSOCIETE
      GERR=1 : GMESSAGE=[F:SDH]SDHNUM+"\"+mess(2,194,1)
      OK=0   : Return
   Endif
#    alim. GSOCIETE,GFINRSP,GLOCALDEV
#   If [M:SRL0]SALFCY = ""
      #Call GETDEV([F:SDH]SALFCY) From DEVSUB
      # Chargement globales référenciels, comptes et sections de la société
      GFCY=[F:SDH]SALFCY : Gosub CHARG_PARAM From SUBSRL : If GERR=1 OK=0 : Return Endif
      Call GLOBVAR([F:SDH]SALFCY,"VEN") From TRTX3
#      [M]SALFCY     = [F:SDH]SALFCY
#   Endif

   WSLTTRSCOD=[M:SRL0]TRSCOD  : # Bug 80677
   [M:SRL0]=[F:SDH]
   [M:SRL0]TRSCOD=WSLTTRSCOD  : # Bug 80677
   [M:SRL1]BETFCY =[F:SDH]BETFCY
   [M:SRL1]BETCPY =[F:SDH]BETCPY

   #--CPO 71065 Code affaire sur les retours
   #--Pour ce qui est du PJT de l'en-tête
   [M:SRL2]PJT=[F:SDH]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:SDH]PJT, "[M:SRL2]PJT",SWPJTMSG) = G_NON Then
     Raz  [M:SRL2]PJT
     Call PJT_ADD_MSG([F:SDH]PJT,SWPJTMSG) From TRTPJT
   Endif
   #--Contôle du PJT de la première ligne pickée
   #--Selon mail CH : ne pas contrôler
   #--/CPO

#   [M]BPCORD     = [F:SDH]BPCORD
#   [M]BPAADD     = [F:SDH]BPAADD
#   [M]BPDNAM     = [F:SDH]BPDNAM
#   [M]EECICT     = [F:SDH]EECICT
#   [M]ICTCTY     = [F:SDH]ICTCTY
#   [M]FFWNUM     = [F:SDH]FFWNUM
#   [M]FFWADD     = [F:SDH]FFWADD
#   If dim([M]EECLOC)>0
#       [M]EECLOC    = [F:SDH]EECLOC
#       [M]EECTRN    = [F:SDH]EECTRN
#       [M]BPIEECNUM = [F:SDH]BPIEECNUM
#   Endif

   [M]STOFCYDLV  = [F:SDH]STOFCY

#   Alimentation du nom client livré
   If [M]BPDNAM(0) = ""
#      -- recherche nom client livré
       If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD
           Read [BPD] BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
       Endif
       [M]BPDNAM = [F:BPD]BPDNAM
   Endif
   # --- adresse livraison
   [M:ADB2]ADBBPR       = [F:SDH]BPCORD
   [M:ADB2]BPRNAM(0)    = [F:SDH]BPDNAM(0)
   [M:ADB2]BPRNAM(1)    = [F:SDH]BPDNAM(1)
   [M:ADB2]BPAADDLIG(0) = [F:SDH]BPDADDLIG(0)
   [M:ADB2]BPAADDLIG(1) = [F:SDH]BPDADDLIG(1)
   [M:ADB2]BPAADDLIG(2) = [F:SDH]BPDADDLIG(2)
   [M:ADB2]POSCOD       = [F:SDH]BPDPOSCOD
   [M:ADB2]CTY          = [F:SDH]BPDCTY
   [M:ADB2]SAT          = [F:SDH]BPDSAT
   [M:ADB2]CRY          = [F:SDH]BPDCRY
   [M:ADB2]CRYNAM       = [F:SDH]BPDCRYNAM
   [M:ADB2]CNTNAM       = [F:SDH]CNDNAM
   If [M:ADB2]BPRNAM <> "" |  [M:ADB2]BPAADDLIG <> "" |
&      [M:ADB2]POSCOD <> "" |  [M:ADB2]CTY <> "" |
&      [M:ADB2]SAT    <> "" |
&      [M:ADB2]CRY    <> "" |  [M:ADB2]CRYNAM <> ""
        [M:ADB2]ADBFLG = 3
   Else
        [M:ADB2]ADBFLG = 0
   Endif
   # Chargement des sections analytiques entête du document
   Call CHARG_CCEH("SRL2","NBAXE","SDH") From TRTX3CPT
   # On complète les sections vides
   If dim([M:SRL2]NBAXE)>0
      [M:SRL2]NBAXE=GNBDIE
      For I=1 To GNBDIE
        If [M:SRL2]CCE(I-1)=""
          [M:SRL2]DIE(I-1)=GDIE(I)
          Call INISEC(SECTION,"SRL",GDIE(I)) From SUBCDE
          [M:SRL2]CCE(I-1)=SECTION
        Endif
      Next I
   Endif
Else
   # Contrôle des conditions des regroupement
   Gosub CTL_LIV
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M]NBLIG+1 >= dim([M]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
   OK=1   : Return
Endif

#--- Sélection correcte

# Ouverture de la ligne
nolign = [M]NBLIG
Insa nolign,1,[M]NBLIG [M]NBLIG
[M]NBLIG += 1
nolign = [M]NBLIG
NOL = nolign-1
status = 0
Call LINNUM("SRDLIN") From TABLEAUX

#-- Initialisation des zones de stock et ctrl si l'article est ok
Default Mask [SRL1]
Call INIZONENT([F:SDD]ITMREF,"SRL1",[M]STOFCY,[M]BPCORD,2,"U", NOL,18,[M]TRSCOD,[M]SRHNUM,3,0) From STKECR
If mkstat
    Dela NOL,1,[M:SRL1]NBLIG-1 [M:SRL1]NBLIG : [M:SRL1]NBLIG-=1
    If [M]NBLIG=0 Raz [M]SALFCY Endif
    Unlock = SYMBOLE2 :  GERR=1 : OK=0 : Return
Endif

# -- alimentation du masque
[M]DEXTRTNDAT(NOL) = [F:SDH]LNDRTNDAT
[M]DETSDHNUM(NOL)  = [F:SDH]SDHNUM
#--- Bug 78668
If dim([M:SRL1]WRH)>0 WWRH=[M:SRL1]WRH(NOL) Endif
#---
[M:SRL1] = [F:SDD]
#--- Bug 78668
If dim([M:SRL1]WRH)>0 [M:SRL1]WRH(NOL)=WWRH Endif

#--CPO 71065 Code affaire sur les retours
[M:SRL1]DPJT(NOL)=[F:SDD]PJT
#--/CPO

# -- qté restant en prêt
#[M]DLVQTY(NOL)     = [F:SDD]QTY - [F:SDD]RTNQTY
#[M]DLVQTYSTU(NOL)  = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
#[M]QTY(NOL)        = [M]DLVQTY(NOL)
# -- calcul quantité en US
#Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE

# -- Calcul qté restant en prêt en US
LQTYSTU             = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
[M]DLVQTYSTU(NOL)   = LQTYSTU
[M]QTYSTU(NOL)      = LQTYSTU

# Bug 77101
If LQTYSTU=[F:SDD]QTYSTU
  # Qté restant en prêt=Qté livrée
  # -- Qté retour en UV = Qté livrée en UV
  [M]QTY(NOL)=[F:SDD]QTY
Else
  # Qté restant en prêt<Qté livrée
  # -- Recalcul de la qté restant en prêt en UV à partir de l'US
  # Si on tombe sur un chiffre rond ok sinon on met tout en US
  # Calcul de la qté en UV
  WQTYSAU=LQTYSTU / [M:SRL1]SAUSTUCOE(NOL)
  WQTY=WQTYSAU
  Call QTEARR(WQTY,[M:SRL1]SAU(NOL)) From TRTDIV
  If WQTYSAU=WQTY
      # On tombe sur un chiffre rond : ok
      [M:SRL1]QTY(NOL)=WQTYSAU
  Else
      # On ne tombe pas sur un chiffre rond : on met tout en US
      Gosub CONV_LIG_SAUSTU
  Endif
Endif
[M]DLVQTY(NOL)      = [M]QTY(NOL)

# -- Lecture article
If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM]ITM0=[M]ITMREF(NOL)
    If fstat Call RSTA ("ITM",[M]ITMREF(NOL))  From GLOCK : Raz [F:ITM] : Endif
Endif
If [F:ITM]ITMREF<>[F:SRD]ITMREF | [F:ITU]BPCNUM<>[F:SRH]BPCORD
    Read [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
    If fstat Raz [F:ITU] : Endif
Endif
Gosub ALI_DACSAUCOE

# Si l'article est géré en stock : on force la mise à jour des stocks
If [M]STOMGTCOD(NOL) > 1
   [M]RTNSTOUPD(NOL) = 2
Else
   [M]RTNSTOUPD(NOL) = 1
   [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif
# Chargement sections analytiques
#Call CHARG_ACCCCE(NOL,"","","[M:SRL1]CCE",
#&                    "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
# -- Chargement sections analytiques depuis la livraison d'origine
Call CHARG_ACCCCE(NOL,"","","[M:SRL1]CCE",
&                    "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
#fin FQ 65292
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
For I=1 To GNBDIE
    If evalue("dim([M:SRL1]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SRL1]CCE"+num$(I)+"(NOL)")=""
        Call INISEC(SECTION, "SRLD", I) From TRTX3CPT
        Assign "[M:SRL1]CCE"+num$(I)+"(NOL)" With SECTION
    Endif
Next

Local Integer WRET
If [M:SRL1]STOMGTCOD(NOL)>1 & [M:SRL1]WSTOFLG(NOL)=0
    If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=7;GFLAG
                            If fstat Raz [F:SLT] Endif
                            Endif
    # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
    Call STJSTOENTW("SRL1",18,13,[M:SRL0]RTNDAT,NOL,[M:SRL1]NBLIG,"SLT",0,WRET) From STKENT
    # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
    # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer (avoir sur facture)
    # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
    # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
    If WRET=4
        Call MESSAGE([M:SRL1]DETSDHNUM(NOL)-":"-[M:SRL1]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
    Elsif WRET<>0
        If WRET=6
            Call ERREUR([M:SRL1]DETSDHNUM(NOL)-":"-[M:SRL1]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
        Endif
        Dela NOL,1,[M:SRL1]NBLIG-1 [M:SRL1]NBLIG : [M:SRL1]NBLIG-=1
        If [M]NBLIG=0 Raz [M]SALFCY Endif
        # Unlock entête livraison
        SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
        Unlock = SYMBOLE2
        GERR=1 : OK=0 : Return
    Endif
Endif

# Point d'entrée pour compléter l'alimentation de l'écran détail retour
GPOINT="ALIPICSRL" : Gosub ENTREE From EXEFNC

#Affzo [M:SRL1]1-99
Return

#########################################################################
$DESEL1
Local Integer I, J, SNOL
Raz I, J, SNOL
OK = 0
If [M]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M]DETSDHNUM(J..[M]NBLIG-1))
      If !I Break Endif
      If [M]CREFLG(J+I-1)=0 & [F:SDD]SDDLIN=[M]SDDLIN(J+I-1)
         SNOL = J+I-1
         Dela SNOL,1,[M]NBLIG-1 [M]NBLIG
         [M]NBLIG -= 1
         If [M]NBLIG=0 Raz [M]SALFCY Endif
#         Affzo [M:SRL1]15
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette livraison, il faut la débloquer
Raz I,J
OK = 2
If [M:SRL1]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M:SRL1]DETSDHNUM(J..[M:SRL1]NBLIG-1))
      If !I Break Endif
      If [M:SRL1]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête livraison
   SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
   Unlock = SYMBOLE2
Endif

Return

#########################################################################
$CTL_LIV
#---------------------------------------------------------------------------------------#
# Contrôle de la ligne livraison sélectionnée                                           #
# Elle doit être cohérente par rapport aux autres lignes sélectionnées                  #
#---------------------------------------------------------------------------------------#
If [F:SDH]BPCORD<>[M]BPCORD | [F:SDH]BPAADD<>[M]BPAADD
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(224,192,1)
   Return
Endif
If [F:SDH]BPCINV<>[M]BPCINV
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(101,191,1)
   Return
Endif
If [F:SDH]SALFCY<>[M]SALFCY
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(103,192,1)
   Return
Endif
If [F:SDH]PLISTC<>[M]PLISTC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SOHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(305,192,1)
   Return
Endif
#--- CPO 72237 Le champ BPIEECNUM est soumis à code activité
#If [F:SDH]BPIEECNUM<>[M]BPIEECNUM | [F:SDH]EECICT<>[M]EECICT
If (dim([M]BPIEECNUM)>0 & [F:SDH]BPIEECNUM<>[M]BPIEECNUM) | [F:SDH]EECICT<>[M]EECICT
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(303,192,1)
   Return
Endif
If dim([M]EECLOC)>0 & [F:SDH]EECLOC<>[M]EECLOC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(304,192,1)
   Return
Endif
#--CPO 71065 - Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
If func TRTPJT.IS_PJT_AVAILABLE([F:SDD]PJT, "[M:SRL1]DPJT",SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SDD]PJT,SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
#--/CPO
Return
#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
If sum([M:SRL1]SDDLIN) <> 0
   For I=0 To [M:SRL1]NBLIG-1
      # La ligne est issue d'un picking livraison réalisé au cours de cette transaction
      If [M:SRL1]DETSDHNUM(I) <> "" & [M:SRL1]CREFLG(I) = 0
         If currbox = GBOXSD2
            Read [SDD]SDD0=[M:SRL1]DETSDHNUM(I);[M:SRL1]SDDLIN(I)
         Endif
         If    WPICK=1 Gosub DEPICK From GOBJSUB
         Elsif WPICK=2 Gosub REPICK From GOBJSUB
         Endif
      Endif
   Next I
Endif
Return
##########################################################################


##########################################################################
##########################################################################
#     ETIQUETTES APPELEES PAR LES COMPOSANTS D'ENTREE EN STOCK
##########################################################################
#########################################################################
# Bouton Détail  en click droit sur NBLIG  Action SAISTOENT             #
# Fenêtre Détail en APRES_NBLIG            Action SAISTOENT             #
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENT (LLIG)
Value Integer LLIG
[M:ENT]STOFCY    = [M:SRL0]STOFCY
[M:ENT]ITMREF    = [M:SRL1]ITMREF(LLIG)
[M:ENT]QTYTOENT  = [M:SRL1]QTY(LLIG)
[M:ENT]PCUTOENT  = [M:SRL1]SAU(LLIG)
[M:ENT]COETOENT  = [M:SRL1]SAUSTUCOE(LLIG)
[M:ENT]STU       = [M:SRL1]STU(LLIG)
[M:ENT]VCRNUM    = [M:SRL0]SRHNUM
[M:ENT]VCRLIN    = [M:SRL1]SRDLIN(LLIG)
[M:ENT]WSTOSEQ   = [M:SRL1]WSTOSEQ(LLIG)
[M:ENT]MVTDES    = [M:SRL1]MVTDES(LLIG)
[M:ENT]PRI       = [M:SRL1]PRIORD(LLIG)
[M:ENT]QUAFLG    = [M:SRL1]QUAFLG(LLIG)        # hcb V6CQ
[M:ENT]QUAFRE    = [M:SRL1]QUAFRE(LLIG)        # hcb V6CQ
If dim([M:SRL1]WRH)>0
  [M:ENT]XWRH    = [M:SRL1]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 18                          : # Type mouvement (M.704)
[M:ENT]TRSCOD    = [M:SRL0]TRSCOD              : # code mouvement
[M:ENT]TRSFAM    = [M:SRL2]TRSFAM
[M:ENT]IPTDAT    = [M:SRL0]RTNDAT              : # Date imputation
[M:ENT]BPRNUM    = [M:SRL0]BPCORD

[M:ENT]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENT]PRNCOD1   = GSLTPRNCOD1
[M:ENT]PRNNBFLG1 = GSLTPRNNBFLG1
[M:ENT]CCECODS   = GSTODIE

If [M:SRL1]DETSDHNUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 4
    [M:ENT]VCRNUMORI = [M:SRL1]DETSDHNUM(LLIG)
    [M:ENT]VCRLINORI = [M:SRL1]SDDLIN(LLIG)
    If [F:SDH]SDHNUM <> [M:SRL1]DETSDHNUM(LLIG)
        Read [SDH]SDH0=[M:SRL1]DETSDHNUM(LLIG)
        If fstat Raz [F:SDH] Endif
    Endif
    [M:ENT]STOFCYORI = [F:SDH]STOFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Else
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Endif
[M:ENT]BPRNUM = [M:SRL0]BPCORD
[M:ENT]FILLOCENT="[F:TLO]LOCCAT<>3"
End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_LIGNE_DOCUMENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
# Donne la main pour maj ligne du document, et grise les champs stock   #
# LPCU    : Unité utilisée dans le détail                               #
# LCOEF   : Coefficient utilisé dans  le détail                         #
# LQTYSTU : Qté en US à répercuter dans le doc                          #
#-----------------------------------------------------------------------#
$MAJ_LIG_SRL
Local Decimal WQTYSAU, WQTY

Local Integer NOL : NOL=LLIGDOC
If !find(GACTION, "SAISTOENT","SAISTOENTM") Return Endif    # hcb 110327
#--- Cas de la suppression : 24/11/03 (tests HN)
If LQTYSTU=0
  If [M:SRL1]CREFLG(NOL)<>0
    [M:SRL1]QTY(NOL)=0
    [M:SRL1]QTYSTU(NOL)=0
    Return
  Elsif [M:SRL1]CREFLG(NOL)=0
    Raz [M:SRL1]WSTOFLG(NOL) : Grizo [M:SRL1]QTY(NOL)
  Endif
Endif
# Dans la fenêtre détail : l'unité ou le coefficient UV-US ou la qté sont différents du document d'origine
# Si la qté en US est modifiée report sur la ligne document origine
If LQTYSTU<>[M:SRL1]QTYSTU(LLIGDOC)
    If LCOEF<>0
    # -- Coef. unique sur toutes les lignes
        If LPCU=[M:SRL1]SAU(LLIGDOC)
        # -- L'entrée a été saisie dans l'unité du document (UV) : On récalcule la qté retour en UV
            If LCOEF=[M:SRL1]SAUSTUCOE(LLIGDOC)
                [M:SRL1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                [M:SRL1]QTYSTU(LLIGDOC)=LQTYSTU
            Else
                # Le coefficient a été modifié
                If [M:SRL1]DACSAUCOE(LLIGDOC)=2
                    # Il est modifiable       : Il est répercuté
                    [M:SRL1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                    [M:SRL1]QTYSTU(LLIGDOC)=LQTYSTU
                    [M:SRL1]SAUSTUCOE(LLIGDOC)=LCOEF
                    # Recalcul de l'ancienne qté retour avec le nvx coefficient
                    WQTY=[M:SRL1]XQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRL1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRL1]XQTY(LLIGDOC)= WQTY
                    # Recalcul de la qté livrée avec le nvx coefficient
                    WQTY=[M:SRL1]DLVQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRL1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRL1]DLVQTY(LLIGDOC)= WQTY
                Else
                    # -- Il n'est pas modifiable : Il n'est pas répercuté
                    #    On recalcule la qté retour ds l'unité du document(UV)
                    #    Si on tombe sur un chiffre rond ok sinon on met tout en US
                    Gosub RECALC_QTYSAU
                Endif
            Endif
        Else
            # -- L'entrée a été saisie en US ou ds une autre unité
            #    On recalcule la qté retour ds l'unité du document(UV)
            #    Si on tombe sur un chiffre rond ok sinon on met tout en US
            Gosub RECALC_QTYSAU
        Endif
    Else
    # -- Coef. non unique sur toutes les lignes : on met tout en US
         Gosub CONV_LIG_SAUSTU
    Endif
    Affzo [M:SRL1]SAU(LLIGDOC), QTY(LLIGDOC), DLVQTY(LLIGDOC), SAUSTUCOE(LLIGDOC)
Endif

If [M:SRL1]SAU(LLIGDOC)=[M:SRL1]STU(LLIGDOC)
  Affzo [M:SRL1]SAUSTUCOE(LLIGDOC) : # pb diszo
  Diszo [M:SRL1]SAUSTUCOE(LLIGDOC)
  Affzo [M:SRL1]SAUSTUCOE(LLIGDOC) : # pb diszo
Endif

Return


$RECALC_QTYSAU
# ------------------------------------------------------------- #
# Recalcul de la qté retour ds l'unité du document (UV)         #
#    Si on tombe sur un chiffre rond ok sinon on met tout en US #
# ------------------------------------------------------------- #
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SRL1]SAUSTUCOE(LLIGDOC)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SRL1]SAU(LLIGDOC)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SRL1]QTY(LLIGDOC)=WQTYSAU
    [M:SRL1]QTYSTU(LLIGDOC)=LQTYSTU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    Gosub CONV_LIG_SAUSTU
Endif
Return
# ------------------------------------------------------------- #
# Passage de la ligne retour en US                              #
# --> L'UV devient l'US                                         #
# --> La qté en UV devient la qté en US                         #
# --> Conversion en US toutes les quantités qui étaient en UV   #
# --> Le coef. UV-US est forcé à 1                              #
# ------------------------------------------------------------- #
$CONV_LIG_SAUSTU
[M:SRL1]QTYSTU(NOL)=LQTYSTU
[M:SRL1]SAU(NOL)=[M:SRL1]STU (NOL)
[M:SRL1]QTY(NOL)=LQTYSTU
# Il faut reconvertir en US toutes les quantités qui étaient en UV
[M:SRL1]XQTY(NOL)   =[M:SRL1]XQTY(NOL)*[M:SRL1]SAUSTUCOE(NOL)
[M:SRL1]DLVQTY(NOL) =[M:SRL1]DLVQTY(NOL)*[M:SRL1]SAUSTUCOE(NOL)
#
[M:SRL1]SAUSTUCOE(NOL)=1
Return
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTB                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CTL_LIGNE_DOCUMENT                                       #
# Donne la main pour effectuer avant stockage dans STOENTW:             #
#  - contrôles de quantités                                             #
#  - affectation diverses                                               #
# En cas d'erreur, donner une valeur différente de 0 à mkstat           #
# Attention : Il est de la responsabilité de chaque document d'afficher #
#             les messages d'erreurs.                                   #
# Variables disponibles :                                               #
# LQTYSTU = Quantité totale en unité de stock des lignes de détail      #
# LPCU    = Unité utilisée dans le détail si unique sinon ""            #
# LCOEF   = Coefficient UC/US si unique sinon ""                        #
#-----------------------------------------------------------------------#
$CTL_LIG_SRL
#------------------------------------------#
# Contrôle au sortir de la saisie de stock #
# ou modif de stock                        #
#------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(TRTLIG)<0    : Local Char     TRTLIG(1) : Endif
If dim(SVGNOL)<0    : Local Integer  SVGNOL    : Endif
If !find (GACTION,"SAISTOENT","SAISTOENTM") Return Endif           # hcb 110327
Local Integer OK
Local Decimal WRTNQTYSTU, WEXTQTYSTU
SVGNOL=nolign : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1
NEWQTE =LQTYSTU

# Modification de la quantité
If LQTYSTU>0 & LQTYSTU<>[M:SRL1]QTYSTU(NOL)
    If [M:SRL1]DETSDHNUM(NOL) <> ""
        # -- Quantité retour > quantité livrée ?
        If LQTYSTU - [M:SRL1]XQTYSTU(NOL) > [M:SRL1]DLVQTYSTU(NOL)
           GMESSAGE = mess(64,192,1) : mkstat = 2 : Return
        Endif
    Endif
Endif
# Contrôle du stock retourné
If [M:SRL1]DETSDHNUM(NOL)<>""
    Call CTR_STK_RETCLI(OK) From STKENT
    If OK mkstat = 2 : Return Endif
Endif

If [M:SRL1]CREFLG(NOL)<>0
  #-- Si la quantité est à 0 (suppression de ligne)
  If LQTYSTU = 0
    TRTLIG="A" : status=65
  Else
    TRTLIG="M" : status=75
  Endif
#  Gosub TEST_MOD_ANU
#  If mkstat Call ERREUR(GMESSAGE) From GESECRAN : nolign=SVGNOL : Return : Endif
Endif
nolign=SVGNOL
Return
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENMA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENTM                                      #
# Chargement Ecran STOENTM (partie parametrage) modification des entrées#
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENTM (LLIG)
Value Integer LLIG

If LLIG<>999999
  [M:ENM]STOFCY   = [M:SRL0]STOFCY
  [M:ENM]ITMREF   = [M:SRL1]ITMREF(LLIG)
  [M:ENM]QTYTOENT = [M:SRL1]QTY(LLIG)
  [M:ENM]PCUTOENT = [M:SRL1]SAU(LLIG)
  [M:ENM]COETOENT = [M:SRL1]SAUSTUCOE(LLIG)
  [M:ENM]STU      = [M:SRL1]STU(LLIG)
  [M:ENM]VCRNUM   = [M:SRL0]SRHNUM
  [M:ENM]VCRLIN   = [M:SRL1]SRDLIN(LLIG)
  [M:ENM]MVTDES   = [M:SRL1]MVTDES(LLIG)
  [M:ENM]QUAFLG   = [M:SRL1]QUAFLG(LLIG)        # hcb V6CQ
  [M:ENM]QUAFRE   = [M:SRL1]QUAFRE(LLIG)        # hcb V6CQ
  If dim([M:SRL1]WRH)>0
    [M:ENM]XWRH   = [M:SRL1]WRH(LLIG)
  Endif
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 18                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [M:SRL0]TRSCOD       : # Code mouvement
  [M:ENM]TRSFAM   = [M:SRL2]TRSFAM
  [M:ENM]BPRNUM   = [M:SRL0]BPCORD
  If dim([M:SRL1]BETCPY)>0 : [M:ENM]BETCPY = [M:SRL1]BETCPY : Endif
     :
#  [M:ENM]ENTCOD   = [M:SRL0]ENTCOD: # Ne sert plus : Le mvt pour les retours de prêt n'est pas valorisé
  If [M:SRL1]DETSDHNUM (LLIG)<> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Else : # Cas de la suppression
# ???
  [M:ENM]STOFCY   = [F:SRD]STOFCY
  [M:ENM]ITMREF   = [F:SRD]ITMREF
  [M:ENM]QTYTOENT = [F:SRD]QTY
  [M:ENM]PCUTOENT = [F:SRD]SAU
  [M:ENM]COETOENT = [F:SRD]SAUSTUCOE
  [M:ENM]STU      = [F:SRD]STU
  [M:ENM]VCRNUM   = [F:SRD]SRHNUM
  [M:ENM]VCRLIN   = [F:SRD]SRDLIN
  [M:ENM]MVTDES   = ""
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 18                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [F:SRH]TRSCOD        : # Code mouvement
  [M:ENM]TRSFAM   = [F:SRH]TRSFAM
  [M:ENM]BPRNUM   = [F:SRH]BPCORD
  [M:ENM]BETCPY   = [F:SRH]BETCPY
#  [M:ENM]ENTCOD   = [F:SRH]ENTCOD: # Ne sert plus : Le mvt pour les retours de prêt n'est pas valorisé
  If [F:SRD]SDHNUM <> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Endif
[M:ENM]FILLOCENT="[F:TLO]LOCCAT<>3"
[M:ENM]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENM]PRNCOD1   = GSLTPRNCOD1
[M:ENM]PRNNBFLG1 = GSLTPRNNBFLG1
End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_MODIFICATION_LIGNE                                   #
# Mise à jour du document origine suite à modifications                 #
# le masque du document origine est chargé avec les nouvelles valeurs   #
#-----------------------------------------------------------------------#
########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

If dim(NOL)<0 :  Local Shortint NOL: Endif
If dim(TRTLIG)<0 Local Char    TRTLIG(1) : Endif

Local Char       SYMBOLE2(50)
Local Shortint   WSUPP
Local Integer    SIGN, WSTAT, SAVNOLIGN, I, OK, WSRDLIN, WRETOUR
Local Decimal    WLIVTTC, DELTAQTY, DELTAQTYSTU

NOL=LLIGDOC
nolign=NOL+1
WSRDLIN=[M:SRL1]SRDLIN(NOL)

Raz WSUPP, WLIVTTC
# Mise à jour des quantités
Gosub MAJ_LIG_SRL
If [M:SRL1]QTYSTU(NOL)=0
    TRTLIG="A"
    # Si la ligne doit être supprimée, on regarde s'il y en a d'autre sur le retour
    # pour déterminer si l'entête retour doit être supprimée
    Filter [SRD] Where SRHNUM=[M:SRL0]SRHNUM & SRDLIN<>[M:SRL1]SRDLIN(NOL)
&                Order By Key SRD0
    Read [SRD]SRD0 First
    If fstat WSUPP = 1 Endif
    Filter [SRD]
Else
    TRTLIG="M"
Endif

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If !find(GREP,"C","D") and [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

# --- Contrôles OK, suite de la mise à jour
If [M:SRL1]QTYSTU(NOL)=0
#  status=65 : nolign=NOL+1 : Call AVANT_NBLIG From SUBSRL
  status=65 : nolign=NOL+1
  Dela NOL,1,[M:SRL1]NBLIG-1 [M:SRL1]NBLIG : [M:SRL1]NBLIG-=1
Endif

# --- Lecture de l'entête retour
If WSUPP = 1
   Readlock [SRH]SRH0=[M:SRL0]SRHNUM
Else
   Read [SRH]SRH0=[M:SRL0]SRHNUM
Endif
If fstat = 1 GOK = -1
   GLOCK = "$SRETURN"-[M:SRL0]SRHNUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SRH",[M:SRL0]SRHNUM) From GLOCK : Return
Endif

#If [F:SRD]SDHNUM<>""
#  SYMBOLE2="SDH"+[F:SRD]SDHNUM : Unlock=SYMBOLE2
#Endif

#-- Maj du détail retour
Readlock [SRD]SRD0=[M:SRL0]SRHNUM;WSRDLIN
If fstat = 1 GOK = -1
   GLOCK = "$SRETURND"-[M:SRL0]SRHNUM-num$(WSRDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SRD",[M:SRL0]SRHNUM-num$(WSRDLIN)) From GLOCK
   Return
Endif
SIGN=-1
#----- Mise à jour statistiques ligne retour -----#
Call VALSTA ("SRD",SIGN) From SUBPS2
If GOK<1 : Return : Endif

If TRTLIG="A"
  DELTAQTY    = -1 * [F:SRD]QTY
  DELTAQTYSTU = -1 * [F:SRD]QTYSTU
  #-- Suppression texte ligne
  If left$([F:SRD]SRDTEX,3)="SRD"
        Call SUP_CLOB([F:SRD]SRDTEX,WRET) From TRTX3TEX
  Endif
  #----- Suppression comptes et sections de la ligne de facture -----#
  Call ENREG_ACCCCE(0,"","","","SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"","A") From TRTX3CPT
  If GOK<1  Return : Endif
  #-----
  #-- Suppression de la ligne de retour
  Delete [SRD] Where SRHNUM=[M:SRL0]SRHNUM & SRDLIN=WSRDLIN
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif
Else
#  DELTAQTY    = [M:SRL1]QTY(NOL) - [F:SRD]QTY
#  DELTAQTYSTU = [M:SRL1]QTYSTU(NOL) - [F:SRD]QTYSTU
  DELTAQTY    = [M]QTY(NOL)    - [M]XQTY(NOL)
  DELTAQTYSTU = [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)

  [F:SRD]QTY=[M:SRL1]QTY(NOL)
  [F:SRD]QTYSTU=[M:SRL1]QTYSTU(NOL)
  [F:SRD]SAU=[M:SRL1]SAU(NOL)
  [F:SRD]SAUSTUCOE=[M:SRL1]SAUSTUCOE(NOL)
  [F:SRD]DLVQTY=[M:SRL1]DLVQTY(NOL)
  SIGN=1
  #-- Réécriture de la ligne de retour
  Rewrite [SRD]
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif
  #----- Mise à jour statistiques ligne retour -----#
  Call VALSTA ("SRD",SIGN) From SUBPS2
  If GOK<1 : Return : Endif
Endif

#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITSRH = 1
Endif

# Maj de la livraison correspondante
If [F:SRD]SDHNUM <> "" & DELTAQTYSTU <> 0
   Local Integer WMAJ_LIV : WMAJ_LIV=1
   Gosub LEC_LIV
   If GOK < 1 Return Endif
   If WMAJ_LIV = 1
       Local Decimal WCNVDELTAQTY
       Gosub CONV_DELTAQTY
       Gosub MAJLIV
       If GOK < 1 Return Endif
       If [F:SDH]SIHNUM = ""
#          WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
          WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       Endif
    Endif
Endif

If WSUPP=1 Delete  [SRH] : Endif
If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Return : Endif

WSENS = "-"
# Maj mouvement client (livré en prêt)
If WLIVTTC <> 0
   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&               0, WLIVTTC, WSENS, "D", "", [F:SDH]LND) From TRTBPMVT
   If GOK < 1 Return Endif
Endif
Return

##########################################################################
#########################################################################
# SRLINIZONENT                                                          #
#    Appelé en AVANT-NBLIG en modification d'une ligne de retour        #
#                                                                       #
#    - Lecture des tables articles                                      #
#    - Lecture de la règle de gestion à appliquer                       #
#    - Si ligne non créée ou créée mais elle devient gérée en stock     #
#         Si ligne gérée en stock :                                     #
#            Désactivation lot, n° série                                #
#    - Si ligne déjà créée :                                            #
#         Si ligne non gérée en stock :                                 #
#            Grisage des champs stock                                   #
#         Si ligne gérée en stock     :                                 #
#            Désactivation des champs stock                             #
#                                                                       #
#                                                                       #
#########################################################################
Subprog SRLINIZONENT
Local Integer NOL : NOL=nolign-1

If [M:SRL1]STOMGTCOD(NOL)<>1 & [M:SRL1]RTNSTOUPD(NOL)=2
    # Si ligne gérée en stock
    # --> Lecture article et règle de gestion (sf si on va le faire ds INIZONENT)
    Call LECFICENT([M:SRL0]STOFCY,[M:SRL0]BPCORD,"",nolign-1,18,[M:SRL0]TRSCOD,0) From STKECR
Endif

If [M:SRL1]CREFLG(NOL)=0 | ([M:SRL1]CREFLG(NOL)<>0 & [M:SRL1]RTNSTOUPD(NOL)=2 & [M:SRL1]YRTNSTOUPD(NOL)=1)
    # ---------------------------------------------------------------------------------------------------- #
    # La ligne n'est pas encore créée ou elle est déjà créée mais le flag maj stock est passé de non à oui #
    # ---------------------------------------------------------------------------------------------------- #
    Actzo [M:SRL1]QTY(NOL)

    If [M:SRL1]STOMGTCOD(NOL)<>1 & [M:SRL1]RTNSTOUPD(NOL)=2
        # -------------------- #
        # Ligne gérée en stock #
        # -------------------- #
        If [M:SRL1]DETSDHNUM(NOL)<>""
           # Il faut Activer/Désactiver les chmps
           #
           #      Il faut désactiver les champs lot, n°série
           # (cas particulier où on a passé le flg mvt de stock de non à oui
           Call STKDISZONPIC("SRL1", NOL) From TRTVENSTK
           #MAE, le 30/09/2010, bg 67156
           # Désactivation des zones stock si plus d'un détail stock
           If func STKENT.CAL_NBENTW([M:SRL1]WSTOSEQ(NOL)) > 1
              Call STKDISLIG(NOL) From STKECR
           Endif
        Endif
    Endif
Else
    # ----------------------- #
    # La ligne est déjà créée #
    # ----------------------- #
    If [M:SRL1]STOMGTCOD(NOL)=1 | [M:SRL1]RTNSTOUPD(NOL)=1
        # --> Si ligne non gérée en stock, grizage des champs stock
        Actzo [M:SRL1]QTY(NOL)
        Call STKGRILIG ("SRL1", NOL) From TRTVENSTK
    Else
        Diszo [M:SRL1]SAU(NOL), QTY(NOL), SAUSTUCOE(NOL)
        Call STKDISLIG(NOL) From STKECR : # Diszone les champs stocks ne pouvznt plu être modifiés
        If dim([M]PRIORD)>0  Diszo [M]PRIORD(NOL) : Endif
        If dim([M]MVTDES)>0  Diszo [M]MVTDES(NOL) : Endif
    Endif
Endif
End

#########################################################################
#---------------------------------------#
#   Gestion du parc client              #
#---------------------------------------#
$TRT_MACRULE
Local Integer WRET, WTYP
Local Integer WERR  # FGR 20/05/2009 : X3SUIVI55175 Variable non déclarée

  Raz WERR          # FGR 20/05/2009 : X3SUIVI55175 Variable non déclarée
  Raz WRET
  WTYP=6
  For [SRD]SRD0 Where SRHNUM=[F:SRH]SRHNUM
    If [F:ITM]ITMREF <> [F:SRD]ITMREF
      Read [ITM]ITM0 = [F:SRD]ITMREF
      If fstat Then
        Raz [F:ITM]
      Endif
    Endif
    If [F:SRD]SAUSTUCOE=0 Then
      [F:SRD]SAUSTUCOE=1
    Endif
    # Pas de gestion des no série
    If [F:ITM]SERMGTCOD < 2
      Gosub CHARGE_MACW
      # Appel au composant d'intégration
      Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
      If WRET Then
        Gosub ERR_MACRULE
        Break                           # FGR 04/01/2011 : X3SUIVI70100
      Endif
      # Gestion des no séries
    Else
      For [STJ]STJ1 Where STOFCY=[F:SRH]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM
&                       & VCRLIN=[F:SRD]SRDLIN & REGFLG<>2 & QTYSTU>0
        Gosub CHARGE_MACW
        # Appel au composant d'intégration
        Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
        If WRET Then
          Gosub ERR_MACRULE
          Break                         # FGR 04/01/2011 : X3SUIVI70100
        Endif
      Next
      If WRET Then                      # FGR 04/01/2011 : X3SUIVI70100
        Break
      Endif
    Endif
  Next
Return


# Traitement des erreurs
$ERR_MACRULE
  GOK = 0                               # FGR 04/01/2011 : X3SUIVI70100
  If WERR=0
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    WERR=1
  Endif
  If [M:MACW]MACSERNUM=""
    Call ECR_TRACE ([F:SRD]ITMREF-":"-mess(WRET,182,2),0) From GESECRAN
  Else
    Call ECR_TRACE ([F:SRD]ITMREF-[M:MACW]MACSERNUM-":"-mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [F:SRD]ITMREF
[M:MACW]MACORIVCR  = [F:SRD]SRHNUM
[M:MACW]MACORIVCRL = [F:SRD]SRDLIN
[M:MACW]SALFCY     = [F:SRH]SALFCY
[M:MACW]MACITNDAT  = [F:SRH]RTNDAT
[M:MACW]PREORI     = 3
[M:MACW]PREORIVCR  = [F:SRD]SDHNUM
[M:MACW]PREORIVCRL = [F:SRD]SDDLIN
If [F:ITM]SERMGTCOD < 2
   [M:MACW]MACQTY     = [F:SRD]QTYSTU
Else
   [M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
   [M:MACW]MACSERNUM  = [F:STJ]SERNUM
Endif
  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRL"
  SZMACWPRE = ""
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return

$TRT_MACRULE_MOD
Local Integer WRET, WTYP

  Raz WRET
  WTYP=6
  For NOL=0 To [M:SRL1]NBLIG-1
    If [M:SRL1]UPDFLG(NOL)<>0 & [M:SRL1]RTNSTOUPD(NOL)=2 & [M:SRL1]YRTNSTOUPD(NOL)<>2
      If [F:ITM]ITMREF <> [M:SRL1]ITMREF(NOL)
        Read [ITM]ITM0 = [M:SRL1]ITMREF(NOL)
        If fstat Then
          Raz [F:ITM]
        Endif
      Endif
      # Gestion des no séries
      If [F:ITM]SERMGTCOD > 1
        For [STJ]STJ1 Where STOFCY=[M:SRL0]STOFCY & VCRTYP=13 & VCRNUM=[M:SRL0]SRHNUM
&                         & VCRLIN=[M:SRL1]SRDLIN(NOL) & REGFLG<>2
          Gosub CHARGE_MACW_MOD
          # Appel au composant d'intégration
          Call MACRULE(WTYP,[M:SRL0]BPCORD,WRET) From TRTMACRULE
          If WRET Then
            Break 2
          Endif
        Next
        If WRET Then                    # FGR 04/01/2011 : X3SUIVI70100
          Break
        Endif
      Endif
    Endif
  Next
  If WRET
    GOK = 0                             # FGR 04/01/2011 : X3SUIVI70100
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    Call ECR_TRACE (mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW_MOD
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [M:SRL1]ITMREF(NOL)
[M:MACW]MACORIVCR  = [M:SRL0]SRHNUM
[M:MACW]MACORIVCRL = [M:SRL1]SRDLIN(NOL)
[M:MACW]MACITNDAT  = [M:SRL0]RTNDAT
[M:MACW]SALFCY     = [M:SRL0]SALFCY
[M:MACW]PREORI     = 3
[M:MACW]PREORIVCR  = [M:SRL1]DETSDHNUM(NOL)
[M:MACW]PREORIVCRL = [M:SRL1]SDDLIN(NOL)
[M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
[M:MACW]MACSERNUM  = [F:STJ]SERNUM
  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRL"
  SZMACWPRE = "MOD"
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SRH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:SRL1]WRHE
      If GWRHOBY=2
         Diszo [M:SRL1]WRH
      Else
         Actzo [M:SRL1]WRH
      Endif
   Elsif [M:SRL1]WRHE<>""
      Diszo [M:SRL1]WRHE
      Diszo [M:SRL1]WRH
   Else
      Actzo [M:SRL1]WRHE
      Actzo [M:SRL1]WRH
   Endif
Else
  Raz   [M:SRL1]WRHE
  Grizo [M:SRL1]WRHE
  Grizo [M:SRL1]WRH
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SRL1) 31/03/2011 15:26:10 (TS)
######################################################################################
#--- Bug 72649
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
If [M:SRL1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:SRL1]LOC(nolign-1),[M:SRL1]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                            # hcb 110327 deb
If dim([M:SRL1]SERNUM) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
   Raz   [M:SRL1]SERNUM (nolign-1)
   Raz   [M:SRL1]SERNUMF(nolign-1)
   Affzo [M:SRL1]SERNUM (nolign-1)
   Affzo [M:SRL1]SERNUMF(nolign-1)
Endif
#                                                                            # hcb 110327 deb
End
#---
######################################################################################
$REC_CPT_RET

If !clalev([F:TRE]) : Local File TABSRHTYP [TRE] : Endif

Local Integer WCPTSRHTYP : [L]WCPTSRHTYP = 0

If [M:SRL0]SRHTYP<>""
  # --- Récupération du code compteur
  #--CPO 75115 - 203
  #--On cherche avant tout sur le type de retour
  #--Lecture de TABSRHTYP si cette dernière n'est pas en ligne
  If (find([F:TRE]SRHTYP,"",[M:SRL0]SRHTYP)<1 | find([F:TRE]LEG,GCURLEG)<1)
      Local Integer WERR
      Call LEC_TRE_LEG(GCURLEG,[M:SRL0]SRHTYP,WERR) From TRTLECLEG
      If WERR Raz [F:TRE] : Call RSTA("TRE", [M:SRL0]SRHTYP) From GLOCK : Endif
  Endif
  #--Initialisation des compteurs en fonction du type de retour
  If [F:TRE]SRHTYP<>""
    If    [M:SRL1]BETFCY=2 & [M:SRL1]BETCPY=1       :#-- Retour Inter-sites
      GCPT=[F:TRE]CODNUMFCY
    Elsif [M:SRL1]BETCPY=2                          :#-- Retour Inter-sociétés
      GCPT=[F:TRE]CODNUMCPY
    Else                                            :#-- Retour normal
      GCPT=[F:TRE]CODNUM
    Endif
    GMANCOU=[F:TRE]MANCOU
    If func AFNC.ACTIV("KPO") #85785
      GCPTENDNBR =[F:TRE]CODNUMEND                         :#-- Compteur définitif
    Endif
    [L]WCPTSRHTYP = 1 :#--Il faut absolument ré-initialiser les compteurs si non passage ici
  Endif
Endif
#--On lit toujours car on utilise pour initialiser aussi d'autres compteurs
#--------(exp dans $OUVRE le GCPTENDNBR=[F:TCA]CODNUM(13))-------
Local Integer WOK
If clalev ([F:TCA]) <= 0 Local File TABCOUAFF [TCA] Endif
Call LECTCA(5,WOK) From SUBTCA
If fstat | !WOK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
Endif

#--Si pas de type de retour ou pas de compteur de paramétré
#--On initialise avec le paramétrage des affectations de compteurs
#--Pas d'entrée dans les "Affectations compteurs" pour le "Retour définitif"
#If [L]WCPTSRHTYP=0 | (func AFNC.ACTIV("DKS")=1 & GCPTENDNBR="") | GCPT="" | [F:TRE]SRHTYP=""
If [L]WCPTSRHTYP=0 | GCPT=""
  If GCPT="" | [F:TRE]SRHTYP=""
    If    GDLVTYP = 2                                       : # Retour de prêt
        GMANCOU=[F:TCA]MANCOU(7)  : GCPT=[F:TCA]CODNUM(7)
    Elsif GDLVTYP = 3                                       : # Retour de sous-traitance
        GMANCOU=[F:TCA]MANCOU(17) : GCPT=[F:TCA]CODNUM(17)
    Elsif [M:SRH1]BETFCY=2 | [M:SRH1]BETCPY=2               : # Retour Intra-société/Inter-société
        GMANCOU=[F:TCA]MANCOU(16) : GCPT=[F:TCA]CODNUM(16)
    Else                                                    : # Retour normal
        GMANCOU=[F:TCA]MANCOU(2)  : GCPT=[F:TCA]CODNUM(2)
    Endif
  Endif
#--Pas d'entrée dans les "Affectations compteurs" pour le "Retour définitif"
#  If func AFNC.ACTIV("DKS") & GCPTENDNBR=""
#    GCPTENDNBR=[F:TCA]CODNUM(xx)   :#-- Compteur définitif
#  Endif
Endif

#--CPO 75115 Le compteur et le compteur définitif doivent être différents
#--Uniquement si le code activité DKS est actif
If func AFNC.ACTIV("KPO")=1 and GCPT <>"" and GCPTENDNBR<>"" and GCPT=GCPTENDNBR #85785
  GERR=1 : GMESSAGE= mess(248,191,1)-GCPT+"/"+GCPTENDNBR : Return
Endif

Return

######################################################################################
Subprog C_DPEDATR(VALEUR)
Variable Date    VALEUR

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRL0]STOFCY,'')=1
  End
Endif

  # FGR 07/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If VALEUR > [M:SRL0]RTNDAT Then
      GMESSAGE = mess(400,192,1) - format$(GFMDAT, VALEUR) - ">" - format$(GFMDAT, [M:SRL0]RTNDAT)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_DPEDATR(VALEUR)
Variable Date    VALEUR

  # FGR 07/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SRL2]ARVDATR = [0/0/0] or ([M:SRL2]ARVDATR <> [0/0/0] and (VALEUR > [M:SRL2]ARVDATR or [M:SRL2]DPEDATR = [M:SRL2]ARVDATR)) Then
      [M:SRL2]ARVDATR = VALEUR
      Affzo [M:SRL2]ARVDATR
    Endif
  Endif
End

######################################################################################
Subprog C_ARVDATR(VALEUR)
Variable Date    VALEUR

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRL0]STOFCY,'')=1
  End
Endif

  # FGR 07/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SRL2]DPEDATR <> [0/0/0] and VALEUR < [M:SRL2]DPEDATR Then
      GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M:SRL2]DPEDATR) - ">" - format$(GFMDAT, VALEUR)
      mkstat = 2
      End
    Endif
  Endif
End
######################################################################################
# BRBAN 23-07-2014 SAM 93745 US2
Subprog AM_GLBDOCNUMR(VALEUR)
Variable Char    VALEUR()
Call AM_GLBDOCNUM(VALEUR) From TRNDOC
End
######################################################################################
Subprog C_MANDOCR(VALEUR)
Variable Char    VALEUR()
Call C_MANDOC(VALEUR) From TRNDOC
End
######################################################################################
Subprog AS_GLBDOCTYPR(VALEUR)
Variable Integer VALEUR
Call AS_GLBDOCTYP(VALEUR) From TRNDOC
End
######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
# BRBAN SAM#93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN(VALEUR,'')=1
    Actzo  [M:SRL2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRL2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
Endif
#-
End
######################################################################################
Subprog AM_GLBDOCR(VALEUR)
Variable Integer VALEUR
Call AM_GLBDOC(VALEUR) From TRNDOC
End
######################################################################################
Subprog C_ETAR(VALEUR)
If VALEUR="0000" : End : Endif
Variable Char    VALEUR()
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRL0]STOFCY,'')=1
  If [M:SRL2]DPEDATR<>[0/0/0] & [M:SRL2]ARVDATR<>[0/0/0]
    If [M:SRL2]DPEDATR=[M:SRL2]ARVDATR & VALEUR<=[M:SRL2]ETDR
       # BRBAN 107887
       Call ERREUR(mess(98,7711,1)) From GESECRAN
       mkstat=2
    Endif
  Endif
Endif
End
######################################################################################

#                                                                            # hcb 110327 deb
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:SRL1]LOCTYP) > 0
   If  [M:SRL1]LOCTYP(nolign-1) <> [F:TLO]LOCTYP
       Read [TLO]TLO0=[M:SRL0]STOFCY;[M:SRL1]LOCTYP(nolign-1)
       If fstat
          Raz [F:TLO]
       Endif
   Endif
   If [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
      mkstat = 2
   Endif
Endif
End
#                                                                            # hcb 110327 deb
#########################################################################
# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
$VERIF_CTL_ALLCCE
Local Integer NE
Local Char SAXECTRL(GLONCCE)

  If func AFNC.ACTIV("ANA")>0
    # -------------------------------------
    For I = 0 To [M]NBAXE-1
      If [M]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M]CCE(I)) From W1SRL2
        If mkstat Then
          OK = 0
          Break
        Endif
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
    #--This control has to be done also during Creation/Update of a document
    For WIJ=0 To [M:SRL1]NBLIG-1
      # -------------------------------------
      For NE = 1 To 20
        If evalue("type([M:SRL1]CCE" + num$(NE) + "(WIJ)) >= 0") Then
          SAXECTRL = evalue("[M:SRL1]CCE" + num$(NE) + "(WIJ)")
          If SAXECTRL <> "" Then
            nolign = WIJ + 1
            #--for the ENAFLG flag
            Call CONTSEL("CCE","!",SAXECTRL,num$(GDIE(NE)),mkstat) From CONTOBJ
            If !mkstat
              Call CTRL_CCE(SAXECTRL, NE, "", GFINRSP, [M:SRL0]RTNDAT) From TRTX3CPT
            Endif
            If mkstat Then
              OK = 0
              GMESSAGE = mess(162,154,1)-[M:SRL1]ITMREF(WIJ)-":"-GMESSAGE
              Break
            Endif
          Endif
        Endif
      Next NE
      If OK = 0 Then
        Break
      Endif
      # -------------------------------------
    Next
    If OK = 0 Then
      Return
    Endif
  Endif

Return
# End issue X3-44998

