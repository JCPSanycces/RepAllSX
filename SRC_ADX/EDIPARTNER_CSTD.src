###############################################################################
# Class EDIPARTNER                                                            #
# Author : RBA +JUCON                                                         #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADELETE_CONTROL_BEFORE" : Gosub ADELETE_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
      Endcase
    When "EPRD"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EPRD_ADDLINE_AFTER
        When "ADELLINE_BEFORE"        : Gosub EPRD_ADELLINE_BEFORE
     Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"           : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "PARCOD"
      Case [L]ARULE
        When "CONTROL"     : Gosub PARCOD_CONTROL
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"        : Gosub PARTYP_INIT
        When "CONTROL"     : Gosub PARTYP_CONTROL
      Endcase
    When "FLGACT"
      Case [L]ARULE
        When "PROPAGATE"   : Gosub FLGACT_PROPAGATE
      Endcase
    When "EPRD.CATCOD"
      Case [L]ARULE
        When "PROPAGATE"   : Gosub EPRD_CATCOD_PROPAGATE
      Endcase
    When "EPRD.CATTYP"
      Case [L]ARULE
        When "PROPAGATE"   : Gosub EPRD_CATTYP_PROPAGATE
      Endcase
    When "EPRD.CATOPE"
      Case [L]ARULE
        When "PROPAGATE"   : Gosub EPRD_CATOPE_PROPAGATE
      Endcase
    When "EPRD.PTCCOD"
      Case [L]ARULE
        When "CONTROL"     : Gosub EPRD_PTCCOD_CONTROL
      Endcase
  Endcase
Return

###################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_CONTROL
#Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#  Local Char WERR(250)
#  #Impossible to change the type in EDI Version 1
#  If this.PARTYP <> 2
#    #"Updating the EDI partner type is not allowed"
#    ASTATUS = fmet this.ASETERROR(CURPRO, mess(98,2006,1), [V]CST_AERROR)
##    this.PARTYP = 2
#  Endif
  Local Char WERR(250)
  If this.PARTYP <> this.snapshot.PARTYP and this.snapshot.PARTYP <> 0
    If func PARCOD_IS_USED(this.PARCOD) = [V]CST_ATRUE
      WERR = mess(9,123,1) #modification impossible
      ASTATUS = fmet this.ASETERROR("PARTYP", WERR, [V]CST_AERROR)
      this.PARTYP = this.snapshot.PARTYP
    Endif
  Endif
Return



###################################################################

$PARCOD_CONTROL
  If this.PARCOD <> ""
    this.PARCOD = func EDILIBA.FORMATVAL("PARCOD", this.PARCOD)
  Endif
Return

###################################################################

$FLGACT_PROPAGATE
  Local Integer WOK, I, WNB
  Local Char WERR(250)
  WNB = 0
  If this.FLGACT = [V]CST_AYES
    For I = 1 To maxtab(this.EPRD)
      If this.EPRD(I) <> null & this.EPRD(I).ASTALIN <> [V]CST_ADEL & this.EPRD(I).ASTALIN <> [V]CST_ANEWDEL
        WNB = WNB + 1
        Break
      Endif
    Next I
    If WNB = 0
      this.FLGACT = [V]CST_ANO
      #"No line defined"
      ASTATUS = fmet this.ASETERROR("FLGACT",mess(63,2006,1),[V]CST_AWARNING)
    Endif
  Else
    #if desactivation
    #check EDIRUN
    Local File EDIRUN [EDR]
    Filter [EDR] Where PARCOD = this.PARCOD
    For [EDR]
      #"EDI partner is used by a process, launching won't be possible"
      ASTATUS = fmet this.ASETERROR("FLGACT",mess(18,2006,1),[V]CST_AWARNING)
      Break
    Next
    LogicClose File [EDR]
  Endif

Return

####################################################################

$EPRD_CATCOD_PROPAGATE
  this.CATTYP = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATTYP")
#  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.CATACT = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATACT")

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif

  Local Integer WOK, I
  Local Char WERR(250)
  If this.CATCOD <> ""
    For I = 1 To maxtab(this.APARENT.EPRD)
      If this.APARENT.EPRD(I) <> null & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ADEL & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ANEWDEL
        #If this.APARENT.EPRD(I).CATCOD = this.CATCOD and this.APARENT.EPRD(I).AORDER <> this.AORDER
        If this.APARENT.EPRD(I).CATCOD = this.CATCOD and this.APARENT.EPRD(I).AORDER <> this.AORDER and this.APARENT.EPRD(I).CATOPE = this.CATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI
# improvements
          ASTATUS = fmet this.ASETERROR("CATCOD", mess(119,2006,1), [V]CST_AERROR)
          Break
        Endif
      Endif
    Next
  Endif
Return

####################################################################

$EPRD_CATTYP_PROPAGATE
  Local Integer WOK, I
  If this.CATCOD <> ""
    For I = 1 To maxtab(this.APARENT.EPRD)
      If this.APARENT.EPRD(I) <> null & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ADEL & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ANEWDEL
#        If this.APARENT.EPRD(I).CATTYP = this.CATTYP and this.APARENT.EPRD(I).AORDER <> this.AORDER
        If this.APARENT.EPRD(I).CATTYP = this.CATTYP and this.APARENT.EPRD(I).AORDER <> this.AORDER and this.APARENT.EPRD(I).CATOPE = this.CATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI
# improvements
          ASTATUS = fmet this.ASETERROR("CATCOD", mess(119,2006,1), [V]CST_AERROR)
          Break
        Endif
      Endif
    Next
  Endif

Return

####################################################################

$EPRD_CATOPE_PROPAGATE
  Local Integer WOK, I
  If this.CATCOD <> ""
    For I = 1 To maxtab(this.APARENT.EPRD)
      If this.APARENT.EPRD(I) <> null & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ADEL & this.APARENT.EPRD(I).ASTALIN <> [V]CST_ANEWDEL
#        If this.APARENT.EPRD(I).CATTYP = this.CATTYP and this.APARENT.EPRD(I).AORDER <> this.AORDER
        If this.APARENT.EPRD(I).CATTYP = this.CATTYP and this.APARENT.EPRD(I).AORDER <> this.AORDER and this.APARENT.EPRD(I).CATOPE = this.CATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI
# improvements
          ASTATUS = fmet this.ASETERROR("CATOPE", mess(119,2006,1), [V]CST_AERROR)
          Break
        Endif
      Endif
    Next
  Endif
Return

####################################################################

$EPRD_PTCCOD_CONTROL
  If this.PTCCOD <> ""
  #  this.PTCCOD = format$("Kv4:20B",toupper(this.PTCCOD))
    this.PTCCOD = func EDILIBA.FORMATVAL("PTCCOD", this.PTCCOD)
  Endif

  If this.snapshot.PTCCOD <> "" and this.snapshot.PTCCOD <> this.PTCCOD
    Local Char WERR(250)
    If func PTCCOD_IS_USED_WITH_PARCOD_AND_CATCOD(this.snapshot.PTCCOD, this.CATCOD, this.PARCOD, WERR) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("PTCCOD", WERR, [V]CST_AERROR)
    Endif
  Endif
Return

#####################################################################

#********************************************************************
# Method EPRD_ADELLINE_BEFORE
#********************************************************************
#*
#*!
$EPRD_ADELLINE_BEFORE
  Local Integer WPOS
  Local Char WERR(250)
  WPOS = fmet this.AGETINDBYLINE('EPRD',ALINE)
  If func CATCOD_IS_USED_WITH_PARCOD(this.EPRD(WPOS).PARCOD, this.EPRD(WPOS).CATCOD) = [V]CST_ATRUE
    WERR = mess(9,123,1) #modification impossible mess(54,123,1) #suppression impossible
    ASTATUS = fmet this.ASETERROR("CATACT", WERR, [V]CST_AERROR)
  Endif
Return


#********************************************************************
# Method EPRD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EPRD_ADDLINE_AFTER
  #on ajoute une ligne

  this.NUMLIN    = 1 + max(this.APARENT.EPRD(1..maxtab(this.APARENT.EPRD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EPRD)
    If this.APARENT.EPRD(I) <> null
      If this.APARENT.EPRD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EPRD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EPRD(AFT_LINE).SORT
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPRD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPRD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EPRD)
        If this.APARENT.EPRD(I) <> null
          OFFSET_LINE = this.APARENT.EPRD(I).AORDER - this.AORDER
#          If this.APARENT.EPRD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EPRD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPRD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPRD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return


#********************************************************************
# Method ADELETE_CONTROL_BEFORE
#********************************************************************
#*
#*!
$ADELETE_CONTROL_BEFORE
  Local Integer I
  Local Char WERR(250)
  For I = 1 To maxtab(this.EPRD)
    If func CATCOD_IS_USED_WITH_PARCOD(this.EPRD(I).PARCOD, this.EPRD(I).CATCOD) = [V]CST_ATRUE
      WERR = mess(54,123,1) #suppression impossible mess(9,123,1) #modification impossible
      ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
      Break
    Endif
  Next
Return

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
  ASTATUS = [V]CST_AOK
  Local Integer I, J
  If maxtab(this.EPRD) > 1
    For I = 1 To maxtab(this.EPRD)-1
      For J = I+1 To maxtab(this.EPRD)
        If this.EPRD(I).CATTYP = this.EPRD(J).CATTYP
&         and this.EPRD(I).CATOPE = this.EPRD(J).CATOPE
&         and this.EPRD(I).ASTALIN <> [V]CST_ADEL
&         and this.EPRD(I).ASTALIN <> [V]CST_ANEWDEL
&         and this.EPRD(J).ASTALIN <> [V]CST_ADEL
&         and this.EPRD(J).ASTALIN <> [V]CST_ANEWDEL
          ASTATUS = fmet this.EPRD(J).ASETERROR("CATCOD", mess(119,2006,1), [V]CST_AERROR)
          Break 2
        Endif
      Next
    Next
  Endif
  ARET_VALUE = ASTATUS
Return



#********************************************************************
# Funprog CATCOD_IS_USED_WITH_PARCOD
#********************************************************************
#
#* test if the PARCOD+CATCOD is used in a setup function
#*
#* @param WPARCOD
#* @param WCATCOD
#* @param WERRTAB
#* @return WOK
#*!
Funprog CATCOD_IS_USED_WITH_PARCOD(WPARCOD, WCATCOD)
Value Char WPARCOD
Value Char WCATCOD


  Local Integer WOK  : WOK = [V]CST_AFALSE
  WERR = ""

  Local File EDIFLO [EFL]
  Filter [EFL] Where CATCOD=WCATCOD and PARCOD=WPARCOD
  For [EFL]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EFL]

#  Local File EDIPARTNERD [EPRD]
#  Filter [EPRD] Where CATCOD=WCATCOD and PARCOD=WPARCOD
#  For [EPRD]
#    WOK = [V]CST_ATRUE
#    Break
#  Next
#  LogicClose File [EPRD]

#  Local File EDIBPRCPYD [EBCD]
#  Filter [EBCD] Where CATCOD=WCATCOD and PARCOD=WPARCOD
#  For [EBCD]
#    WOK = [V]CST_ATRUE
#    Break
#  Next
#  LogicClose File [EBCD]

  Local File EDIRUN [EDR]
  Filter [EDR] Where CATCOD=WCATCOD and PARCOD=WPARCOD
  For [EDR]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EDR]

End WOK


Funprog PTCCOD_IS_USED_WITH_PARCOD_AND_CATCOD(WPTCCOD, WCATCOD, WPARCOD, WERR)
Value Char WPTCCOD
Value Char WCATCOD
Value Char WPARCOD
Variable Char WERR

  Local Integer WOK  : WOK = [V]CST_AFALSE
  WERR = ""

  Local File EDIFLOD [EFLD]
  Local File EDIFLO [EFL]
  Filter [EFLD] Where PTCCOD=WPTCCOD and CATCOD=WCATCOD and PARCOD=WPARCOD
#  Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD; [EFLD]FLOCOD As [LIEN]
#&   Where [EFL]PTCCOD = WPTCCOD
#&   and [EFL]CATCOD = WCATCOD
#&   and [EFL]PARCOD = WPARCOD
  Link [EFL] With [EFLD]EFLD0 = [EFL]FLOCOD; [EFL]FLOCOD As [LIEN]
&   Where [EFL]PTCCOD = WPTCCOD
&   and [EFL]CATCOD = WCATCOD
&   and [EFL]PARCOD = WPARCOD
  For [LIEN]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EFL]
  LogicClose File [EFLD]

#  Local File EDIPARTNERD [EPRD]
#  Filter [EPRD] Where CATCOD=WCATCOD and PARCOD=WPARCOD
#  For [EPRD]
#    WOK = [V]CST_ATRUE
#    Break
#  Next
#  LogicClose File [EPRD]

#  Local File EDIBPRCPYD [EBCD]
#  Filter [EBCD] Where CATCOD=WCATCOD and PARCOD=WPARCOD
#  For [EBCD]
#    WOK = [V]CST_ATRUE
#    Break
#  Next
#  LogicClose File [EBCD]

#  Local File EDIRUN [EDR]
#  Filter [EDR] Where CATCOD=WCATCOD and PARCOD=WPARCOD
#  For [EDR]
#    WOK = [V]CST_ATRUE
#    Break
#  Next
#  LogicClose File [EDR]


  If WOK = [V]CST_ATRUE
    WERR = mess(9,123,1)
  Else
    WERR = ""
  Endif


End WOK

###################################################################

Funprog PARCOD_IS_USED(WPARCOD)
Value Char WPARCOD

  Local Integer WOK  : WOK = [V]CST_AFALSE
  WERR = ""

  Local File EDICPYPAR [ECP]
  Filter [ECP] Where PARCOD=WPARCOD
  For [ECP]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [ECP]

  Local File EDIFCYPAR [EFP]
  Filter [EFP] Where PARCOD=WPARCOD
  For [EFP]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EFP]

  Local File EDIBPRPAR [EBP]
  Filter [EBP] Where PARCOD=WPARCOD
  For [EBP]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EBP]

  Local File EDIBPRCPYD [EBCD]
  Filter [EBCD] Where PARCOD=WPARCOD
  For [EBCD]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EBCD]

  Local File EDIRUN [EDR]
  Filter [EDR] Where PARCOD=WPARCOD
  For [EDR]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EDR]

End WOK

