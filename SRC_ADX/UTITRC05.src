#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UTITRC05   Utility for upgrade for SAM 106867                            #
# ------------------------------------------------------------------------ #
# Problem to be solved :                                                   #
#   Intialize the SST setting for a company.                               #
#   Fields moved from LTAPAR to COMPANY                                    #
############################################################################

#Call MAJ_UTITRC05
#End
#Subprog MAJ_UTITRC05(DOSSIER)
#Value Char  DOSSIER
#Call OUVRE_TRACE("UTITRC05 : Utility for updating SST copmany settings.") From LECFIC
#If DOSSIER<>"" Call EXE_UTITRC05(DOSSIER) : Endif
#Call FERME_TRACE From LECFIC
#Call LEC_TRACE   From LECFIC
#End

Local Char DOSSIER(30) : DOSSIER = nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITRC05 : Utility for updating SST company settings.") From LECFIC

  Call MAJ_UTITRC05(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRC05(DOSSIER)
Value Char  DOSSIER

#----- Variables locales -----#
Local Char    WCPY(5)
Local Integer I

#-----
Call ECR_TRACE("UTITRC1 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Verify LTA active -----#
#gbn-111099-Change the abreviation of the ACTIVE table to avoid conflict with the class opened by the supervisor
If !clalev([F:ACVX]) : Local File =DOSSIER+".ACTIV"    [ACVX] : Endif
Read [ACVX]CODACT="LTA"
If fstat | [F:ACVX]FLACT<>2
 Call ECR_TRACE("UTITRC05 : LTA disable Process End on : "+DOSSIER,0) From GESECRAN
 Close Local File [ACVX]
 End
Endif

#----- Ouverture des fichiers -----#
If !clalev([F:CPY]) : Local File =DOSSIER+".COMPANY"  [CPY] : Endif
If !clalev([F:LTP]) : Local File =DOSSIER+".LTAPAR"   [LTP] : Endif

Read [LTP]LTP0=DOSSIER
If fstat
  Call ECR_TRACE("UTITRC05 : SST not setup for any company on : "+DOSSIER,0) From GESECRAN
  Close Local File [CPY],[LTP],[ACVX]
  End
Endif

Call DEBTRANS From GLOCK

Trbegin [CPY]

For I=0 To dim([F:LTP]CPY)-1 #109831.n
  If [F:LTP]CPY(I)<>"" #109831.n
    Read [CPY]CPY0=[F:LTP]CPY(I)
    If fstat : Goto NEXTCPY : Endif

    WCPY=[F:CPY]CPY

    Readlock [CPY] Curr
    If fstat
      Call ECR_TRACE("File COMPANY"-WCPY+", Error ="-num$(fstat),1) From GESECRAN
      GOK=0
      Break
    Else
      [F:CPY]SSTCPY     = [F:LTP]SSTCPY(I)
      [F:CPY]SSTTAXACT  = 2
      Rewrite [CPY]
      If fstat
        Call ECR_TRACE("File COMPANY"-WCPY+", Error ="-num$(fstat),1) From GESECRAN
        GOK=0
        Break
      Else
        Call ECR_TRACE(WCPY-"Updated SST Company info and set to active",0) From GESECRAN
      Endif
    Endif
  Endif
$NEXTCPY
Next I

If GOK=0
  Rollback
  Call ECR_TRACE("----- Transaction abandoned ("+WCPY+")",1) From GESECRAN
Else
  Commit
  Call ECR_TRACE("----- SST Company updates transaction complete",0) From GESECRAN
Endif

Close Local File [ACVX], [CPY], [LTP]

End

#109833.sn
########################################################################
# Autorun Patch Management                                             #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
If [F:ADS]MODULE(4)<>2 : End : Endif #Check sales module
If filinfo(filpath("FIL","LTAPAR","fde",APPLI),0)<=0 : End : Endif
# Issue 108760 - 2015-08-07 by MAE :
If func DOSVUE.ISVIEW(APPLI,"LTAPAR") : End : Endif
Call MAJ_UTITRC05(APPLI)
End

########################################################################
# For Execution since DOSMAJ (folder validation)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If [F:ADS]MODULE(4)<>2 : End : Endif #Check sales module
If filinfo(filpath("FIL","LTAPAR","fde",APPLI),0)<=0 : End : Endif
# Issue 108760 - 2015-08-07 by MAE :
If func DOSVUE.ISVIEW(APPLI,"LTAPAR") : End : Endif
Call MAJ_UTITRC05(APPLI)
End
#109833.en

