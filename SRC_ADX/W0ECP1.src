#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CRY
mkstat = 0
zoncou = "CRY"
indice = 0
If varinit([M]CRY,indice)=0
 [M]CRY = GPAYS
Endif

## Zone ADD1
mkstat = 0
zoncou = "ADD1"
indice = 0
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADD1 : Endif

## Zone ADD2
mkstat = 0
zoncou = "ADD2"
indice = 0
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADD2 : Endif

## Zone ADD3
mkstat = 0
zoncou = "ADD3"
indice = 0
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADD3 : Endif

## Zone CODPOS
mkstat = 0
zoncou = "CODPOS"
indice = 0
WCHAR = [M]CODPOS
SAVACT = GACTION : GACTION = "FMTPOSPAY"
Call FMTPOSPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CODPOS : Endif

## Zone CTY
mkstat = 0
zoncou = "CTY"
indice = 0
WCHAR = [M]CTY
SAVACT = GACTION : GACTION = "FMTCTYPAY"
Call FMTCTYPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CTY : Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TEL
mkstat = 0
zoncou = "TEL"
indice = 0
WCHAR = [M]TEL
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]TEL : Endif

## Zone FLGTEL
mkstat = 0
zoncou = "FLGTEL"
indice = 0
IMPENT = [M]FLGTEL
If varinit([M]FLGTEL,indice)=0
 IMPENT = 1
Endif
[M]FLGTEL = IMPENT

## Zone MOB
mkstat = 0
zoncou = "MOB"
indice = 0
WCHAR = [M]MOB
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]MOB : Endif

## Zone FAX
mkstat = 0
zoncou = "FAX"
indice = 0
WCHAR = [M]FAX
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]FAX : Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone SITFAMOLD
mkstat = 0
zoncou = "SITFAMOLD"
indice = 0
IMPENT = [M]SITFAMOLD
If varinit([M]SITFAMOLD,indice)=0
 IMPENT = 1
Endif
[M]SITFAMOLD = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone NUMSSC
mkstat = 0
zoncou = "NUMSSC"
indice = 0
SAVACT = GACTION : GACTION = "LECPAY"
Call LECPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]NUMSSC : Endif

## Zone NTT
mkstat = 0
zoncou = "NTT"
indice = 0
If varinit([M]NTT,indice)=0
 [M]NTT = GPAYS
Endif

## Zone CRYBRN
mkstat = 0
zoncou = "CRYBRN"
indice = 0
If varinit([M]CRYBRN,indice)=0
 [M]CRYBRN = GPAYS
Endif

## Zone SEX
mkstat = 0
zoncou = "SEX"
indice = 0
IMPENT = [M]SEX
If varinit([M]SEX,indice)=0
 IMPENT = 1
Endif
[M]SEX = IMPENT

## Zone NUMSSCCTR
mkstat = 0
zoncou = "NUMSSCCTR"
indice = 0
SAVACT = GACTION : GACTION = "LECPAY"
Call LECPAY(func TRTDIV.LECPAYSIT([M:ECP0]FCY)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]NUMSSCCTR : Endif

## Zone NUMSSCCTR2
mkstat = 0
zoncou = "NUMSSCCTR2"
indice = 0
SAVACT = GACTION : GACTION = "LECPAY"
Call LECPAY(func TRTDIV.LECPAYSIT([M:ECP0]FCY)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]NUMSSCCTR2 : Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP1"
Return

