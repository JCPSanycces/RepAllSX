# < DEBUG> #################################################################################### #
End
# </DEBUG> #################################################################################### #




#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE"    : Gosub OUVRE                 # Basic initialization.
        When Default    : Gosub ACTION From BIDLOCDE
    Endcase
Return



#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Handler before opening a window.
#*             Opens some needed tables and initializes some variables for further use.
#*
#*! #####################################################################################

$OUVRE
    Gosub OUVRE From BIDLOCDE
    [L]LENBANCOD = 5                                  # Reset size of bank sort code.
    [L]LENBANACC = 11                                 # Reset size of bank account number.
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ##########                                                                                    #
# ##########                                                                                    #
# ############################################################################################# #


# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank account number                                      #
# ########## Does:  - Checks that the bank account number is numeric                            #
# ##########        - Fills the bank account number with leading zeroes.                        #
# ##########        - Recalculates the IBAN.                                                    #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANACC(VALEUR)
Variable Char VALEUR()

    Call C_BANACC( VALEUR ) From BIDLOCDE
End

Subprog AM_BANACC( VALEUR )
Variable Char VALEUR()

    Call AM_BANACC( VALEUR ) From BIDLOCDE
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank sort code                                           #
# ########## Does:  - Checks that the bank sort code is numeric                                 #
# ##########        - Fills the bank sort code with leading zeroes.                             #
# ##########        - Checks if the bank sort code is valid (if bank control is activated)      #
# ##########        - Fills in bank and IBAN.                                                   #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANCOD( VALEUR )
Variable Char VALEUR()

    Call C_BANCOD( VALEUR ) From BIDLOCDE
End

Subprog AM_BANCOD( VALEUR )
Variable Char VALEUR()

    Call AM_BANCOD( VALEUR ) From BIDLOCDE
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the IBAN                                                     #
# ########## Does:  Checks the validity of the IBAN and restores bank sort code and bank        #
# ##########        account number.                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_IBACOD( VALEUR )
Variable Char VALEUR()

    Call C_IBACOD( VALEUR ) From BIDLOCDE
End

Subprog AM_IBACOD( VALEUR )
Variable Char VALEUR()

    Call AM_IBACOD( VALEUR ) From BIDLOCDE
End
