#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
    When "DEBUT"       : Gosub DEBUT
Endcase
Return

$DEBUT
Local Integer I,NOL

If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif

Raz [M:ITFE]
Transmask [M:ITF0] To [M:ITFE] # Issue 25606_Transmask [M:ITFE]=[M:ITF0]
[M:ITFE]OWNER=[M:ITF0]STOFCY

Raz I,NOL
For [STO]STO3 Where ITMREF=[M:ITFE]ITMREF & STOFCY<>[M:ITFE]OWNER &
&                   OWNER =[M:ITFE]OWNER
   I = find([F:STO]STOFCY,[M:ITFE]STOFCY(0..[M:ITFE]NBLIG-1))
   If I=0
      NOL = [M:ITFE]NBLIG
      [M:ITFE]STOFCY(NOL) = [F:STO]STOFCY

      #If [F:FCY1]FCY<>[F:STO]OWNER
      #   Read [FCY1]FCY0=[F:STO]OWNER
      #   If fstat
      #      If [F:BPS]BPSNUM<>[F:STO]OWNER
      #         Read [BPS]BPS0=[F:STO]OWNER
      #         If !fstat
      #            [M:ITFS]OWNNAM(NOL)=[F:BPS]BPSNAM
      #         Endif
      #      Else
      #         [M:ITFS]OWNNAM(NOL)=[F:BPS]BPSNAM
      #      Endif
      #   Else
      #      [M:ITFS]OWNNAM(NOL)=[F:FCY1]FCYNAM
      #   Endif
      #Else
      #   [M:ITFS]OWNNAM(NOL)=[F:FCY1]FCYNAM
      #Endif

      [M:ITFE]QTYSTUACT(NOL)  = [F:STO]QTYSTUACT
      [M:ITFE]NBLIG += 1
   Else
      NOL = I-1
      [M:ITFE]QTYSTUACT(NOL) += [F:STO]QTYSTUACT
   Endif
   [M:ITFE]QTY += [F:STO]QTYSTUACT
Next

Affzo [M:ITFE]1-99

Return

