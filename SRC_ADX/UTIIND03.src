#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################################
# UTIIND03   Moulinette Indus.                                                                 #
# - Suppression chapitres et menus locaux non définis dans AMENLOC                             #
################################################################################################
# Pour exécution par F5 depuis l'éditeur.
# L'exécution depuis le dossier racine, traite tous les dossiers de la solution.
# Dans les autres dossiers, la moulinette traite le dossier courant.
################################################################################################
  Local Integer OK
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Moulinette UTIIND03") From LECFIC
  If nomap<>GDOSX3
    Call MAJ_UTIIND03(nomap)
  Else
    Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
    If OK<>2 : End : Endif
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    For [ADS]
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        Call MAJ_UTIIND03([F:ADS]DOSSIER)
      Endif
    Next
  Endif
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

################################################################################################
# Moulinette proprement dite
################################################################################################
Subprog MAJ_UTIIND03(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR
  Local Integer WCHP
  
  Call ECR_TRACE("UTIIND03 : Process Start on : "+DOSSIER,0) From GESECRAN

  Local File =DOSSIER+".APLSTD"      [AST]
  Local File =DOSSIER+".AMENLOC"     [AML]

  Trbegin [AST]
    For [AST]CLE(1)
      If !find([F:AST]LANCHP,0,200) :  # ne pas supprimer les chapitres 0 et 200 (intitulés des menus locaux)
        WCHP = [F:AST]LANCHP
        Look [AML]MENLOC = WCHP
        If fstat
          Delete [AST] Where LANCHP=WCHP
          COMPTEUR += adxdlrec
        Endif
      Endif
    Next
  Commit

  Close Local File [AST], [AML]

  Call ECR_TRACE("UTIIND03 : "+num$(COMPTEUR)+" rows deleted",0) From GESECRAN

End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  Call MAJ_UTIIND03(APPLI)
End

#######################################################################
# Pour exécution depuis DOSMAJ (validation dossier)
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  Call MAJ_UTIIND03(APPLI)
End
