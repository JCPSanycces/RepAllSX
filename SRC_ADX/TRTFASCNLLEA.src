########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - MDJ - 09.08.2010 - Fq 64312 - Détachement du contrat de location lors de la suppression du bien
########################################################################################################################

#----------------------------------------
# CHARGEMENT DU CONTRAT DE LOCATION
#----------------------------------------
$LOAD_LEA

  Read [LEA]LEA0=[M:FAS2]LEAREF
  If fstat=0 
     LLOCK = func GLOBIENS.GET_KEY_LEASE ([F:LEA]LEAREF)
     If func GLOBIENS.LOCK_SYMBOLE ("LEA", [M:FAS0]CPY, LLOCK, 0) = 0 Then
        # l'enregistrement est locké ailleurs : on ne peut pas le choisir
        [M:FC0]LOCKED= G_OUI
        [M:FC0]ICOLOCK = "190"
     Else
        [M:FC0]LOCKED = G_NON
        [M:FC0]ICOLOCK = ""
     Endif
     [M:FC0]=[F:LEA]
     #> Par défaut le contrat est détaché
  Endif   
 Affzo [M:FC0]
 
Return
#
