#********************************************************************
# Funprog GET_PROTOPATH
#********************************************************************
#
#*
#* @param WPROPERTY
#* @param WREPCOD
#* @return WPROTOPATH
#*!
Funprog GET_PROTOPATH(WPROPERTY, WREPCOD)
Value Char WPROPERTY
Value Char WREPCOD

  Local Char WPROTOPATH(250)
  Local Char WPROPERTY_TAB(100)(1..)
  Local Char WPROTOPATH_TAB(100)(1..)
  Local Integer I, J

  If WPROPERTY <> "" and WREPCOD <> ""
    #split path into an array
    Local Integer WFOUND   : WFOUND   = [V]CST_AFALSE
    Local Integer WFOUND_I : WFOUND_I = 0
    J = 0
    For I = 1 To len(WPROPERTY)
      If mid$(WPROPERTY, I, 1) = "+" and WFOUND = [V]CST_AFALSE
        J = J + 1
        WPROPERTY_TAB(J) = left$(WPROPERTY, I-1)
        WFOUND = [V]CST_ATRUE
        WFOUND_I = I
      Elsif mid$(WPROPERTY, I, 1) = "+" and WFOUND = [V]CST_ATRUE
        J = J + 1
        WPROPERTY_TAB(J) = mid$(WPROPERTY, WFOUND_I+1, I-WFOUND_I-1)
  #      WFOUND = [V]CST_ATRUE
        WFOUND_I = I
      Endif
    Next I
    If WFOUND = [V]CST_ATRUE
      J = J + 1
      WPROPERTY_TAB(J) = right$(WPROPERTY, WFOUND_I + 1)
    Else
      J = J + 1
      WPROPERTY_TAB(J) = WPROPERTY
    Endif
    #/split path into an array

    Local Integer WONERROR : WONERROR = [V]CST_AFALSE
    Local Char WALIAS(100)
    For I = 1 To maxtab(WPROPERTY_TAB())
      WALIAS = ""
      Local File ASHWEXPPRO [ASWR]
      Filter [ASWR] Where CODREP = WREPCOD
      For [ASWR]
        If [ASWR]CODPRO = WPROPERTY_TAB(I)
          WALIAS = [ASWR]ALIAS
          Break
        Endif
      Next
      LogicClose File [ASWR]
      If WALIAS <> ""
        WPROTOPATH_TAB(I) = func EDILIBC.GET_PROTOPATH(WALIAS, WPROPERTY, WREPCOD)
      Else
        WPROTOPATH_TAB(I) = ""
        WONERROR = [V]CST_ATRUE
      Endif

    Next I

    WPROTOPATH = ""
    If WONERROR = [V]CST_AFALSE
      For I = 1 To maxtab(WPROPERTY_TAB())-1
        WPROTOPATH = WPROTOPATH + WPROTOPATH_TAB(I) + "+"
      Next I
      WPROTOPATH = WPROTOPATH + WPROTOPATH_TAB(I)
    Endif
  Endif
End WPROTOPATH


#********************************************************************
# Funprog PROPERTY_IS_IN_REPRESENTATION
#********************************************************************
#
#*
#* @param WPROPERTY
#* @param WREPCOD
#* @return WOK true or false
#*!
Funprog PROPERTY_IS_IN_REPRESENTATION(WPROPERTY, WREPCOD)
Value Char WPROPERTY
Value Char WREPCOD

  Local Char WPROPERTY_TAB(100)(1..)
  Local Integer I, J
  Local Integer WOK : WOK = [V]CST_ATRUE

  If WPROPERTY <> "" and WREPCOD <> ""
    #split path into an array
    Local Integer WFOUND   : WFOUND   = [V]CST_AFALSE
    Local Integer WFOUND_I : WFOUND_I = 0
    J = 0
    For I = 1 To len(WPROPERTY)
      If mid$(WPROPERTY, I, 1) = "+" and WFOUND = [V]CST_AFALSE
        J = J + 1
        WPROPERTY_TAB(J) = left$(WPROPERTY, I-1)
        WFOUND = [V]CST_ATRUE
        WFOUND_I = I
      Elsif mid$(WPROPERTY, I, 1) = "+" and WFOUND = [V]CST_ATRUE
        J = J + 1
        WPROPERTY_TAB(J) = mid$(WPROPERTY, WFOUND_I+1, I-WFOUND_I-1)
  #      WFOUND = [V]CST_ATRUE
        WFOUND_I = I
      Endif
    Next I
    If WFOUND = [V]CST_ATRUE
      J = J + 1
      WPROPERTY_TAB(J) = right$(WPROPERTY, WFOUND_I + 1)
    Else
      J = J + 1
      WPROPERTY_TAB(J) = WPROPERTY
    Endif
    #/split path into an array

    For I = 1 To maxtab(WPROPERTY_TAB())
      Local File ASHWEXPPRO [ASWR]
      Read [ASWR]ASWR3 = WREPCOD;WPROPERTY_TAB(I)
      If fstat
        WOK = [V]CST_AFALSE
        Break
      Endif
      LogicClose File [ASWR]
    Next I

  Else
    #error
    WOK = [V]CST_AFALSE
  Endif

End WOK

