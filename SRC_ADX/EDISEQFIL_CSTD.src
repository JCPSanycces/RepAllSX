#*********************************************************************
# Method MET_VALIDATE
# Step 1 : Analyse lines
# Step 2 : Check End level of structure = 1
# Step 3 : Set Valid
#*********************************************************************
$MET_VALIDATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK        : WOK        = [V]CST_AOK
  Local Integer WNBERR     : WNBERR     = 0
  Local Integer I, J, K
  Local Char WERR(250)

  #generate proto path
  If this.MSGDIR=2
    For I = 1 To maxtab(this.ESFF)
      If this.ESFF(I)<>null and find(this.ESFF(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        this.ESFF(I).PROTOMAIN = func GET_PROTOPATH(this.ESFF(I).MAINFIELD, this.REPCOD)
        this.ESFF(I).PROTOLINK = func GET_PROTOPATH(this.ESFF(I).LINKFIELD, this.REPCOD)
      Endif
    Next I
  Endif

  If this.MSGDIR=2
    this.KEYPROTOPATH = func EDILIBC.GET_PROTOPATH(this.KEYALIAS, this.KEYPROPERTY, this.REPCOD)
  Endif

  For I = 1 To maxtab(this.ESFD)
    If this.ESFD(I)<>null and find(this.ESFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      this.ESFD(I).PROTOPATH = func EDILIBC.GET_PROTOPATH(this.ESFD(I).ALIAS, this.ESFD(I).EXPRESSION, this.REPCOD)
    Endif
  Next I
  #/generate proto path

  ######################### counts lines #########################

  #Counts nb Files lines
  Local Shortint WNBLINE_ESFF
  For I=1 To maxtab(this.ESFF)
    If this.ESFF(I)<>null and find(this.ESFF(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WNBLINE_ESFF = WNBLINE_ESFF + 1
    Endif
  Next I

  #Counts nb File names lines (for issue only)
  Local Shortint WNBLINE_ESFN
  For I=1 To maxtab(this.ESFN)
    If this.ESFN(I)<>null and find(this.ESFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WNBLINE_ESFN = WNBLINE_ESFN + 1
    Endif
  Next I

  #Counts nb Details lines
  Local Integer WPOS(1..)
  Local Integer WENDREG(1..)
  Local Char    WFILCOD(10)(1..)
  Local Integer WLEVEL(1..)
  Local Char    WFLGREC(20)(1..)
  Local Char    WCFLGREC(20)(1..)
  Local Integer WNBLINE_ESFD , WNBREC, WP

  WNBREC=1

  For I = 1 To maxtab(this.ESFD)
    If this.ESFD(I)<>null and find(this.ESFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WNBLINE_ESFD = WNBLINE_ESFD + 1
      WP=this.ESFD(I).NUMORDER
      WFILCOD(WP) = this.ESFD(I).FILCOD
      WFLGREC(WP) = this.ESFD(I).FLGREC
      WENDREG(WP) = this.ESFD(I).ENDREG
      WLEVEL(WP)    = this.ESFD(I).LEVEL
      WPOS(WP)      = WP
    Endif
  Next I

  ######################### TESTs #########################





 # 1/ tests on ESFF collection (Files block)
  If WNBLINE_ESFF = 0
    # Test 1-01 : At least one detail line must exist in the files block
    WNBERR = WNBERR + 1
    WRET_VALUE = [V]CST_AWARNING
    WERR = mess(63,2006,1) #No line defined
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
  Else
    For I = 1 To maxtab(this.ESFF)
      If this.ESFF(I)<>null and find(this.ESFF(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        If this.ESFF(I).MANDATORY = [V]CST_AYES and !find(this.ESFF(I).FILCOD,WFILCOD(1..WNBLINE_ESFD))
          # Test 1-02 : Mandatory Files have one line at least in ESFD
          WNBERR = WNBERR + 1
          WRET_VALUE = [V]CST_AWARNING
          WERR = mess(54,2006,1)-this.ESFF(I).FILNAM # Mandatory file without any property setup
          ASTATUS = fmet this.ESFF(I).ASETERROR("FILNAM",WERR,[V]CST_AWARNING)
#          Break
        Endif
        If this.MSGDIR = 2
          If this.ESFF(I).PARFILE <> "" and this.ESFF(I).AORDER = 1
            # Test 1-03 : Parent code not allowed in first line
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(75,2006,1) #Parent code not allowed in first line
            ASTATUS = fmet this.ESFF(I).ASETERROR("PARFILE",WERR,[V]CST_AWARNING)
            Break
          Elsif this.ESFF(I).PARFILE = "" and this.ESFF(I).AORDER <> 1
            # Test 1-04 : Parent code mandatory on all lines except 1st one
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(73,2006,1) #Parent code mandatory in this line
            ASTATUS = fmet this.ESFF(I).ASETERROR("PARFILE",WERR,[V]CST_AWARNING)
            Break
          Elsif this.ESFF(I).PARFILE = this.ESFF(I).FILCOD
            # Test 1-05 : Parent code must be different to File code
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(74,2006,1) #Parent code must be different to File code
            ASTATUS = fmet this.ESFF(I).ASETERROR("PARFILE",WERR,[V]CST_AWARNING)
            Break
          Endif
          If this.ESFF(I).AORDER <> 1
            Local Integer WFLG_FOUND_PARFILE : WFLG_FOUND_PARFILE = [V]CST_AFALSE
            For J = 1 To maxtab(this.ESFF)
              If this.ESFF(J)<>null and find(this.ESFF(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
                If this.ESFF(I).PARFILE = this.ESFF(J).FILCOD
                  WFLG_FOUND_PARFILE = [V]CST_ATRUE
                  Break
                Endif
              Endif
            Next J
            If WFLG_FOUND_PARFILE = [V]CST_AFALSE
              # Test 1-06 : Parent code does not match any file code
              WNBERR = WNBERR + 1
              WRET_VALUE = [V]CST_AWARNING
              WERR = mess(72,2006,1) #Parent code does not match any file code
              ASTATUS = fmet this.ESFF(I).ASETERROR("PARFILE",WERR,[V]CST_AWARNING)
              Break
            Elsif this.ESFF(I).AORDER < this.ESFF(J).AORDER
              # Test 1-07 : Parent code does not match any file code
              WNBERR = WNBERR + 1
              WRET_VALUE = [V]CST_AWARNING
              WERR = mess(72,2006,1) #Parent code does not match any file code
              ASTATUS = fmet this.ESFF(I).ASETERROR("PARFILE",WERR,[V]CST_AWARNING)
              Break
            Endif
          Endif
        Endif
      Endif
    Next I
  Endif

  # 2/ tests on ESFN collection (File name definition block)
  If this.MSGDIR = 1
    If WNBLINE_ESFN = 0
      # Test 2-01 : At least one detail line must exist in the file name definition block
      WNBERR = WNBERR + 1
      WRET_VALUE = [V]CST_AWARNING
      WERR = mess(121,2006,1) #Au moins un composant doit être indiqué dans la définition du nom de fichier"Components must be set in file name definition "#mess(26,2006,1) #File name is mandatory
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
    Else
      Local Integer WNBKEY   : WNBKEY   = 0
      Local Integer WFLG_FOUND_FILENAME : WFLG_FOUND_FILENAME = [V]CST_AFALSE
      this.FLGMUX = [V]CST_AYES
      For I = 1 To maxtab(this.ESFN)
        If this.ESFN(I)<>null and find(this.ESFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          Case this.ESFN(I).COMTYP
            When 1: WFLG_FOUND_FILENAME = [V]CST_ATRUE #File name
            When 2: WNBKEY = WNBKEY + 1: this.FLGMUX=[V]CST_ANO #main key
            When 3: WNBKEY = WNBKEY + 1 #merge key
            When 4: #date
            When 5: #heure
            When 6: If this.ESFN(I).AORDER = WNBLINE_ESFN
                      # Test 2-02 : Constant component cannot be in the last position
                      WNBERR = WNBERR + 1
                      WRET_VALUE = [V]CST_AWARNING
                      WERR = mess(16,2006,1) #Constant component cannot be in the last position
                      ASTATUS = fmet this.ESFN(I).ASETERROR("COMTYP",WERR,[V]CST_AWARNING)
                      Break
                    Endif #constant
            When 7: #batch number
            When 8: If this.ESFN(I).AORDER < WNBLINE_ESFN
                      # Test 2-03 : Extension must be the last component
                      WNBERR = WNBERR + 1
                      WRET_VALUE = [V]CST_AWARNING
                      WERR = mess(23,2006,1) #Extension must be the last component
                      ASTATUS = fmet this.ESFN(I).ASETERROR("COMTYP",WERR,[V]CST_AWARNING)
                      Break
                    Endif #extension
          Endcase
        Endif
      Next I
      If WFLG_FOUND_FILENAME = [V]CST_AFALSE
        If WNBLINE_ESFN > 1
#          # Test 2-04 : #File name is mandatory
#          WNBERR = WNBERR + 1
#          WRET_VALUE = [V]CST_AWARNING
#          WERR = mess(26,2006,1) #File name component is mandatory in file name definition
#          ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
        Else
          If WNBLINE_ESFN = 1 and WNBKEY = 0
            # Test 2-05 : Key or Merge key is mandatory if file name is not set
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(55,2006,1) #Key or Merge key is mandatory if file name is not set
            ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
          Endif
        Endif
#      Else
        If WNBLINE_ESFF <> 1
                  # Test 2-04 : #File name is mandatory
          WNBERR = WNBERR + 1
          WRET_VALUE = [V]CST_AWARNING
          WERR = mess(26,2006,1) #File name component is mandatory in file name definition
          ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
        Endif
      Endif
    Endif
  Endif

  # 3/ tests on ESFD collection (Detail block)
  If WNBLINE_ESFD = 0
    # Test 3-01 : At least one detail line must exist in the detail lines block
    WNBERR = WNBERR + 1
    WRET_VALUE = [V]CST_AWARNING
    WERR = mess(63,2006,1) #No line defined
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
  Else
    For I = 1 To WNBLINE_ESFD
      If WPOS(I)= 0: WPOS(I)=I: Endif
      If I = WNBLINE_ESFD
        If I = 1 #only 1 line, must be flagged
          If WENDREG(I) <> [V]CST_AYES
            # Test 3-03 : # unique line must be flagged "End of record"
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(103,2006,1)
            ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("ENDREG",WERR,[V]CST_AWARNING)
          Endif
        Else #last line
          If WENDREG(I) <> [V]CST_AYES
             # Test 3-02 : # Last line must be flagged "End of record"
            WNBERR = WNBERR + 1
            WRET_VALUE = [V]CST_AWARNING
            WERR = mess(103,2006,1)
            ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("ENDREG",WERR,[V]CST_AWARNING)
          Endif
        Endif
      Endif

      If WNBLINE_ESFD > 1
        If I=1: WCFLGREC(WNBREC)=WFLGREC(I): Endif
        If I < WNBLINE_ESFD
          If WENDREG(I) <> [V]CST_AYES
            If WFILCOD(I) <> WFILCOD(I+1)
              # Test 3-03 : # Last line of same FILCOD section must be flagged "End of record"
              WNBERR = WNBERR + 1
              WRET_VALUE = [V]CST_AWARNING
              WERR = mess(103,2006,1)
              ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("ENDREG",WERR,[V]CST_AWARNING)
            Endif
          Else
            If this.MSGDIR=2 and I>1
              If WFLGREC(I) = WFLGREC(I-1) and WENDREG(I-1)=[V]CST_AYES
                WERR = mess(122,2006,1) #"End of record exists in previous line"
                ASTATUS = fmet this.ESFD(I).ASETERROR("FLGREC",WERR,[V]CST_AWARNING)
              Endif
            Endif
          Endif
        Endif
        If I>1
          If WFLGREC(I) <> WFLGREC(I-1) and WENDREG(I-1)=[V]CST_AYES
            WNBREC+=1
            If find(WFLGREC(I),WCFLGREC(1..WNBREC))=0
              WCFLGREC(WNBREC)=WFLGREC(I)
            Else
              WCFLGREC(WNBREC)="WNOK"
            Endif
          Endif
          If this.MSGDIR=2
            If WFLGREC(I)=WFLGREC(I-1) and WENDREG(I-1)= [V]CST_AYES and WFILCOD(I)=WFILCOD(I-1) or WCFLGREC(WNBREC)="WNOK"
              WNBERR = WNBERR + 1
              WRET_VALUE = [V]CST_AERROR
              WERR = mess(123,2006,1) #"Value is already used in other record"
              ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("FLGREC",WERR,[V]CST_AERROR)
              Break
            Elsif WFLGREC(I) <> WFLGREC(I-1) and WENDREG(I-1)<>[V]CST_AYES
#            WNBERR = WNBERR + 1
 #           WRET_VALUE = [V]CST_AWARNING
              If find(WFLGREC(I),WCFLGREC(1..WNBREC))<>0 and find(2,WENDREG(1..I-1))<>0
                WNBERR = WNBERR + 1
                WRET_VALUE = [V]CST_AERROR
                WERR = mess(123,2006,1) #"Value is already used in other record"
                ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("FLGREC",WERR,[V]CST_AERROR)
              Else
                WERR = "Value is different of the previous line value"
                ASTATUS = fmet this.ESFD(WPOS(I)).ASETERROR("FLGREC",WERR,[V]CST_AWARNING)
              Endif
            Endif
          Endif
        Endif
      Endif

    Next I
  Endif


  #4
  If this.MSGDIR=2
    For I = 1 To maxtab(this.ESFF)
      If this.ESFF(I)<>null and find(this.ESFF(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        If this.ESFF(I).PROTOMAIN = ""
          WRET_VALUE = [V]CST_AWARNING
          Break
        Endif

        If this.ESFF(I).PROTOLINK = "" and this.ESFF(I).PARFILE <> ""
          WRET_VALUE = [V]CST_AWARNING
          Break
        Endif
      Endif
    Next I
  Endif

  #5
  If this.MSGDIR=2
    If this.KEYPROTOPATH = ""
      WRET_VALUE = [V]CST_AWARNING
    Endif
  Endif


  ######################### Validating or unvalidating seq file and flow #########################

  If WRET_VALUE <> [V]CST_AOK #0
    #the seq fil is no valid
    this.VALID = [V]CST_ANO
    WRET_VALUE = [V]CST_AFALSE
    #if the seq file begins not valid, all linked flows mustn't be valid and activated
    #unvalidate and unactivate all flows activated and/or validated using this EDISEQFIL
    Local File EDIFLO [EFL]
    Local File EDIFLOD [EFLD]
    Filter [EFLD] Where [EFLD]MSGCOD = this.MSGCOD and [EFLD]MSGREL = this.MSGREL and [EFLD]MSGFILNOR = this.MSGFILNOR
    For [EFLD]
      Read [EFL]EFL0 = [EFLD]FLOCOD; [EFLD]FLOREL
      If !fstat
        Trbegin [EFL]
        [EFL]CACHEUUID = NullUuid()
        [EFL]VALID     = [V]CST_ANO
        [EFL]FLGACT    = [V]CST_ANO
        Rewrite [EFL]
        If !fstat
          Commit
          WERR = "("+[EFLD]FLOCOD+"~"+[EFLD]FLOREL+")"-mess(28,2006,1)  #Flow has been invalidated and deactivated
          ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
        Else
          Rollback
        Endif
      Endif
    Next
    LogicClose File [EFLD]
    LogicClose File [EFL]
  Else
    # Set Valid
    this.VALID = [V]CST_AYES
    WRET_VALUE = [V]CST_ATRUE
  Endif
  ARET_VALUE = WRET_VALUE
Return

