###############################################################################
# Data Class EDISEQFIL                                                        #
# Manages main class EDISEQFIL (this)                                         #
# Author : CJ + RBA + JUCON                                                   #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
      When "ADELETE_CONTROL_AFTER"  : Gosub ADELETE_CONTROL_AFTER
    Endcase
  When "ESFF"
    Case [L]AEVENT
      When "ADELLINE_BEFORE"        : Gosub ESFF_ADELLINE_BEFORE
      When "ADELLINE_AFTER"         : Gosub ESFF_ADELLINE_AFTER
      When "ADDLINE_BEFORE"         : Gosub ESFF_ADDLINE_BEFORE
      When "ADDLINE_AFTER"          : Gosub ESFF_ADDLINE_AFTER
    Endcase
  When "ESFN"
    Case [L]AEVENT
      When "ADDLINE_BEFORE"         : Gosub ESFN_ADDLINE_BEFORE
    Endcase
  When "ESFD"
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub ESFD_AREAD_AFTER
      When "ADELLINE_AFTER"         : Gosub ESFD_ADELLINE_AFTER
      When "ADDLINE_BEFORE"         : Gosub ESFD_ADDLINE_BEFORE
      When "ADDLINE_AFTER"          : Gosub ESFD_ADDLINE_AFTER
    Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_POST_JSON"          : Gosub MET_POST_JSON
    When "MET_PUT_JSON"           : Gosub MET_PUT_JSON
    When "MET_DEL_JSON"           : Gosub MET_DEL_JSON
    When "MET_VALIDATE"           : Gosub MET_VALIDATE
    When "MET_TEST"               : Gosub MET_TEST
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CACHEUUID"
      Case [L]ARULE
        When "INIT"      : Gosub CACHEUUID_INIT
      Endcase
    When "MSGCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGCOD_CONTROL
        When "PROPAGATE" : Gosub MSGCOD_PROPAGATE
      Endcase
    When "MSGREL"
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGREL_CONTROL
        When "PROPAGATE" : Gosub MSGREL_PROPAGATE
      Endcase
    When "MSGFOR"
      Case [L]ARULE
        When 'INIT'       : Gosub MSGFOR_INIT
        When 'CONTROL'    : Gosub MSGFOR_CONTROL
        When 'PROPAGATE'  : Gosub MSGFOR_PROPAGATE
      Endcase
    When "MSGFILNOR"
      Case [L]ARULE
        When "PROPAGATE" : Gosub MSGFILNOR_PROPAGATE
      Endcase
    When "TYPFIL"
      Case [L]ARULE
        When 'INIT'         : Gosub TYPFIL_INIT
        When 'PROPAGATE'    : Gosub TYPFIL_PROPAGATE
      Endcase
    When "OPTDAT"
      Case [L]ARULE
        When "INIT"     : Gosub OPTDAT_INIT
        When "CONTROL"  : Gosub OPTDAT_CONTROL
      Endcase
    When "FLGMUX"
      Case [L]ARULE
        When "INIT"      : Gosub FLGMUX_INIT
      Endcase
    When "SEPDEC"
      Case [L]ARULE
        When "INIT"        : Gosub SEPDEC_INIT
        When "PROPAGATE"   : Gosub SEPDEC_PROPAGATE
      Endcase
  #  When "REPCOD"
    When "KEYALIAS"
      Case [L]ARULE
        When "CONTROL"     : Gosub KEYALIAS_CONTROL
        When "PROPAGATE"   : Gosub KEYALIAS_PROPAGATE
      Endcase
    When "KEYPROPERTY"
      Case [L]ARULE
        When "CONTROL"   : Gosub KEYPROPERTY_CONTROL
        When "PROPAGATE" : Gosub KEYPROPERTY_PROPAGATE
      Endcase
    When "ESFF.MANDATORY"
      Case [L]ARULE
        When "INIT"      : Gosub ESFF_MANDATORY_INIT
        When "CONTROL"   : Gosub ESFF_MANDATORY_CONTROL
      Endcase
    When "ESFF.FILNAM"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFF_FILNAM_CONTROL
      Endcase
    When "ESFF.FILCOD"
      Case [L]ARULE
        When "CONTROL"  : Gosub ESFF_FILCOD_CONTROL
        When "PROPAGATE": Gosub ESFF_FILCOD_PROPAGATE
      Endcase
    When "ESFF.MAINFIELD"
      Case [L]ARULE
        When "CONTROL"    : Gosub ESFF_MAINFIELD_CONTROL
        When "PROPAGATE"  : Gosub ESFF_MAINFIELD_PROPAGATE
      Endcase
    When "ESFF.LINKFIELD"
      Case [L]ARULE
        When "CONTROL"    : Gosub ESFF_LINKFIELD_CONTROL
        When "PROPAGATE"  : Gosub ESFF_LINKFIELD_PROPAGATE
      Endcase
    When "ESFF.PARFILE"
      Case [L]ARULE
        When "CONTROL"  : Gosub ESFF_PARFILE_CONTROL
        When "PROPAGATE": Gosub ESFF_PARFILE_PROPAGATE
      Endcase
    When "ESFN.COMTYP"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFN_COMTYP_CONTROL
        When "PROPAGATE" : Gosub ESFN_COMTYP_PROPAGATE
      Endcase
    When "ESFN.COMVAL"
      Case [L]ARULE
        When "CONTROL"     : Gosub ESFN_COMVAL_CONTROL
        When "PROPAGATE"   : Gosub ESFN_COMVAL_PROPAGATE
      Endcase
    When "ESFD.FILCOD"
      Case [L]ARULE
        When "CONTROL"  : Gosub ESFD_FILCOD_CONTROL
        When "PROPAGATE": Gosub ESFD_FILCOD_PROPAGATE
      Endcase
    When "ESFD.FLGREC"
      Case [L]ARULE
        When "CONTROL"  : Gosub ESFD_FLGREC_CONTROL
      Endcase
    When "ESFD.LEVEL"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFD_LEVEL_CONTROL
        When "PROPAGATE" : Gosub ESFD_LEVEL_PROPAGATE
      Endcase
    When "ESFD.ALIAS"
      Case [L]ARULE
        When "CONTROL"  : Gosub ESFD_ALIAS_CONTROL
        When "PROPAGATE": Gosub ESFD_ALIAS_PROPAGATE
      Endcase
    When "ESFD.EXPRESSION"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFD_EXPRESSION_CONTROL
        When "PROPAGATE" : Gosub ESFD_EXPRESSION_PROPAGATE
      Endcase
    When "ESFD.ENDREG"
      Case [L]ARULE
        When "PROPAGATE": Gosub ESFD_ENDREG_PROPAGATE
      Endcase
    When "ESFD.MANDATORY"
      Case [L]ARULE
        When 'PROPAGATE' : Gosub ESFD_MANDATORY_PROPAGATE
      Endcase
    When "ESFD.LOC"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFD_LOC_CONTROL
        When "PROPAGATE" : Gosub ESFD_LOC_PROPAGATE
      Endcase
    When "ESFD.LNG"
      Case [L]ARULE
        When "CONTROL"   : Gosub ESFD_LNG_CONTROL
      Endcase
    When Default
  Endcase
Return


####################################################################
$MSGCOD_CONTROL
  If this.MSGCOD <> ""
    this.MSGCOD = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCOD)
  Endif
Return

$MSGCOD_PROPAGATE
  Local Integer WOK, I
  Local Char WERR(250)
  WERR = ""

  this.MSGFILNOR = ""
  this.MSGREL = ""

  If this.MSGCOD = ""
    Call DELETELINES(this, "ESFF") From EDILIBA
    Call DELETELINES(this, "ESFD") From EDILIBA
  Else
    #rechercher le sens dans la table
    Local File EDIMSG [EMS]
    Filter [EMS] Where MSGCOD = this.MSGCOD and VALID = [V]CST_AYES Order By Key EMS0 Asc #attention la clé est en caractere et non en chiffre donc le tri n'est pas correct
    Read [EMS]EMS0 First
    If fstat = [V]CST_AOK
      this.MSGREL = [F:EMS]MSGREL
      this.MSGDIR = [F:EMS]MSGDIR
      this.FILDES = [F:EMS]MSGDES
      this.REPCOD = [F:EMS]REPCOD
      this.ABRCLA = [F:EMS]ABRCLA
    Else
      this.MSGREL = ""
      this.MSGDIR = 1
      this.FILDES = ""
      this.REPCOD = ""
      this.ABRCLA = ""
      WERR = mess(126,143,1)
      ASTATUS = fmet this.ASETERROR("MSGCOD",WERR,[V]CST_AERROR)
    Endif
    LogicClose File [EMS]
  Endif

  this.VALID = [V]CST_ANO
Return


####################################################################
$MSGREL_CONTROL
  If this.MSGREL <> ""
    this.MSGREL = func EDILIBA.FORMATVAL("MSGREL", this.MSGREL)
  Endif
Return

$MSGREL_PROPAGATE
  Local Integer WOK
  Local Char WERR(250) : WERR = ""

  this.MSGFILNOR = ""

  If this.MSGREL = ""
    Call DELETELINES(this, "ESFF") From EDILIBA
    Call DELETELINES(this, "ESFD") From EDILIBA
  Else
    If this.MSGCOD <> "" and this.MSGREL <> ""
      Local File EDIMSG [EMS]
      Read [EMS]EMS0 = this.MSGCOD;this.MSGREL
      If !fstat
        If [EMS]VALID = [V]CST_AYES
          this.MSGDIR = [EMS]MSGDIR
          this.FILDES = [EMS]MSGDES
          this.REPCOD = [EMS]REPCOD
        Else
          this.REPCOD = ""
          WERR = mess(126,143,1)
          ASTATUS = fmet this.ASETERROR("MSGREL",WERR,[V]CST_AERROR)
        Endif
      Else
        this.REPCOD = ""
        WERR = mess(126,143,1)
        ASTATUS = fmet this.ASETERROR("MSGREL",WERR,[V]CST_AERROR)
      Endif
      LogicClose File [EMS]

    Endif
  Endif


  this.VALID = [V]CST_ANO
Return


####################################################################
$MSGFILNOR_PROPAGATE
  If this.MSGREL = ""
    Call DELETELINES(this, "ESFF") From EDILIBA
    Call DELETELINES(this, "ESFD") From EDILIBA
  Else
    If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
      Local File EDISEQFIL [ESF]
      Read [ESF]ESF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
      If !fstat
        ASTATUS = fmet this.ASETERROR("MSGREL",mess(45,7779,1)-":"-this.MSGCOD+"~"+this.MSGREL,[V]CST_AERROR)
      Else
        #
      Endif
      LogicClose File [ESF]
    Endif
  Endif
  this.VALID = [V]CST_ANO
Return



####################################################################
$CACHEUUID_INIT
  this.CACHEUUID = NullUuid()
Return


####################################################################
$MSGFOR_INIT
  this.MSGFOR = 1
Return

$MSGFOR_CONTROL
  If this.MSGFOR <> 1
    this.MSGFOR = 1
  Endif
Return

$MSGFOR_PROPAGATE
  this.VALID = [V]CST_ANO
Return


####################################################################
$TYPFIL_INIT
  this.TYPFIL = 3
Return

$TYPFIL_PROPAGATE
  Local Integer WOK
  Local Integer I
  Local Char WERR(250)
  this.FLDLIM = ""
  this.SEPREC = ""
  this.SEPFLD = ""
  this.SEPDEC = "."
  this.CODDBA = 1

  #we use only TYPFIL 3 or 4
  If this.TYPFIL < 3 or this.TYPFIL > 4
    WERR = mess(126,143,1) # invalid value
    ASTATUS = fmet this.ASETERROR("TYPFIL",WERR,[V]CST_AERROR)
  Else
    If this.TYPFIL = 3
      For I = 1 To maxtab(this.ESFD)
        this.ESFD(I).LOC = 0
        this.ESFD(I).LNG = 0
      Next I
#    Elsif this.FILTYP = 4
#      For I = 1 To maxtab(this.ESFD)
#
#      Next I
    Endif
  Endif
  this.VALID = [V]CST_ANO
Return

####################################################################
$OPTDAT_INIT
  this.OPTDAT = 4
  this.OPTMNL = 1
Return

$OPTDAT_CONTROL
  Local Char WERR(250)

  If this.OPTDAT < 1 or this.OPTDAT > 5
    WERR = mess(126,143,1) # invalid value
    ASTATUS = fmet this.ASETERROR("OPTDAT",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################
$SEPDEC_INIT
  this.SEPDEC = "."
Return

$SEPDEC_PROPAGATE
  If this.SEPDEC = ""
    this.SEPDEC = "."
  Endif
Return

####################################################################
#$REPCOD
#  Case ACTION
#    When "PROPAGATE"   : Gosub REPCOD_PROPAGATE
#  Endcase
#Return
#
#$REPCOD_PROPAGATE
#Return


####################################################################
$FLGMUX_INIT
  this.FLGMUX = [V]CST_AYES
Return

####################################################################
$KEYALIAS_CONTROL
  this.KEYALIAS=toupper(this.KEYALIAS)
  If this.MSGDIR = 2 #receipt
    #verifier que l'alias est présent dans le detail ESFD
    Local Integer I
    Local Integer WOK : WOK = [V]CST_AFALSE
    If this.KEYALIAS <> ""
      For I = 1 To maxtab(this.ESFD)
        If this.ESFD(I) <> null and this.ESFD(I).ASTALIN <> [V]CST_ADEL and this.ESFD(I).ASTALIN <> [V]CST_ANEWDEL
          If this.ESFD(I).ALIAS = this.KEYALIAS
            WOK = [V]CST_ATRUE
            Break
          Endif
        Endif
      Next
      If WOK = [V]CST_AFALSE
        ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00126,00143,1),[V]CST_AERROR)
      Endif
    Else
      ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00532,00177,1),[V]CST_AWARNING)
    Endif
  Else
    this.KEYALIAS = ""
  Endif
Return

$KEYALIAS_PROPAGATE
  Local Char WTXT(120)
  Local Char WLAN(3)

  If this.KEYALIAS <> ""
    If this.REPCOD <> ""
      Local File ASHWEXPPRO [ASWR]
      Read [ASWR]ASWR0 = this.REPCOD;this.KEYALIAS
      If !fstat
        this.KEYPROPERTY = [ASWR]CODPRO
        WLAN = this.ACTX.LAN
#        WLAN="ENG"
        ##Always propose the english text
        Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
        this.KEYDES = WTXT
        this.KEYPROTOPATH = func EDILIBC.GET_PROTOPATH(this.KEYALIAS, this.KEYPROPERTY, this.REPCOD)
      Else
        this.KEYPROPERTY = ""
        this.KEYDES = ""
        this.KEYPROTOPATH = ""
        ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00126,00143,1) ,[V]CST_AERROR)
      Endif
      LogicClose File [ASWR]
    Else
      this.KEYPROPERTY = ""
      this.KEYDES = ""
      this.KEYPROTOPATH = ""
    Endif
  Else
    this.KEYPROPERTY = ""
    this.KEYDES = ""
    this.KEYPROTOPATH = ""
  Endif

  this.VALID = [V]CST_ANO
Return

####################################################################
$KEYPROPERTY_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  Local File ASHWEXPPRO
  this.KEYPROPERTY=toupper(this.KEYPROPERTY)
  If this.KEYPROPERTY<>""
    Read [ASWR]ASWR3=this.REPCOD;this.KEYPROPERTY
    If fstat<>[V]CST_AOK
      WERR = mess(00126,00143,1) # invalid value
      ASTATUS = fmet this.ASETERROR("KEYPROPERTY",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$KEYPROPERTY_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################
$ESFF_MANDATORY_INIT
  If this.AORDER = 1 #1ST LINE
    this.MANDATORY = [V]CST_AYES
  Endif
Return

$ESFF_MANDATORY_CONTROL
  Local Char WERR(100)
  If this.APARENT.MSGDIR=2
    If this.MANDATORY = [V]CST_ANO and this.AORDER = 1 #1ST LINE
      WERR=mess(53,2006,1) # First line mandatory
      ASTATUS = fmet this.ASETERROR("MANDATORY",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################
$ESFF_FILCOD_CONTROL
  Local Char WERR(100)
  Local Integer I

  this.FILCOD=toupper(this.FILCOD)

  For I  =1 To maxtab(this.APARENT.ESFF)
    If this.APARENT.ESFF(I) <> null
& and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL
& and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
& and this.APARENT.ESFF(I).AORDER <> this.AORDER
& and this.APARENT.ESFF(I).FILCOD = this.FILCOD
      WERR=mess(00033,00137,1)  # Code already exists
      ASTATUS = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
      Break
    Endif
  Next
Return

$ESFF_FILCOD_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFF_FILNAM_CONTROL
  Local Char WERR(100)
  Local Integer I

  Local Char WCHAR(1)(1..13)
  WCHAR(1) ="/"  :  WCHAR(2) ="\"  : WCHAR(3) ="*"
  WCHAR(4) =":"  :  WCHAR(5) ="?"  : WCHAR(6) ="¿"
  WCHAR(7) ="<"  :  WCHAR(8) =">"  : WCHAR(9) ='"'
  WCHAR(10)="|"  :  WCHAR(11)=" "  : WCHAR(12)="¡"
  WCHAR(13)="!"
  Local Shortint I
  For I = 1 To maxtab(WCHAR())
    If instr(1,this.FILNAM,WCHAR(I)) <> 0
      WERR = func AFNC.MES1(mess(14,2006,1), WCHAR(I))
      ASTATUS = fmet this.ASETERROR("FILNAM",WERR,[V]CST_AERROR)
      Break
    Endif
  Next

  If WERR = ""
      For I  =1 To maxtab(this.APARENT.ESFF)
        If this.APARENT.ESFF(I) <> null
&     and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL
&     and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
&     and this.APARENT.ESFF(I).AORDER <> this.AORDER
&     and this.APARENT.ESFF(I).FILNAM = this.FILNAM
          WERR=mess(00033,00137,1)  # Code already exists
        ASTATUS = fmet this.ASETERROR("FILNAM",WERR,[V]CST_AERROR)
        Break
      Endif
    Next
  Endif
Return

####################################################################
$ESFF_MAINFIELD_CONTROL
  If this.APARENT.MSGDIR=2
    this.MAINFIELD=toupper(this.MAINFIELD)
    #test if mainfield exists in rep
    If func PROPERTY_IS_IN_REPRESENTATION(this.MAINFIELD, this.APARENT.REPCOD) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("MAINFIELD",mess(00126,00143,1),[V]CST_AWARNING)
    Endif
  Endif
Return

$ESFF_MAINFIELD_PROPAGATE
  If this.APARENT.MSGDIR=2
    #get prototype path
    this.PROTOMAIN = func GET_PROTOPATH(this.MAINFIELD, this.APARENT.REPCOD)
  Endif
Return

####################################################################
$ESFF_LINKFIELD_CONTROL
  If this.APARENT.MSGDIR=2
    this.LINKFIELD=toupper(this.LINKFIELD)
    #test if linkfield exists in rep
    If this.LINKFIELD <> ""
      If func PROPERTY_IS_IN_REPRESENTATION(this.LINKFIELD, this.APARENT.REPCOD) = [V]CST_AFALSE
        ASTATUS = fmet this.ASETERROR("LINKFIELD",mess(00126,00143,1),[V]CST_AWARNING)
      Endif
    Endif
  Endif
Return

$ESFF_LINKFIELD_PROPAGATE
  If this.APARENT.MSGDIR=2
    #get prototype path
    this.PROTOLINK = func GET_PROTOPATH(this.LINKFIELD, this.APARENT.REPCOD)
  Endif
Return

####################################################################
$ESFF_PARFILE_CONTROL
  Local Integer I
  Local Char WERR(100) : WERR = ""

  If this.APARENT.MSGDIR=2
    this.PARFILE=toupper(this.PARFILE)
    If this.AORDER=1
      If this.PARFILE<>""
        WERR = mess(75,2006,1)     #Parent code not allowed in first line
      Endif
    Else
      If this.PARFILE=""
        WERR = mess(73,2006,1)     #Parent code mandatory in this line
      Elsif this.PARFILE = this.FILCOD
        WERR = mess(74,2006,1)     #Parent code must be different to File code
      Else
        For I=1 To maxtab(this.APARENT.ESFF)
          If this.APARENT.ESFF(I) <> null
&         and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL
&         and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
&         and this.APARENT.ESFF(I).AORDER <> this.AORDER
&         and this.APARENT.ESFF(I).FILCOD = this.PARFILE
&         and this.APARENT.ESFF(I).AORDER > this.AORDER
            WERR = mess(72,2006,1)     #Parent code does not match any file code
            Break
          Endif
        Next
      Endif
    Endif

    If WERR <> ""
      ASTATUS = fmet this.ASETERROR("PARFILE",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$ESFF_PARFILE_PROPAGATE
  If this.APARENT.MSGDIR=2
    Local Integer I
    If this.PARFILE <> ""
      For I = 1 To maxtab(this.APARENT.ESFF)
        If this.APARENT.ESFF(I) <> null
&       and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL
&       and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
&       and this.APARENT.ESFF(I).FILCOD = this.PARFILE
          this.LINKFIELD = this.APARENT.ESFF(I).MAINFIELD
        Endif
      Next
    Endif
  Endif
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFN_COMTYP_CONTROL
  Local Shortint I, J
  Local Char WERR(100) : WERR = ""

  #test 1
  If this.APARENT.MSGDIR=1 #issue
    If this.COMTYP <> 6 #constant
      For I=1 To maxtab(this.APARENT.ESFN)
        If this.APARENT.ESFN(I)<>null
&       and !find(this.APARENT.ESFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
&       and this.APARENT.ESFN(I).COMTYP = this.COMTYP
&       and this.APARENT.ESFN(I).AORDER <> this.AORDER
          #err
          WERR = mess(91,2006,1) #"This component can only be assigned once"
          Break
        Endif
      Next
    Endif
  Endif

#  #test 2
  If this.APARENT.MSGDIR=1 #issue
    If this.COMTYP = 2 or this.COMTYP = 3 #main key or merge key
      For I=1 To maxtab(this.APARENT.ESFN)
        If this.APARENT.ESFN(I)<>null and !find(this.APARENT.ESFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
          If this.COMTYP = 2 and this.APARENT.ESFN(I).COMTYP = 3 and this.AORDER <> this.APARENT.ESFN(I).AORDER
            WERR = mess(52,2006,1) #"Main key and merge key cannot be associated both"
            #err
            Break
          Elsif this.COMTYP = 3 and this.APARENT.ESFN(I).COMTYP = 2 and this.AORDER <> this.APARENT.ESFN(I).AORDER
            WERR = mess(52,2006,1) #"Main key and merge key cannot be associated both"
            #err
            Break
          Endif
        Endif
      Next
    Endif
  Endif

  If WERR <> ""
    ASTATUS = fmet this.ASETERROR("COMTYP",WERR,[V]CST_AERROR)
  Endif
Return

$ESFN_COMTYP_PROPAGATE
  Case this.COMTYP
    When 4       : this.COMVAL="1": this.FORMAT=mess(1,2015,1)
    When 5       : this.COMVAL="1": this.FORMAT=mess(1,2016,1)
    When Default : this.COMVAL="" : this.FORMAT=""
  Endcase
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFN_COMVAL_CONTROL
  If this.COMVAL <> ""
    Local Char WERR(250) : WERR = ""

    Case this.COMTYP
      When 1, 2:
            WERR = mess(126,143,1) #WERR = "Value cannot be set"
      When 3:
            Local File ASHWEXPPRO [ASWR]
            Read [ASWR]ASWR0 = this.APARENT.REPCOD;this.COMVAL
            If fstat <> [V]CST_AOK
              WERR = mess(126,143,1)- mess(61,2006,1) # invalid value. Must be a property presents in the representation.
            Endif
            LogicClose File [ASWR]
      When 4:
            this.COMVAL=toupper(this.COMVAL)
            If func EDILIBA.STR_ISNUM(this.COMVAL) = [V]CST_ATRUE
              If val(this.COMVAL) > 12 or val(this.COMVAL)<1
                WERR = mess(35,2006,1) #WERR = "Invalid format"
              Endif
            Else
              WERR = mess(35,2006,1) #WERR = "Invalid format"  #only numbers are allowed
            Endif
      When 5:
            this.COMVAL=tolower(this.COMVAL)
            If func EDILIBA.STR_ISNUM(this.COMVAL) = [V]CST_ATRUE
              If val(this.COMVAL) > 4 or val(this.COMVAL)<1
                WERR = mess(35,2006,1) #WERR = "Invalid format"
              Endif
            Else
              WERR = mess(35,2006,1) #WERR = "Invalid format"  #only numbers are allowed
            Endif
      When 6, 8:
            Local Char WCHAR(1)(1..13)
            WCHAR(1) ="/"  :  WCHAR(2) ="\"  : WCHAR(3) ="*"
            WCHAR(4) =":"  :  WCHAR(5) ="?"  : WCHAR(6) ="¿"
            WCHAR(7) ="<"  :  WCHAR(8) =">"  : WCHAR(9) ='"'
            WCHAR(10)="|"  :  WCHAR(11)=" "  : WCHAR(12)="¡"
            WCHAR(13)="!"
            Local Shortint I
            For I = 1 To maxtab(WCHAR())
              If instr(1,this.COMVAL,WCHAR(I)) <> 0
                WERR = func AFNC.MES1(mess(14,2006,1), WCHAR(I))
                Break
              Endif
            Next
    Endcase

    If WERR <> ""
      ASTATUS = fmet this.ASETERROR("COMVAL",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$ESFN_COMVAL_PROPAGATE
  If this.COMVAL <> ""
    Case this.COMTYP
      When 3       : Local File ASHWEXPPRO [ASWR]
                     Read [ASWR]ASWR0 = this.APARENT.REPCOD;this.COMVAL
                     If !fstat
                       this.FORMAT = [ASWR]CODPRO
                     Else
                       this.FORMAT = ""
                     Endif
                     LogicClose File [ASWR]
      When 4       : this.FORMAT = mess(val(this.COMVAL),2015,1) #date
      When 5       : this.FORMAT = mess(val(this.COMVAL),2016,1) #time
      When Default : this.FORMAT = ""
    Endcase
  Endif
  this.APARENT.VALID = [V]CST_ANO
Return


####################################################################
$ESFD_FILCOD_CONTROL
  this.FILCOD = toupper(this.FILCOD)

  Local Integer I
  Local Integer WOK : WOK = [V]CST_AFALSE

  For I = 1 To maxtab(this.APARENT.ESFF)
    If this.APARENT.ESFF(I) <> null
&   and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL
&   and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
&   and this.APARENT.ESFF(I).FILCOD = this.FILCOD
      WOK = [V]CST_ATRUE
      Break
    Endif
  Next I

  If WOK = [V]CST_AFALSE
    WERR=mess(8,9137,1)    #Incorrect value
    ASTATUS = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
  Endif

Return

$ESFD_FILCOD_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
  If this.FILCOD <> ""
    Local Integer I, J

    #1 - get number of actives lines in the collection
    Local Integer WTABSIZE : WTABSIZE = 0
    For I = 1 To maxtab(this.APARENT.ESFD)
      If this.APARENT.ESFD(I) <> null
&     and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ADEL
&     and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ANEWDEL
        WTABSIZE = WTABSIZE + 1
      Endif
    Next I

    Local Integer PREV_I
    Local Integer PREV_ORD
    Local Char    PREV_FILCOD(10)
    Local Integer NEXT_I
    Local Integer NEXT_ORD
    Local Char    NEXT_FILCOD(10)

    #Cas 1 il n’y a aucune ligne
    If WTABSIZE = 1
      #1 - On crée une ligne avec un nom de fichier libre : pas d’erreur
      #rien à faire
    #Cas 2 il y a une ligne
    Elsif WTABSIZE = 2
      #2.1 si on insère en 1ere position
      If this.AORDER = 1
        #On crée une ligne avec le même nom de fichier que la ligne suivante ou bien un nom différent : pas d’erreur
        #rien à faire
      #2.2 si on insère en dernière position
      Else
        #On crée une ligne avec le même nom de fichier que la ligne précédente ou bien un nom différent : pas d’erreur
        #rien à faire
      Endif
    #Cas 3 il y a n lignes
    Else
      #on recherche quels sont les precedent et suivant
      For I=1 To maxtab(this.APARENT.ESFD)
        If this.APARENT.ESFD(I)<>null and find(this.APARENT.ESFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          #on est sur le precedent
          If this.AORDER - 1 = this.APARENT.ESFD(I).AORDER
            PREV_I = I
            PREV_ORD = this.APARENT.ESFD(I).AORDER
            PREV_FILCOD = this.APARENT.ESFD(I).FILCOD
          Endif
          If this.AORDER + 1 = this.APARENT.ESFD(I).AORDER
            NEXT_I = I
            NEXT_ORD = this.APARENT.ESFD(I).AORDER
            NEXT_FILCOD = this.APARENT.ESFD(I).FILCOD
          Endif
        Endif
      Next I

      #3.1 si on insère en 1ere position
      If this.AORDER = 1
        #si on crée une ligne avec le même nom de fichier que la ligne suivante, c’est OK
        If this.FILCOD = NEXT_FILCOD
          #rien à faire
        #si on crée une ligne avec un nom de fichier différent de la ligne suivante,
        Else
          #il faut parcourir toutes les lignes pour voir si ce nom existe déjà.
          For J=1 To maxtab(this.APARENT.ESFD)
            If this.APARENT.ESFD(J)<>null and find(this.APARENT.ESFD(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              If this.AORDER <> this.APARENT.ESFD(J).AORDER
                #S’il n’existe pas c’est OK, s’il existe : Erreur
                If this.FILCOD <> this.APARENT.ESFD(J).FILCOD
                  #rien à faire
                Else
                  #erreur
                  WERR=mess(88,2006,1) #The lines must be sorted by file name
                  WOK = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
                  ASTATUS = [V]CST_AERROR
                Endif
              Endif
            Endif
          Next J
        Endif

      #3.2 si on insère en dernière position
      Elsif this.AORDER = WTABSIZE
        #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
        If this.FILCOD = PREV_FILCOD
          #rien à faire
        Else
        #si on crée une ligne avec un nom de fichier différent de la ligne précédente,
        #il faut parcourir toutes les lignes pour voir si ce nom existe déjà. S’il n’existe pas c’est OK, s’il existe : Erreur
          For J=1 To maxtab(this.APARENT.ESFD)
            If this.APARENT.ESFD(J)<>null and find(this.APARENT.ESFD(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              If this.AORDER <> this.APARENT.ESFD(J).AORDER
                If this.FILCOD <> this.APARENT.ESFD(J).FILCOD
                  #rien à faire
                Else
                  #erreur
                  WERR=mess(88,2006,1)#The lines must be sorted by file name
                  WOK = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
                  ASTATUS = [V]CST_AERROR
                Endif
              Endif
            Endif
          Next J
        Endif

      #3.3 si on insère au milieu de 2 lignes qui ont le même nom de fichier.
      Elsif NEXT_FILCOD = PREV_FILCOD
        #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
        If this.FILCOD = PREV_FILCOD
          #rien à faire
        #si on crée une ligne avec le nom de fichier différent de la ligne précédente, Erreur
        Else
          #erreur
          WERR=mess(88,2006,1) #WERR=THE LINES MUST BE SORTED By File CODE
          WOK = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
          ASTATUS = [V]CST_AERROR
        Endif

      #3.4 si on insère au milieu de 2 lignes qui ont un nom de fichier différent.
      Elsif NEXT_FILCOD <> PREV_FILCOD
        #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
        If this.FILCOD = PREV_FILCOD
          #rien à faire
        #si on crée une ligne avec le même nom de fichier que la ligne suivante, c’est OK
        Elsif this.FILCOD = NEXT_FILCOD
          #rien à faire
        #si on crée une ligne avec un nom de fichier différent de la ligne précédente et suivante,
        #il faut parcourir toutes les lignes pour voir si ce nom existe déjà. S’il n’existe pas c’est OK, s’il existe : Erreur
        Else
          For J=1 To maxtab(this.APARENT.ESFD)
            If this.APARENT.ESFD(J)<>null and find(this.APARENT.ESFD(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              If this.AORDER <> this.APARENT.ESFD(J).AORDER
                If this.FILCOD <> this.APARENT.ESFD(J).FILCOD
                  #rien à faire
                Else
                  #erreur
                  WERR=mess(88,2006,1) #WERR=THE LINES MUST BE SORTED By File CODE
                  WOK = fmet this.ASETERROR("FILCOD",WERR,[V]CST_AERROR)
                  ASTATUS = [V]CST_AERROR
                Endif
              Endif
            Endif
          Next J
        Endif

      Endif
    Endif
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFD_FLGREC_CONTROL
  this.FLGREC = toupper(this.FLGREC)
Return

####################################################################
$ESFD_LEVEL_CONTROL
  Local Integer WOK
  Local Char WERR(250)

  If this.LEVEL = 0
    WERR = mess(47,2006,1) # The level is mandatory
    ASTATUS = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AERROR)
  Endif
Return

$ESFD_LEVEL_PROPAGATE
  Local Integer WOK
  Local Char WERR(250)

  If this.LEVEL > 4
    WERR = mess(105,2006,1) # 4 Level maximum
    ASTATUS = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AERROR)
  Else
    Local Integer I, J
    If this.LEVEL <> 0

      #1 - get number of actives lines in the collection
      Local Integer WTABSIZE
      WTABSIZE = 0
       For I=1 To maxtab(this.APARENT.ESFD)
        If this.APARENT.ESFD(I) <> null and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ADEL and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ANEWDEL
          WTABSIZE = WTABSIZE + 1
        Endif
      Next I

      Local Integer PREV_I
      Local Integer PREV_ORD
      Local Integer PREV_LEVEL
      Local Integer PREV_ENDREG
      Local Char    PREV_FILCOD(10)
      Local Integer NEXT_I
      Local Integer NEXT_ORD
      Local Integer NEXT_LEVEL
      Local Char    NEXT_FILCOD(10)

      #Cas 1 il n’y a aucune ligne
      If WTABSIZE = 1
        #1 - On crée une ligne avec level 1
        If this.LEVEL <> 1
          WERR=mess(86,2006,1) # First Level of a file must be 1
          WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
          ASTATUS = [V]CST_AWARNING
        Endif
      #Cas 2 il y a une ligne
      Elsif WTABSIZE = 2
        #2.1 si on insère en 1ere position
        If this.AORDER = 1
          If this.LEVEL <> 1
            WERR=mess(86,2006,1) # First Level of a file must be 1
            WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
            ASTATUS = [V]CST_AWARNING
         Endif
        #2.2 si on insère en dernière position
        Else
          #On crée une ligne avec le même nom de fichier que la ligne précédente ou bien un nom différent : pas d’erreur
          #rien à faire
        Endif

      #Cas 3 il y a n lignes
      Else
        #on recherche quels sont les precedents et suivants
        For I=1 To maxtab(this.APARENT.ESFD)
          If this.APARENT.ESFD(I)<>null and find(this.APARENT.ESFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
            #on est sur le precedent
            If this.AORDER - 1 = this.APARENT.ESFD(I).AORDER
              PREV_I = I
              PREV_ORD = this.APARENT.ESFD(I).AORDER
              PREV_LEVEL = this.APARENT.ESFD(I).LEVEL
              PREV_FILCOD = this.APARENT.ESFD(I).FILCOD
              PREV_ENDREG = this.APARENT.ESFD(I).ENDREG
            Endif
            If this.AORDER + 1 = this.APARENT.ESFD(I).AORDER
              NEXT_I = I
              NEXT_ORD = this.APARENT.ESFD(I).AORDER
              NEXT_LEVEL = this.APARENT.ESFD(I).LEVEL
              NEXT_FILCOD = this.APARENT.ESFD(I).FILCOD
            Endif
          Endif
        Next I

        #3.1 si on insère en 1ere position
        If this.AORDER = 1
          #si on crée une ligne avec le même nom de fichier que la ligne suivante, c’est OK
          If this.LEVEL <> 1
            WERR=mess(86,2006,1) # First Level of a file must be 1
            WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
            ASTATUS = [V]CST_AWARNING
          Endif


        #3.2 si on insère en dernière position
        Elsif this.AORDER = WTABSIZE
          #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
          If this.FILCOD = PREV_FILCOD
            #rien à faire
            If this.LEVEL = PREV_LEVEL
            Elsif this.LEVEL <> PREV_LEVEL + 1
             WERR=mess(87,2006,1) # First Level of a file must be 1
             WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
             ASTATUS = [V]CST_AWARNING
          #   Endif
            Endif
          Else
            #si on crée une ligne avec un nom de fichier différent de la ligne précédente,
            #il faut parcourir toutes les lignes pour voir si ce nom existe déjà. S’il n’existe pas c’est OK, s’il existe : Erreur
            If this.LEVEL <> 1
              WERR=mess(86,2006,1) # First Level of a file must be 1
              WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
              ASTATUS = [V]CST_AWARNING
            Endif
          Endif

        #3.3 si on insère au milieu de 2 lignes qui ont le même nom de fichier.
        Elsif NEXT_FILCOD = PREV_FILCOD

          #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
  #        If this.FILNAM = PREV_FILNAM
  #          #rien à faire
  #        #si on crée une ligne avec le nom de fichier différent de la ligne précédente, Erreur

        #3.4 si on insère au milieu de 2 lignes qui ont un nom de fichier différent.
        Elsif NEXT_FILCOD <> PREV_FILCOD
          #si on crée une ligne avec le même nom de fichier que la ligne précédente, c’est OK
          If this.FILCOD = PREV_FILCOD
            #rien à faire
            If this.LEVEL <> PREV_LEVEL
              If this.LEVEL < PREV_LEVEL
                If PREV_ENDREG<>2
                  WERR=mess(101,2006,1) #Level cannot be lower than previous level
                Endif
              Elsif this.LEVEL <> PREV_LEVEL + 1
                WERR=mess(87,2006,1) # First Level of a file must be 1
              Endif
              WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
             ASTATUS = [V]CST_AWARNING
            Endif
          #   Endif
            #rien à faire
          #si on crée une ligne avec le même nom de fichier que la ligne suivante, c’est OK
          Else # this.FILNAM = OR <> NEXT_FILNAM
            If this.LEVEL <> 1
            WERR=mess(86,2006,1) # First Level of a file must be 1
            WOK = fmet this.ASETERROR("LEVEL",WERR,[V]CST_AWARNING)
            ASTATUS = [V]CST_AWARNING
            Endif
            #rien à faire
          #si on crée une ligne avec un nom de fichier différent de la ligne précédente et suivante,
          #il faut parcourir toutes les lignes pour voir si ce nom existe déjà. S’il n’existe pas c’est OK, s’il existe : Erreur

          Endif

        Endif
      Endif
    Endif

  Endif
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFD_ALIAS_CONTROL
  this.ALIAS=toupper(this.ALIAS)
Return

$ESFD_ALIAS_PROPAGATE
  Local Char WTXT(120)
  Local Char WLAN(3)

  this.REPCOD=this.APARENT.REPCOD

  If this.ALIAS <> "" and this.REPCOD <> ""
    Local File ASHWEXPPRO [ASWR]
    Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
    If !fstat
      this.EXPRESSION = [ASWR]CODPRO
       WLAN = this.ACTX.LAN
#      WLAN="ENG"
      ##Always propose the english text
      Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
      this.DESCRIPTION = WTXT
      this.PROTOPATH = func EDILIBC.GET_PROTOPATH(this.ALIAS, this.EXPRESSION, this.APARENT.REPCOD)
    Else
      this.EXPRESSION = ""
      this.DESCRIPTION= ""
      this.PROTOPATH = ""
      ASTATUS = fmet this.ASETERROR("ALIAS",mess(00126,00143,1) ,[V]CST_AERROR)
    Endif
    LogicClose File [ASWR]
  Else
    this.EXPRESSION = ""
    this.DESCRIPTION= ""
    this.PROTOPATH = ""
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return


####################################################################
$ESFD_EXPRESSION_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  Local File ASHWEXPPRO
  this.EXPRESSION=toupper(this.EXPRESSION)
  If this.EXPRESSION <> ""
    Read [ASWR]ASWR3 = this.APARENT.REPCOD;this.EXPRESSION
    If fstat
      WERR = mess(00126,00143,1) # invalid value
      ASTATUS = fmet this.ASETERROR("EXPRESSION",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$ESFD_EXPRESSION_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFD_MANDATORY_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return


####################################################################
$ESFD_ENDREG_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFD_LOC_CONTROL
  Local Char WERR(250)
  Local Integer I

  If this.APARENT.TYPFIL=4 and this.APARENT.MSGDIR=1
    If this.LOC=0
      WERR = mess(00532,00177,1)  # The field is mandatory
      ASTATUS = fmet this.ASETERROR("LOC",WERR,[V]CST_AERROR)
    Else
      For I = 1 To maxtab(this.APARENT.ESFD)
        If this.APARENT.ESFD(I) <> null
&       and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ADEL
&       and this.APARENT.ESFD(I).ASTALIN <> [V]CST_ANEWDEL
&       and this.APARENT.ESFD(I).NUMORDER = this.NUMORDER-1
&       and this.APARENT.ESFD(I).FILCOD = this.FILCOD
&       and this.APARENT.ESFD(I).LOC + this.APARENT.ESFD(I).LNG > this.LOC
&       and this.APARENT.ESFD(I).ENDREG = 1
          WERR = mess(101,2006,1)  #Value is lower than the previous position
          ASTATUS = fmet this.ASETERROR("LOC",WERR,[V]CST_AWARNING)
        Endif
      Next
    Endif
  Endif
Return

$ESFD_LOC_PROPAGATE
  If this.APARENT.TYPFIL=4 and this.LOC<>0 and this.LNG=0
    this.LNG=1
  Endif
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################
$ESFD_LNG_CONTROL
  Local Char WERR(250)
  If this.APARENT.TYPFIL = 4 and this.APARENT.MSGDIR=1 and this.LNG=0
    WERR = mess(532,177,1)  # The field is mandatory
    ASTATUS = fmet this.ASETERROR("LNG",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)
  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_POST_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    WERR = mess(45,2006,1) #Sequential file is not valid
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return


#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AUPDATE_CONTROL_AFTER
  Local Integer WOK : WOK = [V]CST_AOK
  Local Char WERR(250)
  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_PUT_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    WERR = mess(45,2006,1) #Sequential file is not valid
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK, WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE
  Local Char WERR(250)

  Local File EDIFLOD [EFLD]
  Filter [EFLD] Where [EFLD]MSGCOD = this.MSGCOD and [EFLD]MSGREL = this.MSGREL and [EFLD]MSGFILNOR = this.MSGFILNOR
&& [EFLD]MSGTYP = 1 and [EFLD]MSGFOR = 1  #X3-68753 (JUCON 15/12/17)
  For [EFLD]
    WFOUND_FLG = [V]CST_ATRUE
    WERR = mess(1,115,1)+"."-mess(147,2006,1)+".("+[EFLD]FLOCOD+"/"+[EFLD]FLOREL+")"
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Break
  Next
  LogicClose File [EFLD]

  If WFOUND_FLG = [V]CST_AFALSE
    WOK = fmet this.MET_DEL_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Endif
Return


#********************************************************************
# Method ESFF_ADELLINE_BEFORE
#********************************************************************
#*
#*!
$ESFF_ADELLINE_BEFORE
  Local Integer I, J
  Local Char WERR(250)

  For I = 1 To maxtab(this.ESFD)
    If this.ESFD(I) <> null and this.ESFD(I).ASTALIN <> [V]CST_ADEL and this.ESFD(I).ASTALIN <> [V]CST_ANEWDEL
      If this.ESFD(I).FILCOD = this.ESFF(fmet this.AGETINDBYLINE('ESFF',ALINE)).FILCOD
        WERR = mess(48,2006,1) #Impossible to delete this line, this file code is used in the setup
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
        Break
      Endif
    Endif
  Next

  this.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFF_ADELLINE_AFTER
#********************************************************************
#*
#*!
$ESFF_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFF_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$ESFF_ADDLINE_BEFORE
  Local Char WERR(100)
  If this.MSGCOD = "" or this.MSGREL = "" or this.MSGFILNOR = ""
    WERR = mess(120,2006,1) #Keys must be set
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Endif
  this.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFF_ADDLINE_AFTER
#********************************************************************
#*
#*!
$ESFF_ADDLINE_AFTER

#  this.MANDATORY = [V]CST_ANO

  this.NUMLIN    = 1 + max(this.APARENT.ESFF(1..maxtab(this.APARENT.ESFF)).NUMLIN)

  #search previous and next lines
  Local Integer I, BEF_LINE, AFT_LINE
  BEF_LINE = 0
  AFT_LINE = 0
  For I = 1 To maxtab(this.APARENT.ESFF)
    If this.APARENT.ESFF(I) <> null
      If this.APARENT.ESFF(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.ESFF(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT
  Local Integer MY_STEP : #Step in the sort order between two records
  MY_STEP = 100
  #insert a line in the array in a position <> first line
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.ESFF(AFT_LINE).SORT
    #check if a next line exist
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ESFF(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    #if no more place to insert -> insert by dichotomy
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if not enough place, we re-assign the SORT property of all the lines after the inserted line
      For I=1 To maxtab(this.APARENT.ESFF)
        If this.APARENT.ESFF(I) <> null
          If this.APARENT.ESFF(I).AORDER >= this.AORDER
            #Assign the SORT property of each line from the current line
            this.APARENT.ESFF(I).SORT = this.APARENT.ESFF(I).AORDER * MY_STEP
          Endif
        Endif
      Next I
    Endif
  #if the line is inserted at the 1st position of the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #we check if there is a next line
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ESFF(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFN_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$ESFN_ADDLINE_BEFORE
  #In receipt, this block is not allowed
  Local Char WERR(100) : WERR = ""
  Local Integer WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE
  Local Integer I

  If this.MSGDIR = 2
    WERR = mess(70,2006,1)      #Insertion impossible. This block is not allowed in receipt sense
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Else
    #if there is nothing into ESFF impossible to add any line here
    For I = 1 To maxtab(this.ESFF)
      If this.ESFF(I) <> null and this.ESFF(I).ASTALIN <> [V]CST_ADEL and this.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
        WFOUND_FLG = [V]CST_ATRUE
        Break
      Endif
    Next

    If WFOUND_FLG = [V]CST_AFALSE
      WERR = mess(63,2006,1)      # Insertion impossible, no file code created
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Endif
  Endif
  this.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFD_AREAD_AFTER
#********************************************************************
#*
#*!
$ESFD_AREAD_AFTER
  Local Char WTXT(120)
  Local Char WLAN(3)

  this.REPCOD = this.APARENT.REPCOD

  If this.ALIAS <> "" and this.REPCOD <> ""
    Local File ASHWEXPPRO [ASWR]
    Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
    If !fstat
      this.EXPRESSION = [ASWR]CODPRO
      WLAN = this.ACTX.LAN
      Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
      this.DESCRIPTION = WTXT
    Else
      this.EXPRESSION = ""
    Endif
    LogicClose File [ASWR]
    Else
      this.EXPRESSION = ""
  Endif

  this.NUMORDER = this.AORDER

Return


#********************************************************************
# Method ESFD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$ESFD_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO

  Local Integer WNB_NUMORI(1..), WNB_NUMI(1..), WNB_AST(1..), W_NUMORI(1..), W_NUMI(1..)
  Local Integer I, K, R, D, WDEL , WNDEL, WNB_END, WNB_REC, WND, WREC

  For I = 1 To maxtab(this.APARENT.ESFD)
    WNB_REC=this.APARENT.ESFD(I).AORDER
    If  find(WNB_REC,WNB_NUMI(1..WREC))<>0 and find(WNB_AST(WNB_REC),2,4)<>0 : Goto NOWRITE: Endif
      WNB_NUMORI(WNB_REC)=WNB_REC
      WNB_NUMI(WNB_REC)=I
      WNB_AST (WNB_REC)=this.APARENT.ESFD(I).ASTALIN
      If WNB_REC>WREC: WREC=WNB_REC: Endif
    $NOWRITE
  Next

  For I = 1 To WREC
    If find(WNB_AST(I),[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WND+=1
      W_NUMORI(WND)=WND
      W_NUMI(WND)=WNB_NUMI(I)
    Endif
  Next

  D=WND
  For I = 1 To maxtab(this.APARENT.ESFD)
    R=find(I,W_NUMI(1..WND))
    If R<>0
      this.APARENT.ESFD(I).NUMORDER=W_NUMORI(R)
    Else
      D+=1
      this.APARENT.ESFD(I).NUMORDER=D
    Endif
  Next I

Return


#********************************************************************
# Method ESFD_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$ESFD_ADDLINE_BEFORE
  #if there is nothing into ESFF impossible to add any line here
  Local Char WERR(100) : WERR = ""
  Local Integer WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE

  Local Integer I

  For I = 1 To maxtab(this.ESFF)
    If this.ESFF(I) <> null and this.ESFF(I).ASTALIN <> [V]CST_ADEL and this.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
      WFOUND_FLG = [V]CST_ATRUE
      Break
    Endif
  Next I

  If WFOUND_FLG = [V]CST_AFALSE
    WERR = mess(63,2006,1)      # Insertion impossible, no file code created
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Endif
  this.VALID = [V]CST_ANO
Return


#********************************************************************
# Method ESFD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$ESFD_ADDLINE_AFTER
  this.MANDATORY = 1 #optional

  #add a line
  this.NUMLIN    = 1 + max(this.APARENT.ESFD(1..maxtab(this.APARENT.ESFD)).NUMLIN)

  #search previous and next lines
  Local Integer I, BEF_LINE, AFT_LINE
  BEF_LINE = 0
  AFT_LINE = 0
  For I = 1 To maxtab(this.APARENT.ESFD)
    If this.APARENT.ESFD(I) <> null
      If this.AORDER>1
        If this.APARENT.ESFD(I).AORDER = this.AORDER - 1
          BEF_LINE=I
        Elsif this.APARENT.ESFD(I).AORDER = this.AORDER + 1
          AFT_LINE=I
        Endif
      Else
        AFT_LINE=1
      Endif
    Endif

  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT
  Local Integer MY_STEP : #Step in the sort order between two records
  MY_STEP = 100
  #insert a line in the array in a position <> first line
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.ESFD(AFT_LINE).SORT
    #check if a next line exist
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ESFD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    #if no more place to insert -> insert by dichotomy
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if not enough place, we re-assign the SORT property of all the lines after the inserted line
      For I=1 To maxtab(this.APARENT.ESFD)
        If this.APARENT.ESFD(I) <> null
          If this.APARENT.ESFD(I).AORDER >= this.AORDER
            #Assign the SORT property of each line from the current line
            this.APARENT.ESFD(I).SORT = this.APARENT.ESFD(I).AORDER * MY_STEP
          Endif
        Endif
      Next I
    Endif
    #set the default values
    If this.AORDER=1
      BEF_LINE=1
#      If this.APARENT.TYPFIL = 3 #delimité
#        this.LOC = 0
#      Else
#        this.LOC = 1
#      Endif
##      this.LOC=1
#       this.LNG = 0
      If this.APARENT.TYPFIL = 4 #Fixed
        this.LOC=1
        this.LNG=1
      Endif
    Else
      If this.APARENT.TYPFIL = 4 #Fixed
        this.LOC = this.APARENT.ESFD(BEF_LINE).LOC + this.APARENT.ESFD(BEF_LINE).LNG
#      this.LNG = 0
        this.LNG=1
      Endif
    Endif

    this.FILCOD = this.APARENT.ESFD(BEF_LINE).FILCOD
    this.FLGREC = this.APARENT.ESFD(BEF_LINE).FLGREC
    this.LEVEL  = this.APARENT.ESFD(BEF_LINE).LEVEL
  #if the line is inserted at the 1st position of the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #we check if there is a next line
    If BEF_LINE <> 0
      BEF_LINE_SORT = this.APARENT.ESFD(BEF_LINE).SORT
      #set the default values
      this.LOC=this.APARENT.ESFD(BEF_LINE).LOC+this.APARENT.ESFD(BEF_LINE).LNG
      this.FILCOD = this.APARENT.ESFD(BEF_LINE).FILCOD
      this.FLGREC = this.APARENT.ESFD(BEF_LINE).FLGREC
      this.LEVEL  = this.APARENT.ESFD(BEF_LINE).LEVEL
    Else
      #set the default values
      #on va chercher la 1ere ligne du tableau ESFF
      For I = 1 To maxtab(this.APARENT.ESFF)
        If this.APARENT.ESFF(I) <> null and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ADEL and this.APARENT.ESFF(I).ASTALIN <> [V]CST_ANEWDEL
          this.FILCOD = this.APARENT.ESFF(I).FILCOD
          Break
        Endif
      Next I
#      this.FILCOD = ""
      this.LEVEL  = 1
      this.FLGREC=""
    Endif

    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP

 Endif

  Local Integer I
  For I = 1 To maxtab(this.APARENT.ESFD)
    If this.APARENT.ESFD(I)<>null and find(this.APARENT.ESFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      this.APARENT.ESFD(I).NUMORDER = this.APARENT.ESFD(I).AORDER
    Endif
  Next I

 this.APARENT.VALID = [V]CST_ANO
Return



