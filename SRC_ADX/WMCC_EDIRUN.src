#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## CRUD-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 814


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub _AVARIABLES From WMC00EDIRUN

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EDIRUN

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub AVARIABLES From WMC00EDIRUN
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EDIRUN
Else
 Gosub AINSERT_EDIRUN
Endif

Gosub _AINSERT_AFTER
[L]A_I = EDIRUN.freeSnapshot
EDIRUN.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUN._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EDIRUN.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUN.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and !find(EDIRUN.EDRD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and !find(EDIRUN.EDRD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EDIRUN
Trbegin [F:EDR]
 Gosub AINSERT_EDIRUN
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EDIRUN
Raz [F:EDR]
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIRUN._MAJSQL_EDIRUN(EDIRUN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]A_TYPMAJ=[V]CST_ANEW

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIRUN.EDRD)
 If EDIRUN.EDRD(A_N2) <> null and
& (EDIRUN.EDRD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ALL)
  If EDIRUN.EDRD(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EDRD]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIRUN._MAJSQL_EDIRUND(EDIRUN.EDRD(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EDIRUN.snapshotEnabled=1
 [L]A_RETIK = EDIRUN.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIRUN.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EDIRUN.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIRUN.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUN.EDRD)
 If EDIRUN.EDRD(A_N2) <> null
  If EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ADEL or EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIRUN.EDRD(A_N2)
   EDIRUN.EDRD(A_N2) = null
  Elsif EDIRUN.EDRD(A_N2).ASTALIN <> [V]CST_ALL
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



