#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("SA-EQU-EEA4","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20) ,CRITERE(250),CRITERE1(250),CRITERE2(250),CRITERE3(250) ,CRITERE4(250)
Local Char    CPY(GLONCPY), FCY(GLONFCY), SRV(GLONSRV)
Local Date    DATEDEB , DATEFIN
Local Char RPTTYP(1),SNR(25)
Local Integer OCC_LEVEL  ,MALE_A  ,MALE_C ,MALE_I  ,MALE_W  ,FEMALE_A ,FEMALE_C  ,FEMALE_I  ,FEMALE_W ,FOREIGN_M ,FOREIGN_F,EMPTYP
Local Decimal MALE_A_REM  ,MALE_C_REM ,MALE_I_REM  ,MALE_W_REM  ,FEMALE_A_REM ,FEMALE_C_REM  ,FEMALE_I_REM  ,FEMALE_W_REM ,FOREIGN_M_REM ,FOREIGN_F_REM


If clalev([F:SAEQU])=0    : Local File HRSAEQU  [SAEQU]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]: Endif
If clalev([F:HRAFRCL])=0  : Local File HRAFRCLASS  [HRAFRCL]: Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:INS])=0    : Local File INSCRIPT  [INS]  : Endif
If clalev([F:HRSES])=0    : Local File SESSIONS  [HRSES]  : Endif
If clalev([F:HRTPER])=0    : Local File HRSTRAINPER  [HRTPER]  : Endif
If clalev([F:ETR])=0    : Local File EMPLOTAXREC  [ETR]  : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]  : Endif
If clalev([F:VEP])=0        : Local File VALEMP        [VEP]             : Endif

Call GETPARAM("cpy",NBPAR,PARAMETRE,CPY)
Call GETPARAM("fcy",NBPAR,PARAMETRE,FCY)
Call GETPARAM("srv",NBPAR,PARAMETRE,SRV)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM

CRITERE = "1=1"
If CPY<>"" : CRITERE -= "& [F:FGR]CPY='"+CPY+"'"    : Endif
If FCY<>"" : CRITERE -= "& [F:HRCTR]ETRFCY='"+FCY+"'"    : Endif
If SRV<>"" : CRITERE -= "& [F:HRCTR]ETRSRV='"+SRV+"'"    : Endif


Gosub CLEARTABLE

  CRITERE -= "& [F:HRCTR]CTRDAT<=["+format$(GFMD,DATEFIN)+"]"

  CRITERE4 -= " [F:HRCTR]XITDAT > ["+format$(GFMD,DATEFIN)+"]"

  CRITERE2 -= " [F:HRCTR]XITDAT >= ["+format$(GFMD,DATEDEB)+"] & [F:HRCTR]XITDAT <= ["+format$(GFMD,DATEFIN)+"]"

  Link [HRCTR] With
& [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE)  &  [F:HRCTR]FLGVAR <> 2 & ( [F:HRCTR]XITFNL <> 2 |  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITFNL = 2 & evalue(CRITERE4)) | ([F:HRCTR]XITFNL = 2 & evalue(CRITERE2)))
& Order By [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Desc

RPTTYP = "1"

Gosub GETDATA


End

$GETDATA
Local Char UNQEMP(30)
Local Date CTRDATE
UNQEMP = "EMPTY"
CTRDATE = [0/0/0]


For OCC_LEVEL=1 To 7
  For [LNK]
    If UNQEMP <> [F:HRCTR]REFNUM + num$([F:HRCTR]CTRNUM) Then
    Filter [ETR] Where [F:ETR]REFNUM = [F:HRCTR]REFNUM and [F:ETR]CTRNUM = [F:HRCTR]CTRNUM  and [F:ETR]TAXSTA <> 8
    If rowcount([ETR]) > 0 Then
      If OCC_LEVEL < 7 Then
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and  [HRAFRCL]CTRDAT = [HRCTR]CTRDAT  and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 1  and [HRAFRCL]PYRMON<= DATEFIN
&       Order By [HRAFRCL]CTRDAT;[HRAFRCL]PYRMON Desc
      Else
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT   and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 2  and [HRAFRCL]PYRMON<= DATEFIN
&       Order By [HRAFRCL]CTRDAT;[HRAFRCL]PYRMON Desc
      Endif
      Gosub COUNTDATA
    Endif
    Endif
    UNQEMP = [F:HRCTR]REFNUM + num$([F:HRCTR]CTRNUM)
    CTRDATE  = [F:HRCTR]CTRDAT


Next
  Gosub WRITE_RECORD
  Gosub CLEAR_VARIABLES
Next OCC_LEVEL
Return

$CLEAR_VARIABLES
MALE_A=0
MALE_C=0
MALE_I=0
MALE_W=0
FEMALE_A=0
FEMALE_C=0
FEMALE_I=0
FEMALE_W=0
FOREIGN_M=0
FOREIGN_F=0
MALE_A_REM=0
MALE_C_REM=0
MALE_I_REM=0
MALE_W_REM=0
FEMALE_A_REM=0
FEMALE_C_REM=0
FEMALE_I_REM=0
FEMALE_W_REM=0
FOREIGN_M_REM=0
FOREIGN_F_REM=0



Return

$WRITE_RECORD
Trbegin [SAEQU]
  Raz [F:SAEQU]
  [F:SAEQU]CPY = CPY
  [F:SAEQU]USR = GUSER
  [F:SAEQU]RPT = 'EEA4'
  [F:SAEQU]TYP = RPTTYP
  [F:SAEQU]OCCLEV = OCC_LEVEL
  [F:SAEQU]MALEA = MALE_A
  [F:SAEQU]MALEC = MALE_C
  [F:SAEQU]MALEI = MALE_I
  [F:SAEQU]MALEW = MALE_W
  [F:SAEQU]FEMALEA = FEMALE_A
  [F:SAEQU]FEMALEC = FEMALE_C
  [F:SAEQU]FEMALEI = FEMALE_I
  [F:SAEQU]FEMALEW = FEMALE_W
  [F:SAEQU]FOREIGNM = FOREIGN_M
  [F:SAEQU]FOREIGNF  = FOREIGN_F
  [F:SAEQU]MALEAREM = MALE_A_REM
  [F:SAEQU]MALECREM = MALE_C_REM
  [F:SAEQU]MALEIREM = MALE_I_REM
  [F:SAEQU]MALEWREM = MALE_W_REM
  [F:SAEQU]FEMALEAREM = FEMALE_A_REM
  [F:SAEQU]FEMALECREM = FEMALE_C_REM
  [F:SAEQU]FEMALEIREM = FEMALE_I_REM
  [F:SAEQU]FEMALEWREM = FEMALE_W_REM
  [F:SAEQU]FOREIGNMREM = FOREIGN_M_REM
  [F:SAEQU]FOREIGNFREM  = FOREIGN_F_REM

  Write [F:SAEQU]
  If fstat=0
    Commit
  Else
  Infbox num$(fstat)
    Rollback
  Endif

Return


$COUNTDATA
Local Char CTUNQEMP(30)
CTUNQEMP = "EMPTY"
  For [HRAFRCL]
    If CTUNQEMP <> [HRAFRCL]REFNUM + num$([HRAFRCL]CTRNUM) Then
      If OCC_LEVEL < 7 Then
        If [HRAFRCL]OCPLEV = OCC_LEVEL Then
          Gosub CDATAREM
          Gosub CDATA
        Endif
      Else
        Gosub CDATAREM
        Gosub CDATA
      Endif
    Endif
    CTUNQEMP = [HRAFRCL]REFNUM + num$([HRAFRCL]CTRNUM)
  Next
Return

$CDATA
If [HRAFRCL]STG = 1 Then
  If [HRAFRCL]SEX = 1 Then
    Case [HRAFRCL]RCEGRP
      When 1: MALE_A+=1
      When 2: MALE_C+=1
      When 3: MALE_I+=1
      When 4: MALE_W+=1
    Endcase
  Elsif [HRAFRCL]SEX = 2 Then
    Case [HRAFRCL]RCEGRP
      When 1: FEMALE_A+=1
      When 2: FEMALE_C+=1
      When 3: FEMALE_I+=1
      When 4: FEMALE_W+=1
    Endcase
  Endif
Elsif [HRAFRCL]STG = 2 Then
  If [HRAFRCL]SEX = 1 Then
    FOREIGN_M+=1
  Elsif [HRAFRCL]SEX = 2 Then
    FOREIGN_F+=1
  Endif
Endif
Return

$CDATAREM
Local Char LASTBUL(20)
Local Decimal REMAMT
Filter [VEP] Where CTRNUM = [F:HRAFRCL]CTRNUM & EMP = [F:HRAFRCL]REFNUM & CTRDAT = [F:HRAFRCL]CTRDAT & PAYDAT >= DATEDEB & PAYDAT <= DATEFIN Order By Key VEP5 Asc
If rowcount([F:VEP])<=0 : Return : Endif
Columns [VEP](BUL)
For [VEP]
  LASTBUL = [VEP]BUL
Next

#Infbox "HSP: " +  num$([F:HRAFRCL]REFNUM) + " " + num$([F:HRAFRCL]CTRNUM) + " " + num$(LASTBUL)

Filter [HSP] Where EMP = [F:HRAFRCL]REFNUM and CTRNUM = [F:HRAFRCL]CTRNUM and BUL = LASTBUL and RUB = 'EQ_REM' and TYP = 1
If rowcount([F:HSP])<=0 : Return : Endif
Columns [HSP](AMT)
For [HSP]
    REMAMT = [HSP]AMT
Next

#Infbox num$(REMAMT)

If [HRAFRCL]STG = 1 Then
  If [HRAFRCL]SEX = 1 Then
    Case [HRAFRCL]RCEGRP
      When 1: MALE_A_REM+=REMAMT
      When 2: MALE_C_REM+=REMAMT
      When 3: MALE_I_REM+=REMAMT
      When 4: MALE_W_REM+=REMAMT
    Endcase
  Elsif [HRAFRCL]SEX = 2 Then
    Case [HRAFRCL]RCEGRP
      When 1: FEMALE_A_REM+=REMAMT
      When 2: FEMALE_C_REM+=REMAMT
      When 3: FEMALE_I_REM+=REMAMT
      When 4: FEMALE_W_REM+=REMAMT
    Endcase
  Endif
Elsif [HRAFRCL]STG = 2 Then
  If [HRAFRCL]SEX = 1 Then
    FOREIGN_M_REM+=REMAMT
  Elsif [HRAFRCL]SEX = 2 Then
    FOREIGN_F_REM+=REMAMT
  Endif
Endif
Return

$CLEARTABLE
Trbegin [SAEQU]
 Delete [SAEQU] Where USR=GUSER
Commit
Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

