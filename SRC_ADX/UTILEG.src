#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UTILEG","UTILEG",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "TERMINE"  : Gosub TERMINE
Endcase
Return

$INIT
If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
If !clalev([F:GAU]) : Local File GAUTACE  [GAU] : Endif
If !clalev([F:GAD]) : Local File GAUTACED [GAD] : Endif
Local Mask UTILEG [DIA]
Return

$CONTROLE
 If [M]MODLEG=""
 Endif
Return

$EXEC
If [M:DIA]MODLEG<>""
#---------
#Mise à jour des pièces automatiques
Call OUVRE_TRACE(mess(208,105,1)) From LECFIC
Call ECR_TRACE(" ",0)              From GESECRAN
Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Call PRTSCR("UTILEG","DIA","",0,1) From ATRTX3
Call ECR_TRACE(" ",0)              From GESECRAN
Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN

Local Integer NBP,NBPL
NBP=0 : NBPL=0

Trbegin [GAU],[GAD]
For [GAU]GAU0
 Case [M]ACTION
  When 1 : #Ajouter
   If !find([M:DIA]MODLEG,[F:GAU]ACTLEG(0..[F:GAU]NBRLEG-1))
    [F:GAU]ACTLEG([F:GAU]NBRLEG)=[M]MODLEG
    [F:GAU]NBRLEG+=1
    NBP+=1
   Endif
  When 2 : #Supprimer
   Local Integer INDLEG
   INDLEG=find([M]MODLEG,[F:GAU]ACTLEG(0..[F:GAU]NBRLEG-1))
   If INDLEG
    For I=INDLEG-1 To [F:GAU]NBRLEG
    [F:GAU]ACTLEG(I)=[F:GAU]ACTLEG(I+1)
    Next
    [F:GAU]NBRLEG-=1
    NBP+=1
   Endif
 Endcase
 #---
 GPE = 0
 GPOINT = "BEFWRIGAU" : Gosub ENTREE From EXEFNC
 If !GPE
  Rewrite [GAU]
  If fstat : GOK=0 : Call FSTA("GAU") From GLOCK : Goto AB_TR : Endif
 Endif
 #---
 For [GAD]GAD0 Where COD=[F:GAU]COD
  Case [M]ACTION
   When 1 : #Ajouter
    If !find([M]MODLEG,[F:GAD]ACTLEG(0..[F:GAD]NBRLEG-1))
     [F:GAD]ACTLEG([F:GAD]NBRLEG)=[M]MODLEG
     [F:GAD]NBRLEG+=1
     NBPL+=1
    Endif
   When 2 : #Supprimer
    Local Integer INDLEG
    INDLEG=find([M]MODLEG,[F:GAD]ACTLEG(0..[F:GAD]NBRLEG-1))
    If INDLEG
     For I=INDLEG-1 To [F:GAD]NBRLEG
     [F:GAD]ACTLEG(I)=[F:GAD]ACTLEG(I+1)
     Next
     [F:GAD]NBRLEG-=1
     NBPL+=1
    Endif
  Endcase
  #---
  GPE = 0
  GPOINT = "BEFWRIGAD" : Gosub ENTREE From EXEFNC
  If !GPE
   Rewrite [GAD]
   If fstat : GOK=0 : Call FSTA("GAD") From GLOCK : Goto AB_TR : Endif
  Endif
  #---
 Next
Next
Commit
Call ECR_TRACE(mess(209,105,1)-":"-num$(NBP),0) From GESECRAN
Call ECR_TRACE(mess(210,105,1)-":"-num$(NBPL),0) From GESECRAN
#----------
Endif

Return

$AB_TR
Rollback
Return

$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto EXEC
Endif
Return

$TERMINE
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Return
