#######################################################################################
# Classe OPPORSTB
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
$CPP
  Case [L]ARULE
    When "CONTROL"   : Gosub CPP_CONTROL
  Endcase
Return

$CPP_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.CPP <> this.snapshot.CPP Then
      [L]ASTATUS = fmet this.SETERROR("CPP", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

