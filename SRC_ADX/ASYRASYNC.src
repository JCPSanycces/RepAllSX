#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Sends a progress status to the user during an asynchronous operation.
#*
#* @param ACTX : Object : the session's context
#* @param PHASE : Char : the phase of the operation (ex : "Patch integration")
#* @param DETAIL : Char : the detail of the phase(ex : "The file xxx is being integrated")
#* @param PROGRESS : Integer : a integer in the range 0-100 which defines the progress of the operation
#*
#* example
#* Call ASYNCTRACK(this.ACTX, "Patch integration", "The file xxx is being integrated", 37) From ASYRASYNC
#*!
Subprog ASYNCTRACK(ACTX, PHASE, DETAIL, PROGRESS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PHASE, DETAIL
Value Integer PROGRESS

Local Clbfile RESBODY(6)
Local Integer ERROR : ERROR=[V]CST_AOK


Local Clbfile ARGS(0)
Local Char SEP1(5),SEP2(5)
SEP1 = '"'
SEP2 = '","'
#ARGS= SEP1 + PHASE + SEP2 + DETAIL + SEP2 +   num$(min(PROGRESS,100)) + SEP1
ARGS= SEP1 + PHASE + SEP2 + DETAIL + SEP2 +   num$(PROGRESS) + SEP1

ERROR = func _TRACK(ACTX,"asyncTrack",ARGS,RESBODY)
End

#**
#* Alerts the user during an asynchronous operation
#*
#* @param ACTX : Object : the session's context
#* @param MESSAGE : Char : The message to be displayed to the user
#* @param SEVERITY : integer: Accepts 3 values : CST_ASUCCESS, CST_AINFO, CST_AERROR
#*
#* example:
#* Call ADDDIAGNOSE(this.ACTX, "error", "The integration of the file xxx failed") From ASYRASYNC
#*!
Subprog ADDDIAGNOSE(ACTX, MESSAGE, SEVERITY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char  MESSAGE
Value Integer SEVERITY

Local Clbfile RESBODY(6)
Local Integer ERROR : ERROR=[V]CST_AOK

Local Clbfile ARGS(0)
Local Char SEP1(5),SEP2(5)

SEP1 = '"'
SEP2 = '","'
ARGS = SEP1
Case SEVERITY
 When [V]CST_ASUCCESS : ARGS += "success"
 When [V]CST_AINFO : ARGS += "info"
 When [V]CST_AERROR : ARGS += "error"
Endcase
ARGS += SEP2 + MESSAGE + SEP1
ERROR =  func  _TRACK(ACTX,"addDiagnose",ARGS,RESBODY)
End

#**
#* The operation has to be aborted if this function returns 1
#*
#* @param ACTX : Object : the session's context
 #* @return ERROR : Integer : 1 if the user requested to abort the operation. 0 else
#*!
Funprog ABORTREQUESTED(ACTX)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT

Local Integer ERROR : ERROR=[V]CST_AOK
Local Clbfile RESBODY(6)

Local Clbfile ARGS

ERROR = func _TRACK(ACTX,"abortRequested",ARGS,RESBODY)
If ERROR=CST_AOK and RESBODY = "true"
 ERROR = 1
Endif
End ERROR


Subprog _ADDLINK(ACTX,NAME,LNK)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char NAME
Variable Clbfile LNK

Local Clbfile RESBODY(6)
Local Integer ERROR : ERROR=[V]CST_AOK

Local Clbfile ARGS(0)
Local Char SEP1(5),SEP2(5)
SEP1 = '"'
SEP2 = '","'
ARGS = SEP1 + NAME + SEP1 + ',' + LNK
ERROR =  func  _TRACK(ACTX,"addLink",ARGS,RESBODY)
End

#**
#* Notifies the user that a file can be downloaded
#*
#* @param ACTX : Object : the session's context
#* @param TYP : Type of the file as defined in the ATYPEPRO table (example : ATYPE9-1)
#* @param FILNAME : Full path (VOLUME + path) of a file stored in the storage area (example : [TMP]/000002.jpg )
#*
#* Example :
#* Call ADDLINKDOWNLOAD(this.ACTX,"ATYPE9-1","[TMP]/000002.jpg") From ASYRASYNC
#*!
Subprog ADDLINKDOWNLOAD(ACTX, TYP, FILNAME)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char TYP
Value Clbfile FILNAME

Local Integer ASTATUS
Local Clbfile URL
Local Clbfile LNK
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,"$title","Download")  From ASYRJSO
ASTATUS = func ASYRSTO.AGET_VOLFILURL(ACTX,CST_ATRUE,FILNAME,URL)
Call JSON_ADDSTRING(NODES,ROOT,"$url",escJson(URL))  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,"$type",fmet ACTX.ACACHE.ATYPPRO.AGETVALCHAR(TYP,"PROTYP"))  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,"$filename",FILNAME)  From ASYRJSO
Call GENERATE_JSON(NODES,LNK) From ASYRJSO
Call _ADDLINK(ACTX,"$download",LNK) From ASYRASYNC
End

#**
#* Adds a link in the tracker displayed to the user
#*
#* @param ACTX : Object : the session's context
#* @param CODLNK : Code of the link (example : $download)
#* @param TITLE : A string which describes the link (example : Download)
#* @param URL: The URL of the link to be displayed
#*!
Subprog ADDLINKOTHER(ACTX, CODLNK, TITLE, URL)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char CODLNK, TITLE
Value Clbfile URL

Local Clbfile LNK
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,"$title",TITLE)  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,"$url",escJson(URL))  From ASYRJSO
Call GENERATE_JSON(NODES,LNK) From ASYRJSO
Call _ADDLINK(ACTX,CODLNK,LNK) From ASYRASYNC
End

Funprog _TRACK(ACTX,FONCTION,ARGUMENTS,RESBODY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char FONCTION
Variable Clbfile ARGUMENTS
Variable Clbfile RESBODY

Local Clbfile RESHEAD(4)
Local Char MODULE(100)
Local Char MODE(10)
Local Char ENCODINGS(40)
Local Integer CALLBACKINDEX
Local Char RETURNS(50)
Local Char RETURNS_ENC(3)
Local Integer STATUSCODE
Local Integer I
Local Integer ERROR : ERROR=[V]CST_AOK
#

MODULE = 'syracuse-sdata/lib/asyncTrack'
MODE = "wait"
ENCODINGS = ''
CALLBACKINDEX = 0
RETURNS = ''
RETURNS_ENC = '0'
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, CALLBACKINDEX,    RETURNS, RETURNS_ENC, RESHEAD, RESBODY)
If STATUSCODE <> [V]CST_AHTTP_OK
 ERROR = CST_AERROR
Endif
End ERROR

