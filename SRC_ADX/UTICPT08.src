#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK IGNORE_SOURCE

##############################################################################
## Initialisation du champ MODULE de la table GAUTACE
###############################################################################
Call MAJ_UTICPT08    
End

Subprog MAJ_UTICPT08

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT08:"-"Initialisation field MODULE (table GAUTACE)") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT08") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT08(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT08(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","GAUTACE","fde",APPLI),0) < 0 : End : Endif
If clalev([F:GAU])=0 : Local File =APPLI+".GAUTACE" [GAU] : Endif

Call ECR_TRACE("UTICPT08: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT08
Call ECR_TRACE("UTICPT08: Process End on : "+APPLI,0) From GESECRAN
End


#### Corps de la moulinette - début
$TR_UTICPT08
Trbegin [GAU]
 For [GAU]GAU0
  [F:GAU]MODULE = [F:GAU]MDU
  Rewrite [GAU]
  If fstat
   GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"GAUTACE"-":"-[F:GAU]COD,1) From GESECRAN
   Break
  Endif
 Next
 If !GOK : Goto AB_UTICPT08 : Endif
Commit
Return


$AB_UTICPT08
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT08(APPLI)
End






