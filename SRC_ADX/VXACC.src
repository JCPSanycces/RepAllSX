#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# Program Name: VXACC
# Description : ADC Cycle Count
# Author      : Chris Deutschbauer / Henri Combet
# Date        : March 8th, 2006    / Fevrier 2007
#########################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"VXACC","VXACC","XWXACC") From GSAISIE

End


########################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
 When "BOUTON"        : Gosub BOUTON
 When "SETBOUT"       : Gosub SETBOUT

Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

If clalev([F:CUN])  = 0 : Local File CUNSESSION [CUN]  : Endif
If clalev([F:CUL])  = 0 : Local File CUNLISTE   [CUL]  : Endif
If clalev([F:CUD])  = 0 : Local File CUNLISDET  [CUD]  : Endif
If clalev([F:CUD1]) = 0 : Local File CUNLISDET  [CUD1] : Endif
If clalev([F:CUD2]) = 0 : Local File CUNLISDET  [CUD2] : Endif    # Issue 110327 - 2016-09-14 by MAE
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:STS])  = 0 : Local File STOSER     [STS]  : Endif
If clalev([F:STJ])  = 0 : Local File STOJOU     [STJ]  : Endif
If clalev([F:STO])  = 0 : Local File STOCK      [STO]  : Endif
If clalev([F:STL])  = 0 : Local File STOLOT     [STL]  : Endif
If clalev([F:SLF])  = 0 : Local File STOLOTFCY  [SLF]  : Endif         # hcb 6800
If clalev([F:ACV])  = 0 : Local File ACTIV      [ACV]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif

# ouverture utiles en cas d ajout de ligne
If !clalev([M:SNL0])  Local Mask SNL0      [SNL0]  : Endif
If !clalev([M:SNL1])  Local Mask SNL1      [SNL1]  : Endif
If !clalev([M:SIW])   Local Mask STOINVW   [SIW]   : Endif

Global Char    GCRIT(250)
Global Char    GMODINV(1)
Global Char    GCUNFCY  # variable passée à l action SELOBJW paramatre "optiona"
Global Integer GCUNLOCK # pour gerer le unlock du CUD1 en cas de passage au suivant sans rewrite

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

#lecture code activite nombre de lignes par liste d inventaire
Global Integer GCOD_INV
Read [ACV]CODACT="INV"
If !fstat
   GCOD_INV =[F:ACV]DIME
Endif
#lecture code activite nombre de listes d inventaire par session
Global Integer GCOD_INL
Read [ACV]CODACT="INL"
If !fstat
   GCOD_INL =[F:ACV]DIME
Endif
#lecture code activite gestion emplacement
Global Integer GCOD_EMP
Read[ACV]CODACT="EMP"
If !fstat
   GCOD_EMP =[F:ACV]FLACT
Endif

Call INIVAR From GLOBSTO
# Initialisation des tables nécessaires à la gestion d'emplacements
Gosub STK_INILOC From STKLOC

# initialisation à 0 rubrique ajout ligne d inventaire
GAJOUINV = 0
#                                                                     hcb 96308 deb
GFCY=GXAFCY
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT      # hcb 104847
#                                                                     hcb 96308 fin

Return

########################################################
$DEBUT

Raz [M:XACC], [M:XAC1]
Gosub INIT_SCREEN

# site ADC non défini

If GXAFCY = "" : Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return : Endif
GCUNFCY = GXAFCY
GCRIT   = "1=1"

Diszo [M:XACC]
Diszo [M:XAC1]
Actzo [M:XACC]CUNSSSNUM
Actzo [M:XACC]PEC                                                                         # hcb 71659

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("Y",CHBOU) CHBOU+="Y" Endif

CHMEN = "Y"
Gosub SET_BOUT_SPE From GSAISIE

Return

########################################################
$BOUTON

# the next button will skip a count line
If [M:XACC]CUNLISNUM = ""
   Return
Endif
Case BOUT
    When "Y" :
         Gosub DISPLAY_COUNT   # ligne suivante
Endcase

Return
########################################################
$DISPLAY_COUNT
Local Integer WOK
If GMODINV = "M"
# Saisie non enregistrée ! Continuer ?
   Call OUINON(mess(28,7750,1), WOK) From GESECRAN
   If WOK <> 2
      Return
   Endif
  # Raz [M]ITMLISNUM
Endif
#                                                                                         # hcb 71659 deb
Local Char WFILTRE(250)
WFILTRE = "1=1"
If [M:SNL0]MULCTGFLG = 2
   If [M:XACC]CTG = 1
      WFILTRE += "& [F:CUD1]QTYPCUNEW1 = 0 & [F:CUD1]ZERSTOFLG1 < 2 & [F:CUD1]QTYPCUNEW = 0 & [F:CUD1]ZERSTOFLG < 2"
   Elsif [M:XACC]CTG = 2
      WFILTRE += "& [F:CUD1]QTYPCUNEW2 = 0 & [F:CUD1]ZERSTOFLG2 < 2 & [F:CUD1]QTYPCUNEW = 0 & [F:CUD1]ZERSTOFLG < 2"
   Endif
Endif
If [M:XACC]PEC = 2 & [M:XACC]CTG = 0
    WFILTRE += "& [F:CUD1]QTYPCUNEW = 0 & [F:CUD1]ZERSTOFLG < 2"
Endif
#                                                                                         # hcb 71659 fin

Raz GMODINV
If [M:XAC1]ITMLISNUM = 0
  # Issue 110327 - 2016-09-14 by MAE : pas d'articles gérés en sortie globale
   #Filter [CUD1] Where CUNSSSNUM = [M:XACC]CUNSSSNUM & CUNLISNUM = [M:XACC]CUNLISNUM & CUNLISSTA < 3 & evalue(WFILTRE) # hcb 71659
   Filter [CUD1] Where CUNSSSNUM = [M:XACC]CUNSSSNUM & CUNLISNUM = [M:XACC]CUNLISNUM & CUNLISSTA < 3 & SERSEQ = 0
&          & evalue(WFILTRE) # hcb 71659
   Readlock [CUD1]CUD0 First
   If fstat
#     Call FSTA("CUD") From GLOCK                                                         # hcb 71659
      GMESSAGE = mess(24,7750,1)       # fin de liste                                     # hcb 71659
      mkstat = 2                                                                          # hcb 71659
        Return
   Endif
Else
   If GCUNLOCK = 1
      Unlock [CUD1]
      Raz GCUNLOCK
   Endif
   Readlock [CUD1]CUD0 Next
   If fstat
#     GMESSAGE = mess(24,7750,1)       # fin de liste                                     # hcb 71659
#     mkstat = 2                                                                          # hcb 71659
      Gosub DISPLAY_COUNT_END                                                             # hcb 71659
        Return
   Endif
   If [F:CUD1]CUNSSSNUM <> [M:XACC]CUNSSSNUM | [F:CUD1]CUNLISNUM <> [M:XACC]CUNLISNUM | [F:CUD1]CUNLISSTA > 2 # hcb 94017
#     GMESSAGE = mess(24,7750,1)       # fin de liste                                     # hcb 71659
#     mkstat = 2                                                                          # hcb 71659
      Gosub DISPLAY_COUNT_END                                                             # hcb 71659
        Return
   Endif

Endif

GCUNLOCK = 1

[M:XACC]     = [F:CUD1]
#MAE
[M:XAC1]     = [F:CUD1]
[M:XAC1]QTYPCUOLD = [F:CUD1]QTYPCUNEW
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   If [M:XACC]CTG = 1
      [M:XACC]QTYPCUNEW = [F:CUD1]QTYPCUNEW1
      [M:XAC1]QTYPCUOLD = [F:CUD1]QTYPCUNEW1
      [M:XACC]ZERSTOFLG = [F:CUD1]ZERSTOFLG1
   Elsif [M:XACC]CTG = 2
      [M:XACC]QTYPCUNEW = [F:CUD1]QTYPCUNEW2
      [M:XAC1]QTYPCUOLD = [F:CUD1]QTYPCUNEW2
      [M:XACC]ZERSTOFLG = [F:CUD1]ZERSTOFLG2
   Endif
Endif
#                                                                                         # hcb 71659 fin


#MAE
If [M:XAC1]STOCOU <> 0
   Read [STO]STO0=GXAFCY;[M:XAC1]STOCOU
   If fstat = 0
      [M:XAC1]CUMALLQTY = [F:STO]CUMALLQTY
   Endif
Else
   Raz [M:XAC1]CUMALLQTY
Endif

#MAE
Affzo [M:XACC]
Affzo [M:XAC1]

# hcb 6800 deb
If [M:XAC1]STOCOU =  0  & [F:CUD1]QTYSTUNEW = 0   # hcb 101334
# gestion des rubriques suivant le contexte
   If [F:ITM]ITMREF <> [M:XAC1]ITMREF
      Read [F:ITM]ITM0=[M:XAC1]ITMREF
      If fstat
         Raz [F:ITM]
      Endif
   Endif
   If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>GXAFCY
      Read [ITF]ITF0=[F:ITM]ITMREF;GXAFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
   If [F:ITM]LOTMGTCOD = 1
      Diszo  [M:XAC1]LOT
      Diszo  [M:XAC1]SLO
   Else
      Actzo  [M:XAC1]LOT
   Endif
   If [F:ITM]LOTMGTCOD = 4
      Actzo  [M:XAC1]SLO
   Else
      Diszo  [M:XAC1]SLO
   Endif
   If [F:ITM]SERMGTCOD<3
      Diszo  [M:XAC1]SERNUM
   Else
      Actzo  [M:XAC1]SERNUM
   Endif
   If [F:ITF]LOCMGTCOD<>2
      Raz    [M:XAC1]LOC
      Affzo  [M:XAC1]LOC
      Diszo  [M:XAC1]LOC
   Else
      Actzo  [M:XAC1]LOC
   Endif
   Actzo [M:XAC1]QTYPCUNEW
Else
# hcb 6800 end
   Diszo [M:XAC1]LOC
   Diszo [M:XAC1]ITMREF
   Diszo [M:XAC1]LOT
   Diszo [M:XAC1]SLO
   Diszo [M:XAC1]SERNUM
   Diszo [M:XAC1]PCU
   Diszo [M:XAC1]STA
   Actzo [M:XAC1]QTYPCUNEW
Endif        # hcb 6800
#MAE
zonsui = "[M:XAC1]ITMLISNUM"
Actzo [M:XAC1]ITMLISNUM
Return

#                                                                                         # hcb 71659 deb
$DISPLAY_COUNT_END
Filter [CUD1]
If [M:SNL0]MULCTGFLG = 2 & [M:XACC]CTG <> 0
   MES = mess(24,7750,1)       # fin de liste
   MES += " : "
   MES += [M:XAC1]WQTYPCUNEW
   MES += "\"+mess(857,197,1)
   Call OUINON(MES,GOK) From GESECRAN
   If GOK =  2
      Local Char RGP_FILTRE (250)
      RGP_FILTRE = "[F:CUD1]CUNSSSNUM=[M:XACC]CUNSSSNUM&[F:CUD1]CUNLISNUM=[M:XACC]CUNLISNUM"
      Call SIT_MULTI_COMPTAGE(RGP_FILTRE,"1=1","1=1",0) From STKINV
      Gosub INIT_SCREEN_SAICOD
      zonsui = "[M:XACC]CUNSSSNUM"
      Return
   Endif
   Raz   [M:XAC1]ITMLISNUM
   Raz   [M:XAC1]LOC
   Raz   [M:XAC1]ITMREF
   Raz   [M:XAC1]LOT
   Raz   [M:XAC1]ECCVALMAJ
   Raz   [M:XAC1]ECCVALMIN
   Raz   [M:XAC1]SLO
   Raz   [M:XAC1]SERNUM
   Raz   [M:XAC1]PCU
   Raz   [M:XAC1]STA
   Raz   [M:XAC1]QTYPCU
   Raz   [M:XAC1]QTYPCUNEW
   Raz   [M:XAC1]QTYPCUOLD
   Raz   GMODINV
   Affzo [M:XAC1]
   zonsui = "[M:XAC1]ITMLISNUM"
Else
   GMESSAGE = mess(24,7750,1)       # fin de liste
   mkstat = 2
   zonsui = "[M:XACC]CUNSSSNUM"
Endif

Return
#                                                                                         # hcb 71659 fin


########################################################
$OK
Local Integer ZEROCOUNT
Local Integer NOL : NOL = 0
Local    Date     WPER
Local    Char     WSLO(GLONSLO) # hcb 6800
Raz [M:SNL1]             # hcb 6800

# Pour interdire la navigation
GREP="C"
FIN = 0
# si nouvelle ligne , si pas de quantite comptée on ne charge pas
#MAE
If [M:XAC1]QTYPCUNEW = 0 & [M:XAC1]ITMLISNUM = 0
    Call ERREUR(mess(26,7750,1)) From GESECRAN    # Stock nul interdit sur nouvelle ligne
    Return
Endif

# if nothing was entered, verify the count is short
If [M:XAC1]QTYPCUNEW = 0
    Call OUINON(mess(135,190,1),ZEROCOUNT) From GESECRAN    # Stock nul ?
    If ZEROCOUNT = 1
        zonsui = "[M:XAC1]QTYPCUNEW"
        Return
    Endif
    If [M:XAC1]STOCOU <> 0
       If [M:XAC1]CUMALLQTY <>  0
          GMESSAGE = mess(450,199,1)       # La qté allouée est supérieure à la qte comptée
          mkstat = 2
          Return
       Endif
    Endif
Endif

If [M:XAC1]ITMLISNUM <> 0
   Trbegin [CUD1]
   Case [M:XACC]CTG                                                                       # hcb 71659
        When 0 :                                                                          # hcb 71659
          [F:CUD1]QTYPCUNEW = [M:XAC1]QTYPCUNEW
          [F:CUD1]QTYSTUNEW = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
          Call QTEARR( [F:CUD1]QTYSTUNEW,[F:ITM]STU) From TRTDIV
          If [F:CUD1]QTYSTUNEW = 0
             [F:CUD1]ZERSTOFLG = 2
          Else
             [F:CUD1]ZERSTOFLG = 1
          Endif
          [F:CUD1]CUNLISSTA = 2
#                                                                                         # hcb 71659 deb
        When 1 :
           [F:CUD1]QTYPCUNEW1 = [M:XAC1]QTYPCUNEW
           [F:CUD1]QTYSTUNEW1 = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
           Call QTEARR( [F:CUD1]QTYSTUNEW1,[F:ITM]STU) From TRTDIV
           If [F:CUD1]QTYSTUNEW1 = 0
              [F:CUD1]ZERSTOFLG1 = 2
           Else
              [F:CUD1]ZERSTOFLG1 = 1
           Endif
        When 2 :
           [F:CUD1]QTYPCUNEW2 = [M:XAC1]QTYPCUNEW
           [F:CUD1]QTYSTUNEW2 = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
           Call QTEARR( [F:CUD1]QTYSTUNEW2,[F:ITM]STU) From TRTDIV
           If [F:CUD1]QTYSTUNEW2 = 0
              [F:CUD1]ZERSTOFLG2 = 2
           Else
              [F:CUD1]ZERSTOFLG2 = 1
           Endif
#                                                            # hcb 71659 pe deb
           Raz GPE
           GPOINT = "INICPTVXAC"
           Gosub  ENTREE From EXEFNC
           If GPE =  0
#                                                            # hcb 71659 pe fin
              If ([F:CUD1]QTYPCUNEW1 = [F:CUD1]QTYPCUNEW2)
&      &         ([F:CUD1]QTYSTUNEW1 = [F:CUD1]QTYSTUNEW2)
&      &         ([F:CUD1]ZERSTOFLG1 = [F:CUD1]ZERSTOFLG2)
                 [F:CUD1]QTYPCUNEW  = [F:CUD1]QTYPCUNEW2
                 [F:CUD1]QTYSTUNEW  = [F:CUD1]QTYSTUNEW2
                 [F:CUD1]ZERSTOFLG  = [F:CUD1]ZERSTOFLG2
                 [F:CUD1]CUNLISSTA  = 2
              Endif
           Endif                                             # hcb 71659 pe
   Endcase
#                                                                                         # hcb 71659 fin

   [F:CUD1]UPDDAT    = date$
   [F:CUD1]UPDUSR    = GUSER
# hcb 6800 deb
   If [M:XAC1]STOCOU = 0
      [F:CUD1]LOT       = [M:XAC1]LOT
      [F:CUD1]ECCVALMAJ = [M:XAC1]ECCVALMAJ
      [F:CUD1]SLO       = [M:XAC1]SLO
      [F:CUD1]SERNUM    = [M:XAC1]SERNUM
      [F:CUD1]STA       = [M:XAC1]STA
      [F:CUD1]LOC       = [M:XAC1]LOC
      [F:CUD1]PCU       = [M:XAC1]PCU
      [F:CUD1]PCUSTUCOE = [M:XAC1]PCUSTUCOE
# L'article est géré par lot et la rubrique lot présente(Code activité LOT OK)
      Raz WSLO
      If dim([M:XAC1]SLO) > 0 & [F:ITM]LOTMGTCOD = 4
         WSLO = [M:XAC1]SLO
      Endif
      If dim([M:XAC1]LOT) > 0
         If [F:ITM]LOTMGTCOD <> 1
            If [M:XAC1]QTYPCUNEW <> 0
               If [F:ITM]LOTMGTCOD = 4
                  Read [STL]STL0=[M:XAC1]ITMREF;[M:XAC1]LOT;WSLO
                        If  fstat
                            Filter [F:STL] Where ITMREF = [M:XAC1]ITMREF & LOT = [M:XAC1]LOT
&                           Order By Key STL0
                            Read [STL] First
                            If fstat
                               Raz [F:STL]
                               Gosub INI_STOLOT
                               [F:STL]ITMREF    = [M:XAC1]ITMREF
                               [F:STL]LOT       = [M:XAC1]LOT
                               [F:STL]ECCVALMAJ = [M:XAC1]ECCVALMAJ
                               [F:STL]ECCVALMIN = [M:XAC1]ECCVALMIN
                               [F:STL]SLO       = WSLO
                               [F:STL]VCRTYP    = 9
                               [F:STL]VCRNUM    = [M:XACC]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]ACT       = 1
                               [F:STL]POT       = [M:SNL1]POT      (0)
                               [F:STL]SHL       = [M:SNL1]SHL      (0)
                               [F:STL]SHLDAT    = [M:SNL1]SHLDAT   (0)
                               [F:STL]REFPER    = [M:SNL1]REFPER   (0)
                               [F:STL]DLUDAT    = [M:SNL1]DLUDAT   (0)
                               [F:STL]NEWLTIDAT = [M:SNL1]NEWLTIDAT(0)
                               [F:STL]SHLUOM    = [M:SNL1]SHLUOM   (0)
                               [F:STL]SHLLTI    = [M:SNL1]SHLLTI   (0)
                               [F:STL]SHLLTIUOM = [M:SNL1]SHLLTIUOM(0)
                               [F:STL]DLU       = [M:SNL1]DLU      (0)
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
                                  Call FSTA("STL") From GLOCK
                                  Rollback
                                  Return
                               Endif
                               [F:SLF]       = [F:STL]
                               [F:SLF]STOFCY = GXAFCY
                               Call ECRSLF From STKLIB
                               If fstat
                                  Call FSTA("SLF") From GLOCK
                                  Rollback
                                  Return
                               Endif
                            Else
                               [F:STL]VCRTYP    = 9
                               [F:STL]SLO       = WSLO
                               [F:STL]VCRNUM    = [M:XACC]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
                                  Call FSTA("STL") From GLOCK
                                  Rollback
                                  Return
                               Endif
                            Endif
                            Filter [F:STL]
                        Endif
                     Else
                        Read [STL]STL0=[M:XAC1]ITMREF;[M:XAC1]LOT;""
                        If  fstat
                               Raz [F:STL]
                               Gosub INI_STOLOT
                               [F:STL]ITMREF    = [M:XAC1]ITMREF
                               [F:STL]LOT       = [M:XAC1]LOT
                               [F:STL]ECCVALMAJ = [M:XAC1]ECCVALMAJ
                               [F:STL]ECCVALMIN = [M:XAC1]ECCVALMIN
                               [F:STL]SLO       = ""
                               [F:STL]VCRTYP    = 9
                               [F:STL]VCRNUM    = [M:XACC]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]ACT       = 1
                               [F:STL]POT       = [M:SNL1]POT      (0)
                               [F:STL]SHL       = [M:SNL1]SHL      (0)
                               [F:STL]SHLDAT    = [M:SNL1]SHLDAT   (0)
                               [F:STL]REFPER    = [M:SNL1]REFPER   (0)
                               [F:STL]DLUDAT    = [M:SNL1]DLUDAT   (0)
                               [F:STL]NEWLTIDAT = [M:SNL1]NEWLTIDAT(0)
                               [F:STL]SHLUOM    = [M:SNL1]SHLUOM   (0)
                               [F:STL]SHLLTI    = [M:SNL1]SHLLTI   (0)
                               [F:STL]SHLLTIUOM = [M:SNL1]SHLLTIUOM(0)
                               [F:STL]DLU       = [M:SNL1]DLU      (0)
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
                                  Call FSTA("STL") From GLOCK
                                  Rollback
                                  Return
                               Endif
                               [F:SLF]       = [F:STL]
                               [F:SLF]STOFCY = GXAFCY
                               Call ECRSLF From STKLIB
                               If fstat
                                  Call FSTA("SLF") From GLOCK
                                  Rollback
                                  Return
                               Endif
                        Endif
                     Endif
                 Endif
              Else
# creation lot blanc pour les articles non gere en lot
                 Raz WSLO
                 Read [STL]STL0=[M:XAC1]ITMREF;"";WSLO
                 If  fstat
                     [F:STL]ITMREF    = [M:XAC1]ITMREF
                     [F:STL]LOT       = ""
                     [F:STL]ECCVALMAJ = ""
                     [F:STL]ECCVALMIN = ""
                     [F:STL]SLO       = WSLO
                     [F:STL]VCRTYP    = 9
                     [F:STL]VCRNUM    = [M:XACC]CUNLISNUM
                     [F:STL]VCRLIN    = 0
                     [F:STL]REFPER    = date$
                     [F:STL]LOTCREDAT = date$
                     [F:STL]POT       = 100
                     [F:STL]ACT       = 1
                     [F:STL]NEWLTIDAT = [31/12/2999]     # date recontrole
                     [F:STL]SHLDAT    = [31/12/2999]     # date péremption
                     Call ECRSTL From STKLIB
                     If fstat
                        Call FSTA("STL") From GLOCK
                        Rollback
                        Return
                     Endif
                     [F:SLF]       = [F:STL]
                     [F:SLF]STOFCY = GXAFCY
                     Call ECRSLF From STKLIB
                     If fstat
                        Call FSTA("SLF") From GLOCK
                        Rollback
                        Return
                     Endif
                 Endif
              Endif
           Endif
   Endif
# hcb 6800 end
   GPOINT = "REWCUD1"                                         # hcb X3-94408
   Gosub ENTREE From EXEFNC                                   # hcb X3-94408
   Rewrite [CUD1]
   If fstat
      Call FSTA("CUD") From GLOCK
      Rollback
   Else
      Commit
   Endif
   Raz GCUNLOCK
   Raz GMODINV
   Gosub DISPLAY_COUNT   # ligne suivante
Else

   Raz [M:SNL0]
   Raz [M:SNL1]
   Raz [M:SIW]
   GOUVINV = 4
# c est la date de creation des enregistrements bidon stojou
   [M:SNL0]IPTDAT           = [F:CUL]CREDAT
   If [M:SNL0]IPTDAT        = [0/0/0]
      [M:SNL0]IPTDAT        = date$
   Endif
   [M:SNL0]STOFCY           = GXAFCY     # hcb 104847
   [M:SNL0]MULCTGFLG        = [F:CUN]MULCTGFLG  # multi-comptages                         # hcb 71659
   [M:SNL1]STOFCY           = GXAFCY
   [M:SNL1]ITMREF           = [M:XAC1]ITMREF
   [M:SNL1]CUNLISNUM        = [M:XACC]CUNLISNUM
   [M:SNL1]CUNSSSNUM        = [M:XACC]CUNSSSNUM
#                                    hcb 68798 deb
   If dim([M:SNL1]LOT) > 0
      [M:SNL1]LOT          (0) = [M:XAC1]LOT
   Endif
   If dim([M:SNL1]ECCVALMAJ) > 0
      [M:SNL1]ECCVALMAJ     (0) = [M:XAC1]ECCVALMAJ
   Endif
   If dim([M:SNL1]ECCVALMIN) > 0
      [M:SNL1]ECCVALMIN     (0) = [M:XAC1]ECCVALMIN
   Endif
   If dim([M:SNL1]SLO) > 0
      [M:SNL1]SLO          (0) = [M:XAC1]SLO
   Endif
   If dim([M:SNL1]SERNUM) > 0
      [M:SNL1]SERNUM       (0) = [M:XAC1]SERNUM
   Endif
   [M:SNL1]STA             (0) = [M:XAC1]STA
   If dim([M:SNL1]LOC) > 0
      [M:SNL1]LOC          (0) = [M:XAC1]LOC
   Endif
#                                    hcb 68798 deb
   [M:SNL1]PCU          (0) = [M:XAC1]PCU
   [M:SNL1]PCUSTUCOE    (0) = [M:XAC1]PCUSTUCOE
#  [M:SNL1]PCUSTUNEW    (0) = [M:XAC1]PCUSTUNEW                                                          # hcb 6800

   [M:SNL1]ITMREF_IMP   (0) = [M:XAC1]ITMREF
   Gosub EXI_INVENTAIRE From TRTSNLINV
   If  WOK <> 0
       mkstat = 2
       Return
   Endif

   Gosub INI_STOLOT     # hcb 6800

#     Call CALPER([F:ITM]EXYMGTCOD,[M:SNL1]REFPER(0),[M:SNL1]SHL(0),[F:ITM]SHLUOM,"",WPER) From STKLIB   # hcb 6800
#     [M:SNL1]SHLDAT    (0) = WPER                                                                       # hcb 6800
#   Endif                                                                                                # hcb 6800

# - element titre (on peut importer le titre sinon on prend celui par defaut (ITM))
   If [F:ITM]STOMGTCOD < 3
      [M:SNL1]POT       (0) = 100
   Else
      If [M:SNL1]POT    (0) = 0
         [M:SNL1]POT    (0) = [F:ITM]DEFPOT
      Endif
   Endif
   [M:SNL1]LINFLG       (0) = 1
   [M:SNL1]ABCCLS       (0) = [F:ITF]ABCCLS
   [M:SNL1]ITMREF       (0) = [M:XAC1]ITMREF
   [M:SNL1]IPTDAT_IMP   (0) = [M:SNL0]IPTDAT
   [M:SNL1]LOTMGT_IMP   (0) = [F:ITM]LOTMGTCOD
   [M:SNL1]ITMREF_IMP   (0) = [M:XAC1]ITMREF
#  [M:SNL1]QTYPCUNEW    (0) = [M:XAC1]QTYPCUNEW                                           # hcb 71659
   [M:SNL1]PCU          (0) = [M:XAC1]PCU
   If [M:SNL1]PCUSTUCOE (0) = 0
      [M:SNL1]PCUSTUCOE (0) = 1
   Endif
#                                                                                         # hcb 71659 deb
   Case [M:XACC]CTG
        When 0 :
           [M:SNL1]QTYPCUNEW(0) = [M:XAC1]QTYPCUNEW
           [M:SNL1]QTYSTUNEW(0) = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
           Call QTEARR( [M:SNL1]QTYSTUNEW(0),[F:ITM]STU) From TRTDIV
           If [M:SNL1]QTYPCUNEW1(0) = 0 &
&             [M:SNL1]QTYSTUNEW1(0) = 0 &
&             [M:SNL1]ZERSTOFLG1(0) <> 2
              [M:SNL1]ZERSTOFLG1(0) = 2
           Endif
           If [M:SNL1]QTYPCUNEW2(0) = 0 &
&             [M:SNL1]QTYSTUNEW2(0) = 0 &
&             [M:SNL1]ZERSTOFLG2(0) <> 2
              [M:SNL1]ZERSTOFLG2(0) = 2
           Endif

         When 1 :
           [M:SNL1]QTYPCUNEW1(0) = [M:XAC1]QTYPCUNEW
           [M:SNL1]QTYSTUNEW1(0) = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
           Call QTEARR( [M:SNL1]QTYSTUNEW1(0),[F:ITM]STU) From TRTDIV
        When 2 :
           [M:SNL1]QTYPCUNEW2(0) = [M:XAC1]QTYPCUNEW
           [M:SNL1]QTYSTUNEW2(0) = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
           Call QTEARR( [M:SNL1]QTYSTUNEW2(0),[F:ITM]STU) From TRTDIV
           If [M:SNL1]QTYPCUNEW1(0) = 0 &
&             [M:SNL1]QTYSTUNEW1(0) = 0 &
&             [M:SNL1]ZERSTOFLG1(0) <> 2
              [M:SNL1]ZERSTOFLG1(0) = 2
           Endif
   Endcase
#  [M:SNL1]QTYSTUNEW    (0) = [M:XAC1]QTYPCUNEW * [M:XAC1]PCUSTUCOE
#  Call QTEARR([M:SNL1]QTYSTUNEW(0),[F:ITM]STU) From TRTDIV
#                                                                                         # hcb 71659 fin
#                                                              hcb 96308 deb
   Local Integer Y
   Raz Y
   Local Char    SECTION
   For Y=1 To GNBDIE
       If dim([M:SNL1]CCE(Y-1)) >0
          Call INISEC(SECTION, "STKINVD", Y) From TRTX3CPT
          [M:SNL1]CCE(Y-1) =  SECTION
       Endif
   Next
#                                                              hcb 96308 fin
   GPOINT = "LOADSNL"                                         # hcb X3-94408
   Gosub ENTREE From EXEFNC                                   # hcb X3-94408
   [M:SNL1]NBLIG = 1
   Gosub MOD_INV From STKINV
#                                                                                         # hcb 71659 deb
#   Gosub INIT_SCREEN
    Raz GMODINV
    Raz   [M:XAC1]
    Gosub INIT_SCREEN_SAICOD
    Affzo [M:XAC1]
#                                                                                         # hcb 71659 fin
   zonsui = "[M:XAC1]ITMLISNUM"
Endif

Return

########################################################
$FIN
# si ajout de lignes il faut renumeroter la liste
If GAJOUINV = 1
   [M:SNL0]CUNLISNUM        = [M:XACC]CUNLISNUM
   [M:SNL0]CUNSSSNUM        = [M:XACC]CUNSSSNUM
# renumerotation
   Gosub RENUM_CUD From STKINV
Endif

# For the test
GVTMOD=0
GREP=""
# hcb  88610 deb
If [M:XACC]CUNSSSNUM <> ""
#  deverrouillage logique liste
   SYMBOLE2 = "CUN"+[M:XACC]CUNSSSNUM+[M:XACC]CUNLISNUM
   Unlock = SYMBOLE2
Endif
# hcb  88610 fin

Return

########################################################
$INIT_SCREEN
Local Char SESSION
Local Char SHEET
Local Integer CUNLIGNE

Default Mask [M:XACC]

Raz SESSION
Raz SHEET
Raz CUNLIGNE
SHEET             = [M:XACC]CUNLISNUM
SESSION           = [M:XACC]CUNSSSNUM
CUNLIGNE          = [M:XAC1]ITMLISNUM

Raz [M:XACC],[M:XAC1]
Raz GMODINV
[M:XACC]CUNLISNUM = SHEET
[M:XACC]CUNSSSNUM = SESSION
[M:XAC1]ITMLISNUM = CUNLIGNE
Raz [F:CUN]                                                                               # hcb 71659
Gosub FORMAT_INV_MULTI From STKINV                                                        # hcb 71659
[M:XACC]PEC = 2                                                                           # hcb 71659

Affzo [M:XACC]
Affzo [M:XAC1]

Return
#                                                                                         # hcb 71659 deb
$INIT_SCREEN_SAICOD

[M:XACC]CTG = 0
Case [M:SNL0]SAICOD(0)
     When "+!","+1","+"
          [M:XACC]SAICOD      = mess(855,197,1)  # compté 1
          [M:XAC1]WQTYPCUNEW  = mess(855,197,1)  # compté 1
          [M:XACC]CTG         = 1
          [M:XACC]PEC         = 1
          Diszo [M:XACC]PEC
     When "*1"
          [M:XACC]SAICOD      = mess(856,197,1)  # compté 2
          [M:XAC1]WQTYPCUNEW  = mess(856,197,1)  # compté 2
          [M:XACC]CTG         = 2
          [M:XACC]PEC         = 1
          Diszo [M:XACC]PEC
     When "*2",""
          [M:XACC]SAICOD      = mess(692,197,1)  # compté
          [M:XAC1]WQTYPCUNEW  = mess(692,197,1)  # compté
Endcase
Affzo [M:XACC]SAICOD
Return
#                                                                                         # hcb 71659 fin

#########################################################################
# INI_STOLOT                                  Initilalisation zones Lot #  hcb 6800
#########################################################################
$INI_STOLOT
Local    Date     WPER
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WEXY
Local    Decimal  WDLU
Local    Integer  WLTI

#  initialisation des éléments STOLOT (on peux creer un LOT)
If [F:ITM]EXYMGTCOD<2
   Raz [M:SNL1]REFPER         (0)
   Raz [M:SNL1]SHL            (0)
   Raz [M:SNL1]SHLUOM         (0)
   Raz [M:SNL1]SHLLTI         (0)
   Raz [M:SNL1]SHLLTIUOM      (0)
   Raz [M:SNL1]DLU            (0)
   [M:SNL1]SHLDAT             (0) = [31/12/2999]
   [M:SNL1]DLUDAT             (0) = [31/12/2999]
   [M:SNL1]NEWLTIDAT          (0) = [31/12/2999]
Else
   If [M:SNL1]REFPER          (0) = [0/0/0]
      [M:SNL1]REFPER          (0) = date$
   Endif
   If [M:SNL1]SHL             (0) = 0
      [M:SNL1]SHL             (0) = [F:ITM]SHL
   Endif
   If [M:SNL1]SHLUOM          (0) = 0
      [M:SNL1]SHLUOM          (0) = [F:ITM]SHLUOM
   Endif
   If [M:SNL1]DLU             (0) = 0
      [M:SNL1]DLU             (0) = [F:ITF]DLU
   Endif
   If [M:SNL1]SHLLTIUOM       (0) = 0
      [M:SNL1]SHLLTIUOM       (0) = [F:ITF]SHLLTIUOM
   Endif
   If [M:SNL1]SHL             (0) = 0
      [M:SNL1]SHL             (0) = [F:ITM]SHL
   Endif
   If [M:SNL1]SHLLTI          (0) = 0
      [M:SNL1]SHLLTI          (0) = [F:ITF]SHLLTI
   Endif
   WCOD = [F:ITM]EXYMGTCOD
   WREF = [M:SNL1]REFPER      (0)
   WEXY = [M:SNL1]SHLDAT      (0)
   WSHL = [M:SNL1]SHL         (0)
   WUOM = [M:SNL1]SHLUOM      (0)
   WDLU = [M:SNL1]DLU         (0)
   Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
   [M:SNL1]SHLDAT             (0)   = WPER
   WEXY =  [M:SNL1]SHLDAT     (0)
   Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
   [M:SNL1]DLUDAT             (0)   = WPER
   WSHL = [M:SNL1]SHLLTI      (0)
   WUOM = [M:SNL1]SHLLTIUOM   (0)
   Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
   [M:SNL1]NEWLTIDAT          (0)   = WPER
#  si date recontrole > date limite utilisation : date recontrole = date limite utilisation
   If [M:SNL1]NEWLTIDAT       (0) <> [31/12/2999]
      If [M:SNL1]NEWLTIDAT    (0)  > [M:SNL1]DLUDAT    (0)
         [M:SNL1]NEWLTIDAT    (0)  = [M:SNL1]DLUDAT    (0)
      Endif
   Endif
Endif
If [F:ITM]STOMGTCOD < 3
   [M:SNL1]POT       (0) = 100
Else
   If [M:SNL1]POT    (0) = 0
      [M:SNL1]POT    (0) = [F:ITM]DEFPOT
   Endif
Endif

Return

#########################################################################
# EXI_SERIE                            Controle existence numéro de série
#########################################################################
$EXI_SERIE
Local Integer WOK
Raz WOK

# recherche CUNLISDET
If WOK = 0
   Filter [CUD] Where STOFCY = GXAFCY &
&                     ITMREF = [M:XAC1]ITMREF &
&                     SERNUM = VALEUR         &
&                     ZERSTOFLG  <> 2         &
&                     CUNLISSTA < 3
&            Order By Key CUD1
   For [CUD]
       WOK = 9
       Break
   Next
   Filter [CUD]
# recherche STOSER
   If WOK = 0
      Read [STS]STS0=[M:XAC1]ITMREF;VALEUR
      If fstat = 0
         WOK = 1
      Endif
   Endif
Endif

If WOK = 9
   mkstat = 2
   GMESSAGE = mess(446,199,1)
Endif
If WOK = 1
   Call AVERTIR(mess(447,199,1),WOK) From GESECRAN
   If WOK = 1
      mkstat = 2
   Else
      mkstat = 0
   Endif
Endif
Return

########################################################
# Action champ
########################################################

Subprog C_CUNLISNUM(VALEUR)
Variable Char     VALEUR

Read [CUL]CUL0=[M:XACC]CUNSSSNUM;VALEUR
If fstat
   mkstat = 2
   End
Endif

# hcb 88610  deb
If VALEUR  <> [M:XACC]CUNLISNUM
   If [M:XACC]CUNLISNUM <> ""
#  deverrouillage logique liste
      SYMBOLE2 = "CUN"+[M:XACC]CUNSSSNUM+[M:XACC]CUNLISNUM
      Unlock = SYMBOLE2
   Endif
   If VALEUR <> ""
      SYMBOLE2 = "CUN"+[M:XACC]CUNSSSNUM+VALEUR
      Lock = SYMBOLE2
# MODIFICATION en cours sur un autre poste
      If fstat
         Call ERREUR((VALEUR)-":"-mess(10,100,1)) From GESECRAN
         mkstat = 2
         End
      Endif
   Endif
#                                                                                         # hcb 71659 deb
    [M:XACC]CTG          = 0
    If [M:SNL0]MULCTGFLG = 2
       Local Char RGP_FILTRE (250)
       Local Char WCUNLISNUM
       WCUNLISNUM = VALEUR
       RGP_FILTRE = "[F:CUD1]CUNSSSNUM=[M:XACC]CUNSSSNUM&[F:CUD1]CUNLISNUM=WCUNLISNUM"
       Call SIT_MULTI_COMPTAGE(RGP_FILTRE,"1=1","1=1",0) From STKINV
       Gosub INIT_SCREEN_SAICOD
    Endif
#                                                                                         # hcb 71659 fin

Endif
# hcb 88610  fin



# si liste cloturée modif interdite
If [F:CUL]CUNLISSTA  > 5
   mkstat = 2
   GMESSAGE = mess(197,199,1)
   End
Endif
End

########################################################
Subprog C_CUNSSSNUM(VALEUR)
Variable Char     VALEUR
Local Integer WOK
If GMODINV = "M"

# Saisie non enregistrée ! Continuer ?
   Call OUINON(mess(28,7750,1), WOK) From GESECRAN
   If WOK <> 2
      VALEUR = [M:XACC]CUNSSSNUM
      End
   Endif
   Raz GMODINV
Endif
# Issue 110327 - 2016-09-14 by MAE : message d'information si la liste contient des articles en série globale
Filter [CUD2] Where [F:CUD2]CUNSSSNUM =VALEUR and [F:CUD2]SERSEQ <> 0
If rowcount([F:CUD2]) > 0
  Call OUINON(mess(460,184,1), WOK) From GESECRAN
   If WOK <> 2
    Raz [M:XACC]CUNSSSNUM
    mkstat = 2
    End
   Endif
Endif
Filter [CUD2]
# Issue 110327 - 2016-09-14 by MAE : End

Read [CUN]CUN0=VALEUR
If fstat
   mkstat = 2
   End
Endif
If [F:CUN]STOFCY <> GXAFCY
   mkstat = 2
   GMESSAGE = mess(82,116,1)    # Site incorrecte
   End
Endif


If [F:CUN]CUNSSSSTA = 1
   mkstat = 2
   GMESSAGE = mess(50,184,1)    # liste non générée
   End
Endif

If [F:CUN]CUNSSSSTA = 3
   mkstat = 2
   GMESSAGE = mess(25,7750,1)   # Session close
   End
Endif
[M:SNL0]MULCTGFLG = [F:CUN]MULCTGFLG  # multi-comptages                                   # hcb 71659
Gosub FORMAT_INV_MULTI From STKINV                                                        # hcb 71659

# si ajout de lignes il faut renumeroter la liste
If GAJOUINV = 1 & VALEUR <> [M:XACC]CUNLISNUM
   [M:SNL0]CUNLISNUM        = [M:XACC]CUNLISNUM
   [M:SNL0]CUNSSSNUM        = [M:XACC]CUNSSSNUM
# renumerotation
   Gosub RENUM_CUD From STKINV
Endif



Local Integer COUNT

Raz COUNT

For [F:CUL] Where CUNSSSNUM = VALEUR
    COUNT += 1
Next

If COUNT = 1
# hcb 88610  deb
   If VALEUR  <> [M:XACC]CUNSSSNUM
      If [M:XACC]CUNSSSNUM <> ""
#  deverrouillage logique liste
         SYMBOLE2 = "CUN"+[M:XACC]CUNSSSNUM+[F:CUL]CUNLISNUM
         Unlock = SYMBOLE2
      Endif
      If VALEUR <> ""
         SYMBOLE2 = "CUN"+VALEUR+[F:CUL]CUNLISNUM
         Lock = SYMBOLE2
# MODIFICATION en cours sur un autre poste
         If fstat
            Call ERREUR((VALEUR)-":"-mess(10,100,1)) From GESECRAN
            mkstat = 2
            End
         Endif
      Endif
   Endif

# hcb 88610  fin

    [M:XACC]CUNLISNUM = [F:CUL]CUNLISNUM
    [M:XACC]CUNSSSNUM = VALEUR
#                                                                                         # hcb 71659 deb
    [M:XACC]CTG           = 0
    If [M:SNL0]MULCTGFLG = 2
       Local Char RGP_FILTRE (250)
       RGP_FILTRE = "[F:CUD1]CUNSSSNUM=[M:XACC]CUNSSSNUM&[F:CUD1]CUNLISNUM=[M:XACC]CUNLISNUM"
       Call SIT_MULTI_COMPTAGE(RGP_FILTRE,"1=1","1=1",0) From STKINV
       Gosub INIT_SCREEN_SAICOD
    Endif
#                                                                                         # hcb 71659 fin
    If GMODINV <>  "M"
       Raz [M:XAC1]ITMLISNUM
    Endif
    Grizo [M:XACC]CUNLISNUM
    Gosub DISPLAY_COUNT   # ligne suivante

    End
Else
# hcb 88610  deb
    If VALEUR  <> [M:XACC]CUNSSSNUM
       If [M:XACC]CUNSSSNUM <> ""
#  deverrouillage logique liste
          SYMBOLE2 = "CUN"+[M:XACC]CUNSSSNUM+[M:XACC]CUNLISNUM
          Unlock = SYMBOLE2
       Endif
    Endif
# hcb 88610  fin


    Raz [M:XACC]CUNLISNUM
    Raz [M:XAC1]ITMLISNUM
    Affzo [M:XACC]CUNLISNUM
    Affzo [M:XAC1]ITMLISNUM
    Actzo [M:XACC]CUNLISNUM
    Actzo [M:XAC1]ITMLISNUM

Endif

Raz   [M:XAC1]LOC
Raz   [M:XAC1]ITMREF
Raz   [M:XAC1]LOT
Raz   [M:XAC1]ECCVALMAJ
Raz   [M:XAC1]ECCVALMIN
Raz   [M:XAC1]SLO
Raz   [M:XAC1]SERNUM
Raz   [M:XAC1]PCU
Raz   [M:XAC1]STA
Raz   [M:XAC1]QTYPCU
Raz   [M:XAC1]QTYPCUNEW
Raz   [M:XAC1]QTYPCUOLD
Raz   GMODINV

Affzo [M:XAC1]LOC
Affzo [M:XAC1]ITMREF
Affzo [M:XAC1]LOT
Affzo [M:XAC1]ECCVALMAJ
Affzo [M:XAC1]ECCVALMIN
Affzo [M:XAC1]SLO
Affzo [M:XAC1]SERNUM
Affzo [M:XAC1]PCU
Affzo [M:XAC1]STA
Affzo [M:XAC1]QTYPCU
Affzo [M:XAC1]QTYPCUNEW
Affzo [M:XACC]CUNLISNUM

End

########################################################
Subprog C_ITMLISNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0

   Raz   [M:XAC1]LOC
   Raz   [M:XAC1]ITMREF
   Raz   [M:XAC1]LOT
   Raz   [M:XAC1]ECCVALMAJ
   Raz   [M:XAC1]ECCVALMIN
   Raz   [M:XAC1]SLO
   Raz   [M:XAC1]SERNUM
   Raz   [M:XAC1]PCU
   Raz   [M:XAC1]STA
   Raz   [M:XAC1]QTYPCU
   Raz   [M:XAC1]QTYPCUNEW
   Raz   [M:XAC1]CUMALLQTY
   Raz   [M:XAC1]ZERSTOFLG
   Raz   [M:XAC1]QTYPCUOLD
   Raz   GMODINV
   Affzo [M:XAC1]LOC
   Affzo [M:XAC1]ITMREF
   Affzo [M:XAC1]LOT
   Affzo [M:XAC1]ECCVALMAJ
   Affzo [M:XAC1]ECCVALMIN
   Affzo [M:XAC1]SLO
   Affzo [M:XAC1]SERNUM
   Affzo [M:XAC1]PCU
   Affzo [M:XAC1]STA
   Affzo [M:XAC1]QTYPCU
   Affzo [M:XAC1]QTYPCUNEW
   Affzo [M:XAC1]CUMALLQTY

   Actzo [M:XAC1]ITMREF
   Actzo [M:XAC1]PCU
   Actzo [M:XAC1]STA
   Actzo [M:XAC1]QTYPCUNEW

Else
   Readlock [CUD1]CUD0=[M:XACC]CUNSSSNUM;[M:XACC]CUNLISNUM;VALEUR
   If fstat
      GMESSAGE = mess(3,216,1)    # pas d inventaire
      mkstat = 2
      End
   Endif
#                                                                                         # hcb 71659 deb
   If [M:SNL0]MULCTGFLG = 2
      If [M:XACC]CTG = 1 & ([F:CUD1]QTYPCUNEW1 <> 0 | [F:CUD1]ZERSTOFLG1 = 2)
         GMESSAGE = mess(858,197,1)    # Comptage 1 déjà réalisé
         mkstat = 2
         End
      Endif
      If [M:XACC]CTG = 2 & ([F:CUD1]QTYPCUNEW2 <> 0 | [F:CUD1]ZERSTOFLG2 = 2)
         GMESSAGE = mess(859,197,1)    # Comptage 2 déjà réalisé
         mkstat = 2
         End
      Endif
   Endif
#                                                                                         # hcb 71659 fin
   GCUNLOCK = 1
   Read [F:ITM]ITM0 = [F:CUD1]ITMREF
   If fstat
      mkstat = 2
      End
   Endif
  [M:XACC]     = [F:CUD1]
  [M:XAC1]     = [F:CUD1]
  [M:XAC1]QTYPCUOLD = [F:CUD1]QTYPCUNEW
  Raz GMODINV
  If [M:XAC1]STOCOU <> 0
     Read [STO]STO0=GXAFCY;[M:XAC1]STOCOU
     If fstat = 0
        [M:XAC1]CUMALLQTY = [F:STO]CUMALLQTY
     Endif
  Else
     Raz [M:XAC1]CUMALLQTY
  Endif

   Affzo [M:XACC]
   Affzo [M:XAC1]

# hcb 6800 deb
   If [M:XAC1]STOCOU =  0
# gestion des rubriques suivant le contexte
      If [F:ITM]ITMREF <> [M:XAC1]ITMREF
         Read [F:ITM]ITM0=[M:XAC1]ITMREF
         If fstat
            Raz [F:ITM]
         Endif
      Endif
      If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>GXAFCY
         Read [ITF]ITF0=[F:ITM]ITMREF;GXAFCY
         If fstat
            Raz [F:ITF]
         Endif
      Endif
      If [F:ITM]LOTMGTCOD = 1
         Diszo  [M:XAC1]LOT
         Diszo  [M:XAC1]SLO
      Else
         Actzo  [M:XAC1]LOT
      Endif
      If [F:ITM]LOTMGTCOD = 4
         Actzo  [M:XAC1]SLO
      Else
         Diszo  [M:XAC1]SLO
      Endif
      If [F:ITM]SERMGTCOD<3
         Diszo  [M:XAC1]SERNUM
      Else
         Actzo  [M:XAC1]SERNUM
      Endif
      If [F:ITF]LOCMGTCOD<>2
         Raz    [M:XAC1]LOC
         Affzo  [M:XAC1]LOC
         Diszo  [M:XAC1]LOC
      Else
         Actzo  [M:XAC1]LOC
      Endif
      Actzo [M:XAC1]QTYPCUNEW
      Raz [M]ECCVALMAJ
      Raz [M]ECCVALMIN
   Else
# hcb 6800 end
      Diszo [M:XAC1]LOC
      Diszo [M:XAC1]ITMREF
      Diszo [M:XAC1]LOT
      Diszo [M:XAC1]SLO
      Diszo [M:XAC1]SERNUM
      Diszo [M:XAC1]PCU
      Diszo [M:XAC1]STA
   Endif   # hcb 68000
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If [F:ITM]ITMREF <> VALEUR
   Read [F:ITM]ITM0=VALEUR
   If fstat
      mkstat = 2
      GMESSAGE = mess(212,199,1)       # article inexistant
      End
   Endif
Endif

#gestion stock
If [F:ITM]STOMGTCOD < 2
   mkstat = 2
   GMESSAGE = mess(137,194,1)          # non gere  en stock
   End
Endif
#                                                          # hcb 71276 deb
If [F:ITM]ECCSTO > 1 & [F:ITM]LOAECCFLG <> 2
    mkstat = 2
    GMESSAGE = mess(429,184,1) #  En VT un aticle géré en version sans préchargement est interdit !
    End
Endif
#                                                          # hcb 71276 fin

#statut article
If [F:CUN]ITMSTA006 = 1
   If [F:ITM]ITMSTA = 6
      mkstat = 2
      GMESSAGE = mess(382,199,1)       # l article est non utilisable
      End
   Endif
Endif

If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>GXAFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;GXAFCY
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif
#controle mode inventaire
Local Integer WOK
WOK = 2
Case [F:CUN]CUNSSSMOD
  When 2 :
     If [F:ITF]CUNCOD <>1
        WOK = 9
     Endif
  When 3 :
    If [F:ITF]CUNCOD <> 2
       WOK = 9
    Endif
  When Default
    If [F:ITF]CUNCOD = 3
       WOK = 9
    Endif
Endcase
If WOK = 9
   mkstat = 2
   GMESSAGE = mess(444,199,1)       # Cet article est de  mode d inventaire non défini pour la session !
   End
Endif
# controle classe abc
WOK = 2
Case [F:ITF]ABCCLS
  When 1 : If [F:CUN]ABCCLSA <> 2
              WOK = 9
           Endif
  When 2 : If [F:CUN]ABCCLSB <> 2
              WOK = 9
           Endif
  When 3 : If [F:CUN]ABCCLSC <> 2
              WOK = 9
           Endif
  When 4 : If [F:CUN]ABCCLSD <> 2
              WOK = 9
           Endif
Endcase
If WOK = 9
   mkstat = 2
   GMESSAGE = mess(443,199,1)       # class abc non coché
   End
Endif

# gestion des rubriques suivant le contexte

If [F:ITM]LOTMGTCOD = 1
   Diszo  [M:XAC1]LOT
   Diszo  [M:XAC1]SLO
Else
   Actzo  [M:XAC1]LOT
Endif

If [F:ITM]LOTMGTCOD = 4
   Actzo  [M:XAC1]SLO
Else
   Diszo  [M:XAC1]SLO
Endif
If [F:ITM]SERMGTCOD<3
   Diszo  [M:XAC1]SERNUM
Else
   Actzo  [M:XAC1]SERNUM
Endif
If [F:ITF]LOCMGTCOD<>2
   Raz    [M:XAC1]LOC
   Affzo  [M:XAC1]LOC
   Diszo  [M:XAC1]LOC
Else
   Actzo  [M:XAC1]LOC
Endif


End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local Integer WOK

# si lot obligatoire alors saisie obligatoire
If [F:ITM]LOTMGTCOD > 2 & VALEUR = ""
  mkstat = 2
  End
Endif
# hcb                     71276 deb
If VALEUR <> [M]LOT
   Raz [M]ECCVALMAJ
   Raz [M]ECCVALMIN
Endif
# hcb                     71276 fin

# Un lot blanc n'a pas de sous lot
Raz [M:XAC1]GESLOT
If VALEUR=""
   [M:XAC1]GESLOT= "B"
   Raz   [M:XAC1]SLO
   Diszo [M:XAC1]SLO
Endif
If VALEUR = "" | [F:ITM]LOTMGTCOD < 4
   Read [STL]STL0=[M:XAC1]ITMREF;VALEUR;""
   If fstat
#lot inexistant pour l article
      Call OUINON(mess(23,107,1)+" : "+VALEUR+" "+mess(445,199,1),WOK) From GESECRAN
      If WOK <> 2
         mkstat = 2
         End
      Endif
  Endif
Endif

End

Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
# si slo obligatoire alors saisie obligatoire
If [F:ITM]LOTMGTCOD = 4 & VALEUR = ""
  mkstat = 2
  End
Endif
Read [STL]STL0=[M:XAC1]ITMREF;[M:XAC1]LOT;VALEUR
If fstat
#lot inexistant pour l article
   Call OUINON(mess(23,107,1)+" : "+[M:XAC1]LOT+" : "+VALEUR+" "+mess(445,199,1),WOK) From GESECRAN
   If WOK <> 2
      mkstat = 2
      End
   Endif
Endif

End

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If [F:ITM]SERMGTCOD > 1 & VALEUR = ""
   mkstat = 2
Endif

Gosub EXI_SERIE
End

Subprog C_PCU(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
   mkstat = 1
Endif

End

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()

Call CONTROLE("LOC","",VALEUR,GCUNFCY,mkstat) From CONTOBJ

End

Subprog C_STA(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
   mkstat = 2
Endif

End

Subprog AM_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR

If [M:XAC1]STOCOU <> 0
   If [M:XAC1]CUMALLQTY > VALEUR * [M:XAC1]PCUSTUCOE
      GMESSAGE = mess(450,199,1)       # La qté allouée est supérieure à la qte comptée
      mkstat = 2
   Endif
Endif

If VALEUR < 0
   mkstat = 2
   End
Endif

If [F:ITM]SERMGTCOD > 2 & VALEUR * [M:XAC1]PCUSTUCOE > 1
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
  End
Endif

If VALEUR <> [M:XAC1]QTYPCUOLD
   GMODINV= "M"
Else
   Raz GMODINV
Endif

End

Subprog AM_CUNLISNUM(VALEUR)
Variable Char    VALEUR()
# Issue 110327 - 2016-09-14 by MAE : message d'information si la liste contient des articles en série globale
Filter [CUD2] Where [F:CUD2]CUNSSSNUM =[M:XACC]CUNSSSNUM and [F:CUD2]CUNLISNUM = VALEUR and [F:CUD2]SERSEQ <> 0
If rowcount([F:CUD2]) > 0
   Call OUINON(mess(460,184,1), WOK) From GESECRAN
   If WOK <> 2
    Raz [M:XACC]CUNSSSNUM:  mkstat = 2: End
   Endif
Endif
Filter [CUD2]
# Issue 110327 - 2016-09-14 by MAE : end
# si ajout de lignes il faut renumeroter la liste
If GAJOUINV = 1 & VALEUR <> [M:XACC]CUNLISNUM
   [M:SNL0]CUNLISNUM        = [M:XACC]CUNLISNUM
   [M:SNL0]CUNSSSNUM        = [M:XACC]CUNSSSNUM
# renumerotation
   Gosub RENUM_CUD From STKINV
Endif

[M:XACC]CUNLISNUM = VALEUR
Raz [M:XAC1]ITMLISNUM
Gosub DISPLAY_COUNT   # ligne suivante

End

Subprog C_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

Local Char    LUSCAV(5)
Local Integer LMODIF
Local Decimal LCOEF
Local Decimal LQTYSTU
Local Char    PLBEFMT(GLONARP)
Local Char    LBPR
Call CTLUOM ([M:XAC1]ITMREF,3,LBPR,VALEUR, LCOEF, LUSCAV,PLBEFMT, LMODIF) From STKACT
If LUSCAV <> "S"
   If LUSCAV <> "C"
      mkstat = 2
      End
   Endif
Endif
[M:XAC1]PCUSTUCOE  = LCOEF

End

