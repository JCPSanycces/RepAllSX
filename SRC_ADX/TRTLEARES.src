#<AdxTL>@(#)1.0.0.0 $Revision$
#
#***********************************************************************************
#
#        SAISIE FENETRE SUR CONTRAT DE LOCATION-FINANCEMENT (LEA)
#
#      LEARES0  :  Entﾃｪte  Rﾃｩsiliation du contrat (OAC0)
#      LEARES   :  Rﾃｩsiliation du contrat (LEAR)
#      CMPRES   :  Maj des biens rattachﾃｩs  (OCP)
#
#***********************************************************************************
#    Crﾃｩation
#    MDR - 24.10.2003
#
#**************************************************************************************
#    Modification
# MWA   24.10.2018 X3-110500 No issue events when terminating a rent contract
# MDJ   10.17.2017 X3-39795   Manage ORIGIN and ORICOD fields in GL Entry
# MDR - 01.12.2007 (*V5)
#
#**************************************************************************************
#
ACTION
 Case ACTION
  When "OUVRE"              : Gosub OUVRE
  When "DEBUT"              : Gosub DEBUT
  When "APRES_MODIF"        : Gosub APRES_MODIF
  When "AVANT_MODFIC"       : Gosub AVANT_MODFIC
  When "OK"                 : Gosub OK
  When "ABA"                : Gosub ABA
  When "FIN"                : Gosub FIN
  When Default
 Endcase

Return
#
#---------------------------------#
# OUVRE                           #
#---------------------------------#
#
$OUVRE

 # X3-110500
 Global Date       G_SORREG
 Global Date       G_SORREGT
 Global Date       G_SORREGI
 Global Date       G_TBSORREG  (0..G301MAX-1)
 Global Date       G_TBSORREGT (0..G301MAX-1)
 Global Date       G_TBSORREGI (0..G301MAX-1)

Global  Date WDATDEBEX
Global  Date WDATFINEXS

# Rﾃｩcupﾃｩration des informations des biens liﾃｩs au contrat

 If !(clalev([F:FAS])) : Local File FXDASSETS [FAS] : Endif
 Filter [FAS] Where LEAREF=[M:LEA0]LEAREF
 Raz nolign
 For [FAS]
  nolign+=1
  [M:OCP]OBJREF(nolign-1)  = [F:FAS]AASREF
  [M:OCP]OBJDES(nolign-1)  = [F:FAS]AASDES1
  [M:OCP]OBJCPY(nolign-1)  = [F:FAS]CPY
  [M:OCP]OBJTYP(nolign-1)  = PARAM(2)
 Next
 Filter [FAS]

 [M:OCP]NBOBJ=nolign

If !(clalev([F:FIS])) : Local File FISCYEAR [FIS] : Endif
# Rﾃｩcupﾃｩration des informations exercices courantdu contexte CPFI
Filter [FIS] Where CPY=[M:LEA0]CPY and CNX = G300CPFI and STAFIY = GVML_TECOURA
Read [FIS]First
Filter [FIS]
WDATDEBEX= [F:FIS]DATSTRFIY
 If !(clalev([F:FISS])) : Local File FISCYEAR [FISS] : Endif
# Rﾃｩcupﾃｩration des informations exercice suivant du contexte CPFI
Filter [FISS] Where CPY=[M:LEA0]CPY and CNX = G300CPFI and STAFIY = GVML_TESUIV
Read [FISS]First
Filter [FISS]
WDATFINEXS = [F:FISS]DATENDFIY


Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$DEBUT

Global Integer NUMACT

# Rﾃｩcupﾃｩration des informations du contrat
  [M:LEAR]TRMLEADAT = [M:LEA1]TRMLEADAT
  Actzo [M:LEAR]
  Affzo [M:LEAR]
  Affzo [M:OCP]

 #=> Dﾃｩtermination / alimentation du numﾃｩro de traitement
 NUMACT+=1

#==> Appel du traitement d'init commun ﾃ toutes les actions
 Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$APRES_MODIF
  REP="M"
Return

#
#-------------------------------------------------------------------------------
$AVANT_MODFIC
Local  Integer LCDRET
Local  Char    LCDINT
Local  Date    WDATEFF
Local  Date    WDATCPTINT
Local Integer  L_RET
Local Date     L_CNXDAT(1..5)
Local Char     LPIECE

GREASON = mess(92,7771,1)
WDATEFF= [M:LEAR]TRMLEADAT

 # Gﾃｩnﾃｩration d'un ﾃｩvﾃｨnement de type "LEATRM" plan Comptable
 LCDINT= "LEATRM"+num$(G301CPT)
 LPIECE = "LCTRM"
 WDATCPTINT = max([M:LEAR]TRMLEADAT,  [M:LEA0]PERENDCPT)
 Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET) From GENEVE
 If (LCDRET > 20 )
   GOK = 0
   Call FSTA("ELEATRM") From GLOCK : Return
 Endif
 #Gosub CPTLEA
 # Issue X3-83749 X3-110500
 If GCNXPROIAS = G_OUI
    # Gﾃｩnﾃｩration d'un ﾃｩvﾃｨnement de type "LEATRM" plan IAS
    LCDINT= "LEATRM"+num$(G301IAS)
    LPIECE = "0LTRM"
    WDATCPTINT=max([M:LEAR]TRMLEADAT,[M:LEA0]PERENDIAS)
    Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET) From GENEVE
   If (LCDRET > 20 )
     GOK = 0
     Call FSTA("ELEATRM") From GLOCK : Return
   Endif
  # Gosub CPTLEA
 Endif

Return
#==========================================================
# Comptabilisation actualisation du contrat

$CPTLEA
 If !clalev([F:E46]) : Local File ELEATRM [E46] : Endif
 Local Char    IDENT(20)(7)
 Local Integer STAT
 Local Char    MESSA(255)
 #*X3-39795 Local Char    TZONE(10)(1..1)   # Tableau des noms des zones ﾃ forcer
 #*X3-39795 Local Char    TVAL (10)(1..1)   # Tableau des valeurs des zones ﾃ forcer
 Local Char     TZONE(10)(1..10) : # Table des zones ﾃ forcer (Ex: type de piﾃｨce)
 Local Char     TVAL(30)(1..10)  : # Table des valeurs des zones ﾃ forcer

 IDENT(0) = [M:LEA0]CPY
 IDENT(1) = "LEATRM"
 IDENT(2) = num$(G301AUC)
 IDENT(3) = [M:LEA0]FCY
 IDENT(4) = [M:LEA0]LEAREF
 IDENT(5) = func GENEVE.BUILD_TIMSTP(date$, time)
 IDENT(6) = GUSER

 TZONE(1) = "REFINT"    : TVAL(1) = "D-"+num$(NUMACT)
 TZONE(2) = "ORIGIN"    : TVAL(2) = "2"        :#Automatic loading  #*X3-39795
 TZONE(3) = "ORICOD"    : TVAL(3) = LPIECE                          #*X3-39795

 Call VALPCE3(LPIECE,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

 If STAT
    Infbox num$(STAT)-MESSA
 Else
    Update [E46] Where (CPY    = IDENT(0) &
&                       EVT    = IDENT(1) &
&                       PLN    = G301AUC  &
&                       FCY    = IDENT(3) &
&                       REF    = IDENT(4) &
&                       TIMSTP = IDENT(5) &
&                       CREUSR = IDENT(6)) With CPTFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
       If fstat
           GOK=0 : Return
       Else
          #Infbox "enregistrements modifiﾃｩs"-num$(adxuprec)
       Endif
 Endif

Return
#====================================================
#
$OK

  [M:LEA0]LEASTA = GVML_STRESIL  :  Affzo   [M:LEA0]LEASTA
  [M:LEA1]TRMLEADAT = [M:LEAR]TRMLEADAT   :  Affzo   [M:LEA1]TRMLEADAT
  Diszo [M:LEA0]
  Diszo [M:LEA1]
  Diszo [M:LEA2]

  # Issue X3-56289
  Diszo [M:LEA0]
  Diszo [M:LEA1]
  Diszo [M:LEA2]
  Diszo [M:LEA3]
  Diszo [M:LEA4]
  Diszo [M:LEA5]
  Diszo [M:LEA9]
#  Actzo [M:LEA9]EVTLIST # X3-110500
  Actzo [M:LEA0]EVTLIST # X3-110500

  G_ACT_MOD=1

  mkstat = 4
  FIN=1
  Affzo   [M:LEAR]

 If G_ACT_MOD & !([M:OCP]NBOBJ=0) # S'il y a des modifs ﾃ reporter et si il y a des objets liﾃｩs
  Global Char G_ACT_NAM           # On crﾃｩe la variable G_ACt_NAM
  G_ACT_NAM="LEARES"               # On l'alimente avec le nom de l'action en cours
 Endif

 Gosub ACTION From TRTOBJACT

Return

#
#====================================================
#
$ABA
 Gosub DEBUT # Clic sur abandon, on recharge toutes les valeurs d'origine
Return
#
#====================================================
#
$FIN

 # On dﾃｩtruit les globales (ﾃ l'action) de gestion des habilitations en sortant
 Gosub ACTION From TRTOBJACT

Return
#====================================================
#
#==============================================================#
# Traitement de mise ﾃ jour et de gﾃｩnﾃｩration d'ﾃｩvﾃｩnement       #
# des biens liﾃｩs lors d'un transfert                           #
#==============================================================#
$ACTMET
 Case ACTMET
  When "CRITMEN"      : Gosub CRITMEN       # Critﾃｨre d'activation du menu.
  When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zone spﾃｩ ﾃ l'action de l'en-tﾃｪte [OAC0]
  When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise ﾃ jour et alimentation des objets liﾃｩs
  When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables ﾃ mettre ﾃ jour dans MAJ_LNK
  When Default
 Endcase
Return

$CRITMEN
 # Permet d'alimenter la variable CRITMEN, condition d'activation du menu
 CRITMEN='REP="" & [M:LEA0]LEASTA = GVML_STENCOU & [M:LEA0]LEATYP = GVML_CREBAIL'
Return

$FILL_HEA

Return

$INIT_OBJ_DIV
Return

$MAJ_LNK

  # File class necessary for issue event generation
  If !(clalev([M:FASS])) : Local Mask FASISSP [FASS] : Endif

  For I_OBJ=0 To [M:OCP]NBOBJ-1          # Boucle sur les biens rattachﾃｩs
    Read [FASM]FAS0=[M:OCP]OBJREF(I_OBJ)

    # Maj Type date de sortie et motif de sortie du bien
    [F:FASM]ISSDAT   = [M:LEA1]TRMLEADAT
    [F:FASM]ISSTYP   = GVML_TSCRESI
    [F:FASM]ISSDATRUL= GVML_IRJOURP

    # X3-110500 Issue start
    Local    Decimal VALNETTE(1..G301MAX-1)
    Local    Date    SORREG  (0..G301MAX-1)
    Local    Date    SORREGT (0..G301MAX-1)
    Local    Date    SORREGI (0..G301MAX-1)
    Local    Integer CODERR

    Call CALCULER_VALEURS_SORTIE ("[F:FASM]", [F:FASM]ISSTYP, [F:FASM]ISSDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR) From TRTFASISS

    Local Integer I_P
    For I_P = 1 To G301MAX-1
      G_TBSORREG  (I_P-1) = SORREG  (I_P-1)
      G_TBSORREGT (I_P-1) = SORREGT (I_P-1)
      G_TBSORREGI (I_P-1) = SORREGI (I_P-1)
      [F:FASM]ISSAMT (I_P-1) = VALNETTE (I_P)
    Next I_P

    Rewrite [FASM]
    If fstat
      GOK=0
      Break
    Endif

    Local Integer L_ERROR
    #---------------------------------
    Call CALCULER_BIEN ([M:OCP]OBJCPY(I_OBJ), [M:OCP]OBJREF(I_OBJ), L_ERROR)  From GLOBB
    #---------------------------------

    #---------------------------------
    Gosub GENERE_ISSUE_EVENT
    #---------------------------------
    # X3-110500 End issue

 Next I_OBJ

# X3-49989
#GOK=0

Return

#---------------------------------
#*********************************
#---------------------------------
$GENERE_ISSUE_EVENT

  If !clalev([F:FASZ])  : Local File FXDASSETS [FASZ]  : Endif
  If !clalev([F:DEPC])  : Local File DEPREC    [DEPC]  : Endif
  If !clalev([F:DEPS])  : Local File DEPREC    [DEPS]  : Endif

  Read [FASM]FAS0=[M:OCP]OBJREF(I_OBJ)
  #------
  [F:FASZ] = [F:FASM]
  [M:FASS] = [F:FASM]
  #------

  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  For [CNX] Where CPY=[F:FASZ]CPY

    Local Date    CNXDAT(1..5)
    Call GET_CNX_DAT([F:CNX]CPY, [F:CNX]CNX, CNXDAT, CODERR) From GLOBIENS

    Local Integer INDICE_PLN
    Local Integer I_PLN
    For INDICE_PLN=1 To [F:CNX]NBPLC
      I_PLN = [F:CNX]PLNCAA(INDICE_PLN-1)
      Local Char    EVTINT
      EVTINT="FASISS"+num$(I_PLN)

      # DEPREC : Current period
      Read[DEPC]DEP0=[F:FASZ]AASREF;I_PLN;CNXDAT(2);CNXDAT(4)

      # Recherche de la ligne correspondant ﾃ la pﾃｩriode de sortie
      Local Date    ISSFIYENDDAT
      Local Date    ISSPERENDDAT
      Call GET_FIY_PER([F:FASZ]ISSDAT, [F:FASZ]CPY, [F:CNX]CNX, ISSFIYENDDAT,ISSPERENDDAT,CODERR) From GLOBIENS
      If CODERR : GOK=0 : Break : Endif

      # DEPREC : Issue period
      Read[DEPS]DEP0=[F:FASZ]AASREF;I_PLN;ISSFIYENDDAT;ISSPERENDDAT
      If fstat Then
        [F:DEPS] = [F:DEPC]
      Endif

      # Issue period before current period (SRA)
      If [F:DEPS]PERENDDAT<[F:DEPC]PERENDDAT
        [F:DEPS]=[F:DEPC]
      Endif
      # Issue period beyond current period
      If [F:DEPS]PERENDDAT>[F:DEPC]PERENDDAT
        [F:DEPC]=[F:DEPS]
      Endif

      # Plan specifities
      Global Decimal CPLDED, REVVAT, GISSRATCUR  : # Globals used in issue event generation
      If [F:CNX]ORIBASDPR(INDICE_PLN-1) = GVML_OBIAS Then
        CPLDED = [F:FASZ]IASCPLDED
        REVVAT = [F:FASZ]IASREVVAT
      Else
        CPLDED = [F:FASZ]ACGCPLDED
        REVVAT = [F:FASZ]ACGREVVAT
      Endif

      Local Date    DATE_EFFET
      DATE_EFFET = max([F:FASZ]ISSDAT,CNXDAT(3))

      # New VAT 2008 (PCG)
      If ( [F:DEPS]DPRPLN = G301CPT ) Then
        # Write issue in VAT history
        If clalev([F:HIS]) = 0  : Local File VATHIS    [HIS]   : Endif
        If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
        [F:HFAS] = [F:FASZ]
        [F:HFAS]VATREGDAT =  date$

        Local Integer  LCDRET
        Local  Integer LTYPREG
        Local  Char    LFORMPCG(50)
        If ( [F:HFAS]ACGCPLDED <> 0 ) Then
          LFORMPCG = "(1 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMT) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:HFAS]ACGREVVAT <> 0 ) Then
          LFORMPCG = "(0 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMT) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:FASZ]ISSVATRAT <> 0 ) Then : LTYPREG = GVML_TRSORST : Else  : LTYPREG = GVML_TRSORNT : Endif
        Call TVA_ECR_HISTORIQUE (LTYPREG, G301CPT, [F:DEPS]BSEVAL, [F:DEPS]BSEVAL, LFORMPCG, LCDRET) From TRTFAS
        If (LCDRET) Then : RERROR = 99 : Break : Endif :   # Erreur ﾃｩcriture dans l'historique
      Endif

      # New VAT 2008 (IAS)
      If ([F:DEPS]DPRPLN=G301IAS) Then
        # Write issue in VAT history
        If clalev([F:HIS]) = 0  : Local File VATHIS    [HIS]   : Endif
        If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
        [F:HFAS] = [F:FASZ]

        Local Integer LCDRET
        Local Integer LTYPREG
        Local  Char   LFORMIAS(50)
        If ( [F:HFAS]IASCPLDED <> 0 ) Then
          LFORMIAS = "(1 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMTI) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:HFAS]IASREVVAT <> 0 ) Then
          LFORMIAS = "(0 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMTI) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:FASZ]ISSVATRAT <> 0 ) Then : LTYPREG = GVML_TRSORST : Else  : LTYPREG = GVML_TRSORNT : Endif
        Call TVA_ECR_HISTORIQUE (LTYPREG, G301IAS, [F:DEPS]BSEVAL, [F:DEPS]BSEVAL, LFORMIAS, LCDRET) From TRTFAS
        If (LCDRET) Then : RERROR = 99 : Break : Endif :   # Erreur ﾃｩcriture dans l'historique
      Endif


      G_SORREG   = G_TBSORREG  (I_PLN-1)
      G_SORREGT  = G_TBSORREGT (I_PLN-1)
      G_SORREGI  = G_TBSORREGI (I_PLN-1)
      # Issue event generation
      Call GENER_EVE(GVML_OMBIEN, [F:FASZ]CPY, [F:FASZ]FCY, [F:FASZ]AASREF, 0, EVTINT, [F:FASZ]ISSDAT, DATE_EFFET, CODERR) From GENEVE

      If CODERR>13
        GOK=0
        # Event generation error
        GMESSAGE=mess(101,7771,1)
        Return
      Endif

      Kill CPLDED, REVVAT, GISSRATCUR : # Globals used in issue event generation

    Next
  Next

Return
#---------------------------------
#*********************************
#---------------------------------

##------------------------------------------------------------------------------------
## Contrﾃｴle de la date de rﾃｩsiliation qui doit ﾃｪtre >= ﾃ la date de dﾃｩbut d'exercice
## courant du contexte comptable et fiscal
##------------------------------------------------------------------------------------
Subprog C_TRMLEADAT(VALEUR)
Variable Date    VALEUR

Local Date    RCNXDAT(1..5)
Local Integer RCRET

Call GET_CNX_DAT([M:LEA0]CPY,G300CPFI,RCNXDAT,RCRET) From GLOBIENS

If VALEUR < RCNXDAT(1)
  GERR= 1
  GMESSAGE= mess(58, 7771, 1)
  mkstat = 2
  End
Endif
# La date de fin de rﾃｩsiliation doit ﾃｪtre <= ﾃ la date de fin de l'exercice
# suivant du contexte CPF
#
If (VALEUR > GFINEXSCPF  )
  GERR= 1
  GMESSAGE= mess(108,7771,1)
  mkstat = 2 : End
Endif

End
##------------------------------------------------------------------------------------
## Contrﾃｴle de la date de rﾃｩsiliation qui doit ﾃｪtre >= ﾃ la date de dﾃｩbut d'exercice
## courant du contexte comptable et fiscal
##------------------------------------------------------------------------------------
Subprog AM_TRMLEADAT(VALEUR)
Variable Date    VALEUR
Local Date    RCNXDAT(1..5)
Local Integer RCRET
Global Date GDATEFF
Call GET_CNX_DAT([M:LEA0]CPY,G300CPFI,RCNXDAT,RCRET) From GLOBIENS

If VALEUR <  WDATDEBEX
  GERR= 1
  GMESSAGE= mess(58, 7771, 1)
  mkstat = 2
  End
Endif

#
# La date de fin de rﾃｩsiliation doit ﾃｪtre <= ﾃ la date de fin de l'exercice
# suivant du contexte CPF
#
If (VALEUR > WDATFINEXS  )
  GERR= 1
  GMESSAGE= mess(108,7771,1)
  mkstat = 2 : End
Endif


For nolign = 1 To [M:LEA2]NBPER2
  If [M:LEA2]ENDPERDAT(nolign-1) < VALEUR
  Else
    [M:LEAR]RMNTPA=[M:LEA2]RMNTPA(nolign-1)
    Break
  Endif
Next nolign

End

######################################################################################

