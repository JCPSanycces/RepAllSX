#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "END"               :    Gosub XEND
    When "OK"                :    Gosub OK
    When "DEBUT"             :    Gosub DEBUT
    When Default
Endcase
Return
#
#
##================================================================================
$DEBUT

    Raz [M:HRESD0]
    [M:HRESD0]STRDAT=[M:HRSDM0]STRDAT
    [M:HRESD0]ENDDAT=[M:HRSDM0]ENDDAT
    [M:HRESD0]MDLDCL=[M:HRSDM0]MDLDCL

    Local Integer XEMPL : [L]XEMPL =1
    Call GENHRLOCAM([L]XEMPL) From TRTGENHRLOCAM
    Affzo [M:HRESD0]

Return
#
##================================================================================
#
$OK
Local Mask GENHRESD0[M:HRESD0]

Local Char ENREG(19)
Local Char ENREG1(241)
Local Char TYP
Local Char SOC
Local Date XDATPAY
Local Integer LPERIODE
Local Integer LNUMAFFIL
Local Integer I
Local Integer MM
Local Integer AAAA
Local Decimal REVERS ,REL , PLAF  ########variable  bloc B02
Local Char PATH (250)

  LPERIODE=val(format$("N0:6X",format$("D:YYYYMM", [M:HRESD0]ENDDAT)))

# Variables pour Poste Client
Local Char FICDON(GDIMFIC),FICHIER(GDIMFIC),NOMFIC(GDIMFIC),URL(GDIMFIC)
Local Char    FILBAL(250) , NAM(250) , FICHIER(GDIMFIC) , CHEMIN(GDIMFIC) , MACHINE(GDIMFIC) , CRITSPE(250)
Local Char  EXT(5)
Local Char  POINT(1)
Local Integer STAT

  If [M:HRESD0]MDLDCL="CIMR" Then
      NAM    = "CIMR_"+num$(LPERIODE) # Nom du fichier
      EXT    = "txt"
  Elsif [M:HRESD0]MDLDCL="9421" Then
      NAM    = "DEC_"+num$(LPERIODE) # Nom du fichier
      EXT    = "xml" # Extension du fichier
  Endif


  If left$([M:HRESD0]DATFIL,1)="#"
     [M:HRESD0]EMPLOC =1
     Call SET_NAMCLI([M:HRESD0]DATFIL) From ORDSYS
  Else
     [M:HRESD0]EMPLOC =2
      If [M:HRESD0]DATFIL="" : [M:HRESD0]DATFIL= filpath("tmp","","",nomap,"","") : Endif
  Endif

  FICHIER = [M:HRESD0]DATFIL
  Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS

  NOMFIC  = NAM

  If [M:HRESD0]EMPLOC = 1 : # Client
      FICHIER = filpath(CHEMIN,NOMFIC,EXT)
      Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
  Else
      FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
  Endif

  If [M:HRESD0]MDLDCL="CIMR" Then
      Call XGENERER_CIMR(LPERIODE,FICDON)
  Elsif [M:HRESD0]MDLDCL="9421" Then
      Call XGENERER_IR(LPERIODE,FICDON)
  Endif

  If [M:HRESD0]EMPLOC = 1
     Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
     If STAT=1
        # Fichier non copiÃ© sur le poste client
        Return
     Elsif STAT>1
        # Fichier inexistant
        Return
     Endif
  Endif
  #Infbox ("La génération du fichier a été effectué") #Generating the file was made
#JASMI - 2016-11-07 - X3PEOP-2602 - START
#  Infbox ("The generation of the file was made")
  Infbox mess(257,107,1)
#JASMI - 2016-11-07 - X3PEOP-2602 - END

Return
#
#
#################################################################################
$XEND
Raz [M:HRESD0]
FIN=1
Return
#
#################################################################################
Subprog XGENERER_CIMR(LPERIODE,LFICH)

Value Integer LPERIODE
Value Char LFICH
Local Integer XCODENR
Local Char XNUMADH,XVALEUR_ZONE
Local Integer XI,XJ,XU,XL,XOK,XTRV1,XTRV2
Local Char XTAUX,XMNT,XNOMPRE
Local Integer XTRIM
Local Char XFRM
Local Char XDATL
Local Char XDATSOR
  If !clalev([F:HRIDC])  : Local File HRINCDLC      [F:HRIDC]  : Endif
  If !clalev([F:HRSDS])  : Local File HRSTADCLSET   [F:HRSDS]  : Endif
  If !clalev([F:XID])    : Local File EMPLOID       [F:XID]    : Endif
  If !clalev([F:CPYAFR]) : Local File HRCOMPANYAFR  [F:CPYAFR] : Endif
  If !clalev([F:CPY])    : Local File COMPANY       [F:CPY]    : Endif

Openo LFICH, 0 Using[XXX]
adxirs = chr$(13)+chr$(10)

  If [M:HRESD0]MDLDCL="CIMR"
    Read[F:HRSDS]HRSDS0=[M:HRSDM0]MDLDCL
    If !fstat Then
      For[F:HRIDC] Where [HRIDC]MDLDCL=[M:HRSDM0]MDLDCL and month([HRIDC]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRIDC]STRDAT)=year([M:HRSDM0]STRDAT)
&       and month([HRIDC]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRIDC]ENDDAT)=year([M:HRSDM0]ENDDAT)
&       and [HRIDC]CPY=[M:HRESD0]CPY #JASMI - 2016-11-07 - X3PEOP-2602 - Added CPY filter

        [L]XCODENR=2 : Raz [L]XNUMADH

        Raz XTAUX,XMNT

        Filter[F:CPYAFR]
#JASMI - 2017-03-27 - 122234 - START
#        Read [F:CPYAFR]CPYAFR0 = GSOC
        Read [F:CPYAFR]CPYAFR0 = [M:HRESD0]CPY
#JASMI - 2017-03-27 - 122234 - END
        If !fstat Then
        #JASMI - 2016-11-03 - X3PEOP-2601 - START
  #       [L]XNUMADH = [F:CPYAFR]RETFDSNUM
          [L]XNUMADH = left$([F:CPYAFR]RETFDSNUM,6)
        #JASMI - 2016-11-03 - X3PEOP-2601 - END
        Endif

        For XI = 1 To [F:HRSDS]NBRFLD
          If instr(1,[F:HRSDS]FLD(XI-1),"]RETDAT") Then
            If [F:HRIDC]FLD(XI-1)<>"00/00/0000" or  ctrans([F:HRIDC]FLD(XI-1), "/","")<>"00000000" Then
              [L]XDATSOR=ctrans([F:HRIDC]FLD(XI-1), "/","")
              If val(mid$([L]XDATSOR,3,2))>= month([M:HRSDM0]STRDAT) and val(mid$([L]XDATSOR,3,2))<=month([M:HRSDM0]ENDDAT) and val(mid$([L]XDATSOR,5,4))>= year([M:HRSDM0]STRDAT) and val(
&             mid$([L]XDATSOR,5,4))<= year([M:HRSDM0]ENDDAT) Then
                [L]XCODENR=7
              Endif
            Endif
          Endif
        Next

      #Taux et montant / Rate and amount
        Raz XTRV1,XTRV2
        For XL=1 To dim ([F:HRSDS]TYPRUB)
          If [F:HRSDS]TYPRUB(XL-1) =2 Then #Taux
            [L]XTAUX=num$([F:HRIDC]AMT(XL-1))
            Call XCALC_SAL([L]XTAUX) From TRTGENHREDC
          #JASMI - 2016-11-03 - X3PEOP-2601 - START
            [L]XTAUX=left$([L]XTAUX,4)
          #JASMI - 2016-11-03 - X3PEOP-2601 - END
            XTRV1=1
          Elsif [F:HRSDS]TYPRUB(XL-1)=1 Then #Montant
            [L]XMNT=num$([F:HRIDC]AMT(XL-1))
            Call XCALC_SAL([L]XMNT) From TRTGENHREDC
          #JASMI - 2016-11-03 - X3PEOP-2601 - START
            [L]XMNT=left$([L]XMNT,10)
          #JASMI - 2016-11-03 - X3PEOP-2601 - END
            XTRV2=1
          Endif
          If XTRV1=1 and XTRV2=1 Then
            Break
          Endif
        Next

#JASMI - 2017-03-28 - 122234 - START
#        Wrseq [L]XCODENR,format$("N0:6X",[L]XNUMADH),"00", Using [XXX]
        Wrseq [L]XCODENR,format$("N0:6X",[L]XNUMADH), Using [XXX]
#JASMI - 2017-03-28 - 122234 - END

        XJ=0
        For XI=1 To [F:HRSDS]NBRFLD
          Raz [L]XVALEUR_ZONE
          XU=0
          Raz XFRM
          If instr(1,[F:HRSDS]FLD(XI-1),"SEX") Then
             If [F:HRIDC]FLD(XI-1)="1" Then
               [L]XVALEUR_ZONE = "M"
             Elsif [F:HRIDC]FLD(XI-1)="2"
               [L]XVALEUR_ZONE = "F"
             Endif
          Elsif instr(1,[F:HRSDS]FLD(XI-1),"NTT") Then
             #Transcodage nationnalité
             #transcoding nationality
             If [F:HRIDC]FLD(XI-1)="MA" Then
               [L]XVALEUR_ZONE = "M"
             Else
               [L]XVALEUR_ZONE = "A"
             Endif
           #Transcodage situation familiale
           #Transcoding family situation
          Elsif instr(1,[F:HRSDS]FLD(XI-1),"SITFAM") Then
            If [F:HRIDC]FLD(XI-1)="1" Then
              [L]XVALEUR_ZONE = "C"
##JASMI - 2017-11-01 - X3-48441 - START
#            Elsif [F:HRIDC]FLD(XI-1)="2"
#              [L]XVALEUR_ZONE = "M"
#            Elsif[F:HRIDC]FLD(XI-1)="3"
#              [L]XVALEUR_ZONE = "D"
#            Elsif [F:HRIDC]FLD(XI-1)="4"
#              [L]XVALEUR_ZONE = "V"
            Elsif [F:HRIDC]FLD(XI-1)="2" | [F:HRIDC]FLD(XI-1)="3" | [F:HRIDC]FLD(XI-1)="7"
              [L]XVALEUR_ZONE = "M"
            Elsif [F:HRIDC]FLD(XI-1)="4" | [F:HRIDC]FLD(XI-1)="6"
              [L]XVALEUR_ZONE = "D"
            Elsif [F:HRIDC]FLD(XI-1)="5"
              [L]XVALEUR_ZONE = "V"
#JASMI - 2017-11-01 - X3-48441 - END
            Endif
          Elsif instr(1,[F:HRSDS]FLD(XI-1),"EMPUID") Then
            If vireblc([F:HRIDC]FLD(XI-1),4)="" Then
              [L]XVALEUR_ZONE=format$("N0:7X","0")
            Else
              [L]XVALEUR_ZONE= [F:HRIDC]FLD(XI-1)
            Endif
          Elsif instr(1,[F:HRSDS]FLD(XI-1),"XITDAT") Then
            [L]XDATSOR=ctrans([F:HRIDC]FLD(XI-1), "/","")
            If val(mid$([L]XDATSOR,3,2))> month([M:HRSDM0]ENDDAT) and val(mid$([L]XDATSOR,5,4))>= year([M:HRSDM0]ENDDAT)  Then
              [L]XVALEUR_ZONE = "0"
            Else
              [L]XVALEUR_ZONE = [F:HRIDC]FLD(XI-1)
            Endif
#JASMI - 2017-03-28 - 122234 - START
          Elsif instr(1,[F:HRSDS]FLD(XI-1),"RETNUM") Then
            [L]XVALEUR_ZONE=format$("N0:9X",val([F:HRIDC]FLD(XI-1)))
#JASMI - 2017-03-28 - 122234 - END
          Else
            [L]XVALEUR_ZONE = [F:HRIDC]FLD(XI-1)
          Endif

          #concatenation du nom et prenom +num interieur de la societe
          #concatenation of the name and surname + num inside the company
          If instr(1,[F:HRSDS]FLD(XI-1),"NAM") Then
            XJ=XI : XU=2
            XNOMPRE=[L]XVALEUR_ZONE+" "+[F:HRIDC]FLD(XI)
            Wrseq format$("K:20X",XNOMPRE),format$("N0:6X","0"), Using [XXX]
          Endif

          #Recuperation du format selon paramétrage declaration
          #Recuperation of the declaration by setting size
          XFRM='K:'+num$([F:HRSDS]NUMCHR(XI-1))+'X'

          XOK=0

#JASMI - 2017-03-28 - 122234 - START
#          If [F:HRSDS]POS(XI-1)=1 Then      #Taux à la position 5 du fichier / Rate at the 5 position of the file
          If [F:HRSDS]POS(XI-1)=2 Then      #Taux à la position 5 du fichier / Rate at the 5 position of the file
#JASMI - 2017-03-28 - 122234 - END
            XOK=1
            Wrseq format$(XFRM,[L]XVALEUR_ZONE), format$("N0:4X",[L]XTAUX),  Using [XXX]
#JASMI - 2017-11-14 - X3-63597 - START
#          Elsif [F:HRSDS]POS(XI-1)=9 Then   #Montant à la position 14 du fichier / Amount to position 14 of the file
          Elsif [F:HRSDS]POS(XI-1)=10 Then   #Montant à la position 14 du fichier / Amount to position 14 of the file
#JASMI - 2017-11-14 - X3-63597 - END
            XOK=1
            Wrseq format$(XFRM,[L]XVALEUR_ZONE), format$("N0:10X",[L]XMNT),   Using [XXX]
          Endif

#JASMI - 2017-03-28 - 122234 - START
#          If XU<>2 and XI<>XJ+1 and XOK=0  Then
          If (XU<>2 and XI<>XJ+1 and XOK=0) | XI=1  Then
#JASMI - 2017-03-28 - 122234 - END
            If ([F:HRSDS]CODTYP(XI-1)<>"D" and [F:HRSDS]CODTYP(XI-1)<>"DTR") Then
              Wrseq format$(XFRM,[L]XVALEUR_ZONE) , Using [XXX]
            Else
              XFRM='N0:'+num$([F:HRSDS]NUMCHR(XI-1))+'X'
              [L]XDATL=ctrans([L]XVALEUR_ZONE, "/","")
              Wrseq format$(XFRM,[L]XDATL), Using [XXX]
            Endif
          Endif
        Next

        If month([M:HRSDM0]STRDAT)=1  Then
          [L]XTRIM=1
        Elsif month([M:HRSDM0]STRDAT)=4  Then
          [L]XTRIM=2
        Elsif month([M:HRSDM0]STRDAT)=7 Then
          [L]XTRIM=3
        Elsif month([M:HRSDM0]STRDAT)=10 Then
          [L]XTRIM=4
        Endif
        Wrseq [L]XTRIM,year([M]STRDAT) Using [XXX]

      Next
    Endif
  Endif

Openo Using[XXX]

End

##====================================================================================================
Subprog XGENERER_IR(LPERIODE,LFICH)
Value Integer LPERIODE
Value Char LFICH

Local Char XIDENTFIS,CPYAFRNAM,XCNTLNA,XCNTFNA,XCOMMUNE(40),XADRESSE(150),XDATFLD
Local Integer XI : Raz XI
Local Char  XVALEUR_ZONE(50),XINT_ZONE(50)
Local Char  XDESPOSTE(50)
Local Char XCIN,XCE
Local Decimal XCNSS

If !clalev([F:HRIDC])  : Local File HRINCDLC     [F:HRIDC]  : Endif
If !clalev([F:HRSDS])  : Local File HRSTADCLSET  [F:HRSDS]  : Endif
If !clalev([F:XID])    : Local File EMPLOID      [F:XID]    : Endif
If !clalev([F:CPYAFR]) : Local File HRCOMPANYAFR [F:CPYAFR] : Endif
If !clalev([F:XAIN])   : Local File CONTACTCRM   [F:XAIN]   : Endif
If !clalev([F:XCTR])   : Local File EMPLOCTR     [F:XCTR]   : Endif
If !clalev([F:XPOT])   : Local File POSTE        [F:XPOT]   : Endif
If !clalev([F:BPA])    : Local File BPADDRESS    [F:BPA]    : Endif
If !clalev([F:HRSDT])  : Local File HRSTADCLTRA  [HRSDT]    : Endif
If !clalev([F:HRSTB])  : Local File HRSTADCLBEN  [HRSTB]    : Endif
If !clalev([F:HRLOP])  : Local File HRLSTPMT     [HRLOP]    : Endif
If !clalev([F:HRTPY])  : Local File HRTOTPAY     [HRTPY]    : Endif
If !clalev([F:HREFT])  : Local File HREFFTOT     [HREFT]    : Endif
If !clalev([F:HRSBP])  : Local File HRSTADCLBSP  [HRSBP]    : Endif #LIPET : 2018-02-08 : HRSBP is changed to HRSBP due to the abbrev already occupied
If !clalev([F:CPY])    : Local File COMPANY      [CPY]      : Endif #DEHEN - Added Company since it still needs to be referenced

Openo LFICH, 0 Using[XXX]
adxirs = chr$(13)+chr$(10)
###Iomode adxium [V]GASCII Using     [XXX]

If [M:HRESD0]MDLDCL="9421" Then
  Read[F:HRSDS]HRSDS0 = [M:HRSDM0]MDLDCL
  If !fstat Then
  #JASMI - 2016-11-07 - X3PEOP-2602 - START
#    Read [F:CPYAFR]CPYAFR0=GSOC
    Read [F:CPYAFR]CPYAFR0=[M:HRESD0]CPY
  #JASMI - 2016-11-07 - X3PEOP-2602 - END
    If !fstat Then
      [L]XIDENTFIS=[F:CPYAFR]TAXNUM
      [L]CPYAFRNAM  =[F:CPYAFR]RGTNAM

      Filter[F:XAIN]
      Read [F:XAIN]AIN0=[F:CPY]CNTNAM
      If !fstat Then
        [L]XCNTLNA=[F:XAIN]CNTLNA
        [L]XCNTFNA=[F:XAIN]CNTFNA
      #JASMI - 2016-11-29 - 119566 - START
         # [L]XCIN=[F:XAIN]XG_CIN
         # [L]XCNSS=[F:XAIN]XG_NUMSC
         # [L]XCE=[F:XAIN]XG_NUMCE
         # infbox needs to be removed becuase these fields needs to be created on the CONTACTCRM, but this is in supervisor model.
        [L]XCIN=""
        [L]XCNSS=0
        [L]XCE=""
        If dim([F:XAIN]UIDCRDNUM)>0 : [L]XCIN=[F:XAIN]UIDCRDNUM : Endif
        If dim([F:XAIN]SSCNUM)>0    : [L]XCNSS=[F:XAIN]SSCNUM   : Endif
        If dim([F:XAIN]RDEPITNUM)>0 : [L]XCE=[F:XAIN]RDEPITNUM  : Endif
      #JASMI - 2016-11-29 - 119566 - END
      Endif

      Filter[F:BPA]
      Read [F:BPA]BPA0=2;[F:CPYAFR]CPY;[F:CPY]BPAADD ##2016/01/11 - DEHEN revert to default company
      If !fstat Then
        [L]XADRESSE=[F:BPA]BPAADDLIG(0)+" "+[F:BPA]BPAADDLIG(1)
        [L]XCOMMUNE=[F:BPA]BPAADDLIG(2)
      Endif
    Endif

    #===================== Entete fichier XML ==========================================#
    #Wrseq "<identifiantFiscal>Test</identifiantFiscal>" Using [XXX]
    Wrseq  mess(5,5000,1) Using [XXX]
    Wrseq  mess(2,5000,1)+mess(3,5000,1)+mess(4,5000,1)Using [XXX]

    #========== Identification du contribuable ==========================================#
    Wrseq "<TraitementEtSalaire>" Using [XXX]
    Wrseq "<identifiantFiscal>"+ctrans([L]XIDENTFIS)+"</identifiantFiscal>" Using [XXX]
    Wrseq "<nom>"+ctrans([L]XCNTLNA)+"</nom>" Using [XXX]
    Wrseq "<prenom>"+ctrans([L]XCNTFNA)+"</prenom>" Using [XXX]
    Wrseq "<raisonSociale>"+ctrans([L]CPYAFRNAM)+"</raisonSociale>" Using [XXX]
    Wrseq "<exerciceFiscalDu>"+num$(format$("D:YYYY[-]MM[-]DD",[M]STRDAT))+"</exerciceFiscalDu>" Using [XXX]
    Wrseq "<exerciceFiscalAu>"+num$(format$("D:YYYY[-]MM[-]DD",[M]ENDDAT))+"</exerciceFiscalAu>" Using [XXX]
    Wrseq "<annee>"+num$(year([M]STRDAT))+"</annee>" Using [XXX]

    Wrseq "<commune>" Using [XXX]
    Wrseq "<"+"code"+">"+ctrans([L]XCOMMUNE)+"</"+"code"+">" Using [XXX]
    Wrseq "</commune>" Using [XXX]
    Wrseq "<"+"adresse"+">"+ctrans([L]XADRESSE)+"</"+"adresse"+">" Using [XXX]

    Wrseq "<"+"numeroCIN"+">"+[L]XCIN+"</"+"numeroCIN"+">" Using [XXX]
    Wrseq "<"+"numeroCNSS"+">"+num$([L]XCNSS)+"</"+"numeroCNSS"+">" Using [XXX]
    Wrseq "<"+"numeroCE"+">"+[L]XCE+"</"+"numeroCE"+">" Using [XXX]

    Wrseq "<"+"numeroRC"+">"+[F:CPYAFR]RGTNUM+"</"+"numeroRC"+">" Using [XXX]
    Wrseq "<"+"numeroFax"+">"+[F:BPA]FAX+"</"+"numeroFax"+">" Using [XXX]
    Wrseq "<"+"numeroTelephone"+">"+[F:BPA]TEL(0)+"</"+"numeroTelephone"+">" Using [XXX]
    Wrseq "<"+"identifiantTP"+">"+[F:CPYAFR]TAXNUM+"</"+"identifiantTP"+">" Using [XXX]
    Wrseq "<"+"email"+">"+ctrans([F:BPA]WEB(0))+"</"+"email"+">" Using [XXX]

    #==========  Effectif  / totaux ==========================================#
  #JASMI - 2016-11-16 - X3PEOP-2602 - START
#    Read[F:HREFT]HREFT0=[M:HRSDM0]MDLDCL;[M:HRSDM0]STRDAT;[M:HRSDM0]ENDDAT
    Read[F:HREFT]HREFT0=[M:HRSDM0]MDLDCL;[M:HRSDM0]STRDAT;[M:HRSDM0]ENDDAT;[M:HRESD0]CPY
  #JASMI - 2016-11-16 - X3PEOP-2602 - END
    If !fstat Then
      Wrseq "<"+"effectifTotal"+">"+num$([F:HREFT]EFFTOT)+"</"+"effectifTotal"+">" Using [XXX]
      Wrseq "<"+"nbrPersoPermanent"+">"+num$([F:HREFT]NBRPEM)+"</"+"nbrPersoPermanent"+">" Using [XXX]
      Wrseq "<"+"nbrPersoOccasionnel"+">"+num$([F:HREFT]NBROCA)+"</"+"nbrPersoOccasionnel"+">" Using [XXX]
      Wrseq "<"+"nbrStagiaires"+">"+num$([F:HREFT]NBRTRE)+"</"+"nbrStagiaires"+">" Using [XXX]

      Wrseq "<"+"totalMtRevenuBrutImposablePP"+">"+num$([F:HREFT]TAXGROTAX)+"</"+"totalMtRevenuBrutImposablePP"+">" Using [XXX]
      Wrseq "<"+"totalMtRevenuNetImposablePP"+">"+num$([F:HREFT]TOTNETTAX)+"</"+"totalMtRevenuNetImposablePP"+">" Using [XXX]
      Wrseq "<"+"totalMtTotalDeductionPP"+">"+num$([F:HREFT]TOTMONDED)+"</"+"totalMtTotalDeductionPP"+">" Using [XXX]
      Wrseq "<"+"totalMtIrPrelevePP"+">"+num$([F:HREFT]TOTMONDED)+"</"+"totalMtIrPrelevePP"+">" Using [XXX]
      Wrseq "<"+"totalMtBrutSommesPO"+">"+num$([F:HREFT]TOTGROSMS)+"</"+"totalMtBrutSommesPO"+">" Using [XXX]
      Wrseq "<"+"totalIrPrelevePO"+">"+num$([F:HREFT]TOTPIC)+"</"+"totalIrPrelevePO"+">" Using [XXX]
      Wrseq "<"+"totalMtBrutTraitSalaireSTG"+">"+num$([F:HREFT]TOTGROSAL)+"</"+"totalMtBrutTraitSalaireSTG"+">" Using [XXX]
      Wrseq "<"+"totalMtBrutIndemnitesSTG"+">"+num$([F:HREFT]TOTGROALW)+"</"+"totalMtBrutIndemnitesSTG"+">" Using [XXX]
      Wrseq "<"+"totalMtRetenuesSTG"+">"+num$([F:HREFT]TOTDED)+"</"+"totalMtRetenuesSTG"+">" Using [XXX]
      Wrseq "<"+"totalMtRevenuNetImpSTG"+">"+num$([F:HREFT]TOTINCAMT)+"</"+"totalMtRevenuNetImpSTG"+">" Using [XXX]
      Wrseq "<"+"totalSommePayeRTS"+">"+num$([F:HREFT]TOTSUMPAY)+"</"+"totalSommePayeRTS"+">" Using [XXX]
      Wrseq "<"+"totalmtAnuuelRevenuSalarial"+">"+num$([F:HREFT]TOTANNWAGINC)+"</"+"totalmtAnuuelRevenuSalarial"+">" Using [XXX]
      Wrseq "<"+"totalmtAbondement"+">"+num$([F:HREFT]TOTEMRCON)+"</"+"totalmtAbondement"+">" Using [XXX]
      Wrseq "<"+"montantPermanent"+">"+num$([F:HREFT]PEMAMT)+"</"+"montantPermanent"+">" Using [XXX]
      Wrseq "<"+"montantOccasionnel"+">"+num$([F:HREFT]CASAMT)+"</"+"montantOccasionnel"+">" Using [XXX]
      Wrseq "<"+"montantStagiaire"+">"+num$([F:HREFT]TREAMT)+"</"+"montantStagiaire"+">" Using [XXX]
    Endif

  #***************************
    Wrseq "<"+"referenceDeclaration"+">"+"</"+"referenceDeclaration"+">" Using [XXX]
  #***************************

  #========== Personnel permanent ==========================================#
    Wrseq "<listPersonnelPermanent>" Using [XXX]
    For [F:HRIDC] Where [HRIDC]MDLDCL=[M:HRSDM0]MDLDCL and month([HRIDC]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRIDC]STRDAT)=year([M:HRSDM0]STRDAT)
&                 and month([HRIDC]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRIDC]ENDDAT)=year([M:HRSDM0]ENDDAT) and [F:HRIDC]EMPTYP=1
&                 and [F:HRIDC]CPY=[M:HRESD0]CPY #JASMI - 2016-11-16 - X3PEOP-2602 - START
      Wrseq "<PersonnelPermanent>" Using [XXX]
      #Données administratives
      For XI=1 To [F:HRSDS]NBRCOL
        If [F:HRIDC]TITFLD(XI-1)<>""  Then
          If !find([F:HRSDS]POS(XI-1),8,9,10,11)
            If [F:HRSDS]CODTYP(XI-1)="D" Then
              Raz  [L]XDATFLD
              [L]XDATFLD=num$(format$("D:YYYY[-]MM[-]DD",[F:HRIDC]FLD(XI-1)))
              If vireblc([L]XDATFLD,4)="--" Then [L]XDATFLD="" : Endif
              Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">"+[L]XDATFLD+"</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
            Else
              Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">"+ctrans([F:HRIDC]FLD(XI-1))+"</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
            Endif
          Endif
        Endif
      Next
    #***************************
      Wrseq "<"+"ifu"+">"+"</"+"ifu"+">" Using [XXX]
    #***************************
      #Rubriques
      For XI=1 To [F:HRSDS]NBRCOL
        If [F:HRIDC]DESCOL(XI-1)<>""  Then
          Wrseq "<"+[F:HRIDC]DESCOL(XI-1)+">"+num$([F:HRIDC]AMT(XI-1))+"</"+[F:HRIDC]DESCOL(XI-1)+">" Using [XXX]
        Endif
      Next

      Wrseq "<"+"casSportif"+">"+"false"+"</"+"casSportif"+">" Using [XXX] #Ajouté Suite à la demande de Abdellatif

      #Suite Données administratives
      For XI=1 To [F:HRSDS]NBRCOL
        If [F:HRIDC]TITFLD(XI-1)<>""  Then
          If find([F:HRSDS]POS(XI-1),8,9,10,11)
            If instr(1,[F:HRSDS]FLD(XI-1),"]SITFAM") Then #Situation familiale
              Gosub XSITUATION
              Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
              Wrseq "<"+"code"+">"+[L]XVALEUR_ZONE+"</"+"code"+">" Using [XXX]
              Wrseq "</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
            Elsif instr(1,[F:HRSDS]FLD(XI-1),"]XG_FRAISPRO") Then #Frais professionnels
              Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
              Wrseq "<"+"code"+">"+ctrans([F:HRIDC]FLD(XI-1))+"</"+"code"+">" Using [XXX]
              Wrseq "</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
            Else
              If [F:HRSDS]CODTYP(XI-1)="D" Then
                Raz [L]XDATFLD
                [L]XDATFLD=num$(format$("D:YYYY[-]MM[-]DD",[F:HRIDC]FLD(XI-1)))
                If vireblc([L]XDATFLD,4)="--" Then [L]XDATFLD="" : Endif
                Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">"+ [L]XDATFLD+"</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
              Else
                Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">"+ctrans([F:HRIDC]FLD(XI-1))+"</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
              Endif
              If [F:HRSDS]POS(XI-1)=9 Then #Date permis suivi de date d'autorisation
                Wrseq "<"+"dateAutorisation"+">"+"</"+"dateAutorisation"+">" Using [XXX]
              Endif
            Endif
          Endif
        Endif
      Next
      Wrseq "</PersonnelPermanent>" Using [XXX]
    Next
    Wrseq "</listPersonnelPermanent>" Using [XXX]

 #========== Personnels Occasionnels ==========================================#
    Filter [F:HRIDC]
    Wrseq "<listPersonnelOccasionnel>" Using [XXX]
    For [F:HRIDC] Where [HRIDC]MDLDCL=[M:HRSDM0]MDLDCL and month([HRIDC]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRIDC]STRDAT)=year([M:HRSDM0]STRDAT)
&                 and month([HRIDC]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRIDC]ENDDAT)=year([M:HRSDM0]ENDDAT) and [F:HRIDC]EMPTYP =2
&                 and [HRIDC]CPY=[M:HRESD0]CPY #JASMI - 2016-11-16 - X3PEOP-2602 - START
      Wrseq "<PersonnelOccasionnel>" Using [XXX]

      #Données administratives
      For XI=1 To [F:HRSDS]NBRCOL
        If [F:HRIDC]TITFLD(XI-1)<>"" Then
          Wrseq "<"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">"+ctrans([F:HRIDC]FLD(XI-1))+"</"+vireblc([F:HRIDC]TITFLD(XI-1),4)+">" Using [XXX]
        Endif
      Next
    #******************************************
      Wrseq "<"+"ifu"+">"+"</"+"ifu"+">" Using [XXX]
    #******************************************
    #Rubriques personnels occasionnels
      For XI=1 To [F:HRSDS]NBRCOL
        If [F:HRIDC]DESCOL(XI-1)<>"" Then
          Wrseq "<"+[F:HRIDC]DESCOL(XI-1)+">"+num$([F:HRIDC]AMT(XI-1))+"</"+[F:HRIDC]DESCOL(XI-1)+">" Using [XXX]
        Endif
      Next

      #Profession
      Raz [L]XDESPOSTE
      Filter [F:XCTR] Order By [F:XCTR]CTRDAT Desc
      Read[F:XCTR]First
      If !fstat Then
        Read[F:XPOT]POT0=[XCTR]POT
        If !fstat Then
          [L]XDESPOSTE=[F:XPOT]DES
        Endif
      Endif
      Filter[F:XCTR]: Filter [F:XPOT]

      Wrseq "<"+"profession"+">"+ctrans([L]XDESPOSTE)+"</"+"profession"+">" Using [XXX]
      Wrseq "</PersonnelOccasionnel>" Using [XXX]
    Next
    Wrseq "</listPersonnelOccasionnel>" Using [XXX]

   #=========================  Stagiares =========================================#
    Wrseq "<listStagiaires>" Using [XXX]
  #JASMI - 2016-11-16 - X3PEOP-2602 - START
#    For[F:HRSDT] Where [HRSDT]MDLDCL=[M:HRSDM0]MDLDCL and month([HRSDT]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRSDT]STRDAT)=year([M:HRSDM0]STRDAT)
#&                      and month([HRSDT]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRSDT]ENDDAT)=year([M:HRSDM0]ENDDAT)
    Link [F:HRSDT]
&   With      [ID7]ID0 = [HRSDT]EMP
&   As        [LNK]
&   Where     [HRSDT]MDLDCL=[M:HRSDM0]MDLDCL
&             and month([HRSDT]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRSDT]STRDAT)=year([M:HRSDM0]STRDAT)
&             and month([HRSDT]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRSDT]ENDDAT)=year([M:HRSDM0]ENDDAT)
&             and [ID7]CPY=[M:HRESD0]CPY
    For [LNK]
  #JASMI - 2016-11-16 - X3PEOP-2602 - END
      Wrseq "<Stagiaire>" Using [XXX]
      Wrseq "<"+"nom"+">"+ctrans([F:HRSDT]NAM)+"</"+"nom"+">" Using [XXX]
      Wrseq "<"+"prenom"+">"+ctrans([F:HRSDT]SRN)+"</"+"prenom"+">" Using [XXX]
      Wrseq "<"+"adressePersonnelle"+">"+ctrans([F:HRSDT]ADD2)+"</"+"adressePersonnelle"+">" Using [XXX]
      Wrseq "<"+"numCNI"+">"+[F:HRSDT]TPYSOCNUM+"</"+"numCNI"+">" Using [XXX]
      Wrseq "<"+"numCE"+">"+[F:HRSDT]RDEPITNUM+"</"+"numCE"+">" Using [XXX]
      Wrseq "<"+"numPPR"+">"+[F:HRSDT]NUMPPR+"</"+"numPPR"+">" Using [XXX]
      Wrseq "<"+"numCNSS"+">"+num$([F:HRSDT]SSCNUM)+"</"+"numCNSS"+">" Using [XXX]
      Wrseq "<"+"ifu"+">"+num$([F:HRSDT]IFU)+"</"+"ifu"+">" Using [XXX]
      Wrseq "<"+"mtBrutTraitementSalaire"+">"+num$([F:HRSDT]GROSAL)+"</"+"mtBrutTraitementSalaire"+">" Using [XXX]
      Wrseq "<"+"mtBrutIndemnites"+">"+ num$([F:HRSDT]GRONSS)+"</"+"mtBrutIndemnites"+">" Using [XXX]
      Wrseq "<"+"mtRetenues"+">"+num$([F:HRSDT]DEDAMT)+"</"+"mtRetenues"+">" Using [XXX]
      Wrseq "<"+"mtRevenuNetImposable"+">"+ num$([F:HRSDT]RVNAMT)+"</"+"mtRevenuNetImposable"+">" Using [XXX]
      Wrseq "<"+"periode"+">"+ num$([F:HRSDT]PER)+"</"+"periode"+">" Using [XXX]
      Wrseq "</Stagiaire>" Using [XXX]
    Next
    Filter [HRSDT]
    Wrseq "</listStagiaires>" Using [XXX]

#=========================  Bénéficiaires =========================================#
    Wrseq "<listBeneficiaires>" Using [XXX]
  #JASMI - 2016-11-16 - X3PEOP-2602 - START
#    For[F:HRSTB] Where [HRSTB]MDLDCL=[M:HRSDM0]MDLDCL and month([HRSTB]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRSTB]STRDAT)=year([M:HRSDM0]STRDAT)
#&                      and month([HRSTB]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRSTB]ENDDAT)=year([M:HRSDM0]ENDDAT)
    Link [F:HRSTB]
&   With      [ID7]ID0 = [HRSTB]EMP
&   As        [LNK]
&   Where     [HRSTB]MDLDCL=[M:HRSDM0]MDLDCL
&             and month([HRSTB]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRSTB]STRDAT)=year([M:HRSDM0]STRDAT)
&             and month([HRSTB]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRSTB]ENDDAT)=year([M:HRSDM0]ENDDAT)
&             and [ID7]CPY=[M:HRESD0]CPY
    For [LNK]
  #JASMI - 2016-11-16 - X3PEOP-2602 - END
      Wrseq "<Benefiaire>" Using [XXX]
      Wrseq "<"+"nom"+">"+ctrans([F:HRSTB]NAM)+"</"+"nom"+">" Using [XXX]
      Wrseq "<"+"prenom"+">"+ctrans([F:HRSTB]SRN)+"</"+"prenom"+">" Using [XXX]
      Wrseq "<"+"adressePersonnelle"+">"+ctrans([F:HRSTB]ADD)+"</"+"adressePersonnelle"+">" Using [XXX]
      Wrseq "<"+"numCNI"+">"+[F:HRSTB]TPYSOCNUM+"</"+"numCNI"+">" Using [XXX]
      Wrseq "<"+"numCE"+">"+[F:HRSTB]RDEPITNUM+"</"+"numCE"+">" Using [XXX]
      Wrseq "<"+"numPPR"+">"+[F:HRSTB]NUMPPR +"</"+"numPPR"+">" Using [XXX]
      Wrseq "<"+"numCNSS"+">"+num$([F:HRSTB]SSCNUM)+"</"+"numCNSS"+">" Using [XXX]
      Wrseq "<"+"ifu"+">"+num$([F:HRSTB]IFU)+"</"+"ifu"+">" Using [XXX]
      Wrseq "<"+"organisme"+">"+[F:HRSTB]ORG+"</"+"organisme"+">" Using [XXX]
      Wrseq "<"+"nbrActionsAquises"+">"+ num$([F:HRSTB]NUMACNACQ)+"</"+"nbrActionsAquises"+">" Using [XXX]
      Wrseq "<"+"nbrActionsDistribuees"+">"+num$([F:HRSTB]NUMACNREP)+"</"+"nbrActionsDistribuees"+">" Using [XXX]
      Wrseq "<"+"prixAcquisition"+">"+ num$([F:HRSTB]PURPRI)+"</"+"prixAcquisition"+">" Using [XXX]
      Wrseq "<"+"valeurActionAttribution"+">"+ num$([F:HRSTB]ACNAWAVAL)+"</"+"valeurActionAttribution"+">" Using [XXX]
      Wrseq "<"+"valeurActionLeveeOption"+">"+ num$([F:HRSTB]VALACNLEV)+"</"+"valeurActionLeveeOption"+">" Using [XXX]
      Wrseq "<"+"mtAbondement"+">"+ num$([F:HRSTB]MHTEMPCON)+"</"+"mtAbondement"+">" Using [XXX]
      Wrseq "<"+"nbrActionsCedees"+">"+ num$([F:HRSTB]NUMSOLACT)+"</"+"nbrActionsCedees"+">" Using [XXX]
      Wrseq "<"+"complementSalaire"+">"+ num$([F:HRSTB]SALSUP)+"</"+"complementSalaire"+">"Using [XXX]

      If [F:HRSTB]GRADAT<>[0/0/0] Then
          Wrseq "<"+"dateAttribution"+">"+num$(format$("D:YYYY[-]MM[-]DD",[F:HRSTB]GRADAT)) +"</"+"dateAttribution"+">" Using [XXX]
      Else
          Wrseq "<"+"dateAttribution"+">"+"</"+"dateAttribution"+">" Using [XXX]
      Endif

      If [F:HRSTB]DATLEVOPT <>[0/0/0] Then
         Wrseq "<"+"dateLeveOption"+">"+ num$(format$("D:YYYY[-]MM[-]DD",[F:HRSTB]DATLEVOPT )) +"</"+"dateLeveOption"+">" Using [XXX]
      Else
         Wrseq "<"+"dateLeveOption"+">" +"</"+"dateLeveOption"+">" Using [XXX]
      Endif

      If [F:HRSTB]DATASN<>[0/0/0] Then
          Wrseq "<"+"dateCession"+">"+  num$(format$("D:YYYY[-]MM[-]DD",[F:HRSTB]DATASN)) +"</"+"dateCession"+">" Using [XXX]
      Else
          Wrseq "<"+"dateCession"+">"+"</"+"dateCession"+">" Using [XXX]
      Endif

      Wrseq "</Benefiaire>" Using [XXX]
    Next
    Filter [HRSTB]
    Wrseq "</listBeneficiaires>" Using [XXX]

#=========================  Bénéficiare plan d'epargne =========================================#
    Wrseq "<listBeneficiairesPlanEpargne>" Using [XXX]
    For [F:HRSBP] Where [HRSBP]MDLDCL=[M:HRSDM0]MDLDCL
&                       and month([HRSBP]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRSBP]STRDAT)=year([M:HRSDM0]STRDAT)
&                       and month([HRSBP]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRSBP]ENDDAT)=year([M:HRSDM0]ENDDAT)
&                       and [HRSBP]CPY=[M:HRESD0]CPY #JASMI - 2016-11-16 - X3PEOP-2602 - START
      Wrseq "<BeneficiairePlanEpargne>" Using [XXX]
      Wrseq "<"+"nom"+">"+ctrans([F:HRSBP]NAM)+"</"+"nom"+">" Using [XXX]
      Wrseq "<"+"prenom"+">"+ctrans([F:HRSBP]SRN)+"</"+"prenom"+">" Using [XXX]
      Wrseq "<"+"adressePersonnelle"+">"+ctrans([F:HRSBP]ADD1)+"</"+"adressePersonnelle"+">" Using [XXX]
      Wrseq "<"+"numCNI"+">"+[F:HRSBP]TPYSOCNUM+"</"+"numCNI"+">" Using [XXX]
      Wrseq "<"+"numCE"+">"+[F:HRSBP]RDEPITNUM+"</"+"numCE"+">" Using [XXX]
      Wrseq "<commune>" Using [XXX]
      Wrseq "<"+"code"+">"+ctrans([F:HRSBP]MUNCOD)+"</"+"code"+">" Using [XXX]
      Wrseq "</commune>" Using [XXX]
      Wrseq "<"+"numPlan"+">"+[F:HRSBP]PLNNUM+"</"+"numPlan"+">" Using [XXX]
      Wrseq "<"+"duree"+">"+num$([F:HRSBP]DUR)+"</"+"duree"+">" Using [XXX]

      If [F:HRSBP]OPNDAT <>[0/0/0] Then
         Wrseq "<"+"dateOuverture"+">"+num$(format$("D:YYYY[-]MM[-]DD",[F:HRSBP]OPNDAT))+"</"+"dateOuverture"+">" Using [XXX]
      Else
         Wrseq "<"+"dateOuverture"+">"+"</"+"dateOuverture"+">" Using [XXX]
      Endif

      Wrseq "<"+"mtAbondement"+">"+num$([F:HRSBP]EMRCTBAMT)+"</"+"mtAbondement"+">" Using [XXX]
      Wrseq "<"+"mtAnuuelRevenuSalarial"+">"+num$([F:HRSBP]MTNANN)+"</"+"mtAnuuelRevenuSalarial"+">" Using [XXX]
      Wrseq "</BeneficiairePlanEpargne>" Using [XXX]
    Next
    Wrseq "</listBeneficiairesPlanEpargne>" Using [XXX]

#=========================  Liste versement =========================================#
    Wrseq "<listVersements>" Using [XXX]
  #JASMI - 2016-11-16 - X3PEOP-2602 - START
#    Filter [HRTPY] Where [HRTPY]MDLDCL=[M:HRSDM0]MDLDCL
#&                        and month([HRTPY]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRTPY]STRDAT)=year([M:HRSDM0]STRDAT)
#&                        and month([HRTPY]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRTPY]ENDDAT)=year([M:HRSDM0]ENDDAT)
#&                  Order By [F:HRTPY]MON
    Filter [HRTPY] Where [HRTPY]MDLDCL=[M:HRSDM0]MDLDCL
&                        and month([HRTPY]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRTPY]STRDAT)=year([M:HRSDM0]STRDAT)
&                        and month([HRTPY]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRTPY]ENDDAT)=year([M:HRSDM0]ENDDAT)
&                        and [HRTPY]CPY=[M:HRESD0]CPY
&                  Order By [F:HRTPY]MON
  #JASMI - 2016-11-16 - X3PEOP-2602 - END
    For [HRTPY]
      Wrseq "<VersementTraitementSalaire>" Using [XXX]
      Wrseq "<"+"mois"+">"+ num$([F:HRTPY]MON)+"</"+"mois"+">" Using [XXX]
      Wrseq "<"+"totalVersement"+">"+ num$([F:HRTPY]TOTPAY)+"</"+"totalVersement"+">" Using [XXX]
      If [F:HRTPY]LSTDAT<>[0/0/0] Then
        Wrseq "<"+"dateDerniereVersment"+">"+num$(format$("D:YYYY[-]MM[-]DD",[F:HRTPY]LSTDAT))+"</"+"dateDerniereVersment"+">" Using [XXX]
      Else
        Wrseq "<"+"dateDerniereVersment"+">"+"</"+"dateDerniereVersment"+">" Using [XXX]
      Endif
      Wrseq "<listDetailPaiement>" Using [XXX]

      For [F:HRLOP] Where [HRLOP]MDLDCL=[M:HRSDM0]MDLDCL
&                         and month([HRSTB]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRLOP]STRDAT)=year([M:HRSDM0]STRDAT)
&                         and month([HRLOP]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRLOP]ENDDAT)=year([M:HRSDM0]ENDDAT)
&                         and [F:HRLOP]MON=[F:HRTPY]MON
&                         and [HRLOP]CPY=[M:HRESD0]CPY #JASMI - 2016-11-16 - X3PEOP-2602 - START
        Wrseq "<DetailPaiementTraitementSalaire>" Using [XXX]
        Wrseq "<"+"reference"+">"+ctrans([F:HRLOP]REF)+"</"+"reference"+">" Using [XXX]
        Wrseq "<"+"totalVerse"+">"+num$([F:HRLOP]TOTPAY)+"</"+"totalVerse"+">" Using [XXX]
        Wrseq "<"+"principal"+">"+num$([F:HRLOP]MAIPAY)+"</"+"principal"+">" Using [XXX]
        Wrseq "<"+"penalite"+">"+num$([F:HRLOP]PNTPAY)+"</"+"penalite"+">" Using [XXX]
        Wrseq "<"+"majoration"+">"+num$([F:HRLOP]INC)+"</"+"majoration"+">" Using [XXX]
        If [F:HRLOP]DATPAY<>[0/0/0] Then
           Wrseq "<"+"dateVersement"+">"+num$(format$("D:YYYY[-]MM[-]DD",[F:HRLOP]DATPAY))+"</"+"dateVersement"+">" Using [XXX]
        Else
           Wrseq "<"+"dateVersement"+">"+"</"+"dateVersement"+">" Using [XXX]
        Endif

        Wrseq "<refMoyenPaiement>" Using [XXX]
        Wrseq "<"+"code"+">"+[F:HRLOP]MOYPAY+"</"+"code"+">" Using [XXX]
        Wrseq "</refMoyenPaiement>" Using [XXX]
        Wrseq "<"+"numQuittance"+">"+[F:HRLOP]RCPNUM+"</"+"numQuittance"+">" Using [XXX]

        Wrseq "</DetailPaiementTraitementSalaire>" Using [XXX]
      Next
      Wrseq "</listDetailPaiement>" Using [XXX]
      Wrseq "</VersementTraitementSalaire>" Using [XXX]
    Next
    Wrseq "</listVersements>" Using [XXX]
    Wrseq "</TraitementEtSalaire>" Using [XXX]
  Endif
Endif
Openo Using[XXX]
End

##====================================================================================================
$XSITUATION
If [F:HRIDC]FLD(XI-1)="1" Then
  [L]XVALEUR_ZONE = "C"
Elsif [F:HRIDC]FLD(XI-1)="2"
  [L]XVALEUR_ZONE = "M"
Elsif[F:HRIDC]FLD(XI-1)="3"
  [L]XVALEUR_ZONE = "D"
Elsif [F:HRIDC]FLD(XI-1)="4"
  [L]XVALEUR_ZONE = "V"
Endif
Return
##====================================================================================================
#

