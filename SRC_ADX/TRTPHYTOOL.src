####################################################################
# Numérotation des éléments physiques à partir du bien
####################################################################
################################################################
# VERIF_UNICITE_BAC : Vérification de l'unicité du code à barre
################################################################
# Parameters E : PBAC     code à barre à tester
#            E ; PCPY     société si unicité par société
#            S : VUNIQUE  unicité code à barre Oui/Non
################################################################
Subprog VERIF_UNICITE_BAC(PBAC,PCPY,VUNIQUE)
Value Char PBAC
Value Char PCPY
Variable Integer VUNIQUE
  VUNIQUE = G_OUI

  If PBAC = "" Then End Endif

  Local Integer OPENFILE : OPENFILE=0
  If !(clalev([F:PHYX])) Then
    Local File PHYELT [PHYX]
    OPENFILE=1
  Endif
  If (GCPYBACUNY = G_OUI) Then
    Look [PHYX]PHY3=PBAC;PCPY
  Else
    Look [PHYX]PHY3=PBAC
  Endif
  If !(fstat) Then
    VUNIQUE = G_NON
  Endif
  If OPENFILE=1 Then
    Close Local File [F:PHYX]
  Endif

End

