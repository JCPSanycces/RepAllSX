######################################################################################
# Declaration des variables gbobales pour éléments physiques(TRTFASTRF)
######################################################################################
Subprog DEC_GLO_PHY
     # Variable globale nombre d'élément physique en attente
     If dim(SV_NBELTATT) <0 Then : Global Integer SV_NBELTATT : Endif
     # Variable globale localisation d'élément physique en attente
     If dim(SV_LOCD) <0 Then : Global Char SV_LOCD : Endif
     # Variable globale eléments physiques rattachés au bien
     If dim(SV_ELTPHYRAT) <0 Then : Global Integer SV_ELTPHYRAT : Endif
     # Variable globale pour transfert imputation inchangée
     If dim(SV_IMPUT_INCH) <0 Then : Global Integer SV_IMPUT_INCH : SV_IMPUT_INCH = G_NON : Endif

End
######################################################################################
# KILL des variables gbobales pour éléments physiques(TRTFASTRF)
######################################################################################
Subprog KIL_GLO_PHY
   # Variable GLOBALE NOMBRE D'élément physique en attente
   If dim(SV_NBELTATT)>0 Then Kill SV_NBELTATT Endif
   # Variable globale localisation d'élément physique en attente
   If dim(SV_LOCD)>0 Then Kill SV_LOCD Endif
   # Variable globale eléments physiques rattachés au bien
   If dim(SV_ELTPHYRAT)>0 Then Kill SV_ELTPHYRAT Endif
   # Variable globale pour transfert imputation inchangée
   If dim(SV_IMPUT_INCH)>0 Then Kill SV_IMPUT_INCH Endif
End



