#-------------------------------------------------------------------------------------------------
# Recherche si les biens composants sont reliés au bien principal
#-------------------------------------------------------------------------------------------------
Funprog RECH_COMP_FAS_PRINC(REF)
 Value Char    REF        : # Référence du bien
 Local Integer OPENFILE, RETOUR

 RETOUR = 0

 If REF = "" Then
    End RETOUR
 Endif

 If !(clalev([F:FASW])) Then
   Local File FXDASSETS [FASW]
   OPENFILE=1
 Endif

 Filter [F:FASW] Where (CMP=REF)
 RETOUR = rowcount ([F:FASW])
 Filter [F:FASW]

 If OPENFILE=1 Then
    Close Local File [F:FASW]
 Endif

End RETOUR


######################################################################################
# Alimentation de la trace avec les éléments physiques transférés (TRTFASTRF)
# Décalage de 2 caractères vers la droite de l'élément physique et de sa désignation
######################################################################################
Subprog DETAIL_ELT_PHY_COMPTE_RENDU(PREF,PDES1,CLASDES)
Value Char PREF,PDES1,CLASDES
Local Char AFF_PHYREF, AFF_PHYDES1(70)
  AFF_PHYREF = "  "+PREF
  AFF_PHYDES1 = "  "+PDES1
  If ACTSILENCE=G_OUI
     GT_OBJ_REF(I_OBJ)=AFF_PHYREF
     GT_OBJ_DES(I_OBJ)=AFF_PHYDES1
     I_OBJ+=1
  Else
     Call BCO_COMPTE_RENDU(evalue(CLASDES+"CPY"),AFF_PHYREF,AFF_PHYDES1,"") From TRTFASTRF
  Endif
End
