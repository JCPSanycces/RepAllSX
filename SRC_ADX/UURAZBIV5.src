#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Raz table BI avant intégration du dico V6.1 standard
#----------------------------------------------------------------------------------------#
Call OUVRE_TRACE("Raz table BI pour la V6.1") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call OUINON("Raz table BI pour la V6.1 sur le dossier"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 Call PATCH(nomap)
Else
 Call OUINON("Raz table BI pour la V6.1 sur tous les dossiers filles de"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If GPRODUIT <> 0 : End : Endif
Gosub RAZBI
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
If GPRODUIT <> 0 : End : Endif
Gosub RAZBI
End

#-------------------#
$RAZBI

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS([L]DOSSIER,"ABI") 
 Return
Endif

Local File =DOSSIER+".ADOVAL"       [ADW] 
Local File =DOSSIER+".ABICOND"      [AII] 
Local File =DOSSIER+".ABIDATMRT"    [ABM]
Local File =DOSSIER+".ABIDIM"       [ABI]
Local File =DOSSIER+".ABIDIMFLD"    [ABJ]
Local File =DOSSIER+".ABIHIERA"     [AHH]
Local File =DOSSIER+".ABIREGDES"    [ABY]
Local File =DOSSIER+".ABIREGORG"    [ABV]
Local File =DOSSIER+".ABIREPORT"    [ABO]
Local File =DOSSIER+".ABIREPORTD"   [ABQ]
Local File =DOSSIER+".ABITABAGG"    [ABE]
Local File =DOSSIER+".ABITABDAT"    [ABF]
Local File =DOSSIER+".ABITABFLD"    [ABZ]
Local File =DOSSIER+".ABITABIND"    [ABX]
Local File =DOSSIER+".ABITABLNK"    [ABK]
Local File =DOSSIER+".ABITRAUNV"    [ATV]

Read [ADW]ADW0="";"";"RAZBIV5"
If !fstat & [F:ADW]VALEUR = "2"
 Return
Endif

# Raz des tables BI
Trbegin [AII]
  ### Datamart
  Call ECR_TRACE(mess(81,125,1)-"ABIDATMRT:"-time$,0) From GESECRAN
  For [ABM] Where COD<"X" and CODACT<"X"
   # Traduction 
   Delete [ATV] Where ABM=[F:ABM]COD
   If fstat : Call ERREUR("ABITRAUNV",3) From DOSDIC : Endif
   Delete [ABM]Curr
   If fstat : Call ERREUR("ABIDATMRT",3) From DOSDIC : Endif
  Next

  ### Table de fait
  Call ECR_TRACE(mess(81,125,1)-"ABITABDAT:"-time$,0) From GESECRAN
  For [ABF] Where CODABF<"X" and CODACT<"X"
   # Champs 
   Delete [ABZ] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABFLD",3) From DOSDIC : Endif
   # Liens 
   Delete [ABK] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABLNK",3) From DOSDIC : Endif
   # Index 
   Delete [ABX] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABIND",3) From DOSDIC : Endif
   # Index 
   Delete [ABE] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABAGG",3) From DOSDIC : Endif
   # table de fait
   Delete [ABF]Curr
   If fstat : Call ERREUR("ABITABDAT",3) From DOSDIC : Endif
  Next 

  ### Dimensions
  Call ECR_TRACE(mess(81,125,1)-"ABIDIM:"-time$,0) From GESECRAN
  For [ABI] Where CODDIM<"X" and CODACT<"X"
   # Champs 
   Delete [ABJ] Where CODDIM=[F:ABI]CODDIM
   If fstat : Call ERREUR("ABIDIMFLD",3) From DOSDIC : Endif
   # table de fait
   Delete [ABI]Curr
   If fstat : Call ERREUR("ABIDIM",3) From DOSDIC : Endif
  Next

  ### hierarchies
  Call ECR_TRACE(mess(81,125,1)-"ABIHIERA:"-time$,0) From GESECRAN
  Delete [AHH] Where COD<"X" and ACV<"X"
  If fstat : Call ERREUR("ABIHIERA",3) From DOSDIC : Endif

  ### Conditions prédéfinies
  Call ECR_TRACE(mess(81,125,1)-"ABICOND:"-time$,0) From GESECRAN
  Delete [AII] Where COD<"X" and ACV<"X"
  If fstat : Call ERREUR("ABICOND",3) From DOSDIC : Endif

  ### Regle de synchro
  Call ECR_TRACE(mess(81,125,1)-"ABIREGDORG:"-time$,0) From GESECRAN
  For [ABV] Where CODREG<"X" and CODACT<"X"
   # destinations 
   Delete [ABY] Where CODREG=[F:ABV]CODREG
   If fstat : Call ERREUR("ABIREGDES",3) From DOSDIC : Endif
   # table de fait
   Delete [ABV]Curr
   If fstat : Call ERREUR("ABIREGORG",3) From DOSDIC : Endif
  Next

  ### Etat Bo
  Call ECR_TRACE(mess(81,125,1)-"ABIREPORT:"-time$,0) From GESECRAN
  For [ABO] Where COD<"X" and ACV<"X"
   # Index 
   Delete [ABQ] Where COD=[F:ABO]COD
   If fstat : Call ERREUR("ABIREPORTD",3) From DOSDIC : Endif
   # table de fait
   Delete [ABO]Curr
   If fstat : Call ERREUR("ABIREPORT",3) From DOSDIC : Endif
  Next

  #### Ecriture parametre RAZBIV5
  Read [ADW]ADW0="";"";"RAZBIV5"
  If !fstat
   [F:ADW]VALEUR = "2"
   Rewrite [ADW]
   If fstat : Call ERREUR("ADOVAL : RAZBIV5",2) From DOSDIC : Endif
  Else
   Raz [F:ADW]
   [F:ADW]PARAM  = "RAZBIV5"
   [F:ADW]VALEUR = "2"
   Write [F:ADW]
   If fstat : Call ERREUR("ADOVAL : RAZBIV5",1) From DOSDIC : Endif
  Endif

Commit

Close Local File [ADW],[AII],[ABM],[ABI],[ABJ],[AHH],[ABY],[ABV],[ABQ],[ABE],[ABF],[ABZ],[ABX],[ABK],[ATV],[ABO]

Return



