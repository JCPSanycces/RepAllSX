#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"      : Gosub IMPORT
 When "IMP_TAB"     : Gosub IMP_TAB

Endcase
Return


$IMPORT
Case IMPFIC
 When "GDA" : # En-tête

  If GREP="C" :  Raz [M:GDA1] : Endif

  [M:GDA1] = [F:GDA]

  OGLANGUE = GLANGUE
  GLANGUE = "imp"
  Call LECTEXTRA([M:GDA1]DESTRA,"GDIAACC","DESTRA",[M:GDA1]DIA,"") From ATEXTRA
  Call LECTEXTRA([M:GDA1]SHOTRA,"GDIAACC","SHOTRA",[M:GDA1]DIA,"") From ATEXTRA
  Call SUPTEXLAN("GDIAACC","DESTRA",GLANGUE,[M:GDA1]DIA,"") From ATEXTRA
  Call SUPTEXLAN("GDIAACC","SHOTRA",GLANGUE,[M:GDA1]DIA,"") From ATEXTRA
  GLANGUE = OGLANGUE

 When "GDC" : # Lignes

  ## Recherche du numéro de ligne en modif
  If GREP="M" & [F:GDC]LINNUM>=1 & [F:GDC]LINNUM<=[M]NBRACC : # Modif ligne existante
   nolign = [F:GDC]LINNUM
  Else                                               : # Ajout d'une ligne
   [M]NBRACC += 1
   nolign = [M]NBRACC
  Endif

Endcase
Return


$IMP_TAB
If left$(IMPZON,3) = "ACC"
 I = val(right$(IMPZON,4))
 Assign "[M]ACC"+num$(I)+"("+num$(indice)+")" With evalue("[F:GDC]ACC("+num$(I-1)+")")
Elsif left$(IMPZON,3) = "CCE"
 I = val(right$(IMPZON,4))
 Assign "[M]CCE"+num$(I)+"("+num$(indice)+")" With evalue("[F:GDC]CCE("+num$(I-1)+")")
Endif
Return


