#<AdxTL>@(#)12.0.0.0 $Revision$
#-----------------------------------------------------#
# Contrôle d'existence d'un dossier
#-----------------------------------------------------#
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Char MACHINE(GDIMFIC), APPLI(GDIMFIC)
VALEUR = ctrans(vireblc(VALEUR,4))
If instr(1,VALEUR,"@")>0
 Call MACHINE(VALEUR,MACHINE,APPLI) From ORDSYS
 VALEUR = MACHINE+"@"+toupper(APPLI)
Else
 VALEUR = toupper(VALEUR)
Endif
Call LECDOS(VALEUR)
End

#-----------------------------------------------------#
Subprog TYPDOS(DOSSIER,PRODUIT,NAMDOS)
Value Char DOSSIER
Variable Integer PRODUIT
Variable Char NAMDOS
Local Integer ER
Onerrgo ERDOS
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 Local File ADOVAL [ADW_]
 Read [ADW_]ADW0 = "";"";"TYPDOS"
 If !ER & !fstat
  NAMDOS= func APRODUCT._AGETPRODUCTNAME()
  Case [F:ADW_]VALEUR
   When "0" : PRODUIT = -1 : NAMDOS = "Superviseur"
   When "1" : PRODUIT = 0  : # X3
   When "2" : PRODUIT = 1  : # Géode
   When "3" : PRODUIT = 2  : # Paye
   When "4" : PRODUIT = 3  : # Biens
  Endcase
 Else
  PRODUIT = 0 : NAMDOS = "X3"
 Endif
 Close Local File [ADW_]
Endif
End

$ERDOS
ER = errn
Resume

#-----------------------------------------------------#
Subprog CTLDOS(DOS)
Value Char DOS()

Gosub CTL_DOS
If mkstat :  End : Endif

End

#-----------------------------------------------------#
Subprog LECDOS(DOS)
Value Char DOS()

Gosub CTL_DOS
If mkstat :  End : Endif

If MACHINE<>"" & MACHINE<>adxmac(0)
 Local File =MACHINE+"@"+SUPERVIS+".ADOSSIER" [ADS_]
Else
 Local File ADOSSIER [ADS_]
Endif
If dim(GFONCTION)<1 or GFONCTION<>"GMAINT"
 Read [ADS_]DOSSIER = APPLI
 If fstat
  GMESSAGE = APPLI-":"-mess(7,125,1) : # Dossier inexistant
  mkstat=2 : End
 Endif
Endif
Close Local File [ADS_]
End

#-----------------------------------------------------#
$CTL_DOS
Local Char    FICAPL(GDIMFIC)
Local Char    MACHINE(GDIMFIC), APPLI(GLONADS) , SUPERVIS(GLONADS)
Local Integer I , OK , STAT , ER

mkstat = 0
fstat  = 0

Call MACHINE(DOS,MACHINE,APPLI) From ORDSYS

# 1) La machine doit exister

If MACHINE<>""
 Call LECMAC(MACHINE,OK)
 If !OK : mkstat = 2 : Return : Endif
Endif

# 2) Il doit vraiment exister

## Test d'existence d'une table du dossier sous système
Call PATHFIL(FICAPL,"FIL","ADOVAL","fde",APPLI,"",MACHINE)
If filinfo(FICAPL,0)<0
 GMESSAGE = DOS-":"-mess(7,125,1) : # Dossier inexistant
 mkstat = 2 : Return
Endif

# 3) Le dossier doit être catalogué

If MACHINE<>"" & MACHINE<>adxmac(0)
 Onerrgo ERDOS
 Local File =DOS+".ADOVAL" [ADW_]
 Read [ADW_]ADW0 = "";"";"SUPDOS"
 If !fstat
  SUPERVIS = [F:ADW_]VALEUR
 Endif
 Close Local File [ADW_]
 Onerrgo
 If ER
  GMESSAGE = DOS-":"-mess(106,125,1) : # Dossier inaccessible
  mkstat = 2 : Return
 Elsif SUPERVIS=""
  GMESSAGE = DOS-":"-mess(78,125,1) : # Superviseur inexistant
  mkstat = 2 : Return
 Endif
 Call INFOFIL(STAT,"FIL","ADOSSIER","fde",SUPERVIS,"",MACHINE,0)
 If STAT<0
  GMESSAGE = DOS-":"-mess(78,125,1) : # Superviseur inexistant
  mkstat = 2 : Return
 Endif
Else
 Onerrgo ERDOS
 Local File =DOS+".ADOVAL" [ADW_]
 Read [ADW_]ADW0 First
 Close Local File [ADW_]
 Onerrgo
 If ER
  GMESSAGE = DOS-":"-mess(106,125,1) : # Dossier inaccessible
  mkstat = 2 : Return
 Endif
Endif
Return
#-----------------------------------------------------#
# Pour ne pas s'emmeler les pinceaux avec les / et les \
#-----------------------------------------------------#

Subprog PATHFIL(FICHIER,REP,FIC,EXT,APP,VOL,MAC)
Variable Char FICHIER()
Value    Char REP
Value    Char FIC
Value    Char EXT
Value    Char APP
Value    Char VOL
Value    Char MAC
Local Integer K
Local Char    C1(1) , C2(1)
FICHIER = filpath(REP,FIC,EXT,APP,VOL,MAC)
Case GOS(1)
 When "unix"
  C1 = "\" : C2 = "/"
 When "dos"
  C1 = "/" : C2 = "\"
Endcase
Repeat
 K = instr(1,FICHIER,C1)
 If K
  FICHIER = left$(FICHIER,K-1)+C2+right$(FICHIER,K+1)
 Endif
Until K = 0
End

#-----------------------------------------------------#
Subprog INFOFIL(STAT,REP,FIC,EXT,APP,VOL,MAC,VALEUR)
Variable Integer STAT
Value    Char    REP
Value    Char    FIC
Value    Char    EXT
Value    Char    APP
Value    Char    VOL
Value    Char    MAC
Value    Integer VALEUR
Local Char FICHIER(250)
Call PATHFIL(FICHIER,REP,FIC,EXT,APP,VOL,MAC)
STAT = filinfo(FICHIER,VALEUR)
End


#-----------------------------------------------------#
# Vérif d'accessibilité d'un serveur
#-----------------------------------------------------#

Subprog LECMAC(MAC,OK)
Value    Char    MAC()
Variable Integer OK
OK = 1
If MAC<>""
 Local Char OS(10)
 Call GET_OS(MAC,OS) From ORDSYS
 If OS=""
  GMESSAGE = MAC-":"-mess(199,100,1) : # Machine inaccessible
  OK = 0
 Endif
Endif
End

#-----------------------------------------------------#
Subprog LECVOL(MAC,VOL)
Value Char MAC()
Value Char VOL()
mkstat=0
Local Integer I , EXISTE, OK
Local Char    REP(GDIMFIC)

Call LECMAC(MAC,OK)
If fstat
 End
Endif

REP = filpath("","","", "!",VOL,MAC)
If REP<>"" & REP<>"@"
 Call EXISTE(REP,EXISTE) From ORDSYS
 If EXISTE<>2 : fstat=5 : Else : fstat=0 : Endif
Else
 fstat=5
Endif
If fstat & inpmode=2
 If    VOL="" : Call ERREUR(mess(5,125,1)) From GESECRAN : # Volume inexistant
 Elsif REP="" : Call ERREUR(VOL-":"-mess(5,125,1)) From GESECRAN : # Volume inexistant
 Else         : Call ERREUR("|"+VOL+":"+REP+"|\"+mess(9,141,1)) From GESECRAN : # Répertoire inexistant
 Endif
 mkstat=2
Endif
End

#--------------------------------------------------------#
# Vérification si dossier origine = dossier destination
#--------------------------------------------------------#

Subprog DOSORGDES(DOS1,DOS2)
Value Char DOS1, DOS2
Local Char MAC1(GDIMFIC), APP1(GDIMFIC), MAC2(GDIMFIC), APP2(GDIMFIC), FIC1(GDIMFIC), FIC2(GDIMFIC)
Local Char OS1(20), OS2(20), VOL1(20), VOL2(20)
Local Integer OK
OK = 1
If DOS1=DOS2
 OK = 0
Else
 Call MACHINE(DOS1,MAC1,APP1) From ORDSYS
 Call MACHINE(DOS2,MAC2,APP2) From ORDSYS
 Call VOLUME(MAC1,DOS1,VOL1) From ORDSYS
 Call VOLUME(MAC2,DOS2,VOL2) From ORDSYS
 Call GET_OS(MAC1,OS1) From ORDSYS
 Call GET_OS(MAC2,OS2) From ORDSYS
 FIC1 = filpath("FIL","ADOVAL","fde",APP1,VOL1,MAC1)
 FIC2 = filpath("FIL","ADOVAL","fde",APP2,VOL2,MAC2)
 If FIC1=FIC2
  OK = 0
 Elsif OS1="unix" & OS2="unix" & filinfo(FIC1,1)=filinfo(FIC2,1) & filinfo(FIC1,7)=filinfo(FIC2,7)
  OK = 0
 Endif
Endif
If !OK
 Call ERREUR(DOS1-"&"-DOS2+"\"+mess(179,115,1)) From GESECRAN : # Applications identiques
 mkstat = 1 : End
Endif
End

#-----------------------------------------------------#
Subprog LECREP(REP)
Value Char REP()
Local Integer EXISTE
Call EXISTE(REP,EXISTE) From ORDSYS
If EXISTE<>2 : fstat=5 : Endif
If fstat & inpmode=2
 If REP="" : Call ERREUR(mess(9,141,1)) From GESECRAN : # Répertoire inexistant
 Else      : Call ERREUR("|"+REP+"|\"+mess(9,141,1)) From GESECRAN : # Répertoire inexistant
 Endif
 mkstat=2
Endif
End

#-----------------------------------------------------#
# Vérification si dossier courant est le superviseur
#-----------------------------------------------------#

Subprog SUPER(OK)
Variable Integer OK
If GSOPHIA & GPRODUIT=-1
 OK = 1
Else
 OK = 0
Endif
End

#-----------------------------------------------------#
# Lecture des législations d'un dossier
#-----------------------------------------------------#

Subprog SETLEG(DOSSIER,DOSLEG,NBLEG)
Value Char DOSSIER
Variable Char DOSLEG()(1..)
Variable Integer NBLEG
Local Char CHAINE(250)
Local Integer K , ER
NBLEG = 0
Onerrgo ERDOS
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 If DOSSIER="" or DOSSIER=nomap
  Local File ADOVAL [ADW_]
 Else
  Local File =DOSSIER+".ADOVAL" [ADW_]
 Endif
 Read [ADW_]ADW0="";"";"DOSLEG"
 If !fstat
  CHAINE = [F:ADW_]VALEUR
  While CHAINE<>""
   NBLEG += 1
   K = instr(1,CHAINE,"~")
   If K
    DOSLEG(NBLEG) = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    DOSLEG(NBLEG) = CHAINE
    CHAINE = ""
   Endif
  Wend
 Endif
 Close Local File [ADW_]
Endif
Onerrgo
End

#-----------------------------------------------------#
# Contrôle droit accés aux dossiers
#-----------------------------------------------------#

Subprog CTL_DROIT_DOSSIER(DOSSIER,OPE)
Value Char DOSSIER , OPE
Local Char MAC(255) , APP(255) , VOL(255)
Local Char OS1(255) , FIC1(GDIMFIC)
Local Char OS2(255) , FIC2(GDIMFIC)
Local Integer I , MACCUR , NIVMIN , ER
Case OPE
 When "E"     : NIVMIN = 3 : # Toutes
 When Default : NIVMIN = 2 : # Lecture
Endcase
Call MACHINE(DOSSIER,MAC,APP) From ORDSYS
Call VOLUME(MAC,DOSSIER,VOL) From ORDSYS
Call GET_OS(MAC,OS1) From ORDSYS
Call GET_OS(adxmac(0),OS2) From ORDSYS
FIC1 = filpath("","","",APP,VOL,MAC)
FIC1 = left$(FIC1,len(FIC1)-len(APP))+"solution.xml"
FIC2 = filpath("","","")
FIC2 = left$(FIC2,len(FIC2)-len(nomap))+"solution.xml"
MACCUR = 0
#109026 If FIC1=FIC2
If MAC=adxmac(0) & FIC1=FIC2
 MACCUR = 1
#109026 Elsif OS1="unix" & OS2="unix" & filinfo(FIC1,1)=filinfo(FIC2,1) & filinfo(FIC1,7)=filinfo(FIC2,7)
Elsif MAC=adxmac(0) & OS1="unix" & OS2="unix" & filinfo(FIC1,1)=filinfo(FIC2,1) & filinfo(FIC1,7)=filinfo(FIC2,7)
 MACCUR = 1
Else
 I = instr(1,FIC1,"@") : If I : FIC1 = right$(FIC1,I+1) : Endif
 I = instr(1,FIC2,"@") : If I : FIC2 = right$(FIC2,I+1) : Endif
 #109026 If FIC1 = FIC2
 If MAC=adxmac(0) & FIC1 = FIC2
  MACCUR = 1
 Endif
Endif
If MACCUR : # On est sur la même solution
 If toupper(APP)<>nomap
  Onerrgo ERDOS
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER = toupper(APP)
  If fstat
   mkstat = 1
  Else
   Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
   Read [ADW]ADW0="";"";"SUPDOS"
   If fstat or [F:ADW]VALEUR<>nomap
    I = find(nomap(0),[F:ADS]SOLDOS)
    If !I
     mkstat = 1
    Elsif [F:ADS]SOLAUZ(I-1)<[L]NIVMIN
     mkstat = 1
    Endif
   Endif
  Endif
  Onerrgo
 Endif
Endif
If mkstat
 GMESSAGE = mess(149,125,1) : # Droit d'accès à ce dossier insuffisant
Endif
End

#-----------------------------------------------------#
Subprog S_DOSSIER(AZC)
Variable Char    AZC()
End

#-----------------------------------------------------#
# Retourne le nom du dossier X3 avec le nom de machine
#-----------------------------------------------------#

Funprog DOSX3(DOSSIER)
Value Char DOSSIER
Local Char    DOSX3(GLONADD)
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS)
Local Integer ER
DOSX3 = ""
Onerrgo ERDOS
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
Read [ADW_]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW_]VALEUR<>""
 DOSX3 = [F:ADW_]VALEUR
Endif
Close Local File [ADW_]
Onerrgo
If !ER & DOSX3<>""
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
 If MACHINE<>""
  DOSX3 = MACHINE+"@"+DOSX3
 Endif
Endif
End DOSX3

#-----------------------------------------------------#
# Retourne le nom de l'appli superviseur
#-----------------------------------------------------#

Funprog APPX3(DOSSIER)
Value Char DOSSIER
Local Char    SUPER(GLONADS)
Local Integer ER
Onerrgo ERDOS
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
Read [ADW_]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW_]VALEUR<>""
 SUPER = [F:ADW_]VALEUR
Endif
Close Local File [ADW_]
Onerrgo
If ER : SUPER = "" : Endif
End SUPER

#-----------------------------------------------------#
# Retourne le nom du dossier historisé
#-----------------------------------------------------#

Funprog HISTO(DOSSIER)
Value Char DOSSIER
Local Char    HISDOS(GLONADS)
Local Integer ER
Onerrgo ERDOS
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
Read [ADW_]ADW0="";"";"HISDOS"
If !fstat & [F:ADW_]VALEUR<>""
 HISDOS = [F:ADW_]VALEUR
Endif
Close Local File [ADW_]
Onerrgo
If ER : HISDOS = "" : Endif
End HISDOS

#-----------------------------------------------------#
# Retourne le chemin du répertoire "dossiers"
#-----------------------------------------------------#

Funprog REPDOS(DOSSIER)
Value Char DOSSIER
Local Char REPDOS(GDIMFIC) , APPLI(GLONADS) , MACHINE(GLONAMC)
If DOSSIER="" : DOSSIER = nomap : Endif
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
REPDOS = filpath("","","",DOSSIER)
REPDOS = left$(REPDOS,len(REPDOS)-len(APPLI)-1)
End REPDOS

#-----------------------------------------------------#
# Retourne le chemin du fichier solution
#-----------------------------------------------------#

Funprog SOLUTION(DOSSIER)
Value Char DOSSIER
Local Char CHEMIN(GDIMFIC) , MACHINE(GLONAMC)
Call MACHINE(func REPDOS(DOSSIER),MACHINE,CHEMIN) From ORDSYS
End filpath(CHEMIN,"solution","xml","","",MACHINE)

