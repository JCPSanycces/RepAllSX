#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HONLINANN","DHONLIN",3,"") From GTRAITE
End

# Annulation des lignes d'honoraires

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE 
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$OUVRE
If clalev([F:HLN])=0 : Local File HONLIN   [HLN] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
Return

$INIT_DIA
TMP = 1 : TRA = 1
Return

$EXEC
Call HONLINANN
Return

$CONTROLE
Return

Subprog HONLINANN
Gosub DECLARE
Gosub OUVRE 

If GSERVEUR
 [M:DIA]TRC = 2
Endif

TIT = mess(58,122,1) : # Annulation des lignes d'honoraires

If !GSERVEUR
 If [M:DIA]TRC=2
  Call OUVRE_TRACE(TIT) From LECFIC
 Endif
Endif

If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN 
Endif

Gosub CRITERE
Filter [HLN] Where evalue(CRITERE)
NBLIN = 0
For [HLN]HLN0(2)
 NBLIN =1
 If [M:DIA]TRC=2
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE([F:HLN]FCY-"-"-[F:HLN]PRVNUM,0) From GESECRAN
  Call ECR_TRACE(string$(104,"-"),0) From GESECRAN 
 Endif
 SITE  = [F:HLN]FCY
 PREST = [F:HLN]PRVNUM
 If [M:DIA]TRC=2
  For [HLN]HLN0
   Call ECR_TRACE(format$("D:"+GFMDAT,[F:HLN]DAT)-[F:HLN]TYPINV-[F:HLN]NUMINV
&   -mess([F:HLN]HON,615,1)-num$([F:HLN]AMTLOC),0) From GESECRAN 
  Next
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
Next
Filter [HLN]
 
If [M:DIA]TRC=2 & !NBLIN
 Call ECR_TRACE(mess(59,122,1),0) From GESECRAN : # Aucune ligne à annuler
Endif
If !GSERVEUR & [M:DIA]TRC=2 
 Call FERME_TRACE From LECFIC
Endif 

$SORTIE
End

$DECLARE
Local Char    CRITERE(250)
Local Char    SITE(GLONFCY)
Local Char    PREST(10)
Local Integer OK, NBLIN
Return

$CRITERE
CRITERE = 'CPY = "'+[M:DIA]CPY+'"'
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Elsif GNBAUZ<>GNBSITE
 CRITERE -= '& find(FCY,GUSRFCY(1..GNBAUZ))'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITERE -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
If [M:DIA]ALLHON<>2
 CRITERE -= '& HON = '+num$([M:DIA]HON)
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE -= '& DAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE -= '& DAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif

$TR1
Trbegin [HLN]
  Delete [HLN] Where FCY=SITE & PRVNUM=PREST
 If fstat=1 
  GOK = -1
  GLOCK = "$HONLIN"-SITE-PREST
  Goto ROLL_TR1
 Elsif fstat>5
  GOK = 0
  Call RSTA("HLN",SITE-PREST) From GLOCK
  Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return
