#<AdxTL>@(#)0.0.0.0 $Revision$ Plan réappro zone consommation

#######################################################################
# SUBSRO : Transactions plan réappro consommation                     #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Génération de 1 écrans de saisie à partir des écrans de base SRO1   #
#                                                                     #
# Nom des écrans générés : WTxyyyz                                    #
#                            x = 9 pour plan réappro consommation     #
#                                                                     #
#                          yyy = nom de la transaction (STRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 pour plan  réappro consommation    #
#######################################################################
Call OBJET("SRO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SRO0]SRTTYP = 9
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "VERIF_CRE"   : Gosub VERIFCRE
 When "VERIF_MOD"   : Gosub VERIFCRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Gosub TRT_ECRAN
 When "AV_IMPRIME"  : Gosub COP_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return


$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock

Local Char APPLI    : APPLI=nomap
Local Char WMODU(3) : WMODU="T"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#---------------------------------------------------#
# traiter les transactions de type reappro          #
#---------------------------------------------------#
$FILTRE
FILTSUP="SRTTYP=9"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$LIENS
#-- Positionnement des valeurs si non renseignées
#** Onglet entete

If [M:SRO0]ENAFLG    =0  [M:SRO0]ENAFLG          =2   : Endif

#** Onglet General

If [M:SRO1]CRIT1     =0   [M:SRO1]CRIT1          =1   : Endif :

If [M:SRO1]SRGPPSCOD =0   [M:SRO1]SRGPPSCOD      =1   : Endif :
If [M:SRO1]SRGPPSSCR =0   [M:SRO1]SRGPPSSCR      =1   : Endif :
If [M:SRO1]STUCOD    =0   [M:SRO1]STUCOD         =1   : Endif :
If [M:SRO1]STUSCR    =0   [M:SRO1]STUSCR         =1   : Endif :
If [M:SRO1]QTYSTUOCOD=0   [M:SRO1]QTYSTUOCOD     =1   : Endif :
If [M:SRO1]QTYSTUOSCR=0   [M:SRO1]QTYSTUOSCR     =1   : Endif :


If [M:SRO1]QTYSTUCOD =0    [M:SRO1]QTYSTUCOD     =1   : Endif :
If [M:SRO1]QTYSTUSCR =0   [M:SRO1]QTYSTUSCR      =1   : Endif :
If dim([M:SRO1]LPNCOD) > 0                                          # hcb x3-82749
   If [M:SRO1]LPNCOD    =0   [M:SRO1]LPNCOD         =1   : Endif :  # hcb x3-82749
   If [M:SRO1]LPNSCR    =0   [M:SRO1]LPNSCR         =1   : Endif :  # hcb x3-82749
Endif                                                               # hcb x3-82749
If dim([M:SRO1]LOTCOD) > 0                                          # hcb 27200
   If [M:SRO1]LOTCOD    =0   [M:SRO1]LOTCOD         =1   : Endif :
   If [M:SRO1]LOTSCR    =0   [M:SRO1]LOTSCR         =1   : Endif :
Endif                                                               # hcb 27200
If dim([M:SRO1]SLOCOD) > 0                                          # hcb 27200
   If [M:SRO1]SLOCOD    =0   [M:SRO1]SLOCOD         =1   : Endif :
   If [M:SRO1]SLOSCR    =0   [M:SRO1]SLOSCR         =1   : Endif :
Endif                                                               # hcb 27200
If [M:SRO1]STACOD    =0   [M:SRO1]STACOD         =1   : Endif :
If [M:SRO1]STASCR    =0   [M:SRO1]STASCR         =1   : Endif :
If [M:SRO1]LOCCOD    =0   [M:SRO1]LOCCOD         =1   : Endif :
If [M:SRO1]LOCSCR    =0   [M:SRO1]LOCSCR         =1   : Endif :

# hcb 27200 deb
If dim([M:SRO1]SERCOD) > 0
   If [M:SRO1]SERCOD    =0   [M:SRO1]SERCOD      =1   : Endif :
   If [M:SRO1]SERSCR    =0   [M:SRO1]SERSCR      =1   : Endif :
   If [M:SRO1]SERECOD   =0   [M:SRO1]SERECOD     =2   : Endif :
   If [M:SRO1]SERESCR   =0   [M:SRO1]SERESCR     =1   : Endif :
Endif
If dim([M:SRO1]IDECOD01) > 0
   If [M:SRO1]IDECOD01    =0   [M:SRO1]IDECOD01  =3   : Endif :
   If [M:SRO1]IDESCR01    =0   [M:SRO1]IDESCR01  =1   : Endif :
   If [M:SRO1]IDECOD02    =0   [M:SRO1]IDECOD02  =3   : Endif :
   If [M:SRO1]IDESCR02    =0   [M:SRO1]IDESCR01  =1   : Endif :
Endif
# hcb 27200 fin

If [M:SRO1]MVTDESCOD =0   [M:SRO1]MVTDESCOD   =1   : Endif :
If [M:SRO1]MVTDESSCR =0   [M:SRO1]MVTDESSCR   =1   : Endif :


If [M:SRO1]LOCREO    =0   [M:SRO1]LOCREO      =1   : Endif :
If [M:SRO1]CSMREO    =0   [M:SRO1]CSMREO      =1   : Endif :
If [M:SRO1]SHTREO    =0   [M:SRO1]SHTREO      =1   : Endif :
If [M:SRO1]DEFLOCCOD =0   [M:SRO1]DEFLOCCOD   =1   : Endif :
If [M:SRO1]DEFTYPCOD =0   [M:SRO1]DEFTYPCOD   =1   : Endif :
If [M:SRO1]DEFLOCSCR =0   [M:SRO1]DEFLOCSCR   =1   : Endif :
If [M:SRO1]DEFTYPSCR =0   [M:SRO1]DEFTYPSCR   =1   : Endif :
If [M:SRO1]ORIREOCOD =0   [M:SRO1]ORIREOCOD   =1   : Endif :
If [M:SRO1]CLEFLGSCR =0   [M:SRO1]CLEFLGSCR   =1   : Endif :
If [M:SRO1]CLEFLGCOD =0   [M:SRO1]CLEFLGCOD   =1   : Endif :
If [M:SRO1]BPRNUMSCR =0   [M:SRO1]BPRNUMSCR   =1   : Endif :
If [M:SRO1]BPRNUMCOD =0   [M:SRO1]BPRNUMCOD   =1   : Endif :
If [M:SRO1]VCRNUMSCR =0   [M:SRO1]VCRNUMSCR   =1   : Endif :
If [M:SRO1]VCRNUMCOD =0   [M:SRO1]VCRNUMCOD   =1   : Endif :


#-- Grisage des zones si besoin
#** Onglet Generale

# les zones Emp conso et typ conso sont parametrables si Zones de consommation est cochée
If [M:SRO1]CSMREO  <>2
   [M:SRO1]DEFLOCCOD= 2
   [M:SRO1]DEFTYPCOD= 2
Endif
# si Zones de consommation est uniquement cochée alors determination automatique est grisée
#                                                   et sernum fin est invisible
If [M:SRO1]CSMREO  = 2 & [M:SRO1]LOCREO  <> 2 & [M:SRO1]SHTREO  <> 2
   [M:SRO1]STKFLG    = 1
   If dim([M:SRO1]SERECOD) > 0                     # hcb 27200
      [M:SRO1]SERECOD   = 2
   Endif                                           # hcb 27200
   Grizo [M:SRO1]STKFLG
Endif

If [M:SRO1]DEFLOCCOD=2  Grizo [SRO1]DEFLOCSCR  Else Actzo [SRO1]DEFLOCSCR : Endif
If [M:SRO1]DEFTYPCOD=2  Grizo [SRO1]DEFTYPSCR  Else Actzo [SRO1]DEFTYPSCR : Endif
If [M:SRO1]ORIREOCOD=2  Grizo [SRO1]ORIREOSCR  Else Actzo [SRO1]ORIREOSCR : Endif


If [M:SRO1]SRGPPSCOD =3  Grizo [SRO1]SRGPPSSCR  Else Actzo [SRO1]SRGPPSSCR  : Endif
If [M:SRO1]STUCOD    =2  Grizo [SRO1]STUSCR     Else Actzo [SRO1]STUSCR     : Endif
If [M:SRO1]QTYSTUOCOD=2  Grizo [SRO1]QTYSTUOSCR Else Actzo [SRO1]QTYSTUOSCR : Endif
If [M:SRO1]BPRNUMCOD =2  Grizo [SRO1]BPRNUMSCR  Else Actzo [SRO1]BPRNUMSCR  : Endif
If [M:SRO1]VCRNUMCOD =2  Grizo [SRO1]VCRNUMSCR  Else Actzo [SRO1]VCRNUMSCR  : Endif

#If [M:SRO1]PCUCOD   =3  Grizo [SRO1]PCUSCR     Else actzo [SRO1]PCUSCR     Endif
#If [M:SRO1]QTYPCUCOD=3  Grizo [SRO1]QTYPCUSCR  Else actzo [SRO1]QTYPCUSCR  Endif
#If [M:SRO1]PCUSTUCOD=3  Grizo [SRO1]PCUSTUSCR  Else actzo [SRO1]PCUSTUSCR  Endif
If [M:SRO1]QTYSTUCOD=3  Grizo [SRO1]QTYSTUSCR  Else Actzo [SRO1]QTYSTUSCR : Endif
If dim([M:SRO1]LPNCOD) > 0                                                                  # hcb x3-82749
   If [M:SRO1]LPNCOD   =3  Grizo [SRO1]LPNSCR     Else Actzo [SRO1]LPNSCR    : Endif        # hcb x3-82749
Endif                                                                                       # hcb x3-82749
If dim([M:SRO1]LOTCOD) > 0                     # hcb 27200
   If [M:SRO1]LOTCOD   =3  Grizo [SRO1]LOTSCR     Else Actzo [SRO1]LOTSCR    : Endif
Endif                                          # hcb 27200
If dim([M:SRO1]SLOCOD) > 0                     # hcb 27200
   If [M:SRO1]SLOCOD   =3  Grizo [SRO1]SLOSCR     Else Actzo [SRO1]SLOSCR    : Endif
Endif                                          # hcb 27200
If [M:SRO1]STACOD   =3  Grizo [SRO1]STASCR     Else Actzo [SRO1]STASCR    : Endif
If [M:SRO1]LOCCOD   =3  Grizo [SRO1]LOCSCR     Else Actzo [SRO1]LOCSCR    : Endif
# hcb 27200 deb
If dim([M:SRO1]SERCOD) > 0
   If [M:SRO1]SERCOD   =3  Grizo [SRO1]SERSCR     Else Actzo [SRO1]SERSCR    : Endif
   If [M:SRO1]SERECOD  =2  Grizo [SRO1]SERESCR    Else Actzo [SRO1]SERESCR   : Endif
Endif
If dim([M:SRO1]IDECOD01) > 0
   If [M:SRO1]IDECOD01    =3   Grizo [SRO1]IDESCR01  Else Actzo [SRO1]IDESCR01   : Endif :
   If [M:SRO1]IDECOD02    =3   Grizo [SRO1]IDESCR02  Else Actzo [SRO1]IDESCR02   : Endif :
Endif

# hcb 27200 fin

If [M:SRO1]MVTDESCOD=3  Grizo [SRO1]MVTDESSCR  Else Actzo [SRO1]MVTDESSCR : Endif

Gosub ANA_ORIGINE


WMODU +=format$("N0:2",[M:SRO0]SRTTYP)
Gosub PE_STKTRS
Return

#---------------------------------------#
# Il n'y a aucun " Réapprovisionnements" de cochés !
#---------------------------------------#
$VERIFCRE

If [M:SRO1]LOCREO <> 2 & [M:SRO1]CSMREO <> 2 & [M:SRO1]SHTREO <> 2
   Call ERREUR(mess(242,184,1)) From GESECRAN
   OK = 0
Endif

Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
#** Onglet entete
[M:SRO0]SRTTYP=9
[M:SRO0]ENAFLG=2
#** Onglet general

[M:SRO1]LOCREO    =2
[M:SRO1]CSMREO    =2
[M:SRO1]SHTREO    =2
[M:SRO1]DEFLOCCOD =1
[M:SRO1]DEFTYPCOD =1
[M:SRO1]ORIREOCOD =1
[M:SRO1]DEFLOCSCR =1
[M:SRO1]DEFTYPSCR =1
[M:SRO1]ORIREOSCR =1

[M:SRO1]CRIT1=1
[M:SRO1]SRGPPSCOD=1
[M:SRO1]SRGPPSSCR=1
[M:SRO1]STUCOD   =1
[M:SRO1]STUSCR   =1
[M:SRO1]QTYSTUOCOD=2
[M:SRO1]QTYSTUOSCR=1
[M:SRO1]BPRNUMCOD=2
[M:SRO1]BPRNUMSCR=1
[M:SRO1]VCRNUMCOD=2
[M:SRO1]VCRNUMSCR=1

[M:SRO1]CLEFLGCOD=1
[M:SRO1]CLEFLGSCR=1


[M:SRO1]QTYSTUCOD=3
[M:SRO1]QTYSTUSCR=1
If dim([M:SRO1]LPNCOD) > 0                     # hcb x3-82749
   [M:SRO1]LPNCOD   =3                         # hcb x3-82749
   [M:SRO1]LPNSCR   =1                         # hcb x3-82749
Endif                                          # hcb x3-82749
If dim([M:SRO1]LOTCOD) > 0                     # hcb 27200
   [M:SRO1]LOTCOD   =3
   [M:SRO1]LOTSCR   =1
Endif                                          # hcb 27200
If dim([M:SRO1]SLOCOD) > 0                     # hcb 27200
   [M:SRO1]SLOCOD   =3
   [M:SRO1]SLOSCR   =1
Endif                                          # hcb 27200
[M:SRO1]STACOD   =3
[M:SRO1]STASCR   =1
[M:SRO1]LOCCOD   =3
[M:SRO1]LOCSCR   =1
# hcb 27200 deb
If dim([M:SRO1]SERCOD) > 0
   [M:SRO1]SERCOD   =3
   [M:SRO1]SERSCR   =1
   [M:SRO1]SERECOD  =2
   [M:SRO1]SERESCR  =1
Endif
If dim([M:SRO1]IDECOD01) > 0
   [M:SRO1]IDECOD01   =3
   [M:SRO1]IDESCR01   =1
   [M:SRO1]IDECOD02   =3
   [M:SRO1]IDESCR02   =1
Endif
# hcb 27200 fin

[M:SRO1]MVTDESCOD=3
[M:SRO1]MVTDESSCR=1

Actzo [SRO0]
Actzo [SRO1]

#-- Grisage des zones si besoin
#** Onglet origine rubrique  (menu local 35  S A I)
# les zones Emp conso et typ conso sont parametrables si Zones de consommation est cochée
If [M:SRO1]CSMREO  <>2
   [M:SRO1]DEFLOCCOD= 2
   [M:SRO1]DEFTYPCOD= 2
Endif
# si Zones de consommation est uniquement cochée alors determination automatique est grisée
#                                                   et sernum fin est invisible
If [M:SRO1]CSMREO  = 2 & [M:SRO1]LOCREO  <> 2 & [M:SRO1]SHTREO  <> 2
   [M:SRO1]STKFLG    = 1
   If dim([M:SRO1]SERECOD) > 0                     # hcb 27200
      [M:SRO1]SERECOD   = 2
   Endif                                           # hcb 27200
   Grizo [M:SRO1]STKFLG
Endif

If [M:SRO1]DEFLOCCOD=2  Grizo [SRO1]DEFLOCSCR  Else Actzo [SRO1]DEFLOCSCR : Endif
If [M:SRO1]DEFTYPCOD=2  Grizo [SRO1]DEFTYPSCR  Else Actzo [SRO1]DEFTYPSCR : Endif
If [M:SRO1]ORIREOCOD=2  Grizo [SRO1]ORIREOSCR  Else Actzo [SRO1]ORIREOSCR : Endif

If [M:SRO1]SRGPPSCOD  =3  Grizo [SRO1]SRGPPSSCR   Else Actzo [SRO1]SRGPPSSCR  : Endif
If dim([M:SRO1]LPNCOD) > 0                                                                     # hcb x3-82749
   If [M:SRO1]LPNCOD     =3  Grizo [SRO1]LPNSCR      Else Actzo [SRO1]LPNSCR     : Endif       # hcb x3-82749
Endif                                                                                          # hcb x3-82749
If dim([M:SRO1]LOTCOD) > 0                     # hcb 27200
   If [M:SRO1]LOTCOD     =3  Grizo [SRO1]LOTSCR      Else Actzo [SRO1]LOTSCR     : Endif
Endif                                          # hcb 27200
If dim([M:SRO1]SLOCOD) > 0                     # hcb 27200
   If [M:SRO1]SLOCOD     =3  Grizo [SRO1]SLOSCR      Else Actzo [SRO1]SLOSCR     : Endif
Endif                                          # hcb 27200
If [M:SRO1]STACOD     =3  Grizo [SRO1]STASCR      Else Actzo [SRO1]STASCR     : Endif
If [M:SRO1]LOCCOD     =3  Grizo [SRO1]LOCSCR      Else Actzo [SRO1]LOCSCR     : Endif
# hcb 27200 deb
If dim([M:SRO1]SERCOD) > 0
   If [M:SRO1]SERCOD   =3  Grizo [SRO1]SERSCR     Else Actzo [SRO1]SERSCR    : Endif
   If [M:SRO1]SERECOD  =2  Grizo [SRO1]SERESCR    Else Actzo [SRO1]SERESCR   : Endif
Endif
If dim([M:SRO1]IDECOD01) > 0
   If [M:SRO1]IDECOD01    =3   Grizo [SRO1]IDESCR01  Else Actzo [SRO1]IDESCR01   : Endif :
   If [M:SRO1]IDECOD02    =3   Grizo [SRO1]IDESCR02  Else Actzo [SRO1]IDESCR02   : Endif :
Endif

# hcb 27200 fin

If [M:SRO1]MVTDESCOD  =3  Grizo [SRO1]MVTDESSCR   Else Actzo [SRO1]MVTDESSCR  : Endif
If [M:SRO1]QTYSTUCOD  =3  Grizo [SRO1]QTYSTUSCR   Else Actzo [SRO1]QTYSTUSCR  : Endif

#**                          (menu local 60 A I)
If [M:SRO1]STUCOD     =2  Grizo [SRO1]STUSCR      Else Actzo [SRO1]STUSCR     : Endif
If [M:SRO1]QTYSTUOCOD =2  Grizo [SRO1]QTYSTUOSCR  Else Actzo [SRO1]QTYSTUOSCR : Endif
If [M:SRO1]BPRNUMCOD  =2  Grizo [SRO1]BPRNUMSCR   Else Actzo [SRO1]BPRNUMSCR  : Endif
If [M:SRO1]VCRNUMCOD  =2  Grizo [SRO1]VCRNUMSCR   Else Actzo [SRO1]VCRNUMSCR  : Endif


Gosub ANA_ORIGINE


WMODU +=format$("N0:2",[M:SRO0]SRTTYP)

Gosub PE_STKTRS

Affzo [SRO0]1-99
Affzo [SRO1]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
When "SRGPPSCOD"
       If val(CZ)=3
         [M:SRO1]SRGPPSSCR=1
         If !GIMPORT Affzo [SRO1]SRGPPSSCR : Grizo [SRO1]SRGPPSSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SRGPPSSCR
       Endif
#                                                                                    # hcb x3-82749 deb
When "LPNCOD"
       If val(CZ)=3
         [M:SRO1]LPNSCR=1
         If !GIMPORT Affzo [SRO1]LPNSCR : Grizo [SRO1]LPNSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LPNSCR
       Endif
#                                                                                    # hcb x3-82749 fin

When "LOTCOD"
       If val(CZ)=3
         [M:SRO1]LOTSCR=1
         If !GIMPORT Affzo [SRO1]LOTSCR : Grizo [SRO1]LOTSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LOTSCR
       Endif
When "SLOCOD"
       If val(CZ)=3
         [M:SRO1]SLOSCR=1
         If !GIMPORT Affzo [SRO1]SLOSCR : Grizo [SRO1]SLOSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SLOSCR
       Endif
When "STACOD"
       If val(CZ)=3
         [M:SRO1]STASCR=1
         If !GIMPORT Affzo [SRO1]STASCR : Grizo [SRO1]STASCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]STASCR
       Endif
When "LOCCOD"
       If val(CZ)=3
         [M:SRO1]LOCSCR=1
         If !GIMPORT Affzo [SRO1]LOCSCR : Grizo [SRO1]LOCSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LOCSCR
       Endif
When "SERCOD"
       If val(CZ)=3
         [M:SRO1]SERSCR=1
         If !GIMPORT Affzo [SRO1]SERSCR : Grizo [SRO1]SERSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SERSCR
       Endif
# hcb 27200 deb
  When "IDECOD01"                                  : # Identifiant 1
       If val(CZ)=3
         [M:SRO1]IDESCR01=1
         If !GIMPORT Affzo [SRO1]IDESCR01: Grizo [SRO1]IDESCR01 : Endif
       Elsif !GIMPORT
         Actzo [SRO1]IDESCR01
       Endif
  When "IDECOD02"                                  : # Identifiant 2
       If val(CZ)=3
         [M:SRO1]IDESCR02=1
         If !GIMPORT Affzo [SRO1]IDESCR02: Grizo [SRO1]IDESCR02 : Endif
       Elsif !GIMPORT
         Actzo [SRO1]IDESCR02
       Endif
# hcb 27200 fin

When "MVTDESCOD"
       If val(CZ)=3
         [M:SRO1]MVTDESSCR=1
         If !GIMPORT Affzo [SRO1]MVTDESSCR : Grizo [SRO1]MVTDESSCR      : Endif
       Elsif !GIMPORT
         Actzo [SRO1]MVTDESSCR
       Endif

When "SERECOD"
       If val(CZ)=2
         [M:SRO1]SERESCR=1
         If !GIMPORT Affzo [SRO1]SERESCR : Grizo [SRO1]SERESCR         : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SERESCR
       Endif

When "BPRNUMCOD"
       If val(CZ)=2
         [M:SRO1]BPRNUMSCR=1
         If !GIMPORT Affzo [SRO1]BPRNUMSCR : Grizo [SRO1]BPRNUMSCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]BPRNUMSCR
       Endif
When "STUCOD"
       If val(CZ)=2
         [M:SRO1]STUSCR=1
         If !GIMPORT Affzo [SRO1]STUSCR : Grizo [SRO1]STUSCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]STUSCR
       Endif
When "QTYSTUOCOD"
       If val(CZ)=2
         [M:SRO1]QTYSTUOSCR=1
         If !GIMPORT Affzo [SRO1]QTYSTUOSCR : Grizo [SRO1]QTYSTUOSCR    : Endif
       Elsif !GIMPORT
         Actzo [SRO1]QTYSTUOSCR
       Endif
When "QTYSTUCOD"
       If val(CZ)=3
         [M:SRO1]QTYSTUSCR=1
         If !GIMPORT Affzo [SRO1]QTYSTUSCR : Grizo [SRO1]QTYSTUSCR      : Endif
       Elsif !GIMPORT
         Actzo [SRO1]QTYSTUSCR
       Endif
#                                                                                    # hcb x3-82749 deb
When "LPNCOD"
       If val(CZ)=3
         [M:SRO1]LPNSCR=1
         If !GIMPORT Affzo [SRO1]LPNSCR : Grizo [SRO1]LPNSCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LPNSCR
       Endif
#                                                                                    # hcb x3-82749 deb
When "LOTCOD"
       If val(CZ)=3
         [M:SRO1]LOTSCR=1
         If !GIMPORT Affzo [SRO1]LOTSCR : Grizo [SRO1]LOTSCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LOTSCR
       Endif
When "SLOCOD"
       If val(CZ)=3
         [M:SRO1]SLOSCR=1
         If !GIMPORT Affzo [SRO1]SLOSCR : Grizo [SRO1]SLOSCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SLOSCR
       Endif
When "STACOD"
       If val(CZ)=3
         [M:SRO1]STASCR=1
         If !GIMPORT Affzo [SRO1]STASCR : Grizo [SRO1]STASCR            : Endif
       Elsif !GIMPORT
         Actzo [SRO1]STASCR
       Endif
When "LOCCOD"
       If val(CZ)=3
         [M:SRO1]LOCSCR=1
         If !GIMPORT Affzo [SRO1]LOCSCR : Grizo [SRO1]LOCSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]LOCSCR
       Endif
When "SERCOD"
       If val(CZ)=3
         [M:SRO1]SERSCR=1
         If !GIMPORT Affzo [SRO1]SERSCR : Grizo [SRO1]SERSCR           : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SERSCR
       Endif
When "SERECOD"
       If val(CZ)=2
         [M:SRO1]SERESCR=1
         If !GIMPORT Affzo [SRO1]SERESCR : Grizo [SRO1]SERESCR         : Endif
       Elsif !GIMPORT
         Actzo [SRO1]SERESCR
       Endif
When "MVTDESCOD"
       If val(CZ)=3
         [M:SRO1]MVTDESSCR=1
         If !GIMPORT Affzo [SRO1]MVTDESSCR : Grizo [SRO1]MVTDESSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRO1]MVTDESSCR
       Endif

When "ORIREOCOD"
       If val(CZ)=2
         [M:SRO1]ORIREOSCR=1
         If !GIMPORT Affzo [SRO1]ORIREOSCR : Grizo [SRO1]ORIREOSCR    : Endif
       Elsif !GIMPORT
         Actzo [SRO1]ORIREOSCR
       Endif
When "DEFTYPCOD"
       If val(CZ)=2
         [M:SRO1]DEFTYPSCR=1
         If !GIMPORT Affzo [SRO1]DEFTYPSCR : Grizo [SRO1]DEFTYPSCR    : Endif
       Elsif !GIMPORT
         Actzo [SRO1]DEFTYPSCR
       Endif
When "DEFLOCCOD"
       If val(CZ)=2
         [M:SRO1]DEFLOCSCR=1
         If !GIMPORT Affzo [SRO1]DEFLOCSCR : Grizo [SRO1]DEFLOCSCR    : Endif
       Elsif !GIMPORT
         Actzo [SRO1]DEFLOCSCR
       Endif
When "VCRNUMCOD"
       If val(CZ)=2
         [M:SRO1]VCRNUMSCR=1
         If !GIMPORT Affzo [SRO1]VCRNUMSCR : Grizo [SRO1]VCRNUMSCR    : Endif
       Elsif !GIMPORT
         Actzo [SRO1]VCRNUMSCR
       Endif

 When Default
       Gosub PE_STKTRS
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SRO0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SRO0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) : Endif
If dim(OK)<0  : Local Integer OK : Endif
If APPLI=""    APPLI=nomap       : Endif
If WMODU=""    WMODU = "T"+format$("N0:2",[M:SRO0]SRTTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

#---------------- Noms fenêtres et traitement pla de rangement---#
Local Char     WINREF1(GLONFEN) : WINREF1="IREO"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WQREO"+[M:SRO0]SRTNUM+"1"
#-------------------------- 1er écran ---------------------------#
MFROM="REO1"
MTO="W"+WMODU+[M:SRO0]SRTNUM+"1"
#MTO="WT"+num$([M:SRO0]SRTTYP)+[M:SRO0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
#                      Menu local 35  S A I
    If [M:SRO1]SRGPPSCOD>1    TZONE(IZON)="SRGPPS"
                              TMOD(IZON) =[M:SRO1]SRGPPSCOD
                              IZON+=1
    Endif
    If [M:SRO1]SRGPPSSCR>1    TZONE(IZON)="SRGPPS"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]SRGPPSSCR)
                              IZON+=1
    Endif

    If [M:SRO1]QTYSTUCOD>1    TZONE(IZON)="QTYSTUACT"
                              TMOD(IZON) =[M:SRO1]QTYSTUCOD
                              IZON+=1
    Endif
    If [M:SRO1]QTYSTUSCR>1    TZONE(IZON)="QTYSTUACT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]QTYSTUSCR)
                              IZON+=1
    Endif
#                                                                                    # hcb x3-82749 deb
   If dim([M:SRO1]LPNCOD) > 0
       If [M:SRO1]LPNCOD>1    TZONE(IZON)="LPNNUM"
                              TMOD(IZON) =[M:SRO1]LPNCOD
                              IZON+=1
       Endif
       If [M:SRO1]LPNSCR>1    TZONE(IZON)="LPNNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]LPNSCR)
                              IZON+=1
       Endif
    Endif
#                                                                                    # hcb x3-82749 fin

    If dim([M:SRO1]LOTCOD) > 0                     # hcb 27200
       If [M:SRO1]LOTCOD>1       TZONE(IZON)="LOT"
                              TMOD(IZON) =[M:SRO1]LOTCOD
                              IZON+=1
       Endif
       If [M:SRO1]LOTSCR>1       TZONE(IZON)="LOT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]LOTSCR)
                              IZON+=1
       Endif
    Endif                                         # hcb 27200
    If dim([M:SRO1]SLOCOD) > 0                    # hcb 27200
       If [M:SRO1]SLOCOD>1       TZONE(IZON)="SLO"
                              TMOD(IZON) =[M:SRO1]SLOCOD
                              IZON+=1
       Endif
       If [M:SRO1]SLOSCR>1       TZONE(IZON)="SLO"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]SLOSCR)
                              IZON+=1
       Endif
    Endif                                         # hcb 27200
    If [M:SRO1]STACOD>1       TZONE(IZON)="STA"
                              TMOD(IZON) =[M:SRO1]STACOD
                              IZON+=1
    Endif
    If [M:SRO1]STASCR>1       TZONE(IZON)="STA"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]STASCR)
                              IZON+=1
    Endif
    If [M:SRO1]LOCCOD>1       TZONE(IZON)="LOC"
                              TMOD(IZON) =[M:SRO1]LOCCOD
                              IZON+=1
    Endif
    If [M:SRO1]LOCSCR>1       TZONE(IZON)="LOC"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]LOCSCR)
                              IZON+=1
    Endif
    If dim([M:SRO1]SERCOD)> 0                             # hcb 27200
       If [M:SRO1]SERCOD>1       TZONE(IZON)="SERNUM"
                              TMOD(IZON) =[M:SRO1]SERCOD
                              IZON+=1
       Endif
       If [M:SRO1]SERSCR>1       TZONE(IZON)="SERNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]SERSCR)
                              IZON+=1
       Endif
       If [M:SRO1]SERECOD>1      TZONE(IZON)="SERNUMF"
                              TMOD(IZON) = 3
                              IZON+=1
       Endif
       If [M:SRO1]SERESCR>1      TZONE(IZON)="SERNUMF"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]SERESCR)
                              IZON+=1
       Endif
    Endif                                                 # hcb 27200

# hcb 27200 deb
   If dim([M:SRO1]IDECOD01)>0
     If [M:SRO1]IDECOD01>1   TZONE(IZON)="PALNUM"             : # identifiant 1
                             TMOD(IZON) =[M:SRO1]IDECOD01
                             IZON+=1
     Endif
     If [M:SRO1]IDESCR01>1   TZONE(IZON)="PALNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SRO1]IDESCR01)
                             IZON+=1
     Endif
     If [M:SRO1]IDECOD02>1   TZONE(IZON)="CTRNUM"             : # identifiant 3
                             TMOD(IZON) =[M:SRO1]IDECOD02
                             IZON+=1
     Endif
     If [M:SRO1]IDESCR02>1   TZONE(IZON)="CTRNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SRO1]IDESCR02)
                             IZON+=1
     Endif
   Endif
# hcb 27200 fin

    If [M:SRO1]MVTDESCOD>1    TZONE(IZON)="MVTDES"
                              TMOD(IZON) =[M:SRO1]MVTDESCOD
                              IZON+=1
    Endif
    If [M:SRO1]MVTDESSCR>1    TZONE(IZON)="MVTDES"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]MVTDESSCR)
                              IZON+=1
    Endif
#                      Menu local 60  A I
    If [M:SRO1]BPRNUMCOD >1   TZONE(IZON)="BPRNUM"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]BPRNUMSCR >1   TZONE(IZON)="BPRNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]BPRNUMSCR)
                              IZON+=1
    Endif
    If [M:SRO1]STUCOD   >1    TZONE(IZON)="STU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]STUSCR>1       TZONE(IZON)="STU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]STUSCR)
                              IZON+=1
    Endif
    If [M:SRO1]QTYSTUOCOD>1   TZONE(IZON)="QTYSTUORIA"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]QTYSTUOSCR>1   TZONE(IZON)="QTYSTUORIA"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]QTYSTUOSCR)
                              IZON+=1
    Endif

    If [M:SRO1]ORIREOCOD >1   TZONE(IZON)="ORIREO"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]ORIREOSCR >1   TZONE(IZON)="ORIREO"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]ORIREOSCR)
                              IZON+=1
    Endif

    If [M:SRO1]DEFTYPCOD >1   TZONE(IZON)="DEFTYPLOC"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]DEFTYPSCR>1   TZONE(IZON)="DEFTYPLOC"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]DEFTYPSCR)
                              IZON+=1
    Endif
    If [M:SRO1]DEFLOCCOD >1   TZONE(IZON)="DEFLOC"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]DEFLOCSCR>1   TZONE(IZON)="DEFLOC"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]DEFLOCSCR)
                              IZON+=1
    Endif
    If [M:SRO1]CLEFLGCOD >1   TZONE(IZON)="CLEFLG"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]CLEFLGSCR >1   TZONE(IZON)="CLEFLG"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]CLEFLGSCR)
                              IZON+=1
    Endif
    If [M:SRO1]VCRNUMCOD >1   TZONE(IZON)="VCRNUM"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRO1]VCRNUMSCR>1   TZONE(IZON)="VCRNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRO1]VCRNUMSCR)
                              IZON+=1
    Endif


    OPT1=2
    Gosub PE_STKTRS
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
#--- Génération des écrans et fenêtres de stock
WNOMOBJ="SRO"
WNOMTRS=[M:SRO0]SRTNUM
WACSCOD=[M:SRO0]ACSCOD
WLIBEL =[M:SRO0]DESAXX
WENAFLG=[M:SRO0]ENAFLG
WNUM   =2
Return

#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV

Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:SRO0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre  si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
#  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
  I=find("REO1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SRO0]ACSCOD
  [F:AWI]LIBEL     = [M:SRO0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SRO0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN

Return

#-----------------------------------------------------------------#
# Modification des écrans de base si sections d'entête invisibles #
#-----------------------------------------------------------------#
$MODIF_ECRAN
Return


#---------------------------------------#
# Restauration de l'écran de base REO1  #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return

$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(5)
Local Char WABR(06)(5)
#
Raz WMSK, WABR
Call TEXTFIC("PURTRS","PTRNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("PURTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:SRO0]SRTNUM-[M:SRO0]DESAXX-WINT(1)+" : "+[M:SRO0]ACSCOD
WMSK(0) = "SRO0"
WMSK(1) = "SRO1"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return

