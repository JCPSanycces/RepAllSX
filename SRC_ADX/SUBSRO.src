#   Endif                         # hcb 27200
#   If dim([M:SRO1]SLOCOD) > 0    # hcb 27200
#      Affzo [M:SRO1]SLOSCR
#      Grizo [M:SRO1]SLOSCR
#   Endif                         # hcb 27200
#   Affzo [M:SRO1]STKFLG
#   Grizo [M:SRO1]STASCR
#   Grizo [M:SRO1]LOCSCR
#   If dim([M:SRO1]SERCOD) > 0    # hcb 27200
#      Grizo [M:SRO1]SERSCR
#      Grizo [M:SRO1]SERESCR
#      Grizo [M:SRO1]SERECOD
#   Endif                         # hcb 27200
#   If dim([M:SRO1]IDECOD01) > 0  # hcb 27200
#      Grizo [M:SRO1]IDESCR01     # hcb 27200
#      Grizo [M:SRO1]IDESCR02     # hcb 27200
#    Endif                        # hcb 27200
#   Grizo [M:SRO1]STKFLG
#Else
