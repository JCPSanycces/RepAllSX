######################################################################################
$ANA_ORIGINE
# locreo = 2   emplacement reapprovisionnable
# csmreo = 4   zone consommation
# shtreo = 8   rupture sur emplacement

# GORIGINE = 2  4 10 14   + GLOCREO = 2
# GORIGINE = 4  6 12 14   + GCSMREO = 2
# GORIGINE = 8 10 12 14   + GSHTREO = 2

#                                                                           hcb 93103 deb
# Si VT on autorise toutes les origines (pas de transaction) ->   non depuis hcb 93103
#If GVTMOD
#   If dim(GLOCREO) <= 0
#      Global Integer GLOCREO
#   Endif
#   If dim(GCSMREO) <= 0
#      Global Integer GCSMREO
#   Endif
#   If dim(GSHTREO) <= 0
#      Global Integer GSHTREO
#   Endif
#   GLOCREO = 2
#   GCSMREO = 2
#   GSHTREO = 2
#   Return
#Endif
#                                                                           hcb 93103 fin

If dim(GORIGINE) <= 0
   Global Integer GORIGINE
Endif
Raz GORIGINE
If [M:SRO1]LOCREO = 2
   GORIGINE      += 2
Endif
If [M:SRO1]CSMREO = 2
    GORIGINE     += 4
Endif
If [M:SRO1]SHTREO = 2
   GORIGINE      += 8
Endif

If GFONC1 <> "GESSRO"
   If dim(GLOCREO) <= 0
      Global Integer GLOCREO
   Endif
   If dim(GCSMREO) <= 0
      Global Integer GCSMREO
   Endif
   If dim(GSHTREO) <= 0
      Global Integer GSHTREO
   Endif
   Raz GLOCREO
   Raz GCSMREO
   Raz GSHTREO
   If find(GORIGINE,2,6,10,14)
      GLOCREO = 2
   Endif
   If find(GORIGINE,4,6,12,14)
      GCSMREO = 2
   Endif
   If find(GORIGINE,8,10,12,14)
      GSHTREO = 2
   Endif
   Return
Endif

