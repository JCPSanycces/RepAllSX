   Actzo [M:SRO1]STACOD
   Actzo [M:SRO1]LOCCOD
   If dim([M:SRO1]LOTCOD) > 0    # hcb 27200
      Actzo [M:SRO1]LOTCOD
   Endif                         # hcb 27200
   If dim([M:SRO1]SLOCOD) > 0    # hcb 27200
      Actzo [M:SRO1]SLOCOD
   Endif                         # hcb 27200
   If dim([M:SRO1]SERCOD) > 0    # hcb 27200
      Actzo [M:SRO1]SERCOD
      Actzo [M:SRO1]SERECOD
   Endif                         # hcb 27200
   If dim([M:SRO1]IDECOD01) > 0  # hcb 27200
      Actzo [M:SRO1]IDECOD01     # hcb 27200
      Actzo [M:SRO1]IDECOD02     # hcb 27200
   Endif                         # hcb 27200
#                                                           # hcb 121947 deb
If GORIGINE = 4
   [M:SRO1]STKFLG  = 1
   Grizo [M:SRO1]STKFLG
Else
   Actzo [M:SRO1]STKFLG
Endif
#                                                           # hcb 121947 deb
   If dim([M:SRO1]LOTCOD) > 0    # hcb 27200
      If [M:SRO1]LOTCOD   =3  Grizo [SRO1]LOTSCR     Else Actzo [SRO1]LOTSCR    : Endif
   Endif                         # hcb 27200
   If dim([M:SRO1]SLOCOD) > 0    # hcb 27200
      If [M:SRO1]SLOCOD   =3  Grizo [SRO1]SLOSCR     Else Actzo [SRO1]SLOSCR    : Endif
   Endif                         # hcb 27200
   If [M:SRO1]STACOD   =3  Grizo [SRO1]STASCR     Else Actzo [SRO1]STASCR    : Endif
   If [M:SRO1]LOCCOD   =3  Grizo [SRO1]LOCSCR     Else Actzo [SRO1]LOCSCR    : Endif
   If dim([M:SRO1]SERCOD) > 0    # hcb 27200
      If [M:SRO1]SERCOD   =3  Grizo [SRO1]SERSCR     Else Actzo [SRO1]SERSCR    : Endif
      If [M:SRO1]SERECOD  =2  Grizo [SRO1]SERESCR    Else Actzo [SRO1]SERESCR   : Endif
   Endif                         # hcb 27200
   If dim([M:SRO1]IDECOD01) > 0  # hcb 27200
      If [M:SRO1]IDECOD01 =3  Grizo [SRO1]IDESCR01   Else Actzo [SRO1]IDESCR01  : Endif  # hcb 27200
      If [M:SRO1]IDECOD02 =3  Grizo [SRO1]IDESCR02   Else Actzo [SRO1]IDESCR02  : Endif  # hcb 27200
   Endif                         # hcb 27200

#Endif
#                                                            # hcb 121947

If find(GORIGINE,2,6,10,14)
   [M:SRO1]BPRNUMCOD = 1
   [M:SRO1]BPRNUMSCR = 1
   [M:SRO1]CLEFLGCOD = 1
   [M:SRO1]CLEFLGSCR = 1
   Affzo [M:SRO1]BPRNUMSCR
   Affzo [M:SRO1]BPRNUMCOD
   Actzo [M:SRO1]BPRNUMSCR
   Actzo [M:SRO1]BPRNUMCOD
Else
   [M:SRO1]BPRNUMCOD = 2
   [M:SRO1]BPRNUMSCR = 1
   [M:SRO1]CLEFLGCOD = 2
   [M:SRO1]CLEFLGSCR = 1
   Affzo [M:SRO1]BPRNUMSCR
   Affzo [M:SRO1]BPRNUMCOD
   Diszo [M:SRO1]BPRNUMSCR
   Diszo [M:SRO1]BPRNUMCOD
Endif

If find(GORIGINE,4,6,12,14)
   [M:SRO1]DEFTYPCOD = 1
   [M:SRO1]DEFTYPSCR = 1
   [M:SRO1]DEFLOCCOD = 1
   [M:SRO1]DEFLOCSCR = 1
   Affzo [M:SRO1]DEFTYPCOD
   Affzo [M:SRO1]DEFTYPSCR
   Affzo [M:SRO1]DEFLOCCOD
   Affzo [M:SRO1]DEFLOCSCR
   Actzo [M:SRO1]DEFTYPCOD
   Actzo [M:SRO1]DEFTYPSCR
   Actzo [M:SRO1]DEFLOCCOD
   Actzo [M:SRO1]DEFLOCSCR
Else
   [M:SRO1]DEFTYPCOD = 2
   [M:SRO1]DEFTYPSCR = 1
   [M:SRO1]DEFLOCCOD = 2
   [M:SRO1]DEFLOCSCR = 1
   Affzo [M:SRO1]DEFTYPCOD
   Affzo [M:SRO1]DEFTYPSCR
   Affzo [M:SRO1]DEFLOCCOD
   Affzo [M:SRO1]DEFLOCSCR
   Grizo [M:SRO1]DEFTYPCOD
   Grizo [M:SRO1]DEFTYPSCR
   Grizo [M:SRO1]DEFLOCCOD
   Grizo [M:SRO1]DEFLOCSCR
Endif
If GORIGINE = 2
   [M:SRO1]VCRNUMCOD = 2
   [M:SRO1]VCRNUMSCR = 1
   Affzo [M:SRO1]VCRNUMCOD
   Affzo [M:SRO1]VCRNUMSCR
   Grizo [M:SRO1]VCRNUMCOD
   Grizo [M:SRO1]VCRNUMSCR
Else
   Actzo [M:SRO1]VCRNUMCOD
   Affzo [M:SRO1]VCRNUMCOD
   If [M:SRO1]VCRNUMCOD   =2  Grizo [SRO1]VCRNUMSCR     Else Actzo [SRO1]VCRNUMSCR    : Endif
Endif
Return

##########################################################################

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(9,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(9,APPLI) From FUNSTKTRS

End

#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 9;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 9 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=9;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif



