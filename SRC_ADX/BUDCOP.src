#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILCOD
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","BUDCOP","DBUDCOP",3,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"     : Gosub OUVRE
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "FIN"      : Gosub FIN
Endcase
Return


##############################################################################
$OUVRE
If clalev([F:BUD]) =0 : Local File BUD        [BUD]  : Endif
If clalev([F:BUD2])=0 : Local File BUD        [BUD2] : Endif
If clalev([F:BUP]) =0 : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUPO])=0 : Local File BUDPAR     [BUPO] : Endif
If clalev([F:BUPD])=0 : Local File BUDPAR     [BUPD] : Endif
If clalev([F:BUV]) =0 : Local File BUDVER     [BUV]  : Endif
If clalev([F:BUVO])=0 : Local File BUDVER     [BUVO] : Endif
If clalev([F:BUVD])=0 : Local File BUDVER     [BUVD] : Endif

If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:DTP])=0  : Local File CADISTMP   [DTP]  : Endif : # Répartition temporelle
If clalev([F:TUN])=0  : Local File TABUNIT    [TUN]  : Endif : # Unités d'oeuvre
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif : # Devise

#150
If clalev([F:GYM])=0  : Local File GACCPYM     [GYM]  : Endif : # Pyramides comptes
If clalev([F:GRY])=0  : Local File GACCGRUPYM  [GRY]  : Endif : # Groupes de comptes
If clalev([F:CYM])=0  : Local File GCCEPYM     [CYM]  : Endif : # Pyramides sections
If clalev([F:CRY])=0  : Local File GCCEGRUPYM  [CRY]  : Endif : # Groupes de sections
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif : # Comptes
If clalev([F:GCM])=0  : Local File GACM        [GCM]  : Endif : # Modèle comptable
If clalev([F:LED])=0  : Local File GLED        [LED]  : Endif : # Referentiel

###GLONFCY car dans la table BUD, le champ FCY qui contient
###soit un site, soit une société, est de type FCY.
Local Char    SOCORG(GLONFCY)    : # Société budget origine
Local Char    SOCDES(GLONFCY)    : # Société budget destination

Local Char    SITORG(GLONFCY)    : # Site budget origine
Local Char    SITDES(GLONFCY)    : # Site budget destination
Local Char    SYMBOLE1(50), SYMBOLE2(50)
Local Integer INDAXE
Local Integer OK
Local Char    CODRTP(GLONDTP)    : # Code de répartition temporelle
Local Integer PYR, PDEB, PFIN
Local Decimal COEDTP(1..99), SUMCOE, SUMAMT, SUMQTY, MTREP, QTREP, MTAREP, QTAREP
Local Decimal ARRONDI1, ARRONDI2
Local Date    DATDEB, DATFIN
Local Char    NUMCPT (GLONVCR)          : # No pour compteur d'OD budgétaires
Local Char    LEDCOD(GLONLED)

Local Integer  I, K , NBDIM, M, N

TIT = mess(43,108,1) : # Copie de budgets
Local Mask BUDCOP [DIA]

Raz [M:DIA]
Return


###########################################
$CONTROLE
TMP = 1
Return

$FIN
Return

###########################################
$EXEC
#Check on BUPO: origin budget
Read [BUPO]BUP0 = [M]BUDORG
If [F:BUPO]LEV = 1
 SOCORG = [M]CPYORG
 SITORG = ""
Else
 SOCORG = [M]CPYORG
 SITORG = [M]FCYORG
Endif
Call LECTURE("TCU",[F:BUPO]CUR,"") From CONTOBJ
ARRONDI1 = [F:TCU]CURRND

If [M]FLGDSP=2
 # PYR indique si le compte du budget est une pyramide ou pas
 If [F:BUPD]PYMACC="" :  PYR = 0
 Else PYR = 1
 Endif
 Call DEF_LEDTYP([M]CPYDES,[F:BUPD]COA,[M]LEDTYPDES)

 # Recherche de la période début et fin de l'exercice
 Raz PDEB,PFIN
 Filter [PER] Where CPY=[M]CPYDES & LEDTYP=[M]LEDTYPDES & FIYNUM=[M]FIYDES & PERSTR=[M]DATDDES
 Read [PER]PER0 First
 PDEB = [F:PER]PERNUM
 Filter [PER] Where CPY=[M]CPYDES & LEDTYP=[M]LEDTYPDES & FIYNUM=[M]FIYDES & PEREND=[M]DATFDES
 Read [PER]PER0 First
 PFIN = [F:PER]PERNUM
Endif

#Check on BUPD: destination budget
Read [BUPD]BUP0 = [M]BUDDES
If !fstat
 If [F:BUPD]LEV = 1
  SOCDES = [M]CPYDES
  SITDES = ""
 Else
  SOCDES = [M]CPYDES
  SITDES = [M]FCYDES
 Endif
 Call LECTURE("TCU",[F:BUPD]CUR,"") From CONTOBJ
 ARRONDI1 = [F:TCU]CURRND
Else
 SOCDES=SOCORG
 SITDES=SITORG
Endif

OK = 1 : Gosub VERROU
If !OK : GERR = 1 : SAI = 1 : Return : Endif

Call ANUBUD(SITDES)
If GOK<1 : GERR = 1 : SAI = 1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TRANSAC
If GOK<1 : GERR = 1 : SAI = 1 : Return : Endif

Gosub DEVERROU
Return

################################################################################################
Subprog DEF_LEDTYP(LCPY,LCOA,NLED)
Value    Char    LCPY
Value    Char    LCOA
Variable Integer NLED

OK=0
Read [CPY]CPY0 = LCPY
If !fstat
 Read [GCM]GCM0 = [F:CPY]ACM

# Read [LED]LED0 =
 If !fstat
#  NLED = find([LED]LED, [GCM]LED)
  For NLED = 1 To len(mess(0,2644,1))
   Read [LED]LED0 = [F:GCM]LED(NLED-1)
   If !fstat
    If [F:LED]COA = LCOA : OK=1 : Break : Endif
   Endif
  Next
 Endif
Endif
If OK=0

Endif
End

$TRANSAC
GOK = 1
Call LEC_LED([F:GCM]LED([M]LEDTYPDES-1)) From CPTLEC
LEDCOD = [F:LED]LED
Trbegin [BUD2], [BUD]
 For [BUD2]BUD0 Where BUD=[M]BUDORG & (([F:BUPO]LEV=1 & CPY=SOCORG) | ([F:BUPO]LEV<>1 & FCY=SITORG))
&                   & FIY=[M]FIYORG & VER=[M]VERORG & LEDTYP=[M]LEDTYPORG
  Raz [F:BUD]
  [F:BUD]       = [F:BUD2]
  [F:BUD]BUD    = [M]BUDDES
  [F:BUD]CPY    = SOCDES
  [F:BUD]FCY    = SITDES
  [F:BUD]FIY    = [M]FIYDES
  [F:BUD]ACC    = [F:BUD2]ACC
  [F:BUD]VER    = [M]VERDES
  [F:BUD]LEDTYP = [M]LEDTYPDES
  [F:BUD]LED    = LEDCOD
  ## Base de transfert en montants annuels
  If [M]FLGDSP=2
   Gosub REPART
   MTAREP = sum([F:BUD2]AMT(PDEB-1..PFIN-1))*[M]COEF
   QTAREP = sum([F:BUD2]QTY(PDEB-1..PFIN-1))*[M]COEF
   For I=PDEB To PFIN
    MTREP            = MTAREP*COEDTP(I)/SUMCOE
    [F:BUD]AMT(I-1) = arr(SUMAMT+MTREP,ARRONDI1)-arr(SUMAMT,ARRONDI1)
    SUMAMT          += MTREP
    QTREP            = QTAREP*COEDTP(I)/SUMCOE
    [F:BUD]QTY(I-1) = arr(SUMQTY+QTREP,ARRONDI2)-arr(SUMQTY,ARRONDI2)
    SUMQTY          += QTREP
   Next
  Else
   ## Base de transfert en montants par périodes
   ## Gestion d'un coef d'augmentation ou de diminution du budget
   If [M]COEF<>1
    NBDIM = dim([F:BUD]AMT)
    For K=0 To NBDIM-1
     [F:BUD]AMT (K) =[F:BUD2]AMT(K)*[M]COEF
     [F:BUD]QTY (K) =[F:BUD2]QTY(K)*[M]COEF
    Next
   Endif
  Endif
  Gosub INDDIE From BUDGET3
  # BUD2 = origin budget
  # BUD  = destination budget
  # effacement des champs DIEx/CCEx du budget destination
  For I=1 To 9
   Assign "[F:BUD]DIE"+num$(I) With ""
   Assign "[F:BUD]CCE"+num$(I) With ""
  Next

  For I=1 To 9
   # recherche de l'axe d'origine dans le paramétrage du budget destination
   If find(evalue("[F:BUD2]DIE"+num$(I)), [F:BUPD]DIE)
    # recherche de l'indice de l'axe d'origine dans le référentiel destination
    DSTDIE = find(evalue("[F:BUD2]DIE"+num$(I)), [F:LED]DIE)
    If DSTDIE>0
     Assign "[F:BUD]DIE"+num$(DSTDIE) With evalue("[F:BUD2]DIE"+num$(I))
     Assign "[F:BUD]CCE"+num$(DSTDIE) With evalue("[F:BUD2]CCE"+num$(I))
    Endif
   Endif
  Next
  [F:BUD]ACCNUM = uniqid([F:BUD])
  Gosub INICRE
  Write [BUD]
  If fstat
   GOK = 0 : Call FSTA("BUD") From GLOCK : Break
  Endif

  If [F:BUP]BUPODS=3      :#Création auto autorisée
   NUMCPT=""
   Gosub CREEBDO From MAJBDO
  Endif
  Call INIBLA From CPTBAL
 Next
 If   GOK<0 : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
Commit
Return

$INICRE
If dim([F:BUD]CREDAT)>0 : [F:BUD]CREDAT=date$ : Endif
If dim([F:BUD]CREUSR)>0 : [F:BUD]CREUSR=GUSER : Endif
If dim([F:BUD]UPDDAT)>0 : Raz [F:BUD]UPDDAT   : Endif
If dim([F:BUD]UPDUSR)>0 : Raz [F:BUD]UPDUSR   : Endif
Return

$REPART
If PYR=0
 Call LECTURE("GAC",[F:BUD2]ACC,[F:BUD2]COA) From CONTOBJ
 CODRTP = [F:GAC]TIMDSP
 Call LECTURE("TUN",[F:GAC]UOM,"") From CONTOBJ
 ARRONDI2 = 1/(10^[F:TUN]UOMDEC)
Else
 Call LECTURE("GRY",[F:BUPO]PYMACC,[F:BUD2]ACC) From CONTOBJ
 CODRTP = [F:GRY]TIMDSP
 Call LECTURE("TUN",[F:GRY]UOM,"") From CONTOBJ
 ARRONDI2 = 1/(10^[F:TUN]UOMDEC)
Endif
Read [DTP]DTP0 = CODRTP
If fstat
 For I=0 To dim([F:DTP]COE)-1
  [F:DTP]COE(I) = 1
 Next
Endif
Raz COEDTP, SUMCOE
# Recherche du coefficient
For I=PDEB To PFIN
 Call DATPER([M]CPYDES,[M]LEDTYPDES,[M]FIYDES,I,DATDEB,DATFIN) From CPTSUB
 # le sous-programme DATPER renvoie la date de début et la date de fin
 # de la période I de l'exercice EXO pour la société CPY
 While DATDEB<>[0/0/0]
  M = month(DATDEB)        : # M contient le no du mois de DATDEB
  N = day(eomonth(DATDEB)) : # N contient le dernier jour de DATDEB
  If M=month(DATFIN)       : # J contient le nb de jours de la période I
   J = DATFIN-DATDEB+1
   DATDEB = [0/0/0]
  Else
   J = eomonth(DATDEB)-DATDEB+1
   DATDEB = eomonth(DATDEB)+1
  Endif
  COEDTP(I) += [F:DTP]COE(M-1)*J/N
 Wend
 SUMCOE += COEDTP(I)
Next
Return

$AB_TRANSAC
Rollback
Return

$ROLL_TRANSAC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRANSAC : Endif
Return


$VERROU
SYMBOLE1 = "BUD"+[M]BUDORG+"\"+SOCORG+"\"+SITORG+"\"+[M]VERORG+"\"+num$([M]FIYORG)
Lock =SYMBOLE1 With lockwait=0
If fstat
 # Modification en cours sur un autre poste
 OK = 0 : GMESSAGE = mess(10,100,1) : Return
Endif
SYMBOLE2 = "BUD"+[M]BUDDES+"\"+SOCDES+"\"+SITDES+"\"+[M]VERDES+"\"+num$([M]FIYDES)
Lock =SYMBOLE2 With lockwait=0
If fstat
 # Modification en cours sur un autre poste
 OK = 0 : GMESSAGE = mess(10,100,1) : Return
Endif
Return

$DEVERROU
Unlock =SYMBOLE1
Unlock =SYMBOLE2
Return


############################################################################
Subprog ANUBUD(SITDES)
Value Char SITDES()
# Effacement des budgets qui avaient été saisis pour le budget destination
############################################################################
If clalev([F:BUD])=0  : Local File BUD  [BUD] : Endif
Call DEBTRANS From GLOCK
Gosub TR_ANNUL
End

$TR_ANNUL
GOK = 1
Trbegin [BUD]

 If [F:BUP]BUPODS=3      :# Création auto autorisée
  For [BUD] Where BUD=[M]BUDDES & LEDTYP=[M]LEDTYPDES & CPY=[M]CPYDES & FCY=SITDES & FIY=[M]FIYDES & VER=[M]VERDES
   NUMCPT=""
   For X=0 To dim([F:BUD]AMT)-1
    [F:BUD]AMT(X) = [F:BUD]AMT(X)*-1
    If [BUP]QTY=2
     [F:BUD]QTY(X) = [F:BUD]QTY(X)*-1
    Endif
   Next
   Gosub CREEBDO From MAJBDO
   If GOK=0 : Break : Endif
  Next
  If !GOK : End : Endif
 Endif

 Delete [BUD] Where BUD=[M]BUDDES & LEDTYP=[M]LEDTYPDES & CPY=[M]CPYDES & FCY=SITDES & FIY=[M]FIYDES & VER=[M]VERDES
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("BUD",[M]BUDDES-SIT-num$([M]FIYDES)) From GLOCK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif

########################################################
# Etiquettes du masque BUDCOP
########################################################
Subprog C_BUDORG(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call CONTROLE("BUP","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Read [BUPO]BUP0 = VALEUR
End

Subprog AS_CPYORG(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUDORG,"") From CONTOBJ
If [F:BUP]LEV=2
 mkstat=2 : End
Endif
End

Subprog C_CPYORG(VALEUR)
Variable Char    VALEUR()
Call CONTALLFCY(VALEUR) From CPTSUB
# initialisation de [M]LEDTYPORG
Call DEF_LEDTYP(VALEUR,[F:BUPO]COA,[M]LEDTYPORG)
End

Subprog AS_FCYORG(VALEUR)
Variable Char    VALEUR()
#Call LECTURE("BUP",[M]BUDORG,"") From CONTOBJ
If [F:BUPO]LEV=1
 mkstat=1 : End
Endif
End

Subprog AP_FCYORG(VALEUR)
Variable Char    VALEUR()
If [F:BUPO]LEV=2
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 [M]CPYORG=[F:FCY]LEGCPY
 Affzo CPYORG
Endif
End

Subprog C_FIYORG(VALEUR)
Variable Decimal VALEUR
If clalev([F:FIY])=0
 Local File FISCALYEAR [FIY]
Endif
Read [FIY]FIY0 = [M]CPYORG;[M]LEDTYPORG;VALEUR
If fstat
 # Exercice incorrect
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
End

Subprog AM_FIYORG(VALEUR)
Variable Decimal VALEUR
Call DATEXE([M]CPYORG,[M]LEDTYPORG,VALEUR,[M]DATDORG,[M]DATFORG) From CPTSUB
If !GIMPORT : Affzo DATDORG , DATFORG : Endif
End

Subprog C_BUDDES(VALEUR)
Variable Char    VALEUR()
Effzo [M]DESBUDDES
Read [F:BUPD]BUP0 = VALEUR
If fstat =0
 Call LECTEXTRA([M]DESBUDDES,"BUDPAR","DESTRA",[F:BUPD]BUD,"") From ATEXTRA
 If clalev([F:BUDO])=0 : Local File BUD [BUDO] : Endif
 Local Integer INDAXE, I

 Call C_BUD(VALEUR) From BUDSUB
 If mkstat : End : Endif

 # On contrôle que le budget de destination a le même niveau de définition
 # (société ou site) que le budget d'origine
 Read [BUPO]BUP0 = [M]BUDORG
 If !fstat & [F:BUPO]LEV<>[F:BUPD]LEV
  If [F:BUPD]LEV = 1
   # Budget défini au niveau société
   GMESSAGE = mess(33,108,1)
   mkstat = 2 : End
  Else
   # Budget défini au niveau site
   GMESSAGE = mess(32,108,1)
   mkstat = 2 : End
  Endif
 Endif

 For I=1 To dim([F:BUPD]DIE)
  INDAXE = find(evalue("[F:BUPD]DIE("+num$(I-1)+")"), [F:BUPO]DIE)
  If !INDAXE : Break : Endif
 Next
 If INDAXE = 0
  # Axes incompatibles
  GMESSAGE = mess(37,108,1)
  mkstat = 2 : End
 Endif

 # Si des pyramides sont associées au budget d'origine, les mêmes pyramides
 # doivent être associées au budget de destination
 If ([F:BUPO]PYMACC<>[F:BUPD]PYMACC) | ([F:BUPO]PYMACCLEV<>[F:BUPD]PYMACCLEV)
  # [F:BUPD]BUD n'est pas défini sur la même pyramide compte que [F:BUPO]BUD
  GMESSAGE = [F:BUPD]BUD-tolower(mess(41,108,1))-[F:BUPO]BUD
  mkstat = 2 : End
 Endif

 For I=1 To dim([F:BUPD]DIE)
  INDAXE = find(evalue("[F:BUPD]DIE("+num$(I-1)+")"), [F:BUPO]DIE)
  If evalue("[F:BUPD]PYMCCE("+num$(I-1)+")") <> evalue("[F:BUPO]PYMCCE("+num$(INDAXE-1)+")")
& | evalue("[F:BUPD]PYMCCELEV("+num$(I-1)+")") <> evalue("[F:BUPO]PYMCCELEV("+num$(INDAXE-1)+")")
   # [F:BUP]BUD n'est pas défini sur les mêmes pyramides sections que [F:BUP2]BUD
   GMESSAGE = [F:BUPD]BUD-tolower(mess(42,108,1))-[F:BUPO]BUD
   mkstat = 2 : End
  Endif
 Next
#####Sinon on demande sa création !
Elsif fstat>2
 Local Integer OK
 #Paramétrage Budget inexistant, voulez-vous le créer ?
 OK=2
 Call OUINON(mess(40,104,1),OK) From GESECRAN
 If OK=2
  Read [F:BUPO]BUP0 = [M]BUDORG
  If ! fstat
   Raz [F:BUPD]
   [F:BUPD]=[F:BUPO]
   [F:BUPD]BUD=VALEUR
   Write [BUPD]
   If fstat
    GOK = 0 : Call FSTA("BUPD") From GLOCK
   Endif
   # Read the DESTRA of origin budget in order to fill in the destination budget DESTRA
   Call LECTEXTRA([M]DESBUDDES,"BUDPAR","DESTRA",[M]BUDORG,"") From ATEXTRA
   Call DUPTEXTRA("BUDPAR","DESTRA",[F:BUPO]BUD,"","BUDPAR","DESTRA",[F:BUPD]BUD,"")From ATEXTRA
  Endif
 Else
  mkstat=2 : End
 Endif
Endif
Affzo [M]DESBUDDES
End

Subprog AS_CPYDES(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUDDES,"") From CONTOBJ
If [F:BUP]LEV=2
 mkstat=2 : End
Endif
End

Subprog C_CPYDES(VALEUR)
Variable Char    VALEUR()
Call CONTALLFCY(VALEUR) From CPTSUB
# initialisation de LEDTYPDES
Call DEF_LEDTYP(VALEUR,[F:BUPD]COA,[M]LEDTYPDES)
End

Subprog AS_FCYDES(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M]BUDDES,"") From CONTOBJ
If[F:BUP]LEV=1
  mkstat=1 : End
Endif
End

Subprog AP_FCYDES(VALEUR)
Variable Char    VALEUR()
If [F:BUP]LEV=2
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 [M]CPYDES=[F:FCY]LEGCPY
 Affzo CPYDES
Endif
End

Subprog C_FIYDES(VALEUR)
Variable Decimal VALEUR
If clalev([F:FIY])=0
 Local File FISCALYEAR [FIY]
Endif
Read [FIY]FIY0 = [M]CPYDES;[M]LEDTYPDES;VALEUR
If fstat
 # Exercice incorrect
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
#il faut que le code budget soit actif sur la totalité de l'exercice
Call LECTURE("BUP",[M]BUDDES,"") From CONTOBJ
If ([F:BUP]VLYSTR>[F:FIY]FIYSTR) |([F:BUP]VLYEND<>[0/0/0] & [F:BUP]VLYEND<[F:FIY]FIYEND)
 # Code budget inactif
 GMESSAGE = mess(31,108,1)
 mkstat = 2 : End
Endif
End

Subprog AM_FIYDES(VALEUR)
Variable Decimal VALEUR
Call DATEXE([M]CPYDES,[M]LEDTYPDES,VALEUR,[M]DATDDES,[M]DATFDES) From CPTSUB
If !GIMPORT : Affzo DATDDES, DATFDES : Endif
End

Subprog AM_CPYORG(VALEUR)
Variable Char VALEUR()
# initialiser LEDTYPORG
Call DEF_LEDTYP(VALEUR,[F:BUPO]COA,[M]LEDTYPORG)
End

Subprog AM_CPYDES(VALEUR)
Variable Char VALEUR()
# initialiser LEDTYPDES
Call DEF_LEDTYP(VALEUR,[F:BUPD]COA,[M]LEDTYPDES)
End

Subprog C_VERDES(VALEUR)
Variable Char VALEUR()
Call LECTURE("BUV",VALEUR,[M]BUDDES) From CONTOBJ
If fstat=0
 If [F:BUV]STA=2
  GMESSAGE = mess(58,109,1) : # Version fermée
  mkstat = 2 : End
 Endif
 Call LECTEXTRA([M]DESVERDES,"BUDVER","DESTRA",[M]BUDDES,VALEUR)From ATEXTRA
# Sinon on demande sa création
Elsif fstat>2
 Local Integer OK
 # Version inexistante, voulez-vous la créer ?
 OK=2
 Call OUINON(mess(138,104,1),OK) From GESECRAN
 If OK=2
  # Version budget inexistante, voulez-vous la créer ?
  Read [F:BUVO]BUV0 = [M]BUDORG;[M]VERORG
  If !fstat
   Raz [F:BUVD]
   [F:BUVD]=[F:BUVO]
   [F:BUVD]BUD=[M]BUDDES
   [F:BUVD]VER=VALEUR
   Write [BUVD]
   If fstat
    GOK = 0 : Call FSTA("BUVD") From GLOCK
   Endif
   # Read the DESTRA of origin version budget in order to fill in the destination version budget DESTRA
   Call LECTEXTRA([M]DESVERDES,"BUDVER","DESTRA",[M]BUDORG,[M]VERORG)From ATEXTRA
   Call DUPTEXTRA("BUDVER","DESTRA",[F:BUVO]BUD,[F:BUVO]VER,"BUDVER","DESTRA",[F:BUVD]BUD,[F:BUVD]VER)From ATEXTRA
  Endif
 Else
  mkstat=2 : End
 Endif
Endif
Affzo [M]DESVERDES
End

######################################################################################
Subprog AS_LEDTYPORG(VALEUR)
Variable Integer VALEUR
Local Integer NB, LEDTYP, I
Local Char LED(250)
Local Libelle TYPLEDGEN, TYPLEDANA

# Initialiser le premier type de réferentiel de la société associé à un code référentiel flagué 'budget'
# et qui est cohérent par rapport au code plan et code axes du code budget (tous les axes du code budget
# doivent être présents dans le (ou les) réferentiel(s) 'budget'
# Si on n'en trouve qu'un alors mkstat=2

Read [CPY]CPY0=[M:DIA]CPYORG
Read [GCM]GCM0=[F:CPY]ACM
Read [BUP]BUP0=[M:DIA]BUDORG

# le référentiel est flaggé budget et n'est pas automatique

NB = 0
For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 Read [LED]LED0 = [F:GCM]LED(I-1)
 If [F:LED]BUD=2 & [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2
  NB    += 1
  LEDTYP = I
  GMENLOC(I) = 0
 Endif
Next I

# on doit initialiser avec la valeur du type de référentiel analytique principal
Call SETMAINREF([F:CPY]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
VALEUR = num$(TYPLEDANA)
# un seul type de référentiel trouvé
If NB = 1 : mkstat = 2 : Endif
End

######################################################################################
Subprog AS_LEDTYPDES(VALEUR)
Variable Integer VALEUR
Local Integer NB, LEDTYP, I
Local Char LED(250)
Local Libelle TYPLEDGEN, TYPLEDANA

# Initialiser le premier type de réferentiel de la société associé à un code référentiel flagué 'budget'
# et qui est cohérent par rapport au code plan et code axes du code budget (tous les axes du code budget
# doivent être présents dans le (ou les) réferentiel(s) 'budget'
# Si on n'en trouve qu'un alors mkstat=2

Read [CPY]CPY0=[M:DIA]CPYDES
Read [GCM]GCM0=[F:CPY]ACM
Read [BUP]BUP0=[M:DIA]BUDDES

# le référentiel est flaggé budget et n'est pas automatique

NB = 0
For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 Read [LED]LED0 = [F:GCM]LED(I-1)
 If [F:LED]BUD=2 & [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2
  NB    += 1
  LEDTYP = I
  GMENLOC(I) = 0
 Endif
Next I

# on doit initialiser avec la valeur du type de référentiel analytique principal
Call SETMAINREF([F:CPY]CPY,TYPLEDGEN,TYPLEDANA) From CPTDIV
VALEUR = num$(TYPLEDANA)
# un seul type de référentiel trouvé
If NB = 1 : mkstat = 2 : Endif
End

