#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FCY2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone MFGFLG
mkstat = 0
zoncou = "MFGFLG"
indice = 0
IMPENT = [M]MFGFLG
If varinit([M]MFGFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MFGFLG,indice)=0
 [M]MFGFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MFGFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MFGFLG(indice)
 Endif
Endif
[M]MFGFLG = IMPENT

## Zone SALFLG
mkstat = 0
zoncou = "SALFLG"
indice = 0
IMPENT = [M]SALFLG
If varinit([M]SALFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]SALFLG,indice)=0
 [M]SALFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SALFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SALFLG(indice)
 Endif
Endif
[M]SALFLG = IMPENT

## Zone PURFLG
mkstat = 0
zoncou = "PURFLG"
indice = 0
IMPENT = [M]PURFLG
If varinit([M]PURFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PURFLG,indice)=0
 [M]PURFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PURFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PURFLG(indice)
 Endif
Endif
[M]PURFLG = IMPENT

## Zone WRHFLG
mkstat = 0
zoncou = "WRHFLG"
indice = 0
IMPENT = [M]WRHFLG
If varinit([M]WRHFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]WRHFLG,indice)=0
 [M]WRHFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WRHFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WRHFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_WRHFLG(IMPENT) From SUBFCYB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WRHFLG" : GZNUM = 3822 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]WRHFLG = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone UVYDAY
mkstat = 0
zoncou = "UVYDAY"
For indice=0 To 6
 IMPENT = [M]UVYDAY(indice)
 If varinit([M]UVYDAY,indice)=0
  IMPENT = 1
 Endif
 If varmode([M]UVYDAY,indice)=0
  [M]UVYDAY(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "UVYDAY" : Gosub ACTION From =IMPTRT
   IMPENT = [M]UVYDAY(indice)
  Endif
 Endif
 [M]UVYDAY(indice) = IMPENT
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone UVYCOD
mkstat = 0
zoncou = "UVYCOD"
indice = 0
If varmode([M]UVYCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UVYCOD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TUV","!",[M]UVYCOD,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "UVYCOD" : GZNUM = 3677 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone BPTNUM
mkstat = 0
zoncou = "BPTNUM"
indice = 0
If varmode([M]BPTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPTNUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPT","!",[M]BPTNUM,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPTNUM" : GZNUM = 1434 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PAYBAN
mkstat = 0
zoncou = "PAYBAN"
indice = 0
If varmode([M]PAYBAN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYBAN" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BAN","!",[M]PAYBAN,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PAYBAN" : GZNUM = 5396 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SPAOPEIGIC
mkstat = 0
zoncou = "SPAOPEIGIC"
indice = 0
IMPENT = [M]SPAOPEIGIC
SAVACT = GACTION : GACTION = "STD"
Call AV_SPAOPEIGIC(IMPENT) From SUBFCYB
GACTION = SAVACT
If mkstat=1 : Raz IMPENT : Endif
If !mkstat
 If varinit([M]SPAOPEIGIC,indice)=0
  IMPENT = 1
 Endif
Endif
If varmode([M]SPAOPEIGIC,indice)=0
 [M]SPAOPEIGIC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAOPEIGIC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAOPEIGIC(indice)
 Endif
Endif
[M]SPAOPEIGIC = IMPENT

## Zone FMTESP
mkstat = 0
zoncou = "FMTESP"
indice = 0
If varinit([M]FMTESP,indice)=0
 [M]FMTESP = "+LA:1"
Endif

## Zone STRHOU
mkstat = 0
zoncou = "STRHOU"
indice = 0
If varmode([M]STRHOU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRHOU" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ENDHOU
mkstat = 0
zoncou = "ENDHOU"
indice = 0
If varmode([M]ENDHOU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDHOU" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "FCY2"
Return

