#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
############################################################################
$ACTION

Case ACTION
   When "INIT"     : Gosub INIT
   When "CONTROLE" : Gosub CONTROLE
   When "EXEC"     : Gosub EXEC
   When "SORTIE"   : Gosub SORTIE
   When "INIT_DIA" : Gosub INIT_DIA
Endcase

Return
$INIT_DIA
Raz [M:TDC0]
Return
############################################################################
############################################################################
$INIT

Gosub OUVRE From CNSTDCSTDTRT
Local Integer DOCPRC  : [L]DOCPRC=0
Local Integer CHGPAG  : [L]CHGPAG = 3

Return
############################################################################
############################################################################
$CONTROLE

#Call OUVRE_TRACE(mess(102,7711,1)) From LECFIC
#Gosub LIC_CONTROLE From STDTRNDOC
#If !OK
#   GERR = 1
#   FIN  = 1
#Endif

Return
############################################################################
############################################################################
$EXEC
If GTRACE = "" : Call OUVRE_TRACE(mess(168,7711,1)) From LECFIC : Endif
If GSERVEUR=0 : Call TEMPON ("O") From GESECRAN : Endif

[M:TDC0]STAT = 5

Gosub LOAD_FILTER From CNSTDCSTDTRT

If [M:TDC0]DOCTYP = 1
  Gosub LNK_ALL_ASC From CNSTDCSTDTRT
Else
  Gosub LNK_NALL_ASC From CNSTDCSTDTRT
Endif

WFIL -='& [F:DKD]ATDTCOD=""'
For [LNK] Where evalue(WFIL) & evalue (WFIL1) & evalue (WFIL2) & evalue (WFIL3) & evalue (WFIL4) & evalue (WFIL5)
  Case [F:DKD]VCRTYP
    When 2
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP, [F:SDH]BPCORD, [F:SDH]SDHTYP, [F:SDH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
      If ctrans([F:SDH]BPDADDLIG(0)+[F:SDH]BPDADDLIG(1)+[F:SDH]BPDADDLIG(2)," ","")<>''
        If [F:SDH]BPDCRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func CNSTDCSTDTRT.GET_BPRNUM([F:DKD]VCRTYP),func CNSTDCSTDTRT.GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From
& SAFTGENPORMG
        If PMGCOUNTRY_ST<>'PT'
          Goto NEXT_RECORD
        Endif
      Endif

      # BRBAN 24-03-2015 #106027
      If func PORLEGLIB1.CTRL_COMDAT([F:SDH]STOFCY,[F:SDH]DPEDAT,[F:SDH]ETD)=0 : Goto NEXT_RECORD : Endif

    When 3,4,5
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP, [F:SRH]BPCORD, [F:SRH]SRHTYP, [F:SRH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
       If ctrans([F:SRH]BPDADDLIG(0)+[F:SRH]BPDADDLIG(1)+[F:SRH]BPDADDLIG(2),' ','')<>''
        If [F:SRH]BPDCRY<>'PT' : Goto NEXT_RECORD : Endif
      Else
        Call ADDRESS(1,func CNSTDCSTDTRT.GET_BPRNUM([F:DKD]VCRTYP),func CNSTDCSTDTRT.GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From
& SAFTGENPORMG
        If PMGCOUNTRY_ST <> "PT" : Goto NEXT_RECORD : Endif
      Endif

      # BRBAN 24-03-2015 #106027
      If func PORLEGLIB1.CTRL_COMDAT([F:SRH]STOFCY,[F:SRH]DPEDATR,[F:SRH]ETDR) = 0 : Goto NEXT_RECORD : Endif

    When 6,7,8
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,'', [F:SGH]SGHTYP, [F:SGH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
      Case [F:SGH]BETFCYCOD
        When 4,5
          Call ADDRESS(1,func CNSTDCSTDTRT.GET_BPRNUM([F:DKD]VCRTYP),func CNSTDCSTDTRT.GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From
& SAFTGENPORMG
        When 2
          Call ADDRESS(3,[F:SGH]FCYDES,[F:SGH]FCYADD,PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
      Endcase
      If PMGCOUNTRY_ST <> "PT"
        Goto NEXT_RECORD
      Endif

      # BRBAN 24-03-2015 #106027
      If func PORLEGLIB1.CTRL_COMDAT([F:SGH]STOFCY,[F:SGH]DPEDAT,[F:SGH]ETD) = 0 : Goto NEXT_RECORD : Endif

    When 9
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,'', [F:PNH]PNHTYP, [F:PNH]PNHFCY)<>1
        Goto NEXT_RECORD
      Endif
      If ctrans([F:PNH]BPAADDLIG(0)+[F:PNH]BPAADDLIG(1)+[F:PNH]BPAADDLIG(2),' ','')<>''
        If [F:PNH]CRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func CNSTDCSTDTRT.GET_BPRNUM([F:DKD]VCRTYP),func CNSTDCSTDTRT.GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From
& SAFTGENPORMG
        If PMGCOUNTRY_ST <> "PT"
          Goto NEXT_RECORD
        Endif
      Endif

      # BRBAN 24-03-2015 #106027
      If func PORLEGLIB1.CTRL_COMDAT([F:PNH]PNHFCY,[F:PNH]DPEDATR,[F:PNH]ETDR) = 0 : Goto NEXT_RECORD : Endif

    When 10
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,[F:TNH]BPRNUM,[F:TNH]TNHTYP,[F:TNH]FCY)<>1
        Goto NEXT_RECORD
      Endif

      Read [F:BPR2]BPR0 = [F:TNH]BPRNUM
      If !fstat
        If [F:TNH]BPCBPS=1 & [F:BPR2]LEGETT=2
          Goto NEXT_RECORD
        Endif
      Endif

      If ctrans([F:TNH]BPDADDLIG(0)+[F:TNH]BPDADDLIG(1)+[F:TNH]BPDADDLIG(2)," ","")<>''
        If [F:TNH]BPDCRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func CNSTDCSTDTRT.GET_BPRNUM([F:DKD]VCRTYP),func CNSTDCSTDTRT.GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From
& SAFTGENPORMG
        If PMGCOUNTRY_ST<>'PT'
          Goto NEXT_RECORD
        Endif
      Endif

      Read [F:FCY]FCY0=[F:TNH]FCY
      If !fstat
        Call ADDRESS(3,[F:TNH]FCY,[F:FCY]BPAADD,PMGSTREETN_SF,PMGADDDETA_SF,PMGCITY_SF,PMGPOSTCOD_SF,PMGCOUNTRY_SF,PMGREGION_SF) From SAFTGENPORMG
      Endif
      If PMGCOUNTRY_SF <> "PT" : Goto NEXT_RECORD : Endif

      # BRBAN 24-03-2015 #106027
      If func PORLEGLIB1.CTRL_COMDAT([F:TNH]FCY,[F:TNH]DPEDAT,[F:TNH]ETD) = 0 : Goto NEXT_RECORD : Endif

    When Default : Goto NEXT_RECORD
  Endcase

  Call SENDDTTOAT([F:DKD]DOCNUM, [F:DKD]VCRTYP, [L]STAT) From PORLEGLIB
  [L]DOCPRC+=1
  $NEXT_RECORD
Next

If [L]DOCPRC = 0
  Call ECR_TRACE(mess(299,117,1),0) From GESECRAN
Else
  Call ECR_TRACE(mess(146,7900,1)-num$([L]DOCPRC),0) From GESECRAN
Endif

If GSERVEUR=0 : Call TEMPOFF From GESECRAN : Endif

Return
############################################################################
############################################################################
$SORTIE

If GTRACE <> ""
   Call FERME_TRACE     From LECFIC
   If !GSERVEUR
      Call LEC_TRACE    From LECFIC
   Endif
Endif

Return
############################################################################
############################################################################
