#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJS1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:10"
A_USER  = "DOC"
A_STAMP = "20181109230110"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBENDP"
  If [M]NBENDP=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask AJS1 [AJS1]
Gosub HORODAT
Local Inpbox "AJS1" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJS1] As [SIM_]
Grizo [AJS1]5
Grizo [AJS1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJS1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=23
Return

$ON_ALS
Onevent CONTROL Call C_ALS(zc) From W1AJS1
Return

Subprog C_ALS(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ALS" : GZNUM = 30818 : Endif
Gosub _AFF
End

$ON_PRIORITY
Onevent CONTROL Call C_PRIORITY(zc) From W1AJS1
Return

Subprog C_PRIORITY(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PRIORITY" : GZNUM = 1164 : Endif
Gosub _AFF
End

$ON_URL
Onevent CONTROL Call C_URL(zc) From W1AJS1
Return

Subprog C_URL(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "URL" : GZNUM = 26967 : Endif
Gosub _AFF
End

$CHG_STY
Return


