#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#########################################################################
#                                                                       #
#     TRANSPORT NOTE VALIDATION                                         #
#                                                                       #
#########################################################################
#########################################################################

#########################################################################
# Model ACTIONS                                                         #
#########################################################################
$ACTION

Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "END"         : Gosub ENDM
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase

Return
#########################################################################
#########################################################################
$INIT

#----- table and variables for printing -----#
Gosub INIT_ETAT From TRTX3ETA
#-----

# In batch, better to set an onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask TND1 [DIA]

Raz [M:DIA]

[M:DIA]FCY=GFCYDEF(7)
[M:DIA]TRNDAT=date$

Return
#########################################################################
#########################################################################
$DEBUT

Affzo [DIA]1-99

Return
#########################################################################
#########################################################################
$OK

GOK=1

Return
#########################################################################
#########################################################################
$ENDM

GOK=0 : FIN=1

Return
#########################################################################
#########################################################################
$CONTROLE

If GOK < 1  FIN=1 Else TMP=1  Endif

Return
#########################################################################
#########################################################################
$EXEC

If !GSERVEUR
# --> open trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("TND1","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif
# --> lecture des entêtes de livraison
Gosub TRHVAL

Return

#########################################################################
#########################################################################
$TERMINE

If NBDLV
  If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
    Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]NDEDEN) From TRTX3ETA
  Endif
Endif

If !GSERVEUR
    If !NBDLV
      Call ECR_TRACE(mess(205,187,1),0) From GESECRAN
    Endif
# --> fermeture trace
    Call FERME_TRACE From LECFIC
    If !NBDLV
      GERR=2 : GMESSAGE=mess(205,187,1)
    Endif
    TRA=1
Endif

Return
#########################################################################
#########################################################################
$OUVRE

Local  Integer  OK, STAT
Local  Char     CRITERE(250), SYMBOLE(50),SYMBOLE2(50)
Local  Decimal  COEFF, WLIN
Local  Integer  WMOD, WRET, NBDLV

If !clalev ([F:TNH]) : Local File TRANNOTEH [TNH] : Endif
If !clalev ([F:ARP]) : Local File AREPORT    [ARP] : Endif

TIT = mess(131,7711,1)

GFCYDEF(0) = GFCYDEF(7)

Local Integer  WCDTUNL

Return
#########################################################################
#########################################################################
$TRHVAL

CRITERE = "CFMFLG<>2"

If [M:DIA]CPY <> ""         : CRITERE -= '& [F:TNH]CPY = "'    +[M:DIA]CPY+ '"'                : Endif
If [M:DIA]FCY <> ""         : CRITERE -= '& [F:TNH]FCY = "'    +[M:DIA]FCY+ '"'                : Endif
If [M:DIA]TRNDAT <> [0/0/0] : CRITERE -= '& [F:TNH]TRNDAT <=[' +format$(GFMD,[M:DIA]TRNDAT)+']': Endif
If [M:DIA]TNHNUMDEB <> ""   : CRITERE -= '& [F:TNH]TNHNUM >="' +[M:DIA]TNHNUMDEB+ '"'          : Endif
If [M:DIA]TNHNUMFIN <> ""   : CRITERE -= '& [F:TNH]TNHNUM <="' +[M:DIA]TNHNUMFIN+ '"'          : Endif
If [M:DIA]BPRNUMDEB <> ""   : CRITERE -= '& [F:TNH]BPRNUM >="' +[M:DIA]BPRNUMDEB+ '"'           : Endif
If [M:DIA]BPRNUMFIN <> ""   : CRITERE -= '& [F:TNH]BPRNUM <="' +[M:DIA]BPRNUMFIN+ '"'           : Endif

# Lecture des livraisons et traitement
For [F:TNH] Where (evalue(CRITERE))

  NBDLV +=1
  SYMBOLE = "TNH"+[F:TNH]TNHNUM
  Lock = SYMBOLE With lockwait=0
  If fstat=1
    # Modification en cours sur un autre poste
    Call ECR_TRACE([F:TNH]TNHNUM-mess(10,100,1),1) From GESECRAN
  Else
    Call VALIDATE(TNHNUM,WRET) From TRTTNH1
    If WRET=1
      If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
        WARP_RPTCOD(0)=[M:DIA]NDENAM
        WARP_NBRCPY=[M:DIA]PRTCOP
      Endif
      #----- Nombre de copies -----#
      # Si modèle d'édition, nbr copie du modèle stocké à la création de la livraison
      # Sinon, nbre de copie de la destination
      #WARP_NBRCPY=[F:SD2]COPNBR#Gbn-Fq73266
      #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
      Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
      #-----
    Endif
    Unlock =SYMBOLE
  Endif
Next

Return
#########################################################################
#########################################################################
$ERRBATCH

Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN

End
#########################################################################
#########################################################################
# Field events                                                          #
#########################################################################
#########################################################################
Subprog AM_TNHNUMDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" : [M]TNHNUMFIN = VALEUR : Endif

End
#########################################################################
#########################################################################
Subprog AM_BPRNUMDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
   [M]BPRNUMFIN = VALEUR
Endif

End
#########################################################################
#########################################################################
Subprog C_TRNDAT(VALEUR)
Variable Date    VALEUR

If VALEUR  > date$
   GMESSAGE = mess(60,192,1) : mkstat = 2
Endif

End
#########################################################################
#########################################################################
Subprog AP_NDEFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = 1
   Raz [M]NDENAM, [M]NDEDEN, [M]NDEIMP, [M]NDESRV
   Diszo [M]NDENAM, NDEDEN
Else
  If vireblc([M]NDENAM,2)=""
#     Call INIT_IMP("SDH", [M]NDENAM, [M]NDEIMP) From TRTVENIMP
     #Call INIT_ARP("SDH", [M]NDENAM) From TRTVENIMP
     Actzo [M]NDENAM, NDEDEN
  Endif
Endif
Affzo [M]NDENAM, NDEDEN, NDEIMP, NDESRV

End
#########################################################################
#########################################################################
Subprog C_NDENAM(VALEUR)
Variable Char    VALEUR()

Local    Char    AUTSIT(10)
Local    Integer OK
# Document obligatoire si impression bon de preparation
If [M:DIA]NDEFLG = 2 & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
   End
Endif

End
#########################################################################
#########################################################################
Subprog C_NDESRV(VALEUR)
Variable Char    VALEUR()

Gosub CTL_SRV From TRTVENIMP

End
#########################################################################
#########################################################################
Subprog C_NDEIMP(VALEUR)
Variable Char    VALEUR()

# Imprimante obligatoire si impression
If [M:DIA]NDENAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif

End
#########################################################################
#########################################################################
Subprog C_NDEDEN(VALEUR)
Variable Char    VALEUR()

# Imprimante obligatoire si impression
If [M:DIA]NDENAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif

End
#########################################################################
#########################################################################
Subprog AP_NDEDEN(VALEUR)
Variable Char    VALEUR()

Call INIT_SRV(VALEUR, [M]NDESRV,[M]NDEIMP) From TRTVENIMP
Affzo [M]NDESRV, NDEIMP
[M:DIA]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)#Fq73266-Gbn

End
#########################################################################
#########################################################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()

Call GETSOC (GFCYDEF(7)) From DEVSUB   : # init avec societe du site stock par defaut
VALEUR=GSOCIETE
[M:DIA]FCY=GFCYDEF(7)

End
#########################################################################
#########################################################################
Subprog AM_CPY(VALEUR)

Variable Char    VALEUR()
GSOCIETE=VALEUR
Raz [M:DIA]FCY

End
#########################################################################
#########################################################################
Subprog AM_ENA(VALEUR)
Variable Integer VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If VALEUR = 1
  Raz   [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
  Diszo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
  Effzo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
Else
  Actzo [M:DIA]STRDAYS,ENDDAYS,STRHOU,ENDHOU
  Read [FCY]FCY0=[M:DIA]FCY
  If !fstat
    [M:DIA]STRHOU = [F:FCY]STRHOU
    [M:DIA]ENDHOU = [F:FCY]ENDHOU
    Affzo [M:DIA]STRHOU,ENDHOU
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END
End
#########################################################################
#########################################################################
Subprog D_STRDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]STRDAYS
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END
End
#########################################################################
#########################################################################
Subprog C_STRDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If VALEUR<0
  Call ERREUR(mess(100,7711,1)) From GESECRAN
  mkstat=2
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog D_ENDDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]ENDDAYS
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog C_ENDDAYS(VALEUR)
Variable Decimal VALEUR

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If VALEUR<0
  Call ERREUR(mess(100,7711,1)) From GESECRAN
  mkstat=2
Elsif VALEUR<[M:DIA]STRDAYS
  Call ERREUR(mess(99,7711,1)) From GESECRAN
  mkstat=2
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog D_STRHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]STRHOU
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog C_STRHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
Local Shortint LOK
Local Char     LHOUR
Local Char     LHOURINT : [L]LHOURINT = VALEUR

Local File     FACILITY [FCY]

If [M:DIA]ENA=2
  If VALEUR<>''
      Call CTRL_HOU(LHOURINT,LHOUR,LOK) From PORLEGLIB
      If LOK=1
        mkstat = 2
      Else
         VALEUR       = LHOUR
      Endif
  Else
      Call ERREUR(mess(94,7711,1)) From GESECRAN
      mkstat = 2
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog D_ENDHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
If [M:DIA]ENA<>2
   Diszo [M:DIA]ENDHOU
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()

#93745 RICAR 2014/07/03 - Transportation notes - BEGIN
Local Shortint LOK
Local Char     LHOUR
Local Char     LHOURINT : [L]LHOURINT = VALEUR

If [M:DIA]ENA=2
  If VALEUR<>''
      Call CTRL_HOU([L]LHOURINT,[L]LHOUR,[L]LOK) From PORLEGLIB
      If LOK=1
        mkstat  = 2
      Else
         VALEUR = [L]LHOUR
      Endif
  Else
      Read [FCY]FCY0=[M:DIA]FCY
      If !fstat
        [M:DIA]ENDHOU = [F:FCY]ENDHOU
        Affzo [M:DIA]ENDHOU
        If [M:DIA]ENDHOU = ''
          Call ERREUR(mess(94,7711,1)) From GESECRAN
          mkstat = 2
        Endif
      Else
        Call ERREUR(mess(94,7711,1)) From GESECRAN
        mkstat = 2
      Endif
  Endif

  If VALEUR<>''& VALEUR <> '0000' & VALEUR <> '00:00'
    If [M:DIA]STRDAYS=[M:DIA]ENDDAYS & VALEUR<[M:DIA]STRHOU
      Call ERREUR(mess(98,7711,1)) From GESECRAN
      mkstat = 2
    Endif
  Endif
Endif
#93745 RICAR 2014/07/03 - Transportation notes - END

End
#########################################################################
#########################################################################

