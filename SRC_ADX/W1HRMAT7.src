#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT7 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:44"
A_USER  = "DOC"
A_STAMP = "20181109230444"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBAXE"
  If [M]NBAXE=0
  Endif
 When "NBRRIB"
  If [M]NBRRIB=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT7 [EMP7]
Gosub HORODAT
Local Inpbox "HRMAT7" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP7] As [SIM_]
Grizo [EMP7]10
Grizo [EMP7]20
Grizo [EMP7]30
Grizo [EMP7]45
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP7]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=74 : Y1(1)=6 : Y2(1)=13
X1(2)=1 : X2(2)=74 : Y1(2)=14 : Y2(2)=21
X1(4)=1 : X2(4)=74 : Y1(4)=22 : Y2(4)=23
Return

$ON_BPR
Onevent CONTROL Call C_BPR(zc) From W1HRMAT7
Return

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_BPR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "BPR" : GZNUM = 46536 : Endif
Gosub _AFF
End

$ON_ACCCOD
Onevent CONTROL Call C_ACCCOD(zc) From W1HRMAT7
Onevent INIT_AREA Call D_ACCCOD(zc) From W1HRMAT7
Onevent BEFORE_INPUT Call AS_ACCCOD(zc) From W1HRMAT7
Onevent AFTER_CHANGE Gosub AMM_ACCCOD From W1HRMAT7
Return

Subprog D_ACCCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]ACCCOD,indice)=0
 ## Action INITACCCOD
 Call INITACCCOD(VALEUR,27) From TRTX3
Endif
Gosub _AFF
End

Subprog AS_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3946,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_ACCCOD(VALEUR) From SUBEML2
If mkstat=2
 [M]ACCCOD(INDIC) = VALEUR
 Affzo ACCCOD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_ACCCOD(zc) From W1HRMAT7
Onkey   2 Titled GBOUTS Call S_ACCCOD(zc) From W1HRMAT7
Onkey 144 Titled GBOUTP Call P_ACCCOD(zc) From W1HRMAT7
Onkey 146 Titled GBOUTA Call SA_ACCCOD(zc) From W1HRMAT7
Gosub _AFF
End

Subprog C_ACCCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
If !mkstat
 ## Action CONTCAC
 Call CONTCAC(VALEUR,"27") From SUBCAC
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("CAC","",VALEUR,"27",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  If !mkstat
   ## Action STD
   Call C_ACCCOD(VALEUR) From SUBEML2
   If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_ACCCOD
Call AM_ACCCOD(zc)
If !mkstat & GOBJET
 zoncou = "ACCCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZACCCOD)")>indice
 [M]ACCCOD(indice) = VALEUR
 Affzo ZACCCOD(indice)
Endif
Gosub _AFF
End

Subprog S_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCAC
 Call SELCAC(VALEUR,"27") From SUBCAC
Endif
Gosub _AFF
End

Subprog B1_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNCAC
 Call TUNCAC(VALEUR,"27") From SUBCAC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CAC"
PARMSK(2) = "27"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "27"
Call VISU("CAC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZACCCOD
Onevent BEFORE_AREA Gosub AV_ZACCCOD From W1HRMAT7
Return

$AV_ZACCCOD
Call LECTEXTRA(zc,"GACCCODE","DESTRA","27",num$([M]ACCCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_DSP
