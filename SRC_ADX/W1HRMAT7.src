If mkstat : GERR = 1 : GZONE = "MODSTL" : GZNUM = 1220 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10387","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "MODSTL" : GZNUM = 1220 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10387",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "MODSTL" : GZNUM = 1220 : Endif
  If !mkstat
   ## Action STD
   Call C_MODSTL(VALEUR) From SUBEML2
   If mkstat : GERR = 1 : GZONE = "MODSTL" : GZNUM = 1220 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

