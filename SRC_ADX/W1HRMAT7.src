Call CONTADI(VALEUR,"10365","") From SUBADI
If mkstat : GERR = 1 : GZONE = "TYPPAY" : GZNUM = 680 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10365",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TYPPAY" : GZNUM = 680 : Endif
Endif
