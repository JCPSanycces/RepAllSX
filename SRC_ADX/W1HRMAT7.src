Subprog AS_DSP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(4805,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DSP(zc) From W1HRMAT7
Onkey   2 Titled GBOUTS Call S_DSP(zc) From W1HRMAT7
Onkey 144 Titled GBOUTP Call P_DSP(zc) From W1HRMAT7
Onkey 146 Titled GBOUTA Call SA_DSP(zc) From W1HRMAT7
Gosub _AFF
End

Subprog C_DSP(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("DSP","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
If !mkstat
 ## Action STD
 Call C_DSP(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
Endif
Gosub _AFF
End

$AMM_DSP
