#<AdxTL>@(#)10.0.0.0 $Revision$
#######################################################################
#                                                                     #
#    TRAITEMENTS de SAISIE ou VISU en FENETRE pour traduction
#                                                                     #
#######################################################################
#                                                                     #
# ACTION MODELISATION E-COMMERCE : GACTION                            #
#---------------------------------------------------------------------#
#######################################################################

$ACTION
#--- Actions liés au type traitement standard 
Case ACTION
 When "INIT"       : Gosub INIT
 When "AVANT_PAR"  : Gosub AVANT_PAR
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "EXEC"       : Gosub EXEC
Endcase

Return

#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
 When "TRTAEX"  : Gosub INIT_TRTAEX
 When "TRTAEXEXP"       : Gosub INIT_TRTAEX
Endcase
Return

$AVANT_PAR
Case GACTION
 When "TRTAEXMOD"   : Gosub AVANT_PAR_TRTAEXMOD
 When "TRTAEXTEX"   : Gosub AVANT_PAR_TRTAEXTEX
Endcase
Return


$DEBUT
Case GACTION
 When "TRTAEX"  : Gosub DEBUT_TRTAEX
 When "TRTAEXEXP"   : Gosub DEBUT_TRTAEX
Endcase
Return

$OK
Case GACTION
 When "TRTAEX"  : Gosub OK_TRTAEX
 When "TRTAEXEXP"  : Gosub OK_TRTAEX
Endcase
Return


$EXEC
Case GACTION
 When "TRTAEX"       : Gosub EXEC_TRTAEX
 When "TRTAEXMOD"    : Gosub EXEC_TRTAEXMOD
 When "TRTAEXEXP"    : Gosub EXEC_TRTAEXEXP
 When "TRTAEXTEX"    : Gosub EXEC_TRTAEXTEX
 When "TRTAEXNBR"    : Gosub EXEC_TRTAEXNBR
Endcase
Return

################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################
$INIT_TRTAEX
Return
#-------------------------------------------------#

$DEBUT_TRTAEX
Raz [M]
GBIDI1 = 0
GOK = 0
[M]LANORI=[M:ARS]LAN
[M]ZTXTREF=[M:ARS]TXT
Return

#-------------------------------------------------#

$AVANT_PAR_TRTAEXMOD
TIT = "Mise a jour du module"  
Return
#-------------------------------------------------#

$AVANT_PAR_TRTAEXTEX
TIT = "Recherche dans ATEXTE"  
Return
#-------------------------------------------------#

$OK_TRTAEX
GOK = 1
GBIDI1 = [M]TXTREF
Return

#-------------------------------------------------#

$EXEC_TRTAEX
If GOK = 0 : Return : Endif

# creation du texte ...........
# dans ATEXTE si type = sans correspondance (1) et dans ce cas , il faut relancer le rpttrans 
# pour prendre en compte la modification ou bien on change l'etat d'origine pour pendre en compte 
# le texte qui existe deja.
#
# sinon  dans ATEXTEXCEP si doublon (2)
If [M:ARS]TYP = 2


    Local Integer WNUMERO

    WNUMERO = 0

    Local File ATEXTEXCEP [ZZZ]
    # on regarde quand même avant que texte n'existe pas
    Read [ZZZ]AEX1 = [M:ARS]VERORI;[M:ARS]NAMREP;[M:ARS]DESREP;[M:ARS]SUBREP;[M:ARS]SECREP;[M:ARS]OBJREP;[M:ARS]LAN
    If fstat <> 0     
        # il faut avant demander le numéro texte correspondance avec ATEXTE
        # zone non obligatoire 
        # recup dernier numero 
        Trbegin [ZZZ]
            Filter [ZZZ] Where LAN = [M:ARS]LAN and VERORI = [M:ARS]VERORI
            Read [ZZZ] Last
            Filter [ZZZ]
            If fstat : WNUMERO = 1 : Else : WNUMERO = [F:ZZZ]NUMERO+1 : Endif
            Raz [F:ZZZ]
            # creation 
            [F:ZZZ] = [M:ARS]
            [F:ZZZ]TXTREF = GBIDI1
            [F:ZZZ]NUMERO = WNUMERO
            GOK = 1
            Write [ZZZ]
            If fstat
                    Infbox "error in writing ATEXTEXCEP"
                    GOK = 0
            Endif
         Commit
    Endif
    Close Local File

Elsif [M:ARS]TYP = 1
    Local Decimal WNUMERO
    WNUMERO = 0

    Local Char WDOSX3(GLONADS)
    WDOSX3 = adxmother(0)
    If WDOSX3=""  
            WDOSX3 = "X3" 
    Endif
    Local File =WDOSX3+".ATEXTE" [ATX]
    GOK = 1
    Call TXTCONT([M:ARS]TXT,[M:ARS]TXT,WNUMERO,30,24,[M]TXT,"TXT") From OBJDIV
    If WNUMERO = 0
            GOK = 0
    Endif
Endif

GBIDI1 = 0
Return


#-------------------------------------------------#

$EXEC_TRTAEXMOD

# mise a jour module du fichier ARPTTRANS
Local File ARPTTRANS [ZTT]
Local File ARPTTRANS [ZT1]
Local File AREPORT [ARP]
Local Char WREPORT(20)
For [ZTT] 
    WREPORT = left$([F:ZTT]NAMREP,len([F:ZTT]NAMREP)-4)
    Filter [ARP] Where CRYCOD = WREPORT
    Read [ARP] First
    If fstat = 0
            Update [ZT1] Where VERORI = [F:ZTT]VERORI and LAN = [F:ZTT]LAN and NUMERO = [F:ZTT]NUMERO With MODULE = [F:ARP]MODULE
    Endif
Next

Close Local File  [ZTT]
Close Local File  [ZT1]
Close Local File  [ARP]
Return

#-------------------------------------------------#


$EXEC_TRTAEXEXP
If GOK = 0 : Return : Endif

# creation du texte dans la table des Exceptions si type = sans correspondance
# pour eviter d'avoir a modifier le report source 
If [M:ARS]TYP = 1
    Local Integer WNUMERO
    WNUMERO = 0
    Local File ATEXTEXCEP [ZZZ]
    # on regarde quand même avant que texte n'existe pas
    Read [ZZZ]AEX1 = [M:ARS]VERORI;[M:ARS]NAMREP;[M:ARS]DESREP;[M:ARS]SUBREP;[M:ARS]SECREP;[M:ARS]OBJREP;[M:ARS]LAN
    If fstat <> 0     
        # il faut avant demander le numéro texte correspondance avec ATEXTE
        # zone non obligatoire 
        # recup dernier numero 
        Trbegin [ZZZ]
            Filter [ZZZ] Where LAN = [M:ARS]LAN and VERORI = [M:ARS]VERORI
            Read [ZZZ] Last
            Filter [ZZZ]
            If fstat : WNUMERO = 1 : Else : WNUMERO = [F:ZZZ]NUMERO+1 : Endif
            Raz [F:ZZZ]
            # creation 
            [F:ZZZ] = [M:ARS]
            [F:ZZZ]TXTREF = GBIDI1
            [F:ZZZ]NUMERO = WNUMERO
            GOK = 1
            Write [ZZZ]
            If fstat
                    Infbox "error in writing ATEXTEXCEP"
                    GOK = 0
            Endif
         Commit
    Endif
    Close Local File

Endif
GBIDI1 = 0
Return


#-------------------------------------------------#


$EXEC_TRTAEXTEX
GMESSAGE = ""

# mise a jour flag texte présent dans ATEXTE
Local File ARPTTRANS [ZTT]
Local File ARPTTRANS [ZT1]
Local File ATEXTE [XXX]
Local Char WREPORT(20)

Filter [ZTT] Where TYP = 1

Update [ZT1] Where VERORI = [F:ZTT]VERORI and LAN = [F:ZTT]LAN With FLGTXT = 1

For [ZTT] 
    Filter [XXX] Where VERORI = [F:ZTT]VERORI and LAN = [F:ZTT]LAN and TEXTE = [F:ZTT]TXT
    Read [XXX] First
    If fstat = 0
            Update [ZT1] Where VERORI = [F:ZTT]VERORI and LAN = [F:ZTT]LAN and NUMERO = [F:ZTT]NUMERO With FLGTXT = 2
    Endif
    Filter [XXX]
Next
Filter [ZTT]

Close Local File  [ZTT]
Close Local File  [ZT1]
Close Local File  [XXX]
Return







$EXEC_TRTAEXNBR

Infbox "nombre erreurs ="-num$(nbrecord ([ARS]))

Filter [ARS] Where [F:ARS]TYP= 1 and [F:ARS]FLG <> 2 and [F:ARS]FLGTXT <> 2

Infbox "manquants ="-num$( rowcount ([ARS]))

Filter [ARS]

Filter [ARS] Where [F:ARS]TYP= 2 and [F:ARS]FLG <> 2 

Infbox "doublons ="-num$( rowcount ([ARS]))
Filter [ARS]

Return






##########################################################################
## 
##########################################################################
Subprog AS_ZTXTREF(VALEUR)
Variable Char    VALEUR()

# si creation texte dans ATEXTE
# pas besoin de saisir le texte
If [M:ARS]TYP <> 2
    mkstat =2
Endif

End
#######################################################

Subprog C_ZTXTREF(VALEUR)
Variable Char    VALEUR()

# on n' a pas le droit de saisir un texte différent
If VALEUR <> [M:ARS]TXT
    mkstat =2
Endif

End


##########################################################################




