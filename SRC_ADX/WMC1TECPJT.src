####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : IMODULE Module code ( Field Local menu number 14)
####################################################################

$SET_IMODULE
If [L]_AOLDVAL<>this.IMODULE
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_IMODULE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.IMODULE
 Gosub PROPAGATE_IMODULE
Endif
Return

$INIT_IMODULE
Gosub DECLARE_VAR From WMC0TECPJT
[L]CURPRO = "IMODULE"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.IMODULE=0 and fmet this.AGETATTRIBUTE("IMODULE","$isMandatory")="true"
 this.IMODULE = 1
Endif
Return
 
$CONTROL_IMODULE
Gosub DECLARE_VAR From WMC0TECPJT
[L]CURPRO = "IMODULE"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_IMODULE               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_IMODULE               : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_IMODULE
[L]CURPRO = "IMODULE"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.IMODULE=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_IMODULE
[L]CURPRO = "IMODULE"
If this.IMODULE<0 or this.IMODULE>len(mess(0,14,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"14 ->"-num$(this.IMODULE)-mess(99,123,1)):  Return : # Local menu "14 -> Invalid option
Endif
Return

$_AOTHERS_IMODULE
[L]CURPRO = "IMODULE"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_IMODULE
[L]CURPRO = "IMODULE"
Return

$PROPAGATE_IMODULE
this.isReadonly = 0
[L]CURPRO = "IMODULE"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_IMODULE
Gosub DECLARE_VAR From WMC0TECPJT
[L]CURPRO = "IMODULE"
$_LNKPRO_IMODULE
Return


