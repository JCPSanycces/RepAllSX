##########################################################################
Subprog C_FIE(VALEUR)
Variable Char    VALEUR()

Local Integer ICANDISP

  ICANDISP = 1
  If VALEUR <> "" Then
    Read [ATZ]CODZONE="MACHINES";VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Else
      #Traitement des exceptions
      Call CHECKFIEMAC(VALEUR, ICANDISP) From SUBMACB
      If !ICANDISP Then
        #Ce champ ne peut pas être utilisé comme critère d'agrégation.
        GMESSAGE = mess(38,177,1)
        GERR = 2
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################
Subprog AM_FIE(VALEUR)
Variable Char    VALEUR()

  [M:CMCC]FIECLACLA = ""
  If VALEUR <> "" Then
    Read [ATZ]CODZONE="MACHINES";VALEUR
    If !fstat Then
      Call TEXTE([F:ATZ]NOCOURT, [M:CMCC]FIECLACLA) From OBJDIV    
    Endif
  Endif
  [M:CMCC]FIE = VALEUR
  Affzo [M:CMCC]
End

##########################################################################
Subprog C_CNSMCCCPY(VALEUR)
Variable Char    VALEUR()
End

##########################################################################
Subprog C_CNSMCCFCY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    # -- Controle autorisation sur le site
    If GUSRFCY(1) <> "\" and !find(VALEUR,GUSRFCY(1..GNBAUZ)) Then
      GMESSAGE = VALEUR - mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
      GERR = 2
      mkstat = 2
      End
    Endif
    Call GETDEV(VALEUR) From DEVSUB
    [M]CNSMCCCPY = GSOCIETE 
    Affzo [M]
  Else
    If [M:MCC1]CNSMCCCPY <> "" Then
      Call CONTALLFCY([M]CNSMCCCPY) From CPTSUB : # Accès à tous les sites de la société ?
    Endif
  Endif
End

##########################################################################
Subprog AM_CNSMCCCPY(VALEUR)
Variable Char    VALEUR()

  [M]CNSMCCFCY = ""
  [M]CNSMCCCPY = VALEUR
End
