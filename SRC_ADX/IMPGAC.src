#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF ###YYFIN_X3-8276_FEB #LS
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF ###YYFIN_X3-8276_FEB #LS
 Endcase
Return
#---------------
$IMP_OUVRE
 #YYFIN_X3-4138_FEB
 If !clalev([F:GAA]) : Local File GACCOUNTA[GAA]  : Endif  : # Codes taxes autorisés/Interdits
Return
#---------------
$IMPORT
GBIDC1 = [F:GAC]COA
[M:GAC0]COA= GBIDC1

If dim([M:GAC6]CSLBPRACE)>0
 If [F:GAC]SAC=2 : [M:GAC6]CSLBPRACE=2 : Endif
Endif

###YYFIN_X3-8276_FEB
Case IMPFIC
 When "GAA" : # Authorizations / Forbidding tax codes
  If dim([M:GAC2]TYPVATCTL)>0
   Raz [M:GAC2]VATCTL
   For NI=0 To dim([F:GAA]VATCTL)-1
    If [F:GAA]VATCTL(NI) <> ""
     [M:GAC2]VATCTL(NI)=[F:GAA]VATCTL(NI)
    Else
     Break
    Endif
   Next
   [M:GAC2]NBVAT = NI
  Endif
Endcase

Return
#---------------
$IMP_ZONE
Case IMPZON
 When "NRPYR" :
  mkstat = 0

 When "ACC" :
 Call INIACCFMT([F:GAC]COA) From SETGLBCOA
 If [F:GAC]ACC<>vireblc(format$("K:"+GFMTACC,[F:GAC]ACC),2)
   # Format incorrect
  Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]ACC,1) From GESECRAN
  mkstat=2
 Endif

 When "NBLIG2" :
  [M]NBLIG2 = dim([M]RPTCODDEB)

 When "DACDIENBR" :
  # Issue X3-75376
  If (GREP <> "M") Then
   [M]DACDIENBR = find("",[F:GAC]DIE)-1
  Endif

 #  in the screen GAC2, the fields CNVACC* are indiced, not in the table GACCOUNT
 When "CNVACC"
  Call INIACCFMT([F:GAC]COA) From SETGLBCOA
  If [M]DIF > 1
   If [F:GAC]CNVACC1<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC1),2)
    # Format incorrect
    Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC1,1) From GESECRAN
    mkstat=2
   Endif
  [M]CNVACC(0) = [F:GAC]CNVACC1

   If [F:GAC]CNVACC2<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC2),2)
    # Format incorrect
    Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC2,1) From GESECRAN
    mkstat=2
   Endif
   [M]CNVACC(1) = [F:GAC]CNVACC2

   If [F:GAC]CNVACC3<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC3),2)
    # Format incorrect
    Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC3,1) From GESECRAN
    mkstat=2
   Endif
   [M]CNVACC(2) = [F:GAC]CNVACC3

   If [F:GAC]CNVACC4<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC4),2)
    # Format incorrect
    Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC4) From GESECRAN
    mkstat=2
   Endif
   [M]CNVACC(3) = [F:GAC]CNVACC4
  Endif

  If [F:GAC]CNVACC5<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC5),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC5) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(4) = [F:GAC]CNVACC5

  If [F:GAC]CNVACC6<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC6),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC6) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(5) = [F:GAC]CNVACC6

  If [F:GAC]CNVACC7<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC7),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC7) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(6) = [F:GAC]CNVACC7

  If [F:GAC]CNVACC8<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC8),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC8) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(7) = [F:GAC]CNVACC8

  If [F:GAC]CNVACC9<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC9),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC9) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(8) = [F:GAC]CNVACC9

  If [F:GAC]CNVACC10<>vireblc(format$("K:"+GFMTACC,[F:GAC]CNVACC10),2)
   # Format incorrect
   Call ECR_TRACE(mess(99,141,1)-"K:"+GFMTACC-[F:GAC]CNVACC10) From GESECRAN
   mkstat=2
  Endif
  [M]CNVACC(9) = [F:GAC]CNVACC10

  [M]NBCNV = 10

Endcase

Return
#---------------
###YYFIN_X3-8276_FEB
$IMP_VERIF
If dim([M:GAC2]TYPVATCTL)>0
 Local Integer NBIMPLIG
 NBIMPLIG = [M]NBVAT
 For nolign=1 To NBIMPLIG
  indice = nolign-1
  [M]NBVAT = nolign
  status = 75
  Call CONTTVT([M]VATCTL(indice),GCURLEG,"GAC2","VATCTL","",[M:GAC1]FCY,"") From SUBTVT
  If mkstat : Break : Endif
  Call C_VATCTL([M]VATCTL(indice)) From SUBGAC
  If mkstat : Break : Endif
  Call AM_VATCTL([M]VATCTL(indice)) From SUBGAC
  If mkstat : Break : Endif
 Next
 indice = 0
 If mkstat : OK = 0 : Return : Endif
 Call C_NBVAT From SUBGAC
 If mkstat : OK = 0 : Return : Endif
Endif
Return

