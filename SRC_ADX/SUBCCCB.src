#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################
#  Sous-programmes utilitaires pour la gestion des produits concurrents
#  Sylvain DENIS                                           26 juin 2000
#
#  supprimer MANAGEILK : Gestion du tableau des articles associés
#  LOAD_ILK : Chargement des tableaux
#  SAVE_ILK Gestion du tableau des articles  concurrents
#  RAZ_SZTAB_ILK
#  LOAD_SZTAB_ILK
#  SAVECLOB  : Enregistrement des CLOBs
#  DELCLOB   : Suppression des CLOBs
#  LOADCLOB  : Chargement du CLOB
#
################################################################################
##########################################################################################################
# Chargement des tableaux
###########################################################
$LOAD_ILK
Local Integer IINDICE

  IINDICE = 0
  Filter [ILK] Where [F:ILK]ITMCPPNUM  = [M:CCC0]NUM
  For [ILK] ILK1
    If IINDICE = dim([M:CCC3]ITMNUM)-1 Then
      Break
    Endif
    [M:CCC3]ITMNUM(IINDICE) = [F:ILK]ITMNUM
    Read [ITM]ITM0=[F:ILK]ITMNUM
    If fstat = 0 Then
      #[M:CCC3]DES0(IINDICE) = [F:ITM]ITMDES1
      #[M:CCC3]DES1(IINDICE) = [F:ITM]ITMDES2
      #[M:CCC3]DES2(IINDICE) = [F:ITM]ITMDES3
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES0(IINDICE), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      Call CHARGE_DEFITMDES("DES2AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES1(IINDICE), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      Call CHARGE_DEFITMDES("DES3AXX",GLANGUE,[F:ITM]ITMREF,[M:CCC3]DES2(IINDICE), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    IINDICE += 1
  Next
  Filter [ILK]
  [M:CCC3]NBITM = IINDICE
Return

##########################################################################################################
# Gestion du tableau des articles  concurrents.
#####################################################################
$SAVE_ILK
Local Integer IINDICE
Local Integer IINDICETAB
Local Integer IBTROUVE
Local Integer IBDELETE

  IINDICE = 0
  IBTROUVE = 0
  IBDELETE = 0
  #suppression des lignes supprimer
  If INBTAB_ILK > 0 and [M:CCC0]NUM <> "" Then
    For IINDICETAB = 0 To INBTAB_ILK-1  
      IBDELETE = 0
      IBTROUVE = 0
      If SZTAB_ILK(IINDICETAB) <> "" Then
        IINDICE = 0
        While IINDICE < [M:CCC3]NBITM
          If [M:CCC3]ITMNUM(IINDICE) = SZTAB_ILK(IINDICETAB) Then
            IBTROUVE = 1
            Break
          Endif
          IINDICE += 1
        Wend
      Endif
      If IBTROUVE = 0 Then
        IBDELETE = 1
      Endif
      If IBDELETE = 1 Then
        Delete [ILK] Where [F:ILK]ITMCPPNUM=[M:CCC0]NUM and [F:ILK]ITMNUM=SZTAB_ILK(IINDICETAB)
        If fstat <> 0 Then
          #Erreur lors de la suppression de l'article concurrent
          GMESSAGE = mess(594,177,1)
          GOK = 0
          Break
        Endif
      Endif
    Next
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des lignes saisies
  For IINDICE = 0 To [M:CCC3]NBITM-1
    If [M:CCC3]ITMNUM(IINDICE) <> "" Then
      Read [ILK]ILK2=[M:CCC3]ITMNUM(IINDICE);[M:CCC0]NUM
      If fstat <> 0 Then
        #Il s'agit d'un nouvel enregistrement
        [F:ILK]ITMNUM  = [M:CCC3]ITMNUM(IINDICE)
        [F:ILK]ITMCPPNUM  = [M:CCC0]NUM
        Write [ILK]
        If fstat Then
          #L'enregistrement des articles concurrents a échoué.
          GMESSAGE = mess(595,177,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        Readlock [ILK]ILK2=[M:CCC3]ITMNUM(IINDICE);[M:CCC0]NUM
        If fstat Then
          #L'enregistrement des articles concurrents a échoué.
          GMESSAGE = mess(595,177,1)
          GERR = 1
          GOK = 0
          Break
        Else
          Rewrite [ILK]
          If fstat Then
            #L'enregistrement des articles concurrents a échoué.
            GMESSAGE = mess(595,177,1)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$RAZ_SZTAB_ILK
  Raz SZTAB_ILK
  Raz INBTAB_ILK
Return


##########################################################################################################
$LOAD_SZTAB_ILK
Local Integer  IINDICE

  Gosub RAZ_SZTAB_ILK
  ILIGNE = 0
  While ILIGNE< [M:CCC3]NBITM
    If [M:CCC3]ITMNUM(ILIGNE) <> "" Then
      SZTAB_ILK(INBTAB_ILK) = [M:CCC3]ITMNUM(ILIGNE)
      INBTAB_ILK += 1
    Endif
    ILIGNE += 1
  Wend
Return


##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  #Description
  If [M:CCC1]FULDES<> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:CCC1]NUMFULDES
    [F:HD6]TYP = [M:CCC1]TYPFULDES
    [F:HD6]CLOB = [M:CCC1]FULDES
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement de la description. Transaction abandonnée.
      GMESSAGE = mess(895,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  If [M:CCC2]FULASE <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:CCC2]NUMFULASE
    [F:HD6]TYP = [M:CCC2]TYPFULASE
    [F:HD6]CLOB = [M:CCC2]FULASE
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement des avantages de la concurrence. Transaction abandonnée.
      GMESSAGE = mess(897,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  If [M:CCC2]FULSHC <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:CCC2]NUMFULSHC
    [F:HD6]TYP = [M:CCC2]TYPFULSHC
    [F:HD6]CLOB = [M:CCC2]FULSHC
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement des faiblesses de la concurrence. Transaction abandonnée.
      GMESSAGE = mess(898,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD6] Where [F:HD6]NUM = [M:CCC1]NUMFULDES and [F:HD6]TYP = [M:CCC1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression de la description. Transaction abandonnée.
    GMESSAGE = mess(896,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD6] Where [F:HD6]NUM = [M:CCC2]NUMFULASE and [F:HD6]TYP = [M:CCC2]TYPFULASE
  If fstat Then
    #Erreur lors de la suppression des avantages de la concurrence. Transaction abandonnée.
    GMESSAGE = mess(899,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD6] Where [F:HD6]NUM = [M:CCC2]NUMFULSHC and [F:HD6]TYP = [M:CCC2]TYPFULSHC
  If fstat Then
    #Erreur lors de la suppression des faiblesses de la concurrence. Transaction abandonnée.
    GMESSAGE = mess(900,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:CCC1]NUMFULDES = "" Then
    Raz [M:CCC1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:CCC1]TYPFULDES = "" Then
    Raz [M:CCC1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:CCC1]NUMFULDES;[M:CCC1]TYPFULDES
    If fstat Then
      Raz [M:CCC1]FULDES
    Else
      [M:CCC1]FULDES = [F:HD6]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:CCC2]NUMFULASE = "" Then
    Raz [M:CCC2]FULASE
    ILOOKFORCLOB = 0
  Endif
  If [M:CCC2]TYPFULASE = "" Then
    Raz [M:CCC2]FULASE
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:CCC2]NUMFULASE;[M:CCC2]TYPFULASE
    If fstat Then
      Raz [M:CCC2]FULASE
    Else
      [M:CCC2]FULASE = [F:HD6]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:CCC2]NUMFULSHC = "" Then
    Raz [M:CCC2]FULSHC
    ILOOKFORCLOB = 0
  Endif
  If [M:CCC2]TYPFULSHC = "" Then
    Raz [M:CCC2]FULSHC
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:CCC2]NUMFULSHC;[M:CCC2]TYPFULSHC
    If fstat Then
      Raz [M:CCC2]FULSHC
    Else
      [M:CCC2]FULSHC = [F:HD6]CLOB
    Endif
  Endif
Return
