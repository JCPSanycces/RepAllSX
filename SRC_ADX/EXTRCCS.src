#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXTRCCS","DEXTRCCS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : EXTRCCS
#########################################
$ACTION
Case ACTION
 When "INIT"     : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
 When "BOUTON"   : Gosub BOUTON  :#81085
Endcase
Return

$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#83271
GCURLEG="FRA"
If dim([M:DIA]LEG)>=0 : [M:DIA]LEG=GCURLEG : Endif
#end 83271
Affzo [DIA] : Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE :#81085
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#81085
######################################################
$BOUTON
Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
Endcase
Return

######################################################

$OUVRE
Local Char    CRITERE(250), CRITERE2(250)
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:PSN])=0 : Local File PRESTATION [PSN] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:CCS])=0 : Local File CERTIFCCS  [CCS] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:FEL])=0 : Local File FILEDIL    [FEL] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

TIT = mess(193,10703,1) : # Extraction congés spectacles
Local Mask EXTRCCS [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","ccs") From GMEMO
Call AFF_MEMO From DIVPAYE :#81085
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Gosub OUVRE From WPDEFTABLE

CRITERE = '[F:PSN]BUL<>"" & [F:HRCTR]STACTR=2'
CRITERE2 = '[F:ID]ENAFLG=2 & [F:ID]FLGINT=2 & [F:ID]FLGNEWSAL<>2'

# Borne matricule
If [M:DIA]MATDEB<>"" : CRITERE -= '& [F:HRCTR]REFNUM>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE -= '& [F:HRCTR]REFNUM<="'+[M:DIA]MATFIN+'"' : Endif
# Borne date
CRITERE -= '& [F:PSN]PSNENDDAT>=['+format$(GFMD,[M:DIA]DATSTR)+']'
CRITERE -= '& [F:PSN]PSNENDDAT<=['+format$(GFMD,[M:DIA]DATEND)+']'
# Borne contrat
If [M:DIA]CTRDEB<>"" : CRITERE -= '& [F:PSN]CTRNUM>="'+[M:DIA]CTRDEB+'"' : Endif
If [M:DIA]CTRFIN<>"" : CRITERE -= '& [F:PSN]CTRNUM<="'+[M:DIA]CTRFIN+'"' : Endif
# Service
If [M:DIA]ALLSRV<>2  : CRITERE -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"'     : Endif
# Profil
If [M:DIA]ALLPRF<>2  : CRITERE -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"'     : Endif
# Site
If [M:DIA]ALLFCY<>2  : CRITERE2 -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"'     : Endif
# Société
If [M:DIA]ALLCPY<>2  : CRITERE2 -= '& [F:FCY]LEGCPY="'+[M:DIA]CPY+'"'     : Endif
# Reextraire CECS déjà extraits
If [M:DIA]FLGUPD<>2  : CRITERE2 -= '& [F:PSN]NUMCER=""'                   : Endif

# Population
#83271
If [M:DIA]POP<>""
 Link [PSN] With
&   [HRPOA]POA0 = [M:DIA]POP;[F:PSN]REFNUM
& , [ID]ID0   = [F:PSN]REFNUM
& , [HRCTR]CTR0 = [F:PSN]REFNUM;[F:PSN]CTRNUM;[F:PSN]CTRDAT
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [VEP]VEP5 = [F:PSN]BUL
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>"" & [F:CPY]LEG=GCURLEG
Else
 Link [PSN] With
&   [ID]ID0   = [F:PSN]REFNUM
& , [HRCTR]CTR0 = [F:PSN]REFNUM;[F:PSN]CTRNUM;[F:PSN]CTRDAT
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [VEP]VEP5 = [F:PSN]BUL
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITERE2) & [F:CPY]LEG=GCURLEG
Endif
#end 83271

Call EXTRACTION(1)

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

Return

################################################################################
#
# Routines
#
################################################################################

Subprog EXTRACTION(TRA)
Value Integer TRA

Local Integer STAT, NBERR, I, FLGCAC, NBPCE
Local Char    FEH([V]GLONADI), TABBUL(GLONVCR)(0..100)
Local Decimal NBCAC, NBDAY

[L]FEH="CCS"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
[L]EXTRACTION=1

Call DEBTRANS From GLOCK
Gosub TR_EXTRACT
If GOK=1
 If !NBPCE
   Call ECR_TRACE(mess(4,10721,1) ,1) From GESECRAN : # Aucun salarié à déclarer
 Else
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(194,10703,1),0) From GESECRAN : # Certificats extraits
 Endif
Endif
End

#-------------------------------------------------------------------------------
$TR_EXTRACT
GOK = 1
Trbegin [CCS]
 #Parcours des prestations par contrat
 For [LNK]PSN0(1)
  Call CONTROLE([F:PSN]REFNUM,[F:PSN]CTRDAT,[F:PSN]CTRNUM,[M]CRI,[L]STAT,0) From DIVPAYE

  #83271
#  If [L]STAT
#    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#    If [F:CPY]LEG<>GCURLEG
#      [L]STAT = 0
#    Endif
#  Endif
  #end 83271

  If [L]STAT
   Raz [F:CCS]
   Raz I

   For [L]NIVEAU=0 To 3
    Gosub RAZVAR From =[L]FEHTRT
   Next

   Onerrgo ERREURWW
   [L]NIVEAU = 0
   Gosub EXTRACTION From =[L]FEHTRT
   Onerrgo

   [L]FLGCAC = 1
   Raz [L]NBCAC, [L]NBDAY

   For [LNK]PSN0
    If [F:PSN]NUMCER<>""
     Delete [CCS]CCS0=[F:PSN]NUMCER
     If fstat=1
      GOK = -1 : GLOCK = "$CERTIFCCS" : Break 2
     Elsif fstat>5
      GOK = 0 : Call FSTA("CCS") From GLOCK : Break 2
     Endif
    Endif
    Onerrgo ERREURWW
    [L]NIVEAU = 1
    Gosub EXTRACTION From =[L]FEHTRT
    Onerrgo
    If !find([F:VEP]BUL,TABBUL)
     TABBUL(I) = [F:VEP]BUL
     I +=1
     Onerrgo ERREURWW
     [L]NIVEAU = 2
     Gosub EXTRACTION From =[L]FEHTRT
     Onerrgo
    Endif
    [F:PSN]NUMCER = [L]NUMCER
    Rewrite [PSN]
    If fstat
     GOK=0 : Call FSTA("PSN") From GLOCK
     Break
    Endif
   Next

   # Ne pas faire figurer les centimes. Arrondi à l'euro le plus proche
   [L]BASLEA = arr([L]BASLEA,1)
   [L]SAL    = arr([L]SAL,1)
   # Ne doit pas contenir de décimal
   [L]NBRDAYCAC = fix([L]NBRDAYCAC)
   Onerrgo ERREURWW
   [L]NIVEAU = 3
   Gosub EXTRACTION From =[L]FEHTRT
   Onerrgo

   [L]NBERR=0
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE([L]NUMCERJOB-":"-[F:HRCTR]REFNUM-[F:ID]NAM-[F:ID]SRN-[F:HRCTR]CTRNUM,0) From GESECRAN
   Onerrgo ERREURWW
   Gosub CONTROLE From =[L]FEHTRT
   Onerrgo
   Gosub MAJFIC From =[L]FEHTRT
   If NBERR=0
    [F:CCS]STACCS  = 2
   Else
    [F:CCS]STACCS  = 1
   Endif
   Write [CCS]
   If fstat
    GOK=0 : Call FSTA("CCS") From GLOCK
    Break
   Endif
   NBPCE +=1
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_EXTRACT
 Elsif !GOK : Goto AB_TR_EXTRACT
 Endif
Commit
Return

#-------------------------------------------------------------------------------
$ERREURWW
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
End

#-------------------------------------------------------------------------------

$AB_TR_EXTRACT
Rollback
Return

$ROLL_TR_EXTRACT
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXTRACT : Endif
Return

######################################################################################
## Etiquette Ecran EXTRCCS
######################################################################################
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If year(VALEUR)<>year([M]DATSTR)
 # Les bornes de dates doivent être sur la même année
 GMESSAGE = mess(175,10703,1)
 mkstat = 2 : End
Endif
If [M]DATSTR<=gdat$(31,03,year([M]DATSTR)) & VALEUR>gdat$(31,03,year([M]DATSTR))
 # La période doit s'arrêter au 31 Mars
 GMESSAGE = mess(195,10703,1)
 mkstat = 2 : End
Endif
VALEUR = eomonth(VALEUR)
End

Subprog C_DATSTR(VALEUR)
Variable Date    VALEUR
   VALEUR = gdat$(01,month(VALEUR),year(VALEUR))
End

Subprog AM_DATSTR(VALEUR)
Variable Date     VALEUR
[M]DATEND = eomonth(VALEUR)
End

######################################################################################

