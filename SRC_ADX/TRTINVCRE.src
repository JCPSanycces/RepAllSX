#<AdxTL>@(#)10.0.0.0 $Revision$
#
# Requirement 81664 - US Financial 92 - Sprint 5 - Sophia Team - June 2012
#------------------------------------------------------------------------------------
# Process of Creating BIC - Customer BP invoice
#------------------------------------------------------------------------------------
#  Subprog HEARDER_BIC
#  Subprog LINES_BIC
#------------------------------------------------------------------------------------
#  Modifications:
# X3-38745  MDJ 11.08.2017   Use of 2 tax levels on Asset Disposal
#------------------------------------------------------------------------------------
Subprog HEADER_BIC(HEAFCY,HEATYP,HEABPR,HEASAC,HEADAT,HEABPRDAT,HEABPRVCR,HEACUR,HEADES,HEAINVNUM,CAS,NUMBIC,OK,MESSA)
Value    Char    HEAFCY           #1  : Header facility
Value    Char    HEATYP           #2  : Entry Type
Value    Char    HEABPR           #3  : Partner
Value    Char    HEASAC           #4  : Control account
Value    Date    HEADAT           #5  : Date
Value    Date    HEABPRDAT        #6  : Source date
Value    Char    HEABPRVCR        #7  : Source document
Value    Char    HEACUR           #8  : Currency
Value    Char    HEADES           #9  : Comments
Value    Char    HEAINVNUM        #10 : Invoice number
Value    Char    CAS              #11 : Status
Variable Char    NUMBIC           #12 : New invoice number
Variable Integer OK               #13 : Error status
Variable Char    MESSA()          #14 : Error message

# CAS - Statut
#  CAS=1... use from Fixed Assets... => the field FLGGEN=2

Gosub DECLARE
Gosub DECLARE_FILE
Gosub DECLARE_FILE_BIC
GOK = 1

If find([L]HEAFCY,GSITE(1..GNBSITE))=0
 MESSA = [L]HEAFCY
 STAT = 1 : Goto ERR
Endif

Call GETSOC([L]HEAFCY) From DEVSUB
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV

# Reading
Call LEC_BPR([L]HEABPR) From CPTLEC
If fstat | [F:BPR]BPCFLG<>2
 MESSA = [L]HEABPR
 STAT = 44 : Goto ERR
Endif
Call LEC_BPC([L]HEABPR) From CPTLEC
If fstat | [F:BPC]BPCSTA<>2
 MESSA = [L]HEABPR
 STAT = 45 : Goto ERR
Endif

#
Raz [F:HEA]
[F:HEA]SIVTYP    = [L]HEATYP
[F:HEA]NUM       = [L]NUMBIC

If [L]HEAINVNUM = ""
 [F:HEA]INVTYP    = 1
 [F:HEA]SNS       = 1
Else
 [F:HEA]INVTYP    = 2
 [F:HEA]SNS       = -1
Endif

[F:HEA]GTE       = G_GTE
[F:HEA]JOU       = G_JOU
[F:HEA]CPY       = GSOCIETE
[F:HEA]FCY       = [L]HEAFCY
[F:HEA]ACCDAT    = [L]HEADAT
[F:HEA]BPR       = [L]HEABPR
[F:HEA]BPRSAC    = [L]HEASAC
[F:HEA]BPRDAT    = [L]HEABPRDAT
[F:HEA]BPRVCR    = [L]HEABPRVCR
[F:HEA]CUR       = [L]HEACUR
Gosub COURS
[F:HEA]STRDUDDAT = [L]HEADAT
[F:HEA]STA       = 1
[F:HEA]ORIMOD    = 3
[F:HEA]DIRINVFLG = 2
[F:HEA]DES       = [L]HEADES

[F:HEA]BPRPAY    = [F:BPC]BPCPYR
If [F:HEA]BPRPAY="" : [F:HEA]BPRPAY = [F:HEA]BPR : Endif

If [F:BPC]BPCTYP=2 & [F:HEA]BPRPAY=[F:HEA]BPR
 [F:HEA]BPAPAY = [F:BPC]BPAINV
Else
 [F:HEA]BPAPAY = [F:BPC]BPAPYR
Endif

Call INIPTE ([F:BPC]BPCPYR,[F:BPC]BPCNUM,"C",[F:HEA]PTE) From TRTX3
Call CONTTPT ([F:HEA]PTE,GCURLEG,"","",[F:HEA]FCY,"",[F:HEA]CPY) From SUBTPT
If mkstat
 Gosub TIT From WOTPT : GMESSAGE = TIT-":"-[F:HEA]PTE+"\"+GMESSAGE
 STAT = 98 : Goto ERR
Endif
Call INIT_ESCOMPTE([F:HEA]BPR,GSOCIETE,"C",[F:HEA]DEP) From CPTSUB
Call CONTTDA ([F:HEA]DEP,GCURLEG,"","",[F:HEA]FCY,"",[F:HEA]CPY) From SUBTDA
If mkstat
 Gosub TIT From WOTDA : GMESSAGE = TIT-":"-[F:HEA]DEP+"\"+GMESSAGE
 STAT = 98 : Goto ERR
Endif
Call INIT_REGIME([F:HEA]BPR,[F:HEA]FCY,"C",[F:HEA]VAC) From CPTSUB
Call CONTTVB ([F:HEA]VAC,GCURLEG,"","",[F:HEA]FCY,"",[F:HEA]CPY) From SUBTVB
If mkstat
 Gosub TIT From WOTVB : GMESSAGE = TIT-":"-[F:HEA]VAC+"\"+GMESSAGE
 STAT = 98 : Goto ERR
Endif

# Header Analytical dimensions
For AXE=1 To GNBAXE
 [F:HEA]DIE(AXE-1) = GAXE(AXE)
 Call INISEC([F:HEA]CCE(AXE-1),"BPCINVH",[F:HEA]DIE(AXE-1)) From SUBCDE
Next AXE

# Addresses
Gosub LECADR

Call ACCNUM([F:HEA]ACCNUM) From SUBGAS

Call GETPERSOC(GSOCIETE,GTYPGEN,[F:HEA]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:HEA]FIY = EXERCICE
[F:HEA]PER = PERIODE

##
[F:HEA]AMTNOT = G_AMTNOT  : # Ex tax
[F:HEA]AMTATI = G_AMTATI  : # Tax incl.

[F:HEA]NBRTAX = G_NBRTAX
For K=1 To G_NBRTAX
 [F:HEA]TAX(K-1)       = G_TAX(K)
 [F:HEA]BASTAX(K-1)    = G_BASTAX(K)
 [F:HEA]AMTTAX(K-1)    = G_AMTTAX(K)
 [F:HEA]EXEAMTTAX(K-1) = G_EXEAMTTAX(K)
Next

#85785
# ----------------------------------------------------------- #
# Digital signature                                           #
# ----------------------------------------------------------- #
If func PORLEGLIB.DIGSIGN("", [F:HEA]CPY)
  Local Char DKSORIG : DKSORIG = "HEA"
  Local Integer DKSRET : DKSRET  = 1
  Gosub DKS_INICRE_TRIGGER From DKSLIB
  If !GOK | DKSRET = 0
    GOK = 0
    Call MESSAGE(GMESSAGE) From GESECRAN
    STAT = 98 : Goto ERR
  Endif
Endif

# Belgian localization (requirement 82614) : VCS Sequencing number --str
If func AFNC.ACTIV("KBE") Then
 # Pour les factures et Notes de débit
 If  find([F:HEA]INVTYP,1,3)>0 Then
  Call BELSETVCS([F:HEA]FCY,[F:HEA]ACCDAT,[F:HEA]BELVCS,STAT,MESSA) From INVVCSLIB
  If STAT
   STAT = 98 : Goto ERR
  Endif
 Endif
Endif
# Belgian localization  (requirement 82614) --end

# Initialization SALPRITYP
If dim(GCOMAMTENT)>0 & GCOMAMTENT =2
 Call PARAM(GSOCIETE,"DEPMGTMOD",DEPMOD) From ADOVAL
 GDEPMGTMOD=val(DEPMOD)
 If [F:HEA]DEP<>"": Call LEC_TDA(GCURLEG,[F:HEA]DEP) From CPTLEC : Endif
 If GDEPMGTMOD=1 or (GDEPMGTMOD = 5 & [F:HEA]DEP<>"" & [F:TDA]SFINUM<>0)
  [F:HEA]SALPRITYP = 1
 Elsif [F:BPC]PRITYP <> 0
  [F:HEA]SALPRITYP = [F:BPC]PRITYP
 Else
  If !clalev([F:BCG])  : Local File BPCCATEG  [BCG]  : Endif
  fstat = 0
  If [F:BPC]BCGCOD<>[F:BCG]BCGCOD
   Read [BCG]BCG0 = [F:BPC]BCGCOD
  Endif
  If !fstat
   [F:HEA]SALPRITYP = [F:BCG]PRITYP
  Endif
  If [F:HEA]SALPRITYP = 0
   If dim(GPRITYP)>0
    [F:HEA]SALPRITYP = GPRITYP
   Else
    [F:HEA]SALPRITYP = 1
   Endif
  Endif
 Endif
Else
 [F:HEA]SALPRITYP = 1
Endif

# Initialization DCLEECNUM
[F:HEA]DCLEECNUM  = [F:BPR]EECNUM
##

##YYFIN_71258_US274 : Initialization UMRNUM
If func AFNC.PARAM("SDDMGT",GSOCIETE)="2"
 Local Integer FLG_UMRNUM
 Call PTESDD([F:HEA]PTE,FLG_UMRNUM) From INVSDDLIB
 If FLG_UMRNUM
  Call INIT_UMRNUM(GSOCIETE,[F:HEA]BPRPAY,2,2,[F:HEA]UMRNUM) From INVSDDLIB
 Endif
Endif

# SAM 110033: Swiss localization: calculate BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_BVRFIELDS_FA([F:HEA]FCY, [F:HEA]INVTYP, [F:HEA]PTE, [F:HEA]BPRPAY, [F:HEA]CUR) From SUBBICSWI
  If not GOK : STAT=99 : Goto ERR : Endif
Endif
# SAM 110033 END

If dim([F:HEA]CREDAT)>0 : [F:HEA]CREDAT = date$ : Endif
If dim([F:HEA]CREUSR)>0 : [F:HEA]CREUSR = GUSER : Endif
If dim([F:HEA]EXPNUM)>0 : [F:HEA]EXPNUM = [C]EXPORT : Endif

Write [HEA]
If fstat
 Call FSTA("SIH") From GLOCK
 STAT=99 : Goto ERR
Endif

If dim(G_TEST)>0 & G_TEST : Gosub SIH From ZZCPUS92B : Endif


# Create of Open item
If GPAYTERM=1   :# tiers payeur
 Call LEC_BPC([F:HEA]BPRPAY) From CPTLEC
 If fstat
  Call LEC_BPC([F:HEA]BPR) From CPTLEC
 Endif
Else
 Call LEC_BPC([F:HEA]BPR) From CPTLEC
Endif
XSOI = 1+([F:BPC]SOIPER>1)
If XSOI=2
 Call LEC_TPT_LEG(GCURLEG,[F:HEA]PTE,1) From CPTLEC
 XSOI = [F:TPT]SOIFLG
Endif
If dim([F:BPC]FUPTYP)>0 & [F:BPC]FUPTYP=1
 XFLGFUP = 1
Else
 XFLGFUP = 2
Endif

[SIH] = [HEA]
Call CREECHE(1,XSOI,XFLGFUP,len(mess(0,510,1))) From SUBBIH
If !GOK
 STAT=99 : Goto ERR
Endif

Gosub KILL_GLOBAL
End


##########################################################################################################################
Subprog LINES_BIC(HEAFCY,HEATYP,HEADAT,HEAINVNUM,HEACUR,FCY,COA,ACC,DES,AMTNOTLIN,
&              VAT,AMTVAT,TAX1,AMTTAX1,TAX2,AMTTAX2,TAXRCP,AMTTAXRCP,TAXISS,AMTTAXISS,TAXOTH1, AMTTAXOTH1,TAXOTH2,AMTTAXOTH2,
&              DSP,DIE,CCE,
&              CAS,NUMBIC,OK,MESSA)
Value    Char    HEAFCY      #1  : Header facility
Value    Char    HEATYP      #2  : Enter type
Value    Date    HEADAT      #3  : Date
Value    Char    HEAINVNUM   #4  : Invoice number
Value    Char    HEACUR      #5  : Currency
Value    Char    FCY()       #6  : Line facility
Value    Char    COA()(1..)  #7  : Chart of accounts
Value    Char    ACC()(1..)  #8  : Accounts
Value    Char    DES()       #9  : Comments
Value    Decimal AMTNOTLIN   #10 : Amount ex tax
Value    Char    VAT()       #11 : Tax
Value    Decimal AMTVAT      #12 : Amount tax
Value    Char    TAX1()      #13 : Tax 1
Value    Decimal AMTTAX1     #14 : Amount tax 1
Value    Char    TAX2()      #15 : Tax 2
Value    Decimal AMTTAX2     #16 : Amount tax 2
Value    Char    TAXRCP()    #17 : Receipt tax
Value    Decimal AMTTAXRCP   #18 : Amount receipt tax
Value    Char    TAXISS()    #19 : Issue tax
Value    Decimal AMTTAXISS   #20 : Amount tax amount
Value    Char    TAXOTH1()   #21 : Other tax 1
Value    Decimal AMTTAXOTH1  #22 : Amount other tax 1
Value    Char    TAXOTH2()   #23 : Other tax 2
Value    Decimal AMTTAXOTH2  #24 : Amount other tax 2
Value    Char    DSP()       #25 : Distribution
Value    Char    DIE()(1..)  #26 : Dimension type code
Value    Char    CCE()(1..)  #27 : Dimension
Value    Char    CAS()       #28 : Status
Variable Char    NUMBIC      #29 : New invoice number
Variable Integer OK          #30 : Error status
Variable Char    MESSA()     #31 : Error message

Gosub DECLARE_FILE
Gosub DECLARE_FILE_BIC
Gosub DECLARE
Local Mask VENTILE     [VTL]
GOK = 1

If dim(G_LIN)<1

 If find([L]HEAFCY,GSITE(1..GNBSITE))=0
  MESSA = [L]HEAFCY
  STAT = 1 : Goto ERR
 Endif

 Gosub DECLARE_GLOBAL
 Call GETSOC([L]HEAFCY) From DEVSUB
 Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
 Gosub DECLARE_GLOBAL From SUBBICS
 Call INI_GLOBAL(1,GSOCIETE,STAT,GMESSAGE) From SUBBICS
 If STAT
  OK = STAT : Goto ERR
 Endif

 #
 fstat = 0
 If [F:TAB]SIVTYP<>[L]HEATYP | [F:TAB]LEG<>GCURLEG
  Read [TAB]TSV0 = [L]HEATYP;GCURLEG
  If fstat
   Read [TAB]TSV0 = [L]HEATYP;""
  Endif
 Endif
 If fstat
  MESSA = [L]HEATYP
  STAT = 2 : Goto ERR
 Endif
 If [F:TAB]INVTYP = 5
  MESSA = [L]HEATYP
  STAT = 3 : Goto ERR
 Endif

 # GTE - Document types
 If [F:TAB]GTE=""
  Call EVALAUTO([F:TAB]COD2,"GTE",G_GTE)From SUBBIC
  If G_GTE=""
   MESSA = [L]HEATYP : STAT = 10 : Goto ERR
  Endif
 Else
  G_GTE=[F:TAB]GTE
 Endif
 Gosub CONTGTE
 If STAT : Goto ERR : Endif

 # JOU - Journal code
 If [F:TAB]JOU=""
  Call EVALAUTO([F:TAB]COD2,"JOU",G_JOU)From SUBBIC
  If G_JOU=""
   Call LEC_GTE_LEG(GCURLEG,G_GTE) From CPTLEC
   If !fstat : G_JOU = [F:GTE]DEFJOU : Endif
  Endif
  If G_JOU=""
   STAT = 54 : Goto ERR
  Endif
 Else
  G_JOU=[F:TAB]JOU
 Endif
 Gosub CONTJOU
 If STAT : Goto ERR : Endif
 #

 Call LEC_GTE_LEG(GCURLEG,G_GTE) From CPTLEC
 Call NUMERO([F:GTE]COU,[L]HEAFCY,[L]HEADAT,G_JOU,NUMBIC,STAT) From SUBANM
 If GOK<1 | STAT
  If STAT
   Gosub MESSAGE From SUBANM
   STAT = 97 : MESSA =mess(60,199,1)-"("+[F:GTE]COU+") : "+MESSA : Goto ERR
  Endif
  STAT=99 : Goto ERR
 Endif

 #
 If [F:GTE]COU<>""
  Read [ANM]ANM0 = [F:GTE]COU
  If fstat
   Call RSTA("ANM",[F:GTE]COU) From GLOCK
   STAT = 99 : Goto ERR
  Endif
  If [F:ANM]CTLCHR=2
   NUMERO = NUMBIC : OK1 = 1
   Repeat
    Call NUMERO_PREC([F:GTE]COU,[L]HEAFCY,[L]HEADAT,G_JOU,NUMERO,[L]SEQ,STAT)  From SUBANM
    If NUMERO = NUMBIC : Break : Endif
    If STAT : GOK = 0 : Break : Endif
    Read [HEA1]SIH0 = NUMERO
    If !fstat
     If [F:HEA1]ACCDAT > [L]HEADAT
      MESSA = num$([F:HEA1]ACCDAT) : STAT = 55 : Goto ERR
      GOK = 0
     Endif
     OK1 = 0
    Endif
   Until OK1=0 or SEQ=1
   If GOK=0 : STAT=99 : Goto ERR : Endif
  Endif
 Endif
Endif

G_LIN += 1
Raz [F:LIN]
If [L]HEAINVNUM = ""
 [F:LIN]INVTYP    = 1
Else
 [F:LIN]INVTYP    = 2
Endif
[F:LIN]NUM       = NUMBIC
[F:LIN]LIG       = G_LIN
[F:LIN]DES       = [L]DES
[F:LIN]FCYLIN    = [L]FCY
[F:LIN]BPRLIN    = ""

For NLED=1 To GNBTYPLED
 [F:LIN]COA(GTYPLED(NLED)-1) = GPLAN(NLED)
 INDCOA = find(GPLAN(NLED),[L]COA(1..dim([L]COA)))
 If INDCOA
  [F:LIN]ACC(GTYPLED(NLED)-1) = evalue("[L]ACC("+num$(INDCOA)+")")
 Endif
 If NLED=GTYPGEN & [F:LIN]ACC(GTYPGEN-1)=""
  STAT=56 : Break
 Endif
 Call LECLED(GSOCIETE,GTYPLED(NLED),[L]CODLED,[L]DEVLED) From CPTDIV
 [F:LIN]LED(GTYPLED(NLED)-1) = [L]CODLED
 Call CONTACC(GTYPLED(NLED),[F:LIN]COA(GTYPLED(NLED)-1),[F:LIN]ACC(GTYPLED(NLED)-1),[F:LIN]FCYLIN,"",[L]HEADAT) From CPTCNT
 If mkstat : STAT=99 : Break : Endif
Next
If STAT : Goto ERR : Endif

Call CNTIPTACC(10,[F:LIN]COA,[F:LIN]ACC,MESSA,STAT) From CPTCNT
If STAT  : STAT=97 :  Goto ERR  : End : Endif

[F:LIN]SAC       = ""
Call RECH_ACC(2,GSOCIETE,GTYPLED,GNBPLAN,[F:LIN]COA,[F:LIN]ACC,PLANA,CPTANA) From CPTDIV
FLGANA=0
If [L]CPTANA<>""
 Call LEC_GAC([L]CPTANA,PLANA) From CPTLEC
 If !fstat
  [F:LIN]DSP = [L]DSP
  [F:LIN]UOM = [F:GAC]UOM
  If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
   Call LEC_CPY(GSOCIETE) From CPTLEC
   Call CONVERT([L]HEACUR,GCURSHR,[F:CPY]ACCCUR,1,[L]HEADAT,[L]AMTNOTLIN,[L]MONTANT,STAT) From TRTDEV
   [F:LIN]QTY = [L]MONTANT/[F:GAC]VALUOM
   Call AROQTE([F:LIN]QTY,[F:GAC]UOM) From CPTINI
  Endif
 Endif
 FLGANA=1
Endif

[F:LIN]AMTNOTLIN = [L]AMTNOTLIN
#*X3-38745  [F:LIN]AMTATILIN = [L]AMTNOTLIN+[L]AMTVAT

[F:LIN]VAT     = [L]VAT      : [F:LIN]AMTVAT     = [L]AMTVAT
[F:LIN]TAX1    = [L]TAX1     : [F:LIN]AMTTAX1    = [L]AMTTAX1
[F:LIN]TAX2    = [L]TAX2     : [F:LIN]AMTTAX2    = [L]AMTTAX2
[F:LIN]TAXRCP  = [L]TAXRCP   : [F:LIN]AMTTAXRCP  = [L]AMTTAXRCP
[F:LIN]TAXISS  = [L]TAXISS   : [F:LIN]AMTTAXISS  = [L]AMTTAXISS
[F:LIN]TAXOTH1 = [L]TAXOTH1  : [F:LIN]AMTTAXOTH1 = [L]AMTTAXOTH1
[F:LIN]TAXOTH2 = [L]TAXOTH2  : [F:LIN]AMTTAXOTH2 = [L]AMTTAXOTH2

#*X3-38745  Use of multi-tax levels on Asset Disposal
[F:LIN]AMTATILIN = [L]AMTNOTLIN+[L]AMTVAT+[L]AMTTAX1+[L]AMTTAX2+[L]AMTTAXRCP+[L]AMTTAXISS+[L]AMTTAXOTH1+[L]AMTTAXOTH2

If CAS="1"
 [F:LIN]FLGGEN    = 2
Endif

# Initialization SALTYP
[F:LIN]SALTYP  = 1
Call LEC_GAC([F:LIN]ACC(GTYPGEN-1),[F:LIN]COA(GTYPGEN-1)) From CPTLEC
If [F:GAC]FLGVAT=2
 Case [F:GAC]VATIPT
  When 2 : [F:LIN]SALTYP = 2
  When 3 : [F:LIN]SALTYP = 3
  When 4 : [F:LIN]SALTYP = 2
 Endcase
Endif
##
[F:LIN]FLGDEP = 1

Write [LIN]
If fstat
 Call FSTA("SIL") From GLOCK
 STAT=99 : Goto ERR
Endif

If dim(G_TEST)>0 & G_TEST : Gosub SIL From ZZCPUS92B : Endif

If FLGANA
 Gosub LINES_ANA
Endif

#
G_AMTNOT  + = [F:LIN]AMTNOTLIN
G_AMTATI  + = [F:LIN]AMTATILIN

BASTVA = [F:LIN]AMTNOTLIN
TVA = 0
TAXE = [F:LIN]TAX1    : MONTANT = [F:LIN]AMTTAX1    : BASE = [F:LIN]AMTNOTLIN : EXOTAX = [F:LIN]EXEAMTTAX1
Gosub SET_TAXE
TAXE = [F:LIN]TAX2    : MONTANT = [F:LIN]AMTTAX2    : BASE = [F:LIN]AMTNOTLIN : EXOTAX = [F:LIN]EXEAMTTAX2
Gosub SET_TAXE
TAXE = [F:LIN]VAT     : MONTANT = [F:LIN]AMTVAT     : BASE = BASTVA           : EXOTAX = [F:LIN]EXEAMTVAT
TVA = 1
Gosub SET_TAXE
End

#######################
$SET_TAXE
If TAXE<>""
 K = find(TAXE,G_TAX(1..G_NBRTAX))
 If !K
  G_NBRTAX += 1 : K = G_NBRTAX
  G_TAX(K) = TAXE
 Endif
 G_BASTAX(K) += BASE
 G_AMTTAX(K) += MONTANT
 G_EXEAMTTAX(K) += EXOTAX
 If !TVA
  Call LEC_TVT_LEG(GCURLEG,TAXE) From CPTLEC
  If [F:TVT]VATCHA=2
   BASTVA += MONTANT
  Endif
 Endif
Endif
Return

#######################
$LECADR
Call LEC_BPC([F:HEA]BPR) From CPTLEC
Read [BPA]BPA0 = 1;[F:HEA]BPR;[F:BPC]BPAADD
If !fstat
 [F:HEA]BPAINV = [F:BPA]BPAADD
 For I=0 To min(dim([F:HEA]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
  [F:HEA]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [F:HEA]POSCOD = [F:BPA]POSCOD
 [F:HEA]CTY    = [F:BPA]CTY
 [F:HEA]CRY    = [F:BPA]CRY
 [F:HEA]CRYNAM = [F:BPA]CRYNAM
Endif
For I=0 To min(dim([F:HEA]BPRNAM),dim([F:BPC]BPCNAM))-1
 [F:HEA]BPRNAM(I) = [F:BPC]BPCNAM(I)
Next I
#
Read [BPA]BPA0 = 1;[F:HEA]BPRPAY;[F:HEA]BPAPAY
If !fstat
 For I=0 To min(dim([F:HEA]BPYADDLIG),dim([F:BPA]BPAADDLIG))-1
  [F:HEA]BPYADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [F:HEA]BPYPOSCOD = [F:BPA]POSCOD
 [F:HEA]BPYCTY    = [F:BPA]CTY
 [F:HEA]BPYCRY    = [F:BPA]CRY
 [F:HEA]BPYSAT    = [F:BPA]SAT
 If [F:BPA]CRYNAM<>"" : [F:HEA]BPYCRYNAM = [F:BPA]CRYNAM
 Else [F:HEA]BPYCRYNAM="" : Call INIPAYS([F:BPA]CRY,[F:HEA]BPYCRYNAM) From TRTDIV
 Endif
Endif
Call LEC_BPC([F:HEA]BPRPAY) From CPTLEC
For I=0 To min(dim([F:HEA]BPYNAM),dim([F:BPC]BPCNAM))-1
 [F:HEA]BPYNAM(I) = [F:BPC]BPCNAM(I)
Next I

Call LEC_BPC([F:HEA]BPR) From CPTLEC
Return

#######################
$CONTGTE
Call CONTGTE(G_GTE,GCURLEG,"") From SUBGTE
If mkstat
 Gosub TIT From WOGTE : GMESSAGE = TIT-":"-G_GTE+"\"+GMESSAGE
 STAT = 98 : Return
Endif
If [F:GTE]ACS<>""
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat
  GMESSAGE = [F:GTE]ACS-GMESSAGE
  STAT = 98 : Return
 Endif
Endif
Call CTLVLYDAT([L]HEADAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
If mkstat
 GMESSAGE=mess(22,107,1)-G_GTE-GMESSAGE
 STAT = 98 : Return
Endif
If [F:GTE]VCRREA<>2
 GMESSAGE=mess(59,119,1)
 STAT = 98 : Return
Endif
Return

#######################
$CONTJOU
Call CONTJOU(G_JOU,GCURLEG,"") From SUBJOU
If mkstat
 Gosub TIT From WOJOU : GMESSAGE = TIT-":"-G_JOU+"\"+GMESSAGE
 STAT = 98 : Return
Endif
If [F:JOU]ACS<>""
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat
  GMESSAGE = [F:JOU]ACS-GMESSAGE
  STAT=98 : Return
 Endif
Endif
If [F:JOU]FCY<>""
 Call VERSOC([F:JOU]FCY,GSOCIETE,[F:HEA]FCY,[F:JOU]JOU) From CFYSUB
 If mkstat
  STAT=98 : Return
 Endif
Endif
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = [F:JOU]JOU-mess(8,106,1)-[F:GTE]TYP
 STAT=98: Return
Endif
Return

$E_END
GOK=0
Rollback
End

#######################
$DECLARE
Local Char    CPTANA(GLONGAC)
Local Char    PLANA(GLONCOA)
Local Integer NLED
Local Integer SEQ
Local Decimal EXERCICE , PERIODE

Local Decimal  MONTANT , BASE , BASTVA , EXOTAX
Local Integer  TVA, CASDSP, LIGANA
Local Char     TAXE(GLONVAT)

Local Integer STAT

Local Char CODLED(GLONLED)
Local Char DEVLED(GLONCUR)

Local Decimal COURS, COURDIV, COURMUL
Local Integer TYPCOURS

Local Integer INDCOA, INDAXE
Local Integer XSOI, XFLGFUP

Local Char    DEPMOD(10)

Raz MESSA
Raz GMESSAGE
Return

#######################
$DECLARE_GLOBAL
 Global Integer G_LIN
 Global Integer G_NBRTAX
 Global Decimal G_AMTNOT, G_AMTATI
 Global Char    G_TAX(GLONVAT)(1..10)
 Global Decimal G_BASTAX(1..10), G_AMTTAX(1..10) , G_EXEAMTTAX(1..10)

 Global Char G_GTE(GLONGTE), G_JOU(GLONJOU)
Return

#######################
$DECLARE_FILE
If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([F:LED])  : Local File GLED       [LED]  : Endif
If !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
If !clalev([F:DIE])  : Local File GDIE       [DIE]  : Endif

If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:GAG])  : Local File GAUTACEF   [GAG]  : Endif
If !clalev([F:TVT])  : Local File TABVAT     [TVT]  : Endif
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:CCE])  : Local File CACCE      [CCE]  : Endif
If !clalev([F:TPT])  : Local File TABPAYTERM [TPT]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:TDA])  : Local File TABDEPAGIO [TDA]  : Endif
Return

#######################
$DECLARE_FILE_BIC
If !clalev([F:HEA])  : Local File SINVOICE   [HEA]  : Endif
If !clalev([F:LIN])  : Local File BPCINVLIG  [LIN]  : Endif
If !clalev([F:LIA])  : Local File BPCINVLIGA [LIA]  : Endif

If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif    # Use CREECHE From SUBBIH
If !clalev([F:HEA1]) : Local File SINVOICE   [HEA1] : Endif
If !clalev([F:TAB])  : Local File TABSIVTYP  [TAB]  : Endif
Return


#######################
$ERR
Case STAT
 When  1 : MESSA = MESSA-":"-mess(15,104,1)
 When  2 : MESSA = MESSA-":"-mess(54,119,1)
 When  3 : MESSA = MESSA-":"-mess(5,645,1)-":"-mess(56,119,1)
 When 10 : MESSA = MESSA-":"-mess(27,110,1)
 When 11 : MESSA = MESSA-":"-mess(53,141,1)
 When 44 : MESSA = MESSA-":"-mess(2,119,1)
 When 45 : MESSA = MESSA-":"-mess(4,119,1)
 When 54 : MESSA = MESSA-":"-mess(53,141,1)
 When 55 : MESSA = MESSA-":"-mess(101,121,1)
 When 56 : MESSA = MESSA-":"-mess(37,102,1)
 When 97 : MESSA = MESSA
 When 98 : MESSA = GMESSAGE
 When 99 : If MESSA<>"" : MESSA = MESSA-":"-"\"+GMESSAGE
           Else         : MESSA = GMESSAGE
           Endif
                                                      : # STAT=99 - INI_GLOBAL - mess(109,106,1)

Endcase

OK = STAT
Gosub KILL_GLOBAL
End

#######################
$KILL_GLOBAL
If dim(G_LIN)>0
 Kill G_LIN
 Kill G_AMTNOT, G_AMTATI
 Kill G_NBRTAX
 Kill G_TAX
 Kill G_BASTAX, G_AMTTAX, G_EXEAMTTAX

 Kill G_GTE, G_JOU
Endif

If dim(GNBPLAN)>0
 Gosub KILL_GLOBAL From SUBBICS
Endif
Return


#######################
$COURS
Call LEC_GTE_LEG(GCURLEG,[F:HEA]GTE) From CPTLEC
If [F:GTE]RATDAT=2 & [F:HEA]BPRDAT<>[0/0/0]
 [F:HEA]RATDAT = [F:HEA]BPRDAT
Else
 [F:HEA]RATDAT = [F:HEA]ACCDAT
Endif

#
[F:HEA]CURTYP= [F:BPC]CHGTYP
If [F:HEA]CURTYP=0 : [F:HEA]CURTYP = 1 : Endif

#
Call SETFLGDEV([F:HEA]CUR,[F:HEA]CPY,[F:HEA]RATDAT) From CPTDIV
For J=1 To len(mess(0,2644,1))
 Call LECLED([F:HEA]CPY,J,[L]CODLED,[L]DEVLED) From CPTDIV
 [F:HEA]LED(J-1)    = [L]CODLED
 [F:HEA]CURLED(J-1) = [L]DEVLED
 If DEVLED=[F:HEA]CUR
  [F:HEA]RATDIV(J-1) = 1
  [F:HEA]RATMLT(J-1) = 1
 Else
  Gosub INIT_COURS_LED
  If STAT : Break : Endif
 Endif
Next
Return


#######################
$INIT_COURS_LED
If [F:GCM]FLGVCRRAT(J-1)=2
 TYPCOURS = [F:HEA]CURTYP
Else
 TYPCOURS = [F:GCM]TYPRAT(J-1)
Endif
Call INI_COURS2([F:HEA]CUR,[F:HEA]CURLED(J-1),TYPCOURS,[F:HEA]RATDAT,COURDIV,COURMUL,STAT) From SUBSCL
If STAT
 Raz STAT : Return
Elsif STAT
 Raz STAT
Endif

Case [F:GCM]DACRAT(J-1)
 When 1 :
  [F:HEA]RATDIV(J-1)=1 :
  [F:HEA]RATMLT(J-1) = arr(COURMUL/COURDIV,10^-GDECRCU)
 When 2 :
  [F:HEA]RATDIV(J-1) = arr(COURDIV/COURMUL,10^-GDECRCU)
  [F:HEA]RATMLT(J-1) = 1
 When 3 :
  [F:HEA]RATDIV(J-1) = COURDIV
  [F:HEA]RATMLT(J-1) = COURMUL
Endcase
Return


##########################################################################################################################
$LINES_ANA
# Répartition standard
If [F:LIN]DSP<>""
 [M:VTL]TOTREP = [F:LIN]AMTNOTLIN : [M:VTL]QTOTREP=[F:LIN]QTY
 Gosub SETCHPLST
 Call CHARGE_VTE_STR([F:LIN]DSP,[F:LIN]UOM,[L]LSTLED,[L]LSTACC,[L]LSTAXE) From VENTILE
 LIGANA = 0
 For I=0 To [M:VTL]BAS-1
  CASDSP = 2 : Gosub WRITE_SIA
  If GOK<1 : Break : Endif
 Next I
 If GOK<1 : STAT=99 : Goto ERR : Endif
Else
 CASDSP = 3 : Gosub WRITE_SIA
 If GOK<1 : STAT=99 : Goto ERR : Endif
Endif
Return

$SETCHPLST
Local Char LSTLED(255)
Local Char LSTACC(255)
Local Char LSTAXE(255)
Raz [L]LSTLED, [L]LSTACC, [L]LSTAXE
Local Integer I, NLED, TLED
For NLED=1 To GNBTYPLED
 Gosub SETCHPLED
Next
Gosub SETCHPAXE
Return

$SETCHPLED
If [F:LIN]ACC(NLED-1)<>""
 If NLED>1
  [L]LSTLED += ";" : [L]LSTACC += ";"
 Endif
 [L]LSTLED += [F:LIN]LED(NLED-1)
 [L]LSTACC += [F:LIN]ACC(NLED-1)
Endif
Return

$SETCHPAXE
For I=1 To GNBAXE
 [L]LSTAXE += GAXE(I) : [L]LSTAXE+=";"
Next
If GNBAXE>0
 [L]LSTAXE = left$([L]LSTAXE,len([L]LSTAXE)-1)
Endif
Return

$WRITE_SIA
Raz [F:LIA]

[F:LIA] = [F:HEA]
[F:LIA] = [F:LIN]

For NLED=0 To dim([F:LIA]COA)-1
 [F:LIA]COA(NLED) = [F:LIN]COA(NLED)
 [F:LIA]ACC(NLED) = [F:LIN]ACC(NLED)
Next

Raz [F:LIA]DIE, [F:LIA]CCE
Case CASDSP
 When 2 : # Distribution standard
  LIGANA += 1
  [F:LIA]AMT = [M:VTL]AMT(I)
  [F:LIA]QTY = [M:VTL]QTY(I)
  For AXE=1 To GNBAXE
   If GAXE(AXE)<>""
    [F:LIA]DIE(AXE-1) = GAXE(AXE)
    [F:LIA]CCE(AXE-1) = evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(I)+")")
    For NLED=1 To GNBTYPLED
     Call CONTCCE([F:LIA]CCE(AXE-1),[F:LIN]LED(GTYPLED(NLED)-1),[F:LIA]DIE(AXE-1),[F:LIN]FCYLIN,[L]HEADAT,[F:LIN]ACC(GTYPLED(NLED)-1),GAXE,"[F:LIA]CCE",0) From CPTCNT
     If mkstat : STAT=99 : Break 2 : Endif
    Next
   Endif
  Next
 When 3 : # No distribution
  For AXE=1 To GNBAXE
   If GAXE(AXE)<>""
    [F:LIA]DIE(AXE-1) = GAXE(AXE)
    INDAXE = find(GAXE(AXE),[L]DIE(1..dim([L]DIE)))
    If INDAXE
     [F:LIA]CCE(AXE-1) = evalue("[L]CCE("+num$(INDAXE)+")")
    Endif
    For NLED=1 To GNBTYPLED
     Call CONTCCE([F:LIA]CCE(AXE-1),[F:LIN]LED(GTYPLED(NLED)-1),[F:LIA]DIE(AXE-1),[F:LIN]FCYLIN,[L]HEADAT,[F:LIN]ACC(GTYPLED(NLED)-1),GAXE,"[F:LIA]CCE",0) From CPTCNT
     If mkstat : STAT=99 : Break 2 : Endif
    Next
   Endif
  Next
  [F:LIA]AMT = [F:LIN]AMTNOTLIN
  [F:LIA]QTY = [F:LIN]QTY
  If sum([F:LIA]CCE(0..GNBAXE-1))<>""
   LIGANA = 1
  Else
   LIGANA = 0
  Endif
Endcase
If STAT=99 : Goto ERR : Endif
If LIGANA
 [F:LIA]ANALIG = LIGANA
 Write [LIA]
 If fstat
  Call FSTA("SIA") From GLOCK
  STAT=99 : Goto ERR
 Endif
 If dim(G_TEST)>0 & G_TEST : Gosub SIA From ZZCPUS92B :  Endif
Endif
Return

