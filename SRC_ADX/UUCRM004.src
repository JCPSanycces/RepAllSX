#<AdxTL>@(#)1.0.0.0 $Revision$
# FGR 26/03/2009 : X3SUIVI50275
# Moulinette pour modifier les tiroir de COR et LDS LD1 et LD2

  Call MAJ_UTICRM004(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICRM004(APPLI)
End

########################################################################
Subprog MAJ_UTICRM004(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Modification des tiroirs") From DOSSUB
  #------------------------------------------------------
  IERR = 0
  Call ECR_TIME("DEBUT => Sur les correspondants") From DOSSUB
  Call CRMSTEP5(DOSSIER, IERR) From CRMMAJ30
  If IERR = 0 Then
    Call VALID("OCOR", DOSSIER, 1, B_OK) From VALWIN
    If B_OK <> 1 Then
      Call ECR_TRACE("AWI : OCOR", 1) From GESECRAN
      IERR = 1
    Else
      Call VALID ("COR", DOSSIER, 1, B_OK) From VALOBJ
      If B_OK <> 1 Then
        Call ECR_TRACE("AOB : COR", 1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Endif
  Call ECR_TIME("FIN => Sur les correspondants") From DOSSUB
  #------------------------------------------------------
  Call ECR_TIME("DEBUT => Sur les leads [LDS]") From DOSSUB
  Call TIROIR_LEADS(DOSSIER, "LDS", IERR)
  Call ECR_TIME("DEBUT => Sur les leads [LDS]") From DOSSUB
  #------------------------------------------------------
  Call ECR_TIME("DEBUT => Sur les leads [LD1]") From DOSSUB
  Call TIROIR_LEADS(DOSSIER, "LD1", IERR)
  Call ECR_TIME("DEBUT => Sur les leads [LD1]") From DOSSUB
  #------------------------------------------------------
  Call ECR_TIME("DEBUT => Sur les leads [LD2]") From DOSSUB
  Call TIROIR_LEADS(DOSSIER, "LD2", IERR)
  Call ECR_TIME("DEBUT => Sur les leads [LD2]") From DOSSUB
  #------------------------------------------------------
End

########################################################################
Subprog TIROIR_LEADS(SZAPPLI, SZAOL, IERR)
Value Char SZAPPLI
Value Char SZAOL
Variable Integer IERR

Local Integer B_OK
Local Integer B_MODIF

  IERR = 0
  B_MODIF = 0
  # FGR 26/03/2009 : X3SUIVI50275
  If filinfo(filpath("FIL", "AOBJLST", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI+".AOBJLST" [AOL]
    Trbegin [AOL]
    Read [AOL]AOL0=SZAOL
    If not fstat Then
      If [F:AOL]SELEXP(3) = "" Then
        [F:AOL]SELZON(3) = ""
        [F:AOL]SELFIC(3) = ""
        [F:AOL]SELEXP(3) = "string$([F:LDS]FNC>0,mess([F:LDS]FNC,233,1)) - string$(len([F:LDS]FNCLIB)>0,'('+[F:LDS]FNCLIB+')')"
        [F:AOL]SELTYP(3) = "A"
        [F:AOL]SELINT(3)  = 103
        [F:AOL]SELSAI(3) = ""
        [F:AOL]SELLNG(3) = 0
        B_MODIF = 1
      Endif
      If [F:AOL]SELZON(4) = "" Then
        [F:AOL]SELZON(4) = "PSTREP"
        [F:AOL]SELFIC(4) = "LEAD"
        [F:AOL]SELEXP(4) = ""
        [F:AOL]SELINT(4) = 1462
        [F:AOL]SELTYP(4) = ""
        [F:AOL]SELSAI(4) = ""
        [F:AOL]SELLNG(4) = 0
        B_MODIF = 1
      Endif
      If B_MODIF = 1 Then
        Rewrite [AOL]
        If fstat <> 0 Then
          Call ECR_TRACE("Rewrite [F:AOL]" - SZAOL - "error="-num$(fstat), 1) From GESECRAN
          IERR = 1
        Else
          # Note : c'est toujours OLDS ici
          Call VALID("OLDS", DOSSIER, 1, B_OK) From VALWIN
          If B_OK <> 1 Then
            Call ECR_TRACE("AWI : OLDS", 1) From GESECRAN
            IERR = 1
          Else
            Call VALID(SZAOL, DOSSIER, 1, B_OK) From VALOBJ
            If B_OK <> 1 Then
              Call ECR_TRACE("AOB :" - SZAOL, 1) From GESECRAN
              IERR = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [AOL]
  Endif
End
