Local Char PARAM(10)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"APRTRAD5","APRTRAD5","SPEAPRTRAD5") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "BOUTON"      : Gosub BOUTON
Endcase
Return

$DEBUT
Effzo [M:ATD5]
Affzo [M:ATD5]
Return


$BOUTON
Case BOUT
   When "A" : Gosub IMPORT
Endcase
Return


$IMPORT
Call IMPORTRA([M]LAN,[M]FICHIER)
Return

# Gestion du masque APRTRAD5

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD5) 06/02/2009 15:00:23 (CCORA)
######################################################################################
Subprog AS_FICHIER(VALEUR)
Variable Char    VALEUR()

  Local Char RETOUR(250),NOMFIC(200),FIC1(200)
  Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskPutFile",
&                       "UILocalFileExts="+ chr$(1)+ "html",
&                       "UILocalPath="+ chr$(1)+ "#myDocuments",
&                       "UIRemoteFileName="+ chr$(1) +"IMPPROC_"+GUSER+".html",
&                       "UIRemotePath="+ chr$(1) +"tmp",
&                       "UIRemoteOverWrite="+ chr$(1) +"1"
VALEUR=filpath("tmp","IMPPROC_"+GUSER,"html")
End

Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
Onerrgo ERRF
Openi VALEUR,0
Openi
Onerrgo
End

$ERRF
  GMESSAGE=mess(101,100,1)  : # Fichier inexistant
  mkstat=2
Resume



######################################################################################
Subprog IMPORTRA(LANGT,FICHIER)
Value Char LANGT
Value Char FICHIER

#   Cette procédure importe les textes des processus dans la langue LANGT
#   Le fichier est lu à l'adresse FICHIER

#   On lit des lignes de FICHIER qu'on met dans le clob TRANSP
#   jusqu'à trouver un </PROC
#   Ceci est fait pour éviter les pb liés au troncatures sur 2 lignes des propriétés
#   et au fait que FICHIER peut être très gros

Local Char PROCCOU,LEGCOU,VALL1(250)
Local Clbfile TRANSP(10)
Local Integer NBPROC,NBTEX,NBTEXP,NBSUPP
Local File APROCTEXTE [AXP]
Local Clbfile CLBTXT(6)
Local Integer D1,D2,D3,FIN,IFIN,ZFIN
Local Integer IDEC,ICOU,NBREP
Local Char PROCCOU,IDCOU
Local Char ABFIC : ABFIC="AXP"

Trbegin [AXP]

# Import des textes des processus
Call OUVRE_TRACE(mess(260,123,1)) From LECFIC 
Call ECR_TRACE(mess(261,123,1)-num$(date$)-num$(time$),0) From GESECRAN : # Importé le
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(259,123,1)-" : "-LANGT,0) From GESECRAN     : # Langue
Call ECR_TRACE("",0) From GESECRAN
Openi FICHIER Using [XML_]
Iomode adxifs "" Using [XML_]
Iomode adxirs "" Using [XML_]
Iomode adxium GUTF8 Using [XML_]
Gosub CHARGFIC
While FIN=0
  Gosub RECHPROC
  If D1=0 : Break 1 : Endif
  Gosub SUPPROC
  While D1<>0
    Gosub RECHID
    If D1<>0 : Gosub INSERTXT : Endif
  Wend
  If ZFIN=0
    Gosub CHARGFIC
  Else
    FIN=1
  Endif
Wend

Openi Using [XML_]
Commit
If PROCCOU<>""
  Call ECR_TRACE(PROCCOU-" : "-num$(NBSUPP)-mess(262,123,1)-"     "-num$(NBTEXP)-mess(263,123,1),0) From GESECRAN   : # texte(s)
Endif

Call ECR_TRACE("",0) From GESECRAN   
Call ECR_TRACE("",0) From GESECRAN   
Call ECR_TRACE("-----------------------------------------------------------",0) From GESECRAN   
Call ECR_TRACE("",0) From GESECRAN   
# Nombre total de processus traités
Call ECR_TRACE(mess(256,123,1)-" : "-num$(NBPROC),0) From GESECRAN   
# Nombre total de textes traités
Call ECR_TRACE(mess(257,123,1)-" : "-num$(NBTEX),0) From GESECRAN    

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

$SUPPROC
Filter [AXP] Where CODPRO=PROCCOU and CODLEG=LEGCOU and LANG=LANGT
Local Integer NBC
For [AXP]
  NBSUPP+=1
Next
Filter [AXP]
Delete [AXP] Where CODPRO=PROCCOU and CODLEG=LEGCOU and LANG=LANGT
Return

$INSERTXT
#  Infbox(PROCCOU-IDCOU-num$(len(CLBTXT))-left$(CLBTXT,30)-right$(CLBTXT,len(CLBTXT)-30))
  [F:AXP]CODPRO=PROCCOU
  [F:AXP]CODLEG=LEGCOU
  [F:AXP]UNIQIDP=IDCOU
  [F:AXP]LANG=LANGT
  Call HTMLENTIT(CLBTXT,NBREP) From AHTMLENTIT
  [F:AXP]CLBTEXT=CLBTXT
  Gosub INICRE From GOBJSUB
  Write [AXP]
  NBTEX+=1
  NBTEXP+=1
Return


$CHARGFIC
If ICOU<>0
  TRANSP=right$(TRANSP,ICOU)
Endif
For D1=1 To 100
  Rdseq VALL1 Using [XML_]
  If fstat<>0 : ZFIN=1 : Endif
  If D1=1 and NBPROC=0 and instr(1,VALL1,"<PROCESSUS ")=0
# Fichier non conforme
    Call ERREUR(mess(251,123,1)) From GESECRAN
    FIN=2 : Break 1
  Endif
  If right$(VALL1,len(VALL1))=chr$(10) : VALL1=left$(VALL1,len(VALL1)-1) : Endif
  APPEND TRANSP,VALL1
  If instr(1,VALL1,"</PROC>")<>0 : Break 1 : Endif
Next D1
ICOU=instr(1,TRANSP,"<PROC ")
IFIN=instr(ICOU,TRANSP,"</PROC>")
Return

$RECHPROC
  D1=instr(ICOU,TRANSP,"<PROC ")
  If D1<>0
    If PROCCOU<>""
      Call ECR_TRACE(PROCCOU-LEGCOU-" : "-num$(NBSUPP)-mess(262,123,1)-"     "-num$(NBTEXP)-mess(263,123,1),0) From GESECRAN   : # texte(s)
    Endif
    D2=instr(D1,TRANSP,"=")
    D3=instr(D2+3,TRANSP,'"')
    PROCCOU=mid$(TRANSP,D2+2,D3-D2-2)
# -----------------------------------------------legislation
    LEGCOU=""
    D1=instr(D3,TRANSP,"LEGISL=")
    If D1<>0
      D2=instr(D1,TRANSP,"=")
      If mid$(TRANSP,D2+1,2)<>'""'
        D3=instr(D2+2,TRANSP,'"')
        LEGCOU=mid$(TRANSP,D2+2,D3-D2-2)
      Endif
    Endif
    NBTEXP=0
    NBSUPP=0
    NBPROC+=1
  Endif
Return

$RECHFINPROC
  D1=instr(ICOU,TRANSP,"</PROC>")
Return


$RECHID
  D1=instr(D1,TRANSP,"<ID ")
  If D1>IFIN : D1=0 : ICOU=IFIN +2 : Return : Endif
  If D1<>0
    D2=instr(D1,TRANSP,"=")
    D3=instr(D2+3,TRANSP,'"')
    IDCOU=mid$(TRANSP,D2+2,D3-D2-2)
    D1=instr(D1+1,TRANSP,"</ID>")
    If D1<>0
      D3=instr(D3,TRANSP,'<TEXTF')
      CLBTXT=mid$(TRANSP,D3,D1-D3)
      ICOU=D1+4
    Endif
  Endif
Return


