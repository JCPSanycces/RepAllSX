#############################################
## Comptage des bulletins de paye
#############################################
#JOJAC - 2016-08-05 - X3PEOP-1012 - START
#$OLD_OK
$OK
#JOJAC - 2016-08-05 - X3PEOP-1012 - END
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Local Char    APPLI(10)
Local Integer BULLETIN , BULDOS , MAXI
BULLETIN = 0
[M]NBLIG = 0
For [ADS]DOSSIER
 APPLI = [F:ADS]DOSSIER
 If filinfo(filpath("FIL","VALEMP","fde",APPLI),0)>=0
  Local File =APPLI+".VALEMP" [VEP]
  BULDOS = 0
  Columns [VEP] (PYRMON,EMP,PYRDAT,ORIDAT,RVSDAT)
  For [VEP]VEP2(2) Where PYRMON=gdat$(1,month([M]DATPAY),year([M]DATPAY)) & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
   BULDOS += 1
  Next
  [M]DOSSIER([M]NBLIG)  = APPLI
  [M]INTIT([M]NBLIG)    = [F:ADS]NOMDOS
  [M]BULLETIN([M]NBLIG) = BULDOS
  BULLETIN += BULDOS
  [M]NBLIG += 1
  Columns [VEP]
  Close Local File [VEP]
 Endif
Next
[M]NOMBRE = BULLETIN
#Call NOMBRE(1,MAXI) From GLOCK

#ADNGO - 2016-08-05 - X3PEOP-783 - START
# SBA 98167
 Local Char VALMAX(30)
 If fmet GACTX.AGETLICPAR("MAXEMPLOYEES",VALMAX)=[V]CST_ATRUE
   MAXI=val(VALMAX)
 Endif
#ADNGO - 2016-08-05 - X3PEOP-783 - END

[M]MAXBUL = MAXI
Affzo
SAI = 1
FIN = 0
Return

