Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTBUL","CPTBUL",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OK"    : Gosub OK
 When "DEBUT" : Gosub DEBUT
Endcase
Return

$DEBUT
[M]DATPAY = GMOIPAY
Return

