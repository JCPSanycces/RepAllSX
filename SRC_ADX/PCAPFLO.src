#<AdxTL>@(#)2.0.0.0 $Revision$ 
#################################################################################
#################################################################################
###
###
###
#################################################################################
#################################################################################
### #RMA * Req. 75183 * 27-10-2011 * new Capital flow report
###
###
#################################################################################
#################################################################################
$ACTION

Case ACTION

Endcase

Return
#################################################################################
#################################################################################
$DECLARE

Local Char     CPY, CUR(GLONCUR), MES(255), ACCPREF(GLONGAC), LEG, PARNAM(30), PARVAL(30)
Local Integer  NUMREQ, LEDT, FIYEAR, PYEAR
Local Shortint I, J, K, ETRA, MAXCOL, MAXLIN

MAXCOL = 12
MAXLIN = 40

Local Decimal AMT(1..[L]MAXLIN,1..[L]MAXCOL)
Local Decimal LEDAMT

If clalev([F:CWT])=0  : Local File CAPFLOTMP   [CWT]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE     [BAL]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD  [DAE]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif

Return
#################################################################################
#################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE() ()

Gosub DECLARE

###--- get parameter values for year, company and request number            ---###
For I = 1 To [L]NBPAR
    J = instr(1,[L]PARAMETRE(I),"=")
    If J
        [L]PARNAM  = left$([L]PARAMETRE(I),J-1)
        [L]PARVAL = right$([L]PARAMETRE(I),J+1)
        Case [L]PARNAM
            When "__REQUETE" : [L]NUMREQ       = val([L]PARVAL)
            When "year"      : [L]PYEAR        = val([L]PARVAL)
            When "company"   : [L]CPY          = [L]PARVAL
            When "numedt"    : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
        Endcase
    Endif
Next I

###--- get accouting currency for the company                               ---###
Read [F:CPY]CPY0 = [L]CPY
If fstat : Raz [F:CPY] : Endif
[L]CUR = [F:CPY]ACCCUR
[L]LEG = [F:CPY]LEG

###--- Open trace                                                           ---###
Call OUVRE_TRACE(mess(212,105,1)) From LECFIC #Capital flow

###--- Get the main general ledger                                          ---###
Call LECLEDMAIN(1, [L]CPY, [L]LEDT) From CPTDIV

###---- Get fiscal year. Legally, the opening date defines the fiscal year. ---###
Filter [F:FIY] Where [F:FIY]CPY=[L]CPY & year([F:FIY]FIYSTR)=[L]PYEAR and [F:FIY]LEDTYP = [L]LEDT Order By [F:FIY]FIYSTR Asc
Read [F:FIY] First
If fstat
    Call ECR_TRACE(mess(7,101,1), 1) From GESECRAN  : [L]ETRA = 1 #Fiscal year not yet defined
    GOK = 0
Endif
Filter [F:FIY]
If !GOK : Goto $OUT : Endif
[L]FIYEAR = [F:FIY]FIYNUM

###--- insert values in temporary table                                     ---###
Gosub FILLTABLE

$OUT

Call FERME_TRACE  From LECFIC
If ETRA
    Call LEC_TRACE  From LECFIC
Else
    Call SUPP_TRACE  From LECFIC
Endif

End
#################################################################################
#################################################################################
$FILLTABLE
###--- Fill the inital values (lines 1 and 21) from BALANCE           ---###
###--- J will define column number (1 to 11) depending on the account ---###
For [F:BAL] Where [F:BAL]LEDTYP=[L]LEDT & [F:BAL]CURLED=[L]CUR & [F:BAL]CPY=[L]CPY & [F:BAL]FCY="" & [F:BAL]BPR="" & [F:BAL]BPR="" & [F:BAL]FIY>=[L]FIYEAR-1 & [F:BAL]FIY<=[L]FIYEAR # &
# (left$([F:BAL]ACC,1)="5" | left$([F:BAL]ACC,1)="8")
    [L]J = 0
    For [L]I = 1 To [L]MAXCOL-1 #last column will be for totals
        #[L]ACCPREF = func AFNC.INTFLD("ATABDIV","A1","390~"+num$([L]I))
        [L]ACCPREF = func CAPFLOLIB.GETACCPREADI(format$("N0:2",[L]I),[L]LEG)
        If [L]ACCPREF <> ""
            If pat([F:BAL]ACC,[L]ACCPREF+"*") = 1 : [L]J = I : Break : Endif
        Endif
    Next
    If J = 8 : J = 10 : Endif # Issue 109854 - 2015-09-23 by RMA : column 8 now merges with column 10
    If [L]J : Gosub GETBALVAL : Endif
Next

###--- Fill the other lines from GACCENTRYD                           ---###
###--- J will define column number (1 to 11) depending on the account ---###
For [F:DAE] Where [F:DAE]CPY=[L]CPY & [F:DAE]FIY>=[L]FIYEAR-1 & [F:DAE]FIY<=[L]FIYEAR & [F:DAE]BPR="" & [F:DAE]LEDTYP=[L]LEDT & [F:DAE]PER>0 # & (left$([F:DAE]ACC,1)="5" | left$([F:DAE]ACC,1)="8")
    [L]J = 0
    For [L]I = 1 To [L]MAXCOL-1 #last column will be for totals
        #[L]ACCPREF = func AFNC.INTFLD("ATABDIV","A1","390~"+num$([L]I))
        [L]ACCPREF = func CAPFLOLIB.GETACCPREADI(format$("N0:2",[L]I),[L]LEG)
        If [L]ACCPREF <> ""
            If pat([F:DAE]ACC,[L]ACCPREF+"*") = 1 : [L]J = I : Break : Endif
        Endif
    Next
    If J = 8 : J = 10 : Endif # Issue 109854 - 2015-09-23 by RMA : column 8 now merges with column 10
    If [L]J : Gosub GETDAEVAL : Endif
Next

Gosub WRITEVAL

Return
#################################################################################
#################################################################################
$GETBALVAL

###--- K defines the row depending on the fiscal period (n or n-1) ---###
If [F:BAL]FIY=[L]FIYEAR : [L]K = 21 : Else : [L]K = 1 : Endif

If [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0) = 0 : Return : Endif

[L]LEDAMT    = [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0)
[L]AMT(K,J) += [L]LEDAMT

###--- Fill the total and subtotal lines ---###
Gosub TOTALS

Return
#################################################################################
#################################################################################
$GETDAEVAL

###--- K defines the row depending on the fiscal period (n or n-1) and on the chosen capital flow ---###
Case [F:DAE]CAPFLOTYP
    When "01" : [L]K = 3
    When "02" : [L]K = 4
    When "03" : [L]K = 5
    When "04" : [L]K = 6
    When "05" : [L]K = 7
    When "06" : [L]K = 8
    When "07" : [L]K = 9
    When "08" : [L]K = 14
    When "09" : [L]K = 15
    When "10" : [L]K = 16
    When "11" : [L]K = 17
    When "12" : [L]K = 18
    When Default
        ###--- special case for column 11, if CAPFLOTYP empty it goes to line 11 or 31 ---###
        If [L]J= 11
            [L]K = 11
        Else
            Call ECR_TRACE (mess(12,107,1)-[F:DAE]NUM-mess(45,102,1)-[F:DAE]ACC-mess(212,105,1)-mess(22,108,1),0) From GESECRAN : [L]ETRA = 1 #Capital flow not assigned
            Return
        Endif
Endcase

If [F:DAE]FIY=[L]FIYEAR : [L]K += 20 : Endif

If [F:DAE]AMTLED = 0 : Return : Endif

[L]LEDAMT    = ([F:DAE]AMTLED*[F:DAE]SNS*(-1))
[L]AMT(K,J) += [L]LEDAMT

###--- Fill the total and subtotal lines ---###
Gosub TOTALS

Return
#################################################################################
#################################################################################
$TOTALS

#Total column = maxcol
[L]AMT([L]K,[L]MAXCOL)  += [L]LEDAMT

#Subtotal B
If find([L]K,3,4,5,6,7,8,9)
    [L]AMT(10,[L]MAXCOL) += [L]LEDAMT     #Subtotal B
    [L]AMT(10,[L]J)      += [L]LEDAMT     #Subtotal B, column 12
Endif

#Subtotal D
If find([L]K,3,4,5,6,7,8,9,11)
    If [L]J = 11
        [L]AMT(12,[L]MAXCOL) += [L]LEDAMT #Subtotal D
        [L]AMT(12,[L]J)      += [L]LEDAMT #Subtotal D, column 12
    Endif
Endif

#Subtotal E
If find([L]K,14,15,16,17,18)
     [L]AMT(19,[L]MAXCOL) += [L]LEDAMT     #Subtotal E
     [L]AMT(19,[L]J)      += [L]LEDAMT     #Subtotal E, column 12
Endif

#Total F
If find([L]K,1,3,4,5,6,7,8,9,11,14,15,16,17,18)
    [L]AMT(20,[L]MAXCOL) += [L]LEDAMT     #Total F
    [L]AMT(20,[L]J)      += [L]LEDAMT     #Total F, column 12
Endif

#Subtotal G
If find([L]K,23,24,25,26,27,28,29)
    [L]AMT(30,[L]MAXCOL) += [L]LEDAMT     #Subtotal G
    [L]AMT(30,[L]J)      += [L]LEDAMT     #Subtotal G, column 12
Endif

#Subtotal I
If find([L]K,23,24,25,26,27,28,29,31)
    If [L]J = 11
        [L]AMT(32,[L]MAXCOL) += [L]LEDAMT #Subtotal I
        [L]AMT(32,[L]J)      += [L]LEDAMT #Subtotal I, column 12
    Endif
Endif

#Subtotal J
If find([L]K,34,35,36,37,38)
     [L]AMT(39,[L]MAXCOL) += [L]LEDAMT     #Subtotal J
     [L]AMT(39,[L]J)      += [L]LEDAMT     #Subtotal J, column 12
Endif

#Total L
If find([L]K,21,23,24,25,26,27,28,29,31,34,35,36,37,38)
    [L]AMT(40,[L]MAXCOL) += [L]LEDAMT     #Total L
    [L]AMT(40,[L]J)      += [L]LEDAMT     #Total L, column 12
Endif

Return
#################################################################################
#################################################################################
$WRITEVAL

Trbegin [F:CWT]

For K = 1 To [L]MAXLIN

    [F:CWT]NUMREQ  = [L]NUMREQ
    [F:CWT]LIN     = [L]K

    For J = 1 To [L]MAXCOL
        [F:CWT]AMT(J-1) = [L]AMT(K,J)
    Next

    Write [F:CWT]
    If fstat
        Gosub FSTAMESS
        Call ECR_TRACE(MES+":"-mess(38,114,1)-num$([L]NUMREQ)+","-mess(61,100,1)-num$(K) ,1) From GESECRAN : ETRA = 1 #Writing error
        GOK = 0
        Break
    Endif
Next

If GOK
    Commit
Else
    Rollback
Endif

Return
#################################################################################
#################################################################################
$FSTAMESS

Case fstat
    When 1       : MES = mess(60,100,1)  : # Enregistrement verrouillé
    When 2       : MES = mess(153,115,1) : # Clé suivante lue
    When 3       : MES = mess(22,100,1)  : # Clé déjà existante
    When 4       : MES = mess(11,100,1)  : # Début/fin de fichier
    When 5       : MES = mess(154,115,1) : # Pas d'enregistrement courant
    When Default : MES = mess(6,123,1)   : # Erreur
Endcase

Return
#################################################################################
#################################################################################
