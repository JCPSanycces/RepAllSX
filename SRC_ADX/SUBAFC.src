#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AFC",GBIDC1,GBIDC2) From GOBJET
End

###################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "INICRE"       : Gosub INICRE : Gosub INIMOD
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "MODIF"        : Gosub MODIF
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "SETBOUT"      : Gosub SETBOUT
 When "VERF_CHG"     : Gosub VERF_CHG
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "AP_ANNULE"    : Gosub AP_ANNULE
Endcase
Return

###################################################################
$OUVRE
Local Char OMENU(10)
Local File AFONCTION [AFC2]
Return

###################################################################
$LIENS
Call TEXTE([M]NOM,[M]ZNOM) From OBJDIV
Call TEXTE([M]AIDE,[M]ZAIDE) From OBJDIV
Call TEXTE([M]LIBMENU,[M]ZLIBMENU) From OBJDIV
For I=0 To dim([M]OPTION)-1
 Call TEXTE([M]OPTION(I),[M]ZOPTION(I)) From OBJDIV
Next I
Local Char ACT(GLONACT)
ACT = [F:AFC]ACTION
Gosub CHARGE_PAR
Gosub GRISE_MEN
Gosub GRISE_ACT
Gosub GRISE_TRT
Gosub GRISE_RPT
Return

$RAZDUP
If left$(CZ,3)="GES"
 Local Char OBJET(GLONAOB)
 OBJET = right$(CZ,4)
 Read [AOB]ABREV = OBJET
 If !fstat & [F:AOB]TYPGES<>4
  [M:AFC1]RPT1 = [F:AOB]RPT1
  [M:AFC1]RPT1 = [F:AOB]RPT1
  Affzo [AFC1]RPT1 , RPT2
  Grizo [AFC1]RPT1 , RPT2
  Return
 Endif
Endif
Actzo [AFC1]RPT1 , RPT2
Return

$AP_ANNULE
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

$RAZCRE
Actzo [AFC1]RPT1 , RPT2
Return

$GRISE_RPT
Local Integer GRI
GRI = 0
If left$([M]CODINT,3)="GES"
 Local Char OBJET(GLONAOB)
 OBJET = right$([M]CODINT,4)
 Read [AOB]ABREV = OBJET
 If !fstat & [F:AOB]TYPGES<>4
  GRI = 1
 Endif
Endif
If GRI
 Diszo [AFC1]RPT1 , RPT2
Else
 Actzo [AFC1]RPT1 , RPT2
Endif
Return

$GRISE_ACT
Local Integer GRI
GRI = 0
Case [M]TYPTRAIT
 When 1 : # Traitement
  If [M]TRAIT<>""
   GRI = 1
  Endif
 When 2 : # Menu
  GRI = 1
Endcase
If GRI
 Effzo [AFC2]
 Grizo [AFC2]
Else
 Actzo [AFC2]
Endif
Return

$GRISE_TRT
If [M]ACTION<>""
 [M:AFC1]TRAIT=""
 Effzo [AFC1]TRAIT
 Grizo [AFC1]TRAIT
Elsif [M]TYPTRAIT=2
 Grizo [AFC1]TRAIT
Else
 Actzo [AFC1]TRAIT
Endif
Return

$GRISE_MEN
If [M]MENU=""
 [M:AFC1]RANG = 0
 [M:AFC1]ZLIBMENU = ""
 [M:AFC1]LIBMENU = 0
 Effzo [AFC1]RANG , ZLIBMENU
 Grizo [AFC1]RANG , ZLIBMENU
Else
 Actzo [AFC1]RANG , ZLIBMENU
Endif
Return

$CHARGE_PAR
Raz [M]NBPAR, [M]PARAM, [M]VALPAR
While ACT<>""
 Read [ACT]ACTION = ACT
 For [ATR]NOPAR Where ACTION=ACT
  If [F:ATR]NOPAR>1 or [F:ACT]TYPACT<>2
   If !find([F:ATR]CODPAR,[M]PARAM(0..[M]NBPAR-1))
    [M]PARAM([M]NBPAR) = [F:ATR]CODPAR
    K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
    If K
     [M]VALPAR([M]NBPAR) = [F:AFC]VALPAR(K-1)
    Endif
    Read [AAR]CODPAR = [F:ATR]CODPAR
    [M]NBPAR += 1
   Endif
  Endif
 Next ATR
 ACT = [F:ACT]ACTSUI
Wend
Return

###################################################################
$VERIF_MOD
$VERIF_CRE
If [M:AFC1]MENU=[M:AFC0]CODINT
 Read [AFC2]CODINT = [M:AFC1]MENU
 If [F:AFC2]TYPTRAIT=2
  GMESSAGE = [M:AFC1]MENU-":"-mess(83,123,1) : # Valeur incorrecte
  zonsui = "MENU" : mkstat = 2 : Return
 Endif
Endif
If [M:AFC1]TYPTRAIT=1 & [M:AFC1]TRAIT="" & [M:AFC2]ACTION=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 zonsui = "TRAIT" : mkstat = 2 : Return
Endif
Return

###################################################################
$INICRE
Read [AFC2]NUMFNC Last
[F]NUMFNC = [F:AFC2]NUMFNC + 1
If [F]NUMFNC>=9001 & [F]NUMFNC<=9999
 [F]NUMFNC = 10000
Endif
If GADONIX<>2
 [F]NUMFNC = max([F]NUMFNC,5001)
Endif
Return

###################################################################
$INIMOD
[F:AFC]CODEXT = [F:AFC]CODINT
Raz [F:AFC]VALPAR : # Pour bien virer les paramètres actions
For I=1 To [M]NBPAR
 [F:AFC]VALPAR(I-1) = [M]VALPAR(I-1)
 [F:AFC]CODPAR(I-1) = [M]PARAM(I-1)
Next I
Return

###################################################################
$MODIF
If left$(CLECUR1,3)="GES"
 Local Char OBJET(GLONAOB)
 OBJET = right$(CLECUR1,4)
 Readlock [AOB]ABREV = OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$AOBJET"-OBJET : Return
 Elsif !fstat & [F:AOB]TYPGES<>4
  If dim([F:AOB]UPDDAT)>0 : [F:AOB]UPDDAT = date$ : Endif
  If dim([F:AOB]UPDUSR)>0 : [F:AOB]UPDUSR = GUSER : Endif
  If dim([F:AOB]UPDTIM)>0 : [F:AOB]UPDTIM = time  : Endif
  [F:AOB]MENU   = [F:AFC]MENU
  [F:AOB]RANG   = [F:AFC]RANG
  Rewrite [AOB]
  If fstat
   GOK = 0 : Call FSTA("AOB") From GLOCK : Return
  Endif
  Call VALID([F:AOB]ABREV,nomap,0,OK) From VALOBJ
 Endif
Endif
Return

###################################################################
$APRES_CRE
[M:AFC1]NUMFNC = [F:AFC]NUMFNC
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
#Affzo [M:AFC1]NUMFNC
Return

###################################################################
$APRES_MOD
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

###################################################################
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
CHMEN += "45"
Return

###################################################################
$VERF_CHG
Read [AFC]CODINT=OCODE
If !fstat & [F:AFC]TYPTRAIT=2 & len(NCODE)>5
 Call ERREUR(mess(72,126,1)) From GESECRAN : # Format code fonction incorrect (max 5 caratères)
 OK = 0 : Return
Endif
Return

###################################################################
$AP_CHANGE
Trbegin [AFC]
 Update [AFC] Where CODINT=NCODE With CODEXT=NCODE
 Read [AFC]CODINT=NCODE
 If !fstat & [F:AFC]TYPTRAIT=2
  Update [AFC] Where CODINT=NCODE With TRAIT=NCODE
 Endif
Commit
Return

###############################################
#modification par cp 12/04/00
$CREATION
## mise à jour de la table AFCTFCY
If [F:AFC]TYPTRAIT<>2 and [F:AFC]FCYAUZ=2
 Call CREATIONFONCTION([M:AFC0]CODINT,[M:AFC1]TYP,[M:AFC1]NBOPT,[M:AFC1]FLAG) From SUBAFP2
Endif
Return

###############################################
#modification par cp 12/04/00
$AVANT_MODFIC
## mise à jour de la table AFCPRF &AFCTFCY
Call MODIFONCTION([M:AFC0]CODINT,[M:AFC1]TYP,[M:AFC1]FCYAUZ,[M:AFC1]NBOPT,[M:AFC1]FLAG,[F:AFC]TYP,[F:AFC]FCYAUZ,[F:AFC]NBOPT,[F:AFC]FLAG)
&    From SUBAFP2
Return

#########################################################################
$SEL_LISTE
Case LISTE
 When "SELFLG"   : Gosub SET_FLAG
 When "SELRNG"   : Gosub SELRNG
Endcase
Return

# Options réservées à la gestion d'objet

$SET_FLAG
Local Char TEXTE(30)(0..10) , TEX(1)(0..10) , TIT(30)
Local Integer NBTEX
Raz TEX , NBTEX
NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX) = TEX(NBTEX)-mess(59,123,1) : # Création
NBTEX += 1 : TEX(NBTEX) = "M" : TEXTE(NBTEX) = TEX(NBTEX)-mess(60,123,1) : # Modification
NBTEX += 1 : TEX(NBTEX) = "S" : TEXTE(NBTEX) = TEX(NBTEX)-mess(53,123,1) : # Suppression
NBTEX += 1 : TEX(NBTEX) = "N" : TEXTE(NBTEX) = TEX(NBTEX)-mess(117,75,1) : # Flag actif
TIT = mess(129,133,1) : # Code réservé
Return

$SELRNG
Local Char    TEX(10)(1..200) , TEXTE(GLONDES)(1..200,1..3)
NBTEX = 0
Local File AFONCTION [AFC]
For [AFC]MENU Where MENU=[M]MENU
 If NBTEX<dim(TEX)
  NBTEX += 1
  Call TEXTE([F:AFC]LIBMENU,TEXTE(NBTEX,3)) From OBJDIV
  TEX(NBTEX) = format$("N:3#",[F:AFC]RANG)
  TEXTE(NBTEX,2) = [F:AFC]CODINT
 Endif
Next AFC
Return

#########################################################################
$SEL_TABLE
Case TABLE
 When "SELTRAIT"  : Gosub S_SELTRAIT
 When "SELMENU"   : Gosub S_SELMENU
Endcase
Return

#########################################################################
$FIN_TABLE
Case TABLE
 When "SELMENU"  : Gosub F_SELMENU
Endcase
Return

##############################################
$S_SELTRAIT
Local File AFONCTION [AFC]
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
Link [AFC] With [ATX]NUMERO=GLANGUE;NOM As [AFC_]
Default File [AFC_]
CRITERE = 'TYPTRAIT=2 & TRAIT<>""'
START   = "TRAIT"
TIT(0) = mess(40,100,1) : # Choix
DEFPAG = 1
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:AFC]TRAIT" : FICHE = "AFONCTION/TRAIT"  : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE" : FICHE = "AFONCTION/NOM"    : Gosub TEXTE
Return

##############################################
$S_SELMENU
Local File AFONCTION [AFC]
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
Link [AFC] With [ATX]NUMERO=GLANGUE;NOM As [AFC_]
Default File [AFC_]
CRITERE = 'MENU>VALEUR'
START   = "MENU"
TIT(0) = mess(40,100,1) : # Choix
DEFPAG = 1
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:AFC]MENU"   : FICHE = "AFONCTION/MENU"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "[F:AFC]CODINT" : FICHE = "AFONCTION/CODINT" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE"  : FICHE = "AFONCTION/NOM"    : Gosub TEXTE
Return

##############################################
$F_SELMENU
VALEUR = [F:AFC]CODINT
Return

$TEXTE
I = instr(1,FICHE,"/")
Read [ATZ]CODZONE = left$(FICHE,I-1);right$(FICHE,I+1)
Call TEXTE([F:ATZ]NOCOURT,TIT(NBCOL)) From OBJDIV
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AFONCTION  [AFC1]
 Local File ATEXTE     [ATX1]
Else
 Local File =[M]DOSORG+".AFONCTION"  [AFC1]
 Local File =[M]DOSORG+".ATEXTE"     [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AFONCTION  [AFC2]
 Local File ATEXTE     [ATX2]
Else
 Local File =[M]DOSDES+".AFONCTION"  [AFC2]
 Local File =[M]DOSDES+".ATEXTE"     [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AFC1], [ATX1], [AFC2], [ATX2]
Return

$TR_COP
GOK = 1
Local Integer NUMERO
Trbegin [AFC2] , [ATX2]
 Delete [AFC2] Where CODINT=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AFONCTION" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AFC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AFC1]CODINT Where CODINT=TABLE
  Read [AFC2]NUMFNC = [F:AFC1]NUMFNC
  If !fstat
   Read [AFC2]NUMFNC Last
   NUMERO = [F:AFC2]NUMFNC+1
   If NUMERO>=9001 & NUMERO<=9999
    NUMERO = 10000
   Endif
   If GADONIX<>2
    NUMERO = max(NUMERO,5001)
   Endif
  Else
   NUMERO = [F:AFC1]NUMFNC
  Endif
  Raz [F:AFC2]
  [F:AFC2] = [F:AFC1]
  Call COPTEXTE([F:AFC1]LIBMENU,[F:AFC2]LIBMENU) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AFC1]AIDE,[F:AFC2]AIDE) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AFC1]NOM,[F:AFC2]NOM) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To dim([F:AFC1]OPTION)-1
   Call COPTEXTE([F:AFC1]OPTION(I),[F:AFC2]OPTION(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  [F:AFC2]NUMFNC = NUMERO
  If dim([F:AFC2]UPDUSR)>0 : [F:AFC2]UPDUSR = GUSER : Endif
  If dim([F:AFC2]UPDDAT)>0 : [F:AFC2]UPDDAT = date$ : Endif
  If dim([F:AFC2]UPDTIM)>0 : [F:AFC2]UPDTIM = time : Endif
  Write [AFC2]
  If fstat
   GOK=0 : Call FSTA("AFC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

###############################################
#  Etiquettes masque AFC1
###############################################

Subprog C_NBOPT
Local Integer I
If [M]TYP=2 & status<>20 : # Clic au-dessus
 For I=1 To [M]NBOPT
  If find([M]FLAG(I-1),"C","M","S","N")
   GMESSAGE = mess(99,123,1)-mess(61,100,1)-num$(I) : # Options incorrectes ligne no i
   mkstat = 1 : Break
  Endif
 Next I
Endif
End

Subprog C_FNCOPT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Look [AFC]CODINT = VALEUR
 If fstat
  GMESSAGE = mess(23,100,1) : # Fiche inexistante
  mkstat = 2 : End
 Endif
Endif
End

Subprog S_RANG(VALEUR)
Variable Decimal VALEUR
Local Char PARAM(30)(1..1)
Call S_LIS_NUM(VALEUR,PARAM,"SELRNG","SUBAFC","") From GACTION
End

Subprog AS_MASQUE(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : VALEUR="" : mkstat=1 : End : Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
If [M]TYPTRAIT=2 : mkstat = 1 : End : Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
End

Subprog C_FCYAUZ(VALEUR)
Variable Integer  VALEUR
If VALEUR<>[M]FCYAUZ & [M]FCYAUZ=2 : # mb 31.5.2 demande 14437
 Call MESSAGE(mess(196,126,1)) From GESECRAN : # Les habilitations pour cette fonction vont être supprimées
Endif
End

Subprog IB_FLAG
Raz GBOUT1
If [M]TYP=2
 GBOUT1 = mess(129,133,1) : # Code réservé
Endif
End

Subprog C_FLAG(VALEUR)
Variable Char     VALEUR
If [M]TYP=2
 Gosub SET_FLAG
 If find(VALEUR,TEX)
  GMESSAGE = mess(99,123,1) : # Options incorrectes
  mkstat = 1 : End
 Endif
Endif
End

Subprog AS_ZOPTION(VALEUR)
Variable Char    VALEUR()
End

Subprog C_TYPTRAIT(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : # Traitement
  If [M:AFC1]MENU="GENE"
   GMESSAGE = mess(83,123,1) : # Valeur incorrecte
   mkstat = 1 : End
  Endif
 When 2 : # Menu
  If len([M:AFC0]CODINT)>5
   GMESSAGE = mess(72,126,1) : # Format code fonction incorrect (max 5 caratères)
   mkstat = 1 : End
  Endif
  [M]TRAIT = [M:AFC0]CODINT
  Affzo TRAIT
Endcase
[M]TYPTRAIT = VALEUR
Gosub GRISE_TRT
Gosub GRISE_ACT
End

Subprog AM_TYPTRAIT(VALEUR)
Variable Integer VALEUR
End

Subprog IB_TRAIT
Case [M]TYPTRAIT
 When 2 : # Menu
  Raz GBOUT1 , GBOUTS
Endcase
End

Subprog D_TRAIT(VALEUR)
Variable Char     VALEUR
Case [M]TYPTRAIT
 When 2 : # Menu
  VALEUR = [M]CODINT
Endcase
End

Subprog C_TRAIT(VALEUR)
Variable Char     VALEUR
Case [M]TYPTRAIT
 When 1 : # Traitement
  [M]TRAIT = VALEUR
  Gosub GRISE_ACT
 When 2 : # Menu
  If VALEUR="" : mkstat = 1 : End : Endif
Endcase
End

Subprog AS_TRAIT(VALEUR)
Variable Char     VALEUR
Case [M]TYPTRAIT
 When 2 : # Menu
  If GREP="D" : VALEUR = [M]CODINT : Endif
Endcase
End

###############################################
#  Etiquettes masque AFC2
###############################################

Subprog C_ACTION(VALEUR)
Variable Char    VALEUR()
Local Char ACT(GLONACT)
Local Integer OK
If VALEUR<>""
 OK = 0
 ACT = VALEUR
 While ACT<>""
  Call LECTURE("ACT",ACT,"") From CONTOBJ
  If fstat : Break : Endif
  If [F:ACT]TYP<>8 : OK = 1 : Break : Endif
  ACT = [F:ACT]ACTSUI
 Wend
 If !OK
  GMESSAGE = VALEUR-":"-mess(8,81,1)+"\"+mess(153,133,1) : # Ce modèle d'action n'est pas géré
  mkstat = 2 : End
 Endif
Endif
[M]ACTION = VALEUR
Gosub GRISE_TRT
End

Subprog AM_ACTION(VALEUR)
Variable Char VALEUR()
Local Char ACT(GLONACT)
ACT = VALEUR
Gosub CHARGE_PAR
If !GIMPORT : Affzo 20 : Endif
End

Subprog C_MENU(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>[M]CODINT
 Read [AFC]CODINT=VALEUR
 If fstat or [F:AFC]TYPTRAIT<>2
  GMESSAGE = mess(154,124,1) : # Menu inexistant
  mkstat = 2 : End
 Endif
Endif
[M]MENU = VALEUR
Gosub GRISE_MEN
End
