#<AdxTL>@(#)0.0.0.0 $Revision$ Picking factures et réceptions
########################################################################
# SUBPPI3 : Picking des factures ou des réceptions        MBT 18/09/08 #
#           Ajout du picking des commandes                 SR 04/10/12 #
#           Ajout du picking des expéditions               SR 01/01/16 #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action de    #
#    picking des factures ou réceptions "SAIPICFCC" pour préhargement  #
#    des factures complémentaires et ne sert qu'à gérer le masque      #
#    écran "PPICINV3 [PPI3]".                                          #
########################################################################


$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
  When "TITRE"        : Gosub TITRE_FEN
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "OK"           : Gosub OK
  When "END"          : Gosub END_ABANDON
  When "ABA"          : Gosub ABA
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
  When "DEB_PIC"      : Gosub DEB_PIC
  When "CRE_PIC"      : Gosub CRE_PIC
  When "ANU_PIC"      : Gosub ANU_PIC
  When "FIN_PIC"      : Gosub FIN_PIC
  When "FINSAI"       : Gosub FINSAI
Endcase
Return

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Local Integer  SAVNOLIGN : SAVNOLIGN=nolign
# Issue 89349 - 2013-10-25 by SR : Rapprochement
Local Integer  WOK
Local Char     WFLTFCS(30) : WFLTFCS = "[F:PIH]STA=3"
Local Char     WMESS(200)
# Issue X3-69477 - 2017-12-28 by SR :
Local Char     WCRITERE(240)
Return

#---------------------------------------------------#
# Avant ouverture de la fenêtre (Avant car GSAISIE) #
#---------------------------------------------------#
$OUVRE_BOITE
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
#----- Chargement des noms des Currbox de chaque tiroir -----#
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR
Global Char GBOXPI3(10), GBOXPT3(10), GBOXPO5(10),GBOXSHIP3(10)
GBOXPI3   ="GAU_CHE"+num$(find("PI3",OBJLIS(1..8))) : # Picking des factures
GBOXPT3   ="GAU_CHE"+num$(find("PT3",OBJLIS(1..8))) : # Picking des réceptions
GBOXPO5   ="GAU_CHE"+num$(find("PO5",OBJLIS(1..8))) : # Picking des commandes
GBOXSHIP3 ="GAU_CHE"+num$(find("SHIP3",OBJLIS(1..8))) : # Picking des Expéditions
#-----
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
#----- Variables locales -----#
Local  Char     WNUM(GLONVCR), SYMBOL2(30)
Local  Integer  WLIN, I, J, K, L, WOK
Local  Shortint NOL,  WPICK, SAVNBLIG, WMKSTAT, WTYP
# Issue 97613 - 2014-09-09 by SR : Pour lancer CONTROL_VALID
Local  Char     WITMREF(GLONITM)
Local  Integer  WSEQ
#-----
SAVNBLIG=[M:PIH3]NBLIG
#-----
Raz [M:PPI3]
[M:PPI3]REPART=2
[M:PPI3]DEV=[M:PIH1]CUR
# Issue 82703 - 2013-02-12 by SR
[M:PPI3]CSTMAJ=2
# Issue 89349 - 2013-10-25 by SR : Rapprochement
Grizo [M:PPI3]FCSCOD
Affzo [PPI3]1-99
Return

#-------------------------------------------------------------------------#
# Activation / désactivation des menus (ToolBar) et boutons (bas d'écran) #
#-------------------------------------------------------------------------#
$SETBOUT
If [M:PPI3]NBLIG=0 | ([M:PPI3]NBLIG=1 & status=65)
  ETABOU(GSPE3)=0   : # Désactivation bouton "Tout exclure"
  ETABOU(GVALI)=0   : # Désactivation bouton "OK"
  If [M:PPI3]REFART="" & [M:PPI3]MTHT=0
    ETABOU(GABAN)=0 : # Désactivation bouton 'Abandon"
  Endif
Endif
Return

#-------------------------------------------#
# Après l'exécution d'un bouton bas d'écran #
#-------------------------------------------#
$BOUTON
Case BOUT
  When "1" : Gosub TIROIR : # Critères picking
  When "2" : Gosub TOUT_INCLURE
  When "3" : Gosub TOUT_EXCLURE
Endcase
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
GPIH_PICK=1
# Issue 91788 - 2013-08-12 by MUARN : ajout d'un message si pas de montant à répartir
Local Integer  OK  : OK=2
If [M:PPI3]MTHT = 0
  Call OUINON(mess(177,117,1)+"\"+mess(205,100,1),OK) From GESECRAN
Endif
If OK = 2
  If [M:PPI3]NBLIG>0
    Default Mask "[PIH3],[PIH1]"
    #----- Tri du tableau par type et numéro de document -----#
    # Issue 101088 - 2014-07-10 by SR : Trier aussi sur ligne/sequence pour la sous-traitance
    Sorta [M:PPI3]NBLIG [M:PPI3]NBLIG Order By [M:PPI3]WTYPORI(indice),
&                                              [M:PPI3]WNUMORI(indice),
&                                              [M:PPI3]WLINORI(indice),
&                                              [M:PPI3]WSEQORI(indice)
# End issue 101088
    #-----
    Local Decimal WMT
    Local Decimal WCUMQTE
    Local Decimal WCUMMNT
    Local Decimal WCUMPOI
    Local Decimal WCUMVOL
    Local Decimal WCUMPOIREP, WCUMVOLREP # Issue 83715 - 2012-07-26 by MUARN : répartion poids/vol
    #----- Cumul des montants, quantités, poids et volume -----#
    Raz WCUMMNT, WCUMQTE, WCUMPOI, WCUMVOL
    Raz WCUMPOIREP, WCUMVOLREP # Issue 83715 - 2012-07-26 by MUARN : répartion poids/vol
    For L=0 To [M:PPI3]NBLIG-1
      #----- Cumul des montants -----#
      If [M:PPI3]LINTYP(L)<>2
        If [M:PPI3]CUR(L)<>[M:PIH1]CUR
          # Issue 82137 - 2012-05-14 by MUARN : devise différente de la facture pickée et facture pickée en devise société
  #        Call CONVERT([M:PPI3]CUR(L),[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
  #&                    [M:PIH0]ACCDAT,[M:PPI3]AMTNOTLIN(L),WMT,K) From TRTDEV
          If [M:PPI3]CUR(L)= GLOCALDEV
            Call COURMNT([M:PIH1]CUR,GLOCALDEV,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH1]RATDAT,0,
&                      [M:PPI3]AMTNOTLIN(L),WMT,[M:PIH1]RAT2,K) From TRTDEV
          Else
            Call CONVERT([M:PPI3]CUR(L),[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                      [M:PIH0]ACCDAT,[M:PPI3]AMTNOTLIN(L),WMT,K) From TRTDEV
          Endif
        Else
          WMT=[M:PPI3]AMTNOTLIN(L)
        Endif
        [M:PPI3]AMTNOTLIN2(L)=WMT
        WCUMMNT+=WMT
      Endif
      #----- Cumul des quantités -----#
      # Issue 102005 - 2015-02-19 by MUARN : qté poids volume sur composé en sous traitance
      #If [M:PPI3]LINTYP(L)<>3  WCUMQTE+=[M:PPI3]QTYUOM(L) : Endif
      If [M:PPI3]LINTYP(L)<3  WCUMQTE+=[M:PPI3]QTYUOM(L) : Endif
      #----- Cumul des poids -----#
      If [M:PPI3]LINTYP(L)<3   WCUMPOI+=[M:PPI3]QTYWEU(L) : Endif
      #----- Cumul des volumes -----#
      If [M:PPI3]LINTYP(L)<3   WCUMVOL+=[M:PPI3]QTYVOU(L) : Endif
      #-----
    Next L
    #-----
    Raz WMT, mkstat
    # Issue 83715 - 2012-07-26 by MUARN : répartition poids ou volume avec cumul poids/volume à 0 on répartit au montant
    If ([M:PPI3]REPART = 3 & WCUMPOI = 0) | ([M:PPI3]REPART = 4 & WCUMVOL = 0) : [M:PPI3]REPART = 2 Endif

    For L=0 To [M:PPI3]NBLIG-1
      #----- Test si tableau des lignes arrivé au maximum -----#
      If [M:PIH3]NBLIG>dim([M:PIH3]TYPORI)-2
        GMESSAGE=mess(26,100,1) : GERR=1
        #----- Déblocage logique des lignes non chargées -----#
        Raz WNUM, WTYP
        For K=I To [M:PPI3]NBLIG-1
          If WTYP<>[M:PPI3]WTYPORI(K) | WNUM<>[M:PPI3]WNUMORI(K)
            WTYP=[M:PPI3]WTYPORI(K)
            WNUM=[M:PPI3]WNUMORI(K)
            Gosub DEVERROU_DOCUMENT
          Endif
        Next K
        #-----
        mkstat=1 : Break
      Endif
      #-----
      NOL=[M:PIH3]NBLIG : nolign=NOL+1
      status=73 : Call INSERE("PIDLIN") From TABLEAUX
      If mkstat  Break : Endif
      [M:PIH3]TYPORI(NOL)=[M:PPI3]WTYPORI(L)
      [M:PIH3]NUMORI(NOL)=[M:PPI3]WNUMORI(L)
      [M:PIH3]LINORI(NOL)=[M:PPI3]WLINORI(L)
      # Issue 82703 - 2012-10-04 by SR
      [M:PIH3]SEQORI(NOL)=[M:PPI3]WSEQORI(L)
      If [M:PPI3]REFART<>""
        [M:PIH3]ITMREF(NOL)=[M:PPI3]REFART
      Else
        [M:PIH3]ITMREF(NOL)=[M:PPI3]ITMREF(L)
      Endif
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      # Issue 82703 - 2013-02-11 by SR
      [M:PIH3]CSTMAJLIN(NOL) = [M:PPI3]CSTMAJ
      # Issue 89349 - 2013-10-25 by SR
      [M:PIH3]FCSCOD(NOL) = [M:PPI3]FCSCOD
      If [M:PIH3]CSTMAJLIN(NOL) = 1
          Actzo [M:PIH3]FCSCOD(NOL)
      Endif
      If L=[M:PPI3]NBLIG-1
        [M:PIH3]GROPRI(NOL)=[M:PPI3]MTHT-WMT
      Else
        # Issue 81115 - 2012-04-13 by SR ajout de [M:PPI3] devant REPART
        Case [M:PPI3]REPART
          When 1 : #----- Répartition prorata quantités -----#
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            #If WCUMQTE<>0 & [M:PPI3]LINTYP(L)<>3
            If WCUMQTE<>0 & [M:PPI3]LINTYP(L)=1
              [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYUOM(L)/WCUMQTE,10^-GDECPRI)
            Elsif WCUMQTE<>0 & [M:PPI3]LINTYP(L)=3
              [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYUOM(L-1)/WCUMQTE,10^-GDECPRI)
            Else
              [M:PIH3]GROPRI(NOL) = 0
            Endif
          When 2 : #----- Répartition prorata montants -----#
            If WCUMMNT<>0 & [M:PPI3]LINTYP(L)<>2
              [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]AMTNOTLIN2(L)/WCUMMNT,10^-GDECPRI)
            Endif
          When 3 : #----- Répartition prorata poids -----#
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            #If WCUMPOI<>0 & [M:PPI3]LINTYP(L)<3
            If WCUMPOI<>0 & [M:PPI3]LINTYP(L)=1
              # Issue 83715 - 2012-07-26 by MUARN : poids nul de la ligne pas de répartition
              #[M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYWEU(L)/WCUMPOI,10^-GDECPRI)
              WCUMPOIREP +=[M:PPI3]QTYWEU(L)
              If WCUMPOIREP < WCUMPOI
                [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYWEU(L)/WCUMPOI,10^-GDECPRI)
              Else
                [M:PIH3]GROPRI(NOL)=[M:PPI3]MTHT-WMT
              Endif
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            #Elsif [M:PPI3]QTYWEU(L) = 0 & [M:PPI3]LINTYP(L)<3
            Elsif [M:PPI3]QTYWEU(L) = 0 & [M:PPI3]LINTYP(L)=1
              [M:PIH3]GROPRI(NOL)=0
            # fin Issue 83715 - 2012-07-26 by MUARN : poids nul de la ligne pas de répartition
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            Elsif WCUMPOI<>0 & [M:PPI3]LINTYP(L)=3
              If [M:PPI3]QTYWEU(L-1) = 0
                [M:PIH3]GROPRI(NOL)=0
              Else
                [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYWEU(L-1)/WCUMPOI,10^-GDECPRI)
              Endif
            Elsif [M:PPI3]LINTYP(L)=4
              [M:PIH3]GROPRI(NOL)=0
            Endif
          When 4 : #----- Répartition prorata volumes -----#
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti en fonction composé sur service en sous traitance
            #If WCUMVOL<>0 & [M:PPI3]LINTYP(L)<3
            If WCUMVOL<>0 & [M:PPI3]LINTYP(L)=1
              # Issue 83715 - 2012-07-26 by MUARN : volume nul de la ligne pas de répartition
              #[M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYVOU(L)/WCUMVOL,10^-GDECPRI)
              WCUMVOLREP+=[M:PPI3]QTYVOU(L)
              If WCUMVOLREP < WCUMVOL
                [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYVOU(L)/WCUMVOL,10^-GDECPRI)
              Else
                [M:PIH3]GROPRI(NOL)=[M:PPI3]MTHT-WMT
              Endif
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            #Elsif [M:PPI3]QTYVOU(L)=0 & [M:PPI3]LINTYP(L)<3
            Elsif [M:PPI3]QTYVOU(L)=0 & [M:PPI3]LINTYP(L)=1
              [M:PIH3]GROPRI(NOL)=0
            # fin Issue 83715 - 2012-07-26 by MUARN : volume nul de la ligne pas de répartition
            # Issue 102005 - 2015-02-19 by MUARN : qté poids volume réparti sur service en fonction composé en sous traitance
            Elsif WCUMVOL<>0 & [M:PPI3]LINTYP(L)=3
              If [M:PPI3]QTYVOU(L-1) = 0
                [M:PIH3]GROPRI(NOL)=0
              Else
                [M:PIH3]GROPRI(NOL)=arr([M:PPI3]MTHT*[M:PPI3]QTYVOU(L-1)/WCUMVOL,10^-GDECPRI)
              Endif
            Elsif [M:PPI3]LINTYP(L)=4
              [M:PIH3]GROPRI(NOL) = 0
            Endif
        Endcase
      Endif
      [M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]GROPRI(NOL)
      Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
      WMT+=[M:PIH3]AMTNOTLIN(NOL)
      status=0 : Call LINNUM("PIDLIN") From TABLEAUX
      [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
    Next L
    #-----
    If mkstat & [M:PIH3]NBLIG=SAVNBLIG
      WMKSTAT=mkstat
    Else
      WMKSTAT=4
    Endif
    Affzo [PIH3]5
  Endif
  GPIH_PICK=0
  FIN=1
Else
  FIN=0
Endif
Return

#----------------------------------#
# Sortie par "Fin" ou par la croix #
#----------------------------------#
$END_ABANDON
Gosub DEVERROU_GENERAL
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
Gosub DEVERROU_GENERAL
WPICK=1 : Gosub ACTUALIS_MARQUAGE
Effzo [PPI3]10-15
REP=""
Return

#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
$APRES_MODIF
REP="M"
# Issue 89349 - 2013-11-05 by SR : Rapprochement
Case COUZON
    When "FCSCOD","CSTMAJ"
      # Recharger le tiroir des factures si plus de charge
      # Tester la valeur de WFLTFCS afin de ne pas raffraichir si pas besoin
      # On prépare le filtre dans tous les cas mais on ne l'exploite que si currbox = factures
      If [M:PPI3]FCSCOD = ""
         If WFLTFCS <> "[F:PIH]STA=3" : WFLTFCS = "[F:PIH]STA=3"
            If currbox = GBOXPI3
              Gosub TIROIR
            Endif
         Endif
       Else
       # Vider le tiroir des factures si Charge renseignée grâce à une égalité impossible
       # Tester la valeur de WFLTFCS afin de ne pas raffraichir si pas besoin
       # On prépare le filtre dans tous les cas mais on ne l'exploite que si currbox = factures
         If WFLTFCS <> "[F:PIH]STA=99" : WFLTFCS = "[F:PIH]STA=99"
            If currbox = GBOXPI3
              Gosub TIROIR
            Endif
          Endif
       Endif
   When Default
Endcase
Return

#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
$FILGAUCHE
# Issue X3-69477 - 2017-12-28 by SR : Section complètement revue pour :
#Remplissage de FILGAUSUP via ADDCRIT
#Utilisation de CRMUTIL150 pour récupérer les rôles
Raz FILGAUSUP, IFILGAUSUP
# Issue 82703 - 2012-10-04 by SR
If currbox=GBOXPO5    : #----- Picking des commandes -----#
  WCRITERE="[F:POH]APPFLG > 2"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  WCRITERE="[F:POQ]POHTYP = 1"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  WCRITERE="[F:POQ]CPY=GSOCIETE"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  # Issue 101413 - 2014-07-15 by SR : Interdire les commandes de sous-traitance
   # Issue 106608 - 2015-02-26 by SR
   # FILGAUSUP(1) = "& !find([F:POQ]VCRTYPORI,10,36)"
  WCRITERE= "!find([F:POQ]VCRTYPORI,10,36)"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  If [M:PPI3]WPOHNUM<>""
    WCRITERE="pat([F:POQ]POHNUM,[M:PPI3]WPOHNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WORDDAT<>[0/0/0]
    WCRITERE="[F:POQ]ORDDAT>=[M:PPI3]WORDDAT"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WBPSNUM<>""
    WCRITERE="pat([F:POQ]BPSNUM,[M:PPI3]WBPSNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WITMREF<>""
    WCRITERE="pat([F:POQ]ITMREF,[M:PPI3]WITMREF)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If GCTLDATORI=2
     WCRITERE="ORDDAT<=[M:PIH0]ACCDAT"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"POH") From CRMUTIL150
  # Issue 110325 - 2016-01-08 by SR :FCC sur Expé
Elsif currbox=GBOXSHIP3  : #----- Picking des expédition
   WCRITERE= "[F:SHD]LEGCPY=GSOCIETE & [F:SHH]SHIPTYP <> 2" # même société et pas de pré réception de commande
   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   If [M:PPI3]WPOHNUM<>""
      WCRITERE="pat([F:SHD]POHNUM,[M:PPI3]WPOHNUM)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WBPTNUM<>""
     WCRITERE="pat([F:SHH]BPTNUM,[M:PPI3]WBPTNUM)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WBPSNUM<>""
     WCRITERE="pat([F:SHH]BPSNUM,[M:PPI3]WBPSNUM)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WSHIPNUM<>""
     WCRITERE="pat([F:SHD]SHIPNUM,[M:PPI3]WSHIPNUM)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WITMREF<>""
     WCRITERE="pat([F:SHD]ITMREF,[M:PPI3]WITMREF)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WSHIPUID<>""
     WCRITERE="pat([F:SHH]SHIPUID,[M:PPI3]WSHIPUID)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WTRNNUM<>""
     WCRITERE="pat([F:SHH]TRNNUM,[M:PPI3]WTRNNUM)<>0"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If [M:PPI3]WSHIPDAT<>[0/0/0]
     WCRITERE="[F:SHH]SHIPDAT>=[M:PPI3]WSHIPDAT"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   If GCTLDATORI=2
     WCRITERE="[F:SHH]SHIPDAT<=[M:PIH0]ACCDAT"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   Endif
   Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"SHIP") From CRMUTIL150
Elsif currbox=GBOXPT3    : #----- Picking des réceptions -----#
  WCRITERE="[F:PTD]LINTYP<3"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  WCRITERE="[F:PTD]CPY=GSOCIETE"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
  #If GCTLDATORI=2  FILGAUSUP(1)+=" & [F:PTH]RCPDAT<=[M:PIH0]ACCDAT" : Endif
  If GCTLDATORI=2
     WCRITERE="(([F:PTH]NDEDAT=[0/0/0] & [F:PTH]RCPDAT<=[M:PIH0]ACCDAT)|([F:PTH]NDEDAT<>[0/0/0] & min([F:PTH]NDEDAT,[F:PTH]RCPDAT)<=[M:PIH0]ACCDAT))"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  # Issue 82703 - 2012-10-04 by SR : si pas rcp mais commande
  If [M:PPI3]WPTHNUM<>""
    WCRITERE="pat([F:PTD]PTHNUM,[M:PPI3]WPTHNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Elsif [M:PPI3]WPOHNUM<>""
    WCRITERE="pat([F:PTD]POHNUM,[M:PPI3]WPOHNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WRCPDAT<>[0/0/0]
    WCRITERE="[F:PTD]RCPDAT>=[M:PPI3]WRCPDAT"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WBPSNDE<>""
    WCRITERE="pat([F:PTH]BPSNDE,[M:PPI3]WBPSNDE)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WBPSNUM<>""
    WCRITERE="pat([F:PTD]BPSNUM,[M:PPI3]WBPSNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WBPTNUM<>""
    WCRITERE="pat([F:PTH]BPTNUM,[M:PPI3]WBPTNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WFFWNUM<>""
    WCRITERE="pat([F:PTH]FFWNUM,[M:PPI3]WFFWNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WITMREF<>""
    WCRITERE="pat([F:PTD]ITMREF,[M:PPI3]WITMREF)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PTH") From CRMUTIL150
Elsif currbox=GBOXPI3 : #------ Picking des factures ------#
  WCRITERE="[F:PID]PIHTYP=1 & [F:PID]CPY=GSOCIETE & [F:PID]LINTYP<3"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  # Issue 89349 - 2013-11-05 by SR : Rapprochement STA = 3 : on affiche, STA=99 on vide
#  FILGAUSUP(1)=" & [F:PIH]ORIMOD=6 & [F:PIH]STA=3"
   WCRITERE="[F:PIH]ORIMOD=6"
   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
   WCRITERE= WFLTFCS
   Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  If GCTLDATORI=2
     WCRITERE="[F:PIH]ACCDAT<=[M:PIH0]ACCDAT"
     Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  # Issue 82703 - 2012-10-04 by SR : si pas rcp mais commande
  If [M:PPI3]WPIHNUM<>""
    WCRITERE="pat([F:PID]NUM,[M:PPI3]WPIHNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Elsif [M:PPI3]WPOHNUM<>""
    WCRITERE="pat([F:PID]POHNUM,[M:PPI3]WPOHNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WACCDAT<>[0/0/0]
    WCRITERE="[F:PID]ACCDAT>=[M:PPI3]WACCDAT"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WBPSNUM<>""
    WCRITERE="pat([F:PID]BPR,[M:PPI3]WBPSNUM)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  If [M:PPI3]WITMREF<>""
    WCRITERE="pat([F:PID]ITMREF,[M:PPI3]WITMREF)<>0"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
  Endif
  Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PIH") From CRMUTIL150
Endif
Return

#---------------------------------------------------------#
# Après pagination avant ou arrière d'une liste de gauche #
#---------------------------------------------------------#
$AP_FILGAUCHE
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If !find(currbox,GBOXPI3,GBOXPT3,GBOXPO5,GBOXSHIP3)  Return : Endif
WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return

#---------------------------------------------------#
# Click sur un tiroir                               #
# Désormais entièrement géré par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel à la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
$TIROIR
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur Expé
If !find(currbox,GBOXPT3,GBOXPI3,GBOXPO5,GBOXSHIP3)  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
Return

#---------------#
# Début picking #
#---------------#
$DEB_PIC
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If !find(currbox,GBOXPI3,GBOXPT3,GBOXPO5,GBOXSHIP3)  Return : Endif
Return

#----------------------#
# Nouvel élément pické #
#----------------------#
$CRE_PIC
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If !find(currbox,GBOXPI3,GBOXPT3,GBOXPO5,GBOXSHIP3)  Return : Endif
Case currbox
  When GBOXPI3   : Gosub PICKE_FAC
  When GBOXPT3   : Gosub PICKE_RCP
  When GBOXPO5   : Gosub PICKE_CDE
  When GBOXSHIP3 : Gosub PICKE_SHIP
Endcase
Return

#------------------------#
# Nouvel élément dépické #
#------------------------#
$ANU_PIC
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If !find(currbox,GBOXPI3,GBOXPT3,GBOXPO5,GBOXSHIP3)  Return : Endif
Case currbox
  When GBOXPI3   : Gosub DEPICK_FAC
  When GBOXPT3   : Gosub DEPICK_RCP
  When GBOXPO5   : Gosub DEPICK_CDE
  When GBOXSHIP3 : Gosub DEPICK_SHIP
Endcase
Return

#-------------#
# Fin picking #
#-------------#
$FIN_PIC
Affzo [PPI3]15
If [M:PPI3]NBLIG>0
  REP="M"
Elsif [M:PPI3]REFART="" & [M:PPI3]MTHT=0
  REP=""
Endif
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
Raz [M:PPI3]
If WMKSTAT=0  Gosub DEVERROU_GENERAL : Endif
Gosub TEST_VALID From SUBPIH : # Màj bases taxables et calcul taxes éléments facturation
#----- Suppression variables globales "noms des currbox" -----#
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If dim([V]GBOXPI3)>0  Kill GBOXPI3, GBOXPT3,GBOXPO5, GBOXSHIP3 : Endif
#-----
mkstat=WMKSTAT
nolign=SAVNOLIGN
Return

#---------------------------------------------------------------#
# Actualisation des éléments "pickés" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                   #
#         1 = Enlever le marquage des éléments "pickés"         #
#         2 = Marquer les éléments "pickés"                     #
#---------------------------------------------------------------#
$ACTUALIS_MARQUAGE
If [M:PPI3]NBLIG>0
  For I=0 To [M:PPI3]NBLIG-1
    Gosub MARQUAGE_LIGNE
  Next I
Endif
Return

#--------------------------------------------------------------#
# Actualisation d'un élément "pické" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                  #
#         1 = Enlever le marquage de l'élément "pické"         #
#         2 = Marquer l'élément "pické"                        #
#     I : indice de la ligne du tableau à traiter              #
#--------------------------------------------------------------#
$MARQUAGE_LIGNE
#----- Si appel depuis Subprog (C_NBLIG.. etc) les variables locales n'existent pas !
If dim(FILGAUSUP)<1
  #----- Variables locales superviseur -----#
  Local Integer  FILTREG : FILTREG=1
  Local Integer  INDCUR  : INDCUR=1
  Local Integer  ICRITERE, IFILROLE, IFILSUITE, IFILGAUSUP
  Local Char     FILTSUP(240), FILROLE(250)(0..2) , FILSUITE(250)(0..5), CRITERE(250)
  Local Char     FILGAUSUP(240)(0..3)
  Local Char     WINPROG(GLONADC), ACTION(20) : WINPROG="WGIPPICINV3"
  Local Char     HINTLIS(10)(0..8)
  #----- Variables locales pour gestion picking liste de gauche -----#
  Local Char     WNUM(GLONVCR)
  # Issue 82703 - 2012-10-04 by SR
  Local Integer  WLIN, J, K,WSEQ
Endif
#-----
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
#If [M:PPI3]WTYPORI(I)<5 & [M:PPI3]WNUMORI(I)<>""
If [M:PPI3]WTYPORI(I)<>5 & [M:PPI3]WNUMORI(I)<>""
  J=WPICK
  # Issue 82703 - 2012-10-04 by SR
  WNUM=[M:PPI3]WNUMORI(I) : WLIN=[M:PPI3]WLINORI(I) : WSEQ = [M:PPI3]WSEQORI(I)
  If [M:PPI3]WTYPORI(I)=1    : #----- commandes -----#
    Read [POQ] POQ0=WNUM;WLIN;WSEQ : If fstat  Raz [F:POQ] : Endif
    Read [POH] POH0=[F:POQ]POHNUM  : If fstat  Raz [F:POH] : Endif
    Read [FCY] FCY0=[F:POQ]PRHFCY  : If fstat  Raz [F:FCY] : Endif
    If [F:POH]POHNUM="" & [F:FCY]FCY=""  WPICK=0 : Endif
  Elsif [M:PPI3]WTYPORI(I)=2    : #----- Réceptions -----#
    Read [PTD] PTD0=WNUM;WLIN     : If fstat  Raz [F:PTD] : Endif
    Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
    Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat  Raz [F:FCY] : Endif
    If [F:PTH]PTHNUM="" & [F:FCY]FCY=""  WPICK=0 : Endif
  Elsif [M:PPI3]WTYPORI(I)=4 : #----- Factures -----#
    Read [PID] PID0=WNUM;WLIN     : If fstat  Raz [F:PID] : Endif
    Read [PIH] PIH0=[F:PID]NUM    : If fstat  Raz [F:PIH] : Endif
    If [F:PIH]NUM=""  WPICK=0 : Endif
  # Issue 110325 - 2016-01-08 by SR : FCC sur expé
  Elsif [M:PPI3]WTYPORI(I)=6 : #----- Expé -----#
    Read [SHD] SHD0=WNUM;WLIN         : If fstat  Raz [F:SHD] : Endif
    Read [SHH] SHH0=[F:SHD]SHIPNUM    : If fstat  Raz [F:SHH] : Endif
    If [F:SHH]SHIPNUM =""  WPICK=0 : Endif
  Endif
  # Issue 82703 - 2012-10-04 by SR
  If ([M:PPI3]WTYPORI(I)=1 & currbox=GBOXPO5) |
&    ([M:PPI3]WTYPORI(I)=2 & currbox=GBOXPT3) |
&    ([M:PPI3]WTYPORI(I)=4 & currbox=GBOXPI3) |
&    ([M:PPI3]WTYPORI(I)=6 & currbox=GBOXSHIP3)
    Case WPICK
      When 1 : Gosub DEPICK From GSAISIE
      When 2 : Gosub REPICK From GSAISIE
    Endcase
  Endif
  WPICK=J
Endif
Return

#----------------------------------#
# Sélection d'une ligne de facture #
#----------------------------------#
# Issue 82703 - 2012-10-04 by SR : Raz [F:POH]
$PICKE_FAC
WNUM=[F:PID]NUM : WLIN=[F:PID]PIDLIN
Read [PID] PID0=WNUM;WLIN  : If fstat Raz [F:PID] : Endif
Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
Raz [F:PTH],[F:POH] : # Par sécurité à cause du chargement par le tiroir réceptions
If [F:PIH]NUM="" & [F:PID]NUM=""
  Call RSTA("XPID",WNUM-num$(WLIN)) From GLOCK
Endif
If  [F:PID]LINTYP=2
  Gosub TEST_MAXLIN_STT
Else
  Gosub TEST_MAXLIN
Endif
If mkstat  FOK=0 : Return : Endif
# Issue 97613 - 2014-09-09 by SR
Raz WOK
WTYP = 4
WITMREF = [F:PID]ITMREF
WSEQ    = 0
Call CONTROL_VALID(WITMREF,WTYP,WNUM,WLIN,WSEQ,WOK) From SUBPIHD
If WOK  FOK=0 : Return : Endif
# End issue 97613
#----- Blocage logique de la réception -----#
SYMBOL2="PIH"+[F:PID]NUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PINVOICE"-[F:PID]NUM-mess(10,100,1) : GERR=1 : FOK=0 : Return
Endif
#--- Issue 90972 by TS
#If [F:PID]LINTYP=2
#  Raz WOK
#  For [PID] PID0 Where NUM    =WNUM
#&                    & PIDLIN>=WLIN
#    If [F:PID]LINTYP<3 & WOK  Break : Endif
#    If [F:PID]LINTYP=2
#      WOK=1
#    Else
#      Gosub TEST_MAXLIN : If mkstat  Break : Endif
#    Endif
#    Gosub CHARG_LIG_FAC
#  Next
#Else
#  Gosub CHARG_LIG_FAC
#Endif
Gosub CHARG_LIG_FAC
# Sous-traitance : traitement des services et matières
If [F:PID]LINTYP=2
  For [PIDB] PID0 Where NUM=WNUM & PIDLIN>WLIN
    If [F:PIDB]LINTYP<3 : Break : Endif
    Gosub TEST_MAXLIN
    If mkstat : Break : Endif
    [F:PID] = [F:PIDB]
    Gosub CHARG_LIG_FAC
  Next
Endif
#---
Return

#----------------------------------------------------#
# Chargement de la ligne à partir du picking facture #
#----------------------------------------------------#
$CHARG_LIG_FAC
[M:PPI3]WTYPORI  (NOL)=4
[M:PPI3]WNUMORI  (NOL)=[F:PID]NUM
[M:PPI3]WLINORI  (NOL)=[F:PID]PIDLIN
# Issue 82703 - 2012-10-04 by SR
[M:PPI3]WSEQORI  (NOL)=0
[M:PPI3]ITMREF   (NOL)=[F:PID]ITMREF
[M:PPI3]QTYUOM   (NOL)=[F:PID]QTYPUU
[M:PPI3]UOM      (NOL)=[F:PID]PUU
[M:PPI3]AMTNOTLIN(NOL)=[F:PID]AMTNOTLIN
[M:PPI3]CUR      (NOL)=[F:PIH]CUR
[M:PPI3]QTYWEU   (NOL)=[F:PID]QTYWEU
[M:PPI3]WEU      (NOL)=[M:PIH4]DSPWEU
[M:PPI3]QTYVOU   (NOL)=[F:PID]QTYVOU
[M:PPI3]VOU      (NOL)=[M:PIH4]DSPVOU
[M:PPI3]PJT      (NOL)=[F:PID]PJT
[M:PPI3]ITMDES   (NOL)=[F:PID]ITMDES
[M:PPI3]LINTYP   (NOL)=[F:PID]LINTYP
[M:PPI3]NBLIG+=1 : status=0 : Call APRES_NBLIG
Return

#------------------------------------#
# Sélection d'une ligne de réception #
#------------------------------------#
# Issue 82703 - 2012-10-04 by SR : Raz [F:POH]
$PICKE_RCP
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
# Issue 89349 - 2013-10-25 by SR : Rapprochement : Si charge saisie, contrôle qu'elle est bien prévue
If [M:PPI3]FCSCOD <> ""
    If [F:PTD]STCNUM = ""
       GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
       FOK = 0 : GERR = 1 : Return
    Endif
    Filter [F:STCD] Where VCRTYP = 6 & VCRNUM = [F:PTD]PTHNUM & VCRLIN = [F:PTD]PTDLIN & FCSCOD = [M:PPI3]FCSCOD
    # la charge est-elle presente
    Read [F:STCD]STCD0 First
    Filter [F:STCD]
    If fstat :
       GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
       FOK = 0 : GERR = 1 : Return
    Elsif [F:STCD]FCSAMT = 0
       Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
       If WOK=1 : FOK = 0 : Return : Endif
    Endif
    # Y-a-t-il déjà un enregistrement pour même charge/même pièce d'origine ?
   Filter [F:STCR] Where TYPORI = 2 &  NUMORI = [F:PTD]PTHNUM & LINORI = [F:PTD]PTDLIN
&                   & SEQORI = 0  & FCSCOD = [M:PPI3]FCSCOD
   Look [F:STCR]STCR0 First
   Filter [F:STCR]
    If !fstat
      WMESS = func AFNC.MES2(mess(467,194,1),[M:PPI3]FCSCOD,[F:PTD]PTHNUM+"/"+num$([F:PTD]PTDLIN))
      Call OUINON(WMESS,WOK) From GESECRAN # La charge $1$ du document $2$  a déjà fait l’objet d’une facture complémentaire
      If WOK=1 : FOK = 0 : Return : Endif
    Endif
 Endif
 # End issue 89349
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
Raz [F:PIH],[F:POH] : # Par sécurité à cause du chargement par le tiroir factures
If [F:PTH]PTHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
Endif
If [F:PTD]LINTYP=2
  Gosub TEST_MAXLIN_STT
Else
  Gosub TEST_MAXLIN
Endif
If mkstat  FOK=0 : Return : Endif
# Issue 108852 - 2015-06-18 by SR : Inutile si pièce d'origine = réception
# Issue 97613 - 2014-09-09 by SR
#Raz WOK
#WTYP = 2
#WITMREF = [F:PTD]ITMREF
#WSEQ    = 0
#Call CONTROL_VALID(WITMREF,WTYP,WNUM,WLIN,WSEQ,WOK) From SUBPIHD
#If WOK  FOK=0 : Return : Endif
# End issue 97613
# End issue 108852
#----- Blocage logique de la réception -----#
SYMBOL2="PTH"+[F:PTD]PTHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PRECEIPT"-[F:PTD]PTHNUM-mess(10,100,1) : GERR=1 : FOK=0 : Return
Endif
#--- Issue 90972 by TS
#If [F:PTD]LINTYP=2
#  Raz WOK
#  For [PTD] PTD0 Where PTHNUM =WNUM
#&                    & PTDLIN>=WLIN
#    If [F:PTD]LINTYP<3 & WOK  Break : Endif
#    If [F:PTD]LINTYP=2
#      WOK=1
#    Else
#      Gosub TEST_MAXLIN : If mkstat  Break : Endif
#    Endif
#    Gosub CHARG_LIG_RCP
#  Next
#Else
#  Gosub CHARG_LIG_RCP
#Endif

Gosub CHARG_LIG_RCP
# Sous-traitance : traitement des services et matières
If [F:PTD]LINTYP=2
  For [PTDB] PTD0 Where PTHNUM=WNUM & PTDLIN>WLIN
    If [F:PTDB]LINTYP<3 : Break : Endif
    Gosub TEST_MAXLIN
    If mkstat : Break : Endif
    [F:PTD] = [F:PTDB]
    Gosub CHARG_LIG_RCP
  Next
Endif
#---
Return

#------------------------------------------------------#
# Chargement de la ligne à partir du picking réception #
#------------------------------------------------------#
$CHARG_LIG_RCP
[M:PPI3]WTYPORI  (NOL)=2
[M:PPI3]WNUMORI  (NOL)=[F:PTD]PTHNUM
[M:PPI3]WLINORI  (NOL)=[F:PTD]PTDLIN
# Issue 82703 - 2012-10-04 by SR
[M:PPI3]WSEQORI  (NOL)=0
[M:PPI3]ITMREF   (NOL)=[F:PTD]ITMREF
[M:PPI3]QTYUOM   (NOL)=[F:PTD]QTYPUU
[M:PPI3]UOM      (NOL)=[F:PTD]PUU
[M:PPI3]AMTNOTLIN(NOL)=[F:PTD]LINAMT
[M:PPI3]CUR      (NOL)=[F:PTD]NETCUR
[M:PPI3]QTYWEU   (NOL)=[F:PTD]QTYWEU
[M:PPI3]WEU      (NOL)=[M:PIH4]DSPWEU
[M:PPI3]QTYVOU   (NOL)=[F:PTD]QTYVOU
[M:PPI3]VOU      (NOL)=[M:PIH4]DSPVOU
[M:PPI3]PJT      (NOL)=[F:PTD]PJT
[M:PPI3]ITMDES   (NOL)=[F:PTD]ITMDES
[M:PPI3]LINTYP   (NOL)=[F:PTD]LINTYP
[M:PPI3]NBLIG+=1 : status=0 : Call APRES_NBLIG
Return

# Issue 82703 - 2012-10-04 by SR
#------------------------------------#
# Sélection d'une ligne de commande  #
#------------------------------------#
$PICKE_CDE
WNUM=[F:POQ]POHNUM : WLIN=[F:POQ]POPLIN  : WSEQ = [F:POQ]POQSEQ
Read [POQ] POQ0=WNUM;WLIN;WSEQ : If fstat Raz [F:POQ] : Endif
# Issue 89349 - 2013-10-25 by SR : Rapprochement : Si charge saisie, contrôle qu'elle est bien prévue
If [M:PPI3]FCSCOD <> ""
    If  [F:POQ]STCNUM = ""
        GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
        FOK = 0 : GERR = 1 : Return
    Endif
    Filter [F:STCD] Where VCRTYP = 14 & VCRNUM = [F:POQ]POHNUM & VCRLIN = [F:POQ]POPLIN
&                       & VCRSEQ = [F:POQ]POQSEQ & FCSCOD = [M:PPI3]FCSCOD
    # la charge est-elle presente
    Read [F:STCD]STCD0 First
    Filter [F:STCD]
    If fstat :
       GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
       FOK = 0 : GERR = 1 : Return
    Elsif [F:STCD]FCSAMT = 0
       Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
       If WOK=1 : FOK = 0 : Return : Endif
    Endif
    # Y-a-t-il déjà un enregistrement pour même charge/même pièce d'origine ?
   Filter [F:STCR] Where TYPORI = 1 &  NUMORI = [F:POQ]POHNUM & LINORI = [F:POQ]POPLIN
&                   & SEQORI = [F:POQ]POQSEQ  & FCSCOD = [M:PPI3]FCSCOD
   Look [F:STCR]STCR0 First
   Filter [F:STCR]
    If !fstat
      WMESS = func AFNC.MES2(mess(467,194,1),[M:PPI3]FCSCOD,[F:POQ]POHNUM+"/"+num$([F:POQ]POPLIN)+"/"+num$([F:POQ]POQSEQ))
      Call OUINON(WMESS,WOK) From GESECRAN # La charge $1$ du document $2$  a déjà fait l’objet d’une facture complémentaire
      If WOK=1 : FOK = 0 : Return : Endif
    Endif
 Endif
 # End issue 89349
Read [POP] POP0=WNUM;WLIN      : If fstat Raz [F:POP] : Endif
Read [POH] POH0=[F:POQ]POHNUM  : If fstat Raz [F:POH] : Endif
Read [FCY] FCY0=[F:POQ]PRHFCY  : If fstat Raz [F:FCY] : Endif
Raz [F:PIH],[F:PTD]
If [F:POH]POHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPOQ",WNUM-num$(WLIN)-num$(WSEQ)) From GLOCK
Endif
Gosub TEST_MAXLIN
If mkstat  FOK=0 : Return : Endif
# Issue 108852 - 2015-06-18 by SR : Inutile si pièce d'origine = Commande
# Issue 97613 - 2014-09-09 by SR
#Raz WOK
#WTYP = 1
#WITMREF = [F:PID]ITMREF
#Call CONTROL_VALID(WITMREF,WTYP,WNUM,WLIN,WSEQ,WOK) From SUBPIHD
#If WOK  FOK=0 : Return : Endif
# End issue 97613
# End issue 108852
#----- Blocage logique de la commande -----#
SYMBOL2="POH"+[F:POQ]POHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PORDER"-[F:POQ]POHNUM-mess(10,100,1) : GERR=1 : FOK=0 : Return
Endif
Gosub CHARG_LIG_CDE
#-----
Return

#------------------------------------------------------#
# Chargement de la ligne à partir du picking commande #
#------------------------------------------------------#
$CHARG_LIG_CDE
[M:PPI3]WTYPORI  (NOL)=1
[M:PPI3]WNUMORI  (NOL)=[F:POQ]POHNUM
[M:PPI3]WLINORI  (NOL)=[F:POQ]POPLIN
[M:PPI3]WSEQORI  (NOL)=[F:POQ]POQSEQ
[M:PPI3]ITMREF   (NOL)=[F:POQ]ITMREF
[M:PPI3]QTYUOM   (NOL)=[F:POQ]QTYUOM
[M:PPI3]UOM      (NOL)=[F:POQ]UOM
[M:PPI3]QTYWEU   (NOL)=[F:POQ]QTYWEU
[M:PPI3]WEU      (NOL)=[M:PIH4]DSPWEU
[M:PPI3]QTYVOU   (NOL)=[F:POQ]QTYVOU
[M:PPI3]VOU      (NOL)=[M:PIH4]DSPVOU
[M:PPI3]AMTNOTLIN(NOL)=[F:POQ]LINAMT
[M:PPI3]CUR      (NOL)=[F:POH]CUR
[M:PPI3]PJT      (NOL)=[F:POP]PJT
[M:PPI3]ITMDES   (NOL)=[F:POP]ITMDES
[M:PPI3]LINTYP   (NOL)=[F:POQ]POHTYP
[M:PPI3]NBLIG+=1 : status=0 : Call APRES_NBLIG
Return


# Issue 110325 - 2016-01-08 by SR : FCC sur expé
#------------------------------------#
# Sélection d'une ligne d'expédition #
#------------------------------------#
$PICKE_SHIP
WNUM=[F:SHD]SHIPNUM : WLIN=[F:SHD]SHIPLIN
Read [SHD] SHD0=WNUM;WLIN : If fstat Raz [F:SHD] : Endif
If [M:PPI3]FCSCOD <> ""
    If  [F:SHD]STCNUM = ""
        GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
        FOK = 0 : GERR = 1 : Return
    Endif
    Filter [F:STCD] Where VCRTYP = 38 & VCRNUM = [F:SHD]SHIPNUM & VCRLIN = [F:SHD]SHIPLIN
&                       & VCRSEQ = 0 & FCSCOD = [M:PPI3]FCSCOD
    # la charge est-elle presente
    Read [F:STCD]STCD0 First
    Filter [F:STCD]
    If fstat :
       GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
       FOK = 0 : GERR = 1 : Return
    Elsif [F:STCD]FCSAMT = 0
       Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
       If WOK=1 : FOK = 0 : Return : Endif
    Endif
    # Y-a-t-il déjà un enregistrement pour même charge/même pièce d'origine ?
   Filter [F:STCR] Where TYPORI = 6 &  NUMORI = [F:SHD]SHIPNUM & LINORI = [F:SHD]SHIPLIN
&                   & SEQORI = 0  & FCSCOD = [M:PPI3]FCSCOD
   Look [F:STCR]STCR0 First
   Filter [F:STCR]
    If !fstat
      WMESS = func AFNC.MES2(mess(467,194,1),[M:PPI3]FCSCOD,[F:SHD]SHIPNUM+"/"+num$([F:SHD]SHIPLIN))
      Call OUINON(WMESS,WOK) From GESECRAN # La charge $1$ du document $2$  a déjà fait l’objet d’une facture complémentaire
      If WOK=1 : FOK = 0 : Return : Endif
    Endif
 Endif
Read [SHH] SHH0=WNUM                                      : If fstat Raz [F:SHH] : Endif
Read [POP] POP0=[F:SHD]POHNUM;[F:SHD]POPLIN               : If fstat Raz [F:POP] : Endif
Read [POQ] POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ : If fstat Raz [F:POQ] : Endif
Read [POH] POH0=[F:SHD]POHNUM                             : If fstat Raz [F:POH] : Endif
Read [FCY] FCY0=[F:POQ]PRHFCY                             : If fstat Raz [F:FCY] : Endif
Raz [F:PIH],[F:PTD]
If [F:SHH]SHIPNUM="" & [F:FCY]FCY=""
  Call RSTA("XSHD",WNUM-num$(WLIN)) From GLOCK
Endif
Gosub TEST_MAXLIN
If mkstat  FOK=0 : Return : Endif
#----- Blocage logique de l'expédition -----#
SYMBOL2="SHH"+[F:SHD]SHIPNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$SHIPMENT"-[F:SHD]SHIPNUM-mess(10,100,1) : GERR=1 : FOK=0 : Return
Endif
Gosub CHARG_LIG_SHIP
#-----
Return

#-------------------------------------------------------#
# Chargement de la ligne à partir du picking expédition #
#-------------------------------------------------------#
$CHARG_LIG_SHIP
[M:PPI3]WTYPORI  (NOL)=6
[M:PPI3]WNUMORI  (NOL)=[F:SHD]SHIPNUM
[M:PPI3]WLINORI  (NOL)=[F:SHD]SHIPLIN
[M:PPI3]WSEQORI  (NOL)=0
[M:PPI3]ITMREF   (NOL)=[F:SHD]ITMREF
[M:PPI3]QTYUOM   (NOL)=[F:SHD]SHIQTY
[M:PPI3]UOM      (NOL)=[F:SHD]UOM
[M:PPI3]QTYWEU   (NOL)=[F:SHD]QTYWEU
[M:PPI3]WEU      (NOL)=[M:PIH4]DSPWEU
[M:PPI3]QTYVOU   (NOL)=[F:SHD]QTYVOU
[M:PPI3]VOU      (NOL)=[M:PIH4]DSPVOU
[M:PPI3]AMTNOTLIN(NOL)=[F:SHD]LINAMT
[M:PPI3]CUR      (NOL)=[F:SHD]NETCUR
[M:PPI3]PJT      (NOL)=[F:POP]PJT
[M:PPI3]ITMDES   (NOL)=[F:POP]ITMDES
[M:PPI3]LINTYP   (NOL)=[F:POQ]POHTYP
[M:PPI3]NBLIG+=1 : status=0 : Call APRES_NBLIG
Return
# End issue 110325

#------------------------------------#
# Déselection d'une ligne de facture #
#------------------------------------#
$DEPICK_FAC
WNUM=[F:PID]NUM : WLIN=[F:PID]PIDLIN
Read [PID] PID0=WNUM;WLIN  : If fstat Raz [F:PID] : Endif
Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
If [F:PIH]NUM="" & [F:PID]NUM=""
  Call RSTA("XPID",WNUM-num$(WLIN)) From GLOCK
  FOK=0 : Return
Endif
#--- Issue 90972 by TS
#If [F:PID]LINTYP=2
#  Raz WOK
#  For [PID] PID0 Where NUM    =WNUM
#&                    & PIDLIN>=WLIN
#    If [F:PID]LINTYP<3 & WOK  Break : Endif
#    If [F:PID]LINTYP=2   WOK=1      : Endif
#    Gosub RECHSUP_LIG_FAC : # Recherche et suppression ligne
#  Next
#----- Lignes classiques (autres que sous-traitance) -----#
#Else
#  Gosub RECHSUP_LIG_FAC   : # Recherche et suppression ligne
#Endif
Gosub RECHSUP_LIG_FAC
# Sous-traitance : traitement des services et matières
If [F:PID]LINTYP=2
  For [PIDB] PID0 Where NUM=WNUM & PIDLIN>WLIN
    If [F:PIDB]LINTYP<3 : Break : Endif
    [F:PID] = [F:PIDB]
    Gosub RECHSUP_LIG_FAC
  Next
Endif
#---
Return

#---------------------------------------------------#
# Recherche et suppression ligne facture "dépickée" #
#---------------------------------------------------#
$RECHSUP_LIG_FAC
Raz J
While J<[M:PPI3]NBLIG
  K=find([F:PID]NUM,[M:PPI3]WNUMORI(J..[M:PPI3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PPI3]NBLIG
  Elsif [M:PPI3]WTYPORI(I)=4 & [M:PPI3]WLINORI(I)=[F:PID]PIDLIN
    nolign=I+1 : status=65
    Call AVANT_NBLIG
    Dela I,1,[M:PPI3]NBLIG-1 [M:PPI3]NBLIG : [M:PPI3]NBLIG-=1
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#--------------------------------------#
# Déselection d'une ligne de réception #
#--------------------------------------#
$DEPICK_RCP
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
If [F:PTH]PTHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
  FOK=0 : Return
Endif
#--- Issue 90972 by TS
#If [F:PTD]LINTYP=2
#  Raz WOK
#  For [PTD] PTD0 Where PTHNUM =WNUM
#&                    & PTDLIN>=WLIN
#    If [F:PTD]LINTYP<3 & WOK  Break : Endif
#    If [F:PTD]LINTYP=2   WOK=1      : Endif
#    Gosub RECHSUP_LIG_RCP : # Recherche et suppression ligne
#  Next
#Else
#  Gosub RECHSUP_LIG_RCP   : # Recherche et suppression ligne
#Endif
Gosub RECHSUP_LIG_RCP
# Sous-traitance : traitement des services et matières
If [F:PTD]LINTYP=2
  For [PTDB] PTD0 Where PTHNUM=WNUM & PTDLIN>WLIN
    If [F:PTDB]LINTYP<3 : Break : Endif
    [F:PTD] = [F:PTDB]
    Gosub RECHSUP_LIG_RCP
  Next
Endif
#---
Return

#-----------------------------------------------------#
# Recherche et suppression ligne réception "dépickée" #
#-----------------------------------------------------#
$RECHSUP_LIG_RCP
Raz J
While J<[M:PPI3]NBLIG
  K=find([F:PTD]PTHNUM,[M:PPI3]WNUMORI(J..[M:PPI3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PPI3]NBLIG
  Elsif [M:PPI3]WTYPORI(I)=2 & [M:PPI3]WLINORI(I)=[F:PTD]PTDLIN
    nolign=I+1 : status=65
    Call AVANT_NBLIG
    Dela I,1,[M:PPI3]NBLIG-1 [M:PPI3]NBLIG : [M:PPI3]NBLIG-=1
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

# Issue 82703 - 2012-10-04 by SR
#--------------------------------------#
# Déselection d'une ligne de commande #
#--------------------------------------#
$DEPICK_CDE
WNUM=[F:POQ]POHNUM : WLIN=[F:POQ]POPLIN : WSEQ = [F:POQ]POQSEQ
Read [POQ] POQ0=WNUM;WLIN;WSEQ : If fstat Raz [F:POQ] : Endif
Read [POP] POP0=WNUM;WLIN      : If fstat Raz [F:POP] : Endif
Read [POH] POH0=[F:POQ]POHNUM  : If fstat Raz [F:POH] : Endif
Read [FCY] FCY0=[F:POQ]PRHFCY  : If fstat Raz [F:FCY] : Endif
If [F:POH]POHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPOQ",WNUM-num$(WLIN)-num$(WSEQ)) From GLOCK
  FOK=0 : Return
Endif
Gosub RECHSUP_LIG_CDE   : # Recherche et suppression ligne
#-----
Return

#-----------------------------------------------------#
# Recherche et suppression ligne réception "dépickée" #
#-----------------------------------------------------#
$RECHSUP_LIG_CDE
Raz J
While J<[M:PPI3]NBLIG
  K=find([F:POQ]POHNUM,[M:PPI3]WNUMORI(J..[M:PPI3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PPI3]NBLIG
  Elsif [M:PPI3]WTYPORI(I)=1 & [M:PPI3]WLINORI(I)=[F:POQ]POPLIN
    nolign=I+1 : status=65
    Call AVANT_NBLIG
    Dela I,1,[M:PPI3]NBLIG-1 [M:PPI3]NBLIG : [M:PPI3]NBLIG-=1
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return


# Issue 110325 - 2016-01-08 by SR : FCC sur expé
#--------------------------------------#
# Déselection d'une ligne d'expédition #
#--------------------------------------#
$DEPICK_SHIP
WNUM=[F:SHD]SHIPNUM : WLIN=[F:SHD]SHIPLIN : WSEQ = 0
Read [SHD] SHD0=WNUM;WLIN : If fstat Raz [F:SHD] : Endif
Read [SHH] SHH0=[F:SHD]SHIPNUM  : If fstat Raz [F:SHH] : Endif
If [F:SHH]SHIPNUM=""
  Call RSTA("XSHD",WNUM-num$(WLIN)) From GLOCK
  FOK=0 : Return
Endif
Gosub RECHSUP_LIG_SHIP  : # Recherche et suppression ligne
#-----
Return

#------------------------------------------------------#
# Recherche et suppression ligne expédition "dépickée" #
#------------------------------------------------------#
$RECHSUP_LIG_SHIP
Raz J
While J<[M:PPI3]NBLIG
  K=find([F:SHD]SHIPNUM,[M:PPI3]WNUMORI(J..[M:PPI3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PPI3]NBLIG
  Elsif [M:PPI3]WTYPORI(I)=6 & [M:PPI3]WLINORI(I)=[F:SHD]SHIPLIN
    nolign=I+1 : status=65
    Call AVANT_NBLIG
    Dela I,1,[M:PPI3]NBLIG-1 [M:PPI3]NBLIG : [M:PPI3]NBLIG-=1
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return
# End issue 110325

#----------------------------------------------#
# Test si tableau des lignes arrivé au maximum #
#----------------------------------------------#
$TEST_MAXLIN
GBIDI2=2 : Gosub TRT_MAXLIN
Return
#----- Prévoir 3 lignes de plus pour la sous-traitance -----#
$TEST_MAXLIN_STT
GBIDI2=5 : Gosub TRT_MAXLIN
Return
#-----
$TRT_MAXLIN
Raz mkstat
If [M:PPI3]NBLIG>dim([M:PPI3]WTYPORI)-GBIDI2
  GMESSAGE=mess(26,100,1) : GERR=1
  mkstat=1 : Return
Endif
NOL=[M:PPI3]NBLIG : nolign=NOL+1
Return

#------------------------------------------------------------#
#  Déblocage logique d'une ligne du tableau issu du picking  #
# ---------------------------------------------------------- #
# NOL doit contenir l'indice de la ligne en cours (nolign-1) #
#------------------------------------------------------------#
$DEVERROU_LIG
WTYP=[M:PPI3]WTYPORI(NOL)
WNUM=[M:PPI3]WNUMORI(NOL)
#----- Test si présence du même numéro dans une autre ligne -----#
Raz I
While I<[M:PPI3]NBLIG
  J=find(WNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
  If J=0
    I=[M:PPI3]NBLIG
  Elsif [M:PPI3]WTYPORI(I+(J-1))=WTYP & I+(J-1)<>NOL
    I=[M:PPI3]NBLIG
  Else
    I+=J : J=0
  Endif
Wend
#-----
If J=0  Gosub DEVERROU_DOCUMENT : Endif
Return

#----------------------------------------------------------------------------------#
# Déblocage logique de toutes les lignes présentes dans le tableau issu du picking #
#----------------------------------------------------------------------------------#
$DEVERROU_GENERAL
If [M:PPI3]NBLIG<1  Return : Endif
Sorta [M:PPI3]NBLIG [M:PPI3]NBLIG Order By [M:PPI3]WTYPORI(indice),
&                                          [M:PPI3]WNUMORI(indice)
Raz WNUM, WTYP
For K=0 To [M:PPI3]NBLIG-1
  If WTYP<>[M:PPI3]WTYPORI(K) | WNUM<>[M:PPI3]WNUMORI(K)
    WTYP=[M:PPI3]WTYPORI(K)
    WNUM=[M:PPI3]WNUMORI(K)
    Gosub DEVERROU_DOCUMENT
  Endif
Next K
Return

#---------------------------------------------------------------#
# Déblocage logique d'un document (/commande/réception/facture) #
#    pour autant qu'il ne soit pas déjà dans une ligne          #
#    de la facture complémentaire !                             #
#---------------------------------------------------------------#
$DEVERROU_DOCUMENT
#----- Test si présence du même numéro dans une ligne de la facture -----#
If [M:PIH3]NBLIG>0
  Raz I
  While I<[M:PIH3]NBLIG
    J=find(WNUM,[M:PIH3]NUMORI(I..[M:PIH3]NBLIG-1))
    If J=0
      I=[M:PIH3]NBLIG
    Elsif [M:PIH3]TYPORI(I+(J-1))=WTYP & [M:PIH3]CREFLG(I+(J-1))=0
      I=[M:PIH3]NBLIG
    Else
      I+=J : J=0
    Endif
  Wend
Endif
#----- Déblocage loqique en fonction du type de la ligne -----#
# Issue 82703 - 2012-10-04 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
If J=0
  Case WTYP
    When 1 : SYMBOL2="POH"+WNUM
    When 2 : SYMBOL2="PTH"+WNUM
    When 4 : SYMBOL2="PIH"+WNUM
    When 6 : SYMBOL2="SHH"+WNUM
  Endcase
  Unlock=SYMBOL2
Endif
Return

#--------------#
# Tout inclure #
#--------------#
$TOUT_INCLURE
# Issue 82703 - 2012-10-04 by SR ajouter les commandes
# Issue 110325 - 2016-01-08 by SR : ajouter les expéditions
# Issue 115268 - 2016-03-14 by SR : If some lines picked before, CRITERE is empty
If CRITERE = ""  : CRITERE  = "1=1" : Endif
If FILSUITE = "" : FILSUITE = "1=1" : Endif
Case currbox
  When GBOXPI3 : #----- Picking des factures -----#
    Gosub DEB_PIC
    For  [PID_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      Raz J
      #----- Test si la ligne est déjà présente dans le tableau -----#
      If [M:PPI3]NBLIG>0
        Raz I
        While I<[M:PPI3]NBLIG
          J=find([F:PID]NUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
          If J=0
            I=[M:PPI3]NBLIG
          Elsif [M:PPI3]WTYPORI(I+(J-1))=4 & [M:PPI3]WLINORI(I+(J-1))=[F:PID]PIDLIN
            I=[M:PPI3]NBLIG
          Else
            I+=J : J=0
          Endif
        Wend
      Endif
      #-----
      If J=0
        Gosub CRE_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
    WPICK=2 : Gosub ACTUALIS_MARQUAGE
  When GBOXPT3 : #----- Picking des réceptions -----#
    Gosub DEB_PIC
    For  [PTD_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      Raz J
      #----- Test si la ligne est déjà présente dans le tableau -----#
      If [M:PPI3]NBLIG>0
        Raz I
        While I<[M:PPI3]NBLIG
          J=find([F:PTD]PTHNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
          If J=0
            I=[M:PPI3]NBLIG
          Elsif [M:PPI3]WTYPORI(I+(J-1))=2 & [M:PPI3]WLINORI(I+(J-1))=[F:PTD]PTDLIN
            I=[M:PPI3]NBLIG
          Else
            I+=J : J=0
          Endif
        Wend
      Endif
      #-----
      If J=0
        Gosub CRE_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
    WPICK=2 : Gosub ACTUALIS_MARQUAGE
  When GBOXPO5 : #----- Picking des commandes -----#
    Gosub DEB_PIC
    For  [POQ_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      Raz J
      #----- Test si la ligne est déjà présente dans le tableau -----#
      If [M:PPI3]NBLIG>0
        Raz I
        While I<[M:PPI3]NBLIG
          J=find([F:POQ]POHNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
          If J=0
            I=[M:PPI3]NBLIG
          Elsif [M:PPI3]WLINORI(I+(J-1))=[F:POQ]POPLIN &[M:PPI3]WSEQORI(I+(J-1))=[F:POQ]POQSEQ
            I=[M:PPI3]NBLIG
          Else
            I+=J : J=0
          Endif
        Wend
      Endif
      #-----
      If J=0
        Gosub CRE_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
    WPICK=2 : Gosub ACTUALIS_MARQUAGE
 When GBOXSHIP3 : #----- Picking des expéditions -----#
    Gosub DEB_PIC
    For  [SHD_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      Raz J
      #----- Test si la ligne est déjà présente dans le tableau -----#
      If [M:PPI3]NBLIG>0
        Raz I
        While I<[M:PPI3]NBLIG
          J=find([F:SHD]SHIPNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
          If J=0
            I=[M:PPI3]NBLIG
          Elsif [M:PPI3]WLINORI(I+(J-1))=[F:SHD]SHIPLIN
            I=[M:PPI3]NBLIG
          Else
            I+=J : J=0
          Endif
        Wend
      Endif
      #-----
      If J=0
        Gosub CRE_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
    WPICK=2 : Gosub ACTUALIS_MARQUAGE
Endcase
Return

#--------------#
# Tout exclure #
#--------------#
$TOUT_EXCLURE
# Issue 82703 - 2012-10-04 by SR ajouter les commandes
# Issue 110325 - 2016-01-08 by SR : ajouter les expéditions
# Issue 115268 - 2016-03-14 by SR : If some lines picked before, CRITERE is empty
If CRITERE = ""  : CRITERE  = "1=1" : Endif
If FILSUITE = "" : FILSUITE = "1=1" : Endif
Case currbox
  When GBOXPI3 : # Picking des factures
    Gosub DEB_PIC
    For  [PID_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      #----- Test si la ligne est présente dans le tableau -----#
      Raz I, J
      While I<[M:PPI3]NBLIG
        J=find([F:PID]NUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
        If J=0
          I=[M:PPI3]NBLIG
        Elsif [M:PPI3]WTYPORI(I+(J-1))=4 & [M:PPI3]WLINORI(I+(J-1))=[F:PID]PIDLIN
          I=[M:PPI3]NBLIG
        Else
          I+=J : J=0
        Endif
      Wend
      #-----
      If J<>0
        Gosub ANU_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
  When GBOXPT3 : # Picking des réceptions
    Gosub DEB_PIC
    For  [PTD_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      #----- Test si la ligne est présente dans le tableau -----#
      Raz I, J
      While I<[M:PPI3]NBLIG
        J=find([F:PTD]PTHNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
        If J=0
          I=[M:PPI3]NBLIG
        Elsif [M:PPI3]WTYPORI(I+(J-1))=2 & [M:PPI3]WLINORI(I+(J-1))=[F:PTD]PTDLIN
          I=[M:PPI3]NBLIG
        Else
          I+=J : J=0
        Endif
      Wend
      #-----
      If J<>0
        Gosub ANU_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
  When GBOXPO5 : # Picking des commandes
    Gosub DEB_PIC
    For  [POQ_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      #----- Test si la ligne est présente dans le tableau -----#
      Raz I, J
      While I<[M:PPI3]NBLIG
        J=find([F:POQ]POHNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
        If J=0
          I=[M:PPI3]NBLIG
        Elsif [M:PPI3]WLINORI(I+(J-1))=[F:POQ]POPLIN & [M:PPI3]WSEQORI(I+(J-1))=[F:POQ]POQSEQ
          I=[M:PPI3]NBLIG
        Else
          I+=J : J=0
        Endif
      Wend
      #-----
      If J<>0
        Gosub ANU_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
 When GBOXSHIP3 : # Picking des expéditions
    Gosub DEB_PIC
    For  [SHD_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
      #----- Test si la ligne est présente dans le tableau -----#
      Raz I, J
      While I<[M:PPI3]NBLIG
        J=find([F:SHD]SHIPNUM,[M:PPI3]WNUMORI(I..[M:PPI3]NBLIG-1))
        If J=0
          I=[M:PPI3]NBLIG
        Elsif [M:PPI3]WLINORI(I+(J-1))=[F:SHD]SHIPLIN
          I=[M:PPI3]NBLIG
        Else
          I+=J : J=0
        Endif
      Wend
      #-----
      If J<>0
        Gosub ANU_PIC : If !FOK  Break : Endif
      Endif
    Next
    Gosub FIN_PIC
Endcase
Return


########################################################################
#             Actions sur champ de l'écran PPICINV3 [PPI3]             #
########################################################################

Subprog AVANT_NBLIG
#----- Si suppression d'une ligne nouvelle, déblocage logique et suppress.texte -----#
If status=65 | status=68 | status=83
  Local Shortint NOL, WPICK, WTYP
  Local Integer  I, J, K, WTYP
  Local Char     WNUM(GLONVCR), SYMBOL2(30)
  NOL=nolign-1    : Gosub DEVERROU_LIG
  WPICK=1 : I=NOL : Gosub MARQUAGE_LIGNE
  # Issue 89349 - 2013-11-05 by SR : Rapprochement
  I = [M:PPI3]NBLIG-1
  Gosub FCSCODMGT
Endif
End

Subprog APRES_NBLIG
Local Shortint NOL : NOL=nolign-1
Local Shortint WPICK, I
If status=65 | status=68 | status=83
  #----- Suppression des lignes liées au composé (produit fini) -----#
  If NOL<[M:PPI3]NBLIG-1 & [M:PPI3]LINTYP(NOL+1)>2
    Local Shortint I : I=NOL+1
    While [M:PPI3]LINTYP(I)>2
      nolign=I+1 : Call AVANT_NBLIG From SUBPPI3
      Dela I,1,[M:PPI3]NBLIG-1 [M:PPI3]NBLIG : [M:PPI3]NBLIG-=1
    Wend
    Affzo [PPI3]15
    nolign=NOL+1
  Endif
Else
  # Issue 89349 - 2013-11-05 by SR : Rapprochement
  I = [M:PPI3]NBLIG
  Gosub FCSCODMGT
Endif

#WPICK=2 : I=NOL : Gosub MARQUAGE_LIGNE
End

# Issue 89349 - 2013-11-05 by SR : Rapprochement
# charge modifiable que si pas de ligne
$FCSCODMGT
If [M:PPI3]CSTMAJ = 1
   If I <> 0
       Diszo [M:PPI3]FCSCOD
   Else
       Actzo [M:PPI3]FCSCOD
   Endif
   Affzo [M:PPI3]FCSCOD
Endif
Return

######################################################################################
# Issue 89349 - 2013-10-25 by SR : Rapprochement : Gestion de FCSCOD selon CSTMAJ
######################################################################################
## Etiquette ajoutée par le superviseur (écran PPICINV3) 25.10.2013 08:22:03 (SR)
######################################################################################
Subprog AM_CSTMAJ(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
   Raz [M:PPI3]FCSCOD
   Grizo [M:PPI3]FCSCOD
Elsif [M:PPI3]NBLIG = 0
   Actzo [M:PPI3]FCSCOD
Endif
Affzo [M:PPI3]FCSCOD
End

