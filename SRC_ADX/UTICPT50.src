#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT50                                                  Module CPT   #
#            Update FCYBAL / BAL                                         #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTICPT50(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT50(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT50 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CPT])  =0  Local File =DOSSIER+".GLED"   [LED] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [LED]
For [LED] Where FCYBAL=2 & BAL<>2
 Readlock [LED] Curr    
 If !fstat
  [F:LED]BAL = 2
  Rewrite [F:LED]
  If !fstat : COMPTEUR += 1 : Endif
 Endif
Next
Commit

Close Local File [LED]

Call ECR_TRACE("UTICPT50 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","GLED","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT50(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If filinfo(filpath("FIL","GLED","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT50(APPLI)
End

