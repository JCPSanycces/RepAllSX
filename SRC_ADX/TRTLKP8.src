#<AdxTL>@(#)10.0.0.0 $Revision$
########################################################################################################################
#   Traitement de gestion de la consultation des demandes trouvées       Module CRM                  8 Décembre 2003   #
########################################################################################################################
########################################################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "FIR"          : Gosub PREMIER
 When "PRE"          : Gosub PRECEDENT
 When "SUI"          : Gosub SUIVANT
 When "LAS"          : Gosub DERNIER
 When Default
Endcase
Return

########################################################################################################################
$OUVRE
Global Char GSZSOLKEY
Global Integer GILASTNOL
Global Integer GIHBDISP
Global Integer GIFIRSOL
Global Integer GINBFSOL

  GSZSOLKEY = ""
  GILASTNOL = 0
  GIHBDISP = 0
  GIFIRSOL = 0
  GINBFSOL = 0
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:SOR]) : Local File SOLRESULT [SOR] : Endif
  If !clalev([F:HD1]) : Local File HD1CLOB [HD1] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
Return

########################################################################################################################
$DEFBOUT
Return

########################################################################################################################
$SETBOUT
  ETABOU(GSPE1) = 1
Return

########################################################################################################################
$OUVRE_BOITE
Return

########################################################################################################################
$DEBUT
  Call TEMPON("R") From GESECRAN
  Gosub SEARCHSOL
  Call CLEANSOR From TRTSRE4
  Call LOADRES(0)
  GIHBDISP = 1
  Call TEMPOFF From GESECRAN
Return

########################################################################################################################
$PREMIER
  Call LOADRES(1)
Return

########################################################################################################################
$PRECEDENT
  Call LOADRES(2)
Return

########################################################################################################################
$SUIVANT
  Call LOADRES(3)
Return

########################################################################################################################
$DERNIER
  Call LOADRES(4)
Return

########################################################################################################################
$AV_CHOIX
Return

########################################################################################################################
AP_CHOIX
Return

########################################################################################################################
$AVANT_BOUTON
Return

########################################################################################################################
$FINSAI
  If GIHBDISP Then
    #Vide la table des résultats si elle a été remplie
    If !clalev([F:SOR]) : Local File SOLRESULT [SOR] : Endif
    Trbegin [SOR]
    Delete [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SRE"
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    #Nettoie l'écran avant de partir.
    Raz [M:LKP8]
  Endif
  Kill GSZSOLKEY
  Kill GILASTNOL
  Kill GIHBDISP
  Kill GIFIRSOL
  Kill GINBFSOL
Return

########################################################################################################################
$FIN
Return

########################################################################################################################
$ABANDON
Return

########################################################################################################################
$APRES_MODIF
Return

########################################################################################################################
$BOUTON
Return

########################################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#######################################################################################################
#
#  LOADRES     : Charge les demandes trouvées dans la fenêtre de résultat.
#  SEARCHSOL   : Exécute la recherche des demandes selon les critères saisis.
#  CHKFILTER   : Vérifie si une demande trouvée par mot-clé est compatible avec les filtres.
#  DO_STRSEA   : Effectue une recherche au sein des champs texte des demandes
#
########################################################################################################
Subprog LOADRES(IWHATTODO)
Value Integer IWHATTODO

Local Integer ITER
Local Integer ITER2
Local Integer IZ
Local Integer IX
Local Integer IMAXREC
Local Integer ISRE4NOL

  ISRE4NOL = 0
  ITER = 0
  ITER2 = 0
  IZ = 0
  IX = 0
  IMAXREC = 0
  #0 : Premier chargement
  #1 : Premier
  #2 : Précédent
  #3 : Suivant
  #4 : Dernier
  Case IWHATTODO
    When 1
      IX = 0
      GIFIRSOL = 0
      If GINBFSOL < dim([M:LKP8]NUM) Then
        End
      Endif
    When 2
      If GINBFSOL < dim([M:LKP8]NUM) Then
        End
      Endif
      IMAXREC = GIFIRSOL - dim([M:LKP8]NUM)
      If IMAXREC <= 0 Then
        IX = 0
      Else
        IX = GIFIRSOL - dim([M:LKP8]NUM)
      Endif
    When 3
      If GINBFSOL < dim([M:LKP8]NUM) Then
        End
      Endif
      IMAXREC = GIFIRSOL + dim([M:LKP8]NUM) + dim([M:LKP8]NUM)-1
      If GINBFSOL < IMAXREC Then
        IX = GINBFSOL - dim([M:LKP8]NUM)
      Else
        IX = GIFIRSOL + dim([M:LKP8]NUM)
      Endif
    When 4
      If GINBFSOL < dim([M:LKP8]NUM) Then
        End
      Endif
      IX = GINBFSOL - dim([M:LKP8]NUM)
  Endcase
  Raz [M:LKP8]
  GIFIRSOL = IX
  If GIHBDISP Then
    Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SRE" and [F:SOR]NUM >= GIFIRSOL
  Else
    Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SRE"
  Endif
  For [SOR]SOR2
    If GIHBDISP Then
      If IZ > dim([M:LKP8]NUM)-1 Then
        Break
      Endif
      If [F:SOR]SOLNUM <> "" Then
        [M:LKP8]NUM(IZ) = [F:SOR]SOLNUM
        [M:LKP8]CLSNUM(IZ) = [F:SOR]NUM
        Read [SRE]SRE0=[M:LKP8]NUM(IZ)
        If fstat Then
          [M:LKP8]DAT(IZ) = [00/00/00]
          [M:LKP8]AUS(IZ) = ""
        Else
          [M:LKP8]DAT(IZ) = [F:SRE]CREDAT
          [M:LKP8]AUS(IZ) = [F:SRE]CREUSR
        Endif
        If IZ = 0 Then
          ISRE4NOL = IZ
          Gosub SETNEWSOL From SUBLKP8
        Endif
        IZ +=1
      Endif
    Else
      If IZ <= dim([M:LKP8]NUM)-1 Then
        If [F:SOR]SOLNUM <> "" Then
          [M:LKP8]NUM(IZ) = [F:SOR]SOLNUM
          [M:LKP8]CLSNUM(IZ) = [F:SOR]NUM
          Read [SRE]SRE0=[M:LKP8]NUM(IZ)
          If fstat Then
            [M:LKP8]DAT(IZ) = [00/00/00]
            [M:LKP8]AUS(IZ) = ""
          Else
            [M:LKP8]DAT(IZ) = [F:SRE]CREDAT
            [M:LKP8]AUS(IZ) = [F:SRE]CREUSR
          Endif
          If IZ = 0 Then
            ISRE4NOL = IZ
            Gosub SETNEWSOL From SUBLKP8
          Endif
          IZ +=1
        Endif
      Endif
      GINBFSOL += 1
    Endif
  Next
  Filter [SOR]
  GSZSOLKEY = [M:LKP8]NUM(0)
  [M:LKP8]NBSOL = IZ
  Affzo [M:LKP8]
End

###############################################################################################
$SEARCHSOL
Local Integer INBSRE
Local Integer IDESSEA
Local Integer ICLOBSEA
Local Integer I
Local Integer INBF
Local Char SZLIB(250)

  I = 0
  INBF = 0
  SZLIB = ""
  INBSRE = 0
  If [M:LKP7]TTRDESFLG = 2 Then
    IDESSEA = 1
  Else
    IDESSEA = 0
  Endif
  If [M:LKP7]SREHD1FLG = 2 Then
    ICLOBSEA = 1
  Else
    ICLOBSEA = 0
  Endif
  If [M:LKP7]TTRDES = "" Then
    Call DO_QURSEA([M:LKP7]QURNUM, INBSRE)
  Else
    SZLIB = [M:LKP7]TTRDES
    Call DO_STRSEA(IDESSEA, ICLOBSEA, SZLIB, INBSRE)
    If [M:LKP7]QURNUM <> "" Then
      #Opérateur OU
      If [M:LKP7]SEAOPD = 2 Then
        Call DO_QURSEA([M:LKP7]QURNUM, INBSRE)
      Endif
      #Opérateur OU PAS
      If [M:LKP7]SEAOPD = 4 Then
        Call DO_NOTQURSEA([M:LKP7]QURNUM, INBSRE)
      Endif
    Endif
  Endif
  If GERR Then
    Return
  Endif
  INBF = 0
  Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SRE"
  For [SOR] SOR2
    INBF += 1
    Break
  Next
  Filter [SOR]
  If GERR Then
    FIN = 1
  Else
    If !INBF Then
      GMESSAGE = mess(904,182,1) #Aucune demande de service ne correspond aux critères de recherche.
      GERR = 2
      FIN = 1
    Endif
  Endif
Return

#####################################################################################
# Intègre un ciblage dans la recherche
#####################################################################################
Subprog DO_QURSEA(SZQURNUM, ISORRECNUM)
Value Char SZQURNUM
Variable Integer ISORRECNUM

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF

  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]KEYTGR > SZCLE Order By [F:QTP]KEYTGR Asc
    For [QTP]
      SZCLE = [F:QTP]KEYTGR
      Read [SOR]SOR3=[F:QTP]KEYTGR;GIDENT;"SRE"
      If fstat Then
        If IPERF = 0 Then
          Trbegin [SOR]
          INTR = 1
        Endif
        Raz [F:SOR]
        [F:SOR]SOLNUM = [F:QTP]KEYTGR
        [F:SOR]NUM = ISORRECNUM
        [F:SOR]SSS = GIDENT
        [F:SOR]TYP = "SRE"
        [F:SOR]CREDAT = date$
        Write [SOR]
        If fstat Then
          GMESSAGE = mess(100,141,1) #Erreur création
          GERR = 1
          INTR = 0
          Rollback
          Break
        Else
          If IPERF >= 478 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
          ISORRECNUM += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [QTP]
    If GERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !GERR Then
      Commit
    Endif
  Endif
End

#####################################################################################
# Effectue une recherche au sein des champs texte des solutions.
#####################################################################################
Subprog DO_STRSEA(IDESSEA, ICLOBSEA, SZLOOKFOR, INBREC)
Value Integer IDESSEA
Value Integer ICLOBSEA
Variable Char SZLOOKFOR
Variable Integer INBREC

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer I
Local Integer ITER
Local Integer ISC
Local Integer ISPACE(35)
Local Char SZUPTTR(80)
Local Char SZUPDES(250)
Local Char SZUPSOL(250)
Local Integer IFOUND
Local Integer IBUFFEMPTY
Local Integer ILNGCLOB
Local Integer INBBYTES
Local Integer IBUFFSIZE

  ILNGCLOB = 0
  INBBYTES = 0
  IBUFFSIZE = 0
  IBUFFEMPTY = 0
  IFOUND = 0
  ITER = 0
  I = 0
  ISC = 0
  SZUPTTR = ""
  SZUPDES = ""
  SZUPSOL = ""
  Raz ISPACE
  # Découpe la chaine en mots indépendants
  SZLOOKFOR = SZLOOKFOR + ' '
  ISPACE(0) = instr(1, SZLOOKFOR, ' ')
  If ISPACE(0) > 0 Then
    I = 1
    While 1
      ISPACE(I) = instr(ISPACE(I-1)+1, SZLOOKFOR, ' ')
      If ISPACE(I) = 0 Then
        Break
      Endif
      I += 1
    Wend
  Else
    End
  Endif

Local Char SZWORD(35)(I)

  For I = 0 To dim(SZWORD)-1
    SZWORD(I) = ""
  Next
  SZWORD(0) = toupper(ctrans(left$(SZLOOKFOR, ISPACE(0)-1)))
  I = 1
  While 1
    If ISPACE(I) <> 0 Then
      SZWORD(I) = toupper(ctrans(mid$(SZLOOKFOR, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1)))
    Else
      Break
    Endif
    I += 1
  Wend
  If ICLOBSEA Then
    Read [ATY]CODTYP="HD1"
    If fstat Then
      ILNGCLOB = 6    
    Else
      ILNGCLOB = [F:ATY]LNGTYP
    Endif
    If ILNGCLOB = 0 Then
      ILNGCLOB = 6    
    Endif
    INBBYTES = 1024*(2^ILNGCLOB)
    IBUFFSIZE = INBBYTES / 200
    IBUFFSIZE += 5

    Local Char SZBUFFER(250)(IBUFFSIZE)
  Endif
  I = 0
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [SRE] Where [F:SRE]SRENUM > SZCLE Order By [F:SRE]SRENUM Asc
    For [SRE]
      SZCLE = [F:SRE]SRENUM
      I = 0
      IFOUND = 0
      If IDESSEA Then
        SZUPTTR = toupper(ctrans([F:SRE]SRETTR))
        SZUPDES = toupper(ctrans([F:SRE]SREDES))
      Endif
      If ICLOBSEA Then
        IBUFFEMPTY = 1
        Read [HD1]HD10=[F:SRE]SRENUM;"SRE"
        If !fstat Then
          Raz SZBUFFER
          Setlob SZBUFFER With [F:HD1]CLOB
          #Vérifie si buffer contient quelque chose
          For ITER = 0 To dim(SZBUFFER)-1
            If SZBUFFER(ITER) <> "" Then
              IBUFFEMPTY = 0
              Break
            Endif
          Next
        Endif
      Endif
      For I = 0 To dim(SZWORD)-1
        If SZWORD(I) <> "" Then
          If IDESSEA Then
            If instr(1, SZUPTTR, SZWORD(I)) Then
              IFOUND = 1
            Endif
            If instr(1, SZUPDES, SZWORD(I)) Then
              IFOUND = 1
            Endif
          Endif
          If IFOUND = 0 Then
            If ICLOBSEA Then
              If IBUFFEMPTY = 0 Then
                Call FINDINCLOB(SZBUFFER, "HD1", SZWORD(I), IFOUND) From CRMUTIL140
              Endif
            Endif
          Endif
          If IFOUND Then
            Read [SOR]SOR3=[F:SRE]SRENUM;GIDENT;"SRE"
            If fstat Then
              If [M:LKP7]QURNUM = "" Then
                ISC = 1
              Else
                #On filtre les demandes trouvées
                #Traitement du ET et du ET PAS
                ISC = 0
                Call CHKFILTER([F:SRE]SRENUM, [M:LKP7]QURNUM, ISC)
              Endif
              If ISC Then
                Trbegin [SOR]
                [F:SOR]SOLNUM = [F:SRE]SRENUM
                [F:SOR]NUM = INBREC
                [F:SOR]SSS = GIDENT
                [F:SOR]TYP = "SRE"
                [F:SOR]CREDAT = date$
                Write [SOR]
                If fstat Then
                  GMESSAGE = mess(100,141,1) #Erreur création
                  GERR = 1
                  Rollback
                  Break
                Else
                  Commit
                  INBREC += 1
                Endif
              Endif
            Endif
          Endif
        Endif
      Next
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
      If GERR Then
        Break
      Endif
    Next
    Filter [SRE]
    If GERR Then
      Break
    Endif
  Wend
End

###################################################################################################
# Vérifie si une solution trouvée par recherche plein texte est compatible avec le ciblage sélectionné
###################################################################################################
Subprog CHKFILTER(SZFSREKEY, SZQURNUM, ISCOMP)
Value Char SZFSREKEY
Value Char SZQURNUM
Variable Integer ISCOMP

  ISCOMP = 1
  If SZFSREKEY = "" Then
    End
  Endif
  If SZQURNUM = "" Then
    End
  Endif
  Case [M:LKP7]SEAOPD
    When 1
      Gosub DOAND
    When 3
      Gosub DOANDNOT
    When Default
      ISCOMP = 1
  Endcase
End

##################################################################################################
# Exécution d'un filtre de type ET
##################################################################################################
$DOAND
  #La demande doit également être présente dans le ciblage
  ISCOMP = 0
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    Return
  Endif
  Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL and [F:QTP]KEYTGR = SZFSREKEY
  For [QTP] QTP1
    ISCOMP = 1
    Break
  Next
  Filter [QTP]
Return

##################################################################################################
# Exécution d'un filtre de type ET PAS
##################################################################################################
$DOANDNOT
  #La demande ne doit pas être présente dans le ciblage
  ISCOMP = 1
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    Return 
  Endif
  Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL and [F:QTP]KEYTGR = SZFSREKEY
  For [QTP] QTP1
    ISCOMP = 0
    Break
  Next
  Filter [QTP]
Return

#####################################################################################
# Intègre un ciblage dans la recherche
#####################################################################################
Subprog DO_NOTQURSEA(SZQURNUM, INBREC)
Value Char SZQURNUM
Variable Integer INBREC

Local Integer ISCOMP
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT

  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
  Endif
  ISCOMP = 0
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [SRE] Where [F:SRE]SRENUM > SZCLE Order By [F:SRE]SRENUM Asc
    For [SRE]
      SZCLE = [F:SRE]SRENUM
      Read [SOR]SOR3=[F:SRE]SRENUM;GIDENT;"SRE"
      If fstat Then
        ISCOMP = 1
        Filter [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL and [F:QTP]KEYTGR = [F:SRE]SRENUM
        For [QTP] QTP1
          ISCOMP = 0
          Break
        Next
        Filter [QTP]
        If ISCOMP Then
          Trbegin [SOR]
          [F:SOR]SOLNUM = [F:SRE]SRENUM
          [F:SOR]NUM = INBREC
          [F:SOR]SSS = GIDENT
          [F:SOR]TYP = "SRE"
          [F:SOR]CREDAT = date$
          Write [SOR]
          If fstat Then
            GMESSAGE = mess(100,141,1) #Erreur création
            GERR = 1
            Rollback
            Break
          Else
            Commit
            INBREC += 1
          Endif
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
      If GERR Then
        Break
      Endif
    Next
    Filter [SRE]
    If GERR Then
      Break
    Endif
  Wend
End
