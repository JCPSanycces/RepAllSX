#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
#                                                                           #
#      TRAITEMENTS LIES à la gestion multi-site                             #
#                                                                           #
#############################################################################
#                                                                           #
# MAJ_SOH     : S/P de mise à jour automatique d'un contrat vente à partir  #
# -------              de la gestion des contrats dans les achats           #
#                                                                           #
# CTL_MAJ_SOH : S/P de contrôle de mise à jour d'un contrat                 #
# -----------                                                               #
# MAJ_SOC     : S/P de mise à jour automatique d'un contrat-article vente   #
# -------              à partir de la gestion des contrats dans les achats  #
#                                                                           #
# CTL_MAJ_SOC : S/P de contrôle de mise à jour d'un contrat-article         #
# -----------                                                               #
# MAJ_SOQ     : S/P de mise à jour automatique d'une DL vente à partir      #
# -------              de la gestion des DL dans les achats                 #
#                                                                           #
# CTL_MAJ_SOQ : S/P de contrôle de mise à jour d'une DL                     #
# -----------                                                               #
#                                                                           #
# RECH_NUM_SEQ: S/P de recherche d'un n° séquence DL vente à mettre en      #
# ------------          correspondance avec un n° séquence DL achat         #
#                                                                           #
#############################################################################
# Issue 116162 - 20160422 by LD : Inter-société et révision des index
# Issue X3-66385 - 20180226 by LD : Sales order: Default package by shipment site

$TRTVENMSIT
Call AUTSOQ
End
#########################################################################
#                                                                       #
# MAJ_SOH : S/P de mise à jour automatique d'un contrat vente à partir  #
#                  de la gestion des contrats dans les achats           #
#                                                                       #
#########################################################################
#                                                                       #
# S/P appelé en action INICRE : Création d'un contrat                   #
#                      INIMOD : Modification d'un contrat               #
#                      ANNULE : Suppression d'un contrat                #
#     appelé à l'intérieur d'une transaction, GOK = 1                   #
#                                                                       #
# ----- Les paramêtres à passer avec l'écran SORW [SORW] -------------- #
#                                                                       #
# MAJCOD    : Code mise à jour (C/M/A)                                  #
# --------                                                              #
#     En Création :                                                     #
# BPCORD    : N° du client                                              #
# SALFCY    : Site de vente                                             #
# VLYDATCON : Date de validité du contrat                               #
# POHNUM    : N° du contrat achat                                       #
# --------                                                              #
#     En Modif    :                                                     #
# SOHNUM    : N° du contrat                                             #
# VLYDATCON : Date de validité du contrat                               #
# --------                                                              #
#     En Suppression :                                                  #
# SOHNUM    : N° du contrat                                             #
#                                                                       #
# ----- Le paramêtres renvoyés ---------------------------------------- #
#                                                                       #
# SOHNUM   : N° du contrat uniquement en création                       #
# GOK      : 1 ou <=0                                                   #
# GMESSAGE : Libellé du message erreur ou ""                            #
# ERRCOD   : Code erreur ou 0                                           #
#                                                                       #
#########################################################################
#########################################################################
Subprog MAJ_SOH

Raz GMESSAGE
[M:SORW]ERRCOD=0

Gosub OUVRE_SOH
If GOK=0 End : Endif
# --- Sélection du traitement demandé
Case [M:SORW]MAJCOD
  When "C"     : Gosub CREATION_SOH
  When "M"     : Gosub MODIFICATION_SOH
  When "A"     : Gosub SUPPRESSION_SOH
  When Default :
Endcase

$FERME_SOH
# --- Restauration variables globales
GABREV =SAVGABREV
Gosub REST_GLOB From TRTX3GLOB

End

# --------------------------------------------------------------- #
#     OUVRE_SOH                                                   #
# --------------------------------------------------------------- #
$OUVRE_SOH

# --- Ouverture tables
If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SOC])=0 : Local File SORDERC    [SOC] : Endif
If clalev([F:SOP])=0 : Local File SORDERP    [SOP] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:LCM])=0 : Local File LASTCUSMVT [LCM] : Endif
If clalev([F:TSO])=0 : Local File TABSOHTYP  [TSO] : Endif
If clalev([F:TUV])=0 : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
# --- Sauvegarde variables globales
Gosub SAUV_GLOB From TRTX3GLOB

Global Char     GNUM(GLONVCR)
Global Shortint GREV  : # 0=question non posée / 1=sans avenant / 2=avec avenant
Local  Integer  STAT, WRET
Local  Integer  SAVGIMPORT     : SAVGIMPORT = GIMPORT
Local  Char     SAVGABREV(5)   : SAVGABREV = GABREV
Local  Char     WGRPDEB(GLONVCR)

GABREV="SOR"
# --- Ouverture écrans
If clalev([M:SOR1])=0  Local Mask SOR1 [SOR1] : Endif

# --- Récupération des types de frais/remises et des no éléments de facturation associés
Call TYPREM(1,"") From TRTPRICE
Return

# -------------------------------------------------------------------- #
#     Création du contrat miroir à partir de celui des achats          #
# -------------------------------------------------------------------- #
$CREATION_SOH

If [M:SORW]SOHNUM <> "" GOK=0 : Return : Endif

GREP="C"
# --- Alimentation de SOH
Gosub ALISOH
If GOK = 0 Return : Endif
# --- Récupération du compteur commande ouverte
If [M]SOHNUM = ""
    Call NUMERO(GCPT,[F:SOH]SALFCY,[F:SOH]ORDDAT,"",GNUM,STAT) From SUBANM
    If STAT = 0
        [F:SOH]SOHNUM  = GNUM
        [M:SOR1]SOHNUM = GNUM
    Else
        [M:SORW]ERRCOD=10 : Gosub TRT_ERR : Return
    Endif
Endif

Write [SOH]
If fstat
    GOK=0 : Call FSTA("SOH") From GLOCK
    [M:SORW]ERRCOD = 11 : Gosub TRT_ERR : Return
Endif
[M:SORW]SOHNUM = [M:SOR1]SOHNUM

#----- Mise à jour du suivi workflow signature -----#
If GOK=1
    # -- Déf des variables workflow
    Call WRKGLOB(170,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOR","C",[F:SOH]SOHNUM,"",0,1,0,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif

Return

# --------------------------------------------------------------- #
#     Alimentation du contrat : Alimentation de SORDER (SOH)      #
# --------------------------------------------------------------- #
$ALISOH
Local Char WBPCINV
# ---  Action : RAZCRE
# Alimentation nb axes analytiques
#If dim([M]NBAXE) > 0 [M]NBAXE = GOPTCANA : Endif

Raz [M:SOR1]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SOR1] = [M:SORW]

[M]CUSORDREF = [M:SORW]POHNUM
[M]ORDDAT = date$
[M]ORIFCY = [M:SORW]POHFCY

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Le PJT transite uniquement en intersite
If [M:SOR1]BETFCY=2 & [M:SOR1]BETCPY=1
    [M:SOR1]PJT=[M:SORW]PJTH
Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

[M:SOR1]APPFLG = 1

# ---  Traitement du type de commande ouverte : Chargement du 1er type existant
#Filter [TSO] Where [TSO]SOHCAT = 4
#Read [TSO]TSO0 First
#If fstat = 0
#    [M]SOHTYP = [F:TSO]SOHTYP
#    [M]SOHCAT = [F:TSO]SOHCAT
#    GCPT = [F:TSO]CODNUM
#Else
#    [M:SORW]ERRCOD = 1 : Gosub TRT_ERR : Return
#Endif
#Filter [TSO]

[M]SOHCAT = 4

Call IS_SOHTYP ([M]SOHCAT, [M]SALFCY,[M]SOHTYP) From FUNBCH

#--CPO 71937 T757 Contrôle de cohérence
#--30.05.2013 Initialisation descendue après l'init des globales liées à la société
#--pour appel LEC_TSO_LEG
#Read [TSO]TSO0=[M]SOHTYP
#If !fstat
#    # flag compteur manuel
##    GMANCOU=[F:TSO]MANCOU
#    # code compteur
#    GCPT=[F:TSO]CODNUM
#    # 75115 : V7 : Extension of Digital Signature : New field delivery type
#    [M:SOR1]SDHTYP = [F:TSO]SDHTYP
#Endif
#--/

# ---  Traitement du site de vente
If [M]SALFCY = "" [M]SALFCY = GFCYDEF(5) Endif
If [M]SALFCY <> ""
    GFCY = [M]SALFCY
    #Call GETDEV(GFCY) From DEVSUB
    # Chargement des globales référenciels, comptes et sections de la société
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#     RéCUPéRATION DES PARAMèTRES VENTE DU SITE / DE LA SOCIéTé
    Call GLOBVAR(GFCY,"VEN") From TRTX3
#     Alimentation du code structure
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    If [F:CPY]CPY<>GSOCIETE
        Read [CPY] CPY0=GSOCIETE
        If fstat Raz [F:CPY] Endif
    Endif
    [M:SOR1]PLISTC=[F:CPY]PLISTC
Endif

#--CPO 71937 T757 Contrôle de cohérence
#--30.05.2013 Initialisation descendue après l'init des globales liées à la société
#--pour appel LEC_TSO_LEG
Local Integer WERR
Call LEC_TSO_LEG([F:CPY]LEG,[M]SOHTYP,WERR) From TRTLECLEG
If !WERR
    # flag compteur manuel
#    GMANCOU=[F:TSO]MANCOU
    # code compteur
    GCPT=[F:TSO]CODNUM
    # 75115 : V7 : Extension of Digital Signature : New field delivery type
    [M:SOR1]SDHTYP = [F:TSO]SDHTYP
Endif
#--/

# ---  Traitement du client commande
If [F:BPC]BPCNUM <> [M:SORW]BPCORD
   Read [BPC]BPC0 = [M:SORW]BPCORD
   If fstat [M:SORW]ERRCOD = 2 : Gosub TRT_ERR : Return : Endif
Endif
Gosub CTL_BPCORD : If GOK = 0 Return : Endif

# 101436 : Alimentation des champs liées aux adresses
# Récup adresse clt cde
Local Char WBPAORD(GLONADR)
WBPAORD=[F:BPC]BPAADD
# Par défaut, l'adresse clt facture est l'adresse de facturation de la fiche client
Local Char WWBPCINV(GLONBPC), WBPAINV(GLONADR)
WWBPCINV=[F:BPC]BPCINV : WBPAINV=[F:BPC]BPAINV
# Par défaut, l'adresse clt payeur est l'adresse client payeur de la fiche client
Local Char WBPCPYR(GLONBPR), WBPAPYR(GLONADR)
WBPCPYR=[F:BPC]BPCPYR  : WBPAPYR=[F:BPC]BPAPYR
# 101436

GIMPORT=1 : Call ALICDE(2, "C", [M]BPCORD) From TRTVENCDE : GIMPORT=SAVGIMPORT
# ---  Traitement du client facture
WBPCINV=[M]BPCINV
If [M:SORW]BPCINV<>"" WBPCINV=[M:SORW]BPCINV : Endif
If [F:BPC]BPCNUM <> WBPCINV
    Read [BPC]BPC0 = WBPCINV
    If fstat [M:SORW]ERRCOD = 7: Gosub TRT_ERR : Return : Endif
Endif
Gosub CTL_BPCINV : If GOK = 0 Return : Endif

# 101436 : Alimentation des champs liées aux adresses
# Récup adresse clt facture
If WBPCINV<>WWBPCINV
    # Si clt facture du contrat n'est pas le clt facture de la fiche client, prendre l'adresse par défaut du clt facture
    # (Sinon l'adresse est l'adresse de facturation de la fiche client)
    WBPAINV=[F:BPC]BPAADD
Endif
# 101436

# Si le client facture est alimenté et qu'il est ok, on le prend
# Il correspond au client lié au site de facturation du contrat achat, il correspond aussi au client payeur
If [M:SORW]BPCINV<>[M]BPCINV & [M:SORW]BPCINV<>""
    [M]BPCINV=[M:SORW]BPCINV
    [M]BPCPYR=[M:SORW]BPCINV
    GIMPORT=1 : Call ALICDE(2, "F", [M]BPCINV) From TRTVENCDE : GIMPORT=SAVGIMPORT
Elsif [M:SORW]BPCINV<>""
    [M]BPCPYR=[M:SORW]BPCINV
    Call INIPTE ([M:SOR1]BPCPYR, [M:SOR1]BPCINV, "C",[M:SOR1]PTE) From TRTX3
Endif
Local Integer WRET

Call IS_DTAPOHSOH ([M:SORW]POHFCY,[M:SOR1]SALFCY,"[M:SORW]","[M:SOR1]",[M:SORW]CUR,[M:SOR1]CHGTYP,[M:SOR1]CUR,[M:SOR1]ORDDAT,WRET) From FUNBCH

# ---  Traitement des clients groupe, payeur
Gosub CTL_BPC : If GOK = 0 Return : Endif

# 101436 : Alimentation des champs liées aux adresses
# Récup adresse clt payeur
If [M]BPCPYR<>WBPCPYR
    # Si clt payeur du contrat n'est pas le clt payeur de la fiche client, prendre l'adresse par défaut du clt payeur
    # (Sinon l'adresse est l'adresse payeur de la fiche client)
    If [F:BPC]BPCNUM<>[M]BPCPYR
        Read [BPC]BPC0=[M]BPCPYR
        If fstat Raz [F:BPC] Endif
    Endif
    WBPAPYR=[F:BPC]BPAADD
Endif
# 101436

# ---  Traitement de la date de validité
If [M]VLYDATCON < date$  [M]ERRCOD = 8 : Gosub TRT_ERR : Return : Endif
# --  Traitement des conditions paiement, devise, type cours, type de prix
# --  Traitement des axes analityques
# --  Traitement des montants de facturation
# --> On considère que c'est ok dans le client
# --- Action : VERIF_CRE
# Vérification que tous les axes sont bien été saisis
Gosub CTL_NBAXE
If GMESSAGE <> ""
    [M:SORW]ERRCOD = 9 : GMESSAGE = [M:SORW]SOHNUM - GMESSAGE
    GOK=0 : Return
Endif

[F:SOH] = [M:SOR1]
# --- Type ALLOCATION = Paramêtre GALLTYP
[F:SOH]ALLTYP = GALLTYP
# --- Alimentation des types de frais/remises et des no éléments de facturation associés
For I = 1 To dim([F:SOH]DISCRGTYP)
   [F:SOH]DISCRGTYP(I-1) = GDISCRGTYP(I-1)
   [F:SOH]INVDTALIN(I-1) = GINVDTALIN(I-1)
Next I
If GAPPSOC>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

# 101436 : Alimentation des champs liées aux adresses
[F:SOH]BPAORD=WBPAORD
[F:SOH]BPAINV=WBPAINV
[F:SOH]BPAPYR=WBPAPYR

# Si code act SAD actif stockage des adresses
If GACTSAD=2
  If [F:BPR]BPRNUM<>[F:SOH]BPCORD
    Read [BPR]BPR0=[F:SOH]BPCORD
    If fstat Raz [F:BPR] Endif
  Endif
  [F:SOH]BPCNAM(0)    = [F:BPR]BPRNAM(0)
  [F:SOH]BPCNAM(1)    = [F:BPR]BPRNAM(1)

  If [F:BPA]BPANUM<>[F:SOH]BPCORD | [F:BPA]BPAADD<>[F:SOH]BPAORD
    Read [BPA]BPA0= 1 ; [F:SOH]BPCORD ; [F:SOH]BPAORD
    If fstat Raz [F:BPA] Endif
  Endif
  [F:SOH]BPCADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:SOH]BPCADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:SOH]BPCADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:SOH]BPCPOSCOD    = [F:BPA]POSCOD
  [F:SOH]BPCCTY       = [F:BPA]CTY
  [F:SOH]BPCSAT       = [F:BPA]SAT
  [F:SOH]BPCCRY       = [F:BPA]CRY
  [F:SOH]BPCCRYNAM    = [F:BPA]CRYNAM

  If [F:BPR]BPRNUM<>[F:SOH]BPCINV
    Read [BPR]BPR0=[F:SOH]BPCINV
    If fstat Raz [F:BPR] Endif
  Endif
  [F:SOH]BPINAM(0)    = [F:BPR]BPRNAM(0)
  [F:SOH]BPINAM(1)    = [F:BPR]BPRNAM(1)

  If [F:BPA]BPANUM<>[F:SOH]BPCINV | [F:BPA]BPAADD<>[F:SOH]BPAINV
    Read [BPA]BPA0= 1 ; [F:SOH]BPCINV ; [F:SOH]BPAINV
    If fstat Raz [F:BPA] Endif
  Endif
  [F:SOH]BPIADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:SOH]BPIADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:SOH]BPIADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:SOH]BPIPOSCOD    = [F:BPA]POSCOD
  [F:SOH]BPICTY       = [F:BPA]CTY
  [F:SOH]BPISAT       = [F:BPA]SAT
  [F:SOH]BPICRY       = [F:BPA]CRY
  [F:SOH]BPICRYNAM    = [F:BPA]CRYNAM
Endif
# 101436

[F:SOH]CPY = GSOCIETE  # FGR 03/10/2014 : X3SUIVI102969

If dim([F:SOH]CREDAT) >0 [F:SOH]CREDAT = date$ : Endif
If dim([F:SOH]CREUSR) >0 [F:SOH]CREUSR = GUSER : Endif
If dim([F:SOH]EXPNUM) >0 [F:SOH]EXPNUM = [C]EXPORT : Endif

Return

# ------------------------------------------------------------------- #
#     Controle du client commande                                     #
# ------------------------------------------------------------------- #
$CTL_BPCORD

# --- Client actif
If [F:BPC]BPCSTA<>2 [M:SORW]ERRCOD = 3 : Gosub TRT_ERR : Return : Endif
# --- Tiers autorisé pour la société
Call CTLBPRCPY([M]BPCORD, [M]SALFCY) From CONTX3
If mkstat [M:SORW]ERRCOD = 6 : Gosub TRT_ERR : Return : Endif
Local Integer WOSTCTL
If [F:BPC]BPCRSK<>[F:BPC]BPCNUM
    Local File BPCUSTOMER [BPC1] : # Lecture du tiers risque ss une autre abrev pour ne pas casser [F:BPC] du clt cde
    If [F:BPC1]BPCNUM <> [F:BPC]BPCRSK
        Read [F:BPC1]BPC0 = [F:BPC]BPCRSK
        If fstat Raz [F:BPC1] : Endif
    Endif
    WOSTCTL=[F:BPC1]OSTCTL
Else
    WOSTCTL=[F:BPC]OSTCTL
Endif
If WOSTCTL = 3 [M:SORW]ERRCOD = 4 : Gosub TRT_ERR : Return : Endif
Return

# ------------------------------------------------------------------- #
#     Controle du client facture                                      #
# ------------------------------------------------------------------- #
$CTL_BPCINV
# --- Tiers autorisé pour la société
Call CTLBPRCPY([F:BPC]BPCNUM, [M]SALFCY) From CONTX3
If mkstat [M:SORW]ERRCOD = 6 : Gosub TRT_ERR : Return : Endif
## --- contrôle client bloqué
#If [F:BPC]OSTCTL=3 [M:SORW]ERRCOD = 4 : Gosub TRT_ERR : Return : Endif
Return

# ------------------------------------------------------------------- #
#     Controle des clients groupe, payeur                             #
# ------------------------------------------------------------------- #
$CTL_BPC
# --- Client groupe
If [M]BPCGRU <> "" & [F:BPC]BPCNUM <> [M]BPCGRU
    Read [BPC]BPC0 = [M]BPCGRU
    If fstat Raz [F:BPC]
# --- Tiers autorisé pour la société
    Else     Call CTLBPRCPY([F:BPC]BPCNUM, [M]SALFCY) From CONTX3
             If mkstat [M:SORW]ERRCOD = 6 : Gosub TRT_ERR : Return : Endif
    Endif
Endif
# --- Client payeur
If [M]BPCPYR <> "" & [F:BPC]BPCNUM <> [M]BPCPYR
    Read [BPC]BPC0 = [M]BPCPYR
    If fstat Raz [F:BPC]
# --- Tiers autorisé pour la société
    Else     Call CTLBPRCPY([F:BPC]BPCNUM, [M]SALFCY) From CONTX3
             If mkstat [M:SORW]ERRCOD = 6 : Gosub TRT_ERR : Return : Endif
    Endif
Endif
Return

# -------------------------------------------------------------------------------- #
#     Traitement d'une erreur                                                      #
# -------------------------------------------------------------------------------- #
$TRT_ERR
#                                                                                  #
# 1 : Aucun type de commande défini                                                #
# 2 : Code client inexistant                                                       #
# 3 : Client non actif                                                             #
# 4 : Client bloqué                                                                #
# 5 : Le client n'est pas inter-site                                               #
# 6 : tiers non autorisé pour cette société                                        #
# 7 : Client facture inexistant                                                    #
# 8 : Date de validité incorrecte                                                  #
# 9 : Des sections analytiques n'ont pas été renseignées                           #
# 10: Pb lors de la récupération du compteur                                       #
# 11: Pb lors de l'écriture/réécriture/suppression sur le fichier                  #
# 12: Pb lors de la lecture du fichier                                             #
# 13: Pb en mise à jour des avenants                                               #
# 14:                                                                              #
# 15: Ce contrat n'est pas supprimable : Il contient des demandes de livraison     #
# 16: Aucune adresse de livraison pour ce client                                   #
# 17: Article vente inexistant                                                     #
# 18: La clé client livré/article existe déjà                                      #
# 19: Article vente sans article maître                                            #
# 20: Article interdit                                                             #
# 21: Date de livraison > Date fin de validité                                     #
# 22: Unité de vente inconnue pour cet article                                     #
# 23: Pb lors de l'écriture/réécriture/suppression sur le fichier                  #
# 24: Pb lors de la lecture du fichier                                             #
# 25: Date d'expédition inférieure à la date du jour                               #
# 26: Compteur en-cours incorrect ou non défini                                    #
#   : Module Stock Affectation des compteurs non trouvée !                         #
# 27: Insertion de la ligne impossible                                             #
# 28: Date d'expédition supérieure à la date de livraison                          #
# 29: Les dates et périodes de livraisons demandées doivent être croissantes:      #
#                  \Jours-Semaines-Mois                                            #
# 30: Pb lors de la récupération du compteur                                       #
# 31: Pb lors de l'écriture/réécriture/suppression sur le fichier                  #
# 32: Pb lors de la lecture du fichier                                             #
# 33: Pb lors de la maj de l'en-cours                                              #
# 34: Pb lors de la suppression des allocations ruptures                           #
# 35:                                                                              #
# 36: Traitement impossible: Cette ligne est allouée/livrée/facturée               #
# 37: Traitement impossible: Cette ligne est soldée                                #
# 38: Qté commandée inférieure au Total livré/alloué                               #
# 39: Statut non modifiable sur une ligne mensuelle ou annuelle                    #
# 40: Modification impossible : Cette ligne est livrée : Quantité livrée = 99      #
# 98: Des paramêtres ne sont pas renseignés                                        #
# 99: Erreur diverse                                                               #
# -------------------------------------------------------------------------------- #
GOK = 0
Case [M:SORW]ERRCOD
    When  1 : GMESSAGE=mess(146,192,1)
    When  2 : GMESSAGE=[M:SORW]BPCORD-":"-mess(139,100,1)
    When  3 : GMESSAGE=[M:SORW]BPCORD-":"-mess(4,119,1)
    When  4 : GMESSAGE=[M:SORW]BPCORD-":"-mess(151,199,1)
    When  5 : GMESSAGE=[M:SORW]BPCORD-":"-mess(158,196,1)
    When  6 : GMESSAGE=[F:BPC]BPCNUM-":"-mess(29,104,1)
    When  7 : GMESSAGE=[M:SOR1]BPCINV-":"-mess(147,192,1)
    When  8 : GMESSAGE=format$(GFMDAT,[M:SORW]VLYDATITM)-":"-mess(148,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    When  9 : GMESSAGE=[M:SORW]SOHNUM-":"-GMESSAGE
    When 10 : GMESSAGE=GCPT-":"-mess(60,199,1)
    When 11 : GMESSAGE=mess(149,192,1)-"SORDER:"-[F:SOH]SOHNUM
    When 12 : GMESSAGE=mess(150,192,1)-"SORDER:"-[M:SORW]SOHNUM
    When 13 : GMESSAGE=mess(151,192,1)
    When 14 :
    When 15 : GMESSAGE=[M:SORW]SOHNUM-":"-mess(11,192,1)
    When 16 : GMESSAGE=[M:SORW]BPCORD-":"-mess(154,192,1)
    When 17 : GMESSAGE=[M:SORW]ITMREF-":"-mess(7,192,1)
    When 18 : GMESSAGE=[M:SORW]ITMREF-[M:SORW]BPCORD-[M:SOI1]BPAADD-":"-mess(31,192,1)
    When 19 : GMESSAGE=[M:SORW]ITMREF-":"-mess(8,192,1)
    When 20 : GMESSAGE=[M:SORW]ITMREF-":"-mess(27,192,1)
    When 21 : GMESSAGE=[M:SORW]DEMDLVDAT-":"-mess(152,192,1)
    When 22 : GMESSAGE=[M:SORW]ITMREF-[M:SORW]SAU-":"-mess(9,192,1)
    When 23 : GMESSAGE=mess(149,192,1)-"SORDERC:"-[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)
    When 24 : GMESSAGE=mess(150,192,1)-"SORDERC:"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)
    When 25 : GMESSAGE=format$(GFMDAT,[F:SOQ]SHIDAT)-mess(155,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    When 26 : #GMESSAGE=WCPT-mess(222,199,1)
              GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
    When 27 : GMESSAGE=[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-":"-mess(122,199,1)
    When 28 : GMESSAGE=mess(153,192,1)
    When 29 : GMESSAGE=mess(21,192,1)
    When 30 : GMESSAGE=GWIP-mess(60,199,1)
    When 31 : GMESSAGE=mess(149,192,1)-"SORDERQ:"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
    When 32 : GMESSAGE=mess(150,192,1)-"SORDERQ:"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)
    When 33 : GMESSAGE=mess(92,197,1)-":"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)
    When 34 : GMESSAGE=mess(96,197,1)-":"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)
    When Default
Endcase
Return

# ------------------------------------------------------------------------ #
#     Modification du contrat miroir à partir de celui des achats          #
# ------------------------------------------------------------------------ #
$MODIFICATION_SOH
Local Integer OK
# --- Lecture du contrat
Read [SOH]SOH0=[M:SORW]SOHNUM
If fstat [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : Return :Endif
# --- Contrôle s'il y a des zones à modifier
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
#If [M:SORW]VLYDATCON = [F:SOH]VLYDATCON Return : Endif
If [M:SORW]VLYDATCON = [F:SOH]VLYDATCON &
&  [M:SORW]PJTH      = [F:SOH]PJT        Return : Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

[M:SOR1]=[F:SOH]
GIMPORT=1 : Gosub LIENS From SUBSOR : GIMPORT=SAVGIMPORT
# --- Action AVANT_MOD
# --> MODIF AVEC OU SANS AVENANT
GREV = 1 : If GSALREV = 2 : GREV = 2 : [M]REVNUM += 1 : Endif
# --- Action : VERIF_CRE
Gosub CTL_NBAXE
If GMESSAGE <> "" [M:SORW]ERRCOD = 9 : Gosub TRT_ERR : Return : Endif

Readlock [SOH]SOH0=[M:SORW]SOHNUM
If fstat=1
    GOK=-1 : GLOCK = "$SORDER"-[M:SORW]SOHNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("SOH", [M:SORW]SOHNUM) From GLOCK
    [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : Return
Endif
# --- Historisation si modif. avec avenant
If GREV = 2 Call HISTO_REV ("SOH", "M") From TRTVENMAJ : Endif
If GOK<=0 [M:SORW]ERRCOD = 13 : Gosub TRT_ERR : Return : Endif

# --> Gestion des signatures
#------------------------------------------------------------------------#
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow #
#------------------------------------------------------------------------#
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
    Call ANNULE_SUIVI("SOR",mess(652,197,1),1,WRET) From TRTVENDIV
    If GOK<1  Return : Endif
    #----- Mise à jour du suivi workflow signature -----#
    # --  Déf des variables workflow
    Call WRKGLOB(171,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    #           1=Avant mise à jour classe [F]                                            #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,1,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
Endif

[M:SOR1]VLYDATCON = [M:SORW]VLYDATCON

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Le PJT transite uniquement en intersite
If [M:SOR1]BETFCY=2 & [M:SOR1]BETCPY=1
    [M:SOR1]PJT=[M:SORW]PJTH
Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

[F:SOH]=[M:SOR1]

If GAPPSOC>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

If dim([F:SOH]UPDDAT) >0 [F:SOH]UPDDAT = date$ : Endif
If dim([F:SOH]UPDUSR) >0 [F:SOH]UPDUSR = GUSER : Endif
If dim([F:SOH]EXPNUM) >0 [F:SOH]EXPNUM = [C]EXPORT : Endif

Rewrite [SOH]
If fstat
    GOK=0 : Call FSTA("SOH") From GLOCK
    [M:SORW]ERRCOD = 11 : Gosub TRT_ERR : Return
Endif

If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    #           2=Après mise à jour classe [F]                                            #
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,2,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif

Return

# ----------------------------------------------------------------------- #
#     Suppression du contrat miroir à partir de celui des achats          #
# ----------------------------------------------------------------------- #
$SUPPRESSION_SOH

# --- Lecture du contrat
Readlock [SOH]SOH0=[M:SORW]SOHNUM
If fstat=1
    GOK=-1 : GLOCK = "$SORDER"-[M:SORW]SOHNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("SOH", [M:SORW]SOHNUM) From GLOCK
    [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : Return
Endif

# --- Action : ANNULE
Local Integer WRET

If left$([F:SOH]SOHTEX1,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX1,WRET) From TRTX3TEX
Endif
If left$([F:SOH]SOHTEX2,3)="SOH"
   Call SUP_CLOB([F:SOH]SOHTEX2,WRET) From TRTX3TEX
Endif

# --> Gestion des signatures
#------------------------------------------------------------------------#
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow #
#------------------------------------------------------------------------#
If GAPPSOC>1
  Call ANNULE_SUIVI("SOR",mess(653,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
Endif

# -- Suppression des enregistrements SORDERC et SORDERP correspondants au contrat
Delete [SOP] Where [SOP]SOHNUM = [SOH]SOHNUM
If fstat = 1 GOK = -1 : GLOCK = "$SORDERP"-[M:SORW]SOHNUM : Return : Endif
Delete [SOC] Where [SOC]SOHNUM = [SOH]SOHNUM
If fstat = 1 GOK = -1 : GLOCK = "$SORDERC"-[M:SORW]SOHNUM : Return : Endif

Delete [SOH] Where SOHNUM=[M:SORW]SOHNUM
If fstat=1
    GOK=-1 : GLOCK = "$SORDER"-[M:SORW]SOHNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("SOH", [M:SORW]SOHNUM) From GLOCK
    [M:SORW]ERRCOD = 11 : Gosub TRT_ERR : Return
Endif

# -- Déf des variables workflow
Call WRKGLOB(172,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
#-------------------------------------------------#
# Traitement d'un Workflow (normal)
#-------------------------------------------------#
Call WORKFLOW(2,"SOR","A",[F:SOH]SOHNUM) From AWRK

Return
########################################################################
$CTL_NBAXE
If dim([M]BETFCY)>0 & [M]BETFCY=2  Return : Endif : # Pas de contrôle si inter-sites
# VéRIFICATION QUE TOUS LES AXES ONT BIEN éTé SAISIS
If dim([M]NBAXE)>0
   For nolign = 1 To GNBDIE
      If [M]CCE(nolign-1)="" & GOBLDIE(nolign)=2
         GMESSAGE = mess(177,199,1)
         Break
      Endif
   Next nolign
Endif
Return
#########################################################################
#                                                                       #
# CTL_MAJ_SOH : S/P de contrôle de mise à jour d'un contrat             #
#                                                                       #
#########################################################################
#                                                                       #
# S/P appelé en action AVANT_MOD : Modification d'un contrat            #
#                      VERF_ANU  : Suppression d'un contrat             #
#                                                                       #
# ----- Les paramêtres à passer avec l'écran SORW [SORW] -------------- #
#                                                                       #
# MAJCOD : Code mise à jour (M/A)                                       #
# SOHNUM : N° du contrat                                                #
#                                                                       #
# ----- Les paramêtres renvoyés --------------------------------------- #
#                                                                       #
# GMESSAGE : Libellé du message erreur ou ""                            #
# ERRCOD   : Code erreur ou 0                                           #
#                                                                       #
#########################################################################
Subprog CTL_MAJ_SOH

If [M:SORW]MAJCOD <> "A" End Endif
If [M:SORW]SOHNUM =  ""  End Endif

If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif

Raz GMESSAGE, [M:SORW]ERRCOD
# --- Lecture du contrat
Read [SOH]SOH0=[M:SORW]SOHNUM
If fstat [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : End : Endif

# Un contrat est supprimable s'il ne contient pas de demandes de livraisons
Filter [SOQ] Where [SOQ]SOHNUM = [F:SOH]SOHNUM
Read [SOQ]SOQ0 First
If fstat <> 4 [M:SORW]ERRCOD = 15 : Gosub TRT_ERR : Endif
Filter [SOQ]

End
#########################################################################
#########################################################################
#                                                                       #
# MAJ_SOC : S/P de mise à jour automatique d'un contrat-article vente   #
#                  à partir de la gestion des contrats dans les achats  #
#                                                                       #
#########################################################################
#                                                                       #
# Si une erreur est détectée  : GOK est mis à 1                         #
#                               [M:SORW]ERRCOD est renseigné            #
#                                                                       #
# S/P appelé en action INICRE : Création d'un contrat                   #
#                      INIMOD : Modification d'un contrat               #
#                      ANNULE : Suppression d'un contrat                #
#     appelé à l'intérieur d'une transaction, GOK = 1                   #
#                                                                       #
# ----- Les paramêtres à passer avec l'écran SORW [SORW] -------------- #
#                                                                       #
# MAJCOD    : Code mise à jour (C/M/A)                                  #
# --------                                                              #
#     En Création :                                                     #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# ITMREF    : Référence article                                         #
# STOFCY    : Site de stockage                                          #
# PRHFCY    : Site de réception                                         #
# SAU       : Unité de vente                                            #
# EXTQTY    : Quantité prévue                                           #
# USEPLC    : Lieu de conso                                             #
# VLYDATITM : Date de validité du contrat-article                       #
# --------                                                              #
#     En Modif    :                                                     #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# EXTQTY    : Quantité prévue                                           #
# USEPLC    : Lieu de conso                                             #
# VLYDATITM : Date de validité du contrat-article                       #
# --------                                                              #
#     En Suppression :                                                  #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# ----- Les paramêtres renvoyés --------------------------------------- #
#                                                                       #
# GOK      : 1 ou <=0                                                   #
# GMESSAGE : Libellé du message erreur ou ""                            #
# ERRCOD   : Code erreur ou 0                                           #
#                                                                       #
#########################################################################
Subprog MAJ_SOC

Raz GMESSAGE
[M:SORW]ERRCOD=0

Gosub OUVRE_SOC
If GOK=0 End : Endif

# Le n° du contrat et de la ligne article doivent être renseignés
If [M:SORW]SOHNUM = "" | [M:SORW]SOPLIN = 0
    [M:SORW]ERRCOD=98 : Gosub TRT_ERR : End
Endif

# --- Lecture du contrat
If [F:SOH]SOHNUM <> [M:SORW]SOHNUM
    Read [SOH]SOH0=[M:SORW]SOHNUM
    If fstat [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : End : Endif
Endif
[M:SOR1]=[F:SOH]
GIMPORT=1 : Gosub LIENS From SUBSOR : GIMPORT=SAVGIMPORT
# --- Ouverture de l'écran de gestion du contrat-article
If clalev([M:SOI1])=0  Local Mask SOI1 [SOI1] : Endif
# --- Sélection du traitement demandé
Case [M:SORW]MAJCOD
  When "C"     : Gosub CREATION_SOC
  When "M"     : Gosub MODIFICATION_SOC
  When "A"     : Gosub SUPPRESSION_SOC
  When Default :
Endcase

$FERME_SOC
GABREV =SAVGABREV
# --- Restauration variables globales
Gosub REST_GLOB From TRTX3GLOB

End

# ------------------------------------------------------------------------------- #
#    OUVRE_SOC                                                                    #
# ------------------------------------------------------------------------------- #
$OUVRE_SOC
Local  Integer  SAVGIMPORT     : SAVGIMPORT = GIMPORT
Local  Char     SAVGABREV(5)   : SAVGABREV  = GABREV

# --- Ouverture tables
If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SOC])=0 : Local File SORDERC    [SOC] : Endif
If clalev([F:SOP])=0 : Local File SORDERP    [SOP] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif
If clalev([F:BPD])=0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:REP])=0 : Local File SALESREP   [REP] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITU])=0 : Local File ITMBPC     [ITU] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK  [SPK] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:REP])=0 : Local File SALESREP   [REP] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITU])=0 : Local File ITMBPC     [ITU] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK  [SPK] : Endif

# --- Sauvegarde variables globales -----
Gosub SAUV_GLOB From TRTX3GLOB
Global Shortint GREV     : # 0=question non posée / 1=sans avenant / 2=avec avenant
Global Shortint GITMREV  : # 1 = sans avenant / 2 = avec avenant
GQSEQ = 0 : GITMREV = 1

GABREV="SOI"

Local  Char      WGRPDEB(GLONVCR)
Local  Integer   WRET

#Global Integer GACTMUL : GACTMUL=1    : # Globale multisociété : 1(non) / 2(oui)
#Read [ACV] CODACT="MUL" : If fstat  Raz [F:ACV] : Endif
#If [F:ACV]FLACT=2 GACTMUL=2 Endif
Local Integer RETOUR
#------------------------------------------------------------#
#              Chargements liés aux tarifs                   #
#------------------------------------------------------------#
# Contrôle existence de la structure tarif par défaut        #
# Chargement des variables globales pour la recherche tarif  #
# Récupération de la structure des frais/remises             #
# Récupération des types de frais/remises                    #
#              des no éléments facturation                   #
#------------------------------------------------------------#
#If GACTMUL=2
# Réhabilité pour le multi-société 07/12/05
GORITITCOL=1 :# Si GORITITCOL=1 l'étiquette TIT_COL n'est pas exécutée, GORITITCOL doit rester à 0 : 26/06/03

GPLISTC="néant" :# Pour forcer l'affichage des entêtes de colonne si structure=""
#Endif
# Contrôle existence de la structure tarif
Call CTLSTRUCT(1,RETOUR) From TRTPRICE
If RETOUR<>0  GOK=0 : [M:SORW]ERRCOD = 99 : Return : Endif
# Alimentation des variables nécessaires à la recherche tarif
Call TARIFCHGT(5) From TRTPRICE
# Récupération de la structure des frais/remises
Call COLREM ("C",1,"") From TRTPRICE
#------------------------------------------------------------#

# --- Ouverture de l'écran de gestion des contrats
If clalev([M:SOR1])=0  Local Mask SOR1 [SOR1] : Endif

# RéCUPéRATION DES TYPES DE FRAIS/REMISES ET DES NO éLéMENTS DE FACTURATION ASSOCIéS
Call TYPREM(1,"") From TRTPRICE
#----------

Return

# ----------------------------------------------------------------------------------- #
#     Création de la ligne article miroir à partir de celle des achats                #
# ----------------------------------------------------------------------------------- #
$CREATION_SOC

# --> Gestion des signatures
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow
If GAPPSOC>1 &  [M:SOR1]SOQSEQ=0
  Call ANNULE_SUIVI("SOR",mess(652,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
Endif

GREP="C"
# --- Alimentation de SOC
Gosub ALISOC
If GOK = 0 Return : Endif

Write [SOC]
If fstat
    GOK=0 : Call FSTA("SOC") From GLOCK
    [M:SORW]ERRCOD =  23 : Gosub TRT_ERR : Return
Endif

# --> Gestion des signatures : La création d'une ligne article repasse le contrat a un statut non signé
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

# --> Gestion des signatures
If GAPPSOC>1 &  [M:SOR1]SOQSEQ=0
    # -- Déf des variables workflow
    Call WRKGLOB(171,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    #           2=Objet                                                                   #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    #           2=Après mise à jour classe [F]
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,2,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif

Return


# --------------------------------------------------------------- #
# Alimentation de l'article : Alimentation de SORDERC (SOC)       #
# --------------------------------------------------------------- #
$ALISOC
Raz [M:SOI1]
[M:SOI1]     = [M:SOR1]
[M:SOI1]XCUR = [M:SOR1]CUR

# ---  Action : RAZCRE

#  A réactiver lorsque l'on génèrera des lignes de prix
#If [M]BETCPY=2
#    GIMPORT=1 : Gosub RAZCD From SUBSOI : GIMPORT=SAVGIMPORT
#Endif
# --- Chargement des zones
[M:SOI1]SOPLIN = [M:SORW]SOPLIN
[M:SOI1]STOFCY = [M:SORW]STOFCY
[M:SOI1]USEPLC = [M:SORW]USEPLC
[M:SOI1]EXTQTY = [M:SORW]EXTQTY
[M:SOI1]PLI    = [M:SORW]PLI
[M:SOI1]EECICT = [M:SORW]EECICT     : # Bug 72215
[M:SOI1]ICTCTY = [M:SORW]ICTCTY     : # Bug 72215
[M:SOI1]FFWNUM = [M:SORW]FFWNUM     : # Bug 72215
[M:SOI1]FFWADD = [M:SORW]FFWADD     : # Bug 72215

# 105605 : CCM - Revision index (LD:03/06/15)
If dim([M:SOI1]ECCVALMAJ) > 0       : # Issue 116162
    [M:SOI1]ECCVALMAJ = [M:SORW]ECCVALMAJ
    [M:SOI1]ECCVALMIN = [M:SORW]ECCVALMIN
Endif                               : # Issue 116162
# 105605 : CCM - Revision index (LD:03/06/15)

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Le PJT transite uniquement en intersite
If [M:SOR1]BETFCY=2 & [M:SOR1]BETCPY=1
    [M:SOI1]DPJT=[M:SORW]PJT
Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

# --- Recherche de l'adresse de livraison ------
If [F:BPR]BPRNUM <> [M:SOI1]BPCORD
   Read [BPR]BPR0 = [M:SOI1]BPCORD
   If fstat Raz [F:BPR] Endif
Endif
#  Recherche du client livré
Filter [BPD] Where [BPD]BPCNUM = [M:SOI1]BPCORD & [BPD]RCPFCY =[M:SORW]PRHFCY
Read [BPD]BPD0 First
If !fstat
    [M:SOI1]BPAADD = [F:BPD]BPAADD
    #  Alimentation régime de taxe du client livré
    If [F:BPD]VACBPR<>"" [M:SOI1]VACBPR = [F:BPD]VACBPR Endif
    # Bug 72215
    If dim([M:SOI1]EECLOC)>0
        [M:SOI1]EECLOC=[F:BPD]EECLOC
        Call INIEECNUM ([M:SOI1]BPCORD,[F:BPD]BPAADD,[M:SOI1]BPCINV,[M:SOI1]BPIEECNUM,[M:SOI1]EECNUMCRY) From TRTVENDIV
    Endif
Else
    [M:SORW]ERRCOD = 16 : Gosub TRT_ERR : Return
Endif
Filter [BPD]

# ----------------------------------------------------- #
#  A réactiver lorsque l'on génèrera des lignes de prix #
#If [M]BETCPY=2
#    #  Alimentation du 1er représentant
#    If dim([M]XREP1) > 0 & [M]XREP1 = ""
#       [M]XREP1 = [F:BPD]REP(0)
#    Endif
#    #  Alimentation du 2eme représentant
#    If dim([M]XREP2) > 0
#       If [M]XREP1 <> "" & [M]XREP2 = ""
#          [M]XREP2 = [F:BPD]REP(1)
#       Endif
#    Endif
#    #  Alimentation du transporteur à partir du client livré
#    [M]XBPTNUM = [F:BPD]BPTNUM
#Endif
# ----------------------------------------------------- #

# ---- Traitement de l'article              ------
If [F:ITS]ITMREF<> [M:SORW]ITMREF
   Read [ITS]ITS0 = [M:SORW]ITMREF
   If fstat [M:SORW]ERRCOD = 17 : Gosub TRT_ERR : Return : Endif
Endif
# --- Controle unicité contrat-article
#Look [SOC]SOC1 = [M]BPCORD;[M]BPAADD;[M:SORW]ITMREF
#If fstat <> 5 [M:SORW]ERRCOD = 18 : Gosub TRT_ERR : Return : Endif

Local Integer    I
[M]ITMREF     = [F:ITS]ITMREF
#[M]ITMDES1    = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1, "[F:ITS]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

Raz [M]SOCTEX
# Lecture article/client correspondant
Read [ITU]ITU0 = [M]ITMREF;[M]BPCORD
If fstat = 0
   [M]ITMREFBPC  = [F:ITU]ITMREFBPC
   [M]ITMDESBPC  = [F:ITU]ITMDESBPC
   [M]SAU        = [F:ITU]SAU
#   [M]XPCK       = [F:ITU]PCK
   If find(GSALTEXLIN,1,5) [M]SOCTEX = [F:ITU]ITSTEX : Endif
Endif
If [M]ITMREFBPC = ""
   [M]ITMREFBPC  = [M]ITMREF
   [M]ITMDESBPC  = [M]ITMDES1
Endif

# --- Controle unicité contrat-article
Look [SOC]SOC2 = [M:SOR1]CUSORDREF;[M:SOI1]BPCORD;[M:SOI1]BPAADD;[M:SOI1]ITMREFBPC
If fstat <> 5 [M:SORW]ERRCOD = 18 : Gosub TRT_ERR : Return : Endif

# Zone non utilisée
# Alimentation emballage à partir de l'article vente si rien sur art/cli
#If [M]XPCK = "" [M]XPCK = [F:ITS]PCK : Endif

# --- Lecture article maitre
Read [ITM]ITM0 = [M]ITMREF
If fstat = 0
    #Call CHARGE_ITMDES("DES1AXX",[M:SOR1]LAN,[F:ITM]ITMREF,[M]ITMDES) From TRTX3
    #If [M]ITMDES = "" [M]ITMDES = [M]ITMDES1 Endif
    Call CHARGE_DEFITMDES("DES1AXX",[M:SOR1]LAN,[F:ITM]ITMREF,[M]ITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

    If [M]SAU = ""
        [M]SAU       = [F:ITM]SAU
    Endif
    [M]STU   = [F:ITM]STU
    [M]STOMGTCOD = [F:ITM]STOMGTCOD
    If [F:ITM]STOMGTCOD>1
        If [F:ITF]ITMREF<>[M]ITMREF | [F:ITF]STOFCY<>[M]STOFCY
            Read [ITF] ITF0=[M]ITMREF ;[M]STOFCY
            If fstat Raz [F:ITF] : Endif
        Endif
        If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD = [F:ITF]STOMGTCOD Endif
    Endif
    [M]VACITM1   = [F:ITM]VACITM(0)
    [M]VACITM2   = [F:ITM]VACITM(1)
    [M]VACITM3   = [F:ITM]VACITM(2)
    #Call ALITAXEV([M]VACBPR,[F:ITM]VACITM,[M]VAT) From TRTX3
    Call RECHVATCOD(1,1,[M]BPCORD,[M]ITMREF,"SOI1",0,[M]VAT) From TRTX3
#    Call ALISAUCOE([M]ITMREF, [M:SOI1]BPCORD, [M]SAU, [M]STU, [M]SAUSTUCOE) From TRTVENQTE
    If dim ([M]TSICOD) <> -1
        For I = 1 To dim ([M]TSICOD)
            [M]TSICOD(I-1) = [F:ITM]TSICOD(I-1)
        Next I
    Endif
Else
    [M:SORW]ERRCOD = 19 : Gosub TRT_ERR : Return
Endif
If find(GSALTEXLIN,1,5) & [M]SOCTEX = "" [M]SOCTEX = [F:ITS]ITSTEX : Endif
# --- Recherche si l'article est interdit
# --> Lecture BPR BPC MVC BPD REP succeptibles d'être des critères de recherche
Gosub INTERDIT
If INTERDIT = 1 [M:SORW]ERRCOD =20 : Gosub TRT_ERR : Return : Endif
# --- Contrôle de la date de valididité
If [M:SORW]VLYDATITM > [M:SOR1]VLYDATCON [M:SORW]ERRCOD = 8 : Gosub TRT_ERR : Return : Endif
[M:SOI1]VLYDATITM = [M:SORW]VLYDATITM
# --- Contrôle unite de vente
Local Char UNIVEN
[M:SOI1]SAU = [M:SORW]SAU
#Call CONTSAUIMP([M]SAU, [M]ITMREF,[M]BPCORD,UNIVEN) From TRTVENCTL
Call CTLUOM([M]ITMREF, 2, [M]BPCORD, [M:SOI1]SAU, [M]SAUSTUCOE, GBIDC1, GBIDC2, [M]DACSAUCOE) From STKACT
If [M:SOI1]SAU= "" [M:SORW]ERRCOD = 22 : Gosub TRT_ERR : Return : Endif

[F:SOC] = [M:SOI1]
[F:SOC]VACITM(0) = [M]VACITM1
[F:SOC]VACITM(1) = [M]VACITM2
[F:SOC]VACITM(2) = [M]VACITM3

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
[F:SOC]PJT=[M:SOI1]DPJT
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

# --- Action : INICRE
[F:SOC]CUMDATEAR = date$
[F:SOC]EARDATCUS = date$
[F:SOC]EARDAT    = date$
[F:SOC]CUSORDREF = [M:SOR1]CUSORDREF

If dim([F:SOC]CREDAT) >0 [F:SOC]CREDAT = date$ : Endif
If dim([F:SOC]CREUSR) >0 [F:SOC]CREUSR = GUSER : Endif
If dim([F:SOC]EXPNUM) >0 [F:SOC]EXPNUM = [C]EXPORT : Endif

Return

# ------------------------------------------------------------------------------------ #
#     Recherche si l'article est interdit                                              #
# ------------------------------------------------------------------------------------ #
$INTERDIT
Local Decimal  MONTANT(0..10)
Local Shortint MOTIF(0..10), PRIORITE(0..10)
Local Char     PLI   (6) (0..10)
Local Char     PLICRD (30) (0..10)
Local Integer  PLILIN    (0..10)
Local Shortint FOCMOTIF
Local Char     FOCITMREF, FOCUOM
Local Decimal  FOCQTY
Local Date     PLISTRDAT, PLIENDDAT
Local Libelle  INTERDIT, ERR
#---- Paramètres complementaires appel recherche tarifs
Local  Char    PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US : # indice 1 = régime de taxe

PARAM_T(1)=[M:SOR1]VACBPR
#  Lecture des enregistrements succeptible d'être des critères de recherche
Read [BPR]BPR0=[M]BPCORD
Read [BPC]BPC0=[M]BPCORD
#Call LECTURE ("MVC",GFINRSP,[M]BPCORD) From CONTOBJ
Read [BPD]BPD0=[M]BPCORD;[M]BPAADD
If dim([M]XREP1) > 0 Call LECTURE ("REP",[M]XREP1,"") From CONTOBJ Endif
Call ALIPLK ("SOI") From TRTPRICE
Call TARIFRECH(5,3,"SOI",date$,[M]EXTQTY,[M]SAU,[M:SOR1]CHGTYP,[M:SOR1]CUR,
&       [M:SOR1]PRITYP,[M]VAT, PARAM_T,
&       MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&       FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT,ERR)
&       From TRTPRICE
Return

# ------------------------------------------------------------------------------------ #
#     Modification d'une ligne article miroir à partir d'une ligne article des achats  #
# ------------------------------------------------------------------------------------ #
$MODIFICATION_SOC

Local Integer OK
Local Integer WMODFLGSIG : Raz WMODFLGSIG

# --- Lecture du contrat-article
Read [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
If fstat [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : Return : Endif

# --- Contrôle s'il y a des zones à modifier
# Bug 72215 : Ajout EECICT ICTCTY FFWNUM FFWADD
# 105605 : CCM - Revision index (LD:03/06/15)
# Ajout ECCVALMAJ ECCVALMIN
# 105605 : CCM - Revision index (LD:03/06/15)
# Issue 116162
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Ajout PJT
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
If [M:SORW]USEPLC    = [F:SOC]USEPLC    &
&  [M:SORW]VLYDATITM = [F:SOC]VLYDATITM &
&  [M:SORW]STOFCY    = [F:SOC]STOFCY    &
&  [M:SORW]EECICT    = [F:SOC]EECICT    &
&  [M:SORW]ICTCTY    = [F:SOC]ICTCTY    &
&  [M:SORW]FFWNUM    = [F:SOC]FFWNUM    &
&  [M:SORW]FFWADD    = [F:SOC]FFWADD    &
&  (dim([M:SORW]ECCVALMAJ)<=0 | (dim([M:SORW]ECCVALMAJ)>0 & [M:SORW]ECCVALMAJ=[F:SOC]ECCVALMAJ)) &
&  (dim([M:SORW]ECCVALMIN)<=0 | (dim([M:SORW]ECCVALMIN)>0 & [M:SORW]ECCVALMIN=[F:SOC]ECCVALMIN)) &
&  [M:SORW]PJT       = [F:SOC]PJT       &
&  [M:SORW]EXTQTY    = [F:SOC]EXTQTY    Return : Endif

[M:SOI1]=[F:SOC]

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
[M:SOI1]DPJT=[F:SOC]PJT
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

# --- Action : LIENS
If [F:ITM]ITMREF <> [M:SOI1]ITMREF
   Read [ITM]ITM0 = [M:SOI1]ITMREF
   If fstat Raz [F:ITM] Endif
Endif
[M]STOMGTCOD = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF<>[M]ITMREF | [F:ITF]STOFCY<>[M]STOFCY
        Read [ITF] ITF0=[M]ITMREF ;[M]STOFCY
        If fstat Raz [F:ITF] : Endif
    Endif
    If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD = [F:ITF]STOMGTCOD Endif
Endif

# ----------------------------------------------------- #
#  A réactiver lorsque l'on génèrera des lignes de prix #
# ----------------------------------------------------- #
#If [M]BETCPY=2
#    #  Lecture article-vente pour chargement base calcul marge
#    If [F:ITS]ITMREF <> [M:SOI1]ITMREF
#        Read [ITS]ITS0 = [M:SOI1]ITMREF
#        If fstat Raz [F:ITS] Endif
#    Endif
#    #  Alimentation des représentants à partir du client commande
#    If [F:BPC]BPCNUM <> [M:SOI1]BPCORD
#       Read [BPC]BPC0 = [M:SOI1]BPCORD
#       If fstat Raz [F:BPC] Endif
#    Endif
#    #  Alimentation du 1er représentant
#    If dim([M]XREP1) > 0
#        [M]XREP1 = [F:BPC]REP(0)
#        #   Alimentation du 2eme représentant
#        If dim([M]XREP2) > 0 & [M]XREP1 <> ""
#            [M]XREP2 = [F:BPC]REP(1)
#        Endif
#    Endif
#    #  Alimentation des représentants à partir du client livré
#    If [F:BPD]BPCNUM <> [M:SOI1]BPCORD & [F:BPD]BPAADD <> [M:SOI1]BPAADD
#        Read [BPD]BPD0 = [M:SOI1]BPCORD;[M:SOI1]BPAADD
#        If fstat Raz [F:BPD] Endif
#    Endif
#    #  Alimentation du 1er représentant
#    If dim([M]XREP1) > 0 & [M]XREP1 = ""
#        [M]XREP1 = [F:BPD]REP(0)
#    Endif
#    #  Alimentation du 2eme représentant
#    If dim([M]XREP2) > 0
#        If [M]XREP1 <> "" & [M]XREP2 = ""
#            [M]XREP2 = [F:BPD]REP(1)
#        Endif
#    Endif
#Endif
# ----------------------------------------------------- #

#  Ces deux zones sont inutilisées
#  Alimentation du transporteur à partir du client livré
#[M]XBPTNUM = [F:BPD]BPTNUM
#
#  Alimentation de l'emballage et de la capacité à partir de l'article
#If [F:ITU]ITMREF <> [M:SOI1]ITMREF & [F:ITU]BPCNUM <> [M:SOI1]BPCORD
#   Read [ITU]ITU0 = [M:SOI1]ITMREF;[M:SOI1]BPCORD
#   If fstat Raz [F:ITU] Endif
#Endif
#[M]XPCK = [F:ITU]PCK
#If [M]XPCK = ""
#    [M]XPCK = [F:ITS]PCK
#Endif
# ----------------------------------------------------- #

# --- Action : AVANT_MOD
# Modif avec ou sans avenant
GITMREV = 1
If GSALREV = 2
   GITMREV = 2 : [M]ITMREVNUM += 1 : [M:SOR1]REVNUM += 1
Endif

Readlock [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
If fstat=1
    GOK=-1 : GLOCK = "$SORDERC"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOC", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)) From GLOCK
    [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : Return
Endif

#------------------------------------------#
# Traitement avant modification            #
# --> Historisation si modif. avec avenant #
#------------------------------------------#
If GITMREV = 2 Call HISTO_REV ("SOC", "M") From TRTVENMAJ : Endif
# -----
# On continue la mise à jour même si on plante ds les avenants
# --> Pb possible de clé duppliquée
# -----
#If GOK<=0 [M:SORW]ERRCOD = 13 : Gosub TRT_ERR : Return : Endif
If GOK <=0 GOK=1 Endif

# --> Gestion des signatures
# Positionnement indicateur "Annulé" sur les lignes de suivi de workflow
If GAPPSOC>1 &  [M:SOR1]SOQSEQ=0 & ([M:SORW]VLYDATITM <> [F:SOC]VLYDATITM | [M:SORW]EXTQTY <> [F:SOC]EXTQTY | [F:SOH]APPFLG=1)
  Call ANNULE_SUIVI("SOR",mess(652,197,1),1,WRET) From TRTVENDIV
  If GOK<1  Return : Endif
  WMODFLGSIG=1
Endif
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
    #----- Mise à jour du suivi workflow signature -----#
    # -- Déf des variables workflow
    Call WRKGLOB(171,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    #           2=Objet                                                                   #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    #           1=Avant mise à jour classe [F]                                            #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,1,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
Endif

# --- Alimentation des zones modifiées
[M:SOI1]USEPLC    = [M:SORW]USEPLC
[M:SOI1]VLYDATITM = [M:SORW]VLYDATITM
[M:SOI1]STOFCY    = [M:SORW]STOFCY
[M:SOI1]EXTQTY    = [M:SORW]EXTQTY
[M:SOI1]EECICT    = [M:SORW]EECICT     : # Bug 72215
[M:SOI1]ICTCTY    = [M:SORW]ICTCTY     : # Bug 72215
[M:SOI1]FFWNUM    = [M:SORW]FFWNUM     : # Bug 72215
[M:SOI1]FFWADD    = [M:SORW]FFWADD     : # Bug 72215
# 105605 : CCM - Revision index (LD:03/06/15)
If dim([M:SOI1]ECCVALMAJ) > 0          : # Issue 116162
    [M:SOI1]ECCVALMAJ = [M:SORW]ECCVALMAJ
    [M:SOI1]ECCVALMIN = [M:SORW]ECCVALMIN
Endif                                  : # Issue 116162
# 105605 : CCM - Revision index (LD:03/06/15)

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Le PJT transite uniquement en intersite
If [M:SOR1]BETFCY=2 & [M:SOR1]BETCPY=1
    [M:SOI1]DPJT=[M:SORW]PJT
Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

[F:SOC]=[M:SOI1]

# 95742 : PJT en inter société/inter site : (LD:21/04/16)
[F:SOC]PJT=[M:SOI1]DPJT
# 95742 : PJT en inter société/inter site : (LD:21/04/16)

If dim([F:SOC]UPDDAT) >0 [F:SOC]UPDDAT = date$ : Endif
If dim([F:SOC]UPDUSR) >0 [F:SOC]UPDUSR = GUSER : Endif
If dim([F:SOC]EXPNUM) >0 [F:SOC]EXPNUM = [C]EXPORT : Endif

Rewrite [SOC]
If fstat
    GOK=0 : Call FSTA("SOH") From GLOCK
    [M:SORW]ERRCOD = 23 : Gosub TRT_ERR : Return
Endif

# --- Action : MODIF
# Réécriture du contrat pour incrémenter le no avenant
Gosub AVENANT
If GOK = 0 [M:SORW]ERRCOD = 11 : Gosub TRT_ERR : Return : Endif

# --> Gestion des signatures  : La modification d'une ligne article repasse le contrat a un statut non signé
If [M:SOR1]SOQSEQ=0 & WMODFLGSIG=1
  If GAPPSOC>1 [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif
Endif

# --> Gestion des signatures
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
    #----------------------------------------------------------------------------------------------------------#
    # Appel manuel du workflow car la règle est liée à l'objet SOR et non SOI (appel depuis l'objet inopérant) #
    #----------------------------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    #           2=Objet                                                                   #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    #           2=Après mise à jour classe [F]
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,2,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif

Return

# ------------------------------------------------------------------------------------ #
#     Suppression d'une ligne article miroir à partir d'une ligne article des achats   #
# ------------------------------------------------------------------------------------ #
$SUPPRESSION_SOC

# --- Lecture du contrat-article
Readlock [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
If fstat=1
    GOK=-1 : GLOCK = "$SORDERC"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOC", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)) From GLOCK
    [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : Return
Endif

# --> Gestion des signatures
# La suppression d'une ligne article repasse le contrat a un statut non signé
If GAPPSOC>1 & find([F:SOH]APPFLG, 2,3) [F:SOH]APPFLG=0 Else [F:SOH]APPFLG=4 : Endif

Delete [SOC] Where SOHNUM=[M:SORW]SOHNUM & SOPLIN=[M:SORW]SOPLIN
If fstat=1
    GOK=-1 : GLOCK = "$SORDERC"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOC", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)) From GLOCK
    [M:SORW]ERRCOD = 23 : Gosub TRT_ERR : Return
Endif

# --> Gestion des signatures
If GAPPSOC>1 & [M:SOR1]SOQSEQ=0
    #------------------------------------------------------------------------#
    # Positionnement indicateur "Annulé" sur les lignes de suivi de workflow #
    #------------------------------------------------------------------------#
    Call ANNULE_SUIVI("SOR",mess(653,197,1),1,WRET) From TRTVENDIV
    If GOK<1  Return : Endif
    # Appel manuel du workflow car la règle est liée à l'objet SOR et non SOI (appel depuis l'objet inopérant)
    # -- Déf des variables workflow
    Call WRKGLOB(171,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------#
    # Traitement d'un Workflow (normal)               #
    #-------------------------------------------------#
    Call WORKPLUS(2,"SOR","M",[F:SOH]SOHNUM,"",0,1,2,WGRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif

Return

# -------------------------------------------------------------------------------- #
#     Modification du contrat our incrémenter le n° avenant                        #
# -------------------------------------------------------------------------------- #
$AVENANT
If GITMREV = 2
   Readlock [SOH]SOH0 = [M]SOHNUM
   If !fstat
      [F:SOH]REVNUM = [M:SOR1]REVNUM
      Rewrite [SOH]
      If fstat  GOK=0 : Call FSTA("SOH") From GLOCK : Endif
   Endif
Endif
Return

#########################################################################
#                                                                       #
# CTL_MAJ_SOC : S/P de contrôle de mise à jour d'un contrat-article     #
#                                                                       #
#########################################################################
#                                                                       #
# S/P appelé en action AVANT_MOD : Modification d'un contrat-article    #
#                      VERF_ANU  : Suppression d'un contrat-article     #
#                                                                       #
# ----- Les paramêtres à passer avec l'écran SORW [SORW] -------------- #
#                                                                       #
# MAJCOD : Code mise à jour (M/A)                                       #
# SOHNUM : N° du contrat                                                #
# SOPLIN : N° de ligne du contrat-article                               #
#                                                                       #
# ----- Les paramêtres renvoyés --------------------------------------- #
#                                                                       #
# GMESSAGE : Libellé du message erreur ou ""                            #
# ERRCOD   : Code erreur ou 0                                           #
#                                                                       #
#########################################################################
Subprog CTL_MAJ_SOC

If [M:SORW]MAJCOD <> "A" End : Endif
If [M:SORW]SOHNUM =  "" | [M:SORW]SOPLIN = 0 End : Endif

Raz GMESSAGE, [M:SORW]ERRCOD
If clalev([F:SOC])=0 : Local File SORDERC    [SOC] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif

# --- Lecture du contrat-article
Read [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
If fstat [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : End : Endif
# --- Un Contrat/article est supprimable s'il ne contient pas de demandes de livraisons
Filter [SOQ] Where [SOQ]SOHNUM = [SOC]SOHNUM & [SOQ]SOPLIN = [SOC]SOPLIN
Read [SOQ]SOQ0 First
If fstat <> 4 [M:SORW]ERRCOD = 15 : Gosub TRT_ERR : Endif
Filter [SOQ]

End

#########################################################################
#########################################################################
# MAJ_SOQ : S/P de mise à jour d'une demande de livraison               #
#########################################################################
#                                                                       #
# S/P appelé en action VALLIG                                           #
#                                                                       #
#     appelé à l'intérieur d'une transaction, GOK = 1                   #
#                                                                       #
# ----- Les paramêtres à passer avec l'écran SORW [SORW] -------------- #
#                                                                       #
# MAJCOD    : Code mise à jour (C/M/A/S)                                #
# --------                                                              #
#     En Création : !! Avoir le masque complet chargé pr le transclasse #
#                                                                       #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# DEMDLVDAT : Date de demande de livraison                              #
# CAD       : Cadencement (1/2/3)                                       #
# YEA       : Année   si 1,2,3                                          #
# MON       : Mois    si 1,  3                                          #
# WEE       : Semaine si   2                                            #
# DLVDAY    : Jour    si 1                                              #
# USEPLC    : Lieu de conso                                             #
# QTY       : Quantité                                                  #
# DEMSTA    : Statut                                                    #
# SOQSTA    : Etat de la ligne                                          #
# POQSEQ    : N° de séquence de la DL correspondante                    #
# --------                                                              #
#     En Modif    :                                                     #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# SOQSEQ    : N° de séquence  de la DL                                  #
# USEPLC    : Lieu de conso                                             #
# QTY       : Quantité                                                  #
# DEMSTA    : Statut                                                    #
# SOQSTA    : Etat de la ligne                                          #
# --------                                                              #
#     En Suppression :                                                  #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# SOQSEQ    : N° de séquence  de la DL                                  #
# --------                                                              #
#     En Solde :                                                        #
# SOHNUM    : N° du contrat                                             #
# SOPLIN    : N° de la ligne contrat-article                            #
# SOQSEQ    : N° de séquence  de la DL                                  #
#                                                                       #
# ----- Les  paramêtres renvoyés -------------------------------------- #
#                                                                       #
# SOQSEQ    : N° de la séquence si création                             #
# GOK       : 1 ou <=0                                                  #
# GMESSAGE  : Libellé du message erreur ou ""                           #
# ERRCOD    : Code erreur ou 0                                          #
#                                                                       #
#########################################################################
Subprog MAJ_SOQ

Raz GMESSAGE
[M:SORW]ERRCOD=0

Gosub OUVRE_SOQ
If GOK=0 End : Endif

# Le n° du contrat et de la ligne article doivent être renseignés
If [M:SORW]SOHNUM = "" | [M:SORW]SOPLIN = 0
    [M:SORW]ERRCOD=98 : Gosub TRT_ERR : End
Endif

# --- Lecture du contrat
If [F:SOH]SOHNUM <> [M:SORW]SOHNUM
    Read [SOH]SOH0=[M:SORW]SOHNUM
    If fstat [M:SORW]ERRCOD = 12 : Gosub TRT_ERR : End : Endif
Endif
# --- Lecture de l'article
If [F:SOC]SOHNUM <> [M:SORW]SOHNUM | [F:SOC]SOPLIN <> [M:SORW]SOPLIN
    Read [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
    If fstat [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : End : Endif
Endif
Gosub LIENS_SOC
If GOK=0 End Endif

# --- Sélection du traitement demandé
Case [M:SORW]MAJCOD
  When "C"     : Gosub CREATION_SOQ
  When "M"     : Gosub MODIFICATION_SOQ
  When "A"     : Gosub SUPPRESSION_SOQ
  When "S"     : Gosub SOLDE_SOQ
  When Default :
Endcase

$FERME_SOQ
# --- Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#----------
End

# -------------------------------------------------------------------------------- #
#    OUVRE_SOQ                                                                     #
# -------------------------------------------------------------------------------- #
$OUVRE_SOQ
# ----- Ouverture tables
If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SOC])=0 : Local File SORDERC    [SOC] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif
If clalev([F:SOP])=0 : Local File SORDERP    [SOP] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPD])=0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:LCM])=0 : Local File LASTCUSMVT [LCM] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITU])=0 : Local File ITMBPC     [ITU] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TUV])=0 : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:TSO])=0 : Local File TABSOHTYP  [TSO] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

# --- Sauvegarde variables globales
Gosub SAUV_GLOB From TRTX3GLOB
Raz GWIP
GQSEQ = 0
GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4"

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK   [ORDK]
# --- Déclaration classe ecran pour les allocations --- #
Local Mask ALLPAR [ALP]

Local Integer STAT
Local Decimal WCPLQTY
Local Char    WTRTORD
Local Decimal WORDQTYCUM

Return

# -------------------------------------------------------------------------------- #
#    Lecture des fichiers nécessaire                                               #
# -------------------------------------------------------------------------------- #
$LIENS_SOC
If [F:BPC]BPCNUM <> [F:SOC]BPCORD
   Read [BPC]BPC0 = [F:SOC]BPCORD
   If fstat Raz [F:BPC] Endif
Endif
If [F:BPD]BPCNUM <> [F:SOC]BPCORD & [F:BPD]BPAADD <> [F:SOC]BPAADD
   Read [BPD]BPD0 = [F:SOC]BPCORD;[F:SOC]BPAADD
   If fstat Raz [F:BPD] Endif
Endif
If [F:ITM]ITMREF <> [F:SOC]ITMREF
   Read [ITM]ITM0 = [F:SOC]ITMREF
   If fstat Raz [F:ITM] Endif
Endif
If [F:ITS]ITMREF <> [F:SOC]ITMREF
   Read [ITS]ITS0 = [F:SOC]ITMREF
   If fstat Raz [F:ITS] Endif
Endif
If [F:ITU]ITMREF <> [F:SOC]ITMREF & [F:ITU]BPCNUM <> [F:SOC]BPCORD
   Read [ITU]ITU0 = [F:SOC]ITMREF;[F:SOC]BPCORD
   If fstat Raz [F:ITU] Endif
Endif
#If [F:SOH]SALFCY <> GFCY   : # Bug 77603
If [F:SOH]SALFCY <> ""      : # Bug 77603
   GFCY = [F:SOH]SALFCY
   #Call GETDEV(GFCY) From DEVSUB
   # Chargement des globales référenciels, comptes et sections de la société
   Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#  Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3

   Local Integer WRET
   If clalev([F:TCA]) = 0 : Local File TABCOUAFF [TCA] : Endif
   # --- Récupération du compteur des encours article
   Call LECTCA(7,WRET) From SUBTCA
   If fstat | !WRET
      [M:SORW]ERRCOD=26 : Gosub TRT_ERR : Return
   Endif
   GWIP=[F:TCA]CODNUM(8)
   Close Local File [TCA]
Endif
Return

# -------------------------------------------------------------------------------- #
#     Création d'une DL article miroir à partir d'une DL des achats                #
# -------------------------------------------------------------------------------- #
$CREATION_SOQ

Local Integer WSOQSEQ,WSUIV_SOQSEQ, WPREV_SOQSEQ
Local Integer WSUIV_CAD, WPREV_CAD
Local Date    WSUIV_DEMDLVDAT, WPREV_DEMDLVDAT

# --- En création la quantité doit être rensaignée
If [M:SORW]QTY    = 0  GOK=0 : [M:SORW]ERRCOD=98 : Gosub TRT_ERR : Return : Endif
# --- Récupération dans SORDERQ de la DL qui suit et la DL qui précède
Gosub RECH_PREV_SUIV
# --- Recherche du n° de séquence
Gosub RECH_SOQSEQ
If GOK=0 Return : Endif

Gosub ALISOQ
If GOK=0 Return : Endif

Write [SOQ]
If fstat
    GOK=0 : Call FSTA("SOQ") From GLOCK
    [M:SORW]ERRCOD = 31 : Gosub TRT_ERR : Return
Endif
# --- Maj des cumuls articles : En-cde client dans ITMMVT                             #
If [F:SOQ]STOMGTCOD <> 1
    Gosub MAJITV
    If GOK<1 : Return : Endif
Endif
# --- Génération de l'en-cours
If [F:SOQ]SOQSTA <> 3 & [F:SOQ]STOMGTCOD <> 1
    WCPLQTY = [F:SOQ]DLVQTYSTU
    WTRTORD="C" : Gosub APPELWIP From TRTVENMAJ
    If GOK<1 [M:SORW]ERRCOD = 33 : Gosub TRT_ERR : Return : Endif
Endif
# --- Mis à jour du cumul article
WORDQTYCUM = [F:SOQ]QTY : Gosub MAJ_CUM_SOC
If GOK < 1 Return : Endif

[M:SORW]SOQSEQ = [F:SOQ]SOQSEQ

Return

# -------------------------------------------------------------------------------- #
#     Alimentation de la DL : Alimentation de SORDERQ (SOQ)                        #
# -------------------------------------------------------------------------------- #
$ALISOQ

Raz [F:SOQ]

[F:SOQ] = [F:SOC]
[F:SOQ] = [M:SORW]

[F:SOQ]SOQSEQ = WSOQSEQ
[F:SOQ]POHNUM = [F:SOH]CUSORDREF
[F:SOQ]POPLIN = [F:SOQ]SOPLIN

[F:SOQ]SOQSTA = 1

[F:SOQ]SOHCAT = [F:SOH]SOHCAT
[F:SOQ]ALLTYP = [F:SOH]ALLTYP
[F:SOQ]DRN    = [F:BPD]DRN
[F:SOQ]DLVPIO = [F:BPD]DLVPIO
[F:SOQ]BPTNUM = [F:BPD]BPTNUM
[F:SOQ]MDL    = [F:BPD]MDL
[F:SOQ]DAYLTI = [F:BPD]DAYLTI

[F:SOQ]STOMGTCOD = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF<>[F:SOQ]ITMREF | [F:ITF]STOFCY<>[F:SOQ]STOFCY
        Read [ITF] ITF0=[F:SOQ]ITMREF ;[F:SOQ]STOFCY
        If fstat Raz [F:ITF] : Endif
    Endif
    If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD = [F:ITF]STOMGTCOD Endif
Endif

# 107890 : Scheduled invoices : (LD:10/06/16)
[F:SOQ]DLVFLG = [F:ITM]DLVFLG
# 107890 : Scheduled invoices : (LD:10/06/16)

# Issue X3-66385
#If [F:SOC]SAU=[F:ITU]SAU
#    [F:SOQ]PCK=[F:ITU]PCK : [F:SOQ]PCKCAP=[F:ITU]PCKCAP
#Elsif [F:SOC]SAU=[F:ITM]SAU
#    Call ALIPCK ([F:SOQ]ITMREF, [F:SOQ]STOFCY, [F:SOQ]PCK, [F:SOQ]PCKCAP) From TRTVENDIV
#Endif
# L'emballage est initialisé en priorité avec l'article client
# Il est initialisé avec l'article (article site ou catégorie article) uniquement si l'UV de l'article = l'UV de la ligne
# et si l'UV de l'article client = l'UV de la ligne mais il n'y a pas d'emballage pour l'article client
# ou si l'UV de l'article client est différente de l'UV de la ligne
# Package is initialized in priority with product customer
# It is initialized  with product (product site or product category) only if UV product= UV line
# and if UV product customer = UV line but there is no package for product customer
# or  if UV product customer <> UV line
If [F:SOC]SAU = [F:ITU]SAU
    [F:SOQ]PCK = [F:ITU]PCK : [F:SOQ]PCKCAP = [F:ITU]PCKCAP
Endif
If [F:SOQ]PCK = ""
    If [F:SOC]SAU = [F:ITM]SAU
      Call ALIPCK ([F:SOQ]ITMREF, [F:SOQ]STOFCY, [F:SOQ]PCK, [F:SOQ]PCKCAP) From TRTVENDIV
    Endif
Endif
# End issue X3-66385

If [F:ITU]ITSTEX <> ""
    [F:SOQ]SOQTEX = [F:ITU]ITSTEX
Else
    [F:SOQ]SOQTEX = [F:ITS]ITSTEX
Endif
If find(GSALTEXLIN,1,5) & [F:SOQ]SOQTEX="" [F:SOQ]SOQTEX=[F:SOC]SOCTEX : Endif
# --- Action champs : C_XDLVDAT
#     --> La date de livraison doit être <= à la date de fin de validité du contrat
If [F:SOQ]DEMDLVDAT > [F:SOC]VLYDATITM
    [M:SORW]ERRCOD = 21 : Gosub TRT_ERR : Return
Endif

If WPREV_CAD <> 0
# Cas où il y a des DL antérieures
#   --> Le Cadencement doit être >= au précédent
    If [F:SOQ]CAD < WPREV_CAD [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return : Endif
    If [F:SOQ]CAD = 1 & WPREV_CAD = 1
#   --> Si cadencement jour, la date de livraison doit être >= à la précédente
        If [F:SOQ]DEMDLVDAT < WPREV_DEMDLVDAT
            [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return
        Endif
    Else
#   --> Sinon la date de livraison doit être > à la précédente
        If [F:SOQ]DEMDLVDAT <= WPREV_DEMDLVDAT
            [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return
        Endif
    Endif
Endif
If WSUIV_CAD <> 0
# Cas où il y a des DL postérieures
    If [F:SOQ]CAD > WSUIV_CAD
        [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return
    Endif
    If [F:SOQ]CAD = 1 & WPREV_CAD = 1
#   --> Si cadencement jour, la date de livraison doit être <= à la précédente
        If [F:SOQ]DEMDLVDAT < WPREV_DEMDLVDAT
            [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return
        Endif
    Else
#   --> Sinon la date de livraison doit être < à la précédente
        If [F:SOQ]DEMDLVDAT <= WPREV_DEMDLVDAT
            [M:SORW]ERRCOD = 29 : Gosub TRT_ERR : Return
        Endif
    Endif
Endif

# --- Calcul date d'expédition si cadencement jour
If [F:SOQ]CAD = 1
#    [F:SOQ]SHIDAT = [F:SOQ]DEMDLVDAT - [F:SOQ]DAYLTI
#    Call CTL_JOU([F:SOQ]SHIDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
    Call CALC_SHIDAT([F:SOQ]DEMDLVDAT,[F:SOQ]DAYLTI,[F:SOQ]STOFCY,1,1,[0/0/0],[F:SOQ]SHIDAT) From TRTVENDAT
    If [F:SOQ]SHIDAT > [F:SOQ]DEMDLVDAT [M:SORW]ERRCOD = 28 : Gosub TRT_ERR : Return : Endif
    If [F:SOQ]SHIDAT < date$ [M:SORW]ERRCOD = 25 : Gosub TRT_ERR : Return : Endif
Endif
# --- Calcul de la qté en US
Call CNVQTY([F:SOQ]QTY,[F:SOC]SAUSTUCOE,[F:SOC]STU, [F:SOQ]QTYSTU) From TRTVENQTE

If dim([F:SOQ]CREDAT) >0 [F:SOQ]CREDAT = date$ : Endif
If dim([F:SOQ]CREUSR) >0 [F:SOQ]CREUSR = GUSER : Endif
If dim([F:SOQ]EXPNUM) >0 [F:SOQ]EXPNUM = [C]EXPORT : Endif

# --- Action : INICRE_LIG
[F:SOQ]ORDDAT = date$
[F:SOQ]ORIQTY = [F:SOQ]QTY
[F:SOQ]INVFLG = 1
[F:SOQ]FMI = 1

# --- Recup du chrono pour les en-cours
If clalev ([F:ITM]) <> 0 & [F:ITM]ITMREF = [F:SOQ]ITMREF & [F:SOQ]STOMGTCOD <> 1
    Call NUMERO(GWIP,[F:SOQ]STOFCY,[F:SOQ]ORDDAT,"",[F:SOQ]DEMNUM,STAT) From SUBANM
    If STAT <> 0 [M:SORW]ERRCOD = 30 : Return : Endif
Endif

If [F:SOQ]SOQTEX<>""
   If left$([F:SOQ]SOQTEX,3)="SOQ"
      Call CRE_CLOB([F:SOQ]SOQTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([F:SOQ]SOQTEX,3),"ITU","ITS")
      Call DUP_CLOB("SOQ",[F:SOQ]SOQTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
Endif
# Initialisation du code prépa
Local Char    WTSCCOD(GLONADI) (0..5)
Local Char    WTSICOD(GLONADI) (0..5)
Local Integer I
If dim([F:SOH]TSCCOD) <> -1
    For I = 1 To dim([F:SOH]TSCCOD)
        WTSCCOD(I-1) = [F:SOH]TSCCOD(I-1)
    Next I
Endif
If dim([F:SOC]TSICOD) <> -1
    For I = 1 To dim([F:SOC]TSICOD)
        WTSICOD(I-1) = [F:SOC]TSICOD(I-1)
    Next I
Endif

If [F:BPC]BPCNUM<>[F:SOH]BPCORD
   Read [BPC]BPC0=[F:SOH]BPCORD
   If fstat Raz [F:BPC] Endif
Endif

Call REC_PRECOD([F:SOQ]STOFCY,[F:SOQ]ITMREF,[F:ITM]TCLCOD,WTSICOD(0),WTSICOD(1),
&               WTSICOD(2),WTSICOD(3),WTSICOD(4),[F:SOH]BPCORD,[F:BPC]BCGCOD,
&               WTSCCOD(0),WTSCCOD(1),WTSCCOD(2),WTSCCOD(3),WTSCCOD(4),
&               [F:SOQ]PRECOD) From STKLIB

Gosub PE_ALISOQ

Return

$PE_ALISOQ
#-------------------------------------------------------#
# Point d'entrée pour alimenter des champs spécifiques  #
#-------------------------------------------------------#
GPOINT ="ALISOQ" : Gosub ENTREE From EXEFNC

Return

# --------------------------------------------------------------------- #
#     Recherche la DL qui suit et de la DL qui précède                  #
# --------------------------------------------------------------------- #
$RECH_PREV_SUIV

Raz WSUIV_SOQSEQ, WSUIV_CAD, WSUIV_DEMDLVDAT
Raz WPREV_SOQSEQ, WPREV_CAD, WPREV_DEMDLVDAT

If clalev([F:SOQ1]) <= 0 Local File SORDERQ [SOQ1] Endif

Columns [SOQ1] (SOQSEQ, CAD, DEMDLVDAT)

#Filter [SOQ1] Where SOHNUM = [M:SORW]SOHNUM & SOPLIN = [M:SORW]SOPLIN &    : # Bug 50102
#&                   DEMDLVDAT > [M:SORW]DEMDLVDAT                          : # Bug 50102
Filter [SOQ1] Where SOHNUM = [M:SORW]SOHNUM & SOPLIN = [M:SORW]SOPLIN &
&                   DEMDLVDAT >= [M:SORW]DEMDLVDAT & SOQSEQ>=[M:SORW]POQSEQ : # Bug 50102
Read First
If !fstat
    WSUIV_SOQSEQ = [F:SOQ1]SOQSEQ
    WSUIV_CAD = [F:SOQ1]CAD : WSUIV_DEMDLVDAT = [F:SOQ1]DEMDLVDAT
Endif

Filter [SOQ1]

#Filter [SOQ1] Where SOHNUM = [M:SORW]SOHNUM & SOPLIN = [M:SORW]SOPLIN &    : # Bug 50102
#&                   DEMDLVDAT <= [M:SORW]DEMDLVDAT                         : # Bug 50102
Filter [SOQ1] Where SOHNUM = [M:SORW]SOHNUM & SOPLIN = [M:SORW]SOPLIN &
&                   DEMDLVDAT <= [M:SORW]DEMDLVDAT & SOQSEQ<=[M:SORW]POQSEQ : # Bug 50102
Read Last
If !fstat
    WPREV_SOQSEQ = [F:SOQ1]SOQSEQ
    WPREV_CAD = [F:SOQ1]CAD : WPREV_DEMDLVDAT = [F:SOQ1]DEMDLVDAT
Endif

Filter [SOQ1]

Columns [SOQ1]

Return

# --------------------------------------------------------------------- #
#     Recherche du n° de séquence                                       #
# --------------------------------------------------------------------- #
$RECH_SOQSEQ

Local Integer WDELTA
Raz WDELTA,WSOQSEQ

#----- Prendre de préférence le même numéro de séquence que la DL d'achat -----#
If [M:SORW]POQSEQ>WPREV_SOQSEQ & (!WSUIV_SOQSEQ | [M:SORW]POQSEQ<WSUIV_SOQSEQ)
  WSOQSEQ=[M:SORW]POQSEQ : Return
Endif

# --- C'est la 1ère DL
If !WPREV_SOQSEQ & !WSUIV_SOQSEQ WSOQSEQ = 1000 : Return : Endif

If WSUIV_SOQSEQ = 0
# --- Il n'y a pas d'enregistrement suivant
   If    WPREV_SOQSEQ < 99998000 : WDELTA = 1000
   Elsif WPREV_SOQSEQ < 99999998 : WDELTA = (99999999-WPREV_SOQSEQ)/2
   Elsif WPREV_SOQSEQ = 99999998 : WDELTA = 1
# Sinon  WPREV_SOQSEQ = 99999999 Aucune insertion n'est possible
   Endif
Else
   WDELTA = (WSUIV_SOQSEQ-WPREV_SOQSEQ)/2
Endif

If WDELTA <> 0
   WSOQSEQ = WPREV_SOQSEQ + WDELTA
Endif

# --- Impossible d'attribuer un no de séquence
If WSOQSEQ = 0
    [M:SORW]ERRCOD = 27 : Gosub TRT_ERR : Return
Endif

Return

# -------------------------------------------------------------------------------- #
#     Modification des cumuls du SORDERC après crea/modif/supp d'une DL            #
# -------------------------------------------------------------------------------- #
$MAJ_CUM_SOC
Readlock [SOC]SOC0=[M:SORW]SOHNUM;[M:SORW]SOPLIN
If fstat=1
    GOK=-1 : GLOCK = "$SORDERC"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOC", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)) From GLOCK
    [M:SORW]ERRCOD = 24 : Gosub TRT_ERR : Return
Endif

[F:SOC]ORDQTYCUM +=WORDQTYCUM

Rewrite [SOC]
If fstat
    GOK=0 : Call FSTA("SOC") From GLOCK
    [M:SORW]ERRCOD = 23 : Gosub TRT_ERR : Return
Endif

Return

#---------------------------------------------------------------------------------#
# Maj des cumuls articles : En-cde client dans ITMMVT                             #
#---------------------------------------------------------------------------------#
$MAJITV
Local Decimal WQTY
Local Char    WSENS   :    Raz WSENS
Local Char    WTYP    :    WTYP="S"
Local Integer WRET
# Calcul du reste à livrer
#--- Bug 31537
#WQTY = [F:SOQ]QTYSTU - [F:SOQ]DLVQTYSTU - [F:SOQ]ODLQTYSTU
WQTY = [F:SOQ]QTYSTU - [F:SOQ]DLVQTYSTU
#--------------
Case [M:SORW]MAJCOD
    When "C" :    # Création
#       Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
        If [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1 Return : Endif
        WSENS="+"
    When "M" :    # Modification
#       Si la ligne devient soldée ou devient non ferme
#       -- Décrémentation de l'En-cde
        If [F:SOQ]SOQSTA<>3 & [M:SORW]SOQSTA=3 | [F:SOQ]DEMSTA=1 & [M:SORW]DEMSTA<>1
            WSENS="-"
#       Si la ligne est désoldée ou devient ferme
#       -- Incrémentation de l'En-cde
        Elsif [F:SOQ]SOQSTA=3 & [M:SORW]SOQSTA<>3 | [F:SOQ]DEMSTA<>1 & [M:SORW]DEMSTA=1
            WSENS="+"
            WQTY+= WNVXQTYSTU
#       Si la qté est modifiée (et ligne non soldée et ferme)
#       -- Modification de l'En-cde
        Elsif [F:SOQ]QTY<>[M:SORW]QTY & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMSTA=1
            WSENS="+"
            # Calcul du reste à livrer
            WQTY = WNVXQTYSTU
        Endif
    When "A" :    # Suppression
#       Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
        If [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1 Return : Endif
        WSENS="-"
    When "S" :   # Solde/Désolde
        If [F:SOQ]SOQSTA=3
            # La ligne était soldée, on la désolde     : Création
            WSENS="+"
        Else
            # La ligne n'était pas soldée, on la solde : Suppression
            WSENS="-"
        Endif
Endcase
If WSENS="" Return Endif
Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WQTY, WSENS, WTYP, WRET) From TRTVENMAJ
If WRET<>0 Return : Endif
Return


# -------------------------------------------------------------------------------- #
#     Modification d'une DL article miroir à partir d'une DL des achats            #
# -------------------------------------------------------------------------------- #
$MODIFICATION_SOQ
Local Integer WFLGSTA : # 0=Rien; 1=Désolde; 3=Solde
Local Integer WFLGWIP : # 0=Rien; 1=Modif
Local Decimal WCPLQTY, WNVXQTYSTU

# --- Lecture de la DL
Read [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat [M:SORW]ERRCOD = 32 : Gosub TRT_ERR : Return :Endif

# --- Contrôle s'il y a des zones à modifier
# 105605 : CCM - Revision index (LD:04/06/15)
# Ajout ECCVALMAJ ECCVALMIN
# 105605 : CCM - Revision index (LD:04/06/15)
# Issue 116162
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Ajout PJT
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
If [M:SORW]USEPLC    = [F:SOQ]USEPLC &
&  [M:SORW]DEMSTA    = [F:SOQ]DEMSTA &
&  [M:SORW]SOQSTA    = [F:SOQ]SOQSTA &
&  (dim([M:SORW]ECCVALMAJ)<=0 | (dim([M:SORW]ECCVALMAJ)>0 & [M:SORW]ECCVALMAJ=[F:SOQ]ECCVALMAJ)) &
&  (dim([M:SORW]ECCVALMIN)<=0 | (dim([M:SORW]ECCVALMIN)>0 & [M:SORW]ECCVALMIN=[F:SOQ]ECCVALMIN)) &
&  [M:SORW]PJT       = [F:SOQ]PJT &
&  ([F:SOQ]QTY + [M:SORW]QTY) = [F:SOQ]QTY Return : Endif

# --- Positionnement flag Solde/Désolde de la ligne
If [M:SORW]SOQSTA <> [F:SOQ]SOQSTA WFLGSTA = [M:SORW]SOQSTA : Endif
# --- Positionnement flag Modif de l'en-cours
If [M:SORW]DEMSTA    <> [F:SOQ]DEMSTA |
&  ([F:SOQ]QTY + [M:SORW]QTY) <> [F:SOQ]QTY |
&  WFLGSTA =1                      WFLGWIP = 1: Endif

Readlock [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat=1
    GOK=-1 : GLOCK = "$SORDERQ"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOQ", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)) From GLOCK
    [M:SORW]ERRCOD = 32 : Gosub TRT_ERR : Return
Endif

WORDQTYCUM -= [F:SOQ]QTY

# --- Si solde de la ligne
#     --> On supprime les allocations ruptures
If WFLGSTA = 3 & [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1
    If [F:SOQ]SHTQTY <> 0 Gosub TRT_DEL_SHTQTY Endif
    If GOK<1 Return : Endif
Endif

# --- Maj des cumuls articles : En-cde client dans ITMMVT
If [F:SOQ]STOMGTCOD <> 1
    Call CNVQTY([M:SORW]QTY,[F:SOC]SAUSTUCOE,[F:SOC]STU, WNVXQTYSTU) From TRTVENQTE
    Gosub MAJITV
    If GOK<1 : Return : Endif
Endif

WCPLQTY = [F:SOQ]DLVQTYSTU
# --- Si solde de la ligne et pas d'encours de livraison ou modification du statut
#     --> On supprime l'en-cours
If ((WFLGSTA = 3 & [F:SOQ]ODLQTYSTU=0) | [F:SOQ]DEMSTA <> [M:SORW]DEMSTA) & [F:SOQ]STOMGTCOD <> 1
    WTRTORD="A" : Gosub APPELWIP From TRTVENMAJ
    If GOK<1 [M:SORW]ERRCOD = 33 : Gosub TRT_ERR : Return : Endif
Endif

# --- Alimentation des zones modifiées
[F:SOQ]USEPLC = [M:SORW]USEPLC
[F:SOQ]DEMSTA = [M:SORW]DEMSTA
[F:SOQ]QTY    = [F:SOQ]QTY + [M:SORW]QTY

#Call SCAL_QUS([F:SOQ]QTY,[F:SOQ]ITMREF,[F:SOQ]BPCORD,[F:SOC]SAU,[F:SOC]STU,
#& [F:SOQ]QTYSTU,GBIDD1) From TRTVENQTE
Call CNVQTY([F:SOQ]QTY,[F:SOC]SAUSTUCOE,[F:SOC]STU, [F:SOQ]QTYSTU) From TRTVENQTE

# ---
If ([F:SOQ]QTY - [F:SOQ]ALLQTY) < [F:SOQ]SHTQTY
   [F:SOQ]SHTQTY    = [F:SOQ]QTY - [F:SOQ]ALLQTY
   [F:SOQ]SHTQTYSTU = [F:SOQ]QTYSTU - [F:SOQ]ALLQTYSTU
Endif

# 105605 : CCM - Revision index (LD:04/06/15)
If dim([M:SORW]ECCVALMAJ) > 0         : # Issue 116162
    [F:SOQ]ECCVALMAJ = [M:SORW]ECCVALMAJ
    [F:SOQ]ECCVALMIN = [M:SORW]ECCVALMIN
Endif                                 : # Issue 116162
# 105605 : CCM - Revision index (LD:04/06/15)

If dim([F:SOQ]UPDDAT) >0 [F:SOQ]UPDDAT = date$ : Endif
If dim([F:SOQ]UPDUSR) >0 [F:SOQ]UPDUSR = GUSER : Endif
If dim([F:SOQ]EXPNUM) >0 [F:SOQ]EXPNUM = [C]EXPORT : Endif

Gosub PE_ALISOQ

Rewrite [SOQ]
If fstat
    GOK=0 : Call FSTA("SOQ") From GLOCK
    [M:SORW]ERRCOD = 31 : Gosub TRT_ERR : Return
Endif
# --- Si changement de la qté, du statut de la dde ou si désolde
#     --> Modification de l'en-cours
If WFLGWIP = 1 & [F:SOQ]STOMGTCOD <> 1
    WTRTORD="M" : Gosub APPELWIP From TRTVENMAJ
    If GOK<1 [M:SORW]ERRCOD = 33 : Gosub TRT_ERR : Return : Endif
Endif
WORDQTYCUM += [F:SOQ]QTY : Gosub MAJ_CUM_SOC
If GOK<1 Return : Endif

Return

# -------------------------------------------------------------------------------- #
# Suppression des allocations rupture dans le cas du solde d'une ligne             #
#--------------------------------------------------------------------------------- #
#$ANCTRT_DEL_SHTQTY
#Local Char    WSOHNUM : WSOHNUM = [F:SOQ]SOHNUM
#Local Decimal WSOPLIN : WSOPLIN = [F:SOQ]SOPLIN
#Local Decimal WSOQSEQ : WSOQSEQ = [F:SOQ]SOQSEQ
#Local Char    WITM    : WITM    = [F:SOQ]ITMREF
#Local Integer WTYP    : WTYP    = 2
#Local Decimal WQTY, WSHT
#Local Integer WRET

#Case [F:SOQ]ALLTYP
#  When 1 :
#    WQTY = 0 : WSHT = [F:SOQ]SHTQTYSTU : WRET = 0
#    Call DELGLO(WTYP,WSOHNUM,WSOPLIN,WSOQSEQ,WITM,2,WQTY,WSHT, WRET) From ALLLIB
#    If WRET <> 0 : [M:SORW]ERRCOD = 34 : Gosub TRT_ERR : Return : Endif
#    [F:SOQ]SHTQTYSTU = 0
#  When 2 :
#    WQTY = 0 : WSHT = 0 : WRET = 0
#    Call DELALL(WTYP,WSOHNUM,WSOPLIN,WSOQSEQ,"",2,WQTY,WSHT,WRET) From ALLLIB
#    If WRET <> 0 : [M:SORW]ERRCOD = 34 : Gosub TRT_ERR : Return : Endif
#    [F:SOQ]SHTQTYSTU = 0
#Endcase
#Return

# -------------------------------------------------------------------------------- #
# Suppression des allocations rupture                                              #
#--------------------------------------------------------------------------------- #
$TRT_DEL_SHTQTY

Local  Integer  WRET
Local  Decimal  WALLQTYSTU, WSHTQTYSTU
WSUPALL=1
WALLQTYSTU=[F:SOQ]ALLQTYSTU
WSHTQTYSTU=[F:SOQ]SHTQTYSTU
Call GENALLORD("","","A", 1, 1, 0, WALLQTYSTU, WSHTQTYSTU, WRET) From TRTVENALL
If WRET=1 [M:SORW]ERRCOD = 34 : Gosub TRT_ERR : Return : Endif
If WSHTQTYSTU<>[F:SOQ]SHTQTYSTU  [M:SORW]ERRCOD = 34 : Gosub TRT_ERR : Return : Endif
[F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
Return

# -------------------------------------------------------------------------------- #
#     Suppression d'une DL article miroir à partir d'une DL des achats             #
# -------------------------------------------------------------------------------- #
$SUPPRESSION_SOQ

# --- Lecture de la DL
Readlock [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat=1
    GOK=-1 : GLOCK = "$SORDERQ"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOQ", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)) From GLOCK
    [M:SORW]ERRCOD = 32 : Gosub TRT_ERR : Return
Endif

# --- Suppression texte ligne
If left$([F:SOQ]SOQTEX,3)="SOQ"
    Call SUP_CLOB([F:SOQ]SOQTEX,WRET) From TRTX3TEX
    If WRET=0 GOK=0 : Return Endif
Endif

# A SUPPRIMER
#Local Integer WRETOUR
#If [F:SOQ]SOQTEX <> ""
#    WRETOUR = 0
#    Call TEX(5,"SOQ1","","","",[F:SOQ]SOQTEX,"A",WRETOUR) From TRTX3TEX
#Endif

# --- Maj des cumuls articles : En-cde client dans ITMMVT                             #
If [F:SOQ]STOMGTCOD <> 1
    Gosub MAJITV
    If GOK<1 : Return : Endif
Endif
WCPLQTY = [F:SOQ]DLVQTYSTU
# --> On supprime les allocations ruptures
If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & [F:SOQ]SHTQTY <> 0
    Gosub TRT_DEL_SHTQTY
    If GOK<1 Return : Endif
    [F:SOQ]SHTQTY=0
Endif
# --- Suppression de l'en-cours
If [F:SOQ]STOMGTCOD <> 1
    WTRTORD="A" : Gosub APPELWIP From TRTVENMAJ
    If GOK<1 [M:SORW]ERRCOD = 33 : Gosub TRT_ERR : Return : Endif
Endif
WORDQTYCUM -= [F:SOQ]QTY : Gosub MAJ_CUM_SOC
If GOK<1 Return : Endif

Delete [SOQ] Where SOHNUM=[M:SORW]SOHNUM & SOPLIN=[M:SORW]SOPLIN & SOQSEQ=[M:SORW]SOQSEQ
If fstat=1
    GOK=-1 : GLOCK = "$SORDERQ"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOQ", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)) From GLOCK
    [M:SORW]ERRCOD = 31 : Gosub TRT_ERR : Return
Endif

Return


# -------------------------------------------------------------------------------- #
#     Solde d'une DL article miroir à partir d'une DL des achats                   #
# -------------------------------------------------------------------------------- #
$SOLDE_SOQ

# --- Lecture de la DL
Readlock [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat=1
    GOK=-1 : GLOCK = "$SORDERQ"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ) : Return
Elsif fstat
    GOK=0 : Call RSTA("SOQ", [M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)) From GLOCK
    [M:SORW]ERRCOD = 32 : Gosub TRT_ERR : Return
Endif

# --> On supprime les allocations ruptures
If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & [F:SOQ]SHTQTY <> 0
    Gosub TRT_DEL_SHTQTY
    If GOK<1 Return : Endif
    [F:SOQ]SHTQTY=0
Endif
# --- Maj des cumuls articles : En-cde client dans ITMMVT                             #
If [F:SOQ]STOMGTCOD <> 1
    Gosub MAJITV
    If GOK<1 : Return : Endif
Endif
WCPLQTY = [F:SOQ]DLVQTYSTU
# --> On supprime l'en-cours
If [F:SOQ]DEMNUM <> "" & [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]ODLQTYSTU = 0
    WTRTORD="A" : Gosub APPELWIP From TRTVENMAJ
    If GOK<1 [M:SORW]ERRCOD = 33 : Gosub TRT_ERR : Return : Endif
Endif

If [F:SOQ]SOQSTA=3
#    Désolde de la ligne
   If [F:SOQ]DEMDLVDAT < date$
      [F:SOQ]SOQSTA = 2
#  Ligne en attente
   Else
      [F:SOQ]SOQSTA = 1
   Endif
Else
#    Solde de la ligne
    [F:SOQ]SOQSTA = 3
Endif

Rewrite [SOQ]
If fstat
    GOK=0 : Call FSTA("SOQ") From GLOCK
    [M:SORW]ERRCOD = 31 : Gosub TRT_ERR : Return
Endif

Return

#############################################################################
#                                                                           #
# CTL_MAJ_SOQ : S/P de contrôle de mise à jour d'une DL                     #
#                                                                           #
#############################################################################
#                                                                           #
# S/P appelé en action champs C_NBLIG                                       #
#                                                                           #
# --------                                                                  #
# Les paramêtres à passer avec l'écran SORW [SORW]                          #
# --------                                                                  #
# MAJCOD : Code mise à jour (M /A /S (Solde)/Q (modif Qté)/ T (modif statut)#
# SOHNUM : N° du contrat                                                    #
# SOPLIN : N° de la ligne contrat-article                                   #
# SOQSEQ : N° de séquence de la DL                                          #
# --------                                                                  #
# Les paramêtres renvoyés                                                   #
# --------                                                                  #
# QTY      : En ctrl de modif, renvoi de la qté cdée non encoree allouée    #
# GMESSAGE : Libellé du message erreur ou ""                                #
# ERRCOD   : Code erreur ou 0                                               #
#                                                                           #
#############################################################################
Subprog CTL_MAJ_SOQ

Raz GMESSAGE, [M:SORW]ERRCOD
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif

# --- Lecture de la DL
Read [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat
    [M:SORW]ERRCOD = 32
    GMESSAGE = mess(150,192,1)-"SORDERQ:"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)
    End
Endif

Local Decimal WQTY1 : # Quantité allouée ou préparée
WQTY1 = [F:SOQ]ALLQTY+[F:SOQ]LPRQTY+[F:SOQ]OPRQTY+[F:SOQ]PREQTY
Local Decimal WQTY2 : # Quantité allouée ou préparée ou livrée
WQTY2 = WQTY1+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
Local Decimal WQTY3 : # Quantité allouée (rupture comprise) ou préparée ou livrée
WQTY3 = WQTY2+[F:SOQ]SHTQTY

If [M:SORW]MAJCOD = "A"
#------------------------------#
# Test de suppression de ligne #
#------------------------------#
# --> pas de suppression si ligne soldée ou allouée/préparée/livrée
#    If ([F:SOQ]SOQSTA = 3 | sum([F:SOQ]ALLQTY,[F:SOQ]LPRQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY,[F:SOQ]ODLQTY,[F:SOQ]DLVQTY)<>0
    If ([F:SOQ]SOQSTA = 3 | WQTY2 <> 0)
        [M:SORW]ERRCOD = 36 : GMESSAGE = mess(311,192,1)
    Endif
Endif
If [M:SORW]MAJCOD = "M"
#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
# --> pas de modification si ligne soldee
    If [F:SOQ]SOQSTA = 3
        If [F:SOQ]DLVQTY <> 0 | [F:SOQ]ODLQTY <> 0
            [M:SORW]ERRCOD = 40
            GMESSAGE=mess(164,192,1)+"\"+mess(40,191,1)+":"+format$("N:15F",[F:SOQ]DLVQTY+[F:SOQ]ODLQTY)
        Else
            [M:SORW]ERRCOD = 37 : GMESSAGE = mess(18,192,1)
        Endif
    Endif
Endif
If [M:SORW]MAJCOD = "S"
#-------------------------------#
# Test de solde de  ligne       #
#-------------------------------#
# --> pas de solde s'il y a une allocation ou une préparation
#    If [F:SOQ]ALLQTY <> 0
    If WQTY1 <> 0
        [M:SORW]ERRCOD = 36 : GMESSAGE = mess(311,192,1)
    Endif
# Pas de ctrl de désolde : normallement c'est ds les achats
Endif

If [M:SORW]MAJCOD = "Q"
#-------------------------------------#
# Test de modification de la quantité #
#-------------------------------------#
    # La qté commandée ne doit pas être inférieure à ce qui est déjà alloué/préparé/livré/facturé
#    If  [M:SORW]QTY < ([F:SOQ]ALLQTY + [F:SOQ]SHTQTY)
#&     | [M:SORW]QTY < ([F:SOQ]ODLQTY + [F:SOQ]DLVQTY)
    If  [M:SORW]QTY < WQTY3
        [M:SORW]ERRCOD=38 : GMESSAGE = mess(312,192,1)
    Endif
    [M:SORW]QTY = [F:SOQ]QTY - ([F:SOQ]ALLQTY + [F:SOQ]SHTQTY)
Endif
If [M:SORW]MAJCOD = "T"
#-------------------------------------#
# Test de modification du statut (LLC)#
#-------------------------------------#
#    If [F:SOQ]ALLQTY <> 0 | [F:SOQ]SHTQTY <> 0
    If WQTY3<>0 [M:SORW]ERRCOD=36 : GMESSAGE = mess(311,192,1) : Endif
    If [F:SOQ]CAD <> 1
        [M:SORW]ERRCOD=39
    Endif
Endif
End

#########################################################################
#                                                                       #
# RECH_NUM_SEQ : S/P de recherche d'un n° séquence DL vente à mettre en #
#                       correspondance avec un n° séquence DL achat     #
#                                                                       #
#########################################################################
#                                                                       #
# S/P appelé ???                                                        #
#                                                                       #
# --------                                                              #
# Les paramêtres à passer avec l'écran SORW [SORW]                      #
# --------                                                              #
# SOHNUM : N° du contrat vente                                          #
# SOPLIN : N° de la ligne contrat-article vente                         #
# SOQSEQ : N° de séquence de la DL vente                                #
# POHNUM : N° du contrat achat                                          #
# POPLIN : N° de la ligne contrat-article achat                         #
# POQSEQ : N° de séquence de la DL achat                                #
# --------                                                              #
# Les paramêtres renvoyés                                               #
# --------                                                              #
# SOQSEQ   : N° de séquence de la DL vente trouvée si ERRCOD=0          #
# GMESSAGE : Libellé du message erreur ou ""                            #
# ERRCOD   : Code erreur ou 0                                           #
#                                                                       #
#########################################################################
Subprog RECH_NUM_SEQ

Local Char    WPOHNUM
Local Integer WPOPLIN, WPOQSEQ

Raz GMESSAGE, [M:SORW]ERRCOD
If clalev([F:SOQ])=0   Local File SORDERQ    [SOQ] : Endif

# --- Lecture de la DL origine
Read [SOQ]SOQ0=[M:SORW]SOHNUM;[M:SORW]SOPLIN;[M:SORW]SOQSEQ
If fstat
    [M:SORW]ERRCOD = 32
    GMESSAGE = mess(150,192,1)-"SORDERQ:"-[M:SORW]SOHNUM-num$([M:SORW]SOPLIN)-num$([M:SORW]SOQSEQ)
    End
Endif
WPOHNUM=[F:SOQ]POHNUM
WPOPLIN=[F:SOQ]POPLIN
WPOQSEQ=[F:SOQ]POQSEQ
# --- Recherche de la DL qui a éte générée à la livraison à partir de la DL origine
#     Elle a le même n° DL achat
Filter [SOQ] Where POHNUM = WPOHNUM & POPLIN = WPOPLIN & POQSEQ = WPOQSEQ &
&                  SOHNUM = [M:SORW]SOHNUM & SOPLIN = [M:SORW]SOPLIN & SOQSEQ <> [M:SORW]SOQSEQ
Read [SOQ]SOQ0 First
If !fstat
#   --- On a trouvé une ligne : Elle doit être unique
    Look [SOQ]SOQ0 Next
    If !fstat [M:SORW]ERRCOD=99 : Gosub FIN_RECH : End : Endif
#   --- La ligne trouvée est unique
#       --> Mise à jour du N° séquence achat et renvoi du N° séquence vente
    Readlock [SOQ]SOQ0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
    If fstat=1
        GOK=-1 : GLOCK = "$SORDER"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
        [M:SORW]ERRCOD = 99 : Gosub FIN_RECH : End
    Elsif fstat
        GOK=0 : Call RSTA("SOQ", [F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK
        [M:SORW]ERRCOD = 32
        GMESSAGE = mess(150,192,1)-"SORDERQ:"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
        Gosub FIN_RECH : End
    Endif
    [F:SOQ]POQSEQ = [M:SORW]POQSEQ
    Rewrite [SOQ]
    If fstat
        GOK=0 : Call FSTA("SOQ") From GLOCK
        [M:SORW]ERRCOD = 31
        GMESSAGE = mess(150,192,1)-"SORDERQ:"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
        Gosub FIN_RECH : End
    Endif
    [M:SORW]SOQSEQ=[F:SOQ]SOQSEQ
Else
#   --- On a trouvé aucune ligne
    [M:SORW]ERRCOD=99
Endif

$FIN_RECH
Filter [SOQ]

End
#########################################################################
#########################################################################
#    SOUS-PRO UTILISES POUR TESTER LES COMPOSANTS                       #
#########################################################################
#########################################################################
Subprog AUTSOH

Local Mask SORW [SORW]
Raz [M:SORW]

#Goto MOD_SOH

[M:SORW]MAJCOD = "C"
[M:SORW]BPCORD = "LD3"
[M:SORW]SALFCY = "MAR"
[M:SORW]VLYDATCON = [01/02/2000]
[M:SORW]POHNUM = "ACH-OUV-001"
Goto SUI_SOH

$MOD_SOH
[M:SORW]MAJCOD = "M"
[M:SORW]SOHNUM = "OUV-MAR99000020"
[M:SORW]VLYDATCON = [01/02/2000]
Goto SUI_SOH

$SUP_SOH
[M:SORW]MAJCOD = "A"
[M:SORW]SOHNUM = "OUV-MAR99000020"
[M:SORW]VLYDATCON = [31/12/1999]

$SUI_SOH
If [M:SORW]MAJCOD = "A"
    Raz GMESSAGE
    Call CTL_MAJ_SOH
    If [M:SORW]ERRCOD <> 0 Infbox ("ERREUR :"+num$([M:SORW]ERRCOD)+GMESSAGE) : End : Endif
Endif

Call DEBTRANS From GLOCK

Gosub SOH_TR1

If [M:SORW]ERRCOD <> 0
    Infbox ("Erreur :"+num$([M:SORW]ERRCOD)+GMESSAGE)
Else
    Infbox ([M:SORW]MAJCOD+ "Commande :"+[M:SORW]SOHNUM)
Endif

End

$SOH_TR1
GOK = 1
Trbegin ADOVAL
    Call MAJ_SOH
    If GOK < 0 Goto ROLL_MAJSOH
    Elsif !GOK Goto AB_MAJSOH
    Endif
Commit
Return

$ROLL_MAJSOH
Rollback
Call ROLL From GLOCK
If !GROLL Goto SOH_TR1 Endif
Return

$AB_MAJSOH
Rollback
Return
