#########################################################################
Subprog RECHSOQ

Local Mask SORW [SORW]
Raz [M:SORW]

[M:SORW]SOHNUM = "OUV-MAR99000023"
[M:SORW]SOPLIN = 1
[M:SORW]SOQSEQ = 2000

[M:SORW]POHNUM = "ACH-OUV-023"
[M:SORW]POPLIN = 1
[M:SORW]POQSEQ = 2500

Call RECH_NUM_SEQ
If [M:SORW]ERRCOD <> 0 Infbox ("Erreur :"+num$([M:SORW]ERRCOD)+GMESSAGE) : End : Endif

End

