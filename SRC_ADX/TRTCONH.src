#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la saisie du parc couvert                   Module CRM        24 avril 2003
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "RAF"          : Gosub REFRESH
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
   Endcase
Return

##########################################################################################################
$REFRESH
  Call TEMPON("L") From GESECRAN
  [M:CONH]PRECONHNOL = 0
  Call LOADITM
  Call TEMPOFF From GESECRAN
  Affzo [M:CONH]1-99
Return

##########################################################################################################
$OUVRE
Global Integer GINSERT
Global Char GSZCONHCONNUM(GLONDCO)

Local Char SZCONTXT(GLONDCO)

  Local File CONTCOV [CCVX]
  #PARAM(1) = Code contrat de service
  #PARAM(2) = Devise
  #PARAM(3) = Flag modèle
  #PARAM(4) = Code client
  #PARAM(5) = Famille de compétence
  #PARAM(6) = Couverture croisée identique
  #
  #Si aucun contrat de service on ne peut rien faire.
  If PARAM(1) = "" Then
    #Aucun code de contrat de service n'a été obtenu. Action abandonnée.
    GMESSAGE = mess(265,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  #Si aucun code client on ne peut rien faire.
  If val(PARAM(3)) <> 2 Then
    If PARAM(4) = "" Then
      #Aucun code client n'a été communiqué. Action abandonnée.
      GMESSAGE = mess(292,182,1)
      GERR = 1
      FIN = 1
      Return
    Endif
  Endif
  If val(PARAM(3)) = 2 Then
    SZCONTXT = mess(418,182,1)                 #Modèle n°
  Else
    Call TEXTE(16090, SZCONTXT) From OBJDIV      #Contrat n°
  Endif
  GSZCONHCONNUM = SZCONTXT + PARAM(1)
  GINSERT = 0
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCONH"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:CONH]DIRTYFLG Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Char SZDES(GLONDCO)  # FGR 23/09/2009 : X3SUIVI58024

  [M:CONH]PRECONHNOL = 0
  [M:CONH]CONNUM = PARAM(1)
  [M:CONH]CUR = PARAM(2)
  [M:CONH]TPL = val(PARAM(3))
  [M:CONH]CONBPC = PARAM(4)
  [M:CONH]CONPBL = PARAM(5)
  [M:CONH]CRSCOVSAM = val(PARAM(6))
  If [M:CONH]TPL = 2 Then
    Read [COT]COT0=[M:CONH]CONNUM
    If fstat Then
      [M:CONH]CONNAM = GSZCONHCONNUM
    Else
      [M:CONH]CONNAM = [F:COT]TPLNAM
    Endif
  Else
    Read [CON]CON0=[M:CONH]CONNUM
    If fstat Then
      [M:CONH]CONNAM = GSZCONHCONNUM
    Else
      [M:CONH]CONNAM = [F:CON]CONNAM
    Endif
  Endif
  If [M:CONH]CONPBL = "" Then
    [M:CONH]PBLCRS = ""
  Else
    #Croisement avec la compétence :
    Read [PBL]PBL0=[M:CONH]CONPBL
    If fstat Then
      [M:CONH]PBLCRS = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #If [F:PBL]GRPPBLDES = "" Then
      #  [M:CONH]PBLCRS = mess(295,182,1) - ":" - [F:PBL]NUM
      #Else
      #  [M:CONH]PBLCRS = mess(295,182,1) - ":" - [F:PBL]GRPPBLDES
      #Endif
      Call LECTEXTRA(SZDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      If SZDES = "" Then
        [M:CONH]PBLCRS = mess(295,182,1) - ":" - [F:PBL]NUM
      Else
        [M:CONH]PBLCRS = mess(295,182,1) - ":" - SZDES
      Endif
    Endif
  Endif
  Call LOADITM
  Affzo [M:CONH]1-99
  # FGR 06/06/2012 : X3SUIVI60482 (début)
  If GCONSULT = 2 Then
    Diszo [M:CONH]
  Endif
  # FGR 06/06/2012 : X3SUIVI60482 (fin)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Close Local File [CCVX]
  #Nettoie l'écran avant de partir.
  If clalev([M:CONH]) Then
    Raz [M:CONH]
  Endif
  Kill GINSERT
  Kill GSZCONHCONNUM
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  [M:CONH]DIRTYFLG = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
##########################################################################################################
$ONSAVE
Local Integer ZI
Local Integer IERRINF
Local Integer IBDEBTRANSFLG             # FGR 04/01/2013 : X3SUIVI86783 :  gestion du Trbegin quand il faut

  ZI = 0
  IERRINF = 0
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  If [M:CONH]TPL = 2 Then
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
  Else
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
  Endif
  If fstat Then
    #Erreur lors de l'enregistrement de la couverture article.
    GMESSAGE = mess(293,182,1)
    GERR = 1
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Endif
  If GERR Then
    Return
  Endif
  #Enregistrement des articles couverts
  For ZI = 0 To ([M:CONH]NBITM - 1)
    If [M:CONH]CONMACNUM(ZI) <> "" Then
      Raz [F:CCV]
      [F:CCV]CONNUM = [M:CONH]CONNUM
      If [M:CONH]TPL = 2 Then
        [F:CCV]TPL = 2
      Else
        [F:CCV]TPL = 1
      Endif
      [F:CCV]BPC = [M:CONH]CONBPC
      [F:CCV]RECTYP = "MAC"
      Case [M:CONH]COVTYP(ZI)
        When 1
          [F:CCV]SBBRECTYP = "MAC"
          [F:CCV]CPNSRT = "CMACMAC"
        When 2
          [F:CCV]SBBRECTYP = "ITM"
          [F:CCV]CPNSRT = "BMACITM"
        When 3
          [F:CCV]SBBRECTYP = "CIA"
          [F:CCV]CPNSRT = "AMACCIA"
      Endcase
      [F:CCV]RECNUM = [M:CONH]CONMACNUM(ZI)
      [F:CCV]CMT = [M:CONH]CONMACCOD(ZI)
      [F:CCV]LNDAUZ = [M:CONH]LNDAUZ(ZI)
      [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
      [F:CCV]PAEKEY(1) = ""
      [F:CCV]PAEKEY(2) = ""
      [F:CCV]CPNICDFLG = [M:CONH]CPNICDFLG(ZI)
      [F:CCV]ITMICDFLG = [M:CONH]CITITMICD(ZI)
      [F:CCV]HEIPRC(0) = [M:CONH]CITIHEIPRC(ZI)
      [F:CCV]MINCOV(0) = [M:CONH]CITIMINCOV(ZI)
      [F:CCV]MAXCOV(0) = [M:CONH]CITIMAXCOV(ZI)
      [F:CCV]LABICDFLG = [M:CONH]CITLABICD(ZI)
      [F:CCV]HEIPRC(1) = [M:CONH]CITLHEIPRC(ZI)
      [F:CCV]MINCOV(1) = [M:CONH]CITLMINCOV(ZI)
      [F:CCV]MAXCOV(1) = [M:CONH]CITLMAXCOV(ZI)
      [F:CCV]EXSICDFLG = [M:CONH]CITEXSICD(ZI)
      [F:CCV]HEIPRC(2) = [M:CONH]CITEHEIPRC(ZI)
      [F:CCV]MINCOV(2) = [M:CONH]CITEMINCOV(ZI)
      [F:CCV]MAXCOV(2) = [M:CONH]CITEMAXCOV(ZI)
      Write [CCV]
      If fstat Then
        #Erreur lors de l'enregistrement de la couverture article.
        GMESSAGE = mess(293,182,1)
        GERR = 1
        If IBDEBTRANSFLG = 0 Then
          Rollback
        Endif
        Break
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  #Enregistrement des prestations
  Call SAVECPN([M:CONH]CONMACNUM([M:CONH]PRECONHNOL), [M:CONH]PRECONHNOL)
  #Couverture croisée identique
  If [M:CONH]CRSCOVSAM = 2 Then
    Call DOCRSCOVSAM([M:CONH]CONNUM, [M:CONH]CONPBL, [M:CONH]TPL, IERRINF)
    If IERRINF Then
      #Erreur lors de l'enregistrement de la couverture croisée à l'identique.
      GMESSAGE = mess(432,182,1)
      GERR = 1
      Return
    Endif
  Endif
  #Remise à zéro des flags de modif.
  Raz [M:CONH]DIRTYFLG
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
Return

##########################################################################################################
#  Gestion des lignes du tableaux des composants couverts
#  Création et mise à jour des lignes
##########################################################################################################
Subprog SAVECPN(SZITMNUM, IPRECONHNOL)
Value Char SZITMNUM
Value Integer IPRECONHNOL

Local Integer J
Local Integer IBDEBTRANSFLG             # FGR 04/01/2013 : X3SUIVI86783 :  gestion du Trbegin quand il faut

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  If [M:CONH]TPL = 2 Then
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                  and [F:CCV]PAEKEY(1) = SZITMNUM
  Else
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                  and [F:CCV]PAEKEY(1) = SZITMNUM
  Endif
  If fstat Then
    #Erreur lors de l'enregistrement de la couverture des composants.
    GMESSAGE = mess(266,182,1)
    GERR = 1
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Endif
  If GERR Then
    End
  Endif
  #Enregistrement des lignes saisies
  #Pièces
  For J = 0 To [M:CONH]NBCPN-1
    If [M:CONH]CNNCPN(J) <> "" Then
      Raz [F:CCV]
      [F:CCV]CONNUM = [M:CONH]CONNUM
      If [M:CONH]TPL = 2 Then
        [F:CCV]TPL = 2
      Else
        [F:CCV]TPL = 1
      Endif
      [F:CCV]BPC = [M:CONH]CONBPC
      [F:CCV]RECTYP = "CPN"
      [F:CCV]SBBRECTYP = ""
      [F:CCV]ICDFLG = [M:CONH]CNNICDFLG(J)
      [F:CCV]RECNUM = [M:CONH]CNNCPN(J)
      [F:CCV]CMT = [M:CONH]CONMACCOD(IPRECONHNOL)
      [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
      [F:CCV]PAEKEY(1) = SZITMNUM
      [F:CCV]PAEKEY(2) = ""
      Case [M:CONH]COVTYP(IPRECONHNOL)
        When 1
          #Parc
          [F:CCV]PAEKEYTYP(1) = "MAC"
          [F:CCV]CPNSRT = "CCPNMAC"
        When 2
          #Article
          [F:CCV]PAEKEYTYP(1) = "ITM"
          [F:CCV]CPNSRT = "BCPNITM"
        When 3
          #Famille commerciale
          [F:CCV]PAEKEYTYP(1) = "CIA"
          [F:CCV]CPNSRT = "ACPNCIA"
        When Default
          [F:CCV]PAEKEYTYP(1) = ""
          [F:CCV]CPNSRT = ""
      Endcase
      [F:CCV]ITMICDFLG = [M:CONH]ITMICDFLG(J)
      [F:CCV]HEIPRC(0) = [M:CONH]CNNIHEIPRC(J)
      [F:CCV]MINCOV(0) = [M:CONH]CNNIMINCOV(J)
      [F:CCV]MAXCOV(0) = [M:CONH]CNNIMAXCOV(J)
      [F:CCV]LABICDFLG = [M:CONH]LABICDFLG(J)
      [F:CCV]HEIPRC(1) = [M:CONH]CNNLHEIPRC(J)
      [F:CCV]MINCOV(1) = [M:CONH]CNNLMINCOV(J)
      [F:CCV]MAXCOV(1) = [M:CONH]CNNLMAXCOV(J)
      [F:CCV]EXSICDFLG = [M:CONH]EXSICDFLG(J)
      [F:CCV]HEIPRC(2) = [M:CONH]CNNEHEIPRC(J)
      [F:CCV]MINCOV(2) = [M:CONH]CNNEMINCOV(J)
      [F:CCV]MAXCOV(2) = [M:CONH]CNNEMAXCOV(J)
      Write [CCV]
      If fstat Then
        #Erreur lors de l'enregistrement de la couverture des composants.
        GMESSAGE = mess(266,182,1)
        GERR = 1
        If IBDEBTRANSFLG = 0 Then
          Rollback
        Endif
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
End

##########################################################################################################
# Chargement du tableau des articles couverts
##########################################################################################################
Subprog LOADITM
Local Integer IB
Local Integer IADINUM

  Raz [M:CONH]NBITM
  Raz [M:CONH]NBITMSEL
  Raz [M:CONH]MORCOVITM
  Raz [M:CONH]COVTYP
  Raz [M:CONH]CONMACCOD
  Raz [M:CONH]MACDES
  If [M:CONH]TPL <> 2 Then
    Raz [M:CONH]SERNUM
  Endif
  Raz [M:CONH]LNDAUZ
  Raz [M:CONH]CONMACNUM
  Raz [M:CONH]CPNICDFLG
  Raz [M:CONH]ICDFLGX
  Raz [M:CONH]CITITMICD
  Raz [M:CONH]CITIHEIPRC
  Raz [M:CONH]CITIMINCOV
  Raz [M:CONH]CITIMAXCOV
  Raz [M:CONH]CITLABICD
  Raz [M:CONH]CITLHEIPRC
  Raz [M:CONH]CITLMINCOV
  Raz [M:CONH]CITLMAXCOV
  Raz [M:CONH]CITEXSICD
  Raz [M:CONH]CITEHEIPRC
  Raz [M:CONH]CITEMINCOV
  Raz [M:CONH]CITEMAXCOV
  Raz [M:CONH]MACITMREF

  IB = 0
  IADINUM = 19 + GFAMCIA
  If [M:CONH]TPL = 2 Then
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                Order By [F:CCV]RECNUM Asc
  Else
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                Order By [F:CCV]RECNUM Asc
  Endif
  For [CCV]
    If IB >= dim([M:CONH]COVTYP)-1 Then
      Break
    Endif
    If IB = 0 Then
      [M:CONH]NBITMSEL(IB) = "->"
      [M:CONH]ICDFLGX = [F:CCV]CPNICDFLG
    Else
      [M:CONH]NBITMSEL(IB) = ""
    Endif
    Case [F:CCV]SBBRECTYP
      When "MAC"
        [M:CONH]COVTYP(IB) = 1
      When "ITM"
        [M:CONH]COVTYP(IB) = 2
      When "CIA"
        [M:CONH]COVTYP(IB) = 3
    Endcase
    [M:CONH]CONMACCOD(IB) = [F:CCV]CMT
    [M:CONH]CONMACNUM(IB) = [F:CCV]RECNUM
    [M:CONH]LNDAUZ(IB) = [F:CCV]LNDAUZ
    Case [M:CONH]COVTYP(IB)
      When 1
        Read [MAC]MAC0=[M:CONH]CONMACCOD(IB)
        If !fstat Then
          [M:CONH]MACDES(IB) = [F:MAC]MACDES
          [M:CONH]MACITMREF(IB) = [F:MAC]MACPDTCOD
          If [M:CONH]TPL <> 2 Then
            [M:CONH]SERNUM(IB) = [F:MAC]MACSERNUM
          Endif
        Endif
      When 2
        Read [ITM]ITM0=[M:CONH]CONMACCOD(IB)
        If !fstat Then
          #Call LECTEXTRA([M:CONH]MACDES(IB), "ITMMASTER", "DES1AXX", [M:CONH]CONMACCOD(IB), "") From ATEXTRA
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CONH]MACDES(IB), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
          [M:CONH]MACITMREF(IB) = [F:ITM]ITMREF
          If [M:CONH]TPL <> 2 Then
            [M:CONH]SERNUM(IB) = ""
          Endif
        Endif
      When 3
        Call GET_LIB(IADINUM, [M:CONH]CONMACCOD(IB), [M:CONH]MACDES(IB)) From CRM_UTIL
        If [M:CONH]TPL <> 2 Then
          [M:CONH]SERNUM(IB) = ""
        Endif
        [M:CONH]MACITMREF(IB) = ""
      When Default
    Endcase
    #Inclusion/Exclusion des composants
    [M:CONH]CPNICDFLG(IB) = [F:CCV]CPNICDFLG
    If [M:CONH]CPNICDFLG(IB) = 0 Then
      [M:CONH]CPNICDFLG(IB) = GCPNICD
      If [M:CONH]CPNICDFLG(IB) = 0 Then
        [M:CONH]CPNICDFLG(IB) = 1
      Endif
    Endif
    #Inclusion/Exclusion détail couverture
    #Pièces
    [M:CONH]CITITMICD(IB) = [F:CCV]ITMICDFLG
    If [M:CONH]CITITMICD(IB) = 0 Then
      [M:CONH]CITITMICD(IB) = GITMICD
      If [M:CONH]CITITMICD(IB) = 0 Then
        [M:CONH]CITITMICD(IB) = 1
      Endif
    Endif
    [M:CONH]CITIHEIPRC(IB) = [F:CCV]HEIPRC(0)
    [M:CONH]CITIMINCOV(IB) = [F:CCV]MINCOV(0)
    [M:CONH]CITIMAXCOV(IB) = [F:CCV]MAXCOV(0)
    #Main d'oeuvre
    [M:CONH]CITLABICD(IB) = [F:CCV]LABICDFLG
    If [M:CONH]CITLABICD(IB) = 0 Then
      [M:CONH]CITLABICD(IB) = GLABICD
      If [M:CONH]CITLABICD(IB) = 0 Then
        [M:CONH]CITLABICD(IB) = 1
      Endif
    Endif
    [M:CONH]CITLHEIPRC(IB) = [F:CCV]HEIPRC(1)
    [M:CONH]CITLMINCOV(IB) = [F:CCV]MINCOV(1)
    [M:CONH]CITLMAXCOV(IB) = [F:CCV]MAXCOV(1)
    #Frais de mission
    [M:CONH]CITEXSICD(IB) = [F:CCV]EXSICDFLG
    If [M:CONH]CITEXSICD(IB) = 0 Then
      [M:CONH]CITEXSICD(IB) = GEXSICD
      If [M:CONH]CITEXSICD(IB) = 0 Then
        [M:CONH]CITEXSICD(IB) = 1
      Endif
    Endif
    [M:CONH]CITEHEIPRC(IB) = [F:CCV]HEIPRC(2)
    [M:CONH]CITEMINCOV(IB) = [F:CCV]MINCOV(2)
    [M:CONH]CITEMAXCOV(IB) = [F:CCV]MAXCOV(2)
    #Champs indicateur de la présence d'un détail de couverture
    [M:CONH]MORCOVITM(IB) = ""
    If [M:CONH]CITIHEIPRC(IB) > 0 Then
      [M:CONH]MORCOVITM(IB) = "+"
    Else
      If [M:CONH]CITITMICD(IB) = 2 Then
        If [M:CONH]CITIHEIPRC(IB) = 0 Then
          [M:CONH]MORCOVITM(IB) = "+"
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITIMINCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITIMAXCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITLHEIPRC(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Else
        If [M:CONH]CITLABICD(IB) = 2 Then
          If [M:CONH]CITLHEIPRC(IB) = 0 Then
            [M:CONH]MORCOVITM(IB) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITLMINCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITLMAXCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITEHEIPRC(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Else
        If [M:CONH]CITEXSICD(IB) = 2 Then
          If [M:CONH]CITEHEIPRC(IB) = 0 Then
            [M:CONH]MORCOVITM(IB) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITEMINCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]CITEMAXCOV(IB) > 0 Then
        [M:CONH]MORCOVITM(IB) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVITM(IB) = "" Then
      If [M:CONH]TPL = 2 Then
        Filter [CCVX] Where [F:CCVX]CONNUM = [M:CONH]CONNUM and [F:CCVX]TPL = 2 and [F:CCVX]RECTYP = "AAA" and [F:CCVX]PAEKEY(0) = [M:CONH]CONPBL
&                       and [F:CCVX]PAEKEY(1) = [M:CONH]CONMACNUM(IB) and [F:CCVX]PAEKEY(2) = ""
      Else
        Filter [CCVX] Where [F:CCVX]CONNUM = [M:CONH]CONNUM and [F:CCVX]TPL <> 2 and [F:CCVX]RECTYP = "AAA" and [F:CCVX]PAEKEY(0) = [M:CONH]CONPBL
&                       and [F:CCVX]PAEKEY(1) = [M:CONH]CONMACNUM(IB) and [F:CCVX]PAEKEY(2) = ""
      Endif
      For [CCVX]
        [M:CONH]MORCOVITM(IB) = "+"
        Break
      Next
      Filter [CCVX]
    Endif
    IB += 1
  Next
  [M:CONH]NBITM = IB
  Filter [CCV]
  If [M:CONH]NBITM = 0 Then
    [M:CONH]ICDFLGX = GCPNICD
    If [M:CONH]ICDFLGX = 0 Then
      [M:CONH]ICDFLGX = 1
    Endif
  Else
    [M:CONH]ICDFLGX = [M:CONH]CPNICDFLG(0)
  Endif
  Call LOADCPN([M:CONH]CONMACNUM(0))
End

##########################################################################################################
# Chargement du tableau des composants
##########################################################################################################
Subprog LOADCPN(SZITMNUM)
Value Char SZITMNUM

Local Integer ARRNBLIG

  ARRNBLIG = 0
  Raz [M:CONH]NBCPN
  Raz [M:CONH]MORCOVCPN
  Raz [M:CONH]CNNICDFLG
  Raz [M:CONH]CNNCPN
  Raz [M:CONH]CNNCPNDES
  Raz [M:CONH]ITMICDFLG
  Raz [M:CONH]CNNIHEIPRC
  Raz [M:CONH]CNNIMINCOV
  Raz [M:CONH]CNNIMAXCOV
  Raz [M:CONH]LABICDFLG
  Raz [M:CONH]CNNLHEIPRC
  Raz [M:CONH]CNNLMINCOV
  Raz [M:CONH]CNNLMAXCOV
  Raz [M:CONH]EXSICDFLG
  Raz [M:CONH]CNNEHEIPRC
  Raz [M:CONH]CNNEMINCOV
  Raz [M:CONH]CNNEMAXCOV
  If [M:CONH]TPL = 2 Then
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                  and [F:CCV]PAEKEY(1) = SZITMNUM
&             Order By [F:CCV]RECNUM Asc
  Else
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
&                  and [F:CCV]PAEKEY(1) = SZITMNUM
&             Order By [F:CCV]RECNUM Asc
  Endif
  For [CCV]
    If ARRNBLIG >= dim([M:CONH]CNNCPN)-1 Then
      Break
    Endif
    [M:CONH]CNNICDFLG(ARRNBLIG) = [F:CCV]ICDFLG
    [M:CONH]CNNCPN(ARRNBLIG) = [F:CCV]RECNUM
    [M:CONH]ITMICDFLG(ARRNBLIG) = [F:CCV]ITMICDFLG
    [M:CONH]CNNIHEIPRC(ARRNBLIG) = [F:CCV]HEIPRC(0)
    [M:CONH]CNNIMINCOV(ARRNBLIG) = [F:CCV]MINCOV(0)
    [M:CONH]CNNIMAXCOV(ARRNBLIG) = [F:CCV]MAXCOV(0)
    [M:CONH]LABICDFLG(ARRNBLIG) = [F:CCV]LABICDFLG
    [M:CONH]CNNLHEIPRC(ARRNBLIG) = [F:CCV]HEIPRC(1)
    [M:CONH]CNNLMINCOV(ARRNBLIG) = [F:CCV]MINCOV(1)
    [M:CONH]CNNLMAXCOV(ARRNBLIG) = [F:CCV]MAXCOV(1)
    [M:CONH]EXSICDFLG(ARRNBLIG) = [F:CCV]EXSICDFLG
    [M:CONH]CNNEHEIPRC(ARRNBLIG) = [F:CCV]HEIPRC(2)
    [M:CONH]CNNEMINCOV(ARRNBLIG) = [F:CCV]MINCOV(2)
    [M:CONH]CNNEMAXCOV(ARRNBLIG) = [F:CCV]MAXCOV(2)
    Read [ITM]ITM0=[M:CONH]CNNCPN(ARRNBLIG)
    If fstat Then
      [M:CONH]CNNCPNDES(ARRNBLIG) = ""
    Else
      #Call LECTEXTRA([M:CONH]CNNCPNDES(ARRNBLIG), "ITMMASTER", "DES1AXX", [M:CONH]CNNCPN(ARRNBLIG), "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CONH]CNNCPNDES(ARRNBLIG), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    Endif
    #Champs indicateur de la présence d'un détail de couverture
    [M:CONH]MORCOVCPN(ARRNBLIG) = ""
    If [M:CONH]CNNIHEIPRC(ARRNBLIG) > 0 Then
      [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
    Else
      If [M:CONH]ITMICDFLG(ARRNBLIG) = 2 Then
        If [M:CONH]CNNIHEIPRC(ARRNBLIG) = 0 Then
          [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNIMINCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNIMAXCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNLHEIPRC(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Else
        If [M:CONH]LABICDFLG(ARRNBLIG) = 2 Then
          If [M:CONH]CNNLHEIPRC(ARRNBLIG) = 0 Then
            [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNLMINCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNLMAXCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNEHEIPRC(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Else
        If [M:CONH]EXSICDFLG(ARRNBLIG) = 2 Then
          If [M:CONH]CNNEHEIPRC(ARRNBLIG) = 0 Then
            [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNEMINCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]CNNEMAXCOV(ARRNBLIG) > 0 Then
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
      Endif
    Endif
    If [M:CONH]MORCOVCPN(ARRNBLIG) = "" Then
      If [M:CONH]TPL = 2 Then
        Filter [CCVX] Where [F:CCVX]CONNUM = [M:CONH]CONNUM and [F:CCVX]TPL = 2 and [F:CCVX]RECTYP = "AAA" and [F:CCVX]PAEKEY(0) = [M:CONH]CONPBL
&                       and [F:CCVX]PAEKEY(1) = SZITMNUM and [F:CCVX]PAEKEY(2) = [M:CONH]CNNCPN(ARRNBLIG)
      Else
        Filter [CCVX] Where [F:CCVX]CONNUM = [M:CONH]CONNUM and [F:CCVX]TPL <> 2 and [F:CCVX]RECTYP = "AAA" and [F:CCVX]PAEKEY(0) = [M:CONH]CONPBL
&                       and [F:CCVX]PAEKEY(1) = SZITMNUM and [F:CCVX]PAEKEY(2) = [M:CONH]CNNCPN(ARRNBLIG)
      Endif
      For [CCVX]
        [M:CONH]MORCOVCPN(ARRNBLIG) = "+"
        Break
      Next
      Filter [CCVX]
    Endif
    ARRNBLIG += 1
  Next
  [M:CONH]NBCPN = ARRNBLIG
  Filter [CCV]
End

##########################################################################################################
# Contrôle la saisie du tableau des machines et prestations couvertes.
##########################################################################################################
Subprog GESNBITM(INOL)
Value Integer INOL

  [M:CONH]CURITM = [M:CONH]CONMACCOD(INOL)
  [M:CONH]CPNICDFLG([M:CONH]PRECONHNOL) = [M:CONH]ICDFLGX
  Call SAVECPN([M:CONH]CONMACNUM([M:CONH]PRECONHNOL), [M:CONH]PRECONHNOL)
  If INOL >= dim([M:CONH]CONMACCOD)-1 Then
    End
  Endif
  Call LOADCPN([M:CONH]CONMACNUM(INOL))
  If [M:CONH]PRECONHNOL <> INOL Then
    [M:CONH]NBITMSEL([M:CONH]PRECONHNOL) = ""
    [M:CONH]NBITMSEL(INOL) = "->"
    [M:CONH]PRECONHNOL = INOL
  Endif
  [M:CONH]ICDFLGX = [M:CONH]CPNICDFLG(INOL)
  If [M:CONH]ICDFLGX = 0 Then
    [M:CONH]ICDFLGX = GCPNICD
    If [M:CONH]ICDFLGX = 0 Then
      [M:CONH]ICDFLGX = 1
    Endif
  Endif
  Affzo [M:CONH]1-99
End

##########################################################################################################
# Annulation de tous les articles et couverture pour un contrat.
##########################################################################################################
Subprog RAZPCOV(SZOBJTYP, SZCONNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZOBJTYP
Value Char SZCONNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  #
  If SZOBJTYP = "CON" Then
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]CPNSRT <> "DAAAPBL"
  Else
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]CPNSRT <> "DAAAPBL"
  Endif
  If fstat Then
    IBRETOUR = 0
    IERRINF = 613
    ICHAPTER = 177
    If IBDEBTRANSFLG = 0 Then
      Rollback
      End
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Annulation de toutes les familles de compétences couvertes pour un contrat.
##########################################################################################################
Subprog RAZPBL(SZOBJTYP, SZCONNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZOBJTYP
Value Char SZCONNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  If SZOBJTYP = "CON" Then
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "PBL"
  Else
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "PBL"
  Endif
  If fstat Then
    IBRETOUR = 0
    IERRINF = 612
    ICHAPTER = 177
    If IBDEBTRANSFLG = 0 Then
      Rollback
      End
    Endif
  Endif
  If SZOBJTYP = "CON" Then
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]PAEKEY(0) <> ""
  Else
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]PAEKEY(0) <> ""
  Endif
  If fstat Then
    IBRETOUR = 0
    IERRINF = 612
    ICHAPTER = 177
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
End

##########################################################################################################
# Met à jour la couverture financières suite à une modification de la devise du contrat.
##########################################################################################################
Subprog UPDITMCOV(SZOLDCUR, SZNEWCUR, ITPL)
Value Char SZOLDCUR
Value Char SZNEWCUR
Value Integer ITPL

Local Char SZSITE(GLONFCY)
Local Decimal IMINCOV
Local Decimal IMAXCOV
Local Decimal IHEIAMT
Local Integer IERROR                    # FGR 08/02/2010 : X3SUIVI60986
Local Integer IBDEBTRANSFLG             # FGR 04/01/2013 : X3SUIVI86783 :  gestion du Trbegin quand il faut

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  IERROR = 0   # FGR 08/02/2010 : X3SUIVI60986
  SZSITE = ""
  IMINCOV = 0
  IMAXCOV = 0
  IHEIAMT = 0
  #Obtient le site
  If ITPL = 2 Then
    SZSITE = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", "")
  Else
    SZSITE = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", [M:CON0]SALFCY)
  Endif
  If ITPL = 2 Then
    Filter [CCV] Where [F:CCV]CONNUM = [M:COT0]CONNUM and [F:CCV]TPL = 2
  Else
    Filter [CCV] Where [F:CCV]CONNUM = [M:CON0]CONNUM and [F:CCV]TPL <> 2
  Endif
  #Enregistrement des lignes saisies
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  For [CCV]
    IMINCOV = [F:CCV]MINCOV
    IMAXCOV = [F:CCV]MAXCOV
    Call SETCOVAMT(SZSITE, SZOLDCUR, SZNEWCUR, IMINCOV, [F:CCV]MINCOV) From SUBCOND
    Call SETCOVAMT(SZSITE, SZOLDCUR, SZNEWCUR, IMAXCOV, [F:CCV]MAXCOV) From SUBCOND
    Rewrite [CCV]
    If fstat Then
      #Erreur lors de la conversion des montants relatifs aux différents détails de couverture.
      GMESSAGE = mess(267,182,1)
      GERR = 1
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      IERROR = 1
      Break
    Endif
  Next
  Filter [CCV]
  If IERROR Then
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
End

##########################################################################################################
# Enregistrement de la couverture croisée à l'identique de la couverture simple
##########################################################################################################
Subprog DOCRSCOVSAM(SZCONNUM, SZPBL, ITPL, IERRINF)
Value Char SZCONNUM
Value Char SZPBL
Value Integer ITPL
Variable Integer IERRINF

Local Integer IBDEBTRANSFLG             # FGR 04/01/2013 : X3SUIVI86783 :  gestion du Trbegin quand il faut

  Local File CONTCOV [CCV2]
  Local File CONTCOV [CCV3]
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Trbegin [CCV]
  Endif
  If SZPBL = "" Then
    #Alimentation de la couverture croisée à partir de la couverture simple.
    #On commence par tout effacer
    If ITPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> "" and [F:CCV]CPNSRT <> "DAAAPBL"
    Else
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> "" and [F:CCV]CPNSRT <> "DAAAPBL"
    Endif
    If fstat Then
      IERRINF = 1
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
    #On recopie
    If ITPL = 2 Then
      Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL = 2 and [F:CCV3]RECTYP = "PBL"
    Else
      Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL <> 2 and [F:CCV3]RECTYP = "PBL"
    Endif
    For [CCV3]
      If ITPL = 2 Then
        #Modèle de contrat
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = ""
      Else
        #Contrat
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = ""
      Endif
      For [CCV2]
        Raz [F:CCV]
        [F:CCV] = [F:CCV2]
        [F:CCV]PAEKEY(0) = [F:CCV3]RECNUM
        Write [CCV]
        If fstat Then
          IERRINF = 1
          Break
        Endif
      Next
      Filter [CCV2]
      If IERRINF Then
        Break
      Endif
    Next
    Filter [CCV3]
    If IERRINF Then
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
  Else
    #---------------------------------------------------#
    #Alimentation de la couverture simple à partir de la couverture croisée.
    #On commence par supprimer la couverture simple
    If ITPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) = ""
    Else
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) = ""
    Endif
    If fstat Then
      IERRINF = 1
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
    #Ensuite, on efface toutes les couvertures croisées des autres compétences
    Trbegin [CCV]
    If ITPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> SZPBL and [F:CCV]CPNSRT <> "DAAAPBL"
    Else
      Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> SZPBL and [F:CCV]CPNSRT <> "DAAAPBL"
    Endif
    If fstat Then
      IERRINF = 1
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
    #Ensuite, on copie la couverture de la compétence courante en tant que couverture simple
    #On recopie
    If ITPL = 2 Then
      #Modèle de contrat
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = SZPBL and [F:CCV2]CPNSRT <> "DAAAPBL"
    Else
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = SZPBL and [F:CCV2]CPNSRT <> "DAAAPBL"
    Endif
    For [CCV2]
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]PAEKEY(0) = ""
      Write [CCV]
      If fstat Then
        IERRINF = 1
        Break
      Endif
    Next
    Filter [CCV2]
    If IERRINF Then
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
    #Ensuite, on régénère toutes les compétences croisées des autres compétences.
    If ITPL = 2 Then
      Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL = 2 and [F:CCV3]RECTYP = "PBL" and [F:CCV3]RECNUM <> SZPBL
    Else
      Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL <> 2 and [F:CCV3]RECTYP = "PBL" and [F:CCV3]RECNUM <> SZPBL
    Endif
    For [CCV3]
      If ITPL = 2 Then
        #Modèle de contrat
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = SZPBL
&                       and [F:CCV2]CPNSRT <> "DAAAPBL"
      Else
        #Contrat
        Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = SZPBL
&                       and [F:CCV2]CPNSRT <> "DAAAPBL"
      Endif
      For [CCV2]
        Raz [F:CCV]
        [F:CCV] = [F:CCV2]
        [F:CCV]PAEKEY(0) = [F:CCV3]RECNUM
        Write [CCV]
        If fstat Then
          IERRINF = 1
          Break
        Endif
      Next
      Filter [CCV2]
      If IERRINF Then
        Break
      Endif
    Next
    Filter [CCV3]
    If IERRINF Then
      If IBDEBTRANSFLG = 0 Then
        Rollback
      Endif
      End
    Endif
  Endif
  # -----------------------------
  If IERRINF = 0 Then
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Suppression des couvertures croisées
##########################################################################################################
Subprog DELCRSCOVSAM(SZCONNUM, ITPL, IERRINF)
Value Char SZCONNUM
Value Integer ITPL
Variable Integer IERRINF

Local Integer IBDEBTRANSFLG             # FGR 04/01/2013 : X3SUIVI86783 :  gestion du Trbegin quand il faut

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Trbegin [CCV]
  Endif
  If ITPL = 2 Then
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> "" and [F:CCV]CPNSRT <> "DAAAPBL"
  Else
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP <> "PBL" and [F:CCV]PAEKEY(0) <> "" and [F:CCV]CPNSRT <> "DAAAPBL"
  Endif
  If fstat Then
    IERRINF = 1
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# FGR 19/12/2012 : X3SUIVI86670
# Test si un composant est couvert par le contrat
##########################################################################################################
Funprog COVERED_COMPONENT(SCONNUM, IOVRCOV, SMACNUM, SITMREF)
Value Char SCONNUM
Value Integer IOVRCOV
Value Char SMACNUM
Value Char SITMREF

Local Integer ITROUVE
Local Integer IARENDRE
Local Char SCRITERE(250)

  # --------------------------------------------
  # IOVRCOR : ML3003
  #           1 Totalement couverte
  #           2 Partiellement couverte
  #           3 Non couverte
  #           4 Couverte par contrat de service
  #           5 Couverte par commande de vente
  #           6 Couverte commercialement
  #           7 Couverte par facturation directe
  # --------------------------------------------
  If IOVRCOV = 1 or IOVRCOV = 4 or IOVRCOV = 5 or IOVRCOV = 6 or IOVRCOV = 7 Then
    IARENDRE = G_YES                   # Composant couvert
    Local File CONTCOV [CCV1]
    Local File CONTCOV [CCV2]
    # ---------------------------------------------------------------------
    If SMACNUM = "" Then
      SCRITERE = "(1=1)"
    Else
      SCRITERE = "([F:CCV1]CMT = '" + SMACNUM + "')"
    Endif
    Filter [CCV1] Where [F:CCV1]CONNUM = SCONNUM and [F:CCV1]TPL = 1
&                    and [F:CCV1]PAEKEY(1) = ''
&                    and evalue(SCRITERE)
&              Order By [F:CCV1]RECNUM
    For [CCV1]
      ITROUVE = 0
      Filter [CCV2] Where [F:CCV2]CONNUM = [F:CCV1]CONNUM and [F:CCV2]TPL = [F:CCV1]TPL
&                     and [F:CCV2]PAEKEY(1) = [F:CCV1]RECNUM
&                     and [F:CCV2]RECNUM = SITMREF
      For [CCV2]
        ITROUVE = 1
        Break
      Next
      Filter [CCV2]
      If [F:CCV1]CPNICDFLG = 1 Then
        # Exclut les composants non listés
        If ITROUVE = 0 Then
          IARENDRE = G_NO              # On ne l'a pas trouvé : il est exclus
        Else
          # On l'a trouvé, on teste [F:CCV2]ICDFLG
          If [F:CCV2]ICDFLG = 1 Then
            # Exclut
            IARENDRE = G_NO            # Il est exclut explicitement
            Break                      # S'il est exclut on sort c'est facturable
          Endif
        Endif
      Else
        # Inclut les composants non listés
        If ITROUVE = 1 Then
          # On l'a trouvé : on teste [F:CCV2]ICDFLG
          If [F:CCV2]ICDFLG = 1 Then
            # Exclut
            IARENDRE = G_NO            # Il est exclut explicitement
            Break                      # S'il est exclut on sort c'est facturable
          Endif
        Endif
      Endif
    Next
    Filter [CCV1]
    # ---------------------------------------------------------------------
  Elsif IOVRCOV = 4 or IOVRCOV = 5 or IOVRCOV = 6 or IOVRCOV = 7 Then
    IARENDRE = G_YES                   # Composant couvert
  Else
    IARENDRE = G_NO                    # Composant non couvert
  Endif
End IARENDRE
