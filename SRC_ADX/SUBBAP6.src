#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque BAP6
##########################################################################################################
Subprog AS_NBBPRADD

#If GNAVIG(GPILNAV) = "GESBAP"
If [M:BAP6]CONTEXT="BAP3"
    Call AFFBPRADD(nolign - 1) From TRTBAP6
Endif
#If GNAVIG(GPILNAV) = "GESITN"
If [M:BAP6]CONTEXT="ITN3"
    Call AFFBPRADD(nolign - 1) From TRTBAP6B
Endif
End

