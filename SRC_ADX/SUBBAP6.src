##########################################################################################################
Subprog AS_NBCCNADD
#If GNAVIG(GPILNAV) = "GESBAP"
If [M:BAP6]CONTEXT="BAP3"
    Call AFFCCNADD(nolign - 1) From TRTBAP6
Endif
#If GNAVIG(GPILNAV) = "GESITN"
If [M:BAP6]CONTEXT="ITN3"
    Call AFFCCNADD(nolign - 1) From TRTBAP6B
Endif
End

