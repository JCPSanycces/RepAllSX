# --------------------------------------- BPCORD ---------------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran SBPCALL) 26/04/2006 12:03:18 (LD)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer OK

Raz GWIP
If clalev([F:TCA]) = 0 : Local File TABCOUAFF [TCA] : Endif
# --- Récupération du code compteur
Call LECTCA(7,OK) From SUBTCA
If fstat | !OK
    GERR=1 : mkstat=2 : GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : End
Endif
GWIP  = [F:TCA]CODNUM(8)
Close Local File [TCA]

Raz [M]BPCORD, BPAADD
Affzo [M]BPCORD, BPAADD
Effzo [M]10
End
# --------------------------------------- BPCORD ---------------------------------
Subprog C_BPCORD(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
Local    Decimal ENCOURS
Gosub CTR_BPC
End
#######################################################################
Subprog AM_BPCORD(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()

# -- Recherche adresse de livraison --------------------
Filter [BPD] Where  BPCNUM = VALEUR & ENAFLG=2
Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
If fstat <> 0
   Read [BPD]BPD0 First
Endif
If fstat =  0 [M]BPAADD  = [F:BPD]BPAADD
              [M]ZBPAADD = [F:BPD]BPDNAM
Else          Raz [M]BPAADD
              Endif
Gosub INIT_STOFCY
Filter [BPD]
GBPCNUM = VALEUR
Affzo [M]BPAADD
End
#######################################################################
# --------------------------------------- BPAADD ---------------------------------
Subprog AM_BPAADD(VALEUR)    : # Web - Faible - Asynchrone
Variable Char    VALEUR()
Gosub INIT_STOFCY
End
########################################
# --------------------------------------- NBLIG ---------------------------------
########################################
Subprog AS_NBLIG
Gosub AFF_ITM
End
########################################
Subprog APRES_NBLIG
If status = 7 | status = 6 End : Endif
[M]UPDFLG(nolign-1) = 1
End
#######################################################################
# --------------------------------------- ITMREF ---------------------------------
Subprog IB_ITMREF
If [M]CREFLG(nolign-1) = 0 & [M]UPDFLG(nolign-1) = 0
    GBOUT1 = mess(22,198,1)          :# Bouton tunnel article
Endif
End
########################################
Subprog AS_ITMREF(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]CREFLG(nolign-1) <> 0 | [M]UPDFLG(nolign-1) <> 0 mkstat = 2 Endif
End
########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

#Call LECTURE("ITM", VALEUR, "") From CONTOBJ
#If fstat <> 0          GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif
If [F:ITM]ITMREF <> VALEUR
    Read [ITM] ITM0=VALEUR
    If fstat GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif
Endif
#Call CONTITF(VALEUR,[M]STOFCY(nolign-1), [F:ITM]STOMGTCOD) From TRTVENCTL
# Bug 2590 : Si article-site inexistant, pouvoir continuer pour aller modifier le site
#If mkstat = 2 mkstat=0 Endif

End
########################################
Subprog AM_ITMREF(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1

[M]STOFCY(NOL)   = [M]YSTOFCY
[M]DSAU (NOL)    = [F:ITM]SAU
[M]DSTU (NOL)    = [F:ITM]STU
[M]SAU           = [F:ITM]SAU
[M]STU           = [F:ITM]STU
#[M]DITMDES1(NOL) = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]DITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
#[M]ITMDES1       = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
#   récupération du coef de conversion unite vente - unite stock
Call SCAL_QUS(0, VALEUR, [M]BPCORD, [M]DSAU(NOL), [M]DSTU(NOL), GBIDD1, [M]DCOE(NOL)) From TRTVENQTE
[M]COE           = [M]DCOE(NOL)

Affzo [M]DSAU(NOL), STOFCY(NOL),DSTU(NOL)
Affzo [M]ITMDES1, SAU, STU, COE

End
#######################################################################
# --------------------------------------- ALLDAT ---------------------------------
Subprog C_ALLDAT(VALEUR)
Variable Date    VALEUR
# la date doit être >= à la date du jour
If VALEUR < date$
  GMESSAGE = mess(65,194,1) : mkstat=2 : End
Endif
End
#######################################################################
# --------------------------------------- STOFCY ---------------------------------
########################################
Subprog AS_STOFCY(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]CREFLG(nolign-1) <> 0 | [M]UPDFLG(nolign-1) <> 0 mkstat = 2 Endif
End
#######################################################################
Subprog AP_STOFCY(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
Local    Integer NOL     : NOL=nolign-1
Local    Char    WSTOFCY

WSTOFCY=VALEUR : Gosub LECITM
Affzo [M]DISSTOSAU, DISSTOSTU, SHTSTO, PHYSTOSAU, PHYSTOSTU
If [M]DISSTOSAU < [M]QTYSAU(NOL) GERR=1: GMESSAGE = mess(148,199,1) : mkstat=2: Endif

End
########################################
# --------------------------------------- DSAU ---------------------------------
Subprog AS_DSAU(VALEUR)   : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]CREFLG(nolign-1) <> 0 | [M]UPDFLG(nolign-1) <> 0 mkstat = 2 Endif
End
########################################
Subprog AM_DSAU(VALEUR)     : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1

Raz [M]QTYSAU(nolign-1)

#   récupération du coef de conversion unite cde - unite stock
Call SCAL_QUS(0, [M]ITMREF(NOL), [M]BPCORD, VALEUR, [M]DSTU(NOL), GBIDD1, [M]DCOE(NOL)) From TRTVENQTE
[M]COE = [M]DCOE(NOL)
[M]SAU = VALEUR

[M]PHYSTOSAU=[M]PHYSTOSTU*(1/[M]COE)
Call QTEARR([M]PHYSTOSAU, [M]SAU) From TRTDIV
[M]DISSTOSAU=[M]DISSTOSTU*(1/[M]COE)
Call QTEARR([M]DISSTOSAU, [M]SAU) From TRTDIV

Affzo [M]SAU, PHYSTOSAU, DISSTOSAU, COE

End
#######################################################################
# --------------------------------------- QTYSAU ---------------------------------
Subprog C_QTYSAU(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Decimal VALEUR
Local Integer NOL       : NOL=nolign-1
Local Decimal QTY_STU, COEF
If VALEUR < 0 mkstat=2 : End : Endif

If VALEUR <> [M]QTYSAU(NOL)
    QTY_STU = VALEUR * [M]DCOE(NOL)
    Call QTEARR(QTY_STU, [M]DSTU(NOL)) From TRTDIV
    [M]DISSTOSTU += [M]YQTYSTUACT(NOL)
    If [M]DISSTOSTU < QTY_STU GMESSAGE = mess(148,199,1) : mkstat=2 : End : Endif
    # Dde de confirmation si on alloue malgré les ruptures déjà existantes
    If [M]DISSTOSTU > 0 & [M]SHTSTO > 0
         GERR=3:GMESSAGE = mess(51,191,1)
    Endif
Endif
End
########################################
Subprog AM_QTYSAU(VALEUR)    : # Web - Faible - Synchrone
Variable Decimal VALEUR
Local    Integer OK
Affzo [M]QTYSTUACT(nolign-1)
End
#######################################################################
#                       ETIQUETTES                                    #
#######################################################################
$LEC_BPD             : # Lecture du client livré
If [F:BPD]BPCNUM <>  [M]BPCORD | [F:BPD]BPAADD <> [M]BPAADD
                     Read [BPD] BPD0=[M]BPCORD;[M]BPAADD
                     If fstat Raz [F:BPD] : Endif
                     Endif
Return
$LEC_ITM             : # Lecture de l'article
If [F:ITM]ITMREF <>  [M]ITMREF(NOL)
                     Read [ITM] ITM0=[M]ITMREF(NOL)
                     If fstat Raz [F:ITM] : Endif
                     Endif
Return
$LEC_ITS             : # Lecture de l'article vente
If [F:ITS]ITMREF <>  [M]ITMREF(NOL)
                     Read [ITS] ITS0=[M]ITMREF(NOL)
                     If fstat Raz [F:ITS] : Endif
                     Endif
Return
$LECITM             : # Lecture des tables article
Local Integer WRET, WSTA

Call LECITM(WSTOFCY,[M]ITMREF(NOL),"",0,"",WRET) From STKLIB
If WRET<>0  Return : Endif

[M]SHTSTO    = [F:ITV]DETSHT+[F:ITV]GLOSHT

# A voir ? si il faut ajouter CTLSTO et REJSTO
[M]PHYSTOSTU = [F:ITV]PHYSTO
If [M]PHYSTOSTU <> 0
    [M]PHYSTOSAU=[M]PHYSTOSTU*(1/[M]COE)
    Call QTEARR([M]PHYSTOSAU, [M]SAU) From TRTDIV
Else
    [M]PHYSTOSAU = 0
Endif

# Récupération des statuts autorisés
Raz WSTA
If [F:ITG]GLOAAAFLG=2 WSTA+=1 Endif
If [F:ITG]GLOQQQFLG=2 WSTA+=2 Endif
If [F:ITG]GLORRRFLG=2 WSTA+=4 Endif
# Calcul stock disponible
Call STODISTOT("",1,WSTA,"",[M]DISSTOSTU) From STKLIB
If [M]DISSTOSTU <> 0
    [M]DISSTOSAU=[M]DISSTOSTU*(1/[M]COE)
    Call QTEARR([M]DISSTOSAU, [M]SAU) From TRTDIV
Else
    [M]DISSTOSAU = 0
Endif
Return
#---------------------------------------------------#
# Controle client                                   #
#---------------------------------------------------#
$CTR_BPC
Local Integer OK, SPSTAT
Local Decimal ENCOURS, ENCOURSSHR
Local Date    WOSTDAT
Local Libelle WOSTCHGTYP
Local Char    WPARAM(10)

# -- Client inactif ---------------------------------
If [F:BPC]BPCSTA = 1 GMESSAGE = mess(004,119,1) : mkstat=2 : Return : Endif
# -- Client prospect --------------------------------
If [F:BPC]BPCTYP = 4 GMESSAGE = mess(152,199,1) : mkstat=2 : Return : Endif
# -- Contrôle en-cours
# On recherche le tiers risque lié au client
If [F:BPC]BPCRSK="" Return Endif
If [F:BPC]BPCNUM<>[F:BPC]BPCRSK
    Read [BPC]BPC0 = [F:BPC]BPCRSK : If fstat Raz [F:BPC] Endif
Endif
# -- Client bloqué ----------------------------------
If [F:BPC]OSTCTL = 3 GMESSAGE = mess(151,199,1) : mkstat=2 : Return : Endif
# -- L'encours client doit etre controle ------------
If [F:BPC]OSTCTL = 2 Return : Endif
# Calcul de l'en-cours en devise dossier (GOSTCTL=1) ou société (GOSTCTL=2)
If GOSTCHGTYP=2
    # Si Origine cours pour contrôle en-cours = actualisé
    WOSTDAT=datesyst                                        : # Date          : date du jour
    Call PARAML(GSOCIETE,"OSTTYPCUR",WPARAM) From ADOVAL     : # Type de cours : Type de cours ctrl au cours actualisé      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    WOSTCHGTYP= val(WPARAM)
Else
    # Si Origine cours pour contrôle en-cours = historique
    WOSTDAT=datesyst                                        : # Date          : date du jour
    WOSTCHGTYP=[F:BPC]CHGTYP                                : # Type de cours : Type de cours du document
Endif
Call CALENC([F:BPC]BPCNUM, WOSTDAT, ENCOURS) From TRTBPMVT
# L'en-cours est tjs en devise dossier
# Conversion de l'en-cours en devise société si nécessaire
If GOSTCTL=2 & GLOCALDEV<>GCURSHR
    Call CONVERT(GLOCALDEV, GCURSHR, GLOCALDEV, WOSTCHGTYP, WOSTDAT, ENCOURS, ENCOURSSHR, SPSTAT) From TRTDEV
Else
    ENCOURSSHR = ENCOURS
Endif
If ENCOURSSHR > [F:BPC]OSTAUZ GERR=3 : GMESSAGE = mess(29,192,1) Endif
Return
#---------------------------------------------------#
# Affichage article                                 #
#---------------------------------------------------#
$AFF_ITM
Local Integer NOL     : NOL=nolign-1
Local Char    WSTOFCY

If [M]ITMREF(NOL) = ""
#[M]STOFCY(NOL) = [M]YSTOFCY
#                       Affzo [M]STOFCY(NOL)
                       Raz [M]DISSTOSAU, DISSTOSTU, SHTSTO
                       Raz [M]PHYSTOSAU, PHYSTOSTU
                       Raz [M]ITMDES1, SAU,STU,COE
                       Effzo [M]15
Else                   [M]ITMDES1 = [M]DITMDES1(NOL)
                       [M]SAU     = [M]DSAU(NOL)
                       [M]STU     = [M]DSTU(NOL)
                       [M]COE     = [M]DCOE(NOL)
                       WSTOFCY=[M]STOFCY(NOL)
                       Gosub LECITM
                       Affzo [M]15
Endif
Return
#---------------------------------------------------#
# Initialisation du site d'expé                     #
#---------------------------------------------------#
$INIT_STOFCY
If [F:BPD]STOFCY <> ""
    If [F:FCY]FCY<>[F:BPD]STOFCY
        Read [FCY]FCY0=[F:BPD]STOFCY
    Endif
    If [F:FCY]LEGCPY=[M]CPY
        [M]YSTOFCY = [F:BPD]STOFCY
    Endif
Elsif GFCYDEF(7)<>""
    If [F:FCY]FCY<>GFCYDEF(7)
        Read [FCY]FCY0=GFCYDEF(7)
    Endif
    If [F:FCY]LEGCPY=[M]CPY
        [M]YSTOFCY = GFCYDEF(7)
    Endif
Endif
Return

