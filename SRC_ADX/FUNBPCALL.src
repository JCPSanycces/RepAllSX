#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTION  : TRTBPCALL  : Action traitement allocation client            #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub MODIF
 When "SUP"        : Gosub ANNUL
 When "SUI"        : Gosub SUIVANT
 When "PRE"        : Gosub PRECEDENT
 When "FIR"        : Gosub PREMIER
 When "LAS"        : Gosub DERNIER
 When "ABA"        : Gosub ABANDON
 When "END"        : Gosub ABORT
 When "FIN"        : Gosub FIN
Endcase
Return
#######################################################################
#    Détail des actions liées au traitement standard                  #
#######################################################################
#######################################################################
$INIT

Gosub OUVRE

Local Char     SAVBOITE(10)

Local Char     TIT(50) : TIT = mess(119,197,1)

Return
#######################################################################
$CONTROLE
Return
#######################################################################
$TERMINE

Local Integer OK : OK=1
Call OUINON (mess(56,191,1),OK) From GESECRAN
If OK=2 Gosub PURGE : Endif

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

BOITE = SAVBOITE

Return
#########################################################################
#    Détail des actions liées à la fenêtre de saisie                    #
#########################################################################
#########################################################################
$DEBUT

Local Integer ONUM(0..dim([M]VCRLIN)-1), MAXSTA

Raz [M]
REP=""
[M]CPY=GSOCIETE

 Link [STA] With
& [FCY]FCY0=[STA]STOFCY
& As [KSTA]

Return
#########################################################################
$FIN

If VERROU Gosub DEVERROU : Endif
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3

Return
#######################################################################
$ABANDON
Case REP
    When "" :
        If VERROU Gosub DEVERROU : Endif
        Gosub SET_CLE : Gosub LIRE
    When "M" :
        Gosub AB_MODIF
        Gosub SET_CLE : Gosub LIRE
        REP = ""
Endcase
Return

$AB_MODIF
If REP = "M" Gosub DEGRISE_CLE : Endif
Return

#######################################################################
$ABORT
OK  = 2
Return

#-----------------------------------------------------------------------#
#    Ouvre                                                              #
#-----------------------------------------------------------------------#
$OUVRE

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:BPC]) = 0 Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPR]) = 0 Local File BPARTNER   [BPR]:Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD]:Endif
If clalev([F:ITS]) = 0 Local File ITMSALES   [ITS]:Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER  [ITM]:Endif
If clalev([F:ITV]) = 0 Local File ITMMVT     [ITV]:Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT [ITF]:Endif
If clalev([F:ITG]) = 0 Local File ITMCATEG   [ITG]:Endif
If clalev([F:FCY]) = 0 Local File FACILITY   [FCY]:Endif
If clalev([F:ORD]) = 0 Local File ORDERS     [ORD]:Endif
If clalev([F:STA]) = 0 Local File STOALL     [STA]:Endif
If clalev([F:FCY]) = 0 Local File FACILITY   [FCY] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

Local Char    REP(1)
Local Char    WMESS(80), WMESS1(80), WMESS2(140), WMESS3(80)
Local Integer VERROU
Local Integer DERLIN
Local Char    WTRTLIG(1), WTRTORD(1), WSTOFCY(GLONFCY), WITMREF(GLONITM)
# --------------------------------------
# FGR 13/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  Local Char  WECCVALMAJ(type([F:ORD]ECCVALMAJ)-10)
  Local Char  WECCVALMIN(type([F:ORD]ECCVALMIN)-10)
Endif
# FGR 13/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
Local Integer WTYP
Local Char    WNUM, WCPY
Local Decimal WLIN, WSEQ
Local Decimal WALLSTU, WQTYWIP
Local Decimal LQTY
Local Integer OK, WRET, NBALL
Local Char    WITM(GLONITM) :      Raz WITM
Local Char    WFCY(GLONFCY) :      Raz WFCY
Local Date    WDAT

#---------------------------------------------------#
# Alimentation à partir du site de vente            #
#              du site financier   GFINRSP          #
#                 société          GSOCIETE         #
#                 devise société   GLOCALDEV        #
#---------------------------------------------------#
GFCY = GFCYDEF(5)
Call GETDEV(GFCY) From DEVSUB
#---------------------------------------------------#
# Récupération des parametres ventes                #
#---------------------------------------------------#
Call GLOBVAR(GFCY,"VEN") From TRTX3

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK   [ORDK]
# --- Déclaration classe ecran pour les allocations --- #
Local Mask ALLPAR [ALP]  : Raz [M:ALP]

Raz GWIP
If clalev([F:TCA]) = 0 : Local File TABCOUAFF [TCA] : Endif
# --- Récupération du code compteur
Call LECTCA(7,OK) From SUBTCA
If fstat | !OK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : Return
Endif
GWIP  = [F:TCA]CODNUM(8)
Close Local File [TCA]

Default File [STA]

Return

#---------------------------------------------------#
# SETBOUT                                           #
#---------------------------------------------------#
$SETBOUT

# Grisage/dégrisage des boutons
Raz ETABOU
Case REP
    When "" :         # Consultation
        If [M]BPCORD <> ""
#           Il y a des lignes d'allocation : Bouton supprimer
            If [M]NBLIG <> 0 ETABOU(GSUPP) = 1 : Endif
            ETABOU(GPREC) = 1
            ETABOU(GSUIV) = 1
        Endif
        ETABOU(GPREM) = 1
        ETABOU(GDERN) = 1
    When "M" :        # Modification
        ETABOU(GENRE) = 1
        ETABOU(GABAN) = 1
Endcase
ETABOU(GBFIN) = 1

Return


#---------------------------------------------------#
# Traitement des actions evenementielles            #
#---------------------------------------------------#
$APRES_MODIF

If find (COUZON, "BPCORD", "BPAADD")
    Assign "[M]"+COUZON With CZ
#    C'est une zone de clé : on tente une recherche --- #
    If [M]BPCORD <> ""
        Case REP
             When ""  :
#                 On deverrouille l'enregistrement courant
                If VERROU Gosub DEVERROU : Endif
#                 On positionne la clé (WNUM)
                Gosub SET_CLE
#                 On lit et on verouille
                Gosub LIRE
             When "M"  :
        Endcase
    Endif
Else
#    Ce n'est pas une zone de clé --------------------- #
    Case REP
        When "" :
#             On tente d'entrer en modif
            If [M]BPCORD <> ""
                RELIT = 0
                If !VERROU
#                      On verouille si cela n'a pas été fait
                    Gosub VERROU
                    If !VERROU
                        GERR=1 : GMESSAGE = mess(10,100,1)
                        mkstat = 1 : Return
                    Endif
                Endif
                If RELIT
                    Gosub SET_CLE
                    Gosub LIRE
                Endif
                REP = "M"
                Gosub GRISE_CLE
            Endif
        When "M" :
    Endcase
Endif
Return


$GRISE_CLE
Diszo [M]5
Return

$DEGRISE_CLE
Actzo [M]5
Return

#---------------------------------------------------#
$SET_CLE
Gosub SET_WNUM
Raz [M]
[M]CPY=WCPY
[M]BPCORD = vireblc(left$(WNUM, GLONBPC), 1)
[M]BPAADD = vireblc(mid$(WNUM, GLONBPC+1, GLONBPD), 1)
If [M]BPAADD <> "" Gosub LEC_BPD : Endif
Gosub INIT_STOFCY
Return

#---------------------------------------------------#
$SET_WNUM
WCPY = [M]CPY
WNUM = format$("K:"+num$(GLONBPC)+"X", [M]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M]BPAADD)
WNUM = vireblc(WNUM, 1)
Return

#---------------------------------------------------#
# Lecture des allocations à traiter                 #
#---------------------------------------------------#
$LIRE
nolign=0
DERLIN=0
Filter [KSTA] Where VCRTYP = 1 & VCRNUM=WNUM & VCRSEQ=0 & STOCOU=0 & [FCY]LEGCPY=WCPY
&            Order By ITMREF ; ALLDAT
For [KSTA] Hint Key STA1
    nolign+=1
    NOL=nolign-1
#    [M] = [F]
    [M]ITMREF(NOL)      = [F:STA]ITMREF
    [M]ALLDAT(NOL)      = [F:STA]ALLDAT
    [M]STOFCY(NOL)      = [F:STA]STOFCY
    [M]QTYSTUACT(NOL)   = [F:STA]QTYSTUACT
    [M]VCRLIN(NOL)      = [F:STA]VCRLIN
    Gosub LEC_ITM
    [M]YQTYSTUACT (NOL) = [F:STA]QTYSTUACT
    [M]DSAU (NOL)       = [F:ITM]SAU
    [M]DSTU (NOL)       = [F:ITM]STU
    Gosub LEC_ITS
    #[M]DITMDES1(NOL)    = [F:ITS]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]DITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
#   récupération du coef de conversion unite vente - unite stock
    Call SCAL_QUS(0, [M]ITMREF(NOL), [M]BPCORD, [M]DSAU(NOL), [M]DSTU(NOL), GBIDD1, [M]DCOE(NOL))
&                 From TRTVENQTE

    [M]QTYSAU(NOL)=[M]QTYSTUACT(NOL)*(1/[M]DCOE(NOL))
    Call QTEARR([M]QTYSAU(NOL), [M]DSAU(NOL)) From TRTDIV
    [M]UPDFLG(NOL) = 0
    [M]CREFLG(NOL) = NOL+1
    ONUM(NOL) = [M]VCRLIN(NOL)
    If [M]VCRLIN(NOL) > DERLIN DERLIN = [M]VCRLIN(NOL):Endif
Next
Filter [KSTA]
[M]NBLIG = nolign
MAXSTA   = nolign
GBPCNUM = [M]BPCORD

Gosub VERROU
Affzo [M]1-99
Return

#---------------------------------------------------#
# Modification du tableau des allocations           #
#---------------------------------------------------#
$MODIF
Call DEBTRANS From GLOCK
If GTRACE = "" Call OUVRE_TRACE (TIT) From LECFIC Endif
WMESS=mess(99,197,1)+" "+[M]BPCORD+" "+[M]BPAADD
Gosub ECRIRE
Gosub SET_CLE
Gosub LIRE
Gosub DEGRISE_CLE

$FIN_MODIF
Return


$DEVERROU
Unlock = SYMBOLE
If !fstat VERROU = 0 : Endif
Return

$VERROU
If WNUM <> ""
    SYMBOLE = "STA"+num$(1)+WNUM
    Lock = SYMBOLE With lockwait = 0
    If fstat
        VERROU=0
    Else
        VERROU=1
    Endif
Endif
Return

#----------------------------------------------------#
# Recherche allocations client suivant               #
#----------------------------------------------------#
$SUIVANT
Gosub ABORT
If !OK Return : Endif
If VERROU Gosub DEVERROU : Endif
Gosub SET_WNUM
Filter [KSTA] Where VCRTYP = 1 & [FCY]LEGCPY=WCPY
Read [F:KSTA]STA1 > 1;WNUM;99999999;99999999
Filter [KSTA]
Gosub SUIVPREV
Return

#----------------------------------------------------#
# Recherche allocations client precedent             #
#----------------------------------------------------#
$PRECEDENT
Gosub ABORT
If !OK Return : Endif
If VERROU Gosub DEVERROU : Endif
Gosub SET_WNUM
Filter [KSTA] Where VCRTYP = 1 & [FCY]LEGCPY=WCPY
Read [F:KSTA]STA1 < 1;WNUM;0;0
Filter [KSTA]
Gosub SUIVPREV
Return
#----------------------------------------------------#
# Recherche allocations premier client               #
#----------------------------------------------------#
$PREMIER
Gosub ABORT
If !OK Return : Endif
If VERROU Gosub DEVERROU : Endif
Filter [KSTA] Where VCRTYP = 1 & [FCY]LEGCPY=[M]CPY
Read [F:KSTA]STA1 First
Filter [KSTA]
Gosub SUIVPREV
Return
#----------------------------------------------------#
# Recherche allocations dernier client               #
#----------------------------------------------------#
$DERNIER
Gosub ABORT
If !OK Return : Endif
If VERROU Gosub DEVERROU : Endif
Filter [KSTA] Where VCRTYP = 1 & [FCY]LEGCPY=[M]CPY
Read [F:KSTA]STA1 < 2;"";0;0
Filter [KSTA]
Gosub SUIVPREV
Return

$SUIVPREV
Gosub AB_MODIF
If fstat <= 2 & [F:STA]VCRTYP = 1
    [M]BPCORD = vireblc(left$([F:STA]VCRNUM, GLONBPC), 1)
    [M]BPAADD = vireblc(mid$([F:STA]VCRNUM, GLONBPC+1, GLONBPD), 1)
Else
    GERR=1: GMESSAGE = mess(11,100,1)
Endif
Gosub SET_CLE
Gosub LIRE
REP = ""
Return
#---------------------------------------------------#
# Annulation des allocations du client              #
#---------------------------------------------------#
$ANNUL

WTYP=1
Raz WRET : Raz NBALL

If GTRACE = "" Call OUVRE_TRACE (TIT) From LECFIC : Endif

WMESS=mess(99,197,1)+" "+[M]BPCORD+" "+[M]BPAADD
Gosub SET_WNUM
#Gosub SET_CLE
WSEQ=0
If !VERROU
    Gosub VERROU
    If !VERROU
        GERR=1 : GMESSAGE = mess(10,100,1)
        Return
    Else
        Gosub LIRE
        Gosub SETBOUT
    Endif
Endif
Trbegin [STA], [ITV]
    For nolign=1 To [M]NBLIG
        NOL=nolign-1
        WLIN = [M]VCRLIN(NOL)
        WTRTLIG="A"
        WMESS1=mess(80,197,1)-[M]ITMREF(NOL)-mess(81,197,1)-[M]STOFCY(NOL)-mess(208,197,1)-format$(GFMD,[M]ALLDAT(NOL))
        WSTOFCY=[M]STOFCY(NOL) : WITMREF=[M]ITMREF(NOL)
#       Génération de l'allocation
        Call GENALLBPC(WITM,WFCY,WDAT,WNUM,WLIN,WSEQ,WTRTLIG,WALLSTU,WRET) From TRTVENALL
        If NBALL = 0 Call ECR_TRACE(WMESS,0) From GESECRAN  Endif
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        If WRET <> 0
            Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
            GOK=0 : Gosub AB_ECRIRE
        Endif
        WALLSTU*=-1
        WMESS2 = mess(106,197,1)+":"+format$("N:15F", WALLSTU)-[M]DSTU(NOL)
        Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
        WTRTORD= "A" : Gosub MAJORDERS
        NBALL=+1
    Next nolign
If WRET = 0 Commit : Endif
Gosub DEVERROU
Effzo
Gosub SET_CLE
Return

$ROLL_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL Return : Else : Goto ANNUL : Endif

$AB_ANNUL
Rollback
Return

#---------------------------------------------------#
# Mise à jour des modifications effectuées          #
#---------------------------------------------------#
$ECRIRE
WTYP=1
Raz LQTY : Raz WRET : Raz NBALL : Raz WSEQ
Trbegin [STA], [ITV]
    Gosub SET_WNUM
# --- 1er   passage : Suppression des lignes annulees   --- #
    For nolign=1 To MAXSTA
        NOL = nolign-1
        If !find(nolign, [M]CREFLG(0..[M]NBLIG-1))
            WLIN = ONUM(NOL)
            WTRTLIG="A"
            Read [STA]STA1=WTYP;WNUM;WLIN;WSEQ;0
            If !fstat
                WMESS1=mess(80,197,1)-[F:STA]ITMREF-mess(81,197,1)-[F:STA]STOFCY-mess(208,197,1)-format$(GFMD,[F:STA]ALLDAT)
                WSTOFCY=[F:STA]STOFCY : WITMREF= [F:STA]ITMREF
                If [F:ITM]ITMREF<>[F:STA]ITMREF
                    Read [ITM] ITM0=[F:STA]ITMREF : If fstat Raz [F:ITM] : Endif
                Endif
            Else
                Call RSTA("STA", num$(WTYP)-num$(LNUM)-num$(WLIN)-num$(WSEQ)) From GLOCK
                GOK=0 : Gosub AB_ECRIRE
            Endif
#           Suppression de l'allocation
            Call GENALLBPC(WITM,WFCY,WDAT,WNUM,WLIN,WSEQ,WTRTLIG,WALLSTU,WRET) From TRTVENALL
            If NBALL = 0 Call ECR_TRACE(WMESS,0) From GESECRAN  Endif
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            If WRET <> 0
                Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
                GOK=0 : Gosub AB_ECRIRE
            Endif
            WALLSTU*=-1
            WMESS2 = mess(106,197,1)+":"+format$("N:15F", WALLSTU)-[F:ITM]STU
            Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
            WTRTORD= "A" : Gosub MAJORDERS
            NBALL+=1
        Endif
    Next nolign
    If WRET Return : Endif
# --- 2eme passage : Creation et modification           --- #
    For nolign=1 To [M]NBLIG
        NOL = nolign-1
        WMESS1=mess(80,197,1)-[M]ITMREF(NOL)-mess(81,197,1)-[M]STOFCY(NOL)-mess(208,197,1)-format$(GFMD, [M]ALLDAT(NOL))
        If ([M]UPDFLG(NOL)<>0 & [M]YQTYSTUACT(NOL)<>[M]QTYSTUACT(NOL)) | [M]CREFLG(NOL) = 0
            If [M]VCRLIN(NOL) <> 0 WLIN=[M]VCRLIN(NOL)
            Else                   DERLIN+=1
                                   [M]VCRLIN(NOL)=DERLIN
                                   WLIN = [M]VCRLIN(NOL): Endif
            WQTYWIP=[M]QTYSTUACT(NOL)
            If [M]CREFLG(NOL) = 0
                WTRTLIG="C" : WTRTORD="C"
                WALLSTU=[M]QTYSTUACT(NOL)
            Else
                WTRTORD="M"
                If [M]YQTYSTUACT(NOL) < [M]QTYSTUACT(NOL)
                    WTRTLIG="M"
                    WALLSTU=[M]QTYSTUACT(NOL) - [M]YQTYSTUACT(NOL)
                Else
                    WTRTLIG="D"
                    WALLSTU=[M]YQTYSTUACT(NOL) - [M]QTYSTUACT(NOL)
                Endif
            Endif
#           Génération de l'allocation
            Call GENALLBPC([M]ITMREF(NOL),[M]STOFCY(NOL),[M]ALLDAT(NOL),WNUM,WLIN,WSEQ,WTRTLIG,WALLSTU,WRET) From TRTVENALL
            If NBALL = 0 Call ECR_TRACE(WMESS,0) From GESECRAN  Endif
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            If WRET <> 0
                Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
                GOK=0 : Gosub AB_ECRIRE
            Endif
            If WTRTLIG="C"
                If WALLSTU <> [M]QTYSTUACT(NOL)
                    WMESS2 = mess(165,197,1)+format$("N:15F", [M]QTYSTUACT(NOL))-[M]DSTU(NOL)
                    WMESS3 = mess(106,197,1)+":"+format$("N:15F", WALLSTU)-[M]DSTU(NOL)
                    Call ECR_TRACE(sum("          ",mess(207,197,1)," ",WMESS2," ",WMESS3),0) From GESECRAN
                Else
                    WMESS2 = mess(106,197,1)+":"+format$("N:15F", WALLSTU)-[M]DSTU(NOL)
                    Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
                Endif
            Elsif WTRTLIG="D"
                WMESS2=mess(483,197,1)+format$("N:15F",[M]YQTYSTUACT(NOL))-[M]DSTU(NOL)-mess(484,197,1)+format$("N:15F",[M]QTYSTUACT(NOL))-[M]DSTU(NOL)
                Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
            Else
                If WALLSTU <> [M]QTYSTUACT(NOL)
                    WMESS2 = mess(165,197,1)+format$("N:15F", [M]QTYSTUACT(NOL)-[M]YQTYSTUACT(NOL))-[M]DSTU(NOL)
                    WMESS3 = mess(106,197,1)+":"+format$("N:15F", WALLSTU-[M]YQTYSTUACT(NOL))-[M]DSTU(NOL)
                    Call ECR_TRACE(sum("          ",mess(207,197,1)," ",WMESS2," ",WMESS3),0) From GESECRAN
                Else
                    WMESS2 = mess(106,197,1)+":"+format$("N:15F", WALLSTU-[M]YQTYSTUACT(NOL))-[M]DSTU(NOL)
                    Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
                Endif
                WMESS2=mess(483,197,1)+format$("N:15F",[M]YQTYSTUACT(NOL))-[M]DSAU(NOL)-mess(484,197,1)+format$("N:15F",[M]QTYSTUACT(NOL))-[M]DSTU(NOL)
                Call ECR_TRACE(sum("          ",WMESS2),0) From GESECRAN
            Endif
            NBALL+=1
            WSTOFCY=[M]STOFCY(NOL) : WITMREF=[M]ITMREF(NOL)
            Gosub MAJORDERS
        Elsif ([M]UPDFLG(NOL)<>0)
#           Modification de l'allocation (modification de la date)
            Local Char WPRE : Raz WPRE
            WLIN = ONUM(NOL)
            Call MAJALLBPC([M]ALLDAT(NOL),1,WNUM,WLIN,WSEQ,WPRE,WRET) From TRTVENALL
            If WRET <> 0
                If NBALL = 0 Call ECR_TRACE(WMESS,0) From GESECRAN  Endif
                Call ECR_TRACE(WMESS1,0) From GESECRAN
                Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
                GOK=0 : Gosub AB_ECRIRE
            Endif
            # 94475 : Maj date de fin sur l'encours
            WTRTORD="M"
            WSTOFCY=[M]STOFCY(NOL) : WITMREF=[M]ITMREF(NOL)
            WQTYWIP=[M]QTYSTUACT(NOL)
            Gosub MAJORDERS
            # 94475
        Endif
    Next nolign
If WRET = 0 Commit : Endif
$FIN_ECRIRE
REP=""
Gosub DEGRISE_CLE
Return

$ROLL_ECRIRE
Rollback
Call ROLL From GLOCK
If GROLL Return : Else : Goto ECRIRE : Endif

$AB_ECRIRE
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

#--------------------------------------------------#
# Mise à jour de l'encours                         #
#--------------------------------------------------#
$MAJORDERS
Local Char     WWIPNUM(GLONVCR), WORIFCY(GLONFCY)
Local Date     WALLDAT
Local Integer  STAT

# En création : recherche du prochain n°en-cours
If WTRTORD="C"
    Call NUMERO(GWIP,[M]STOFCY(NOL),date$,"",WWIPNUM,STAT) From SUBANM
    If STAT <> 0
        GERR=1 : GMESSAGE = GWIP-mess(60,199,1)
    Endif
Endif
# En modif ou suppression de l'allocation : Il faut retrouver le n° de l'en-cours
If WTRTORD = "A" | WTRTORD = "M"
#   Retrouver le n° en-cours
    Filter [ORD] Where STOFCY=WSTOFCY & VCRTYP=WTYP &
&                      VCRNUM=WNUM & VCRLIN=WLIN & VCRSEQ=0 & WIPTYP=12 & ITMREF=WITMREF
&                Order By Key ORD3
    Read [F:ORD]ORD3 First
    # --------------------------------------
    # FGR 13/04/2015 : X3SUIVI105605 (début)
    #If !fstat WWIPNUM=[F:ORD]WIPNUM : Endif
    If !fstat Then
      WWIPNUM = [F:ORD]WIPNUM
      If dim(WECCVALMAJ) >= 0 Then
        WECCVALMAJ = [F:ORD]ECCVALMAJ
      Endif
      If dim(WECCVALMIN) >= 0 Then
        WECCVALMIN = [F:ORD]ECCVALMIN
      Endif
    Endif
    # FGR 13/04/2015 : X3SUIVI105605 (fin)
    # --------------------------------------
    Filter [ORD]
Endif
If WTRTORD = "C" | WTRTORD = "M"
    WORIFCY = GFCYDEF(5)
    WALLDAT = [M]ALLDAT(NOL)
Endif

Local Char    LNUM(type(WNUM)-10) : LNUM=WNUM    # FGR 13/04/2015 : X3SUIVI105605
Local Decimal LQTY : LQTY=WQTYWIP
Gosub APPELWIP_BPCALL From TRTVENMAJ
Return

#--------------------------------------------------#
# Purge des allocations globales echues            #
#--------------------------------------------------#
$PURGE
Local Char    WFCY(GLONFCY) : WFCY = ""
Local Char    WITM(GLONITM): WITM = ""
Local Date    WDAT    : WDAT = date$
Local Integer WRET

If GTRACE="" Call OUVRE_TRACE("") From LECFIC Endif
Trbegin [STA], [ITV]
    Call PURGLO(WFCY, WITM, WDAT, 2, WRET) From STKALL
    Call PURORD(WFCY, WITM, WDAT,2,WRET)
If WRET = 0 Commit
Else        Rollback : Endif

Return
###########################################################
#Suppression de tous les en-cours liés aux allocations échus
# attention mettre Trbegin avant appel
#                  commit ou rollback selon code retour
# Paramètres entrée
# LFCY = Site / rien si tous les sites
# LITM = Numéro d'article / rien si tous les articles
# LDAT = date de référence (défaut date du jour)
# LTRC = 1 si fichier trace (ouverture+ecritures+fermeture+lecture)
#      = 2 si fichier trace (ecritures seules)
#
# Paramètres sortie
# LRET = code retour
#
Subprog PURORD(LFCY,LITM,LDAT,LTRC,LRET)
Value    Char    LFCY
Value    Char    LITM
Value    Date    LDAT
Value    Integer LTRC
Variable Integer LRET
#
Local    Date    WDAT
Local    Integer WRET
Local    Char    WMSG(120)
#Préparation des paramètres
LRET = 0
If LDAT = [0/0/0]
  WDAT = date$-1
Else
  WDAT = LDAT
Endif
#Ouverture trace
If LTRC = 1
   WMSG = mess(77,196,1)+" : "+format$("D:"+GFMDAT,WDAT)
   Call OUVRE_TRACE(WMSG) From LECFIC
Endif
If clalev([F:ORD1]) = 0 : Local File ORDERS [ORD1] : Endif
#Sélection enregistrements à traiter
If LFCY = ""
  If LITM = ""
    Filter [ORD1] Where WIPTYP=12 & ENDDAT < WDAT Order By Key ORD0
  Else
    Filter [ORD1] Where ITMREF = LITM & WIPTYP=12 & ENDDAT < WDAT Order By Key ORD0
  Endif
Else
  If LITM = ""
    Filter [ORD1] Where STOFCY = LFCY & WIPTYP=12 & ENDDAT < WDAT Order By Key ORD0
  Else
    Filter [ORD1] Where STOFCY = LFCY & ITMREF = LITM & WIPTYP=12 & ENDDAT < WDAT Order By Key ORD1
  Endif
Endif
#Lecture
For [ORD1]
    Readlock
    If fstat <> 0  LRET =fstat : Break : Endif
    Delete [ORD1]
    If fstat LRET= fstat : Call FSTA("STA") From GLOCK : Break  : Endif
Next
Filter [ORD1]
If LRET End Endif
#Fin de traitement
If LRET = 0
  If LTRC <> 0
    WMSG = mess(77,196,1)+" : "+format$("D:"+GFMDAT,WDAT)
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
Else
  If LTRC <> 0
    WMSG = mess(77,196,1)+" : "+format$("D:"+GFMDAT,WDAT)+mess(139,199,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
Endif
If LTRC = 1
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#
Close Local File [ORD1]
End

