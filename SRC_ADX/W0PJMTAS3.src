#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLNK
mkstat = 0
zoncou = "NBLNK"
indice = 0
status = 1
zoncou = "NBLNK"
If varmode([M]NBLNK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLNK" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLNK
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLNK = nolign
   status = 75
   Call SAI_NBLNK(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLNK From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLNK" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLNK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLNK
mkstat = 0
zoncou = "NBLNK"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLNK From SUBPJTA
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLNK" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone OPPNUMLNK
mkstat = 0
zoncou = "OPPNUMLNK"
WCHAR = [M]OPPNUMLNK(indice)
If varmode([M]OPPNUMLNK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUMLNK" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PIM","!A",[M]OPPNUMLNK(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUMLNK" : GZNUM = 1002424 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]OPPNUMLNK(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPPNUMLNK([M]OPPNUMLNK(indice)) From SUBPJTA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPPNUMLNK" : GZNUM = 1002424 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TASCODLNK
mkstat = 0
zoncou = "TASCODLNK"
WCHAR = [M]TASCODLNK(indice)
If varmode([M]TASCODLNK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TASCODLNK" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TASCODLNK(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TASCODLNK" : GZNUM = 1002396 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]TASCODLNK(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TASCODLNK([M]TASCODLNK(indice)) From SUBPJTA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TASCODLNK" : GZNUM = 1002396 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TASLNKTYP
mkstat = 0
zoncou = "TASLNKTYP"
IMPENT = [M]TASLNKTYP(indice)
WNUM = IMPENT
If varinit([M]TASLNKTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TASLNKTYP,indice)=0
 [M]TASLNKTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TASLNKTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TASLNKTYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TASLNKTYP" : GZNUM = 10108 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TASLNKTYP(IMPENT) From SUBPJTA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TASLNKTYP" : GZNUM = 10108 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TASLNKTYP(indice) = IMPENT

## Zone TASLNKCSTR
mkstat = 0
zoncou = "TASLNKCSTR"
IMPENT = [M]TASLNKCSTR(indice)
WNUM = IMPENT
If varinit([M]TASLNKCSTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]TASLNKCSTR,indice)=0
 [M]TASLNKCSTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TASLNKCSTR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TASLNKCSTR(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TASLNKCSTR" : GZNUM = 1002411 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TASLNKCSTR(IMPENT) From SUBPJTA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TASLNKCSTR" : GZNUM = 1002411 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TASLNKCSTR(indice) = IMPENT

## Zone TASLNKLAG
mkstat = 0
zoncou = "TASLNKLAG"
WNUM = [M]TASLNKLAG(indice)
If varmode([M]TASLNKLAG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TASLNKLAG" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]TASLNKLAG(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TASLNKLAG([M]TASLNKLAG(indice)) From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TASLNKLAG" : GZNUM = 1003273 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
WDATE = [M]STRDAT(indice)
If varmode([M]STRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]STRDAT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_STRDAT([M]STRDAT(indice)) From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
WDATE = [M]ENDDAT(indice)
If varmode([M]ENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]ENDDAT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_ENDDAT([M]ENDDAT(indice)) From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBLNK
mkstat = 0
zoncou = "NBLNK"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTAS3"
Return

