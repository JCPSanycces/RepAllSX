#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBPPI2 : Picking des besoins achats (cde/art)         MBT 08/06/98 #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
# prise en compte des besoins "PICKING" et ne sert qu'à gérer le      #
# masque écran "PPICORD2 [PPI2]".                                     #
#######################################################################

$ACTION
Case ACTION
 When "AB1_NBLIG" : Gosub AB1_NBLIG
Endcase
Return


Subprog C_WITMREF(VALEUR)
#-------------------------------------------#
# Contrôle réf.article géré ou non en stock #
#-------------------------------------------#
Variable Char    VALEUR()
Read [ITM] ITM0=VALEUR : If fstat Raz [F:ITM] : End : Endif
End

Subprog AM_WITMREF(VALEUR)
#----------------------------------------------------------------------------------#
# Après modif de la réf.article : Chargement désignation, raz et effacement lignes #
#----------------------------------------------------------------------------------#
Variable Char    VALEUR()
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMREF<>""
  Local Integer OK
  If [F:ITM]ITMSTA=3
    OK=2 : Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
    If OK=1  mkstat=1 : End : Endif
  Elsif [F:ITM]ITMSTA<>1
    Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
    mkstat=1 : End
  Endif
Endif
# Issue 10622 - 2011-12-30 by MUARN : ajout article fin
If [M]WITMREFEND = ""     : [M]WITMREFEND = VALEUR : Affzo [M]WITMREFEND : Endif
If [M]WITMREFEND < VALEUR : [M]WITMREFEND = VALEUR : Affzo [M]WITMREFEND : Endif
# Issue 85565 GA 10/2012
If [F:ITM]SCPFLG=2 [M:PPI2]SCOFLG=1 Else [M:PPI2]SCOFLG=2 Endif
Affzo [M:PPI2]SCOFLG
#-----
#[M:PPI2]WITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PPI2]WITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Affzo [PPI2]WITMDES1
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog AM_MAXDAT(VALEUR)
#---------------------------------------------------------#
# Après modif de la date borne : Raz et effacement lignes #
#---------------------------------------------------------#
Variable Date    VALEUR
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
# Issue 10622 - 2011-12-30 by MUARN : ajout date fin
If VALEUR <> [0/0/0] : [M]MAXDATEND = eomonth(VALEUR) : Affzo [M]MAXDATEND : Endif
End

Subprog AM_FOUDEB(VALEUR)
#-------------------------------------------#
# Après modif de la borne fournisseur début #
#-------------------------------------------#
Variable Char    VALEUR()
# Issue 10622 - 2011-12-30 by MUARN : ajout fenêtre critère
If [M]FOUFIN<VALEUR
  [M]FOUFIN=VALEUR : Affzo [M]FOUFIN
Endif
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog C_FOUFIN(VALEUR)
#------------------------------------#
# Contrôle sur borne fournisseur fin #
#------------------------------------#
Variable Char    VALEUR()
If VALEUR<[M:PPI2]FOUDEB
  GMESSAGE=mess(44,199,1) : mkstat=1 : End
Endif
End

Subprog AM_FOUFIN(VALEUR)
#-----------------------------------------#
# Après modif de la borne fournisseur fin #
#-----------------------------------------#
Variable Char    VALEUR()
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog AM_CTMFLG(VALEUR)
#------------------------------------------#
# Après modif de l'indicateur contremarque #
#------------------------------------------#
Variable Integer VALEUR
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog AM_CHXDAT(VALEUR)
#-----------------------------------------------------------------------#
# Après modif du choix date de sélection : Raz et effacement des lignes #
#-----------------------------------------------------------------------#
Variable Integer VALEUR
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog AM_SCOFLG(VALEUR) # ISsue 84500 GA 10/2012
#--------------------------------------------#
# Après modif de l'indicateur sous-traitance #
#--------------------------------------------#
Variable Integer VALEUR
Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
End

Subprog C_NBLIG
#------------------------------#
# Contrôle sur numéro de ligne #
#------------------------------#
Local    Integer NOL
If status=75 NOL=nolign-1 : Gosub TEST_MOD : Endif
End

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
Return

Subprog AS_NBLIG
#-------------------------------------#
# Chargement des lignes si nécessaire #
#-------------------------------------#
If [M:PPI2]NBLIG=0 Gosub CHARG_TABLEAU : Call IB_NBLIG : Endif
If [M:PPI2]TOTQTY=0
  Disable GSTAOK : GETABOU(GVALI)=0   : # Désactivation Ok
Else
  Enable  GSTAOK : GETABOU(GVALI)=1   : # Activation    Ok
Endif
If [M:PPI2]NBLIG=0
  Disable GSTABOU2+1, GSTABOU2+2      : # Désactivation Inclure / Exclure
  GETABOU(GSPE1)=0 : GETABOU(GSPE2)=0
  Call MESSAGE(mess(96,194,1)) From GESECRAN
  # mkstat=1
Else
  Enable  GSTABOU2+1, GSTABOU2+2      : # Activation    Inclure / Exclure
  GETABOU(GSPE1)=1 : GETABOU(GSPE2)=1
Endif
End

Subprog IB_NBLIG
#------------------------------------------------------------------------------#
# Activation des boutons "Tri date" "Tri site" "Tri article" "Inclure/exclure" #
#------------------------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If [M:PPI2]NBLIG>0
  GBOUT2=mess(449,198,1) : GBOUT3=mess(115,198,1)
  GBOUT4=mess(116,198,1) : GBOUT5=mess(127,198,1)
Endif
GBOUT6=mess(306,198,1)
If dim([M:PPI2]ITMREF)<nolign End : Endif : # Maximum lignes atteint
If [M:PPI2]VCRNUM(nolign-1)<>"" | [M:PPI2]SOHNUM(nolign-1)<>""
  If [M:PPI2]WIPCOD(nolign-1)="SOF"
    GBOUT1=mess(391,198,1)
  Elsif [M:PPI2]WIPCOD(nolign-1)="POP"
    GBOUT1=mess(61,198,1)
  Endif
Else
  Raz GBOUT1
Endif
End

$AB1_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel sur DA ou cde vente #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WCLE1 (GLONVCR)
Local Char     WOBJET(GLONAOB)
If [M:PPI2]WIPCOD(NOL)="SOF"
  WCLE1 =[M:PPI2]SOHNUM(NOL)
  WOBJET="SOH"
Else
  WCLE1 =[M:PPI2]VCRNUM(NOL)
  WOBJET="PSH"
Endif
Return

Subprog B2_NBLIG
#----------------------------#
# Tri par date début et site #
#----------------------------#
Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]STRDAT(indice),
&                                          [M:PPI2]STOFCY(indice),
&                                          [M:PPI2]VCRNUM(indice),
&                                          [M:PPI2]VCRLIN(indice)
Affzo [PPI2]10
End

Subprog B3_NBLIG
#--------------------------#
# Tri par date fin et site #
#--------------------------#
Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]ENDDAT(indice),
&                                          [M:PPI2]STOFCY(indice),
&                                          [M:PPI2]VCRNUM(indice),
&                                          [M:PPI2]VCRLIN(indice)
Affzo [PPI2]10
End

Subprog B4_NBLIG
#----------------------#
# Tri par site et date #
#----------------------#
Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]STOFCY(indice),
&                                          [M:PPI2]ENDDAT(indice),
&                                          [M:PPI2]VCRNUM(indice),
&                                          [M:PPI2]VCRLIN(indice)
Affzo [PPI2]10
End

Subprog B5_NBLIG
#-------------------------#
# Tri par article et date #
#-------------------------#
Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]ITMREF(indice),
&                                          [M:PPI2]ENDDAT(indice),
&                                          [M:PPI2]VCRNUM(indice),
&                                          [M:PPI2]VCRLIN(indice)
Affzo [PPI2]10
End

Subprog B6_NBLIG
#-----------------#
# Inclure/exclure #
#-----------------#
If [M:PPI2]PICQTY(nolign-1)=0
  [M:PPI2]PICQTY(nolign-1)=[M:PPI2]RMNEXTQTY(nolign-1)
Else
  [M:PPI2]PICQTY(nolign-1)=0
Endif
[M:PPI2]TOTQTY=sum([M:PPI2]PICQTY(0..NBLIG-1))
Affzo [PPI2]PICQTY(nolign-1)
If [M:PPI2]TOTQTY=0
  Disable GSTAOK : GETABOU(GVALI)=0   : # Désactivation Ok
Else
  Enable  GSTAOK : GETABOU(GVALI)=1   : # Activation    Ok
Endif
#mkstat=4 : # Pour ne pas perdre le plein écran !
End

Subprog AVANT_NBLIG
#---------------#
# Avant ligne : #
#---------------#
End

Subprog APRES_NBLIG
#----------------------------------------#
# Après ligne : Recalcul quantité totale #
#----------------------------------------#
If [M:PPI2]NBLIG>0 [M:PPI2]TOTQTY=sum([M:PPI2]PICQTY(0..[M:PPI2]NBLIG-1)) : Endif
End

Subprog AV_ITMREF(VALEUR)
#-------------------------------------------------#
# Colorisation en bleu de la référence article    #
# si celle-ci fait l'objet d'une commande ouverte #
#-------------------------------------------------#
Variable Char    VALEUR()
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
 Look [POC] POC2 First
Filter [POC]
If fstat
  pcolor=GCOUL(0) : # Noir
Else
  pcolor=GCOUL(3) : # Bleu
Endif
End

Subprog AS_PICQTY(VALEUR)
#--------------------------------#
# Avant saisie "Quantité totale" #
#--------------------------------#
Variable Decimal VALEUR
# Issue 13072 - 2012-01-19 by MUARN : quantité mini de commande
Local Decimal WQTEUA
If !clalev([F:ITM]) Local File ITMMASTER [ITM] : Endif
If !clalev([F:ITP]) Local File ITMBPS [ITP] : Endif
Read [ITM] ITM0=[M:PPI2]ITMREF(nolign-1)
If VALEUR = 0
  Call PCAL_QTY([M:PPI2]RMNEXTQTY(nolign-1),[M:PPI2]STU(nolign-1),WQTEUA,[F:ITM]PUU,
&            [M:PPI2]ITMREF(nolign-1),[M:PPI2]BPRNUM(nolign-1),1,GBIDD1) From TRTACHQTE1
  Read [ITP] ITP0=[M:PPI2]ITMREF(nolign-1);[M:PPI2]BPRNUM(nolign-1)
  If fstat
    VALEUR= [M:PPI2]RMNEXTQTY(nolign-1)
  Else
    If WQTEUA < [F:ITP]PURMINQTY
      Call PCAL_QTY([F:ITP]PURMINQTY, [F:ITM]PUU, VALEUR, [M:PPI2]STU(nolign-1),
&               [M:PPI2]ITMREF(nolign-1), [M:PPI2]BPRNUM(nolign-1),1,GBIDD1) From TRTACHQTE1
    Else
      VALEUR= [M:PPI2]RMNEXTQTY(nolign-1)
    Endif
  Endif
  [M:PPI2]TOTQTY=sum([M:PPI2]PICQTY(0..[M:PPI2]NBLIG-1))
  # Issue 93849 - 2013-11-04 by MUARN : perte du format de l'unité de stock
  #Affzo [PPI2]TOTQTY,10
  Affzo [PPI2]TOTQTY, PICQTY(nolign-1)
Endif
End

Subprog IB_PICQTY
#----------------------------------------#
# Activation du bouton "Quantité totale" #
#----------------------------------------#
GBOUT1=mess(47,198,1)
End

Subprog B1_PICQTY(VALEUR)
#------------------------------------#
# Prise en compte totale de la ligne #
#------------------------------------#
Variable Decimal VALEUR
VALEUR=[M:PPI2]RMNEXTQTY(nolign-1) : mkstat=99
End

Subprog C_PICQTY(VALEUR)
#-------------------------#
# Contrôle quantité prise #
#-------------------------#
Variable Decimal VALEUR
#If VALEUR>[M:PPI2]RMNEXTQTY(nolign-1) & [M:PPI2]WIPCOD(nolign-1)<>"SOF"
#  mkstat=1
#Endif
If [M:PPI2]BPRNUM(nolign-1)<>""
  If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
  If [F:BPR]BPRNUM<>[M:PPI2]BPRNUM(nolign-1)
    Read [BPR]BPR0=[M:PPI2]BPRNUM(nolign-1)
    If fstat : Raz [F:BPR] : Endif
  Endif
Endif
End

Subprog AM_PICQTY(VALEUR)
#-------------------------#
# Contrôle quantité prise #
#-------------------------#
Variable Decimal VALEUR
# Issue 13072 - 2011-12-14 by MUARN : controle mini de commande
Local Decimal  QTEUA
Local Integer WOK
Local Shortint NOL : NOL=nolign-1
If !clalev([F:ITP]) Local File ITMBPS [ITP] : Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] : Endif
Read [ITM] ITM0=[M:PPI2]ITMREF(NOL)
Call PCAL_QTY(VALEUR,[M:PPI2]STU(NOL),QTEUA,[F:ITM]PUU,
&            [M:PPI2]ITMREF(NOL),[M:PPI2]BPRNUM(NOL),1,GBIDD1) From TRTACHQTE1
Read [ITP] ITP0=[M:PPI2]ITMREF(NOL);[M:PPI2]BPRNUM(NOL)
If QTEUA<[F:ITP]PURMINQTY
#   GBIDD1=QTEUA
   GMESSAGE=mess(14,194,1)-format$("N:15F",[F:ITP]PURMINQTY)-[F:ITM]PUU
   If GPOHMINQTY=1
      mkstat=1
      If CODE=1 GERR=1 : Endif
      End
   Elsif GPOHMINQTY=2
      WOK=2
      Call AVERTIR (GMESSAGE, WOK)From GESECRAN
      If WOK=1
          Raz GMESSAGE
          mkstat=1
          If CODE=1 GERR=1 : Endif
          End
      Endif
    Endif
    Raz GMESSAGE
Endif
#----- Avertissement si contremarque -----#
If [M:PPI2]WIPCOD(nolign-1)="SOF"
  If VALEUR<>0 & VALEUR<>[M:PPI2]RMNEXTQTY(nolign-1)
    Local Integer OK
    OK=2 : Call AVERTIR(mess(117,194,1),OK) From GESECRAN
    If OK=1 mkstat=1 : End : Endif
  Endif
Endif
#-----
# 106430 - Purchase planning
[M:PPI2]LINWEI(nolign-1) = [F:ITM]ITMWEI * VALEUR
[M:PPI2]LINVOL(nolign-1) = [F:ITM]ITMVOU * VALEUR
[M:PPI2]LINTCTRWEI(nolign-1) = [M:PPI2]LINWEI(nolign-1)
[M:PPI2]LINTCTRVOL(nolign-1) = [M:PPI2]LINVOL(nolign-1)
If [M:PPI2]LINWEU(nolign-1)<>[M:PPI2]WEU
  Call CONVERT_QTY([M:PPI2]LINWEU(nolign-1),[M:PPI2]WEU,[M:PPI2]LINTCTRWEI(nolign-1))From TRTX3
Endif
If [M:PPI2]LINVOU(nolign-1)<>[M:PPI2]VOU
  Call CONVERT_QTY([M:PPI2]LINVOU(nolign-1),[M:PPI2]VOU,[M:PPI2]LINTCTRVOL(nolign-1))From TRTX3
Endif

[M:PPI2]WEITOT=sum([M:PPI2]LINTCTRWEI(0..[M:PPI2]NBLIG-1))
[M:PPI2]VOLTOT=sum([M:PPI2]LINTCTRVOL(0..[M:PPI2]NBLIG-1))

Affzo [M:PPI2]LINWEI(nolign-1), LINVOL(nolign-1), WEITOT, VOLTOT

[M:PPI2]TOTQTY-=[M:PPI2]PICQTY(nolign-1)
[M:PPI2]TOTQTY+=VALEUR
End

$CHARG_TABLEAU
#-----------------------------------------------------------------------#
# Chargement du tableau des lignes                                      #
#-----------------------------------------------------------------------#
# CODE : Code traitement  1 = Prise en compte des "POS"                 #
#                         2 = Prise en compte des "POP"                 #
#                         3 = Prise en compte des "POS" et "POP"        #
#                         4 = Prise en compte des "SCS", "SCP" et "SCF" #
#                             sr 75543 : Seulement les SCF              #
#                         6 = Prise en compte des  DA                   #
#                         9 = Prise en compte des "EOS", "EOP" et "EOF" #
#                             sr 86705 : Seulement les EOF              #
#                        10 = Prise en compte de tout sauf EOx          #
#                        11 = Prise en compte de tout sauf SCx          #
#                        12 = Pas de besoins de sous-traitance          #
#                        13 = Prise en compte de tout                   #
#-----------------------------------------------------------------------#
Call TEMPON("O") From GESECRAN : # Opération en cours ...
Local Date     BORNE
Local Char     CRITERES(240), CRITLNK(50), REFART(GLONITM), WX(2)
# Issue 10622 - 2011-12-29 by MUARN : XZSCRITERES sous dimmensionné
Local Char     ABREV(4), XZSCRITERES(240), XZSCRITLNK(50), CRITSUP(240), CRITLNK2(240)
Local Char     CRITERES1(250), CRITERES2(250) #issue 10622 fenetre criteres muarn 01/02/2012
# Issue 114623 - 2016-02-23 by SR : Prendre en compte les critères TCLCOD et TSICOD
Local Char     CRITERES3(250)
# Issue 112754 - 2017-01-20 by MUARN : Besoin criteres supplémentaire
Local Char     CRITERES4(250)
Local Shortint WI
# End issue 114623
Local Shortint I, SAVXZSI, TRAIT, TYPFILT, WRET
Local Decimal  RMNQTY
Local Integer  WCDTSTA, WIPTYPSOH
Local Integer  WMANHOLDBTB #Issue 119459 - 2017-03-09 by CATUA
Local Char CRITERESITM(240) # Issue 10622 - 2011-12-29 by MUARN : critere pour articles
# Issue 104550 - 2014-12-08 by SR
Local Char    FORMULE1(250)
# Issue X3-55891 - 2018-08-20 by SR : Déclinaison par site des données Article/fournisseur
Local Integer WRETOUR, WITMBPS
Local Char    WBPSNUM(GLONBPS)
# End issue X3-55891
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
# End issue 104550
#-----
If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
#-----
REFART=[M:PPI2]WITMREF

# Issue 10622 - 2011-12-29 by MUARN : ajout article fin
#If [M:PPI2]WITMDES1="" WX='>=' Else WX='=' : Endif
If [M:PPI2]WITMREF <> ""
    CRITERESITM = 'ITMREF>=[M:PPI2]WITMREF'      # borne début article
Endif
If [M:PPI2]WITMREFEND<>""
  If CRITERESITM <> ""
    CRITERESITM += ' & ITMREF<=[M:PPI2]WITMREFEND'      # borne fin   article
  Else
    CRITERESITM += 'ITMREF<=[M:PPI2]WITMREFEND'      # borne fin   article
  Endif
Endif
If CRITERESITM = ""
  CRITERESITM = 'ITMREF>=REFART'
Endif
# Issue 104550 - 2014-12-08 by SR
# analyse présence formule de sélection
If [M:PPI2]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=10;[M:PPI2]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif
# End issue 104550
# Issue 112754 - 2016-10-24 by SR : Services
If [M:PPI2]ITMKND <> 0 # on connait déjà l'article et le type d'article
#  If [M:PPI2]CTMFLG=3          Goto CHARG_SOQ : Endif
   #  Si contremarque seule : si service sous-traitance, on sort
   If [M:PPI2]CTMFLG = 3
    If [M:PPI2]ITMKND = 2 Goto FIN_CHARG_TABLEAU : Else Goto CHARG_SOQ : Endif
   Endif
#  If [F:ITM]SCSFLG=2 & [F:ITM]ITMREF=REFART    # & [F:ITM]PURFLG<>2
  If  [M:PPI2]ITMKND=2 & [F:ITM]ITMREF=REFART     # & [F:ITM]PURFLG<>2
    [M:PPI2]CODE=10                            # [M:PPI2]CODE = 4  # GH 03/01/2013 bug 86995
  Elsif [F:ITM]SCPFLG=2 & [F:ITM]ITMREF=REFART # & [F:ITM]PURFLG<>2
    [M:PPI2]CODE=11                            # [M:PPI2]CODE=9    # GH 03/01/2013 bug 86995
  Elsif [M:PPI2]SCOFLG=1                       # Issue 84500 GA 10/2012 AML=588 PEC des EOx
    [M:PPI2]CODE=11                            # Issue 86341 GA 12/2012 on propose tout sauf les SCx
  Else                                         # [M:PPI2]SCOFLG=2 # Issue 84500 GA 10/2012 AML=588 PEC des SCx
    [M:PPI2]CODE=10
  Endif
  # Pas de DA pour articles Service de  sous-traitance
#  If find([M:PPI2]CODE,1,4,9)  Goto CHARG_ORD : Endif
  If find([M:PPI2]CODE,1,4,9) | [M:PPI2]ITMKND = 2 :   Goto CHARG_ORD : Endif
Else
  # ITMKND non passé en paramètre,  on prend tout
  [M:PPI2]CODE=13
  If [M:PPI2]CTMFLG = 3 : Goto CHARG_SOQ : Endif
Endif
# End issue 112754
#-----------------------------------------------------------------------#
# Chargement tableau à partir du fichier des DA pour article non stocké #
#-----------------------------------------------------------------------#
# Issue 10622 - 2011-12-29 by MUARN : ajout borne fin article et date
CRITERES = CRITERESITM
CRITERES += ' & LINORDFLG=1 & LINCLEFLG=1 & LINAPPFLG>2 & WIPNUM=""'
If GBUYFLT=2  CRITERES += ' & (LINBUY=[M:PPI2]ORDBUY | LINBUY="")' : Endif
If [M:PPI2]MAXDAT <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & EXTORDDAT>=[M:PPI2]MAXDAT'
  Else
    CRITERES +=' & EXTRCPDAT>=[M:PPI2]MAXDAT'
  Endif
Endif
If [M:PPI2]MAXDATEND <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & EXTORDDAT<=[M:PPI2]MAXDATEND'
  Else
    CRITERES +=' & EXTRCPDAT<=[M:PPI2]MAXDATEND'
  Endif
Endif

# Issue 87988 - 2013-02-15 by MUARN : ne pas prendre fournisseur vide si foudeb ou foufin renseigné et prise en compte que foufin
# If [M:PPI2]FOUDEB<>""
If [M:PPI2]FOUDEB <> "" | [M:PPI2]FOUFIN <> ""
  #CRITERES += ' & (BPSNUM="" | (BPSNUM>=FOUDEB & BPSNUM<=FOUFIN))'
  CRITERES += ' & (BPSNUM<>"" & (BPSNUM>=FOUDEB & BPSNUM<=FOUFIN))'
Endif

#---------------------------------------------------------------------#
# Point d'entrée PECFILTSUP pour ajouter un filtre supplémentaire     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TYPFILT   : Type de filtre                                          #
#             1 = sur la table des lignes DA  PREQUISD [PSD]          #
# CRITERES  : Filtre standard                                         #
# CRITSUP   : Filtre supplémentaire chargé par le point d'entrée      #
#---------------------------------------------------------------------#
TYPFILT=1
XZSCRITERES=CRITERES
XZSCRITLNK =CRITLNK
CRITSUP=""
GPOINT="PECFILTSUP" : Gosub ENTREE From EXEFNC
CRITERES=XZSCRITERES
CRITLNK =XZSCRITLNK
If CRITSUP="" CRITSUP="1=1" : Endif
#-----
If parse(CRITSUP)
  Call ERREUR("Filter error CRITSUP") From GESECRAN : CRITSUP="1=1"
Endif
# Issue 114623 - 2016-02-23 by SR : Prendre en compte les critères TCLCOD et TSICOD
CRITERES3 = "1=1"
  If [M:PPI2]TCLCODSTR <> ""
     CRITERES3-= "& [F:ITM]TCLCOD>=[M:PPI2]TCLCODSTR"         # borne catégorie
  Endif
  If [M:PPI2]TCLCODEND <> ""
     CRITERES3 -= "& [F:ITM]TCLCOD<=[M:PPI2]TCLCODEND"         # borne catégorie
  Endif
  If dim([M:PPI2]TSICODSTR) > 0                # familles statistiques
      For WI = 0 To dim([M:PPI2]TSICODSTR)-1
          If [M:PPI2]TSICODSTR(WI) <> ""
              CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")>=[M:PPI2]TSICODSTR("+num$(WI)+")"
          Endif
          If [M:PPI2]TSICODEND(WI) <> ""
              CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")<=[M:PPI2]TSICODEND("+num$(WI)+")"
          Endif
      Next WI
  Endif
  # Issue 112754 - 2016-10-25 by SR : S'assurer qu'on ne prend que les DA des articles non gérés en stock
  # les autres seront prises lors du chargement des encours
  CRITERES3 -= "& [F:ITM]STOMGTCOD=1"
#-----
#For [PSD] Where evalue(CRITERES) & evalue(CRITSUP)
Link [PSD] With [ITM] ITM0=[F:PSD]ITMREF As [PSF] # [F:PSD]ITMREF à la place de [F:ORD]ITMREF
For [PSF] Where evalue(CRITERES) & evalue(CRITSUP) & evalue(CRITERES3)
  If [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU
#--------------------------------------------------------------------#
# Contrôle existence du site et appartenance à la même sté juridique #
#--------------------------------------------------------------------#
    If [F:FCY]FCY<>[F:PSD]PSHFCY
      Read [FCY] FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
    Endif
    # Issue 10622 - 2012-01-25 by MUARN : ajout filtre site
    If [M:PPI2]EVRFCY = 2 | [M:POI1]POHFCY=[F:FCY]FCY
      If [F:FCY]LEGCPY=GSOCIETE Gosub CHARG_LIG_DA : Endif
    Endif
  Endif
  If I>dim([M:PPI2]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
If GERR=2  Goto FIN_CHARG_TABLEAU : Endif
#
# Issue 112754 - 2016-10-25 by SR : Services Si CODE = 13,  on prend tout
If [M:PPI2]CODE = 13 : Goto CHARG_ORD : Endif
# Issue 86341 GA 12/2012 avant [M:PPI2]CODE>10  Goto CHARG_SOQ
# Si service, pas d'encours
If find([M:PPI2]CODE,0,5,7,8) | [M:PPI2]CODE>11 | [M:PPI2]ITMKND = 3 : Goto CHARG_SOQ : Endif
# End issue 112754

#------------------------------------------------------------------------#
# Chargement tableau à partir du fichier des encours pour article stocké #
#------------------------------------------------------------------------#
# Issue 75543 - 2011-08-18 by SR : Code = 4 : Seulement les SCF
# Issue 80350 - 2012-03-08 by SR : Code = 10 : seulement les SCF
# Issue 84500 GA 10/2012 Code = 10 : seulement les SCF, et on exclut les EOx
#             CRITERES-='|((WIPTYP=4|WIPTYP=13)& WIPSTA=1)) & ITMREF'+WX+'REFART'
# Issue 86341 GA 12/2012 ajout code 11 tout sauf les SCx
# Issue 86705 - 2012-12-17 by SR : Code = 9 : Seulement les EOF
# Issue 105229 - 2015-01-12 by SR : Pour les SCF : Le fournisseur doit être renseigné : CODE = 4/10
# Issue 112754- 2016-10-25 by SR : Code = 13: Tout
$CHARG_ORD
CRITERES = CRITERESITM
# Issue 10622 - 2011-12-29 by MUARN : ajout borne fin article et date
# Issue 10622 - 2013-06-05 by MUARN : A supprimer si tests OK
#Case [M:PPI2]CODE
#  When  1 : CRITERES ='WIPTYP=2 & WIPSTA=3 & ITMREF'+WX+'REFART & left$(ABBFIL,2)<>"PO"'
#  When  2 : CRITERES ='WIPTYP=2 & WIPSTA=2 & ITMREF'+WX+'REFART & left$(ABBFIL,2)<>"PO"'
#  When  3 : CRITERES ='WIPTYP=2 & WIPSTA>1 & ITMREF'+WX+'REFART & left$(ABBFIL,2)<>"PO"'
#  When  4 : CRITERES ='WIPTYP=4 & WIPSTA=1 & ITMREF'+WX+'REFART'
#  When  6 : CRITERES ='WIPTYP=2 & WIPSTA=2 & ITMREF'+WX+'REFART & ABBFIL="PSD"'
#  When  9 : CRITERES ='WIPTYP=13 & WIPSTA = 1 & ITMREF'+WX+'REFART'
#  When 10 : CRITERES ='((WIPTYP=2 & WIPSTA>1 & left$(ABBFIL,2)<>"PO")'
#            CRITERES-='|(WIPTYP=4 & WIPSTA=1)) & ITMREF'+WX+'REFART'
#  When 11 : CRITERES ='((WIPTYP=2 & WIPSTA>1 & left$(ABBFIL,2)<>"PO")'
#            CRITERES-='|(WIPTYP=13 & WIPSTA=1)) & ITMREF'+WX+'REFART'
#Endcase

Case [M:PPI2]CODE
  When  1 : CRITERES +=' & WIPTYP=2  & WIPSTA=3 & left$(ABBFIL,2)<>"PO"'
  When  2 : CRITERES +=' & WIPTYP=2  & WIPSTA=2 & left$(ABBFIL,2)<>"PO"'
  When  3 : CRITERES +=' & WIPTYP=2  & WIPSTA>1 & left$(ABBFIL,2)<>"PO"'
  When  4 : CRITERES +=' & WIPTYP=4  & WIPSTA=1 & BPRNUM <> ""'
  When  6 : CRITERES +=' & WIPTYP=2  & WIPSTA=2 & ABBFIL="PSD"'
  When  9 : CRITERES +=' & WIPTYP=13 & WIPSTA=1'
  When 10 : CRITERES +=' & ((WIPTYP=2 & WIPSTA>1 & left$(ABBFIL,2)<>"PO")'
            CRITERES -='|(WIPTYP=4 & WIPSTA=1 & BPRNUM <> ""))'
  When 11 : CRITERES +=' & ((WIPTYP=2 & WIPSTA>1 & left$(ABBFIL,2)<>"PO")'
            CRITERES -='|(WIPTYP=13 & WIPSTA=1))'
  When 13 : CRITERES +=' & ((WIPTYP=2 & WIPSTA>1 & left$(ABBFIL,2)<>"PO")'
            CRITERES -='|(WIPTYP=4 & WIPSTA=1 & BPRNUM <> "")'
            CRITERES -='|(WIPTYP=13 & WIPSTA=1))'
Endcase
If [M:PPI2]MAXDAT <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & STRDAT>=[M:PPI2]MAXDAT'
  Else
    CRITERES +=' & ENDDAT>=[M:PPI2]MAXDAT'
  Endif
Endif
If [M:PPI2]MAXDATEND <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & STRDAT<=[M:PPI2]MAXDATEND'
  Else
    CRITERES +=' & ENDDAT<=[M:PPI2]MAXDATEND'
  Endif
Endif

# Issue 112754 - 2017-01-20 by MUARN : CRITERES tronqué
CRITERES4  = "1=1"
# Issue 87988 - 2013-02-15 - by MUARN : ne pas prendre fournisseur vide si foudeb ou foufin renseigné et prise en compte que fournisseur fin
#If [M:PPI2]FOUDEB<>""
If [M:PPI2]FOUDEB <> "" | [M:PPI2]FOUFIN <> ""
  # Issue 87988 - 2013-02-15 by MUARN : ne pas prendre fournisseur vide si foudeb ou foufin renseigné
  #CRITERES += ' & (BPRNUM="" | (BPRNUM>=FOUDEB & BPRNUM<=FOUFIN))'
  #CRITERES1 += ' & (BPRNUM<>"" & (BPRNUM>=FOUDEB & BPRNUM<=FOUFIN))'
  CRITERES4 = ' (BPRNUM<>"" & (BPRNUM>=FOUDEB & BPRNUM<=FOUFIN))'
Endif

If GBUYFLT=2
  CRITLNK='[F:ITF]BUY=[M:PPI2]ORDBUY | [F:ITF]BUY=""'
Else
  CRITLNK="1=1"
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECFILTSUP pour ajouter un filtre supplémentaire     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TYPFILT   : Type de filtre                                          #
#             2 = sur la table des encours  ORDERS [ORD]              #
# CRITERES  : Filtre standard                                         #
# CRITLNK   : Filtre standard du "Link"                               #
# CRITSUP   : Filtre supplémentaire chargé par le point d'entrée      #
# CRITLNK2  : Filtre supplémentaire sur la table ITMFACILIT [ITF]     #
#---------------------------------------------------------------------#
TYPFILT=2
XZSCRITERES=CRITERES
XZSCRITLNK =CRITLNK
CRITSUP =""
CRITLNK2=""
GPOINT="PECFILTSUP" : Gosub ENTREE From EXEFNC
CRITERES=XZSCRITERES
CRITLNK =XZSCRITLNK
If CRITSUP =""  CRITSUP ="1=1" : Endif
If CRITLNK2=""  CRITLNK2="1=1" : Endif
#-----
If parse(CRITSUP)
  Call ERREUR("Filter error CRITSUP")  From GESECRAN : CRITSUP ="1=1"
Endif
If parse(CRITLNK2)
  Call ERREUR("Filter error CRITLNK2") From GESECRAN : CRITLNK2="1=1"
Endif
#-----

# Issue 10622 - 2012-01-31 by MUARN : ajout fenêtre critères
CRITERES1  = "1=1"
# affaire
If [M:PPI2]PJTSTR <> ""
   CRITERES1 += " & PJT>=[M:PPI2]PJTSTR"               # borne début affaire
Endif
If [M:PPI2]PJTEND <> ""
   CRITERES1 += " & PJT<=[M:PPI2]PJTEND"               # borne fin   affaire
Endif
# pièce
If [M:PPI2]VCRNUMSTR <> ""
   CRITERES1 += " & VCRNUM>=[M:PPI2]VCRNUMSTR"         # borne début pièce
Endif
If [M:PPI2] VCRNUMEND <> ""
   CRITERES1 += " & VCRNUM<=[M:PPI2]VCRNUMEND"         # borne fin   pièce
Endif
# Pièce origine
If [M:PPI2]VCRORISTR <> ""
   CRITERES1 +=" & VCRNUMORI>=[M:PPI2]VCRORISTR"       # borne début pièce origine
Endif
If [M:PPI2]VCRORIEND <>""
   CRITERES1 += " & VCRNUMORI <=[M:PPI2]VCRORIEND"     # borne fin pièce origine
Endif

# Issue 114623 - 2016-02-23 by SR : Prendre en compte les critères TCLCOD et TSICOD
CRITERES3 = "1=1"
If [M:PPI2]TCLCODSTR <> ""
   CRITERES3-= "& [F:ITM]TCLCOD>=[M:PPI2]TCLCODSTR"         # borne catégorie
Endif
If [M:PPI2]TCLCODEND <> ""
   CRITERES3 -= "& [F:ITM]TCLCOD<=[M:PPI2]TCLCODEND"         # borne catégorie
Endif
If dim([M:PPI2]TSICODSTR) > 0                # familles statistiques
    For WI = 0 To dim([M:PPI2]TSICODSTR)-1
        If [M:PPI2]TSICODSTR(WI) <> ""
            CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")>=[M:PPI2]TSICODSTR("+num$(WI)+")"
        Endif
        If [M:PPI2]TSICODEND(WI) <> ""
            CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")<=[M:PPI2]TSICODEND("+num$(WI)+")"
        Endif
    Next WI
Endif
# End issue 114623

# Issue 112754 - 2017-01-20 by MUARN : ajout CRITERES4
# Issue 10622 - 2012-01-31 by MUARN : Ajout fenetre criteres
# Issue 104550 - 2014-12-08 by SR
#Filter [ORD] Where evalue(CRITERES) & evalue(CRITSUP) & evalue(CRITERES1)
Filter [ORD] Where evalue(CRITERES) & evalue(CRITSUP) & evalue(CRITERES1) & evalue(FORMULE1) & evalue(CRITERES4)
# End issue 104550
# Issue 114623 - 2016-02-23 by SR : Prendre en compte les critères TCLCOD et TSICOD
Link [ORD] With [ITF] ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY,
&               [ITM] ITM0=[F:ORD]ITMREF As [ORF]
For [ORF] Where evalue(CRITLNK) & evalue(CRITLNK2) & evalue(CRITERES3)
  # End issue 114623
  If [F:ORD]RMNEXTQTY>0
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
    # Issue 10622 - 2012-01-25 by MUARN : ajout filtre site
    If [M:PPI2]EVRFCY = 2 | [M:POI1]POHFCY=[F:FCY]FCY
      If [F:FCY]LEGCPY=GSOCIETE
        #----- "POP" demande d'achat : Prise en compte si ligne complètement signée -----#
        If [F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2 & [M:PPI2]CODE<>5
          Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
          If fstat Raz [F:PSD] : Endif
          If [F:PSD]LINAPPFLG>2 Gosub CHARG_LIG_ORD : Endif
        #----- "POS" besoins production : Prise en compte si DA non obligatoire -----#
        Elsif [F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=3
          If [F:ITM]ITMREF<>[F:ORD]ITMREF
            Read [ITM] ITM0=[F:ORD]ITMREF : If fstat Raz [F:ITM] : Endif
          Endif
          Call CTLITMBUY([F:ORD]ITMREF,[M:POI1]BUY,WRET) From TRTACHCTL1
          If !WRET & [F:ITM]PRQFLG<2  Gosub CHARG_LIG_ORD : Endif
        #-----
        Elsif find([F:ORD]WIPTYP,13,4) # Sous-traitance
         # Suite Issue 87637 GA 09/2013 Controled by CTLORD
         # Call CTLITMBUY([F:ORD]ITMREF,[M:POI1]BUY,WRET) From TRTACHCTL1
         # Issue 86425 & 86433 GA 12/2012 Bom alternative and supplier are mandatory
          WRET=0  : Gosub CTLORD From TRTACHSCO1
          If !WRET  Gosub CHARG_LIG_ORD : Endif
        Else
          Call CTLITMBUY([F:ORD]ITMREF,[M:POI1]BUY,WRET) From TRTACHCTL1
          If !WRET  Gosub CHARG_LIG_ORD : Endif
        Endif
      Endif
    Endif
  Endif
  If I>dim([M:PPI2]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
Filter [ORD]
If GERR=2  Goto FIN_CHARG_TABLEAU : Endif
#
# Issue 112754 - 2016-10-25 by SR : Pas de contremarque si Service de sous-traitance
If [M:PPI2]ITMKND = 2 : Goto FIN_CHARG_TABLEAU : Endif
#-----------------------------------------------------------------------------#
# Chargement tableau à partir du fichier des lignes de cde vente contremarque #
#-----------------------------------------------------------------------------#
$CHARG_SOQ
If [M:PPI2]CTMFLG<2  Goto FIN_CHARG_TABLEAU : Endif
If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif : # En principe est déjà ouvert !
If !clalev([F:SOQ])  Local File SORDERQ [SOQ] : Endif : # En principe est déjà ouvert !
If !clalev([F:SOP])  Local File SORDERP [SOP] : Endif : # En principe est déjà ouvert !
Raz [F:SOH]

# Issue 10622 - 2011-12-29 by MUARN : ajout borne fin article et date
CRITERES = CRITERESITM
If [M:PPI2]MAXDAT <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & ORDDAT>=[M:PPI2]MAXDAT'
  Else
    CRITERES +=' & DEMDLVDAT>=[M:PPI2]MAXDAT'
  Endif
Endif
If [M:PPI2]MAXDATEND <> [0/0/0]
  If [M:PPI2]CHXDAT=1
    CRITERES +=' & ORDDAT<=[M:PPI2]MAXDATEND'
  Else
    CRITERES +=' & DEMDLVDAT<=[M:PPI2]MAXDATEND'
  Endif
Endif
For [SOQ] SOQ4 Where SOQSTA<>3
&                  & SOHCAT<>4
&                  & find(FMI,2,3)<>0
&                  & FMINUM=""
&                  & evalue(CRITERES)

# Issue 85598 - 2012-11-08 by SR :  # si client bloqué, pas de contremarque
  If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
    Read [F:SOH]SOH0 = [F:SOQ]SOHNUM
    If fstat : Raz [F:SOH] : Endif
    Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&                 [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT

    #Issue 119459.sn - 2017-03-09 by CATUA
    Raz WMANHOLDBTB
    #Check Block BTB (Back-To-Back) flag within manual hold reason miscellaneous table (204)
    If [F:SOH]HLDCOD <> AVOID.ACHAR & [F:SOH]HLDSTA = [V]CST_AYES &
&      func MANHLDLIB.BLK_BACK_TO_BACK([F:SOH]HLDSTA, [F:SOH]HLDCOD) = [V]CST_AYES
          WMANHOLDBTB = 1
    Endif
    #Issue 119459.en - 2017-03-09 by CATUA
  Endif

  # Issue 93297 - 2013-11-13 by MUARN : prise en compte du paramètre DIRORDCTL
  If (WCDTSTA = 1 | (WCDTSTA=3 & GDIRORDCTL=2)) & !WMANHOLDBTB
      # Issue 10622 - 2012-02-01 by MUARN : ajout fenêtre critère
      CRITERES1  = "1=1"
      # affaire
      If [M:PPI2]PJTSTR <> ""
         CRITERES1 += " & PJT>=[M:PPI2]PJTSTR"               # borne début affaire
      Endif
      If [M:PPI2]PJTEND <> ""
         CRITERES1 += " & PJT<=[M:PPI2]PJTEND"               # borne fin   affaire
      Endif
      # pièce
      If [M:PPI2]VCRNUMSTR <> ""
         CRITERES1 += " & VCRNUM>=[M:PPI2]VCRNUMSTR"         # borne début pièce
      Endif
      If [M:PPI2] VCRNUMEND <> ""
         CRITERES1 += " & VCRNUM<=[M:PPI2]VCRNUMEND"         # borne fin   pièce
      Endif
      # Pièce origine
      If [M:PPI2]VCRORISTR <> ""
         CRITERES1 +=" & VCRNUMORI>=[M:PPI2]VCRORISTR"       # borne début pièce origine
      Endif
      If [M:PPI2]VCRORIEND <>""
         CRITERES1 += " & VCRNUMORI <=[M:PPI2]VCRORIEND"     # borne fin pièce origine
      Endif

      #----- Contrôle existence du site et appartenance à la même sté juridique -----#
      If [F:FCY]FCY<>[F:SOQ]STOFCY
        Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
      Endif
      # Issue 10622 - 2012-01-25 by MUARN : ajout filtre site
      If [M:PPI2]EVRFCY = 2 | [M:POI1]POHFCY=[F:FCY]FCY
        If [F:FCY]LEGCPY=GSOCIETE
          # Issue X3-55891 - 2018-08-20 by SR : Exploitation données déclinées par site
          #Raz [F:ITP]
          #----- Recherche fournisseur contremarque (litige non bloquant) -----#
          #For [ITP] ITP1 Where ITMREF=[F:SOQ]ITMREF & CTMBPSFLG=2
          # If [F:ITP]DOUFLG<3  Break : Endif
          #Next
          #If [F:ITP]DOUFLG>2  Raz [F:ITP] : Endif
          #----- Recherche fournisseur autre (litige non bloquant) -----#
          #If [F:ITP]BPSNUM=""
          #  For [ITP] ITP1 Where ITMREF=[F:SOQ]ITMREF & CTMBPSFLG<>2
          #    If [F:ITP]DOUFLG<3  Break : Endif
          #  Next
          #Endif
          #If [F:ITP]DOUFLG>2  Raz [F:ITP] : Endif
          #If ([M:PPI2]FOUDEB<>"" & ([F:ITP]BPSNUM<[M:PPI2]FOUDEB | [F:ITP]BPSNUM>[M:PPI2]FOUFIN))
          #  Raz [F:ITP]
          Raz WRETOUR, WITMBPS, WBPSNUM
          # Si on a déjà le fournisseur : On recherche juste son niveau de blocage
          If ([M:PPI2]FOUDEB = [M:PPI2]FOUFIN) &  [M:PPI2]FOUDEB <> ""
            Call BPSNUM_DOUBTFUL_LEVEL(1,[F:SOQ]ITMREF,[M:PPI2]FOUDEB,[F:SOQ]STOFCY,WITMBPS,WRETOUR) From TRTACHCTL1
            If WRETOUR <> 0 : WITMBPS = 0 : Endif
          # sinon, on recherche un fournisseur
          Else
            Call DEFBPSNUM([F:SOQ]ITMREF,[M:POI1]POHFCY,[F:SOQ]STOFCY,[F:SOQ]STOFCY,2,WBPSNUM,WITMBPS) From TRTACHDEF1
            If WITMBPS = 0 : Raz [F:ITP] : Endif
          Endif
          #-----
          # On a trouvé un fournisseur en dehors de bornes
          If ([M:PPI2]FOUDEB<>"" & ([F:ITP]BPSNUM<[M:PPI2]FOUDEB | [F:ITP]BPSNUM>[M:PPI2]FOUFIN))
            Raz [F:ITP]
          # End issue X3-55891
          Else
            Call CTLITMBUY([F:SOQ]ITMREF,[M:POI1]BUY,WRET) From TRTACHCTL1
            # Issue 10622 - 2012-01-31 by MUARN : Ajout fenetre criteres
            If !WRET
              # Issue 112754 - 2016-10-24 by SR :Services
              If CRITERES1 <> "1=1" & [F:ITM]SCSFLG = 1
                CRITERES2 = "ITMREF=REFART & WIPTYP=1 & WIPSTA=1"
                # Issue 114623 - 2016-02-23 by SR : Prendre en compte les critères TCLCOD et TSICOD
                CRITERES3 = "1=1"
                If [M:PPI2]TCLCODSTR <> ""
                   CRITERES3-= "& [F:ITM]TCLCOD>=[M:PPI2]TCLCODSTR"         # borne catégorie
                Endif
                If [M:PPI2]TCLCODEND <> ""
                   CRITERES3 -= "& [F:ITM]TCLCOD<=[M:PPI2]TCLCODEND"         # borne catégorie
                Endif
                If dim([M:PPI2]TSICODSTR) > 0                # familles statistiques
                    For WI = 0 To dim([M:PPI2]TSICODSTR)-1
                        If [M:PPI2]TSICODSTR(WI) <> ""
                            CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")>=[M:PPI2]TSICODSTR("+num$(WI)+")"
                        Endif
                        If [M:PPI2]TSICODEND(WI) <> "" # Issue X3-71947 by MGO - corrected variable
                            CRITERES3 -= "& [F:ITM]TSICOD("+num$(WI)+")<=[M:PPI2]TSICODEND("+num$(WI)+")"
                        Endif
                    Next WI
                Endif
#                Filter [ORD] Where evalue(CRITERES2) & evalue(CRITERES1)
#                Read [ORD] ORD0 First
                Link [ORD] With [ITM] ITM0=[F:ORD]ITMREF As [ORF]
&                   Where evalue(CRITERES2) & evalue(CRITERES1) & evalue(CRITERES3)
                Read [ORF] ORD0 First
                If !fstat
                    Gosub CHARG_LIG_SOQ
                Endif
 #               Filter [ORD]
                # End issue 114623
              Else
                Gosub CHARG_LIG_SOQ
              Endif
            Endif

          Endif
        Endif
      Endif
      If I>dim([M:PPI2]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
  Endif
Next
#-----
$FIN_CHARG_TABLEAU
[M:PPI2]NBLIG=I

# Issue 10622 - 2012-01-02 by MUARN : tri tableau selon fenêtre critères
If [M:PPI2]NBLIG <> 0
  Case [M:PPI2]SRTCOD
      When 1: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]STOFCY(indice),[M:PPI2]STRDAT(indice),[M:PPI2]VCRNUM(indice)
      When 2: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]ITMREF(indice),[M:PPI2]STRDAT(indice),[M:PPI2]VCRNUM(indice)
      When 3: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYPSTA(indice),[M:PPI2]STRDAT(indice),[M:PPI2]VCRNUM(indice)
      When 4: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]VCRTYP(indice),[M:PPI2]STRDAT(indice),[M:PPI2]VCRNUM(indice)
      When 5: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]STRDAT(indice),[M:PPI2]VCRNUM(indice)
      When 6: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]REQDAT(indice),[M:PPI2]VCRNUM(indice)
      When 7: Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]BPRNUM(indice),[M:PPI2]VCRNUM(indice)
  Endcase
Endif

Affzo [PPI2]TOTQTY, WEITOT, VOLTOT, 10
Enable GSTAFIN : GETABOU(GABAN)=1 : # Activation Abandon
Call TEMPOFF From GESECRAN
Return

$CHARG_LIG_DA
#---------------------------------------------------#
# Chargement d'une ligne à partir du fichier des DA #
#---------------------------------------------------#
If clalev ([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=[M:PPI2]WPRONUM
&                    & CODFNC=[M:PPI2]WCODFNC
&                    & WIPTYP=2
&                    & WIPNUM=[F:PSD]PSHNUM
&                    & PSDLIN=[F:PSD]PSDLIN
&                    & ITMREF=[F:PSD]ITMREF
     [F:PSD]ORDQTYSTU+=[F:PWO]QTYSTU
  Next
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             1 = depuis la table des lignes DA  PREQUISD [PSD]       #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI2] et [F:PSD]                            #
# [M:PPI2]CODE : Code du traitement                                   #
#                1 = Prise en compte des "POS"                        #
#                2 = prise en compte des "POP"                        #
#                3 = prise en compte des "POS" et "POP"               #
#                4 = prise en compte des "SCS", "SCP" et "SCF"        #
#                6 = prise en compte des DA                           #
#                9 = prise en compte des "EOS", "EOP" et "EOF"        #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=1
ABREV="PPI2"
RMNQTY=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
#-----
If RMNQTY<=0 Return : Endif
[M:PPI2]WIPTYP(I)   =2
[M:PPI2]WIPSTA(I)   =2
[M:PPI2]WIPNUM(I)   =""
[M:PPI2]ITMREF(I)   =[F:PSD]ITMREF
[M:PPI2]ITMDES(I)   =[F:PSD]ITMDES
[M:PPI2]STRDAT(I)   =[F:PSD]EXTORDDAT
[M:PPI2]ENDDAT(I)   =[F:PSD]EXTRCPDAT
[M:PPI2]STOFCY(I)   =[F:PSD]PRHFCY
[M:PPI2]STU(I)      =[F:PSD]STU
[M:PPI2]BUY(I)      =[F:PSD]LINBUY
[M:PPI2]BPRNUM(I)   =[F:PSD]BPSNUM
[M:PPI2]PICQTY(I)   =0
[M:PPI2]RMNEXTQTY(I)=RMNQTY
[M:PPI2]VCRNUM(I)   =[F:PSD]PSHNUM
[M:PPI2]VCRLIN(I)   =[F:PSD]PSDLIN
[M:PPI2]WPJT(I)     =[F:PSD]PJT
If dim([M:PPI2]ORI)>0
  [M:PPI2]ORI(I)    =1 : # Origine Achats
Endif
#----- Indicateur inter-sociétés -----#
If [F:PSD]BPSNUM<>""
  If [F:BPR2]BPRNUM<>[F:PSD]BPSNUM
    Read [BPR2] BPR0=[F:PSD]BPSNUM : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>""
    [M:PPI2]WIPISO(I)=func TRTACHISO1.ISOFLG([F:BPR2]FCY,[F:PSD]PRHFCY)
  Else
    [M:PPI2]WIPISO(I)=1
  Endif
Else
  [M:PPI2]WIPISO(I)=1
Endif
#-----
[M:PPI2]WIPCOD(I)   ="POP"
If [M:PPI2]WIPISO(I)=2  [M:PPI2]WIPCOD(I)+=chr$(126) : Endif
Raz [M:PPI2]SOHNUM(I), [M:PPI2]SOPLIN(I)
# Issue 10622 - 2012-01-09 by MUARN : ajout fenêtre critères
[M:PPI2]VCRTYP(I)=0
[M:PPI2]REQDAT(I)=[F:PSD]EXTRCPDAT
[M:PPI2]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)
If [M:PPI2]WIPISO(I)= 2 : [M:PPI2]WIPTYPSTA(I) += chr$(126) : Endif

# 106430 - Purchase planning - set weight and volume UOM
If [F:ITM]ITMREF<>[F:PSD]ITMREF
   Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
[M:PPI2]LINWEU(I)   =[F:ITM]WEU
[M:PPI2]LINVOU(I)   =[F:ITM]VOU

I+=1
Return

$CHARG_LIG_ORD
#--------------------------------------------------------#
# Chargement d'une ligne à partir du fichier des encours #
#--------------------------------------------------------#
Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
If clalev ([F:PWO])>0
   For [PWO] PWO0 Where PRONUM=[M:PPI2]WPRONUM
&                     & CODFNC=[M:PPI2]WCODFNC
&                     & WIPTYP=[F:ORD]WIPTYP
&                     & WIPNUM=[F:ORD]WIPNUM
&                     & ITMREF=[F:ORD]ITMREF
       [F:ORD]RMNEXTQTY-=[F:PWO]QTYSTU
   Next
Endif
If [F:ITM]ITMREF<>[F:ORD]ITMREF
   Read [ITM] ITM0=[F:ORD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[F:ORD]ITMREF | [F:ITF]STOFCY <> [F:ORD]STOFCY
   Read [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY : If fstat Raz [F:ITF] : Endif
Endif
If [F:ITM]ITMSTA<>1 | [F:ITM]PURFLG<>2  Return : Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             2 = depuis la table des encours  ORDERS [ORD]           #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI2] et [F:ORD]                            #
# [M:PPI2]CODE : Code du traitement                                   #
#                1 = prise en compte des "POS"                        #
#                2 = prise en compte des "POP"                        #
#                3 = prise en compte des "POS" et "POP"               #
#                4 = prise en compte des "SCS", "SCP" et "SCF"        #
#                6 = prise en compte des DA                           #
#                9 = prise en compte des "EOS", "EOP" et "EOF"        #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=2
ABREV="PPI2"
RMNQTY=[F:ORD]RMNEXTQTY
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
#-----
If RMNQTY<=0 Return : Endif
[M:PPI2]WIPTYP(I)   =[F:ORD]WIPTYP
[M:PPI2]WIPSTA(I)   =[F:ORD]WIPSTA
[M:PPI2]WIPNUM(I)   =[F:ORD]WIPNUM
[M:PPI2]ITMREF(I)   =[F:ORD]ITMREF
#[M:PPI2]ITMDES(I)  =[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PPI2]ITMDES(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:PPI2]STRDAT(I)   =[F:ORD]STRDAT
[M:PPI2]ENDDAT(I)   =[F:ORD]ENDDAT
[M:PPI2]STOFCY(I)   =[F:ORD]STOFCY
[M:PPI2]STU(I)      =[F:ITM]STU
[M:PPI2]LINWEU(I)   =[F:ITM]WEU     # 106430.n
[M:PPI2]LINVOU(I)   =[F:ITM]VOU     # 106430.n
[M:PPI2]BUY(I)      =[F:ITF]BUY
[M:PPI2]BPRNUM(I)   =[F:ORD]BPRNUM
[M:PPI2]WPJT(I)     =[F:ORD]PJT
If dim([M:PPI2]ORI)>0
  [M:PPI2]ORI(I)    =[F:ORD]ORI : # Origine du besoin
Endif
[M:PPI2]PICQTY(I)   =0
[M:PPI2]RMNEXTQTY(I)=RMNQTY
If [F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2
  [M:PPI2]VCRNUM(I)=[F:ORD]VCRNUM
  [M:PPI2]VCRLIN(I)=[F:ORD]VCRLIN
  Columns [PSD] (ITMDES)
  Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
  If fstat  Raz [F:PSD] : Endif
  Columns [PSD]
  If [F:PSD]ITMDES<>""  [M:PPI2]ITMDES(I)=[F:PSD]ITMDES : Endif
Elsif find([F:ORD]WIPTYP,4,13)
  [M:PPI2]VCRNUM(I)=[F:ORD]VCRNUM
  [M:PPI2]VCRLIN(I)=[F:ORD]VCRLIN
Else
  Raz [M:PPI2]VCRNUM(I), [M:PPI2]VCRLIN(I)
Endif
#----- Indicateur inter-sociétés -----#
If [F:ORD]WIPTYP=2 & [F:ORD]BPRNUM<>""
  If [F:BPR2]BPRNUM<>[F:ORD]BPRNUM
    Read [BPR2] BPR0=[F:ORD]BPRNUM : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>""
    [M:PPI2]WIPISO(I)=func TRTACHISO1.ISOFLG([F:BPR2]FCY,[F:ORD]STOFCY)
  Else
    [M:PPI2]WIPISO(I)=1
  Endif
Else
  [M:PPI2]WIPISO(I)=1
Endif
#-----
# Issue 84500 GA 10/2012
#If [M:PPI2]WIPTYP(I)=2
#  If [M:PPI2]WIPSTA(I)=1 [M:PPI2]WIPCOD(I)="POF" : Endif
#  If [M:PPI2]WIPSTA(I)=2 [M:PPI2]WIPCOD(I)="POP" : Endif
#  If [M:PPI2]WIPSTA(I)=3 [M:PPI2]WIPCOD(I)="POS" : Endif
#Elsif [M:PPI2]WIPTYP(I)=4
#  If [M:PPI2]WIPSTA(I)=1 [M:PPI2]WIPCOD(I)="SCF" : Endif
#  If [M:PPI2]WIPSTA(I)=2 [M:PPI2]WIPCOD(I)="SCP" : Endif
#  If [M:PPI2]WIPSTA(I)=3 [M:PPI2]WIPCOD(I)="SCS" : Endif
#Elsif [M:PPI2]WIPTYP(I)=7
#  If [M:PPI2]WIPSTA(I)=1 [M:PPI2]WIPCOD(I)="TRF" : Endif
#  If [M:PPI2]WIPSTA(I)=2 [M:PPI2]WIPCOD(I)="TRP" : Endif
#  If [M:PPI2]WIPSTA(I)=3 [M:PPI2]WIPCOD(I)="TRS" : Endif
#Elsif [M:PPI2]WIPTYP(I)=13
#  If [M:PPI2]WIPSTA(I)=1 [M:PPI2]WIPCOD(I)="EOF" : Endif
#  If [M:PPI2]WIPSTA(I)=2 [M:PPI2]WIPCOD(I)="EOP" : Endif
#  If [M:PPI2]WIPSTA(I)=3 [M:PPI2]WIPCOD(I)="EOS" : Endif
#Endif
If [M:PPI2]WIPTYP(I)>0
   [M:PPI2]WIPCOD(I)= mess([M:PPI2]WIPTYP(I),341,1)+mess([M:PPI2]WIPSTA(I),342,1)
Endif
If [M:PPI2]WIPISO(I)=2 [M:PPI2]WIPCOD(I)+=chr$(126) : Endif

Raz [M:PPI2]SOHNUM(I), [M:PPI2]SOPLIN(I)
# Issue 10622 - 2012-01-09 by MUARN : ajout fenêtre critères
If ([F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2) | find([F:ORD]WIPTYP,4,13)
  [M:PPI2]VCRTYP(I)=[F:ORD]VCRTYP
Else
  Raz [M:PPI2]VCRTYP(I)
Endif
[M:PPI2]REQDAT(I)=[F:ORD]MRPDAT
If [M:PPI2]REQDAT(I)=[0/0/0] : [M:PPI2]REQDAT(I) = [M:PPI2]ENDDAT(I) Endif
[M:PPI2]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)
If [M:PPI2]WIPTYP(I)=2 & [M:PPI2]WIPISO(I)= 2 : [M:PPI2]WIPTYPSTA(I) += chr$(126) : Endif

I+=1
Return

$CHARG_LIG_SOQ
#---------------------------------------------------------------#
# Chargement d'une ligne à partir des cdes ventes contremarques #
#---------------------------------------------------------------#
#----- Relecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:SOQ]ITMREF
  Read [ITM] ITM0=[F:SOQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Relecture cde entête vente et contrôle si nécessaire -----#
If [F:SOH]SOHNUM<>[F:SOQ]SOHNUM
  Read [SOH] SOH0=[F:SOQ]SOHNUM : If fstat Raz [F:SOH] : Endif
  #----- Vérification si commande bloquée -----#
  # Bug 48964 : Ctrl sur clt facture (et non sur clt commande)
  Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&               [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
  Case WCDTSTA
    When 2 : Return
    When 3 : If GDIRORDCTL<2  Return : Endif
  Endcase
  #------------------------------------------------------------#
  # Point d'entrée CTMFILTRE1 pour exclure certaines commandes #
  # ---------------------------------------------------------- #
  # Variable utilisable par le point d'entrée                  #
  #                                                            #
  # WCDTSTA : Indicateur d'exclusion (0 = Pas d'exclusion)     #
  #------------------------------------------------------------#
  Raz WCDTSTA
  Gosub POINT_CTMFILTRE1 From TRTACHCDE1
  If WCDTSTA  Return : Endif
Endif
If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2  WIPTYPSOH=8  Else  WIPTYPSOH=1 : Endif
#-----
# Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
RMNQTY=[F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
If RMNQTY< 0 : RMNQTY = 0 : Endif
If clalev ([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=[M:PPI2]WPRONUM
&                    & CODFNC=[M:PPI2]WCODFNC
&                    & WIPTYP=WIPTYPSOH
&                    & WIPNUM=[F:SOQ]SOHNUM
&                    & PSDLIN=[F:SOQ]SOPLIN
&                    & ITMREF=[F:SOQ]ITMREF
    Raz RMNQTY : Break
  Next
Endif
If RMNQTY=0 Return : Endif
If [F:SOP]SOHNUM<>[F:SOQ]SOHNUM |
&  [F:SOP]SOPLIN<>[F:SOQ]SOPLIN |
&  [F:SOP]SOPSEQ<>[F:SOQ]SOQSEQ
  Read [SOP] SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
  If fstat Raz [F:SOP] : Endif
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             3 = depuis la table des lignes cde vte SORDERQ [SOQ]    #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI2] et [F:SOQ]                            #
# [M:PPI2]CODE : Code du traitement                                   #
#                1 = prise en compte des "POS"                        #
#                2 = prise en compte des "POP"                        #
#                3 = prise en compte des "POS" et "POP"               #
#                4 = prise en compte des "SCS", "SCP" et "SCF"        #
#                6 = prise en compte des DA                           #
#                9 = prise en compte des "EOS", "EOP" et "EOF"        #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=3
ABREV="PPI2"
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
# Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
If RMNQTY<>0 RMNQTY=[F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU : Endif
If RMNQTY<=0 Return : Endif
#-----
[M:PPI2]WIPTYP(I)   =WIPTYPSOH
[M:PPI2]WIPSTA(I)   =1
[M:PPI2]WIPNUM(I)   =[F:SOQ]DEMNUM
[M:PPI2]ITMREF(I)   =[F:SOQ]ITMREF
If [F:SOP]ITMDES<>""
  [M:PPI2]ITMDES(I)=[F:SOP]ITMDES
Else
  #[M:PPI2]ITMDES(I)=[F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PPI2]ITMDES(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif
[M:PPI2]STRDAT(I)   =[F:SOQ]ORDDAT
#----------------------------------------------------------------#
# Date de réception prévue :                                     #
#    = Date de livraison chez le client si contremarque directe  #
#    = Date d'expédition si contremarque réceptionnée            #
#      ajustement avec le délai de préparation de l'article-site #
#      et des indisponibilités du site de réception.             #
#----------------------------------------------------------------#
If [F:SOQ]FMI=2
  [M:PPI2]ENDDAT(I) = [F:SOQ]EXTDLVDAT
Else
  [M:PPI2]ENDDAT(I) = [F:SOQ]SHIDAT
  If [F:FCY]FCY<>[F:SOQ]STOFCY
    Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
  Endif
  If [F:ITF]ITMREF<>[F:SOQ]ITMREF | [F:ITF]STOFCY<>[F:SOQ]STOFCY
    Read [ITF] ITF0=[F:SOQ]ITMREF;[F:SOQ]STOFCY : If fstat Raz [F:ITF] : Endif
  Endif
  #VPO 26/10/10 22933 on tient compte des jours ouvrés pour calcul date de recept selon delai preparation
  #[M:PPI2]ENDDAT(I)-=[F:ITF]PRPLTI
  Call TRT_PRPLTI([M:PPI2]ENDDAT(I),[F:ITF]PRPLTI) From TRTACHCDE1
Endif
If [M:PPI2]ENDDAT(I)<[M:PPI2]STRDAT(I)
  [M:PPI2]ENDDAT(I) =[M:PPI2]STRDAT(I)
Endif
#-----
[M:PPI2]STOFCY(I)   =[F:SOQ]STOFCY
[M:PPI2]STU(I)      =[F:ITM]STU
[M:PPI2]LINWEU(I)   =[F:ITM]WEU   # 106430.n
[M:PPI2]LINVOU(I)   =[F:ITM]VOU   # 106430.n
[M:PPI2]BUY(I)      =""
[M:PPI2]BPRNUM(I)   =[F:ITP]BPSNUM
[M:PPI2]PICQTY(I)   =0
[M:PPI2]RMNEXTQTY(I)=RMNQTY
[M:PPI2]SOHNUM(I)   =[F:SOQ]SOHNUM
[M:PPI2]SOPLIN(I)   =[F:SOQ]SOPLIN
# Issue 71069 - 2016-06-28 by SR : PJT maintenant à la ligne sur les commandes de vente
[M:PPI2]WPJT(I)     =[F:SOQ]PJT
If dim([M:PPI2]ORI)>0
  [M:PPI2]ORI(I)    =2 : # Origine Ventes
Endif
#----- Indicateur inter-sociétés -----#
If [F:SOH]BETCPY=2
  [M:PPI2]WIPISO(I)=2
Else
  [M:PPI2]WIPISO(I)=1
Endif
#-----
If [M:PPI2]WIPTYP(I)=8
  [M:PPI2]WIPCOD(I) ="TPF"
Else
  [M:PPI2]WIPCOD(I) ="SOF"
  If [M:PPI2]WIPISO(I)=2 [M:PPI2]WIPCOD(I)+=chr$(126) : Endif
Endif
Raz [M:PPI2]VCRNUM(I), [M:PPI2]VCRLIN(I)
# Issue 10622 - 2012-01-09 by MUARN : ajout fenêtre critères
[M:PPI2]VCRTYP(I)=2
[M:PPI2]REQDAT(I)=[F:SOQ]ORDDAT
[M:PPI2]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1)+ mess([F:ORD]WIPSTA,342,1)
If [M:PPI2]WIPTYP(I)<>8 & [M:PPI2]WIPISO(I)= 2 : [M:PPI2]WIPTYPSTA(I) += chr$(126) : Endif

I+=1
Return

