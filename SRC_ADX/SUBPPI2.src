If [M]FOUFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]FOUFIN" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

