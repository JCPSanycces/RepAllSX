#<AdxTL>@(#)0.0.0.0 $Revision$
End
###########
# Sécurité
###########
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "X3DEVV7"
Call AVENMAJ40()
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
#####################################################################################
# VENMAJ40 : Mises à jour à effectuer lors du passage à la version 7 Module ventes  #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AVENMAJ40                                                       #
#                                                                                   #
#    - Table SALTRS [SLT]                 : Transactions Ventes                     #
#    - Table STKTRS [SRT]                 : Transactions Stock pour BP              #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour VENMAJ40                                                        #
#                                                                                   #
#####################################################################################
#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module ventes   #
#################################################################################
Subprog AVENMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("VENMAJ40 : Process for sales data") From LECFIC
    WOUV_TRACE=1
Endif

Gosub SET_FIRST   From TRTFIRST

Call AV_SLT : # Moulinette des transactions Ventes
Call AV_SRT : # Moulinette des transactions Stocks

Gosub UNSET_FIRST   From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
#    ---> Concerne les transactions VENTES                                      #
#################################################################################
Subprog AV_SLT

Local Shortint INDIC, WI
Local Integer  I

If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif

#-------------------------------------------------------------------------------#
# Initialisation transactions ventes pour les nouvelles zones                   #
#-------------------------------------------------------------------------------#
Call ECR_TIME("VENMAJ40 Sales Transactions Process : Update SALTRS") From DOSSUB

Local File =[F:ADS]DOSSIER+".SALTRS"    [SLT]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 1 ") From DOSSUB
Gosub TXNDEV : # Transaction pour les devis                                  #

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 2 ") From DOSSUB
Gosub TXNCDE : # Transaction pour les commandes                              #

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 3 ") From DOSSUB
Gosub TXNOUV : # Transaction pour les commandes ouvertes                     #

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 4 ") From DOSSUB
Gosub TXNLIV : # Transaction pour les livraisons                             #

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 5 ") From DOSSUB
Gosub TXNFAC : # Transaction pour les factures                               #

Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 6 ") From DOSSUB
Gosub TXNRET : # Transaction pour les retours                                #

Close Local File [SLT]

End


#################################################################################
#    ---> Concerne les transactions STOCKS                                      #
#################################################################################
Subprog AV_SRT

Local Shortint INDIC
Local Integer  I

If filinfo(filpath("FIL","STKTRS","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif

#-------------------------------------------------------------------------------#
# Initialisation transactions ventes pour les nouvelles zones                   #
#-------------------------------------------------------------------------------#
Call ECR_TIME("VENMAJ40 Sales Transactions Process : Update STKTRS") From DOSSUB

Local File =[F:ADS]DOSSIER+".STKTRS"    [SRT]

#-- X3-Suivi 75115 : Passage du Type livraison de commande à BP --#
Call ECR_TIME("VENMAJ40 Sales Transactions Process : --- Step 6 ") From DOSSUB
Gosub TXNPLA : # Transaction pour les plans de préparation                   #

Close Local File [SRT]

End


#-------------------------------------------------------------------------------#
#-------------------------------------------------------------------------------#
#-------------------------------------------------------------------------------#


#-------------------------------------------------------------------------------#
# Transaction pour les plans de préparation                                     #
#-------------------------------------------------------------------------------#
$TXNPLA
Trbegin [SRT]
  For [SRT]SRT0 Where SRTTYP=10
    Raz INDIC
    #-- X3-Suivi 75115 : Passage du Type livraison de commande à BP --#
    #-- Type livraison
    If dim([F:SRT]SDHTYPCOD)>0
        If !find([F:SRT]SDHTYPCOD,1,2)    INDIC=1 : [F:SRT]SDHTYPCOD=1  : Endif : # (affiché)
    Endif
    If dim([F:SRT]SDHTYPSCR)>0
        If !find([F:SRT]SDHTYPSCR,1,2,3)    INDIC=1 : [F:SRT]SDHTYPSCR=1  : Endif : # (fiche+tableau)
    Endif
    If INDIC=1
        Rewrite [SRT]
        If fstat
            Call ECR_TRACE("File STKTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les devis                                                    #
#-------------------------------------------------------------------------------#
$TXNDEV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=1
      Raz INDIC
      #Gbn-79065         : Sage Sales Tax integration
      #Gbn-94935 - 96043 : Remove condition on the activity code LTA because the field already exists in the table
      If dim([F:SLT]SSTENTCOD)>0
       If !find([F:SLT]SSTENTCOD,1,2)  INDIC=1 : [F:SLT]SSTENTCOD = 1 : Endif
      Endif
      If INDIC=1
         Rewrite [SLT]
         If fstat
             Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
         Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TXNCDE
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=2
      Raz INDIC
      # 75115 : V7 : Extension of Digital Signature : New field delivery type
      If dim([F:SLT]SDHTYPCOD)>0
       If !find([F:SLT]SDHTYPCOD,1,2)  INDIC=1 : [F:SLT]SDHTYPCOD = 1 : Endif
      Endif
      # 79704 : UNLCOD replaced by CDTBTNCOD
      If dim([F:SLT]CDTBTNCOD)>0
        If !find([F:SLT]CDTBTNCOD,1,2) : INDIC=1 : [F:SLT]CDTBTNCOD = 1 : Endif
        If dim([F:SLT]UNLCOD)>0 & find([F:SLT]UNLCOD,1,2) : [F:SLT]CDTBTNCOD=2 : Endif
      Endif
      #Gbn-79065         : Sage Sales Tax integration
      #Gbn-94935 - 96043 : Remove condition on the activity code LTA because the field already exists in the table
      If dim([F:SLT]SSTENTCOD)>0
       If !find([F:SLT]SSTENTCOD,1,2)  INDIC=1 : [F:SLT]SSTENTCOD = 1 : Endif
      Endif
      If INDIC=1
          Rewrite [SLT]
          If fstat
              Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes ouvertes                                       #
#-------------------------------------------------------------------------------#
$TXNOUV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=3
    Raz INDIC
    # 75115 : V7 : Extension of Digital Signature : New field delivery type
    If dim([F:SLT]SDHTYPCOD)>0
     If !find([F:SLT]SDHTYPCOD,1,2)  INDIC=1 : [F:SLT]SDHTYPCOD = 1 : Endif
    Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les livraisons                                               #
#-------------------------------------------------------------------------------#
$TXNLIV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=4
    Raz INDIC
    # 75115-Les transactions "Tous types de livraison" ont maintenant la valeur 4 dans DLVTYP
    If len(mess(0,447,1))=4 & [F:SLT]DLVTYP=3
     [F:SLT]DLVTYP=4 : INDIC=1
    Endif
    #Gbn-79065         : Sage Sales Tax integration
    #Gbn-94935 - 96043 : Remove condition on the activity code LTA because the field already exists in the table
    If dim([F:SLT]SSTENTCOD)>0
     If !find([F:SLT]SSTENTCOD,1,2)  INDIC=1 : [F:SLT]SSTENTCOD = 1 : Endif
    Endif
    # -------------------------------------
    # FGR 04/07/2014 : X3SUIVI91606 (début)
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DEPDATCOD) > 0 Then
      If !find([F:SLT]DEPDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DEPDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARRDATCOD) > 0 Then
      If !find([F:SLT]ARRDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARRDATCOD = 3
      Endif
    Endif
    # FGR 04/07/2014 : X3SUIVI91606 (fin)
    # -------------------------------------
    #---------
    If INDIC=1
      Rewrite [SLT]
      If fstat
          Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures / Avoirs                                        #
#-------------------------------------------------------------------------------#
$TXNFAC
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=5
    Raz INDIC
    #Gbn-79065         : Sage Sales Tax integration
    #Gbn-94935 - 96043 : Remove condition on the activity code LTA because the field already exists in the table
    If dim([F:SLT]SSTENTCOD)>0
     If !find([F:SLT]SSTENTCOD,1,2)  INDIC=1 : [F:SLT]SSTENTCOD = 1 : Endif
    Endif
    #Gbn-xxxx : DCLEECNUMCOD - Portugal
    #Gbn-94935 : Remove condition on the activity code VATTN because the field already exists in the table
    If dim([F:SLT]DCLEECNUMCOD)>0
     If !find([F:SLT]DCLEECNUMCOD,1,2)  INDIC=1 : [F:SLT]DCLEECNUMCOD = 1 : Endif
    Endif
    # Dde 87923 : SDD management
    If dim([F:SLT]UMRNUMCOD)>0                  : # Référence mandat
      If !find([F:SLT]UMRNUMCOD,1,2,3)
          If dim([F:SLT]PTECOD)>0 & find([F:SLT]PTECOD,1,2,3)
              [F:SLT]UMRNUMCOD=[F:SLT]PTECOD    : # Same value as Payment terms
          Else
              [F:SLT]UMRNUMCOD=3                : # invisible
          Endif
          INDIC=1
      Endif
    Endif
    # -------------------------------------
    # FGR 07/07/2014 : X3SUIVI91606 (début)
    If dim([F:SLT]LICPLATCOD) > 0 Then
      If !find([F:SLT]LICPLATCOD,1,2,3) Then
        # Immattriculation (invisible)
        INDIC = 1
        [F:SLT]LICPLATCOD = 3
      Endif
    Endif
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DEPDATCOD) > 0 Then
      If !find([F:SLT]DEPDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DEPDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARRDATCOD) > 0 Then
      If !find([F:SLT]ARRDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARRDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETDCOD) > 0 Then
      If !find([F:SLT]ETDCOD,1,2,3) Then
        # Heure départ (invisible)
        INDIC = 1
        [F:SLT]ETDCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETACOD) > 0 Then
      If !find([F:SLT]ETACOD,1,2,3) Then
        # Heure arrivée (invisible)
        INDIC = 1
        [F:SLT]ETACOD = 3
      Endif
    Endif
    # FGR 07/07/2014 : X3SUIVI91606 (fin)
    # -------------------------------------
    # FGR 12/08/2014 : X3SUIVI86249 (début)
    If dim([F:SLT]BELVCSCOD) > 0 Then
      If !find([F:SLT]BELVCSCOD,1,2,3) Then
        If dim(IKBEENABLE) < 0 Then
          Local Integer IKBEENABLE

          IKBEENABLE = 1
          Local File =DOSSIER+".ACTIV"    [WACV]
          Read [F:WACV]CODACT="KBE"
          If !fstat Then
            If [F:WACV]FLACT = 2 Then
              IKBEENABLE = 2
            Endif
          Endif
          Close Local File [WACV]
        Endif
        # ---------------------------
        INDIC = 1
        If IKBEENABLE = 2 Then
          [F:SLT]BELVCSCOD = 1 # Saisi
        Else
          [F:SLT]BELVCSCOD = 3 # Invisible
        Endif
        # ---------------------------
      Endif
    Endif
    # FGR 12/08/2014 : X3SUIVI86249 (fin)
    # -------------------------------------
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les retours                                                  #
#-------------------------------------------------------------------------------#
$TXNRET
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=6 | STRTYP=7 | STRTYP=8
    Raz INDIC
    # -------------------------------------
    # FGR 07/07/2014 : X3SUIVI91606 (début)
    If dim([F:SLT]LICPLATCOD) > 0 Then
      If !find([F:SLT]LICPLATCOD,1,2,3) Then
        # Immattriculation (invisible)
        INDIC = 1
        [F:SLT]LICPLATCOD = 3
      Endif
    Endif
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DEPDATCOD) > 0 Then
      If !find([F:SLT]DEPDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DEPDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARRDATCOD) > 0 Then
      If !find([F:SLT]ARRDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARRDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETDCOD) > 0 Then
      If !find([F:SLT]ETDCOD,1,2,3) Then
        # Heure départ (invisible)
        INDIC = 1
        [F:SLT]ETDCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETACOD) > 0 Then
      If !find([F:SLT]ETACOD,1,2,3) Then
        # Heure arrivée (invisible)
        INDIC = 1
        [F:SLT]ETACOD = 3
      Endif
    Endif
    # FGR 07/07/2014 : X3SUIVI91606 (fin)
    # -------------------------------------
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

##################################################################################
# Moulinettes avec champs version V7 uniquement màj concernant le module ventes #
##################################################################################
Subprog VENMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("VENMAJ40 : Process for sales data") From LECFIC
    WOUV_TRACE=1
Endif

Gosub SET_FIRST   From TRTFIRST

# Migration process here

Gosub UNSET_FIRST   From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


#---------------------------------------------------------------------------------
$INIVAR
#Gbn-94935 : Not necessary to read activity code.
# Local File =[F:ADS]DOSSIER+".ACTIV"    [MACV]   # Codes activités
#
# Global Integer ACT_LTA     : ACT_LTA=1
# Global Integer ACT_VATTN   : ACT_VATTN=1
#
# Read [MACV]CODACT="LTA"   : ACT_LTA   = [F:MACV]FLACT
# Read [MACV]CODACT="VATTN" : ACT_VATTN = [F:MACV]FLACT

Return

#---------------------------------------------------------------------------------
$KILLVAR
#Gbn-94935 : Not necessary to read activity code.
# If dim(ACT_LTA)>0   : Kill ACT_LTA   : Endif
# If dim(ACT_VATTN)>0 : Kill ACT_VATTN : Endif
Return
