#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSP0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:31"
A_USER  = "DOC"
A_STAMP = "20181109230531"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSP0 [NCSP0]
Gosub HORODAT
Local Inpbox "NCSP0" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSP0] As [SIM_]
Grizo [NCSP0]5
Grizo [NCSP0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSP0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=113 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=113 : Y1(1)=3 : Y2(1)=6
Return

$ON_PLANID
Return

$ON_PLANSTATUS
Onevent INIT_AREA Call D_PLANSTATUS(zc) From W1NCSP0
Return

Subprog D_PLANSTATUS(VALEUR)
Variable Integer VALEUR
If varinit([M]PLANSTATUS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_UPDUSR
Return

$ON_ZUPDUSR
Onevent BEFORE_AREA Gosub AV_ZUPDUSR From W1NCSP0
Return

$AV_ZUPDUSR
Call LECTEXTRA(zc,"AUTILIS","INTUSR",num$([M]UPDUSR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_UPDDAT
Onevent BEFORE_AREA Gosub AV_UPDDAT From W1NCSP0
Return

$AV_UPDDAT
Chgfmt [M]UPDDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_SITE
Return

$ON_ZSITE
Onevent BEFORE_AREA Gosub AV_ZSITE From W1NCSP0
Return

$AV_ZSITE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]SITE(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

$ON_NCSID
Return

$ON_ZNCSID
Onevent BEFORE_AREA Gosub AV_ZNCSID From W1NCSP0
Return

$AV_ZNCSID
If clalev([F:NCSRC])=0 : Local File NCSRECENT [NCSRC] : Endif
Call LECTURE("NCSH",num$([M]NCSID(indice)),"") From CONTOBJ
zc = [F:NCSRC]TITLE
Gosub _AFF
Return

$ON_NCSSTA
Onevent INIT_AREA Call D_NCSSTA(zc) From W1NCSP0
Return

Subprog D_NCSSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]NCSSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PRODUCT
Return

$ON_ZPRODUCT
Onevent BEFORE_AREA Gosub AV_ZPRODUCT From W1NCSP0
Return

$AV_ZPRODUCT
Call LECTEXTRA(zc,"ITMMASTER","DES1AXX",num$([M]PRODUCT(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_ECCVALMIN
Return

$ON_NCSMANAGER
Return

$ON_ZNCSMANAGER
Onevent BEFORE_AREA Gosub AV_ZNCSMANAGER From W1NCSP0
Return

$AV_ZNCSMANAGER
Call LECTEXTRA(zc,"AUTILIS","INTUSR",num$([M]NCSMANAGER(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_NCSPLANNER
Return

$ON_ZNCSPLANNER
Onevent BEFORE_AREA Gosub AV_ZNCSPLANNER From W1NCSP0
Return

$AV_ZNCSPLANNER
Call LECTEXTRA(zc,"AUTILIS","INTUSR",num$([M]NCSPLANNER(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


