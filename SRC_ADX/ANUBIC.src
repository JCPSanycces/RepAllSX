#<AdxTL>@(#)6.0.0.0 $Revision$


Subprog DEVALID(FACTURE)
Value Char FACTURE

GPOINT = "DELVCRINV" : Gosub ENTREE From EXEFNC
If GPE=1 : End : Endif

If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:BLA])=0 : Local File BALANA     [BLA] : Endif
If clalev([F:BLQ])=0 : Local File BLAQTY     [BLQ] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE  [TCH] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
If clalev([F:TVD])=0 : Local File TRCVCRDOC  [TVD] : Endif
If clalev([F:JST])=0 : Local File GAJOUSTA   [JST] : Endif

Local File GACCENTRY [HAE] , GACCENTRYD [DAE], GACCENTRYA [DAA] , GACCENTRYD [DAE0]
Local File GACCENTRY [HAE2]

Local Char    TYPPCE(GLONGTE) , PIECE(GLONVCR) , SYMBOLE(30)
Local Integer STAT , OK
Local Decimal MONTCLI , COURCPY
Local Char    DEVORG(GLONCUR) , DEVDES(GLONCUR)
Local Date    DATMIN , DATMAX

# Vérifs
# Confirmation d'annulation
OK = 1 : Call OUINON(mess(28,100,1),OK) From GESECRAN
If OK<>2 : End : Endif

Read [SIH]SIH0 = FACTURE
If fstat : End : Endif
If [F:SIH]STA<>3 : End : Endif
TYPPCE = [F:SIH]GTE
PIECE  = [F:SIH]NUM
Read [HAE]HAE0 = TYPPCE;PIECE
If fstat : End : Endif

SYMBOLE = "HAE"+PIECE+"\"+TYPPCE
Lock =SYMBOLE
If fstat=1
 # Pièce en cours de modifications
 Call ECR_TRACE(TYPPCE-PIECE-mess(12,110,1),1) From GESECRAN
 GOK = 0 : End
Endif

If [F:HAE]STA=2
 Call ECR_TRACE(mess(67,119,1),1) From GESECRAN
 Unlock =SYMBOLE
 GOK = 0 : End
Endif

OK = 1

Read[JST]JST0=[F:HAE]CPY;[F:HAE]JOU
If !fstat & (([F:JST]OPGSTRDAT<>[0/0/0] & [F:JST]OPGSTRDAT>[F:HAE]ACCDAT) | ([F:JST]OPGENDDAT<>[0/0/0] & [F:HAE]ACCDAT>[F:JST]OPGENDDAT))
 Call ECR_TRACE(mess(7,106,1)-"\"-mess(49,117,1),1) From GESECRAN  # Journal inactif. Annulation impossible.
 Unlock =SYMBOLE
 GOK = 0 : End
Endif

For [DAE0]DAE0 Where TYP=TYPPCE & NUM=PIECE & MTC<>""
 OK = 0 : Break
Next
If !OK
 # Ecriture lettrée, annulation impossible.
 Call ECR_TRACE(mess(64,119,1),1) From GESECRAN
 Unlock =SYMBOLE
 GOK = 0 : End
Endif
OK = 1
For [DUD] Where TYP=TYPPCE & NUM=PIECE & (TMPCUR>0 | TMPLOC>0)
 OK = 0 : Break
Next
If !OK
 # Echéance en cours de règlement. Annulation impossible
 Call ECR_TRACE(mess(50,119,1)-"."-mess(49,117,1),1) From GESECRAN
 Unlock =SYMBOLE
 GOK = 0 : End
Endif
For [PYD] Where VCRTYP=TYPPCE & VCRNUM=PIECE
 OK = 0 : Break
Next
If !OK
 # Echéance en cours de règlement. Annulation impossible
 Call ECR_TRACE(mess(50,119,1)-"."-mess(49,117,1),1) From GESECRAN
 Unlock =SYMBOLE
 GOK = 0 : End
Endif

Call TEMPON("A") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
Call TEMPOFF From GESECRAN
End

$TR1
GOK = 1
Trbegin [SIH] , [HAE]
 Readlock [SIH]SIH0 = FACTURE
 If fstat=1
  GOK = -1 : GLOCK = "$SINVOICE"-FACTURE : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("SIH",FACTURE) From GLOCK : Goto AB_TR1
 Endif
 Gosub MAJCLI
 If    GOK<0  : Goto ROLL_TR1
 Elsif !GOK   : Goto AB_TR1
 Endif

 # Anulation des mouvements
 Filter [TVD] Where ACCNUM=[F:SIH]ACCNUM
 If rowcount([TVD])>0
  For [TVD]
   Call ANUPCE([F:TVD]TYPVCR,[F:TVD]NUMVCR)
   If GOK<=0 : Break : Endif
  Next
 Else
  Call ANUPCE(TYPPCE,PIECE)
 Endif
 Filter [TVD]
 If    GOK<0  : Goto ROLL_TR1
 Elsif !GOK   : Goto AB_TR1
 Endif
 Filter [HAE2] Where REFINT="TR"+[F:SIH]SIVTYP+PIECE Order By Key CLE = REFINT
 For [HAE2]CLE
  Call ANUPCE([F:HAE2]TYP,[F:HAE2]NUM)
  If GOK<1 : Break : Endif
 Next
 If    GOK<0  : Goto ROLL_TR1
 Elsif !GOK   : Goto AB_TR1
 Endif
 Filter [HAE2]
 [F:SIH]STA = 1
 [F:SIH]STARPT = 1
 Rewrite [SIH]
 If fstat
  GOK = 0 : Call FSTA("SIH") From GLOCK : Goto AB_TR1
 Endif

 # Demande 23087
 GPE = 0
 GPOINT = "BEFDELBIC" : Gosub ENTREE From EXEFNC
 If GPE : Goto AB_TR1 : Endif

Commit

# LTA.sn - Once the accounting cancellation is committed reverse the committed status on SST
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Local Integer ERR
  Local Char ERRMSG(250)
  #101089 SST Syracuse integration.  SST_UNCOMITTAX is being removed from TRTTAXUSA.  Commit is handles by CALCTAX.
  #Call SST_UNCOMMITTAX([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP,ERR,ERRMSG) From TRTTAXUSA      #101089.O
  # Call SST_UNCOMMITBPINV([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP,ERR,ERRMSG) From TRTTAXUSA   #101089.n   # 106867.o
  Call SST_UNCOMMITBPINV([F:SIH]CPY,[F:SIH]NUM,[F:SIH]INVTYP,ERR,ERRMSG) From TRTTAXSST   #101089.n   # 106867.n
Endif
# LTA.en
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

############################
## Annulation pièce
############################

Subprog ANUPCE(TYPPCE,PIECE)
Value Char TYPPCE
Value Char PIECE
Local Date SVGDAT

Local Char LSTTYPLED(10) : # Liste des types référentiels flagués 'Double Entry Method'

# Dévalorisation des balances
If !clalev([F:LED]) : Local File =GTABCPT+"GLED"  [LED] : Endif

Read [HAE]HAE0 = TYPPCE;PIECE
Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
SVGDAT=[F:HAE]ACCDAT
For [DAE] Where TYP=TYPPCE & NUM=PIECE

 Call VALSTA("GAS",-1) From SUBPS2
 If GOK<1 : Break : Endif
 If [F:HAE]CAT<>3 & [F:HAE]CAT<>5

  If [F:LED]LED<>[F:DAE]LED
   Read [LED]LED0 = [F:DAE]LED
   If fstat  : Raz [LED] :  Endif
  Endif

  # Mise à jour de la balance générale
  If [F:LED]GEN=2
   Call BALANCE(-1) From CPTBAL
   If GOK<1 : Break : Endif
  Endif

  # Mise à jour de la balance analytique
  If [F:LED]ANA=2
   For [DAA]DAA0 Where TYP=TYPPCE & NUM=PIECE & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
    Call BALANA(-1) From CPTBAL
    If GOK<1 : Break 2 : Endif
    ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
    If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAE]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
     Call BALDEM(-1) From CPTBAL
     If GOK<1 : Break 2 : Endif
    Endif
   Next
  Endif
 Endif
Next
If GOK<1 : End : Endif

# Effacement pièce

Delete [HAE] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRY"-TYPPCE-PIECE : End
Endif
Delete [DAE] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRYD"-TYPPCE-PIECE : End
Endif
Delete [DAA] Where TYP=TYPPCE & NUM=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$GACCENTRYA"-TYPPCE-PIECE : End
Endif
GPOINT = "AFTDELVCR" : Gosub ENTREE From EXEFNC
If GOK<1 : End : Endif

# Mise à jour échéances

# Cas multi-collectif
Local Integer XSOI, XFUP, CAS, SVG_SAC
Raz SVG_SAC, XSOI, XFUP, CAS

For [DUD] Where TYP=TYPPCE & NUM=PIECE
 If XSOI=0 : XSOI = [F:DUD]SOI    : Endif
 If XFUP=0 : XFUP = [F:DUD]FLGFUP : Endif
 If [F:DUD]SAC<>""
  If [L]SVG_SAC=0
   [L]SVG_SAC = [F:DUD]LIG
  Elsif [L]SVG_SAC<>[F:DUD]LIG
   CAS=1
  Endif
 Endif
Next

If !CAS
 For [DUD] Where TYP=TYPPCE & NUM=PIECE
  [F:DUD]DUDSTA = 1
  Rewrite [DUD]
  If fstat
   GOK = 0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,SVGDAT)From MODECHE
 Next
Else
 Call HISTOSUPPR ("TYP='"+TYPPCE+"' & NUM='"+PIECE+"'") From MODECHE
 Delete [DUD] Where TYP=TYPPCE & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCDUDATE"-TYPPCE-PIECE : End
 Endif
 Call CREECHE(1,[L]XSOI,[L]XFUP,len(mess(0,510,1))) From SUBBIH
Endif

# Effacement dans la table de lien
Delete [TVD] Where TYPVCR=TYPPCE & NUMVCR=PIECE
If fstat=1
 GOK = -1 : GLOCK = "$TRCVCRDOC"-TYPPCE-PIECE : End
Endif

If func AFNC.ACTIV("INTCO") & func AFNC.PARAM("INTCPYINV",[F:HAE]CPY)="2"
 If !clalev([F:ICF]) : Local File INTCOFLO  [ICF] : Endif
 Update [ICF] Where TYPVCR=TYPPCE & NUMVCR=PIECE With NUMVCR=""
 If fstat=1
  GOK=-1 : GLOCK="$INTCOFLO"-TYPPCE-PIECE : End
 Elsif fstat
  GOK=0 : Call RSTA("ICF",TYPPCE-PIECE) From GLOCK : End
 Endif
Endif
End

##############################
## MAJ mvt clients
##############################
$MAJCLI
Local Char WSNS(1), WTYP(1)
Local Decimal WINVAMT
Local Decimal COURS

Call GETDEV([F:SIH]FCY) From DEVSUB

If [F:SIH]RATDIV(GTYPGEN-1)>0 : COURS  = [F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1) : Endif

Case [F:SIH]INVTYP
 When 1,3 : WSNS="+" : WTYP="I" : WINVAMT+=[F:SIH]AMTATI
 When 2,4 : WSNS="-" : WTYP="N" : WINVAMT-=[F:SIH]AMTATI
Endcase

Call MAJMVC([F:SIH]BPR,[F:SIH]CUR,[F:SIH]CURTYP,COURS,[F:SIH]ACCDAT,[F:SIH]NUM,[F:SIH]FCY,0,WINVAMT,WSNS,WTYP,"",0) From TRTBPMVT

Return

