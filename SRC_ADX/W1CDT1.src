#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CDT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:05"
A_USER  = "DOC"
A_STAMP = "20181109230305"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDIE"
  If [M]NBRDIE=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CDT1 [CDT1]
Gosub HORODAT
Local Inpbox "CDT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [CDT1] As [SIM_]
Grizo [CDT1]5
Grizo [CDT1]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CDT1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=74 : Y1(1)=4 : Y2(1)=28
Return

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1CDT1
Onevent BEFORE_INPUT Call AS_COD(zc) From W1CDT1
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1CDT1
Onkey 144 Titled GBOUTP Call P_COD(zc) From W1CDT1
Onkey 146 Titled GBOUTA Call SA_COD(zc) From W1CDT1
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CDT"
PARMSK(2) = "$"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CDT"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_COD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CDT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1CDT1
Onevent CONTROL Call C_LEG(zc) From W1CDT1
Onevent AFTER_CHANGE Gosub AMM_LEG From W1CDT1
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1CDT1
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1CDT1
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1CDT1
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1CDT1
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1CDT1
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"909","") From SUBADI
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"909",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBCDT
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1CDT1
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBRDIE
Onevent BEFORE_INPUT Call AS_NBRDIE From W1CDT1
Return

Subprog AS_NBRDIE
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(29437,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRDIE From W1CDT1
Gosub _AFF
End

Subprog B1_NBRDIE
Local Decimal BASPAG
If !GWEBSERV
 ## Action DIELOD
 Call DIELOAD("") From CPTBOUT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DIE
Onevent CONTROL Call C_DIE(zc) From W1CDT1
Onevent BEFORE_INPUT Call AS_DIE(zc) From W1CDT1
Onevent AFTER_CHANGE Gosub AMM_DIE From W1CDT1
Return

Subprog AS_DIE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6829,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DIE(zc) From W1CDT1
Onkey   2 Titled GBOUTS Call S_DIE(zc) From W1CDT1
Onkey 144 Titled GBOUTP Call P_DIE(zc) From W1CDT1
Onkey 146 Titled GBOUTA Call SA_DIE(zc) From W1CDT1
Gosub _AFF
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("DIE","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
 If !mkstat
  ## Action STD
  Call C_DIE(VALEUR) From SUBCDT
  If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 55843 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DIE
Call AM_DIE(zc)
If !mkstat & GOBJET
 zoncou = "DIE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DIE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZDIE)")>indice
 [M]DIE(indice) = VALEUR
 Affzo ZDIE(indice)
Endif
Gosub _AFF
End

Subprog S_DIE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJCRIT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJCRIT"
 PARMSK(1) = "DIE"
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = "!find([F:DIE]DIE,[M:CDT1]DIE)"
 PARMSK(5) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DIE(VALEUR)
Variable Char    VALEUR()
Call OBJET("DIE",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_DIE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "DIE"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DIE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("DIE",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDIE
Onevent BEFORE_AREA Gosub AV_ZDIE From W1CDT1
Return

$AV_ZDIE
Call LECTEXTRA(zc,"GDIE","DESTRA",num$([M]DIE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_OPT
Onevent BEFORE_INPUT Call AS_OPT(zc) From W1CDT1
Onevent INIT_AREA Call D_OPT(zc) From W1CDT1
Onevent CONTROL Call C_OPT(zc) From W1CDT1
Return

Subprog D_OPT(VALEUR)
Variable Integer VALEUR
If varinit([M]OPT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(35) From COMBOS
## Action STD
Call AS_OPT(VALEUR) From SUBCDT
If mkstat=2
 [M]OPT(INDIC) = VALEUR
 Affzo OPT(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,35,1))))
Endif
If !mkstat
 Discombo 0 From OPT(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From OPT(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_OPT(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_OBG
Onevent BEFORE_INPUT Call AS_OBG(zc) From W1CDT1
Onevent INIT_AREA Call D_OBG(zc) From W1CDT1
Return

Subprog D_OBG(VALEUR)
Variable Integer VALEUR
If varinit([M]OBG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OBG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_OBG(VALEUR) From SUBCDT
If mkstat=2
 [M]OBG(INDIC) = VALEUR
 Affzo OBG(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_SOH
Onevent INIT_AREA Call D_SOH(zc) From W1CDT1
Onevent BEFORE_INPUT Call AS_SOH(zc) From W1CDT1
Return

Subprog D_SOH(VALEUR)
Variable Integer VALEUR
If varinit([M]SOH,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SOH(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


