#<AdxTL>@(#)218.0.0.0 $Revision$
############################################################################################ 
# Librairie de sous-programme de gestion des documents OF                                  # 
############################################################################################ 
# Subprog UPDPRN(LCOD,LMSG)                                                                #
# Subprog GENPRN(CDAT,CALT)                                                                #
# Subprog DISPLAY_PRN                                                                      #
# Subprog SUPPRN(LDIS)                                                                     #
############################################################################################ 
# Mise à jour de la table des UC
Subprog UPDPRN(LCOD,LMSG,LLIG) 
Value    Integer  LCOD
Value    Integer  LMSG
Value    Integer  LLIG

 
# ajout, suppression des conditionnements
Case LCOD  
    When 1:    Call SUPPRN(2)
    When 2:    Call GENPRN(LLIG)
Endcase    
#
End  

############################################################ 
# Recherche des conditionnements de l'article lancé 
# (premier article si OF groupé)
Subprog GENPRN(WLIG)
Value    Integer  WLIG 
Local    Integer  I
Local    Integer  IMAX: IMAX = dim([F:ITM]PCU)    # llc 01.02 PCU

# si des conditionnements existent (cas de la modif), on les supprime
If [M:MFG4]NBLIG <> 0 : Call SUPPRN(1) : Endif
# lecture de l'article si nécessaire
If [F:ITM]ITMREF <> [M:MFG1]ITMREF(WLIG)
    Read [ITM]ITM0=[M:MFG1]ITMREF(WLIG)
    If fstat : End : Endif  
Endif 
# 
For I=0 To IMAX-1
    If [F:ITM]PCU(I) <> "" : Call DISPLAY_PRN(I,WLIG) : Endif
Next I
#
If [M:MFG4]NBLIG <> 0 : Affzo [M:MFG4] : Endif  
#
End

############################################################ 
# alimentation de la classe écran
Subprog DISPLAY_PRN(L, WL)
Value Integer L
Value Integer WL
Local Integer LIG
#
LIG = [M:MFG4]NBLIG
#
[M:MFG4]PCU(L)       = [F:ITM]PCU(L)
[M:MFG4]PCUSTUCOE(L) = [F:ITM]PCUSTUCOE(L)
[M:MFG4]LBEFMT(L)    = [F:ITM]LBEFMT(L)
If [M:MFG4]PCU(L) = [M:MFG1]UOM(WL)
    [M:MFG4]PCUNBR(L) = [M:MFG1]UOMEXTQTY(WL)
Endif 
# incrémentation du nombre de ligne 
[M:MFG4]NBLIG += 1 
#
End  

############################################################  
# Suppression des conditionnements
Subprog SUPPRN(LDIS)
Value Integer LDIS      
# suppression des lignes
Dela 0,[M:MFG4]NBLIG [M:MFG4]NBLIG   
[M:MFG4]NBLIG = 0
# affichage si demandé
Case LDIS
    When 1:    # ben rien ...
    When 2:    Affzo [M:MFG4]
Endcase
# 
End 

############################################################  
# incrémentation nbr conditionnement
Subprog INCNBR(L)
Value Integer L
Local Integer  I
Local Integer  IMAX: IMAX = dim([F:ITM]PCU)    # llc 01.02 PCU
#
For I=0 To IMAX-1
    If [M:MFG4]PCU(I) = [M:MFG1]UOM(L)
        [M:MFG4]PCUNBR(I) += [M:MFG1]UOMEXTQTY(L)
        Affzo [M:MFG4]10
        Break
    Endif
Next I
#
End

############################################################  
# décrémentation nbr conditionnement
Subprog DECNBR(L)
Value Integer L
Local Integer  I
Local Integer  IMAX: IMAX = dim([F:ITM]PCU)    # llc 01.02 PCU
#
For I=0 To IMAX-1
    If [M:MFG4]PCU(I) = [M:MFG1]UOM(L)
        If [M:MFG4]PCUNBR >= [M:MFG1]UOMEXTQTY(L)
            [M:MFG4]PCUNBR(I) -= [M:MFG1]UOMEXTQTY(L)
        Else
            [M:MFG4]PCUNBR(I)  = 0
        Endif
        Affzo [M:MFG4]10
        Break
    Endif
Next I
#
End

