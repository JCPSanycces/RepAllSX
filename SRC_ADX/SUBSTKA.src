###########################################################
Subprog AP_CLCCOD(VALEUR)
Variable Integer  VALEUR
If VALEUR = 3
  Raz [M]FORCOD, FORDES, FORFOR, AAABKT, BBBBKT, CCCBKT
  Affzo [M]15-25
Endif 
Raz GMENLOC
End
