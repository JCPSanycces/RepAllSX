###########################################################
Subprog S_FORCOD(VALEUR)
Variable Char    VALEUR()
Call SELECT("TFO","",VALEUR,"6") From SELOBJ
End
###########################################################
Subprog AV_AAABKT(VALEUR)
Variable Decimal  VALEUR
End
###########################################################
Subprog AS_AAABKT(VALEUR)
Variable Decimal  VALEUR
If [M]CLCCOD = 3
  mkstat = 2
Endif
End
###########################################################
Subprog AV_BBBBKT(VALEUR)
Variable Decimal VALEUR
End
###########################################################
Subprog AS_BBBBKT(VALEUR)
Variable Decimal  VALEUR
If [M]CLCCOD = 3
  mkstat = 2
Endif
End
###########################################################
Subprog AV_CCCBKT(VALEUR)
Variable Decimal VALEUR
If [M]CLCCOD = 3
  VALEUR = 0
Else
  VALEUR = 100 - ([M]AAABKT + [M]BBBBKT)
Endif
End
###########################################################
Subprog AS_CCCBKT(VALEUR)
Variable Decimal  VALEUR
If [M]CLCCOD = 3
  mkstat = 2
Endif
End
###########################################################
Subprog C_CCCBKT(VALEUR)
Variable Decimal VALEUR
If ([M]AAABKT + [M]BBBBKT + VALEUR) <> 100
  mkstat = 2
Endif
End 
########################################################### 
Subprog AS_FORCOD(VALEUR)
Variable Char     VALEUR
If [M]CLCCOD = 3
  mkstat = 2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran STKA) 17/12/2010 16:00:10 (HCB)
######################################################################################
Subprog AM_FORCOD(VALEUR)
Variable Char    VALEUR()
Local Char WPAR(10)
Local Char WTXT(160)

[M] = [F:TFO]
Call PARAM([M]STOFCY,"ABCBKTA",WPAR) From ADOVAL
[M]AAABKT = val(WPAR)
Call PARAM([M]STOFCY,"ABCBKTB",WPAR) From ADOVAL
[M]BBBBKT = val(WPAR)
If ([M]AAABKT+[M]BBBBKT) > 100
  [M]BBBBKT = 0
Endif
If [M]AAABKT > 100
  [M]AAABKT = 0
Endif
[M]CCCBKT = (100-([M]AAABKT+[M]BBBBKT))
Affzo [M]15-25

End


