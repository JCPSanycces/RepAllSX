#<AdxTL>@(#)169.0.0.0 $Revision$
#LS Utilitaire de pointage des ecritures de compte et de relevés 
#bancaires sans contrepartie
#5 juin 1998
 
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UTICHK","DUTICHK",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE # <JFL>
Endcase
Return

$OUVRE
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:RBK])=0 : Local File RELBANK    [RBK] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
Local Integer OK, NBECR
Local Char    CRITERE(200), LIGTRACE(100), SYMBCHK(20)
TMP = 1 : TRA = 1
Return

$EXEC
Gosub VERROU
If GERR : FIN = 1 : Return : Endif
Call OUVRE_TRACE(mess(31,120,1)+" "+mess(45,120,1)+" "+[M]BAN) From LECFIC 
# Lignes pointées sans contrepartie BANQUE :
Call ECR_TRACE(mess(59,100,1)+space$(6)+mess(88,100,1)+space$(10)+
&              mess(32,105,1)+space$(10)+mess(29,159,1),0) From GESECRAN
# type     Date          Montant          Désignation
Call ECR_TRACE(string$(72,"="),0) From GESECRAN
Read [BAN]BAN0=[M]BAN
Call GETSOC([F:BAN]CPY) From DEVSUB   
Call PARAM([F:BAN]CPY,"SNSBNQ",[M]SNSBNQ) From ADOVAL
Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBCHK
Call FERME_TRACE From LECFIC 
If NBECR=0
 Call ECR_TRACE(mess(39,120,1),0) From GESECRAN : # Pas d'écriture à pointer
Endif
Return

$VERROU
SYMBCHK ="AUTCHK"+"\"+[M]BAN
Lock =SYMBCHK
If fstat
 GERR = 1 : GMESSAGE = mess(23,120,1) : # Compte en cours de pointage
 Unlock =SYMBCHK
 Return
Endif
Return

$SORTIE
Return

$TR1
GOK=1
Trbegin [DAE], [RBK] 
 If [M]SELE = 2 : # LA1 Oui
  CRITERE = 'LEDTYP=GTYPGEN & CPY=[F:BAN]CPY & ACC=[F:BAN]BANACC  & BPR=[F:BAN]BANBPR & CHK=""'
  If [M]DATDEB <> [0/0/0] : CRITERE += ' & ACCDAT>=[M]DATDEB' : Endif
  If [M]DATFIN <> [0/0/0] : CRITERE += ' & ACCDAT<=[M]DATFIN' : Endif
  If [F:BAN]FCY <> ""
   CRITERE += ' & FCYLIN=[F:BAN]FCY'
  Else
   If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE 
    CRITERE += ' & find(FCYLIN,GUSRFCY(1..GNBAUZ))' 
   Endif
   If [M]FCYDEB <> "" : CRITERE += ' & FCYLIN>=[M]FCYDEB'    : Endif
   If [M]FCYFIN <> "" : CRITERE += ' & FCYLIN<=[M]FCYFIN'    : Endif 
  Endif
  Filter [DAE] Where evalue(CRITERE)
  For [DAE]
   OK = 1
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   If fstat : OK = 0 : Endif
   If [F:HAE]CAT <> 1 | [F:HAE]FLGREP=2  : OK = 0 : Endif : #(LA618) Réel (LA1)A nouveau=Oui
   If OK
    Call LECTURE("TCU",[F:DAE]CUR,"") From CONTOBJ
    Readlock [DAE]
    GCLE = num$([F:DAE]ACCNUM)
    If fstat=1
     GOK = -1 : GLOCK="$GACCENTRYD"-GCLE : Break
    Elsif fstat
     GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK : Break
    Elsif [F:DAE]BPR="" | [F:DAE]BPR=[F:BAN]BANBPR
     LIGTRACE = mess(47,120,1)+space$(3)+format$("D:"+GFMDAT,[F:DAE]ACCDAT) : #Ecriture
     If [F:DAE]SNS=1
      LIGTRACE += space$(3)+"D"+ num$(format$("N3:"+[F:TCU]CURFMT1,[F:DAE]AMTCUR))+
&                 space$(3)+[F:DAE]DES
     Else
      LIGTRACE += space$(3)+"C"+ num$(format$("N3:"+[F:TCU]CURFMT1,[F:DAE]AMTCUR))+
&                 space$(3)+[F:DAE]DES
     Endif
     [F:DAE]CHK    = "*"
     [F:DAE]CHKDAT = date$
     Rewrite [DAE]
     If fstat
      GOK = 0 : Call FSTA("DAE") From GLOCK : Break
     Else   
      Call ECR_TRACE(LIGTRACE,0) From GESECRAN 
      NBECR +=1
     Endif 
    Endif
   Endif
  Next
  Filter [DAE]
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif 
 
 If [M]SELB = 2 : # LA1 Non 
  CRITERE = 'BAN=[M]BAN & RECTYP=2 & CHK=""'
  If [M]DATDEB <> [0/0/0] : CRITERE += ' & OPEDAT>=[M]DATDEB' : Endif
  If [M]DATFIN <> [0/0/0] : CRITERE += ' & OPEDAT<=[M]DATFIN' : Endif
  Filter [RBK] Where evalue(CRITERE)
  For [RBK]
   Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
   Readlock [RBK]
   GCLE = [F:RBK]BAN-num$([F:RBK]RBKNUM)-num$([F:RBK]RECTYP)-num$([F:RBK]RBKLIN)
   If fstat=1
    GOK = -1 : GLOCK="$RELBANK"-GCLE : Break
   Elsif fstat
    GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : Break
   Else
    LIGTRACE = mess(42,117,1)+space$(3)+format$("D:"+GFMDAT,[F:RBK]OPEDAT) : #Relevé
    If ([F:RBK]SNS=1 & val([M]SNSBNQ)=1) |
&      ([F:RBK]SNS=-1 & val([M]SNSBNQ)=2)
     LIGTRACE += space$(3)+"D"+num$(format$("N3:"+[F:TCU]CURFMT1,[F:RBK]AMTCUR))+
&                space$(3)+[F:RBK]DES
    Endif
    If ([F:RBK]SNS=1 & val([M]SNSBNQ)=2) |
&      ([F:RBK]SNS=-1 & val([M]SNSBNQ)=1)
     LIGTRACE += space$(3)+"C"+num$(format$("N3:"+[F:TCU]CURFMT1,[F:RBK]AMTCUR))+
&                space$(3)+[F:RBK]DES
    Endif
    [F:RBK]CHK = "*"
    [F:RBK]DATCHK = date$
    Rewrite [RBK]
    If fstat
     GOK = 0 : Call FSTA("RBK") From GLOCK : Break
    Else   
     Call ECR_TRACE(LIGTRACE,0) From GESECRAN 
     NBECR +=1
    Endif
   Endif
  Next
  Filter [RBK]
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif 
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

########################################
Subprog AS_BAN(VALEUR) 
Variable Char    VALEUR() 
If VALEUR="" 
 Call BANDEF(VALEUR) From SUBCHK 
Endif 
End 

Subprog C_BAN(VALEUR)
Variable Char   VALEUR()
#Contrôle accés à la fonction
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 GMESSAGE = mess(25,120,1)-" "-VALEUR : #Vous n'avez pas accés à la banque
 mkstat = 2
 End
Endif
#Recherche du compte banque
Read [BAN]BAN0 = VALEUR
If !fstat
 [M]BANACC = [F:BAN]BANACC
 [M]BANBPR = [F:BAN]BANBPR
 [M]CPY    = [F:BAN]CPY
Endif
End

Subprog AS_FCYDEB(VALEUR)
Variable Char    VALEUR()
If [F:BAN]FCY<>"" : mkstat = 2 : End : Endif
End

Subprog AS_FCYFIN(VALEUR)
Variable Char    VALEUR()
If [F:BAN]FCY<>"" : mkstat = 2 : End : Endif
If VALEUR="" | VALEUR<[M]FCYDEB : VALEUR=[M]FCYDEB : Endif
End

Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]FCYDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End


##########################################################################################################
# The PATCH subprogramm has been added just to avoid problems during the continuous integration due to   #
# the name of the processing UTI*                                                                        #
##########################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
End
