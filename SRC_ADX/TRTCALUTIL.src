###############################################################################################################
#
#   Traitements utilitaires pour la génération de l'agenda XML X3
#   Module CRM                                                                          25 Septembre 2002
#   
###############################################################################################################
#
# BUILDFICNAME  : Construit un nom de fichier
# XMLXSLT       : Construit la liaison avec une feuille de style XSLT
# XSLTENTET     : Construit un en-tête de feuille de style XSLT
# GETSORTFIE    : Retourne les champs composant la premiere clé sans homonyme d'une table
#
###############################################################################################################
##############################################################################
# Construit un nom de fichier
##############################################################################
Subprog BUILDFICNAME(IDIRECTORY, SZWISHEDNAME, SZWISHEDEXT, SZWHOLENAME, SZFICNAME, SZFICWEXT)
Value Integer IDIRECTORY
Value Char SZWISHEDNAME
Value Char SZWISHEDEXT
Variable Char SZWHOLENAME
Variable Char SZFICNAME
Variable Char SZFICWEXT

  #IDIRECTORY
  # 0 = Serveur
  # 1 = Client (Rts/Temp)

Local Char SZDIRECTORY(250)
Local Char SZPREFIX(250)
Local Char SP(2)

  SP = '_'
  If IDIRECTORY = 0 Then
    #Serveur
    SZPREFIX = adxmac(-1) + SP + num$(adxtcp) + SP + nomap + SP + GUSER + SP
    SZFICNAME = SZPREFIX + SZWISHEDNAME
    SZWHOLENAME = filpath("",SZFICNAME, SZWISHEDEXT,nomap)
    SZFICWEXT = SZFICNAME
    SZFICNAME = SZFICNAME + '.' + SZWISHEDEXT

  Elsif IDIRECTORY = 1 Then
    #Client
    SZDIRECTORY = filpath("!","","","","","#") + "\temp\"
    SZPREFIX = adxmac(-1) + SP + num$(adxtcp) + SP + nomap + SP + GUSER + SP
    SZWHOLENAME = SZDIRECTORY + SZPREFIX + SZWISHEDNAME + '.' + SZWISHEDEXT
    SZFICNAME = SZPREFIX + SZWISHEDNAME + '.' + SZWISHEDEXT
    SZFICWEXT = SZPREFIX + SZWISHEDNAME
  Endif
End

##################################################################################
# Construit la liaison avec une feuille de style XSLT
##################################################################################
Subprog XMLXSLT(SZXSLNAME, ZONE)
Variable Char SZXSLNAME
Variable Char ZONE()
Local Char VQ

  VQ = '"'
  ZONE(0) = "<?xml-stylesheet type=" + VQ + "text/xsl" + VQ
  ZONE(1) = " HREF=" + VQ + SZXSLNAME + ".xsl" + VQ + "?>"
End

##################################################################################
# Construit un en-tête de feuille de style XSLT
##################################################################################
Subprog XSLTENTET(ZONE)
Variable Char ZONE
Local Char VQ

  VQ = '"'
  ZONE = "<xsl:stylesheet xmlns:xsl=" + VQ + "http://www.w3.org/1999/XSL/Transform" + VQ + " version=" + VQ + "1.0" + VQ + ">"
End

####################################################
# Retourne les champs composant la premiere clé sans homonyme d'une table
####################################################
Subprog GETSORTFIE(SZTABLE, SZKEYNAME, IKEYTYPE)
Value Char SZTABLE
Variable Char SZKEYNAME()
Variable Integer IKEYTYPE()

Local Char SZIDXCPN2(30)(dim(SZKEYNAME))
Local Char SZINDDESCRIPT(250)
Local Integer IHOMINDFOUND
Local Integer IMAXIDX
Local Integer ITERIDX
Local Integer INBINDCPN
Local Integer ISTRINDSEA
Local Integer ISTRINDSEA2
Local Integer ILASTSTRSEA

  Raz SZIDXCPN2
  Raz SZKEYNAME
  Raz IKEYTYPE
  IMAXIDX = 0
  ITERIDX = 0
  INBINDCPN = 1
  ISTRINDSEA = 1
  ILASTSTRSEA = 1
  IHOMINDFOUND = 0
  SZINDDESCRIPT = ""
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  Filter [ATI] Where [F:ATI]CODFIC = SZTABLE and [F:ATI]HOMONYM <> 2
  For [ATI]NUMLIG
    SZINDDESCRIPT = [F:ATI]DESCRIPT
    If SZINDDESCRIPT <> "" Then
      IHOMINDFOUND = 1
    Endif
    Break
  Next
  Filter [ATI]
  If !IHOMINDFOUND Then
    End
  Endif
  INBINDCPN = 1
  ISTRINDSEA = 1
  While instr(ISTRINDSEA, SZINDDESCRIPT, '+')
    INBINDCPN += 1
    ISTRINDSEA2 = instr(ISTRINDSEA, SZINDDESCRIPT, '+')
    ISTRINDSEA = ISTRINDSEA2 + 1
  Wend
  IMAXIDX = INBINDCPN - 1
  ITERIDX = 0
  ISTRINDSEA = 1
  ILASTSTRSEA = 1
  Local File =SZTABLE [TYP1]
  For ITERIDX = 0 To IMAXIDX 
    ISTRINDSEA2 = instr(ISTRINDSEA, SZINDDESCRIPT, '+')
    If ISTRINDSEA2 Then
      SZKEYNAME(ITERIDX) = mid$(SZINDDESCRIPT, ILASTSTRSEA, ISTRINDSEA2 - ILASTSTRSEA)
      ISTRINDSEA = ISTRINDSEA2 + 1
      ILASTSTRSEA = ISTRINDSEA2 + 1
    Else
      SZKEYNAME(ITERIDX) = right$(SZINDDESCRIPT, ILASTSTRSEA)
    Endif
    IKEYTYPE(ITERIDX) = evalue("Type([F:TYP1]" + SZKEYNAME(ITERIDX) + ")")
    If ITERIDX >= dim(SZKEYNAME) Then
      Break
    Endif
  Next
  Close Local File [TYP1]
End
