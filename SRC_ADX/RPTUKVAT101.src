#   UPDATES :    2016-07-25 DNE SAM #117745
#                2016-08-08 DNE SAM #117956, #117959
#
#################################################################################################################

# < DEBUG> ######################################################################################################
End
# </DEBUG> ######################################################################################################


####################################################
## Report UK-VAT101
####################################################

$ACTION
Return


####################################################
## IMPRIME
####################################################

Subprog IMPRIME( NBPAR, PARAMETRE )
Variable Integer NBPAR                          # Number of parameters
Variable Char    PARAMETRE()(1..)               # Array of parameters. Form: [PARAMNAME]=[PARAMVALUE])
Local Char       PARAMRETC(255)                 # Return value for GETPARAM procedure.

    # Local Variables
    Local Integer NUMREQ                        # Data ID for the report: Everything with this ID belongs to this report instance.
    Local Char REPORTCODE(255)                  # ID code of the report
    Local Char CPYSTR(GLONCPY), CPYEND(GLONCPY) # Company range
    Local Char FCYSTR(GLONFCY), FCYEND(GLONFCY) # Site range
    Local Date DATSTR, DATEND                   # Date range
    Local Char CRITERIA(255) : CRITERIA= "1=1"  # User selection criteria (company, site and date ranges)

    # ------------------------------------------
    # Get/Set parameter values.
    # ------------------------------------------
    #

    # Get the ID code of the report.
    #
    Call GETPARAM( "__REPORT", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    REPORTCODE= left$( PARAMRETC , instr( 1, PARAMRETC ,"." ) - 1 )

    # Get the data ID for the report, ...
    #
    Call GETPARAM( "__REQUETE", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    NUMREQ= val( PARAMRETC )

    # ... and set the "numedt" parameter for the report.
    # (Informs the report which data ID to use.)
    #
    Call SETPARAM( "numedt", NBPAR, PARAMETRE, PARAMRETC ) From ETAT

    # Get user report parameters:
    Call GETPARAM( "cpydeb", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    CPYSTR= PARAMRETC
    Call GETPARAM( "cpyfin", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    CPYEND= PARAMRETC
    Call GETPARAM( "fcydeb", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    FCYSTR= PARAMRETC
    Call GETPARAM( "fcyfin", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    FCYEND= PARAMRETC
    Call GETPARAM( "datedeb", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    DATSTR = PARAMRETC
    Call GETPARAM( "datefin", NBPAR, PARAMETRE, PARAMRETC ) From ETAT
    DATEND = PARAMRETC
    If left$(CPYSTR, 1) <> "?" and left$(CPYEND, 1) <> "?"
        CRITERIA += " & [F:SIH]CPY >= '" + CPYSTR +  "' & [F:SIH]CPY <= '" + CPYEND + "'"
    Endif
    If left$(FCYSTR, 1) <> "?" and left$(FCYEND, 1) <> "?"
        CRITERIA  += " & [F:SIH]FCY >= '" + FCYSTR +  "' & [F:SIH]FCY <= '" + FCYEND + "'"
    Endif
    CRITERIA  += " & [F:SIH]ACCDAT >= [L]DATSTR & [F:SIH]ACCDAT <= [L]DATEND"

    # ------------------------------------------
    # Write data to the reporting table.
    # ------------------------------------------
    #
    # Open necessary tables.
    #
    If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif
    If !clalev([F:SID])  : Local File SINVOICED  [SID]  : Endif
    If !clalev([F:SID2]) : Local File SINVOICED  [SID2] : Endif
    If !clalev([F:SIV])  : Local File SINVOICEV  [SIV]  : Endif
    If !clalev([F:SIL])  : Local File BPCINVLIG  [SIL]  : Endif
    If !clalev([F:SVF])  : Local File SVCRFOOT   [SVF]  : Endif
    If !clalev([F:SFI])  : Local File SFOOTINV   [SFI]  : Endif
    If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
    If !clalev([F:TCYC]) : Local File TABCOUNTRY [TCYC] : Endif
    If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
    If !clalev([F:TCYB]) : Local File TABCOUNTRY [TCYB] : Endif
    If !clalev([F:CAL])  : Local File CPTANALIN  [CAL]  : Endif
    If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
    If !clalev([F:ARM])  : Local File AREPORTM   [ARM]  : Endif

    # ...
    Local Integer I : Raz I                      # Index: Line number counter
    Local Integer J
    Local Integer DIMDDTANOT : DIMDDTANOT = dim( [F:SID]DDTANOT ) - 1
    Local Integer DIMINVDTA  : DIMINVDTA  = dim( [F:SIV]INVDTA )  - 1
    Local Decimal TOTAMTNOTLIN
    Local Char NUMOLD(GLONVCR) : Raz NUMOLD
# 2016-08-09 DNE INSERT BEGIN (SAM #117956)
    Local Decimal RATCUR                          # Multiplikative conversion RATCUR.
# 2016-08-09 DNE INSERT END

    # Open a new transaktion for AREPORTM.
    #
    Trbegin [ARM]

    # PART 1 - Sales invoices (GESSIH)
    #
    # Create DB select.
    #
    Link [F:SID] With
&        [F:SIH]SIH0    ~= [F:SID]NUM,
&        [F:CPY]CPY0    ~= [F:SIH]CPY,
&        [F:TCYC]TCY0   ~= [F:CPY]CRY,
&        [F:BPR]BPR0    ~= [F:SIH]BPR,
&        [F:TCYB]TCY0   ~= [F:BPR]CRY,
&        [F:CAL]CAL0(4) ~= "SID"; 0; [F:SID]NUM; [F:SID]SIDLIN,
&        [F:GAC]GAC0     = [F:CAL]COA; [F:CAL]ACC
&   As [LNK]
&   Where [F:SIH]STA = 3
&   and [F:CPY]CRY <> [F:BPR]CRY
&   and [F:TCYC]EECFLG = 2
&   and [F:TCYB]EECFLG = 2
&   and len( [F:BPR]EECNUM ) > 2
&   and evalue(CRITERIA)
&   Order By Key CLE = [F:SID]NUM; [F:SID]SIDLIN

    # Common information for all AREPORTM records.
    Raz [F:ARM]
    [F:ARM]RPTCOD = REPORTCODE
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = NUMREQ                   # Selection ID in AREPORTM
    [F:ARM]CREDAT = date$

    # Collect data in the AREPORT table.
    #
    For [LNK]CLE
        I= I + 1

# 2016-08-09 DNE INSERT (SAM #117956)
        # Get RATCUR (and be aware that RATMLT can be 0!).
        If [F:SIH]RATDIV(0) = 0
            RATCUR = [F:SIH]RATMLT(0)
        Else
            RATCUR = [F:SIH]RATMLT(0) / [F:SIH]RATDIV(0)
        Endif

        # Fallback: If zero calculate if from amounts.
        #
        # Note: There seems to be known bug. Or there was one.
        #       (OK its harsh but better than nothing. And be aware that in
        #        the end the report will round down to Pounds...)
        #
        If RATCUR = 0
            RATCUR = [F:SIH]AMTNOTL / [F:SIH]AMTNOT
        Endif
# 2016-08-09 DNE INSERT

        [F:ARM]NUMLIG = I                        # Line number (e. g. for sorting)
        [F:ARM]CLEA1  = [F:SID]NUM               # Invoice number
        [F:ARM]CLEN1  = [F:SID]SIDLIN            # Invoice line

        # Information needed for indicator calculation in the report.
        [F:ARM]CLEN3  = [F:GAC]ESDTRK

        # Line amount
# 2016-08-08 DNE MODIF BEGIN (SAM #117956)
        [F:ARM]CLEMD1 = [F:SID]AMTNOTLIN * [F:SIH]SNS * RATCUR
# 2016-08-08 DNE MODIF ORIG
#        [F:ARM]CLEMD1 = [F:SID]AMTNOTLIN * [F:SIH]SNS * [F:SIH]RATMLT(0)
# 2016-08-08 DNE MODIF END

        # Total of invoicing elements on an invoice line.
# 2016-08-08 DNE MODIF BEGIN (SAM #117956)
        [F:ARM]CLEMD2 = sum( [F:SID]DDTANOT(0..DIMDDTANOT) ) * [F:SIH]SNS * RATCUR
# 2016-08-08 DNE MODIF ORIG
#        [F:ARM]CLEMD2 = sum( [F:SID]DDTANOT(0..DIMDDTANOT) ) * [F:SIH]SNS * [F:SIH]RATMLT(0)
# 2016-08-08 DNE MODIF END

        # Total of invoice based on line amounts (with performance optimization).
        If NUMOLD <> [F:SIH]NUM
            NUMOLD = [F:SIH]NUM
            Raz TOTAMTNOTLIN
            Filter [F:SID2] Where NUM = [F:SIH]NUM
            For [F:SID2]SID0
                TOTAMTNOTLIN += [F:SID2]AMTNOTLIN
            Next
            Filter [F:SID2]
        Endif

        # Total of invoicing elements on invoice level distributed on the lines.
        Raz [F:ARM]CLEMD3
        Filter [F:SVF] Where NUM = [F:SIH]NUM
        For [F:SVF]SVF0
            Read [F:SFI]SFI0 = [F:SVF]DTA
            If !fstat and ( [F:SFI]DSPLIN = 1 )
# 2016-08-08 DNE MODIF BEGIN (SAM #117956)
                CLEMD3 += [F:SVF]DTANOT * [F:SIH]SNS * RATCUR
# 2016-08-08 DNE MODIF ORIG
#                CLEMD3 += [F:SVF]DTANOT * [F:SIH]SNS * [F:SIH]RATMLT(0)
# 2016-08-08 DNE MODIF END
            Endif
        Next # [F:SVF]SVF0
# 2016-07-25 DNE MODIF BEGIN (SAM #117745)
        If TOTAMTNOTLIN = 0 # Check for 0-invoices.
            CLEMD3 = 0      # We cannot say anything about it. So "no" value.
        Else
            CLEMD3 *= [F:SID]AMTNOTLIN / TOTAMTNOTLIN
        Endif
# 2016-07-25 DNE MODIF ORIG
#        CLEMD3 *= [F:SID]AMTNOTLIN / TOTAMTNOTLIN
# 2016-07-25 DNE MODIF END
        Filter [F:SVF]

        # Write to database.
        Write [ARM]
        If fstat Then
           GOK = 0                               # Signal error and reject report printing.
           Break
        Endif
    Next

    # Do not continue if there was a database error before.
    If !GOK : Goto LEAVE : Endif

    # PART 2 - Customer invoices (GESBIC)
    #
    # Create DB select.
    #
    Link [F:SIL] With
&        [F:SIH]SIH0  ~= [F:SIL]NUM,
&        [F:CPY]CPY0  ~= [F:SIH]CPY,
&        [F:TCYC]TCY0 ~= [F:CPY]CRY,
&        [F:BPR]BPR0  ~= [F:SIH]BPR,
&        [F:TCYB]TCY0 ~= [F:BPR]CRY,
&        [F:GAC]GAC0   = [F:SIL]COA; [F:SIL]ACC
&   As [LNK2]
&   Where [F:SIH]STA = 3
&   and [F:CPY]CRY <> [F:BPR]CRY
&   and [F:TCYC]EECFLG = 2
&   and [F:TCYB]EECFLG = 2
&   and len( [F:BPR]EECNUM ) > 2
&   and evalue(CRITERIA)
&   Order By Key CLE = [F:SIL]NUM; [F:SIL]LIG

    # Common information for all AREPORTM records.
    Raz [F:ARM]
    [F:ARM]RPTCOD = REPORTCODE
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = NUMREQ                   # Selection ID in AREPORTM
    [F:ARM]CREDAT = date$

    # Collect data in the AREPORT table.
    #
    For [LNK2]CLE
        I= I + 1

# 2016-08-09 DNE INSERT
        # Get RATCUR (and be aware that RATMLT can be 0!).
        If [F:SIH]RATDIV(0) = 0
            RATCUR = [F:SIH]RATMLT(0)
        Else
            RATCUR = [F:SIH]RATMLT(0) / [F:SIH]RATDIV(0)
        Endif
# 2016-08-09 DNE INSERT

        [F:ARM]NUMLIG = I                        # Line number (e. g. for sorting)
        [F:ARM]CLEA1  = [F:SIL]NUM               # Invoice number
        [F:ARM]CLEN2  = [F:SIL]LIG               # Invoice line

        # Information needed for indicator calculation in the report.
        [F:ARM]CLEN3  = [F:GAC]ESDTRK

        # Line amount
# 2016-08-08 DNE MODIF BEGIN (SAM #117956)
        [F:ARM]CLEMD1 = [F:SIL]AMTNOTLIN * [F:SIH]SNS * RATCUR
# 2016-08-08 DNE MODIF ORIG
#        [F:ARM]CLEMD1 = [F:SIL]AMTNOTLIN * [F:SIH]SNS * [F:SIH]RATMLT(0)
# 2016-08-08 DNE MODIF END

        # Write to database.
        Write [ARM]
        If fstat Then
           GOK = 0                               # Signal error and reject report printing.
           Break
        Endif
    Next

    # Commit (or rollback) the transaction for AREPORTM.
    #
$LEAVE
    If GOK < 1 Then
        Rollback
    Else
        Commit
    Endif
End

