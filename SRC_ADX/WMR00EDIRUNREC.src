# Supervisor
## CRUD-CLASSE ## EDIRUNREC
# 2018-10-17 07:54:26 937

Gosub TEST From WMCR_EDIRUN : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,NUM)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EDIRUN : EDIRUN
# EDIRUND : EDIRUN EDIRUND
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EDIRUNREC._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EDIRUNREC.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EDIRUNREC.ACTX.AFOLDER,nomap,"")>0
 Local File EDIRUN [EDR]
 Local File EDIRUND [EDRD]
Else
 Local File =EDIRUNREC.ACTX.AFOLDER+".EDIRUN" [EDR]
 Local File =EDIRUNREC.ACTX.AFOLDER+".EDIRUND" [EDRD]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EDR] With
& [EDRD]EDRD0 = [F:EDR]NUM
& As [LNK_]
Return



