#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTIACH14      Utilitaire de récupération du bug 39270     Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   La modification de la date fin de validité d'une ligne article d'un  #
#      contrat n'était pas reportée sur la date de fin de validité de la #
#      dernière ligne de prix.                                           #
#   L'utilitaire a pour but de mettre à jour cette date fin de validité  #
#      de la dernière ligne de prix [F:POP]POPDAT si cette ligne de prix #
#      a été saisie manuellement [F:POP]POPCREFLG=1.                     #
##########################################################################

Call MAJ_UTIACH14
End

Subprog MAJ_UTIACH14
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH14 - Récup. Bug 39270") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH14 : Utilitaire réajustement dates fin validité ligne contrat") From LECFIC
  Call EXE_UTIACH14(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH14(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), CRITERE(100)
Local Char     CLE1(GLONPOH)
Local Integer COMPTEUR, STOP
Local Integer  NBENR, NBCOR, CLE2
Local Char     WPOHNUM(GLONPOH)
Local Integer  WPOPLIN
Local Integer  WPOPSEQ
#-----
Call ECR_TIME("UTIACH14 : Début traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:POC])  Local File =DOSSIER+".PORDERC"   [POC] : Endif
If !clalev([F:POP])  Local File =DOSSIER+".PORDERP"   [POP] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, NBENR, NBCOR, STOP
Raz WPOHNUM
#-----
$BOUCLE_POC
If STOP=1
  STOP=2 : CRITERE ='POHNUM="'+CLE1+'"'+' & POPLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE ='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POP]
  For [POC] POC0 Where evalue(CRITERE)
    NBENR+=1
    WPOHNUM=[F:POC]POHNUM
    WPOPLIN=[F:POC]POPLIN
    #-----
    Filter [POP] Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN
    Read [POP] POP0 Last
    If !fstat & [F:POP]POPCREFLG=1 & [F:POP]POPDAT<[F:POC]ENDDAT
      WPOPSEQ=[F:POP]POPSEQ
      COMPTEUR+=1
      Update [POP] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POPSEQ=WPOPSEQ
&                  With POPDAT=[F:POC]ENDDAT           
      If fstat
        Call ECR_TRACE("Update PORDERP"-WPOHNUM-num$(WPOPLIN)-num$(WPOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
       #If fstat=3  GOK=0 : Break : Endif : # Pour l'instant on continue en cas d'erreur !
      Else
        NBCOR+=1
        WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOPSEQ)-[F:POP]ITMREF
        WMSG+=space$(GLONITM-len([F:POP]ITMREF))
        WMSG+="Date fin validité :"-num$([F:POP]POPDAT)-"-->"-num$([F:POC]ENDDAT)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    #-----
    If COMPTEUR>GMAXUPDTRS
      CLE1=WPOHNUM : CLE2=WPOPLIN
      STOP=1 : Break
    Endif
  Next
  If GOK<1  Rollback : Goto FIN_UTIACH14 : Endif
Commit
If STOP  Goto BOUCLE_POC : Endif
#----- Fin du traitement -----#
$FIN_UTIACH14
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH14 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [POC], [POP]
End
