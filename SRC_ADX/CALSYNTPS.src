#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT" : TIT = mess(147,10709,1)
 When "EXEC"
  #43204
  Local Char MATRI(GLONEML), CTR(GLONHRCTR)
  Local Date DATMAT
  Local Date DATDEB,DATFIN
  Local Date WCTRD(0..8) # Verrouillé US 2022 65062
  Local Integer WI,WJ # Verrouillé US 2022 65062
  Local Date DATPAY2
  Raz DATDEB,DATFIN
  Gosub OUVRE From WPDEFTABLE
  MATRI  = PARAM(1)
  DATMAT = PARAM(2)
  CTR    = PARAM(3)
  Gosub LECEMP From WPDEFTABLE
  #64333 : Ajout func TPSDAT(MATRI,DATPAY,CTR)
  #Call MAJ(PARAM(1),PARAM(2),PARAM(3),1,0,0,1) From TRTSYN
  # FQ82073 - MABON 21/12/12 - Ajout paramètre CTRD
#  Call MAJ(PARAM(1),PARAM(2),PARAM(3),1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),PARAM(2),PARAM(3))) From TRTSYN
#  Call MAJ(PARAM(1),PARAM(2),PARAM(3),[0/0/0],1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),PARAM(2),PARAM(3),[0/0/0])) From TRTSYN
  # Fin MABON
  # Verrouillé US 2022 65062 plusieurs période d'activité du contrat possible
  # PARAM(4) à PARAM(12) = paramètres contenants [M:TIR3]SW1 à [M:TIR3]SW9 valeurs des périodes de la synthèse des temps
  WJ=0
  For WI = 4 To 12
    If dim(PARAM(WI))>0 & PARAM(WI)<> ""
      Call DECOMPVAL(PARAM(WI),[L]DATDEB,[L]DATFIN) From SUBTIR
      GMESSAGE=""
      If !find([L]DATDEB,[L]WCTRD(0..WJ)) : [L]WCTRD(WJ)=[L]DATDEB : WJ+=1 : Endif
    Endif
  Next
  # FQ98507 - 26/05/14 - Ajout paramètre sur appel de TRTSYN.MAJ
  # FQ91472 US2912 SEGAY call MAJ only once without CTRD
#  If [L]WCTRD(0) <> [0/0/0]
#    Local Date WCTRD2(0..8)
#    For WI = 0 To WJ-1
#      If [L]WCTRD(WI) <> [0/0/0]
#        # FQ91472 US2857/58 - SEGAY 02/09/14
#        [L]DATPAY2=DATMAT
#        Read[F:CTR]CTR0=MATRI;CTR;[L]WCTRD(WI)
#        If !fstat
#          Call TPSDATPAY(MATRI,CTR,[L]WCTRD(WI),[F:CTR]XITDAT,DATMAT,[F:CTR]ETRFCY,[L]DATPAY2) From TRTTPS
#        Endif
#        # FQ98507 - 26/05/14 - Si plusieurs périodes d'activité sur le même mois de paie, on écrasait la synthèse de la 1ère période lors du calcul de
#        # la seconde. Maintenant, on ne remet à 0 que sur le calcul de la 1ère période d'activité
##        Call MAJ(PARAM(1),[L]DATPAY2,PARAM(3),[L]WCTRD(WI),1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),[L]DATPAY2,PARAM(3),[L]WCTRD(WI)),WI) From TRTSYN
#        Local Integer FIRSTCTR : FIRSTCTR=0
#        If clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
#        Filter [F:VEP2] Where EMP=MATRI & PYRDAT=[L]DATPAY2 Order By CTRDAT
#        If rowcount([F:VEP2])>1 Then
#          Read [F:VEP2] First
#          If [F:VEP2]CTRDAT=[L]WCTRD(WI) Then
#            FIRSTCTR=0
#          Else
#            FIRSTCTR=1
#          Endif
#        Endif
#        Filter [F:VEP2]
#        Call MAJ(PARAM(1),[L]DATPAY2,PARAM(3),[L]WCTRD(WI),1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),[L]DATPAY2,PARAM(3),[L]WCTRD(WI)),FIRSTCTR,[L]WCTRD2) From TRTSYN
#      Endif
#    Next
#  Else
#    Call MAJ(PARAM(1),PARAM(2),PARAM(3),[0/0/0],1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),PARAM(2),PARAM(3),[0/0/0]),0,[L]WCTRD) From TRTSYN
#  Endif
#JASMI - 2017-02-09 - Issue 121325 - START
#  Call MAJ(PARAM(1),PARAM(2),PARAM(3),[0/0/0],1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),PARAM(2),PARAM(3),[0/0/0]),0,[L]WCTRD) From TRTSYN
  Call MAJ(PARAM(1),PARAM(2),PARAM(3),[0/0/0],1,0,0,1,func TRTTPS.TPSDAT(PARAM(1),PARAM(2),PARAM(3),[0/0/0]),0,[L]WCTRD,0) From TRTHRSYN
#JASMI - 2017-02-09 - Issue 121325 - END
  # END Verrouillé US 2022 65062
Endcase
Return

