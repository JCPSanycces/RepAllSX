#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DDEBSPA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EECNUMDEB
mkstat = 0
zoncou = "EECNUMDEB"
indice = 0
WNUM = [M]EECNUMDEB
If varmode([M]EECNUMDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EECNUMDEB" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]EECNUMDEB or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_EECNUMDEB([M]EECNUMDEB) From FUNDEBSPA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EECNUMDEB" : GZNUM = 13761 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 46657 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 46657 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 46657 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTCPYLEG"
    Call CONTCPYLEG([M]CPY,"SPA") From TRTX3
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 46657 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone DATINI
mkstat = 0
zoncou = "DATINI"
indice = 0
If varmode([M]DATINI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATINI" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATEND
mkstat = 0
zoncou = "DATEND"
indice = 0
If varmode([M]DATEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATEND" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call AP_DATEND([M]DATEND) From FUNDEBSPA
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DATEND" : GZNUM = 51412 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DDEBSPA"
Return

