#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# IMPLDS : Import/Export standards des pistes 2008                      #
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
# avec import/exports des textes sous formes clobs                      #
#########################################################################
$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub OUVRE
    When "IMPORT"        : Gosub IMPORT
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMP_TAB"       : Gosub IMP_TAB
    When "IMP_FERME"     : Gosub FERME
    #-----
    When "EXP_OUVRE"     : Gosub EXP_OUVRE  
    When "EXPORT"        : Gosub EXPORT 
    When "EXP_ZONE"      : Gosub EXP_ZONE
  Endcase
Return

##########################################################################################################
#                                  IMPORT                                #
##########################################################################
# Début de l'import/export #
#--------------------------#
$OUVRE
Local Char CORFIC (10)
Global Char GIMPLDS(10)

  GIMPLDS = ACTION
  CORFIC = "BPADDRESS"
  Gosub IMP_CORRESP From TRTX3IMP
Return

##########################################################################################################
#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Local Integer NOL

  Gosub IMP_DECLARE From TRTX3IMP
  Case IMPFIC
    When "LDS"
      If GREP = "C" Then
        [M:LDS5]PSTORITYP = 4
      Endif
    When "HD8"      
      #Affectation clob compte rendu
      [M:LDS5]CLOB = [F:HD8]CLOB
    When "AIN"
      [M:LDS3]ADD1 = [F:AIN]ADD(0)
      [M:LDS3]ADD2 = [F:AIN]ADD(1)
      [M:LDS3]ADD3 = [F:AIN]ADD(2)
    When "BPA"
      # Adresse
      #Default Mask [BPAL]
      #MAE/FGR, bg 71813
      Call NEW_TEL_EMAIL("[F:BPA]") From IMPBPC
      ICLEPRIM(0) = "[F:BPA]BPAADD"
      TPRIM(0) = "CODADR"
      NBASTAB = "NBADR"
      Gosub RECHERCHE_LIGNE From TRTX3IMP
      # C'est une nouvelle ligne
      If nolign = 0 Then
        NOL = [M]NBADR 
        [M]XNUMLIG = NOL
        nolign = NOL + 1
        [M]NBADR += 1
      Else
        [M]XNUMLIG = nolign - 1
      Endif
    When Default
  Endcase
Return

##########################################################################################################
#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Local Char IMPZONFIC(30)
Local Char IMPZONMSK(30)
Local Integer IINDICE
Local Integer IXZ

  IMPZONFIC = ""
  IMPZONMSK = ""
  IINDICE = 0
  Case IMPFIC
    When "BPA"
      # Adresse
      Gosub IMP_ZON_BPA From TRTX3IMP
    When Default
      #Case IMPZON
      #  When "FNC" 
      #    [M]FNC = num$([F:LDS]FNC)
      #Endcase
  Endcase
  #
  If IMPZONFIC <> "" and IMPZONMSK <> "" Then
    # On recherche si la zone est paramétrée
    If IINDICE <> 0 Then
      # Zone indicée 
      I = find(IMPFIC-IMPZONFIC+"("+num$(indice)+")",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
      If I <> 0 Then
        IMPZONFIC = IMPZONFIC + "("+num$(indice)+")"
      Endif
    Endif
    If IINDICE = 0 or (IINDICE = 1 and I = 0) Then
      # Zone non indicée ou zone indicée de 0 non trouvée 
      I = find(IMPFIC-IMPZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
    Endif
    If I <> 0 Then
      # On charge la classe [M]
      # Cas spécial : Ecran adresse contact et client livré                         #
      # Il faut passer systématiquement en AM_ pour charger le tableau invisible    #
      # même si la zone n'a pas changée                                             #
      If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) Then
        IMPMOD = 1
        Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
      Endif
    Else #MAE/FGR, BG 71813
      Gosub IMP_ZONE_TELMAIL From IMPBPC
    Endif
    OK = 0
  Endif
Return

##########################################################################################################
#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
  #Case IMPZON
  #  When ""     
  #Endcase
Return

##########################################################################################################
#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
  Kill GIMPLDS
Return

##########################################################################################################
#                                   EXPORT                               #
##########################################################################
#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
Return

##########################################################################################################
#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
  Case EXPFIC
    When "LDS"
    When "HD8"
    When "AIN"
    When "BPA"
  Endcase
Return

##########################################################################################################
#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return
