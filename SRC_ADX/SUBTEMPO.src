#<AdxTL>@(#)3.0.0.0 $Revision$
Call TEMPON("Test GA")

#########################################################################
# Affichage d'un message d'attente (selon TEMPON From GESECRAN)
#########################################################################
$ACTION
Case ACTION
 When "TITRE"      : Gosub TITRE_FEN
Endcase
Return

#########################################################################
$TITRE_FEN
TIT = "Veuillez patienter SVP ..."
Return

############################################################
Subprog TEMPON(LMSG)
Value Char LMSG()

Local Char    WINPROG(GLONADC) , SAVPROG(GLONADC)
Local Integer NOL, CPT
If GSERVEUR | GSILENCE
 End
Elsif GBROWS
 Infbox "$$TEMPON"
 End
Endif

NOL = nolign
SAVPROG    = GPROGRAMME

Call NOMTRTWIN("MSGTEMPO",WINPROG) From MSKDIV
GPROGRAMME = "SUBTEMPO"
Gosub OUVRE_BOITE From =WINPROG

If dim([M:TMP]MSG)>0
   [M:TMP]MSG= LMSG : Affzo [M:TMP]MSG
Endif

GTEMPON = 1
nolign = NOL
GPROGRAMME = SAVPROG

End
 
#################################################################
Subprog TEMPOFF 

If GSERVEUR | GSILENCE
 End
Elsif GBROWS
 GTEMPON = 0
 Infbox "$$TEMPOFF"
 End  
Elsif clalev([M:TMP])<=0
 End
Endif

Close Global Mask [TMP]    
GTEMPON = 0
End

######################################################################################
Subprog D_MSG(VALEUR)
Variable Char    VALEUR()
End
######################################################################################

