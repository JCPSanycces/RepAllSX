#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet TED
######################################################################################
## Etiquette ajoutée par le superviseur (Objet TED) 20/09/2011 15:40:47 (MAE)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "AFFMASK"     : Gosub AFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 #When "CHANGE"      : Call CHANGE_AXX ("TABCODEDT", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When "SEL_LISTE"   : Gosub SELTEDLEG
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "CHGCOD"      : Gosub CHGCOD
 When "FERME"       : Gosub FERME
 When "AS_CODEDT"   : Raz GCURLEG
 When Default
Endcase
Return

######################################################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

######################################################################
$LIENS
GCURLEG = [F:TED]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Return

######################################################################
$INICRE
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TED1]DESAXX,"TABCODEDT","DESAXX",[M:TED1]CODEDT,[M:TED1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TED1]SHOAXX,"TABCODEDT","SHOAXX",[M:TED1]CODEDT,[M:TED1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TED]LANDESSHO)>0
   [F:TED]LANDESSHO=GLANGUE+"~"+[M:TED1]DESAXX+"~"+[M:TED1]SHOAXX
Endif
Return
######################################################################
$AP_CHANGE
Call CHGTEXTRA("TABCODEDT","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABCODEDT","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return
######################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Return
######################################################################
$RAZCRE
Gosub GRILEG
Return

######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:TED1]LEG
  [M:TED1]LEG=GDOSLEG(1)
  Affzo [M:TED1]LEG
Endif
Return
######################################################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

# To manage the button Tunnel
If TUNNEL<>1 | dim(VCOD)<1 : Return : Endif
VCOD = CLE2
Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABCODEDT" & IDENT1=[F:TED]CODEDT & IDENT2=[F:TED]LEG
Return

######################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

##################################################
Subprog CONTTED(COD,LEG)
Value Char       COD()
Value Char    LEG()
Local Integer    CAS

If GFONCTION = "GESTED" | COD="" : End : Endif
If clalev([F:TED])=0 : Local File TABCODEDT [TED] : Endif
If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [TED]TED0=COD;LEG
 If fstat
  Read [TED]TED0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TED]TED0(1)=COD
 If !fstat
  LEG = [F:TED]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TED] Where CODEDT=COD
 Look [TED]TED0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TED]
 mkstat = 2 : End
Endif
If CAS=2
 Call CONTROLE("TED","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TED","","",COD,mkstat) From CONTOBJ
Endif
End

##################################################
## Tunnel Report

Subprog TUNTED(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONTED)
 TOKILL = 1
Endif

If clalev([F:TED])=0 : Local File TABCODEDT [TED] : Endif

# To update the TED code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG="" : # If LEG="" then firstly we search a TED record with LEG="" secondly a TED record with LEG<>""
 Read [TED]TED0 = VCOD;LEG
 If fstat
  Read [TED]TED0(1)=VCOD
  If !fstat
   LEG = [F:TED]LEG
  Endif
 Endif
Endif

Call LEC_TED(LEG,VCOD) From CPTLEC
If !fstat
 LEG = [F:TED]LEG
Else
 Raz VCOD,LEG
Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("TED",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE
If VCOD<>"" : COD = VCOD : Endif
If TOKILL : Kill VCOD : Endif
End
##################################################
$SELTEDLEG
If clalev([F:AXX])=0  :  Local File ATEXTRA [AXX] : Endif
If clalev([F:TED])=0  :  Local File TABCODEDT [TED] : Endif


Local Char TEX(50)(1..max(1,nbrecord([TED])))
Local Char TEXTE(30)(1..max(1,nbrecord([TED])),1..3) , TIT(30)(0..3)
NBTEX = 0

If PARAM(1)<>""

 Link [TED] With [AXX]AXX0="TABCODEDT";"DESAXX";GLANGUE;[F:TED]CODEDT;[F:TED]LEG
& As [LTED]
& Order By Key CLE = CODEDT Asc ; LEG Desc

 For [LTED]CLE(1) Where (LEG=PARAM(1)| LEG ="")
  NBTEX += 1
  TEX(NBTEX)     = [F:TED]CODEDT
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [AXX]TEXTE
  TEXTE(NBTEX,3) = string$([F:TED]LEG<>'',[F:TED]LEG)+string$([F:TED]LEG='',mess(91,187,1))
 Next
Else

 Link [TED] With [AXX]AXX0="TABCODEDT";"DESAXX";GLANGUE;[F:TED]CODEDT;[F:TED]LEG
& As [LTED]
& Order By Key CLE = CODEDT Asc ; LEG Asc

 For [LTED]CLE(1)
  NBTEX += 1
  TEX(NBTEX)    = [F:TED]CODEDT
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [AXX]TEXTE
  TEXTE(NBTEX,3) = string$([F:TED]LEG<>'',[F:TED]LEG)+string$([F:TED]LEG='',mess(91,187,1))

 Next
Endif

# Code Edition
Call TEXTE(10591,TIT(0)) From OBJDIV
# Mode de réglement
TIT(1) = TIT(0)
#Call TEXTE(10591,TIT(0)) From OBJDIV
# Intitulé
TIT(2) = mess(3,113,1)
# législation
TIT(3) = mess(218,107,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif

Return
##################################################
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

######################################################################################
# Etiquettes du masque TED1
######################################################################################
Subprog IB_CODEDT
If GFONCTION = "GESTED" : GBOUT1="" : End : Endif
End

