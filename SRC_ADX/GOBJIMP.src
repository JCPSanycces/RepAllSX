#<AdxTL>@(#)12.0.0.0 $Revision$

#####################################################################
## Listes
#####################################################################
$LISTE
OK = 1
ACTION = "AV_LISTE" : Gosub ACTION From GOBJSUB
If OK
 If [L]REPORT2<>""
  Gosub LISTE_CR
 Elsif dim([L]RQTGRP)>0
  Gosub LISTE_ALH
 Endif
Endif
Return

$LISTE_CR
Call IMPDEF([L]REPORT2,AREPORT,GFONCTION) From ETAT
If dim(GIMPETAT)>0 & GIMPETAT>0
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 Call WORKFLOW(2,ABREV,"I",IDENT) From AWRK
Endif
ACTION = "AP_LISTE" : Gosub ACTION From GOBJSUB
Return

$LISTE_ALH
Local Integer NEWREC
Call ACT_LISTE(ABREV,[L]RQTGRP,NEWREC)
ACTION = "AP_LISTE" : Gosub ACTION From GOBJSUB
If OK & NEWREC
 Gosub DEFAUT From =PROGOBJ
 If VERROU : Gosub DEVERROU From GOBJET : Endif
 Gosub AB_MODIF From GOBJSUB
 Assign "[G:"+ABFIC+"]currind" With INDCUR
 Assign "[G:"+ABFIC+"]currlen" With 0
 If TYPGES=3
  Gosub CRITTAB From GOBJET3
  Read First
 Else
  Read =
 Endif
 Gosub LECTURE From GOBJSUB
Endif
Return

Subprog ACT_LISTE(OBJET,RQT,NEWREC)
Value    Char    OBJET
Value    Char    RQT
Variable Integer NEWREC
Local Char PARAM(250)(1..7) , VALEUR(10) , SAVACT(10)
Local Char SAVREP1(20) , SAVREP2(20)
If RQT="" : PARAM(1) = GABREV : Else PARAM(1)=RQT : Endif
PARAM(2) = "1"    : # Chgt liste (1-Groupe requete, 0-Code requete)
PARAM(3) = "0"    : # Reprise du résultat précédent en priorité
PARAM(4) = ""     : # Critère sélection
PARAM(5) = ""     : # Critère sélection
PARAM(6) = ""     : # Option
PARAM(7) = ""     : # Titre
NEWREC = 0
SAVACT = GACTION
GACTION = "ALISTE2"
SAVREP1 = GREPORT1
SAVREP2 = GREPORT2
GREPORT1 = ""
GREPORT2 = ""
Call TRAITE_CHAR(VALEUR,PARAM,"ALISTE","SUBALH2","ALISTE",6,"SPEALH") From GTRAITE
GACTION = SAVACT
GREPORT1 = SAVREP1
GREPORT2 = SAVREP2
If VALEUR="#"
 NEWREC = 1
Endif
End

#####################################################################
## Impressions
#####################################################################
$IMPRIME
Case GPRODUIT
 When 1       : Gosub IMP_GEODE
 When Default : Gosub IMP_X3
Endcase
Return

$IMP_X3
OK = 1
ACTION = "AV_IMPRIME" : Gosub ACTION From GOBJSUB
If OK
 Call IMPCOMP([L]REPORT1,AREPORT,GFONCTION,OK,NBMASK,NOMMSK,ABMSK,AMA,TIT) From ETAT
 If [L]REPORT1<>"PRTSCR"
  ## Y-a-t-il des pièces jointes ?
  If OK=1 & GSTAIMG(2)=1 & (dim(GIMPPCEJOI)<0 | GIMPPCEJOI<>1) : # mb 18.4.2 bug 13949
   Call IMP_PCE_JOIN(ABREV,CLECUR1,CLECUR2)
  Endif
 Endif
 If dim(GIMPETAT)>0 & GIMPETAT>0
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"E",IDENT) From AWRK
 Endif
 ACTION = "AP_IMPRIME" : Gosub ACTION From GOBJSUB
Endif
Return

$IMP_GEODE
OK = 1
ACTION = "AV_IMPRIME" : Gosub ACTION From GOBJSUB
If OK
 Local Char ETAT(GLONARP)
 Call SAIETAT([L]REPORT1,[L]ETAT)
 ACTION = "IMPRIME" : Gosub ACTION From GOBJSUB
 If [L]ETAT<>""
  Call IMPCOMP([L]ETAT,AREPORT,GFONCTION,OK,NBMASK,NOMMSK,ABMSK,AMA,TIT) From ETAT
 Endif
 ## Y-a-t-il des pièces jointes ?
 If GSTAIMG(2)=1
  Call IMP_PCE_JOIN(ABREV,CLE1,CLE2)
 Endif
 ACTION = "AP_IMPRIME" : Gosub ACTION From GOBJSUB
Endif
Return

Subprog SAIETAT(RPTCOD,ETAT)
Value    Char RPTCOD
Variable Char ETAT
Local Char PARAM(20)(1..2) , VALEUR(10)
PARAM(1) = RPTCOD
If GPRODUIT=1 : PARAM(1+(RPTCOD<>"")) = "PRTSCR" : Endif : ## GEODE
Call S_LIS_CHAR(VALEUR,PARAM,"AIMP0","AIMP0","") From GACTION
ETAT = PARAM(1)
End

Subprog EDITION(ETAT)
Value Char ETAT()
Local Char TBPAR(20)(1..99)
Local Char TBVAL(30)(1..99)
Call ETATN(ETAT,GFONCTION,TBPAR,TBVAL) From ETAT
End

Subprog HCOPY(NBMASK,NOMMSK,ABMSK,AMA,TIT)
Value    Integer NBMASK
Variable Char    NOMMSK()(0..)
Variable Char    ABMSK()(0..)
Variable Integer AMA(0..)
Value    Char    TIT
Local Integer MA
Local Char    MSK(GLONAMK)(1..2) , ABR(GLONABR)(1..2)
If clalev([F:PSW]) = 0 :  Local File PRTSCRWRK [PSW] : Endif
For MA=1 To NBMASK
 If MA=1 & AMA(0)=1 : # AMA(0)<2
  MSK(1) = NOMMSK(0)  : ABR(1) = ABMSK(0)
  MSK(2) = NOMMSK(MA) : ABR(2) = ABMSK(MA)
  Call PRTSCR(MSK(1..2),ABR(1..2),TIT,0,0) From ATRTX3
 Else
  MSK(1) = NOMMSK(MA) : ABR(1) = ABMSK(MA)
  Call PRTSCR(MSK(1),ABR(1),TIT,0,0) From ATRTX3
 Endif
Next MA
Call IMPSCR From ATRTX3
End

Subprog IMP_PCE_JOIN(OBJET,CLE1,CLE2)
Value    Char OBJET
Value    Char CLE1
Value    Char CLE2()(1..)
Local Char PARAM(10)(1..2) , VALEUR(10) , CLEBIS(GLONID2) , CLECUR(80)(0..16)
If clalev([F:AOX])=0 : Local File AOBJTXT [AOX] : Endif
Local Mask AOBJTXT [AOX]
For I=1 To dim(CLE2)
 If I<=dim(CLECUR)
  CLECUR(I-1) = CLE2(I)
 Endif
Next I
Call SETCLE(OBJET,CLEBIS,CLECUR) From GOBJTXT
Gosub SET_PCE From GOBJTXT
Raz [M]
[M]ABREV = OBJET
[M]CBLOB  = CBLOB+OBJET
[M]IDENT1 = CLE1
[M]IDENT2 = CLEBIS
nolign = 0
For [AOX]AOX0 Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
  nolign += 1
  [M] = [F:AOX]
  [M]M1(nolign-1) = [F:AOX]MOTCLE(0)
  [M]M2(nolign-1) = [F:AOX]MOTCLE(1)
  [M]M3(nolign-1) = [F:AOX]MOTCLE(2)
  [M]M4(nolign-1) = [F:AOX]MOTCLE(3)
  [M]M5(nolign-1) = [F:AOX]MOTCLE(4)
Next
[M]NBLIG = nolign
If [M]NBLIG
 For nolign=1 To [M]NBLIG
  Call TRAITE_CHAR(VALEUR,PARAM,"","AIMPTXT","AIMPTXT",4,"XYAIMPTXT") From GTRAITE
 Next nolign
Endif
End
