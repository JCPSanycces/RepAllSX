#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque HBP1
##########################################################################################################
Subprog AS_NBHBP
If nolign - 1 >= dim([M:HBP1]TYPCLA) - 1
    End
Endif
If nolign > 0
    GSZHBPREC = [M:HBP1]NUM(nolign - 1)
    GSZHBPTYP = [M:HBP1]TYP(nolign - 1)
Endif
End

##########################################################################################################
Subprog C_NBHBP
If nolign - 1 >= dim([M:HBP1]TYPCLA) - 1
    End
Endif
If nolign > 0
    GSZHBPREC = [M:HBP1]NUM(nolign - 1)
    GSZHBPTYP = [M:HBP1]TYP(nolign - 1)
Endif
End

