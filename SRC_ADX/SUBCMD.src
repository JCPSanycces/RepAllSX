#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# SUBCMD : Transactions de saisie agenda support        CRM 13/02/04 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:HTR]HDKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base         #
# HDKAGD1
# HDKAGD2
# HDKAGD3
#                                                                     #
# Nom des écrans générés : WHxyyyz                                    #
#                            x = 1 pour parc client                   #
#                            x = 2 pour demandes                      #
#                            x = 3 pour interventions
#                            x = 4 pour plan de travail
#                            x = 5 pour agenda support
#                                                                     #
#                          yyy = nom de la transaction (HTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0, 1, 2, 3, 4 pour parc
#######################################################################
Call OBJET("CMD",GBIDC1,GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FILTRE"      : Gosub FILTRE
    When "EFFMASK"     : [M:CMD0]HTRTYP = 5
    When "SETBOUT"     : Gosub SETBOUT  
    When "EXEBOUT"     : Gosub EXEBOUT  
    When "LIENS"       : Gosub LIENS
    When "RAZCRE"      : Gosub RAZCRE
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "ANNULE"      : Gosub ANNULE
    When "AV_IMPRIME"  : Gosub COP_ECRAN
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return

##########################################################################################################
#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char APPLI
Local Integer IINIMODTRS   # FGR 29/01/2010 : X3SUIVI62022

  APPLI = nomap
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
#-------------------------------------------------------#
# Ne traiter que les transactions de type agenda support#
#-------------------------------------------------------#
$FILTRE
  FILTSUP = "[F:HTR]HTRTYP=5"
Return
  
##########################################################################################################
#----------------------------------------------#  
# Désactivation bouton "Validation" et "Copie" #  
#----------------------------------------------#  
$SETBOUT  
  If GREP<>"" or !CLECUR Then
    Call VIREBOUT(CHAINE,"12") From GOBJET
  Endif  
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return  

##########################################################################################################
#-------------------------------------#  
# Après appui sur bouton "Validation" #  
#-------------------------------------#  
$EXEBOUT  
  Case REP  
    When "1"
      Call DEBTRANS From GLOCK  
      Trbegin ADOVAL  
      Gosub TRT_ECRAN
      If GOK < 1 Then
        ROLLBACK
      Else
        Commit
      Endif
    When Default  
  Endcase  
Return  

##########################################################################################################
#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
  Gosub LOADDATA From SUBCMDB
Return

##########################################################################################################
#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
  [M:CMD0]HTRTYP = 5
  [M:CMD0]ENAFLG = 2
  Gosub ONGLETS_INIT From SUBCMDB
  Gosub COLFIX_INIT From SUBCMDB
  Gosub CHAMPS_INIT From SUBCMDB
  Gosub VALINITIAL_INIT From SUBCMDB
  Gosub PE_HDKTRS From SUBHDKTRS
  Gosub REORGANISE From SUBCMDB
  Gosub AFF_FENETRE From SUBCMDB
Return

##########################################################################################################
#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
  Case COUZON
    When Default
      Gosub PE_HDKTRS From SUBHDKTRS
  Endcase
Return

##########################################################################################################
#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
  Raz [F:HTV]
  Gosub CHARGE_ATEXTRA 
  Gosub ONGLETS_ENREG From SUBCMDB
  Gosub COLFIX_ENREG From SUBCMDB
  Gosub CHAMPS_ENREG From SUBCMDB
  Gosub VALINITIAL_ENREG From SUBCMDB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$CREATION
  [F:HTV] = [F:HTR]
  Gosub PE_HDKTRS From SUBHDKTRS
  Write [HTV]
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE = mess(521,177,1)
    Return
  Endif
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_CRE
  Gosub REORGANISE From SUBCMDB
  Gosub AFF_FENETRE From SUBCMDB
Return

##########################################################################################################
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
  Gosub CHARGE_ATEXTRA
  IINIMODTRS = 0  # FGR 28/01/2010 : X3SUIVI62022
  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    # FGR 28/01/2010 : X3SUIVI62022 (début)
    IINIMODTRS = 1
    #GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    #GERR = 2
    #Erreur lors de la lecture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    #GMESSAGE = mess(521,177,1)
    #Return
    # FGR 28/01/2010 : X3SUIVI62022 (fin)
  Endif
  Gosub ONGLETS_ENREG From SUBCMDB
  Gosub COLFIX_ENREG From SUBCMDB
  Gosub CHAMPS_ENREG From SUBCMDB
  Gosub VALINITIAL_ENREG From SUBCMDB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$MODIF
  [F:HTV] = [F:HTR]
  Gosub PE_HDKTRS From SUBHDKTRS
  If IINIMODTRS = 0 Then
    Rewrite [HTV]
  Else
    Write [HTV]
  Endif
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE = mess(521,177,1)
    Return
  Endif
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_MOD
  Gosub REORGANISE From SUBCMDB
  Gosub AFF_FENETRE From SUBCMDB
Return

##########################################################################################################
$ANNULE
  Delete [AXX] Where CODFIC="HDKTRS" and IDENT1=num$([F:HTR]HTRTYP) and IDENT2=[F:HTR]HTRNUM
  Gosub TRT_ECRAN
  Delete [HTV] Where [F:HTV]HTRTYP=[F:HTR]HTRTYP and [F:HTV]HTRNUM=[F:HTR]HTRNUM
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de la suppression dans la  table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE = mess(523,177,1)
    Return
  Endif
Return

##########################################################################################################
#----------------------------------------#
# Création ou modif de texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA 
  Call MAJTEXTRA([M:CMD0]DESAXX,"HDKTRS","DESAXX",num$([M:CMD0]HTRTYP),[M:CMD0]HTRNUM) From ATEXTRA
  [F:HTR]HTRDES = GLANGUE + "~" + [M:CMD0]DESAXX
  [F:HTR]HTRTYPCAR = num$([F:HTR]HTRTYP)
Return

##########################################################################################################
#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
  Gosub INIT_VARIABLES From CRMTRSUTI
  #---------------- Noms fenêtres et traitement -----------------#
Local Char     WINREF(GLONFEN) : WINREF = "OHDA"
Local Char     NOMWIN(GLONFEN) : NOMWIN = "WOHDA" + [M:CMD0]HTRNUM
Local Char     NOMTRT(GLONADC) : NOMTRT = "WGOHDA" + [M:CMD0]HTRNUM
  #------------------------- Entete --------------------------#
  MFROM = "HDKAGD0"
  MTO = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "0"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Demandes de service --------------------------#
  MFROM = "HDKAGD1"
  MTO = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "1"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Intervention --------------------------#
  MFROM = "HDKAGD2"
  MTO = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "2"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Information --------------------------#
  MFROM = "HDKAGD3"
  MTO = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "3"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  If ACTION = "ANNULE" Then
    Gosub TRT_SUP_FEN
  Else
    Gosub TRT_GEN_FEN
  Endif
Return

##########################################################################################################
#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
  Call DELWIN(NOMWIN,APPLI) From MSKDIV
Return

##########################################################################################################
#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
  If clalev([F:AOB])=0 Local File =APPLI+".AOBJET"  [AOB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNHDKTRS
  #----- Suppression fenêtre si transaction non active -----#
  If [M:CMD0]ENAFLG = 1 Then
    Gosub TRT_SUP_FEN
    Return
  Endif
  #----- Génération fenêtre si transaction active -----#
  Delete [AWI] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINDOW" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0 
    Call RSTA ("AWI",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINPAR" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0 
    Call RSTA ("AWP",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBRO" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWB",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBOUT" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWT",NOMWIN) From GLOCK
    Return
  Endif
  Read [AWI]AWI0=WINREF
  If fstat <> 0 Then
    GOK = 0
    Return
  Endif
  #Entête
  WNOMMSK = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "0"
  [F:AWI]WIN = NOMWIN
  [F:AWI]MSKENT = WNOMMSK
  #Demandes de service
  WMSKREF = "HDKAGD1" 
  WNOMMSK = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "1"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 0
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Interventions
  WMSKREF = "HDKAGD2" 
  WNOMMSK = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "2"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 1
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Informations
  WMSKREF = "HDKAGD3" 
  WNOMMSK = "WH" + num$([M:CMD0]HTRTYP) + [M:CMD0]HTRNUM + "3"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #
  [F:AWI]ENAFLG = 2
  [F:AWI]ACS = [M:CMD0]ACSCOD
  If dim([F:AWI]LIBEL) > 0 Then
    [F:AWI]LIBEL = ""
  Endif
  [F:AWI]TRN = ""
  [F:AWI]WINTYP = 1
  [F:AWI]OBJ = ""
  Write [AWI]
  If fstat Then
    GOK = 0
    Call FSTA("AWI") From GLOCK
    Return
  Endif
  For [AWP] AWP0 Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat Then
      GOK = 0
      Call FSTA("AWP") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  For [AWB] AWB0 Where WIN=WINREF
    [F:AWB]WIN = NOMWIN
    Write [AWB]
    If fstat Then
      GOK = 0
      Call FSTA("AWB") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  For [AWT] AWT0 Where WIN=WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat Then
      GOK = 0
      Call FSTA("AWT") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
  If !OK Then
    GOK = 0
  Endif
Return

##########################################################################################################
Subprog AS_HTRNUM(VALEUR)
Variable Char    VALEUR()

  #-----------------------#
  # Avant saisie document #
  #-----------------------#
  [M:CMD0]HTRTYP = 5
End

##########################################################################################################
Subprog AM_ONGLETACT(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  If VALEUR <> "" Then
    Call GETLIB_ONGLET("FHDKAGD", VALEUR, SZLIBELLE,SZMESSAGE, IBRETOUR) From CRMTRSUTI
    If IBRETOUR = 0 Then
      SZLIBELLE = ""
      mkstat = 2
      GMESSAGE = SZMESSAGE
    Endif
  Else
    SZLIBELLE = ""
  Endif
  [M:CMD4]LIBONGLET = SZLIBELLE
  Affzo [M:CMD4]LIBONGLET
End

##########################################################################################################
Subprog B3_SREFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE = 1
    If ILIGNE > dim([M:CMD1]SREFIEPOS) Then
      IBCONTINUE = 0
      Break
    Endif
    If [M:CMD1]SREFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CMD1]SREFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CMD1]SREFIEPOS(ILIGNE)
    ILIGNE += 1
    INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

##########################################################################################################
Subprog B3_ITNFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE=1
    If ILIGNE > dim([M:CMD2]ITNFIEPOS) Then
      IBCONTINUE = 0
      Break
    Endif
    If [M:CMD2]ITNFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CMD2]ITNFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CMD2]ITNFIEPOS(ILIGNE)
    ILIGNE += 1
     INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

##########################################################################################################
Subprog B3_INFFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE=1
    If ILIGNE > dim([M:CMD3]INFFIEPOS) Then
      IBCONTINUE = 0
      Break
    Endif
    If [M:CMD3]INFFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CMD3]INFFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CMD3]INFFIEPOS(ILIGNE)
    ILIGNE += 1
    INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

######################################################################################
##########################################################################################################
#-------------------------------------#
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2) 
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(4)
Local Char WABR(GLONABR)(2)

  #-----
  Call TEXTFIC("HDKTRS","HTRNUM",2,WINT(0)) From OBJDIV
  Call TEXTFIC("HDKTRS","ACSCOD",2,WINT(1)) From OBJDIV
  WTIT = WINT(0)+" : "+[M:CMD0]HTRNUM-[M:CMD0]DESAXX-WINT(1)+" : "+[M:CMD0]ACSCOD
  WMSK(0) = "CMD4"
  WMSK(1) = "CMD1"
  WMSK(2) = "CMD2"
  WMSK(3) = "CMD4"
  Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
  OK = 0 : # Pour ne pas imprimer tout de suite !
Return

##########################################################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif

Local Integer TYP

  TYP = 5
  Gosub GENPATCH From FUNHDKTRS
End

##########################################################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI

Local Integer TYP

  TYP = 5
  Gosub GENDOS From FUNHDKTRS
End

##########################################################################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE
Local Integer TYP
Local Char CODTAB(GLONTRS)

  MODULE = 12
  TYP = 5
  CODTAB = TABLE
  #-----
  Gosub OUVRE_COPTRS From SELTRS
  Gosub EXEC_COPTRS  From SELTRS
  Gosub FERME_COPTRS From SELTRS
Return
