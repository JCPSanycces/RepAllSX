#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR11 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLGEXCPEN
mkstat = 0
zoncou = "FLGEXCPEN"
indice = 0
IMPENT = [M]FLGEXCPEN
WNUM = IMPENT
If varinit([M]FLGEXCPEN,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGEXCPEN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FLGEXCPEN(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]FLGEXCPEN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGEXCPEN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGEXCPEN(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_FLGEXCPEN(IMPENT) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FLGEXCPEN" : GZNUM = 55208 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]FLGEXCPEN = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRPEN"
If !mkstat
 NBLIG = [M]NBRPEN
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRPEN = nolign
  status = 75
  Call SAI_NBRPEN(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone WPEN
mkstat = 0
zoncou = "WPEN"
indice = 0
If varinit([M]WPEN,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WPEN,"410","") From SUBADI
 GACTION = SAVACT
Endif

## Zone WSTRDATPEN
mkstat = 0
zoncou = "WSTRDATPEN"
indice = 0
If varmode([M]WSTRDATPEN,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]WSTRDATPEN) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WSTRDATPEN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WSTRDATPEN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WENDDATPEN
mkstat = 0
zoncou = "WENDDATPEN"
indice = 0
If varmode([M]WENDDATPEN,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]WENDDATPEN) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WENDDATPEN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WENDDATPEN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WPRVORG
mkstat = 0
zoncou = "WPRVORG"
indice = 0
WCHAR = [M]WPRVORG
If varmode([M]WPRVORG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WPRVORG([M]WPRVORG) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WPRVORG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPRVORG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]WPRVORG or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WPRVORG([M]WPRVORG) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WPRVORG" : GZNUM = 55019 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone WPRVCOL
mkstat = 0
zoncou = "WPRVCOL"
indice = 0
WCHAR = [M]WPRVCOL
If varmode([M]WPRVCOL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WPRVCOL([M]WPRVCOL) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WPRVCOL : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPRVCOL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]WPRVCOL or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WPRVCOL([M]WPRVCOL) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WPRVCOL" : GZNUM = 55021 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone WPRVIND
mkstat = 0
zoncou = "WPRVIND"
indice = 0
WCHAR = [M]WPRVIND
If varmode([M]WPRVIND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WPRVIND([M]WPRVIND) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WPRVIND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPRVIND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]WPRVIND or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WPRVIND([M]WPRVIND) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WPRVIND" : GZNUM = 55023 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone WCOMMENT
mkstat = 0
zoncou = "WCOMMENT"
indice = 0
WCHAR = [M]WCOMMENT
If varmode([M]WCOMMENT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WCOMMENT([M]WCOMMENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WCOMMENT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WCOMMENT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]WCOMMENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WCOMMENT([M]WCOMMENT) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WCOMMENT" : GZNUM = 1677 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRPEN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1


## Zone PEN
mkstat = 0
zoncou = "PEN"
WCHAR = [M]PEN(indice)
If varinit([M]PEN,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PEN(indice),"410","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PEN,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PEN" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]PEN(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]PEN(indice),"410","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]PEN(indice),"410",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]PEN(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_PEN([M]PEN(indice)) From SUBCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone STRDATPEN
mkstat = 0
zoncou = "STRDATPEN"
WDATE = [M]STRDATPEN(indice)
If varinit([M]STRDATPEN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call D_STRDATPEN([M]STRDATPEN(indice)) From SUBCTR
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]STRDATPEN,indice)=0
  SAVACT = GACTION : GACTION = "SUBCTRLEG"
  Call BEFORE_ENTRY([M]STRDATPEN(indice)) From SUBCTRLEG
  GACTION = SAVACT
  If mkstat=1 : Raz [M]STRDATPEN(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "STRDATPEN" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If [M]STRDATPEN(indice)=[0/0/0]
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_STRDATPEN([M]STRDATPEN(indice)) From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WDATE<>[M]STRDATPEN(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_STRDATPEN([M]STRDATPEN(indice)) From SUBCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ENDDATPEN
mkstat = 0
zoncou = "ENDDATPEN"
WDATE = [M]ENDDATPEN(indice)
If varmode([M]ENDDATPEN,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]ENDDATPEN(indice)) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ENDDATPEN(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDATPEN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLDATV"
  Call CTLDATV([M]ENDDATPEN(indice),[M:CTRB]STRDATPEN(nolign-1)) From CONTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_ENDDATPEN([M]ENDDATPEN(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WDATE<>[M]ENDDATPEN(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_ENDDATPEN([M]ENDDATPEN(indice)) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LIBPEN
mkstat = 0
zoncou = "LIBPEN"
SAVACT = GACTION : GACTION = "STD"
Call AV_LIBPEN([M]LIBPEN(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]LIBPEN(indice) : Endif


End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR11"
Return

