####################################################################
# 31 : PROTEARNAMT Protected earnings ( Field DCB 13)
####################################################################

$SET_PROTEARNAMT
If [L]_AOLDVAL<>this.PROTEARNAMT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PROTEARNAMT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PROTEARNAMT
 Gosub PROPAGATE_PROTEARNAMT
Endif
Return

$INIT_PROTEARNAMT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PROTEARNAMT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PROTEARNAMT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PROTEARNAMT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PROTEARNAMT           : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PROTEARNAMT           : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PROTEARNAMT
[L]CURPRO = "PROTEARNAMT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.PROTEARNAMT=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PROTEARNAMT
[L]CURPRO = "PROTEARNAMT"
Return

$_AOTHERS_PROTEARNAMT
[L]CURPRO = "PROTEARNAMT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PROTEARNAMT
[L]CURPRO = "PROTEARNAMT"
Return

$PROPAGATE_PROTEARNAMT
this.isReadonly = 0
[L]CURPRO = "PROTEARNAMT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PROTEARNAMT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PROTEARNAMT"
$_LNKPRO_PROTEARNAMT
Return


