#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AV_CHOIX" : Gosub AV_CHOIX
  When "OK"       : Gosub OK
Endcase
Return

$OK
#copy start and end balance to entry batch
Local Decimal PROBAL
Local Decimal PRODIF
Actzo [M:PAY4]4
[M:PAY4]STRBAL = [M:BPAY1]STRBAL
[M:PAY4]ENDBAL = [M:BPAY1]ENDBAL
[M:PAY4]BANCUR = [M:BPAY1]BALCUR1
If [M:PAY4]TOTLOC <> 0
  Local Decimal ATLOC : ATLOC = [M:PAY4]TOTLOC
  PROBAL = [M:PAY4]STRBAL + ATLOC
  PRODIF = [M:PAY4]ENDBAL - PROBAL
  [M:PAY4]PROBAL = PROBAL
  [M:PAY4]PRODIF = PRODIF
Endif
Affzo [M:PAY4]

Return

$AV_CHOIX
# Load bank currency in currency fields
If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
Read [BAN]BAN0 = [M:PAY1]BAN
[M:BPAY1]BALCUR1 = [BAN]CUR
[M:BPAY1]BALCUR2 = [BAN]CUR
[M:BPAY1]STRBAL = [M:PAY4]STRBAL
[M:BPAY1]ENDBAL = [M:PAY4]ENDBAL
Affzo [M:BPAY1]
Return
