#<AdxTL>@(#)8.0.0.0 $Revision$
##################################################################################
#   Import d'un objet de type tableau
##################################################################################

#CHECK UNUSED_BEGIN

$CHARGEMSK
If GPRODUIT=1 & [M:IMP2]TYPENV : ## GEODE GX
 If [M:IMP2]TABCUR=1 : Return : Endif
 Gosub SETCLE
 GNBIMP+=1
 If GTRACE<>"" & [M:IMP2]TABCUR>0
  Call ECR_TRACE(string$(20,"-")-mess(198,124,1)-num$(GNBIMP)-"("+mess(61,100,1)-num$(NBENR)+")",0) From GESECRAN
 Endif
 Case [M:IMP2]TYPENV
  When 1
   Read [FCY]FCY0 = GFCY
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(1,310,1)-GFCY) From SUBIMPOBJ : # Site
   Endif
  When 2
   Read [DEP]DEP0 = GFCY;GDEP
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(2,310,1)-GFCY-GDEP) From SUBIMPOBJ : # Déposant
   Endif
 Endcase
 If !OK : Return : Endif
Else
 GCLE = NOMFIC
Endif
Gosub VERROU
If !OK : Return : Endif
[F:AAA_] = [F]
[G]currind = 1
Gosub CRITTAB
Filter [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(CRITTAB)
MA = 1 : IMA = 1
Gosub SETMASK From =WINPROG
Raz [M]
ACTION = "LIENS0"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_LIENS0" : Gosub ACTION  From SUBIMPOBJ
nolign = 0
For [F]
 nolign += 1
 If nolign>MAXLIG
  MAXLIG*=-1 : Break
 Endif
 Gosub CHARGEMSK From =WINPROG
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
Next
Assign "[M]"+BASPAG With nolign
If MAXLIG<0
 MAXLIG*=-1
 Call TRACE2(2,GCLE-mess(26,100,1),-1) From SUBIMPOBJ : # Tableau plein
 OK=0 : Return
Endif
ACTION = "LIENS2"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_LIENS2" : Gosub ACTION  From SUBIMPOBJ
Filter [F]
CLECUR = 1
CHAINE = "M"
ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
If instr(1,CHAINE,"M") & ([M:AOE1]OPTUPD=2 | GPRODUIT=1)
 GREP = "M" : REP = "M"
Elsif instr(1,CHAINE,"M")
 Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
 GREP = "" : REP =""
Else
 OK = 0 : Call TRACE2(2,GCLE-mess(9,123,1),-1) From SUBIMPOBJ : # Modification impossible
 GREP = "" : REP = ""
Endif
[F] = [F:AAA_]
Return

$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
If !OK : Return : Endif
SYMBOLE = GCLE
Lock =SYMBOLE With lockwait = 0
If fstat
 Call TRACE2(2,GCLE-mess(61,141,1),-1) From SUBIMPOBJ : # Fiche en cours de modification
 OK = 0 : Return
Endif
Gosub DEFAUT From =PROGOBJ
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
Unlock =SYMBOLE
Return

$SETCLE
GCLE = NOMFIC
If dim([L]CLEFCY)>0 & [L]CLEPRIM=[L]CLEFCY
 GCLE += "\"+[V]GFCY
Elsif dim([L]CLEDEP)>0 & [L]CLEPRIM=[L]CLEDEP
 GCLE += "\"+[V]GDEP
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>"" & evalue("dim([M:"+ABMSK(1)+"]"+CLESEC(CL)+")")<2
  If dim([L]CLEFCY)>0 & CLESEC(CL)=[L]CLEFCY
   GCLE += "\"+[V]GFCY
  Elsif dim([L]CLEFCY)>0 & CLESEC(CL)=[L]CLEDEP
   GCLE += "\"+[V]GDEP
  Elsif dim([L]CLEVALEUR)<0 | CLESEC(CL)<>[L]CLEVALEUR
   GCLE += "\"+num$(evalue("[F]"+CLESEC(CL)))
  Endif
 Endif
Next CL
Return

$CHARGE_LIG
Local Integer ILIG , NBLIG2 , LIG2 , OKLIG
NBLIG2 = evalue("[M]"+BASPAG)
LIG2  = 0
For ILIG=1 To NBLIG2
 If dim([L]CLEVALEUR)>0
  If evalue("[F]"+CLEVALEUR)=evalue("[M]"+CLEVALEUR+"("+num$(ILIG-1)+")")
   OKLIG = 1
   For CL=0 To dim(CLESUPP)-1
    If CLESUPP(CL)<>"" & evalue("dim([M]"+CLESUPP(CL)+")")>=ILIG
     If evalue("[F]"+CLESUPP(CL))<>evalue("[M]"+CLESUPP(CL)+"("+num$(ILIG-1)+")")
      OKLIG = 0 : Break
     Endif
    Endif
   Next CL
  Endif
 Else
  If evalue("[F]"+CLEPRIM)=evalue("[M]"+CLEPRIM+"("+num$(ILIG-1)+")")
   OKLIG = 1
   For CL=0 To dim(CLESEC)-1
    If CLESEC(CL)<>"" & evalue("dim([M]"+CLESEC(CL)+")")>=ILIG
     If evalue("[F]"+CLESEC(CL))<>evalue("[M]"+CLESEC(CL)+"("+num$(ILIG-1)+")")
      OKLIG = 0 : Break
     Endif
    Endif
   Next CL
  Endif
 Endif
 If OKLIG
  LIG2 = ILIG : Break
 Endif
Next ILIG
If GPRODUIT=1 & ((LIG2<>0 & [M:AOE1]OPTUPD<>2) | (LIG2=0 & dim([M:AOE1]OPTCRE)>0 & [M:AOE1]OPTCRE<>2))
 Gosub SETMSG
 Call TRACE2(-2,GCLE-GMESSAGE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
 GMESSAGE="" : nolign=0
Elsif LIG2<>0
 nolign = LIG2
 status = 75
 NBMOD += 1
Elsif NBLIG2+1>MAXLIG
 Gosub SETMSG
 Call TRACE2(-2,GCLE-GMESSAGE-mess(26,100,1),-1) From SUBIMPOBJ : # Tableau plein
 GMESSAGE="" : nolign=0
Else
 NBLIG2 += 1
 nolign = NBLIG2
 status = 82
 NBCRE += 1
Endif
Assign "[M]"+BASPAG With NBLIG2
Return

$SETMSG
If dim([L]CLEVALEUR)>0
 GMESSAGE=num$(evalue("[F]"+CLEVALEUR))
 For CL=0 To dim(CLESUPP)-1
  If CLESUPP(CL)<>"" : GMESSAGE+="\"+num$(evalue("[F]"+CLESUPP(CL))) : Endif
 Next CL
Else
 GMESSAGE=num$(evalue("[F]"+CLEPRIM))
 For CL=0 To dim(CLESEC)-1
  If CLESEC(CL)<>"" : GMESSAGE+="\"+num$(evalue("[F]"+CLESEC(CL))) : Endif
 Next CL
Endif
Return

$VALID
If NBCRE=0 & NBMOD=0 : Return : Endif
ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : GREP = "" : NBCRE=0 : NBMOD=0 : Return : Endif
ACTION = "IMP_VERIF_MOD" : Gosub ACTION  From SUBIMPOBJ
If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
If !OK : GREP = "" : NBCRE=0 : NBMOD=0 : Return : Endif
Gosub TR3
If GOK<1
 Call TRACE2(2,mess(101,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur modification
Else
 ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_APRES_MOD" : Gosub ACTION  From SUBIMPOBJ
 Call TRACE2(1,GCLE,-1) From SUBIMPOBJ
 If GPRODUIT=1 & GTRACE<>"" & [M:IMP2]TYPENV
  If NBCRE
   Call ECR_TRACE(num$(NBCRE)-mess(103,141,1),0) From GESECRAN : # Enregistrements créés
  Endif
  If NBMOD
   Call ECR_TRACE(num$(NBMOD)-mess(104,141,1),0) From GESECRAN : # Enregistrements modifiés
  Endif
 Endif
 Gosub SET_CLE2 From GOBJSUB
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 If (dim([M:AOE1]ENAWRK)<0 | [M:AOE1]ENAWRK=2)
  Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
If GPRODUIT=1 & [M:IMP2]TYPENV
 NBCRE=0 : NBMOD=0
Endif
Return

$TR3
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Lock [F]
 If fstat
  GOK=-1 : GLOCK="$"+NOMFIC : Goto ROLL_TR3
 Endif
 OK = 1
 ACTION = "MOD_IMPORT" : Gosub ACTION From SUBIMPOBJ
 If OK
  Gosub CRITTAB
  Delete [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(CRITTAB)
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA(ABFIC,"*") From GLOCK : Goto AB_TR3
  Endif
  For nolign=1 To evalue("[M]"+BASPAG)
   Raz [F]
   [F] = [M]
   Gosub INICRE From GOBJSUB
   If GOK<1 : Break : Endif
   Gosub INIEXP From SUBIMPOBJ
   ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
   ACTION = "IMP_INICRE" : Gosub ACTION  From SUBIMPOBJ
   Write
   If fstat
    GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
   Endif
   ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
   If GOK<1 : Break : Endif
   ACTION = "IMP_CREATION" : Gosub ACTION  From SUBIMPOBJ
   If GOK<1 : Break : Endif
  Next nolign
  If    GOK<0 : Goto ROLL_TR3
  Elsif GOK=0 : Goto AB_TR3
  Endif
  ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
  If GOK<0   : Goto ROLL_TR3
  Elsif !GOK : Goto AB_TR3
  Endif
  ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
  If GOK<0   : Goto ROLL_TR3
  Elsif !GOK : Goto AB_TR3
  Endif
 Endif
Commit
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GLOCK : Return : Else : Goto TR3 : Endif

$AB_TR3
Rollback
Return

$CRITTAB
CRITTAB = ""
If CLESEC<>"" & CLE2<>"" & (dim([L]CLEVALEUR)<0 | !find(CLESEC,CLEFCY,CLEDEP))
 If TPCLE2=1
  CRITTAB = CLESEC+"='"+CLE2+"'"
 Else
  CRITTAB = CLESEC+"="+CLE2
 Endif
Endif
If CRITTAB="" : CRITTAB="1=1" : Endif
Raz CRITERE, ICRITERE, FILTSUP
ACTION = "FILTRE" : Gosub ACTIONG From SUBIMPOBJ
If FILTSUP="" : FILTSUP="1=1" : Endif
If CRITERE="" : CRITERE="1=1" : Endif
Return

#CHECK UNUSED_END
