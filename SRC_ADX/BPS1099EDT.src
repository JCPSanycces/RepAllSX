#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
#    Process Name:    BPS1099EDT - Edit Supplier 1099 Payments
#
######################################################################################
$ACTION

Case ACTION

  When "OUVRE"          : Gosub OUVRE
  When "DEBUT"          : Gosub DEBUT

  When "SETBOUT"        : Gosub SETBOUT

  When "APRES_MODIF"    : Gosub APRES_MODIF

  When "ENR"            : Gosub SAVE

  When "AB2_NBLIG"      : Gosub AB2_NBLIG
  When "ABA"            : Gosub ABA

Endcase

Return
######################################################################################
$OUVRE

If clalev([F:B9P])=0  : Local File BPS1099PAY   [B9P]  : Endif
If clalev([F:B9P2])=0 : Local File BPS1099PAY   [B9P2] : Endif
If clalev([F:B9P3])=0 : Local File BPS1099PAY   [B9P3] : Endif

If clalev([F:BX9])=0 : Local File BOX1099       [BX9] : Endif
If clalev([F:B9B])=0 : Local File BP1099BEGBAL  [B9B] : Endif

If clalev([F:BPS])=0 : Local File BPSUPPLIER    [BPS] : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH      [PYH] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD      [PYD] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE      [PIH] : Endif
If clalev([F:PID])=0 : Local File PINVOICED     [PID] : Endif
If clalev([F:B9G])=0 : Local File BPS1099GEN    [B9G] : Endif
If clalev([F:CPY])=0 : Local File COMPANY       [CPY] : Endif

Local Integer KOUNT, NOL, NOSEARCH

Return
######################################################################################
$DEBUT

[M:B9E1]YR1099  = val(PARAM(1))
[M:B9E1]CPY     = PARAM(2)
[M:B9E1]BPSNUM  = PARAM(3)
[M:B9E1]TFRM1099  = val(PARAM(4))
[M:B9E1]TBOX1099  = PARAM(5)


Read [F:B9B]B9B1=[M:B9E1]YR1099;[M:B9E1]CPY;[M:B9E1]BPSNUM;[M:B9E1]TFRM1099;[M:B9E1]TBOX1099
If fstat = 0
    [M:B9E1]BEGBAL = [F:B9B]BEGBAL
Else
    [M:B9E1]BEGBAL = 0
Endif
Read [CPY]CPY0=[M:B9S1]THECPY
 If !fstat
  [M:B9E1]CURLED    = [F:CPY]ACCCUR
 Else
  Raz [CPY]
 Endif

Gosub SEARCH_DISPLAY
Grizo [M:B9E1]YR1099, CPY, BPSNUM

Return
######################################################################################
$SETBOUT

# Activate the Save button if we are in Edit mode
If REP="M"
    ETABOU(GENRE) = 1
Endif

Return
######################################################################################
$APRES_MODIF

Case COUZON

    When "FRM1099", "BOX1099", "AMT1099"

        [M:B9E1]UPDFLG(nolign-1) = 1
        REP = "M"

Endcase

Return

######################################################################################
$SAVE

Local Integer XOK #105013.n
Look [F:B9G]B9G1 = [M:B9E1]YR1099;[M:B9E1]CPY;[M:B9E1]BPSNUM
If [S]fstat <=2 # Generate record exists
  Call OUINON(mess(81,122,1),XOK) From GESECRAN # Warning message prompt
  If XOK<>2
    GERR=1
    OK=0
    Return
  Endif
Endif

Call DEBTRANS From GLOCK

Trbegin [B9P2], [PIH]

For NOL = 0 To [M:B9E1]NBLIG-1

    If [M:B9E1]UPDFLG(NOL) > 0

        GCLE = [M:B9E1]INVNUM(NOL)

        Readlock [PIH]PIH0=[M:B9E1]INVNUM(NOL)
        If fstat=1
            GOK = -1 : GLOCK = "$PINVOICE"-GCLE : Break
        Elsif fstat
            GOK = 0 : Call RSTA("PIH", GCLE) From GLOCK
        Elsif !fstat

            #
            # We do not update Amount subject to 1099 on amount changes other than when we include or exclude the entire invoice
            #
            If [F:PIH]FRM1099 = 1    and [M:B9E1]FRM1099(NOL) <> 1    # From None to something else
                [F:PIH]AMTSUBJ1099 += [M:B9E1]AMT1099(NOL)

            Elsif [F:PIH]FRM1099 <> 1    and [M:B9E1]FRM1099(NOL) = 1  # From something else to None
                [F:PIH]AMTSUBJ1099 = 0
            Endif

            [F:PIH]FRM1099 = [M:B9E1]FRM1099(NOL)
            [F:PIH]BOX1099 = [M:B9E1]BOX1099(NOL)

            Rewrite [PIH]
            If fstat
              GOK = 0 : Call FSTA("PIH") From GLOCK : Break
            Endif

            GCLE = num$([M:B9E1]YR1099) - [M:B9E1]CPY - [M:B9E1]BPSNUM - [M:B9E1]PAYNUM(NOL) - num$([M:B9E1]PAYLIN(NOL))

            Readlock [B9P2]B9P0 = [M:B9E1]YR1099;[M:B9E1]CPY;[M:B9E1]BPSNUM;[M:B9E1]PAYNUM(NOL);[M:B9E1]PAYLIN(NOL)

            If fstat=1
                GOK = -1 : GLOCK = "$BP1099PAY"-GCLE : Break
            Elsif fstat
                GOK = 0 : Call RSTA("B9P2",GCLE) From GLOCK
            Elsif !fstat

                [F:B9P2]FRM1099        = [M:B9E1]FRM1099(NOL)
                [F:B9P2]BOX1099        = [M:B9E1]BOX1099(NOL)
                [F:B9P2]AMT1099        = [M:B9E1]AMT1099(NOL)
                [M:B9E1]CAMT1099(NOL)  = [M:B9E1]AMT1099(NOL)

                Rewrite [B9P2]
                If fstat
                    GOK = 0 : Call FSTA("B9P2") From GLOCK : Break
                Endif
            Endif
        Endif

        [M:B9E1]UPDFLG(NOL)=0

    Endif

Next NOL

If GOK < 1 : Rollback : Return : Endif

Commit

Gosub SEARCH_DISPLAY

REP = ""

Return

######################################################################################
$ABA
# Cancel button
Raz [M:B9E1]
# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

######################################################################################
$SEARCH_DISPLAY

Effzo [M:B9E1]20
nolign = 0
[M:B9E1]NBLIG = 0


Filter [F:B9P3] Where YR1099 = [M:B9E1]YR1099 and CPY = [M:B9E1]CPY and BPSNUM = [M:B9E1]BPSNUM and FRM1099 = [M:B9E1]TFRM1099 and BOX1099 = [M:B9E1]TBOX1099

For [F:B9P3]

    Read [F:PYH]PYH0=[F:B9P3]PAYNUM
    If fstat
        Raz [F:PYH]
    Endif

    Read [F:PYD]PYD0=[F:B9P3]PAYNUM;[F:B9P3]PAYLIN
    If fstat
        Raz [F:PYD]
    Endif

    [M:B9E1]FRM1099(nolign)     = [F:B9P3]FRM1099
    [M:B9E1]BOX1099(nolign)     = [F:B9P3]BOX1099
    [M:B9E1]PAYNUM(nolign)      = [F:B9P3]PAYNUM
    [M:B9E1]AMT1099(nolign)     = [F:B9P3]AMT1099
    [M:B9E1]CAMT1099(nolign)    = [F:B9P3]AMT1099
    [M:B9E1]INVNUM(nolign)      = [F:B9P3]INVNUM
    [M:B9E1]PAYLIN(nolign)      = [F:B9P3]PAYLIN
    [M:B9E1]ACCDAT(nolign)      = [F:PYH]ACCDAT
    [M:B9E1]AMTLIN(nolign)      = [F:PYD]AMTLIN
    nolign += 1

Next

[M:B9E1]NBLIG = nolign

If [M:B9E1]NBLIG > 0
    Affzo [M:B9E1]
Else
    Effzo [M:B9E1]20
Endif

Filter [F:B9P3]

Return
######################################################################################
$AB2_NBLIG

Local Char VALC1(20), VALC2(20), VALC3(20)

[L]VALC2=[M]INVNUM(nolign-1)

If [L]VALC2="" : mkstat=2 : Return : Endif

Call LECTURE("BIS",[L]VALC2,"") From CONTOBJ

If [F:PIH]ORIMOD=3
    [L]VALC1 = "BIS"
Elsif [F:PIH]ORIMOD=6
    [L]VALC1 = "PIH"
Endif

Return
######################################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

Read [F:BPS]BPS0 = VALEUR
If fstat = 0
    If [F:BPS]FRM1099 <= 1
        GMESSAGE = mess(76,122,1)    # Invalid 1099 supplier
        mkstat = 2
    Endif
Endif

End
######################################################################################
Subprog AM_FRM1099(VALEUR)
Variable Integer VALEUR

    Raz [M]BOX1099(nolign-1)
    If VALEUR = 1    # None
        [M]AMT1099(nolign-1) = 0
        Affzo [M]AMT1099(nolign-1)
    Endif

    Call CHANGE_INVOICE(VALEUR, [M]BOX1099(nolign-1), nolign-1)

End
######################################################################################
Subprog AM_BOX1099(VALEUR)
Variable Char    VALEUR()

    Call CHANGE_INVOICE([M]FRM1099(nolign-1), VALEUR, nolign-1)

End
######################################################################################
Subprog CHANGE_INVOICE(IFRM1099, IBOX1099, INOL)
Value Integer IFRM1099
Value Char    IBOX1099
Value Integer INOL

Local Integer III

For III = 0 To [M]NBLIG-1

    If III <> INOL and [M]INVNUM(III) = [M]INVNUM(INOL)
        [M]FRM1099(III) = IFRM1099
        [M]BOX1099(III) = IBOX1099

        If IFRM1099 = 1    # None
            [M]AMT1099(III) = 0
            Affzo [M]AMT1099(III)
        Endif

        Affzo [M]FRM1099(III), BOX1099(III)
        [M]UPDFLG(III) = 1
    Endif
Next

End
######################################################################################
Subprog C_AMT1099(VALEUR)
Variable Decimal VALEUR

If VALEUR > [M]AMTLIN(nolign-1)
    GMESSAGE = mess(75,122,1) : mkstat = 2 :    End     # 1099 amount cannot be greater than payment amount
Endif

End
######################################################################################
