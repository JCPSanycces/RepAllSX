#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char   OBJET(GLONAOB)
Local Integer OK
OBJET = "ZZM"
GTRACE = ""
Call VALID(OBJET,nomap,1,OK) From VALOBJ
End


#  Validation Web des écrans - Création de l'XML


$VALWEB

Local Integer WE_I,WE_J              : # Variables de travail
Local Char    WE_PROP(100)           : # Propriété du noeud
Local Char    WE_VALUE(100)          : # Valeur de la propriété
Local Char    WE_NOMFIC(200)         : # Nom du fichier XML produit
Local Char    WE_VALL1(200)          : # Zone de stockage des tags XML
Local Integer WE_NTEX                : # No du texte à traiter
Local Char    WE_NTEXKEY(80)         : # clé unique du texte à traiter
Local Char    WE_CAPDEF(100)         : # Caption dans la langue par défaut
Local Char    VALLM(200)             : # Caption pour les MODVAL
Local Char    WE_INTEV(100)          : # Intitulé évalué
Local Integer WE_NOMEN               : # Numéro de menu local
Local Integer WE_NOMES               : # Numéro de message
Local Integer WE_COU                 : # indice courant
Local Integer WE_TREC                : # Transaction en cours
Local Char WE_HORDAT(14)             : # Horodatage de génération
WE_HORDAT=JOUR+left$(HEURE,2)+mid$(HEURE,4,2)+right$(HEURE,7)

If dim(GI_DOSS)=-1 or GI_DOSS<>APPLI : Call GLOBWEB(APPLI) From INTRUTILA : Endif

# Ouverture fichier XML produit
Call NAMEFIC(APPLI,"OBJT","",OBJET,WE_NOMFIC) From INTRUTILA
Openo WE_NOMFIC,0 Using [HTM_]
Iomode adxifs "" Using [HTM_]
Iomode adxirs chr$(10) Using [HTM_]
Iomode adxium GUTF8 Using [HTM_]
# Ecriture En-tête écran
WE_VALL1='<?xml version="1.0" encoding="utf-8" ?>'
Wrseq WE_VALL1 Using [HTM_]


# Entête de la query list objet
Gosub WECR_OBJET

# Champs de la query list objet
For WE_COU=1 To AOB_NBSEL
  Gosub WECR_COL
Next WE_COU



Gosub WECR_FOBJET

Openo Using [HTM_]

# Mise à jour des liens
If adxlog=0
  WE_TREC=1
  Trbegin [AEL],[AEK]
Endif
Gosub WI_CREOBJT From INTRUTILB
If WE_TREC=1 : Commit : Endif


Gosub JSON From VALOBJJSON

Return





# -------------------------------------------------------------------------------
#   Ecriture par type d'élément
# -------------------------------------------------------------------------------


#  1 - Type OBJET

$WECR_OBJET:
  # Ecriture Entête Query Objet
  WE_VALL1="<OBJT"
  WE_PROP="NAM"       : WE_VALUE=OBJET : Gosub WE_ADDPROP
  WE_PROP="TIM"       : WE_VALUE=WE_HORDAT : Gosub WE_ADDPROP
  WE_PROP="APP"       : WE_VALUE=APPLI : Gosub WE_ADDPROP
  WE_PROP="VER"      : WE_VALUE=GI_VGEN : Gosub WE_ADDPROP
  WE_PROP="TRI"       : WE_VALUE=num$(AOB_ORD) : Gosub WE_ADDPROP
  WE_PROP="HIE"       : WE_VALUE=num$(AOB_TRE-1) : Gosub WE_ADDPROP
  WE_PROP="NBZ"       : WE_VALUE=num$(AOB_NBSEL) : Gosub WE_ADDPROP
  Gosub WE_FINF
Return

$WECR_FOBJET:
  # Ecriture Fin En-tête Query Objet
  WE_VALL1="</OBJT"
  Gosub WE_FINF
Return


#  2 - Type COL

$WECR_COL:
  # Ecriture colonnes de liste gauche
  WE_VALL1="<COL"
  WE_PROP="NAM"  : WE_VALUE=AOB_SELZON(WE_COU) : Gosub WE_ADDPROP
  WE_PROP="XID"  : WE_VALUE=num$(WE_COU) : Gosub WE_ADDPROP
  WE_NTEX=AOB_SELINT(WE_COU): WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  If left$(AOB_SELFMT(WE_COU),1)<>"="
    WE_PROP="FMT"
    #112877
    #WE_VALUE=AOB_SELFMT(WE_COU)
    If instr(1,AOB_SELFMT(WE_COU),"+G")>0
     WE_VALUE=evalue('"'+AOB_SELFMT(WE_COU)+'"')
    Else
     WE_VALUE=AOB_SELFMT(WE_COU)
    Endif
    Gosub WE_ADDPROP
  Endif
  WE_PROP="TDO" :
  If AOB_SELTYP(WE_COU)="ATX"      : #  CC pour traiter cas particulier des textes
    WE_VALUE="7"
  Else
    WE_VALUE=num$(AOB_SELTYPTYP(WE_COU))
  Endif
  Gosub WE_ADDPROP
  If AOB_SELNOLIB(WE_COU)<>0
    WE_PROP="MNU"  : WE_VALUE=num$(AOB_SELNOLIB(WE_COU)) : Gosub WE_ADDPROP
    WE_PROP="TYP"  : WE_VALUE="7" : Gosub WE_ADDPROP
  Else
    WE_PROP="TYP"  : WE_VALUE="6" : Gosub WE_ADDPROP
  Endif
  WE_PROP="SZ"  : WE_VALUE=num$(AOB_SELLNG(WE_COU)) : Gosub WE_ADDPROP
  Gosub WE_FINFF
Return

$WECR_FCOL:
  # Ecriture Fin colonnes de liste gauche
  WE_VALL1="</COL"
  Gosub WE_FINF
Return




# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
#   Utilitaires d'écriture



$WE_FINF
#      Ferme le tag et écrit l'enregistrement
  WE_VALL1+=">"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_FINFF
#      Ferme le tag avec / et écrit l'enregistrement
  WE_VALL1+="/>"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_ADDPROP
#      Ajoute une propriété et écrit un enreg si la longueur de la ligne est > 100
  If len(WE_VALL1)+len(WE_PROP)+len(WE_VALUE) > 100
    Wrseq WE_VALL1 Using [HTM_]
    WE_VALL1=WE_PROP+'="'+WE_VALUE+'"'
  Else
    WE_VALL1-=WE_PROP+'="'+WE_VALUE+'"'
  Endif
Return

