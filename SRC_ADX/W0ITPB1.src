#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITPB1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone XBPSNUM
mkstat = 0
zoncou = "XBPSNUM"
indice = 0
If varmode([M]XBPSNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "XBPSNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]XBPSNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "XBPSNUM" : GZNUM = 3680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("BPR","",[M]XBPSNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "XBPSNUM" : GZNUM = 3680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DOUFLG
mkstat = 0
zoncou = "DOUFLG"
indice = 0
IMPENT = [M]DOUFLG
If varinit([M]DOUFLG,indice)=0
 IMPENT = 1
Endif
[M]DOUFLG = IMPENT

## Zone WTEX
mkstat = 0
zoncou = "WTEX"
indice = 0
IMPENT = [M]WTEX
If varinit([M]WTEX,indice)=0
 IMPENT = 1
Endif
[M]WTEX = IMPENT

## Zone CTMBPSFLG
mkstat = 0
zoncou = "CTMBPSFLG"
indice = 0
IMPENT = [M]CTMBPSFLG
If varinit([M]CTMBPSFLG,indice)=0
 IMPENT = 1
Endif
[M]CTMBPSFLG = IMPENT

## Zone BETFCY
mkstat = 0
zoncou = "BETFCY"
indice = 0
IMPENT = [M]BETFCY
If varinit([M]BETFCY,indice)=0
 IMPENT = 1
Endif
[M]BETFCY = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone CPRAMT
mkstat = 0
zoncou = "CPRAMT"
indice = 0
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]CPRAMT : Endif

## Zone STCNUMITF
mkstat = 0
zoncou = "STCNUMITF"
indice = 0
If varinit([M]STCNUMITF,indice)=0
 [M]STCNUMITF = 131
Endif
If varmode([M]STCNUMITF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STCNUMITF" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone PUU2
mkstat = 0
zoncou = "PUU2"
indice = 0
[M]PUU2 = [M]PUU

## Zone PCUSTUCOE
mkstat = 0
zoncou = "PCUSTUCOE"
indice = 0
[M]PCUSTUCOE = arr([M]PCUPUUCOE*[M]PUUSTUCOE,10^-6)

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone QUAFLG
mkstat = 0
zoncou = "QUAFLG"
indice = 0
IMPENT = [M]QUAFLG
If varinit([M]QUAFLG,indice)=0
 IMPENT = 1
Endif
[M]QUAFLG = IMPENT

####################################
## Bloc liste 6
####################################
IMPTBL = 0

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITPB1"
Return

