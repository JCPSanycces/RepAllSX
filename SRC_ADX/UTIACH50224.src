#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH50224  Utilitaire de validation de l'objet CTRH1    Module ACHAT #
#               ISSUE X3-50224                                           #
#               MAE                                           25/09/2017 #
##########################################################################


Call MAJ_UTIACH50224
End


Subprog MAJ_UTIACH50224
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH50224 - Validate container object") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH50224 : Validate container object ") From LECFIC
  Call EXE_UTIACH50224(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH50224(DOSSIER)
Value Char     DOSSIER
#----- Variables locales -----#
Local Integer LRET

#-----
Call ECR_TIME("UTIACH50224 : Start process  "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

# Mise à jour de l'onglet sélection de l'objet MFC (+raz du dernier lu)
Call MAJ_SEL(DOSSIER,"CTRH1") From PATCHAOB
Call VALID("CTRH1",DOSSIER,1,LRET) From VALOBJ
Call VALID("OSHIP",DOSSIER,1,LRET) From VALWIN
#----- Fin du traitement -----#
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

End



###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH (DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH50224(DOSSIER)
Endif
#-----
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH50224(DOSSIER)
Endif
#-----
End

