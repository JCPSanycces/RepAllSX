#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIACH29      Utilitaire de corrections                   Module ACHAT #
#               des commandes et des workflow de signature achat         #
#               Suite au bug 79162 sur migration V5->V6                  #
##########################################################################


Call MAJ_UTIACH29
End


Subprog MAJ_UTIACH29
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle WSIMUL  : WSIMUL=1     : # 0=normale, 1=simulation (pas de màj)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTIACH29 - Workflow signature purchasing order v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTIACH29 - Workflow signature purchasing order v6") From LECFIC
  Endif
  Call EXE_UTIACH29(WDOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTIACH29(WDOSSIER,WTRACE,WSIMUL)
Value Char     WDOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL
#----- Variables locales -----#
Local Char     WMSG(90), WMSG2(90), WID0(40)
Local Integer  NBLUS, NBCORPOH, NBCORAWS
Local Char     CLE1(GLONVCR)
Local Char     CRITERE(150)
Local Integer COMPTEUR, STOP
Local Integer  WAPPFLG,WMAJAWS
Local Char     WCHRONO_FIRST(GLONVCR)
Local Char     WUSR_FIRST(GLONAUS)
#-----
Call ECR_TIME("UTIACH29 - Workflow signature purchasing order v6") From DOSSUB
Call ECR_TRACE("UTIACH29 : Process Start on : "+WDOSSIER,0) From GESECRAN

If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If dim(GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
Gosub TRT_POC
#-----
$FIN_UTIACH29
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif
#-----
End


#-----------------------------------------------------#
# Vérification des commandes partiellement signées    #
# --------------------------------------------------- #
# Fichier PORDER                                      #
# --------------------------------------------------- #
$TRT_POC
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".AWRKHISSUI"     [AWS]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTIACH29 : Purchase Order Process : Update PORDER") From DOSSUB
Endif
Raz CLE1, STOP, NBLUS, NBCORPOH, NBCORAWS
#-----
$BOUCLE_POH
If STOP=1
  CRITERE='POHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [POH]
  For [POH] POH0 Where APPFLG=2 & CLEFLG<>2 & evalue(CRITERE)
    NBLUS+=1

    Raz WCHRONO_FIRST,WUSR_FIRST
    Raz WAPPFLG
    Filter [AWS] Where ([F:AWS]TYPEVT=2 | [F:AWS]TYPEVT=9) & [F:AWS]CLEDEC=[F:POH]POHNUM Order By Key CLE=[F:AWS]LEVSIG
    For [AWS]CLE
        Raz WMAJAWS
        If [F:AWS]LEVSIG=0
          WCHRONO_FIRST =[F:AWS]CHRONO
          WUSR_FIRST    =[F:AWS]DEST
        Elsif WCHRONO_FIRST<>""
          If [F:AWS]NUMORG<>WCHRONO_FIRST
             [F:AWS]NUMORG   =WCHRONO_FIRST
             WMAJAWS=1
          Endif
          If [F:AWS]USRORG<>WUSR_FIRST
             [F:AWS]USRORG   =WUSR_FIRST
             WMAJAWS=1
          Endif
        Endif
        If [F:AWS]ABROBJ  <>"POH"
          [F:AWS]ABROBJ   ="POH"
          WMAJAWS=1
        Endif
        If [F:AWS]LEVSIG=([F:AWS]NBRUSR-1) & [F:AWS]FLGSIG=5 
            WAPPFLG=1
        Endif
        If WMAJAWS
          COMPTEUR+=1 : NBCORAWS+=1
          If WTRACE=2
            WMSG="Update AWRKHISSUI"-[F:AWS]CHRONO+'/'+[F:AWS]DEST-"on order"-[F:POH]POHNUM
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          Rewrite [AWS]
          If fstat
            Call ECR_TRACE("File AWRKHISSUI, Error ="-num$(fstat)-", AWRKHISSUI"-[F:AWS]CHRONO+'/'+[F:AWS]DEST-", POHNUM="+[F:POH]POHNUM,1) From GESECRAN
          Endif
        Endif
    Next
    Filter [AWS]
    #-----
    If WAPPFLG
      COMPTEUR+=1 : NBCORPOH+=1
      If WTRACE=2
        WMSG="Update APPFLG on order"-[F:POH]POHNUM
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:POH]APPFLG=3
      Rewrite [POH]
      If fstat
        Call ECR_TRACE("File PORDERH, Error ="-num$(fstat)-", POHNUM="+[F:POH]POHNUM,1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POH]POHNUM  : STOP=1 : Break
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_POH : Endif
#-----
Close Local File [POH], [AWS]
#-----
WMSG ="UTIACH29 : Number of processed orders :"-num$(NBLUS)
Call ECR_TIME(WMSG) From DOSSUB
WMSG=" PORDER corrected :"-num$(NBCORPOH)
Call ECR_TIME(WMSG) From DOSSUB
WMSG=" AWRKHISSUI corrected :"-num$(NBCORAWS)
Call ECR_TIME(WMSG) From DOSSUB
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH29(DOSSIER,1,0)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH29(DOSSIER,1,0)
Endif
#-----
End
