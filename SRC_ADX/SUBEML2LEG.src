  If dim([M:EMP3]NBRPASMID)>0 :  Chgfmt [M:EMP3]NBRPASMID  With "Nz:4" :Endif
  If dim([M:EMP3]PASNUMMID)>0 :  Chgfmt [M:EMP3]PASNUMMID  With "K:20X" :Endif
  If dim([M:EMP3]CRYBRNMID)>0 :  Chgfmt [M:EMP3]CRYBRNMID  With "K:3X" :Endif
