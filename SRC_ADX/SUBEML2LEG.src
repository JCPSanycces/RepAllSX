Subprog DISPLAY_FRA()
  #HRMAT1
  If dim([M:EMP1]CODSEE)>0 :  Chgfmt [M:EMP1]CODSEE  With "+K:5X" :    Endif

  If func AFNC.ACTIV("FINTM")>0
    If dim([M:EMP1]FLGINT)>0 :  Chgfmt [M:EMP1]FLGINT  With "+LA:1" : Endif
    If dim([M:EMP1]NUMCCS)>0 :  Chgfmt [M:EMP1]NUMCCS  With "+K:20X" : Endif
  Endif

  #HRMAT2
  If dim([M:EMP2]CTYBRNSEE)>0 :  Chgfmt [M:EMP2]CTYBRNSEE  With "K:5X"  :Endif
  If dim([M:EMP2]DEPBRN)>0 :  Chgfmt [M:EMP2]DEPBRN  With "K:2X"  :Endif
  If dim([M:EMP2]CODUE)>0 :  Chgfmt [M:EMP2]CODUE  With "LA:11702"  :Endif

  #HRMAT3
  If func AFNC.ACTIV("FPAPO") > 0
    If dim([M:EMP3]BORWRK)>0 :  Chgfmt [M:EMP3]BORWRK  With "LA:1"  :Endif
  Endif

  #HRMAT6
  #FINTM - KFR & INTMT
  If func AFNC.ACTIV("FINTM")>0
    If dim([M:EMP6]CALPAY)>0 :  Chgfmt [M:EMP6]CALPAY  With "-K:15X"  :Endif
  Endif

End

Subprog DISPLAY_KPO()

  #HRMAT1
