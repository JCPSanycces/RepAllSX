Subprog AV_EMPTAXNBR(VALEUR)
Variable Char    VALEUR()
If (func SUBEML.IS_LEG('POR') or func SUBEML.IS_LEG('ANG'))
  If func SUBEML.IS_LEG('ANG')
     GFMT = "20X"
  Else
     GFMT = "9X"
  Endif
Else
   GFMT = ""  #hide field
Endif

End

Subprog AV_IDNBR(VALEUR)
Variable Char    VALEUR()
If (func SUBEML.IS_LEG('POR') or func SUBEML.IS_LEG('ANG'))
  If func SUBEML.IS_LEG('ANG')
     GFMT = "20X"
  Else
     GFMT = "12X"
  Endif
Else
   GFMT = ""  #hide field
Endif


End

Subprog AV_BUSTEL(VALEUR)
Variable Char    VALEUR()
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
  If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
  Read [TCY]TCY0 = [M]CRY
  GFMT = [F:TCY]TELFMT
Else
  GFMT = ""  #hide field
Endif

End


Subprog AS_SSCDAT(VALEUR)
Variable Date    VALEUR

If func SUBEML.IS_LEG('MAR')
 If dim([M:EMP5]SSCDAT)>0 :  Chgfmt [M:EMP5]SSCDAT  With "D:"+GFMDAT  :Endif
Else
   If dim([M:EMP5]SSCDAT)>0 :  Chgfmt [M:EMP5]SSCDAT  With "-D:"+GFMDAT  :Endif
Endif

End


Subprog AS_RETDAT(VALEUR)
Variable Date    VALEUR
If func SUBEML.IS_LEG('MAR')
   If dim([M:EMP5]RETDAT)>0 :  Chgfmt [M:EMP5]RETDAT  With "D:"+GFMDAT  :Endif
  Else
   If dim([M:EMP5]RETDAT)>0 :  Chgfmt [M:EMP5]RETDAT  With "-D:"+GFMDAT  :Endif
  Endif
End


Subprog AS_MRGDAT(VALEUR)
Variable Date    VALEUR

If (func SUBEML.IS_LEG('ANG') or func SUBEML.IS_LEG('SWZ') or func SUBEML.IS_LEG('LSO'))
  If dim([M:EMP2]MRGDAT)>0 :  Chgfmt [M:EMP2]MRGDAT  With "D:"+GFMDAT :Endif
Else
   If dim([M:EMP2]MRGDAT)>0 :  Chgfmt [M:EMP2]MRGDAT  With "-D:"+GFMDAT :Endif
Endif

End

Subprog MRGDAT(VALEUR)
Value Integer VALEUR
  If (func SUBEML.IS_LEG('ANG') or func SUBEML.IS_LEG('SWZ') or func SUBEML.IS_LEG('LSO'))
    If VALEUR = 1
      If dim([M:EMP2]MRGDAT)>0  : Effzo [M:EMP2]MRGDAT : Endif
      If dim([M:EMP2]MRGDAT)>0  : Grizo [M:EMP2]MRGDAT : Endif
    Else
       If dim([M:EMP2]MRGDAT)>0 : Actzo [M:EMP2]MRGDAT : Endif
    Endif
  Else
    If dim([M:EMP2]MRGDAT)>0    : Actzo [M:EMP2]MRGDAT : Endif
    If dim([M:EMP2]MRGDAT)>0    : Affzo [M:EMP2]MRGDAT : Endif
    If dim([M:EMP2]MRGDAT)>0    : Chgfmt [M:EMP2]MRGDAT  With "-D:"+GFMDAT4 : Endif
  Endif
End


Subprog SPOMDNNAM(VALEUR)
Value Integer VALEUR

If func SUBEML.IS_LEG('ANG')
    If VALEUR = 1
       If dim([M:EMP2]SPOMDNNAM)>0  : Effzo [M:EMP2]SPOMDNNAM : Endif
       If dim([M:EMP2]SPOMDNNAM)>0  : Grizo [M:EMP2]SPOMDNNAM : Endif
    Else
       If dim([M:EMP2]SPOMDNNAM)>0  : Actzo [M:EMP2]SPOMDNNAM : Endif
    Endif
Endif

End

