  If dim([M:EMP3]PLCISSMID)>0 :  Chgfmt [M:EMP3]PLCISSMID  With "K:30X"  :Endif
  If dim([M:EMP3]PASCRYMID)>0 :  Chgfmt [M:EMP3]PASCRYMID  With "K:3X" :Endif
  If dim([M:EMP3]ISSAUZMID)>0 :  Chgfmt [M:EMP3]ISSAUZMID  With "K:40X"  :Endif
  If dim([M:EMP3]EXPDATMID)>0 :  Chgfmt [M:EMP3]EXPDATMID  With "D:"+GFMDAT  :Endif
  If dim([M:EMP3]ETRPITTYP)>0 :  Chgfmt [M:EMP3]ETRPITTYP  With "K:40X" :Endif
  If dim([M:EMP3]ETRPITDAT)>0 :  Chgfmt [M:EMP3]ETRPITDAT  With "D:"+GFMDAT  :Endif
  If dim([M:EMP3]ETRPITEXPDAT)>0 :  Chgfmt [M:EMP3]ETRPITEXPDAT  With "D:"+GFMDAT   :Endif

  #HRMAT3 KMIEA BLOCK 10 array
  If dim([M:EMP3]ITMMDLNUM(0))>0 :  Chgfmt [M:EMP3]ITMMDLNUM(0)  With "K:50X"  :Endif
  If dim([M:EMP3]DATISS(0))>0 :  Chgfmt [M:EMP3]DATISS(0)  With "D:"+GFMDAT  :Endif
  If dim([M:EMP3]DATRTR(0))>0 :  Chgfmt [M:EMP3]DATRTR(0)  With "D:"+GFMDAT   :Endif
   If dim([M:EMP3]ITMTYP(0))>0 :  Chgfmt [M:EMP3]ITMTYP(0)  With "K:20X" :Endif


  If dim([M:EMP3]ITMMDLNUM(1))>0 :  Chgfmt [M:EMP3]ITMMDLNUM(1)  With "K:50X" :Endif
  If dim([M:EMP3]DATISS(1))>0 :  Chgfmt [M:EMP3]DATISS(1)  With "D:"+GFMDAT   :Endif
  If dim([M:EMP3]DATRTR(1))>0 :  Chgfmt [M:EMP3]DATRTR(1)  With "D:"+GFMDAT   :Endif
  If dim([M:EMP3]ITMTYP(1))>0 :  Chgfmt [M:EMP3]ITMTYP(1)  With "K:20X" :Endif

  If dim([M:EMP3]ITMMDLNUM(2))>0 :  Chgfmt [M:EMP3]ITMMDLNUM(2)  With "K:50X"  :Endif
  If dim([M:EMP3]DATISS(2))>0 :  Chgfmt [M:EMP3]DATISS(2)  With "D:"+GFMDAT   :Endif
  If dim([M:EMP3]DATRTR(2))>0 :  Chgfmt [M:EMP3]DATRTR(2)  With "D:"+GFMDAT  :Endif
  If dim([M:EMP3]ITMTYP(2))>0 :  Chgfmt [M:EMP3]ITMTYP(2)  With "K:20X" :Endif

  #HRMAT7
