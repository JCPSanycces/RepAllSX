############################################################################################
# MAPAD -2016-04-06
# Window  : OEML
# Screens : HRMAT1(Address), HRMAT2(Civil status),HRMAT3(Administrative information),HRMAT5(AdditiFonal), HRMAT6(Contract),HRMAT7(Accounting information)
# Summary : Used to display localised fields on the EMPLOYEE screen
# Logic   : First hide ALL localisation fields. Display main site legislation fields if no contracts. If contracts exists display all fields associated to each legislation
############################################################################################

#MAPAD - 2016-04-06 - Req 114309 - START
Subprog DISPLAY_HIDE(PCURLEG)
Variable Char    PCURLEG()


If func DIVPAYE.IS_AFRICA_LEG(PCURLEG) :Call DISPLAY_KAFR(): Endif
If func DIVPAYE.IS_MIDDLEEAST_LEG(PCURLEG) : Call DISPLAY_KMIEA(): Endif
If func DIVPAYE.IS_ZA_DEV_LEG(PCURLEG) :  Call DISPLAY_ZADEV(): Endif
If func DIVPAYE.IS_KFR_LEG(PCURLEG): Call DISPLAY_FRA() Endif
If PCURLEG = "ZAF" : Call DISPLAY_ZAF(): Endif #South Africa
If PCURLEG = "ANG":  Call DISPLAY_KAO(): Endif #Angola
If PCURLEG = "POR":  Call DISPLAY_KPO(): Endif #Portugal
If PCURLEG = "AUS":  Call DISPLAY_AUS(): Endif #Australia
If PCURLEG = "MAR":  Call DISPLAY_MAR(): Endif #Morocco
If PCURLEG = "BWA":  Call DISPLAY_BWA(): Endif #Botswana
If PCURLEG = "KEN":  Call DISPLAY_KEN(): Endif #Kenya
If PCURLEG = "LSO":  Call DISPLAY_LSO(): Endif #LESOTHO
If PCURLEG = "NAM":  Call DISPLAY_NAM(): Endif #Namibia
If PCURLEG = "NGA":  Call DISPLAY_NGA(): Endif #Nigeria
If PCURLEG = "SWZ":  Call DISPLAY_SWI(): Endif #Swaziland
If PCURLEG = "ZMB":  Call DISPLAY_ZMB(): Endif #Zambia
If PCURLEG = "SAU":  Call DISPLAY_SAU(): Endif #Saudi Arabia
If PCURLEG = "QAT":  Call DISPLAY_QAT(): Endif #Qatar
If PCURLEG = "ARE":  Call DISPLAY_ARE(): Endif #United Arab Emirates

End

Subprog HIDE_ALL_FIELDS()

#If GUSER="SBA": Infbox "ici" :Endif

Gosub HIDEHRMAT1
Gosub HIDEHRMAT2
Gosub HIDEHRMAT3
Gosub HIDEHRMAT5
Gosub HIDEHRMAT6
Gosub HIDEHRMAT7

End


# Mask Participation
$FIELDHRMAT12
  Read [F:AWIN]AWI0 = "OEML"
  Read [F:AMKW]CODMSK = "HRMAT12"
  WNAMEBLCK=""
  If(WDISPBLCK)
    WNAMEBLCK=func AFNC.TEXTE([F:AWIN]INTMSK(5))
  Endif
  Chgtfd [M:EMPC] With WNAMEBLCK

  WNUMLIBEL=0
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(0)
  Endif
  Chgtbk [M:EMPC]10          With func AFNC.TEXTE(WNUMLIBEL)
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(1)
  Endif
  Chgtbk [M:EMPC]20          With func AFNC.TEXTE(WNUMLIBEL)
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(2)
  Endif
  Chgtbk [M:EMPC]30          With func AFNC.TEXTE(WNUMLIBEL)
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(3)
  Endif
  Chgtbk [M:EMPC]40          With func AFNC.TEXTE(WNUMLIBEL)
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(4)
  Endif
  Chgtbk [M:EMPC]50          With func AFNC.TEXTE(WNUMLIBEL)
  If(!WDISPBLCK)
    [M:EMPC]NBRPAR=0
    [M:EMPC]WNBRFDSPAR=0
    [M:EMPC]WNBRFDSITS=0
  Endif
#  Chgfmt [M:EMPC]NBRPAR      With WSIGN+"N:3"     #not hidden  Variable bas de tableau
  Chgfmt [M:EMPC]PARDAT      With WSIGN+"D:"+GFMDAT     #not hidden  on style in SUBEML
  Chgfmt [M:EMPC]WPARDAT     With WSIGN+"D:"+GFMDAT     #not hidden  on style in SUBEML
  Chgfmt [M:EMPC]WFLGPAR     With WSIGN+"LA:1"      #Bénéficiaire participation ML1
  Chgfmt [M:EMPC]WFLGITS     With WSIGN+"LA:1"      #Bénéficiaire intéressement ML1
#  Chgfmt [M:EMPC]WNBRFDSPAR     With WSIGN+"N:3"       #not hidden  Variable bas de tableau
  Chgfmt [M:EMPC]WFDSPAR     With WSIGN+"K:10X"     #Fonds FDS
  Chgfmt [M:EMPC]ZWFDSPAR    With WSIGN+"K:30X"     #Fonds FDS
  Chgfmt [M:EMPC]WFDSPARPRC  With WSIGN+"N:3.2"     #Pourcentage RAT
#  Chgfmt [M:EMPC]WNBRFDSITS  With WSIGN+"N:3"       #not hidden  Variable bas de tableau
  Chgfmt [M:EMPC]WFDSITS     With WSIGN+"K:10X"     #Fonds FDS
  Chgfmt [M:EMPC]ZWFDSITS    With WSIGN+"K:10X"     #Fonds FDS
  Chgfmt [M:EMPC]WFDSITSPRC  With WSIGN+"N:3.2"     #Pourcentage RAT
  Chgfmt [M:EMPC]WADD7       With WSIGN+"LA:1"      #Ajouter ML1

  If WSIGN="-" Then
    Raz [M:EMPC]PARDAT
    Raz [M:EMPC]WPARDAT
    Raz [M:EMPC]WFLGPAR
    Raz [M:EMPC]WFLGITS
    Raz [M:EMPC]WFDSPAR
    Raz [M:EMPC]ZWFDSPAR
    Raz [M:EMPC]WFDSPARPRC
    Raz [M:EMPC]WFDSITS
    Raz [M:EMPC]ZWFDSITS
    Raz [M:EMPC]WFDSITSPRC
    Raz [M:EMPC]WADD7
  Endif
Return

# Mask Spécifique
$FIELDHRMAT11
  Read [F:AWIN]AWI0 = "OEML"
  Read [F:AMKW]CODMSK = "HRMAT11"
  WNAMEBLCK=""
  If(WDISPBLCK)
  #MABOS-FQ74502-US1642-10/06/13 -
#    WNAMEBLCK=func AFNC.TEXTE([F:AWIN]INTMSK(8))
    WNAMEBLCK=func AFNC.TEXTE([F:AWIN]INTMSK(9))
  Endif
  Chgtfd [M:EMPB] With WNAMEBLCK
  WNUMLIBEL=0
  If(WDISPBLCK)
    WNUMLIBEL=[F:AMKW]TITBLOC(0)
  Endif
  Chgtbk [M:EMPB]10          With func AFNC.TEXTE(WNUMLIBEL)
  Chgfmt [M:EMPB]RETCAP      With WSIGN+"LA:1"      #Par capitalisation

  If WSIGN="-" Then
    Raz [M:EMPB]RETCAP
  Endif
Return




$HIDEHRMAT1
#KFR
If dim([M:EMP1]CODSEE)>0 :  Chgfmt [M:EMP1]CODSEE  With "-K:5X"  :Endif
If dim([M:EMP1]EMPTAXNBR)>0 :  Chgfmt [M:EMP1]EMPTAXNBR  With "-K:20X" :Endif
If dim([M:EMP1]IDNBR)>0 :  Chgfmt [M:EMP1]IDNBR  With "-K:20X": Endif
#If dim([M:EMP1]BUSTEL)>0 :  Chgfmt [M:EMP1]BUSTEL  With "-K:20X": Endif

#KPOAO
If dim([M:EMP1]FORTAXNBR)>0 :  Chgfmt [M:EMP1]FORTAXNBR  With "-K:9X" :Endif
If dim([M:EMP1]PLCRGT)>0 :  Chgfmt [M:EMP1]PLCRGT  With "-K:20X" :Endif
If dim([M:EMP1]HABCOD)>0 :  Chgfmt [M:EMP1]HABCOD  With "-K:20X" :Endif

#FINTM - KFR & INTMT
If dim([M:EMP1]FLGINT)>0 :  Chgfmt [M:EMP1]FLGINT  With "-LA:1" :Endif
If dim([M:EMP1]NUMCCS)>0 :  Chgfmt [M:EMP1]NUMCCS  With "-K:20X":Endif

Local Char DESCRIPTION(250)
If clalev([ATZ])=0 : Local File ATABZON [ATZ] : Endif

Read [ATZ]CODZONE="EMPLOID";"PSD"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP0]PSD      With (DESCRIPTION)
 Endif

Read [ATZ]CODZONE="EMPLOID";"NAM"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP0]NAM      With (DESCRIPTION)
Endif

Read [ATZ]CODZONE="EMPLOID";"ADD1"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP1]ADD1      With (DESCRIPTION)
 Endif

Read [ATZ]CODZONE="EMPLOID";"ADD2"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP1]ADD2      With (DESCRIPTION)
Endif

Read [ATZ]CODZONE="EMPLOID";"ADD3"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP1]ADD3      With (DESCRIPTION)
Endif


Affzo[M:EMP0]PSD
Affzo[M:EMP0]NAM


Affzo [M:EMP1]ADD1
Affzo [M:EMP1]ADD2
Affzo [M:EMP1]ADD3


Return

