Subprog DISPLAY_SAU()
  #HRMAT0
  Chgtzn[M:EMP0]PSD           With mess(00003,11738,1)
  Chgtzn[M:EMP0]NAM           With mess(00004,11738,1)

  #HRMAT1
   Chgtzn [M:EMP1]ADD1         With mess(00075,00702,1)
   Chgtzn [M:EMP1]ADD2         With mess(00076,00702,1)
   Chgtzn [M:EMP1]ADD3         With mess(00019,11738,1)

  #HRMAT2
  Chgtzn[M:EMP2]CRYBRN        With mess(00005,11738,1)
  Chgtzn[M:EMP2]CRYNAMBRN     With mess(00006,11738,1)
  Chgtbk[M:EMP2]50           With mess(00005,11706, 1)
  Chgtzn[M:EMP2]OLDNAM        With mess(00004,11738,1)



  If dim([M:EMP2]CTYBRN)>0    : Chgfmt [M:EMP2]CTYBRN       With "K:18X"                 : Endif
  If dim([M:EMP2]NUMSSC )>0   : Chgfmt [M:EMP2]NUMSSC       With "-K:30X"                : Endif #Hide for SAU only
  If dim([M:EMP2]ICOS)>0      : Chgfmt [M:EMP2]ICOS         With "K:3X"                  : Endif


End

