Read [ATZ]CODZONE="EMPLOID";"CRYBRN"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP2]CRYBRN      With (DESCRIPTION)
 Endif

Read [ATZ]CODZONE="EMPLOID";"CRYNAMBRN"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT ,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP2]CRYNAMBRN      With (DESCRIPTION)
Endif

Read [ATZ]CODZONE="EMPLOID";"OLDNAM"
If(!fstat)
    Call TEXTE([ATZ]NOCOURT,DESCRIPTION) From OBJDIV
    Chgtzn[M:EMP2]OLDNAM      With (DESCRIPTION)
Endif


Return

