#<AdxTL>@(#)0.0.0.0 $Revision$ 


################################################################################
Subprog GETSEMTYP( PLANNING,MATRICULE,CONTRAT,DATDEB,DATFIN,CTRNUM,DAT,WTY,TYPDAY,NBRDAY
&                , STRTIM0,ENDTIM0,STRTIM1,ENDTIM1,STRTIM2,ENDTIM2,SOA_GMESSAGE
&                )
Value    Char    PLANNING(), MATRICULE(), CONTRAT()
Value    Date    DATDEB, DATFIN
Variable Char    CTRNUM()(0..), WTY()(0..), STRTIM0()(0..), ENDTIM0()(0..), STRTIM1()(0..)
Variable Char    ENDTIM1()(0..), STRTIM2()(0..), ENDTIM2()(0..)
Variable Date    DAT(0..)
Variable Integer TYPDAY(0..)
Variable Decimal NBRDAY(0..)
Variable Char    SOA_GMESSAGE

Local Char ETRFCY(GLONFCY)    # STCAH - 2017-08-14 - X3-50596

Local File TYPWEEK  [WTY]
Local File PLANTYP  [PLN]

If clalev([F:HRCTRP]) = 0  :  Local File EMPLOCTR  [HRCTRP] :  Endif

Local Date    DEB, FIN, SEM0
Local Integer AN, SEM, N, I
Local Char    PLNTYP(GLONPLN)
Local Integer SOA_GERR

Local Integer  SOA_GTPS :  Call GTPS(SOA_GTPS) From ESSGLOB_SOA

Call SEMAINE(year([L]DATDEB),0,[L]SEM0,[L]FIN,CONTRAT,MATRICULE) From SUBPLN_SOA

If [L]PLANNING>AVOID.ACHAR
  [L]PLNTYP=[L]PLANNING
  [L]DEB   =[L]DATDEB
  [L]FIN   =[L]DATFIN
  # required to get legislation from site
  # STCAH - 2017-08-14 - X3-50596 - START
  ETRFCY = [F:HRCTR]ETRFCY
  # STCAH - 2017-08-14 - X3-50596 - START
  Gosub SEMTYP
Else
  Local Date DATDEBCTR
  For [HRCTRP]CTR0 Where REFNUM=[L]MATRICULE & (CTRNUM=[L]CONTRAT | [L]CONTRAT=AVOID.ACHAR)
&                  & (CTRDAT<=[L]DATFIN | (FLGRET=2 & RETDATEFF<=[L]DATFIN)) & (XITDAT=[0/0/0] | XITDAT>=[L]DATDEB | XITFNL<>2)
  DATDEBCTR=[F:HRCTRP]CTRDAT
  If [F:HRCTRP]FLGRET=2 & [F:HRCTRP]RETDATEFF<>[0/0/0] Then
    DATDEBCTR=[F:HRCTRP]RETDATEFF
  Endif
  [L]DEB=max([L]DATDEB,DATDEBCTR)
  If [F:HRCTRP]XITDAT=[0/0/0] : [L]FIN=[L]DATFIN
  Else                       [L]FIN=min([L]DATFIN,[F:HRCTRP]XITDAT)
  Endif
  Local Char SOA_GPLANNING(30)  : Call GPLANNING(SOA_GPLANNING) From ESSGLOB_SOA
  If [F:HRCTRP]PLNTYP=AVOID.ACHAR : [L]PLNTYP=SOA_GPLANNING : Else [L]PLNTYP=[F:HRCTRP]PLNTYP : Endif
  If [L]FIN>=[L]DEB
    ETRFCY = [F:HRCTRP]ETRFCY  # STCAH - 2017-08-14 - X3-50596
    Gosub SEMTYP
  Endif
 Next
Endif

If SOA_GERR
 #SOA_GMESSAGE="GETSEMTYP :"-func AFNC.MES1(mess(80,701,1),num$(N))
 SOA_GMESSAGE=func ASYRFNC.MES1(mess(80,10701,1),num$(N))
Endif

End
################################################################################
$SEMTYP

Local Integer SOA_GNBHOR : Call GNBHOR(SOA_GNBHOR) From ESSGLOB_SOA

# STCAH - 2017-08-07 - X3-50596 - START
Local Char CTR_LEG(GLONADI)
Local Integer VLEGLVL : VLEGLVL = 1
CTR_LEG = func DIVPAYE_SOA.GET_LEG_FCY([L]ETRFCY,VLEGLVL)
# STCAH - 2017-08-07 - X3-50596 - END

fstat=0
Repeat
 Call DAT([L]DEB,[L]AN,[L]SEM,CTRNUM,MATRICULE) From SUBPLN_SOA
 I=mod([L]DEB-[L]SEM0,7)
 If [F:PLN]YEA<>[L]AN | [F:PLN]COD<>[L]PLNTYP
  Read [PLN]PLN0=[L]AN;[L]PLNTYP;CTR_LEG                          # STCAH - 2017-08-07 - X3-50596 - add CTR_LEG
 Endif
 If fstat = [V]CST_AOK & [F:WTY]COD<>[F:PLN]WEKTYP([L]SEM-1)
  Read [WTY]WTY0=CTR_LEG;[F:PLN]WEKTYP([L]SEM-1)                  # STCAH - 2017-08-07 - X3-50596 - add CTR_LEG

 Endif

 If fstat = [V]CST_AOK
  If N>=dim([L]CTRNUM)
    SOA_GERR=1
  Else
   [L]CTRNUM (N)=[F:HRCTRP]CTRNUM
   [L]DAT    (N)=[L]DEB
   [L]WTY    (N)=[F:WTY]COD
   [L]TYPDAY (N)=[F:WTY]TYPDAY (I)
   [L]NBRDAY (N)=[F:WTY]NBRDAY1(I)
   [L]STRTIM0(N)=[F:WTY]STRTIM0(I)
   [L]ENDTIM0(N)=[F:WTY]ENDTIM0(I)
   If !SOA_GTPS
    [L]STRTIM1(N) = "12"
   Endif
   If SOA_GNBHOR>1
    [L]STRTIM1(N)=[F:WTY]STRTIM1(I)
    [L]ENDTIM1(N)=[F:WTY]ENDTIM1(I)
    If SOA_GNBHOR>2
     [L]STRTIM2(N)=[F:WTY]STRTIM2(I)
     [L]ENDTIM2(N)=[F:WTY]ENDTIM2(I)
    Endif
   Endif
  Endif
  N     +=1
 Endif
 [L]DEB+=1
Until [L]DEB>[L]FIN
Return
################################################################################

