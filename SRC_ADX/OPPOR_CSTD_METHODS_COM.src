#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPOR
#######################################################################################
# COM METHODS                                                                         #
#######################################################################################
$COM_MANAGE_LCM_CREATE
Local Char SMESSAGE(250)
Local Integer IERROR

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.OPPCMP <> "" Then
    Local File BPARTNER [BPR]
    Read [BPR]BPR0=this.OPPCMP
    If fstat <> 0 Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(445,177,1) - ":" - this.OPPCMP, [V]CST_AERROR)
      Return
    Endif
    If [F:BPR]BPCFLG <> [V]CST_AYES and [F:BPR]PPTFLG <> [V]CST_AYES Then
      Return
    Endif
    #Gestion dernière affaire
    Call LCM_BPRLASTOPP(this.OPPCMP, "", this.SALFCY, SMESSAGE, IERROR) From TRTLCMCRM_SYRA
    If IERROR = [V]CST_AYES Then
      [L]ARET_VALUE = fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR)
    Endif
  Endif
Return

#######################################################################################
$COM_MANAGE_LCM_UPDATE
Local Char SMESSAGE(250)
Local Integer IERROR
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI(GLONCPY)
Local Integer IBCHANGE_LCMKEY

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  IBTRAITBPR = [V]CST_AFALSE
  IBTRAITBPRINI = [V]CST_AFALSE
  IBCHANGE_LCMKEY = [V]CST_AFALSE
  Raz SZSOCINI
  # ---------------------------------------------
  If this.snapshot.SALFCY <> this.SALFCY or
&    this.snapshot.OPPCMP <> this.OPPCMP or
&    this.snapshot.OPPDATOPN <> this.OPPDATOPN
& Then
    Local File BPARTNER [BPR]      # Issue X3-15260/120347 - 2016-12-09 by FGR
    If this.OPPCMP <> "" Then
      #Local File BPARTNER [BPR]   # Issue X3-15260/120347 - 2016-12-09 by FGR      Read [BPR]BPR0=this.OPPCMP
      If fstat <> 0 Then
        [L]ARET_VALUE = fmet this.SETERROR("", mess(445,177,1) - ":" - this.OPPCMP, [V]CST_AERROR)
        Return
      Endif
      If [F:BPR]BPCFLG = [V]CST_AYES or [F:BPR]PPTFLG = [V]CST_AYES Then
        IBTRAITBPR = [V]CST_ATRUE
      Endif
    Endif
    If this.snapshot.SALFCY <> this.SALFCY Then
      #On recherche la société initiale
      If this.snapshot.SALFCY <> "" Then
        Read [FCY]FCY0=this.snapshot.SALFCY
        If fstat = 0 Then
          SZSOCINI = [F:FCY]LEGCPY
        Else
          #Erreur lors de la lecture de la table des sites
          [L]ARET_VALUE = fmet this.SETERROR("", mess(444,177,1) - ":" - this.snapshot.SALFCY, [V]CST_AERROR)
          Return
        Endif
        If SZSOCINI <> this.CPY Then
          IBCHANGE_LCMKEY = [V]CST_ATRUE
        Endif
      Else
        SZSOCINI = ""
      Endif
    Else
      SZSOCINI = this.CPY
    Endif
    If this.snapshot.OPPCMP <> this.OPPCMP Then
      If this.snapshot.OPPCMP <> "" Then
        IBCHANGE_LCMKEY = [V]CST_ATRUE
        Read [BPR]BPR0=this.snapshot.OPPCMP
        If fstat <> 0 Then
          #Erreur lors de la lecture du tiers + " : " +[M:OPP0]OPPCMP
          [L]ARET_VALUE = fmet this.SETERROR("", mess(445,177,1) - ":" - this.snapshot.OPPCMP, [V]CST_AERROR)
          Return
        Endif
        If [F:BPR]BPCFLG = [V]CST_AYES or [F:BPR]PPTFLG = [V]CST_AYES Then
          IBTRAITBPRINI = [V]CST_ATRUE
        Endif
      Endif
    Else
      IBTRAITBPRINI = IBTRAITBPR
    Endif
    If IBCHANGE_LCMKEY = [V]CST_ATRUE and IBTRAITBPRINI = [V]CST_ATRUE Then
      # On a changé de société. On remet à jour les infos pour l'ancienne société
      Call LCM_BPRLASTOPP(this.snapshot.OPPCMP, SZSOCINI, this.snapshot.SALFCY, SMESSAGE, IERROR) From TRTLCMCRM_SYRA
      If IERROR = [V]CST_AYES Then
        [L]ARET_VALUE = fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR)
        Return
      Endif
    Endif
    # ---------------------------------------------
    If IBTRAITBPR = [V]CST_ATRUE Then
      # C'est un client ou un prospect
      # GERE_LCM_CREATION fait tout ce qu'il faut.
      [L]ARET_VALUE = fmet this.COM_MANAGE_LCM_CREATE()
    Endif
  Endif
Return

#######################################################################################
$COM_MANAGE_LCM_DELETE
Local Char SMESSAGE(250)
Local Integer IERROR
Local Integer IBSUPR

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  IBSUPR = [V]CST_AFALSE
  If this.OPPCMP <> "" Then
    Local File BPARTNER [BPR]
    Read [BPR]BPR0=this.OPPCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:OPP0]OPPCMP
      [L]ARET_VALUE = fmet this.SETERROR("", mess(445,177,1) - ":" - this.OPPCMP, [V]CST_AERROR)
      Return
    Endif
    If [F:BPR]BPCFLG <> [V]CST_AYES and [F:BPR]PPTFLG <> [V]CST_AYES Then
      Return
    Endif
    # On a chagement de clé dans LCM, il faut traiter pour l'ancienne clé
    Call LCM_DELKEY(9, this.OPPNUM, IBSUPR, SMESSAGE, IERROR) From TRTLCMCRM_SYRA
    If IERROR = [V]CST_AYES Then
      [L]ARET_VALUE = fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR)
      Return
    Endif
    If IBSUPR = [V]CST_ATRUE Then
      # on a supprimé quelque chose : donc on refait la recherche
      # GERE_LCM_CREATION fait tout ce qu'il faut.
      [L]ARET_VALUE = fmet this.COM_MANAGE_LCM_CREATE()
    Endif
  Endif
Return

#######################################################################################
$COM_PROMOTE_CRM
Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.CRM(1) = null Then
    ILINE = fmet this.ADDLINE("CRM", [V]CST_ALASTPOS)
  Endif
  If ILINE <> [V]CST_ANOTDEFINED Then
    [L]ARET_VALUE = fmet this.CRM_INIT_TECH_PROP()
    # -------------------
    # Issue X3-36111/122765 - 2017-05-05 by FGR : BEGIN
    #If maxtab(this.PJM) = 0 or this.PJM(1) = null Then
    #  this.PIMPL.PIMTYP = 1
    #Else
    #  this.PIMPL.PIMTYP = 3  # If it's not CRM before, become a mixte one
    #Endif
    If this.TCHISPJM = [V]CST_AFALSE Then
      this.PIMPL.PIMTYP = 1
    Elsif maxtab(this.PJM) = 0 or this.PJM(1) = null Then
      this.PIMPL.PIMTYP = 1
    Else
      this.PIMPL.PIMTYP = 3  # If it's not CRM before, become a mixte one
    Endif
    # Issue X3-36111/122765 - 2017-05-05 by FGR : END
    # -------------------
  Else
    [L]ARET_VALUE = [V]CST_AERROR
  Endif
Return

#######################################################################################
$COM_PROMOTE_PJM
Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  # Issue X3-56123 - 2017-10-16 by FGR : BEGIN
  If this.OPPCMP <> AVOID.ACHAR Then
    Local File BPARTNER [BPR]
    Read [BPR]BPR0=this.OPPCMP
    If [F:BPR]BPCFLG <> [V]CST_AYES Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("OPPCMP", mess(983,2260,1), [V]CST_AERROR))
      Return
    Endif
  Endif
  # Issue X3-56123 - 2017-10-16 by FGR : END
  # -------------------
  If this.PJM(1) = null Then
    ILINE = fmet this.ADDLINE("PJM", [V]CST_ALASTPOS)
  Endif
  If ILINE <> [V]CST_ANOTDEFINED Then
    [L]ARET_VALUE = fmet this.PJM_INIT_TECH_PROP()
    # -------------------
    If maxtab(this.CRM) = 0 or this.CRM(1) = null Then
      this.PIMPL.PIMTYP = 2
    Else
      this.PIMPL.PIMTYP = 3  # If it's not PJM before, become a mixte one
    Endif
    # -------------------
  Else
    # Issue X3-107691 - 2018-10-15 by FGR : BEGIN : not linger to the issue but more clean
    #[L]ARET_VALUE = [V]CST_AERROR
    [L]ARET_VALUE = max([L]ARET_VALUE, [V]CST_AERROR)
    # Issue X3-107691 - 2018-10-15 by FGR : END
  Endif
Return

#######################################################################################
$COM_IS_CRM_OPPOR
  If find(this.PIMPL.PIMTYP,1,3) > 0 Then
    [L]ARET_VALUE = [V]CST_ATRUE
  Else
    [L]ARET_VALUE = [V]CST_AFALSE
  Endif
Return

#######################################################################################
$COM_IS_PJM_OPPOR
  If find(this.PIMPL.PIMTYP,2,3) > 0 Then
    [L]ARET_VALUE = [V]CST_ATRUE
  Else
    [L]ARET_VALUE = [V]CST_AFALSE
  Endif
Return

#######################################################################################
$COM_LOAD_OPPMCNNAM

  # Issue X3-80586 - 2018-04-11 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  If this.OPPMCN = AVOID.ACHAR Then
    this.OPPMCNNAM = AVOID.ACHAR
  Else
    Local File CONTACTCRM [AIN]
    Read [AIN]AIN0=this.OPPMCN
    If fstat Then
      this.OPPMCNNAM = AVOID.ACHAR
    Else
      this.OPPMCNNAM = func CRMUTIL140_SYRA.BUILDFULNAM(this.ACTX, "AIN", this.OPPMCN)
    Endif
  Endif
Return

