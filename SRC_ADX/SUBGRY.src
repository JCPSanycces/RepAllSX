#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Local Char BIDC1(20) , BIDC2(20)
Call OBJET("GRY",BIDC1,BIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "FIN"           : Gosub FIN

 When "LIENS2"        : Gosub LIENS2
 When "AVANT_ACT"     : Gosub AVANT_ACT
 When "CREATION"      : Gosub CREATION
 When "MODIF"         : Gosub MODIF
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "ANNULE"        : Gosub ANNULE

 When "GRISE"         : Gosub GRISE
 When "DEGRISE"       : Gosub DEGRISE
 When "EFFMASK"       : Gosub EFFMASK
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "FILTRE"        : Gosub FILTRE
 When "EXEBOUT"       : Gosub EXEBOUT
 When "RAZCRE"        : Gosub RAZCRE
 When "RAZDUP"        : Gosub RAZDUP
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INIMOD
 When "SETBOUT"       : Gosub SETBOUT
 When "STATUT"        : Gosub STATUT
 When "AVANTBOUT"     : Gosub AVANTBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "FIN_ACTION"    : Gosub FIN_ACTION

 When "TIROIR"        : Gosub TIROIR
 When "PICKE"         : Gosub PICKE
 When "DEPICK"        : Gosub DEPICK

 When "SEL_TABLE"     : Gosub SEL_TABLE
Endcase
Return

#########################################################################
$OUVRE
Local Integer NGRU , NACC , LIN , FLMODIF
Local Integer SAVGAUCHE , LEVPICK
Local Integer PYRREF

If clalev([F:GRY0])=0 : Local File GACCGRUPYM [GRY0] : Endif
If clalev([F:GRY2])=0 : Local File GACCGRUPYM [GRY2] : Endif
If clalev([F:GYM])=0  : Local File GACCPYM    [GYM]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS    [CLS]  : Endif
If clalev([F:GYK])=0  : Local File GACCPYMLIK [GYK]  : Endif
If clalev([F:GYP])=0  : Local File GACCPYMPRT [GYP]  : Endif

Local Mask GRUPIK [PIK]
Default Mask [GRY1]

If !GIMPORT
 If CLE2<>""
  Read [GYM]GYM0 = CLE2
  If fstat
   CLE2 = ""
  Endif
 Endif
 If CLE2=""
  Read [GYM]GYM0 First
  CLE2 = [F:GYM]PYM 
 Endif
 GBIDC1 = CLE2
 GBIDC2 = [F:GYM]COA
 If CLE1=""
  Filter [GRY] Where PYM=CLE2
  Read [GRY]GRY0 First
  Filter [GRY]
  If !fstat
   CLE1 = [F:GRY]GRU
  Endif
 Endif
Endif
FLMODIF = 0
Gosub PYRREF
Return

$PYRREF
Filter [COA] Where PYRREF=[F:GYM]PYM
Read [COA] First
Filter [COA]
If fstat<=2
 PYRREF = 1
Else
 PYRREF = 0
Endif
[M]PYRREF = PYRREF
Return

#########################################################################
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCGRUPYM","DESTRA",CLECUR2,CLECUR1,"GACCGRUPYM","DESTRA",[M]PYM,[M]GRU)  From ATEXTRA
 Call DUPTEXTRA("GACCGRUPYM","SHOTRA",CLECUR2,CLECUR1,"GACCGRUPYM","SHOTRA",[M]PYM,[M]GRU)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GACCGRUPYM","DESTRA",[M]PYM,[M]GRU) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GACCGRUPYM","SHOTRA",[M]PYM,[M]GRU) From ATEXTRA
Return

#########################################################################
$OUVRE_BOITE
Local Integer BROWACC , BROWGRC
BROWACC = find("GAC",OBJLIS)-1
BROWGRC = find("GRC",OBJLIS)-1
[M:PIK]BOXACC  = "GAU_CHE"+num$(BROWACC)
[M:PIK]BOXGRC  = "GAU_CHE"+num$(BROWGRC)
Return

#########################################################################
$GRISE
Grizo VGRU
Return

$DEGRISE
Actzo VGRU
Return

$EFFMASK
If MA=0 | MA=1
 [M]VPYM = GBIDC1
 [M]VCOA = GBIDC2
 Affzo VPYM,VCOA
Endif
Return

$RAZCRE
[M]VPYM = GBIDC1
[M]VCOA = GBIDC2
Gosub LOAD_COA
Gosub SETPICK
[M]LEGCLSINV = [F:COA]LEGCLS
Return

$RAZDUP
Effzo 30,35
Gosub SETPICK
Return

$INICRE
$INIMOD
If dim([F:GRY]DES)>0
 [F:GRY]DES = [M:GRY1]DESTRA
Endif
[F:GRY]COA = [M:GRY1]VCOA
Return

$LOAD_COA
#Read COA to know if "Suivi analitique" is on
Call LECTURE("COA",GBIDC2,"") From CONTOBJ
If [F:COA]ANATRK <> 2
 Effzo VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
 Grizo VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
Else
 Actzo [M]VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
Endif
Return

$FILTRE
If GFONCTION="GESGRY" & zoncou<>"VACC" & zoncou<>"VSBBGRU" & dim(CRITERE)>0
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:GRY]PYM="'+GBIDC1+'"'
Endif
Return

$SETBOUT
CHMEN = ""
If GREP<>"" or TUNNEL or !instr(1,GUSRAUZ(1),"1")
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If GBIDC1="" or GBIDC2="" 
 Call VIREBOUT(CHAINE,"AC") From GOBJET
Else
 If CLECUR & REP="" & VERROU
  CHAINE += "AH"
 Endif
Endif 
If REP=""
 If instr(1,GUSRAUZ(1),"2")
  CHMEN += "2"
 Endif
 If instr(1,GUSRAUZ(1),"3") & ![M]PYRREF
  CHMEN += "3"
 Endif
 CHMEN += "4"
 If [M]PYRREF
  CHMEN += "5"
 Endif
Endif 
Return

$APRES_MODIF
Case COUZON
 When "VGRU"
  COUZON = "GRU"
  [M]PYM = GBIDC1
  [M]GRU = [M]VGRU
Endcase
Return

$AVANTBOUT
If BOUT = "3" : # Génération auto
 Filter [GRY2] Where PYM=[M]PYM
 Read [GRY2]GRY0 First 
 Filter [GRY2]
 If !fstat
  # Groupes existants  pour cette pyramide
  OK = 2 : Call AVERTIR(mess(97,102,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif    
Return

$FIN
Gosub MAJ_LIENS
Return

$MAJ_LIENS
If FLMODIF & GBIDC1<>""
 Call TEMPON("V") From GESECRAN
 Call PYRAMPRT(GBIDC1,GBIDC2,nomap) From LIENPYRACC
 Call PYRAMLIK(GBIDC1,GBIDC2,nomap) From LIENPYRACC
 Call TEMPOFF From GESECRAN
 FLMODIF = 0
Endif
Return

$FIN_ACTION
If find(REPONSE,GSTAANU,GSTACHG)
 FLMODIF = 1
Endif
Return

#########################################################################
## Transfert Tableau invisible => Tableaux visibles  (lecture)
#########################################################################
$LIENS2
Call LECTURE("GYM",[M]PYM,"") From CONTOBJ
[M]PYM  = [F:GYM]PYM
[M]VPYM = [F:GYM]PYM
[M]COA  = [F:GYM]COA
[M]VCOA = [F:GYM]COA
Call LECTURE("COA",[M]COA,"") From CONTOBJ
If [F:COA]ANATRK<>2
 Effzo VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
 Grizo VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
Else
 Actzo [M]VUOMDAC,VUOM,VDEFVAL,VBUDTRK,VTIMDSP
 Call GRISE_IPT([F:GRY]UOMDAC)
 Call GRISE_BUD([F:GRY]BUDTRK)
Endif
NGRU = -1
NACC = -1
[M]VGRU    = [M]GRU(0)
Call LECTEXTRA([M]DESTRA(0),"GACCGRUPYM","DESTRA",[M]PYM(0),[M]GRU(0)) From ATEXTRA
Call LECTEXTRA([M]SHOTRA(0),"GACCGRUPYM","SHOTRA",[M]PYM(0),[M]GRU(0)) From ATEXTRA
[M]VDESTRA = [M]DESTRA(0)
[M]VSHOTRA = [M]SHOTRA(0)
[M]VLEV    = [M]LEV(0)
[M]VPRNROW = [M]PRNROW(0)
[M]VCLSCOD = [M]CLSCOD(0)
[M]LEGCLSINV = [F:COA]LEGCLS
If [M]VCLSCOD<>""
 Call LECTEXTRA([M]VCLSNAM,"GACCCLS","DESTRA",[F:COA]LEGCLS,[M]VCLSCOD) From ATEXTRA
Else
 [M]VCLSNAM = ""
Endif
[M]VUOMDAC = [M]UOMDAC(0)
[M]VUOM    = [M]UOM(0)
[M]VDEFVAL = [M]DEFVAL(0)
[M]VBUDTRK = [M]BUDTRK(0)
[M]VTIMDSP = [M]TIMDSP(0)
For  I=0 To [M]LIN-1
 If [M]SBBGRU(I) = "" 
  NACC += 1 
  [M]VACC(NACC) = [M]ACC(I)
  Read [GAC]GAC0 = [M]COA;[M]ACC(I)
  If !fstat 
   Call LECTEXTRA([M]VACCDES(NACC),"GACCOUNT","DESTRA",[M]COA,[M]ACC(I)) From ATEXTRA
  Endif
 Else 
  NGRU += 1
  [M]VSBBGRU(NGRU) = [M]SBBGRU(I)
  Read [GRY0]GRY0(2) = [M]PYM;[M]SBBGRU(I)             
  If !fstat
   Call LECTEXTRA([M]VSGRDES(NGRU),"GACCGRUPYM","DESTRA",[M]PYM,[M]SBBGRU(I)) From ATEXTRA
  Endif
 Endif
Next I
[M]VNBRGRP = NGRU+1
[M]VNBRACC = NACC+1
Read [GRY]GRY2(2) = [M]PYM;[M]VGRU
If !fstat
 [M]VPERE = [F:GRY]GRU
 Call LECTEXTRA([M]VPDES,"GACCGRUPYM","DESTRA",[M]PYM,[F:GRY]GRU) From ATEXTRA
Else
 [M]VPERE = ""
 [M]VPDES = ""
Endif
Read [GRY]GRY0(2) = [M]PYM;[M]VGRU
If currbox=[M:PIK]BOXGRC & [M]VLEV<>LEVPICK
 Gosub TIROIR
Else
 Gosub SETPICK
Endif
[M]PYRREF = PYRREF
Return

#########################################################################
## Transfert Tableaux visibles => Tableau invisible  (écriture)
#########################################################################
$AVANT_ACT
Case BOUT
 When "E", "C" : # Enregistrer, créer
  If ([M]VNBRACC=0 and [M]VNBRGRP=0)
   Call MESSAGE(mess(178,123,1)) From GESECRAN  : # Il doit y avoir au moins une ligne
   OK = 0
  Else
   Gosub UPDATE_INVISIBLE
   FLMODIF = 1
  Endif 
Endcase
Return

$UPDATE_INVISIBLE
LIN = -1 
Raz [M]PYM,GRU,SHOTRA,DESTRA,LEV,BUDTRK,ACC,SBBGRU
For I=0 To [M]VNBRGRP-1
 LIN += 1
 Gosub FILLCOLUMNS
 [M]SBBGRU(LIN) = [M]VSBBGRU(I)
 [M]ACC(LIN)    = ""
Next I
For I=0 To [M]VNBRACC -1
 LIN += 1
 Gosub FILLCOLUMNS
 [M]ACC(LIN)    = [M]VACC(I)
 [M]SBBGRU(LIN) = ""
Next I
[M]LIN = LIN+1
Return

$FILLCOLUMNS
[M]PYM(LIN)    = [M]VPYM
[M]GRU(LIN)    = [M]VGRU
[M]SHOTRA(LIN) = [M]VSHOTRA
[M]DESTRA(LIN) = [M]VDESTRA
Call MAJTEXTRA([M]DESTRA(LIN),"GACCGRUPYM","DESTRA",[M]PYM(LIN),[M]GRU(LIN)) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA(LIN),"GACCGRUPYM","SHOTRA",[M]PYM(LIN),[M]GRU(LIN)) From ATEXTRA
[M]LEV(LIN)    = [M]VLEV
[M]BUDTRK(LIN) = [M]VBUDTRK      
[M]PRNROW(LIN) = [M]VPRNROW
[M]CLSCOD(LIN) = [M]VCLSCOD
[M]UOMDAC(LIN) = [M]VUOMDAC
[M]UOM(LIN)    = [M]VUOM
[M]DEFVAL(LIN) = [M]VDEFVAL
[M]TIMDSP(LIN) = [M]VTIMDSP
Return

#########################################################################
## Suppression des lignes déplacées
#########################################################################
$MODIF
Local Integer NBLIN
Local Char    GRPLIN(GLONGRY)
For I=0 To [M]VNBRACC-1
 If [M]VACC(I)<>""
  For [GRY0]GRY5 Where PYM=[M]VPYM & ACC=[M]VACC(I) & GRU<>[M]VGRU
   Gosub VIRE
   If GOK<1 : Break 2 : Endif
  Next
 Endif
Next I
If GOK<1 : Return : Endif
For I=0 To [M]VNBRGRP-1
 For [GRY0]GRY2 Where PYM=[M]VPYM & SBBGRU=[M]VSBBGRU(I) & GRU<>[M]VGRU
  If [M]VSBBGRU(I)<>""
   Gosub VIRE
   If GOK<1 : Break 2 : Endif
  Endif
 Next
Next I
If GOK<1 : Return : Endif
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$VIRE
GRPLIN = [F:GRY0]GRU
NBLIN  = 0
For [GRY2]GRY0 Where PYM=[M]VPYM & GRU=GRPLIN
 NBLIN += 1
Next
If NBLIN=1
 [F:GRY0]SBBGRU = ""
 [F:GRY0]ACC    = ""
 [F:GRY0]LIN    = 1
 Rewrite [GRY0]
 If fstat
  GOK = 0 : Call FSTA("GRY0") From GLOCK : Return
 Endif
Else
 Delete [GRY0]
 If fstat=1
  GOK = -1 : GLOCK = "$GACCGRUPYM"-[F:GRY0]PYM-[F:GRY0]GRU : Return
 Endif
 NBLIN = 0
 For [GRY2]GRY0 Where PYM=[M]VPYM & GRU=GRPLIN
  NBLIN += 1
  [F:GRY2]LIN = NBLIN
  Rewrite [GRY2]
  If fstat
   GOK = 0 : Call FSTA("GRY2") From GLOCK : Break
  Endif
 Next
Endif
Return

#########################################################################
## Annulation / Changement de clé
#########################################################################
$AP_CHANGE
Call DEBTRANS From GLOCK
Gosub TR_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GACCGRUPYM","VDESTRA",[M]PYM,[M]GRU,[M]PYM,NCODE) From ATEXTRA
#Call CHGTEXTRA("GACCGRUPYM","VSHOTRA",[M]PYM,[M]GRU,[M]PYM,NCODE) From ATEXTRA
Call CHGTEXTRA("GACCGRUPYM","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("GACCGRUPYM","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Return

$TR_CHANGE
GOK = 1
Trbegin [GRY2]
 For [GRY2]GRY2 Where PYM=GBIDC1 & SBBGRU=OCODE
  [F:GRY2]SBBGRU = NCODE
  Rewrite [GRY2]
  If fstat
   GOK = 0 : Call FSTA("GRY2") From GLOCK : Break
  Endif
 Next
Commit
[M]LIN = 1
Return

$ANNULE
Call SUPTEXTRA("GACCGRUPYM","DESTRA",[M]PYM,[M]GRU) From ATEXTRA
Call SUPTEXTRA("GACCGRUPYM","SHOTRA",[M]PYM,[M]GRU) From ATEXTRA
Return

#########################################################################
## Gestion des listes de gauche
#########################################################################
$TIROIR
[M:PIK]NBPIK = 0
Case currbox   
 When [M:PIK]BOXACC , [M:PIK]BOXGRC
  ILIS = val(right$(currbox,8))
  SAVGAUCHE = GNBGAUCHE
  GNBGAUCHE = 9999
  Gosub REMP_LISGAU From GOBJSUB
  GNBGAUCHE = SAVGAUCHE
  Gosub SETPICK
 When Default
  Gosub REMPLIT From GOBJSUB
Endcase
Return

$FILGAUCHE
If ILIS
 Case ILIS
  When BROWACC   : # selezione conti
   FILGAUSUP = 'COA="'+[M]VCOA+'" & ENAFLG=2'
  When BROWGRC   : # selezione gruppi
   LEVPICK = [M]VLEV
   FILGAUSUP = 'PYM="'+[M]PYM+'" & LIN=1 & LEV>'+num$(LEVPICK)
 Endcase
Else
 FILGAUCHE = '[F:GRY]PYM="'+[M]VPYM+'"'
Endif
Return

#########################################################################
## Gestion du picking
#########################################################################
$PICKE
Case currbox
 When [M:PIK]BOXACC
  nolign = [M]VNBRACC+1
  Call C_VACC([F:GAC]ACC)      
  If !mkstat
   [M]VACC(nolign-1)    = [F:GAC]ACC 
   Call LECTEXTRA([M]VACCDES(nolign-1),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   [M]VNBRACC += 1
   Affzo VACC(nolign-1),VACCDES(nolign-1)
   [M:PIK]NBPIK +=1
   [M:PIK]TBPIK([M:PIK]NBPIK) = [F:GAC]ACC
  Endif
 When [M:PIK]BOXGRC
  nolign = [M]VNBRGRP+1
  Call CONT_VSBBGRU([F:GRY]GRU)      
  If !mkstat
   [M]VSBBGRU(nolign-1) = [F:GRY]GRU
   Call LECTEXTRA([M]VSGRDES(nolign-1),"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
   [M]VNBRGRP += 1
   Affzo VSBBGRU(nolign-1),VSGRDES(nolign-1)
   [M:PIK]NBPIK +=1
   [M:PIK]TBPIK([M:PIK]NBPIK) = [F:GRY]GRU
   [M:PIK]LVPIK([M:PIK]NBPIK) = [F:GRY]LEV
  Endif
Endcase
Return

$DEPICK
Case currbox
 When [M:PIK]BOXACC
  K = find([F:GAC]ACC,[M]VACC(0..[M]VNBRACC-1))
  If K
   Dela K-1,1 [M]VNBRACC
   [M]VNBRACC -= 1
   Affzo VNBRACC,VACC,VACCDES
  Endif
  K = find([F:GAC]ACC,[M:PIK]TBPIK(1..[M:PIK]NBPIK))
  If K
   Dela K,1 [M:PIK]TBPIK
   [M:PIK]NBPIK -= 1
  Endif
 When [M:PIK]BOXGRC
  K = find([F:GRY]GRU,[M]VSBBGRU(0..[M]VNBRGRP-1))
  If K
   Dela K-1,1 [M]VNBRGRP
   [M]VNBRGRP -= 1
   Affzo VNBRGRP,VSBBGRU,VSGRDES
  Endif
  K = find([F:GRY]GRU,[M:PIK]TBPIK(1..[M:PIK]NBPIK))
  If K
   Dela K,1 [M:PIK]TBPIK
   [M:PIK]NBPIK -= 1
  Endif
Endcase
Return

$SETPICK
Case currbox
 When [M:PIK]BOXACC
  For K=1 To [M:PIK]NBPIK
   [F:GAC]COA = GBIDC2
   [F:GAC]ACC = [M:PIK]TBPIK(K)
   Gosub DEPICK From =WINPROG
  Next K
  [M:PIK]NBPIK = 0
  For K=0 To [M]VNBRACC-1
   If !instr(1,[M]VACC(K),"*") & !instr(1,[M]VACC(K),"?")
&   & !instr(1,[M]VACC(K),"!") & !instr(1,[M]VACC(K),"#")
    [M:PIK]NBPIK += 1
    [M:PIK]TBPIK([M:PIK]NBPIK) = [M]VACC(K)
    [F:GAC]COA = GBIDC2
    [F:GAC]ACC = [M:PIK]TBPIK([M:PIK]NBPIK)
    Gosub REPICK From =WINPROG
   Endif
  Next K
 When [M:PIK]BOXGRC
  For K=1 To [M:PIK]NBPIK
   [F:GRY]PYM = GBIDC1
   [F:GRY]GRU = [M:PIK]TBPIK(K)
   [F:GRY]LEV = [M:PIK]LVPIK(K)
   [F:GRY]LIN = 1
   Gosub DEPICK From =WINPROG
  Next K
  [M:PIK]NBPIK = 0
  For K=0 To [M]VNBRGRP-1
   If !instr(1,[M]VSBBGRU(K),"*") & !instr(1,[M]VSBBGRU(K),"?")
&   & !instr(1,[M]VSBBGRU(K),"!") & !instr(1,[M]VSBBGRU(K),"#")
    Read [GRY2]GRY0(2) = GBIDC1;[M]VSBBGRU(K)
    [M:PIK]NBPIK += 1
    [M:PIK]TBPIK([M:PIK]NBPIK) = [M]VSBBGRU(K)
    [M:PIK]LVPIK([M:PIK]NBPIK) = [F:GRY2]LEV
    [F:GRY]PYM = GBIDC1
    [F:GRY]GRU = [M:PIK]TBPIK([M:PIK]NBPIK)
    [F:GRY]LEV = [M:PIK]LVPIK([M:PIK]NBPIK)
    [F:GRY]LIN = 1
    Gosub REPICK From =WINPROG
   Endif
  Next K
  [F:GRY]GRU = [M]VGRU
  [F:GRY]LEV = [M]VLEV
Endcase
Return

#########################################################################
## Gestion des boutons
#########################################################################
$EXEBOUT
Case BOUT
 When "1" : # Changement de pyramide
  Gosub CHGPYR
Endcase
Return

$STATUT
Case BOUT
 When "2" : # Duplication
  If GBIDC3<>""
   GBIDC1 = GBIDC3
   FLMODIF = 0
   Gosub RAFFICHE
  Endif
 When "3" : # Génération auto
  FLMODIF = 0
  Gosub RAFFICHE
 When "5" : # Réorganisation
  Call REORG([M]VPYM) From SUBGYM
  FLMODIF = 0
  Gosub RAFFICHE
Endcase
Return

$RAFFICHE
Read [GYM]GYM0 = GBIDC1
[M]PYM  = GBIDC1
[M]VPYM = GBIDC1
[M]COA  = [F:GYM]COA
[M]VCOA = [F:GYM]COA
Affzo PYM,VPYM,COA,VCOA
GBIDC1  = [M]PYM
CLECUR2 = GBIDC1
GBIDC2  = [M]COA
Filter [GRY] Where PYM=GBIDC1
Read [GRY]GRY0 First
Filter [GRY]
If fstat<=2
 CLECUR     = 1
 CLECUR1    = [F:GRY]GRU
 CLECUR2(1) = "1"
Else
 CLECUR = 0
 [M]GRU = ""
Endif
Gosub RELIT From GOBJSUB
Gosub SETBOUT
Gosub LOAD_COA
Gosub TIROIR
[M:PIK]NBPIK = 0
Gosub SETPICK
Return

#########################################################################
## Changement de pyramide
#########################################################################
$CHGPYR
If (VALBOUT="") : Return : Endif
Gosub MAJ_LIENS
Gosub DEVERROU From GOBJET
Raz [M]
Effzo
GBIDC1  = VALBOUT
Gosub RAFFICHE
Gosub PYRREF
Return

#########################################################################
## Action SELSBBGRU, sélection de sous-groupe
#########################################################################
$SEL_TABLE
Case TABLE
 When "SELSBBGRU"
#  If clalev([F:GRY1])=0 : Local File GACCGRUPYM [GRY1] : Endif
#  Default File [GRY1]
  CRITERE = 'PYM="'+[M]VPYM+'" & GRU<>"'+[M]VGRU+'" & LEV>'+num$([M]VLEV)+' & LIN=1'
  ORDRE = "LEV;GRU"
  OBJET="GRC"
#  NBCOL = 0
#  NBCOL += 1 : COL(NBCOL) = "GRU"  : TIT(NBCOL) = mess(37,113,1) : # Groupe compte
#  NBCOL += 1 : COL(NBCOL) = "PYM"  : TIT(NBCOL) = mess(38,113,1) : # Pyramide compte
#  NBCOL += 1 : COL(NBCOL) = "DES"  : TIT(NBCOL) = mess(3,113,1)  : # Intitulé
#  NBCOL += 1 : COL(NBCOL) = "LEV"  : TIT(NBCOL) = mess(31,113,1) : # Groupe de niveau
#  TIT(0) = mess(18,100,1)-mess(37,113,1) : # Sélection groupe de comptes
Endcase
Return

######################################################################################
## ECRAN GRY1
######################################################################################
Subprog C_VLEV(VALEUR)
Variable Decimal VALEUR
Local Decimal LIVELLO
LIVELLO = VALEUR
If clalev([F:GRY2])=0 : Local File GACCGRUPYM [GRY2] : Endif
If clalev([F:GRY3])=0 : Local File GACCGRUPYM [GRY3] : Endif
Filter [GRY2] Where PYM=[M]VPYM and SBBGRU=[M]VGRU and LEV>=LIVELLO
Read [F:GRY2] First
If !fstat & [F:GRY2]GRU<>""
 GMESSAGE = (mess(32,113,1)-[F:GRY2]GRU-">"-num$([F:GRY2]LEV)) : # Regroupé dans
 mkstat = 2 :  End 
Endif
Filter [GRY2]
For [GRY2]GRY0 Where PYM=[M]VPYM & GRU=[M]VGRU & ACC=""
 Filter [GRY3] Where PYM=[M]VPYM and GRU=[F:GRY2]SBBGRU 
 Read   [GRY3]  First
 If !fstat
  If   LIVELLO>=[F:GRY3]LEV     
   GMESSAGE = mess(40,113,1)-"(>"-num$([F:GRY3]LEV)-")" : # Niveau incompatible avec le groupe ...
   mkstat=2 : Break   
  Endif
 Endif
 Filter [GRY3] 
Next    
End

Subprog AS_VCLSCOD(VALEUR)
Variable Char VALEUR
Local Char CLASSE(GLONCLA)
Call CLASSE([M]VGRU,CLASSE)
VALEUR = CLASSE
End

Subprog C_VCLSCOD(VALEUR)
Variable Char VALEUR
Call LECTURE("COA",[M]VCOA,"") From CONTOBJ
Read [CLS]CLS0 = [F:COA]LEGCLS;VALEUR
If [F:CLS]TYP=3
 GMESSAGE = mess(5,113,1) : # Classe inutilisée
 mkstat = 2 : End
Endif
End

Subprog CLASSE(COMPTE,CLASSE)
Value    Char    COMPTE
Variable Char    CLASSE
Call LECTURE("COA",[M]VCOA,"") From CONTOBJ
CLASSE = ""
For I=0 To dim([F:COA]PFX)-1
 If left$(COMPTE,len([F:COA]PFX(I)))=[F:COA]PFX(I)
  CLASSE = [F:COA]CLSCOD(I) : Break 
 Endif
Next I
End

Subprog C_VUOMDAC(VALEUR)
Variable Integer VALEUR
Call GRISE_IPT(VALEUR)
End

Subprog C_VBUDTRK(VALEUR)
Variable Integer VALEUR
Call GRISE_BUD(VALEUR)
End

Subprog GRISE_IPT(VALEUR)
Value Integer VALEUR
If VALEUR<>2
 Effzo VUOM,VDEFVAL
 Grizo VUOM,VDEFVAL
Else
 Actzo [M]VUOM,VDEFVAL
Endif
End

Subprog GRISE_BUD(VALEUR)
Value Integer VALEUR
If dim([M]VBUDTRK)<1 : End : Endif
If VALEUR<>2
 Effzo VTIMDSP
 Grizo VTIMDSP
Else
 Actzo VTIMDSP
Endif
End

############################################################################
## Groupes de comptes
############################################################################
Subprog C_VNBRGRP
If status=65 & currbox=[M:PIK]BOXGRC
 Local Integer K
 Gosub SETWIN
 K = find([M]VSBBGRU(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:GRY]PYM = GBIDC1
  [F:GRY]GRU = [M:PIK]TBPIK(K)
  [F:GRY]LEV = [M:PIK]LVPIK(K)
  [F:GRY]LIN = 1
  Gosub DEPICK From =WINPROG
  Dela K,1 [M:PIK]TBPIK
  [M:PIK]NBPIK -= 1
 Endif
 [F:GRY]GRU = [M]VGRU
 [F:GRY]LEV = [M]VLEV
Endif
End

$SETWIN
Local Char    WINPROG(GLONADC)
WINPROG = "WGOGRY"
Return

Subprog C_VSBBGRU(VALEUR)
Variable Char    VALEUR()
Call CONT_VSBBGRU(VALEUR)
If mkstat : End : Endif
Call LECTEXTRA([M]VSGRDES(nolign-1),"GACCGRUPYM","DESTRA",[F:GRY0]PYM,[F:GRY0]GRU) From ATEXTRA
If VALEUR<>[M]VSBBGRU(nolign-1) & currbox=[M:PIK]BOXGRC
 Local Integer K
 Gosub SETWIN
 K = find([M]VSBBGRU(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:GRY]PYM = GBIDC1
  [F:GRY]GRU = [M:PIK]TBPIK(K)
  [F:GRY]LEV = [M:PIK]LVPIK(K)
  [F:GRY]LIN = 1
  Gosub DEPICK From =WINPROG
 Else
  [M:PIK]NBPIK += 1
  K = [M:PIK]NBPIK
 Endif
 [M:PIK]TBPIK(K)  = VALEUR
 [M:PIK]LVPIK(K)  = [F:GRY0]LEV
 [F:GRY]PYM = GBIDC1
 [F:GRY]GRU = [M:PIK]TBPIK(K)
 [F:GRY]LEV = [M:PIK]LVPIK(K)
 [F:GRY]LIN = 1
 Gosub REPICK From =WINPROG
 [F:GRY]GRU = [M]VGRU
 [F:GRY]LEV = [M]VLEV
Endif
End

Subprog CONT_VSBBGRU(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VSBBGRU) From OBJDIV
If mkstat : End : Endif
Read [GRY0]GRY0(2) = [M]VPYM;VALEUR
If [F:GRY0]LEV<=[M]VLEV
 GMESSAGE = mess(31,113,1)-num$([F:GRY0]LEV) : # Groupe de niveau ...
 mkstat = 2 : End
Endif
If [M]PYRREF<>0
 Filter [GRY0] Where PYM=[M]VPYM
 Read [GRY0]GRY1 First
 Filter [GRY0]
 If left$(VALEUR,len([M]VGRU))<>[M]VGRU & [M]VLEV>[F:GRY0]LEV
  GMESSAGE = mess(42,113,1)-[M]VGRU : # Le groupe doit commencer par
  mkstat = 2 : End
 Endif
Endif
End

############################################################################
## Comptes
############################################################################
Subprog C_VNBRACC
If status=65 & currbox=[M:PIK]BOXACC
 Local Integer K
 Gosub SETWIN
 K = find([M]VACC(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:GAC]COA = GBIDC2
  [F:GAC]ACC = [M:PIK]TBPIK(K)
  Gosub DEPICK From =WINPROG
  Dela K,1 [M:PIK]TBPIK
  [M:PIK]NBPIK -= 1
 Endif
Endif
End

Subprog C_VACC(VALEUR)
Variable Char    VALEUR()
Local Integer I , JOKER
VALEUR = toupper(VALEUR)
Call UNICITE(VALEUR,[M]VACC(0..[M]VNBRACC-1)) From OBJDIV
If mkstat : End : Endif
If [M]PYRREF<>0 & left$(VALEUR,len([M]VGRU))<>[M]VGRU
 GMESSAGE = mess(41,113,1)-[M]VGRU : # Le groupe doit commencer par
 mkstat = 2 : End
Endif
If VALEUR<>""
 JOKER  = 0
 For I=1 To len(VALEUR)
  If instr(1,"!#?*",mid$(VALEUR,I,1))
   JOKER = 1 : Break
  Endif
 Next I
 If !JOKER
  Call CONTROLE("GAC","",VALEUR,[M]VCOA,mkstat) From CONTOBJ
  If mkstat : End : Endif
   Call LECTEXTRA([M]VACCDES(nolign-1),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Else 
  [M]VACCDES(nolign-1) = ""
 Endif
Endif
If VALEUR<>[M]VACC(nolign-1) & currbox=[M:PIK]BOXACC
 Local Integer K
 Gosub SETWIN
 K = find([M]VACC(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:GAC]COA = GBIDC2
  [F:GAC]ACC = [M:PIK]TBPIK(K)
  Gosub DEPICK From =WINPROG
 Else
  [M:PIK]NBPIK += 1
  K = [M:PIK]NBPIK
 Endif
 [M:PIK]TBPIK(K)  = VALEUR
 [F:GAC]COA = GBIDC2
 [F:GAC]ACC = [M:PIK]TBPIK(K)
 Gosub REPICK From =WINPROG
Endif
End

