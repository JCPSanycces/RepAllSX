  If !mkstat
   Call CONTROLE("ADI","!",[M]PSNJOB,"10604",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PSNJOB" : GZNUM = 47312 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_PSNJOB([M]PSNJOB) From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PSNJOB" : GZNUM = 47312 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

