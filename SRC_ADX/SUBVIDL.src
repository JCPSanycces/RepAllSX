#########################################################################
# Traitement lié à la fenêtre de situation commande ouverte             #
#########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"      : Gosub DEBUT
Endcase
Return

#########################################################################
# Actions sur la fenêtre de saisie                                      #
#########################################################################
$DEBUT
Local Integer NOL

# Action VISUSITOUV / Fenêtre ISITOUV
If GACTION = "VISUSITOUV"
   [M:VIDL] = [F:SOC]
   Affzo [M:VIDL]1-99
Endif
Return
