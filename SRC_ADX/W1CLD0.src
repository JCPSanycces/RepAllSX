#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLD0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:10"
A_USER  = "DOC"
A_STAMP = "20181109230310"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDAT"
  If [M]NBRDAT=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CLD0 [CLD0]
Gosub HORODAT
Local Inpbox "CLD0" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLD0] As [SIM_]
Grizo [CLD0]5
Grizo [CLD0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLD0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=104 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=104 : Y1(1)=11 : Y2(1)=28
Return

$ON_TYPCLD
Onevent INIT_AREA Call D_TYPCLD(zc) From W1CLD0
Onevent BEFORE_INPUT Call AS_TYPCLD(zc) From W1CLD0
Onevent CONTROL Call C_TYPCLD(zc) From W1CLD0
Return

Subprog D_TYPCLD(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPCLD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPCLD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYPCLD(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TYPCLD" : GZNUM = 25891 : Endif
Gosub _AFF
End

$ON_DESIGN
Onevent INIT_AREA Call D_DESIGN(zc) From W1CLD0
Onevent CONTROL Call C_DESIGN(zc) From W1CLD0
Onevent BEFORE_INPUT Call AS_DESIGN(zc) From W1CLD0
Onevent AFTER_CHANGE Gosub AMM_DESIGN From W1CLD0
Return

Subprog D_DESIGN(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESIGN,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10703","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10703") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DESIGN(zc) From W1CLD0
Onkey   2 Titled GBOUTS Call S_DESIGN(zc) From W1CLD0
Onkey 144 Titled GBOUTP Call P_DESIGN(zc) From W1CLD0
Onkey 146 Titled GBOUTA Call SA_DESIGN(zc) From W1CLD0
Gosub _AFF
End

Subprog C_DESIGN(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10703","") From SUBADI
If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10703",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
Endif
Gosub _AFF
End

$AMM_DESIGN
Call AM_DESIGN(zc)
If !mkstat & GOBJET
 zoncou = "DESIGN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DESIGN(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZDESIGN)")>indice
 [M]DESIGN(indice) = VALEUR
 Affzo ZDESIGN(indice)
Endif
Gosub _AFF
End

Subprog S_DESIGN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10703"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DESIGN(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10703") From GOBJET
Gosub _AFF
End

Subprog SA_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10703"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10703"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDESIGN
Onevent BEFORE_AREA Gosub AV_ZDESIGN From W1CLD0
Return

$AV_ZDESIGN
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10703",num$([M]DESIGN(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_PERIOD
Onevent INIT_AREA Call D_PERIOD(zc) From W1CLD0
Onevent CONTROL Call C_PERIOD(zc) From W1CLD0
Onevent BEFORE_INPUT Call AS_PERIOD(zc) From W1CLD0
Onevent AFTER_CHANGE Gosub AMM_PERIOD From W1CLD0
Return

Subprog D_PERIOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]PERIOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10702","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PERIOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10702") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PERIOD(zc) From W1CLD0
Onkey   2 Titled GBOUTS Call S_PERIOD(zc) From W1CLD0
Onkey 144 Titled GBOUTP Call P_PERIOD(zc) From W1CLD0
Onkey 146 Titled GBOUTA Call SA_PERIOD(zc) From W1CLD0
If VALEUR="" : Call INIADI(VALEUR,"10702") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_PERIOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10702","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10702",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PERIOD
Call AM_PERIOD(zc)
If !mkstat & GOBJET
 zoncou = "PERIOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PERIOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPERIOD)")>indice
 [M]PERIOD(indice) = VALEUR
 Affzo ZPERIOD(indice)
Endif
Gosub _AFF
End

Subprog S_PERIOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10702"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PERIOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10702") From GOBJET
Gosub _AFF
End

Subprog SA_PERIOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10702"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PERIOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10702"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPERIOD
Onevent BEFORE_AREA Gosub AV_ZPERIOD From W1CLD0
Return

$AV_ZPERIOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10702",num$([M]PERIOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_STRDAT
Onevent CONTROL Call C_STRDAT(zc) From W1CLD0
Onevent BEFORE_AREA Gosub AV_STRDAT From W1CLD0
Return

$AV_STRDAT
Chgfmt [M]STRDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_STRDAT(VALEUR) From SUBCLD
If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_ENDDAT
Onevent CONTROL Call C_ENDDAT(zc) From W1CLD0
Onevent BEFORE_AREA Gosub AV_ENDDAT From W1CLD0
Return

$AV_ENDDAT
Chgfmt [M]ENDDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]STRDAT(nolign-1)) From EXEFNC
If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
If !mkstat
 ## Action STD
 Call C_ENDDAT(VALEUR) From SUBCLD
 If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


