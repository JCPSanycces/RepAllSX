#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(250)(1..2) , VALEUR(10)
PARAM(1)="105"
PARAM(2)="000000000100000000000000199955000198761234EUR120000103870FR000000000299988                                                                        "
#PARAM(2)="001111111111111222222222222222333333333333121212010101"
#PARAM(2)="000456789012345000456789012345000456789012010101020202"
#PARAM(2)="Rien ne sert de penser, il faut réfléchir avant"
Call SAISIE_CHAR(VALEUR,PARAM,"FRBKBELCOM","SUBRBB3","") From GSAISIE
End

######################################################################################
# Traitement : SUBRBB3
# -----------------------------------------------------------------------------------
# Description: Releves belges - visualisation des communications structurees
# -----------------------------------------------------------------------------------
######################################################################################

$ACTION
  Case ACTION
    When "DEBUT"   : Gosub DEBUT
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------#
$DEBUT
#-------------------------------------------------------------------------------#
If !clalev([F:TYC]) : Local File TYPCOMBEL [TYC]  : Endif
Local Integer WNOL, ILNG, IPOS
Local Char STEMP(250), TCOMDT(250)

Filter [F:TYC] Where COD=PARAM(1)
Raz [M:RBKC]
[M:RBKC]TYPCOM=PARAM(1) :#-- type de com
IPOS=1
TCOMDT=PARAM(2) :#-- contenu de la com
For [F:TYC]TYC0
  If [F:TYC]FRM<>""
    Onerrgo  ERR_EVAL
    STEMP=vireblc(evalue([F:TYC]FRM),0)
    Onerrgo
  Else
    STEMP=mid$(PARAM(2),IPOS,[F:TYC]LNG)
  Endif
  [M:RBKC]DESLIN(WNOL)=[F:TYC]DESLIN
  [M:RBKC]WCOMVAL(WNOL)=STEMP
  WNOL+=1
  IPOS+=[F:TYC]LNG
Next
[M:RBKC]NBCOM=WNOL

Affzo [M:RBKC]
Filter [F:TYC]
Return

$ERR_EVAL
STEMP=mid$(PARAM(2),IPOS,[F:TYC]LNG)
#-- Erreur en évaluation de la formule
Call ERREUR(mess(65,106,1)-[F:TYC]FRM) From GESECRAN
Resume
######################################################################################

