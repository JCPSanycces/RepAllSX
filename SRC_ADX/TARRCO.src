#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################
$ENREG_DEB
#Code enreg
RESULTAT="DEB"
#Identification de l'émetteur
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 Case [F:DUC]KEYSEN
 When 1 :
   INFO=[F:FCY2]CRN
   Gosub RECUP_INFO From TRTDCS
   RESULTAT+="5"+space$(3)
 When 2 :
   INFO=[F:DUC]LIBKEYSEN
   Gosub RECUP_INFO From TRTDCS
   RESULTAT+="ZZZ"+space$(1)
 Endcase
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Identification du récepteur
Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
If !fstat
 Case [F:ORG]KEYORG
 When 1 :
   INFO=[F:ORG]CRN
   Gosub RECUP_INFO From TRTDCS
   RESULTAT+="5"+space$(3)
 When 2 :
   INFO=[F:ORG]LIBKEYORG
   Gosub RECUP_INFO From TRTDCS
   RESULTAT+="ZZZ"+space$(1)
 Endcase
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
 OK=0 : Return
Endif
Gosub COMDEB1 From TRTDCS
#Type déclaration
RESULTAT+="903"
Gosub COMDEB2 From TRTDCS
#Type de borderau
RESULTAT+=NUMBORD
Gosub COMDEB3 From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR
Gosub ENREG_DT
Gosub ENREG_MR
#Tiers déclarant
If [F:DUC]FLGEXT=2 : Gosub ENREG_AE : Endif
Gosub ENREG_GEN
Return

#########################################
$ENREG_FR
#code enreg
RESULTAT="FR1"
#Intervenant
RESULTAT+="FR"+space$(1)
#Identifiant emetteur
#Identification de l'émetteur
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 Case [F:DUC]KEYSEN
 When 1 :
   INFO=[F:FCY2]CRN
   Gosub RECUP_INFO From TRTDCS
 When 2 :
   INFO=[F:DUC]LIBKEYSEN
   Gosub RECUP_INFO From TRTDCS
 Endcase
Else
 Call ECR_TRACE("FR"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Zone reservée
RESULTAT+=space$(3)
Gosub RECUP_FCY From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR2
Return

#########################################
$ENREG_FR2
#code enreg
RESULTAT="FR2"
#collaborateur
Read [CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If fstat=0
  Gosub RECUP_CNT From TRTDCS
  Call ORGAFFIL ([M:DIA]ORG,[F:FCY2]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
  #no id emetteur chez l'IRC
  If len(VNUMAFF)<35
   RESULTAT+=VNUMAFF+space$(35-len(VNUMAFF))
  Else
   RESULTAT+=left$(VNUMAFF,35)
  Endif
  #Zones non utilisées
  RESULTAT+=space$(132)
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
  Gosub ENREG_FR3
 Else
  Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
  OK=0 : Return
 Endif
Else
 Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_FR3
#code enreg
RESULTAT="FR3"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If !fstat
  Gosub RECUP_EMAIL From TRTDCS
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Else
  Call ECR_TRACE("FR3"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
  OK=0 : Return
 Endif
Else
 Call ECR_TRACE("FR3"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_DT
#code enreg
RESULTAT="DT1"
#Intervenant
RESULTAT+="DT"+space$(1)
#Siret déclarant
Read[F:FCY2]FCY0=[F:DUC]FCYDCL
If !fstat
 If [F:FCY2]CRN=""
  #Identification du déclarant
  Call ECRIT_TRACE("DT1",mess(7,10707,1)) From TRTDCS
 Else
  If len ([F:FCY2]CRN)<35
   RESULTAT+=[F:FCY2]CRN+space$(35-len([F:FCY2]CRN))
  Else
   RESULTAT+=left$([F:FCY2]CRN,35)
  Endif
 Endif
Else
 Call ECR_TRACE("DT1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Zone reservée
RESULTAT+=space$(3)
Gosub RECUP_FCY From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_DT2
Return

#########################################
$ENREG_DT2
#code enreg
RESULTAT="DT2"
#collaborateur
Read [CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Gosub RECUP_CNT From TRTDCS
 #no id adhérent chez l'IRC
 Call ORGAFFIL ([M:DIA]ORG,[F:FCY2]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 If len(VNUMAFF)<35
  RESULTAT+=VNUMAFF+space$(35-len(VNUMAFF))
 Else
  RESULTAT+=left$(VNUMAFF,35)
 Endif
 #Code NAF/APE
 If len ([F:FCY2]NAF)<35
  RESULTAT+=[F:FCY2]NAF+space$(35-len([F:FCY2]NAF))
 Else
  RESULTAT+=left$([F:FCY2]NAF,35)
 Endif
 #Zones non utilisées
 RESULTAT+=space$(97)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_DT3
Else
 Call ECR_TRACE("DT2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_DT3
#code enreg
RESULTAT="DT3"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If !fstat
  Gosub RECUP_EMAIL From TRTDCS
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Else
  Call ECR_TRACE("DT3"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
  OK=0 : Return
 Endif
Else
 Call ECR_TRACE("DT3"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_MR
#code enreg
RESULTAT="MR1"
#Intervenant
RESULTAT+="MR"+space$(1)
#Siret organisme
INFO=[F:ORG]CRN
Gosub RECUP_INFO From TRTDCS
#Zone reservée
RESULTAT+=space$(3)
Read [F:ORG]ORG0=GCURLEG;[M:DIA]ORG
If fstat=0
 #Nom1
 If len([F:ORG]DES)<35
  RESULTAT+=[F:ORG]DES+space$(35-len([F:ORG]DES))
 Else
  RESULTAT+=left$([F:ORG]DES,35)
 Endif
 #Nom2
 RESULTAT+=space$(35)
 #Adresse
 If len([F:ORG]ADD(0))<35
  RESULTAT+=[F:ORG]ADD(0)+space$(35-len([F:ORG]ADD(0)))
 Else
  RESULTAT+=left$([F:ORG]ADD(0),35)
 Endif
 If len([F:ORG]ADD(1))<35
  RESULTAT+=[F:ORG]ADD(1)+space$(35-len([F:ORG]ADD(1)))
 Else
  RESULTAT+=left$([F:ORG]ADD(1),35)
 Endif
 If len([F:ORG]CTY)<35
  RESULTAT+=[F:ORG]CTY+space$(35-len([F:ORG]CTY))
 Else
  RESULTAT+=left$([F:ORG]CTY,35)
 Endif
 If len([F:ORG]POS)<9
  RESULTAT+=[F:ORG]POS+space$(9-len([F:ORG]POS))
 Else
  RESULTAT+=left$([F:ORG]POS,9)
 Endif
 #Filler
 RESULTAT+=space$(27)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_MR2
Else
 Call ECR_TRACE("MR1"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_MR2
#code enreg
RESULTAT="MR2"
#collaborateur
If len ([F:ORG]CNT)<35
 RESULTAT+=[F:ORG]CNT+space$(35-len([F:ORG]CNT))
Else
 RESULTAT+=left$([F:ORG]CNT,35)
Endif
#téléphone
If len ([F:ORG]TEL)<25
 RESULTAT+=[F:ORG]TEL+space$(25-len([F:ORG]TEL))
Else
 RESULTAT+=left$([F:ORG]TEL,25)
Endif
#fax
If len ([F:ORG]FAX)<25
 RESULTAT+=[F:ORG]FAX+space$(25-len([F:ORG]FAX))
Else
 RESULTAT+=left$([F:ORG]FAX,25)
Endif
#No Agrement
Read[F:ADI]CODE=10340;[F:ORG]NUMDCS
If !fstat
 If [F:ADI]A1<>""
  If len([F:ADI]A1)<35
    RESULTAT+=[F:ADI]A1+space$(35-len([F:ADI]A1))
  Else
    RESULTAT+=left$([F:ADI]A1,35)
  Endif
 Endif
Else
 Call ECR_TRACE("MR2"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
 OK=0 : Return
Endif

#Zones inutilisées+filler
RESULTAT+=space$(132)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]

#MR3 Non utilisé en 4.2 -> ne pas fournir !!!
#Gosub ENREG_MR3
Return

#########################################
$ENREG_MR3
#code enreg
RESULTAT="MR3"
If len ([F:ORG]WEB)<252
 RESULTAT+=[F:ORG]WEB+space$(252-len([F:ORG]WEB))
Else
 RESULTAT+=left$([F:ORG]WEB,252)
Endif
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
