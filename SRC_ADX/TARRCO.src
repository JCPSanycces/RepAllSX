#########################################
$ENREG_AE3
#code enreg
RESULTAT="AE3"
If len ([F:DUC]WEBEXT)<252
 RESULTAT+=[F:DUC]WEBEXT+space$(252-len([F:DUC]WEBEXT))
Else
 RESULTAT+=left$([F:DUC]WEBEXT,252)
Endif
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Return


#########################################
$ENREG_GEN
If [M:DIA]FLGNEA=2 : Raz AMTTOT : Raz NBLIGN : Endif
#code enreg
RESULTAT="GEN"
Case [L]NUMBORD
 When "931" :
  Call RECUP_DATE ([M:DIA]STRDAT, "AAAAMM", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(29)+"610"
 When "930" :
  Call RECUP_DATE ([M:DIA]STRDAT, "AAAAT", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(30)+"608"
 When "932" :
  Call RECUP_DATE ([M:DIA]STRDAT, "AAAA", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(31)+"602"
Endcase
#période2 + qualifiant période2
RESULTAT+=space$(38)
#effectif non utilisé
RESULTAT+=string$(15,"0")
#statut juridique non utilisé
RESULTAT+=space$(35)
#Montant 1 Total cotisation (en centimes)
RESULTAT+=string$(18-len(num$(abs(AMTTOT)*100)),"0")+num$(abs(AMTTOT)*100)
#Qualifiant montant1
If AMTTOT>=0 : RESULTAT+="277" : Else : RESULTAT+="977" : Endif
#montant 2 crédit à déduire (en centimes mais attention ne pas arrondir CREDIT)
RESULTAT+=string$(18-len(num$(abs(CREDIT)*100)),"0")+num$(abs(CREDIT)*100)
#Qualifiant montant2
If CREDIT<>0 : RESULTAT+="210" : Else : RESULTAT+=space$(3) : Endif
#montant 3 débit à ajouter  (en centimes mais attention ne pas arrondir DEBIT)
RESULTAT+=string$(18-len(num$(abs(DEBIT)*100)),"0")+num$(abs(DEBIT)*100)
#Qualifiant montant3
If DEBIT<>0 : RESULTAT+="211" : Else : RESULTAT+=space$(3) : Endif
#nb lignes(18 caractères)
RESULTAT+=string$(18-len(num$(NBLIGN)),"0")+num$(NBLIGN)
#authentification
RESULTAT+=space$(35)
#devise
RESULTAT+=DEVISE
#filler
RESULTAT+=space$(7)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Return

#########################################
$ENREG_EN
#Code enreg
RESULTAT="EN1"
#qualif intervenant
RESULTAT+="WP"+space$(1)
Read[F:FCY2]FCY0=[F:FCY]FCY
If fstat=0
 #identification intervenant
 INFO=[F:FCY2]CRN
 Gosub RECUP_INFO From TRTDCS
 RESULTAT+=space$(3)
 Gosub RECUP_FCY From TRTDCS
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN2
Else
 Call ECR_TRACE("EN1"-mess(4,10707,1)-"COMPANY [CPY]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN2
#Code enreg
RESULTAT="EN2"
#collaborateur
Read [CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Gosub RECUP_CNT From TRTDCS
 #no contrat chez l'IRC (rattachement)
 Call ORGAFFIL ([M:DIA]ORG,[F:FCY2]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 If len(VNUMCTR)<35
  RESULTAT+=VNUMCTR+space$(35-len(VNUMCTR))
 Else
  RESULTAT+=left$(VNUMCTR,35)
 Endif
 #Zones inutilisées
 RESULTAT+=space$(132)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN3
Else
 Call ECR_TRACE("EN2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN3
#Mtt à Zéro si déclaration néant
If [M:DIA]FLGNEA=2 : Raz AMTFCY : Endif

#Code enreg
RESULTAT="EN3"
#Date/Période + Qualifiant date /période
RESULTAT+=space$(38)
#Montant 1 : Total cotisations (en centimes)
RESULTAT+=string$(18-len(num$(abs(AMTFCY)*100)),"0")+num$(abs(AMTFCY)*100)
#Qualifiant montant 1
If AMTFCY>=0 : RESULTAT+="277" : Else : RESULTAT+="977" : Endif
#Montant 2 +qualifiant 2
RESULTAT+=string$(18,"0")+space$(3)
#Montant 3 +qualifiant 3
RESULTAT+=string$(18,"0")+space$(3)
#Qualifiant date /période + Date/Période Qualifiant + date /période
RESULTAT+=space$(8)
#Montant 4 +qualifiant 4
RESULTAT+=string$(18,"0")+space$(3)
#Filler
RESULTAT+=space$(122)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
If [M:DIA]FLGNEA<>2
 If FLGGRP
  #cotisations regroupés de tous les sites
  CRITCOT="1=1"
  Gosub ENREG_COT
 Else
  #Cotisations du site courant
  CRITCOT="FCY=[F:FCY2]FCY"
  Gosub ENREG_COT
 Endif
Endif
Return

#########################################
$ENREG_COT
COMPTEUR=0
For[F:TDU]TDU0 Where USR=GUSER & CREDAT=date$ & CAI=[M:DIA]CAI & evalue(CRITCOT)
 #Code enreg
 RESULTAT="COT"
 #Qualif ligne cotisation
 #51407 : Ajout test TYPDCS (vaut 1  pour l'AGFF)
 If [F:TDU]CAICOD=GINDARR
  Read[ADI]CODE=10377;[F:TDU]CODDCS
  If !fstat
   If [F:ADI]N1>99 & [F:ADI]N1<1000
    RESULTAT+=num$([F:ADI]N1)
   Elsif  [F:TDU]TYPDCS=1
    RESULTAT+="912" :#AGFF
   Else
    RESULTAT+="908" :#Arrco par défaut
   Endif
  Else
   Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
   OK=0 : Break
  Endif
 Elsif [F:TDU]CAICOD=GINDAGI
  Read[ADI]CODE=10377;[F:TDU]CODDCS
  If !fstat
   If [F:ADI]N1>99 & [F:ADI]N1<1000
    RESULTAT+=num$([F:ADI]N1)
   Elsif  [F:TDU]TYPDCS=1
    RESULTAT+="912" :#AGFF
   Else
    RESULTAT+="907" :#Agirc par défaut
   Endif
  Else
   Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV[ADI]",1) From GESECRAN
   OK=0 : Break
  Endif
 Else
  #73621
  Read[ADI]CODE=10377;[F:TDU]CODDCS
  If !fstat :
   RESULTAT+=num$([F:ADI]N1)
  Else
   RESULTAT+="909" :#Prevoyance par défaut
  Endif
 Endif
 If !OK : Break : Endif
 Read[ADI]CODE=10377;[F:TDU]CODDCS
 If !fstat
  #Type cotisation
  RESULTAT+=[F:ADI]A2
 Else
  Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
  OK=0 : Break
 Endif
 #Qualif instruction + qualifiant
 If [F:TDU]LIBREF2<>""
  RESULTAT+="CSC"+[F:TDU]LIBREF2
 Else
  RESULTAT+="CSC"+"SCS"
 Endif
 #No ligne
 COMPTEUR=COMPTEUR+1
 If len(num$(COMPTEUR))<6
  RESULTAT+=string$(6-len(num$(COMPTEUR)),"0")+num$(COMPTEUR)
 Else
  RESULTAT+=left$(num$(COMPTEUR),6)
 Endif
 #Date de début de changements de cotisations sur 35 cacarctères
 If [F:TDU]PERDEB<>[0/0/0]
  Call RECUP_DATE ([F:TDU]PERDEB, "AAAAMMJJ", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(35-len(WDAT))+"102"
 Else
  RESULTAT+=space$(38)
 Endif
 #% cotisations (pas de taux pour les forfaits)
 If [F:TDU]NBREMP2=0
  RESULTAT+=string$(8-len(num$([F:TDU]RAT*10000)),"0")+num$([F:TDU]RAT*10000)
 Else
  RESULTAT+=string$(8,"0")
 Endif
 #Type montant(941 = positif ; 951 = négatif)
 If [F:TDU]AMT3>=0 :  RESULTAT+="941" : Else :  RESULTAT+="951" : Endif
 #Montant1 cotisation (en centimes)
 RESULTAT+=string$(18-len(num$(abs(arr([F:TDU]AMT3,1))*100)),"0")+num$(abs(arr([F:TDU]AMT3,1))*100)
 #Champ réservé
 RESULTAT+=space$(3)
 #Type base forfait/assiette
 #(940 = assiette positive ; 950 = assiette négative)
 #(942 = forfait positif ; 952 = forfait négatif)
 If [F:TDU]AMT1>0
  RESULTAT+="940"
 Elsif [F:TDU]AMT1<0
  RESULTAT+="950"
 Elsif [F:TDU]AMT2>0
  RESULTAT+="942"
 Elsif [F:TDU]AMT2<0
  RESULTAT+="952"
 Elsif [F:TDU]AMT1=0 & [F:TDU]AMT2=0
  RESULTAT+=space$(3)
 Endif
 If [F:TDU]AMT1<>0
  #Montant2 Assiette (en centimes)
  RESULTAT+=string$(18-len(num$(abs(arr([F:TDU]AMT1,1))*100)),"0")+num$(abs(arr([F:TDU]AMT1,1))*100)
 Else
  #Montant2 Forfait (en centimes : attention ne pas arrondir le forfait)
  RESULTAT+=string$(18-len(num$(abs([F:TDU]AMT2)*100)),"0")+num$(abs([F:TDU]AMT2)*100)
 Endif
 #Champ réservé
 RESULTAT+=space$(3)
 If [F:TDU]NBREMP1>0
  #Effectif
  RESULTAT+=string$(15-len(num$([F:TDU]NBREMP1)),"0")+num$([F:TDU]NBREMP1)
 Else
  RESULTAT+=string$(15,"0")
 Endif
 If[F:TDU]NBREMP2>0
  #Nb forfait sur 4 decimales (1->10000)
  RESULTAT+=string$(15-len(num$([F:TDU]NBREMP2*10000)),"0")+num$([F:TDU]NBREMP2*10000)
 Else
  RESULTAT+=string$(15,"0")
 Endif
 #Qualifiant ref 1 (Prof ou cat socio-pro)
 RESULTAT+="GCO"
 #No ref 1 (code CPN)
 If [F:TDU]LIBREF1<>""
  Read[F:ADI]CODE=10389;[F:TDU]LIBREF1
  If !fstat & [F:ADI]A1<>""
   If len([F:ADI]A1)<35
    RESULTAT+=[F:ADI]A1+space$(35-len([F:ADI]A1))
   Else
    RESULTAT+=left$([F:ADI]A1,35)
   Endif
  Else
   Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
   OK=0 : Break
  Endif
 Else
  RESULTAT+="999"+space$(32) :#Tous régimes par défaut
 Endif
 #Qualifiant ref 2
 RESULTAT+="AFN"
 Read[F:ORG]ORG0=GCURLEG;[F:TDU]ORGCOD
 If !fstat & [F:ORG]NUMDCS<>""
  Read[F:ADI]CODE=10340;[F:ORG]NUMDCS
  If !fstat
   If [F:ADI]A1<>""
    If len([F:ADI]A1)<35
     RESULTAT+=[F:ADI]A1+space$(35-len([F:ADI]A1))
    Else
     RESULTAT+=left$([F:ADI]A1,35)
    Endif
   Endif
  Else
   Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
   OK=0 : Break
  Endif
 Else
  Call ECR_TRACE("COT"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
  OK=0 : Break
 Endif
 #Filler
 RESULTAT+=space$(34)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Next
Return

#########################################
$ENREG_PAI
#Code enreg
RESULTAT="PAI"
Call ORGBAN([M:DIA]ORG,[M:DIA]CPY,[L]MODPAY,[L]BAN(0),[L]BAN(1)) From SUBORA
If [L]MODPAY
 #Mode de paiement +Qualif du compte bancaire
 If [L]MODPAY=1     :#chèque
  RESULTAT+="20"+space$(1)
  RESULTAT+="BF"+space$(1)
  RESULTAT+=space$(75)
 Elsif [L]MODPAY=2  :#virement
  RESULTAT+="30"+space$(1)
  RESULTAT+="BF"+space$(1)
  Call RECUP_ORG ([M:DIA]COD,RESULTAT,OK)From TRTDCS
 Else                      :#télérèglement
  RESULTAT+="Z10"
  RESULTAT+="OR"+space$(1)
  If [M:DIA]BANFCY(NUMBANK)<>""
   Call RECUP_BANK ([M:DIA]BANFCY(NUMBANK),RESULTAT,OK)From TRTDCS
  Else
   #Banque non renseignée
   Call ECR_TRACE("PAI"-mess(20,10711,1),1) From GESECRAN
   OK=0 : Return
  Endif
 Endif
 If OK=0 : Return : Endif
 #Montant réglé (en centimes : attention ne pas arrondir le montant du paiement)
 If NUMBANK=0
  If MAXAMT<>0 & MAXAMT<AMTTOT
   RESULTAT+=string$(18-len(num$(abs(MAXAMT)*100)),"0")+num$(abs(MAXAMT)*100)
  Else
   RESULTAT+=string$(18-len(num$(abs(AMTTOT)*100)),"0")+num$(abs(AMTTOT)*100)
  Endif
 Else
  RESULTAT+=string$(18-len(num$(abs(AMTTOT)*100-abs(MAXAMT)*100)),"0")+num$(abs(AMTTOT)*100-abs(MAXAMT)*100)
 Endif
 #Devise
 RESULTAT+=DEVISE+space$(3-len(DEVISE))
 #Type de référence
 If [L]MODPAY<3     :#chèque ou virement
  RESULTAT+="PQ"+space$(1)
  RESULTAT+="99" :#pour clé non calculée
  RESULTAT+="S3" :#IRC
  Call ORGAFFIL ([M:DIA]ORG,[M:DIA]CPY,"","",VNUMAFF,VNUMCTR) From SUBORA
  INFO=VNUMCTR
  Gosub REF_SOCIALE From TRTDCS
 Else
  RESULTAT+="CR"+space$(1)
  RESULTAT+="IRC"+space$(5)
  Gosub REF_CPOP From TRTDCS
 Endif
 #Filler
 RESULTAT+=space$(71)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Else
 Call ECR_TRACE("PAI"-mess(4,10707,1)-"ORGBAN [ORB]",1) From GESECRAN
 OK=0 : Return
Endif
Return
