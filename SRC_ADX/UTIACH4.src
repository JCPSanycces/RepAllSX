#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTIACH4        Utilitaire de récupération du bug 12109    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Resynchroniser la quantité commandée de la ligne article-contrat     #
#   avec le cumul des quantités commandées des DL fermes                 #
##########################################################################

Call MAJ_UTIACH4
End

Subprog MAJ_UTIACH4
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH4") From SAIDOS
If DOSSIER<>"" Call EXE_UTIACH2(DOSSIER) : Endif
End

Subprog EXE_UTIACH2(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WNUM(GLONPOH), CLE1(GLONPOH), CRITERE(50), WLINA(8)
Local Decimal  WQTYPUU,  WQTYSTU 
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR, WLIN, CLE2
#-----
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH4 : Utilitaire de recalcul des quantités commandées par contrat") From LECFIC
Call ECR_TRACE("UTIACH4 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:POQ]) =0  Local File =DOSSIER+".PORDERQ"    [POQ] : Endif 
If clalev([F:POC]) =0  Local File =DOSSIER+".PORDERC"    [POC] : Endif 
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, NBENR, NBCOR
#-----
$BOUCLE_POC
If STOP=1
  STOP=2 : CRITERE='POHNUM="'+CLE1+'" & POPLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POC]
  For [POC] Where evalue(CRITERE)
    WNUM =[F:POC]POHNUM
    WLIN =[F:POC]POPLIN
    WLINA=mid$("        ",1,8-len(num$([F:POC]POPLIN)))+num$([F:POC]POPLIN)
    If COMPTEUR=0
      Call ECR_TRACE("----- Début de transaction ("+WNUM-num$(WLIN)+")",0) From GESECRAN
    Endif
    NBENR+=1
    Raz WQTYPUU
    For [POQ] POQ0 Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN & WIPSTA=1
      WQTYPUU+=[F:POQ]QTYPUU
    Next
    If WQTYPUU<>[F:POC]ORDQTYPUU
      WMSG ="Contrat"-WNUM+WLINA
      WMSG-="Rectification qté commandée ("+[F:POC]PUU+")"
      WMSG-=num$([F:POC]ORDQTYPUU)-"-->"-num$(WQTYPUU)
      #----- Calcul qté commandée en US -----# 
      Call PCAL_QTY(WQTYPUU,[F:POC]PUU,WQTYSTU,[F:POC]STU,[F:POC]ITMREF, 
&                   [F:POC]BPSNUM,1,GBIDD1) From TRTACHQTE1 
      Update [POC] Where POHNUM=WNUM & POPLIN=WLIN
&                  With  ORDQTYPUU=WQTYPUU, ORDQTYSTU=WQTYSTU
      If fstat
        GOK=0 : Call FSTA("POC") From GLOCK
      Else
        NBCOR+=1 : Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Endif
    If GOK=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS : CLE1=[F:POC]POHNUM : CLE2=[F:POC]POPLIN : STOP=1 : Break : Endif
    Else
      Break
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM-num$(WLIN)+")",1) From GESECRAN
    Goto FIN_UTIACH4
  Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM-num$(WLIN)+")",0) From GESECRAN
Endif
If STOP  Goto BOUCLE_POC : Endif
#----- Fin du traitement -----#
$FIN_UTIACH4
Call TEMPOFF From GESECRAN
WMSG ="UTIACH4 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Close Local File [POC]
Close Local File [POQ]
End
