#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGPOSCPT03                                          Module  Accounting #
#                                                                          #
#              Post-migration of Commitments                               #
#                                                                          #
# Management of new field  : UOM                                           #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSCPT03") From LECFIC
  Endif

  #Call RAZ_UUMGPOSCPT03(DOSSIER)
  Call MAJ_UUMGPOSCPT03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSCPT03(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSCPT03",ERR) From TRTMIG

End

###################################################################################
Subprog MAJ_UUMGPOSCPT03(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(1)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGPOSCPT03 Commitment Process : Update GCOMMITD - Fields : UOM") From DOSSUB
Call ECR_TRACE("UUMGPOSCPT03 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Index addition  ----------#
Call MIGINDCRE (DOSSIER,"GCOMMITD","CPY+NUM+LIN","","",0,ERR) From TRTMIG
If ERR
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",7,ERR) From TRTMIG : Goto FIN
Endif

#--------------- Opening of files  -----#
If clalev([F:CMD]) : Close File [CMD] : Endif
If clalev([F:CMD])  = 0 : Local File =DOSSIER+".GCOMMITD"      [CMD]  : Endif

If clalev([F:GAC])  = 0 : Local File =DOSSIER+".GACCOUNT"    [GAC]   : Endif
If clalev([F:GCM])  = 0 : Local File =DOSSIER+".GACM"        [GCM]   : Endif
If clalev([F:CPY])  = 0 : Local File =DOSSIER+".COMPANY"     [CPY]   : Endif

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3
Local Date DCLE1
Local Integer TYPANA

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT03
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:CMD]UOM='' & [F:CMD]CPY='"+ACLE1+"' & [F:CMD]NUM='"+ACLE2+"' & [F:CMD]LIN>"+num$(ICLE1)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:CMD]UOM='' & [F:CMD]CPY='"+ACLE1+"' & [F:CMD]NUM>'"+ACLE2+"'"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:CMD]UOM='' & [F:CMD]CPY>'"+ACLE1+"'"
Else
 CRITERE = "[F:CMD]UOM='' & 1=1"
Endif

Trbegin [CMD]
GOK = 1


For [CMD]MIG(1) Where evalue(CRITERE)

 # By company
 TYPANA = 0
 Read [CPY]CPY0 = [F:CMD]CPY
 If !fstat
  If [F:CPY]ACM <> [F:GCM]GCM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif
  If  [F:GCM]LED(1)<>""
   TYPANA = 2
  Else
   If [F:GCM]ANALEDTYP=0
    # Reading error - Account Core Model doesn't exist
    TYPANA = 0 : GOK=0 : Call ERREUR(mess(2,45,1)-[F:CMD]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Else
    TYPANA = [F:GCM]ANALEDTYP
   Endif
  Endif
 Else
  # No company... Migration isn't avaiable for journal entries
  GOK = 0 : Call ERREUR([F:CMD]CPY-mess(16,104,1),4) From DOSDIC
 Endif

 For [CMD]MIG

  NBLUS+=1

  If [F:CMD]COA([L]TYPANA-1)<>"" & [F:CMD]ACC([L]TYPANA-1)<>""
   OK = 0
   If [F:GAC]ACC<>[F:CMD]ACC([L]TYPANA-1) | [F:GAC]COA<>[F:CMD]COA([L]TYPANA-1)
    Read [GAC]GAC0 = [F:CMD]COA([L]TYPANA-1);[F:CMD]ACC([L]TYPANA-1)
    OK=fstat
   Endif

   If !OK & [F:CMD]UOM<>[F:GAC]UOM
    [F:CMD]UOM=[F:GAC]UOM
    Rewrite [F:CMD]
    If fstat
     Call ECR_TRACE("File GCOMMITD(NUM/LIN)"-[F:CMD]NUM+"/"+num$([F:CMD]LIN)+", Error ="-num$(fstat),1) From GESECRAN
     GOK=0 : Break
    Endif

    NBCOMMIT += 1
   Endif

   NB+=1
   If NB>GMAXUPDTRS
    ACLE1 = [F:CMD]CPY
    ACLE2 = [F:CMD]NUM
    ICLE1 = [F:CMD]LIN
    STOP=1
    Break 2
   Endif

  Endif
 Next
Next

If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT03",7,ERR) From TRTMIG
Else
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSCPT03",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT03
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [CMD]

#--------------- Deleting an index ----------#
Call MIGINDDEL (DOSSIER,"GCOMMITD",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSCPT03") From TRTMIG
Call ECR_TIME("UUMGPOSCPT03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

