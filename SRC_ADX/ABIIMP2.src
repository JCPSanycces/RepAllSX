#<AdxTL>@(#)5.0.0.0 $Revision$
GTEST = 0
Raz GNBMASKOUV
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIIMP","ABIIMP",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "DEBUT"     : Gosub DEBUT
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

$INIT
If !clalev([M:RPT])
 FIN = 1 : Return
Endif

Call CONT_COD([M:RPT]COD,GMESSAGE,GBIDI1) From ABIIMP
mkstat = GBIDI1
If mkstat : FIN = 1 : Return : Endif

Call VARPSEBO(GUSER,GBIDC1,GBIDC2,GBIDC3,GBIDI1,GBIDI2) From GESUSER
If !GBIDI2 & GFUSION=0
 Call ERREUR(mess(74,100,1)-":"-GBIDC3) From GESECRAN : # Fonction non autorisée
 Raz GBIDC1,GBIDC2,GBIDI1
 FIN =1
Endif
Local Mask ABIIMP2   [RPT2]
If !clalev([F:ABO]) : Local File ABIREPORT [ABO] : Endif
If !clalev([F:ABOID]) : Local File ABIREPORTID [F:ABOID] : Endif
If !clalev([F:ABW]) : Local File ABIDATWRH [ABW] : Endif
Return

$DEBUT
Raz  [RPT2]
Local Char ETAT(50) : ETAT = PARAM(1)
Local Char DATAWARE(GLONABW)
Local Char VALEUR(250)
Local Integer JJ,MM,AA
Read [ABO]ABO0 = ETAT
If !fstat
 Call S_LIS_CHAR(DATAWARE,PARAM,"SELDATWAR","ABIIMP2","") From GACTION
 Read [F:ABOID]ABOID0 = ETAT;DATAWARE;GLANGUE
 If fstat : Call ERREUR(func AFNC.MES2(mess(166,148,1), ETAT, GREPBI+"."+GINSTID+"."+DATAWARE+"."+GLANGUE)) From GESECRAN: FIN = 1 : Return : Endif
 GPE = 0
 GPOINT = "DEFPATH1" : Gosub ENTREE From EXEFNC
 If !GPE
  [M:RPT2]DOCID = [F:ABOID]DOCID
  [M:RPT2]RAPPORT = [F:ABO]REPCOD
  [M:RPT2]REP1(0) = GREPBI
  [M:RPT2]REP1(1) = GINSTID
  [M:RPT2]REP1(2) = DATAWARE
  [M:RPT2]REP1(3) = GLANGUE
  GPOINT = "DEFPATH2" : Gosub ENTREE From EXEFNC
  For I=0 To [M:RPT]NBRPAR-1
   Case [M:RPT]TYPBO(I)
    When 1 : [M:RPT2]INVT(I) = "S"
    When 2 : [M:RPT2]INVT(I) = "M"
    When 3 : [M:RPT2]INVT(I) = "R"
   Endcase
   [M:RPT2]INV1(I) = [M:RPT]PARDES(I)
   VALEUR = [M:RPT]VALINT1(I)
   Case [M:RPT]TYPTYP(I)
    When 1,2,3,4 : If VALEUR="" : VALEUR = "0" : Endif
    When 7       :
     If VALEUR="" & [M:RPT]STREND(I)=2 : VALEUR = " " : Endif
    When 8       :
     If VALEUR="" or VALEUR="000000" or VALEUR="00000000"
      #VALEUR = format$("D:"+GDATBO,"18000101")
      Call FORMAT_DATE("DD[/]MM[/]YYYY","01/01/1800",GDATBO,JJ,MM,AA,VALEUR)
     Else
      #VALEUR =  format$("D:"+GDATBO,[M:RPT]VALEUR1(I))
      Call FORMAT_DATE(GFMDAT4,[M:RPT]VALEUR1(I),GDATBO,JJ,MM,AA,VALEUR)
     Endif
   Endcase
   If [M:RPT]STREND(I)=3
    Case [M:RPT]TYPTYP(I)
     When 1 : If val(VALEUR)=0 : VALEUR = "255" : Endif
     When 2 : If val(VALEUR)=0 : VALEUR = "32767" : Endif
     When 3 : If val(VALEUR)=0 : VALEUR = "99999999" : Endif
     When 4 : If val(VALEUR)=0 : VALEUR = "999999999999999" : Endif
     When 7 : If VALEUR=""     : VALEUR = "zzzzzzzzzz" : Endif
     When 8 :
      If VALEUR="" or VALEUR="000000" or VALEUR="00000000"
       #VALEUR = format$("D:"+GDATBO,"29991231")
       Call FORMAT_DATE("DD[/]MM[/]YYYY","31/12/2999",GDATBO,JJ,MM,AA,VALEUR)
      Else
       #VALEUR =  format$("D:"+GDATBO,[M:RPT]VALEUR1(I))
       Call FORMAT_DATE(GFMDAT4,[M:RPT]VALEUR1(I),GDATBO,JJ,MM,AA,VALEUR)
      Endif
    Endcase
   Endif
   [M:RPT2]INV2(I) = VALEUR
  Next I
  Gosub CREBO
 Endif
Endif
Return


$SEL_LISTE
Case LISTE
 When "SELDATWAR" : Gosub SEL_DATWAR
Endcase
Return

$SEL_DATWAR
Local Char TEXTE(GLONADD)(1..GNBSEL,1..3) , TEX(GLONABW)(1..GNBSEL)
If clalev([ABW])=0 : Local File ABIDATWRH [ABW] : Endif
For [ABW]ABW0
 For  I=0 To [F:ABW]NBRABM-1
  If [F:ABW]CODABM(I) = [F:ABO]DATAM
   NBTEX += 1
   TEX(NBTEX) = [F:ABW]COD
   TEXTE(NBTEX,2) = [F:ABW]INTIT
   TEXTE(NBTEX,3) = [F:ABW]LAN
   Break
  Endif
 Next I
Next ABW
TIT(0) = mess(90,148,1) : # CHOIX DU DATAWAREHOUSE ?
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
TIT(3) = mess(259,123,1) : #LANGUE
Return

Subprog  FORMAT_DATE(FORMATORI,VALEUR,FORMATDES,JOUR,MOIS,ANNEE,VALEUR2)
Value    Char    FORMATORI
Value    Char    VALEUR
Value    Char    FORMATDES
Variable Integer JOUR
Variable Integer MOIS
Variable Integer ANNEE
Variable Char    VALEUR2

Local Date    VALDAT
Local Integer DD , MM , YY
Local Integer I , J , V1 , V2 , V3
Local Char SEPA

DD = instr(1,FORMATORI,"DD")
MM = instr(1,FORMATORI,"MM")
YY = instr(1,FORMATORI,"YY")

If DD=0 or MM=0 or YY=0
 GMESSAGE = FORMATORI-":"-mess(149,100,1) : End : # Format incorrect
Endif
I = instr(1,VALEUR,"/")
J = instr(I+1,VALEUR,"/")
If I & J>I
 V1 = val(left$(VALEUR,I-1))
 V2 = val(seg$(VALEUR,I+1,J-1))
 V3 = val(right$(VALEUR,J+1))
 If V1<100 : VALEUR  = format$("N0:2#",V1) : Else : VALEUR  = format$("N0:4#",V1) : Endif
 If V2<100 : VALEUR += format$("N0:2#",V2) : Else : VALEUR += format$("N0:4#",V2) : Endif
 If V3<100 : VALEUR += format$("N0:2#",V3) : Else : VALEUR += format$("N0:4#",V3) : Endif
Else
 I = 1
 While I<=len(VALEUR)
  If !instr(1,"0123456789",mid$(VALEUR,I,1))
   VALEUR = left$(VALEUR,I-1)+right$(VALEUR,I+1)
  Else
   I += 1
  Endif
 Wend
Endif
If DD<MM
 If    YY<DD : V1 = 1 : V3 = 5 : V2 = 7
 Elsif YY>MM : V3 = 1 : V2 = 3 : V1 = 5
 Else        : V3 = 1 : V1 = 3 : V2 = 7
 Endif
Else
 If    YY<MM : V1 = 1 : V2 = 5 : V3 = 7
 Elsif YY>DD : V2 = 1 : V3 = 3 : V1 = 5
 Else        : V2 = 1 : V1 = 3 : V3 = 7
 Endif
Endif
ANNEE = val(mid$(VALEUR,V1,4))
MOIS  = val(mid$(VALEUR,V2,2))
JOUR  = val(mid$(VALEUR,V3,2))

If toupper(GBOVERSION)='R4'
 VALEUR2 = "Date("+num$(ANNEE)+","+num$(MOIS)+","+num$(JOUR)+")"
Else

 DD = instr(1,FORMATDES,"DD")
 MM = instr(1,FORMATDES,"MM")
 YY = instr(1,FORMATDES,"YY")
 If instr(1,FORMATDES,"[")>0 & instr(1,FORMATDES,"]")>0
  SEPA = seg$(FORMATDES,instr(1,FORMATDES,"[")+1,instr(1,FORMATDES,"]")-1)
 Endif

 If DD<MM & MM<YY    : VALEUR2 = format$("N0:2",num$(JOUR))+SEPA+format$("N0:2",num$(MOIS))+SEPA+num$(ANNEE)

 Elsif DD<MM & YY<MM : VALEUR2 = format$("N0:2",num$(JOUR))+SEPA+num$(ANNEE)+SEPA+format$("N0:2",num$(MOIS))

 Elsif MM<DD & DD<YY : VALEUR2 = format$("N0:2",num$(MOIS))+SEPA+format$("N0:2",num$(JOUR))+SEPA+num$(ANNEE)

 Elsif MM<DD & YY<DD : VALEUR2 = format$("N0:2",num$(MOIS))+SEPA+num$(ANNEE)+SEPA+format$("N0:2",num$(JOUR))

 Elsif YY<DD & DD<MM : VALEUR2 = num$(ANNEE)+format$("N0:2",num$(JOUR))+SEPA+format$("N0:2",num$(MOIS))

 Elsif YY<DD & MM<DD : VALEUR2 = num$(ANNEE)+SEPA+format$("N0:2",num$(MOIS))+SEPA+format$("N0:2",num$(JOUR))

 Endif
Endif
End


######################################################################################
$CREBO
Local Integer I
Local Char BOTYP(1)(1..100)
Local Char BOINV(80)(1..100)
Local Char BOVAL(80)(1..100)
For I=1 To dim([M:RPT2]INVT)
 If [M:RPT2]INV1(I-1)<>""
  BOTYP(I)=[M:RPT2]INVT(I-1)
  BOINV(I)=[M:RPT2]INV1(I-1)
  BOVAL(I)=[M:RPT2]INV2(I-1)
 Endif
Next I

GPOINT = "CREURLBO" : Gosub ENTREE From EXEFNC

If GTEST
 Local Mask AFFCLOB [AFF]
 Raz [M:AFF]
 For I=1 To dim(BOINV)
  If BOINV(I)<>""
    Append [M:AFF]AFFCLB , BOTYP(I)-"--"-BOINV(I)-"--"-BOVAL(I)+chr$(10)
  Endif
 Next
 Call DIALWIN(GBIDI1,mess(258,139,1),"AFFCLOB") From GESECRAN : # Visualisation source
 Call OUINON(mess(00205,00100,1),GBIDI2) From GESECRAN : # Voulez-vous continuer ?
 If GBIDI2<>2
  FIN = 1 : Return
 Endif
Endif

If toupper(GBOVERSION)='R4'
 Call CREURLBO([M:RPT2]DOCID,[M:RPT2]REP1,BOTYP,BOINV,BOVAL) From INTRUTILA
Else
 Call CREURLBO([M:RPT2]RAPPORT,[M:RPT2]REP1,BOTYP,BOINV,BOVAL) From INTRUTILA
Endif
Call INITBO([M:RTP2]CBL1) From INTRUTILA
Affzo CBL1
Return
######################################################################################
