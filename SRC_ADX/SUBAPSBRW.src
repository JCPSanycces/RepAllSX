#<AdxTL>@(#)11.0.0.0 $Revision$
# ------------------------------------------------------------
# SUBAPSBRW
# Version 0002
#    Serveur de browsers (anciennement liste gauche des objets X3)
#        U_VIEWCODE        Code de la vue portail
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
#        M_ACTION          Code de l'action à traiter soumis par le provider Htc
#
#        E45836       # Decodage B_FILPAG
#
# ------------------------------------------------------------


# ------------------------------------------------------------
$B_EXECUTE                         # Init + type de dialogue
    # Trace
    U_TRAMES="--> Debut: " + "Serveur de browseurs du portail": Gosub U_TRAPUT From SUBAPSUTI 

    # init
    Gosub B_INIT

    # Lecture objet
    B_BRWCODE=[F:APV]SRCCOD
    Call LECTURE(PC_BRWOBJ, B_BRWCODE ,"")From CONTOBJ
    If fstat <> 0
        U_MESCODE="X3BRWUNKNOWN" : U_MESP1=B_BRWCODE : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endif

    #-- XML
    U_SEQPUT=' <Lists Nb="' + num$([F:AP2]AP2NBOBJ) + '" >' : Gosub U_PUT From SUBAPSUTI         
    ### Gestion Action titres ou données
    Case M_ACTION
        When PQ_ACTTITLE                                            ## Demande de titres
            U_TECMES="<RequestFor>ALL</RequestFor>" : Gosub U_TECPUT From SUBAPSUTI
            For B_LSTNUM=1 To [F:AP2]AP2NBOBJ
                Gosub B_XMLLSTNUMDEB    #XML
                Gosub B_TIT : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENUM: Endif
                Gosub B_XMLLSTNUMEND    #XML
            Next
        When Default                                                 ## Demande de données
            # flag titre
            U_QSCODE=PQ_TITLEOPT : Gosub U_QSREAD_UC From SUBAPSUTI
            B_TITFLG=1
            If U_QSEXIST
                If U_QSVAL=PQ_NO : B_TITFLG=0 : Endif
            Endif      

            ### Gestion action sur toutes les listes ou par liste
            Case M_ACTION
                When PQ_ACTFRTALL                                   ## Données initiales
                    U_TECMES="<RequestFor>ALL</RequestFor>" : Gosub U_TECPUT From SUBAPSUTI  
                    For B_LSTNUM=1 To [F:AP2]AP2NBOBJ
                        Gosub B_XMLLSTNUMDEB    #XML
                        Gosub B_DATA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENUM: Endif
                        Gosub B_XMLLSTNUMEND    #XML
                    Next
                When Default                                        ## Une seule liste
                    ### Gestion action sur une liste
                    Case M_ACTION
                        When PQ_ACTFIRST                           ## First 
                            B_FILPAG=""
                            Gosub B_NUMLIST : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENB: Endif
                        When PQ_ACTNEXT, PQ_ACTPREV                ## Next, Prev
                            U_QSCODE=PQ_FILPAG : Gosub U_QSREAD From SUBAPSUTI
                            U_TXT_ENCODED=U_QSVAL : Gosub U_TXT_DECODE From SUBAPSUTI        # #  E45836 
                            U_TXTTOHEX=U_TXT_DECODED : Gosub U_HEXTOTXT From SUBAPSUTI
                            B_FILPAG=U_HEXTOTXT
                            Gosub B_NUMLIST : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENB: Endif
                        When Default                                 ## Erreur
                            U_MESCODE="X3ACTUNKNOWN" : U_MESP1=M_ACTION : U_MESP2= [F:APV]SRCCODTYP : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto ERRXMLCLOSENB
                    Endcase    ### fin Gestion action sur une liste

                    # Get datas
                    U_TECMES="<RequestForListNum>"+num$(B_LSTNUM)+"</RequestForListNum>" : Gosub U_TECPUT From SUBAPSUTI
                    Gosub B_XMLLSTNUMDEB    #XML
                    Gosub B_DATA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENUM: Endif
                    Gosub B_XMLLSTNUMEND    #XML
            
            Endcase    ### fin Gestion action sur toutes les listes
      
    Endcase     ### fin gestion Action titres ou données

    #-- XML 
    U_SEQPUT=' </Lists>' : Gosub U_PUT From SUBAPSUTI

    # Trace
    U_TRAMES="--> Fin: " + "Serveur de browseurs du portail": Gosub U_TRAPUT From SUBAPSUTI 

Return

$ERRXMLCLOSENUM    # fermeture XML liste et listes
    Gosub B_XMLLSTNUMEND    #XML

$ERRXMLCLOSENB    # fermeture XML listes
    U_SEQPUT=' </Lists>' : Gosub U_PUT From SUBAPSUTI
Return


  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# 
# - - - - - - - - - - - - - - - - - -
$B_DATA
    #U_MESCODE="ENTRAVAIL" : U_MESP1="" : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto B_ERR
#Call TEST(M_ACTION, B_LSTNUM, B_FILPAG) From SUBAPSBRWA
    Gosub B_DATAINIT From SUBAPSBRWA : If U_ERR=UC_ERRG : Return : Endif
    Gosub B_DATAPUT From SUBAPSBRWA : If U_ERR=UC_ERRG : Return : Endif
    If B_TITFLG    # les titres
         Gosub B_TITPUT From SUBAPSBRWA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSENUM : Endif 
    Endif
Return

$B_TIT
    #U_MESCODE="ENTRAVAIL" : U_MESP1="" : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto B_ERR
    Gosub B_DATAINIT From SUBAPSBRWA : If U_ERR=UC_ERRG : Return : Endif
    Gosub B_TITPUT From SUBAPSBRWA : If U_ERR=UC_ERRG : Return : Endif
Return

$B_XMLLSTNUMDEB    #-- XML
    U_SEQPUT='  <List Num="' + num$(B_LSTNUM) + '" >' : Gosub U_PUT From SUBAPSUTI
Return

$B_XMLLSTNUMEND    #-- XML
    U_SEQPUT='  </List>' : Gosub U_PUT From SUBAPSUTI
Return

$B_NUMLIST
    # numero de la liste
    U_QSCODE=PQ_LSTNUM : Gosub U_QSREAD_UC From SUBAPSUTI
    B_LSTNUM=val(U_QSVAL)
    If (not(U_QSEXIST) or B_LSTNUM < 1 or B_LSTNUM > [F:AP2]AP2NBOBJ )
        U_MESCODE="X3LISTNUMBADVALUE" : U_MESP1=U_QSVAL : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI
    Endif
Return    


# Variables
# - - - - - - - - - - - - - - - - - -
$B_INIT
# Objet X3 Fournisseur browser
Local Char PC_BRWOBJ : PC_BRWOBJ="AP2"                             # Objet X3
Local Char B_BRWCODE(10), PQ_BRWCODE(10) : PQ_BRWCODE="BRWCODE"  # Code fiche browser X3
# Table browser
If clalev([F:AP2])  = 0 : Local File APRTBRW [AP2] : Endif

# Actions
Local Char PQ_ACTFRTALL(10) : PQ_ACTFRTALL='FIRSTALL'     # Données à partir du premier pour toutes les listes
Local Char PQ_ACTFIRST(10) : PQ_ACTFIRST='FIRST'            # Données à partir du premier
Local Char PQ_ACTNEXT(10) : PQ_ACTNEXT='NEXT'               # Données suivantes
Local Char PQ_ACTPREV(10) : PQ_ACTPREV='PREV'               # Données précédentes
Local Char PQ_ACTTITLE(10) : PQ_ACTTITLE='TITLE'            # Titres seuls

# Indice de la liste à traiter (obligatoires pour tous sauf FIRSTALL et PQ_ACTTITLE)
Local Char PQ_LSTNUM(10) : PQ_LSTNUM='LISTNUM'               #
Local Integer B_LSTNUM

# Option titres (QS) en mode données
Local Char PQ_TITLEOPT(5) : PQ_TITLEOPT='TITLE'               # Option
Local Char PQ_YES(3) : PQ_YES='YES'                           # avec titres (défaut)
Local Char PQ_NO(2) : PQ_NO='NO'                              # sans titre
Local Integer B_TITFLG                                          # Flag de gestion des titres

# Fitre pagination liste gauche passer en QS
Local Char B_FILPAG(250) : PQ_FILPAG : PQ_FILPAG='FILPAG' 
Local Integer E_NBREC

# Travail
Local Integer PW_I
Return

