#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(30)(1..6) , VALEUR(10)
PARAM(1) = "ZZCC3"
PARAM(2) = "ADC"
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = "1"
Call TRAITE_CHAR(VALEUR,PARAM,"","ADIF","ADIF",3,"XYADIF") From GTRAITE
End

$ACTION
Case BCRIT
 When "ADIF"
  Case ACTION
   When "INIT"
    Local Char    OBJET(GLONAOB) , CODE(30) , DOSORG(GLONADD) , DOSDES(GLONADD)
    Local Integer I , J , K , ERR , STAT , DET
    DOSORG = PARAM(3)
    DOSDES = PARAM(4)
    DET    = val(PARAM(5))
    Onerrgo ERREUR
    I = evalue("dim("+PARAM(1)+")")
    J = evalue("dim("+PARAM(2)+")")
    Onerrgo
    If ERR or I<0 or J<0
     CODE   = PARAM(1)
     OBJET  = PARAM(2)
    Endif
   When "INIT_DIA"
    If I>0 and J>0
     [M]OBJET = mess(167,123,1) : # Divers
     Affzo OBJET
     Grizo OBJET
    Else
     Call TITOBJ(OBJET,"",[M]OBJET) From CONTOBJ
     If [M]OBJET=""
      [M]OBJET = OBJET-CODE
     Else
      [M]OBJET = [M]OBJET-CODE
     Endif
    Endif
    If DOSORG<>""
     [M]DOSORG = DOSORG
    Endif
    If DOSDES<>""
     [M]DOSDES = DOSDES
    Endif
   When "CONTROLE"
    TMP = 1
    TIT = mess(81,126,1)-[M]DOSORG-"&"-[M]DOSDES : # Différence
   When "EXEC"
    TRA = 1
    Call OUVRE_TRACE(mess(81,126,1)-[M]DOSORG-"=>"-[M]DOSDES) From LECFIC   # Différence
    If I>0 & J>0
     For K=0 To I-1
      CODE  = evalue(PARAM(1)+"("+num$(K)+")")
      OBJET = evalue(PARAM(2)+"("+num$(K)+")")
      Gosub VERIF
      If OK
       Call COMPARAISON_SOLO(OBJET,CODE,0,DET,[M]DOSORG,[M]DOSDES,STAT) From ACOMPOBJ
      Endif
     Next K
    Else
     Gosub VERIF
     If OK
      Call COMPARAISON_SOLO(OBJET,CODE,0,DET,[M]DOSORG,[M]DOSDES,STAT) From ACOMPOBJ
     Endif
    Endif
    Call FERME_TRACE From LECFIC
    GERRTRACE = 0
  Endcase
Endcase
Return

$VERIF
OK = 1

If find(OBJET,"","ETA","TXT")
 OK = 0 : Return
Elsif func IS_ADIF_GERE(OBJET)=0
 Call ECR_TRACE(OBJET-":"-mess(61,139,1),-1) From GESECRAN : # Objet non géré
 OK = 0 : Return
Endif
If find(OBJET,"ADC","ADX") : OBJET = "TRT" : Endif
If OBJET="AML" : OBJET = "AST" : Endif
Return

$ERREUR
ERR = errn
Resume

Funprog IS_ADIF_GERE(OBJET)
Value Char OBJET
If find(OBJET,"AMK","AWI","AOB","AOC","AFC","ACT","ATY","ATB","ARP","ADI",
&             "AST","ACN","ADC","ADX","TRT","AML","ACLA","ASW")
 End 1
Endif
End 0

Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If GDOSPATH="" or VALEUR<>"" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call DOSORGDES([M]DOSORG,VALEUR) From DOSCONT
If mkstat : End : Endif
GDOSPATH = VALEUR
End
