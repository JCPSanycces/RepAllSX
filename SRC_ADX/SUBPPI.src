## Etiquette ajoutée par le superviseur (écran MFGBCRIT7) 20/08/2013 13:53:01 (MUARN)
######################################################################################
# Issue 71069 - 2013-08-20 by MUARN : PJT
Subprog AS_PJTSTR(VALEUR)
Variable Char    VALEUR()
Local Decimal WQTEUA
If (clalev([M:POH1]) & [M:POH1]PJTH<>"" & GPJTSNGDOC = 2) |
&  (clalev([M:PSH1]) &[M:PSH0]PJTH<>"" & GPJTSNGDOC=2 )
  mkstat=2
Endif
End

Subprog AS_PJTEND(VALEUR)
Variable Char    VALEUR()
If clalev([M:POH1]) & [M:POH1]PJTH<>"" & GPJTSNGDOC = 2 |
&  (clalev([M:PSH1]) &[M:PSH0]PJTH<>"" & GPJTSNGDOC=2 )
  mkstat=2
Endif
End

######################################################################################
Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()

#106430 - only show weight and volume related fields when coming from PO
If GFONCTION <> "GESPOH"
  Chgfmt [M:PPI1]WEITOT     With "-K"
  Chgfmt [M:PPI1]WEU        With "-K"
  Chgfmt [M:PPI1]VOLTOT     With "-K"
  Chgfmt [M:PPI1]VOU        With "-K"
  Chgfmt [M:PPI1]LINWEI     With "-K"
  Chgfmt [M:PPI1]LINWEU     With "-K"
  Chgfmt [M:PPI1]LINVOL     With "-K"
  Chgfmt [M:PPI1]LINVOU     With "-K"
Endif

End

Subprog AV_LSTFLDLIN(VALEUR)
Variable Char    VALEUR()

#106430 - only show weight and volume related fields when coming from PO
If GFONCTION <> "GESPOH"
  Chgfmt [M:PPI1]LINWEI     With "-K"
  Chgfmt [M:PPI1]LINVOL     With "-K"
Endif

End

