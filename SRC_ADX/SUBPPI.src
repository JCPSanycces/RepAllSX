#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################
# SUBPPI : Picking des besoins achats (cde/fourn)         MBT 13/03/98 #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de      #
# prise en compte des besoins "PICKING" et ne sert qu'à gérer le       #
# masque écran "PPICORD1 [PPI1]".                                      #
########################################################################

$ACTION
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
Case ACTION
 When "AB1_NBLIG"    : Gosub AB1_NBLIG
 When "BB1_NBLIG"    : Gosub BB1_NBLIG
 When Default
Endcase
Return


Subprog AM_MAXDAT(VALEUR)
#-------------------------------------------------------------#
# Après modif de la date borne : Raz et effacement des lignes #
#-------------------------------------------------------------#
Variable Date    VALEUR
Effzo [PPI1]10
Affzo [PPI1]TOTQTY
# Issue 10622 - 2011-12-30 by MUARN : ajout date fin
If VALEUR <> [0/0/0] : [M]MAXDATEND = eomonth(VALEUR) : Affzo [M]MAXDATEND : Endif
End

Subprog C_MAXDAT(VALEUR)
#-------------------------------------------#
# Dans le cas cdes ouvertes borne <= wborne #
#-------------------------------------------#
Variable Date    VALEUR
If [M:PPI1]POCFLG=2 & [M:PPI1]WBORNE<>[0/0/0]
   If VALEUR=[0/0/0]
      VALEUR=[M:PPI1]WBORNE
   Endif
   If VALEUR>[M:PPI1]WBORNE
      GMESSAGE=mess (97,194,1)-num$([M:PPI1]WBORNE) : mkstat=1
   Endif
Endif
End


Subprog AM_UOM(VALEUR)
#-------------------------------------------------------#
# Après modif de l'unité : Raz et effacement des lignes #
# et conversion quantité appel d'offre                  #
#-------------------------------------------------------#
Variable Char    VALEUR()
Effzo [PPI1]10
Call PCAL_QTY([M:PPI1]QTEAOF,[M:PPI1]PUU,[M:PPI1]PPDQTY,[M:PPI1]UOM,
&            [F:ITM]ITMREF,[F:BPS]BPSNUM,1,GBIDD1) From TRTACHQTE1
Affzo [PPI1]PPDQTY
End


Subprog AM_CHXDAT(VALEUR)
#-----------------------------------------------------------------------#
# Après modif du choix date de sélection : Raz et effacement des lignes #
#-----------------------------------------------------------------------#
Variable Integer VALEUR
Effzo [PPI1]10
Affzo [PPI1]TOTQTY
End

Subprog AM_CTMFLG(VALEUR)
#------------------------------------------#
# Après modif de l'indicateur contremarque #
#------------------------------------------#
Variable Integer VALEUR
Effzo [PPI1]10 : Raz [M:PPI1]TOTQTY
End

Subprog AS_NBLIG
#--------------------------------------------------------#
# Activation des boutons "Tri date-site" "Tri site-date" #
# et chargement des lignes si nécessaire                 #
#--------------------------------------------------------#
If [M:PPI1]NBLIG=0 Gosub CHARG_TABLEAU : Call IB_NBLIG : Endif
If [M:PPI1]TOTQTY=0
  Disable GSTAOK : GETABOU(GVALI)=0   : # Désactivation Ok
Else
  Enable  GSTAOK : GETABOU(GVALI)=1   : # Activation    Ok
Endif
# Issue 15330 - 2012-01-23 by MUARN : ajout bouton Tout inclure/Tout exclure
If [M:PPI1]NBLIG=0
  Disable GSTABOU2+1, GSTABOU2+2      : # Désactivation Inclure / Exclure
  GETABOU(GSPE1)=0 : GETABOU(GSPE2)=0
  Call MESSAGE(mess(96,194,1)) From GESECRAN
Else
  Enable  GSTABOU2+1, GSTABOU2+2      : # Activation    Inclure / Exclure
  GETABOU(GSPE1)=1 : GETABOU(GSPE2)=1
Endif
End

Subprog IB_NBLIG
#----------------------------#
# Initialisation des boutons #
#----------------------------#
Raz GBOUT1, GBOUT1, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT2=mess(449,198,1) : GBOUT3=mess(115,198,1) : GBOUT4=mess(116,198,1)
If dim([M:PPI1]ENDDAT)<nolign End : Endif : # Maximum lignes atteint
If nolign = 0 End : Endif
If [M:PPI1]VCRNUM(nolign-1)<>"" & [M:PPI1]WIPTYP(nolign-1)=2
  GBOUT1=mess(61,198,1)
Endif
End

$AB1_NBLIG
#-------------------------------------------------------#
# Avant exécution du bouton tunnel sur demandes d'achat #
#-------------------------------------------------------#
If [M:PPI1]VCRNUM(nolign-1)<>"" & [M:PPI1]WIPTYP(nolign-1)=2
   Local Mask PPICORD1 [PPI9] : [M:PPI9]=[M:PPI1] : # Sauvegarde car ouvert dans DA
Endif
Return

$BB1_NBLIG
#--------------------------------------------#
# Après exécution du tunnel demandes d'achat #
#--------------------------------------------#
[M:PPI1]=[M:PPI9] : Close Local Mask [PPI9] : Affzo [PPI1]1-99
Return

Subprog B2_NBLIG
#----------------------------#
# Tri par date début et site #
#----------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STRDAT(indice),
&                                          [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog B3_NBLIG
#--------------------------#
# Tri par date fin et site #
#--------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]ENDDAT(indice),
&                                          [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog B4_NBLIG
#----------------------#
# Tri par site et date #
#----------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]ENDDAT(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog APRES_NBLIG
#-----------------------------------------------------#
# Après ligne : Recalcul et affichage quantité totale #
#-----------------------------------------------------#
Affzo [PPI1]TOTQTY
End


Subprog IB_PICQTY
#----------------------------------------#
# Activation du bouton "Quantité totale" #
#----------------------------------------#
Raz GBOUT1, GBOUT1, GBOUT3, GBOUT4
If [M:PPI1]QTYFLG(nolign-1)=0  GBOUT1=mess(47,198,1) : Endif
End

Subprog B1_PICQTY(VALEUR)
#------------------------------------#
# Prise en compte totale de la ligne #
#------------------------------------#
Variable Decimal VALEUR
VALEUR=[M:PPI1]RMNEXTQTY(nolign-1) : mkstat=99
End

Subprog AV_PICQTY(VALEUR)
#-------------------------------------------------------#
# Avant zone quantité : Colorisation de la qté en rouge #
#    si elle fait partie de l'appel d'offre sélectionné #
#-------------------------------------------------------#
Variable Decimal VALEUR
If [M:PPI1]QTYFLG(nolign-1)=0
  pcolor=GCOUL(0) : # Noir
Else
  pcolor=GCOUL(1) : # Rouge  (3=Bleu)
Endif
End

Subprog AS_PICQTY(VALEUR)
#-----------------------------#
# Avant saisie de la quantité #
#-----------------------------#
Variable Decimal VALEUR
Local Decimal WQTEUA
If !clalev([F:ITP]) Local File ITMBPS [ITP] : Endif
If [M:PPI1]QTYFLG(nolign-1)=1  mkstat=2 : Endif
# Issue 13072 - 2012-01-19 by MUARN : quantité mini de commande
If VALEUR = 0
  Call PCAL_QTY([M:PPI1]RMNEXTQTY(nolign-1),[M:PPI1]UOM,WQTEUA,[M:PPI1]PUU,
&            [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD1) From TRTACHQTE1
  Read [ITP] ITP0=[M:PPI1]ITMREF;[M:PPI1]BPSNUM
  If fstat
    VALEUR= [M:PPI1]RMNEXTQTY(nolign-1)
  Else
    If WQTEUA < [F:ITP]PURMINQTY
      Call PCAL_QTY([F:ITP]PURMINQTY, [M:PPI1]PUU, VALEUR, [M:PPI1]UOM,
&               [M:PPI1]ITMREF, [M:PPI1]BPSNUM,1,GBIDD1) From TRTACHQTE1
    Else
      VALEUR= [M:PPI1]RMNEXTQTY(nolign-1)
    Endif
   Endif
  [M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))
  Affzo [PPI1]TOTQTY,10
Endif
End

Subprog C_PICQTY(VALEUR)
#-------------------------#
# Contrôle quantité prise #
#-------------------------#
Variable Decimal VALEUR
#If VALEUR>[M:PPI1]RMNEXTQTY(nolign-1) mkstat=1 : Endif : # Contrôle supprimé !
# Issue 71069 - 2013-08-20 by MUARN : PJT
If GPJTSNGDOC=2 & [M:PPI1]PJTDOC<>[M:PPI1]WPJT(nolign-1) & [M:PPI1]TOTQTY>0 & VALEUR <> 0
  GMESSAGE=mess(1023,196,1) : mkstat=1
Endif
End

Subprog AM_PICQTY(VALEUR)
#--------------------------------------------#
# Après modif de la quantité prise en compte #
#--------------------------------------------#
Variable Decimal  VALEUR

# Issue 13072 - 2011-12-14 by MUARN : controle mini de commande
Local Decimal  QTEUA
Local Integer WOK
If !clalev([F:ITP]) Local File ITMBPS [ITP] : Endif
Call PCAL_QTY(VALEUR,[M:PPI1]UOM,QTEUA,[M:PPI1]PUU,
&            [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD1) From TRTACHQTE1
Read [ITP] ITP0=[M:PPI1]ITMREF;[M:PPI1]BPSNUM
If QTEUA<[F:ITP]PURMINQTY & VALEUR <> 0
   GMESSAGE=mess(14,194,1)-format$("N:15F",[F:ITP]PURMINQTY)-[M:PPI1]PUU
   If GPOHMINQTY=1
      mkstat=1
      If CODE=1 GERR=1 : Endif
      End
   Elsif GPOHMINQTY = 2
      WOK=2
      Call AVERTIR (GMESSAGE, WOK)From GESECRAN
      If WOK=1
          Raz GMESSAGE
          mkstat=1
          If CODE=1 GERR=1 : Endif
          End
      Endif
    Endif
    Raz GMESSAGE
Endif
# fin Issue 13072 - 2011-12-14 by MUARN : controle mini de commande

If dim([M:POH0]DME)>0 & ([M:POH0]DME=3 | GLINBPD<>2) & [M:PPI1]RCPFCY<>"" &
& [M:PPI1]STOFCY(nolign-1)<>[M:PPI1]RCPFCY & VALEUR<>0
  GERR=1 : GMESSAGE=mess(266,194,1) : mkstat=2 : End
Endif
[M:PPI1]PICQTY(nolign-1)=VALEUR
If dim([M:POH0]DME)>0 & ([M:POH0]DME=3 | GLINBPD<>2)
  Raz GBIDI1
  For I=0 To [M:PPI1]NBLIG-1
     If [M:PPI1]PICQTY(I)<>0 & [M:PPI1]STOFCY(I)=[M:PPI1]RCPFCY : GBIDI1=1 : Break : Endif
  Next I
  If GBIDI1=0 Raz [M:PPI1]RCPFCY : Endif
  If [M:PPI1]RCPFCY="" & VALEUR <> 0 : [M:PPI1]RCPFCY=[M:PPI1]STOFCY(nolign-1) : Endif
Endif
# Issue 42064 - 2012-01-30 by MUARN : PEC sur commande ajout contremarque
#----- Avertissement si contremarque -----#
If [M:PPI1]WIPCOD(nolign-1)="SOF"
  If VALEUR<>0 & VALEUR<>[M:PPI1]RMNEXTQTY(nolign-1)
    Local Integer OK
    OK=2 : Call AVERTIR(mess(117,194,1),OK) From GESECRAN
    If OK=1 mkstat=1 : End : Endif
  Endif
Endif
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))
# Issue 71069 - 2013-08-20 by MUARN : PJT
If GPJTSNGDOC=2 & [M:PPI1]WPJT(nolign-1)<>""
  [M:PPI1]PJTDOC=[M:PPI1]WPJT(nolign-1)
Endif

Affzo [PPI1]TOTQTY

# 106430 - Purchase planning
If GFONCTION="GESPOH"
  [M:PPI1]LINWEI(nolign-1) = [M:PPI1]ITMWEI * VALEUR
  [M:PPI1]LINVOL(nolign-1) = [M:PPI1]ITMVOL * VALEUR
  [M:PPI1]WEITOT=sum([M:PPI1]LINWEI(0..[M:PPI1]NBLIG-1))
  [M:PPI1]VOLTOT=sum([M:PPI1]LINVOL(0..[M:PPI1]NBLIG-1))
  Affzo [M:PPI1]LINWEI(nolign-1), LINVOL(nolign-1), WEITOT, VOLTOT
Endif

End


$CHARG_TABLEAU
#-------------------------------#
# Chargement tableau des lignes #
#-------------------------------#
Call TEMPON("O") From GESECRAN : # Opération en cours ...
Local Date     BORNE
Local Char     CRITERES(250), CRITLNK(70), FOURN(GLONBPS), REFART(GLONITM)
Local Char     ABREV(4), XZSCRITERES(250), XZSCRITLNK(70), CRITSUP(240), CRITLNK2(240)
Local Char     CRITBETPOH(240), WNOMSITE(6)
Local Char     CRITERES1(250), CRITERES2(250) #issue 10622 fenetre criteres muarn 31/01/2012
Local Shortint I, SAVXZSI, TRAIT, TYPFILT , WRET # Issue 42064 - 2011-12-27 by MUARN : contre-marque
Local Decimal  RMNQTY
Local Integer  WCDTSTA, WIPTYPSOH # Issue 42064 - 2011-12-27 by MUARN : contre-marque
# Issue 104857 - 2014-12-08 by SR
Local Char    FORMULE1(250)
# Issue X3-55891 - 2018-08-17 by SR : Déclinaison par site des données Article/fournisseur
Local Integer WRETOUR
Local Char    WFCY(GLONFCY)
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
# End issue 104857
#-----
If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
#-----
FOURN =[M:PPI1]BPSNUM
REFART=[M:PPI1]ITMREF
# Issue 104857 - 2014-12-08 by SR
# analyse présence formule de sélection
If [M:PPI1]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=10;[M:PPI1]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif
# End issue 104857
# Issue 42064 - 2011-12-26 by MUARN : PEC sur commande ajout contremarque
# Issue 112754 - 2016-10-17 by SR : Services : Recherche contremarque
# Ne pas y aller si sous-traitance
# Si non géré en stock, y aller si "avec contremarque" ou "contremarque seule"
# Sinon, y aller si "Contremarque seule"
If [M:PPI1]CTMFLG=3 & find([M:PPI1]ITMKND,1,3)
    Goto CHARG_SOQ
# Si service de sous-traitance et "Contremarque seule" demandée : on sort
Elsif [M:PPI1]CTMFLG=3 & [M:PPI1]ITMKND=2
   Goto FIN_CHARG_TABLEAU
Endif
#----- Rendre invisible colonne "Article composé" si besoins différents de "SCx" -----#
If [M:PPI1]CODE=4
  Chgfmt [M:PPI1]ITMREFORI With "KP:"+num$(GLONITM)+"X"
Else
  Chgfmt [M:PPI1]ITMREFORI With "-KP:"+num$(GLONITM)+"X"
Endif
#-----
If [M:PPI1]CODE<>6 Goto CHARG_ORD : Endif
# Issue 112754 - 2016-10-18 by SR : Pas de DA pour articles de sous-traitance
If [M:PPI1]ITMKND = 2 :Goto FIN_CHARG_TABLEAU : Endif
#----- Chargement tableau à partir du fichier des DA -----#
CRITERES='LINORDFLG=1 & ITMREF=REFART & LINCLEFLG=1 & LINAPPFLG>2'
If GBUYFLT=2          CRITERES-='& (LINBUY=[M:PPI1]ORDBUY | LINBUY="")' : Endif
If [M:PPI1]RCPFCY<>"" CRITERES-='& PRHFCY=[M:PPI1]RCPFCY'               : Endif
#----- Chargement du filtre supplémentaire pour inter-sites si cde classique -----#
If clalev([M:POH0])
  If [M:POH0]BETFCY=2 & [M:POH0]BPCORD<>"" & [M:PPI1]RCPFCY=""
    WNOMSITE="PRHFCY"
    Gosub CRITBETPOH From SUBPOHB : # Sites de réception des adresse client livré
  Else
    CRITBETPOH="1=1"
  Endif
Else
  CRITBETPOH="1=1"
Endif
#-----

# Issue 10622 - 2011-12-30 by MUARN : ajout date fin
If [M:PPI1]MAXDAT <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & EXTORDDAT>=[M:PPI1]MAXDAT'
  Else
    CRITERES +=' & EXTRCPDAT>=[M:PPI1]MAXDAT'
  Endif
Endif
If [M:PPI1]MAXDATEND <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & EXTORDDAT<=[M:PPI1]MAXDATEND'
  Else
    CRITERES +=' & EXTRCPDAT<=[M:PPI1]MAXDATEND'
  Endif
Endif

#---------------------------------------------------------------------#
# Point d'entrée PECFILTSUP pour ajouter un filtre supplémentaire     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TYPFILT   : Type de filtre                                          #
#             1 = sur la table des lignes DA  PREQUISD [PSD]          #
# CRITERE   : Filtre standard                                         #
# CRITSUP   : Filtre supplémentaire chargé par le point d'entrée      #
#---------------------------------------------------------------------#
TYPFILT=1
XZSCRITERES=CRITERES
XZSCRITLNK =CRITLNK
CRITSUP=""
GPOINT="PECFILTSUP" : Gosub ENTREE From EXEFNC
CRITERES=XZSCRITERES
CRITLNK =XZSCRITLNK
If CRITSUP="" CRITSUP="1=1" : Endif
#-----
If parse(CRITSUP)
  Call ERREUR("Filter error CRITSUP") From GESECRAN : CRITSUP="1=1"
Endif
#-----

# Issue 10622 - 2012-02-01 by MUARN : ajout fenêtre critère
CRITERES1  = "1=1"
# affaire
# Issue 71069 - 2013-08-20 by MUARN : PJT
#If [M:PPI1]PJTSTR <> ""
#   CRITERES1 += " & PJT>=[M:PPI1]PJTSTR"               # borne début affaire
#Endif
#If [M:PPI1]PJTEND <> ""
#   CRITERES1 += " & PJT<=[M:PPI1]PJTEND"               # borne fin   affaire
#Endif
# Issue 71069 - 2016-03-29 by MUARN : demande de livraison
If GFONCTION="GESPOD"
  CRITERES1 += " & PJT=[M:PPI1]PJTDOC"
Else
  If GPJTSNGDOC = 1
    If [M:PPI1]PJTSTR <> ""
       CRITERES1 += " & PJT>=[M:PPI1]PJTSTR"               # borne début affaire
    Endif
    If [M:PPI1]PJTEND <> ""
       CRITERES1 += " & PJT<=[M:PPI1]PJTEND"               # borne fin   affaire
    Endif
  Else
    If [M:PPI1]PJTSTR <>"" | (clalev([M:POH1]) & [M:POH2]NBLIG>0) |
&    (clalev([M:PSH1]) & [M:PSH1]NBLIG>0 )
      CRITERES1 += " & (PJT=[M:PPI1]PJTSTR)"
    Endif
  Endif
Endif
# pièce
If [M:PPI1]VCRNUMSTR <> ""
   CRITERES1 += " & VCRNUM>=[M:PPI1]VCRNUMSTR"         # borne début pièce
Endif
If [M:PPI1] VCRNUMEND <> ""
   CRITERES1 += " & VCRNUM<=[M:PPI1]VCRNUMEND"         # borne fin   pièce
Endif
# Pièce origine
If [M:PPI1]VCRORISTR <> ""
   CRITERES1 +=" & VCRNUMORI>=[M:PPI1]VCRORISTR"       # borne début pièce origine
Endif
If [M:PPI1]VCRORIEND <>""
   CRITERES1 += " & VCRNUMORI <=[M:PPI1]VCRORIEND"     # borne fin pièce origine
Endif

For [PSD] Where evalue(CRITERES) & evalue(CRITBETPOH) & evalue(CRITSUP)
  If [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:PSD]PSHFCY
      Read [FCY] FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
    Endif
    # Issue 10622 - 2012-01-25 by MUARN : ajout filtre site
    If [M:PPI1]EVRFCY = 2 | [M:POH0]POHFCY=[F:FCY]FCY
      # Issue 10622 - 2012-02-01 by MUARN : ajout fenêtre critère
      If [F:FCY]LEGCPY=GSOCIETE
        # Issue 112754 - 2016-10-17 by SR : Services
        If CRITERES1 <> "1=1" & [M:PPI1]ITMKND = 1
          CRITERES2 = "ITMREF=REFART & WIPTYP=2 & WIPSTA=2"
          Filter [ORD] Where evalue(CRITERES2) & evalue(CRITERES1)
          Read [ORD] ORD0 First
            If !fstat
              Gosub CHARG_LIG
            Endif
          Filter [ORD]
        Else
          Gosub CHARG_LIG
        Endif
      Endif
    Endif
  Endif
  If I>dim([M:PPI1]ENDDAT)-1 Call MESSAGE(mess(26,100,1))From GESECRAN : Break : Endif
Next
# Issue 112754 - 2016-10-17 by SR : Services et "avec contremarque"
If [M:PPI1]ITMKND = 3 & [M:PPI1]CTMFLG = 2 : Goto CHARG_SOQ : Endif
#
Goto FIN_CHARG_TABLEAU

$CHARG_ORD
#----------------------------------------------------#
# Chargement tableau à partir du fichier des encours #
#----------------------------------------------------#
# Issue 85410 - 2011-08-18 by SR : Code = 4 : Seulement les SCF
# Issue 86705 - 2012-12-17 by SR : Code = 9,92,93,98,96 : Si EO alors Seulement les EOF
# Issue 93771 GA 12/2013 changement de fournisseur interdit en sous-traitance
# on filtre les WIPTYP=4 ou 13 sur le fournisseur courant
Case [M:PPI1]CODE
  When 1 : CRITERES='WIPTYP=2 & WIPSTA=3 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 2 : CRITERES='WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 3 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 4 : CRITERES='WIPTYP=4 & ITMREF=REFART & WIPSTA=1 & (BPRNUM=FOURN | BPRNUM="")'
  When 5 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO" & ABBFIL<>"PSD"'
  When 7 : CRITERES='WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 8 : CRITERES ='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO") |'
           CRITERES-='(WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO")'
  When 9 : CRITERES='WIPTYP=13 & WIPSTA = 1 &  ITMREF=REFART & BPRNUM=FOURN'
  #VPO 25/01/11 70999 un art ss-traité peut aussi être acheté via POS (cas 92,93,98,96)
  When 92 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 93 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 98 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO") |'
            CRITERES+='(WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 96 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
Endcase
#----- Filtre sur site de réception et site d'expédition -----#
If [M:PPI1]RCPFCY<>""          CRITERES-='& STOFCY=[M:PPI1]RCPFCY' : Endif
If [M:PPI1]SHIFCY<>"" & CODE>6 CRITERES-='& (ORIFCY=[M:PPI1]SHIFCY | WIPTYP<>7)' : Endif
#----- Chargement du filtre supplémentaire pour inter-sites cde classique -----#
If clalev([M:POH0])
  If [M:POH0]BETFCY=2 & [M:POH0]BPCORD<>"" & [M:PPI1]RCPFCY=""
    WNOMSITE="STOFCY"
    Gosub CRITBETPOH From SUBPOHB : # Sites de réception des adresse client livré
  Else
    CRITBETPOH="1=1"
  Endif
Else
  CRITBETPOH="1=1"
Endif
#----- Filtre sur acheteur -----#
If GBUYFLT=2 & [M:PPI1]CODE<>1 & [M:PPI1]CODE<>7
  CRITLNK='[F:ITF]BUY=[M:PPI1]ORDBUY | [F:ITF]BUY="" | [F:ORD]WIPTYP=7'
Else
  CRITLNK="1=1"
Endif
#----- Filtre sur date borne -----#
# Issue 10622 - 2011-12-30 by MUARN : ajout date fin
If [M:PPI1]MAXDAT <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & STRDAT>=[M:PPI1]MAXDAT'
  Else
    CRITERES +=' & ENDDAT>=[M:PPI1]MAXDAT'
  Endif
Endif
If [M:PPI1]MAXDATEND <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & STRDAT<=[M:PPI1]MAXDATEND'
  Else
    CRITERES +=' & ENDDAT<=[M:PPI1]MAXDATEND'
  Endif
Endif
# Issue 103381 - 2014-12-09 by SR
If [M:PPI1]BPSNUM <> ""
   CRITERES +=' & (BPRNUM= [M:PPI1]BPSNUM | BPRNUM = "")'
Endif
# End issue 103381

#---------------------------------------------------------------------#
# Point d'entrée PECFILTSUP pour ajouter un filtre supplémentaire     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TYPFILT   : Type de filtre                                          #
#             2 = sur la table des encours  ORDERS [ORD]              #
# CRITERE   : Filtre standard                                         #
# CRITLNK   : Filtre standard du "Link"                               #
# CRITSUP   : Filtre supplémentaire chargé par le point d'entrée      #
# CRITLNK2  : Filtre supplémentaire sur la table ITMFACILIT [ITF]     #
#---------------------------------------------------------------------#
TYPFILT=2
XZSCRITERES=CRITERES
XZSCRITLNK =CRITLNK
CRITSUP =""
CRITLNK2=""
GPOINT="PECFILTSUP" : Gosub ENTREE From EXEFNC
CRITERES=XZSCRITERES
CRITLNK =XZSCRITLNK
If CRITSUP =""  CRITSUP ="1=1" : Endif
If CRITLNK2=""  CRITLNK2="1=1" : Endif
#-----
If parse(CRITSUP)
  Call ERREUR("Filter error CRITSUP")  From GESECRAN : CRITSUP ="1=1"
Endif
If parse(CRITLNK2)
  Call ERREUR("Filter error CRITLNK2") From GESECRAN : CRITLNK2="1=1"
Endif
#-----

# Issue 10622 - 2012-01-31 by MUARN : ajout fenêtre critères
CRITERES1  = "1=1"
# affaire
# Issue 71069 - 2016-03-18 by MUARN : on présente tout dans le tableau, contrôle ensuite
# Issue 71069 - 2013-08-20 by MUARN : PJT
#If GPJTSNGDOC = 1
# Issue 71069 - 2016-03-29 by MUARN : demande de livraison
If GFONCTION="GESPOD"
  CRITERES1 += " & PJT=[M:PPI1]PJTDOC"
Else
  If [M:PPI1]PJTSTR <> ""
     CRITERES1 += " & PJT>=[M:PPI1]PJTSTR"               # borne début affaire
  Endif
  If [M:PPI1]PJTEND <> ""
     CRITERES1 += " & PJT<=[M:PPI1]PJTEND"               # borne fin   affaire
  Endif
Endif
#Else
#  If [M:PPI1]PJTSTR <>"" | (clalev([M:POH1]) & [M:POH2]NBLIG>0) |
#&    (clalev([M:PSH1]) & [M:PSH1]NBLIG>0 )
#    CRITERES1 += " & (PJT=[M:PPI1]PJTSTR)"
#  Endif
#Endif
# pièce
If [M:PPI1]VCRNUMSTR <> ""
   CRITERES1 += " & VCRNUM>=[M:PPI1]VCRNUMSTR"         # borne début pièce
Endif
If [M:PPI1] VCRNUMEND <> ""
   CRITERES1 += " & VCRNUM<=[M:PPI1]VCRNUMEND"         # borne fin   pièce
Endif
# Pièce origine
If [M:PPI1]VCRORISTR <> ""
   CRITERES1 +=" & VCRNUMORI>=[M:PPI1]VCRORISTR"       # borne début pièce origine
Endif
If [M:PPI1]VCRORIEND <>""
   CRITERES1 += " & VCRNUMORI <=[M:PPI1]VCRORIEND"     # borne fin pièce origine
Endif

# Issue 10622 - 2012-01-31 by MUARN : Ajout fenetre criteres
# Issue 104857 - 2014-12-08 by SR ajout FORMULE1
Filter [ORD] Where evalue(CRITERES) & evalue(CRITBETPOH) & evalue(CRITSUP) & evalue(CRITERES1)
&            & evalue(FORMULE1)
# End issue 104857
Link [ORD] With [ITF] ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY As [ORF]
For [ORF] Where evalue(CRITLNK) & evalue(CRITLNK2)
  If [F:ORD]RMNEXTQTY>0
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
    # Issue 10622 - 2012-01-25 by MUARN : ajout filtre site
    # Issue 120896 - 2017-01-13 by MUARN Appel : depuis DA et Commande
    #If [M:PPI1]EVRFCY = 2 | [M:POH0]POHFCY=[F:FCY]FCY
    If [M:PPI1]EVRFCY = 2 | [M:PPI1]FCY=[F:FCY]FCY
      If [F:FCY]LEGCPY=GSOCIETE
        #----- "POP" demande d'achat : Prise en compte si ligne complètement signée -----#
        If [F:ORD]WIPSTA=2 & [F:ORD]ABBFIL="PSD"
          Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
          If fstat Raz [F:PSD] : Endif
          If [F:PSD]LINAPPFLG>2 Gosub CHARG_LIG : Endif
      Elsif find([F:ORD]WIPTYP,13,4) # Suite Issue 87637 GA 09/2013 idem SUBPPI2
        If dim(WRET)<=0 Local Integer WRET Endif
        WRET=0 : Gosub CTLORD From TRTACHSCO1
        If !WRET  Gosub CHARG_LIG_ORD : Endif
      Else
        #----- "POS","TRS"  Prise en compte sans restriction -----#
          Gosub CHARG_LIG
        Endif
      Endif
    Endif
  Endif
  If I>dim([M:PPI1]ENDDAT)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
Filter [ORD]
# Issue 112754 - 2016-10-17 by SR : Services
If [M:PPI1]ITMKND = 2 : Goto FIN_CHARG_TABLEAU : Endif

$CHARG_SOQ
# Issue 42064 - 2011-12-26 by MUARN : PEC sur commande ajout contremarque
#-----------------------------------------------------------------------------#
# Chargement tableau à partir du fichier des lignes de cde vente contremarque #
#-----------------------------------------------------------------------------#
If [M:PPI1]CTMFLG<2  Goto FIN_CHARG_TABLEAU : Endif
If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif : # En principe est déjà ouvert !
If !clalev([F:SOQ])  Local File SORDERQ [SOQ] : Endif : # En principe est déjà ouvert !
If !clalev([F:SOP])  Local File SORDERP [SOP] : Endif : # En principe est déjà ouvert !
Raz [F:SOH]
CRITERES='ITMREF=REFART'

If [M:PPI1]MAXDAT <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & ORDDAT>=[M:PPI1]MAXDAT'
  Else
    CRITERES +=' & DEMDLVDAT>=[M:PPI1]MAXDAT'
  Endif
Endif
If [M:PPI1]MAXDATEND <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & ORDDAT<=[M:PPI1]MAXDATEND'
  Else
    CRITERES +=' & DEMDLVDAT<=[M:PPI1]MAXDATEND'
  Endif
Endif

For [SOQ] SOQ4 Where SOQSTA<>3
&                  & SOHCAT<>4
&                  & find(FMI,2,3)<>0
&                  & FMINUM=""
&                  & evalue(CRITERES)
  CRITERES1  = "1=1"
  # affaire
  # Issue 71069 - 2013-08-20 by MUARN : PJT
  # Issue 71069 - 2016-03-29 by MUARN : demande de livraison
  If GFONCTION="GESPOD"
    CRITERES1 += " & PJT=[M:PPI1]PJTDOC"
  Else
    If GPJTSNGDOC = 1
      If [M:PPI1]PJTSTR <> ""
         CRITERES1 += " & PJT>=[M:PPI1]PJTSTR"               # borne début affaire
      Endif
      If [M:PPI1]PJTEND <> ""
         CRITERES1 += " & PJT<=[M:PPI1]PJTEND"               # borne fin   affaire
      Endif
    Else
      If [M:PPI1]PJTSTR <>"" | (clalev([M:POH1]) & [M:POH2]NBLIG>0) |
&      (clalev([M:PSH1]) & [M:PSH1]NBLIG>0 )
        CRITERES1 += " & (PJT=[M:PPI1]PJTSTR)"
      Endif
    Endif
  Endif
  # pièce
  If [M:PPI1]VCRNUMSTR <> ""
     CRITERES1 += " & VCRNUM>=[M:PPI1]VCRNUMSTR"         # borne début pièce
  Endif
  If [M:PPI1] VCRNUMEND <> ""
     CRITERES1 += " & VCRNUM<=[M:PPI1]VCRNUMEND"         # borne fin   pièce
  Endif
  # Pièce origine
  If [M:PPI1]VCRORISTR <> ""
     CRITERES1 +=" & VCRNUMORI>=[M:PPI1]VCRORISTR"       # borne début pièce origine
  Endif
  If [M:PPI1]VCRORIEND <>""
     CRITERES1 += " & VCRNUMORI <=[M:PPI1]VCRORIEND"     # borne fin pièce origine
  Endif

  #----- Contrôle existence du site et appartenance à la même sté juridique -----#
  If [F:FCY]FCY<>[F:SOQ]STOFCY
    Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
  Endif
  If [M:PPI1]EVRFCY = 2 | [M:POH0]POHFCY=[F:FCY]FCY
    If [F:FCY]LEGCPY=GSOCIETE
      # Issue X3-55891 - 2018-08-17 by SR : Exploitation données déclinées par site
      #Raz [F:ITP]
      #Read [ITP] ITP0=[F:SOQ]ITMREF+[M:PPI1]BPSNUM
      #If [F:ITP]DOUFLG>2 Raz [F:ITP] : Endif
      Raz WRETOUR, GBIDI1
      # On a déjà le fournisseur : On recherche juste son niveau de blocage
      If [M:PPI1]RCPFCY <> ""
        WFCY = [M:PPI1]RCPFCY
      Else
        WFCY = [F:SOQ]STOFCY
      Endif
      # Intersite
      If [M:POH0]BETFCY = 2 & [M:POH0]BETCPY <> 2
        Call BPSNUM_DOUBTFUL_LEVEL(2,[F:SOQ]ITMREF,[M:PPI1]BPSNUM,WFCY,GBIDI1,WRETOUR) From TRTACHCTL1
      Else
        Call BPSNUM_DOUBTFUL_LEVEL(1,[F:SOQ]ITMREF,[M:PPI1]BPSNUM,WFCY,GBIDI1,WRETOUR) From TRTACHCTL1
      Endif
      If WRETOUR <> 0 : Raz [F:ITP] : Endif
      # End issue X3-55891
      Call CTLITMBUY([F:SOQ]ITMREF,[M:POH1]BUY,WRET) From TRTACHCTL1
      If !WRET
        # Issue 112754 - 2016-10-17 by SR : Services
        If CRITERES1 <> "1=1" & [M:PPI1]ITMKND = 1
          CRITERES2 = "ITMREF=REFART & WIPTYP=1 & WIPSTA=1"
          Filter [ORD] Where evalue(CRITERES2) & evalue(CRITERES1)
          Read [ORD] ORD0 First
            If !fstat
              Gosub CHARG_LIG_SOQ
            Endif
          Filter [ORD]
        Else
          Gosub CHARG_LIG_SOQ
        Endif
      Endif
    Endif
  Endif
  If I>dim([M:PPI1]ENDDAT)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next

#-----
$FIN_CHARG_TABLEAU
[M:PPI1]NBLIG=I
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))

# Issue 10622 - 2012-01-13 by MUARN : tri tableau
If [M:PPI1]NBLIG <> 0
  Case [M:PPI1]SRTCOD
      When 1: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STOFCY(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 2: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]ITMREF(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 3: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYPSTA(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 4: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]VCRTYP(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 5: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 6: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]REQDAT(indice),[M:PPI1]VCRNUM(indice)
      When 7: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]BPRNUM(indice),[M:PPI1]VCRNUM(indice)
  Endcase
Endif

Affzo [PPI1]TOTQTY,10

# 106430 - Purchase planning - set values only if coming from PO
If GFONCTION="GESPOH"
  [M:PPI1]WEITOT=sum([M:PPI1]LINWEI(0..[M:PPI1]NBLIG-1))
  [M:PPI1]VOLTOT=sum([M:PPI1]LINVOL(0..[M:PPI1]NBLIG-1))
  Affzo [M:PPI1]WEITOT, VOLTOT
Endif

Enable GSTAFIN : GETABOU(GABAN)=1 : # Activation Abandon
Call TEMPOFF From GESECRAN
Return


$CHARG_LIG
#------------------------#
# Chargement d'une ligne #
#------------------------#
If [M:PPI1]CODE<>6 Goto CHARG_LIG_ORD : Endif
#----- Chargement ligne a partir du fichier des DA -----#
If clalev([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=[M:PPI1]WCODFNC
&                    & WIPTYP=2
&                    & WIPNUM=[F:PSD]PSHNUM
&                    & PSDLIN=[F:PSD]PSDLIN
&                    & ITMREF=[F:PSD]ITMREF
    [F:PSD]ORDQTYSTU+=[F:PWO]QTYSTU
  Next
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             1 = depuis la table des lignes DA  PREQUISD [PSD]       #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI1] et [F:PSD]                            #
# [M:PPI1]CODE : Code du traitement                                   #
#                6 = prise en compte des demandes d'achat             #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=1
ABREV="PPI1"
RMNQTY=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
#-----
If RMNQTY<=0 Return : Endif
[M:PPI1]WIPTYP(I)   =2
[M:PPI1]WIPSTA(I)   =2
[M:PPI1]WIPNUM(I)   =""
[M:PPI1]STRDAT(I)   =[F:PSD]EXTORDDAT
[M:PPI1]ENDDAT(I)   =[F:PSD]EXTRCPDAT
[M:PPI1]STOFCY(I)   =[F:PSD]PRHFCY
[M:PPI1]STU(I)      =[F:ITM]STU
[M:PPI1]ORIFCY(I)   =""
[M:PPI1]BUY(I)      =[F:PSD]LINBUY
[M:PPI1]BPRNUM(I)   =[F:PSD]BPSNUM
[M:PPI1]VCRTYP(I)   =0
[M:PPI1]VCRNUM(I)   =[F:PSD]PSHNUM
[M:PPI1]VCRLIN(I)   =[F:PSD]PSDLIN
[M:PPI1]WPJT(I)     =[F:PSD]PJT
# Issue 15330 - 2011-12-27 by MUARN : initialisation quantite ligne a 0
[M:PPI1]PICQTY(I)   =0
# 106430 - Purchase planning - Get Item information
[M:PPI1]LINWEU(I)   =[F:ITM]WEU
[M:PPI1]LINVOU(I)   =[F:ITM]VOU

If dim([M:PPI1]ORI)>0
  [M:PPI1]ORI(I)    =1 : # Origine Achats
Endif
#----- Indicateur inter-sociétés -----#
If [F:PSD]BPSNUM<>""
  If [F:BPR2]BPRNUM<>[F:PSD]BPSNUM
    Read [BPR2] BPR0=[F:PSD]BPSNUM : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>""
    [M:PPI1]WIPISO(I)=func TRTACHISO1.ISOFLG([F:BPR2]FCY,[F:PSD]PRHFCY)
  Else
    [M:PPI1]WIPISO(I)=1
  Endif
Else
  [M:PPI1]WIPISO(I)=1
Endif
# Issue 10622 - 2012-01-13 by MUARN : ajout fenêtre critères
[M:PPI1]REQDAT(I)=[F:PSD]EXTRCPDAT
[M:PPI1]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)
If [M:PPI1]WIPISO(I)= 2 : [M:PPI1]WIPTYPSTA(I) += chr$(126) : Endif

#-----
Call PCAL_QTY(RMNQTY,[F:ITM]STU,[M:PPI1]RMNEXTQTY(I),[M:PPI1]UOM,
&             [F:ITM]ITMREF,[F:BPS]BPSNUM,1,GBIDD1) From TRTACHQTE1
Goto FIN_CHARG_LIG
#----- Chargement ligne a partir du fichier des encours -----#

$CHARG_LIG_ORD
Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
If clalev ([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=[M:PPI1]WCODFNC
&                    & WIPTYP=[F:ORD]WIPTYP
&                    & WIPNUM=[F:ORD]WIPNUM
&                    & ITMREF=[F:ORD]ITMREF
    [F:ORD]RMNEXTQTY-=[F:PWO]QTYSTU
  Next
Endif
If [F:ITF]ITMREF<>[F:ORD]ITMREF | [F:ITF]STOFCY <> [F:ORD]STOFCY
  Read [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY : If fstat Raz [F:ITF] : Endif
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             2 = depuis la table des encours  ORDERS [ORD]           #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI1] et [F:ORD]                            #
# [M:PPI1]CODE : Code du traitement                                   #
#                1 = prise en compte des "POS"                        #
#                2 = prise en compte des "POP"                        #
#                3 = prise en compte des "POS" et "POP"               #
#                4 = prise en compte des "SCS", "SCP" et "SCF"        #
#                5 = prise en compte des "POS" et "POP" autres que DA #
#                7 = prise en compte des "TRS" et "TRP"               #
#                8 = idem codes 2 + 7                                 #
#                9 = prise en compte des "EOS", "EOP" et "EOF"        #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=2
ABREV="PPI1"
RMNQTY=[F:ORD]RMNEXTQTY
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
#-----
If RMNQTY<=0 Return : Endif
[M:PPI1]WIPTYP(I)   =[F:ORD]WIPTYP
[M:PPI1]WIPSTA(I)   =[F:ORD]WIPSTA
[M:PPI1]WIPNUM(I)   =[F:ORD]WIPNUM
[M:PPI1]STRDAT(I)   =[F:ORD]STRDAT
[M:PPI1]ENDDAT(I)   =[F:ORD]ENDDAT
[M:PPI1]STOFCY(I)   =[F:ORD]STOFCY
[M:PPI1]STU(I)      =[F:ITM]STU # Issue 42064 - 2011-12-27 by MUARN : unité stock ajout pour contre marque
# Issue 15330 - 2011-12-27 by MUARN : initialisation quantite ligne a 0
[M:PPI1]PICQTY(I)   =0
If [M:PPI1]WIPTYP=7
  [M:PPI1]ORIFCY(I) =[F:ORD]ORIFCY
Else
  [M:PPI1]ORIFCY(I) =""
Endif
[M:PPI1]BUY(I)      =[F:ITF]BUY
[M:PPI1]BPRNUM(I)   =[F:ORD]BPRNUM
[M:PPI1]WPJT(I)     =[F:ORD]PJT
[M:PPI1]ITMREFORI(I)=[F:ORD]ITMREFORI

# 106430 - Purchase planning - Get Item information
[M:PPI1]LINWEU(I)   =[F:ITM]WEU
[M:PPI1]LINVOU(I)   =[F:ITM]VOU

If dim([M:PPI1]ORI)>0
  [M:PPI1]ORI(I)    =[F:ORD]ORI : # Origine du besoin
Endif
If ([F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2) | find([F:ORD]WIPTYP,4,13)
  [M:PPI1]VCRTYP(I)=[F:ORD]VCRTYP
  [M:PPI1]VCRNUM(I)=[F:ORD]VCRNUM
  [M:PPI1]VCRLIN(I)=[F:ORD]VCRLIN
Else
  Raz [M:PPI1]VCRTYP(I), [M:PPI1]VCRNUM(I), [M:PPI1]VCRLIN(I)
Endif
#----- Indicateur inter-sociétés -----#
If [F:ORD]WIPTYP=2 & [F:ORD]BPRNUM<>""
  If [F:BPR2]BPRNUM<>[F:ORD]BPRNUM
    Read [BPR2] BPR0=[F:ORD]BPRNUM : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>""
    [M:PPI1]WIPISO(I)=func TRTACHISO1.ISOFLG([F:BPR2]FCY,[F:ORD]STOFCY)
  Else
    [M:PPI1]WIPISO(I)=1
  Endif
Else
  [M:PPI1]WIPISO(I)=1
Endif
#-----
Call PCAL_QTY(RMNQTY,[F:ITM]STU,[M:PPI1]RMNEXTQTY(I),[M:PPI1]UOM,
&             [F:ITM]ITMREF,[F:BPS]BPSNUM,1,GBIDD1) From TRTACHQTE1
#-----
# Issue 10622 - 2012-01-13 by MUARN : ajout fenêtre critères
[M:PPI1]REQDAT(I)=[F:ORD]MRPDAT
If [M:PPI1]REQDAT(I)=[0/0/0] : [M:PPI1]REQDAT(I) = [M:PPI1]ENDDAT(I) Endif
[M:PPI1]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)
If [M:PPI1]WIPTYP(I)=2 & [M:PPI1]WIPISO(I)= 2 : [M:PPI1]WIPTYPSTA(I) += chr$(126) : Endif

$FIN_CHARG_LIG
If [M:PPI1]CODE=5 | [M:PPI1]CODE=7 | [M:PPI1]BPRNUM(I)="" | [M:PPI1]BPRNUM(I)=[M:PPI1]BPSNUM
  # Issue 15330 - 2011-12-27 by MUARN : quantité prise initialisée à 0
  [M:PPI1]PICQTY(I)=0
  #-- En inter-site, si site de réception unique
  If dim([M:POH0]DME)>0 & ([M:POH0]DME=3 | GLINBPD<>2)
    #-- On ne connait pas encore ce site de réception
    If [M:PPI1]RCPFCY=""
      [M:PPI1]RCPFCY=[M:PPI1]STOFCY(I)
    Elsif [M:PPI1]RCPFCY<>[M:PPI1]STOFCY(I)
      Raz [M:PPI1]PICQTY(I)
    Endif
  Endif
Else
  Raz [M:PPI1]PICQTY(I)
Endif
# Issue 84500 GA 10/2012
#If [M:PPI1]WIPTYP(I)=2
#  If [M:PPI1]WIPSTA(I)=1 [M:PPI1]WIPCOD(I)="POF" : Endif
#  If [M:PPI1]WIPSTA(I)=2 [M:PPI1]WIPCOD(I)="POP" : Endif
#  If [M:PPI1]WIPSTA(I)=3 [M:PPI1]WIPCOD(I)="POS" : Endif
#Elsif [M:PPI1]WIPTYP(I)=4
#  If [M:PPI1]WIPSTA(I)=1 [M:PPI1]WIPCOD(I)="SCF" : Endif
#  If [M:PPI1]WIPSTA(I)=2 [M:PPI1]WIPCOD(I)="SCP" : Endif
#  If [M:PPI1]WIPSTA(I)=3 [M:PPI1]WIPCOD(I)="SCS" : Endif
#Elsif [M:PPI1]WIPTYP(I)=7
#  If [M:PPI1]WIPSTA(I)=1 [M:PPI1]WIPCOD(I)="TRF" : Endif
#  If [M:PPI1]WIPSTA(I)=2 [M:PPI1]WIPCOD(I)="TRP" : Endif
#  If [M:PPI1]WIPSTA(I)=3 [M:PPI1]WIPCOD(I)="TRS" : Endif
#Elsif [M:PPI1]WIPTYP(I)=13
#  If [M:PPI1]WIPSTA(I)=1 [M:PPI1]WIPCOD(I)="EOF" : Endif
#  If [M:PPI1]WIPSTA(I)=2 [M:PPI1]WIPCOD(I)="EOP" : Endif
#  If [M:PPI1]WIPSTA(I)=3 [M:PPI1]WIPCOD(I)="EOS" : Endif
#Endif
If [M:PPI1]WIPTYP(I)>0
   [M:PPI1]WIPCOD(I)= mess([M:PPI1]WIPTYP(I),341,1)+mess([M:PPI1]WIPSTA(I),342,1)
Endif
If [M:PPI1]WIPISO(I)=2 [M:PPI1]WIPCOD(I)+=chr$(126) : Endif

#----- Si prise en compte d'un appel d'offre, prendre en compte les DA associées -----#
If clalev([F:PSA]) & [M:PPI1]QTEAOF<>0 & [M:PPI1]PQHNUM<>"" & [M:PPI1]WIPCOD(I)="POP"
  Look [PSA] PSA1=[M:PPI1]PQHNUM;[M:PPI1]PQDLIN;[M:PPI1]VCRNUM(I);[M:PPI1]VCRLIN(I)
  If !fstat
    # Issue 15330 - 2011-12-27 by MUARN : quantité prise initialisée à 0
    [M:PPI1]QTYFLG(I)=1 : [M:PPI1]PICQTY(I)=0
  Else
    [M:PPI1]QTYFLG(I)=0
  Endif
Else
  [M:PPI1]QTYFLG(I)=0
Endif
#-----
I+=1
Return

$CHARG_LIG_SOQ
# Issue 42064 - 2011-12-26 by MUARN : PEC sur commande ajout contremarque
#---------------------------------------------------------------#
# Chargement d'une ligne à partir des cdes ventes contremarques #
#---------------------------------------------------------------#
#----- Relecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:SOQ]ITMREF
  Read [ITM] ITM0=[F:SOQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Relecture cde entête vente et contrôle si nécessaire -----#
If [F:SOH]SOHNUM<>[F:SOQ]SOHNUM
  Read [SOH] SOH0=[F:SOQ]SOHNUM : If fstat Raz [F:SOH] : Endif
  #----- Vérification si commande bloquée -----#
  Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&               [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
  Case WCDTSTA
    When 2 : Return
    When 3 : If GDIRORDCTL<2  Return : Endif
  Endcase
  #------------------------------------------------------------#
  # Point d'entrée CTMFILTRE1 pour exclure certaines commandes #
  # ---------------------------------------------------------- #
  # Variable utilisable par le point d'entrée                  #
  #                                                            #
  # WCDTSTA : Indicateur d'exclusion (0 = Pas d'exclusion)     #
  #------------------------------------------------------------#
  Raz WCDTSTA
  Gosub POINT_CTMFILTRE1 From TRTACHCDE1
  If WCDTSTA  Return : Endif
Endif
If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2  WIPTYPSOH=8  Else  WIPTYPSOH=1 : Endif
#-----
RMNQTY=[F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU
If clalev ([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=[M:PPI1]WCODFNC
&                    & WIPTYP=WIPTYPSOH
&                    & WIPNUM=[F:SOQ]SOHNUM
&                    & PSDLIN=[F:SOQ]SOPLIN
&                    & ITMREF=[F:SOQ]ITMREF
    Raz RMNQTY : Break
  Next
Endif
If RMNQTY=0 Return : Endif
If [F:SOP]SOHNUM<>[F:SOQ]SOHNUM |
&  [F:SOP]SOPLIN<>[F:SOQ]SOPLIN |
&  [F:SOP]SOPSEQ<>[F:SOQ]SOQSEQ
  Read [SOP] SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
  If fstat Raz [F:SOP] : Endif
Endif
#---------------------------------------------------------------------#
# Point d'entrée PECBESOINS pour intervenir sur les besoins proposés  #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# TRAIT     : Type de prise en compte                                 #
#             3 = depuis la table des lignes cde vte SORDERQ [SOQ]    #
# ABREV     : Abréviation du masque écran en cours de chargement      #
# RMNQTY    : Quantité à prendre en compte exprimée en unité de stock #
#             si 0 pas de prise en compte ligne besoin non visualisée #
#                                                                     #
# Classes consultables [M:PPI1] et [F:SOQ]                            #
# [M:PPI1]CODE : Code du traitement                                   #
#                1 = prise en compte des "POS"                        #
#                2 = prise en compte des "POP"                        #
#                3 = prise en compte des "POS" et "POP"               #
#                4 = prise en compte des "SCS", "SCP" et "SCF"        #
#                6 = prise en compte des DA                           #
#                9 = prise en compte des "EOS", "EOP" et "EOF"        #
# Nota : I est l'indice de la ligne du tableau en cours de chargement #
#---------------------------------------------------------------------#
TRAIT=3
ABREV="PPI1"
SAVXZSI=I
GPOINT="PECBESOINS" : Gosub ENTREE From EXEFNC
I=SAVXZSI
#-----
If RMNQTY<=0 Return : Endif
# réafectation de la quantité après le test de la valeur négative
If RMNQTY<>0 RMNQTY=[F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU : Endif
[M:PPI1]WIPTYP(I)   =WIPTYPSOH
[M:PPI1]WIPSTA(I)   =1
[M:PPI1]WIPNUM(I)   =[F:SOQ]DEMNUM
[M:PPI1]STRDAT(I)   =[F:SOQ]ORDDAT
#----------------------------------------------------------------#
# Date de réception prévue :                                     #
#    = Date de livraison chez le client si contremarque directe  #
#    = Date d'expédition si contremarque réceptionnée            #
#      ajustement avec le délai de préparation de l'article-site #
#      et des indisponibilités du site de réception.             #
#----------------------------------------------------------------#
If [F:SOQ]FMI=2
  [M:PPI1]ENDDAT(I) = [F:SOQ]EXTDLVDAT
Else
  [M:PPI1]ENDDAT(I) = [F:SOQ]SHIDAT
  If [F:FCY]FCY<>[F:SOQ]STOFCY
    Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
  Endif
  If [F:ITF]ITMREF<>[F:SOQ]ITMREF | [F:ITF]STOFCY<>[F:SOQ]STOFCY
    Read [ITF] ITF0=[F:SOQ]ITMREF;[F:SOQ]STOFCY : If fstat Raz [F:ITF] : Endif
  Endif
  Call TRT_PRPLTI([M:PPI1]ENDDAT(I),[F:ITF]PRPLTI) From TRTACHCDE1
Endif
If [M:PPI1]ENDDAT(I)<[M:PPI1]STRDAT(I)
  [M:PPI1]ENDDAT(I) =[M:PPI1]STRDAT(I)
Endif
#-----
[M:PPI1]STOFCY(I)   =[F:SOQ]STOFCY
[M:PPI1]STU(I)      =[F:ITM]STU
[M:PPI1]BUY(I)      =""
[M:PPI1]BPRNUM(I)   =[F:ITP]BPSNUM
[M:PPI1]PICQTY(I)   =0
[M:PPI1]RMNEXTQTY(I)=RMNQTY
[M:PPI1]SOHNUM(I)   =[F:SOQ]SOHNUM
[M:PPI1]SOPLIN(I)   =[F:SOQ]SOPLIN
[M:PPI1]WPJT(I)     =[F:SOH]PJT
If dim([M:PPI1]ORI)>0
  [M:PPI1]ORI(I)    =2 : # Origine Ventes
Endif
#----- Indicateur inter-sociétés -----#
If [F:SOH]BETCPY=2
  [M:PPI1]WIPISO(I)=2
Else
  [M:PPI1]WIPISO(I)=1
Endif
#-----
If [M:PPI1]WIPTYP(I)=8
  [M:PPI1]WIPCOD(I) ="TPF"
Else
  [M:PPI1]WIPCOD(I) ="SOF"
  If [M:PPI1]WIPISO(I)=2 [M:PPI1]WIPCOD(I)+=chr$(126) : Endif
Endif
Raz [M:PPI1]VCRNUM(I), [M:PPI1]VCRLIN(I)
[M:PPI1]VCRTYP(I)=2
[M:PPI1]REQDAT(I)=[F:SOQ]ORDDAT
[M:PPI1]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1)+ mess([F:ORD]WIPSTA,342,1)
If [M:PPI1]WIPTYP(I)<>8 & [M:PPI1]WIPISO(I)= 2 : [M:PPI1]WIPTYPSTA(I) += chr$(126) : Endif

I+=1
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFGBCRIT7) 28/12/2011 15:46:55 (MUARN)
## Issue 10622 - 2011-12-30 by MUARN : ajout fenêtre critère, borne de fin date
######################################################################################
Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M]PJTEND = ""     : [M]PJTEND = VALEUR : Affzo [M]PJTEND : Endif
If [M]PJTEND < VALEUR : [M]PJTEND = VALEUR : Affzo [M]PJTEND : Endif
End

Subprog AS_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M:PPI1]BPSNUM <> "" : [M]ORDFILTER += "&BPRNUM>=[M:PPI1]BPSNUM" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMEND = ""     : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif
End

Subprog AS_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M:PPI1]BPSNUM <> "" : [M]ORDFILTER += "&BPRNUM>=[M:PPI1]BPSNUM" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AS_VCRORISTR(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AM_VCRORISTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRORIEND ="" : [M]VCRORIEND= VALEUR : Affzo [M]VCRORIEND : Endif
If [M]VCRORIEND< VALEUR : [M]VCRORIEND = VALEUR : Affzo [M]VCRORIEND : Endif
End

Subprog AS_VCRORIEND(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog C_MAXDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]MAXDAT : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_MAXDATEND(VALEUR)
Variable Date    VALEUR
Effzo [PPI1]10 : Raz [M:PPI1]TOTQTY
End

Subprog AM_EVRFCY(VALEUR)
Variable Integer VALEUR
Effzo [PPI1]10 : Raz [M:PPI1]TOTQTY
End

