# Superviseur
## CRUD-CLASSE ## CCMCRORIGI
# 2018-10-19 07:50:16 204


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(CCMCRORIGI,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Variable Integer ASTATUS

If CCMCRORIGI = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_CCMCRORIGI

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(CCMCRORIGI,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Variable Integer ASTATUS

If CCMCRORIGI = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGI
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_CCMCRORIGI
Else
 Gosub ADELETE_CCMCRORIGI
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(CCMCRORIGI,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If CCMCRORIGI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGI.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_CCMCRORIGI
Trbegin [F:CCMCROI]
 Gosub ADELETE_CCMCRORIGI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_CCMCRORIGI
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(CCMCRORIGI,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGI._MAJSQL_CCMCRORIGI(CCMCRORIGI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If CCMCRORIGI.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGI.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGI.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



