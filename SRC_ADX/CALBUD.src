   SEC9 = [F:CRY9]GRU : Gosub CALCUL
  Next
 Endif
Endif
Return

$CALCUL
NOMBRE += 1
Case [M:BUC0]FLGDSP
 When 1 : Gosub BUD_PER : # Base de transfert en montants par périodes
 When 2 : Gosub BUD_AN  : # Base de transfert en montants annuels
Endcase
Return

###################################################################
# Base de transfert en montants par périodes
###################################################################
$BUD_PER
For J=0 To NBEXO
 For I=1 To NBBUDFOR
  EXO = [M:BUC1]FIYSTR(I)+J
  Gosub INI_LIGBUD
  If OKCAL
   For K=0 To dim([F:BUD2]AMT)-1
    PAMT(I,K) = 0
    DAMT(I,K) = 0
    PQTY(I,K) = 0
   Next K
   # Recherche de la période début et de la période fin pour l'exercice EXO
   Raz PDEB, PFIN
   If EXO=[M:BUC1]FIYSTR(I) : PDEB = [M:BUC1]PERDEB(I) : Endif
   If EXO=[M:BUC1]FIYEND(I) : PFIN = [M:BUC1]PERFIN(I) : Endif
   If PDEB=0 : PDEB = 1 : Endif
   If PFIN=0 : Call NBPER([M:BUC1]CPY(I),[M:BUC1]LEDTYP(I),EXO,PFIN) From CPTSUB : Endif
   If PFIN=0 : Break 2 : Endif
   # Lecture BUD ou BALANA
   If [M:BUC1]TYP(I)=1 : # Budget
    Gosub CRITBUD
    Filter [BUD] Where LEDTYP=[M:BUC1]LEDTYP(I) & BUD=[M:BUC1]BUD(I) & CPY=[M:BUC1]CPY(I) & FCY=[M:BUC1]FCY(I) &
&   VER=VERSION & FIY=EXO & evalue(CRITBAL)
    For [BUD]BUD0
     For K=PDEB-1 To PFIN-1
      PAMT(I,K) += [F:BUD]AMT(K)
      DAMT(I,K) += [F:BUD]AMT(K)
      PQTY(I,K) += [F:BUD]QTY(K)
     Next
    Next
    Filter [BUD]
    # On convertit dans la devise du budget à calculer (DEVBUDO => DEVBUD)
    Call CONVERT_TAB(DEVBUDO,DEVBUD,DEVCUR,TYPCUR,PAMT,I,MESSA,STAT)
    If STAT : Gosub ERR_TRACE : GOK = 0 : Break : Endif
   Else  : # Balance
    FLQTE = 0 : Gosub BALANA
    If CALQTE
     FLQTE = 1 : Gosub BALANA
    Endif
    # On convertit dans la devise du budget à calculer (DEVCUR => DEVBUD)
    Call CONVERT_TAB(DEVCUR,DEVBUD,DEVCUR,TYPCUR,PAMT,I,MESSA,STAT)
    If STAT : Gosub ERR_TRACE : GOK = 0 : Break : Endif
   Endif
  Endif
 Next I

 If GOK<1 : Break : Endif
 # On évalue la formule de calcul période par période
 # Mise à jour de BUD avec le budget à calculer
 Raz RESAMT , RESQTY
 Raz PDEB , PFIN
 EXO = [M:BUC1]FIYSTR(0)+J
 If EXO=[M:BUC1]FIYSTR(0) : PDEB = [M:BUC1]PERDEB(0) : Endif
 If EXO=[M:BUC1]FIYEND(0) : PFIN = [M:BUC1]PERFIN(0) : Endif
 If PDEB=0 : PDEB = 1 : Endif
 If PFIN=0
  PFIN = PERNUMEND(EXO)
 Endif

 If PFIN=0 : Break : Endif

 #*X3-66273 For ODBUD dates because PERDATSTR(EXO) & PERDATEND(EXO) are always null
 Gosub READ_PER
 # If ODBUD
 #  DEBEX = PERDATSTR(EXO)
 #  FINEX = PERDATEND(EXO)
 # Endif
 #*X3-66273 END

 For K=PDEB-1 To PFIN-1
  Gosub EVAL
  If GOK<1 : Break : Endif
  RESAMT(K) = TOTAMT
  RESQTY(K) = TOTQTY
 Next K
 If GOK<1 : Break : Endif
 Gosub MAJ_BUD
 If GOK<1 : Break : Endif
Next J
Return

$BALANA
If PYRCPT=""
 VACC = VALACC : Gosub BALSEC1
Else
 CRIT0  = 'PYM="'+PYRCPT+'"'
 CRIT0 -= '& LEV='+num$(NIVCPT)
 If func JOKER(VALACC)
  CRIT0 -= '& pat(GRU,"'+VALACC+'")<>0'
 Else
  CRIT0 -= '& GRU="'+VALACC+'"'
 Endif
 For [GYK] Where evalue(CRIT0)
  VACC = [F:GYK]ACC : Gosub BALSEC1
 Next
Endif
Return

$BALSEC1
If PYRSEC1=""
 VCCE1 = VALCCE1 : Gosub BALSEC2
Else
 CRIT1  = 'PYM="'+PYRSEC1+'"'
 CRIT1 -= '& LEV='+num$(NIVSEC1)
 If func JOKER(VALCCE1)
  CRIT1 -= '& pat(GRU,"'+VALCCE1+'")<>0'
 Else
  CRIT1 -= '& GRU="'+VALCCE1+'"'
 Endif
 For [CYK1] Where evalue(CRIT1)
  VCCE1 = [F:CYK1]CCE : Gosub BALSEC2
 Next
Endif
Return

$BALSEC2
If PYRSEC2=""
 VCCE2 = VALCCE2 : Gosub BALSEC3
Else
 CRIT2  = 'PYM="'+PYRSEC2+'"'
 CRIT2 -= '& LEV='+num$(NIVSEC2)
 If func JOKER(VALCCE2)
  CRIT2 -= '& pat(GRU,"'+VALCCE2+'")<>0'
 Else
  CRIT2 -= '& GRU="'+VALCCE2+'"'
 Endif
 For [CYK2] Where evalue(CRIT2)
  VCCE2 = [F:CYK2]CCE : Gosub BALSEC3
 Next
Endif
Return

$BALSEC3
If PYRSEC3=""
 VCCE3 = VALCCE3 : Gosub BALSEC4
Else
 CRIT3  = 'PYM="'+PYRSEC3+'"'
 CRIT3 -= '& LEV='+num$(NIVSEC3)
 If func JOKER(VALCCE3)
  CRIT3 -= '& pat(GRU,"'+VALCCE3+'")<>0'
 Else
  CRIT3 -= '& GRU="'+VALCCE3+'"'
 Endif
 For [CYK3] Where evalue(CRIT3)
  VCCE3 = [F:CYK3]CCE : Gosub BALSEC4
 Next
Endif
Return

$BALSEC4
If PYRSEC4=""
 VCCE4 = VALCCE4 : Gosub BALSEC5
Else
 CRIT4  = 'PYM="'+PYRSEC4+'"'
 CRIT4 -= '& LEV='+num$(NIVSEC4)
 If func JOKER(VALCCE4)
  CRIT4 -= '& pat(GRU,"'+VALCCE4+'")<>0'
 Else
  CRIT4 -= '& GRU="'+VALCCE4+'"'
 Endif
 For [CYK4] Where evalue(CRIT4)
  VCCE4 = [F:CYK4]CCE : Gosub BALSEC5
 Next
Endif
Return

$BALSEC5
If PYRSEC5=""
 VCCE5 = VALCCE5 : Gosub BALSEC6
Else
 CRIT5  = 'PYM="'+PYRSEC5+'"'
 CRIT5 -= '& LEV='+num$(NIVSEC5)
 If func JOKER(VALCCE5)
  CRIT5 -= '& pat(GRU,"'+VALCCE5+'")<>0'
