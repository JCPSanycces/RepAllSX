$BALSEC6
If PYRSEC6=""
 VCCE6 = VALCCE6 : Gosub BALSEC7
Else
 CRIT6  = 'PYM="'+PYRSEC6+'"'
 CRIT6 -= '& LEV='+num$(NIVSEC6)
 If func JOKER(VALCCE6)
  CRIT6 -= '& pat(GRU,"'+VALCCE6+'")<>0'
 Else
  CRIT6 -= '& GRU="'+VALCCE6+'"'
 Endif
 For [CYK6] Where evalue(CRIT6)
  VCCE6 = [F:CYK6]CCE : Gosub BALSEC7
 Next
Endif
Return

$BALSEC7
If PYRSEC7=""
 VCCE7 = VALCCE7 : Gosub BALSEC8
Else
 CRIT7  = 'PYM="'+PYRSEC7+'"'
 CRIT7 -= '& LEV='+num$(NIVSEC7)
 If func JOKER(VALCCE7)
  CRIT7 -= '& pat(GRU,"'+VALCCE7+'")<>0'
 Else
  CRIT7 -= '& GRU="'+VALCCE7+'"'
 Endif
 For [CYK7] Where evalue(CRIT7)
  VCCE7 = [F:CYK7]CCE : Gosub BALSEC8
 Next
Endif
Return

$BALSEC8
If PYRSEC8=""
 VCCE8 = VALCCE8 : Gosub BALSEC9
Else
 CRIT8  = 'PYM="'+PYRSEC8+'"'
 CRIT8 -= '& LEV='+num$(NIVSEC8)
 If func JOKER(VALCCE8)
  CRIT8 -= '& pat(GRU,"'+VALCCE8+'")<>0'
 Else
  CRIT8 -= '& GRU="'+VALCCE8+'"'
 Endif
 For [CYK8] Where evalue(CRIT8)
  VCCE8 = [F:CYK8]CCE : Gosub BALSEC9
 Next
Endif
Return

$BALSEC9
If PYRSEC9=""
 VCCE9 = VALCCE9 : Gosub BALCPT
Else
 CRIT9  = 'PYM="'+PYRSEC9+'"'
 CRIT9 -= '& LEV='+num$(NIVSEC9)
 If func JOKER(VALCCE9)
  CRIT9 -= '& pat(GRU,"'+VALCCE9+'")<>0'
 Else
  CRIT9 -= '& GRU="'+VALCCE9+'"'
 Endif
 For [CYK9] Where evalue(CRIT9)
  VCCE9 = [F:CYK9]CCE : Gosub BALCPT
 Next
Endif
Return

#CHECK IGNORE_BEGIN
$BALCPT
Gosub CRITBAL
If FLQTE
 For [LNKQ] Where [BLAQ]LEDTYP=[M:BUC1]LEDTYP(I) & [BLAQ]CPY=[M:BUC1]CPY(I) & [BLAQ]FCY=[M:BUC1]FCY(I) & [BLAQ]FIY=EXO
&& [BLAQ]BPR='' & evalue(CRITBAL)
  Gosub SIGNE
  For K=PDEB-1 To PFIN-1
   Case [M:BUC0]FLGDSP
    When 1 : # En montant par période
     Case [M:BUC1]TYP(I)
      When 2 : PQTY(I,K) += SIGN*[F:BLAQ]QTY(K+1)       : # Réel
      When 3 : PQTY(I,K) += SIGN*[F:BLAQ]QTYCMM(K+1)    : # Engagé
      When 4 : PQTY(I,K) += SIGN*[F:BLAQ]QTYPRP(K+1)    : # Pré-engagé
     Endcase
    When 2 : # En montants annuels
     Case [M:BUC1]TYP(I)
      When 2 : QTYREA(I) += SIGN*[F:BLAQ]QTY(K+1)       : # Réel
      When 3 : QTYCMM(I) += SIGN*[F:BLAQ]QTYCMM(K+1)    : # Engagé
      When 4 : QTYPRP(I) += SIGN*[F:BLAQ]QTYPRP(K+1)    : # Pré engagé
     Endcase
   Endcase
  Next
 Next

Else

 Case [M:BUC1]TYP(I)
  When 2  : # Réel
   For [LNKA] Where [BLAA]LEDTYP=[M:BUC1]LEDTYP(I) & [BLAA]CPY=[M:BUC1]CPY(I) & [BLAA]FCY=[M:BUC1]FCY(I) & [BLAA]FIY=EXO
&& [BLAA]BPR='' & evalue(CRITBAL)
    Gosub SIGNE
    For K=PDEB-1 To PFIN-1
     Case [M:BUC0]FLGDSP
      When 1
       PAMT(I,K) += SIGN*([F:BLAA]DEBLED(K+1)-[F:BLAA]CDTLED(K+1))
       DAMT(I,K) += SIGN*([F:BLAA]DEBLED(K+1)-[F:BLAA]CDTLED(K+1))
      When 2
       AMTREA(I) += SIGN*([F:BLAA]DEBLED(K+1)-[F:BLAA]CDTLED(K+1))
     Endcase
    Next
   Next

  When 3 : # Engagé
   For [LNKC] Where [BLAC]LEDTYP=[M:BUC1]LEDTYP(I) & [BLAC]CPY=[M:BUC1]CPY(I) & [BLAC]FCY=[M:BUC1]FCY(I) & [BLAC]FIY=EXO
&& [BLAC]BPR='' & evalue(CRITBAL)
    Gosub SIGNE
    For K=PDEB-1 To PFIN-1
     Case [M:BUC0]FLGDSP
      When 1
       PAMT(I,K) += SIGN*[F:BLAC]CMMLED(K+1)
       DAMT(I,K) += SIGN*[F:BLAC]CMMLED(K+1)
      When 2
       AMTCMM(I) += SIGN*[F:BLAC]CMMLED(K+1)
     Endcase
    Next
   Next

  When 4 : # Pré-engagé
   For [LNKC] Where [BLAC]LEDTYP=[M:BUC1]LEDTYP(I) & [BLAC]CPY=[M:BUC1]CPY(I) & [BLAC]FCY=[M:BUC1]FCY(I) & [BLAC]FIY=EXO
&& [BLAC]BPR='' & evalue(CRITBAL)
    Gosub SIGNE
    For K=PDEB-1 To PFIN-1
     Case [M:BUC0]FLGDSP
      When 1
       PAMT(I,K) += SIGN*[F:BLAC]CMMPRPLED(K+1)
       DAMT(I,K) += SIGN*[F:BLAC]CMMPRPLED(K+1)
      When 2
       AMTPRP(I) += SIGN*[F:BLAC]CMMPRPLED(K+1)
     Endcase
    Next
   Next
 Endcase
Endif
Return
#CHECK IGNORE_END

$CRITBAL
Raz CRITBAL, ICRIT
If func JOKER(VACC)
 Call ADDCRIT(CRITBAL,ICRIT,"ACC","pat(ACC,'"+VACC+"')"," & ") From GOBJSUB
Else
 Call ADDCRIT(CRITBAL,ICRIT,"ACC","ACC='"+VACC+"'"," & ") From GOBJSUB
Endif
If IAXE1<>0
 If func JOKER(VCCE1)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE1)+",'"+VCCE1+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE1)+"='"+VCCE1+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE2<>0
 If func JOKER(VCCE2)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE2)+",'"+VCCE2+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE2)+"='"+VCCE2+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE3<>0
 If func JOKER(VCCE3)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE3)+",'"+VCCE3+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE3)+"='"+VCCE3+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE4<>0
 If func JOKER(VCCE4)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE4)+",'"+VCCE4+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE4)+"='"+VCCE4+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE5<>0
 If func JOKER(VCCE5)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE5)+",'"+VCCE5+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE5)+"='"+VCCE5+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE6<>0
 If func JOKER(VCCE6)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE6)+",'"+VCCE6+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE6)+"='"+VCCE6+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE7<>0
 If func JOKER(VCCE7)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE7)+",'"+VCCE7+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE7)+"='"+VCCE7+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE8<>0
 If func JOKER(VCCE8)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE8)+",'"+VCCE8+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE8)+"='"+VCCE8+"'"," & ") From GOBJSUB
 Endif
Endif
If IAXE9<>0
 If func JOKER(VCCE9)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE9)+",'"+VCCE9+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE9)+"='"+VCCE9+"'"," & ") From GOBJSUB
 Endif
Endif
Return

$SIGNE
If [F:CLS]SNSANA=2 : # Type de nature=Produit (stocké en <0 dans BALANA)
 SIGN = -1
Else
 SIGN = +1
Endif
Return

$CRITBUD
Raz CRITBAL, ICRIT
If func JOKER(VALACC)
 Call ADDCRIT(CRITBAL,ICRIT,"ACC","pat(ACC,'"+VALACC+"')"," & ") From GOBJSUB
Else
 Call ADDCRIT(CRITBAL,ICRIT,"ACC","ACC='"+VALACC+"'"," & ") From GOBJSUB
Endif
If AXE1<>""
 If func JOKER(VALCCE1)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE1)+",'"+VALCCE1+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE1)+"='"+VALCCE1+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE2<>""
 If func JOKER(VALCCE2)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE2)+",'"+VALCCE2+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE2)+"='"+VALCCE2+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE3<>""
 If func JOKER(VALCCE3)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE3)+",'"+VALCCE3+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE3)+"='"+VALCCE3+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE4<>""
 If func JOKER(VALCCE4)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE4)+",'"+VALCCE4+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE4)+"='"+VALCCE4+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE5<>""
 If func JOKER(VALCCE5)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE5)+",'"+VALCCE5+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE5)+"='"+VALCCE5+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE6<>""
 If func JOKER(VALCCE6)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE6)+",'"+VALCCE6+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE6)+"='"+VALCCE6+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE7<>""
 If func JOKER(VALCCE7)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE7)+",'"+VALCCE7+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE7)+"='"+VALCCE7+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE8<>""
 If func JOKER(VALCCE8)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE8)+",'"+VALCCE8+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE8)+"='"+VALCCE8+"'"," & ") From GOBJSUB
 Endif
Endif
If AXE9<>""
 If func JOKER(VALCCE9)
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","pat(CCE"+num$(IAXE9)+",'"+VALCCE9+"')"," & ") From GOBJSUB
 Else
  Call ADDCRIT(CRITBAL,ICRIT,"CCE","CCE"+num$(IAXE9)+"='"+VALCCE9+"'"," & ") From GOBJSUB
 Endif
