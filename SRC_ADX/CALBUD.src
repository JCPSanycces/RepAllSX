###################################################################################
# Initialise les lignes des formules budgétaires en remplaçant
# les variables V_ par leurs valeurs
# Initialise les axes et la devise du budget qui sert de base au calcul
###################################################################################
$INI_LIGBUD
Raz VALACC,VALCCE1,VALCCE2,VALCCE3,VALCCE4,VALCCE5,VALCCE6,VALCCE7,VALCCE8,VALCCE9
VALACC  = [M:BUC1]ACC(I)
VALCCE1 = [M:BUC1]CCE1(I)
VALCCE2 = [M:BUC1]CCE2(I)
VALCCE3 = [M:BUC1]CCE3(I)
VALCCE4 = [M:BUC1]CCE4(I)
VALCCE5 = [M:BUC1]CCE5(I)
VALCCE6 = [M:BUC1]CCE6(I)
VALCCE7 = [M:BUC1]CCE7(I)
VALCCE8 = [M:BUC1]CCE8(I)
VALCCE9 = [M:BUC1]CCE9(I)
VERSION = [M:BUC1]VER(I)
For K=0 To [M:DIA]NBLIG2-1
 If VALACC =[M:DIA]VARCOD(K) : VALACC  = [M:DIA]VARVAL(K) : Endif
 If VALCCE1=[M:DIA]VARCOD(K) : VALCCE1 = [M:DIA]VARVAL(K) : Endif
 If VALCCE2=[M:DIA]VARCOD(K) : VALCCE2 = [M:DIA]VARVAL(K) : Endif
 If VALCCE3=[M:DIA]VARCOD(K) : VALCCE3 = [M:DIA]VARVAL(K) : Endif
 If VALCCE4=[M:DIA]VARCOD(K) : VALCCE4 = [M:DIA]VARVAL(K) : Endif
 If VALCCE5=[M:DIA]VARCOD(K) : VALCCE5 = [M:DIA]VARVAL(K) : Endif
 If VALCCE6=[M:DIA]VARCOD(K) : VALCCE6 = [M:DIA]VARVAL(K) : Endif
 If VALCCE7=[M:DIA]VARCOD(K) : VALCCE7 = [M:DIA]VARVAL(K) : Endif
 If VALCCE8=[M:DIA]VARCOD(K) : VALCCE8 = [M:DIA]VARVAL(K) : Endif
 If VALCCE9=[M:DIA]VARCOD(K) : VALCCE9 = [M:DIA]VARVAL(K) : Endif
 If VERSION=[M:DIA]VARCOD(K) : VERSION = [M:DIA]VARVAL(K) : Endif
Next K
# Pour ne pas recalculer les lignes qui ne varient pas avec les sections à calculer
If NOMBRE=1
 OKCAL  = 1
Else
 OKCAL  = (VALACC="")
 OKCAL += (VALCCE1="" & AXE1<>"")
 OKCAL += (VALCCE2="" & AXE2<>"")
 OKCAL += (VALCCE3="" & AXE3<>"")
 OKCAL += (VALCCE4="" & AXE4<>"")
 OKCAL += (VALCCE5="" & AXE5<>"")
 OKCAL += (VALCCE6="" & AXE6<>"")
 OKCAL += (VALCCE7="" & AXE7<>"")
 OKCAL += (VALCCE8="" & AXE8<>"")
 OKCAL += (VALCCE9="" & AXE9<>"")
Endif
If !OKCAL : Return : Endif
If VALACC="" : VALACC = COMPTE : Endif
If VALCCE1="" & AXE1<>"" : VALCCE1 = SEC1 : Endif
If VALCCE2="" & AXE2<>"" : VALCCE2 = SEC2 : Endif
If VALCCE3="" & AXE3<>"" : VALCCE3 = SEC3 : Endif
If VALCCE4="" & AXE4<>"" : VALCCE4 = SEC4 : Endif
If VALCCE5="" & AXE5<>"" : VALCCE5 = SEC5 : Endif
If VALCCE6="" & AXE6<>"" : VALCCE6 = SEC6 : Endif
If VALCCE7="" & AXE7<>"" : VALCCE7 = SEC7 : Endif
If VALCCE8="" & AXE8<>"" : VALCCE8 = SEC8 : Endif
If VALCCE9="" & AXE9<>"" : VALCCE9 = SEC9 : Endif
Call LEC_BUP([M:BUC1]BUD(I)) From CPTLEC
Call LEC_CPY([M:BUC1]CPY(I))  From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED([M:BUC1]LEDTYP(I)-1)) From CPTLEC
IAXE1 = find(AXE1,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE2 = find(AXE2,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE3 = find(AXE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE4 = find(AXE4,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE5 = find(AXE5,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE6 = find(AXE6,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE7 = find(AXE7,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE8 = find(AXE8,[F:LED]DIE(0..[F:LED]DIENBR-1))
IAXE9 = find(AXE9,[F:LED]DIE(0..[F:LED]DIENBR-1))
DEVBUDO = [F:BUP]CUR
DEVCUR  = [F:GCM]CUR([M:BUC1]LEDTYP(I)-1)
Return

###################################################################
# Mise à jour du budget
###################################################################
$MAJ_BUD
If [M:BUC0]DEL=2 & sum(RESAMT)=0 & sum(RESQTY)=0
 Return : # Si on a tout effacé, pas besoin de lire si 0
Endif
Gosub INIVAR_BUDCCE

Readlock [BUD2]BUD0 = TYPREF;BUDGET;SOCIETE;SITE;EXO;VERBUD;COMPTE;
&                     BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
If fstat=1
  GOK = -1 : GLOCK = "$BUD"-BUDGET-SOCIETE-SITE-num$(EXO)-VERBUD-COMPTE-
&                     BUDCCE(0)-BUDCCE(1)-BUDCCE(2)-BUDCCE(3)-BUDCCE(4)-BUDCCE(5)-BUDCCE(6)-BUDCCE(7)-BUDCCE(8)  : Return
Elsif fstat=0 : # Le budget existe
 If sum(RESAMT)=0 & sum(RESQTY)=0
  DELTA_AMT = -sum([F:BUD2]AMT(PDEB-1..PFIN-1))
  DELTA_QTY = -sum([F:BUD2]QTY(PDEB-1..PFIN-1))
  Gosub LIG_OD
  If GOK<1 : Return : Endif
  For K=PDEB-1 To PFIN-1
   [F:BUD2]AMT(K) = 0
   [F:BUD2]QTY(K) = 0
  Next K
  If sum([F:BUD2]AMT)=0 & sum([F:BUD2]QTY)=0
   Delete [BUD2]
   NBDEL += 1
  Else
   Rewrite [BUD2]
   NBMAJ += 1
   If fstat
    GOK = 0 : Call FSTA("BUD2") From GLOCK : Return
   Endif
  Endif
 Else
  DELTA_AMT = sum(RESAMT)-sum([F:BUD2]AMT(PDEB-1..PFIN-1))
  DELTA_QTY = sum(RESQTY)-sum([F:BUD2]QTY(PDEB-1..PFIN-1))
  Gosub LIG_OD
  If GOK<1 : Return : Endif
  For K=PDEB-1 To PFIN-1
   [F:BUD2]AMT(K) = RESAMT(K)
   [F:BUD2]QTY(K) = RESQTY(K)
  Next K
  If dim([F:BUD2]UPDDAT)>0 : [F:BUD2]UPDDAT = date$ : Endif
  If dim([F:BUD2]UPDUSR)>0 : [F:BUD2]UPDUSR = GUSER : Endif
  If dim([F:BUD2]UPDTIM)>0 : [F:BUD2]UPDTIM = time  : Endif
  # Calculé par la formule
  [F:BUD2]TEX = mess(98,108,1)-[M:BUC0]BUDFOR
  Rewrite [BUD2]
  NBMAJ += 1
  If fstat
   GOK = 0 : Call FSTA("BUD2") From GLOCK : Return
  Endif
 Endif


Else : # Budget inexistant
 If sum(RESAMT)<>0 | sum(RESQTY)<>0
  DELTA_AMT = sum(RESAMT)
  DELTA_QTY = sum(RESQTY)
  Gosub LIG_OD
  If GOK<1 : Return : Endif
  Raz [F:BUD2]
  [F:BUD2]LEDTYP = TYPREF
  [F:BUD2]LED    = REFERENTIEL
  [F:BUD2]BUD    = BUDGET
  [F:BUD2]CPY    = SOCIETE
  [F:BUD2]FCY    = SITE
  [F:BUD2]FIY    = EXO
  [F:BUD2]VER    = VERBUD
  [F:BUD2]ACC    = COMPTE
  [F:BUD2]CCE1   = BUDCCE(0)
  [F:BUD2]CCE2   = BUDCCE(1)
  [F:BUD2]CCE3   = BUDCCE(2)
  [F:BUD2]CCE4   = BUDCCE(3)
  [F:BUD2]CCE5   = BUDCCE(4)
  [F:BUD2]CCE6   = BUDCCE(5)
  [F:BUD2]CCE7   = BUDCCE(6)
  [F:BUD2]CCE8   = BUDCCE(7)
  [F:BUD2]CCE9   = BUDCCE(8)
  [F:BUD2]CUR    = DEVBUD
  [F:BUD2]COA    = PLAN
  [F:BUD2]DIE1   = BUDDIE(0)
  [F:BUD2]DIE2   = BUDDIE(1)
  [F:BUD2]DIE3   = BUDDIE(2)
  [F:BUD2]DIE4   = BUDDIE(3)
  [F:BUD2]DIE5   = BUDDIE(4)
  [F:BUD2]DIE6   = BUDDIE(5)
  [F:BUD2]DIE7   = BUDDIE(6)
  [F:BUD2]DIE8   = BUDDIE(7)
  [F:BUD2]DIE9   = BUDDIE(8)
  [F:BUD2]UOM    = UNITE
  # Calculé par la formule
  [F:BUD2]TEX    = mess(98,108,1)-[M:BUC0]BUDFOR
  [F:BUD2]ACCNUM = uniqid([F:BUD2])
  If dim([F:BUD2]CREDAT)>0 : [F:BUD2]CREDAT = date$ : Endif
  If dim([F:BUD2]CREUSR)>0 : [F:BUD2]CREUSR = GUSER : Endif
  If dim([F:BUD2]CRETIM)>0 : [F:BUD2]CRETIM = time  : Endif
  For K=0 To dim([F:BUD2]AMT)-1
   [F:BUD2]AMT(K) = RESAMT(K)
   [F:BUD2]QTY(K) = RESQTY(K)
  Next
  Write [BUD2]
  NBMAJ += 1
  If fstat
   GOK = 0 : Call FSTA("BUD2") From GLOCK : Return
  Endif
 Endif
Endif
Gosub TRACE
Return

$EVAL
TOTAMT = 0 : TOTQTY = 0
For I=1 To NBBUDFOR
 Case [M:BUC1]TYP(I)
  When 1 : AMTBUD(I) = PAMT(I,K) : QTYBUD(I) = PQTY(I,K) : # Budget
  When 2 : AMTREA(I) = PAMT(I,K) : QTYREA(I) = PQTY(I,K) : # Réel
  When 3 : AMTCMM(I) = PAMT(I,K) : QTYCMM(I) = PQTY(I,K) : # Engagé
  When 4 : AMTPRP(I) = PAMT(I,K) : QTYPRP(I) = PQTY(I,K) : # Pré engagé
 Endcase
Next
ERREUR = 0
Onerrgo ERR_FORMULE
TOTAMT = arr(evalue(FORMULE1),[F:TCU]CURRND)
Onerrgo
If ERREUR : GOK = 0 : Return : Endif
ERREUR = 0
If UNITE<>""
 Onerrgo ERR_FORMULE
 TOTQTY = arr(evalue(FORMULE2),10^(-[F:TUN]UOMDEC))
 Onerrgo
Endif
If ERREUR : GOK = 0 : Return : Endif
Return

#################################################################
$INIVAR_BUDCCE
Call LEC_LED(REFERENTIEL) From CPTLEC
Raz BUDCCE, BUDDIE
For L=0 To [F:LED]DIENBR-1
 If [F:LED]DIE(L)=[F:BUP]DIE(0)
  BUDCCE(L) = SEC1 : BUDDIE(L) = [F:BUP]DIE(0)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(1)
  BUDCCE(L) = SEC2 :  BUDDIE(L) = [F:BUP]DIE(1)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(2)
  BUDCCE(L) = SEC3 :  BUDDIE(L) = [F:BUP]DIE(2)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(3)
  BUDCCE(L) = SEC4 :  BUDDIE(L) = [F:BUP]DIE(3)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(4)
  BUDCCE(L) = SEC5 :  BUDDIE(L) = [F:BUP]DIE(4)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(5)
  BUDCCE(L) = SEC6 :  BUDDIE(L) = [F:BUP]DIE(5)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(6)
  BUDCCE(L) = SEC7 :  BUDDIE(L) = [F:BUP]DIE(6)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(7)
  BUDCCE(L) = SEC8 :  BUDDIE(L) = [F:BUP]DIE(7)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(8)
  BUDCCE(L) = SEC9 :  BUDDIE(L) = [F:BUP]DIE(8)
 Endif
Next
Return

###################################################################
# Génération OD budgétaire
###################################################################
$LIG_OD
If ODBUD & (DELTA_AMT<>0 or DELTA_QTY<>0)
 LIGOD += 1
 If LIGOD=1
  Gosub TET_OD
  DEBOD = [F:BDE]NUM
 Elsif LIGOD>MAXOD
  LIGOD = 1
  Gosub TET_OD
  FINOD = [F:BDE]NUM
 Endif
 [F:BDO] = [F:BDE]
 [F:BDO]LIN    = LIGOD
 [F:BDO]LEDTYP = TYPREF
 [F:BDO]LED    = REFERENTIEL
 [F:BDO]CPY    = SOCIETE
 [F:BDO]FCY    = SITE
 [F:BDO]STRDAT = DEBEX
 [F:BDO]ENDDAT = FINEX
 [F:BDO]FIY    = EXO
 [F:BDO]COA    = PLAN
 [F:BDO]ACC    = COMPTE
 [F:BDO]DIE1   = AXE1
 [F:BDO]CCE1   = SEC1
 [F:BDO]DIE2   = AXE2
 [F:BDO]CCE2   = SEC2
 [F:BDO]DIE3   = AXE3
 [F:BDO]CCE3   = SEC3
 [F:BDO]DIE4   = AXE4
 [F:BDO]CCE4   = SEC4
 [F:BDO]DIE5   = AXE5
 [F:BDO]CCE5   = SEC5
 [F:BDO]DIE6   = AXE6
 [F:BDO]CCE6   = SEC6
 [F:BDO]DIE7   = AXE7
 [F:BDO]CCE7   = SEC7
 [F:BDO]DIE8   = AXE8
 [F:BDO]CCE8   = SEC8
 [F:BDO]DIE9   = AXE9
 [F:BDO]CCE9   = SEC9
 [F:BDO]CUR    = DEVBUD
 [F:BDO]AMT    = DELTA_AMT
 [F:BDO]UOM    = UNITE
 [F:BDO]QTY    = DELTA_QTY
 Write [BDO]
 If fstat
  GOK = 0 : Call FSTA("BDO") From GLOCK : Return
 Endif
Endif
Return

$TET_OD
Raz [F:BDE]
Call COMPTEUR([F:BDE]NUM,ERREUR) From SUBBDO
If GOK<1
 MESSA = GMESSAGE : Gosub ERR_TRACE : Return
Endif
[F:BDE]BUD    = BUDGET
[F:BDE]VER    = VERBUD
# Calcul budgétaire
[F:BDE]DES    = mess(78,108,1)-[M:BUC0]BUDFOR-"("+GUSER+")"
[F:BDE]ENAEXT = 1
[F:BDE]BUDTYP = TRBUD
If dim([F:BDE]CREUSR)>0 : [F:BDE]CREUSR = GUSER : Endif
If dim([F:BDE]CREDAT)>0 : [F:BDE]CREDAT = date$ : Endif
Write [BDE]
If fstat
 GOK = 0 : Call FSTA("BDE") From GLOCK : Return
Endif
NBOD += 1
Return


###################################################################
# Base de transfert en montants annuel
###################################################################
$BUD_AN
Columns [BUD] (AMT,QTY)
For I=1 To NBBUDFOR : # Indice 0=Budget à calculer
 Gosub INI_LIGBUD
 If OKCAL
  AMTBUD(I) = 0
  QTYBUD(I) = 0
  AMTREA(I) = 0
  AMTCMM(I) = 0
  AMTPRP(I) = 0
  QTYREA(I) = 0
  QTYCMM(I) = 0
  QTYPRP(I) = 0
  For J=[M:BUC1]FIYSTR(I) To [M:BUC1]FIYEND(I)
   EXO = J
   # Recherche de la période début et de la période fin de chaque exercice
   Raz PDEB,PFIN
   If J=[M:BUC1]FIYSTR(I) : PDEB = [M:BUC1]PERDEB(I) : Endif
   If J=[M:BUC1]FIYEND(I) : PFIN = [M:BUC1]PERFIN(I) : Endif
   If PDEB=0 : PDEB = 1 : Endif
   If PFIN=0 : Call NBPER([M:BUC1]CPY(I),[M:BUC1]LEDTYP(I),J,PFIN) From CPTSUB : Endif
   If PFIN=0 : GOK = 0 : Break 2 : Endif
   If [M:BUC1]TYP(I)=1 : # Budget
    Gosub CRITBUD
    Filter [BUD] Where LEDTYP=[M:BUC1]LEDTYP(I) & BUD=[M:BUC1]BUD(I) & CPY=[M:BUC1]CPY(I) & FCY=[M:BUC1]FCY(I) &
&   VER=VERSION & FIY=EXO & evalue(CRITBAL)
    For [BUD]BUD0
     # On a les montants budgétés dans la devise du budget qui sert de base au calcul
     AMTBUD(I) += sum([F:BUD]AMT(PDEB-1..PFIN-1))
     QTYBUD(I) += sum([F:BUD]QTY(PDEB-1..PFIN-1))
    Next
    Filter [BUD]
   Else  : # Balance
    FLQTE = 0 : Gosub BALANA
    If CALQTE
     FLQTE = 1 : Gosub BALANA
    Endif
   Endif
  Next J
 Endif
 # On convertit dans la devise du budget à calculer
 Case [M:BUC1]TYP(I)
  When 1 : # Budget
   ORGBUD(I) = AMTBUD(I)
   Call CONVERT(DEVBUDO,DEVBUD,DEVCUR,TYPCUR,AMTBUD(I),MESSA,STAT)
  When 2 : # Réel
   ORGREA(I) = AMTREA(I)
   Call CONVERT(DEVCUR,DEVBUD,DEVCUR,TYPCUR,AMTREA(I),MESSA,STAT)
  When 3 : # Engagé
   ORGCMM(I) = AMTCMM(I)
   Call CONVERT(DEVCUR,DEVBUD,DEVCUR,TYPCUR,AMTCMM(I),MESSA,STAT)
  When 4 : # Pré engagé
   ORGPRP(I) = AMTPRP(I)
   Call CONVERT(DEVCUR,DEVBUD,DEVCUR,TYPCUR,AMTPRP(I),MESSA,STAT)
 Endcase
 If STAT : Gosub ERR_TRACE : GOK = 0 : Break : Endif
Next I
Columns [BUD]
Gosub CALBUD_AN
If GOK<1 : Goto FIN : Endif
Return

###################################################################
# Calcul du budget en montants annuel
###################################################################
$CALBUD_AN
# On applique la répartition temporelle
Gosub CAL_COEF
# On a les valeurs des variables AMTxxx et QTxxx qui composent la formule de calcul
Raz TOTAMT,TOTQTY
Raz RESAMT,RESQTY
ERREUR = 0
Onerrgo ERR_FORMULE
TOTAMT = evalue(FORMULE1)
Onerrgo
If ERREUR : GOK = 0 : Return : Endif
If CALQTE & UNITE<>""
 Onerrgo ERR_FORMULE
 TOTQTY = evalue(FORMULE2)
 Onerrgo
 If ERREUR : GOK = 0 : Return : Endif
Endif
Call LEC_BUP(BUDGET) From CPTLEC
For EXO=[M:BUC1]FIYSTR(0) To [M:BUC1]FIYEND(0)
 Raz SUMAMT, SUMQTY
 #103694 : Calcul un exo N complet puis un exo N+1 sur les P premières periodes, il faut raz les mts calculés sur N pour P+1..
 Raz RESAMT,RESQTY
 Raz [F:BUD]
 # Recherche de la période début et de la période fin de chaque exercice
 Raz PDEB,PFIN
 If EXO=[M:BUC1]FIYSTR(0) : PDEB = [M:BUC1]PERDEB(0) : Endif
 If EXO=[M:BUC1]FIYEND(0) : PFIN = [M:BUC1]PERFIN(0) : Endif
 If PDEB=0 : PDEB = 1 : Endif
 If PFIN=0
  PFIN = PERNUMEND(EXO-[M:BUC1]FIYSTR(0))
 Endif
 If PFIN=0 : Break : Endif

 #*X3-66273 because PERDATSTR() and PERDATEND() are always null
 Gosub READ_PER
 # If ODBUD
 # DEBEX = PERDATSTR(EXO-[M:BUC1]FIYSTR(0))
 # FINEX = PERDATEND(EXO-[M:BUC1]FIYSTR(0))
 # Endif
 #*X3-66273 END

 For I=PDEB To PFIN
  MTREP           = TOTAMT*COEDTP(EXO,I)/SUMCOE
  RESAMT(I-1)     = arr(SUMAMT+MTREP,[F:TCU]CURRND)-arr(SUMAMT,[F:TCU]CURRND)
  SUMAMT         += MTREP
  If CALQTE & UNITE<>""
   QTREP          = TOTQTY*COEDTP(EXO,I)/SUMCOE
   RESQTY(I-1)    = arr(SUMQTY+QTREP,10^(-[F:TUN]UOMDEC))-arr(SUMQTY,10^(-[F:TUN]UOMDEC))
   SUMQTY        += QTREP
  Endif
 Next I
 Gosub MAJ_BUD
 If GOK<1 : Break : Endif
Next EXO
Return

# YYFIN_104036_US24 #$READ_PER removed
#*X3-66273
$READ_PER
If ODBUD
  Read [PER]PER0=SOCIETE;TYPREF;EXO;PDEB
  If !fstat : DEBEX = [F:PER]PERSTR : Endif
  Read [PER]PER0=SOCIETE;TYPREF;EXO;PFIN
  If !fstat : FINEX = [F:PER]PEREND : Endif
Endif
Return
#*X3-66273 END

$CAL_COEF
If [F:DTP]DTP<>CODRTP or SUMCOE=0
 Gosub SUM_COE
Endif
Return

$SUM_COE
Call LEC_DTP(CODRTP) From CPTLEC
If fstat or CODRTP=""
 For I=0 To dim([F:DTP]COE)-1
  [F:DTP]COE(I) = 1
 Next
Endif
Raz COEDTP, SUMCOE
For EXO=[M:BUC1]FIYSTR(0) To [M:BUC1]FIYEND(0)
 # Recherche de la période début et de la période fin de chaque exercice
 Raz PDEB,PFIN
 If EXO=[M:BUC1]FIYSTR(0) : PDEB = [M:BUC1]PERDEB(0) : Endif
 If EXO=[M:BUC1]FIYEND(0) : PFIN = [M:BUC1]PERFIN(0) : Endif
 If PDEB=0 : PDEB = 1 : Endif
 If PFIN=0
  PFIN = PERNUMEND(EXO-[M:BUC1]FIYSTR(0))
 Endif
 If PFIN=0 : Break : Endif
 # Recherche du coefficient
 For I=PDEB To PFIN
  Read [PER]PER0=SOCIETE;TYPREF;EXO;I
  If !fstat
   DATDEB = [F:PER]PERSTR
   DATFIN = [F:PER]PEREND
  Endif
  While DATDEB<>[0/0/0]
   M = month(DATDEB)        : # M contient le no du mois de DATDEB
   N = day(eomonth(DATDEB)) : # N contient le dernier jour de DATDEB
   If M=month(DATFIN)       : # J contient le nb de jours de la période I
    J = DATFIN-DATDEB+1
    DATDEB = [0/0/0]
   Else
    J = eomonth(DATDEB)-DATDEB+1
    DATDEB = eomonth(DATDEB)+1
   Endif
   COEDTP(EXO,I) += [F:DTP]COE(M-1)*J/N
  Wend
  SUMCOE += COEDTP(EXO,I)
 Next
Next
Return

################################################################
## Déclarations
################################################################
$DECLARE
# Chaque indice correspond à un budget entrant dans le calcul.
# Ex : Si F1 = Montant réel, Alors on stocke dans AMTREA(1) le montant réel du budget
# On prend [M:BUC1]NBLIG-1 car la 1ère ligne du tableau concerne le budget cible à trouver
Local Decimal AMTBUD(1..max(1,[M:BUC1]NBLIG-1)) : # Montant budgété
Local Decimal ORGBUD(1..max(1,[M:BUC1]NBLIG-1)) : # Montant budgété
Local Decimal AMTREA(1..max(1,[M:BUC1]NBLIG-1)) : # Montant réel
Local Decimal ORGREA(1..max(1,[M:BUC1]NBLIG-1)) : # Montant réel
Local Decimal AMTCMM(1..max(1,[M:BUC1]NBLIG-1)) : # Montant engagé
Local Decimal ORGCMM(1..max(1,[M:BUC1]NBLIG-1)) : # Montant engagé
Local Decimal AMTPRP(1..max(1,[M:BUC1]NBLIG-1)) : # Montant pré engagé
Local Decimal ORGPRP(1..max(1,[M:BUC1]NBLIG-1)) : # Montant pré engagé
Local Decimal QTYBUD(1..max(1,[M:BUC1]NBLIG-1)) : # Quantité budgété
Local Decimal QTYREA(1..max(1,[M:BUC1]NBLIG-1)) : # Quantité réel
Local Decimal QTYCMM(1..max(1,[M:BUC1]NBLIG-1)) : # Quantité engagé
Local Decimal QTYPRP(1..max(1,[M:BUC1]NBLIG-1)) : # Quantité pré engagé
Local Decimal TOTAMT,TOTQTY              : # Résultat de la formule de calcul
# Contient les montants ou quantités de l'enregistrement BUD ou BALANA
# qui correspond à la ligne du budget (Montants/périodes)
Local Decimal PAMT(1..max(1,[M:BUC1]NBLIG-1),0..dim([F:BUD]AMT)-1)
Local Decimal DAMT(1..max(1,[M:BUC1]NBLIG-1),0..dim([F:BUD]AMT)-1)
Local Decimal PQTY(1..max(1,[M:BUC1]NBLIG-1),0..dim([F:BUD]QTY)-1)
Local Char    FORMULE1(250)              : # Formule de calcul du budget en montant
Local Char    FORMULE2(250)              : # Formule de calcul du budget en quantité
Local Char    CODRTP(GLONDTP)            : # Code de répartition temporelle
Local Integer I, J, K, STAT, M, N, INDAXE
Local Char    SUITE(50)                  : # Caractères autorisés dans le nom d'une variable
Local Integer RANG
Local Char    DEVCUR(GLONCUR)            : # Devise de balance société courante
Local Char    DEVBUDO(GLONCUR)           : # Devise du budgets origine
Local Char    DEVBUD(GLONCUR)            : # Devise du budget à calculer
Local Integer PDEB, PFIN, EXO            : # N°periode début et fn de l'exo en cours
Local Date    DATDEB, DATFIN             : # Calcul de la répartition(Montants annuels)
Local Decimal COEDTP(1..99,1..99)
Local Decimal SUMCOE, SUMAMT, SUMQTY
Local Decimal MTREP, QTREP
Local Integer NBVARIA, NBBUDFOR          : # Nombre de variables, Nombre de formules F*
Local Char    VALACC(20)
Local Char    VALCCE1(20), VALCCE2(20), VALCCE3(20), VALCCE4(20), VALCCE5(20), VALCCE6(20), VALCCE7(20), VALCCE8(20), VALCCE9(20)
Local Integer NBEXO                      : # Nombre d'exercice (Montants/périodes)
NBVARIA  = [M:DIA]NBLIG2
NBBUDFOR = [M:BUC1]NBLIG-1
Local Char    VARIA(10)(1..max(1,NBVARIA))       : # Tableau des variables
Local Char    VARVAL(20)(1..max(1,NBVARIA))      : # Tableau des valeurs
Local Char    BUDFOR(10)(1..max(1,NBBUDFOR))     : # Tableau des formules de budgets origines du calcul
Local Char    BUDGET(GLONBUP) , SOCIETE(GLONCPY) , SITE(GLONFCY), SAVSOC(GLONCPY)
Local Integer TYPREF , SIGN , CALQTE , FLQTE
Local Char    CRITBAL(250)(0..4) , VERSION(20) , VERBUD(20)
Local Integer ICRIT
Local Char    PLAN(GLONCOA) , PYRCPT(GLONGYM) , COMPTE(max(GLONGAC,GLONGRY))
Local Char    CRITACC(20),CRITCCE1(20),CRITCCE2(20),CRITCCE3(20),CRITCCE4(20),CRITCCE5(20),CRITCCE6(20),CRITCCE7(20),CRITCCE8(20),CRITCCE9(20)
Local Char    LIBBUP(GLONAX3)
Local Integer NIVCPT
Local Char    AXE1(GLONDIE),AXE2(GLONDIE),AXE3(GLONDIE),AXE4(GLONDIE),AXE5(GLONDIE),AXE6(GLONDIE),AXE7(GLONDIE),AXE8(GLONDIE),AXE9(GLONDIE)
Local Char    SEC1(max(GLONCCE,GLONCRY)) , SEC2(max(GLONCCE,GLONCRY)) , SEC3(max(GLONCCE,GLONCRY)), SEC4(max(GLONCCE,GLONCRY))
Local Char    SEC5(max(GLONCCE,GLONCRY)) , SEC6(max(GLONCCE,GLONCRY)) , SEC7(max(GLONCCE,GLONCRY)), SEC8(max(GLONCCE,GLONCRY)), SEC9(max(GLONCCE,GLONCRY))
Local Char    PYRSEC1(GLONCYM),PYRSEC2(GLONCYM),PYRSEC3(GLONCYM),PYRSEC4(GLONCYM),PYRSEC5(GLONCYM),PYRSEC6(GLONCYM),PYRSEC7(GLONCYM),PYRSEC8(GLONCYM),PYRSEC9(GLONCYM)
Local Integer NIVSEC1,NIVSEC2,NIVSEC3,NIVSEC4,NIVSEC5,NIVSEC6,NIVSEC7,NIVSEC8,NIVSEC9,NIVSEC10
Local Integer IAXE1,IAXE2,IAXE3,IAXE4,IAXE5,IAXE6,IAXE7,IAXE8,IAXE9
Local Char    BUDDIE(GLONDIE)(0..8)
Local Char    BUDCCE(max(GLONCCE,GLONCYR))(0..8)
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Decimal RESAMT(0..dim([F:BUD]AMT)-1)
Local Decimal RESQTY(0..dim([F:BUD]QTY)-1)
Local Char    UNITE(GLONUOM)
Local Char    VACC(20)
Local Char    VCCE1(20),VCCE2(20),VCCE3(20),VCCE4(20),VCCE5(20),VCCE6(20),VCCE7(20),VCCE8(20),VCCE9(20)
Local Char    CRIT0(250),CRIT1(250),CRIT2(250),CRIT3(250),CRIT4(250),CRIT5(250),CRIT6(250),CRIT7(250),CRIT8(250),CRIT9(250),MESSA(250)
Local Integer TYPCUR
Local Char    VALPAR(10)
Local Integer NOMBRE , NBDEL , NBMAJ
Local Char    TSYMBOLE(50)(1..10)
Local Integer NBLOK , VERROU , ERREUR , OKCAL
Local Char    REFERENTIEL(GLONLED)
Local Integer ODBUD , LIGOD , SIMUL , MAXOD , NBOD
Local Decimal DELTA_AMT , DELTA_QTY
Local Date    DEBEX , FINEX
Local Char    TRBUD(GLONTBU)
Local Char    DEBOD(GLONVCR) , FINOD(GLONVCR)
Local Integer OKSOC
Local Char    NUMCPT (GLONVCR)               : # No pour compteur d'OD budgétaires
Local Integer X, NBRLIG
Local Char    LEGCLS(GLONADI)
Return

$OUVFIC
#
# BALANA et BLAQTY ne sont pas ouvertes, car on switche avec BLACMM en fonction des besoins
#
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUD2])=0 : Local File BUD        [BUD2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
