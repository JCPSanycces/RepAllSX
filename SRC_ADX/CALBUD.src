 If PYRSEC9=""
  For [CCE9]CCE0 Where DIE=AXE9 & BUDTRK=2 & pat(CCE,CRITCCE9)<>0
   SEC9 = [F:CCE9]CCE : Gosub CALCUL
  Next
 Else
