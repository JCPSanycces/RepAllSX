##########################################################################
## Verrous
##########################################################################
$VERROU
NBLOK  = 0
VERROU = 1
If [M:BUC1]FIYEND(0)-[M:BUC1]FIYSTR(0)>=dim(TSYMBOLE)
 Call ECR_TRACE(mess(135,141,1)-num$([M:BUC1]STRDAT(0))-num$([M:BUC1]ENDDAT(0)),1) From GESECRAN
 VERROU = 0
 Return
Endif
For J=[M:BUC1]FIYSTR(0) To [M:BUC1]FIYEND(0)
 NBLOK += 1
 TSYMBOLE(NBLOK) = "BUD"+BUDGET+"\"+SOCIETE+"\"+SITE+"\"+VERBUD+"\"+num$(J)
 Lock =TSYMBOLE(NBLOK) With lockwait=0
 If fstat
  # Modification en cours sur autre poste
  MESSA = mess(10,100,1)
  Gosub ERR_TRACE
  Gosub DEVERROU
  VERROU = 0
  Break
 Endif
Next J
Return

$DEVERROU
For I=1 To NBLOK
 Unlock =TSYMBOLE(I)
Next
Return

$ERR_FORMULE
If errn<>53 : # Division par 0 => on arrête pas les calculs
 ERREUR = errn
 # Formule incorrecte
 MESSA = mess(9,108,1)-":"-num$([M:BUC0]CLCFOR)+"\"+errmes$(ERREUR)+"\|"+errm+"|"
 Gosub ERR_TRACE
Endif
Resume

##########################################################################
## Retourne s'il y a un joker dans la chaine
##########################################################################
Funprog JOKER(CHAINE)
Value Char CHAINE
If instr(1,CHAINE,"*") | instr(1,CHAINE,"?") | instr(1,CHAINE,"#") | instr(1,CHAINE,"!")
 End 1
Else
 End 0
Endif
End

##########################################################################
## Conversion devises
##########################################################################
Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCUR,MNT,MESSA,STA)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Char    DEVSOC
Value    Integer TYPCUR
Variable Decimal MNT
Variable Char    MESSA()
Variable Integer STA
If DEVORG<>DEVDES
 Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCUR,datesyst,MNT,MNT,STA) From TRTDEV
 If STA
  # Pas de cours
  MESSA = mess(4,109,1)-DEVORG-"=>"-DEVDES
  End
 Endif
Endif
End

Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCUR,MNT,LIG,MESSA,STA)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Char    DEVSOC
Value    Integer TYPCUR
Variable Decimal MNT(1..,0..)
Value    Integer LIG
Variable Char    MESSA()
Variable Integer STA
# Pour convertir PAMT en devise du budget il faut un tableau à 1 dimension
Local Integer    K
Local Decimal    PAMTBUD(0..dim([F:BUD]AMT)-1)
If DEVORG<>DEVDES
 For K=0 To dim([F:BUD]AMT)-1
  PAMTBUD(K) = MNT(LIG,K)
 Next
 Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCUR,datesyst,PAMTBUD,PAMTBUD,STA) From TRTDEV
 If STA
  # Pas de cours
  MESSA = mess(4,109,1)-DEVORG-"=>"-DEVDES
  End
 Endif
 For K=0 To dim([F:BUD]AMT)-1
  MNT(LIG,K) = PAMTBUD(K)
 Next
Endif
End

