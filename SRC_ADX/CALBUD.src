#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ,GBIDI1
Call OBJET("BUC",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-66273 - MDJ : No period defined on the budget Mos
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
Endcase
Return

$INIT_DIA
[M:DIA] = [M:BUC2]
Return

$CONTROLE
Gosub OUVFIC
Read [BUV]BUV0 = [M:BUC1]BUD(0);[M:BUC1]VER(0)
If fstat
 Call ERREUR([M:BUC1]BUD(0)-[M:BUC1]VER(0)-mess(144,111,1)) From GESECRAN
 FIN = 1 : Return
Elsif [F:BUV]STA=2
 Call ERREUR([M:BUC1]BUD(0)-[M:BUC1]VER(0)-mess(58,109,1)) From GESECRAN
 FIN = 1 : Return
Endif
TMP = 1
TRA = 1
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Call FERME_TRACE From LECFIC
Return

$TR_EXEC
# tmp
GOK = 1
Gosub DECLARE
Gosub DEBUT
Gosub OUVRE_TRACE
Gosub DEB_TRACE
Gosub TRADUC_EXPR
If ERREUR : Return : Endif
Gosub VERROU
If !VERROU : Return : Endif
NBDEL = 0
Trbegin [BUD2]
If [M:BUC0]DEL=2
 For EXO=[M:BUC1]FIYSTR(0) To [M:BUC1]FIYEND(0)
  Delete [BUD2] Where LEDTYP=TYPREF & BUD=BUDGET & CPY=SOCIETE & FCY=SITE & FIY=EXO & VER=VERBUD
  If fstat=1
   GOK = -1 : GLOCK = "$BUD"-[M:BUC1]BUD(0)-SOCIETE-SITE-num$(EXO)-VERBUD : Break
  Endif
  NBDEL += adxdlrec
 Next
 If GOK<1 : Goto FIN : Endif
 Gosub DEL_TRACE
Endif
NBMAJ = 0
NBDEL = 0
Gosub CALBUD
If GOK<1 : Goto FIN : Endif
If SIMUL : Rollback : Else : Commit : Endif
Gosub FIN_TRACE
If ODBUD & NBOD
 Gosub OD_TRACE
Endif
Gosub DEVERROU
Return

$FIN
If GOK=0
 Rollback
Elsif GOK<0
 Rollback
 Call ROLL From GLOCK
 If !GROLL : Goto TR_EXEC : Endif
Endif
Gosub DEVERROU
Columns [CCE1]
Columns [CCE2]
Columns [CCE3]
Columns [CCE4]
Columns [CCE5]
Columns [CCE6]
Columns [CCE7]
Columns [CCE8]
Columns [CCE9]
Columns [CRY1]
Columns [CRY2]
Columns [CRY3]
Columns [CRY4]
Columns [CRY5]
Columns [CRY6]
Columns [CRY7]
Columns [CRY8]
Columns [CRY9]
Columns [CYK1]
Columns [CYK2]
Columns [CYK3]
Columns [CYK4]
Columns [CYK5]
Columns [CYK6]
Columns [CYK7]
Columns [CYK8]
Columns [CYK9]
Return

#########################################################################################################
# Trace
#########################################################################################################
$OUVRE_TRACE
Local Char INTIT(GLONAX3)
Call OUVRE_TRACE(mess(78,108,1)) From LECFIC
Call LECTEXTRA([L]INTIT,"BUDFORCAL","DESTRA",[M:BUC0]BUDFOR,num$(0)) From ATEXTRA
Call ECR_TRACE(mess(78,108,1)-[M:BUC0]BUDFOR-[L]INTIT,0) From GESECRAN
If SIMUL
 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return

$DEB_TRACE
Call LEC_BUP(BUDGET) From CPTLEC
Call LECTEXTRA([L]LIBBUP,"BUDPAR","DESTRA",BUDGET,"") From ATEXTRA
Call ECR_TRACE(mess(2,116,1)-[M:BUC1]CPY(0)-mess(5,116,1)-[M:BUC1]FCY(0)
& -"("+mess(208,111,1)-mess([M:BUC1]LEDTYP(0),2644,1)+")",0) From GESECRAN
Call ECR_TRACE(mess(79,108,1)-[M:BUC1]BUD(0)-[L]LIBBUP-mess(126,105,1)-[M:BUC1]VER(0)-"("+[F:BUP]CUR+")"
& -mess(4,197,1)-format$("D:"+GFMDAT4,[M:BUC1]STRDAT(0))
& -mess(38,197,1)-format$("D:"+GFMDAT4,[M:BUC1]ENDDAT(0)),0) From GESECRAN
If [M:DIA]TRACE=2
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(135,105,1)-":"-[M:BUC0]CLCFOR,0) From GESECRAN
 For I=1 To NBBUDFOR
  MESSA  = space$(10)+"F"+num$(I)-":"-mess([M:BUC1]TYP(I),874,1)-[M:BUC1]CPY(I)-[M:BUC1]FCY(I)
  MESSA -= "("+mess([M:BUC1]LEDTYP(I),2644,1)+")"
  MESSA -= [M:BUC1]BUD(I)-[M:BUC1]VER(I)-"("+[M:BUC1]CUR(I)+")"
  MESSA -= format$("D:"+GFMDAT4,[M:BUC1]STRDAT(I))-format$("D:"+GFMDAT4,[M:BUC1]ENDDAT(I))
  Call ECR_TRACE(MESSA,0) From GESECRAN
 Next I
 If NBVARIA
  Call ECR_TRACE("",0) From GESECRAN
  For I=0 To NBVARIA-1
   MESSA  = space$(10)+[M:DIA]VARCOD(I)-[M:DIA]DES(I)-":"-[M:DIA]VARVAL(I)
   Call ECR_TRACE(MESSA,0) From GESECRAN
  Next I
 Endif
Endif
Call ECR_TRACE("",0) From GESECRAN
Return

$TRACE
If sum(RESAMT)<>0 | sum(RESQTY)<>0
 MESSA = COMPTE
 If AXE1<>"" : MESSA -= "/"-SEC1 : Endif
 If AXE2<>"" : MESSA -= "/"-SEC2 : Endif
 If AXE3<>"" : MESSA -= "/"-SEC3 : Endif
 If AXE4<>"" : MESSA -= "/"-SEC4 : Endif
 If AXE5<>"" : MESSA -= "/"-SEC5 : Endif
 If AXE6<>"" : MESSA -= "/"-SEC6 : Endif
 If AXE7<>"" : MESSA -= "/"-SEC7 : Endif
 If AXE8<>"" : MESSA -= "/"-SEC8 : Endif
 If AXE9<>"" : MESSA -= "/"-SEC9 : Endif
 MESSA -= ":"-mess(85,108,1)-num$(sum(RESAMT))-DEVBUD
 If CALQTE & sum(RESQTY)<>0
  MESSA -= ","-num$(sum(RESQTY))-UNITE
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 If [M:DIA]TRACE=2
  If [M:BUC0]FLGDSP=1
   Raz ORGBUD,ORGREA,ORGCMM,ORGPRP
   Raz QTYBUD,QTYREA,QTYCMM,QTYPRP
   For I=1 To NBBUDFOR
    For K=0 To dim([F:BUD2]AMT)-1
     Case [M:BUC1]TYP(I)
      When 1 : ORGBUD(I) += DAMT(I,K) : QTYBUD(I) += PQTY(I,K)
      When 2 : ORGREA(I) += DAMT(I,K) : QTYREA(I) += PQTY(I,K)
      When 3 : ORGCMM(I) += DAMT(I,K) : QTYCMM(I) += PQTY(I,K)
      When 4 : ORGPRP(I) += DAMT(I,K) : QTYPRP(I) += PQTY(I,K)
     Endcase
    Next K
   Next I
  Endif
  For I=1 To NBBUDFOR
   MESSA = space$(10)+"F"+num$(I)-":"
   Case [M:BUC1]TYP(I)
    When 1 : MESSA -= num$(ORGBUD(I))
    When 2 : MESSA -= num$(ORGREA(I))
    When 3 : MESSA -= num$(ORGCMM(I))
    When 4 : MESSA -= num$(ORGPRP(I))
   Endcase
   MESSA -= [M:BUC1]CUR(I)
   If CALQTE & sum(RESQTY)<>0
    Case [M:BUC1]TYP(I)
     When 1 : MESSA -= ","-num$(QTYBUD(I))
     When 2 : MESSA -= ","-num$(QTYREA(I))
     When 3 : MESSA -= ","-num$(QTYCMM(I))
     When 4 : MESSA -= ","-num$(QTYPRP(I))
    Endcase
    MESSA -= UNITE
   Endif
   Call ECR_TRACE(MESSA,0) From GESECRAN
  Next I
 Endif
Endif
Return

$DEL_TRACE
If NBDEL
 Call ECR_TRACE(num$(NBDEL)-mess(20,133,1),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
Endif
Return

$OD_TRACE
If DEBOD<>""
 Call ECR_TRACE("",0) From GESECRAN
 MESSA = DEBOD
 If FINOD<>""
  MESSA -= "=>"-FINOD-"("+num$(NBOD)+")"
 Endif
 Call ECR_TRACE(mess(59,108,1)-MESSA,0) From GESECRAN
Endif
Return

$FIN_TRACE
Call ECR_TRACE("",0) From GESECRAN
If NBDEL
 MESSA = num$(NBDEL)-mess(20,133,1)
 If SIMUL : MESSA -= "("+mess(6,115,1)+")" : Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif
If NBMAJ
 MESSA = num$(NBMAJ)-mess(192,124,1)
 If SIMUL : MESSA -= "("+mess(6,115,1)+")" : Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif
Return

$ERR_TRACE
Call ECR_TRACE(MESSA,1) From GESECRAN
Return

#########################################################################################################
# Traduction de la formule de calcul du budget en remplaçant V_xxxxx et F*
# Il faut calculer le budget en quantité et en montant => on traduit en FORMULE1 et FORMULE2
#########################################################################################################
$TRADUC_EXPR
# Remplissage du tableau des variables
For I=1 To NBVARIA
 VARIA(I)  = [M:DIA]VARCOD(I-1)
 VARVAL(I) = [M:DIA]VARVAL(I-1)
Next I

# Remplissage du tableau des formules de budgets origines
For I=1 To NBBUDFOR
 BUDFOR(I) = [M:BUC1]FORNAM(I)
Next I

FORMULE1 = [M:BUC0]CLCFOR
SUITE    = "ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"

# On remplace les variables V_xxxxx par leurs valeurs
For I=1 To NBVARIA
 K = 1 : RANG = 1
 While K
  K = instr(RANG,FORMULE1,VARIA(I))
  If K
   # Si 2 variables commencent par les mêmes lettres il faut éviter la confusion
   # Exemple : V_MT et V_MT2
   If instr(1,SUITE,mid$(FORMULE1,K+len(VARIA(I)),1)) & len(FORMULE1)>K+len(VARIA(I))-1
    RANG = K+len(VARIA(I))
   Else
    If VARVAL(I)=""
     MESSA = mess(9,108,1)-":"-num$([M:BUC0]CLCFOR)-"\"-VARIA(I)-":"-mess(72,108,1)
     Gosub ERR_TRACE : ERREUR = 1
     Break
    Endif
    FORMULE1 = left$(FORMULE1,K-1)+VARVAL(I)+right$(FORMULE1,K+len(VARIA(I)))
    RANG = K+len(VARVAL(I))
   Endif
  Endif
 Wend
Next I
If ERREUR : Return : Endif

# Vérif valeur nulles + contrôles dans version, compte, sections
Call LEC_BUP([M:BUC1]BUD(0)) From CPTLEC
For I=1 To NBVARIA
 # Variable utilisée dans une version ou dans un compte de 1ère ligne
 If find(VARIA(I),[M:BUC1]VER(0..NBBUDFOR))
& or find(VARIA(I),[M:BUC1]ACC(0),[M:BUC1]CCE1(0),[M:BUC1]CCE2(0),[M:BUC1]CCE3(0))
  If VARVAL(I)=""
   MESSA = mess(9,108,1)-":"-VARIA(I)-":"-mess(72,108,1)
   Gosub ERR_TRACE : ERREUR = 1
   Break
  Endif
 Endif
 If find(VARIA(I),[M:BUC1]ACC(0),[M:BUC1]CCE1(0),[M:BUC1]CCE2(0),[M:BUC1]CCE3(0),
&                 [M:BUC1]CCE4(0),[M:BUC1]CCE5(0),[M:BUC1]CCE6(0),[M:BUC1]CCE7(0),
&                 [M:BUC1]CCE8(0),[M:BUC1]CCE9(0)) & !func JOKER(VARVAL(I))
  If VARIA(I)=[M:BUC1]ACC(0)
   If [F:BUP]PYMACC=""
    Call CONTROLE("GAC","",VARVAL(I),[F:BUP]COA,mkstat) From CONTOBJ
    If mkstat
     MESSA = VARVAL(I)-mess(44,102,1)
     Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
    If [F:GAC]BUDTRK<>2
     MESSA = VARVAL(I)-mess(4,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
    If [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND<[M]STRDAT(0) | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[M]ENDDAT(0)
     MESSA = VARVAL(I)-mess(6,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
   Else
    Call CONTROLE("GRY","",VARVAL(I),[F:BUP]PYMACC,mkstat) From CONTOBJ
    If mkstat
     MESSA = VARVAL(I)-mess(31,103,1)
     Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
    If [F:GRY]BUDTRK<>2
     MESSA = VARVAL(I)-mess(26,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
    If [F:GRY]LEV<>[F:BUP]PYMACCLEV
     MESSA = VARVAL(I)-mess(31,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
   Endif
  Endif
  For K=0 To 8
   If VARIA(I)=evalue("[M:BUC1]CCE"+num$(K+1)+"(0)")
    If [F:BUP]PYMCCE(K)=""
     Call CONTROLE("CCE","",VARVAL(I),[F:BUP]DIE(K),mkstat) From CONTOBJ
     If mkstat
      MESSA = VARVAL(I)-mess(35,106,1)
      Gosub ERR_TRACE : ERREUR = 1 : Break
     Endif
     If [F:CCE]BUDTRK<>2
      MESSA = VARVAL(I)-mess(5,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
     Endif
     If [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[M]STRDAT(0) | [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[M]ENDDAT(0)
      MESSA = VARVAL(I)-mess(7,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
    Endif
    Else
     Call CONTROLE("CRY","",VARVAL(I),[F:BUP]PYMCCE(K),mkstat) From CONTOBJ
     If mkstat
      MESSA = VARVAL(I)-mess(32,103,1)
      Gosub ERR_TRACE : ERREUR = 1 : Break
     Endif
     If [F:CRY]BUDTRK<>2
      MESSA = mess(27,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
     Endif
     If [F:CRY]LEV<>[F:BUP]PYMCCELEV(K)
      MESSA = mess(32,103,1) : Gosub ERR_TRACE : ERREUR = 1 : Break
     Endif
    Endif
   Endif
  Next K
 Endif
Next I
If ERREUR : Return : Endif

FORMULE2 = FORMULE1
SUITE    = "0123456789"

# Dans FORMULE1 on remplace les formules budgets F* par les variables AMTxxx
# Dans FORMULE2 on remplace les formules budgets F* par les variables QTYxxx
For I=1 To NBBUDFOR
 K = 1 : RANG = 1
 While K
  K = instr(RANG,FORMULE1,BUDFOR(I))
  If K
   # Si 2 formules commencent par les mêmes lettres il faut éviter la confusion (F1 et F12)
   If instr(1,SUITE,mid$(FORMULE1,K+len(BUDFOR(I)),1)) & len(FORMULE1)>K+len(BUDFOR(I))-1
    RANG = K + len(BUDFOR(I))
   Else
    Case [M:BUC1]TYP(I)
     When 1 : # Budgété
      FORMULE1 = left$(FORMULE1,K-1)+"AMTBUD("+num$(I)+")"+right$(FORMULE1,K+len(BUDFOR(I)))
      FORMULE2 = left$(FORMULE2,K-1)+"QTYBUD("+num$(I)+")"+right$(FORMULE2,K+len(BUDFOR(I)))
     When 2 : # Réel
      FORMULE1 = left$(FORMULE1,K-1)+"AMTREA("+num$(I)+")"+right$(FORMULE1,K+len(BUDFOR(I)))
      FORMULE2 = left$(FORMULE2,K-1)+"QTYREA("+num$(I)+")"+right$(FORMULE2,K+len(BUDFOR(I)))
     When 3 : # Engagé
      FORMULE1 = left$(FORMULE1,K-1)+"AMTCMM("+num$(I)+")"+right$(FORMULE1,K+len(BUDFOR(I)))
      FORMULE2 = left$(FORMULE2,K-1)+"QTYCMM("+num$(I)+")"+right$(FORMULE2,K+len(BUDFOR(I)))
     When 4 : # Pré engagé
      FORMULE1 = left$(FORMULE1,K-1)+"AMTPRP("+num$(I)+")"+right$(FORMULE1,K+len(BUDFOR(I)))
      FORMULE2 = left$(FORMULE2,K-1)+"QTYPRP("+num$(I)+")"+right$(FORMULE2,K+len(BUDFOR(I)))
    Endcase
    RANG = K + 8 + (len(BUDFOR(I))-1)
   Endif
  Endif
 Wend
Next
If parse(FORMULE1)
 ERREUR = 1
 MESSA = mess(9,108,1)-":"-num$([M:BUC0]CLCFOR)
 Gosub ERR_TRACE
 Return
Endif
Return

###################################################################
# Init des variables
###################################################################
$DEBUT

# Structure du budget à calculer
BUDGET  = [M:BUC1]BUD(0)
SOCIETE = [M:BUC1]CPY(0)
SITE    = [M:BUC1]FCY(0)
TYPREF  = [M:BUC1]LEDTYP(0)
Call LEC_BUP(BUDGET) From CPTLEC
Call LEC_CPY(SOCIETE)  From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
REFERENTIEL = [F:GCM]LED(TYPREF-1)
Call LEC_LED(REFERENTIEL) From CPTLEC
DEVCUR  = [F:GCM]CUR(TYPREF-1)
DEVBUD  = [F:BUP]CUR
PLAN    = [F:BUP]COA
Call LEC_COA(PLAN) From CPTLEC
LEGCLS  = [F:COA]LEGCLS
PYRCPT  = [F:BUP]PYMACC
NIVCPT  = [F:BUP]PYMACCLEV
AXE1    = [F:BUP]DIE(0)
PYRSEC1 = [F:BUP]PYMCCE(0)
NIVSEC1 = [F:BUP]PYMCCELEV(0)
AXE2    = [F:BUP]DIE(1)
PYRSEC2 = [F:BUP]PYMCCE(1)
NIVSEC2 = [F:BUP]PYMCCELEV(1)
AXE3    = [F:BUP]DIE(2)
PYRSEC3 = [F:BUP]PYMCCE(2)
NIVSEC3 = [F:BUP]PYMCCELEV(2)
AXE4    = [F:BUP]DIE(3)
PYRSEC4 = [F:BUP]PYMCCE(3)
NIVSEC4 = [F:BUP]PYMCCELEV(3)
AXE5    = [F:BUP]DIE(4)
PYRSEC5 = [F:BUP]PYMCCE(4)
NIVSEC5 = [F:BUP]PYMCCELEV(4)
AXE6    = [F:BUP]DIE(5)
PYRSEC6 = [F:BUP]PYMCCE(5)
NIVSEC6 = [F:BUP]PYMCCELEV(5)
AXE7    = [F:BUP]DIE(6)
PYRSEC7 = [F:BUP]PYMCCE(6)
NIVSEC7 = [F:BUP]PYMCCELEV(6)
AXE8    = [F:BUP]DIE(7)
PYRSEC8 = [F:BUP]PYMCCE(7)
NIVSEC8 = [F:BUP]PYMCCELEV(7)
AXE9    = [F:BUP]DIE(8)
PYRSEC9 = [F:BUP]PYMCCE(8)
NIVSEC9 = [F:BUP]PYMCCELEV(8)
CALQTE  = ([F:BUP]QTY=2)

# Compte et sections après remplacement des variables
Raz CRITACC,CRITCCE1,CRITCCE2,CRITCCE3,CRITCCE4,CRITCCE5,CRITCCE6,CRITCCE7,CRITCCE8,CRITCCE9
CRITACC  = [M:BUC1]ACC(0)
CRITCCE1 = [M:BUC1]CCE1(0)
CRITCCE2 = [M:BUC1]CCE2(0)
CRITCCE3 = [M:BUC1]CCE3(0)
CRITCCE4 = [M:BUC1]CCE4(0)
CRITCCE5 = [M:BUC1]CCE5(0)
CRITCCE6 = [M:BUC1]CCE6(0)
CRITCCE7 = [M:BUC1]CCE7(0)
CRITCCE8 = [M:BUC1]CCE8(0)
CRITCCE9 = [M:BUC1]CCE9(0)
VERBUD   = [M:BUC1]VER(0)
For K=0 To [M:DIA]NBLIG2-1
 If CRITACC =[M:DIA]VARCOD(K) : CRITACC  = [M:DIA]VARVAL(K) : Endif
 If CRITCCE1=[M:DIA]VARCOD(K) : CRITCCE1 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE2=[M:DIA]VARCOD(K) : CRITCCE2 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE3=[M:DIA]VARCOD(K) : CRITCCE3 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE4=[M:DIA]VARCOD(K) : CRITCCE4 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE5=[M:DIA]VARCOD(K) : CRITCCE5 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE6=[M:DIA]VARCOD(K) : CRITCCE6 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE7=[M:DIA]VARCOD(K) : CRITCCE7 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE8=[M:DIA]VARCOD(K) : CRITCCE8 = [M:DIA]VARVAL(K) : Endif
 If CRITCCE9=[M:DIA]VARCOD(K) : CRITCCE9 = [M:DIA]VARVAL(K) : Endif
 If VERBUD  =[M:DIA]VARCOD(K) : VERBUD   = [M:DIA]VARVAL(K) : Endif
Next K

# OD budgétaires
ODBUD = ([M:BUC0]OD=2)*([F:BUP]BUPODS>1)
SIMUL = ([M:DIA]SIMUL=2)
TRBUD = "" : # Transaction pour OD
Local Mask BDO1 [BDO1]
MAXOD = dim([M:BDO1]ACC)
Close Local Mask [BDO1]

# Type de cours de conversion
If [F:BUP]LEV=1
 Call PARAM(SOCIETE,"BUDTYPCUR",VALPAR) From ADOVAL
Else
 Call PARAM(SITE,"BUDTYPCUR",VALPAR) From ADOVAL
Endif
TYPCUR = val(VALPAR)
If TYPCUR=0 : TYPCUR = 1 : Endif

# Devise de chaque formule
For I=1 To NBBUDFOR
 If [M:BUC1]TYP(I)=1
  Call LEC_BUP([M:BUC1]BUD(I)) From CPTLEC
  [M:BUC1]CUR(I) = [F:BUP]CUR
 Else
  Call LEC_CPY([M:BUC1]CPY(I))  From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  [M:BUC1]CUR(I) = [F:GCM]CUR([M:BUC1]LEDTYP(I)-1)
 Endif
Next I

Link [BLAQ] With [GAC]GAC0~=[F:BLAQ]COA;[F:BLAQ]ACC , [CLS]CLS0~=LEGCLS;[F:GAC]CLSCOD As [LNKQ]
Link [BLAA] With [GAC]GAC0~=[F:BLAA]COA;[F:BLAA]ACC , [CLS]CLS0~=LEGCLS;[F:GAC]CLSCOD As [LNKA]
Link [BLAC] With [GAC]GAC0~=[F:BLAC]COA;[F:BLAC]ACC , [CLS]CLS0~=LEGCLS;[F:GAC]CLSCOD As [LNKC]
Columns [LNKQ] ([BLAQ]QTY, [BLAQ]QTYCMM, [BLAQ]QTYPRP, [CLS]SNSANA)
Columns [LNKA] ([BLAA]DEBLED, [BLAA]CDTLED, [CLS]SNSANA)
Columns [LNKC] ([BLAC]CMMLED, [BLAC]CMMPRPLED, [CLS]SNSANA)

Return

###################################################################
# Boucle sur les budgets récepteurs
###################################################################
$CALBUD
Local Integer PERNUMEND(0..99)
Local Date    PERDATSTR(0..99), PERDATEND(0..99)
Local Integer ASTATUS

LIGOD = 0
NBOD  = 0
Raz PERNUMEND
Raz PERDATSTR,PERDATEND

For J=0 To ([M:BUC1]FIYEND(0)-[M:BUC1]FIYSTR(0))
 EXO = [M:BUC1]FIYSTR(I)+J
 Call NBPER(SOCIETE,TYPREF,EXO,PERNUMEND(J)) From CPTSUB
 ASTATUS = func FINPER_SYRA.GET_FIYDATES(GACTX, SOCIETE, TYPREF, EXO, PERDATSTR(J), PERDATEND(J), GMESSAGE)
Next

NBEXO = [M:BUC1]FIYEND(0)-[M:BUC1]FIYSTR(0)
Call LEC_TCU(DEVBUD) From CPTLEC

If [M:BUC0]FLGDSP = 1 : # Base de transfert en montants par périodes
 Columns [BUD] (AMT,QTY)
Endif

Gosub BOUCLE

If [M:BUC0]FLGDSP = 1 : # Base de transfert en montants par périodes
 Columns [BUD]
Endif
Return

# Boucle sur les comptes
$BOUCLE
NOMBRE = 0
If !func JOKER(CRITACC)
 If PYRCPT=""
  Call LEC_GAC(CRITACC,PLAN) From CPTLEC
  CODRTP = [F:GAC]TIMDSP
  If CALQTE & [F:GAC]FLGUOM=2
   UNITE = [F:GAC]UOM
   Call LEC_TUN(UNITE) From CPTLEC
  Else
   UNITE = ""
  Endif
 Else
  Read [GRY]GRY0(2) = PYRCPT;CRITACC
  CODRTP = [F:GRY]TIMDSP
  If CALQTE & [F:GRY]UOMDAC=2
   UNITE = [F:GRY]UOM
   Call LEC_TUN(UNITE) From CPTLEC
  Else
   UNITE = ""
  Endif
 Endif
 COMPTE = CRITACC : Gosub BOUCLE1
Else
 If PYRCPT=""
  For [GAC1]GAC0 Where COA=PLAN & BUDTRK=2 & ENAFLG=2 & pat(ACC,CRITACC)<>0
   CODRTP = [F:GAC1]TIMDSP
   If CALQTE & [F:GAC1]FLGUOM=2
    UNITE = [F:GAC1]UOM
    Call LEC_TUN(UNITE) From CPTLEC
   Else
    UNITE = ""
   Endif
   COMPTE = [F:GAC1]ACC : Gosub BOUCLE1
  Next
 Else
  For [GRY1]GRY1(3) Where PYM=PYRCPT & LEV=NIVCPT & BUDTRK=2 & pat(GRU,CRITACC)<>0
   CODRTP = [F:GRY1]TIMDSP
   If CALQTE & [F:GRY1]UOMDAC=2
    UNITE = [F:GRY1]UOM
    Call LEC_TUN(UNITE) From CPTLEC
   Else
    UNITE = ""
   Endif
   COMPTE = [F:GRY1]GRU : Gosub BOUCLE1
  Next
 Endif
Endif
Return

# Boucle sur le 1er axe
$BOUCLE1
If AXE1=""
 SEC1="":SEC2="":SEC3="":SEC4="":SEC5="":SEC6="":SEC7="":SEC8="":SEC9="" : Gosub CALCUL
Elsif !func JOKER(CRITCCE1)
 SEC1 = CRITCCE1 : Gosub BOUCLE2
Else
 If PYRSEC1=""
  For [CCE1]CCE0 Where DIE=AXE1 & BUDTRK=2 & ENAFLG=2 & pat(CCE,CRITCCE1)<>0
   SEC1 = [F:CCE1]CCE : Gosub BOUCLE2
  Next
 Else
  For [CRY1]CRY1(3) Where PYM=PYRSEC1 & LEV=NIVSEC1 & BUDTRK=2 & pat(GRU,CRITCCE1)<>0
   SEC1 = [F:CRY1]GRU : Gosub BOUCLE2
  Next
 Endif
Endif
Return

# Boucle sur le 2éme axe
