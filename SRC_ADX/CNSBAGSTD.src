#--- Changement d'ﺣ۸cran : on gﺣ۷re le nb d'intervalle possible...
Subprog AM_ECRAN(VALEUR)
Variable Char    VALEUR()
Local Integer TYP, NBCOL
If GFONCTION="CONSBAG" | GFONCTION="CONSBAGF"
 TYP=1
Else
 TYP=2
Endif
Read [GBS]GBS0=TYP;VALEUR
NBCOL=[F:GBS]NBRINT+1
Gosub RECUP_INTER
Call AFF_INTER (NBCOL)
End

