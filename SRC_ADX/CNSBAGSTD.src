#############################################################################
#--- Vﺣ۸rification de l'ordre des intervalles
Subprog C_COL1(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL2)<>0 : [M]COL1 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL2(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL3)<>0 : [M]COL2 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL3(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL4)<>0 : [M]COL3 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL4(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL5)<>0 : [M]COL4 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL5(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL6)<>0 : [M]COL5 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL6(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL7)<>0 : [M]COL6 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL7(VALEUR)
Variable Decimal VALEUR
If varmode([M:CBAG]COL8)<>0 : [M]COL7 = VALEUR : Goto ORDRE  Else End : Endif
Subprog C_COL8(VALEUR)
Variable Decimal VALEUR
[M]COL8 = VALEUR

$ORDRE
Local Integer I
For I=2 To 8
 If evalue("varmode([M:CBAG]COL"+num$(I)+")")=0
  If evalue("[M:CBAG]COL"+num$(I))>=evalue("[M:CBAG]COL"+num$(I-1))
   #La saisie des intervalles doit se faire dans l'ordre dﺣ۸croissant
   Call ERREUR(mess(39,104,1)) From GESECRAN
   mkstat=2 : Break
   zonsui = "COL"+num$(I-1)
  Endif
 Else
  Break
 Endif
Next I
End

###############################################################################
##              Etiquettes masque CONSBAG2                                  ##
###############################################################################
Subprog IB_NBLIG
Gosub SETNOL From TRTZOMBAG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
mkstat = 0
If NOL>=[M:BAG2]NBLIG | [M:BAG2]NBLIG=0 : End : Endif
If [M:BAG2]ACCNUM(NOL)<>0
 GBOUT1 = mess(53,117,1) :#"Document origine"
Endif
If [M:BAG2]TYP(NOL)="" or [M:BAG2]NUM(NOL)=""  : End : Endif
## Bouton 2 : Zoom sur la facture
Read [F:SIH]SIH2 = [M:BAG2]TYP(NOL);[M:BAG2]NUM(NOL)
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : GBOUT2 = mess(43,109,1) : # Facture tiers client
  When 5 : GBOUT2 = mess(45,109,1) : # Facture vente
 Endcase
Elsif fstat=5
 Read [F:PIH]PIH2 = [M:BAG2]TYP(NOL);[M:BAG2]NUM(NOL)
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : GBOUT2 = mess(44,109,1) : # Facture tiers fournisseur
   When 6 : GBOUT2 = mess(46,109,1) : # Facture achat
  Endcase
 Endif
Endif
## Bouton 3 : Zoom sur piﺣ۷ce
Read [F:HAE] = [M:BAG2]TYP(NOL);[M:BAG2]NUM(NOL)
If !fstat
 GBOUT3 = mess(18,109,1) : #  Piﺣ۷ce
Endif
## Bouton 4 : Zoom sur rﺣ۸glement
Read [PYH]PYH0 = [M]REG(NOL)
If !fstat
 GBOUT4 = mess(47,109,1) : # Rﺣ۷glement
Endif
End

Subprog B1_NBLIG
Gosub SETNOL From TRTZOMBAG
If find([M:BAG2]TYP(NOL),"",GDIV(0),GDIV(1)) : End : Endif
Read [F:HAE]HAE0=[M:BAG2]TYP(NOL);[M:BAG2]NUM(NOL)
If fstat | [F:HAE]BPRVCR="" : End : Endif
# "Document origine"
GERR = 2
GMESSAGE = mess(53,117,1)-":"-num$([F:HAE]BPRVCR)
End

