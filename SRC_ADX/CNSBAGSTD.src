#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GTUNCPT
Local Char PARAM(10)(1..8)
PARAM(1)="2"
PARAM(2)="DEL001"
PARAM(3)="ASN"
PARAM(5)=date$
PARAM(6)="2"     :#Balance ﺣ۱gﺣ۸e normale (pas historisﺣ۸e !)
PARAM(7)="CONSBAG4"     :#position 1er onglet
Call GCONSULT("BAG","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "TITRE"      : Gosub ONGLET
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AFF_LIB
 When "SETBOUT"    : Gosub SETBOUT
 When "CLECUR"     : If !CLECUR & [M:BAG1]BPR<>"" : CLECUR=1 : Endif

 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "AP_CHOIX2"  : Gosub AP_CHOIX2
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "FIN_CRIT"   : Gosub FIN_CRIT

 When "FERME"      : Gosub FERME
Endcase
Return

############################################
$AUTORIS
Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(14)
If GTUNCPT(14)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une mﺣ۹me fonction ne peut pas ﺣ۹tre appelﺣ۸e deux fois !
Else
 GTUNCPT(14) = 1
Endif

MEMO="bag"
If PARAM(1)="2" : MEMO="bg2" : Endif
Return

############################################
$FERME
If dim(OTUNCPT)>0 : GTUNCPT(14) = OTUNCPT : Endif
Return

############################################
$OUVRE
If clalev ([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev ([F:GSC])=0 : Local File GRPSAC     [GSC] : Endif
If clalev ([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev ([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev ([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:CNT])=0 : Local File CONTACT    [CNT] : Endif
If clalev ([F:AIN])=0 : Local File CONTACTCRM [AIN] : Endif # Issue X3-77408 - 2018-04-04 by FPE : fix clalev, it should read [F:AIN]
If clalev ([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev ([F:UNP])=0 : Local File UNPAID     [UNP] : Endif
If clalev ([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev ([F:MVS])=0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev ([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif :#facture vente
If clalev ([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif :#facture achat
If clalev ([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
If clalev ([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
If clalev ([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev ([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev ([F:GBS])=0 : Local File GBAGSCR    [GBS] : Endif
If clalev ([F:LCM])=0 : Local File LASTCUSMVT [LCM] : Endif
If clalev ([F:LSM])=0 : Local File LASTSUPMVT [LSM] : Endif
If func AFNC.ACTIV("FUP") : # Campagnes de relances
 If clalev ([F:TFP1])=0 : Local File TMPFUP1  [TFP1] : Endif
Endif

If func AFNC.ACTIV("HDU") : # Historisation des ﺣ۸chﺣ۸ances
 If clalev ([F:HDU])=0   : Local File HISTODUD  [HDU]  : Endif
 If clalev ([F:HDU2])=0  : Local File HISTODUD  [HDU2] : Endif
Endif

# Date Pivot ou Date de Rﺣ۸f
Local Char LIBDAT(50)
If GFONCTION="CONSBAG"
 [L]LIBDAT=mess(71,104,1) # Date pivot
Else
 [L]LIBDAT=mess(72,104,1) # Date de rﺣ۸f.
Endif

# Gestion des filtres
Local Char    FILTBAG(255)(0..8)
Local Integer IFILT
Local Char    FILTPAG(255)(0..8)
Local Integer PFILT
Local Char    FILTPAY(150)


# Clﺣ۸ de parcours pour la pagination
Local Date    DUDDATD , DUDDATF, ACCDATD, ACCDATF
Local Char    TYPD(GLONGTE), TYPF(GLONGTE)
Local Char    VCRD(GLONVCR), VCRF(GLONVCR)
Local Char    NUMD(15)     , NUMF(15)
Local Decimal HDUD, HDUF

Local Char BPRCUR(GLONBPR), BPRRSKCUR(GLONBPR),BPRPAYCUR(GLONBPR),CPYCUR(GLONCPY), FCYCUR(GLONFCY), ECRCUR(10)
Local Integer COL1CUR,COL2CUR,COL3CUR,COL4CUR,COL5CUR,COL6CUR,COL7CUR,COL8CUR

Local Date DATCUR

Local Char ORDRE(100)

######################
Local Integer NBSITE, NBSOC, ISITE, I, J
NBSITE = max(1,GNBSITE)
NBSOC = max(1,GNBSOC)
Local Char    TSITE(GLONFCY)(1..NBSITE), TBSOC(GLONCPY)(1..NBSOC), TDEVSOC(GLONCUR)(1..NBSOC)
NBSITE = 0
Local Integer GRP

Local Integer NBJ, NBCOL, STAT
Local Decimal MTT
Global Integer GMODIF

#Gestion des intervalles
If GFONCTION="CONSBAH"
 Gosub SET_ECRAN From CNSBAHSTD
 Gosub RECUP_INTER
 Gosub DEFCRIT From CNSBAHSTD
Else
 Gosub SET_ECRAN
 Gosub RECUP_INTER
 Gosub DEFCRIT
 Gosub INTITULE
Endif
Return

################################################################################################
# Rﺣ۸cupﺣ۸ration du nombre d'intervalles ﺣ  utiliser en fonction de l'ﺣ۸cran de consultation choisi
$SET_ECRAN
If [M:CBAG]ECRAN=""
 Read [GBS]GBS0=1;"STD" : # Ecran par dﺣ۸faut
 If fstat : Read [GBS]GBS0 First :  Endif
 If !fstat
  NBCOL=[F:GBS]NBRINT+1
  [M:CBAG]ECRAN=[F:GBS]COD
 Endif
Else
 Read [GBS]GBS0=1;[M:CBAG]ECRAN
 If !fstat
  NBCOL=[F:GBS]NBRINT+1
 Endif
Endif
Return

############################################
#Rﺣ۸cupﺣ۸ration du nom des intervalles dans les valeurs paramﺣ۷tres
$RECUP_INTER
Local Char VALPAR (10)
Local Integer DEB (1..10)
Local Char COLONNE (15)
If [M:CBAG]MEMO<>"STD"
 For I=1 To NBCOL-1
  Call PARAM("","STRINT"+num$(I),VALPAR) From ADOVAL
  J=find (val(VALPAR),DEB(1..NBCOL-1))
  If J=0
   DEB(I)=val(VALPAR)
   COLONNE="[M:CBAG]COL"+num$(I)
   Assign COLONNE With val(VALPAR)
  Endif
 Next
Endif
Return

############################################
#Affectation des zones par les paramﺣ۷tres
$DEFCRIT
Default Mask [BAG1]

If [M:BAG1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:BAG1]FCY,GUSRFCY(1..GNBAUZ))
 [M:BAG1]FCY=""
Endif
For I=1 To dim(PARAM)
 Case I
  When 1 :
   If val(PARAM(I))=2
    [M:BAG1]CLIFOUR="F"
    [M:BAG1]OBJ="BPS"
   Else
    [M:BAG1]CLIFOUR="C"
    [M:BAG1]OBJ="BPC"
   Endif
  When 2 : # Tiers risque
   If PARAM(I)<>""
    Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAG1]BPR = PARAM(I)
     Call AFFCNT ([M:BAG1]BPR,"")
    Endif
   Endif
  When 3 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BAG1]FCY = PARAM(I)
     [M:BAG1]CPY = [F:FCY]LEGCPY
     PARAM(4)= [M:BAG1]CPY    :#Evite de mettre GDEFSOC dans CPY si FCY<>""
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     If !fstat : [M:BAG1]ACCCUR = [F:CPY]ACCCUR : Endif
    Endif
   Endif
  When 4 : # Sociﺣ۸tﺣ۸
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAG1]CPY = PARAM(I)
     [M:BAG1]ACCCUR = [F:CPY]ACCCUR
     If [M:BAG1]FCY<>""
      Call LECTURE("FCY",[M:BAG1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BAG1]CPY : [M:BAG1]FCY="" : Endif
     Endif
    Else
     Call LECTURE("CPY",GDEFSOC,"") From CONTOBJ
     If !fstat
      [M:BAG1]CPY = GDEFSOC
      [M:BAG1]ACCCUR = GDEVSOC
     Endif
    Endif
   Endif
  When 5 : # Date
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BAG1]DAT = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:BAG1]DAT = PARAM(I)
    Endif
   Endif
  When 6 : # type de balance ﺣ۱gﺣ۸e
    If PARAM(I)=""
     [M:BAG1]CNSOPT="1"
    Else
     [M:BAG1]CNSOPT=PARAM(I)
    Endif
  Endcase
Next I
If [M:BAG1]FCY="" & [M:BAG1]CPY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
 [M:BAG1]FCY = GFCYDEF
 Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
 [M:BAG1]CPY = [F:FCY]LEGCPY
Endif
If [M:BAG1]DAT=[0/0/0] : [M:BAG1]DAT=date$ : Endif

Default Mask [BAG1]
Gosub CRITENT From =PROGCNS
Return

############################################
# Certaines zones ne doivent apparaﺣ؟tre qu'en balance ﺣ۱gﺣ۸e client et d'autres
# qu'en balance ﺣ۱gﺣ۸e fournisseur. Pour ﺣ۸viter de faire 2 ﺣ۸crans diffﺣ۸rents, on
# ne met pas de libellﺣ۸ devant les zones inutiles(utilisation de libellﺣ۸s ﺣ۸valuﺣ۸s).
$INTITULE
Raz [M:BAG3]INTIT
Raz [M:BAG4]INTIT2
If [M:BAG1]CLIFOUR="F"
 [M:BAG3]INTIT(4)=mess(145,121,1) #"Echﺣ۸ances non BAP +"
 [M:BAG3]INTIT(5)=mess(144,121,1) #"Echﺣ۸ances BAP +"
Else
 [M:BAG3]INTIT(0)=mess(41,104,1)  #"En prﺣ۹t commande +"
 [M:BAG3]INTIT(1)=mess(42,104,1)  #"En-cours livraison +"
 [M:BAG3]INTIT(2)=mess(43,104,1)  #"Livrﺣ۸ en prﺣ۹t +"
 [M:BAG3]INTIT(3)=mess(6,121,1)   #"Impayﺣ۸"      # Dﺣ۸placement de cette zone en BAG4
 [M:BAG3]INTIT(5)=mess(146,121,1) #"Factures + "

 [M:BAG4]INTIT2(0)=mess(64,126,1) #"Statistiques"
 [M:BAG4]INTIT2(1)=mess(20,125,1) #"Actions"
 [M:BAG4]INTIT2(2)=mess(54,104,1) #"Client commande"
 [M:BAG4]INTIT2(3)=mess(57,104,1) #"Nb impayﺣ۸s"
 [M:BAG4]INTIT2(4)=mess(58,104,1) #"Plus haut niv. de relance"
 [M:BAG4]INTIT2(5)=mess(46,183,1) #"Date du premier contact"
 [M:BAG4]INTIT2(6)=mess(59,100,1) #"Type"
 [M:BAG4]INTIT2(7)=mess(49,183,1) #"Date du dernier contact"
 [M:BAG4]INTIT2(8)=mess(50,183,1) #"Date du prochain contact"
 [M:BAG4]INTIT2(9)=mess(55,104,1) #"Historique mouvement cde"
 [M:BAG4]INTIT2(10)=mess(56,104,1)#"Historique prﺣ۹t cde"
Endif
Return

#Positionnement sur un onglet en particulier en entrant dans la fonction
############################################
$ONGLET
If clalev ([F:AWI])=0 : Local File AWINDOW  [AWI] : Endif

If dim([M:FUP]BPC)>0 & dim([M:CFP1]BPRFUP)>0
 If [M:CFP1]BPRFUP=2 # Tiers facturﺣ۸
  [M:BAG1]BPR = [M:FUP]BPC(nolign-1)
  [M:BAG1]BPRPAY = ""
  [M:BAG1]BPRRSK = ""
 Else # Tiers payeur
  [M:BAG1]BPR = ""
  [M:BAG1]BPRPAY = [M:FUP]BPC(nolign-1)
  [M:BAG1]BPRRSK = ""
 Endif
Endif

#Initialisation du champ Tiers risque quelque soit l'onglet choisit
If [M:BAG1]CLIFOUR="C" & dim([M:BPC3]BPCRSK)>0
 [M:BAG1]BPRRSK=[M:BPC3]BPCRSK
Endif
If  [M:BAG1]CLIFOUR="F" &  dim([M:BPS2]BPSRSK)>0
 [M:BAG1]BPRRSK=[M:BPS2]BPSRSK
Endif

If PARAM(7)<>""
 Read [F:AWI]AWI0="FCNSBAG"
 If !fstat
  POS = find (PARAM(7), [F:AWI]NOMMSK(0..14))
  If POS
   AFOLDEF=POS
  Endif
 Endif
Endif
Return

############################################
#Gestion des boutons magnﺣ۸to.
$AV_MAGNETO
If [M]CLIFOUR="C"
 NOMFIC = "BPCUSTOMER"
 ABFIC = "BPC"
 CLE = "BPC0"
 NBCMP = 1
 CLECMP(0) = "BPCNUM"
 If [M]BPR<>""
  CLEMSK(0) = "BPR"
 Endif
 FILTRE=""
 Default File [BPC]
Else
 NOMFIC = "BPSUPPLIER"
 ABFIC = "BPS"
 CLE = "BPS0"
 NBCMP = 1
 CLECMP(0) = "BPSNUM"
 If [M]BPR<>""
  CLEMSK(0) = "BPR"
 Endif
 FILTRE=""
 Default File [BPS]
Endif
Return

$AP_MAGNETO
 Call AM_BPR([M]BPR)
Return

############################################
#Chargement du tableau
$LECTURE
Gosub AFF_LIB    : # Obliger de le faire ici car dans $OUVRE c'est trop tﺣﺑt...
Gosub DEVISE     : # Obliger de le faire ici car dans $OUVRE c'est trop tﺣﺑt...

If [M:BAG1]BPR="" & [M:BAG1]BPRPAY="" & [M:BAG1]BPRRSK="" : NBLU=0 : Return : Endif

Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

Gosub INIT
Gosub DEVISE

# Filtres
Gosub FILTRE
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# Parcours de page en page
If CHGPAG>0 # Page suivante
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else         # Page prﺣ۸cﺣ۸dente
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:BAG2]5 : Endif

# chargement d'une tableau des ﺣ۸chﺣ۸ances
Gosub LECT_DUD

# Re-calcul des totaux et du risque si besoin...
If BPRCUR<>[M:BAG1]BPR | BPRRSKCUR<>[M:BAG1]BPRRSK | BPRPAYCUR<>[M:BAG1]BPRPAY |
&  CPYCUR<>[M:BAG1]CPY | FCYCUR<>[M:BAG1]FCY |  DATCUR<>[M:BAG1]DAT | ECRCUR<>[M:CBAG]ECRAN |
&  COL1CUR<>[M:CBAG]COL1 | COL2CUR<>[M:CBAG]COL2 | COL3CUR<>[M:CBAG]COL3 | COL4CUR<>[M:CBAG]COL4 |
&  COL5CUR<>[M:CBAG]COL5 | COL6CUR<>[M:CBAG]COL6 | COL7CUR<>[M:CBAG]COL7 | COL8CUR<>[M:CBAG]COL8
 If dim([M:BAG2]AMTTOTLOC)>0 | GMODIF=1
  Gosub TOTAL : GMODIF=0
 Endif
 If [M:BAG1]BPRRSK<>""
  Call RISQUE(FILTBAG,TSITE,NBSITE,TBSOC,NBSOC,GRP,TDEVSOC) From TRTCNSBAG
 Else
  Raz [M:BAG3]
  If NBLU<2
   Affzo [M:BAG3]
  Endif
 Endif
 If [M:BAG1]BPR<>"" & [M:BAG1]CPY<>""
  Call DERNIER From TRTCNSBAG
 Else
  Raz [M:BAG4]
  If NBLU<2
   Affzo [M:BAG4]
  Endif
 Endif

 GPOINT = "UPDENQBAG" : Gosub ENTREE From EXEFNC
Endif

BPRCUR    = [M:BAG1]BPR
BPRRSKCUR = [M:BAG1]BPRRSK
BPRPAYCUR = [M:BAG1]BPRPAY
FCYCUR    = [M:BAG1]FCY
CPYCUR    = [M:BAG1]CPY
DATCUR    = [M:BAG1]DAT
ECRCUR    = [M:CBAG]ECRAN
COL1CUR   = [M:CBAG]COL1
COL2CUR   = [M:CBAG]COL2
COL3CUR   = [M:CBAG]COL3
COL4CUR   = [M:CBAG]COL4
COL5CUR   = [M:CBAG]COL5
COL6CUR   = [M:CBAG]COL6
COL7CUR   = [M:CBAG]COL7
COL8CUR   = [M:CBAG]COL8
Return

############################################
$LECT_DUD
# Ordre (choix dans la fenﺣ۹tre de critﺣ۷re)
If [M:CBAG]ORDDUD=2 #Desc
 If CHGPAG>0    :# Page suivante
  If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
   ORDRE = "[F:HAE]ACCDAT Desc;[F:HAE]TYP Desc;[F:HAE]NUM Desc;[F:DUD]NUMDUD Desc"
  Else
   ORDRE = "[F:DUD]DUDDAT Desc;[F:HAE]TYP Desc;[F:HAE]NUM Desc;[F:DUD]NUMDUD Desc"
  Endif
 Else           :# Page prﺣ۸cﺣ۸dente
  If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
   ORDRE = "[F:HAE]ACCDAT;[F:HAE]TYP;[F:HAE]NUM;[F:DUD]NUMDUD"
  Else
   ORDRE = "[F:DUD]DUDDAT;[F:HAE]TYP;[F:HAE]NUM;[F:DUD]NUMDUD"
  Endif
 Endif
Else
 If CHGPAG>0   :# Page suivante
  If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
   ORDRE = "[F:HAE]ACCDAT;[F:HAE]TYP;[F:HAE]NUM;[F:DUD]NUMDUD"
  Else
   ORDRE = "[F:DUD]DUDDAT;[F:HAE]TYP;[F:HAE]NUM;[F:DUD]NUMDUD"
  Endif
 Else          :# Page prﺣ۸cﺣ۸dente
  If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
   ORDRE = "[F:HAE]ACCDAT Desc;[F:HAE]TYP Desc;[F:HAE]NUM Desc;[F:DUD]NUMDUD Desc"
  Else
   ORDRE = "[F:DUD]DUDDAT Desc;[F:HAE]TYP Desc;[F:HAE]NUM Desc;[F:DUD]NUMDUD Desc"
  Endif
 Endif
Endif

#Link...
Case [M:BAG1]CLIFOUR
 When "F" :
   Link [DUD] With [HAE]HAE0=[DUD]TYP;[DUD]NUM , [F:BPS]BPS0=[F:DUD]BPR As [LNK]
&  Order With [L]ORDRE
   Columns [DUD] ([F:DUD],[F:HAE]ACCDAT,[F:HAE]TYP,[F:HAE]NUM,[F:HAE]BPRVCR,[F:HAE]BPRDATVCR)
 When "C" :
   Link [DUD] With [HAE]HAE0=[DUD]TYP;[DUD]NUM , [F:BPC]BPC0=[F:DUD]BPR As [LNK]
&  Order With [L]ORDRE
   Columns [DUD] ([F:DUD],[F:HAE]ACCDAT,[F:HAE]TYP,[F:HAE]NUM,[F:HAE]BPRVCR,[F:HAE]BPRDATVCR)
Endcase

Filter [F:LNK] Where evalue(FILTBAG) & evalue(FILTPAY) & evalue(FILTPAG)

For [LNK]
 If GRP=1
  ISITE  = find([F:DUD]FCY,TSITE(1..NBSITE))
 Endif
 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Effzo [M:BAG2]5 : Endif
  NBLU=2
 Endif
 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
  NOL += 1
  If NOL = 0
   ACCDATD = [F:HAE]ACCDAT
   DUDDATD = [F:DUD]DUDDAT
   NUMD    = [F:DUD]NUMDUD
   TYPD    = [F:HAE]TYP
   VCRD    = [F:HAE]NUM
  Endif
  ACCDATF = [F:HAE]ACCDAT
  DUDDATF = [F:DUD]DUDDAT
  NUMF    = [F:DUD]NUMDUD
  TYPF    = [F:HAE]TYP
  VCRF    = [F:HAE]NUM
 Else
  If NOL<=0 : RETOUR=2 : Break : Endif
  NOL-=1
  If NOL = MAXLIG-1 :
   ACCDATF = [F:HAE]ACCDAT
   DUDDATF = [F:DUD]DUDDAT
   NUMF    = [F:DUD]NUMDUD
   TYPF    = [F:HAE]TYP
   VCRF    = [F:HAE]NUM
  Endif
  ACCDATD = [F:HAE]ACCDAT
  DUDDATD = [F:DUD]DUDDAT
  NUMD    = [F:DUD]NUMDUD
  TYPD    = [F:HAE]TYP
  VCRD    = [F:HAE]NUM
 Endif
 nolign=NOL+1
 [M:BAG2]=[F:HAE]
 [M:BAG2]=[F:DUD]
 Case [M:BAG1]CLIFOUR
  When "F" :
  [M:BAG2]BPRRSK(NOL)=[F:BPS]BPSRSK
  [M:BAG2]BPRGRU(NOL)=[F:BPS]BPSGRU
  When "C"
  [M:BAG2]BPRRSK(NOL)=[F:BPC]BPCRSK
  [M:BAG2]BPRGRU(NOL)=[F:BPC]BPCGRU
 Endcase
 If dim([M:BAG2]REG)>0
  Gosub LECT_REGL
 Endif
 Gosub MTT_CUR
 Gosub MTT_LOC
Next

Filter [F:LNK]
Return

############################################
#Gestion des libellﺣ۸s de colonne suivant les intervalles choisies et de ceux des totaux.
$AFF_LIB
Local Char ZLIB (20)
Gosub SET_ECRAN    #libellﺣ۸s des colonnes
Raz [M:BAG2]LIB
For I=1 To NBCOL
 If I=1
  [M:BAG2]LIB(I-1)= ">=" - num$(evalue("[M:CBAG]COL"+num$(I)))-mess(38,104,1)
 Elsif I<NBCOL
  [M:BAG2]LIB(I-1)= num$(evalue("[M:CBAG]COL"+num$(I))) -tolower(mess(41,101,1))- num$(evalue("[M:CBAG]COL"+num$(I-1))-1)-mess(38,104,1) #MH 06/25/15 Changed -"/"- to -tolower(mess(41,101,1))-
 Else
  [M:BAG2]LIB(I-1)= "<" - num$(evalue("[M:CBAG]COL"+num$(I-1)))-mess(38,104,1)
 Endif
 #libellﺣ۸s des totaux
 If dim([M:BAG2]AMTTOTLOC)>0 & I<8
  ZLIB="[M:BAG2]LIBTOT"+num$(I)
  #Cadrage ﺣ  droite mais bon c'est pas gﺣ۸nial !!!
  If len([M:BAG2]LIB(I-1))<15
   [M:BAG2]LIB(I-1)=space$(15-len([M:BAG2]LIB(I-1)))+[M:BAG2]LIB(I-1)
  Endif
  Assign ZLIB With [M:BAG2]LIB(I-1)
  Assign "[M:BAG2]LIBTOT("+num$(I-1)+")" With [M:BAG2]LIB(I-1)
 Endif
Next
If dim([M:BAG2]AMTTOTLOC)>0 & NBCOL>7
 [M:BAG2]LIBTOT7 = "<"-num$([M:CBAG]COL6)-mess(38,104,1)
 [M:BAG2]LIBTOT(6) = "<"-num$([M:CBAG]COL6)-mess(38,104,1)
Endif
If dim([M:BAG2]AMTTOTLOC)>0
 [M:BAG2]LIBTOTLOC = mess(155,121,1)
Endif

Affzo [M:BAG2]
Diszo [M:BAG3]    :#Pour les tunnels
Affzo [M:BAG3]
Affzo [M:BAG4]
Return

############################################
#Ligne en devise courante
$MTT_CUR
Local Integer NBJ
Local Char ZONE (200)
NBJ = [M:BAG1]DAT - [M:BAG2]DUDDAT(nolign-1)
For I=1 To NBCOL
 If I=1
  If NBJ>=[M:CBAG]COL1
   If [M:CBAG]FLGDUD2 = 2
     [M:BAG2]AMTCUR1(nolign-1) = ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1)-[M:BAG2]TMPCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
   Else
     [M:BAG2]AMTCUR1(nolign-1) = ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
   Endif
   Break : Return
  Endif
 Elsif I<NBCOL
  If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
   ZONE="[M:BAG2]AMTCUR"+num$(I)+"(nolign-1)"
   If [M:CBAG]FLGDUD2 = 2
       Assign ZONE With ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1)-[M:BAG2]TMPCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
   Else
       Assign ZONE With ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
   Endif
   Break : Return
  Endif
 Else
  ZONE="[M:BAG2]AMTCUR"+num$(NBCOL)+"(nolign-1)"
  If [M:CBAG]FLGDUD2 = 2
      Assign ZONE With ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1)-[M:BAG2]TMPCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
  Else
      Assign ZONE With ([M:BAG2]AMTCUR(nolign-1)-[M:BAG2]PAYCUR(nolign-1))*[M:BAG2]SNS(nolign-1)
  Endif
  Break : Return
 Endif
Next
If [M:CBAG]FLGDUD2 = 2
 [M:BAG2]AMTCUR(nolign-1) = ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
Else
 [M:BAG2]AMTCUR(nolign-1) = ([F:DUD]AMTCUR-[F:DUD]PAYCUR)*[F:DUD]SNS
Endif
Return

############################################
#Ligne en devise locale
$MTT_LOC
Local Integer NBJ
Local Char ZONE (200)
NBJ = [M:BAG1]DAT - [M:BAG2]DUDDAT(nolign-1)
For I=1 To NBCOL
 If I=1
  If NBJ>=[M:CBAG]COL1
   If [M:CBAG]FLGDUD2 = 2
       [M:BAG2]AMTLOC1(nolign-1) = ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1)-[M:BAG2]TMPLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Else
       [M:BAG2]AMTLOC1(nolign-1) = ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Endif
   Break : Return
  Endif
 Elsif I<NBCOL
  If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
   ZONE="[M:BAG2]AMTLOC"+num$(I)+"(nolign-1)"
   If [M:CBAG]FLGDUD2 = 2
       Assign ZONE With ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1)-[M:BAG2]TMPLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Else
       Assign ZONE With ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Endif
   Break : Return
  Endif
 Else
   ZONE="[M:BAG2]AMTLOC"+num$(NBCOL)+"(nolign-1)"
   If [M:CBAG]FLGDUD2 = 2
       Assign ZONE With ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1)-[M:BAG2]TMPLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Else
       Assign ZONE With ([M:BAG2]AMTLOC(nolign-1)-[M:BAG2]PAYLOC(nolign-1))*[M:BAG2]SNS(nolign-1)
   Endif
   Break : Return
 Endif
Next
If [M:CBAG]FLGDUD2 = 2
 [M:BAG2]AMTLOC(nolign-1) = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
Else
 [M:BAG2]AMTLOC(nolign-1) = ([F:DUD]AMTLOC-[F:DUD]PAYLOC)*[F:DUD]SNS
Endif
Return

############################################
#Affectation des totaux en bas d'ﺣ۸cran via le champ [M:BAG1]ACCCUR, initialisﺣ۸ sous $INIT
$TOTAL
#Remise ﺣ  zﺣ۸ro des totaux
Raz [M:BAG2]NBTOT
For I=1 To 7
 ZONE="[M:BAG2]AMTTOT"+num$(I)
 Assign ZONE With 0
 ZONE="[M:BAG2]AMTTOT("+num$(I-1)+")"
 Assign ZONE With 0
 ZONE="[M:BAG2]PER"+num$(I)
 Assign ZONE With 0
Next
[M:BAG2]AMTTOTLOC=0

If [M:BAG1]BPR="" & [M:BAG1]BPRPAY="" & [M:BAG1]BPRRSK="" : Return : Endif
Filter [F:LNK] Where evalue (FILTBAG) & evalue(FILTPAY)
For [LNK]

 If [M:CBAG]FLGDUD2 = 2
   MTT=([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
 Else
   MTT=([F:DUD]AMTLOC-[F:DUD]PAYLOC)*[F:DUD]SNS
 Endif

 # Dans le cas de toutes sociﺣ۸tﺣ۸ ou Groupes sociﺣ۸tﺣ۸/sites avec devise <>
 If [F:HAE]CPY<>[F:CPY]CPY
  Read [F:CPY]CPY0 = [F:HAE]CPY
 Endif
 If [F:CPY]ACCCUR<>[M:BAG1]ACCCUR
   Call CONVERT([F:CPY]ACCCUR,[M:BAG1]ACCCUR,[M:BAG1]ACCCUR,[F:HAE]TYPRAT,[F:HAE]ACCDAT,MTT,MTT,STAT) From TRTDEV
 Endif

 NBJ = [M:BAG1]DAT - [F:DUD]DUDDAT
 For I=1 To NBCOL
  If I=1
   If NBJ>=[M:CBAG]COL1
    [M:BAG2]AMTTOT1 += MTT
    [M:BAG2]AMTTOT(0) += MTT
    Break
   Endif
  Elsif I<NBCOL & I<7
   If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
    ZONE="[M:BAG2]AMTTOT"+num$(I)
    Assign ZONE With (evalue(ZONE)+MTT)
    ZONE="[M:BAG2]AMTTOT("+num$(I-1)+")"
    Assign ZONE With (evalue(ZONE)+MTT)
    Break
   Endif
  Elsif I=NBCOL & I<=7
   ZONE="[M:BAG2]AMTTOT"+num$(NBCOL)
   Assign ZONE With (evalue(ZONE)+MTT)
   ZONE="[M:BAG2]AMTTOT("+num$(NBCOL-1)+")"
   Assign ZONE With (evalue(ZONE)+MTT)
   Break
  Else
   [M:BAG2]AMTTOT7 += MTT
   [M:BAG2]AMTTOT(6) += MTT
   Break
  Endif
 Next
 [M:BAG2]AMTTOTLOC+=MTT
Next
[M:BAG2]NBTOT = [F:GBS]NBRINT+1
Filter [F:LNK]

If [M:BAG2]AMTTOTLOC<>0
 [M:BAG2]PER1 = arr([M:BAG2]AMTTOT1 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER2 = arr([M:BAG2]AMTTOT2 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER3 = arr([M:BAG2]AMTTOT3 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER4 = arr([M:BAG2]AMTTOT4 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER5 = arr([M:BAG2]AMTTOT5 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER6 = arr([M:BAG2]AMTTOT6 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
 [M:BAG2]PER7 = arr([M:BAG2]AMTTOT7 / [M:BAG2]AMTTOTLOC  * 100 ,0.1)
Else
 Raz [M:BAG2]PER1
 Raz [M:BAG2]PER2
 Raz [M:BAG2]PER3
 Raz [M:BAG2]PER4
 Raz [M:BAG2]PER5
 Raz [M:BAG2]PER6
 Raz [M:BAG2]PER7
Endif
Return

############################################
#Crﺣ۸ation de critﺣ۷re de selection
$FILTRE
Raz FILTBAG, IFILT

# Le tiers est dans un critﺣ۷re indﺣ۸pendant car le filtre est utilisﺣ۸ pour l'onglet 2
#  qui concerne les zones recherchﺣ۸es sous le fichier GACCDUDATE
#  (par ailleurs, l'onglet 2 doit se focaliser uniquement sur le notion de TIERS RISQUE)

# Tiers
FILTPAY = "1=1"
If [M:BAG1]BPR<>""
 FILTPAY += "& [F:DUD]BPR='"+[M:BAG1]BPR+"'"
Endif

If [M:BAG1]BPRPAY<>""
 FILTPAY += "& [F:DUD]BPRPAY='"+[M:BAG1]BPRPAY+"'"
Endif


If [M:BAG1]BPRRSK<>"" & [M:BAG1]BPR="" & [M:BAG1]BPRPAY=""
 If [M:BAG1]CLIFOUR="F"
  Call ADDCRIT(FILTBAG,IFILT,"BPSRSK",'[F:BPS]BPSRSK="'+[M:BAG1]BPRRSK+'"'," & ") From GOBJSUB
 Else
  Call ADDCRIT(FILTBAG,IFILT,"BPCRSK",'[F:BPC]BPCRSK="'+[M:BAG1]BPRRSK+'"'," & ") From GOBJSUB
 Endif
Endif


# Sociﺣ۸tﺣ۸ & Site
Case GRP
 When 0 :
  # Sociﺣ۸tﺣ۸ juridique
  Call ADDCRIT(FILTBAG,IFILT,"CPY",'[F:DUD]CPY="'+[M:BAG1]CPY+'"'," & ") From GOBJSUB
  If [M:BAG1]FCY<>""
   Call ADDCRIT(FILTBAG,IFILT,"FCY",'[F:DUD]FCY="'+[M:BAG1]FCY+'"'," & ") From GOBJSUB
  Endif
 When 1
  # Groupement de sites
  Call ADDCRIT(FILTBAG,IFILT,"FCY",'find([F:DUD]FCY,TSITE(1..NBSITE))'," & ") From GOBJSUB
Endcase

# Autorisation site
If GUSRFCY(1)<>"\" & ([M:BAG1]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
 Call ADDCRIT(FILTBAG,IFILT,"FCY",'find([F:DUD]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
Endif

# Type d'ﺣ۸chﺣ۸ances (Fournisseur/Client)
If [M:BAG1]CLIFOUR="F"
 Call ADDCRIT(FILTBAG,IFILT,"BPRTYP",'[F:DUD]BPRTYP=2'," & ") From GOBJSUB
Else
 Call ADDCRIT(FILTBAG,IFILT,"BPRTYP",'[F:DUD]BPRTYP=1'," & ") From GOBJSUB
Endif

# Statut de l'ﺣ۸chﺣ۸ance (Toujours validﺣ۸es)
Call ADDCRIT(FILTBAG,IFILT,"DUDSTA",'[F:DUD]DUDSTA=2'," & ") From GOBJSUB

# Retrait des ﺣ۸chﺣ۸ance sur piﺣ۷ce d'ﺣ -nouveau
Call ADDCRIT(FILTBAG,IFILT,"FLGREP",'[F:HAE]FLGREP<>2'," & ") From GOBJSUB


# Autres conditions ﺣ  partir de la fenetre critiﺣ۷res
#--- Inclure les ﺣ۸critures de simulation
If [M:CBAG]FLGDUD1 = 2
 Call ADDCRIT(FILTBAG,IFILT,"CAT",'find([F:HAE]CAT,1,2,4)<>0'," & ") From GOBJSUB
Else
 Call ADDCRIT(FILTBAG,IFILT,"CAT",'find([F:HAE]CAT,1,4)<>0'," & ") From GOBJSUB
Endif
#--- Inclure les rﺣ۷glements provisoires
If [M:CBAG]FLGDUD2=2
 Call ADDCRIT(FILTBAG,IFILT,"FLGCLE",'[F:DUD]FLGCLE=1'," & ") From GOBJSUB
Else
 Call ADDCRIT(FILTBAG,IFILT,"FLGCLE",'([F:DUD]FLGCLE=1 or [F:DUD]FLGCLE=4)'," & ") From GOBJSUB
Endif

#--- Odre  (1/Ascendant & 2/Dﺣ۸scendant)
Raz FILTPAG, PFILT
If BPRCUR=[M:BAG1]BPR
 If [M:CBAG]ORDDUD=2
  Gosub FILTRE_DESC
 Else
  Gosub FILTRE_ASC
 Endif
Endif
If FILTPAG="" : FILTPAG="1=1" : Endif
Return

############################################
#Crﺣ۸ation de critﺣ۷re de selection pour la pagination
$FILTRE_ASC
Case CHGPAG
 When 3 : # Rafraichissement
   If [M]NBLIG=0 : Return : Endif
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & [F:DUD]NUMDUD>"'+NUMF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATF)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & [F:DUD]NUMDUD>"'+NUMF+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [F:DUD]DUDDAT>['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When 2 : # Suite
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMDUD>"'+NUMF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATF)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMDUD>"'+NUMF+'")'+
&        'or ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [DUD]DUDDAT>['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When -2 : # Retour
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & [F:DUD]NUMDUD<"'+NUMD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM<"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP<"'+TYPD+'")'+
&        'or  [F:HAE]ACCDAT<['+format$(GFMD,ACCDATD)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & [F:DUD]NUMDUD<"'+NUMD+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM<"'+VCRD+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP<"'+TYPD+'")'+
&        'or  [F:DUD]DUDDAT<['+format$(GFMD,DUDDATD)+'])'," & ") From GOBJSUB
   Endif
 Endcase
Return

############################################
#Crﺣ۸ation de critﺣ۷re de selection pour la pagination
$FILTRE_DESC
Case CHGPAG
 When 3 : # Rafraichissement
   If [M]NBLIG=0 : Return : Endif
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & [F:DUD]NUMDUD<"'+NUMF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM<"'+VCRF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP<"'+TYPF+'")'+
&        'or  [F:HAE]ACCDAT<['+format$(GFMD,ACCDATF)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & [F:DUD]NUMDUD<"'+NUMF+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM<"'+VCRF+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP<"'+TYPF+'")'+
&        'or  [F:DUD]DUDDAT<['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When 2 : # Suite
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMDUD<"'+NUMF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM<"'+VCRF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP<"'+TYPF+'")'+
&        'or  [F:HAE]ACCDAT<['+format$(GFMD,ACCDATF)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMDUD<"'+NUMF+'")'+
&        'or ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM<"'+VCRF+'")'+
&        'or ([DUD]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP<"'+TYPF+'")'+
&        'or  [DUD]DUDDAT<['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When -2 : # Retour
   If [M:CBAG]TRIDUD=2 :#tri par piﺣ۷ce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & [F:DUD]NUMDUD>"'+NUMD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATD)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMDUD",
&        '(  ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & [F:DUD]NUMDUD>"'+NUMD+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:DUD]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:DUD]DUDDAT>['+format$(GFMD,DUDDATD)+'])'," & ") From GOBJSUB
   Endif
 Endcase
Return

############################################
#Affectation de la devise dans tous les onglets...
$DEVISE
If dim([M:BAG2]ACCCUR2)>0
 [M:BAG2]ACCCUR2=[M:BAG1]ACCCUR
 Affzo [M:BAG2]ACCCUR2
Endif
If dim([M:BAG3]ACCCUR3)>0
 [M:BAG3]ACCCUR3=[M:BAG1]ACCCUR
 Affzo [M:BAG3]ACCCUR3
Endif
If dim([M:BAG4]ACCCUR4)>0
 [M:BAG4]ACCCUR4=[M:BAG1]ACCCUR
 Affzo [M:BAG4]ACCCUR4
Endif
Return

############################################
# Dﺣ۸termination Si Groupes de sites (GRP=1) / Sociﺣ۸tﺣ۸ (GRP=0) / Toutes sociﺣ۸tﺣ۸s confondues (GRP=-1)
$INIT
GRP=-1
Raz TSITE
If [M:BAG1]CPY<>""
 Call LECTURE("CPY",[M:BAG1]CPY,"") From CONTOBJ
 GRP=([F:CPY]CPYLEGFLG<>2)
 If !GRP
  #-- Sociﺣ۸tﺣ۸ juridique
  [M:BAG1]ACCCUR = [F:CPY]ACCCUR
 Else
  #-- Sociﺣ۸tﺣ۸ non juridique
  NBSITE = 0 : NBSOC=0
  For [FGR]FGR0 Where CPY = [M:BAG1]CPY
   NBSITE+=1
   TSITE(NBSITE) = [F:FGR]FCY
   Call LECTURE("FCY",TSITE(NBSITE),"") From CONTOBJ
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   If find([F:CPY]CPY,TBSOC(1..NBSOC))=0
    NBSOC+=1
    TBSOC(NBSOC)   = [F:CPY]CPY
    TDEVSOC(NBSOC) = [F:CPY]ACCCUR
   Endif
  Next : # [FGR]

  [M:BAG1]ACCCUR = TDEVSOC(1)
  If [M:BAG1]ACCCUR=""
   [M:BAG1]ACCCUR = GCURSHR
  Else
   For I=2 To NBSOC
    If TDEVSOC(1)<>TDEVSOC(I) : [M:BAG1]ACCCUR = GCURSHR : Break : Endif
   Next I
  Endif
 Endif
Else
 [M:BAG1]ACCCUR = GCURSHR
Endif
Return

############################################
# Lecture des reglements
$LECT_REGL
Filter [PYD] Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
&            Order By Key CLE=DUDNUM;DUDLIG
Read [F:PYD]CLE First
If fstat = 0
 [M:BAG2]REG (nolign-1) = [F:PYD]NUM
Endif
Filter [PYD]
Return

############################################
#Tunnel sur les rﺣ۸glements
$SETBOUT
CHMEN += "1"
Return

############################################
$DEB_CRIT
Local Integer NBCOL
If GFONCTION="CONSBAH"
 Gosub SET_ECRAN From CNSBAHSTD
Else
 Gosub SET_ECRAN
Endif
Call AFF_INTER (NBCOL)
Affzo [M:CBAG]
Return

###########################################
$FIN_CRIT
If CHANGE : GMODIF=1 : Endif
Return

###########################################
Subprog AFF_INTER (PNBCOL)
Value Integer PNBCOL
Actzo [M:CBAG]20
For I=PNBCOL To 8
Case I
 When 1 : Effzo [M:CBAG]COL1 : Grizo [M:CBAG]COL1
 When 2 : Effzo [M:CBAG]COL2 : Grizo [M:CBAG]COL2
 When 3 : Effzo [M:CBAG]COL3 : Grizo [M:CBAG]COL3
 When 4 : Effzo [M:CBAG]COL4 : Grizo [M:CBAG]COL4
 When 5 : Effzo [M:CBAG]COL5 : Grizo [M:CBAG]COL5
 When 6 : Effzo [M:CBAG]COL6 : Grizo [M:CBAG]COL6
 When 7 : Effzo [M:CBAG]COL7 : Grizo [M:CBAG]COL7
 When 8 : Effzo [M:CBAG]COL8 : Grizo [M:CBAG]COL8
Endcase
Next
Affzo [M:CBAG]20
End

###########################################
#Affectation du contact...
Subprog AFFCNT (PAYBPR, FNCCNTBPR)
Value Char PAYBPR()
Value Char FNCCNTBPR ()
Local Integer TROUVE

Effzo [M]CNT, TEL, FNCCNT
Read [F:BPR]BPR0=PAYBPR
If !fstat
 If FNCCNTBPR<>""
  #Affectation du contact dont la fonction a ﺣ۸tﺣ۸ choisie
   [M]CNT=mess([F:AIN]CNTTTL,2607,1)-[F:AIN]CNTLNA
   [M]FNCCNT=[F:CNT]CNTFNC
   Read [F:BPA]BPA0=1;PAYBPR;[F:CNT]BPAADD
   If !fstat
    [M]CRY=[F:BPA]CRY
   Endif
   [M]TEL=[F:CNT]TEL
 Else
  #Affectation du contact principal
  Read [F:CNT]CNT0=1;PAYBPR;[F:BPR]CNTNAM
  If !fstat
   If [F:CNT]CCNCRM<>""
    Read[F:AIN]AIN0=[F:CNT]CCNCRM
    If !fstat
     [M]CNT=mess([F:AIN]CNTTTL,2607,1)-[F:AIN]CNTLNA
    Endif
   Endif
   [M]FNCCNT=[F:CNT]CNTFNC
   Read [F:BPA]BPA0=1;PAYBPR;[F:CNT]BPAADD
   If !fstat
    [M]CRY=[F:BPA]CRY
   Endif
   [M]TEL=[F:CNT]TEL
  Endif
 Endif
Endif
Affzo [M]CNT, TEL, FNCCNT
End

$AP_CHOIX2
Local Char    SAVACT(GLONACT), XMEM(3)
Local Integer FLGEXE

If GFONCTION="CONSBAG"
 XMEM="bag"
 If [M:BAG1]CLIFOUR="F" : XMEM = "bg2" : Endif
Else
 XMEM="bah"
 If [M:BAH1]CLIFOUR="F" : XMEM = "bh2" : Endif
Endif
I=find(REPONSE,LBOUT)
If I<1 : Return : Endif
SAVACT = GACTION
Case CBOUT(I-1)
 When "M"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBAG]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "1"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
 When "R"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBAG]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "2"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
 When "E"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "[M:CBAG]"
  PARBOUT(2) = XMEM
  PARBOUT(3) = "3"
  FLGEXE = 1
  GACTION = "MEMO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","XWGMEMO") From GSAISIE
  REPONSE=0
Endcase
GACTION = SAVACT
Return

###############################################################################
##              Etiquettes communes masque CONSBAG1 & CRITBAG                ##
###############################################################################
#Controle des droits sur le tiers
Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [BPR]BPR0 = VALEUR
 If [F:BPR]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:BPR]ACS,DROIT) From CPTSUB
  If !DROIT
   GMESSAGE = mess(4,104,1) : mkstat = 2 : End
  Endif
 Endif
 If dim([M:BPP0]BPCNUM)>0 : End : Endif
 If [M]CLIFOUR="C" & [BPR]BPCFLG<>2
  GMESSAGE = VALEUR-mess(106,116,1) : mkstat = 2 : End
 Elsif [M]CLIFOUR="F" & [BPR]BPSFLG<>2
  GMESSAGE = VALEUR-mess(107,116,1) : mkstat = 2 : End
 Endif
Endif
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
Call AFFCNT(VALEUR,"")
#BPRRSK intiatization
If dim([M:BAG1]CLIFOUR)>=1 & VALEUR<>""
 If dim([M:CFP1]BPRFUP)>0 | dim([M:BPC3]BPCRSK)>0 | dim([M:BPS2]BPSNUM)>0
  End
 Endif

 If clalev ([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
 If clalev ([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif

 If [M:BAG1]CLIFOUR="F"
  Read [F:BPS]BPS0 = VALEUR
  If fstat | [F:BPS]BPSRSK=""
   [M]BPRRSK = ""
  Else
   [M]BPRRSK = [F:BPS]BPSRSK
  Endif
 Else
  Read [F:BPC]BPC0 = VALEUR
  If fstat | [F:BPC]BPCRSK=""
   [M]BPRRSK = ""
  Else
   [M]BPRRSK = [F:BPC]BPCRSK
  Endif
 Endif
 Affzo [M]BPRRSK
Endif
End

#MAJ infos contact
Subprog AM_FNCCNT(VALEUR)
Variable Integer VALEUR
Filter [F:CNT] Where BPATYP=1 & BPANUM=[M]BPR & CNTFNC=VALEUR
Read [F:CNT]CNT1 First
Filter [F:CNT]
If fstat
 Effzo [M]CNT, TEL
Else
 If [F:CNT]CCNCRM<>""
  Read[F:AIN]AIN0=[F:CNT]CCNCRM
  Call AFFCNT([M]BPR,num$(VALEUR))
 Endif
Endif
End

#MAJ de la monnaie sociﺣ۸tﺣ۸ + raz du site
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]FCY = ""
 Affzo [M]FCY
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 [M]CPY=VALEUR
 [M]ACCCUR = [F:CPY]ACCCUR
 Gosub DEVISE
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If GNBAUZ <> GNBSITE
 If VALEUR<>""
  Call CONTFCY(VALEUR) From CPTSUB
  If mkstat : End : Endif
  If [M]CPY<>[F:FCY]LEGCPY
   [M]CPY = [F:FCY]LEGCPY
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   [M]ACCCUR = [F:CPY]ACCCUR
   Gosub DEVISE
   Affzo [M]CPY
   [M]CPY = [F:FCY]LEGCPY
  Endif
 Elsif [M]CPY=""
  GMESSAGE = mess(9,109,1) : # Vous devez saisir une sociﺣ۸tﺣ۸ ou un site
  mkstat = 2 : End
 Else
  Call CONTALLFCY([M]CPY) From CPTSUB : # Accﺣ۷s ﺣ  tous les sites de la sociﺣ۸tﺣ۸ ?
 Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [M]CPY<>[F:FCY]LEGCPY
  [M]CPY = [F:FCY]LEGCPY
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  [M]ACCCUR = [F:CPY]ACCCUR
  Gosub DEVISE
  Affzo [M]CPY
  [M]CPY = [F:FCY]LEGCPY
  Endif
Endif
End

