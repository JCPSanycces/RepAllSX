###############################################################################
##              Etiquettes masque CONSBAG4                                  ##
###############################################################################
Subprog IB_NBRLIG
If clalev ([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif :#facture vente
If clalev ([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif :#facture achat
Gosub SETNOL From TRTZOMBAG
Raz GBOUT1
mkstat = 0
If NOL>=[M:BAG4]NBRLIG | [M:BAG4]NBRLIG=0 : End : Endif
If [M:BAG4]NUM(NOL)=""  : End : Endif
GBIDC2=[M:BAG4]NUM(NOL)
If [M:BAG1]CLIFOUR="F"
 GBOUT1= mess(NOL+1,2611,1)
 Case NOL+1
  When 1 : GBIDC1="PQH"
  When 2 : GBIDC1="POH"
  When 3 : GBIDC1="PTH"
  When 4 : GBIDC1="PIH"
  Read[F:PIH]PIH0=GBIDC2
  If !fstat
   If [F:PIH]ORIMOD=3 :#Tiers
    GBIDC1="BIS"
   Else
    GBIDC1="PIH"
   Endif
  Endif
  When 5 : GBIDC1="PAY"
 Endcase
Else
 GBOUT1= mess(NOL+1,2610,1)
 Case NOL+1
  When 2 : GBIDC1="SQH"
  When 3 : GBIDC1="SOH"
  When 4 : GBIDC1="SDH"
  When 5 :
  Read[F:SIH]SIH0=GBIDC2
  If !fstat
   If [F:SIH]ORIMOD=3 :#Tiers
    GBIDC1="BIC"
   Else
    GBIDC1="SIH"
   Endif
  Endif
  When 6,7 : GBIDC1="PAY"
  When 8 : Raz GBOUT1, GBIDC1, GBIDC2
 Endcase
Endif
End

