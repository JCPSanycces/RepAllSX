#<AdxTL>@(#)%I%
# Supervisor
# Inquiry MWC

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:11"
A_USER  = "ADMIN"
A_STAMP = "20181109081111"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(18148,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSMWCSTD"
PROGSPE    = "CNSMWCSPE"
CBOITE     = "DCNSMWC"
BOITE      = "FCNSMWC"
NOMMSK(0)  = "CONSMWC1"
ABMSK(0)   = "MWC1"
NOMMSK(1)  = "CONSMWC2"
ABMSK(1)   = "MWC2"
CMEMO      = "mwc"
CNOMMSK    = "CRITMWC"
CABMSK     = "CMWC"
CODMSKDEF  = "STD"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER    [ITM] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT   [ITF] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT      [TUN] : Endif
If clalev([F:MFG])=0 : Local File MFGHEAD      [MFG] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CMWC]
 When  0 : Local Mask =NOMMSK(0) [MWC1]
 When  1 : Local Mask =NOMMSK(1) [MWC2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CMWC]
 When  0 : Grizo [MWC1]
 When  1 : Grizo [MWC2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CMWC]ITMREFSTR)>0
 Grizo [CMWC]ITMREFSTR
Endif
If dim([M:CMWC]ITMREFEND)>0
 Grizo [CMWC]ITMREFEND
Endif
If dim([M:CMWC]BOMOPESTR)>0
 Grizo [CMWC]BOMOPESTR
Endif
If dim([M:CMWC]BOMOPEEND)>0
 Grizo [CMWC]BOMOPEEND
Endif
If dim([M:CMWC]CTNSTR)>0
 Grizo [CMWC]CTNSTR
Endif
If dim([M:CMWC]CTNEND)>0
 Grizo [CMWC]CTNEND
Endif
If dim([M:CMWC]MFGNUMSTR)>0
 Grizo [CMWC]MFGNUMSTR
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CMWC])>0 : Close Local Mask [CMWC] : Endif
 When  0 : If clalev([M:MWC1])>0 : Close Local Mask [MWC1] : Endif
 When  1 : If clalev([M:MWC2])>0 : Close Local Mask [MWC2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CMWC]
 When  0 : Default Mask [MWC1]
 When  1 : Default Mask [MWC2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CMWC]
 When  0 : Raz [M:MWC1]
 When  1 : Raz [M:MWC2]
Endcase
Return

$CRITENT
If dim([M:CMWC]ITMREFSTR)>0 & dim([M:MWC1]ITMREFSTR)>0
 [M:CMWC]ITMREFSTR = [M:MWC1]ITMREFSTR
Endif
If dim([M:CMWC]ITMREFEND)>0 & dim([M:MWC1]ITMREFEND)>0
 [M:CMWC]ITMREFEND = [M:MWC1]ITMREFEND
Endif
If dim([M:CMWC]BOMOPESTR)>0 & dim([M:MWC1]BOMOPESTR)>0
 [M:CMWC]BOMOPESTR = [M:MWC1]BOMOPESTR
Endif
If dim([M:CMWC]BOMOPEEND)>0 & dim([M:MWC1]BOMOPEEND)>0
 [M:CMWC]BOMOPEEND = [M:MWC1]BOMOPEEND
Endif
If dim([M:CMWC]CTNSTR)>0 & dim([M:MWC1]CTNSTR)>0
 [M:CMWC]CTNSTR = [M:MWC1]CTNSTR
Endif
If dim([M:CMWC]CTNEND)>0 & dim([M:MWC1]CTNEND)>0
 [M:CMWC]CTNEND = [M:MWC1]CTNEND
Endif
If dim([M:CMWC]MFGNUMSTR)>0 & dim([M:MWC1]MFGNUMSTR)>0
 [M:CMWC]MFGNUMSTR = [M:MWC1]MFGNUMSTR
Endif
Return

$ENTCRIT
If dim([M:CMWC]ITMREFSTR)>0 & dim([M:MWC1]ITMREFSTR)>0
[M:MWC1]ITMREFSTR = [M:CMWC]ITMREFSTR
Endif
If dim([M:CMWC]ITMREFEND)>0 & dim([M:MWC1]ITMREFEND)>0
[M:MWC1]ITMREFEND = [M:CMWC]ITMREFEND
Endif
If dim([M:CMWC]BOMOPESTR)>0 & dim([M:MWC1]BOMOPESTR)>0
[M:MWC1]BOMOPESTR = [M:CMWC]BOMOPESTR
Endif
If dim([M:CMWC]BOMOPEEND)>0 & dim([M:MWC1]BOMOPEEND)>0
[M:MWC1]BOMOPEEND = [M:CMWC]BOMOPEEND
Endif
If dim([M:CMWC]CTNSTR)>0 & dim([M:MWC1]CTNSTR)>0
[M:MWC1]CTNSTR = [M:CMWC]CTNSTR
Endif
If dim([M:CMWC]CTNEND)>0 & dim([M:MWC1]CTNEND)>0
[M:MWC1]CTNEND = [M:CMWC]CTNEND
Endif
If dim([M:CMWC]MFGNUMSTR)>0 & dim([M:MWC1]MFGNUMSTR)>0
[M:MWC1]MFGNUMSTR = [M:CMWC]MFGNUMSTR
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSMWC2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "MWC"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:MWC1]MFGFCY,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(ITMREF(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$(BOMOPE(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]MFGNUM(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("0","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("1","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$(BOMSEQ(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(CTN2(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("2","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M:MWC1]MFGFCY" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "ITMREF(nolign-1)" With ctrans(func AFNC.PART(INFO,4),"¨","~")
  Assign "BOMOPE(nolign-1)" With val(ctrans(func AFNC.PART(INFO,5),"¨","~"))
  Assign "[M]MFGNUM(nolign-1)" With ctrans(func AFNC.PART(INFO,6),"¨","~")
  Assign "0" With val(ctrans(func AFNC.PART(INFO,10),"¨","~"))
  Assign "1" With val(ctrans(func AFNC.PART(INFO,11),"¨","~"))
  Assign "BOMSEQ(nolign-1)" With val(ctrans(func AFNC.PART(INFO,12),"¨","~"))
  Assign "CTN2(nolign-1)" With ctrans(func AFNC.PART(INFO,13),"¨","~")
  Assign "2" With val(ctrans(func AFNC.PART(INFO,14),"¨","~"))
  Onerrgo
  Call B1_NBLIG From ="W1CONSMWC2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


