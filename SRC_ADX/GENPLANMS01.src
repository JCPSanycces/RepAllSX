#########################################################################################
## Génération du WPMS*PLANCUM1 : Lecture et écriture des cumuls simulés masse salariale
#########################################################################################

$MAJCUMMS1
PROG = "WPMS"+[L]LEGPLAN+"PLANCUM1"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
Wrseq "## Initialisation des cumuls en fonction de la dernière simulation MS du salarié courant"
Wrseq "## Si pas trouvé on cherche dans HISTOPAYE (Gosub LEC_REEL)"
Wrseq
Wrseq "$LECTURE"

#######################################

Wrseq "Raz ";PHISMS
###

Wrseq "If GIHYP<2"
Wrseq " I = GIHYP"
# WGA -Wrseq " Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=0 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY "
#63613
#Wrseq " Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY"
Wrseq " Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY & SIM=2"
Wrseq " Read ";PHISMS;" MHS0 Last"
Wrseq " Filter ";PHISMS
Wrseq "Else"
Wrseq " For I= GIHYP To 2 Step -1"
#57210+57286
#Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=GIHYP-1 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY "
#63613
#Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I-1 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY"
#Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I-1 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY & SIM=2"
Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP & DAT<DATPAY & SIM=2"
Wrseq "  Read ";PHISMS;" MHS0 Last"
Wrseq "  Filter ";PHISMS
Wrseq "  If fstat<=2 : Break : Endif"
Wrseq " Next"
Wrseq "Endif"
Wrseq "If fstat>2"
#57286
Wrseq " If CHREMP=''"
Wrseq "  Gosub LEC_REEL From WPMS"+[L]LEGPLAN+"PLANCUM2"
Wrseq " Endif"
# fin 57286
Wrseq " Return"
Wrseq "Else"
Wrseq " DATPREC = ";PHISMS;"DAT"
Wrseq "Endif"

Wrseq

Wrseq "If DATPREC<>[0/0/0]"
Wrseq " If GIHYP<2"
# WGA -Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=0 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP"
Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP"
Wrseq "& & DAT=DATPREC & TYP=6 & AMT<>0"
Wrseq " Else"
#57210+57286
#Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=GIHYP-1 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP"
#Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I-1 & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP"
Wrseq "  Filter ";PHISMS;" Where COD=SCENARIO & LIGHYP=I & CODHYP=LISHYP(I) & EMP=MATRI & CTR=CTR & MSEMP=CHREMP"
Wrseq "& & DAT=DATPREC & TYP=6 & AMT<>0"
Wrseq " Endif"
#Wrseq " For ";PHISMS;"MHS1"
Wrseq " For ";PHISMS;"MHS0"
###

Wrseq "  Case ";PHISMS;"RUB"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq '   When ';format$('K:13X','"'+[F:CUM]CUMCOD+'"');' : ';
 Wrseq format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';PHISMS;'AMT'
Next
Wrseq "  Endcase"
Wrseq " Next"
Wrseq " Filter ";PHISMS
Wrseq
Wrseq "# Réinitialisation des cumuls"
Wrseq " J = month(DATPREC)+1"

Wrseq " K = month(DATFIN)+12*(year(DATFIN)-year(DATPREC))"

For P=1 To len(mess(0,10334,1))

 Wrseq ' INICUM = "'+INICUM(P)+'"'
 For [ECC]ECC1 Where  LEG=LEGPLAN and PER=P
  Read [ECH]ECH0 = LEGPLAN;[F:ECC]COD
  FLIF = 0
  If [F:ECH]FCY<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'SITE="';[F:ECH]FCY;'"'
  Endif
  If [F:ECH]PRF<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'PROFIL="';[F:ECH]PRF;'"'
  Endif
  If [F:ECH]SRV<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'SERVICE="';[F:ECH]SRV;'"'
  Endif
  If [F:ECH]EMPSTR<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'MATRI>="';[F:ECH]EMPSTR;'"'
  Endif
  If [F:ECH]EMPEND<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'MATRI<="';[F:ECH]EMPEND;'"'
  Endif
  If [F:ECH]CRI<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq "(";vireblc(format$("KT:250X",[F:ECH]CRI),2);")"
  Endif
  If [F:ECC]DATSTR<>[0/0/0]
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'DATPAY>=[';format$(GFMD,[F:ECC]DATSTR);"]"
  Endif
  If [F:ECC]DATEND<>[0/0/0]
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'DATPAY<=[';format$(GFMD,[F:ECC]DATEND);"]"
  Endif
  SPA = 2
  If [F:ECH]POP<>""
   Wrseq space$(SPA);'Read [POA]POA0 = "';[F:ECH]POP;'";MATRI'
   Wrseq space$(SPA);'If !fstat'
   SPA += 1
  Endif
  Wrseq space$(SPA);'INICUM = "'+[F:ECC]TYP+[F:ECC]TYP+'"'
  If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  If FLIF : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
 Next

 K = 0
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP<=1 & RAZCUM<2 & LEG=LEGPLAN
  If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : K=1 : Endif
  Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP<=1 & RAZCUM<2 & LEG=LEGPLAN
  If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : K=1 : Endif
  Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP<=1 & RAZCUM=2 & LEG=LEGPLAN
  If    K=0 : Wrseq ' If [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=1
  Elsif K=1 : Wrseq ' Elsif [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=2
  Endif
  Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP<=1 & RAZCUM=2 & LEG=LEGPLAN
  If    K=0 : Wrseq ' If [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=1
  Elsif K=1 : Wrseq ' Elsif [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=2
  Endif
  Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
 Next
 If K : Wrseq " Endif" : Endif
Next P
Wrseq ' ';'For K=1 To find("",CUMSVG)-1'
Wrseq ' ';' Assign "'+PCUM+'"+CUMSVG(K) With evalue("'+PCUMSVG+'"+CUMSVG(K))'
Wrseq ' ';'Next'
Wrseq "Endif"

Wrseq "# Sauvegarde des cumuls"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(2)');' = ';PCUM;[F:CUM]CUMCOD;'(1)'
Next
Wrseq "Return"
Wrseq

# / 76086
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB

PROG = "WPMS"+[L]LEGPLAN+"PLANCUM3"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
#   76086 /

Wrseq "## Ecriture des résultats simulés dans MSHISTO"
Wrseq "$ECRITURE"
For [CUM]CUM1 Where CUMTMP<>2 & LEG=LEGPLAN
 Wrseq 'RUB  = "';[F:CUM]CUMCOD;'" : ';
 Wrseq "MONT = ";PCUM;[F:CUM]CUMCOD;" : ";
 Wrseq "BASE = ";PCUM;[F:CUM]CUMCOD;"(2) : ";
 Wrseq "Gosub MSMAJCUM From GPLAN"
 Wrseq "If GOK<1 : Return : Endif"
Next
Wrseq "Return"
Wrseq
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

#####################################################################################################
## Génération du WPMS*PLANCUM2 : Lecture cumuls réels et écriture des cumuls réels dans MSHISTO
#####################################################################################################

$MAJCUMMS2
PROG = "WPMS"+[L]LEGPLAN+"PLANCUM2"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
Wrseq "## Initialisation des cumuls en fonction de la date de référence"
Wrseq "$LEC_REEL"
Wrseq "Filter [VEP3] Where EMP=MATRI & PYRDAT<=DATREF & CTRNUM=CTR"
Wrseq "Read [VEP3]VEP0 Last"
Wrseq "Filter [VEP3]"
Wrseq "If fstat>2 : DATPREC = [0/0/0] : Else : DATPREC = [F:VEP3]ENDDAT : Endif"
Wrseq "If fstat>2 "
Wrseq " [L]RAZCUM=0"
Wrseq "Else"
Wrseq " Filter [CTR2] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[F:VEP3]ENDDAT"
Wrseq " Read [CTR2]CTR0 Last"
Wrseq " Filter [CTR2]"
Wrseq " If fstat<2 & [F:CTR2]CTRDAT<>[F:HRCTR]CTRDAT & [F:CTR2]RAZCUM=2 : [L]RAZCUM=1 : Else [L]RAZCUM=0 : Endif"
Wrseq "Endif"
###

Wrseq "If DATPREC<>[0/0/0]"

Wrseq " For ";PHIS;"HSP3 Where BUL=[F:VEP3]BUL & TYP=6 & AMT<>0"
###

Wrseq "  Case ";PHIS;"RUB"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq '   When ';format$('K:13X','"'+[F:CUM]CUMCOD+'"');' : ';
 Wrseq format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';PHIS;'AMT'
Next
Wrseq "  Endcase"
Wrseq " Next"
Wrseq
Wrseq "# Réinitialisation des cumuls"
Wrseq " J = month(DATPREC)+1"

Wrseq " K = month(DATFIN)+12*(year(DATFIN)-year(DATPREC))"

For P=1 To len(mess(0,10334,1))

 Wrseq ' INICUM = "'+INICUM(P)+'"'
 For [ECC]ECC1 Where LEG=LEGPLAN and PER=P
  Read [ECH]ECH0 = LEGPLAN;[F:ECC]COD
  FLIF = 0
  If [F:ECH]FCY<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'SITE="';[F:ECH]FCY;'"'
  Endif
  If [F:ECH]PRF<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'PROFIL="';[F:ECH]PRF;'"'
  Endif
  If [F:ECH]SRV<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'SERVICE="';[F:ECH]SRV;'"'
  Endif
  If [F:ECH]EMPSTR<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'MATRI>="';[F:ECH]EMPSTR;'"'
  Endif
  If [F:ECH]EMPEND<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'MATRI<="';[F:ECH]EMPEND;'"'
  Endif
  If [F:ECH]CRI<>""
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq "(";vireblc(format$("KT:250X",[F:ECH]CRI),2);")"
  Endif
  If [F:ECC]DATSTR<>[0/0/0]
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'DATPAY>=[';format$(GFMD,[F:ECC]DATSTR);"]"
  Endif
  If [F:ECC]DATEND<>[0/0/0]
   If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
   Wrseq 'DATPAY<=[';format$(GFMD,[F:ECC]DATEND);"]"
  Endif
  SPA = 2
  If [F:ECH]POP<>""
   Wrseq space$(SPA);'Read [POA]POA0 = "';[F:ECH]POP;'";MATRI'
   Wrseq space$(SPA);'If !fstat'
   SPA += 1
  Endif
  Wrseq space$(SPA);'INICUM = "'+[F:ECC]TYP+[F:ECC]TYP+'"'
  If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  If FLIF : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
 Next

 K = 0
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP<=1 & RAZCUM<2 & LEG=LEGPLAN
  If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : K=1 : Endif
# 31083
# Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
# fin 31083
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP<=1 & RAZCUM<2 & LEG=LEGPLAN
  If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : K=1 : Endif
  Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP<=1 & RAZCUM=2 & LEG=LEGPLAN
  If    K=0 : Wrseq ' If [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=1
  Elsif K=1 : Wrseq ' Elsif [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=2
  Endif
# 31083
# Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
  Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
# fin 31083
 Next
 For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP<=1 & RAZCUM=2 & LEG=LEGPLAN
  If    K=0 : Wrseq ' If [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=1
  Elsif K=1 : Wrseq ' Elsif [L]RAZCUM | (K>=J & instr(1,seg$(INICUM,J,K),"O"))' : K=2
  Endif
  Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
 Next

#57410
 #For J=1 To len(mess(0,10349,1))
 # If RAZCUMRUB(J)=P
 #  If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : Endif
 #  K += 1
  # Wrseq "  [F:EPC]CUM"+num$(J);" = 0"
 # Endif
 #Next J
# fin 57410
 If K : Wrseq " Endif" : Endif
Next P

# 31083
Wrseq ' ';'For K=1 To find("",CUMSVG)-1'
Wrseq ' ';' Assign "'+PCUM+'"+CUMSVG(K) With evalue("'+PCUMSVG+'"+CUMSVG(K))'
Wrseq ' ';'Next'
# fin 31083

Wrseq "Endif"
Wrseq "# Sauvegarde des cumuls"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(2)');' = ';PCUM;[F:CUM]CUMCOD;'(1)'
Next
Wrseq "Return"
Wrseq

Wrseq "## Ecriture des résultats réels (déjà calculé cause révision budgétaire) dans MSHISTO"
Wrseq "## Report des cumuls réels dans la masse salariale"
Wrseq "## ne concerne pas les entrants & les remplaçants (pas de paye réelle)"
Wrseq "$ECR_REEL"
Wrseq "Filter [F:HSP] Where BUL=BULLETIN"
Wrseq "For [F:HSP]HSP3"
Wrseq " Raz [F:MHS]"
Wrseq " [F:MHS]COD    = SCENARIO"
Wrseq " If GIHYP>1"
#Wrseq "  [F:MHS]LIGHYP = GIHYP-1"
Wrseq "  [F:MHS]LIGHYP = GIHYP"
Wrseq " Endif"
Wrseq " [F:MHS]CODHYP = LISHYP(GIHYP)"
Wrseq " [F:MHS]TYPHYP = val(TYPHYP(GIHYP))"
Wrseq " [F:MHS]BUD    = GBUDHYP(GIHYP)"
Wrseq " [F:MHS]EMP    = MATRI"
Wrseq " [F:MHS]CTR    = CTR"
Wrseq " [F:MHS]DAT    = DATPAY"
Wrseq "# [F:MHS]RUB    = RUB # modif WGA"
Wrseq " [F:MHS]RUB    = [F:HSP]RUB"
Wrseq " [F:MHS]TYP    = [F:HSP]TYP"
Wrseq " [F:MHS]BAS    = [F:HSP]BAS"
Wrseq " [F:MHS]RAT    = [F:HSP]RAT"
Wrseq " [F:MHS]AMT    = [F:HSP]AMT"
Wrseq " [F:MHS]CPY    = SOCIETE"
Wrseq " [F:MHS]FCY    = SITE"
Wrseq " [F:MHS]SRV    = SERVICE"
Wrseq " [F:MHS]PRF    = PROFIL"
Wrseq " [F:MHS]SIM    = 2"

Wrseq ' If evalue("dim('+PGRP+'"+RUB+")") > 0'
Wrseq '  [F:MHS]GRP = evalue("GRP_"+RUB)'
Wrseq '  If evalue("dim('+PCAT+'"+evalue("GRP_"+RUB)+")") > 0 : [F:MHS]CAT = evalue(PCAT+evalue("GRP_"+RUB)) : Endif'
Wrseq ' Endif'

Wrseq " Write [MHS]"
Wrseq " If fstat"
Wrseq '  GOK = 0 : Call FSTA("MHS") From GLOCK : Break'
Wrseq " Endif"
Wrseq "Next"
Wrseq "Filter [F:HSP]"
Wrseq "Raz [F:MHS]"
Wrseq "Return"

Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

$INSERT_FILE

Wrseq "##################################"
Wrseq "$RELIT_VAR"
Wrseq "Local Integer IR, OKH"
Wrseq "If (SITE<>[F:HRCTR]ETRFCY) or (PROFIL<>[F:HRCTR]PROPRF) or (SERVICE<>[F:HRCTR]ETRSRV) or (MODIFVAR=2 & find([F:MCL]TYPHYP,4,5)>0) Then"
Wrseq "  Local Char    SAVFILE (250)"
Wrseq "  SAVFILE=dbgstr(2)"
Wrseq "  If clalev([F:MCL2])=0  : Local File MSSCENAL    [MCL2]  : ENDIF"
Wrseq "  PROFIL  = [F:HRCTR]PROPRF"
Wrseq "  SERVICE = [F:HRCTR]ETRSRV"
Wrseq "  SITE    = [F:HRCTR]ETRFCY"
Wrseq "  Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & PYRDAT<=DATREF"
Wrseq "  Read [VEP]VEP0 Last"
Wrseq "  Filter [VEP]"
Wrseq "  If fstat<=2"
Wrseq "    DATREF   = DATPAY"
Wrseq "    DATPAY   = [F:VEP]PYRDAT"
Wrseq "    Gosub DECLARE From WPMSPLANDECV":#93072
For I=1 To NBPLANVRA
  Wrseq "    Gosub LECTURE From WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I)
Next
Wrseq "    DATPAY = DATREF"
Wrseq "    DATREF = [F:VEP]PYRDAT"
Wrseq
Wrseq "    For [F:MCL2]MCL0 Where COD=SCENARIO & STAHYP<>3 & STRHYP<PERFIN & ENDHYP>PERDEB & NUMLIG<[F:MCL]NUMLIG"
Wrseq "      If LIGHYPO=0 | LIGHYPO<=[F:MCL2]NUMLIG"
Wrseq "        For IR=2 To GIHYP"
Wrseq "          # Parcours des hypothèses précédentes actives de modif contrat & E/S salarié"
Wrseq "          If LISHYP(IR)<>'' & ( (LIGHYPO=0 & find(TYPHYP(IR),'5','6')) |"
Wrseq "&           (LIGHYPO<>0 & TYPHYP(IR)=TYPHYP(LIGHYPO+1) & LISHYP(IR)=LISHYP(LIGHYPO+1) & find(TYPHYP(IR),'4','5')) )"
Wrseq "            NOMTRT='WPMS'+TYPHYP(IR)+LISHYP(IR)"
Wrseq '            If filexist("","'+APPLI+'",NOMTRT)'
Wrseq "              If LIGHYPO=0 & find(TYPHYP(IR),'5','6')"
Wrseq "                ## Prise en compte des hypothèses : modifs contrat, sortie salarié uniquement pour salariés réels"
Wrseq "                Gosub LECTURE From =NOMTRT"
Wrseq "              Else"
Wrseq "                ## Prise en compte des hypothèses : entrée salarié ou remplacement salarié"
Wrseq "                Gosub LIRE From =NOMTRT"
Wrseq "              Endif"
Wrseq "              If OKSIM=0 : Break 2 : Endif"
Wrseq "            Endif"
Wrseq "          Endif"
Wrseq "        Next"
Wrseq
Wrseq "        ## Affectation des variables en fonction des hypothèses du scénario"
Wrseq "        If num$([F:MCL2]TYPHYP)='1'| num$([F:MCL2]TYPHYP)='4' | num$([F:MCL2]TYPHYP)='5' | num$([F:MCL2]TYPHYP)='6' | num$([F:MCL2]TYPHYP)='9'"
Wrseq "          OKH=2"
Wrseq "          If [F:MCL]TYPHYP=4 Then"
Wrseq "            If [F:MHE]SRCENT=MATRI Then OKH=1 : Endif"
Wrseq "          Endif"
Wrseq "          If [F:MCL]TYPHYP=5 Then"
Wrseq "            If [F:MHX]SRCENT=MATRI Then OKH=1 : Endif"
Wrseq "          Endif"
Wrseq "          NOMTRT='WPMS'+num$([F:MCL2]TYPHYP)+[F:MCL2]CODHYP"
Wrseq '          If filexist("","'+APPLI+'",NOMTRT) & OKH=2'
Wrseq "           Gosub HYPOVAR From =NOMTRT"
Wrseq "          Endif"
Wrseq "        Endif"
Wrseq
Wrseq "      Else"
Wrseq
Wrseq "        If num$([F:MCL2]TYPHYP)='1' | num$([F:MCL2]TYPHYP)='9'"
Wrseq "          NOMTRT='WPMS'+num$([F:MCL2]TYPHYP)+[F:MCL2]CODHYP"
Wrseq '          If filexist("","'+APPLI+'",NOMTRT)'
Wrseq "            Gosub HYPOVAR From =NOMTRT"
Wrseq "          Endif"
Wrseq "        Endif"
Wrseq "      Endif"
Wrseq "    Next"
Wrseq "    Close File [F:MCL2]"
Wrseq "    Default File SAVFILE"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "Return"
Wrseq

Return

$DECLARE_VAR
Local Integer K
PROG = "WPMSPLANDECV"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1)-mess(0,10722,1) : # Plan de paye Masse salariale
Wrseq "## Déclaration variables"
Wrseq "$DECLARE"
K = 0
For [VRA]VRA0 Where FLGEXS<>2 and LEG=[L]LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PVAR+[F:VRA]COD;
 K += 1
Next
Wrseq
Wrseq "Return"
Wrseq
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
#end 93072
Return

