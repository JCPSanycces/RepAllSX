#<AdxTL>@(#)2.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Supp ref croisée pour suppression des classes ATECH*
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Supp ref croisée pour suppression des classes ATECH*") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DELATECH
End

#----------------------------------------------#
$DELATECH
Local File =DOSSIER+".ACLAFLD" [ACLAF]
Trbegin [ACLAF]
  Delete [ACLAF] Where CODCLA="ATECHASHWLNK" & LNKCLA="ATECHASHWLNK"
  If fstat = 0
   Call ECR_TRACE(num$(adxdlrec)-"recod(s) deleted",0) From GESECRAN
  Endif
  Delete [ACLAF] Where CODCLA="ATECHCLALNK" & LNKCLA="ATECHCLASSE"
  If fstat = 0
   Call ECR_TRACE(num$(adxdlrec)-"recod(s) deleted",0) From GESECRAN
  Endif
  Delete [ACLAF] Where CODCLA="ACLASSE" & LNKCLA="ACLASSE"
  If fstat = 0
   Call ECR_TRACE(num$(adxdlrec)-"recod(s) deleted",0) From GESECRAN
  Endif
Commit
Close Local File [ACLAF]
Return
