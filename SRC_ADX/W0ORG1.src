# Superviseur
# Gestion du masque ORG1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TYP
mkstat = 0
zoncou = "TYP"
indice = 0
IMPENT = [M]TYP
WNUM = IMPENT
SAVACT = GACTION : GACTION = "STD"
Call AV_TYP(IMPENT) From SUBORG
GACTION = SAVACT
If mkstat=1 : Raz IMPENT : Endif
If !mkstat
 If varinit([M]TYP,indice)=0
  IMPENT = 1
 Endif
Endif
If varmode([M]TYP,indice)=0
 [M]TYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYP(IMPENT) From SUBORG
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 46893 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYP = IMPENT

## Zone CRN
mkstat = 0
zoncou = "CRN"
indice = 0
If varmode([M]CRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTSIRET"
 Call CONTSIRET([M]CRN,[M]CRY,"") From CONTNUM
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CRN" : GZNUM = 26815 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NSSCOD
mkstat = 0
zoncou = "NSSCOD"
indice = 0
If varinit([M]NSSCOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NSSCOD,"","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NSSCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NSSCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]NSSCOD,"","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NSSCOD" : GZNUM = 56302 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]NSSCOD,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "NSSCOD" : GZNUM = 56302 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

