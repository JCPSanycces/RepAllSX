   IMPMOD = 0 : IMPZON = "POS" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "POSCNTOBL"
  PARAM(1) = [M]CRY
  PARAM(2) = "0"
  Local Char    VALEUR(250)
  VALEUR = [M]POS
  Call S_AFF_CHAR(VALEUR,PARAM,"POSCNTOBL","SUBPOS","") From GACTION
  [M]POS = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "POS" : GZNUM = 16059 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]POS or IMPMOD
    SAVACT = GACTION : GACTION = "CPCONT"
    PARAM(1) = [M]CRY
    PARAM(2) = [M]CTY
    PARAM(3) = ""
    Local Char    VALEUR(250)
    VALEUR = [M]POS
    Call S_AFF_CHAR(VALEUR,PARAM,"CPCONT","SUBPOS","") From GACTION
    [M]POS = VALEUR
    [M]CTY = PARAM(2)
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "POS" : GZNUM = 16059 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

