 When "GER":
  Case _ID
   When 3498: RES='Einheitentabelle'
   When 2685: RES='Einheit'
   When 8: RES='Bezeichnung'
   When 4010: RES='Kurzbezeichnung'
   When 483: RES='Symbol'
  Endcase
 When "POL":
  Case _ID
   When 3498: RES='Jednostka'
   When 2685: RES='JM'
   When 8: RES='Opis'
   When 4010: RES='Krótki tytuł'
   When 483: RES='Symbol'
  Endcase
 When "CHI":
  Case _ID
   When 3498: RES='计量单位'
   When 2685: RES='单位'
   When 8: RES='标题'
   When 4010: RES='简称'
