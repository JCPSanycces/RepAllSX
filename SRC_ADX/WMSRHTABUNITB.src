$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 3498: RES='Table des unités'
   When 2685: RES='Unité'
   When 8: RES='Intitulé'
   When 4010: RES='Intitulé court'
   When 483: RES='Symbole'
  Endcase
 When "ENG":
  Case _ID
   When 3498: RES='Table of units of measure'
   When 2685: RES='Unit'
   When 8: RES='Description'
   When 4010: RES='Short description'
   When 483: RES='Symbol'
  Endcase
 When "ITA":
  Case _ID
   When 3498: RES='Tabella delle unità'
   When 2685: RES='Unità'
   When 8: RES='Descrizione'
   When 4010: RES='Descr. breve'
   When 483: RES='Simbolo'
  Endcase
 When "POR":
  Case _ID
   When 3498: RES='Tabela das unidades'
   When 2685: RES='Unid.'
   When 8: RES='Descr.'
   When 4010: RES='Desc. curta'
   When 483: RES='Símbolo'
  Endcase
 When "SPA":
  Case _ID
   When 3498: RES='Tabla de unidades'
   When 2685: RES='Unidad'
   When 8: RES='Descripción'
   When 4010: RES='Descrip. corta'
   When 483: RES='Símbolo'
  Endcase
 When "BRI":
  Case _ID
   When 3498: RES='Unit of Measure'
   When 2685: RES='Unit'
   When 8: RES='Description'
   When 4010: RES='Short title'
   When 483: RES='Symbol'
