#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour Liste de gauche objet AIA AWU
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update objects for SAM 95997 translation project") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAOB
End

#-------------------#
$MAJAOB

Local Integer I , VALMOD(20)

If DOSSIER=GDOSX3
 Return
Endif
If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

# Mise à jour de la table AOBJET
Call ECR_TRACE(mess(81,125,1)-"AOBJET:"-time$,0) From GESECRAN

# Onglet Sélection
Local Char ZOBJ(3)(1..33)
Local Integer  ZMOD

For J=1 To 33
  Gosub OBJLIST
  If [F:ADS]MODULE(ZMOD-1)<>2 : Goto SKIP_SEL : Endif  # 12-Jan-2015  EWI
Call MAJ_SEL(DOSSIER,ZOBJ) From PATCHAOB
$ SKIP_SEL
Next J

# Validation de l'objet

For J = 1 To 33
  Gosub OBJLIST # 12/Jan/15
  If [F:ADS]MODULE(ZMOD-1)<>2 : Goto SKIP : Endif  # 12-Jan-2015  EWI
  Call VALID_TRT(DOSSIER,0,"","","","","","","","",ZOBJ,ZOBJ,"","","","","","","","","","",VALMOD) From VALDICO
  Call VALFEN(DOSSIER,ZOBJ) From SUBAOB
$SKIP
Next J

Return


$OBJLIST
Case J
  When 1 ZOBJ='BUT' : ZMOD=2 # Fin     2
  When 2 ZOBJ='CDA' : ZMOD=3 # A/P     3
  When 3 ZOBJ='COA' : ZMOD=9 # Common  9
  When 4 ZOBJ='DAD' : ZMOD=2 # Fin     2
  When 5 ZOBJ='DTP' : ZMOD=2 # Fin     2
  When 6 ZOBJ='EDM' : ZMOD=3 # A/P     3
  When 7 ZOBJ='FGP' : ZMOD=3 # A/P     3
  When 8 ZOBJ='FRM' : ZMOD=3 # A/P     3
  When 9 ZOBJ='GAU' : ZMOD=9 # Common  9
  When 10 ZOBJ='GBS' : ZMOD=3 # A/P    3
  When 11 ZOBJ='GCM' : ZMOD=9 # Common 9
  When 12 ZOBJ='GCO' : ZMOD=2 # Fin    2
  When 13 ZOBJ='GDE' : ZMOD=2 # Fin    2
  When 14 ZOBJ='GDS' : ZMOD=3 # A/P    3
  When 15 ZOBJ='GFP' : ZMOD=3 # A/P    3
  When 16 ZOBJ='GRA' : ZMOD=9 # Common 9
  When 17 ZOBJ='GVG' : ZMOD=9 # Common 9
  When 18 ZOBJ='IDP' : ZMOD=3 # A/P    3
  When 19 ZOBJ='LOC' : ZMOD=7 # Stock  7
  When 20 ZOBJ='PAB' : ZMOD=3 # A/P    3
  When 21 ZOBJ='PH1' : ZMOD=5 # Sales  5
  When 22 ZOBJ='SOH' : ZMOD=5 # Sales  5
  When 23 ZOBJ='TAM' : ZMOD=9 # Common 9
  When 24 ZOBJ='TCM' : ZMOD=9 # Common 9
  When 25 ZOBJ='TES' : ZMOD=3 # A/P    3
  When 26 ZOBJ='TFB' : ZMOD=3 # A/P    3
  When 27 ZOBJ='TLO' : ZMOD=7 # Stock  7
  When 28 ZOBJ='TMD' : ZMOD=9 # Common 9
  When 29 ZOBJ='TPY' : ZMOD=3 # A/P    3
  When 30 ZOBJ='TYC' : ZMOD=3 # A/P    3
  When 31 ZOBJ='ANM' : ZMOD=1 # Sup    1
  When 32 ZOBJ='GIC' : ZMOD=2 # Fin    2
  When 33 ZOBJ='TCY' : ZMOD=1 # Sup    1
  When Default
Endcase

Return
