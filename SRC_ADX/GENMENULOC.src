#<AdxTL>@(#)2.0.0.0 $Revision$
Call MENULOC
End

##################################################################
Subprog MENULOC
Local Char PARAM(30)(1..2), VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","GENMENULOC","GENMENULOC",3,"XYGENMENULOC") From GTRAITE
End

##################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
Endcase
Return

###################################################################
$INIT
Local Mask GENMENULOC [DIA]
Local Char    SYMBOLE(80)
SYMBOLE = "APLSTD"
Gosub INIT_DIA
Return

##################################################################
$INIT_DIA
TIT = mess(28,115,1) # Mise à jour menus locaux
Return

##################################################################
$EXEC
Lock =SYMBOLE With lockwait=0
If !fstat
 Call GENMENU(nomap,0,([M:DIA]TOULAN=2),GLANGUE)
 Unlock =SYMBOLE
Else
 Call ERREUR(mess(10,100,1)) From GESECRAN
 SAI = 1
Endif
Return

##################################################################
Subprog GENMENU(APPLI,BATCH,TOULAN,LANG)
Value Char    APPLI
Value Integer BATCH
Value Integer TOULAN
Value Char    LANG

Local Char    LANGUE(GLONLAN) , LANDEF(GLONLAN)
Local Char    TLANGUE(GLONLAN)(1..50)
Local Integer NUCHP(1..30000)
Local Integer OK , NBLAN , LAN , NBLANX3 , NBCHP , CHP , STAT
Local Char    DOSX3(GLONADS) , HISDOS(GLONADS)
Local Char    MACHINE(GDIMFIC) , CHEMIN(GDIMFIC) , FICHIER(GDIMFIC) , FIC(20)(1..500)
Local Integer NBFIC
Local Char    WE_HORDAT(14)
Local Integer TMENUL(1..30000)          :  # Type des menus : 1 menu local , -1 message
Local Integer NBENTM : NBENTM=400       :  # Nombre max d'entrées par menu local
Local Char    VMENUL(200)(1..NBENTM)         :  # Table des valeurs du menu local
Local Char    VMENULNC(200)(1..NBENTM)       :  # Table des valeurs du menu local non codées
Local Char    VREFM(200)(1..NBENTM)        :  # Table des valeurs du menu de référence (ancien menu)
Local Char    VALLM(250),NOMFIC(GDIMFIC),NOMFICI(GDIMFIC)
Local Integer I,REEC,ICOU,MCOU
Local Integer RGD,RGF,NBREF,TRCOU
Local Char    FICLAN(GDIMFIC) , LANREF(GLONLAN)

If GTRACE<>""
 Call ECR_TIME(mess(28,115,1)) From DOSSUB : # Mise à jour des menus locaux
Endif

# Tableau des langues et des chapitres traités

If !BATCH
 Call TEMPON(mess(163,100,1)) From GESECRAN : # Recherche en cours
Endif

Local File =APPLI+".APLSTD" [AST]
Raz NBLAN , NBLANX3 , NBCHP
If TOULAN
 For [AST]LAN(1)
  NBLAN += 1
  TLANGUE(NBLAN) = [F:AST]LAN
  For [AST]LAN(2)
   If [F:AST]LANCHP>=1 & [F:AST]LANCHP<30000 & !find([F:AST]LANCHP,NUCHP)
    NBCHP += 1
    NUCHP(NBCHP) = [F:AST]LANCHP
   Endif
  Next AST(2)
 Next AST(1)
Else
 NBLAN      = 1
 TLANGUE(1) = LANG
 For [AST]LAN(2) Where LAN=TLANGUE(1)
   If [F:AST]LANCHP>=1 & [F:AST]LANCHP<30000 & !find([F:AST]LANCHP,NUCHP)
   NBCHP += 1
   NUCHP(NBCHP) = [F:AST]LANCHP
  Endif
 Next
Endif

If !BATCH
 Call TEMPOFF From GESECRAN
Endif

# Recherche du dossier histo

Local File =APPLI+".ADOVAL" [A_DW]
Read [A_DW]ADW0 = "";"";"HISDOS"
If !fstat  : HISDOS = [F:A_DW]VALEUR : Endif

# Pour les besoins de traduction des états, il faut générer tous les fichiers menuLAN

Read [A_DW]ADW0 = "";"";"SUPDOS"
If !fstat : DOSX3 = [F:A_DW]VALEUR : Endif
If APPLI=DOSX3 : DOSX3 = "" : Endif
If DOSX3<>"" & filinfo(filpath("FIL","APLSTD","fde",DOSX3),0)<0
 DOSX3 = ""
Endif
LANDEF = ""
If DOSX3<>"" and TOULAN
 Local File =DOSX3+".APLSTD"  [A_ST]
 For [A_ST]LAN(1)
  If !find([F:A_ST]LAN,TLANGUE(1..NBLAN))
   NBLANX3 += 1
   TLANGUE(NBLAN+NBLANX3) = [F:A_ST]LAN
  Endif
 Next A_ST
 Close Local File [A_DW]
 Local File =DOSX3+".ADOVAL" [A_DW]
 Read [A_DW]ADW0 = "";"";"LANGUAGE"
 If !fstat : LANDEF = [F:A_DW]VALEUR : Endif
Endif
Close Local File [A_DW]

# Génération de la table des menus

Call GENMENUS(APPLI,BATCH)

# Génération des menus dans la LANGUE

Local File =APPLI+".APLSTD"  [STD]
Local File =APPLI+".AMENLOC" [AML]
If DOSX3<>""
 Local File =DOSX3+".APLSTD"  [STDX]
Endif

#  Positionnements des variables globales et locales Web  :  CC 02/03/2003

Local File =APPLI+".AELT" [AEL]
Call ENVVAR(WE_HORDAT) From INTRUTILA
Call GLOBWEB(APPLI) From INTRUTILA

If adxlog=0
 Trbegin [AEL]
 TRCOU=1
Endif

# Boucle sur les LANGUES

For LAN=1 To NBLAN+NBLANX3
 If LAN>NBLAN
  Close Local File [STD] , [AML]
  Local File =DOSX3+".APLSTD"  [STD]
  Local File =DOSX3+".AMENLOC" [AML]
 Endif
 LANGUE = TLANGUE(LAN)
 If LANGUE="" : Goto NEXTLANG : Endif
 FICLAN = filpath("","menu"+tolower(LANGUE),"",APPLI)
 Call NAMEFIC(APPLI,"MENL",LANGUE,"",NOMFICI) From INTRUTILA
 If !BATCH
  Call TEMPON(mess(29,115,1)-LANGUE) From GESECRAN : # Génération
 Endif
 Openo FICLAN , 0 Using [A_MN]
 Iomode adxifs "" Using [A_MN]
 Iomode adxirs chr$(13)+chr$(10) Using [A_MN]
 Iomode adxium GUTF8 Using [A_MN]

# Génération json
Local Char MENJSONFILE(250),REP(250),DIRSEP
Local Integer GENJSON,NBWRJSON
If LANGUE<>"XXX"
  Case GOS(1)
   When "dos"   : DIRSEP="\"
   When Default : DIRSEP="/"
  Endcase
  REP = APPLI+DIRSEP+"GEN"+DIRSEP+LANGUE+DIRSEP+"MENL"
  NAMEFIC = filpath(REP,"","","X3_PUB")
  If filinfo(NAMEFIC,7)>=0
    Call NAMEFIC(APPLI,"MENLJ",LANGUE,"",MENJSONFILE) From INTRUTILA
    Openo MENJSONFILE,0 Using [JSON]
    Iomode adxifs "" Using [JSON]
    Iomode adxirs chr$(10) Using [JSON]
    Iomode adxium GUTF8 Using [JSON]
    Wrseq "{" Using [JSON]
    GENJSON=1
  Endif
Endif



 For CHP=1 To NBCHP
  Read [STD]LAN(2) = LANGUE ; NUCHP(CHP)
  If !fstat
   Wrseq [F:STD]LANCHP Using [A_MN]
   MCOU=[F:STD]LANCHP
   If TMENUL(MCOU)=0
    Read [AML]MENLOC=MCOU
    If [F:AML]MENLOCAL=2
     TMENUL(MCOU)=1
    Else
     TMENUL(MCOU)=-1
    Endif
   Endif
   Raz VMENUL,VMENULNC : ICOU=-1

   For [STD]LAN Where LAN=LANGUE & LANCHP=NUCHP(CHP)
    Wrseq [F:STD]LANMES Using [A_MN]
    ICOU+=1
    If ICOU>0 and ICOU<=NBENTM and TMENUL(MCOU)=1 and find(LANGUE,GI_LLAN(1..GI_NBLAN))
     VALLM=[F:STD]LANMES
     VMENULNC(ICOU)=VALLM
     Gosub MVALC1 From INTRUTILA
     VMENUL(ICOU)=VALLM
    Endif
   Next STD
   Wrseq "|" Using [A_MN]
   If ICOU>0 and ICOU<=NBENTM and TMENUL([F:STD]LANCHP)=1 and find(LANGUE,GI_LLAN(1..GI_NBLAN))
    Gosub WRIMWEB
   Endif
  Elsif DOSX3<>""
   LANREF = ""
   Read [STDX]LAN(2) = LANGUE ; NUCHP(CHP) : # Le chapitre existe-t'il dans la langue ?
   If !fstat
    LANREF = LANGUE
   Endif
   If LANREF="" & LANDEF<>""
    Read [STDX]LAN(2) = LANDEF ; NUCHP(CHP) : # Existe-t'il dans la langue par défaut du dossier superviseur
    If !fstat
     LANREF = LANDEF
    Endif
   Endif
   If LANREF<>""
    Wrseq [F:STDX]LANCHP Using [A_MN]
    MCOU=[F:STDX]LANCHP
    If TMENUL(MCOU)=0
     Read [AML]MENLOC=MCOU
     If !fstat and [F:AML]MENLOCAL=2
      TMENUL(MCOU)=1
     Else
      TMENUL(MCOU)=-1
     Endif
    Endif
    Raz VMENUL,VMENULNC : ICOU=-1
    For [STDX]LAN Where LAN=LANREF & LANCHP=NUCHP(CHP)
     Wrseq [F:STDX]LANMES Using [A_MN]
     ICOU+=1
     If ICOU>0 and ICOU<=NBENTM and TMENUL(MCOU)=1 and find(LANGUE,GI_LLAN(1..GI_NBLAN))
      VALLM=[F:STDX]LANMES
      VMENULNC(ICOU)=VALLM
      Gosub MVALC1 From INTRUTILA
      VMENUL(ICOU)=VALLM
     Endif
    Next STDX
    Wrseq "|" Using [A_MN]
    If ICOU>0 and ICOU<=NBENTM and TMENUL([F:STDX]LANCHP)=1 and find(LANGUE,GI_LLAN(1..GI_NBLAN))
     Gosub WRIMWEB
    Endif
   Endif
  Endif
 Next CHP
 Openo Using [A_MN]
 If !BATCH : Call TEMPOFF From GESECRAN : Endif

#     test CC
 If GENJSON=1
  Wrseq "}" Using [JSON]
  Openo  Using [JSON]
 Endif
#     fin test CC

$NEXTLANG
Next LAN

Call INILIBW(APPLI) From VALCSTWEB

If TRCOU=1 : Commit : Endif

# Copie des fichier menus* dans le dossier historisé

If HISDOS<>""
 If TOULAN
  CHEMIN = filpath("","","",APPLI)
  Call MACHINE(CHEMIN,MACHINE,FICHIER) From ORDSYS
  Call SYSTEME2(MACHINE,'lsadx -a'-APPLI-FICHIER,'',NBFIC,FIC) From ORDSYS
  NBFIC = min(NBFIC,dim(FIC))
  For I=1 To NBFIC
   If left$(FIC(I),4)="menu"
    Call COPIE(filpath("",FIC(I),"",APPLI),filpath("",FIC(I),"",HISDOS),STAT) From ORDSYS
   Endif
  Next I
 Else
  For FICHIER="menus","menu"+tolower(LANG)
   If filinfo(filpath("",FICHIER,"",APPLI),0)>0
    Call COPIE(filpath("",FICHIER,"",APPLI),filpath("",FICHIER,"",HISDOS),STAT) From ORDSYS
   Endif
  Next FICHIER
 Endif
Endif

End

##################################################################
# Génération de la table des menus
##################################################################

Subprog GENMENUS(APPLI,BATCH)
Value Char    APPLI
Value Integer BATCH
Local Char    FICDES(GDIMFIC)
Local Integer LIBEL

If !BATCH : Call TEMPON("V") From GESECRAN : Endif

Local File =APPLI+".ATABZON" [ATZ]
Local File =APPLI+".ATYPE"   [ATY]
Link [ATZ] With [ATY]CODTYP=[F:ATZ]CODTYP As [AATZ]
FICDES = filpath("","menus","",APPLI)
Openo FICDES , 0  Using [A_MN]
Iomode adxifs tab$ Using [A_MN]
Iomode adxirs chr$(13)+chr$(10) Using [A_MN]
Iomode adxium GUTF8 Using [A_MN]
For [AATZ]CODZONE Where [F:ATY]TYPTYP=1
 If [F:ATY]NOLIB<>0
  LIBEL = [F:ATY]NOLIB
 Else
  LIBEL = [F:ATZ]NOLIB
 Endif
 Wrseq [F:ATZ]CODFIC;[F:ATZ]CODZONE;LIBEL Using [A_MN]
Next AATZ
Openo Using [A_MN]

If !BATCH : Call TEMPOFF From GESECRAN : Endif

End

################################################################
Funprog FMTMNL(MENLOC)
Value Integer MENLOC
Local Char FMT(20)
If MENLOC<=9999
 FMT = "####"
Else
 FMT = "#####"
Endif
End FMT

##################################################################
$WRIMWEB
#    Le fichier a-t-il évolué par rapport au dernier stocké
REEC=1
NOMFIC=NOMFICI+"M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)+".xml"
If filinfo(NOMFIC, 7) > 0

  Openi NOMFIC Using [AX_I]
  Iomode adxifs "" Using [AX_I]
  Iomode adxirs chr$(10) Using [AX_I]
  Iomode adxium GUTF8 Using [AX_I]


#    Charge image disque de "l'ancien" menu
  Raz VREFM,NBREF
  Openi NOMFIC Using [AX_I]
  Iomode adxifs "" Using [AX_I]
  Iomode adxirs chr$(10) Using [AX_I]
  Iomode adxium GUTF8 Using [AX_I]
    Repeat
      Rdseq VALLM Using [AX_I]
      RGD=instr(1,VALLM,"<V>")
      RGF=instr(1,VALLM,"</V>")
      If RGD<>0 and RGF<>0 Then
        NBREF+=1
        #VREFM(NBREF)=mid$(VALLM,RGD+3,RGF-RGD-3)
        VREFM(NBREF)=seg$(VALLM,RGD+3,RGF-1)
      Endif
    Until fstat<>0
  Openi Using [AX_I]
#    Comparaison ancien / nouveau
  If NBREF=ICOU
    REEC=0
    For I=1 To ICOU
      If (VMENUL(I)<>VREFM(I)) : REEC=1 : Break 1 : Endif
    Next I
  Endif
Endif

#    Reecriture du fichier XML du menu si il y a des différences
If REEC=1
  Openo NOMFIC,0 Using [AX_M]
  Iomode adxifs "" Using [AX_M]
  Iomode adxirs chr$(10) Using [AX_M]
  Iomode adxium GUTF8 Using [AX_M]
  Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [AX_M]
  VALLM='<MENL NAM="M'+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)+'" NBZ="'+num$(ICOU)+'"'
  VALLM+=' LAN="'+LANGUE+'" TIM="'+WE_HORDAT+'" APP="'+GI_DOSS+'">'
  Wrseq VALLM Using [AX_M]

  For I=1 To ICOU
    Wrseq '  <V>'+VMENUL(I)+'</V>' Using [AX_M]
  Next I
  Wrseq "</MENL>" Using [AX_M]
  Openo Using [AX_M]
  Gosub WI_CREMENL From INTRUTILB
  If GTRACE<>"" : Call ECR_TRACE(mess(60,150,1)-num$(MCOU)-LANGUE,0) From GESECRAN : Endif
Endif




If GENJSON=1
# "1":["Non","Oui"],
  If NBWRJSON=0
    VALLM='"'+num$(MCOU)+'":['
  Else
    VALLM=',"'+num$(MCOU)+'":['
  Endif
  NBWRJSON+=1
  For I=1 To ICOU
# On remplace les " par des '  et les \ par des "/"
    VMENULNC(I)=ctrans(VMENULNC(I),'"',"'")
    VMENULNC(I)=ctrans(VMENULNC(I),'\',"/")
    VMENULNC(I)=ctrans(VMENULNC(I),chr$(9)," ")
    VMENULNC(I)=ctrans(VMENULNC(I),chr$(25),"'")
    VMENULNC(I)=ctrans(VMENULNC(I),chr$(9500),"'")
    VMENULNC(I)=ctrans(VMENULNC(I),chr$(10),"") :#SAM 122544
    VMENULNC(I)=ctrans(VMENULNC(I),chr$(13),"") :#SAM 122544


    VALLM+='"'+VMENULNC(I)+'"'
    If I=ICOU
      VALLM+="]"
    Else
      VALLM+=","
    Endif
    If len(VALLM)>110 and I<>ICOU : Wrseq VALLM  Using [JSON] : Raz VALLM : Endif
  Next I
  Wrseq VALLM  Using [JSON]
Endif






Return

#-----------------------------------------------------------------------
Subprog GENONEMENU(APPLI,MCOU,LANGUE)
Value Integer MCOU
Value Char APPLI,LANGUE

Local Char NOMFIC(200),NOMFICI(200),WE_HORDAT(14)
Local Char VALLM(200),LANTRAV
Local Integer ICOU,I

Call NAMEFIC(APPLI,"MENL",LANGUE,"",NOMFICI) From INTRUTILA
NOMFIC=NOMFICI+"M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)+".xml"
Call ENVVAR(WE_HORDAT) From INTRUTILA

Openo NOMFIC,0 Using [AX_M]
Iomode adxifs "" Using [AX_M]
Iomode adxirs chr$(10) Using [AX_M]
Iomode adxium GUTF8 Using [AX_M]
Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [AX_M]

#    Détermination de la valeur de ICOU  :   CC 31/03/2005  Bug 29506
Local File =APPLI+".APLSTD" [S_TD]
Filter [S_TD] Where LANCHP=MCOU and LANNUM>0 and LAN=GLANGUE
For [S_TD]
  ICOU+=1
Next
Filter [S_TD]

VALLM='<MENL NAM="M'+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)+'" NBZ="'+num$(ICOU)+'"'
VALLM+=' LAN="'+LANGUE+'" TIM="'+WE_HORDAT+'" APP="'+APPLI+'">'
Wrseq VALLM Using [AX_M]

LANTRAV=LANGUE
ICOU=0

$DEFMENWIN
Filter [S_TD] Where LANCHP=MCOU and LANNUM>0 and LAN=LANTRAV
For [S_TD]
  ICOU+=1
  VALLM=[F:S_TD]LANMES
  Gosub MVALC1 From INTRUTILA
  Wrseq '  <V>'+VALLM+'</V>' Using [AX_M]
Next
Filter [S_TD]

If ICOU=0
  If LANTRAV=GLANGUE
    Wrseq '  <V>'+" "+'</V>' Using [AX_M]
  Else
    LANTRAV=GLANGUE
    Goto DEFMENWIN
  Endif
  Call ECR_TRACE(mess(98,123,1)-num$(MCOU)-LANGUE,1) From GESECRAN
Endif

Wrseq "</MENL>" Using [AX_M]


Openo Using [AX_M]


If clalev([F:AEL])=0 : Local File =APPLI+".AELT" [AEL] : Endif

Local Integer TRCOU
If adxlog=0
 Trbegin [AEL]
 TRCOU=1
Endif

#Gosub WI_CREMENL From INTRUTILB
#  Crée l'enreg menu local MCOU dans la langue LANGUE
  Local Char WI_CMENL
  WI_CMENL="M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)
  Readlock [AEL]ELT0="MENL";WI_CMENL;LANGUE
  [F:AEL]ELTTYP="MENL"
  [F:AEL]ELT=WI_CMENL
  [F:AEL]ELTLAN=LANGUE
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  If fstat=0
    Rewrite [AEL]
  Else
    Write [AEL]
  Endif


If TRCOU=1 : Commit : Endif


End


####################################################################################
# Pour exécution validation des menus locaux dans les dossiers applicatifs
# lors intégration du PATCH
####################################################################################
Subprog PATCH(APPLI)
Value Char APPLI
If clalev([F:ADS])<=0 Local File ADOSSIER [ADS]:  Endif
Read [ADS]DOSSIER = APPLI
If fstat : End : Endif
#--------------------------------------------------------------------------------------------------#
# pas de test avec lock symbole car intégration patch donc personne ne travaille sur les dossiers
#--------------------------------------------------------------------------------------------------#
Call ECR_TRACE(mess(28,115,1)-mess(178,126,1)-APPLI,0) From GESECRAN : # Mise à jour menus locaux/dans le dossier
Call GENMENU(APPLI,1,1,GLANGUE) From GENMENULOC
End

