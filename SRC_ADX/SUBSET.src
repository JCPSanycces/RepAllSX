#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet SET
Call OBJET ("SET", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

############################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "LIENS"      : Gosub LIENS
    When "RAZDUP"     : Gosub RAZDUP
    When "RAZCRE"     : Gosub RAZCRE
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "ANNULE"     : Gosub ANNULE
    When "DEFLIG"     : Gosub DEFLIG
    When "LIENS_LIG"  : Gosub LIENS_LIG
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "INIMOD_LIG" : Gosub INIMOD_LIG
    When "VALLIG"     : Gosub VALLIG
    When Default
  Endcase
Return

############################################################################################################
$OUVRE
Global Char GCSETCPT(GLONANM)    # Code compteur pour le modèle de demande de service
Global Char GSR2CSETCPT(GLONANM) # Code compteur pour numéro de séquence.
Global Integer GMANCOU12         # FGR 20/12/2012 : X3SUIVI71937

  # FGR 10/07/2009 : X3SUIVI56412 : Fonctionnalité non disponible
  GERR = 1
  GMESSAGE = mess(634,177,1)
  OK = 0
  Return
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(8)
  #  GCSETCPT = [F:TCA]CODNUM(8)
  #  GSR2CSETCPT = [F:TCA]CODNUM(11)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

############################################################################################################
$FERME
  Kill GMANCOU12         # FGR 20/12/2012 : X3SUIVI71937
  Kill GSR2CSETCPT
  Kill GCSETCPT
Return

############################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

############################################################################################################
$RAZDUP
  #Calcul d'un code séquence temporaire
  Call SETSEQNUM([M:SET0]CRESEQ) From SUBSETB
  If GERR Then
    Call RAZMAC From SUBSETB
    Grizo [M:SET4]15
  Endif
  #Duplication des composants concerné
  Call DUPLICPN([M:SET0]SETNUM, [M:SET0]CRESEQ) From SUBSETB
  Affzo [M:SET4]
Return

############################################################################################################
$RAZCRE
Local Char SZREAC
Local Integer IREAC

  #Calcul d'un code séquence temporaire
  Call SETSEQNUM([M:SET0]CRESEQ) From SUBSETB
  If GERR Then
    Grizo [M:SET4]15
  Endif
  [M:SET0]TPLCON = 2
  [M:SET0]TPLSVC = 2
  #Infos relatives au parc concerné
  [M:SET4]TYPMAC = 1
  [M:SET4]MACFLT = ""
  [M:SET4]MACFLTINT = 2
  Grizo [M:SET4]MACFLT
  Grizo [M:SET4]MACFLTINT
  Actzo [M:SET4]10
  Actzo [M:SET4]15
  [M:SET3]ASS = 1
  Call DEFVALADI(428, [M:SET3]PIOLEV) From CRMUTIL140
  Call PARAM("", "QREAC", SZREAC) From ADOVAL
  IREAC = val(SZREAC)
  [M:SET3]LTIDAY = IREAC
  ######################################################
  #Affichage des icônes
  ######################################################
  Gosub DISPICON From SUBSETB
  Affzo [M:SET0]
  Affzo [M:SET1]
  Affzo [M:SET3]
  Affzo [M:SET4]
Return

############################################################################################################
$LIENS
  [M:SET0]CRESEQ = ""
  ######################################################
  #Lecture du clob description complète
  ######################################################
  Gosub LOADHD1 From SUBSETB
  ######################################################
  # Affichage de la famille de compétence
  ######################################################
  If [M:SET1]PBL = "" Then
    [M:SET1]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:SET1]PBL
    If fstat Then
      [M:SET1]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SET1]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SET1]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  ######################################################
  #Chargement du parc
  ######################################################
  If [M:SET4]TYPMAC = 0 Then
    [M:SET4]TYPMAC = 1
  Endif
  If [M:SET4]TYPMAC = 1 Then
    [M:SET4]MACFLT = ""
    [M:SET4]MACFLTINT = 2
    Grizo [M:SET4]MACFLT
    Grizo [M:SET4]MACFLTINT
    Actzo [M:SET4]10
    Actzo [M:SET4]15
  Else
    Actzo [M:SET4]MACFLT
    Actzo [M:SET4]MACFLTINT
    Grizo [M:SET4]10
    Grizo [M:SET4]15
  Endif
  Gosub SET4MAC
  ######################################################
  #Chargement des consommations
  ######################################################
  Call LOADHDT([M:SET0]SETNUM) From SUBSETB
  ######################################################
  #Affichage des icônes
  ######################################################
  Gosub DISPICON From SUBSETB
  Affzo [M:SET4]
  Affzo [M:SET1]
Return

############################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:SET0]SALFCY, 12, 8, GSOCIETE, GCURLEG, GCSETCPT, GMANCOU) From CRM_UTIL               # FGR 20/05/2015 : X3SUIVI107775
  Call READ_COUNTER([M:SET0]SALFCY, 12, 11, GSOCIETE, GCURLEG, GSR2CSETCPT, GMANCOU12) From CRM_UTIL         # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", [M:SET0]SALFCY, GCSETCPT, date$, "", [M:SET0]SETNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:SET]SETNUM = [M:SET0]SETNUM
      Affzo [M:SET0]SETNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:SET]TYPFULDES = "SET"
  [F:SET]NUMFULDES = [M:SET0]SETNUM
  [M:SET1]TYPFULDES = "SET"
  [M:SET1]NUMFULDES = [M:SET0]SETNUM
Return

############################################################################################################
$VERIF_CRE
Return

############################################################################################################
$VERIF_MOD
Return

############################################################################################################
$CREATION
  #Enregistrement du CLOB description complète
  Gosub SAVEHD1 From SUBSETB
  If GOK < 1 Then
    Return
  Endif
Return

############################################################################################################
$MODIF
  #Enregistrement du CLOB description complète
  Gosub SAVEHD1 From SUBSETB
  If GOK < 1 Then
    Return
  Endif
Return

############################################################################################################
$APRES_CRE
  #Enregistrement du parc concerné
  Call SAVECPN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 1) From SUBSETB
  Call SAVEMAC([M:SET0]SETNUM) From SUBSETB
  Call SAVECPNWKEY([M:SET0]CRESEQ, [M:SET0]SETNUM) From SUBSETB
  Gosub SET4MAC
  #Enregistrement des consommations
  Call SAVEHDT([M:SET0]SETNUM) From SUBSETB
  Call LOADHDT([M:SET0]SETNUM) From SUBSETB
  ######################################################
  #Affichage des icônes
  ######################################################
  Gosub DISPICON From SUBSETB
  [M:SET0]CRESEQ = ""
  Affzo [M:SET1]
Return

############################################################################################################
$APRES_MOD
  #Enregistrement du parc concerné
  Call SAVECPN([M:SET0]SETNUM, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 0) From SUBSETB
  Call SAVEMAC([M:SET0]SETNUM) From SUBSETB
  Gosub SET4MAC
  #Enregistrement des consommations
  Call SAVEHDT([M:SET0]SETNUM) From SUBSETB
  Call LOADHDT([M:SET0]SETNUM) From SUBSETB
  [M:SET0]CRESEQ = ""
  ######################################################
  #Affichage des icônes
  ######################################################
  Gosub DISPICON From SUBSETB
  Affzo [M:SET1]
Return

############################################################################################################
$ANNULE
  #Suppression du clob description complète de la demande
  Gosub DELHD1 From SUBSETB
  If GOK < 1 Then
    Return
  Endif
Return

############################################################################################################
$DEFLIG
Return

############################################################################################################
$LIENS_LIG
Return

############################################################################################################
$INICRE_LIG
Return

############################################################################################################
$INIMOD_LIG
Return

############################################################################################################
$VALLIG
Return

############################################################################################################
######################################################
# Chargement du parc
######################################################
$SET4MAC
  Call LOADMAC([M:SET0]SETNUM) From SUBSETB
  If [M:SET4]NBMAC Then
    Call LOADCPN([M:SET0]SETNUM, [M:SET4]ITMREF(0), 0) From SUBSETB
  Else
    Raz [M:SET4]NBCPN
    Raz [M:SET4]CPNITM
    Raz [M:SET4]CPNITMDES
    Raz [M:SET4]CPNQTY
    Raz [M:SET4]CPNSEQ
  Endif
  [M:SET4]PRESET4NOL = 0
Return

############################################################################################################
####################################################################
# Sous-programmes
####################################################################
Subprog AM_TYPMAC(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:SET4]MACFLTINT = 2
    Actzo [M:SET4]MACFLT
    Actzo [M:SET4]MACFLTINT
    Call RAZMAC From SUBSETB
    Grizo [M:SET4]10
    Grizo [M:SET4]15
  Else
    [M:SET4]MACFLTINT = 2
    [M:SET4]MACFLT = ""
    Grizo [M:SET4]MACFLT
    Grizo [M:SET4]MACFLTINT
    Actzo [M:SET4]10
    Actzo [M:SET4]15
  Endif
  [M:SET4]TYPMAC = VALEUR
  Affzo [M:SET4]
End

##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR

  SZVALEUR = VALEUR
  Read [ITM]ITM0=VALEUR
  If fstat Then
    [M:SET4]ITMDES(nolign-1) = VALEUR
  Else
    #Call LECTEXTRA([M:SET4]ITMDES(nolign-1), "ITMMASTER", "DES1AXX", SZVALEUR, "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SET4]ITMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Endif
  [M:SET4]ITMREF(nolign-1) = VALEUR
  Affzo [M:SET4]ITMREF(nolign-1), ITMDES(nolign-1)
End

##########################################################################
Subprog AS_HDTTYP(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
  GMENLOC(5) = 1
  If [M:SET2]HDTITM(nolign-1) <> "" Then
    End
  Endif
  If GDEFHDTTYP < 1 Then
    VALEUR = 2
    End
  Elsif GDEFHDTTYP > 3 Then
    VALEUR = 2
    End
  Endif
  VALEUR = GDEFHDTTYP + 1
End

##########################################################################
Subprog AM_TPLNAM(VALEUR)
Variable Char    VALEUR()

  [M:SET0]TPLNAM = VALEUR
  If [M:SET1]TTR = "" Then
    [M:SET1]TTR = VALEUR
  Endif
  Affzo [M:SET0]TPLNAM
  Affzo [M:SET1]TTR
End

##########################################################################
Subprog AS_NBMAC

  If nolign >= dim([M:SET4]ITMREF) Then
    End
  Endif
  If nolign > 0 Then
    If GREP = "C" Then
      Call SAVECPN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 1) From SUBSETB
      Call LOADCPN([M:SET0]CRESEQ, [M:SET4]ITMREF(nolign-1), 1) From SUBSETB
    Elsif GREP = "D" Then
      Call SAVECPN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 1) From SUBSETB
      Call LOADCPN([M:SET0]CRESEQ, [M:SET4]ITMREF(nolign-1), 1) From SUBSETB
    Else
      Call SAVECPN([M:SET0]SETNUM, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 0) From SUBSETB
      Call LOADCPN([M:SET0]SETNUM, [M:SET4]ITMREF(nolign-1), 0) From SUBSETB
    Endif
    If [M:SET4]PRESET4NOL <> nolign-1 Then
      [M:SET4]NBMACSEL([M:SET4]PRESET4NOL) = ""
      [M:SET4]NBMACSEL(nolign-1) = "->"
      [M:SET4]PRESET4NOL = nolign-1
    Endif
  Endif
  Affzo [M:SET4]
End

##########################################################################
Subprog C_NBMAC

  If nolign >= dim([M:SET4]ITMREF) Then
    End
  Endif

Local Integer NUMLIGNE

  If status = 65 Then
    #Effacement d'une seule ligne
    Read [SEM] SEM0 = [M:SET0]SETNUM;[M:SET4]ITMREF(nolign-1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SEM], [SEN]
      Delete [SEM] Curr
      If fstat Then
        Rollback
        Affzo [M:SET4]
        End
      Endif
      If GREP = "C" Then
        Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET4]ITMREF(nolign-1) and [F:SEN]TPYFLG = 1
        If fstat Then
          Rollback
          Affzo [M:SET4]
          End
        Endif
      Elsif GREP = "D" Then
        Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET4]ITMREF(nolign-1) and [F:SEN]TPYFLG = 1
        If fstat Then
          Rollback
          Affzo [M:SET4]
          End
        Endif
      Else
        Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]SETNUM and [F:SEN]ITMREF = [M:SET4]ITMREF(nolign-1) and [F:SEN]TPYFLG = 0
        If fstat Then
          Rollback
          Affzo [M:SET4]
          End
        Endif
      Endif
      Commit
      Raz [M:SET4]NBCPN
      Raz [M:SET4]CPNITM
      Raz [M:SET4]CPNITMDES
      Raz [M:SET4]CPNQTY
      Raz [M:SET4]CPNSEQ
    Endif
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      Read [SEM]SEM0=[M:SET0]SETNUM;[M:SET4]ITMREF(NUMLIGNE)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SEM], [SEN]
        Delete [SEM]Curr
        If fstat Then
          Rollback
          Affzo [M:SET4]
          Break
        Endif
        If GREP = "C" Then
          Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET4]ITMREF(NUMLIGNE) and [F:SEN]TPYFLG = 1
          If fstat Then
            Rollback
            Affzo [M:SET4]
            Break
          Endif
        Elsif GREP = "D" Then
          Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET4]ITMREF(NUMLIGNE) and [F:SEN]TPYFLG = 1
          If fstat Then
            Rollback
            Affzo [M:SET4]
            Break
          Endif
        Else
          Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]SETNUM and [F:SEN]ITMREF = [M:SET4]ITMREF(NUMLIGNE) and [F:SEN]TPYFLG = 0
          If fstat Then
            Rollback
            Affzo [M:SET4]
            Break
          Endif
        Endif
        Commit
        Raz [M:SET4]NBCPN
        Raz [M:SET4]CPNITM
        Raz [M:SET4]CPNITMDES
        Raz [M:SET4]CPNQTY
        Raz [M:SET4]CPNSEQ
      Endif
    Next
  Endif
  If nolign > 0 Then
    If GREP = "C" Then
      Call SAVECPN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 1) From SUBSETB
      Call LOADCPN([M:SET0]CRESEQ, [M:SET4]ITMREF(nolign-1), 1) From SUBSETB
    Elsif GREP = "D" Then
      Call SAVECPN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 1) From SUBSETB
      Call LOADCPN([M:SET0]CRESEQ, [M:SET4]ITMREF(nolign-1), 1) From SUBSETB
    Else
      Call SAVECPN([M:SET0]SETNUM, [M:SET4]ITMREF([M:SET4]PRESET4NOL), 0) From SUBSETB
      Call LOADCPN([M:SET0]SETNUM, [M:SET4]ITMREF(nolign-1), 0) From SUBSETB
    Endif
    If [M:SET4]PRESET4NOL <> nolign-1 Then
      [M:SET4]NBMACSEL([M:SET4]PRESET4NOL) = ""
      [M:SET4]NBMACSEL(nolign-1) = "->"
      [M:SET4]PRESET4NOL = nolign-1
    Endif
  Endif
  Affzo [M:SET4]
End

##########################################################################
Subprog APRES_NBCPN
Local Integer INOL

  INOL = nolign-1
  If nolign > 0 Then
    If GREP = "C" Then
      Call SAVECPNLIN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), [M:SET4]CPNITM(INOL), 1, INOL) From SUBSETB
    Elsif GREP = "D" Then
      Call SAVECPNLIN([M:SET0]CRESEQ, [M:SET4]ITMREF([M:SET4]PRESET4NOL), [M:SET4]CPNITM(INOL), 1, INOL) From SUBSETB
    Else
      Call SAVECPNLIN([M:SET0]SETNUM, [M:SET4]ITMREF([M:SET4]PRESET4NOL), [M:SET4]CPNITM(INOL), 0, INOL) From SUBSETB
    Endif
  Endif
End

##########################################################################
Subprog AM_CPNITM(VALEUR)
Variable Char    VALEUR()

Local Char SZITMREF(GLONITM)

  SZITMREF = [M:SET4]ITMREF([M:SET4]PRESET4NOL)
  #Obtention de l'alternative nomenclature
  If SZITMREF <> "" Then
    Read [ITM]ITM0=SZITMREF
    If !fstat Then
      #Call LECTEXTRA([M:SET4]CPNITMDES(nolign-1), "ITMMASTER", "DES1AXX", VALEUR, "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SET4]CPNITMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      If [M:SET4]CPNSEQ(nolign-1) = 0 Then
        #Recherche d'un numero de séquence
        If [F:ITM]ALTBOMHDK > 0 Then
          Filter [BOD] Where [F:BOD]ITMREF = SZITMREF and [F:BOD]BOMALT = [F:ITM]ALTBOMHDK and [F:BOD]BOMALTTYP = 1 and [F:BOD]CPNITMREF = VALEUR Order By [F:BOD]BOMSEQ Asc
          For [BOD]
            [M:SET4]CPNSEQ(nolign-1) = [F:BOD]BOMSEQ
            Break
          Next
          Filter [BOD]
        Endif
      Endif
    Endif
  Endif
  [M:SET4]CPNITM(nolign-1) = VALEUR
  Affzo [M:SET4]
End

##########################################################################
Subprog IB_MACFLT

  Raz GBOUT1
  Raz GBOUT2
  Call TEXTE(19061, GBOUT1) From OBJDIV      #Ciblages
  If [M:SET4]MACFLT <> "" Then
    Read [MQR]MQR0=[M:SET4]MACFLT
    If !fstat Then
      If [F:MQR]QURNAM = "" Then
        Call TEXTE(6425, GBOUT2) From OBJDIV      #Critères
      Else
        GBOUT2 = [F:MQR]QURNAM
      Endif
    Endif
  Endif
End

##########################################################################
Subprog C_PBL(VALEUR)
Variable Char    VALEUR()

  Gosub CTLSHORTCUT From SUBPBLB
End

##########################################################################
Subprog AM_PBL(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SET1]PBLCLA = ""
  Else
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:SET1]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SET1]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SET1]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  [M:SET1]PBL = VALEUR
  Affzo [M:SET1]PBL, PBLCLA
End

##########################################################################
Subprog IB_FULDES
#Local Char SZDESCTL(GLONCLT)

  Raz GBOUT1
  # FGR 06/08/2014 : X3SUIVI95250
  #  Raz SZDESCTL
  #  Setlob SZDESCTL With [M:SET1]FULDES
  #  If SZDESCTL <> "" Then
  #    If len(SZDESCTL) > GLONCLE Then
  #      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
  #    Endif
  #  Endif
  If [M:SET1]FULDES <> "" Then
    If len([M:SET1]FULDES) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################
Subprog AM_FULDES (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:SET1]FULDES, VALEUR, [M:SET1]DES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:SET1]FULDES = VALEUR
  Gosub DISPICON From SUBSETB
  Affzo [M:SET1]
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SET4) 12/04/2005 11:47:00 (LSE)
######################################################################################
Subprog C_CPNITM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  If [M:SET4]ITMREF([M:SET4]PRESET4NOL) = ""  Then
    #Un article doit impérativement être sélectionné avant de procéder à la saisie d'un composant.
    GMESSAGE = mess(203,177,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    End
  Else
    Read [ITM]ITM0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  #Vérifie si un code identique n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:SET4]CPNITM)-1
    If I <> nolign-1 Then
      If [M:SET4]CPNITM(I) = VALEUR Then
        GMESSAGE = mess(268,182,1) - num$(I+1)   #Ce composant a déjà été saisi en ligne n°
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Endif
End

##########################################################################
Subprog IB_HDTMACSET

  If [M:SET4]TYPMAC = 2 Then
    #Parc filtré
    Raz GBOUT3
  Else
    Raz GBOUTS
    Raz GBOUT1
  Endif
End

##########################################################################
Subprog C_HDTMACSET(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif
  #si type parc filtre on ne verifie pas l'appartenance
  If [M:SET4]TYPMAC = 2  Then
    End
  Endif

Local Integer ITER
Local Integer IFOUND

  IFOUND = 0
  #Vérifie que le parc sélectionné provient de l'onglet parc concerné.
  For ITER = 0 To [M:SET4]NBMAC-1
    If [M:SET4]ITMREF(ITER) = VALEUR Then
      IFOUND = 1
      Break
    Endif
  Next
  If !IFOUND Then
    #Le parc indiqué ne provient pas de l'onglet Parc concerné. Saisie refusée.
    GMESSAGE = mess(200,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################
Subprog AM_HDTMACSET(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If !fstat Then
    # FGR 05/10/2009 : X3SUIVI58372
    #Call GET_ATEXTRA("ITMMASTER","DES1AXX","",HDTDES(nolign-1)) From TRTX3TEX
    Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [F:ITM]ITMREF, HDTDES(nolign-1), "[F:ITM]") From TRTX3
  Endif
End

##########################################################################
Subprog AS_HDTCPN(VALEUR)
Variable Char    VALEUR()

  If [M:SET2]HDTMACSET(nolign-1) = "" Then
    mkstat = 2
  Endif
End

##########################################################################
Subprog C_HDTCPN(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif

Local Integer IFOUND

  IFOUND = 0
  #Vérifie que le parc sélectionné provient de l'onglet composants concernés.
  If GREP = "C" Then
    Filter [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET2]HDTMACSET(nolign-1) and [F:SEN]TPYFLG = 1
    For [SEN]
      If [F:SEN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SEN]
  Elsif GREP = "D" Then
    Filter [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]ITMREF = [M:SET2]HDTMACSET(nolign-1) and [F:SEN]TPYFLG = 1
    For [SEN]
      If [F:SEN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SEN]
  Else
    Filter [SEN] Where [F:SEN]SETNUM = [M:SET0]SETNUM and [F:SEN]ITMREF = [M:SET2]HDTMACSET(nolign-1) and [F:SEN]TPYFLG = 0
    For [SEN]
      If [F:SEN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SEN]
  Endif
  If !IFOUND Then
    #Le composant indiqué ne provient pas de l'onglet Parc concerné. Saisie refusée.
    GMESSAGE = mess(201,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################
Subprog AM_HDTTYP(VALEUR)
Variable Integer VALEUR

  [M:SET2]HDTITM(nolign-1) = ""
  [M:SET2]HDTUOM(nolign-1) = ""
  [M:SET2]HDTQTY(nolign-1) = 0
  If GCLOINV = 2 Then
    [M:SET2]HDTINVMOD(nolign-1) = 2
  Else
    [M:SET2]HDTINVMOD(nolign-1) = 1
  Endif
  [M:SET2]HDTTYP(nolign-1) = VALEUR
  Affzo [M:SET2]HDTITM(nolign-1), HDTUOM(nolign-1), HDTQTY(nolign-1), HDTINVMOD(nolign-1)
End

##########################################################################
Subprog IB_HDTITM

  Raz GBOUT3
  If [M:SET2]HDTTYP(nolign-1) = 2 Then
    Call TEXTE(17614, GBOUT3) From OBJDIV      #Stocks articles
  Endif
End

##########################################################################
Subprog AS_HDTITM(VALEUR)
Variable Char    VALEUR()
End

######################################################################################################
Subprog C_HDTITM(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Else
    If [F:ITM]HDKITMTYP <> [M:SET2]HDTTYP(nolign-1) Then
      #Cet article ne correspond au type indiqué. Saisie refusée.
      GMESSAGE = mess(198,182,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  IITFOK = 1
End

########################################################################################################
Subprog AM_HDTITM(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Char    SECTION
Local Integer INOL

  INOL = nolign-1
  IERRINF = 0
  #On complète le parc concerné si besoin
  If [M:SET2]HDTMACSET(nolign-1) = "" Then
    Gosub ADDHDTITM From SUBSETB
  Endif
  Read [ITM]ITM0=VALEUR
  If fstat Then
    [M:SET2]HDTUOM(nolign-1) = ""
  Else
    [M:SET2]HDTUOM(nolign-1) = [F:ITM]SAU
  Endif
  [M:SET2]HDTQTY(nolign-1) = 0
  If GCLOINV = 2 Then
    [M:SET2]HDTINVMOD(nolign-1) = 2
  Else
    [M:SET2]HDTINVMOD(nolign-1) = 1
  Endif
  Affzo [M:SET2]HDTUOM(nolign-1), HDTQTY(nolign-1)
End

############################################################################################################
Subprog C_HDTQTY(VALEUR)
Variable Decimal VALEUR

  If VALEUR <= 0 Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    End
  Endif
End

