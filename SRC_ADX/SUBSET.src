Subprog AS_HDTUOM(VALEUR)
Variable Char    VALEUR()
End

############################################################################################################
Subprog C_HDTUOM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
  Endif
End

