#<AdxTL>@(#)2.0.0.0 $Revision$
#*********************************************************************
#
#                    GESTION DES  SUBVENTIONS
#
#*********************************************************************
#    Création V5
#    MDJ - 19.12.2007
#*********************************************************************
#  Modification
# Issue X3-109499 -2018-09-20 MDJ : RD - Events Icon in header
# MDJ   05.04.2016 114673       Creation of a subsidy without reference
# MDJ   14.09.2015 FQ111003     Suite-FQ110083 nom champ erroné
# MDJ   07.08.2015 FQ110083     Projet investissement sur plusieurs société, à tort
# CBO   14.10.2013 FQ104534     Event not created when subsidies amount are entrered
# CBO   14.10.2013 FQ-91644     Appel de PARAM from ADOVAL
# GLE   10.09.2012 FQ 84403     Remise à zéro du montant de subvention si type de subvention à "Forfait"
# CBO   16.08.2012 FQ 83314     contrôle des axes en création
# CBO   22.06.2012 FQ 82709     contrôle (général) des axes analytiques
# MDJ   29.05.2012 Fq 82221     Montants subvention non-alimentés dans EVTS si type subvention= % ou plafond
# MDJ   22.12.2010 Fq 70141     Vérification de sources (interne)
# MDJ   19.04.2010 FQ 64122     TEMPO_EVT : étiquette supprimée en V5..
# GBO   27.01.2010 FQ61803      Faire disparaître le menu contextuel "paramétrage société" si le paramètre DBG est à non
#*********************************************************************
Raz GPILOBJ
Call OBJET("GRT",GBIDC1,GBIDC2) From GOBJET
End
#********************************************************************
$ACTION
 #Infbox "ACTION = "-num$(ACTION)

Case ACTION
   When "SETTRANS"       : Local Integer LGRTTRS : Gosub SET_TRS_PARM From SUBTSH
   When "OUVRE"          : Gosub OUVRE
   When "OUVRE_BOITE"    : Gosub OUVRE_BOITE
   When "RAZCRE"         : Gosub RAZCRE
   When "RAZDUP"         : Gosub RAZDUP
   When "SETBOUT"        : Gosub SETBOUT
   When "EXEBOUT"        : Gosub EXEBOUT
   When "VERIF_CRE"      : Gosub VERIF_CRE
   When "INICRE"         : Gosub INICRE
   When "APRES_CRE"      : Gosub APRES_CRE
   When "CREATION"       : Gosub CREATION
   When "DEVERROU"       : Gosub DEVERROU
   When "LIENS"          : Gosub LIENS
   When "TIROIR"         : Gosub TIROIR
   When "VERIF_MOD"      : Gosub VERIF_MOD
   When "AVANT_MODFIC"   : Gosub AVANT_MODFIC
   When "MODIF"          : Gosub MODIF
   When "APRES_MOD"      : Gosub APRES_MOD
   When "APRES_MODIF"    : Gosub APRES_MODIF
   When "APRES_CHOI"     : Gosub APRES_CHOI
   When "AV_ANNULE"      : Gosub AV_ANNULE
   When "ANNULE"         : Gosub ANNULE
   When "FERME"          : Gosub FERME
   When "SEL_TABLE"      : Gosub SEL_PLNINV

   When Default
Endcase

Return
#********************************************************************
$OUVRE

  # Appel à la fonction de gestion des zones libres
  Gosub OUVRE From SUBFRZ
  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

  # Numérotation automatique
  Local  Integer   STAT

  Global Integer  GDATAMOD  : GDATAMOD  = G_NON   : # donnée subvention modifiée
  Global Integer  GCASHMOD  : GCASHMOD  = G_NON   : # montant encaissement modifié
  Global Char     GREASON   : GREASON   = ""      : # Motif pour événements
  Global Decimal  G_GRAAMT                        : # Ecart montant subvention
  Global Decimal  G_MAXGRAAMT                     : # Ecart montant plafond subvention
  Global Decimal  G_INVGRAAMT                     : # Ecart montant immobilisé subventionné
  Global Decimal  G_REAGRAAMT                     : # Ecart montant réalisé subventionné
  Global Decimal  G_CRBGRAAMT                     : # Ecart montant réintégré dans l'exercice
  Global Decimal  G_CRBGRACUM                     : # Ecart montant cumulé réintégré
  Global Decimal  G_CASHAMT                       : # Ecart montant versé
  Global Date     G_CASHDAT                       : # Date d'effet encaissement
  Global Integer  G_NBAXE                         : #Fq-79815 Nb d'axes à saisir (max 20)

  # Déclaration des tables
  If clalev([F:GRT])=0  : Local File GRANTS      [GRT] : Endif  # table des subventions
  If clalev([F:GRTW])=0 : Local File GRANTS      [GRTW]: Endif  # table des subventions
  If clalev([F:CAS])=0  : Local File CASHING     [CAS] : Endif  # table des encaissements
  If clalev([F:TCA])=0  : Local File TABCOUAFF   [TCA] : Endif  # table des affectations de compteurs
  If clalev([F:ADI])=0  : Local File ATABDIV     [ADI] : Endif  # table des tables diverses
  If clalev([F:CPY])=0  : Local File COMPANY     [CPY] : Endif  # table sociétés
  If clalev([F:FCY])=0  : Local File FACILITY    [FCY] : Endif  # table des établissements/sites
  If clalev([F:CNX])=0  : Local File CONTEXT     [CNX] : Endif  # table des contextes
  If clalev([F:DEP])=0  : Local File DEPREC      [DEP] : Endif  # table des plans d'amortissements
  If clalev([F:FAS])=0  : Local File FXDASSETS   [FAS] : Endif  # table des plans des biens comptables
  If clalev([F:CCE])=0  : Local File CACCE       [CCE] : Endif  # table des sections analytiques
  If clalev([F:E61])=0  : Local File EGRTCASH    [E61] : Endif  # table des événements - Versement subvention
  If clalev([F:E62])=0  : Local File EGRTCRT     [E62] : Endif  # table des événements - Création subvention
  If clalev([F:E63])=0  : Local File EGRTCRB     [E63] : Endif  # table des événements - Réintégration subvention

#-----------------------------------------------------------------------------------#
# Si on vient par tunnel il faut sauvegarder les variables globales                 #
#-----------------------------------------------------------------------------------#
If TUNNEL : Gosub SAUVE_GLOBAL_SV   From GLOBIMM   : Endif
If TUNNEL : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif

Return
#-------------------------------------------------------------------------------
$OUVRE_BOITE

  Gosub DECLARE_TIROIRS

Return
#-------------------------------------------------------------------------------
$DECLARE_TIROIRS

  # Récupération des positions des tiroirs en fonction de leurs noms et
  # affectation dans des variables locales
  Local Char LTI_DEPLIEE : LTI_DEPLIEE = 'GAU_CHE'+num$(find('LOS',OBJLIS(1..10))) : # Dépenses liées

Return
#-------------------------------------------------------------------------------
$TIROIR

If currbox = LTI_DEPLIEE
  # Dépenses liées
  Raz CRITERE
  Gosub FILGAUCHE
  If (dim(FILTREG) > 0) Then : FILTREG = 1 : Endif
  Gosub REMPLIT
Endif

Return
#-------------------------------------------------------------------------------
$REMPLIT

  Case currbox
    When "GAU_CHE1" : Gosub REMPLIT_1 From WGOGRT
  Endcase

Return
#-------------------------------------------------------------------------------
$FILGAUCHE
Local Integer N_I, N_E
Local Char LCOND(250)

If currbox = LTI_DEPLIEE
  # Dépenses regroupées
  Raz FILGAUSUP
  FILGAUSUP(0) = "PLNINV=[M:GRT1]INVPLN and FLGGRA = G_OUI and CPY = [M:GRT0]CPY"
Endif

Return
#=====================================================================
$APRES_CHOI
Local Integer OK

  If currbox = LTI_DEPLIEE Then
    # Si on est sur le tiroir des dépenses liées
    # pour le moment je vais le mettre sur le click, mais le top serait sur le double-clic (GSTALF2),
    # mais il ça ne fonctionne pas sur ce type de liste !
    Case REPONSE
      When GSTALFT
        If dim([M:LOF0]CPY) < 0 Then
          # L'écran des dépenses n'est pas ouvert : on peut repartir dessus
          Local Char LFGRFGR
          Call OBJET_CHAR(LFGRFGR, "LOF", [F:LOF]CODLOF+"@"+num$([F:LOF]LINLOF)) From GOBJET
        Else
          # L'écran des dépenses est ouvert, on ne peut pas faire un tunnel dans ce cas,
          # y a un message d'erreur de X3
          GERR=1: GMESSAGE = mess(41,GML_MSGFAS, 1): OK= 0: Return
        Endif
    Endcase
  Endif
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2

Return
#********************************************************************
# attribution des valeurs par défaut et rafraîchissement des écrans
#********************************************************************
$RAZCRE

  Raz [M:GRT0]
  Raz [M:GRT1]
  Raz [M:GRT2]
  Raz [M:GRT3]

  # le Affzo déclenche le Call ACTION_FCY From GLOFCYCPY
  [M:GRT0]FCY = GCOUSIT

  Affzo [M:GRT0]
  Affzo [M:GRT1]
  Affzo [M:GRT2]
  Affzo [M:GRT3]

  Call LOAD_FASPARCPY([M:GRT0]CPY, "", G_NON, ERR) From GLOFCYCPY
  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:GRT]","[M:FPC]","[M:GRT2]",LNBRCCE) From GLOBIENSANA
  [M:GRT2]NBRCCE=LNBRCCE
  Affzo [M:GRT2]
  G_NBAXE = LNBRCCE  #Fq-79815

  GCASHMOD = G_NON # FQ104534

  Gosub CHARGE_PLAN

Return
#********************************************************************
$RAZDUP

  [M:GRT0]DESADL = ""
  Raz [M:GRT2]
  Raz [M:GRT3]

  Affzo [M:GRT0]
  Affzo [M:GRT1]
  Affzo [M:GRT2]
  Affzo [M:GRT3]

  GCASHMOD = G_NON # FQ104534

  Gosub CHARGE_PLAN

Return
#-------------------------------------------------------------------------------
$VERROU
Local Integer OK
Local Char LLOCK(200)

  # Pour interdire toute modification sur l'objet
  LLOCK = func GLOBIENS.GET_KEY_GRANT ([M:GRT0]GRAREF)
  If func GLOBIENS.IS_SYMBOLE_LOCKED ("GRT", [M:GRT0]CPY, LLOCK) = 0 Then
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    OK = 0
  Else
    # sinon on gère à la main le verrou identifiant+société pour permettre le contrôle
    # de tester si le lockage de la table pour la société est possible
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("GRT", [M:GRT0]CPY, LLOCK, 0) = 0 Then
      # on teste rien, normalement ça marche puisqu'on a pu locker l'enregistrement
      # et que la société n'est pas lockée
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$DEVERROU

#Local Char LLOCK(200)
  LLOCK = func GLOBIENS.GET_KEY_GRANT ([M:GRT0]GRAREF)
  Call UNLOCK_SYMBOLE_CPY ("GRT", [M:GRT0]CPY, LLOCK) From GLOBIENS

Return

#********************************************************************
$LIENS

  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:GRT]CPY,"",G_NON,ERR) From GLOFCYCPY

  GCASHMOD = G_NON # FQ104534

#* Lecture des encaissements
    nolign = 1

    Filter [CAS] Where (CPY =[M:GRT0]CPY and GRAREF=[M:GRT0]GRAREF) Order By CASHDAT Desc
      For [CAS]
         [M:GRT3] = [F:CAS]
         nolign += 1
      Next
      [M:GRT3]NBCASH = nolign-1
    Filter [CAS]

   Affzo [M:GRT3]

  For nolign = 1 To [M:GRT3]NBCASH
     If  [M:GRT3]EVTFLG(nolign-1)=G_OUI
        Diszo [M:GRT3]CASHAMT(nolign-1)
        Diszo [M:GRT3]CASHDAT(nolign-1)
     Endif
  Next nolign

  Gosub RECALCUL_TOT

  Affzo[M:GRT1]TOBERECAMT

# Valeurs des variables globales en fonction du site
Call  ACTION_FCY  ([M:GRT0]FCY, [M:GRT0]CPY) From GLOFCYCPY
#*********************************************************************
# on peut au lieu du filter faire un sorta en sortie de boucle
# quelle est la solution la + performante ???
#
#   Sorta [M]NBCASH [M]NBCASH  Order By [M:GRT3]CASHDAT(indice) Desc
#*********************************************************************
      Case [M:GRT1]GRASTA
         When GVML_SUBIACH          : Gosub DISZO_GRIZO
         When GVML_SUBANNU           : Gosub DISZO_GRIZO
         When GVML_SUBTOTR          : Gosub DISZO_GRIZO
         When Default
           Affzo [M:GRT0]    :    Actzo [M:GRT0]
           Affzo [M:GRT1]    :    Actzo [M:GRT1]
           Affzo [M:GRT2]    :    Actzo [M:GRT2]
           Affzo [M:GRT3]
      Endcase

    If ([M:GRT1]GRATYP <> GVML_TSUBPRC and [M:GRT1]GRATYP <> GVML_TSUBPLF )
        Raz [M:GRT1]INVGRARAT,MAXGRAAMT
        Diszo [M:GRT1]INVGRARAT,MAXGRAAMT
        Actzo [M:GRT1]GRAAMT
        Affzo [M:GRT1]GRAAMT
    Else
        If [M:GRT1]GRAAMT > 0
            Affzo [M:GRT1]GRAAMT
            Actzo [M:GRT1]GRAAMT
        Else
            Diszo [M:GRT1]GRAAMT
        Endif
    Endif

    If [M:GRT1]GRATYP <> GVML_TSUBPLF
        Raz [M:GRT1]MAXGRAAMT
        Diszo [M:GRT1]MAXGRAAMT
    Else
        Actzo [M:GRT1]MAXGRAAMT
    Endif

    Diszo [M:GRT1]INVGRAAMT
    Diszo [M:GRT1]REAGRAAMT
    Diszo [M:GRT1]CRBGRAAMT
    Diszo [M:GRT1]CRBGRACUM


    Case [M:GRT1]GRASTA
       When GVML_SUBIACH      : Gosub DISZO_GRIZO
       When GVML_SUBANNU      : Gosub DISZO_GRIZO
       When GVML_SUBTOTR      : Gosub DISZO_GRIZO
       When Default
    Endcase

   If [M:GRT1]REAGRAAMT > 0
     Diszo [M:GRT1]INVPLN
     Affzo [M:GRT1]INVPLN
   Endif

  Gosub CHARGE_PLAN

  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:GRT]","[M:FPC]","[M:GRT2]",LNBRCCE) From GLOBIENSANA
  [M:GRT2]NBRCCE=LNBRCCE
  G_NBAXE = LNBRCCE  #Fq-79815

Return
#-------------------------------------------------------------------------------
$SETBOUT

# Désactivation de l'action  Changer de clé
Call VIREBOUT(CHAINE,"H") From GOBJET

  # Pas de suppression si calcul ou dépense ou bien rattaché
    If  (  [M:GRT1]GRASTA      <> GVML_SUBANNU )
      Call VIREBOUT (CHAINE, "A") From GOBJET
    Endif

  # Menu Action/Evénements
   [L]CHMEN+="E"


Return
#-------------------------------------------------------------------------------
$FERME
#-----------------------------------------------------------------------------------#
# Si on vient par tunnel il faut restaurer les variables globales   #
#-----------------------------------------------------------------------------------#
If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM     : Endif
If TUNNEL : Gosub RESTAURE_GLOB_TUNNEL From TRUPROACT : Endif

 If dim(GCASHMOD)>0      : Kill GCASHMOD      : Endif
 If dim(GDATAMOD)>0      : Kill GDATAMOD      : Endif
 If dim(G_GRAAMT)>0      : Kill G_GRAAMT      : Endif
 If dim(G_MAXGRAAMT)>0   : Kill G_MAXGRAAMT   : Endif
 If dim(G_INVGRAAMT)>0   : Kill G_INVGRAAMT   : Endif
 If dim(G_REAGRAAMT)>0   : Kill G_REAGRAAMT   : Endif
 If dim(G_CRBGRAAMT)>0   : Kill G_CRBGRAAMT   : Endif
 If dim(G_CRBGRACUM)>0   : Kill G_CRBGRACUM   : Endif
 If dim(G_CASHAMT)>0     : Kill G_CASHAMT     : Endif
 If dim(GPERENDDAT)>0    : Kill GPERENDDAT    : Endif

Return
#=====================================================================
$APRES_MODIF

Return
#********************************************************************
# Activation des boutons
#********************************************************************
$EXEBOUT

Return
#======================================================================================
# Chargement de certaines valeurs
#======================================================================================
$CHARGE_PLAN

Local Date    PCPTDAT(1..5)
Local Integer PRET
Global Date   GPERENDDAT
Local Integer LCNX
Local Date    PCPTDATI(1..5)
Global Date   GPERENDDATI

# Date de fin de période courante du contexte CPFI et donc du plan de subvention
 Call GET_CNX_DAT([M:GRT0]CPY,G300CPFI,PCPTDAT,PRET) From GLOBIENS
 If PCPTDAT(4)<> [0/0/0]
   GPERENDDAT = PCPTDAT(4)
 Else
   GPERENDDAT = PCPTDAT(2)
 Endif

If G_ACTIAS=G_OUI
   If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
   Call GET_CNX_FROM_PLAN([M:GRT0]CPY, G301IAS, LCNX) From GLOBIENS
   If (LCNX > 0 ) Then
     # Date de fin de période courante du plan IAS et donc du plan de subvention
     Call GET_CNX_DAT([M:GRT0]CPY,LCNX,PCPTDATI,PRET) From GLOBIENS
     If PCPTDAT(4)<> [0/0/0]
        GPERENDDATI = PCPTDATI(4)
     Else
        GPERENDDATI = PCPTDATI(2)
     Endif
   Endif
Endif

Return
#======================================================================================
$INICRE

  #=====================================================
  # R0030-Numérotation automatique de la réf. Subvention
  #=====================================================
  If GGRTAUTNUM = 2 or (GGRTAUTNUM = 3 and [M:GRT0]GRAREF = "")
    # Appel du compteur de document FQ85464
    Call GET_NUMERO("GRT",GVML_NUMGRT-1,1,[M:GRT0]CPY,[M:GRT0]FCY,date$,[F:GRT]GRAREF,STAT) From GLOBIENS
    If STAT
      GOK      = 0
      Return
    Endif
    [M:GRT0]GRAREF=[F:GRT]GRAREF
    Affzo[M:GRT0]GRAREF
  Endif

Return
#**********************************************************************
# attribution des valeurs par défaut et rafraîchissement des écrans
#**********************************************************************
$VERIF_CRE

  # Contrôle cohérence société/site
  OK = func GLOFCYCPY.IS_CPYFCY_OK([M:GRT0]CPY,[M:GRT0]FCY)
  # Site financier et société incompatibles
  If !OK : Return : Endif

  # Issue 114673
  If ([M:GRT0]GRAREF= "")
    GMESSAGE = mess(3,GML_MSGFAS, 1)
    GOK=0
    Return
  Endif   # End Issue 114673

  G_GRAAMT    =  [M:GRT1]GRAAMT
  G_MAXGRAAMT =  [M:GRT1]MAXGRAAMT
  G_INVGRAAMT =  [M:GRT1]INVGRAAMT
  G_REAGRAAMT =  [M:GRT1]REAGRAAMT

  # Contrôle de validité des axes analytiques :
  Gosub CTRL_TAB_CCE From GLOBIENSANA
  #Fq-79815 ajout de l'alimentation des axes par défaut, si non-renseignés en Import
  If GIMPORT
     If LERR
        Call  AS_NBRCCE() From SUBGRT
        GMESSAGE="" : OK=1
     Endif
  Endif  #Fq-79815

Return
#**********************************************************************
# On vérifie que les 6 comptes sont tous renseignés avant de générer un
# événement d'annulation
#**********************************************************************
$VERIF_MOD
Local Integer LCDRET
Local Integer LJAUGE

  G_GRAAMT    =  [M:GRT1]GRAAMT    - [F:GRT]GRAAMT
  G_MAXGRAAMT =  [M:GRT1]MAXGRAAMT - [F:GRT]MAXGRAAMT
  G_INVGRAAMT =  [M:GRT1]INVGRAAMT - [F:GRT]INVGRAAMT
  G_REAGRAAMT =  [M:GRT1]REAGRAAMT - [F:GRT]REAGRAAMT

  #*En cas d'Annulation de subvention
  If [M:GRT1]GRASTA = GVML_SUBANNU and [F:GRT]GRASTA <> GVML_SUBANNU
       # Extourner événements qui ont été passé
       LJAUGE = G_OUI
       # Suppression
       GREASON = mess(94,GML_MSGGRT,1)
       Call DETRICOTE_EVE (GVML_OMSUBV, [F:GRT]CPY, [F:GRT]GRAREF, 0, date$,LJAUGE, LCDRET) From GENEVE
       If (LCDRET > 20 ) Then
          GOK = 0
          Call FSTA("EGRTCRT") From GLOCK
       Endif
  Endif
  # FQ82709 contrôle (général) des axes analytiques
  # Contrôle de validité des axes analytiques :
  Gosub CTRL_TAB_CCE From GLOBIENSANA

  #FQ110083
  #FQ111003 Filter [F:GRTW] Where INVPLN=[M:GRT1]GRASTA and [F:GRTW]CPY<> [M:GRT0]CPY
  Filter [F:GRTW] Where ( INVPLN=[M:GRT1]INVPLN ) and ( CPY<>[M:GRT0]CPY )
  Read [GRTW]GRT0 First
  Filter [F:GRTW]
  If fstat=0
    #"Ce projet est déjà rattaché à une subvention d'une autre société, vous ne pouvez pas l'utiliser."
    GMESSAGE = mess(120,GML_MSGGRT,1)
    GOK=0
    Return
  Endif


Return
#**********************************************************************
$AVANT_MODFIC

If GREP = "M"
  G_GRAAMT    =  [M:GRT1]GRAAMT    - [F:GRT]GRAAMT
  G_MAXGRAAMT =  [M:GRT1]MAXGRAAMT - [F:GRT]MAXGRAAMT
  G_INVGRAAMT =  [M:GRT1]INVGRAAMT - [F:GRT]INVGRAAMT
  G_REAGRAAMT =  [M:GRT1]REAGRAAMT - [F:GRT]REAGRAAMT
Endif

Return

#********************************************************************
$APRES_CRE
  Local Integer ERROR
  Call COMPTA_DIRECTE([M:GRT0]CPY, [M:GRT0]FCY, [M:GRT0]GRAREF, 0, "", ERROR) From TRTCPTINT
Return

#********************************************************************
$APRES_MOD
  Local Integer ERROR
  Call COMPTA_DIRECTE([M:GRT0]CPY, [M:GRT0]FCY, [M:GRT0]GRAREF, 0, "", ERROR) From TRTCPTINT
Return

#********************************************************************
$CREATION

    Gosub RECALCUL_TOT
    Gosub INSERT

Return
#********************************************************************
$MODIF
Local Integer LCDRET
Local Date WDATEFF, WDATCPTINT

  Gosub RECALCUL_TOT

  GOK=1

  Delete [CAS] Where CPY=[M:GRT0]CPY and GRAREF=[M:GRT0]GRAREF
  If fstat= 1
      GOK = 0
      Call RSTA("CAS",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Return
  Endif

   Gosub INSERT

  If ( [F:GRT]GRASTA <>  GVML_SUBANNU )
    If  ( GDATAMOD = G_OUI )
      #-Evénement de modification CPT
      LCDINT= "GRTCRT"+num$(G301CPT)
      # Modification
      GREASON = mess(93,GML_MSGGRT,1)
      WDATEFF=date$
      WDATCPTINT=max(WDATEFF, GPERENDDAT)
      Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
      If (LCDRET > 20 ) Then
        GOK = 0
        Call FSTA("EGRTCRT") From GLOCK
      Endif
      If G_ACTIAS = G_OUI & GCNXPROIAS = G_OUI
         #-Evénement de modification IAS
         LCDINT= "GRTCRT"+num$(G301IAS)
         GREASON = mess(93,GML_MSGGRT,1)
         WDATEFF=date$
         WDATCPTINT=max(WDATEFF, GPERENDDATI)
         Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
         If (LCDRET > 20 ) Then
           GOK = 0
           Call FSTA("EGRTCRT") From GLOCK
         Endif
      Endif
    Endif

    If GCASHMOD=G_OUI
      For nolign = 1 To [M]NBCASH
        #FQ104534
#        If  [M:GRT3]EVTFLG(nolign-1) = G_NON &  [M:GRT3]CASHAMT(nolign-1)<> 0
        If  [M:GRT3]EVTFLG(nolign-1) <> G_OUI and [M:GRT3]CASHAMT(nolign-1) <> 0
          Gosub GENERER_GRTCASH
          If G_ACTIAS=G_OUI & GCNXPROIAS = G_OUI
            Gosub GENERER_GRTCASH_IAS
          Endif
         Endif
      Next
   Endif
Endif

  #*En cas d'Annulation de subvention
  If [M:GRT1]GRASTA = GVML_SUBANNU and [F:GRT]GRASTA <> GVML_SUBANNU
     #**Si projet d'investissement non rattaché à une autre subvention : mise à jour des dépenses
     #** subventionnées avec remise à zéro du montant de subvention et décochage du flag de forçage
     Filter [GRT] Where GRAREF <> [M:GRT0]GRAREF & INVPLN=[M:GRT1]INVPLN
     Read [GRT]First
     Filter [GRT]
     If fstat <> 0
        Filter[LOF] Where PLNINV = [M:GRT1]INVPLN
        For [LOF]
           [F:LOF]AMTGRA=0
           [F:LOF]FLGGRA=G_NON
           [F:LOF]FLGAMTGRA=G_NON
           Rewrite [LOF]
           If fstat<>0
             GOK = 0 : Call FSTA("LOF") From GLOCK : Break
           Endif
        Next
        Filter[LOF]
      Endif
   Endif

Return
#========================================================
$GENERER_GRTCASH

  G_CASHAMT =  [M:GRT3]CASHAMT(nolign-1)
  G_CASHDAT =  [M:GRT3]CASHDAT(nolign-1)

   LCDINT= "GRTCASH"+num$(G301CPT)
   # Modification
   GREASON = mess(93,GML_MSGGRT,1)
   WDATEFF=G_CASHDAT
   WDATCPTINT=max(WDATEFF, GPERENDDAT)
   [F:E61]CREDAT     = date$
   [F:E61]CRETIM     = time
   [F:E61]TIMSTP     = func GENEVE.BUILD_TIMSTP([F:E61]CREDAT, [F:E61]CRETIM)
   Read [E61]EVE2=G_OUI;G301CPT;[F:GRT]CPY;[F:GRT]FCY;[F:GRT]GRAREF
   If fstat
      Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)
&                             From GENEVE
   #*FQ-64122 Else
   #*FQ-64122   Local Integer NBMAXTRY : NBMAXTRY=2
   #*FQ-64122   For NBTRY=1 To NBMAXTRY
   #*FQ-64122 Call TEMPO_EVT() From GENEVE
   #*FQ-64122   [F:E61]CRETIM = time
   #*FQ-64122   [F:E61]TIMSTP = func GENEVE.BUILD_TIMSTP([F:E61]CREDAT, [F:E61]CRETIM)
   #*FQ-64122   Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)
   #*FQ-64122&                             From GENEVE
   #*FQ-64122   If !fstat
   #*FQ-64122      Break
   #*FQ-64122   Endif
   #*FQ-64122   Next NBTRY
   #*FQ-64122   #> Si la nouvelle tentative après tempo a de nouveau échouée, erreur
      If fstat
         RCOD = 90
         Infbox mess(101,GML_MSGGRT,1)-num$(RERROR)-"\"-[F:E61]CPY-"-"-LCDINT-"-"-"-"-[F:E61]REF
         GOK    = 0
      Endif
    Endif
    If (LCDRET > 20 ) Then
       GOK = 0
      Call FSTA("EGRTCASH") From GLOCK
    Else
       Update [CAS] Where ( GRAREF  = [M:GRT0]GRAREF &
&                                    CASHDAT = WDATEFF ) With EVTFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
          If fstat
              GOK=0 : Return
          Else
             [M:GRT3]EVTFLG(nolign-1) = G_OUI : Affzo [M:GRT3]EVTFLG(nolign-1)
             Diszo [M:GRT3]CASHDAT(nolign-1) :  Affzo [M:GRT3]CASHDAT(nolign-1)
             Diszo [M:GRT3]CASHAMT(nolign-1) :  Affzo [M:GRT3]CASHAMT(nolign-1)
          Endif
   Endif

Return
#========================================================
$GENERER_GRTCASH_IAS

  G_CASHAMT =  [M:GRT3]CASHAMT(nolign-1)
  G_CASHDAT =  [M:GRT3]CASHDAT(nolign-1)

   LCDINT= "GRTCASH"+num$(G301IAS)
   # Modification
   GREASON = mess(93,GML_MSGGRT,1)
   WDATEFF=G_CASHDAT
   WDATCPTINT=max(WDATEFF, GPERENDDATI)
   [F:E61]CREDAT     = date$
   [F:E61]CRETIM     = time
   [F:E61]TIMSTP     = func GENEVE.BUILD_TIMSTP([F:E61]CREDAT, [F:E61]CRETIM)
   Read [E61]EVE2=G_OUI;G301IAS;[F:GRT]CPY;[F:GRT]FCY;[F:GRT]GRAREF
   If fstat
      Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)
&                             From GENEVE
   #*FQ-64122Else
   #*FQ-64122   Local Integer NBMAXTRY : NBMAXTRY=2
   #*FQ-64122   For NBTRY=1 To NBMAXTRY
   #*FQ-64122   Call TEMPO_EVT() From GENEVE
   #*FQ-64122   [F:E61]CRETIM = time
   #*FQ-64122   [F:E61]TIMSTP = func GENEVE.BUILD_TIMSTP([F:E61]CREDAT, [F:E61]CRETIM)
   #*FQ-64122   Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)
   #*FQ-64122&                             From GENEVE
   #*FQ-64122If !fstat
   #*FQ-64122Break
   #*FQ-64122Endif
   #*FQ-64122   Next NBTRY
   #*FQ-64122   #> Si la nouvelle tentative après tempo a de nouveau échouée, erreur
   #*FQ-64122   If fstat
   #*FQ-64122      RCOD = 90
   #*FQ-64122      Infbox "Erreur : création événement /"-num$(RERROR)-"\"-[F:E61]CPY-"-"-LCDINT-"-"-"-"-[F:E61]REF
   #*FQ-64122      GOK    = 0
   #*FQ-64122   Endif
    Endif
    If (LCDRET > 20 ) Then
       GOK = 0
      Call FSTA("EGRTCASH") From GLOCK
   Endif

Return

#********************************************************************
$AV_ANNULE
  Local Integer LCDRET
  Local Integer NBEVESUP

  Call SUPP_EVE_OBJ(GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,[0/0/0],NBEVESUP,LCDRET) From GENEVE

  If LCDRET
   Infbox "SUPP_EVE_OBJ =>"-num$(LCDRET)
   GOK=0
   Return
  Endif
  Call CRE_EVE_CNL_OBJ(GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,[0/0/0],LCDRET) From GENEVE
  If LCDRET
   Infbox "CRE_EVE_CNL_OBJ =>"-num$(LCDRET)
   GOK=0
   Return
  Endif
Return

#********************************************************************
$ANNULE
Local Integer LCDRET
Local Integer NBEVESUP #FQ-XXXXX

# Suppression  des subventions
  Delete [GRT] Where GRAREF=[M:GRT0]GRAREF
  If fstat=1
    GOK=0
    Call RSTA("GRT",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
    Return
  Endif

# Suppression  des encaissements
  Delete [CAS] Where CPY=[M:GRT0]CPY and GRAREF=[M:GRT0]GRAREF
  If fstat=1
    GOK=0
    Call RSTA("CAS",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
    Return
  Endif

  # Génération d'un évènement de type "Suppression de Subvention"
  If GREP="M"
    LCDINT= "GRTCRT"+num$(G301CPT)
    # Suppression CPT
    GREASON = mess(94,GML_MSGGRT,1)
    Call SUPP_EVE_OBJ(GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,NBEVESUP,LCDRET)  From GENEVE
    If (LCDRET > 20 ) Then
      GOK = 0
      Call FSTA("EVEGRT") From GLOCK
    Endif
    If G_ACTIAS = G_OUI & GCNXPROIAS = G_OUI
      #  Evénement de suppression  IAS
      LCDINT= "GRTCRT"+num$(G301IAS)
      GREASON = mess(94,GML_MSGGRT,1)
      Call SUPP_EVE_OBJ(GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,NBEVESUP,LCDRET)  From GENEVE
      If (LCDRET > 20 ) Then
        GOK = 0
        Call FSTA("EGRTCRT") From GLOCK
      Endif
   Endif
  Endif


Return
#********************************************************************
# Sauve l'enregistrement "CASHING"
#********************************************************************
$INSERT
Local Integer LCDRET
Local Date    WDATEFF
Local Date    WDATCPTINT

    For nolign = 1 To [M]NBCASH
      Raz  [F:CAS]
      [F:CAS] = [M:GRT0]
      [F:CAS]CPY = [M:GRT0]CPY
      [F:CAS]FCY = [M:GRT0]FCY
      [F:CAS] = [M:GRT3]

      Write [F:CAS]
      If fstat
         GOK = 0
         Call FSTA("CAS") From GLOCK
         Break
      Endif
    Next nolign
    If OK=0 : Return : Endif

    # Génération d'un évènement de type "Subvention"
    #If (GREP="C" or GREP="D" or GREP="") & ([F:GRT]GRAAMT <> 0 or [F:GRT]INVGRARAT > 0 ) & ( [F:GRT]GRASTA <>  GVML_SUBANNU )
    If (GREP="C" or GREP="D" or GREP="") & ([F:GRT]GRAAMT <> 0 ) & ( [F:GRT]GRASTA <>  GVML_SUBANNU )
      LCDINT= "GRTCRT"+num$(G301CPT)
      # Création
      GREASON = mess(92,GML_MSGGRT,1)
      WDATEFF=[F:GRT]APPROVDAT
      WDATCPTINT = max(WDATEFF, GPERENDDAT)
      Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
      If (LCDRET > 20 ) Then
        GOK = 0
        Call FSTA("EVEGRT") From GLOCK
      Endif
      If G_ACTIAS = G_OUI & GCNXPROIAS = G_OUI
         #  Evénement de création IAS
         LCDINT= "GRTCRT"+num$(G301IAS)
         GREASON = mess(92,GML_MSGGRT,1)
         WDATEFF=[F:GRT]APPROVDAT
         WDATCPTINT = max(WDATEFF, GPERENDDAT)
         Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
         If (LCDRET > 20 ) Then
           GOK = 0
           Call FSTA("EGRTCRT") From GLOCK
         Endif
      Endif
    Endif

    # Génération d'un évènement de type "Versement"
    If (GREP="C" or GREP="D" or GREP="") & (GCASHMOD = G_OUI) & ( [F:GRT]GRASTA <>  GVML_SUBANNU )
      For nolign = 1 To [M]NBCASH
        If  [M:GRT3]EVTFLG(nolign-1) = G_NON and [M:GRT3]CASHAMT(nolign-1) <> 0
          Gosub GENERER_GRTCASH
          If G_ACTIAS=G_OUI & GCNXPROIAS = G_OUI
            Gosub GENERER_GRTCASH_IAS
          Endif
         Endif
      Next
    Endif

Return
#=================================================================================
$AFFZO_ACTZO

        Actzo [M:GRT1]
        Actzo [M:GRT2]
        Actzo [M:GRT3]5
        Actzo [M:GRT3]10
        Actzo [M:GRT9]

Return
#=================================================================================
$DISZO_GRIZO

        Diszo [M:GRT1]
        Diszo [M:GRT2]
        Diszo [M:GRT3]5
        Diszo [M:GRT3]10
        Diszo [M:GRT9]

Return
#**************************************************************************************
#                     E C R A N      G R T 0  - Entête -
#=======================================================================================
#  R0010-Apres saisie Etablissement/Site
#=======================================================================================
Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
Local Char LZVSOC(GLONCPY)

Local Integer  RCNX  : RCNX = G_NON

  LZVSOC = [M:GRT0]CPY
  Call ACTION_FCY (VALEUR, [M:GRT0]CPY) From GLOFCYCPY
  If [M:GRT0]CPY <> LZVSOC Then
    Affzo [M:GRT0]CPY
  Endif

 # Pas de plan de subvention pour cette société
 If [M:GRT0]CPY <>""

 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
    # >>>>>
    For [CNX]CNX0 Where CPY=[M:GRT0]CPY
       If find (G301SUB,  [F:CNX]PLNCAA(0..[F:CNX]NBPLC-1)) > 0
          RCNX = G_OUI
          Break
       Endif
    Next
    If RCNX = G_NON
       GMESSAGE = mess(67,GML_MSGGRT,1)-num$(CPY)     # Pas de plan Subvention pour cette société
       mkstat=2 : End
    Endif
 Endif

End
#=======================================================================================
# -Contrôles  FCY
#=======================================================================================
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()
End
#==================================================
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer ISITE, OK
  Local Char    SOCIETE (GLONCPY)

  # Recherche de la société du site
  ISITE = find(VALEUR,GSITE(1..GNBSITE))
  If ISITE
    SOCIETE = GSOCSITE(ISITE)
  Else
    GMESSAGE = mess(15,104,1) : # Site inexistant
    mkstat = 2 : End
  Endif

  # La duplication ne peut avoir lieu que sur un site financier appartenant à la même société
  If (GREP = 'D' and VALEUR <> [M:GRT0]FCY) Then
    If ( GCOUSOC <> SOCIETE ) Then
      # Site financier invalide
      GERR= 1: GMESSAGE = mess(19,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Endif
End
#==================================================
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

Local Integer  RCNX  : RCNX = G_NON

  If VALEUR<>""
    Read [F:FCY]FCY0=VALEUR
      [M:GRT0]CPY = [F:FCY]LEGCPY
      Affzo [M:GRT0]CPY
   Endif

 # Pas de plan de subvention pour cette société
 If [M:GRT0]CPY <>""

 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
    # >>>>>
    For [CNX]CNX0 Where CPY=[M:GRT0]CPY
       If find (G301SUB,  [F:CNX]PLNCAA(0..[F:CNX]NBPLC-1)) > 0
          RCNX = G_OUI
          Break
       Endif
    Next
    If RCNX = G_NON
       GMESSAGE = mess(67,GML_MSGGRT,1)-num$(CPY)     # Pas de plan Subvention pour cette société
       mkstat=2 : End
    Endif
 Endif

  # Affichage de l'intitulé société (non pris en compte par les actions associées au type de donnée BFC)
  If dim([M:GRT0]ZCPY) > 0 Then
    Affzo [M:GRT0]ZCPY
  Endif

End
########################################
Subprog AP_GRAREF(VALEUR)
Variable Char    VALEUR()

Call C_GRAREF(VALEUR)

End
########################################
Subprog C_GRAREF(VALEUR)
Variable Char    VALEUR()

  If ( GGRTAUTNUM = 1 and VALEUR= "" )
    GERR= 1: GMESSAGE = mess(3,GML_MSGFAS, 1)
    mkstat = 2
  Elsif ( VALEUR = "" and !GIMPORT )
    # Création forcée
    mkstat = 4
  Endif

End
######################################################################################
#FQ61803
Subprog AS_DES(VALEUR)
Variable Char    VALEUR()
 If GDEBUG<>G_OUI : GBOUT1 = "" : Endif
End
######################################################################################
##Fq-79815 Activation et contrôle des sections analytiques
######################################################################################
Subprog AS_NBRCCE

 Local Integer AXE

 # Pour récupèree les sections par défautce il faut être en  Création/Duplication de subvention
 # .... et ne pas avoir renseigné de clé répartition
 If (GREP <> "C"  and GREP <> "D" ) or  [M:GRT2]DSP <> ""
    End
 Endif

  #*<<<Fq-79815
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
     [M:GRT2]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
     If ( GREP = "C" or GREP = "D" )
        If ([M:GRT2]CCE(I_DIE-1)="")
           Call INISEC([M:GRT2]CCE(I_DIE-1),"FXDGRANTS", [M:GRT2]DIE(I_DIE-1)) From SUBCDE
        Endif
     Endif
     Affzo [M:GRT2]DIE(I_DIE-1) : Affzo [M:GRT2]ZDIE(I_DIE-1)
     Affzo [M:GRT2]CCE(I_DIE-1) : Affzo [M:GRT2]ZCCE(I_DIE-1)
  Next I_DIE
  #*FQ-79815>>>>>

  Affzo [M:GRT2]NBRCCE

   For AXE=1 To G_NBAXE
     Actzo [M:GRT2]CCE(AXE-1)
   Next

End
#######################################
Subprog C_NBRCCE


# adxgtb= 0 = On est encore en saisie dans le tableau
# adxgtb= 1 = Sortie invalide du tableau ==> pas la peine de faire ces contrôles car il y a au préalable des anomalies à corriger
# adxgtb= 2 = Sortie valide du tableau ==>  on fait des contrôles complémentaires sur chaque ligne du tableau
If adxgtb=2
   If clalev([F:CAZ])=0  : Local File CAAUZ   [CAZ]  : Endif
   If clalev([F:CCE])=0  : Local File CACCE   [CCE]  : Endif  : # Sections
   If clalev([F:CCE2])=0 : Local File CACCE   [CCE2] : Endif  : # Sections

   For AXE=1 To G_NBAXE
      If [M]CCE(AXE-1)<>""
         nolign=AXE
         # Contrôle interdiction section/section
         Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
         For I=AXE+1 To G_NBAXE
            If [M]CCE(I-1)<>""
               Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
               Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
               If !fstat
                  # Interdit avec la section
                  GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
                  mkstat = 1 : Break 2
               Endif
            Endif
         Next
      Endif
   Next
Endif


End
#***************************************************************************************
#                     E C R A N      G R T 1 - Principal -
#=======================================================================================
#  R1020-date d'accord subvention
#=======================================================================================
Subprog C_APPROVDAT(VALEUR)
Variable Date    VALEUR

Local Integer OK

# R1020-Si la date d'approbation est < à la date début exercice fiscal & comptable

    If VALEUR  < GDEBEXECPF & !GIMPORT
        Call AVERTIR (mess(19,GML_MSGGRT,1), OK) From GESECRAN
        If OK = 1 Then
          GERR   = 1
          mkstat = 2
          End
        Endif
    Endif

End
#=======================================================================================
# R1030-type de subvention
#   GVML_TSUBFOR = Type subvention forfaitaire
#   GVML_TSUBPRC = Type subvention selon un pourcentage
#   GVML_TSUBPLF = Type subvention selon un pourcentage plafonné
#=======================================================================================
Subprog AP_GRATYP(VALEUR)
Variable Integer VALEUR

  [M:GRT1]GRATYP = VALEUR
  Affzo [M:GRT1]GRATYP
  Call AM_GRATYP([M:GRT1]GRATYP)

End

#=======================================================================================
# R1030-type de subvention
#   GVML_TSUBFOR = Type subvention forfaitaire
#   GVML_TSUBPRC = Type subvention selon un pourcentage
#   GVML_TSUBPLF = Type subvention selon un pourcentage plafonné
#=======================================================================================
Subprog AM_GRATYP(VALEUR)
Variable Integer VALEUR

  Case VALEUR

    When GVML_TSUBFOR:    Raz   [M:GRT1]INVGRARAT
                          Diszo [M:GRT1]INVGRARAT
                          Affzo [M:GRT1]INVGRARAT

                          Raz   [M:GRT1]MAXGRAAMT
                          Diszo [M:GRT1]MAXGRAAMT
                          Affzo [M:GRT1]MAXGRAAMT

                          Actzo [M:GRT1]GRAAMT
                          Affzo [M:GRT1]GRAAMT

    When GVML_TSUBPRC :   Raz   [M:GRT1]MAXGRAAMT
                          Diszo [M:GRT1]MAXGRAAMT
                          Affzo [M:GRT1]MAXGRAAMT

                          Raz   [M:GRT1]GRAAMT
                          Diszo [M:GRT1]GRAAMT
                          Affzo [M:GRT1]GRAAMT

                          Actzo [M:GRT1]INVGRARAT
                          Affzo [M:GRT1]INVGRARAT

    When GVML_TSUBPLF  :  Raz   [M:GRT1]GRAAMT
                          Diszo [M:GRT1]GRAAMT
                          Affzo [M:GRT1]GRAAMT

                          Affzo [M:GRT1]INVGRARAT
                          Actzo [M:GRT1]INVGRARAT

                          Affzo [M:GRT1]MAXGRAAMT
                          Actzo [M:GRT1]MAXGRAAMT

    When Default
  Endcase


  If (VALEUR <>  0) & (VALEUR <> [M:GRT1]GRATYP) & (GREP = "M")
    GDATAMOD = G_OUI
  Endif


End
#=======================================================================================
#  R1040-%age de l'investissement subventionné
#=======================================================================================
Subprog AS_INVGRARAT(VALEUR)
Variable Decimal VALEUR

    If [M:GRT1]GRATYP <> GVML_TSUBPRC and [M:GRT1]GRATYP <> GVML_TSUBPLF
        Raz [M:GRT1]INVGRARAT
        Diszo [M:GRT1]INVGRARAT
    Else
        Actzo [M:GRT1]INVGRARAT
        Affzo [M:GRT1]INVGRARAT
    Endif

End
#=======================================================================================
Subprog C_INVGRARAT(VALEUR)
Variable Decimal VALEUR

 # Infbox "On va passer par C_INVGRARAT "
    If ([M:GRT1]GRATYP =GVML_TSUBPRC or [M:GRT1]GRATYP = GVML_TSUBPLF) & (VALEUR = 0 or VALEUR > 100)
          GMESSAGE = mess(28,GML_MSGGRT,1) : # le taux ne doit pas être supérieur à 100%
          GERR=1
          mkstat=2
     Endif

End
#=======================================================================================
#  R1050-Plafond de Subvention
#=======================================================================================
Subprog AS_MAXGRAAMT(VALEUR)
Variable Decimal VALEUR

End
#=======================================================================================
#  R1070-Montant de la Subvention
#  R1060-gestion du flag de forçage du montant
#=======================================================================================
Subprog C_GRAAMT(VALEUR)
Variable Decimal VALEUR

    If ([M:GRT1]GRASTA = GVML_SUBENC) & (VALEUR = 0)
        If ([M:GRT1]GRATYP=GVML_TSUBFOR)
              GMESSAGE = mess(6,GML_MSGGRT,1) : # Montant obligatoire si type=forfait
              GERR=1
              mkstat=2
       Endif
    Endif

End
#=======================================================================================
Subprog AM_GRAAMT(VALEUR)
Variable Decimal VALEUR

  If (VALEUR <>  0) & (VALEUR <> [M:GRT1]GRAAMT) & (GREP <>  "C") & (GREP <>  "D")
    GDATAMOD = G_OUI
    G_GRAAMT = [F:GRT]GRAAMT - VALEUR
  Endif

  If  [M:GRT1]GRAAMT <> 0 and [M:GRT1]GRAAMT >= [M:GRT3]CASHTOT
     [M:GRT1]TOBERECAMT =  [M:GRT1]GRAAMT - [M:GRT3]CASHTOT
  Else
    [M:GRT1]TOBERECAMT = 0
   Endif
   Affzo [M:GRT1] TOBERECAMT
End
#=======================================================================================
#  R1050-Plafond de subvention
#=======================================================================================
Subprog C_MAXGRAAMT(VALEUR)
Variable Decimal VALEUR

  If VALEUR=0 and [M:GRT1]GRATYP=3
        GMESSAGE = mess(8,GML_MSGGRT,1) : # Montant obligatoire si type=pourcentage plafonné
        GERR=1
        mkstat=2
   Endif

End
#=======================================================================================
Subprog AS_GRASTA(VALEUR)
Variable Integer VALEUR

    Raz GMENLOC
    GMENLOC(4)=1    # on ne propose pas le choix "subvention réintégrée : maj par le trt de calcul
End
#=======================================================================================
Subprog AM_GRASTA(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local Integer LGRTPRVUPD
Local Char LPARAM

   ##**Annulation interdite si :
   ##    1-remise en cause de la situation comptable antérieure interdite
   ##    2-au-moins une dépense est rattachée à un bien qui a déjà subi une clôture
    If (VALEUR = GVML_SUBANNU) & (VALEUR <> [M:GRT1]GRASTA)
        # FQ91644 ajout du site ds PARAM
        Call PARAM([M:GRT0]FCY ,"GRTPRVUPD",LPARAM) From ADOVAL
        LGRTPRVUPD = val(LPARAM)
        If LGRTPRVUPD = G_NON & ( [M:GRT1]REAGRAAMT <> 0 ) & ( [M:GRT1]CRBGRACUM <> 0 )
           # Vous ne pouvez pas annuler cette subvention : au moins un bien a déjà subi une clôture
           GMESSAGE = mess(98,GML_MSGGRT,1)
           GERR   = 1
           mkstat = 2
           End
        Endif
    Endif

    Case VALEUR
       When GVML_SUBIACH         : Gosub DISZO_GRIZO
       When GVML_SUBANNU
          Call AVERTIR (mess(85,GML_MSGGRT,1), OK) From GESECRAN
          If OK = 1 Then
            GERR   = 1
            mkstat = 2
            End
          Endif
          Gosub DISZO_GRIZO
       When GVML_SUBTOTR         : Gosub DISZO_GRIZO
       When Default              : Gosub AFFZO_ACTZO:
    Endcase


    If (VALEUR <>  0) & (VALEUR <> [M:GRT1]GRASTA) & (GREP = "M")
      GDATAMOD = G_OUI
    Endif

End
