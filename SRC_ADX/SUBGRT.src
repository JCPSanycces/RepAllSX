#----------------------------------------------------------#
## sélection des projets d'investissement de la société
#----------------------------------------------------------#
$SEL_PLNINV
Local Char LNUMTAB
Local Char LSOC

If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

LNUMTAB = PARAM(1) : # table diverse
LSOC    = PARAM(2) : # code société

CRITERE = 'NUMTAB = '+LNUMTAB
If LSOC <>""
  Read [ADV]CODE = val(LNUMTAB)
  CRITERE += ' & (A1 = '+LSOC+')'
  If fstat
    Infbox mess(81,75,1)
  Endif
Endif
Default File [ADI]
OBJET   = "ADI"
START   = "[F:ADI]CODE"

Return
#=======================================================================================
Subprog AM_INVPLN(VALEUR)
Variable Char    VALEUR()

  Read[ADI]CODE=GTD_INVPLN;VALEUR
  If [F:ADI]A1 <> [M:GRT0]CPY
     GMESSAGE = mess(86,GML_MSGGRT,1) : # Ce projet n'est pas rattaché à la société de la subvention.
     GERR=1
     mkstat=2  : End
  Else #FQ110083
    Filter [F:GRTW] Where ( INVPLN=VALEUR )  and ( CPY<>[M:GRT0]CPY )
    Read [GRTW]GRT0 First
    Filter [F:GRTW]
    If fstat=0
      #"Ce projet est déjà rattaché à une subvention d'une autre société, vous ne pouvez pas l'utiliser."
      GMESSAGE = mess(120,GML_MSGGRT,1)
      GERR=1
      mkstat=2  : End
    Endif
  Endif

  If ( VALEUR <>  "") & (VALEUR <> [M:GRT1]INVPLN )
     If  (GREP = "M")
        GDATAMOD = G_OUI
     Endif
     [M:GRT1]INVPLN = VALEUR  #FQ-82221
     Affzo [M:GRT1]INVPLN     #FQ-82221
     Gosub CALCUL_GRAAMT      #FQ-82221
  Endif



End
