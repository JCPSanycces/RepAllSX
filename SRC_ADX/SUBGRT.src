End
#=======================================================================================
# R1090-recalcul du montant restant à encaisser (TOBERECAMT)
#=======================================================================================
$RECALCUL_TOT

Local Integer I
Local Decimal WCASHTOT

  WCASHTOT = [M:GRT3]CASHTOT

  Raz[M:GRT3]CASHTOT
  Affzo[M:GRT3]CASHTOT

  For I=0 To [M:GRT3]NBCASH-1
       [M:GRT3]CASHTOT=[M:GRT3]CASHTOT+[M:GRT3]CASHAMT(I)
  Next

  Affzo[M:GRT3]CASHTOT

  If [M:GRT3]CASHTOT <> WCASHTOT
    G_CASHAMT =  [M:GRT3]CASHTOT-WCASHTOT
  Endif

  If  [M:GRT1]GRAAMT <> 0 and [M:GRT1]GRAAMT >= [M:GRT3]CASHTOT
     [M:GRT1]TOBERECAMT =  [M:GRT1]GRAAMT - [M:GRT3]CASHTOT
  Else
    [M:GRT1]TOBERECAMT = 0
  Endif
  Affzo[M:GRT1]TOBERECAMT


Return
