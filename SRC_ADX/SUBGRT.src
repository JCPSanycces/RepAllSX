If VALEUR <> [M:GRT1]INVGRARAT
  GDATAMOD = G_OUI
Endif

 #Fq-82221
 [M:GRT1]INVGRARAT = VALEUR
 Affzo [M:GRT1]INVGRARAT
 If [M:GRT1]INVPLN <> ""
   Gosub CALCUL_GRAAMT
 Endif


End
#=======================================================================================
Subprog AM_MAXGRAAMT(VALEUR)
Variable Decimal VALEUR

If VALEUR <> [M:GRT1]MAXGRAAMT
  GDATAMOD = G_OUI
Endif

#Fq-82221
 [M:GRT1]MAXGRAAMT = VALEUR
 Affzo [M:GRT1]MAXGRAAMT
 If [M:GRT1]INVPLN <> ""
   Gosub CALCUL_GRAAMT
 Endif

End
############################################################
#*Fq-82221 : calcul montant de la subvention
#* si type de subvention égal pourcentage ou plafond
#############################################################
$CALCUL_GRAAMT
Local Decimal  CMREA               # Montant calculé si pourcentage
Local Decimal  WREAGRAAMT          # Montant Réalisé subventionné
Local Decimal  WINVGRAAMT          # Montant Immobilisé subventionné
Local Decimal  WGGRAAMT            # Montant subvention sur les Subventions
Local Decimal  WMTCONV             # Montant intermédiaire pour conversion
Local Decimal  RMONTANT            # Montant intermédiaire pour arrondi

  # FQ84403
  If [M:GRT1]GRATYP = GVML_TSUBFOR
    # Si le type de subvention est "Forfait" il ne faut pas lancer ce calcul
    Return
  Endif

  Local Integer STAT
  Filter [GRT] Where ( INVPLN=[M:GRT1]INVPLN and GRAREF <> [M:GRT0]GRAREF )
    Read [GRT]First
    If fstat=0
         GMESSAGE = mess(113,GML_MSGGRT,1)+" : "+mess(114,GML_MSGGRT,1)
         GERR = 1  : mkstat=0
         GDATAMOD = G_NON # pour éviter de générer un evt vide
    Endif
  Filter [GRT]
  If GDATAMOD = G_NON : Return : Endif
  #---------- boucle sur les dépenses rattachées à  l'investissement ------
  #---------- et cumul des montants subventionnés dans INVGRAAMT et REAGRAAMT ------
  #*Fq-82221 Filter [LOF] Where (PLNINV=[M:GRT1]INVPLN) & (CPY=[M:GRT0]CPY)
  Filter [LOF] Where (PLNINV=[M:GRT1]INVPLN) & (CPY=[M:GRT0]CPY)  & (FLGGRA=G_OUI)
  For [LOF]
    WNUMLOF = sum(num$([F:LOF]CODLOF),num$("/"),num$([F:LOF]LINLOF))
    If [F:LOF]AASREF <> ""
        WINVGRAAMT += [F:LOF]AMTNOTCPY
    Endif
    WREAGRAAMT +=[F:LOF]AMTNOTCPY
  Next
  Filter[LOF]
  #----------
  If [F:LOF]CUR <> ""
    Call CONVERT3([F:LOF]CUR,[M:GRT1]CUR,[M:GRT1]CUR, [F:LOF]CURTYP,date$,WINVGRAAMT,WMTCONV,[F:LOF]RATCUR,STAT) From CPTSUB
    Call GET_MNT_ARRONDI(WMTCONV,[M:GRT1]CUR,RMONTANT) From GLOBIENS
  Endif
  Call GET_MNT_ARRONDI(WINVGRAAMT,[M:GRT1]CUR,RMONTANT) From GLOBIENS
  WINVGRAAMT       = RMONTANT

  If [F:LOF]CUR <> ""
    Call CONVERT3([F:LOF]CUR,[M:GRT1]CUR,[M:GRT1]CUR,[F:LOF]CURTYP,date$,WREAGRAAMT,WMTCONV,[F:LOF]RATCUR,STAT) From CPTSUB
    Call GET_MNT_ARRONDI(WMTCONV,[M:GRT1]CUR,RMONTANT) From GLOBIENS
  Endif
  Call GET_MNT_ARRONDI(WREAGRAAMT,[M:GRT1]CUR,RMONTANT) From GLOBIENS
  WREAGRAAMT       = RMONTANT

   #---------- si type POURCENTAGE : maj de GRAAMT dans GRANTS ------
    If [M:GRT1]GRATYP = GVML_TSUBPRC
      CMREA = (WREAGRAAMT * [M:GRT1]INVGRARAT)/100
      Call GET_MNT_ARRONDI(CMREA,[M:GRT1]CUR,CMREA) From GLOBIENS
      WGGRAAMT = CMREA
    Else   #---------- si type POURCENTAGE PLAFONNE :, maj de GRAAMT dans GRANTS ------
      If [M:GRT1]GRATYP = GVML_TSUBPLF
        If [M:GRT1]MAXGRAAMT > 0
          CMREA = (WREAGRAAMT  * [M:GRT1]INVGRARAT)/100
          Call GET_MNT_ARRONDI(CMREA,[M:GRT1]CUR,CMREA) From GLOBIENS
          If CMREA > [M:GRT1]MAXGRAAMT
              CMREA = [M:GRT1]MAXGRAAMT
          Endif
          WGGRAAMT = CMREA
        Endif
      Endif
    Endif

    [M:GRT1]INVGRAAMT = WINVGRAAMT : Affzo [M:GRT1]INVGRAAMT
    [M:GRT1]REAGRAAMT = WREAGRAAMT : Affzo [M:GRT1]REAGRAAMT
    [M:GRT1]GRAAMT    = WGGRAAMT   : Affzo [M:GRT1]GRAAMT


Return
