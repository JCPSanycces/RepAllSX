#                     E C R A N      G R T 2 - Imputations
#=======================================================================================
######################################################################################
#----------------------------------------------
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()

 If VALEUR <> ""
   If !clalev([DSP]) : Local File CADSP [DSP] : Endif

   Read [DSP]DSP0 = VALEUR;1 : # Lecture de la première ligne

   #> Vérification site / société
   If [F:DSP]FCY<>"" Then
     Call VERIF_FCY("DSP", [F:DSP]FCY, [M:GRT0]CPY, [M:GRT0]FCY, VALEUR) From GLOBIENS
     If mkstat : End : Endif
   Endif
Endif

End
##-------------------------------------------------
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()

  Local Integer N_CCE

  For N_CCE = 0 To GOPTCANA-1
    If VALEUR = ""
      # Si une clé de répartition est remise à blanc, il faut dégriser les axes
      Actzo [M:GRT2]CCE(N_CCE)
    Else
      # Si une clé de répartition est saisie, il faut griser les axes
      [M:GRT2]CCE(N_CCE) = ""
      Diszo [M:GRT2]CCE(N_CCE)
    Endif
  Next N_CCE

End

