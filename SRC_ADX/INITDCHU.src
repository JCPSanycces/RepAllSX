#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("UCHARGES","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()

Gosub OUVFIC From INITDCH
Gosub DECLARATION From INITDCH
Gosub DECL_EFF From TRTDUXTR
Local Char PARAM(30), VALEUR(30)
Local Char VALPAR (50)
Local Date VALDAT
Local Char VNUMCTR (50)

#Recup no de requete
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)

CRITCPY="1=1"
CRITFCY="1=1"
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "mthyea"      : If [L]VALEUR<>[0/0/0]
                         [L]VALDAT=VALEUR
                        Else
                         Call ERREUR (mess(69,10702,1)) From GESECRAN
                         GOK=0 : End
                        Endif
   When "cpy"         : If [L]VALEUR<>""
                         [L]CRITCPY -= '& [F:FGR]CPY="'+[L]VALEUR+'"'
                        Else
                         Call ERREUR (mess(68,10702,1)) From GESECRAN
                         GOK=0 : End
                        Endif
   When "fcydeb"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY>="'+[L]VALEUR+'"'
                        Endif
   When "fcyfin"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY<="'+[L]VALEUR+'"'
                        Endif
   When "arrbas"      : If [L]VALEUR="1" :#Oui
                         [L]ARRBASE= 2
                        Else
                         [L]ARRBASE=1
                        Endif
   When "arrmtt"      : If [L]VALEUR="1" :#Oui
                         [L]ARRMONTANT=2
                        Else
                         [L]ARRMONTANT=1
                        Endif
  Endcase
 Endif
Next

#Calcul des dates de la période choisie
VDATDEB=gdat$(01,month(VALDAT),year(VALDAT))
VDATFIN=eomonth (VALDAT)

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

# Affectation du libellé de la période
PARAM = month$(month(VALDAT))-num$(year(VALDAT))
Call SETPARAM("libperiode",NBPAR,PARAMETRE,PARAM) From ETAT

# Affectation de la date limite de reception
PARAM = num$(VDATFIN+5)
Call SETPARAM("datlimite",NBPAR,PARAMETRE,PARAM) From ETAT

#Affectation de la date de versement des salaires
PARAM=num$(gdat$(func DIVPAYE.INIPARUSR("DATREG","","")))
Call SETPARAM("datreg",NBPAR,PARAMETRE,PARAM) From ETAT

Gosub EFFACE From INITDCH
Trbegin [HRTDE]
 Delete [F:HRTDE] Where USR=GUSER
Commit

Gosub TR1
End

$TR1
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [TM1], [TM2]
Gosub TR2
If    GOK<0 : Goto ROL_TR2
Elsif GOK=0 : Goto AB_TR2
Endif
Commit
Return

#######################################
$AB_TR2
Rollback
Return

#######################################
$ROL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

########################################
$TR2
LIG=1
For [F:FGR]FGR0 Where evalue (CRITCPY)& evalue(CRITFCY)
 Read [F:FCY]FCY0 = [F:FGR]FCY
 SITE=[F:FCY]FCY
 Gosub TR_INIT
 For [F:DCH]DCH1 Where CAI=GINDURS & OPTSAL<>6 & OPTSAL<>7
  Gosub REINIT From INITDCH
  Gosub RECUP_RUB From INITDCH
  If OK =1
  #87135 : CICE
  Read[F:ADI]CODE=377;[F:DCH]CODDCS
  If !fstat
    If [F:ADI]A2='400'
      Gosub TR_CICE
    Else
     For [F:VEP]VEP0(1) Where PYRDAT>=VDATDEB & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
      NBVEP=0
      MATRI=[F:VEP]EMP
      Read [ID]ID0=MATRI
      #63102 : Lectures inutiles = ralentissements
      If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
      #
      For [F:VEP]VEP0
       DATMAT=[F:VEP]ENDDAT
       CTR=[F:VEP]CTRNUM
       #63102
       #Gosub LECEMP From WPDEFTABLE
       Gosub LECEMP From INITDCH
       #
       FLAG=1 :  DREF=[F:VEP]PYRDAT
       Gosub CODEXO From INITDCH
       Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
       If ORGANISME="" or ORGANISME=ORGCOURANT
        Gosub POPULATION From INITDCH
        If SALOK
         Gosub REINIT From INITDCH
         For R=1 To NRUB
          Read[RUB]RUB0=GCURLEG;RUBCOD(R)
          If fstat : Break : Endif
          VDEBUT=0 : VFIN=0
          Case TYPECAL(R)
           When 1 : VDEBUT=1 : VFIN=1 :#PS
           When 2 : VDEBUT=2 : VFIN=2 :#PP
           When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
          Endcase
          If VDEBUT
           Gosub RECUP_AT From INITDCH
           For I=VDEBUT To VFIN
            Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
            If !fstat
             If FLGQTY(R)=2
               QTY+=[F:HSP]BAS
             Else
              TAUX+=[F:HSP]RAT
              If I=1   :#salarial
               BASESAL=[F:HSP]BAS
              Else     :#patronal
               BASEPAT=[F:HSP]BAS
              Endif
              MONTANT+=[F:HSP]AMT
             Endif
            Endif
            Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
            If !fstat & FLGQTY(R)<>2  :#pas une quantité
             BASEREG+=[F:HSP]AMT
            Endif
           Next I
           LIMITE_BASE=0
           If [F:DCH]TYPBAS=2 :#cas particulier
            Gosub CAS_PART From INITDCH
           Endif
           Gosub AFFECT_BASE From INITDCH
           BASESAL=0 : BASEPAT=0
          Endif
         Next R
         If BASE<>0 :
          REGUL=1
          #87135: Loi CICE
          Gosub LOI_CICE From INITDCH
          Gosub ECRIT_LIGNES
          If !GOK : Break 4 : Endif
         Endif
         If BASEREG<>0 #Ecrire une 2ième ligne
          BASE=BASEREG
          TAUX=100 : TAUXAT=0
          MONTANT=BASEREG
          REGUL=2
          Gosub ECRIT_LIGNES
          If !GOK : Break 4 : Endif
         Endif
        Endif
       Endif
      Next :#VEP
     Next :#VEP
    Endif
   Endif
  Endif
 Next :#DCH
Next : #FGR
If !GOK : Return : Endif
If ARRBASE=2 or ARRMONTANT=2
 Gosub ARRONDIR From INITDCH
Endif
Return

########################################
$TR_CICE
Local Date DATDEBCICE
Local Char DMA (2)
Raz DMA
DMA=func AFNC.PARAM("DMA", [F:FCY]FCY)
If DMA='' : DMA='12' : Endif
If DMA='12'
 DATDEBCICE=gdat$(1,1,year(VDATFIN))
Else
  If month(VDATFIN)=val(DMA)+1
   DATDEBCICE=gdat$(1,month(VDATFIN), year(VDATFIN))
  Else
   DATDEBCICE=gdat$(1,val(DMA)+1,year(VDATFIN)-1)
  Endif
Endif
For [F:VEP]VEP0(1) Where PYRDAT>=DATDEBCICE & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
 NBVEP=0
 MATRI=[F:VEP]EMP
 Read [ID]ID0=MATRI
 #63102 : Lectures inutiles = ralentissements
 If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
 #
 For [F:VEP]VEP0
   DATMAT=[F:VEP]ENDDAT
   CTR=[F:VEP]CTRNUM
   #63102
   #Gosub LECEMP From WPDEFTABLE
   Gosub LECEMP From INITDCH
   #
   FLAG=1 :  DREF=[F:VEP]PYRDAT
   Gosub CODEXO From INITDCH
   Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
   If ORGANISME="" or ORGANISME=ORGCOURANT
     Gosub POPULATION From INITDCH
     If SALOK
      Gosub REINIT From INITDCH
      For R=1 To NRUB
       Read[RUB]RUB0=GCURLEG;RUBCOD(R)
       If fstat : Break : Endif
       VDEBUT=0 : VFIN=0
       Case TYPECAL(R)
           When 1 : VDEBUT=1 : VFIN=1 :#PS
           When 2 : VDEBUT=2 : VFIN=2 :#PP
           When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
       Endcase
       If VDEBUT
         Gosub RECUP_AT From INITDCH
         For I=VDEBUT To VFIN
          Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
          If !fstat
           If FLGQTY(R)=2
             QTY+=[F:HSP]BAS
           Else
            TAUX+=[F:HSP]RAT
            If I=1   :#salarial
             BASESAL=[F:HSP]BAS
            Else     :#patronal
             BASEPAT=[F:HSP]BAS
            Endif
            MONTANT+=[F:HSP]AMT
           Endif
          Endif
          Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
          If !fstat & FLGQTY(R)<>2  :#pas une quantité
           BASEREG+=[F:HSP]AMT
          Endif
         Next I
         LIMITE_BASE=0
         If [F:DCH]TYPBAS=2 :#cas particulier
          Gosub CAS_PART From INITDCH
         Endif
         Gosub AFFECT_BASE From INITDCH
         BASESAL=0 : BASEPAT=0
       Endif
      Next R
      If BASE<>0 :
       REGUL=1
       #87135: Loi CICE
       Gosub LOI_CICE From INITDCH
       Gosub ECRIT_LIGNES
       If !GOK : Break 4 : Endif
      Endif
      If BASEREG<>0 #Ecrire une 2ième ligne
        BASE=BASEREG
        TAUX=100 : TAUXAT=0
        MONTANT=BASEREG
        REGUL=2
        Gosub ECRIT_LIGNES
        If !GOK : Break 4 : Endif
      Endif
     Endif
   Endif
 Next :#VEP
Next :#VEP
Return

########################################
$TR_INIT
TYPCAI=GINDURS
NUMBORD=""

Call PARAM([F:FCY]FCY,"DMA",VALPAR) From ADOVAL
If val(VALPAR)=0 : VALPAR="12" : Endif
If val(VALPAR)=12
 VCOTDEB=VDATDEB
 VCOTFIN=VDATFIN
Else
 VCOTDEB=addmonth(VDATDEB,-1)
 VCOTFIN=eomonth(addmonth(VDATFIN,-1))
Endif

#Salariés présents sur la période
Filter [HRCTR] Where ETRFCY=[F:FCY]FCY & CTRDAT<=VCOTFIN & (XITDAT=[0/0/0] | XITDAT>=VCOTDEB)
For [HRCTR]CTR0(1)
 Read [F:ID]ID0=[HRCTR]REFNUM
 For [HRCTR]CTR0
  Gosub CTRL_EFF From TRTDUXTR
  If !GOK : Break 2 : Endif
  If VALSAL=1 : Break : Endif        :#compté donc on change de salarié
 Next
Next
Filter [HRCTR] 
##**
Return

########################################
$ECRIT_LIGNES
Gosub LOI_TEPA From INITDCH
NBVEP+=1
Gosub ECRIT_ENTETE
If !GOK : Return : Endif
FLAG=0
Raz [F:TM2]
For[F:TM2]TM20 Where USR=GUSER & NUMREQ=[L]NUMREQ & DCHFCY=SITE & DCHCAI=[F:DCH]CAI & DCHORG=ORGCOURANT & CODDCC=[F:DCH]CODDCC
 If [F:TM2]WACRAT=TAUXAT & [F:TM2]FLGREG=REGUL & (([F:TM2]RAT=TAUX-TAUXAT) | ([F:DCH]CAI=GINDURS & ([F:ADI]A2="003" |[F:ADI]A2="004"| [F:ADI]A2="005")))
  #Même taux donc même ligne...
  FLAG=1
  [F:TM2]BAS+=BASE
  [F:TM2]AMT+=MONTANT
  #Quantité pour Heures supp (Loi TEPA)
  [F:TM2]QTY2+=QTY

#87135 : CICE
#  If  NBVEP=1 :#Si le salarié a plusieurs payes on ne le compte qu'une fois.
#   If [F:ID]CIV=1
#    [F:TM2]NBRMEN+=1
#    [F:TM2]NBREMP+=1
#   Else
#    [F:TM2]NBRWOM+=1
#    [F:TM2]NBREMP+=1
#   Endif
#  Endif

  If [F:ADI]A2="400" & CODDCC=[F:DCH]CODDCC
   If NBVEP=1 & BASE>0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
    Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
    Endif
   Elsif BASE<0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN-=1
      [F:TM2]NBREMP-=1
    Else
      [F:TM2]NBRWOM-=1
      [F:TM2]NBREMP-=1
    Endif
    NBVEP=0
   Endif
  Else
   If NBVEP=1 & CODDCC=[F:DCH]CODDCC
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
     Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
     Endif
   Endif
  Endif
#
  Rewrite [F:TM2]
  If fstat<>0
   GOK = 0 : Call FSTA("TM2") From GLOCK
  Endif
  Break
 Endif
Next
If !GOK : Return : Endif
If FLAG=0
 [F:TM2]DAT=date$
 [F:TM2]USR=GUSER
 [F:TM2]NUMREQ=[L]NUMREQ
 [F:TM2]DCHFCY=SITE
 [F:TM2]DCHCAI=[F:DCH]CAI
 [F:TM2]DCHORG=ORGCOURANT
 [F:TM2]CODDCC=[F:DCH]CODDCC
 [F:TM2]NUMLIG=LIG
 LIG+=1
 [F:TM2]NUMORD=[F:DCH]NUMORD
 [F:TM2]CODLIG=[F:DCH]CODEDT1+[F:DCH]CODEDT2
 [F:TM2]DESLIG=[F:DCH]DESEDT
 [F:TM2]FLGREG=REGUL
 [F:TM2]BAS=BASE
 [F:TM2]AMT=MONTANT
 #Quantité pour Heures supp (Loi TEPA)
 [F:TM2]QTY2=QTY
 [F:TM2]WACRAT=TAUXAT
 Gosub WR_TEPA From INITDCH
 [F:TM2]TOTRAT=[F:TM2]RAT+[F:TM2]WACRAT
 If [F:ID]CIV=1
  [F:TM2]NBRMEN=1
  [F:TM2]NBRWOM=0
  [F:TM2]NBREMP=1
 Else
  [F:TM2]NBRMEN=0
  [F:TM2]NBRWOM=1
  [F:TM2]NBREMP=1
 Endif
 Write [F:TM2]
 If fstat<>0
  GOK = 0 : Call FSTA("TM2") From GLOCK
 Endif
Endif
Return

#######################################
$ECRIT_ENTETE
Raz [F:TM1]
Read[F:TM1]TM10=GUSER;[L]NUMREQ;SITE;[F:DCH]CAI;ORGCOURANT
###35211
If fstat=5
 [F:TM1]USR=GUSER
 [F:TM1]NUMREQ=[L]NUMREQ
 [F:TM1]DCHFCY=SITE
 [F:TM1]DCHCAI=[F:DCH]CAI
 [F:TM1]DCHORG=ORGCOURANT
 #Effectif
 #Nb de salarié inscrit pour ce site et cet organsime...
 Read[F:HRTDE]TDE0=GUSER;[F:FCY]FCY;ORGANISME
 If !fstat
  [F:TM1]NBRXIT = [F:HRTDE]NBREMPMRK
  [F:TM1]NBREMP= [F:HRTDE]NBREMPPAY
 Endif
 Call ORGAFFIL (ORGCOURANT,SITE,"","",[F:TM1]NUMAFF,VNUMCTR) From SUBORA
 Write [F:TM1]
 If fstat<>0
  GOK = 0 : Call FSTA("TM1") From GLOCK
 Endif
Endif
Return
