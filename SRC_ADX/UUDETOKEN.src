#<AdxTL>@(#)7.0.0.0 $Revision$
Local Integer OK
Local Char    TIT(80) , APPLI(GLONADS)
TIT = "Détokenisation"
Call SAICAR(APPLI,TIT,mess(85,115,1),"ADS",0,0,"",OK) From GESECRAN : # Dossier
If OK<>2 : End : Endif
TIT -= APPLI
Call OUVRE_TRACE(TIT) From LECFIC
Call DETOKEN(TIT,APPLI,0,1)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog DETOKEN(TIT,APPLI,TEST,TRACE)
Value Char    TIT , APPLI
Value Integer TEST , TRACE

Local Integer I , J , K, TROUV, NBAPP, MODIF
Local Integer NBTYP , NBZONE
Local Char    TYP(GLONATY)(1..1000)
Local Char    LISTAPP(GLONADS)(1..10),LISTMAC(GLONAMC)(1..10)
Local Char    ZONE(GLONAVA)(1..100)
Local Integer DIME(1..100)
Local Char    FICHIER(GLONATB) , OVAL(250) , NVAL(250) , TEXTE(250)

If !GSERVEUR & !(dim(GINFO)>0 & GINFO)
 Call TEMPON(TIT) From GESECRAN
Endif

Local File =APPLI+".ATABZON" [ATZ] , =APPLI+".ATYPE" [ATY] , =APPLI+".ATABLE" [ATB]

For [ATY]CODTYP
 If instr(1,[F:ATY]OPTION,"T")
  NBTYP += 1 : TYP(NBTYP) = [F:ATY]CODTYP
 Endif
Next

#  Charge les applications "mères"

For I=1 To 8
 If adxmother(I)="" : Break 1 : Endif
 If adxmother(I)<>APPLI
  If NBAPP=0
   NBAPP+=1 : LISTAPP(NBAPP)=adxmother(I) : LISTMAC(I)=adxmac(I)
  Else
   TROUV=0
   For J=1 To NBAPP
    If LISTAPP(J)=adxmother(I) : TROUV=1 : Break 1 : Endif
   Next J
   If TROUV=0 : NBAPP+=1 : LISTAPP(NBAPP)=adxmother(I): LISTMAC(I)=adxmac(I) : Endif
  Endif
 Endif
Next I

For [ATZ]CODZONE(1)
 NBZONE = 0
 FICHIER = [F:ATZ]CODFIC
 For [ATZ]CODZONE
  If find([F:ATZ]CODTYP,TYP(1..NBTYP)) or instr(1,[F:ATZ]OPTION,"T")
   NBZONE += 1 : ZONE(NBZONE) = [F:ATZ]CODZONE
  Endif
 Next ATZ
 If NBZONE>0
# Recherche la localisation du fichier 
  If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>=0
   Local File =APPLI+"."+FICHIER [WWW]
   Call ECR_TRACE(mess(56,123,1)-":"-FICHIER,0) From GESECRAN
  Else
   TROUV=0
   For I=1 To NBAPP
    If filinfo(filpath("FIL",FICHIER,"fde",LISTAPP(I)),0)>=0
     TROUV=1
     Local File =LISTMAC(I)+LISTAPP(I)+"."+FICHIER [WWW]
     If TRACE
      Call ECR_TRACE(mess(56,123,1)-": ++ "-LISTAPP(I)+" ++"-FICHIER,0) From GESECRAN
     Endif
     Break 1
    Endif
   Next I
   If TROUV=0 : Goto SUITM1 : Endif
  Endif

  TEXTE = ""
  For I=1 To NBZONE
   TEXTE -= ZONE(I)
   DIME(I) = evalue("dim([F:WWW]"+ZONE(I)+")")-1
  Next I
  If TRACE
   Call ECR_TRACE(TEXTE,0) From GESECRAN
  Endif
  Trbegin [WWW]
   For [WWW]
    MODIF = 0
    For I=1 To NBZONE
     For J=0 To DIME(I)
      OVAL = evalue("[F:WWW]"+ZONE(I)+"("+num$(J)+")")
      NVAL = vireblc(format$("KT:250X",OVAL),2)
      If OVAL<>NVAL
       If TRACE
        Call ECR_TRACE("  "+ZONE(I)-":"-OVAL+"/"+NVAL,-1) From GESECRAN
       Endif
       Assign "[F:WWW]"+ZONE(I)+"("+num$(J)+")" With NVAL
       MODIF = 1
      Endif
     Next J
    Next I
    If !TEST & MODIF
     Rewrite [WWW]
     If fstat
      Call ERREUR(FICHIER,2) From DOSDIC
     Endif
    Endif
   Next WWW
  Commit
  Close Local File [WWW]
$SUITM1:
 Endif
Next ATZ

Close Local File [ATZ] , [ATY] , [ATB]

If !GSERVEUR & !(dim(GINFO)>0 & GINFO)
 Call TEMPOFF From GESECRAN
Endif

End
