#<AdxTL>@(#)0.0.0.0 $Revision$Class Degrees
# Supervisor
## CRUD-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:13 263


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOEXM

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOEXM

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOEXM
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOEXM
Else
 Gosub AINSERT_EMPLOEXM
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOEXM.freeSnapshot
EMPLOEXM.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOEXM.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOEXM.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOEXM
Trbegin [F:HREXM]
 Gosub AINSERT_EMPLOEXM
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOEXM
Raz [F:HREXM]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOEXM._MAJSQL_EMPLOEXM(EMPLOEXM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOEXM.snapshotEnabled=1
 [L]A_RETIK = EMPLOEXM.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOEXM.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOEXM.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOEXM.ASTALIN = [V]CST_ALL
Endif
Return



