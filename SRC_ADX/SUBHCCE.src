#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################
# SUBHCCE : Saisie des sections analytiques entête       MBT 15/09/06 #
#           en contrôle des factures achats                           #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
#        saisie des sections analytiques entête et ne sert qu'à       #
#        gérer le MASQUE écran "HEACCE [HCCE]".                       #
#######################################################################


Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If !find(status,1,4,5,20,21,26,92,93) End : Endif 
#----- Contrôle sections obligatoires si celles-ci sont saisies -----#
If [M:HCEE]NBAXE>0 & GHEADIE=1 & varmode([M:HCEE]CCE,0)=0
  Local Integer I
  For I=1 To [M:HCEE]NBAXE
    If [M:HCEE]CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End
