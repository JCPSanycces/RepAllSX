#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Program Name: ECMSEB (XJZBPCC)
# Description:  Dom test sub-program
# Created Date: 17/11/2015
# Created By:   Dom Nash
# Called by Web Service ECMSEB (WSXJZXBP)
#-------------------------------------------------------
# Input Parameters:
# BPCNUM   - Customer Number
# ACCNAM - Account Default Name
# PRCCOD
# CRDTYP
# CCEXPIRY
# CCV#ACCL4D
# ADDLIG0
# ADDLIG1
# CTY
# SAT
# POSCOD
# CRY
# EMAIL
# SVLTUID
#-------------------------------------------------------
# Output Parameters:
# RESULT  - This is an error containing any errors
#######################################################
Subprog PAYMENT_DATA(BPCNUM,ACCNAM,PRCCOD,CRDTYP,CCEXPIRY,CCV,ACCL4D,ADDLIG0,ADDLIG1,CTY,SAT,POSCOD,CRY,EMAIL,SVLTUID,NICKNAME,RESULT)
  Variable Char BPCNUM
  Variable Char ACCNAM
  Variable Char PRCCOD
  Variable Char CRDTYP
  Variable Char CCEXPIRY
  Variable Char CCV
  Variable Char ACCL4D
  Variable Char ADDLIG0
  Variable Char ADDLIG1
  Variable Char CTY
  Variable Char SAT
  Variable Char POSCOD
  Variable Char CRY
  Variable Char EMAIL
  Variable Char SVLTUID
  Variable Char NICKNAME
  Variable Char RESULT

  Local Integer ERR : ERR = 0
  Local Integer CCEXISTS : CCEXISTS = 0
    # Validate Input Data
    ######################
    #Open SEBPC Table
    If clalev([F:SEB]) = 0 : Local File SEBPC [SEB] : Endif

    # Open BPCUSTOMER Table & validate BPCNUM
    If clalev([F:BPC])= 0 : Local File BPCUSTOMER [BPC] : Endif
    Read [F:BPC]BPC0=BPCNUM
    If fstat
        RESULT = mess(5,7730,1)   # Invalid customer number ("Invalid Customer")
        ERR = ERR + 1
    Else
        If ACCNAM = ""
            RESULT = mess(23,7730,1)    # Account name required ("No account name detected")
            ERR = ERR + 1
        Endif
    Endif

    If NICKNAME = ""
        NICKNAME = func ASYRFNC.TEXTE(1000985)  # E-commerce ("SYMPHONY")
    Endif
    If ERR = 0
    Read [F:SEB]SEB0=BPCNUM+NICKNAME
    If !fstat
            If [F:SEB]ACCNAM = ACCNAM and [F:SEB]EXPDAT = CCEXPIRY and [F:SEB]ACCL4D= ACCL4D
        CCEXISTS = 1
      Endif
        Endif

    Raz [F:SEB]
    [F:SEB]BPCNUM = BPCNUM    # Customer
    [F:SEB]ACCNAM = ACCNAM    # CC Name
    [F:SEB]PRCCOD = PRCCOD    # Processing code
    [F:SEB]ACCNCKNAM = NICKNAME # Nickname
    [F:SEB]ADDLIG(0) = ADDLIG0  # Address 1
    [F:SEB]ADDLIG(1) = ADDLIG1  # Address 2
    [F:SEB]CTY = CTY          # City
    [F:SEB]SAT = SAT          # State
    [F:SEB]POSCOD = POSCOD      # Zip
    [F:SEB]CRY = CRY            # Country
    [F:SEB]EMAIL = EMAIL        # Email
    [F:SEB]AUUID = AUUID        # Single Identifier
    [F:SEB]VLTGUID = SVLTUID    # Vault GUID
    [F:SEB]USEBILLADR = 2       # Billing Address
    [F:SEB]FLACT = 2            # Active
    [F:SEB]FLDEF = 2            # Default
    [F:SEB]VLTREQ = 1           # Request
    [F:SEB]EXPDAT= CCEXPIRY     # Expiry Date
    [F:SEB]ACCL4D= ACCL4D       # Last 4 Digits
    [F:SEB]CRDTYP= CRDTYP       # Card Type
    If CCEXISTS = 1
      Rewrite [F:SEB]
    Else
      Write [F:SEB]
    Endif
    If fstat = 1
      RESULT = mess(20,7730,1)   # Error creating or updating payment gateway customer data ("Error creating Sage Exchange customer data")
      ERR = ERR + 1
    Else
      RESULT = mess(16,7730,1)   # Success
    Endif
    Endif

  Close Local File [SEB]
  Close Local File [BPC]
End





