##########################################################################################################
#   Programmes utilitaires pour la gestion des affaires          Module CRM     27 Septembre 2000
##########################################################################################################
#
# SETAFFVALCUR  :Affect la valeur de la devise dans les zones d'affichages
#   SETSREINF    : Affecte les valeurs par défaut relatives à une demande de service.
#   SETSTEINF    : Met à jour les différentes étapes du cycle de vente.
#   ADDOPPSTE    : Ajoute une étape avant-vente d'affaire
#   SETPREOPP    : Mémorise le code de l'affaire précédente sur une devis, commande, appel ou rdv
#   SETMKGORI    : Enregistre l'origine marketing d'une commande ou d'une facture directe.
#   DISPCCN      : Affichage de l'interlocuteur
#   DISPBKGCCN   : Affichage du background de l'interlocuteur
#   SETOPPREACDA : Défini la date effective de conclusion de l'affaire
#
#  DEFOBJORI    : Définition du type de pièce
#  VERIFORI     : Vérification cohérence entre origine et numéro de pièce
#  GERE_LCM_CREATION  : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF     : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE    : gere les données  pour la gestion des en cours en annulation
##########################################################################################################
##########################################################################################################
Subprog AFFICHE_BCK_TIERS(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZTYP(GLONDES)

  Call GETBPRTYP(SZBPRNUM, SZTYP, [M:OPP0]OPPCMPAOB) From CRM_UTIL
  Chgtzn [M:OPP0]OPPCMP With SZTYP
  [M:OPP0]OPPCMPLIB = SZTYP
End

##########################################################################################################
#Affect la valeur de la devise dans les zones d'affichages
Subprog SETAFFVALCUR(SZCUR)
Value Char SZCUR

  [M:OPP1]OPPCUR1 = SZCUR
  [M:OPP1]OPPCUR2 = SZCUR
  [M:OPP1]OPPCUR3 = SZCUR
  [M:OPP1]OPPCUR4 = SZCUR
  Affzo [M:OPP1]OPPCUR1
  Affzo [M:OPP1]OPPCUR2
  Affzo [M:OPP1]OPPCUR3
  Affzo [M:OPP1]OPPCUR4
End

##########################################################################################################
#Gere l'accessibilité des zones suivant le type d'interlocuteur (Piste ou non)
$GEREECRAN
Local Integer IBENABLE

  IBENABLE = [V]CST_ATRUE
  If [M:OPP0]OPPCMP = "" Then
    If [M:OPP0]CCNTYP = 2 Then
      IBENABLE = [V]CST_AFALSE
    Endif
  Endif
  If IBENABLE = [V]CST_AFALSE Then
    Diszo [M:OPP4]NBOPP4
  Else
    Actzo [M:OPP4]NBOPP4
  Endif
Return

##########################################################################################################
Funprog IS_AFFAIRE_CRM(SZOPPNUM)
Value Char SZOPPNUM

Local Integer IARENDRE

  Local File PIMPL [PIM]
  IARENDRE = [V]CST_AYES
  Read [PIM]PIM0=SZOPPNUM
  If fstat Then
    IARENDRE = [V]CST_ANO
  Else
    If [F:PIM]PIMTYP <> 1 and [F:PIM]PIMTYP <> 3 Then
      # Ca n'est pas une affaire CRM : on repart sans rien faire. c'est bon.
      IARENDRE = [V]CST_ANO
    Endif
  Endif
End IARENDRE

##########################################################################################################
# Mémorise le code de l'affaire précédente sur une devis, commande, appel ou rdv
#############################################################
Subprog SETPREOPP(SZCONTEXT)
Value Char SZCONTEXT

Local Integer NI

  If SZCONTEXT = "BAP" Then
    If [M:BAP0]APTDON = 2 Then
      [M:BAP0]PREOPP = [M:BAP0]APTPJT
    Else
      [M:BAP0]PREOPP = ""
    Endif
  Elsif SZCONTEXT = "CLL" Then
    If [M:CLL0]CLLDON = 2 Then
      [M:CLL0]PREOPP = [M:CLL0]CLLOPP
    Else
      [M:CLL0]PREOPP = ""
    Endif
  Elsif SZCONTEXT = "SQH" Then
    [M:SQH1]PREOPP = [M:SQH1]PJT
    For NI = 0 To [M:SQH2]NBLIG-1
      [M:SQH2]DPREOPP(NI) = [M:SQH2]DPJT(NI)
    Next NI
  Elsif SZCONTEXT = "SOH" Then
    [M:SOH1]PREOPP = [M:SOH1]PJT
    For NI = 0 To [M:SOH4]NBLIG-1
      [M:SOH4]DPREOPP(NI) = [M:SOH4]DPJT(NI)
    Next NI
  Endif
End

##########################################################################################################
# Enregistre l'origine marketing d'une commande ou d'une facture directe.
#############################################################
Subprog SETMKGORI(SZCONTEXT, SZOPPNUM)
Value Char SZCONTEXT
Value Char SZOPPNUM

  If GMODU(13) <> 2 Then
    End
  Endif
  If func IS_AFFAIRE_CRM(SZOPPNUM) = [V]CST_ANO Then
    End
  Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If SZCONTEXT = "SOH" Then
    If SZOPPNUM <> "" Then
      Read [OPP]OPP0=SZOPPNUM
      If !fstat Then
        [M:SOH1]CMGNUM = [F:OPP]OPPCMGNUM
        [M:SOH1]OPGNUM = [F:OPP]OPPOPGNUM
        [M:SOH1]OPGTYP = [F:OPP]OPPOPGTYP
      Endif
    Endif
  Elsif SZCONTEXT = "SIH" Then
    If [M:SIH1]SIHORI = 1 Then
      If SZOPPNUM <> "" Then
        Read [OPP]OPP0=SZOPPNUM
        If !fstat Then
          [M:SIH1]CMGNUM = [F:OPP]OPPCMGNUM
          [M:SIH1]OPGNUM = [F:OPP]OPPOPGNUM
          [M:SIH1]OPGTYP = [F:OPP]OPPOPGTYP
        Endif
      Endif
    Else
      [M:SIH1]CMGNUM = ""
      [M:SIH1]OPGNUM = ""
      [M:SIH1]OPGTYP = ""
    Endif
  Endif
End

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:OPP0]OPPMCN = "" Then
    [M:OPP0]CCNTYP = 1
  Else
    Read [AIN]AIN0=[M:OPP0]OPPMCN
    If fstat Then
      [M:OPP0]CCNTYP = 1
    Else
      [M:OPP0]CCNTYP = [F:AIN]CNTTYP
    Endif
  Endif
  If [M:OPP0]CCNTYP = 1 Then
    [M:OPP0]CCNOBJ = "AIN"
  Else
    [M:OPP0]CCNOBJ = "LDS"
  Endif
Return

##########################################################################################################
#Affichage du background de l'interlocuteur
######################################################
$DISPBKGCCN
  If GIMPORT Then
    Return
  Endif
  If [M:OPP0]CCNTYP = 0 Then
    [M:OPP0]CCNTYP = 1
  Endif
  Chgtzn [M:OPP0]OPPMCN With mess([M:OPP0]CCNTYP,3038,1)
  If [M:OPP0]CCNTYP = 1 Then
    [M:OPP0]CCNOBJ = "AIN"
  Else
    [M:OPP0]CCNOBJ = "LDS"
  Endif
Return

##########################################################################################################
#Définition du type de pièce
$DEFOBJORI
  Case [M:OPP1]OPPORI
    When 0
      [M:OPP1]OPPORIOBC = ""
      [M:OPP1]OPPORIAVA = ""
    When 1
      [M:OPP1]OPPORIOBC = ""
      [M:OPP1]OPPORIAVA = ""
    When 2
      [M:OPP1]OPPORIOBC = "OMM"
      [M:OPP1]OPPORIAVA = "OMMNUM"
    When 3
      [M:OPP1]OPPORIOBC = "OMP"
      [M:OPP1]OPPORIAVA = "OMPNUM"
    When 4
      [M:OPP1]OPPORIOBC = "OMT"
      [M:OPP1]OPPORIAVA = "OMTNUM"
    When 5
      [M:OPP1]OPPORIOBC = "OMN"
      [M:OPP1]OPPORIAVA = "OMNNUM"
    When 6
      [M:OPP1]OPPORIOBC = "SRE"
      [M:OPP1]OPPORIAVA = "SRENUM"
    When 7
      [M:OPP1]OPPORIOBC = "CMG"
      [M:OPP1]OPPORIAVA = "NUM"
    When Default
  Endcase
Return

