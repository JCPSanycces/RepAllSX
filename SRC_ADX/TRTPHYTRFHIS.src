#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# AFFICHAGE DES IMPUTATIONS DU BIEN AVANT LE DERNIER TRANSFERT ANA / GEO
#
# Création le :     18/12/2007
# Modification le : XX/XX/XXXX
################################################################################$
#
#    USR - DD.MM.YYYY FQnnnnn : Comment
# MDJ   09.02.2015 FQ100398 : Suppression site géographique
# GBO   20.01.2011 FQ68447  : Contrôle des sources
################################################################################
$ACTION

  Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When Default
   Endcase
Return


################################################################################
$OUVRE
Local Char    BCOREF
Local Char    BCOCPY
Local Char    BCOFCY
Local Date    BCOTRFDAT
Local Char    EVTTRF : EVTTRF="PHYAFFGEO"
Local Integer ANNEE
Local Integer MOIS
Local Integer JOUR

  BCOCPY    = PARAM(1)
  BCOFCY    = PARAM(2)
  BCOREF    = PARAM(3)
  ANNEE     = val(left$(PARAM(4),4))
  MOIS      = val(mid$(PARAM(4),5,2))
  JOUR      = val(right$(PARAM(4),7))
  BCOTRFDAT = gdat$(JOUR,MOIS,ANNEE)
Return


################################################################################
$DEBUT
Local Integer NBREVT  : NBREVT=0
Local Integer I_AXE
Local Char    SECTION
Local Integer PLAN

  PLAN = func TRTPHYTRFHIS.GET_PLN_EVE_TRF(BCOCPY,BCOFCY,BCOREF,BCOTRFDAT)

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  Filter [F:TB0] Where (CPY=BCOCPY & DPRPLN=PLAN & REF=BCOREF & EVTDAT=BCOTRFDAT)
  Filter [F:TB0]

  # [M:FASH]FCY    = [F:TB0]FCY
  # [M:FASH]LOC    = [F:TB0]LOCO
Return


################################################################################
Subprog LST_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT,REVEPLN)
Value    Char    PCPY       # Société du BCO
Value    Char    PFCY       # Site du BCO (Obsolète)
Value    Char    PREF       # référence du BCO
Value    Date    PEVTDAT    # Date d'effet du transfert
Variable Integer REVEPLN(0..) # Liste de flag d'existence d'un événement par plan

Local Integer I_PLN

  For I_PLN=1 To G301MAX
    REVEPLN(I_PLN-1)=G_NON
  Next I_PLN

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  Filter [TB0] Where (CPY=PCPY & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT)
  For [TB0]EVE0
    REVEPLN([F:TB0]DPRPLN-1)=G_OUI
  Next
  Filter [TB0]
End


################################################################################
Funprog GET_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT)
Value    Char    PCPY       # Société du BCO
Value    Char    PFCY       # Site du BCO (Obsolète)
Value    Char    PREF       # référence du BCO
Value    Date    PEVTDAT    # Date d'effet du transfert

Local Integer PLAN
Local Integer I_PLN
Local Integer EVEPLN(0..G301MAX-1)

  Call LST_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT,EVEPLN) From TRTPHYTRFHIS

  PLAN=0

  For I_PLN=1 To G301MAX
    If EVEPLN(I_PLN-1)=G_OUI Then
      PLAN=I_PLN
      Break
    Endif
  Next I_PLN
End PLAN


################################################################################
Funprog EXISTE_EVE_TRF(PCPY,PPLN,PFCY,PREF,PEVTDAT)
Value Char    PCPY          # Société du BCO
Value Integer PPLN          # Plan d'amortissement à vérifier
Value Char    PFCY          # Site du BCO
Value Char    PREF          # Référence du BCO
Value Date    PEVTDAT       # Date d'effet de l'événement à retrouver.

Local Integer EXISTE : EXISTE=0

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  Filter [F:TB0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT)
  Read[TB0]EVE0 Last
  Filter [F:TB0]

  If fstat=0 Then
    EXISTE=1
  Else
    EXISTE=0
  Endif
End EXISTE


#CHECK IGNORE_BEGIN
################################################################################
Subprog GET_ETRNOT_ORI(PCPY, PPLN, PFCY, PREF, PEVTDAT, RACGETRNOT, RIASETRNOT, RETOUR)
Value    Char    PCPY
Value    Integer PPLN
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Decimal RACGETRNOT
Variable Decimal RIASETRNOT
Variable Integer RETOUR

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  Filter [F:TB0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT)

  If fstat=0 Then
    RACGETRNOT = [F:TB0]ACGETRNOT
    RIASETRNOT = [F:TB0]IASETRNOT
    RETOUR=0
  Else
    Raz RACGETRNOT, RIASETRNOT
    RETOUR=1
  Endif

  Filter [F:TB0]
End
#CHECK IGNORE_END


######################################################################################
# Pour ce sous-programme, on suppose que la classe [F:EVT0] existe. Si l'événement
# est trouvé, il est chargé dans la classe et le code retour vaut 0. S'il n'est pas
# trouvé, le code retour vaut fstat
######################################################################################
Subprog CHARGE_EVE_TRF(PCPY,PPLN,PREF,PEVTDAT,RCOD)
Value    Char    PCPY
Value    Integer PPLN
Value    Char    PREF
Value    Date    PEVTDAT
Variable Integer RCOD

  Filter [F:EVT0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT)
  Read[EVT0]EVE0 Last
  Filter [F:EVT0]

  If fstat=0 Then
    RCOD=0
  Else
    RCOD=fstat
  Endif
End


################################################################################
# On recherche l'événement qui n'est pas un évt d'annulation, et qui n'a pas
# encore été annulé. Autrement dit, le dernier transfert non encore annulé
################################################################################
Funprog GET_EVE(PCPY,PFCY,PREF,PEVTDAT,RCOD)
Value Char    PCPY
Value Char    PFCY
Value Char    PREF
Value Date    PEVTDAT
Value Integer RCOD

Local Char TIMSTP_A


  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif

  Filter [F:TB0] Where (CPY=PCPY & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT & (EVEANN=G_NON or EVEANN=0))
  Read [F:TB0]EVE0 Last

  If fstat Then
    # RCOD=1
    End TIMSTP_A
  Endif

  TIMSTP_A = [F:TB0]TIMSTP
  Filter [F:TB0]
End TIMSTP_A


################################################################################
Subprog GET_IMPUT_ORI(PCPY,PFCY,PREF,PEVTDAT,RFCYORI,RLOCORI,RTRFDATORI,RMVTTRORI,RCOD)
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Char    RFCYORI
Variable Char    RLOCORI
Variable Date    RTRFDATORI
Variable Char    RMVTTRORI
Variable Integer RCOD

Local Integer    PLAN
Local Integer    NB_ANN
Local Char       TIMSTP_A

  # PLAN toujours égal à la même valeur pour les éléments physiques : 16
  # PLAN=func TRTPHYTRFHIS.GET_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT)

  Raz RCOD

  TIMSTP_A = func GET_EVE(PCPY,PFCY,PREF,PEVTDAT,RCOD)
  If TIMSTP_A <> "" Then
    If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
    Read [F:TB0]EVE0=PREF;TIMSTP_A

    RFCYORI    = [F:TB0]FCY
    RLOCORI    = [F:TB0]LOCO
    # RTRFDATORI = [F:TB0]EVTDAT
    RTRFDATORI = [F:TB0]LASTDATTRF
    RMVTTRORI  = [F:TB0]REN
  Endif
End


###############################################################################################################
# Récupération de l'origine depuis la gestion des évènements de transfert d'éléments physiques depuis les Biens
###############################################################################################################
Subprog GET_IMPUT_ORI_FAS(PCPY,PFCY,PREF,PEVTDAT,RFCYORI,RLOCORI,RTRFDATORI,RMVTTRORI,RCOD)
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Char    RFCYORI
Variable Char    RLOCORI
Variable Date    RTRFDATORI
Variable Char    RMVTTRORI
Variable Integer RCOD

Local Integer PLAN

  # PLAN toujours égal à la même valeur pour les éléments physiques : 16
  # PLAN=func TRTPHYTRFHIS.GET_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT)

  Raz RCOD

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  # transfert site financier
  Filter [F:TB0] Where (CPY=PCPY & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT
&                     &  FCY=PFCY) Order By Key EVE0 Asc
  # fin 49517 (SYMEU) : transfert site financier
  Read [F:TB0]EVE0 Last

  If fstat Then
    RCOD=1
    End
  Endif

  RFCYORI    = [F:TB0]FCY
  RLOCORI    = [F:TB0]LOCO
  RTRFDATORI = [F:TB0]LASTDATTRF
  RMVTTRORI  = [F:TB0]REN

  Filter [F:TB0]
End

###############################################################################################################
# 49517 (SYMEU) : transfert de site financier
# Récupération de l'origine depuis la gestion des évènements de transfert d'éléments physiques depuis les Biens
# quand on est en annulation de transfert
###############################################################################################################
Subprog GET_IMPUT_ORI_FAS_ANNUL(PCPY,PFCY,PREF,PEVTDA,RFCYORI,RLOCORI,RTRFDATORI,RMVTTRORI,RCOD)
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Char    RFCYORI
Variable Char    RLOCORI
Variable Date    RTRFDATORI
Variable Char    RMVTTRORI
Variable Integer RCOD

Local Integer PLAN

  Raz RCOD

  If !clalev([F:TB0]) : Local File EPHYAFFGEO [TB0] : Endif
  Filter [F:TB0] Where (CPY=PCPY & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT
&                     &  FCYD=PFCY) Order By Key EVE0 Asc
  Read [F:TB0]EVE0 Last

  If fstat Then
    RCOD=1
    End
  Endif

  RFCYORI    = [F:TB0]FCY
  RLOCORI    = [F:TB0]LOCO
  RTRFDATORI = [F:TB0]LASTDATTRF
  RMVTTRORI  = [F:TB0]REN

  Filter [F:TB0]
End
