#<AdxTL>@(#)6.0.0.0 $Revision$
#############################################################
#                                                           #
# Traitement lié à l'action de suppression de gamme         #
#                                                           #
#     Action : TRTROUSUP                                    #
#                                               07/01   MM  #
#############################################################
# Issue X3-57058 - 2017-10-09 by YARAM : Mass route deletion to block the removal of versioned routes.


$ACTION

Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase


Return

#############################################################
$INIT
Local Char WFIL (250), CLE1(30)
Local Char CLE2(30)(2)
Global Integer STOP
Local  Char    FORMULE1(255)

If clalev ([F:ACC])=0 : Local File ACCES[ACC]     : Endif
If clalev ([F:TRO])=0 : Local File TABROUALT[TRO] : Endif
If clalev ([F:ITF])=0 : Local File ITMFACILIT[ITF] : Endif


If clalev ([F:ROH])=0 : Local File ROUTING [ROH]  : Endif
If clalev ([F:ROO])=0 : Local File ROUOPE [ROO]   : Endif
If clalev ([F:ROS])=0 : Local File ROUSCD [ROS]   : Endif
If clalev ([F:ROT])=0 : Local File ROUOPESTD [ROT]: Endif

If clalev ([F:ADL])=0 : Local File ADELETE [ADL]   : Endif
If clalev ([F:A_OB])=0: Local File AOBJET  [A_OB]  : Endif
If clalev ([F:ATX])=0 : Local File ATEXTE  [ATX]   : Endif
If clalev ([F:ALI])=0 : Local File ALINK   [ALI]   : Endif
If clalev ([F:AOX])=0 : Local File AOBJTXT [AOX]   : Endif
If clalev ([F:AOM])=0 : Local File AOBJTXTA [AOM]  : Endif

If clalev([F:TFO])=0  : Local File TABFOR    [TFO] : Endif

Local Mask ROUSUP0 [DIA]
Return


#############################################################
$CONTROLE
Local Integer OK

# Pour gérer la fin sans validation

OK =1
# Issue X3-57058 - 2017-10-09 by YARAM : Mass route deletion to block the removal of versioned routes.
If func AFNC.ACTIV("RVM")
   Call OUINON(mess(20,196,1)+"\"+"\"+mess(418,193, 1), OK) From GESECRAN
Else
   Call OUINON(mess(20,196,1), OK) From GESECRAN
Endif
# End issue X3-57058
If OK<> 2  : SAI = 1 :  Return : Endif




Return


#############################################################
$EXEC
Local Integer WINT
# Issue X3-57058 - 2017-10-11 by YARAM : Mass route deletion to block the removal of versioned routes.
Local Integer WECCROU
WECCROU = func AFNC.ACTIV("RVM")    #activity code eccrou
# End issue X3-57058

Call OUVRE_TRACE(mess(143,190,1)) From LECFIC    #suppression gamme

# pour copier l'écran dans la trace
Call PRTSCR("ROUSUP0","DIA","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

#préparation du filtre de sélection
WFIL = "1=1"

If (([M:DIA]ITMREFDEB<>"") & ([M:DIA]ITMREFDEB=[M:DIA]ITMREFFIN))
    WFIL = "ITMREF = [M:DIA]ITMREFDEB"
Endif
WFIL += "& ROUALT = [M:DIA]ROUALT"
WFIL += "& FCY = [M:DIA]FCY"    # 30204 MM 06.05

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

# Issue X3-57058 - 2017-10-10 by YARAM : Mass route deletion to block the removal of versioned routes.
If WECCROU
  Call ECR_TRACE(mess(418,193,1) ,0) From GESECRAN
Endif
# End issue X3-57058

Call DEBTRANS From GLOCK
Trbegin [ROH]
Filter [ROH] Where evalue (WFIL) & evalue (FORMULE1)

For [ROH]
    STOP = 0
    # Test si gamme courante appartient à la sélection de gammes à copier
    If ( [M:DIA]ITMREFFIN<>"")
        If (([ROH]ITMREF< [M:DIA]ITMREFDEB) | ([ROH]ITMREF > [M:DIA]ITMREFFIN))
           STOP = 1
        Endif
    Endif
    If STOP <>1
       WINT =0         # MM  04.03
       Call ECR_TRACE(  " " ,0) From GESECRAN
       ERR_TRA = mess (63,198,1) - [ROH]ITMREF
       Call ECR_TRACE(  ERR_TRA ,0) From GESECRAN
       # Issue X3-57058 - 2017-10-12 by YARAM : Mass route deletion to block the removal of versioned routes.
       If WECCROU
          If func RVMLIB.NBRCPNROU([ROH]ITMREF) > 0
            Call ECR_TRACE(mess(416,193,1) ,0) From GESECRAN
            Goto NEXT_OPE
          Endif
       Endif
       # End issue X3-57058
       # Test si gamme supprimable
       # 30204 MM 06.05
       #CLE1 = [ROH]ITMREF
       #CLE2(0) = [M:DIA]FCY
       #CLE2(1) = num$([M:DIA]ROUALT)
       # FQ 52338 GA 02/2009 Beryl clé modifiée par Bordeaux ROH0=ITMREF+ROUALT+FCY
       CLE1    = num$([M:DIA]ROUALT)  # 2eme partie de clé pour l'objet ROU
       CLE2(0) = [ROH]ITMREF          # 1ere partie de clé
       CLE2(1) = [M:DIA]FCY           # 3eme partie de clé
       Call SUPPRIME("ROU", CLE1,CLE2)

       # demande 9993 MM  04.02
       # Test si gamme présente dans fiche article-site (article+alternative sr 03.05)
       Read [ITF]ITF0 = [ROH]ITMREF;[ROH]FCY
       If !fstat
         If (([ITF]MFGROU=[ROH]ITMREF & [ITF]MFGROUALT = [F:ROH]ROUALT) |
&            ([ITF]CSTROU= [ROH]ITMREF & [ITF]CSTROUALT = [F:ROH]ROUALT)|
&            ([ITF]RCCROU=[ROH]ITMREF & [ITF]RCCROUALT = [F:ROH]ROUALT))
             Call MESSAGE(mess(63,198,1)-[ROH]ITMREF-mess(166,190,1)+"."-mess(1,115,1)) From GESECRAN
             ERR_TRA = mess(63,198,1)-mess(166,190,1)
             Call ECR_TRACE(  ERR_TRA ,0) From GESECRAN
             Goto NEXT_OPE
         Endif
       Endif
    Endif

    If STOP <>1
        For [ROO]ROO0 Where  FCY = [ROH]FCY & ITMREF=[ROH]ITMREF & ROUALT=[ROH]ROUALT
             # rupture
             If WINT <>  [ROO]OPENUM
                 WINT = [ROO]OPENUM  # on stocke le numero d'opération courante

                 # MAJ de la table Gamme Jalonnement opérations = ROUSCD
                 Read [ROS]ROS0 = [ROO]FCY;[ROO]ITMREF;[ROO]ROUALT;[ROO]OPENUM    # 30204 MM 06.05
                 If fstat : GERR=1 : GMESSAGE=mess(297,196,1) : Break    # erreur de lecture
                 Endif
                 Delete [F:ROS]
                 If fstat <> 0 : GERR=1 : GMESSAGE=mess(28,125,1) :  Break # erreur d'effacement
                 Endif
             Endif
             # MAJ de la table Gamme opération = ROUOPE
             Delete [F:ROO]
             If fstat <> 0 : GERR=1 : GMESSAGE=mess(28,125,1) :  Break # erreur d'effacement
             Endif
        Next
        If GERR=1 : Goto  ROL_TRTJAL Endif

        # MAJ de la table Gamme entête = ROUTING
        Delete [F:ROH]
        If fstat <> 0 : GERR=1 : GMESSAGE=mess(28,125,1) :  Break # erreur d'effacement
           Goto  ROL_TRTJAL
        Endif
        ERR_TRA =  mess (144,190,1)
        Call ECR_TRACE(  ERR_TRA ,0) From GESECRAN
    Endif

$NEXT_OPE
Next

Filter [ROH]
Commit

Return
#############################################################
$ROL_TRTJAL
    Rollback :  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=9;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

#############################################################
Subprog SUPPRIME(OBJET,CLE1,CLE2)
Value Char OBJET
Value Char CLE1
Value Char CLE2
Local Char    TIT(80) , ACTION(20)
Local Integer OKANU , SAVSERV

SAVSERV  = GSERVEUR
GSERVEUR = 1
Read [A_OB]ABREV = OBJET
Local File =[F:A_OB]NOMFIC, =[F:A_OB]NOMFIC [AN__] # FQ 52338 GA 02/2009 Beryl avant [ANU_]

Call LECTURE(OBJET,CLE1,CLE2) From CONTOBJ
If fstat
 # 30204 MM 06.05
 Call ECR_TRACE(OBJET-mess(6,114,1)-":"-CLE2(0)-CLE1-CLE2(1),1) From GESECRAN : # Clé inexistante
 STOP =1
 Goto FIN_SUPP
Endif
Gosub DEFAUT From ="WO"+OBJET
[F:AN__] = [F]                                     # FQ 52338 GA 02/2009 Beryl avant [ANU_]

Call VERIF(nomap,OBJET,CLE1,CLE2,OKANU) From ANUCOD
If !OKANU
 Call ECR_TRACE(mess(184, 193,1 ),0) From GESECRAN    #suppression interdite
 STOP =1
 Goto FIN_SUPP
Else
 STOP =0                    # Gamme supprimable
Endif
$FIN_SUPP
GSERVEUR = SAVSERV
End




#############################################################
$SORTIE

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Raz[M:DIA]
Close Local Mask [DIA]

Return


################################################################################
#                                                                              #
# Etiquettes                                                                   #
#                                                                              #
################################################################################
########################################
#30204 MM 06.05
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
Raz [M:DIA]FCY
Actzo [M:DIA]FCY
End

########################################
#30204 MM 06.05
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
# on récupère le site d'origine, s'il existe
Read [TRO]TRO0 = [M:DIA]ROUALT

If  fstat : GMESSAGE=mess(297,196,1) : End : Endif
# erreur de lecture. La recherche est abandonnée
If [F:TRO]FCY<>""  : VALEUR = [F:TRO]FCY : Grizo [M:DIA]FCY : Affzo [M:DIA]FCY : Endif

End

########################################
Subprog C_ITMREFDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <>""
    Look[ROH]ROH1 =[M:DIA]FCY;VALEUR;[M:DIA]ROUALT    # 30204 MM 06.05
    If fstat : mkstat = 2 :GMESSAGE= mess(23,100,1) : End : Endif      # fiche inexistante
Endif

End

########################################
Subprog C_ITMREFFIN(VALEUR)
Variable Char    VALEUR()

If VALEUR < [M]ITMREFDEB
    GMESSAGE= mess(44,199,1) : mkstat = 2 : End
Endif

If VALEUR <>""
    Look[ROH]ROH1 = [M:DIA]FCY;VALEUR;[M:DIA]ROUALT    # 30204 MM 06.05
    If fstat : mkstat = 2 :GMESSAGE= mess(23,100,1) : End : Endif      # fiche inexistante
Endif

End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <>""
    [M:DIA]ITMREFFIN = VALEUR
Endif

End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR

# contrôle droits de l'utilisateur
Read [ACC]CODACC = GUSER;[F:TRO]ACSCOD
If !fstat & [F:ACC]MODIF = 1
    mkstat =2 : GMESSAGE = mess(144,199,1)
Endif


End

