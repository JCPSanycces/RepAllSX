#<AdxTL>@(#)0.0.0.0 $Revision$

###################################################################################
# Sage Sales Tax Address Library
#
# Process:    SSTADRLIB
#             Code to call Avatax Address Verification web service
####################################################################################
####################################################################################
# Subprogram : SST_VRF_ADR
# Description: Check Address
####################################################################################
#*
#* Check Address against Sage Sales Tax - Return updated address
#*
#* @param X3_CPY - Passed - X3 Company code used to determine Sage Sales Tax company
#* @param ADR_LINE - Passed/Returned Array - Passed as address lines to check and returned as  updated lines from Sage Sales Tax
#* @param ADR_CTY - Passed/Returned - Passed in City to check and returned as updated City
#* @param ADR_REGION - Passed/Returned - Passed in State/Province/Region to check and returned as updated State/Province/Region
#* @param ADR_POSCOD - Passed/Returned - Passed in Postal Code to check and returned as updated Postal Code
#* @param ADR_CRY - Passed/Returned - Passed in Country to check and returned as updated Country
#* @param ADR_TYPE - Returned - Type of address according to Sage Sales Tax
#* F - Firm or Company
#* G - General Delivery
#* H - High-rise or business complex
#* P - PO Box
#* R - Rural Address
#* S - Street or Residential Address
#* @param ERR - Returned - 0 if no error otherwise error
#* @param ERRMSG - Returned - Error Message
#*!

  Subprog SST_VRF_ADR(IX3CPY,IOLINE1,IOLINE2,IOLINE3,IOCTY,IOREGION,IOPOSCOD,IOCRY,OTYPE,OERR,OERRMSG)
  Value    Char    IX3CPY()
  Variable Char    IOLINE1(),IOLINE2(),IOLINE3(),IOCTY(),IOREGION(),IOPOSCOD(),IOCRY()
  Variable Char    OTYPE()
  Variable Integer OERR
  Variable Char    OERRMSG()

  Local Clbfile CHKADR_RESULT(4),REMAIN_RESULT(4)

  Local Char SST_ACCOUNT(30),SST_LICENSE(30),SST_URL(250),SST_CPY(25)
  Local Char LINE4(50),ADR_FIPS(30),WX3ADDRESS(30)
  Local Char TMP_LINE(50)(3)
  #Syracusation
  Local Char    AUTH(50),FUNCTION(30)
  Local Clbfile ARGUMENTS(0),RESHEAD(0),RESBODY(6)
  Local Char    RESULTCODE(15)

  # Save address lines in case line 4 is returned from address verification
  TMP_LINE(0)=IOLINE1
  TMP_LINE(1)=IOLINE2
  TMP_LINE(2)=IOLINE3

  Call SST_PARAM(IX3CPY,SST_CPY,SST_ACCOUNT,SST_LICENSE,SST_URL,OERR,OERRMSG) From SSTLIB    # Get connection info
  If  OERR : Goto CHKADR_CLEAN : Endif

  IOLINE1 = func INS_ESC_CHAR(IOLINE1)  # 115761.n
  IOLINE2 = func INS_ESC_CHAR(IOLINE2)  # 115761.n
  IOLINE3 = func INS_ESC_CHAR(IOLINE3)  # 115761.n

  IOLINE1 = func ENCODE_SPECIAL_CHARS(IOLINE1)  # 120623.n
  IOLINE2 = func ENCODE_SPECIAL_CHARS(IOLINE2)  # 120623.n
  IOLINE3 = func ENCODE_SPECIAL_CHARS(IOLINE3)  # 120623.n

  #Syracuse Address Verification
  AUTH = SST_ACCOUNT + ":" + SST_LICENSE
  SST_URL += "/1.0/address/validate"

  FUNCTION = 'sstValidateAddr'

  Append ARGUMENTS, '"'  + AUTH     + '"'
  Append ARGUMENTS, ',"' + SST_URL  + '"'
  Append ARGUMENTS, ',"' + IOLINE1  + '"'
  Append ARGUMENTS, ',"' + IOLINE2  + '"'
  Append ARGUMENTS, ',"' + IOLINE3  + '"'
  Append ARGUMENTS, ',"' + IOCTY    + '"'
  Append ARGUMENTS, ',"' + IOREGION + '"'
  Append ARGUMENTS, ',"' + IOPOSCOD + '"'
  Append ARGUMENTS, ',"' + IOCRY    + '"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,OERR,OERRMSG) From SSTLIB
  If OERR
    OERRMSG = mess(00194,00133,1) + ": " + OERRMSG
    Goto CHKADR_CLEAN
  Endif

  RESULTCODE = func FINDVAL(RESBODY,"ResultCode")

  If toupper(RESULTCODE) = "SUCCESS"
    IOLINE1  = func FINDVAL(RESBODY,"Line1")
    IOLINE2  = func FINDVAL(RESBODY,"Line2")
    IOLINE3  = func FINDVAL(RESBODY,"Line3")
    IOCITY   = func FINDVAL(RESBODY,"City")
    IOREGION = func FINDVAL(RESBODY,"Region")
    IOPOSCOD = func FINDVAL(RESBODY,"PostalCode")
    IOCRY    = func FINDVAL(RESBODY,"Country")
    ADR_FIPS = func FINDVAL(RESBODY,"FipsCode")
    OTYPE    = func FINDVAL(RESBODY,"AddressType")
  Else
    OERR    = 1
    OERRMSG = FUNCTION + ": " + func FINDVAL(RESBODY,"Summary")
  Endif

  $CHKADR_CLEAN
  #120623.sn
  If OERR
    IOLINE1=TMP_LINE(0)
    IOLINE2=TMP_LINE(1)
    IOLINE3=TMP_LINE(2)
  Endif
  #120623.en
End

####################################################################################
Funprog FINDVAL(RESP,K)
  Value    Clbfile  RESP
  Value    Char     K
  Local Integer X
  Local Char RETVAL(255)

  X = instr(1,RESP, '"' + K + '"' + ":")
  If !X : End "" : Endif
  X += len(K)+5
  RETVAL = seg$(RESP,X,instr(X,RESP,'"')-1)

  # 115761.sn
  If left$(K,4) = "Line"
    RETVAL = func REM_ESC_CHAR(RETVAL)
  Endif
  # 115761.en
End RETVAL

####################################################################################
# 115761.sn
Funprog INS_ESC_CHAR(ESCSTR)
  Value Char  ESCSTR

  Local Char TMPSTR(255)
  Local Integer CHARPOS1
  Local Integer CHARPOS2

  # Place escape character in front of backslash character
  If instr(1,ESCSTR,'\')
    CHARPOS1 = 1
    CHARPOS2 = instr(1,ESCSTR,'\')

    Repeat
      TMPSTR  = seg$(ESCSTR,CHARPOS1,CHARPOS2-1) + "\\"
      CHARPOS1 = CHARPOS2 + 1
      CHARPOS2 = instr(CHARPOS1,ESCSTR,'\')
    Until CHARPOS2 = 0

    ESCSTR = TMPSTR + seg$(ESCSTR,CHARPOS1,len(ESCSTR))
  Endif

End ESCSTR

####################################################################################
Funprog REM_ESC_CHAR(ESCSTR)
  Value Char    ESCSTR
  Local Char    RETVAL(255)

  RETVAL = ESCSTR

  # Remove the escape characters inserted
  If instr(0, RETVAL, "\\")
    RETVAL = ctrans(RETVAL,"\\", "\")
  Endif
  If instr(0, RETVAL, "\/")
    RETVAL = ctrans(RETVAL,"\/", "/")
  Endif

End RETVAL
# 115761.en
####################################################################################
# 120623.sn  JOBRO
Funprog ENCODE_SPECIAL_CHARS(ESCSTR)
  Value Char  ESCSTR

  Local Char TMPSTR(255)
  Local Integer CHARPOS1
  Local Integer CHARPOS2

  # When using node, the ampersand should be converted to its hex value 26
  If instr(1,ESCSTR,'&')
    CHARPOS1 = 1
    CHARPOS2 = instr(1,ESCSTR,'&')

    Repeat
      TMPSTR  = TMPSTR + seg$(ESCSTR,CHARPOS1,CHARPOS2-1) + "%26"
      CHARPOS1 = CHARPOS2 + 1
      CHARPOS2 = instr(CHARPOS1,ESCSTR,'&')
    Until CHARPOS2 = 0

    ESCSTR = TMPSTR + seg$(ESCSTR,CHARPOS1,len(ESCSTR))
  Endif

End ESCSTR
# 120623.en JOBRO

