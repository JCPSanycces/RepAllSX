#<AdxTL>@(#)1.0.0.0 $Revision$
Goto TEST
End

##############################################################################

$TEST
Local Integer  BASE , NBRQT
Local Char     RQT(250)(1..2000)

Call OUVRE_TRACE("") From LECFIC
Call CRETRI(2,nomap,"AMSK",NBRQT,RQT)
For I=1 To NBRQT
 Call ECR_TRACE(RQT(I),0) From GESECRAN
Next
Call LEC_TRACE From LECFIC
Call FERME_TRACE From LECFIC
End

##############################################################################
Subprog TRIGGER_UPDTICK(APPLI,TABLE)
Value Char APPLI
Value Char TABLE


Local Integer  BASE , NBRQT
Local Char     RQT(250)(1..2000)

If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif

Read [ADS]DOSSIER = APPLI
BASE = [F:ADS]TYPDBA

Call VALTRI(BASE,APPLI,TABLE,NBRQT,RQT)

End

##############################################################################
Subprog VALTRI(BASE,APPLI,TABLE,NBRQT,RQT)
Value    Integer BASE
Value    Char    APPLI
Value    Char    TABLE
Variable Integer NBRQT
Variable Char    RQT()(1..)

Local Integer EFFACE

Call SUPTRI(BASE,APPLI,TABLE,NBRQT,RQT)
EFFACE = 1
Gosub EXEC

Call CRETRI(BASE,APPLI,TABLE,NBRQT,RQT)
EFFACE = 0
Gosub EXEC

End

##############################################################################
$EXEC
Onerrgo ERREUR

Case BASE
 When 1 : Execsql From "3" Sql RQT(1..NBRQT)
 When 2 : Execsql From "5" Sql RQT(1..NBRQT)
Endcase

Onerrgo
Return

##############################################################################
$ERREUR
If !EFFACE
 Call ECR_TRACE(TABLE-":"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,1) From GESECRAN : # Erreur
Endif
Resume

##############################################################################
Subprog CRETRI(BASE,APPLI,TABLE,NBRQT,RQT)
Value    Integer BASE
Value    Char    APPLI
Value    Char    TABLE
Variable Integer NBRQT
Variable Char    RQT()(1..)

Gosub CRLF

Case BASE
 When 1 : Gosub CRETRI_ORA : # Oracle
 When 2 : Gosub CRETRI_SQL : # Sql
Endcase

End

##############################################################################
Subprog SUPTRI(BASE,APPLI,TABLE,NBRQT,RQT)
Value    Integer BASE
Value    Char    APPLI
Value    Char    TABLE
Variable Integer NBRQT
Variable Char    RQT()(1..)

Gosub CRLF

Case BASE
 When 1 : Gosub SUPTRI_ORA : # Oracle
 When 2 : Gosub SUPTRI_SQL : # Sql
Endcase

End

##############################################################################
$CRLF
Local Char    CRLF(2) : CRLF = " "+chr$(10)
Return

##############################################################################
$CRETRI_ORA
Raz NBRQT , RQT
NBRQT +=1 : RQT(NBRQT) = 'CREATE OR REPLACE TRIGGER "'+APPLI+'"."'+TABLE+'_UPDTICK"'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'BEFORE UPDATE OR INSERT ON '+APPLI+"."+TABLE+' FOR EACH ROW' +[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'DECLARE' +[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' NCOUNT INTEGER ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'BEGIN'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'IF :NEW.UPDTICK_0 IS NULL THEN'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' :NEW.UPDTICK_0 := 1 ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'ELSE'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' NCOUNT := :OLD.UPDTICK_0 ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' IF NCOUNT = 999999999 OR NCOUNT IS NULL THEN'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = '  NCOUNT := 1 ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' ELSE'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = '  NCOUNT := NCOUNT + 1  ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' END IF ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' :NEW.UPDTICK_0 := NCOUNT ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = ' END IF ;'+[L]CRLF
NBRQT +=1 : RQT(NBRQT) = 'END ;'+[L]CRLF
Return

$SUPTRI_ORA
Raz NBRQT , RQT
NBRQT +=1 : RQT(NBRQT) = 'Drop Trigger "'+APPLI+'"."'+TABLE+'_UPDTICK"'+[L]CRLF
Return

##############################################################################
$CRETRI_SQL
Raz NBRQT , RQT
Local Char    TABCOL(GLONAVA+5)(1..)
Local Integer NBCOL,I
Call CHARGE_CLE(APPLI,TABLE,TABCOL,NBCOL)
NBRQT +=1 : RQT(NBRQT)  = "CREATE trigger "+APPLI+"."+TABLE+'_UPDTICK'+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = 'ON '+APPLI+"."+TABLE+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = 'AFTER UPDATE'+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "AS"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "BEGIN"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "set nocount on"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = 'UPDATE '+APPLI+"."+TABLE+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "SET UPDTICK_0=(CASE UPDTICK_0 WHEN 999999999 THEN 1 ELSE UPDTICK_0+1 END)"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "WHERE EXISTS (SELECT 'x' FROM inserted AS ins"+[L]CRLF
For I=1 To NBCOL
 If I=1
 NBRQT +=1 : RQT(NBRQT)  = 'WHERE '+TABLE+"."+TABCOL(I)+"_0="+"ins."+TABCOL(I)+"_0"+[L]CRLF
 Else
 NBRQT +=1 : RQT(NBRQT)  = 'AND '+TABLE+"."+TABCOL(I)+"_0="+"ins."+TABCOL(I)+"_0"+[L]CRLF
 Endif
Next
NBRQT +=1 : RQT(NBRQT)  = ")"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "set nocount off"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "END"+[L]CRLF
Return

#####################################################################################################################
#####################################################################################################################
Subprog CHARGE_CLE(DOSSIER,TABLE,TABCOL,NBCOL)
Value Char    DOSSIER
Value Char    TABLE
Variable Char    TABCOL()(1..)
Variable Integer NBCOL

Local Char CHAINE(250)
Local Integer I,J,WNUM

Local File =[L]DOSSIER+".ATABIND"      [ATI]
For [ATI]NUMLIG Where CODFIC=[L]TABLE
 If [F:ATI]HOMONYM<>2
    CHAINE = [F:ATI]DESCRIPT
    Break
 Endif
 If I=0
    CHAINE = [F:ATI]DESCRIPT
 Endif
 I+=1
Next

Close Local File [ATI]

# ---CF VERIF_INDEX/SUBATB

Local Char   ZINDEX(120), ZONE(GLONAVA)
Local Decimal LNGZON , DIME

While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  ZINDEX = left$(CHAINE,I-1)
# CC    14/02/2013   ----   Pour autoriser des index avec - sur la première colonne
  If J=1 and ZINDEX=""
    I = instr(2,CHAINE,"+")
    J = instr(2,CHAINE,"-")
    If I<>0 or J<>0
      ZINDEX=mid$(CHAINE,2,max(I,J)-1)
    Else
      ZINDEX=right$(CHAINE,2)
      CHAINE=""
    Endif
    I=J
  Endif
  CHAINE = right$(CHAINE,I+1)
 Else
  ZINDEX = CHAINE
  CHAINE = ""
 Endif
 If ZINDEX<>""
  I = instr(1,ZINDEX,"(")
  If I
   ZONE = left$(ZINDEX,I-1)
   DIME = val(right$(ZINDEX,I+1))+1
  Else
   ZONE = ZINDEX
   DIME = 1
  Endif
 Endif
 NBCOL+=1
 TABCOL(NBCOL)=ZONE
Wend

End

$SUPTRI_SQL
Raz NBRQT , RQT
###NBRQT +=1 : RQT(NBRQT) = 'Drop Trigger "'+APPLI+'"."'+TABLE+'_UPDTICK"'+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "BEGIN"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "set nocount on"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "DROP trigger "+APPLI+"."+TABLE+'_UPDTICK'+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "set nocount off"+[L]CRLF
NBRQT +=1 : RQT(NBRQT)  = "END"+[L]CRLF
Return

