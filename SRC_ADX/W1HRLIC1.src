Subprog B1_CODACS(VALEUR)
Variable Char    VALEUR()
Call OBJET("ACS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CODACS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ACS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODACS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ACS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODACS
Onevent BEFORE_AREA Gosub AV_ZCODACS From W1HRLIC1
Return

$AV_ZCODACS
Call LECTEXTRA(zc,"ACCCOD","DESACC",num$([M]CODACS(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_DEFVAL
Onevent INIT_AREA Call D_DEFVAL(zc) From W1HRLIC1
Onevent BEFORE_INPUT Call AS_DEFVAL(zc) From W1HRLIC1
Return

Subprog D_DEFVAL(VALEUR)
Variable Integer VALEUR
If varinit([M]DEFVAL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DEFVAL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_VLY
Onevent CONTROL Call C_VLY(zc) From W1HRLIC1
Return

Subprog C_VLY(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$CHG_STY
Return


