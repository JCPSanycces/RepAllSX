#<AdxTL>@(#)%I%
# Supervisor
# Inquiry BRV

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:10:59"
A_USER  = "ADMIN"
A_STAMP = "20181109081059"
Return

$DEFAUT
Default File [BRV]
Return

$OUVFIC
Local File BUDREV [BRV]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(33788,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSBRVSTD"
PROGSPE    = "CNSBRVSPE"
CBOITE     = "DCNSBRV"
BOITE      = "FCNSBRV"
NOMMSK(0)  = "CONSBRV1"
ABMSK(0)   = "BRV1"
NOMMSK(1)  = "CONSBRV2"
ABMSK(1)   = "BRV2"
CMEMO      = "brv"
CNOMMSK    = "CRITBRV"
CABMSK     = "CBRV"
NOMFIC     = "BUDREV"
ABFIC      = "BRV"
OBJDERLU   = "BRV"
CODMSKDEF  = "STD"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "BRV0"
NBCMP = 1
CLECMP(0) = "NUM"
CLEMSK(0) = "SELNUM"
Return

$OUVRE
If clalev([F:BRV])=0 : Local File BUDREV       [BRV] : Endif
If clalev([F:BRV])=0 : Local File BUDREV       [BRV] : Endif
If clalev([F:PRJ])=0 : Local File PROJET       [PRJ] : Endif
If clalev([F:ENV])=0 : Local File ENVELOPPE    [ENV] : Endif
If clalev([F:ENF])=0 : Local File ENVFIY       [ENF] : Endif
If clalev([F:BUD])=0 : Local File BUD          [BUD] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR       [BUP] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CBRV]
 When  0 : Local Mask =NOMMSK(0) [BRV1]
 When  1 : Local Mask =NOMMSK(1) [BRV2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CBRV]
 When  0 : Grizo [BRV1]
 When  1 : Grizo [BRV2]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CBRV]SELNUM)>0 : Grizo [CBRV]SELNUM : Endif
 When  0 : If dim([M:BRV1]SELNUM)>0 : Grizo [BRV1]SELNUM : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CBRV]SELNUM)>0
 Grizo [CBRV]SELNUM
Endif
If dim([M:CBRV]CPY)>0
 Grizo [CBRV]CPY
Endif
If dim([M:CBRV]FCY)>0
 Grizo [CBRV]FCY
Endif
If dim([M:CBRV]DATDEB)>0
 Grizo [CBRV]DATDEB
Endif
If dim([M:CBRV]DATFIN)>0
 Grizo [CBRV]DATFIN
Endif
If dim([M:CBRV]ALLTYP)>0
 Grizo [CBRV]ALLTYP
Endif
If dim([M:CBRV]SELTYP)>0
 Grizo [CBRV]SELTYP
Endif
If dim([M:CBRV]PRJ)>0
 Grizo [CBRV]PRJ
Endif
If dim([M:CBRV]ENTMSTR)>0
 Grizo [CBRV]ENTMSTR
Endif
If dim([M:CBRV]ENTMEND)>0
 Grizo [CBRV]ENTMEND
Endif
If dim([M:CBRV]ENTASTR)>0
 Grizo [CBRV]ENTASTR
Endif
If dim([M:CBRV]ENTAEND)>0
 Grizo [CBRV]ENTAEND
Endif
If dim([M:CBRV]ENVSTR)>0
 Grizo [CBRV]ENVSTR
Endif
If dim([M:CBRV]ENVEND)>0
 Grizo [CBRV]ENVEND
Endif
If dim([M:CBRV]SELACC)>0
 Grizo [CBRV]SELACC
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CBRV])>0 : Close Local Mask [CBRV] : Endif
 When  0 : If clalev([M:BRV1])>0 : Close Local Mask [BRV1] : Endif
 When  1 : If clalev([M:BRV2])>0 : Close Local Mask [BRV2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CBRV]
 When  0 : Default Mask [BRV1]
 When  1 : Default Mask [BRV2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CBRV]
 When  0 : Raz [M:BRV1]
 When  1 : Raz [M:BRV2]
Endcase
Return

$CRITENT
If dim([M:CBRV]SELNUM)>0 & dim([M:BRV1]SELNUM)>0
 [M:CBRV]SELNUM = [M:BRV1]SELNUM
Endif
If dim([M:CBRV]CPY)>0 & dim([M:BRV1]CPY)>0
 [M:CBRV]CPY = [M:BRV1]CPY
Endif
If dim([M:CBRV]FCY)>0 & dim([M:BRV1]FCY)>0
 [M:CBRV]FCY = [M:BRV1]FCY
Endif
If dim([M:CBRV]DATDEB)>0 & dim([M:BRV1]DATDEB)>0
 [M:CBRV]DATDEB = [M:BRV1]DATDEB
Endif
If dim([M:CBRV]DATFIN)>0 & dim([M:BRV1]DATFIN)>0
 [M:CBRV]DATFIN = [M:BRV1]DATFIN
Endif
If dim([M:CBRV]ALLTYP)>0 & dim([M:BRV1]ALLTYP)>0
 [M:CBRV]ALLTYP = [M:BRV1]ALLTYP
Endif
If dim([M:CBRV]SELTYP)>0 & dim([M:BRV1]SELTYP)>0
 [M:CBRV]SELTYP = [M:BRV1]SELTYP
Endif
If dim([M:CBRV]PRJ)>0 & dim([M:BRV1]PRJ)>0
 [M:CBRV]PRJ = [M:BRV1]PRJ
Endif
If dim([M:CBRV]ENTMSTR)>0 & dim([M:BRV1]ENTMSTR)>0
 [M:CBRV]ENTMSTR = [M:BRV1]ENTMSTR
Endif
If dim([M:CBRV]ENTMEND)>0 & dim([M:BRV1]ENTMEND)>0
 [M:CBRV]ENTMEND = [M:BRV1]ENTMEND
Endif
If dim([M:CBRV]ENTASTR)>0 & dim([M:BRV1]ENTASTR)>0
 [M:CBRV]ENTASTR = [M:BRV1]ENTASTR
Endif
If dim([M:CBRV]ENTAEND)>0 & dim([M:BRV1]ENTAEND)>0
 [M:CBRV]ENTAEND = [M:BRV1]ENTAEND
Endif
If dim([M:CBRV]ENVSTR)>0 & dim([M:BRV1]ENVSTR)>0
 [M:CBRV]ENVSTR = [M:BRV1]ENVSTR
Endif
If dim([M:CBRV]ENVEND)>0 & dim([M:BRV1]ENVEND)>0
 [M:CBRV]ENVEND = [M:BRV1]ENVEND
Endif
If dim([M:CBRV]SELACC)>0 & dim([M:BRV1]SELACC)>0
 [M:CBRV]SELACC = [M:BRV1]SELACC
Endif
Return

$ENTCRIT
If dim([M:CBRV]SELNUM)>0 & dim([M:BRV1]SELNUM)>0
[M:BRV1]SELNUM = [M:CBRV]SELNUM
Endif
If dim([M:CBRV]CPY)>0 & dim([M:BRV1]CPY)>0
[M:BRV1]CPY = [M:CBRV]CPY
Endif
If dim([M:CBRV]FCY)>0 & dim([M:BRV1]FCY)>0
[M:BRV1]FCY = [M:CBRV]FCY
Endif
If dim([M:CBRV]DATDEB)>0 & dim([M:BRV1]DATDEB)>0
[M:BRV1]DATDEB = [M:CBRV]DATDEB
Endif
If dim([M:CBRV]DATFIN)>0 & dim([M:BRV1]DATFIN)>0
[M:BRV1]DATFIN = [M:CBRV]DATFIN
Endif
If dim([M:CBRV]ALLTYP)>0 & dim([M:BRV1]ALLTYP)>0
[M:BRV1]ALLTYP = [M:CBRV]ALLTYP
Endif
If dim([M:CBRV]SELTYP)>0 & dim([M:BRV1]SELTYP)>0
[M:BRV1]SELTYP = [M:CBRV]SELTYP
Endif
If dim([M:CBRV]PRJ)>0 & dim([M:BRV1]PRJ)>0
[M:BRV1]PRJ = [M:CBRV]PRJ
Endif
If dim([M:CBRV]ENTMSTR)>0 & dim([M:BRV1]ENTMSTR)>0
[M:BRV1]ENTMSTR = [M:CBRV]ENTMSTR
Endif
If dim([M:CBRV]ENTMEND)>0 & dim([M:BRV1]ENTMEND)>0
[M:BRV1]ENTMEND = [M:CBRV]ENTMEND
Endif
If dim([M:CBRV]ENTASTR)>0 & dim([M:BRV1]ENTASTR)>0
[M:BRV1]ENTASTR = [M:CBRV]ENTASTR
Endif
If dim([M:CBRV]ENTAEND)>0 & dim([M:BRV1]ENTAEND)>0
[M:BRV1]ENTAEND = [M:CBRV]ENTAEND
Endif
If dim([M:CBRV]ENVSTR)>0 & dim([M:BRV1]ENVSTR)>0
[M:BRV1]ENVSTR = [M:CBRV]ENVSTR
Endif
If dim([M:CBRV]ENVEND)>0 & dim([M:BRV1]ENVEND)>0
[M:BRV1]ENVEND = [M:CBRV]ENVEND
Endif
If dim([M:CBRV]SELACC)>0 & dim([M:BRV1]SELACC)>0
[M:BRV1]SELACC = [M:CBRV]SELACC
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
CRITAFF(1) = "ECRAN" : CRITAFF2(1) = ""
NBCA = 1
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSBRV2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "BRV"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]NUM(nolign-1),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M]NUM(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSBRV2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


