#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet ATP
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ATP",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
## Etiquette ajoutée par le superviseur (Objet ATP) 07/06/2007 09:02:39 (CCORA)
######################################################################################
$ACTION
Case ACTION
 When "LIENS" : Gosub LIENS
 When default
Endcase
Return


######################################################################################

$LIENS
Global Char PORTICO(200)
Call TEXTE([M:ATP0]INTITF,[M:ATP0]ZINTITF) From OBJDIV
For indice=0 To [M]NBPAR-1
  Call TEXTE([M:ATP1]PROPI(indice),[M:ATP1]ZPROPI(indice)) From OBJDIV
Next indice
Local Char NOMICO(50)
NOMICO=[M:ATP1]ICONE : Gosub AFFICO
Return


$AFFICO
If dim(PORTICO)<0 : Global Char PORTICO(200) : Endif
If left$(NOMICO,5)="http:"
  PORTICO=[M:AVP1]ICONE
Else
  PORTICO=""
  Local Integer PA1 : PA1=instr(1,NOMICO,"\")
  If PA1<>0
    PORTICO="http://"+GVIRTDIR+"/X3_ROOT/"+left$(NOMICO,PA1-1)+"/IMG/"+right$(NOMICO,PA1+1)
  Endif
Endif
Call INITURL([M:ATP1]VISUICO,"ICOPORTAL","","") From INTRUTILA
Affzo [M:ATP1]VISUICO
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran AVT1) 11/06/2007 17:46:00 (CCORA)
######################################################################################
Subprog C_ICONE(VALEUR)
Variable Char    VALEUR()
# Icône prise sur Internet
If dim(PORTICO)<0 : Global Char PORTICO(200) : Endif
If left$(VALEUR,5)="http:" : End : Endif
Local Char DIRSEP,TYPRES,NOMF(50)
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
Local Integer ERR,PA1 : PA1=instr(1,VALEUR,"\")
If PA1<>0
    TYPRES=left$(VALEUR,PA1-1)
    If !find(TYPRES,"RESSTD","RESPER","RESVER") : ERR+=1 : Endif
    NOMF=right$(VALEUR,PA1+1)
    If filinfo(filpath("X3_ROOT"+DIRSEP+TYPRES+DIRSEP+"IMG","","","X3_PUB")+DIRSEP+right$(VALEUR,PA1+1),7)<=0 : ERR+=1 : Endif
Endif
If ERR>0
  GMESSAGE=mess(20,7837,1)     :  # "Icône non trouvée" 
  mkstat=2
Endif
End

Subprog AM_ICONE(VALEUR)
Variable Char    VALEUR()
Local Char NOMICO(50)
NOMICO=VALEUR
Gosub AFFICO
End
