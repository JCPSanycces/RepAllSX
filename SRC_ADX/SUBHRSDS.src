######################################################################################
## Section automatically added (screen HRSDS0) 05/04/2016 11:07:38 (JASMI)
######################################################################################
Subprog C_CRI(VALEUR)
Variable Char    VALEUR()

Local Char CHAMP(20) , ABREV(10)
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
CHAMP = toupper(VALEUR)
K = instr(1,CHAMP,"]")
If K
 ABREV = seg$(CHAMP,2,K-1)
 CHAMP = right$(CHAMP,K+1)
 If left$(ABREV,2)="F:"
  ABREV = right$(ABREV,3)
 Endif
 If toupper(ABREV)="VEP"
  Read [ATZ]CODZONE = "VALEMP";CHAMP
  If !fstat
   VALEUR = "[F:VEP]"+CHAMP
   End
  Endif
 Endif
Endif
Read [DIC]DIC0 = CHAMP
If fstat
 GMESSAGE = mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Endif
Read [ATB]CODFIC = [F:DIC]TBL
VALEUR = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP

End

