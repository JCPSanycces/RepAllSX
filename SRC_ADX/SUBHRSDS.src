######################################################################################
## Section automatically added (screen HRSDS0) 05/04/2016 11:10:19 (JASMI)
######################################################################################
Subprog AVANT_NBRCOL

[M]STA(nolign-1) = status

End

######################################################################################

######################################################################################
## Section automatically added (screen HRSDS0) 05/04/2016 11:14:24 (JASMI)
######################################################################################
Subprog APRES_NBRCOL

Local Integer I , J , K , L , NOL
NOL = nolign-1
If find(status,65,68,83)
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYPAMT(I)=9
   For J=NOL+1 To 99
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J-1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
Elsif [M]STA(NOL)=73
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYPAMT(I)=9
   For J=99 To NOL+1 Step -1
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J+1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
Endif
[M]STA(NOL) = 0

End

