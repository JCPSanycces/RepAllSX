######################################################################################
## Section automatically added (screen HRSDS0) 04/05/2016 10:50:44 (DEHEN)
######################################################################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
#HRFLDC - Old script naming. To be Removed once testing is completed.
Local Char CHAMP(20) , ABREV(10)
  If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
  CHAMP = toupper(VALEUR)
  K = instr(1,CHAMP,"]")
    If K
      ABREV = seg$(CHAMP,2,K-1)
      CHAMP = right$(CHAMP,K+1)
      If left$(ABREV,2)="F:"
        ABREV = right$(ABREV,3)
      Endif
      If toupper(ABREV)="VEP"
        Read [ATZ]CODZONE = "VALEMP";CHAMP
        If !fstat
          VALEUR = "[F:VEP]"+CHAMP
        End
      Endif
    Endif
  Endif
  Read [DIC]DIC0 = CHAMP
  If fstat
    GMESSAGE = mess(41,100,1) : # Champ inexistant / Non Existend Field
    mkstat = 2 : End
  Endif
  Read [ATB]CODFIC = [F:DIC]TBL
  [M:HRSDS0]FLD(nolign-1)= "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
  VALEUR= "[F:"+[F:ATB]ABRFIC+"]"+CHAMP

End

######################################################################################

######################################################################################
## Section automatically added (screen HRSDS0) 04/07/2016 14:05:35 (DEHEN)
######################################################################################
Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
Local Char CHAMP (20)
Local Integer I

Gosub OUVRE From WPDEFTABLE

  If VALEUR<>"" Then
    If !clalev([F:XATZ]) Local File ATABZON[F:XATZ] : Endif
    [M:HRSDS0]FLD(nolign-1)=toupper(VALEUR)
    [M:HRSDS0]POS(nolign-1)=nolign
    I = instr(1,VALEUR, "]")
    CHAMP= mid$ (VALEUR,I+1,len(VALEUR)-I)
    Read [F:DIC]DIC0=CHAMP
    If !fstat
      Call TEXTE([F:DIC]DES,[M:HRSDS0]TIT(nolign-1)) From OBJDIV
      [M:HRSDS0]FLDTYP(nolign-1)=evalue("type("+VALEUR+")")
      Affzo [M:HRSDS0]TIT(nolign-1)
      Read[F:XATZ]CODZONE=[F:DIC]TBL;[F:DIC]FLD
      If !fstat Then
        [M:HRSDS0]CODTYP(nolign-1)=[F:XATZ]CODTYP
      Endif
    Endif

    #in the case of inserting line

    For I=1 To [M:HRSDS0]NBRFLD-1
      If I<>nolign and [M:HRSDS0]FLD(I-1)<>"" Then
        [M:HRSDS0]POS(I-1)=I
      Endif
    Next
    Affzo [M:HRSDS0]POS
  Else
   Raz [M:HRSDS0]TIT(nolign-1),[M:HRSDS0]CODTYP(nolign-1),[M:HRSDS0]POS(nolign-1)
  Endif

End


