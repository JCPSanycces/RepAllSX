    Endif
  Endif
  If dim([M:BPAR]ADDLIG2) > 0 Then
    If [F:CORL]CPYADD(1) <> [M:BPAR]ADDLIG2(ILIGNE) Then
      IBMODIF = 1
    Endif
  Endif
