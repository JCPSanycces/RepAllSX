        IBMODIF = 1
      Endif
      If [M:CNTC]CNTBIR(ILIGNE) <> [M:CNTI]CNTBIR(ILIGNEOLD) Then
        IBMODIF = 1
      Endif
    When "BPS"
      If [M:CNTS]CNTTTL(ILIGNE) <> [M:CNTI]CNTTTL(ILIGNEOLD) Then
