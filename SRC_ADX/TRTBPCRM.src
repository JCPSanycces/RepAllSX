##########################################################################################################
#Affecte les valeurs quand on vient d'une LEAD
$CREATE_FROM_LDS
Local Char SZCODBPR(GLONBPN)
Local Integer WI

  Raz SZCODBPR
  If clalev([M:CLD0]) > 0 Then
    If [M:CLD0]BPRCOD <> "" Then
      SZCODBPR = [M:CLD0]BPRCOD
    Endif
  Endif
  #
  Case GSZCRMOBJET
    When "BPP"
      Default Mask [BPP0]
      Default Mask [BPRP]
      Default Mask [BPAP]
      Default Mask [CNTP]
    When "BPC"
      Default Mask [BPC0]
      Default Mask [BPRC]
      Default Mask [BPAC]
      Default Mask [CNTC]
  Endcase
  #
  [M]BPCNUM = SZCODBPR
  #
  Case GSZCRMOBJET
    When "BPP"
      Affzo [BPP0]1-99  # FGR 22/04/2013 : X3SUIVI87528 ajout 1-99 pour que l'écran soit invalide
    When "BPC"
      Affzo [BPC0]1-99  # FGR 22/04/2013 : X3SUIVI87528 ajout 1-99 pour que l'écran soit invalide
  Endcase
  #
  [M]BPRSHO = [M:LDS2]CPYNAM
  [M]BPRNAM = [M:LDS2]CPYNAM
  [M]CRY = [M:LDS2]CPYCRY
  [M]CRN = [M:LDS2]CPYCRN
  If dim([M]NAF) >= 0 Then       # FGR 05/08/2010 : X3SUIVI66532 : conditionné par code activité KFR
    [M]NAF = [M:LDS2]CPYNAF
  Endif
  [M]LAN = [M:LDS3]CNTLAN
  If dim([M]REP) >= 0 Then       # FGR 05/08/2010 : X3SUIVI66532 : Pas obligatoire d'en avoir
    [M]REP(0) = [M:LDS0]PSTREP   # FGR 03/09/2008 : X3SUIVI48264
  Endif
  # FGR 06/05/2014 : X3SUIVI99220 : ne pas faire ça
  #  If dim([M]NAF) >= 0 Then       # FGR 05/08/2010 : X3SUIVI66532 : conditionné par code activité FTC
  #    [M]PPTFLG = 2
  #  Endif
  # FGR 10/09/2008 : ajout des nouvelles rubriques
  [M]BUS = [M:LDS2]BUS
  [M]CUR = [M:LDS2]CUR
  [M]ORIPPT = [M:LDS2]ORIPPT
  #
  Case GSZCRMOBJET
    When "BPP"
      Affzo [BPRP]
    When "BPC"
      Affzo [BPRC]
  Endcase
  # FGR 24/07/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  Case GSZCRMOBJET
    When "BPP"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPAP] = [M:BPAL]
      Raz [M:BPAP] : Transmask [M:BPAL] To [M:BPAP]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "BPC"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPAC] = [M:BPAL]
      Raz [M:BPAC] : Transmask [M:BPAL] To [M:BPAC]
      # Issue X3-35454 - 2017-05-03 by FGR : END
      # --------------------------------------
      # FGR 16/06/2015 : X3SUIVI108741 (début)
      If GACTFTC = 2 Then
         Local Char WFCY(GLONFCY)
         Local Char WBPAADD(GLONADR)
         Local Integer NIBPAADD

         WFCY = [M:BPRC]FCY
         # On peut alimenter l'adresse du 1er client livré avec l'adresse par défaut du tiers
         NIBPAADD = find([V]CST_AYES,[M:BPAC]BPAADDFLG(0..[M:BPAC]NBADR-1))
         If NIBPAADD > 0 Then
           [M:BPC4]BPAADD(0) = [M:BPAC]CODADR(NIBPAADD-1)
           [M:BPC4]FLMOD(0) = 1
           WBPAADD = [M:BPC4]BPAADD(0)
           [M:BPC4]NBDLV=1
           nolign = 1
           Gosub CHARGE_BPAADD From SUBBPC
           Affzo [M:BPC4]5, 10
         Endif
      Endif
      # FGR 16/06/2015 : X3SUIVI108741 (fin)
      # --------------------------------------
  Endcase
  # Alimentation du code adresse par défaut
  WI = func SUBLDSB.GET_IND_ADD_PRINC()
  If WI <> 0 Then
    [M]BPAINV = [M:BPAL]CODADR(WI-1)
    [M]BPAPYR = [M:BPAL]CODADR(WI-1)
  Endif
  #
  nolign = 1
  Case GSZCRMOBJET
    When "BPP"
      Actzo [M:BPAP]30
      Affzo [M:BPAP]1-99
    When "BPC"
      Actzo [M:BPAC]30
      Affzo [M:BPAC]1-99
  Endcase
  #
  [M]NBCNT = 1
  nolign = 1
  [M]CCNCRM(0) = [M:LDS0]PSTNUM
  [M]KCCNCRM = [M:LDS0]PSTNUM

  [M]CNTLNA(0) = [M:LDS0]CNTLNA
  [M]KCNTLNA = [M:LDS0]CNTLNA

  [M]CNTFNA(0) = [M:LDS0]CNTFNA
  [M]KCNTFNA = [M:LDS0]CNTFNA

  [M]CNTBIR(0) = [M:LDS3]CNTBIR
  [M]KCNTBIR = [M:LDS3]CNTBIR

  [M]CNTTTL(0) = [M:LDS0]CNTTTL
  [M]KCNTTTL = [M:LDS0]CNTTTL

  [M]CNTFNC(0) = [M:LDS2]FNC
  [M]KCNTFNC = [M:LDS2]FNC

  [M]CNTSRV(0) = [M:LDS2]SRV
  [M]KCNTSRV = [M:LDS2]SRV

  [M]CNTMSS(0) = [M:LDS2]MSS
  [M]KCNTMSS = [M:LDS2]MSS

  If WI <> 0 Then
    [M]CNTADD(0) = [M]CODADR(WI-1)
    [M]KCNTADD = [M]CODADR(WI-1)
    [M]KADDNAM = [M]BPADES(WI-1)
  Endif

  [M]CNTTEL(0) = [M:LDS3]CNTETS            ## ??? [M:LDS2]CPYTEL
  [M]KCNTTEL = [M:LDS3]CNTETS              ## ??? [M:LDS2]CPYTEL

  [M]CNTFAX(0) = [M:LDS3]CNTFAX            ## ??? [M:LDS2]CPYFAX
  [M]KCNTFAX = [M:LDS3]CNTFAX              ## ??? [M:LDS2]CPYFAX

  [M]CNTWEB(0) = [M:LDS3]CNTEMA            ## ??? [M:LDS2]CPYEML
  [M]KCNTWEB = [M:LDS3]CNTEMA              ## ??? [M:LDS2]CPYEML

  [M]CNTMOB(0) = [M:LDS3]CNTMOB            ## ??? [M:LDS2]CPYMOB
  [M]KCNTMOB = [M:LDS3]CNTMOB              ## ??? [M:LDS2]CPYMOB
  [M]CNTFLG(0) = 2
  [M]KCNTFLG = 2
  nolign = 1
  Case GSZCRMOBJET
    When "BPP"
      Actzo [M:CNTP]25
      Affzo [M:CNTP]1-99
    When "BPC"
      Actzo [M:CNTC]25
      Affzo [M:CNTC]1-99
  Endcase
Return

##########################################################################################################
$GERELEAD
Local Integer IINDICE

  If clalev([F:LDSL])=0 : Local File LEAD [LDSL] : Endif
  For IINDICE = 0 To [M]NBCNT-1
    Read [LDSL]LDS2=2;[M]CCNCRM(IINDICE)
    If fstat = 0 Then
      Readlock Curr
      If fstat = 0 Then
        [F:LDSL]PSTTYP = 1
        Rewrite [LDSL]
      Else
        GOK = 0
        Call FSTA("LDSL") From GLOCK
        Break
      Endif
    Endif
  Next IINDICE
Return

##########################################################################################################
$MODIF_FROM_LDS
  If IGBCRMFLGUPD = 1 Then
    If !GIMPORT Then
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESLDS" Then
          # On vient de la gestion de la LEAD il faut créer contact
          Gosub MODIFLDS
      Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MODIFLDS
Local Integer ILIGNE
Local Integer NOLIGNSAVE
Local Integer IINDADR
Local Char SZADRESSE(GLONADR)
Local Integer IBCONTINUE
Local Integer IBTROUVE
Local Integer ILGCODE
Local Integer IBERROR
Local Char SZMESSAGE (250)
Local Integer IBEXIST
Local Integer WI

  If dim([M:LLD0]NBBPA) < 0 Then
    Return
  Endif
  NOLIGNSAVE = nolign
  IINDADR = 1
  Raz SZADRESSE
  IBCONTINUE = 1
  IBTROUVE = 1
  ILGCODE = 0
  IBERROR = 0
  Raz SZMESSAGE
  IBEXIST = 0
  WI = func SUBLDSB.GET_IND_ADD_PRINC()
  #
  ILIGNE = 0
  While ILIGNE < [M:LLD0]NBBPA
    If [M:LLD0]CHOIX(ILIGNE) = 2 Then
      SZADRESSE = [M:LLD0]CODADR(ILIGNE)
      IBEXIST = [M:LLD0]EXISTE(ILIGNE)
      Break
    Endif
    ILIGNE += 1
  Wend
  #
  If SZADRESSE = "" and IBEXIST = 0 Then
    #Il faut creer l'adresse
    Case GSZCRMOBJET
      When "BPP"
        Default Mask [BPAP]
      When "BPC"
        Default Mask [BPAC]
    Endcase
    ILGCODE = type([M]CODADR) - 10
    While IBCONTINUE
      #Recherche code adresse
      SZADRESSE = string$(ILGCODE-len(num$(IINDADR)),"0") + num$(IINDADR)
      IBTROUVE = 0
      ILIGNE = 0
      While ILIGNE < [M]NBADR
      If [M]CODADR(ILIGNE) = SZADRESSE Then
          IBTROUVE = 1
          Break
      Endif
        ILIGNE += 1
      Wend
      If IBTROUVE = 0 Then
        Break
      Endif
      IINDADR = IINDADR + 1
      If IINDADR > dim([M]CODADR) Then
        IBERROR = 0
        #Création d'adresse impossible
        SZMESSAGE = mess(474,177,1)
        Break
      Endif
    Wend
  Endif
  #
  If IBERROR = 0 and SZADRESSE <> "" and IBEXIST = 0 Then
    [M]CODADR([M]NBADR) = SZADRESSE
    [M]BPADES([M]NBADR) = [M:BPAL]BPADES(WI-1)
    [M]BPACRY([M]NBADR) = [M:BPAL]BPACRY(WI-1)
    [M]CRYNAM([M]NBADR) = [M:BPAL]CRYNAM(WI-1)
    [M]ADDLIG1([M]NBADR) = [M:BPAL]ADDLIG1(WI-1)
    [M]ADDLIG2([M]NBADR) = [M:BPAL]ADDLIG2(WI-1)
    [M]ADDLIG3([M]NBADR) = [M:BPAL]ADDLIG3(WI-1)
    If dim([M]SAT) > 0 Then
      [M]SAT([M]NBADR) = [M:BPAL]SAT(WI-1)
    Endif
    [M]POSCOD([M]NBADR) = [M:BPAL]POSCOD(WI-1)
    [M]CTY([M]NBADR) = [M:BPAL]CTY(WI-1)
    #    [M]TEL([M]NBADR) = [M:BPAL]TEL1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus TEL
    #    [M]FAX([M]NBADR) = [M:BPAL]TEL2(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus FAX
    #    [M]MOB([M]NBADR) = [M:BPAL]TEL5(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus MOB
    #    [M]WEB([M]NBADR) = [M:BPAL]WEB1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus WEB
    [M]TEL1([M]NBADR) = [M:BPAL]TEL1(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]TEL2([M]NBADR) = [M:BPAL]TEL2(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]TEL3([M]NBADR) = [M:BPAL]TEL3(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]TEL4([M]NBADR) = [M:BPAL]TEL4(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]TEL5([M]NBADR) = [M:BPAL]TEL5(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]WEB1([M]NBADR) = [M:BPAL]WEB1(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]WEB2([M]NBADR) = [M:BPAL]WEB2(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]WEB3([M]NBADR) = [M:BPAL]WEB3(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]WEB4([M]NBADR) = [M:BPAL]WEB4(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    [M]WEB5([M]NBADR) = [M:BPAL]WEB5(WI-1)      # FGR 23/05/2012 : X3SUIVI82342
    #
    [M]BPAADDFLG([M]NBADR) = 1
    [M]NBADR += 1
    Case GSZCRMOBJET
      When "BPP"
        [M:BPAP]FLMOD([M]NBADR-1) = 1                    # FGR 13/04/2012 : X3SUIVI81576
        Actzo [M:BPAP]30
        Affzo [M:BPAP]1-99
      When "BPC"
        [M:BPAC]FLMOD([M]NBADR-1) = 1                    # FGR 13/04/2012 : X3SUIVI81576
        Actzo [M:BPAC]30
        Affzo [M:BPAC]1-99
    Endcase
  Endif
  #
  If IBERROR = 0 and SZADRESSE <> "" Then
    [M]CCNCRM([M]NBCNT) = [M:LDS0]PSTNUM
    If [M:LDS0]CNTLNA = "" Then
      # FGR 26/03/2015 : X3SUIVI107289
      # le nom n'est pas obligatoire sur les leads. S'il est vide on prend le numéro, c'est mieux que rien
      [M]CNTLNA([M]NBCNT) = [M:LDS0]PSTNUM
    Else
      [M]CNTLNA([M]NBCNT) = [M:LDS0]CNTLNA
    Endif
    [M]CNTFNA([M]NBCNT) = [M:LDS0]CNTFNA
    [M]CNTTTL([M]NBCNT) = [M:LDS0]CNTTTL
    [M]CNTFNC([M]NBCNT) = [M:LDS2]FNC
    [M]CNTSRV([M]NBCNT) = [M:LDS2]SRV
    [M]CNTMSS([M]NBCNT) = [M:LDS2]MSS
    [M]CNTADD([M]NBCNT) = SZADRESSE
    [M]CNTTEL([M]NBCNT) = [M:LDS3]CNTETS                   # ??? [M:LDS2]CPYTEL
    [M]CNTFAX([M]NBCNT) = [M:LDS3]CNTFAX                   # ??? [M:LDS2]CPYFAX
    [M]CNTWEB([M]NBCNT) = [M:LDS3]CNTEMA                   # ??? [M:LDS2]CPYEML
    [M]CNTMOB([M]NBCNT) = [M:LDS3]CNTMOB                   # ??? [M:LDS2]CPYMOB
    [M]CNTFLG([M]NBCNT) = 1
    [M]NBCNT += 1
    Case GSZCRMOBJET
      When "BPP"
        [M:CNTP]FLNEW([M]NBCNT-1) = 1                      # FGR 13/04/2012 : X3SUIVI81576
        [M:CNTP]FLMOD([M]NBCNT-1) = 1                      # FGR 13/04/2012 : X3SUIVI81576
        [M:CNTP]FLMODFONC([M]NBCNT-1) = 1                  # FGR 26/03/2015 : X3SUIVI107289
        Actzo [M:CNTP]25
        Affzo [M:CNTP]1-99
      When "BPC"
        [M:CNTC]FLNEW([M]NBCNT-1) = 1                      # FGR 13/04/2012 : X3SUIVI81576
        [M:CNTC]FLMOD([M]NBCNT-1) = 1                      # FGR 13/04/2012 : X3SUIVI81576
        [M:CNTC]FLMODFONC([M]NBCNT-1) = 1                  # FGR 26/03/2015 : X3SUIVI107289
        Actzo [M:CNTC]25
        Affzo [M:CNTC]1-99
    Endcase
  Endif
Return

