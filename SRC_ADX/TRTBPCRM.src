          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAC]ADDLIG3) > 0 Then
        If [F:CORL]CPYADD(2) <> [M:BPAC]ADDLIG3(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAC]SAT) > 0 Then
        If [F:CORL]CPYSAT <> [M:BPAC]SAT(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If [F:CORL]CPYZIP <> [M:BPAC]POSCOD(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCTY <> [M:BPAC]CTY(ILIGNE) Then
        IBMODIF = 1
      Endif
    When "BPS"
      If [F:CORL]CPYBPADES <> [M:BPAS]BPADES(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCRY <> [M:BPAS]BPACRY(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCRYNAM <> [M:BPAS]CRYNAM(ILIGNE) Then
        IBMODIF = 1
      Endif
      If dim([M:BPAS]ADDLIG1) > 0 Then
        If [F:CORL]CPYADD(0) <> [M:BPAS]ADDLIG1(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAS]ADDLIG2) > 0 Then
        If [F:CORL]CPYADD(1) <> [M:BPAS]ADDLIG2(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAS]ADDLIG3) > 0 Then
        If [F:CORL]CPYADD(2) <> [M:BPAS]ADDLIG3(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAS]SAT) > 0 Then
        If [F:CORL]CPYSAT <> [M:BPAS]SAT(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If [F:CORL]CPYZIP <> [M:BPAS]POSCOD(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCTY <> [M:BPAS]CTY(ILIGNE) Then
        IBMODIF = 1
      Endif
    When "BPT"
      If [F:CORL]CPYBPADES <> [M:BPAT]BPADES(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCRY <> [M:BPAT]BPACRY(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCRYNAM <> [M:BPAT]CRYNAM(ILIGNE) Then
        IBMODIF = 1
      Endif
      If dim([M:BPAT]ADDLIG1) > 0 Then
        If [F:CORL]CPYADD(0) <> [M:BPAT]ADDLIG1(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAT]ADDLIG2) > 0 Then
        If [F:CORL]CPYADD(1) <> [M:BPAT]ADDLIG2(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAT]ADDLIG3) > 0 Then
        If [F:CORL]CPYADD(2) <> [M:BPAT]ADDLIG3(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If dim([M:BPAT]SAT) > 0 Then
        If [F:CORL]CPYSAT <> [M:BPAT]SAT(ILIGNE) Then
          IBMODIF = 1
        Endif
      Endif
      If [F:CORL]CPYZIP <> [M:BPAT]POSCOD(ILIGNE) Then
        IBMODIF = 1
      Endif
      If [F:CORL]CPYCTY <> [M:BPAT]CTY(ILIGNE) Then
        IBMODIF = 1
      Endif
  Endcase
Return

##########################################################################################################
$GEREBPREPCOR
Local Integer IBMODIF
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOPUSER(GLONAUS)
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer ILIGNE
Local Integer ILIGNEOLD
Local Integer IBTROUVE

  IBMODIF = 0
  IBERROR = 0
  Raz SZCOPUSER
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  ILIGNE = 0
  ILIGNEOLD = 0
  IBTROUVE = 0
  # ---------------------------------------------------------------------
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  # ---------------------------------------------------------------------
  #Partie tiers
  Gosub TEST_M_REP_M_REP_SAVE
  If IBMODIF = 1 Then
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]BPRNUM = [M:REP0]REPNUM and CORTYP = "REP"
      Gosub TEST_REP_M_REP_F_CORL
      If IBMODIF = 1 Then
        [F:CORL]LNA = [M:BPRR]BPRNAM
        # FGR 13/10/2010 : X3SUIVI60986
        #[F:CORL]BPRLIB = [M:BPRR]BPRLIB
        [F:CORL]BPRLIB = [M:BPRR]BPRNAM
        IINDICE = find (2,[M:BPAR]BPAADDFLG(0..[M:BPAR]NBADR-1))
        If IINDICE > 0 Then
          [F:CORL]CPYBPANUM = [M:BPAR]CODADR(IINDICE-1)
        Endif
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
          Break
        Endif
        If IBERROR = 0 Then
          Gosub GERE_COP From SUBCORB
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
    Return
  Endif
  # ---------------------------------------------------------------------
  #Vérification sur les adresses
  ILIGNE = 0
  While ILIGNE < [M:BPAR]NBADR
    IBTROUVE = 0
    If [M:BPAR]CODADR(ILIGNE) <> "" Then
      #On va rechercher si présent au depart
      ILIGNEOLD = 0
      While ILIGNEOLD < [M:BPAI]NBADR
        If [M:BPAI]CODADR(ILIGNEOLD) = [M:BPAR]CODADR(ILIGNE) Then
          IBTROUVE = 1
          Break
        Endif
        ILIGNEOLD += 1
      Wend
      If IBTROUVE = 1 Then
        #Est ce qu'il y a des modifs dans la partie adresse
        Gosub TEST_REP_M_BPA_M_BPA_SAVE
        If IBMODIF = 1 Then
          #Il y a eu des changements
          For [CORL] Where [F:CORL]BPRNUM = [M:REP0]REPNUM and [F:CORL]CPYBPANUM = [M:BPAR]CODADR(ILIGNE)
            #On verifie si différence
            Gosub TEST_REP_M_BPA_F_COR
            If IBMODIF = 1 Then
              #On a des différences, on reporte
              [F:CORL]CPYBPADES = [M:BPAR]BPADES(ILIGNE)
              [F:CORL]CPYCRY = [M:BPAR]BPACRY(ILIGNE)
              [F:CORL]CPYCRYNAM = [M:BPAR]CRYNAM(ILIGNE)
              If dim([M:BPAR]ADDLIG1) > 0 Then
                [F:CORL]CPYADD(0) = [M:BPAR]ADDLIG1(ILIGNE)
              Else
                [F:CORL]CPYADD(0) = ""
              Endif
              If dim([M:BPAR]ADDLIG2) > 0 Then
                [F:CORL]CPYADD(1) = [M:BPAR]ADDLIG2(ILIGNE)
              Else
                [F:CORL]CPYADD(1) = ""
              Endif
              If dim([M:BPAR]ADDLIG3) > 0 Then
                [F:CORL]CPYADD(2) = [M:BPAR]ADDLIG3(ILIGNE)
              Else
                [F:CORL]CPYADD(2) = ""
              Endif
              If dim([M:BPAR]SAT) > 0 Then
                [F:CORL]CPYSAT = [M:BPAR]SAT(ILIGNE)
              Else
                [F:CORL]CPYSAT = ""
              Endif
              [F:CORL]CPYZIP = [M:BPAR]POSCOD(ILIGNE)
              [F:CORL]UPDUSR = GUSER
              [F:CORL]UPDDAT = date$
              Rewrite [CORL]
              If fstat <> 0 Then
                IBERROR = 1
                #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
                GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
                GOK = 0
              Endif
              If IBERROR = 0 Then
                Gosub GERE_COP From SUBCORB
              Endif
              If IBERROR = 1 Then
                Break
              Endif
            Endif
          Next
        Endif
      Endif
    Endif
    ILIGNE += 1
  Wend
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$TEST_M_REP_M_REP_SAVE
Local Integer IINDICE
Local Char SZCODADRESSE(GLONADR)

  IBMODIF = 0
  IINDICE = 0
  Raz SZCODADRESSE
  #On test les différentes zones
  If [M:BPRR]BPRNAM <> [M:BPRI]BPRNAM Then
    IBMODIF = 1
  Endif
  IINDICE = find (2, [M:BPAR]BPAADDFLG(0..[M:BPAR]NBADR-1))
  If IINDICE > 0 Then
    SZCODADRESSE = [M:BPAR]CODADR(IINDICE-1)
  Endif
  IINDICE = find (2, [M:BPAI]BPAADDFLG(0..[M:BPAI]NBADR-1))
  If IINDICE > 0 Then
    If SZCODADRESSE <> [M:BPAI]CODADR(IINDICE-1) Then
      IMODIF = 1
    Endif
  Endif
Return

#########################################################################################################
$TEST_REP_M_REP_F_CORL
Local Integer IINDICE
Local Char SZCODADRESSE(GLONADR)

  IBMODIF = 0
  IINDICE = 0
  Raz SZCODADRESSE
  #On test les différentes zones
  If [F:CORL]LNA <> [M:BPRR]BPRNAM Then
    IBMODIF = 1
  Endif
  IINDICE = find (2,[M:BPAR]BPAADDFLG (0..[M:BPAR]NBADR-1))
  If IINDICE > 0 Then
    SZCODADRESSE = [M:BPAR]CODADR (IINDICE-1)
  Endif
  IINDICE = find (2,[M:BPAI]BPAADDFLG (0..[M:BPAI]NBADR-1))
  If IINDICE > 0 Then
    If [F:CORL]CPYBPANUM <> SZCODADRESSE Then
      IMODIF = 1
    Endif
  Endif
Return

##########################################################################################################
$TEST_REP_M_BPA_M_BPA_SAVE
  IBMODIF = 0
  #On test les différentes zones
  If [M:BPAR]BPADES(ILIGNE) <> [M:BPAI]BPADES(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
  If [M:BPAR]BPACRY(ILIGNE) <> [M:BPAI]BPACRY(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
  If [M:BPAR]CRYNAM(ILIGNE) <> [M:BPAI]CRYNAM(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
  If dim([M:BPAR]ADDLIG1) > 0 Then
    If [M:BPAR]ADDLIG1(ILIGNE) <> [M:BPAI]ADDLIG1(ILIGNEOLD) Then
      IBMODIF = 1
    Endif
  Endif
  If dim([M:BPAR]ADDLIG2) > 0 Then
    If [M:BPAR]ADDLIG2(ILIGNE) <> [M:BPAI]ADDLIG2(ILIGNEOLD) Then
      IBMODIF = 1
    Endif
  Endif
  If dim([M:BPAR]ADDLIG3) > 0 Then
    If [M:BPAR]ADDLIG3(ILIGNE) <> [M:BPAI]ADDLIG3(ILIGNEOLD) Then
      IBMODIF = 1
    Endif
  Endif
  If dim([M:BPAR]SAT) > 0 Then
    If [M:BPAR]SAT(ILIGNE) <> [M:BPAI]SAT(ILIGNEOLD) Then
      IBMODIF = 1
    Endif
  Endif
  If [M:BPAR]POSCOD(ILIGNE) <> [M:BPAI]POSCOD(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
  If [M:BPAR]CTY(ILIGNE) <> [M:BPAI]CTY(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
Return

##########################################################################################################
$TEST_REP_M_BPA_F_COR
  IBMODIF = 0
  #On test les différentes zones
  If [F:CORL]CPYBPADES <> [M:BPAR]BPADES(ILIGNE) Then
    IBMODIF = 1
  Endif
  If [F:CORL]CPYCRY <> [M:BPAR]BPACRY(ILIGNE) Then
    IBMODIF = 1
  Endif
  If [F:CORL]CPYCRYNAM <> [M:BPAR]CRYNAM(ILIGNE) Then
    IBMODIF = 1
  Endif
  If dim([M:BPAR]ADDLIG1) > 0 Then
    If [F:CORL]CPYADD(0) <> [M:BPAR]ADDLIG1(ILIGNE) Then
