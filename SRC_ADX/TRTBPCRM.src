#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion synchro Tiers/COR                   Module CRM     07/2006
##########################################################################################################
# OUVRE_CRM         traitement sur l'action OUVRE des écrans BPx et REP
# LIENS_CRM         traitement sur l'action LIENS des écrans BPx et REP
# FERME_CRM         traitement sur l'action FERME des écrans BPx et REP
# RAZCRE_CRM        traitement sur l'action RAZCRE des écrans BPx et REP
# RAZDUP_CRM        traitement sur l'action RAZDUP des écrans BPx et REP
# CREATION_CRM      traitement sur l'action CREATION des écrans BPx et REP
# MODIF_CRM         traitement sur l'action MODIF des écrans BPx et REP
# AVANT_CHOI_CRM    traitement sur l'action AVANT_CHOI des écrans BPx et REP
# GEREBPCOR                  gestion de la mise à jour de CORRESPOND et de la synchro pour BPx
# TEST_BP_M_AIN_M_AIN_SAVE   test si différence sur écran pour BPx données interlocuteur
# TEST_BP_M_AIN_F_COR        test si différence écran/COR avec données interlocuteur
# TEST_BP_M_CNT_M_CNT_SAVE   test si différence sur écran pour BPx données Contact
# TEST_BP_M_CNT_F_COR        test si différence écran/COR pour BPx données Contact
# TEST_BP_M_BPA_M_BPA_SAVE   test si différence sur écran pour BPx données adresses
# TEST_BP_M_BPA_F_COR        test si différence écran/COR pour BPx données adresses
# GEREBPREPCOR               gestion de la mise à jour de CORRESPOND et de la synchro pour REP
# TEST_M_REP_M_REP_SAVE      test si différence sur écran pour REP données représentant
# TEST_REP_M_REP_F_CORL      test si différence écran/COR pour REP données représentant
# TEST_REP_M_BPA_M_BPA_SAVE  test si différence sur écran pour REP données adresses
# TEST_REP_M_BPA_F_COR       test si différence écran/COR pour REP données adresses
# CREATE_FROM_LDS            Affecte les valeurs quand on vient d'une LEAD
##########################################################################################################
$OUVRE_CRM
  # FGR 27/03/2015 : X3SUIVI107276 (début)
Local Integer IGBCRMFLGUPD
Local Integer IGBCRMFLGNEW

  IGBCRMFLGUPD = GBCRMFLGUPD
  IGBCRMFLGNEW = GBCRMFLGNEW
  # FGR 27/03/2015 : X3SUIVI107276 (fin)
  If dim(GSZCRMOBJETSAVE) < 0 Then
    Global Char GSZCRMOBJETSAVE(GLONAOB)(50)
    Global Integer GINBCRMOBJETSAVE

    GINBCRMOBJETSAVE = 0
  Endif
  #
  If dim(GSZCRMOBJET) < 0 Then
    Global Char GSZCRMOBJET(GLONAOB)
  Else
    GSZCRMOBJETSAVE(GINBCRMOBJETSAVE) = GSZCRMOBJET
    GINBCRMOBJETSAVE = GINBCRMOBJETSAVE + 1
  Endif
  Raz GSZCRMOBJET
  #
  If GMODU(13) <> 2 Then
    Return
  Endif
  # FGR 04/06/2008 : Fichiers non ouvert, notamment pour les prospects, représentants
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  #
  Local Mask BPR1 [BPRI]
  Local Mask CNTBPR [CNTI]
  Local Mask BPABPR [BPAI]
  Raz [M:BPRI]
  Raz [M:CNTI]
  Raz [M:BPAI]
  Gosub OUVRE_CRM_COR  # FGR 18/06/2010 : X3SUIVI65260 (début)
Return

##########################################################################################################
$OUVRE_CRM_COR
  # FGR 18/06/2010 : X3SUIVI65260 (début)
  If dim(GZCRMCPTCOR) > 0 Then
    # Si on vient là c'est qu'il a été créé et qu'on a bougé en tunnel => Donc on ne fait rien
    Return
  Endif

Global Char GZCRMCPTCOR(GLONANM)
Global Char GZCRMFONCTION(GLONAFC)
Global Integer GZCRMIMPORT

  GZCRMFONCTION = GFONCTION
  GZCRMIMPORT = GIMPORT     # Permet de savoir si on est en import pour le message
  # FGR 18/06/2010 : X3SUIVI65260 (fin)
Return

##########################################################################################################
$LIENS_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif

#Sauvegarde valeurs initial pour secteur marché
Local Integer IFOUND
Local Integer IINDICE

  IFOUND = 0
  Case GSZCRMOBJET
    When "BPR"
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:BPR0]XPREFLGADD = [M:BPAB]CODADR(IFOUND-1)
      Else
        [M:BPR0]XPREFLGADD = ""
      Endif
    When "BPP"
      For IINDICE = 0 To dim([M:BPP1]REP)-1
        [M:BPP1]PREREP(IINDICE) = [M:BPP1]REP(IINDICE)
      Next
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:BPP0]XPREFLGADD = [M:BPAP]CODADR(IFOUND-1)
      Else
        [M:BPP0]XPREFLGADD = ""
      Endif
    When "BPC"
      If GACTFTC=2    : # Issue 106137
        For IINDICE = 0 To dim([M:BPC1]REP)-1
          [M:BPC1]PREREP(IINDICE) = [M:BPC1]REP(IINDICE)
        Next
        For IINDICE = 0 To [M:BPC4]NBDLV-1
          [M:BPC4]PREREP0(IINDICE) = [M:BPC4]REP0(IINDICE)
          [M:BPC4]PREREP1(IINDICE) = [M:BPC4]REP1(IINDICE)
        Next
      Endif           : # Issue 106137
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:BPC0]XPREFLGADD = [M:BPAC]CODADR(IFOUND-1)
      Else
        [M:BPC0]XPREFLGADD = ""
      Endif
    When "BPS"
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:BPS0]XPREFLGADD = [M:BPAS]CODADR(IFOUND-1)
      Else
        [M:BPS0]XPREFLGADD = ""
      Endif
    When "REP"
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:REP0]XPREFLGADD = [M:BPAR]CODADR(IFOUND-1)
      Else
        [M:REP0]XPREFLGADD = ""
      Endif
    When "BPT"
      IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
      If IFOUND > 0 Then
        [M:BPT0]XPREFLGADD = [M:BPAT]CODADR(IFOUND-1)
      Else
        [M:BPT0]XPREFLGADD = ""
      Endif
    When Default
  Endcase
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  #Sauvegarde valeurs initial pour synchronisation
  Case GSZCRMOBJET
    When "BPR"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPR1]
      #[M:BPAI] = [M:BPAB]
      #[M:CNTI] = [M:CNTB]
      Raz [M:BPRI] : Transmask [M:BPR1] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAB] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNTB] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "BPC"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPRC]
      #[M:BPAI] = [M:BPAC]
      #[M:CNTI] = [M:CNTC]
      Raz [M:BPRI] : Transmask [M:BPRC] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAC] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNTC] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "BPP"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPRP]
      #[M:BPAI] = [M:BPAP]
      #[M:CNTI] = [M:CNTP]
      Raz [M:BPRI] : Transmask [M:BPRP] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAP] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNTP] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "BPS"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPRS]
      #[M:BPAI] = [M:BPAS]
      #[M:CNTI] = [M:CNTS]
      Raz [M:BPRI] : Transmask [M:BPRS] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAS] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNTS] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "BPT"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPRT]
      #[M:BPAI] = [M:BPAT]
      #[M:CNTI] = [M:CNTT]
      Raz [M:BPRI] : Transmask [M:BPRT] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAT] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNTT] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "FCY"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:FCY1]
      #[M:BPAI] = [M:BPF]
      #[M:CNTI] = [M:CNF]
      Raz [M:BPRI] : Transmask [M:FCY1] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPF] To [M:BPAI]
      Raz [M:CNTI] : Transmask [M:CNF] To [M:CNTI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
    When "REP"
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:BPRI] = [M:BPRR]
      #[M:BPAI] = [M:BPAR]
      Raz [M:BPRI] : Transmask [M:BPRR] To [M:BPRI]
      Raz [M:BPAI] : Transmask [M:BPAR] To [M:BPAI]
      # Issue X3-35454 - 2017-05-03 by FGR : END
      Raz [M:CNTI]
  Endcase
Return

##########################################################################################################
$FERME_CRM
  Gosub FERME_CRM_COR # FGR 18/06/2010 : X3SUIVI65260
  If dim(GINBCRMOBJETSAVE) > 0 and dim(GSZCRMOBJETSAVE) > 0 and GINBCRMOBJETSAVE > 0 Then
    GINBCRMOBJETSAVE = GINBCRMOBJETSAVE-1
    GSZCRMOBJET = GSZCRMOBJETSAVE(GINBCRMOBJETSAVE)
  Else
    If dim(GSZCRMOBJET) > 0 Then
      Kill GSZCRMOBJET
    Endif
  Endif
  If GMODU(13) <> 2 Then
    Return
  Endif
  If (dim(GCRMSYNC) > 0 and GCRMSYNC <> 2) or (dim(GCRMSYNCCOR) > 0 and GCRMSYNCCOR <> 2) Then
    Return
  Endif
  If clalev([M:BPRI]) : Close Local Mask [BPRI] : Endif
  If clalev([M:CNTI]) : Close Local Mask [CNTI] : Endif
  If clalev([M:BPAI]) : Close Local Mask [BPAI] : Endif
  If func SUBMSTB1.GENTRT_VALIDE(2) Then
    # FGR 09/04/2010 : X3SUIVI63627 : Si besoin la globale GTRTMSTOK est détruite
  Endif
Return

##########################################################################################################
$FERME_CRM_COR
  # FGR 18/06/2010 : X3SUIVI65260 (début)
  If dim(GZCRMCPTCOR) > 0 Then
    If dim(GZCRMCPTCOR) > 0 Then
      If GZCRMFONCTION = GFONCTION Then
        # Si on vient là c'est qu'on n'est pas dans un tunnel => Donc on détruit les globales.
        Kill GZCRMCPTCOR
        Kill GZCRMFONCTION
        Kill GZCRMIMPORT
      Endif
    Endif
  Endif
  # FGR 18/06/2010 : X3SUIVI65260 (fin)
Return

##########################################################################################################
$RAZCRE_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif
  If IGBCRMFLGNEW = 1 Then
    #On est en création depuis
    If !GIMPORT Then
      If GPILNAV > 1 Then
        Case GNAVIG(GPILNAV-1)
          When "GESLDS"
            Gosub CREATE_FROM_LDS
        Endcase
      Endif
    Endif
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  Raz [M:BPRI]
  Raz [M:CNTI]
  Raz [M:BPAI]
Return

##########################################################################################################
$RAZDUP_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  Raz [M:BPRI]
  Raz [M:CNTI]
  Raz [M:BPAI]
Return

##########################################################################################################
$CREATION_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif
  #Traitement des secteur de marché
  If GMSTACT = 2 Then
    Gosub TRT_MST From SUBMSTB1
    If GOK < 1 Then
      GERR = 1
      Return
    Endif
  Endif
  #traitement des LEADs
  If GSZCRMOBJET <> "REP" Then
    Gosub GERELEAD
    If GOK < 0 Then
      GERR = 1
      Return
    Endif
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  #Pour l'instant pas de possibilité en création
  #Gosub GEREBPCOR
Return

##########################################################################################################
$MODIF_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif
  # Traitement des secteur de marché
  If GMSTACT = 2 Then
    Gosub TRT_MST From SUBMSTB1
    If GOK < 1 Then
      GERR = 1
      Return
    Endif
  Endif
  #traitement des LEADs
  If GSZCRMOBJET <> "REP" Then
    Gosub GERELEAD
    If GOK < 0 Then
      GERR = 1
      Return
    Endif
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  If GSZCRMOBJET <> "REP" Then
    Gosub GEREBPCOR
  Else
    Gosub GEREBPREPCOR
  Endif
Return

##########################################################################################################
$AVANT_CHOI_CRM
  If GMODU(13) <> 2 Then
    Return
  Endif
  #If GBCRMFLGNEW = 1 Then   # FGR 27/03/2015 : X3SUIVI107276
  If IGBCRMFLGNEW = 1 Then   # FGR 27/03/2015 : X3SUIVI107276
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    #GBCRMFLGNEW = 0         # FGR 27/03/2015 : X3SUIVI107276
    IGBCRMFLGNEW = 0         # FGR 27/03/2015 : X3SUIVI107276
    Gosub SETBOUT From GOBJSUB
  Endif
  #If GBCRMFLGUPD = 1 Then   # FGR 27/03/2015 : X3SUIVI107276
  If IGBCRMFLGUPD = 1 Then   # FGR 27/03/2015 : X3SUIVI107276
    Gosub ENTRE_MODIF From GOBJSUB
    Gosub MODIF_FROM_LDS
    #GBCRMFLGUPD = 0         # FGR 27/03/2015 : X3SUIVI107276
    IGBCRMFLGUPD = 0         # FGR 27/03/2015 : X3SUIVI107276
    Gosub SETBOUT From GOBJSUB
  Endif
Return

##########################################################################################################
$GEREBPCOR
Local Integer IBMODIF
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOPUSER(GLONAUS)
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer ILIGNE
Local Integer ILIGNEOLD
Local Integer IBTROUVE
Local Integer INBLIGMAXCNT
Local Integer INBLIGMAXBPA
Local Char SZAINNUM(GLONAIN)
Local Char SZBPANUM(GLONADR)
Local Char SZBPNUM(GLONBPN)
Local Char SZBPRNAME (GLONNAC)
Local Integer IZAINFLMOD               # FGR 05/06/2014 : X3SUIVI100629
Local Integer IZBPAFLMOD               # FGR 05/06/2014 : X3SUIVI100629
Local Integer ISVLIGNE                 # FGR 29/07/2014 : X3SUIVI100629

  IBMODIF = 0
  IBERROR = 0
  Raz SZCOPUSER
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  ILIGNE = 0
  ILIGNEOLD = 0
  IBTROUVE = 0
  Raz SZAINNUM
  Raz SZBPANUM
  Raz SZBPNUM
  Raz SZBPRNAME
  # ----------------------------------------------------------------------------------------------------------------------------------------------------------
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  # ----------------------------------------------------------------------------------------------------------------------------------------------------------
  Case GSZCRMOBJET
    When "BPR"
      SZBPNUM = [M:BPR0]BPRNUM
      SZBPRNAME = [M:BPR1]BPRNAM
      INBLIGMAXCNT = [M:CNTB]NBCNT
      INBLIGMAXBPA = [M:BPAB]NBADR
    When "BPP"
      SZBPNUM = [M:BPP0]BPCNUM
      SZBPRNAME = [M:BPRP]BPRNAM
      INBLIGMAXCNT = [M:CNTP]NBCNT
      INBLIGMAXBPA = [M:BPAP]NBADR
    When "BPC"
      SZBPNUM = [M:BPC0]BPCNUM
      SZBPRNAME = [M:BPRC]BPRNAM
      INBLIGMAXCNT = [M:CNTC]NBCNT
      INBLIGMAXBPA = [M:BPAC]NBADR
    When "BPS"
      SZBPNUM = [M:BPS0]BPSNUM
      SZBPRNAME = [M:BPRS]BPRNAM
      INBLIGMAXCNT = [M:CNTS]NBCNT
      INBLIGMAXBPA = [M:BPAS]NBADR
    When "BPT"
      SZBPNUM = [M:BPT0]BPTNUM
      SZBPRNAME = [M:BPRT]BPRNAM
      INBLIGMAXCNT = [M:CNTT]NBCNT
      INBLIGMAXBPA = [M:BPAT]NBADR
  Endcase
  # ----------------------------------------------------------------------------------------------------------------------------------------------------------
  #Partie tiers
  If SZBPRNAME <> [M:BPRI]BPRNAM(0) Then
    IBMODIF = 1
    #On a eu une modif, il faut reporté la modif
    For [CORL] Where [F:CORL]BPRNUM=SZBPNUM and [F:CORL]BPRLIB<>SZBPRNAME and CORTYP<>"REP"
      [F:CORL]BPRLIB = SZBPRNAME
      Rewrite [CORL]
      If fstat <> 0 Then
        IBERROR = 1
        #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
        GMESSAGE = mess(285,177,1) - ":"- [F:CORL]CORNUM
        GOK = 0
        Break
      Endif
      If IBERROR = 0 Then
        # Pour chaque correspondant mis à jour on gère les table SYD pour la synchro outlook
        Gosub GERE_COP From SUBCORB
      Endif
      If IBERROR = 1 Then
        Break
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
    Return
  Endif
  # ----------------------------------------------------------------------------------------------------------------------------------------------------------
  #Partie interlocuteur
  # On regarde si au moins une ligne a été modifiée. Si aucune on ne fera pas la boucle
  IBTROUVE = 0
  Case GSZCRMOBJET
    When "BPR"
      IBTROUVE = find(1, [M:CNTB]FLMODFONC(0..[M:CNTB]NBCNT-1))
    When "BPP"
      IBTROUVE = find(1, [M:CNTP]FLMODFONC(0..[M:CNTP]NBCNT-1))
    When "BPC"
      IBTROUVE = find(1, [M:CNTC]FLMODFONC(0..[M:CNTC]NBCNT-1))
    When "BPS"
      IBTROUVE = find(1, [M:CNTS]FLMODFONC(0..[M:CNTS]NBCNT-1))
    When "BPT"
      IBTROUVE = find(1, [M:CNTT]FLMODFONC(0..[M:CNTT]NBCNT-1))
  Endcase
  If IBTROUVE > 0 Then
    ILIGNE = IBTROUVE - 1
    While ILIGNE < INBLIGMAXCNT
      IBTROUVE = 0
      # FGR 05/06/2014 : X3SUIVI100629 : Pourquoi uniquement BPR ?
      Case GSZCRMOBJET
        When "BPR"
          SZAINNUM = [M:CNTB]CCNCRM(ILIGNE)
          IZAINFLMOD = [M:CNTB]FLMODFONC(ILIGNE)
        When "BPP"
          SZAINNUM = [M:CNTP]CCNCRM(ILIGNE)
          IZAINFLMOD = [M:CNTP]FLMODFONC(ILIGNE)
        When "BPC"
          SZAINNUM = [M:CNTC]CCNCRM(ILIGNE)
          IZAINFLMOD = [M:CNTC]FLMODFONC(ILIGNE)
        When "BPS"
          SZAINNUM = [M:CNTS]CCNCRM(ILIGNE)
          IZAINFLMOD = [M:CNTS]FLMODFONC(ILIGNE)
        When "BPT"
          SZAINNUM = [M:CNTT]CCNCRM(ILIGNE)
          IZAINFLMOD = [M:CNTT]FLMODFONC(ILIGNE)
      Endcase
      If SZAINNUM <> "" Then
        #On va rechercher si présent au depart
        IBTROUVE = find(SZAINNUM, [M:CNTI]CCNCRM(0..[M:CNTI]NBCNT-1))
        If IBTROUVE > 0 Then
          #Est ce qu'il y a des modifs dans la partie interlocuteur
          If IZAINFLMOD <> 0 Then
            # Si la ligne a été modifiée on regardera si c'est une modification qui nous intéresse ici
            # 1°) PARTIE COMMUNE A TOUS LES CORRESPONDANTS
            Gosub TEST_BP_M_AIN_M_AIN_SAVE
            If IBMODIF = 1 Then
              #Il y a eu des changements
              For [CORL] Where [F:CORL]CNTNUM = SZAINNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]CNTNUM <> ""
                #On verifie si différence
                Gosub TEST_BP_M_AIN_F_COR
                If IBMODIF = 1 Then
                  #On a des différences, on reporte
                  Case GSZCRMOBJET
                    When "BPR"
                      [F:CORL]TTL = [M:CNTB]CNTTTL(ILIGNE)
                      [F:CORL]LNA = [M:CNTB]CNTLNA(ILIGNE)
                      [F:CORL]FNA = [M:CNTB]CNTFNA(ILIGNE)
                      [F:CORL]BIR = [M:CNTB]CNTBIR(ILIGNE)
                    When "BPP"
                      [F:CORL]TTL = [M:CNTP]CNTTTL(ILIGNE)
                      [F:CORL]LNA = [M:CNTP]CNTLNA(ILIGNE)
                      [F:CORL]FNA = [M:CNTP]CNTFNA(ILIGNE)
                      [F:CORL]BIR = [M:CNTP]CNTBIR(ILIGNE)
                    When "BPC"
                      [F:CORL]TTL = [M:CNTC]CNTTTL(ILIGNE)
                      [F:CORL]LNA = [M:CNTC]CNTLNA(ILIGNE)
                      [F:CORL]FNA = [M:CNTC]CNTFNA(ILIGNE)
                      [F:CORL]BIR = [M:CNTC]CNTBIR(ILIGNE)
                    When "BPS"
                      [F:CORL]TTL = [M:CNTS]CNTTTL(ILIGNE)
                      [F:CORL]LNA = [M:CNTS]CNTLNA(ILIGNE)
                      [F:CORL]FNA = [M:CNTS]CNTFNA(ILIGNE)
                      [F:CORL]BIR = [M:CNTS]CNTBIR(ILIGNE)
                    When "BPT"
                      [F:CORL]TTL = [M:CNTT]CNTTTL(ILIGNE)
                      [F:CORL]LNA = [M:CNTT]CNTLNA(ILIGNE)
                      [F:CORL]FNA = [M:CNTT]CNTFNA(ILIGNE)
                      [F:CORL]BIR = [M:CNTT]CNTBIR(ILIGNE)
                  Endcase
                  [F:CORL]UPDUSR = GUSER
                  [F:CORL]UPDDAT = date$
                  Rewrite [CORL]
                  If fstat <> 0 Then
                    IBERROR = 1
                    #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
                    GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
                    GOK = 0
                  Endif
                  If IBERROR = 0 Then
                    Gosub GERE_COP From SUBCORB
                  Endif
                  If IBERROR = 1 Then
                    Break
                  Endif
                Endif
              Next
            Endif
            #Est ce qu'il y a des modifs dans la partie contact
            # 2°) PARTIE POUR LES CORRESPONDANTS SUR LE TIERS TRAITE (d'ou 2 boucles)
            Gosub TEST_BP_M_CNT_M_CNT_SAVE
            If IBMODIF = 1 Then
              #Il y a eu des changements
              For [CORL] Where [F:CORL]CNTNUM = SZAINNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]CNTNUM <> "" and [F:CORL]BPRNUM = SZBPNUM
                #On verifie si différence
                Gosub TEST_BP_M_CNT_F_COR
                If IBMODIF = 1 Then
                  #On a des différences, on reporte
                  Case GSZCRMOBJET
                    When "BPR"
                      [F:CORL]FNC = [M:CNTB]CNTFNC(ILIGNE)
                      [F:CORL]SRV = [M:CNTB]CNTSRV(ILIGNE)
                      [F:CORL]MSS = [M:CNTB]CNTMSS(ILIGNE)
                      [F:CORL]CPYBPANUM = [M:CNTB]CNTADD(ILIGNE)
                      [F:CORL]CPYEML = [M:CNTB]CNTWEB(ILIGNE)
                      [F:CORL]CPYTEL = [M:CNTB]CNTTEL(ILIGNE)
                      [F:CORL]CPYFAX = [M:CNTB]CNTFAX(ILIGNE)
                      [F:CORL]CPYMOB = [M:CNTB]CNTMOB(ILIGNE)
                    When "BPP"
                      [F:CORL]FNC = [M:CNTP]CNTFNC(ILIGNE)
                      [F:CORL]SRV = [M:CNTP]CNTSRV(ILIGNE)
                      [F:CORL]MSS = [M:CNTP]CNTMSS(ILIGNE)
                      [F:CORL]CPYBPANUM = [M:CNTP]CNTADD(ILIGNE)
                      [F:CORL]CPYEML = [M:CNTP]CNTWEB(ILIGNE)
                      [F:CORL]CPYTEL = [M:CNTP]CNTTEL(ILIGNE)
                      [F:CORL]CPYFAX = [M:CNTP]CNTFAX(ILIGNE)
                      [F:CORL]CPYMOB = [M:CNTP]CNTMOB(ILIGNE)
                    When "BPC"
                      [F:CORL]FNC = [M:CNTC]CNTFNC(ILIGNE)
                      [F:CORL]SRV = [M:CNTC]CNTSRV(ILIGNE)
                      [F:CORL]MSS = [M:CNTC]CNTMSS(ILIGNE)
                      [F:CORL]CPYBPANUM = [M:CNTC]CNTADD(ILIGNE)
                      [F:CORL]CPYEML = [M:CNTC]CNTWEB(ILIGNE)
                      [F:CORL]CPYTEL = [M:CNTC]CNTTEL(ILIGNE)
                      [F:CORL]CPYFAX = [M:CNTC]CNTFAX(ILIGNE)
                      [F:CORL]CPYMOB = [M:CNTC]CNTMOB(ILIGNE)
                    When "BPS"
                      [F:CORL]FNC = [M:CNTS]CNTFNC(ILIGNE)
                      [F:CORL]SRV = [M:CNTS]CNTSRV(ILIGNE)
                      [F:CORL]MSS = [M:CNTS]CNTMSS(ILIGNE)
                      [F:CORL]CPYBPANUM = [M:CNTS]CNTADD(ILIGNE)
                      [F:CORL]CPYEML = [M:CNTS]CNTWEB(ILIGNE)
                      [F:CORL]CPYTEL = [M:CNTS]CNTTEL(ILIGNE)
                      [F:CORL]CPYFAX = [M:CNTS]CNTFAX(ILIGNE)
                      [F:CORL]CPYMOB = [M:CNTS]CNTMOB(ILIGNE)
                    When "BPT"
                      [F:CORL]FNC = [M:CNTT]CNTFNC(ILIGNE)
                      [F:CORL]SRV = [M:CNTT]CNTSRV(ILIGNE)
                      [F:CORL]MSS = [M:CNTT]CNTMSS(ILIGNE)
                      [F:CORL]CPYBPANUM = [M:CNTT]CNTADD(ILIGNE)
                      [F:CORL]CPYEML = [M:CNTT]CNTWEB(ILIGNE)
                      [F:CORL]CPYTEL = [M:CNTT]CNTTEL(ILIGNE)
                      [F:CORL]CPYFAX = [M:CNTT]CNTFAX(ILIGNE)
                      [F:CORL]CPYMOB = [M:CNTT]CNTMOB(ILIGNE)
                  Endcase
                  [F:CORL]UPDUSR = GUSER
                  [F:CORL]UPDDAT = date$
                  Rewrite [CORL]
                  If fstat <> 0 Then
                    IBERROR = 1
                    #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
                    GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
                    GOK = 0
                  Endif
                  If IBERROR = 0 Then
                    Gosub GERE_COP From SUBCORB
                  Endif
                  If IBERROR = 1 Then
                    Break
                  Endif
                Endif
              Next
            Endif
          Endif
        Endif
      Endif
      # -----------------------------------------
      # Pour aller directement au suivant modifié
      ISVLIGNE = ILIGNE
      Case GSZCRMOBJET
        When "BPR"
          ILIGNE = find(1, [M:CNTB]FLMODFONC(ISVLIGNE..[M:CNTB]NBCNT-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPP"
          ILIGNE = find(1, [M:CNTP]FLMODFONC(ISVLIGNE..[M:CNTP]NBCNT-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPC"
          ILIGNE = find(1, [M:CNTC]FLMODFONC(ISVLIGNE..[M:CNTC]NBCNT-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPS"
          ILIGNE = find(1, [M:CNTS]FLMODFONC(ISVLIGNE..[M:CNTS]NBCNT-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPT"
          ILIGNE = find(1, [M:CNTT]FLMODFONC(ISVLIGNE..[M:CNTT]NBCNT-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
      Endcase
      If ILIGNE > 0 Then
        ILIGNE = ILIGNE + ISVLIGNE
      Endif
      If ILIGNE <= 0 Then
        Break
      Endif
      # -----------------------------------------
    Wend
    If IBERROR = 1 Then
      GOK = 0
      Return
    Endif
  Endif
  # ----------------------------------------------------------------------------------------------------------------------------------------------------------
  ##############################
  #Vérification sur les adresses
  IBTROUVE = 0
  Case GSZCRMOBJET
    When "BPR"
      IBTROUVE = find(1, [M:BPAB]FLMODFONC(0..[M:BPAB]NBADR-1))
    When "BPP"
      IBTROUVE = find(1, [M:BPAP]FLMODFONC(0..[M:BPAP]NBADR-1))
    When "BPC"
      IBTROUVE = find(1, [M:BPAC]FLMODFONC(0..[M:BPAC]NBADR-1))
    When "BPS"
      IBTROUVE = find(1, [M:BPAS]FLMODFONC(0..[M:BPAS]NBADR-1))
    When "BPT"
      IBTROUVE = find(1, [M:BPAT]FLMODFONC(0..[M:BPAT]NBADR-1))
  Endcase
  If IBTROUVE > 0 Then
    ILIGNE = IBTROUVE - 1
    While ILIGNE < INBLIGMAXBPA
      IBTROUVE = 0
      Case GSZCRMOBJET
        When "BPR"
          SZBPANUM = [M:BPAB]CODADR(ILIGNE)
          IZBPAFLMOD = [M:BPAB]FLMODFONC(ILIGNE)
        When "BPP"
          SZBPANUM = [M:BPAP]CODADR(ILIGNE)
          IZBPAFLMOD = [M:BPAP]FLMODFONC(ILIGNE)
        When "BPC"
          SZBPANUM = [M:BPAC]CODADR(ILIGNE)
          IZBPAFLMOD = [M:BPAC]FLMODFONC(ILIGNE)
        When "BPS"
          SZBPANUM = [M:BPAS]CODADR(ILIGNE)
          IZBPAFLMOD = [M:BPAS]FLMODFONC(ILIGNE)
        When "BPT"
          SZBPANUM = [M:BPAT]CODADR(ILIGNE)
          IZBPAFLMOD = [M:BPAT]FLMODFONC(ILIGNE)
      Endcase
      If SZBPANUM <> "" Then
        #On va rechercher si présent au depart
        IBTROUVE = find(SZBPANUM, [M:BPAI]CODADR(0..[M:BPAI]NBADR-1))
        If IBTROUVE > 0 Then
          #Est ce qu'il y a des modifs dans la partie contact
          If IZBPAFLMOD <> 0 Then
            Gosub TEST_BP_M_BPA_M_BPA_SAVE
            If IBMODIF = 1 Then
              #Il y a eu des changements
              For [CORL] Where [F:CORL]BPRNUM = SZBPNUM and [F:CORL]CPYBPANUM = SZBPANUM
                #On verifie si différence
                Gosub TEST_BP_M_BPA_F_COR
                If IBMODIF = 1 Then
                  #On a des différences, on reporte
                  Case GSZCRMOBJET
                    When "BPR"
                      [F:CORL]CPYBPADES = [M:BPAB]BPADES(ILIGNE)
                      [F:CORL]CPYCRY = [M:BPAB]BPACRY(ILIGNE)
                      [F:CORL]CPYCRYNAM = [M:BPAB]CRYNAM(ILIGNE)
                      If dim([M:BPAB]ADDLIG1) > 0 Then
                        [F:CORL]CPYADD(0) = [M:BPAB]ADDLIG1(ILIGNE)
                      Else
                        [F:CORL]CPYADD(0) = ""
                      Endif
                      If dim([M:BPAB]ADDLIG2) > 0 Then
                        [F:CORL]CPYADD(1) = [M:BPAB]ADDLIG2(ILIGNE)
                      Else
                        [F:CORL]CPYADD(1) = ""
                      Endif
                      If dim([M:BPAB]ADDLIG3) > 0 Then
                        [F:CORL]CPYADD(2) = [M:BPAB]ADDLIG3(ILIGNE)
                      Else
                        [F:CORL]CPYADD(2) = ""
                      Endif
                      If dim([M:BPAB]SAT) > 0 Then
                        [F:CORL]CPYSAT = [M:BPAB]SAT(ILIGNE)
                      Else
                        [F:CORL]CPYSAT = ""
                      Endif
                      [F:CORL]CPYZIP = [M:BPAB]POSCOD(ILIGNE)
                      [F:CORL]CPYCTY = [M:BPAB]CTY(ILIGNE)
                    When "BPP"
                      [F:CORL]CPYBPADES = [M:BPAP]BPADES(ILIGNE)
                      [F:CORL]CPYCRY = [M:BPAP]BPACRY(ILIGNE)
                      [F:CORL]CPYCRYNAM = [M:BPAP]CRYNAM(ILIGNE)
                      If dim([M:BPAP]ADDLIG1) > 0 Then
                        [F:CORL]CPYADD(0) = [M:BPAP]ADDLIG1(ILIGNE)
                      Else
                        [F:CORL]CPYADD(0) = ""
                      Endif
                      If dim([M:BPAP]ADDLIG2) > 0 Then
                        [F:CORL]CPYADD(1) = [M:BPAP]ADDLIG2(ILIGNE)
                      Else
                        [F:CORL]CPYADD(1) = ""
                      Endif
                      If dim([M:BPAP]ADDLIG3) > 0 Then
                        [F:CORL]CPYADD(2) = [M:BPAP]ADDLIG3(ILIGNE)
                      Else
                        [F:CORL]CPYADD(2) = ""
                      Endif
                      If dim([M:BPAP]SAT) > 0 Then
                        [F:CORL]CPYSAT = [M:BPAP]SAT(ILIGNE)
                      Else
                        [F:CORL]CPYSAT = ""
                      Endif
                      [F:CORL]CPYZIP = [M:BPAP]POSCOD(ILIGNE)
                      [F:CORL]CPYCTY = [M:BPAP]CTY(ILIGNE)
                    When "BPC"
                      [F:CORL]CPYBPADES = [M:BPAC]BPADES(ILIGNE)
                      [F:CORL]CPYCRY = [M:BPAC]BPACRY(ILIGNE)
                      [F:CORL]CPYCRYNAM = [M:BPAC]CRYNAM(ILIGNE)
                      If dim([M:BPAC]ADDLIG1) > 0 Then
                        [F:CORL]CPYADD(0) = [M:BPAC]ADDLIG1(ILIGNE)
                      Else
                        [F:CORL]CPYADD(0) = ""
                      Endif
                      If dim([M:BPAC]ADDLIG2) > 0 Then
                        [F:CORL]CPYADD(1) = [M:BPAC]ADDLIG2(ILIGNE)
                      Else
                        [F:CORL]CPYADD(1) = ""
                      Endif
                      If dim([M:BPAC]ADDLIG3) > 0 Then
                        [F:CORL]CPYADD(2) = [M:BPAC]ADDLIG3(ILIGNE)
                      Else
                        [F:CORL]CPYADD(2) = ""
                      Endif
                      If dim([M:BPAC]SAT) > 0 Then
                        [F:CORL]CPYSAT = [M:BPAC]SAT(ILIGNE)
                      Else
                        [F:CORL]CPYSAT = ""
                      Endif
                      [F:CORL]CPYZIP = [M:BPAC]POSCOD(ILIGNE)
                      [F:CORL]CPYCTY = [M:BPAC]CTY(ILIGNE)
                    When "BPS"
                      [F:CORL]CPYBPADES = [M:BPAS]BPADES(ILIGNE)
                      [F:CORL]CPYCRY = [M:BPAS]BPACRY(ILIGNE)
                      [F:CORL]CPYCRYNAM = [M:BPAS]CRYNAM(ILIGNE)
                      If dim([M:BPAS]ADDLIG1) > 0 Then
                        [F:CORL]CPYADD(0) = [M:BPAS]ADDLIG1(ILIGNE)
                      Else
                        [F:CORL]CPYADD(0) = ""
                      Endif
                      If dim([M:BPAS]ADDLIG2) > 0 Then
                        [F:CORL]CPYADD(1) = [M:BPAS]ADDLIG2(ILIGNE)
                      Else
                        [F:CORL]CPYADD(1) = ""
                      Endif
                      If dim([M:BPAS]ADDLIG3) > 0 Then
                        [F:CORL]CPYADD(2) = [M:BPAS]ADDLIG3(ILIGNE)
                      Else
                        [F:CORL]CPYADD(2) = ""
                      Endif
                      If dim([M:BPAS]SAT) > 0 Then
                        [F:CORL]CPYSAT = [M:BPAS]SAT(ILIGNE)
                      Else
                        [F:CORL]CPYSAT = ""
                      Endif
                      [F:CORL]CPYZIP = [M:BPAS]POSCOD(ILIGNE)
                      [F:CORL]CPYCTY = [M:BPAS]CTY(ILIGNE)
                    When "BPT"
                      [F:CORL]CPYBPADES = [M:BPAT]BPADES(ILIGNE)
                      [F:CORL]CPYCRY = [M:BPAT]BPACRY(ILIGNE)
                      [F:CORL]CPYCRYNAM = [M:BPAT]CRYNAM(ILIGNE)
                      If dim([M:BPAT]ADDLIG1) > 0 Then
                        [F:CORL]CPYADD(0) = [M:BPAT]ADDLIG1(ILIGNE)
                      Else
                        [F:CORL]CPYADD(0) = ""
                      Endif
                      If dim([M:BPAT]ADDLIG2) > 0 Then
                        [F:CORL]CPYADD(1) = [M:BPAT]ADDLIG2(ILIGNE)
                      Else
                        [F:CORL]CPYADD(1) = ""
                      Endif
                      If dim([M:BPAT]ADDLIG3) > 0 Then
                        [F:CORL]CPYADD(2) = [M:BPAT]ADDLIG3(ILIGNE)
                      Else
                        [F:CORL]CPYADD(2) = ""
                      Endif
                      If dim([M:BPAT]SAT) > 0 Then
                        [F:CORL]CPYSAT = [M:BPAT]SAT(ILIGNE)
                      Else
                        [F:CORL]CPYSAT = ""
                      Endif
                      [F:CORL]CPYZIP = [M:BPAT]POSCOD(ILIGNE)
                      [F:CORL]CPYCTY = [M:BPAT]CTY(ILIGNE)
                  Endcase
                  [F:CORL]UPDUSR = GUSER
                  [F:CORL]UPDDAT = date$
                  Rewrite [CORL]
                  If fstat <> 0 Then
                    IBERROR = 1
                    #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
                    GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
                    GOK = 0
                  Endif
                  If IBERROR = 0 Then
                    Gosub GERE_COP From SUBCORB
                  Endif
                  If IBERROR = 1 Then
                    Break
                  Endif
                Endif
              Next
            Endif
          Endif
        Endif
      Endif
      # -----------------------------------------
      # Pour aller directement au suivant modifié
      ISVLIGNE = ILIGNE
      Case GSZCRMOBJET
        When "BPR"
          ILIGNE = find(1, [M:BPAB]FLMODFONC(ISVLIGNE..[M:BPAB]NBADR-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPP"
          ILIGNE = find(1, [M:BPAP]FLMODFONC(ISVLIGNE..[M:BPAP]NBADR-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPC"
          ILIGNE = find(1, [M:BPAC]FLMODFONC(ISVLIGNE..[M:BPAC]NBADR-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPS"
          ILIGNE = find(1, [M:BPAS]FLMODFONC(ISVLIGNE..[M:BPAS]NBADR-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
        When "BPT"
          ILIGNE = find(1, [M:BPAT]FLMODFONC(ISVLIGNE..[M:BPAT]NBADR-1)) # FGR 20/10/2014 : X3SUIVI103436 : pas de - 1
      Endcase
      If ILIGNE > 0 Then
        ILIGNE = ILIGNE + ISVLIGNE
      Endif
      If ILIGNE <= 0 Then
        Break
      Endif
      # -----------------------------------------
    Wend
    If IBERROR = 1 Then
      GOK = 0
    Endif
  Endif
  # -----------------------------------------
  Case GSZCRMOBJET
    When "BPR"
      Raz [M:BPAB]FLMODFONC
      Raz [M:CNTB]FLMODFONC
    When "BPP"
      Raz [M:BPAP]FLMODFONC
      Raz [M:CNTP]FLMODFONC
    When "BPC"
      Raz [M:BPAC]FLMODFONC
      Raz [M:CNTC]FLMODFONC
    When "BPS"
      Raz [M:BPAS]FLMODFONC
      Raz [M:CNTS]FLMODFONC
    When "BPT"
      Raz [M:BPAT]FLMODFONC
      Raz [M:CNTT]FLMODFONC
  Endcase
Return

