#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTITC02   Moulinette d'alimentation des nouvelles            Module TC #
#           catégories fournisseurs à partir des anciennes               #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTITC02(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITC02(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTITC02: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
# Issue 86740 - 2012-12-18 by SR : Tester si ancienne table toujours présente
If filinfo(filpath("FIL","TABCATBPS","fde",DOSSIER),0)<0 : End : Endif
If clalev([F:TCS])=0  Local File =DOSSIER+".TABCATBPS"  [TCS] : Endif
If clalev([F:BSG])=0  Local File =DOSSIER+".BPSCATEG"   [BSG] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [BSG]
For [TCS]
   Read [BSG]BSG0=[F:TCS]BPSCAT
   If fstat
      Raz [F:BSG]
      [F:BSG]       = [F:TCS]
      [F:BSG]BSGCOD = [F:TCS]BPSCAT
      [F:BSG]BSGDES = [F:TCS]TCSDES
      [F:BSG]BSGSHO = [F:TCS]TCSSHO
      Write [BSG]
      COMPTEUR += 1
   Endif
Next
Commit

Close Local File [BSG]
Close Local File [TCS]

Call ECR_TRACE("UTITC02 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABCATBPS") : End : Endif
# End MAE 108760
Call MAJ_UTITC02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
# Issue 108760 - 2015-08-07 by MAE :
If func DOSVUE.ISVIEW(APPLI,"TABCATBPS") : End : Endif
Call MAJ_UTITC02(APPLI)
End

