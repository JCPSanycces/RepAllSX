#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque PRX3
########################################
Subprog AM_CUR1(VALEUR)
Variable Char    VALEUR()

  [M:PRX3]CUR2 = VALEUR
  [M:PRX3]CUR1 = VALEUR
  Affzo [M:PRX3]CUR1, CUR2
End

########################################
Subprog AM_EXSINV(VALEUR)
Variable Char    VALEUR()

Local Char SZEXPCOD
Local Char SZVALEUR

  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  SZVALEUR = VALEUR
  SZEXPCOD = ""
  Read [ADI]CODE=423;SZVALEUR
  If !fstat Then
    SZEXPCOD = [F:ADI]A1
  Endif
  Case SZEXPCOD
    When "A"
      [M:PRX3]EXSVLT = 0
      [M:PRX3]CUR2 = ""
      [M:PRX3]EXSVLTX = ""
      Grizo [M:PRX3]EXSVLT
      Grizo [M:PRX3]EXSVLTX
      Grizo [M:PRX3]CUR2
    When "B"
      Actzo [M:PRX3]EXSVLT
      Actzo [M:PRX3]EXSVLTX
      Actzo [M:PRX3]CUR2
      If [M:PRX3]CUR2 = "" Then
        [M:PRX3]CUR2 = [M:PRX3]CUR1
      Endif
      [M:PRX3]EXSVLTX = mess(228,196,1)  #en tant que montant forfaitaire
    When "C"
      Actzo [M:PRX3]EXSVLT
      Actzo [M:PRX3]EXSVLTX
      Actzo [M:PRX3]CUR2
      If [M:PRX3]CUR2 = "" Then
        [M:PRX3]CUR2 = [M:PRX3]CUR1
      Endif
      [M:PRX3]EXSVLTX = mess(229,196,1)  #par kilomètre parcouru
    When "D"
      Actzo [M:PRX3]EXSVLT
      Actzo [M:PRX3]EXSVLTX
      Actzo [M:PRX3]CUR2
      If [M:PRX3]CUR2 = "" Then
        [M:PRX3]CUR2 = [M:PRX3]CUR1
      Endif
      [M:PRX3]EXSVLTX = mess(230,196,1)  #par heure écoulée
    When Default
  Endcase
  Affzo [M:PRX3]EXSVLTX, EXSVLT, CUR2
End

########################################
Subprog AM_CUR2(VALEUR)
Variable Char    VALEUR()

  [M:PRX3]CUR2 = VALEUR
  [M:PRX3]CUR1 = VALEUR
  Affzo [M:PRX3]CUR1, CUR2
End

########################################
Subprog AM_EVRARA(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Call RAZARA([M:PRX0]BPRNUM) From TRTBPRPRX
    Raz [M:PRX2]CRY
    Raz [M:PRX2]ARACOD
    Raz [M:PRX2]ARANAM
    [M:PRX2]NBARA = 0
    Grizo [M:PRX2]10
  Else
    Actzo [M:PRX2]10
  Endif
  [M:PRX2]EVRARA = VALEUR
  Affzo [M:PRX2]EVRARA
  Affzo [M:PRX2]10
End

########################################
Subprog C_NBARA
Local Integer NUMLIGNE

  NUMLIGNE = 0
  #Effacement d'une seule ligne
  If status = 65 Then
    Read [SBG]SBG2=[M:PRX0]BPRNUM;[M:PRX2]CRY(nolign - 1);[M:PRX2]ARACOD(nolign - 1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SBG]
      Delete [SBG] Curr
      If fstat Then
        Rollback
        Affzo [M:PRX2]
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #Effacement d'un groupe de lignes
  If status = 68 or status = 83 Then
    For NUMLIGNE = nolign-1 To nolign1-1
      Read [SBG]SBG2=[M:PRX0]BPRNUM;[M:PRX2]CRY(NUMLIGNE);[M:PRX2]ARACOD(NUMLIGNE)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SBG]
        Delete [SBG] Curr
        If fstat Then
          Rollback
          Affzo [M:PRX2]
          Break
        Else
          Commit
        Endif
      Endif
    Next
  Endif
End

########################################
Subprog C_NBPBL
Local Integer NUMLIGNE

  NUMLIGNE = 0
  #Effacement d'une seule ligne
  If status = 65 Then
    Read [SBP]SBP2=[M:PRX0]BPRNUM;[M:PRX1]PBL(nolign - 1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SBP]
      Delete [SBP] Curr
      If fstat Then
        Rollback
        Affzo [M:PRX1]
        End
      Endif
      Commit
    Endif
  Endif
  #Effacement d'un groupe de lignes
  If status = 68 or status = 83 Then
    For NUMLIGNE = nolign-1 To nolign1-1
      Read [SBP]SBP2=[M:PRX0]BPRNUM;[M:PRX1]PBL(NUMLIGNE)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SBP]
        Delete [SBP] Curr
        If fstat Then
          Rollback
          Affzo [M:PRX1]
          Break
        Else
          Commit
        Endif
      Endif
    Next
  Endif
End

########################################
Subprog C_PBL(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  Gosub CTLSHORTCUT From SUBPBLB
End

########################################
Subprog AM_PBL(VALEUR)
Variable Char    VALEUR()

  #Effacement de la famille de compétence précédente
  If VALEUR <> "" Then
    Read [SBP]SBP2=[M:PRX0]BPRNUM;[M:PRX1]PBL(nolign - 1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SBP]
      Delete [SBP] Curr
      If fstat Then
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  [M:PRX1]PBL(nolign-1) = VALEUR
  If [M:PRX1]PBL(nolign-1) = "" Then
    [M:PRX1]PBLCLA(nolign-1) = ""
  Else
    Read [PBL]PBL0=[M:PRX1]PBL(nolign-1)
    If fstat Then
      [M:PRX1]PBLCLA(nolign-1) = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PRX1]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PRX1]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  Affzo [M:PRX1]PBL(nolign-1), PBLCLA(nolign-1)
End

