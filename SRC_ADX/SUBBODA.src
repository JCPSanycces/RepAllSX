########################################################
$SEL_TABLE
Case TABLE
  When "SELALTBOM" Gosub SELALTBOM
Endcase
Return

########################################################
$SELALTBOM
Case GFONBOD
When "BOMC"
  CRITERE = "BOMALTTYP =1"
When "BOMP"
  CRITERE = "BOMALTTYP =2"
When "BOMS"
  CRITERE = "BOMALTTYP =3"
Endcase
OBJET = "TBO"
Return

$GRIZEBUTPLM
If dim([M:BOH0]PLMATTURL)>0
    If [M:BOH0]PLMATTURL=""
        Grizo [M:BOH0]BUTATTURL
    Else
        Actzo [M:BOH0]BUTATTURL
    Endif
Endif
If dim([M:BOH0]BUTATTURL)>0 & [M:BOH0]BUTATTURL=""
   [M:BOH0]BUTATTURL="63"
   Affzo [M:BOH0]BUTATTURL
Endif
Return

$EFFMASK
#VPO 20/03/09
Gosub GRIZEBUTPLM
Return

$AFFMASK
Gosub AFFMASK From ECCBOM
Return

