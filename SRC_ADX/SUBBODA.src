$WRITE_BOH
  [F:BOH]CREUSR=GUSER    # FQ 77838 GA 11/2011
  [F:BOH]CREDAT=date$
# point d'entrée  pour mise à jour sur [F:BOD]
  GPOINT = "BEFWRIBOH" : GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE > 0 : GOK=0 : Return : Endif
#
  Write [BOH]
  If fstat
   GOK=0 : Call FSTA("BOH") From GLOCK
  Endif
Return

