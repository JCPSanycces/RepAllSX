#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
## SUBBODA  : Appelé par SUBBOD
############################################################################
#Case ACTION
# When "VARIANTE"         : Gosub VARIANTE From SUBBODA
# When "AVANT_OUVRE"      : Gosub AVANT_OUVRE From SUBBODA
# When "OUVRE"            : Gosub OUVRE From SUBBODA
# When "OUVRE_BATCH"      : Gosub OUVRE From SUBBODA          : # GA 10/2008
# When "OUVRE_BOITE"      : Gosub OUVRE_BOITE  From SUBBODA
# When "HINTCLE"          : Gosub HINTCLE      From SUBBODA
# When "STATUT"           : Gosub STATUT From SUBBODA
# When "FERME"            : Gosub FERME From SUBBODA
# When "VERIF_CRE"        : Gosub VERIF_CRE From SUBBODA
# When "VERIF_MOD"        : Gosub VERIF_MOD From SUBBODA
# When "INICRE"           : Gosub INICRE From SUBBODA
# When "INIMOD"           : Gosub INICRE From SUBBODA
# When "CREATION"         : Gosub CREATION From SUBBODA
# When "APRES_CRE"        : Gosub APRES_CRE From SUBBODA
# When "AVANT_MODFIC"     : Gosub AVANT_MODFIC From SUBBODA
# When "APRES_MOD"        : Gosub APRES_MOD From SUBBODA
# When "APRES_MODIF"      : Gosub APRES_MODIF From SUBBODA
# When "MODIF"            : Gosub MODIF From SUBBODA
# When "FILTRE"           : Gosub FILTRE From SUBBODA
# When "LIENS"            : Gosub LIENS From SUBBODA
# When "SETBOUT"          : Gosub SETBOUT From SUBBODA
# When "AVANTBOUT"        : Gosub AVANTBOUT From SUBBODA
# When "EXEBOUT"          : Gosub EXEBOUT From SUBBODA
# When "EXEACT"           : Gosub EXEACT From SUBBODA     # 27172 12.04 MM
# When "VERF_ANU"         : Gosub VERF_ANU From SUBBODA
# When "ANNULE"           : Gosub ANNULE From SUBBODA
# When "AP_ANNULE"        : Gosub AP_ANNULE From SUBBODA
# When "RAZCRE"           : Gosub RAZCRE From SUBBODA
# When "RAZDUP"           : Gosub RAZDUP From SUBBODA
# When "ABANDON"          : Gosub SUPPRESS_TEX From SUBBODA
# When "AB_CREATION"      : Gosub SUPPRESS_TEX From SUBBODA
# When "FILGAUCHE"        : Gosub FILGAUCHE From SUBBODA
# When "TIROIR"           : Gosub TIROIR    From SUBBODA
# When "FIN_ACTION"       : Gosub FIN_ACTION  From SUBBODA   # 12.06 demande 38646
# When "SEL_TABLE"        : Gosub SEL_TABLE From SUBBODA
# When "EFFMASK"          : Gosub EFFMASK From SUBBODA
# When "AFFMASK"          : Gosub AFFMASK From SUBBODA

## Modif GA 21/06/2005 ajout BOMS

#If GFONBOD = "BOMS" # FQ 55649 GA 01/2010 nouvel objet BOS
#  Call OBJET("BOS",GBIDC1,GBIDC2) From GOBJET
#Else
#  Call OBJET("BOD",GBIDC1,GBIDC2) From GOBJET
#Endif
#End

########################################################
$VARIANTE
If [F:AWI]TRN <> GFONBOD : OK = 0 : Endif
Return

# Etiquettes d'actions de l'objet BOD
########################################################
$AVANT_OUVRE
Local Char OFONCTION(10)

OFONCTION = GFONCTION
If  GFONBOD = "BOMC"
    GFONCTION  = "GESBODC"
    Call AUTORIS From EXEFNC
    Raz CRE, MODI, SUPPR
    If GNBAUZ=0
     If GNBSITE=0
      Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans la société
      OK=0 # Issue 92587 GA 01/2014
      Return
     Else
      Call ERREUR(mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
      OK=0 # Issue 92587 GA 01/2014
      Return
     Endif
    Elsif GUSRFCY(1)="\"
     CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
     MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
     SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
    Endif
Elsif GFONBOD = "BOMP"
    GFONCTION  = "GESBODP"
    Call AUTORIS From EXEFNC
    Raz CRE, MODI, SUPPR
    If GNBAUZ=0
     If GNBSITE=0
      Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans la société
      OK=0 # Issue 92587 GA 01/2014
      Return
     Else
      Call ERREUR(mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
      OK=0 # Issue 92587 GA 01/2014
      Return
     Endif
    Elsif GUSRFCY(1)="\"
     CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
     MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
     SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
    Endif
Elsif GFONBOD = "BOMS"
    GFONCTION  = "GESBODS"
    Call AUTORIS From EXEFNC
    Raz CRE, MODI, SUPPR
    If GNBAUZ=0
     If GNBSITE=0
      Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans la société
      OK=0 # Issue 92587 GA 01/2014
      Return
     Else
      Call ERREUR(mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
      OK=0 # Issue 92587 GA 01/2014
      Return
     Endif
    Elsif GUSRFCY(1)="\"
     CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
     MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
     SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
    Endif
Elsif find(GFONBOD,"","ADELETE") # FQ 44515 GA 10/2008 cas de suppression différée
  # à compléter en V6: le BOMALTTYP se trouve dans la [F:ADL]CLE2 "CD100~2"
    GFONBOD="BOMP"
Endif

GFONCTION = OFONCTION
Return

########################################################
## Déclaration des variables
########################################################
$OUVRE
Local Char    CRIT(250), ABLIG(5)
# Issue 77371 - 2011-11-23 by MUARN : Ajout d'une deuxième variable pour la sous traitance
#Local Integer STAT , SIGN , MAXLIG, OLDLLC, LLCMAX
Local Integer STAT , SIGN , MAXLIG, MAXLIG2 : #, OLDLLC, LLCMAX
# fin Issue 77371 - 2011-11-23 by MUARN : Ajout d'une deuxième variable pour la sous traitance
Local Integer OSEQ(dim([M:BOD1]BOMSEQ))
Local Char    OCPN(GLONITM)(dim([M:BOD1]BOMSEQ))
Local Libelle OCPNTYP(dim([M:BOD1]BOMSEQ))
If GFONBOD = "BOMS" & clalev([M:BOS2])>0
  # GA services pour nomenclatures de sous-traitance
  Local Integer OSEQS(dim([M:BOS2]BOMSEQ))
  Local Char    OCPNS(GLONITM)(dim([M:BOS2]BOMSEQ))
Endif

Global Integer GNIV       : # NIVEAU DE NOMENCLATURE
Global Integer GBOHLLC    : # llc de l'article maître pour calcul
#Local  Integer SAVLLC     : # llc de l'article maître affiché
#Local  Char    BOHMAX(GLONITM) : # article maître pour LLCMAX (en annulation)
Local  Integer WLLCTYP, SYNCLLC

If clalev([F:ITB])=0 Local File ITMBOM [ITB] Endif
# ouverture des liens de nomencl. sous autre abréviation
If clalev([F:BOD2]) = 0 Local File BOMD   [BOD2] Endif
# ouverture des liens de nomencl. pour éclatement sous-niveaux
If clalev([F:BOD1]) = 0 Local File BOMD   [BOD1] Endif
# 24415 11.04 MM
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
#  ouverture des nomencl. entête sous autre abréviation
If clalev([F:BOHW])=0 : Local File BOM [BOHW] : Endif
# versioning
Gosub OUVRE From ECCBOM
Local Integer MAJGRP

If GFONBOD = "BOMS"
  # GA 06/2005 pour lecture des articles "prestations de sous-traitance"
  If clalev([F:ITM2])=0 Local File ITMMASTER [ITM2] Endif
Endif
If !dim(GDATEREF) > 1 Then
  Global Date GDATEREF
Endif
#
If GDATEREF = [0/0/0]
    # Déclarée en globale pour être mise à jour depuis une
    # action après-zone (DATREF) :
    Global Date   GDATEREF
    If !GIMPORT
       GDATEREF = date$ : # par défaut affichage compsnt actifs à date du jour
    Endif
Else
    Local Date BWARP
    BWARP = GDATEREF
Endif
#
# Distinction des alternatives commerciales/ Production/Sous-traitance selon Fonction
If GFONBOD = "BOMC"
   [M:BOH0]BOMALTTYP = 1
   If dim([V]GTABZON)>0 & [V]GTABZON="BOD2" : Raz [V]GTABZON  : Endif : # GH 11/2015 # enhancement
Elsif GFONBOD = "BOMP"
   [M:BOH0]BOMALTTYP = 2
   If dim([V]GTABZON)>0 & [V]GTABZON="BOD1" : Raz [V]GTABZON  : Endif : # GH 11/2015 # enhancement
Elsif GFONBOD = "BOMS"
   [M:BOH0]BOMALTTYP = 3
   If dim([V]GTABZON)>0 & [V]GTABZON="BOD3" : Raz [V]GTABZON  : Endif : # GH 11/2015 # enhancement
Endif

# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If GFONBOD <> "BOMC"
  Chgfmt [M:BOD1]FORSEL With "-K:1X"
  Chgfmt [M:BOD1]FORQTY With "-K:1X"
Endif

Return

##########################################################################################
$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#

Global Char     GBOXBO1(10)
GBOXBO1="GAU_CHE"+num$(find("BO1",OBJLIS(1..8))) : # sous-niveaux
If GFONBOD = "BOMC" : # GH 20/09/2013 bug 92798
  Chgtzn [M:BOH0]BOMSTU With mess(6,191,1) : # Unité vente
Endif

Gosub OUVRE_BOITE From ECCBOM

Return

##########################################################################################
$HINTCLE
Return

##########################################################################################
$BOITE
# (ouverture avec liste hiérarchisée récursive faite par le trt généré WGOBOD)
Return

##########################################################################################
$FILGAUCHE
# filtre pour les sous-niveaux     (05/06/01) Bug 9357
If currbox = GBOXBO1
  FILGAUSUP(0) = 'BOMALT='+num$([M:BOH0]BOMALT)+' & ITMREF="'+[M:BOH0]ITMREF+'"'
  # 12.06 demande 38646 remplacer les > et < et >= et <=
  If [M:BOH0]DATREF <> [0/0/0]
    FILGAUSUP(0) += '& BOMSTRDAT<=[M:BOH0]DATREF & (BOMENDDAT=[0/0/0] | BOMENDDAT>=[M:BOH0]DATREF)'
  Endif
  # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
  FILGAUSUP(0) += '& FORSEL=""'
Endif
Return

#rajouté le 03/08/01 pour test Web car les sous-niveaux ne sont pas rechargés
$TIROIR
If currbox = GBOXBO1 & GBROWS=0 ##GINTRA=0 # test sur indications CORA
  Gosub FILGAUCHE
  FILTREG = 1     # comme GOBJSUB bug 17798 (28/03/03)
  Gosub REMPLIT_1 From ="WG"+GBOITE  # au lieu de GESBOD
Endif
Return

###########################################################################################
$FIN_ACTION
# 12.06 demande 38646 repositionner le filtre
If GSTATIR & dim([V]GBOXBO1)=1 & currbox = GBOXBO1 & [M:BOH0]DATREF <> [0/0/0]
    Filter [F:BOD] Where evalue("BOMSTRDAT<=[M:BOH0]DATREF & (BOMENDDAT=[0/0/0] | BOMENDDAT>=[M:BOH0]DATREF)")
Else
    Filter [F:BOD]
Endif
Return

###########################################################################################
$STATUT
If mkstat=4 & GREP=""
   #GREP="M" : REP="M"
   #Gosub SETBOUT From GOBJSUB
   #Grizo [M:BOH0]ITMREF
   #Grizo [M:BOH0]BOMALT
  #MAE, bg 50938
  Gosub ENTRE_MODIF From GOBJSUB
Endif
If [M:BOH0]HEATEX <> "" & !GIMPORT
    Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT
    Call RESET_IMAGE (4) From GESECRAN
Endif

Gosub STATUT From ECCBOM
Return

#########################################################
$FERME
GFONBOD = ""
If GFONC1="GESBOD" : Raz GFONC1 : Endif

If dim(BWARP)<=0  : Raz GDATEREF : Endif
If dim(GBOXBO1)>0 : Kill GBOXBO1 : Endif

# FQ 49557 pb de GIMPOBJ en mode Test le masque écran n'est pas ouvert et GIMPORT non positionné
If clalev([M:BOD1])>0  Raz [M:BOD1] Endif

#----- Effacement icone texte -----#
If !GIMPORT : Call RESET_IMAGE(4) From GESECRAN : Endif

Return

########################################################
## Action technique de définition du filtre de lecture
########################################################
$DEFLIG
# Le fichier des lignes doit être "par défaut"
Default File [BOD]
ABLIG = "BOD"
Default Mask [BOD1] # rajouté car pb si écran spécifique (08/04/02) Bug 13737
# CRIT = 'ITMREF="'+[M:BOH0]ITMREF+'" & BOMALT='+num$([M:BOH0]BOMALT)
Return

$APRES_MODIF
# controler la saisie de la date de référence
# OK=-1 pour ne pas passer en mode modif (COUZON au lieu de zoncou)
Case COUZON
 When "BOMALT"
     # controler l'autorisation du code d'accès de l'alternative
     # (si on n'est pas encore en duplication...)
     Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD
     If fstat & GUSRACS < 2
        OK = 0 : GMESSAGE = mess(57,133,1) : Return : # Code d'accès non autorisé Corr 21936
     Endif
     # 27172 12.04 MM
     If GREP = "C" & !fstat & [F:ACC]MODIF=1
        mkstat =2 : GMESSAGE = mess(144,199,1) : Return : # Pas d'autorisation de modification sur cette alternative
     Endif
 When "DATREF"
     OK = - 1
     [M:BOH0]DATREF = CZ    # car [M] pas encore chargé ! 04/03/03 (17507)
     Raz [M:BOD1]
     Gosub LIENS   :# relire les détails et charger l'écran
     If !GIMPORT : Affzo [BOD1] : Endif
     zc = [M:BOH0]DATREF
Endcase
Gosub APRES_MODIF From ECCBOM
Return

########################################################
## Lecture des lignes
########################################################
$LIENS
Local Integer I

If GFONCTION1="GESBOD" Call RAZ_CLOB From ACLOB Endif

If GDATEREF <> [0/0/0]
   [M:BOH0]DATREF = GDATEREF
Endif

Gosub LIENS1 From ECCBOM

# Test de la validité
If GDATEREF <> [0/0/0] & ([F:BOH]BOHSTRDAT > GDATEREF | ([F:BOH]BOHENDDAT < GDATEREF & [F:BOH]BOHENDDAT <>[0/0/0]))
   GMESSAGE = mess(54,199,1)
   GERR = 2  # rajouté le 04/07/01 msg informatif !
Endif

Read [ITM]ITM0=[F:BOH]ITMREF
If GFONBOD = "BOMC"
  [M:BOH0]BOMSTU = [F:ITM]SAU
Else
  [M:BOH0]BOMSTU = [F:ITM]STU
Endif

# 98144 - Display the allergens for the parent
If GFONBOD = "BOMP" & func AFNC.ACTIV("FOA")
  [M:BOH0]ALG = [F:ITM]ALG
  [M:BOH0]ALGDAT = [F:ITM]ALGDAT
  [M:BOH0]ALGBOM = [F:ITM]ALGBOM
Endif

# FQ 52200 [M:BOH0]STOFCY n'est pas chargé d'où pb quand on va dans VISUBOMG
If [F:TBO]BOMALT <> [M:BOH0]BOMALT | [F:TBO]BOMALTTYP <> [M:BOH0]BOMALTTYP
   Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
   If fstat : Raz [F:TBO] : Endif
Endif
If [M:BOH0]STOFCY="" & [F:TBO]FCY<>"" [M:BOH0]STOFCY=[F:TBO]FCY Endif

# Lecture des détails de nomenclature valides
nolign = 0
##### Filter [BOD] # pour résoudre pb sous Web (?) Attention liste hiérarch récursive sur la même classe !!
If [M:BOH0]BOMALTTYP = 1
  [G:BOD]currind = 3 # pour tri selon complément de séquence (v 140)
Else
  [G:BOD]currind = 1
Endif
# 12.06 demande 38646

If GDATEREF <> [0/0/0]
# GA 03/2006 sauf composants de type 7=Service + BOMALTTYP dans clé primaire
 For [BOD] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&               & (BOMSTRDAT <= GDATEREF)
&               & (BOMENDDAT >= GDATEREF | BOMENDDAT = [0/0/0])
&               & (CPNTYP<7 or CPNTYP=8 or CPNTYP=9) : #-- X3Suivi 71277 --#
   nolign +=1
   Gosub ZAFF
 Next
Else   : # la date de référence est nulle
# GA 03/2006 sauf composants de type 7=Service + BOMALTTYP dans clé primaire
 For [BOD] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&               & (CPNTYP<7 or CPNTYP=8 or CPNTYP=9) : #-- X3Suivi 71277 --#

   nolign +=1
   Gosub ZAFF
 Next
Endif
[M:BOD1]NBLIG = nolign
MAXLIG = nolign
Raz [M:BOH0]CUMQTE # pour ne pas cumuler 2x (gosub LIENS en Apres_cre) 10/08/00

#If [M:BOH0]QTYCOD = 4 : # Nomenclature au pourcentage
 # ne prendre que ceux correspondant à la date CUMREF  bug 17507       03/03/03
If [M:BOH0]DATREF = [0/0/0]
   [M:BOH0]CUMREF = datesyst
Else
   [M:BOH0]CUMREF = [M:BOH0]DATREF
Endif
For [BOD] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&             & (BOMSTRDAT <= [M:BOH0]CUMREF)
&             & (BOMENDDAT >= [M:BOH0]CUMREF | BOMENDDAT = [0/0/0]
&             & CPNTYP = 1) # 06/12/10 Bug 69643
    # 30793 MM 06.05
    If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
        [M:BOH0]CUMQTE += [F:BOD]LIKQTY
    Else
        [M:BOH0]CUMQTE += [F:BOD]BOMQTY
    Endif
Next
#Endif Toujours alimenté (en cas de modif Code QTéBase) bug 15141 15/07/02

# Chargement de la concaténation pour ctrl unicité
For I =0 To [M:BOD1]NBLIG-1
  [M:BOD1]CONCATKEY(I) = num$([M:BOD1]BOMSEQ(I)) + [M:BOD1]CPNITMREF(I)
Next I

#------------------------#
# Affichage icone texte  #
#------------------------#
If !GIMPORT
  If [M:BOH0]HEATEX <> ""
        Call SET_IMAGE (4) From GESECRAN
  Else
        Call RESET_IMAGE (4) From GESECRAN
  Endif
  # rajout (TB -- le 19/03/99) pour treebox sous-niv -- Modif pour v 130 :
##  If CLECUR <> 0 ### & GFONBOD="BOMP"
  # vu avec mb 02/08/01 : exclure mode Web (corrige le 9133 ou 8208)
  # en Web le remplissage serait fait automatiquement quand on clique (? NON !! 12/12)
  # Remplissage de la boite même si on n'est pas dessus (Currbox pas testé)
  #If CLECUR <> 0 & !GINTRA & OBJLIS(1)="BO1"  # Présence du browse (Corr 12847 - 14/02/02)
  If CLECUR <> 0 & !GBROWS & OBJLIS(ILIS)="BO1"        # (TB) v 140 (Corr 20821 - 25/05/04)
    FILGAUSUP(0) = 'BOMALT='+num$([M:BOH0]BOMALT)+' & ITMREF="'+[M:BOH0]ITMREF+'"'
    If [M:BOH0]DATREF <> [0/0/0]
      FILGAUSUP(0) += '& BOMSTRDAT<=[M:BOH0]DATREF & (BOMENDDAT=[0/0/0] | BOMENDDAT>=[M:BOH0]DATREF)'
    Endif
    FILTREG = 1     # comme GOBJSUB bug 17798 (28/03/03)
    Gosub REMPLIT_1 From ="WG"+GBOITE # au lieu de GESBOD

  Endif
Endif

#VPO 20/03/09
Gosub GRIZEBUTPLM

# -----------------------------------------------
# Nomenclature de sous-traitance: lecture de BOMS
# -----------------------------------------------
If GFONBOD = "BOMS"
  # GA 04/07/2005 services pour nomenclatures de sous-traitance
  Gosub LIENS_BOMS From SUBBODB
Endif

Default Mask [BOD1]

Gosub LIENS2 From ECCBOM

# Issue 110957 - 2015-09-21 by GH
If !GIMPORT
   If dim([M:BOH0]CRID)>0
      [M:BOH0]CRID = func TRTX3FNC.CCMID([M:BOH0]ITMREF,
&                                        func TRTX3FNC.VALFLD_C("[M:BOH0]BOHECCMAJ"),
&                                        func TRTX3FNC.VALFLD_C("[M:BOH0]BOHECCMIN"))
      Diszo [BOH0]CRID
   Endif
   If dim([M:BOH0]CRFLG)>0
      [M:BOH0]CRFLG = string$([M:BOH0]CRID<>"","151")
   Endif
   If dim([M:BOD1]CRID)>0
      Diszo [BOD1]CRID
   Endif
Endif
Return

# zones affichées dans les lignes
$ZAFF
[M:BOD1] = [F:BOD]
# (llc 05.00 sous-produits)
If GFONBOD = "BOMP"
   If [M:BOD1]CPNTYP(nolign-1) = 0  : [M:BOD1]CPNTYP(nolign-1) = 1 : Endif
   If dim([M:BOD1]CSTFLG) > 0
      If [M:BOD1]CSTFLG(nolign-1) = 0  : [M:BOD1]CSTFLG(nolign-1) = 2 : Endif
   Endif
Endif
[M:BOD1]UPDFLG(nolign-1) = 0
[M:BOD1]CREFLG(nolign-1) = nolign
OSEQ(nolign-1)           = [F:BOD]BOMSEQ
OCPN(nolign-1)           = [F:BOD]CPNITMREF
OCPNTYP(nolign-1)        = [F:BOD]CPNTYP

Read [ITM]ITM0 = [F:BOD]CPNITMREF
If !fstat
   If GFONBOD = "BOMC"
    [M:BOD1]STU(nolign-1) = [F:ITM]SAU
   Else
    [M:BOD1]STU(nolign-1) = [F:ITM]STU
   Endif

   # 98144 - Display the allergens for the components
   If GFONBOD = "BOMP" & func AFNC.ACTIV("FOA") & [M:BOD1]CPNTYP(nolign-1) = 1
    [M:BOD1]ALG(nolign-1) = [F:ITM]ALG
   Endif

# 03.07 Demande 40156
#   [M:BOD1]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Endif

# Issue 110957 - 2015-09-21 by GH
If !GIMPORT & dim([M:BOD1]CRID)>0
    [M:BOD1]CRID(nolign-1) = func TRTX3FNC.CCMID([M:BOD1]CPNITMREF(nolign-1),
&                                                func TRTX3FNC.VALFLD_C("[M:BOD1]ECCVALMAJ(nolign-1)"),
&                                                func TRTX3FNC.VALFLD_C("[M:BOD1]ECCVALMIN(nolign-1)"))
    If dim([M:BOD1]CRFLG)>0
       [M:BOD1]CRFLG(nolign-1) = string$([M:BOD1]CRID(nolign-1)<>"","151")
    Endif
Endif
Return

$FILTRE
# Distinction des alternatives commerciales/ Production selon Fonction
If GFONBOD = "BOMC"
   FILTSUP = "[F]BOMALTTYP = 1"
Elsif GFONBOD = "BOMP"
   FILTSUP = "[F]BOMALTTYP = 2"
# GA 06/2005 ajout BOMS alt de sous-traitance
Elsif GFONBOD = "BOMS"
   FILTSUP = "[F]BOMALTTYP = 3"
Endif
# !! FILTRE est appelé de SELOBJ il faut que FILTSUP soit une expr évaluable

# Ajout LLC ... ------------------------------------
# 07.04 Bug 54125 on utilisait GFONC1, mais ce dernier est souvent raz à la sortie
# des écrans
# FQ 55649 GA 01/2010 si Objet BOS on a GESBOS
#If GFONCTION<>"GESBOD" # aussi contexte de copie + fusion (18/01/02)
If !find(GFONCTION,"GESBOD","GESBOS") & GBOMALT<>0
    If FILTSUP = ""
        FILTSUP="find(BOMALT, GBOMALT)"
    Else
        FILTSUP-="& find(BOMALT, GBOMALT)"
    Endif
Endif
# Fin Ajout LLC ... --------------------------------
Return

$VERIF_CRE
# correction 9882  (cas de duplication)  13/08/01
If find([M:BOH0]ITMREF, [M:BOD1]CPNITMREF(0..[M:BOD1]NBLIG-1))
    GMESSAGE = mess(280,199,1)
    OK = 0
    Return
Endif
Gosub VERIF_TYP
Return

$VERIF_TYP
# Vérifier les types par / aux séquences pour les nomencl.commerciales
Local Integer I,LIG
If [M:BOH0]BOMALTTYP <> 1 : Goto CTLPCT : Endif
Sorta [M:BOD1]NBLIG [M:BOD1]NBLIG Order By [M:BOD1]BOMSEQ(indice),[M:BOD1]CPNTYP(indice)
For nolign = 1 To [M:BOD1]NBLIG
  If nolign > 1 & [M:BOD1]BOMSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign-2)
&               & [M:BOD1]CPNTYP(nolign-1) <> [M:BOD1]CPNTYP(nolign-2)
&             & !(([M:BOD1]CPNTYP(nolign-1)= 1 & [M:BOD1]CPNTYP(nolign-2)=9) | ([M:BOD1]CPNTYP(nolign-1)= 9 & [M:BOD1]CPNTYP(nolign-2)=1))

     I = nolign
     OK = 0
     GMESSAGE = mess(83,199,1)
     If !GIMPORT : Affzo [BOD1] : Endif
     nolign = I
     If !GIMPORT : SUIZON = "BOMSEQ(I-1)" : Endif
     Break
  Endif

  # recherche de variante isolée
  If [M:BOD1]CPNTYP(nolign-1) = 3 & [M:BOD1]FORSEL(nolign-1) = '' & (nolign=1 | [M:BOD1]BOMSEQ(nolign-1) <> [M:BOD1]BOMSEQ(nolign-2))
    LIG = nolign
    While I < [M:BOD1]NBLIG & LIG < [M:BOD1]NBLIG : # test suppl. rajouté(23/06/99)
     I = LIG+find([M:BOD1]BOMSEQ(nolign-1),[M:BOD1]BOMSEQ(LIG..[M:BOD1]NBLIG-1))-1
     If I > (LIG-1) & [M:BOD1]CPNTYP(I) = 3 : OK = 1 : Break
        Elsif I = LIG - 1                   : OK = 0 : Break
     Endif
     LIG = I
    Wend
    # test particulier rajouté le 23/06/99 : dernière ligne : variante isolée ?
    If [M:BOD1]NBLIG = 1 & [M:BOD1]CPNTYP(0) = 3
&    | (nolign = [M:BOD1]NBLIG & [M:BOD1]CPNTYP(nolign-2) <> 3)
       OK = 0
    Endif
    If OK <> 1
       GMESSAGE = mess(84,199,1)
       If !GIMPORT : Affzo [BOD1] : Endif
       nolign = LIG
       If !GIMPORT : SUIZON = "BOMSEQ(nolign-1)" : Endif
       Break
    Endif
  Endif

  #-- X3Suivi 71277 : Recherche de Option multiple isolée
  If [M:BOD1]CPNTYP(nolign-1) = 8 & [M:BOD1]FORSEL(nolign-1) = '' & (nolign=1 | [M:BOD1]BOMSEQ(nolign-1) <> [M:BOD1]BOMSEQ(nolign-2))
    LIG = nolign
    While I < [M:BOD1]NBLIG & LIG < [M:BOD1]NBLIG : # test suppl. rajouté(23/06/99)
     I = LIG+find([M:BOD1]BOMSEQ(nolign-1),[M:BOD1]BOMSEQ(LIG..[M:BOD1]NBLIG-1))-1
     If I > (LIG-1) & [M:BOD1]CPNTYP(I) = 8 : OK = 1 : Break
        Elsif I = LIG - 1                   : OK = 0 : Break
     Endif
     LIG = I
    Wend
    # test particulier rajouté le 23/06/99 : dernière ligne : Option multipleisolée ?
    If [M:BOD1]NBLIG = 1 & [M:BOD1]CPNTYP(0) = 8
&    | (nolign = [M:BOD1]NBLIG & [M:BOD1]CPNTYP(nolign-2) <> 8)
       OK = 0
    Endif
    If OK <> 1
       GMESSAGE = mess(576,199,1)
       If !GIMPORT : Affzo [BOD1] : Endif
       nolign = LIG
       If !GIMPORT : SUIZON = "BOMSEQ(nolign-1)" : Endif
       Break
    Endif
  Endif

Next

$CTLPCT
# Controle (nomencl. au pourcentage) cumul des qtés=100 au nb déc près du composé
If [M:BOH0]QTYCOD <> 4 : Goto CTLSUITE : Endif

# GH 02/10/2013 bug 93119
#If clalev([F:TUN])=0 : Local File TABUNIT [TUN] : Endif
#Read [TUN]TUN0 = [M:BOH0]BOMSTU
#If arr([M:BOH0]CUMQTE,10^-[F:TUN]UOMDEC) > 100
If [M:BOH0]CUMQTE > 100
    GMESSAGE = mess(4,199,1) : OK = 0
# FQ 62119 GA 02/2010 pb aux US : ne pas arrondir ?
#Elsif arr([M:BOH0]CUMQTE,10^-[F:TUN]UOMDEC) < 100
Elsif [M:BOH0]CUMQTE < 100
    GMESSAGE = mess(5,199,1) : OK = 0
Endif

$CTLSUITE
# -----------------------------------------------
# Nomenclature de sous-traitance: ctrl de BOMS
# -----------------------------------------------
If GFONBOD = "BOMS" | [M:BOH0]BOMALTTYP = 3
  # GA 04/07/2005 services pour nomenclatures de sous-traitance
  Gosub VERIF_BOMS  From SUBBODB
Endif
Return

$VERIF_MOD
Local Integer IQUEST , IANNUL , OK1
# Issue 77371 - 2011-11-22 by MUARN : pour les nomenclatures sous-traitance controle du deuxième onglet
#If [M:BOD1]NBLIG=0
If [M:BOD1]NBLIG=0 & ((GFONBOD = "BOMS" & [M:BOS2]NBLIG=0) | GFONBOD <> "BOMS")
&                  & !(dim([L]TRTGBM)=1 & [L]TRTGBM="CREEVL")
# fin Issue 77371 - 2011-11-22 by MUARN : pour les nomenclatures sous-traitance controle du deuxième onglet
 IQUEST = 1
# voir s'il existe d'autres enreg dans la table
 If GDATEREF <> [0/0/0]
# Issue 77371 - 2011-11-22 by MUARN : erreur sur recherche date début
#   For [BOD2] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
#&               & ((BOMENDDAT < GDATEREF & BOMENDDAT <> [0/0/0])
#&               | (BOMSTRDAT = GDATEREF))
For [BOD2] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&               & ((BOMENDDAT < GDATEREF & BOMENDDAT <> [0/0/0])
&               | (BOMSTRDAT > GDATEREF))
# fin Issue 77371 - 2011-11-22 by MUARN : erreur sur recherche date début
       IQUEST = 0 : Break
   Next
 Endif

# "La nomenclature n'a plus de lien. Voulez-vous la supprimer?"
 If IQUEST = 1
   Call OUINON(mess(68,199,1),OK1) From GESECRAN
   If OK1 = 2 : IANNUL = 1 : Endif
 Endif

Endif

Gosub VERIF_TYP
Return

$APRES_MOD
If SYNCLLC
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ERREUR(mess(198,196,1)) From GESECRAN
  SYNCLLC=0
Endif

Gosub APRES_MOD From ECCBOM

# Si l'opérateur a demandé l'annulation de l'entête après vidage des lignes
If !GIMPORT
 # 98144 - perform rollup on save
 If func AFNC.ACTIV("FOA") : Call AUTOROLLUP From FUNFOAROLL : Endif
 If IANNUL = 1
  Call ANUCOD("BOD",CLECUR1,CLECUR2,OK) From GOBJACT            # 10.04
  If OK : CLECUR1="" : CLECUR2="" : CLECUR=0 : Endif
  Gosub RELIT From GOBJET
 Else
  Gosub LIENS    : # rajouté le 23/06/99 (TB)
  Affzo [BOD1]
  Affzo [BOH0]DATREF
 Endif
Endif
Return

####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
# on ne vire jamais les textes sur les données de base pour l'instant
#If [M:BOH0]HEATEX="" & [F:BOH]HEATEX <> ""
#   Call SUP_CLOB([F:BOH]HEATEX,WRET) From TRTX3TEX
#Endif
Return

########################################################
## Enregistrement des lignes
########################################################
$MODIF
#-- X3Suivi 71277 --#
If GFONBOD = "BOMC"
 Local Integer WMAJ : WMAJ=2
 Gosub MAJ_TYPE_NORMALEAVECFORMULE
Endif

# FGR 01/10/2009 : X3SUIVI57935
Call MAJTEXTRA([M:BOH0]BOMDESAXX, "BOM", "BOMDESAXX", [M:BOH0]ITMREF+"~"+num$([M:BOH0]BOMALT),num$([M:BOH0]BOMALTTYP)) From ATEXTRA

#WLLCTYP = func LLCLIB.LLCTYP([M:BOH0]BOMALTTYP)
#Read  [ITB]ITB0 = [M:BOH0]ITMREF;[M:BOH0]BOMALT;WLLCTYP
#If !fstat
#   SAVLLC = [F:ITB]LLC
#Endif
SYNCLLC=0

Gosub DEFLIG
If dim([L]LLCBOD)>0 : [L]LLCNBR=0 : Endif

## Première passe, lignes annulées
#If !clalev([F:ITB2]) Local File ITMBOM [ITB2] Endif :# T E S T pour màj LLC (performances ?)
If [M:BOH0]DATREF<>[0/0/0] & [M:BOH0]USESTA=1 : MAJGRP=0 : Else MAJGRP=-1 : Endif
For nolign=1 To MAXLIG
 If !find(nolign,[M]CREFLG(0..[M]NBLIG-1))
  Readlock [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;OSEQ(nolign-1);OCPN(nolign-1);[M:BOH0]BOMALTTYP
  If fstat=1
   GOK = -1
   GLOCK = "$BOMD"-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)-num$(OSEQ(nolign-1))-OCPN(nolign-1)
   Break
  Elsif !fstat : # Au cas où
   If !MAJGRP & [F:BOD]ECCRLEGRP<>0 : MAJGRP=1 : Endif
   # Issue 118021 GH 07/09/2016 - delete the BOM lines records before updating ITMBOM records
   #SIGN = -1 : Gosub VALLIG
   #If GOK<1 : Break : Endif
   Delete [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;OSEQ(nolign-1);OCPN(nolign-1);[M:BOH0]BOMALTTYP
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif

For nolign=1 To MAXLIG
 If !find(nolign,[M]CREFLG(0..[M]NBLIG-1))
    SIGN = -1 : Gosub VALLIG
 Endif
Next

## Deuxième passe, créations et modifications
Raz [F:BOD] : # Issue 119341 GH 21/11/16 - reset to blank before transclass
For nolign=1 To [M]NBLIG
 If [M:BOD1]BOMTEXNUM(nolign-1) <> ""
     Call CRE_CLOB([M:BOD1]BOMTEXNUM(nolign-1),GOK) From TRTX3TEX
     [F:BOD]BOMTEXNUM = [M:BOD1]BOMTEXNUM(nolign-1)
 Endif
 If [M]CREFLG(nolign-1)=0  : # C'est une nouvelle ligne
  [F:BOD]       = [M:BOD1]
  # process 03.04 MM
  If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
      [F:BOD]BOMUOM =[M:BOD1]STU(nolign-1)
      [F:BOD]BOMSTUCOE=1
      [F:BOD]BOMQTY=[M:BOD1]LIKQTY(nolign-1)
  Endif
  # Fin process 03.04 MM
  [F:BOD]ITMREF    = [M:BOH0]ITMREF
  [F:BOD]BOMALT    = [M:BOH0]BOMALT
  [F:BOD]BOMALTTYP = [M:BOH0]BOMALTTYP
  Gosub INICRE_LIG From TABLEAUX
  Gosub WRITE_BOD
  If GOK<1 : Break : Endif
  #
  SIGN = +1 : Gosub VALLIG
 Elsif [M]UPDFLG(nolign-1)<>0 : # La ligne a été modifiée
  Readlock [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOD1]BOMSEQ(nolign-1);[M:BOD1]CPNITMREF(nolign-1);[M:BOH0]BOMALTTYP
  If fstat=1
   GOK = -1
   GLOCK = "$BOMD"-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)-[M:BOD1]CONCATKEY(nolign-1)
   Break
  Endif
  If !MAJGRP & [F:BOD]ECCRLEGRP<>0 & [M:BOD1]ECCRLEGRP(nolign-1)=0 : MAJGRP=1 : Endif
  # on a viré le texte
  # on ne vire jamais les textes sur les données de base pour l'instant
  If [M:BOD1]BOMTEXNUM(nolign-1)="" & [F:BOD]BOMTEXNUM <> ""
#       Call SUP_CLOB([F:BOD]BOMTEXNUM,WRET) From TRTX3TEX
  Endif
  [F:BOD] = [M:BOD1]
  # process 03.04 MM
  If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
      [F:BOD]BOMUOM =[M:BOD1]STU(nolign-1)
      [F:BOD]BOMSTUCOE=1
      [F:BOD]BOMQTY=[M:BOD1]LIKQTY(nolign-1)
  Endif
  # Fin process 03.04 MM

  Gosub INIMOD_LIG From TABLEAUX
# RIEN à MÀJ puisque Réf COMPOSANT non modifiable (Réactivable pour TEST)
# SIGN = +1 : Gosub VALLIG
  Gosub REWRITE_BOD
  If GOK<1 : Break : Endif

 # Issue 118021 GH 07/09/2016 - Update ITMBOM records for a component no more by-product (CPNTYP:4->1)
  If [M:BOD1]CPNTYP(nolign-1)<>OCPNTYP(nolign-1) & OCPNTYP(nolign-1)=4
     SIGN = +1 : Gosub VALLIG
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif

For nolign=1 To [M]NBLIG
 # Issue 118021 GH 07/09/2016 - Update ITMBOM records for a component which becomes by-product (CPNTYP:1->4)
  If [M]CREFLG(nolign-1)<>0 & [M]UPDFLG(nolign-1)<>0 & [M:BOD1]CPNTYP(nolign-1)<>OCPNTYP(nolign-1) & [M:BOD1]CPNTYP(nolign-1)=4
     J=GOK : GOK=1
     Call UPDLLC([M:BOH0]BOMALTTYP, [M:BOH0]BOMALT, [M:BOH0]ITMREF, [M]CPNITMREF(nolign-1), -4, -1) From SUBBODB
     If GOK<1 : SYNCLLC=1 : Endif
     GOK=J
  Endif
Next nolign

# -----------------------------------------------
# Nomenclature de sous-traitance: maj de BOMS
# -----------------------------------------------
If GFONBOD = "BOMS"
  # GA 04/07/2005 services pour nomenclatures de sous-traitance
  Gosub MODIF_BOMS From SUBBODB
  If GOK<1 : Return : Endif
Endif

Gosub MODIF From ECCBOM
If GOK<1 : Return : Endif

If SYNCLLC & GTRACE<>""
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
  SYNCLLC=0
Endif
Return

#######################################################
## $MAJ_TYPE_NORMALEAVECFORMULE                      ##
#######################################################
$MAJ_TYPE_NORMALEAVECFORMULE

#- X3Suivi 71277
Local Integer WIND_DEB,WIND_FIN, WSEQ1, WCAS, WFORMULE_OK, WJ , WK
Local Char    WMESS1 (150)

WFORMULE_OK = 1
For nolign=1 To [M]NBLIG
  WJ = nolign
  If [M:BOD1]FORSEL(WJ) <>'' : WFORMULE_OK=2 : Endif
  If WJ > 1 & [M:BOD1]BOMSEQ(WJ-1) <> [M:BOD1]BOMSEQ(WJ-2)
    WIND_FIN = WJ-2
    Gosub MAJ_SEQUENCE
    WIND_DEB = WJ-1
  Endif
Next nolign

WIND_FIN= [M]NBLIG-1
Gosub MAJ_SEQUENCE

Affzo [M:BOD1]

Return

#######################################################
## $MAJ_SEQUENCE                                     ##
#######################################################
$MAJ_SEQUENCE
#- X3Suivi 71277

 If WIND_DEB < 0 or WIND_FIN < 0 : Return : Endif

 WCAS       = [M:BOD1]CPNTYP (WIND_DEB)
 WSEQ1      = [M:BOD1]BOMSEQ (WIND_DEB)
 WFORMULE_OK=1

 For WK=WIND_DEB To WIND_FIN
  If [M:BOD1]FORSEL(WK) <>'' : WFORMULE_OK=2 : Endif
 Next WK

 If WFORMULE_OK=2 & (WCAS = 9 | WCAS = 1)
  For WK=WIND_DEB To WIND_FIN
   [M:BOD1]CPNTYP (WK) = 9 : #-- Type composant = normal (avec formule)
   If WMAJ=2 : [M:BOD1]UPDFLG (WK) = 1 : Else : [M:BOD1]CREFLG (WK) = 1: Endif
  Next WK
 Elsif WFORMULE_OK=1 & (WCAS = 9 | WCAS = 1)
  For WK=WIND_DEB To WIND_FIN
   [M:BOD1]CPNTYP (WK) = 1 : #-- Type composant = normal
   If WMAJ=2 : [M:BOD1]UPDFLG (WK) = 1 : Else : [M:BOD1]CREFLG (WK) = 1: Endif
  Next WK
 Endif

Return

#######################################################
$INICRE
# FGR 01/10/2009 : X3SUIVI57935
[F:BOH]IDENT1 = [M:BOH0]ITMREF + "~" + num$([M:BOH0]BOMALT)

Read [TBO]TBO0= [M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
[F:BOH]ACSCOD = [F:TBO]ACSCOD  # bug 6336  Code accès en Redondance 12/01/01

#texte
If [M:BOH0]HEATEX<>""
      Call CRE_CLOB([M:BOH0]HEATEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:BOH]HEATEX = [M:BOH0]HEATEX
Endif
Return

#######################################################
$CREATION

#-- X3Suivi 71277 --#
If GFONBOD = "BOMC"
 Local Integer WMAJ : WMAJ=1
 Gosub MAJ_TYPE_NORMALEAVECFORMULE
Endif

# FGR 01/10/2009 : X3SUIVI57935
Call MAJTEXTRA([M:BOH0]BOMDESAXX, "BOM", "BOMDESAXX", [M:BOH0]ITMREF+"~"+num$([M:BOH0]BOMALT),num$([M:BOH0]BOMALTTYP)) From ATEXTRA

# Màj de ITMBOM pour entête
# Pour objet BOD le mask par défaut doit être BOD1
# Pour Copie nomenclature soit BOD1 soit BOD2 selon type
# Local File BOMD   [BOD2]  # PB sur l'import de nomenclature FQ 67258
Gosub DEFLIG
If dim([L]LLCBOD)>0 : [L]LLCNBR=0 : Endif

SYNCLLC=0
WLLCTYP = func LLCLIB.LLCTYP([M:BOH0]BOMALTTYP)
J=GOK : GOK=1
Readlock [ITB]ITB0 = [M:BOH0]ITMREF;[M:BOH0]BOMALT;WLLCTYP
If fstat = 1  : # enreg déjà locké : rollback
   GOK = -1 : GLOCK = "$ITMBOM"-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)-num$(WLLCTYP)
Elsif fstat
   Raz [F:ITB]
   [F:ITB]ITMREF = [M:BOH0]ITMREF
   [F:ITB]BOMALT = [M:BOH0]BOMALT
   [F:ITB]LLCTYP = WLLCTYP
   [F:ITB]BOMEXIFLG = 2
   [F:ITB]LLC    = 0
   [F:ITB]CREDAT = date$
   [F:ITB]CREUSR = GUSER
   Write [ITB]
   If fstat : GOK=0 : Endif
Elsif [F:ITB]BOMEXIFLG<>2
   [F:ITB]BOMEXIFLG = 2
   Rewrite [ITB]
   If fstat : GOK=0 : Endif
Endif
If GOK<1 : SYNCLLC=1 : Endif
GOK=J

#SAVLLC = [F:ITB]LLC
# création des détails nomenclature
Raz [F:BOD] : # Issue 119341 GH 21/11/16 - reset to blank before transclass
For  nolign = 1 To [M]NBLIG
 [F:BOD] = [M]
  # process 03.04 MM
  If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
      [F:BOD]BOMUOM =[M:BOD1]STU(nolign-1)
      [F:BOD]BOMSTUCOE=1
      [F:BOD]BOMQTY=[M:BOD1]LIKQTY(nolign-1)
  Endif
  # Fin process 03.04 MM
 [F:BOD]ITMREF    = [M:BOH0]ITMREF
 [F:BOD]BOMALT    = [M:BOH0]BOMALT
 [F:BOD]BOMALTTYP = [M:BOH0]BOMALTTYP
 If GREP = "C" & [M:BOD1]BOMTEXNUM(nolign-1)<>""
      Call CRE_CLOB([M:BOD1]BOMTEXNUM(nolign-1),GOK) From TRTX3TEX
      If GOK<1 : Break : Endif
      [F:BOD]BOMTEXNUM = [M:BOD1]BOMTEXNUM(nolign-1)
 Endif
 If GIMPORT & find([M:BOD1]CPNTYP(nolign-1),5,6)  & (dim([M:BOD1]PKC) > 0)
         [F:BOD]PKC = 1
 Endif

 Gosub INICRE_LIG From TABLEAUX

 Gosub WRITE_BOD
 If GOK<1 : Break : Endif
#
 SIGN = +1 : Gosub VALLIG
Next nolign
If GOK<1 : Return : Endif

# ------------------------------------------------
# Nomenclature de sous-traitance: creation de BOMS
# ------------------------------------------------
If GFONBOD = "BOMS"
  # GA 04/07/2005 services pour nomenclatures de sous-traitance
  Gosub CREATION_BOMS From SUBBODB
  If GOK<1 : Return : Endif
Endif

Gosub CREATION From ECCBOM
If GOK<1 : Return : Endif

If SYNCLLC & GTRACE<>""
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
  SYNCLLC=0
Endif
Return

#############################################################
$APRES_CRE
Local Integer OK
Raz OK

If SYNCLLC
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ERREUR(mess(198,196,1)) From GESECRAN
  SYNCLLC=0
Endif

Gosub APRES_CRE From ECCBOM

Gosub LIENS : # rajouté le 23/06/99 (TB)
#  #----- Affichage icone texte ----- et rafraichissement écran #
If !GIMPORT
    Affzo [BOD1]
    Affzo [BOH0]DATREF
    If [M:BOH0]HEATEX<>""
        Call SET_IMAGE(4)   From GESECRAN
    Else
        Call RESET_IMAGE(4) From GESECRAN
    Endif
Endif

#X3-38684 CATUA.so do not retrieve the same access code from the previous record when creating a duplicate copy.
## report du code accès appliqué à l'alternative dans [F:BOH]ACSCOD
## 24415 11.04 MM
## il existe déjà une nomenclature qui possède cette alternative
#OK=0
#Filter [BOH] Where BOMALT=[M:BOH0]BOMALT & BOMALTTYP=[M:BOH0]BOMALTTYP
#For [BOH]
#    If [F:BOH]ITMREF<>[M:BOH0]ITMREF
#        OK=adxlog
#        If !OK : Trbegin [BOHW] : Endif
#        Readlock [BOHW]BOH0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOH0]BOMALTTYP
#        If !fstat
#            [F:BOHW]ACSCOD =  [F:BOH]ACSCOD
#            Rewrite [BOHW]
#            If fstat & !OK : Rollback : OK=1 : Endif
#        Endif
#        Unlock [BOHW]
#        If !OK : Commit : Endif
#        OK=1
#    Endif
#    If OK=1 Break Endif
#Next
#Filter [BOH]
#X3-38684 CATUA.eo

# c'est la première nomenclature qui possède cette alternative
#If !OK #X3-38684 CATUA.o
  Read [TBO]TBO0 =[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
  If !fstat
    Read [ACC]CODACC=GUSER;[F:TBO]ACSCOD
    If !fstat & [F:ACC]CODACC<>""
        OK=adxlog
        If !OK : Trbegin [BOH] : Endif
        Readlock [BOH]BOH0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOH0]BOMALTTYP
        If !fstat
            [F:BOH]ACSCOD = [F:ACC]CODACC
            Rewrite [BOH]
            If fstat & !OK : Rollback : OK=1 : Endif
        Endif
        Unlock [BOH]
        If !OK : Commit : Endif
        OK=0
    Endif
  Endif
#Endif #X3-38684 CATUA.o

# 98144 - Perform allergens rollup
If !GIMPORT & func AFNC.ACTIV("FOA") : Call AUTOROLLUP From FUNFOAROLL : Endif  # 106737.n - Added !GIMPORT

Return

##############################################################
# Traitements complémentaires effectués à la ligne
##############################################################
$VALLIG
# Issue 104223 - 2015-04-13 by CCC : Call of SUBBODB.UPDLLC

If dim([L]LLCBOD)<0
   Local Integer LLCNBR
   LLCNBR = max(0,dim([M]CPNITMREF)) + max(0,dim([L]OCPN))
   LLCNBR = max(1,LLCNBR)
   Local Char    LLCBOD([V]GLONITM+2)(LLCNBR)
   LLCNBR=0
Endif

If SIGN=+1
    If find([M]CPNITMREF(nolign-1)-num$([M]CPNTYP(nolign-1)),LLCBOD(0..LLCNBR-1))
       Return
    Endif
    LLCBOD(LLCNBR) = [M]CPNITMREF(nolign-1)-num$([M]CPNTYP(nolign-1))
    LLCNBR+=1
Else
    If find(OCPN(nolign-1),LLCBOD(0..LLCNBR-1))
       Return
    Endif
    LLCBOD(LLCNBR) = OCPN(nolign-1)
    LLCNBR+=1
Endif

# Issue 118021 GH 07/09/2016 - if there is an issue for ITMBOM updates, it doesn't stop the transaction
#                              in this case, we ask to execute the resynchronization of LLC
J=GOK : GOK=1
If SIGN=+1
    Call UPDLLC([M:BOH0]BOMALTTYP, [M:BOH0]BOMALT, [M:BOH0]ITMREF, [M]CPNITMREF(nolign-1), [M]CPNTYP(nolign-1), SIGN) From SUBBODB
Else
    Call UPDLLC([M:BOH0]BOMALTTYP, [M:BOH0]BOMALT, [M:BOH0]ITMREF, OCPN(nolign-1), 0, SIGN) From SUBBODB
Endif
If GOK<1 : SYNCLLC=1 : Endif
GOK=J
Return

############################################
$RAZCRE
Call RAZ_CLOB From ACLOB
[M:BOH0]HEATEX  = ""
Raz [M:BOD1]BOMTEXNUM
If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif

# initialiser la date CUMREF pour les contrôles qte  (bug 17507)       03/03/03
[M:BOH0]CUMREF = datesyst

#VPO 20/03/09
Gosub GRIZEBUTPLM

Gosub AFFMASK From ECCBOM

# Issue 110957 - 2015-09-21 by GH
If !GIMPORT
   If dim([M:BOH0]CRID)>0 : Diszo [BOH0]CRID : Endif
   If dim([M:BOD1]CRID)>0 : Diszo [BOD1]CRID : Endif
Endif
Return

##############################################
$RAZDUP
Local Integer WRET,I
Call RAZ_CLOB From ACLOB
Call DUP_CLOB("BOH",[M:BOH0]HEATEX,WRET) From TRTX3TEX
If WRET<1 Raz [M:BOH0]HEATEX : Endif

For I=0 To [M:BOD1]NBLIG-1
    Call DUP_CLOB("BOD",[M:BOD1]BOMTEXNUM(I),WRET) From TRTX3TEX
    If WRET<1 Raz [M:BOD1]BOMTEXNUM(I) : Endif
Next

# versioning
If dim([L]TRTGBM)=1 & [L]TRTGBM="CREEVL" : Return : Endif
Gosub RAZDUP From ECCBOM

Raz [M:BOD1]UPDFLG
Raz [M:BOD1]CREFLG

#raz de la zone de PLM
If dim([M:BOH0]PLMATTURL)>0
   Raz [M:BOH0]PLMATTURL : Affzo [M:BOH0]PLMATTURL
Endif
#VPO 20/03/09
Gosub GRIZEBUTPLM
Return

##################################################
# 27172 12.04 MM
$EXEACT
Case BOUT
    When "C" :
    # Si la nomenclature possède une alternative à laquelle est attribuée un code accès
    # pour lequel l'utilisateur n'a pas les droits en modification, on interdit la création/duplication
    If GREP="D"
    Read  [ACC]CODACC = GUSER;[F:TBO]ACSCOD
    If !fstat & [F:ACC]MODIF=1
        mkstat =2 : GMESSAGE = mess(144,199,1)  #Pas d'autorisation de modification sur cette alternative
    Endif
    Endif

Endcase
Return

##################################################
# Définition et exécution des boutons spéciaux   #
##################################################
$AVANTBOUT
Local Integer  WRETOUR
Local Char     WNUMTEX(12), WCLE1(100), WCLE2(100)
Local Integer  WMODULE : WMODULE=9
Local Char     WTYP(4)

Local Char     ALTALP(3) : # alternative format alpha pour appel action objet
Local Integer  NBTRO
Local Char     WGAMME(GLONITM)    : # utilisé en param de l'action objet sur fenetre

Case BOUT
  When "F" :   If [M:BOH0]ITMREF = "" & GREP <> "C" & GREP <> "D"
#                       GMESSAGE est à blc, il faut positionner ERR
                        GERR = 1 : GMESSAGE= "" : Return
               Endif
 When "1":
    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681
        # 56970
        If clalev([TRO]) : Close Local File [TRO] : Endif
        If clalev([ROH]) : Close Local File [ROH] : Endif

        Local File TABROUALT [TRO] Where BOMALT1=[M:BOH0]BOMALT | BOMALT2=[M:BOH0]BOMALT | BOMALT3=[M:BOH0]BOMALT
    #   sélectionner les alt. de gammes qui ont pour alt.nomencl associée
    #   l'alternative passée en paramètre
        For [TRO]TRO0
            GROUALT (NBTRO) = [F:TRO]ROUALT
            NBTRO += 1
        Next
    Endif

    # llc 02.01 7996, si alternative liée à un site, recherche gamme mère
    WGAMME = [M:BOH0]ITMREF
    If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
    If [F:TBO]BOMALT <> [M:BOH0]BOMALT | [F:TBO]BOMALTTYP <> [M:BOH0]BOMALTTYP
        Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
        If fstat : Raz [TBO] : Endif
    Endif

    # llc 04.01 8741
    If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
    If [F:ITF]ITMREF <> [M:BOH0]ITMREF
        If [F:TBO]FCY <> ""
            Read [ITF]ITF0=[M:BOH0]ITMREF;[F:TBO]FCY
            If fstat : Raz [ITF] : Endif
        Else
            Filter [ITF] Where ITMREF = [M:BOH0]ITMREF
            Read [ITF] First
            If fstat : Raz [ITF] : Endif
            Filter [ITF]
        Endif
    Endif
    # Bug 69309 09/12/10
    If [F:ITF]MFGROU <> ""
        # ici on a toutes les information de la clé
        WGAMME = [F:ITF]MFGROU
        ALTALP =  num$([F:ITF]MFGROUALT)
    Else
        If NBTRO = 1
          # si on a qu'une seule alternative on la positionne
          ALTALP = num$(GROUALT(0))
        Else
          # ici on se sait pas quelle alternative prendre
          ALTALP = ""
        Endif
    Endif
    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681
        # table réouverte systématiquement pour filtre !
        If [F:TBO]FCY <> ""
            Local File ROUTING [ROH] Where find(ROUALT, GROUALT)<>0 & ITMREF=WGAMME & FCY = [F:TBO]FCY
        Else
            Local File ROUTING [ROH] Where find(ROUALT, GROUALT)<>0 & ITMREF=WGAMME
        Endif
    Endif
  When "3"  #recette
     If clalev([M:VBOG]):[M:BOH0]STOFCY = [M:VBOG]STOFCY :Endif
     # GFONCTION ="VISUBOMROU" # GH 21/01/2014 bug 95091
  When "2"
     If clalev([M:VBOR]):[M:BOH0]STOFCY = [M:VBOR]STOFCY :Endif
Endcase
Return


$SETBOUT
If CLECUR & GREP="" Then
  CHAINE += "A"
Endif
Call VIREBOUT(CHAINE,"HT") From GOBJET # T oté car variante mais pas transaction
#---------------------------------------------------------------------------------#
# Activation / Désactivation menus "Texte entête" dans la ToolBar                 #
#---------------------------------------------------------------------------------#
If GREP<>"D" & GREP<>"C" & CLECUR=0
 ##  ETAMEN(1)=0
Else
 ##  ETAMEN(1)=1
   CHMEN += "F"   # v 140
Endif
#Listes des OF
CHMEN += "@"

# 98144 - Food allergens
CHMEN+="Of"
#
#  Autorisation de modif selon accès de l'altern. pour ce profil
If CLECUR1 <> ""
 Read [ACC]CODACC=GUSER;[F:BOH]ACSCOD    # 24415 11.04 MM
 If !fstat & [F:ACC]MODIF = 1
   Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Endif
Endif
# GA 09/2008 Accès nomenclature multi-niveaux sur les autres types de nomenclature
#If CLECUR = 0 | GFONBOD <> "BOMP" | GREP <> "" | GMODU(8) < 2
# MABON 16/12/08 : on ne peut aller dans les gammes si on vient des gammes par clic droit
If CLECUR = 0 | GREP <> "" | GMODU(8) < 2 | find("GESROU",GNAVIG(1..GPILNAV-1))
   Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If CLECUR = 0 | GREP <> "" | GMODU(8) < 2 | find("VISUBOMG",GNAVIG(1..GPILNAV-1))
   Call VIREBOUT(CHAINE,"2") From GOBJET #visu multi-niv (01/10/01 - 10716)
Endif
#
# désactivation du boutnon multi niveaux quand on vient d'un tunnel
If dim(TUNNEL)> 0 & TUNNEL=1 & GPILNAV>1 Then
#If dim(TUNNEL)> 0 and TUNNEL=1 Then : # GH 27/11/12 bug 85081
  If find(GNAVIG(GPILNAV-1),"VISUBOMG") Then
    If GFONBOD ="BOMP"
      Call VIREBOUT(CHAINE,"2") From GOBJET
    Elsif GFONBOD ="BOMS"
      Call VIREBOUT(CHAINE,"1") From GOBJET
    Endif
  Endif
  If find(GNAVIG(GPILNAV-1),"VISUBOMROU") or clalev([M:VBOR])  Then
     Call VIREBOUT(CHAINE,"3") From GOBJET
  Endif
Endif
If !CLECUR | GREP <> "" Then
  Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

Gosub SETBOUT From ECCBOM
Return

$EXEBOUT
Case REP
 When "1"
    If GMODU(8)=2 # Si et seulement si module GPAO actif ... FQ 75681
        # modélisé : après action de fenêtre, rétablir le contexte
        Raz GROUALT
        # 56970
        #If clalev([TRO]) <= 0 : Local File [TRO] : Endif
        #If clalev([ROH]) <= 0 : Local File [ROH] : Endif
        # Issue 48563 03/08/2017 by GEBIL : class was opened with a filter (can't see all lines)
        If clalev([F:ROH]) > 0 : Close Local File [ROH] : Endif
        Local File ROUTING [ROH]

        If clalev([F:TRO]) > 0 : Close Local File [TRO] : Endif
        Local File TABROUALT [TRO]
    Endif
    Default File [BOH]  : # pour restaurer la classe par défaut après le Local file

 When "2" : GFONCTION = "GESBOD" : # MAE, 11/07/11, bg 70480
 #When "3" : GFONCTION = "GESBOD" : # GH 21/01/2014 bug 95091
Endcase
Return

##################################################
## Contrôle d'annulation
##################################################
$VERF_ANU
# on ne peut pas annuler si la date de réf est <> 0 (enreg filtrés)
# Si l'on vient de la modif après suppr des lignes le test est inutile (fait en Verif_mod)
If GDATEREF <> [0/0/0] & GREP = "A"
  GMESSAGE = mess(69,199,1)
  OK = 0 : Return
Endif

Gosub VERF_ANU From ECCBOM
If !OK : Return : Endif
Return

##################################################
## Traitements particuliers d'annulation
##################################################
$ANNULE
# L'action VALLIG sera appelée pour chaque ligne avec SIGN=-1
# Les variables de OUVRE ne sont plus connues à ce niveau
# car ces étiquettes sont appelées depuis le Trt ANUCOD !!!!!!

Gosub ANNULE From ECCBOM
If GOK<1 : Return : Endif

If [M:BOH0]BOMALTTYP=3
    #Local Integer OSEQ(max(dim([M:BOS2]BOMSEQ),dim([M:BOD1]BOMSEQ)))
    Local Char    OCPN(GLONITM)(max(dim([M:BOS2]BOMSEQ),dim([M:BOD1]BOMSEQ)))
Else
    #Local Integer OSEQ(dim([M:BOD1]BOMSEQ))
    Local Char    OCPN(GLONITM)(dim([M:BOD1]BOMSEQ))
Endif
Local Integer WLLCTYP, SYNCLLC, SIGN, J
Local File    BOMD [BOD2]

# FGR 01/10/2009 : X3SUIVI57935
Call SUPTEXTRA("BOM", "BOMDESAXX", [M:BOH0]ITMREF+"~"+num$([M:BOH0]BOMALT),num$([M:BOH0]BOMALTTYP)) From ATEXTRA

WLLCTYP = func LLCLIB.LLCTYP([M:BOH0]BOMALTTYP)

Read [ITB]ITB0 = [M:BOH0]ITMREF;[M:BOH0]BOMALT;WLLCTYP
If !fstat
    #SAVLLC = [F:ITB]LLC   # Issue 104223
    SIGN = -1
    For nolign = 1 To [M:BOD1]NBLIG
        #OSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign - 1)
        OCPN(nolign-1) = [M:BOD1]CPNITMREF(nolign - 1)
        Gosub VALLIG
    Next nolign
    # Issue 94401 - 2014-01-27 by CCC : update ITB for services
    If [M:BOH0]BOMALTTYP=3
        Raz OCPN : #, OSEQ
        For nolign = 1 To [M:BOS2]NBLIG
            #OSEQ(nolign-1) = [M:BOS2]BOMSEQ(nolign - 1)
            OCPN(nolign-1) = [M:BOS2]CPNITMREF(nolign - 1)
            Gosub VALLIG
        Next nolign
    Endif

    # Issue 104223 - 2015-04-15 by CCC : ITB has to be deleted after update of components
    # FQ 67833 GA 10/2010 VALLIG sert à mettre a jour [F:ITB] (code déplacé dans le If !fstat)
    # s'il n'y a plus de cas d'emploi, supprimer l'enreg (bug 8140  26/02/01)
    # GH 28/04/2015 bug 114730 : read again [F:ITB] for the parent item, because it was changed meanwhile
    Read  [ITB]ITB0 = [M:BOH0]ITMREF;[M:BOH0]BOMALT;WLLCTYP
    If !fstat
      If [F:ITB]WUSEXIFLG = 2
        # mise à jour de ITB pour le composé
        [F:ITB]BOMEXIFLG = 1 : # mis à NON
        Rewrite [ITB]
      Else
        Delete  [ITB]
      Endif
      If fstat : SYNCLLC=1 : Endif
    Endif
Endif

# 106737.sn
Read [ITM]ITM0 = [M:BOH0]ITMREF
If !fstat
  [F:ITM]ALG    = ""
  [F:ITM]ALGDAT = date$
  [F:ITM]ALGBOM = 0
  Rewrite [ITM]
Endif
# 106737.en

If SYNCLLC & GTRACE<>""
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
  SYNCLLC=0
Endif
Return

$AP_ANNULE
If SYNCLLC
  # Il serait préférable de lancer Resynchronisation codes de plus bas niveau
  Call ERREUR(mess(198,196,1)) From GESECRAN
  SYNCLLC=0
Endif
Return

########################################################
$SUPPRESS_TEX
Local Integer WRET, I
# on ne vire les textes que si abandon en dupplication
If GREP = "D"
      Call SUP_CLOB([M:BOH0]HEATEX,WRET) From TRTX3TEX
      For I=0 To [M]NBLIG-1
          Call SUP_CLOB([M:BOD1]BOMTEXNUM(I),WRET) From TRTX3TEX
      Next I
Endif
Call RAZ_CLOB From ACLOB
Return

