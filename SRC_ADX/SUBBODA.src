  GPOINT = "BEFREWBOH" : GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE > 0 : GOK=0 : Return : Endif
#
  Rewrite [BOH]
  If fstat
   GOK=0 : Call FSTA("BOH") From GLOCK
  Endif
