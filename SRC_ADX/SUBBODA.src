$REWRITE_BOD
  [F:BOD]UPDUSR=GUSER    # FQ 77838 GA 11/2011
  [F:BOD]UPDDAT=date$
# point d'entrée  pour mise à jour sur [F:BOD]
  GPOINT = "BEFREWBOD" : GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE > 0 : GOK=0 : Return : Endif
#
  Rewrite [BOD]
  If fstat
   GOK=0 : Call FSTA("BOD") From GLOCK
  Endif
