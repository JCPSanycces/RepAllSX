#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char    LSENS : LSENS="-"
Local Date    WD1   : WD1=[21/11/2006]
Local Date    WD2
Local Integer LPER  : LPER=15    
Local Integer WAN, WMO
Local Integer WNB1, WNB2
Local Decimal WMD

Infbox num$(WD2)
End

#########################################################################
# CALDATPER   Calcul d'une date à partir d'une date origine en fonction 
#             d'un type et d'un nombre de périodes et selon un sens     
#------------------------------------------------------------------------
# Entrée      LTYP     : 1=Journée
#                        2=Semaine
#                        3=Quinzaine
#                        4=Mois
#                        5=Trimestre
#                        6=Semestre
#                        7=Année
#                        8=Décade
#             LPER     : Nombre de périodes
#             LSENS    : +=en plus
#                        -=en moins 
#             LOLDDAT  : Ancienne date origine
#             LNEWDAT  : Nouvelle date origine
#-----------------------------------------------------------------------
# Sortie      LCALDAT  : Date calculée 
#                        [00/00/00] si LOLDDAT et LNEWDAT dans la même 
#                        période (pas de calcul) 
#
######################################################################## 
Subprog CALDATPER (LTYP,LPER,LSENS,LOLDDAT,LNEWDAT,LCALDAT)
Value    Integer LTYP
Value    Integer LPER
Value    Char    LSENS
Value    Date    LOLDDAT
Value    Date    LNEWDAT
Variable Date    LCALDAT

Local    Date    WD1, WD2
Local    Integer WAN, WMO, WJO
Local    Integer WNB1, WNB2
Local    Decimal WMD

LCALDAT = [00/00/00]

If LNEWDAT=[00/00/00] | LPER=0 | !find(LSENS,"+","-") : End : Endif

If year(LOLDDAT)=year(LNEWDAT)
   Case LTYP
    When 2 : If week(LOLDDAT) =week(LNEWDAT)  : End : Endif 
    When 3 : If month(LOLDDAT)=month(LNEWDAT) & int(day(LOLDDAT)/16)=int(day(LNEWDAT)/16) : End : Endif 
    When 4 : If month(LOLDDAT)=month(LNEWDAT) : End : Endif 
    When 5 : If int(month(LOLDDAT)/3)=int(month(LNEWDAT)/3) : End : Endif 
    When 6 : If int(month(LOLDDAT)/6)=int(month(LNEWDAT)/6) : End : Endif 
    When 7 : End
    When 8 : If month(LOLDDAT)=month(LNEWDAT)
                If day(LOLDDAT)<=10 
                   If day(LNEWDAT)<=10 : End : Endif
                Elsif day(LOLDDAT)<=20  
                   If day(LNEWDAT)> 10 & day(LNEWDAT)<=20 : End : Endif
                Elsif day(LOLDDAT)> 20
                   If day(LNEWDAT)> 20 : End : Endif
                Endif
             Endif  
   Endcase
Endif

WD1 = LNEWDAT
WD2 = LCALDAT

Case LTYP

 When 1 : If LSENS="-"                 : #--- Jour
             WD2 = WD1-(LPER-1)
          Else
             WD2 = WD1+(LPER-1)
          Endif

 When 2 : If LSENS="-"                 : #--- Semaine
             WD2 = WD1-(LPER-1)*7
             WD2-= dayn(WD2)-1     : # passage au lundi précédent
          Else
             WD2 = WD1+(LPER-1)*7
             WD2+= 7-dayn(WD2)     : # passage au dimanche suivant
          Endif

 When 3 : WNB1 = int((LPER-1)/24)       : #--- Quinzaine
          WNB2 = mod((LPER-1),24)

          If LSENS="-"
             If day(WD1)<16 WNB2+=1 Endif
             WMD = month(WD1)-int(WNB2/2)
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1 
             Else
                WMO  = WMD
             Endif
             WAN = year(WD1)-WNB1
             If mod(WNB2,2)=0
                WJO=16
             Else
                WJO=1
             Endif
             WD2 = gdat$(WJO,WMO,WAN)
          Else
             If day(WD1)>15 WNB2+=1 Endif
             WMD = month(WD1)+int(WNB2/2)
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif 
             WAN = year(WD1)+WNB1
             If mod(WNB2,2)=0
                WJO=15
             Else  
                Case WMO
                 When 1,3,5,7,8,10,12 : WJO = 31
                 When 4,6,9,11        : WJO = 30
                 When 2               : If mod(2000+WAN,4)=0
                                           WJO=29 
                                        Else
                                           WJO=28
                                        Endif
                Endcase
             Endif
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 4 : WNB1 = int((LPER-1)/12)        : #--- Mois 
          WNB2 = mod((LPER-1),12) 
          If LSENS="-"
             WMD = month(WD1)-WNB2
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1 
             Else
                WMO  = WMD
             Endif
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif 
             WAN = year(WD1)+WNB1
             Case WMO
              When 1,3,5,7,8,10,12 : WJO = 31
              When 4,6,9,11        : WJO = 30
              When 2               : If mod(2000+WAN,4)=0
                                        WJO=29 
                                     Else
                                        WJO=28
                                     Endif
             Endcase
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 5 : WNB1 = int((LPER-1)/4)         : #--- Trimestre
          WNB2 = mod((LPER-1),4) 
          If LSENS="-"
             WMD = month(WD1)-WNB2*3
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1
             Else
                WMO  = WMD
             Endif
             If    WMO>9  WMO=10
             Elsif WMO>6  WMO=7 
             Elsif WMO>3  WMO=4 
             Else         WMO=1
             Endif  
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2*3
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif
             If    WMO<4  WMO=3
             Elsif WMO<7  WMO=6 
             Elsif WMO<10 WMO=9 
             Else         WMO=12
             Endif  
             WAN = year(WD1)+WNB1
             Case WMO
              When 3,12 : WJO = 31
              When 6,9  : WJO = 30
             Endcase
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 6 : WNB1 = int((LPER-1)/2)         : #--- Semestre
          WNB2 = mod((LPER-1),2) 
          If LSENS="-"
             WMD = month(WD1)-WNB2*6
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1
             Else
                WMO  = WMD
             Endif
             If    WMO>6  WMO=7
             Else         WMO=1
             Endif  
             WAN = year(WD1)-WNB1
             WD2 = gdat$(01,WMO,WAN)
          Else
             WMD = month(WD1)+WNB2*6
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif
             If    WMO<7  WMO=6
             Else         WMO=12
             Endif  
             WAN = year(WD1)+WNB1
             If WMO=12 WJO=31 Else WJO=30 Endif
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

 When 7 : If LSENS="-"                   :#--- Année
             WAN = year(WD1)-(LPER-1)
             WD2 = gdat$(01,01,WAN)
          Else
             WAN = year(WD1)+(LPER-1)
             WD2 = gdat$(31,12,WAN)
          Endif

 When 8 : WNB1 = int((LPER-1)/36)       : #--- Décade
          WNB2 = mod((LPER-1),36)

          If LSENS="-"
             If    day(WD1)<11 
                WNB2+=2
             Elsif day(WD1)<21
                WNB2+=1
             Endif
             WMD = month(WD1)-int(WNB2/3)
             If WMD<1 
                WMO  = WMD+12
                WNB1+= 1 
             Else
                WMO  = WMD
             Endif
             WAN = year(WD1)-WNB1
             If    mod(WNB2,3)=0
                WJO=21
             Elsif mod(WNB2,3)=1
                WJO=11
             Else
                WJO=1
             Endif
             WD2 = gdat$(WJO,WMO,WAN)
          Else
             If    day(WD1)>20
                WNB2+=2
             Elsif day(WD1)>10
                WNB2+=1
             Endif
             WMD = month(WD1)+int(WNB2/3)
             If WMD>12 
                WMO  = WMD-12
                WNB1+= 1  
             Else
                WMO  = WMD
             Endif 
             WAN = year(WD1)+WNB1
             If    mod(WNB2,3)=0
                WJO=10
             Elsif mod(WNB2,3)=1
                WJO=20
             Else  
                Case WMO
                 When 1,3,5,7,8,10,12 : WJO = 31
                 When 4,6,9,11        : WJO = 30
                 When 2               : If mod(2000+WAN,4)=0
                                           WJO=29 
                                        Else
                                           WJO=28
                                        Endif
                Endcase
             Endif
             WD2 = gdat$(WJO,WMO,WAN)
          Endif

Endcase

LCALDAT = WD2
     
End        

######################################################################
# CALPERNBR   Recalcul du nombre de périodes après un changement 
#             du code périodicité     
#---------------------------------------------------------------------
# Entrée            LOLDPERCOD : Ancien code périodicité
#                   LNEWPERCOD : Nouveau code périodicité
#                                1=Jour
#                                2=Semaine
#                                3=Quinzaine
#                                4=Mois
#                                5=Trimestre
#                                6=Semestre
#                                7=Année
#                                8=Décade
#---------------------------------------------------------------------
# Entrée /sortie    LPERNBR    : Nombre de périodes réajusté
###################################################################### 
Subprog CALPERNBR (LOLDPERCOD,LNEWPERCOD,LPERNBR)
Value    Integer LOLDPERCOD
Value    Integer LNEWPERCOD
Variable Decimal LPERNBR
#-----
Case LOLDPERCOD
  When 1
    Case LNEWPERCOD
      When 2 : LPERNBR=arr(LPERNBR/7,1)
      When 3 : LPERNBR=arr(LPERNBR/14,1)
      When 4 : LPERNBR=arr(LPERNBR/30.41,1)
      When 5 : LPERNBR=arr(LPERNBR/91.25,1)
      When 6 : LPERNBR=arr(LPERNBR/182.5,1)
      When 7 : LPERNBR=arr(LPERNBR/365,1)
      When 8 : LPERNBR=arr(LPERNBR/3652,1)
    Endcase
  When 2
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*7,1)
      When 3 : LPERNBR=arr(LPERNBR/2,1)
      When 4 : LPERNBR=arr(LPERNBR/4.34,1)
      When 5 : LPERNBR=arr(LPERNBR/13.03,1)
      When 6 : LPERNBR=arr(LPERNBR/26.07,1)
      When 7 : LPERNBR=arr(LPERNBR/52.14,1)
      When 8 : LPERNBR=arr(LPERNBR/521.4,1)
    Endcase
  When 3
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*14,1)
      When 2 : LPERNBR=arr(LPERNBR*2,1)
      When 4 : LPERNBR=arr(LPERNBR/2.17,1)
      When 5 : LPERNBR=arr(LPERNBR/6.51,1)
      When 6 : LPERNBR=arr(LPERNBR/13.03,1)
      When 7 : LPERNBR=arr(LPERNBR/26.07,1)
      When 8 : LPERNBR=arr(LPERNBR/260.7,1)
    Endcase
  When 4
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*30.41,1)
      When 2 : LPERNBR=arr(LPERNBR*4.34,1)
      When 3 : LPERNBR=arr(LPERNBR*2.17,1)
      When 5 : LPERNBR=arr(LPERNBR/3,1)
      When 6 : LPERNBR=arr(LPERNBR/6,1)
      When 7 : LPERNBR=arr(LPERNBR/12,1)
      When 8 : LPERNBR=arr(LPERNBR/120,1)
    Endcase
  When 5
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*91.23,1)
      When 2 : LPERNBR=arr(LPERNBR*13.03,1)
      When 3 : LPERNBR=arr(LPERNBR*6.51,1)
      When 4 : LPERNBR=arr(LPERNBR*3,1)
      When 6 : LPERNBR=arr(LPERNBR/2,1)
      When 7 : LPERNBR=arr(LPERNBR/4,1)
      When 8 : LPERNBR=arr(LPERNBR/40,1)
    Endcase
  When 6
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*182.5,1)
      When 2 : LPERNBR=arr(LPERNBR*26.07,1)
      When 3 : LPERNBR=arr(LPERNBR*13.03,1)
      When 4 : LPERNBR=arr(LPERNBR*6,1)
      When 5 : LPERNBR=arr(LPERNBR*2,1)
      When 7 : LPERNBR=arr(LPERNBR/2,1)
      When 8 : LPERNBR=arr(LPERNBR/20,1)
    Endcase
  When 7
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*365.2,1)
      When 2 : LPERNBR=arr(LPERNBR*52.14,1)
      When 3 : LPERNBR=arr(LPERNBR*26.07,1)
      When 4 : LPERNBR=arr(LPERNBR*12,1)
      When 5 : LPERNBR=arr(LPERNBR*4,1)
      When 6 : LPERNBR=arr(LPERNBR*2,1)
      When 8 : LPERNBR=arr(LPERNBR/10,1)
    Endcase
  When 8
    Case LNEWPERCOD
      When 1 : LPERNBR=arr(LPERNBR*3652,1)
      When 2 : LPERNBR=arr(LPERNBR*521.4,1)
      When 3 : LPERNBR=arr(LPERNBR*260.7,1)
      When 4 : LPERNBR=arr(LPERNBR*120,1)
      When 5 : LPERNBR=arr(LPERNBR*40,1)
      When 6 : LPERNBR=arr(LPERNBR*20,1)
      When 7 : LPERNBR=arr(LPERNBR*10,1)
    Endcase
Endcase
#-----
End

