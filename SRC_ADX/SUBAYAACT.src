#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion Action Xtend
## Actions X3
#  Version 0001
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 

Case ACTION
 When "SUP"              : Gosub SUP
 When "OUVRE"            : Gosub OUVRE
 When "DEBUT"            : Gosub DEBUT
 When "TITRE"            : Gosub TITR
 When "SEL_LISTE"        : Gosub SEL_LISTE
 When "TRT_DIV"          : Gosub TRT_DIV
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYAFIESEL     FIESEL        Sélection d'un champ Action
#      AYAFIECTL     FIECTL        Controle d'un champ Action
#      AYAPARUSG     PARUSG        Utilisation d'un paramètre d'une action
######################################################################################
$TRT_DIV
Case TRAIT
  When "FIECTL" : Gosub FIE_CTL
Endcase
Return

$SEL_LISTE
Case LISTE
  When "FIESEL" : Gosub FIE_SEL
Endcase
Return

$OUVRE
Case GACTION
  When "AYAPARUSG" : Gosub PARUSG_OUV
Endcase
Return

$DEBUT
Case GACTION
  When "AYAPARUSG" : Gosub PARUSG_DEB
Endcase
Return

$TITR
Case GACTION
  When "AYAPARUSG" : Gosub PARUSG_TIT
Endcase
Return

$SUP
Case GACTION
  When "AYAPARUSG" : Gosub PARUSG_SUP
Endcase
Return


#    AYAFIESEL  Sélection d'un champ Action
######################################################################################
# VALEUR        Code champ    A    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Site Xtend    V
#          2    Code Action   V        
#          3    Code Entité   V
#          4    Options       V      "F": Gestion Action par file (non utilisée)
#                                    "S": Paramètres en saisie uniquement (cas Action uniquement)
#               
$FIE_SEL
#---------------------------------------------------------------#
Local Char FCYWRK(GLONAYG), ENTCOD(GLONAYE), LNKENTCOD(GLONAYE), LNKFIECOD(GLONAYF)
Local Char WSTR, OPTION
Local Integer WI, W_ACTPARALL
If clalev([F:AYN])=0 : Local File AYTLINES [AYN] : Endif
[L]FCYWRK= PARAM(1)  # Site 
[L]ENTCOD= PARAM(3)  # Entité
[L]OPTION= PARAM(4)

W_ACTPARALL=(instr(1,OPTION,"S")=0)

If [L]ENTCOD=""    # Saisie des paramétres (par écran AYA1)
    TIT=mess(82,7900,1)-[L]ENTCOD
    For WI=0 To [AYA1]NUM40-1
        If (W_ACTPARALL | [AYA1]VALTYP40(WI)=6)    # Tous ou uniquement ceux en saisie
            NBTEX+=1
            TEX(NBTEX)=[AYA1]PARCOD40(WI)
            TEXTE(NBTEX)=TEX(NBTEX)
            If dim([AYA1]ZPARCOD40(WI))>0 : TEXTE(NBTEX)=TEXTE(NBTEX)-"-"-[AYA1]ZPARCOD40(WI) : Endif
        Endif
    Next
Else               # Saisie chps de l'entité lié à l'interface
    ## Action AYEFIESEL
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "AYEFIESEL"
    PARMSK(1) = [L]FCYWRK
    PARMSK(2) = [L]ENTCOD
    PARMSK(3) = "EL"    # ts les chps - Pas d'option I car il ne s'agit pas de l'interface d'accès...
    Call S_LIS_CHAR(VALEUR,PARMSK,"FIESEL","SUBAYEACT","") From GACTION
    GACTION = SAVACT
Endif
Return


#    AYAFIECTL  Controle d'un champ Action
######################################################################################
# VALEUR        Code champ    A    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Site Xtend    V
#          2    Code Action   V        
#          3    Code Entité   V
#          4    Options       V      "F": Gestion Action par file (non utilisée)
#                                    "S": Paramètres en saisie uniquement (cas Action uniquement)
#               
$FIE_CTL
Local Char FCYWRK(GLONAYG), ENTCOD(GLONAYE), LNKENTCOD(GLONAYE), LNKFIECOD(GLONAYF)
Local Char WFILT(200), WSTR(200), OPTION
Local Integer WI, W_ACTPARALL
[L]FCYWRK= PARAM(1)  # Site 
[L]ENTCOD= PARAM(3)  # Entité
[L]OPTION= PARAM(4) 

W_ACTPARALL=(instr(1,OPTION,"S")=0)

If [L]ENTCOD=""    # Saisie des paramétres (écran AYA1)
    If !find(VALEUR,[M:AYA1]PARCOD40) 
        mkstat=2 
        GMESSAGE=mess(83,7900,1)
    Else
        If (!W_ACTPARALL & [AYA1]VALTYP40(WI)<>6)    # Uniquement paramètres en mode saisie
            mkstat=2 
            GMESSAGE=mess(135,7900,1)
        Endif
    Endif
Else               # Saisie chps de l'entité lié à l'interface
  ## Action AYEFIECTL
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "AYEFIECTL"
  PARMSK(1) = [M]FCYCOD
  PARMSK(2) = [L]ENTCOD
  PARMSK(3) = "EL"
  Call S_AFF_CHAR(VALEUR,PARMSK,"FIECTL","SUBAYEACT","") From GACTION
  GACTION = SAVACT
Endif

Return

#    AYAPARUSG  Usage d'un paramètre d'une action
######################################################################################
# PARAM    1    Site Xtend    V
#          2    Code Action   V        
#          3    Code Para     V
#          4    Retour        A      0:pas d'usage   1:des usages
#          5    Msg origine   V
#               
$PARUSG_OUV
#---------------------------------------------------------------#
Local Char FCYCOD(GLONAYG), ACTCOD(GLONAYA), PARCOD(GLONAYF)
Local Char MSGORI(120)
[L]FCYCOD= PARAM(1)  
[L]ACTCOD= PARAM(2) 
[L]PARCOD= PARAM(3) 
[L]MSGORI= PARAM(5) 

If [L]PARCOD="" : FIN=1 : Return : Endif   

Local Integer MSGNB
Local Char    MSGTAB(100)(1..30)
Local Integer MSGTABMAX : MSGTABMAX = dim(MSGTAB)


If clalev([F:AYN])=0 : Local File AYTLINES  [AYN] : Endif

#  Recherche utilisation sur lien dynamique
If clalev([F:AYL])=0 : Local File AYTELTDLK [AYL] : Endif
For [F:AYL]AYL0 Where FCYCOD=[L]FCYCOD and ACTCOD=[L]ACTCOD
    For [F:AYN]AYN0 Where FCYCOD=[L]FCYCOD and LINCODTYP = 4
&                     and LINCOD = toupper([F:AYL]DLKCOD) and  LINTYP = 41
&                     and PARCOD = [L]PARCOD
        MSGNB+=1 : RET=0
        If MSGNB>= MSGTABMAX : MSGTAB(MSGNB)=mess(109,7900,1) : Break 2 : Endif
        MSGTAB(MSGNB)=mess(10,7910,1)-[F:AYL]DLKCOD   #-[F:AYN]LINCOD
    Next
Next

PARAM(4)=num$(MSGNB<>0)
If MSGNB=0 : FIN=1 : Endif
Return

$PARUSG_TIT
#---------------------------------------------------------------#
TIT=mess(106,7900,1)+":"-[L]PARCOD  
Return

$PARUSG_DEB
#---------------------------------------------------------------#
[M:DIA]MSG1=[L]MSGORI
[M:DIA]MSG2=mess(138,7900,1)
[M:DIA]MSG3=mess(142,7900,1)
[M:DIA]MSGCLB=""
For WI=1 To MSGNB
    [M:DIA]MSGCLB+=MSGTAB(WI)+chr$(13)+chr$(10)
Next
Diszo [M:DIA]MSGCLB  # Permet le copier par rapport à un champ en saisie
Return

$PARUSG_SUP
#---------------------------------------------------------------#
# Suppresion des cas d'emploi des liens dynamiques
# - - - - - - - - - - - - - - - - - - - - - - - -
Local Char WSYMB_AYL(40)    # Symbole objet lien dynamique
If clalev([F:AYN])=0 : Local File AYTLINES  [AYN] : Endif
If clalev([F:AYL])=0 : Local File AYTELTDLK [AYL] : Endif

$TR_DEL
GOK = 1
Trbegin [AYN]
For [F:AYL]AYL0 Where FCYCOD=[L]FCYCOD and ACTCOD=[L]ACTCOD
    WSYMB_AYL="AYL"+[F:AYL]DLKCOD+"\"+[L]FCYCOD
    Lock =WSYMB_AYL
    If fstat
        Local Char MACHINE(GDIMFIC), USER
        Call  QUILOCKE(WSYMB_AYL,MACHINE,USER) From OBJDIV
        GMESSAGE=mess(10,7910,1)+":"-[F:AYL]DLKCOD+"\"+mess(140,7900,1)-GUSER+"/"+MACHINE 
        Goto AB_TR_DEL
    Endif
    Delete [F:AYN] Where FCYCOD=[L]FCYCOD and LINCODTYP = 4
&                     and LINCOD = toupper([F:AYL]DLKCOD) and  LINTYP = 41
&                     and PARCOD = [L]PARCOD
    If fstat=1
      GOK=-1 : GLOCK = "$AYTLIN" : Goto ROLL_TR_DEL
    Elsif fstat>5
      GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
    Endif
    Unlock =WSYMB_AYL
Next

Commit
PARAM(4)="0"    # Plus d'utilisation
FIN=1
Return

$AB_TR_DEL
Rollback
PARAM(4)=1
Return

$ROLL_TR_DEL
Rollback
Call ROLL From GLOCK
If GROLL : PARAM(4)=1 : Return : Else : Goto TR_DEL : Endif


