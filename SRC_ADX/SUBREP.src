#Local Char SZMESSAGE(250)
#Local Integer IBRETOUR
#Raz SZMESSAGE
#IBRETOUR=1
#
#Call MAJ_HC_BP ( nomap,[M:REP0]REPNUM,[M:BPRR]BPRNAM,"[M:BPAR]", SZMESSAGE, IBRETOUR) From TRTHCODE
#If IBRETOUR=0
#    GMESSAGE=SZMESSAGE
#    GERR=1
#    GOK=0
#    Return
#Endif

#CRM
Gosub CREATION_CRM From TRTBPCRM
If GOK < 1 : Return : Endif
#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:REP0]REPNUM <> ""
    Read [BPRW]BPR0 = [M:REP0]REPNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif

Return

###################################################################
$AVANTMOD
#---- verrouillage symbole BPR       #

#SYMBOLE2 = "BPR"+num$([M:REP0]REPNUM) : # cg le 28/01/98
#Lock = SYMBOLE2 With lockwait = 0
#OK = 1
#If fstat
#     Call ERREUR(mess(10,100,1)) From GESECRAN
#     OK = 0
#Endif
Return

###################################################################
$VERROU
If [M:REP0]REPNUM <> ""
        Read [BPR]BPR0 = [M:REP0]REPNUM
        If fstat = 0
            #------------------------------------#
            # il faut verrouiller symbole BPR    #
            #------------------------------------#
            SYMBOLE2 = "BPR"+num$([M:REP0]REPNUM)
            Lock = SYMBOLE2 With lockwait = 0
            If fstat
#              Call ERREUR(mess(10,100,1)) From GESECRAN
               #-- on debloque le BPS - modif non autorisée
               #-- sinon on a probleme sur lock reste dans le fichier
               Unlock = SYMBOLE
               OK = 0
            Endif
         Endif
Endif
Return

###################################################################
$FINMODIF
  #---- deverrouillage symbole BPR       #
  # FGR 15/10/2009 : X3SUIVI58119 : on délocke dans DEVERROU, c'est tout
  #SYMBOLE2 = "BPR"+num$([M:REP0]REPNUM) : # cg le 28/01/98
  #Unlock = SYMBOLE2
  Diszo [M:REP1]CLLDEL
  Affzo [M:REP1]CLLDEL
  Gosub FIN_GILOCKBPR  # FGR 16/04/2012 : X3SUIVI81335
Return

###################################################################
$DEVERROU
  #-------------------------------------------------#
  # il faut deverrouiller BPARTNER                  #
  #-------------------------------------------------#
  # FGR 15/10/2009 : X3SUIVI58119 : on délocke dans DEVERROU, c'est tout
  SYMBOLE2 = "BPR"+num$([M:REP0]REPNUM)
  Unlock = SYMBOLE2
Return

###################################################################
$FIN_GILOCKBPR
  # FGR 16/04/2012 : X3SUIVI81335
  If dim(GILOCKBPR) >= 0 Then
    Gosub DEVERROU
    Kill GILOCKBPR
  Endif
Return

######################################################################
$AVANT_MODFIC
Local Integer WMAJNAM : Raz WMAJNAM
If [M:BPRR]BPRNAM <> [F:REP]REPNAM WMAJNAM=1 Endif
Return

###################################################################
$MODIF
#------------------------------------------------#
# creation ou modification enregistrement tiers  #
#------------------------------------------------#
Gosub CREBPR
If GOK < 1 : Return : Endif

#------------------------------------------------#
# creation ou modification enregistrement adresse#
#------------------------------------------------#
Gosub CREBPA
If GOK < 1 : Return : Endif

