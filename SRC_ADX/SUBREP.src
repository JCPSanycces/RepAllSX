#<AdxTL>@(#)9.0.0.0 $Revision$
Call OBJET ("REP",GBIDC1,GBIDC2) From GOBJET
End
########################################################################
# gestion des représentants                            eb octobre 1997 #
#                                                                      #
# SUBREP.src                                                           #
########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AFFMASK"      : Gosub AFFMASK
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERIF_CRE"    : Gosub VERIFCRE_MOD    : # cg le 30/01/98
 When "INICRE"       : Gosub INIREP
 When "CREATION"     : Gosub CREATION
 When "VERIF_MOD"    : Gosub VERIFCRE_MOD    : # cg le 30/01/98
 When "INIMOD"       : Gosub INIREP
 When "AVANT_MOD"    : Gosub AVANTMOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "MODIF"        : Gosub MODIF
 When "FIN_MOD"      : Gosub FINMODIF
 When "ABANDON"      : Gosub FINMODIF
 When "ANNULE"       : Gosub ANNULE
 When "VERROU"       : Gosub VERROU          : # cg le 14/09/98
 #When "DEVERROU"     : Gosub FINMODIF        : # cg le 14/09/98
 When "DEVERROU"     : Gosub DEVERROU        : # FGR 15/10/2009 : X3SUIVI58119
 When "FERME"        : Gosub FERME
 When "APRES_CRE"    : Gosub APRES_CRE       : #Modif CRM 31 juillet 2000
 When "APRES_MOD"    : Gosub APRES_MOD       : #Modif CRM 31 juillet 2000
 When "AP_ANNULE"    : Gosub AP_ANNULE       : #Modif CRM 31 juillet 2000
 When "VERF_ANU"     : Gosub VERF_ANU        : #Modif CRM 26 mars 2001
 When "APRES_MODIF"  : Gosub APRES_MODIF     :
 When Default
Endcase
Return
####################################################################
$OUVRE
Local Char SYMBOLE2 (20) : # cg le 28/01/98
#--------------------------------------------------------#
# positionnement sur écran 2 (rep1) si on vient du tiers #
#--------------------------------------------------------#
If   clalev ([M:BPR0])
     PRMASK = 3
Endif

If !clalev([F:DIE])  : Local File GDIE     [DIE]  : Endif
If !clalev([F:CDI])  : Local File CADIEDEF [CDI]  : Endif

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

#---- alimentation des variables globales liées au site
Call GLOBVAR (GFCYDEF(9)) From WWGLOBVEN

#---- Initialisation du code comptable par défaut
#MAE, le 06/01/09, SUP_GACCCOD
#Call INITACCCOD(GACCCOD,4) From TRTX3

Local Integer WBPATYP : WBPATYP = 1

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="REP"

Return

####################################################################
$FERME

#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1 = "GESREP" :  GFONC1 = "" : Endif

#CRM
Gosub FERME_CRM From TRTBPCRM

Return

####################################################################
$SETBOUT
#---------------------------------------------#
# suppression du bouton #code :               #
# modif du n° seult dans la gestion des tiers #
#---------------------------------------------#
Call VIREBOUT (CHAINE,"H") From GOBJET
# ----------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                        #
# ----------------------------------------------------------------------------------------- #
# C : Consultations comptes  : Actif si représentant en ligne                               #
# ----------------------------------------------------------------------------------------- #
If CLECUR CHMEN += "C" : Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################################################
$LIENS
#-------------------------------------------------------------#
# lecture enregistrement tiers pour récuperer premier masque  #
#-------------------------------------------------------------#
Read [BPR]BPR0 = [M:REP0]REPNUM
If fstat = 0
    [M:BPRR] = [F:BPR]
    [M:REP0]REPNAM = [F:BPR]BPRNAM
    [M:BPRR]CUR    = [F:REP]CUR   : # Récupération devise représentant
Else
    Raz [M:BPRR]
Endif

# FGR 09/04/2013 : X3SUIVI89276 (début)
  If [F:REP]AUSNUM <> "" Then
    [M:REP0]REPUSRX3 = G_YES
  Else
    [M:REP0]REPUSRX3 = G_NO
  Endif
# FGR 09/04/2013 : X3SUIVI89276 (fin)

#-----------------------------#
# Chargement tableau des axes #
#-----------------------------#
If dim([M:REP1]NBAXE)>0
   Call CHARG_DIE(4,"","REP1","NBAXE") From TRTX3CPT
Endif

#MAE, bg 57776
If dim([M:REP1]NBRAT)>0
  If [M:REP1]NBRAT=0  [M:REP1]NBRAT=min(GCOMCAT,len(mess(0,403,1))) : Endif
Endif

# ------------------------------------------
# A SUPPRIMER
#-------------------------------------------------------------#
# lecture des adresses et chargement BPA                      #
#-------------------------------------------------------------#
#Call CHARG_BPA (GABREV,[M:REP0]REPNUM,1,[F:BPR]BPAADD ) From TRTADR
# ------------------------------------------

Default Mask [BPAR]
Call CHARG_BPA(WBPATYP,[M:REP0]REPNUM,[F:REP]BPAADD) From TRTBPA
Gosub DEFAUT

#-------------------------------------------------------------------------#
# Lecture de la fonction du représentant dans la table des utilisateurs   #
# Modif Module CRM                                         22 juin 2000   #
#-------------------------------------------------------------------------#
Local Char SZFNC
SZFNC = ""
If [M]AUSNUM <> ""
    Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
    If SZFNC = ""
        [M:REP1]FNC = 1
    Else
        [M:REP1]FNC = val(SZFNC)
    Endif
Else
    [M:REP1]FNC = 1
Endif
#-------------------------------------------------------------------------#
# Calcul le nombre d'appels en retard du représentant                     #
# Modif Module CRM                                         16 mars 2001   #
#-------------------------------------------------------------------------#

[M:REP1]CLLDEL=0

If GMODU(13) = 2
    If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
    Filter [CLL] Where [F:CLL]CLLDON <> 2 and [F:CLL]CLLREP = [M:REP0]REPNUM and [F:CLL]CLLDATX < date$
    [M:REP1]CLLDEL = 0
    For [CLL] CLL4
        [M:REP1]CLLDEL += 1
    Next
    Filter [CLL]
    Diszo [M:REP1]CLLDEL
    Affzo [M:REP1]CLLDEL
Endif


#LSE 02/03/2007
##---------------------------------------------------#
##Modif CRM 6/02/2002
#If GMODU(13) = 2
#    Call SETPREREP("REP") From TRTMST4
#Endif
##---------------------------------------------------#

#Initialisation CRM
Gosub LIENS_CRM From TRTBPCRM

Gosub GRIZE_LIENS

#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:REP0]REPNUM <> ""
    Read [BPRW]BPR0 = [M:REP0]REPNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif


Return

####################################################################
$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From="WGO"+GABREV
 Endif
Next MA
Return

###################################################################
$GRIZE_LIENS
#---------------------------------------------------#
#Modif CRM
If [M:REP1]FNC=3
    Actzo [M:REP1]OBJCLL
    Actzo [M:REP1]NSE
Else
    Grizo [M:REP1]OBJCLL
    Grizo [M:REP1]NSE
Endif
Diszo [M:REP1]CLLDEL
Affzo [M:REP1]CLLDEL

#---------------------------------------------------#
If [M:REP1]COMBAS=3
    Actzo [M:REP1]COMFOR1,COMFOR2
Else
    Grizo [M:REP1]COMFOR1,COMFOR2
Endif
Return

###################################################################
$AFFMASK

Grizo [M:BPRR]BETFCY, FCY

Return

###################################################################
$RAZCRE

Grizo [M:BPRR]BETFCY, FCY

[M:REP1]CLLDEL=0

# Ne pas écraser les zones qui ont pu venir du tiers
If [M:BPRR]CRY = ""
    [M:BPRR]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
    Endif
    [M:BPRR]LAN = [F:TCY]LAN
    [M:BPRR]CUR = [F:TCY]CUR
Endif
#---------------------------------------------------#
# init. type entité en création pour le subbpa      #
#---------------------------------------------------#
[F:BPA]BPATYP = WBPATYP

If dim([M:REP1]NBRAT)>0
  If [M:REP1]NBRAT=0  [M:REP1]NBRAT=min(GCOMCAT,len(mess(0,403,1))) : Endif
Endif
#MAE, le 06/01/09, SUP_GACCCOD
#[M:REP1]ACCCOD = GACCCOD

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:REP1]NBAXE)>0
   Call INIT_DIE(4,"","REP1","NBAXE") From TRTX3CPT
Endif


If [M:REP1]FNC=2
    Actzo [M:REP1]OBJCLL
Else
    Grizo [M:REP1]OBJCLL
Endif

#CRM
Gosub RAZCRE_CRM From TRTBPCRM

Diszo [M:REP1]CLLDEL
Grizo [M:REP1]COMFOR1, COMFOR2

#Affzo [M:BPRR]CRY, LAN, CUR
#Affzo [M:REP1]1-99

#LSE 06/02/2007
Affzo [M:REP0]1-99
Affzo [M:BPRR]1-99
Affzo [M:BPAR]1-99
Affzo [M:REP1]1-99

Return

###################################################################
$RAZDUP

Grizo [M:BPRR]BETFCY, FCY

[M:REP1]CLLDEL=0

#---------------------------#
# init. flags du tiers      #
#---------------------------#
If CLECUR
    If CZ <> [M:REP0]REPNUM
        Look  [BPR]BPR0 = num$(CZ)
        If fstat
           #-- on remet les indicateurs a zero
           [M:BPRR]BPSFLG    = 1
           [M:BPRR]BPCFLG    = 1
           [M:BPRR]BPTFLG    = 1
           [M:BPRR]FCTFLG    = 1
        #-- pas celui de tiers divers
        #  [M:BPRR]BPRACC    = 1
           [M:BPRR]REPFLG    = 2
        Endif
    Endif
Endif
If [M:REP1]COMBAS = 3
    Actzo [M:REP1]COMFOR1, COMFOR2
Else
    Grizo [M:REP1]COMFOR1, COMFOR2
Endif
If [M:REP1]FNC=2
    Actzo [M:REP1]OBJCLL
Else
    Grizo [M:REP1]OBJCLL
Endif

#CRM
Gosub RAZDUP_CRM From TRTBPCRM

Diszo [M:REP1]CLLDEL
Affzo [M:REP1]CLLDEL
Raz [M:REP1]AUSNUM
Return

###################################################################
$VERIFCRE_MOD
#----------------------------------#
# avant la creation du representant#
# on verifie qu'une adresse existe #
#----------------------------------#
If [M:BPAR]NBADR = 0
        GERR=1:GMESSAGE=mess(31,199,1) : OK = 0
        Return
Endif
#---------------------------------------------------#
# on verifie qu une adresse est désignée par défaut #
#---------------------------------------------------#
If find (2,[M:BPAR]BPAADDFLG (0..[M:BPAR]NBADR -1)) = 0
        GERR=1:GMESSAGE=mess(110,199,1) : OK = 0
        Return
Endif

Return

###################################################################
$INIREP
#---------------------------------------------------#
# récupération du nom et de l'intitulé court du BPR #
#---------------------------------------------------#
[F:REP]REPNAM = [M:BPRR]BPRNAM(0)

# Alimentation du code adresse par défaut et du contact par défaut
Local Shortint WI
WI = find (2,[M:BPAR]BPAADDFLG (0..[M:BPAR]NBADR -1))
If WI<>0 [F:REP]BPAADD = [M:BPAR]CODADR (WI-1) Endif

Return

###################################################################
$CREATION
#------------------------------------------------#
# creation ou modification enregistrement tiers  #
#------------------------------------------------#
Gosub CREBPR
If GOK < 1 : Return : Endif

#------------------------------------------------#
# creation ou modification enregistrement adresse#
#------------------------------------------------#
Gosub CREBPA
If GOK < 1 : Return : Endif

