########################################
##    actions champ           ##########
########################################
#----------------------- REPNUM --------------------------------------#
########################################
Subprog IB_REPNUM
If [M:REP1]AUSNUM = ""
    Raz GBOUT3
Else
    #LSE 09/01/207
    If GPILNAV>1
        If GNAVIG(GPILNAV-1) = "GESAUS"
            Raz GBOUT3
        Else
            GBOUT3 = mess(323, 196, 2) #Informations utilisateurs.
        Endif
    Else
        GBOUT3 = mess(323, 196, 2) #Informations utilisateurs.
    Endif
Endif
End
########################################
Subprog AM_REPNUM(VALEUR)
Variable Char    VALEUR()

#-------------------------------------#
# il faut verrouiller symbole BPR     #
# si pas deja fait dans action verrou #
#-------------------------------------#
Read [BPR]BPR0 = VALEUR
If fstat = 0
    If GREP = "C" | GREP = "D" | GREP = ""
        [M:BPRR] = [F:BPR]
        [M:REP0]REPNAM = [F:BPR]BPRNAM
        Affzo [M:REP0]REPNAM
        Affzo [M:BPRR]
        Default Mask [BPAR]
        Call CHARG_BPA(1,VALEUR,[F:BPR]BPAADD) From TRTBPA
        Affzo [M:BPAR]
        Default Mask [REP0]
    Endif
    If GNAVIG(GPILNAV-1) <> "GESBPR" or (GNAVIG(GPILNAV-1) = "GESBPR" and [M:BPR0]BPRNUM <> VALEUR) Then # FGR 16/04/2012 : X3SUIVI81335
      SYMBOLE2 = "BPR"+num$(VALEUR)
      Lock = SYMBOLE2 With lockwait = 0
      If fstat
        If GREP = "C" or GREP = "D"
          GERR=1 : GMESSAGE=mess(10,100,1) : mkstat = 2
        Endif
        Else
          # FGR 16/04/2012 : X3SUIVI81335
          Global Integer GILOCKBPR

          GILOCKBPR = 1
      Endif
    Endif
Endif

End
#----------------------- COMBAS --------------------------------------#
########################################
Subprog AM_COMBAS(VALEUR)
Variable Integer VALEUR
If    [M:REP1]COMBAS = 3 & VALEUR <> 3
    Effzo COMFOR1, COMFOR2
Endif
If    VALEUR = 3
    Actzo [M:REP1]COMFOR1, COMFOR2
Else
    Grizo [M:REP1]COMFOR1, COMFOR2
Endif
End
##########################################################################
Subprog IB_CLLDEL

#Modif CRM 14/11/2003
Local Char SZFNC
Local Integer IFNC
SZFNC = ""
IFNC = 0
Raz GBOUT1
Raz GBOUT2

If GMODU(13) = 2
    Call PARAMUTIL("AUSCRMA", SZFNC, GUSER, "") From SUBAUS
    If SZFNC = ""
        IFNC = 1
    Else
        IFNC = val(SZFNC)
    Endif

    If IFNC = 4
        If [M:REP0]REPNUM <> ""
            If [M:REP1]CLLDEL > 0
                #Réactualiser les appels
                GBOUT1 = mess(684, 182, 2)
                #Supprimer les appels en retard
                GBOUT2 = mess(689, 182, 2)
            Endif
        Endif
    Endif
Endif
End

##########################################################################
Subprog B1_CLLDEL(VALEUR)
Variable Decimal VALEUR

#Modif CRM 14/11/2003
If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif

Local Integer IPBL
Local Integer IDAYN
Local Integer CRMNBREC
Local Integer CRMOK
Local Integer INTBPCOK
Local Decimal CRMCOUNT
Local Char SZCLE2
Local Integer ICLECOUNT2
Local Integer ICUT2
SZCLE2 = ""
ICUT2 = 2500
ICLECOUNT2 = ICUT2
INTBPCOK = 0
CRMNBREC = 0
CRMOK = 0
CRMCOUNT = 0
IPBL = 0
IDAYN = 0

#Confirmez-vous la réactualisation de tous les appels de ce représentant ?
Call OUINON(mess(685, 182, 2), INTBPCOK) From GESECRAN
If INTBPCOK <> 2
    End
Endif

Call TEMPON("R") From GESECRAN

While ICLECOUNT2 >= ICUT2
    ICLECOUNT2 = 0

    Filter [CLL] Where [F:CLL]CLLNUM > SZCLE2
&                  and [F:CLL]CLLDON <> 2
&                  and [F:CLL]CLLREP = [M:REP0]REPNUM
&                  and [F:CLL]CLLDATX < date$
    For [CLL]CLL0 Hint Key CLL4
        SZCLE2 = [F:CLL]CLLNUM
        CRMNBREC += 1
        ICLECOUNT2 += 1
        If ICLECOUNT2 >= ICUT2 : Break : Endif
    Next

    Filter [CLL]

Wend

Call TEMPOFF From GESECRAN

SZCLE2 = ""
ICUT2 = 2500
ICLECOUNT2 = ICUT2

Call OUVRE_BOITE(mess(687, 182, 2), CRMNBREC) From GESECRAN

While ICLECOUNT2 >= ICUT2
    ICLECOUNT2 = 0

    Call DEBTRANS From GLOCK
    Trbegin [CLL]

    Filter [CLL] Where [F:CLL]CLLNUM > SZCLE2
&                  and [F:CLL]CLLDON <> 2
&                  and [F:CLL]CLLREP = [M:REP0]REPNUM
&                  and [F:CLL]CLLDATX < date$
    For [CLL]CLL0 Hint Key CLL4
        SZCLE2 = [F:CLL]CLLNUM

        If [F:CLL]CLLDAT = [00/00/00]
            IDAYN = dayn(date$)
            IDAYN -= 1
            [F:CLL]CLLDATX = date$ - IDAYN
            [F:CLL]CLLWEE = week(date$)
        Else
            [F:CLL]CLLDAT = date$
            [F:CLL]CLLDATX = date$
            [F:CLL]CLLWEE = week(date$)
        Endif

        Rewrite [CLL]
        If fstat
            IPBL = 1
            Break
        Endif

        CRMCOUNT += 1
        ICLECOUNT2 += 1
        If ICLECOUNT2 >= ICUT2 : Break : Endif
        Call AFF_BOITE ([F:CLL]CLLNUM, CRMCOUNT, CRMOK) From GESECRAN
    Next

    Filter [CLL]

    If IPBL : Break : Endif
    Commit
Wend

Call FERME_BOITE From GESECRAN

If IPBL
    #La réactualisation des appels a échoué.
    Rollback
    GMESSAGE = mess(686, 182, 2)
    GERR = 1
    End
Endif

#On recalcul
Filter [CLL] Where [F:CLL]CLLDON <> 2 and [F:CLL]CLLREP = [M:REP0]REPNUM and [F:CLL]CLLDATX < date$
[M:REP1]CLLDEL = 0
For [CLL] CLL4
    [M:REP1]CLLDEL += 1
Next
Filter [CLL]
Diszo [M:REP1]CLLDEL
Affzo [M:REP1]CLLDEL

End

##########################################################################
Subprog B2_CLLDEL(VALEUR)
Variable Decimal VALEUR

#Modif CRM 14/11/2003
If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif

Local Integer INTBPCOK
INTBPCOK = 0

#Confirmez-vous la suppression de tous les appels en retard hors campagnes d'appels pour ce représentant ?
Call OUINON(mess(688, 182, 2), INTBPCOK) From GESECRAN
If INTBPCOK <> 2
    End
Endif

#Effectue la suppression
Call TEMPON("A") From GESECRAN

Call DEBTRANS From GLOCK
Trbegin [CLL]
Delete [CLL] Where [F:CLL]CLLDON <> 2
&              and [F:CLL]CLLDATX < date$
&              and [F:CLL]CLLREP = [M:REP0]REPNUM
&              and [F:CLL]CLLCMGFLG = 0
If fstat
    #La suppression des appels en retard a échoué.
    Rollback
    GMESSAGE = mess(690, 182, 2)
    GERR = 1
    End
Else
    Commit
Endif

#On recalcul
Filter [CLL] Where [F:CLL]CLLDON <> 2 and [F:CLL]CLLREP = [M:REP0]REPNUM and [F:CLL]CLLDATX < date$
[M:REP1]CLLDEL = 0
For [CLL] CLL4
    [M:REP1]CLLDEL += 1
Next
Filter [CLL]

Call TEMPOFF From GESECRAN

Diszo [M:REP1]CLLDEL
Affzo [M:REP1]CLLDEL

End

######################################################################################
