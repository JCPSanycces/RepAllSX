##########################################################################
$VERF_ANU
#Modif CRM      26 mars 2001

Local Char SZFNC
Local Integer IFNC
SZFNC = ""
IFNC = 0

# FGR 20/04/2010 : X3SUIVI64106 : Utiliser la classe [F] en cas de suppression depuis GESAUS
  If GFONCTION <> "GESAUS" Then
    #If [M:REP1]AUSNUM <> ""
    If [F:REP]AUSNUM <> ""
      Read [AUS] CODUSR = [F:REP]AUSNUM
      If !fstat
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = ""
            IFNC = 1
        Else
            IFNC = val(SZFNC)
        Endif

        If IFNC = 2 | IFNC = 3 | IFNC = 4
            OK = 0
            #Ce représentant ne peut être supprimé que depuis la fiche utilisateur dénommée : XXXXX Suppression refusée.
            GMESSAGE = mess(390, 182, 2) + " " + [F:REP]AUSNUM + ". "+ mess(391, 182, 2)
            GERR = 2
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################
$APRES_MODIF
If COUZON = "CODADR" SUIZON= "XBPADES" : Endif
Return

########################################
$CREBPR
#----------------------------------------------#
# il faut récuperer le code adresse par defaut #
# si on ne trouve pas on recupere la premiere  #
#----------------------------------------------#
#Local Shortint I
#I = find (2,[M:BPAR]BPAADDFLG (0..[M:BPAR]NBADR -1))
#If I <> 0     I -= 1 : Endif
#If I < 0      I = 0  : Endif

Look [BPR]BPR0 = [F:REP]REPNUM
If fstat <> 0
     Raz [F:BPR]
     [F:BPR]          = [M:BPRR]
     [F:BPR]BPRNUM    = [F:REP]REPNUM
     [F:BPR]BPAADD    = [F:REP]BPAADD
     [F:BPR]ENAFLG    = 2
     [F:BPR]REPFLG    = 2
     [F:BPR]CREDAT    = date$
     [F:BPR]CREUSR    = GUSER
     Write [BPR]
     If   fstat
          GOK = 0 : Call FSTA("BPR") From GLOCK
     Endif
Else
     Readlock [BPR]BPR0 = [F:REP]REPNUM
     If    fstat = 1
           GOK = -1 : GLOCK = "$BPARTNER"-[F:REP]REPNUM : Return
     Endif
     Local Char WSAV_CUR(GLONCUR)
     [L]WSAV_CUR      = [F:BPR]CUR        : # Sauvegarde devise tiers
     [F:BPR]          = [M:BPRR]
     [F:BPR]BPRNUM    = [F:REP]REPNUM
     [F:BPR]CUR       = [L]WSAV_CUR       : # Restitution devise tiers
#     [F:BPR]BPAADD    = [M:BPAR]CODADR (I)
     [F:BPR]REPFLG    = 2
     [F:BPR]UPDDAT    = date$
     [F:BPR]UPDUSR    = GUSER
     Rewrite [BPR]
Endif
Return

########################################
$CREBPA
#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#Call CREBPA_CPYFCY (GABREV,[M:REP0]REPNUM,1) From TRTADR
#If   GOK < 1 : Return : Endif

Default Mask [BPAR]
Call CREBPA(WBPATYP,[M:REP0]REPNUM) From TRTBPA
If GOK < 1 : Return : Endif

Return
