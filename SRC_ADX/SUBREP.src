#CRM
#Local Char SZMESSAGE(250)
#Local Integer IBRETOUR
#Raz SZMESSAGE
#IBRETOUR=1
#
#Call MAJ_HC_BP ( nomap,[M:REP0]REPNUM,[M:BPRR]BPRNAM,"[M:BPAR]", SZMESSAGE, IBRETOUR) From TRTHCODE
#If IBRETOUR=0
#    GMESSAGE=SZMESSAGE
#    GERR=1
#    GOK=0
#    Return
#Endif

#CRM
Gosub MODIF_CRM From TRTBPCRM
If GOK < 1 : Return : Endif

#    Mise à jour de la raison sociale
If WMAJNAM=0 Return Endif
If [M:BPRR]BPCFLG = 2
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    Update [BPC] Where [F:BPC]BPCNUM = [M:REP0]REPNUM With BPCNAM=[M:BPRR]BPRNAM
    If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
Endif
If [M:BPRR]BPSFLG = 2
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    Update [BPS] Where [F:BPS]BPSNUM = [M:REP0]REPNUM With BPSNAM=[M:BPRR]BPRNAM
    If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
Endif
If dim([M:BPRR]BPTFLG)>0 & [M:BPRR]BPTFLG=2
    If clalev([F:BPT])=0 : Local File BPCARRIER [BPT] : Endif
    Update [BPT] Where [F:BPT]BPTNUM = [M:REP0]REPNUM With BPTNAM=[M:BPRR]BPRNAM
    If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
Endif

#CRM
Gosub MODIF_CRM From TRTBPCRM
If GOK < 1 : Return : Endif

Return

#######################################################################
$ANNULE
#------------------------------------------------------#
# lecture bpartner pour depositionner le flag REPFLG   #
#------------------------------------------------------#
# FGR 20/04/2010 : X3SUIVI64106 : Utiliser la classe [F] en cas de suppression depuis GESAUS
#Update [BPR] Where [F:BPR]BPRNUM = [M:REP0]REPNUM With REPFLG = 1
Update [BPR] Where [F:BPR]BPRNUM = [F:REP]REPNUM With REPFLG = 1
If   fstat <> 0
     GERR=1:GMESSAGE=mess(4,192,1):GOK = 0
Endif
Return

####################################################################
$APRES_CRE

#Modif CRM 10 janvier 2002
#Gère les secteurs de marché
#LSE 08/03/2007
#deplacer dans le TRTBPCRM
#If GMODU(13) = 2
