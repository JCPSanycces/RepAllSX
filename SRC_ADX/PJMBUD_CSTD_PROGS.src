###################################################################################################
# Classe PJMBUD
###################################################################################################
Funprog GET_APARENT(SOPPNUM, SPBUCOD)
Value Char SOPPNUM
Value Char SPBUCOD

Local Char SARENDRE(GLONPBU)

  Raz SARENDRE
  # ------------------------------
  Local File PJMBUD [PJBU]
  # ------------------------------
  Read [PJBU]PJBU0=SOPPNUM;SPBUCOD
  If !fstat Then
    SARENDRE = [F:PJBU]PBUPAE
  Endif
  # ------------------------------
End SARENDRE

###################################################################################################
Funprog GET_PBUPAE(ACTX, SOPPNUM, SPBUCOD, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD
Variable Char SMESSAGE

Local Char SARENDRE(GLONPBU)

  # Issue number X3-68131- 2018-02-19 by FGR
  Raz SARENDRE
  Raz SMESSAGE
  # ------------------------------
  Local File PJMBUD [PJBU]
  # ------------------------------
  Read [PJBU]PJBU0=SOPPNUM;SPBUCOD
  If !fstat Then
    SARENDRE = [F:PJBU]PBUPAE
  Endif
  # ------------------------------
End SARENDRE

