###################################################################################################
Funprog PBUDESTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMBUD", "PBUDESTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

###################################################################################################
Funprog PBUCOMTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMBUD", "PBUCOMTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

###################################################################################################
Funprog GET_FAMILY(SOPPNUM, SPBUCOD, STBCODE)
Value Char SOPPNUM
Value Char SPBUCOD
Variable Char STBCODE ()(1..)

Local Integer IARENDRE
Local Integer INBTAB

  # Issue X3-46735 - 2017-06-28 by FGR
  IARENDRE = [V]CST_AOK
  # ------------------------------
  Raz STBCODE
  INBTAB = 0
  IARENDRE = func _GET_FAMILY(SOPPNUM, SPBUCOD, INBTAB, STBCODE)
  # ------------------------------
End IARENDRE

###################################################################################################
Funprog _GET_FAMILY(SOPPNUM, SPBUCOD, INBTAB, STBCODE)
Value Char SOPPNUM
Value Char SPBUCOD
Variable Integer INBTAB
Variable Char STBCODE()(1..)

Local Integer IARENDRE

  # Issue X3-46735 - 2017-06-28 by FGR
  IARENDRE = [V]CST_AOK
  # ------------------------------
  Local File PJMBUD [PJBU]
  # ------------------------------
  Filter [PJBU] Where [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = SPBUCOD
  For [PJBU]
    IARENDRE = func _GET_FAMILY([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, INBTAB, STBCODE)
  Next
  Filter [PJBU]
  # ------------------------------
  INBTAB += 1
  STBCODE(INBTAB) = SPBUCOD
  # ------------------------------
End IARENDRE

###################################################################################################
Funprog IS_PARENT(ACTX, SOPPNUM, SPBUCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD

Local Integer IARENDRE

  # Issue X3-46735 - 2017-06-28 by FGR
  IARENDRE = [V]CST_ANO
  # ------------------------------
  Local File PJMBUD [PJBU]
  # ------------------------------
  Filter [PJBU] Where [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = SPBUCOD
  For [PJBU]
    IARENDRE = [V]CST_AYES
    Break
  Next
  Filter [PJBU]
End IARENDRE

