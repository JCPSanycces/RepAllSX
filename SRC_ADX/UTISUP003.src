#<AdxTL>@(#)6.0.0.0 $Revision$
################################################################################
# MOULINETTE POUR transformer les Documentations CDE. Objet CDE : clé à 2 zones#
################################################################################

##################################################################
#Comments(1)                                                     #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER<>""
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTISUP003 : CDE documentation Update") From LECFIC
    Call EXE_UTIXXX(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

  Call EXE_UTIXXX(APPLI)
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################
Subprog EXE_UTIXXX(APPLI)
Value Char APPLI()
Local Libelle  SIMFLG
Local Integer  OK
Local Integer  NB_DOCS_OK, NB_DOCS_MAJ, NB_DOCS_KO
Local Integer  NB_BLOB_OK, NB_BLOB_MAJ, NB_BLOB_KO
Local Integer  NB_CLOB_OK, NB_CLOB_MAJ, NB_CLOB_KO
Local Integer  NB_LINK_OK, NB_LINK_MAJ, NB_LINK_KO
Local Char     WMSG(100)
Local Char     TYPDOC(GLONADI)       : [L]TYPDOC="CDE"
Local Char     WTIRET(1)             : [L]WTIRET="_"
Local Char     FILTRE_TYP(20)        : [L]FILTRE_TYP   =" TYP='"+[L]TYPDOC+"'"
Local Char     FILTRE_TYPLNK(20)     : [L]FILTRE_TYPLNK=" TYPLNK='"+[L]TYPDOC+"'"


  #### Corps de la moulinette - DEBUT
  ## Doit s'executer sur tous les dossiers
  WMSG=[L]TYPDOC-"documentation Update"
  Call ECR_TIME("UTISUP003 -"-WMSG-"Process Start on : "+APPLI) From DOSSUB
  Call ECR_TRACE("                    > Process descritption : Key update by adding a leading"-[L]WTIRET,0) From GESECRAN
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

  If !clalev([F:ADO3]) Local File =APPLI+".ADOCUMENT" [ADO3] : Endif
  If !clalev([F:ADB3]) Local File =APPLI+".ADOCBLB"   [ADB3] : Endif
  If !clalev([F:ADH3]) Local File =APPLI+".ADOCCLB"   [ADH3] : Endif
  If !clalev([F:ADF3]) Local File =APPLI+".ADOCFNC"   [ADF3] : Endif

  # Process de MAJ réalisé pour les documentations CDE dans toutes les langues
  Gosub MAJ_DOC

  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Call ECR_TIME("UTISUP003 -"-WMSG-"Process End on : "+APPLI) From DOSSUB
  
  Close Local File [ADO3], [ADB3], [ADH3], [ADF3]
  #### Corps de la moulinette - FIN
End

#----------------------------------------------------------#
$MAJ_DOC
  # Ajout du caractèe _ à la fin du code documentation car en V6, les CDE ont une clé sur 2 champs
  # Deuxieme champs CPY à vide : valable pour toute société
  Trbegin [ADO3], [ADB3], [ADH3], [ADF3]
    Gosub MAJ_DOC_ADO3
    Gosub MAJ_DOC_ADB3
    Gosub MAJ_DOC_ADH3
    Gosub MAJ_DOC_ADF3
  Commit

  Call ECR_TRACE(" "+[L]TYPDOC-": not allowed As MAIN Link DOCUMENTATION => No process to do for the main key of : ADOCFNC",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(" No documentation field available            => No process to do for table : ADOCFLD",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
Return

#----------------------------------------------------------#
$MAJ_DOC_ADO3
    # Copie des Documentations principales
    # Update [ADO3] Where evalue([L]FILTRE_TYP) With COD=[ADO3]COD+[L]WTIRET
    Raz [L]NB_DOCS_OK,[L]NB_DOCS_MAJ, [L]NB_DOCS_KO
    For [ADO3]ADO0  Where evalue([L]FILTRE_TYP) With Lock
      NB_DOCS_OK+=1
      If !instr(0,[ADO3]COD,[L]WTIRET)
        WMSG=[ADO3]LAN+"~"+[ADO3]TYP+"~"+[ADO3]COD+"~"+num$([ADO3]LEV)+"~"+num$([ADO3]SUBLEV)
        [ADO3]COD=[ADO3]COD+[L]WTIRET
        Rewrite [ADO3]
        If !fstat
          NB_DOCS_MAJ+=1
          Call ECR_TRACE(WMSG-"OK",0) From GESECRAN
        Else
          NB_DOCS_KO+=1
          Call ECR_TRACE(WMSG-"Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next ADO3
    Call ECR_TRACE(" Main Documentation Update :"-num$(NB_DOCS_MAJ)+"/"+num$(NB_DOCS_OK)-"records ("+num$(NB_DOCS_KO)+" failed)",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return

$MAJ_DOC_ADB3
    # Copie des BLOB de Documentations
    # Update [ADB3] Where evalue([L]FILTRE_TYP) With COD=[ADB3]COD+[L]WTIRET
    Raz [L]NB_BLOB_OK,[L]NB_BLOB_MAJ, [L]NB_BLOB_KO
    For [ADB3]ADB0  Where evalue([L]FILTRE_TYP) With Lock
      NB_BLOB_OK+=1
      If !instr(0,[ADB3]COD,[L]WTIRET)
        WMSG=[ADB3]LAN+"~"+[ADB3]TYP+"~"+[ADB3]COD+"~"+num$([ADB3]LEV)+"~"+num$([ADB3]SUBLEV)+"~"+num$([ADB3]LIG)
        [ADB3]COD=[ADB3]COD+[L]WTIRET
        Rewrite [ADB3]
        If !fstat
          NB_BLOB_MAJ+=1
          Call ECR_TRACE(WMSG-"OK",0) From GESECRAN
        Else
          NB_BLOB_KO+=1
          Call ECR_TRACE(WMSG-"Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next ADB3
    Call ECR_TRACE(" BLOB Documentation Update :"-num$(NB_BLOB_MAJ)+"/"+num$(NB_BLOB_OK)-"records ("+num$(NB_BLOB_KO)+" failed)",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return

$MAJ_DOC_ADH3
    # Copie des CLOB de Documentations
    # Update [ADH3] Where evalue([L]FILTRE_TYP) With COD=[ADH3]COD+[L]WTIRET
    Raz [L]NB_CLOB_OK,[L]NB_CLOB_MAJ, [L]NB_CLOB_KO
    For [ADH3]ADH0  Where evalue([L]FILTRE_TYP) With Lock
      NB_CLOB_OK+=1
      If !instr(0,[ADH3]COD,[L]WTIRET)
        WMSG=[ADH3]LAN+"~"+[ADH3]TYP+"~"+[ADH3]COD+"~"+num$([ADH3]LEV)+"~"+num$([ADH3]SUBLEV)
        [ADH3]COD=[ADH3]COD+[L]WTIRET
        Rewrite [ADH3]
        If !fstat
          NB_CLOB_MAJ+=1
          Call ECR_TRACE(WMSG-"OK",0) From GESECRAN
        Else
          NB_CLOB_KO+=1
          Call ECR_TRACE(WMSG-"Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next ADH3
    Call ECR_TRACE(" CLOB Documentation Update :"-num$(NB_CLOB_MAJ)+"/"+num$(NB_CLOB_OK)-"records ("+num$(NB_CLOB_KO)+" failed)",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return

$MAJ_DOC_ADF3
    # Copie des Liens sur Documentations
    # Update [ADF3] Where evalue([L]TYPLNK) With COD=[ADF3]COD+[L]WTIRET
    Raz [L]NB_LINK_OK,[L]NB_LINK_MAJ, [L]NB_LINK_KO
    For [ADF3]ADF0  Where evalue([L]FILTRE_TYPLNK) With Lock
      NB_LINK_OK+=1
      If !instr(0,[ADF3]CLELNK,[L]WTIRET)
        WMSG=[ADF3]TYP+"~"+[ADF3]COD+"~"+num$([ADF3]NUM)
        [ADF3]CLELNK=[ADF3]CLELNK+[L]WTIRET
        Rewrite [ADF3]
        If !fstat
          NB_LINK_MAJ+=1
          Call ECR_TRACE(WMSG-"OK",0) From GESECRAN
        Else
          NB_LINK_KO+=1
          Call ECR_TRACE(WMSG-"Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next ADF3
    Call ECR_TRACE(" Link Documentation Update :"-num$(NB_LINK_MAJ)+"/"+num$(NB_LINK_OK)-"records ("+num$(NB_LINK_KO)+" failed)",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return
#----------------------------------------------------------#

###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier GX (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call EXE_UTIXXX(APPLI)
End
