#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque MGG1
########################################
Subprog AV_PPLOPD(VALEUR)
Variable Integer VALEUR

  If nolign = 1 Then
    VALEUR = 1
  Else
    If VALEUR = 1 Then
      VALEUR = 2
    Endif
  Endif
End

########################################
Subprog AS_PPLOPD(VALEUR)
Variable Integer VALEUR

  If nolign = 1 Then
    mkstat = 2
  Else
    GMENLOC(1) = 1
  Endif
End

########################################
Subprog AM_PPLOPD(VALEUR)
Variable Integer VALEUR

  [M:MGG1]PPLOPD(nolign-1) = VALEUR
  #Renseigne la définition des groupes
  Call SETPPLGRU From SUBMGGB
  Affzo [M:MGG1]PPLOPD(nolign-1)
  Affzo [M:MGG1]PPLGRUDIO
End

########################################
Subprog AM_PPLSELSPT(VALEUR)
Variable Char    VALEUR()

Local Integer ICRINUM
Local Integer IPRENUM
Local Integer IPOSNUM
Local Integer IINSERT
Local Integer ITER

  ICRINUM = 0
  IPRENUM = 0
  IPOSNUM = 0
  IINSERT = 0
  #Calcul un numéro de critère
  If [M:MGG1]PPLORD(nolign-1) = 0 Then
    If nolign > 1 Then
      IPRENUM = [M:MGG1]PPLORD(nolign-2)
      If nolign > [M:MGG1]NBPPL Then
        IPOSNUM = 0
        IINSERT = 0
      Else
        IPOSNUM = [M:MGG1]PPLORD(nolign)
        IINSERT = 1
      Endif
    Else
      IPRENUM = 0
      If [M:MGG1]NBPPL = nolign-1 Then
        IPOSNUM = 0
        IINSERT = 0
      Else
        IPOSNUM = [M:MGG1]PPLORD(nolign)
        IINSERT = 1
      Endif
    Endif
    If IINSERT Then
      ICRINUM = (IPOSNUM + IPRENUM) / 2
    Else
      For ITER = 0 To [M:MGG1]NBPPL-1
        ICRINUM += [M:MGG1]PPLORD(ITER)
      Next
      ICRINUM += 100
    Endif
    [M:MGG1]PPLORD(nolign-1) = ICRINUM
  Endif
  [M:MGG1]PPLSELSPT(nolign-1) = VALEUR
  #Active le support pour la saisie de critère.
  Gosub AS_C_NBPPL
  #Renseigne la définition des groupes
  Call SETPPLGRU From SUBMGGB
  Affzo [M:MGG1]PPLSELSPT(nolign-1)
  Affzo [M:MGG1]PPLGRUDIO
End

########################################
Subprog AM_PPLDESX(VALEUR)
Variable Char    VALEUR()

  [M:MGG1]PPLDESX = VALEUR
  [M:MGG1]PPLDES(GPREMGG1NOL) = [M:MGG1]PPLDESX
  Affzo [M:MGG1]PPLDESX
End

########################################
Subprog AS_NBPPL
Local Integer ICANSAVE

  ICANSAVE = 1
  #Effacement d'une seule ligne
  If status <> 65 Then
    #Effacement d'un groupe de lignes
    If status = 68 or status = 83 Then
      Gosub ONDISPFIRSTPPL
    Elsif status <> 73 Then
      #Cours normal des opérations
      If nolign >= dim([M:MGG1]PPLOPD) Then
        End
      Endif
      #Contrôle du champ Regroupement des critères
      Call CTLPPLGRU([M:MGG2]NBCRI, "CRI", [M:MGG2]CRIGRUDIO, ICANSAVE) From SUBMGGB
      If ICANSAVE Then
        [M:MGG1]CRIGRUDIOX(GPREMGG1NOL) = [M:MGG2]CRIGRUDIO
      Else
        GMESSAGE = GMESSAGE - '->' - mess(576,196,1)
        End
      Endif
      Call GESNBPPL(nolign-1) From SUBMGGB
      If nolign > 0 Then
        If GPREMGG1NOL <> nolign-1 Then
          Gosub AS_C_NBPPL
        Endif
      Endif
    Endif
  Else
    Gosub ONDISPFIRSTPPL
  Endif
End

########################################
Subprog C_NBPPL
Local Integer ICANSAVE
Local Integer NUMLIGNE

  NUMLIGNE = 0
  ICANSAVE = 1
  #Effacement d'une seule ligne
  If status = 65 Then
    NUMLIGNE = nolign-1
    Gosub ONDELPPL
  Else
    #Effacement d'un groupe de lignes
    If status = 68 or status = 83 Then
      For NUMLIGNE = nolign-1 To nolign1-1
        Gosub ONDELPPL
      Next
    Elsif status = 73 Then
      #Insertion d'une ligne
      Raz [M:MGG1]NBPPLSEL
      Raz [M:MGG2]
      Affzo [M:MGG1]
      Affzo [M:MGG2]
    Else
      #Cours normal des opérations
      If nolign >= dim([M:MGG1]PPLOPD) Then
        End
      Endif
      #Contrôle du champ Regroupement des critères
      Call CTLPPLGRU([M:MGG2]NBCRI, "CRI", [M:MGG2]CRIGRUDIO, ICANSAVE) From SUBMGGB
      If ICANSAVE Then
        [M:MGG1]CRIGRUDIOX(GPREMGG1NOL) = [M:MGG2]CRIGRUDIO
      Else
        GMESSAGE = GMESSAGE - '->' - mess(576,196,1)
        End
      Endif
      Call GESNBPPL(nolign-1) From SUBMGGB
      If nolign > 0 Then
        If GPREMGG1NOL <> nolign-1 Then
          Gosub AS_C_NBPPL
        Endif
      Endif
    Endif
  Endif
End

########################################
$ONDELPPL
  Call DEBTRANS From GLOCK
  Trbegin [MQP], [QCR], [QCV]
  Delete [MQP] Where [F:MQP]QURNUM = [M:MGG0]QURNUM and [F:MQP]PPLORD = [M:MGG1]PPLORD(NUMLIGNE)
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [QCR] Where [F:QCR]QURNUM = [M:MGG0]QURNUM and [F:QCR]PPLORD = [M:MGG1]PPLORD(NUMLIGNE)
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM and [F:QCV]PPLORD = [M:MGG1]PPLORD(NUMLIGNE)
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Commit
Return

########################################
$ONDISPFIRSTPPL
  #Charge les populations
  If [M:MGG1]NBPPL = 0 Then
    Raz [M:MGG1]
    Raz [M:MGG2]
  Else
    Call LOADCRI([M:MGG0]QURNUM, [M:MGG1]PPLORD(nolign-1)) From TRTMGG
    #Renseigne la définition des groupes
    Call SETPPLGRU From SUBMGGB
    #Affiche le résumé du ciblage
    Gosub DISPSUMUP From TRTMGG
    Raz [M:MGG1]NBPPLSEL
    [M:MGG1]NBPPLSEL(nolign-1) = "->"
    [M:MGG1]PPLDESX = [M:MGG1]PPLDES(nolign-1)
    [M:MGG2]CURSPT = [M:MGG1]PPLSELSPT(nolign-1)
    [M:MGG2]PPLORDX = [M:MGG1]PPLORD(nolign-1)
    [M:MGG2]CRIGRUDIO = [M:MGG1]CRIGRUDIOX(nolign-1)
    Call GESTION_CURSPT
    GPREMGG1NOL = nolign-1
  Endif
  Affzo [M:MGG1]
  Affzo [M:MGG2]
Return

########################################
$AS_C_NBPPL
  [M:MGG1]NBPPLSEL(GPREMGG1NOL) = ""
  [M:MGG1]NBPPLSEL(nolign-1) = "->"
  [M:MGG1]PPLDESX = [M:MGG1]PPLDES(nolign-1)
  [M:MGG2]CURSPT = [M:MGG1]PPLSELSPT(nolign-1)
  [M:MGG2]PPLORDX = [M:MGG1]PPLORD(nolign-1)
  [M:MGG2]CRIGRUDIO = [M:MGG1]CRIGRUDIOX(nolign-1)
  Call GESTION_CURSPT
  Affzo [M:MGG1]NBPPLSEL(GPREMGG1NOL)
  Affzo [M:MGG1]PPLDESX
  Affzo [M:MGG2]CRIGRUDIO
  GPREMGG1NOL = nolign-1
  Affzo [M:MGG1]NBPPLSEL(GPREMGG1NOL)
Return

########################################
Subprog GESTION_CURSPT

  If [M:MGG2]CURSPT <> "" Then
    Read [SSP]SSP0=[M:MGG2]CURSPT
    If !fstat Then
      If [F:SSP]SPTTYP = 2 or [F:SSP]SPTTYP = 3 Then
        Grizo [M:MGG2]
      Else
        Actzo [M:MGG2]
      Endif
    Endif
  Endif
End

########################################
Subprog AS_PPLDESX(VALEUR)
Variable Char    VALEUR()

Local Integer ITER
Local Integer IFOUND

  IFOUND = 0
  #Vérifie si une ligne a bien été sélectionnée avant de saisir une description.
  If [M:MGG1]NBPPL > 1 Then
    #Recherche une ligne sélectionnée
    For ITER = 0 To dim([M:MGG1]PPLOPD)-1
      If [M:MGG1]NBPPLSEL(ITER) = "->" Then
        IFOUND = 1
      Endif
      If IFOUND Then
        Break
      Endif
    Next
    If !IFOUND Then
      #Il faut d'abord sélectionner une population avant de saisir sa description.
      GMESSAGE = mess(577,196,1)
      GERR = 3
      mkstat = 2
    Endif
  Else
    GPREMGG1NOL = 0
  Endif
End

########################################
Subprog AV_CRIOPD(VALEUR)
Variable Integer VALEUR

  If nolign = 1 Then
    VALEUR = 1
  Else
    If VALEUR = 1 Then
      VALEUR = 2
    Endif
  Endif
End

########################################
Subprog AS_CRIOPD(VALEUR)
Variable Integer VALEUR

  Read [SSP]SSP0=[M:MGG2]CURSPT
  If fstat Then
    If nolign = 1 Then
      mkstat = 2
    Else
      GMENLOC(1) = 1
      GMENLOC(4) = 1
      GMENLOC(5) = 1
    Endif
  Else
    If [F:SSP]SPTTYP = 4 Then
      If nolign = 1 Then
        mkstat = 2
      Else
        GMENLOC(1) = 1
        GMENLOC(4) = 1
        GMENLOC(5) = 1
      Endif
    Else
      If nolign = 1 Then
        mkstat = 2
      Else
        GMENLOC(1) = 1
        GMENLOC(4) = 1
        GMENLOC(5) = 1
      Endif
    Endif
  Endif
End

########################################
Subprog AM_CRIOPD(VALEUR)
Variable Integer VALEUR

  [M:MGG2]CRIOPD(nolign-1) = VALEUR
  #Renseigne la définition des groupes
  Call SETCRIGRU From SUBMGGB
  Affzo [M:MGG2]CRIOPD(nolign-1)
  Affzo [M:MGG2]CRIGRUDIO
End

########################################
Subprog C_CRITAB(VALEUR)
Variable Char    VALEUR()

Local Integer ISSCFOUND
Local Integer ITER
Local Integer INOL
Local Integer IMOREONE

  ISSCFOUND = 0
  ITER = 0
  INOL = nolign-1
  IMOREONE = 0
  If VALEUR = "" Then
    #Zone obligatoire
    GMESSAGE = mess(10,123,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  If VALEUR <> "" Then
    Read [ATB]CODFIC=VALEUR
    If fstat Then
      #La table indiquée n'existe pas dans le dictionnaire des tables. Saisie refusée.
      GMESSAGE = mess(573,196,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  If VALEUR <> "" Then
    Filter [SSC] Where [F:SSC]SPTNUM = [M:MGG2]CURSPT
    For [SSC]SSC1
      If [F:SSC]SPTTAB = VALEUR Then
        ISSCFOUND = 1
        Break
      Endif
    Next
    Filter [SSC]
    If !ISSCFOUND Then
      #Vérifie s'il ne s'agit pas de la table cible
      Read [SSP]SSP0=[M:MGG2]CURSPT
      If fstat Then
        #La table indiquée n'est pas une composante du support de sélection :
        GMESSAGE = mess(590,196,1) - [M:MGG2]CURSPT
        GERR = 3
        mkstat = 2
      Else
        If [F:SSP]SPTTGR <> VALEUR Then
          #La table indiquée n'est pas une composante du support de sélection :
          GMESSAGE = mess(590,196,1) - [M:MGG2]CURSPT
          GERR = 3
          mkstat = 2
        Endif
      Endif
    Endif
    #Vérifie que deux critères d'une même table sont bien groupés
    If !GERR Then
      For ITER = 0 To [M:MGG2]NBCRI-1
        If ITER <> INOL Then
          If [M:MGG2]CRITAB(ITER) <> "" Then
            If VALEUR <> "" Then
              If VALEUR = [M:MGG2]CRITAB(ITER) Then
                IMOREONE = 1
              Endif
            Endif
          Endif
        Endif
      Next
      #Il y a d'autres critères sur la même table
      #On autorise uniquement un critère immédiatement au dessus ou au dessous
      If IMOREONE Then
        IMOREONE = 0
        If INOL > 0 Then
          If [M:MGG2]CRITAB(INOL-1) = VALEUR Then
            IMOREONE = 1
          Endif
        Endif
        If INOL < dim([M:MGG2]CRITAB)-1 Then
          If [M:MGG2]CRITAB(INOL+1) = VALEUR Then
            IMOREONE = 1
          Endif
        Endif
        If !IMOREONE Then
          #Les critères posés sur une même table doivent être groupés. Saisie refusée
          GMESSAGE = mess(693,196,1) - mess(627,196,1)
          GERR = 3
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
End

########################################
Subprog AM_CRITAB(VALEUR)
Variable Char    VALEUR()

  [M:MGG2]CRITAB(nolign-1) = VALEUR
  #Renseigne la définition des groupes
  Call SETCRIGRU From SUBMGGB
  Affzo [M:MGG2]CRITAB(nolign-1)
  Affzo [M:MGG2]CRIGRUDIO
End

########################################
Subprog C_CRIFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:MGG2]CRITAB(nolign-1), VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    GERR = 2
    End
  Endif
End

########################################
Subprog AM_CRIFIE(VALEUR)
Variable Char    VALEUR()

Local Integer ICRINUM
Local Integer IPRENUM
Local Integer IPOSNUM
Local Integer IINSERT
Local Integer ITER
Local Char SZFIETYP
Local Integer IFIETYP
Local Integer IFIEDIM
Local Integer IRAFF10
Local Integer ICTLDIM

  SZFIETYP = ""
  IFIETYP = 0
  IFIEDIM = 0
  ICTLDIM = 0
  ICRINUM = 0
  IPRENUM = 0
  IPOSNUM = 0
  IINSERT = 0
  ITER = 0
  IRAFF10 = 0
  #Calcul un numéro de critère
  If [M:MGG2]CRINUM(nolign-1) = 0 Then
    If nolign > 1 Then
      IPRENUM = [M:MGG2]CRINUM(nolign-2)
      If nolign > [M:MGG2]NBCRI Then
        IPOSNUM = 0
        IINSERT = 0
      Else
        IPOSNUM = [M:MGG2]CRINUM(nolign)
        IINSERT = 1
      Endif
    Else
      IPRENUM = 0
      If [M:MGG2]NBCRI = nolign-1 Then
        IPOSNUM = 0
        IINSERT = 0
      Else
        IPOSNUM = [M:MGG2]CRINUM(nolign)
        IINSERT = 1
      Endif
    Endif
    If IINSERT Then
      ICRINUM = (IPOSNUM + IPRENUM) / 2
    Else
      For ITER = 0 To [M:MGG2]NBCRI-1
        ICRINUM += [M:MGG2]CRINUM(ITER)
      Next
      ICRINUM += 100
    Endif
    [M:MGG2]CRINUM(nolign-1) = ICRINUM
  Endif
  VALEUR = toupper(VALEUR)
  [M:MGG2]CRIFIE(nolign-1) = VALEUR
  #Obtient le type d'un champ
  Local File =[M:MGG2]CRITAB(nolign-1) [TYPX]
  IFIETYP = evalue("Type([F:TYPX]" + [M:MGG2]CRIFIE(nolign-1) + ")")
  IFIEDIM = evalue("Dim([F:TYPX]" + [M:MGG2]CRIFIE(nolign-1) + ")")
  Close Local File [TYPX]
  #Vérifie si l'on a pas remplacé un type de champs par un autre
  If [M:MGG2]CRIFIETYP(nolign-1) = "" Then
    #On calcul un type pour le champs indiqué
    If IFIETYP < 0 Then
      [M:MGG2]CRIFIETYP(nolign-1) = ""
    Elsif IFIETYP = 1 or IFIETYP = 2 Then
      [M:MGG2]CRIFIETYP(nolign-1) = "N"
    Elsif IFIETYP = 3 Then
      [M:MGG2]CRIFIETYP(nolign-1) = "D"
    Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
      [M:MGG2]CRIFIETYP(nolign-1) = "N"
    Elsif IFIETYP >= 10 Then
      [M:MGG2]CRIFIETYP(nolign-1) = "A"
    Endif
  Else
    #On interprète un type pour le nouveau champ indiqué
    If IFIETYP < 0 Then
      SZFIETYP = ""
    Elsif IFIETYP = 1 or IFIETYP = 2 Then
      SZFIETYP = "N"
    Elsif IFIETYP = 3 Then
      SZFIETYP = "D"
    Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
      SZFIETYP = "N"
    Elsif IFIETYP >= 10 Then
      SZFIETYP = "A"
    Endif
    If SZFIETYP <> [M:MGG2]CRIFIETYP(nolign-1) Then
      #On supprime les valeurs de critère existantes.
      Call DEBTRANS From GLOCK
      Trbegin [QCV]
      Delete [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM and [F:QCV]PPLORD = [M:MGG2]PPLORDX and [F:QCV]CRINUM = [M:MGG2]CRINUM(nolign-1)
      If fstat Then
        Rollback
      Else
        Commit
      Endif
      #On définit le nouveau type du champs
      [M:MGG2]CRIFIETYP(nolign-1) = SZFIETYP
      #Et on vide le tableau des valeurs
      Raz [M:MGG2]NBOCC
      Raz [M:MGG2]CRIVAL
      Raz [M:MGG2]CRIVALNUM
      Raz [M:MGG2]CRIVALDAT
      IRAFF10 = 1
    Endif
  Endif
  #Renseigne la définition des groupes
  Call SETCRIGRU From SUBMGGB
  If IRAFF10 Then
    Affzo [M:MGG2]
  Else
    Affzo [M:MGG2]CRIFIE(nolign-1)
    Affzo [M:MGG2]CRIGRUDIO
  Endif
  If GERR = 0 Then
    If VALEUR <> "" Then
      If IFIEDIM > 1 Then
        ICTLDIM = instr(1, VALEUR, '(')
        If ICTLDIM = 0 Then
          #Ce champ est dimensionné. Un opérateur OU sera appliqué sur chacune de ses dimensions.
          GMESSAGE = mess(100,177,1)
          GERR = 2
        Endif
      Endif
    Endif
  Endif
End

########################################
Subprog AS_CRICND(VALEUR)
Variable Integer VALEUR

Local Integer IFIETYP

  IFIETYP = 0
  #Obtient le type d'un champ
  Local File =[M:MGG2]CRITAB(nolign-1) [TYPX]
  IFIETYP = evalue("Type([F:TYPX]" + [M:MGG2]CRIFIE(nolign-1) + ")")
  Close Local File [TYPX]
  If IFIETYP > 0 and IFIETYP < 10 Then
    #Numérique ou Date
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
  Endif
End

########################################
Subprog AM_CRICND(VALEUR)
Variable Integer VALEUR

Local Integer IRAFF10

  IRAFF10 = 0
  Case VALEUR
    When 6
      Gosub PUTONEVAL
    When 7
      Gosub PUTONEVAL
    When 8
      Gosub PUTONEVAL
    When 9
       Gosub PUTONEVAL
    When Default
  Endcase
  [M:MGG2]CRICND(nolign-1) = VALEUR
  If IRAFF10 Then
    Affzo [M:MGG2]
  Else
    Affzo [M:MGG2]CRICND(nolign-1)
  Endif
End

###########################################
$PUTONEVAL
#Autorise une seule valeur de critère pour certaine conditions
Local Integer INBLIN
Local Integer ICOUNT
Local Integer IPBL

  IPBL = 0
  INBLIN = 0
  ICOUNT = 0
  #On vide le tableau des valeurs
  Raz [M:MGG2]NBOCC
  Raz [M:MGG2]CRIVAL
  Raz [M:MGG2]CRIVALNUM
  Raz [M:MGG2]CRIVALDAT
  Call DEBTRANS From GLOCK
  Trbegin [QCV]
  INBLIN = 0
  Filter [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM and [F:QCV]PPLORD = [M:MGG2]PPLORDX and [F:QCV]CRINUM = [M:MGG2]CRINUM(nolign-1)
  For [QCV]QCV1
    If INBLIN = 0 Then
      [M:MGG2]CRIVAL(INBLIN) = [F:QCV]CRIVAL
      [M:MGG2]CRIVALNUM(INBLIN) = [F:QCV]CRIVALNUM
      [M:MGG2]CRIVALDAT(INBLIN) = [F:QCV]CRIVALDAT
      ICOUNT += 1
    Else
      Delete [QCV] Curr
      If fstat Then
        IPBL = 1
      Endif
      If IPBL Then
        Break
      Endif
    Endif
    INBLIN += 1
  Next
  Filter [QCV]
  If IPBL Then
    Rollback
  Else
    Commit
  Endif
  [M:MGG2]NBOCC = ICOUNT
  IRAFF10 = 1
Return

########################################
Subprog AS_NBCRI
Local Integer IPROMPTTYP

  IPROMPTTYP = 0
  If [M:MGG2]CURSPT = "" Then
    #IL faut sélectionner un support de sélection avant de procéder à la saisie des critères.
    GMESSAGE = mess(751,196,1)
    GERR = 2
    Grizo [M:MGG2]
    Affzo [M:MGG2]
  Else
    Call GESTION_CURSPT
    If [F:SSP]SPTNUM <> [M:MGG2]CURSPT Then
      Read [SSP]SSP0=[M:MGG2]CURSPT
    Endif
    If [F:SSP]SPTTYP = 2 or [F:SSP]SPTTYP = 3 Then
      IPROMPTTYP = [F:SSP]SPTTYP
    Endif
    Affzo [M:MGG2]
  Endif
  Call GESNBCRI(nolign-1) From SUBMGGB
  If nolign >= dim([M:MGG2]CRIOPD) Then
    End
  Endif
  If nolign > 0 Then
    Gosub AS_C_NBCRI
  Endif
  If IPROMPTTYP Then
    GERR = 2
    If IPROMPTTYP = 2 Then
      GMESSAGE = mess(855,196,1)
    Elsif IPROMPTTYP = 3 Then
      GMESSAGE = mess(856,196,1)
    Endif
  Endif
End

######################################
$AS_C_NBCRI
  If GPRECRINOL <> nolign-1 Then
    [M:MGG2]NBCRISEL(GPRECRINOL) = ""
    [M:MGG2]NBCRISEL(nolign-1) = "->"
    Affzo [M:MGG2]NBCRISEL(GPRECRINOL)
    GPRECRINOL = nolign-1
    Affzo [M:MGG2]NBCRISEL(GPRECRINOL)
  Endif
Return

########################################
Subprog C_NBCRI
Local Integer NUMLIGNE
Local Integer INUMCRI
Local Integer ILINQTY
Local Integer IERREUR    # FGR 02/02/2010 : X3SUIVI60986

  NUMLIGNE = 0
  INUMCRI = 0
  IERREUR = 0    # FGR 02/02/2010 : X3SUIVI60986
  ILINQTY = [M:MGG2]NBCRI
  If status = 65 Then
    #Effacement d'une seule ligne
    If [M:MGG2]CRINUM(nolign-1) > 0 Then
      INUMCRI = [M:MGG2]CRINUM(nolign-1)
      Read [QCR]QCR1=[M:MGG0]QURNUM;[M:MGG2]PPLORDX;[M:MGG2]CRINUM(nolign-1)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [QCR], [QCV]
        Delete [QCR] Curr
        If fstat Then
          Rollback
          End
        Endif
        Delete [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM and [F:QCV]PPLORD = [M:MGG2]PPLORDX and [F:QCV]CRINUM = INUMCRI
        If fstat Then
          Rollback
          End
        Endif
        Commit
      Endif
    Endif
    #Contrôle que la première ligne ne se retrouve pas avec un opérateur différent de '.'
    If ILINQTY > 0 Then
      [M:MGG2]CRIOPD(0) = 1
    Endif
    #Renseigne la définition des groupes
    ILINQTY -= 1
    Call SETCRIGRU2(ILINQTY) From SUBMGGB
    GSZPREGRU = [M:MGG2]CRIGRUDIO
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      If [M:MGG2]CRINUM(NUMLIGNE) > 0 Then
        INUMCRI = [M:MGG2]CRINUM(NUMLIGNE)
        Read [QCR]QCR1=[M:MGG0]QURNUM;[M:MGG2]PPLORDX;[M:MGG2]CRINUM(NUMLIGNE)
        If fstat = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [QCR], [QCV]
          Delete [QCR]Curr
          If fstat Then
            Rollback
            Break
          Endif
          Delete [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM and [F:QCV]PPLORD = [M:MGG2]PPLORDX and [F:QCV]CRINUM = INUMCRI
          If fstat Then
            Rollback
            #End           # FGR 02/02/2010 : X3SUIVI60986
            IERREUR = 1    # FGR 02/02/2010 : X3SUIVI60986
            Break          # FGR 02/02/2010 : X3SUIVI60986
          Endif
          Commit
        Endif
      Endif
      ILINQTY -= 1
    Next
    If IERREUR Then
      # FGR 02/02/2010 : X3SUIVI60986
      End
    Endif
    #Contrôle que la première ligne ne se retrouve pas avec un opérateur différent de '.'
    If ILINQTY > 0 Then
      [M:MGG2]CRIOPD(0) = 1
    Endif
    #Renseigne la définition des groupes
    Call SETCRIGRU2(ILINQTY) From SUBMGGB
    GSZPREGRU = [M:MGG2]CRIGRUDIO
  Elsif status = 73 Then
    #Insertion d'une ligne
    Raz NBCRISEL
    Raz [M:MGG2]NBOCC
    Raz [M:MGG2]CRIVAL
    Raz [M:MGG2]CRIVALNUM
    Raz [M:MGG2]CRIVALDAT
    Affzo [M:MGG2]
  Else
    Call GESNBCRI(nolign-1) From SUBMGGB
    Affzo [M:MGG2]
    If nolign >= dim([M:MGG2]CRIOPD) Then
      End
    Endif
    If nolign > 0 Then
      Gosub AS_C_NBCRI
    Endif
  Endif
End

########################################
Subprog AM_NBCRI
  GPPLDIRTY = 1
End

########################################
Subprog AM_NBOCC
  GPPLDIRTY = 1
  GCRIDIRTY = 1
End

########################################
Subprog IB_NBOCC
Local Char SZTABPLUSFIE(GLONATB+GLONAVA+10)
Local Char SZLIEFIE(type([F:ATB]INTIT)-10)
Local Char SZLIEKEY(type([F:ATZ]CODZONE)-10)
Local Char SZCRITIBB(200)
Local Char SZMENUBOUT(100)
Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  SZCRITIBB = ""
  SZLIEFIE = ""
  SZLIEKEY = ""
  SZMENUBOUT = ""
  If [M:MGG2]CRIVAL(nolign-1) = "" Then
    Raz GBOUT1
    End
  Endif

Local Char SZLEFTCRIFIE(GLONAVA)
Local Integer IDIMLEVPOS1
Local Integer IDIMLEVPOS2
Local Integer IDIMLEVPOS3
Local Integer IUSERDIMLEV
Local Integer IFAMSTATDEB
Local Integer IFAMSTATFIN

  IFAMSTATDEB = 0
  IFAMSTATFIN = 0
  IUSERDIMLEV = 0
  IDIMLEVPOS1 = 0
  IDIMLEVPOS2 = 0
  IDIMLEVPOS3 = 0
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND ([M:MGG2]CRIFIE(GPRECRINOL)) # FGR 13/01/2009 : X3SUIVI51579
  If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
    #Obtention de l'indice saisi
    IDIMLEVPOS1 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(')
    If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')') Then
      IDIMLEVPOS2 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')')
      If IDIMLEVPOS2 > IDIMLEVPOS1 Then
        IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
        If IDIMLEVPOS3 > 1 Then
          IUSERDIMLEV = val(mid$([M:MGG2]CRIFIE(GPRECRINOL), IDIMLEVPOS1+1, IDIMLEVPOS3-1))
        Endif
      Endif
    Endif
  Endif
  SZTABPLUSFIE = [M:MGG2]CRITAB(GPRECRINOL) + SZLEFTCRIFIE
  Read [ATZ]CODZONE=[M:MGG2]CRITAB(GPRECRINOL);SZLEFTCRIFIE
  If fstat Then
    Raz GBOUT1
    End
  Endif
  Case [F:ATZ]CODTYP
    When "ADI"
        If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
        Case SZTABPLUSFIE
          When "BPCUSTOMERTSCCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 30
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          When "BPSUPPLIERTSSCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 40
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          When "ITMMASTERTSICOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 20
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          When "SERREQUESTTSDCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 445
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          When "CONTSERVCONTYP"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 440
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          # FGR 18/07/2012 : X3SUIVI83551 (début)
          When "SDELIVERYTSCCOD", "SINVOICEVTSCCOD", "SORDERTSCCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 30
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          When "SDELIVERYDTSICOD", "SINVOICEDTSICOD", "SORDERPTSICOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 20
              Read [ADI]CODE=IFAMSTATDEB;[M:MGG2]CRIVAL(nolign-1)
              If fstat Then
                Raz GBOUT1
              Else
                Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
              Endif
            Else
              Raz GBOUT1
            Endif
          # FGR 18/07/2012 : X3SUIVI83551 (fin)
          When Default
            IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
            IADISEPARATOR -= 1
            Read [ADI]CODE=val(left$([F:ATZ]EXPLIEN, IADISEPARATOR));[M:MGG2]CRIVAL(nolign-1)
            If fstat Then
              Raz GBOUT1
            Else
              Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, GBOUT1) From CRM_UTIL
            Endif
        Endcase
    When "M", "MM"
      GBOUT1 = mess(val([M:MGG2]CRIVAL(nolign-1)), [F:ATZ]NOLIB, 2)
    When "AXX"
      Raz GBOUT1
    When Default
      Read [ATY]CODTYP=[F:ATZ]CODTYP
      If fstat Then
        Raz GBOUT1
      Else
        If [F:ATY]OBJLIEN = "" Then
          Raz GBOUT1
        Else
          Read [AOB]ABREV=[F:ATY]OBJLIEN
          If fstat Then
            Raz GBOUT1
          Else
            If [F:ATY]TYPTYP = 7 Then
              Read [ATB]CODFIC=[F:AOB]NOMFIC
              If fstat Then
                Raz GBOUT1
              Else
                SZLIEFIE = [F:ATB]INTIT
                If SZLIEFIE = "" Then
                  Raz GBOUT1
                Else
                  Read [ATZ]CODZONE=[F:AOB]NOMFIC;SZLIEFIE
                  If fstat Then
                    Raz GBOUT1
                  Else
                    If [F:ATZ]CODTYP = "AXX" Then
                      Call GET_TRADAUT([F:AOB]NOMFIC, SZLIEFIE, [M:MGG2]CRIVAL(nolign-1), SZMENUBOUT) From CRM_UTIL
                      GBOUT1 = SZMENUBOUT
                    Else
                      SZLIEKEY = ""
                      Filter [ATZ] Where [F:ATZ]CODFIC = [F:AOB]NOMFIC
                      For [ATZ] CODZONE
                        If instr(1, [F:ATZ]OPTION, 'C') Then
                          SZLIEKEY = [F:ATZ]CODZONE
                          Break
                        Endif
                      Next
                      Filter [ATZ]
                      If SZLIEKEY = "" Then
                        Raz GBOUT1
                      Else
                        SZCRITIBB = "[F:IBBX]" + SZLIEKEY + "=[M:MGG2]CRIVAL(nolign-1)"
                        Local File =[F:AOB]NOMFIC [IBBX]
                        Filter [IBBX] Where evalue(SZCRITIBB)
                        For [IBBX]
                          SZMENUBOUT = evalue("[F:IBBX]" + SZLIEFIE)
                          Break
                        Next
                        Filter [IBBX]
                        Close Local File [IBBX]
                        If SZMENUBOUT = "" Then
                          Raz GBOUT1
                        Else
                          GBOUT1 = SZMENUBOUT
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Else
              Raz GBOUT1
            Endif
          Endif
        Endif
      Endif
  Endcase
End

########################################
Subprog B1_NBOCC
End

##########################################################################
Subprog AS_NBOCC

  # FGR 08/11/2012 : X3SUIVI83551
  Case [M:MGG2]CRICND(GPRECRINOL)
    When 6
      # Supérieur à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 7
      # Supérieur ou égal
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 8
      #Inférieur à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 9
      #Inférieur ou égal à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 10
      # Compris entre
      If nolign > 2 Then
        mkstat = 2
      Endif
    When Default
  Endcase
End

########################################
Subprog AS_CRIVAL(VALEUR)
Variable Char    VALEUR()

  Case [M:MGG2]CRICND(GPRECRINOL)
    When 6
      # Supérieur à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 7
      # Supérieur ou égal
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 8
      #Inférieur à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 9
      #Inférieur ou égal à
      If nolign > 1 Then
        mkstat = 2
      Endif
    When 10
      # Compris entre
      If nolign > 2 Then
        mkstat = 2
      Endif
    When Default
  Endcase
End

########################################
Subprog C_CRIVAL(VALEUR)
Variable Char    VALEUR()

Local Char SZTABPLUSFIE(GLONATB+GLONAVA+10)
Local Integer IFOUND
Local Integer IZ
Local Integer IFIETYP
Local Char SZVAL(type(VALEUR)-10)
Local Char SZVALINT(50)
Local Integer INOL
Local Integer INBOCC
Local Integer IADISEPARATOR

  # FGR 30/08/2016 : X3SUIVI117617 (début)
  If [M:MGG2]CRITAB(GPRECRINOL) = "" Then
    VALEUR = ""
    mkstat = 2
    GMESSAGE = mess(684,177,1)
    GERR = 1
    End
  Endif
  # FGR 30/08/2016 : X3SUIVI117617 (fin)
  IADISEPARATOR = 0
  IFIETYP = 0
  IFOUND = 0
  IZ = 0
  SZVAL = VALEUR
  SZVALINT = ""
  INOL = nolign-1
  INBOCC = [M:MGG2]NBOCC - 1
  #Vérifie si la valeur n'a pas déjà été préalablement saisi dans le tableau
  For IZ = 0 To INBOCC
    If IZ <> INOL Then
      If [M:MGG2]CRIVAL(IZ) = VALEUR and [M:MGG2]CRIVAL(IZ) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(24,123,1) - num$(IZ+1) : # Code déjà existant en ligne
        GERR = 2
        Endif
    Endif
    If GERR > 0 Then
      Break
    Endif
  Next
  IZ = 0
  If GERR > 0 Then
    End
  Endif

  #Contrôle si le code de table diverse ou de menu local saisi est correcte.
Local Integer IQUOTE1
Local Integer IQUOTE2
Local Integer IQUOTE3
Local Integer IQUOTE4
Local Char SZLEFTCRIFIE(GLONAVA)
Local Integer IDIMLEVPOS1
Local Integer IDIMLEVPOS2
Local Integer IDIMLEVPOS3
Local Integer IUSERDIMLEV
Local Integer IFAMSTATDEB
Local Integer IFAMSTATFIN
Local Date DCTLDATE1
Local Date DCTLDATE2

  DCTLDATE1 = [00/00/00]
  DCTLDATE2 = [00/00/00]
  IQUOTE1 = 0
  IQUOTE2 = 0
  IQUOTE3 = 0
  IQUOTE4 = 0
  IFAMSTATDEB = 0
  IFAMSTATFIN = 0
  IUSERDIMLEV = 0
  IDIMLEVPOS1 = 0
  IDIMLEVPOS2 = 0
  IDIMLEVPOS3 = 0
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND ([M:MGG2]CRIFIE(GPRECRINOL)) # FGR 13/01/2009 : X3SUIVI51579
  If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
    #Obtention de l'indice saisi
    IDIMLEVPOS1 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(')
    If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')') Then
      IDIMLEVPOS2 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')')
      If IDIMLEVPOS2 > IDIMLEVPOS1 Then
        IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
        If IDIMLEVPOS3 > 1 Then
          IUSERDIMLEV = val(mid$([M:MGG2]CRIFIE(GPRECRINOL), IDIMLEVPOS1+1, IDIMLEVPOS3-1))
        Endif
      Endif
    Endif
  Endif
  SZTABPLUSFIE = [M:MGG2]CRITAB(GPRECRINOL) + SZLEFTCRIFIE
  Read [ATZ]CODZONE=[M:MGG2]CRITAB(GPRECRINOL);SZLEFTCRIFIE
  If fstat Then
    #Erreur lors de la recherche du type du champ.
    GMESSAGE = mess(578,196,1)
    GERR = 1
    End
  Endif
  Case [F:ATZ]CODTYP
    When "ADI"
        If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
        Case SZTABPLUSFIE
          When "BPCUSTOMERTSCCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 30
              IFAMSTATFIN = IUSERDIMLEV + 30
            Else
              IFAMSTATDEB = 30
              IFAMSTATFIN = 34
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          When "BPSUPPLIERTSSCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 40
              IFAMSTATFIN = IUSERDIMLEV + 40
            Else
              IFAMSTATDEB = 40
              IFAMSTATFIN = 44
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          When "ITMMASTERTSICOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 20
              IFAMSTATFIN = IUSERDIMLEV + 20
            Else
              IFAMSTATDEB = 20
              IFAMSTATFIN = 24
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          When "SERREQUESTTSDCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 445
              IFAMSTATFIN = IUSERDIMLEV + 445
            Else
              IFAMSTATDEB = 445
              IFAMSTATFIN = 449
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          When "CONTSERVCONTYP"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 440
              IFAMSTATFIN = IUSERDIMLEV + 440
            Else
              IFAMSTATDEB = 440
              IFAMSTATFIN = 444
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          # FGR 18/07/2012 : X3SUIVI83551 (début)
          When "SDELIVERYTSCCOD", "SINVOICEVTSCCOD", "SORDERTSCCOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 30
              IFAMSTATFIN = IUSERDIMLEV + 30
            Else
              IFAMSTATDEB = 30
              IFAMSTATFIN = 34
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          When "SDELIVERYDTSICOD", "SINVOICEDTSICOD", "SORDERPTSICOD"
            If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(') Then
              IFAMSTATDEB = IUSERDIMLEV + 20
              IFAMSTATFIN = IUSERDIMLEV + 20
            Else
              IFAMSTATDEB = 20
              IFAMSTATFIN = 24
            Endif
            Gosub READ_ADI_FSTAT # FGR 18/07/2012 : X3SUIVI83551
          # FGR 18/07/2012 : X3SUIVI83551 (fin)
          When Default
            IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
            IADISEPARATOR -= 1
            Filter [ADI] Where [F:ADI]NUMTAB = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR))
            For [ADI] CODE
              If [F:ADI]CODE = VALEUR Then
                IFOUND = 1
                Break
              Endif
            Next
            Filter [ADI]
        Endcase
    When "M", "MM"
      If mess(val(VALEUR), [F:ATZ]NOLIB, 2) <> "" Then
        IFOUND = 1
      Endif
    When "PBL"
      #On vérifie la saisie
      Gosub CTLSHORTCUT From SUBPBLB
      If GERR Then
        IFOUND = 0
      Else
        IFOUND = 1
      Endif
    When Default
      IFOUND = 1
  Endcase
  If !IFOUND Then
    GMESSAGE = mess(83,123,1)  #Valeur incorrecte
    GERR = 1
    mkstat = 2
    End
  Endif
  #Obtient le type d'un champ
  Local File =[M:MGG2]CRITAB(GPRECRINOL) [TYPX]
  IFIETYP = evalue("Type([F:TYPX]" + [M:MGG2]CRIFIE(GPRECRINOL) + ")")
  Close Local File [TYPX]
  #Traitement du format date
  If IFIETYP = 3 Then
    If instr(1, SZVAL, "date$") Then
      Raz [M:MGG2]CRIVALDAT(nolign-1)
    Else
      If left$(SZVAL, 2) = "??" Then
        Raz [M:MGG2]CRIVALDAT(nolign-1)
      Else
        Call CHARGE(SZVAL, "D", 0, 0, SZVALINT) From FMTVAR
        If GMESSAGE <> "" or GERR > 0 Then
          mkstat = 2
          End
        Endif
        VALEUR = SZVAL
        [M:MGG2]CRIVALDAT(nolign-1) = SZVALINT
      Endif
    Endif
  Endif
  #Avec la condition compris entre
  #Vérifie que la deuxième valeur est bien supérieur à la premiere
  If [M:MGG2]CRICND(GPRECRINOL) = 10 Then
    If nolign = 1 Then
      If [M:MGG2]CRIVAL(1) <> "" Then
        If IFIETYP = 1 or IFIETYP = 2 Then
          If left$(SZVAL, 2) <> "??" Then
            If val([M:MGG2]CRIVAL(nolign)) < val(SZVAL) Then
              #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
              GMESSAGE = mess(136,177,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Elsif IFIETYP = 3 Then
          If left$(SZVAL, 2) <> "??" Then
            If instr(1, SZVAL, "date$") Then
              If instr(1, [M:MGG2]CRIVAL(nolign), "date$") Then
                DCTLDATE1 = evalue([M:MGG2]CRIVAL(nolign))
                DCTLDATE2 = evalue(SZVAL)
                If DCTLDATE1 < DCTLDATE2 Then
                  #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
                  GMESSAGE = mess(136,177,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Else
                DCTLDATE2 = evalue(SZVAL)
                If [M:MGG2]CRIVALDAT(nolign) < DCTLDATE2 Then
                  #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
                  GMESSAGE = mess(136,177,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Endif
            Else
              If instr(1, [M:MGG2]CRIVAL(nolign), "date$") Then
                DCTLDATE1 = evalue([M:MGG2]CRIVAL(nolign))
                If DCTLDATE1 < [M:MGG2]CRIVALDAT(nolign-1) Then
                  #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
                  GMESSAGE = mess(136,177,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Else
                If [M:MGG2]CRIVALDAT(nolign) < SZVALINT Then
                  #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
                  GMESSAGE = mess(136,177,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Endif
            Endif
          Endif
        Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
          If left$(SZVAL, 2) <> "??" Then
            If val([M:MGG2]CRIVAL(nolign)) < val(SZVAL)
              #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
              GMESSAGE = mess(136,177,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Elsif IFIETYP >= 10 Then
          If left$(SZVAL, 2) <> "??" Then
            If [M:MGG2]CRIVAL(nolign) < SZVAL Then
              #Cette valeur ne doit pas être supérieure à la deuxième. Saisie refusée.
              GMESSAGE = mess(136,177,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Endif
      Endif
    Endif
    If nolign = 2 Then
      If [M:MGG2]CRIVAL(0) <> "" Then
        If IFIETYP = 1 or IFIETYP = 2 Then
          If left$(SZVAL, 2) <> "??" Then
            If val([M:MGG2]CRIVAL(nolign-2)) > val(SZVAL) Then
              #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
              GMESSAGE = mess(757,196,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Elsif IFIETYP = 3 Then
          If left$(SZVAL, 2) <> "??" Then
            If instr(1, SZVAL, "date$") Then
              If instr(1, [M:MGG2]CRIVAL(nolign - 2), "date$") Then
                DCTLDATE1 = evalue([M:MGG2]CRIVAL(nolign-2))
                DCTLDATE2 = evalue(SZVAL)
                If DCTLDATE1 > DCTLDATE2 Then
                  #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
                  GMESSAGE = mess(757,196,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Else
                DCTLDATE2 = evalue(SZVAL)
                If [M:MGG2]CRIVALDAT(nolign-2) > DCTLDATE2 Then
                  #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
                  GMESSAGE = mess(757,196,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Endif
            Else
              If instr(1, [M:MGG2]CRIVAL(nolign - 2), "date$") Then
                DCTLDATE1 = evalue([M:MGG2]CRIVAL(nolign-2))
                If DCTLDATE1 > [M:MGG2]CRIVALDAT(nolign-1) Then
                  #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
                  GMESSAGE = mess(757,196,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Else
                If [M:MGG2]CRIVALDAT(nolign - 2) > SZVALINT Then
                  #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
                  GMESSAGE = mess(757,196,1) - mess(627,196,1)
                  GERR = 1
                  mkstat = 2
                Endif
              Endif
            Endif
          Endif
        Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
          If left$(SZVAL, 2) <> "??" Then
            If val([M:MGG2]CRIVAL(nolign - 2)) > val(SZVAL) Then
              #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
              GMESSAGE = mess(757,196,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Elsif IFIETYP >= 10 Then
          If left$(SZVAL, 2) <> "??" Then
            If [M:MGG2]CRIVAL(nolign-2) > SZVAL Then
              #Cette valeur ne doit pas être inférieure à la première. Saisie refusée.
              GMESSAGE = mess(757,196,1) - mess(627,196,1)
              GERR = 1
              mkstat = 2
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  If GERR Then
    End
  Endif
  #Contrôle de la saisie de guillemets
  If IFIETYP >= 10 Then
    IQUOTE1 = instr(1, SZVAL, '"')
    If IQUOTE1 > 0 Then
      IQUOTE3 = IQUOTE1 + 1
      IQUOTE2 = instr(IQUOTE3, SZVAL, '"')
      IQUOTE4 = IQUOTE2 - IQUOTE1
      If IQUOTE4 > 1 Then
        #Les valeurs alphanumériques ne doivent pas être saisies au sein de guillemets.
        GMESSAGE = mess(114,177,1)
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

########################################################################################################################
$READ_ADI_FSTAT
  # FGR 18/07/2012 : X3SUIVI83551
  IFOUND = 0
  Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
  For [ADI] CODE
    If [F:ADI]CODE = VALEUR Then
      IFOUND = 1
      Break
    Endif
  Next
  Filter [ADI]
Return

########################################
Subprog AM_CRIVAL(VALEUR)
Variable Char    VALEUR()

Local Integer IFIETYP

  IFIETYP = 0
  #Obtient le type d'un champ
  Local File =[M:MGG2]CRITAB(GPRECRINOL) [TYPX]
  IFIETYP = evalue("Type([F:TYPX]" + [M:MGG2]CRIFIE(GPRECRINOL) + ")")
  Close Local File [TYPX]
  If VALEUR = "" Then
    If IFIETYP = 1 or IFIETYP = 2 Then
      VALEUR = "0"
    Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
      VALEUR = "0"
    Endif
  Else
    If len(VALEUR) > 2 Then
      If left$(VALEUR, 2) <> "??" Then
        If IFIETYP = 1 or IFIETYP = 2 Then
          VALEUR = num$(val(VALEUR))
        Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
          VALEUR = num$(val(VALEUR))
        Endif
      Endif
    Else
      If IFIETYP = 1 or IFIETYP = 2 Then
        VALEUR = num$(val(VALEUR))
      Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
        VALEUR = num$(val(VALEUR))
      Endif
    Endif
  Endif
  [M:MGG2]CRIVAL(nolign-1) = VALEUR
  Affzo [M:MGG2]CRIVAL(nolign-1)
End

########################################
Subprog IB_CRIVAL
Local Char SZTABCRINAM
Local Char SZLEFTCRIFIE(GLONAVA)

  SZTABCRINAM = ""
  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT3
  Raz GBOUT4
  Raz GBOUT5
  Raz GBOUT6
  If [M:MGG2]CRITAB(GPRECRINOL) = "" Then
    End
  Endif
  If [M:MGG2]CRIFIE(GPRECRINOL) = "" Then
    End
  Endif
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND ([M:MGG2]CRIFIE(GPRECRINOL)) # FGR 13/01/2009 : X3SUIVI51579
  Read [ATZ]CODZONE=[M:MGG2]CRITAB(GPRECRINOL);SZLEFTCRIFIE
  If fstat Then
    #Erreur lors de la recherche du type du champ.
    GMESSAGE = mess(578,196,1)
    GERR = 1
    End
  Endif
  If [F:ATZ]CODTYP = "ADI" or [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
    GBOUT1 = mess(8,31,1)   #Sélection
  Else
    If [F:ATZ]CODTYP <> "" Then
      Read [ATY]CODTYP=[F:ATZ]CODTYP
      If !fstat Then
        If [F:ATY]OBJLIEN <> "" Then
          Read [AOB]ABREV=[F:ATY]OBJLIEN
          If !fstat Then
            GBOUT2 = mess(8,31,1)   #Sélection
          Endif
        Endif
      Endif
    Endif
  Endif
  If [F:ATZ]CODTYP = "PBL" Then
    Call TEXTE(18894, GBOUT6) From OBJDIV      #Sélection arborescente
  Endif
  If GBOUT1 = "" Then
    If GBOUT2 = "" Then
      SZTABCRINAM = [M:MGG2]CRITAB(GPRECRINOL) + '|' + [M:MGG2]CRIFIE(GPRECRINOL)
      Read [DVA]DVA0="MGV";SZTABCRINAM
      If !fstat Then
        GBOUT3 = mess(8,31,1)   #Sélection
      Endif
    Endif
  Endif
  If GBOUT1 = "" Then
    If GBOUT2 = "" Then
      If GBOUT3 = "" Then
        If [M:MGG2]CRIFIE(GPRECRINOL) = "CREUSR" or [M:MGG2]CRIFIE(GPRECRINOL) = "UPDUSR" Then
          GBOUT4 = mess(8,31,1)   #Sélection
        Endif
      Endif
    Endif
  Endif
  If GBOUT1 = "" Then
    If GBOUT2 = "" Then
      If GBOUT3 = "" Then
        If GBOUT4 = "" Then
          If [M:MGG2]CRITAB(GPRECRINOL) = "SCPASW" and [M:MGG2]CRIFIE(GPRECRINOL) = "ASWALH"
            GBOUT5 = mess(8,31,1)   #Sélection
          Endif
        Endif
      Endif
    Endif
  Endif
End

########################################
Subprog AM_TGR(VALEUR)
Variable Char    VALEUR()

Local Char SZDVAPARAM

  [M:MGG0]TGR = VALEUR
  If [M:MGG0]TGR = "" Then
    [M:MGG0]TGPNUM = ""
    [M:MGG0]QURCAT = ""
    [M:MGG0]QURNAM = ""
    Grizo [M:MGG0]TGPNUM
    Grizo [M:MGG0]QURCAT
    Grizo [M:MGG0]QURNAM
    Grizo [M:MGG1]
    Grizo [M:MGG2]
  Else
    Actzo [M:MGG1]
    Actzo [M:MGG2]
    Actzo [M:MGG0]TGPNUM
    Actzo [M:MGG0]QURCAT
    Actzo [M:MGG0]QURNAM
    Grizo [M:MGG0]TGR
    #On renseigne la dénomination de la cible
    Read [TGL]TGL0=[M:MGG0]TGR
    #On propose un support de présentation
    SZDVAPARAM = GUSER + [M:MGG0]TGR
    #D'abord un support pour l'utilisateur
    Read [DVA]DVA0="TGP";SZDVAPARAM
    If fstat Then
      #Sinon le support par défaut de la cible
      Read [TGL]TGL0=[M:MGG0]TGR
      If fstat Then
        [M:MGG0]TGPNUM = ""
      Else
        [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
      Endif
    Else
      #On vérifie que le support existe
      If [F:DVA]ALHX(0) = "" Then
        #Sinon le support par défaut de la cible
        Read [TGL]TGL0=[M:MGG0]TGR
        If fstat Then
          [M:MGG0]TGPNUM = ""
        Else
          [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
        Endif
      Else
        Read [TGP]TGP0=[F:DVA]ALHX(0)
        If fstat Then
          #Supprime le support personnel de l'utilisateur
          Call DEBTRANS From GLOCK
          Trbegin [DVA]
          Delete [DVA] Where [F:DVA]OBC = "TGP" and [F:DVA]PARAM = SZDVAPARAM
          If fstat Then
            Rollback
          Else
            Commit
          Endif
          #Sinon le support par défaut de la cible
          Read [TGL]TGL0=[M:MGG0]TGR
          If fstat Then
            [M:MGG0]TGPNUM = ""
          Else
            [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
          Endif
        Else
          [M:MGG0]TGPNUM = [F:DVA]ALHX(0)
        Endif
      Endif
    Endif
  Endif
  Affzo [M:MGG0]
  Affzo [M:MGG1]
  Affzo [M:MGG2]
End

########################################
Subprog B3_TGPNUM(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR

  SZVALEUR = VALEUR
  Call SETUSERTGP(SZVALEUR, [M:MGG0]TGR) From SUBTGPB
End

########################################
Subprog IB_CRIFIE

  Read [FID]FID0=[M:MGG2]CRITAB(nolign-1);GAUSCRMI
  If fstat Then
    Read [FID]FID0=[M:MGG2]CRITAB(nolign-1);""
    If fstat Then
      Raz GBOUT1
    Else
      Call TEXTE(18653, GBOUT1) From OBJDIV    #Critères de ciblage
    Endif
  Else
    Call TEXTE(18653, GBOUT1) From OBJDIV      #Critères de ciblage
  Endif
End

#######################################
Subprog C_PPLSELSPT(VALEUR)
Variable Char    VALEUR()

  Read [SSP]SSP0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
  Else
    If [F:SSP]SPTTGR <> [M:MGG0]TGR Then
      #Le support de sélection indiqué ne correspond pas à la cible.
      GMESSAGE = mess(142,182,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################
Subprog APRES_NBPPL
End

##########################################################################
Subprog C_TGPNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [TGP]TGP0=VALEUR
    If !fstat Then
      If [F:TGP]TGR <> [M:MGG0]TGR Then
        #Le support de présentation sélectionné est incompatible avec la cible.
        GMESSAGE = mess(65,177,1)
        GERR = 2
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

