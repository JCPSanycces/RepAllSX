#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* PHYEVTLST Class
#* Query and detail from Physical element's events
#*
#* @param REF     Event's reference
#* @param TIMSTP  Must be null (for having all events of object)
#*!

$EVENTS

  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_OPEN_AFTER"  : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER" : Gosub AQUERY_CLOSE_AFTER
        When "AREAD_AFTER"        : Gosub AREAD_AFTER
      Endcase
  Endcase

Return

$METHODS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

$AQUERY_OPEN_AFTER
  Local File ATEXTRA [ATX]
Return

$AQUERY_CLOSE_AFTER
  Close File [ATX]
Return

$AQUERY_TRANS_AFTER

  # Affect the event's description
  Read [ATX]AXX0 = "ATABDIV"; "LNGDES"; GACTX.LAN; num$([V]CST_TD_EVENT); this.EVT.EVTINT
  this.DESCOD = [F:ATX]TEXTE

  # Issue number 110495
  this.EVTCRETIM = mid$(num$(this.EVT.CREDATTIM),12,2)+mid$(num$(this.EVT.CREDATTIM),15,2)+mid$(num$(this.EVT.CREDATTIM),18,2)

  # End issue number 110495

Return

$AREAD_AFTER

Local Integer IND_NUM, IND_ALPHA, IND_MENU, IND_DATE, STACK_ERROR, NB_EXCLUDE
Local Char WEVT_TABLE(30)
Local Char EXCFLD(20)(1..50)

  WEVT_TABLE = "E" + this.EVT.EVTINT
  Local File =WEVT_TABLE [EEE]
  Local File ATABZON [ATZ]
  Local File ATYPE   [ATY]
  Local File ATEXTE  [ATX]
  Local File ATEXTRA [AXX]

  Read [EEE]EVE0 = this.EVT.REF; this.EVT.TIMSTP
  If fstat
    Close File [EEE]

    [L]STACK_ERROR = fmet this.ASETERROR("REF", mess(81, 75, 1), [V]CST_AERROR)
    ARET_VALUE= [V]CST_AERROR
    Return
  Endif

  # Affect the event's description
  Read [AXX]AXX0 = "ATABDIV"; "LNGDES"; GACTX.LAN; num$([V]CST_TD_EVENT); this.EVT.EVTINT
  If fstat = [V]CST_AOK
    this.DESCOD = [F:AXX]TEXTE
  Endif

  this.DES = [F:EEE]DES

  # Issue number 110495
  this.EVTCRETIM = mid$(num$([F:EEE]CREDATTIM),12,2)+mid$(num$([F:EEE]CREDATTIM),15,2)+mid$(num$([F:EEE]CREDATTIM),18,2)
  # End issue number 110495

  #* List of exclude properties (which are yet of main screen)
  Gosub PROPERTIES_EXCLUDE

  # put the properties on the screen
  Raz IND_NUM, IND_ALPHA, IND_MENU, IND_DATE
  For [ATZ] Where CODFIC = WEVT_TABLE
    If find([F:ATZ]CODZONE, EXCFLD(1..NB_EXCLUDE)) = 0
      Gosub PROPERTIES_LOAD
    Endif
  Next
  Filter [ATZ]

  Close File [EEE]

Return

#**
#* List of exclude properties (which are yet of main screen)
#*!
$PROPERTIES_EXCLUDE

  NB_EXCLUDE = 1
  EXCFLD(NB_EXCLUDE)  = "CPY"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "FCY"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "REF"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "LIN"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "DPRPLN"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CNX"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "EVTINT"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CREUSR"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CREDAT"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CRETIM"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "TIMSTP"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "EVTDAT"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CPTDATINT"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CPTFLG"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "SNSEVE"
  NB_EXCLUDE += 1
#  EXCFLD(NB_EXCLUDE)  = "SNSCPT"
#  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CREUSRO"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "TIMSTPO"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CPTDATINTO"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "CREORI"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "UPDUSR"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "UPDDAT"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "UPDTIM"
#  NB_EXCLUDE += 1
#  EXCFLD(NB_EXCLUDE)  = "CURPERSTR"
  NB_EXCLUDE += 1
  EXCFLD(NB_EXCLUDE)  = "DES"

Return

#**
#* put the properties on the screen (with type property)
#*!
$PROPERTIES_LOAD

  Read [ATY]CODTYP=[F:ATZ]CODTYP

  #> number type property

  If [F:ATY]TYPTYP=2 or  [F:ATY]TYPTYP=3 or  [F:ATY]TYPTYP=4 or  [F:ATY]TYPTYP=5 or [F:ATY]TYPTYP=6

    IND_NUM += 1
    this.EVT.PROPNUM(IND_NUM) = NewInstance  =this.AllocGrp, C_PHYEVTLST_PROPNUM(this.ACTX, NullUuid, IND_NUM, this, "PROPNUM")

    this.EVT.PROPNUM(IND_NUM).CODEN = [F:ATZ]CODZONE
    Read [ATX]NUMERO = GACTX.LAN; [F:ATZ]NOCOURT
    this.EVT.PROPNUM(IND_NUM).DESIN = [F:ATX]TEXTE
    If [F:ATY]TYPTYP=2 or  [F:ATY]TYPTYP=3
      this.EVT.PROPNUM(IND_NUM).VALEURN = num$(evalue("[F:EEE]" + [F:ATZ]CODZONE))
    Else
      this.EVT.PROPNUM(IND_NUM).VALEURN = format$("N:13.2", evalue("[F:EEE]" + [F:ATZ]CODZONE))
    Endif

  Endif

  #> Menu type property

  If [F:ATY]TYPTYP = 1 #or [F:ATY]TYPTYP = 2

    IND_MENU += 1
    this.EVT.PROPMENU(IND_MENU) = NewInstance  =this.AllocGrp, C_PHYEVTLST_PROPMENU(this.ACTX, NullUuid, IND_MENU, this, "PROPMENU")

    this.EVT.PROPMENU(IND_MENU).CODEM = [F:ATZ]CODZONE
    Read [ATX]NUMERO = GACTX.LAN; [F:ATZ]NOCOURT
    this.EVT.PROPMENU(IND_MENU).DESIM = [F:ATX]TEXTE
    this.EVT.PROPMENU(IND_MENU).VALEURM = num$(evalue("[F:EEE]" + [F:ATZ]CODZONE))
    If evalue("[F:EEE]" + [F:ATZ]CODZONE) > 0
      this.EVT.PROPMENU(IND_MENU).VALEURM -= mess(evalue("[F:EEE]" + [F:ATZ]CODZONE), [F:ATZ]NOLIB, 1)
    Endif

  Endif

  #> Alphanum.  type property

  If [F:ATY]TYPTYP = 7

    IND_ALPHA += 1
    this.EVT.PROPALPHA(IND_ALPHA) = NewInstance  =this.AllocGrp, C_PHYEVTLST_PROPALPHA(this.ACTX, NullUuid, IND_ALPHA, this, "PROPALPHA")

    this.EVT.PROPALPHA(IND_ALPHA).CODEA = [F:ATZ]CODZONE
    Read [ATX]NUMERO = GACTX.LAN; [F:ATZ]NOCOURT
    this.EVT.PROPALPHA(IND_ALPHA).DESIA = [F:ATX]TEXTE
    this.EVT.PROPALPHA(IND_ALPHA).VALEURA = evalue("[F:EEE]" + [F:ATZ]CODZONE)

  Endif

  #> Date type property

  If [F:ATY]TYPTYP = 8

    IND_DATE += 1
    this.EVT.PROPDATE(IND_DATE) = NewInstance  =this.AllocGrp, C_PHYEVTLST_PROPDATE(this.ACTX, NullUuid, IND_DATE, this, "PROPDATE")

    this.EVT.PROPDATE(IND_DATE).CODEDT = [F:ATZ]CODZONE
    Read [ATX]NUMERO = GACTX.LAN; [F:ATZ]NOCOURT
    this.EVT.PROPDATE(IND_DATE).DESIDT = [F:ATX]TEXTE
    this.EVT.PROPDATE(IND_DATE).VALEURDT = format$("D:DD[/]MM[/]YYYY", evalue("[F:EEE]" + [F:ATZ]CODZONE))

  Endif

Return

