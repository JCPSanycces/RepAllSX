If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_BAN From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0BSIITCD
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_BSICODTC From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_BSICODTC From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LIN From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LIN From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LEV From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LEV From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_COD From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_COD From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESAXX From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESAXX From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SIG From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SIG From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SUMCOD From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SUMCOD From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REC From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REC From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESFLD From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESFLD From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_BAN From WMC1BSIITCD : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_BAN From WMC1BSIITCD : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



