# Subprog GERER_ASSOCIATION(PVALDETAAS, PDETAAS, POBJ, PTYPDET, PWIN, RFLGASS)
# Subprog DECLENCHER_ASSOCIATION(PCPY, PVALDETAAS, PDETAAS, PTYPDET, POBJ, PWIN, PPHP, RFLGASS)  #*FQ-58042
# Subprog DETER_ACCCOD(VALDETAAS, CPY, RACCCOD, RUPDFLG)
# Subprog DETER_VAL_PLANS(PCPY, PFAM, PACCCOD, PPLAN, RDPM, RDPRDUR, RDPRRAT, RALWCOD, RCRBVEHCOD, RPRATYP, RACLCOE, RUPDFLG)
# Subprog DETER_VAL_PLANS_F(PCPY, PFAM, PACCCOD, PPLAN, RDPM, RDPRDUR, RDPRRAT, RALWCOD, RCRBVEHCOD, RPRATYP, RACLCOE)
# Subprog DETER_VAL_NEW_PLAN(PFAM, PACCCOD, PPLAN, RDPM, RDUR, RRAT, RALW, RVEH, RERROR)
# Subprog DETER_VAL_NEW_PLAN_F(PCPY, PFAM, PACCCOD, PPLAN, RDPM, RDUR, RRAT, RALW, RVEH, RERROR)
# Subprog RUBRIQUES_DETERMINEES (POBJ, PCPY, PDISZO)
# Subprog RUBRIQUES_DETERMINEES_P((POBJ, PCPY, PDETAAS, PPLAN, PDISZO)
# Subprog RUBRIQUES_DETERMINEES_PMR((POBJ, PCPY, PDETAAS, PPLAN, PDISZO) # V5 pour MODIF_REDUITE de SUBFAS
###########################################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

###########################################################################################################
#Fq-59277 Subprog GERER_ASSOCIATION(PVALDETAAS, PDETAAS, POBJ, PWIN, RFLGASS)
Subprog GERER_ASSOCIATION(PVALDETAAS, PDETAAS, POBJ, PTYPDET, PWIN, RFLGASS)
# Application des associations dans la fenêtre d'un objet métier
Value    Char    PVALDETAAS : # Valeur du déterminant
Value    Char    PDETAAS    : # Déterminant ("FAM" : Famille comptable, "COD" : Code comptable,
Value    Integer PTYPDET    : ##Fq-59277 Type de détention pour un bien comptable, sinon = 0
Value    Char    POBJ       : # Objet métier ("LOF" : Dépense, "FAS" : Bien comptable, "GRT" : Subvention
Value    Char    PWIN       : # Fenêtre où s'appliquent les associations
# Rend :
Variable Integer RFLGASS    : # indicateur prenant la valeur G_OUI après application de l'association
                              # indicateur prenant la valeur G_NON si pas d'association existante pour ce jeu
                              # d'associations
#----------------------------------------------------------------------------------------------------------
###########################################################################################################
Local Integer LDETAAS   : # Déterminant (selon valeurs du ML 313)
Local Integer LOBJ      : # Objet métier (selon valeurs du ML 341)
Local Char    LNOMVAR   : # Nom de la rubrique déterminée à traiter
Local Char    LSSPRO    : # Préfixe sous-programme
Local Char    WINPROG   : # Nom du traitement de la fenêtre
Local Char    WWTRT     : # Nom du traitement de l'écran
Local Char    VALCHAR   : # Variable de travail en Char
Local Integer VALINT    : # Variable de travail en Integer
Local Decimal VALDECI   : # Variable de travail en Decimal
Local Integer SAVINDICE : # Sauvegarde de indice
Local Integer SAVNOLIGN : # Sauvegarde de nolign
Local Char    SAVZONCOU : # Sauvegarde de zoncou
Local Integer VALINT    : # Variable de travail en Integer
Local Integer I, J, MA, OK, K
Local Char    PMSK0
Local Char    CHAMP_CPY

Case PDETAAS
  When "FAM"   : LDETAAS=GVML_DTAFAM
  When "COD"   : LDETAAS=GVML_DTACCO
  When "ORG"   : LDETAAS=GVML_DTAORG
  When Default
Endcase

Case POBJ
  When "LOF"   : LOBJ=GVML_OMDEPEN  :    PMSK0  =   "[M:LOF0]"
  When "FAS"   : LOBJ=GVML_OMBIEN   :    PMSK0  =   "[M:FAS0]"
  When "GRT"   : LOBJ=GVML_OMSUBV   :    PMSK0  =   "[M:GRT0]"
  When Default
Endcase

If PVALDETAAS = "" | PWIN = "" | LDETAAS = 0 | LOBJ = 0 : # Paramètres incomplet, on s'en va
  End
Endif

# récupération de la liste des masques et de leurs abréviations
Call NOMTRTWIN(PWIN,WINPROG) From MSKDIV
If WINPROG = "" Then
  End
Endif
Gosub DEFVAR From =WINPROG

If clalev([F:RDE])=0      : Local File RUBASSDEF  [RDE]      : Endif
If clalev([F:RVA])=0      : Local File RUBASSVAL  [RVA]      : Endif
If LOBJ=GVML_OMBIEN
  If clalev([F:RDP])=0    : Local File RUBASSDEFP [RDP]      : Endif
  If clalev([F:RVP])=0    : Local File RUBASSVALP [RVP]      : Endif
Endif

# sauvegarde indice, nolign et zoncou
SAVINDICE = indice
SAVNOLIGN = nolign
SAVZONCOU = zoncou

OK = 1
If clalev([F:CPY])=0    :   Local File COMPANY [CPY]        : Endif


#<*Fq-59867

# Issue 115015  Local Char LACM
# Issue 115015  READ [CPY]CPY0=CPY

#Fq-76033 si l'on vient du Regroupement des dépense le masque par défaut est LOF7
If PWIN="LOFGRPFASM"
   Default Mask [LOF7]
   WWTRT  = "LOF7"
Endif

# Issue 115015
Local Char LACM(3)
Read [CPY]CPY0=[M]CPY
If fstat=0
   LACM=[F:CPY]ACM
Endif # End Issue 115015

#<*Fq-59867
#* On recherche s'il existe une association portant sur la valeur du déterminant
#*Fq-59867 Read [RDE]RDE0=LOBJ;LDETAAS;[M]GCM;[M]CPY
Read [RDE]RDE0=LOBJ;LDETAAS;LACM;[M]CPY
If fstat | [F:RDE]ENAFLG <> G_OUI
  #*Fq-59867Read [RDE]RDE0=LOBJ;LDETAAS;[M]GCM;""
  Read [RDE]RDE0=LOBJ;LDETAAS;LACM;""
Endif
If !fstat & [F:RDE]ENAFLG = G_OUI
  Read [RVA]RVA0=num$(LOBJ)+num$(LDETAAS)+[F:RDE]ACM+[F:RDE]CPY;PVALDETAAS
  If fstat=0
    For J = 0 To [F:RDE]NBRUB0-1
      If [F:RDE]RUBRAS(J)<>"" & [F:RDE]MGTFLG(J) = G_OUI
        I=find([F:RDE]RUBRAS(J),[F:RVA]RUBRAS(0..[F:RVA]NBLIG-1))-1
        If I >= 0
          If [F:RVA]VALDETEAS(I) <> ""
            OK = 1
            Gosub TRT_RUBRIQUE
            If !OK : Break : Endif
          Endif
        Endif
      Endif
    Next J
  Endif

  # si l'on vient de l'objet Bien comptable: recherche des valeurs déterminées pour les plans d'amortissement
  #Fq-76033 If POBJ="FAS" & OK
  If POBJ="FAS" & OK & PWIN <> "LOFGRPFASM"
     Default Mask [FAS3] : # FQ83398
     WWTRT  = "FAS3"     : # FQ83398
     For [RDP]RDP0 Where REFOBJ=[F:RDE]REFOBJ & DETAAS=[F:RDE]DETAAS & ACM=[F:RDE]ACM  & CPY=[F:RDE]CPY
      J = find([F:RDP]DPRPLN,[M:FAS3]DPRPLN(0..[M:FAS3]NBLIG1-1))
      If J & find(G_OUI,[F:RDP]MGTFLGP(0..[F:RDP]NBRUBP-1))
        Read [RVP]RVP0=[F:RDP]NUMASS;PVALDETAAS;[F:RDP]DPRPLN
        If fstat = 0
          nolign = J : # FQ79283
          For I = 0 To [F:RDP]NBRUBP-1
            If [F:RDP]MGTFLGP(I) = G_OUI
              LNOMVAR = [F:RDP]RUBRASP(I)
              Case LNOMVAR
                When "DPM", "CRBVEHCOD"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> "" & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = ""
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK=1
                    VALCHAR = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                When "DPRDUR", "DPRRAT" , "DPRRAT2", "ACLCOE"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = 0
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK = 1
                    VALDECI = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                # ajout pour tester la valeur 1
                When "ALWCOD"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 &
&                           ( evalue("[M]"+LNOMVAR+"("+num$(J-1)+")")  = 0    or
&                             evalue("[M]"+LNOMVAR+"("+num$(J-1)+")")  = 1 )  or
&                             ( [F:RDP]FRCFLGP(I) = G_OUI )
                    OK=1
                    VALINT = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                When Default
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = 0
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK=1
                    VALINT = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
              Endcase
            Endif
          Next
        Endif
      Endif
    Next
    Setmok [M] With 0
  Endif
Endif
If !OK
  mkstat=2
  # Les données déterminées par le paramétrage des associations sont invalides
  GMESSAGE=mess(139,7770,1)
Endif

# restauration indice, nolign et zoncou
indice = SAVINDICE
nolign = SAVNOLIGN
zoncou = SAVZONCOU

End
### FQ-58042 #########################################################################################################
#*Fq-59277 Subprog DECLENCHER_ASSOCIATION(PCPY, PVALDETAAS, PDETAAS, PTYPDET, POBJ, PWIN, PPHP, RFLGASS)
Subprog DECLENCHER_ASSOCIATION(PCPY, PVALDETAAS, PDETAAS, POBJ, PTYPDET, PWIN, PPHP, RFLGASS)
# Application des associations via une action métier, dans la fenêtre d'un objet métier
Value    Char    PCPY       : # Valeur de la société
Value    Char    PVALDETAAS : # Valeur du déterminant
Value    Char    PDETAAS    : # Déterminant ("FAM" : Famille comptable, "COD" : Code comptable,
                            : # "ORG" : Organisme)
Value    Integer PTYPDET    : #Fq-59277 Type de détention (=0 : si pas de type à récupérer)
Value    Char    POBJ       : # Objet métier ("LOF" : Dépense, "FAS" : Bien comptable, "GRT" : Subvention
Value    Char    PWIN       : # Fenêtre où s'appliquent les associations
Value    Char    PPHP        : # "Plans" (P) ou "Hors-plans" (HP)
# Rend :
Variable Integer RFLGASS    : # indicateur prenant la valeur G_OUI après application de l'association
                              # indicateur prenant la valeur G_NON si pas d'association existante pour ce jeu
                              # d'associations
#----------------------------------------------------------------------------------------------------------
###########################################################################################################
Local Integer LDETAAS   : # Déterminant (selon valeurs du ML 313)
Local Integer LOBJ      : # Objet métier (selon valeurs du ML 341)
Local Char    LCPY      : # Société
Local Char    LPHP      : # "Plans" (P) ou "Hors-plans" (HP)
Local Char    LNOMVAR   : # Nom de la rubrique déterminée à traiter
Local Char    LSSPRO    : # Préfixe sous-programme
Local Char    WINPROG   : # Nom du traitement de la fenêtre
Local Char    WWTRT     : # Nom du traitement de l'écran
Local Char    VALCHAR   : # Variable de travail en Char
Local Integer VALINT    : # Variable de travail en Integer
Local Decimal VALDECI   : # Variable de travail en Decimal
Local Integer SAVINDICE : # Sauvegarde de indice
Local Integer SAVNOLIGN : # Sauvegarde de nolign
Local Char    SAVZONCOU : # Sauvegarde de zoncou
Local Integer VALINT    : # Variable de travail en Integer
Local Integer I, J, MA, OK
Local Char    PMSK0     : # FQ 46680
Local Char    CHAMP_CPY : # FQ 46680

Case PDETAAS
  When "FAM"   : LDETAAS=GVML_DTAFAM
  When "COD"   : LDETAAS=GVML_DTACCO
  When "ORG"   : LDETAAS=GVML_DTAORG
  When Default
Endcase

Case POBJ
  When "LOF"   : LOBJ=GVML_OMDEPEN  :    PMSK0  =   "[M:LOF0]"    # FQ 46680
  When "FAS"   : LOBJ=GVML_OMBIEN   :    PMSK0  =   "[M:FAS0]"    # FQ 46680
  When "GRT"   : LOBJ=GVML_OMSUBV   :    PMSK0  =   "[M:GRT0]"    # FQ 46680
  When Default
Endcase

LCPY = PCPY
LPHP = PPHP

If PVALDETAAS = "" | PWIN = "" | LDETAAS = 0 | LOBJ = 0 : # Paramètres incomplet, on s'en va
  End
Endif

# récupération de la liste des masques et de leurs abréviations
Call NOMTRTWIN(PWIN,WINPROG) From MSKDIV
If WINPROG = "" Then
  End
Endif
Gosub DEFVAR From =WINPROG

If clalev([F:RDE])=0      : Local File RUBASSDEF  [RDE]      : Endif
If clalev([F:RVA])=0      : Local File RUBASSVAL  [RVA]      : Endif
If LOBJ=GVML_OMBIEN
  If clalev([F:RDP])=0    : Local File RUBASSDEFP [RDP]      : Endif
  If clalev([F:RVP])=0    : Local File RUBASSVALP [RVP]      : Endif
Endif

# Récup du modèle comptable
If clalev([F:CPY]) = 0
    Local File COMPANY [CPY]
Endif
Local Char LACM
Read [CPY]CPY0=LCPY
If fstat=0
   LACM=[F:CPY]ACM
Endif
# sauvegarde indice, nolign et zoncou
SAVINDICE = indice
SAVNOLIGN = nolign
SAVZONCOU = zoncou

OK = 1

If LPHP = "HP"
   #* On recherche s'il existe une association portant sur la valeur du déterminant
   # Ajout de LACM ds la clef
   Read [RDE]RDE0=LOBJ;LDETAAS;LACM;LCPY
   If fstat | [F:RDE]ENAFLG <> G_OUI
     #FQ80032
     Read [RDE]RDE0=LOBJ;LDETAAS;LACM;""
     # CBO 2012.07.31 FQ83779
     LCPY = ""
   Endif

   If !fstat & [F:RDE]ENAFLG = G_OUI
     Read [RVA]RVA0=num$(LOBJ)+num$(LDETAAS)+LACM+LCPY;PVALDETAAS
     If fstat=0
       For J = 0 To [F:RDE]NBRUB0-1
         If [F:RDE]RUBRAS(J)<>"" & [F:RDE]MGTFLG(J) = G_OUI
           I=find([F:RDE]RUBRAS(J),[F:RVA]RUBRAS(0..[F:RVA]NBLIG-1))-1
           If I >= 0
             If [F:RVA]VALDETEAS(I) <> ""
               OK = 1
               Gosub TRT_RUBRIQUE
               If !OK : Break : Endif
             Endif
           Endif
         Endif
       Next J
     Endif
Endif
If LPHP <> "PHP" : Goto FIN_ASSOC : Endif
# si l'on vient de l'objet Bien comptable: recherche des valeurs déterminées pour les plans d'amortissement
  If POBJ="FAS" & OK
    #Default Mask [FASTRFCP]
    #WWTRT = "W1FASTRFCP"
    WWTRT = "FASTRFCP"
   # FQ80032
    For [RDP]RDP0 Where REFOBJ=[F:RDE]REFOBJ & DETAAS=[F:RDE]DETAAS & ACM=[F:RDE]ACM & CPY=[F:RDE]CPY
#    For [RDP]RDP0 Where REFOBJ=[F:RDE]REFOBJ & DETAAS=[F:RDE]DETAAS & CPY=[F:RDE]CPY
      J = find([F:RDP]DPRPLN,[M:FAS3]DPRPLN(0..[M:FAS3]NBLIG1-1))
      If J & find(G_OUI,[F:RDP]MGTFLGP(0..[F:RDP]NBRUBP-1))
        Read [RVP]RVP0=[F:RDP]NUMASS;PVALDETAAS;[F:RDP]DPRPLN
        If fstat = 0
          nolign = J : # FQ79283
          For I = 0 To [F:RDP]NBRUBP-1
            If [F:RDP]MGTFLGP(I) = G_OUI
              LNOMVAR = [F:RDP]RUBRASP(I)
              Case LNOMVAR
                When "DPM", "CRBVEHCOD"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> "" & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = ""
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK=1
                    VALCHAR = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                When "DPRDUR", "DPRRAT" , "DPRRAT2", "ACLCOE"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = 0
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK = 1
                    VALDECI = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                # ajout pour tester la valeur 1
                When "ALWCOD"
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 &
&                           ( evalue("[M]"+LNOMVAR+"("+num$(J-1)+")")  = 0    or
&                             evalue("[M]"+LNOMVAR+"("+num$(J-1)+")")  = 1 )  or
&                             ( [F:RDP]FRCFLGP(I) = G_OUI )
                    OK=1
                    VALINT = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
                When Default
                  If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 & (evalue("[M]"+LNOMVAR+"("+num$(J-1)+")") = 0
&                  | [F:RDP]FRCFLGP(I) = G_OUI)
                    OK=1
                    VALINT = evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
                    Gosub TRT_RUBPLAN
                    If !OK : Break : Endif
                  Endif
              Endcase
            Endif
          Next
        Endif
      Endif
    Next
    Setmok [M] With 0
  Endif
Endif
$FIN_ASSOC
If !OK
  mkstat=2
  # Les données déterminées par le paramétrage des associations sont invalides
  GMESSAGE=mess(139,GML_MSGFASPR,1)
Endif

# restauration indice, nolign et zoncou
indice = SAVINDICE
nolign = SAVNOLIGN
zoncou = SAVZONCOU

End
#*======================================================================================
$TRT_RUBRIQUE
#* - alimentation des rubriques  déterminées avec leur valeur déduite par association si
#*    le champ n'est pas renseigné ou si l'indicateur de forçage est à "oui"
#* -  le champ est rendu Diszo si l'indicateur de "modification" est à "non"
#*======================================================================================
LNOMVAR = [F:RDE]RUBRAS(J)

If GCNXPROIAS = G_NON & (find (LNOMVAR, "IASACC", "IASACN") <> 0)
   Return
Endif
# Récupération du masque en fonction de la rubrique à traiter
For MA=1 To NBMASK                                        : # On part de 1 pour sauter l'en-tête
  If evalue("dim([M:"+ABMSK(MA)+"]"+LNOMVAR+") > 0")      : # on a trouvé le masque
    Default Mask "["+ABMSK(MA)+"]"
    #WWTRT = "W1"+NOMMSK(MA)
    WWTRT = NOMMSK(MA)
    Break
  Endif
Next

indice = 0
nolign = 0
zoncou = LNOMVAR

If [F:RVA]NOLIB(I) > 0   or   LNOMVAR ="ADMCOE"          # si rubrique déterminée de type Menu Local
     If  ( [F:RVA]NOLIB(I) > 0 and LNOMVAR <> "ADMCOE"  and ( evalue("[M]"+LNOMVAR)  < 1   | [F:RDE]FRCFLG(J) = G_OUI ) ) or
&     ( LNOMVAR ="ADMCOE"   and  (  [F:RDE]FRCFLG(J) = G_OUI ) )
       #Fq-57900 &     ( LNOMVAR ="ADMCOE"   and  ( evalue("[M]"+LNOMVAR)  <> 0   & [F:RDE]FRCFLG(J) = G_OUI ) )
       VALINT = val([F:RVA]VALDETEAS(I))
       # Gestion du code admission
       If LNOMVAR="ADMCOE"
          VALDECI = val([F:RVA]VALDETEAS(I))
          Gosub SUBPROG_DECI
          If OK
             CHAMP_CPY  = (evalue(PMSK0+"CPY"))
             If !( func GLOFCYCPY.GET_SOC_PAYS(CHAMP_CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG(CHAMP_CPY) = "FRA" ) Then
                Assign "[M]"+LNOMVAR With 1
             Else
                Assign "[M]"+LNOMVAR With VALDECI
             Endif
          Endif
       Else
          If LOBJ = GVML_OMBIEN  and (LNOMVAR <> "OBYRNWCOD"  or PTYPDET = GVML_TDCONCE ) #Fq-59277
             VALINT = val([F:RVA]VALDETEAS(I))
             Gosub SUBPROG_INT
             If OK : Assign "[M]"+LNOMVAR With VALINT : Endif
          Else
             If ( LOBJ = GVML_OMDEPEN ) and ( LNOMVAR <> "OBYRNWCOD" )
             VALINT = val([F:RVA]VALDETEAS(I))
             Gosub SUBPROG_INT
             If OK : Assign "[M]"+LNOMVAR With VALINT : Endif
          Endif
          Endif
       Endif
     Endif
   Else

     If evalue("[M]"+LNOMVAR) = "" | [F:RDE]FRCFLG(J)= G_OUI
       If LOBJ = GVML_OMBIEN  #FQ-61676 and (LNOMVAR <> "CCNACTCOD"  or PTYPDET = GVML_TDCONCE )
           VALCHAR = [F:RVA]VALDETEAS(I)
           Gosub SUBPROG_CHAR
           If OK : Assign "[M]"+LNOMVAR With VALCHAR : Endif
        Else
           If LOBJ = GVML_OMDEPEN  and (LNOMVAR <> "CCNACTCOD" )
           VALCHAR = [F:RVA]VALDETEAS(I)
           Gosub SUBPROG_CHAR
           If OK : Assign "[M]"+LNOMVAR With VALCHAR : Endif
        Endif
     Endif
   Endif
Endif

If OK
  # affichage de la valeur déterminée
  Affzo [M]=LNOMVAR

  # protection du champ si mise à jour interdite
  If [F:RDE]UPDFLG(J) = G_NON # protection du champ si mise à jour interdite et contrôles OK
    Diszo [M]=LNOMVAR
  Endif

  RFLGASS = G_OUI

Endif

Return

#*======================================================================================
$TRT_RUBPLAN
#* - alimentation des rubriques des plans déterminées avec leur valeur déduite par association si
#*    le champ n'est pas renseigné ou si l'indicateur de forçage est à "oui"
#* -  le champ est rendu Diszo si l'indicateur de "modification" est à "non"
#*======================================================================================

# Appel aux sous-programmes des actions champs de l'écran
If !(dim(ACTMETNAM)<0) or GIMPORT : # FQ79976 Uniquement en import ou via une action métier, sinon
                                    #         on peut rester bloqué en saisie transactionnelle
  Case LNOMVAR
    When "DPM", "CRBVEHCOD", "PRATYP"
      Gosub SUBPROG_CHAR
    When "DPRDUR", "DPRRAT", "DPRRAT2", "ACLCOE"
      Gosub SUBPROG_DECI
    When Default
      Gosub SUBPROG_INT
  Endcase
Endif

If OK

  RFLGASS = G_OUI

  # Affectation de la valeur déterminée dans le masque
  Assign "[M]"+LNOMVAR+"("+num$(J-1)+")" With evalue("[F:RVP]"+[F:RDP]RUBRASP(I))

  If LNOMVAR="DPRRAT"
    Assign "[M]DPRRATFLG"+"("+num$(J-1)+")" With G_OUI
    Affzo [M]DPRRATFLG(J-1)
  Endif

  # affichage de la valeur déterminée
  Affzo [M]=LNOMVAR+"("+num$(J-1)+")"

  # protection du champ si mise à jour interdite
  If [F:RDP]UPDFLGP(I) = G_NON   # protection du champ si mise à jour interdite et contrôles OK
    Diszo [M]=LNOMVAR+"("+num$(J-1)+")"
  Endif
Endif

Return

#*==============================================================
$SUBPROG_INT

Onerrgo ERREUR
Local Integer K, ER

#FQ-62340 If LNOMVAR <> "DPRRAT" and  LNOMVAR <> "DPRRAT2" and  LNOMVAR <> "TAXTYP": Onerrgo ERREUR : Return :  Endif
#FQ-62340    If LNOMVAR = "TAXTYP"
If find(LNOMVAR,  "DPRRAT", "DPRRAT2", "TAXTYP", "CMPSTA") = 0 : Onerrgo ERREUR : Return :  Endif
   For LSSPRO = "C", "AP", "AM"
    If (LNOMVAR = "TAXTYP" or  LNOMVAR = "CMPSTA") and  (LSSPRO <> "AM")
    Endif
    #*FQ-71694 Call =LSSPRO+"_"+LNOMVAR With(VALINT) From  ="W1"+WWTRT
    #<FQ-71694
    K=1 : ER=0
    Onerrgo ERREUR
    Call =LSSPRO+"_"+LNOMVAR With(VALINT) From ="W"+num$(K)+WWTRT
    While ER and K < 10
      K+=1
      Call =LSSPRO+"_"+LNOMVAR With(VALINT) From ="W"+num$(K)+WWTRT
    Wend
Next
Onerrgo ERREUR
 #FQ-71694>

Return
#*==============================================================
$SUBPROG_DECI

Onerrgo ERREUR
Local Integer K, ER
#***On ne passe pas dans le contrôle alors que toute l'association n'a pas
# encore été appliquée car alors message (483,403) à tort
If LNOMVAR =  "DPRRAT" or LNOMVAR = "DPRRAT2"   or LNOMVAR ="ACLCOE ": Onerrgo ERREUR : Return :  Endif
For LSSPRO = "C", "AP", "AM"
  #*FQ-71694 Call =LSSPRO+"_"+LNOMVAR With(VALDECI) From  =WWTRT
  #<FQ-71694
  K=1 : ER=0
  Onerrgo ERREUR
  Call =LSSPRO+"_"+LNOMVAR With(VALDECI) From ="W"+num$(K)+WWTRT
  While ER and K < 10
    K+=1
    Call =LSSPRO+"_"+LNOMVAR With(VALDECI) From ="W"+num$(K)+WWTRT
  Wend
Next
Onerrgo ERREUR
#FQ-71694>

Return
#*==============================================================
$SUBPROG_CHAR

Onerrgo ERREUR
Local Integer K, ER

For LSSPRO = "C", "AP", "AM"
  #---- rq : on ne fait pas l'AM_ pour le Code comptable car sinon l'on rentre dans le call
  #---- de l'association Code comptable avant d'avoir terminé celui de l'association Famille
  #---- c'est pourquoi dans le SUBFAS on doit enchaîner les 2 calls en AM_ACGGRP
  #*Fq-54343 on ne passe pas par le C_CCNACTCOD, sinon on passe dans une sélection qui prend le pas sur l'association
  If LSSPRO = "AM" & LOBJ = GVML_OMBIEN  & (LNOMVAR = "ACCCOD" )    : Break : Endif
  If LSSPRO = "C"  & LOBJ = GVML_OMBIEN  & (LNOMVAR = "CCNACTCOD" ) : Break : Endif   #Fq-54343
  If LSSPRO = "C"  & LOBJ = GVML_OMDEPEN & (LNOMVAR = "CCNACTCOD" ) : Break : Endif   #Fq-54343
 #<FQ-71694
  K=1 : ER=0
  Onerrgo ERREUR
  Call =LSSPRO+"_"+LNOMVAR With(VALCHAR) From ="W"+num$(K)+WWTRT
  While ER and K < 10
    K+=1
    Call =LSSPRO+"_"+LNOMVAR With(VALCHAR) From ="W"+num$(K)+WWTRT
  Wend
Next
Onerrgo   ERREUR
#FQ-71694>

Return
#*==============================================================
$ERREUR
ER = 1
Resume
Return
###############################################################################
Subprog DETER_ACCCOD(VALDETAAS, CPY, RACCCOD, RUPDFLG)
# Application des associations pour déterminer le code comptable
Value    Char    VALDETAAS : # Famille comptable
Value    Char    CPY       : # Société
# Rend :
Variable Char    RACCCOD   : # Code comptable
Variable Integer RUPDFLG      # Indicateur code comptable :
                              # 1 : Non modifiable
                              # 2 : Oui modifiable
                              # 0 : pas de famille renseignée ou pas d'association paramétrée sur le code comptable (FQ90537)
# ------------------------------------------------------------------------------
###############################################################################
RACCCOD = ""
#Fq-79509  RUPDFLG = G_OUI
#FQ90537 RUPDFLG = G_NON
RUPDFLG = 0

If VALDETAAS="" : End : Endif

Local Integer I, J

If clalev([F:RDE])=0    :   Local File RUBASSDEF [RDE]      : Endif
If clalev([F:RVA])=0    :   Local File RUBASSVAL [RVA]      : Endif
If clalev([F:CPY])=0    :   Local File COMPANY [CPY]        : Endif

Local Char LACM
Read [CPY]CPY0=CPY
If fstat=0
   LACM=[F:CPY]ACM
Endif

Read [RDE]RDE0=GVML_OMBIEN;GVML_DTAFAM; LACM ;CPY  : # accès au paramétrage société
If fstat | [F:RDE]ENAFLG <> G_OUI
  Read [RDE]RDE0=GVML_OMBIEN;GVML_DTAFAM; LACM; "" : # accès au paramétrage par défaut
Endif

If fstat=0 & [F:RDE]ENAFLG = G_OUI
  I = find("ACCCOD",[F:RDE]RUBRAS(0..[F:RDE]NBRUB0-1))
  If I & [F:RDE]MGTFLG(I-1) = G_OUI
    Read [RVA]RVA0=num$(GVML_OMBIEN)+num$(GVML_DTAFAM)+[F:RDE]ACM+[F:RDE]CPY;VALDETAAS : # accès valeur déterminant
    If fstat=0
      J = find("ACCCOD",[F:RVA]RUBRAS(0..[F:RDE]NBRUB0-1))
      RACCCOD = [F:RVA]VALDETEAS(J-1)
      If RACCCOD <> ""
        RUPDFLG = [F:RDE]UPDFLG(I-1)
      Endif
    Endif
  Endif
Endif

End
#########################################################################################################
Subprog DETER_VAL_PLANS(PCPY,PFAM,PACCCOD,PPLAN,RDPM,RDPRDUR,RDPRRAT,RDPRRAT2,RALWCOD,RCRBVEHCOD,RPRATYP,RACLCOE,RUPDFLG)
# A partir d'un tableau de plans, d'une société, d'une valeur de famille comptable et d'une valeur de code
# comptable, récupération de 8 tableaux dont les éléments sont triés dans l'ordre des plans
Value    Char    PCPY           : # société
Value    Char    PFAM           : # famille comptable
Value    Char    PACCCOD        : # code comptable
Value    Integer PPLAN()        : # tableau des plans à traiter
# Rend :
Variable Char    RDPM()()       : # tableau des modes d'amortissement
Variable Decimal RDPRDUR()      : # tableau des durées d'amortissement
Variable Decimal RDPRRAT()      : # tableau des taux d'amortissement
Variable Decimal RDPRRAT2()     : # tableau des taux d'amortissement exceptionnels
Variable Integer RALWCOD()      : # tableau des règles particulières
Variable Char    RCRBVEHCOD()   : # tableau des codes plafond véhicule
Variable Integer RPRATYP()      : # tableau des Type prorata temporis
Variable Decimal RACLCOE()      : # tableau des coefficients d'accélèration

Variable Integer RUPDFLG(,)     : # tableau des indicateurs de mise à jour autorisée (1 : Non, 2 : Oui)
#                                   1ère dimension : rubriques déterminées (0 : DPM, 1 : DPRDUR, etc)
#                                   2nde dimension : plans
# -------------------------------------------------------------------------------------------------------
#########################################################################################################

Local Integer LDETAAS
Local Integer LTROUVE
Local Char    LCPY (GLONCPY)
Local Char    LCRITERE (250)
Local Char    LVALDET
Local Char    LVARIAB
Local Integer OK, I, J, K

K=find(0,PPLAN)
Raz RDPM, RDPRDUR, RDPRRAT,RDPRRAT2,  RALWCOD, RCRBVEHCOD, RPRATYP, RACLCOE
For I = 0 To K-2
  For J=0 To dim(RUPDFLG,1)-1 : RUPDFLG(J,I) = G_OUI : Next
Next

If clalev([F:RDP])=0      :       Local File RUBASSDEFP [RDP]     : Endif
If clalev([F:RVP])=0      :       Local File RUBASSVALP [RVP]     : Endif

If PFAM <> ""
  LDETAAS = GVML_DTAFAM
  LVALDET = PFAM
  Gosub ASSO_PLAN
Endif

If !OK & PACCCOD <> ""
  LDETAAS = GVML_DTACCO
  LVALDET = PACCCOD
  Gosub ASSO_PLAN
Endif
End

$ASSO_PLAN

LCPY=PCPY

Local Char LACM
Read [CPY]CPY0=LCPY
If fstat=0
   LACM=[F:CPY]ACM
Endif

LCRITERE="REFOBJ=GVML_OMBIEN & DETAAS=LDETAAS & ACM=LACM & CPY=LCPY & ENAFLG=G_OUI"
Raz LTROUVE

Repeat
  For [RDP]RDP0 Where evalue(LCRITERE)
    LTROUVE = 1
    J = find([F:RDP]DPRPLN,PPLAN)
    If J & find(G_OUI,[F:RDP]MGTFLGP(0..[F:RDP]NBRUBP-1))
      Read [RVP]RVP0=num$(GVML_OMBIEN)+num$(LDETAAS)+[F:RDP]ACM+[F:RDP]CPY;LVALDET;[F:RDP]DPRPLN
      If !fstat
        For I = 0 To [F:RDP]NBRUBP-1
          If [F:RDP]MGTFLGP(I) = G_OUI
            LVARIAB = "R"+[F:RDP]RUBRASP(I)
            Assign LVARIAB+"("+num$(J-1)+")" With evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
            Case LVARIAB
              When "RDPM", "RCRBVEHCOD"
                If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> "" & [F:RDP]UPDFLGP(I) = G_NON
                  RUPDFLG(I,J-1) = [F:RDP]UPDFLGP(I)
                Endif
              When Default
                If evalue("[F:RVP]"+[F:RDP]RUBRASP(I)) <> 0 & [F:RDP]UPDFLGP(I) = G_NON
                  RUPDFLG(I,J-1) = [F:RDP]UPDFLGP(I)
                Endif
            Endcase
          Endif
        Next
        If K = 2 : # Un seul plan à traiter
          OK = 1
          Break
        Endif
      Endif
    Endif
  Next
  If LCPY <> "" & !LTROUVE : # Rien trouvé sur le paramétrage société,
    LCPY = ""              : # on ré-essaye avec le paramétrage par défaut
  Else
    Break                  : # sinon on s'en va
  Endif
Until LTROUVE
Return
#########################################################################################################
#*** FQ 32364 Subprog DETER_VAL_NEW_PLAN(PFAM, PACCCOD, PPLAN, RDPM, RDUR, RRAT, RALW, RVEH, RERROR)
Subprog DETER_VAL_NEW_PLAN(PFAM, PACCCOD, PPLAN, RDPM, RDUR, RRAT, RRAT2, RALW, RVEH, RERROR)
# Pour un plan, à partir d'une valeur de famille comptable et d'une valeur de code comptable,
# récupération des rubriques déterminées par le paramétrage par défaut
Value    Char    PFAM           : # Famille comptable
Value    Char    PACCCOD        : # Code comptable
Value    Integer PPLAN          : # Plan à traiter
# Rend :
Variable Char    RDPM           : # Mode d'amortissement
Variable Decimal RDUR           : # Durée d'amortissement
Variable Decimal RRAT           : # Taux d'amortissement
Variable Decimal RRAT2          : # Taux d'amortissement exceptionnel
Variable Integer RALW           : # Règle particulière
Variable Char    RVEH           : # Code plafond véhicule
#Variable Integer RPRA           : # Type prorata
#Variable Decimal RACL           : # coeff accélération
Variable Integer RERROR         : # Code retour (0 : OK, 1 : KO)
# -------------------------------------------------------------------------------------------------------
#########################################################################################################
RERROR  = 1

Local Integer LPLAN   (G301MAX)
Local Char    LDPM    (GLONDPM) (G301MAX)
Local Decimal LDUR    (G301MAX)
Local Decimal LRAT    (G301MAX)
Local Decimal LRAT2   (G301MAX)
Local Integer LALW    (G301MAX)
Local Char    LVEH    (GLONADI) (G301MAX)
Local Integer LPRA    (G301MAX)
Local Decimal LACL    (G301MAX)
Local Integer LUPDFLG (5,G301MAX)

LPLAN(0) = PPLAN

Call DETER_VAL_PLANS("", PFAM, PACCCOD, LPLAN, LDPM, LDUR, LRAT, LRAT2, LALW, LVEH, LPRA, LACL, LUPDFLG)

RDPM    = LDPM(0)
RDUR    = LDUR(0)
RRAT    = LRAT(0)
RRAT2   = LRAT2(0)
RALW    = LALW(0)
RVEH    = LVEH(0)
RPRA    = LPRA(0)
RACL    = LACL(0)
RERROR  = 0

End
###############################################################################
Subprog RUBRIQUES_DETERMINEES (POBJ, PCPY, PDISZO)
# Activation/désactivation des rubriques déterminées par association sur les
# écrans figurant dans la liste des masques par défaut en fonction du (ou des)
# jeu(x) d'association applicable(s) - flags géré & modifiable
Value Integer POBJ    : # Objet métier (suivant valeur du ML 341)
Value Char    PCPY    : # Société
Value Integer PDISZO  : # Effectuer les désactivations (1 : Non, 2 : Oui). Pour
#                      la valeur 1 (Non) seules les activations sont effectuées
#------------------------------------------------------------------------------
###############################################################################
Local Char    LCPY
Local Char    LCRITERE(250)
Local Integer LTROUVE
Local Integer LFIN
Local Integer LDISZO
Local Integer I, MA
Local Char    WINPROG

# récupération de la liste des masques et de leurs abréviations
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

If clalev([F:RDE])=0  : Local File RUBASSDEF  [RDE] : Endif : # Associations - définition

LCPY=PCPY
LDISZO=PDISZO
LCRITERE="REFOBJ=POBJ & CPY=LCPY & ENAFLG=2"
While !LFIN
 Filter [RDE] Where evalue(LCRITERE)
 For [RDE]RDE0
   LTROUVE+=1 : Gosub ACTZO_DISZO
 Next
 Filter [RDE]

 If LCPY<>"" & (!LTROUVE | (POBJ=2 & LTROUVE<2)) : # Rien trouvé, ou un seul jeu pour les biens comptables :
  LCPY=""                                        : # on ré-essaye avec le paramétrage par défaut
  If POBJ=2 & LTROUVE=1                          : # Un seul jeu pour les biens comptables :
    LCRITERE-="& DETAAS<>"+num$([F:RDE]DETAAS)   : # on cherche l'autre jeu dans le paramétrage par défaut
  Endif
 Else
  LFIN=1
 Endif
Wend

If !LTROUVE  or  [M]ACGGRP="" : # Rien trouvé, même pas de paramétrage par défaut : il faut faire des actzo en se basant sur
 Gosub LECADI : # la table diverse décrivant les associations (951)
Endif

End
#----------------------------------------------------------------------------------------------------
$ACTZO_DISZO

# on ne désactive que si le déterminant est renseigné
If PDISZO=G_OUI
  Case [F:RDE]DETAAS
    When GVML_DTAFAM
      If [M]ACGGRP="" : LDISZO=G_NON : Endif
    When GVML_DTACCO
      If [M]ACCCOD="" : LDISZO=G_NON : Endif
    When GVML_DTAORG
      If [M]GRAORG="" : LDISZO=G_NON : Endif
    When Default
  Endcase
Endif

# Activation/désactivation des rubriques déterminées de l'objet métier
For I=0 To dim([F:RDE]RUBRAS)-1
   If [F:RDE]RUBRAS(I)<>""
     If evalue("dim([M]"+[F:RDE]RUBRAS(I)+") > 0")                  : # le champ est sur 1 des écrans
       If [F:RDE]MGTFLG(I)=G_OUI & [F:RDE]UPDFLG(I)=G_NON  & LDISZO=G_OUI  # le champ doit être disable
          If func GLOBIENS.IS_CHAMP_ENABLE (("[M]"+[F:RDE]RUBRAS(I)), 0) = G_OUI : # il est enable
             For MA=1 To NBMASK
                If evalue("dim([M:"+ABMSK(MA)+"]"+[F:RDE]RUBRAS(I)+") > 0") : # on a trouvé le masque
                   Call ACTDISZO(ABMSK(MA),[F:RDE]RUBRAS(I),ACB_DISZO)
                   Break
                Endif
             Next
          Endif
       Elsif LTROUVE=1                                                : # le champ doit être enable
          #FQ-46680  Gestion du code admission
          # on ne met pas enable, le code admission s'il a été mis disable par SUBFAS
          If !find([F:RDE]RUBRAS(I),"ADMCOE", "CCNACTCOD", "OBYRNWCOD")
             If func GLOBIENS.IS_CHAMP_ENABLE (("[M]"+[F:RDE]RUBRAS(I)), 0) = G_NON : # il est disable
                For MA=1 To NBMASK
                   If evalue("dim([M:"+ABMSK(MA)+"]"+[F:RDE]RUBRAS(I)+") > 0") : # on a trouvé le masque
                      Call ACTDISZO(ABMSK(MA),[F:RDE]RUBRAS(I),ACB_ACTZO)
                      Break
                   Endif
                Next
             Endif
          Endif
       Endif
     Endif
  Else                                                         : # on a traité toutes les rubriques déterminées
     Break
  Endif
Next

# Pour les rubriques déterminées des plans, il n'y a rien à faire car l'ensemble de l'écran FAS3
# est toujours protégé dès lors que l'on affiche un bien existant

Return
#----------------------------------------------------------------------------------------------------
$LECADI

If clalev([F:ADI])=0  : Local File ATABDIV  [ADI] : Endif : # Tables diverse
LCRITERE = 'NUMTAB='+num$(GTD_ASSORUB)-'& (A1="F"'
Case POBJ
 When GVML_OMDEPEN : LCRITERE -= '| pat(A1,"D*"))'
 When GVML_OMBIEN  : LCRITERE -= '| pat(A1,"B*"))'
 When GVML_OMSUBV  : LCRITERE -= '| pat(A1,"S*"))'
Endcase
For [ADI]CODE Where evalue(LCRITERE)
# Activation des rubriques déterminées de l'objet métier
 If evalue("dim([M]"+[F:ADI]CODE+") > 0")                         : # le champ est sur 1 des écrans
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M]"+[F:ADI]CODE, 0) = G_NON : # il est disable
    # on ne met pas enable, Code comptable ou Statut
    # on ne met pas enable ces champs s'ils ont été mis disable par SUBFAS
    If !find([F:ADI]CODE,"CMPSTA", "CCNACTCOD", "OBYRNWCOD")
    For MA=1 To NBMASK
     If evalue("dim([M:"+ABMSK(MA)+"]"+[F:ADI]CODE+") > 0")       : # on a trouvé le masque
      Call ACTDISZO(ABMSK(MA),[F:ADI]CODE,ACB_ACTZO)
      Break
     Endif
    Next
  Endif
  Endif
 Endif
Next

Return
#----------------------------------------------------------------------------------------------------
Subprog ACTDISZO(PMSK,PRUB,PACTION)

Value Char    PMSK
Value Char    PRUB
Value Integer PACTION
Default Mask "["+PMSK+"]"
Case PACTION
 When ACB_DISZO :  Diszo [M]=PRUB
 When ACB_ACTZO :  Actzo [M]=PRUB
Endcase

End
###############################################################################
Subprog RUBRIQUES_DETERMINEES_P (POBJ, PCPY, PDETAAS, PPLAN, RLIGNE)
# Activation/désactivation des rubriques déterminées par association pour chaque plan
# en fonction du (ou des) jeu(x) d'association applicable(s) - flags géré & modifiable
Value Integer POBJ    : # Objet métier (suivant valeur du ML 341)
Value Char    PCPY    : # Société
Value Integer PPLAN   : # Plan à traiter
Value Char    PDETAAS : # Déterminant
Value Integer RLIGNE  : # Ligne de l'écran FAS3 à traiter
#------------------------------------------------------------------------------
###############################################################################
Local Char    LCPY
Local Integer LPLN
Local Integer LINDICE
Local Char    LCRITERP(250)
Local Integer LDETAAS
Local Integer LTROUVE
Local Integer LFIN
Local Integer I, MA
Local Char    WINPROG

Case PDETAAS
  When "FAM"   : LDETAAS=GVML_DTAFAM
  When "COD"   : LDETAAS=GVML_DTACCO
  When Default
Endcase

# récupération de la liste des masques et de leurs abréviations
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

LFIN=0
LCPY=PCPY
LPLN = PPLAN
LINDICE = RLIGNE

Local Char LACM
Read [CPY]CPY0=LCPY
If fstat=0
   LACM=[F:CPY]ACM
Endif

If clalev([F:RDP])=0  : Local File RUBASSDEFP  [RDP] : Endif : # Associations - définition

#***
#*** pour les rubriques déterminées/plan
#***
Read[RDP]RDP0= POBJ;LDETAAS;LACM;LCPY;LPLN
If fstat <> 0
  LCPY= ""
  Read[RDP]RDP0= POBJ;LDETAAS;LACM;LCPY;LPLN
  If fstat <> 0
    LTROUVE=0
  End
  Endif
Else
  LTROUVE+=1
  Gosub ACTZO_DISZO_P
Endif

End
#----------------------------------------------------------------------------------------------------
$ACTZO_DISZO_P

# Activation/désactivation des rubriques déterminées de l'objet métier
For J=0 To dim([F:RDP]RUBRASP)-1
 If [F:RDP]RUBRASP(J)<>""
  If evalue("dim([M]"+[F:RDP]RUBRASP(J)+") > 0")                  : # le champ est sur 1 des écrans
   If [F:RDP]MGTFLGP(J)=G_OUI & [F:RDP]UPDFLGP(J)=G_NON             # le champ doit être disable
     # il est disable
     If func GLOBIENS.IS_CHAMP_ENABLE (("[M:FAS3]"+[F:RDP]RUBRASP(J)+"("+num$(LINDICE-1)+")"), LINDICE-1) = G_OUI
     For MA=1 To NBMASK
      If evalue("dim([M:"+ABMSK(MA)+"]"+[F:RDP]RUBRASP(J)+") > 0")
        Call ACTDISZO_P(ABMSK(MA),[F:RDP]RUBRASP(J),LINDICE, ACB_DISZO)
        Break
      Endif
     Next
    Endif
#*FQ102491Elsif [F:RDP]MGTFLGP(J)=G_OUI & [F:RDP]UPDFLGP(J)=G_OUI  # le champ doit être enable il est disable
#*FQ102491  If func GLOBIENS.IS_CHAMP_ENABLE (("[M:FAS3]"+[F:RDP]RUBRASP(J)+"("+num$(LINDICE-1)+")"), LINDICE-1) = G_NON
#*FQ102491    For MA=1 To NBMASK
#*FQ102491      If evalue("dim([M:"+ABMSK(MA)+"]"+[F:RDP]RUBRASP(J)+") > 0") : # on a trouvé le masque
#*FQ102491        Call ACTDISZO_P(ABMSK(MA),[F:RDP]RUBRASP(J), LINDICE, ACB_ACTZO)
#*FQ102491        Break
#*FQ102491      Endif
#*FQ102491    Next
#*FQ102491  Endif
      Endif
    Endif
  Else                                                         : # on a traité toutes les rubriques déterminées
    Break
  Endif
Next

Return
#----------------------------------------------------------------------------------------------------
Subprog ACTDISZO_P(PMSK,PRUB, PINDICE, PACTION)
Value Char       PMSK      # masque sur lequel se trouve le champ
Value Char       PRUB      # nom de la rubrique déterminée
Value Integer    PINDICE   # indice de la ligne du tableau sur laquelle se trouve le champ

Value Integer PACTION

Local Char RUB

Default Mask "["+PMSK+"]"

RUB=PRUB+"("+num$(PINDICE-1)+")"

Case PACTION
 When ACB_DISZO :  Diszo [M]=RUB  # Infbox "diszo RUB="-num$(RUB)
 When ACB_ACTZO :  Actzo [M]=RUB  # Infbox "actzo RUB="-num$(RUB)
Endcase

End
###############################################################################
Subprog DETER_ACCCOD_FORCE(VALDETAAS, CPY, RACCCOD, RFRCFLG)
# Application des associations pour déterminer le code comptable si rubrique forcée
Value    Char    VALDETAAS : # Famille comptable
Value    Char    CPY       : # Société
# Rend :
Variable Char    RACCCOD   : # Code comptable
Variable Integer RFRCFLG   : # Indicateur code comptable forçé (1 : Non, 2 : Oui)
# ------------------------------------------------------------------------------
###############################################################################

RACCCOD = ""
RFRCFLG = G_OUI
If VALDETAAS="" : End : Endif

Local Integer I, J

If clalev([F:RDE])=0    :   Local File RUBASSDEF [RDE]      : Endif
If clalev([F:RVA])=0    :   Local File RUBASSVAL [RVA]      : Endif

Local Char    LACM
Read [CPY]CPY0=CPY
If fstat=0
   LACM=[F:CPY]ACM
Endif

Read [RDE]RDE0=GVML_OMBIEN;GVML_DTAFAM;LACM;CPY  : # accès au paramétrage société
If fstat | [F:RDE]ENAFLG <> G_OUI
  Read [RDE]RDE0=GVML_OMBIEN;GVML_DTAFAM;LACM;"" : # accès au paramétrage par défaut
Endif

If fstat=0 & [F:RDE]ENAFLG = G_OUI
  I = find("ACCCOD",[F:RDE]RUBRAS(0..[F:RDE]NBRUB0-1))
  If I & [F:RDE]FRCFLG(I-1) = G_OUI
    Read [RVA]RVA0=num$(GVML_OMBIEN)+num$(GVML_DTAFAM)+[F:RDE]ACM+[F:RDE]CPY;VALDETAAS : # accès valeur déterminant
    If fstat=0
      J = find("ACCCOD",[F:RVA]RUBRAS(0..[F:RDE]NBRUB0-1))
      RACCCOD = [F:RVA]VALDETEAS(J-1)
      If RACCCOD <> ""
        RFRCFLG = [F:RDE]FRCFLG(I-1)
      Endif
    Endif
  Endif
Endif

End
#########################################################################################################
Subprog DETER_VAL_NEW_PLAN_F(PCPY, PFAM, PACCCOD, PPLAN, RDPM, RDUR, RRAT, RRAT2, RALW,RVEH, RPRA, RACL, RERROR)
# Pour un plan, à partir d'une valeur de famille comptable et d'une valeur de code comptable,
# récupération des rubriques déterminées par le paramétrage par défaut
Value    Char    PCPY           : # Société
Value    Char    PFAM           : # Famille comptable
Value    Char    PACCCOD        : # Code comptable
Value    Integer PPLAN          : # Plan à traiter
# Rend :
Variable Char    RDPM           : # Mode d'amortissement
Variable Decimal RDUR           : # Durée d'amortissement
Variable Decimal RRAT           : # Taux d'amortissement
Variable Decimal RRAT2          : # Taux d'amortissement exceptionnel
Variable Integer RALW           : # Règle particulière
Variable Char    RVEH           : # Code plafond véhicule
Variable Integer RPRA           : # Type prorata temporis
Variable Decimal RACL           : # coefficients d'accélèration
Variable Integer RERROR         : # Code retour (0 : OK, 1 : KO)
# -------------------------------------------------------------------------------------------------------
#########################################################################################################
RERROR  = 1

Local Integer LPLAN
Local Char    LDPM
Local Decimal LDUR
Local Decimal LRAT
Local Decimal LRAT2
Local Integer LALW
Local Char    LVEH
Local Integer LPRA
Local Decimal LACL

LPLAN = PPLAN

Call DETER_VAL_PLANS("", PFAM, PACCCOD, LPLAN, LDPM, LDUR, LRAT, LRAT2, LALW, LVEH, LPRA, LACL, LUPDFLG)

RDPM    = LDPM
RDUR    = LDUR
RRAT    = LRAT
RRAT2   = LRAT2
RALW    = LALW
RVEH    = LVEH
RERROR  = 0

End
#########################################################################################################
Subprog DETER_VAL_PLANS_F(PCPY, PFAM, PACCCOD, PPLAN, RDPM, RDPRDUR, RDPRRAT, RDPRRAT2, RALWCOD, RCRBVEHCOD, RPRATYP, RACLCOE)
# A partir d'un tableau de plans, d'une société, d'une valeur de famille comptable et d'une valeur de code
# comptable, récupération de 6 tableaux dont les éléments sont triés dans l'ordre des plans
Value    Char    PCPY           : # société
Value    Char    PFAM           : # famille comptable
Value    Char    PACCCOD        : # code comptable
Value    Integer PPLAN()        : # tableau des plans à traiter
# Rend :
Variable Char    RDPM         : #  modes d'amortissement
Variable Decimal RDPRDUR      : #  durées d'amortissement
Variable Decimal RDPRRAT      : # taux d'amortissement
Variable Decimal RDPRRAT2     : # taux d'amortissement exceptionnels
Variable Integer RALWCOD      : #  règles particulières
Variable Char    RCRBVEHCOD   : # codes plafond véhicule
Variable Integer RPRATYP()    : # tableau des Type prorata temporis
Variable Decimal RACLCOE()    : # tableau des coefficients d'accélèration

# -------------------------------------------------------------------------------------------------------
#########################################################################################################

Local Integer LDETAAS
Local Integer LTROUVE
Local Char    LCPY
Local Char    LCRITERE (250)
Local Char    LVALDET
Local Char    LVARIAB
Local Integer OK, I, J, K

K=find(0,PPLAN)

Raz RDPM, RDPRDUR, RDPRRAT, RALWCOD, RCRBVEHCOD, RPRATYP, RACLCOE

If clalev([F:RDP])=0      :       Local File RUBASSDEFP [RDP]     : Endif
If clalev([F:RVP])=0      :       Local File RUBASSVALP [RVP]     : Endif

If PFAM <> ""
  LDETAAS = GVML_DTAFAM
  LVALDET = PFAM
  Gosub ASSO_PLAN_F
Endif

If !OK & PACCCOD <> ""
  LDETAAS = GVML_DTACCO
  LVALDET = PACCCOD
  Gosub ASSO_PLAN_F
Endif

End
# -------------------------------------------------------------------------------------------------------
$ASSO_PLAN_F
LCPY=PCPY
LCRITERE="REFOBJ=GVML_OMBIEN & DETAAS=LDETAAS & CPY=LCPY & ENAFLG=G_OUI"
Raz LTROUVE

Repeat
  For [RDP]RDP0 Where evalue(LCRITERE)
    LTROUVE = 1
    J = find([F:RDP]DPRPLN,PPLAN)
    If J & find(G_OUI,[F:RDP]MGTFLGP(0..[F:RDP]NBRUBP-1) )
      Read [RVP]RVP0=num$(GVML_OMBIEN)+num$(LDETAAS)+[F:RDP]ACM+[F:RDP]CPY;LVALDET;[F:RDP]DPRPLN
      If !fstat
        For I = 0 To [F:RDP]NBRUBP-1
          If [F:RDP]MGTFLGP(I) = G_OUI  & [F:RDP]FRCFLGP(I) = G_OUI
            LVARIAB = "R"+[F:RDP]RUBRASP(I)
            Assign LVARIAB+"("+num$(J-1)+")" With evalue("[F:RVP]"+[F:RDP]RUBRASP(I))
          Endif
        Next
      Endif
    Endif
  Next
  If LCPY <> "" & !LTROUVE : # Rien trouvé sur le paramétrage société,
    LCPY = ""              : # on ré-essaye avec le paramétrage par défaut
  Else
    Break                  : # sinon on s'en va
  Endif
Until LTROUVE
Return
###############################################################################
#Fq-88454 Subprog RUBRIQUES_DETERMINEES_PMR (POBJ, PCPY, PDETAAS, PPLAN, PMSK, RLIGNE)
Subprog RUBRIQUES_DETERMINEES_PMR (POBJ, PCPY, PDETAAS, PPLAN, PMSK, RLIGNE)
# Activation des rubriques déterminées par association pour chaque plan
# en fonction du (ou des) jeu(x) d'association applicable(s) - flags géré & modifiable
# UTILISE DANS MODIF_REDUITE de SUBFAS
Value Integer POBJ    : # Objet métier (suivant valeur du ML 341)
Value Char    PCPY    : # Société
Value Integer PPLAN   : # Plan à traiter
Value Char    PDETAAS : # Déterminant
Value Char    PMSK    : # Masque traité                      #*Fq-88454
Value Integer RLIGNE  : # Ligne de l'écran FAS3 à traiter
#------------------------------------------------------------------------------
###############################################################################

Local Char    LCPY
Local Integer LPLN
Local Integer LINDICE
Local Char    LCRITERP(250)
Local Integer LDETAAS
Local Integer LTROUVE
Local Integer LFIN
Local Integer I, MA
Local Char    WINPROG

Case PDETAAS
  When "FAM"   : LDETAAS=GVML_DTAFAM
  When "COD"   : LDETAAS=GVML_DTACCO
  When Default
Endcase

# récupération de la liste des masques et de leurs abréviations
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

LFIN=0
LCPY=PCPY
LPLN = PPLAN
LINDICE = RLIGNE

If clalev([F:RDP])=0  : Local File RUBASSDEFP  [RDP] : Endif : # Associations - définition

Local Char    LACM
Read [CPY]CPY0=CPY
If fstat=0
   LACM=[F:CPY]ACM
Endif
#***
#*** pour les rubriques déterminées/plan
#***
Read[RDP]RDP0= POBJ;LDETAAS;LACM;LCPY;LPLN
If fstat <> 0
  LCPY= ""
  Read[RDP]RDP0= POBJ;LDETAAS;LACM;LCPY;LPLN
  If fstat <> 0
    LTROUVE=0
  End
  Endif
Else
  LTROUVE+=1
  Gosub ACTZO_DISZO_PMR
Endif

End
#----------------------------------------------------------------------------------------------------
$ACTZO_DISZO_PMR

## Activationdes rubriques déterminées de l'objet métier
#For J=0 To dim([F:RDP]RUBRASP)-1
# If [F:RDP]RUBRASP(J)<>""
#  If evalue("dim([M]"+[F:RDP]RUBRASP(J)+") > 0")                    # le champ est sur 1 des écrans
#   If [F:RDP]MGTFLGP(J)=G_OUI & [F:RDP]UPDFLGP(J)=G_NON             # le champ doit être disable
#     # il est disable
#     If func GLOBIENS.IS_CHAMP_ENABLE (("[M:FAS3]"+[F:RDP]RUBRASP(J)+"("+num$(LINDICE-1)+")"), LINDICE-1) = G_OUI
#     For MA=1 To NBMASK
#      If evalue("dim([M:"+ABMSK(MA)+"]"+[F:RDP]RUBRASP(J)+") > 0")
#        Call ACTDISZO_P(ABMSK(MA),[F:RDP]RUBRASP(J),LINDICE, ACB_DISZO)
#        Break
#      Endif
#     Next
#    Endif
#   # Désactivation des rubriques déterminées de l'objet métier : annulée pour MODIF_REDUITE
#   Endif
#  Endif
# Else                  : # on a traité toutes les rubriques déterminées
#  Break
# Endif
#Next

# Activation/Désactivation  des rubriques déterminées de l'objet métier
For J=0 To dim([F:RDP]RUBRASP)-1
  If [F:RDP]RUBRASP(J)<>""
    If evalue("dim([M:"+PMSK+"]"+[F:RDP]RUBRASP(J)+") > 0")       # le champ est sur l'écran
      If [F:RDP]MGTFLGP(J)=G_OUI
        If  [F:RDP]UPDFLGP(J) <> G_OUI                          # le champ doit être disable
          # Désactivation  des rubriques déterminées de l'objet métier
          If func GLOBIENS.IS_CHAMP_ENABLE (("[M:FAS3]"+[F:RDP]RUBRASP(J)+"("+num$(LINDICE-1)+")"), LINDICE-1) = G_OUI
            #*Fq-88454 For MA=1 To NBMASK
            ABMSK(MA)=PMSK
            If evalue("dim([M:"+PMSK+"]"+[F:RDP]RUBRASP(J)+") > 0")
              Call ACTDISZO_P(PMSK,[F:RDP]RUBRASP(J),LINDICE, ACB_DISZO)
            Endif
          Endif
#*FQ102491Else                                   # le champ doit être enable
#*FQ102491  # Activation des rubriques déterminées de l'objet métier
#*FQ102491  If func GLOBIENS.IS_CHAMP_ENABLE (("[M:FAS3]"+[F:RDP]RUBRASP(J)+"("+num$(LINDICE-1)+")"), LINDICE-1) <> G_OUI
#*FQ102491    ABMSK(MA)=PMSK
#*FQ102491    If evalue("dim([M:"+PMSK+"]"+[F:RDP]RUBRASP(J)+") > 0")
#*FQ102491      Call ACTDISZO_P(PMSK,[F:RDP]RUBRASP(J),LINDICE, ACB_ACTZO)
#*FQ102491    Endif
        Endif
      Endif
    Endif
  Else                  : # on a traité toutes les rubriques déterminées
    Break
  Endif
Next

Return

