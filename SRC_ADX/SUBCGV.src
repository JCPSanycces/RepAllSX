#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du masque CHGVAL

##########################################################################
## Etiquette ajoutée par le superviseur 12/05/2003 11:55:22 (CCC)
##########################################################################
$ACTION
Case ACTION
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "DEBUT"       : Gosub DEBUT
    When "ABA"         : Gosub ABA
    When "SETBOUT"     : Gosub SETBOUT
    When "EDI"         : Gosub IMP
    When "OK"          : Gosub OK
    When "FIN"         : Gosub FIN
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When Default
Endcase
Return

#------------------------------------------------------------------------#
#                        ACTIONS                                         #
#------------------------------------------------------------------------#

#############################################################
# Sélection du code pièce auto
#############################################################
$SEL_TABLE
Case COUZON
  When "ENTCOD"
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return

##########################################################################
$OUVRE_BOITE
Local Integer LRET
    If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
    If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
    If !clalev([F:ITV]) : Local File ITMMVT     [ITV] : Endif
    If !clalev([F:STO]) : Local File STOCK      [STO] : Endif
    If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
    If !clalev([F:STP]) : Local File STOCOST    [STP] : Endif
    If !clalev([F:STL]) : Local File STOLOT     [STL] : Endif
    If !clalev([F:SLF]) : Local File STOLOTFCY  [SLF] : Endif
    If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
    If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
    If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif  # 116166/112688.n

    Global Integer GCGVRELOAD      # 0=Pas de rechargement sur contrôle de l'article
    Global Integer GCGVMODIF    # 1=Modif valeur globale; 2=Modif pile FIFO; 3=Modif valeurs lots

    Call CTRCPT(GSTKCPT(21),type([F:STJ]VCRNUM), LRET) From STKLIB
    If LRET<>0
        GMESSAGE = mess(115,184,1)
        GERR = 1
        FIN  = 1
        Return
    Endif

    #----- Sauvegarde variables globales -----#
    Gosub SAUV_GLOB From TRTX3GLOB

Return

##########################################################################
$DEBUT
    Raz [M:CGV]
    Actzo [M:CGV]
    [M:CGV]CCECODS = 1
    Call STKASFCY([M:CGV]STOFCY) From STKACT
    # Issue 76083 - 2011-09-16 by CCC : initialisation des variables globales nécessaires aux sections analytiques
    #----- Chargement des globales référenciels, comptes et sections de la société -----#
    GFCY=[M:CGV]STOFCY
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT
    Call GETDEV([M:CGV]STOFCY) From DEVSUB
Return

##########################################################################
$ABA
    Call CHARG_CGV([M:CGV]STOFCY, [M:CGV]ITMREF) From SUBCGVB
    Affzo [M:CGV]
Return

##########################################################################
$FIN
    Kill GCGVRELOAD
    Kill GCGVMODIF

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
Return

##########################################################################
$OK
    # Positionne GMESSAGE et GERR en cas d'erreur
    Gosub CTR_ENR_CGV From SUBCGVB
    If GMESSAGE=""
        Gosub ENR_CGV From SUBCGVB
        Call CHARG_CGV([M:CGV]STOFCY, [M:CGV]ITMREF)  From SUBCGVB
        Affzo [M:CGV]
    Endif
    FIN=0
Return

##########################################################################
$SETBOUT
    CHBOU += "AI"
    Gosub SET_BOUT_STD From GSAISIE
Return

$IMP
  Call PRTSCR("CHGVAL","CGV","",0,0) From ATRTX3
  Call IMPSCR From ATRTX3
Return

#------------------------------------------------------------------------#
#                        ACTIONS CHAMPS                                  #
#------------------------------------------------------------------------#

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

    # Issue 76083 - 2011-09-16 by CCC : initialisation des variables globales nécessaires aux sections analytiques
    #----- Chargement des globales référenciels, comptes et sections de la société -----#
    GFCY=VALEUR
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT

    Call GETDEV(VALEUR) From DEVSUB
    GCGVRELOAD = 1
    Call INITCCE
End

##########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>[M:CGV]ITMREF | GCGVRELOAD
        Call CHARG_CGV([M:CGV]STOFCY, VALEUR)  From SUBCGVB
        If !mkstat
            Affzo [M:CGV]
            GCGVRELOAD = 0
        Else
            GCGVRELOAD = 1
        Endif
    Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/08/2004 08:45:52 (CCC)
##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

    Call INITCCE

End

##########################################################################
Subprog AM_AVCBASAMT(VALEUR)
Variable Decimal VALEUR
    If !GCGVMODIF
        Diszo [M:CGV]15-20
        GCGVMODIF = 1
    Endif
    If [M:CGV]BASAMTORI<>0
        [M:CGV]PERDEP = arr((VALEUR-[M:CGV]BASAMTORI)*100/[M:CGV]BASAMTORI,0.000001)
        Affzo [M:CGV]PERDEP
    Else
        [M:CGV]PERDEP = 0
        Diszo [M:CGV]PERDEP
    Endif
    [M:CGV]AVC = VALEUR / [M:CGV]AVCBASQTY
    Affzo [M:CGV]AVC
End

##########################################################################
Subprog AM_PERDEP(VALEUR)
Variable Decimal VALEUR
    [M:CGV]AVCBASAMT = arr((1+VALEUR/100)*[M:CGV]BASAMTORI,0.000001)

    If !GCGVMODIF
        Diszo [M:CGV]15-20
        GCGVMODIF = 1
    Endif
    [M:CGV]AVC = [M:CGV]AVCBASAMT / [M:CGV]AVCBASQTY
    Affzo [M:CGV]AVCBASAMT,AVC
End

#------------------------------------------------------------------------#
#--------------------- Tableau pile FIFO --------------------------------#
#------------------------------------------------------------------------#

##########################################################################
Subprog C_NBFIFO
    If find(status,65,68)
        [M:CGV]CSTCOUDEL([M:CGV]NBDEL) = [M:CGV]CSTCOU(nolign-1)
        [M:CGV]NBDEL += 1
        Raz [M:CGV]QTYSTUACT(nolign-1),[M:CGV]CST(nolign-1)    # Pour les calculs qui suivent
        Call APMODFIFO
    Endif
End

##########################################################################
Subprog APRES_NBFIFO
    If adxgtb=1
        End
    Endif
    If  [M:CGV]QTYSTUACT(nolign-1)<>[M:CGV]QTYSTUORI(nolign-1)
&     | [M:CGV]CST(nolign-1)   <>[M:CGV]CSTORI(nolign-1)

        [M:CGV]FIFOFLG(nolign-1) = 2
    Else
        [M:CGV]FIFOFLG(nolign-1) = 1
    Endif
    If [M:CGV]QTYSTUORI(nolign-1)=0
        [M:CGV]VCRTYPP(nolign-1) = 30
        Affzo [M:CGV]VCRTYPP(nolign-1)
    Endif
    Affzo [M:CGV]CST(nolign-1), QTYSTUACT(nolign-1), AVCCST(nolign-1)
    Call APMODFIFO
End

Subprog APMODFIFO
    Call MODIF(2) From SUBCGVB
    [M:CGV]QTYTOTCST = sum([M:CGV]QTYSTUACT)
    [M:CGV]DIFQTYCST = [M:CGV]QTYTOTCST-[M:CGV]AVCBASQTY
    [M:CGV]AMTTOTCST = sum([M:CGV]CST)
    If [M:CGV]QTYTOTCST>0
        [M:CGV]PRICST    = [M:CGV]AMTTOTCST / [M:CGV]QTYTOTCST
    Else
        [M:CGV]PRICST    = 0
    Endif
    Affzo [M:CGV]QTYTOTCST, DIFQTYCST, AMTTOTCST, PRICST
End

##########################################################################
Subprog AV_CST(VALEUR)
Variable Decimal VALEUR
    If  [M:CGV]QTYSTUACT(nolign-1)<>[M:CGV]QTYSTUORI(nolign-1)
&     | [M:CGV]CST(nolign-1)   <>[M:CGV]CSTORI(nolign-1)
        pcolor = GCOUL(1)
    Else
        pcolor = GCOUL(0)
    Endif
End

##########################################################################
Subprog AM_CST(VALEUR)
Variable Decimal VALEUR
    If [M:CGV]QTYSTUACT(nolign-1)<>0
        [M:CGV]AVCCST(nolign-1) = arr(VALEUR/[M:CGV]QTYSTUACT(nolign-1),0.000001)
        Affzo [M:CGV]AVCCST(nolign-1)
    Endif
End

##########################################################################
Subprog AV_QTYSTUACT(VALEUR)
Variable Decimal VALEUR
    If  [M:CGV]QTYSTUACT(nolign-1)<>[M:CGV]QTYSTUORI(nolign-1)
&     | [M:CGV]CST(nolign-1)   <>[M:CGV]CSTORI(nolign-1)
        pcolor = GCOUL(1)
    Else
        pcolor = GCOUL(0)
    Endif
End

##########################################################################
Subprog AM_QTYSTUACT(VALEUR)
Variable Decimal VALEUR
    If VALEUR>0
        [M:CGV]AVCCST(nolign-1) = arr([M:CGV]CST(nolign-1)/VALEUR,0.000001)
        Affzo [M:CGV]AVCCST(nolign-1)
    Elsif VALEUR<0
        mkstat = 2
    Endif
End

##########################################################################
Subprog AV_AVCCST(VALEUR)
Variable Decimal VALEUR
    If  [M:CGV]QTYSTUACT(nolign-1)<>[M:CGV]QTYSTUORI(nolign-1)
&     | [M:CGV]CST(nolign-1)   <>[M:CGV]CSTORI(nolign-1)
        pcolor = GCOUL(1)
    Else
        pcolor = GCOUL(0)
    Endif
End

##########################################################################
Subprog AM_AVCCST(VALEUR)
Variable Decimal VALEUR
    [M:CGV]CST(nolign-1) = arr(VALEUR*[M:CGV]QTYSTUACT(nolign-1),0.000001)
    Affzo [M:CGV]CST(nolign-1)
End

#------------------------------------------------------------------------#
#--------------------- Tableau des lots ---------------------------------#
#------------------------------------------------------------------------#

##########################################################################
Subprog APRES_NBLOT
    If  [M:CGV]LOTCST(nolign-1) <> [M:CGV]LOTCSTORI(nolign-1)
        [M:CGV]LOTFLG(nolign-1)=2
    Else
        [M:CGV]LOTFLG(nolign-1)=1
    Endif
    Call MODIF(3) From SUBCGVB
    Affzo [M:CGV]LOTCST(nolign-1), LOTAVC(nolign-1)
    [M:CGV]AMTTOTLOT = sum([M:CGV]LOTCST)
    Affzo [M:CGV]AMTTOTLOT
End

##########################################################################
Subprog AV_LOTCST(VALEUR)
Variable Decimal VALEUR
    If  [M:CGV]LOTCST(nolign-1) <> [M:CGV]LOTCSTORI(nolign-1)
        pcolor = GCOUL(1)
    Else
        pcolor = GCOUL(0)
    Endif
End

##########################################################################
Subprog AM_LOTCST(VALEUR)
Variable Decimal VALEUR
    [M:CGV]LOTAVC(nolign-1) = arr(VALEUR/[M:CGV]LOTQTYACT(nolign-1),0.000001)
    Affzo [M:CGV]LOTAVC(nolign-1)
End

##########################################################################
Subprog AV_LOTAVC(VALEUR)
Variable Decimal VALEUR
    If  [M:CGV]LOTCST(nolign-1) <> [M:CGV]LOTCSTORI(nolign-1)
        pcolor = GCOUL(1)
    Else
        pcolor = GCOUL(0)
    Endif
End

##########################################################################
Subprog AM_LOTAVC(VALEUR)
Variable Decimal VALEUR
    [M:CGV]LOTCST(nolign-1) = arr(VALEUR*[M:CGV]LOTQTYACT(nolign-1),0.000001)
    Affzo [M:CGV]LOTCST(nolign-1)
End


##########################################################################


##########################################################################

Subprog INITCCE
Local Integer I
Local Char    LSEC(GLONCCE)

    For I=1 To GOPTCANA
        If dim([M:CGV]CCE)>I-1
            Call INISEC (LSEC, "STJVAL", I) From TRTX3CPT
            [M:CGV]CCE(I-1) = LSEC
        Else
            Break
        Endif
    Next
End

##########################################################################

