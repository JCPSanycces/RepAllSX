#################################################################################
# Table structure with old and new fields                                       #
#################################################################################
Subprog AMAJ

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ70 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

# Issue 116422 - 2016-05-20 by CCC : Delete wrong records in TABBOMALT
Call UTI_MOUL([F:ADS]DOSSIER) From UTITC71

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

