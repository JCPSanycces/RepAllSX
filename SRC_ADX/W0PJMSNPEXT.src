#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNPEXT 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ALLCPY
mkstat = 0
zoncou = "ALLCPY"
indice = 0
IMPENT = [M]ALLCPY
If varinit([M]ALLCPY,indice)=0
 IMPENT = 1
Endif
If varmode([M]ALLCPY,indice)=0
 [M]ALLCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLCPY(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ALLCPY(IMPENT) From PJMSNPEXT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLCPY" : GZNUM = 6052 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLCPY = IMPENT

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ALLSNP
mkstat = 0
zoncou = "ALLSNP"
indice = 0
IMPENT = [M]ALLSNP
If varinit([M]ALLSNP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ALLSNP,indice)=0
 [M]ALLSNP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLSNP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLSNP(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ALLSNP(IMPENT) From PJMSNPEXT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLSNP" : GZNUM = 1003642 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLSNP = IMPENT

## Zone SNPCODF
mkstat = 0
zoncou = "SNPCODF"
indice = 0
WCHAR = [M]SNPCODF
If varmode([M]SNPCODF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SNPCODF" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]SNPCODF or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_SNPCODF([M]SNPCODF) From PJMSNPEXT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SNPCODF" : GZNUM = 1003640 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SNPCODT
mkstat = 0
zoncou = "SNPCODT"
indice = 0
If varmode([M]SNPCODT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SNPCODT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ALLPRJ
mkstat = 0
zoncou = "ALLPRJ"
indice = 0
IMPENT = [M]ALLPRJ
If varinit([M]ALLPRJ,indice)=0
 IMPENT = 1
Endif
If varmode([M]ALLPRJ,indice)=0
 [M]ALLPRJ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLPRJ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLPRJ(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ALLPRJ(IMPENT) From PJMSNPEXT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLPRJ" : GZNUM = 33868 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLPRJ = IMPENT

## Zone OPPNUMF
mkstat = 0
zoncou = "OPPNUMF"
indice = 0
WCHAR = [M]OPPNUMF
If varmode([M]OPPNUMF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUMF" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PIM","!A",[M]OPPNUMF,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUMF" : GZNUM = 51313 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]OPPNUMF or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPPNUMF([M]OPPNUMF) From PJMSNPEXT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPPNUMF" : GZNUM = 51313 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OPPNUMT
mkstat = 0
zoncou = "OPPNUMT"
indice = 0
If varmode([M]OPPNUMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUMT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PIM","!A",[M]OPPNUMT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUMT" : GZNUM = 51314 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LCHDPRJ
mkstat = 0
zoncou = "LCHDPRJ"
indice = 0
IMPENT = [M]LCHDPRJ
If varinit([M]LCHDPRJ,indice)=0
 IMPENT = 1
Endif
If varmode([M]LCHDPRJ,indice)=0
 [M]LCHDPRJ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LCHDPRJ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LCHDPRJ(indice)
 Endif
Endif
[M]LCHDPRJ = IMPENT

## Zone CLSDPRJ
mkstat = 0
zoncou = "CLSDPRJ"
indice = 0
IMPENT = [M]CLSDPRJ
If varinit([M]CLSDPRJ,indice)=0
 IMPENT = 1
Endif
If varmode([M]CLSDPRJ,indice)=0
 [M]CLSDPRJ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLSDPRJ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CLSDPRJ(indice)
 Endif
Endif
[M]CLSDPRJ = IMPENT

## Zone LOGFILE
mkstat = 0
zoncou = "LOGFILE"
indice = 0
IMPENT = [M]LOGFILE
If varinit([M]LOGFILE,indice)=0
 IMPENT = 1
Endif
If varmode([M]LOGFILE,indice)=0
 [M]LOGFILE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LOGFILE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LOGFILE(indice)
 Endif
Endif
[M]LOGFILE = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMSNPEXT"
Return

