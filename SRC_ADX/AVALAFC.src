#<AdxTL>@(#)7.0.0.0 $Revision$
Call VALIDATION(GBIDC1)
End

Subprog VALIDATION(APPLI)
Value Char APPLI
Local Char PARAM(250)(1..1) , VALEUR(10)
PARAM(1) = APPLI
Call TRAITE_CHAR(VALEUR,PARAM,"","AVALAFC","",2,"XYAVALAFC") From GTRAITE
End

#####################################
$ACTION
Case ACTION
 When "EXEC"      : Gosub EXEC
 # Issue 82875 - 2012-06-18 by VPO
 #When "AVANT_PAR" : TIT = mess(68,126,1) : # Validation des fonctions
 #
 #96435
 ## Resynchronisation des profils fonction site
 ##
 ## Cette opération peut être longue car elle traite tous les profil/fonction/site du dossier
 ## Resynchronisation des profils fonction site
 ## Voulez-vous continuer ?
 When "AVANT_PAR" : TIT = mess(258,126,1)+"\\"+mess(276,126,1)+"\"+mess(205,100,1)
Endcase
Return

#####################################
$EXEC
Local Char APPLI(250)
APPLI = PARAM(1)
If APPLI=""
 APPLI = nomap
Endif
Call VALFCT(APPLI)
Return

Subprog VALFCT(APPLI)
Value Char APPLI
If APPLI=nomap
 If clalev([F:AFT])   = 0 : Local File AFCTFCT   [AFT]  : Endif
 If clalev([F:AFF])   = 0 : Local File AFCTFCY   [AFF]  : Endif
 If clalev([F:AFC])   = 0 : Local File AFONCTION [AFC]  : Endif
 If clalev([F:FCY])   = 0 : Local File FACILITY  [FCY]  : Endif
 If clalev([F:AFP1])  = 0 : Local File AFCTPRF   [AFP1] : Endif
 If clalev([F:AGF])   = 0 : Local File AGRPFCY   [AGF]  : Endif
Else
 If clalev([F:AFT])   = 0 : Local File =APPLI+".AFCTFCT"   [AFT]  : Endif
 If clalev([F:AFF])   = 0 : Local File =APPLI+".AFCTFCY"   [AFF]  : Endif
 If clalev([F:AFC])   = 0 : Local File =APPLI+".AFONCTION" [AFC]  : Endif
 If clalev([F:FCY])   = 0 : Local File =APPLI+".FACILITY"  [FCY]  : Endif
 If clalev([F:AFP1])  = 0 : Local File =APPLI+".AFCTPRF"   [AFP1] : Endif
 If clalev([F:AGF])   = 0 : Local File =APPLI+".AGRPFCY"   [AGF]  : Endif
Endif

Gosub MENAGE

Call MAJAFF2("") From SUBAFP1

If APPLI=nomap
 If clalev([F:FGRA])  = 0 : Local File FACGROUP  [FGRA] : Endif
Else
 If clalev([F:FGRA])  = 0 : Local File =APPLI+".FACGROUP"  [FGRA] : Endif
Endif

Call MAJAFF("") From SUBAFP1

End

$MENAGE
If !GSERVEUR & !GINFO
 # Remise à zéro en cours
 Call OUVRE_VLC(mess(149,124,1),"","") From GESECRAN
Endif
Call DEBTRANS From GLOCK
Gosub TR_MENAGE
If !GSERVEUR & !GINFO
 Call FERME_VLC From GESECRAN
Endif
Return

$TR_MENAGE
Local Integer OK
Trbegin [AFF]
 Delete [AFF] Where 1=1
 For [AFP1]AFP0
  OK = 1
  Look [AFT]AFT0=[F:AFP1]PRFCOD
  If fstat
   OK = 0
  Else
   Look [AFC]CODINT=[F:AFP1]FNC
   If fstat
    OK = 0
   Elsif [F:AFP1]FCYGRU<>""
    Case [F:AFP1]FCYGRUCOD
     When 1 : # Regroupement
      Look [AGF]AGF0=[F:AFP1]FCYGRU
      If fstat : OK = 0 : Endif
     When 2 : # Site
      Look [FCY]FCY0=[F:AFP1]FCYGRU
      If fstat : OK = 0 : Endif
    Endcase
   Endif
  Endif
  If !OK
   Delete [AFP1] Curr
  Endif
 Next AFP1
Commit
Return
