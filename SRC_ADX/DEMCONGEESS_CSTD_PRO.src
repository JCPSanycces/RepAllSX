#STCAH - 2017-04-26 - REQUIREMENT nnn - US nnn
#Handling all properties for DEMCONGEESS_CSTD
############################################################################################################
$PROPERTIES
#Handling all  the property code in DEMCONGEESS_CSTD_PRO

Case [L]CURPRO
  When "REFNUM"                     : Gosub DEMCONGEESS_REFNUM
  When "TCH_EMPSBD"                 : Gosub DEMCONGEESS_TCH_EMPSBD
  When "STRDAT"                     : Gosub DEMCONGEESS_STRDAT      # starting date
  When "STRDAY"                     : Gosub DEMCONGEESS_STRDAY      # morning
  When "ENDDAT"                     : Gosub DEMCONGEESS_ENDDAT      # ending date
  When "ENDDAY"                     : Gosub DEMCONGEESS_ENDDAY      # afternoon
  When "CTRNUM"                     : Gosub DEMCONGEESS_CTRNUM
  When "NBRDAY"                     : Gosub DEMCONGEESS_NBRDAY
  When "NBRHOU"                     : Gosub DEMCONGEESS_NBRHOU
  When "TIM"                        : Gosub DEMCONGEESS_TIM
  When "CMT"                        : Gosub DEMCONGEESS_CMT
  When "RPL"                        : Gosub DEMCONGEESS_RPL
  When "TYPPGN"                     : Gosub DEMCONGEESS_TYPPGN
  When "STA"                        : Gosub DEMCONGEESS_STA
  When "WRK"                        : Gosub DEMCONGEESS_WRK
  When "CMT2"                       : Gosub DEMCONGEESS_CMT2
  When "ESSATT.NUMLIG"              : Gosub DEMCONGEESS_ESSATT_NUMLIG
  When "LVERSN"                     : Gosub DEMCONGEESS_LVERSN #FRLAA 2018-02-27 X3-74480
  When "LVENOT"                     : Gosub DEMCONGEESS_LVENOT #FRLAA 2018-02-27 X3-74480
  When "TCH_BALDAT"                 : Gosub DEMCONGEESS_TCH_BALDAT #FRLAA 2018-03-27 X3-79298
  When "TCH_BALACT"                 : Gosub DEMCONGEESS_TCH_BALACT #FRLAA 2018-04-12 X3-79298
  When "TCH_BALCTR"                 : Gosub DEMCONGEESS_TCH_BALCTR #FRLAA 2018-04-12 X3-79298
  When "UID"                        : Gosub DEMCONGEESS_UID
  When "DEM"                        : Gosub DEMCONGEESS_DEM
Endcase

Return

############################################################################################################
$DEMCONGEESS_REFNUM
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_REFNUM_INIT
  When "CONTROL"
    Gosub DEMCONGEESS_REFNUM_CONTROL
  When "PROPAGATE"
    Gosub DEMCONGEESS_REFNUM_PROPAGATE
Endcase
Return
#---------------------------
$DEMCONGEESS_REFNUM_INIT



Gosub DEMCONGEESS_REFNUM_INIT From DEMCONGE_CSTD_PRO

Return
#---------------------------
$DEMCONGEESS_REFNUM_CONTROL

Gosub DEMCONGEESS_REFNUM_CONTROL From DEMCONGE_CSTD_PRO

Return
#---------------------------
$DEMCONGEESS_REFNUM_PROPAGATE

#Set technical properties - DEMCONEESS Only
Local File EMPLOID [ID4]
Read [ID4]ID0 = this.REFNUM
If fstat = [V]CST_AOK
  this.TCH_NAMSRN= toupper([F:ID4]NAM)-tolower([F:ID4]SRN)
Endif

#FRLAA 2018-03-27 X3-79298 - START
If func AFNC.ACTIV("GLM")>0
  this.TCH_BALEML = this.REFNUM
Endif
#FRLAA 2018-03-27 X3-79298 - END

Gosub DEMCONGEESS_REFNUM_PROPAGATE From DEMCONGE_CSTD_PRO

Return
############################################################################################################
$DEMCONGEESS_ESSATT_NUMLIG
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_ESSATT_NUMLIG_INIT
Endcase
Return
#---------------------------
$DEMCONGEESS_ESSATT_NUMLIG_INIT
  Local Integer CURNUM : CURNUM = maxtab(this.APARENT.ESSATT)
  this.NUMLIG = CURNUM
Return
