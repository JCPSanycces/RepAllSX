#FRLAA 2018-03-27 X3-79298 - START
$DEMCONGEESS_TCH_BALDAT
Case [L]ARULE
  When "PROPAGATE"
    Gosub DEMCONGEESS_TCH_BALDAT_PROPAGATE
Endcase
Return

$DEMCONGEESS_TCH_BALDAT_PROPAGATE
  If clalev([HRCTR3]) = 0 : Local File EMPLOCTR[HRCTR3] : Endif
  If clalev([FCY]) = 0 : Local File FACILITY[FCY] : Endif
  Link [HRCTR3]
&   With [FCY]FCY0=ETRFCY
&   As [LNK]
&   Where REFNUM=this.TCH_BALEML
&       & (CTRDAT<=this.TCH_BALDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&       & (XITDAT=[0/0/0] | XITDAT>=this.TCH_BALDAT)
&       & (CTRDAT<=this.TCH_BALDAT) & [FCY]LEG=this.TCH_LEG


  Filter [LNK]
  Read [LNK] First
  If rowcount([LNK])=1
    this.TCH_BALCTR = [F:HRCTR3]CTRNUM
    this.TCH_BALDTR = [F:HRCTR3]CTRDAT
  Endif
  LogicClose File [HRCTR3]
  LogicClose File [FCY]
Return
#FRLAA 2018-03-27 X3-79298 - END

#FRLAA 2018-04-12 X3-79298 - START
$DEMCONGEESS_TCH_BALACT
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_TCH_BALACT_INIT
Endcase
Return

$DEMCONGEESS_TCH_BALACT_INIT
this.TCH_BALACT = 2
Return


$DEMCONGEESS_TCH_BALCTR
Case [L]ARULE
  When "PROPAGATE"
    Gosub DEMCONGEESS_TCH_BALCTR_PROPAGATE
Endcase
Return

$DEMCONGEESS_TCH_BALCTR_PROPAGATE
#Set the legislation field
Local File EMPLOCTR [HRCTR9]

  Filter [HRCTR9] Where REFNUM=this.TCH_BALEML & CTRNUM=this.TCH_BALCTR & (CTRDAT<=this.TCH_BALDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.TCH_BALDAT) Order By CTRDAT Desc

Read [HRCTR9] First
If fstat = [V]CST_AOK
  this.TCH_BALLEG = func DIVPAYE_SOA.GET_LEG_FCY([F:HRCTR9]ETRFCY,1)
Endif

Return


