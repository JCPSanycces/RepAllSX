$DEMCONGEESS_TCH_EMPSBD_PROPAGATE

Gosub DEMCONGEESS_TCH_EMPSBD_PROPAGATE From DEMCONGE_CSTD_PRO
#Set technical properties - DEMCONEESS Only
Local File EMPLOID [ID4]
Read [ID4]ID0 = this.TCH_EMPSBD
If fstat = [V]CST_AOK
  this.TCH_SBDSRN = toupper([F:ID4]NAM)-tolower([F:ID4]SRN)
Endif

Return


