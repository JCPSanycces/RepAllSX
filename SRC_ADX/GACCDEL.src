#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "ZZK"
Call TRAITE_CHAR(VALEUR,PARAM,"","GACCDEL","GACCDEL",3,"") From GTRAITE
End

########################################################################################################
# Be informed that this tool is not an efficient one. It should be used only during the folder creation.  
# We have decided to use the DELETE instruction instead of the Supervisor subprogram ANNULATION of process
# ANUCOD; due to the fact that the latter is really slow (There exists a lot of links between tables GCOA, GACCOUNT
# and all the tables that have to be deleted).
# Normally we shoudn't have links between tables as there are no data.
########################################################################################################

############################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "FIN"         : Gosub FIN
Endcase
Return

############################################
$INIT
#In order to have the Timing trace because it is a second-hand window
#Call ACTIVE From TIMING
Gosub OUVRE 
Return

############################################
$CONTROLE
#Msge non traduit encore
#Avez-vous bien pris connaissance des contraintes et limites de cet utilitaire ?
Call AVERTIR (mess(143,102,1),OK) From GESECRAN
If OK<>2 : FIN=1 : Endif
Return

############################################
$FIN
If !GSERVEUR & [M:DIA]TRC=2 
 TRA = 1
Else
 TRA = 0
Endif

If FIN : Return : Endif
#to have the Timing trace 
#Call LECTURE("/home1/runtime/tmp/KC.tra",1) From TIMING
Return

############################################
$EXEC
If GSERVEUR 
 [M:DIA]TRC = 2 
Endif
If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
#Keep "intitulé traduisible" of Chart of Accounts 
Call LECTEXTRA([L]DESCOA,"GCOA","DESTRA",[F:GAC]COA,"") From ATEXTRA 
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(mess(128,102,1)-[M:DIA]COA-[L]DESCOA,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Endif

#Check the access code if present in the chart of account
Call LECTURE("COA",[M:DIA]COA,"")From CONTOBJ
Call CONTEXE([F:COA]ACS)From CPTSUB
If mkstat
 # You do not have the execution rights
 Call ECR_TRACE([M:DIA]COA-GMESSAGE,1) From GESECRAN
 Return
Endif

#if access Ok , CRITERE is filled in.
CRITERE = 'COA = "'+[M:DIA]COA+'"' 

If [M:DIA]STRACC <> ""
 CRITERE -= '& ACC >= "'+[M:DIA]STRACC+'"'
Endif
If [M:DIA]ENDACC <> ""
 CRITERE -= '& ACC <= "'+ [M:DIA]ENDACC+'"'
Endif

Call DEBTRANS From GLOCK
Call TEMPON("S") From GESECRAN
Gosub TR1
Call TEMPOFF From GESECRAN

#Close file trace
If !GSERVEUR & [M:DIA]TRC=2 
 Call FERME_TRACE From LECFIC
Endif

Return

###############################################################

$OUVRE_BATCH
$OUVRE
Local Char    CRITERE(250),DESACC(30),DESCOA(30),TABNAM(30)
Local Char    ENTITE(GLONBPA)

#Non traduit encore
#Suppression comptes en masse
TIT = mess(136,102,1)
 
If clalev([F:COA])=0  : Local File GCOA      [COA]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT  [GAC]  : Endif
If clalev([F:GAC2])=0 : Local File GACCOUNT  [GAC2] : Endif
If clalev([F:BID])=0  : Local File BID       [BID]  : Endif
If clalev([F:BLA])=0  : Local File BALANA    [BLA]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE   [BAL]  : Endif
If clalev([F:BLM])=0  : Local File BLACMM    [BLM]  : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY    [BLQ]  : Endif
If clalev([F:BUD])=0  : Local File BUD       [BUD]  : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS [BPA]  : Endif   
If clalev([F:ATB])=0  : Local File ATABLE    [ATB]  : Endif 
If clalev([F:GRY])=0  : Local File GACCGRUPYM[GRY]  : Endif 
If clalev([F:GRY2])=0 : Local File GACCGRUPYM[GRY2] : Endif 
If clalev([F:GYK])=0  : Local File GACCPYMLIK[GYK]  : Endif 
If clalev([F:GYK2])=0 : Local File GACCPYMLIK[GYK2] : Endif 
If clalev([F:GYP])=0  : Local File GACCPYMPRT[GYP]  : Endif

#In case of Russia Localisation open this following table.
If filinfo(filpath("FIL","BALDEM","fde",0),0)>=0
 If clalev([F:BAM])  = 0 : Local File BALDEM [BAM] : Endif
 Endif
 
Return

#################################################################
$TR1
Trbegin [COA], [GAC], [GAC2]

 For [GAC]GAC0 Where evalue(CRITERE)
  #Keep the "intitulé traduisible" of account
  Call LECTEXTRA([L]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  #Check if accounts of LCOA could be deleted
  Gosub CONTROLES
  If OK 
   # Delete the Address, the Rib and the description associated to the account
   # deleted.
   Gosub DELTABLE
   # All is OK so go to delete the account.
   Delete [GAC2] Where COA=[F:GAC]COA & ACC=[F:GAC]ACC
   If fstat=1
    GOK = -1 : GLOCK = "$GACCOUNT"-[F:GAC2]COA-[F:GAC2]ACC
   Else
    # non traduit
    # mess = Suppression effectuée compte xxxx
    Call ECR_TRACE(mess(60,126,1)-mess(45,102,1)-[F:GAC2]ACC-[L]DESACC,0) From GESECRAN  
   Endif
  Else
   # Account present in one the balance or budget then do not delete
   Call ECR_TRACE(mess(144,102,1)-[F:GAC]ACC-[L]DESACC-mess(145,102,1)-MESSA,1) From GESECRAN
   MESSA=""
  Endif 
 Next
Commit
Return

#################################################################
$CONTROLES
OK=1
Gosub CONTBALANA
If !OK : Return 
Else
 Gosub CONTBALANCE
 If !OK : Return 
 Else 
  Gosub CONTBLACMM
  If !OK : Return 
  Else
   Gosub CONTBLAQTY
   If !OK : Return 
   Else
    Gosub CONTBUD
    If !OK : Return
    Else
     Gosub CONTBALDEM 
     If !OK : Return
     Endif
    Endif
   Endif
  Endif
 Endif    
Endif
Return

#################################################################
$CONTBALANA
Filter [BLA] Where [BLA]COA=[F:GAC]COA & [BLA]ACC=[F:GAC]ACC 
Read [BLA]BLA0 First
Filter [BLA]
If fstat=0 : OK=0 : MESSA="BALANA" : Return : Endif
Return

$CONTBALANCE
Filter [BAL] Where [BAL]COA=[F:GAC]COA & [BAL]ACC=[F:GAC]ACC 
Read [BAL]BAL0 First
Filter [BAL]
If fstat=0 : OK=0 : MESSA="BALANCE" : Return : Endif
Return

$CONTBALDEM
If filinfo(filpath("FIL","BALDEM","fde",0),0)>=0
 If clalev([F:BAM])  = 0 : Local File BALDEM [BAM] : Endif
 Filter [BAM] Where [BAM]COA=[F:GAC]COA & [BAM]DEBACC=[F:GAC]ACC 
 Read [BAM]BAM0 First
 Filter [BAM]
 If fstat=0 : OK=0 : MESSA="BALDEM" : Return : Endif
 Filter [BAM] Where [BAM]COA=[F:GAC]COA & [BAM]CDTACC=[F:GAC]ACC 
 Read [BAM]BAM0 First
 Filter [BAM]
 If fstat=0 : OK=0 : MESSA="BALDEM" : Return : Endif
Endif
Return

$CONTBLACMM
Filter [BLM] Where [BLM]COA=[F:GAC]COA & [BLM]ACC=[F:GAC]ACC 
Read [BLM]BLM0 First
Filter [BLM]
If fstat=0 : OK=0 : MESSA="BLACMM" : Return : Endif
Return

$CONTBLAQTY
Filter [BLQ] Where [BLQ]COA=[F:GAC]COA & [BLQ]ACC=[F:GAC]ACC 
Read [BLQ]BLQ0 First
Filter [BLQ]
If fstat=0 : OK=0 : MESSA="BLAQTY" : Return : Endif
Return

$CONTBUD
Filter [BUD] Where [BUD]COA=[F:GAC]COA & [BUD]ACC=[F:GAC]ACC 
Read [BUD]BUD0 First
Filter [BUD]
If fstat=0 : OK=0 : MESSA="BUD" : Return : Endif
Return

#################################################################################
$DELTABLE

Call BPA([F:GAC]COA,[F:GAC]ACC,ENTITE) From SUBGAC
If GOK 
 Call ANNBPA(5,ENTITE) From TRTBPA
 If GOK
  Call ANNRIB(5,ENTITE) From TRTBPA
  If GOK
   Call ANNPYR([F:GAC]COA,[F:GAC]ACC)
    If GOK
     Call SUPTEXTRA("GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
     If GOK
      Call SUPTEXTRA("GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
     Endif
    Endif
   Endif
 Endif
Endif
   
Return

#################################################################################
Subprog ANNPYR(CHART,ACCOUNT)
#Delete the pyramid records linked to ACCOUNT of the CHART.
Value Char CHART
Value Char ACCOUNT
Local Char PYRAM(GLONGYM)

#Print pyramid
Filter [GYP] Where COA=CHART & ACC=ACCOUNT
For [GYP]
 Delete [GYP] Where COA=CHART & ACC=ACCOUNT
 If fstat=1
  GOK = -1 : GLOCK = "$GACCPYMPRT"-CHART-ACCOUNT
 Endif
Next
Filter[GYP]
  
#Link Account of pyramid
Filter [GYK] Where ACC=ACCOUNT
 For [GYK]
  Delete [GYK] Where ACC=ACCOUNT
  If fstat=1
   GOK = -1 : GLOCK = "$GACCPYMLIK"-ACCOUNT
  Endif
 Next
Filter [GYK]
 
 #Account of pyramid
 Filter [GRY] Where ACC=ACCOUNT
 For [GRY] 
  Delete [GRY] Where ACC=ACCOUNT
  If fstat=1
   GOK = -1 : GLOCK = "$GACGRUPYM"-ACCOUNT
  Endif
 Next
Filter [GRY]

End

#################################################################################
# Etiquettes du masque 
#################################################################################
Subprog C_STRACC(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ENDACC(VALEUR)
Variable Char    VALEUR()
End


