#Subprog AS_CAILEG(VALEUR)
#Variable Char    VALEUR()
#If dim([M]LEG)>0  & [M]LEG<>"" : mkstat=2 : End : Endif
#End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
# SEGAY 07/12/12 US 1047 81085
#If VALEUR<>""
# If [M]TYPFOR=2 : [M]CAILEG=VALEUR : Call AM_CAILEG(VALEUR) : Affzo[M]CAILEG Endif
#Endif

Call AM_TYPFOR([M]TYPFOR)

End


