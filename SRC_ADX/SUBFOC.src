#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet FOC
Raz GPILOBJ
Call OBJET("FOC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "LIENS" : Gosub LIENS
 When "FERME" : Gosub FERME
 When "MODIF" : Gosub MODIF
 When "CREATION" : Gosub CREATION
 When "ANNULE" : Gosub ANNULE
 When "INICRE" : Gosub INICRE
 When "RAZCRE" : Gosub RAZCRE # SEGAY 07/12/12 US 1047 81085
 When "AS_CODFOR"  : Gosub AS_CODFOR # SEGAY 07/12/12 US 1047 81085
 When "BS_CODFOR"  : Gosub BS_CODFOR # SEGAY 07/12/12 US 1047 81085
Endcase
Return

$OUVRE
Local Integer TYP
  # 25/04/12 - DKA - Add Legislation
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return
# SEGAY 07/12/12 US 1047 81085
#Before selection on field CODFOR
#############
$AS_CODFOR
Gosub SAVE_GCURLEG From TOOLSHRLEG
#JOJAC - 2016-04-21 - REQ114309 US96 - START
#Raz GCURLEG
#JOJAC - 2016-04-21 - REQ114309 US96 - END
Return

# SEGAY 07/12/12 US 1047 81085
#After selection on field CODFOR
############
$BS_CODFOR
Gosub RESTAURE_GCURLEG From TOOLSHRLEG
Return


$LIENS
  # 25/04/12 - DKA - Make DESFOR a translatable text
  GCURLEG = [F:FOC]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Call LECTEXTRA([M]DESFOR,"FORCTR","DESFOR",GCURLEG,[M]CODFOR) From ATEXTRA

  TYP=[F]TYPFOR
  Call AM_TYPFOR (TYP)
  #89241
  If val([M]CAIFOR)>0 & [M]CAILIB>0
    [M]CAIVAL=mess(val([M]CAIFOR),[M]CAILIB,1)
  Else
    [M]CAIVAL=""
  Endif
  #end 89241

#JOJAC - 2016-04-21 - REQ114309 US96 - START
#[M:FOC0]LEG=GLEGFIL
#Raz [M:FOC0]CODFOR : Affzo [M:FOC0]CODFOR
#Raz [M:FOC0]DESFOR : Affzo [M:FOC0]DESFOR
#JOJAC - 2016-04-21 - REQ114309 US96 - END
Return

$FERME
  # 25/04/12 - DKA - Add Legislation
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

# 03/05/12 - DKA - Save translatable text
$MODIF
$CREATION
  If GREP="D"
   ## In duplication mode we keep the translated text
   Call DUPTEXTRA("FORCTR","DESFOR",CLECUR1,"","FORCTR","DESFOR",GCURLEG,[F:FOC]CODFOR)  From ATEXTRA
  Endif
  Call MAJTEXTRA([M:FOC0]DESFOR,"FORCTR","DESFOR",GCURLEG,[F:FOC]CODFOR) From ATEXTRA
Return

# 03/05/12 - DKA - Delete translated texts
$ANNULE
  Call SUPTEXTRA("FORCTR","DESFOR",GCURLEG,[F:FOC]CODFOR) From ATEXTRA
Return

# SEGAY 07/12/12 US 1047 81085
# 03/05/12 - DKA - Initialise GCURLEG
$INICRE
#JOJAC - 2016-04-21 - REQ114309 US96 - START
  If GLEGFIL<>"" & GCURLEG="" Then
    GCURLEG=GLEGFIL
  Endif
#JOJAC - 2016-04-21 - REQ114309 US96 - END
Return

#JOJAC - 2016-04-21 - REQ114309 US96 - START
# 29/06/12 - PCA - Default the LEG
$RAZCRE
If dim([M:FOC0]LEG)>0 Then
 [M:FOC0]LEG=GLEGFIL
  Affzo [M:FOC0]LEG
  Raz [M:FOC0]CODFOR : Effzo [M:FOC0]CODFOR
Endif
Return
#JOJAC - 2016-04-21 - REQ114309 US96 - END


# SEGAY 07/12/12 US 1047 81085
#$RAZCRE
#JOJAC - 2016-04-21 - REQ114309 US96 - START
#GCURLEG = ""
#JOJAC - 2016-04-21 - REQ114309 US96 - END
#Return

Subprog AM_TYPFOR(VALEUR)
Variable Integer VALEUR
Local Char LSTORG
If VALEUR=1
# SEGAY 07/12/12 US 1047 81085
#89556
# Effzo [M]CAIFOR,CAILEG,CAIVAL, ADIFOR
# Grizo [M]CAIFOR,CAILEG,CAIVAL, ADIFOR
 Effzo [M]CAIFOR,CAIVAL, ADIFOR
 Grizo [M]CAIFOR,CAIVAL, ADIFOR

 Actzo [M]FMTFOR
Elsif VALEUR=2
# SEGAY 07/12/12 US 1047 81085
# Actzo [M]CAIFOR,CAILEG,CAIVAL,FMTFOR
 #89556
 #Actzo [M]CAIFOR,CAIVAL,FMTFOR
 Actzo [M]CAIFOR,CAIVAL,FMTFOR
 Effzo [M]ADIFOR
 Grizo [M]ADIFOR

  If dim([M]LEG)>0
# SEGAY 07/12/12 US 1047 81085
#    If [M]LEG <> '' and [M]CAILEG = ''
#      [M]CAILEG = [M]LEG
#    Endif
#    Call    ([M]CAILEG,"LSTORG",LSTORG) From ADOVAL
    Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL
    [M]CAILIB = val(LSTORG)
    Affzo [M]CAILIB
  Else
    Call PARAM (GDOSLEG,"LSTORG",LSTORG) From ADOVAL
    [M]CAILIB = val(LSTORG)
    Affzo [M]CAILIB
  Endif
Else
 Actzo [M]ADIFOR
# Effzo [M]CAIFOR,CAILEG,CAIVAL,FMTFOR
# Grizo [M]CAIFOR,CAILEG,CAIVAL,FMTFOR
#89556
# Effzo [M]CAIFOR,CAIVAL,FMTFOR
# Grizo [M]CAIFOR,CAIVAL,FMTFOR
 Effzo [M]CAIFOR,CAIVAL,FMTFOR
 Grizo [M]CAIFOR,CAIVAL,FMTFOR
Endif
# SEGAY 07/12/12 US 1047 81085
If  (dim([M]LEG)>0 &  GCURLEG = '')
#89556
# Effzo [M]CAIFOR,CAIVAL
# Grizo [M]CAIFOR,CAIVAL
 Effzo [M]CAIFOR,CAIVAL
 Grizo [M]CAIFOR,CAIVAL
Endif
End
