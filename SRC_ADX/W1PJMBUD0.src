#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:44"
A_USER  = "DOC"
A_STAMP = "20181109230544"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMBUD0 [PJBU0]
Gosub HORODAT
Local Inpbox "PJMBUD0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0] As [SIM_]
Grizo [PJBU0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJBU0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMBUD0
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBPJBU
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16964,GBOUT1) From OBJDIV
Call TEXTE(54893,GBOUT2) From OBJDIV
Call TEXTE(55280,GBOUT3) From OBJDIV
Call TEXTE(56446,GBOUT4) From OBJDIV
Call TEXTE(54486,GBOUT5) From OBJDIV
Call IB_NBLIG
## Action STD
Call AS_NBLIG From SUBPJBU
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMBUD0
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1PJMBUD0
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1PJMBUD0
Onkey 132 Titled GBOUT4 Call B4_NBLIG From W1PJMBUD0
Onkey 133 Titled GBOUT5 Call B5_NBLIG From W1PJMBUD0
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMEVEB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMEVEB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMBUD"
 PARMSK(2) = [M:PJBU0]KEYBUD(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OEVENB","SUBPEV","") From GSAISIE
 ACTION = "BB1_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMAUTBUD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMAUTBUD"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB2_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:PJBU0]OPPNUM
 PARMSK(2) = [M:PJBU0]KEYBUD(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMAUTBUD","PJMAUTBUD","") From GSAISIE
 ACTION = "BB2_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMACTSPLD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMACTSPLD"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB3_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = func PJMACTBUD.GET_PJMACTSPLD_ORI(nolign-1)
 PARMSK(2) = func PJMACTBUD.GET_PJMACTSPLD_COD(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMACTSPLD","PJMACTSPLD","") From GSAISIE
 ACTION = "BB3_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B4_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMBUD1T
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMBUD1T"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB4_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:PJBU0]KEYBUD(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMBUD1T","SUBPJBU1T","SPEPJBU1T") From GSAISIE
 ACTION = "BB4_NBLIG" : PROGSUB = "SUBPJBU" : PROGSPE = "SPEPJBU" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B5_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMFINOV0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMFINOV0"
 PARMSK(1) = [M:PJBU0]OPPNUM
 PARMSK(2) = [M:PJBU0]KEYBUD(nolign-1)
 PARMSK(3) = AVOID.ACHAR
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMFINOV0","PJMFINOV0","") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ICO
Onevent INIT_AREA Call D_ICO(zc) From W1PJMBUD0
Return

Subprog D_ICO(VALEUR)
Variable Char    VALEUR()
If varinit([M]ICO,indice)=0
 VALEUR = "Folder.gif"
Endif
Gosub _AFF
End

