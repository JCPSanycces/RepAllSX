#<AdxTL>@(#)0.0.0.0 $Revision$
##################################
# 104943 : version management in Work orders
#          - Enterprise Planning
##################################

##################################
# for usage in MBW3
##################################
Subprog AM_ITMREF(VALEUR)
Variable Char VALEUR

Local Integer LALT

# enable, disable ECCVALMAJ, ECCVALMIN, BOMALT
Call ECCAFF(VALEUR,"MBW3")  From MFGECCLIB
If func ECCLIB.NBRCPN(VALEUR)
    # ECC preload of major and minor version + BOM code
    LALT = [M:MBW3]BOMALT2
    Raz [M:MBW3]ECCVALMAJ, [M:MBW3]ECCVALMIN
    Call INIECCBOM(VALEUR, [M:MBW3]STOFCY, [M:MBW3]STRDAT2, 2, [M:MBW3]ECCVALMAJ,[M:MBW3]ECCVALMIN,LALT) From MFGECCLIB
    [M:MBW3]BOMALT2 = LALT
    Affzo [M:MBW3]ECCVALMAJ, ECCVALMIN, BOMALT2
Else
    Effzo [M:MBW3]ECCVALMAJ, ECCVALMIN
Endif

End

##################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
# Issue 104943 - 2015-07-20 by BEEBE : implementing versioning
# No version product or WO has status Firm (1)
If func ECCLIB.NBRCPN([M]ITMREF)<1
&  | (clalev([F:ORD1]) & [F:ORD1]WIPSTA=1 & [F:ORD1]WIPTYP=5)
    mkstat=2
Endif
End

##################################
# for usage in MBW1, MBW3, MBW4
# - Start-date
##################################
Subprog C_ECCVALMAJ(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR()
Local    Char    LECCVALMAJ : LECCVALMAJ=[M]ECCVALMAJ

Call CTRECC([M]ITMREF,ABR,"ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
    mkstat=2
Endif
End

##################################

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
# Issue 104943 - 2015-07-20 by BEEBE : implementing versioning
# No minor-version product or WO has status Firm (1)
# -> modification is enabled
If func ECCLIB.NBRCPN([M]ITMREF)<2
&  | (clalev([F:ORD1]) & [F:ORD1]WIPSTA=1 & [F:ORD1]WIPTYP=5)
&  | [M]ECCVALMAJ=""
    mkstat=2
Endif
End

##################################
# for usage in MBW1, MBW3, MBW4
# - Start-date
##################################
Subprog C_ECCVALMIN(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR
Local    Char    LECCVALMIN : LECCVALMIN=[M]ECCVALMIN

Call CTRECC([M]ITMREF, ABR,"ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
    mkstat=2
Endif

End

##################################
Subprog C_STRDAT2(VALEUR, ABR)
Variable Date VALEUR
Value    Char ABR

Local Date LSAVDAT
Local Integer IND
Local Integer LALT

# VALEUR can contain a new value, but CTRECCPRD needs [M:MBWx]STRDAT2
Case ABR
    When "MBW1"
            LSAVDAT = [M:MBW1]STRDAT2
            If LSAVDAT <> VALEUR
                [M:MBW1]STRDAT2 = VALEUR
            Endif
            If [M:MBW1]ECCVALMAJ<>""
                Call CTRECCPRD("MBW1") From MFGECCLIB     # Control each line of product and highlight them if necessary
            Endif
            IND = find(GERR,1,4)
    When "MBW3"
            LSAVDAT = [M:MBW3]STRDAT2
            If LSAVDAT <> VALEUR
                [M:MBW3]STRDAT2 = VALEUR
            Endif
            Call CTRECCPRD("MBW3") From MFGECCLIB     # Control each line of product and highlight them if necessary
            IND = find(GERR,1,4)
    When "MBW4"
            LSAVDAT = [M:MBW4]STRDAT2
            If LSAVDAT <> VALEUR
                [M:MBW4]STRDAT2 = VALEUR
            Endif
            Call CTRECCPRD("MBW4") From MFGECCLIB     # Control each line of product and highlight them if necessary
            IND = find(GERR,1,4)
Endcase

# Only when major-version is not loaded
# -> getting an initial value for major (and minor) version
If [M]ECCVALMAJ=""
    Call ECCAFF([M]ITMREF,ABR) From MFGECCLIB
    If func ECCLIB.NBRCPN([M]ITMREF)
        # ECC preload of major and minor version + BOM code
        LALT = [M]BOMALT2
        Raz [M]ECCVALMAJ,[M]ECCVALMIN
        Call INIECCBOM([M]ITMREF, [M]STOFCY, [M]STRDAT2, 2, [M]ECCVALMAJ,[M]ECCVALMIN,LALT) From MFGECCLIB
        [M]BOMALT2 = LALT
        Affzo [M]ECCVALMAJ,ECCVALMIN,BOMALT2
        GERR=0
        GMESSAGE=""
        End
    Endif
Endif

# In case of an error -> error-message
If IND>0 | GERR>0
    # Issue 104943 by BEEBE - 11/01/2016 : differed result depending of the answer to the message with OK/Abort
    Local Integer OKCAN : OKCAN=1
    Call AVERTIR(GMESSAGE, OKCAN) From GESECRAN
    GMESSAGE=""
    If OKCAN<>1
        GERR=0
        Affzo [M]STRDAT2
        Affzo [M]ENDDAT2
    Else
        [M]STRDAT2 = LSAVDAT
        Affzo [M]STRDAT2
        GERR=1
        mkstat=2
    Endif
Endif
End

#####################################################################
# Issue 104943 - 2015-07-27 by BEEBE : Implementing Versioning
#####################################################################
Subprog AM_ENDDAT2(VALEUR, ABR)
Variable Date VALEUR
Value    Char ABR
Local Date LSAVDAT

# Only when Backward Scheduling Mode
If [F:MTS]SCDMODSAI = 1
    # VALEUR can contain a new value, but CTRECCPRD needs [M:MBWx]STRDAT2
    Case ABR
        When "MBW1"
                If [M:MBW1]ECCVALMAJ<>""
                    Call CTRECCPRD("MBW1") From MFGECCLIB     # Control each line of product and highlight them if necessary
                Endif
                IND = find(GERR,1,3,4) # Issue 104943 by BEEBE - 11/01/2016 : regarding GERR = 3 too
        When "MBW3"
                Call CTRECCPRD("MBW3") From MFGECCLIB     # Control each line of product and highlight them if necessary
                IND = find(GERR,1,3,4) # Issue 104943 by BEEBE - 11/01/2016 : regarding GERR = 3 too
        When "MBW4"
                Call CTRECCPRD("MBW4") From MFGECCLIB     # Control each line of product and highlight them if necessary
                IND = find(GERR,1,3,4) # Issue 104943 by BEEBE - 11/01/2016 : regarding GERR = 3 too
    Endcase

    # In case of an error -> Warning Message
    If IND>0
        # Issue 104943 by BEEBE - 11/01/2016 : differed result depending of the answer to the message with OK/Abort
        Local Integer OKCAN : OKCAN=1
        Call AVERTIR(GMESSAGE, OKCAN) From GESECRAN
        GMESSAGE=""
        If OKCAN<>1
            GERR=0
        Else
            GERR=1
            mkstat=2
        Endif
    Endif
Endif
End

#####################################################################
# Issue 104937 - 2016-01-08 by BEEBE : implementing after change action for validation
# check major version after changing ECCVALMAJ
# for usage in MBW1, MBW3, MBW4
# - Start-date
#####################################################################
Subprog AM_ECCVALMAJ(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR()
Local    Char    LECCVALMAJ : LECCVALMAJ=[M]ECCVALMAJ

Call CTRECC([M]ITMREF,ABR,"ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
Endif
End

#####################################################################
# Issue 104937 - 2016-01-08 by BEEBE : implementing after change action for validation
# check major version after changing ECCVALMIN
# for usage in MBW1, MBW3, MBW4
# - Start-date
#####################################################################
Subprog AM_ECCVALMIN(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR
Local    Char    LECCVALMIN : LECCVALMIN=[M]ECCVALMIN

Call CTRECC([M]ITMREF, ABR,"ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

# Only Warning Message
If GERR>0
    GERR=2
Endif

End

