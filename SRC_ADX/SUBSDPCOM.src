#<AdxTL>@(#)0.0.0.0 $Revision$
#<gen>
# COPSDP2VALW : ?
# PROSDP : ?
# SUMSVW2SDP : Ajoute les différentes composantes de SVW dans SDP
# SDP2FIL : Copie les valeurs contenues dans SDP vers un fichier
#</gen>

#################################
# Charger, selon les documents appelant, les champs suivants:
# - ITMREF (Article)
# - STOFCY (Site)
# - UOM (Unité)
# - QTY (Qté)
# - CUR (devise)
#################################
$CHARGE_PARAM
Local Decimal LDIFPRI, LQTYTOT
Local Integer I
Local Char REQ(250)(3)

Case LVCRTYP
    When 9  :    # Inventaires
        [M:SDP]ITMREF = [M:SNL1]ITMREF
        [M:SDP]STOFCY = [M:SNL1]STOFCY
        [M:SDP]UOM    = [M:SNL1]STU
        [M:SDP]QTY    = [M:SNL1]QTYSTUNEW(LLIGDOC)    # Qté US comptée
        [M:SDP]CUR    = GLOCALDEV

    When 19 :    # Entrées diverses
        [M:SDP]ITMREF = [M:SMR1]ITMREF(LLIGDOC)
        [M:SDP]STOFCY = [M:SMR0]STOFCY
        [M:SDP]UOM    = [M:SMR1]STU(LLIGDOC)
        [M:SDP]QTY    = [M:SMR1]QTYSTU(LLIGDOC)
        [M:SDP]CUR    = GLOCALDEV
        [M]TRSTYP     = 1
        [M:SDP]PRISAI = [M:SMR1]PRISAI(LLIGDOC)
    When 32 :    # Désassemblage
        [M:SDP]ITMREF = [M:DBY1]ITMREF(LLIGDOC)
        [M:SDP]STOFCY = [M:DBY0]STOFCY
        [M:SDP]UOM    = [M:DBY1]STU(LLIGDOC)
        [M:SDP]QTY    = [M:DBY1]QTYSTU(LLIGDOC)
        [M:SDP]CUR    = GLOCALDEV
Endcase

Case GPRIORI
    When "SJVO", "SJVV"
        [M:SDP]ITMREF = [F:SJV]ITMREF
        [M:SDP]STOFCY = [F:SJV]STOFCY
        [M:SDP]UOM    = [F:STJ]STU
        [M:SDP]QTY    = [F:STJ]ACTQTY
        [M:SDP]CUR    = GLOCALDEV
        Raz REQ, I
        Call ADDCRIT(REQ,I,"","SELECT sum(ACTQTY_0) From STOJOU STJ"," ") From GOBJSUB
        Call ADDCRIT(REQ,I,"","Where STJ.STOFCY_0='"+[F:STJ]STOFCY+"'"," ") From GOBJSUB
        Call ADDCRIT(REQ,I,"","and STJ.ITMREF_0 = '"+[F:STJ]ITMREF+"'"," ") From GOBJSUB
        Call ADDCRIT(REQ,I,"","and STJ.VCRNUM_0='"+[F:STJ]VCRNUM+"'"," ") From GOBJSUB
        Call ADDCRIT(REQ,I,"","and STJ.VCRTYP_0="+num$([F:STJ]VCRTYP)," ") From GOBJSUB
        Call ADDCRIT(REQ,I,"","and STJ.VCRLIN_0="+num$([F:STJ]VCRLIN)," ") From GOBJSUB
        For (Decimal ACTQTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
            LQTYTOT = [F:SQLX]ACTQTY
        Next
        If GPRIORI="SJVO"
            Call LOADSDPX2("SDP","[F:SJV]","O","CST",1) From STKVAL
        Else
            Call LOADSDPX2("SDP","[F:SJV]","V","CST",1) From STKVAL
        Endif
        If [M:SDP]QTY<>0
            Call PROSDP("SDP",1/[M:SDP]QTY)
        Endif
        If GPRIORI="SJVO" & [F:STJ]REGFLG<>2
            # Issue 82159 - 2012-07-06 by CCC
            If !clalev([F:SJO]) : Local File STOJOUOVE : Endif
            Raz REQ,I
            Call ADDCRIT(REQ,I,"","SELECT OVENAT_0, sum(ONAAMT_0) From STOJOUOVE SJO"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","INNER JOIN STOJOU STJ"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","ON SJO.STOFCY_0    = STJ.STOFCY_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and SJO.UPDCOD_0   = STJ.UPDCOD_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and SJO.ITMREF_0   = STJ.ITMREF_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and SJO.IPTDAT_0   = STJ.IPTDAT_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and SJO.MVTSEQ_0   = STJ.MVTSEQ_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and SJO.MVTIND_0   = STJ.MVTIND_0"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","Where STJ.STOFCY_0='"+[F:STJ]STOFCY+"'"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and STJ.ITMREF_0 = '"+[F:STJ]ITMREF+"'"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and STJ.VCRNUM_0='"+[F:STJ]VCRNUM+"'"," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and STJ.VCRTYP_0="+num$([F:STJ]VCRTYP)," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","and STJ.VCRLIN_0="+num$([F:STJ]VCRLIN)," ") From GOBJSUB
            Call ADDCRIT(REQ,I,"","GROUP By OVENAT_0"," ") From GOBJSUB
            For (Char OVENAT, Decimal ONAAMT) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
                If [M:SDP]NBONA<dim([M:SDP]OVENAT)
                    [M:SDP]OVENAT([M:SDP]NBONA) = [F:SQLX]OVENAT
                    [M:SDP]ONAAMT([M:SDP]NBONA) = arr([F:SQLX]ONAAMT/LQTYTOT,10^-GDECPRI)
                    [M:SDP]ONATYP([M:SDP]NBONA) = 1
                    [M:SDP]NBONA += 1
                Endif
            Next
        Else
            # Sur un mouvement de régul, il est impossible de connaitre les natures qu'il y avait à ce moment là
            # Sur le montant de valo, il est impossible de connaitre les natures => nature bidon
            Call ADDONA
        Endif
        Gosub CAL_TOT From SUBSDP
        Gosub REFRESH From SUBSDP

    When "AVC"
        [M:SDP]ITMREF = [F:ITV]ITMREF
        [M:SDP]STOFCY = [F:ITV]STOFCY
        [M:SDP]UOM    = [F:ITM]STU
        [M:SDP]QTY    = [F:ITV]AVCBASQTY
        [M:SDP]CUR    = GLOCALDEV
        Call LOADSDPX2("SDP","[F:ITV]","A","AVC",1) From STKVAL
        Call ADDONA     # Issue 79289 - 2012-02-07 by CCC
        Gosub CAL_TOT From SUBSDP
        Gosub REFRESH From SUBSDP
#        If [F:ITV]AVCBASQTY<>0
#            LDIFPRI = -[M:SDP]PRI*([F:ITV]AVCBASQTY-1)/[F:ITV]AVCBASQTY
#            Gosub REPARTIR From SUBSDP
#        Endif

    When "LAS"
        [M:SDP]ITMREF = [F:ITV]ITMREF
        [M:SDP]STOFCY = [F:ITV]STOFCY
        [M:SDP]UOM    = [F:ITM]STU
        [M:SDP]QTY    = [F:ITV]AVCBASQTY
        [M:SDP]CUR    = GLOCALDEV
        Call LOADSDP("[F:ITV]","L",1) From STKVAL
        Call ADDONA     # Issue 79289 - 2012-02-07 by CCC
        Gosub CAL_TOT From SUBSDP
        Gosub REFRESH From SUBSDP

    When "STD","STDL", "ACT", "ACTL"
        If [F:ITC]ITMREF<>""
            [M:SDP]ITMREF = [F:ITC]ITMREF
            [M:SDP]STOFCY = [F:ITC]STOFCY
            [M:SDP]UOM    = [F:ITM]STU
            [M:SDP]QTY    = [F:ITC]CLCQTY
            [M:SDP]CUR    = GLOCALDEV
            Case GPRIORI
                When "STD", "ACT"
                    Call LOADSDPX2("SDP","[F:ITC]","","CST",1) From STKVAL
                When "STDL", "ACTL" :
                    Call LOADSDPX2("SDP","[F:ITC]","","LEVCST",1) From STKVAL
            Endcase
            Gosub CAL_TOT From SUBSDP

            Effzo [M:SDP]30
            If !clalev([F:ICN]) : Local File ITCNAT [ICN] : Endif
            If !clalev([F:ONA]) : Local File OVENAT [ONA] : Endif
            Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&                      As [LNK]
&                      Where ITMREF = [F:ITC]ITMREF
&                          & STOFCY = [F:ITC]STOFCY
&                          & CSTTYP = [F:ITC]CSTTYP
&                          & ITCSEQ = [F:ITC]ITCSEQ
&                          & UID    = [F:ITC]UID
            For [LNK]
                For I=1 To dim([F:ICN]NATAMTLEV)-1
                    Case GPRIORI
                        When "STD", "ACT" :
                            If [F:ICN]NATAMTSSE(I)+[F:ICN]NATAMTLEV(I)>0
                                [M:SDP]OVENAT([M:SDP]NBONA) = [F:ICN]OVENAT
                                If find(I,1,6)
                                    [M:SDP]ONATYP([M:SDP]NBONA) = 2
                                Else
                                    [M:SDP]ONATYP([M:SDP]NBONA) = I
                                Endif
                                [M:SDP]ONAAMT([M:SDP]NBONA) = [F:ICN]NATAMTSSE(I)+[F:ICN]NATAMTLEV(I)
                                [M:SDP]NBONA += 1
                            Endif

                        When "STDL", "ACTL" :
                            If [F:ICN]NATAMTLEV(I)>0
                                [M:SDP]OVENAT([M:SDP]NBONA) = [F:ICN]OVENAT
                                If find(I,1,6)
                                    [M:SDP]ONATYP([M:SDP]NBONA) = 2
                                Else
                                    [M:SDP]ONATYP([M:SDP]NBONA) = I
                                Endif
                                [M:SDP]ONAAMT([M:SDP]NBONA) = [F:ICN]NATAMTLEV(I)
                                [M:SDP]NBONA += 1
                            Endif
                    Endcase
                Next
            Next
            If [M:SDP]NBONA=0
                Effzo [M:SDP]OVEMATCST,OVEMACCST,OVELABCST,OVESCOCST
            Endif
            Gosub REFRESH From SUBSDP
        Else
            FIN=1
        Endif

    When "ITCD","ICLD" : Call CPYTOSDP(GPRIORI)
    When "ITCA" : [M:SDP] = [M:ITCA]
    When "ITCB" : [M:SDP] = [M:ITCB]
    When "ITCS" : [M:SDP] = [M:ITCS]
    When "ICLA" : [M:SDP] = [M:ICLA]
    When "ICLB" : [M:SDP] = [M:ICLB]
    When "ICLS" : [M:SDP] = [M:ICLS]

    When "MFCL" : [M:SDP]QTY = [F:MFC]QTYSTU
                  [M:SDP] = [F:MFC]
                  Call LOAD_MCN(1)

    When "MFC"  : Call MFC2SDP
                  Call LOAD_MCN(2)
Endcase

Call ARRSDP("SDP",10^-GDECPRI) From SUBSDPCOM

Return


########################################
$AFFZONPRI
Case LVCRTYP
    When 9  :    # Inventaires
        Affzo [M:SNL1]PRIORD(LLIGDOC)
        [M:SNL1]MODFLG(LLIGDOC) = 2
        mkstat=4
    When 19 :    # Entrées diverses
        Affzo [M:SMR1]PRI(LLIGDOC)
        Affzo [M:SMR1]PRIORD(LLIGDOC)
        If dim(LMODIF)>0 & LMODIF
            [M:SMR1]PRISAI(LLIGDOC) = [M:SDP]PRISAI
            Actzo [M:SMR1]PRISAI(LLIGDOC)
            Affzo [M:SMR1]PRISAI(LLIGDOC)
        Endif
    When 32 :    # Désassemblage
        Affzo [M:DBY1]PRIORD(LLIGDOC)
Endcase

If find(GPRIORI,"ICLD")
    Gosub CHARGE_GRAPH From SUBICDG
    Affzo [M:ICD1]
    Affzo [M:ICD2]
    mkstat = 4
Endif

Return

###########################################
Subprog COPSDP2VALW(PINDW,PABRVALW, PABRSDP)
Value Integer PINDW
Value Char    PABRVALW
Value Char    PABRSDP

Local Integer I
# Stockage dans [VALW]
    Assign "[M:"+PABRVALW+"]PRI(PINDW)" With evalue("[M:"+PABRSDP+"]PRI")

        #------- MATIERE ---------#
        For I=0 To GACTMAT-1
            Assign "[M:"+PABRVALW+"]OMATCST(PINDW*GACTMAT+I)" With evalue("[M:"+PABRSDP+"]MATCST(I)")
        Next

        Assign "[M:"+PABRVALW+"]OOVEMATCST(PINDW)" With evalue("[M:"+PABRSDP+"]OVEMATCST")

        #------- MACHINE ---------#
        For I=0 To GACTMAC-1
            Assign "[M:"+PABRVALW+"]OMACCST(PINDW*GACTMAC+I)" With evalue("[M:"+PABRSDP+"]MACCST(I)")
        Next

        Assign "[M:"+PABRVALW+"]OOVEMACCST(PINDW)" With evalue("[M:"+PABRSDP+"]OVEMACCST")

        #------- MAIN D'OEUVRE ---------#
        For I=0 To GACTLAB-1
            Assign "[M:"+PABRVALW+"]OLABCST(PINDW*GACTLAB+I)" With evalue("[M:"+PABRSDP+"]LABCST(I)")
        Next

        Assign "[M:"+PABRVALW+"]OOVELABCST(PINDW)" With evalue("[M:"+PABRSDP+"]OVELABCST")

        #------- SOUS-TRAITANCE ---------#
        Assign "[M:"+PABRVALW+"]OSCOTOT(PINDW)" With evalue("[M:"+PABRSDP+"]SCOTOT")

        Assign "[M:"+PABRVALW+"]OOVESCOCST(PINDW)" With evalue("[M:"+PABRSDP+"]OVESCOCST")

        #------- Eléments de facture ---------#
        Assign "[M:"+PABRVALW+"]OINVDTACST(PINDW)" With evalue("[M:"+PABRSDP+"]INVDTACST")

    For I=0 To evalue("[M:"+PABRVALW+"]NBONA")-1
        If evalue("[M:"+PABRVALW+"]OWSTOSEQ(I)")=evalue("[M:"+PABRVALW+"]WSTOSEQ(PINDW)")
            Assign "[M:"+PABRVALW+"]OWSTOSEQ(I)" With 0
        Endif
    Next

    For I=0 To evalue("[M:"+PABRSDP+"]NBONA")-1
        Assign "[M:"+PABRVALW+"]ONAAMT([M:"+PABRVALW+"]NBONA)" With evalue("[M:"+PABRSDP+"]ONAAMT(I)")
        Assign "[M:"+PABRVALW+"]OVENAT([M:"+PABRVALW+"]NBONA)" With evalue("[M:"+PABRSDP+"]OVENAT(I)")
        Assign "[M:"+PABRVALW+"]ONATYP([M:"+PABRVALW+"]NBONA)" With evalue("[M:"+PABRSDP+"]ONATYP(I)")
        Assign "[M:"+PABRVALW+"]OWSTOSEQ([M:"+PABRVALW+"]NBONA)" With evalue("[M:"+PABRVALW+"]WSTOSEQ(PINDW)")
        Assign "[M:"+PABRVALW+"]NBONA" With evalue("[M:"+PABRVALW+"]NBONA")+1
    Next
End

###########################################
Subprog PROSDP(PABR,PCOE)
Value Char    PABR
Value Decimal PCOE

Local Integer I

    For I=0 To evalue("dim([M:"+PABR+"]MATCST)-1")
        Assign "[M:"+PABR+"]MATCST(I)" With evalue("[M:"+PABR+"]MATCST(I)") * PCOE
    Next
    Assign "[M:"+PABR+"]OVEMATCST" With evalue("[M:"+PABR+"]OVEMATCST") * PCOE

    For I=0 To evalue("dim([M:"+PABR+"]MACCST)-1")
        Assign "[M:"+PABR+"]MACCST(I)" With evalue("[M:"+PABR+"]MACCST(I)") * PCOE
    Next
    Assign "[M:"+PABR+"]OVEMACCST" With evalue("[M:"+PABR+"]OVEMACCST") * PCOE

    For I=0 To evalue("dim([M:"+PABR+"]LABCST)-1")
        Assign "[M:"+PABR+"]LABCST(I)" With evalue("[M:"+PABR+"]LABCST(I)") * PCOE
    Next
    Assign "[M:"+PABR+"]OVELABCST" With evalue("[M:"+PABR+"]OVELABCST") * PCOE

    # Issue 75637 - 2011-09-07 by CCC : SCOCST n'était pas proratisé
    Assign "[M:"+PABR+"]SCOCST" With evalue("[M:"+PABR+"]SCOCST") * PCOE
    Assign "[M:"+PABR+"]SCOTOT" With evalue("[M:"+PABR+"]SCOTOT") * PCOE
    Assign "[M:"+PABR+"]OVESCOCST" With evalue("[M:"+PABR+"]OVESCOCST") * PCOE

    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") * PCOE
End

################################################
# Ajoute les différentes composantes de SVW dans SDP
################################################
# Paramètres E : PABR = abréviation du masque SDP
#                PADD = si <> 0 => on ajoute sinon on affecte
################################################
Subprog SUMSVW2SDP(PABR, PADD)
Value Char    PABR
Value Integer PADD

    For I=0 To GACTMAT-1
        Assign "[M:"+PABR+"]MATCST(I)"
&         With evalue("[M:"+PABR+"]MATCST(I)") * (PADD<>0)
&            + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OMATCST(indcum*GACTMAT+I))
    Next
    If I>0 & evalue("dim([M:"+PABR+"]NBMAT)")>0
      Assign "[M:"+PABR+"]NBMAT" With I+1
    Endif
    Assign "[M:"+PABR+"]OVEMATCST" With evalue("[M:"+PABR+"]OVEMATCST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OOVEMATTOT(indcum))

    For I=0 To GACTMAC-1
        Assign "[M:"+PABR+"]MACCST(I)"
&         With evalue("[M:"+PABR+"]MACCST(I)") * (PADD<>0)
&            + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OMACCST(indcum*GACTMAC+I))
    Next
    If I>0 & evalue("dim([M:"+PABR+"]NBMAC)")>0
      Assign "[M:"+PABR+"]NBMAC" With I+1
    Endif
    Assign "[M:"+PABR+"]OVEMACCST" With evalue("[M:"+PABR+"]OVEMACCST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OOVEMACTOT(indcum))

    For I=0 To GACTLAB-1
        Assign "[M:"+PABR+"]LABCST(I)"
&         With evalue("[M:"+PABR+"]LABCST(I)") * (PADD<>0)
&            + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OLABCST(indcum*GACTLAB+I))
    Next
    If I>0 & evalue("dim([M:"+PABR+"]NBLAB)")>0
      Assign "[M:"+PABR+"]NBLAB" With I+1
    Endif
    Assign "[M:"+PABR+"]OVELABCST" With evalue("[M:"+PABR+"]OVELABCST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OOVELABTOT(indcum))

    Assign "[M:"+PABR+"]SCOCST" With evalue("[M:"+PABR+"]SCOCST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OSCOTOT(indcum)) # Issue 84789 - 2012-09-28 by CCC
    Assign "[M:"+PABR+"]SCOTOT" With evalue("[M:"+PABR+"]SCOTOT") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OSCOTOT(indcum))
    Assign "[M:"+PABR+"]OVESCOCST" With evalue("[M:"+PABR+"]OVESCOCST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OOVESCOTOT(indcum))

    Assign "[M:"+PABR+"]INVDTACST" With evalue("[M:"+PABR+"]INVDTACST") * (PADD<>0) + sigma(0,[M:STW]NBLIG-1,(1-2*([M:STW]MAJCOD(indcum)='A'))*[M:SVW]OINVDTA(indcum))

    # Issue 85149 - 2012-10-12 by CCC : ajout des natures "ZZZ" pour la calcul des totaux
    If evalue("[M:"+PABR+"]NBONA")=0
&    | evalue("sigma(0,[M:"+PABR+"]NBONA-1,[M:"+PABR+"]OVENAT(indcum)='ZZZ')")=evalue("[M:"+PABR+"]NBONA")
        Case PABR
            When "SDP" : Raz [M:SDP]ONAAMT,[M:SDP]ONATYP,[M:SDP]OVENAT,[M:SDP]NBONA
            When "SDPA": Raz [M:SDPA]ONAAMT,[M:SDPA]ONATYP,[M:SDPA]OVENAT,[M:SDPA]NBONA
            When Default : I=evalue("sigma(I=0,[M:"+PABR+"]NBONA-1,sigma([M:"+PABR+"]ONAAMT(I)=0,-1,0))")
                           I=evalue("sigma(I=0,[M:"+PABR+"]NBONA-1,sigma([M:"+PABR+"]ONATYP(I)=0,-1,0))")
                           For I=0 To evalue("[M:"+PABR+"]NBONA")-1
                               Assign "[M:"+PABR+"]OVENAT(I)" With ""
                           Next
                           Assign "[M:"+PABR+"]NBONA" With 0
        Endcase
        Call ADDONA2(PABR)
    Endif
End

################################################
# Copie les valeurs contenues dans SDP vers un fichier
################################################
Subprog SDP2FIL(PFIC, PREFIX, PCOE)
Value Char PFIC
Value Char PREFIX
Value Decimal PCOE

Local Integer I

#---- Matière ----#
For I=0 To GACTMAT-1
    Assign PFIC+PREFIX+"MATCST(I)" With [M:SDP]MATCST(I)*PCOE
Next

If evalue("dim("+PFIC+PREFIX+"OVEMATCST)")>0
    Assign PFIC+PREFIX+"OVEMATCST" With [M:SDP]OVEMATCST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMATTOT)")>0
    Assign PFIC+PREFIX+"OVEMATTOT" With [M:SDP]OVEMATCST*PCOE
Endif

#---- Machine ----#
For I=0 To GACTMAC-1
    Assign PFIC+PREFIX+"MACCST(I)" With [M:SDP]MACCST(I)*PCOE
Next

If evalue("dim("+PFIC+PREFIX+"OVEMACCST)")>0
    Assign PFIC+PREFIX+"OVEMACCST" With [M:SDP]OVEMACCST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVEMACTOT)")>0
    Assign PFIC+PREFIX+"OVEMACTOT" With [M:SDP]OVEMACCST*PCOE
Endif

#---- Main d'oeuvre ----#
For I=0 To GACTLAB-1
    Assign PFIC+PREFIX+"LABCST(I)" With [M:SDP]LABCST(I)*PCOE
Next
If evalue("dim("+PFIC+PREFIX+"OVELABCST)")>0
    Assign PFIC+PREFIX+"OVELABCST" With [M:SDP]OVELABCST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVELABTOT)")>0
    Assign PFIC+PREFIX+"OVELABTOT" With [M:SDP]OVELABCST*PCOE
Endif

#---- /s-traitance ----#
If evalue("dim("+PFIC+PREFIX+"SCOCST)")>0
    Assign PFIC+PREFIX+"SCOCST" With [M:SDP]SCOTOT*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"SCOTOT)")>0
    Assign PFIC+PREFIX+"SCOTOT" With [M:SDP]SCOTOT*PCOE
Endif
If evalue("dim("+PFIC+PREFIX+"OVESCOCST)")>0
    Assign PFIC+PREFIX+"OVESCOCST" With [M:SDP]OVESCOCST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"OVESCOTOT)")>0
    Assign PFIC+PREFIX+"OVESCOTOT" With [M:SDP]OVESCOCST*PCOE
Endif

#---- élements de facture ----#
If evalue("dim("+PFIC+PREFIX+"INVDTACST)")>0
    Assign PFIC+PREFIX+"INVDTACST" With [M:SDP]INVDTACST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTATOT)")>0
    Assign PFIC+PREFIX+"INVDTATOT" With [M:SDP]INVDTACST*PCOE
Elsif evalue("dim("+PFIC+PREFIX+"INVDTA)")>0
    Assign PFIC+PREFIX+"INVDTA" With [M:SDP]INVDTACST*PCOE
Endif
End


#####################################################################
# Arrondi les valeurs (montants et prix) de l'écran SAIDECPRI
#####################################################################
# Paramètres E : PABR = abréviation de l'écran
#                PARR = type arrondi ex : 0.01=arrondi sur 2 décimales
#####################################################################
Subprog ARRSDP(PABR,PARR)
Value Char    PABR
Value Decimal PARR

Local Integer I
Local Char LZONMAX(8+GLONAVA+4)    #longueur nom de zone +4 pour l'indice + 8 pour l'abrev du masque
Local Decimal LVAL, LVALMAX

    # On fait la somme des composantes non arrondies pour pouvoir calculer l'écart à la fin
    Assign "[M:"+PABR+"]PRI" With func SUMCST(PABR)

    For I=0 To GACTMAT-1
        LVAL = evalue("[M:"+PABR+"]MATCST(I)")
        If abs(LVAL)>LVALMAX
            LVALMAX = abs(LVAL)
            LZONMAX = "[M:"+PABR+"]MATCST("+num$(I)+")"
        Endif
        Assign "[M:"+PABR+"]MATCST(I)" With arr(LVAL,PARR)
    Next
    LVAL = evalue("[M:"+PABR+"]OVEMATCST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]OVEMATCST"
    Endif
    Assign "[M:"+PABR+"]OVEMATCST" With arr(LVAL,PARR)

    For I=0 To GACTMAC-1
        LVAL = evalue("[M:"+PABR+"]MACCST(I)")
        If abs(LVAL)>LVALMAX
            LVALMAX = abs(LVAL)
            LZONMAX = "[M:"+PABR+"]MACCST("+num$(I)+")"
        Endif
        Assign "[M:"+PABR+"]MACCST(I)" With arr(LVAL,PARR)
    Next
    LVAL = evalue("[M:"+PABR+"]OVEMACCST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]OVEMACCST"
    Endif
    Assign "[M:"+PABR+"]OVEMACCST" With arr(LVAL,PARR)

    For I=0 To GACTLAB-1
        LVAL = evalue("[M:"+PABR+"]LABCST(I)")
        If abs(LVAL)>LVALMAX
            LVALMAX = abs(LVAL)
            LZONMAX = "[M:"+PABR+"]LABCST("+num$(I)+")"
        Endif
        Assign "[M:"+PABR+"]LABCST(I)" With arr(LVAL,PARR)
    Next
    LVAL = evalue("[M:"+PABR+"]OVELABCST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]OVELABCST"
    Endif
    Assign "[M:"+PABR+"]OVELABCST" With arr(LVAL,PARR)

    LVAL = evalue("[M:"+PABR+"]SCOCST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]SCOCST"
    Endif
    Assign "[M:"+PABR+"]SCOCST" With arr(LVAL,PARR)

    LVAL = evalue("[M:"+PABR+"]OVESCOCST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]OVESCOCST"
    Endif
    Assign "[M:"+PABR+"]OVESCOCST" With arr(LVAL,PARR)

    LVAL = evalue("[M:"+PABR+"]INVDTACST")
    If abs(LVAL)>LVALMAX
        LVALMAX = abs(LVAL)
        LZONMAX = "[M:"+PABR+"]INVDTACST"
    Endif
    Assign "[M:"+PABR+"]INVDTACST" With arr(LVAL,PARR)

    For I=0 To evalue("dim([M:"+PABR+"]ONAAMT)-1")
        If evalue("[M:"+PABR+"]OVENAT(I)")="" : Break : Endif
        LVAL = evalue("[M:"+PABR+"]ONAAMT(I)")
        If abs(LVAL)>LVALMAX
            LVALMAX = abs(LVAL)
            LZONMAX = "[M:"+PABR+"]ONAAMT("+num$(I)+")"
        Endif
        Assign "[M:"+PABR+"]ONAAMT(I)" With arr(LVAL,PARR)
    Next

    LVAL = evalue("[M:"+PABR+"]PRI")
    Assign "[M:"+PABR+"]PRI" With arr(LVAL,PARR)

# On affecte à la plus grande valeur l'écart d'arrondi
    LVAL = arr(evalue("[M:"+PABR+"]PRI"), PARR)
&        - func SUMCST(PABR)
    If LVAL<>0
        Assign LZONMAX With evalue(LZONMAX)+LVAL
    Endif

    Gosub CAL_TOT From SUBSDP
End

#####################################################
# SUMCST : Calcule le total des composantes
#####################################################
Funprog SUMCST(PABR)
Value Char PABR

Local Decimal LTOT

If PABR="SDP"
    LTOT = sum([M:SDP]MATCST(0..GACTMAT-1))+sum([M:SDP]MACCST(0..GACTMAC-1))+sum([M:SDP]LABCST(0..GACTLAB-1))+[M:SDP]SCOCST+[M:SDP]INVDTACST
&         +sum([M:SDP]OVEMATCST,[M:SDP]OVEMACCST,[M:SDP]OVELABCST,[M:SDP]OVESCOCST)
Else
    LTOT = evalue("sum([M:"+PABR+"]MATCST(0..GACTMAT-1))+sum([M:"+PABR+"]MACCST(0..GACTMAC-1))+sum([M:"+PABR+"]LABCST(0..GACTLAB-1))+[M:"+PABR+"]SCOCST+[M:"+PABR+"]INVDTACST")
&         +evalue("sum([M:"+PABR+"]OVEMATCST,[M:"+PABR+"]OVEMACCST,[M:"+PABR+"]OVELABCST,[M:"+PABR+"]OVESCOCST)")
Endif
End LTOT


################################################################
# CST2SDP : Copie les valeurs d'un produit contenues dans
#           l'écran CST vers l'écran SDP
################################################################
# Paramètre E : PLNK = identifiant des lignes du tableau de produits dans CST
################################################################
Subprog CST2SDP(PLNK)
Value Integer PLNK

Local Integer I

Raz [M:SDP]MATLEV0
For I=0 To GACTMAT-1
    [M:SDP]MATCST(I) = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)
&                                            *([M:CST]IMATCST(indcum*GACTMAT+I)+[M:CST]IFMATCST(indcum*GACTMAT+I)
&                                             + [M:CST]ISMATCST(indcum*GACTMAT+I)+[M:CST]IFSMATCST(indcum*GACTMAT+I)))
    [M:SDP]MATLEV0 += sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)
&                                            *([M:CST]IMATLEV0(indcum*GACTMAT+I)+[M:CST]IFMATLEV0(indcum*GACTMAT+I)))
Next
For I=0 To GACTMAC-1
    [M:SDP]MACCST(I) = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IMACCST(indcum*GACTMAC+I)+[M:CST]IFMACCST(indcum*GACTMAC+I)))
Next

For I=0 To GACTLAB-1
    [M:SDP]LABCST(I) = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]ILABCST(indcum*GACTLAB+I)+[M:CST]IFLABCST(indcum*GACTLAB+I)))
Next

[M:SDP]SCOCST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]ISCOCST(indcum)+[M:CST]IFSCOCST(indcum)))

[M:SDP]INVDTACST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IINVDTA(indcum)+[M:CST]IFINVDTA(indcum)))

[M:SDP]OVEMATCST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IOVEMATCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",1,[M:CST]ILNK(indcum))))

[M:SDP]OVEMACCST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IOVEMACCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",2,[M:CST]ILNK(indcum))))

[M:SDP]OVELABCST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IOVELABCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",3,[M:CST]ILNK(indcum))))

[M:SDP]OVESCOCST = sigma(0,[M:CST]NBITM-1,(PLNK=[M:CST]ILNK(indcum) & [M:CST]ITMTYP(indcum)<>2)*([M:CST]IOVESCOCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",4,[M:CST]ILNK(indcum))))

# Issue 82159 - 2012-07-04 by CCC : Récupération des natures de FG
Local Integer I, J, LEXI
Local Decimal LQTYLIN, LQTYTOT
Local Decimal LCOE

LQTYLIN = func TRTCST.SUMQTY("P",PLNK)
LQTYTOT = func TRTCST.SUMQTY("P",0)

# On récupère les natures de FG des composants --> nature ZZZ
For I=0 To [M:CST]NBMAT-1
    If [M:CST]MLNK(I)=0 | [M:CST]MLNK(I)=PLNK
        J=find("ZZZ",[M:SDP]OVENAT)-1
        If J<0
            J=[M:SDP]NBONA
            [M:SDP]NBONA+=1
        Endif
        [M:SDP]OVENAT(J) = "ZZZ"
        [M:SDP]ONATYP(J) = 2
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]MLNK(I)=0
                [M:SDP]ONAAMT(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))*LQTYLIN/LQTYTOT
            Else
                [M:SDP]ONAAMT(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))
            Endif
        Endif
    Endif
Next

For I=0 To [M:CST]NBFGMAT-1
    If [M:CST]MOLNK(I)=0 | [M:CST]MOLNK(I)=PLNK
        J=find([M:CST]NATMAT(I),[M:SDP]OVENAT)-1
        If J<0
            J=[M:SDP]NBONA
            [M:SDP]NBONA+=1
        Endif
        [M:SDP]OVENAT(J) = [M:CST]NATMAT(I)
        [M:SDP]ONATYP(J) = [M:CST]MOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0 & [M:CST]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
            If [M:CST]MOLNK(I)=0
                [M:SDP]ONAAMT(J) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP]ONAAMT(J) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I))
            Endif
        Endif

    Endif
Next


For I=0 To [M:CST]NBFGITM-1
    If [M:CST]IOLNK(I)=0 | [M:CST]IOLNK(I)=PLNK
        J=find([M:CST]NATITM(I),[M:SDP]OVENAT)-1
        If J<0
            J=[M:SDP]NBONA
            [M:SDP]NBONA+=1
        Endif
        [M:SDP]OVENAT(J) = [M:CST]NATITM(I)
        [M:SDP]ONATYP(J) = [M:CST]IOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]IOLNK(I)=0
                [M:SDP]ONAAMT(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP]ONAAMT(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I))
            Endif
        Endif

    Endif
Next

For I=0 To [M:CST]NBFGWST-1
    If [M:CST]WOLNK(I)=0 | [M:CST]WOLNK(I)=PLNK
        J=find([M:CST]NATWST(I),[M:SDP]OVENAT)-1
        If J<0
            J=[M:SDP]NBONA
            [M:SDP]NBONA+=1
        Endif
        [M:SDP]OVENAT(J) = [M:CST]NATWST(I)
        [M:SDP]ONATYP(J) = [M:CST]WOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]WOLNK(I)=0
                [M:SDP]ONAAMT(J) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP]ONAAMT(J) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I))
            Endif
        Endif

    Endif
Next
For I=0 To [M:CST]NBFGSCO-1
    If [M:CST]SOLNK(I)=0 | [M:CST]SOLNK(I)=PLNK
        J=find([M:CST]NATSCO(I),[M:SDP]OVENAT)-1
        If J<0
            J=[M:SDP]NBONA
            [M:SDP]NBONA+=1
        Endif
        [M:SDP]OVENAT(J) = [M:CST]NATSCO(I)
        [M:SDP]ONATYP(J) = [M:CST]SOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0 & [M:CST]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
            If [M:CST]SOLNK(I)=0
                [M:SDP]ONAAMT(J) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP]ONAAMT(J) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I))
            Endif
        Endif

    Endif
Next

End

# Issue 94421 - 2013-11-15 by CCC : Si mask CST2 ouvert par PE => on le gère pour améliorer la précision
# Alimente [M:SDP2] avec [M:CST2] comme CST2SDP
Subprog CST2SDP2(PLNK)
Value Integer PLNK

Local Integer I

Raz [M:SDP2]MATLEV0
For I=0 To GACTMAT-1
    [M:SDP2]MATCST(I) = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                            *([M:CST2]IMATCST(indcum*GACTMAT+I)+[M:CST2]IFMATCST(indcum*GACTMAT+I)
&                                             + [M:CST2]ISMATCST(indcum*GACTMAT+I)+[M:CST2]IFSMATCST(indcum*GACTMAT+I)))
    [M:SDP2]MATLEV0 += sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                            *([M:CST2]IMATLEV0(indcum*GACTMAT+I)+[M:CST2]IFMATLEV0(indcum*GACTMAT+I)))
Next
For I=0 To GACTMAC-1
    [M:SDP2]MACCST(I) = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                              *([M:CST2]IMACCST(indcum*GACTMAC+I)+[M:CST2]IFMACCST(indcum*GACTMAC+I)))
Next

For I=0 To GACTLAB-1
    [M:SDP2]LABCST(I) = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                              *([M:CST2]ILABCST(indcum*GACTLAB+I)+[M:CST2]IFLABCST(indcum*GACTLAB+I)))
Next

[M:SDP2]SCOCST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                       *([M:CST2]ISCOCST(indcum)+[M:CST2]IFSCOCST(indcum)))

[M:SDP2]INVDTACST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                          *([M:CST2]IINVDTA(indcum)+[M:CST2]IFINVDTA(indcum)))

[M:SDP2]OVEMATCST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                          *([M:CST2]IOVEMATCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",1,[M:CST2]ILNK(indcum))))

[M:SDP2]OVEMACCST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                          *([M:CST2]IOVEMACCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",2,[M:CST2]ILNK(indcum))))

[M:SDP2]OVELABCST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                          *([M:CST2]IOVELABCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",3,[M:CST2]ILNK(indcum))))

[M:SDP2]OVESCOCST = sigma(0,[M:CST2]NBITM-1,(PLNK=[M:CST2]ILNK(indcum) & [M:CST2]ITMTYP(indcum)<>2)
&                                          *([M:CST2]IOVESCOCST(indcum)- (dim(GOVEPRD)>0 & GOVEPRD)*func TRTCST.SUMOVE("P",4,[M:CST2]ILNK(indcum))))

# Issue 82159 - 2012-07-04 by CCC : Récupération des natures de FG
Local Integer I, J, LEXI
Local Decimal LQTYLIN, LQTYTOT
Local Decimal LCOE

# Utilise [M:CST] mais les quantités dans [M:CST2] sont les mêmes
LQTYLIN = func TRTCST.SUMQTY("P",PLNK)
LQTYTOT = func TRTCST.SUMQTY("P",0)

# On récupère les natures de FG des composants --> nature ZZZ
For I=0 To [M:CST2]NBMAT-1
    If [M:CST2]MLNK(I)=0 | [M:CST2]MLNK(I)=PLNK
        J=find("ZZZ",[M:SDP2]OVENAT)-1
        If J<0
            J=[M:SDP2]NBONA
            [M:SDP2]NBONA+=1
        Endif
        [M:SDP2]OVENAT(J) = "ZZZ"
        [M:SDP2]ONATYP(J) = 2
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST2]MLNK(I)=0
                [M:SDP2]ONAAMT(J) += sum([M:CST2]MOVEMATCST(I),[M:CST2]MOVEMACCST(I),[M:CST2]MOVELABCST(I),[M:CST2]MOVESCOCST(I))*LQTYLIN/LQTYTOT
            Else
                [M:SDP2]ONAAMT(J) += sum([M:CST2]MOVEMATCST(I),[M:CST2]MOVEMACCST(I),[M:CST2]MOVELABCST(I),[M:CST2]MOVESCOCST(I))
            Endif
        Endif
    Endif
Next

For I=0 To [M:CST2]NBFGMAT-1
    If [M:CST2]MOLNK(I)=0 | [M:CST2]MOLNK(I)=PLNK
        J=find([M:CST2]NATMAT(I),[M:SDP2]OVENAT)-1
        If J<0
            J=[M:SDP2]NBONA
            [M:SDP2]NBONA+=1
        Endif
        [M:SDP2]OVENAT(J) = [M:CST2]NATMAT(I)
        [M:SDP2]ONATYP(J) = [M:CST2]MOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0 & [M:CST2]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
            If [M:CST2]MOLNK(I)=0
                [M:SDP2]ONAAMT(J) += ([M:CST2]MVARAMT(I) + [M:CST2]MFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP2]ONAAMT(J) += ([M:CST2]MVARAMT(I) + [M:CST2]MFXDAMT(I))
            Endif
        Endif

    Endif
Next


For I=0 To [M:CST2]NBFGITM-1
    If [M:CST2]IOLNK(I)=0 | [M:CST2]IOLNK(I)=PLNK
        J=find([M:CST2]NATITM(I),[M:SDP2]OVENAT)-1
        If J<0
            J=[M:SDP2]NBONA
            [M:SDP2]NBONA+=1
        Endif
        [M:SDP2]OVENAT(J) = [M:CST2]NATITM(I)
        [M:SDP2]ONATYP(J) = [M:CST2]IOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST2]IOLNK(I)=0
                [M:SDP2]ONAAMT(J) += ([M:CST2]IVARAMT(I) + [M:CST2]IFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP2]ONAAMT(J) += ([M:CST2]IVARAMT(I) + [M:CST2]IFXDAMT(I))
            Endif
        Endif

    Endif
Next

For I=0 To [M:CST2]NBFGWST-1
    If [M:CST2]WOLNK(I)=0 | [M:CST2]WOLNK(I)=PLNK
        J=find([M:CST2]NATWST(I),[M:SDP2]OVENAT)-1
        If J<0
            J=[M:SDP2]NBONA
            [M:SDP2]NBONA+=1
        Endif
        [M:SDP2]OVENAT(J) = [M:CST2]NATWST(I)
        [M:SDP2]ONATYP(J) = [M:CST2]WOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST2]WOLNK(I)=0
                [M:SDP2]ONAAMT(J) += ([M:CST2]WVARAMT(I) + [M:CST2]WFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP2]ONAAMT(J) += ([M:CST2]WVARAMT(I) + [M:CST2]WFXDAMT(I))
            Endif
        Endif

    Endif
Next
For I=0 To [M:CST2]NBFGSCO-1
    If [M:CST2]SOLNK(I)=0 | [M:CST2]SOLNK(I)=PLNK
        J=find([M:CST2]NATSCO(I),[M:SDP2]OVENAT)-1
        If J<0
            J=[M:SDP2]NBONA
            [M:SDP2]NBONA+=1
        Endif
        [M:SDP2]OVENAT(J) = [M:CST2]NATSCO(I)
        [M:SDP2]ONATYP(J) = [M:CST2]SOVETYP(I)
        If LQTYLIN<>0 & LQTYTOT<>0 & [M:CST2]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
            If [M:CST2]SOLNK(I)=0
                [M:SDP2]ONAAMT(J) += ([M:CST2]SVARAMT(I) + [M:CST2]SFXDAMT(I))*LQTYLIN / LQTYTOT
            Else
                [M:SDP2]ONAAMT(J) += ([M:CST2]SVARAMT(I) + [M:CST2]SFXDAMT(I))
            Endif
        Endif

    Endif
Next

End

################################################################
# MFC2SDP : Affecte les valeurs multi-niveaux de MFGCOST dans SDP
################################################################
Subprog MFC2SDP

    [M:SDP]ITMREF = [F:MFC]ITMREF
    [M:SDP]STOFCY = [F:MFC]STOFCY
    [M:SDP]QTY    = [F:MFC]QTYSTU

    For I=0 To GACTMAT-1
        [M:SDP]MATCST(I) = [F:MFC]MATCPNCST(I)
    Next
    [M:SDP]OVEMATCST = [F:MFC]OVEMATCPN+[F:MFC]OVEMATCST

    For I=0 To GACTMAC-1
        [M:SDP]MACCST(I) = [F:MFC]MACCPNCST(I)+[F:MFC]MACCST(I)
    Next
    [M:SDP]OVEMACCST = [F:MFC]OVEMACCPN+[F:MFC]OVEMACCST

    For I=0 To GACTLAB-1
        [M:SDP]LABCST(I) = [F:MFC]LABCPNCST(I)+[F:MFC]LABCST(I)
    Next
    [M:SDP]OVELABCST = [F:MFC]OVELABCPN+[F:MFC]OVELABCST

# Issue 84660 - 2012-09-20 by CCC
#    [M:SDP]SCOTOT    = [F:MFC]SCOCPNCST+[F:MFC]SCOCST
    [M:SDP]SCOCST    = [F:MFC]SCOCPNCST+[F:MFC]SCOCST
    [M:SDP]OVESCOCST = [F:MFC]OVESCOCPN+[F:MFC]OVESCOCST

    [M:SDP]INVDTACST = [F:MFC]INVDTACPN+[F:MFC]INVDTACST
End

################################################################
# LOAD_MCN : Charge les natures de FG dans SDP
################################################################
# Parameters E :
#            S :
################################################################
Subprog LOAD_MCN(PNIV)
Value Integer PNIV

Local Integer I

If clalev([F:MCN])=0 : Local File MFCNAT [MCN] : Endif

For [MCN] Where STOFCY=[F:MFC]STOFCY
&             & ITMREF=[F:MFC]ITMREF
&             & VCRTYP=[F:MFC]VCRTYP
&             & VCRNUM=[F:MFC]VCRNUM
&             & VCRLIN=[F:MFC]VCRLIN
&             & MFCTYP=[F:MFC]MFCTYP
&             & UID   =[F:MFC]UID
    If PNIV=1 & [F:MCN]NATAMTLEV(0)<>0
        For I=1 To dim([F:MCN]NATAMTLEV)-1
            If [F:MCN]NATAMTLEV(I)<>0
                [M:SDP]OVENAT([M:SDP]NBONA) = [F:MCN]OVENAT
                If find(I,3,4,5)  # ML 2384 "Type de FG" : machine - main d'oeuvre - sous-traitance
                    [M:SDP]ONATYP([M:SDP]NBONA) = I
                Else
                    [M:SDP]ONATYP([M:SDP]NBONA) = 2 # Matière
                Endif
                [M:SDP]ONAAMT([M:SDP]NBONA) = [F:MCN]NATAMTLEV(I)
                [M:SDP]NBONA += 1
            Endif
        Next
    Elsif PNIV=2 & ([F:MCN]NATAMTLEV(0)+[F:MCN]NATAMTSSE(0))<>0
        For I=1 To dim([F:MCN]NATAMTLEV)-1
            If [F:MCN]NATAMTLEV(I)+[F:MCN]NATAMTSSE(I)<>0
                [M:SDP]OVENAT([M:SDP]NBONA) = [F:MCN]OVENAT
                If find(I,3,4,5)  # ML 2384 "Type de FG" : machine - main d'oeuvre - sous-traitance
                    [M:SDP]ONATYP([M:SDP]NBONA) = I
                Else
                    [M:SDP]ONATYP([M:SDP]NBONA) = 2 # Matière
                Endif
                [M:SDP]ONAAMT([M:SDP]NBONA) = [F:MCN]NATAMTLEV(I)+[F:MCN]NATAMTSSE(I)
                [M:SDP]NBONA += 1
            Endif
        Next
    Endif
Next
End

# Issue 79289 - 2012-02-07 by CCC
##############################################################
# ADDONA : Ajoute des natures FG bidon pour que les calculs de totaux soient corrects
##############################################################
# Ce sous-pro est utilisé pour l'affichage du PMP et du dernier prix
# car ceux-ci n'ont pas de natures de FG
##############################################################
Subprog ADDONA
If [M:SDP]OVEMATCST<>0
    [M:SDP]ONAAMT([M:SDP]NBONA)=[M:SDP]OVEMATCST
    [M:SDP]ONATYP([M:SDP]NBONA)=2
    [M:SDP]OVENAT([M:SDP]NBONA)="ZZZ"
    [M:SDP]NBONA+=1
Endif
If [M:SDP]OVEMACCST<>0
    [M:SDP]ONAAMT([M:SDP]NBONA)=[M:SDP]OVEMACCST
    [M:SDP]ONATYP([M:SDP]NBONA)=3
    [M:SDP]OVENAT([M:SDP]NBONA)="ZZZ"
    [M:SDP]NBONA+=1
Endif
If [M:SDP]OVELABCST<>0
    [M:SDP]ONAAMT([M:SDP]NBONA)=[M:SDP]OVELABCST
    [M:SDP]ONATYP([M:SDP]NBONA)=4
    [M:SDP]OVENAT([M:SDP]NBONA)="ZZZ"
    [M:SDP]NBONA+=1
Endif
If [M:SDP]OVESCOCST<>0
    [M:SDP]ONAAMT([M:SDP]NBONA)=[M:SDP]OVESCOCST
    [M:SDP]ONATYP([M:SDP]NBONA)=5
    [M:SDP]OVENAT([M:SDP]NBONA)="ZZZ"
    [M:SDP]NBONA+=1
Endif
End

Subprog ADDONA2(PABR)
Value Char PABR

Local Integer NB
NB = evalue("[M:"+PABR+"]NBONA")

If evalue("[M:"+PABR+"]OVEMATCST")<>0
    Assign "[M:"+PABR+"]ONAAMT(NB)" With evalue("[M:"+PABR+"]OVEMATCST")
    Assign "[M:"+PABR+"]ONATYP(NB)" With 2
    Assign "[M:"+PABR+"]OVENAT(NB)" With "ZZZ"
    NB+=1
Endif
If evalue("[M:"+PABR+"]OVEMACCST")<>0
    Assign "[M:"+PABR+"]ONAAMT(NB)" With evalue("[M:"+PABR+"]OVEMACCST")
    Assign "[M:"+PABR+"]ONATYP(NB)" With 3
    Assign "[M:"+PABR+"]OVENAT(NB)" With "ZZZ"
    NB+=1
Endif
If evalue("[M:"+PABR+"]OVELABCST")<>0
    Assign "[M:"+PABR+"]ONAAMT(NB)" With evalue("[M:"+PABR+"]OVELABCST")
    Assign "[M:"+PABR+"]ONATYP(NB)" With 4
    Assign "[M:"+PABR+"]OVENAT(NB)" With "ZZZ"
    NB+=1
Endif
If evalue("[M:"+PABR+"]OVESCOCST")<>0
    Assign "[M:"+PABR+"]ONAAMT(NB)" With evalue("[M:"+PABR+"]OVESCOCST")
    Assign "[M:"+PABR+"]ONATYP(NB)" With 5
    Assign "[M:"+PABR+"]OVENAT(NB)" With "ZZZ"
    NB+=1
Endif
Assign "[M:"+PABR+"]NBONA" With NB
End

Subprog CPYTOSDP(PABR)
Value Char PABR

  #Verify that the dimension variables are populated
  If evalue("[M:"+PABR+"]NBMAC")=0 : Assign "[M:"+PABR+"]NBMAC" With GACTMAC+1 : Endif
  If evalue("[M:"+PABR+"]NBMAT")=0 : Assign "[M:"+PABR+"]NBMAT" With GACTMAT+1 : Endif
  If evalue("[M:"+PABR+"]NBLAB")=0 : Assign "[M:"+PABR+"]NBLAB" With GACTLAB+1 : Endif

  #Call transmask to populate
  Case PABR
    When "ICLD" : Transmask [M:ICLD] To [M:SDP]
    When "ITCD" : Transmask [M:ITCD] To [M:SDP]
  Endcase
End

