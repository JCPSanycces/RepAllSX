#<AdxTL>@(#)0.0.0.0 $Revision$
#                                                                                                       #
# Action métier :  CHANGER LA METHODE D'AMORTISSEMENT ( Traitement 2 - $ACTMET)                         #
#                                                                                                       #
#########################################################################################################
#                                                                                                          #
#    Modifications
# MDJ  09.11.2017  X3-61112  : FR - Update for the 40% tax deduction on investement (Macron Law)
# MWA  12.02.2015  FQ122001  : Mauvaise affectation PERREFCLC si changement de méthode contextes exercices décalés.
# MWA  12.02.2015  FQ105809  : Ajout modes turques - TL Linéaire turque  & TD Dégressif turque
# MWA  10.09.2014  FQ95754_3 : Classement pour vente (Sprint 38 - US 3) Opération interdite pour un bien classé pour vente
# MDJ  30.10.2013  FQ92611   : Suppression champs CRETIM et UPDTIM
# MDJ  18.04.2013  FQ89463   : (suite Fq-87928) : Ctrls incorrects entre plan Fiscal et plan Subvention                                                                                       #
# MWA  15.04.2013  FQ84281   : Ajout modes suisse                                                   #
# MWA  13.03.2013  FQ84283   : Ajout modes australiens - AL Prime cost  & AD Diminishing value      #
# MDJ  22.02.2032  FQ87928   : Autoriser accès plan de SUBV + ouverture de [M:MET2] pour CONTROLE_METHODE
# MDJ  19.09.2012  FQ84623   : Déforçage du cumul à tort lors d'un changement de méthode massif
# CBO  07.17.2012  FQ80039   : pb rattrapage
# CBO  10.05.2012  FQ82075   : Linéaire espagnol jour
# MDJ  20.04.2012  FQ78438   : Chgt méthode avec passage date début amort s/ exe antérieur
# MWA  01.03.2012  FQ77877   : Roumanie                                                            #
# MDJ  15.09.2011  FQ76303   : POL : Modification du taux possible si mode ML
# MDJ  21.07.2011  FQ60501   : Pb si changement méthode à partir d"un mode "SA"
# GBO  23.02.2011  Fq67577   : Pologne - Modernisation                                             #
# MDJ  28.01.2011  Fq70482   : Certif. NC-37  revue et corrigée                            #
# MDJ  22.12.2010  Fq70141   : Vérification de sources (interne)                                   #
# GLE  15.11.2010  FQ66894   : Optimisation des flux                                               #
# MWA  20.10.2010  FQ68431   : Mauvaise affectation de l'indicateur de recalcul d'un contexte      #                                                               #
# MDJ  05.08.2010  FQ65873   :  N°mess remplacés par des variables globales                         #
# MWA  12.07.2010  FQ31508   : MAJ du taux d'amort. n'est pas pris en compte pour le mode LP       #
# MDJ  23.04.2010  FQ64291   : CERTIF NC37 : Lien plan de subvention/Plan fiscal                   #
# MDJ  16.10.2009  FQ58289   : Passage en résiduel et conservation du Prorata                      #
# MDJ  05.10.2009  FQ58042   : Application des associations + gestion flag plan à traiter          #
# MDJ  04.09.2009  FQ54343   : Possibilité de forcer la date de fin d'amortissement                #
# GBN  01.09.2009  FQ57523   : Changement de méthode en mode silencieux                            #
#########################################################################################################

#=====================================================================
# Unitaire : critère désactivation / activation menu
$CRITMEN
 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option
 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'T') )
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif
Return

#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire
$SET_PRECHARGE
 PRECHARGE=G_OUI
Return
#=====================================================================
# Unitaire / massif : Critère de sélection particulier à l'action métier
$SET_CRITACT
  # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
  # Les biens modèles ou ceux ayant fait l'objet d'une sortie "réelle" sont exclus de la sélection
  # FQ95754_3 CRITACT=" (OWNTYP <> GVML_TDMODEL and ( ISSDAT = [0/0/0] or EXTISSFLG = G_OUI )) "
  CRITACT=" (OWNTYP <> GVML_TDMODEL AND SALCLSDAT = [0/0/0] and ( ISSDAT = [0/0/0] or EXTISSFLG = G_OUI )) "
Return
#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return
#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES From TRTFASMTC
Return
#=====================================================================
# Massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
$MAS1_LOCK_AUTRE
Return
#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
  Gosub OUVRE_TABLES From TRTFASMTC
Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
 If !GSERVEUR
  #If ( G_TRACE = G_OUI)   : Infbox "MAS1_ALIM_TMP1" : Endif
 Endif

  # Alimentation des tables temporaires
  #**************************
  Raz [F:TMP1]
  Raz [F:TPF1]
  [F:TMP1]FLGERR     = G_NON
  [F:TMP1]FLGMOD     = G_OUI

  # Chargement table temporaire TMPPLNFAS [F:TPF1] avec infos de chacun des plans d'amort [M:FASM]
  # >>>>>>>>>
  For nolign=1 To [M:FASM]NBLIG1
  #--- 0 ----
    If ([M:FASM]MTCFLG(nolign-1) = G_OUI  or ACTTYPGES= GTAMUNI)
      [F:TPF1]FLGERR = G_NON
      [F:TPF1]FLGMOD = G_OUI
      If (ACTTYPGES = GTAMUNI )
        [F:TPF1]FLGMOD     = G_NON
      Endif

      # Lecture DEPREC pour l'exercice et la période courante
      Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);
&                     [M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
      If (fstat)
        # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
        Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(nolign-1)
        Read [DEP]DEP0 Last
        Filter [DEP]
        If (fstat)
          RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(nolign-1))
          GOK=0 : Break
        Endif
      Endif
      If [F:DEP]ENDDPEFLG = G_OUI
         [F:TPF1]FLGERR = G_OUI
         [F:TPF1]FLGMOD = G_NON
      Endif
      # ------------------
      [F:TPF1]  = [F:DEP]
      # ------------------
      # Informations spécifiques
      [F:TPF1]TRTNUM     = NUMACT
      [F:TPF1]OBJREF     = [F:MAS1]AASREF
      [F:TPF1]DPMO       = [F:DEP]DPM

      # CBO 2012.07.17 FQ-80039
      [F:TPF1]DPMIO       = [F:DEP]DPMI
      If [F:TPF1]DPMIO = ""
          [F:TPF1]DPMIO = [F:DEP]DPM
      Endif

      [F:TPF1]DPMTO       = [F:DEP]DPMT
      If [F:TPF1]DPMTO = ""
          [F:TPF1]DPMTO = [F:DEP]DPM
      Endif

      [F:TPF1]MTCTIATYP  = [F:DEP]MTCTIATYP
      [F:TPF1]STRDPRDATO = [F:DEP]STRDPRDAT
      [F:TPF1]ENDDPRFLGO = [F:DEP]ENDDPRFLG
      [F:TPF1]ENDDPRDATO = [F:DEP]ENDDPRDAT
      [F:TPF1]FIYSTRDAT  = [F:DEP]FIYSTRDAT
      [F:TPF1]DPRDURO    = [F:DEP]DPRDUR
      [F:TPF1]DPRRATFLGO = [F:DEP]DPRRATFLG
      [F:TPF1]DPRRATO    = [F:DEP]DPRRAT
      [F:TPF1]DPRRAT2O   = [F:DEP]DPRRAT2
      [F:TPF1]RSDVALO    = [F:DEP]RSDVAL
      [F:TPF1]DPRBAS     = [F:DEP]DPRBAS
      [F:TPF1]DPRCUM     = [F:DEP]DPRCUM
      [F:TPF1]DPRCUMFLG  = [F:DEP]DPRCUMFLG
      [F:TPF1]PERCLOCUM  = [F:DEP]PERCLOCUM
      [F:TPF1]CRBVEHCODO = [F:DEP]CRBVEHCOD
      [F:TPF1]ALWCODO    = [F:DEP]ALWCOD
      [F:TPF1]PRATYPO    = [F:DEP]PRATYP
      [F:TPF1]ACLCOEO    = [F:DEP]ACLCOE
      [F:TPF1]ALWAMTO    = [F:DEP]ALWAMT
      Write [TPF1]
      If (fstat)
        Case fstat
          When 1
            # Erreur entrée sortie.
            RMES=mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=-1
          When 3
            # Tentative d'écriture en double
            RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=0
          When Default
            RMES=mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK = -1
        Endcase
        Break
      Else
        NBTMPPLN +=1
      Endif
    Endif
  #--- 0 ----
  Next
  # <<<<<<<<

  If (GOK <> 1 )
    Return
  Endif

  # Chargement table temporaire TMPFASMAS [F:TMP1] avec infos du bien comptable [F:MAS1]
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]CPY        = [F:MAS1]CPY
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]AASDES1    = [F:MAS1]AASDES1

  [F:TMP1]AASTYP     = [F:MAS1]AASTYP
  [F:TMP1]OWNTYP     = [F:MAS1]OWNTYP
  [F:TMP1]ACCCOD     = [F:MAS1]ACCCOD
  [F:TMP1]ACCCODO    = ""
  [F:TMP1]ACGGRP     = [F:MAS1]ACGGRP
  [F:TMP1]AASIPTDAT  = [F:MAS1]AASIPTDAT
  If (ACTMETNAM = "FASTRFC")
     [F:TMP1]ACCCODO    = [F:MAS1]ACCCOD
     [F:TMP1]ITSDAT     = [M:FASC]ITSDATD
  Endif
  Write [TMP1]
  If (fstat)
    Case fstat
      When 1
        # Erreur entrée sortie.
        RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
        GOK=-1
      When 3
        # Tentative d'écriture en double
        RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF+"/"+num$([F:TMP1]DPRPLN)
        GOK=0
      When Default
    Endcase
    Return
  Else
    NBTMP+=1
  Endif

Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:MAS1]))   : Local File FXDASSETS   [MAS1]   : Endif
Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

Local Char LMESSAGE
Local Integer LCDRET

Local Integer LOK, LERRBCO, LCABAUTO, LIMMAT
Local Date LDATE

 If !GSERVEUR
  #If ( G_TRACE = G_OUI)   : Infbox "TMP1_APPL_TMP1" : Endif
 Endif

  LOK = G_OUI

  RMES           = ""
  [F:TPF1]MSGERR = ""
  [F:TMP1]FLGMOD = G_NON

  If ( LOK <> G_OUI )
    [F:TMP1]FLGERR = G_OUI
    # Pas d'affichage des plans
    For [TPF1]TPF0 Where TRTNUM= [F:TMP1]TRTNUM and OBJREF=[F:TMP1]OBJREF
      [F:TPF1]FLGERR = G_NON
      Rewrite [F:TPF1]
    #------------------------------
    Next
  Endif

Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1

 If !GSERVEUR
  #If ( G_TRACE = G_OUI)   : Infbox "TPF1_APPL_TPF1" : Endif
 Endif

Local Integer I_PLN, LCOUR, LOK, LERROR, LCHGD, RETOUR

  # Lecture du bien dans MAS1
  Read [MAS1] FAS0=[F:TMP1]OBJREF
  If (fstat)   : GOK= 0 : Return : Endif

  # [F:TPF1] <- [M:FASM]
  # -------------------------------
  I_PLN=find([F:TPF1]DPRPLN,[M:FASM]DPRPLND) : # Rang du plan dans tableau paramètres

  # Initialisation des indicateurs
  LOK = G_OUI : LERROR = 0
  [F:TPF1]MSGERR = ""
  [F:TPF1]FLGERR = G_NON
  [F:TPF1]FLGMOD = G_OUI
  If (ACTTYPGES = GTAMUNI )   : [F:TPF1]FLGMOD = G_NON : Endif : # Si unitaire, Contrôler non modifiable
  LCHGD = G_NON : # Les paramètres de la méthode n'ont pas changé

  # Lecture DEPREC pour l'exercice et la période courante
  Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(I_PLN-1);
&                 [M:FASM]FIYENDDAT(I_PLN-1); [M:FASM]PERENDDAT(I_PLN-1)
  If ( fstat )
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(I_PLN-1)
    Read [DEP]DEP0 Last
    Filter [DEP]
    If (fstat)
      RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(I_PLN-1))
      GOK=0 : Return
    Endif
    LCOUR = G_NON
  Else
    LCOUR = G_OUI
  Endif

  # Contrôle
  If LCOUR = G_OUI & [F:DEP]ENDDPEFLG = G_OUI
       # "Au moins une erreur détectée sur un plan"
       [F:TMP1]MSGERR   =  mess(179,GML_MSGFAS,1)
        # La dotation exercice du plan a été forcée, la méthode du plan ne peut être changée.
       [F:TPF1]MSGERR   =  mess(375,GML_MSGFAS,1)- mess([F:DEP]DPRPLN,3101,1)- '-->' - mess(596, GML_MSGFAS,1)
       LOK = G_NON
       [F:TPF1]FLGMOD = G_NON
  Endif

  If ( LOK = G_OUI and LCOUR = G_NON )
    # Le bien n'est pas amorti dans l'exercice courant/période courante
    LERROR = 180 : LOK = G_NON
    [F:TPF1]FLGMOD = G_NON
  Endif

  # Toujours : Sauvegarde anciennes valeurs dans DEPW
  [F:DEPW] = [F:DEP]

  #--- 1 ---
  If ( ACTMETNAM =  "FASTRFC" ) & ([M:FASM]TRTFLG(I_PLN-1) <>  G_OUI  )  : LOK=G_NON : Endif

   # Application de la valeur des paramètres
   If ( LOK = G_OUI )
     # Nouvelles valeurs DEP
     Gosub ALIM_ENR_PLN From TRTFASMTC
     # Si la date de début d'amortissement a été saisie en paramètre
     # et qu'il ne s'agit pas d'une mise en service
     # la date de début d'amortissement ne doit pas être modifiée
     If ( ACTMETNAM =  "FASTRFC" )
          If ( ( [F:MAS1]GACACN = GVML_NIENSER or [M:FASC]GACACND <> GVML_NIENSER )
&               and  [F:DEP]STRDPRDAT  <> [F:DEPW]STRDPRDAT )
            [F:DEP]STRDPRDAT = [F:DEPW]STRDPRDAT
          Endif
        Endif
     Endif

  # Contrôle (Fq-79215 : ajout test sur MTCTIATYP)
  If ( LOK = G_OUI and
&      [F:DEP]DPM        = [F:DEPW]DPM       and
&      [F:DEP]STRDPRDAT  = [F:DEPW]STRDPRDAT and
&      [F:DEP]ENDDPRDAT  = [F:DEPW]ENDDPRDAT and
&      [F:DEP]DPRDUR     = [F:DEPW]DPRDUR    and
&      [F:DEP]DPRRAT     = [F:DEPW]DPRRAT    and
&      [F:DEP]DPRRAT2    = [F:DEPW]DPRRAT2   and
&      [F:DEP]RSDVAL     = [F:DEPW]RSDVAL    and
&      [F:DEP]CRBVEHCOD  = [F:DEPW]CRBVEHCOD and
&      [F:DEP]ALWCOD     = [F:DEPW]ALWCOD    and
&      [F:DEP]PRATYP     = [F:DEPW]PRATYP    and
&      [F:DEP]ALWAMT     = [F:DEPW]ALWAMT    and
&      [F:DEP]MTCTIATYP  = [F:DEPW]MTCTIATYP and
&      [F:DEP]ACLCOE     = [F:DEPW]ACLCOE     )
    # La méthode du plan n'a pas changé
    LERROR = 183 : LOK = G_NON
  Else
    LCHGD = G_OUI
  Endif

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI & [M:FPC]LEG="POL" & LOK = G_OUI & LCHGD=G_OUI
   If [F:DEP]KMDRDEV<>0
    LERROR         = 827
    LOK            = G_NON
    [F:TPF1]FLGMOD = G_NON
   Endif
  Endif
  #Fin-Pologne

  # Passage en mode résiduel si le bien a subi une clôture
  If ( LOK = G_OUI)
     Local Integer RETOUR
     If ( ACTMETNAM <>  "FASTRFC" )  or   ( G_MES=G_NON )
        # Pas de passage en résiduel pour un bien ayant subi une clôture et amorti en LP
        Call DETERM_MTCTIADAT( [M:FASM]MTCTIATYP(I_PLN-1),
&                              [M:FASM]FIYSTRDAT(I_PLN-1), [M:FASM]PERSTRDAT(I_PLN-1), [F:DEP]STRDPRDAT,
&                              [F:DEP]MTCTIADAT ) From TRTFASMTC
        #-Dès que la prise d'effet du changement est > à la date de début d'amortissement, on passe en mode résiduel
        #*Fq-60501 If  [F:DEP]MTCTIADAT > [F:DEP]STRDPRDAT  and
        If  [F:DEP]MTCTIADAT > [F:DEP]STRDPRDAT and [F:DEPW]DPM <> G_DPMSA  and
&         ( [F:DEP]DPM    <> [F:DEPW]DPM    or
&          [F:DEP]RSDVAL <> [F:DEPW]RSDVAL  or
&          [F:DEP]DPRDUR <> [F:DEPW]DPRDUR  or
&          [F:DEP]DPRRAT <> [F:DEPW]DPRRAT )
           Local Char    WDPM
           Local Integer GNRSD
           Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
           Local Integer L_PRATYP       # Type de prorata
           WDPM = [F:DEP]DPM
           # Si le mode résiduel existe.
           Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
           If ( ( L_RSDDPMTGR <>"" ) & (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> G_DPMSA )
              [F:DEP]DPM    = L_RSDDPMTGR
             If L_PRATYP > 0
               [F:DEP]PRATYP  = L_PRATYP
             Endif
           Endif
        Endif
     Endif
  Endif

 If (ACTTYPGES = GTAMMAS ) #Fq-89463 uniquement en Massif
     ##Fq-87928   #Fq-70482 Contrôle entre durées plan fiscal et plan de subvention
     Local Integer   I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND ) #Fq-89463
     Local Integer   I_SUB :  I_SUB=find(G301SUB,[M:FASM]DPRPLND ) #Fq-89463
#
           # On est sur le plan fiscal et on gère un plan de subvention
     If [F:DEP]DPRPLN = G301FIS  and GFRADGI=G_OUI and I_SUB > 0
           Local Decimal DPRDUR_FIS, DPRDUR_SUB
           DPRDUR_FIS = [F:DEP]DPRDUR
           ##Fq-87928       DPRDUR_SUB = DPRDUR_FIS
           ##Fq-87928       If [M:FASM]DPRDURD(I_SUB-1)> 0
           ##Fq-87928          [M:FASM]DPRDURD(I_SUB-1)= DPRDUR_SUB
           ##Fq-87928       Else
           # Lecture DEPREC pour l'exercice et la période courante
           If !clalev([F:DEPS]) : Local File DEPREC [DEPS] : Endif
           Read [DEPS] DEP0=[F:MAS1]AASREF;G301SUB;[M:FASM]FIYENDDAT(I_SUB-1);[M:FASM]PERENDDAT(I_SUB-1)
           If fstat=0
              If ( [F:DEPS]DPM <> G_DPMSA )
                 DPRDUR_SUB = [F:DEPS]DPRDUR
              Endif
           Endif
           ##Fq-87928  Endif
        #Fq-89463 If DPRDUR_SUB <> DPRDUR_FIS
        If ( [F:DEPS]DPM <>  G_DPMSA )  and ( DPRDUR_SUB <> DPRDUR_FIS )
              LERROR = 819 : LOK = G_NON : LCHGD = G_OUI
           Endif
        Endif
           # On est sur le plan de subvention et on gère un plan fiscal
      If [F:DEP]DPRPLN = G301SUB  and GFRADGI=G_OUI and  I_FIS > 0
           Local Decimal DPRDUR_FIS, DPRDUR_SUB
           DPRDUR_SUB = [F:DEP]DPRDUR
           # Lecture DEPREC pour l'exercice et la période courante
           If !clalev([F:DEPF]) : Local File DEPREC [DEPF] : Endif
           Read [DEPF] DEP0=[F:MAS1]AASREF;G301FIS;[M:FASM]FIYENDDAT(I_FIS-1);[M:FASM]PERENDDAT(I_FIS-1)
           If fstat=0
           #Fq-89463 If ( [F:DEPS]DPM <> G_DPMSA )
            If ( [F:DEPF]DPM <> G_DPMSA )
                 DPRDUR_FIS = [F:DEPF]DPRDUR
              Endif
           Endif
         #Fq-89463 If DPRDUR_SUB <> DPRDUR_FIS
         If ( [F:DEPF]DPM <>  G_DPMSA ) and ( [F:DEPS]DPM <>  G_DPMSA )  and ( DPRDUR_SUB <> DPRDUR_FIS )
              LERROR = 819 : LOK = G_NON : LCHGD = G_OUI
           Endif
        Endif
      Endif

  Gosub BEFORE_REWRITE_DEP From TRTFASMTC #Fq-74308

  # Contrôle - LERROR
   If ( LOK = G_OUI )
     # Contrôle des méthodes d'amortissement des plan du bien
     [M:METH] = [F:MAS1]
     [M:METH] = [F:DEP]
     [M:METH]FLGBCO = G_OUI
     #Infbox "Contrôle méthode - 1 (Massif / Unitaire par contrôler ou unitaire direct)"
     Call CONTROLE_METHODE () From TRTFAS
     # Si le mode d'amt n'est pas autorisé au plan, on met SA
     If ( [M:METH]MSGERR)
        If (ACTTYPGES = GTAMMAS )
           If [M:METH]MSGERR = 587 : [M:METH]MSGERR = 607 : Endif
            [F:TMP1]MSGERR  = mess(179,GML_MSGFAS,1) : # "Au moins une erreur détectée sur un plan"
            [F:TPF1]MSGERR  = '-->'- mess([M:METH]MSGERR,[M:METH]MSGFIL,1)
        Else
          LERROR = [M:METH]MSGERR
        Endif
        LOK = G_NON
     Endif
  Endif

  # Contrôle - LERROR
  If (LOK = G_OUI and [F:DEP]RSDVAL <> [F:DEPW]RSDVAL )
    # Contrôle de la valeur résiduelle
    # (Saisie complémentaire ne concerne pas MAS1_APPL_DIRT)
    Call CTRL_RSDVAL ([F:DEP]RSDVAL, [F:DEP]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYENDDAT, [F:DEP]PERENDDAT, LERROR ) From TRTFAS
    If ( LERROR )   : LOK = G_NON : Endif
  Endif

  # Contrôle - LERROR
  If ( LOK = G_OUI )
     If ( [F:DEP]DPM <> [F:DEPW]DPM )
        Read [CNX]CNX0= [F:DEP]CPY;[F:DEP]CNX
        # Si changement du mode d'amortissement
        # FQ82075 FQ105809
        If (( find([F:DEP]DPM, G_DPMLP,G_DPMSL,G_DPMTL) >0 ) and
&            [M:FASM]STRDPRDATD(I_PLN-1) < [M:FASM]FIYSTRDAT(I_PLN-1) ) and
&          ( [F:DEP]DPRCUM <> 0  and  [F:DEPW]DPM <> G_DPMSA  )
            #Fq-60501 If ( [F:DEPW]DPM <> G_DPMSA )  or  ( [F:CNX]FLUTRAACC (I_PLN) = G_OUI ) or  ( [F:CNX]FLUTRATXS (I_PLN)<> "" )
           # Le nouveau mode ne peut pas être LP s'il existe un cumul d'amortissement pour le plan.
           LERROR = 606 : LOK = G_NON
             #Fq-60501 Endif
        Endif
     Endif
  Endif

  # Contrôle - LERROR
  If ( LOK = G_OUI and [F:DEP]STRDPRDAT <> [F:DEPW]STRDPRDAT and [F:DEP]DPRCUM <> 0  )
    # Si bien clôturée le changement de date de début d'amortissement est interdit
    LERROR = 329 : LOK = G_NON
  Endif

 # Contrôle - LERROR
 If ( LOK = G_OUI and ([F:DEP]DPRRAT2 <> [F:DEPW]DPRRAT2
&                 or   [F:DEP]DPRRAT  <> [F:DEPW]DPRRAT )
&                 and  [F:DEP]DPM = G_DPMIT and G_DPMIT <> "")
   # Si Mode IT et changement de taux antipato, contrôles sur le taux anticipato
   If ( [F:DEP]DPRRAT2 > 0 )
     Local Integer L_NBANNMAX
     Local Integer L_NUMANNUITE
     Case [F:MAS1]PURNAT
      When GVML_NANEUF
       L_NBANNMAX = 3
      When GVML_NAOCCAS
       L_NBANNMAX = 1
     Endcase
     L_NUMANNUITE = func GLOBB8.TX_ANTICIPATO_PERMIS([F:DEPW]CPY,
&                                                    [F:DEPW]CNX,
&                                                    [F:MAS1]PURNAT,
&                                                    [F:DEPW]STRDPRDAT,
&                                                    [F:DEPW]FIYSTRDAT,
&                                                    [F:DEPW]FIYENDDAT)
     # Test sur le numéro d'annuité
     If ( [F:DEP]DPRRAT2 > 0 & L_NUMANNUITE > L_NBANNMAX)
       # Amt Anticipato ne peut être appliqué au delà de trois ans pour les biens neufs, d'un an pour les biens d'occasion
       If  L_NBANNMAX=1
        LERROR = 489
       Elsif L_NBANNMAX=3
        LERROR = 490
       Endif
       LOK = G_NON
     Endif
     # Test de la valeur du taux anticipato par rapport au taux oridinario
     If ( [F:DEP]DPRRAT2 > [F:DEP]DPRRAT)
       LERROR = 483 : LOK = G_NON
     Endif
   Endif
 Endif

  # Gestion message - LOK - LERROR
  If ( LOK = G_NON and LERROR <> 0 )
     RMES = mess(83,GML_MSGFAS,1)- '-->' - mess(LERROR,GML_MSGFAS,1)
     [F:TMP1]MSGERR    = mess(179,GML_MSGFAS,1) : # "Au moins une erreur détectée sur un plan"
     [F:TPF1]MSGERR    = mess(LERROR,GML_MSGFAS,1)
  Endif
  # ------------------
  If ( LOK = G_OUI )
     Call DETERM_MTCTIADAT( [M:FASM]MTCTIATYP(I_PLN-1),
&                           [M:FASM]FIYSTRDAT(I_PLN-1), [M:FASM]PERSTRDAT(I_PLN-1), [F:DEP]STRDPRDAT,
&                           [F:DEP]MTCTIADAT ) From TRTFASMTC

   If [M:FASM] MTCTIATYP(I_PLN-1) = GVML_PEDBPE
      [F:DEP]PERREFCLC  = [M:FASM]PERSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCI = [M:FASM]PERSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCT = [M:FASM]PERSTRDAT(I_PLN-1)
   Else
      [F:DEP]PERREFCLC  = [M:FASM]FIYSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCI = [M:FASM]FIYSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCT = [M:FASM]FIYSTRDAT(I_PLN-1)
   Endif
 #Fq-84623  [F:DEP]DPRCUMFLG = [M:FASM]DPRCUMFLG(I_PLN-1) #Fq-78438
   [F:DEP]MTCDPEDAT = [F:DEP]MTCTIADAT
   [F:DEP]DEPSTA    = GVML_SCNOCAL

   #FQ76303 FQ77877 FQ84283 FQ84281 FQ105809
   If find([F:DEP]DPM, G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMDP, G_DPMDI, G_DPMRE,
&                       G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMSY,  G_DPMUO, G_DPMDV, G_DPMRA, G_DPMDM, G_DPMML,
&                       G_DPMRX, G_DPMRD, G_DPMAL, G_DPMAD, G_DPMHL )  &
&           [F:DEP]DPRRATFLG=G_OUI
      [F:DEP]DPRRATFLG=G_NON
   Endif
    # Si tout est OK la table temporaire est mise à jour telle que la méthode est actualisée
    [F:TPF1]  = [F:DEP]
  Else
    # En cas d'erreur la table temporaire est mise à jour telle que le plan conserve son ancienne méthode
    [F:TPF1]  = [F:DEPW]
    If ( LCHGD = G_NON and ACTTYPGES = GTAMUNI)
      # Si on est en unitaire et qu'aucun paramètre saisi pour le plan
      # ou que les paramètres saisis ne modifie pas le plan => pas d'erreur
      RMES = ""
      If ( [F:TMP1]FLGERR <> G_OUI )
        [F:TMP1]MSGERR    = ""
      Endif
      [F:TPF1]MSGERR    = ""
    Else
      [F:TPF1]FLGERR = G_OUI
      [F:TMP1]FLGERR = G_OUI
    Endif
  Endif
  # ------------------



Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
  # Maj des champs UPDx 9
  [M:FAS9]UPDUSR=GUSER
  [M:FAS9]UPDDAT=date$
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK

Local Integer I_PLN
Local Integer RETOUR

 If !GSERVEUR
     #If ( G_TRACE = G_OUI)   : Infbox "TPF1_ALIM_MASK" : Endif
 Endif

  I_PLN=find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)

  If  not ( [M:FAS3]STRDPRDAT(I_PLN-1) = [F:TPF1]STRDPRDAT   and
&           [M:FAS3]ENDDPRFLG(I_PLN-1) = [F:TPF1]ENDDPRFLG   and
&           [M:FAS3]ENDDPRDAT(I_PLN-1) = [F:TPF1]ENDDPRDAT   and
&           [M:FAS3]DPM(I_PLN-1)       = [F:TPF1]DPM         and
&           [M:FAS3]DPRDUR(I_PLN-1)    = [F:TPF1]DPRDUR      and
&           [M:FAS3]DPRRATFLG(I_PLN-1) = [F:TPF1]DPRRATFLG   and
&           [M:FAS3]DPRRAT(I_PLN-1)    = [F:TPF1]DPRRAT      and
&           [M:FAS3]DPRRAT2(I_PLN-1)   = [F:TPF1]DPRRAT2     and
&           [M:FAS3]RSDVAL(I_PLN-1)    = [F:TPF1]RSDVAL      and
&           [M:FAS3]CRBVEHCOD(I_PLN-1) = [F:TPF1]CRBVEHCOD   and
&           [M:FAS3]ALWCOD(I_PLN-1)    = [F:TPF1]ALWCOD      and
&           [M:FAS3]PRATYP(I_PLN-1)    = [F:TPF1]PRATYP      and
&           [M:FAS3]ALWAMT(I_PLN-1)    = [F:TPF1]ALWAMT      and
&           [M:FAS3]ACLCOE(I_PLN-1)    = [F:TPF1]ACLCOE           )

    If dim(ACTMODIF)>0  : ACTMODIF=1 : Endif
     # En norme française, le plan de subvention n'est modifiable que via le plan fiscal
    [M:FAS3]DEPSTA(I_PLN-1)        = GVML_SCNOCAL
    [M:FAS3]MTCDEVADJ(I_PLN-1)     = [F:TPF1]MTCDEVADJ
    [M:FAS3]STRDPRDAT(I_PLN-1)     = [F:TPF1]STRDPRDAT
    [M:FAS3]ENDDPRFLG(I_PLN-1)     = [F:TPF1]ENDDPRFLG
    [M:FAS3]ENDDPRDAT(I_PLN-1)     = [F:TPF1]ENDDPRDAT
    [M:FAS3]DPM(I_PLN-1)           = [F:TPF1]DPM
    [M:FAS3]DPMI(I_PLN-1)          = [F:TPF1]DPM
    [M:FAS3]DPMT(I_PLN-1)          = [F:TPF1]DPM
    [M:FAS3]DPRDUR(I_PLN-1)        = [F:TPF1]DPRDUR
    [M:FAS3]DPRRATFLG(I_PLN-1)     = [F:TPF1]DPRRATFLG
    [M:FAS3]DPRRAT(I_PLN-1)        = [F:TPF1]DPRRAT
    [M:FAS3]DPRRAT2(I_PLN-1)       = [F:TPF1]DPRRAT2
    [M:FAS3]RSDVAL(I_PLN-1)        = [F:TPF1]RSDVAL
    [M:FAS3]CRBVEHCOD(I_PLN-1)     = [F:TPF1]CRBVEHCOD
    [M:FAS3]ALWCOD(I_PLN-1)        = [F:TPF1]ALWCOD
    [M:FAS3]PRATYP(I_PLN-1)        = [F:TPF1]PRATYP
    [M:FAS3]ALWAMT(I_PLN-1)        = [F:TPF1]ALWAMT
    [M:FAS3]ACLCOE(I_PLN-1)        = [F:TPF1]ACLCOE
    [M:FAS3]MTCTIATYP(I_PLN-1)     = [F:TPF1]MTCTIATYP
    [M:FAS3]MTCTIADAT(I_PLN-1)     = [F:TPF1]MTCTIADAT
    [M:FAS3]DPRCUMFLG(I_PLN-1)     = [F:TPF1]DPRCUMFLG #Fq-78438

   # FQ122001
   If [M:FAS3] MTCTIATYP(I_PLN-1) = GVML_PEDBPE
      [M:FAS3]PERREFCLC(I_PLN-1)  = [M:FAS3]PERSTRDAT(I_PLN-1)
      [M:FAS3]PERREFCLCI(I_PLN-1) = [M:FAS3]PERSTRDAT(I_PLN-1)
      [M:FAS3]PERREFCLCT(I_PLN-1) = [M:FAS3]PERSTRDAT(I_PLN-1)
   Else
      [M:FAS3]PERREFCLC(I_PLN-1)  = [M:FAS3]FIYSTRDAT(I_PLN-1)
      [M:FAS3]PERREFCLCI(I_PLN-1) = [M:FAS3]FIYSTRDAT(I_PLN-1)
      [M:FAS3]PERREFCLCT(I_PLN-1) = [M:FAS3]FIYSTRDAT(I_PLN-1)
   Endif

    [M:FAS3] MTCDPEDAT(I_PLN-1) =   [M:FAS3]MTCTIADAT(I_PLN-1)

    If (  ( G_DPMSA  <> "" and [M:FAS3]DPM(I_PLN-1) = G_DPMSA )
&      or ( G_DPMUO  <> "" and [M:FAS3]DPM(I_PLN-1) = G_DPMUO ) )
       # Si mode d'amort = "SA" ou "UO" alors le flag taux d'amort non forcé
       [M:FAS3]DPRRATFLG(I_PLN-1) = G_NON
    Endif
    # Contexte, Bien à recalculer
    [M:FAS0]FLGCLC                      = G_OUI
    [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I_PLN-1)-1)    = G_OUI
  Endif

  Call MAJFLGCNXFLX("[M:FAS0]", "", [F:TPF1]CNX, num$(GVML_FLXNOTG)) From TRTFAS : # FQ66894
Return
#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
$REAF_ALIM_MASK
  Affzo [M:FAS0]
  Affzo [M:FAS3]
  Affzo [M:FAS9]
Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_DIRT
$OUVR_APPL_DIRT
  Gosub OUVRE_TABLES From TRTFASMTC
  # Société courante : rupture société pour émission en-tête trace
  Local Char   TRC_CPY    : Raz TRC_CPY
  Local Char   TRC_AASREF : Raz TRC_AASREF
Return
#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT
#------------------------------------------
# -----   GOK = 0 : Erreur provoquant l'arrêt de la procédure : DEP et MAS1 subissent un rollback
# -----   MAS1 contient les informations du bien
# -----   DEPW contient les anciennes valeurs du plan
# -----   DEP  contient les nouvelles valeurs du plan
# -----   La mise à jour des données dans MAS1 et DEP est à la charge du programme (rewrite).
# La table DEPREC située à l'intérieur d'un trbegin subit également un rollback en cas d'erreur

If !GSERVEUR
 #If ( G_TRACE = G_OUI)   : Infbox "MAS1_APPL_DIRT" : Endif
Endif

Local Integer LCDRET, LERROR, LOK, LCOUR, I_PLN
Local Char    LCDINT(10)
Local Char    TABORI
Local Char    LMESSAGE
Local Integer I_ERREUR

  #-> A rupture société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY )
    Gosub ECR_ENT_PLN
    TRC_CPY=[F:MAS1]CPY
  Endif

  # Initialisation des indicateurs
  LOK = G_OUI : LERROR = 0
  G_INCR = G_OUI : # Erreur à n'incrémenter qu'une seule fois

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign=1  To  [M:FASM]NBLIG1
    #--- 1 ----
    #FQ-84037 If ( [M:FASM]MTCFLG(nolign-1) <> G_OUI ) : break : Endif
    If ( [M:FASM]MTCFLG(nolign-1) <> G_OUI ) : Goto NEXTPLN : Endif    : # Changement de méthode pour le plan

     # Lecture DEPREC pour l'exercice et la période courante
     Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);
&                    [M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
     If (fstat)
        # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
        Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(nolign-1)
        Read [DEP]DEP0 Last
        Filter [DEP]
        If (fstat)
          # Erreur technique
          RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(nolign-1))
          GOK=0 : Return
        Endif
        LCOUR = G_NON
      Else
        LCOUR = G_OUI
      Endif

     # Contrôle dotation exercice
     If LCOUR = G_OUI & [F:DEP]ENDDPEFLG = G_OUI
        # La dotation exercice du plan a été forcée, la méthode du plan ne peut être changée.
       LERROR = 596 : LOK = G_NON
     Endif

     #Fq-70482 Contrôle entre durées plan fiscal et plan de subvention
     #Fq-87928 If  [M:FASM]DPRPLND(nolign-1) = G301FIS and (func GLOFCYCPY.GET_SOC_LEG([F:MAS1]CPY) = "FRA")
     Local Integer  I_SUB  :    I_SUB=find(G301SUB,[M:FASM]DPRPLND)
     Local Integer  I_FIS  :    I_FIS=find(G301FIS,[M:FASM]DPRPLND)
     If  [M:FASM]DPRPLND(nolign-1) = G301FIS and GFRADGI=G_OUI and I_SUB > 0
        If  [M:FASM]DPRDURD(nolign-1) > 0
              If ( [M:FASM]DPRDURD(I_SUB-1) <> 0 and  [M:FASM]DPRDURD(nolign-1)<> [M:FASM]DPRDURD(I_SUB-1) ) or
&                ( [M:FASM]DPRDURD(I_SUB-1) = 0  and  [M:FASM]DPRDURD(nolign-1)<> [M:FASM]DPRDURO(I_SUB-1) )
                 LERROR = 819 : LOK = G_NON
              Endif
           Endif
        Endif
     If  [M:FASM]DPRPLND(nolign-1) = G301SUB and GFRADGI=G_OUI and I_FIS > 0
        If  [M:FASM]DPRDURD(nolign-1) > 0
              If ( [M:FASM]DPRDURD(I_FIS-1) <> 0 and  [M:FASM]DPRDURD(nolign-1)<> [M:FASM]DPRDURD(I_FIS-1) ) or
&                ( [M:FASM]DPRDURD(I_FIS-1) = 0  and  [M:FASM]DPRDURD(nolign-1)<> [M:FASM]DPRDURO(I_FIS-1) )
                 LERROR = 819 : LOK = G_NON
              Endif
           Endif
        Endif

      # Sauvegarde anciennes valeurs du plan dans DEPW
      [F:DEPW] = [F:DEP]

      # Trace anciennes valeurs pour le plan du bien ( à partir de DEPW)
      Gosub ECR_PLN_OLD

      # Contrôle
      If ( LOK = G_OUI and LCOUR <> G_OUI )
        # Le bien n'est pas amorti dans l'exercice courant/période courante
        LERROR = 180 : LOK = G_NON
      Endif

      # Application de la valeur des paramètres
      If ( LOK = G_OUI )
        I_PLN = nolign
        Gosub ALIM_ENR_PLN From TRTFASMTC : # ( anciennes valeurs dans DEPW )
      Endif

      # Contrôle
      If (  LOK = G_OUI and
&           [F:DEP]DPM       = [F:DEPW]DPM       and
&           [F:DEP]STRDPRDAT = [F:DEPW]STRDPRDAT and
&           [F:DEP]ENDDPRDAT = [F:DEPW]ENDDPRDAT and
&           [F:DEP]DPRDUR    = [F:DEPW]DPRDUR    and
&           [F:DEP]DPRRAT    = [F:DEPW]DPRRAT    and
&           [F:DEP]DPRRAT2   = [F:DEPW]DPRRAT2   and
&           [F:DEP]RSDVAL    = [F:DEPW]RSDVAL    and
&           [F:DEP]CRBVEHCOD = [F:DEPW]CRBVEHCOD and
&           [F:DEP]ALWCOD    = [F:DEPW]ALWCOD    and
&           [F:DEP]PRATYP    = [F:DEPW]PRATYP    and
&           [F:DEP]ALWAMT    = [F:DEPW]ALWAMT    and
&           [F:DEP]ACLCOE    = [F:DEPW]ACLCOE      )
        # "Après application des paramètres, la méthode est inchangée
        LERROR = 183 : LOK = G_NON
      Endif

      #Fq67577-Pologne
      If G_ACTKPL=G_OUI & [M:FPC]LEG="POL" & LOK = G_OUI
       If [F:DEP]KMDRDEV<>0
        LERROR         = 827
        LOK            = G_NON
       Endif
      Endif
      #Fin-Pologne

      # Dès que la prise d'effet du changement est > à la date de début d'amortissement, on passe en mode résiduel
      Local Integer RETOUR
      If ( ACTMETNAM <>  "FASTRFC" )  or   ( G_MES=G_NON )
         #*Fq-60501 If ( [F:DEP]MTCTIADAT > [F:DEP]STRDPRDAT and [F:DEPW]DPM <> G_DPMSA ) and
         #*Fq-79215 ajout test sur MTCTIATYP
         If ( [F:DEP]MTCTIADAT > [F:DEP]STRDPRDAT and [F:DEPW]DPM <> G_DPMSA ) and
&           ( [F:DEP]DPM    <> [F:DEPW]DPM    or
&             [F:DEP]RSDVAL <> [F:DEPW]RSDVAL or
&             [F:DEP]DPRDUR <> [F:DEPW]DPRDUR or
&             [F:DEP]DPRRAT <> [F:DEPW]DPRRAT or
&             [F:DEP]MTCTIATYP <> [F:DEPW]MTCTIATYP )
            Local Char    WDPM
            Local Integer GNRSD
            Local Char    L_RSDDPMTGR    # Mode résiduel
            Local Integer L_PRATYP       # Type de prorata
            WDPM = [F:DEP]DPM
            # Si le mode résiduel cible est vide ou identique, on sort.
            Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
            If ( ( L_RSDDPMTGR <>"" ) & ( L_RSDDPMTGR <>  WDPM ) ) and (  WDPM <> G_DPMSA )
                  [F:DEP]DPM    = L_RSDDPMTGR
               If L_PRATYP > 0
                  [F:DEP]PRATYP  = L_PRATYP
               Endif
            Endif
         Endif
      Endif

      Gosub BEFORE_REWRITE_DEP From TRTFASMTC #Fq-74308

    If ( LOK = G_OUI )
       # Contrôle des méthodes d'amortissement du plan du bien
       [M:METH]       = [F:MAS1]
       [M:METH]       = [F:DEP]
       [M:METH]FLGBCO = G_OUI
       # Infbox "Contrôle méthode - 2 ( Massif direct )"
       Call CONTROLE_METHODE () From TRTFAS
       #X3-61112 If ( [M:METH]MSGERR  )
       If ( [M:METH]MSGERR  ) and  [M:METH]MSGERR <> 942
          If [M:METH]MSGERR = 587 : [M:METH]MSGERR = 607 :   Endif
          LERROR = [M:METH]MSGERR :   LOK    = G_NON
       Endif
    Endif

     # Contrôle
     If ( LOK = G_OUI and  [F:DEP]DPM <> [F:DEPW]DPM )
        Read [CNX]CNX0= [F:DEP]CPY;[F:DEP]CNX
        # Si changement du mode d'amortissement
        ##Fq-60501 If ( [F:DEP]DPM = G_DPMLP and [F:DEPW]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) )
        # FQ82075 105809
        # Le nouveau mode ne peut pas être LP s'il existe un cumul d'amortissement pour le plan.
        If (( find([F:DEP]DPM, G_DPMLP,G_DPMSL,G_DPMTL)>0) and
&           [M:FASM]STRDPRDATD(nolign-1) < [M:FASM]FIYSTRDAT(nolign-1) ) and
&         ( [F:DEP]DPRCUM <> 0   and [F:DEPW]DPM <>  G_DPMSA)
           LERROR = 606 : LOK = G_NON
        Endif
     #Fq-84623 Endif

        #Fq-84623  Read [CNX]CNX0= [F:DEP]CPY;[F:DEP]CNX
        # FQ82075 105809
        If (( find([F:DEP]DPM, G_DPMLP,G_DPMSL,G_DPMTL)>0) and
&       [M:FASM]STRDPRDATD(nolign-1) < [M:FASM]FIYSTRDAT(nolign-1) ) and
&          ( [F:DEP]DPRCUM <> 0   or  [F:CNX]FLUTRAACC(I_PLN) = G_OUI or  [F:CNX]FLUTRATXS(I_PLN)<> ""   )
          LERROR = 606 : LOK = G_NON
        Endif
     Endif #Fq-84623

    # Contrôle
     If ( LOK = G_OUI and [F:DEP]STRDPRDAT <> [F:DEPW]STRDPRDAT and
&        [F:DEP]DPRCUM <> 0  )
        # Si bien clôturée le changement de date de début d'amortissement est interdit
      LERROR = 329 : LOK = G_NON
    Endif

 # Contrôle - LERROR
 If ( LOK = G_OUI and ([F:DEP]DPRRAT2 <> [F:DEPW]DPRRAT2
&                 or   [F:DEP]DPRRAT  <> [F:DEPW]DPRRAT)
&                 and  [F:DEP]DPM = G_DPMIT and G_DPMIT <> "")
   # Si Mode IT et changement de taux antipato, contrôles sur le taux anticipato
   If ( [F:DEP]DPRRAT2 > 0 )
     Local Integer L_NBANNMAX
     Case [F:MAS1]PURNAT
      When GVML_NANEUF
       L_NBANNMAX = 3
      When GVML_NAOCCAS
       L_NBANNMAX = 1
     Endcase
     # Test sur le numéro d'annuité
     If ( [F:DEP]DPRRAT2 > 0  &
&       func GLOBB8.TX_ANTICIPATO_PERMIS([F:DEPW]CPY,
&                                        [F:DEPW]CNX,
&                                        [F:MAS1]PURNAT,
&                                        [F:DEPW]STRDPRDAT,
&                                        [F:DEPW]FIYSTRDAT,
&                                        [F:DEPW]FIYENDDAT ) > L_NBANNMAX  )
       # Amt Anticipato ne peut être appliqué au delà de trois ans pour les biens neufs, d'un an pour les biens d'occasion
       If  L_NBANNMAX=1
        LERROR = 489
       Elsif L_NBANNMAX=3
        LERROR = 490
       Endif
       LOK = G_NON
     Endif
     # Test de la valeur du taux anticipato par rapport au taux oridinario
     If ( [F:DEP]DPRRAT2 > [F:DEP]DPRRAT)
       LERROR = 483 : LOK = G_NON
     Endif
   Endif
 Endif

    # Gestion message  - LOK - LERROR
    If ( LOK = G_NON and LERROR <> 0)
      # Erreur  - détail de l'erreur dans la trace
        If ACTSILENCE<>G_OUI
         Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [F:DEP]DPRPLN, G_INCR, mess(LERROR,GML_MSGFAS,1))
&            From TRCPROCOM
        If (G_INCR = G_OUI)   : G_INCR = G_NON : Endif
        Else
         G_MAJOK = G_NON
         If ( ( I_OBJ>0 & GT_OBJ_REF(I_OBJ-1)<> [F:MAS1]AASREF ) | (I_OBJ=0) )
            GT_OBJ_REF(I_OBJ)    = [F:MAS1]AASREF
            GT_OBJ_DES(I_OBJ)    = [F:MAS1]AASDES1 : I_OBJ+=1
         Endif
         GT_LIS_ERR(I_ERREUR) = mess([F:DEP]DPRPLN,3101,1)-":"-mess(LERROR,GML_MSGFAS,1) : I_ERREUR+=1
      Endif
    Endif
      #------------
      If (LOK = G_OUI )
        If ( FLGSIM = G_NON )
           Call DETERM_MTCTIADAT( [M:FASM]MTCTIATYP(nolign-1),
&                                 [M:FASM]FIYSTRDAT(nolign-1), [M:FASM]PERSTRDAT(nolign-1), [F:DEP]STRDPRDAT,
&                                 [F:DEP]MTCTIADAT ) From TRTFASMTC
          # Si le mode actuel est "LP - Linéaire pur"
          # FQ82075 FQ105809
          If (( find([F:DEPW]DPM, G_DPMLP,G_DPMSL, G_DPMTL) >0) and
&            not find([F:DEP]DPM, G_DPMRE,G_DPMUO,G_DPMSA))
             # - déb amort < deb exercice et prise d'effet <> déb amort
             # ou
             # - déb amort > deb exercice et < déb per et prise d'effet =  déb per
             #-------------------------------------------
             If ( [F:DEP]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) and [M:FASM]MTCTIATYP(nolign-1)<> GVML_PEDBAM ) or
&               ( [F:DEP]STRDPRDAT > [M:FASM]FIYSTRDAT(nolign-1) and [F:DEP]STRDPRDAT < [M:FASM]PERSTRDAT(nolign-1) and
&                                                                    [M:FASM]MTCTIATYP(nolign-1)= GVML_PEDBPE )
                Local Char    WDPM
                Local Integer GNRSD
                Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
                Local Integer L_PRATYP       # Type de prorata
                WDPM = [F:DEPW]DPM
                # Si le mode résiduel existe.
                Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
                #Fq-56015 If ( ( L_RSDDPMTGR<>"" ) | (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> "SA" )
                If ( (  L_RSDDPMTGR <>"" ) & (L_RSDDPMTGR <>  WDPM ) ) and (  WDPM <> G_DPMSA )
                   [F:DEP]DPM    = L_RSDDPMTGR
                   #*FQ-58289 [F:DEP]PRATYP = L_PRATYP
                   #*FQ-58289
                   If L_PRATYP > 0
                     [F:DEP]PRATYP  = L_PRATYP
                   Endif
                Endif
             Endif
          Endif
          #-------------------------------------------
          # Génération d'un évènement
          LCDINT= "FASMTC"+num$([F:DEP]DPRPLN)
          Global Char     GFAS, GDPO, GDPN
          Local Date LDATCPT
          LDATCPT = max( [M:FASM]PERSTRDAT(nolign-1), [F:DEP]STRDPRDAT)
          GFAS = "[F:MAS1]"
          GDPO = "[F:DEPW]"
          GDPN = "[F:DEP]"
          Call GENER_EVE
&            (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]MTCTIADAT,LDATCPT,LCDRET)
&         From GENEVE
          If (LCDRET > 20)
            # Erreur technique
            RMES = mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
            GOK=0 : Return
          Endif
        Endif

        # Trace nouvelles valeurs pour le bien
        Gosub ECR_PLN_NEW

        # Mise à jour DEPREC
        If ( FLGSIM = G_NON )
           If [M:FASM] MTCTIATYP(I_PLN-1) = GVML_PEDBPE
              [F:DEP]PERREFCLC  = [M:FASM]PERSTRDAT(I_PLN-1)
              [F:DEP]PERREFCLCI = [M:FASM]PERSTRDAT(I_PLN-1)
              [F:DEP]PERREFCLCT = [M:FASM]PERSTRDAT(I_PLN-1)
           Else
              [F:DEP]PERREFCLC  = [M:FASM]FIYSTRDAT(I_PLN-1)
              [F:DEP]PERREFCLCI = [M:FASM]FIYSTRDAT(I_PLN-1)
              [F:DEP]PERREFCLCT = [M:FASM]FIYSTRDAT(I_PLN-1)
           Endif
           # Plan à recalculer
           [F:DEP]DEPSTA     =  GVML_SCNOCAL
#Fq-84623  [F:DEP]DPRCUMFLG = [M:FASM]DPRCUMFLG(I_PLN-1) #Fq-78438
           [F:DEP]MTCDPEDAT  =  [F:DEP]MTCTIADAT # ajouté car testé dans la réévaluation (MWA:27-02-2008)

           Gosub BEFORE_REWRITE_DEP From TRTFASMTC
          #---------------
          Rewrite [DEP]
          #---------------
          If (fstat)
            # Erreur technique
            RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)-[F:DEP]AASREF+"/"+num$([M:DEP]DPRPLN(nolign-1))
            GOK=0 : Return
          Endif
        Endif
      Endif
      #------------
      If ( FLGSIM = G_NON )
       [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
      Endif
   #--- 1 ---
   If ( FLGSIM = G_NON )
      #les indicateurs du bien et du contexte sont mis "à recalculer"
       [F:MAS1]FLGCLC = G_OUI
      # Maj des infos UPD du bien comptable
      [F:MAS1]UPDUSR=GUSER
      [F:MAS1]UPDDAT=date$
      #*FQ92611 [F:MAS1]UPDTIM=time
      Rewrite [MAS1]
      If fstat
         #Erreur technique
         RMES= mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF
         GOK=0 : Return
      Endif
   Endif
   $NEXTPLN #FQ-84037
 Next nolign
  #<<<<<<<<<<<<

Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE

If !GSERVEUR
 #If ( G_TRACE = G_OUI)   : Infbox "OUVRE_ALIM_TABLE" : Endif
Endif

  Gosub OUVRE_TABLES From TRTFASMTC

  # Société courante : rupture société pour émission en-tête trace
  Local Char TRC_CPY    : Raz TRC_CPY
  Local Char TRC_AASREF : Raz TRC_AASREF
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE

  If !GSERVEUR
    #If ( G_TRACE = G_OUI)   : Infbox "TMP1_ALIM_TABLE" : Endif
  Endif

  # Pour chaque bien de la table TMPMASFAS,
  # transfert des infos de TMPMASFAS [TMP1] dans la table FXDASSETS [MAS1]
  # Pas de rewrite : la mise à jour est prise en charge par le traitement standard

  #-> A rupture société on émet un en-tête dans la trace
  If ( [F:TMP1]CPY <> TRC_CPY and ACTTYPGES = GTAMMAS )
    Gosub ECR_ENT_PLN
    TRC_CPY=[F:TMP1]CPY
  Endif

  #- On n'émet le message d'erreur ici que si l'erreur est de niveau BCO
  If [F:TMP1]FLGERR=G_OUI & [F:TMP1]MSGERR<>mess(179,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:TMP1]CPY, [F:TMP1]OBJREF, 0, G_OUI, mess(411,GML_MSGFAS,1)) From TRCPROCOM
  Endif

  G_INCR = G_OUI

 [F:MAS1]FLGCLC            = G_OUI
 For [CNX]CNX0 Where CPY=[F:TMP1]CPY
    [F:MAS1]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
 Next

 # Maj des infos UPD du bien comptable
 [F:MAS1]UPDUSR=GUSER
 [F:MAS1]UPDDAT=date$
 #*FQ92611 [F:MAS1]UPDTIM=time

Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de données annexe
$TPF1_ALIM_TABLE

Local Integer I_PLN
  # [F:TPF1] <- [M:FASM]
  # -------------------------------
  I_PLN=find([F:TPF1]DPRPLN,[M:FASM]DPRPLND) : # Rang du plan dans tableau paramètres

If !GSERVEUR
 #If ( G_TRACE = G_OUI)   : Infbox "TPF1_ALIM_TABLE" : Endif
Endif

# Transfert des zones [TPF1] dans l'enregistrement de la table choisie à mettre à jour
# rewrite de la table choisie. Utiliser GOK pour interrompre le traitement.
# Pour chaque bien de la table TMPPLNFAS,
# transfert des infos de TMPPLNFAS [TPF1] dans la table DEPREC [DEP]
# Rewrite à effectuer : la mise à jour n'est pas prise en charge par le traitement standard

Local Integer LCDRET, LOK
Local Char    LCDINT(10)
Local Integer LPLNSTD

  # On passe dans nnnn_ALIM_TABLE en massif et en unitaire
  # Ceci afin de rendre possible la génération des événements en unitaire
  # En unitaire, le reste des opérations est pris en charge par la transaction appelante (nnnn_ALIM_MASK)
  # (pas de trace pas de mise à jour du bien courant)
  # La fonction IS_OBJ_MAIN oui/non permet de savoir s'il s'agit du bien traité dans l'appelant
  # dont les plans sont mis à jour par l'appelant à différencier des autres biens (ex: composant)
  # qui eux sont à mettre à jour.


  #-Si erreur de niveau BCO, on traite pas les plans
  If ( [F:TMP1]FLGERR = G_OUI & [F:TMP1]MSGERR<>mess(179,GML_MSGFAS,1))   : Return : Endif

  Read [DEP]DEP0=[F:TPF1]OBJREF;[F:TPF1]DPRPLN;[F:TPF1]FIYENDDAT;[F:TPF1]PERENDDAT
  #=== 1 =======
  If (fstat)
     If (ACTTYPGES = GTAMMAS)   : # Massif uniquement
        # Erreur technique
        RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN+"/")
     Endif
     GOK=0 : Return
  #=== 1 =======
  Else
     # Sauvegarde ancienne valeur
     [F:DEPW] = [F:DEP]

    Gosub ECR_PLN_OLD  # Massif uniquement

     # Impression d'un message d'erreur
     If ([F:TPF1]MSGERR <> "" and ACTTYPGES = GTAMMAS )
        Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [F:TPF1]DPRPLN, G_INCR, [F:TPF1]MSGERR) From TRCPROCOM
        If (G_INCR = G_OUI)   : G_INCR = G_NON : Endif
     Endif
     LOK = G_NON

     If ( [F:DEP]STRDPRDAT <> [F:TPF1]STRDPRDAT )   : [F:DEP]STRDPRDAT = [F:TPF1]STRDPRDAT : LOK = G_OUI : Endif
     If ( [F:DEP]ENDDPRFLG <> [F:TPF1]ENDDPRFLG )   : [F:DEP]ENDDPRFLG = [F:TPF1]ENDDPRFLG : LOK = G_OUI : Endif
     If ( [F:DEP]ENDDPRDAT <> [F:TPF1]ENDDPRDAT )   : [F:DEP]ENDDPRDAT = [F:TPF1]ENDDPRDAT : LOK = G_OUI : Endif
     If ( [F:DEP]DPM       <> [F:TPF1]DPM       )   : [F:DEP]DPM       = [F:TPF1]DPM       : LOK = G_OUI : Endif
     # CBO 2012.07.23 FQ80039
     [F:DEP]DPMI       = [F:TPF1]DPMI
     [F:DEP]DPMT       = [F:TPF1]DPMT
     If ( [F:DEP]DPRDUR    <> [F:TPF1]DPRDUR    )   : [F:DEP]DPRDUR    = [F:TPF1]DPRDUR    : LOK = G_OUI : Endif
     If ( [F:DEP]DPRRATFLG <> [F:TPF1]DPRRATFLG )   : [F:DEP]DPRRATFLG = [F:TPF1]DPRRATFLG : LOK = G_OUI : Endif
     If ( [F:DEP]DPRRAT    <> [F:TPF1]DPRRAT    )   : [F:DEP]DPRRAT    = [F:TPF1]DPRRAT    : LOK = G_OUI : Endif
     If ( [F:DEP]DPRRAT2   <> [F:TPF1]DPRRAT2   )   : [F:DEP]DPRRAT2   = [F:TPF1]DPRRAT2   : LOK = G_OUI : Endif
     If ( [F:DEP]RSDVAL    <> [F:TPF1]RSDVAL    )   : [F:DEP]RSDVAL    = [F:TPF1]RSDVAL    : LOK = G_OUI : Endif
     If ( [F:DEP]CRBVEHCOD <> [F:TPF1]CRBVEHCOD )   : [F:DEP]CRBVEHCOD = [F:TPF1]CRBVEHCOD : LOK = G_OUI : Endif
     If ( [F:DEP]ALWCOD    <> [F:TPF1]ALWCOD    )   : [F:DEP]ALWCOD    = [F:TPF1]ALWCOD    : LOK = G_OUI : Endif
     If ( [F:DEP]PRATYP    <> [F:TPF1]PRATYP    )   : [F:DEP]PRATYP    = [F:TPF1]PRATYP    : LOK = G_OUI : Endif
     If ( [F:DEP]ALWAMT    <> [F:TPF1]ALWAMT    )   : [F:DEP]ALWAMT    = [F:TPF1]ALWAMT    : LOK = G_OUI : Endif
     If ( [F:DEP]ACLCOE    <> [F:TPF1]ACLCOE    )   : [F:DEP]ACLCOE    = [F:TPF1]ACLCOE    : LOK = G_OUI : Endif
     [F:DEP]MTCDEVADJ = [F:TPF1]MTCDEVADJ
     [F:DEP]MTCTIATYP = [F:TPF1]MTCTIATYP #Fq-84623
     #===== 2 =========
     If (LOK = G_OUI )
        If ( ( ACTTYPGES = GTAMMAS & dim(FLGSIM) > 0 and  FLGSIM = G_NON )  or  (ACTTYPGES = GTAMUNI) )
        Call DETERM_MTCTIADAT([M:FASM]MTCTIATYP(I_PLN-1),
&                             [M:FASM]FIYSTRDAT(I_PLN-1), [M:FASM]PERSTRDAT(I_PLN-1), [F:TPF1]STRDPRDAT,
&                             [F:DEP]MTCTIADAT ) From TRTFASMTC
          # Si le mode actuel est "LP - Linéaire pur"
          # FQ82075 FQ105809
          If (( find([F:DEPW]DPM, G_DPMLP,G_DPMSL,G_DPMTL)>0) and
&            not find([F:DEP]DPM, G_DPMRE,G_DPMUO,G_DPMSA))
             # - déb amort < deb exercice et prise d'effet <> déb amort
             # ou
             # - déb amort > deb exercice et < déb per et prise d'effet =  déb per
             #-------------------------------------------
             If (  [F:TPF1]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) and [M:FASM]MTCTIATYP(nolign-1)<> GVML_PEDBAM ) or
&               (  [F:TPF1]STRDPRDAT > [M:FASM]FIYSTRDAT(nolign-1) and [F:TPF1]STRDPRDAT < [M:FASM]PERSTRDAT(nolign-1) and
&                                                                      [M:FASM]MTCTIATYP(nolign-1)= GVML_PEDBPE )
                Local Char    WDPM
                Local Integer GNRSD
                Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
                Local Integer L_PRATYP       # Type de prorata
                WDPM = [F:DEPW]DPM
                # Si le mode résiduel existe.
                Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
                #Fq-56015 If ( ( L_RSDDPMTGR <>"" ) | (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> "SA" )
                If ( ( L_RSDDPMTGR <>"" ) & ( L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> G_DPMSA )
                   [F:DEP]DPM    = L_RSDDPMTGR
                   If L_PRATYP > 0
                     [F:DEP]PRATYP  = L_PRATYP
                   Endif
                Endif
             Endif
          Endif
          #-------------------------------------------
        # Génération d'un évènement que l'on soit en unitaire ou en massif
        LCDINT= "FASMTC"+num$([F:DEP]DPRPLN)
        Global Char     GFAS, GDPO, GDPN
        Local Date LDATCPT
        LDATCPT = max( [F:TPF1]PERSTRDAT, [F:DEP]STRDPRDAT)
        GFAS = "[F:MAS1]"
        GDPO = "[F:DEPW]"
        GDPN = "[F:DEP]"
        Call GENER_EVE
&          (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]MTCTIADAT,LDATCPT, LCDRET)
&       From GENEVE
        If (LCDRET > 20)
           If (ACTTYPGES = GTAMMAS)   : # Massif uniquement
               # Erreur technique
               RMES = mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
           Endif
           GOK=0 : Return
        Endif
     Endif
     #===== 3 =========
     Gosub ECR_PLN_NEW  # Massif uniquement
     If ( ACTTYPGES = GTAMMAS & dim(FLGSIM) > 0 and  FLGSIM = G_NON )   : # Massif uniquement
        Gosub BEFORE_REWRITE_DEP From TRTFASMTC
        If [M:FASM] MTCTIATYP(I_PLN-1) = GVML_PEDBPE
            [F:DEP]PERREFCLC  = [M:FASM]PERSTRDAT(I_PLN-1)
            [F:DEP]PERREFCLCI = [M:FASM]PERSTRDAT(I_PLN-1)
            [F:DEP]PERREFCLCT = [M:FASM]PERSTRDAT(I_PLN-1)
        Else
            [F:DEP]PERREFCLC  = [M:FASM]FIYSTRDAT(I_PLN-1)
            [F:DEP]PERREFCLCI = [M:FASM]FIYSTRDAT(I_PLN-1)
            [F:DEP]PERREFCLCT = [M:FASM]FIYSTRDAT(I_PLN-1)
        Endif
        # Plan à recalculer
        [F:DEP]DEPSTA      = GVML_SCNOCAL
 #Fq-84623       [F:DEP]DPRCUMFLG   = [M:FASM]DPRCUMFLG(I_PLN-1) #Fq-78438
        [F:DEP]MTCDPEDAT   =  [F:DEP]MTCTIADAT  # ajouté car testé dans la réévaluation (MWA:27-02-2008)
        Rewrite [DEP]
        If (fstat)
           # Erreur technique
           RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
           GOK=0 : Return
        Else
           GOK=1 : Return
        Endif
        # les indicateurs du bien et du contexte sont mis "à recalculer"
        [F:MAS1]FLGCLC = G_OUI
        [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
        Rewrite [MAS1]
        If fstat
           # Erreur technique
           RMES= mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF
           GOK=0 : Return
        Endif
     Endif
   Endif
   #===== 2 =========
 Endif
 #=== 1 =======

Return
#=====================================================================
$END_ALIM_TABLE

  #==> Suppression des globales nécessaires à la fonction
  If dim(GMD1)          >0      : Kill GMD1           : Endif
  If dim(GQTY)          >0      : Kill GQTY           : Endif
  If dim(G_REPORT)      >0      : Kill G_REPORT       : Endif
  If dim(G_TRACE)       >0      : Kill G_TRACE        : Endif
  If dim(G_INCR)        >0      : Kill G_INCR         : Endif
  If dim(G_PARM)        >0      : Kill G_PARM         : Endif
  If dim(GFAS)          >0      : Kill GFAS           : Endif
  If dim(GDPO)          >0      : Kill GDPO           : Endif
  If dim(GDPN)          >0      : Kill GDPN           : Endif
  If dim(GDATREF)       >0      : Kill GDATREF        : Endif
  If ( ACTTYPGES = GTAMMAS and dim(G_DEFORCE) >0 )
    Kill G_DEFORCE
  Endif

Return
#=====================================================================
$END_APPL_DIRT

  #==> Suppression des globales nécessaires à la fonction
  If dim(GMD1)          >0      : Kill GMD1           : Endif
  If dim(GQTY)          >0      : Kill GQTY           : Endif
  If dim(G_REPORT)      >0      : Kill G_REPORT       : Endif
  If dim(G_TRACE)       >0      : Kill G_TRACE        : Endif
  If dim(G_INCR)        >0      : Kill G_INCR         : Endif
  If dim(G_PARM)        >0      : Kill G_PARM         : Endif
  If dim(GFAS)          >0      : Kill GFAS           : Endif
  If dim(GDPO)          >0      : Kill GDPO           : Endif
  If dim(GDPN)          >0      : Kill GDPN           : Endif
  If dim(GDATREF)       >0      : Kill GDATREF        : Endif
  If ( ACTTYPGES = GTAMMAS and dim(G_DEFORCE) >0 )
    Kill G_DEFORCE
  Endif

Return
#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#===============================
$GESTION_ECART

Local Char    WDPM
Local Integer GNRSD
Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
Local Integer L_PRATYP       # Type de prorata

  WDPM = [M:MFS0]DPM(NOL-1)
  # Si le mode résiduel cible est vide ou identique, on sort.
  Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
  If ( ( L_RSDDPMTGR="" ) | (L_RSDDPMTGR = WDPM ) )
      GNRSD = G_OUI
  Else
      GNRSD = G_NON
  Endif
  # Si changement de méthode et qu'un cumul d'amortissement existe et que le mode n'est pas basé sur le résiduel
  # et que le plan n'est pas IAS.
  If ( LIG_CHG = G_OUI and [M:MFS0]STRDPRDAT(NOL-1) < [M:FASM]FIYSTRDAT(NOL-1) and
&      GNRSD = G_OUI ) or
&     ( ACTMETNAM = "FASTRFC" )
     If ( ACTMETNAM = "FASTRFC" ) &  ( G_MES= G_OUI )
        [M:MFS0]MTCDEVADJ(NOL-1)= GVML_RDOTPER
     Else
        If ( [M:MFS0]MTCDEVADJ(NOL-1) = 0 )
             [M:MFS0]MTCDEVADJ(NOL-1)= GVML_REXCPER
        Endif
        Actzo [M:MFS0]MTCDEVADJ(NOL-1)
     Endif
     If  [M:MFS0]MTCTIADAT (NOL-1) > [M:MFS0]STRDPRDAT(NOL-1) and
&        [M:MFS0]MTCTIATYP (NOL-1)  = GVML_PEDBPE and
&        [M:MFS0]DPRPLN(NOL-1) <> G301FIS and
&        [M:MFS0]DPMO(NOL-1)   <> G_DPMSA and
&        GNRSD = G_NON
         [M:MFS0]DPM(NOL-1) = L_RSDDPMTGR
     Endif
  Else
    Diszo [M:MFS0]MTCDEVADJ(NOL-1)
  Endif

  Affzo [M:MFS0]MTCDEVADJ(NOL-1)
  Affzo [M:MFS0]DPM(NOL-1)

Return
#===============================
$GESTION_FLGERR
Local Integer I, NL

  NL = find( [M:MFS0]OBJREFDSP(0), [M:MFS0]OBJREF )

  # NL  Position dans 1er tableau (bien)
  # NOL Position dans 2er tableau (plan)

  If ( LIG_CHG = G_OUI )
    If ( [M:MFS0]FLGERRPLN(NOL-1) = G_OUI  )
      [M:MFS0]FLGERRPLN(NOL-1) = G_NON
      [M:MFS0]MSGERRPLN(NOL-1) = ""
      [M:MFS0]FLGERR(NL-1)     = G_NON
      [M:MFS0]MSGERR(NL-1)     = ""
      For I=1 To [M:MFS0]NBPLN
        If ([M:MFS0]FLGERRPLN(I-1) = G_OUI)
        [M:MFS0]FLGERR(NL-1)   = G_OUI
        [M:MFS0]MSGERR(NL-1)   = mess(179,GML_MSGFAS,1) # Au moins une erreur détectée sur un plan
        Break 1
        Endif
      Next I
    Endif
  Else
    # La méthode est inchangée
    [M:MFS0]FLGERRPLN(NOL-1) = G_OUI
    [M:MFS0]MSGERRPLN(NOL-1) = mess(183,GML_MSGFAS,1) # Méthode inchangée
    [M:MFS0]FLGERR(NL-1)     = G_OUI
    [M:MFS0]MSGERR(NL-1)     = mess(179,GML_MSGFAS,1) # Au moins une erreur détectée sur un plan
  Endif

Return
#==============================
Funprog DETECTE_CHG_LIG ( PNOL )
Value Integer PNOL

Local Integer CHG

  If not( [M:MFS0]DPMO(PNOL-1)        =  [M:MFS0]DPM(PNOL-1)        and
&         [M:MFS0]STRDPRDATO(PNOL-1)  =  [M:MFS0]STRDPRDAT(PNOL-1)  and
&         [M:MFS0]ENDDPRDATO(PNOL-1)  =  [M:MFS0]ENDDPRDAT(PNOL-1)  and
&         [M:MFS0]DPRDURO(PNOL-1)     =  [M:MFS0]DPRDUR(PNOL-1)     and
&       ( [M:MFS0]DPRRATFLGO(PNOL-1)  =  [M:MFS0]DPRRATFLG(PNOL-1)  or
&         ([M:MFS0]DPRRATFLGO(PNOL-1) <> [M:MFS0]DPRRATFLG(PNOL-1)  and
&          [M:MFS0]DPRRATFLGO(PNOL-1) <> G_OUI                      and
&             [M:MFS0]DPRRATFLG(PNOL-1)  <> G_OUI)                   ) and
&       ( [M:MFS0]DPRRATO(PNOL-1)     =  [M:MFS0]DPRRAT(PNOL-1)      or
&         ([M:MFS0]DPRRATO(PNOL-1)    <> [M:MFS0]DPRRAT(PNOL-1)     and
&          [M:MFS0]DPRRATFLGO(PNOL-1) <> G_OUI                      and
&             [M:MFS0]DPRRATFLG(PNOL-1)  <> G_OUI)                   ) and
&         [M:MFS0]DPRRATO(PNOL-1)     =  [M:MFS0]DPRRAT(PNOL-1)     and
&         [M:MFS0]RSDVALO(PNOL-1)     =  [M:MFS0]RSDVAL(PNOL-1)     and
&         [M:MFS0]CRBVEHCODO(PNOL-1)  =  [M:MFS0]CRBVEHCOD(PNOL-1)  and
&         [M:MFS0]PRATYPO(PNOL-1)     =  [M:MFS0]PRATYP(PNOL-1)     and
&         [M:MFS0]ACLCOEO(PNOL-1)     =  [M:MFS0]ACLCOE(PNOL-1)     and
&         [M:MFS0]ALWCODO(PNOL-1)     =  [M:MFS0]ALWCOD(PNOL-1)                  )
    CHG = G_OUI
  Else
    CHG = G_NON
  Endif

End CHG
################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
#==============================
$ECR_PARM_PLN

  If ACTSILENCE=G_OUI : Return : Endif

  Local Integer ERROR

  Call ECR_TRACE("", GTRC_PARAM,"",0,1) From TRACEABX3
  Call ECR_TRACE("", GTRC_PARAM,mess(685,GML_MSGFAS,1)-" :"-mess(GPRVSITUPD,1,1),0,1) From TRACEABX3
  Call ECR_TRACE("", GTRC_PARAM,"",0,1) From TRACEABX3
  Call ECR_TRACE("", GTRC_PARAM,mess(375,GML_MSGFAS,1)-mess([M:FASM]DPRPLND(I-1),GML_NPLAN,1),0,1) From TRACEABX3
  If ([M:FASM]STRDPRDATD(I-1) <> [0/0/0])
    Call ECR_TRACE("", GTRC_PARAM,mess(198,GML_MSGFAS,1)-num$([M:FASM]STRDPRDATD(I-1)),0,1) From TRACEABX3
  Endif

  If ([M:FASM]ENDDPRDATD(I-1) <> [0/0/0])
    Call ECR_TRACE("", GTRC_PARAM,mess(198,GML_MSGFAS,1)-num$([M:FASM]ENDDPRDATD(I-1)),0,1) From TRACEABX3
  Endif
  If ([M:FASM]MTCTIATYP(I-1) > 0)
    Call ECR_TRACE("", GTRC_PARAM,mess(203,GML_MSGFAS,1)-mess([M:FASM]MTCTIATYP(I-1),GML_PECHGMET,1),0,1) From TRACEABX3
  Endif
  If ([M:FASM]DPMD(I-1) <> "" )
    Call ECR_TRACE("", GTRC_PARAM,mess(199,GML_MSGFAS,1)-[M:FASM]DPMD(I-1),0,1) From TRACEABX3
  Endif
  If ([M:FASM]DPRDURD(I-1) > 0 )
    Call ECR_TRACE("", GTRC_PARAM,mess(200,GML_MSGFAS,1)-format$("N:3.3",[M:FASM]DPRDURD(I-1)),0,1) From TRACEABX3
  Endif
  If ([M:FASM]DPRRATD(I-1) > 0 )
    Call ECR_TRACE("", GTRC_PARAM,mess(201,GML_MSGFAS,1)-format$("N:3.6",[M:FASM]DPRRATD(I-1)),0,1) From TRACEABX3
  Endif
  If ([M:FASM]DPRRAT2D(I-1) > 0 )
    Call ECR_TRACE("", GTRC_PARAM,mess(492,GML_MSGFAS,1)-format$("N:3.6",[M:FASM]DPRRAT2D(I-1)),0,1) From TRACEABX3
  Endif
  If ([M:FASM]CRBVEHCODD(I-1) <> "" )
    Call GET_TDIV_ALPHA ([M:FASM]CRBVEHCODD(I-1), GTD_PLREINV , 'L', LDES, ERROR) From GLOBIENS
    Call ECR_TRACE("", GTRC_PARAM,mess(202,GML_MSGFAS,1)-LDES,0,1) From TRACEABX3
  Endif
  If ([M:FASM]ALWCODD(I-1) > 0)
    Call ECR_TRACE("", GTRC_PARAM,mess(203,GML_MSGFAS,1)-mess([M:FASM]ALWCODD(I-1),GML_REGLPART,1),0,1) From TRACEABX3
  Endif
  If ([M:FASM]MTCDEVADJ(I-1) > 0)
    Call ECR_TRACE("", GTRC_PARAM,mess(205,GML_MSGFAS,1)-mess([M:FASM]MTCDEVADJ(I-1),GML_RATECCHG,1),0,1) From TRACEABX3
  Endif

Return
#==============================
$LOAD_PARM
Local Integer  J
Local Integer  SORT : SORT= G_NON

  # Si une édition détaillée n'est pas réclamée
  If (FLGDET = G_NON)   : Return : Endif

  J= 0
  # Valeur résiduelle
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]RSDFLG(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "VR" : Break
    Endif
  Next nolign

  # Début d'amortissement
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]STRFLG(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "DA"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Mode d'amortissement
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]DPMD(nolign-1) <> "" )
      J += 1 : G_PARM(J) = "MD"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Durée d'amortissement
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]DURFLG(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "DU"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Taux d'amortissement
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]DPRRATFLGD(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "TX"
       If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Taux d'amortissement
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]DPRRA2FLGD(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "T2"
       If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Véhicule
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]VEHFLG(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "VE"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Règle particulières
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]ALWFLG(nolign-1) = G_OUI )
      J += 1 : G_PARM(J) = "RP"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Code équipe
  For nolign = 1 To [M:FASM]NBLIG1
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Gestion écart
  For nolign = 1 To [M:FASM]NBLIG1
    If ( [M:FASM]MTCDEVADJ(nolign-1) <> 0 )
      J += 1 : G_PARM(J) = "EC"
      If (J = 5)   : SORT= G_OUI : Endif
      Break
    Endif
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Date écart
  For nolign = 1 To [M:FASM]NBLIG1
  Next nolign

  If SORT=G_OUI : Return : Endif
  # Mode écart
  For nolign = 1 To [M:FASM]NBLIG1
  Next nolign

Return
#==============================
$ECR_ENT_PLN

 If ACTSILENCE=G_OUI : Return : Endif

Local    Char    LIGNE(250), LINE(130), CHAINE(33)
Local Integer    I_PAR, I_LONG

  Gosub LOAD_PARM

  If ( ACTTYPGES = GTAMMAS and FLGDET = G_OUI )
    # Entête (ligne 1)
    LINE = string$(115,"*")
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LIGNE =      left$( mess(182,GML_MSGFAS,1) + string$(20,' '), 20)+"!"
    LIGNE +=     left$( mess(184,GML_MSGFAS,1) + string$(12,' '), 12)+"!"

    For I_PAR = 1 To 5
      CHAINE = ""
      Case G_PARM(I_PAR)
        When "VR" : I_LONG = 14 : CHAINE =  mess(195,GML_MSGFAS,1)
        When "UR" : I_LONG = 10 : CHAINE =  mess(189,GML_MSGFAS,1)
        When "UE" : I_LONG = 10 : CHAINE =  mess(190,GML_MSGFAS,1)
        When "UP" : I_LONG = 10 : CHAINE =  mess(181,GML_MSGFAS,1)
        When "DA" : I_LONG = 10 : CHAINE =  mess(186,GML_MSGFAS,1)
        When "MD" : I_LONG =  4 : CHAINE =  mess(185,GML_MSGFAS,1)
        When "DU" : I_LONG =  7 : CHAINE =  mess(187,GML_MSGFAS,1)
        When "TX" : I_LONG = 10 : CHAINE =  mess(188,GML_MSGFAS,1)
        When "T2" : I_LONG = 13 : CHAINE =  mess(491,GML_MSGFAS,1)
        When "VE" : I_LONG =  5 : CHAINE =  mess(192,GML_MSGFAS,1)
        When "RP" : I_LONG = 21 : CHAINE =  mess(193,GML_MSGFAS,1)
        When "EQ" : I_LONG = 14 : CHAINE =  mess(194,GML_MSGFAS,1)
        When "EC" : I_LONG = 33 : CHAINE =  mess(196,GML_MSGFAS,1)
        When "ED" : I_LONG = 10 : CHAINE =  mess(197,GML_MSGFAS,1)
        When "EM" : I_LONG =  4 : CHAINE =  mess(185,GML_MSGFAS,1)
        When Default
      Endcase
      LIGNE +=     left$( CHAINE + string$(I_LONG ,' '), I_LONG )+"!"
    Next I_PAR
    LINE = left$( LIGNE + string$(115 ,' '), 115 )
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif
  LINE = string$(115,"*")
  Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3

Return
#==============================
$ECR_PLN_OLD

 If ACTSILENCE=G_OUI : Return : Endif

Local    Char    LIGNE(250), LINE(130), CHAINE(33)
Local Integer    I_PAR, I_LONG

  If ( ACTTYPGES = GTAMMAS and FLGDET = G_OUI )

    #-> A rupture bien on édite un en-tête dans la trace
    If ( [F:MAS1]AASREF<>TRC_AASREF )
      LIGNE =    left$( [F:MAS1]AASREF   + string$(20,' '), 20)+"!"
      TRC_AASREF=[F:MAS1]AASREF
    Else
      LIGNE =      string$(20,' ')+"!"
    Endif

    LIGNE +=     left$(  mess([F:DEPW]DPRPLN,GML_NPLAN,1) + string$(12,' '), 12)+"!"

    For I_PAR = 1 To 5
      CHAINE = ""
      Case G_PARM(I_PAR)
        When "VR" : I_LONG = 14 : CHAINE =  format$('N:'+GFMT3, [F:DEPW]RSDVAL)
        When "DA" : I_LONG = 10 : CHAINE =  num$([F:DEPW]STRDPRDAT)
        When "MD" : I_LONG =  4 : CHAINE =  [F:DEPW]DPM
        When "DU" : I_LONG =  7 : CHAINE =  format$("N:3.3",[F:DEPW]DPRDUR)
        When "TX" : I_LONG = 10 : CHAINE =  format$("N:3.6",[F:DEPW]DPRRAT)
        When "T2" : I_LONG = 13 : CHAINE =  format$("N:3.6",[F:DEPW]DPRRAT2)
        When "VE" : I_LONG =  5 : CHAINE =  [F:DEPW]CRBVEHCOD
        When "RP" : I_LONG = 21 : CHAINE =  mess([F:DEPW]ALWCOD,GML_REGLPART,1)
        When "EC" : I_LONG = 33 : CHAINE =  string$(I_LONG,' ')
        When "ED" : I_LONG = 10 : CHAINE =  string$(I_LONG,' ')
        When "EM" : I_LONG =  4 : CHAINE =  string$(I_LONG,' ')
        When Default
      Endcase
      LIGNE +=     left$( CHAINE + string$(I_LONG ,' '), I_LONG )+"!"
    Next I_PAR
    LINE = left$( LIGNE + string$(115 ,' '), 115 )
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif

Return
#==============================
$ECR_PLN_NEW

 If ACTSILENCE=G_OUI : Return : Endif

Local    Char    LIGNE(250), LINE(130), CHAINE(33)
Local Integer    I_PAR, I_LONG

  If ( ACTTYPGES = GTAMMAS and FLGDET = G_OUI )
    LIGNE =      string$(20,' ')+"!"
    LIGNE +=     string$(12,' ')+"!"
    For I_PAR = 1 To 5
      CHAINE = ""

      Case G_PARM(I_PAR)
        When "VR" : I_LONG = 14 : CHAINE =  format$('N:'+GFMT3, [F:DEP]RSDVAL)
        When "DA" : I_LONG = 10 : CHAINE =  num$([F:DEP]STRDPRDAT)
        When "MD" : I_LONG =  4 : CHAINE =  [F:DEP]DPM
        When "DU" : I_LONG =  7 : CHAINE =  format$("N:3.3",[F:DEP]DPRDUR)
        When "TX" : I_LONG = 10 : CHAINE =  format$("N:3.6",[F:DEP]DPRRAT)
        When "T2" : I_LONG = 13 : CHAINE =  format$("N:3.6",[F:DEP]DPRRAT2)
        When "VE" : I_LONG =  5 : CHAINE =  [F:DEP]CRBVEHCOD
        When "RP" : I_LONG = 21 : CHAINE =  mess([F:DEP]ALWCOD,GML_REGLPART,1)
        When "EC" :
                    If ( [F:DEP]MTCDEVADJ > 0 )
                      I_LONG = 33 : CHAINE =  mess([F:DEP]MTCDEVADJ,GML_RATECCHG,1)
                    Else
                      I_LONG = 33 : CHAINE =  string$(33,' ')+"!"
                   Endif
        When "ED" : I_LONG = 10
        When "EM" : I_LONG =  4
        When Default
      Endcase
      LIGNE +=     left$( CHAINE + string$(I_LONG,' '), I_LONG )+"!"
    Next I_PAR
    LINE = left$( LIGNE + string$(115 ,' '), 115 )
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif

Return
######################################################################
# Sous-pro et routines communes
######################################################################
#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

  Case PACTTYP
    When GTAMUNI
      Raz GPILOBJ
      Call DEFVAR From GLOBIMM
      Call INIVAR From GLOBIMM
      Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
    When GTAMMAS
      Local Char PARAM(30)(1..5)
      Local Char VALEUR
      PARAM(1)= GTAMMAS           # Massif / unitaire
      PARAM(2)= "FASMTC"          # Nom de l'action métier
      PARAM(3)= num$(GVML_OMBIEN) # Objet métier de référence
      PARAM(4)= num$(G_OUI)       # Mono société
      PARAM(5)= num$(G_OUI)       # Plan d'amortissement
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASMTC","FASMTCM",4,"") From GTRAITE
    When Default
  Endcase

End

