#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Program Name: VXAPI
# Description : ADC PO Inquiry
# Author      : NA Development
# Date        : September 11th, 2017
# Type        : NA Core
######################################################################################

$ACTION
   Case ACTION
       When "DEBUT"        : Gosub DEBUT
       When "OUVRE"        : Gosub OUVRE
       When "SETBOUT"      : Gosub SETBOUT
       When "BOUTON"       : Gosub BOUTON
       When "APRES_MODIF"  : Gosub APRES_MODIF
       When "FIN"          : Gosub FIN
   Endcase
Return

######################################################################################

$OUVRE
   Local Char CRIT(255)
   Local Char LORDNUM(20)
   Local Integer LORDLIN
   Local Char NORDNUM(20)
   Local Char NITMREF(20)
   Global Date TMPDAT

   If clalev([F:POH]) = 0 : Local File PORDER    [POH] : Endif
   If clalev([F:POQ]) = 0 : Local File PORDERQ   [POQ] : Endif
   If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

   TMPDAT = date$
   GVTMOD = 1

#- Set the default Where Clause
   CRIT = " [F:POH]APPFLG > 2" +
&         " and [F:POQ]PRHFCY = '" + GXAFCY + "'" +
&         " and [F:POQ]WIPSTA < 2" +
&         " and [F:POQ]ORI <> 2" +
&         " and [F:POQ]LINTYP < 3" +
&         " and [F:POQ]LINSTA <> 3" +
&         " and [F:POQ]LINCLEFLG = 1" +
&         " and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU))"

#- Initalize Stock Site
   Gosub INIT_STOFCY From ENVADC
Return

######################################################################################

$DEBUT
# Verify the ADC site is set
   If GXAFCY = "" : Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return : Endif

   Raz [M:API]
   Affzo [M:API]
Return

######################################################################################

$SETBOUT
#- "Page +" button
   If [M:API]FPOHNUM <> "" or [M:API]FITMREF <> ""
      Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                    As [ORDS]
&                 Where ([M:API]FPOHNUM = "" or ([M:API]FPOHNUM <> "" and [F:POQ]POHNUM = [M:API]FPOHNUM))
&                   and ([M:API]FITMREF = "" or ([M:API]FITMREF <> "" and [F:POQ]ITMREF = [M:API]FITMREF))
&                   and ([M:API]FRECDAT = [0/0/0] or ([M:API]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:API]FRECDAT))
&                   and ([F:POQ]POHNUM > LORDNUM or ([F:POQ]POHNUM = LORDNUM and [F:POQ]POPLIN > LORDLIN))
&                   and evalue(CRIT)
      Read [ORDS] First
      If fstat = 0
         CHMEN += "1"
      Else
         Call VIREBOUT(CHMEN, "1") From GOBJET
      Endif
   Else
      Call VIREBOUT(CHMEN, "1") From GOBJET
   Endif

#- "PO no +" Button
   If [M:API]FPOHNUM <> ""
      Link [F:POQ] With [F:POH]POH0=[F:POQ]POHNUM
&                    As [ORDS]
&                 Where [F:POQ]POHNUM > [M:API]FPOHNUM
&                   and ([M:API]FITMREF = "" or ([M:API]FITMREF <> "" and [F:POQ]ITMREF = [M:API]FITMREF))
&                   and ([M:API]FRECDAT = [0/0/0] or ([M:API]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:API]FRECDAT))
&                   and evalue(CRIT)
&              Order By [F:POQ]POHNUM

      Read [ORDS] First
      If fstat = 0
         NORDNUM = [F:POQ]POHNUM
         CHMEN += "2"
      Else
         NORDNUM = ""
         Call VIREBOUT(CHMEN, '2') From GOBJET
      Endif
   Else
      Call VIREBOUT(CHMEN, '2') From GOBJET
   Endif

#- "Product +" Button
   If [M:API]FITMREF <> ""
      Link [F:POQ] With [F:POH]POH0=[F:POQ]POHNUM
&                    As [ORDS]
&                 Where [F:POQ]ITMREF > [M:API]FITMREF
&                   and ([M:API]FPOHNUM = "" or ([M:API]FPOHNUM <> "" and [F:POQ]POHNUM = [M:API]FPOHNUM))
&                   and ([M:API]FRECDAT = [0/0/0] or ([M:API]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:API]FRECDAT))
&                   and evalue(CRIT)
&              Order By [F:POQ]ITMREF

      Read [ORDS] First
      If fstat = 0
         NITMREF = [F:POQ]ITMREF
         CHMEN += "3"
      Else
         NITMREF = ""
         Call VIREBOUT(CHMEN, '3') From GOBJET
      Endif
   Else
      Call VIREBOUT(CHMEN, '3') From GOBJET
   Endif
Return

######################################################################################

$BOUTON
   If BOUT = "1" : Gosub LOAD_PAGE : Endif
   If BOUT = "2" : LORDNUM = "" : LORDLIN = 0 : [M:API]FPOHNUM = NORDNUM : Gosub LOAD_PAGE : Endif
   If BOUT = "3" : LORDNUM = "" : LORDLIN = 0 : [M:API]FITMREF = NITMREF : Gosub LOAD_PAGE : Endif
Return

######################################################################################

Subprog AV_FPOHNUM(VALEUR)
   Variable Char VALEUR()

   If TMPDAT <> [0/0/0]
      [M:API]FRECDAT = TMPDAT
      Affzo [M:API]FRECDAT
   Endif
End

######################################################################################

Subprog C_FPOHNUM(VALEUR)
   Variable Char    VALEUR()

   If VALEUR <> ""
      [M:API]FPOHNUM = VALEUR

      Read [F:POH]POH0 = VALEUR
      If fstat : mkstat = 2 : GMESSAGE = mess(58,4111,1) : End : Endif

      Filter [F:POQ] Where POHNUM = VALEUR and PRHFCY = GXAFCY
      Read [F:POQ] First
      Filter [F:POQ]
      If fstat : mkstat = 2 : GMESSAGE = mess(103,194,1) : End : Endif
   Endif
End

######################################################################################

Subprog AS_FRECDAT(VALEUR)
   Variable Date VALEUR()

   If [M:API]FPOHNUM = "" and [M:API]FITMREF = ""
      Call ERREUR(mess(44,7750,1)) From GESECRAN
      zonsui = "[M:API]FPOHNUM"
      mkstat = 1
   Endif
End

######################################################################################

$APRES_MODIF
   Case COUZON
      When "FPOHNUM"
         [M:API]FPOHNUM = CZ

      When "FITMREF"
         [M:API]FITMREF = CZ

      When "FRECDAT"
         [M:API]FRECDAT = CZ
         TMPDAT = CZ
   Endcase

   Raz [M:API]NBLIG
   Affzo [M:API]

   If [M:API]FPOHNUM <> "" or [M:API]FITMREF <> ""
      Raz LORDNUM, LORDLIN
      Gosub LOAD_PAGE
   Endif
Return

######################################################################################

$LOAD_PAGE
   Raz [M:API]NBLIG, nolign

   Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                 As [ORDS]
&              Where ([M:API]FPOHNUM = "" or ([M:API]FPOHNUM <> "" and [F:POQ]POHNUM = [M:API]FPOHNUM))
&                and ([M:API]FITMREF = "" or ([M:API]FITMREF <> "" and [F:POQ]ITMREF = [M:API]FITMREF))
&                and ([M:API]FRECDAT = [0/0/0] or ([M:API]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:API]FRECDAT))
&                and ([F:POQ]POHNUM > LORDNUM or ([F:POQ]POHNUM = LORDNUM and [F:POQ]POPLIN > LORDLIN))
&                and evalue(CRIT)

   For [ORDS]
      If nolign < dim([M:API]ITMREF)
         Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:POQ]ITMREF,[M:API]ITMDESC(nolign), "[F:ITM]") From TRTX3   #X3-63011.n

         [M:API]ITMREF(nolign) = [F:POQ]ITMREF
         [M:API]POHNUM(nolign) = [F:POQ]POHNUM
         [M:API]POPLIN(nolign) = [F:POQ]POPLIN
         [M:API]RECDAT(nolign) = [F:POQ]EXTRCPDAT
         [M:API]REMQTY(nolign) = [F:POQ]QTYSTU - [F:POQ]RCPQTYSTU
         [M:API]STU(nolign)    = [F:POQ]STU
         nolign+=1
         LORDNUM = [F:POQ]POHNUM
         LORDLIN = [F:POQ]POPLIN
      Else
         Break
      Endif
   Next

   [M:API]NBLIG = nolign

   Affzo[M:API]
Return

######################################################################################

$FIN
   Kill TMPDAT

   GVTMOD = 0

   If clalev ([F:POH]) : Close Local File [F:POH] : Endif
   If clalev ([F:POQ]) : Close Local File [F:POQ] : Endif
   If clalev ([F:ITM]) : Close Local File [F:ITM] : Endif
Return

######################################################################################

