#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer OK
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "GX3APP"
If !fstat
 Call VERIF(OK)
Endif
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
####################################################################################
# VERIFMAJ70 : Vérification à effectuer avant le passage à la version V10 (AVENGER)
####################################################################################

Subprog VERIF(OK)
Variable Integer OK

OK=1
#-------------------------------------#
#       Avant validation dossier      #
#-------------------------------------#
Onerrgo ERREUR

Call ECR_TRACE("************** VERIFMAJ70 ***************",-1) From GESECRAN

Local Char WDOSSIER(GLONADS)
WDOSSIER=[F:ADS]DOSSIER


# Vérification Comptabilité/Tiers
If [F:ADS]MODULE(2)=2
   Gosub VERIF_CPT
Endif

Onerrgo
End


###################################################################################
$VERIF_CPT
If func DOSSUB.ISHISTFOLD(WDOSSIER)=1 : Return : Endif

If (filinfo(filpath("FIL","APLSTD","fde",WDOSSIER),0))>0
 Local File =WDOSSIER+".APLSTD" [AST]
 Local File =[F:ADS]DOSREF+".APLSTD" [AST_]
 For [AST]LAN Where LANCHP=853 & LANMES<>"" & LANNUM<>0 & find(LAN,[F:ADS]LAN)<>0
  Raz [F:AST_]
  Read [F:AST_]LAN=[F:AST]LAN;853;[F:AST]LANNUM
  If fstat | [F:AST]LANMES<>[F:AST_]LANMES
   Call ECR_TRACE(mess(78,100,1)-"853"-[F:AST]LAN-mess(210,115,1)-":"-[F:AST]LANMES-[F:AST_]LANMES,-1)  From GESECRAN
  Endif
 Next
 Close Local File [AST],[AST_]
Endif

Return


###################################################################################

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
LRET=1
Resume

