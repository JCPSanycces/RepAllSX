#<AdxTL>@(#)2.0.0.0 $Revision$
End
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

#####################################################
## Calcul des taxes                                ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE(CTX,SOCIETE,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,MONTANT,MONTDED,TYPREG,STAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    SOCIETE          : # Société
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
If CTX=null : CTX=GACTX : Endif
CAS = 1 : Gosub CAL_TAXE
End

#####################################################
## Calcul des taxes : utilisé pour les achats      ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE2(CTX,SOCIETE,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,OTHBASE,MONTANT,MONTDED,TYPREG,STAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    SOCIETE          : # Société
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Value    Decimal OTHBASE(1..)     : # Autres bases 1 à 7 (parafiscale, spéciale ..etc)
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
If CTX=null : CTX=GACTX : Endif
CAS = 2 : Gosub CAL_TAXE
End

#####################################################
## Calcul des taxes avec gestion des exonérations  ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE3(CTX,SOCIETE,CLIENT,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,MONTANT,MONTDED,EXEAMTTAX,TYPREG,STAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    SOCIETE          : # Société
Value    Char    CLIENT           : # Code client
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Decimal EXEAMTTAX(1..)   : # Montant exonération
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
If CTX=null : CTX=GACTX : Endif
CAS = 3 : Gosub CAL_TAXE
End

$CAL_TAXE
## TYPBASE = 1 : Base HT
## TYPBASE = 2 : Base TTC

## TYPREG = 1 : Normal, il faut appliquer les taxes
## TYPREG = 2 : Export, il ne faut pas appliquer les taxes
## TYPREG = 3 : Suspension de taxes, il ne faut pas appliquer les taxes
## TYPREG = 4 : CEE, cas spécial selon achat/vente

## STAT = 0 : RAS TVB
## STAT = 1 : Un code taxe n'existe pas
## STAT = 2 : Y'a pas de taux applicable
## STAT = 3 : Type de base incorrect
## STAT = 4 : Il y a 2 taxes de type TVA
## STAT = 5 : Code régime inexistant
## STAT = 6 : Société ou site inexistant
## STAT = 7 : Taxes de régime différents
## STAT = 8 : Devise inexistante

Local File TABVAT    [TVT]
Local File TABRATVAT [TRA]
Local File TABCUR    [TCU]
Local File COMPANY   [CPY]
Local File TABVACBPR [TVB]

Local Libelle TYPTAX(1..NBTAXE)
Local Libelle SOUMIS(1..NBTAXE)
Local Libelle BASVAT(1..NBTAXE)
Local Char    TAX(GLONVAT) , COMPANY(GLONCPY) , DEVLED(GLONCUR)
Local Decimal TAUX1 , TAUX2 , MONTANT1 , MONTANT2 , BASTVA , BASTAX
Local Integer NTVA , I
Local Integer WRET

Local Integer CTX_ARGEXO
Local Integer CTX_CHGTYP:#--Remplacement des globales GCHGTYP, GCURSHR
Local Char  CTX_CURSHR(GLONCUR) :#--Remplacement des globales GCHGTYP, GCURSHR

Raz MONTANT , MONTDED , TYPREG , STAT

#--Au cas où...
If CTX=null : CTX=GACTX : Endif

#--Passage par la classe cache C_TCU
#--On attendant la classe cache C_TCU on laisse le Read...
If [F:TCU]CUR<>DEVISE
    Read [TCU]TCU0=DEVISE : If fstat  Raz [F:TCU] : Endif
Endif
#Local Integer  CUR_INDEX
#Local Instance CUR Using C_TCU
#
#CUR_INDEX = CTX.ACACHE.TCU.AGETINDEX(DEVISE)
#If CUR_INDEX=[V]CST_ANOTDEFINED
#  # The currency does not exist, handle the error and exit
#STAT = 8 : Return : # Perdu!!
#Endif
#
#CUR = CTX.ACACHE.TCU.ACOL(CUR_INDEX)

#--Remplacement des globales GOSC et GSITE
# La société est-elle une société ou un site ??
#--On fait les Read (en attente d'une solution genre classes cache)...
Read [F:CPY]CPY0=SOCIETE
If fstat
Read [F:FCY]FCY0=SOCIETE
If fstat : STAT = 6 : Return : Endif :# Perdu!!
Read [F:CPY]CPY0=[F:FCY]LEGCPY
If fstat : STAT = 6 : Return : Endif :# Perdu!!
Endif
[L]COMPANY=[F:CPY]CPY
#--/

#--Remplacement des globales GCHGTYP, GCURSHR et paramètre ARGEXO
If func AFNC.ACTIV("KAG")   # Issue X3-107197
  CTX_ARGEXO    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY ,[F:CPY]CPY ,"ARGEXO")
Endif   # Issue X3-107197
CTX_CHGTYP    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCHGTYP")
CTX_CURSHR    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"CURSHRFLD")

#--Pas dispo sur X3DEVV7
#Call SETCUR(1,[F:CPY]CPY,DEVLED) From FINLIBINI

Local File GACM    [GCM]

Call LEC_GCM([F:CPY]ACM) From CPTLEC
If !fstat
 Case CAS
   When 1 : DEVLED=[F:GCM]CUR([F:GCM]GENLEDTYP-1)
   When 2 : DEVLED=[F:GCM]CUR([F:GCM]ANALEDTYP-1)
 Endcase
Endif
#--/

# Lecture des taxes
REGIME = ""

For I=1 To NBTAXE
 If TAXES(I)<>""
  Raz WRET
  Call LEC_TVT_LEG(CTX,[F:CPY]LEG,TAXES(I),WRET) From TRTLECLEG_SYRA
  If WRET : Raz [F:TVT] : STAT = 1 : Break : Endif

  TYPTAX(I) = [F:TVT]VATTYP
  SOUMIS(I) = [F:TVT]VATCHA
  BASVAT(I) = [F:TVT]VATBAS
  If REGIME=""
   REGIME = [F:TVT]VATVAC
  Elsif REGIME<>[F:TVT]VATVAC & [F:TVT]VATVAC<>"" & CAS<>2
   STAT = 7 : Break
  Endif
 Endif
Next I
If STAT : Return : Endif

# Type de régime applicable
If REGIME=""
 TYPREG = 1 : # Par défaut "normal"
Else
 Local Integer WRET
 Call LEC_TVB_LEG(CTX,[F:CPY]LEG,REGIME,WRET) From TRTLECLEG_SYRA
 If WRET Raz [F:TVB] : Endif
 TYPREG = [F:TVB]REGVAC
Endif

Case TYPBASE
 When 1       : Gosub CALNORM
 When 2       : Gosub CALINV2 :#Gosub CALINV #--CPO 84846 CALINV2 est le nouveau sous-pro (pas encore qualifié par l'équipe finance)
 When Default : STAT = 3 : Return
Endcase

Return

$CALNORM
# Calcul à partir d'un montant HT
# On commence par les taxes parafiscales
BASTVA = BASE
For I=1 To NBTAXE
 If TYPTAX(I)>1
  TAX    = TAXES(I)
  If CAS = 1 | CAS = 3
   BASTAX = BASE
  Elsif CAS = 2
   If BASVAT(I) > 1
    BASTAX = OTHBASE(I)
   Else
    BASTAX = BASE
   Endif
  Endif
  Gosub CALCUL
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  If SOUMIS(I)=2
   BASTVA += MONTANT(I)
  Endif
 Endif
Next I
If STAT : Return : Endif

# On peut maintenant calculer la TVA
NTVA = 0
For I=1 To NBTAXE
 If TYPTAX(I)=1
  If NTVA : STAT = 4 : Break : Endif
  TAX    = TAXES(I)
  BASTAX = BASTVA
  Gosub CALCUL
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
 Endif
Next I
If STAT : Return : Endif
Return


$CALINV
# Calcul à partir d'un montant TTC
# On commence par les taxes parafiscales non soumises
BASTVA = BASE
For I=1 To NBTAXE
 If TYPTAX(I)>1 & SOUMIS(I)<>2
  TAX    = TAXES(I)
  If CAS = 1
   BASTAX = BASTVA
  Elsif CAS = 2
   If BASVAT(I) > 1
    BASTAX = OTHBASE(I)
   Else
    BASTAX = BASTVA
   Endif
  Endif
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
# Ensuite la TVA
NTVA = 0
For I=1 To NBTAXE
 If TYPTAX(I)=1
  If NTVA : STAT = 4 : Break : Endif
  TAX    = TAXES(I)
  BASTAX = BASTVA
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
If STAT : Return : Endif
# Puis enfin les taxes soumises
For I=NBTAXE To 1 Step -1
 If TYPTAX(I)>1 & SOUMIS(I)=2
  TAX    = TAXES(I)
  If CAS = 1
   BASTAX = BASTVA
  Elsif CAS = 2
   If BASVAT(I) > 1
    BASTAX = OTHBASE(I)
   Else
    BASTAX = BASTVA
   Endif
  Endif
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
Return


$CALCUL
Gosub LECTAX
If STAT = 2 : Return : Endif
Call RNDTVA(CTX,[F:CPY]CPY,BASTAX,TAUX1,[F:TCU]CURRND,MONTANT1)
Gosub EXONERATION
# Pour le montant déductible, quelle option ?
MONTANT2 = arr(MONTANT1*TAUX2/100,[F:TCU]CURRND)
Return

$CALCUL2
Gosub LECTAX
If STAT = 2 : Return : Endif
Call RNDTVA2(CTX,[F:CPY]CPY,BASTAX,TAUX1,[F:TCU]CURRND,MONTANT1)
Gosub EXONERATION
# Pour le montant déductible, quelle option ?
MONTANT2 = arr(MONTANT1*TAUX2/100,[F:TCU]CURRND)
Return

$LECTAX
Local Integer WWRET
If [F:CPY]CPY<>COMPANY
Read [F:CPY]CPY0=COMPANY
If fstat : Raz [F:CPY] : Endif
Endif
# Cas particulier société ??
#Call LEC_TVT_LEG([F:CPY]LEG,TAX) From CPTLEC
Call LEC_TVT_LEG(CTX,[F:CPY]LEG,TAX,WWRET) From TRTLECLEG_SYRA
If WWRET : Raz [F:TVT] : Endif

Filter [TRA] Where CPY=COMPANY & VAT=TAX & STRDAT<=DAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
# sinon on se rabat sur le code dossier
 Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If fstat>2 : STAT = 2 : Return : Endif
Endif
TAUX1 = [F:TRA]VATRAT
TAUX2 = [F:TRA]DEDRAT
Return

$EXONERATION
If CAS<>3 : Return : Endif
If MONTANT1=0 : EXEAMTTAX(I) = 0 : Endif
## En gestion des exonérations, on accepte par exemple d'avoir pour un client, une société et un code taxe de type TVA
## un taux éxonération de 10% et d'avoir pour tous les autres codes taxes de type TVA un taux d'éxonération de 20%. Dans
## ce cas, on pourra réaliser ce paramétrage en ne spécifiant pas de code taxe pour le second cas.
## Par conséquent, on tient compte de la priorité à donner pour la recherche de l'exonération :
## 1 °) On regarde d'abord s'il y a une exonération pour le client qui est spécifique à la société et au code taxe
#If clalev([F:TEX])=0 : Local File TABVATEXE [TEX] : Endif

Local File TABVATEXE [TEX]

Local Decimal TSDMINFAC, TSDMAXFAC
Filter [TEX] Where BPCNUM = [L]CLIENT
&                & CPY = [L]SOCIETE & VAT=[L]TAX
&                & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
Read [TEX]TEX0 First
If fstat
 ## 2°) On regarde alors s'il y a une exonération pour le client qui est spécifique à la société (=pour un client,
 ## et une société une éxonération s'applique pour toute une catégorie de taxe)
 Filter [TEX] Where BPCNUM = [L]CLIENT
&              &    CPY = [L]SOCIETE & VAT="" & VATTYP = TYPTAX(I)
&                 & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
 Read [TEX]TEX0 First
 If fstat
  ## 3°) On regarde alors s'il y a une exonération pour le client qui est spécifique au code taxe mais valable pour toutes
  ## les sociétés

#--Remplacement du paramètre ARGEXO
  #If func AFNC.PARAM("ARGEXO",[L]SOCIETE)="2"
  If CTX_ARGEXO = 2
  #--/

   Filter [TEX] Where BPCNUM = [L]CLIENT
&                   & CPY = "" & VAT=[L]TAX
&                   & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
   Read [TEX]TEX0 First
   If fstat
    ## 4°) On regarde alors s'il y a une exonération pour le client qui est spécifique qui est s'applique pour toute une
    ## catégorie de taxes et pour toutes les sociétés
    Filter [TEX] Where BPCNUM = [L]CLIENT
&                    & CPY = "" & VAT="" & VATTYP = TYPTAX(I)
&                    & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
    Read [TEX]TEX0 First
   Endif
  Endif
 Endif
Endif
Call CONVERT(CTX,CTX_CURSHR,DEVISE,[L]DEVLED,CTX_CHGTYP,[L]DAT,[F:TEX]TSDMIN,TSDMINFAC,STAT) From TRTDEV_SYRA
If STAT
 Call ECR_TRACE(mess(4,109,1)-CTX_CURSHR-"=>"-DEVISE,1) From GESECRAN
Endif
Call CONVERT(CTX,CTX_CURSHR,DEVISE,[L]DEVLED,CTX_CHGTYP,[L]DAT,[F:TEX]TSDMAX,TSDMAXFAC,STAT) From TRTDEV_SYRA
If STAT
 Call ECR_TRACE(mess(4,109,1)-CTX_CURSHR-"=>"-DEVISE,1) From GESECRAN
Endif
If BASTAX>=TSDMINFAC & ([F:TEX]TSDMAX=0 | BASTAX<=TSDMAXFAC)
 EXEAMTTAX(I) = arr(MONTANT1*[F:TEX]EXERAT/100,[F:TCU]CURRND)
 MONTANT1 = MONTANT1 - EXEAMTTAX(I)
Endif
Return


Subprog ERR_CALTAXE(STAT,MESSA)
Value Integer STAT
Variable Char MESSA()
Case STAT
 When 1 : MESSA = mess(37,119,1) : # Un code taxe n'existe pas
 When 2 : MESSA = mess(38,119,1) : # Il n'y a aucun taux applicable
 When 3 : MESSA = mess(39,119,1) : # Type de base incorrecte
 When 4 : MESSA = mess(40,119,1) : # Il y a deux taxes de type TVA
 When 5 : MESSA = mess(41,119,1) : # Code régime inexistant
 When 6 : MESSA = mess(21,104,1) : # Société ou site inexistant
 When 7 : MESSA = mess(42,119,1) : # Taxes de régimes différents
 When 8 : MESSA = mess(151,105,1): # Devise inexistante
Endcase
End

##########################################
## Calcul du montant d'une taxe
##########################################
## 1) A partir du HT
##
Subprog RNDTVA(CTX,SOCIETE,BASE,TAUX,ARROND,MONTANT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    SOCIETE
Value    Decimal BASE
Value    Decimal TAUX
Value    Decimal ARROND
Variable Decimal MONTANT
Local Integer TYP

Local Integer CTX_VATRND
#--Remplacement de la globale GVATRND
CTX_VATRND    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY ,SOCIETE ,"VATRND")
If CTX_VATRND>0
TYP=CTX_VATRND
Else
TYP=3
Endif
#--/

Case TYP
 When 1       : # Supérieur
  MONTANT = -ARROND*int(-(BASE*TAUX)/(100*ARROND))
 When 2       : # Inférieur
  MONTANT = ARROND*int((BASE*TAUX)/(100*ARROND))
 When Default : # 5/4
  MONTANT = arr(BASE*TAUX/100,ARROND)
Endcase
End
## 2) A partir du TTC
##
Subprog RNDTVA2(CTX,SOCIETE,BASE,TAUX,ARROND,MONTANT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    SOCIETE
Value    Decimal BASE
Value    Decimal TAUX
Value    Decimal ARROND
Variable Decimal MONTANT
Local Integer TYP

Local Integer CTX_VATRND
#--Remplacement de la globale GVATRND
CTX_VATRND    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY ,SOCIETE ,"VATRND")
If CTX_VATRND>0
TYP=CTX_VATRND
Else
TYP=3
Endif
#--/

Case TYP
 When 1       : # Supérieur
  MONTANT = -ARROND*int(-(BASE-BASE/(1+TAUX/100))/ARROND)
 When 2       : # Inférieur
  MONTANT = ARROND*int((BASE-BASE/(1+TAUX/100))/ARROND)
 When Default : # 5/4
  MONTANT = arr(BASE-BASE/(1+TAUX/100),ARROND)
Endcase
End
######################################################################################
#--CPO 84846 Nouveau sous-pro de calcul de taxe TTC vers HT
#######################################################################################
$CALINV2
Local Decimal  MONTCALC
Local Decimal  WRAT    (1..NBTAXE)   : # les 3 taux de taxe
Local Decimal  WRATDED (1..NBTAXE)   : # les taux déductibles
Local Decimal  WBASTAX (1..NBTAXE)   : # les bases de taxe

#--Pour passage des bases soumises des taxes
Raz STAT
For I=1 To NBTAXE
  If TAXES(I)<>""
    Raz TAUX1,TAUX2
    TAX = TAXES(I) : Gosub LECTAX
    If STAT=2 : Return Endif
WRAT(I)=TAUX1
    WRATDED(I)=TAUX2
    If CAS=2 and TYPTAX(I)<>1 and BASVAT(I)>1
      WBASTAX(I)=OTHBASE(I)
    Else
    WBASTAX(I)=BASE
    Endif
  Endif
Next

Call CALCULTAXE(CTX,CAS,SOCIETE,DEVISE,DAT,TYPBASE,NBTAXE,TAXES,TYPTAX,SOUMIS,BASVAT,WRAT,WBASTAX,MONTANT,MONTCALC,BASE)
#--Calcul des montants déductibles
For I=1 To NBTAXE
If TAXES(I)<>""
    MONTANT1=MONTANT(I)
    Gosub EXONERATION #From SUBTVT
    # Pour le montant déductible, quelle option ?
    MONTDED(I) = arr(MONTANT1*WRATDED(I)/100,[F:TCU]CURRND)
  Endif
Next

Return
#########################################################################
# CALCULTAXE calcule les montants des taxes
#------------------------------------------------------------------------
# appel (garnir) :
#   CPY    CUR  DAT  PRITYP  VAT
#   RAT    si le taux n'est pas garni (=999.99) il est recherche en table
#   BASTAX montants soumis aux taxes
#     lignes produit  : (0) soumis à TVA  (1) soumis à TS1  (2) soumis à TS2
#     frais           : (3) soumis à TVA
#     taxe secondaire : (4) soumis à TVA
# retour
#   RAT    si non garnis à l'appel
#   BASTAX les montants sont mis à jour (ex: (4) si TS1 TS2 soumis à TVA)
#          mis à jour dans le cas du calcul à partir du TTC
#      nota un montant exonéré reste garni (pour les répartitions prorata)
#   AMTNOT montant HT
#   AMTATI montant TTC
#
#########################################################################
Subprog CALCULTAXE (CTX, CAS,CPY,CUR,DAT,PRITYP,NBVAT,VAT,TYPVAT,SOUMIS,BASVAT,RAT,BASTAX,AMTTAX,AMTNOT,AMTATI)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Integer  CAS
Value    Char     CPY            : # société (nécessaire à table des taux de taxe
Value    Char     CUR            : # devise
Value    Date     DAT            : # date (nécessaire à table des taux de taxe)
Value    Integer  PRITYP         : # 1=HT 2=TTC
Value    Integer  NBVAT
Value    Char     VAT () (0..)   : # les 3 codes de taxe
Value    Libelle  TYPVAT(0..)
Value    Libelle  SOUMIS(0..)
Value    Libelle  BASVAT(0..)
Variable Decimal  RAT (0..)      : # les 3 taux de taxe
Variable Decimal  BASTAX (0..)   : # les bases de taxe
Variable Decimal  AMTTAX (0..)   : # les montants
Variable Decimal  AMTNOT         : # montant HT  (si ligne=celui de la ligne)
Variable Decimal  AMTATI         : # montant TTC (si ligne=celui de la ligne)

Local    Shortint I,J
Local    Decimal  MTSOUMIS (0..)
Local    Decimal  TAXE1          : # si calcul sur autre que le ht
Local    Decimal  TAXE2          : # si calcul sur autre que le ht
Local    Decimal  TVATAXE1       : # si calcul sur autre que le ht et taxe soumise à tva : # Bug 65799
Local    Decimal  TVATAXE2       : # si calcul sur autre que le ht et taxe soumise à tva : # Bug 65799
Local    Decimal  TXTOT          : # taux total de la ligne si prix TTC
Local    Decimal  MTSOUMISTVA
Local    Decimal  RATTVA
Local    Integer  INDTVA
Local    Decimal  BASTAX4,BASTAX5
Local    Decimal  TOT_BASTAXSEC,TOT_AMTTAXSEC,TOT_BASTAXFORMT
Local    Decimal  TOT_TVATAXE1,TOT_TVATAXE2
Local    Decimal  TOT_TAXE1,TOT_TAXE2

Local  Decimal  WGBIDD3

#--Passage par classe cache C_TCU
Local File TABCUR [TCU]
#
If [F:TCU]CUR<>CUR
    Read [TCU]TCU0=CUR : If fstat  Raz [F:TCU] : Endif
Endif

#Local Integer  CUR_INDEX
#Local Instance CUR Using C_TCU
#
#CUR_INDEX = CTX.ACACHE.TCU.AGETINDEX(DEVISE)
#If CUR_INDEX=[V]CST_ANOTDEFINED
#  # The currency does not exist, handle the error and exit
#End : # Perdu!!
#Endif
#
#CUR = CTX.ACACHE.TCU.ACOL(CUR_INDEX)
#--/

#--Cas où pas de taxe de type TVA => Normalement impossible ?
INDTVA = -1

For I=0 To NBVAT-1
  If TYPVAT(I)=1
   MTSOUMISTVA=BASTAX(I)
   RATTVA=RAT(I)
   INDTVA=I
  Endif
  MTSOUMIS(I)=BASTAX(I)
Next
# Taxes secondaires :
# - Calcul de la taxe UNIQUEMENT si la base n est pas le HT
Raz TVATAXE1, TVATAXE2
Raz TOT_TVATAXE1, TOT_TVATAXE2
Raz TAXE1, TAXE2
#--Uniquement pour appels depuis les achats
If CAS=2
  For I=0 To NBVAT-1
   If VAT(I)<>"" and TYPVAT(I)<>1
     # Si Document HT,  calcul des taxes secondaires
     # Si Document TTC, calcul des taxes secondaires sf si mnt TTC ligne taxe principale à 0 (Dans ce cas, pas de taxe donc pas de calcul des taxes)
    If (PRITYP=1 | MTSOUMISTVA<>0)
      If BASVAT(I)=2   : # si base de taxe est montant1
        If MTSOUMIS(I)<>0
          Call RNDTVA(CTX,CPY,MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE1) #From SUBTVT
        Endif
        AMTTAX(I)=TAXE1
        TOT_TAXE1 += TAXE1
        If SOUMIS(I)=2      : # la taxe est soumise à taxe principale
         If TAXE1<>0
            Call RNDTVA(CTX,CPY,TAXE1,RATTVA,[F:TCU]CURRND,TVATAXE1) #From SUBTVT : # calcul de la taxe principale : # Bug 65799
            TOT_TVATAXE1 += TVATAXE1
            If TYPVAT(I)=2 : BASTAX4 += TAXE1 : Endif : # c'EST UNE TAXE PARAFISCALE
            If TYPVAT(I)=3 : BASTAX5 += TAXE1 : Endif : # c'est une taxe spéciale
          Endif
        Endif
      Endif
      If BASVAT(I)=3    : # si base de taxe est montant2
        If MTSOUMIS(I)<>0
          Call RNDTVA(CTX,CPY,MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE2) #From SUBTVT
        Endif
        AMTTAX(I)=TAXE2
        TOT_TAXE2 += TAXE2
        If SOUMIS(I)=2  : # la taxe est soumise à taxe principale
          If TAXE2<>0
            Call RNDTVA(CTX,CPY,TAXE2,RATTVA,[F:TCU]CURRND,TVATAXE2) #From SUBTVT : # calcul de la taxe principale : # Bug 65799
            TOT_TVATAXE2 += TVATAXE2
            If TYPVAT(I)=2 : BASTAX4 += TAXE2 : Endif : # c'est une taxe parafiscale
            If TYPVAT(I)=3 : BASTAX5 += TAXE2 : Endif : # c'est une taxe spéciale
          Endif
        Endif
      Endif
    Endif
   Endif
  Next I
Endif
# Document saisi avec type de prix TTC
# - cumul des % pour determiner la base HT de chaque taxe
# - Attention : il faut enlever du TTC ligne les taxes TAXE1 et TAXE2 calculees sur autre que HT
If PRITYP=2
  Raz TXTOT                        : # taux cumule
  For I=0 To NBVAT-1
    If VAT(I)<>"" and (CAS<>2 | (CAS=2 and BASVAT(I)<2))  : # uniquement si taxe sur HT
      TXTOT += RAT(I)/100
      If SOUMIS(I)=2 and I<>INDTVA    : # si taxe principale sur taxe secondaire
        TXTOT += (RAT(I)/100)*(RATTVA/100)
      Endif
    Endif
  Next I
  For I=0 To NBVAT-1
    If VAT(I)<>"" and (CAS<>2 | (CAS=2 and BASVAT(I)<2))  : # uniquement si taxe sur HT
      If TXTOT<>0
          Raz WGBIDD3

          If MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2<>0
            Call RNDTVA2(CTX,CPY,MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2,TXTOT*100,[F:TCU]CURRND,WGBIDD3) #From SUBTVT
          Endif
          BASTAX(I)=MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2-WGBIDD3
      Endif
    Endif
  Next I
Endif

# Calcul des taxes secondaires sur HT
For I=0 To NBVAT-1
 If VAT(I)<>"" and TYPVAT(I)<>1
  If (CAS<>2 | (CAS=2 and BASVAT(I)<2))
    Raz AMTTAX(I)
    If BASTAX(I)<>0
      Call RNDTVA(CTX,CPY,BASTAX(I),RAT(I),[F:TCU]CURRND,AMTTAX(I)) #From SUBTVT
      If SOUMIS(I)=2      : # la taxe est soumise à taxe principale
        If TYPVAT(I)=2 : BASTAX4 += AMTTAX(I) : Endif : # c'est une taxe parafiscale
        If TYPVAT(I)=3 : BASTAX5 += AMTTAX(I) : Endif : # c'est une taxe spéciale
      Endif
    Endif
  Endif
 Endif
Next I

#--Calcul de la taxe principale
For I=0 To NBVAT-1
  If VAT(I)<>"" and TYPVAT(I)<>1
  TOT_BASTAXSEC += BASTAX(I)
  TOT_AMTTAXSEC += AMTTAX(I)
Endif
Next

[L]TOT_BASTAXFORMT = BASTAX4+BASTAX5

If INDTVA>-1
  If PRITYP=1
      WGBIDD3=BASTAX(INDTVA)+ TOT_BASTAXFORMT
      Raz AMTTAX(INDTVA)
      If WGBIDD3<>0
        Call RNDTVA(CTX,CPY,WGBIDD3,RAT(INDTVA),[F:TCU]CURRND,AMTTAX(INDTVA)) #From SUBTVT
      Endif
      # Calcul du HT et TTC ligne
    AMTNOT=MTSOUMISTVA
    AMTATI=AMTNOT+AMTTAX(INDTVA)+ [L]TOT_AMTTAXSEC
  Endif

  If PRITYP=2
    If [F:TCU]CUR<>""
      AMTTAX(INDTVA) = arr(max(0,MTSOUMIS(INDTVA)-BASTAX(INDTVA)-[L]TOT_AMTTAXSEC),[F:TCU]CURRND)
      Else
        AMTTAX(INDTVA)=max(0,MTSOUMIS(INDTVA)-BASTAX(INDTVA)-[L]TOT_AMTTAXSEC)
      Endif
      # Calcul du HT et TTC ligne
      AMTATI=MTSOUMIS(INDTVA)
      AMTNOT=AMTATI-AMTTAX(INDTVA)-[L]TOT_AMTTAXSEC
  Endif
Endif

End

