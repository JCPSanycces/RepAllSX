#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Invalidation de tous les écrans
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Invalidation of screens") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub RAZMSK
End

#-------------------#
$RAZMSK

Local File =DOSSIER+".AMSKZON" [UAMZ]
Local File =DOSSIER+".ATYPE"   [UATY]

Local Integer I , VALMOD(20)

If DOSSIER=GDOSX3
 #Return
Endif
If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
 VALMOD(0) = 2 : # Superviseur
 VALMOD(8) = 2 : # Tronc commun
Endif

# raz screens
Call ECR_TRACE("Invalidation screens"-time$,0) From GESECRAN
Local Integer LNB

Link [UAMZ] With [UATY]GLOBVAR~=10;[UAMZ]CODTYP
&           As [ULNK]
&           Order By Key KULNK=[UAMZ]CODMSK;[UAMZ]CODZON
For [ULNK]KULNK(1)
    LNB+=1
    Call VALID_DIF(DOSSIER,0,"","","","","","",[F:UAMZ]CODMSK,[F:UAMZ]CODMSK,"","","","","","","","","","","","",VALMOD) From VALDICO
    For [ULNK]KULNK
        Break
    Next
Next
Call ECR_TRACE(num$(LNB)-"screens invalidated"-time$,0) From GESECRAN
Close Local File [UAMZ]
Close Local File [UATY]
Return

