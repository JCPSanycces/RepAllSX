$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 23220: RES='Codes frais'
   When 41193: RES='Code frais'
   When 8: RES='Intitulé'
   When 4010: RES='Intitulé court'
   When 43998: RES='Nature de dépense'
   When 71: RES='Code d'+"'"+'accès'
  Endcase
 When "ENG":
  Case _ID
   When 23220: RES='Expense codes'
   When 41193: RES='Expense code'
   When 8: RES='Description'
   When 4010: RES='Short description'
   When 43998: RES='Cost type'
   When 71: RES='Access code'
  Endcase
 When "ITA":
  Case _ID
   When 23220: RES='Codice spesa'
   When 41193: RES='Codice spesa'
   When 8: RES='Descrizione'
   When 4010: RES='Descr. breve'
   When 43998: RES='Natura spesa'
   When 71: RES='Codice accesso'
  Endcase
 When "POR":
  Case _ID
   When 23220: RES='Cód. desp.'
   When 41193: RES='Cód desp.'
   When 8: RES='Descr.'
   When 4010: RES='Desc. curta'
   When 43998: RES='Natureza despesa'
   When 71: RES='Código acesso'
  Endcase
 When "SPA":
  Case _ID
   When 23220: RES='Código gastos'
   When 41193: RES='Código gasto'
   When 8: RES='Descripción'
   When 4010: RES='Descrip. corta'
   When 43998: RES='Naturaleza de gastos'
   When 71: RES='Cód. de acceso'
  Endcase
 When "BRI":
  Case _ID
   When 23220: RES='Charge code'
   When 41193: RES='Expenses Code'
   When 8: RES='Description'
   When 4010: RES='Short title'
   When 43998: RES='Expense nature'
   When 71: RES='Access code'
  Endcase
 When "GER":
  Case _ID
   When 23220: RES='Spesencodes'
   When 41193: RES='Kostencode'
   When 8: RES='Bezeichnung'
   When 4010: RES='Kurzbezeichnung'
   When 43998: RES='Kostenart'
   When 71: RES='Zugriffscode'
  Endcase
 When "POL":
  Case _ID
   When 23220: RES='Kody wydatków'
   When 41193: RES='Kod kosztu'
   When 8: RES='Opis'
   When 4010: RES='Krótki tytuł'
