   When 71: RES='Kod dostępu'
  Endcase
 When "CHI":
  Case _ID
   When 23220: RES='费用代码'
   When 41193: RES='费用代码'
   When 8: RES='标题'
   When 4010: RES='简称'
   When 43998: RES='费用属性'
   When 71: RES='访问代码'
  Endcase
 When "ARB":
  Case _ID
   When 23220: RES='رموز النفقات'
   When 41193: RES='رمز المصاريف'
   When 8: RES='العنوان'
   When 4010: RES='وصف قصير'
   When 43998: RES='طبيعة النفقة'
   When 71: RES='رمز الدخول'
  Endcase
Endcase
Return
