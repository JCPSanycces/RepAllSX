#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ADXD","ADXD","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAF"         : Gosub RAF
Endcase
Return

$OUVRE
Local Mask ADXD [ADX]
Raz [M]
Return

$DEBUT
[M]SERVICE = adxtcp
Call LECTURE
Return

$SETBOUT
CHBOU += "=" : # Rafraîchir
Return

$BOUTON
Case BOUT
 When "1" : Call LECTURE
Endcase
Return

$APRES_MODIF
Case zoncou
 When "SERVICE" : Assign "[M]"+zoncou With zc : Call LECTURE
Endcase
Return

$RAF
Call LECTURE
Return

Subprog LECTURE
Local Char CHAINE(255)(1..5)
Local Integer I , J , K , DIME
Call VARIA("ADXDIR",CHAINE)
[M]REPERT = CHAINE
If [M]REPERT=""
 Call ERREUR(mess(23,139,1)) From GESECRAN : # Service inexistant sur cette machine
 Effzo 20-99
 End
Endif

Call VARIA("PATH",CHAINE)
Setlob [M]PATH With CHAINE

Call VARIA("ORACLE_HOME",CHAINE)
[M]ORAHOME = CHAINE

Call VARIA("ORACLE_SID",CHAINE)
[M]ORASID = CHAINE

Call VARIA("ADXORAOPT",CHAINE)
[M]OPTORA = CHAINE

Call VARIA("SQLS7_SID",CHAINE)
[M]SQLSID = CHAINE

If CHAINE=""
 Call VARIA("DB2_SID",CHAINE)
 [M]SQLSID = CHAINE
Endif

Call VARIA("DATASOURCE",CHAINE)
[M]SQLDATA = CHAINE

Affzo
End

Subprog VARIA(VARIA,CHAINE)
Value Char VARIA
Variable Char CHAINE()(1..)
Local Char MACHINE(250)
[L]MACHINE = [M]MACHINE+":"+num$([M]SERVICE)
Call VARADX(VARIA,[L]MACHINE,CHAINE)
End

Subprog VARADX(VARIA,MACHINE,CHAINE)
Value Char VARIA,MACHINE
Variable Char CHAINE()(1..)
Local Integer STAT , I
Local Integer SERVICE
I = instr(1,[L]MACHINE,":")
If I
 [L]SERVICE = val(right$([L]MACHINE,I+1))
 [L]MACHINE = left$([L]MACHINE,I-1)
Endif
If [L]MACHINE=""
 [L]MACHINE = adxmac(0)
Endif
If [L]SERVICE=0
 [L]SERVICE = adxtcp
Endif
Gosub SET_MACHINE
If !OK : End : Endif
Call SYSTEME2([L]MACHINE,"adxdwhat"-VARIA-num$([L]SERVICE),"",STAT,CHAINE) From ORDSYS
I = instr(1,CHAINE,":")
If I
 CHAINE = right$(CHAINE,I+2) : # Blanc devant 
Endif
End

$SET_MACHINE
Local Integer OK
If [L]MACHINE=""
 OK = 1
Else
 If [L]SERVICE<>0
  [L]MACHINE += ":"+num$([L]SERVICE)
 Endif
 Call LECMAC([L]MACHINE,OK) From DOSCONT
Endif
Return

Subprog C_SERVICE(VALEUR)
Variable Decimal VALEUR()
Local Char MACHINE(250)
Local Integer SERVICE
[L]MACHINE = [M]MACHINE
[L]SERVICE = VALEUR
Gosub SET_MACHINE
If !OK
 mkstat = 2
Else
 mkstat = 4
Endif
End
