#<AdxTL>@(#)0.0.0.0 $Revision$Class Non-conformance ID
# Supervisor
## ATY-ATYPE ## NCSID
# 2018-11-09 07:14:47 846

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,NCSID,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char NCSID
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File NCSRECENT [NCSRC]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".NCSRECENT" [NCSRC]
Endif

Default File [F:NCSRC]
Read [F:NCSRC]NCSRC0 = [L]NCSID
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]NCSID)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]NCSID)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


