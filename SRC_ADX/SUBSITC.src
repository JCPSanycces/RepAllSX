# Gestion du masque SITRACOD
$ACTION
Case ACTION
    When Default
Endcase
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran SITRACOD) 31/01/2007 15:07:43 (CCC)
######################################################################################
Subprog AP_CAR1(VALEUR)
Variable Char    VALEUR()
VALEUR = format$("K:1X",VALEUR)
If VALEUR=" "
    VALEUR=GTXTSPC
Endif
End

######################################################################################
Subprog AS_CAR1(VALEUR)
Variable Char    VALEUR()
If VALEUR=GTXTSPC
    VALEUR=" "
Endif
End

######################################################################################
Subprog C_CAR1(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    GMESSAGE=mess(10,123,1)
    mkstat=2
    End
Endif
End


######################################################################################
Subprog AP_CAR2(VALEUR)
Variable Char    VALEUR()
VALEUR = format$("K:1X",VALEUR)    # Il faut tronquer à 1 caractère
If VALEUR=" "
    VALEUR=GTXTVID
Endif
End

######################################################################################
Subprog AS_CAR2(VALEUR)
Variable Char    VALEUR()
If VALEUR=GTXTVID    # Si le champ est défini sur 1 caractère, on n'a pas la bonne valeur => il faut tronquer en AP
    VALEUR=" "
Endif
End

######################################################################################
Subprog AM_FMTCLE(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Diszo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
        [M:SITC]SPC(nolign-1)=2
        [M:SITC]MAJ(nolign-1)=2
        [M:SITC]ACCENT(nolign-1)=2
        Affzo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
    Else
        Actzo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
        Affzo [M:SITC]SPC(nolign-1),MAJ(nolign-1),ACCENT(nolign-1)
    Endif
End


######################################################################################
Subprog C_LNG(VALEUR)
Variable Char    VALEUR()

Onerrgo LNG_ERR
GBIDI1 = evalue(VALEUR)
Onerrgo
End

$LNG_ERR
    GMESSAGE = mess(83,123,1)
    mkstat=2
Resume

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SITRACOD) 01/02/2007 16:24:19 (CCC)
######################################################################################
Subprog B2_NBCAR
Local Integer I
Effzo [M:SITC]CAR1,CAR2
Raz [M:SITC]NBCAR
[M:SITC]CAR1([M:SITC]NBCAR)=GTXTSPC
[M:SITC]CAR2([M:SITC]NBCAR)="_"
[M:SITC]NBCAR+=1
For I=33 To 47
    [M:SITC]CAR1([M:SITC]NBCAR)=chr$(I)
    [M:SITC]CAR2([M:SITC]NBCAR)=GTXTVID
    [M:SITC]NBCAR+=1
Next
For I=58 To 64
    [M:SITC]CAR1([M:SITC]NBCAR)=chr$(I)
    [M:SITC]CAR2([M:SITC]NBCAR)=GTXTVID
    [M:SITC]NBCAR+=1
Next
For I=91 To 96
    [M:SITC]CAR1([M:SITC]NBCAR)=chr$(I)
    [M:SITC]CAR2([M:SITC]NBCAR)=GTXTVID
    [M:SITC]NBCAR+=1
Next
For I=123 To 126
    [M:SITC]CAR1([M:SITC]NBCAR)=chr$(I)
    [M:SITC]CAR2([M:SITC]NBCAR)=GTXTVID
    [M:SITC]NBCAR+=1
Next
Affzo [M:SITC]
End

######################################################################################
Subprog AM_CODFIC(VALEUR)
Variable Char    VALEUR()
    [M:SITC]SEQ(nolign-1) = func SEQ(VALEUR,[M]CODZONE(nolign-1))
End

######################################################################################
Subprog AM_CODZONE(VALEUR)
Variable Char    VALEUR()
    [M:SITC]SEQ(nolign-1) = func SEQ([M]CODFIC(nolign-1),VALEUR)
End

######################################################################################
Funprog SEQ(PFIC,PZON)
Value Char PFIC  # FGR 01/02/2010 : X3SUIVI60986
Value Char PZON  # FGR 01/02/2010 : X3SUIVI60986

Local Integer LSEQ, I

Raz LSEQ

For I=0 To [M:SITC]NBLIG-1
    If [M:SITC]CODFIC(I)=PFIC
&    & [M:SITC]CODZONE(I)=PZON
&    & [M:SITC]SEQ(I)>LSEQ
        LSEQ = [M:SITC]SEQ(I)
    Endif
Next

LSEQ += 1

End LSEQ

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SITRACOD) 08/02/2007 11:41:09 (CCC)
######################################################################################
Subprog C_CODZONE(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif

Look [ATZ]CODZONE=[M:SITC]CODFIC(nolign-1);VALEUR
If fstat
    GMESSAGE=mess(13,133,1)
    mkstat=2
Endif

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SITRACOD) 08/02/2007 16:20:18 (CCC)
######################################################################################
Subprog AM_LNG(VALEUR)
Variable Char    VALEUR()
    [M:SITC]VALLNG(nolign-1) = evalue(VALEUR)
    Affzo [M:SITC]VALLNG(nolign-1)
End


######################################################################################
# Tout sélectionner
######################################################################################
Subprog B2_NBLIG
Local Integer I
For I=0 To [M:SITC]NBLIG-1
    If [M:SITC]CODZONE2(I)=""
        [M:SITC]VALID(I) = 2
    Endif
Next
Affzo [M:SITC]
End

######################################################################################
# Tout désélectionner
######################################################################################
Subprog B3_NBLIG
Local Integer I
For I=0 To [M:SITC]NBLIG-1
    [M:SITC]VALID(I) = 1
Next
Affzo [M:SITC]
End

######################################################################################
Subprog C_VALID(VALEUR)
Variable Integer VALEUR
    # Les tables avec plusieurs éléments de clé ne peuvent être transcodés automatiquement
    If [M:SITC]CODZONE2(nolign-1)<>""
        VALEUR=1
    Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SITRACOD) 17/07/2009 15:18:15 (GA)
######################################################################################
Subprog AS_VALID(VALEUR)
Variable Integer VALEUR
    # Les tables avec plusieurs éléments de clé ne peuvent être transcodés automatiquement
    If [M:SITC]CODZONE2(nolign-1)<>""
        mkstat=2
    Endif
End

