#<AdxTL>@(#)5.0.0.0 $Revision$
##################################################################################################
#
#  Consultation en devise
#     --> Filtre des mouvements dans une devise souhaitée
#     --> Affichage des mouvements en contre valeur
#
#####  V140  #####
# 4 Cas :
#    1 - Devise non renseignée : Tous les mouvements renseignés en devise de la société
#    2 - Devise locale         : Uniquement les mouvements passés dans la devise société
#    3 - Devise reporting      : Les mouvements passés uniquement dans la devise reporting + la contre valeur
#    4 - Autres                : Les mouvements passés dans la devise souhaitée + la contre valeur
#
#####  V6  #####
# 3 Cas :
#  1 - Devise de transaction correspondant à la devise référentiel  :
#      => On filtre sur les mouvements saisis dans cette devise
#      => On renseigne tous les champs (doublons)
#  2 - Devise renseignée <> devise référentiel :
#      => On filtre sur les mouvements saisi dans cette devise de selection(transaction)
#      => On renseigne les champs normaux dans cette devise ET les champs en devise référentiel
#  3 - Devise de transaction non renseignée :
#      => On prend TOUS les mouvements
#      => On ne renseigne que les champs en devise référentiel
#
##################################################################################################

Raz GNBMASKOUV
Local Char PARAM(10)(1..7)
Call GCONSULT("BAL","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"BAL") From SUBGTC
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LECTURE"     : Gosub LECTURE
 When "LISTE1"      : Gosub LISTE1
 When "LISTE2"      : Gosub LISTE2
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$OUVRE
Local Integer SPSTAT, TYPBAL
Local Char TYPDEV
Local Integer I, J, K, CTLACS
Local Integer NOL
Local Integer DERPER, MAXPER(0..50)
Local Integer E, EDEB, EFIN, PDEB, PFIN, BDEB, BFIN
Local Libelle XDEV, PLEIN, GRP, LIG, COHGRP
Local Decimal EXERCICE, PERIODE, MONTANT, MT
Local Char    FILBAL(250)
Local Char    RACDEB(GLONGAC), RACFIN(GLONGAC), CPDEB(GLONGAC), CPFIN(GLONGAC)
Local Char    SACCUR(GLONSAC), CPTCUR(GLONGAC), COLL(GLONGAC), DEVLEC(GLONCUR), DEVSOC(GLONCUR),DEVLED(GLONCUR)
Local Date    DDEB, DFIN, DEBEX
Local Integer NBSITE, COURTYP

NBSITE = max(1,GNBSITE)
Local Integer TPDEB(1..NBSITE) , TPFIN(1..NBSITE)
Local Integer TEDEB(1..NBSITE) , TEFIN(1..NBSITE) , TMAXPER(0..50,1..NBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE), TSOCIETE(GLONCPY)(1..NBSITE)

Local Char    TDEVLEC(GLONCUR)(1..NBSITE) , TDEVSOC(GLONCUR)(1..NBSITE)
Local Char    TDEVLED(GLONCUR)(1..NBSITE)

NBSITE = 0
Local Decimal DEB, CRE, DEBANT, CREANT
Local Decimal DEBLED, CRELED, DEBANTLED, CREANTLED
RACDEB=""
DERPER = dim([F:BAL]DEB)-1
Gosub DEFCRIT

Return

$DEFCRIT
If [M:BAL1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:BAL1]FCY,GUSRFCY(1..GNBAUZ))
 [M:BAL1]FCY=""
Endif
DDEB=[M:BAL1]DATDEB
DFIN=[M:BAL1]DATFIN
For I=1 To dim(PARAM)
 Case I
  When 1 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAL1]CPY = PARAM(I)
     If [M:BAL1]FCY<>""
      Call LECTURE("FCY",[M:BAL1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BAL1]CPY : [M:BAL1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 2 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BAL1]FCY = PARAM(I)
     [M:BAL1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
  When 3 : # Type de référentiel
   If clalev([GCM])=0 : Local File GACM [GCM] : Endif
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   If val(PARAM(I))<>0
    If [M:BAL1]CPY<>""
     Call LECTURE("CPY",[M:BAL1]CPY,"") From CONTOBJ
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:BAL1]LEDTYP = val(PARAM(I))
      [M:BAL1]COA    = [F:LED]COA
     Endif
    Endif
   Endif
   If [M:BAL1]LEDTYP = 0 :  [M:BAL1]LEDTYP = 1 : Endif
  When 4 : # Collectif
   If PARAM(I)<>""
    Read [GAC]GAC1 = [M:BAL1]COA;PARAM(I)
    If !fstat & [F:GAC]SAC=2 : [M:BAL1]SAC = PARAM(I) : Endif
   Endif
  When 5 : # Filtre
   If PARAM(I)<>""
    mkstat=0 : Call C_CPDEB(PARAM(I))
    If !mkstat : [M:BAL1]CPDEB = PARAM(I) : Endif
   Endif
  When 6 : # Date début
   If instr(1,PARAM(I),"/")
    [M:BAL1]DATDEB = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BAL1]DATDEB = PARAM(I)
   Endif
  When 7 : # Date fin
   If instr(1,PARAM(I),"/")
    [M:BAL1]DATFIN = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BAL1]DATFIN = PARAM(I)
   Endif
  When 8 : Break
 Endcase
Next I

# Valeurs par défaut
Default Mask [BAL1]
Call INIT(DDEB,DFIN) From CONSSUB

If [M:CBAL]HBILAN=0  : [M:CBAL]HBILAN  = 2 : Endif
If [M:CBAL]ANOUV=0   : [M:CBAL]ANOUV   = 2 : Endif
If [M:CBAL]CLOTURE=0 : [M:CBAL]CLOTURE = 2 : Endif

Gosub CRITENT From =PROGCNS
Return

$LECTURE
If [M:BAL1]CPY=""  | [M:BAL1]DATDEB=[0/0/0] | [M:BAL1]DATFIN=[0/0/0] : NBLU=0 : Return : Endif
Effzo [M:BAL2]5
XDEV = 0
Call LECTURE("CPY",[M:BAL1]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>2
 # On ne verifie plus que la cohérence des débuts de période (exercices décalés autorisés)
 Call CNTCOHPERV6([M:BAL1]CPY,[M:BAL1]LEDTYP,[M:BAL1]DATDEB,[M:BAL1]DATFIN,SPSTAT,GMESSAGE) From CPTCNT
 If SPSTAT=0 : Return : Endif
Endif

Gosub INIT
If GRP & !COHGRP & (CHGPAG=1 or CHGPAG=3)
 Call MESSAGE(mess(62,109,1)) From GESECRAN : # Les exercices de ce groupe sont décalés, pas de soldes antérieurs
Endif

##################################################################
# Cas des Regroupements de sites :                               #
#  Si on ne posséde pas une devise unique pour l'ensemble des    #
#  sociétés juridiques des sites faisant partie du regroupement  #
#  &  que la devise souhaitée est non renseignée (cas=1) alors   #
#  aucune lecture de la balance n'est possible                   #
##################################################################
If [M:BAL1]CUR="" & XDEV
 GERR=1
 # Devises hétérogènes pour ce regroupement
 GMESSAGE = mess(54,109,1)-[M:BAL1]CPY : Return
Endif

If [M:BAL1]SAC<>""
 Read [GAC]GAC1 = [M:BAL1]COA;[M:BAL1]SAC
 TYPBAL = 2 : COLL = [F:GAC]ACC
Else
 TYPBAL = 1 : COLL = ""
Endif

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

J = instr(1,[M:BAL1]CPDEB,"*")
K = instr(1,[M:BAL1]CPDEB,"?")

If     J & K : J = min(J,K)
Elsif !J & K : J = K
Endif

If J
 RACDEB = left$([M:BAL1]CPDEB,J-1)
 If RACDEB<>""
  RACFIN = left$(RACDEB,len(RACDEB)-1)+chr$(ascii(mid$(RACDEB,len(RACDEB),1))+1)
 Endif
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:BAL2] : Endif
If !GRP
 Gosub LECT
Else
 Gosub LECT_GRP
Endif
SACCUR = [M:BAL1]SAC
CPTCUR = [M:BAL1]CPDEB

## Demande de modif 14308 (CP : 04/12/03)
If !CTLACS
 # Vos résultats sont restreints à vos droits utilisateurs
 Call MESSAGE(mess(55,109,1)) From GESECRAN
 Return
Endif
Return


######################################
# Lecture pour une société juridique #
######################################
$LECT
Gosub FILTRE

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

If CHGPAG>0
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE = LEDTYP;CPY;FCY;ACC;BPR;FIY;CUR
Else
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE = LEDTYP Desc;CPY Desc;FCY Desc; ACC Desc;BPR Desc;FIY Desc;CUR Desc
Endif

CTLACS = 1
For [BAL]CLE(5) : # BPR
 OK = 1
 If TYPBAL=1
  Read [GAC]GAC0 = [M:BAL1]COA;[F:BAL]ACC
  If !fstat
   If [F:GAC]CLSCOD<>"" & [M:CBAL]HBILAN<>2
    Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
    Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
    If [F:CLS]TYP=2
     OK = 0
    Endif
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS = 0 : Endif
  Endif
 Endif
 If OK
  Gosub RAZE
  For [BAL]CLE(6) : # FIY
   For [BAL]CLE
    Gosub CALCUL
   Next : # CLE(6)
  Next : # CLE
  If LIG
   If NBLU=1
    If CHGPAG=2 or CHGPAG=-2 : Raz [M:BAL2] : Endif
    NBLU = 2
   Endif
   If CHGPAG>0
    If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
    NOL += 1
    Case TYPBAL
     When 1
      If NOL=0 : CPDEB = [F:BAL]ACC : Endif
      CPFIN = [F:BAL]ACC
     When 2
      If NOL=0 : CPDEB = [F:BAL]BPR : Endif
      CPFIN = [F:BAL]BPR
    Endcase
   Else
    If NOL<=0 : RETOUR = 2 : Break : Endif
    NOL -= 1
    Case TYPBAL
     When 1
      If NOL=MAXLIG-1 : CPFIN = [F:BAL]ACC : Endif
      CPDEB = [F:BAL]ACC
     When 2
      If NOL=MAXLIG-1 : CPFIN = [F:BAL]BPR : Endif
      CPDEB = [F:BAL]BPR
    Endcase
   Endif
   Case TYPBAL
    When 1
     [M:BAL2]COMPTE(NOL) = [F:BAL]ACC
     Call LECTEXTRA([M:BAL2]INTIT(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    When 2
     [M:BAL2]COMPTE(NOL) = [F:BAL]BPR
     Read [BPR]BPR0 = [M:BAL2]COMPTE(NOL)
     If !fstat : [M:BAL2]INTIT(NOL) = [F:BPR]BPRNAM : Endif
   Endcase
   Gosub TOTAUX
  Endif
 Endif : # (OK)
Next : # CLE
Filter [BAL]
Return


##########################################
# Lecture pour une société non juridique #
##########################################
$LECT_GRP
Gosub FILT_GRP

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

If CHGPAG>0

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 = LEDTYP;ACC;BPR;CPY;FCY;FIY;CUR

Else

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 =  LEDTYP Desc; ACC Desc;BPR Desc;CPY Desc;FCY Desc;FIY Desc;CUR Desc

Endif


CTLACS = 1
For [LNK]CLE2(3) : # Compte/tiers
 OK = 1
 If TYPBAL=1
  If [F:GAC]CLSCOD<>"" & [M:CBAL]HBILAN<>2
   Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
   Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
   If [F:CLS]TYP=2
    OK = 0
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS = 0 : Endif
  Endif
 Endif
 If OK
  Gosub RAZE
  For [LNK]CLE2
   I = find([F:BAL]FCY,TSITE(1..NBSITE))
   If I
    DEVSOC=TDEVSOC(I)
    DEVLED=TDEVLED(I)
    EDEB = TEDEB(I) : EFIN = TEFIN(I) : PDEB = TPDEB(I) : PFIN = TPFIN(I)
    For E=EDEB To EFIN : MAXPER(E) = TMAXPER(E,I) : Next E
    If [F:BAL]FIY>=EDEB & [F:BAL]FIY<=EFIN
     Gosub CALCUL
    Endif
   Endif
  Next : # [BAL]
  If LIG
   If NBLU=1
    If CHGPAG=2 or CHGPAG=-2 : Raz [M:BAL2] : Endif
    NBLU=2
   Endif
   If CHGPAG>0
    If NOL>=MAXLIG-1 : SUITE = 2 : PLEIN = 1 : Break : Endif
    NOL += 1
    Case TYPBAL
     When 1
      If NOL=0 : CPDEB = [F:BAL]ACC : Endif
      CPFIN = [F:BAL]ACC
     When 2
      If NOL=0 : CPDEB = [F:BAL]BPR : Endif
      CPFIN = [F:BAL]BPR
    Endcase
   Else
    If NOL<=0 : RETOUR = 2 : PLEIN = 1 : Break : Endif
    NOL -= 1
    Case TYPBAL
     When 1
      If NOL=MAXLIG-1 : CPFIN = [F:BAL]ACC : Endif
      CPDEB = [F:BAL]ACC
     When 2
      If NOL=MAXLIG-1 : CPFIN = [F:BAL]BPR : Endif
      CPDEB = [F:BAL]BPR
    Endcase
   Endif
   Case TYPBAL
    When 1
     [M:BAL2]COMPTE(NOL) = [F:BAL]ACC
     Call LECTEXTRA([M:BAL2]INTIT(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    When 2
     [M:BAL2]COMPTE(NOL) = [F:BAL]BPR
     [M:BAL2]INTIT(NOL)  = [F:BPR]BPRNAM
   Endcase
   Gosub TOTAUX
  Endif
 Endif
Next
Return

###################################################################################
## Calculs
###################################################################################
$RAZE
Raz LIG
Raz DEB, CRE, DEBANT, CREANT
Raz DEBLED, CRELED, DEBANTLED, CREANTLED
Return

$CALCUL
#
# Pointeurs de la balance
#
E = [F:BAL]FIY
#
# Exercice intermédiaire, on prend tout
#
BDEB = 1
BFIN = MAXPER(E)
#
# 1er Exercice, plus d'à-nouveaux, il y a une colonne spéciale
#
If E=EDEB
 BDEB = PDEB
Endif
#
# Dernier exercice, on ajoute la clôture (sauf société avec exercices décalés)
#
If E=EFIN
 If PFIN=MAXPER(E) & [M:CBAL]CLOTURE=2 & COHGRP : BFIN = DERPER
 Else                                           : BFIN = PFIN
 Endif
Endif
#
# Pour l'Italie, on prend en compte tous les à-nouveaux ????
#
#If [F:LED]ENDVCR=2 & E<>EDEB : # voir CONSBAF
# If BDEB=1 & [M:CBAL]ANOUV=2 : BDEB = 0 : Endif
#Endif

Case TYPDEV

 When "1","2" :
  #cas1 => On renseigne tous les champs (doublons)
  #cas2 => On renseigne les champs normaux dans cette devise ET les champs en devise référentiel

  If COHGRP & E=EDEB
   DEBANT    += sum([F:BAL]DEB(1..BDEB-1))
   CREANT    += sum([F:BAL]CDT(1..BDEB-1))
   DEBANTLED += sum([F:BAL]DEBLED(1..BDEB-1))
   CREANTLED += sum([F:BAL]CDTLED(1..BDEB-1))
   If [M:CBAL]ANOUV=2
    DEBANT    += [F:BAL]DEB(0)
    CREANT    += [F:BAL]CDT(0)
    DEBANTLED += [F:BAL]DEBLED(0)
    CREANTLED += [F:BAL]CDTLED(0)
    #KC
    #Si ANOUV et que FINEX executer alors on affiche pas cette ligne ds la balance
    If DEBANTLED=CREANTLED
     DEBANTLED=0
     CREANTLED=0
     LIG=0
    Endif
    #KC
   Endif
  Endif
  DEB       += sum([F:BAL]DEB(BDEB..BFIN))
  CRE       += sum([F:BAL]CDT(BDEB..BFIN))
  DEBLED    += sum([F:BAL]DEBLED(BDEB..BFIN))
  CRELED    += sum([F:BAL]CDTLED(BDEB..BFIN))

 When "3" :

  #cas3 => On ne renseigne que les champs en devise référentiel
  If COHGRP & E=EDEB
   DEBANTLED += sum([F:BAL]DEBLED(1..BDEB-1))
   CREANTLED += sum([F:BAL]CDTLED(1..BDEB-1))
   If [M:CBAL]ANOUV=2
    DEBANTLED += [F:BAL]DEBLED(0)
    CREANTLED += [F:BAL]CDTLED(0)
    #KC
    #Si ANOUV et que FINEX executer alors on affiche pas cette ligne ds la balance
    If DEBANTLED=CREANTLED
     DEBANTLED=0
     CREANTLED=0
     LIG=0
    Endif
    #KC
   Endif
  Endif
  DEBLED    += sum([F:BAL]DEBLED(BDEB..BFIN))
  CRELED    += sum([F:BAL]CDTLED(BDEB..BFIN))

Endcase


If   DEB<>0    or CRE<>0    or DEBANT<>0    or CREANT<>0
& or DEBLED<>0 or CRELED<>0 or DEBANTLED<>0 or CREANTLED<>0
  LIG = 1
Endif

GPOINT = "UPDENQBAL" : Gosub ENTREE From EXEFNC
Return

###################################################################################
## Totaux, Soldes
###################################################################################
$TOTAUX
[M:BAL2]ANTDEB(NOL)    = DEBANT
[M:BAL2]ANTCDT(NOL)    = CREANT
[M:BAL2]DEB(NOL)       = DEB
[M:BAL2]CDT(NOL)       = CRE
[M:BAL2]ANTDEBLED(NOL) = DEBANTLED
[M:BAL2]ANTCDTLED(NOL) = CREANTLED
[M:BAL2]DEBLED(NOL)    = DEBLED
[M:BAL2]CDTLED(NOL)    = CRELED

Case TYPDEV
 When "1","2" :

# Totaux en devises

  If [M:BAL2]ANTDEB(NOL)>[M:BAL2]ANTCDT(NOL)
   [M:BAL2]ANTDEB(NOL) = [M:BAL2]ANTDEB(NOL)-[M:BAL2]ANTCDT(NOL)
   [M:BAL2]ANTCDT(NOL) = 0
  Else
   [M:BAL2]ANTCDT(NOL) = [M:BAL2]ANTCDT(NOL)-[M:BAL2]ANTDEB(NOL)
   [M:BAL2]ANTDEB(NOL) = 0
  Endif
  If [M:BAL2]DEB(NOL)>[M:BAL2]CDT(NOL)
   [M:BAL2]SOLDEB(NOL) = [M:BAL2]DEB(NOL)-[M:BAL2]CDT(NOL)
   [M:BAL2]SOLCDT(NOL) = 0
  Else
   [M:BAL2]SOLCDT(NOL) = [M:BAL2]CDT(NOL)-[M:BAL2]DEB(NOL)
   [M:BAL2]SOLDEB(NOL) = 0
  Endif
  [M:BAL2]FINDEB(NOL) = [M:BAL2]ANTDEB(NOL)-[M:BAL2]ANTCDT(NOL)+[M:BAL2]SOLDEB(NOL)-[M:BAL2]SOLCDT(NOL)
  If [M:BAL2]FINDEB(NOL)<0
   [M:BAL2]FINCDT(NOL) = -[M:BAL2]FINDEB(NOL)
   [M:BAL2]FINDEB(NOL) = 0
  Endif

# Totaux en devise référentiel

  If [M:BAL2]ANTDEBLED(NOL)>[M:BAL2]ANTCDTLED(NOL)
   [M:BAL2]ANTDEBLED(NOL) = [M:BAL2]ANTDEBLED(NOL)-[M:BAL2]ANTCDTLED(NOL)
   [M:BAL2]ANTCDTLED(NOL) = 0
  Else
   [M:BAL2]ANTCDTLED(NOL) = [M:BAL2]ANTCDTLED(NOL)-[M:BAL2]ANTDEBLED(NOL)
   [M:BAL2]ANTDEBLED(NOL) = 0
  Endif
  If [M:BAL2]DEBLED(NOL)>[M:BAL2]CDTLED(NOL)
   [M:BAL2]SOLDEBLED(NOL) = [M:BAL2]DEBLED(NOL)-[M:BAL2]CDTLED(NOL)
   [M:BAL2]SOLCDTLED(NOL) = 0
  Else
   [M:BAL2]SOLCDTLED(NOL) = [M:BAL2]CDTLED(NOL)-[M:BAL2]DEBLED(NOL)
   [M:BAL2]SOLDEBLED(NOL) = 0
  Endif
  [M:BAL2]FINDEBLED(NOL) = [M:BAL2]ANTDEBLED(NOL)-[M:BAL2]ANTCDTLED(NOL)+[M:BAL2]SOLDEBLED(NOL)-[M:BAL2]SOLCDTLED(NOL)
  If [M:BAL2]FINDEBLED(NOL)<0
   [M:BAL2]FINCDTLED(NOL) = -[M:BAL2]FINDEBLED(NOL)
   [M:BAL2]FINDEBLED(NOL) = 0
  Endif

 When "3" :

# Totaux en devise référentiel

  If [M:BAL2]ANTDEBLED(NOL)>[M:BAL2]ANTCDTLED(NOL)
   [M:BAL2]ANTDEBLED(NOL) = [M:BAL2]ANTDEBLED(NOL)-[M:BAL2]ANTCDTLED(NOL)
   [M:BAL2]ANTCDTLED(NOL) = 0
  Else
   [M:BAL2]ANTCDTLED(NOL) = [M:BAL2]ANTCDTLED(NOL)-[M:BAL2]ANTDEBLED(NOL)
   [M:BAL2]ANTDEBLED(NOL) = 0
  Endif
  If [M:BAL2]DEBLED(NOL)>[M:BAL2]CDTLED(NOL)
   [M:BAL2]SOLDEBLED(NOL) = [M:BAL2]DEBLED(NOL)-[M:BAL2]CDTLED(NOL)
   [M:BAL2]SOLCDTLED(NOL) = 0
  Else
   [M:BAL2]SOLCDTLED(NOL) = [M:BAL2]CDTLED(NOL)-[M:BAL2]DEBLED(NOL)
   [M:BAL2]SOLDEBLED(NOL) = 0
  Endif
  [M:BAL2]FINDEBLED(NOL) = [M:BAL2]ANTDEBLED(NOL)-[M:BAL2]ANTCDTLED(NOL)+[M:BAL2]SOLDEBLED(NOL)-[M:BAL2]SOLCDTLED(NOL)
  If [M:BAL2]FINDEBLED(NOL)<0
   [M:BAL2]FINCDTLED(NOL) = -[M:BAL2]FINDEBLED(NOL)
   [M:BAL2]FINDEBLED(NOL) = 0
  Endif

Endcase
Local Integer DIV
If [M:BAL1]DIVISE<>0
 DIV = [M:BAL1]DIVISE
Else
 DIV = 1
Endif

[M:BAL2]ANTDEB(NOL)    /= DIV
[M:BAL2]ANTCDT(NOL)    /= DIV
[M:BAL2]DEB(NOL)       /= DIV
[M:BAL2]CDT(NOL)       /= DIV
[M:BAL2]DEBLED(NOL)    /= DIV
[M:BAL2]CDTLED(NOL)    /= DIV
[M:BAL2]FINDEB(NOL)    /= DIV
[M:BAL2]FINCDT(NOL)    /= DIV

[M:BAL2]ANTDEBLED(NOL) /= DIV
[M:BAL2]ANTCDTLED(NOL) /= DIV
[M:BAL2]SOLDEB(NOL)    /= DIV
[M:BAL2]SOLCDT(NOL)    /= DIV
[M:BAL2]SOLDEBLED(NOL) /= DIV
[M:BAL2]SOLCDTLED(NOL) /= DIV
[M:BAL2]FINDEBLED(NOL) /= DIV
[M:BAL2]FINCDTLED(NOL) /= DIV

Return

######################################################################################
## Filtre pour une société juridique
######################################################################################
$FILTRE
FILBAL = 'LEDTYP='+num$([M:BAL1]LEDTYP)
Case [M:BAL1]CUR
 When "" :
  TYPDEV = "3"
  FILBAL -= ""
 When [M:BAL1]CURLED :
  TYPDEV = "1"
  FILBAL -= '& CUR="'+[M:BAL1]CUR+'"'
 When Default :
  TYPDEV = "2"
  FILBAL -= '& CUR="'+[M:BAL1]CUR+'"'
Endcase
FILBAL -= '& FCY="'+[M:BAL1]FCY+'"'
FILBAL -= '& CPY="'+[M:BAL1]CPY+'"'
FILBAL -= '& FIY>='+num$(EDEB)+' & FIY<='+num$(EFIN)

# Plus d'autorisation site. On vérifie qu'on a droit à ce qu'on demande

Case TYPBAL
 When 1
  FILBAL -= '& BPR=""'
  If J
   If RACDEB<>"" : FILBAL -= '& ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& ACC<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(ACC,"'+[M:BAL1]CPDEB+'")'
  Elsif [M:BAL1]CPDEB<>""
   FILBAL -= '& ACC>="'+[M:BAL1]CPDEB+'"'
  Endif
 When 2
  FILBAL -= '& ACC="'+COLL+'" & BPR<>""'
  If J
   If RACDEB<>"" : FILBAL -= '& BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& BPR<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(BPR,"'+[M:BAL1]CPDEB+'")'
  Elsif [M:BAL1]CPDEB<>""
   FILBAL -= '& BPR>="'+[M:BAL1]CPDEB+'"'
  Endif
Endcase
If SACCUR=[M:BAL1]SAC & CPTCUR=[M:BAL1]CPDEB
 Case CHGPAG
  When 3 : # Rafraichissement
   Case TYPBAL
    When 1 : FILBAL -= '& ACC>="'+CPDEB+'"'
    When 2 : FILBAL -= '& BPR>="'+CPDEB+'"'
   Endcase
  When 2 : # Suite
   Case TYPBAL
    When 1 : FILBAL -= '& ACC>"'+CPFIN+'"'
    When 2 : FILBAL -= '& BPR>"'+CPFIN+'"'
   Endcase
  When -2 : # Retour
   Case TYPBAL
    When 1 : FILBAL -= '& ACC<"'+CPDEB+'"'
    When 2 : FILBAL -= '& BPR<"'+CPDEB+'"'
   Endcase
 Endcase
Endif
Return


######################################################################################
## Filtre pour des groupements de sites
######################################################################################
$FILT_GRP
FILBAL   = '[F:BAL]LEDTYP='+num$([M:BAL1]LEDTYP)
FILBAL  -= '& [F:BAL]COA="'+[M:BAL1]COA+'"'
Case [M:BAL1]CUR
 When "" :
  TYPDEV = "3"
 When [M:BAL1]CURLED :
  TYPDEV = "1"
  FILBAL -= '& [F:BAL]CUR="'+[M:BAL1]CUR+'"'
 When Default :
  TYPDEV = "2"
  FILBAL -= '& [F:BAL]CUR="'+[M:BAL1]CUR+'"'
Endcase
FILBAL -= '& [F:FGR]CPY="'+[M]CPY+'"'
FILBAL -= '& [F:BAL]FCY<>""'

Case TYPBAL
 When 1
  FILBAL -= '& [F:BAL]BPR=""'
  If J
   If RACDEB<>"" : FILBAL -= '& [F:BAL]ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]ACC<"'+RACFIN+'"'  : Endif
   FILBAL -= '& pat([F:BAL]ACC,"'+[M:BAL1]CPDEB+'")<>0'
  Elsif [M:BAL1]CPDEB<>""
   FILBAL -= '& [F:BAL]ACC>="'+[M:BAL1]CPDEB+'"'
  Endif
 When 2
  FILBAL -= '& [F:BAL]BPR<>""'
  FILBAL -= '& [F:BAL]ACC="'+COLL+'"'
  If J
   FILBAL -= '& pat([F:BAL]BPR,"'+[M:BAL1]CPDEB+'")<>0'
   If RACDEB<>"" : FILBAL -= '& [F:BAL]BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]BPR<"'+RACFIN+'"' : Endif
  Elsif [M:BAL1]CPDEB<>""
   FILBAL -= '& [F:BAL]BPR>="'+[M:BAL1]CPDEB+'"'
  Endif
Endcase

If SACCUR=[M:BAL1]SAC & CPTCUR=[M:BAL1]CPDEB
 Case CHGPAG
  When 3 : # Rafraichissement
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC>="'+CPDEB+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR>="'+CPDEB+'"'
   Endcase
  When 2 : # Suite
  Case TYPBAL
   When 1 : FILBAL -= '& [F:BAL]ACC>"'+CPFIN+'"'
   When 2 : FILBAL -= '& [F:BAL]BPR>"'+CPFIN+'"'
  Endcase
  When -2 : # Retour
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC<"'+CPDEB+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR<"'+CPDEB+'"'
   Endcase
 Endcase
Endif

Return

################################################
$INIT
Raz MAXPER
Call LECTURE("CPY",[M:BAL1]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If [M:BAL1]LED<>""
 Call LECTURE("LED",[M:BAL1]LED,"") From CONTOBJ
Else
 Call LECTURE("LED",[F:GCM]LED([M:BAL1]LEDTYP-1),"") From CONTOBJ
Endif
GRP = ([F:CPY]CPYLEGFLG=1)
If !GRP
 [M:BAL1]COA = [F:LED]COA
 Call GETPERSOC([M:BAL1]CPY,[M:BAL1]LEDTYP,[M:BAL1]DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 PDEB = PERIODE

 Call GETPERSOC([M:BAL1]CPY,[M:BAL1]LEDTYP,[M:BAL1]DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 PFIN = PERIODE

 Read [FIY]FIY0 = [M:BAL1]CPY;[M:BAL1]LEDTYP;EXERCICE
 For EXERCICE=EDEB To EFIN
  Filter [PER] Where CPY=[M:BAL1]CPY & LEDTYP=[M:BAL1]LEDTYP & FIYNUM=EXERCICE
  Read [PER]PER0 Last
  MAXPER(EXERCICE) = [F:PER]PERNUM
 Next
 Filter [PER]
 DEVLED = [F:GCM]CUR([M:BAL1]LEDTYP-1)
 DEVSOC = DEVLED : # Il n'y a plus de DEVSOC!
 XDEV   = 0
 COHGRP = 1

Else

 XDEV   = 0 : # Même devise pour les # sites
 COHGRP = 1 : # Cohérence des exercices
 NBSITE = 0
 For [FGR]FGR0 Where CPY = [M:BAL1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ

  # On borne par rapport aux premier et dernier exercice

  Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BAL1]LEDTYP
  Read [FIY]FIY0 First
  If [M:BAL1]DATDEB>=[F:FIY]FIYSTR : DDEB = [M:BAL1]DATDEB : Else : DDEB = [F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If [M:BAL1]DATFIN<=[F:FIY]FIYEND : DFIN = [M:BAL1]DATFIN : Else : DFIN = [F:FIY]FIYEND : Endif
  Filter [FIY]

  # On ne prend en compte le site que si la période est mouvementée

  If DDEB<=DFIN
   NBSITE += 1
   TSITE(NBSITE) = [F:FGR]FCY
   Call GETPERSOC([F:FCY]LEGCPY,[M:BAL1]LEDTYP,DDEB,EXERCICE,PERIODE) From CPTSUB
   TEDEB(NBSITE) = EXERCICE
   TPDEB(NBSITE) = PERIODE
   Read [FIY]FIY0 = [F:FCY]LEGCPY;[M:BAL1]LEDTYP;EXERCICE
   If NBSITE=1
    DEBEX = [F:FIY]FIYSTR
   Elsif DEBEX<>[F:FIY]FIYSTR
    COHGRP = 0
   Endif
   Call GETPERSOC([F:FCY]LEGCPY,[M:BAL1]LEDTYP,DFIN,EXERCICE,PERIODE) From CPTSUB
   TEFIN(NBSITE) = EXERCICE
   TPFIN(NBSITE) = PERIODE
   For EXERCICE=TEDEB(NBSITE) To TEFIN(NBSITE) : # voir CONSBAF
    Filter [PER] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BAL1]LEDTYP & FIYNUM=EXERCICE
    Read [PER]PER0 Last
    TMAXPER(EXERCICE,NBSITE) = [F:PER]PERNUM
    Filter [PER]
   Next
   TSOCIETE(NBSITE) = [F:FCY]LEGCPY
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   TDEVSOC(NBSITE) = [F:CPY]ACCCUR
   Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
   TDEVLED(NBSITE) = [F:GCM]CUR([M:BAL1]LEDTYP-1)
   TDEVSOC(NBSITE) = TDEVLED(NBSITE) : # Il n'y a plus de DEVSOC!
   If NBSITE>1 & TDEVSOC(NBSITE)<>TDEVSOC(1) : XDEV = 1 : Endif
   Call LECTURE("LED",[F:GCM]LED([M:BAL1]LEDTYP-1),"") From CONTOBJ
   [M:BAL1]COA = [F:LED]COA
  Endif
 Next : # [FGR]
Endif
Return

$LISTE1
If [M:BAL1]SAC<>""
 #RPTCOD = "BALGRPAUX"
 RPTCOD="CNSBALAUX"
Else
 #RPTCOD = "BALGRP"
 RPTCOD="CNSBALGRP"
Endif
Return

$LISTE2
[M:BAL1]CDEB = ""
[M:BAL1]CFIN = "ZZZ"
If [M:BAL1]CPDEB<>""
 J = instr(1,[M:BAL1]CPDEB,"*")
 K = instr(1,[M:BAL1]CPDEB,"?")
 If     J & K : J = min(J,K)
 Elsif !J & K : J = K
 Endif
 If J
  [M:BAL1]CDEB = left$([M:BAL1]CPDEB,J-1)
  If [M:BAL1]CDEB<>""
   [M:BAL1]CFIN = [M:BAL1]CDEB+"ZZZ"
  Endif
 Endif
Endif

DEVLEC = [M:BAL1]CURLED

Call LECTURE("CPY",[M:BAL1]CPY,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)
If [M:BAL1]CUR<>""
 DEVLEC = [M:BAL1]CUR
Else
 DEVLEC = [M:BAL1]CURLED
Endif

J += 1 : TBPAR(J) = mess(18,105,1) : TBVAL(J) = DEVLEC

If [M:BAL1]DIVISE<>0
 # cours : devise de lecture exprimée en devise d'impression ([M:BAL1]CUR)
 MT = [M:BAL1]DIVISE
 Call CONVERT(DEVLEC,[M:BAL1]CUR,DEVSOC,COURTYP,[M:BAL1]DATFIN,MT,MONTANT,SPSTAT) From TRTDEV
 If !SPSTAT
  MONTANT = MONTANT / MT
  J+=1 : TBPAR(J)=mess(19,105,1) : TBVAL(J)=num$(MONTANT)
 Endif
Endif
Return

$APRES_MODIF
If COUZON="NBLIG"
 Call LECTURE("GAC",[M]COMPTE(nolign-1),[M:BAL1]COA) From CONTOBJ
 If [F:GAC]SAC=2
  [M:BAL1]SAC   = [F:GAC]ACCSHO
  [M:BAL1]CPDEB = ""
  CHGPAG=1
  Default [L] : # Sinon c'est la classe [M] dans cette étiquette
  Gosub LECTURE From GCONSULT
  Gosub SETBOUT From GCONSULT
  Affzo
 Endif
Endif
Return


##################################################################################################
##                                                                                              ##
## Etiquettes des masques CONSBAL1 & CRITBAL & CONSBAL2                                         ##
##                                                                                              ##
##################################################################################################

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char CPYSVE(GLONCPY)
CPYSVE= [M]CPY
Call C_CPY(VALEUR) From CONSSUB
# Remise à vide du chmp CUR, ne doit pas être initialisé par CONSSUB car ici le chp CUR est
# le champ de devise d'affichage et pas la devise de la société.On devrait renomer le champ CUR en CURDSP par exemple.
If [M:BAL1]CPY <> CPYSVE : [M:BAL1]CUR="" : Affzo [M:BAL1]CUR : Endif
## Si on a saisi un regroupement de sites, on contrôle qu'on ait accès à tous les sites du regroupement
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 Call CONTALLFCY(VALEUR) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=1 : # # Référentiels flagués 'Général'
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PERSTR<=VALEUR
 Read [PER]PER0 Last
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PERSTR
 Endif
Else
Endif
End

Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PEREND>=VALEUR
 Read [PER]PER0 First
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PEREND
 Endif
Else
Endif
End

Subprog C_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAC]GAC1 = [M:BAL1]COA;VALEUR
 If [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # Vous n'avez pas les droits pour ce code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_CPDEB(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Integer I
Local Char    LISTE(50)
LISTE = "ABCDEFGHIJKLMNOPQRSTUVWXYZ*?0123456789."
For I=1 To len(VALEUR)
 If !instr(1,LISTE,mid$(VALEUR,I,1))
  mkstat = 1 : Break
 Endif
Next I
Read [GAC]GAC0 = [M:BAL1]COA;VALEUR
If !fstat & [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # Vous n'avez pas les droits pour ce code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
Endif
End

Subprog IB_CPDEB
Raz GBOUT1, GBOUT2
If [M]SAC=""
 GBOUT1 = mess(8,31,1)   # Sélection
Else
 GBOUT2 = mess(8,31,1)   # Sélection
Endif
End


Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If nolign-1>=[M]NBLIG | [M:BAL2]COMPTE(nolign-1)="" : End : Endif
If !GTUNCPT(1)
 If [M:BAL1]SAC<>""
  GBOUT1 = mess(25,109,1)  # Compte
 Else
  Call LECTURE("GAC",[M:BAL2]COMPTE(nolign-1),[M:BAL1]COA) From CONTOBJ
  If [F:GAC]SAC<>2
   GBOUT1 = mess(25,109,1)  # Compte
  Else
   GBOUT2 = mess(25,109,1)  # Compte
  Endif
 Endif
Endif
End

Subprog B2_NBLIG
Call LECTURE("GAC",[M]COMPTE(nolign-1),[M:BAL1]COA) From CONTOBJ
If [F:GAC]SAC=2
 mkstat = 4
Endif
End

