#<AdxTL>@(#)1.0.0.0 $Revision$
#############################################################################
# 27/06/12 PAYMENT DAYS IN CUSTOMER FUNCTION SAM #82280                     #
# 08/05/13 LAW OF BAD DEBT SAM #88427                                       #
#############################################################################
# $CALDAYS                                                                  #
#       If we are in the GESBIC, GESSIH, FUNAUTINVO, FUNAUTINVD, FUNAUTINVC #
#       or FUNAUTINVT function and the fields DAYMON()                      #
#       in BPCUSTOMER table aren't equal to zero then the [F:TPT]DAYMON()   #
#       values are replaced by [F:BPC]DAYMON() values.                      #                                                                      #
# $UNAVAILABLE                                                              #
#       If we are in the GESBIC, GESSIH, FUNAUTINVO, FUNAUTINVD, FUNAUTINVC #
#       or FUNAUTINVT functions and the customer has                        #
#       an unavailable code ([F:BPC]UVYCOD<>"") we test if the calculated   #
#       due date is in an unavailable day or period. If this occurs then    #
#       the due date is recalculated until the next authorized day          #
# $DATCLC                                                                   #
#       If we are in the GESBIC, GESSIH, FUNAUTINVO, FUNAUTINVD, FUNAUTINVC #
#       or FUNAUTINVT function, we make a legal control in DAT variable     #
#############################################################################
$CALDAYS
#MGG  X3-43664 Max payment day in Schedule invoice generation
If GFONCTION="GESBIC" or GFONCTION="GESSIH" or GFONCTION="FUNAUTINVO" or GFONCTION="FUNAUTINVD"
&   or GFONCTION="FUNAUTINVC" or GFONCTION="FUNAUTINVT" or GFONCTION="FUNAUTINVSCH" or  GFONCTION="FUNAUTINVS"
  If [F:BPC]DAYMON(0)<>0
     [F:TPT]DAYMON(0)=[F:BPC]DAYMON(0)
     [F:TPT]DAYMON(1)=[F:BPC]DAYMON(1)
     [F:TPT]DAYMON(2)=[F:BPC]DAYMON(2)
     [F:TPT]DAYMON(3)=[F:BPC]DAYMON(3)
     [F:TPT]DAYMON(4)=[F:BPC]DAYMON(4)
     [F:TPT]DAYMON(5)=[F:BPC]DAYMON(5)
  Endif
Endif
#END MGG  X3-43664 Max payment day in Schedule invoice generation
Return

$UNAVAILABLE
#MGG  X3-43664 Max payment day in Schedule invoice generation
# 08/05/13 Law of bad debt SAM #88427
If GFONCTION="GESBIC" or GFONCTION="GESSIH" or GFONCTION="FUNAUTINVO" or GFONCTION="FUNAUTINVD"
&   or GFONCTION="FUNAUTINVC" or GFONCTION="FUNAUTINVT" or GFONCTION="FUNAUTINVSCH" or  GFONCTION="FUNAUTINVS"

If func AFNC.ACTIV("MAXPD")
  Local Char NDAYS (5)
  Local Integer OKK
    If [F:BPR]BPPFLG=2
      Call PARAM(SITE,"DMAXPAYP",NDAYS) From ADOVAL
      If val(NDAYS)=0: OKK=1: Endif
    Else
      Call PARAM(SITE,"DMAXPAY",NDAYS) From ADOVAL
      If val(NDAYS)=0: OKK=1: Endif
    Endif
  If OKK=0: Return: Endif
Endif  # No use unavailable periods if MAXPD active

Local Date DAT1
  If [F:BPC]UVYCOD2<>""
$INI_CAL
     DATMOD = 0
     DAT1=DAT
     Read [TUV]UVY0 = [F:BPC]UVYCOD2
     If !fstat and [F:TUV]UVYPER=2  ## The unavailable periods are periodic (for all the years)
       For I=0 To [F:TUV]UVYNBR-1
         If year([F:TUV]UVYSTRDAT(I))=year([F:TUV]UVYENDDAT(I))
           If DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(DAT)) &
&            DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT))
              DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT))+1
              DATMOD = 1
              Break
           Endif
         Else
          If month(DAT) > month([F:TUV]UVYENDDAT(I))
           If DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(DAT)) &
&           DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT)+1)
             DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT)+1)+1
             DATMOD = 1
             Break
           Endif
          Else
           If DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(DAT)-1) &
&           DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT))
             DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(DAT))+1
             DATMOD = 1
             Break
           Endif
         Endif
        Endif
       Next I
     Else
       For I=0 To [F:TUV]UVYNBR-1
         If DAT >= [F:TUV]UVYSTRDAT(I) & DAT <= [F:TUV]UVYENDDAT(I)
           DAT= [F:TUV]UVYENDDAT(I)+1
            DATMOD = 1
            Break
         Endif
       Next I
     Endif
     If DATMOD=1  ## We look for the following authorized day
        QUANT=day(DAT)
        MOIS = month(DAT)
        DYEAR = year(DAT)
        If ((int(DYEAR/4)=DYEAR/4) and (int(DYEAR/100)<>DYEAR/100))
&       or (int(DYEAR/400)=DYEAR/400) Then
           WNBDAYFEB = 29
        Else
           WNBDAYFEB = 28
        Endif
        DAT1=DAT
        If [F:TPT]DAYMON(0)<>0
          If MOIS <> 2
            If QUANT<=[F:TPT]DAYMON(0)  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME From SUBTPT
            Elsif QUANT<=[F:TPT]DAYMON(1) QT=[F:TPT]DAYMON(1) : Gosub QUANTIEME From SUBTPT
            Elsif QUANT<=[F:TPT]DAYMON(2) QT=[F:TPT]DAYMON(2) : Gosub QUANTIEME From SUBTPT
            Elsif QUANT<=[F:TPT]DAYMON(3) QT=[F:TPT]DAYMON(3) : Gosub QUANTIEME From SUBTPT
            Elsif QUANT<=[F:TPT]DAYMON(4) QT=[F:TPT]DAYMON(4) : Gosub QUANTIEME From SUBTPT
            Elsif QUANT<=[F:TPT]DAYMON(5) QT=[F:TPT]DAYMON(5) : Gosub QUANTIEME From SUBTPT
            Else  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME From SUBTPT
            Endif
          Else
            If (QUANT<=[F:TPT]DAYMON(0) & [F:TPT]DAYMON(0)<=WNBDAYFEB)|([F:TPT]DAYMON(0)=99)
               QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME From SUBTPT
            Elsif (QUANT<=[F:TPT]DAYMON(1)& [F:TPT]DAYMON(1)<=WNBDAYFEB)|([F:TPT]DAYMON(1)=99)
               QT=[F:TPT]DAYMON(1) : Gosub QUANTIEME From SUBTPT
            Elsif (QUANT<=[F:TPT]DAYMON(2) & [F:TPT]DAYMON(2)<=WNBDAYFEB)|([F:TPT]DAYMON(2)=99)
               QT=[F:TPT]DAYMON(2) : Gosub QUANTIEME From SUBTPT
            Elsif (QUANT<=[F:TPT]DAYMON(3) & [F:TPT]DAYMON(3)<=WNBDAYFEB)|([F:TPT]DAYMON(3)=99)
               QT=[F:TPT]DAYMON(3) : Gosub QUANTIEME From SUBTPT
            Elsif (QUANT<=[F:TPT]DAYMON(4) & [F:TPT]DAYMON(4)<=WNBDAYFEB)|([F:TPT]DAYMON(4)=99)
               QT=[F:TPT]DAYMON(4) : Gosub QUANTIEME From SUBTPT
            Elsif (QUANT<=[F:TPT]DAYMON(5) & [F:TPT]DAYMON(5)<=WNBDAYFEB)|([F:TPT]DAYMON(5)=99)
               QT=[F:TPT]DAYMON(5) : Gosub QUANTIEME From SUBTPT
            Else  QT=[F:TPT]DAYMON(0) : Gosub QUANTIEME From SUBTPT
            Endif
          Endif
        Endif
     Endif
     If DAT1<>DAT: Goto INI_CAL: Endif ## We test again if the calculated date is in a forbidden period
  Endif
Endif
#END MGG  X3-43664 Max payment day in Schedule invoice generation
Return

# 08/05/13 Law of bad debt SAM #88427
$MAXDAYPAY
  If !func AFNC.ACTIV("MAXPD"): Return: Endif
  Local Char NDAYS (5)
  Local Shortint DMAXPAY, BPCOK, NOK
#MGG  X3-43664 Max payment day in Schedule invoice generation
  Case GFONCTION
    When "GESSIH","GESBIC","FUNAUTINVO","FUNAUTINVD","FUNAUTINVC","FUNAUTINVT","FUNAUTINVSCH","FUNAUTINVS": BPCOK=1
    When "GESPIH","GESBIS","MODECHE2","MODECHE": BPCOK=0
    When Default: Return
  Endcase
#END MGG  X3-43664 Max payment day in Schedule invoice generation
  DMAXPAY=0                   ### SAM 105470
  If func AFNC.ACTIV("MUL")   ### SAM 105470
    If !clalev([F:BPE]): Local File BPEXCEPT [BPE]: Endif

    Read[BPE]BPE0=[F:BPR]BPRNUM;[F:FCY]LEGCPY
    If !fstat and [F:BPE]PAYDAY<>0
      DMAXPAY=[F:BPE]PAYDAY
    Endif
  Endif

  If DMAXPAY=0                ### SAM 105470
    If [F:BPR]BPPFLG=2
      Call PARAM(SITE,"DMAXPAYP",NDAYS) From ADOVAL
      DMAXPAY = val(NDAYS)
    Else
      Call PARAM(SITE,"DMAXPAY",NDAYS) From ADOVAL
      DMAXPAY = val(NDAYS)
    Endif
  Endif

  If DMAXPAY=0 : Return: Endif
  If DMAXPAY<>0
    Local Date INIDATE
    Raz INIDATE, NOK
    If BPCOK=1
      Case GFONCTION
        When "GESBIC": INIDATE=[M:BIC1]STRDUDDAT
        When Default : INIDATE=[M:SIH2]STRDUDDAT
      Endcase
    Endif
    If BPCOK=0
      Case GFONCTION
        When "GESPIH": INIDATE=[M:PIH1]STRDUDDAT
        When "GESBIS": INIDATE=[M:BIS1]STRDUDDAT: If [M:BIS3]NBLIG=0: NOK=1: Endif
        When Default : INIDATE= DATINI
      Endcase
    Endif
    If (DAT-INIDATE)>DMAXPAY
      Local Integer WOK: WOK=1

      If maskcou="BPCDUD" or maskcou="BPSDUD"
        BPCOK=0
      Endif

      MESSAGE=mess(180,187,1)-"("+num$(INIDATE+DMAXPAY)+")"

      If BPCOK=1
        DAT=INIDATE+DMAXPAY
        Gosub DAYMONTH
        #MGG SAL_X3-46612_MAX_PAYMENT_DAY_WITH_A_DAY_OF_PAYMENT_IN_THE_PAIMENT_TERM
        If DAT<INIDATE: DAT=INIDATE+DMAXPAY Endif #DAT=INIDATE: Endif
        #END MGG SAL_X3-46612_MAX_PAYMENT_DAY_WITH_A_DAY_OF_PAYMENT_IN_THE_PAIMENT_TERM
      Elsif BPCOK=0 and NOK=0
        Call AVERTIR (MESSAGE, WOK)From GESECRAN
        If (maskcou="BPSDUD" or GFONCTION="MODECHE" or GFONCTION="MODECHE2") and  WOK=1
          mkstat=2: End
        Endif
      Endif
    Endif
  Endif

Return

$DAYMONTH
  Local Integer INIDAY, PAYDAY(6)
  INIDAY=day(DAT)
  Raz PAYDAY
  If [F:BPC]DAYMON(0)<>0
    For I=0 To 5
      PAYDAY(I)=[F:BPC]DAYMON(I)
    Next
  Elsif [F:TPT]DAYMON(0)<>0
    For I=0 To 5
      PAYDAY(I)=[F:TPT]DAYMON(I)
    Next
  Endif

  If PAYDAY(0)=0 or INIDAY=PAYDAY(0): Return: Endif

  If INIDAY<PAYDAY(0)
    DAT=DAT-INIDAY
    For I=5 To 0 Step-1
      If PAYDAY(I)<>0 and PAYDAY(I)<>99
        DAT=gdat$(PAYDAY(I),month(DAT),year(DAT)): Break
      Elsif PAYDAY(I)=99
        Break
      Endif
    Next
  Else
    For I=5 To 1 Step-1
      If PAYDAY(I)=0 and INIDAY>PAYDAY(I-1) and PAYDAY(I-1)<>0
        DAT=gdat$(PAYDAY(I-1),month(DAT),year(DAT)): Break
      Endif
      If PAYDAY(I)<>0
        If INIDAY=PAYDAY(I)
           Break
        Endif
        If INIDAY<PAYDAY(I) and INIDAY>PAYDAY(I-1)
          DAT=gdat$(PAYDAY(I-1),month(DAT),year(DAT)): Break
        Endif
      Endif
    Next
  Endif

Return

# 08/05/13 Law of bad debt SAM #88427
########################################
Subprog CONTDUD(VALEUR)
  Variable Date VALEUR
  Local Date DAT, DATINI
  Local Shortint WOKK

  If !func AFNC.ACTIV("MAXPD"): Return: Endif

  WOKK=1
  SITE=[F:DUD]FCY

  If GFONCTION="MODECHE2"
    DATINI=[M:SAI1]BPRDATVCR(indice)
  Endif

  If GFONCTION="MODECHE"
    WOKK=0
    Read [DUD]DUD1=[M:SAI1]ACCNUM(indice);[M:SAI1]DUDLIG(indice)
    SITE=[F:DUD]FCY

    If [F:DUD]BPRTYP=1
      If !clalev ([F:SIH]): Local File SINVOICE: Endif
      Read [SIH]SIH0=[F:DUD]NUM
      If !fstat and [F:SIH]INVTYP<5
        DATINI=[F:SIH]STRDUDDAT: WOKK=1
      Endif
      Close File [SIH]
    Elsif [F:DUD]BPRTYP=2
      If !clalev ([F:PIH]): Local File PINVOICE: Endif
      Read [PIH]PIH0=[F:DUD]NUM
      If !fstat and [F:PIH]INVTYP<5
        DATINI=[F:PIH]STRDUDDAT: WOKK=1
      Endif
      Close File [PIH]
    Endif
  Endif

  If WOKK=1
    DAT= VALEUR
    Gosub MAXDAYPAY
  Endif

End

