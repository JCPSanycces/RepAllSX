#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
Local Char GLOBEML(GLONEML)
If clalev([F:RIB1])    = 0 : Local File EMPLORIB     [RIB1]     : Endif

GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#Manage Localisations
Call MANAGE_LOCALISATION("ESSRIB") From DIVPAYE

Default File [F:RIB1]
Return

$DEBUT
Local Char EMPCODE (GLONEML)
EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

Filter [F:RIB1] Where REFNUM = EMPCODE
nolign =0
For [F:RIB1]
  nolign+=1
  [M:ESRIB] = [F:RIB1]
  [M:ESRIB]NBRRIB = nolign
Next
Filter [F:RIB1]


#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSRIBHIDE
Call SHOW_LEGACTCALLS From WESSRIBSHOW

#Manage Add-hoc localistions
Gosub MANAGE_LOCALISATION_ADDHOC

Affzo [M:ESRIB]1-99

Return


$MANAGE_LOCALISATION_ADDHOC
If GCURLEG = "BRI"
  If dim([M:ESRIB]BNF)>0       : Chgfmt [M:ESRIB]BNF       With "-K:40X"  : Raz[M:ESRIB]BNF   : Endif
  If dim([M:ESRIB]CUR)>0       : Chgfmt [M:ESRIB]CUR       With "-K:3X"   : Raz[M:ESRIB]CUR   : Endif
Endif

Return



