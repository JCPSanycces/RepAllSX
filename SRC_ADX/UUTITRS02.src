#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################################################
# UUTITRS02   Utilitaire de mise à jour de la table TMPFUP0 avec conservation des données           Module Tiers #
#             Traitement exécuté après la maintenance qui livre la nouvelle structure de la table TMPFUP0        #
#             Ce traitement copie les données de TMPFUP01 dans la table TMPFUP0                                  #
##################################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UUTITRS02:"-"TMPFUP0 table structure updates") From LECFIC

 Call MAJ_UTITRS02(APPLI) 
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

# copie des données de TMPFUP01 dans la table TMPFUP0
Subprog MAJ_UTITRS02(APPLI)
Value Char APPLI


# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

# test de présence des tables
If filinfo(filpath("FIL","TMPFUP0","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TMPFUP01","fde",APPLI),0)<=0 : End : Endif

# table origine
Local File =APPLI+".TMPFUP01" [ZTF]

# table destination
Local File =APPLI+".TMPFUP0" [TFP]

# si la table TMPFUP01 est vide, pas la peine d'exécuter le traitement
If nbrecord([ZTF])=0 : End : Endif

Call ECR_TRACE("UUTITRS02: Process Start on : "+APPLI,0) From GESECRAN
Trbegin [ZTF]
# transfert des données
For [ZTF]
 [F:TFP] = [F:ZTF]
 Write [TFP]
Next
Commit # TFP

Call ECR_TRACE("UUTITRS02: Process End on : "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read[ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS02(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation APPLI)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS02(APPLI)
End
