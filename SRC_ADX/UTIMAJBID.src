#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour champ ACCNONREI dan la table BID
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ACCNONREI field in BID file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESBID
End

#-------------------#
$DESBID

Local File =DOSSIER+".BID"   [BID] 

If dim([F:BID]ACCNONREI)<0
 Close Local File [BID]
 Return 
Endif

# Mise à jour de la table BID
Call ECR_TRACE(mess(81,125,1)-"BID:"-time$,0) From GESECRAN
Trbegin [BID]
 For [BID]BID0
  If [F:BID]ACCNONREI=0
   [F:BID]ACCNONREI = 1
   Rewrite [BID]
   If fstat
    Call ERREUR("BID"-[F:BID]BPANUM,2) From DOSDIC
   Endif 
  Endif
 Next
Commit

Close Local File [BID]

Return
