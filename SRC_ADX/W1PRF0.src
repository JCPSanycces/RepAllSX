#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:04"
A_USER  = "DOC"
A_STAMP = "20181109230604"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PRF0 [PRF0]
Gosub HORODAT
Local Inpbox "PRF0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PRF0] As [SIM_]
Grizo [PRF0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PRF0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=77 : Y1(0)=1 : Y2(0)=3
Return

$ON_PRFCOD
Onevent CONTROL Call C_PRFCOD(zc) From W1PRF0
Onevent BEFORE_INPUT Call AS_PRFCOD(zc) From W1PRF0
Return

Subprog AS_PRFCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(8750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PRFCOD(zc) From W1PRF0
Onkey   2 Titled GBOUTS Call S_PRFCOD(zc) From W1PRF0
Onkey 144 Titled GBOUTP Call P_PRFCOD(zc) From W1PRF0
Onkey 146 Titled GBOUTA Call SA_PRFCOD(zc) From W1PRF0
Gosub _AFF
End

Subprog C_PRFCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PRFCOD" : GZNUM = 8750 : Endif
If !mkstat
 ## Action CONTPRF
 Call CONTPRF(VALEUR) From SUBPRF
 If mkstat : GERR = 1 : GZONE = "PRFCOD" : GZNUM = 8750 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRFCOD" : GZNUM = 8750 : Endif
  If !mkstat
   ## Action CONTOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARMSK(1) = "PRF"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PRFCOD" : GZNUM = 8750 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_PRFCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJ1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJ1"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_PRFCOD" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PRF"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 ACTION = "BS_PRFCOD" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PRFCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPRF
 Call TUNPRF(VALEUR) From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_PRFCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PRF"
PARMSK(2) = num$(GCURLEG)
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PRFCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("PRF",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1PRF0
Onevent CONTROL Call C_LEG(zc) From W1PRF0
Onevent AFTER_CHANGE Gosub AMM_LEG From W1PRF0
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1PRF0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1PRF0
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1PRF0
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1PRF0
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1PRF0
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBPRF
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1PRF0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_PRFDES
Onevent INIT_AREA Call D_PRFDES(zc) From W1PRF0
Onevent BEFORE_INPUT Call AS_PRFDES(zc) From W1PRF0
Return

Subprog IB_PRFDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_PRFDES(VALEUR)
Variable Char    VALEUR()
If varinit([M]PRFDES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PROFIL","PRFDES",GCURLEG,[M]PRFCOD) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_PRFDES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_PRFDES(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PRFDES(zc) From W1PRF0
Gosub _AFF
End

Subprog B1_PRFDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_PRFDES" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PROFIL"
 PARMSK(2) = "PRFDES"
 PARMSK(3) = GCURLEG
 PARMSK(4) = [M]PRFCOD
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_PRFDES" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PRFSHO
Onevent INIT_AREA Call D_PRFSHO(zc) From W1PRF0
Onevent BEFORE_INPUT Call AS_PRFSHO(zc) From W1PRF0
Return

Subprog IB_PRFSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_PRFSHO(VALEUR)
Variable Char    VALEUR()
If varinit([M]PRFSHO,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PROFIL","PRFSHO",GCURLEG,[M]PRFCOD) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_PRFSHO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_PRFSHO(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PRFSHO(zc) From W1PRF0
Gosub _AFF
End

Subprog B1_PRFSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_PRFSHO" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PROFIL"
 PARMSK(2) = "PRFSHO"
 PARMSK(3) = GCURLEG
 PARMSK(4) = [M]PRFCOD
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_PRFSHO" : PROGSUB = "SUBPRF" : PROGSPE = "SPEPRF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ENAFLG
Onevent AFTER_CHANGE Gosub AMM_ENAFLG From W1PRF0
Onevent INIT_AREA Call D_ENAFLG(zc) From W1PRF0
Onevent BEFORE_INPUT Call AS_ENAFLG(zc) From W1PRF0
Return

Subprog D_ENAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_ENAFLG
Call AM_ENAFLG(zc)
If !mkstat & GOBJET
 zoncou = "ENAFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_ENAFLG(VALEUR) From SUBPRF
If mkstat : GERR = 1 : GZONE = "ENAFLG" : GZNUM = 188 : Endif
Gosub _AFF
End

$ON_FLGSUP
Onevent INIT_AREA Call D_FLGSUP(zc) From W1PRF0
Onevent BEFORE_INPUT Call AS_FLGSUP(zc) From W1PRF0
Return

Subprog D_FLGSUP(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGSUP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGSUP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


