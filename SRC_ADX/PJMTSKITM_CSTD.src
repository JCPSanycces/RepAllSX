#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKITM
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PJMTSKITM_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PJMTSKITM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PJMTSKITM_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PJMTSKITM_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PJMTSKITM_CSTD_METHODS
    When "WIP"                         : Gosub WIP                             From PJMTSKITM_CSTD_METHODS
    When "COPY"                        : Gosub COPY                            From PJMTSKITM_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"        : Gosub COPY_LOAD_PROPERTIES            From PJMTSKITM_CSTD_METHODS
    When "SUM_SOQ_QTYSTU"              : Gosub SUM_SOQ_QTYSTU                  From PJMTSKITM_CSTD_METHODS
    When "SET_COSTMETS"                : Gosub SET_COSTMETS                    From PJMTSKITM_CSTD_METHODS
    When "FRCDLTALLFLG_UPDATABLE"      : Gosub FRCDLTALLFLG_UPDATABLE          From PJMTSKITM_CSTD_METHODS   # Issue X3-105748 - 2018-08-30 by FGR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "KEYCONCAT"                   : Gosub KEYCONCAT                       From PJMTSKITM_CSTD_PROPERTIES
    When "ITTQTY"                      : Gosub ITTQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "ITMREF"                      : Gosub ITMREF                          From PJMTSKITM_CSTD_PROPERTIES
    When "STOFCY"                      : Gosub STOFCY                          From PJMTSKITM_CSTD_PROPERTIES  # Issue X3-65941 - 2018-01-12 by FGR
    When "ECCVALMAJ"                   : Gosub ECCVALMAJ                       From PJMTSKITM_CSTD_PROPERTIES
    When "SALITM"                      : Gosub SALITM                          From PJMTSKITM_CSTD_PROPERTIES
    When "SOQQTY"                      : Gosub SOQQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "REQDAT"                      : Gosub REQDAT                          From PJMTSKITM_CSTD_PROPERTIES
    When "TCHPURFLG"                   : Gosub TCHPURFLG                       From PJMTSKITM_CSTD_PROPERTIES
    #
    When "CSMTYP"                      : Gosub CSMTYP                          From PJMTSKITM_CSTD_PROPERTIES
    When "ALLQTY"                      : Gosub ALLQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "WALLQTY"                     : Gosub WALLQTY                         From PJMTSKITM_CSTD_PROPERTIES
    When "SHTQTY "                     : Gosub SHTQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "ALLSTA"                      : Gosub ALLSTA                          From PJMTSKITM_CSTD_PROPERTIES
    When "ALLTYP"                      : Gosub ALLTYP                          From PJMTSKITM_CSTD_PROPERTIES
    When "TDLQTY"                      : Gosub TDLQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "ODLQTY"                      : Gosub ODLQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "DLVQTY"                      : Gosub DLVQTY                          From PJMTSKITM_CSTD_PROPERTIES
    When "DLVSTA"                      : Gosub DLVSTA                          From PJMTSKITM_CSTD_PROPERTIES
    When "ITMDLVFLG"                   : Gosub ITMDLVFLG                       From PJMTSKITM_CSTD_PROPERTIES
  Endcase
Return

