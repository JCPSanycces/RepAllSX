#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Agenda crm module commercial                           Module CRM         octobre 2006
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT"         : Gosub INIT
    When "AVANT_PAR"    : Gosub AVANT_PAR
    When "SEL_LISTE"    : Gosub SEL_LISTE
    When "VERF_LISTE"   : Gosub VERF_LISTE
    When "CONTROLE"     : Gosub CONTROLE
    When "TITRE"        : Gosub TITR
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub MENU
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When Default
  Endcase
Return

##########################################################################################################
$INIT
Global Char GCRMAGDCTRNUM(GLONTRS)
Local Integer INBCTR
Local Char SZCRMTRSNUM(GLONTRS)

  If !clalev ([F:CTR]) : Local File CRMTRS [CTR] : Endif
  GCRMAGDCTRNUM = ""
  INBCTR = 0
  SZCRMTRSNUM = ""
  Filter [CTR] Where [F:CTR]CTRTYP = 1 and ENAFLG = 2
  For [CTR]
    SZCRMTRSNUM = [F:CTR]CTRNUM
    INBCTR += 1
  Next
  Filter [CTR]
  If INBCTR = 0 Then
    #On créé une transaction par défaut
    #    Call CREHDKAGDHTR From SUBCMDB
    #    Call OUVRE_TRACE(mess(100,196,1)-" : HDK - DEF") From LECFIC
    #    Call VAL_CRMTRS(5,"DEF",nomap) From FUNCRMTRS
    #    Call FERME_TRACE From LECFIC
    #    GHDKCTRNUM = "DEF"
  Endif
  If INBCTR = 1 Then
    #On utilise la seule transaction qui soit définie
    GCRMAGDCTRNUM = SZCRMTRSNUM
  Endif
Return

##########################################################################################################
$AVANT_PAR
  If GCRMAGDCTRNUM = "" Then
    If GFLAG <> "" Then
      Read [CTR]CTR0=1;GFLAG
      If !fstat Then
        GCRMAGDCTRNUM = GFLAG
        Call LOAD_SITE_GRP([F:CTR]GFY) From CRMUTIL150
        TYPPRG = 0
      Endif
    Endif
  Else
    Read [CTR]CTR0=1;GCRMAGDCTRNUM
    If !fstat Then
      TYPPRG = 0
      Call LOAD_SITE_GRP([F:CTR]GFY) From CRMUTIL150
    Endif
  Endif
Return

##########################################################################################################
# Avant ouverture de la fenêtre de sélection des transactions #
#-------------------------------------------------------------#
$SEL_LISTE
Local Integer NBACS
Local Integer I
Local Char TABACS(10)(100)
Local Char CRITERE(250)

  If !clalev([F:CTR]) : Local File CRMTRS [CTR] : Endif
  If !clalev([F:ACC]) : Local File ACCES  [ACC] : Endif
  #
  CRITERE = "CTRTYP = 1"
  Raz TABACS
  If GPROFIL <> GSUPER Then
    For [ACC]CODACC Where USR = GUSER
      If [F:ACC]EXEC = 2 Then
        [L]TABACS(NBACS) = vireblc([F:ACC]CODACC,1)
        NBACS += 1
      Endif
      If NBACS > 99 Then
        Break
      Endif
    Next
    CRITERE -= " And (ACSCOD='' or find(ACSCOD,TABACS(0..99)))"
  Endif
  #
  If GFLAG = "" Then
    Filter [CTR] Where evalue(CRITERE) and ENAFLG = 2
    If rowcount([CTR]) = 1 Then
      Read [CTR]First
      If !fstat Then
        GFLAG = [F:CTR]CTRNUM
      Endif
    Endif
    Filter [CTR]
  Endif
  #
  If GFLAG <> "" Then
    Filter [CTR] Where evalue(CRITERE) and ENAFLG = 2
    Read [CTR]CTR0=1;GFLAG
    If !fstat Then
      OK = 0
      GCRMAGDCTRNUM = GFLAG
    Endif
    Filter [CTR]
  Endif
  #
  If GFLAG = "" Then
    I = 1
    Raz TEX, TEXTE
    Filter [CTR] Where evalue(CRITERE) and ENAFLG = 2
    Read [CTR]First
    While !fstat
      TEX(I)   = [F:CTR]CTRNUM
      TEXTE(I) = [F:CTR]CTRNUM + space$(6-len([F:CTR]CTRNUM))
      Call LECTEXTRA(TIT, "CRMTRS", "DESAXX", num$([F:CTR]CTRTYP), [F:CTR]CTRNUM) From ATEXTRA
      TEXTE(I) += TIT + space$(GLONAX3-len(TIT)) + [F:CTR]ACSCOD
      I += 1
      If I >= dim(TEX) Then
        Break
      Endif
      Read [CTR]Next
    Wend
    Filter [CTR]
    NBTEX = I - 1
    TIT = mess(3,126,1)
  Endif
Return

$OLDSEL_LISTE
  If !clalev([F:CTR]) : Local File CRMTRS [CTR] : Endif
  I = 1
  Raz TEX, TEXTE
  For [CTR]CTR0 Where CTRTYP = 1 and ENAFLG = 2
    TEX(I)   = [F:CTR]CTRNUM
    TEXTE(I) = [F:CTR]CTRNUM + space$(6-len([F:CTR]CTRNUM))
    Call LECTEXTRA(TIT,"CRMTRS","DESAXX",num$(CTRTYP), CTRNUM) From ATEXTRA
    TEXTE(I) += TIT
    I += 1
    If I >= dim(TEX) Then
      Break
    Endif
  Next
  NBTEX = I - 1
  TIT = mess(3,126,1)
Return

##########################################################################################################
# La transaction de saisie a été choisie #
#----------------------------------------#
$VERF_LISTE
  GCRMAGDCTRNUM = VALEUR
Return

##########################################################################################################
$CONTROLE
  If GCRMAGDCTRNUM <> "" Then
    BOITE = "WOCRA" + GCRMAGDCTRNUM
    Read [CTR]CTR0=1;GCRMAGDCTRNUM
    If !fstat Then
      Call LOAD_SITE_GRP([F:CTR]GFY) From CRMUTIL150
    Endif
  Else
    FIN = 1
  Endif
Return

##########################################################################################################
$TITR
Local Integer IONGLET
Local Integer IBRETOUR
Local Char SZMESSAGE(250)

  IONGLET = 0
  Call GET_ONGLET_DEF_CRM(1, GCRMAGDCTRNUM, "FCRMAGD", IONGLET, SZMESSAGE, IBRETOUR) From CRMTRSUTI
  If IONGLET <> 0 Then
    AFOLDEF = IONGLET
  Endif
Return

##########################################################################################################
$OUVRE
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:OPPCRM]) : Local File OPPORCRM [OPPCRM] : Endif      # Issue X3-60926 - 2018-03-28 by FGR
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If GMODU(12) = 2 Then
    #Renouvellement des garanties à tacite reconduction
    Call REWWARRANTY From SUBCONB2
  Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCRMAGD"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
#Initialisation
Local Char SZREPCONNECT(GLONREP)
Local Char SZMESSAGE(250)
Local Integer IMONTH
Local Integer IYEAR
Local Integer IBRETOUR

  Raz SZREPCONNECT
  Raz SZMESSAGE
  IBRETOUR = 1
  Call GETREPFROMUTI (GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT <> "" Then
    [M:CRM0]REP = SZREPCONNECT
  Endif
  IMONTH = month(date$)
  IYEAR = year(date$)
  If IMONTH < 0 Then
    IYEAR = IYEAR - 1
    IMONTH = IMONTH + 12
  Endif
  [M:CRM0]DATMIN = gdat$(1, IMONTH, IYEAR)
  IMONTH = month(date$)
  IYEAR = year(date$)
  IMONTH = IMONTH + 1
  If IMONTH > 12 Then
    IMONTH = IMONTH - 12
    IYEAR = IYEAR + 1
  Endif
  [M:CRM0]DATMAX = eomonth(gdat$(1, IMONTH, IYEAR))
  Affzo [M:CRM0]1-99
  [M:CRM1]NBLIGAGD = 1
  Affzo [M:CRM1]NBLIGAGD
  [M:CRM2]SEACLLCMG = 1
  Affzo [M:CRM2]SEACLLCMG
  If GMODU(12) <> 2 Then
    [M:CRM6]INFCON = 1
    Affzo [M:CRM6]INFCON
    Diszo [M:CRM6]INFCON
  Endif
  Call AFFECT_VAL_TRS_CRM (1, GCRMAGDCTRNUM, SZMESSAGE, IBRETOUR) From CRMTRSUTI
  Affzo [M:CRM1]
  Affzo [M:CRM2]
  Affzo [M:CRM3]
  Affzo [M:CRM4]
  Affzo [M:CRM6]
  Affzo [M:CRM7]
  Affzo [M:CRM8]
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$AVANT_MEN
  [M:CRM0]NVGCOD = BOUT
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "("
      #Planifier Appel
      GBCRMFLGNEW = 1
    When "£"
      #Planifier Tache
      GBCRMFLGNEW = 1
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer Tache
      GBCRMFLGNEW = 1
    When "!"
      #Enregistrer Affaire
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$FINSAI
  Raz [M:CRM0]
  Raz [M:CRM1]
  Raz [M:CRM2]
  Raz [M:CRM3]
  Raz [M:CRM4]
  Raz [M:CRM6]
Return

##########################################################################################################
$FIN
  If dim(GLST_SITE) > 0 Then
    Kill GLST_SITE
  Endif
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$MENU
Local Integer IBLOAD

  IBLOAD = 0
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      IBLOAD = 1
    When "("
      #Planifier Appel
      IBLOAD = 1
    When "£"
      #Planifier Tache
      IBLOAD = 1
    When "}"
      #Enregistrer Rendez-vous
      IBLOAD = 1
    When "{"
      #Enregistrer Appel
      IBLOAD = 1
    When "~"
      #Enregistrer Tache
      IBLOAD = 1
    When "!"
      #Enregistrer Affaire
      IBLOAD = 1
    When "%"
      #Enregistrer demande de service
      IBLOAD = 1
  Endcase
  If IBLOAD = 1 Then
    Gosub ONLOAD
  Endif
Return

##########################################################################################################
$VAR_PE_CRMAGD
Local Char SZCNTCRMAGD(GLONDES)
Local Integer IFILTDIM

  IFILTDIM = 20
  SZCNTCRMAGD = "FILTDIM"
  Gosub PE_CRMAGD From TRTCRMPE
Return

##########################################################################################################
Subprog GET_CHRONO_ITI(ILIGNE, SCHRONO)
Variable Integer ILIGNE
Variable Char SCHRONO

Local Integer NI
Local Integer NBEGIN
Local Integer NFOUND

  If [M:CRM7]NBLIGAPP = 0 Then
    ILIGNE = -1
    Raz SCHRONO
  Else
    NBEGIN = ILIGNE + 1
    If NBEGIN > [M:CRM7]NBLIGAPP-1 Then
      ILIGNE = -1
      Raz SCHRONO
    Else
      NFOUND = 0
      For NI = NBEGIN To [M:CRM7]NBLIGAPP-1
        If [M:CRM7]APTPLCX(NI) <> 2 Then
          ILIGNE = NI
          SCHRONO = [M:CRM7]APTNUM(ILIGNE)
          NFOUND = 1
          Break
        Endif
      Next NI
      If NFOUND = 0 Then
        ILIGNE = -1
        Raz SCHRONO
      Endif
    Endif
  Endif
End

##########################################################################################################
$ONLOAD
  Gosub LOAD_AGD
  Gosub LOAD_BAP
  Gosub LOAD_CLL
  Gosub LOAD_TSK
  Gosub LOAD_OPP
  Gosub LOAD_CAMPAGNE
  Gosub LOAD_INF
Return

##########################################################################################################
$LOAD_AGD
  Gosub VAR_PE_CRMAGD

Local Char CSTHEUREDEB(GLONDES)
Local Char CSTHEUREFIN(GLONDES)
Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(100)
Local Char SZLIBELLE(250)
Local Char SZCODE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Integer IBCONTINUE
Local Date DTDATEDEB
Local Date DTDATEFIN
Local Char SZHOURDEB
Local Char SZHOURFIN
Local Integer IBGENEREBAP
Local Integer INBDAY
Local Integer IBDATEFINOK

  CSTHEUREDEB = "0800"
  CSTHEUREFIN = "1800"
  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  Raz SZLIBELLE
  Raz SZCODE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  IBCONTINUE = 1
  Raz DTDATEDEB
  Raz DTDATEFIN
  Raz SZHOURDEB
  Raz SZHOURFIN
  IBGENEREBAP = 0
  INBDAY = 0
  IBDATEFINOK = 0
  Effzo [M:CRM1]20
  [M:CRM1]NBLIGAGD = 0
  Local Mask CRMAGD1 [CRMW]
  #
  [M:CRMW]AGDBAP = [M:CRM1]AGDBAP
  [M:CRMW]AGDTSK = [M:CRM1]AGDTSK
  [M:CRMW]AGDCLL = [M:CRM1]AGDCLL
  Effzo [M:CRMW]20
  [M:CRMW]NBLIGAGD = 0
  #-------------------------
  If [M:CRMW]AGDBAP = 2 Then
    #Sélection des rendez vous
    ILIGNEWHERE = 0
    Raz SZWHERE
    SZAND = ""
    If [M:CRM0]REP <> "" Then
      SZWHERE(ILIGNEWHERE) = SZAND - "find([M:CRM0]REP,[F:BAP]APTREPNUM)<>0 "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMIN <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:BAP]APTDATX<>[00/00/00] and [F:BAP]APTDATX>=[M:CRM0]DATMIN) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMAX <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:BAP]APTDATX<>[00/00/00] and [F:BAP]APTDATX<=[M:CRM0]DATMAX) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    #
    SZCNTCRMAGD = "AGDBAP"
    Gosub PE_CRMAGD From TRTCRMPE
    SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
    If SZROLE <> "1=1" Then
      SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "BAP") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
    If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
      Filter [BAP] Where evalue(SZWHERE) Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
    Else
      Filter [BAP] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
    Endif
    ILIGNE = [M:CRMW]NBLIGAGD
    For [BAP]Hint Key APP4
      If [F:BAP]APTNUM <> "" Then
        If ILIGNE >= dim([M:CRMW]KEYACT)-1 Then
          Break
        Endif
        #
        IBCONTINUE = 1
        IBGENEREBAP = 0
        IBDATEFINOK = 1
        If [F:BAP]APTDAT = [00/00/00] Then
          DTDATEDEB = [F:BAP]APTDATX
        Else
          DTDATEDEB = [F:BAP]APTDAT
        Endif
        SZHOURDEB = [F:BAP]APTHOU
        DTDATEFIN = [F:BAP]APTDATEND
        SZHOURFIN = [F:BAP]APTHOUEND
        If DTDATEFIN = [00/00/00] Then
          DTDATEFIN = DTDATEDEB
          IBDATEFINOK = 0
        Endif
        While IBCONTINUE = 1
          If ILIGNE >= dim([M:CRMW]KEYACT)-1 Then
            Break
          Endif
          If DTDATEDEB <> [F:BAP]APTDATEND and IBDATEFINOK = 1 Then
            DTDATEFIN=DTDATEDEB
            SZHOURFIN=CSTHEUREFIN
          Else
            DTDATEFIN = DTDATEDEB
            SZHOURFIN = [F:BAP]APTHOUEND
            IBCONTINUE = 0
          Endif
          [M:CRMW]KEYACT(ILIGNE)     = [F:BAP]APTNUM
          [M:CRMW]OBJ(ILIGNE)        = "BAP"
          [M:CRMW]SEMAINE(ILIGNE)    = num$(week(DTDATEDEB))
          [M:CRMW]DATDEB(ILIGNE)     = DTDATEDEB
          Call CONVDI(DTDATEDEB, SZVALEUR) From CRMUTIL150
          [M:CRMW]DATDEBINT(ILIGNE)  = SZVALEUR
          [M:CRMW]HEURDEB(ILIGNE)    = SZHOURDEB
          [M:CRMW]DATFIN(ILIGNE)     = DTDATEFIN
          Call CONVDI(DTDATEFIN, SZVALEUR) From CRMUTIL150
          [M:CRMW]DATFININT(ILIGNE)  = SZVALEUR
          [M:CRMW]HEURFIN(ILIGNE)    = SZHOURFIN
          [M:CRMW]TYPACT(ILIGNE)     = 3
          [M:CRMW]EXE(ILIGNE)        = [F:BAP]APTDON
          [M:CRMW]OBJET(ILIGNE)      = left$([F:BAP]APTOBJ, 250)
          [M:CRMW]CATEG(ILIGNE)      = [F:BAP]APTTYP
          If [M:CRMW]CATEG(ILIGNE) = "" Then
            [M:CRMW]LIBCATEG(ILIGNE) = ""
          Else
            Call GET_LIB(433, [M:CRMW]CATEG(ILIGNE), [M:CRMW]LIBCATEG(ILIGNE)) From CRM_UTIL
          Endif
          [M:CRMW]BPR(ILIGNE)        = [F:BAP]APTCMP
          If [M:CRMW]BPR(ILIGNE) <> "" Then
            SZCODE = [M:CRMW]BPR(ILIGNE)
            Read [BPR]BPR0=SZCODE
            If fstat = 0 Then
              SZLIBELLE = [F:BPR]BPRNAM
            Else
              SZLIBELLE = ""
            Endif
          Else
            SZCODE = ""
            SZLIBELLE = ""
          Endif
          Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBBPRAGD(ILIGNE)) From CRMUTIL150
          # Interlocuteur
          [M:CRMW]CCN(ILIGNE)        = [F:BAP]APTCCNNUM(0)
          If [M:CRMW]CCN(ILIGNE) = "" Then
            SZCODE = ""
            SZLIBELLE = ""
          Else
            SZCODE = [M:CRMW]CCN(ILIGNE)
            Read [AIN]AIN0=[M:CRMW]CCN(ILIGNE)
            If fstat Then
              SZLIBELLE = ""
            Else
              Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
            Endif
          Endif
          Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBCCNAGD(ILIGNE)) From CRMUTIL150
          ILIGNE += 1
          If IBCONTINUE = 1 Then
            INBDAY = nday(DTDATEDEB)
            INBDAY = INBDAY + 1
            DTDATEDEB = nday$(INBDAY)
            SZHOURDEB = CSTHEUREDEB
          Endif
        Wend
      Endif
    Next
    Filter [BAP]
    [M:CRMW]NBLIGAGD = ILIGNE
  Endif
  #-------------------------
  If [M:CRMW]AGDCLL = 2 Then
    #Sélection des appels
    ILIGNEWHERE = 0
    Raz SZWHERE
    SZAND = ""
    If [M:CRM0]REP <> "" Then
      SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLREP=[M:CRM0]REP "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMIN <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE)= SZAND - "([F:CLL]CLLDATX<>[00/00/00] and [F:CLL]CLLDATX>=[M:CRM0]DATMIN) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMAX <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:CLL]CLLDATX<>[00/00/00] and [F:CLL]CLLDATX<=[M:CRM0]DATMAX) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMIN = [00/00/00] and [M:CRM0]DATMAX = [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:CLL]CLLDATX<>[00/00/00]) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    #
    SZCNTCRMAGD = "AGDCLL"
    Gosub PE_CRMAGD From TRTCRMPE
    SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
    If SZROLE <> "1=1" Then
      SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CLL") From CRMUTIL150
    If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
      Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
    Else
      Filter [CLL] Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
    Endif
    ILIGNE = [M:CRMW]NBLIGAGD
    For [CLL] Hint Key CLL4
      If ILIGNE >= dim([M:CRMW]KEYACT)-1 Then
        Break
      Endif
      If [F:CLL]CLLNUM <> "" Then
        [M:CRMW]KEYACT(ILIGNE)       = [F:CLL]CLLNUM
        [M:CRMW]OBJ(ILIGNE)          = "CLL"
        If [F:CLL]CLLDAT <> [00/00/00] Then
          DTDATEDEB = [F:CLL]CLLDAT
        Else
          DTDATEDEB = [F:CLL]CLLDATX
        Endif
        [M:CRMW]SEMAINE(ILIGNE)      = num$(week(DTDATEDEB))
        [M:CRMW]DATDEB(ILIGNE)       = DTDATEDEB
        Call CONVDI(DTDATEDEB,SZVALEUR) From CRMUTIL150
        [M:CRMW]DATDEBINT(ILIGNE)    = SZVALEUR
        [M:CRMW]HEURDEB(ILIGNE)      = [F:CLL]CLLHOU
        [M:CRMW]DATFIN(ILIGNE)       = DTDATEDEB
        Call CONVDI(DTDATEDEB,SZVALEUR) From CRMUTIL150
        [M:CRMW]DATFININT(ILIGNE)    = SZVALEUR
        [M:CRMW]HEURFIN(ILIGNE)      = ""
        [M:CRMW]TYPACT(ILIGNE)       = 2
        [M:CRMW]EXE(ILIGNE)          = [F:CLL]CLLDON
        [M:CRMW]OBJET(ILIGNE)        = left$([F:CLL]CLLOBJ, 250)
        [M:CRMW]CATEG(ILIGNE)        = [F:CLL]CLLCAT
        If [M:CRMW]CATEG(ILIGNE)= "" Then
          [M:CRMW]LIBCATEG(ILIGNE)   = ""
        Else
          Call GET_LIB(432, [M:CRMW]CATEG(ILIGNE), [M:CRMW]LIBCATEG(ILIGNE)) From CRM_UTIL
        Endif
        [M:CRMW]BPR(ILIGNE)          = [F:CLL]CLLCMP
        If [M:CRMW]BPR(ILIGNE) <> "" Then
          SZCODE = [M:CRMW]BPR(ILIGNE)
          Read [BPR]BPR0=SZCODE
          If fstat = 0 Then
            SZLIBELLE = [F:BPR]BPRNAM
          Else
            SZLIBELLE = ""
          Endif
        Else
          SZCODE = ""
          SZLIBELLE = ""
        Endif
        Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBBPRAGD(ILIGNE)) From CRMUTIL150
        [M:CRMW]CCN(ILIGNE)          = [F:CLL]CLLCCN
        If [M:CRMW]CCN(ILIGNE) = "" Then
          SZCODE = ""
          SZLIBELLE = ""
        Else
          SZCODE = [M:CRMW]CCN(ILIGNE)
          Read [AIN]AIN0=[M:CRMW]CCN(ILIGNE)
          If fstat Then
            SZLIBELLE = ""
          Else
            Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
          Endif
        Endif
        Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBCCNAGD(ILIGNE)) From CRMUTIL150
        ILIGNE += 1
      Endif
    Next
    Filter [CLL]
    [M:CRMW]NBLIGAGD = ILIGNE
  Endif
  #-------------------------
  If [M:CRMW]AGDTSK = 2 Then
    #Sélection des taches
    ILIGNEWHERE = 0
    Raz SZWHERE
    SZAND = ""
    If [M:CRM0]REP <> "" Then
      SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKREP=[M:CRM0]REP "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMIN <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:TSK]TSKDAT<>[00/00/00] and [F:TSK]TSKDAT>=[M:CRM0]DATMIN) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMAX <> [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:TSK]TSKDAT<>[00/00/00] and [F:TSK]TSKDAT<=[M:CRM0]DATMAX) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    If [M:CRM0]DATMIN = [00/00/00] and [M:CRM0]DATMAX = [00/00/00] Then
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:TSK]TSKDAT<>[00/00/00]) "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    #
    SZCNTCRMAGD = "AGDTSK"
    Gosub PE_CRMAGD From TRTCRMPE
    SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
    If SZROLE <> "1=1" Then
      SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
    Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "TSK") From CRMUTIL150
    If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
      Filter [TSK] Where evalue(SZWHERE) Order By [F:TSK]TSKDAT Asc
    Else
      Filter [TSK] Order By [F:TSK]TSKDAT Asc
    Endif
    ILIGNE = [M:CRMW]NBLIGAGD
    For [TSK] Hint Key TSK4
      If ILIGNE >= dim([M:CRMW]KEYACT)-1 Then
        Break
      Endif
      If [F:TSK]TSKNUM <> "" Then
        [M:CRMW]OBJ(ILIGNE)          = "TSK"
        [M:CRMW]KEYACT(ILIGNE)       = [F:TSK]TSKNUM
        [M:CRMW]SEMAINE(ILIGNE)      = num$(week([F:TSK]TSKDAT))
        [M:CRMW]DATDEB(ILIGNE)       = [F:TSK]TSKDAT
        Call CONVDI([F:TSK]TSKDAT, SZVALEUR) From CRMUTIL150
        [M:CRMW]DATDEBINT(ILIGNE)    = SZVALEUR
        [M:CRMW]HEURDEB(ILIGNE)      = "0900"
        [M:CRMW]DATFIN(ILIGNE)       = [F:TSK]TSKDAT
        Call CONVDI([F:TSK]TSKDAT, SZVALEUR) From CRMUTIL150
        [M:CRMW]DATFININT(ILIGNE)    = SZVALEUR
        [M:CRMW]HEURFIN(ILIGNE)      = ""
        [M:CRMW]TYPACT(ILIGNE)       = 1
        [M:CRMW]EXE(ILIGNE)          = [F:TSK]TSKDON
        [M:CRMW]OBJET(ILIGNE)        = left$([F:TSK]TSKDES, 250)
        [M:CRMW]CATEG(ILIGNE)        = [F:TSK]TSKTYP
        If [M:CRMW]CATEG(ILIGNE) = "" Then
          [M:CRMW]LIBCATEG(ILIGNE)   = ""
        Else
          Call GET_LIB(431, [M:CRMW]CATEG(ILIGNE), [M:CRMW]LIBCATEG(ILIGNE)) From CRM_UTIL
        Endif
        [M:CRMW]BPR(ILIGNE)          = [F:TSK]TSKCMP
        If [M:CRMW]BPR(ILIGNE) <> "" Then
          SZCODE = [M:CRMW]BPR(ILIGNE)
          Read [BPR]BPR0=SZCODE
          If fstat = 0 Then
            SZLIBELLE = [F:BPR]BPRNAM
          Else
            SZLIBELLE = ""
          Endif
        Else
          SZCODE = ""
          SZLIBELLE = ""
        Endif
        Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBBPRAGD(ILIGNE)) From CRMUTIL150
        [M:CRMW]CCN(ILIGNE)          = [F:TSK]TSKCCN
        If [M:CRMW]CCN(ILIGNE) = "" Then
          SZCODE = ""
          SZLIBELLE = ""
        Else
          SZCODE = [M:CRMW]CCN(ILIGNE)
          Read [AIN]AIN0=[M:CRMW]CCN(ILIGNE)
          If fstat Then
            SZLIBELLE = ""
          Else
            Call BUILDFULNAM("AIN", SZLIBELLE) From CRMUTIL140
          Endif
        Endif
        Call CRMAFFAGD(SZCODE, SZLIBELLE, [M:CRMW]LIBCCNAGD(ILIGNE)) From CRMUTIL150
        ILIGNE += 1
      Endif
    Next
    Filter [TSK]
    [M:CRMW]NBLIGAGD = ILIGNE
  Endif
  Sorta [M:CRMW]NBLIGAGD [M:CRMW]NBLIGAGD Order By [M:CRMW]DATDEB(indice), [M:CRMW]HEURDEB(indice), [M:CRMW]TYPACT(indice)
  Raz [M:CRM1] : Transmask [M:CRMW] To [M:CRM1]
  Close Local Mask [CRMW]
  If [M:CRM1]NBLIGAGD = 0 Then
    [M:CRM1]NBLIGAGD = 1
  Endif
  Affzo [M:CRM1]1-99
Return

##########################################################################################################
$LOAD_CAMPAGNE
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(100)
Local Char SZLIBELLE(250)
Local Char SZCODE
Local Integer ILIGNE

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  Raz SZLIBELLE
  Raz SZCODE
  ILIGNE = 0
  #Remplit le tableau des campagnes marketing
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:OMP]CLO <> 2"
  ILIGNEWHERE += 1
  SZAND = " AND "
  #
  SZCNTCRMAGD = "PHONING"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("FCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "OMP") From CRMUTIL150
  nolign = 0
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [OMP] Where evalue(SZWHERE) Order By [F:OMP]OMPEND Desc
  Else
    Filter [OMP] Order By [F:OMP]OMPEND Desc
  Endif
  For [OMP]
    If ILIGNE >= dim([M:CRM8]TTROPG)-1 Then
      Break
    Endif
    #Transclass Campagne d'appels
    nolign += 1
    [M:CRM8] = [F:OMP]
    [M:CRM8]NBRCLL(ILIGNE) = [F:OMP]NBRCLLOMP
    If ILIGNE = 0 Then
      [M:CRM8]TTROPG(ILIGNE) = "->" - left$([F:OMP]DES, 37)
    Else
      [M:CRM8]TTROPG(ILIGNE) = left$([F:OMP]DES, 40)
    Endif
    [M:CRM8]TTROPGSAVE(ILIGNE) = left$([F:OMP]DES, 40)
    [M:CRM8]OPGDATSTR(ILIGNE) = [F:OMP]OMPSTR
    [M:CRM8]OPGDATEND(ILIGNE) = [F:OMP]OMPEND
    [M:CRM8]OPGMKGNUM(ILIGNE) = [F:OMP]OMPNUM
    [M:CRM8]RMNCLL(ILIGNE) = [F:OMP]NBRCLLPCD
    [M:CRM8]RMNCLLX(ILIGNE) = [F:OMP]NBRCLLPCDX
    Read [CMG]CMG0=[F:OMP]CMGNUM
    If fstat Then
      [M:CRM8]TTRCMG(ILIGNE) = ""
      [M:CRM8]CMGDATSTR(ILIGNE) = [00/00/00]
      [M:CRM8]CMGDATEND(ILIGNE) = [00/00/00]
      [M:CRM8]CMGMKGNUM(ILIGNE) = ""
    Else
      [M:CRM8]TTRCMG(ILIGNE) = left$([F:CMG]TTR, 40)
      [M:CRM8]CMGDATSTR(ILIGNE) = [F:CMG]DATSTR
      [M:CRM8]CMGDATEND(ILIGNE) = [F:CMG]DATEND
      [M:CRM8]CMGMKGNUM(ILIGNE) = [F:CMG]NUM
    Endif
    ILIGNE += 1
  Next
  Filter [OMP]
  [M:CRM8]NBLIGCMG = ILIGNE
  #Remplit le tableau des appels à effectuer par opération
  If [M:CRM8]NBLIGCMG > 0 Then
    If [M:CRM8]EVRCLL = 2 Then
      Call LALLCLL
    Else
      Call LOPGCLL([M:CRM8]OPGMKGNUM(0))
    Endif
  Endif
  Affzo [M:CRM8]1-99
Return

##########################################################################################################
$LOAD_OPP
  Gosub VAR_PE_CRMAGD

Local Char SZROLE (250)
Local Char SZWHERE (250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR (250)
Local Char SZRECHERCHE (100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  #Remplissage du tableau des affaires
  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:CRM4]20
  [M:CRM4]NBLIGOPP = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPP]OPPCLO<>2 "
  ILIGNEWHERE += 1
  SZAND=" AND "
  If [M:CRM0]REP<>"" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPP]OPPREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM4]SEAOPPTYP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPP]OPPTYP=[M:CRM4]SEAOPPTYP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM4]SEAOPPSTE <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPSTE=[M:CRM4]SEAOPPSTE "                                                         # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMIN <> [00/00/00] Then
    If GIOPPRANGE > 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "(([F:OPPCRM]OPPCDA>=[M:CRM0]DATMIN - GIOPPRANGE) or [F:OPPCRM]OPPCDA=[00/00/00]) "         # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      ILIGNEWHERE += 1
      SZAND = " AND "
    Else
      SZWHERE(ILIGNEWHERE) = SZAND - "(([F:OPPCRM]OPPCDA>=[M:CRM0]DATMIN - 30) or [F:OPPCRM]OPPCDA=[00/00/00])"                  # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  If [M:CRM0]DATMAX <> [00/00/00] Then
    If GIOPPRANGE > 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA<=[M:CRM0]DATMAX + GIOPPRANGE "                                            # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      ILIGNEWHERE += 1
      SZAND = " AND "
    Else
      SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA<=[M:CRM0]DATMAX + 30 "                                                    # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  If [M:CRM4]NOOPPCDA <> 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA <> [00/00/00] "                                                             # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "OPPOR"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "OPP") From CRMUTIL150
  # Issue X3-60926 - 2018-03-28 by FGR : BEGIN
  Link [OPP] With [OPPCRM]OPPCRM0=[F:OPP]OPPNUM
&              As [LOPP]
&    Order By Key OPP6=[F:OPP]OPPREP;[F:OPPCRM]OPPCDA
  # Issue X3-60926 - 2018-03-28 by FGR : END
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    #Filter [OPP] Where evalue(SZWHERE) Order By [F:OPP]OPPCDA Desc            # Issue X3-60926 - 2018-03-28 by FGR
    Filter [LOPP] Where evalue(SZWHERE) Order By [F:OPPCRM]OPPCDA Desc         # Issue X3-60926 - 2018-03-28 by FGR
  Else
    #Filter [OPP] Order By [F:OPP]OPPCDA Desc                                  # Issue X3-60926 - 2018-03-28 by FGR
    Filter [LOPP] Order By [F:OPPCRM]OPPCDA Desc                               # Issue X3-60926 - 2018-03-28 by FGR
  Endif
  ILIGNE = 0
  #For [OPP] Hint Key OPP6                                                     # Issue X3-60926 - 2018-03-28 by FGR
  For [LOPP] Hint Key OPP6                                                     # Issue X3-60926 - 2018-03-28 by FGR
    If ILIGNE = dim([M:CRM4]OPPCDA)-1 Then
      Break
    Endif
    #Transclass Affaires
    nolign = ILIGNE + 1
    [M:CRM4]                         = [F:OPP]
    [M:CRM4]OPPCDA(ILIGNE)           = [F:OPPCRM]OPPCDA                        # Issue X3-60926 - 2018-03-28 by FGR
    Call GET_LIB(400, [F:OPPCRM]OPPSTE, SZVALEUR) From CRM_UTIL                # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    [M:CRM4]OPPSTE(ILIGNE)           = SZVALEUR
    [M:CRM4]OPPCMP(ILIGNE)           = [F:OPP]OPPCMP
    Read [BPR]BPR0=[F:OPP]OPPCMP
    If fstat Then
      [M:CRM4]OPPCMPNAM(ILIGNE)      = [F:OPP]OPPCMP
    Else
      [M:CRM4]OPPCMPNAM(ILIGNE)      = [F:BPR]BPRNAM
    Endif
    [M:CRM4]OPPTYP(ILIGNE)           = [F:OPP]OPPTYP
    Call GET_LIB(434, [F:OPP]OPPTYP, SZVALEUR) From CRM_UTIL
    [M:CRM4]OPPTYPCLA(ILIGNE)        = SZVALEUR
    [M:CRM4]OPPAMT(ILIGNE)           = [F:OPPCRM]OPPAMT                        # Issue X3-60926 - 2018-03-28 by FGR
    [M:CRM4]CUR(ILIGNE)              = [F:OPP]CUR
    [M:CRM4]OPPSUC(ILIGNE)           = [F:OPPCRM]OPPSUC                        # Issue X3-60926 - 2018-03-28 by FGR
    [M:CRM4]OPPNBQ(ILIGNE)           = [F:OPPCRM]OPPNBQ                        # Issue X3-60926 - 2018-03-28 by FGR
    # Issue X3-60926 - 2018-03-28 by FGR : BEGIN
    #[M:CRM4]OPPDES(ILIGNE)          = [F:OPP]OPPDES
    [M:CRM4]OPPDES(ILIGNE)           = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM)
    # Issue X3-60926 - 2018-03-28 by FGR : END
    [M:CRM4]OPPNUM(ILIGNE)           = [F:OPP]OPPNUM
    [M:CRM4]OPPCNT(ILIGNE)           = [F:OPP]OPPMCN
    ILIGNE += 1
  Next
  Filter [OPP]
  [M:CRM4]NBLIGOPP = ILIGNE
  Affzo [M:CRM4]1-99
Return

##########################################################################################################
$LOAD_BAP
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Char SZZIP
Local Integer IZIPLEN

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  Effzo [M:CRM7]5
  [M:CRM7]NBLIGAPP = 0
  SZWHERE(ILIGNEWHERE) = "[F:BAP]APTDON <> 2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "find([M:CRM0]REP,[F:BAP]APTREPNUM)<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM7]SEAAPTTYP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:BAP]APTTYP=[M:CRM7]SEAAPTTYP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM7]SEABCS = 1 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:BAP]APTDAT>=date$ or [F:BAP]APTDATEND>=date$) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:BAP]APTDAT>=[M:CRM0]DATMIN or [F:BAP]APTDATEND>=[M:CRM0]DATMIN) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:BAP]APTDAT<=[M:CRM0]DATMAX or [F:BAP]APTDATEND<=[M:CRM0]DATMAX) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "BAPPOINT"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "BAP") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [BAP] Where evalue(SZWHERE) Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Else
    Filter [BAP] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Endif
  ILIGNE = 0
  For [BAP] Hint Key APP4
    If ILIGNE = dim([M:CRM7]APTDAT)-1 Then
      Break
    Endif
    #Transclass Appels
    nolign = ILIGNE + 1
    [M:CRM7]                         = [F:BAP]
    #
    [M:CRM7]APTDAT(ILIGNE)           = [F:BAP]APTDAT
    [M:CRM7]APTHOU(ILIGNE)           = [F:BAP]APTHOU
    [M:CRM7]APTDATEND(ILIGNE)        = [F:BAP]APTDATEND
    [M:CRM7]APTHOUEND(ILIGNE)        = [F:BAP]APTHOUEND
    [M:CRM7]APTWEE(ILIGNE)           = [F:BAP]APTWEE
    [M:CRM7]APTTYP(ILIGNE)           = [F:BAP]APTTYP
    Call GET_LIB(433, [F:BAP]APTTYP, SZVALEUR) From CRM_UTIL
    [M:CRM7]APTTYPCLA(ILIGNE)        = SZVALEUR
    [M:CRM7]APTOBJ(ILIGNE)           = left$([F:BAP]APTOBJ, 100)
    If [M:CRM7]APTOBJ(ILIGNE) <> "" Then
      Call REMOVECHAR(chr$(10), [M:CRM7]APTOBJ(ILIGNE)) From CRMUTIL140
      Call REMOVECHAR(chr$(13), [M:CRM7]APTOBJ(ILIGNE)) From CRMUTIL140
    Endif
    If [F:BAP]APTCMP = "" Then
      If [F:BAP]APTCCNNUM(0) = "" Then
        If [F:BAP]APTOBJ = "" Then
          If [F:BAP]APTTYP <> "" Then
            Call GET_LIB(433, [F:BAP]APTTYP, [M:CRM7]APTCMP(ILIGNE)) From CRM_UTIL
          Endif
        Else
          [M:CRM7]APTCMP(ILIGNE)     = left$([F:BAP]APTOBJ, 35)
        Endif
      Else
        Read [AIN]AIN0=[F:BAP]APTCCNNUM(0)
        If fstat Then
          [M:CRM7]APTCMP(ILIGNE)     = [F:BAP]APTCCNNUM(0)
        Else
          Call BUILDFULNAM("AIN", [M:CRM7]APTCMP(ILIGNE)) From CRMUTIL140
        Endif
      Endif
    Else
      Read [BPR]BPR0=[F:BAP]APTCMP
      If fstat Then
        [M:CRM7]APTCMP(ILIGNE)       = [F:BAP]APTCMP
      Else
        [M:CRM7]APTCMP(ILIGNE)       = [F:BPR]BPRNAM
      Endif
    Endif
    If [M:CRM7]APTCMP(ILIGNE) <> "" Then
      Call REMOVECHAR(chr$(10), [M:CRM7]APTCMP(ILIGNE)) From CRMUTIL140
      Call REMOVECHAR(chr$(13), [M:CRM7]APTCMP(ILIGNE)) From CRMUTIL140
    Endif
    [M:CRM7]APTCMPX(ILIGNE)          = [F:BAP]APTCMP
    [M:CRM7]APTCCNX(ILIGNE)          = [F:BAP]APTCCNNUM(0)
    [M:CRM7]APTOPPX(ILIGNE)          = [F:BAP]APTPJT
    If [F:BAP]APTPLC <> 2 Then
      SZZIP = [F:BAP]APTZIP
      IZIPLEN = len(SZZIP)
      [M:CRM7]APTPLC(ILIGNE) = SZZIP + left$([F:BAP]APTCTY, 24-IZIPLEN)
      If [M:CRM7]APTPLC(ILIGNE) <> "" Then
        [M:CRM7]APTPLC(ILIGNE) = SZZIP + "/" + left$([F:BAP]APTCTY, 24 - IZIPLEN)
      Endif
    Else
      Call GET_LIBM(955, [F:BAP]APTPLC, GLANGUE, SZVALEUR) From CRM_UTIL
      [M:CRM7]APTPLC(ILIGNE) = left$(SZVALEUR, 25)
    Endif
    Read [AUS]CODUSR=[F:BAP]CREUSR
    If fstat Then
      [M:CRM7]APTCREUSR(ILIGNE)      = [F:BAP]CREUSR
    Else
      [M:CRM7]APTCREUSR(ILIGNE)      = [F:AUS]NOMUSR
    Endif
    [M:CRM7]APTNUM(ILIGNE)           = [F:BAP]APTNUM
    [M:CRM7]APTCTY(ILIGNE)           = [F:BAP]APTCTY
    [M:CRM7]APTADD0(ILIGNE)          = [F:BAP]APTADD(0)
    [M:CRM7]APTZIP(ILIGNE)           = [F:BAP]APTZIP
    [M:CRM7]APTCRY(ILIGNE)           = [F:BAP]APTCRY
    [M:CRM7]SALFCY(ILIGNE)           = [F:BAP]SALFCY
    [M:CRM7]APTPLCX(ILIGNE)          = [F:BAP]APTPLC
    #
    ILIGNE += 1
  Next
  Filter [BAP]
  [M:CRM7]NBLIGAPP = ILIGNE
  Affzo [M:CRM7]1-99
Return

##########################################################################################################
$LOAD_CLL
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZDATENONULL(150)

  Gosub ICONE_RETOUR From SUBCLLB
  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZDATENONULL
  Effzo [M:CRM2]20
  [M:CRM2]NBLIGCLL = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDON<>2 and [F:CLL]CLLTYP=2"
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM2]SEACLLCAT <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLCAT=[M:CRM2]SEACLLCAT "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM2]SEACLLPIO <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLPIOLEV=[M:CRM2]SEACLLPIO "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM2]SEACLLNDT = 2 Then
    SZDATENONULL = "or [F:CLL]CLLDATX=[00/00/00]"
  Else
    SZDATENONULL = ""
  Endif
  If [M:CRM2]SEACLLDEL = 1 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:CLL]CLLDATX>=date$" - SZDATENONULL + ") "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:CLL]CLLDATX>=[M:CRM0]DATMIN" - SZDATENONULL + ") "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:CLL]CLLDATX<=[M:CRM0]DATMAX" - SZDATENONULL + ") "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM2]SEACLLCMG = 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLCMGFLG = 0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Elsif [M:CRM2]SEACLLCMG = 3 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLCMGFLG = 1 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "PHONECALL"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CLL") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Else
    Filter [CLL] Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Endif
  ILIGNE = 0
  For [CLL] Hint Key CLL4
    If ILIGNE = dim([M:CRM2]CLLDAT) - 1 Then
      Break
    Endif
    #Transclass Appels
    nolign = ILIGNE + 1
    [M:CRM2]                         = [F:CLL]
    [M:CRM2]CLLDAT(ILIGNE)           = [F:CLL]CLLDAT
    [M:CRM2]CLLHOU(ILIGNE)           = [F:CLL]CLLHOU
    [M:CRM2]CLLWEEK(ILIGNE)          = num$([F:CLL]CLLWEE)
    [M:CRM2]CLLCAT(ILIGNE)           = [F:CLL]CLLCAT
    Call GET_LIB(432, [F:CLL]CLLCAT, SZVALEUR) From CRM_UTIL
    [M:CRM2]CLLCATCLA(ILIGNE)        = SZVALEUR
    [M:CRM2]CLLPIOLEV(ILIGNE)        = [F:CLL]CLLPIOLEV
    Call GET_LIB(405, [F:CLL]CLLPIOLEV, SZVALEUR) From CRM_UTIL
    [M:CRM2]CLLPIOCLA(ILIGNE)        = SZVALEUR
    [M:CRM2]CLLCMP(ILIGNE)           = [F:CLL]CLLCMP
    Read [BPR] BPR0=[F:CLL]CLLCMP
    If fstat Then
      [M:CRM2]CLLCMPNAM(ILIGNE)      = [F:CLL]CLLCMP
    Else
      [M:CRM2]CLLCMPNAM(ILIGNE)      = [F:BPR]BPRNAM
    Endif
    [M:CRM2]CLLCNT(ILIGNE)           = [F:CLL]CLLCCN
    Read [AIN] AIN0=[F:CLL]CLLCCN
    If fstat Then
      [M:CRM2]CLLCNTNAM(ILIGNE)      = [F:CLL]CLLCCN
      [M:CRM2]CLLCRY(ILIGNE)         = GPAYS
    Else
      Call BUILDFULNAM("AIN", [M:CRM2]CLLCNTNAM(ILIGNE)) From CRMUTIL140
      [M:CRM2]CLLCRY(ILIGNE)         = [F:AIN]CRY
    Endif
    [M:CRM2]CLLETS(ILIGNE)           = [F:CLL]CLLETS
    [M:CRM2]CLLMOB(ILIGNE)           = [F:CLL]CLLMOB
    [M:CRM2]NBRTNT(ILIGNE)           = [F:CLL]CLLTNTPRE
    [M:CRM2]CLLOBJ(ILIGNE)           = left$([F:CLL]CLLOBJ, 100)
    If [M:CRM2]CLLOBJ(ILIGNE) <> "" Then
      Call REMOVECHAR(chr$(10), [M:CRM2]CLLOBJ(ILIGNE)) From CRMUTIL140
      Call REMOVECHAR(chr$(13), [M:CRM2]CLLOBJ(ILIGNE)) From CRMUTIL140
    Endif
    [M:CRM2]CLLNUM(ILIGNE)           = [F:CLL]CLLNUM
    [M:CRM2]CLLSCP(ILIGNE)           = [F:CLL]CLLSCP
    [M:CRM2]CLLCMGNUM(ILIGNE)        = [F:CLL]CLLCMGNUM
    [M:CRM2]CLLOPGNUM(ILIGNE)        = [F:CLL]CLLOPGNUM
    [M:CRM2]CLLREP(ILIGNE)           = [F:CLL]CLLREP
    [M:CRM2]CLLOPP(ILIGNE)           = [F:CLL]CLLOPP
    If [F:CLL]CLLORIADI = "MKT3" Then
      If [F:CLL]CLLCMGFLG = 0 Then
        [M:CRM2]CLLORIICO(ILIGNE)    = SZICOCOMPTE    # Appels non comptés dans les retours
      Else
        [M:CRM2]CLLORIICO(ILIGNE)    = SZICONOCOMPTE  # Appels comptés dans les retours
      Endif
    Else
      Raz [M:CRM2]CLLORIICO(ILIGNE)
    Endif
    ILIGNE += 1
  Next
  Filter [CLL]
  [M:CRM2]NBLIGCLL = ILIGNE
  Affzo [M:CRM2]1-99
Return

##########################################################################################################
$LOAD_TSK
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZDTDEBNONULL(150)
Local Char SZDTECHNONULL(150)

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZDTDEBNONULL
  Raz SZDTECHNONULL
  Effzo [M:CRM3]20
  [M:CRM3]NBLIGTSK = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKDON<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM3]SEATSKTYP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKTYP=[M:CRM3]SEATSKTYP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM3]SEATSKPIO <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKPIOLEV=[M:CRM3]SEATSKPIO "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM3]SEATSKNDT = 2 Then
    SZDTDEBNONULL = "or [F:TSK]TSKSTR=[00/00/00]"
    SZDTECHNONULL = "or [F:TSK]TSKDAT=[00/00/00]"
  Else
    SZDTDEBNONULL = ""
    SZDTECHNONULL = " and [F:TSK]TSKDAT <> [00/00/00]"
  Endif
  If [M:CRM3]SEATSKDEL = 1 Then
    If [M:CRM3]SEATSKRTD = 2 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "(([F:TSK]TSKDAT+[F:TSK]TSKDEL)>=date$" - SZDTECHNONULL + ") "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Else
      SZWHERE(ILIGNEWHERE) = SZAND - "([F:TSK]TSKDAT>=date$" - SZDTECHNONULL + ") "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  If [M:CRM0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND + "(([F:TSK]TSKSTR>=[M:CRM0]DATMIN" - SZDTDEBNONULL + ") or ([F:TSK]TSKDAT>=[M:CRM0]DATMIN" - SZDTECHNONULL + "))"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "(([F:TSK]TSKSTR<=[M:CRM0]DATMAX" - SZDTDEBNONULL + ") or ([F:TSK]TSKDAT<=[M:CRM0]DATMAX" - SZDTECHNONULL + "))"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "TASK"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "TSK") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [TSK] Where evalue(SZWHERE) Order By [F:TSK]TSKDAT Desc; [F:TSK]TSKPIOLEV Asc
  Else
    Filter [TSK] Order By [F:TSK]TSKDAT Desc; [F:TSK]TSKPIOLEV Asc
  Endif
  ILIGNE = 0
  For [TSK] Hint Key TSK4
    If ILIGNE = dim([M:CRM3]TSKDAT)-1 Then
      Break
    Endif
    #Transclass Tâches
    nolign = ILIGNE + 1
    [M:CRM3]                         = [F:TSK]
    [M:CRM3]TSKWEEK(ILIGNE)          = num$(week([F:TSK]TSKDAT))
    [M:CRM3]TSKDUD(ILIGNE)           = [F:TSK]TSKDAT
    [M:CRM3]TSKDES(ILIGNE)           = left$([F:TSK]TSKDES, 55)
    If [M:CRM3]TSKDES(ILIGNE) <> "" Then
      Call REMOVECHAR(chr$(10), [M:CRM3]TSKDES(ILIGNE)) From CRMUTIL140
      Call REMOVECHAR(chr$(13), [M:CRM3]TSKDES(ILIGNE)) From CRMUTIL140
    Endif
    [M:CRM3]TSKPIOLEV(ILIGNE)        = [F:TSK]TSKPIOLEV
    Call GET_LIB(405, [F:TSK]TSKPIOLEV, SZVALEUR) From CRM_UTIL
    [M:CRM3]TSKPIOCLA(ILIGNE)        = SZVALEUR
    [M:CRM3]TSKTYP(ILIGNE)           = [F:TSK]TSKTYP
    Call GET_LIB(431, [F:TSK]TSKTYP, SZVALEUR) From CRM_UTIL
    [M:CRM3]TSKTYPCLA(ILIGNE)        = SZVALEUR
    [M:CRM3]TSKCMP(ILIGNE)           = [F:TSK]TSKCMP
    Read [BPR]BPR0=[F:TSK]TSKCMP
    If fstat Then
      [M:CRM3]TSKCMPNAM(ILIGNE)      = [F:TSK]TSKCMP
    Else
      [M:CRM3]TSKCMPNAM(ILIGNE)      = [F:BPR]BPRNAM
    Endif
    [M:CRM3]TSKCNT(ILIGNE)           = [F:TSK]TSKCCN
    Read [AIN]AIN0=[F:TSK]TSKCCN
    If fstat Then
      [M:CRM3]TSKCNTNAM(ILIGNE)      = [F:TSK]TSKCCN
    Else
      Call BUILDFULNAM("AIN", [M:CRM3]TSKCNTNAM(ILIGNE)) From CRMUTIL140
    Endif
    [M:CRM3]TSKOPP(ILIGNE)           = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:TSK]TSKPJT) # Issue X3-101789 - 2018-07-23 by FGR : [F:OPP]OPPDES
    #Read [OPP]OPP0=[F:TSK]TSKPJT      # Issue X3-101789 - 2018-07-23 by FGR
    If fstat Then
      [M:CRM3]TSKOPPNAM(ILIGNE)      = [F:TSK]TSKPJT
    Else
      [M:CRM3]TSKOPPNAM(ILIGNE)      = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:TSK]TSKPJT) # Issue X3-101789 - 2018-07-23 by FGR : [F:OPP]OPPDES
    Endif
    [M:CRM3]TSKNUM(ILIGNE)           = [F:TSK]TSKNUM
    ILIGNE += 1
  Next
  Filter [TSK]
  [M:CRM3]NBLIGTSK = ILIGNE
  Affzo [M:CRM3]1-99
Return

##########################################################################################################
$LOAD_INF
  Effzo [M:CRM6]20
  [M:CRM6]NBLIGINF = 0
  Gosub LD_INF_BAP
  Gosub LD_INF_CLL
  Gosub LD_INF_TSK
  Gosub LD_INF_OPP
  Gosub LD_INF_CON
  Affzo [M:CRM6]1-99
Return

##########################################################################################################
$LD_INF_BAP
  If [M:CRM6]INFBAP <> 2 Then
    Return
  Endif
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZINFO(250)
Local Char SZREPNAM(100)
Local Integer IRETARD

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZREPNAM
  IRETARD = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:BAP]APTDON<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "find([M:CRM0]REP,[F:BAP]APTREPNUM)<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  SZWHERE(ILIGNEWHERE) = SZAND - "(([F:BAP]APTDAT<date$ and [F:BAP]APTDAT <> [00/00/00])"
&                          + " or ([F:BAP]APTDAT=[00/00/00] and [F:BAP]APTWEE<week(date$) and [F:BAP]APTDATX<date$)) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  #
  SZCNTCRMAGD = "INFBAP"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "BAP") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [BAP] Where evalue(SZWHERE) Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Else
    Filter [BAP] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  Endif
  ILIGNE = [M:CRM6]NBLIGINF
  For [BAP] Hint Key APP4
    If ILIGNE = dim([M:CRM6]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZREPNAM
    If [F:BAP]ATPREPMNA <> "" Then
      Read [REP]REP0=[F:BAP]ATPREPMNA
      If fstat = 0 Then
        SZREPNAM = [F:REP]REPNAM
      Endif
    Else
      Read [REP]REP0=[F:BAP]APTREPNUM(0)
      If fstat = 0 Then
        SZREPNAM = [F:REP]REPNAM
      Endif
    Endif
    #Rendez-vous annulé ou non marqué effectué
    SZINFO = mess(491,177,1)
    [M:CRM6]INFREPNAM(ILIGNE)        = SZREPNAM
    [M:CRM6]INFINFO(ILIGNE)          = SZINFO
    [M:CRM6]INFDELAY(ILIGNE)         = nday(date$) - nday([F:BAP]APTDATX)
    [M:CRM6]INFKEY(ILIGNE)           = [F:BAP]APTNUM
    [M:CRM6]CMPKEY(ILIGNE)           = [F:BAP]APTCMP
    [M:CRM6]CCNKEY(ILIGNE)           = [F:BAP]APTCCNNUM(0)
    [M:CRM6]OPPKEY(ILIGNE)           = [F:BAP]APTPJT
    [M:CRM6]INFTYPE(ILIGNE)          = 1
    [M:CRM6]INFOBJ(ILIGNE)           = "BAP"
    ILIGNE += 1
  Next
  Filter [BAP]
  [M:CRM6]NBLIGINF = ILIGNE
Return

##########################################################################################################
$LD_INF_CLL
  If [M:CRM6]INFCLL <> 2 Then
    Return
  Endif
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZINFO(250)
Local Char SZREPNAM(100)
Local Integer IRETARD

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZREPNAM
  IRETARD = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDON<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  SZWHERE(ILIGNEWHERE) = SZAND - "(([F:CLL]CLLDAT<date$ and [F:CLL]CLLDAT <> [00/00/00])"
&                          + " or ([F:CLL]CLLDAT=[00/00/00] and [F:CLL]CLLWEE<week(date$) and [F:CLL]CLLDATX<date$ and [F:CLL]CLLDATX <> [00/00/00])"
&                          + " or ([F:CLL]CLLDATX=[00/00/00])) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  #
  SZCNTCRMAGD = "INFCLL"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CLL") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
  Else
    Filter [CLL] Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
  Endif
  ILIGNE = [M:CRM6]NBLIGINF
  For [CLL] Hint Key CLL4
    If ILIGNE = dim([M:CRM6]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZREPNAM
    If [F:CLL]CLLREP <> "" Then
      Read [REP]REP0=[F:CLL]CLLREP
      If fstat = 0 Then
        SZREPNAM = [F:REP]REPNAM
      Endif
    Endif
    If [F:CLL]CLLDAT <> [00/00/00] or [F:CLL]CLLDATX <> [00/00/00] Then
      #Appel annulé ou non marqué effectué
      SZINFO = mess(492,177,1)
    Else
      #Appel non planifié
      SZINFO = mess(515,177,1)
    Endif
    [M:CRM6]INFREPNAM(ILIGNE)        = SZREPNAM
    [M:CRM6]INFINFO(ILIGNE)          = SZINFO
    If [F:CLL]CLLDATX <> [00/00/00] Then
      [M:CRM6]INFDELAY(ILIGNE)       = nday(date$) - nday([F:CLL]CLLDATX)
    Else
      [M:CRM6]INFDELAY(ILIGNE)       = 0
    Endif
    [M:CRM6]INFKEY(ILIGNE)           = [F:CLL]CLLNUM
    [M:CRM6]CMPKEY(ILIGNE)           = [F:CLL]CLLCMP
    [M:CRM6]CCNKEY(ILIGNE)           = [F:CLL]CLLCCN
    [M:CRM6]OPPKEY(ILIGNE)           = [F:CLL]CLLOPP
    [M:CRM6]INFTYPE(ILIGNE)          = 2
    [M:CRM6]INFOBJ(ILIGNE)           = "CLL"
    ILIGNE += 1
  Next
  Filter [CLL]
  [M:CRM6]NBLIGINF = ILIGNE
Return

##########################################################################################################
$LD_INF_TSK
  If [M:CRM6]INFTSK <> 2 Then
    Return
  Endif
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZINFO(250)
Local Char SZREPNAM(100)
Local Integer IRETARD

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZREPNAM
  IRETARD = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKDON<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:TSK]TSKREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  SZWHERE(ILIGNEWHERE) = SZAND - "([F:TSK]TSKDAT<date$ or [F:TSK]TSKDAT=[00/00/00] or [F:TSK]TSKSTR=[00/00/00]) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  #
  SZCNTCRMAGD = "INFTSK"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "TSK") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [TSK] Where evalue( SZWHERE) Order By [F:TSK]TSKDAT Asc; [F:TSK]TSKPIOLEV Asc
  Else
    Filter [TSK] Order By [F:TSK]TSKDAT Asc; [F:TSK]TSKPIOLEV Asc
  Endif
  ILIGNE = [M:CRM6]NBLIGINF
  For [TSK] Hint Key TSK4
    If ILIGNE = dim([M:CRM6]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZREPNAM
    If [F:TSK]TSKDAT <> [00/00/00] Then
      IRETARD = nday(date$) - nday([F:TSK]TSKDAT)
      If IRETARD < 0 Then
        IRETARD = 0
      Endif
    Else
      IRETARD = 0
    Endif
    If [F:TSK]TSKREP <> "" Then
      Read [REP]REP0=[F:TSK]TSKREP
      If fstat = 0 Then
        SZREPNAM = [F:REP]REPNAM
      Endif
    Endif
    # Retard +" : " + num$(IRETARD ) + " " + mess(2,976,1)
    #SZINFO=mess(490,177,1) - ":" - num$(IRETARD ) - mess(2,976,1)
    If [F:TSK]TSKDAT = [00/00/00] Then
      #Tâche non planifiée
      SZINFO = mess(516,177,1)
    Else
      If [F:TSK]TSKDAT < date$ Then
        #Tâche en retard ou non marqué effectuée
        SZINFO = mess(490,177,1)
      Else
        If [F:TSK]TSKSTR = [00/00/00] Then
          #Tâche avec date de début absente
          SZINFO = mess(517,177,1)
        Endif
      Endif
    Endif
    [M:CRM6]INFDELAY(ILIGNE)         = IRETARD
    [M:CRM6]INFREPNAM(ILIGNE)        = SZREPNAM
    [M:CRM6]INFINFO(ILIGNE)          = SZINFO
    [M:CRM6]INFKEY(ILIGNE)           = [F:TSK]TSKNUM
    [M:CRM6]CMPKEY(ILIGNE)           = [F:TSK]TSKCMP
    [M:CRM6]CCNKEY(ILIGNE)           = [F:TSK]TSKCCN
    [M:CRM6]OPPKEY(ILIGNE)           = [F:TSK]TSKPJT
    [M:CRM6]INFTYPE(ILIGNE)          = 3
    [M:CRM6]INFOBJ(ILIGNE)           = "TSK"
    ILIGNE += 1
  Next
  Filter [TSK]
  [M:CRM6]NBLIGINF = ILIGNE
Return

##########################################################################################################
$LD_INF_OPP
  If [M:CRM6]INFOPP <> 2 Then
    Return
  Endif
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZINFO(250)
Local Char SZREPNAM(100)
Local Integer IRETARD

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZREPNAM
  IRETARD = 0
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPP]OPPCLO<>2 "
  ILIGNEWHERE += 1
  SZAND = " AND "
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA <> [00/00/00] "             # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPP]OPPREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If GIOPPRANGE > 0 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA + GIOPPRANGE<date$ "      # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    ILIGNEWHERE += 1
    SZAND = " AND "
  Else
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:OPPCRM]OPPCDA<date$ "                   # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "INFOPP"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "OPP") From CRMUTIL150
  # Issue X3-101789 - 2018-07-23 by FGR : BEGIN
  #If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
  #  Filter [OPP] Where evalue(SZWHERE) Order By [F:OPP]OPPCDA Asc
  #Else
  #  Filter [OPP] Order By [F:OPP]OPPCDA Asc
  #Endif
  Link [OPP] With [OPPCRM]OPPCRM0=[F:OPP]OPPNUM
&              As [LOPP]
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [LOPP] Where evalue(SZWHERE) Order By [F:OPPCRM]OPPCDA Desc
  Else
    Filter [LOPP] Order By [F:OPPCRM]OPPCDA Desc
  Endif
  # Issue X3-101789 - 2018-07-23 by FGR : END
  ILIGNE = [M:CRM6]NBLIGINF
  For [OPP] Hint Key OPP4
    If ILIGNE = dim([M:CRM6]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZREPNAM
    IRETARD = nday(date$) - nday([F:OPPCRM]OPPCDA)                             # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
    If [F:OPP]OPPREP <> "" Then
      Read [REP]REP0=[F:OPP]OPPREP
      If fstat = 0 Then
        SZREPNAM = [F:REP]REPNAM
      Endif
    Endif
    #Date de conclusion dépassée
    SZINFO = mess(496,177,1)
    [M:CRM6]INFDELAY(ILIGNE)         = IRETARD
    [M:CRM6]INFREPNAM(ILIGNE)        = SZREPNAM
    [M:CRM6]INFINFO(ILIGNE)          = SZINFO
    [M:CRM6]INFKEY(ILIGNE)           = [F:OPP]OPPNUM
    [M:CRM6]CMPKEY(ILIGNE)           = [F:OPP]OPPCMP
    [M:CRM6]CCNKEY(ILIGNE)           = [F:OPP]OPPMCN
    [M:CRM6]OPPKEY(ILIGNE)           = ""
    [M:CRM6]INFTYPE(ILIGNE)          = 4
    [M:CRM6]INFOBJ(ILIGNE)           = "OPP"
    ILIGNE += 1
  Next
  Filter [OPP]
  [M:CRM6]NBLIGINF = ILIGNE
Return

##########################################################################################################
$LD_INF_CON
  If [M:CRM6]INFCON <> 2 Then
    Return
  Endif
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZVALEUR(250)
Local Char SZINFO(250)
Local Char SZREPNAM(100)
Local Integer IREFDAY
Local Integer INBDAY
Local Integer ISTEP
Local Integer IBWRITE

  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZVALEUR
  Raz SZINFO
  Raz SZREPNAM
  IREFDAY = 0
  INBDAY = 0
  ISTEP = 1

$STEP_CON
  ILIGNEWHERE = 0
  Raz SZWHERE
  SZAND = ""
  IBWRITE = 0
  If [M:CRM0]REP <> "" Then
    If func AFNC.ACTIV("REC") > 0 Then
      SZWHERE(ILIGNEWHERE) = SZAND - "find([M:CRM0]REP,[F:CON]SALREP)<>0 "
      ILIGNEWHERE += 1
      SZAND = " AND "
    Endif
  Endif
  SZWHERE(ILIGNEWHERE) = SZAND - "([F:CON]DSYWND=2 or [F:CON]DSYWND=4) "
  ILIGNEWHERE += 1
  SZAND = " AND "
  If ISTEP = 1 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:CON]CONCAT=3 and [F:CON]CONENDDAT>=date$) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Elsif ISTEP = 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "(([F:CON]CONCAT=3 or [F:CON]CONCAT=4) and [F:CON]CONENDDAT<date$) "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "INFCON"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CON") From CRMUTIL150
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CON] Where evalue(SZWHERE) Order By [F:CON]CONCAT Asc; [F:CON]CONENDDAT Asc
  Else
    Filter [CON] Order By [F:CON]CONCAT Asc; [F:CON]CONENDDAT Asc
  Endif
  ILIGNE = [M:CRM6]NBLIGINF
  IREFDAY = nday(date$)
  For [CON]
    If ILIGNE = dim([M:CRM6]INFKEY)-1 Then
      Break
    Endif
    Raz SZINFO
    Raz SZREPNAM
    IBWRITE = 0
    If dim([F:CON]SALREP) > 0 Then
      If [F:CON]SALREP(0) <> "" Then
        Read [REP]REP0=[F:CON]SALREP(0)
        If fstat = 0 Then
          SZREPNAM = [F:REP]REPNAM
        Endif
      Endif
    Endif
    If [F:CON]CONCAT = 4 Then
      If [F:CON]CONENDDAT < date$ Then
        INBDAY = IREFDAY - nday([F:CON]CONENDDAT)
        #Contrat à points à terme avec des points non épuisés
        SZINFO = mess(493,177,1)
        IBWRITE = 1
      Endif
    Endif
    If [F:CON]CONCAT = 3 Then
      #Contrats de maintenance
      If [F:CON]CONENDDAT < date$ Then
        INBDAY = IREFDAY - nday([F:CON]CONENDDAT)
        #Contrat de service échéance dépassée.
        SZINFO = mess(494,177,1)
        IBWRITE = 1
      Else
        INBDAY = nday([F:CON]CONENDDAT) - IREFDAY
        #Contrat de service à renouveller.
        SZINFO = mess(495,177,1)
        IBWRITE = 1
      Endif
    Endif
    If IBWRITE = 1 Then
      [M:CRM6]INFREPNAM(ILIGNE)      = SZREPNAM
      [M:CRM6]INFINFO(ILIGNE)        = SZINFO
      [M:CRM6]INFDELAY(ILIGNE)       = INBDAY
      [M:CRM6]INFKEY(ILIGNE)         = [F:CON]CONNUM
      [M:CRM6]CMPKEY(ILIGNE)         = [F:CON]CONBPC
      [M:CRM6]CCNKEY(ILIGNE)         = [F:CON]CONCCN
      [M:CRM6]OPPKEY(ILIGNE)         = [F:CON]CONPJT
      [M:CRM6]INFTYPE(ILIGNE)        = 5
      [M:CRM6]INFOBJ(ILIGNE)         = "CON"
      ILIGNE += 1
    Endif
  Next
  Filter [CON]
  [M:CRM6]NBLIGINF = ILIGNE
  If ISTEP = 1 Then
    ISTEP = 2
    Gosub STEP_CON
  Endif
Return

#########################################################
# Charge les appels d'une campagne d'appels.
#########################################################
Subprog LOPGCLL(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IA

  IA = 0
  nolign = 0
  Raz [M:CRM8]NBLIGCLLX
  Raz [M:CRM8]DAT
  Raz [M:CRM8]HOU
  Raz [M:CRM8]CMP
  Raz [M:CRM8]CCN
  Raz [M:CRM8]CLLNUM
  Gosub LCLL_WHERE
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLORIADI = 'MKT3' and [F:CLL]CLLORIVCR = SZOPGCOD"
  ILIGNEWHERE += 1
  SZAND = " AND "
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Else
    Filter [CLL] Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Endif
  For [CLL] Hint Key CLL4
    If IA >= dim([M:CRM8]DAT)-1 Then
      Break
    Endif
    #Transclass Appels
    nolign += 1
    [M:CRM8]                         = [F:CLL]
    [M:CRM8]DAT(IA)                  = [F:CLL]CLLDAT
    [M:CRM8]HOU(IA)                  = [F:CLL]CLLHOU
    [M:CRM8]CMP(IA)                  = [F:CLL]CLLCMP
    Read [BPR]BPR0=[F:CLL]CLLCMP
    If fstat Then
      [M:CRM8]CMP(IA)                = [F:CLL]CLLCMP
    Else
      [M:CRM8]CMP(IA)                = [F:BPR]BPRNAM
    Endif
    [M:CRM8]CMPX(IA)                 = [F:CLL]CLLCMP
    Gosub DISPCRM8CCN
    [M:CRM8]CCNX(IA)                 = [F:CLL]CLLCCN
    [M:CRM8]ETS(IA)                  = [F:CLL]CLLETS
    [M:CRM8]MOB(IA)                  = [F:CLL]CLLMOB
    [M:CRM8]TNT(IA)                  = [F:CLL]CLLTNTPRE
    [M:CRM8]CLLNUM(IA)               = [F:CLL]CLLNUM
    [M:CRM8]REPX(IA)                 = [F:CLL]CLLREP
    [M:CRM8]OPPX(IA)                 = [F:CLL]CLLOPP
    # FGR 30/04/2009 : X3SUIVI54457
    If [F:CLL]CLLCMGFLG = 0 Then
      [M:CRM8]CLLORIICO(IA)          = SZICOCOMPTE    # Appels non comptés dans les retours
    Else
      [M:CRM8]CLLORIICO(IA)          = SZICONOCOMPTE  # Appels comptés dans les retours
    Endif
    IA += 1
  Next
  Filter [CLL]
  [M:CRM8]NBLIGCLLX                  = IA
End

##########################################################################################################
$LCLL_WHERE
  Gosub VAR_PE_CRMAGD

Local Char SZROLE(250)
Local Char SZWHERE(250)(IFILTDIM)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(250)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL
Local Char SZDATENONULL(150)

  Gosub ICONE_RETOUR From SUBCLLB
  Raz SZROLE
  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Raz SZDATENONULL
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDON<>2 and [F:CLL]CLLTYP=2"
  ILIGNEWHERE += 1
  SZAND = " AND "
  If [M:CRM0]REP <> "" Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLREP=[M:CRM0]REP "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM8]DELAY = 1 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDATX>=date$ "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMIN <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDATX>=[M:CRM0]DATMIN "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM0]DATMAX <> [00/00/00] Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLDATX<=[M:CRM0]DATMAX "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  #
  SZCNTCRMAGD = "OPGCLL"
  Gosub PE_CRMAGD From TRTCRMPE
  SZROLE = func CRMUTIL150.GET_FILTRE_SITE_GRP ("SALFCY")
  If SZROLE <> "1=1" Then
    SZWHERE(ILIGNEWHERE) = SZAND - SZROLE
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "CLL") From CRMUTIL150
Return

##########################################################################################################
#Affiche le nom de l'interlocuteur
#####################################################
$DISPCRM8CCN
  [M:CRM8]CCN(IA) = ""
  [M:CRM8]CRYX(IA) = GPAYS
  If [F:CLL]CLLCCN = "" Then
    If [F:CLL]CLLORIADI = "MKT3" Then
      If [F:CLL]CLLORIVCR <> "" Then
        Read [OMP]OMP0=[F:CLL]CLLORIVCR
        If !fstat Then
          If [F:OMP]TYPSEA <> "CCN" Then
            If [F:OMP]CNTTTR <> "" Then
              [M:CRM8]CCN(IA) = left$([F:OMP]CNTTTR, 50)
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    Read [AIN]AIN0=[F:CLL]CLLCCN
    If !fstat Then
      Call BUILDFULNAM("AIN", [M:CRM8]CCN(IA)) From CRMUTIL140
      [M:CRM8]CRYX(IA) = [F:AIN]CRY
    Endif
  Endif
Return

##########################################################################################################
# Charge tous les appels de toutes les campagnes d'appels.
#########################################################
Subprog LALLCLL
Local Integer IA

  IA = 0
  nolign = 0
  Raz [M:CRM8]NBLIGCLLX
  Raz [M:CRM8]DAT
  Raz [M:CRM8]HOU
  Raz [M:CRM8]CMP
  Raz [M:CRM8]CCN
  Raz [M:CRM8]CLLNUM
  #Remplit le tableau des appels à effectuer par campagne
  Gosub LCLL_WHERE
  SZWHERE(ILIGNEWHERE) = SZAND - "[F:CLL]CLLOPGTYP='OMP' and [F:CLL]CLLOPGNUM<>''"
  ILIGNEWHERE += 1
  SZAND = " AND "
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [CLL] Where evalue(SZWHERE) Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Else
    Filter [CLL] Order By [F:CLL]CLLDATX Desc; [F:CLL]CLLHOU Desc
  Endif
  For [CLL] Hint Key CLL4
    If IA >= dim([M:CRM8]DAT)-1 Then
      Break
    Endif
    #Transclass Appels
    nolign += 1
    [M:CRM8]                         = [F:CLL]
    [M:CRM8]DAT(IA)                  = [F:CLL]CLLDAT
    [M:CRM8]HOU(IA)                  = [F:CLL]CLLHOU
    [M:CRM8]CMP(IA)                  = [F:CLL]CLLCMP
    Read [BPR]BPR0=[F:CLL]CLLCMP
    If fstat Then
      [M:CRM8]CMP(IA)                = [F:CLL]CLLCMP
    Else
      [M:CRM8]CMP(IA)                = [F:BPR]BPRNAM
    Endif
    [M:CRM8]CMPX(IA)                 = [F:CLL]CLLCMP
    Gosub DISPCRM8CCN
    [M:CRM8]CCNX(IA)                 = [F:CLL]CLLCCN
    [M:CRM8]ETS(IA)                  = [F:CLL]CLLETS
    [M:CRM8]MOB(IA)                  = [F:CLL]CLLMOB
    [M:CRM8]TNT(IA)                  = [F:CLL]CLLTNTPRE
    [M:CRM8]CLLNUM(IA)               = [F:CLL]CLLNUM
    [M:CRM8]REPX(IA)                 = [F:CLL]CLLREP
    [M:CRM8]OPPX(IA)                 = [F:CLL]CLLOPP
    If [F:CLL]CLLCMGFLG = 0 Then
      [M:CRM8]CLLORIICO(IA)          = SZICOCOMPTE    # Appels non comptés dans les retours
    Else
      [M:CRM8]CLLORIICO(IA)          = SZICONOCOMPTE  # Appels comptés dans les retours
    Endif
    IA += 1
  Next
  Filter [CLL]
  [M:CRM8]NBLIGCLLX                  = IA
End

