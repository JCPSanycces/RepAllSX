#<AdxTL>@(#)5.0.0.0 $Revision$
Subprog C_XCPTNUM(VALEUR)
Variable Char    VALEUR() 
# Si compteur manuel, on vérifie qu'il a été renseigné 
If GMANCOU <> 1 & VALEUR = "" 
  Call ERREUR(mess(182,199,1)) From GESECRAN  
  mkstat = 2 
  End 
Endif 
# Si compteur manuel, on vérifie qu'il n'existe pas déjà 
If GMANCOU <> 1 
   Look [F:SDH]SDH0=VALEUR 
   If fstat = 0 
      Call ERREUR(mess(49,192,1)) From GESECRAN  
      mkstat = 2 
   Endif 
Endif 
End

########################################
Subprog AP_XSTOFCY(VALEUR)
Variable Char    VALEUR()

Call GETDEV(VALEUR)  From DEVSUB
End

########################################
Subprog AP_XSALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
   Call GLOBVAR(VALEUR) From WWGLOBVEN
Endif
End

########################################
Subprog C_XSALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" 
   Call CONTSALFCY(VALEUR) From TRTVENCTL 
Endif 
End

########################################
Subprog AM_XBPCORD(VALEUR)
Variable Char    VALEUR()
 
[M]XBPAADD = [F:BPC]BPAADD : Affzo [M]XBPAADD 
End

########################################
Subprog AS_XBPAADD(VALEUR)
Variable Char    VALEUR()

GBPCNUM = [M]XBPCORD
End 

########################################
Subprog AM_XBPAADD(VALEUR)
Variable Char    VALEUR()
 
[M]XBPDNAM = [F:BPD]BPDNAM(0) 
Affzo [M]XBPDNAM 
End 

########################################
Subprog C_XNUMDEB(VALEUR)
Variable Char    VALEUR()

If XNUMFIN <> "" & VALEUR > XNUMFIN
   mkstat = 2
Endif
End

########################################
Subprog AM_XNUMDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" & XNUMFIN = ""
   XNUMFIN = VALEUR
Endif
End

########################################
Subprog C_XNUMFIN(VALEUR)
Variable Char    VALEUR()

If XNUMDEB <> "" & VALEUR < XNUMDEB
   mkstat = 2
Endif
End

########################################
Subprog AP_XNUMFIN(VALEUR)
Variable Char    VALEUR()

status = 92
End
########################################
Subprog C_NBCDE
End

