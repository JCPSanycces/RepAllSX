Subprog AS_GRVDEMAMT(VALEUR, NUM)
Variable Decimal VALEUR
Value Integer NUM

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY
Local Integer STA

# Y'a t il une variable "NUM"
[L]NOMVAR = [L]MSK + "GRVVRACOD"+num$([L]NUM)
If evalue([L]NOMVAR) = ""
    mkstat = 2 : End
Endif

# Interdiction de saisie si variable prise en compte
[L]NOMVAR = [L]MSK + "GRVSTA"+num$([L]NUM)+"([L]NOL)"
If evalue([L]NOMVAR) = [L]PPDSTA_PRISENCOMPTE
    mkstat = 2
Endif

End

