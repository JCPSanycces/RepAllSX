#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet PPH
#** V7 : Waiting Time Mangement **#
#*********************************#

#-------------------------------------------------------------------------------------
# SUBHRPPH : Gestion des bordereaux de demandes préparation paye
# DLE 19/08/11 : old SUBPPH
#-------------------------------------------------------------------------------------
# (C) PROSPER 08/10
# LOT P03 - 66096
#-------------------------------------------------------------------------------------
# NBCOLSAISIECROISEETAG : Tag positionné partout ou des modifs seront nécessaire pour
#                         changer le nombre de colonnes en saisie croisée.
#-------------------------------------------------------------------------------------

Call OBJET("HRPPH", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
    When "OUVRE"            : Gosub OUVRE
    When "LIENS"            : Gosub LIENS
    When "SETBOUT"          : Gosub SETBOUT
    When "EXEBOUT"          : Gosub EXEBOUT
    When "STATUT"           : Gosub STATUT
    When "EXEACT"           : Gosub EXEACT
    When "INICRE"           : Gosub INICRE
    When "INIMOD"           : Gosub INIMOD
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "CREATION"         : Gosub CREATION
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "MODIF"            : Gosub MODIF
    When "ANNULE"           : Gosub ANNULE
    When "RAZCRE"           : Gosub RAZCRE
    When "RAZDUP"           : Gosub RAZDUP
    When "APRES_CRE"        : Gosub APRES_CRE
    When "APRES_MOD"        : Gosub APRES_MOD
    When "ABANDON"          : Gosub ABANDON
    When "ANNULE"           :
    When "FERME"            : Gosub FERME
    When Default
Endcase
Return

$OUVRE

Local Char WCODNUM([V]GLONANM), WFCY([V]GLONFCY), WCOMPLEMENT(250), WREQNUM([V]GLONHRPPH)
Local Char VOIDCHAR(250)
Local Date WDAT
Local Integer WMANCOU

Local Char TREFNUM([V]GLONEML)(dim([M:HRPPH1]REFNUM)), REFNUM([V]GLONEML)
Local Char TCTRNUM([V]GLONHRCTR)(dim([M:HRPPH1]CTRNUM)), CTRNUM([V]GLONHRCTR)        :#89508 GLONEML->GLONHRCTR !
Local Date TCTRDAT(dim([M:HRPPH1]CTRNUM)), CTRDAT
Local Char S_REQNUM([V]GLONHRPPH)

Gosub SETFLX



Local Integer STAT, FLGLOA, NBCTR, NBMAX_PPDVAR, I, J, K
Local Integer TTYPMGR(len(mess(0,50,1)))
Local Char MESSAGE(250)

Local Integer INDICE_DEBUT_SALARIE : [L]INDICE_DEBUT_SALARIE = 21
Global Integer GPPHAFFMSK : [V]GPPHAFFMSK = 1

# Doit on avoir une notion de groupe de saisie dans la liste
# de variable (VRAGRP), basée sur une table diverse indépendante (442) ou doit on reprendre
# le thème de la variable (table 391, thème stocké dans VARIA).
# Du coup, on fait les deux ^^
# GPPHVRAGRP = 1 = non = on récupère le thème dans VARIA
# GPPHVRAGRP = 2 = oui = on exploite une zone VRAGRP dans PVD

If dim([V]GPPHVRAGRP) < 0
    Global Integer GPPHVRAGRP : [V]GPPHVRAGRP = 2
Endif

If clalev([F:TCA])  = 0    : Local File TABCOUAFF   [TCA]    : Endif
If clalev([F:HRCTR])= 0    : Local File EMPLOCTR    [HRCTR]  : Endif
If clalev([F:ID])   = 0    : Local File EMPLOID     [ID]     : Endif
If clalev([F:HRPVD])  = 0  : Local File PPVRALISD   [HRPVD]  : Endif
If clalev([F:PVH])  = 0    : Local File PPVRALISH   [PVH]    : Endif
If clalev([F:FCY])  = 0    : Local File FACILITY    [FCY]    : Endif
If clalev([F:CPY])  = 0    : Local File COMPANY     [CPY]    : Endif
If clalev([F:HRPOA])  = 0  : Local File POPULA      [HRPOA]  : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:HRPEO])  = 0  : Local File HRPERIOD    [HRPEO]    : Endif
#*!
If clalev([F:HRPEOD])  = 0  : Local File HRPEODET    [HRPEOD]    : Endif
#LIPET - 2017-05-20 - END
If clalev([F:ELC])  = 0    : Local File EMPLOELC    [ELC]    : Endif

# Récupération du code du compteur affecté (module paye 15, compteur 7)
#Call GET_PARCPT(15, 7, [L]WCODNUM, [L]WMANCOU) From DIVPPH

# Récupération des états PPDSTA
Gosub GET_PPDSTA From TRTPREPAY

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$FERME
Kill [V]GPPHAFFMSK
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$SETBOUT
Call VIREBOUT([L]CHAINE, "s") From GOBJET    : # Suppression soumission
If CLECUR
    Case [M:HRPPH0]REQSTA
        When 1
            # Brouillon
            [L]CHAINE += "s"    : # Ajout soumission
        When 2
            # Soumis
        When 3
            # Traité ( tout est pris en compte ), on ne permet plus de modification
            Call VIREBOUT([L]CHAINE, "M") From GOBJET
    Endcase
    If find([L]PPDSTA_PRISENCOMPTE, [M:HRPPH1]STA)
        # si une ligne est prise en compte, on ne peut plus supprimer le bordereau
        Call VIREBOUT([L]CHAINE, "A") From GOBJET
    Endif
    [L]CHMEN += "1"

    # Ajout salarié - A voir sur demande du portail - non disponible V1
    # If [V]GREP = "" : [L]CHMEN += "2" : Endif

    # Lancement de l'action TRTPREPAY
    If [V]GREP = "" & find([L]PPDSTA_ACCEPTE, [M:HRPPH1]STA) : [L]CHMEN += "3" : Endif

    Gosub ACTZO_MSK
Else
    If not find([L]REP, "C")
        Gosub GRIZO_MSK
    Endif
Endif
Return

$EXEBOUT
Case [L]BOUT
    When "s"
        # A modéliser pour soumission en masse ?
        Call SOUMISSION([M:HRPPH0]REQNUM) From TRTPPHSOU
        Gosub RELIT From GOBJSUB
Endcase
Return

$STATUT
Case [L]BOUT
    When "2"
        # Test ajout salarié
        # Call AJOUT_SALARIE([PPH0]REQNUM, "200900000383","MER00000012")
        # Gosub RELIT From GOBJSUB
Endcase
Return

$EXEACT
Return

#------------------------------------------------------------------------------------------------------
# RAZCRE : Ou comment ouvrir une petite boite "avant" la saisie effective, mouvementer les écrans en
#          fonction et interrompre la création si on ne fait pas "OK" sur la petite boite
#------------------------------------------------------------------------------------------------------
$RAZCRE

[L]S_REQNUM = [M:HRPPH0]REQNUM

Raz [L]NBCTR, [L]TREFNUM, [L]TCTRNUM, [L]TCTRDAT

# => ACTION TRTPPHNOU : Nouvelle demande prépaie
Local Char WPARMSK(250)(1..dim([M:HRPPH1]REFNUM)+20) , WSAVACT(20), WVALEUR(250)
[L]WSAVACT = [V]GACTION : [V]GACTION = "TRTPPHNOU"

Call SAISIE_CHAR([L]WVALEUR, [L]WPARMSK, "TRTPPHNOU", "TRTPPHNOU", "XYTRTPPHNOU") From GSAISIE
[V]GACTION = [L]SAVACT

If [L]WVALEUR = "OK"

    # Pour l'instant affectation en direct, évolution prévue vers un PARMSK du type "NOMZONE=VALEUR"
    [M:HRPPH9]PVHCOD = [L]WPARMSK(1)
    [M:HRPPH9]CRICPY = [L]WPARMSK(2)
    [M:HRPPH9]CRIFCY = [L]WPARMSK(3)
    [M:HRPPH9]CRISRV = [L]WPARMSK(4)
    [M:HRPPH9]CRIPOP = [L]WPARMSK(5)
    [M:HRPPH9]CRIPRF = [L]WPARMSK(6)

    [M:HRPPH9]ALLCPY = max(1, val(mid$([L]WPARMSK(9), 1, 1)) )
    [M:HRPPH9]ALLFCY = max(1, val(mid$([L]WPARMSK(9), 2, 1)) )
    [M:HRPPH9]ALLSRV = max(1, val(mid$([L]WPARMSK(9), 3, 1)) )
    [M:HRPPH9]ALLPRF = max(1, val(mid$([L]WPARMSK(9), 4, 1)) )

    [M:HRPPH0]DES = [L]WPARMSK(10)
    [M:HRPPH0]MGR = [L]WPARMSK(11)

    If [L]WPARMSK(12) <> ""
        [M:HRPPH0]DEMDAT = [L]WPARMSK(12)
    Endif
    If [L]WPARMSK(13) <> ""
        [M:HRPPH0]APLDAT = [L]WPARMSK(13)
    Endif
    ##**82073
    If [L]WPARMSK(14) <> ""
        [M:HRPPH0]APLSTR = [L]WPARMSK(14)
    Endif

    If [L]WPARMSK(15) <> ""
      GCURLEG = [L]WPARMSK(15)
    Endif

    # Si on récupère des valeurs à partir de l'indice debut contrat, c'est une série de variable
    # sous la forme REFNUM~CTRNUM~CTRDAT

    If [L]WPARMSK([L]INDICE_DEBUT_SALARIE) <> ""
        Raz [L]NBCTR, [L]TREFNUM, [L]TCTRNUM, [L]TCTRDAT
        For [L]I = [L]INDICE_DEBUT_SALARIE To dim([L]WPARMSK)
            If [L]WPARMSK([L]I) = "" : Break : Endif
            Call SPLIT([L]WPARMSK([L]I), [L]TREFNUM([L]NBCTR), [L]TCTRNUM([L]NBCTR), [L]TCTRDAT([L]NBCTR))
            [L]NBCTR += 1
        Next
    Endif

    Affzo [M:HRPPH0]
    Affzo [M:HRPPH9]

    Gosub CHARGE_PPH

    Affzo [M:HRPPH0]
    Affzo [M:HRPPH1]

    zonsui = "[M:HRPPH1]NBLIG"

    If [M:HRPPH1]NBLIG = 0
        # mess(15,150,1) : Sélection vide
        Call MESSAGE(mess(15, 150, 1)) From GESECRAN
        [L]REP = "" : [V]GREP = ""
        Gosub GRIZO_MSK
    Else
        Call CL_PREVRA([L]VOIDCHAR)
        Call CL_PRESAL([L]VOIDCHAR)
        Call CL_PREGRV([L]VOIDCHAR)

        Call LECTCA(15,STAT) From SUBTCA
        If !STAT
          [L]WMANCOU = 2
        Else
          [L]WMANCOU= [F:TCA]MANCOU(7)
        Endif

        If [L]WMANCOU <> 2
            # Si pas de compteur manuel, on grise !
            Grizo [M:HRPPH0]REQNUM
        Endif
    Endif
Else
    # On efface le contenu de REP, la création ne peut se poursuivre
    [L]REP = "" : [V]GREP = ""
    Gosub GRIZO_MSK
Endif

Kill [L]WVALEUR, [L]WPARMSK, [L]WSAVACT

Return

#-------------------------------------------------------------------------------------------------
# RAZDUP : Passage en duplication , on l'autorise (à voir) et donc on réinitialise les notions de
#          demande et les IDPPD
#-------------------------------------------------------------------------------------------------
$RAZDUP
[M:HRPPH0]REQSTA = 1    : # Brouillon
Affzo [M:HRPPH0]
Raz [M:HRPPH1]IDPPD, [M:HRPPH1]BUL
For [L]I = 0 To [M:HRPPH1]NBLIG - 1
    [M:HRPPH1]STA([L]I) = [L]PPDSTA_BROUILLON
    Call COHERENCE([M:HRPPH1]IDLIG([L]I))
Next
Call AFFMSK("", "1234")
Return

#---------------------------------------------------------------------------------------------------------
# GRIZO_MSK : Grisage général
#             On gère par rang sur les masques tableaux car le tableau a déjà ses cellules grisées ou non
#---------------------------------------------------------------------------------------------------------
$GRIZO_MSK
Raz [M:HRPPH0]
Raz [M:HRPPH1]
Raz [M:HRPPH2]
Raz [M:HRPPH3]
Raz [M:HRPPH4]
Raz [M:HRPPH9]
Grizo [M:HRPPH0]
Grizo [M:HRPPH1] 5
Grizo [M:HRPPH2] 5
Grizo [M:HRPPH3] 5
Grizo [M:HRPPH4] 5
Grizo [M:HRPPH9]
Actzo [M:HRPPH0]REQNUM
Return

#---------------------------------
# ACTZO_MSK : Activation générale
#---------------------------------
$ACTZO_MSK
Actzo [M:HRPPH0]
Actzo [M:HRPPH1] 5
Actzo [M:HRPPH2] 5
Actzo [M:HRPPH3] 5
Actzo [M:HRPPH4] 5
Actzo [M:HRPPH9]
Return

#---------
# ABANDON
#---------
$ABANDON
If find([L]REP, "C", "D")
    Gosub GRIZO_MSK
Endif
Return

#----------------------------------------------------------------
# INICRE : Initialisation création - Attribution N° de bordereau
#----------------------------------------------------------------
$INICRE
If [M:HRPPH0]REQNUM = ""
    # On va prendre le site du "manager" en saisie ... on prends le site de son dernier contrat "valide"
    # si pas de contrat, on passe sur le site intial de la fiche ID

    # (C) PROSPER 23/09/10 - Demande Badredine 22/09/10
    #                        Subtilité dans le cas du multi contrat, on choisit le contrat faisant
    #                        apparaître la notion de site maitre (cf éléctions prudhommales).
    #                        dubitatif sur la façon de le faire cependant (table EMPLOELC à mettre
    #                        dans la boucle ...)
    #                        On récupère en complément une zone de la fiche salarié contenant ses
    #                        initiales.

    Raz [L]WFCY, [L]WDAT, [L]WCOMPLEMENT, [L]WREQNUM
    Read [F:ID]ID0 = [M:HRPPH0]MGR
    If fstat <> 0 : Raz [F:ID] : Endif

    [L]WDAT = [M:HRPPH0]DEMDAT

    [L]WFCY = func SUBHRPPH.GET_FCYMGR([M:HRPPH0]MGR, [L]WDAT)

    If [L]WFCY = "" & dim([F:ID]FCYORI) > 0
        If fstat = 0
            [L]WFCY = [F:ID]FCYORI
        Endif
    Endif

    If dim([F:ID]NCKNAM) > 0
        [L]WCOMPLEMENT = [F:ID]NCKNAM
    Endif

    If WFCY<>""
      Call LECTURE("FCY",WFCY,"") From CONTOBJ
      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
      GSOCIETE=[F:CPY]CPY
      If GNBLEG = 1
        GCURLEG = GDOSLEG
      Else
        If dim([F:CPY]LEG)>0
          GCURLEG =[F:CPY]LEG
        Endif
      Endif
    Endif

    [F:HRPPH]LEG = GCURLEG

    Call LECTCA(15,STAT) From SUBTCA
    If !STAT
      GMESSAGE = mess(12,114,1) : # Compteur inexistant
      GOK = 0 : Return
    Else
      [L]WCODNUM= [F:TCA]CODNUM(7)
    Endif

    Call NUMERO([L]WCODNUM, [L]WFCY, [L]WDAT, [L]WCOMPLEMENT, [L]WREQNUM, [L]STAT) From SUBANM
    If not [L]STAT
        [F:HRPPH]REQNUM = [L]WREQNUM
        [M:HRPPH0]REQNUM = [F:HRPPH]REQNUM
    Else
        [V]GMESSAGE = mess(4,10702,1)-[L]WCODNUM    : # Erreur sur compteur
        [V]GOK = 0 : Return
    Endif
Endif
# Pour des contraintes de workflow avec des circuits hiérarchiques "par site", on stocke le
# site de rattachement du manager
If dim([F:HRPPH]FCYMGR) > 0
    [F:HRPPH]FCYMGR = func SUBHRPPH.GET_FCYMGR([F:HRPPH]MGR, [F:HRPPH]DEMDAT)
Endif
Return

$INIMOD
# Pour des contraintes de workflow avec des circuits hiérarchiques "par site", on stocke le
# site de rattachement du manager
If dim([F:HRPPH]FCYMGR) > 0
    [F:HRPPH]FCYMGR = func SUBHRPPH.GET_FCYMGR([F:HRPPH]MGR, [F:HRPPH]DEMDAT)
Endif
Return

#----------
# CREATION
#----------
$CREATION
Gosub WRITE_PPD
If [V]GOK < 1 : Return : Endif
Return


#--------------------------------------
# WRITE_PPD : Ecriture du tableau HRPPH1
#--------------------------------------
$WRITE_PPD

If dim(CRITPPD) < 0
 Local Char CRITPPD (250)
Endif

# Can be already filled when called by the portal
If GWEBSERV
 CRITPPD -= '& [F:HRPPD]REQNUM ="'+[M:HRPPH0]REQNUM+'"'
Else
 CRITPPD  = '[F:HRPPD]REQNUM ="'+[M:HRPPH0]REQNUM+'"'
Endif

# Réinitialisation des codes opérations pour le workflow
#SBA test pour statut correct
#Update [F:HRPPD] Where evalue(CRITPPD)
#&                & [F:HRPPD]WRK > ""
#&                With [F:HRPPD]WRK = ""
Update [F:HRPPD] Where evalue(CRITPPD)
&                & [F:HRPPD]WRK = "s"
&                With [F:HRPPD]WRK = "S"
Update [F:HRPPD] Where evalue(CRITPPD)
&                & [F:HRPPD]WRK = "M"
&                With [F:HRPPD]WRK = "m"

For [F:HRPPD]PPD0 Where [F:HRPPD]REQNUM = [M:HRPPH0]REQNUM
    nolign = find([F:HRPPD]IDPPD, [M:HRPPH1]IDPPD(0..[M:HRPPH1]NBLIG-1))
    If nolign > 0
        If [F:HRPPD]DEMAMT = [M:HRPPH1]DEMAMT(nolign-1)
            If([M:HRPPH1]DEMAMT(nolign-1)>0 and [M:HRPPH1]STA(nolign-1)=4 and [F:HRPPD]VRACMT<>[M:HRPPH1]VRACMT(nolign-1))
               [F:HRPPD]WRK = "M"
               [F:HRPPD]STA = 3
               [M:HRPPH1]STA(nolign-1)=3
               [F:HRPPD]CHRONO = ""
            Endif
            # Montant identique, seule cette info est considérée comme une modification
            # pour le workflow
        Else
            # Montant différent, cela entraine une "modification" au sens workflow
            # SBA test
            If([F:HRPPD]CHRONO<>"")
               [F:HRPPD]WRK = "M"
            Else
              [F:HRPPD]WRK = "s"
            Endif
            #[F:HRPPD]WRK = "M"
            # SBA test fin
            [F:HRPPD]CHRONO = ""
        Endif
        [F:HRPPD] = [M:HRPPH0]
        [F:HRPPD] = [M:HRPPH9]
        [F:HRPPD] = [M:HRPPH1]
#        [F:PPD]NUMLIG = nolign
        If dim(GNUM_LIG)<0
         [F:HRPPD]NUMLIG = nolign
        Else
         # numérotation pour le portail
         GNUM_LIG +=1
         [F:HRPPD]NUMLIG = GNUM_LIG
        Endif
        #75686 no coment if no amount
        If [F:HRPPD]DEMAMT=0
          Raz [F:HRPPD]VRACMT
        Endif
        #end 75686
        Rewrite [F:HRPPD]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("HRPPD") From GLOCK
            Break
        Endif
    Else
        # Ligne supprimée ? - Pas possible pour l'instant
    Endif
Next
If [V]GOK < 1 : Return : Endif

# Pour toutes les lignes du tableau qui n'ont pas été enregistrées (IDPPD=0)
For nolign = 1 To [M:HRPPH1]NBLIG
    If [M:HRPPH1]IDPPD(nolign-1) = 0
        Raz [F:HRPPD]
        [F:HRPPD] = [M:HRPPH0]
        [F:HRPPD] = [M:HRPPH9]
        [F:HRPPD] = [M:HRPPH1]
        If dim(GNUM_LIG)<0
         [F:HRPPD]NUMLIG = nolign
        Else
         # numérotation pour le portail
         GNUM_LIG +=1
         [F:HRPPD]NUMLIG = GNUM_LIG
        Endif
        # Gestion d'un identifiant "unique" si non présent (nouvelle ligne)
        [F:HRPPD]IDPPD = uniqid([HRPPD])
        Case [M:HRPPH0]REQSTA
            When 1
                [F:HRPPD]STA = 1
            When 2
                # Ajout sur un bordereau soumis - à voir si on l'autorise
                # impossible pour l'instant, tableau sans append.
                If [M:HRPPH1]DEMAMT(nolign-1) = 0
                        [F:HRPPD]STA = [L]PDDSTA_INACTIF
                Else
                    #64648
                    #If [M:PPH1]FLGVAL(nolign-1) = 2
                    If [M:HRPPH1]FLGAPP(nolign-1) = 2
                        [F:HRPPD]STA = [L]PPDSTA_DEMANDE
                    Else
                        [F:HRPPD]STA = [L]PPDSTA_ACCEPTE
                        [F:HRPPD]ACPAMT = [F:HRPPD]DEMAMT
                    Endif
                Endif
            When 3
                # Impossible, le bordereau n'est plus modifiable
                [F:HRPPD]STA = [L]PPDSTA_PRISENCOMPTE
                [F:HRPPD]BUL = "*** PANIC ***"
        Endcase
        [F:HRPPD]WRK = "C"
        [F:HRPPD]CHRONO = ""
        #75686 no coment if no amount
        If [F:HRPPD]DEMAMT=0
          Raz [F:HRPPD]VRACMT
        Endif
        #end 75686
        Write [F:HRPPD]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("HRPPD") From GLOCK
            Break
        Endif
    Endif
Next
If [V]GOK < 1 : Return : Endif

Return

#-----------
# APRES_CRE
#-----------
$APRES_CRE
Gosub RELIT From GOBJSUB
Return

#--------
# LIENS
#--------
$LIENS
Raz [M:HRPPH1], [M:HRPPH2], [M:HRPPH3], [M:HRPPH4], nolign

#If clalev([F:PVH1]) = 0 : Local File PPVRALISH [PVH1] : Endif
#Read [F:PVH1]PVH0 = [M:HRPPH9]PVHCOD
#If fstat = 0
#  GCURLEG = [F:PVH1]LEG
#Endif

GCURLEG = [F:HRPPH]LEG

For [F:HRPPD]PPD0 Where [F:HRPPD]REQNUM = [M:HRPPH0]REQNUM
    If nolign >= dim([M:HRPPH1]REFNUM)
        # mess(26,100,1) : Tableau plein
        Call ERREUR(mess(26, 100, 1)) From GESECRAN
        Break
    Endif
    nolign += 1
    [M:HRPPH1] = [F:HRPPD]
    # Récupération des "paramètres" associés à cette variable dans cette liste - Le non stockage
    # est voulu pour qu'une modification de paramétrage se propage automatiquement dans une demande
    # existante (et modifiable)
    Call GET_PVD([M:HRPPH9]PVHCOD, [F:HRPPD]VRACOD, nolign)

    If dim([M:HRPPH1]IDLIG) > 0
        [M:HRPPH1]IDLIG(nolign-1) = func SUBHRPPH.IDLIG([F:HRPPD]REFNUM, [F:HRPPD]CTRNUM, [F:HRPPD]CTRDAT, [F:HRPPD]VRACOD) :##**82073
    Endif

Next

[M:HRPPH1]NBLIG = nolign

Call SET_PYRDAT([M:HRPPH0]APLDAT) From TRTPPHNOU

# affzo [M:PPH1]

# Sur demande DBA - Précharger les onglets complémentaires
Call CL_PREVRA([L]VOIDCHAR)
Call CL_PRESAL([L]VOIDCHAR)
Call CL_PREGRV([L]VOIDCHAR)

Return

#-----------
# MODIF
#-----------
$MODIF
Gosub WRITE_PPD
If [V]GOK < 1 : Return : Endif
Return

#-----------
# APRES_MOD
#-----------
$APRES_MOD
Gosub RELIT From GOBJSUB
Return

$ANNULE
Gosub DELETE_PPD_OLD
Return

$VERIF_CRE
Gosub VERIFICATION
Return

$VERIF_MOD
Gosub VERIFICATION
Return

$VERIFICATION
# Contrôle si toutes les variables pour lesquelles ont a un commentaire obligatoire sont servies ...

# mess(174,10702,1) : Commentaire obligatoire
# mess(190,10702,1) : onglet éléments
[L]MESSAGE = mess(174, 10702, 1) - mess(190, 10702, 1)

Raz [L]I, [L]J

For [L]I = 0 To [M:HRPPH1]NBLIG - 1
    If [M:HRPPH1]DEMAMT([L]I) <> 0 & [M:HRPPH1]FLGCMTOBG([L]I) = 2 & vireblc([M:HRPPH1]VRACMT([L]I), 4) = ""
        [L]MESSAGE += "\"
        # mess(189,10702,1) : ligne
        [L]MESSAGE += mess(189, 10702, 1) - num$([L]I+1)
        [L]J += 1
        If [L]J >= 7
            Break
        Endif
    Endif
Next
If [L]J > 0
    Call ERREUR([L]MESSAGE) From GESECRAN
    [L]OK = 0
Endif

Return

#---------------------------------------------------------------------------------------------
# DELETE_PPD : Effacement des lignes de demandes (mode de fonctionnement EFFACEMENT/CREATION)
#---------------------------------------------------------------------------------------------
$DELETE_PPD_OLD
# A revoir => cas des "suppression" de ligne que l'on devrait détecter pour du workflow ?
Delete [F:HRPPD] Where [F:HRPPD]REQNUM = [M:HRPPH0]REQNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("HRPPD") From GLOCK
    Return
Endif
# FQ66191 - MABON 15/11/10 - Quand on supprime un bordereau, il faut mettre à jour l'inscription s'y référant
# pour permettre à nouveau de lancer l'arrêté de formation
If clalev([F:INS])=0 : Local File INSCRIPT [INS] : Endif
Filter [F:INS] Where REQNUMSTT=[M:HRPPH0]REQNUM
For [F:INS]
  [F:INS]TRFTPS=1
  [F:INS]REQNUMSTT=""
  Rewrite [F:INS]
Next
Filter [F:INS] Where REQNUMHTT=[M:HRPPH0]REQNUM
For [F:INS]
  [F:INS]TRFREQ=1
  [F:INS]REQNUMHTT=""
  Rewrite [F:INS]
Next
Filter [F:INS]

#WAITING expenses module
# FQ66382 - MABON 23/05/11 - Quand on supprime un bordereau, il faut mettre à jour la note de frais s'y référant
# pour permettre à nouveau de lancer l'arrêté de notes de frais
#
#
#LIPET - 2017-06-14 - START
If clalev([F:HREXS])=0 : Local File HREXPENSES [HREXS] : Endif
Filter [F:HREXS] Where REQNUM=[M:HRPPH0]REQNUM
For [F:HREXS]
  [F:HREXS]TRFREQ=1
  [F:HREXS]REQNUM=""
  Rewrite [F:HREXS]
Next
Filter [F:HREXS]
#LIPET - 2017-06-14 - END
#

# FQ66382 - MABON 23/05/11 - Quand on supprime un bordereau, il faut mettre à jour la participation s'y référant
# pour permettre à nouveau de lancer l'arrêté de participation
If clalev([F:PAI])=0 : Local File PARIND [PAI] : Endif
Filter [F:PAI] Where REQNUM=[M:HRPPH0]REQNUM
For [F:PAI]
  [F:PAI]TRFREQ=1
  [F:PAI]REQNUM=""
  Rewrite [F:PAI]
Next
Filter [F:PAI]
Return

#--------------------------------------------------------------------------
# CHARGE_PPH : Chargement d'un tableau "vierge" SALARIE-CONTRAT / VARIABLE
#--------------------------------------------------------------------------
$CHARGE_PPH

Read [F:PVH]PVH0 = GCURLEG;[M:HRPPH9]PVHCOD
If fstat = 0

#JOJAC - 2016-06-14 - REQ114309 US122 - START
 If GWEBSERV<>1
#JOJAC - 2016-06-14 - REQ114309 US122 - END
    Call TEMPON("") From GESECRAN
#JOJAC - 2016-06-14 - REQ114309 US122 - START
 Endif
#JOJAC - 2016-06-14 - REQ114309 US122 - END
#LIPET - 2017-06-14 - START
If !(dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "HRPPH" & [L]NBCTR <> 0)
 Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY
Endif
#LIPET - 2017-06-14 - END
    If [L]NBCTR = 0
##**82073
        Call GET_CTRLIST([M:HRPPH0]MGR, [L]TTYPMGR,
&                        [M:HRPPH9]CRICPY, [M:HRPPH9]CRIFCY, [M:HRPPH9]CRISRV, [M:HRPPH9]CRIPOP, [M:HRPPH9]CRIPRF, [M:HRPPH0]APLSTR, [M:HRPPH0]APLDAT,
&                        [L]TREFNUM, [L]TCTRNUM, [L]TCTRDAT, [L]NBCTR) From TRTPREPAY
    Endif

    [L]J = [M:HRPPH1]NBLIG : [L]J -= 1 : Raz [L]NBMAX_PPDVAR

    Filter [F:HRPVD] Where [F:HRPVD]PVHCOD = [F:PVH]PVHCOD
    [L]NBMAX_PPDVAR = rowcount([F:HRPVD])

    # On met de coté le nombre de variables à prendre en compte
    # Pour arrêter le chargement par bloc de salarié "entier" (évolution ...)

    For [L]I = 0 To [L]NBCTR - 1
        # Pour un couple TREFNUM / TCTRNUM
        [L]REFNUM = [L]TREFNUM([L]I) : [L]CTRNUM = [L]TCTRNUM([L]I) : [L]CTRDAT = [L]TCTRDAT([L]I)

        If [L]I > 0 & ([L]J + [L]NBMAX_PPDVAR) >= dim([M:HRPPH1]REFNUM) - 1
            # mess(26,100,1) : Tableau plein
            Call ERREUR(mess(26, 100, 1)) From GESECRAN
            Break
        Endif

        Read [F:ID]ID0 = [L]REFNUM

        Read [F:HRCTR]CTR0 = [L]REFNUM ; [L]CTRNUM ; [L]CTRDAT
        If fstat = 0
#JOJAC - 2016-06-14 - REQ114309 US122 - START
          #         Lecture dans PVD ne sont pas nécessaire si on vient du portail
          If dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "PPH"
            For W_I=1 To G_NBPVD
              If G_WVRACOD(W_I) <> "" & func DIVPPH.IS_AUTHVAR(G_WVRACOD(W_I)) = 1
                    [L]J += 1
                    [M:HRPPH1]REFNUM([L]J) = [L]REFNUM
                    [M:HRPPH1]CTRNUM([L]J) = [L]CTRNUM
                    [M:HRPPH1]CTRDAT([L]J) = [L]CTRDAT    :##**82073
                    [M:HRPPH1]VRACOD([L]J) = G_WVRACOD(W_I)
                    [M:HRPPH1]FLGAPP([L]J) = G_WFLGAPP(W_I)
                    [M:HRPPH1]FLGCMTOBG([L]J) = G_WFLGCMTOBG(W_I)
                    [M:HRPPH1]VRAROW([L]J) = G_WVRAROW(W_I)
                    [M:HRPPH1]VRAGRP([L]J) = G_WVRAGRP(W_I)
                    [M:HRPPH1]IDLIG([L]J) = func SUBPPH.IDLIG([L]REFNUM, [L]CTRNUM, [L]CTRDAT, G_WVRACOD(W_I))    :##**82073
              Endif
             Next
          Else
#JOJAC - 2016-06-14 - REQ114309 US122 - END
            For [F:HRPVD]PVD2 Where [F:HRPVD]PVHCOD = [F:PVH]PVHCOD

                If func DIVPPH.IS_AUTHVAR([F:HRPVD]VRACOD, GCURLEG) = 1

                    [L]J += 1

                    [M:HRPPH1]REFNUM([L]J) = [L]REFNUM
                    [M:HRPPH1]CTRNUM([L]J) = [L]CTRNUM
                    [M:HRPPH1]CTRDAT([L]J) = [L]CTRDAT    :##**82073
                    [M:HRPPH1]VRACOD([L]J) = [F:HRPVD]VRACOD

                    Call GET_PVD([M:HRPPH9]PVHCOD, [F:HRPVD]VRACOD, [L]J+1)

                    [M:HRPPH1]IDLIG([L]J) = func SUBHRPPH.IDLIG([L]REFNUM, [L]CTRNUM, [L]CTRDAT, [F:HRPVD]VRACOD) :##**82073

                Endif

            Next
#JOJAC - 2016-06-14 - REQ114309 US122 - START
        Endif
#JOJAC - 2016-06-14 - REQ114309 US122 - START
     Endif
    Next

    [M:HRPPH1]NBLIG = [L]J+1

    Filter [F:HRPVD]

    Call TEMPOFF From GESECRAN

    Call SET_PYRDAT([M:HRPPH0]APLDAT) From TRTPPHNOU
Endif

Return

#------------------------------------------------------------------------------------------
# GET_PVD : Mouvemente une ligne de saisie du tableau avec les valeurs HRPVD correspondantes
#------------------------------------------------------------------------------------------
Subprog GET_PVD(PVHCOD, VRACOD, LIGNE)
Value Char PVHCOD(), VRACOD()
Value Integer LIGNE
Local Integer S_NOLIGN
Read [F:HRPVD]PVD1(2) = [L]PVHCOD ; [L]VRACOD
If fstat = 0
    [L]S_NOLIGN = nolign
    nolign = [L]LIGNE
    [M:HRPPH1] = [F:HRPVD]

    # Cas particulier du chargement du groupe par le thème

    If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
        Read [F:VRA]VRA0 = GCURLEG;[L]VRACOD
        [M:HRPPH1]VRAGRP([L]LIGNE-1) = [F:VRA]VRATHM
    Endif

    nolign = [L]S_NOLIGN
Else
    # Cette variable n'est pas dans la liste, normalement impossible.
    # Cependant on peut imaginer une évolution de saisie "sans liste", ou avec une
    # liste sans variable ...
    # Choix de gestion , on décide arbitraitement que la variable doit être
    # controlée, saisie du commentaire obligatoire
    [M:HRPPH1]FLGCMTOBG([L]LIGNE-1) = 2
    [M:HRPPH1]FLGAPP([L]LIGNE-1) = 2
Endif

End

#--------------------------------------------
# IDLIG : Fabrication d'une idlig normalisée
#--------------------------------------------
##**82073
Funprog IDLIG(REFNUM, CTRNUM, CTRDAT, VRACOD)
Value Char REFNUM(), CTRNUM()
Value Date CTRDAT
Value Char VRACOD()

Local Char IDLIG(80)
[L]IDLIG = [L]REFNUM + "~" + [L]CTRNUM + "~" + format$(GFMDAT4,[L]CTRDAT)+ "~" + [L]VRACOD
End [L]IDLIG

#----------------------------------------------------------------------------------------
# GET_LSTCHR : Fabrication d'une dernier chrono normalisé (uniqid ou autre chose)
#              Utilisé dans le workflow pour tagger les éléments qui vont ensemble
#----------------------------------------------------------------------------------------
Funprog GET_LSTCHR()
Local Char LSTCHR(250)
Local File PPREQUESTH [WHRPPH]
[L]LSTCHR = num$(uniqid([WHRPPH]))
Close Local File [WHRPPH]
End [L]LSTCHR

#-------------------------------------------------------------------------------------
# ISVALIDATEUR : Détermine qui est validateur d'un manager - Abandonné pour l'instant
#-------------------------------------------------------------------------------------
Funprog ISVALIDATEUR(USR, MGR)
Value Char USR(), MGR()
Local Integer ISVALIDATEUR
End [L]ISVALIDATEUR


#-------------------------------------- ECRAN -----------------------------------

$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

$SETMSK
Local Char MSK(10), NOMVAR(250)
# Dans la mesure ou nom du masque = abréviation on pourrait se contenter du raccourci
# [L]MSK = "[M:"+maskcou+"]"
# Mais on ne sait jamais !
Case maskcou
    When "HRPPH0"
        [L]MSK = "[M:HRPPH0]"
    When "HRPPH1"
        [L]MSK = "[M:HRPPH1]"
    When "HRPPH2"
        [L]MSK = "[M:HRPPH2]"
    When "HRPPH3"
        [L]MSK = "[M:HRPPH3]"
    When "HRPPH4"
        [L]MSK = "[M:HRPPH4]"
    When "HRPPH9"
        [L]MSK = "[M:HRPPH9]"
    When Default
        [L]MSK = "[M]"
Endcase
Return

$SETFLX
Local Char FLUX_METIER([V]GLONFJH)
If dim([V]GFLXPREPAI) > 0 & [V]GFLXPREPAI <> ""
    [L]FLUX_METIER = [V]GFLXPREPAI
Else
    [L]FLUX_METIER = "PREPAI"
Endif
Return

