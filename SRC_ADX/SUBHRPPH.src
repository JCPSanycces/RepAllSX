Subprog AV_NAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL : Gosub SETMSK
Local Char REFNUM([V]GLONEML)
[L]REFNUM = evalue([L]MSK + "REFNUM([L]NOL)")
[L]VALEUR = func SUBHRPPH.GET_NAM([L]REFNUM, 3)
End

Subprog AS_ACPAMT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL : Gosub SETMSK : Gosub SETFLX
Local Integer TTYPMGR(len(mess(0,50,1))), TTYPOFR(len(mess(0,50,1)))

# Pour pouvoir modifier le montant accepté, il faut
# - Que la variable demande une validation (sinon, le montant demandé est directement accepté)
# - Que l'utilisateur dispose de tous les droits (cas des responsables rh)
# - Ou que l'utilisateur soit "manager" du "manager" qui a saisi le bordereau ou responsable
#   "validateur" ( OFR => Officer ) du manager

If not instr(1, [V]GUSRAUZ, "A")
    Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY
    If not func TRTPREPAY.ISCHEF([V]GREFNUM, [L]TTYPMGR, [M:HRPPH0]MGR, "", [M:HRPPH0]APLDAT, "1234")
        # Déjà, il est pas manager du manager ...
        Call GET_TTYPOFR([L]TTYPOFR) From TRTPREPAY
        If not func TRTPREPAY.ISCHEF([V]GREFNUM, [L]TTYPOFR, [M:HRPPH0]MGR, "", [M:HRPPH0]APLDAT, "1234")
            # Et il n'est pas officer du manager ...
            mkstat = 2
        Endif
    Endif
Else
    # Il a tous les droits
Endif
End

Subprog AS_VRACMT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL : Gosub SETMSK
If evalue([L]MSK + "DEMAMT([L]NOL)") = 0 : Raz [L]VALEUR : mkstat = 2 : End : Endif
End

Subprog C_VRACMT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL : Gosub SETMSK

If [L]VALEUR = "" & evalue([L]MSK+"FLGCMTOBG([L]NOL)") = 2
    # mess(174,10702,1) : Commentaire obligatoire
    [V]GMESSAGE = mess(174, 10702, 1)
    mkstat = 2
Endif

End

Subprog AS_STA(VALEUR)
Variable Integer  VALEUR
Local Integer TTYPMGR(len(mess(0,50,1))), TTYPOFR(len(mess(0,50,1)))

Gosub SETNOL : Gosub SETMSK : Gosub SETFLX
Gosub GET_PPDSTA From TRTPREPAY

If [M:HRPPH0]REQSTA = 1 : [L]VALEUR = [L]PPDSTA_BROUILLON : mkstat = 2 : End : Endif
If evalue([L]MSK+"DEMAMT([L]NOL)") = 0 : [L]VALEUR = [L]PPDSTA_INACTIF : mkstat = 2 : End : Endif

# Pour pouvoir acceder à la zone, il faut
# - Que la variable demande une validation (sinon, le montant demandé est directement accepté)
# - Que l'utilisateur dispose de tous les droits (cas des responsables rh)
# - Ou que l'utilisateur soit "manager" du "manager" qui a saisi le bordereau ou responsable
#   "validateur" ( OFR => Officer ) du manager
If evalue([L]MSK+"FLGAPP([L]NOL)") <> 2 : mkstat = 2 : End : Endif

If not instr(1, [V]GUSRAUZ, "A")
    Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY
    If not func TRTPREPAY.ISCHEF([V]GREFNUM, [L]TTYPMGR, [M:HRPPH0]MGR, "", [M:HRPPH0]APLDAT, "1234")
        # Déjà, il est pas manager du manager ...
        Call GET_TTYPOFR([L]TTYPOFR) From TRTPREPAY
        If not func TRTPREPAY.ISCHEF([V]GREFNUM, [L]TTYPOFR, [M:HRPPH0]MGR, "", [M:HRPPH0]APLDAT, "1234")
            # Et il n'est pas officer du manager ...
            mkstat = 2 : End
        Endif
    Endif
Else
    # Il a tous les droits
Endif

# Suppression de certains choix
[V]GMENLOC([L]PPDSTA_BROUILLON) = 1
[V]GMENLOC([L]PPDSTA_INACTIF) = 1
[V]GMENLOC([L]PPDSTA_PRISENCOMPTE) = 1

End

Subprog C_STA(VALEUR)
Variable Integer VALEUR
End

Subprog APRES_NBLIG
Call COHERENCE([M:HRPPH1]IDLIG(nolign-1))
Call AFFMSK([M:HRPPH1]IDLIG(nolign-1), "234")
End

# -------------------------------- ECRAN HRPPH2 - Saisie par variable -------------------------

Subprog CL_PREVRA(VALEUR)
Variable Char    VALEUR()
Call PRENEXVRA(-1)
End

Subprog CL_NEXVRA(VALEUR)
Variable Char    VALEUR()
Call PRENEXVRA(1)
End

Subprog S_SELVRA(VALEUR)
Variable Char    VALEUR()

Local Integer VRANB, I, MAXLIG, CHOI
[L]MAXLIG = dim([M:HRPPH1]VRACOD)

Local Char TVRACOD([V]GLONVRA)(1..[L]MAXLIG)
Local Char TVRADES(30)(1..[L]MAXLIG)
Local Char TVRALIS(250)(1..[L]MAXLIG,1..2), TIT(GLONDES)(0..2)

Call GET_VRALIS([M:HRPPH9]PVHCOD, [L]TVRACOD, [L]TVRADES, [L]VRANB, 1) : # Récupère la liste
                                                                       # Le dernier chiffre = tri ...
# Remise en forme pour faire une fenêtre de sélection multi colonne

For [L]I = 1 To [L]VRANB
    [L]TVRALIS([L]I, 1) = [L]TVRACOD([L]I)
    [L]TVRALIS([L]I, 2) = [L]TVRADES([L]I)

    If [L]VALEUR = [L]TVRACOD([L]I)
        [L]CHOI = [L]I
    Endif
Next

# Intitulé des colonnes de la fenêtre de sélection - On a choisi de créer tous les intitulés
#                                                    histoire de les conserver ensemble, sans volonté
#                                                    de réutiliser des textes existants.
# mess(175,10702,1) : Sélection d'une variable
# mess(176,10702,1) : Code variable
# mess(177,10702,1) : Intitulé

[L]TIT(0) = mess(175,10702,1)
[L]TIT(1) = mess(176,10702,1)
[L]TIT(2) = mess(177,10702,1)

Call SAITEX([L]VRANB, [L]TVRALIS, [L]CHOI, [L]TIT) From GESECRAN
If status <> 7 & [L]CHOI <> 0
    [L]VALEUR = [L]TVRALIS([L]CHOI, 1)
Endif

End

Subprog AM_SELVRA(VALEUR)
Variable Char    VALEUR()
Call LOAD_PPH2([L]VALEUR)    : # Chargement de l'écran
End

Subprog AV_DESVRA(VALEUR)
Variable Char    VALEUR()
If [M:HRPPH2]SELVRA <> ""
    #Read [F:VRA]VRA0 = [M:HRPPH2]SELVRA;GCURLEG
    #If fstat = 0 : [L]VALEUR = [F:VRA]DES : Endif
   Call LECTEXTRA(VALEUR,"VARIA","DES",GCURLEG,[M:HRPPH2]SELVRA) From ATEXTRA
Endif
End

Subprog C_NBLIGVRA
Call CTRL_VARBASTAB
End

Subprog APRES_NBLIGVRA
Call MAJ_PPH1_FROM_PPH2(nolign-1)
Call AFFMSK([M:HRPPH2]IDLIG(nolign-1), "134")
End

Subprog AV_NBLIGVRA
If [V]GPPHAFFMSK = 1
    Affzo [M:HRPPH2]TOTVRA
Endif
End

# ------------------------------ Sous programmes de l'écran HRPPH2 -----------------

#-------------------------------------------------------------------------------------------------
# PRENEXVRA : Previous / next vra - récupération de la variable précédente suivante dans la liste
#-------------------------------------------------------------------------------------------------
Subprog PRENEXVRA(SENS)
Value Integer SENS
Local Char TVRACOD([V]GLONVRA)(1..dim([M:HRPPH1]VRACOD))
Local Char TVRADES(30)(1..dim([M:HRPPH1]VRACOD))
Local Integer VRANB, I
Call GET_VRALIS([M:HRPPH9]PVHCOD, [L]TVRACOD, [L]TVRADES, [L]VRANB, 1) : # Récupère la liste
                                                                       # Le dernier chiffre = tri ...
[L]I = find([M:HRPPH2]SELVRA, [L]TVRACOD(1..[L]VRANB))
If [L]I > 0
    [L]I += [L]SENS
    If [L]I < 1 : [L]I = 1 : Endif
    If [L]I > [L]VRANB : [L]I = [L]VRANB : Endif
Else
    If [L]SENS = 1
        [L]I = [L]VRANB
    Else
        [L]I = 1
    Endif
Endif
[M:HRPPH2]SELVRA = [L]TVRACOD([L]I)
Call AM_SELVRA([M:HRPPH2]SELVRA)
End

#----------------------------------------------------------------------
# GET_VRALIS : Renvoie une liste de variable pour un code liste PVHCOD
#----------------------------------------------------------------------
Subprog GET_VRALIS(PVHCOD, TVRACOD, TVRADES, VRANB, MODE)
Value Char PVHCOD()
Variable Char TVRACOD()(1..), TVRADES()(1..)
Variable Integer VRANB
Value Integer MODE

If clalev([F:HRPVD]) = 0 : Local File PPVRALISD [HRPVD] : Endif
If clalev([F:VRA]) = 0 : Local File VARIA     [VRA] : Endif

Local Integer VRANB

Link [HRPVD] With
&        [VRA]VRA0 = [F:HRPVD]VRACOD;GCURLEG
&        As [WLNK]
&        Where [F:HRPVD]PVHCOD = [L]PVHCOD

Case [L]MODE
    When 0
        Filter [F:WLNK] Order By Key PVD0
    When 1
        Filter [F:WLNK] Order By Key PVD1
    When 2
        Filter [F:WLNK] Order By Key PVD2
    When Default
        Filter [F:WLNK] Order By Key PVD0
Endcase

Raz [L]VRANB, [L]TVRACOD, [L]TVRADES

For [F:WLNK]
    [L]VRANB += 1
    [L]TVRACOD([L]VRANB) = [F:HRPVD]VRACOD
    #[L]TVRADES([L]VRANB) = [F:VRA]DES
    Call LECTEXTRA([L]TVRADES([L]VRANB),"VARIA","DES",GCURLEG,[F:HRPVD]VRACOD) From ATEXTRA
Next

Close Local File [WLNK]

End

#----------------------------------------------------
# LOAD_PPH2 : Chargement des données pour une VRACOD
#----------------------------------------------------
Subprog LOAD_PPH2(VRACOD)
Value Char VRACOD()
Local Integer LIG_ORIGINE, LIG_DESTINATION

Raz [M:HRPPH2], [L]LIG_DESTINATION

[M:HRPPH2]SELVRA = [L]VRACOD

For [L]LIG_ORIGINE = 0 To [M:HRPPH1]NBLIG - 1
    If [M:HRPPH1]VRACOD([L]LIG_ORIGINE) = [L]VRACOD
        Call TRANSFERE("HRPPH1", "HRPPH2", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
        [L]LIG_DESTINATION += 1
    Endif
Next

[M:HRPPH2]NBLIGVRA = [L]LIG_DESTINATION

[V]GPE = 0
GPOINT = "LOAD_PPH2" : Gosub ENTREE From EXEFNC

Affzo [M:HRPPH2]

End

#----------------------------------------------------------------------------------------
# MAJ_PPH1_FROM_PPH2 : Sauvegarde des infos d'une ligne HRPPH2 vers HRPPH1 - Ecran référence
#----------------------------------------------------------------------------------------
Subprog MAJ_PPH1_FROM_PPH2(NOL)
Value Integer NOL

Local Integer LIG_ORIGINE, LIG_DESTINATION
Local Char VAR_ORIGINE(250), VAR_DESTINATION(250), ZONE(20)

[L]LIG_ORIGINE = [L]NOL
[L]LIG_DESTINATION = find([M:HRPPH2]IDLIG([L]LIG_ORIGINE), [M:HRPPH1]IDLIG)
[L]LIG_DESTINATION -= 1
If [L]LIG_DESTINATION >= 0
    Call TRANSFERE("HRPPH2", "HRPPH1", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
    Call COHERENCE([M:HRPPH2]IDLIG([L]LIG_ORIGINE))
Endif

End

# -------------------------------------- Ecran HRPPH3 - Saisie par matricule -----------------------

Subprog CL_PRESAL(VALEUR)
Variable Char    VALEUR()
Call PRENEXSAL(-1)
End

Subprog CL_NEXSAL(VALEUR)
Variable Char    VALEUR()
Call PRENEXSAL(1)
End

Subprog S_SELREFNUM(VALEUR)
