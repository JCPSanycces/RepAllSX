Subprog AS_DEMAMT(VALEUR)
Variable Decimal VALEUR
End

#--------------------------------------------------------------------------------------
# AM_DEMAMT : Modification du montant demandé => changement du flag d'état de la ligne
#--------------------------------------------------------------------------------------
Subprog AM_DEMAMT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

[L]NOMVAR = [L]MSK + "STA([L]NOL)"

If [M:HRPPH0]REQSTA = 1
    Assign [L]NOMVAR With [L]PPDSTA_BROUILLON
Else
    If [L]VALEUR = 0
        Assign [L]NOMVAR With [L]PPDSTA_INACTIF
        End
    Endif

    If evalue([L]MSK+"FLGAPP([L]NOL)") = 2
        Assign [L]NOMVAR With [L]PPDSTA_DEMANDE
    Else
        Assign [L]NOMVAR With [L]PPDSTA_ACCEPTE
        [L]NOMVAR = [L]MSK + "ACPAMT([L]NOL)"
        Assign [L]NOMVAR With [L]VALEUR
    Endif
Endif

Case [L]MSK
    When "[M:HRPPH3]"
        [M:HRPPH3]DEMAMT([L]NOL) = [L]VALEUR
        If [V]GPPHAFFMSK
        Affzo [M:HRPPH3]TOTVRA
        Endif
    When "[M:HRPPH2]"
        [M:HRPPH2]DEMAMT([L]NOL) = [L]VALEUR
        If [V]GPPHAFFMSK
        Affzo [M:HRPPH2]TOTVRA
        Endif
Endcase

End

#--------------------------------------------------------------------------------------------
# B3_DEMAMT : Recopie vers le bas d'une valeur
#             Appel depuis HRPPH1, HRPPH2
#             HRPPH3 : pas de recopie vers le bas, on traite toutes les variables d'un salarié
#             HRPPH4 : saisie croisée, traité par un B3_GRVDEMAMT
#--------------------------------------------------------------------------------------------
Subprog B3_DEMAMT(VALEUR)
Variable Decimal VALEUR

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

Local Integer I, S_NOL

[L]S_NOL = [L]NOL

Case [L]MSK
    When "[M:HRPPH1]"
        For [L]NOL = [L]S_NOL+1 To [M:HRPPH1]NBLIG - 1
            If [M:HRPPH1]VRACOD([L]NOL) = [M:HRPPH1]VRACOD([L]S_NOL)
&                & [M:HRPPH1]STA([L]NOL) < [L]PPDSTA_PRISENCOMPTE
                nolign = [L]NOL + 1
                [M:HRPPH1]DEMAMT([L]NOL) = [L]VALEUR
                Call AM_DEMAMT([M:HRPPH1]DEMAMT([L]NOL))
                [V]GPPHAFFMSK = 0                        : # Désactivation des affichages
                Call APRES_NBLIG
                [V]GPPHAFFMSK = 1
            Endif
        Next
    When "[M:HRPPH2]"
        For [L]NOL = [L]S_NOL+1 To [M:HRPPH2]NBLIGVRA - 1
            If [M:HRPPH2]VRACOD([L]NOL) = [M:HRPPH2]VRACOD([L]S_NOL)
&                & [M:HRPPH2]STA([L]NOL) < [L]PPDSTA_PRISENCOMPTE
                nolign = [L]NOL + 1
                [M:HRPPH2]DEMAMT([L]NOL) = [L]VALEUR
                Call AM_DEMAMT([M:HRPPH2]DEMAMT([L]NOL))
                [V]GPPHAFFMSK = 0
                Call APRES_NBLIGVRA
                [V]GPPHAFFMSK = 1
            Endif
        Next
Endcase
nolign = [L]S_NOL + 1
Call AFFMSK("", "1234")                                : # Affichage général
End

#--------------------------------------------------------------------------------------------
# B3_DEMAMT : Recopie vers le bas d'une commentaire
#             Appel depuis HRPPH1, HRPPH2
#             HRPPH3 : pas de recopie vers le bas, on traite toutes les variables d'un salarié
#             HRPPH4 : A VOIR ---- saisie croisée, traité par un B3_GRVDEMAMT
#--------------------------------------------------------------------------------------------
Subprog B3_VRACMT(VALEUR)
Variable Char VALEUR()

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

Local Integer I, S_NOL

[L]S_NOL = [L]NOL

Case [L]MSK
    When "[M:HRPPH1]"
        For [L]NOL = [L]S_NOL+1 To [M:HRPPH1]NBLIG - 1
            If [M:HRPPH1]VRACOD([L]NOL) = [M:HRPPH1]VRACOD([L]S_NOL)
&                & [M:HRPPH1]STA([L]NOL) < [L]PPDSTA_PRISENCOMPTE
&                & [M:HRPPH1]DEMAMT([L]NOL) <> 0
                nolign = [L]NOL + 1
                [M:HRPPH1]VRACMT([L]NOL) = [L]VALEUR
                # Call AM_VRACMT([M:PPH1]VRACMT([L]NOL))
                [V]GPPHAFFMSK = 0                        : # Désactivation des affichages
                Call APRES_NBLIG
                [V]GPPHAFFMSK = 1
            Endif
        Next
    When "[M:HRPPH2]"
        For [L]NOL = [L]S_NOL+1 To [M:HRPPH2]NBLIGVRA - 1
            If [M:HRPPH2]VRACOD([L]NOL) = [M:HRPPH2]VRACOD([L]S_NOL)
&                & [M:HRPPH2]STA([L]NOL) < [L]PPDSTA_PRISENCOMPTE
&                & [M:HRPPH2]DEMAMT([L]NOL) <> 0
                nolign = [L]NOL + 1
                [M:HRPPH2]VRACMT([L]NOL) = [L]VALEUR
                # Call AM_VRACMT([M:PPH2]VRACMT([L]NOL))
                [V]GPPHAFFMSK = 0
                Call APRES_NBLIGVRA
                [V]GPPHAFFMSK = 1
            Endif
        Next
Endcase
nolign = [L]S_NOL + 1
Call AFFMSK("", "1234")                                : # Affichage général
End

