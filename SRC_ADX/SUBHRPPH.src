Subprog B4_GRVDEMAMT(VALEUR, NUM)
Variable Decimal VALEUR
Value Integer NUM

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

Local Integer S_NOL
Local Char VOIDCHAR(250)

[L]S_NOL = [L]NOL

For [L]NOL = [L]S_NOL+1 To [M:HRPPH4]NBLIGGRV - 1
    If evalue("[M:HRPPH4]GRVSTA"+num$([L]NUM)+"([L]NOL)") < [L]PPDSTA_PRISENCOMPTE
&        & evalue("[M:HRPPH4]GRVDEMAMT" + num$([L]NUM) + "([L]NOL)") <> 0
        nolign = [L]NOL + 1
        [L]NOMVAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]NOL)"
        [L]VOIDCHAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]S_NOL)"
        Assign [L]NOMVAR With evalue([L]VOIDCHAR)

        [V]GPPHAFFMSK = 0
        Call APRES_NBLIGGRV
        [V]GPPHAFFMSK = 1

    Endif
Next

nolign = [L]S_NOL + 1

Call AFFMSK("", "1234")

End

Subprog C_NBLIGGRV
End

Subprog APRES_NBLIGGRV
Call MAJ_PPH1_FROM_PPH4(nolign-1)
Call AFFMSK("", "123")
End

# --------------------------- Sous programme de l'écran HRPPH4 --------------------------------------

#----------------------------------------
# LOAD_PPH4 : Chargement de l'écran HRPPH4
#----------------------------------------
Subprog LOAD_PPH4(SELGRV)
Value Char SELGRV()
Local Integer I, J, NBVRA, MAXVRA
# NBCOLSAISIECROISEETAG
[L]MAXVRA = 15                    : # On pourrait le déduire en cherchant la plus grande GRVVRACODxx
                                    # mais tant qu'on sera obligé de faire un Titcol sans nombre de
                                    # colonne variable on sera de toute facon obligé de toucher au code

Local Char TGRVVRACOD([V]GLONVRA)(1..[L]MAXVRA)
Local Integer TGRVVRAROW(1..[L]MAXVRA)
Local Char NOMVAR(250), INTITULE(250)

Local Char TREFNUM([V]GLONEML)(1..dim([M:HRPPH1]REFNUM))
Local Char TCTRNUM([V]GLONHRCTR)(1..dim([M:HRPPH1]CTRNUM))
Local Char TSALID([V]GLONEML+1+[V]GLONHRCTR)(1..dim([M:HRPPH1]REFNUM))
Local Char TSALDES(60)(1..dim([M:HRPPH1]REFNUM))
Local Integer SALNB

Local Char REFNUM([V]GLONEML), CTRNUM([V]GLONHRCTR), VRACOD([V]GLONVRA)
Local Date CTRDAT     :##**82073

Raz [M:HRPPH4]
Gosub RAZ_TITCOL

[M:HRPPH4]SELGRV = [L]SELGRV

# Récupérer les variables du groupe SELGRV , dans l'ordre des rangs

For [L]I = 0 To [M:HRPPH1]NBLIG-1
    If [M:HRPPH1]VRAGRP([L]I) = [L]SELGRV
        If not find([M:HRPPH1]VRACOD([L]I), [L]TGRVVRACOD)
            [L]NBVRA += 1
            [L]TGRVVRACOD([L]NBVRA) = [M:HRPPH1]VRACOD([L]I)
            [L]TGRVVRAROW([L]NBVRA) = [M:HRPPH1]VRAROW([L]I)
        Endif
    Endif
Next

If [L]NBVRA > 0

    #72004 : Tableau avec indice démarrant à 1 et non à 0...
    #Sorta [L]NBVRA [L]TGRVVRACOD, [L]TGRVVRAROW Order By [L]TGRVVRAROW(indice), [L]TGRVVRACOD(indice)
    Sorta [L]NBVRA [L]TGRVVRACOD, [L]TGRVVRAROW Order By [L]TGRVVRAROW(indice+1), [L]TGRVVRACOD(indice+1)


    # Affecter les variables aux colonnes (titcol)

    For [L]I = 1 To [L]NBVRA
        [L]NOMVAR = "[M:HRPPH4]GRVVRACOD"+num$([L]I)
        Assign [L]NOMVAR With [L]TGRVVRACOD([L]I)

        # Récupération de l'intitulé de la colonne
        Read [F:VRA]VRA0 = GCURLEG;[L]TGRVVRACOD([L]I)
        If fstat <> 0 : Raz [F:VRA] : Endif
        Read [F:HRPVD]PVD1(2) = [M:HRPPH9]PVHCOD ; [L]TGRVVRACOD([L]I)
        If fstat <> 0 : Raz [F:HRPVD] : Endif

        Raz [L]INTITULE

        If [F:HRPVD]CROINPDES <> ""
            [L]INTITULE = "[F:HRPVD]CROINPDES"
        Else
            [L]INTITULE = "[F:VRA]COD"
        Endif

        [L]NOMVAR = "[M:HRPPH4]GRVVRADES"+num$([L]I)


        Assign [L]NOMVAR With evalue([L]INTITULE)

    Next

    # Malheureusement le titcol ne semble pas vouloir traiter de variables multidimensionnées

     # Titcol [M:PPH4]NBLIGGRV "Salarié", "Contrat", "Nom", [L]TGRVVRACOD

    Gosub SET_TITCOL

    # Récupérer la liste des salariés / contrat
#JOJAC - 2016-08-02 - X3PEOP-918 - START
#    Call GET_SALLIS([M:HRPPH4]REFNUM, [M:HRPPH4]CTRNUM,
#&                    [L]TSALID, [L]TSALDES, [L]SALNB, 1)
    Call GET_SALLIS([M:HRPPH4]REFNUM, [M:HRPPH4]CTRNUM,[M:HRPPH4]CTRDAT,
&                    [L]TSALID, [L]TSALDES, [L]SALNB, 1)
#JOJAC - 2016-08-02 - X3PEOP-918 - END

    [M:HRPPH4]NBLIGGRV = [L]SALNB

    # Affecter à chaque petite case l'identifiant ligne pointant vers HRPPH1

    For [L]I = 0 To [M:HRPPH4]NBLIGGRV - 1
        #ADNGO - 2017-07-14 - X3-47002 - START
        #[L]REFNUM = [M:HRPPH4]REFNUM([L]I) : [L]CTRNUM = [M:HRPPH4]CTRNUM([L]I)
        [L]REFNUM = [M:HRPPH4]REFNUM([L]I) : [L]CTRNUM = [M:HRPPH4]CTRNUM([L]I) : : [L]CTRDAT = [M:HRPPH4]CTRDAT([L]I)
        #ADNGO - 2017-07-14 - X3-47002 - END
        For [L]J = 1 To [L]NBVRA
            [L]VRACOD = evalue("[M:HRPPH4]GRVVRACOD" + num$([L]J))
            [L]NOMVAR = "[M:HRPPH4]GRVIDLIG" + num$([L]J) + "([L]I)"
            Assign [L]NOMVAR With func SUBHRPPH.IDLIG([L]REFNUM, [L]CTRNUM, [L]CTRDAT, [L]VRACOD)    :##**82073

            # Récupérer pour chaque croisement la valeur de la variable (+ les infos nécessaires)

            Call TRANSPOSE("HRPPH1", "HRPPH4", evalue([L]NOMVAR), [L]NBVRA)

        Next

    Next

    [M:HRPPH4]NBVRA = [L]NBVRA

    [V]GPE = 0
    GPOINT = "LOAD_PPH4" : Gosub ENTREE From EXEFNC

Endif

Affzo [M:HRPPH4]

End

#-----------------------------------------------------------------------------------------
# MAJ_PPH1_FROM_PPH4 : Sauvegarde des infos d'une ligne HRPPH4 vers HRPPH1 - Ecran référence
#-----------------------------------------------------------------------------------------
Subprog MAJ_PPH1_FROM_PPH4(NOL)
Value Integer NOL

Local Integer LIG_ORIGINE, CASE_ORIGINE
Local Char IDLIG(250)

[L]LIG_ORIGINE = [L]NOL

For [L]CASE_ORIGINE = 1 To [M:HRPPH4]NBVRA
    [L]IDLIG = evalue("[M:HRPPH4]GRVIDLIG"+num$([L]CASE_ORIGINE)+"([L]LIG_ORIGINE)")
    Call TRANSPOSE("HRPPH4", "HRPPH1", [L]IDLIG, [M:HRPPH4]NBVRA)
    Call COHERENCE([L]IDLIG)
Next

Call AFFMSK("", "123")

End

#-------------------------------------------------------------------------------------------------
# PRENEXGRV : Previous / next groupe de variable
#-------------------------------------------------------------------------------------------------
Subprog PRENEXGRV(SENS)
Value Integer SENS
Local Char TGRV(10)(1..dim([M:HRPPH1]VRAGRP))
Local Char TGRVDES(30)(1..dim([M:HRPPH1]VRAGRP))
Local Integer GRVNB, I

If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
    Call GET_GRVLIS([M:HRPPH9]PVHCOD, [M:HRPPH1]VRACOD, [L]TGRV, [L]TGRVDES, [L]GRVNB, 1)
Else
    Call GET_GRVLIS([M:HRPPH9]PVHCOD, [M:HRPPH1]VRACOD, [L]TGRV, [L]TGRVDES, [L]GRVNB, 2)
Endif

[L]I = find([M:HRPPH4]SELGRV, [L]TGRV(1..[L]GRVNB))
If [L]I > 0
    [L]I += [L]SENS
    If [L]I < 1 : [L]I = 1 : Endif
    If [L]I > [L]GRVNB : [L]I = [L]GRVNB : Endif
Else
    If [L]SENS = 1
        [L]I = [L]GRVNB
    Else
        [L]I = 1
    Endif
Endif
[M:HRPPH4]SELGRV = [L]TGRV([L]I)
Call AM_SELGRV([M:HRPPH4]SELGRV)
End

#--------------------------------------------------------------------------------
# GET_GRVLIS : Renvoie une liste de groupe de variable pour un code liste PVHCOD
#--------------------------------------------------------------------------------
Subprog GET_GRVLIS(PVHCOD, TVRACOD, TGRV, TGRVDES, GRVNB, MODE)
Value Char PVHCOD(), TVRACOD()
Variable Char TGRV()(1..), TGRVDES()(1..)
Variable Integer GRVNB
Value Integer MODE

If clalev([F:HRPVD]) = 0 : Local File PPVRALISD [HRPVD] : Endif

Local Integer GRVNB, I, AJOUTER_GRV_VIDE, GRV_VIDE

Raz [L]GRVNB, [L]TGRV, [L]TGRVDES
[L]AJOUTER_GRV_VIDE = 2                : # Doit on ajouter les groupes vide (constante) ?
[L]GRV_VIDE = 1                        : # Présence d'un groupe vide ?

Case [L]MODE
    When 1
        For [L]I = 0 To dim([L]TVRACOD)-1
            If [L]TVRACOD([L]I) = "" : Break : Endif
            Read [F:VRA]VRA0 = GCURLEG;[L]TVRACOD([L]I)
            If fstat = 0
                If [F:VRA]VRATHM = ""
                    [L]GRV_VIDE = 2
                Endif
                If not find([F:VRA]VRATHM, [L]TGRV)
                    [L]GRVNB += 1
                    [L]TGRV([L]GRVNB) = [F:VRA]VRATHM
                    [L]TGRVDES([L]GRVNB) = func AFNC.TEXTRA("ATABDIV", "LNGDES", "10391", [F:VRA]VRATHM)
                Endif
            Endif
        Next
        If [L]AJOUTER_GRV_VIDE = 2 & [L]GRV_VIDE = 2
            [L]GRVNB += 1
            [L]TGRV([L]GRVNB) = ""
            # mess(187,10702,1) : Thème
            # mess(188,10702,1) : non défini
            [L]TGRVDES([L]GRVNB) = mess(187,10702,1) - mess(188,10702,1)
        Endif
    When 2
        For [F:HRPVD]PVD2(2) Where [F:HRPVD]PVHCOD = [L]PVHCOD
            If [F:HRPVD]VRAGRP <> ""
                [L]GRVNB += 1
                [L]TGRV([L]GRVNB) = [F:HRPVD]VRAGRP
                [L]TGRVDES([L]GRVNB) = func AFNC.TEXTRA("ATABDIV", "LNGDES", "10442", [F:HRPVD]VRAGRP)
            Else
                [L]GRV_VIDE = 2
            Endif
        Next

        If [L]AJOUTER_GRV_VIDE = 2 & [L]GRV_VIDE = 2
            [L]GRVNB += 1
            [L]TGRV([L]GRVNB) = ""
            # mess(183,10702,1) : Groupe
            # mess(188,10702,1) : non défini
            [L]TGRVDES([L]GRVNB) = mess(183,10702,1) - mess(188,10702,1)
        Endif
Endcase

End

#------------------------------ Sous programmes génériques ----------------------------------------

#-----------------------------------------------------
# TRANSFERE : Transfert d'une ligne vers une autre
#-----------------------------------------------------
Subprog TRANSFERE(MSK_ORIGINE, MSK_DESTINATION, LIG_ORIGINE, LIG_DESTINATION)
Value Char MSK_ORIGINE(), MSK_DESTINATION()
Value Integer LIG_ORIGINE, LIG_DESTINATION
Local Char ZONE(20), VAR_ORIGINE(250), VAR_DESTINATION(250)

# Pour l'instant on donne la liste des variables à transferer, évolution à faire vers une fabrication
# de la liste à la volée en fonction de l'écran

# (C) PROSPER 15/10/10 - Ajout zone BUL oubliée et qu'on veut voir sur les autres masques pour zoom
For [L]ZONE = "IDLIG", "REFNUM", "CTRNUM", "VRACOD", "DEMAMT", "VRACMT", "STA", "FLGAPP", "FLGCMTOBG",
&                "BUL", "CTRDAT"    :##**82073
    [L]VAR_ORIGINE = "[M:"+[L]MSK_ORIGINE+"]"+[L]ZONE+"("+num$([L]LIG_ORIGINE)+")"
    [L]VAR_DESTINATION = "[M:"+[L]MSK_DESTINATION+"]"+[L]ZONE+"("+num$([L]LIG_DESTINATION)+")"
    Assign [L]VAR_DESTINATION With evalue([L]VAR_ORIGINE)
Next
End

#--------------------------------------------------------------------
# COHERENCE : Remise en cohérence des données d'un écran depuis HRPPH1
#--------------------------------------------------------------------
Subprog COHERENCE(IDLIG)
Value Char IDLIG()

# L'écran HRPPH1 est l'écran maitre ; on va propager dans tous les autres écrans où apparaît l'IDLIG
# concernée le contenu de la ligne HRPPH1 en question

Local Integer LIG_ORIGINE, LIG_DESTINATION

[L]LIG_ORIGINE = find([L]IDLIG, [M:HRPPH1]IDLIG)
[L]LIG_ORIGINE -= 1
If [L]LIG_ORIGINE >= 0
    [L]LIG_DESTINATION = find([L]IDLIG, [M:HRPPH2]IDLIG)
    [L]LIG_DESTINATION -= 1
    If [L]LIG_DESTINATION >= 0
        Call TRANSFERE("HRPPH1", "HRPPH2", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
    Endif
    [L]LIG_DESTINATION = find([L]IDLIG, [M:HRPPH3]IDLIG)
    [L]LIG_DESTINATION -= 1
    If [L]LIG_DESTINATION >= 0
        Call TRANSFERE("HRPPH1", "HRPPH3", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
    Endif

    # Et pour bien faire, recherche dans les croisements de HRPPH4
    Call TRANSPOSE("HRPPH1", "HRPPH4", [L]IDLIG, [M:HRPPH4]NBVRA)
Endif
End

#-------------------------------------------------------------
# TRANSPOSE : Transfert d'élément avec mask de saisie croisée
#-------------------------------------------------------------
Subprog TRANSPOSE(MSK_ORIGINE, MSK_DESTINATION, IDLIG, NBVRA)
Value Char MSK_ORIGINE(), MSK_DESTINATION(), IDLIG()
Value Integer NBVRA

Local Integer LIG_ORIGINE, LIG_DESTINATION, NUMVRA, I, J
Local Char FORMULE(250), NOMVAR(250), ZONE(250)

If [L]MSK_ORIGINE = "HRPPH1"
    [L]LIG_ORIGINE = find([L]IDLIG, [M:HRPPH1]IDLIG)
    [L]LIG_ORIGINE -= 1

    If [L]LIG_ORIGINE < 0
        # Catastrophe, une ligne a sauté dans le tableau HRPPH1
        End
    Endif

    [L]LIG_DESTINATION = -1 : [L]NUMVRA = 0

    For [L]I = 1 To [L]NBVRA
        [L]FORMULE = "find([L]IDLIG, [M:HRPPH4]GRVIDLIG" + num$([L]I) + ")"
        [L]LIG_DESTINATION = evalue([L]FORMULE)
        [L]LIG_DESTINATION -= 1
        If [L]LIG_DESTINATION >= 0
            [L]NUMVRA = [L]I
            Break
        Endif
    Next

    If [L]LIG_DESTINATION >= 0 & [L]NUMVRA > 0
        For [L]ZONE = "DEMAMT", "ACPAMT", "STA", "FLGAPP", "VRACMT"
            [L]NOMVAR = "[M:HRPPH4]GRV" + [L]ZONE + num$([L]NUMVRA) + "(" + num$([L]LIG_DESTINATION) + ")"
            Assign [L]NOMVAR With evalue("[M:HRPPH1]" + [L]ZONE + "([L]LIG_ORIGINE)")
        Next
    Endif
Elsif [L]MSK_ORIGINE = "HRPPH4"
    # Récupération dans HRPPH1 des éléments croisés de HRPPH4

    [L]LIG_ORIGINE = -1 : [L]NUMVRA = 0

    For [L]I = 1 To [L]NBVRA
        [L]FORMULE = "find([L]IDLIG, [M:HRPPH4]GRVIDLIG" + num$([L]I) + ")"
        [L]LIG_ORIGINE = evalue([L]FORMULE)
        [L]LIG_ORIGINE -= 1
        If [L]LIG_ORIGINE >= 0
            [L]NUMVRA = [L]I
            Break
        Endif
    Next

    If [L]LIG_ORIGINE < 0 : End : Endif

    [L]LIG_DESTINATION = find([L]IDLIG, [M:HRPPH1]IDLIG)
    [L]LIG_DESTINATION -= 1

    If [L]LIG_DESTINATION >= 0 & [L]NUMVRA > 0
        For [L]ZONE = "DEMAMT", "ACPAMT", "STA", "FLGAPP", "VRACMT"
            [L]NOMVAR = "[M:HRPPH1]" + [L]ZONE + "(" + num$([L]LIG_DESTINATION) + ")"
            Assign [L]NOMVAR With evalue("[M:HRPPH4]GRV" + [L]ZONE + num$([L]NUMVRA) + "([L]LIG_ORIGINE)")
        Next
    Endif
Else
    # Appel improbable ....
Endif
End

