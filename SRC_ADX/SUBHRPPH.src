Subprog AM_GRVDEMAMT(VALEUR, NUM, OUVRIR_COMMENTAIRE)
Variable Decimal VALEUR
Value Integer NUM
Value Integer OUVRIR_COMMENTAIRE

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

[L]NOMVAR = [L]MSK + "GRVSTA" + num$([L]NUM) + "([L]NOL)"

If [M:HRPPH0]REQSTA = 1
    Assign [L]NOMVAR With [L]PPDSTA_BROUILLON
Else
    If [L]VALEUR = 0
    Assign [L]NOMVAR With [L]PPDSTA_INACTIF
        End
    Endif

    If evalue([L]MSK + "GRVFLGAPP" + num$([L]NUM) + "([L]NOL)") = 2
        Assign [L]NOMVAR With [L]PPDSTA_DEMANDE
    Else
        Assign [L]NOMVAR With [L]PPDSTA_ACCEPTE
        [L]NOMVAR = [L]MSK + "GRVACPAMT" + num$([L]NUM) + "([L]NOL)"
        Assign [L]NOMVAR With [L]VALEUR
    Endif
Endif

# Ouverture automatique des commentaires si FLGCMTOBG et commentaire vide et valeur DEMAMT <> 0
# => Ajout d'un flag pour permettre de squizzer cela en recopie vers le bas de la valeur.
If [L]VALEUR <> 0 & [L]OUVRIR_COMMENTAIRE = 2
    [L]NOMVAR = [L]MSK + "GRVIDLIG" + num$([L]NUM) + "([L]NOL)"
    If func SUBHRPPH.EVAL("FLGCMTOBG", evalue([L]NOMVAR)) = 2
        [L]NOMVAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]NOL)"
        If vireblc(evalue([L]NOMVAR),4) = ""
            Local Char    PARMSK(250)(1..20) , SAVACT(20)
            Local Char RETOUR(10)
            Repeat
                PARMSK(1) = evalue([L]NOMVAR)
                SAVACT = GACTION : GACTION = "TRTPPHCMT"
                Call SAISIE_CHAR([L]RETOUR, [L]PARMSK, "TRTPPHCMT", "TRTPPHCMT", "XYTRTPPHCMT") From GSAISIE
                GACTION = SAVACT
            Until [L]RETOUR = "OK" & vireblc([L]PARMSK(1), 4) <> ""
            If [L]RETOUR = "OK"
                Assign [L]NOMVAR With [L]PARMSK(1)
                # Call APRES_NBLIGGRV
            Endif
        Endif
    Endif
Endif

End

