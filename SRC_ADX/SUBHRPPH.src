#-----------------------------------------------------------------------------------------
# AFFMSK : Affichage du masque HRPPHx (1 à 4) en optimisation d'affichage avec un setmok
#          => au final le gain entre la version brute "affzo" y compris dans les boucles
#             et l'utilisation du setmok fait passer les temps de traitement sur une
#             recopie vers le bas de 2300ms à 50ms
#-----------------------------------------------------------------------------------------
Subprog AFFMSK(IDLIG, LISTE_AFFICHAGE)
Value Char IDLIG(), LISTE_AFFICHAGE()

#JOJAC - 2016-06-14 - REQ114309 US122 - START
If dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "PPH" : End : Endif
#JOJAC - 2016-06-14 - REQ114309 US122 - END

If [V]GPPHAFFMSK = 0 : End : Endif        : # Optimisation, on positionne un flag d'affichage
                                            # quand on traite en masse des éléments pour que
                                            # l'appel à un APRES_NBLIG ne fasse pas d'affichage
                                            # à chaque ligne ; on relancera un affichage général
                                            # après la boucle de traitement.

If instr(1, [L]LISTE_AFFICHAGE, "1")
    If [L]IDLIG = "" or find([L]IDLIG, [M:HRPPH1]IDLIG)    : # Optimisation, n'affiche que si l'IDLIG
                                                           # apparaît dans l'écran courant. Sur HRPPH1
                                                           # c'est toujours oui de toute facon.
        Setmok [M:HRPPH1] With 1
        Affzo [M:HRPPH1]
        Setmok [M:HRPPH1] With 0
    Endif
Endif

If instr(1, [L]LISTE_AFFICHAGE, "2")
    If [L]IDLIG = "" or find([L]IDLIG, [M:HRPPH2]IDLIG)
        Setmok [M:HRPPH2] With 1
        Affzo [M:HRPPH2]
        Setmok [M:HRPPH2] With 0
    Endif
Endif

If instr(1, [L]LISTE_AFFICHAGE, "3")
    If [L]IDLIG = "" or find([L]IDLIG, [M:HRPPH3]IDLIG)
        Setmok [M:HRPPH3] With 1
        Affzo [M:HRPPH3]
        Setmok [M:HRPPH3] With 0
    Endif
Endif

If instr(1, [L]LISTE_AFFICHAGE, "4")
    # NBCOLSAISIECROISEETAG
    If [L]IDLIG = "" or
&                    find([L]IDLIG, [M:HRPPH4]GRVIDLIG1, [M:HRPPH4]GRVIDLIG2, [M:HRPPH4]GRVIDLIG3,
&                        [M:HRPPH4]GRVIDLIG4, [M:HRPPH4]GRVIDLIG5, [M:HRPPH4]GRVIDLIG6,
&                        [M:HRPPH4]GRVIDLIG7, [M:HRPPH4]GRVIDLIG8, [M:HRPPH4]GRVIDLIG9,
&                        [M:HRPPH4]GRVIDLIG10, [M:HRPPH4]GRVIDLIG11, [M:HRPPH4]GRVIDLIG12,
&                        [M:HRPPH4]GRVIDLIG13, [M:HRPPH4]GRVIDLIG14, [M:HRPPH4]GRVIDLIG15 )

        Setmok [M:HRPPH4] With 1
        Affzo [M:HRPPH4]
        Setmok [M:HRPPH4] With 0
    Endif
Endif

End

#---------------------------------------------------------------
# EVAL : Renvoie la valeur d'une zone pour un IDLIG depuis HRPPH1
#---------------------------------------------------------------
Funprog EVAL(ZONE, IDLIG)
Value Char ZONE(), IDLIG()

Local Integer LIG_ORIGINE
[L]LIG_ORIGINE = find([L]IDLIG, [M:HRPPH1]IDLIG)
[L]LIG_ORIGINE -= 1
If [L]LIG_ORIGINE >= 0
    End evalue("[M:HRPPH1]"+[L]ZONE+"([L]LIG_ORIGINE)")
Endif
End

#-------------------------------------
# GET_NAM : Renvoie le nom / prénom
# MODE
#-------------------------------------
# 1 : Prénom
# 2 : Nom
# 3 : Prénom - Nom
# 4 : Nom - Prénom
#-------------------------------------
Funprog GET_NAM(REFNUM, MODE)
Value Char REFNUM()
Value Integer MODE
Local Char NOM(250) : Raz [L]NOM
If not clalev([F:ID]) : Local File EMPLOID [ID] : Endif
Read [F:ID]ID0 = [L]REFNUM
If fstat = 0
    Case [L]MODE
        When 1
            [L]NOM = [F:ID]SRN
        When 2
            [L]NOM = [F:ID]NAM
        When 3
            [L]NOM = [F:ID]SRN - [F:ID]NAM
        When 4
            [L]NOM = [F:ID]NAM - [F:ID]SRN
    Endcase
Endif
End [L]NOM

Subprog B3_ACPAMT(VALEUR)
Variable Decimal VALEUR
End


#------------------------------------- Gestion du workflow associé HRPPHxxx ------------------------

#------------------------------------------------------------------------------
# WRKRER : Reroutage
#          D'après ce que je comprends cela modifie le destinataire d'un suivi
#          ATTENTION à faire évoluer le VALCTXxx en fonction de la règle.
#------------------------------------------------------------------------------
Subprog WRKRER(CHRONO,ADEST)
Value    Char    CHRONO
Value    Char    ADEST

Update [F:AWS2] Where [F:AWS2]CHRONO = [L]CHRONO & [F:AWS2]DEST = [L]ADEST
&                With  VALCTX10 = [F:AWS2]DEST

End

Subprog WRKFINRER(CHRONO,ADEST)
Value    Char    CHRONO
Value    Char    ADEST

Update [F:AWS2] Where [F:AWS2]CHRONO = [L]CHRONO & [F:AWS2]DEST = [L]ADEST
&                With  VALCTX10 = ""

End


#------------------------------------------------------------------------------------
# WRKMES : Envoi d'un libellé en clair sur un code action workflow (zone WRK de PPD)
#------------------------------------------------------------------------------------
Funprog WRKMES(WRK)
Value Char WRK()

Local Char MESSAGE(250)
Local Integer POS

# mess(0,10643,1) : CMs => Raccourci code opération workflow
# C : Création / M : Modification / s : Soumission

Local Char W_STR(1)
Case WRK
  When "S": [L]W_STR="s"
  When "m": [L]W_STR="M"
  When Default : [L]W_STR=WRK
Endcase

#[L]POS = instr(1, mess(0,10643,1), [L]WRK)
[L]POS = instr(1, mess(0,10643, 1), [L]W_STR)
If [L]POS > 0
    [L]MESSAGE = mess([L]POS,10643,1)
Endif

# Moins élégant .....
# Case [F:PPD]WRK
#    When "C"
#        # Création => Ajout d'une demande sur un bordereau déjà soumis
#        [L]MESSAGE = "CREATION"
#     When "S"
#        # Suppression => non géré
#     When "M"
#        # Modification => Modification (montant) sur un bordereau déjà soumis
#        [L]MESSAGE = "MODIFICATION"
#     When "s"
#        # Soumission
#        [L]MESSAGE = "SOUMISSION"
# Endcase
End [L]MESSAGE

#---------------------------------------------------------------------------------------------
# WRKSIG : Signature via le workflow
#---------------------------------------------------------------------------------------------
# Fonction générique admettant un mode de signature en paramètre pour permettre de déterminer
# un niveau de détail en signature
#---------------------------------------------------------------------------------------------
# MODE
# G : GENERAL - Tout le bordereau REQNUM est traité (*)
# D : DETAIL - La ligne IDPPD est traitée ( sauf si pris en compte )
# V : VARIABLE - Toutes les variables VRACOD du bordereau REQNUM sont traitées (*)
# S : SALARIE - Toutes les variables du
# (*) : Filtre sur état des lignes, seules les lignes DEMANDE/REFUSE/ACCEPTE sont traitées
#---------------------------------------------------------------------------------------------
# EVT
# VIS : Passe à l'état PPDSTA_ACCEPTE
# REF : Passe à l'état PDDSTA_REFUSE
#---------------------------------------------------------------------------------------------
Subprog WRKSIG(EVT, MODE, REQNUM, NUMLIG, IDPPD, REFNUM, VRACOD, CHRONO)
Value Char EVT(), MODE(), REQNUM(), NUMLIG(), IDPPD(), REFNUM(), VRACOD(), CHRONO()

Local Integer WNUMLIG, WIDPPD
Local Integer TRANSACTION : [L]TRANSACTION = 1
Local Char SYMBOLE(35)

# Openo filpath("tmp","AAA-sig","fl"), 0 Using [PIPO]
# Iomode adxium GASCII Using [PIPO]
# Iomode adxifs chr$(9) Using [PIPO]
# Iomode adxirs chr$(10) Using [PIPO]

[L]WNUMLIG = val(vireblc([L]NUMLIG, 4))
[L]WIDPPD = val(vireblc([L]IDPPD, 4))

Local Char CRITERE(250)
Gosub GET_PPDSTA From TRTPREPAY

If clalev([F:HRPPD]) = 0 : Local File PPREQUESTD [HRPPD] : Endif

# Wrseq EVT, MODE, REQNUM, NUMLIG, IDPPD, REFNUM, VRACOD, CHRONO Using [PIPO]

Case [L]MODE
    When "G"
        # Général : on accepte toutes les saisies du bordereau
        [L]CRITERE = "[F:HRPPD]REQNUM = [L]REQNUM"
        [L]CRITERE -= "&"
        [L]CRITERE -= "find([F:HRPPD]STA, [L]PPDSTA_DEMANDE, [L]PPDSTA_REFUSE, [L]PPDSTA_ACCEPTE)"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]CHRONO = [L]CHRONO"

        # Wrseq CRITERE Using [PIPO]

    When "D"
        [L]CRITERE = "[F:HRPPD]IDPPD = [L]WIDPPD"
        [L]CRITERE -= "& [F:HRPPD]STA <> [L]PPDSTA_PRISENCOMPTE"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]CHRONO = [L]CHRONO"
    When "S"
        # Signature par salarié : on accepte toutes les saisies pour un salarié d'un bordereau
        [L]CRITERE = "[F:HRPPD]REQNUM = [L]REQNUM"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]REFNUM = [L]REFNUM"
        [L]CRITERE -= "&"
        [L]CRITERE -= "find([F:HRPPD]STA, [L]PPDSTA_DEMANDE, [L]PPDSTA_REFUSE, [L]PPDSTA_ACCEPTE)"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]CHRONO = [L]CHRONO"
    When "V"
        # Signature par variable : on accepte toutes les variables d'un bordereau
        [L]CRITERE = "[F:HRPPD]REQNUM = [L]REQNUM"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]VRACOD = [L]VRACOD"
        [L]CRITERE -= "&"
        [L]CRITERE -= "find([F:HRPPD]STA, [L]PPDSTA_DEMANDE, [L]PPDSTA_REFUSE, [L]PPDSTA_ACCEPTE)"
        [L]CRITERE -= "&"
        [L]CRITERE -= "[F:HRPPD]CHRONO = [L]CHRONO"
Endcase

If find([L]EVT, "VIS", "REF", "CMP")
    If adxlog <> 1
        # Pas de transaction en cours, on en démarre une
        Trbegin [HRPPD] : [V]GOK = 1 : [L]TRANSACTION = 2
    Else
        [L]TRANSACTION = 1
    Endif

    [L]SYMBOLE = "HRPPH" + [L]REQNUM
    Lock =[L]SYMBOLE
    If fstat = 1
        [V]GOK = -1 : [V]GLOCK = "%" + [L]SYMBOLE
    Elsif fstat = 0
        Case [L]EVT
            When "VIS"
                # Signature

                # Wrseq "avant update" Using [PIPO]

                Update [F:HRPPD] Where evalue([L]CRITERE)
&                               With [F:HRPPD]STA = [L]PPDSTA_ACCEPTE,
&                               [F:HRPPD]ACPAMT = [F:HRPPD]DEMAMT,
&                               [F:HRPPD]VRACMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,VRACMT)  : #75611
                # Wrseq "apres udpate fstat"-num$(fstat) Using [PIPO]

            When "REF"
                # Refuse
                Update [F:HRPPD] Where evalue([L]CRITERE)
&                               With [F:HRPPD]STA = [L]PPDSTA_REFUSE,
&                               [F:HRPPD]ACPAMT = 0,
&                               [F:HRPPD]VRACMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,VRACMT) : #75611
                # Evolution possible : remettre à zéro la zone chrono pour interdire une
                # seconde signature sur l'élément
                # & [F:PPD]CHRONO = ""
            When "CMP"
                # Demande de complement ... que faire ??? ... on bascule à refusé dans
                # l'attente d'une modification de la variable qui la repassera à demande ?
                Update [F:HRPPD] Where evalue([L]CRITERE)
&                               With [F:HRPPD]STA = [L]PPDSTA_REFUSE,
&                               [F:HRPPD]ACPAMT = 0,
&                               [F:HRPPD]VRACMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,VRACMT) : #75611
        Endcase

        If [V]GOK = 1 & fstat = 1
            [V]GOK = -1 : [V]GLOCK = "$PPREQUESTD"
        Elsif fstat <> 0
            [V]GOK = 0
            Call FSTA("HRPPD") From GLOCK
        Endif

        If [L]TRANSACTION = 2
            If [V]GOK = 1
                # Wrseq "commit" Using [PIPO]
                Commit
            Else
                Rollback
                # A voir si une gestion des verrous avec retry est utile sur ce type
                # d'opération ou si on laisse l'appelant nous réinvoquer.
            Endif
        Endif

        # Openo Using [PIPO]

    Endif
Endif

End

#---------------------------------------------------------
# WRKSET_LIG : Renvoi une ligne formatée pour le workflow
#---------------------------------------------------------
Funprog WRKSET_LIG(ID)
Value Char ID()
Local Char LIG(250)

Case [L]ID
    When "PPHVAR"
        #-------------------------------------
        # Format de la ligne : 146 caractères
        #-------------------------------------
        # 12           17                  15        30                           28                          7                      30
        # Statut       Période application Matricule Nom + Prénom                 Contrat                     Montant               Commentaire
        # ============ ======== =============== ==============================   ============================ ======= ==============================
        [L]LIG = format$("K:12X", func SUBHRPPH.WRKMES([F:HRPPD]WRK))
        [L]LIG += " "
        ##**82073
        [L]LIG += format$("D:DD[/]MM[/]YY", [F:HRPPD]APLSTR)-format$("D:DD[/]MM[/]YY", [F:HRPPD]APLDAT)
        [L]LIG += " "
        [L]LIG += format$("K:15X",[F:HRPPD]REFNUM)
        [L]LIG += " "
        [L]LIG += format$("K:"+num$(GLONCTR)+"X",[F:HRPPD]CTRNUM)
        [L]LIG += " "
        [L]LIG += format$("D:DD[/]MM[/]YY", [F:HRPPD]CTRDAT)
        [L]LIG += " "
        [L]LIG += format$("K:30X", func SUBHRPPH.GET_NAM([F:HRPPD]REFNUM, 3))
        [L]LIG += " "
        [L]LIG += format$("N:4.2#",[F:HRPPD]DEMAMT)
        [L]LIG += " "
        [L]LIG += format$("K:30X", [F:HRPPD]VRACMT)
Endcase
End [L]LIG

Funprog GETDETLINE(ID)
Value Char ID()
Local Char LIG(250)
Case [L]ID
    When "PPHVAR"
        #-------------------------------------
        # Format de la ligne : 146 caractères
        #-------------------------------------
        # 12           17                  15        30                           28                          7                      30
        # Statut       Période application Matricule Nom + Prénom                 Contrat                     Montant               Commentaire
        # ============ ======== =============== ==============================   ============================ ======= ==============================
        [L]LIG = format$("K:12X", func SUBPPH.WRKMES([F:PPD_]WRK))
        [L]LIG += " "
        ##**82073
        [L]LIG += format$("D:DD[/]MM[/]YY", [F:PPD_]APLSTR)-format$("D:DD[/]MM[/]YY", [F:PPD_]APLDAT)
        [L]LIG += " "
        [L]LIG += format$("K:"+num$(GLONMAT)+"X",[F:PPD_]REFNUM)
        [L]LIG += " "
        [L]LIG += format$("K:30X", func SUBPPH.GET_NAM([F:PPD_]REFNUM, 4))
        [L]LIG += " "
        [L]LIG += format$("K:"+num$(GLONCTR)+"X",[F:PPD_]CTRNUM)
        [L]LIG += " "
        [L]LIG += format$("D:DD[/]MM[/]YY", [F:PPD_]CTRDAT)
        [L]LIG += " "
        [L]LIG += format$("N:4.2#",[F:PPD_]DEMAMT)
        [L]LIG += " "
        [L]LIG += format$("K:30X", [F:PPD_]VRACMT)
Endcase
End [L]LIG

Funprog WRKSET_GETLIGS(ID,TYPLEC)
Value Char ID
Value Char TYPLEC

Local Clbfile RESULT

If clalev([F:PPD_]) = 0 : Local File PPREQUESTD  [PPD_] : Endif

If TYPLEC="CRE"
  Filter [F:PPD_] Where [F:PPD_]REQNUM=[F:PPD]REQNUM and [F:PPD_]CHRONO="~"+num$(-adxuid(2))
Else
  Filter [F:PPD_] Where [F:PPD_]REQNUM=[F:PPD]REQNUM and [F:PPD_]CHRONO=[F:AWS2]VALCTX6
Endif

For [F:PPD_]
[L]RESULT +=func GETDETLINE(ID)
[L]RESULT +=chr$(10)+chr$(13)
Next
End RESULT
#-----------------------------------------------------------------------------------------------
# PPHCHR : Flag des lignes PPD présentes sur un mail
#          => Utilisé à la signature pour ne bien
#             prendre en compte que celles sur le mail choisi
#             Du coup le "dernier" mail envoyé est le seul
#             faisant foi. Si on répond à un "ancien" mail,
#             le chrono ne va pas permettre de flagger les lignes PPD
# Subtilité du workflow "ligne" : Quand on traite une action avec
#                                 un déclenchement ligne on n'a pas encore le numéro CHRONO
#                                 de suivi workflow. On va donc marquer un certain nombre
#                                 de ligne pour repasser derriere en déclenchement fin workflow
#                                 afin de les affecter au bon chrono
#-----------------------------------------------------------------------------------------------
Subprog WRKCHR(MODE, REQNUM, CHRONO, UID)
Value Integer MODE
Value Char REQNUM(), CHRONO(), UID()

Local File PPREQUESTD [WPPD]

Local Integer WIDPPD
[L]WIDPPD = val(vireblc([L]UID, 4))

Case [L]MODE
    When 1
        # Marquage des lignes traitées avec un code bidon
        Update [F:WPPD] Where [F:WPPD]REQNUM = [L]REQNUM
&                        & [F:WPPD]IDPPD = [L]WIDPPD
&                        With [F:WPPD]CHRONO = [L]CHRONO
    When 2
        # Attribution du chrono aux lignes préalablements marquées
        Update [F:WPPD] Where [F:WPPD]REQNUM = [L]REQNUM
&                        & [F:WPPD]CHRONO = [L]UID
&                        With [F:WPPD]CHRONO = [L]CHRONO
Endcase

Close Local File [WPPD]

End

#------------------------------------------------------------------------------
# Griser le CTRNUM pour respecter le look & feel des mono / multicontrat
# => ATTENTION : la zone CTRNUM doit être saisissable pour que cela fonctionne
#------------------------------------------------------------------------------
Subprog GRISE_CTRNUM(NOL, MSK)
Value Integer NOL
Value Char MSK()
Local Char REFNUM([V]GLONEML)
If [V]GPPHAFFMSK = 0 : End : Endif
[L]REFNUM = evalue([L]MSK + "REFNUM([L]NOL)")
If [L]REFNUM <> ""
    If [L]REFNUM <> [F:ID]REFNUM
        Read [F:ID]ID0 = [L]REFNUM
    Endif
    If [F:ID]FLGMULCTR = 2
        Case [L]MSK
            When "[M:HRPPH1]"
                Diszo [M:HRPPH1]CTRNUM([L]NOL)
            When "[M:HRPPH2]"
                Diszo [M:HRPPH2]CTRNUM([L]NOL)
            When "[M:HRPPH3]"
                Diszo [M:HRPPH3]CTRNUM([L]NOL)
            When "[M:HRPPH4]"
                Diszo [M:HRPPH4]CTRNUM([L]NOL)
        Endcase
        # Pas d'erreur à la compil mais comportement étrange ...
        # Diszo =[L]MSK + "CTRNUM([L]NOL)"
    Else
        Case [L]MSK
            When "[M:HRPPH1]"
                Grizo [M:HRPPH1]CTRNUM([L]NOL)
            When "[M:HRPPH2]"
                Grizo [M:HRPPH2]CTRNUM([L]NOL)
            When "[M:HRPPH3]"
                Grizo [M:HRPPH3]CTRNUM([L]NOL)
            When "[M:HRPPH4]"
                Grizo [M:HRPPH4]CTRNUM([L]NOL)
        Endcase
        # Grizo =[L]MSK + "CTRNUM([L]NOL)"
    Endif
Endif
End

#--------------------------------------------------
# Non finalisé - test pour demande portail à venir
#--------------------------------------------------
Subprog AJOUT_SALARIE(REQNUM, REFNUM, CTRNUM)
Value Char REQNUM(), REFNUM(), CTRNUM()

Local File PPREQUESTH [WHRPPH], PPREQUESTD [WPPD], PPVRALISD [WPVD]

Local Integer NUMLIG, OK

Gosub GET_PPDSTA From TRTPREPAY

Call DEBTRANS From GLOCK

Repeat

    [V]GOK = 1 : [L]OK = 2
    Trbegin [WHRPPH], [WPPD]

    Readlock [F:WHRPPH]HRPPH0 = [L]REQNUM
    If fstat = 1
        [V]GOK = -1 : [V]GLOCK = "PPREQUESTH"
    Elsif fstat <> 0
        [V]GOK = 0
        Call RSTA("WHRPPH", [L]REQNUM) From GLOCK
    Endif

    If [V]GOK = 1
        Filter [F:WPPD] Where [F:WPPD]REQNUM = [F:WHRPPH]REQNUM
        Read [F:WPPD]PPD0 Last
        If fstat = 0
            [L]NUMLIG = [F:WPPD]NUMLIG
        Else
            [L]NUMLIG = 0
        Endif

        For [F:WPVD]PVD0 Where [F:WPVD]PVHCOD = [F:WHRPPH]PVHCOD
            Raz [F:WPPD]

            [L]NUMLIG += 1

            [F:WPPD] = [F:WHRPPH]

            [F:WPPD]REFNUM = [L]REFNUM
            [F:WPPD]CTRNUM = [L]CTRNUM
            [F:WPPD]VRACOD = [F:WPVD]VRACOD

            [F:WPPD]STA = [L]PPDSTA_INACTIF
            [F:WPPD]NUMLIG = [L]NUMLIG

            [F:WPPD]IDPPD = uniqid([WPPD])

            [F:WPPD]CREUSR = [V]GUSER
            [F:WPPD]CREDAT = date$

            Write [F:WPPD]
            If fstat <> 0
                [V]GOK = 0
                Call FSTA("WPPD") From GLOCK
                Break
            Endif
        Next

        Filter [F:WPPD]

    Endif
    If [V]GOK = 1
        Commit
    Else
        Rollback
        If [V]GOK = -1
            Call ROLL From GLOCK
            If not [V]GROLL : [L]OK = 1 : Endif
        Endif
    Endif
Until [L]OK = 2

Close Local File [WHRPPH], [WPPD], [WPVD]

End

Subprog AV_TOTVRA(VALEUR)
Variable Decimal  VALEUR
Gosub SETMSK
Case [L]MSK
    When "[M:HRPPH2]"
        [L]VALEUR = sum([M:HRPPH2]DEMAMT)
    When "[M:HRPPH3]"
        [L]VALEUR = sum([M:HRPPH3]DEMAMT)
Endcase
End

Subprog AV_NBLIGSAL
If [V]GPPHAFFMSK = 1
    Affzo [M:HRPPH3]TOTVRA
Endif
End

Subprog SPLIT(CHAINE, REFNUM, CTRNUM, CTRDAT)
Value Char CHAINE()
Variable Char REFNUM(), CTRNUM()
Variable Date CTRDAT

Local Integer POS
Raz [L]REFNUM, [L]CTRNUM, [L]CTRDAT

[L]POS = instr(1, [L]CHAINE, "~")
If [L]POS > 0
    [L]REFNUM = mid$([L]CHAINE, 1, [L]POS-1)
    [L]CHAINE = right$([L]CHAINE, [L]POS+1)
    [L]POS = instr(1, [L]CHAINE, "~")
    If [L]POS > 0
        [L]CTRNUM = mid$([L]CHAINE, 1, [L]POS-1)
        [L]CTRDAT = right$([L]CHAINE, [L]POS+1)
    Endif
Endif

End

Funprog GET_FCYMGR(REFNUM, DAT)
Value Char REFNUM()
Value Date DAT

Local Char WFCY([V]GLONFCY)
Local File EMPLOCTR [WCTR], EMPLOELC [WELC]

Raz [L]WFCY

Link [F:WCTR] With
&    [F:WELC]ELC0 = [F:WCTR]REFNUM ; [F:WCTR]ETRFCY
&    As [WLNK]
&    Where [F:WCTR]REFNUM = [L]REFNUM
&        & [F:WCTR]CTRDAT <= [L]DAT
&        Order By Key CLE = [F:WCTR]REFNUM ; [F:WCTR]CTRDAT

Read [F:WLNK] Last
If fstat <= 2
    [L]WFCY = [F:WCTR]ETRFCY
Endif
Filter [F:WLNK]

Close Local File [WLNK], [WCTR], [WELC]

End [L]WFCY
