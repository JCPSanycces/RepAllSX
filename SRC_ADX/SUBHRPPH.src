Subprog AM_DEMDAT(VALEUR)
Variable Date    VALEUR
##**82073
If [L]VALEUR > [M:HRPPH0]APLDAT & !GWEBSERV
    GMESSAGE = mess(199,126,1)-'"'+mess(164,10701,1)+'"' : # Valeur supérieure à Date de la demande
    mkstat = 2 : End
Endif
End

##**82073
Subprog AS_APLSTR(VALEUR)
Variable Date    VALEUR
Gosub GET_PPDSTA From TRTPREPAY
# Si une ligne est prise en compte, interdit de changer la date !
If find([L]PPDSTA_PRISENCOMPTE, [M:HRPPH1]STA)
    GMESSAGE= mess(9,123,1) #: Modification impossible
    mkstat = 2 : End
Endif
End

Subprog AS_APLDAT(VALEUR)
Variable Date     VALEUR
Gosub GET_PPDSTA From TRTPREPAY
# Si une ligne est prise en compte, interdit de changer la date !
If find([L]PPDSTA_PRISENCOMPTE, [M:HRPPH1]STA)
    GMESSAGE= mess(9,123,1) #: Modification impossible
    mkstat = 2: End
Endif
End

Subprog C_APLDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR < [M:HRPPH0]DEMDAT
    GMESSAGE = mess(200,126,1)-'"'+mess(164,10701,1)+'"' : # Valeur inférieure à Date de la demande
    mkstat = 2 :    End
Endif
End

Subprog AM_APLDAT(VALEUR)
Variable Date    VALEUR
Call SET_PYRDAT([L]VALEUR) From TRTPPHNOU
Affzo PYRDAT, DATDEB,DATFIN,FMOIS
End

Subprog C_NBLIG
Call CTRL_VARBASTAB
End

#-------------------------------------------------------------------------------------
# CTRL_VARBASTAB : Contrôle variable bas de tableau sur les écrans HRPPH1 / HRPPH2 / HRPPH3
#-------------------------------------------------------------------------------------
Subprog CTRL_VARBASTAB
Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY
Local Integer STA

If [L]MSK <> ""
 [L]STA = evalue([L]MSK + "STA([L]NOL)")
Endif

Case [L]STA
    When [L]PPDSTA_BROUILLON
    When [L]PPDSTA_INACTIF
    When [L]PPDSTA_DEMANDE
    When [L]PPDSTA_REFUSE
    When [L]PPDSTA_ACCEPTE
    When [L]PPDSTA_PRISENCOMPTE
        # Ligne prise en compte, aucune modif possible
        If find(status, 65, 75) : mkstat = 2 : Endif
    When Default
        # 0 , ligne en cours de saisie non initialisée
Endcase

End

