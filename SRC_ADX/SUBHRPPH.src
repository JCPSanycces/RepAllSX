Call S_SALID(1, [L]VALEUR)
If [L]VALEUR <> ""
    Call AM_SELCTRNUM([M:HRPPH3]SELCTRNUM)
Else
    mkstat = 2
Endif
End

Subprog AM_SELREFNUM(VALEUR)
Variable Char    VALEUR()
Call S_SALID(3, [L]VALEUR)
If [L]VALEUR <> ""
    Call AM_SELCTRNUM([M:HRPPH3]SELCTRNUM)
Else
    mkstat = 2
Endif
End

Subprog B1_SELREFNUM(VALEUR)
Variable Char    VALEUR()
## Action GOBJETC0
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "GOBJETC0"
Call OBJET_CHAR([L]VALEUR ,"EML", "") From GOBJET
GACTION = SAVACT
If [L]VALEUR <> [M:HRPPH3]SELREFNUM
    # Le salopard s'est déplacé ....
    Call S_SALID(3, [L]VALEUR)
    If [L]VALEUR <> ""
        Call AM_SELCTRNUM([M:HRPPH3]SELCTRNUM)
    Else
        mkstat = 2
    Endif
Endif
End

Subprog S_SELCTRNUM(VALEUR)
Variable Char    VALEUR()
Call S_SALID(2, [L]VALEUR)
If [L]VALEUR <> ""
    Call AM_SELCTRNUM([M:HRPPH3]SELCTRNUM)
Else
    mkstat = 2
Endif
End

Subprog AM_SELCTRNUM(VALEUR)
Variable Char    VALEUR()
Call LOAD_PPH3([M:HRPPH3]SELREFNUM, [L]VALEUR,[M:HRPPH3]SELCTRDAT) :##**82073
End

Subprog AV_SELCTRNUM(VALEUR)
Variable Char    VALEUR()
If [M:HRPPH3]SELREFNUM <> ""
   Read [F:ID]ID0 = [M:HRPPH3]SELREFNUM
   If fstat = 0
      If [F:ID]FLGMULCTR = 2
         Actzo [M:HRPPH3]SELCTRNUM
      Else
         Diszo [M:HRPPH3]SELCTRNUM
      Endif
   Endif
Else
   Actzo [M:HRPPH3]SELCTRNUM
Endif
End

Subprog AV_DESSAL(VALEUR)
Variable Char    VALEUR()
If [M:HRPPH3]REFNUM <> ""
     [L]VALEUR = func SUBHRPPH.GET_NAM([M:HRPPH3]REFNUM, 3)
Endif
End

Subprog C_NBLIGSAL
Call CTRL_VARBASTAB
End

Subprog APRES_NBLIGSAL
Call MAJ_PPH1_FROM_PPH3(nolign-1)
Call AFFMSK([M:HRPPH3]IDLIG(nolign-1), "124")
End

# ----------------------------------- Sous programmes de l'écran HRPPH3 -------------------------

#----------------------------------------------------------
# LOAD_PPH3 : Chargement des données pour un REFNUM/CTRNUM
#----------------------------------------------------------
##**82073
Subprog LOAD_PPH3(REFNUM, CTRNUM, CTRDAT)
Value Char REFNUM(), CTRNUM()
Value Date CTRDAT

Local Integer LIG_ORIGINE, LIG_DESTINATION

Raz [M:HRPPH3], [L]LIG_DESTINATION
#LIPET - 2017-06-14 - START
#[M:HRPPH3]SELREFNUM = [L]REFNUM : [M:HRPPH3]SELCTRNUM = [L]CTRNUM
[M:HRPPH3]SELREFNUM = [L]REFNUM : [M:HRPPH3]SELCTRNUM = [L]CTRNUM : [M:HRPPH3]SELCTRDAT = [L]CTRDAT
#LIPET - 2017-06-14 - END
For [L]LIG_ORIGINE = 0 To [M:HRPPH1]NBLIG - 1
    If [M:HRPPH1]REFNUM([L]LIG_ORIGINE) = [L]REFNUM & [M:HRPPH1]CTRNUM([L]LIG_ORIGINE) = [L]CTRNUM
&    & [M:HRPPH1]CTRDAT([L]LIG_ORIGINE) = [L]CTRDAT        :##**82073
        Call TRANSFERE("HRPPH1", "HRPPH3", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
        [L]LIG_DESTINATION += 1
    Endif
Next

[M:HRPPH3]NBLIGSAL = [L]LIG_DESTINATION

[V]GPE = 0
GPOINT = "LOAD_PPH3" : Gosub ENTREE From EXEFNC

Affzo [M:HRPPH3]

End

#-----------------------------------------------------------------------------------------
# MAJ_PPH1_FROM_PPH3 : Sauvegarde des infos d'une ligne HRPPH3 vers HRPPH1 - Ecran référence
#-----------------------------------------------------------------------------------------
Subprog MAJ_PPH1_FROM_PPH3(NOL)
Value Integer NOL

Local Integer LIG_ORIGINE, LIG_DESTINATION
Local Char VAR_ORIGINE(250), VAR_DESTINATION(250), ZONE(20)

[L]LIG_ORIGINE = [L]NOL
[L]LIG_DESTINATION = find([M:HRPPH3]IDLIG([L]LIG_ORIGINE), [M:HRPPH1]IDLIG)
[L]LIG_DESTINATION -= 1
If [L]LIG_DESTINATION >= 0
    Call TRANSFERE("HRPPH3", "HRPPH1", [L]LIG_ORIGINE, [L]LIG_DESTINATION)
    Call COHERENCE([M:HRPPH3]IDLIG([L]LIG_ORIGINE))
Endif

End

#--------------------
# PRENEXSAL
#--------------------
##**82073
Subprog PRENEXSAL(SENS)
Value Integer SENS
Local Char TREFNUM([V]GLONEML)(1..dim([M:HRPPH1]REFNUM))
Local Char TCTRNUM([V]GLONHRCTR)(1..dim([M:HRPPH1]CTRNUM))
Local Date TCTRDAT (1..dim([M:HRPPH1]CTRDAT))
#LIPET - 2017-06-14 - START
#Local Char TSALID([V]GLONEML+1+[V]GLONHRCTR)(1..dim([M:HRPPH1]REFNUM))
Local Char TSALID([V]GLONEML+1+[V]GLONHRCTR+11)(1..dim([M:HRPPH1]REFNUM))
#LIPET - 2017-06-14 - END
Local Char TSALDES(60)(1..dim([M:HRPPH1]REFNUM))
Local Integer SALNB, I
#LIPET - 2017-06-14 - START
#Local Char SALID([V]GLONEML+1+[V]GLONHRCTR)
Local Char SALID([V]GLONEML+1+[V]GLONHRCTR+11)
#LIPET - 2017-06-14 - END
[L]SALID = [M:HRPPH3]SELREFNUM + "~" + [M:HRPPH3]SELCTRNUM + "~" + format$(GFMDAT4,[M:HRPPH3]SELCTRDAT)
Call GET_SALLIS([L]TREFNUM, [L]TCTRNUM, [L]TCTRDAT, [L]TSALID, [L]TSALDES, [L]SALNB, 0)
[L]I = find([L]SALID, [L]TSALID(1..[L]SALNB))
If [L]I > 0
    [L]I += [L]SENS
    If [L]I < 1 : [L]I = 1 : Endif
    If [L]I > [L]SALNB : [L]I = [L]SALNB : Endif
Else
    If [L]SENS = 1
        [L]I = [L]SALNB
    Else
        [L]I = 1
    Endif
Endif
[M:HRPPH3]SELREFNUM = [L]TREFNUM([L]I) : [M:HRPPH3]SELCTRNUM = [L]TCTRNUM([L]I) : [M:HRPPH3]SELCTRDAT = [L]TCTRDAT([L]I)
Call AM_SELCTRNUM([M:HRPPH3]SELCTRNUM)
End

#------------------------------------------------------------------------------------
# GET_SALLIS : Renvoie une liste de salarié et de contrat présents dans l'écran HRPPH1
#------------------------------------------------------------------------------------
##**82073
Subprog GET_SALLIS(TREFNUM, TCTRNUM, TCTRDAT, TSALID, TSALDES, SALNB, MODE)
Variable Char TREFNUM()(0..), TCTRNUM()(0..)
Variable Date TCTRDAT(0..)
Variable Char TSALID()(0..), TSALDES()(0..)
Variable Integer SALNB
Value Integer MODE
Local Integer I

Local Char REFNUM([V]GLONEML), CTRNUM([V]GLONHRCTR), SALID([V]GLONEML+1+[V]GLONHRCTR+11)
Local Date CTRDAT

Raz [L]TREFNUM, [L]TCTRNUM, [L]TSALDES, [L]TSALID, [L]SALNB, [L]REFNUM, [L]CTRNUM, [L]SALID, [L]TCTRDAT, [L]CTRDAT
[L]SALNB = -1

For [L]I = 0 To [M:HRPPH1]NBLIG - 1

    [L]REFNUM = [M:HRPPH1]REFNUM([L]I)
    [L]CTRNUM = [M:HRPPH1]CTRNUM([L]I)
    [L]CTRDAT = [M:HRPPH1]CTRDAT([L]I)
    [L]SALID = [L]REFNUM + "~" + [L]CTRNUM + "~" + format$(GFMDAT4,[L]CTRDAT)

    If not find([L]SALID, [L]TSALID)
        [L]SALNB += 1
        [L]TSALID([L]SALNB) = [L]SALID
        [L]TREFNUM([L]SALNB) = [L]REFNUM
        [L]TCTRNUM([L]SALNB) = [L]CTRNUM
        [L]TCTRDAT([L]SALNB) = [L]CTRDAT
        Read [F:ID]ID0 = [L]REFNUM
        If fstat = 0
            [L]TSALDES([L]SALNB) = [F:ID]SRN-[F:ID]NAM
        Else
            [L]TSALDES([L]SALNB) = "*** PANIC ***"
        Endif
    Endif
Next
[L]SALNB += 1

Case [L]MODE
    When 0
        # Pas de tri
    When Default
        Sorta [L]SALNB [L]TREFNUM, [L]TCTRNUM, [L]TCTRDAT, [L]TSALDES, [L]TSALID
&                Order By [L]TREFNUM(indice), [L]TCTRNUM(indice),[L]TCTRDAT(indice), [L]TSALDES(indice)
Endcase

End

#------------------------------------------------------
# S_SALID : Fenêtre de sélection sur salarie / contrat
#------------------------------------------------------
Subprog S_SALID(ORIGINE, VALEUR)
Value Integer ORIGINE
Variable Char VALEUR()

Local Integer SALNB, I, MAXLIG, CHOI, SALNB_EFFECTIF
[L]MAXLIG = dim([M:HRPPH1]REFNUM)

Local Char TREFNUM([V]GLONEML)(1..[L]MAXLIG)
Local Char TCTRNUM([V]GLONHRCTR)(1..[L]MAXLIG)
Local Date TCTRDAT(1..[L]MAXLIG)
Local Char TSALID([V]GLONEML+1+[V]GLONHRCTR)(1..[L]MAXLIG)
Local Char TSALDES(60)(1..[L]MAXLIG)
Local Char SALID([V]GLONEML+1+[V]GLONHRCTR)
Local Char TSALLIS(250)(1..[L]MAXLIG, 1..4)
Local Char TIT(250)(0..4)

Call GET_SALLIS([L]TREFNUM, [L]TCTRNUM,[L]TCTRDAT, [L]TSALID, [L]TSALDES, [L]SALNB, 1)

Raz [L]SALNB_EFFECTIF

# Remise en forme pour faire une fenêtre de sélection multi colonne

For [L]I = 1 To [L]SALNB
    If find([L]ORIGINE, 1, 2) or ([L]ORIGINE=3 & [L]TREFNUM([L]I)=[L]VALEUR)

        [L]SALNB_EFFECTIF += 1

        [L]TSALLIS([L]SALNB_EFFECTIF, 1) = [L]TREFNUM([L]I)
        [L]TSALLIS([L]SALNB_EFFECTIF, 2) = [L]TCTRNUM([L]I)
        #LIPET - 2017-06-14 - START
        #[L]TSALLIS([L]SALNB_EFFECTIF, 3) = [L]TSALDES([L]I)
        [L]TSALLIS([L]SALNB_EFFECTIF, 3) = format$(GFMDAT4,[L]TCTRDAT([L]I))
        [L]TSALLIS([L]SALNB_EFFECTIF, 4) = [L]TSALDES([L]I)
        #LIPET - 2017-06-14 - END
        Case [L]ORIGINE
            When 1, 4
                If [L]VALEUR = [L]TREFNUM([L]SALNB_EFFECTIF) &
&                                ([M:HRPPH3]SELCTRNUM = [L]TCTRNUM([L]SALNB_EFFECTIF) or [M:HRPPH3]SELCTRNUM = "")
                    [L]CHOI = [L]SALNB_EFFECTIF
                Endif
            When 2,3
                If [L]VALEUR = [L]TCTRNUM([L]SALNB_EFFECTIF) &
&                                ([M:HRPPH3]SELREFNUM = [L]TREFNUM([L]SALNB_EFFECTIF) or [M:HRPPH3]SELREFNUM = "")
                    [L]CHOI = [L]SALNB_EFFECTIF
                Endif

        Endcase
    Endif
Next

# mess(178,10702,1) : Sélection d'un matricule et d'un contrat
# mess(179,10702,1) : Matricule
# mess(180,10702,1) : Contrat
# mess(181,10702,1) : Nom

[L]TIT(0) = mess(178,10702,1)
[L]TIT(1) = mess(179,10702,1)
[L]TIT(2) = mess(180,10702,1)
[L]TIT(3) = mess(181,10702,1)
[L]TIT(4) = mess(181,10702, 1)
If [L]SALNB_EFFECTIF = 1
    # Inutile d'ouvrir la fenêtre pour faire choisir un élément unique !
    [L]CHOI = 1
Elsif [L]SALNB_EFFECTIF > 0
    Call SAITEX([L]SALNB_EFFECTIF, [L]TSALLIS, [L]CHOI, [L]TIT) From GESECRAN
Endif

If status <> 7 & [L]CHOI <> 0
    Case [L]ORIGINE
        When 1, 3
            [L]VALEUR = [L]TSALLIS([L]CHOI, 1)
        When 2
            [L]VALEUR = [L]TSALLIS([L]CHOI, 2)
    Endcase
    [M:HRPPH3]SELREFNUM = [L]TSALLIS([L]CHOI, 1)
    [M:HRPPH3]SELCTRNUM = [L]TSALLIS([L]CHOI, 2)
    [M:HRPPH3]SELCTRDAT = gdat$(val(mid$([L]TSALLIS([L]CHOI, 3),1,2)),val(mid$([L]TSALLIS([L]CHOI, 3),4,2)),val(mid$([L]TSALLIS([L]CHOI, 3),7,4)))
    # Call AM_SELCTRNUM([M:PPH3]SELCTRNUM)
    # mkstat = 2
Else
    Raz [L]VALEUR
    mkstat = 2
Endif

End

# --------------------------------------------- Ecran HRPPH4 Saisie croisée ---------------------------
Subprog CL_PREGRV(VALEUR)
Variable Char    VALEUR()
Call PRENEXGRV(-1)
End

Subprog CL_NEXGRV(VALEUR)
Variable Char    VALEUR()
Call PRENEXGRV(1)
End

Subprog S_SELGRV(VALEUR)
Variable Char VALEUR()

Local Integer GRVNB, I, MAXLIG, CHOI
[L]MAXLIG = dim([M:HRPPH1]VRAGRP)

Local Char TGRV([V]GLONADI)(1..[L]MAXLIG)
Local Char TGRVDES([V]GLONDES)(1..[L]MAXLIG)
Local Char TGRVLIS(250)(1..[L]MAXLIG,1..2), TIT(GLONDES)(0..2)

If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
    Call GET_GRVLIS([M:HRPPH9]PVHCOD, [M:HRPPH1]VRACOD, [L]TGRV, [L]TGRVDES, [L]GRVNB, 1)
Else
    Call GET_GRVLIS([M:HRPPH9]PVHCOD, [M:HRPPH1]VRACOD, [L]TGRV, [L]TGRVDES, [L]GRVNB, 2)
Endif

For [L]I = 1 To [L]GRVNB
    [L]TGRVLIS([L]I, 1) = [L]TGRV([L]I)
    [L]TGRVLIS([L]I, 2) = [L]TGRVDES([L]I)

    If [L]VALEUR = [L]TGRV([L]I)
        [L]CHOI = [L]I
    Endif
Next

# mess(182,10702, 1) : Sélection d'un groupe de saisie
# mess(183,10702, 1) : Groupe
# mess(184,10702, 1) : Intitulé

[L]TIT(0) = mess(182,10702,1)
[L]TIT(1) = mess(183,10702,1)
[L]TIT(2) = mess(184,10702,1)

Call SAITEX([L]GRVNB, [L]TGRVLIS, [L]CHOI, [L]TIT) From GESECRAN
If status <> 7 & [L]CHOI <> 0
    [L]VALEUR = [L]TGRVLIS([L]CHOI, 1)
Endif

End

Subprog AM_SELGRV(VALEUR)
Variable Char    VALEUR()
Call LOAD_PPH4([L]VALEUR)
End

Subprog AV_DESGRV(VALEUR)
Variable Char    VALEUR()
If [M:HRPPH4]SELGRV <> ""
    If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
        [L]VALEUR = func AFNC.TEXTRA("ATABDIV", "LNGDES", "10391", [M:HRPPH4]SELGRV)
    Else
        [L]VALEUR = func AFNC.TEXTRA("ATABDIV", "LNGDES", "10442", [M:HRPPH4]SELGRV)
    Endif
Else
    If dim([V]GPPHVRAGRP) > 0 & [V]GPPHVRAGRP = 1
        [L]VALEUR = mess(187,10702,1) - mess(188,10702,1)
    Else
        [L]VALEUR = mess(183,10702,1) - mess(188,10702,1)
    Endif
Endif
End

