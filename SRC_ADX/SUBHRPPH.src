#---------------------------------------------------------
# B1_GRVDEMAMT : Saisie de commentaire sur HRPPH4
#                Appel depuis chaque bouton B1_GRVDEMAMTx
#---------------------------------------------------------
Subprog B1_GRVDEMAMT(VALEUR, NUM)
Variable Decimal VALEUR
Value Integer NUM

If [L]VALEUR = 0 : End : Endif

Gosub SETNOL

Local Char NOMVAR(250)

## Action TRTPPHCMT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Char RETOUR(10)
SAVACT = GACTION : GACTION = "TRTPPHCMT"

[L]NOMVAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]NOL)"
PARMSK(1) = evalue([L]NOMVAR)

[L]NOMVAR = "[M:HRPPH4]REFNUM([L]NOL)"
PARMSK(2) = evalue([L]NOMVAR)

[L]NOMVAR = "[M:HRPPH4]CTRNUM([L]NOL)"
PARMSK(3) = evalue([L]NOMVAR)

[L]NOMVAR = "[M:HRPPH4]GRVVRACOD"+num$([L]NUM)
PARMSK(4) = evalue([L]NOMVAR)

PARMSK(5) = num$([L]VALEUR)

Call SAISIE_CHAR([L]RETOUR, [L]PARMSK, "TRTPPHCMT", "TRTPPHCMT", "XYTRTPPHCMT") From GSAISIE
GACTION = SAVACT

If [L]RETOUR = "OK"
    [L]NOMVAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]NOL)"
    Assign [L]NOMVAR With [L]PARMSK(1)
    Call APRES_NBLIGGRV
Endif

End

