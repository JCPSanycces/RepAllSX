#----------------------------------------------------------
# B3_GRVDEMAMT : Recopie vers le bas
#                Appel depuis chaque bouton B3_GRVDEMAMTx
#----------------------------------------------------------
Subprog B3_GRVDEMAMT(VALEUR, NUM)
Variable Decimal VALEUR
Value Integer NUM

Gosub SETNOL : Gosub SETMSK
Gosub GET_PPDSTA From TRTPREPAY

Local Integer S_NOL, RECOPIE_COMMENTAIRE
Local Char VOIDCHAR(250)

[L]RECOPIE_COMMENTAIRE = 1

# If evalue("[M:PPH4]GRVFLGAPP"+ num$([L]NUM)+"([L]NOL)") = 2
    [L]RECOPIE_COMMENTAIRE = 2
    # mess(204,702,1) : Désirez-vous recopier les commentaires ?
    Call OUINON(mess(204,10702,1), [L]RECOPIE_COMMENTAIRE) From GESECRAN
# Endif

[L]S_NOL = [L]NOL

For [L]NOL = [L]S_NOL+1 To [M:HRPPH4]NBLIGGRV - 1
    If evalue("[M:HRPPH4]GRVSTA"+num$([L]NUM)+"([L]NOL)") < [L]PPDSTA_PRISENCOMPTE
        nolign = [L]NOL + 1
        [L]NOMVAR = "[M:HRPPH4]GRVDEMAMT" + num$([L]NUM) + "([L]NOL)"
        Assign [L]NOMVAR With [L]VALEUR
        Call AM_GRVDEMAMT([L]VALEUR, [L]NUM, 1)

        If [L]RECOPIE_COMMENTAIRE = 2
            [L]NOMVAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]NOL)"
            # If vireblc(evalue([L]NOMVAR),4) = ""
                [L]VOIDCHAR = "[M:HRPPH4]GRVVRACMT"+num$([L]NUM)+"([L]S_NOL)"
                Assign [L]NOMVAR With evalue([L]VOIDCHAR)
            # Endif
        Endif

        [V]GPPHAFFMSK = 0
        Call APRES_NBLIGGRV
        [V]GPPHAFFMSK = 1
    Endif
Next

nolign = [L]S_NOL + 1

Call AFFMSK("", "1234")

End

