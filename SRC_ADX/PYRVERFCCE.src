#<AdxTL>@(#)9.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "ORGA"
Call TRAITE_CHAR(VALEUR,PARAM,"","PYRVERFCCE","",1,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return


$INIT
TMP = 1
Return

$EXEC
TRA = 1
Local Integer I , ER1 , ER2 , ER3 , NBREF , NIV
Local Char    REF(GLONCYR)(1..100)
Local Char    DESIG(GLONAX3)
If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
If clalev([F:CYM])=0  : Local File GCCEPYM    [CYM]  : Endif
If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY]  : Endif
If clalev([F:CRY2])=0 : Local File GCCEGRUPYM [CRY2] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif

Read [CYM]CYM0 = PARAM(1)
If fstat : End : Endif

Call OUVRE_TRACE(mess(59,103,1)-PARAM(1)) From LECFIC : # Vérification pyramide

ER1 = 0
For [CCE]CCE0 Where DIE=[F:CYM]DIE
 NBREF = 0
 For [CRY]CRY5 Where PYM=PARAM(1) & CCE>"" & pat([F:CCE]CCE,[F:CRY]CCE)<>0
  NBREF = 1 : Break
 Next
 If NBREF=0
  If ER1=0 
   Call ECR_TRACE(mess(77,103,1),0) From GESECRAN : # Sections non référéncées
   Call ECR_TRACE("",0) From GESECRAN
   ER1 += 1
  Endif
  Call LECTEXTRA(DESIG,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  Call ECR_TRACE([F:CCE]CCE-DESIG,0) From GESECRAN
 Endif
Next

ER2 = 0
For [CCE]CCE0 Where DIE=[F:CYM]DIE
 NBREF = 0
 For [CRY]CRY5 Where PYM=PARAM(1) & CCE>"" & pat([F:CCE]CCE,[F:CRY]CCE)<>0
  NBREF += 1 : REF(NBREF) = [F:CRY]GRU
  If NBREF>=dim(REF) : Break : Endif
 Next
 If NBREF>1
  If ER2=0
   If ER1
    Call ECR_TRACE("",0) From GESECRAN
   Endif
   Call ECR_TRACE(mess(78,103,1),0) From GESECRAN : # Sections multi-référéncées
   Call ECR_TRACE("",0) From GESECRAN
   ER2 += 1
  Endif
  Call LECTEXTRA(DESIG,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  For I=1 To NBREF
   Call ECR_TRACE([F:CCE]CCE-DESIG-":"-mess(25,103,1)-REF(I),0) From GESECRAN : # Groupe de sections
  Next I
 Endif
Next

ER3 = 0
NIV = 0
For [CRY]CRY1(2) Where PYM=PARAM(1)
 NIV += 1
 If NIV>1
  For [CRY]CRY1
   NBREF = 0
   For [CRY2]CRY2 Where PYM=PARAM(1) & SBBGRU=[F:CRY]GRU
    NBREF = 1 : Break
   Next
   If NBREF=0
    If ER3=0
     If ER1 or ER2
      Call ECR_TRACE("",0) From GESECRAN
     Endif
     Call ECR_TRACE(mess(79,103,1),0) From GESECRAN : # Groupes sans père
     Call ECR_TRACE("",0) From GESECRAN
     ER3 += 1
    Endif
    Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
    Call ECR_TRACE([F:CRY]GRU-DESIG,0) From GESECRAN
   Endif
  Next
 Endif
Next

If ER1=0 & ER2=0 & ER3=0
 Call ECR_TRACE(mess(164,115,1),0) From GESECRAN : # Aucune anomalie
Endif
Call FERME_TRACE From LECFIC
Return


