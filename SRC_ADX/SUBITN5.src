#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque ITN5
##########################################################################################################
Subprog AS_NBAUS

  GAUSNOL = nolign - 1
  If GAUSNOL >= 0 Then
    Raz [M:ITN5]NBAUSSEL
    [M:ITN5]NBAUSSEL(nolign - 1) = "->"
    GSZSELAUS = [M:ITN5]AUSNUM(GAUSNOL)
    Call LOADRAN([M:ITN5]AUSNUM(GAUSNOL)) From TRTITN5
  Endif
  Affzo [M:ITN5]5
End

##########################################################################################################
Subprog AS_NBRAN

  If nolign >= 1 Then
    GISELRAN = nolign-1
    Call LOADPNITN(nolign-1) From TRTITN5
  Endif
End
