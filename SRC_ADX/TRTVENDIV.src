#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS DIVERS dans les VENTES                               #
#                                                                       #
#########################################################################
#-----------------------------------------------------------------------#
# Traitements e_commerce                                                #
#-----------------------------------------------------------------------#
# ACTIONS                                                               #
#-----------------------------------------------------------------------#
# ALISALFCY  : Après saisie site vente                                  #
# ALISTOFCY  : Après saisie site expédition                             #
# TRTMAJDET  : Répercution des modifs entête vers les lignes détails    #
#                                                                       #
# Action créées pour le workflow des signatures devis et commandes :    #
#                                                                       #
# SAMAPPFLG  : S/P de test modification rubrique majeure                #
# DIVSQHAPP1 : Maj indicateur signature d'1 devis à val.1(non signé)    #
# DIVSOHAPP1 : Maj indicateur signature d'1 cde à val.1(non signée)     #
# DIVSOHDUD  : Mise à jour des acomptes d'une commande                  #
# DIVSOHWIP  : Mise à jour des encours article d'une commande           #
# DIVSOHALL  : Mise à jour des allocations d'une commande               #
# DIVSOHOST  : Mise à jour des encours client  d'une commande           #
#                                                                       #
#########################################################################
# Issue 113857 - 20160128 by LD : Désallocation commande contremarque signée
# Issue 114550 - 20160219 by LD : Non mise à jour ITMMVT suite annulation signature

$ACTION
#--- Actions liés au type traitement et affichage divers
Case ACTION
 When "TRT_DIV"      : Gosub TRT_DIV
Endcase
#--- Actions liés au type traitement standard
Case ACTION
 When "INIT"         : Gosub INIT
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "SORTIE"       : Gosub SORTIE      : # 79705 : V7 : SAT in SPRICLINK
Endcase
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "BOUTON"       : Gosub BOUTON
Endcase
Return
#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$TRT_DIV
Case TRAIT
    When "ALISALFCY" : Gosub ALISALFCY
    When "ALISTOFCY" : Gosub ALISTOFCY
Endcase
Return
#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
 When "TRTMAJDET"    : Gosub INI_TRTMAJDET
Endcase
Return
$EXEC
Case GACTION
 When "TRTMAJDET"    : Gosub EXEC_TRTMAJDET
Endcase
Return
$TERMINE
Case GACTION
 When "TRTMAJDET"    : Gosub TERMINE_TRTMAJDET
Endcase
Return
# 79705 : V7 : SAT in SPRICLINK
$SORTIE
Case GACTION
 When "TRTMAJDET"    : Gosub SORTIE_TRTMAJDET
Endcase
Return
#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$DEBUT
Case GACTION
 When "TRTMAJDET"  : Gosub DEB_TRTMAJDET
Endcase
Return
$BOUTON
Case GACTION
 When "TRTMAJDET"  : Gosub BOUT_TRTMAJDET
Endcase
Return
################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################
################################################################################
# TRTMAJDET : Répercution des modifs entête vers les lignes détails            #
################################################################################
$INI_TRTMAJDET
If dim(indice)>0 : Local Integer SAVINDICE : SAVINDICE=indice : Endif #Fq74245-gbn
Local Char    WOBJET     : WOBJET  = PARAM(1)
Local Char    WZONCOU    : WZONCOU = PARAM(2)
Local Char    FFLGMOD    : Raz FFLGMOD
# Particularité zone BPAADD : Si W_ALICDE= 2 : On a ddé de réalimenter des zones d'entête avec la nvelle adresse
#                             --> On répercutera tous les champs concernés
#                             Si W_ALICDE=21 : Il faut forcer la répercution sur les lignes (pour ne pas avoir d'incohérences)
Local Integer W_ALICDE   : W_ALICDE=val(PARAM(3)) : # W_ALICDE est testé dans MOD_BPAADD de SUBSOHB SUBSQHB

Local Integer SAVMKSTAT : SAVMKSTAT=mkstat : # 79705 : V7 : SAT in SPRICLINK

If GREP = "C"
    If WOBJET="SOH" & [M:SOH4]NBLIG=0 FIN=1 : Return Endif
    If WOBJET="SQH" & [M:SQH2]NBLIG=0 FIN=1 : Return Endif
Endif

# 107890 : Scheduled invoices : (LD:15/12/15)
# Invoicing condition musn't be put on lines if the value not fed
If WZONCOU="INVCND" & VALEUR="" FIN=1 : Return : Endif
# 107890 : Scheduled invoices : (LD:15/12/15)

# 79705 : V7 : SAT in SPRICLINK
# Si on vient du bouton adresse depuis les champs client il faut passer en AM_ pour dégrizer le bouton enregistrer
# mais il ne faut pas executer cette action car il n'y a rien à répercuter sur les lignes
If WZONCOU="BPAADD" & [M]BPAADD=VALEUR FIN=1 : Return : Endif
# 79705 : V7 : SAT in SPRICLINK

# Modif. de l'adresse de livraison et pas de gestion des adresses à la ligne : répercution automatique
If WZONCOU="BPAADD" & GLINBPD=1 TYPPRG=1 : PARAM(3)="1" : Return : Endif
# Modif. de l'adresse de livraison et incohérences : répercution automatique
If WZONCOU="BPAADD" & W_ALICDE=21 W_ALICDE=2 : TYPPRG=1 : PARAM(3)="1" : Return : Endif
# Modif. du représentant et pas de gestion des rep à la ligne : répercution automatique
If WZONCOU="REP" & GLINREP=1 TYPPRG=1 : PARAM(3)="1" : Return : Endif
# Gestion des commandes :
# Modif. du site expédition et livraison commande complète : répercution automatique
# Modif. du N°tournée et livraison commande complète       : répercution automatique
If WOBJET="SOH" & find (WZONCOU, "STOFCY", "DRN") & [M:SOH2]DME=3 TYPPRG=1 : PARAM(3)="1" : Return : Endif
# En duplication,il faut proposer la mise à jour
#If GREP = "D" FIN = 1 : Endif
Return
# ------------------------------------------------------------------------------
$DEB_TRTMAJDET
Local Char    WOBJET   : WOBJET  = PARAM(1)
Local Char    WZONCOU  : WZONCOU = PARAM(2)
Local Char    FFLGMOD  : Raz FFLGMOD
Local Char    WREP(GLONREP) : WREP=""

[M:CHX]TEXTE = mess(67,196,1)
# Particularité du message à afficher selon les objets
Case WOBJET
    When "SOH"
        If WZONCOU="STOFCY"
#       --> il y a des allocations
            If sum([M:SOH4]ALLQTY,[M:SOH4]SHTQTY) <> 0
                [M:CHX]TEXTE = mess(121,191,1)
#       --> il y a des préparations
            Elsif sum([M:SOH4]LPRQTY,[M:SOH4]OPRQTY,[M:SOH4]PREQTY) <> 0
                [M:CHX]TEXTE = mess(212,191,1)
# 107888 : Scheduled invoices : (LD:20/05/16)
#            Elsif [M:SOH0]SOHCAT <> 3 & sum([M:SOH4]ODLQTY,[M:SOH4]DLVQTY) <> 0
#                [M:CHX]TEXTE = mess(122,191,1)
#       --> Commande normale/prêt et ligne livrable
#       --> il y a des livraisons ou/et des factures
            Elsif [M:SOH0]SOHCAT <> 3 & sum([M:SOH4]ODLQTY,[M:SOH4]DLVQTY, [M:SOH4]INVQTY) <> 0
                [M:CHX]TEXTE = mess(276,191,1)
#       --> Commande à facturation directe
#       --> Commande normale et ligne non livrable
# 107888 : Scheduled invoices : (LD:20/05/16)
#       --> il y a des factures
            Elsif [M:SOH0]SOHCAT =  3 & sum([M:SOH4]ODLQTY, [M:SOH4]INVQTY) <> 0
                [M:CHX]TEXTE = mess(123,191,1)
            Endif
        Endif
    When Default
Endcase
Affzo [M:CHX]TEXTE

Return
# ------------------------------------------------------------------------------
$BOUT_TRTMAJDET
Case BOUT
    When "1"  :  # Oui
        PARAM(3) = num$(1)
    When "2"  :  # Non
        PARAM(3) = num$(2)
    When "3"  :  # Valeur
        PARAM(3) = num$(3)
    When Default
Endcase
FIN=1
Return
# ------------------------------------------------------------------------------
$EXEC_TRTMAJDET

If find(PARAM(3),"","2")
    # On a répondu "non" : Pas de répercution sur les lignes : on execute pas l'action
    # 79705 : V7 : SAT in SPRICLINK
    #If (WZONCOU = "BPAADD" & GLINREP = 2) | (WZONCOU <> "BPAADD")  FIN=1 : Return : Endif
    If WZONCOU = "BPAADD"
      # Modif de l'adresse de livraison
      If GLINREP = 1
        # 0n ne gère pas les représentants à la ligne :
        # les rép sur les lignes doivent forcément être les mêmes que ceux de l'entête ->
        # On execute l'action de répercution uniquement pour répercuter les rep sur les lignes
        Return
      Else
        # 0n gère les représentants à la ligne :
        # les rép sur les lignes peuvent être différents de ceux de l'entête ->
        # on execute pas l'action
        FIN=1 : Return
      Endif
    Else
        # Dans tous les autres cas :
        # on execute pas l'action
        FIN=1 : Return
    Endif
    # 79705 : V7 : SAT in SPRICLINK
Endif

# Particularité selon les objets
Case WOBJET
    When "SQH"
        If find(WZONCOU,"BPAADD")
            # 79705 : SAT in SPRICLINK : Step 2
            FFLGMOD = PARAM(3)
            Call OUVRE_TRACE(mess(256,191,1)) From LECFIC
            Gosub VERIF_LIGNES From SUBSQHB
            Call FERME_TRACE From LECFIC
            If GERR=1
              Call LEC_TRACE   From LECFIC
              # Si ctrl non bloquant et la répercussion n'est pas obligatoire on peut accepter les interdits
        #      If GDACLOK=2 & GLINBPD=2 & GLINREP=2
              If GDACLOK=2
                Local Integer WOK
                WOK=2 : Call AVERTIR (mess(27,192,1)-":"-mess(205,100,1), WOK) From GESECRAN
        #        If WOK=1 mkstat=2 : GERR=1 : FIN=1 : Return Endif
                If WOK=1 mkstat=2 : FIN=1 : Return Endif
              Else
                mkstat=2 : GERR=1 : GMESSAGE=mess(27,192,1)-":"-mess(9,123,1) : FIN=1 : Return
              Endif
            Endif
            # 79705 : SAT in SPRICLINK : Step 2
            # 79705 : V7 : SAT in SPRICLINK
            Global Char GADDACTMOD(GLONDES)
            GADDACTMOD = "1"
            # Recherche tarif déclenchée maintenant par l'action TRTRECTAR
            #Local Integer WOK
            #Call OUINON (mess(21,191,1),WOK) From GESECRAN
            #If WOK=2 GTARFLG="1" Endif
            # 79705 : V7 : SAT in SPRICLINK
        Endif
    When "SOH"
        If find(WZONCOU,"DEMDLVDAT","DAYLTI")
            If sum([M]FMINUM) <> ""
                GERR=3 : GMESSAGE= mess(54,191,1)+"\"+mess(53,191,1)
            Endif
        Elsif find(WZONCOU,"SHIDAT")
            If sum([M]FMINUM) <> ""
                GERR=3 : GMESSAGE= mess(53,191,1)
            Endif
        Elsif find(WZONCOU,"BPAADD")
            # 79705 : SAT in SPRICLINK : Step 2
            FFLGMOD = PARAM(3)
            Call OUVRE_TRACE(mess(256,191,1)) From LECFIC
            Gosub VERIF_LIGNES From SUBSOHB
            Call FERME_TRACE From LECFIC
            If GERR=1
              Call LEC_TRACE   From LECFIC
              # Si ctrl non bloquant et la répercussion n'est pas obligatoire on peut accepter les interdits
        #      If GDACLOK=2 & GLINBPD=2 & GLINREP=2
              If GDACLOK=2
                Local Integer WOK
                WOK=2 : Call AVERTIR (mess(27,192,1)-":"-mess(205,100,1), WOK) From GESECRAN
        #        If WOK=1 mkstat=2 : GERR=1 : FIN=1 : Return Endif
                If WOK=1 mkstat=2 : FIN=1 : Return Endif
              Else
                mkstat=2 : GERR=1 : GMESSAGE=mess(27,192,1)-":"-mess(9,123,1) : FIN=1 : Return
              Endif
            Endif
            # 79705 : SAT in SPRICLINK : Step 2
            # 79705 : V7 : SAT in SPRICLINK
            Global Char GADDACTMOD(GLONDES)
            GADDACTMOD = "1"
            # Recherche tarif déclenchée maintenant par l'action TRTRECTAR
            #Local Integer WOK
            #Call OUINON (mess(21,191,1),WOK) From GESECRAN
            #If WOK=2 GTARFLG="1" Endif
            # 79705 : V7 : SAT in SPRICLINK
        Endif
    When Default
Endcase
Return
# ------------------------------------------------------------------------------
$TERMINE_TRTMAJDET
FFLGMOD = PARAM(3)
#If find(FFLGMOD,"1","3")
    Local Char    WANCCUR(GLONCUR)    : WANCCUR=[M]CUR
    Local Char    WANCVACBPR(GLONTVB) : WANCVACBPR=[M]VACBPR
    Local Integer WANCPRITYP          : WANCPRITYP=[M]PRITYP
    # Bug 55405 : Si modif adr liv alors modif possible du régime
    #             [M]VACBPR étant déjà rechargé, raz ancienne valeur pour forcer les recalculs
    If WZONCOU="BPAADD" Raz WANCVACBPR Endif
    # Particularité selon les objets
    Case WOBJET
        When "SOH"
            Gosub RECALC_LIGNE From SUBSOHB
        When "SQH"
            Gosub RECALC_LIGNE From SUBSQHB
    When Default
Endcase
#Endif
Raz GTARFLG
If dim(SAVINDICE)>0 : indice = SAVINDICE : Endif #Fq74245-gbn
Return
# 79705 : V7 : SAT in SPRICLINK
# ------------------------------------------------------------------------------
$SORTIE_TRTMAJDET
If mkstat<>2 mkstat=SAVMKSTAT Endif     : # 79705 : SAT in SPRICLINK : Step 2
Return
# 79705 : V7 : SAT in SPRICLINK

#########################################################################
# Alimentation en AP_SALFCY                                             #
#########################################################################
$ALISALFCY
GFCY=VALEUR
# --> Réalimentation site fin.(GFINRSP), soc.(GSOCIETE), dev.soc.(GLOCALDEV)
If val(PARAM(1))=1
    Call GETDEV(GFCY) From DEVSUB
Endif
# --> Récupération des paramètres vente du site / de la société
Call GLOBVAR(GFCY,"VEN") From TRTX3

  # FGR 28/11/2011 : X3SUIVI71065
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
Return

#########################################################################
# Alimentation en AP_STOFCY                                             #
#########################################################################
$ALISTOFCY
GFCY=VALEUR
# --> Réalimentation site fin.(GFINRSP), soc.(GSOCIETE), dev.soc.(GLOCALDEV)
If val(PARAM(1))=1
    Call GETDEV(GFCY) From DEVSUB
Endif
# --> Récupération des paramètres stock du site / de la société
Call GLOBSTOFCY(GFCY) From TRTVENGLOB
Return

######################################################################
#                                                                    #
# Subprog ALIPCK (WITMREF, WSTOFCY,WPCK,WPCKCAP)                     #
#      Alimentation de l'emballage et de la capacité                 #
# Subprog RECH_CNTNAM (WBPCORD,WBPAADD,WCNTNAM)                      #
#      Recherche d'un contact lié à une adresse                      #
# Subprog CHARGE_ADRMSK(WABRMSK, WBPRNUM)                            #
#      Chargement d'une adresse tiers dans unn ecran adresse         #
# Subprog INIEECNUM (WBPCORD, WBPAADD, WBPCINV, WEECNUM)             #
#      Alimentation du n°identification CEE                          #
# Subprog SAMAPPFLG (WABMSK, NOLIG)                                  #
#      Test modif rubr. majeure pour raz signatures                  #
# Subprog ANNULE_SUIVI(WOBJET,WMOTIF,WMSGFLG,WRET)                   #
#      Positionnemnt indicateur "Annulé" sur lignes de suivi workflow#
#                                                                    #
######################################################################

################################################################################
# ---------------------------------------------------------------------------- #
# ---------------------------------------------------------------------------- #
#   WOBJET  : Code l'objet ("SQH","SOH","SOR")                                 #
#   WMOTIF  : Motif de l'annulation                                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                           1 = Erreur avec GOK=0 si bloquant)                 #
################################################################################


####################################################################
#------------------------------------------------------------------#
# Alimentation de l'emballage                                      #
#------------------------------------------------------------------#
# Entrée   WITMREF : Référence article                             #
#          WSTOFCY : Site expédition                               #
# Sortie   WPCK    : Code emballage                                #
#          WPCKCAP : Capacité d'emballage                          #
#------------------------------------------------------------------#
Subprog ALIPCK (WITMREF, WSTOFCY, WPCK, WPCKCAP)
Value    Char    WITMREF
Value    Char    WSTOFCY
Variable Char    WPCK
Variable Decimal WPCKCAP

If clalev([F:ITM]) = 0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITG]) = 0 Local File ITMCATEG   [ITG] : Endif

Local Integer WITF, WITG : Raz WITF, WITG
#--- Lecture article site
If [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>WSTOFCY
    Read [ITF]ITF0=WITMREF;WSTOFCY
    If fstat
        If [F:ITM]ITMREF<>WITMREF
            Read [ITM]ITM0=WITMREF : If fstat Raz [F:ITM] Endif
        Endif
        #--- Lecture catégorie article/site
        If [F:ITG]TCLCOD<>[F:ITM]TCLCOD | [F:ITG]STOFCY<>WSTOFCY
            Read [ITG]ITG1=[F:ITM]TCLCOD;WSTOFCY
            If fstat
                Read [ITG]ITG1=[F:ITM]TCLCOD;""
                If fstat Raz [F:ITG] Endif : WITG=1
            Else
                WITG=1
            Endif
        Else
            WITG=1
        Endif
    Else
        WITF=1
    Endif
Else
    WITF=1
Endif
If WITG
    #CPO 63410 - pb découvert lors de la correction de cette fiche
    # -- on prend le paramétragé de la catégorie article si l'UV de celle-ci = UV de [ITM]
    # -- (car avant appel à ALIPCK on teste si [ITM]SAU = [M:xxxn]SAU(NOL)
    If [F:ITM]SAU = [F:ITG]SAU
      WPCK    = [F:ITG]PCK
      WPCKCAP = [F:ITG]PCKCAP
    Endif
Elsif WITF
    WPCK    = [F:ITF]PCK
    WPCKCAP = [F:ITF]PCKCAP
Endif

End
#                                                                  #
####################################################################
#------------------------------------------------------------------#
# Recherche d'un contact lié à une adresse                         #
#------------------------------------------------------------------#
# Entrée   BPCORD  : Client                                        #
#          WBPAADD : Code adresse                                  #
# Sortie   WCNTNAM : Contact                                       #
#------------------------------------------------------------------#
Subprog RECH_CNTNAM(WBPCORD, WBPAADD, WCNTNAM)
Value    Char    WBPCORD
Value    Char    WBPAADD
Variable Char    WCNTNAM

# FGR 08/02/2013 : X3SUIVI87255 (début)
#If clalev([F:CNT]) = 0 Local File CONTACT    [CNT] : Endif
#If clalev([F:BPC]) = 0 Local File BPCUSTOMER [BPC] : Endif
  Local File CONTACT    [CNT]
  Local File BPCUSTOMER [BPC]
# FGR 08/02/2013 : X3SUIVI87255 (fin)

# On recherche d'abord si le contact par defaut du client est lié à ce code adresse
# Si oui, on le prend
If [F:BPC]BPCNUM <> WBPCORD
    Read [BPC]BPC0 = WBPCORD
    If fstat Raz [F:BPC] Endif
Endif
If [F:BPC]CNTNAM <> ""
    Read [CNT]CNT0=1;WBPCORD;[F:BPC]CNTNAM
    If !fstat
        If [F:CNT]BPAADD = WBPAADD WCNTNAM=[F:BPC]CNTNAM : End : Endif
    Endif
Endif
# On recherche ensuite s'il y a un contact pour ce code adresse
Filter [CNT] Where [CNT]BPATYP = 1 & [CNT]BPANUM = WBPCORD & [CNT]BPAADD = WBPAADD
Read [CNT]CNT0 First
If !fstat
# Si oui, on prend le 1er
    WCNTNAM=[F:CNT]CCNCRM
Else
# Si aucun contact avec ce code adresse : Récupération du contact par défaut du client
    WCNTNAM=[F:BPC]CNTNAM
Endif
Filter [CNT]
End


#------------------------------------------------------------------#
# Chargement d'une adresse tiers dans un ecran adresse             #
#------------------------------------------------------------------#
# Entrée   WABRMSK : Abréviation du masque adresse                 #
#          WBPRNUM : Code tiers                                    #
#------------------------------------------------------------------#
Subprog CHARGE_ADRMSK(WABRMSK, WBPRNUM)
Value Char    WABRMSK
Value Char    WBPRNUM

Local Char    WBPAADD
Local Integer I
If clalev([F:BPR]) = 0 Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC]) = 0 Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD] : Endif

If [F:BPR]BPRNUM<>WBPRNUM
    Read [BPR]BPR0 = WBPRNUM
    If fstat Raz [F:BPR] Endif
Endif
If [F:BPC]BPCNUM<>WBPRNUM
    Read [BPC]BPC0 = WBPRNUM
    If fstat Raz [F:BPC] Endif
Endif

WBPAADD = evalue("[M:"+WABRMSK+"]BPAADD")

If WBPAADD<>""
    Read [BPA]BPA0=1;WBPRNUM;WBPAADD
Elsif WABRMSK = "ADI4" & WBPAADD = "" : # ADI4: adr payeur
    Read [BPA]BPA0=1;WBPRNUM;[F:BPC]BPAPYR
Else
    Read [BPA]BPA0=1;WBPRNUM;[F:BPC]BPAADD
Endif
If fstat Raz [F:BPA] Endif

Assign "[M:"+WABRMSK+"]BPAADD"    With [F:BPA]BPAADD

Assign "[M:"+WABRMSK+"]BPRNAM(0)" With [F:BPR]BPRNAM(0)
Assign "[M:"+WABRMSK+"]BPRNAM(1)" With [F:BPR]BPRNAM(1)

If WABRMSK="ADB2" & WBPAADD<>""
    If [F:BPD]BPCNUM<>WBPRNUM | [F:BPD]BPAADD<>WBPAADD
        Read [BPD]BPD0 = WBPRNUM;WBPAADD
    Endif
    If [F:BPD]BPCNUM=WBPRNUM & [F:BPD]BPAADD=WBPAADD
        Assign "[M:"+WABRMSK+"]BPRNAM(0)" With [F:BPD]BPDNAM(0)
        Assign "[M:"+WABRMSK+"]BPRNAM(1)" With [F:BPD]BPDNAM(1)
    Endif
Endif
#If evalue("dim([M:"+WABRMSK+"]EECNUM)")>0
#    If evalue("[M:"+WABRMSK+"]EECNUM")=""
#        Assign "[M:"+WABRMSK+"]EECNUM" With [F:BPR]EECNUM
#    Endif
#Endif
For I=0 To 2
    Assign ("[M:"+WABRMSK+"]BPAADDLIG("+num$(I)+")") With evalue("[F:BPA]BPAADDLIG("+num$(I)+")")
Next
Assign "[M:"+WABRMSK+"]CRY"     With [F:BPA]CRY
Assign "[M:"+WABRMSK+"]CRYNAM"  With [F:BPA]CRYNAM
Assign "[M:"+WABRMSK+"]SAT"     With [F:BPA]SAT
Assign "[M:"+WABRMSK+"]POSCOD"  With [F:BPA]POSCOD
Assign "[M:"+WABRMSK+"]CTY"     With [F:BPA]CTY
Assign "[M:"+WABRMSK+"]ADBBPR"  With [F:BPR]BPRNUM
#LTA.sn
If WABRMSK = "ADB2" and dim([M:ADB2]ADRVAL) > 0
  Assign "[M:"+WABRMSK+"]ADRVAL"  With [F:BPA]ADRVAL
Endif
#LTA.en

End

#---------------------------------------------------------------------#
# Alimentation du n°identification CEE et du code pays associé        #
#---------------------------------------------------------------------#
# Entrée   WBPCORD    : Client commande                               #
#          WBPAADD    : Adresse de livraison                          #
#          WBPCINV    : Client facture                                #
# Sortie   WEECNUM    : N°identification CEE                          #
#          WEECNUMCRY : Code pays associé                             #
#---------------------------------------------------------------------#
Subprog INIEECNUM (WBPCORD, WBPAADD, WBPCINV, WEECNUM, WEECNUMCRY)
Value    Char   WBPCORD
Value    Char   WBPAADD
Value    Char   WBPCINV
Variable Char   WEECNUM
Variable Char   WEECNUMCRY
# Le n°identification CEE est issu du client livré ou du client facture
# Le code pays est le code pays de l'adresse de livraison ou du client facture

If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif

If WBPAADD<>""
    If [F:BPD]BPCNUM<>WBPCORD | [F:BPD]BPAADD<>WBPAADD
        Read [BPD] BPD0=WBPCORD;WBPAADD
        If fstat Raz [F:BPD] Endif
    Endif
    WEECNUM=[F:BPD]EECNUM
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WBPAADD
        Read [BPA]BPA0=1;WBPCORD;WBPAADD
        If fstat Raz [F:BPA] Endif
    Endif
    WEECNUMCRY=[F:BPA]CRY
Endif

If WEECNUM=""
    If [F:BPR]BPRNUM<>WBPCINV
        Read [BPR] BPR0=WBPCINV
        If fstat Raz [F:BPR] Endif
    Endif
    WEECNUM=[F:BPR]EECNUM
    # X3-101236 (LCC-23/07/18) Control "EU VAT no"
    #If WBPAADD="" WEECNUMCRY=[F:BPR]CRY Endif
    WEECNUMCRY=[F:BPR]CRY
    # X3-101236 (LCC-23/07/18) Control "EU VAT no"
Endif

End



#---------------------------------------------------------------------#
# ACA - 52052 - Alimentation des DSPLINWEI et DSPLINVOL               #
#---------------------------------------------------------------------#
# Entrée   NLIG       : Numéro de la ligne du document                #
#          Masque du document                                         #
#          [F:ITM]                                                    #
# Sortie   [M]DSPLINVOL(NLIG)                                         #
#          [M]DSPLINVOL(NLIG)                                         #
#---------------------------------------------------------------------#
$CALC_DSP

MNTCALC = [F:ITM]ITMWEI * [M]QTY(NLIG) * [M]SAUSTUCOE(NLIG)
Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,MNTCALC) From TRTX3
[M]DSPLINWEI(NLIG) = MNTCALC

MNTCALC = [F:ITM]ITMVOU * [M]QTY(NLIG) * [M]SAUSTUCOE(NLIG)
Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,MNTCALC) From TRTX3
[M]DSPLINVOL(NLIG) = MNTCALC

Return


########################################################################
#                                                                      #
# TRAITEMENTS LIES AU WORKFLOW                                         #
#                                                                      #
########################################################################
# SAMAPPFLG : S/P de test modification rubrique majeure   LD  20/04/10 #
#             pour reprise du cycle de signature                       #
#----------------------------------------------------------------------#
# Subprog SAMAPPFLG (WABMSK,NOLIG)                                     #
#   WABMSK  : Abréviation du masque écran contenant les lignes         #
#            si "" --> Mise à jour de l'indicateur GUPDAPPFLG          #
#   NOLIG   : Indice de la ligne active (nolign-1)                     #
#                                                                      #
# Attention : Ce S/P est appelé par une action "Après_Modif"           #
########################################################################
Subprog SAMAPPFLG (WABMSK,NOLIG)
Value  Char     WABMSK
Value  Integer  NOLIG

If WABMSK=""
    GUPDAPPFLG=2
Else
    Assign "[M:"+WABMSK+"]WUPDAPPFLG(NOLIG)"  With 2
Endif

End

################################################################################
# ANNULE_SUIVI : S/P Positionnement indicateur "Annulé"           LD 22/04/10  #
#                sur les lignes de suivi de workflow                           #
# ---------------------------------------------------------------------------- #
# Subprog ANNULE_SUIVI(WOBJET,WMOTIF,WMSGFLG,WRET)                             #
# ---------------------------------------------------------------------------- #
#   WOBJET  : Code l'objet ("SQH","SOH","SOR")                                 #
#   WMOTIF  : Motif de l'annulation                                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                           1 = Erreur avec GOK=0 si bloquant)                 #
################################################################################
Subprog ANNULE_SUIVI(WOBJET,WMOTIF,WMSGFLG,WRET)
Value    Char    WOBJET
Value    Char    WMOTIF
Value    Integer WMSGFLG
Variable Integer WRET
#----- Variables locales -----#
Local    Integer WTYPEVT,     WTYPEVT2
Local    Char    WCODEVT(10), WCODEVT2(10)
#-----
Raz [L]WRET
Case [L]WOBJET
  When "SQH" : [L]WTYPEVT=2 : [L]WCODEVT="SQH" : [L]WTYPEVT2=9 : [L]WCODEVT2="SQHSIG"
  When "SOH" : [L]WTYPEVT=2 : [L]WCODEVT="SOH" : [L]WTYPEVT2=9 : [L]WCODEVT2="SOHSIG"
  When "SOR" : [L]WTYPEVT=2 : [L]WCODEVT="SOR" : [L]WTYPEVT2=9 : [L]WCODEVT2="SOCSIG"
Endcase
#-----
Call ANNULE_SUIVI([L]WTYPEVT,[L]WCODEVT,0,[L]WRET,[L]WMOTIF,0) From AWRKDEL
If GOK<1  Gosub ERR_ANNULE_SUIVI : End : Endif
End
$ERR_ANNULE_SUIVI
#If [L]WMSGFLG=1
#  Case [L]WOBJET
#    When "SQH" : If GPURTRACE=1  GPURTRACE=2  Else  GPURTRACE=1 : Endif
#    When "SOH" : If GPURTRACE=1  GPURTRACE=2 : Endif
#    When "SOC"
#  Endcase
#Endif
Return


################################################################################
# DIVSQHAPP1 : Mise à jour indicateur signature d'un              LD  22/04/10 #
#              devis à la valeur 1 (non signé)                                 #
# ---------------------------------------------------------------------------- #
# Subprog DIVSQHAPP1 (WSQHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSQHAPP1.                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSQHNUM : Numéro du devis                                                  #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSQHAPP1(WSQHNUM,WMSGFLG)
Value    Char    WSQHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
Local    Char    WNUM(GLONVCR), WABREV, WTABLE
#-----
WABREV="SQH" : WNUM=WSQHNUM
WTABLE="SQUOTE"
#-----
Gosub DIVAPP1
End

$DIVAPP1
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_NUMAPP1
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub NUMAPP1
If GOK=-1  Goto ROLL_NUMAPP1 : Endif
If GOK=0   Goto AB_NUMAPP1   : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
Return

$ROLL_NUMAPP1
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  Return Else  Goto TR_NUMAPP1 : Endif
Else
  Return
Endif
#-----
$AB_NUMAPP1
If [L]WADXLOG=0
  Rollback
Endif
Return

#--------------------------------------------------------------#
# Traitement de la màj indicateur signature du document à 1    #
#--------------------------------------------------------------#
$NUMAPP1
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
#-----

If [L]WNUM=""  [L]WRET=11 : Gosub TRT_ERR_NUMAPP1 : Return : Endif
#----- Contrôle lock logique -----#
Call JELOCKE([L]WABREV+[L]WNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock=[L]WABREV+[L]WNUM
  If fstat        [L]WRET=12 : Gosub TRT_ERR_NUMAPP1 : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#-----
Case [L]WABREV
    When "SQH" :
        If !clalev([F:SQH])  Local File SQUOTE    [SQH] : Endif
        #----- Mise à 1 de l'indicateur du devis  -----#
        Update [SQH] Where SQHNUM=[L]WNUM With APPFLG=1
    When "SOH" :
        If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif
        #----- Mise à 1 de l'indicateur de la commande -----#
        Update [SOH] Where SOHNUM=[L]WNUM With APPFLG=1
Endcase
If fstat
    GOK=0   : Call FSTA([L]WABREV) From GLOCK
    [L]WRET=18 : Gosub TRT_ERR_NUMAPP1 : Goto FIN_NUMAPP1
Endif
#-----
$FIN_NUMAPP1
If [L]WLOCK  Unlock=[L]WABREV+[L]WNUM : Endif
Return
#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
# 11 = WSQHNUM Paramètre non renseigné                            #
# 12 = $SQUOTE xxxxxxxx Modification en cours sur un autre poste  #
# 18 = Erreur d'écriture sur le fichier SQUOTE xxxxxxxx           #
#-----------------------------------------------------------------#
$TRT_ERR_NUMAPP1
Case [L]WRET
  When 11 : [L]WMSG="W"+[L]WABREV+"NUM"-mess(136,199,1) : GOK=0
  When 12 : [L]WMSG="$"+[L]TABLE-[L]WNUM-mess(10,100,1) : GOK=0
  When 18 : [L]WMSG=mess(13,100,1)-[L]TABLE-[L]WNUM
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


################################################################################
# DIVSOHAPP1 : Mise à jour indicateur signature d'une             LD  22/04/10 #
#              commande à la valeur 1 (non signée)                             #
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHAPP1 (WSOHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSOHAPP1.                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande                                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHAPP1(WSOHNUM,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
Local    Char    WNUM(GLONVCR), WABREV, WTABLE
#-----
WABREV="SOH" : WNUM=WSOHNUM
WTABLE="SORDER"
#-----
Gosub DIVAPP1
End

################################################################################
# DIVSOHDUD  : Mise à jour des acomptes d'une commande            LD  14/05/10 #
#              lors de sa signature                                            #
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHDUD  (WSOHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSOHDUD .                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande                                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHDUD(WSOHNUM,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG

#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
##-----
$TR_SOHDUD
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub SOHDUD
If GOK=-1  Goto ROLL_SOHDUD  : Endif
If GOK=0   Goto AB_SOHDUD    : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End

$ROLL_SOHDUD
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  Return Else  Goto TR_SOHDUD : Endif
Else
  Return
Endif
#-----
$AB_SOHDUD
If [L]WADXLOG=0
  Rollback
Endif
Return

#--------------------------------------------------------------#
# Traitement de la création des acomptes                       #
#--------------------------------------------------------------#
$SOHDUD
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
#-----
If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif

If [L]WSOHNUM=""  [L]WRET=1 : Gosub TRT_ERR_SOHDUD  : Return : Endif
If [F:SOH]SOHNUM<>[L]WSOHNUM
    Read [SOH] SOH0=[L]WSOHNUM
    If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHDUD : Return : Endif
Endif
#----- Contrôle lock logique -----#
Call JELOCKE("SOH"+[L]WSOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="SOH"+[L]WSOHNUM
  If fstat  [L]WRET=3 : Gosub TRT_ERR_SOHDUD : Return  : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#----- Variables locales -----#
Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE  =GSOCIETE
Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV =GLOCALDEV
Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP   =GFINRSP
Local Integer SAV_GTYPGEN            : [L]SAV_GTYPGEN   =GTYPGEN
Local Integer SAV_GTYPANA            : [L]SAV_GTYPANA   =GTYPANA
Local Integer SAV_GNBCOA             : [L]SAV_GNBCOA    =GNBCOA
Local Char    SAV_GCOA(GLONCOA)   (1..10)  : # Codes plans
[L]SAV_GCOA(1)=GCOA(1):[L]SAV_GCOA(2)=GCOA(2):[L]SAV_GCOA(3)=GCOA(3):[L]SAV_GCOA(4)=GCOA(4):[L]SAV_GCOA(5)=GCOA(5)
[L]SAV_GCOA(6)=GCOA(6):[L]SAV_GCOA(7)=GCOA(7):[L]SAV_GCOA(8)=GCOA(8):[L]SAV_GCOA(9)=GCOA(9):[L]SAV_GCOA(10)=GCOA(10)

Local Char    WMODELE(GLONGCM)

Call GETDEV([F:SOH]SALFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[F:SOH]SALFCY : Endif
#----- Recherche du modèle comtable de la société -----#
Call SETGCM(GSOCIETE,[L]WMODELE) From CPTDIV
#----- Chargement codes plans, types de référentiel d'une société   -----#
Call SETPLAN3([L]WMODELE,GNBCOA,GCOA,GTYPLED) From CPTDIV

#----- Création des acomptes -----#
Call ACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&             [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&             1,[L]WRET) From TRTTPT
If GOK<1 [L]WRET=4 : Gosub TRT_ERR_SOHDUD : Return : Endif
#-----
$FIN_SOHDUD
If [L]WLOCK  Unlock="SOH"+[L]WSOHNUM : Endif

GSOCIETE  =[L]SAV_GSOCIETE
GLOCALDEV =[L]SAV_GLOCALDEV
GFINRSP   =[L]SAV_GFINRSP
GTYPGEN   =[L]SAV_GTYPGEN
GTYPANA   =[L]SAV_GTYPANA
GNBCOA    =[L]SAV_GNBCOA
GCOA(1)=[L]SAV_GCOA(1):GCOA(2)=[L]SAV_GCOA(2):GCOA(3)=[L]SAV_GCOA(3):GCOA(4)=[L]SAV_GCOA(4):GCOA(5)=[L]SAV_GCOA(5)
GCOA(6)=[L]SAV_GCOA(6):GCOA(7)=[L]SAV_GCOA(7):GCOA(8)=[L]SAV_GCOA(8):GCOA(9)=[L]SAV_GCOA(9):GCOA(10)=[L]SAV_GCOA(10)

Return
#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
#  1 = WSOHNUM Paramètre non renseigné                            #
#  2 = xxxxxxxxxx Pièce inexistante                               #
#  3 = $SORDER xxxxxxxx Modification en cours sur un autre poste  #
#  4 = xxxxxxxxxx Pb de mise à jour des acomptes                  #
#-----------------------------------------------------------------#
$TRT_ERR_SOHDUD
Case [L]WRET
  When 1 : [L]WMSG="WSOHNUM"-mess(136,199,1)  : GOK=0
  When 2 : [L]WMSG=[L]WSOHNUM-mess(261,197,1) : GOK=0
  When 3 : [L]WMSG="$SORDER"-[L]WSOHNUM-mess(10,100,1) : GOK=0
  When 4 : [L]WMSG=[L]WSOHNUM-mess(378,197,1) : GOK=0
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return

################################################################################
# DIVSOHWIP  : Mise à jour des encours article d'une commande     LD  17/05/10 #
#              Mise à jour de la table ORDERS et de la table ITMMVT            #
#              lors de sa signature                                            #
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHWIP  (WSOHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSOHWIP .                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande                                            #
#   WSIGN   : Sens de ma mise à jour (+1 = Mise à jour,                        #
#                                     -1 = Annulation)                         #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHWIP(WSOHNUM,WSIGN,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WSIGN
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
#-----

If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
##-----
$TR_SOHWIP
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub SOHWIP
If GOK=-1  Goto ROLL_SOHWIP  : Endif
If GOK=0   Goto AB_SOHWIP    : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End

$SOHWIP
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
Local    Char    WTRTORD
Local    Integer WSOPLIN, WSOQSEQ
Local    Decimal WCPLQTY, WQTY
Local    Char    WSENS
Local    Integer WWIPTYP      : # 91786
Local    Integer STAT         : # 91786
Local    Decimal WQTYITV      : # Issue 114550

#If WSIGN=-1 [L]WTRTORD="A" : [L]WSENS="-" Else [L]WTRTORD="C" : [L]WSENS="+" Endif
If WSIGN=-1 [L]WSENS="-" Else [L]WSENS="+" Endif

#-----
If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif
If !clalev([F:SOQ])  Local File SORDERQ   [SOQ] : Endif
If GMODU(6)=2
    If !clalev([F:POQ]) Local File PORDERQ [POQ] : Endif
Endif

# --- Déclaration classe ecran pour les encours --- #
If clalev([M:ORDK])=0 Local Mask ORDK [ORDK] Endif
Raz [M:ORDK]

# 91786
If !clalev([F:ORD])  Local File ORDERS    [ORD] : Endif
# --- Déclaration classe Buffer mise à jour OF --- #
If clalev([M:MFGK])=0 Local Mask MFGK [MFGK] Endif
Raz [M:MFGK]
# 91786

If [L]WSOHNUM=""  [L]WRET=1 : Gosub TRT_ERR_SOHWIP  : Return : Endif
# Issue 113857
# Il faut systématiquement lire [F:SOH] sinon [F:SOH]APPPFLG reste à 0 et n'est pas mis à 1
#If [F:SOH]SOHNUM<>[L]WSOHNUM
#    Read [SOH] SOH0=[L]WSOHNUM
#    If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHWIP : Return : Endif
#Endif
Read [SOH] SOH0=[L]WSOHNUM
If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHWIP : Return : Endif

# Ne plus supprimer systématiquement les allocations en cas d'annulation signature
# supprimer ssi la cde repasse à non signée : Suppression par la règle de workflow
# -- Nécessite la modification de la régle de workflow SOHSIG mais la table AWRKPAR est une table de paramétrage
#    dont la copie à partir du dossier de référence est conditionnelle et non automatique
#    --> Trop dangereux de modifier ce paramétrage en standard pour les versions en diffusion
#        car la copie ne sera pas forcément effectuée par le client
#    --> A partir de la V10 AVENGER, fait en standard
#        --------------------------
#        correction dans le source SUBSOHA + modification SOHSIG + Nouvelle action DIVSOHWIP1
#        Le sous-pro DIVSOHWIP est utilisé par 2 actions : DIVSOHWIP et DIVSOHWIP1
#        Différence entre les 2 : DIVSOHWIP1 enchaine l'action DIVSOHALL
#        On a pas le choix car nous sommes limités à 10 actions pour une règle de signature, on ne peut pas appeler directement DIVSOHALL
#
#        Dans le cas ou :
#        - SOHAPPORD=1 et GSOHAPPALL=1, encours pour les cdes non signées à Non, allocations à Non
#          On enchaine la suppression des encours et des allocations
#        - SOHAPPORD=2 et GSOHAPPALL=1, encours pour les cdes non signées à Oui, allocations à Non
#          bien qu'il ne faille pas supprimer les encours, il faut appeler l'action DIVSOHWIP1 pour supprimer les allocations
#          Il faut sortir tout de suite de SOHSOHWIP et exécuter DIVSOHALL
#    --> Versions antérieures, Solution spécifique
#        --------------------------
#        Utilisation du PE "DESALLSIG" pour correction dans SUBSOHA + modification manuelle SOHSIG + création manuelle DIVSOHWIP1

#If GSOHAPPORD=2 &  WSIGN=-1 Return Endif
If func AFNC.PARAM("SOHAPPORD",[F:SOH]SALFCY)="2" & WSIGN=-1 Return Endif
# End issue 113857

#----- Contrôle lock logique -----#
Call JELOCKE("SOH"+[L]WSOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="SOH"+[L]WSOHNUM
  If fstat  [L]WRET=3 : Gosub TRT_ERR_SOHWIP : Return  : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif

# On force APPFLG à 0 pr passage ds APPELWIP (On teste APPFLG mais içi il n'est pas encore maj par le workflow)
[F:SOH]APPFLG=0

For [SOQ] SOQ0 Where SOHNUM=[L]WSOHNUM
    Readlock [SOQ] Curr
    If fstat=1
        GOK=-1  : GLOCK="$SORDERQ"-[L]WSOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
        [L]WRET=5 : Gosub TRT_ERR_SOHWIP : Break
    Elsif fstat
        GOK=0   : Call RSTA("SOQ",[L]WSOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK
        [L]WRET=6 : Gosub TRT_ERR_SOHWIP : Break
    Endif
# 107888 : Scheduled invoices : (LD:20/05/16)
    #If [F:SOH]SOHCAT = 3
    If [F:SOH]SOHCAT = 3 | ([F:SOH]SOHCAT = 1 & [F:SOQ]DLVFLG=1)
        # --> Commande à facturation directe
        # --> Commande normale et ligne non livrable
# 107888 : Scheduled invoices : (LD:20/05/16)
        [L]WCPLQTY = [F:SOQ]INVQTYSTU
        # Calcul du reste à livrer
#        [L]WQTY = [F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU-[F:SOQ]ODLQTYSTU
        [L]WQTY = [F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU-[F:SOQ]ODLQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
    Else
        # --> Commande normale/prêt et ligne livrable       :  # 107888 : Scheduled invoices : (LD:20/05/16)
        [L]WCPLQTY = [F:SOQ]DLVQTYSTU
        # Calcul du reste à livrer
        [L]WQTY = [F:SOQ]QTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]ODLQTYSTU
    Endif

    # Issue 114550
    # Pour la lecture de l'enregistrement dans ORDERS
    If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2
       WWIPTYP  = 8 : # C'est une Demande inter_site/intra-société : TP
    Else
       WWIPTYP  = 1 : # C'est une Commande de vente  : SO
    Endif
    # End issue 114550

    #---------------------------------------------------------------------------------#
    # Mise à jour de l'encours dans la table ORDERS                                   #
    #---------------------------------------------------------------------------------#
    # Suppression de l'encours existant si annulation ou si la ligne est soldée ou en ctm directe ou non gérée en stock
    If WSIGN=-1 | ((([F:SOQ]SOQSTA=3 & [F:SOQ]ODLQTY=0) | [F:SOQ]FMI=2 | [F:SOQ]STOMGTCOD=1) & [F:SOQ]DEMNUM<>"")

        [L]WTRTORD="A"
        # 91786
        If WSIGN=-1
            # Annulation signature et Pas d'encours sur les cdes non signées et la cde passe de signée à non signée
            # Effectuer la suppression ssi l'encours existe (si cde non signée avt annulation signature, pas d'encours à supprimer)

            # Issue 114550
            # Annulation signature : Décrémentation de l'encde article
            # --> Il faut retrouver la qté à décrémenter ce n'est pas forcément la qté commandée
            # (Cas où c'est la modification de la qté qui a entrainé la suppression de la signature)
            # Si la qté cdée a été modifiée de 10 à 5, il ne faut pas décrémenter de 5 mais de 10 ...
#            If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2
#               WWIPTYP  = 8 : # C'est une Demande inter_site/intra-société : TP
#            Else
#               WWIPTYP  = 1 : # C'est une Commande de vente  : SO
#            Endif
#            Look [ORD]ORD0=WWIPTYP;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
#            If fstat Raz [L]WTRTORD Endif
            Read [ORD]ORD0=WWIPTYP;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
            If fstat
                Raz [L]WTRTORD
            Else
                [L]WQTYITV=[F:ORD]EXTQTY
            Endif
            # End issue 114550
        Endif
        If [L]WTRTORD<> ""
            # Suppression des affectations
            Gosub SUP_MTO_AV_SOQ From SALMTOLIB
        Endif
        # 91786
    Elsif [F:SOQ]DEMNUM<>""
        [L]WTRTORD="M"

        # Issue 114550
        # Modification de la cde avec signature : Modification de l'encde article
        # --> Il faut retrouver la qté à modifier ce n'est pas forcément la nouvelle qté commandée
        Read [ORD]ORD0=WWIPTYP;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
        If fstat
            Raz [L]WTRTORD
        Else
            [L]WQTYITV=[L]WQTY-[F:ORD]EXTQTY
        Endif
        # End issue 114550
    Else
        [L]WTRTORD="C"
        # 91786
        Call NUMERO(GWIP,[F:SOQ]STOFCY,[F:SOQ]ORDDAT,"",[F:SOQ]DEMNUM,STAT) From SUBANM
        If GOK<0 [L]WRET=8 : Gosub TRT_ERR_SOHWIP : Break Endif
        If STAT<>0 | GOK<1 [L]WRET=9 : Gosub TRT_ERR_SOHWIP : Break Endif
        # 91786

        # Issue 114550
        [L]WQTYITV=[L]WQTY
        # End issue 114550

    Endif
    # Annulation de signature
    If ([L]WTRTORD="C" & [F:SOQ]SOQSTA<>3 & [F:SOQ]STOMGTCOD>1) | [L]WTRTORD="M" | [L]WTRTORD="A"
        Gosub APPELWIP From TRTVENMAJ
        If GOK<1 Break : Endif
        If [L]WTRTORD="A" [F:SOQ]DEMNUM="" Endif
        # 91786
        If [L]WTRTORD="C" | [L]WTRTORD="M"
            # Maj des affectations
            If [F:SOQ]FMI=3 & [F:SOQ]FMINUM<>""
                Read [POQ]POQ0=[F:SOQ]FMINUM;[F:SOQ]FMILIN;[F:SOQ]FMISEQ
                If !fstat
                    Gosub CRE_MTO_SO_PO From PURMTOLIB
                Endif
            Elsif [F:SOQ]FMI=5 & [F:SOQ]FMINUM<>""
                [M:MFGK]MFGFCY   =[F:SOQ]STOFCY
                [M:MFGK]ITMREF   =[F:SOQ]ITMREF
                [M:MFGK]FMI      =[F:SOQ]FMI
                [M:MFGK]VCRNUMORI=[F:SOQ]SOHNUM
                [M:MFGK]VCRLINORI=[F:SOQ]SOPLIN
                [M:MFGK]VCRSEQORI=[F:SOQ]SOQSEQ
                [M:MFGK]MFGNUM   =[F:SOQ]FMINUM
                [M:MFGK]MFGLIN   =[F:SOQ]FMILIN
                # X3-69678 - STWIL - This sub-routine now creates an assignment between all type of demands and a work order
                Gosub CRE_MTO_SO_WO From MFGMTOLIB
            Else
                Gosub MAJ_MTO_SOQ From SALMTOLIB
            Endif
        Endif
        # 91786
    Endif

    #---------------------------------------------------------------------------------#
    # Maj des cumuls articles : En-cde client dans ITMMVT                             #
    #---------------------------------------------------------------------------------#
    # Pas de maj si article non géré en stock, ligne soldée ou ligne non ferme
    #If [F:SOQ]STOMGTCOD<>1 & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMSTA=1 : # 91786
    If [F:SOQ]STOMGTCOD<>1 & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMSTA=1 & [L]WTRTORD<>"" : # 91786
        # Issue 114550
        #Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, [L]WQTY, [L]WSENS, "S", [L]WRET) From TRTVENMAJ
        Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, [L]WQTYITV, [L]WSENS, "S", [L]WRET) From TRTVENMAJ
        If GOK<1 Break : Endif
        # End issue 114550
    Endif
    Rewrite [SOQ]
    If fstat
        GOK=0   : Call FSTA("SOQ") From GLOCK
        [L]WRET=7 : Gosub TRT_ERR_SOHWIP : Break
    Endif
Next
If GOK<1 Return Endif
#-----
$FIN_SOHWIP
If [L]WLOCK  Unlock="SOH"+[L]WSOHNUM : Endif
Return

$ROLL_SOHWIP
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  Return Else  Goto TR_SOHWIP : Endif
Else
  Return
Endif
#-----
$AB_SOHWIP
If [L]WADXLOG=0
  Rollback
Endif
Return

#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
#  1 = WSOHNUM Paramètre non renseigné                            #
#  2 = xxxxxxxxxx Pièce inexistante                               #
#  3 = $SORDER xxxxxxxx Modification en cours sur un autre poste  #
#  4 = xxxxxxxxxx Pb en mise à jour des encours                   #
#  5 = Erreur d'accès sur le fichier SORDERQ  xxxxxxxx            #
#  6 = xxxxxxxxxx 9999 Ligne de commande introuvable !            #
#  7 = Erreur d'écriture sur le fichier SORDERQ xxxxxxxx          #
#-----------------------------------------------------------------#
$TRT_ERR_SOHWIP
Case [L]WRET
  When 1 : [L]WMSG="WSOHNUM"-mess(136,199,1)  : GOK=0
  When 2 : [L]WMSG=[L]WSOHNUM-mess(261,197,1) : GOK=0
  When 3 : [L]WMSG="$SORDER"-[L]WSOHNUM-mess(10,100,1) : GOK=0
  When 4 : [L]WMSG=[L]WSOHNUM-mess(92, 197,1) : GOK=0
  When 5 : [L]WMSG=mess(12,100,1)-"SORDERQ"-[L]WSOHNUM
  When 6 : [L]WMSG=[L]WSOHNUM-num$([F:SOQ]SOPLIN)-mess(360,197,1)
  When 7 : [L]WMSG=mess(13,100,1)-"SORDERQ"-[F:SOQ]SOPLIN
  When 8 : [L]WMSG=mess(60,199,1)-"("+GWIP+") : "         : # 91786
  When 9 : [L]WMSG=mess(60,199,1)-"("+GWIP+") : "         : # 91786
           Gosub MESSAGE From SUBANM                      : # 91786
           [L]WMSG-=MESSA                                 : # 91786
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


################################################################################
# DIVSOHALL  : Mise à jour des allocations d'une commande     LD  11/06/10     #
#              Cas d'emploi :                                                  #
#              Désallocation d'une cde lors de l'annulation de la signature    #
#              Désallocation d'une cde si la cde passe de signée à non signée  # # 113857
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHALL  (WSOHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSOHALL .                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande                                            #
#   WSIGN   : Sens de ma mise à jour (+1 = Mise à jour,                        #
#                                     -1 = Annulation)                         #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHALL(WSOHNUM,WSIGN,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WSIGN
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
#-----

If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
##-----
$TR_SOHALL
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub SOHALL
If GOK=-1  Goto ROLL_SOHALL  : Endif
If GOK=0   Goto AB_SOHALL    : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End

$SOHALL
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
Local    Char    WTRTLIG, WTRTORD
Local    Integer WSOPLIN, WSOQSEQ
Local    Decimal WCPLQTY, WQTY
Local    Char    WSENS
Local    Decimal WALLQTYSTU, WSHTQTYSTU, WCPLQTY

[L]WTRTORD="M"
If WSIGN=-1 [L]WTRTLIG="A" : [L]WSENS="-" Else [L]WTRTLIG="C" : [L]WSENS="+" Endif


#-----
If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif
If !clalev([F:SOQ])  Local File SORDERQ   [SOQ] : Endif
If !clalev([F:SOP])  Local File SORDERP   [SOP] : Endif

# --- Déclaration classe ecran pour les allocations --- #
If clalev([M:STOK])=0 Local Mask STOK [STOK] Endif
Raz [M:STOK]
# --- Déclaration classe ecran pour les allocations --- #
If clalev([M:ALP])=0 Local Mask ALLPAR [ALP] Endif
Raz [M:ALP]
# --- Déclaration classe ecran pour les encours --- #
If clalev([M:ORDK])=0 Local Mask ORDK [ORDK] Endif
Raz [M:ORDK]

If [L]WSOHNUM=""  [L]WRET=1 : Gosub TRT_ERR_SOHALL : Return : Endif

# Issue 113857
# Il faut systématiquement lire [F:SOH] sinon [F:SOH]APPPFLG reste à 0 et n'est pas mis à 1
#If [F:SOH]SOHNUM<>[L]WSOHNUM
#    Read [SOH] SOH0=[L]WSOHNUM
#    If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHALL : Return : Endif
#Endif
Read [SOH] SOH0=[L]WSOHNUM
If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHALL : Return : Endif

# Ne plus supprimer systématiquement les allocations en cas d'annulation signature
# supprimer ssi la cde repasse à non signée : Suppression par la règle de workflow
# -- Nécessite la modification de la régle de workflow SOHSIG mais la table AWRKPAR est une table de paramétrage
#    dont la copie à partir du dossier de référence est conditionnelle et non automatique
#    --> Trop dangereux de modifier ce paramétrage en standard pour les versions en diffusion
#        car la copie ne sera pas forcément effectuée par le client
#    --> A partir de la V10 AVENGER, fait en standard
#        --------------------------
#        correction dans le source SUBSOHA + modification SOHSIG + Nouvelle action DIVSOHWIP1
#        Le sous-pro DIVSOHWIP est utilisé par 2 actions : DIVSOHWIP et DIVSOHWIP1
#        Différence entre les 2 : DIVSOHWIP1 enchaine l'action DIVSOHALL
#        On a pas le choix car nous sommes limités à 10 actions pour une règle de signature, on ne peut pas appeler directement DIVSOHALL
#
#        Dans le cas ou :
#        - SOHAPPORD=1 et SOHAPPALL=1, encours pour les cdes non signées à Non, allocations à Non
#          On enchaine la suppression des encours et des allocations
#        - SOHAPPORD=2 et SOHAPPALL=1, encours pour les cdes non signées à Oui, allocations à Non
#          bien qu'il ne faille pas supprimer les encours, il faut appeler l'action DIVSOHWIP1 pour supprimer les allocations
#          Il faut sortir tout de suite de SOHSOHWIP et exécuter DIVSOHALL
#        - SOHAPPORD=2 et SOHAPPALL=2, encours pour les cdes non signées à Oui, allocations à Oui
#          Il faut sortir tout de suite de SOHSOHWIP et de DIVSOHALL
#        - SOHAPPORD=1 et SOHAPPALL=2, encours pour les cdes non signées à Non, allocations à Oui
#          On enchaine la suppression des encours et des allocations
#    --> Versions antérieures, Solution spécifique
#        --------------------------
#        Utilisation du PE "DESALLSIG" pour correction dans SUBSOHA + modification manuelle SOHSIG + création manuelle DIVSOHWIP1

#If GSOHAPPORD=2 & GSOHAPPALL=2 & WSIGN=-1 Return Endif
If func AFNC.PARAM("SOHAPPORD",[F:SOH]SALFCY)="2" & func AFNC.PARAM("SOHAPPALL",[F:SOH]SALFCY)="2" & WSIGN=-1 Return Endif
# End issue 113857

#----- Contrôle lock logique -----#
Call JELOCKE("SOH"+[L]WSOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="SOH"+[L]WSOHNUM
  If fstat  [L]WRET=3 : Gosub TRT_ERR_SOHALL : Return  : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif

#----- Variables locales -----#
Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE  =GSOCIETE
Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV =GLOCALDEV
Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP   =GFINRSP
Local Char    SAV_GCURLEG(GLONADI)   : [L]SAV_GCURLEG   =GCURLEG
Local Integer SAV_GTYPGEN            : [L]SAV_GTYPGEN   =GTYPGEN
Local Integer SAV_GTYPANA            : [L]SAV_GTYPANA   =GTYPANA
Call GETDEV([F:SOH]SALFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[F:SOH]SALFCY : Endif
# --> Récupération du paramètre vente : GSOHAPPALL    : Allocation commandes non signées
Local Char     WPARAM(GLONADP)
Call PARAML([F:SOH]STOFCY,"SOHAPPALL",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSOHAPPALL= val(WPARAM)

For [SOQ] SOQ0 Where SOHNUM=[L]WSOHNUM & SOQSTA=1 & DEMSTA=1
    If sum([F:SOQ]ALLQTYSTU, [F:SOQ]SHTQTYSTU)<>0
        Readlock [SOQ] Curr
        If fstat=1
            GOK=-1  : GLOCK="$SORDERQ"-[L]WSOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
            [L]WRET=5 : Gosub TRT_ERR_SOHALL : Break
        Elsif fstat
            GOK=0   : Call RSTA("SOQ",[L]WSOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK
            [L]WRET=6 : Gosub TRT_ERR_SOHALL : Break
        Endif

        If [F:SOQ]STOMGTCOD>1
            If [F:SOP]SOHNUM<>[L]WSOHNUM | [F:SOP]SOPLIN<>[F:SOQ]SOPLIN | [F:SOP]SOPSEQ<>[F:SOQ]SOQSEQ
                Read [SOP] SOP0=[L]WSOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
                If fstat  [L]WRET=9 : Gosub TRT_ERR_SOHALL : Break : Endif
            Endif
            Local  Decimal  WALLQTYSTU, WSHTQTYSTU
            [L]WALLQTYSTU=[F:SOQ]ALLQTYSTU
            [L]WSHTQTYSTU=[F:SOQ]SHTQTYSTU
            Call GENALLORD("","","A", 1, 1, 0, [L]WALLQTYSTU, [L]WSHTQTYSTU, [L]WRET) From TRTVENALL
            If [L]WRET = 1 GOK=0 : [L]WRET=19 : Gosub TRT_ERR_SOHALL : Break : Endif
            If [L]WALLQTYSTU<>[F:SOQ]ALLQTYSTU | [L]WSHTQTYSTU<>[F:SOQ]SHTQTYSTU
                GOK=0 : [L]WRET=4 : Gosub TRT_ERR_SOHALL : Break
            Endif

            # --> Mise à jour de l'encours
            If [F:SOH]SOHCAT = 3
                [L]WCPLQTY = [F:SOQ]INVQTYSTU
            Else
                [L]WCPLQTY = [F:SOQ]DLVQTYSTU
            Endif

            # Issue 113857
            # Maj avant la maj de l'encours car la  maj de l'encours utilise ces valeurs
            [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
            [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
            # End Issue 113857

            WTRTORD = "M" : Gosub APPELWIP From TRTVENMAJ
            If GOK<1 Break : Endif

            # V6 Affectations
            Gosub MAJ_MTO_SOQ From SALMTOLIB
            # Issue 113857
        Else
            [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
            [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
            # End Issue 113857
        Endif

         # Issue 113857
#        [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
#        [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
         # End Issue 113857

        Rewrite [SOQ]
        If fstat
            GOK=0 : Call FSTA("SOQ") From GLOCK
            [L]WRET=7 : Gosub TRT_ERR_SOHALL : Break
        Endif
    Endif
Next
If GOK<1 Return Endif

#   -----------------------------------------------------------------------#
#   Mise à jour de l'entête commande                                       #
#   -----------------------------------------------------------------------#
# --> Décrémentation du nbre lignes à allouer
Raz [F:SOH]ALLLINNBR
# --> Mise à jour de l'état allocation
[F:SOH]ALLSTA = 1
#   ---------------------------------------------------------------------#
#    Point d'entree mise à jour de la commande                           #
#   ---------------------------------------------------------------------#
GPOINT="MAJCDEALL" : Gosub ENTREE From EXEFNC
If GOK < 1 : Goto FIN_SOHALL : Endif
# --> Reecriture de la commande
Rewrite [SOH]
If fstat
    GOK=0 : Call FSTA("SOH") From GLOCK :
    [L]WRET=8 : Gosub TRT_ERR_SOHALL : Goto FIN_SOHALL
Endif

#-----
$FIN_SOHALL
If [L]WLOCK  Unlock="SOH"+[L]WSOHNUM : Endif

GSOCIETE =[L]SAV_GSOCIETE
GLOCALDEV=[L]SAV_GLOCALDEV
GFINRSP  =[L]SAV_GFINRSP
GCURLEG  =[L]SAV_GCURLEG
GTYPGEN  =[L]SAV_GTYPGEN
GTYPANA  =[L]SAV_GTYPANA
Return

$ROLL_SOHALL
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  Return Else  Goto TR_SOHALL : Endif
Else
  Return
Endif
#-----
$AB_SOHALL
If [L]WADXLOG=0
  Rollback
Endif
Return

#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
#  1 = WSOHNUM Paramètre non renseigné                            #
#  2 = xxxxxxxxxx Pièce inexistante                               #
#  3 = $SORDER xxxxxxxx Modification en cours sur un autre poste  #
#  4 = xxxxxxxxxx Problème de mise à jour des allocations         #
#  5 = Erreur d'accès sur le fichier SORDERQ  xxxxxxxx            #
#  6 = xxxxxxxxxx 9999 Ligne de commande introuvable !            #
#  7 = Erreur d'écriture sur le fichier SORDERQ xxxxxxxx          #
#  8 = Erreur d'écriture sur le fichier SORDER  xxxxxxxx          #
#  9 = xxxxxxxxxx 999999 9999 Pièce inexistante                   #
#-----------------------------------------------------------------#
$TRT_ERR_SOHALL
Case [L]WRET
  When 1 : [L]WMSG="WSOHNUM"-mess(136,199,1)  : GOK=0
  When 2 : [L]WMSG=[L]WSOHNUM-mess(261,197,1) : GOK=0
  When 3 : [L]WMSG="$SORDER"-[L]WSOHNUM-mess(10,100,1) : GOK=0
  When 4 : [L]WMSG=[F:SOQ]ITMREF-mess(96,197,1)
  When 5 : [L]WMSG=mess(12,100,1)-"SORDERQ"-[L]WSOHNUM
  When 6 : [L]WMSG=[L]WSOHNUM-num$([F:SOQ]SOPLIN)-mess(360,197,1)
  When 7 : [L]WMSG=mess(13,100,1)-"SORDERQ"-[F:SOQ]SOPLIN
  When 8 : [L]WMSG=mess(13,100,1)-"SORDER"-[L]WSOHNUM
  When 9 : [L]WMSG=[L]WSOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)-mess(261,197,1) : GOK=0
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


################################################################################
# DIVSOHOST  : Mise à jour des encours client  d'une commande     LD  17/05/10 #
#              lors de sa signature                                            #
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHOST  (WSOHNUM,WMSGFLG)                                         #
#   Sous-programme appelé par l'action DIVSOHOST .                             #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande                                            #
#   WSIGN   : Sens de ma mise à jour (+1 = Mise à jour,                        #
#                                     -1 = Annulation)                         #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHOST(WSOHNUM,WSIGN,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WSIGN
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG

#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
##-----
$TR_SOHOST
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub SOHOST
If GOK=-1  Goto ROLL_SOHOST  : Endif
If GOK=0   Goto AB_SOHOST    : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End

$SOHOST
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
Local    Char    WSENS
Local    Char    WGREP
If WSIGN=+1 WSENS="+" Else WSENS="-" Endif
If WSIGN=-1 WGREP=""  Else WGREP="C" Endif : # A voir
#-----
If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif

If [L]WSOHNUM=""  [L]WRET=1 : Gosub TRT_ERR_SOHOST  : Return : Endif
If [F:SOH]SOHNUM<>[L]WSOHNUM
    Read [SOH] SOH0=[L]WSOHNUM
    If fstat  [L]WRET=2 : Gosub TRT_ERR_SOHOST : Return : Endif
Endif
#----- Contrôle lock logique -----#
Call JELOCKE("SOH"+[L]WSOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="SOH"+[L]WSOHNUM
  If fstat  [L]WRET=3 : Gosub TRT_ERR_SOHOST : Return  : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#----- Variables locales -----#
Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE  =GSOCIETE
Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV =GLOCALDEV
Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP   =GFINRSP
Local Char    SAV_GCURLEG(GLONADI)   : [L]SAV_GCURLEG   =GCURLEG
Local Integer SAV_GTYPGEN            : [L]SAV_GTYPGEN   =GTYPGEN
Local Integer SAV_GTYPANA            : [L]SAV_GTYPANA   =GTYPANA
Call GETDEV([F:SOH]SALFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[F:SOH]SALFCY : Endif
# Maj sf si commande non signée ou cde intra-société
If !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
    # Maj mouvement client (en commande client cde)
    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&       [F:SOH]ORDNOT, [F:SOH]ORDATI, [L]WSENS, "C", "", [F:SOH]SOHCAT) From TRTBPMVT          : # Bug 70837
#&       [F:SOH]DLRNOT, [F:SOH]DLRATI, [L]WSENS, "C", "", [F:SOH]SOHCAT) From TRTBPMVT         : # Bug 70837
    If GOK<1 [L]WRET=4 : Gosub TRT_ERR_SOHOST : Return : Endif

    # Maj mouvement client (en commande)
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:12/12/16)
    Local Decimal WORDBPINOT, WORDBPIATI
    # On order amount : To deliver amount for deliverable products + To scheduled invoice amount for undeliverable products
    WORDBPINOT = [F:SOH]DLRNOT+[F:SOH]INRSCHNOT
    WORDBPIATI = [F:SOH]DLRATI+[F:SOH]INRSCHATI
#    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
#&       [F:SOH]DLRNOT, [F:SOH]DLRATI, [L]WSENS, "F", [L]WGREP, [F:SOH]SOHCAT) From TRTBPMVT
#    If GOK<1 [L]WRET=4 : Gosub TRT_ERR_SOHOST : Return : Endif
    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&       WORDBPINOT, WORDBPIATI, [L]WSENS, "F", [L]WGREP, [F:SOH]SOHCAT) From TRTBPMVT
    If GOK<1 [L]WRET=4 : Gosub TRT_ERR_SOHOST : Return : Endif
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:12/12/16)

Endif
#-----
$FIN_SOHOST
If [L]WLOCK  Unlock="SOH"+[L]WSOHNUM : Endif
Return

$ROLL_SOHOST
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  Return Else  Goto TR_SOHOST : Endif
Else
  Return
Endif
#-----
$AB_SOHOST
If [L]WADXLOG=0
  Rollback
Endif
Return

#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
#  1 = WSOHNUM Paramètre non renseigné                            #
#  2 = xxxxxxxxxx Pièce inexistante                               #
#  3 = $SORDER xxxxxxxx Modification en cours sur un autre poste  #
#  4 = xxxxxxxxxx Pb en mise à jour des mouvements client         #
#-----------------------------------------------------------------#
$TRT_ERR_SOHOST
Case [L]WRET
  When 1 : [L]WMSG="WSOHNUM"-mess(136,199,1)  : GOK=0
  When 2 : [L]WMSG=[L]WSOHNUM-mess(261,197,1) : GOK=0
  When 3 : [L]WMSG="$SORDER"-[L]WSOHNUM-mess(10,100,1) : GOK=0
  When 4 : [L]WMSG=[L]WSOHNUM-mess(769,197,1) : GOK=0
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return

#CPO 63410
####################################################################
#------------------------------------------------------------------#
# Alimentation de la capacité de l'emballage                       #
#------------------------------------------------------------------#
# Entrée   WITMREF : Référence article                             #
#          WSTOFCY : Site expédition                               #
#          WSAU    : Unité de vente
#          WPCK    : Code emballage                                #
# Sortie   WPCKCAP : Capacité d'emballage                          #
#------------------------------------------------------------------#
Subprog AMPCK(WITMREF, WSTOFCY, WSAU, WPCK, WPCKCAP)
Value    Char    WITMREF
Value    Char    WSTOFCY
Value    Char    WSAU
Value    Char    WPCK
Variable Decimal WPCKCAP

If clalev([F:ITM]) = 0 Local File ITMMASTER  [ITM] : Endif :# Article
If clalev([F:ITF]) = 0 Local File ITMFACILIT [ITF] : Endif :# Article-site
If clalev([F:ITG]) = 0 Local File ITMCATEG   [ITG] : Endif :# Catégorie article
If clalev([F:ITU]) = 0 Local File ITMBPC     [ITU] : Endif :# Article-client

If WPCK <> ""
  #Un code emballage est renseigné
  # - il faut alimenter la capacité mais uniquement si
  #   UV lig cde = UV du paramétrage et Code emballage saisi = Code emballage paramétrage
  # -- On cheche d'abord l'Article-client
  If [F:ITU]ITMREF <> WITMREF | [F:ITU]BPCNUM <> WSTOFCY
    Read [ITU] ITU0=WITMREF;WSTOFCY
    If fstat Raz [F:ITU] Endif
  Endif
  If WPCK = [F:ITU]PCK and WSAU = [F:ITU]SAU
    WPCKCAP = [F:ITU]PCKCAP : End
  Else
    # -- Si pas la même UV, on cherche l'article-site
    If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> WSTOFCY
      Read [ITF]ITF0=WITMREF;WSTOFCY
      If fstat
          If [F:ITM]ITMREF <> WITMREF
              Read [ITM]ITM0 = WITMREF : If fstat Raz [F:ITM] Endif
          Endif
      Endif
    Endif
    If WPCK = [F:ITF]PCK and WSAU = [F:ITM]SAU
      WPCKCAP = [F:ITF]PCKCAP : End
    Else
      # -- Si pas la même UV, on cherche la catégorie article
      If [F:ITG]TCLCOD <> [F:ITM]TCLCOD | [F:ITG]STOFCY <> WSTOFCY
        Read [ITG]ITG1=[F:ITM]TCLCOD;WSTOFCY
        If fstat
          Read [ITG]ITG1=[F:ITM]TCLCOD;"" :  If fstat Raz [F:ITG] Endif
        Endif
      Endif
      If WPCK = [F:ITG]PCK and WSAU = [F:ITG]SAU
        WPCKCAP = [F:ITG]PCKCAP : End
      Else
        Raz WPCKCAP  : End
      Endif
    Endif
  Endif
Endif

End
#################################################################################
#  Sous-pro appelé en suppression d'une ligne d'un document déjà créé
#   Sert à envoyer un message d'avertissement si la ligne provient d'un document
#   d'origine ayant des élements de facturation
#   (car pas de re-calcul des elts en modification)
#  Paramètres :
#               PABREV "SOH" Cde / "SDH" Livr / "SIH" Fact
#               PNOL   nolign-1
#  En Sortie :
#               VRET à 1 s'il faut afficher le message d'information
#################################################################################
#--CPO 79343
Subprog CTLSUPP_EXISTDSP(PABREV,PNOL,VRET)
Value Char       PABREV
Value Integer    PNOL
Variable Integer VRET

Raz VRET

#--Aucun contrôle si nous sommes en création ou pas d'abréviation passée
If PNOL<0 or PABREV="" or GREP="C" : End : Endif

If clalev([F:SVF])=0 : Local File SVCRFOOT [SVF] : Endif
#--Sauvegarde
Local Shortint WSAVE_GCURRLEN : WSAVE_GCURLEN=[G:SVF]currlen
Local Shortint WSAVE_GCURRIND : WSAVE_GCURIND=[G:SVF]currind

Local Integer WVCRTYP
Local Char    WVCRNUM(GLONVCR)

# Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
Local Integer WFSTAT1,WFSTAT2 : WFSTAT1=0 : WFSTAT2=0

Case PABREV
  When "SOH"
    #--Ligne d'une commande : origine devis
    If [M:SOH4]DETSQHNUM(PNOL)="" Goto END1 Endif

    #--La commande doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= [M:SOH0]SOHNUM
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT1=fstat

    #--Le devis d'origine doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= [M:SOH4]DETSQHNUM(PNOL)
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT2=fstat

    If WFSTAT1>0 and WFSTAT2>0 Goto END1 Endif # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice

    #--Arrivés ici nous avons un doc d'origine ayant des elts de fact
    #--Message d'avertissement !
    VRET = 1

  When "SDH"
    #--Ligne livraison : origine cde ou bon de préparation BP
    #--(BP d'une cde => le n° cde à l'origine du BP est renseigné sur la ligne de livr.)
    If [M:SDH1]XSOHNUM(PNOL)="" : Goto END1 : Endif

    #--La livraison doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= [M:SDH0]SDHNUM
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT1=fstat

    #--La cde d'origine doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= [M:SDH1]XSOHNUM(PNOL)
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT2=fstat

    If WFSTAT1>0 and WFSTAT2>0 Goto END1 Endif # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice

    #--Arrivés ici nous avons un doc d'origine ayant des elts de fact
    #--Message d'avertissement !
    VRET = 1

  When "SIH"
    # 107888 : Scheduled invoices : (LD:11/05/16)
    #--Facture origine Cde,Livr,Fact,Devis ou échéance
    #If !find([M:SIH1]SIHORI,2,3,4,5) : Goto END1 Endif
    If !find([M:SIH1]SIHORI,2,3,4,5,10) : Goto END1 Endif
    # 107888 : Scheduled invoices : (LD:11/05/16)

    #--Ligne facture : origine cde, livraison ou facture (si avoir)
    If [M:SIH4]SQHNUM(PNOL)="" and [M:SIH4]SOHNUM(PNOL)="" and [M:SIH4]SDHNUM(PNOL)="" and [M:SIH4]XSIHORINUM(PNOL)="" Goto END1 : Endif

    #--La facture doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= [M:SIH0]NUM
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT1=fstat

    Raz WVCRNUM
    Case [M:SIH1]SIHORI
      When 2 : WVCRNUM=[M:SIH4]SOHNUM(PNOL)
      When 3 : WVCRNUM=[M:SIH4]SDHNUM(PNOL)
      When 4 : WVCRNUM=[M:SIH4]XSIHORINUM(PNOL)
      When 5 : WVCRNUM=[M:SIH4]SQHNUM(PNOL)
        # 107888 : Scheduled invoices : (LD:11/05/16)
      When 10 :
        # For the moment, we manage only scheduled invoices from order
        # This will have to be changed when we'll manage other scheduled invoices
        If [M:SIH4]VCRINVCNDTYP(PNOL)=10 & [M:SIH4]VCRINVCNDLIN(PNOL)>0  WVCRNUM=[M:SIH4]SOHNUM(PNOL) Endif
        # 107888 : Scheduled invoices : (LD:11/05/16)
      When Default : Goto END1
    Endcase
    If WVCRNUM="" Goto END1 Endif
    #--Le document d'origine doit avoir des élements de facturation non nuls
    Look [F:SVF]SVF0(1)= WVCRNUM
    # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice
    #If fstat Goto END1 Endif
    WFSTAT2=fstat

    If WFSTAT1>0 and WFSTAT2>0 Goto END1 Endif # Issue 115279 - 2016-03-18 by CPO : Picking a delivery with inv. elements in an existing invoice

    #--Arrivés ici nous avons un doc d'origine ayant des elts de fact
    #--Message d'avertissement !
    VRET = 1

  When Default : Goto END1
Endcase

$END1
#--Restauration
[G:SVF]currlen=WSAVE_GCURLEN
[G:SVF]currind=WSAVE_GCURIND

End

