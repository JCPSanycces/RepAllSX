#########################################################
Subprog  CAL_DOT_TX_MENSUEL
&      ( PTABTX, PNBTX, PDBTX, PBASAMTRGL, PRGLTXAMT, PRGLAMTMIN, PTXAMTMIN, PRGLAMTMAX, PTXAMTMAX,
&        PDTDB, PDTFN, PDUREXEREF, PDTDBAMT, PDURAMT, PDTFNAMT, PDATSOR,
&        PBASAMTFIC, PVALRES, PVLNAMT, RDOT )
#
# - Objet  : Calcule d'une dotation selon la règle BASE X TAUX MENSUEL
#
#
# - Entrée : [M:DOT] Structure Cdota
#
#            PTABTX        Table des taux mensuels
#            PNBTX         Nombre de taux à considérer dans la table des taux mensuels
#            PDBTX         Indic  de début des taux à considérer dans la table des taux mensuels
#            PBASAMTRGL    Base calculée selon règle
#            PRGLTXAMT     Règle application taux
#            PRGLAMTMIN    Règle amortissement minimum
#            PTXAMTMIN     Taux amortissement minimum
#            PRGLAMTMAX    Règle amortissement maximum
#            PTXAMTMAX     Taux amortissement maximum
#            PDTDB         Date de début exercice
#            PDTFN         Date de fin exercice
#            PDUREXEREF    Durée exercice de reference
#            PDTDBAMT      Date de début d'amortissement
#            PDURAMT       Date d'amortissement
#            PDTFNAMT      Date de fin d'amortissement
#            PDATSOR       Date de sortie
#            PBASAMTFIC    Base d'amortissement ficher
#            PVALRES       Valeur résiduelle
#            PVLNAMT       Valeur nette amortissable
#
# - Sortie :
#            RDOT      Dotation
#
#   Boite noire GCFC47
#
#
Value Decimal     PTABTX(0..)      : # Table des taux mensuels
Value Integer     PNBTX            : # Nombre de taux à considérer dans la table des taux mensuels
Value Integer     PDBTX            : # Indice début des taux dans la table des taux mensuels
Value Decimal     PBASAMTRGL       : # Base calculée selon règle
Value Integer     PRGLTXAMT        : # Règle application taux
Value Integer     PRGLAMTMIN       : # Règle amortissement plancher
Value Decimal     PTXAMTMIN        : # Taux plancher
Value Integer     PRGLAMTMAX       : # Règle amortissement plafond
Value Decimal     PTXAMTMAX        : # Taux plafond
Value Date        PDTDB            : # Date de début (exercice/période)
Value Date        PDTFN            : # Date de fin (exercice/période)
Value Decimal     PDUREXEREF       : # Durée de l'exercice de référence
Value Date        PDTDBAMT         : # Date de début d'amortissement
Value Decimal     PDURAMT          : # Durée d'amortissement
Value Date        PDTFNAMT         : # Date de fin d'amortissement
Value Date        PDATSOR          : # Date de sortie
Value Decimal     PBASAMTFIC       : # Base d'amortissement fichier
Value Decimal     PVALRES          : # Valeur residuelle
Value Decimal     PVLNAMT          : # Valeur nette amortissable
Variable Decimal  RDOT  : RDOT = 0 : # Dotation


Local Integer LIND     : # Indice
Local Date    LDTDBCUR : # Date début mois courant
Local Date    LDTFNCUR : # Date fin mois courant
Local Decimal LZERO    : LZERO = 0.     : # Constante à 0.

Local Decimal WTX      : WTX = 0.       : # Taux de la mensualité
Local Decimal WDOT     : WDOT = 0.      : # Dotation de la mensualité
Local Decimal WAMTMIN  : WAMTMIN  = 0.  : # Amortissement minimum
Local Decimal WAMTMAX  : WAMTMAX  = 0.  : # Amortissement maximum


  # Recherche du nombre de mois séparant
  # la date de début d'amortissement de celle passée en paramètre
  LIND=1
  LDTDBCUR = PDTDBAMT
  # >>>>>>>
  # Jusqu'à ce que la date de début du mois courant se situe dans l'intervalle à calculer
  While ( LDTDBCUR < PDTDB )
    # Incrémentation de l'indice du mois courant dans la table des taux mensuels
    LIND +=1
    # Positionnement de la Date de début au même jour mais du mois suivant
    LDTDBCUR = func GLOBB9.CAL_DAT_PLUS( LDTDBCUR, 1, "M" )
  Wend
  # <<<<<<<

  # Date de fin du mois courant cadrée sur fin du mois de la date de début
  LDTFNCUR = func GLOBB9.CAL_DAT_DERN( LDTDBCUR , "M" )

  # Calcul de la dotation pour l'intervalle considéré. Elle est
  # égale au cumul des dotations mensuelles successives obtenues
  # en appliquant à la base le taux mensuel correspondant.

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  WDOT = 0
  # >>>>>>>>>>>>
  # Tant que
  # la date de fin du mois courant n'est pas supérieure à la date de sortie ( si renseignée ) ET
  # la date de fin du mois courant n'est pas supérieure à la date de fin d'amortissement      ET
  # la date de fin du mois courant n'est pas supérieure à la date de fin de l'intervalle
  While ( ( PDATSOR = [0/0/0] or PDATSOR >= LDTFNCUR )
&   and ( PDTFNAMT >= LDTFNCUR) and ( PDTFN >= LDTFNCUR)   )

    #-----------
    # Récupération du taux correspondant à la mensualité
    If ( LIND > PNBTX ) Then
      # Au delà des limites du tableau le dernier taux mensuel est constant
      If ( PNBTX > 0 ) Then : WTX = PTABTX((PDBTX+PNBTX-1)-1) : Else : WTX = 0 : Endif
    Else
    #-----------
      # Taux de la mensualité
      WTX = PTABTX((LIND+PDBTX-1)-1)
    Endif
    #-----------

    # Dotation mensuelle (non arrondie)
    WDOT = PBASAMTRGL * WTX

    # Détermination amortissement minimum selon règle plancher
    Call CAL_AMT_MINIMUM_SELON_REGLE
&       ( [M:DPM]MINDPRTYP([M:DIV]INDMOD-1),
&         [M:DPM]MINDPRRAT([M:DIV]INDMOD-1),LZERO, LZERO, LZERO,
&         PDTDB, PDTDBAMT, PDURAMT, PDTFNAMT,
&         PBASAMTFIC, PVALRES, PVLNAMT,  WAMTMIN ) From =G_GLOB7
    #Call CAL_ARRONDI_MNT (WAMTMIN , [M:DIV]CUR , WAMTMIN ) From =G_GLOB8
    [M:DIV]PV(0)= WAMTMIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WAMTMIN = [M:DIV]RV(1)


    # Détermination amortissement maximum selon règle plafond
    Call CAL_AMT_MAXIMUM_SELON_REGLE
&       ( [M:DPM]MAXDPRTYP([M:DIV]INDMOD-1),
&         [M:DPM]MAXDPRRAT([M:DIV]INDMOD-1), LZERO, LZERO,
&         WDOT, PBASAMTFIC, PVALRES, PVLNAMT, WAMTMAX ) From =G_GLOB7
    #Call CAL_ARRONDI_MNT (WAMTMAX , [M:DIV]CUR , WAMTMAX ) From =G_GLOB8
    [M:DIV]PV(0)= WAMTMAX : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WAMTMAX = [M:DIV]RV(1)

    # Ajustement de la dotation mensuelle par rapport au plancher et plafond d'amortissement
    If ( abs(WDOT) < abs(WAMTMIN) ) Then
      WDOT = WAMTMIN
    Endif
    If ( abs(WDOT) > abs(WAMTMAX) ) Then
      WDOT = WAMTMAX
    Endif

    # Dotation mensuelle ajoutée à la dotation de l'intervalle
    RDOT += WDOT
    # Positionnement de la date de fin du mois courant au même jour mais du mois suivant
    LDTFNCUR = func GLOBB9.CAL_DAT_PLUS( LDTFNCUR, 1, "M" )
    # Incrémentation de l'indice du mois courant dans la table des taux mensuels
    LIND +=1
  Wend
  # <<<<<<<<<<<<

End

#
#########################################################
Subprog CAL_DATE_DEB_AMT_SELON_REGLE
&       ( PRGLDEBAMT, PDTDBAMT, PDTDBEXI, PDTFNEXI, PDTDBEXIS, PTYPPRO, RDTDBAMTREG )
#
# - Objet  : Renvoie la date de début d'amortissement régularisée selon la règle pécisée
#
#
# - Entrée : [M:CNT]
#            Règle début d'amortissment
#            Date de début d'amortissement (fichier)
#            Date début d'exercice d'investissement
#            Date fin d'exercice d'investissement
#            Date début d'exercice suivant d'investissement
#            Type de prorata
# - Sortie : Date de début d'amortissement régularisée

#   Boite noire gcfc6c
#
Value    Integer   PRGLDEBAMT
Value    Date      PDTDBAMT
Value    Date      PDTDBEXI
Value    Date      PDTFNEXI
Value    Date      PDTDBEXIS
Value    Integer   PTYPPRO
Variable Date      RDTDBAMTREG : RDTDBAMTREG = [0/0/0]

Local    Date      WDTDBSEM
Local    Date      WDTDBEXI, WDTFNEXI


    # Calcul de la date de début d'amortissement régularisée selon règle
    Case PRGLDEBAMT
      When GVML_DAJOURP
        # AU JOUR PRES
        RDTDBAMTREG = PDTDBAMT
      When GVML_DA1ERM
        # AU 1er JOUR DU MOIS d'investissement
        RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
      When GVML_DA1ERMS
        # AU 1er JOUR DU MOIS SUIVANT l'investissement
        RDTDBAMTREG = func GLOBB9.CAL_DAT_PLUS( gdat$(01,month(PDTDBAMT),year(PDTDBAMT)), 1, "M" )
      When GVML_DA1ERE
        # AU 1er JOUR DE L'EXERCICE d'investissement
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, PDTDBEXI, "D", RDTDBAMTREG) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= PDTDBEXI : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        RDTDBAMTREG = [M:DIV]RD(0)
      When GVML_DA1ERES
        # AU 1er JOUR DE L'EXERCICE SUIVANT l'investissement
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, PDTDBEXIS, "D", RDTDBAMTREG) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= PDTDBEXIS : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        RDTDBAMTREG = [M:DIV]RD(0)
      When GVML_DA1ERS
        # AU 1er JOUR DU SEMESTRE d'investissement
        # -- calcul date du début du deuxième semestre
        # -- ajout  du nombre de mois de l'ex d'invest /2  à la date de début de l'ex d'invest
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, PDTDBEXI, "D", WDTDBEXI) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= PDTDBEXI : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTDBEXI = [M:DIV]RD(0)
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, PDTFNEXI, "F", WDTFNEXI) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= PDTFNEXI : [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTFNEXI = [M:DIV]RD(0)
        Call CAL_DAT_DEBUT_SEMESTRE ( WDTDBEXI, WDTFNEXI, PDTDBAMT,  RDTDBAMTREG ) From =G_GLOB9
      When Default
        RDTDBAMTREG = PDTDBAMT
    Endcase

End

#
#########################################################
Subprog CAL_DATE_SORTIE_SELON_REGLE( PRGLDATSOR,  PDATSOR, PTYPPRO, RDATSORREG )
#
# - Objet  : Renvoie la date de sortie régularisée selon la règle pécisée
#            Cette fonction traite
#                  1°) la règle de sortie précisée pour un mode libre - ML324
#                      (menu également utilisé pour la règle de fin d'amort. du mode libre)
#                  2°) la règle de sortie précisée lors de la sortie  - ML474
#
#
# - Entrée : [M:CNT]
#            Règle date de sortie
#            Date de sortie (fichier)
#            Type de prorata
# - Sortie : Date de sortie régularisée

#   Boite noire gcfc6h
#
Value    Integer   PRGLDATSOR
Value    Date      PDATSOR
Value    Integer   PTYPPRO
Variable Date      RDATSORREG  : RDATSORREG = [0/0/0]

Local    Date      WDTDBEXE, WDTFNEXE
Local    Date      WDTDBSEM
Local    Integer   WINDEXE

    # FQ54343
    # Si la date de sortie est à 0 aucune règle n'est applicable
    If ( PDATSOR = [0/0/0] ) Then : RDATSORREG= PDATSOR  : End : Endif

    # Calcul de la date de début d'amortissement régularisée selon règle
    Case PRGLDATSOR
      When GVML_DSJOURP, GVML_IRJOURP
        # AU JOUR PRES
        RDATSORREG = PDATSOR
      When GVML_DSDERMP, GVML_IRDERMP
        # AU dernier JOUR DU MOIS PRECEDANT la sortie (gcfc6g)
        # Sauf si la sortie est en fin du mois au quel cas la date de sortie reste inchangée
        RDATSORREG = func GLOBB9.CAL_DAT_DERN( PDATSOR, "M" )
        If ( RDATSORREG <> PDATSOR ) Then
        RDATSORREG = eomonth(func GLOBB9.CAL_DAT_PLUS( RDATSORREG, -1, "M" ))
        Endif
      When GVML_DSDERMC, GVML_IRDERMC
        # AU dernier JOUR DU MOIS de sortie
        RDATSORREG = func GLOBB9.CAL_DAT_DERN( PDATSOR, "M" )
      When GVML_DSDEREP, GVML_IRDEREP
        # AU dernier JOUR DE L'EXERCICE PRECEDANT la sortie
        #>Call CAL_EXERCICE_SELON_DATE ( PDATSOR, PTYPPRO, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= PDATSOR : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        RDATSORREG = func GLOBB9.CAL_DAT_PLUS( WDTDBEXE, -1, "D" )
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, RDATSORREG, "F", RDATSORREG) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= RDATSORREG : [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        RDATSORREG = [M:DIV]RD(0)
      When GVML_DSDEREC, GVML_IRDEREC
        # AU dernier JOUR DE L'EXERCICE de sortie
        #>Call CAL_EXERCICE_SELON_DATE ( PDATSOR, PTYPPRO, WDTDBEXE, RDATSORREG, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= PDATSOR : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : RDATSORREG = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, RDATSORREG, "F", RDATSORREG) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= RDATSORREG : [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        RDATSORREG = [M:DIV]RD(0)
      When GVML_DSDERSP, GVML_IRDERSP
        # AU dernier JOUR DU SEMESTRE PRECEDANT la sortie
        # -- calcul date du début du deuxième semestre
        # -- ajout  du nombre de mois de l'ex d'invest /2  à la date de début de l'ex d'invest
        #>Call CAL_EXERCICE_SELON_DATE ( PDATSOR, PTYPPRO, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= PDATSOR : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTDBEXE, "D", WDTDBEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTDBEXE: [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(0)
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTFNEXE, "F", WDTFNEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTFNEXE: [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTFNEXE = [M:DIV]RD(0)
        # 1er jour du semestre courant
        Call CAL_DAT_DEBUT_SEMESTRE ( WDTDBEXE, WDTFNEXE, PDATSOR,  WDTDBSEM ) From =G_GLOB9
        # Dernier jour du semestre précédent
        RDATSORREG = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , -1, "D" )
      When GVML_DSDERSC, GVML_IRDERSC
        # AU dernier JOUR DU SEMESTRE de la sortie
        # -- calcul date du début du deuxième semestre
        # -- ajout  du nombre de mois de l'ex de sortie /2  à la date de début de l'ex de sortie
        #>Call CAL_EXERCICE_SELON_DATE ( PDATSOR, PTYPPRO, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= PDATSOR : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTDBEXE, "D", WDTDBEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTDBEXE: [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(0)
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTFNEXE, "F", WDTFNEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTFNEXE: [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTFNEXE = [M:DIV]RD(0)
        Call CAL_DAT_FIN_SEMESTRE ( WDTDBEXE, WDTFNEXE, PDATSOR,  RDATSORREG ) From =G_GLOB9
      When GVML_DSJPREC, GVML_IRJPREC
        # AU JOUR PRECEDENT la sortie
        RDATSORREG = func GLOBB9.CAL_DAT_PLUS( PDATSOR, -1, "D" )
      When GVML_DS1ERSC
        # AU premier JOUR DU SEMESTRE COURANT de la sortie
        # -- calcul date du début du deuxième semestre
        # -- ajout  du nombre de mois de l'ex de sortie /2  à la date de début de l'ex de sortie
        #>Call CAL_EXERCICE_SELON_DATE ( PDATSOR, PTYPPRO, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= PDATSOR : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTDBEXE, "D", WDTDBEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTDBEXE: [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(0)
        #>Call CAL_AJUST_DATE_SELON_PRORATA ( PTYPPRO, WDTFNEXE, "F", WDTFNEXE) From =G_GLOB8
        [M:DIV]PE(0)= PTYPPRO : [M:DIV]PD(0)= WDTFNEXE: [M:DIV]PC(0)= "F"
        Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
        WDTFNEXE = [M:DIV]RD(0)
        Call CAL_DAT_DEBUT_SEMESTRE ( WDTDBEXE, WDTFNEXE, PDATSOR,  RDATSORREG ) From =G_GLOB9
      When GVML_DSDERTC
        # AU dernier JOUR DU TRIMESTRE de sortie
        If    ( PDATSOR > gdat$(30, 09, year(PDATSOR)) ) Then
          RDATSORREG = gdat$(31, 12, year(PDATSOR))
        Elsif ( PDATSOR > gdat$(30, 06, year(PDATSOR)) ) Then
          RDATSORREG = gdat$(30, 09, year(PDATSOR))
        Elsif ( PDATSOR > gdat$(31, 03, year(PDATSOR)) ) Then
          RDATSORREG = gdat$(30, 06, year(PDATSOR))
        Else
          RDATSORREG = gdat$(31, 03, year(PDATSOR))
        Endif
        # FQ54343
        # When GVML_IRCONCE
        # 1er BIEN CEDE DE LA CONCESSION : Sortie non prise en compte
        # RDATSORREG = [0/0/0]
      When Default
        RDATSORREG = PDATSOR
    Endcase

End


#
#########################################################
Subprog CAL_DATE_FIN_AMORT_SELON_REGLE ( PRGLFINAMT, PDEC1EREXE, PDTDBEXI, PDTDBAMT, PDURAMT, PTYPPRO,  RDTFNAMT )
#
# - Objet  : Renvoie la date de fin d'amortissement selon la règle pécisée
#
#
# - Entrée : [M:CNT]
#            Règle fin d'amortissement
#            Indicateur 1er exercice décompté pour un an
#            Date de début d'amortissement
#            Durée d'amortissement
#            Type prorata
# - Sortie : Date de fin d'amortissement régularisée

#   Boite noire gcfc66 - gère en plus fin d'année et fin de concession.
#
Value    Integer   PRGLFINAMT
Value    Integer   PDEC1EREXE
Value    Date      PDTDBEXI
Value    Date      PDTDBAMT
Value    Decimal   PDURAMT
Value    Integer   PTYPPRO
Variable Date      RDTFNAMT : RDTFNAMT = [0/0/0]

Local    Date      WDTDBEXE
Local    Date      WDTFNEXE
Local    Date      WDTFNAMT
Local    Integer   WINDEXE



  #-1 --------------------------
  If ( PDEC1EREXE = G_OUI ) Then
    # Premier exercice décompté pour une année entière
    Call CAL_DAT_FIN_SELON_DUREE ( PDTDBEXI, PDURAMT, GVML_TPJOUR,  WDTFNAMT) From =G_GLOB9
    RDTFNAMT = WDTFNAMT
  #-1 --------------------------
  Else
    # Calcul de la date de fin d'amortissement selon règle
    Case PRGLFINAMT
      When GVML_DSJOURP
        # AU JOUR PRES
        Call CAL_DAT_FIN_SELON_DUREE ( PDTDBAMT, PDURAMT, PTYPPRO,  WDTFNAMT) From =G_GLOB9
        RDTFNAMT = WDTFNAMT
      When GVML_DSDERMC
        # AU dernier JOUR DU MOIS courant
        Call CAL_DAT_FIN_SELON_DUREE ( PDTDBAMT, PDURAMT, PTYPPRO,  WDTFNAMT) From =G_GLOB9
        RDTFNAMT = func GLOBB9.CAL_DAT_DERN( WDTFNAMT, "M")
      When GVML_DSDEREC
        # AU dernier JOUR DE L'EXERCICE courant
        Call CAL_DAT_FIN_SELON_DUREE ( PDTDBAMT, PDURAMT, PTYPPRO,  WDTFNAMT) From =G_GLOB9
        #>Call CAL_EXERCICE_SELON_DATE ( WDTFNAMT, PTYPPRO, WDTDBEXE, RDTFNAMT, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= WDTFNAMT : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : RDTFNAMT = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
      When GVML_DSDERSC
        # AU dernier JOUR DU SEMESTRE courant
        # -- calcul date du début du deuxième semestre en ajoutant
        # -- le nombre de mois de l'ex de fin d'amort /2  à la date de début de l'ex de fin d'amort
        Call CAL_DAT_FIN_SELON_DUREE ( PDTDBAMT, PDURAMT, PTYPPRO,  WDTFNAMT) From =G_GLOB9
        #>Call CAL_EXERCICE_SELON_DATE ( WDTFNAMT, PTYPPRO, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= WDTFNAMT : [M:DIV]PV(0)= PTYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        Call CAL_DAT_FIN_SEMESTRE ( WDTDBEXE, WDTFNEXE, WDTFNAMT,  RDTFNAMT ) From =G_GLOB9
      When Default
        Call CAL_DAT_FIN_SELON_DUREE ( PDTDBAMT, PDURAMT, PTYPPRO,  WDTFNAMT) From =G_GLOB9
        RDTFNAMT = WDTFNAMT
    Endcase
  Endif
  #-1 --------------------------
End


#
#########################################################
Subprog CAL_BASE_SELON_REGLE
& ( PRGLBASAMT, PDUREXEREF, PDURAMT, PDURRES, PBASAMT,   PVALRES,    PVLNAMT,   RBASAMTREG )
#
# - Objet  : Renvoie la base d'amortissement selon la règle pécisée
#            au niveau de la méthode libre.
#
# - Entrée : [M:CNT]
#            Règle application base
#            Durée exercice de référence selon prorata
#            Durée d'amortissement
#            Durée restant à amortir
#            Base d'amortissement (fichier)
#            Valeur résiduelle
#            Valeur nette amortissable
# - Sortie : Base d'amortissement (selon règle)

#   Boite noire gcfc52
#
Value    Integer   PRGLBASAMT                     : # Règle application base
Value    Decimal   PDUREXEREF                     : # Durée de l'exercice de référence
Value    Decimal   PDURAMT                        : # Durée d'amortissement
Value    Decimal   PDURRES                        : # Durée restant à amortir
Value    Decimal   PBASAMT                        : # Base d'amortissement
Value    Decimal   PVALRES                        : # Valeur résiduelle
Value    Decimal   PVLNAMT                        : # Valeur nette amortissable
Variable Decimal   RBASAMTREG : RBASAMTREG = 0    : # Base d'amortissement selon règle

Local    Decimal   LDURRES

  # Par sécurité
  RBASAMTREG = PBASAMT

  # Calcul de la base d'amortissement selon règle
  Case PRGLBASAMT
    When GVML_TBVALBI
      # VALEUR BILAN
      RBASAMTREG = PBASAMT
    When GVML_TBVLNET
      # VALEUR NETTE
      RBASAMTREG = PVLNAMT + PVALRES
    When GVML_TBBSDUR
      # BASE / DUREE D'AMORTISSEMENT
      If ( PDURAMT > 0 ) Then
      RBASAMTREG = PBASAMT / PDURAMT
      Endif
    When GVML_TBVNDDR
      # VAL NETTE / DUREE RESIDUELLE
      If ( PDURRES <> 0 ) Then
        RBASAMTREG = ( PVLNAMT + PVALRES ) * ( PDUREXEREF / PDURRES )
      Endif
    When GVML_TBVNDDT
      # VAL NETTE / DUREE TOTALE
      If ( PDURAMT > 0 ) Then
        RBASAMTREG = ( PVLNAMT + PVALRES ) / PDURAMT
      Endif
    When GVML_TBVLAMT
      # VAL BILAN - VAL RESIDUELLE
      RBASAMTREG = PBASAMT - PVALRES
    When GVML_TBVNAMT
      # VAL NETTE - VAL RESIDUELLE
      RBASAMTREG = PVLNAMT

    When GVML_TBVNAADR
      # VAL NETTE AMORTISSABLE / DUREE RESIDUELLE
      If ( PDURRES <> 0 ) Then
        RBASAMTREG = PVLNAMT * ( PDUREXEREF / PDURRES )
      Endif
    When Default
      RBASAMTREG = PBASAMT
  Endcase

End



#
#########################################################
Subprog CAL_AMT_MINIMUM_SELON_REGLE ( PRGLAMTMIN, PTXAMTMIN, PDURDET, PDUREXE, PDURRES,
&       PDTDBEXE, PDTDBAMT, PDURAMT, PDTFNAMT, PBASAMT, PVALRES, PVLNAMT,  RAMTMIN )
#
# - Objet  : Renvoie la valeur plancher de l'amortissement selon la règle pécisée.
#            La valeur minimum que peut avoir la dotation.
#
# - Entrée : [M:CNT]
#            Règle amortissement minimum
#            Taux amortissement minimum
#            Durée de détention dans l'exercice
#            Durée de l'exercice de référence
#            Durée restant à amortir
#            Date début d'exercice
#            Date début d'amortissement
#            Durée d'amortissement
#            Date fin d'amortissement
#            Base d'amortissment
#            Valeur résiduelle
#            Valeur nette amortissable
#
# - Sortie : Amortissement minimum
#
#   Boite noire gcfc52
#
Value    Integer   PRGLAMTMIN                  : # Règle amortissement plancher
Value    Decimal   PTXAMTMIN                   : # Taux plancher
Value    Decimal   PDURDET                     : # Durée détention
Value    Decimal   PDUREXE                     : # Durée exercice de référence
Value    Decimal   PDURRES                     : # Durée résiduelle
Value    Date      PDTDBEXE                    : # Date début exercice
Value    Date      PDTDBAMT                    : # Date début d'amortissement
Value    Decimal   PDURAMT                     : # Durée d'amortissement
Value    Date      PDTFNAMT                    : # Date fin d'amortissement
Value    Decimal   PBASAMT                     : # Base d'amortissement
Value    Decimal   PVALRES                     : # Valeur résiduelle
Value    Decimal   PVLNAMT                     : # Valeur nette amortissable

Variable Decimal   RAMTMIN     : RAMTMIN = 0   : # Amortissement minimum


  # Calcul de l'amortissement minimum selon règle
  Case PRGLAMTMIN
    When GVML_COPBASE
      # % BASE D'AMORTISSEMENT
      RAMTMIN = PBASAMT * PTXAMTMIN
    When GVML_COPVNFE
      # % VALEUR NETTE FIN EXERCICE PRECEDENT
      RAMTMIN = ( PVLNAMT + PRSDVAL ) * PTXAMTMIN
    When GVML_COPVNA
      # % VALEUR NETTE AMORTISSABLE FIN EXERCICE PRECEDENT
      RAMTMIN =  PVLNAMT  * PTXAMTMIN
    When GVML_COBSDDU
      # BASE / DUREE
      If ( PDURAMT <> 0 ) Then
        RAMTMIN = PBASAMT / PDURAMT
      Endif
    When GVML_COVNDDR
      # VALEUR NETTE / DUREE RESIDUELLE
      If ( PDURRES <> 0 ) Then
        RAMTMIN = ( PVLNAMT + PRSDVAL ) * ( PDUREXEREF / PDURRES )
      Endif
    When GVML_COVNADR
      # VALEUR NETTE AMORTISSABLE / DUREE RESIDUELLE
      If ( PDURRES <> 0 ) Then
        RAMTMIN = PVLNAMT * ( PDUREXEREF / PDURRES )
      Endif
    When GVML_COBSADU
      # BASE AMORTISSABLE / DUREE
      If ( PDURAMT <> 0 ) Then
        RAMTMIN = ( PBASAMT - PRSDVAL ) / PDURAMT
      Endif
    When Default
      RAMTMIN   = 0
  Endcase
  #------------------------
  # Application du prorata temporis
  If ( PDURDET > 0 and PDURDET < PDUREXE ) Then
    RAMTMIN = RAMTMIN * ( PDURDET / PDUREXE )
  Endif
  #------------------------

End

#
#########################################################
Subprog CAL_AMT_MAXIMUM_SELON_REGLE ( PRGLAMTMAX, PTXAMTMAX, PDURDET, PDUREXE,
&       PDOTEXE, PBASAMT,  PVALRES, PVLNAMT, RAMTMAX )
#
# - Objet  : Renvoie la valeur plafond de l'amortissement selon la règle pécisée.
#            La valeur maximum que peut avoir la dotation.
#
# - Entrée : [M:CNT]
#            Règle amortissement maximum
#            Taux amortissement maximum
#            Durée de détention dans l'exercice
#            Durée de l'exercice de référence
#            Dotation exercice
#            Base d'amortissment
#            Valeur résiduelle
#            Valeur nette amortissable
#
# - Sortie : Amortissement maximum
#
#   Boite noire gcfc52
#
Value    Integer   PRGLAMTMAX                  : # Règle amortissement plafond
Value    Decimal   PTXAMTMAX                   : # Taux plafond
Value    Decimal   PDURDET                     : # Durée détention
Value    Decimal   PDUREXE                     : # Durée exercice de référence
Value    Decimal   PDOTEXE                     : # Dotation exercice
Value    Decimal   PBASAMT                     : # Base d'amortissement
Value    Decimal   PVALRES                     : # Valeur résiduelle
Value    Decimal   PVLNAMT                     : # Valeur nette amortissable

Variable Decimal   RAMTMAX     : RAMTMAX = 0   : # Amortissement maximum

Local Integer B_DEFAULT
  B_DEFAULT = 0

  # Calcul de l'amortissement maximum selon règle
  Case PRGLAMTMAX
    When GVML_COPBASE
      # % BASE D'AMORTISSEMENT
      RAMTMAX = PBASAMT * PTXAMTMAX
      #------------------------
    When GVML_COPVNFE
      # % VALEUR NETTE FIN EXERCICE PRECEDENT
      RAMTMAX = ( PVLNAMT + PVALRES ) * PTXAMTMAX
      #------------------------
    When GVML_COPVNA
      # % VALEUR NETTE AMORTISSABLE FIN EXERCICE PRECEDENT
      RAMTMAX = PVLNAMT * PTXAMTMAX
      #------------------------
    When Default
      B_DEFAULT = 1
      RAMTMAX  = PDOTEXE
  Endcase
  # Application du prorata temporis
  If ( !B_DEFAULT and PDURDET > 0 and PDURDET < PDUREXE ) Then
    RAMTMAX = RAMTMAX * ( PDURDET / PDUREXE )
  Endif
  #------------------------

End



#
#########################################################
Subprog CAL_DETERM_FLAG_OER ( PCONTEXT, POWNTYP, PGESCON, POCRFLG, PTPAFLG, PDTFNCON, PDTFNAMT, ROERFLG )
#
# - Objet  : Renvoie la valeur de l'indicateur précisant l'Obligation Effective de Renouvellement.
#
#
# - Entrée :
#
# - Sortie :
#
#   FQ54343
#
Value    Char      PCONTEXT                    : # Contexte d'appel
Value    Integer   POWNTYP                     : # Type de détention du bien
Value    Integer   PGESCON                     : # Type de gestion concession
Value    Integer   POCRFLG                     : # Indicateur Obligation Contractuelle de Renouvellement
Value    Integer   PTPAFLG                     : # Indicateur remis contre indemnité
Value    Date      PDTFNCON                    : # Date fin de concession
Value    Date      PDTFNAMT                    : # Date prévisionnelle de renouvellement

Variable Integer   ROERFLG                     : # Indicateur Obligation Effective de Renouvellement

  ROERFLG = G_NON
  #------------------------
  If ( POWNTYP = GVML_TDCONCE ) Then
    # Le type de détention du bien est "En concession"
    If ( PGESCON = GVML_GCRNW )  Then
      # Le type de gestion de la concession est "Transmis par renouvellement"
      If ( PTPAFLG <> G_OUI ) Then
        # Indicateur OER toujours à Non si l'indicateur Remis contre indemnité est à Oui
        If ( POCRFLG = G_OUI ) Then
          # Il y a obligation contractuelle de renouvellement
          If ( PDTFNAMT <> [0/0/0] and PDTFNAMT < PDTFNCON ) Then
            # La date prévisionnelle de renouvellement s'achève avant la fin de la concession
            # L'indicateur Obligation Effective de Renouvellement est positionné.
            ROERFLG = G_OUI
          Endif
        Endif
      Endif
    Endif
  Endif
  #------------------------


  #------------------------
  If ( PCONTEXT <> "" ) Then
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
    # E   Point d'entrée    AFTOERFLG               E
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
    # FQ115265
    If (dim(G_ETP_GLOBI7) <=0) Then
      Global Integer G_ETP_GLOBI7
      G_ETP_GLOBI7   = find('GLOBI7',  GENTSTD(1..GNBENTREE))
    Endif
    If ( G_ETP_GLOBI7 ) Then : # FQ114113
      GPOINT = "AFTOERFLG"
      Gosub ENTREE From EXEFNC
      If !(GOK) Then
        [M:DIV]ERRID = 9000 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
      Endif
    Endif
#CHECK IGNORE_END
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  Endif
  #------------------------


End


#
#########################################################
Subprog CAL_INI_PER_EXE ( PDEBEXE, PFINEXE )
#
# - Objet  : Initialise le tableau des périodes pour calcul de la dotation exercice.
#            Récupère les dates des périodes d'un exercice
#
#
# - Entrée :
#
# - Sortie :
#
#   FQ59941 FQ77877
#
Value    Date      PDEBEXE                    : # Début exercice
Value    Date      PFINEXE                    : # Fin   exercice


Local Integer I_P
Local Integer I_FP
Local Integer I_E

  # Remise à blanc du tableau
  nolign = 1
  For I_P = 1 To 24
    [M:DIV2]PERSTRDAT(nolign-1) = [0/0/0]
    [M:DIV2]PERENDDAT(nolign-1) = [0/0/0]

    Case [M:DIV]TYPCAL
      When "R"
        [M:DIV2]DOTPER(nolign-1)    = 0
        [M:DIV2]DOT1AP(nolign-1)    = 0
        [M:DIV2]EXCPER(nolign-1)    = 0
        [M:DIV2]EXC1AP(nolign-1)    = 0
        [M:DIV2]BIRNBV(nolign-1)    = 0
      When "T"
        [M:DIV2]DOTPERT(nolign-1)    = 0
        [M:DIV2]DOT1APT(nolign-1)    = 0
        [M:DIV2]EXCPERT(nolign-1)    = 0
        [M:DIV2]EXC1APT(nolign-1)    = 0
        [M:DIV2]BIRNBVT(nolign-1)    = 0
      When "I"
        [M:DIV2]DOTPERI(nolign-1)    = 0
        [M:DIV2]DOT1API(nolign-1)    = 0
        [M:DIV2]EXCPERI(nolign-1)    = 0
        [M:DIV2]EXC1API(nolign-1)    = 0
        [M:DIV2]BIRNBVI(nolign-1)    = 0
    Endcase
    nolign += 1
  Next I
  [M:DIV2]NB_PER= nolign-1

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # Indice le l'exercice courant dans le masque CALFIY
  I_E = find(PFINEXE, [M:FIY]DATENDFIY)

  #-1 --------------------
  # FQ68426 If ( I_E = 0 ) Then
  If ( I_E = 0 or [M:FIY]NBRPER(I_E-1) = 1 ) Then
    # L'exercice ne se trouve pas dans la table des exercices
    # ou s'il n'est pas découpé en périodes
    # Découpage de l'exercice en fonction du prorata
    Local Date L_DEBPER
    L_DEBPER = PDEBEXE
    For I_P = 1 To 24
      # Alimentation des périodes de l'exercice
      [M:DIV2]PERSTRDAT(I_P-1) = L_DEBPER
      # Prorata en MOIS
      [M:DIV2]PERENDDAT(I_P-1) = eomonth(L_DEBPER)
      L_DEBPER = [M:DIV2]PERENDDAT(I_P-1) + 1
      If ( L_DEBPER > PFINEXE ) Then : Break : Endif
    Next I_P
    [M:DIV2]NB_PER = I_P
  #-1 --------------------
  Else
    # L'exercice se trouve dans la table des exercices
    Local Date L_DEBPER
    L_DEBPER = PDEBEXE
    For I_P = 1 To 24
      # Alimentation des périodes de l'exercice
      [M:DIV2]PERSTRDAT(I_P-1) = [M:FIY]DATSTRPER([M:FIY]INDDEBPER(I_E-1)+I_P-2)
      [M:DIV2]PERENDDAT(I_P-1) = [M:FIY]DATENDPER([M:FIY]INDDEBPER(I_E-1)+I_P-2)
      # Prorata en MOIS
      L_DEBPER = [M:DIV2]PERENDDAT(I_P-1) + 1
      If ( L_DEBPER > PFINEXE ) Then : Break : Endif
    Next I_P
    [M:DIV2]NB_PER = I_P
  Endif
  #-1 --------------------


End

$CAL_VERIF_PERREFCLC
  # "Bien : XXXX  Plan : x PEREFCLCn = 00/00/00 en dehors de l'exercice courant"
  Local Char LMSG(80)
  If ( not func GLOBB9.CAL_DAT_INSIDE([M:DEP]PERREFCLC (nolign-1), DTDBEXE, DTFNEXE, "I") ) Then
    WPERREF = "PERREFCLC ="+ num$([M:DEP]PERREFCLC (nolign-1))
    LMSG = func GLOFUNC.SUBSTIT3(mess(195,7774,1), [F:WDEP]AASREF, num$([F:WDEP]DPRPLN), WPERREF)
    Call ECR_TRACE( LMSG, -1) From =G_GLOB0
    [M:DEP]PERREFCLC (nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
  Endif
  If ( not func GLOBB9.CAL_DAT_INSIDE([M:DEP]PERREFCLCI (nolign-1), DTDBEXE, DTFNEXE, "I") ) Then
    WPERREF = "PERREFCLCI ="+ num$([M:DEP]PERREFCLCI (nolign-1))
    LMSG = func GLOFUNC.SUBSTIT3(mess(195,7774,1), [F:WDEP]AASREF, num$([F:WDEP]DPRPLN), WPERREF)
    Call ECR_TRACE( LMSG, -1) From =G_GLOB0
    [M:DEP]PERREFCLCI(nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
  Endif
  If ( not func GLOBB9.CAL_DAT_INSIDE([M:DEP]PERREFCLCT (nolign-1), DTDBEXE, DTFNEXE, "I") ) Then
    WPERREF = "PERREFCLCT ="+ num$([M:DEP]PERREFCLCT (nolign-1))
    LMSG = func GLOFUNC.SUBSTIT3(mess(195,7774,1), [F:WDEP]AASREF, num$([F:WDEP]DPRPLN), WPERREF)
    Call ECR_TRACE( LMSG, -1) From =G_GLOB0
    [M:DEP]PERREFCLCT(nolign-1) = [M:DEP]FIYSTRDAT(nolign-1)
  Endif

Return

#
#########################################################
Subprog CAL_DED40_GLOBALE_SELON_LOF ( RDED40 )
#
# - Objet  : Evaluation du montant globale de la déduction. FQ107988
# - Rappel des étapes :
#    1-Initialement applicable jusqu’au 14 avril 2016,
#    2-la déduction exceptionnelle a été reconduite pour 1 an, jusqu’au 14 avril 2017.(FQ115155)
#    3-Possibilité d'appliquer la règle part. après le 14/04/2017 dans certains cas décrits par la Loi de Finance,
#      sous la responsabilité de l'utilisateur (message avertissement uniquement) (X3-61112)
#
#            La date d'achat du bien doit être supérieure au [15/04/2015] (borne supérieure du 14/04/2017 supprimée)
#
#            Si le bien a au moins une dépense rattachée
#               Déduction = 40% du cumul de la valeur HT en devise société des dépenses rattachées au bien comptable
#                                                                                       créées à partir de [15/04/2015]
#            Si le bien ne possède pas de dépenses rattachées
#               Déduction = 40% de la valeur HT en devise société du bien comptable
#
#   Remarque : la déduction fiscale, dans ce cas, est extra-comptable et n'affecte pas la dotation exercice.
#
#
#
Value    Char      PAASREF                    : # Référence bien comptable
Variable Decimal   RDED40                     : # Déduction


  If clalev([F:WLOF]) =0    : Local File LAYOUTFAS     [WLOF]    : Endif : # Table des dépenses

  RDED40 = 0

  #If ([F:WFAS]PURDAT >= [15/04/2015] and [F:WFAS]PURDAT <= [14/04/2017]) #FQ115155/X3-61112
  If ([F:WFAS]PURDAT >= [15/04/2015] )

    Local Integer I_NBLOF : I_NBLOF = 0
    #>1 >>>>>>>>>>>>>>>>>>
    #For [WLOF]LOF6 Where AASREF = [F:WFAS]AASREF and DATVCR >= [15/04/2015] and DATVCR <= [14/04/2017] #FQ115155/X3-61112
    For [WLOF]LOF6 Where AASREF = [F:WFAS]AASREF and DATVCR >= [15/04/2015]
      I_NBLOF +=1
      RDED40 += [F:WLOF]AMTNOTCPY + [F:WLOF]AMTVATCPY - [F:WLOF]AMTVATRCPY
    Next
    #<1 <<<<<<<<<<<<<<<<<<

    If (I_NBLOF = 0)
      RDED40 = [F:WFAS]ACGETRNOT + [F:WFAS]IVCVATAMT - [F:WFAS]DEDVATAMT
    Endif

    RDED40 = RDED40 * 0.40
  Endif


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (RDED40, [M:DIV]CUR , RDED40) From =G_GLOB8
  [M:DIV]PV(0)= RDED40 : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RDED40 = [M:DIV]RV(1)

  Close File [WLOF]
End

#########################################################
Subprog  CAL_DED40_EXE(RDED40)
#
# - Objet   : Calcule la déduction de l'exercice si la règle particulière est égale à Déduction 40% [15avr15 - 14avr16]
#             FQ107988
# - Entrée :
#
# - Sortie :
#
#
Variable Decimal RDED40      : # Déduction pour l'exercice

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice

  #=================
  # Date Déb. Amort.
  #=================
  Local Date L_DTDBAMT
  # Au Premier Jour du Mois du début d'amortissement
  L_DTDBAMT = gdat$(01,month([F:DEPC]STRDPRDAT), year([F:DEPC]STRDPRDAT) )
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Début d'amort.               =" + num$(L_DTDBAMT)    ) From =G_GLOB0
  #=================
  # Date Fin Amort.
  #=================
  Local Date L_DTFNAMT
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée fin de mois)
  Call CAL_DAT_FIN_SELON_DUREE ( L_DTDBAMT, [M:DIV]DURAMTREG, GVML_TPMOIS, L_DTFNAMT) From =G_GLOB9
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Fin   d'amort.               =" + num$(L_DTFNAMT)    ) From =G_GLOB0
  #======================
  # Déduction résiduelle déb. exe.
  #======================
  Local Decimal L_DEDRES
  L_DEDRES = [M:DIV2]GLODED40 - [F:DEPC]ALWCUM
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Déduction résid. déb. exe.  =" + num$(L_DEDRES) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Date de référence           =" + num$([M:DIV]EXEDATREF) ) From =G_GLOB0

  #---------------------
  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, L_DTDBAMT,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DATNUL, [M:DIV]TYPPRODAT, WDURDET ) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]DTDBEXE   : [M:DIV]PD(1)= [M:DIV]DTFNEXE   : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= L_DTDBAMT        : [M:DIV]PD(5)= L_DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DATNUL : [M:DIV]PC(0)= "M"
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  #Call  CAL_DUR_REST_AMT (L_DTDBAMT, [M:DIV]EXEDATREF, L_DTFNAMT, "M", WDURRES) From =G_GLOB8
  Call  CAL_DUR_REST_AMT (L_DTDBAMT, [M:DIV]DTDBEXE, L_DTFNAMT, "M", WDURRES) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( WDURRES <> 0 ) Then
    Call ECR_FICH("FS1", 7,
&   "CAL_DED40_EXE - Déduc. Exe. = Déduc. Résid. Déb. Exe. * (Dur. Dét. Exe. / Dur. Resid.)") From =G_GLOB0
    RDED40 = L_DEDRES * ( WDURDET / WDURRES)
  Else
    RDED40 = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (RDED40, [M:DIV]CUR , RDED40) From =G_GLOB8
  [M:DIV]PV(0)= RDED40 : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RDED40 = [M:DIV]RV(1)

  # Fin d'amortissement dépassée, la valeur nette doit être soldée
  # FQ114353
  If ( L_DTFNAMT < [M:DIV]DTDBEXE and [M:DIV]DATSORREG = [0/0/0] and L_DEDRES <> 0  ) Then
    RDED40  = L_DEDRES
    Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Fin amort dépassée et déduction résiduelle <> 0 => Solde ") From =G_GLOB0
  Endif

  # Sécurité, si la déduction est > à la déduction résiduelle, la déduction exercice ne peut être qu'égale à la déduction résiduelle
  If ( abs(RDED40) > abs(L_DEDRES)) Then
    RDED40 = L_DEDRES
    Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Déduction > Déduction résid., Déduction = Déduction résid. ") From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DED40_EXE - Déduction         =" + num$(RDED40) ) From =G_GLOB0


End


    If ([F:DEPC]ALWCOD = GVML_RPDED40 and [M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN = G301FIS ) Then
      # Si pays France et plan comptable pas de reprise de réévaluation
    Endif

