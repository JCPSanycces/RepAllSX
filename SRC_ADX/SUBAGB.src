#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet AGB
Raz GPILCOD
Call OBJET("AGB",GBIDC1,GBIDC2) From GOBJET
End
#----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "MODIF"       : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return
#----------------------------------------------------------------------------#
$OUVRE
If clalev([F:ADP2])=0  : Local File ADOPAR  [ADP2]  : Endif
Gosub SET_TRT
Return
#----------------------------------------------------------------------------#
$VERIF_CRE
$VERIF_MOD
If [M]PUBFLG=2 & len([M]TEXTE)=0
 # Le descriptif doit être renseignée pour une variable publiée
 Call ERREUR(mess(196,139,1)) From GESECRAN
 OK = 0 : zonsui = "TEXTE"
Endif
Gosub SET_TRT
#If [M]TRTSTD=TRTADX
# Read [ATY]CODTYP=[M]CODTYP
# If !fstat & [F:ATY]TYPTYP=7 & [F:ATY]LNGTYP<>0
#  # Ce type de données ne peut pas être utilisé dans une variable déclarée dans #
#  Call ERREUR([M]CODTYP-":"-func AFNC.MES(mess(274,139,1),TRTADX)) From GESECRAN
#  OK = 0 : zonsui = "CODTYP"
# Endif
#Endif
Return
#----------------------------------------------------------------------------#
$RAZCRE
$RAZDUP
Effzo PARAM , DES1
Gosub GRISE_CHAMP
Gosub GRISE_TYPTYP
Gosub GRISE_FORDIM
Gosub GRISE_TRTSTD
Gosub GRISE_TRTINI
Gosub AFF_TRTINTIT
Return
#----------------------------------------------------------------------------#
$LIENS
Call TEXTE([M:AGB1]INTIT,[M:AGB1]ZINTIT) From OBJDIV
[M]FORDIM0 = [F:AGB]FORDIM(0)
[M]FORDIM1 = [F:AGB]FORDIM(1)
[M]FORDEB0 = [F:AGB]FORDEB(0)
[M]FORDEB1 = [F:AGB]FORDEB(1)
Gosub GRISE_CHAMP
Gosub GRISE_TYPTYP
[M]TYPTYP = [F:ATY]TYPTYP
Gosub GRISE_FORDIM
Gosub GRISE_TRTSTD
Gosub GRISE_TRTINI
Gosub GRISE_FORINI
Gosub GRISE_PARAM
Gosub AFF_TRTINTIT
Call LECTURE_DOC("AGB",[M]CODVAR,[M]TEXTE,K) From SUBADO
Return
#----------------------------------------------------------------------------#
$MODIF
$CREATION
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
Call ECRIRE_DOC("AGB",[M]CODVAR,[M]TEXTE,[M]ZINTIT,[M]MODULE,[M]CODACT) From SUBADO
Return
#----------------------------------------------------------------------------#
$ANNULE
Call EFFACE_DOC("AGB",[L]CODE) From SUBADO
Return
#----------------------------------------------------------------------------#
$AP_ANNULE
Call VALIDATION(APPLI,[M:AGB1]TRTSTD,0)
If [M:AGB1]PARAM<>""
 Read [ADP]ADP1 = [M:AGB1]PARAM
 Call VALCHAP(APPLI,[F:ADP]CHAPITRE,0)
Endif

# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("AGB",[L]CODE,"A") From AGENLIBA

Return
#----------------------------------------------------------------------------#
$INIMOD
$INICRE
[F:AGB]FORDIM(0) = [M]FORDIM0
[F:AGB]FORDIM(1) = [M]FORDIM1
[F:AGB]FORDEB(0) = [M]FORDEB0
[F:AGB]FORDEB(1) = [M]FORDEB1
Return
#----------------------------------------------------------------------------#
$EXEBOUT
Case BOUT
 When "V"
  Call OUVRE_VLC(mess(86,123,1),mess(1,13,1),"") From GESECRAN
  Call OUVRE_TRACE(mess(86,123,1)) From LECFIC
  Call VALIDATION(nomap,"",0)
  For [ADP2]ADP0(1)
   Call VALCHAP(nomap,[F:ADP2]CHAPITRE,0)
  Next
  Call FERME_VLC From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endcase
Return
#----------------------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
Call STD([M:AGB1]CODVAR,K)
If GADONIX<>2 & K
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
CHMEN += "4"
Return

Subprog STD(CODVAR,STD)
Value Char CODVAR
Variable Integer STD
STD = 0
If find(CODVAR,"GZNUM","GZONE")
 STD = 1
Elsif find(left$(CODVAR,1),"G") & !find(left$(CODVAR,2),"GX","GY","GZ")
 STD = 1
Endif
End

#----------------------------------------------------------------------------#
$APRES_CRE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("AGB",[M]CODVAR,"C") From AGENLIBA
Gosub APRES_CREMOD
Return

$APRES_MOD
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("AGB",[M]CODVAR,"M") From AGENLIBA
Gosub APRES_CREMOD
Return

$APRES_CREMOD
Call VALIDATION(nomap,[M:AGB1]TRTSTD,0)
If [M:AGB1]PARAM<>""
 Read [ADP]ADP1 = [M:AGB1]PARAM
 Call VALCHAP(nomap,[F:ADP]CHAPITRE,0)
Endif
Return

#----------------------------------------------------------------------------#
$GRISE_TRTINI
If [M:AGB1]FORINI<>"" or [M:AGB1]PARAM<>""
 Effzo [AGB1]TRTINI
 Grizo [AGB1]TRTINI
Else
 Call STD([M:AGB1]CODVAR,K)
 If GADONIX<>2 & K
  Diszo [AGB1]TRTINI
 Else
  Actzo [AGB1]TRTINI
 Endif
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_TYPTYP
Read [ATY]CODTYP = [M:AGB1]CODTYP
If !fstat & [F:ATY]LNGTYP=0 & ([F:ATY]TYPTYP=7 | [F:ATY]TYPTYP=10 | [F:ATY]TYPTYP=9)
 Actzo [AGB1]LNGTYP
Else
 Effzo [AGB1]LNGTYP
 Grizo [AGB1]LNGTYP
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_TRTSTD
If [M:AGB1]PARAM<>""
 Diszo [AGB1]TRTSTD
Else
 Call STD([M:AGB1]CODVAR,K)
 If GADONIX<>2 & K
  Diszo [AGB1]TRTSTD
 Else
  Actzo [AGB1]TRTSTD
 Endif
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_FORINI
If [M]TRTINI<>"" or [M]PARAM<>""
 Effzo [AGB1]FORINI
 Grizo [AGB1]FORINI
Else
 Actzo [AGB1]FORINI
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_PARAM
If [M]FORINI<>"" or [M]TRTINI<>""
 Effzo [AGB1]PARAM
 Grizo [AGB1]PARAM
Else
 Actzo [AGB1]PARAM
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_FORDIM
If [M]PARAM<>""
 Effzo [AGB1]FORDIM0,FORDIM1,FORDEB0,FORDEB1
 Grizo [AGB1]FORDIM0,FORDIM1,FORDEB0,FORDEB1
 Grizo [AGB1]FORDIM0,FORDIM1,FORDEB0,FORDEB1
Elsif [M]FORDIM0<>""
 Actzo [AGB1]FORDIM0,FORDIM1,FORDEB0,FORDEB1
Else
 Actzo [AGB1]FORDIM0,FORDEB0
 Effzo [AGB1]FORDIM1,FORDEB1
 Grizo [AGB1]FORDIM1,FORDEB1
Endif
Return
#----------------------------------------------------------------------------#
$AFF_TRTINTIT
[M:AGB1]TRTINTIT = ""
If [M:AGB1]TRTSTD<>""
 Read [ADC]ADC0=[M:AGB1]TRTSTD
 If !fstat
  [M:AGB1]TRTINTIT = [F:ADC]DES
 Endif
Endif
Affzo [AGB1]TRTINTIT
Return
#----------------------------------------------------------------------------#
$GRISE_CHAMP
Call STD([M:AGB1]CODVAR,K)
If GADONIX<>2 & K
 Diszo [AGB1]CODTYP
 Diszo [AGB1]30
 Diszo [AGB1]35
Else
 Actzo [AGB1]CODTYP
 Actzo [AGB1]30
 Actzo [AGB1]35
Endif
Return
#----------------------------------------------------------------------------#
$SET_TRT
Local Char    TRTUSR(GLONADC) , TRTVAR(GLONADC) , TRTADX(GLONADC)
TRTUSR = "WWAGLOBUSR"
TRTVAR = "WWAGLOBVAR"
TRTADX = "WWAGLOBADX"
Return
#----------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELAGB"
  CRITERE = 'TRTSTD="'+[M]TRTSTD+'"'
  OBJET   = "AG2"
  START   = "RANG"
 When "SELAGB2"
  CRITERE = 'TRTSTD<>""'
  OBJET   = "AG3"
 Endcase
Return
#----------------------------------------------------------------------------#
$SEL_LISTE
Gosub SET_TRT
Local Char TEXTE(GLONDES)(1..dim(TEX),1..3) , TIT(GLONDES)(0..3)
NBTEX=0
For [AGB]AGB1(1)
 If [F:AGB]TRTSTD<>TRTUSR & [F:AGB]TRTSTD<>TRTVAR
  NBTEX += 1
  TEX(NBTEX) = [F:AGB]TRTSTD
  Read [ADC]ADC0 = [F:AGB]TRTSTD
  If !fstat
   TEXTE(NBTEX,2) = [F:ADC]DES
   TEXTE(NBTEX,3) = mess([F:ADC]MODULE,14,1)
  Else
   TEXTE(NBTEX,2) = mess(86,123,1) : # Variables globales
   TEXTE(NBTEX,3) = ""
  Endif
 Endif
Next
TIT(0) = mess(189,139,1) : # Traitements générés
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
TIT(3) = mess(58,105,1)  : # Module
Return
#----------------------------------------------------------------------------#
$FIN_LISTE
If VALEUR <> ""
 [M:AGB1]TRTSTD = vireblc(VALEUR,3)
Endif
Return
#----------------------------------------------------------------------------#
Subprog GENDOS(APPLI)
Value Char    APPLI
Local File =APPLI+".AGLOBVAR" [AGB]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ADOPAR"   [ADP]
Local File =APPLI+".ADOPAR"   [ADP2]
Call ECR_TRACE(mess(183,139,1)-mess(178,126,1)-APPLI,0) From GESECRAN : # Validation des variables globales/dans le dossier
Call VALIDATION(APPLI,"",1)
For [ADP2]ADP0(1)
 Call VALCHAP(APPLI,[F:ADP2]CHAPITRE,1)
Next
End
#----------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI
Call GENDOS(APPLI)
End
#----------------------------------------------------------------------------#
Subprog VALIDATION(DOSSIER,TRAITEMENT,SILENCE)
Value Char    DOSSIER
Value Char    TRAITEMENT
Value Integer SILENCE
Local Char    NOMTRT(GLONADC)
Local Char    FICTRT(GDIMFIC) , FICOLD(GDIMFIC) , FICLCK(GDIMFIC) , FICNEW(GDIMFIC)
Local Char    TETADO(80) , TEXTE(250) , CHAINE(250)
Local Integer STAT , I , K, N , M
Local Char    LIGNE(250)(1..200)
Local Char    MACHINE(GDIMFIC) , APPLI(GDIMFIC)
Gosub SET_TRT

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:AGB])=0  : Local File =DOSSIER+".AGLOBVAR" [AGB]  : Endif
If clalev([F:ATX])=0  : Local File =DOSSIER+".ATEXTE"   [ATX]  : Endif
If clalev([F:ADP])=0  : Local File =DOSSIER+".ADOPAR"   [ADP]  : Endif
If clalev([F:ATY])=0  : Local File =DOSSIER+".ATYPE"    [ATY]  : Endif

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
For [AGB]AGB1(1) Where TRAITEMENT="" or TRTSTD=TRAITEMENT
 If !GSERVEUR & !SILENCE
  Call AFF_VLC([F:AGB]TRTSTD,mess(1,100,1)) From GESECRAN : # Validation en cours
 Endif
 If [F:AGB]TRTSTD=""
  # Variable globale : Traitement inexistant
  Call ECR_TRACE(mess(122,139,1)-[F:AGB]CODVAR-":"-mess(90,123,1),-1) From GESECRAN
 Else
  NOMTRT = [F:AGB]TRTSTD
  FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
  FICOLD = filpath("TRT",NOMTRT,"old",APPLI,"",MACHINE)
  FICNEW = filpath("TRT",NOMTRT,"new",APPLI,"",MACHINE)
  FICLCK = filpath("TRT",NOMTRT,"LCKsrc",APPLI,"",MACHINE)
  If filinfo(FICNEW,0)>0
   Call EFFACE(FICNEW,STAT) From ORDSYS
  Endif
  If filinfo(FICLCK,0)>0
   If GTRACE<>"" & !SILENCE
    Call ECR_TRACE(NOMTRT-":"-mess(13,139,1),1) From GESECRAN : # Traitement verrouillé
   Endif
  Else
   Openo FICLCK,0 Using [LOK]
   Iomode adxifs "" Using [LOK]
   Iomode adxirs chr$(10) Using [LOK]
   Iomode adxium GUTF8 Using [LOK]
   Wrseq adxmac(-2) Using [LOK]
   Wrseq adxusr Using [LOK]
   Wrseq format$(GFMD,date$)-"-"-time$ Using [LOK]
   Openo Using [LOK]

   #101663
   If filinfo(FICOLD,0)>0
    Call EFFACE(FICOLD,STAT) From ORDSYS
   Endif
   #101663
   If filinfo(FICTRT,0)>0
    Call COPIE(FICTRT,FICOLD,STAT) From ORDSYS
   Endif

   Openo FICTRT,0 Using [FIC]
   Iomode adxifs "" Using [FIC]
   Iomode adxirs chr$(10) Using [FIC]
   Iomode adxium GUTF8 Using [FIC]
   Wrseq TETADO;" ";mess(86,123,1)  Using [FIC] : # Variables globales
   Wrseq "Subprog DEFVAR" Using [FIC]
   Case [F:AGB]TRTSTD
    When TRTVAR
     Wrseq "Onerrgo ERREUR" Using [FIC]
     Wrseq "Local File ADOPAR [ADP]" Using [FIC]
     Wrseq "Local File ADOVAL [ADW]" Using [FIC]
     Wrseq "Local Char   PARAM(250)" Using [FIC]
    When TRTUSR
     Wrseq "Onerrgo ERREUR" Using [FIC]
     Wrseq "Local File ADOPAR    [ADP]" Using [FIC]
     Wrseq "Local File ADOVAL    [ADW]" Using [FIC]
     Wrseq "Local File ADOVALAUS [ADU]" Using [FIC]
     Wrseq "Local Char    PARAM(250)" Using [FIC]
    When Default
     Wrseq "Local Char    PARAM(250)" Using [FIC]
   Endcase
   For [AGB]AGB1
    Read [ATY]CODTYP = [F:AGB]CODTYP
    If !fstat
     Case [F:ATY]TYPTYP
      When 1  : TEXTE = "Global Libelle  "
      When 2  : TEXTE = "Global Shortint "
      When 3  : TEXTE = "Global Integer  "
      When 4  : TEXTE = "Global Decimal  "
      When 5  : TEXTE = "Global Float    "
      When 6  : TEXTE = "Global Double   "
      When 7  : TEXTE = "Global Char     "
      When 8  : TEXTE = "Global Date     "
      When 9  : TEXTE = "Global Blbfile  "
      When 10 : TEXTE = "Global Clbfile  "
     Endcase
     TEXTE += [F:AGB]CODVAR
     If [F:ATY]TYPTYP=7 & [F:ATY]LNGTYP>0
      TEXTE += "(GLON"+[F:AGB]CODTYP+")"
     Elsif [F:AGB]LNGTYP<>""
      TEXTE += "("+[F:AGB]LNGTYP+")"
     Endif
     If [F:AGB]FORDIM(0) <> ""
      If [F:AGB]FORDEB(0) = 2 : TEXTE += "(1.." : Else : TEXTE += "(0.." : Endif
      TEXTE += [F:AGB]FORDIM(0)
     Endif
     If [F:AGB]FORDIM(1) <> ""
      If [F:AGB]FORDEB(1) = 2 : TEXTE += ",1.." : Else : TEXTE += ",0.." : Endif
      TEXTE += [F:AGB]FORDIM(1)
     Endif
     If [F:AGB]FORDIM(0) <> ""
      TEXTE += ")"
     Endif
     Wrseq TEXTE; Using [FIC]
     Call TEXTE([F:AGB]INTIT,CHAINE) From OBJDIV
     If CHAINE<>""
      Wrseq space$(max(0,35-len(TEXTE)))+" : # "+CHAINE Using [FIC]
     Else
      Wrseq "" Using [FIC]
     Endif
     If [F:AGB]PARAM <> ""
      Read [ADP]ADP1 = [F:AGB]PARAM
      If [F:ADP]NIVDEF<>4
       Wrseq 'Call PARAM("","';[F:AGB]PARAM;'",PARAM) From ADOVAL' Using [FIC]
      Else
       Wrseq 'Call PARAMUTIL("';[F:AGB]PARAM;'",PARAM,"","") From SUBAUS' Using [FIC]
      Endif
      If [F:ATY]TYPTYP=7 : # Char
       Wrseq [F:AGB]CODVAR;" = PARAM" Using [FIC]
      Elsif [F:ATY]TYPTYP=8 : # Date
       Wrseq [F:AGB]CODVAR;' = func ADOVAL.INIDAT("'+[F:AGB]CODVAR+'",PARAM)' Using [FIC]
      Else
       Wrseq [F:AGB]CODVAR;" = val(PARAM)" Using [FIC]
      Endif
     Endif
     If [F:AGB]FORINI <> ""
      Wrseq "   "+[F:AGB]CODVAR+" = "+[F:AGB]FORINI Using [FIC]
     Endif
     If len([F:AGB]TRTINI) > 0
      Setlob LIGNE With [F:AGB]TRTINI
      If LIGNE<>""
       K = dim(LIGNE)
       While K & LIGNE(K)=""
        K -= 1
       Wend
       For I=1 To K
        K = instr(1,LIGNE(I),chr$(13))
        While K
         LIGNE(I) = left$(LIGNE(I),K-1)+right$(LIGNE(I),K+1)
         K = instr(K,LIGNE(I),chr$(13))
        Wend
        Wrseq LIGNE(I); Using [FIC]
       Next I
       Wrseq Using [FIC]
      Endif
     Endif
    Endif
   Next AGB
   Wrseq "End" Using [FIC]
   If find([F:AGB]TRTSTD,TRTUSR,TRTVAR)
    Wrseq Using [FIC]
    Wrseq "$ERREUR" Using [FIC]
    Wrseq 'Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)-errm) From GESECRAN' Using [FIC]
    Wrseq 'Resume' Using [FIC]
   Endif
   Openo Using [FIC]
   If GTRACE<>"" & !SILENCE
    Call ECR_TRACE(mess(159,133,1)-NOMTRT,0) From GESECRAN : # Validation du traitement ...
   Endif
   Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
   If !STAT
    Call COPIE(FICTRT,FICNEW,STAT) From ORDSYS
    If GTRACE<>"" & !SILENCE
     Call ECR_TRACE(mess(20,123,1)-"\|"+FICNEW+"|",0) From GESECRAN : # Erreur en validation du traitement
    Endif
    Call EFFACE(FICTRT,STAT) From ORDSYS
    #101663
    If filinfo(FICOLD,0)>0
     Call COPIE(FICOLD,FICTRT,STAT) From ORDSYS
     If GTRACE<>"" & !SILENCE
      Call ECR_TRACE(mess(226,133,1)-NOMTRT,0) From GESECRAN : # Validation de l'ancien traitement
     Endif
     Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
     Call EFFACE(FICOLD,STAT) From ORDSYS
    Endif
    Call EFFACE(FICLCK,STAT) From ORDSYS
    Break
   Elsif APPLI=nomap & MACHINE=adxmac(0) & find([F:AGB]TRTSTD,TRTUSR,TRTVAR)
    Call DEFVAR From =NOMTRT
   Endif
   Call EFFACE(FICOLD,STAT) From ORDSYS
   Call EFFACE(FICLCK,STAT) From ORDSYS
  Endif
 Endif
Next AGB(1)
End
#----------------------------------------------------------------------------#
Subprog VALCHAP(DOSSIER,CHAP,SILENCE)
Value Char    DOSSIER
Value Char    CHAP
Value Integer SILENCE
Local Char    NOMTRT(GLONADC) , FICTRT(GDIMFIC) , FICLCK(GDIMFIC) , TETADO(80)
Local Char    CHAINE(250) , TEXTE(250)
Local Integer STAT
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

If clalev([F:AGB])=0 : Local File =DOSSIER+".AGLOBVAR" [AGB] : Endif
If clalev([F:ATX])=0 : Local File =DOSSIER+".ATEXTE"   [ATX] : Endif
If clalev([F:ADP])=0 : Local File =DOSSIER+".ADOPAR"   [ADP] : Endif
If clalev([F:ATY])=0 : Local File =DOSSIER+".ATYPE"    [ATY] : Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

NOMTRT = "WWGLOB"+CHAP
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
FICLCK = filpath("TRT",NOMTRT,"LCKsrc",APPLI,"",MACHINE)
If filinfo(FICLCK,0)>0
 If GTRACE<>"" & !SILENCE
  Call ECR_TRACE(NOMTRT-":"-mess(13,139,1),1) From GESECRAN : # Traitement verrouillé
  End
 Endif
Else
 Openo FICLCK,0 Using [LOK]
 Iomode adxifs "" Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GUTF8 Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq format$(GFMD,date$)-"-"-time$ Using [LOK]
 Openo Using [LOK]
Endif

Link [AGB]
& With [ADP]ADP1=[F:AGB]PARAM
& As [LNK]
& Where [AGB]PARAM<>"" & [F:ADP]NIVDEF>1 & [F:ADP]NIVDEF<>4 & [F:ADP]CHAPITRE=CHAP
& Order By Key CLE=[F:ADP]CHAPITRE;[F:ADP]PARAM

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Openo FICTRT,0 Using [FIC]
Iomode adxifs "" Using [FIC]
Iomode adxirs chr$(10) Using [FIC]
Iomode adxium GUTF8 Using [FIC]
Wrseq TETADO;" ";mess(86,123,1) Using [FIC] : # Variables globales
Wrseq "Subprog GLOBVAR(SITE)" Using [FIC]
Wrseq "Value Char SITE" Using [FIC]
Wrseq "Onerrgo ERREUR" Using [FIC]
Wrseq "Local File ADOPAR [ADP]" Using [FIC]
Wrseq "Local File ADOVAL [ADW]" Using [FIC]
Wrseq "Local Char    PARAM(250)" Using [FIC]
For [LNK]CLE
 Read [ATY]CODTYP = [F:AGB]CODTYP
 If !fstat
  Case [F:ATY]TYPTYP
   When 1  : TEXTE = "Global Libelle  "
   When 2  : TEXTE = "Global Shortint "
   When 3  : TEXTE = "Global Integer  "
   When 4  : TEXTE = "Global Decimal  "
   When 5  : TEXTE = "Global Float    "
   When 6  : TEXTE = "Global Double   "
   When 7  : TEXTE = "Global Char     "
   When 8  : TEXTE = "Global Date     "
   When 9  : TEXTE = "Global Blbfile  "
   When 10 : TEXTE = "Global Clbfile  "
  Endcase
  TEXTE += [F:AGB]CODVAR
  If [F:ATY]TYPTYP=7 & [F:ATY]LNGTYP>0
   TEXTE += "(GLON"+[F:AGB]CODTYP+")"
  Elsif [F:AGB]LNGTYP<>""
   TEXTE += "("+[F:AGB]LNGTYP+")"
  Endif
  If [F:AGB]FORDIM(0) <> ""
   If [F:AGB]FORDEB(0) = 2 : TEXTE += "(1.." : Else : TEXTE += "(0.." : Endif
   TEXTE += [F:AGB]FORDIM(0)
  Endif
  If [F:AGB]FORDIM(1) <> ""
   If [F:AGB]FORDEB(1) = 2 : TEXTE += ",1.." : Else : TEXTE += ",0.." : Endif
   TEXTE += [F:AGB]FORDIM(1)
  Endif
  If [F:AGB]FORDIM(0) <> ""
   TEXTE += ")"
  Endif
  Wrseq TEXTE; Using [FIC]
  Call TEXTE([F:AGB]INTIT,CHAINE) From OBJDIV
  If CHAINE<>""
   Wrseq space$(max(0,35-len(TEXTE)))+" : # "+CHAINE Using [FIC]
  Else
   Wrseq "" Using [FIC]
  Endif
  Wrseq 'Call PARAM(SITE,"';[F:AGB]PARAM;'",PARAM) From ADOVAL' Using [FIC]
  Case [F:ATY]TYPTYP
   When 1,2,3,4,5,6 : Wrseq [F:AGB]CODVAR;" = val(PARAM)" Using [FIC]
   When 7           : Wrseq [F:AGB]CODVAR;" = PARAM" Using [FIC]
   When 8           : Wrseq 'If len(PARAM)=6 | len(PARAM)=8 : ';[F:AGB]CODVAR;' = PARAM : Endif' Using [FIC]
  Endcase
 Endif
Next LNK
Wrseq "End" Using [FIC]
Wrseq Using [FIC]
Wrseq "$ERREUR" Using [FIC]
Wrseq 'Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)-errm) From GESECRAN' Using [FIC]
Wrseq 'Resume' Using [FIC]
Wrseq Using [FIC]
Openo Using [FIC]
If GTRACE<>"" & !SILENCE
 Call ECR_TRACE(mess(159,133,1)-NOMTRT,0) From GESECRAN : # Validation du traitement ...
Endif
Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
If STAT & APPLI=nomap & MACHINE=adxmac(0)
 Call GLOBVAR("") From =NOMTRT
Endif
Call EFFACE(FICLCK,STAT) From ORDSYS
End
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AGLOBVAR  [AGB1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".AGLOBVAR"  [AGB1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File AGLOBVAR  [AGB2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".AGLOBVAR"  [AGB2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
OK = 1
If GTRACE=""
 Read [AGB2]AGB0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AGB1], [ATX1], [AGB2], [ATX2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
Return

$TR_COP
GOK = 1
Trbegin [AGB2] , [ATX2]
 Delete [AGB2] Where CODVAR=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AGLOBVAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AGB2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AGB1]AGB0 Where CODVAR=TABLE
  [F:AGB2] = [F:AGB1]
  Call COPTEXTE([F:AGB1]INTIT,[F:AGB2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AGB2]UPDUSR)>0 : [F:AGB2]UPDUSR = GUSER : Endif
  If dim([F:AGB2]UPDDAT)>0 : [F:AGB2]UPDDAT = date$ : Endif
  If dim([F:AGB2]UPDTIM)>0 : [F:AGB2]UPDTIM = time  : Endif
  Write [AGB2]
  If fstat
   GOK=0 : Call FSTA("AGB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPIE_DOC("AGB",TABLE,[M]DOSORG,[M]DOSDES) From SUBADO
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------  SUBPROG DE L'ECRAN AGB1  ---------------------------#
#----------------------------------------------------------------------------#
Subprog C_PARAM(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR<>""
 Read [ADP]ADP1 = VALEUR
 If fstat
  GMESSAGE = VALEUR-":"-mess(11,133,1) :  # Paramètre inexistant
  mkstat=2 : End
 Else
  Read [ATY]CODTYP = [M:AGB1]CODTYP
  Case [F:ADP]TYPVAL
   When 1   : If [F:ATY]TYPTYP<>7                 : Gosub MESS_PARAM : mkstat = 2 : End : Endif
   When 2,4 : If !find([F:ATY]TYPTYP,1,2,3,4,5,6) : Gosub MESS_PARAM : mkstat = 2 : End : Endif
   When 3   : If [F:ATY]TYPTYP<>8                 : Gosub MESS_PARAM : mkstat = 2 : End : Endif
  Endcase
 Endif
 Read [AGB]AGB2  = VALEUR
 If !fstat  & [M:AGB1]CODVAR<>[F:AGB]CODVAR
  GMESSAGE = VALEUR-":"-mess(229,133,1)-[F:AGB]CODVAR : # Ce paramètre est utilisé par la variable globale
  mkstat=2 : End
 Endif
Endif
End

$MESS_PARAM
GMESSAGE = mess(14,133,1) : # Type de données incorrect
GMESSAGE += "\|"+mess(86,123,1)-"("-mess([F:ATY]TYPTYP,30,1)-") <>" : # Variables globales
GMESSAGE -= mess(7,42,1)-"("-mess([F:ADP]TYPVAL ,11,1)-")" : # Paramètres
Return

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Integer OK
Call MODIF_DOC("AGB",[M]CODVAR,OK) From SUBADO
If !OK : VALEUR = [M]TEXTE : Affzo TEXTE : Endif
End

Subprog AM_PARAM(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR=""
 [M:AGB1]TRTSTD = ""
Else
 Gosub SET_TRT
 Read [ADP]ADP1=VALEUR
 If [F:ADP]NIVDEF=4
  [M:AGB1]TRTSTD = TRTUSR
 Else
  [M:AGB1]TRTSTD = TRTVAR
 Endif
Endif
Affzo [M:AGB1]TRTSTD
[M]PARAM = VALEUR
Gosub GRISE_TRTSTD
Gosub AFF_TRTINTIT
Gosub GRISE_TRTINI
Gosub GRISE_FORINI
Gosub GRISE_FORDIM
End

#----------------------------------------------------------------------------#
Subprog B1_PARAM(VALEUR)
Variable Char    VALEUR()
Read [ADP]ADP1=VALEUR
If fstat : Raz [F:ADP] : Endif
Call OBJET("ADP",VALEUR,[F:ADP]CHAPITRE) From GOBJET
VALEUR = [F:ADP]PARAM
End

#----------------------------------------------------------------------------#
Subprog B2_PARAM(VALEUR)
Variable Char    VALEUR()
Read [ADP]ADP1=VALEUR
If fstat : Raz [F:ADP] : Endif
Call VISU("ADP",VALEUR,[F:ADP]CHAPITRE) From SUBAOP
End

#----------------------------------------------------------------------------#
Subprog C_CODVAR(VALEUR)
Variable Char    VALEUR()
Call CONT_VAR(VALEUR)
End

Subprog CONT_VAR(VALEUR)
Variable Char VALEUR
Local Integer K
If VALEUR="" : End : Endif
Call STD(VALEUR,K)
If GADONIX<>2 & K
 Look [AGB]AGB0=VALEUR
 If fstat
  # Les variables globales commençant par $1$ sont réservées $2$/std
  GMESSAGE = func AFNC.MES2(mess(197,139,1),"G[A-W]",mess(1,7804,1))
  mkstat = 2 : End
 Endif
Elsif GADONIX=2 & !K
 Look [AGB]AGB0=VALEUR
 If fstat
  # Les variables globales commençant par $1$ sont réservées $2$/spé
  GMESSAGE = func AFNC.MES2(mess(197,139,1),"X,Y,Z,GX,GY,GZ",mess(3,7804,1))
  mkstat = 2 : End
 Endif
Endif
If !find(left$(VALEUR,1),"G","X","Y","Z")
 GMESSAGE = VALEUR-":"-mess(83,123,1)+"\|"+mess(88,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
Filter [AGB] Where left$([AGB]CODVAR,12)=left$(VALEUR,12) & [AGB]CODVAR<>VALEUR
Read [AGB]AGB0 First
Filter [AGB]
If !fstat
 # Les 12 premiers caractères sont déja utilisés par une autre variable globale
 GMESSAGE = VALEUR-":"-mess(127,139,1)-[F:AGB]CODVAR
 mkstat = 2 : End
Endif
VALEUR = format$("KTv2:250X",VALEUR)
End

#----------------------------------------------------------------------------#
Subprog AM_CODTYP(VALEUR)
Variable Char    VALEUR()
Gosub SET_TRT
#If [M]TRTSTD=TRTADX
# Read [ATY]CODTYP=VALEUR
# If !fstat & [F:ATY]TYPTYP=7 & [F:ATY]LNGTYP<>0
#  # Ce type de données ne peut pas être utilisé dans une variable déclarée dans #
#  GMESSAGE = func AFNC.MES(mess(274,139,1),TRTADX)
#  mkstat = 2 : End
# Endif
#Endif
[M]CODTYP = VALEUR
Gosub GRISE_TYPTYP
[M]TYPTYP = [F:ATY]TYPTYP
Affzo TYPTYP
End

Subprog C_LNGTYP(VALEUR)
Variable Char    VALEUR()
Local Decimal ENTIER , DECIM , CHIFFRE
If left$(VALEUR,1)<"0" or left$(VALEUR,1)>"9"
 End
Endif
CHIFFRE = val(num$(VALEUR))
If CHIFFRE=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
ENTIER = int(CHIFFRE)
DECIM  = 10*(CHIFFRE-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 7  : If DECIM<>0 | ENTIER>255            : mkstat = 1 : Endif : # Char
 When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
 When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

#----------------------------------------------------------------------------#
Subprog AV_DES1(VALEUR)
Variable Char    VALEUR()
If [M]PARAM <> ""
 Read [ADP]ADP1=[M]PARAM
 Call TEXTE([F:ADP]NAM,VALEUR) From OBJDIV
Else
 VALEUR = ""
Endif
End

#----------------------------------------------------------------------------#
Subprog B1_RANG(VALEUR)
Variable Decimal VALEUR
Filter [AGB] Where TRTSTD = [M]TRTSTD
Read [AGB]AGB1 Last
VALEUR = [F:AGB]RANG+10
Filter [AGB]
End

#----------------------------------------------------------------------------#
Subprog C_TRTSTD(VALEUR)
Variable Char    VALEUR()
Gosub SET_TRT
If left$(VALEUR,7)<>"WWAGLOB"
 GMESSAGE = VALEUR-":"-mess(83,123,1)+"\|"+mess(228,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Elsif [M]PARAM<>"" & !find(VALEUR,TRTUSR,TRTVAR)
 GMESSAGE = VALEUR-":"-mess(83,123,1) :  # Valeur incorrecte
 mkstat = 2 : End
Elsif [M]PARAM="" & find(VALEUR,TRTUSR,TRTVAR)
 GMESSAGE = VALEUR-":"-mess(83,123,1) :  # Valeur incorrecte
 mkstat = 2 : End
Else
 VALEUR = vireblc(VALEUR,3)
 [M]TRTSTD = VALEUR
 Gosub AFF_TRTINTIT
Endif
End

#----------------------------------------------------------------------------#
Subprog C_FORINI(VALEUR)
Variable Char    VALEUR()
Local Integer K
[M]FORINI = VALEUR
Gosub GRISE_TRTINI
Gosub GRISE_PARAM
End

#----------------------------------------------------------------------------#
Subprog C_FORDIM0(VALEUR)
Variable Char    VALEUR()
[M]FORDIM0 = VALEUR
Gosub GRISE_FORDIM
Gosub GRISE_PARAM
End

#----------------------------------------------------------------------------#
Subprog AM_CODVAR(VALEUR)
Variable Char    VALEUR()
End

