###################################################################################################
# Classe PJMTSKOPE
###################################################################################################
Funprog GET_KEYCONCAT_VARIABLES(ACTX, SOPPNUM, STASCOD, IOPENUM, IOPESPLNUM)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT  # Issue X3-68131 - 2018-02-12 by FGR : add context
Value Char SOPPNUM
Value Char STASCOD
Value Integer IOPENUM
Value Integer IOPESPLNUM

Local Char SARENDRE(250)

  # Specially used for translated texts key
  SARENDRE = SOPPNUM + "~" + STASCOD + "~" + num$(IOPENUM) + "~" + num$(IOPESPLNUM)
End SARENDRE

###################################################################################################
Funprog GET_ROODESAXX(CTX, SKEYCONCAT)
Variable Instance CTX Using OBJECT
Value Char SKEYCONCAT

Local Char SARENDRE(GLONDCO)

  Raz SARENDRE
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PJMTSKOPE", "ROODESAXX", SKEYCONCAT, AVOID.ACHAR) From ATEXTRA
End SARENDRE

###################################################################################################
Funprog GET_ROODESAXX_DET(CTX, SOPPNUM, STASCOD, IOPENUM, IOPESPLNUM)
Variable Instance CTX Using OBJECT
Value Char SOPPNUM
Value Char STASCOD
Value Integer IOPENUM
Value Integer IOPESPLNUM

Local Char SARENDRE(GLONDCO)
Local Char SKEYCONCAT(GLONVPJ)

  # Issue X3-68131 - 2018-02-12 by FGR
  Raz SARENDRE
  SKEYCONCAT = func GET_KEYCONCAT_VARIABLES(CTX.ACTX, SOPPNUM, STASCOD, IOPENUM, IOPESPLNUM)
  SARENDRE = func GET_ROODESAXX(CTX, SKEYCONCAT)
End SARENDRE

###################################################################################################
Funprog OPEDESTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTSKOPE", "OPEDESTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

###################################################################################################
Funprog OPECOMTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTSKOPE", "OPECOMTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

