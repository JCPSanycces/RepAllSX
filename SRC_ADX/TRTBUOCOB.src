Subprog IB_NBLIG2
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
End

Subprog IB_NBLIG1
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
End

