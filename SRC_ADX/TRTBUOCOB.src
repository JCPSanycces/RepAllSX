#<AdxTL>@(#)3.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Fonction : CLOOPNBUD - Fermeture/Ouverture Budgétaire
#   Action   : CLOOPNBUD
#   Fenêtre  : CLOOPNBUD
#   Ecran concerné : COB0, COB1, COB2
#   Description : Pour passer le statut d'une enveloppe et ses objets à 'fermé'
#
#--------------------------------------------------------------------------

Local Char PARAM(10)(1..5) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"CLOOPNBUD","TRTBUOCOB","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "OK"           : Gosub OK
 When "SETBOUT"      : Gosub SETBOUT
 When Default
Endcase
Return

$OUVRE
#Recup du parametrage du niveau d'approbation
Global Char GAPPNIV(3)
#Entité de l'utilisateur courant (GUSER)
Global Char GENTUSR(GLONENT)
Call PARAMUTIL("GDDENTUSR",GENTUSR,"","") From SUBAUS
#Tables utiles
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([GCM]) : Local File GACM       [GCM] : Endif
#Mask
#Local Mask COB0 [COB0], COB1 [COB1], COB2 [COB2]
Return

$SETBOUT
#CHMEN+="1"
If [M:COB1]NBLIG1<=0 & [M:COB2]NBLIG2<=0
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return

$DEBUT
Raz [M:COB1]
Raz [M:COB2]
[M:COB0]DATSTR=gdat$(1,1,year(date$))
[M:COB0]DATEND=gdat$(31,12,year(date$))
Affzo [M:COB0]
Affzo [M:COB1]
Affzo [M:COB2]
Return

$OK
Call DEBTRANS From GLOCK
Gosub TR_OKCLO
If GOK=1
 Call DEBTRANS From GLOCK
 Gosub TR_OKOPN
Endif
Return

$TR_OKCLO
# Fermetures
GOK=1
Trbegin [ENV], [ENF]
 For I=0 To [M:COB1]NBLIG1-1
  If [M]CLO(I)=2
   Case [M:COB1]NIV(I)
    When 1 :
     Readlock [ENV]ENV0 = [M:COB1]ENV(I)
     If fstat=1
      GOK=-1 : GLOCK="$ENV"-[M:COB1]ENV(I) : Break
     Elsif fstat
      GOK=0 : Call FSTA("ENV") From GLOCK : Break
     Elsif !fstat
      [F:ENV]STA=4
      Rewrite [ENV]
      If fstat
       GOK=0 : Call FSTA("ENV") From GLOCK : Break
      Endif
     Endif
    When 2 :
     Readlock [ENF]ENF0 = [M:COB1]ENV(I);[M:COB1]FIY(I)
     If fstat=1
      GOK=-1 : GLOCK="$ENF"-[M:COB1]ENV(I)-num$([M:COB1]FIY(I)) : Break
     Elsif fstat
      GOK=0 : Call FSTA("ENF") From GLOCK : Break
     Elsif !fstat
      [F:ENF]STAFIY=4
      Rewrite [ENF]
      If fstat
       GOK=0 : Call FSTA("ENF") From GLOCK : Break
      Endif
     Endif
    When 3:
     Readlock [BUD]BUD1=[M:COB1]ACCNUM(I)
     If fstat=1
      GOK=-1 : GLOCK="$BUD"-num$([M:COB1]ACCNUM(I)) : Break
     Elsif fstat
      GOK=0 : Call FSTA("BUD") From GLOCK : Break
     Elsif !fstat
      [F:BUD]STA=4
      Rewrite [BUD]
      If fstat
       GOK=0 : Call FSTA("BUD") From GLOCK : Break
      Endif
     Endif
   Endcase
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_OKCLO
 Elsif !GOK : Goto ABANDON
 Endif
Commit
Return

$TR_OKOPN
# Réouverture
GOK=1
Trbegin [ENV],[ENF]
 Local Integer FIY_OK
 For I=0 To [M:COB2]NBLIG2-1
  FIY_OK=0
  If [M]OPN(I)=2
   Gosub VERIF_EXE
   If FIY_OK
    Case [M:COB2]NIV(I)
     When 1 :
      Readlock [ENV]ENV0 = [M:COB2]ENV(I)
      If fstat=1
       GOK=-1 : GLOCK="$ENV"-[M:COB2]ENV(I) : Break
      Elsif fstat
       GOK=0 : Call FSTA("ENV") From GLOCK : Break
      Elsif !fstat
       [F:ENV]STA=3
       Rewrite [ENV]
       If fstat
        GOK=0 : Call FSTA("ENV") From GLOCK : Break
       Endif
      Endif
     When 2 :
      Readlock [ENF]ENF0 = [M:COB2]ENV(I);[M:COB2]FIY(I)
      If fstat=1
       GOK=-1 : GLOCK="$ENF"-[M:COB2]ENV(I)-num$([M:COB2]FIY(I)) : Break
      Elsif fstat
        GOK=0 : Call FSTA("ENF") From GLOCK : Break
      Elsif !fstat
       [F:ENF]STAFIY=3
       Rewrite [ENF]
       If fstat
        GOK=0 : Call FSTA("ENF") From GLOCK : Break
       Endif
      Endif
    When 3:
     Readlock [BUD]BUD1=[M:COB2]ACCNUM(I)
     If fstat=1
      GOK=-1 : GLOCK="$BUD"-num$([F:BUD]ACCNUM) : Break
     Elsif fstat
      GOK=0 : Call FSTA("BUD") From GLOCK : Break
     Elsif !fstat
      [F:BUD]STA=3
      Rewrite [BUD]
      If fstat
       GOK=0 : Call FSTA("BUD") From GLOCK : Break
      Endif
     Endif
    Endcase
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_OKOPN
 Elsif !GOK : Goto ABANDON
 Endif
Commit
Return

$ABANDON
Rollback
Return

$ROLL_TR_OKCLO
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_OKCLO : Endif

$ROLL_TR_OKOPN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_OKOPN : Endif

$VERIF_EXE
Local Integer ISOC, ISITE
Local Libelle LEDTYPGEN, LEDTYPANA
Local Decimal EXERCICE
ISOC = find([M:COB2]FCY(I),GSOC(1..GNBSOC))
If !ISOC
 ISITE = find([M:COB2]FCY(I),GSITE(1..GNBSITE))
 If ISITE
  SOCIETE = GSOCSITE(ISITE)
 Endif
Else
 SOCIETE = GSOC(ISOC)
Endif
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
Call GETEXE(SOCIETE,LEDTYPANA,[M:COB2]DAT(I),EXERCICE) From CPTSUB
Read [FIY]FIY0 = SOCIETE;LEDTYPANA;EXERCICE
If !fstat & [F:FIY]FIYSTA=2
 FIY_OK=1
Endif
Return

############################################################################

$CHARGE_TABS
#Criteres
Local Char CRITENV(250), CRITLIG(250), CRITLIGSUP(250)
Local Integer INDENV, INDENT, INDCCE3
Local Integer I,J
Local Integer OKACS, CTLACS
CTLACS = 1
Gosub CHARGE_TAB_CLO
Gosub CHARGE_TAB_OPN
If [M:COB1]NBLIG1=0 & [M:COB2]NBLIG2=0
 #Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN : Return
Endif
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Return

$CHARGE_TAB_CLO
CRITENV = '1=1'
CRITLIG = '1=1'
Gosub CRIT_SUIT
I=0
Raz [M:COB1]
#Intitulé enveloppe
Local Char INTENV(30)
Local Integer REP

#Les enveloppes
Filter [ENV] Where evalue(CRITENV)
For [ENV]ENV0 :# WHERE ENTMNA=GENTUSR
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif
 If OKACS
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  Call VERFALLAPP(1,[F:ENV]ENV,0,INDENV,REP)
  CRITLIGSUP = '1=1'
  Gosub CRITLIG
  If [F:ENV]STA=3 & REP
   [M:COB1]NIV(I)    = 1
   [M:COB1]ENV(I)    = [F:ENV]ENV
   Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
   [M:COB1]ENVINT(I) = INTENV
   [M:COB1]FCY(I)    = [F:ENV]FCY
   [M:COB1]DAT(I)    = [F:ENV]APPDAT
   [M:COB1]PRJ(I)    = [F:ENV]PRJ
   [M:COB1]ENTMNA(I) = [F:ENV]ENTMNA
   [M:COB1]CLO(I)    = 1
   I+=1
   #----TB protection----
   If I>dim([M:COB1]NIV)-1
    #Tableau Plein
    Call MESSAGE(mess(63,105,1)-"1"-mess(26,100,1)) From GESECRAN : I-=1 : Break
   Endif
   #--------------------
  Endif
 Endif
 #Les budgets exercices
 For [ENF]ENF0 Where ENV=[F:ENV]ENV & OKACS=1
  Call VERFALLAPP(2,[F:ENF]ENV,[F:ENF]FIYNUM,INDENV,REP)
  If [F:ENF]STAFIY=3 & REP
   [M:COB1]NIV(I) = 2
   [M:COB1]ENV(I)    = [F:ENF]ENV
   [M:COB1]FIY(I)    = [F:ENF]FIYNUM
   [M:COB1]DAT(I)    = [F:ENF]APPDATFIY
   Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENF]ENV,"") From ATEXTRA
   [M:COB1]ENVINT(I) = INTENV
   [M:COB1]FCY(I)    = [F:ENV]FCY
   [M:COB1]PRJ(I)    = [F:ENV]PRJ
   [M:COB1]ENTMNA(I) = [F:ENV]ENTMNA
   [M:COB1]CLO(I)    = 1
   I+=1
   #----TB protection----
   If I>dim([M:COB1]NIV)-1
    #Tableau Plein
    Call MESSAGE(mess(63,105,1)-"1"-mess(26,100,1)) From GESECRAN : I-=1 : Break 2
   Endif
   #--------------------
    #Les Lignes Budgétaires
   For [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG) & evalue(CRITLIGSUP)
     If [F:BUD]STA=3
      [M:COB1]NIV(I)    = 3
     [M:COB1]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
      [M:COB1]FIY(I)    = [F:BUD]FIY
      [M:COB1]ACCNUM(I) = [F:BUD]ACCNUM
     [M:COB1]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
      [M:COB1]ACC(I)    = [F:BUD]ACC
      [M:COB1]DAT(I)    = [F:BUD]APPDAT
     Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",evalue('[F:BUD]CCE'+num$(INDENV)),"") From ATEXTRA
      [M:COB1]ENVINT(I) = INTENV
      [M:COB1]FCY(I)    = [F:ENV]FCY
      [M:COB1]PRJ(I)    = [F:ENV]PRJ
      [M:COB1]ENTMNA(I) = [F:ENV]ENTMNA
      [M:COB1]CLO(I)    = 1
      I+=1
      #----TB protection----
      If I>dim([M:COB1]NIV)-1
       #Tableau Plein
       Call MESSAGE(mess(63,105,1)-"1"-mess(26,100,1)) From GESECRAN : I-=1 : Break 3
      Endif
      #--------------------
     Endif
    Next
   Endif
 Next
Next
Filter [ENV]
[M:COB1]NBLIG1=I
Affzo [M:COB1]
Gosub COLORIZE_1
Return

$COLORIZE_1
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M:COB1]ENV(0)
For I=0 To [M:COB1]NBLIG1-1
 If [M:COB1]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M:COB1]NBLIG1(I) With "GDD"+num$(K)
 Else
  Chgstl [M:COB1]NBLIG1(I) With "GDD"+num$(K)
 Endif
 ENVCUR=[M:COB1]ENV(I)
Next
Affzo [M:COB1]
Return

######################################################################################

$CHARGE_TAB_OPN
CRITENV = '1=1'
CRITLIG = '1=1'
Gosub CRIT_SUIT
I=0
Raz [M:COB2]

#Intitulé enveloppe
Local Char INTENV(30)

#Les enveloppes
Filter [ENV] Where evalue(CRITENV)
For [ENV]ENV0 :# WHERE ENTMNA=GENTUSR
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif
 If OKACS
  If [F:ENV]STA=4
   [M:COB2]NIV(I)    = 1
   [M:COB2]ENV(I)    = [F:ENV]ENV
   Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
   [M:COB2]ENVINT(I) = INTENV
   [M:COB2]FCY(I)    = [F:ENV]FCY
   [M:COB2]DAT(I)    = [F:ENV]APPDAT
   [M:COB2]PRJ(I)    = [F:ENV]PRJ
   [M:COB2]ENTMNA(I) = [F:ENV]ENTMNA
   [M:COB2]OPN(I)    = 1
   I+=1
   #----TB protection----
   If I>dim([M:COB2]NIV)-1
    #Tableau Plein
    Call MESSAGE(mess(63,105,1)-"2"-mess(26,100,1)) From GESECRAN : I-=1 : Break
   Endif
   #--------------------
  Endif
 Endif
 #Les budgets exercices
 For [ENF]ENF0 Where ENV=[F:ENV]ENV & OKACS=1
  If [F:ENF]STAFIY=4
   [M:COB2]NIV(I) = 2
   [M:COB2]ENV(I)    = [F:ENF]ENV
   [M:COB2]FIY(I)    = [F:ENF]FIYNUM
   [M:COB2]DAT(I)    = [F:ENF]APPDATFIY
   Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENF]ENV,"") From ATEXTRA
   [M:COB2]ENVINT(I) = INTENV
   [M:COB2]FCY(I)    = [F:ENV]FCY
   [M:COB2]PRJ(I)    = [F:ENV]PRJ
   [M:COB2]ENTMNA(I) = [F:ENV]ENTMNA
   [M:COB2]OPN(I)    = 1
   I+=1
   #----TB protection----
   If I>dim([M:COB2]NIV)-1
    #Tableau Plein
    Call MESSAGE(mess(63,105,1)-"2"-mess(26,100,1)) From GESECRAN : I-=1 : Break 2
   Endif
   #--------------------
  Endif
  #Les Lignes Budgétaires
  For [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
   If [F:BUD]STA=4
    [M:COB2]NIV(I)    = 3
    [M:COB2]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
    [M:COB2]FIY(I)    = [F:BUD]FIY
    [M:COB2]ACCNUM(I) = [F:BUD]ACCNUM
    [M:COB2]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
    [M:COB2]ACC(I)    = [F:BUD]ACC
    [M:COB2]DAT(I)    = [F:BUD]APPDAT
    Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",evalue('[F:BUD]CCE'+num$(INDENV)),"") From ATEXTRA
    [M:COB2]ENVINT(I) = INTENV
    [M:COB2]FCY(I)    = [F:ENV]FCY
    [M:COB2]PRJ(I)    = [F:ENV]PRJ
    [M:COB2]ENTMNA(I) = [F:ENV]ENTMNA
    [M:COB2]OPN(I)    = 1
    I+=1
    #----TB protection----
    If I>dim([M:COB2]NIV)-1
     #Tableau Plein
     Call MESSAGE(mess(63,105,1)-"2"-mess(26,100,1)) From GESECRAN : I-=1 : Break 3
    Endif
    #--------------------
   Endif
  Next
 Next
Next
Filter [ENV]
[M:COB2]NBLIG2=I
Affzo [M:COB2]
Gosub COLORIZE_2
Return

$COLORIZE_2
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M:COB2]ENV(0)
For I=0 To [M:COB2]NBLIG2-1
 If [M:COB2]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M:COB2]NBLIG2(I) With "GDD"+num$(K)
 Else
  Chgstl [M:COB2]NBLIG2(I) With "GDD"+num$(K)
 Endif
 ENVCUR=[M:COB2]ENV(I)
Next
Affzo [M:COB2]
Return

Subprog VERFALLAPP(CAS,ENVELOPPE,EXENUM,INDENV,REPONSE)
Value Integer CAS
Value Char    ENVELOPPE()
Value Integer EXENUM
Value Integer INDENV
Variable Integer REPONSE

REPONSE=1
If !clalev([ENF2]) : Local File ENVFIY [ENF2] : Endif
If !clalev([BUD2]) : Local File BUD    [BUD2] : Endif
If !clalev([BRV])  : Local File BUDREV [BRV]  : Endif
Case CAS
 When 1
  For [ENF2]ENF0 Where ENV=ENVELOPPE
   If [F:ENF2]STAFIY<3 : REPONSE=0 : Break : Endif
   For [BUD2]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENF2]ENV & FIY=[F:ENF2]FIYNUM
    If [F:BUD2]STA<3 : REPONSE=0 : Break 2 : Endif
   Next
  Next
 When 2
  For [BUD2]BUD0 Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=EXENUM
   If [F:BUD2]STA<3 : REPONSE=0 : Break : Endif
  Next
Endcase
Filter [BRV] Where ENV=ENVELOPPE & STA=2
Read [BRV]BRV0 First
If !fstat
 REPONSE=0
Endif
End

##################### CRITERES ######################################################

$CRIT_SUIT
#Société/Site
Local Integer SOC,J,K
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
SOC=find([M]CFY,GSOC(1..GNBSOC))
J=1
If SOC
 For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
  LISTFCY(J)=[F:FCY]FCY
  J+=1
 Next
Endif
CRITENV -= '& (FCY="'+[M:COB0]CFY+'" | find(FCY,LISTFCY(1..J)))'

If [M:COB0]FCY<>""
 CRITLIG -= '& CPY="'+[M:COB0]CPY+'" & FCY="'+[M:COB0]FCY+'"'
Else
 CRITLIG -= '& CPY="'+[M:COB0]CPY+'"'
Endif

#Entités
If [M:COB0]ALLENT<>2
 CRITENV -= '& ENTMNA>="'+[M:COB0]ENTSTR+'" & ENTMNA<="'+[M:COB0]ENTEND+'"'
Endif

#Enveloppes
If [M:COB0]ALLENV<>2
 CRITENV -= '& ENV>="'+[M:COB0]ENVSTR+'" & ENV<="'+[M:COB0]ENVEND+'"'
Endif

#Projets
If [M:COB0]ALLPRJ<>2
 CRITENV -= '& PRJ>="'+[M:COB0]PRJSTR+'" & PRJ<="'+[M:COB0]PRJEND+'"'
Endif

# Dates
CRITENV -= '& REASTR<=['+format$("D:DD[/]MM[/]YYYY",[M:COB0]DATEND)+'] & REAEND>=['+format$("D:DD[/]MM[/]YYYY",[M:COB0]DATSTR)+']'
Return


$CRITLIG
If [M:COB0]ALLENV<>2
 CRITLIGSUP -= '& CCE'+num$(INDENV)+'>="'+[M:COB0]ENVSTR+'" & CCE'+num$(INDENV)+'<="'+[M:COB0]ENVEND+'"'
Endif
If [M:COB0]ALLENT<>2
 CRITLIGSUP -= '& CCE'+num$(INDENT)+'>="'+[M:COB0]ENTSTR+'" & CCE'+num$(INDENT)+'<="'+[M:COB0]ENTEND+'"'
Endif
Return

######################################################################################
## Etiquettes des écrans COBx ; x=[0,1,2]  05&06/2008
######################################################################################

Subprog C_CFY(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC, ISITE
ISOC   = find(VALEUR,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 [M:COB0]FCY=VALEUR
 #06/10/09-Dmd54223:Autorisation site
 Call CONTFCY(VALEUR) From CPTSUB
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Else
 Call CONTCPY(VALEUR) From CPTSUB
  Raz [M:COB0]FCY
Endif
 [M:COB0]CPY=GSOC(ISOC)
Call SETGLBAPP([M:COB0]CPY,[M:COB0]APPNIV) From TRTGDD
#Affzo [M:COB0]
End

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CFY<>"" & [M]DATSTR<>[0/0/0] & [M]DATEND<>[0/0/0]
 Gosub CHARGE_TABS
Endif
End

######################################################################################

Subprog C_ALLENT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz   [M]ENTSTR,ENTEND
 Grizo [M]ENTSTR,ENTEND
Else
 Actzo [M]ENTSTR,ENTEND
Endif
End

Subprog C_ENTEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog C_ALLPRJ(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz   [M]PRJSTR,PRJEND
 Grizo [M]PRJSTR,PRJEND
Else
 Actzo [M]PRJSTR,PRJEND
Endif
End

Subprog C_PRJEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]PRJSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog C_ALLENV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz   [M]ENVSTR,ENVEND
 Grizo [M]ENVSTR,ENVEND
Else
 Actzo [M]ENVSTR,ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENVSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

##################################################

Subprog AM_CLO(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:COB1]CLO(nolign-1)=VALEUR
 Local Integer X,Y
 Case [M:COB1]NIV(nolign-1)
  When 1
   For X=0 To [M:COB1]NBLIG1-1
    If X<>(nolign-1) & [M:COB1]ENV(X)=[M:COB1]ENV(nolign-1)
     [M:COB1]CLO(X)=2 : Grizo [M:COB1]CLO(X) : Affzo [M:COB1]CLO(X)
    Endif
   Next X
  When 2
   For Y=0 To [M:COB1]NBLIG1-1
    If Y<>(nolign-1) & [M:COB1]ENV(Y)=[M:COB1]ENV(nolign-1) & [M:COB1]FIY(Y)=[M:COB1]FIY(nolign-1)
     [M:COB1]CLO(Y)=2 : Grizo [M:COB1]CLO(Y) : Affzo [M:COB1]CLO(Y)
    Endif
   Next Y
 Endcase
Else
 [M:COB1]CLO(nolign-1)=VALEUR
 Local Integer X,Y
 Case [M:COB1]NIV(nolign-1)
  When 1
   For X=0 To [M:COB1]NBLIG1-1
    If X<>(nolign-1) & [M:COB1]ENV(X)=[M:COB1]ENV(nolign-1)
     Actzo [M:COB1]CLO(X) : Affzo [M:COB1]CLO(X)
    Endif
   Next X
  When 2
   For Y=0 To [M:COB1]NBLIG1-1
    If Y<>(nolign-1) & [M:COB1]ENV(Y)=[M:COB1]ENV(nolign-1) & [M:COB1]FIY(Y)=[M:COB1]FIY(nolign-1)
     Actzo [M:COB1]CLO(Y) : Affzo [M:COB1]CLO(Y)
    Endif
   Next Y
 Endcase
Endif
End

Subprog AM_OPN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:COB2]OPN(nolign-1)=VALEUR
 Local Integer X,Y
 Case [M:COB2]NIV(nolign-1)
  When 2
   For X=0 To [M:COB2]NBLIG2-1
    If X<>(nolign-1) & [M:COB2]ENV(X)=[M:COB2]ENV(nolign-1) & [M:COB2]NIV(X)<[M:COB2]NIV(nolign-1)
     [M:COB2]OPN(X)=2 : Grizo [M:COB2]OPN(X) : Affzo [M:COB2]OPN(X)
    Endif
   Next X
  When 3
   For Y=0 To [M:COB2]NBLIG2-1
    If Y<>(nolign-1) & [M:COB2]ENV(Y)=[M:COB2]ENV(nolign-1)
     Case [M:COB2]NIV(Y)
      When 1 :
        [M:COB2]OPN(Y)=2 : Grizo [M:COB2]OPN(Y) : Affzo [M:COB2]OPN(Y)
      When 2 :
       If  [M:COB2]FIY(Y)=[M:COB2]FIY(nolign-1)
        [M:COB2]OPN(Y)=2 : Grizo [M:COB2]OPN(Y) : Affzo [M:COB2]OPN(Y)
       Endif
     Endcase
    Endif
   Next Y
 Endcase
Else
 [M:COB2]OPN(nolign-1)=VALEUR
 Local Integer X,Y
 For X=0 To [M:COB2]NBLIG2-1
  If X<>(nolign-1) & [M:COB2]ENV(X)=[M:COB2]ENV(nolign-1) & [M:COB2]NIV(X)<[M:COB2]NIV(nolign-1)
   If [M:COB2]NIV(nolign-1)<>3
    Actzo [M:COB2]OPN(X)
   Elsif [M:COB2]NIV(X)=2 & [M:COB2]FIY(X)=[M:COB2]FIY(nolign-1)
    Actzo [M:COB2]OPN(X)
   Endif
  Endif
   Affzo [M:COB2]OPN(X)
 Next X
Endif

