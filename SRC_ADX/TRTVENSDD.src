##########################################################################################
#                                                                                        #
# TRTVENSDD : Standard code for Sales module                                             #
#             Code related to  SEPA DIRECT DEBIT MANDATE (SDD)                           #
##########################################################################################
# 87923 : Gestion des prélèvements SDD                                                   #
##########################################################################################
#                                                                                        #
# Subprog DISPLAY_UMRNUM (LINVTYP)                                                       #
#   Gestion de l'affichage du champ UMRNUM sur SIH2                                      #
#                                                                                        #
# $GRIZO_UMRNUM                                                                          #
#   Gestion de la saisie du champ UMRNUM sur SIH2                                        #
#                                                                                        #
# Subprog CTRL_UMRNUM (LUMR,LCPY)                                                        #
#   Contrôle du champ UMRNUM                                                             #
#                                                                                        #
# $INIT_TPY                                                                              #
#   Initialisation des champs liés au paramétrage de la txn de saisie règlement          #
#   Gestion de la saisie des champs liés au règlement                                    #
#                                                                                        #
##########################################################################################


# ----------------------------------------------- #
# Gestion de l'affichage du champ UMRNUM sur SIH2 #
# ----------------------------------------------- #
# Entrée  LINVTYP : Catégorie de facture          #
# ----------------------------------------------- #
Subprog DISPLAY_UMRNUM (WINVTYP)
Value Integer WINVTYP

If GSDDMGT<>2 | !find(WINVTYP, 1,2)
    # La société ne gère pas le SDD ou ce n'est ni une facture ni un avoir
    # Champ invisible
    Chgfmt [M:SIH2]UMRNUM With "-K:"+num$(GLONMDT)+"X"
Else
    # Champ saisissable en fonction de la txn de saisie
    If GSLTUMRNUMCOD=1             : # Saisissable par txn
      Chgfmt [M:SIH2]UMRNUM With "K:"+num$(GLONMDT)+"X"
    Elsif GSLTUMRNUMCOD=2          : # Affiché     par txn
      Chgfmt [M:SIH2]UMRNUM With "KP:"+num$(GLONMDT)+"X"
    Elsif GSLTUMRNUMCOD=3          : # Invisible   par txn
      Chgfmt [M:SIH2]UMRNUM With "-K:"+num$(GLONMDT)+"X"
    Endif
Endif

End


# --------------------------------------------------------------- #
# Gestion de la saisie du champ UMRNUM sur SIH2                   #
# --------------------------------------------------------------- #
$GRIZO_UMRNUM

If dim([M:SIH2]UMRNUM)<=0 : Return : Endif

If [M:SIH2]SDDFLG=2
 Actzo [M:SIH2]UMRNUM
Else
 Grizo [M:SIH2]UMRNUM
Endif
Affzo [M:SIH2]UMRNUM

Return

# ----------------------------------------------- #
# Contrôle du champ UMRNUM                        #
# Vérifie si le mondat est validé                 #
# ----------------------------------------------- #
# Entrée  LUMRNUM : N° mandat                     #
#         LCPY    : Société                       #
# ----------------------------------------------- #
Subprog CTRL_UMRNUM(LUMRNUM,LCPY)
Value    Char    LUMRNUM
Value    Char    LCPY

If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
Raz mkstat, GMESSAGE

If [F:MDT]UMRNUM<>LUMRNUM | [F:MDT]CPY<>LCPY
 Read [MDT]MDT0 = LCPY;LUMRNUM
Endif
If [F:MDT]STA<>2
 GMESSAGE=[F:MDT]UMRNUM-":"-mess(382,192,1)
 mkstat=2 : End
Endif
End

# -------------------------------------------------------------------------------------------- #
# Initialisation des champs liés au paramétrage de la txn de saisie règlement                  #
# Gestion de la saisie des champs liés au règlement                                            #
# -------------------------------------------------------------------------------------------- #
# Utilisé par le bouton Règlement de la gestion des factures                                   #
# --> Dans $DEB_SAIREGSIH  de TRTVENFACP (A l'ouverture de la fenêtre des saisie du règlement) #
# --> Dans AM_PAYTYP       de SUBIVPY    (Après modification de la txn de règlement)           #
# -------------------------------------------------------------------------------------------- #
# L'enregistrement [F:TPY] est en ligne                                                        #
# -------------------------------------------------------------------------------------------- #
$INIT_TPY
Local Integer C1 , C2 , C3
Local Char    ZONE(10)

For ZONE="BAN","CHQNUM","CRDNUM","CHQBAN"
 Case evalue("[F:TPY]DAC"+ZONE)
  When 1       : C1 = 2 : C2 = 2
  When 2       : C1 = 2 : C2 = 1
  When Default : C1 = 1 : C2 = 1
 Endcase
 If evalue("dim([M]DAC"+ZONE+")")>0         : # Champ saisi/non saisi
  Assign "[M]DAC"+ZONE With C1
 Endif
 If evalue("dim([M]"+ZONE+"OBL)")>0         : # Champ obligatoire oui/non
  Assign "[M]"+ZONE+"OBL" With C2
 Endif
Next ZONE

[M:IVPY]PAYTYP=[F:TPY]PAYTYP
[M:IVPY]RATTYP=[F:TPY]RATTYP
[M:IVPY]BANCSH=[F:TPY]BANCSH

# Saisie du champ banque ou caisse
If [M:IVPY]BANCSH=1
    Raz [M:IVPY]CASH   : [M:IVPY]BANK = GBANDEF
    Diszo [M:IVPY]CASH : Actzo [M:IVPY]BANK
Else
    Raz [M:IVPY]BANK   : [M:IVPY]CASH = GCSHDEF
    Actzo [M:IVPY]CASH : Diszo [M:IVPY]BANK
Endif
# Saisie du champ n°chèque
If [M]DACCHQNUM=2
    Actzo [M:IVPY]CHQNUM
Else
    Raz [M:IVPY]CHQNUM : Diszo [M:IVPY]CHQNUM
Endif
# Saisie des champs type de carte, n° de carte
If [M]DACCRDNUM=2
    Actzo [M:IVPY]CRDTYP : Actzo [M:IVPY]CRDNUM : Actzo [M:IVPY]CRDEXYDAT
Else
    Raz [M:IVPY]CRDTYP : Raz [M:IVPY]CRDNUM : Raz [M:IVPY]CRDEXYDAT
    Diszo [M:IVPY]CRDTYP : Diszo [M:IVPY]CRDNUM : Diszo [M:IVPY]CRDEXYDAT
Endif
# Saisie du champ Etablissement payeur
If [M:IVPY]DACCHQBAN=2
    Actzo [M:IVPY]CHQBAN
Else
    Raz [M:IVPY]CHQBAN : Diszo [M:IVPY]CHQBAN
Endif

Return

################################################################################
# FGR 22/07/2013 : X3SUIVI87923
# Contrôle la condition de paiement relativement au tiers payeur, à la société
# ------------------------------------------------------------------------------
# Ajout du contrôle si la société gère le SDD.
# Le contrôle doit être réalisé en contrôle de la condition de paiement. Il doit se faire par rapport au tiers
# payeur du document. Si le tiers payeur est divers, la condition de paiement ne peut pas être de type SDD
# Le contrôle doit toujours s’activer si le champ est saisissable. S’il ne l’est pas, il faut faire le contrôle
# en création/modification du document.
# ------------------------------------------------------------------------------
Subprog CTRL_PTE_SEPA_SDD(SPTE, SCPY, SBPCPAY)
Value Char SPTE
Value Char SCPY
Value Char SBPCPAY

  If func AFNC.ACTIV("SDD") Then
    Call CTRL_PTE_SEPA(SPTE, SCPY, SBPCPAY)
  Endif
End

# ------------------------------------------------------------------------------
Subprog CTRL_PTE_SEPA_BPC_SDD(SPTE, SCPY, SBPC)
Value Char SPTE
Value Char SCPY
Value Char SBPC

  If func AFNC.ACTIV("SDD") Then
    Call CTRL_PTE_SEPA_BPC(SPTE, SCPY, SBPC)
  Endif
End

# ------------------------------------------------------------------------------
# FGR 02/04/2015 : X3SUIVI109045 (début)
Subprog CTRL_TRSF_BPR_BPEXCEPT(SBPR, IERR, SMESSAGE)
Value Char SBPR
Variable Integer IERR
Variable Char SMESSAGE

  IERR = 0
  Raz SMESSAGE
  If func AFNC.ACTIV("SDD") and func AFNC.ACTIV("MUL") Then
    # -----------------------------------------------
    Local File BPARTNER [BPR]
    Local File BPEXCEPT [BPE]
    # -----------------------------------------------
    Read [BPR]BPR0=SBPR
    If fstat Then
      IERR = 1
      SMESSAGE = SBPR - mess(23,100,1)
    Endif
    # -----------------------------------------------
    Filter [BPE] Where [F:BPE]BPRNUM = SBPR and [F:BPE]PTEBPC <> ""
    For [BPE]
      Call CTRL_PTE_SEPA_BPRC([F:BPE]PTEBPC, [F:BPE]CPY, SBPR)
      If mkstat Then
        IERR = 1
        SMESSAGE = mess(2,45,1) - [F:BPE]CPY - ":" - GMESSAGE
        Raz GMESSAGE
        mkstat = 0
        Break
      Endif
    Next
    Filter [BPE]
  Endif
End
# FGR 02/04/2015 : X3SUIVI109045 (fin)

# ------------------------------------------------------------------------------
# FGR 26/11/2013 : X3SUIVI94727 (début)
Subprog CTRL_PTE_SEPA_BPRC_SDD(SPTE, SCPY, SBPC)
Value Char SPTE
Value Char SCPY
Value Char SBPC

  If func AFNC.ACTIV("SDD") Then
    Call CTRL_PTE_SEPA_BPRC(SPTE, SCPY, SBPC)
  Endif
End
# FGR 26/11/2013 : X3SUIVI94727 (fin)

# ------------------------------------------------------------------------------
# FGR 26/11/2013 : X3SUIVI94727 (début)
# Contrôle par rapport au tiers payeur du client passé
# Cas particulier où le tiers peut ne pas être client.
#   => Dans ce cas si l'enregistrement n'existe pas dans BPCUSTOMER, le PTE ne
#      DOIT PAS être SEPA
Subprog CTRL_PTE_SEPA_BPRC(SPTE, SCPY, SBPC)
Value Char SPTE
Value Char SCPY
Value Char SBPC

Local Integer IFLGSDD
Local Char PARAM2(10)
Local Integer ISDDMGT

  If SPTE="" : End : Endif :#--CPO 111544
  If SCPY <> "" Then
    Call PARAML(SCPY, "SDDMGT", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    ISDDMGT = val(PARAM2)
    If ISDDMGT <> 1 and ISDDMGT <> 2 Then
      ISDDMGT = 1
    Endif
    If ISDDMGT <> 2 Then
      End
    Endif
  Endif
  # -----------------------
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  # -----------------------
  # FGR 30/06/2015 : X3SUIVI109045 (début)
#  Read [BPR]BPR0=SBPC
#  If fstat Then
#    GMESSAGE = mess(31,105,1) - ":" - SBPC - ":" - mess(87,100,1)  # FGR 05/11/2013 : X3SUIVI94110
#    mkstat = 1
#    End
#  Endif
#  # -----------------------
#  Read [BPC]BPC0=SBPC
#  If fstat Then
#    # Ca n'est pas un client : on contrôle la condition de paiement qui ne doit pas être SEPA
#    IFLGSDD = func IS_PTE_SDD(SPTE, SCPY)
#    If IFLGSDD = 2 Then
#      # Une condition de paiement SEPA ne peut être utilisée pour un prospect
#      GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(323,117,1)
#      mkstat = 1
#      End
#    Endif
#  Else
#    Call CTRL_PTE_SEPA_BPC(SPTE, SCPY, SBPC)
#  Endif
  If (GFONCTION = "GESBPR" and GREP <> "C" and GREP <> "D") or (GFONCTION = "GESBPC") or (GFONCTION = "GESBPP") Then
    Read [BPR]BPR0=SBPC
    If fstat Then
      GMESSAGE = mess(31,105,1) - ":" - SBPC - ":" - mess(87,100,1)  # FGR 05/11/2013 : X3SUIVI94110
      mkstat = 1
      End
    Endif
    # -----------------------
    Read [BPC]BPC0=SBPC
    If fstat Then
      # Ca n'est pas un client : on contrôle la condition de paiement qui ne doit pas être SEPA
      IFLGSDD = func IS_PTE_SDD(SPTE,SCPY)
      If IFLGSDD = 2 Then
        # Une condition de paiement SEPA ne peut être utilisée pour un prospect
        #GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(321,117,1)
        GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(340,117,1)
        mkstat = 1
        End
      Endif
    Else
      Call CTRL_PTE_SEPA_BPC(SPTE, SCPY, SBPC)
    Endif
  Else
    Local Integer IFLGSDD

    IFLGSDD = func IS_PTE_SDD(SPTE,SCPY)
    If IFLGSDD <> 2 Then
      # Une condition de paiement SEPA ne peut être utilisée pour un prospect
      GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(339,117,1)
      mkstat = 1
      End
    Endif
  Endif
  # FGR 30/06/2015 : X3SUIVI109045 (fin)
End
# FGR 26/11/2013 : X3SUIVI94727 (fin)

# ------------------------------------------------------------------------------
# Contrôle par rapport au tiers payeur du client passé
Subprog CTRL_PTE_SEPA_BPC(SPTE, SCPY, SBPC)
Value Char SPTE
Value Char SCPY
Value Char SBPC

Local Integer IFLGSDD   # FGR 05/11/2013 : X3SUIVI94110
Local Char PARAM2(10)   # FGR 26/11/2013 : X3SUIVI94727
Local Integer ISDDMGT   # FGR 26/11/2013 : X3SUIVI94727

  If SPTE = "" : End : Endif #--CPO 109045
  # -----------------------
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  # -----------------------
  Read [BPR]BPR0=SBPC
  If fstat Then
    GMESSAGE = mess(31,105,1) - ":" - SBPC - ":" - mess(87,100,1)  # FGR 05/11/2013 : X3SUIVI94110
    mkstat = 1
    End
  Endif
  # -----------------------
  Read [BPC]BPC0=SBPC
  If fstat Then
    GMESSAGE = mess(12,159,1) + "/" + mess(13,159,1) - ":" - SBPC - ":" - mess(87,100,1)  # FGR 05/11/2013 : X3SUIVI94110
    mkstat = 1
    End
  Endif
  # -----------------------
  If [F:BPR]BPCFLG = 2 Then  # FGR 05/11/2013 : X3SUIVI94110 pas pour les prospects
    Call CTRL_PTE_SEPA(SPTE, SCPY, [F:BPC]BPCPYR)
  Elsif [F:BPR]PPTFLG = 2 Then
     #--CPO 109045 Quelle que soit la gestion SDD de la société, il ne faut pas avoir de condition SEPA sur un prospect
#    # FGR 05/11/2013 : X3SUIVI94110 Pour les prospects on interdit le SEPA.
#    If SCPY <> "" Then
#      # FGR 26/11/2013 : X3SUIVI94727 (début)
#      # Faire le test par rapport à la société passée et pas par rapport à la globale.
#      # Si la société ne gère pas le SEPA, on ne contrôle rien
#      #If dim(GSDDMGT) >= 0 and GSDDMGT <> 2 Then
#      #  # Si la société ne gère pas le SEPA, on ne contrôle rien
#      #  End
#      #Endif
#      Call PARAM(SCPY, "SDDMGT", PARAM2) From ADOVAL
#      ISDDMGT = val(PARAM2)
#      If ISDDMGT <> 1 and ISDDMGT <> 2 Then
#        ISDDMGT = 1
#      Endif
#      If ISDDMGT <> 2 Then
#        End
#      Endif
#      # FGR 26/11/2013 : X3SUIVI94727 (fin)
#    Endif
    #--/
    # C'est un prospect : on contrôle la condition de paiement qui ne doit pas être SEPA
    IFLGSDD = func IS_PTE_SDD(SPTE,SCPY)
    #--CPO 109045 Quelle que soit la gestion SDD de la société, il ne faut pas avoir de condition SEPA sur un prospect
    #If IFLGSDD <>2 Then
    If IFLGSDD = 2 Then
    #--/
      # Une condition de paiement SEPA ne peut être utilisée pour un prospect
      GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(321,117,1)
      mkstat = 1
      End
    Endif
  Endif
End

# ------------------------------------------------------------------------------
Subprog CTRL_PTE_SEPA(SPTE, SCPY, SBPCPAY)
Value Char SPTE
Value Char SCPY
Value Char SBPCPAY

Local Integer IFLGSDD
Local Char PARAM2(10)   # FGR 26/11/2013 : X3SUIVI94727
Local Integer ISDDMGT   # FGR 26/11/2013 : X3SUIVI94727

  If SPTE = "" : End : Endif #--CPO 109045
  # FGR 22/07/2013 : X3SUIVI87923
  # Si la société n'est pas renseignée le contrôle doit toujours se faire au niveau du tiers.
  If SCPY <> "" Then
    #Local File COMPANY [CPY]
    # -----------------------
    #Read [CPY]CPY0=SCPY
    #If fstat Then
    #  GMESSAGE = mess(16,104,1) - ":" - SCPY
    #  mkstat = 1
    #  End
    #Endif
    # -----------------------
    # FGR 26/11/2013 : X3SUIVI94727 (début)
    # Faire le test par rapport à la société passée et pas par rapport à la globale.
    # Si la société ne gère pas le SEPA, on ne contrôle rien
    #If dim(GSDDMGT) >= 0 and GSDDMGT <> 2 Then
    #  # Si la société ne gère pas le SEPA, on ne contrôle rien
    #  End
    #Endif
    Call PARAML(SCPY, "SDDMGT", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    ISDDMGT = val(PARAM2)
    If ISDDMGT <> 1 and ISDDMGT <> 2 Then
      ISDDMGT = 1
    Endif
    If ISDDMGT <> 2 Then
      End
    Endif
    # FGR 26/11/2013 : X3SUIVI94727 (fin)
  Endif
  # -----------------------
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  # -----------------------
  Read [BPR]BPR0=SBPCPAY
  If fstat Then
    GMESSAGE = mess(53,15,1) - ":" - SBPCPAY - ":" - mess(87,100,1)
    mkstat = 1
    End
  Endif
  # -----------------------
  Read [BPC]BPC0=SBPCPAY
  If fstat Then
    GMESSAGE = mess(53,15,1) - ":" - SBPCPAY - ":" - mess(87,100,1)
    mkstat = 1
    End
  Endif
  # -----------------------
  If [F:BPC]BPCTYP = 2 Then
    # C'est un tiers divers : on contrôle la condition de paiement qui ne doit pas être SEPA
    IFLGSDD = func IS_PTE_SDD(SPTE,SCPY)
    If IFLGSDD = 2 Then
      # Une condition de paiement SEPA ne peut être utilisée pour une tiers divers
      GMESSAGE = mess(58,2289,1) - SPTE - ":" - mess(318,117,1)
      mkstat = 1
      End
    Endif
  Endif
  # -----------------------
End

# ------------------------------------------------------------------------------
Funprog IS_PTE_SDD(SPTE, SCPY)
Value Char SPTE
Value Char SCPY

Local Integer IARENDRE
Local Integer IRET
Local Char SLEG(GLONADI)

  IARENDRE = G_NO
  Raz SLEG
  If SCPY <> "" Then
    Local File COMPANY [CPY]
    Read [CPY]CPY0=SCPY
    SLEG = [F:CPY]LEG
  Endif
  Local File TABPAYTERM [TPT]
  Call LEC_TPT_LEG(SLEG, SPTE, 1, IRET) From TRTLECLEG
  If IRET Then
    # erreur de lecture
  Else
    #--CPO 87923 : Gestion des prélèvements SDD
    #--Cas de la condition de paiement retenue "Toutes législations"
    #--Dont le/les modes de règlements sont déterminés par le contexte
    #--Selon exception gérée pour le TPT : même leg et même groupe entre TPT et TAM
    #--Ici, il faut chercher le mode de réglement lié au contexte,
    #--car la finance utilise les modes de règlements en fonction de GCURLEG et non pas [TPT]LEG
    If [F:TPT]LEG=""
      Call PTESDD(SPTE,IARENDRE) From INVSDDLIB
      If IARENDRE > 0 : IARENDRE=G_YES Else IARENDRE=G_NO : Endif
    Else
    #--/
      If [F:TPT]SDDFLG = G_YES Then
        IARENDRE = G_YES
      Endif
    Endif
  Endif
End IARENDRE

################################################################################
#--CPO 87923 : Gestion des prélèvements SDD
# ------------------------------------------------------------------- #
# Init et contrôle du UMRNUM lors des traitements auto de facturation #
# ------------------------------------------------------------------- #
Subprog INIT_CTL_UMRNUM(CPY,BPR,PTE,UMRNUM,MESSAGE)
Value Char    CPY
Value Char    BPR
Value Char    PTE
Variable Char UMRNUM
Variable Char MESSAGE

Local Integer WFLG_UMRNUM
Local Integer WFLG_WARNING

Raz [L]MESSAGE

#--Uniquement si code activité SDD actif et paramètre société à Oui
If func AFNC.ACTIV("SDD") & func AFNC.PARAM("SDDMGT",[L]CPY)="2"

  #--Si la condition de paiement est gérée avec SDD
  #Call PTESDD([L]PTE,WFLG_UMRNUM) From INVSDDLIB
  [L]WFLG_UMRNUM=func TRTVENSDD.IS_PTE_SDD([L]PTE,[L]CPY)

  If [L]WFLG_UMRNUM = G_YES

    If [L]UMRNUM=""
      #--Si pas déjà renseigné :
      #---soit par le PE ALISIH de TRTVENFAC
      #---soit depuis le document d'origine(à l'avenir)
      #--Mandat par défaut et Statut=2 (Validé)
      Call INIT_UMRNUM([L]CPY,[L]BPR,2,2,[L]UMRNUM) From INVSDDLIB
    Endif

    #--Contrôle du mandat
    If [L]UMRNUM<>""
      Call CTL_UMRNUM([L]UMRNUM,[L]CPY,[L]BPR) From INVSDDLIB
      If mkstat : Raz mkstat : [L]WFLG_WARNING=1 : Endif
    Else
      #--Si le champ n'est pas alimenté alors que la condition de paiement est gérée en SDD
      [L]WFLG_WARNING=1
    Endif

  Elsif [L]UMRNUM<>""
   #--Si condition de paiement non gérée SDD et mandat renseigné, on affiche le message
   [L]WFLG_WARNING=1
  Endif

Elsif [L]UMRNUM<>""
	#--Si pas de code activité ou société non gérée SDD et mandat renseigné, on affiche le message
	[L]WFLG_WARNING=1
Endif

If [L]WFLG_WARNING = 1
    MESSAGE  = mess(801,197,1)+"."-mess(802,197,1)
    Raz [L]UMRNUM
Endif

End
#--/

