######################################################################################
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCEE) 04/06/2009 14:51:13 (VPO)
######################################################################################
Subprog AS_XICTCTY(VALEUR)
Variable Char    VALEUR()
If dim([M:SOH1]BPAADD)>0 & dim([M:SOH0]BPCORD)>0
    Read [BPA]BPA0 = 1;[M:SOH0]BPCORD;[M:SOH1]BPAADD
    If !fstat
        [M:SCEE]WPOSCOD=[F:BPA]POSCOD
    Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SCEE) 20/08/2015 09:51:55 (FGR)
######################################################################################
Subprog AV_XEECNUM(VALEUR)
Variable Char    VALEUR()

  # FGR 20/08/2015 : X3SUIVI109467 : nécessaire pour contredire le type de données du champ
  # Ctrl autorisation modification
  If !find (GREP,"C","D") Then
    GBIDC2 = "M"
    Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2 Then
      Diszo [M]1-99
      End
    Endif
  Endif
  #
  If [M]ABRMSK = "SIH0" Then
    If [M:SIH1]INVSTA=3 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
  Elsif [M]ABRMSK = "SDH0" Then
    If [M:SDH1]CFMFLG=2 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
  Elsif [M]ABRMSK = "TNH0" Then
    If [M:TNH1]CFMFLG=2 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
  Elsif [M]ABRMSK = "SOH0" Then
    If GCONSULT Diszo [M]1-99 Endif
  Elsif GCONSULT Then
    Diszo [M]1-99
  Endif
End

