######################################################################################
## Etiquette ajoutée par le superviseur (écran SCEE) 13/07/2005 12:53:59 (LD)
######################################################################################
Subprog AM_XFFWNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" Raz [M]XFFWADD : Affzo [M]XFFWADD : Diszo [M]XFFWADD : End : Endif

[M:SCEE]XFFWADD=[F:BPT]BPAADD
Affzo [M:SCEE]XFFWADD : Actzo [M:SCEE]XFFWADD

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCEE) 13/07/2005 12:50:26 (LD)
######################################################################################
Subprog C_XFFWADD(VALEUR)
Variable Char    VALEUR()

Look [BPA]BPA0 = 1;[M:SCEE]XFFWNUM;VALEUR
If   fstat : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif

End
