###################################################################################################
# Classe PJMCOSTGRP
# Issue X3-26712 - 2017-05-19 by ALMON/FGR
###################################################################################################
$PCGTYP
  # Note: PROPAGATE is managed at class parent level
  Case [L]ARULE
    When "INIT"      : Gosub PCGTYP_INIT
    When "CONTROL"   : Gosub PCGTYP_CONTROL
  Endcase
Return

$PCGTYP_INIT
  this.PCGTYP = 1
Return

$PCGTYP_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PCGTYP <> this.snapshot.PCGTYP Then
      [L]ASTATUS = fmet this.ASETERROR("PCGTYP", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$PCGGRPMAT
  Case [L]ARULE
    When "CONTROL"   : Gosub PCGGRPMAT_CONTROL
  Endcase
Return

$PCGGRPMAT_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PCGGRPMAT <> this.snapshot.PCGGRPMAT Then
      [L]ASTATUS = fmet this.ASETERROR("PCGGRPMAT", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$PCGGRPLAB
  Case [L]ARULE
    When "CONTROL"   : Gosub PCGGRPLAB_CONTROL
  Endcase
Return

$PCGGRPLAB_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PCGGRPLAB <> this.snapshot.PCGGRPLAB Then
      [L]ASTATUS = fmet this.ASETERROR("PCGGRPLAB", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$PCGGRPMAC
  Case [L]ARULE
