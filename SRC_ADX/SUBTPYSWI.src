######################################################################################################
# Project       : Swiss Localization
# File          : SUBTPYSWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 08.05.15
######################################################################################################
# Module        : Accounting
# Description   : check if BVR type of payment method fits to BVR type of payment type
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
 # 19.06.15 |Bader |V9     |use LEC_TAM instead of direct read in TABPAM (because of legislation)
######################################################################################################

Subprog C_PAM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
   If dim([M:TPY1]SWIPAYTYP) > 0   # field "Swiss payment type" exists?
     If [M:TPY1]SWIPAYTYP > 1      # DTA or EZAG payment
        If !clalev([F:TAM]) : Local File TABPAM [TAM] : Endif   # payment methods
        Call LEC_TAM([M:TPY0]LEG, VALEUR) From CPTLEC
        If !fstat
          OK = 1
          # X3-29237
          Case [M:TPY1]SWIPAYTYP
             When 2 :              # DTA
                If [F:TAM]SWIPAMBVR <> 3 : OK = 0 : Endif
             When 3 :              # EZAG
                If [F:TAM]SWIPAMBVR <> 4 : OK = 0 : Endif
             When 4 :              # ISO
                If [F:TAM]SWIPAMBVR <> 5 : OK = 0 : Endif
          Endcase
          If !OK
            Call AVERTIR(mess(47,3648,1),OK) From GESECRAN  # The Swiss payment type of the payment method differs from the Swiss payment type of the payment entry type.
            If OK=1 mkstat=2 : End Endif
          Endif
        Endif
     Endif
   Endif
End

