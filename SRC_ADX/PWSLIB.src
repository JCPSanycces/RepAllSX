#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################################
# Traitement PWSLIB - Librairie maj table temporaire PWRKSTT      V150 #
########################################################################
#
# Subprog EFFACE_PWS(LCODFNC,LRET)
#         Effacement lignes temporaires session courante
#
# Subprog EFFACE_LIGD_PWS(LCODFNC,LVCRTYP,LVCRNUM,LCRLIN,LVCRSEQ,LRET)
#         Effacement une ligne temporaire session courante
#
# Subprog WRITE_PWS(LCODFNC)
#         Ecriture de la ligne [F:PWS] courante
#         après avoir contrôlé qu'on soit bien dans une transaction
#
########################################################################

$OPEN_FILES
If clalev([F:PWS])<=0 Local File PWRKSTT [PWS] : Endif
Return


#-----------------------------------------------#
# Effacement écran et fichier de travail STT    #
# pour l'écran courant et la connexion courante #
#-----------------------------------------------#
Subprog EFFACE_PWS(LCODFNC,LRET)
Value    Char      LCODFNC
Variable Integer   LRET

If clalev([M:PSTT])  Raz [M:PSTT] : Endif
If clalev([M:PSCM])  Raz [M:PSCM] : Endif
LRET=1
Call DEBTRANS From GLOCK
$TR_PWS
GOK=1
Trbegin [PWS]
  Delete [PWS] Where PRONUM=adxuid(1) & CODFNC=LCODFNC
  If    fstat=1  GOK=-1 : LRET=0 : GLOCK="$PWRKSTT"-num$(adxuid(1))-LCODFNC
        Goto ROLL_PWS
  Elsif fstat GOK=0  : LRET=0 : Call RSTA("PWS",num$(adxuid(1))-LCODFNC) From GLOCK
        Goto AB_PWS
  Endif
Commit
End
$AB_PWS
Rollback : End
$ROLL_PWS
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWS : Endif : End


#-----------------------------------------------#
# Effacement d'une ligne du fichier de travail  #
# pour l'écran courant et la connexion courante #
#-----------------------------------------------#
Subprog EFFACE_LIGD_PWS(LCODFNC,LVCRTYP,LVCRNUM,LVCRLIN,LVCRSEQ,LRET)
Value    Char    LCODFNC
Value    Integer LVCRTYP
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Variable Integer LRET

# Issue 95496 & 97173 - 2014-02-26 by CCC : transaction could have been opened before
Local Integer LTRANS : LTRANS=adxlog

LRET=1
Call DEBTRANS From GLOCK
$TR_PWS_LIGD
If !LTRANS
    GOK=1
    Trbegin [PWS]
Endif

  If LVCRSEQ=-1   : # Effacer tout
     Delete [F:PWS] Where PRONUM=adxuid(1) & CODFNC=LCODFNC & VCRTYP=LVCRTYP
&                       & VCRNUM=LVCRNUM   & VCRLIN=LVCRLIN
  Else            : # Effacer ligne courante
     Delete [F:PWS] Where PRONUM=adxuid(1) & CODFNC=LCODFNC & VCRTYP=LVCRTYP
&                       & VCRNUM=LVCRNUM   & VCRLIN=LVCRLIN & VCRSEQ=LVCRSEQ
  Endif
  LRET=adxdlrec
  If    fstat=1  GOK=-1 : LRET=0 : GLOCK="$PWRKSTT"-num$(adxuid(1))-LCODFNC
        Goto ROLL_PWS_LIGD
  Elsif fstat GOK=0  : LRET=0 : Call RSTA("PWS",num$(adxuid(1))-LCODFNC) From GLOCK
        Goto AB_PWS_LIGD
  Endif
If !LTRANS
    Commit
Endif
End

$AB_PWS_LIGD
If !LTRANS
    Rollback
Endif
End

$ROLL_PWS_LIGD
If !LTRANS
    Rollback
Endif
Call ROLL From GLOCK : If !GROLL Goto TR_PWS_LIGD : Endif
End


#-------------------------------------------------#
# Ecriture de la ligne dans le fichier de travail #
# pour l'écran courant et la connexion courante   #
#-------------------------------------------------#
Subprog WRITE_PWS(LCODFNC)
Value Char    LCODFNC()

Local Integer WTRBEGIN
Raz WTRBEGIN

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [PWS]
   WTRBEGIN=1
Endif

If [F:PWS]CODFNC=""
   [F:PWS]PRONUM = adxuid(1)
   [F:PWS]CODFNC = LCODFNC
Endif
Write [PWS]

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

End
