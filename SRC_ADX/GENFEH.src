#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENTRT(nomap,"DUE")
End
Call GENATB(nomap,"AEM")
Call OUVRE_TRACE("test") From LECFIC
Call CONTAMK(nomap,"AEM")
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#-------------------------------------------------------------------------------
$DEFVAR
Local Libelle EMISSION, EXTRACTION, RECEPTION, NIVEAU
Return

#-------------------------------------------------------------------------------
$GENVAR
Local Char FEHABR(5), FEHTRT([V]GLONADC), FEHATB([V]GLONATB), FEHMSK([V]GLONATB)
Case [L]FEH
When "AEM"
 [L]FEHABR="MEA"
 [L]FEHTRT="WWMEA"
 [L]FEHATB="MEAEMP"
When "CCS"
 [L]FEHABR="CCS"
 [L]FEHTRT="WWCCS"
 [L]FEHATB="CERTIFCCS"
When "DUE"
 [L]FEHABR="DUE"
 [L]FEHTRT="WWDUE"
 [L]FEHATB="DUEEMP"
When "TRL"
 [L]FEHABR="TRL"
 [L]FEHTRT="WWTRL"
 [L]FEHATB="TIKRESLIG"
When "CQL"
 [L]FEHABR="HRCQL"
 [L]FEHTRT="WWCQL"
 [L]FEHATB="CHQDEJLIG"
 [L]FEHMSK="CQL"
Endcase
Return

#-------------------------------------------------------------------------------
Subprog GENTRT(DOSSIER,FEH)
Value Char DOSSIER(), FEH

Local Char     CONTROLE(250), FICSRC(250), SAVIFS(1), SAVIRS(2)
Local Shortint I, J, K
Local Integer  OK

Gosub GENVAR

Local File =[L]DOSSIER+".FILEDIH" [FEH] Where FEH=[L]FEH
Local File =[L]DOSSIER+".AMSKZON" [AMZ]
Local File =[L]DOSSIER+".ATYPE"   [ATY]
Local File =[L]DOSSIER+".FILEDIL" [FEL] Where FEH=[L]FEH
Local File =[L]DOSSIER+".AMSKPAR" [AMP]

[L]CONTROLE ='func GENFEH.LISTE([L]OK) | [F:FEH]OBL=2 | [F:FEH]FMT>""'
&          - '| [F:FEH]TYP=2 | ([F:FEH]TYP=3 & [F:ATY]TYPTYP=7) | len([F:FEH]CTL)>0'
[L]FICSRC   =filpath("TRT",[L]FEHTRT,"src",[L]DOSSIER)
[L]SAVIFS   =adxifs
[L]SAVIRS   =adxirs
adxifs      =""
adxirs      =chr$(10)

Openo [L]FICSRC, 0

Wrseq '#<AdxT';[V]GADOVERS;'>@(#)0.0.0.0 $Revision$'
Wrseq '#'
Wrseq "# Traitement automatique de l'EDI ";[L]FEH
Wrseq '# généré par ';trtcou;' le ';num$(date$);' à ';time$
Wrseq '#'
Wrseq
# sba : pb alias masque différent de la table
If( [L]FEHMSK="")
  [L]FEHMSK=[L]FEHABR
Endif
Wrseq '$DEFVAR'
#Link [FEH] With [AMZ]DICO(1)~=ZON
#&             , [ATY]CODTYP  =[AMZ]CODTYP
#&            As [LNK]
#&         Where [AMZ]CODMSK>=[L]FEHABR+"0" & [AMZ]CODMSK<=[L]FEHABR+"9"

Link [FEH] With [AMZ]DICO(1)~=ZON
&             , [ATY]CODTYP  =[AMZ]CODTYP
&            As [LNK]
&         Where [AMZ]CODMSK>=[L]FEHMSK+"0" & [AMZ]CODMSK<=[L]FEHMSK+"9"
For [LNK]FEH0(2)
 Case [F:ATY]TYPTYP
  When 2     : Wrseq 'Local Shortint ';[F:FEH]ZON
  When 3     : Wrseq 'Local Integer  ';[F:FEH]ZON
  When 4,5,6 : Wrseq 'Local Decimal  ';[F:FEH]ZON
  When 7     : Wrseq 'Local Char     ';[F:FEH]ZON;'(';[F:FEH]LNG;')'
  When 8     : Wrseq 'Local Date     ';[F:FEH]ZON
 Endcase
Next
Wrseq 'Return'
Wrseq

Wrseq '$RAZVAR'
Wrseq 'Case [L]NIVEAU'
Filter [FEH] Order By Key CLE=LVL;LOC
For [FEH]CLE(1) Where ZON>""
 Wrseq 'When ';[F:FEH]LVL
 For [FEH]CLE : Wrseq ' Raz [L]';[F:FEH]ZON : Next
Next
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

Wrseq '$OPPOSE'
Wrseq 'Case [L]NIVEAU'
Filter [LNK] Order By Key CLE=LVL;LOC
For [LNK]CLE(1) Where find([ATY]TYPTYP,2,3,4,5,6)<>0
 Wrseq 'When ';[F:FEH]LVL
 For [LNK]CLE(2)
  Wrseq ' [L]';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);"*=-1"
 Next
Next
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

Wrseq '$LIENS'
Filter [AMP] Order By Key CLE=CODAFF;CODZON;CODPAR
For [AMP]CLE Where CODAFF>=[L]FEHABR+"0" & CODAFF<=[L]FEHABR+"9"
&                & find(CODPAR,"NOCOL","ZONE")<>0
 Case [F:AMP]CODPAR
 When "NOCOL"
  [L]OK=val([F:AMP]VALPAR)
 When "ZONE"
  If [L]OK>0 & ctrans([F:AMP]VALPAR,'"','')>""
   Wrseq 'If [M:';[F:AMP]CODAFF;']';[F:AMP]CODZON;'>""'
   Wrseq ' Read [FEL]FEL0=';[L]OK;';[M:';[F:AMP]CODAFF;']';[F:AMP]CODZON;';"';[L]FEH;
   Wrseq '"'
   Wrseq ' If !fstat : [M:';[F:AMP]CODAFF;']';ctrans([F:AMP]VALPAR,'"','');'=[F:FEL]DES';
   Wrseq ' : Endif'
   Wrseq 'Endif'
  Endif
 Endcase
Next
Filter [AMP]
Wrseq 'Return'
Wrseq

Wrseq '$CHGTZON'
Filter [LNK] Order By Key CLE=[AMZ]CODMSK;[AMZ]NUMBLOC;[AMZ]NOZONE;[AMZ]CODZON
I=0
For [LNK]CLE
 Wrseq 'Chgtzn [';[F:AMZ]CODMSK;'] ';format$("K:"+num$([V]GLONAVA)+"X",[F:AMZ]CODZON);
 Wrseq ' With [L]INTIT(';I;')'
 I+=1
Next
Filter [LNK]
Wrseq 'Return'
Wrseq

Wrseq '$EXTRACTION'
Wrseq 'Case [L]NIVEAU'
#Filter [FEH] Order By Key CLE=LVL;LOC
For [FEH]CLE(1) Where num$(len(FRM))>"0" & DAC=1
 Wrseq 'When ';[F:FEH]LVL
 For [FEH]CLE : Wrseq ' Gosub D_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON) : Next
Next
Filter [FEH]
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

Wrseq '$MAJFIC'
Filter [FEH]
For [FEH]FEH0 Where ZON>"" & DAC<3
 Wrseq '[F:';[L]FEHABR;']';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=[L]';[F:FEH]ZON
Next
Wrseq 'Return'
Wrseq

Wrseq '$LECFIC'
Filter [FEH]
For [FEH]FEH0 Where ZON>"" & DAC<3
 Wrseq '[L]';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=[F:';[L]FEHABR;']';[F:FEH]ZON
Next
Wrseq 'Return'
Wrseq

Wrseq '$LECMASQ'
For [LNK]FEH0(2)
 Wrseq '[L]';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=[M:';[F:AMZ]CODMSK;']';
 Wrseq [F:FEH]ZON
Next
Wrseq 'Return'
Wrseq

Wrseq '$EMISSION'
Filter [FEH] Where num$(len(FRM))>"0" & DAC<3 & (ZON="" | DAC=2)
Look [FEH] First
Filter [FEH]
If fstat
 Wrseq 'Goto LECFIC'
Else
 For [FEH]FEH0 Where num$(len(FRM))>"0" & DAC<3
  If [F:FEH]ZON="" | [F:FEH]DAC=2
   Wrseq 'Gosub D_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
  Else
   Wrseq '[L]';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=[F:';[L]FEHABR;']';
   Wrseq [F:FEH]ZON
  Endif
 Next
 Wrseq 'Return'
Endif
Wrseq

Wrseq '$RECEPTION'
For [FEH]FEH0 Where DAC=3
 Wrseq '[F:';[L]FEHABR;']';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=[L]';[F:FEH]ZON
Next
Wrseq 'Return'
Wrseq

Wrseq '$VALIDATION'
For [FEH]FEH0 Where DAC=3 & num$(len(CTL))>"0"
 Wrseq 'Gosub V_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
Next
Wrseq 'Return'
Wrseq

Filter [LNK] Where DAC<3

Wrseq '$CONTROLE'
For [LNK]FEH0(2)
 If evalue([L]CONTROLE)
  If [F:FEH]DAC=2 : Wrseq 'If [L]EMISSION' : I=1 : Else I=0 : Endif
  Wrseq space$(I);'Gosub C_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
  Wrseq space$(I);'[V]GZONE="';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON);'"'
  Wrseq space$(I);'[V]GZNUM=';[F:AMZ]INTIT
  Wrseq space$(I);'Gosub AFF From GENFEH'
  If I : Wrseq 'Endif' : Endif
 Endif
Next
Wrseq 'Return'
Wrseq

Wrseq '$STYLE'
Wrseq 'Case [V]GZONE'
For [LNK]FEH0(2) Where DAC=1
 If evalue([L]CONTROLE)
  Wrseq ' When "';
  Wrseq format$( "K:"+num$(type([F:FEH]LIB)-9)+"X"
&              , [F:FEH]LIB+string$([F:FEH]LIB="",[F:FEH]ZON)+'"'
&              );
  Wrseq ' : Chgstl [';[F:AMZ]CODMSK;'] ';
  Wrseq format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);' With string$([V]GERR,[L]FEHSTL)'
 Endif
Next
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

Wrseq '$CONTZON'
Wrseq 'Case [L]COUZON'
For [LNK]FEH0(2)
 If evalue([L]CONTROLE)
  Wrseq 'When "';[F:FEH]ZON;'"'
  Wrseq ' [L]';format$("K:"+num$([V]GLONAVA)+"X",[F:FEH]ZON);'=';
  Case [F:ATY]TYPTYP
   When 2,3,4,5,6 : Wrseq 'val([L]CZ)  '
   When 7         : Wrseq '[L]CZ       '
   When 8         : Wrseq 'gdat$([L]CZ)'
  Endcase
  Wrseq ' [V]GZONE';space$([V]GLONAVA-5);'="';[F:FEH]LIB;
  Wrseq string$([F:FEH]LIB="",[F:FEH]ZON);'"'
  Wrseq ' Gosub C_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
 Endif
Next
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

For [FEH]FEH0 Where num$(len(FRM))>"0"
 Wrseq '$D_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
 Wrseq ctrans([F:FEH]FRM,chr$(13),"")
 Wrseq 'Return'
 Wrseq
Next

For [LNK]FEH0(2)
 If evalue([L]CONTROLE)
  Wrseq '$C_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)

  If [F:FEH]OBL<2
   K=2
  Else
   K=0
   Gosub TEST_NUL
   Wrseq ' : [V]GERR=1 : [V]GMESSAGE=mess(10,123,1) : Return : Endif'
   #                                 Zone obligatoire
  Endif

  If ![L]OK
   Case [F:FEH]TYP
   When 2 : # Alphabétique
    If K=2
     Gosub TEST_NUL
    Endif
    Wrseq space$(K);'If ctrans([L]';[F:FEH]ZON;',"0123456789","")<>[L]';[F:FEH]ZON;
    Wrseq ' : [V]GERR=1 : [V]GMESSAGE=mess(149,100,1) : Return : Endif'
    #                                 Format incorrect
   When 3 : # Numérique
    If [F:ATY]TYPTYP=7
     If K=2
      Gosub TEST_NUL
     Endif
     Wrseq space$(K);'If ctrans([L]';[F:FEH]ZON;',"0123456789.,","")<>"" : [V]GERR=1';
     Wrseq ' : [V]GMESSAGE=mess(149,100,1) : Return : Endif' : # Format incorrect
    Endif
   Endcase
  Endif

  If [F:FEH]FMT>""
   If K=2
    Gosub TEST_NUL
   Endif
   Wrseq space$(K);'[V]GMESSAGE=func GENFEH.DISTINCTC(ctrans([L]';[F:FEH]ZON;',"';
   I=instr(1,[F:FEH]FMT,'..')
   While I
    For J=ascii(mid$([F:FEH]FMT,I-1,1)) To ascii(mid$([F:FEH]FMT,I+2,1))
     Wrseq chr$(J);
    Next
    I=instr(I+4,[F:FEH]FMT,'..')
   Wend
   I=1
   Repeat
    If mid$([F:FEH]FMT,I+1,2)='..' :                                I+=4
    Elsif mid$([F:FEH]FMT,I,1)='"' : Wrseq '"';"+'";'"';"'+";'"'; : I+=1
    Else                             Wrseq mid$([F:FEH]FMT,I,1);  : I+=1
    Endif
   Until I>len([F:FEH]FMT)
   Wrseq '",""))'
   Wrseq space$(K);'If [V]GMESSAGE<>"" : [V]GERR=1 : [V]GMESSAGE=mess(6,10721,1)';
   #                                                   Caractères interdits
   Wrseq '-"<< "+[V]GMESSAGE+" >>" : Return : Endif'
  Endif

  If [L]OK
   If K=2
    Gosub TEST_NUL
   Endif
   If [F:FEH]LIB="C_QUALIF" & [F:FEH]FEH="DUE"
    Wrseq space$(K);'Read [FEL]FEL0=';[F:FEH]LOC;';[L]JOBCOD+[L]FRTCOD;"';[L]FEH;'"'
   Else
    Wrseq space$(K);'Look [FEL]FEL0=';[F:FEH]LOC;';[L]';[F:FEH]ZON;';"';[L]FEH;'"'
   Endif
   Wrseq space$(K);'If fstat : [V]GERR=1 : [V]GMESSAGE=[L]';[F:FEH]ZON;
   Wrseq '-":"-mess(7,10721,1)';
   #           Code inexistant
   Wrseq ' : Return : Endif'
  Endif

  If K=1 : Wrseq 'Endif' : Endif
  If len([F:FEH]CTL) : Wrseq ctrans([F:FEH]CTL,chr$(13),"") : Endif

  Wrseq 'Return'
  Wrseq
 Endif
Next

Filter [LNK]

For [FEH]FEH0 Where DAC=3 & num$(len(CTL))>"0"
 Wrseq '$V_';[F:FEH]LIB;string$([F:FEH]LIB="",[F:FEH]ZON)
 Wrseq ctrans([F:FEH]CTL,chr$(13),"")
 Wrseq 'Return'
 Wrseq
Next

Openo

adxirs=[L]SAVIRS
adxifs=[L]SAVIFS

Call VALID([L]FEHTRT,[L]DOSSIER,[L]OK) From GENBILSOC

End

#-------------------------------------------------------------------------------
Funprog LISTE(OK)
Variable Integer OK

Filter [FEL] Where LOC=[F:FEH]LOC
Look [FEL] First
Filter [FEL]
[L]OK=!fstat

End [L]OK

#-------------------------------------------------------------------------------
$TEST_NUL
Wrseq 'If [L]';[F:FEH]ZON;
If K=0 : Wrseq '='; : Else Wrseq '<>'; : Endif
Case [F:ATY]TYPTYP
 When 2,3,4,5,6 : Wrseq '0';
 When 7         : Wrseq '""';
 When 8         : Wrseq '[0/0/0]';
Endcase
If K : Wrseq : K=1 : Endif
Return

#-------------------------------------------------------------------------------
# Supprime les occurences multiples des caractères d'une chaîne
#
Funprog DISTINCTC(CHAINE)
Value Char CHAINE()

If len([L]CHAINE)<=1  : End [L]CHAINE : Endif

Local Libelle I

I=1
While I<len([L]CHAINE)
 [L]CHAINE =left$([L]CHAINE,I)+ctrans(right$([L]CHAINE,I+1),mid$([L]CHAINE,I,1),"")
 I        +=1
Wend

End [L]CHAINE

#-------------------------------------------------------------------------------
# Appelé par $CONTROLE des traitements générés
#
$AFF
If [V]GERR
 If [V]GTRACE>""
  If [V]GZNUM
   If !clalev([F:ATX]) : Local File ATEXTE [ATX] : Endif
   Read [ATX]NUMERO=[V]GLANGUE;[V]GZNUM
  Else
   fstat=5
  Endif
  If !fstat
   Call ECR_TRACE([V]GZONE-"("+[F:ATX]TEXTE+") :"-[V]GMESSAGE,[V]GERR) From GESECRAN
  Else
   Call ECR_TRACE([V]GZONE-":"-[V]GMESSAGE,[V]GERR) From GESECRAN
  Endif
 Endif
 If dim([L]NBERR)=1 : [L]NBERR+=1 : Endif
Endif
If dim([L]FEHSTL)=1 & [L]FEHSTL>"" : Gosub STYLE From =[L]FEHTRT : Endif
Raz [V]GERR, [V]GMESSAGE, [V]GZONE
Return

#-------------------------------------------------------------------------------
# En ACTION="APRES_MODIF" colorie les zones en erreur
#
Subprog CONTZON(FEH,FEHSTL,COUZON,CZ,OK)
Value Char FEH(), FEHSTL(), CONTZON(), CZ()
Variable Integer OK

Gosub GENVAR
Gosub DEFVAR
Gosub DEFVAR From =[L]FEHTRT
Gosub LECMASQ From =[L]FEHTRT

Onerrgo ERREURZON
Gosub CONTZON From =[L]FEHTRT
Onerrgo

Gosub STYLE From =[L]FEHTRT
If [V]GERR
 Call MESSAGE([V]GMESSAGE) From GESECRAN
Endif
Raz [V]GERR, [V]GMESSAGE, [V]GZONE

End

#-------------------------------------------------------------------------------
$ERREURZON
[V]GMESSAGE=errp-num$(errl)-errmes$(errn)-errm
[V]GERR    =1
Resume

#-------------------------------------------------------------------------------
# Colorie toutes les zones en erreur
#
Subprog SETSTYLE(FEH,FEHSTL)
Value Char FEH(), FEHSTL()

If [L]FEHSTL="" : End : Endif

Gosub GENVAR
Gosub DEFVAR

Gosub DEFVAR From =[L]FEHTRT
Gosub LECMASQ From =[L]FEHTRT
Gosub CONTROLE From =[L]FEHTRT

End

#-------------------------------------------------------------------------------
# Change les intitulés des zones
#
Subprog CHGTZON(FEH,LIBFLG)
Value    Char    FEH
Variable Libelle LIBFLG

Local Libelle I
Local Char    INTIT(type([F:ATX]TEXTE)-10)(rowcount([FEH]))

Gosub GENVAR From GENFEH

[L]LIBFLG=mod([L]LIBFLG+1,4)
Filter [FEH] Where FEH=[L]FEH & LIB>""
Look [FEH] First
If fstat : [L]LIBFLG+=([L]LIBFLG=1) : Endif
Filter [FEH]

Link [FEH] With [AMZ]DICO(1)~=ZON
&             , [ATX]NUMERO  =[V]GLANGUE;[AMZ]INTIT
&            As [LNK]
&  Order By Key CLE=[AMZ]CODMSK;[AMZ]NUMBLOC;[AMZ]NOZONE;[AMZ]CODZON

For [LNK]CLE Where FEH=[L]FEH & [AMZ]CODMSK>=[L]FEHABR+"0" & [AMZ]CODMSK<=[L]FEHABR+"9"
 Case [L]LIBFLG
  When 0 : [L]INTIT(I)=[F:ATX]TEXTE
  When 1 : [L]INTIT(I)=[F:FEH]LIB
  When 2 : [L]INTIT(I)=[F:FEH]ZON
  When 3 : [L]INTIT(I)=num$([F:FEH]LOC)
 Endcase
 I+=1
Next

Gosub CHGTZON From =[L]FEHTRT

End

#-------------------------------------------------------------------------------
Subprog GENATB(DOSSIER,FEH)
Value Char DOSSIER()
Value Char FEH()

Gosub GENVAR

Local Char    SYMBOLE(50)
Local Libelle I

[L]SYMBOLE="ATB"+[L]FEHATB
Lock =[L]SYMBOLE
If fstat
 Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
 Call ECR_TRACE([V]GMESSAGE,1) From GESECRAN
 Raz [V]GMESSAGE
 End
Endif

Local File =[L]DOSSIER+".ATABZON" [ATZ]
Local File =[L]DOSSIER+".FILEDIH" [FEH] Where FEH=[L]FEH
Local File =[L]DOSSIER+".ATYPE"   [ATY]
Local File =[L]DOSSIER+".AMSKPAR" [AMP]
Local File =[L]DOSSIER+".AMSKZON" [AMZ]

Call DEBTRANS From GLOCK

$TR_TABLE
[V]GOK=1
Trbegin [ATZ]
 Gosub MAJ_TABLE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : End : Else Goto TR_TABLE : Endif
 Elsif ![V]GOK
  Rollback
  End
 Endif
Commit

Call MAJFIC([L]FEHATB,[L]DOSSIER,1) From VALDIC
Unlock =[L]SYMBOLE

End

#-------------------------------------------------------------------------------
$MAJ_TABLE
Update [ATZ] Where CODFIC=[L]FEHATB With NUMLIG+=1000
If fstat=1
 [V]GOK  =1
 [V]GLOCK="$ATABZON"-[L]FEHATB
 Return
Elsif fstat
 [V]GOK=0
 Call RSTA("ATZ",[L]FEHATB) From GLOCK
 Return
Endif

Raz [F:ATZ]
[F:ATZ]CODFIC =[L]FEHATB
[F:ATZ]DIME   =1
[F:ATZ]OBLIG  =1
[F:ATZ]NUMLIG =4
[F:ATZ]ZERO   =1

Link [FEH] With [AMZ]DICO(1)=ZON
&             , [ATY]CODTYP =[AMZ]CODTYP
&             , [AMP]CODAFF =[AMZ]CODMSK;[AMZ]CODZON
&            As [LNK]

For [LNK]FEH0(2) Where find(ZON,"","REFNUM","CTRNUM","AEMNUM")=0
&                    & [AMZ]CODMSK>=[L]FEHABR+"0" & [AMZ]CODMSK<=[L]FEHABR+"9"

 If    [F:AMZ]INTIT  : [F:ATZ]NOABREG=[F:AMZ]INTIT
 Else                  [F:ATZ]NOABREG=603 : # Champ
 Endif
 [F:ATZ]NOCOURT=[F:ATZ]NOABREG
 [F:ATZ]NOLONG =[F:ATZ]NOABREG

 [F:ATZ]NUMLIG +=1
 [F:ATZ]CODZONE =[F:FEH]ZON
 [F:ATZ]CODTYP  =[F:AMZ]CODTYP
 If find([F:ATY]TYPTYP,4,5,6) : [F:ATZ]LONG=[F:AMZ]LONG
 Else                           [F:ATZ]LONG=[F:FEH]LNG
 Endif
 [F:ATZ]OPTION  =[F:AMZ]OPTSAI
 Raz [F:ATZ]ANNUL, [F:ATZ]VERIF, [F:ATZ]LIEN, [F:ATZ]EXPLIEN

 Case [F:ATZ]CODTYP
 When "ADI", "FEL"
  Case [F:ATZ]CODTYP
   When "ADI" : [F:ATZ]LIEN="ATABDIV"
   When "FEL" : [F:ATZ]LIEN="FILEDIL"
  Endcase
  For [LNK]FEH0
   Case [AMP]CODPAR
    When "ADI"
     [F:ATZ]EXPLIEN=ctrans([F:AMP]VALPAR,'"','')+";"+[F:ATZ]CODZONE
    When "FEL"
     [F:ATZ]EXPLIEN =ctrans([F:AMP]VALPAR,'"','')
     I              =instr(1,[F:ATZ]EXPLIEN,"~")
     [F:ATZ]EXPLIEN =left$([F:ATZ]EXPLIEN,I-1)+";"+[F:ATZ]CODZONE+';"'
&                  + right$([F:ATZ]EXPLIEN,I+1)+'"'
   Endcase
  Next
  [F:ATZ]VERIF =2
  [F:ATZ]ANNUL =1 : # Bloquant
  [F:ATZ]CODTYP="A"
 When "D","DTR"
  [F:ATZ]LONG=0
 Endcase

 Look [ATZ]CODZONE =
 If fstat : Write [ATZ] :  Else Rewrite [ATZ] : Endif
 If fstat
  [V]GOK=0
  Call FSTA("ATZ") From GLOCK
  Break
 Endif
Next
If [V]GOK<1 : Return : Endif

# On ne supprime pas les champs qui sont dans l'ancien paramétrage mais plus dans
# le nouveau
nolign=[F:ATZ]NUMLIG
For [F:ATZ]NUMLIG Where CODFIC=[L]FEHATB & NUMLIG>1000
 nolign       +=1
 [F:ATZ]NUMLIG =nolign
 Rewrite [ATZ] Curr
 If fstat
  [V]GOK=0
  Call FSTA("ATZ") From GLOCK
  Break
 Endif
Next
If [V]GOK<1 : Return : Endif
Return

#-------------------------------------------------------------------------------
Subprog CONTAMK(DOSSIER,FEH)
Value Char DOSSIER()
Value Char FEH()

Gosub GENVAR

Local Libelle I

Local File =[L]DOSSIER+".AMSKZON" [AMZ]
Local File =[L]DOSSIER+".FILEDIH" [FEH] Where FEH=[L]FEH
Local File =[L]DOSSIER+".ATYPE"   [ATY]
Local File =[L]DOSSIER+".FILEDIL" [FEL] Where FEH=[L]FEH
Local File =[L]DOSSIER+".AMSKPAR" [AMP]

Link [FEH] With [AMZ]DICO(1)~=ZON
&             , [ATY]CODTYP ~=[AMZ]CODTYP
&            As [LNK]

For [LNK]FEH0 Where [AMZ]CODMSK>=[L]FEHABR+"0" & [AMZ]CODMSK<=[L]FEHABR+"9"
&                 & [ATY]CODTYP<>"D" & [ATY]CODTYP<>"DTR"
 If find([F:ATY]TYPTYP,4,5,6)
  I=max( evalue(ctrans(num$([F:ATY]LNGTYP),".","+"))
&      , evalue(ctrans(num$([F:AMZ]LONG),".","+"))
&      )
 Else
  I=max([F:ATY]LNGTYP,[F:AMZ]LONG)
 Endif
 If [F:AMZ]OPTLNG>0 : I=min(I,[F:AMZ]OPTLNG) : Endif
 If [F:FEH]LNG>I & [F:ATY]FORTYP=""
  #Zone trop petite
  Call ECR_TRACE(mess(21,10721,1)-[F:AMZ]CODMSK-[F:AMZ]CODZON-":"-num$(I)-"->"
&               - num$([F:FEH]LNG),1
&               ) From GESECRAN
 Elsif [F:FEH]LNG<I & [F:ATY]FORTYP=""
  #Zone trop longue
  Call ECR_TRACE(mess(22,10721,1)-[F:AMZ]CODMSK-[F:AMZ]CODZON-":"-num$(I)-"->"
&               - num$([F:FEH]LNG),-1
&               ) From GESECRAN
 Endif
 If [F:FEH]DAC=3 & [F:AMZ]SAIAFF=1
  #Zone non saisissable
  Call ECR_TRACE(mess(23,10721,1)-[F:AMZ]CODMSK-[F:AMZ]CODZON,1) From GESECRAN
 Elsif [F:FEH]DAC<>3 & [F:AMZ]SAIAFF=2
  #76312
  #Zone saisissable
  Call ECR_TRACE(mess(24,10721,1)-[F:AMZ]CODMSK-[F:AMZ]CODZON,-1) From GESECRAN
 Endif
Next

For [FEL]FEL0(1) Where DES>""
 Filter [AMP] Where CODAFF>=[L]FEHABR+"0" & CODAFF<=[L]FEHABR+"9" & CODPAR="NOCOL"
&                 & VALPAR=num$([F:FEL]LOC)
 Read [AMP] First
 If !fstat
  Filter [AMP]
  [F:AMP]CODPAR="ZONE"
  Read [AMP]CODPAR =
  If !fstat & ctrans([F:AMP]VALPAR,'" ','')>""
   Read [AMZ]DICO=ctrans([F:AMP]VALPAR,'" ','');[F:AMP]CODAFF
   If !fstat
    I=0
    For [FEL]FEL0 : I=max(I,len([F:FEL]DES)) : Next
    If I>[F:AMZ]LONG
     Call ECR_TRACE( "Zone trop petite"-[F:AMZ]CODMSK-[F:AMZ]CODZON-":"
&                  - num$([F:AMZ]LONG)-"->"-num$(I),-1
&                  ) From GESECRAN
    Elsif I<[F:AMZ]LONG
     Call ECR_TRACE( "Zone trop longue"-[F:AMZ]CODMSK-[F:AMZ]CODZON-":"
&                  - num$([F:AMZ]LONG)-"->"-num$(I),-1
&                  ) From GESECRAN
    Endif
   Endif
  Endif
 Endif
Next
Filter [AMP]

End

#-------------------------------------------------------------------------------
Funprog ERRANM(STAT)
Value Integer STAT

Local Char MESSA(255)

Gosub MESSAGE From SUBANM

End [L]MESSA

