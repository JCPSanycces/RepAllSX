#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local File AREPORTM   [ARM]
Local File COMPANY    [CPY]
Local File GACCDENCOD [CDA]
Local File PAYMENTH   [PYH]
Local File PAYMENTD   [PYD]
Local File TABSIVTYP  [TSV]
Local File TMPARPT    [TARPT]

Local Char    CRITERE(255)(2), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local Integer NUMREQ, I, J
Local Integer NUMCOPY
Local Integer ACCTYP
Local Char    LINDES(100)

[L]CRITERE(0) = "1=1"
[L]CRITERE(1) = "1=1"

#-----
For I=1 To [L]NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM ([L]PARAM,[L]NBPAR,[L]PARAMETRE,VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"       : [L]ETAT        = [L]VALEUR
      When "__REQUETE"   : [L]NUMREQ      = val([L]VALEUR)
      When "numdeb"      : [L]CRITERE(0) -= "& NUM>='"+[L]VALEUR+"'"
      When "numfin"      : [L]CRITERE(0) -= "& NUM<='"+[L]VALEUR+"'"
      When "numcopy"     : [L]NUMCOPY      = val([L]VALEUR)
      When "numedt"      : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "seqedt"      : [L]PARAMETRE(I) = "seqedt=0"
      When "usr"         : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"        : [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next

Look [ARM]ARM0 = [L]NUMREQ;GUSER;[F:ARP]RPTCOD;1
If !fstat
  # Enreg trouvé, car lancement enchainé
  # On bloque la boucle
  CRITERE="1=2"
  #On laisse GOK=1 sinon l'état ne sort pas
Endif

Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [F:ARP]RPTCOD
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]CREDAT = date$

If [L]NUMCOPY > 4
  [L]NUMCOPY = 4
Endif

Call DEBTRANS From GLOCK
Trbegin [ARM], [TARPT]

For [PYH] PYH0 Where evalue([L]CRITERE(0))
  If [F:CPY]CPY <> [F:PYH]CPY
    Read [F:CPY]CPY0 = [F:PYH]CPY
  Endif
  #Issue X3-92219 – 2018-07-16  by MADOR - 2018.R6 - P-RECIBO report
  For K=1 To max([L]NUMCOPY,1)
    [F:ARM]NUMLIG+= 1
    [F:ARM]CLEA1  = [F:PYH]NUM
    [F:ARM]CLEA2  = mess(K,2280,1)
    [F:ARM]CLEA3  = "PAYMENTH"
    [F:ARM]CLEN1  = 0
    [F:ARM]CLEN2  = 0
    Gosub ALIMETAT_PE From ETAT
    Write [ARM]
    If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
  Next K

  For [F:PYD] Where [F:PYD]NUM = [F:PYH]NUM
    Call GET_LIN_INFO ([F:CPY]LEG,[F:PYD]DENCOD,[F:PYD]VCRTYP,LINDES,ACCTYP)
    [F:ARM]NUMLIG+= 1
    [F:ARM]CLEA1  = [F:PYH]NUM
    [F:ARM]CLEA2  = LINDES
    [F:ARM]CLEA3  = "PAYMENTD"
    [F:ARM]CLEN1  = [F:PYD]LIN
    [F:ARM]CLEN2  = ACCTYP
    Gosub ALIMETAT_PE From ETAT
    Write [ARM]
    If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
  Next
  #Issue X3-92219 end
  If func AFNC.ACTIV('KPO')>0 #& func PORLEGLIB.DIGSIGN('',[F:PYH]CPY)=1
    Gosub ALIM_TMPARPT
    If GOK=0 : Break : Endif
  Endif

Next

If GOK<1  Rollback  Else  Commit : Endif
End
#########################################################################
#########################################################################
$ALIM_TMPARPT

Raz [F:TARPT]

[F:TARPT] = [F:ARM]
[F:TARPT]VCRNUM = [F:PYH]NUM

Write [F:TARPT]
If fstat : GOK=0 : Call FSTA("TARPT") From GLOCK : Endif

Return
#########################################################################
#########################################################################
Subprog GET_LIN_INFO(LEG,DENCOD,VCRTYP,DES,ACCTYP)
Value    Char    LEG
Value    Char    DENCOD
Value    Char    VCRTYP
Variable Char    DES
Variable Integer ACCTYP

Local Shortint CDA_ACCTYP
Local Integer  RET

Raz DES, ACCTYP

If DENCOD <> ""
  Call LEC_CDA_LEG(LEG,DENCOD,RET) From TRTLECLEG
  If RET = 0 : ACCTYP = [F:CDA]ACCTYP : DES = [F:CDA]DES
  Endif
Endif

If VCRTYP <> ""
  Call LEC_TSV_LEG(LEG,VCRTYP,RET) From TRTLECLEG
  If RET = 0
    Case [F:TSV]SAFTINVTYP
      When 1,2,5,7 : DES = "Fatura"
      When 3       : DES = "Nota de débito"
      When 4,6     : DES = "Nota de crédito"
    Endcase
  Endif
Endif

End
#########################################################################
#########################################################################

