#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque CFGVAL1
$ACTION            # Obligatoire pour traiter le cas d'actions avec paramètre: action avant/après zone
Case ACTION
 When default
Endcase
Return


############################################################
Subprog IB_NBLIG1
If clalev([F:ROH]) > 0
  Read [ROH]ROH0=[M]ITMREF(nolign-1);val([M]ROUALTALP);[M:CFV0]FCY
  If fstat
    GBOUT8 = ""
  Endif
Else
  GBOUT8 = ""
Endif
GBOUT12 = ""
End
############################################################
Subprog IB_NBLIG2
If clalev([F:ROH]) > 0
  Read [ROH]ROH0=[M]CPNITMREF(nolign-1);val([M]ROUALTALP);[M:CFV0]FCY
  If fstat
    GBOUT9 = ""
  Endif
Else
  GBOUT9 = ""
Endif
End

