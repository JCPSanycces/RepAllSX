#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-77876 - 2018-03-27 by JUSYN : Create non-conformance by document
# Issue X3-88688 - 2018-04-27 by BAKHA : Set status to New for created Non-conformance
# Issue X3-83483 - 2018-05-01 by BAKHA : Set initial values for Reason, Root cause and Probable cause
# Issue X3-94378 - 2018-06-08 by ALSHE : Resructure data base
# Issue X3-94378 - 2018-06-29 by JUSYN : Replace abbreviation NCSDOC by NCSDHD
# Issue X3-94378 - 2018-06-29 by JUSYN : Replace abbreviation NCSDOC by NCSDHD
# Issue X3-83486 - 2018-08-15 by BAKHA : If customer/suppler, copy to first line of Customers/Suppliers collection
# Issue X3-104585 - 2018-09-03 by BAKHA : Add stock unit to documents

$ACTION
Case ACTION
    When "OUVRE":         Case GACTION
                              When "NCSCREDOC"  : Gosub OUVRE_CREDOC
                              When "NCSLISTDOC" : Gosub OUVRE_LISTDOC
                          Endcase
    When "DEBUT":         Case GACTION
                              When "NCSCREDOC"  : Gosub DEBUT_CREDOC
                              When "NCSLISTDOC" : Gosub DEBUT_LISTDOC
                          Endcase
    When "BOUTON":        Case GACTION
                              When "NCSCREDOC" : Gosub BOUTON_CREDOC
                          Endcase
Endcase
Return

$OUVRE_CREDOC
Local    Char       WSITE(GLONFCY)
Local    Integer    WDOCTYP
Local    Char       WVCRNUM(GLONVCR)
Local    Char       WNCSBPC(GLONBPC)
Local    Char       WNCSBPS(GLONBPS)
Local    Date       WDOCDAT
Local    Char       WPJT(40)
Local    Integer    WVCRLIN
Local    Char       WITMREF(GLONITM)
Local    Char       WECCVALMAJ(GLONECS)
Local    Char       WECCVALMIN(GLONEVL)
Local    Decimal    WDOCQTY
Local    Char       MODE(32)
Local    Char       WSTU(GLONUOM)          # Issue X3-104585 - stock unit

# receiving parameters
WSITE   = PARAM(1)
WDOCTYP = val(PARAM(2))
WVCRNUM = PARAM(3)
WNCSBPC = PARAM(4)
WNCSBPS = PARAM(5)
WDOCDAT = PARAM(6)
WPJT    = PARAM(7)
WVCRLIN = val(PARAM(8))
WITMREF = PARAM(9)
WECCVALMAJ = PARAM(10)
WECCVALMIN = PARAM(11)
WDOCQTY    = val(PARAM(12))
WSTU = PARAM(13)                # Issue X3-104585 - stock unit

# Issue X3-92174 - 2018-07-09 by JUSYN : fullmode creation NC
 # Issue X3-84473 - check document mode
Call PARAMUTIL("NCSDOCCRE", MODE, GUSER, "") From SUBAUS
If (MODE = "2")
    GBCRMFLGNEW = 1
    Case WDOCTYP
        When 1  :   Default Mask [PTH0]
        When 2  :   Default Mask [SRH0]
        When 3  :   Default Mask [MTK0]
    Endcase
    [M]NCSPJT    = WPJT
    [M]NCSVCRLIN = WVCRLIN
    [M]NCSITMREF = WITMREF
    [M]NCSECCMAJ = WECCVALMAJ
    [M]NCSECCMIN = WECCVALMIN
    [M]NCSQTY    = WDOCQTY
    [M]NCSSTU    = WSTU         # Issue X3-104585 - stock unit

    SAVACT = GACTION : GACTION = "GOBJETC4"
    Call OBJET_CHAR(GBIDC3,"NCSH","") From GOBJET
    GACTION = SAVACT
    # End issue X3-92174
    FIN=1
Endif

Return

$OUVRE_LISTDOC
Local    Char       WSITE(GLONFCY)
Local    Integer    WDOCTYP
Local    Char       WVCRNUM(GLONVCR)

# receiving parameters
WSITE   = PARAM(1)
WDOCTYP = val(PARAM(2))
WVCRNUM = PARAM(3)

Return

$DEBUT_CREDOC

    Raz [M:NCSD0]
    If (WVCRLIN > 0)
      [M:NCSD0]TITLE = mess (WDOCTYP,3718,1) - WVCRNUM - num$(WVCRLIN)
    Else
      [M:NCSD0]TITLE = mess (WDOCTYP,3718,1) - WVCRNUM
    Endif

Return


$DEBUT_LISTDOC
  Raz [M:NCSD1]
  [M:NCSD1]LSITE    = WSITE
  [M:NCSD1]LDOCTYP  = WDOCTYP
  [M:NCSD1]LVCRNUM  = WVCRNUM

  If [M:NCSD1]LVCRNUM <> ""
      Call DISPLAY_DOC_DETAILS()
  Endif

Return


$BOUTON_CREDOC

Case BOUT
    When "1"       :     # Create NCS record
                         Gosub CREATE_NCS
Endcase

Return

$CREATE_NCS
  Local Integer INDEX
  Local Integer MY_STATUS
  Global Instance WNCSRECENT Using C_NCSRECENT
  Local Char MESSAGE(100)

  If WNCSRECENT <> null : FreeGroup WNCSRECENT :Endif
  #--- Class instanciation
  WNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  [L]MY_STATUS = fmet WNCSRECENT.AINIT()
  If [L]MY_STATUS >= [V]CST_AERROR
    GOK=0 : GERR=1: Return
  Endif

  SetInstance WNCSRECENT With [M:NCSD0]

  # set defaults

  Call INIADI(WNCSRECENT.NCSREASON,"802") From TRTDIV
  Call INIADI(WNCSRECENT.NCSROOCAU,"803") From TRTDIV
  Call INIADI(WNCSRECENT.NCSPROCAU,"804") From TRTDIV

  # set default Category depending on doctyp
  Case WDOCTYP
      When 1
          WNCSRECENT.NCSCATEGORY = 3 # Default: supplier category
      When 2
          WNCSRECENT.NCSCATEGORY = 2 # Default: Customer category
      When Default
          WNCSRECENT.NCSCATEGORY = 4 # Default: Internal
  Endcase

  WNCSRECENT.SITE    = WSITE
  WNCSRECENT.PRODUCT = WITMREF
  WNCSRECENT.ECCVALMAJ = WECCVALMAJ
  WNCSRECENT.ECCVALMIN = WECCVALMIN
  WNCSRECENT.NCSBPC  = WNCSBPC
  WNCSRECENT.NCSBPS  = WNCSBPS

  # Get default QA manager
  Call PARAM(WNCSRECENT.SITE, "NCSQADEF", WNCSRECENT.NCSMANAGER) From ADOVAL
  # Get default Planner
  Call PARAM(WNCSRECENT.SITE, "NCSPLADEF", WNCSRECENT.NCSPLANNER) From ADOVAL

  #--- AINSERT method
  [L]MY_STATUS = fmet WNCSRECENT.AINSERT()
  If [L]MY_STATUS >= [V]CST_AERROR
      Call GET_ERRORS(WNCSRECENT)
      If GMESSAGE = AVOID.ACHAR Then
          GMESSAGE = mess(25,3702,1)  # Unknown error occurred while creating a Non-conformance.
      Endif
      If GOK=0 : Return : Endif
  Endif

  # Issue X3-83486 - if customer then add to customer collection
  If (WNCSBPC <> "")
    INDEX = fmet WNCSRECENT.ADDLINE("NCSBPCCOL", [V]CST_ALASTPOS)
    If INDEX = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GERR = 4
        GOK = 1
        Return
    Endif
    WNCSRECENT.NCSBPCCOL(INDEX).NCSID   = WNCSRECENT.NCSID
    WNCSRECENT.NCSBPCCOL(INDEX).BPCNUM  = WNCSBPC
    # get default contact
    Call GET_DEFAULT_CUSTOMER_CONTACT(WNCSBPC, WNCSRECENT.NCSBPCCOL(INDEX).CUSTCONTACT) From SUBNCSHA

  Elsif (WNCSBPS <> "") # if Supplier then add to Supplier collection
    INDEX = fmet WNCSRECENT.ADDLINE("NCSBPSCOL", [V]CST_ALASTPOS)
    If INDEX = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GERR = 4
        GOK = 1
        Return
    Endif
    WNCSRECENT.NCSBPSCOL(INDEX).NCSID   = WNCSRECENT.NCSID
    WNCSRECENT.NCSBPSCOL(INDEX).BPSNUM  = WNCSBPS
    # get default contact
    Call GET_DEFAULT_SUPPLIER_CONTACT(WNCSBPS, WNCSRECENT.NCSBPSCOL(INDEX).SUPPCONTACT) From SUBNCSHA

  Endif
  # Issue X3-83486 -end

  # document line
  # Issue X3-94378 - 2018-06-08 by ALSHE : replace CCMNCSDOC by NCSDOCHDR
  INDEX = fmet WNCSRECENT.ADDLINE("NCSDOCHDR", [V]CST_ALASTPOS)
  If INDEX = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
      GERR = 4
      GOK = 1
      Return
  Endif

  # fill document line

  WNCSRECENT.NCSDOCHDR(INDEX).NCSID   = WNCSRECENT.NCSID
  WNCSRECENT.NCSDOCHDR(INDEX).DOCTYP  = WDOCTYP
  WNCSRECENT.NCSDOCHDR(INDEX).VCRNUM  = WVCRNUM
  WNCSRECENT.NCSDOCHDR(INDEX).VCRLIN  = WVCRLIN
  WNCSRECENT.NCSDOCHDR(INDEX).DOCDAT  = WDOCDAT
  WNCSRECENT.NCSDOCHDR(INDEX).DOCQTY  = WDOCQTY
  WNCSRECENT.NCSDOCHDR(INDEX).NCSQTY  = WDOCQTY
  WNCSRECENT.NCSDOCHDR(INDEX).STU     = WSTU        # Issue X3-104585
  WNCSRECENT.NCSDOCHDR(INDEX).BPSNUM  = WNCSBPS
  WNCSRECENT.NCSDOCHDR(INDEX).BPCNUM  = WNCSBPC
  WNCSRECENT.NCSDOCHDR(INDEX).PJT     = WPJT
  WNCSRECENT.NCSDOCHDR(INDEX).LINSTA  = 1
  # Issue X3-100238 - 2018-08-14 by JUSYN : Existing NCS record without product allows to link header and detail lines.
  #                                         If detail lines linked product information saved in document line. So here as well to be consistent.
  WNCSRECENT.NCSDOCHDR(INDEX).ITMREF    = WITMREF
  WNCSRECENT.NCSDOCHDR(INDEX).ECCVALMAJ = WECCVALMAJ
  WNCSRECENT.NCSDOCHDR(INDEX).ECCVALMIN = WECCVALMIN
  # End issue X3-100238

  # if NC for document line
  If (WVCRLIN > 0 and WDOCQTY > 0)
    MY_STATUS = fmet WNCSRECENT.CREATE_DOCUMENT_LINES (INDEX, MESSAGE)
    If (MY_STATUS = CST_AFALSE)
      GMESSAGE = MESSAGE
      If GOK=0 : Return : Endif
    Endif
  Endif

  MY_STATUS = fmet WNCSRECENT.AUPDATE()

  #--- AUPDATE method
  If [L]MY_STATUS >= [V]CST_AERROR
      Call GET_ERRORS(WNCSRECENT)
      If GMESSAGE = AVOID.ACHAR Then
          GMESSAGE = mess(26,3702,1)  # Unknown error occurred while updating a Non-conformance.
      Endif
      If GOK=0 : Return : Endif
  Endif

  GERR = 2
  GMESSAGE = func AFNC.MES1(mess(36,3702,1), WNCSRECENT.NCSID)

  FIN=1
Return

Subprog GET_ERRORS(WNCSRECENT)
Variable Instance WNCSRECENT Using C_NCSRECENT

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE

  # ----------------------------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(WNCSRECENT, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GERR = 2
    GMESSAGE = SMESSAGE
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GERR = 1
    GMESSAGE = SMESSAGE
    GOK = 0
  Endif

  # ----------------------------------------------------------
  # To help debug process : write a classic log file with all errors in class.
  Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG_" + GUSER) From LECFIC
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(WNCSRECENT) From SYRSTACKTOOLS
  Call FERME_TRACE From LECFIC
  # ----------------------------------------------------------
# Issue X3-94378 - 2018-06-08 by ALSHE : replace CCM* by NCS*
  For NI = 1 To maxtab(WNCSRECENT.NCSDOCHDR)
    MY_STATUS = fmet WNCSRECENT.NCSDOCHDR(NI).ADELETERRORALL()
  Next NI

  MY_STATUS = fmet WNCSRECENT.ADELETERRORALL()
  # Hybrid part (end)
End

# Displays non-conformance records created
# Attention: Subprog is used in actions NCSCREDOC and NCSLISTDOC
#            Ensure used fields are available on NCSD1
Subprog DISPLAY_DOC_DETAILS()
Local Integer J

# Issue X3-94378 - 2018-06-08 by ALSHE : replace CCM* by NCS*
If clalev ([F:NCSDHD]) <= 0 : Local File NCSDOCHDR [NCSDHD] : Endif
If clalev ([F:NCSRC]) <= 0  : Local File NCSRECENT [NCSRC] : Endif
If clalev ([F:WNCSDHD]) <= 0
    Link [NCSDHD] With [NCSRC]NCSRC0=[F:NCSDHD]NCSID As [WNCSDHD]
&        Where [F:NCSDHD]VCRNUM = [M:NCSD1]LVCRNUM and [F:NCSDHD]LINSTA = 1 and find([F:NCSRC]NCSSTA,1,2,3,4,5) > 0 Order By CREDATTIM Desc
Endif

Raz [M:NCSD1]
nolign = 0

For [WNCSDHD]
    Gosub READ_AND_FILL_NCSDHD
Next

LogicClose File [NCSDHD]
LogicClose File [NCSRC]
LogicClose File [WNCSDHD]

[M:NCSD1]NBLIG = nolign
# after deletion of NC after tunneling from the list and return to list and only one NC was there doctyp and vcrlin were initialised
# to avoid this behavior affzo without these two columns
If nolign > 0
    For J = 0 To nolign-1
        Affzo [M:NCSD1]NCSID(J)
        Affzo [M:NCSD1]TITLE(J)
        Affzo [M:NCSD1]DOCLIN(J)
        Affzo [M:NCSD1]NCSQTY(J)
        Affzo [M:NCSD1]VCRNUM(J)
        Affzo [M:NCSD1]DOCDAT(J)
        Affzo [M:NCSD1]DOCQTY(J)
        Affzo [M:NCSD1]BPSNUM(J)
        Affzo [M:NCSD1]BPCNUM(J)
        Affzo [M:NCSD1]PJT(J)
        Affzo [M:NCSD1]LINSTA(J)
        Affzo [M:NCSD1]DOCTYP(J)
        Affzo [M:NCSD1]VCRLIN(J)
    Next
Else
    Affzo [M:NCSD1]NCSID
    Affzo [M:NCSD1]TITLE
    Affzo [M:NCSD1]DOCLIN
    Affzo [M:NCSD1]NCSQTY
    Affzo [M:NCSD1]VCRNUM
    Affzo [M:NCSD1]DOCDAT
    Affzo [M:NCSD1]DOCQTY
    Affzo [M:NCSD1]BPSNUM
    Affzo [M:NCSD1]BPCNUM
    Affzo [M:NCSD1]PJT
Endif

End

$READ_AND_FILL_NCSDHD
nolign += 1
# Issue X3-94378 - 2018-06-08 by ALSHE : replace CRID by NCSID
[M:NCSD1]CODOBJ(nolign-1)  = "NCSH"
[M:NCSD1]NCSID(nolign-1)   = [F:WNCSDHD]NCSID
[M:NCSD1]TITLE(nolign-1)   = [F:NCSRC]TITLE
[M:NCSD1]DOCLIN(nolign-1)  = [F:WNCSDHD]DOCLIN
[M:NCSD1]DOCTYP(nolign-1)  = [F:WNCSDHD]DOCTYP
[M:NCSD1]NCSQTY(nolign-1)  = [F:WNCSDHD]NCSQTY
[M:NCSD1]VCRNUM(nolign-1)  = [F:WNCSDHD]VCRNUM
[M:NCSD1]DOCDAT(nolign-1)  = [F:WNCSDHD]DOCDAT
[M:NCSD1]DOCQTY(nolign-1)  = [F:WNCSDHD]DOCQTY
[M:NCSD1]BPSNUM(nolign-1)  = [F:WNCSDHD]BPSNUM
[M:NCSD1]BPCNUM(nolign-1)  = [F:WNCSDHD]BPCNUM
[M:NCSD1]PJT(nolign-1)     = [F:WNCSDHD]PJT
[M:NCSD1]LINSTA(nolign-1)  = [F:WNCSDHD]LINSTA
[M:NCSD1]VCRLIN(nolign-1)  = [F:WNCSDHD]VCRLIN

Return

