######################################################################################
Subprog AS_SAU(VALEUR)
Variable Char    VALEUR()

#LSE 05/12/2006 FQ38520
#Local Integer NOL : NOL=nolign-1
#If [F:ITM]ITMREF <> [M:SOI1]ITMREF(NOL)
If [F:ITM]ITMREF <> [M:SOI1]ITMREF
    Read [ITM]ITM0=[M:SOI1]ITMREF
    If fstat Raz [F:ITM] Endif
Endif
If [F:ITM]HDKITMTYP=5
    mkstat=2
Endif

End


######################################################################################
######################################################################################
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SOI1) 21/12/2010 15:50:50 (CPO)
######################################################################################
#CPO 63410 - pb découvert lors de la correction de cette fiche
# -- Suite à la modification de l'UV il faut revoir la compatibilité de l'emballage/capacité emb.
Subprog AM_SAU(VALEUR)
Variable Char    VALEUR()

# -- Raz de l'emballage, si l'unité de commande n'est plus l'UV article ou article-client
If [F:ITU]ITMREF <> [M]ITMREF | [F:ITU]BPCNUM <> [M]BPCORD
   Read [ITU] ITU0=[M]ITMREF;[M]BPCORD
   If fstat Raz [F:ITU] Endif
Endif

# Issue X3-66385
#If VALEUR <> [F:ITU]SAU
#    If [F:ITM]ITMREF <> [M]ITMREF
#       Read [ITM]ITM0=[M]ITMREF
#       If fstat Raz [F:ITM] Endif
#    Endif
#    If VALEUR <> [F:ITM]SAU
#        Raz [M]XPCK
#    Else
#       # -- L'unité de commande est l'UV article    : On réinitialise l'emballage
#       Call ALIPCK ([M]ITMREF, [M]STOFCY, [M]XPCK, GBIDD1) From TRTVENDIV
#    Endif
#Else
#    # -- L'unité de commande est l'UV article-client : On réinitialise l'emballage
#    [M]XPCK  = [F:ITU]PCK
#Endif
If [F:ITM]ITMREF <> [M]ITMREF
   Read [ITM]ITM0=[M]ITMREF
   If fstat Raz [F:ITM] Endif
Endif
Raz [M]XPCK
# L'emballage est initialisé en priorité avec l'article client
# Il est initialisé avec l'article (article site ou catégorie article) uniquement si l'UV de l'article = l'UV de la ligne
# et si l'UV de l'article client = l'UV de la ligne mais il n'y a pas d'emballage pour l'article client
# ou si l'UV de l'article client est différente de l'UV de la ligne
# Package is initialized in priority with product customer
# It is initialized  with product (product site or product category) onky if UV product= UV line
# and if UV product customer = UV line but there is no package for product customer
# or  if UV product customer <> UV line
If VALEUR = [F:ITU]SAU
#   L'unité de commande est l'UV article-client : On réinitialise l'emballage
    [M]XPCK = [F:ITU]PCK
Endif
If [M]XPCK = ""
    If VALEUR = [F:ITM]SAU
      Call ALIPCK ([M]ITMREF, [M]STOFCY, [M]XPCK, GBIDD1) From TRTVENDIV
    Endif
Endif
# End issue X3-66385

End
######################################################################################

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

# 106867.sn
If func AFNC.ACTIV("LTA") & GSOCIETE<>[F:CPY]CPY
  Gosub GET_CPY_SSTTAXACT From TRTTAXSST
Endif
# 106867.en

# If GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Grizo [M:SOI1]VACITM1,VACITM2,VACITM3
  If dim([M:SOI1]SSTCOD)>0 :
    Chgfmt [M:SOI1]SSTCOD     With "K:"   + num$(type([M:SOI1]SSTCOD)-10)     + "B"     # Show enterable
    Actzo [M:SOI1]SSTCOD
  Endif
Else
  # TTD-116411: Tax level fields should stay lock when it is Intersite
  If [M:SOR1]BETFCY <> [V]CST_AYES
    Actzo [M:SOI1]VACITM1,VACITM2,VACITM3
  Endif
  If dim([M:SOI1]SSTCOD)>0
    Chgfmt [M:SOI1]SSTCOD     With "-K:"  + num$(type([M:SOI1]SSTCOD)-10)     + "B"     # Hide
  Endif
Endif

End

