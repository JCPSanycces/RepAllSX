######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

  # FGR 10/04/2015 : X3SUIVI105605
  Call CTLECCVAL(VALEUR, [M:SOI1]STOFCY, [M:SOI1]ITMREF, 4, "", [M:SOI1]ORDDAT, LRET) From STKSOR
  If LRET > 1 Then
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

  # FGR 10/04/2015 : X3SUIVI105605
  Raz WECCVALMAJ
  Raz WECCVALMIN
  Raz PITM
  # si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:SOI1]ITMREF Then
    Read [ITM]ITM0=[M:SOI1]ITMREF
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:SOI1]ECCVALMIN = WECCVALMIN
    Affzo [M:SOI1]ECCVALMIN
  Elsif VALEUR = "" and [M:SOI1]ECCVALMIN <> "" Then
    Raz [M:SOI1]ECCVALMIN
    Affzo [M:SOI1]ECCVALMIN
  Endif
End

