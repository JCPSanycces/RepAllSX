######################################################################################
## Etiquette ajoutée par le superviseur (écran SOI1) 17/06/2005 08:43:16 (LD)
######################################################################################
Subprog AM_VACBPR(VALEUR)
Variable Char    VALEUR()
Local Char    WVACITM(GLONTVI)(3)
Local Char    WVAT(GLONVAT)(3)                      : # Bug 75162
Local Char    WANCVACBPR(GLONTVB) : WANCVACBPR=[M]VACBPR     : # Bug 75162

# On vérifie que le régime de taxe du contrat est le même que le régime de taxe du client livré
If [M:SOR1]VACBPR<>VALEUR
    Local Integer WOK : WOK=1
    GMESSAGE=mess(620,197,1)-mess(621,197,1)-mess(622,197,1)-mess(92,198,1)-"("-[M:SOR1]VACBPR-")"
    Call AVERTIR (GMESSAGE, WOK) From GESECRAN : If WOK=1 Raz GMESSAGE : mkstat=2 : End Endif
Endif

# Modification du régime de taxe : Réalimentation des codes taxes
If clalev ([F:ITS])=0 Local File ITMSALES  [ITS] Endif
If clalev ([F:ITM])=0 Local File ITMMASTER [ITM] Endif

If [F:ITS]ITMREF<>[M:SOI1]ITMREF
    Read [F:ITS]ITS0=[M:SOI1]ITMREF : If fstat Raz [F:ITS] Endif
Endif
If [F:ITM]ITMREF<>[M:SOI1]ITMREF
    Read [F:ITM]ITM0=[M:SOI1]ITMREF : If fstat Raz [F:ITM] Endif
Endif
#WVACITM(0) = [M:SOI1]VACITM1
#WVACITM(1) = [M:SOI1]VACITM2
#WVACITM(2) = [M:SOI1]VACITM3
#Call ALITAXEV(VALEUR,WVACITM,[M:SOI1]VAT) From TRTX3
[M:SOI1]VACBPR=VALEUR
Call RECHVATCOD(1,1,[M]BPCORD,[M]ITMREF,"SOI1",0,WVAT) From TRTX3
# Bug 75162 : Contrôle que le code taxe1 est bien renseigné
Call CTLVAT(WVAT(0)) From TRTVENCTL
If mkstat=2
    [M:SOI1]VACBPR=WANCVACBPR
    GMESSAGE = [M:SOI1]ITMREF-" : "-GMESSAGE : End
Endif
[M:SOI1]VAT(0) = WVAT(0)
[M:SOI1]VAT(1) = WVAT(1)
[M:SOI1]VAT(2) = WVAT(2)
# Bug 75162

If [M:SOI1]NBLIG=0 End Endif
# Recalcul de la marge sur ttes les lignes
nolign=1
While nolign <= [M:SOI1]NBLIG
    Gosub MARGE
    [M:SOI1]UPDFLG(nolign-1)=1
    nolign+=1
Wend

End
# --------------------------------------- VACITM1 --------------------------------
Subprog C_VACITM1(VALEUR)
Variable Char    VALEUR()
If [M]VACITM1=VALEUR
    Call CTLVAT([M]VAT(0)) From TRTVENCTL
Else
    Raz [M:SOI1]VAT(0)        : # Bug 78972
    Call ALIVAT(VALEUR,11,1,[M:SOI1]BPCORD,[M:SOI1]ITMREF,"SOI1",-1,[M:SOI1]VAT(0)) From TRTX3
Endif
End
######################################## Obligatoire
Subprog AS_NBLIG

If [M]PLI <> ""
#   Call ERREUR(mess(127,192,1)) From GESECRAN
   mkstat = 2
Endif
If date$ > [M:SOR1]VLYDATCON
   GERR=1 : GMESSAGE=mess(10,192,1)
   mkstat = 2
Endif
End

######################################## Obligatoire
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1
Local Integer  I

# Si l'on est en création d'une nouvelle ligne
If [M]CREFLG(NOL) = 0
#  Alimentation du représentant 1
   If dim([M]XREP1) > 0 [M]REP1(NOL) = [M]XREP1
      If [M]XREP1 <> ""
         Read [BPC]BPC0=[M]BPCORD
         Read [REP]REP0 = [M]XREP1
         If fstat = 0 & [F:BPC]COMCAT <> 0
            [M]REPRAT1(NOL) = [F:REP]COMRAT1([F:BPC]COMCAT-1)
         Endif
      Endif
   Endif
#  Alimentation du représentant 2
   If dim([M]XREP2) > 0 [M]REP2(NOL) = [M]XREP2
      If [M]XREP2 <> ""
         Read [REP]REP0 = [M]XREP2
         If fstat = 0 & [F:BPC]COMCAT <> 0
            [M]REPRAT2(NOL) = [F:REP]COMRAT2([F:BPC]COMCAT-1)
         Endif
      Endif
   Endif
Endif
# Initialisation de la date de contrôle pour les sections analytiques
Raz [M]DATCTLCCE
If [M]CREFLG(NOL)=0 & [M]UPDFLG(NOL)=0
    # Ligne en cours de création
    If nolign>=1 & nolign<=[M]NBLIG
        [M]DATCTLCCE=[M]STRDAT(nolign)-1   : # Date de début de validité de la ligne suivante
    Elsif nolign>[M]NBLIG
        [M]DATCTLCCE=[M]VLYDATITM          : # Dernière ligne : date de fin de contrat
    Endif
Else
    # Ligne déjà créée
    If nolign>=1 & nolign<[M]NBLIG
        [M]DATCTLCCE=[M]STRDAT(nolign)-1   : # Date de début de validité de la ligne suivante
    Elsif nolign>=[M]NBLIG
        [M]DATCTLCCE=[M]VLYDATITM          : # Dernière ligne : date de fin de contrat
    Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SOI1) 03/06/2010 17:14:56 (LD)
######################################################################################
Subprog C_NBLIG

# Raz signatures si suppression d'une ligne
If status = 65 & [M:SOI1]SOQSEQ=0 GUPDAPPFLG=2 Endif
End
######################################## Obligatoire
Subprog APRES_NBLIG
Local Integer I
Local Decimal MAJREM(0..8)
Local Decimal NET, PHTNET
Local Decimal COUTHT, COUTHTC
Local Integer LOK, NOL

NOL = nolign-1
# Si abandon avant validation de la ligne
Case status
   When 6,7,27,28 : End
Endcase
If status >= 1792   End Endif

# Abandon sans validation de la ligne
#If adxgtb = 1 End Endif


# Raz signatures si ajout d'une ligne
If [M:SOI1]SOQSEQ=0 & GREP="M" & [M]CREFLG(NOL)=0 GUPDAPPFLG=2 Endif

# Si suppression ligne
If status = 65
#  Forcage de la date fin de la ligne précédente à la date début-1 de la
#  ligne suivante si la ligne supprimé n'est ni la première ni la dernière
   If nolign > 1 & nolign < [M]NBLIG
      [M]ENDDAT(nolign-2) = [M]STRDAT(nolign) - 1
      [M]UPDFLG(nolign-2) = 1
   Endif
   End
Endif

# Forcage de la date de fin de la ligne courante
# à la date début - 1 de la ligne suivante
If nolign < [M]NBLIG
   [M]ENDDAT(nolign-1) = [M]STRDAT(nolign) - 1
Else
   If [M]ENDDAT(nolign-1) = [0/0/0]
      [M]ENDDAT(nolign-1) = [M]VLYDATITM
   Endif
Endif
# Forcage de la date fin de la ligne précédente
# à la date début - 1 de la ligne courante
If nolign <> 1 & [M]STRDAT(nolign-1) <> [0/0/0]
   [M]ENDDAT(nolign-2) = [M]STRDAT(nolign-1) - 1
   [M]UPDFLG(nolign-2) = 1
Endif

If [M:SOR1]PRITYP=1
   [M]NETPRINOT(NOL) = [M]NETPRI(NOL)
   Call CLCTAXEPRIV([M]NETPRI(NOL),[M]VAT,[M:SOR1]PRITYP,GSOCIETE,[M]STRDAT(NOL),
&                  0,[M:SOR1]VACBPR,0,0,[M]NETPRIATI(NOL)) From TRTX3
Else
   [M]NETPRIATI(NOL) = [M]NETPRI(NOL)
   Call CLCTAXEPRIV([M]NETPRI(NOL),[M]VAT,[M:SOR1]PRITYP,GSOCIETE,[M]STRDAT(NOL),
&                  0,[M:SOR1]VACBPR,0,0,[M]NETPRINOT(NOL)) From TRTX3
Endif

End
######################################## Obligatoire
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
   If nolign <= 1
      VALEUR  = date$
      [M]ENDDAT(nolign-1) = [M]VLYDATITM
   Else
      If [M]ENDDAT(nolign-2) <> [M]VLYDATITM
         VALEUR = [M]ENDDAT(nolign-2)
      Endif
   Endif
Endif
End

######################################## Obligatoire
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
# La date doit être >= à la date du jour
#If nolign = 1 & [M]CREFLG(0) = 0 & VALEUR < date$
#   GERR=1 : GMESSAGE=mess(72,199,1) : mkstat=2 : End
#Endif
# 101874 : V9 : Taxe code control
If VALEUR < [M]ORDDAT
   GERR=1 : GMESSAGE=mess(98,199,1) : mkstat=2 : End
Endif
# 101874

If VALEUR > [M]VLYDATITM
   GERR=1 : GMESSAGE=mess(128,192,1) : mkstat=2 : End
Endif
# La date doit être > à la date de la ligne précédente
If nolign <> 1 & VALEUR <= [M]STRDAT(nolign-2)
   GERR=1 : GMESSAGE=mess(73,199,1) : mkstat=2 : End
Endif
# La date doit être < à la date début de la ligne suivante
If nolign < [M]NBLIG & VALEUR >= [M]STRDAT(nolign)
   GERR=1 : GMESSAGE=mess(73,199,1) : mkstat=2 : End
Endif
# Modification de la date
If [M]CREFLG(nolign-1)<>0 | [M]UPDFLG(nolign-1)<>0
    # La date doit être <= à la date de fin de validité de la ligne
    If VALEUR > [M]ENDDAT(nolign-1)
       GERR=1 : GMESSAGE=mess(320,192,1)-"("-format$(GFMDAT,[M]ENDDAT(nolign-1))-")" : mkstat=2 : End :#--CPO 83985 GFMDAT au lieu de GFMD
    Endif
Endif
End

######################################## Facultatif
Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
Local    Decimal MNTDES
Local    Decimal COEF
# Initialisation du prix si création ligne
If VALEUR <> 0 End Endif
Read [ITS]ITS0=[M]ITMREF : #Call LECTURE ("ITS",[M]ITMREF,"") From CONTOBJ
If fstat Call RSTA ("ITS",[M]ITMREF) From GLOCK
Else
   If [F:ITM]SAU = [M]SAU COEF = 1
   Else
       If [M]SAUSTUCOE=0
           Call SREC_COE([M]ITMREF,[M]BPCORD,[F:ITM]SAU,[M]SAU,COEF) From TRTVENQTE
       Else
          # calcul coef. conversion UV cde --> UV article  car le prix de base est exprimé ds l'UV article
          # coef. conversion UV --> US / coef. conversion UV --> US de la fiche article
          COEF =[M]SAUSTUCOE/[F:ITM]SAUSTUCOE
          # Issue X3-24710
          # Like in SREC_COE From TRTVENQTE Used in price search when a conversion in document unit is necessary
          # Do not round the coefficient to calculate the good price
          #COEF=arr(COEF,0.000001)
          # End issue X3-24710
          If COEF=0 : GBIDD1=1 : Endif
       Endif
   Endif
   VALEUR = [F:ITS]BASPRI * COEF
   If [M:SOR1]CUR <> GSYSCUR
      Call CONVERT2 (GSYSCUR, [M:SOR1]CUR, GLOCALDEV, [M:SOR1]CHGTYP, date$, VALEUR, MNTDES, GBIDI1) From TRTDEV
      If GBIDI1 = 0 VALEUR = MNTDES Endif
   Endif
VALEUR = arr(VALEUR, 10^-GDECPRI)

Endif
End

######################################## Facultatif
Subprog AM_REP1(VALEUR)
Variable Char    VALEUR()
# Initialisation du taux commission représentant 1 si création ligne
If VALEUR = "" : [M]REPRAT1(nolign-1) = 0 : End : Endif
If [M]CREFLG(nolign-1) <> 0 : End : Endif
Read [BPC]BPC0=[M]BPCORD
If fstat : End : Endif
Read [REP]REP0 = VALEUR
If fstat = 0
   If [F:BPC]COMCAT <> 0
      [M]REPRAT1(nolign-1) = [F:REP]COMRAT1([F:BPC]COMCAT-1)
   Endif
Endif
End

######################################## Facultatif
Subprog AS_REPRAT1(VALEUR)
Variable Decimal VALEUR
# Si représentant non renseigné pas de saisie du taux de comm
If [M]REP1(nolign-1) = ""
   VALEUR = 0
   mkstat = 2
Endif
End

