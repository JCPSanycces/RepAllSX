If fstat : End : Endif
Read [REP]REP0 = VALEUR
If fstat = 0
   If [F:BPC]COMCAT <> 0
      [M]REPRAT2(nolign-1) = [F:REP]COMRAT2([F:BPC]COMCAT-1)
   Endif
Endif
End

######################################## Facultatif
Subprog AS_REPRAT2(VALEUR)
Variable Decimal VALEUR
# Si représentant non renseigné pas de saisie du taux de comm
If [M]REP2(nolign-1) = ""
   VALEUR = 0
   mkstat = 2
Endif
End

#########################################################################
# SECTION CONTENANT TRAITEMENTS ANNEXES                                 #
#########################################################################
$AVENANT
# Réécriture du contrat pour incrémenter le no avenant
If GITMREV = 2
   Readlock [SOH]SOH0 = [M]SOHNUM
   If !fstat
      [F:SOH]REVNUM = [M:SOR1]REVNUM
      Rewrite [SOH]
      If fstat  GOK=0 : Call FSTA("SOH") From GLOCK : Endif
   Endif
Endif
Return
########################################
$INTERDIT
# Recherche interdit
Local Decimal  MONTANT(0..10)
Local Shortint MOTIF(0..10), PRIORITE(0..10)
Local Char     PLI   (6) (0..10)
Local Char     PLICRD (30) (0..10)
Local Integer  PLILIN    (0..10)
Local Shortint FOCMOTIF
Local Char     FOCITMREF, FOCUOM
Local Decimal  FOCQTY
Local Date     PLISTRDAT, PLIENDDAT
Local Libelle  INTERDIT, ERR
#---- Paramètres complementaires appel recherche tarifs
Local  Char    PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US : # indice 1 = régime de taxe
PARAM_T(1)=[M:SOR1]VACBPR
#  Lecture des enregistrements succeptible d'être des critères de recherche
Read [BPR]BPR0=[M]BPCORD
Read [BPC]BPC0=[M]BPCORD
#Call LECTURE ("MVC",GFINRSP,[M]BPCORD) From CONTOBJ
Read [BPD]BPD0=[M]BPCORD;[M]BPAADD
If dim([M]XREP1) > 0 Call LECTURE ("REP",[M]XREP1,"") From CONTOBJ Endif
Call ALIPLK ("SOI") From TRTPRICE
Call TARIFRECH(5,3,"SOI",date$,[M]EXTQTY,[M]SAU,[M:SOR1]CHGTYP,[M:SOR1]CUR,
&       [M:SOR1]PRITYP,[M]VAT,PARAM_T,
&       MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&       FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT,ERR)
&       From TRTPRICE
Return
########################################
$PRIXNET
# Calcul prix net
Local Integer NOL
Local Decimal NET
Local Decimal MAJREM(0..8)
NOL = nolign-1
# Chargement des valeurs frais/remises
For I = 0 To dim([F:SOH]DISCRGTYP) - 1
   If evalue("dim([M]DISCRGVAL"+num$(I+1)+")") > 0
      MAJREM(I) = evalue("DISCRGVAL"+num$(I+1)+"("+num$(NOL)+")")
   Endif
Next I
# Calcul du prix net
NET = [M]NETPRI(NOL)
#Call CALNET (1,"",[M]GROPRI(NOL),MAJREM,1,NET, [M:SOR1]CUR) From TRTPRICE
If dim(GCALNETLIN)>0 : GCALNETLIN=NOL+1    : Endif
If dim(GCALNETABR)>0 : GCALNETABR="[M]"    : Endif
Call CALNET (1,[M]PLISTC,[M]GROPRI(NOL),MAJREM,1,NET, [M:SOR1]CUR) From TRTPRICE
[M]NETPRI(NOL) = NET
Affzo [M]NETPRI(NOL)
Return
########################################
$MARGE
# Calcul marge
Local Decimal PHTNET
Local Decimal COUTHT, COUTHTC
Local Integer LOK, NOL
Local    Decimal PFM, PFMRAT
Local    Decimal WQTY

NOL = nolign-1

# Pas de calcul de marge pour les prix à 0
If [M]NETPRI(NOL) = 0 Return : Endif

# Récupération du coef de conversion UV en US pour calcul de la marge
#COEF = 1
#If [M]SAU <> [M]STU
#   Call SCAL_QUS(0,[M]ITMREF,[M]BPCORD,[M]SAU,[M]STU,WQTY,COEF)
#&              From TRTVENQTE
#Endif

# --> Calcul de la marge : # FQ 47040 + param "[M]"
Call CALPFM("[M]",NOL,[M]NETPRI(NOL),[M]VAT,[M:SOR1]PRITYP,[M]STOFCY,[M]ITMREF,
&          [M:SOR1]CHGTYP,[M]STRDAT(NOL),[M:SOR1]CUR,[M]SAUSTUCOE,1,[M]STOMGTCOD, PFM,GBIDD1) From TRTVENPRI

[M]PFM(NOL) = PFM
Affzo [M]PFM(NOL)

Return
