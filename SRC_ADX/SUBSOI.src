# -------------------------------------- SAU ------------------------
##########################################################################
## Etiquette ajoutée par le superviseur 02/06/2004 17:02:10 (LD)
##########################################################################
Subprog C_SAU(VALEUR)
Variable Char    VALEUR()

Local Integer NOL    :    NOL = nolign-1
Local Decimal WQTY, COEF

# CTLUOM ctrle l'unité et ramène le coef de conversion et le flag autorisation de saisie
# Ne ramener le coef de conversion que si on a modifié l'unité de vente
# car sinon si on a modifié à la main le coef il est systématiquement écrasé
If VALEUR <> [M]SAU | GIMPORT
    # Recherche du nouveau coefficient UV-US
    Call CTLUOM([M]ITMREF,2,[M]BPCORD,VALEUR,COEF,GBIDC1,GBIDC2,
&               [M]DACSAUCOE) From STKACT
    If mkstat=2 End Endif
    [M]SAUSTUCOE = COEF
    Affzo [M]SAUSTUCOE
    If VALEUR=[M]STU | [M]DACSAUCOE < 2
        Diszo [M]SAUSTUCOE
    Else
        Actzo [M]SAUSTUCOE
    Endif
Endif

End
