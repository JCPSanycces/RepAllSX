          When 6  : Chgtzn [M:PHY9]USRFLDA6  With evalue("GABLIA"+num$([L]N_I))
          When 7  : Chgtzn [M:PHY9]USRFLDA7  With evalue("GABLIA"+num$([L]N_I))
