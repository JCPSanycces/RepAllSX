          When 1  : Chgtzn [M:GRT9]USRFLDM1  With evalue("GABLIM"+num$([L]N_I))
          When 2  : Chgtzn [M:GRT9]USRFLDM2  With evalue("GABLIM"+num$([L]N_I))
