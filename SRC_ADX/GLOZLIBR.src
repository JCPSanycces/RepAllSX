          When 1  : Chgtzn [M:LEA9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:LEA9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:LEA9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
