# Zones libres coef
For [L]N_I = 1 To 2
  Call LECTEXTRA([L]INTIT,"FREFLD","USRFLDC"+num$([L]N_I),num$([L]OBJ),GABZLCPY) From ATEXTRA
  Assign 'GABLIC'+num$([L]N_I) With [L]INTIT
############ Chgtzn provisoires ##############
  If !INIT
#    Chgtzn ="[M:"+[L]ABRMSK+"]USRFLDC"+num$([L]N_I) With evalue("GABLIC"+num$([L]N_I))
    Case [L]ABRMSK
      When "FRZ9"
        Case [L]N_I
          When 1  : Chgtzn [M:FRZ9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:FRZ9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "FAS9"
        Case [L]N_I
          When 1  : Chgtzn [M:FAS9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:FAS9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "LOF9"
        Case [L]N_I
          When 1  : Chgtzn [M:LOF9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:LOF9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "GRT9"
        Case [L]N_I
          When 1  : Chgtzn [M:GRT9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:GRT9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "LEA9"
        Case [L]N_I
          When 1  : Chgtzn [M:LEA9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:LEA9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "PHY9"
        Case [L]N_I
          When 1  : Chgtzn [M:PHY9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:PHY9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
      When "CCN9"
        Case [L]N_I
          When 1  : Chgtzn [M:CCN9]USRFLDC1  With evalue("GABLIC"+num$([L]N_I))
          When 2  : Chgtzn [M:CCN9]USRFLDC2  With evalue("GABLIC"+num$([L]N_I))
        Endcase
    Endcase
  Endif
############ Chgtzn provisoires ##############
Next [L]N_I

Return

#################################################################################
$TRT_REFTAB
# Changements des Nô¯ de table de rûˋfûˋrence dans l'ûˋcran FREEZON9
For [L]N_I = 1 To 10
  If evalue("[M:"+[L]ABRMSK+"]REFTAB"+num$([L]N_I)) > 0
    Assign "[M:"+[L]ABRMSK+"]REFTAB"+num$([L]N_I) With evalue("GABLIADI"+num$([L]N_I))
  Endif
Next [L]N_I
Return

################################################################################
Subprog GET_DEVISE (P_DEVISE, P_SITE)
# Initialise les paramû´tres devises associûˋs aux zones libres montants
# Si le paramûˋtrage est incorrect, la devise positionnûˋe est la devise sociûˋtûˋ
# Doit ûˆtre appelûˋ sur le "AVANT_ZONE" et le "APRES_MODIF" de la devise de l'objet mûˋtier
# ------------------------------------------------------------------------------
Value Char P_SITE
Value Char P_DEVISE

Local Integer OBJ    : # Code objet => menu local 341
Local Integer OK     : # Indicateur lecture dico zones libres correcte
Local Integer N_I    : # Indice pour boucle sur montants libres

# Recherche la sociûˋtûˋ courante et la devise sociûˋtûˋ
Call GET_DEV([L]P_SITE) From GLOFCYCPY

# Fin si la sociûˋtûˋ et la devise courante n'ont pas changûˋ
If GCOUSOC=[M]FRFAMTCPY & [L]P_DEVISE=[M]FRFAMTCUR : End : Endif

If clalev([F:FRF])=0 : Local File FREFLD    [FRF]  : Endif

[L]OBJ = find(GABREV,GOBJTAB)
[L]OK  = 1

Read [FRF]FRF0=[L]OBJ;GCOUSOC : # Paramûˋtrage Sociûˋtûˋ
If fstat
  Read [FRF]FRF0=[L]OBJ;"" : # Paramûˋtrage par dûˋfaut
  If fstat : [L]OK = 0 : Endif
Endif

# Zones libres montant
For [L]N_I = 1 To 6
  If OK & [F:FRF]AMTCUR ([L]N_I-1) = 2
    Assign 'GABZLMNT'+num$([L]N_I) With [L]P_DEVISE
  Else
    Assign 'GABZLMNT'+num$([L]N_I) With GCOUDEV
  Endif
Next [L]N_I

Call AFFICHE_DEVISES() From SUBFRZ

# mûˋmorisation sociûˋtûˋ et devise courantes
[M]FRFAMTCPY = GCOUSOC
[M]FRFAMTCUR = [L]P_DEVISE

End

