# Zones libres date
For [L]N_I = 1 To 4
  Call LECTEXTRA([L]INTIT,"FREFLD","USRFLDD"+num$([L]N_I),num$([L]OBJ),GABZLCPY) From ATEXTRA
  Assign 'GABLID'+num$([L]N_I) With [L]INTIT
