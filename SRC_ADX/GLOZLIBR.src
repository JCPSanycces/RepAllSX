          When 10 : Chgtzn [M:PHY9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        Endcase
      When "CCN9"
        Case [L]N_I
          When 1  : Chgtzn [M:CCN9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:CCN9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:CCN9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
          When 4  : Chgtzn [M:CCN9]USRFLDA4  With evalue("GABLIA"+num$([L]N_I))
          When 5  : Chgtzn [M:CCN9]USRFLDA5  With evalue("GABLIA"+num$([L]N_I))
          When 6  : Chgtzn [M:CCN9]USRFLDA6  With evalue("GABLIA"+num$([L]N_I))
          When 7  : Chgtzn [M:CCN9]USRFLDA7  With evalue("GABLIA"+num$([L]N_I))
          When 8  : Chgtzn [M:CCN9]USRFLDA8  With evalue("GABLIA"+num$([L]N_I))
          When 9  : Chgtzn [M:CCN9]USRFLDA9  With evalue("GABLIA"+num$([L]N_I))
          When 10 : Chgtzn [M:CCN9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        When Default
          GMESSAGE = [L]ABRMSK - ": This mask doesn't exist"
        Endcase
    Endcase
  Endif
############ Chgtzn provisoires ##############
  If [L]OK & [F:FRF]ALPREF([L]N_I-1) <> 0
    Assign 'GABLIADI'+num$([L]N_I) With [F:FRF]ALPREF([L]N_I-1)
  Else
    Assign 'GABLIADI'+num$([L]N_I) With 0
  Endif
Next [L]N_I
If GMESSAGE <> ""
    Return
Endif

# Zones libres montant
For [L]N_I = 1 To 6
  Call LECTEXTRA([L]INTIT,"FREFLD","USRFLDM"+num$([L]N_I),num$([L]OBJ),GABZLCPY) From ATEXTRA
  Assign 'GABLIM'+num$([L]N_I) With [L]INTIT
############ Chgtzn provisoires ##############
  If !INIT
#    Chgtzn ="[M:"+[L]ABRMSK+"]USRFLDM"+num$([L]N_I) With evalue("GABLIM"+num$([L]N_I))
    Case [L]ABRMSK
      When "FRZ9"
        Case [L]N_I
          When 1  : Chgtzn [M:FRZ9]USRFLDM1  With evalue("GABLIM"+num$([L]N_I))
          When 2  : Chgtzn [M:FRZ9]USRFLDM2  With evalue("GABLIM"+num$([L]N_I))
