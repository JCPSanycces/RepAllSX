          When 1  : Chgtzn [M:FAS9]USRFLDM1  With evalue("GABLIM"+num$([L]N_I))
          When 2  : Chgtzn [M:FAS9]USRFLDM2  With evalue("GABLIM"+num$([L]N_I))
          When 3  : Chgtzn [M:FAS9]USRFLDM3  With evalue("GABLIM"+num$([L]N_I))
          When 4  : Chgtzn [M:FAS9]USRFLDM4  With evalue("GABLIM"+num$([L]N_I))
          When 5  : Chgtzn [M:FAS9]USRFLDM5  With evalue("GABLIM"+num$([L]N_I))
          When 6  : Chgtzn [M:FAS9]USRFLDM6  With evalue("GABLIM"+num$([L]N_I))
        Endcase
      When "LOF9"
        Case [L]N_I
          When 1  : Chgtzn [M:LOF9]USRFLDM1  With evalue("GABLIM"+num$([L]N_I))
          When 2  : Chgtzn [M:LOF9]USRFLDM2  With evalue("GABLIM"+num$([L]N_I))
          When 3  : Chgtzn [M:LOF9]USRFLDM3  With evalue("GABLIM"+num$([L]N_I))
          When 4  : Chgtzn [M:LOF9]USRFLDM4  With evalue("GABLIM"+num$([L]N_I))
          When 5  : Chgtzn [M:LOF9]USRFLDM5  With evalue("GABLIM"+num$([L]N_I))
