#    SYSTEME DE PARAMETRAGE DES ZONES LIBRES
#    FGR
#    Crûˋation le : 17/02/2003
#
#    Modification le : 01/03/2010 GLE - Ajout de la gestion des des ûˋlûˋments physiques et des contrats de concession
#    Modification le : 12/06/2003 ELA - Remplacement des tables div. 450, 451 et 452 par FREFLD
#    Modification le : 08/07/2003 ELA - Adaptation aux libellûˋs traduisibles (accû´s û  ATEXTRA)
#    Modification le : 10/09/2003 ELA - Gestion dynamique des intitulûˋs en fonction du site de l'objet
################################################################################
# Subprog INIT_INTIT : Init globales des zones libres (intitulûˋs et Nô¯ table de rûˋfûˋrence)
# Subprog GET_INTIT(SITE) : Maj globales des zones libres (intitulûˋs et Nô¯ table de rûˋfûˋrence)+affichage
# Subprog GET_DEVISE (P_DEVISE, P_SITE) : Init. globales associûˋes aux zones libres montants+affichage
#################################################################################

#################################################################################
# Sous-programme INIT_INTIT
# Initialise les globales des zones libres û  partir de la table FREFLD
#  * Libellûˋs pour toutes
#  * liaisons tables diverses pour les 10 alpha
# Les intitulûˋs sont ensuite affichûˋs sur le masque "Autres Infos" par le superviseur (intitulûˋs ûˋvaluûˋs)
#################################################################################
Subprog INIT_INTIT

Gosub DECLARE

[L]INIT=1
[L]OBJ = find(GABREV,GOBJTAB)

If ![L]OBJ :  End : Endif

Raz GABZLFCY, GABZLCPY

Gosub PARDEF

Gosub TRT_GLOBALES

End

#################################################################################
# Sous-programme GET_INTIT(SITE)
# Met û  jour les globales des zones libres û  partir de la table FREFLD en fonction du site
#  * Libellûˋs pour toutes
#  * liaisons tables diverses pour les 10 alpha
# Affiche les intitulûˋs sur le masque "Autres Infos"
#################################################################################
Subprog GET_INTIT(SITE)
Value    Char    SITE : # Site

Gosub DECLARE

INIT=0
OBJ = find(GABREV,GOBJTAB)

If ![L]OBJ :  End : Endif

# On est sur le site courant
If SITE = GABZLFCY : End : Endif

GABZLFCY=SITE

# Recherche de la sociûˋtûˋ courante
Call GET_SOC(SITE) From GLOFCYCPY

# On est sur la sociûˋtûˋ courant
If GCOUSOC = GABZLCPY : End : Endif

Gosub PARDEF

Read [FRF]FRF0=OBJ;GCOUSOC : # Paramûˋtrage Sociûˋtûˋ

If OK & GABZLCPY=[F:FRF]CPY
  End
Elsif GABZLCPY<>[F:FRF]CPY
  GABZLCPY=[F:FRF]CPY
Else
  Raz GABZLCPY
Endif

Gosub TRT_GLOBALES

Gosub TRT_REFTAB

End

#################################################################################
$DECLARE
# Dûˋclaration variables locales

Local Integer OBJ     : # Code objet => menu local 341
Local Integer OK      : # Indicateur lecture dico zones libres correcte
Local Integer N_I     : # Indice pour boucle sur zones libres
Local Integer INIT    : # Indicateur contexte initialisation
Local Char    INTIT   : # Intitulûˋ
Local Char    ABRMSK  : # Abrûˋviation masque "Autres infos"
Return

#################################################################################
$PARDEF
# Accû´s au paramûˋtrage par dûˋfaut

If clalev([F:FRF])=0 : Local File FREFLD    [FRF]  : Endif

[L]OK = 1
Read [FRF]FRF0=[L]OBJ;"" : # Paramûˋtrage par dûˋfaut
If fstat : [L]OK = 0 : Endif

If ![L]OK | clalev([M:FRZ9])
  [L]ABRMSK="FRZ9"
Else
  [L]ABRMSK=[F:FRF]ABRMSK
Endif
Return

#################################################################################
$TRT_GLOBALES
# Chargements des globales et affichage des intitulûˋs

# Zones libres Alpha
# charge le libellûˋ et la table diverse
# si l'information n'est pas disponible l'ûˋcran est initialisûˋ sans libellûˋ
# et la table 0

For [L]N_I = 1 To 10
  Call LECTEXTRA([L]INTIT,"FREFLD","USRFLDA"+num$([L]N_I),num$([L]OBJ),GABZLCPY) From ATEXTRA
  Assign 'GABLIA'+num$([L]N_I) With [L]INTIT
############ Chgtzn provisoires ##############
  If ![L]INIT
#    Chgtzn ="[M:"+[L]ABRMSK+"]USRFLDA"+num$([L]N_I) With evalue("GABLIA"+num$([L]N_I))
    Case [L]ABRMSK
      When "FAS9"
        Case [L]N_I
          When 1  : Chgtzn [M:FAS9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:FAS9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:FAS9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
          When 4  : Chgtzn [M:FAS9]USRFLDA4  With evalue("GABLIA"+num$([L]N_I))
          When 5  : Chgtzn [M:FAS9]USRFLDA5  With evalue("GABLIA"+num$([L]N_I))
          When 6  : Chgtzn [M:FAS9]USRFLDA6  With evalue("GABLIA"+num$([L]N_I))
          When 7  : Chgtzn [M:FAS9]USRFLDA7  With evalue("GABLIA"+num$([L]N_I))
          When 8  : Chgtzn [M:FAS9]USRFLDA8  With evalue("GABLIA"+num$([L]N_I))
          When 9  : Chgtzn [M:FAS9]USRFLDA9  With evalue("GABLIA"+num$([L]N_I))
          When 10 : Chgtzn [M:FAS9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        Endcase
      When "LOF9"
        Case [L]N_I
          When 1  : Chgtzn [M:LOF9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:LOF9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:LOF9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
          When 4  : Chgtzn [M:LOF9]USRFLDA4  With evalue("GABLIA"+num$([L]N_I))
          When 5  : Chgtzn [M:LOF9]USRFLDA5  With evalue("GABLIA"+num$([L]N_I))
          When 6  : Chgtzn [M:LOF9]USRFLDA6  With evalue("GABLIA"+num$([L]N_I))
          When 7  : Chgtzn [M:LOF9]USRFLDA7  With evalue("GABLIA"+num$([L]N_I))
          When 8  : Chgtzn [M:LOF9]USRFLDA8  With evalue("GABLIA"+num$([L]N_I))
          When 9  : Chgtzn [M:LOF9]USRFLDA9  With evalue("GABLIA"+num$([L]N_I))
          When 10 : Chgtzn [M:LOF9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        Endcase
      When "GRT9"
        Case [L]N_I
          When 1  : Chgtzn [M:GRT9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:GRT9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:GRT9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
          When 4  : Chgtzn [M:GRT9]USRFLDA4  With evalue("GABLIA"+num$([L]N_I))
          When 5  : Chgtzn [M:GRT9]USRFLDA5  With evalue("GABLIA"+num$([L]N_I))
          When 6  : Chgtzn [M:GRT9]USRFLDA6  With evalue("GABLIA"+num$([L]N_I))
          When 7  : Chgtzn [M:GRT9]USRFLDA7  With evalue("GABLIA"+num$([L]N_I))
          When 8  : Chgtzn [M:GRT9]USRFLDA8  With evalue("GABLIA"+num$([L]N_I))
          When 9  : Chgtzn [M:GRT9]USRFLDA9  With evalue("GABLIA"+num$([L]N_I))
          When 10 : Chgtzn [M:GRT9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        Endcase
      When "LEA9"
