          When 1  : Chgtzn [M:LEA9]USRFLDM1  With evalue("GABLIM"+num$([L]N_I))
          When 2  : Chgtzn [M:LEA9]USRFLDM2  With evalue("GABLIM"+num$([L]N_I))
          When 3  : Chgtzn [M:LEA9]USRFLDM3  With evalue("GABLIM"+num$([L]N_I))
          When 4  : Chgtzn [M:LEA9]USRFLDM4  With evalue("GABLIM"+num$([L]N_I))
          When 5  : Chgtzn [M:LEA9]USRFLDM5  With evalue("GABLIM"+num$([L]N_I))
