          When 8  : Chgtzn [M:LEA9]USRFLDA8  With evalue("GABLIA"+num$([L]N_I))
          When 9  : Chgtzn [M:LEA9]USRFLDA9  With evalue("GABLIA"+num$([L]N_I))
          When 10 : Chgtzn [M:LEA9]USRFLDA10 With evalue("GABLIA"+num$([L]N_I))
        Endcase
      When "PHY9"
        Case [L]N_I
          When 1  : Chgtzn [M:PHY9]USRFLDA1  With evalue("GABLIA"+num$([L]N_I))
          When 2  : Chgtzn [M:PHY9]USRFLDA2  With evalue("GABLIA"+num$([L]N_I))
          When 3  : Chgtzn [M:PHY9]USRFLDA3  With evalue("GABLIA"+num$([L]N_I))
          When 4  : Chgtzn [M:PHY9]USRFLDA4  With evalue("GABLIA"+num$([L]N_I))
