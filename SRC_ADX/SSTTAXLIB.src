####################################################################################################
# New function for parsing JSON - 106738
Subprog TRUNCATE_JSON(STR_REMAIN, FIND_STR)
  Variable Clbfile STR_REMAIN()
  Value Char FIND_STR()

  X = instr(1,STR_REMAIN, FIND_STR)

  STR_REMAIN = right$(STR_REMAIN,X+1)

End



####################################################################################################
Funprog REPLACE_CHARACTERS(TEXT)
  Value Clbfile TEXT

  Local Clbfile TMPTEXT
  Local Integer CHARPOS1
  Local Integer CHARPOS2

  # Place escape character in front of backslash character
  If instr(1,TEXT,'\')
    CHARPOS1 = 1
    CHARPOS2 = instr(1,TEXT,'\')

    Repeat
      TMPTEXT  = seg$(TEXT,CHARPOS1,CHARPOS2-1) + "\\"
      CHARPOS1 = CHARPOS2 + 1
      CHARPOS2 = instr(CHARPOS1,TEXT,'\')
    Until CHARPOS2 = 0

    TEXT = TMPTEXT + seg$(TEXT,CHARPOS1,len(TEXT))
  Endif

  # Place escape character in front of double quote character
  If instr(1,TEXT,'"')
    CHARPOS1 = 1
    CHARPOS2 = instr(1,TEXT,'"')

    Repeat
      TMPTEXT += seg$(TEXT,CHARPOS1,CHARPOS2-1) + '\"'
      CHARPOS1 = CHARPOS2 + 1
      CHARPOS2 = instr(CHARPOS1,TEXT,'"')
    Until CHARPOS2 = 0

    TEXT = TMPTEXT + seg$(TEXT,CHARPOS1,len(TEXT))
  Endif

End TEXT

