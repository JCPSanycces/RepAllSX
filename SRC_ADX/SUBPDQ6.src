#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque PDSYPTD
##########################################################################
# SUBPDQ6 : Affichage de la situation d'une ligne rcp       HN 05/02/03  #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action         #
# VISUETAPTD et sert à gérer le masque  écran "PDQ6 [PDQ6]"              #
##########################################################################
$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# VISUETAPTD : Affichage situation ligne de réception                 #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUV_VISUETAPTD
 When "TITRE"       : Gosub TITRE_VISUETAPTD
 When "DEBUT"       : Gosub DEB_VISUETAPTD
 When "FINSAI"      : Gosub FINSAI_VISUETAPTD
Endcase
Return
#############################################################################
# Remplacé par l'action VISUETAPTD avec paramètres :                        #
#   PARAM(1) = NUM    : Numéro   de la récept à traiter                     #
#   PARAM(2) = LIN    : Numéro   de la ligne de récept à traiter            #
#   PARAM(3) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(4) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETAPTD
#----- Variables locales -----#
Local Char     NUMRCP(GLONPTH) : NUMRCP=PARAM(1)
Local Integer  LINRCP          : LINRCP=val(PARAM(2))
Local Char     WABMSK(4)       : WABMSK =PARAM(3)
Local Shortint NOL             : NOL=val(PARAM(4))
Local Shortint SAVGNOLIGN, I, J, K, L
SAVNOLIGN=nolign
If evalue("[M:"+WABMSK+"]NBLIG=0") |
&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETAPTD
#--- Issue 95710 by TS
TIT=mess(164,198,1)-mess(117,198,1)-NUMRCP-num$(LINRCP)
#TIT=mess(164,198,1)-NUMRCP-num$(LINRCP)
#---
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETAPTD
Local Char WQLYCTLDEM(GLONVCR) : #VPO 09/12/10 69709
Local Decimal WAMT  # Issue X3-70225 - 2018-08-07 by SDEM
Local Integer WSTAT # Issue X3-70225 - 2018-08-07 by SDEM
Local Decimal WRATCUR # Issue X3-70225 - 2018-08-07 by SDEM
Raz [M:PDQ6]
Call TEMPON("O") From GESECRAN
#----- Lecture ligne réception à traiter si nécessaire -----#
If [F:PTD]PTHNUM<>NUMRCP | [F:PTD]PTDLIN<>LINRCP
  Read [PTD] PTD0=NUMRCP;LINRCP  : If fstat Raz [F:PTD] : Endif
Endif
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:PND])<=0 Local File PRETURND   [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE   [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED  [PID] : Endif
If clalev([F:STJ])<=0 Local File STOJOU     [STJ] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 Local File ITMFACILIT [ITF] : Endif

#----- Chargement des zones dans le masque -----#
[M:PDQ6]=[F:PTD]
[M:PDQ6]PUU1=[F:PTD]PUU
[M:PDQ6]STU1=[F:PTD]STU
[M:PDQ6]PUU2=[F:PTD]PUU
[M:PDQ6]STU2=[F:PTD]STU
[M:PDQ6]UOM1=[F:PTD]UOM
[M:PDQ6]UOM11=[F:PTD]UOM
[M:PDQ6]UOM12=[F:PTD]UOM
[M:PDQ6]UOM2=[F:PTD]PUU
[M:PDQ6]UOM21=[F:PTD]PUU
[M:PDQ6]UOM22=[F:PTD]PUU


# Issue 82703 - 2012-10-12 by MUARN : ajout montant ligne
[M:PDQ6]CUR1     =evalue("[M:"+WABMSK+"]NETCUR")
[M:PDQ6]LINAMT   =evalue("[M:"+WABMSK+"]LINAMT(NOL)")

If [F:ITM]ITMREF<>[F:PTD]ITMREF
  Read [ITM]ITM0=[F:PTD]ITMREF
  If fstat : Raz [F:ITM]ITMREF : Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITM]STOMGTCOD>1
   If [F:ITF]STOFCY <> [F:PTD]PRHFCY | [F:ITF]ITMREF <> [F:PTD]ITMREF
      Read [ITF]ITF0 = [F:PTD]ITMREF;[F:PTD]PRHFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
Endif

#--- Pour les articles gérés en stock on regarde les mouvements
If  [F:ITM]STOMGTCOD>1 & [F:ITF]STOMGTCOD>1
  Raz WQLYCTLDEM : #VPO 09/12/10 69709
  Raz GBIDD1, GBIDD2, GBIDD3
  For [STJ]STJ1 Where STOFCY = [F:PTD]PRHFCY   &
&                     VCRTYP = 6               &
&                     VCRNUM = [F:PTD]PTHNUM   &
&                     VCRLIN = [F:PTD]PTDLIN   &
&                     ITMREF = [F:PTD]ITMREF   &
&                     UPDCOD = 2               &
&                     REGFLG <>2               &
&                     TRSTYP <>29                : #--- Issue 115206
    If [F:STJ]QTYSTU>0
      If left$([F:STJ]STA,1)="A"
        GBIDD1+=[F:STJ]QTYSTU
      Elsif left$([F:STJ]STA,1)="Q"
        GBIDD2+=[F:STJ]QTYSTU
        #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
        # on récupère demande d'analyse
        If [F:STJ]QLYCTLDEM<>""  WQLYCTLDEM=[F:STJ]QLYCTLDEM : Endif
      Elsif left$([F:STJ]STA,1)="R"
        GBIDD3+=[F:STJ]QTYSTU
      Endif
    Endif
  Next
  #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
  # selon demande d'analyse
  If WQLYCTLDEM<>""
      For [STJ] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                    & VCRNUM=WQLYCTLDEM
&                    & VCRTYPORI=6
&                    & VCRNUMORI=[F:PTD]PTHNUM
&                    & VCRLINORI=[F:PTD]PTDLIN
&                    & ITMREF = [F:PTD]ITMREF
&                    & UPDCOD = 2
&                    & REGFLG<>2
&                    & TRSTYP<>29                : #--- Issue 115206
          If left$([F:STJ]STA,1)="A"
            GBIDD1+=[F:STJ]QTYSTU
          Elsif left$([F:STJ]STA,1)="Q"
            GBIDD2+=[F:STJ]QTYSTU
          Elsif left$([F:STJ]STA,1)="R"
            GBIDD3+=[F:STJ]QTYSTU
          Endif
      Next
  Endif
  If [F:PTD]UOMSTUCOE=0 : [F:PTD]UOMSTUCOE=1 : Endif
  GBIDD1=GBIDD1/[F:PTD]UOMSTUCOE
  Call QTEARR(GBIDD1, [F:PTD]UOM) From TRTDIV
  [M:PDQ6]AAAQTY   =GBIDD1
  If [F:PTD]UOM=[F:PTD]PUU
    [M:PDQ6]AAAQTYPUU=[M:PDQ6]AAAQTY
  Else
    GBIDD1=[M:PDQ6]AAAQTY*[F:PTD]UOMPUUCOE
    Call QTEARR(GBIDD1, [F:PTD]PUU) From TRTDIV
    [M:PDQ6]AAAQTYPUU=GBIDD1
  Endif
  GBIDD2=GBIDD2/[F:PTD]UOMSTUCOE
  Call QTEARR(GBIDD2, [F:PTD]UOM) From TRTDIV
  [M:PDQ6]QQQQTY   =GBIDD2
  If [F:PTD]UOM=[F:PTD]PUU
    [M:PDQ6]QQQQTYPUU=[M:PDQ6]QQQQTY
  Else
    GBIDD2=[M:PDQ6]QQQQTY*[F:PTD]UOMPUUCOE
    Call QTEARR(GBIDD2, [F:PTD]PUU) From TRTDIV
    [M:PDQ6]QQQQTYPUU=GBIDD2
  Endif
  GBIDD3=GBIDD3/[F:PTD]UOMSTUCOE
  Call QTEARR(GBIDD3, [F:PTD]UOM) From TRTDIV
  [M:PDQ6]RRRQTY   =GBIDD3
  If [F:PTD]UOM=[F:PTD]PUU
    [M:PDQ6]RRRQTYPUU=[M:PDQ6]RRRQTY
  Else
    GBIDD3=[M:PDQ6]RRRQTY*[F:PTD]UOMPUUCOE
    Call QTEARR(GBIDD3, [F:PTD]PUU) From TRTDIV
    [M:PDQ6]RRRQTYPUU=GBIDD3
  Endif
Else
#--- Pour les autres seule la quantité en A et R
  If [F:PTD]UOMPUUCOE=0 [F:PTD]UOMPUUCOE=1 : Endif
  [M:PDQ6]AAAQTY=([F:PTD]QTYPUU-[F:PTD]RRRQTYPUU)/[F:PTD]UOMPUUCOE
  [M:PDQ6]AAAQTYPUU=[F:PTD]QTYPUU-[F:PTD]RRRQTYPUU
  Raz [M:PDQ6]QQQQTY, [M:PDQ6]QQQQTYPUU
  [M:PDQ6]RRRQTY=[F:PTD]RRRQTYPUU/[F:PTD]UOMPUUCOE
  [M:PDQ6]RRRQTYPUU=[F:PTD]RRRQTYPUU
Endif
[M:PDQ6]RTNQTYPUU   =[F:PTD]RTNQTYPUU
[M:PDQ6]RTNQTYSTU   =[F:PTD]RTNQTYSTU
Call QTEARR([M:PDQ6]AAAQTY,[M:PDQ6]UOM1) From TRTDIV
Call QTEARR([M:PDQ6]QQQQTY,[M:PDQ6]UOM1) From TRTDIV
Call QTEARR([M:PDQ6]RRRQTY,[M:PDQ6]UOM1) From TRTDIV
#-- Si quantité facturée >= quantité de la réception
If [F:PTD]INVQTYPUU>0 & [F:PTD]INVQTYPUU>=[F:PTD]QTYPUU
  [M:PDQ6]WLININVFLG=3 : # Totalement facturée
Elsif [F:PTD]INVQTYPUU<=0
  [M:PDQ6]WLININVFLG=1 : # Non facturée
Elsif [F:PTD]INVQTYPUU>=0
  [M:PDQ6]WLININVFLG=2 : # Facturation partielle
Endif
[M:PDQ6]LININVFLG=[F:PTD]LININVFLG
Raz I
Raz GERR
Filter [PID] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & SEQORI=0
&              Order By Key PID1
For [PID]
  Gosub CHARG_LIG_FAC
  If GERR<>0 Break : Endif
Next
Filter [PID]
# Issue 84130 - 2013-03-28 by MUARN : landed-cost ne pas tenir compte des quantité facturées sinon factures complémentaires non visualisées
If [F:PTD]POHNUM<>""
  #----- Chargement des factures effectuées sur la ligne de commande -----#
  Filter [PID] Where TYPORI=1 & NUMORI=[F:PTD]POHNUM & LINORI=[F:PTD]POPLIN & SEQORI=[F:PTD]POQSEQ
&              Order By Key PID1
  For [PID]
    Gosub CHARG_LIG_FAC
    If GERR<>0 Break : Endif
  Next
  Filter [PID]
Endif
#-- Il y a une qté facturé mais pas sur la réception, ni sur la commande
#-- Il s'agit d'une autre réception surfacturée
If [F:PTD]INVQTYPUU>0 & [M:PDQ6]NBFAC=0
  #----- Chargement des factures effectuées sur la ligne de commande -----#
  Filter [PID] Where TYPORI=2 & POHNUM=[F:PTD]POHNUM & POPLIN=[F:PTD]POPLIN & POQSEQ=[F:PTD]POQSEQ
&              Order By Key PID1
  GBIDD3=[F:PTD]INVQTYPUU
  For [PID]
    Gosub CHARG_LIG_FAC
    If GERR<>0  Break : Endif
    GBIDD3-=[F:PID]QTYPUU : If GBIDD3<=0  Break : Endif
  Next
  Filter [PID]
Endif
Raz J
Filter [PND] Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[F:PTD]PTDLIN
&            Order By Key PND1
For [PND]
  Gosub CHARG_LIG_RET
  If GERR<>0 : Break : Endif
Next
Filter [PND]
Gosub CHARG_RET_FAC
Gosub CHARG_COM_FAC
[M:PDQ6]LININVNBR=[M:PDQ6]NBFAC
[M:PDQ6]LINPNHNBR=[M:PDQ6]NBPNH

# Issue 82703 - 2012-10-12 by MUARN : ajout montant total factures complémentaires
[M:PDQ6]CUR2     =evalue("[M:"+WABMSK+"]NETCUR")
#--- Issue X3-70225 - 2018-08-07 by SDEM : Start
#--- Issue 95710 by TS
#[M:PDQ6]AMTPIHFCC =sigma(I=0,[M:PDQ6]NBFAC-1,[M:PDQ6]AMTNOTLIN(I)*([M:PDQ6]PIHTYP(I)=2))
#[M:PDQ6]AMTPIHFCC =sigma(I=0,[M:PDQ6]NBFAC-1,
#&                  [M:PDQ6]AMTNOTLIN(I)*([M:PDQ6]PIHTYP(I)=2)
#&                 +[M:PDQ6]AMTNOTLIN(I)*([M:PDQ6]PIHTYP(I)=3&[M:PDQ6]NETPRI(I)=0&[M:PDQ6]FACQTYPUU(I)=0))
#---
  [M:PDQ6]AMTPIHFCC =0
  For NI=0 To [M:PDQ6]NBFAC-1
    Read [F:PIH]PIH0=[M:PDQ6]NUM(NI)
    If [M:PDQ6]PIHTYP(NI)=2 or ([M:PDQ6]PIHTYP(NI)=3 and [M:PDQ6]NETPRI(NI)=0 and [M:PDQ6]FACQTYPUU(NI)=0)
      If [M:PDQ6]CUR(NI)= [M:PDQ6]CUR2 Then
        [M:PDQ6]AMTPIHFCC +=[M:PDQ6]AMTNOTLIN(NI)
      Else
        WI=find([F:PTH]CUR,[F:PIH]CURLED)
        If WI & [F:PIH]RATDIV(WI-1)<>0
          WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
          WAMT=[M:PDQ6]AMTNOTLIN(NI)
          WAMT=WAMT*WRATCUR
        Else
          WAMT=0
          Call CONVERT2([M:PDQ6]CUR(NI),[M:PDQ6]CUR2,GLOCALDEV,[F:PIH]CURTYP,[M:PDQ6]ACCDAT(NI),
&         [M:PDQ6]AMTNOTLIN(NI),WAMT,WSTAT) From TRTDEV
        Endif
        [M:PDQ6]AMTPIHFCC += WAMT
      Endif
    Endif
  Next NI
  # Issue X3-70225 - 2018-08-07 by SDEM : End


#----- Affichage foreground -----#
Filter [PID] : Filter [PND]
Affzo [PDQ6]
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETAPTD
nolign=SAVNOLIGN
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
If I>dim([M:PDQ6]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
OK=1
For L=0 To [M:PDQ6]NBFAC-1
  If [M:PDQ6]NUM(L)=[F:PID]NUM & [M:PDQ6]PIDLIN(L)=[F:PID]PIDLIN
    OK=0
  Endif
  If OK=0 Break : Endif
Next L
If OK<>0
  [M:PDQ6]TYPORI(I)   =[F:PID]TYPORI
  [M:PDQ6]NUM(I)      =[F:PID]NUM
  [M:PDQ6]PIDLIN(I)   =[F:PID]PIDLIN
  # Issue 82703 - 2012-10-11 by MUARN : type de facture
  [M:PDQ6]PIHTYP(I)   =[F:PID]PIHTYP
  If [F:PIH]NUM<>[F:PID]NUM
    Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
  Endif
  [M:PDQ6]ACCDAT(I)   =[F:PIH]ACCDAT
  [M:PDQ6]FCY(I)      =[F:PID]FCY
  [M:PDQ6]FACQTYPUU(I)=[F:PID]QTYPUU
  If [F:PID]PIHTYP>2 [M:PDQ6]FACQTYPUU(I)=0-[M:PDQ6]FACQTYPUU(I) : Endif
  [M:PDQ6]FACQTYSTU(I)=[F:PID]QTYSTU
  If [F:PID]PIHTYP>2 [M:PDQ6]FACQTYSTU(I)=0-[M:PDQ6]FACQTYSTU(I) : Endif
  [M:PDQ6]NETPRI(I)   =[F:PID]NETPRI
  [M:PDQ6]CUR(I)      =[F:PIH]CUR
  [M:PDQ6]AMTNOTLIN(I)=[F:PID]AMTNOTLIN
  If [F:PID]PIHTYP>2 [M:PDQ6]AMTNOTLIN(I)=0-[M:PDQ6]AMTNOTLIN(I) : Endif
  I+=1 : [M:PDQ6]NBFAC=I
  If I>dim([M:PDQ6]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Endif
Return

#----------------------------#
# Chargement ligne de retour #
#----------------------------#
$CHARG_LIG_RET
[M:PDQ6]PNHNUM(J)=[F:PND]PNHNUM
[M:PDQ6]PNDLIN(J)=[F:PND]PNDLIN
[M:PDQ6]RTNDAT(J)=[F:PND]RTNDAT
[M:PDQ6]PNHFCY(J)=[F:PND]PNHFCY
[M:PDQ6]RTQTYPUU(J)=[F:PND]QTYPUU
[M:PDQ6]RTQTYSTU(J)=[F:PND]QTYSTU
#----- Positionnement indicateur facturé -----#
If [F:PND]LININVFLG=2
  [M:PDQ6]XLININVFLG(J)=3 : # Totalement facturé
Elsif [F:PND]INVQTYPUU<>0
  [M:PDQ6]XLININVFLG(J)=2 : # Facturation partielle
Else
  [M:PDQ6]XLININVFLG(J)=1 : # Non facturé
Endif
#-----
J+=1 : [M:PDQ6]NBPNH=J
If J>dim([M:PDQ6]PNHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

$CHARG_RET_FAC
#---------------------------#
# Chargement des avoir      #
#---------------------------#
For J=0 To [M:PDQ6]NBPNH-1
  If [M:PDQ6]XLININVFLG(J)>1
    I=[M:PDQ6]NBFAC
    If I+1>dim([M:PDQ6]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Filter [PID] Where TYPORI=3 & PNHNUM=[M:PDQ6]PNHNUM(J) & PNDLIN=[M:PDQ6]PNDLIN(J)
&             Order By Key PID1
    For [PID]
     Gosub CHARG_LIG_FAC
     If GERR<>0  Break : Endif
    Next
    Filter [PID]
    If GERR<>0  Break : Endif
  Endif
Next J
Return

$CHARG_COM_FAC
#---------------------#
# Chargement fac comp #
#---------------------#
For J=0 To [M:PDQ6]NBFAC-1
   I=[M:PDQ6]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDQ6]NUM(J) & LINORI=[M:PDQ6]PIDLIN(J)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC
     If  GERR=2 : Break : Endif
   Next
   Filter [PID]
Next J
Return


##########################################################################

Subprog IB_NBPNH
#--------------------------------------------#
# Avant zone : Activation bouton "Réception" #
#--------------------------------------------#
Raz GBOUT1
If dim([M:PDQ6]PNHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDQ6]PNHNUM(nolign-1)<>"" & GFONC1<>"GESPNH"
  GBOUT1=mess(192,198,1)-[M:PDQ6]PNHNUM(nolign-1)
Endif
End

Subprog IB_NBFAC
#------------------------------------------#
# Avant zone : Activation bouton "Facture" #
#------------------------------------------#
Raz GBOUT1
If dim([M:PDQ6]NUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDQ6]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(55,198,1)-[M:PDQ6]NUM(nolign-1)
Endif
End

Subprog IB_NUM
End

