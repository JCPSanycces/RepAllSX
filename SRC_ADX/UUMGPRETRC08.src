#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGPRETRC08   Pre-migration fournisseurs                  Module TRC    #
# Gestion des adresses                                                     #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRETRC08") From LECFIC
  Endif
  Call MAJ_UUMGPRETRC08(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPRETRC08(DOSSIER)
Value Char DOSSIER

# Issue 108760 by TS
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Call ECR_TIME("UUMGPRETRC08 Sales Order Process : Update BPSUPPLIER") From DOSSUB
Call ECR_TRACE("UUMGPRETRC08 : Process Start on : "+DOSSIER,0) From GESECRAN
Local Integer COMPTEUR
Local Integer ERR

#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPRETRC08 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
# Passage en V6
If val(VERSION)<GMIGX3VER60
  # Mise à jour des champs par boucle de lecture de la table et maj

  # ----------------------------------------
  # 1- ajouter les colonnes dans la table BPS
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_V6
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"BPSUPPLIER",ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Endif


$FIN
Call ECR_TIME("UUMGPRETRC08 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
End

########################################################################

$ADDCOLV6
# 1- ajouter les colonnes dans la table BPS
# ----------------------------------------

# Ajout des champs
# ----------------
# Ajout du champ BPAPAY : Adresse tiers payé
Call MIGADDCOL (DOSSIER,"BPSUPPLIER","BPAPAY","A",5,1,ERR) From TRTMIG
If ERR : Goto FIN : Endif
# Ajout du champ BPAINV : Adresse client facture
Call MIGADDCOL (DOSSIER,"BPSUPPLIER","BPAINV","A",5,1,ERR) From TRTMIG
If ERR : Goto FIN : Endif
# Ajout du champ BPSRSK : Tiers risque
Call MIGADDCOL (DOSSIER,"BPSUPPLIER","BPSRSK","BPR",0,1,ERR) From TRTMIG
If ERR : Goto FIN : Endif
# Ajout du champ CUR : Devise
Call MIGADDCOL (DOSSIER,"BPSUPPLIER","CUR","CUR",0,1,ERR) From TRTMIG
If ERR : Goto FIN : Endif
# Ajout du champ CNTNAM : Contact par defaut
Call MIGADDCOL (DOSSIER,"BPSUPPLIER","CNTNAM","NAM",0,1,ERR) From TRTMIG
If ERR : Goto FIN : Endif
# Ajout du champ BPAADD : Adresse par defaut
Call MIGINDCRE (DOSSIER,"BPSUPPLIER","","BPAADD","A",5,ERR) From TRTMIG
If ERR : Goto FIN : Endif

Return
########################################################################
$TRT_X3_V6
# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:BPS]) : Close File [BPS] : Endif
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"  [BPS]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif


#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2, ACLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPS
Raz NB
If STOP=1
 STOP = 0
 CRITERE  = "[F:BPS]BPSNUM>ACLE1 "
Else
 CRITERE  = "1=1"
Endif

Trbegin [BPS]
GOK = 1

For [BPS]BPS0 Where evalue(CRITERE)

  # --- alimentation des champs
  Gosub RECUP_BPR

  Rewrite [F:BPS]
  If fstat
    Call ECR_TRACE("File BPSUPPLIER(BPSNUM)"-[F:BPS]BPSNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:BPS]BPSNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_BPS
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_BPS
  Endif
Endif


Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPS], [BPR]

Return

########################################################################
$RECUP_BPR

      If [F:BPS]BPRPAY=""  [F:BPS]BPRPAY=[F:BPS]BPSNUM : Endif
      If [F:BPS]BPSINV=""  [F:BPS]BPSINV=[F:BPS]BPSNUM : Endif
      If [F:BPS]BPAPAY=""
        If [F:BPR]BPRNUM<>[F:BPS]BPRPAY
          Read [BPR] BPR0=[F:BPS]BPRPAY : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:BPS]BPAPAY=[F:BPR]BPAADD
      Endif
      If [F:BPS]BPAINV=""
        If [F:BPR]BPRNUM<>[F:BPS]BPSINV
          Read [BPR] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:BPS]BPAINV=[F:BPR]BPAADD
      Endif
      If [F:BPS]CUR="" | [F:BPS]BPAADD="" | [F:BPS]CNTNAM=""
        If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
          Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        If [F:BPS]CUR=""    [F:BPS]CUR   =[F:BPR]CUR    : Endif
        If [F:BPS]BPAADD="" [F:BPS]BPAADD=[F:BPR]BPAADD : Endif
        If [F:BPS]CNTNAM="" [F:BPS]CNTNAM=[F:BPR]CNTNAM : Endif
      Endif
      If [F:BPS]BPSRSK=""
        If dim(GINIBPRRSK)<=0
          [F:BPS]BPSRSK=[F:BPS]BPSINV
        Else
          Case GINIBPRRSK
            When 1       : [F:BPS]BPSRSK=[F:BPS]BPSINV
            When 2       : [F:BPS]BPSRSK=[F:BPS]BPRPAY
            When 3       : [F:BPS]BPSRSK=[F:BPS]BPSGRU
            When Default : [F:BPS]BPSRSK=[F:BPS]BPSINV
          Endcase
        Endif
      Endif
Return

