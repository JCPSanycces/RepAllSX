#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR03   Migration des Commandes                    Module Achats#
#                Commandes ouvertes                                      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR03") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR03(DOSSIER)
  Call MAJ_UUMGTRTPUR03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR03(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif
# Issue 112622 - 2015-11-19 by SR
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
# End issue 112622

Local Char WNAMPOHM,WNAMPOPM,WNAMPOQM,WNAMPOCM
Call MIGTABNAME (DOSSIER,"PORDER",WNAMPOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERP",WNAMPOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERQ",WNAMPOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERC",WNAMPOCM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPOHM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPOPM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPOQM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPOCM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
Local File =DOSSIER+".PORDER"    [POH]
Local File =DOSSIER+".PORDERP"    [POP]
Local File =DOSSIER+".PORDERQ"    [POQ]
Local File =DOSSIER+".PORDERC"    [POC]
Local File =DOSSIER+".CPTANALIN"   [CAL]
Local File =DOSSIER+".PVCRVAT"    [PVV]
Local File =DOSSIER+".PVCRFOOT"   [PVF]

Onerrgo ERR_SQL
Trbegin [POH]
REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDER WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [POP]
REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDERP WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [POQ]
REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDERQ WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Call MIGTABRAZ (DOSSIER,"PORDERC",ERR) From TRTMIG

# Issue 112622 - 2015-11-19 by SR
If val(VERSION)<GMIGX3VER60
  Onerrgo ERR_SQL
  Trbegin [CAL]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='POP' AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER WHERE CPTANALIN.VCRNUM_0=PORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit

  Onerrgo ERR_SQL
  Trbegin [PVF]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".PVCRFOOT WHERE VCRTYP_0=5 AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER WHERE PVCRFOOT.VCRNUM_0=PORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit
Endif
# End issue 112622


##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR03",ERR) From TRTMIG

End
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
ERR=1
Resume

##########################################################################
Subprog MAJ_UUMGTRTPUR03(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPOHM,WNAMPOPM,WNAMPOQM,WNAMPOCM
Call MIGTABNAME (DOSSIER,"PORDER",WNAMPOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERP",WNAMPOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERQ",WNAMPOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERC",WNAMPOCM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPOHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPOPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPOQM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPOCM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_POH (100) (adxwrb)
Local Char WTAB_POP (100) (adxwrb)
Local Char WTAB_POQ (100) (adxwrb)
Local Char WTAB_POC (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_POH,WCPT_POP,WCPT_POQ,WCPT_POC,WCPT_PVF,WCPT_CAL

Call ECR_TIME("UUMGTRTPUR03 Purchase Orders Contracts Process : Update PORDER-C-P-Q") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR03 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PORDERQ",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PORDERC",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:POH])  = 0 : Local File =DOSSIER+".PORDER"    [POH]  : Endif   # Fichier X3 "Vide"
If clalev([F:POP])  = 0 : Local File =DOSSIER+".PORDERP"    [POP]  : Endif   # Fichier X3 "Vide"
If clalev([F:POQ])  = 0 : Local File =DOSSIER+".PORDERQ"    [POQ]  : Endif   # Fichier X3 "Vide"
If clalev([F:POC])  = 0 : Local File =DOSSIER+".PORDERC"    [POC]  : Endif   # Fichier X3 "Vide"

If clalev([F:POHM]) = 0 : Local File =DOSSIER+"."+WNAMPOHM   [POHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:POPM]) = 0 : Local File =DOSSIER+"."+WNAMPOPM   [POPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:POQM]) = 0 : Local File =DOSSIER+"."+WNAMPOQM   [POQM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:POCM]) = 0 : Local File =DOSSIER+"."+WNAMPOCM   [POCM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)

Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_POH From UUMGTRTPUR00
# Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
Gosub OUVRE_PUR02 From UUMGTRTPUR02

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [POHM] With [BPS]BPS0=[F:POHM]BPSNUM As [LNK]
&    Order By Key CLE = [F:POHM]POHTYP;[F:POHM]POHFCY;[F:POHM]POHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_POC00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:POHM]POHTYP=2 & [F:POHM]POHFCY=TABMIGKEY(2) & [F:POHM]POHNUM>TABMIGKEY(3)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:POHM]POHTYP=2 & [F:POHM]POHFCY>TABMIGKEY(2)"
Else
 CRITERE = "[F:POHM]POHTYP=2 "
Endif

Trbegin [POH],[POP], [POQ], [POC]
GOK = 1

For [LNK]CLE(3) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEPOC : Endif
  Endif

#  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_POH From UUMGTRTPUR02
  Endif
#  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
     Gosub RAZV7_POH  From UUMGTRTPUR02
  Endif
  [F:POH] = [F:POHM]

  If WSITE<>[F:POH]POHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:POH]POHFCY) From TRTX3CPT
      WSITE=[F:POH]POHFCY
  Endif

  [F:POH]CPY=GSOCIETE
  #  version < V6, raz des champs v6
  # Issue 111478 - 2015-10-08 by SR
  # If val(VERSION)<GMIGX3VER70
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AVPOH From UUMGTRTPUR02
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AVPOH From UUMGTRTPUR02
    If GOK<1 : Break : Endif
  Endif

  [F:TB0]=[F:POH]
  ############################
  #-- Boucle sur les lignes
  ############################
  Link [POCM] With [ITM]ITM0=[F:POCM]ITMREF As [LNKC]
  For [LNKC]POC0 Where POHNUM=[F:POH]POHNUM
    #rupture par ligne de facture
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_POC
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
    # Issue 96845 - 2014-02-07 by SR : rien en V7
#       Gosub RAZV7_POC
    Endif
   # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_POC
    Endif
    [F:POC] = [F:POCM]

    #Appel proc de migration sur detail
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_POC
      If GOK<1 : Break : Endif
    Endif
#    # Issue 112754 - 2017-01-27 by SR :Inutile en migration en v12
#    #  version < V7, traitement v7
#    If val(VERSION)<GMIGX3VER70
#    # Issue 111289 - 2015-09-25 by SR : Copier à minima POPM dan POP
#    # Issue 96845 - 2014-02-07 by SR : rien en V7
#     Gosub MAJV7_POC
#     If GOK<1 : Break : Endif
#     # End issue 111289
#    Endif
   #  version < V12, traitement v12 : Copier à minima POPM dan POP
    If val(VERSION)<GMIGX3VER120
       Gosub MAJV12_POC
       If GOK<1 : Break : Endif
    Endif
    # End issue 112754
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#   If NEWMOTEUR
#        Gosub POC_STK : # pour stocker ref
#        WriteB [POC]
#    Else
#        Write [POC]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
#          Gosub POC_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PORDERC(POHNUM/POPLIN)"-[F:POC]POHNUM-num$([F:POC]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub POC_STK : # pour stocker ref
     WriteB [POC]
     If fstat
        Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub POC_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next
  If GOK<1 : Break : Endif
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:POP]
    If fstat
        Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub POP_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
        GOK=0
    Endif
# Endif
 # End issue 108760
  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete
  #  version < V7, traitement v7
  # Issue 112754 - 2017-01-26 by SR : Services
  If val(VERSION)<GMIGX3VER120
    Gosub MAJ_POH From UUMGTRTPUR02
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub POH_STK From UUMGTRTPUR02 : # pour stocker ref
#      WriteB [F:POH]
#  Else
#      Write [F:POH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
#      Gosub POH_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PORDER(POHNUM)"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub POH_STK From UUMGTRTPUR02 : # pour stocker ref
   WriteB [F:POH]
  If fstat
     Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
     Gosub POH_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
     GOK=0 : Break
  Endif
  # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:POHM]POHTYP)
    TABMIGKEY(2) = [F:POHM]POHFCY
    TABMIGKEY(3) = [F:POHM]POHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLEPOC
Next

$FIN_BOUCLEPOC
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR03",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:POH]
    If fstat
        Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub POH_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
    Flush [F:POP]
    If fstat
        Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub POP_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
    Flush [F:POQ]
    If fstat
        Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub POQ_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
    Flush [F:POC]
    If fstat
        Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub POC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOC : #on part sur rollback
    Endif
 # Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEPOC
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR03",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_POC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Filter [POHM]

Close Local File [POH], [POP], [POQ], [POC]
Close Local File [POHM], [POPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PORDER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PORDERQ",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PORDERC",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR03") From TRTMIG
Call ECR_TIME("UUMGTRTPUR03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$POC_STK
Call STK (WTAB_POC,WCPT_POC,[F:POC]POHNUM-'/'-num$([F:POC]POPLIN)) From TRTMIG
Return
##############################################################################################
$POC_ERRTRA
Call ERRTRA (WTAB_POC,WCPT_POC,"File PORDERC(POHNUM/POPLIN)=") From TRTMIG
Return

##############################################################################################
$RAZV6_POC
Raz [F:POC]COA
Raz [F:POC]CPY
Raz [F:POC]EECICT2
Raz [F:POC]EECLOC2
Raz [F:POC]EECNUM2
Raz [F:POC]FFWADD2
Raz [F:POC]FFWNUM2
Raz [F:POC]ICTCTY2
Raz [F:POC]LINACC
Raz [F:POC]LINPURTYP
Return
##############################################################################################
$RAZV7_POC
# Issue 96602 - 2014-02-07 by SR : rien en V7
Return
################################################
# Issue 112754 - 2016-12-19 by SR : Services en V12
$RAZV12_POC
Raz [F:POC]ITMKND
Return

##############################################################################################
$MAJV6_POC
        WPOPLIN=[F:POC]POPLIN
        #----- Chargement de la société -----#
        [F:POC]CPY=[F:POH]CPY
        #----- Chargement comptes et type d'achat -----#
        If [F:POC]COA(0)="" & [F:POC]LINACC(0)="" & [F:POC]COA(1)="" & [F:POC]LINACC(1)=""
          [F:TB1]=[F:POH]
          [F:TB1]=[F:POC]
          [F:TB1]LINPURTYP=max([F:POC]LINPURTYP,1)
          #-----
          If dim([F:POQM]LINACC)>0
            Filter [POQM] Where POHNUM=[F:POH]POHNUM & POPLIN=WPOPLIN & (LINACC<>"" | LINCNA<>"")
          Else
            Filter [POQM] Where POHNUM=[F:POH]POHNUM & POPLIN=WPOPLIN
          Endif
          Read [POQM] POQ0 First
          If fstat
            Raz [F:POQM]
          Else
            [F:TB1]=[F:POQM]
          Endif
          Filter [POQM]
          #-----
          If dim([F:POQM]LINACC)>0 & ([F:POQM]LINACC<>"" | [F:POQM]LINCNA<>"")
            Raz TPLAN, TCOMPTE
            TPLAN(1)  =GCOA(1)
            TCOMPTE(1)=[F:POQM]LINACC
            TPLAN(2)  =GCOA(2)
            TCOMPTE(2)=[F:POQM]LINCNA
            TPLAN(3)  =GCOA(3)
            WPURTYP   =max([F:POQM]LINPURTYP,1)
          Else
            #----- Chargement table liée PORDERP pour la pièce auto PORD -----#
            Read [POPM] POP0(2)=[F:POH]POHNUM;WPOPLIN
            If fstat
              Raz [F:POPM]
            Endif
            [G:POPM]currind=1 : [G:POPM]currlen=0 : # Réinitialisation clé par défaut
            If [F:POPM]POHNUM=""
              [F:POPM]=[F:POH]
              [F:POPM]=[F:POC]
              Gosub LECT_ITMPOC
              For I=0 To dim([F:POPM]TSICOD)-1
                [F:POPM]TSICOD(I)=[F:ITM]TSICOD(I)
              Next I
              Gosub ALIVATCOD
            Endif
            #----- Chargement table liée CPTANALIN pour la pièce auto PORD -----#
            Raz [F:TB2]
            [F:TB2]ABRFIC="POP"
            [F:TB2]VCRNUM=[F:POH]POHNUM
            [F:TB2]VCRLIN=WPOPLIN
            [F:TB2]VCRSEQ=[F:POPM]POPSEQ
            [F:TB2]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:TB2]LED(I-1)=GLEDSOC(I)
              [F:TB2]COA(I-1)=GCOA(I)
              [F:TB2]ACC(I-1)=""
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:TB2]DIE(I-1)=GDIE(I)
              Case I
              When 1 : [F:TB2]CCE(I-1)=[F:POPM]CCE1
              When 2 : [F:TB2]CCE(I-1)=[F:POPM]CCE2
              When 3 : [F:TB2]CCE(I-1)=[F:POPM]CCE3
              When 4 : [F:TB2]CCE(I-1)=[F:POPM]CCE4
              When 5 : [F:TB2]CCE(I-1)=[F:POPM]CCE5
              When 6 : [F:TB2]CCE(I-1)=[F:POPM]CCE6
              When 7 : [F:TB2]CCE(I-1)=[F:POPM]CCE7
              When 8 : [F:TB2]CCE(I-1)=[F:POPM]CCE8
              When 9 : [F:TB2]CCE(I-1)=[F:POPM]CCE9
              When Default
              Endcase
            Next I
            #----- Recherche comptes et type d'achat -----#
            Raz ID1,ID2
            #Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
            #If STAT
            #  Raz TPLAN, TCOMPTE
            #  WPURTYP=1
            #Else
            #  If [F:GAC]COA<>TPLAN(1) | [F:GAC]ACC<>TCOMPTE(1)
            #    Read [GAC] GAC0=TPLAN(1);TCOMPTE(1) : If fstat  Raz [F:GAC] : Endif
            #  Endif
            #  If [F:GAC]VATIPT=5
            #    WPURTYP=3
            #  Elsif [F:GAC]VATIPT=4
            #    WPURTYP=2
            #  Else
            #    WPURTYP=1
            #  Endif
            #Endif
            Raz TPLAN, TCOMPTE : WPURTYP=1
          Endif
          #-----
          Raz [F:POC]COA, [F:POC]LINACC
          For I=1 To 10
            If TPLAN(I)<>""
              J=find(TPLAN(I),GCOA(1..GNBCOA))
              If J
                [F:POC]COA(J-1)   =GCOA(J)
                [F:POC]LINACC(J-1)=TCOMPTE(I)
              Endif
            Endif
          Next I
          [F:POC]LINPURTYP=WPURTYP
        Endif
        #----- Chargement des informations douanières -----#
        If [F:POC]EECICT2=""  [F:POC]EECICT2=[L]WEECICT : Endif : # Incoterm
        If GACTDEB=2
          If [F:POC]EECLOC2=0 [F:POC]EECLOC2=[L]WEECLOC : Endif : # Lieu de transport CEE
          If [F:POC]EECNUM2=""
            Gosub LECT_BPRI From UUMGTRTPUR02
            [F:POC]EECNUM2=[F:BPR]EECNUM : # Identification CEE
          Endif
        Endif
        #---------Traitement des POP--------------#
        Gosub BOUCLE_POP
        If GOK<1 : Return : Endif
Return

# Issue 112754 - 2017-01-27 by SR : Inutile en migration v12
