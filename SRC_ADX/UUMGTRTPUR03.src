# Issue 112754 - 2016-12-19 by SR : Services en v12
########################################################################
$MAJV12_POC
[F:POC]ITMKND = 1
  # Si version < V6, la copie a déjà été faite pour passer en V6, donc on ne le refait pas
  # sinon, il faut au moins récupérer les enreg POP
  If val(VERSION) >= GMIGX3VER60 & val(VERSION) < GMIGX3VER120
     Gosub BOUCLE_POP
  Endif
Return
# End issue 112754

##############################################################################################
$BOUCLE_POP
  For [POPM] POP0 Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN
      #  version < V6, traitement v6
      If val(VERSION)<GMIGX3VER60
        Gosub RAZV6_POP From UUMGTRTPUR02
      Endif
      [F:POP] = [F:POPM]

      #Appel proc de migration sur detail
      #  version < V6, traitement v6
      If val(VERSION)<GMIGX3VER60
        Gosub MAJV6_POP From UUMGTRTPUR02
        If GOK<1 : Break : Endif
      # Issue 111289 - 2015-09-25 by SR :Endif décalé
      #Endif
        #----- Création lignes comptables analytiques pour commandes ouvertes -----#
        Gosub WRITE_CAL_POC
        If GOK<1 : Break : Endif
      Endif
      # Issue 111289 - 2015-09-25 by SR

      # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#      If NEWMOTEUR
#          Gosub POP_STK From UUMGTRTPUR02 : # pour stocker ref
#          WriteB [POP]
#      Else
#          Write [POP]
#      Endif
#      If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
#            Gosub POP_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
#          Else
#            Call ECR_TRACE("File PORDERP(POHNUM/POPLIN/POPSEQ)="-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#          Endif
#          GOK=0 : Break
#      Endif
       Gosub POP_STK From UUMGTRTPUR02 : # pour stocker ref
       WriteB [POP]
       If fstat
          Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
          Gosub POP_ERRTRA From UUMGTRTPUR02 : # pour afficher les ref
          GOK=0 : Break
       Endif
       # End issue 108760
  Next
Return

$WRITE_CAL_POC
  Raz [F:CAL]
  [F:CAL]ABRFIC="POP"
  [F:CAL]VCRNUM=[F:POP]POHNUM
  [F:CAL]VCRLIN=[F:POP]POPLIN
  [F:CAL]VCRSEQ=[F:POP]POPSEQ
  [F:CAL]ANALIG=1
  For I=1 To max(GNBCOA,2)
    [F:CAL]LED(I-1)=GLEDSOC(I)
    [F:CAL]COA(I-1)=GCOA(I)
    [F:CAL]ACC(I-1)=[F:POC]LINACC(I-1)
  Next I
  For I=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(I-1)=GDIE(I)
    ###If evalue("dim([F:POPM]CCE"+num$(I)+")")>0
    ###  [F:CAL]CCE(I-1)=evalue("[F:POPM]CCE"+num$(I))
    ###Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:POPM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:POPM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:POPM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:POPM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:POPM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:POPM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:POPM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:POPM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:POPM]CCE9
    When Default
    Endcase
  Next I

  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#      WriteB [F:CAL]
#  Else
#      Write [F:CAL]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#    Call ECR_TRACE("File CPTANALIN POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#  Endif
   Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
   WriteB [F:CAL]
   If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
      GOK=0 : Return
  Endif
  # End issue 108760

Return
#############################################
# Alimentation des codes taxes dans [F:POP] #
#############################################
$ALIVATCOD
    If [F:ITM]VACITM(0)<>""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(0),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:POP]VAT(0)=WTVCVAT(WJTVC-1)
      Endif
    Endif
    If [F:ITM]VACITM(1)<>""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(1),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:POP]VAT(1)=WTVCVAT(WJTVC-1)
      Endif
    Endif
    If [F:ITM]VACITM(2)<> ""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(2),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:POP]VAT(2)=WTVCVAT(WJTVC-1)
      Endif
    Endif
Return

$LECT_ITMPOC
  If [F:ITM]ITMREF<>[F:POC]ITMREF
    WITM=[F:POC]ITMREF
    Gosub LECT_ITM From UUMGTRTPUR02
  Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR03(APPLI)
End

