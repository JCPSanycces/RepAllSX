      Endif
    Endif
  Endif
  Commit
  Call ECR_TIME("HDK activity codes update finished.") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
End

#######################################################################
#Mise à jour mosdule Support client
Subprog MAJHDK140V5(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRFLG
Local Integer IERRCOUNT

  IERRFLG = 0
  IERRCOUNT = 0
  #Appels des différentes moulinettes successives
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Start HDK Migration 140 to V5 ") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 1
  #
  # Transfert données table CRMTRS vers HDKTRS 
  # 
  #
  #---------------------------------------------------#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("HDK Step 1 : Fill table HDKTRS from table CRMTRS.") From DOSSUB
  IERRFLG = 0
  Call HDKSTEP1(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("HDK Step 1 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("HDK Step 1 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
End

###########################################################################################
# transfert donneés de la table CRMTRS versla table HDKTRS
#
###########################################################################################
Subprog HDKSTEP1(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Date DTDATE
Local Integer IBREWRITE
Local Integer IINDICE

  Local File =SZAPPLI+".HDKTRS" [HTR]
  Local File =SZAPPLI+".CRMTRS" [CTR]
  Raz COMPTEUR, CLE1, STOP, WNBR
  Raz DTDATE
  IBREWRITE=0
  IINDICE=0
  $BOUCLE_HDKSTEP1
  If STOP=1
    CRITERE = 'CTRNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [HTR]
  For [CTR] CTR0 Where evalue(CRITERE)
    Readlock [CTR] Curr
    If fstat
      Call ECR_TRACE("File CRMTRS"-[F:CTR]CTRNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      Read [HTR] HTR0=[F:CTR]CTRTYP;[F:CTR]CTRNUM
      If fstat=0
        IBREWRITE=1
      Else
        Raz [F:HTR]
        IBREWRITE=0
      Endif
      [F:HTR]=[F:CTR]
      [F:HTR]HTRNUM=[F:CTR]CTRNUM
      [F:HTR]HTRTYP=[F:CTR]CTRTYP
      [F:HTR]HTRDES=[F:CTR]CTRDES
      [F:HTR]HTRNUM=[F:CTR]CTRNUM
      If IBREWRITE = 0
        Write [HTR]
      Else
        Rewrite [HTR]
      Endif
      If fstat
        Call ECR_TRACE("File HTRNUM"-[F:HTR]HTRNUM+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS 
      CLE1=[F:CTR]CTRNUM
      STOP=1 
      Break 
    Endif
  Next
  Commit
  If STOP 
    Goto BOUCLE_HDKSTEP1
  Endif
  Close Local File [HTR]
  Close Local File [CTR]
End

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
#                ACTION COMMERCIALE
#######################################################################
Subprog MAJCRMAMAJ140V5  (DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

  Local File =DOSSIER+".ACODNUM"  [ANM]
  Local File =DOSSIER+".TABCOUAFF"  [TCA]
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM : Update sequence number") From DOSSUB
  Look [ANM] ANM0="SYD"
  If fstat <>0
    Call COPOBJ(DOSREF,DOSSIER ,"ANM","SYD","","","") From ACOPIE  : # Création du compteur SYD
    Call ECR_TRACE("CRM : Sequence number SYD copied",0) From GESECRAN
  Endif
  Look [ANM] ANM0="SYL"
  If fstat <>0
    Call COPOBJ(DOSREF,DOSSIER ,"ANM","SYL","","","") From ACOPIE  : # Création du compteur SYL
    Call ECR_TRACE("CRM : Sequence number SYL copied",0) From GESECRAN
  Endif
  Look [ANM] ANM0="CRC"
  If fstat <>0
    Call COPOBJ(DOSREF,DOSSIER ,"ANM","CRC","","","") From ACOPIE  : # Création du compteur CRC
    Call ECR_TRACE("CRM : Sequence number CRC copied",0) From GESECRAN
  Endif
  Look [ANM] ANM0="COR"
  If fstat <>0
    Call COPOBJ(DOSREF,DOSSIER ,"ANM","COR","","","") From ACOPIE  : # Création du compteur COR
    Call ECR_TRACE("CRM : Sequence number COR copied",0) From GESECRAN
  Endif
  # FGR 18/07/2008 : X3SUIVI47694 Le pb n'était pas où on l'a cru au début !
  #Trbegin [TCA]
  Read [TCA]TCA0=13
  If fstat
    Call ECR_TRACE("File TABCOUAFF-(a)-[F:TCA]MODULE=13, Error ="-num$(fstat),1) From GESECRAN
  Else
    # FGR 18/07/2008 : X3SUIVI47694 Le pb n'était pas où on l'a cru au début !
    Trbegin [TCA]
    Read [TCA]TCA0=13
    #
    If [F:TCA]CODNUM(8)=""
      [F:TCA]CODNUM(8)="SYD"
      [F:TCA]MANCOU(8)=1
    Endif
    If [F:TCA]CODNUM(9)=""
      [F:TCA]CODNUM(9)="SYL"
      [F:TCA]MANCOU(9)=1
    Endif
    If [F:TCA]CODNUM(10)=""
      [F:TCA]CODNUM(10)="CRC"
      [F:TCA]MANCOU(10)=1
    Endif
    If [F:TCA]CODNUM(11)=""
      [F:TCA]CODNUM(11)="COR"
      [F:TCA]MANCOU(11)=1
    Endif
    Rewrite [TCA]
    If fstat=0
      Commit
      Call ECR_TRACE("CRM : Sequence number assignement updated",0) From GESECRAN
    Else
      Call ECR_TRACE("File TABCOUAFF-(b)-Rewrite [F:TCA]MODULE=13, Error ="-num$(fstat),1) From GESECRAN
      Rollback
    Endif
  Endif
  Close Local File [ANM]
  Close Local File [TCA]
End

#######################################################################
#Mise à jour des codes activités
Subprog MAJCRMACT140V5 (SZAPPLI)
Value Char SZAPPLI

# FGR 03/06/2008 : X3SUIVI47694 : paramètre declaré 2 fois !
#Value Char SZAPPLI

  # FGR 03/06/2008 : X3SUIVI47694 : MB préconise d'ouvrir ADOSACT sans préciser de nombre d'appli
  #Local File =GDOSX3+".ADOSACT" [ADA]
  Local File ADOSACT [ADA]
  Local File =SZAPPLI+".AMSK" [AMK]

  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Activity codes update start.") From DOSSUB
 
  Call DEBTRANS From GLOCK
  Trbegin [ADA]
  #---------------------------------------------------#
  #BAA : Nb appels agenda Action co  (999)   CRMAGD2-1
  Call ECR_TIME("BAA : Nb appels agenda Action co  (999)   CRMAGD2-1") From DOSSUB
  Read [ADA] ADA0=SZAPPLI;"BAA"
  If fstat = 0 Then
    If [F:ADA]DIME = 0 Then
      [F:ADA]DIME = 999
      Read [AMK]CODMSK="CRMAGD2"
      If fstat = 0 Then
        If [F:AMK]NBLIGT(1) <> 0 Then
          [F:ADA]DIME=[F:AMK]NBLIGT(1)
        Endif
      Endif
      Rewrite [ADA]
      If fstat <> 0 Then
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
