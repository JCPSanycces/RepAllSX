#######################################################################
#Mise à jour mosdule action commerciale
Subprog MAJCRM140V5(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRFLG
Local Integer IERRCOUNT

  IERRFLG = 0
  IERRCOUNT = 0
  #Appels des différentes moulinettes successives
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Start CRM Migration 140 to V5 ") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 1
  #
  # Mettre à jour le nouveau champ USEQUR des Liste des sélections marketing. 
  # Le mettre à 2 si CNTTTR vide 1 sinon 
  #
  #---------------------------------------------------#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 1 : Fill USEQUR field from SELCMG table.") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP1(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 1 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 1 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 2
  # Mise à jour de la table OPPOR
  #    alimentation des champs OPPORI, OPPORITYP
  #
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 2 : Update table OPPOR") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP2(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 2 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 2  : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 3
  # Mise à jour de la table TASK
  #    alimentation des champs TSKORI, TSKORITYP
  #
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 3 : Update table TASK") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP3(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 3 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 3 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 4
  # Mise à jour de la table CONTACTCRM
  #    alimentation des champs CNTTYP
  #
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 4 : Update table CONTACTCRM") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP4(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 4 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 4 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 5
  # Mise à jour de la table PHONECALL
  #    alimentation des champs CLLORI, CLLORITYP
  #
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 5 : Update table PHONECALL") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP5(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 5 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 5 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 6
  # Mise à jour de la table BAPPOINT
  #    alimentation des champs APTORI, APTORITYP
  #
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("CRM Step 6 : Update table BAPPOINT") From DOSSUB
  IERRFLG = 0
  Call CRMSTEP6(SZAPPLI, IERRFLG)
  If IERRFLG
    Call ECR_TIME("CRM Step 6 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("CRM Step 6 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
End

###########################################################################################
# Mettre à jour le nouveau champ USEQUR des Liste des sélections marketing. 
# Le mettre à 2 si CNTTTR vide 1 sinon 
###########################################################################################
Subprog CRMSTEP1(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)

  If !clalev([F:SEC]) : Local File =SZAPPLI+".SELCMG" [SEC] : Endif
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [SEC] Where [F:SEC]OPGNUM> SZCLE Order By [F:SEC]OPGNUM Asc
    For [SEC]
      SZCLE = [F:SEC]OPGNUM
      If IPERF = 0
        Trbegin [SEC]
        INTR = 1
      Endif
      If [F:SEC]CNTTTR = ""
        [F:SEC]USEQUR = 2
      Else
        [F:SEC]USEQUR = 1
      Endif
      Rewrite [SEC]
      If fstat
        IERR = 1
        SZMESS = "Error while setting the USEQUR field value for the operation code n°" + [F:SEC]OPGNUM
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("CRM Step 1 failed.") From DOSSUB
        Rollback
        INTR = 0
        Break
      Else
        If IPERF >= 478
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT : Break : Endif
    Next
    Filter [SEC]
    If IERR
      Break
    Endif
  Wend
  If INTR
    If !IERR
      Commit
    Endif
  Endif
End

###########################################################################################
# Mise à jour de la table OPPOR
#    alimentation des champs OPPORI, OPPORITYP
###########################################################################################
Subprog CRMSTEP2(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Date DTDATE
Local Integer IINDICE

  Local File =SZAPPLI+".OPPOR"  [OPP]
  Raz COMPTEUR, CLE1, STOP, WNBR
  Raz DTDATE
  IINDICE=0
  $BOUCLE_CRMSTEP2
  If STOP=1
    CRITERE = 'OPPNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [OPP]
  For [OPP] OPP0 Where evalue(CRITERE)
    Readlock [OPP] Curr
    If fstat
      Call ECR_TRACE("File OPPNUM"-[F:OPP]OPPNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      If [F:OPP]OPPORI=0
        [F:OPP]OPPORI=1
      Endif
      [F:OPP]OPPORITYP=1
      If [F:OPP]OPPSRENUM<>""
        [F:OPP]OPPORITYP=2 #Généré
        [F:OPP]OPPORI=6     #Demande de service
        [F:OPP]OPPORIVCR=[F:OPP]OPPSRENUM
      Else
        If [F:OPP]OPPOPGNUM<>""
          If [F:OPP]OPPOPGTYP<>""
            Case [F:OPP]OPPOPGTYP    
              When "OMM"
                [F:OPP]OPPORI=2
                [F:OPP]OPPORIVCR=[F:OPP]OPPOPGNUM
                [F:OPP]OPPORITYP=1
              When "OMP"
                [F:OPP]OPPORI=3
                [F:OPP]OPPORIVCR=[F:OPP]OPPOPGNUM
                [F:OPP]OPPORITYP=1
              When "OMT"
                [F:OPP]OPPORI=4
                [F:OPP]OPPORIVCR=[F:OPP]OPPOPGNUM
                [F:OPP]OPPORITYP=1
              When "OMN"
                [F:OPP]OPPORI=5
                [F:OPP]OPPORIVCR=[F:OPP]OPPOPGNUM
                [F:OPP]OPPORITYP=1
            Endcase
          Endif
        Else
          If [F:OPP]OPPCMGNUM<>""
            [F:OPP]OPPORI=7
            [F:OPP]OPPORIVCR=[F:OPP]OPPCMGNUM
            [F:OPP]OPPORITYP=1
          Endif
        Endif
      Endif
      IINDICE=0
      DTDATE=[00/00/00]
      While IINDICE<dim([F:OPP]ENDDAT)
        If [F:OPP]ENDDAT(IINDICE)<>[00/00/00]
          If DTDATE=[00/00/00]
            DTDATE=[F:OPP]ENDDAT(IINDICE)
          Else
            If [F:OPP]ENDDAT(IINDICE)<DTDATE
              DTDATE=[F:OPP]ENDDAT(IINDICE)
            Endif
          Endif
        Endif
        IINDICE= IINDICE+1
      Wend
      IINDICE=0
      While IINDICE<dim([F:OPP]ENDDATX)
        If [F:OPP]ENDDATX(IINDICE)<>[00/00/00]
          If DTDATE=[00/00/00]
            DTDATE=[F:OPP]ENDDATX(IINDICE)
          Else
            If [F:OPP]ENDDAT(IINDICE)<DTDATE
              DTDATE=[F:OPP]ENDDATX(IINDICE)
            Endif
          Endif
        Endif
        IINDICE= IINDICE+1
      Wend
      [F:OPP]OPPDATOPN=DTDATE
      Rewrite [OPP]
      If fstat
        Call ECR_TRACE("File OPPNUM"-[F:OPP]OPPNUM+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS 
      CLE1=[F:OPP]OPPNUM
      STOP=1 
      Break 
    Endif
  Next
  Commit
  If STOP 
    Goto BOUCLE_CRMSTEP2
  Endif
  Close Local File [OPP]
End

###########################################################################################
# Mise à jour de la table TASK
#    alimentation des champs TSKORI, TSKORITYP
###########################################################################################
Subprog CRMSTEP3(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI+".TASK"  [TSK]
  Raz COMPTEUR, CLE1, STOP, WNBR
  $BOUCLE_CRMSTEP3
  If STOP=1
    CRITERE = 'TSKNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [TSK]
  For [TSK] TSK0 Where evalue(CRITERE)
    Readlock [TSK] Curr
    If fstat
      Call ECR_TRACE("File TASK"-[F:TSK]TSKNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      If [F:TSK]TSKORI=0
        [F:TSK]TSKORI=1
      Endif
      If [F:TSK]TSKORI=2
        [F:TSK]TSKORITYP=2
      Else
        [F:TSK]TSKORITYP=1
      Endif
      Rewrite [TSK]
      If fstat
        Call ECR_TRACE("File TASK"-[F:TSK]TSKNUM+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS 
      CLE1=[F:TSK]TSKNUM
      STOP=1 
      Break 
    Endif
  Next
  Commit
  If STOP 
    Goto BOUCLE_CRMSTEP3
  Endif
  Close Local File [TSK]
End

###########################################################################################
# Mise à jour de la table CONTACTCRM
#    alimentation des champs CNTTYP
###########################################################################################
Subprog CRMSTEP4(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI+".CONTACTCRM"  [AIN]
  Raz COMPTEUR, CLE1, STOP, WNBR
  $BOUCLE_CRMSTEP4
  If STOP=1
    CRITERE = 'CNTNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [AIN]
  #LSE FQ42486
  Filter [AIN] Where evalue(CRITERE) Order By CNTNUM Asc
  For [AIN]
    #  For [AIN] AIN0 Where evalue(CRITERE)
    #    Readlock [AIN] Curr
    #    If fstat
    #      Call ECR_TRACE("File CONTACTCRM"-[F:AIN]CNTNUM+", Error ="-num$(fstat),1) From GESECRAN
    #    Else
    If [F:AIN]CNTTYP=0
      [F:AIN]CNTTYP=1
    Endif
    Rewrite [AIN]
    If fstat
      Call ECR_TRACE("File CONTACTCRM"-[F:AIN]CNTNUM+"0, Error ="-num$(fstat),1) From GESECRAN
    Endif
    #    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:AIN]CNTNUM
      STOP=1 
      Break 
    Endif
  Next
  Filter [AIN]
  Commit
  If STOP 
    Goto BOUCLE_CRMSTEP4
  Endif
  Close Local File [AIN]
End

###########################################################################################
# Mise à jour de la table PHONECALL
#    alimentation des champs CLLORI, CLLORITYP
###########################################################################################
Subprog CRMSTEP5(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI+".PHONECALL"  [CLL]
  Raz COMPTEUR, CLE1, STOP, WNBR
  $BOUCLE_CRMSTEP5
  If STOP=1
    CRITERE = 'CLLNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [CLL]
  For [CLL] CLL0 Where evalue(CRITERE)
    Readlock [CLL] Curr
    If fstat
      Call ECR_TRACE("File PHONECALL"-[F:CLL]CLLNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      If [F:CLL]CLLORI=0
        [F:CLL]CLLORI=1
      Endif
      If [F:CLL]CLLORI=2  or [F:CLL]CLLORI=3
        [F:CLL]CLLORITYP=2
      Else
        [F:CLL]CLLORITYP=1
      Endif
      If [F:CLL]CLLDATX=[00/00/00]
        [F:CLL]CLLDATX=[F:CLL]CLLDAT
      Endif
      Rewrite [CLL]
      If fstat
        Call ECR_TRACE("File PHONECALL"-[F:CLL]CLLNUM+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS 
      CLE1=[F:CLL]CLLNUM
      STOP=1 
      Break 
    Endif
  Next
  Commit
  If STOP 
    Goto BOUCLE_CRMSTEP5
  Endif
  Close Local File [CLL]
End

###########################################################################################
# Mise à jour de la table BAPPOINT
#    alimentation des champs APTORI, APTORITYP
###########################################################################################
Subprog CRMSTEP6(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI+".BAPPOINT"  [BAP]
  Raz COMPTEUR, CLE1, STOP, WNBR
  $BOUCLE_CRMSTEP6
  If STOP=1
    CRITERE = 'APTNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [BAP]
  For [BAP] APP0 Where evalue(CRITERE)
    Readlock [BAP] Curr
    If fstat
      Call ECR_TRACE("File BAPPOINT"-[F:BAP]APTNUM+", Error ="-num$(fstat),1) From GESECRAN
      ##ctl-src    Call ECR_TRACE("File BAPPOINT"-[F:CLL]APTNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      If [F:BAP]APTORI=0
        [F:BAP]APTORI=1
      Endif
      If [F:BAP]APTORI=2  or [F:BAP]APTORI=3
        [F:BAP]APTORITYP=2
      Else
        [F:BAP]APTORITYP=1
      Endif
      If [F:BAP]APTDATX=[00/00/00]
        [F:BAP]APTDATX=[F:BAP]APTDAT
      Endif
      Rewrite [BAP]
      If fstat
        Call ECR_TRACE("File BAPPOINT"-[F:BAP]APTNUM+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS 
      CLE1=[F:BAP]APTNUM
      STOP=1 
      Break 
    Endif
  Next
  Commit
  If STOP 
    Goto BOUCLE_CRMSTEP6
  Endif
  Close Local File [BAP]
End

