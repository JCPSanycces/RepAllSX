#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Pour exécution hors intégration de patch
##########################################################################################################

Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER<>""
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Migration 140 to V5. CRM module") From LECFIC
    Call MAJHDKACT140V5 (DOSSIER)
    Call MAJHDK140V5(DOSSIER)
    Call MAJCRMACT140V5 (DOSSIER)
    Call MAJCRM140V5(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End
##########################################################################################################

##########################################################################################################
#                                                                                              
# Migration 140 vers V5 Module CRM        novembre 2006
#                                                                                                                   #
##########################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI="X3" : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI
  If fstat
    Raz [F:ADS]
    End
  Endif
  #Si Module Support client non actif. On ne fait rien.
  If [F:ADS]MODULE(11) = 2 
    Call MAJHDK140V5(APPLI)
  Endif
  #Si Module Action Co non actif. On ne fait rien.
  If [F:ADS]MODULE(12) = 2
    Call MAJCRM140V5(APPLI)
  Endif
End

#######################################################################
#Moulinette AVANT
#Module Support client
Subprog ACR1MAJV5

  Call MAJHDKAMAJ140V5 ([F:ADS]DOSSIER,[F:ADS]DOSREF)
  Call MAJHDKACT140V5 ([F:ADS]DOSSIER)
  Call MAJHDK140V5([F:ADS]DOSSIER)
  # FGR 21/12/2011 : X3SUIVI78240 : doit être fait AVANT en migration V140->V6
  Call MAJ_UTICRM005([F:ADS]DOSSIER) From UTICRM005
End

#######################################################################
#Moulinette AVANT
#Module Action commerciale
Subprog ACR2MAJV5

  Call MAJCRMAMAJ140V5 ([F:ADS]DOSSIER,[F:ADS]DOSREF)
  Call MAJCRMACT140V5 ([F:ADS]DOSSIER)
  Call MAJCRM140V5([F:ADS]DOSSIER)
End

#######################################################################
#Moulinette APRES
#Module Support client
Subprog CR1MAJV5

  # FGR 21/12/2011 : X3SUIVI78240 : doit être fait AVANT en migration V140->V6
  ## FGR 17/02/2008 : X3SUIVI52520
  #Call MAJ_UTICRM005([F:ADS]DOSSIER) From UTICRM005
End

#######################################################################
#Moulinette APRES
#Module Action commerciale
Subprog CR2MAJV5
End

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
#                SUPPORT CLIENT
#######################################################################
Subprog MAJHDKAMAJ140V5  (DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(10)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("HDK : Update objet CMH") From DOSSUB
  # FGR 16/11/2007 : X3SUIVI44151 Suite mail de LSE du 14/11/2007
  #                  Ajout de , "CMA", "CMI", "CMS", "HDK"
  Trbegin [AOL]
  For WOBJET = "CMH", "CMA", "CMI", "CMS", "HDK"
    Read [AOL]AOL0 = WOBJET
    If !fstat
      Read [AOL2]AOL0 = WOBJET
      If !fstat
        [F:AOL] = [F:AOL2]
        Rewrite [AOL]
        If fstat <> 0
          Call ECR_TRACE("objet "+WOBJET+" +Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
  Next WOBJET
  Commit
  Close Local File [AOL], [AOL2]
End

#######################################################################
#Mise à jour des codes activités
Subprog MAJHDKACT140V5 (SZAPPLI)
Value Char SZAPPLI

  # FGR 03/06/2008 : X3SUIVI47694 : MB préconise d'ouvrir ADOSACT sans préciser de nombre d'appli
  #Local File =GDOSX3+".ADOSACT"  [ADA]
  Local File ADOSACT [ADA]
  Local File =SZAPPLI+".AMSK"  [AMK]

  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("HDK Activity codes update start.") From DOSSUB
  Call DEBTRANS From GLOCK
  Trbegin [ADA]
  #---------------------------------------------------#
  #HAD : Nb dem service agenda Sup cl (999) HDKAGD1-2
  Read [ADA] ADA0=SZAPPLI;"HAD"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=999
      Read [AMK] CODMSK="HDKAGD1"
      If fstat=0
        If [F:AMK]NBLIGT(2)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(2)
        Endif
      Endif
      Rewrite [ADA]
      If fstat<>0
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #HAE : Nb avertissements agenda Su cl (999) HDKAGD3-0
  Read [ADA] ADA0=SZAPPLI;"HAE"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=999
      [F:ADA]FLACT=2
      Read [AMK] CODMSK="HDKAGD3"
      If fstat=0
        If [F:AMK]NBLIGT(0)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(0)
        Endif
      Endif
      Rewrite [ADA]
      If fstat<>0
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #HAG : Nb interventions agenda Sup cl (999)HDKAGD2-2
  Read [ADA] ADA0=SZAPPLI;"HAG"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=999
      [F:ADA]FLACT=2
      Read [AMK] CODMSK="HDKAGD2"
      If fstat=0
        If [F:AMK]NBLIGT(2)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(2)
        Endif
      Endif
      Rewrite [ADA]
      If fstat<>0
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #HAS : Nb catégories/escalade  (99)  ECE4-1
  Read [ADA] ADA0=SZAPPLI;"HAS"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=99
      [F:ADA]FLACT=2
      Read [AMK] CODMSK="ECE4"
      If fstat=0
        If [F:AMK]NBLIGT(1)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(1)
        Endif
      Endif
      Rewrite [ADA]
      If fstat<>0
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #HCD : Nb collaborateurs disponibles  (50) ITN5-0
  Read [ADA] ADA0=SZAPPLI;"HCD"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=50
      [F:ADA]FLACT=2
      Read [AMK] CODMSK="ITN5"
      If fstat=0
        If [F:AMK]NBLIGT(0)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(0)
        Endif
