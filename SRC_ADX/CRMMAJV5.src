      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #SHD : Consommations (SAV)  (100) ITN8-0 SRE9-0
  Read [ADA] ADA0=SZAPPLI;"SHD"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=100
      [F:ADA]FLACT=2
      Read [AMK] CODMSK="ITN8"
      If fstat=0
        If [F:AMK]NBLIGT(0)<>0
          [F:ADA]DIME=[F:AMK]NBLIGT(0)
        Endif
      Endif
      Rewrite [ADA]
      If fstat<>0
        Call ECR_TRACE("Activity code "-[F:ADA]CODACT+"0, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #SMA : Parc concerné (SAV)  (100) SRE7-1
  Read [ADA] ADA0=SZAPPLI;"SMA"
  If fstat=0
    If [F:ADA]DIME=0
      [F:ADA]DIME=100
      [F:ADA]FLACT=2
