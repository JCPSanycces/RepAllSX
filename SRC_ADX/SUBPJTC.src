######################################################################################
Subprog AM_RATMUL(VALEUR)
Variable Decimal VALEUR

  # Issue X3-100532 - 2018-07-12 by SINGC
  GZINSPJTC.RATMUL = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
  If GERR = 1 Then
    GZINSPJTC.RATMUL = GZINSPJTC.snapshot.RATMUL
    GERR = 1
    mkstat = 2
    End
  Endif
  Call SHOW_HEADER()
End

######################################################################################
# SUBROUTINES / FUNCTIONS
######################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
Variable Instance GZINSPJTC Using C_PJMTIMCAT

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

  # ----------------------------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSPJTC, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
  # To help debug process : write a classic log file with all errors in class.
  If GERR <> 0 Then
    If GTRACE = AVOID.ACHAR Then
      Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
      IOPEN_TRACE = [V]CST_AYES
    Endif
    Call ECR_TRACE("->", 0) From GESECRAN
    Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GZINSPJTC) From SYRSTACKTOOLS
    If IOPEN_TRACE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
    Endif
  Endif
  # ----------------------------------------------------------
  [L]MY_STATUS = fmet GZINSPJTC.RESET_ERRORS()
End

######################################################################################
Subprog SHOW_HEADER()

  SetInstance [M:PJTC0] With GZINSPJTC
  Affzo [M:PJTC0]1-99
End

