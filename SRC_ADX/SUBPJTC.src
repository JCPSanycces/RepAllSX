#<AdxTL>@(#)0.0.0.0 $Revision$ Object management PJTC
######################################################################################
## Management of OPJMTIMCAT
# Issue X3-66468 - 2018-01-11 by SINGC
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                : Gosub OUVRE
    When "FERME"                : Gosub FERME
    When "RAZCRE"               : Gosub RAZCRE
    When "RAZDUP"               : Gosub RAZDUP
    When "CREATION"             : Gosub CREATION
    When "APRES_CRE"            : Gosub APRES_CRE
    When "LIENS"                : Gosub LIENS
    When "MODIF"                : Gosub MODIF
    When "APRES_MOD"            : Gosub APRES_MOD
    When "AV_ANNULE"            : Gosub AV_ANNULE
    When "ANNULE"               : Gosub ANNULE
    When Default
  Endcase
Return

######################################################################################
# Object PJTC
######################################################################################
$OUVRE
Global Instance GZINSPJTC Using C_PJMTIMCAT      # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  ANOWRITE = 1
  If !clalev ([F:PJTC]) : Local File PJMTIMCAT [PJTC] : Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$FERME
  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSPJTC <> null Then
    FreeGroup GZINSPJTC
  Endif
  Kill GZINSPJTC
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$RAZCRE
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSPJTC <> null Then
    FreeGroup GZINSPJTC
  Endif
  # -------------------------------
  GZINSPJTC = NewInstance C_PJMTIMCAT AllocGroup null
  [L]MY_STATUS = fmet GZINSPJTC.AINIT()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(372,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      OK = 0
      Return
    Endif
  Endif
  # ------------------------------------
  SetInstance [M:PJTC0] With GZINSPJTC
  # Hybrid part (end)
  # ----------------------------------------------------------
  Affzo [M:PJTC0]1-99
Return

######################################################################################
$RAZDUP
  # ----------------------------------------------------------
  # Hybrid part (begin)
  Gosub RELIT From GOBJSUB
  GMESSAGE = mess(464,2260,1)
  GOK = 0
  GERR = 1
  REP = ""
  mkstat = 2
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$CREATION
  # ----------------------------------------------------------
  # Hybrid part (begin)
  SetInstance GZINSPJTC With [M:PJTC0]
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJTC.AINSERT()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1034,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # ----------------------------------
  SetInstance [F:PJTC] With GZINSPJTC
  [M:PJTC0] = [F:PJTC]
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$APRES_CRE
  Gosub RELIT From GOBJSUB
  Affzo [M:PJTC0]1-99
Return

######################################################################################
$LIENS
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSPJTC <> null Then
    FreeGroup GZINSPJTC
  Endif
  # ----------------------------------
  GZINSPJTC = NewInstance C_PJMTIMCAT AllocGroup null
  [L]MY_STATUS = fmet GZINSPJTC.AREAD([M:PJTC0]CATCOD)
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1035,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # ----------------------------------
  SetInstance [M:PJTC0] With GZINSPJTC
  Affzo [M:PJTC0]1-99
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$MODIF
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  SetInstance GZINSPJTC With [M:PJTC0]
  # ----------------------------------
  [L]MY_STATUS = fmet GZINSPJTC.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1036,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
  Affzo [M:PJTC0]1-99
Return

######################################################################################
$AV_ANNULE
Local Integer ANOWRITE

  # ----------------------------------------------------------
  # Hybrid part (begin)
  ANOWRITE = 1
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
$ANNULE
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  [L]MY_STATUS = fmet GZINSPJTC.ADELETE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(1037,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

######################################################################################
# Screens fields
######################################################################################
# PJTC0
######################################################################################
Subprog AM_CATCOD(VALEUR)
Variable Char    VALEUR()

  If GZINSPJTC = null Then
    GMESSAGE = mess(1048,2260,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  # -----------------------------
  GZINSPJTC.CATCOD = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJTC)
  If GERR = 1 Then
    GZINSPJTC.CATCOD = GZINSPJTC.snapshot.CATCOD
    GERR = 1
    mkstat = 2
    End
  Endif
  Call SHOW_HEADER()
End

######################################################################################
Subprog AM_DESAXX(VALEUR)
Variable Char    VALEUR()

  GZINSPJTC.DESAXX = VALEUR
