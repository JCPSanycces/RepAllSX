Return

Subprog D_WADD6(VALEUR)
Variable Integer VALEUR
If varinit([M]WADD6,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WADD6(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WADD6(VALEUR) From SUBEML2
If mkstat=2
 [M]WADD6(INDIC) = VALEUR
 Affzo WADD6(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

