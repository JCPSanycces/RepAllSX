Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRADI
 Call TUNHRADI(VALEUR,"10380",string$(GCURLEG2<>'',GCURLEG2)+string$(GCURLEG2='',GCURLEG),"") From TOOLSHRLEG
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_WSTADES
Onevent INIT_AREA Call D_WSTADES(zc) From W1HRMAT9
Return

Subprog D_WSTADES(VALEUR)
Variable Char    VALEUR()
If varinit([M]WSTADES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"ATABDIV","WSTADES","10380",[M]WSTATRY) From ATEXTRA
Endif
Gosub _AFF
End

