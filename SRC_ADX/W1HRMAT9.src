Subprog S_WDOMEXM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADILEGH
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADILEGH"
 PARMSK(1) = "10381"
 PARMSK(2) = string$(GCURLEG2<>'',GCURLEG2)+string$(GCURLEG2='',GCURLEG)
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILEGH","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WDOMEXM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRADI
 Call TUNHRADI(VALEUR,"10381",string$(GCURLEG2<>'',GCURLEG2)+string$(GCURLEG2='',GCURLEG),"") From TOOLSHRLEG
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

