#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT9 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:44"
A_USER  = "DOC"
A_STAMP = "20181109230444"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBREXM"
  If [M]NBREXM=0
  Endif
 When "NBRTRY"
  If [M]NBRTRY=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT9 [EMP9]
Gosub HORODAT
Local Inpbox "HRMAT9" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP9] As [SIM_]
Grizo [EMP9]10
Grizo [EMP9]20
Grizo [EMP9]30
Grizo [EMP9]40
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP9]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=8 : Y1(0)=1 : Y2(0)=11
X1(1)=9 : X2(1)=88 : Y1(1)=1 : Y2(1)=11
X1(2)=1 : X2(2)=8 : Y1(2)=12 : Y2(2)=22
X1(3)=9 : X2(3)=88 : Y1(3)=12 : Y2(3)=22
Return

$ON_NBREXM
Onevent BEFORE_INPUT Call AS_NBREXM From W1HRMAT9
Onevent CONTROL Call C_NBREXM From W1HRMAT9
Return

Subprog AS_NBREXM
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBREXM From SUBEML2
Gosub _AFF
End

Subprog C_NBREXM
Local Decimal BASPAG
## Action STD
Call C_NBREXM From SUBEML2
If mkstat : GERR = 1 : GZONE = "NBREXM" : GZNUM = 0 : Endif
Gosub _AFF
End

