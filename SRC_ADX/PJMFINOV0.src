###################################################################################################
$FIN
Local Integer IRET

  If TECFINOVE <> null Then
    IRET = fmet TECFINOVE.DELETE_ALL()
    FreeGroup TECFINOVE
  Endif
  Kill TECFINOVE
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "1"
      Gosub LOAD_PAGE
  Endcase
Return

###################################################################################################
$TITLE
  # X3-73879 Enhancement ALMON 01-02-2018
  If PARAM(3) <> AVOID.ACHAR Then
    TIT = func SUBPJMSNP.GET_KEYEXT_DESC(PARAM(3))
  Endif
Return

###################################################################################################
# Screens fields
###################################################################################################
# PFOV
###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

Local Char STUNBUD(GLONPBU)  # Contain the budget given by parameter

  STUNBUD = AVOID.ACHAR
  [M:PFOV]SHOWQTY = [V]CST_AYES
  [M:PFOV]SHOWAMT = [V]CST_AYES
  [M:PFOV]PBUCOD  = AVOID.ACHAR
  Call LOAD_SCREEN_DEFAULT(VALEUR)
  Gosub LOAD_PAGE
End

###################################################################################################
Subprog AM_SHOWGRP(VALEUR)
Variable Char    VALEUR()

  TECFINOVE.SHOWGRP = VALEUR
  [M:PFOV]SHOWGRP = VALEUR
  IRET = fmet TECFINOVE._GET_SELECTED_GRP(TECFINOVE.SHOWGRP)
  [M:PFOV]SHOWQTY = TECFINOVE.SHOWQTY
  [M:PFOV]SHOWAMT = TECFINOVE.SHOWMNT
  [M:PFOV]SHOWADV = TECFINOVE.ADVINCL
End

###################################################################################################
Subprog C_UNITE(VALEUR)
Variable Char    VALEUR()

Local Char STIMUOM(GLONUOM)

  Local File TABCOEFF [TCO]
  STIMUOM = fmet TECFINOVE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, TECFINOVE.ACTX.AFOLDER, "HOURLYUNIT")
  If VALEUR <> STIMUOM Then
    Read [TCO]TCO0=VALEUR;STIMUOM
    If fstat Then
      GMESSAGE = func AFNC.MES1(mess(298,2260,1), STIMUOM)
      GOK = 0
      GERR = 1
      End
    Endif
  Endif
End

###################################################################################################
Subprog AM_SHOWQTY(VALEUR)
Variable Integer    VALEUR()

  [M:PFOV]SHOWQTY   = VALEUR
  TECFINOVE.SHOWQTY = VALEUR
  # Issue X3-106367 - 2018-08-28 by FGR : BEGIN
  #Affzo [M:PFOV2]1-99
  #Affzo [M:PFOV1]1-99
  Call CHGSTL_PFOV1()
  Call CHGSTL_PFOV2()
  # Issue X3-106367 - 2018-08-28 by FGR : END
End

###################################################################################################
Subprog AM_SHOWAMT(VALEUR)
Variable Integer    VALEUR()

  [M:PFOV]SHOWAMT   = VALEUR
  TECFINOVE.SHOWMNT = VALEUR
  # Issue X3-106367 - 2018-08-28 by FGR : BEGIN
  #Affzo [M:PFOV2]1-99
  #Affzo [M:PFOV1]1-99
  Call CHGSTL_PFOV1()
  Call CHGSTL_PFOV2()
  # Issue X3-106367 - 2018-08-28 by FGR : END
End

###################################################################################################
Subprog AM_MULPRJ(VALEUR)
Variable Integer VALEUR

  [M:PFOV]MULPRJ   = VALEUR
  TECFINOVE.MULPRJ = VALEUR
  Affzo [M:PFOV2]1-99
  Affzo [M:PFOV1]1-99
End

###################################################################################################
# PFOV1
###################################################################################################
Subprog IB_NBDET

  If [M:PFOV1]PCCCOD(nolign-1) = AVOID.ACHAR Then
    Raz GBOUT1
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : If in snapshot mode diable contextual menu
  If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    Raz GBOUT1
  Endif
End

###################################################################################################
# PFOV2
###################################################################################################
Subprog IB_NBLIG

Local Integer BUDSUB
Local Integer LIGSUB
Local Integer SCCUB
Local Integer IRET
Local Char COLDES(250)
Local Char PARGRP(GLONADI)
Local Decimal FLDVAL (20)
Local Decimal CONQTY
Local Char SELBUD(GLONPBU)
Local Char SELPRJ(GLONOPP)

  If [M:PFOV2]BUDCOD(nolign-1) = AVOID.ACHAR Then
    Raz GBOUT2
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : BEGIN disable contextual menus if in snapshot mode
  If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    Raz GBOUT1
    Raz GBOUT2
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : end
  SELBUD = [M:PFOV2]BUDCOD(nolign-1)
  SELPRJ = [M:PFOV2]OPPNUM(nolign-1)
  BUDSUB = nolign-1
  COLDES = [M:PFOV2]OBJDES(nolign-1)
  TECFINOVE.PBUCOD = [M:PFOV2]BUDCOD(nolign-1)
  Gosub GET_PJMSCCT_DET
  [M:PFOV1]NBDET = LIGSUB
  Call DSPDET_WITH_STYLE()
  Affzo [M:PFOV2]10
  Affzo [M:PFOV1]10
End

###################################################################################################
# Subroutines
###################################################################################################
Subprog LOAD_TREE(PARBUD)
Value Char PARBUD

Local Integer NI
Local Integer NE
Local Integer NZ
Local Integer B1
Local Integer C1
Local Integer IRET
Local Char STBOPPNUM(GLONPIM)(0..)
Local Char SFILTER(250)

  NE = 0
  # Loop through Projects List
  Raz STBOPPNUM
  NZ = 0
  If [M:PFOV]KEYEXT = AVOID.ACHAR Then  # X3-73879 Enhancement ALMON 01-02-2018
    For NI = 1 To maxtab(TECFINOVE.PRJLST)
      If TECFINOVE.PRJLST(NI) <> null Then
        NZ += 1
        STBOPPNUM(NZ) = TECFINOVE.PRJLST(NI).OPPLST
      Endif
    Next NI
  Else
    # X3-73879 Enhancement ALMON 01-02-2018
    NZ += 1
    STBOPPNUM(NZ) = [M:PFOV]OPPNUM
  Endif
  If NZ > 1 Then
    NZ = 0
  Else
    NZ = 1
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : BEGIN
  If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    SFILTER = "1=1"
  Else
    SFILTER = "[F:PJSC]PSCSSS = TECFINOVE.SESSION"
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : END
  For NI = NZ To maxtab(STBOPPNUM)
    If PARBUD = AVOID.ACHAR Then
      # Issue X33-91329 - 2018-06-01 by FGR : BEGIN
      #Filter [PJSC] Where evalue(SFILTER) and [F:PJSC]OPPNUM = STBOPPNUM(NI) and [F:PJSC]PCCCOD = AVOID.ACHAR Order By OPPNUM;PBUPAE;PBUCOD
      Filter [PJSC] Where evalue(SFILTER) and [F:PJSC]OPPNUM = STBOPPNUM(NI) and [F:PJSC]PCCCOD = AVOID.ACHAR Order By OPPNUM;PBUPAE;PBUSOR;PBUCOD
      # Issue X33-91329 - 2018-06-01 by FGR : END
    Else
      # Issue X33-91329 - 2018-06-01 by FGR : BEGIN
      #Filter [PJSC] Where [F:PJSC]OPPNUM = STBOPPNUM(NI) and [F:PJSC]PBUCOD <> AVOID.ACHAR and [F:PJSC]PCCCOD = AVOID.ACHAR Order By OPPNUM;PBUPAE;PBUCOD
      Filter [PJSC] Where [F:PJSC]OPPNUM = STBOPPNUM(NI) and [F:PJSC]PBUCOD <> AVOID.ACHAR and [F:PJSC]PCCCOD = AVOID.ACHAR Order By OPPNUM;PBUPAE;PBUSOR;PBUCOD
      # Issue X33-91329 - 2018-06-01 by FGR : END
    Endif
    For [PJSC]
      Gosub GET_SUMM_PJMSC
    Next
  Next NI
  Filter [PJSC]
  [M:PFOV2]NBLIG = NE
  Affzo [M:PFOV2]10
  Affzo [M:PFOV1]10
End

###################################################################################################
Subprog LOAD_CLASS_TECFINOVE(STUNBUD)
Value Char STUNBUD

Local Integer IRET

  If TECFINOVE <> null Then
    IRET = fmet TECFINOVE.DELETE_ALL()
    FreeGroup TECFINOVE
  Endif
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  TECFINOVE.ISBUDUPD = [V]CST_ANO            # Note FGR : set to [V]CST_ANO in financial overview
  TECFINOVE.SHOWGRP  = [M:PFOV]SHOWGRP
  TECFINOVE.SHOWQTY  = [M:PFOV]SHOWQTY
  TECFINOVE.SHOWMNT  = [M:PFOV]SHOWAMT
  TECFINOVE.OPPNUM   = [M:PFOV]OPPNUM
  TECFINOVE.CUR      = [M:PFOV]SHOCUR
  TECFINOVE.UOM      = [M:PFOV]UNITE
  TECFINOVE.ADVINCL  = [M:PFOV]SHOWADV
  TECFINOVE.MULPRJ   = [M:PFOV]MULPRJ
  TECFINOVE.PBUCOD   = STUNBUD
End

###################################################################################################
Subprog LOAD_SCREEN_DEFAULT(SOPPNUM)
Value Char SOPPNUM

Local Integer IRET
Local Integer IMESSAGE
Local Char SFCY(GLONFCY)
Local Char SMESS(250)

  If TECFINOVE = null Then
    TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  Endif
  IRET = fmet TECFINOVE._GET_DEFAULT_GRP()
  If IRET <> [V]CST_AOK Then
    IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(TECFINOVE, GMESSAGE)
    GERR = 1
    GOK = 0
    End
  Else
    # Issue X3-107215 - 2018-10-05 by FGR : BEGIN : Undo X3-106683 which is wrong !
    ##X3-106683 ENHANCEMENT ALMON 09-05-2018 : Load QTY and AMT defaults from TECFINOVE and bypass if SNAPSHOT mode
    #If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    #  TECFINOVE.SHOWQTY = [M:PFOV]SHOWQTY
    #  TECFINOVE.SHOWMNT = [M:PFOV]SHOWAMT
    #  End
    #Endif
    ##X3-106683 ENHANCEMENT ALMON 09-05-2018 : END
    # Issue X3-107215 - 2018-10-05 by FGR : END
    Local File OPPORSBB [OBB]
    [M:PFOV]OPPNUM = SOPPNUM
    [M:PFOV]SHOWGRP = TECFINOVE.SHOWGRP
    [M:PFOV]SHOWQTY = TECFINOVE.SHOWQTY
    [M:PFOV]SHOWAMT = TECFINOVE.SHOWMNT
    #[M:PFOV]SHOCUR = func OPPOR_CSTD_PROGS_COM.GET_CUR_VALUE(TECFINOVE.ACTX, SOPPNUM, SMESS)      # Issue X3-107215 - 2018-10-04 by FGR
    [M:PFOV]SHOCUR = func OPPORPJM_CSTD_PROGS.GET_CUROPP_VALUE(TECFINOVE.ACTX, SOPPNUM, SMESS)     # Issue X3-107215 - 2018-10-04 by FGR
    SFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(TECFINOVE.ACTX, SOPPNUM, "", "", SMESS)
    [M:PFOV]UNITE = fmet TECFINOVE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, SFCY, "HOURLYUNIT")
    IRET = [V]CST_ANO
    [M:PFOV]MULPRJ = [V]CST_ANO
    Filter [OBB] Where [F:OBB]OPPNUM = SOPPNUM
    For [OBB]
      If [F:OBB]CONSFLG = [V]CST_AYES Then
        If find(func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(TECFINOVE.ACTX, [F:OBB]SBBPJT, AVOID.ACHAR, AVOID.ACHAR, SMESS), 2, 3) Then
          IRET = [V]CST_AYES
          Break
        Endif
      Endif
    Next
    Filter [OBB]
    If IRET = [V]CST_ANO Then
      Grizo [M:PFOV]MULPRJ
    Else
      Actzo [M:PFOV]MULPRJ
    Endif
    Affzo [M:PFOV]1-99
  Endif
End

###################################################################################################
# X3-73879 Enhancement ALMON 01-02-2018 : START Trap for snapshop driver
$LOAD_PAGE
Local Integer IRET
Local Integer IMESSAGE
Local Char SELBUD(GLONPBU)
Local Char SELPRJ(GLONOPP)
Local Integer BUDSUB
Local Integer NI

  Call LOAD_CLASS_TECFINOVE(STUNBUD)
  If [M:PFOV]KEYEXT = AVOID.ACHAR Then
    IRET = fmet TECFINOVE.EXTRACT_ALL()
    If IRET <> [V]CST_AOK Then
      IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(TECFINOVE, GMESSAGE)
      GERR = 1
      GOK = 0
      Return
    Endif
  Else
    IRET = fmet TECFINOVE.TITLE_EXTRACT()
    If IRET <> [V]CST_AOK Then
      IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(TECFINOVE, GMESSAGE)
      GERR = 1
      GOK = 0
      Return
    Endif
  Endif
  If IRET = [V]CST_AOK Then
    Effzo [M:PFOV1]10
    Call CHGSTL_PFOV1()      # Issue X3-106367 - 2018-08-28 by FGR
    Effzo [M:PFOV2]10
    Call CHGSTL_PFOV2()      # Issue X3-106367 - 2018-08-28 by FGR
    Call LOAD_TREE(STUNBUD)
    SELBUD = STUNBUD
    If [M:PFOV]MULPRJ = [V]CST_ANO Then
      SELPRJ = [M:PFOV]OPPNUM
    Endif
    BUDSUB = 0
    Gosub GET_PJMSCCT_DET
    [M:PFOV1]NBDET = LIGSUB
    Call DSPDET_WITH_STYLE()
    Affzo [M:PFOV2]10
    Affzo [M:PFOV1]10
  Endif
Return

