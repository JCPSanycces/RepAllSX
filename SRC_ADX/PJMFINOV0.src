#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# PJMFINOV0
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "FIN"                         : Gosub FIN
    When "BOUTON"                      : Gosub BOUTON
    When "TITRE"                       : Gosub TITLE       # X3-73879 Enhancement ALMON 01-02-2018
    When "BB1_NBLIG"                   : Gosub BB1_NBLIG
    When "BB2_NBLIG"                   : Gosub BB2_NBLIG
    When Default
  Endcase
Return

###################################################################################################
$BB1_NBLIG
Local Char STUNBUD(GLONPBU)

  STUNBUD = [M:PFOV]PBUCOD
  Gosub LOAD_PAGE
Return

###################################################################################################
$BB2_NBLIG
Local Char STUNBUD(GLONPBU)

  STUNBUD = [M:PFOV]PBUCOD
  Gosub LOAD_PAGE
Return

###################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
# Issue X3-107215 - 2018-10-05 by FGR : BEGIN
$DEBUT
Global Instance TECFINOVE Using C_TECFINOVE

Local Char STUNBUD(GLONPBU)  # Contain the budget given by parameter
Local Char WRKPRJ (GLONPIM)
Local Char WRKSNP (GLONSNP)
Local Date SNPDTE
Local Integer IRET

  [M:PFOV]KEYEXT = PARAM(3)
  # -------------------------------------------------------
  If [M:PFOV]KEYEXT = AVOID.ACHAR Then
    Local File PJMSC [PJSC]
    Local File PJMDE [PJE]
    Local File PJMSCCT [PJCT]
    Local File PJMBUD [PJBD]
  Else
    Local File PJMFINOVRRPT [PJSC] Where [F:PJSC]KEYEXT = [M:PFOV]KEYEXT
    Local File PJMFINCTORPT [PJCT] Where [F:PJCT]KEYEXT = [M:PFOV]KEYEXT
  Endif
  # -------------------------------------------------------
  # PARAM Work
  [M:PFOV]CALLBY = AVOID.ACHAR
  Raz [M:PFOV]OPPNUM
  If PARAM(1) <> AVOID.ACHAR Then
    [M:PFOV]CALLBY = "PJM"
    [M:PFOV]OPPNUM = PARAM(1)
    Grizo [M:PFOV]OPPNUM
  Endif
  STUNBUD = PARAM(2)
  [M:PFOV]SHOWQTY = [V]CST_AYES
  [M:PFOV]SHOWAMT = [V]CST_AYES
  [M:PFOV]PBUCOD  = STUNBUD
  # -------------------------------------------------------
  If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    Grizo [M:PFOV]UNITE
    Grizo [M:PFOV]SHOCUR
    Grizo [M:PFOV]SHOWGRP
    Chgfmt [M:PFOV]MULPRJ With "-N:5.0"
    [M:PFOV]MULPRJ = [V]CST_ANO
    If func SUBPJMSNP.GET_SNAPSHOT_HEADER([M:PFOV]KEYEXT, WRKPRJ, WRKSNP, [M:PFOV]SHOWGRP, [M:PFOV]UNITE, [M:PFOV]SHOCUR, SNPDTE, GMESSAGE) = [V]CST_AERROR Then
      GERR = 1
      GOK = 0
      Return
    Endif
    IRET = func TECFINOVE_CSTD_PROGS.GET_DEFAULT_SHOWQTY_SHOWAMT(GACTX, [M:PFOV]SHOWGRP, [M:PFOV]SHOWQTY, [M:PFOV]SHOWAMT)
  Else
    Call LOAD_SCREEN_DEFAULT([M:PFOV]OPPNUM)
  Endif
  # -------------------------------------------------------
  If [M:PFOV]CALLBY = "PJM" Then
    Gosub LOAD_PAGE
    Call DSPDET_WITH_STYLE()
    Affzo [M:PFOV]1-99
    Affzo [M:PFOV2]10
    Affzo [M:PFOV1]10
  Endif
Return

