###################################################################################################
Funprog COLGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVE, INDEX, [M:PFOV]SHOWAMT, [M:PFOV]SHOCUR, [M:PFOV]SHOWQTY, [M:PFOV]UNITE)
End SARENDRE

###################################################################################################
Funprog COL_GET_TITLE(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.COL_GET_TITLE(TECFINOVE, INDEX)
End SARENDRE

###################################################################################################
Funprog GET_FAMILY(SOPPNUM, SPBUCOD)
Value Char SOPPNUM
Value Char SPBUCOD

Local Char SARENDRE(250)
Local Char STBCODE(GLONPBU)(1..)
Local Integer NI
Local Integer IRET

  Raz SARENDRE
  If [M:PFOV]MULPRJ = [V]CST_AYES Then
    SARENDRE = "ALL"
  Endif
  If SOPPNUM <> AVOID.ACHAR Then
    If SARENDRE <> AVOID.ACHAR Then
      SARENDRE += "~"
    Endif
    SARENDRE += SOPPNUM
    If SPBUCOD <> AVOID.ACHAR Then
      IRET = func PJMBUD_CSTD_PROGS.GET_FAMILY(SOPPNUM, SPBUCOD, STBCODE)
      For NI = maxtab(STBCODE) To 1 Step -1
        If SARENDRE <> AVOID.ACHAR Then
          SARENDRE += "~"
        Endif
        SARENDRE += STBCODE(NI)
      Next NI
    Endif
  Endif
End SARENDRE

####################################################################################################
$GET_SUMM_PJMSC
Local Integer ISPARENT
Local Char WRKPIMNUM(250)

  [M:PFOV2]PBUIMP(NE) = [V]CST_ANO
  If [M:PFOV]MULPRJ = [V]CST_AYES and [F:PJSC]OPPNUM = AVOID.ACHAR Then
    [M:PFOV2]PARKEY(NE) = AVOID.ACHAR
    [M:PFOV2]OBJDES(NE) = mess(579,2260,1)
    [M:PFOV2]KEYC(NE)   = func GET_FAMILY(AVOID.ACHAR, AVOID.ACHAR)
    [M:PFOV2]EXPFLG(NE) = [V]CST_AYES
    [M:PFOV2]ICO(NE)    = "Folder.gif"
    [M:PFOV2]BUDCOD(NE) = ""
  Else
    If [F:PJSC]OPPNUM <> AVOID.ACHAR and [F:PJSC]PBUPAE = AVOID.ACHAR and [F:PJSC]PBUCOD = AVOID.ACHAR and PARBUD = AVOID.ACHAR Then
      [M:PFOV2]PARKEY(NE) = func GET_FAMILY(AVOID.ACHAR, AVOID.ACHAR)
      [M:PFOV2]OBJDES(NE) = [F:PJSC]OPPNUM - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVE.ACTX, [F:PJSC]OPPNUM)
      [M:PFOV2]KEYC(NE)   = func GET_FAMILY([F:PJSC]OPPNUM, AVOID.ACHAR)
      [M:PFOV2]EXPFLG(NE) = [V]CST_AYES
      [M:PFOV2]ICO(NE)    = "Folder.gif"
      [M:PFOV2]BUDCOD(NE) = ""
    Else
      [M:PFOV2]PBUIMP(NE) = func PJMBUD_CSTD_PROGS.GET_PBUIMP([F:PJSC]OPPNUM, [F:PJSC]PBUCOD)
      If [F:PJSC]PBUCOD <> AVOID.ACHAR Then
        WRKPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(TECFINOVE.ACTX, [F:PJSC]OPPNUM, [F:PJSC]PBUCOD)
        [M:PFOV2]OBJDES(NE) = [F:PJSC]PBUCOD - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVE.ACTX, WRKPIMNUM)
        [M:PFOV2]BUDCOD(NE) = [F:PJSC]PBUCOD
        [M:PFOV2]EXPFLG(NE) = [V]CST_ANO # No expanded nodes by default
        #
        [M:PFOV2]KEYC(NE)   = func GET_FAMILY([F:PJSC]OPPNUM, [F:PJSC]PBUCOD)
        If NE = 0 Then
          [M:PFOV2]PARKEY(NE) = func GET_FAMILY(AVOID.ACHAR, AVOID.ACHAR)
        Else
          [M:PFOV2]PARKEY(NE) = func GET_FAMILY([F:PJSC]OPPNUM, [F:PJSC]PBUPAE)
        Endif
        #
        If [M:PFOV2]PBUIMP(NE) = [V]CST_ANO Then
          [M:PFOV2]ICO(NE)  = "Folder.gif"
        Else
          [M:PFOV2]ICO(NE)  = "Book.gif"
        Endif
      Else
        If [F:PJSC]PBUPAE <> AVOID.ACHAR Then
          WRKPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(TECFINOVE.ACTX, [F:PJSC]OPPNUM, [F:PJSC]PBUPAE)
          [M:PFOV2]OBJDES(NE) = [F:PJSC]PBUPAE - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVE.ACTX, WRKPIMNUM)
          [M:PFOV2]KEYC(NE)   = [F:PJSC]PBUPAE
          [M:PFOV2]BUDCOD(NE) = [F:PJSC]PBUCOD
          [M:PFOV2]EXPFLG(NE) = [V]CST_AYES
          If [M:PFOV2]PBUIMP(NE) = [V]CST_ANO Then
            [M:PFOV2]PARKEY(NE) = [F:PJSC]OPPNUM
            [M:PFOV2]ICO(NE)  = "Folder.gif"
          Else
            [M:PFOV2]PARKEY(NE) = [F:PJSC]OPPNUM
            [M:PFOV2]ICO(NE)  = "Book.gif"
          Endif
        Else
          Return
        Endif
      Endif
    Endif
  Endif
  # ----------------------------
  [M:PFOV2]OPPNUM(NE)        = [F:PJSC]OPPNUM
  [M:PFOV2]COLUMN6(NE)       = [F:PJSC]PSCBUDQTY
  [M:PFOV2]COLUMN7(NE)       = [F:PJSC]PSCBUDAMT
  [M:PFOV2]COLUMN8(NE)       = [F:PJSC]PSCQTY1
  [M:PFOV2]COLUMN9(NE)       = [F:PJSC]PSCAMT1
  [M:PFOV2]COLUMN10(NE)      = [F:PJSC]PSCQTY2
  [M:PFOV2]COLUMN11(NE)      = [F:PJSC]PSCAMT2
  [M:PFOV2]COLUMN12(NE)      = [F:PJSC]PSCQTY3
  [M:PFOV2]COLUMN13(NE)      = [F:PJSC]PSCAMT3
  [M:PFOV2]COLUMN14(NE)      = [F:PJSC]PSCQTY4
  [M:PFOV2]COLUMN15(NE)      = [F:PJSC]PSCAMT4
  [M:PFOV2]COLUMN16(NE)      = [F:PJSC]PSCQTY5
  [M:PFOV2]COLUMN17(NE)      = [F:PJSC]PSCAMT5
  [M:PFOV2]COLUMN18(NE)      = [F:PJSC]PSCREMQTY
  [M:PFOV2]COLUMN19(NE)      = [F:PJSC]PSCREMAMT
  [M:PFOV2]COLUMN20(NE)      = [F:PJSC]PSCWIPQTY
  [M:PFOV2]COLUMN21(NE)      = [F:PJSC]PSCWIPAMT
  [M:PFOV2]COLUMN22(NE)      = [F:PJSC]PSCTOTQTY
  [M:PFOV2]COLUMN23(NE)      = [F:PJSC]PSCTOTAMT
  [M:PFOV2]COLUMN24(NE)      = [F:PJSC]PSCMARGQTY
  [M:PFOV2]COLUMN25(NE)      = [F:PJSC]PSCPCTMQTY
  [M:PFOV2]COLUMN26(NE)      = [F:PJSC]PSCMARGAMT
  [M:PFOV2]COLUMN27(NE)      = [F:PJSC]PSCPCTMAMT
  # ADVANCED
  [M:PFOV2]COLUMN28(NE)      = [F:PJSC]PSCFREEC6A
  [M:PFOV2]COLUMN29(NE)      = [F:PJSC]PSCFREEC6B
  [M:PFOV2]COLUMN30(NE)      = [F:PJSC]PSCMARGBUD6
  [M:PFOV2]COLUMN31(NE)      = [F:PJSC]PSCPCTMBUD6
  [M:PFOV2]COLUMN32(NE)      = [F:PJSC]PSCMARGTOT6
  [M:PFOV2]COLUMN33(NE)      = [F:PJSC]PSCPCTMTOT6
  [M:PFOV2]COLUMN34(NE)      = [F:PJSC]PSCFREEC7A
  [M:PFOV2]COLUMN35(NE)      = [F:PJSC]PSCFREEC7B
  [M:PFOV2]COLUMN36(NE)      = [F:PJSC]PSCFREEC8A
  [M:PFOV2]COLUMN37(NE)      = [F:PJSC]PSCFREEC8B
  [M:PFOV2]COLUMN38(NE)      = [F:PJSC]PSCFREEC9A
  [M:PFOV2]COLUMN39(NE)      = [F:PJSC]PSCFREEC9B
  [M:PFOV2]COLUMN40(NE)      = [F:PJSC]PSCFREEC10A
  [M:PFOV2]COLUMN41(NE)      = [F:PJSC]PSCFREEC10B
  [M:PFOV2]COLUMN42(NE)      = [F:PJSC]PSCESTTOTQTY
  [M:PFOV2]COLUMN43(NE)      = [F:PJSC]PSCESTTOTAMT
  # ----------------------------
  NE += 1
Return

###################################################################################################
$GET_PJMSCCT_DET
Local Char PCCGRP(GLONADI)
Local Char COLDES(25)
Local Char WRKPIMNUM(250)
Local Char SFILTER(250)

  LIGSUB = 0
  Affzo [M:PFOV1]10
  # X3-73879 Enhancement ALMON 01-02-2018 : BEGIN
  If [M:PFOV]KEYEXT <> AVOID.ACHAR Then
    SFILTER = "1=1"
  Else
    SFILTER = "[F:PJCT]PSCSSS = TECFINOVE.SESSION"
  Endif
  # X3-73879 Enhancement ALMON 01-02-2018 : END
  If [M:PFOV]MULPRJ = [V]CST_AYES Then
    If SELPRJ = AVOID.ACHAR Then
      If SELBUD = AVOID.ACHAR Then
        Filter [PJCT] Where evalue(SFILTER) and [F:PJCT]OPPNUM = AVOID.ACHAR and [F:PJCT]PBUPAE = AVOID.ACHAR and [F:PJCT]PBUCOD = AVOID.ACHAR Order By PCCGRPSOR;PCCGRP;PCCCOD
      Endif
    Else
      If SELBUD <> AVOID.ACHAR Then
        Filter [PJCT] Where evalue(SFILTER) and [F:PJCT]OPPNUM = SELPRJ and [F:PJCT]PBUCOD = SELBUD  Order By PCCGRPSOR;PCCGRP;PCCCOD
      Else
        Filter [PJCT] Where evalue(SFILTER) and [F:PJCT]OPPNUM = SELPRJ and [F:PJCT]PBUPAE = AVOID.ACHAR and PBUCOD = AVOID.ACHAR Order By PCCGRPSOR;PCCGRP;PCCCOD
      Endif
    Endif
  Else
    If SELBUD = AVOID.ACHAR Then
      Filter [PJCT] Where evalue(SFILTER) and [F:PJCT]OPPNUM = SELPRJ and [F:PJCT]PBUPAE = AVOID.ACHAR and [F:PJCT]PBUCOD = AVOID.ACHAR Order By PCCGRPSOR;PCCGRP;PCCCOD
    Else
      Filter [PJCT] Where evalue(SFILTER) and [F:PJCT]OPPNUM = SELPRJ and [F:PJCT]PBUCOD = SELBUD Order By PCCGRPSOR;PCCGRP;PCCCOD
    Endif
  Endif
  For [PJCT]
    [M:PFOV1]PCCCOD(LIGSUB) = AVOID.ACHAR
    COLDES = ""
    If LIGSUB = 0 Then
      [M:PFOV1]EXPFLG(LIGSUB) = [V]CST_AYES
      [M:PFOV1]ICO(LIGSUB) = "Folder.gif"
      If SELBUD = AVOID.ACHAR and SELPRJ = AVOID.ACHAR Then
        If [M:PFOV]MULPRJ = [V]CST_AYES Then
          [M:PFOV1]OBJDES(LIGSUB) = mess(579,2260,1)
          [M:PFOV1]KEYC(LIGSUB)   = "ALL"
        Else
          [M:PFOV1]OBJDES(LIGSUB) = TECFINOVE.OPPNUM - func PIMPL_CSTD_PROGS.GET_PIMDESAXX(TECFINOVE.ACTX, TECFINOVE.OPPNUM)
          [M:PFOV1]KEYC(LIGSUB)   = [F:PJCT]OPPNUM
        Endif
      Else
        [M:PFOV1]OBJDES(LIGSUB) = [M:PFOV2]OBJDES(BUDSUB)
        [M:PFOV1]KEYC(LIGSUB)   = SELBUD
      Endif
    Else
      [M:PFOV1]EXPFLG(LIGSUB) = [V]CST_ANO
      If [F:PJCT]PCCCOD <> AVOID.ACHAR Then
        [M:PFOV1]PARKEY(LIGSUB) = [F:PJCT]PCCGRP
        Call LECTEXTRA_SYR(TECFINOVE, AVOID.ACHAR, COLDES, "PJMCOSTCTR", "DESAXX", [F:PJCT]PCCCOD, AVOID.ACHAR) From ATEXTRA
        [M:PFOV1]OBJDES(LIGSUB)   = [F:PJCT]PCCCOD - COLDES
        [M:PFOV1]KEYC(LIGSUB)     = [F:PJCT]PCCCOD + "~" + [F:PJCT]PCCCOD
        [M:PFOV1]ICO(LIGSUB)      = "Book.gif"
        [M:PFOV1]PCCCOD(LIGSUB)   = [F:PJCT]PCCCOD
      Else
        If [F:PJCT]PCCGRP <> AVOID.ACHAR Then
          [M:PFOV1]KEYC(LIGSUB)   = [F:PJCT]PCCGRP
          [M:PFOV1]PCCCOD         = AVOID.ACHAR
          [M:PFOV1]PARKEY(LIGSUB) = [M:PFOV1]KEYC(0)
          [M:PFOV1]ICO(LIGSUB)    = "Folder.gif"
          Call LECTEXTRA_SYR(TECFINOVE, AVOID.ACHAR, COLDES, "ATABDIV", "LNGDES", "386", [F:PJCT]PCCGRP) From ATEXTRA
          [M:PFOV1]OBJDES(LIGSUB) = [F:PJCT]PCCGRP - COLDES
        Endif
      Endif
    Endif
    #
    [M:PFOV1]PBUCOD(LIGSUB)       = SELBUD
    [M:PFOV1]OPPNUM(LIGSUB)       = SELPRJ
    #
    [M:PFOV1]PSCBUDQTY(LIGSUB)    = [F:PJCT]PSCBUDQTY     #COLUMN6
    [M:PFOV1]PSCBUDAMT(LIGSUB)    = [F:PJCT]PSCBUDAMT     #COLUMN7
    [M:PFOV1]PSCQTY1(LIGSUB)      = [F:PJCT]PSCQTY1       #COLUMN8
    [M:PFOV1]PSCAMT1(LIGSUB)      = [F:PJCT]PSCAMT1       #COLUMN9
    [M:PFOV1]PSCQTY2(LIGSUB)      = [F:PJCT]PSCQTY2       #COLUMN10
    [M:PFOV1]PSCAMT2(LIGSUB)      = [F:PJCT]PSCAMT2       #COLUMN11
    [M:PFOV1]PSCQTY3(LIGSUB)      = [F:PJCT]PSCQTY3       #COLUMN12
    [M:PFOV1]PSCAMT3(LIGSUB)      = [F:PJCT]PSCAMT3       #COLUMN13
    [M:PFOV1]PSCQTY4(LIGSUB)      = [F:PJCT]PSCQTY4       #COLUMN14
    [M:PFOV1]PSCAMT4(LIGSUB)      = [F:PJCT]PSCAMT4       #COLUMN15
    [M:PFOV1]PSCQTY5(LIGSUB)      = [F:PJCT]PSCQTY5       #COLUMN16
    [M:PFOV1]PSCAMT5(LIGSUB)      = [F:PJCT]PSCAMT5       #COLUMN17
    [M:PFOV1]PSCREMQTY(LIGSUB)    = [F:PJCT]PSCREMQTY     #COLUMN18
    [M:PFOV1]PSCREMAMT(LIGSUB)    = [F:PJCT]PSCREMAMT     #COLUMN19
    [M:PFOV1]PSCWIPQTY(LIGSUB)    = [F:PJCT]PSCWIPQTY     #COLUMN20
    [M:PFOV1]PSCWIPAMT(LIGSUB)    = [F:PJCT]PSCWIPAMT     #COLUMN21
    [M:PFOV1]PSCTOTQTY(LIGSUB)    = [F:PJCT]PSCTOTQTY     #COLUMN22
    [M:PFOV1]PSCTOTAMT(LIGSUB)    = [F:PJCT]PSCTOTAMT     #COLUMN23
    [M:PFOV1]PSCMARGQTY(LIGSUB)   = [F:PJCT]PSCMARGQTY    #COLUMN24
    [M:PFOV1]PSCPCTMQTY(LIGSUB)   = [F:PJCT]PSCPCTMQTY    #COLUMN25
    [M:PFOV1]PSCMARGAMT(LIGSUB)   = [F:PJCT]PSCMARGAMT    #COLUMN26
    [M:PFOV1]PSCPCTMAMT(LIGSUB)   = [F:PJCT]PSCPCTMAMT    #COLUMN27
    # ADVANCED
    [M:PFOV1]PSCQTY30(LIGSUB)      = [F:PJCT]PSCFREEC6A   #COLUMN28
    [M:PFOV1]PSCAMT30(LIGSUB)      = [F:PJCT]PSCFREEC6B   #COLUMN29
    [M:PFOV1]PSCQTY31(LIGSUB)      = [F:PJCT]PSCMARGBUD6  #COLUMN30
    [M:PFOV1]PSCAMT31(LIGSUB)      = [F:PJCT]PSCPCTMBUD6  #COLUMN31
    [M:PFOV1]PSCQTY32(LIGSUB)      = [F:PJCT]PSCMARGTOT6  #COLUMN32
    [M:PFOV1]PSCAMT32(LIGSUB)      = [F:PJCT]PSCPCTMTOT6  #COLUMN33
    [M:PFOV1]PSCQTY33(LIGSUB)      = [F:PJCT]PSCFREEC7A   #COLUMN34
    [M:PFOV1]PSCAMT33(LIGSUB)      = [F:PJCT]PSCFREEC7B   #COLUMN35
    [M:PFOV1]PSCQTY34(LIGSUB)      = [F:PJCT]PSCFREEC8A   #COLUMN36
    [M:PFOV1]PSCAMT34(LIGSUB)      = [F:PJCT]PSCFREEC8B   #COLUMN37
    [M:PFOV1]PSCQTY35(LIGSUB)      = [F:PJCT]PSCFREEC9A   #COLUMN48
    [M:PFOV1]PSCAMT35(LIGSUB)      = [F:PJCT]PSCFREEC9B   #COLUMN49
    [M:PFOV1]PSCQTY36(LIGSUB)      = [F:PJCT]PSCFREEC10A  #COLUMN40
    [M:PFOV1]PSCAMT36(LIGSUB)      = [F:PJCT]PSCFREEC10B  #COLUMN41
    [M:PFOV1]PSCESTTOTQTY(LIGSUB)  = [F:PJCT]PSCESTTOTQTY #COLUMN42
    [M:PFOV1]PSCESTTOTAMT(LIGSUB)  = [F:PJCT]PSCESTTOTAMT #COLUMN43
    LIGSUB += 1
  Next
  Filter [PJCT]
  [M:PFOV1]NBDET = LIGSUB
Return

###################################################################################################
Subprog DSPDET_WITH_STYLE()
Local Integer NI

  Affzo [M:PFOV2]10
  For NI = 0 To [M:PFOV2]NBLIG-1
    If [M:PFOV2]PBUIMP(NI) = [V]CST_AYES Then
      Chgstl [M:PFOV2]NBLIG(NI)    With ""
      Chgstl [M:PFOV2]COLUMN6(NI)  With "PJMBUD"
      Chgstl [M:PFOV2]COLUMN7(NI)  With "PJMBUD"
      Chgstl [M:PFOV2]COLUMN18(NI) With "PJMREMAINS"
      Chgstl [M:PFOV2]COLUMN19(NI) With "PJMREMAINS"
      Chgstl [M:PFOV2]COLUMN20(NI) With "PJMREMAINS"
      Chgstl [M:PFOV2]COLUMN21(NI) With "PJMREMAINS"
      Chgstl [M:PFOV2]COLUMN22(NI) With "PJMTOTAL"
      Chgstl [M:PFOV2]COLUMN23(NI) With "PJMTOTAL"
      If [M:PFOV2]COLUMN24(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN24(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN24(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN25(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN25(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN25(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN26(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN26(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN26(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN27(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN27(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN27(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN30(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN30(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN30(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN31(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN31(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN31(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN32(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN32(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN32(NI) With "PJMFINPOSV"
      Endif
      If [M:PFOV2]COLUMN33(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN33(NI) With "PJMFINNEGV"
      Else
        Chgstl [M:PFOV2]COLUMN33(NI) With "PJMFINPOSV"
      Endif
    Else
      Chgstl [M:PFOV2]NBLIG(NI)    With "PJMWHITEB"
      Chgstl [M:PFOV2]COLUMN6(NI)  With "PJMBUDB"
      Chgstl [M:PFOV2]COLUMN7(NI)  With "PJMBUDB"
      Chgstl [M:PFOV2]COLUMN18(NI) With "PJMREMAINB"
      Chgstl [M:PFOV2]COLUMN19(NI) With "PJMREMAINB"
      Chgstl [M:PFOV2]COLUMN20(NI) With "PJMREMAINB"
      Chgstl [M:PFOV2]COLUMN21(NI) With "PJMREMAINB"
      Chgstl [M:PFOV2]COLUMN22(NI) With "PJMTOTALB"
      Chgstl [M:PFOV2]COLUMN23(NI) With "PJMTOTALB"
      If [M:PFOV2]COLUMN24(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN24(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN24(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN25(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN25(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN25(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN26(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN26(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN26(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN27(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN27(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN27(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN30(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN30(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN30(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN31(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN31(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN31(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN32(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN32(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN32(NI) With "PJMFINPOSB"
      Endif
      If [M:PFOV2]COLUMN33(NI) < 0 Then
        Chgstl [M:PFOV2]COLUMN33(NI) With "PJMFINNEGB"
      Else
        Chgstl [M:PFOV2]COLUMN33(NI) With "PJMFINPOSB"
      Endif
    Endif
  Next NI
  # ----------------------------------
  Affzo [M:PFOV1]10
  For NI = 0 To [M:PFOV1]NBDET-1
    If [M:PFOV1]PCCCOD(NI) = AVOID.ACHAR Then
      Chgstl [M:PFOV1]NBDET    (NI) With "PJMWHITEB"
      Chgstl [M:PFOV1]PSCBUDQTY(NI) With "PJMBUDB"
      Chgstl [M:PFOV1]PSCBUDAMT(NI) With "PJMBUDB"
      Chgstl [M:PFOV1]PSCREMQTY(NI) With "PJMREMAINB"
