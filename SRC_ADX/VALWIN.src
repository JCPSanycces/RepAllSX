#<AdxTL>@(#)1.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
# VALWIN Programme principal
#---------------------------------------------------------------------------------------------------#

GTEST = 0
GBIDC1 = "OAUS"
GTRACE = ""
Call VALID(GBIDC1,nomap,0,GBIDI1)
End

#---------------------------------------------------------------------------------------------------#
# VALWIN        Prog principal
# VALWINLEC     Lecture en mémoire
# VALWINTRT     Ecriture du traitement WGxxx
# VALWINSUB     Sous-programmes de VALWINTRT
#---------------------------------------------------------------------------------------------------#



Subprog VALIDDIRECT(FEN,APPLI,SILENCE,MOK)
Value    Char    FEN
Value    Char    APPLI
Value    Integer SILENCE
Variable Integer MOK

Local Integer VALIDDIFF
VALIDDIFF=1
Goto VALIDWIN

#---------------------------------------------------------------------------------------------------#

Subprog VALID(FEN,APPLI,SILENCE,MOK)
Value    Char    FEN
Value    Char    APPLI
Value    Integer SILENCE
Variable Integer MOK

#  Fenêtres à exclure de la validation différée
Local Char EXCLUDDIF(200)
EXCLUDDIF=":TEMPON:TEMPON2:VALIDCAR:AASELECT:AACHOOSE:AAFORMULA:"

Local Integer VALIDDIFF
If dim(GVALIDDIFF)>0 and GVALIDDIFF=3 and instr(1,EXCLUDDIF,":"+FEN+":")<=0  and left$(FEN,8)<>"DEBUGGER":  VALIDDIFF=2 : Endif


$VALIDWIN
#  --- Pour vérifier si fenêtre à synchroniser -> revalidation des écrans qui la constitue
#      sauf si on vient déjà de ISSCREENTOGENER
If dim(COMFROMSCRTOGEN)<0 and VALIDDIFF<>2
  Call ISSCREENTOGENER(APPLI,FEN,SILENCE) From INTRUTILB
Endif


Onerrgo ERREUR
MOK = 1
Local Integer TEST : TEST = 0
If TEST
 Call OUVRE_TRACE(mess(28,126,1)-FEN) From LECFIC
Endif


If !SILENCE
 If VALIDDIFF=2
   Call TEMPON(mess(262,133,1)-FEN) From GESECRAN : # Validation différée de la fenêtre
 Else
   Call TEMPON(mess(28,126,1)-FEN) From GESECRAN : # Validation fenêtre
 Endif
Endif
If GTRACE<>""
 If VALIDDIFF=2
   Call ECR_TRACE(mess(262,133,1)-FEN,0) From GESECRAN : # Validation différée de la fenêtre
 Else
   Call ECR_TRACE(mess(84,125,1)-FEN,0) From GESECRAN : # Validation de la fenêtre
 Endif
Endif

If VALIDDIFF=2
  Call GENERDIFFWIN(APPLI,FEN) From INTRUTILB
  Goto FIN
Endif

# Pour forcer l'allocation de 1 Mo de mémoire (perfs)
Local Char FENETRE : FENETRE=FEN
Local Schar TOTO(10)(1024,100)
Local Char WE_HORDAT(14)             : # Horodatage de génération
Kill TOTO

#103231
#adxmto = max(adxmto,200)
adxmto = max(adxmto,220)

Gosub OUVFIC  From VALWINLEC
Gosub DEFVAR  From VALWINLEC

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

# Mise en mémoire des tables
Gosub LECTURE From VALWINLEC
If !OK : Goto PERDU : Endif


WE_HORDAT=JOUR+left$(HEURE,2)+mid$(HEURE,4,2)+right$(HEURE,7)

# Génération et validation du traitement WGxxx
Gosub VALTRT From VALWINTRT

Gosub VALWEB From VALWINWEB

# Pour Géode validation des interfaces
If GPRODUIT=1
 Call VALID_FENETRE(APPLI,FENETRE) From GENTRTWF
Endif

$FIN
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
If VALIDDIFF<>2
  adxifs = SAVIFS
  adxirs = SAVIRS
  adxium = SAVIUM
Endif
Onerrgo
End

$PERDU
If GMESSAGE<>""
  # Issue X3-75929 - 2018-07-26 by ALSHE : set message type depending on status
  If GERR = 3 # Warning message
    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else # Error message
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Endif
  Raz GMESSAGE
  Raz GERR
Endif
Raz MOK
Call DEL_TRTWIN(FENETRE,APPLI) From MSKDIV
Goto FIN

$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
MOK = 0
End

