#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILCOD , GNBMASKOUV
Call PASSE
End

#------------------------------------------------------------------------------------#
Subprog CHGPASSE
Local Char PARAM(30)(1..2) , VALEUR(10) , PROGSPE(GLONADC)
PARAM(1) = "1"
Call TRTSPE(nomap,"SAIPASSE",PROGSPE) From SUBACT
Call SAISIE_CHAR(VALEUR,PARAM,"FPASSE","PASSE",PROGSPE) From GSAISIE
End

#------------------------------------------------------------------------------------#
Subprog PASSE
Local Char PARAM(30)(1..2) , VALEUR(10) , PROGSPE(GLONADC)
PARAM(1) = "0"
Call TRTSPE(nomap,"SAIPASSE",PROGSPE) From SUBACT
Call SAISIE_CHAR(VALEUR,PARAM,"FPASSE","PASSE",PROGSPE) From GSAISIE
End

#------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "OK"       : Gosub OK
 When "FIN"      : Gosub FIN
 When "AP_CHOIX" : Gosub AP_CHOIX
Endcase
Return

#--------------------------------------------------------------#
$OUVRE
Local Integer STAEND
If func ARECAUO.USRSAG(GUSER)
 GMESSAGE = mess(57,134,1)-GUSER : # Fonction non autorisée à l'utilisateur
 GERR = 1 : FIN = 1 : Return
Endif
Return

#--------------------------------------------------------------#
$DEBUT
Local Integer CHANGE
CHANGE = val(PARAM(1))
Raz [M]
Return

#---------------------------------#
$AP_CHOIX
If REPONSE=GSTAEND
 STAEND = 1 
Endif
Return

#-----------------------#
$FIN
If STAEND
 GSTATUT = GSTAEND
Endif
Return

#--------------------------------------------------------------#
$OK
Call MAJ_NEWPASSE(GUSER,[M]PAS1,[M]PAS2,[M]PAS3,CHANGE,OK)
If !OK : FIN = 0 : Endif
Return

#-------------------------------------------------------------------------#
Subprog MAJ_NEWPASSE(USER,OLDPASSE,NEWPASSE1,NEWPASSE2,CHANGE,OK)
Value Char    USER , OLDPASSE , NEWPASSE1 , NEWPASSE2
Value Integer CHANGE
Variable Integer OK
Local Char    PASSE(24)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = USER
If fstat
 GMESSAGE = USER-mess(141,100,1) : # Code utilisateur inexistant
 GERR = 1 : OK = 0
Else
 Lock ="AUS"+USER With lockwait=0
 If fstat=1
  GMESSAGE = mess(30,100,1) : # Opération en cours sur un autre poste
  GERR = 1 : OK = 0
 Else
  Call VERF_PASSE(USER,[F:AUS]NEWPAS,[F:AUS]PASSE,OLDPASSE,NEWPASSE1,NEWPASSE2,CHANGE,7,OK)
  If OK
   [L]PASSE = NEWPASSE1
   GOK = 1
   Call DEBTRANS From GLOCK
   GPE = 0
   GPOINT = "CTLPASSE" : Gosub ENTREE From EXEFNC
   If GPE=0
    Gosub TR1
    If GOK<1
     OK = 0
    Else
     GMESSAGE = mess(82,100,1) : # Nouveau mot de passe enregistré
     GERR = 2 : OK = 1
    Endif
   Endif
  Endif
  Unlock ="AUS"+USER
 Endif
Endif
End

#--------------------------------------------------------------#
$TR1
Trbegin [AUS]
 Readlock [AUS]CODUSR=USER
 If fstat=1
  GOK=-1 : GLOCK="$AUTILIS"-USER : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("AUS",USER) From GLOCK : Goto AB_TR1
 Endif
 If dim([F:AUS]UPDUSR)>0 : [F:AUS]UPDUSR = USER : Endif
 If dim([F:AUS]UPDDAT)>0 : [F:AUS]UPDDAT = date$ : Endif
 If dim([F:AUS]UPDTIM)>0 : [F:AUS]UPDTIM = time : Endif
 [F:AUS]PASSE  = [L]PASSE : Call CRYPT([F:AUS]PASSE) From GESUSER : # on le garde encore pour le web
 [F:AUS]NEWPAS = [L]PASSE : Call CRYPTNEW([F:AUS]NEWPAS) From GESUSER
 [F:AUS]PASSDAT = date$
 # Here the password is definitely not a provisionnel one, so reset the indicator ISPASPROV
 If dim([F:AUS]FLGPASPRV)>=1
  [F:AUS]FLGPASPRV = 1
 Endif
 Rewrite [AUS]
 If fstat
  GOK=0 : Call FSTA("AUS") From GLOCK : Goto AB_TR1
 Endif
 Call ESPION("",7,[F:AUS]NEWPAS,"") From ESPION
 If GOK<1 : Goto AB_TR1 : Endif
Commit
#  En C/S on informe le client du changement de password pour le retour de workflow
If GBROWS=0
 Local Char NEWP(30)
 Call INCRYPT([L]PASSE,NEWP) From INTRUTILA
 Callui RETOUR="" With "UIAction=" + chr$(1) + "SessionSettings","UISetUsrPasswd=" + chr$(1) + "CRYPT:"+NEWP
Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#------------------------------------------------------------------------------------------------#
Subprog VERF_PASSE(USER,CURPASSE,ANCIENPAS,OLDPASSE,NEWPASSE1,NEWPASSE2,CHANGE,TYPPAS,OK)
Value Char    USER , CURPASSE , ANCIENPAS, OLDPASSE , NEWPASSE1 , NEWPASSE2
Value Integer CHANGE , TYPPAS
Variable Integer OK
Local Integer I , PASOBLI , PASLNG , NBNUM , NBCAR , ERP
Local Char    PASSE(24) , CAR(1) , CRYPT(24)
Local Char    ALPHA(52) , CHIFFRE(10) , CRITERE(250)
If clalev([F:ADW])=0 : Local File ADOVAL  [ADW] : Endif
If clalev([F:AES])=0 : Local File AESPION [AES] : Endif
Read [ADW]ADW0 = "";"";"PASSWD"
If !fstat : PASOBLI = val([F:ADW]VALEUR) : Endif
Read [ADW]ADW0 = "";"";"PASLNG"
If !fstat : PASLNG = val([F:ADW]VALEUR) : Endif
ALPHA   = sigma(0,25,chr$(65+indcum))+sigma(0,25,chr$(97+indcum))
CHIFFRE = sigma(0,9,chr$(48+indcum))
[L]PASSE = OLDPASSE
OK = 1
If CURPASSE<>""
 Onerrgo ERP
 Call CRYPTNEW([L]PASSE) From GESUSER
 Onerrgo
 If ERP
  GMESSAGE = mess(80,100,1)  : # Ancien mot de passe incorrect
  GERR = 1 : OK = 0
 Endif
 If CURPASSE<>[L]PASSE : OK = 0 : Endif
Else
 Call CRYPT([L]PASSE) From GESUSER
 If ANCIENPAS<>[L]PASSE : OK = 0 : Endif
Endif
If !OK
 GMESSAGE = mess(80,100,1)  : # Ancien mot de passe incorrect
 GERR = 1 : OK = 0
Elsif NEWPASSE1<>NEWPASSE2
 GMESSAGE = mess(81,100,1)  : # Les 2 mots de passe ne sont pas identiques
 GERR = 1 : OK = 0
Elsif NEWPASSE1=USER
 GMESSAGE = mess(88,139,1) : # Le mot de passe ne doit pas correspondre au code utilisateur
 GERR = 1 : OK = 0
Elsif NEWPASSE1="" & PASOBLI=2
 GMESSAGE = mess(100,100,1) : # Vous devez saisir un mot de passe
 GERR = 1 : OK = 0
Elsif NEWPASSE1<>"" & len(NEWPASSE1)<PASLNG
 GMESSAGE = mess(218,100,1)-":"-num$(PASLNG) : # Nb de caractères mini
 GERR = 1 : OK = 0
Elsif NEWPASSE1=OLDPASSE & CHANGE=1
 GMESSAGE = mess(83,100,1)  : # Vous devez changer de mot de passe
 GERR = 1 : OK = 0
Else
 [L]CRYPT = NEWPASSE1
 Onerrgo ERP
 Call CRYPTNEW([L]CRYPT) From GESUSER
 If ERP
  GMESSAGE = mess(77,130,1)  : # Caractère incorrect dans le mot de passe
  GERR = 1 : OK = 0
 Endif
 If PASOBLI=2
  CRITERE = 'ESPNAT='+num$(TYPPAS)
  CRITERE -= '& ESP1="'+[L]CRYPT+'"'
  Case TYPPAS
   When 7 : CRITERE -= '& ESPUSR="'+USER+'"'
   When 8 : CRITERE -= '& ESP2="'+USER+'"'
  Endcase
  For [AES] Where evalue(CRITERE)
   OK = 0 : Break
  Next AES
  If !OK
   GMESSAGE = mess(89,139,1) : # Ce mot de passe a déjà été utilisé
   GERR = 1 : OK = 0
  Else
   Raz NBNUM , NBCAR
   For I=1 To len(NEWPASSE1)
    CAR = mid$(NEWPASSE1,I,1)
    If instr(1,ALPHA,CAR)
     NBCAR += 1
    Elsif instr(1,CHIFFRE,CAR)
     NBNUM += 1
    Endif
   Next I
   If NBCAR & len(NEWPASSE1)=NBCAR
    GMESSAGE = mess(90,139,1) : # Le mot de passe ne doit pas être composé que de lettres
    GERR = 1 : OK = 0
   Elsif NBNUM & len(NEWPASSE1)=NBNUM
    GMESSAGE = mess(91,139,1) : # Le mot de passe ne doit pas être composé que de chiffres
    GERR = 1 : OK = 0
   Elsif NBCAR=0 & NBNUM=0
    GMESSAGE = mess(92,139,1) : # Le mot de passe ne doit pas être composé que de caractères spéciaux
    GERR = 1 : OK = 0
   Endif
  Endif
 Endif
Endif
End

$ERP
ERP = errn
Resume

#--------------------------------------------------------------------#
# Génération d'un mot de passe provisoire
#--------------------------------------------------------------------#

Subprog GEN_PASSE(USR,PASSE)
Value    Char USR
Variable Char PASSE
Local Integer PASLNG , NBCAR , NBNUM
Local Char    CAR(1) , CRYPT(24) , ALPHA(52) , CHIFFRE(10)
Local Char    CHAINE(10)
Local Integer I , J , OK
If clalev([F:AES])=0 : Local File AESPION [AES] : Endif
Call PARAM("","PASLNG",CHAINE) From ADOVAL
PASLNG  = max(val(CHAINE),5)
# On enlève le O et I pour ne pas confondre avec 0 et 1
ALPHA   = sigma(0,25,string$(find(chr$(65+indcum),"O","I")=0,chr$(65+indcum)))
# On enlève le o et l pour ne pas confondre avec 0 et 1
ALPHA  += sigma(0,25,string$(find(chr$(97+indcum),"o","l")=0,chr$(97+indcum)))
# On enlève le 0 et 1 pour ne pas confondre avec O et I
CHIFFRE = sigma(2,9,chr$(48+indcum))
OK = 0
While !OK
 [L]PASSE = sigma(1,PASLNG,mid$(ALPHA+CHIFFRE,int(rnd(len(ALPHA+CHIFFRE))+1),1))
 Raz NBNUM , NBCAR
 For I=1 To  PASLNG
  CAR = mid$([L]PASSE,I,1)
  If instr(1,ALPHA,CAR)
   NBCAR += 1
  Elsif instr(1,CHIFFRE,CAR)
   NBNUM += 1
  Endif
 Next I
 If NBCAR<>0 & NBNUM<>0 & [L]PASSE<>[L]USR
  [L]CRYPT = [L]PASSE
  Call CRYPTNEW([L]CRYPT) From GESUSER
  OK = 1
  For [AES] Where ESPNAT=7 & ESPUSR=[L]USR & ESP1=[L]CRYPT
   OK = 0 : Break
  Next AES
 Endif
Wend
End

#------------------------------------------------------------------------------------#
# Changement du mot de passe (WEB Service)
#------------------------------------------------------------------------------------#

Subprog NEWPASSE(USER,OLDPASSE,NEWPASSE,OK)
Value Char USER , OLDPASSE, NEWPASSE
Variable Integer OK
Call MAJ_NEWPASSE(USER,OLDPASSE,NEWPASSE,NEWPASSE,0,OK)
End

