#<AdxTL>@(#)7.0.0.0 $Revision$
# Gestion du masque SMBENCHW4 selon MBENCHW4
# Traitement de la fenêtre dans BENCHLIBS
# - fenêtre DPECEOX lorsque l'action SAIMODEOX est appelée sur un encours 1,2,3 ou 8

########################################
Subprog AM_PUU2(VALEUR)
#-----------------------------#
# Contrôle de l'unité d'achat #
#-----------------------------#
Variable Char    VALEUR()
#----- contrôle que l'unité d'achat convienne pour le couple article/fournisseur -----#
  Local Char WUOM(GLONUOM) : WUOM=VALEUR
  Call CTLUOM([M:SMW4]ITMREF,1,[M:SMW4]BPRNUM2,WUOM,[M:SMW4]PUUSTUCOE,
&             GBIDC2,GBIDC3,GBIDI1) From STKACT
  If mkstat  End : Endif
End


########################################
Subprog C_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

########################################
Subprog AS_QTYPUU2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If ([M:SMW4]VCRNUM = "" & [M:SMW4]BOMALT2 = 0)
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog B1_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW4]ITMREF
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY*[M:SMW4]PUUSTUCOE
End

########################################
Subprog B2_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW4]ITMREF
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY*[M:SMW4]PUUSTUCOE
End

########################################
Subprog AM_QTYPUU2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI,WAVAOFS,WQUALTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

If VALEUR = 0 : mkstat = 2 : End : Endif

# conversion de la qté UA en US
Call PCAL_QTY(VALEUR,[M:SMW4]PUU2,[M:SMW4]EXTQTY2,[M:SMW4]STU2,
&             [M:SMW4]ITMREF,[M:SMW4]BPRNUM2,1,[M:SMW4]PUUSTUCOE) From TRTACHQTE1

Call AM_EXTQTY2([M:SMW4]EXTQTY2)

End



########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If ([M:SMW4]VCRNUM = "" & [M:SMW4]BOMALT2 = 0)
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW4]ITMREF
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW4]ITMREF
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog C_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

WQTY = VALEUR

If [M:SMW4]STRDAT2 = [0/0/0] | [M:SMW4]ENDDAT2 = [0/0/0] : End : Endif

WORIFCY=[M:SMW4]PRHFCY
WLTI=0

# lecture ITF
If [F:ITF]ITMREF<>[M:SMW4]ITMREF
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : End : Endif
Endif

If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:SCI]EXTQTY - [M:SMW4]EXTQTY1 + VALEUR
Else
    WQTY = VALEUR
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WORIDAT=[M:SMW4]ENDDAT2
WMEMDAT=[M:SMW4]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:SMW4]STRDAT2) From MFGLIB

Affzo [M:SMW4]STRDAT2
Call CHECK_PAST([M:SMW4]STRDAT2, 2) From MFGLIB

End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=date$ : Endif
End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW4]POHFCY) From MFGLIB

If [M:SMW4]BOMALT2 = 0 & [F:ITM]ITMREF = [M:SMW4]ITMREF
    [M:SMW4]STRDAT2 = VALEUR
    Call RECH_NOM([M:SMW4]POHFCY, [M:SMW4]STRDAT2, [M:SMW4]BOMALT2,3) From BENCHLIB
Endif
End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY


# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# calendrier
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW4]POHFCY) From MFGLIB
#If mkstat = 2 : End : Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

WORIDAT=VALEUR
WORIFCY=[M:SMW4]POHFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
If fstat : End : Endif
WQTY = [M:SMW4]EXTQTY2
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
If WLTI>0
  # révision calendriers (llc 06.00)
  Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:SMW4]ENDDAT2) From MFGLIB
  Affzo [M:SMW4]ENDDAT2
Endif

End

########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW4]POHFCY) From MFGLIB
#If mkstat : End : Endif


End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If VALEUR < [M:SMW4]STRDAT2 : mkstat = 2 : End : Endif

  # calcul de la date de début selon date fin
    WORIDAT=VALEUR
    WORIFCY=[M:SMW4]POHFCY
    WLTI=0

    # lecture article site
    Read [ITF]ITF0=[M:SMW4]ITMREF;[M:SMW4]POHFCY
    If fstat : End : Endif
    WQTY = [M:SMW4]EXTQTY2
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI
    If [M:SMW4]STRDAT2=[0/0/0]
       # révision calendriers (llc 06.00)
       Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:SMW4]STRDAT2) From MFGLIB

       Affzo [M:SMW4]STRDAT2
       Call CHECK_PAST([M:SMW4]STRDAT2, 2) From MFGLIB
    Endif
    If [M:SMW4]BOMALT2 = 0
       Call RECH_NOM([M:SMW4]POHFCY, [M:SMW4]STRDAT2, [M:SMW4]BOMALT2,3) From BENCHLIB
    Endif

End


########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY
Local    Integer WALT

If [M:SMW4]STRDAT2=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:SMW4]STRDAT2
Endif

WFCY=[M:SMW4]POHFCY
#    Lecture BOM
Read [TBO]TBO0=3;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=[M:SMW4]ITMREF;VALEUR;3
If fstat : mkstat=2 : End : Endif
Call CONTSCONOM(WFCY,WALT,WDAT,1) From SCOLIB
If WALT=0 : mkstat=2 : End : Endif
End


########################################
Subprog AS_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Avant saisie du fournisseur                  #
#---------------------------------------------------#
Local Char       WBPS
Local Integer    WBOMALT : WBOMALT = [M:SMW4]BOMALT2
Raz WBPS

Call FIND_BPRNUM ([M:SMW4]ITMREF,WBOMALT,[M:SMW4]POHFCY,[M:SMW4]PRHFCY,VALEUR) From SCOLIB

If VALEUR = "" & WBPS <> ""
   VALEUR         = WBPS
   [M:SMW4]BPRNUM = WBPS
   Affzo [M:SMW4]BPRNUM
Endif
End

########################################
Subprog AM_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
GCUR=[F:BPR]CUR
#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE ([M:SMW4]POHFCY,VALEUR)
  If mkstat
    GERR=1 : mkstat=1 : End
  Endif
End


######################################################################################
Subprog CTRL_INTERSITE (LPOHFCY,LBPSNUM)
Variable Char    LPOHFCY
Variable Char    LBPSNUM

Local Char    WSALFCY(GLONFCY)
Local Char    WINVFCY(GLONFCY)
Local Char    WMFGFCY(GLONFCY)
Local Char    WBPCORD(GLONBPR)
Local Char    WBPCINV(GLONBPR)
Local Integer WDME

#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# LPOHFCY : Site de commande                          #
# LBPSNUM : Fournisseur de la commande                #
#-----------------------------------------------------#
If LBPSNUM="" | LPOHFCY="" : End : Endif

Raz GRCPFCY
Call CTRL_INTERSITE(LPOHFCY,LBPSNUM,2,[M:SMW4]BETFCY,[M:SMW4]BETCPY,WSALFCY,
&                   WMFGFCY,WBPCORD,WINVFCY,WBPCINV,
&                   WDME) From TRTACHCTL1
If mkstat  GERR=1 : End : Endif
#-----
# Demande LLC: afficher un libellé plutôt que BETFCY et BETCPY
If [M:SMW4]BETCPY = 2
   [M:SMW4]ZBETCPY = mess(491,197,1)
Elsif [M:SMW4]BETFCY = 2
   [M:SMW4]ZBETCPY = mess(645,197,1)
Else
   [M:SMW4]ZBETCPY = ""
Endif
Affzo [M:SMW4]ZBETCPY

End

######################################################################################
Subprog D_PRHFCY(VALEUR)
Variable Char     VALEUR
VALEUR=[M:SMW4]POHFCY
End

Subprog AS_PRHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:SMW4]POHFCY
Endif
End

Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR()
End


Subprog AM_POHFCY(VALEUR)
Variable Char    VALEUR()
# Issue 86437 GA 12/2012
#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE (VALEUR,[M:SMW4]BPRNUM2)
  If mkstat
    GERR=1 : mkstat=1 : End
  Endif
End


