#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry SMF

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "DEB_CRIT"   : Raz [M:CSMF] : Transmask [M:SMF1] To [M:CSMF]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$OUVRE
Raz GSOC_ACTIVE

  If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
  If !clalev([F:STJ2]): Local File STOJOU     [STJ2]: Endif
  If !clalev([F:SJV]) : Local File STOJOUVAL  [SJV] : Endif
  If !clalev([F:SMC]) : Local File STOMVTCOST [SMC] : Endif
  If !clalev([F:CGVD]): Local File CGVDET     [CGVD]: Endif
  If !clalev([F:STP]) : Local File STOCOST    [STP] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITV]) : Local File ITMMVT     [ITV] : Endif
  If !clalev([F:STO]) : Local File STOCK      [STO] : Endif
  If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
  If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
  If !clalev([F:TFO]) : Local File TABFOR     [TFO] : Endif
  If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
  If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
  If !clalev([F:SRU]) : Local File TABSTORUL  [SRU] : Endif

  If GMODU(2)=2 : # If module counts active
    If !clalev([F:GCM])    Local File GACM       [GCM] : Endif
  Endif

  Local Mask CONSSMF2 [SMFT]

  # Loading global indexes, accounts and sections of society
  GFCY=GFCYDEF(7)
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
  [M:SMF1]CUR=GLOCALDEV
  GORITITCOL=1

  Local Char    WFIL1(250),WFIL2(250), WFILF(250), DATE_RANGE(250)
  Local Integer LRECEIPT, LINE_NUM
  Local Integer WSKIP, WLIG, WPAGE, WSTL #Paging variables
  Local Decimal PRE_STO, PRE_AMT
  Local Integer I, J, SMFT_SIZE
  Local Integer WOK

  Local Integer BRK

  #Array variables are used to group together all of the issues and value changes for each receipt
  # and them sort them internally before dumping them into the screen. This is necessary because we
  # can't do a propper sort on a screen and the only other alternative is creating a temp table,
  # writting all the records to that table, sorting the table, and then reading them all back.

#activity code just in case
  Local Char     LSTOFCY(GLONFCY)(1..), LITMREF(GLONITM)(1..), LCSTTIM(10)(1..), LSTU(GLONUOM)(1..), LSTA(GLONSTA)(1..)
  Local Char     LWRH(GLONWRH)(1..), LLOC(GLONLOC)(1..), LPALNUM(GLONPAL)(1..), LCTRNUM(GLONCTR)(1..), LMVTDES(GLONDES)(1..)
  Local Char     LPJT(GLONPJT)(1..), LVCRNUM(GLONVCR)(1..), LVCRNUMORI(GLONVCR)(1..), LTRSFAM(GLONTRS)(1..), LNUMVCR(GLONVCR)(1..)
  Local Char     LGTE(GLONGTE)(1..), LOWNER(GLONBPF)(1..), LCREUSR(GLONAUS)(1..), LCRETIM(10)(1..), LCREMVTTIM(10)(1..)
  Local Integer  LCSTCOU(1..), LMVTSEQ(1..), LMVTIND(1..), LUPDCOD(1..), LTRSTYP(1..), LVCRTYP(1..), LVCRLIN(1..)
  Local Integer  LBETCPY(1..), LCREMVTSEQ(1..), LVCRTYPORI(1..), LVCRLINORI(1..), LPITVALFLG(1..), LPRINAT(1..)
  Local Decimal  LQTYSTU(1..), LAMTORD(1..), LAMTVAL(1..), LVARORD(1..), LVARVAL(1..), LAMTDEV(1..), LMVTIND(1..), LMVTSEQ(1..)
  Local Decimal  LBEFSTO(1..), LAFTSTO(1..), LBEFAMT(1..), LAFTAMT(1..), LACTQTY(1..)
  Local Decimal  LPRIORD(1..), LAMTDEV(1..), LPOT(1..), LPRIVAL(1..), LPOT(1..)
  Local Date     LIPTDAT(1..), LCSTDAT(1..), LACCDAT(1..), LCREDAT(1..), LCREMVTDAT(1..)
  Local Datetime LCREDATTIM(1..)

  If dim([M:SMFT]WRH) > 0
    Local Char LWRH(GLONWRH)(1..)
  Else
    Local Char LWRH(5)(1..)
  Endif
  If dim([M:SMFT]LOC) > 0
    Local Char LLOC(GLONLOC)(1..)
  Else
    Local Char LLOC(5)(1..)
  Endif
  If dim([M:SMFT]PALNUM) > 0
    Local Char LPALNUM(GLONPAL)(1..)
  Else
    Local Char LPALNUM(5)(1..)
  Endif
  If dim([M:SMFT]CTRNUM) > 0
    Local Char LCTRNUM(GLONCTR)(1..)
  Else
    Local Char LCTRNUM(5)(1..)
  Endif


  [M:SMF1]SRTCOD = 7
  [M:SMF1]MISFLG = 1

  NAVIG="CONSSMF"
  SUITE  = 1
  RETOUR = 1

  #Set default rules for line color formating
  If [M:SMF1]NBFOR=0
    [M:SMF1]FORASY([M:SMF1]NBFOR) = "[M:SMF2]AFTSTO(nolign-1)<0"
    [M:SMF1]CODSTL([M:SMF1]NBFOR) = "BACKRED"
    [M:SMF1]CODZON([M:SMF1]NBFOR) = "AFTSTO"
    [M:SMF1]NBFOR+=1
    [M:SMF1]FORASY([M:SMF1]NBFOR) = "[M:SMF2]IPTDAT(nolign-1)<>[M:SMF2]CREDAT(nolign-1)"
    [M:SMF1]CODSTL([M:SMF1]NBFOR) = "BACKORANGE"
    [M:SMF1]CODZON([M:SMF1]NBFOR) = "IPTDAT"
    [M:SMF1]NBFOR+=1
  Endif

  #This handles the formating of lines based on criteria above
  Call GENTRT(WOK)
  If WOK
    FIN=1
  Endif

Return

############################################################
$LOAD_FILTER
  Raz WFIL1

  If [M:SMF1]SRTCOD = 0
    [M:SMF1]SRTCOD =9
  Endif

  WFIL1 = "[F]STOFCY=[M:SMF1]FCY"
  If [M:SMF1]UPDFLG <> 2
    WFIL1 += "&[F]UPDCOD=2"
  Else
    WFIL1 += "&[F]UPDCOD=1"
  Endif

  WFIL1 += " &[F]ITMREF=[M:SMF1]ITMREF"

  WFIL1 += " &[F]CSTDAT=[M:SMF1]REFDAT"

  WFIL2 = "[F]TRSTYP<>0"

  If [M:SMF1]MISFLG <> 2
    WFIL2 += " &!find([F]TRSTYP,7,8,9,21,25)"
  Endif

  WFIL2 += " & [F]REGFLG = 1"

  # Filter formula
  WFILF = "1=1"
  If [M:SMF1]SELFOR <> ""
    Read [TFO]TFO0=11;[M:SMF1]SELFOR
    If fstat = 0
      WFILF = [F:TFO]FORFOR
    Endif
  Endif

Return

############################################################
#This handles the formating of lines based on the criteria screen
Subprog GENTRT(PRET)
Variable Integer PRET

  Local Integer I
  Local Char TRTGEN(20),FICTRT(250)
  Local Char SAV_IFS(10), SAV_IRS(10)

  TRTGEN="WCNSSMFSTD"
  FICTRT=filpath('TRT',TRTGEN,'src',nomap)

  SAV_IFS = adxifs # backup of separator system variables
  SAV_IRS = adxirs
  adxifs = ""
  adxirs = chr$(10)

  Openo FICTRT , 0
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.0  $"
  Wrseq
  Wrseq "Subprog AFFSTL(PSTL,PLIG)"
  Wrseq "Value Integer PSTL"
  Wrseq "Value Integer PLIG"
  Wrseq "Case PSTL"

  For I=0 To [M:SMF1]NBFOR-1
  Wrseq "    When "+num$(I)+" :Chgstl [M:SMF2]"+[M:SMF1]CODZON(I)+"(PLIG) With ''  : Chgstl [M:SMF2]"+[M:SMF1]CODZON(I)+"(PLIG) With '"+[M:SMF1]CODSTL(I)+"'"
  Next
  Wrseq "Endcase"
  Wrseq "End"

  adxifs = SAV_IFS
  adxirs = SAV_IRS
  Call VALID("TRT",TRTGEN,nomap,PRET) From VALMSKSUB
  If PRET = 0
      PRET=2
      Call ERREUR(mess(20,123,1)) From GESECRAN    #Process validation error
  Else
      Raz PRET
  Endif

End

############################################################
#Moves everything from criteria window to main window
$FIN_CRIT
  [M:SMF1] = [M:CSMF]
  Call GENTRT(GBIDI1) #sets the formating for the lines
Return

############################################################
$LECTURE

  If [M:SMF1]ITMREF = ""
    NBLU = 0
    Return
  Endif

  SUITE  = 0
  RETOUR = 0
  [M:SMF2]NBLIG=0
  LCSTCOU = -1
  Raz nolign

  #Handles paging requests
  Case CHGPAG
    When 1 : #Search
      WSKIP=0
      WPAGE=0
      Gosub ADDLIN
      NOL+=nolign
      WPAGE += 1
      RETOUR = 1
      If nolign < MAXLIG
        SUITE = 1
      Endif
    When 2 : #Next
      WSKIP = WPAGE * MAXLIG
      Gosub ADDLIN
      NOL+=nolign
      WPAGE += 1
      If nolign < MAXLIG
        SUITE = 1
      Endif
    When -1 : #Last
      WLIG=0
      WLIG = rowcount([STJ])
      If mod(WLIG,MAXLIG) = 0
        WPAGE = int(WLIG/MAXLIG)
      Else
        WPAGE = int(WLIG/MAXLIG)+1
      Endif
      WSKIP  = (WPAGE-1) * MAXLIG
      Gosub ADDLIN
      If WPAGE = 1
        RETOUR = 1
      Endif
      SUITE  = 1
      CHGPAG=2
      NOL=nolign-1
    When -2 : #Back
      WPAGE -= 1
      WSKIP  = (WPAGE-1) * MAXLIG
      Gosub ADDLIN
      NOL    = 0
      If WPAGE = 1
        RETOUR = 1
      Endif
  Endcase

  [M:SMF2]NBLIG = max(0,min(nolign,MAXLIG))

  If CHGPAG=1
    Affzo [M:SMF2]
  Endif

  # Highlighting styles
  WOK=1
  Chgstl [M:SMF2] With ""

  Onerrgo ERR_FOR
  For nolign=1 To [M:SMF2]NBLIG
    If [M:SMF2]QTYSTU(nolign-1) < 0
      Chgstl [M:SMF2]QTYSTU(nolign-1) With ''
      Chgstl [M:SMF2]QTYSTU(nolign-1) With 'AWARNHIGH'
    Endif

    For WSTL=0 To [M:SMF1]NBFOR-1
      If WOK
        If !sigma(0,WSTL-1,[M:SMF1]CODZON(indcum)=[M:SMF1]CODZON(WSTL)) & evalue([M:SMF1]FORASY(WSTL))
          Call AFFSTL(WSTL,nolign-1) From WCNSSMFSTD
        Endif
      Else
        Break 2
      Endif
    Next
  Next
  Onerrgo

  Affzo [M:SMF2]
Return

############################################################
$ERR_FOR
    Call ERREUR(errmes$(errn)+"\"+[M:SMF1]FORASY(WSTL)) From GESECRAN
    WOK=0
Resume

#############################################################
$ADDLIN
#Fill everything in the correct order before we display the current page
#ADDLIN2 will determine if it needs to be in ascending or descending order

  Local Char STJ(10)
  SMFT_SIZE = 0
  Gosub RAZ_ARRAYS
  Raz [M:SMFT]

  Gosub LOAD_FILTER

  #Look at all receipts
  Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & QTYSTU >0 & REGFLG = 1
&                Order By CSTDAT Asc; CSTTIM Asc; CREDAT Asc; CRETIM Asc; IPTDAT Asc; MVTSEQ

  LINE_NUM = 0

  For [F:STJ]

    If LINE_NUM = 0 or [F:STJ]CSTCOU <> LCSTCOU(LINE_NUM)
      LINE_NUM += 1
      If LINE_NUM <> 1
        Gosub SORT_ARRAY
        Gosub LOAD_TEMP_SCREEN
      Endif
      Gosub RAZ_ARRAYS

      Gosub LOAD_SMC
      Gosub LOAD_CGVD
#      LINE_NUM += 1
    Endif

    STJ = "[F:STJ]"
    Gosub LOAD_FROM_STOJOU


  Next

  Gosub SORT_ARRAY
  Gosub LOAD_TEMP_SCREEN

  Gosub ADDLIN2

Return

#############################################################
$LOAD_SMC #Look for all issue records for this tier in [SMC] and dump their info into a new array index

  For [F:SMC] Where [F:SMC]CSTCOU = [F:STJ]CSTCOU and [F:SMC]CSTDAT = [F:STJ]CSTDAT  and [F:SMC]ITMREF = [F:STJ]ITMREF
    Filter [F:STJ2] Where [F:STJ2]VCRTYP = [F:SMC]VCRTYP and [F:STJ2]VCRNUM = [F:SMC]VCRNUM and [F:STJ2]VCRLIN = [F:SMC]VCRLIN and
&                         [F:STJ2]ITMREF = [F:SMC]ITMREF and [F:STJ2]REGFLG = 1
    Read [F:STJ2] First
    STJ = "[F:STJ2]"
    Gosub LOAD_FROM_STOJOU
    Filter [F:STJ2]
    LCSTDAT(LINE_NUM)  = [F:SMC]CSTDAT
    LCSTTIM(LINE_NUM)  = [F:SMC]CSTTIM
    LCSTCOU(LINE_NUM)  = [F:SMC]CSTCOU

    If dim([F:STJ2]POT) > 0 and [F:STJ2]POT <> 0
      LQTYSTU(LINE_NUM)  = -[F:SMC]QTYSTU / ([F:STJ2]POT/100) #Potency is stored as a whole number, so 80% is stored as 80, not 0.8 ... for some reason
    Else
      LQTYSTU(LINE_NUM)  = -[F:SMC]QTYSTU
    Endif
    LACTQTY(LINE_NUM)  = -[F:SMC]QTYSTU
    LAMTVAL(LINE_NUM)  = -[F:SMC]CST
    LVARORD(LINE_NUM)  = -[F:SMC]CST
    LVARVAL(LINE_NUM)  = -[F:SMC]CST
    LAMTORD(LINE_NUM)  = -[F:SMC]CST

    LPRIVAL(LINE_NUM)  = [F:SMC]CST / [F:SMC]QTYSTU
    LPRIORD(LINE_NUM)  = [F:SMC]CST / [F:SMC]QTYSTU
    LINE_NUM += 1
  Next
Return
#############################################################
$LOAD_CGVD #Look for all change val records for this tier in [CGV] and dump their info into a new array index

  Filter [F:CGVD] Where [F:CGVD]CSTTIM = [F:STJ]CSTTIM and [F:CGVD]CSTDAT = [F:STJ]CSTDAT and
&                       [F:CGVD]CSTCOU = [F:STJ]CSTCOU and CGVTYP = 2

  For [F:CGVD]
    Filter [F:STJ2] Where [F:STJ2]TRSTYP = 23 and [F:STJ2]VCRNUM = [F:CGVD]CGVNUM and [F:STJ2]REGFLG = 1
    Read [F:STJ2] First
    If fstat : Goto NEXT_CGVD : Endif
    STJ = "[F:STJ2]"
    Gosub LOAD_FROM_STOJOU
    Filter [F:STJ2]

    #Dont create a line if there was no changes done. creating a value change for a specific tier
    # will create a record for all available tiers.
    If [F:CGVD]ACTQTY = [F:CGVD]ACTQTYORI and [F:CGVD]AMT = [F:CGVD]AMTORI
      Goto $NEXT_CGVD
    Endif

    LCSTDAT(LINE_NUM)  = [F:CGVD]CSTDAT
    LCSTTIM(LINE_NUM)  = [F:CGVD]CSTTIM
    LCSTCOU(LINE_NUM)  = [F:CGVD]CSTCOU

#    LQTY = [F:CGVD]ACTQTY - [F:CGVD]ACTQTYORI
#    LCST = [F:CGVD]AMT    - [F:CGVD]AMTORI

    LQTYSTU(LINE_NUM)  = [F:CGVD]ACTQTY - [F:CGVD]ACTQTYORI
    LACTQTY(LINE_NUM)  = [F:CGVD]ACTQTY - [F:CGVD]ACTQTYORI
    LAMTVAL(LINE_NUM)  = [F:CGVD]AMT - [F:CGVD]AMTORI
    LVARORD(LINE_NUM)  = LAMTVAL(LINE_NUM)
    LVARVAL(LINE_NUM)  = LAMTVAL(LINE_NUM)
    LAMTORD(LINE_NUM)  = LAMTVAL(LINE_NUM)
    If LQTYSTU(LINE_NUM) <> 0
      LPRIVAL(LINE_NUM)  = LAMTVAL(LINE_NUM) / LQTYSTU(LINE_NUM)
      LPRIORD(LINE_NUM)  = LAMTVAL(LINE_NUM) / LQTYSTU(LINE_NUM)
    Else
      LPRIVAL(LINE_NUM)  = 0
      LPRIORD(LINE_NUM)  = 0
    Endif
    LINE_NUM += 1

    $NEXT_CGVD
  Next
  Filter [F:CGVD]
Return
#############################################################
$SORT_ARRAY #Do a SORTA command on all the array fields, order by CSTDAT>CSTTIM>CSTCOU>IPTDAT>MVTDAT>MVTTIM

  Sorta maxtab(LCSTCOU)
&    LCSTDAT, LCSTTIM, LCSTCOU, LIPTDAT, LCREMVTDAT,LCREMVTTIM,
&    LMVTSEQ, LACCDAT,  LITMREF, LSTOFCY, LCSTTIM, LTRSTYP,
&    LVCRNUM, LVCRLIN, LQTYSTU, LAMTVAL, LVARORD, LVARVAL,
&    LAMTORD, LAMTDEV, LPRIORD, LVCRTYPORI, LVCRNUMORI, LVCRLINORI,
&    LCREDAT, LCRETIM, LCREMVTSEQ, LCREDATTIM, LVCRTYP,
&    LOWNER,  LWRH, LPJT, LGTE, LBETCPY, LLOC, LMVTSEQ,
&    LMVTIND, LPALNUM, LCREUSR, LPOT, LSTU, LCTRNUM,
&    LTRSFAM, LUPDCOD, LSTA, LMVTDES, LNUMVCR, LPITVALFLG,
&    LBEFAMT, LAFTAMT, LBEFSTO, LAFTSTO, LPRIVAL, LACTQTY

Return
#############################################################
$LOAD_TEMP_SCREEN
  For INDEX = 1 To maxtab(LCSTCOU)
    SMFT_SIZE += 1
    [M:SMFT]ACCDAT(SMFT_SIZE-1)    = LACCDAT(INDEX)
    [M:SMFT]IPTDAT(SMFT_SIZE-1)    = LIPTDAT(INDEX)

    [M:SMFT]STOFCY(SMFT_SIZE-1)    = LSTOFCY(INDEX)

    [M:SMFT]CSTCOU(SMFT_SIZE-1)    = LCSTCOU(INDEX)
    [M:SMFT]CSTDAT(SMFT_SIZE-1)    = LCSTDAT(INDEX)
    [M:SMFT]CSTTIM(SMFT_SIZE-1)    = LCSTTIM(INDEX)

    [M:SMFT]TRSTYP(SMFT_SIZE-1)    = LTRSTYP(INDEX)
    [M:SMFT]VCRTYP(SMFT_SIZE-1)    = LVCRTYP(INDEX)
    [M:SMFT]VCRNUM(SMFT_SIZE-1)    = LVCRNUM(INDEX)
    [M:SMFT]VCRLIN(SMFT_SIZE-1)    = LVCRLIN(INDEX)
    [M:SMFT]PRINAT(SMFT_SIZE-1)    = LPRINAT(INDEX)

    [M:SMFT]QTYSTU(SMFT_SIZE-1)    = LQTYSTU(INDEX)
    [M:SMFT]ACTQTY(SMFT_SIZE-1)    = LACTQTY(INDEX)
    [M:SMFT]AMTVAL(SMFT_SIZE-1)    = LAMTVAL(INDEX)
    [M:SMFT]VARORD(SMFT_SIZE-1)    = LVARORD(INDEX)
    [M:SMFT]VARVAL(SMFT_SIZE-1)    = LVARVAL(INDEX)
    [M:SMFT]AMTORD(SMFT_SIZE-1)    = LAMTORD(INDEX)
    [M:SMFT]AMTDEV(SMFT_SIZE-1)    = LAMTDEV(INDEX)
    [M:SMFT]PRIORD(SMFT_SIZE-1)    = LPRIORD(INDEX)
    [M:SMFT]PRIVAL(SMFT_SIZE-1)    = LPRIVAL(INDEX)


    [M:SMFT]VCRTYPORI(SMFT_SIZE-1) = LVCRTYPORI(INDEX)
    [M:SMFT]VCRNUMORI(SMFT_SIZE-1) = LVCRNUMORI(INDEX)
    [M:SMFT]VCRLINORI(SMFT_SIZE-1) = LVCRLINORI(INDEX)

    [M:SMFT]CREDAT(SMFT_SIZE-1)    = LCREMVTDAT(INDEX)
    [M:SMFT]CRETIM(SMFT_SIZE-1)    = LCREMVTTIM(INDEX)
    [M:SMFT]CREMVTTIM(SMFT_SIZE-1) = LCREMVTTIM(INDEX)
    [M:SMFT]CREMVTDAT(SMFT_SIZE-1) = LCREMVTDAT(INDEX)
    [M:SMFT]CREMVTSEQ(SMFT_SIZE-1) = LCREMVTSEQ(INDEX)
    [M:SMFT]OWNER(SMFT_SIZE-1)     = LOWNER(INDEX)

    [M:SMFT]PJT(SMFT_SIZE-1)       = LPJT(INDEX)
    [M:SMFT]GTE(SMFT_SIZE-1)       = LGTE(INDEX)
    [M:SMFT]BETCPY(SMFT_SIZE-1)    = LBETCPY(INDEX)
    [M:SMFT]MVTSEQ(SMFT_SIZE-1)    = LMVTSEQ(INDEX)
    [M:SMFT]MVTIND(SMFT_SIZE-1)    = LMVTIND(INDEX)
    [M:SMFT]CREUSR(SMFT_SIZE-1)    = LCREUSR(INDEX)
    [M:SMFT]STU(SMFT_SIZE-1)       = LSTU(INDEX)
    [M:SMFT]TRSFAM(SMFT_SIZE-1)    = LTRSFAM(INDEX)
    [M:SMFT]STA(SMFT_SIZE-1)       = LSTA(INDEX)
    [M:SMFT]MVTDES(SMFT_SIZE-1)    = LMVTDES(INDEX)
    [M:SMFT]NUMVCR(SMFT_SIZE-1)    = LNUMVCR(INDEX)
    [M:SMFT]PITVALFLG(SMFT_SIZE-1) = LPITVALFLG(INDEX)

    If dim([M:SMFT]WRH) > 0
      [M:SMFT]WRH(SMFT_SIZE-1)     = LWRH(INDEX)
    Endif
    If dim([M:SMFT]LOC) > 0
      [M:SMFT]LOC(SMFT_SIZE-1)     = LLOC(INDEX)
    Endif
    If dim([M:SMFT]PALNUM) > 0
      [M:SMFT]PALNUM(SMFT_SIZE-1)  = LPALNUM(INDEX)
    Endif
    If dim([M:SMFT]CTRNUM) > 0
      [M:SMFT]CTRNUM(SMFT_SIZE-1)  = LCTRNUM(INDEX)
    Endif
    If dim([M:SMFT]POT) > 0
      [M:SMFT]POT(SMFT_SIZE-1)     = LPOT(INDEX)
    Endif

    If(INDEX = 1)
      [M:SMFT]BEFAMT(SMFT_SIZE-1)  = 0
      [M:SMFT]AFTAMT(SMFT_SIZE-1)  = [M:SMFT]AMTORD(SMFT_SIZE-1)
      [M:SMFT]BEFSTO(SMFT_SIZE-1)  = 0
      [M:SMFT]AFTSTO(SMFT_SIZE-1)  = [M:SMFT]ACTQTY(SMFT_SIZE-1)
    Else
      [M:SMFT]BEFAMT(SMFT_SIZE-1)  = [M:SMFT]AFTAMT(SMFT_SIZE-2)
      [M:SMFT]AFTAMT(SMFT_SIZE-1)  = [M:SMFT]AFTAMT(SMFT_SIZE-2) + [M:SMFT]AMTORD(SMFT_SIZE-1)
      [M:SMFT]BEFSTO(SMFT_SIZE-1)  = [M:SMFT]AFTSTO(SMFT_SIZE-2)
      [M:SMFT]AFTSTO(SMFT_SIZE-1)  = [M:SMFT]AFTSTO(SMFT_SIZE-2) + [M:SMFT]ACTQTY(SMFT_SIZE-1)
    Endif
  Next
Return

#############################################################
$RAZ_ARRAYS

  Raz LACCDAT, LIPTDAT, LITMREF, LSTOFCY, LCSTCOU, LCSTDAT
  Raz LCSTTIM, LTRSTYP, LVCRTYP, LVCRNUM, LVCRLIN, LQTYSTU
  Raz LAMTVAL, LVARORD, LVARVAL, LAMTORD, LAMTDEV, LPRIORD
  Raz LVCRTYPORI, LVCRNUMORI, LVCRLINORI, LCREDAT, LCRETIM
  Raz LCREMVTTIM, LCREMVTDAT, LCREMVTSEQ, LOWNER, LWRH
  Raz LPJT, LGTE, LBETCPY, LLOC, LMVTSEQ, LMVTIND, LPALNUM
  Raz LCREUSR, LPOT, LSTU, LCTRNUM, LTRSFAM, LUPDCOD, LSTA
  Raz LMVTDES, LNUMVCR, LPITVALFLG, LBEFAMT, LAFTAMT, LBEFSTO
  Raz LAFTSTO, LCREDATTIM, LPRIVAL, LACTQTY

  LINE_NUM = 1

Return

#############################################################
$LOAD_FROM_STOJOU

  LACCDAT(LINE_NUM)    = evalue(STJ+"ACCDAT")
  LIPTDAT(LINE_NUM)    = evalue(STJ+"IPTDAT")
  LITMREF(LINE_NUM)    = evalue(STJ+"ITMREF")
  LSTOFCY(LINE_NUM)    = evalue(STJ+"STOFCY")

  LCSTCOU(LINE_NUM)    = evalue(STJ+"CSTCOU")
  LCSTDAT(LINE_NUM)    = evalue(STJ+"CSTDAT")
  LCSTTIM(LINE_NUM)    = evalue(STJ+"CSTTIM")

  LTRSTYP(LINE_NUM)    = evalue(STJ+"TRSTYP")
  LVCRTYP(LINE_NUM)    = evalue(STJ+"VCRTYP")
  LVCRNUM(LINE_NUM)    = evalue(STJ+"VCRNUM")
  LVCRLIN(LINE_NUM)    = evalue(STJ+"VCRLIN")
  LPRINAT(LINE_NUM)    = evalue(STJ+"PRINAT")

  LQTYSTU(LINE_NUM)   += evalue(STJ+"QTYSTU")
  LACTQTY(LINE_NUM)   += evalue(STJ+"ACTQTY")
  LAMTVAL(LINE_NUM)   += evalue(STJ+"AMTVAL")
  LVARORD(LINE_NUM)   += evalue(STJ+"VARORD")
  LVARVAL(LINE_NUM)   += evalue(STJ+"VARVAL")
  LAMTORD(LINE_NUM)   += evalue(STJ+"AMTORD")
  LAMTDEV(LINE_NUM)   += evalue(STJ+"AMTDEV")
  LPRIORD(LINE_NUM)    = evalue(STJ+"PRIORD")
  LPRIVAL(LINE_NUM)    = evalue(STJ+"PRIVAL")

  LVCRTYPORI(LINE_NUM) = evalue(STJ+"VCRTYPORI")
  LVCRNUMORI(LINE_NUM) = evalue(STJ+"VCRNUMORI")
  LVCRLINORI(LINE_NUM) = evalue(STJ+"VCRLINORI")

  LCREDAT(LINE_NUM)    = evalue(STJ+"CREDAT")
  LCRETIM(LINE_NUM)    = evalue(STJ+"CRETIM")
  LCREDATTIM(LINE_NUM) = evalue(STJ+"CREDATTIM")
  LCREMVTTIM(LINE_NUM) = evalue(STJ+"CREMVTTIM")
  LCREMVTDAT(LINE_NUM) = evalue(STJ+"CREMVTDAT")
  LCREMVTSEQ(LINE_NUM) = evalue(STJ+"CREMVTSEQ")
  LOWNER(LINE_NUM)     = evalue(STJ+"OWNER")


  LPJT(LINE_NUM)       = evalue(STJ+"PJT")
  LGTE(LINE_NUM)       = evalue(STJ+"GTE")
  LBETCPY(LINE_NUM)    = evalue(STJ+"BETCPY")

  LMVTSEQ(LINE_NUM)    = evalue(STJ+"MVTSEQ")
  LMVTIND(LINE_NUM)    = evalue(STJ+"MVTIND")

  LCREUSR(LINE_NUM)    = evalue(STJ+"CREUSR")

  LSTU(LINE_NUM)       = evalue(STJ+"STU")

  LTRSFAM(LINE_NUM)    = evalue(STJ+"TRSFAM")
  LUPDCOD(LINE_NUM)    = evalue(STJ+"UPDCOD")
  LSTA(LINE_NUM)       = evalue(STJ+"STA")
  LMVTDES(LINE_NUM)    = evalue(STJ+"MVTDES")
  LNUMVCR(LINE_NUM)    = evalue(STJ+"NUMVCR")
  LPITVALFLG(LINE_NUM) = evalue(STJ+"PITVALFLG")

  If dim([M:SMF2]WRH) > 0
    LWRH(LINE_NUM)     = evalue(STJ+"WRH")
  Endif
  If dim([M:SMF2]LOC) > 0
    LLOC(LINE_NUM)     = evalue(STJ+"LOC")
  Endif
  If dim([M:SMF2]PALNUM) > 0
    LPALNUM(LINE_NUM)  = evalue(STJ+"PALNUM")
  Endif
  If dim([M:SMF2]CTRNUM) > 0
    LCTRNUM(LINE_NUM)  = evalue(STJ+"CTRNUM")
  Endif
  If dim([M:SMF2]POT) > 0
    LPOT(LINE_NUM)     = evalue(STJ+"POT")
  Endif

Return

############################################################
$ADDLIN2
  Local Integer INDEX
  Raz INDEX

  For WLIG = 0 To SMFT_SIZE -1
    If WLIG >= WSKIP
      If nolign < MAXLIG
        Gosub LOAD_LINES
        NBLU = 2
      Else
        BRK = 1
        Return
      Endif
    Endif
  Next
Return

############################################################
$LOAD_LINES
  nolign += 1

  #Set index for either ascending or descending order
  If [M:SMF1]SRTCOD=9
    INDEX = WLIG
  Else
    INDEX = SMFT_SIZE-WLIG-1
  Endif

  [M:SMF2]ACCDAT(nolign-1)    = [M:SMFT]ACCDAT(INDEX)
  [M:SMF2]IPTDAT(nolign-1)    = [M:SMFT]IPTDAT(INDEX)

  [M:SMF2]STOFCY(nolign-1)    = [M:SMFT]STOFCY(INDEX)

  [M:SMF2]CSTCOU(nolign-1)    = [M:SMFT]CSTCOU(INDEX)
  [M:SMF2]CSTDAT(nolign-1)    = [M:SMFT]CSTDAT(INDEX)
  [M:SMF2]CSTTIM(nolign-1)    = [M:SMFT]CSTTIM(INDEX)

  [M:SMF2]TRSTYP(nolign-1)    = [M:SMFT]TRSTYP(INDEX)
  [M:SMF2]VCRTYP(nolign-1)    = [M:SMFT]VCRTYP(INDEX)
  [M:SMF2]VCRNUM(nolign-1)    = [M:SMFT]VCRNUM(INDEX)
  [M:SMF2]VCRLIN(nolign-1)    = [M:SMFT]VCRLIN(INDEX)
  [M:SMF2]PRINAT(nolign-1)    = [M:SMFT]PRINAT(INDEX)


  [M:SMF2]QTYSTU(nolign-1)    = [M:SMFT]QTYSTU(INDEX)
  [M:SMF2]ACTQTY(nolign-1)    = [M:SMFT]ACTQTY(INDEX)
  [M:SMF2]AMTVAL(nolign-1)    = [M:SMFT]AMTVAL(INDEX)
  [M:SMF2]VARORD(nolign-1)    = [M:SMFT]VARORD(INDEX)
  [M:SMF2]VARVAL(nolign-1)    = [M:SMFT]VARVAL(INDEX)
  [M:SMF2]AMTORD(nolign-1)    = [M:SMFT]AMTORD(INDEX)
  [M:SMF2]AMTDEV(nolign-1)    = [M:SMFT]AMTDEV(INDEX)
  [M:SMF2]PRIORD(nolign-1)    = [M:SMFT]PRIORD(INDEX)
  [M:SMF2]PRIVAL(nolign-1)    = [M:SMFT]PRIVAL(INDEX)

  [M:SMF2]VCRTYPORI(nolign-1) = [M:SMFT]VCRTYPORI(INDEX)
  [M:SMF2]VCRNUMORI(nolign-1) = [M:SMFT]VCRNUMORI(INDEX)
  [M:SMF2]VCRLINORI(nolign-1) = [M:SMFT]VCRLINORI(INDEX)

  [M:SMF2]CREDAT(nolign-1)    = [M:SMFT]CREMVTDAT(INDEX)
  [M:SMF2]CRETIM(nolign-1)    = [M:SMFT]CREMVTTIM(INDEX)
  [M:SMF2]CREMVTTIM(nolign-1) = [M:SMFT]CREMVTTIM(INDEX)
  [M:SMF2]CREMVTDAT(nolign-1) = [M:SMFT]CREMVTDAT(INDEX)
  [M:SMF2]CREMVTSEQ(nolign-1) = [M:SMFT]CREMVTSEQ(INDEX)
  [M:SMF2]OWNER(nolign-1)     = [M:SMFT]OWNER(INDEX)

  [M:SMF2]PJT(nolign-1)       = [M:SMFT]PJT(INDEX)
  [M:SMF2]GTE(nolign-1)       = [M:SMFT]GTE(INDEX)
  [M:SMF2]BETCPY(nolign-1)    = [M:SMFT]BETCPY(INDEX)
  [M:SMF2]MVTSEQ(nolign-1)    = [M:SMFT]MVTSEQ(INDEX)
  [M:SMF2]MVTIND(nolign-1)    = [M:SMFT]MVTIND(INDEX)
  [M:SMF2]CREUSR(nolign-1)    = [M:SMFT]CREUSR(INDEX)
  [M:SMF2]STU(nolign-1)       = [M:SMFT]STU(INDEX)
  [M:SMF2]TRSFAM(nolign-1)    = [M:SMFT]TRSFAM(INDEX)

  [M:SMF2]STA(nolign-1)       = [M:SMFT]STA(INDEX)
  [M:SMF2]MVTDES(nolign-1)    = [M:SMFT]MVTDES(INDEX)
  [M:SMF2]NUMVCR(nolign-1)    = [M:SMFT]NUMVCR(INDEX)
  [M:SMF2]PITVALFLG(nolign-1) = [M:SMFT]PITVALFLG(INDEX)

  [M:SMF2]BEFAMT(nolign-1)    = [M:SMFT]BEFAMT(INDEX)
  [M:SMF2]AFTAMT(nolign-1)    = [M:SMFT]AFTAMT(INDEX)
  [M:SMF2]BEFSTO(nolign-1)    = [M:SMFT]BEFSTO(INDEX)
  [M:SMF2]AFTSTO(nolign-1)    = [M:SMFT]AFTSTO(INDEX)

  If dim([M:SMF2]WRH) > 0
    [M:SMF2]WRH(nolign-1)     = [M:SMFT]WRH(INDEX)
  Endif
  If dim([M:SMF2]LOC) > 0
    [M:SMF2]LOC(nolign-1)     = [M:SMFT]LOC(INDEX)
  Endif
  If dim([M:SMFT]PALNUM) > 0
    [M:SMF2]PALNUM(nolign-1)  = [M:SMFT]PALNUM(INDEX)
  Endif
  If dim([M:SMF2]CTRNUM) > 0
    [M:SMF2]CTRNUM(nolign-1)  = [M:SMFT]CTRNUM(INDEX)
  Endif
  If dim([M:SMF2]POT) > 0
    [M:SMF2]POT(nolign-1)     = [M:SMFT]POT(INDEX)
  Endif
Return

############################################################
$ERR_FORM
  Call MESSAGE (mess(65,106,1)) From GESECRAN
  End
Resume



############################################################
Subprog INIT_PAR(PITM,PFCY)
Value Char PITM
Value Char PFCY

  Affzo [M:SMF1]SRTCOD
End

############################################################
$SETBOUT
  If [M:SMF1]ITMREF <> ""
   CHMEN += "12"
  Endif
Return

############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
  If GCONSULT <> 0
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Call GETCPY(VALEUR,"",0,"") From TRTX3CPT
  [M:SMF1]CUR=GLOCALDEV

End

############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
  GMENLOC(1) = 1
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  GMENLOC(4) = 1
  GMENLOC(5) = 1
  GMENLOC(6) = 1
  GMENLOC(8) = 1
  GMENLOC(10) = 1
  GMENLOC(11) = 1
  GMENLOC(12) = 1
End

############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
End

######################################################################################
Subprog IB_NBLIG

  # Only OF receptions and entries could be regularized
  If !find([M:SMF2]TRSTYP(nolign-1),3,5)
    Raz GBOUT2
  Endif
  If [M:SMF2]NUMVCR(nolign-1)=""
    Raz GBOUT3
  Endif

  # No inventory / lot or traceability consultation if not specified
  If dim([M:SMF2]LOT) > 0
    If [M:SMF2]LOT(nolign-1)=""
      Raz GBOUT4
    Endif
  Endif

  If (dim([M:SMF2]LOT) > 0 and [M:SMF2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1
    Raz GBOUT5
  Endif


  If !GACTDECCST | [M:SMF1]REGFLG<>2
    Raz GBOUT6, GBOUT7
  Endif

  If !find([M:SMF2]VCRTYP(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
    Raz GBOUT8
  Else
    GBOUT8 = mess([M:SMF2]VCRTYP(nolign-1),701,1)-"("+[M:SMF2]VCRNUM(nolign-1)+")"
  Endif

  If !find([M:SMF2]VCRTYPORI(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
    Raz GBOUT9
  Else
    GBOUT9 = mess([M:SMF2]VCRTYPORI(nolign-1),701,1)-"("+[M:SMF2]VCRNUMORI(nolign-1)+")"
  Endif

  If [M:SMF2]TRSTYP(nolign-1)=34 | [M:SMF2]VCRTYP(nolign-1)=28
    Raz GBOUT8
    #if piece origin = change of stock, no tunnel because the change of stock is
    #related to a quality control is not visible by the object
    If [M:SMF2]VCRTYPORI(nolign-1)=29
      Raz GBOUT9
    Endif
  Endif

End

######################################################################################
Subprog B6_NBLIG
  GBIDC1="SJVO"
  Gosub ACT_SAIDECPRI
End

Subprog B7_NBLIG
    GBIDC1="SJVV"
    Gosub ACT_SAIDECPRI
End

$ACT_SAIDECPRI

  If GACTDECCST
  Raz [F:SJV]
    Raz [F:STJ], [F:SJV]
    For [F:STJ] Where STOFCY=[M:SMF1]FCY
&                   & UPDCOD=2
&                   & ITMREF=[M:SMF1]ITMREF
&                   & IPTDAT=[M:SMF2]IPTDAT(nolign-1)
&                   & MVTSEQ=[M:SMF2]MVTSEQ(nolign-1)
&                   & MVTIND=[M:SMF2]MVTIND(nolign-1)
      Break
    Next

    Read [SJV]SJV0=[M:SMF1]FCY;2;[M:SMF1]ITMREF;[M:SMF2]IPTDAT(nolign-1);[M:SMF2]MVTSEQ(nolign-1);[M:SMF2]MVTIND(nolign-1)
    If fstat
        mkstat=2
    Endif
  Endif
Return

######################################################################################
Subprog B8_NBLIG
  Local Integer NOL : NOL = nolign-1
  Call LNK2VCR([M:SMF2]VCRTYP(NOL),[M:SMF2]VCRNUM(NOL))
End

######################################################################################
Subprog B9_NBLIG
  Local Integer NOL : NOL = nolign-1
  Call LNK2VCR([M:SMF2]VCRTYPORI(NOL),[M:SMF2]VCRNUMORI(NOL))
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM)
Value Integer PTYP
Value Char    PNUM

  GCONSULT = 2
  Case PTYP
  When 2   # Sales order
      Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
  When 4   # Delivery
      Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
  When 5   # Sales invoice
      Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
  When 6   # Receipt
      Call OBJET("PTH",PNUM,num$(PTYP)) From GOBJET
  When 8   # Return to supplier
      Call OBJET("PNH",PNUM,num$(PTYP)) From GOBJET
  When 9   # Inventory
      Gosub SET_NOL From STKINV
      GCONSULT = 2
      Call OBJET("SNL",PNUM,[M:SMF2]VCRNUMORI(NOL)) From GOBJET
      GCONSULT = 0
  When 10  # Work order
      Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
  When 12  # Production tracking
      Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
  When 13  # Customer return
      Call OBJET("SRH",PNUM,num$(PTYP)) From GOBJET
  When 14  # Purchase order
      Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
  When 15  # Production declaration
      Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
  When 17  # Supplier invoice
      Call OBJET("PIH",PNUM,num$(PTYP)) From GOBJET
  When 18  # Sales credit
      Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
  When 19  # Miscellaneous receipt
      Call OBJET("SMR",PNUM,num$(PTYP)) From GOBJET
  When 20  # Miscellaneous issue
      Call OBJET("SMO",PNUM,num$(PTYP)) From GOBJET
  When 26  # Return to stock (not active)
      Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
  When 28  # Quality control
      Call OBJET("STQ",PNUM,num$(PTYP)) From GOBJET
  When 29  # Stock change
      Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
  When 31  # Assembly
      Call OBJET("BBY",PNUM,num$(PTYP)) From GOBJET
  When 32  # Disassembly
      Call OBJET("DBY",PNUM,num$(PTYP)) From GOBJET
  When 33  # Service request
      Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
  When 35  # Lot modification
      #no tunnel on Lot modification because we do not know what object used
  When 36  # Subcontract order
      Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
  Endcase
  GCONSULT = 0

End

