#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ATB3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBINDEX
mkstat = 0
zoncou = "NBINDEX"
indice = 0
status = 1
zoncou = "NBINDEX"
If varmode([M]NBINDEX,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBINDEX" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBINDEX
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBINDEX = nolign
   status = 75
   Call SAI_NBINDEX(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ORDINDSTA
mkstat = 0
zoncou = "ORDINDSTA"
indice = 0
IMPENT = [M]ORDINDSTA
If varinit([M]ORDINDSTA,indice)=0
 IMPENT = 1
Endif
If varmode([M]ORDINDSTA,indice)=0
 [M]ORDINDSTA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ORDINDSTA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ORDINDSTA(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ORDINDSTA(IMPENT) From SUBATB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ORDINDSTA" : GZNUM = 57298 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ORDINDSTA = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone FICCFG
mkstat = 0
zoncou = "FICCFG"
indice = 0
If varmode([M]FICCFG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FICCFG" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBINDEX(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBINDEX
mkstat = 0
zoncou = "NBINDEX"

## Zone NUMLIG
mkstat = 0
zoncou = "NUMLIG"
[M]NUMLIG(indice) = nolign

## Zone CODIND
mkstat = 0
zoncou = "CODIND"
If varmode([M]CODIND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODIND" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODIND(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODIND" : GZNUM = 38 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLINDTAB2"
  Call CTLINDTAB2([M]CODIND(indice),"") From LNKSUB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODIND" : GZNUM = 38 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CODIND([M]CODIND(indice)) From SUBATB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODIND" : GZNUM = 38 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DESCRIPT
mkstat = 0
zoncou = "DESCRIPT"
If varmode([M]DESCRIPT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DESCRIPT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DESCRIPT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DESCRIPT" : GZNUM = 39 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DESCRIPT([M]DESCRIPT(indice)) From SUBATB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DESCRIPT" : GZNUM = 39 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone HOMONYM
mkstat = 0
zoncou = "HOMONYM"
IMPENT = [M]HOMONYM(indice)
If varinit([M]HOMONYM,indice)=0
 IMPENT = 1
Endif
If varmode([M]HOMONYM,indice)=0
 [M]HOMONYM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HOMONYM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HOMONYM(indice)
 Endif
Endif
[M]HOMONYM(indice) = IMPENT

## Zone DEFORDIND
mkstat = 0
zoncou = "DEFORDIND"
IMPENT = [M]DEFORDIND(indice)
If varinit([M]DEFORDIND,indice)=0
 IMPENT = 1
Endif
If varmode([M]DEFORDIND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DEFORDIND(IMPENT) From SUBATB
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]DEFORDIND(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFORDIND" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFORDIND(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DEFORDIND(IMPENT) From SUBATB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DEFORDIND" : GZNUM = 57292 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]DEFORDIND(indice) = IMPENT

## Zone ORDIND
mkstat = 0
zoncou = "ORDIND"
IMPENT = [M]ORDIND(indice)
WNUM = IMPENT
If varinit([M]ORDIND,indice)=0
 IMPENT = 1
Endif
If varmode([M]ORDIND,indice)=0
 [M]ORDIND(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ORDIND" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ORDIND(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ORDIND(IMPENT) From SUBATB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ORDIND" : GZNUM = 48766 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_ORDIND(IMPENT) From SUBATB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ORDIND" : GZNUM = 48766 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]ORDIND(indice) = IMPENT

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 7252 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTACV"
  Call CONTACT([M]CODACT(indice),[M]CODACT(nolign-1)) From OBJDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 7252 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBINDEX
mkstat = 0
zoncou = "NBINDEX"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ATB3"
Return

