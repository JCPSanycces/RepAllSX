#<AdxTL>@(#)2.0.0.0 $Revision$
#-------------------------------------------------#
# Annulation d'une ligne de suivi
#-------------------------------------------------#

# Dans le cas de la suppression d'une fiche, ce traitement permet d'annuler (FLGSIG=1)
# les chronos générés par les workflows de type objet sur l'objet courant.
# Ces chronos ne doivent pas être signés.
# La recherche des chronos sur la table AWRKHISSUI est réalisée sur les champs IDENTREF et IDENTGRP
# Pour reconstituer la valeur de ces champs, avant d'appeler ce sous-programme, 
# il faut renseigner les classes [F] qui ont été utilisées à la création du suivi.

#-------------------------------------------------------------------------------------------------#
# Sous-programme pouvant être utilisé dans le workflow courant pour annuler le dernier suivi
#-------------------------------------------------------------------------------------------------#

Subprog ANUWRK
Local Integer TYPEVT
Local Char    CODEVT
Local Integer ERD
Local Integer SIGNE
Local Char    SUIREF(250) , SUIGRP(250)
Local Integer ERN , OK , TRACE , COMPLET
Local Char    ERM(250)
Local Char    NOMPROG(GLONADC) , PREF(4) , MOTIF(30)
Local Char    CHRORG(GLONVCR) 

OK =  (clalev([F:AWA])>0 & [F:AWA]CODE<>"")
OK *= (clalev([F:AWF])>0)
OK *= (clalev([F:AWS])>0)
If !OK : End : Endif

TYPEVT = [F:AWA]TYPEVT
CODEVT = [F:AWA]CODEVT
ERD    = ([F:AWA]DEBUG=2)
COMPLET  = 0

Gosub OK

If TRACE
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

End

#---------------------------------------------------------------------------------------------------#
# Sous-programme pouvant être appelé depuis une action objet (cas annulation ligne de commande)
#---------------------------------------------------------------------------------------------------#

Subprog ANNULE_SUIVI(TYPEVT,CODEVT,ERD,SIGNE,MOTIF,COMPLET)
Value    Integer TYPEVT  : # Type d'évènement Workflow (objet/import/etc.)
Value    Char    CODEVT  : # Code évènement
Value    Integer ERD     : # Trace
Variable Integer SIGNE   : # Suivi déjà signé
Value    Char    MOTIF   : # Motif annulation
Value    Integer COMPLET : # Annulation de tous les suivis même si les suivis sont déjà signés

Local Char    SUIREF(250) , SUIGRP(250)
Local Integer ERN , OK , TRACE
Local Char    ERM(250)
Local Char    NOMPROG(GLONADC) , PREF(4) , CHRORG(GLONVCR)

Onerrgo ERR
If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
Onerrgo
If ERN : End : Endif

SIGNE = 0
Read [AWA]AWA1 First
While !fstat
 OK =  ([F:AWA]TYPEVT=[L]TYPEVT & [F:AWA]CODEVT=[L]CODEVT & [F:AWA]ENAFLG=2)
 OK *= ([F:AWA]ENAMES=2 | [F:AWA]ENASUI=2 | [F:AWA]ENAACT=2)
 If OK
  Read [AWF]AWF0 = [F:AWA]CODE
  Gosub OK
 Endif
 Read [AWA]AWA1 Next
Wend

If TRACE
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

End

#--------------------#
$ERR
ERN = errn
Resume

#--------------------#
$TRACE
If ERD
 Call ECR_TRACE(ERM,0) From GESECRAN
Endif
Return

#-----------------------------------#
$OK
Call SET_PREF([F:AWA]CODE,PREF) From SUBAWA
NOMPROG = PREF+[F:AWA]CODE

# Annulation suivi workflow
If ERD & !GSERVEUR & GTRACE=""
 TRACE = 1
 Call OUVRE_TRACE(mess(142,75,1)-[L]CODEVT-"("+mess([L]TYPEVT,988,1)+")") From LECFIC
Endif
ERM = string$(80,"-")+"\"+mess(55,75,1)-[F:AWA]CODE+"\"+string$(80,"-")
Gosub TRACE

# Valeur de la clé de la table principale
Gosub OUVREF From =NOMPROG
If TABREF=""
 ERM = mess(80,75,1) : # Table de référence inexistante
 Gosub TRACE
 Return
Endif
Gosub LNKREF From =NOMPROG
SUIREF = TABREF
If CLEREF<>""
 SUIREF += "/"+evalue(CLEREF)
Endif
Look [F] =
If fstat
 # Fiche inexistante
 ERM = TABREF-SUIREF-":"-mess(23,100,1) : # Fiche inexistante
 Gosub TRACE
 Return
Endif

# Motif annulation
If MOTIF=""
 MOTIF = mess(1,2922,1)-format$(GFMDAT,date$)-time$ : # Annulé
Endif

# Valeur de la clé de la table ligne
Gosub LNKGRP From =NOMPROG
SUIGRP = TABGRP
If CLEGRP<>""
 SUIGRP += "/"+evalue(CLEGRP)
Endif

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 Gosub FLG_ANNULE
Endif

# Trace des suivis annulés
If GOK=1
 For [AWS2] Where TYPEVT=[F:AWA]TYPEVT & CODEVT=[F:AWA]CODEVT & CODWRK=[F:AWA]CODE
&               & IDENTGRP=SUIGRP & IDENTREF=SUIREF
  CHRORG = ""
  Case [F:AWS2]TYPEVT
   When 9       : CHRORG = [F:AWS2]NUMORG
   When Default : CHRORG = [F:AWS2]CHRONO
  Endcase
  For [AWS] Where NUMORG=CHRORG & FLGSIG=1 & REASON=MOTIF
   # Annulation chrono
   ERM = mess(143,75,1)-[F:AWS]CHRONO-format$("D:",[F:AWS]DATENV)-format$("K:##[:]##[:]##",[F:AWS]TIMENV)
   Gosub TRACE
  Next AWS
  For [AWS] Where CHRONO=CHRORG & FLGSIG=1 & REASON=MOTIF
   # Annulation chrono
   ERM = mess(143,75,1)-[F:AWS]CHRONO-format$("D:",[F:AWS]DATENV)-format$("K:##[:]##[:]##",[F:AWS]TIMENV)
   Gosub TRACE
  Next AWS
 Next AWS2
Endif
Return

#-------------------------------------#
$TR1
Trbegin [AWS]
 Gosub FLG_ANNULE
 If GOK<0 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------------------------------#
$FLG_ANNULE
For [AWS2] Where TYPEVT=[F:AWA]TYPEVT & CODEVT=[F:AWA]CODEVT & CODWRK=[F:AWA]CODE
&              & IDENTGRP=SUIGRP & IDENTREF=SUIREF
 CHRORG = ""
 Case [F:AWS2]TYPEVT
  When 9       : CHRORG = [F:AWS2]NUMORG
  When Default : CHRORG = [F:AWS2]CHRONO
 Endcase
 If CHRORG<>""
  If COMPLET
   # Annulation de toutes les signatures (en cas de réattribution du circuit de signature)
   Update [AWS] Where NUMORG=CHRORG & FLGSIG>1 With FLGSIG = 1 , REASON = MOTIF
   Update [AWS] Where CHRONO=CHRORG & FLGSIG>1 With FLGSIG = 1 , REASON = MOTIF
  Else
   # Annulation des chronos non signés
   Update [AWS] Where NUMORG=CHRORG & FLGSIG>1 & FLGSIG<4 With FLGSIG = 1 , REASON = MOTIF
   Update [AWS] Where CHRONO=CHRORG & FLGSIG>1 & FLGSIG<4 With FLGSIG = 1 , REASON = MOTIF
  Endif
 Endif
Next AWS2
If fstat=1
 GOK=-1 : GLOCK="$AWRKHISSUI" : Return
Elsif fstat
 GOK=0 : Call FSTA("AWS") From GLOCK : Return
Endif
Return
