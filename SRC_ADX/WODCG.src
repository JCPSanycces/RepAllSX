$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(15)(0..GNBDERNIER)
Local Char     A_BUF2(40)(0..GNBDERNIER)
Local Char     A_BUF3(40)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
Local Char     A_BUF5(5)(0..GNBDERNIER)
If clalev([F:ID9])>0 : Close Local File [ID9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(15),
& Char     A_TAB2(40),
& Char     A_TAB3(40),
& Char     A_TAB4(5),
& Char     A_TAB5(5)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5
& As [ID9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:ID]FCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Return

$CHARGE_DERLU
If clalev([F:ID9])>0
 Read [ID9] = [F:ID9]A_TABI
 [L]CLE = [F:ID9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:ID9])>0
 Filter [ID9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [DCG1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:ID9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:ID]REFNUM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:ID9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:ID9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:ID]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]NAM"
Call TEXTE(18622,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]NAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRN"
Call TEXTE(1825,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRV"
Call TEXTE(18735,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRV"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]FCY"
Call TEXTE(1344,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:ID_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:AD])=0 : Local file EMPLOAD [AD] : Endif
Link [ID] With
& [AFF]AFF0~=[F:ID]FCY;GPROFIL;GUSRFCT,
& [FCY]FCY0=[F:ID]FCY,
& [AD]AD0=[F:ID]REFNUM
& As [ID_]
Return

$DEFAUT_LISTE
