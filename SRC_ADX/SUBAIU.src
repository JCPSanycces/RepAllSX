#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet AIU
Raz GPILOBJ
Call OBJET("AIU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"   : Gosub SETBOUT
 When "INICRE"    : Gosub INI_ADMIN
 When "INIMOD"    : Gosub INI_ADMIN
 When "MODIF"     : Gosub MAJTEX
 When "CREATION"  : Gosub MAJTEX
 When "CHANGE"    : Gosub CHANGE
 When "ANNULE"    : Gosub ANNULE
Endcase 
Return

$MAJTEX
Call MAJTEXTRA([M]INTUSR,"ABIPRFUSR","INTUSR",[M]PRF,"") From ATEXTRA
Return

$CHANGE
Update [AXX] Where CODFIC="ABIPRFUSR" & ZONE = "INTUSR" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ABIPRFUSR"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="ABIPRFUSR" & ZONE = "INTUSR"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Else
 #If toupper([M:AIU1]USR) <> "ADMINISTRATOR"
If toupper([F:AIU]USR) <> "ADMINISTRATOR1"   : #   POUR TEST ************************************************

  CHMEN += "1" : # Mot de passe
 Endif
Endif
Return

$INI_ADMIN
If toupper([F:AIU]USR) = "ADMINISTRATOR"
 [F:AIU]USR = "Administrator"
 [F:AIU]PWD = ""
Endif
Return

$TRTCOP
If [M]DOSORG=nomap 
 Local File ABIPRFUSR  [AIU1] 
Else 
 Local File =[M]DOSORG+".ABIPRFUSR"  [AIU1]
Endif 
If [M]DOSDES=nomap 
 Local File ABIPRFUSR  [AIU2] 
Else 
 Local File =[M]DOSDES+".ABIPRFUSR"  [AIU2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AIU1], [AIU2]
Return

$TR_COP
GOK = 1
Trbegin [AIU2]
 Delete [AIU2] Where PRF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIPRFUSR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AIU2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AIU1]AIU0 Where PRF=TABLE
  [F:AIU2] = [F:AIU1]
  If dim([F:AIU2]UPDUSR)>0 : [F:AIU2]UPDUSR = GUSER : Endif
  If dim([F:AIU2]UPDDAT)>0 : [F:AIU2]UPDDAT = date$ : Endif
  If dim([F:AIU2]UPDTIM)>0 : [F:AIU2]UPDTIM = time : Endif
  Write [AIU2]
  If fstat
   GOK=0 : Call FSTA("AIU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Subprog AS_MODE(VALEUR)
Variable Integer VALEUR
#   Dans cette version on ne gère que l'authentification de type entreprise (SecEnterprise)
GMENLOC(2) = 1 
GMENLOC(3) = 1 
GMENLOC(4) = 1 
End
