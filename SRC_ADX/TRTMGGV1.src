#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################################################################
#  Affichage d'un ciblage fonctionnel                                            Module CRM          9 Septembre 2004 #
#######################################################################################################################
##########################################################
# Détail des paramètres TRTMGGV1
# PARAM(1) : Code ciblage
# PARAM(2) : Code support de présentation à utiliser pour l'affichage.
#########################################################
##########################################################
# Détail des paramètres TRTMGC1
# PARAM(1) : Code ciblage
# PARAM(2) : Cible
# PARAM(3) : Détermine s'il faut effectuer une recherche ou simplement afficher le contenu d'un échantillon.
# PARAM(4) : Code support de présentation à utiliser pour l'affichage.
#########################################################
#######################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "TITRE"        : Gosub TITREWND From TRTMGC1
    When "DEFBOUT"      : Gosub DEFBOUT From TRTMGC1
    When "SETBOUT"      : Gosub SETBOUT From TRTMGC1
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE From TRTMGC1
    When "DEBUT"        : Gosub DEBUT From TRTMGC1
    When "AV_CHOIX"     : Gosub AV_CHOIX From TRTMGC1
    When "AP_CHOIX"     : Gosub AP_CHOIX From TRTMGC1
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON From TRTMGC1
    When "FINSAI"       : Gosub FINSAI From TRTMGC1
    When "FIN"          : Gosub FIN From TRTMGC1
    When "ABANDON"      : Gosub ABANDON From TRTMGC1
    When "APRES_MODIF"  : Gosub APRES_MODIF From TRTMGC1
    When "BOUTON"       : Gosub BOUTON From TRTMGC1
    When "FIR"          : Gosub PREMIER From TRTMGC1
    When "PRE"          : Gosub PRECEDENT From TRTMGC1
    When "SUI"          : Gosub SUIVANT From TRTMGC1
    When "LAS"          : Gosub DERNIER From TRTMGC1
    When "MEN"          : Gosub ONMENU From TRTMGC1
    When "RAF"          : Gosub REFRESH From TRTMGC1
    When Default
  Endcase
Return

#######################################################################################################################
$OUVRE
Local Char SZMGGV1TGR
Local Char SZMGGV1TGP

  If PARAM(1) = "" Then
    #Aucun ciblage n'est précisé. Action abandonnée.
    GMESSAGE = mess(146,177,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  Gosub OUVTABGLOB From TRTMGC1
  SZMGGV1TGR = ""
  SZMGGV1TGP = ""
  Read [MQR]MQR0=PARAM(1)
  If fstat Then
    #Le ciblage indiqué est incorrect. Action abandonnée.
    GMESSAGE = mess(147,177,1)
    GERR = 1
    FIN = 1
    Return
  Else
    If [F:MQR]TGR = "" Then
      #Aucune cible n'a pu être obtenue. Action abandonnée.
      GMESSAGE = mess(149,177,1)
      GERR = 1
      FIN = 1
      Return
    Else
      SZMGGV1TGR = [F:MQR]TGR
    Endif
    If PARAM(2) = "" Then
      If [F:MQR]TGPNUM = "" Then
        #Aucun support de présentation n'a pu être obtenu. Action abandonnée.
        GMESSAGE = mess(148,177,1)
        GERR = 1
        FIN = 1
        Return
      Else
        SZMGGV1TGP = [F:MQR]TGPNUM
      Endif
    Else
      If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
      Read [TGP]TGP0=PARAM(2)
      If fstat Then
        #Le support de présentation indiqué est incorrect. Action abandonnée.
        GMESSAGE = mess(150,177,1)
        GERR = 1
        FIN = 1
        Return
      Endif
    Endif
  Endif
  PARAM(2) = SZMGGV1TGR
  PARAM(3) = "Y"
  PARAM(4) = SZMGGV1TGP
  SZMGC1PARAM2 = PARAM(2)
  SZMGC1PARAM4 = PARAM(4)
  Gosub SETMGCCOL From TRTMGC1
Return
