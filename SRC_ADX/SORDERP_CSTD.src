# -------------------------------------------------------------------- #
#       Traitement lié à la classe de données SORDERP                  #
# -------------------------------------------------------------------- #
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"     : Gosub AREAD_AFTER            From SORDERP_CSTD_METHODS
          When "AINIT"           : Gosub AINIT                  From SORDERP_CSTD_METHODS
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSICODADI"  : Gosub INIT_TSICODADI         From SORDERP_CSTD_METHODS
  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "LINORDNOT"              :  Gosub LINORDNOT  From SORDERP_PROPERTIES
    When "LINORDATI"              :  Gosub LINORDATI  From SORDERP_PROPERTIES
    When "LINPFM"                 :  Gosub LINPFM     From SORDERP_PROPERTIES
    When "CURVCR"                 :  Gosub CURVCR     From SORDERP_PROPERTIES
    When Default
  Endcase
Return
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG properties related calls and also all AREAD_AFTER_xxx badly called from other scripts

