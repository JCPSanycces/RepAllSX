#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la consultation des collaborateurs disponibles  Module CRM 29 septembre 2000#
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GAUSFOUND
Global Char GSZSELAUS
Global Integer GIRANOK
Global Integer GISELRAN
Global Integer GAUSNOL

  GAUSNOL = 0
  GAUSFOUND = 0
  GIRANOK = 0
  GSZSELAUS = ""
  GISELRAN = 0
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Gosub LOADDISP
  GSZSELAUS = [M:ITN5]AUSNUM(0)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GAUSFOUND Then
    #Nettoie l'écran avant de partir.
    Raz [M:ITN5]
  Endif
  Kill GAUSFOUND
  Kill GSZSELAUS
  Kill GAUSNOL
  Kill GIRANOK
  Kill GISELRAN
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When "B"
      Gosub ONALLSKI
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
#  LOADDISP    : Charge les disponibilités trouvées dans la fenêtre de résultat.
#  ONSELECT    : Gestion du bouton Sélectionner
#  ONALLSKI    : Gestion du bouton Toutes compétences.
#  LOADRAN     : Charge les disponibilités d'un collaborateur.
#  LOADPNITN   : Chargement de l'intervention précédente et suivante
##########################################################################################################
$LOADDISP
Local Integer I
Local Char SZBPL

  I = 0
  SZPBL = ""
  If [M:ITN0]SRVDEMNUM = "" Then
    Gosub ONALLSKI
    Return
  Endif
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    Return
  Endif
  SZPBL = [F:SRE]SREPBLGRP
  Filter [PBR] Where [F:PBR]GRPPBLNUM = SZPBL and [F:PBR]STTFLG = 0
  For [PBR]
    If  I >= dim([M:ITN5]AUSNUM)-1 Then
      Break
    Endif
    [M:ITN5]AUSNUM(I) = [F:PBR]REPNUM
    [M:ITN5]AUSNAM(I) = [F:PBR]REPNAM
    I += 1
  Next
  Filter [PBR]
  If I = 0 Then
    Gosub ONALLSKI
    GMESSAGE = mess(325,196,1)  #Aucun collaborateur compétent n'a été trouvé. Tous les collaborateurs vont être affichés.
    GERR = 2
    Return
  Endif
  GAUSFOUND = 1
  [M:ITN5]NBAUS = I
  Affzo [M:ITN5]1-99
Return

##########################################################################################################
$ONSELECT
Local Char SZDUR(type([M:ITN1]DUR)-10)  # FGR 23/07/2014 : X3SUIVI101618

  SZDUR = ""
  #Affectation du collaborateur
  VALEUR = GSZSELAUS
  #Affectation de la plage horaire
  If GIRANOK Then
    If [M:ITN5]RANSTRDAT(GISELRAN) <> [00/00/00] Then
      [M:ITN1]DAT = [M:ITN5]RANSTRDAT(GISELRAN)
      [M:ITN1]HOU = [M:ITN5]RANSTRHOU(GISELRAN)
      If [M:ITN5]RANENDDAT(GISELRAN) = [00/00/00] Then
        [M:ITN1]DATEND = [M:ITN1]DAT
        [M:ITN1]HOUEND = num$(val(left$([M:ITN1]HOU, 2)) + 1) + mid$([M:ITN1]HOU, 3, 2)
      Else
        [M:ITN1]DATEND = [M:ITN5]RANENDDAT(GISELRAN)
        [M:ITN1]HOUEND = [M:ITN5]RANENDHOU(GISELRAN)
      Endif
      #Met à jour la durée de l'intervention.
      # FGR 19/03/2012 : X3SUIVI80829
      #Call GETDUR(nday([M:ITN1]DAT), [M:ITN1]HOU, nday([M:ITN1]DATEND), [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
      # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
      Call GET_DUREE_DT_HO(1, VALEUR, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, [M:ITN1]HOUEND, SZDUR) From CRM_UTIL
      #
      [M:ITN1]DUR = SZDUR
      #Met à jour le numéro de semaine avec la nouvelle date
      [M:ITN1]WEE = week([M:ITN1]DAT)
    Endif
  Endif
  mkstat = 4
  FIN = 1
  Affzo [M:ITN1]1-99
Return

##########################################################################################################
$ONALLSKI
Local Integer I
Local Char SZHDKREP
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  I = 0
  Raz [M:ITN5]
  Filter [AUS] Where [F:AUS]ENAFLG = 2
  For [AUS]
    If I >= dim([M:ITN5]AUSNUM)-1 Then
      Break
    Endif
    Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
    If SZHDKREP = "" Then
      IHDKREP = 1
    Else
      IHDKREP = val(SZHDKREP)
    Endif
    If IHDKREP = 2 Then
      [M:ITN5]AUSNUM(I) = [F:AUS]USR
      [M:ITN5]AUSNAM(I) = [F:AUS]NOMUSR
      I += 1
    Endif
  Next
  Filter [AUS]
  If I = 0 Then
    GMESSAGE = mess(319,196,1)  #Aucun collaborateur Help-Desk n'est déclaré dans l'application.
    GERR = 2
    FIN = 1
    Return
  Endif
  GAUSFOUND = 1
  [M:ITN5]NBAUS = I
  Affzo [M:ITN5]1-99
Return

##########################################################################################################
# Chargement du tableau des plages disponibles pour un collaborateur
###########################################################
Subprog LOADRAN(SZAUSNUM)
Value Char SZAUSNUM

Local Integer ARRNBLIG
Local Integer IFSTEP

  ARRNBLIG = 0
  IFSTEP = 1
  Raz [M:ITN5]NBRAN
  Raz [M:ITN5]RANSTRDAT
  Raz [M:ITN5]RANSTRHOU
  Raz [M:ITN5]RANENDDAT
  Raz [M:ITN5]RANENDHOU
  Filter [ITN] Where [F:ITN]REP = SZAUSNUM and [F:ITN]DON <> 2 and [F:ITN]DAT > date$
  For [ITN]ITN5
    If IFSTEP Then
      [M:ITN5]RANSTRDAT(ARRNBLIG) = date$
      [M:ITN5]RANSTRHOU(ARRNBLIG) = left$(time$, 2) + mid$(time$, 4, 2)
      [M:ITN5]RANENDDAT(ARRNBLIG) = [F:ITN]DAT
      [M:ITN5]RANENDHOU(ARRNBLIG) = [F:ITN]HOU
      [M:ITN5]RANSTRDAT(ARRNBLIG+1) = [F:ITN]DATEND
      [M:ITN5]RANSTRHOU(ARRNBLIG+1) = [F:ITN]HOUEND
      IFSTEP = 0
    Else
      [M:ITN5]RANSTRDAT(ARRNBLIG+1) = [F:ITN]DATEND
      [M:ITN5]RANSTRHOU(ARRNBLIG+1) = [F:ITN]HOUEND
      [M:ITN5]RANENDDAT(ARRNBLIG) = [F:ITN]DAT
      [M:ITN5]RANENDHOU(ARRNBLIG) = [F:ITN]HOU
    Endif
    [M:ITN5]NEXSTRDX(ARRNBLIG) = [F:ITN]DAT
    [M:ITN5]NEXSTRHX(ARRNBLIG) = [F:ITN]HOU
    [M:ITN5]NEXENDDX(ARRNBLIG) = [F:ITN]DATEND
    [M:ITN5]NEXENDHX(ARRNBLIG) = [F:ITN]HOUEND
    [M:ITN5]NEXADD1X(ARRNBLIG) = [F:ITN]ADD(0)
    [M:ITN5]NEXADD2X(ARRNBLIG) = [F:ITN]ADD(1)
    [M:ITN5]NEXADD3X(ARRNBLIG) = [F:ITN]ADD(2)
    [M:ITN5]NEXZIPX(ARRNBLIG) = [F:ITN]ZIP
    [M:ITN5]NEXCTYX(ARRNBLIG) = [F:ITN]CTY
    [M:ITN5]NEXCRYX(ARRNBLIG) = [F:ITN]CRY
    [M:ITN5]PRESTRDX(ARRNBLIG+1) = [F:ITN]DAT
    [M:ITN5]PRESTRHX(ARRNBLIG+1) = [F:ITN]HOU
    [M:ITN5]PREENDDX(ARRNBLIG+1) = [F:ITN]DATEND
    [M:ITN5]PREENDHX(ARRNBLIG+1) = [F:ITN]HOUEND
    [M:ITN5]PREADD1X(ARRNBLIG+1) = [F:ITN]ADD(0)
    [M:ITN5]PREADD2X(ARRNBLIG+1) = [F:ITN]ADD(1)
    [M:ITN5]PREADD3X(ARRNBLIG+1) = [F:ITN]ADD(2)
    [M:ITN5]PREZIPX(ARRNBLIG+1) = [F:ITN]ZIP
    [M:ITN5]PRECTYX(ARRNBLIG+1) = [F:ITN]CTY
    [M:ITN5]PRECRYX(ARRNBLIG+1) = [F:ITN]CRY
    ARRNBLIG += 1
  Next
  If ARRNBLIG > 0 Then
    [M:ITN5]RANENDDAT(ARRNBLIG) = [00/00/00]
    [M:ITN5]RANENDHOU(ARRNBLIG) = "0000"
    [M:ITN5]NBRAN = ARRNBLIG + 1
    GIRANOK = 1
  Else
    [M:ITN5]NBRAN = 0
    GIRANOK = 0
  Endif
  GISELRAN = 0
  Filter [ITN]
  Affzo [M:ITN5]10
End

##########################################################################################################
# Chargement de l'intervention précédente et suivante
###########################################################
Subprog LOADPNITN(IITNNUM)
Value Integer IITNNUM

  #Charge l'intervention précédente :
  [M:ITN5]PRESTRD = [M:ITN5]PRESTRDX(IITNNUM)
  [M:ITN5]PRESTRH = [M:ITN5]PRESTRHX(IITNNUM)
  [M:ITN5]PREENDD = [M:ITN5]PREENDDX(IITNNUM)
  [M:ITN5]PREENDH = [M:ITN5]PREENDHX(IITNNUM)
  [M:ITN5]PREADD(0) = [M:ITN5]PREADD1X(IITNNUM)
  [M:ITN5]PREADD(1) = [M:ITN5]PREADD2X(IITNNUM)
  [M:ITN5]PREADD(2) = [M:ITN5]PREADD3X(IITNNUM)
  [M:ITN5]PREZIP = [M:ITN5]PREZIPX(IITNNUM)
  [M:ITN5]PRECTY = [M:ITN5]PRECTYX(IITNNUM)
  [M:ITN5]PRECRY = [M:ITN5]PRECRYX(IITNNUM)
  #Charge l'intervention suivante :
  [M:ITN5]NEXSTRD = [M:ITN5]NEXSTRDX(IITNNUM)
  [M:ITN5]NEXSTRH = [M:ITN5]NEXSTRHX(IITNNUM)
  [M:ITN5]NEXENDD = [M:ITN5]NEXENDDX(IITNNUM)
  [M:ITN5]NEXENDH = [M:ITN5]NEXENDHX(IITNNUM)
  [M:ITN5]NEXADD(0) = [M:ITN5]NEXADD1X(IITNNUM)
  [M:ITN5]NEXADD(1) = [M:ITN5]NEXADD2X(IITNNUM)
  [M:ITN5]NEXADD(2) = [M:ITN5]NEXADD3X(IITNNUM)
  [M:ITN5]NEXZIP = [M:ITN5]NEXZIPX(IITNNUM)
  [M:ITN5]NEXCTY = [M:ITN5]NEXCTYX(IITNNUM)
  [M:ITN5]NEXCRY = [M:ITN5]NEXCRYX(IITNNUM)
  Affzo [M:ITN5]PRESTRD
  Affzo [M:ITN5]PRESTRH
  Affzo [M:ITN5]PREENDD
  Affzo [M:ITN5]PREENDH
  Affzo [M:ITN5]PREADD(0)
  Affzo [M:ITN5]PREADD(1)
  Affzo [M:ITN5]PREADD(2)
  Affzo [M:ITN5]PREZIP
  Affzo [M:ITN5]PRECTY
  Affzo [M:ITN5]PRECRY
  Affzo [M:ITN5]NEXSTRD
  Affzo [M:ITN5]NEXSTRH
  Affzo [M:ITN5]NEXENDD
  Affzo [M:ITN5]NEXENDH
  Affzo [M:ITN5]NEXADD(0)
  Affzo [M:ITN5]NEXADD(1)
  Affzo [M:ITN5]NEXADD(2)
  Affzo [M:ITN5]NEXZIP
  Affzo [M:ITN5]NEXCTY
  Affzo [M:ITN5]NEXCRY
End
