#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIVEN59635 TOOL TO INITIALIZE THE METCORCOD FIELD IN THE TRANSACTION OF           #
# SALES INVOICES    (jucon 13/10/2017)                                               #
######################################################################################
  Call MAJ_UTIVEN59635
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN59635
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN59635 - New sales invoices transactions field initialisation") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN59635 : New sales invoices transactions field initialisation") From LECFIC
    Call EXE_UTIVEN59635(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN59635(DOSSIER)
Value Char    DOSSIER

  If clalev([F:ACV])>0 : Close File [ACV] : Endif
  Local File =DOSSIER+".ACTIV" [ACV]

  Call ECR_TIME("UTIVEN59635 : Start folder's process"-DOSSIER) From DOSSUB

  If func AFNC.ACTIV("KSP")=0 : Goto FIN_UTIVEN59635 : Endif

  #----- Chargement globale GMAXUPDTRS -----#
  If dim([V]GMAXUPDTRS) < 1 Then
    Global Integer GMAXUPDTRS
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW] ADW0="";"";"MAXUPDTRS"
  If fstat Then
    Raz [F:ADW]
  Endif
  If val([F:ADW]VALEUR) > 0 Then
    GMAXUPDTRS = val([F:ADW]VALEUR)
  Else
    GMAXUPDTRS = 1000
  Endif
  Close Local File [ADW]
  #----- Début mise à jour SALTRS -----#
  Gosub TRT_SLT
  #----- Fin mise à jour SALTRS   -----#

$FIN_UTIVEN59635
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVEN59635 : End folder's process"-DOSSIER) From DOSSUB

  Close File [ACV]
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions vente              #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Transactions vente                                             #
#-------------------------------------------------------------------------------#
$TRT_SLT
Local Shortint INDIC

  If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIVEN59635 Sales Transactions Process : Update SALTRS") From DOSSUB
  Local File =DOSSIER+".SALTRS"    [SLT]
  #
  Call ECR_TIME("UTIVEN59635 Sales Invoices Transactions Process") From DOSSUB
  Gosub TXNSIH

  Close Local File [SLT]
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures et avoirs                                       #
#-------------------------------------------------------------------------------#
$TXNSIH
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 5
    Raz INDIC
    If dim([F:SLT]METCORCOD) > 0 Then
      If !find([F:SLT]METCORCOD ,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]METCORCOD  = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN59635(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN59635(APPLI)
End

