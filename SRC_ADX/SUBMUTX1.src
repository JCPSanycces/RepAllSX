#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque MULTIWOX1
#########################################################################
# GA 02/2008 + graphique "Nomenclature verticale" NBLIG devient NBLIG   #
#########################################################################
$ACTION
Return

########################################
Subprog B1_NBLIG

Case [M]TRI
    When 1: Sorta [M]NBLIG [M]NBLIG Order By [M]LEVEL(indice) : [M]TRI = 2
    When 2: Sorta [M]NBLIG [M]NBLIG Order By [M]LIGNE(indice) : [M]TRI = 1
Endcase
Affzo 1-99
mkstat = 99

End

########################################
Subprog IB_NBLIG

GBOUT1 = ""
GBOUT3 = ""
If [M]ITMREF(nolign-1) = ""  : End : Endif
Case [M]TRI
    When 1: GBOUT1 = mess(430,198,1)
    When 2: GBOUT1 = mess(431,198,1)
Endcase
If [M]ORI <> "D"  : GBOUT3 = mess(261,198,1) : Endif
If [M]REOCOD(nolign-1) <> 3 : GBOUT4 = "" : Endif

End

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer SAVPEC
SAVPEC = [M:MUX1]PECFLG(nolign-1)

[M:MUX1]PECFLG(nolign-1)=2
# Issue 111414/11 - 2016-02-10 by JUSYN : versions flag
Call UPD_PECFLG(nolign-1,nolign-1,1) From TRTMULTIWX
pcolor = GCOUL([M:MUX1]PECFLG(nolign-1)=1)

[M:MUX1]PECFLG(nolign-1) = SAVPEC

End

########################################
Subprog B1_EXTQTY(VALEUR)
Variable Decimal VALEUR

If [F:ITF]ITMREF <> [M]ITMREF(nolign-1)
    Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY

End

########################################
Subprog B2_EXTQTY(VALEUR)
Variable Decimal VALEUR

If [F:ITF]ITMREF <> [M]ITMREF(nolign-1)
    Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY

End

########################################
Subprog AS_EXTQTY(VALEUR)
Variable Decimal VALEUR

GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If [M]BOMALT(nolign-1) = 0
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif

End

########################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 : mkstat = 2 : Endif

End

########################################
Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR

Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
# Issue 111414/113 - 2016-03-29 by JUSYN : work date for start date of routing version
Local    Date    WDAT

If [M]STRDAT(nolign-1) = [0/0/0] | [M]ENDDAT(nolign-1) = [0/0/0] : End : Endif

If [M]REOCOD(nolign-1) <> 3
    Call PCAL_QTY(VALEUR, [M]STU(nolign-1),[M]PUUPECQTY(nolign-1),[M]PUU(nolign-1),
&                 [M]ITMREF(nolign-1),[M]BPSNUM(nolign-1),1,GBIDD1) From TRTACHQTE1

    End
Endif

Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT = [M]ENDDAT(nolign-1)
WORIFCY = [M]MFGFCY
WLTI    = 0

# lecture ITF
If [F:ITF]ITMREF<>[M]ITMREF(nolign-1)
    Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
    If fstat : End : Endif
Endif

WQTY = VALEUR
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers (llc 06.00)
# Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB : # GH 11/04/2013

## calcul du délai et de date début
# -- 12.05 33887
ILTI=0
If [M]LTICOD = 2
    Raz [M:JALK]
    [M:JALK]CODORI     = 0
    [M:JALK]CODMAJ     = 2
    [M:JALK]CODTRS     = 0
    [M:JALK]MFGFCY     = [M]MFGFCY
    # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
    # [M:JALK]ROUNUM     = [M]ITMREF(nolign-1)
    [M:JALK]ROUNUM     = [M]ROUNUM(nolign-1)
    [M:JALK]ROUALT     = [M]ROUALT(nolign-1)
    # Issue 111414/113 - 2016-03-29 by JUSYN : VALEUR instead of screen variable
    [M:JALK]REOMINQTY  = VALEUR
    [M:JALK]TRTDAT     = [M]STRDAT(nolign-1)
    [M:JALK]STRDAT     = [M]STRDAT(nolign-1)
    [M:JALK]ENDDAT     = [M]ENDDAT(nolign-1)
    [M:JALK]JAVFLG     = 1
    [M:JALK]SCDMOD     = 1 : # [M:JALK]SCDMOD=2 : # GH 11/04/2013
    # Issue 111414/113 - 2016-03-29 by JUSYN : correct date to read routing needed
    # ROUDAT = Date to read the routing in JALLIB.JALLONE. Take start date not end date when routing is versioned in order to schedule backwards
    #               Routing version entered in MULTIWOX1 has to be taken. End date would probably look for another version.
    If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
        Call INIECCROUDAT([M]ITMREF(nolign-1),[M:JALK]MFGFCY,[M]ROUALT(nolign-1),[M]ROUECCMAJ(nolign-1),[M]ROUECCMIN(nolign-1),WDAT) From RVMLIB
        If WDAT = [0/0/0] : WDAT = [M:JALK]ENDDAT : Endif
        [M:JALK]ROUDAT = WDAT
    Endif

    Call JALONNE From JALLIB
    ILTI = ([M:JALK]CODRET <> 0)
    # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
    If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : ILTI = 0  : Endif
    [M]STRDAT(nolign-1) = [M:JALK]STRDAT : # [M]ENDDAT(nolign-1) = [M:JALK]ENDDAT : # GH 11/04/2013
Endif
# --
If [M]LTICOD = 1 | ILTI=1 : # GH 11/04/2013
   # révision calendriers (llc 06.00)
   Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB
Endif

Call TEMPOFF From GESECRAN

Affzo STRDAT(nolign-1)
Call CHECK_PAST([M]STRDAT(nolign-1), 2) From MFGLIB

End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# Issue 111414/11 - 2016-02-19 by JUSYN : Rework handling
# Issue 111835 - 2015-10-27 by BEEBE : validation modified start date -> the version may not change

Call CHECK_VERSION_STRDAT(VALEUR)
If GERR
    # Issue 111414/11 - 2016-02-10 by JUSYN : Keep cursor in start date field and untick line
    mkstat = 2
    End
Endif

# Issue 111414/113 - 2016-03-30 by JUSYN : control on routing version too early at this position so deleted.

## GH 03/06/2013 bug 90223 : même pour un ordre SST les dates début/fin doivent être des jours ouvrés
If find([M]REOCOD(nolign-1),3,5)
  # révision calendriers (llc 06.00)
  Call CONTROL_DATE_PLN(VALEUR, [M]MFGFCY) From MFGLIB
Endif

End

########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI, WLTIJO
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Char    WSNS(1), WSRVITMREF(GLONITM)
# Issue 111414/113 - 2016-03-29 by JUSYN : work date for start date of routing version
Local    Date    WDAT

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB
# recalcul date fin
Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT = VALEUR
WORIFCY = [M]MFGFCY
WLTI    = 0

# lecture article site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif

# calcul du délai et de date début
Case [M]REOCOD(nolign-1)
    When 2, 4, 5 :  If [M]REOCOD(nolign-1)=5 : # GH 24/05/2013
                      WSRVITMREF = "" : XLTI=0
                      Call FIND_SCI_LTI([M:MUX1]ITMREF(nolign-1),[M:MUX1]BPSNUM(nolign-1),[M:MUX1]MFGFCY,[M:MUX1]BOMALT(nolign-1),WSRVITMREF,XLTI) From SCOLIB
                      WLTI = XLTI
                      WLTIJO = 2
                    Else
                      WLTI = [F:ITF]OFS
                      WLTIJO = 0
                    Endif
                    # GH 11/04/2013 suite au bug 88210 corrigé par GA
                    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB
                    WSNS = "+"
                    Gosub CAL_PURDAT From TRTMULTIWX
                    [M]ENDDAT(nolign-1) = WDAT
    When 3       :  WQTY = [M]EXTQTY(nolign-1)
                    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                    ILTI    = int(XLTI)
                    WRMD    = XLTI - ILTI
                    If WRMD <> 0 : ILTI += 1 : Endif
                    WLTI=ILTI
                    # -- 12.05 33887
                    ILTI=0
                    If [M]LTICOD = 2
                        Raz [M:JALK]
                        [M:JALK]CODORI     = 0
                        [M:JALK]CODMAJ     = 2
                        [M:JALK]CODTRS     = 0
                        [M:JALK]MFGFCY     = [M]MFGFCY
                        # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
                        # [M:JALK]ROUNUM     = [M]ITMREF(nolign-1)
                        [M:JALK]ROUNUM     = [M]ROUNUM(nolign-1)
                        [M:JALK]ROUALT     = [M]ROUALT(nolign-1)
                        [M:JALK]REOMINQTY  = [M]EXTQTY(nolign-1)
                        [M:JALK]TRTDAT     = VALEUR
                        [M:JALK]STRDAT     = VALEUR
                        [M:JALK]ENDDAT     = [M]ENDDAT(nolign-1)
                        [M:JALK]JAVFLG     = 1
                        [M:JALK]SCDMOD     = 2
                        # Issue 111414/113 - 2016-03-29 by JUSYN : correct start date to select routing needed
                        If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
                            Call INIECCROUDAT([M]ITMREF(nolign-1),[M:JALK]MFGFCY,[M]ROUALT(nolign-1),[M]ROUECCMAJ(nolign-1),[M]ROUECCMIN(nolign-1),WDAT) From RVMLIB
                            If WDAT = [0/0/0] : WDAT = [M:JALK]STRDAT : Endif
                            [M:JALK]ROUDAT = WDAT
                        Endif

                        Call JALONNE From JALLIB
                        ILTI = ([M:JALK]CODRET <> 0)
                        # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
                        If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : ILTI = 0  : Endif

                        [M]ENDDAT(nolign-1) = [M:JALK]ENDDAT
                    Endif
                    # --
                    If [M]LTICOD=1 | ILTI=1 : # GH 11/04/2013
                       # révision calendriers (llc 06.00)
                       Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M]ENDDAT(nolign-1)) From MFGLIB
                    Endif
Endcase

Call TEMPOFF From GESECRAN
Affzo ENDDAT(nolign-1)
#
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

## GH 03/06/2013 bug 90223 : même pour un ordre SST les dates début/fin doivent être des jours ouvrés
If find([M]REOCOD(nolign-1),3,5)
  # révision calendriers (llc 06.00)
  Call CONTROL_DATE_PLN(VALEUR, [M]MFGFCY) From MFGLIB
  If mkstat : End : Endif
Endif

If [M]STRDAT(nolign-1) = [0/0/0] : End : Endif

If [M]REOCOD(nolign-1) <> 3 : End : Endif

If [M]BOMALT = 0
    Call RECH_NOM([M]MFGFCY, [M]STRDAT(nolign-1), [M]BOMALT(nolign-1),2) From BENCHLIB
Endif

If ([M]ROUALT(nolign-1) = 0 | [M]ROUNUM(nolign-1) = "") & ([F:MTS]MFGMODC = 2 | [F:MTS]MFGMODO = 2)
    If [F:ITF]MFGROU = ""
        [M]ROUNUM(nolign-1) = [M]ITMREF(nolign-1)
    Else
        [M]ROUNUM(nolign-1) = [F:ITF]MFGROU
    Endif

    Call RECH_GAM([M]MFGFCY, [M]STRDAT(nolign-1), [M]ROUNUM(nolign-1), [M]EXTQTY(nolign-1),
&                 [M]STU(nolign-1), [M]BOMALT(nolign-1), [M]ROUALT(nolign-1)) From BENCHLIB
    If [M]ROUALT(nolign-1) = 0 & [F:MTS]MFGMODM = 2 : Raz [M]ROUNUM(nolign-1) : Endif                # llc 06.04 22880
Endif

End

########################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI, WLTIJO
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Char    WSNS(1), WSRVITMREF(GLONITM)
# Issue 111414/113 - 2016-03-29 by JUSYN : work date for start date of routing version
Local    Date    WDAT

Call CHECK_PAST(VALEUR, 2) From MFGLIB

Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT = VALEUR
WORIFCY = [M]MFGFCY
WLTI    = 0

# lecture article site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif

# calcul du délai et de date début
Case [M]REOCOD(nolign-1)
    When 2, 4, 5 :  If [M]REOCOD(nolign-1)=5 : # GH 24/05/2013
                      WSRVITMREF = "" : XLTI=0
                      Call FIND_SCI_LTI([M:MUX1]ITMREF(nolign-1),[M:MUX1]BPSNUM(nolign-1),[M:MUX1]MFGFCY,[M:MUX1]BOMALT(nolign-1),WSRVITMREF,XLTI) From SCOLIB
                      WLTI = XLTI
                      WLTIJO = 2
                    Else
                      WLTI = [F:ITF]OFS
                      WLTIJO = 0
                    Endif
                    # GH 11/04/2013 suite au bug 88210 corrigé par GA
                    # Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB
                    WSNS = "-"
                    Gosub CAL_PURDAT From TRTMULTIWX

                    # Issue 111835 - 2015-10-27 by BEEBE : validation modified start date -> the version may not change
                    Call CHECK_VERSION_STRDAT(WDAT)
                    If GERR
                        VALEUR=[M]ENDDAT(nolign-1)
                        End
                    Endif

                    [M]STRDAT(nolign-1) = WDAT
    When 3      :   WQTY = [M]EXTQTY(nolign-1)
                    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                    ILTI    = int(XLTI)
                    WRMD    = XLTI - ILTI
                    If WRMD <> 0 : ILTI += 1 : Endif
                    WLTI=ILTI
                    # -- 12.05 33887
                    ILTI=0
                    If [M]LTICOD = 2
                        Raz [M:JALK]
                        [M:JALK]CODORI     = 0
                        [M:JALK]CODMAJ     = 2
                        [M:JALK]CODTRS     = 0
                        [M:JALK]MFGFCY     = [M]MFGFCY
                        # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
                        # [M:JALK]ROUNUM     = [M]ITMREF(nolign-1)
                        [M:JALK]ROUNUM     = [M]ROUNUM(nolign-1)
                        [M:JALK]ROUALT     = [M]ROUALT(nolign-1)
                        [M:JALK]REOMINQTY  = [M]EXTQTY(nolign-1)
                        [M:JALK]TRTDAT     = VALEUR
                        [M:JALK]STRDAT     = [M]STRDAT(nolign-1)
                        [M:JALK]ENDDAT     = VALEUR
                        [M:JALK]JAVFLG     = 1
                        [M:JALK]SCDMOD     = 1
                        # Issue 111414/113 - 2016-03-29 by JUSYN : correct start date to select routing needed
                        If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
                            Call INIECCROUDAT([M]ITMREF(nolign-1),[M:JALK]MFGFCY,[M]ROUALT(nolign-1),[M]ROUECCMAJ(nolign-1),[M]ROUECCMIN(nolign-1),WDAT) From RVMLIB
                            If WDAT = [0/0/0] : WDAT = [M:JALK]ENDDAT : Endif
                            [M:JALK]ROUDAT = WDAT
                        Endif

                        Call JALONNE From JALLIB
                        ILTI = ([M:JALK]CODRET <> 0)
                        # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
                        If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : ILTI = 0  : Endif

                        # Issue 111835 - 2015-10-27 by BEEBE : validation modified start date -> the version may not change
                        Call CHECK_VERSION_STRDAT([M:JALK]STRDAT)
                        If GERR
                            VALEUR=[M]ENDDAT(nolign-1)
                            End
                        Endif
                        [M]STRDAT(nolign-1) = [M:JALK]STRDAT
                    Endif
                    # --
                    If [M]LTICOD=1 | ILTI=1 : # GH 11/04/2013
                        # Issue 111835 - 2015-10-27 by BEEBE : validation modified start date -> the version may not change
                        Local Date WORISTRDAT : WORISTRDAT=[M]STRDAT(nolign-1)
                        # révision calendriers (llc 06.00)

                        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB

                        Local Date WNEWSTRDAT : WNEWSTRDAT=[M]STRDAT(nolign-1)
                        Call CHECK_VERSION_STRDAT(WNEWSTRDAT)

                        # when new date not valid to major/minor version
                        If GERR
                            Call TEMPOFF From GESECRAN
                            [M]STRDAT(nolign-1) = WORISTRDAT
                            Affzo STRDAT(nolign-1)
                            VALEUR              = [M]ENDDAT(nolign-1)
                            End
                        Endif
                    Endif
Endcase

Call TEMPOFF From GESECRAN

Affzo STRDAT(nolign-1)
Call CHECK_PAST([M]STRDAT(nolign-1), 2) From MFGLIB
#
End

########################################
Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR

GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
If !find([M]REOCOD(nolign-1),3,5) : mkstat = 2 : End : Endif : # GH 12/04/12 [M]REOCOD(nolign-1) <> 3
GBOUT1=mess(153,198,1)

End

########################################
Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY
Local    Integer WALT

#    Lecture BOM
# GH 12/04/2013 la nomenclature peut être de prod, ou désormais de sous-traitance
Read [TBO]TBO0=[M]BOMALTTYP(nolign-1);VALEUR
If fstat : mkstat=2 : End : Endif

Read [BOH]BOH0=[M]ITMREF(nolign-1);VALEUR;[M]BOMALTTYP(nolign-1)
If fstat : Call ERREUR(mess(95,193,1)) From GESECRAN : mkstat=2 : End : Endif

WFCY=[M]MFGFCY
If [M]STRDAT(nolign-1)=[0/0/0]
    WDAT=date$
Else
    WDAT=[M]STRDAT(nolign-1)
Endif
Case [M]BOMALTTYP(nolign-1)
  When 2 : # production
     Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
     If WALT=0 : Call ERREUR(GMESSAGE) From GESECRAN : mkstat=2 : End : Endif
  When 3 : # sous-traitance
     Call CONTSCONOM(WFCY,WALT,WDAT,1) From SCOLIB
     If WALT=0 : Call ERREUR(GMESSAGE) From GESECRAN : mkstat=2 : End : Endif

     Local    Integer    WLTI, WLTIJO
     Local    Decimal    XLTI
     Local    Char       WSRVIMREF(GLONITM), WORIFCY(GLONFCY), WSNS(1)
     Local    Date       WORIDAT
     # recherche du délai du service associé
     WSRVITMREF = "" : XLTI=0
     Call FIND_SCI_LTI([M]ITMREF(nolign-1), [M]BPSNUM(nolign-1), [M]MFGFCY, VALEUR, WSRVITMREF,XLTI) From SCOLIB
     WLTI = XLTI
     # recalcul date de fin
     WORIDAT=WDAT
     WORIFCY=WFCY
     WSNS = "+"
     WLTIJO = 2
     Gosub CAL_PURDAT From TRTMULTIWX
     [M]ENDDAT(nolign-1) = WDAT
     Affzo ENDDAT(nolign-1)
Endcase

End

########################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()

If [M]REOCOD(nolign-1) <> 3 : mkstat = 2 : End : Endif

# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    Raz VALEUR,[M]ROUNUM(nolign-1),ROUALT(nolign-1)
    mkstat = 2
    End
Endif
GBOUT1=mess(63,198,1)
GBOUT2=""
GBOUT3=""

End

########################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()

# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODM = 1  & VALEUR = ""
    GMESSAGE = mess(31,190,1)
    mkstat = 2
Endif

# Issue 111414/116 - 2016-04-07 by JUSYN :
# check for same version management
If dim([M:MUX1]ROUECCMAJ)>0 & VALEUR<>[M:MUX1]ITMREF(nolign-1)
    If func RVMLIB.NBRCPNROU(VALEUR) <> func RVMLIB.NBRCPNROU([M:MUX1]ITMREF(nolign-1))
        GMESSAGE= mess(343,193,1)
        mkstat=2
        End
    Endif
Endif
# Determine whether to start scheduling later on.
If (VALEUR <> "") & (func RVMLIB.NBRCPNROU(VALEUR) = 0)
    If VALEUR <> [M:MUX1]ROUNUM(nolign-1)  : GROUTINGCX = 1 : Endif
Endif
End

########################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
    [M]ROUALT(nolign-1) = 0
    Affzo ROUALT(nolign-1)
Endif

End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR

If [M]REOCOD(nolign-1) <> 3 : mkstat = 2 : End : Endif

# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    mkstat = 2
    End
Endif
GBOUT1=mess(63,198,1)
GBOUT2=""
GBOUT3=""

End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR

Local    Char    WFCY
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)
# Issue 111414/116 - 2016-04-07 by JUSYN : subprog identifier
Local Char LSUBPROGID(3) : LSUBPROGID = "ALT"
#
If VALEUR = 0
  If [F:MTS]MFGMODM = 2 & [M]ROUNUM(nolign-1) = ""
     End
  Else
    mkstat = 2
    End
  Endif
Endif

WDAT=[M]STRDAT(nolign-1)
WFCY=[M]MFGFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH0=[M]ROUNUM(nolign-1);VALEUR;WFCY   : # Beryl Site en fin de clé primaire
If fstat : mkstat=2 : End : Endif

Call CONTMFGGAM(WFCY,WALT,WDAT,[M]EXTQTY(nolign-1), [M]STU(nolign-1), 1) From MFGLIB
If WALT=0 : Call ERREUR(GMESSAGE) From GESECRAN : mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M]BOMALT(nolign-1), TABTBO)
   GMESSAGE=mess(53,193,1)
   mkstat=2
   End
Endif

# Issue 111414/116 - 2016-04-07 by JUSYN : Check whether to start scheduling and schedule if necessary.
If (VALEUR <> [M:MUX1]ROUALT(nolign-1)) & (func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) = 0)
    GROUTINGCX = 1
Endif
If GROUTINGCX = 1
    Gosub SCHED_ROUTING_NOVERSION
Endif

End

########################################
Subprog AM_FIRRELDAT(VALEUR)
Variable Date    VALEUR

If VALEUR = [0/0/0] : End : Endif
[M]FIRRELDAT = VALEUR
Gosub REJAL From TRTMULTIWX

End

##########################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Read [BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif
    If [M]REOCOD(nolign-1) =  4 & [F:BPR]FCY =  "" : GMESSAGE =mess(235,193,1) :  mkstat=2 : End : Endif
    If [M]REOCOD(nolign-1) <> 4 & [F:BPR]FCY <> "" : GMESSAGE =mess(233,193,1) :  mkstat=2 : End : Endif
Else
    If [M]REOCOD(nolign-1) = 4                     : GMESSAGE =mess(493,199,1) :  mkstat=2 : End : Endif
    If [M]REOCOD(nolign-1) = 5                     : GMESSAGE =mess(534,199,1) :  mkstat=2 : End : Endif
Endif

End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM, WCOEF1, WCOEF2
Local Char       WPUU

#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
Read [ITP]ITP0 = [M]ITMREF(nolign-1);VALEUR
If fstat = 0
    # test du code blocage
    If [F:ITP]DOUFLG = 3
           GMESSAGE = mess(9,194,1)
           Call ERREUR(GMESSAGE) From GESECRAN
           mkstat = 2
           End
    Elsif [F:ITP]DOUFLG = 2
           GMESSAGE = mess(9,194,1)
           Call AVERTIR(GMESSAGE, WRETOUR) From GESECRAN
           If WRETOUR= 1
                     VALEUR = [M]BPSNUM(nolign-1)
                     mkstat = 2
                     End
           Endif
    Endif

    WQTY = [M]PUUPECQTY(nolign-1)
    WPUU = [F:ITP]PUU
    #----- Récupération des coefficients entre UA et US -----#
    # 05.05 30036
    Call PCAL_QTY (1, [M]PUU(nolign-1), GBIDD3, [M]STU(nolign-1),
&                  [M]ITMREF(nolign-1), [M]BPSNUM(nolign-1), 1, WCOEF1) From TRTACHQTE1
    Call PCAL_QTY (1, [F:ITP]PUU, GBIDD3, [M]STU(nolign-1),
&                  [M]ITMREF(nolign-1), VALEUR, 1, WCOEF2) From TRTACHQTE1
    If [M]PUU(nolign-1) <> [F:ITP]PUU | WCOEF1 <> WCOEF2
           GMESSAGE = mess(13,194,1)
           Call MESSAGE(GMESSAGE) From GESECRAN
           #--------- qté achat saisie ------#
           Call PCAL_QTY ([M]EXTQTY(nolign-1), [M]STU(nolign-1), WQTY, [F:ITP]PUU,
&                  [M]ITMREF(nolign-1), VALEUR, 1, [M]PUUSTUCOE(nolign-1)) From TRTACHQTE1
    Endif
    [M]PUUPECQTY(nolign-1) = WQTY
    [M]PUU(nolign-1)       = WPUU
    # qté stock saisie
    Call PCAL_QTY ([M]PUUPECQTY(nolign-1), [M]PUU(nolign-1), [M]EXTQTY(nolign-1), [M]STU(nolign-1),
&                  [M]ITMREF(nolign-1), VALEUR, 1, [M]PUUSTUCOE(nolign-1)) From TRTACHQTE1



    Affzo EXTQTY(nolign-1)
    Affzo PUUPECQTY(nolign-1)
    Affzo PUU(nolign-1)
Else
  # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
  If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
  If [F:BPS]BPSNUM<>VALEUR
    Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Si fournisseur <> Divers -----#
  If [F:BPS]BPSTYP<>3
    # Issue 6976 - 2011-12-16 by MUARN : référencement inutile si article type générique
    If clalev ([F:ITM])<= 0 : Local File ITMMASTER [ITM] : Endif
    If [F:ITM]ITMREF <> [M]ITMREF(nolign-1)
      Read [ITM] ITM0=[M]ITMREF(nolign-1): If fstat Raz [F:ITM] : Endif
    Endif
    If [F:ITM]GENFLG <> 2
      # couple article - fournisseur n'existe pas
      If GITMBPS = 1
             # paramètre général : on ne continue pas
             Call ERREUR(mess(8,194,1)) From GESECRAN
             mkstat = 2
             End
      Elsif GITMBPS = 2
             # paramètre général : facultatif donc avertir
             Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
             If WRETOUR = 1
                  VALEUR = [M]BPSNUM(nolign-1)
                  mkstat = 2
                  End
             Endif
      Endif
    Endif
  Endif
Endif
[M]BPSNUM(nolign-1) = VALEUR
Affzo 10

End

########################################
Subprog C_POHNUM(VALEUR)
Variable Char    VALEUR()

Local    Integer WOK
Local    Date    WDATREF
Local    Date    TODAY : TODAY = date$

If VALEUR = "" : End : Endif

Look [POH]POH0=VALEUR
If fstat: GMESSAGE = mess(354,197,1) : mkstat = 2 : End : Endif
If [M]REOCOD(nolign-1) = 4 & ([F:POH]BETFCY <> 2 | [F:POH]BETCPY = 2)
    GMESSAGE = mess(492,199,1) : mkstat = 2 : End
Endif
If [M]REOCOD(nolign-1) <> 4 & ([F:POH]BETFCY = 2 & [F:POH]BETCPY <> 2)
    GMESSAGE = mess(491,199,1) : mkstat = 2 : End
Endif
If [M]ENDDAT(nolign-1) >= TODAY
    WDATEREF = [M]ENDDAT(nolign-1)
Else
    WDATEREF = TODAY
Endif
## GH 18/01/13 bug 87167 ajout test de STRDAT
Filter [POC] Where POHNUM =  VALEUR & ITMREF   = [M]ITMREF(nolign-1) &
&                  ENDDAT >= WDATEREF & STRDAT <= WDATEREF & PRHFCY = [M]MFGFCY
WOK = 0
For [POC]POC1
    WOK = 1 : Break
Next
Filter [POC]
If !WOK : GMESSAGE = mess(128,192,1) : mkstat = 2 : End : Endif

End

########################################
Subprog AM_POHNUM(VALEUR)
Variable Char    VALEUR()

Local    Char    WUOM1, WUOM2
Local    Decimal WCOEFF

Read [POC]POC0=VALEUR;[M]POPLIN(nolign-1)
If !fstat
    [M]PUU(nolign-1) = [F:POC]PUU
    WUOM1                = [F:POC]PUU
    WUOM2                = [F:POC]STU
    Call RECH_COEFF(WUOM1,WUOM2,WCOEFF) From MFGLIB
    [M]PUUSTUCOE(nolign-1)     = WCOEFF
Endif
If VALEUR <> ""
    Read [POH]POH0=VALEUR
    If fstat : Raz [POH] : Endif

    [M]BPSNUM(nolign-1) = [F:POH]BPSNUM
    [M]PJT(nolign-1)    = ""

    Affzo BPSNUM(nolign-1)
    Affzo PJT(nolign-1)
    Call PCAL_QTY([M]EXTQTY(nolign-1), [M]STU(nolign-1),[M]PUUPECQTY(nolign-1),[M]PUU(nolign-1),
&             [M]ITMREF(nolign-1),[M]BPSNUM(nolign-1),1,WCOEFF) From TRTACHQTE1
    If WCOEFF <> 0 : [M]PUUSTUCOE(nolign-1) = 1/WCOEFF : Endif        # 05.01 llc

    [M]POHNUM(nolign-1) = VALEUR
    Affzo 10
Endif

End

