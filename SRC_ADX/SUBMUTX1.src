########################################
# Issue 111835 - 2015-10-27 by BEEBE : validation modified start date -> the version may not change
Subprog CHECK_VERSION_STRDAT(VALEUR)
Variable Date VALEUR()

Local Integer LECCTYP
Local Integer LFOUND : LFOUND=0

If dim([M]ECCVALMAJ)>0 & [M]ECCVALMAJ(nolign-1)<>""
    Case [M]WIPTYP(nolign-1)
        When 5       : LECCTYP=2
        When 13,4    : LECCTYP=3
        When Default : LECCTYP=4
    Endcase

    If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
    If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif

    # Is the actual version valid for the new start date ?
    # selection depends of the flow-type
    Local Date WDATE : WDATE=VALEUR

    If LECCTYP=4
        Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&                  As [LNK]
&                  Where [EVL]ITMREF=[M]ITMREF(nolign-1)
&                      & [EVL]ECCVALMAJ=[M]ECCVALMAJ(nolign-1)
&                      & [EVL]ECCVALMIN=[M]ECCVALMIN(nolign-1)
&                      & [EVL]ECCTYP=4
&                      & [EVL]USESTA=2
&                      & [ECS]STRDAT<=WDATE
&                      & ([F:ECS]ENDDAT=[0/0/0] | [F:ECS]ENDDAT>=WDATE | [F:ECS]EXNFLG=2)
&                      & ([F:ECS]EXNDAT=[0/0/0] | [F:ECS]EXNDAT>=WDATE | [F:ECS]EXNFLG=1)
&                      & [F:ECS]ECCSTA<>3
&               Order By EXNFLG;ECCSEQ
    Else
        Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&                  As [LNK]
&                  Where [EVL]ITMREF=[M]ITMREF(nolign-1)
&                      & [EVL]ECCVALMAJ=[M]ECCVALMAJ(nolign-1)
&                      & [EVL]ECCVALMIN=[M]ECCVALMIN(nolign-1)
&                      & [EVL]ECCTYP=LECCTYP
&                      & [EVL]USESTA=2
&                      & [EVL]STRDAT<=WDATE
&                      & ([F:EVL]ENDDAT=[0/0/0] | [F:EVL]ENDDAT>=WDATE | [F:EVL]EXNFLG=2)
&                      & ([F:EVL]EXNDAT=[0/0/0] | [F:EVL]EXNDAT>=WDATE | [F:EVL]EXNFLG=1)
&                      & [F:ECS]ECCSTA<>3
&               Order By EXNFLG;ECCSEQ
    Endif

    # LFOUND=1 -> the version is valid for the new start date
    For [LNK]
        LFOUND=1
        Break
    Next

    # LFOUND=False -> the version is not valid, the start date has to be
    #                 set to the origin start date
    If !LFOUND
        GMESSAGE=mess(432,184,1)-num$(WDATE)
        # Issue 111414/11 - 2016-02-10 by JUSYN : Extend message to be clear message raised because of error in BOM version
        Gosub ERR_TIT
        If TIT <> ""
            Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(153,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
            GMESSAGE = ""
        Endif
        [M:MUX1]PECFLG(nolign-1) = 1

        mkstat=2
        GERR=1
    Endif
Endif
End

######################################################################################
# Issue 111414/11 - 2016-02-10 by JUSYN : Check validity of routing version
Funprog CHECK_ROUVERSION_STRDAT(PDAT)
Variable Date PDAT
Local Integer LRET


If dim([M:MUX1]ROUECCMAJ) > 0 & [M:MUX1]ROUNUM(nolign-1) <> "" & func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) > 0
    Call CTRROUECC([M:MUX1]ROUNUM(nolign-1),[M]MFGFCY,"MUX1","STRDAT",[M:MUX1]ROUECCMAJ(nolign-1),[M:MUX1]ROUECCMIN(nolign-1),
&                 PDAT,LRET,GMESSAGE) From RVMLIB
Endif

If find(LRET,1,4)
    Gosub ERR_TIT
    If TIT <> ""
        Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(63,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
        GMESSAGE = ""
    Endif
    mkstat = 2 : End 1
Endif
End 0

# Get current field title in current language to specifiy validated field
$ERR_TIT
Local Char TIT(GLONDES)
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
Read [AMZ]CODE = maskcou;zoncou
If !fstat
   If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
   Read [ATX]NUMERO = GLANGUE;[F:AMZ]INTIT
   If !fstat : TIT=[F:ATX]TEXTE : Endif
Endif
Return

# Issue 111414/11 - 2016-02-22 by JUSYN : routing validation handling
######################################################################################
## Section automatically added (screen MULTIWOX1) 02/17/2016 15:02:26 (JUSYN)
######################################################################################
Subprog AS_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()

If func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) < 1
   mkstat = 1
Endif
End

End
######################################################################################
Subprog C_ROUECCMAJ(VALEUR)
Variable Char   VALEUR()
Local Integer   LRET
# Issue 111414/113 - 2016-03-31 by JUSYN : subprog identifier
Local Char LSUBPROGID(3) : LSUBPROGID = "MAJ"


If VALEUR = ""
    GMESSAGE = mess(10,123,1) : LRET=1
Else
    Call CTRROUECC([M:MUX1]ROUNUM(nolign-1),[M:MUX1]MFGFCY,"MUX1","ROUECCMAJ",VALEUR,[M:MUX1]ROUECCMIN(nolign-1),
&                  [M:MUX1]STRDAT(nolign-1),LRET,GMESSAGE) From RVMLIB
Endif

If find(LRET,1,4)
    Gosub ERR_TIT
    If TIT <> ""
        Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(63,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone...
        GMESSAGE = ""
    Endif
    mkstat = 2 : End
Endif

If VALEUR <> [M:MUX1]ROUECCMAJ(nolign-1)  : GROUTINGX = 1 : Endif
If func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) = 1
    Gosub SCHED_ROUTING
Endif

End
######################################################################################
Subprog AS_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

If func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) < 2
   mkstat = 1
Endif
End
######################################################################################
Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
# Issue 111414/113 - 2016-03-31 by JUSYN : subprog identifier
Local Char LSUBPROGID(3) : LSUBPROGID = "MIN"


If VALEUR = ""
    GMESSAGE = mess(10,123,1) : LRET=1
Else
    Call CTRROUECC([M:MUX1]ROUNUM(nolign-1),[M:MUX1]MFGFCY,"MUX1","ROUECCMIN",[M:MUX1]ROUECCMAJ(nolign-1),VALEUR,
&                 [M:MUX1]STRDAT(nolign-1),LRET,GMESSAGE) From RVMLIB
Endif
If find(LRET,1,4)
    Gosub ERR_TIT
    If TIT <> ""
        Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(63,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
        GMESSAGE = ""
    Endif
    mkstat = 2 : End
Endif

If VALEUR <> [M:MUX1]ROUECCMIN(nolign-1)  : GROUTINGX = 1 : Endif
If func RVMLIB.NBRCPNROU([M:MUX1]ROUNUM(nolign-1)) = 2
    Gosub SCHED_ROUTING
Endif

End

# Issue 111414/11 - 2016-02-22 by JUSYN : routing validation handling
######################################################################################
## Section automatically added (screen MULTIWOX1) 02/22/2016 14:11:15 (JUSYN)
######################################################################################
Subprog AVANT_NBLIG
GROUTINGX = 0
# Issue 111414/116 - 2016-04-07 by JUSYN : Initialise
GROUTINGCX = 0
End
######################################################################################
$SCHED_ROUTING
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI, WLTIJO
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Char    WSNS(1), WSRVITMREF(GLONITM)
# Issue 111414/113 - 2016-03-29 by JUSYN : work date for start date of routing version
Local    Date    WDAT
Local    Char    WROUECCMAJ(GLONICVVAL)      : # Working field for route major version
Local    Char    WROUECCMIN(GLONICVVAL)      : # Working field for route minor version


If GROUTINGX <> 1
    Return
Endif
# Issue 111414/113 - 2016-03-31 by JUSYN : fill working field for route version
If LSUBPROGID = "MAJ"
    WROUECCMAJ = VALEUR
    WROUECCMIN = [M]ROUECCMIN(nolign-1)
Else
    WROUECCMAJ = [M]ROUECCMAJ(nolign-1)
    WROUECCMIN = VALEUR
Endif

WORIDAT = [M]ENDDAT(nolign-1)
WORIFCY = [M]MFGFCY
WLTI    = 0

# Read product site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif

# calculate start date
Case [M]REOCOD(nolign-1)
    When 3      :   WQTY = [M]EXTQTY(nolign-1)
                    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                    ILTI    = int(XLTI)
                    WRMD    = XLTI - ILTI
                    If WRMD <> 0 : ILTI += 1 : Endif
                    WLTI=ILTI

                    ILTI=0
                    If [M]LTICOD = 2
                        Raz [M:JALK]
                        [M:JALK]CODORI     = 0
                        [M:JALK]CODMAJ     = 2
                        [M:JALK]CODTRS     = 0
                        [M:JALK]MFGFCY     = [M]MFGFCY
                        # Issue 111414/116 - 2016-04-07 by JUSYN : ITMREF not automatically the routing number. Must be taken from ROUNUM.
                        # [M:JALK]ROUNUM     = [M]ITMREF(nolign-1)
                        [M:JALK]ROUNUM     = [M]ROUNUM(nolign-1)
                        [M:JALK]ROUALT     = [M]ROUALT(nolign-1)
                        [M:JALK]REOMINQTY  = [M]EXTQTY(nolign-1)
                        [M:JALK]TRTDAT     = [M]STRDAT(nolign-1)
                        [M:JALK]STRDAT     = [M]STRDAT(nolign-1)
                        [M:JALK]ENDDAT     = [M]ENDDAT(nolign-1)
                        [M:JALK]JAVFLG     = 1
                        [M:JALK]SCDMOD     = 1
                        # Issue 111414/113 - 2016-03-31 by JUSYN : correct start date to select routing needed
                        If func RVMLIB.NBRCPNROU([M:JALK]ROUNUM) > 0
                            Call INIECCROUDAT([M]ITMREF(nolign-1),[M:JALK]MFGFCY,[M]ROUALT(nolign-1),WROUECCMAJ,WROUECCMIN,WDAT) From RVMLIB
                            If WDAT = [0/0/0] : WDAT = [M:JALK]ENDDAT : Endif
                            [M:JALK]ROUDAT = WDAT
                        Endif

                        Call JALONNE From JALLIB
                        ILTI = ([M:JALK]CODRET <> 0)
                        # Issue 111414/113 - 2016-03-29 by JUSYN : Versioned routing in scheduling mode backwards with invalid version at start date taken to report error in MULTIWOX1.
                        If [M:JALK]ROUDAT <> [0/0/0] & [M:JALK]CODRET = 2 : ILTI = 0  : Endif

                        [M]STRDAT(nolign-1) = [M:JALK]STRDAT
                    Endif
                    # --
                    If [M:JALK]CODRET = 2 : ILTI = 0 : Endif
                    If [M]LTICOD=1 | ILTI=1
                        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB
                    Endif
Endcase

Affzo [M]STRDAT(nolign-1)
Call CHECK_PAST([M]STRDAT(nolign-1), 2) From MFGLIB
GROUTINGX = 0
Return

# Issue 111414/116 - 2016-04-07 by JUSYN : scheduling after change of routing or routing code
######################################################################################
$SCHED_ROUTING_NOVERSION
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI, WLTIJO
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Char    WSNS(1), WSRVITMREF(GLONITM)
Local    Integer WROUALT

If GROUTINGCX <> 1
    Return
Endif

If LSUBPROGID = "ALT"
    WROUALT = VALEUR
Endif

WORIDAT = [M]ENDDAT(nolign-1)
WORIFCY = [M]MFGFCY
WLTI    = 0

# Read product site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif

# calculate start date
Case [M]REOCOD(nolign-1)
    When 3      :   WQTY = [M]EXTQTY(nolign-1)
                    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
                    ILTI    = int(XLTI)
                    WRMD    = XLTI - ILTI
                    If WRMD <> 0 : ILTI += 1 : Endif
                    WLTI=ILTI

                    ILTI=0
                    If [M]LTICOD = 2
                        Raz [M:JALK]
                        [M:JALK]CODORI     = 0
                        [M:JALK]CODMAJ     = 2
                        [M:JALK]CODTRS     = 0
                        [M:JALK]MFGFCY     = [M]MFGFCY
                        [M:JALK]ROUNUM     = [M]ROUNUM(nolign-1)
                        [M:JALK]ROUALT     = WROUALT
                        [M:JALK]REOMINQTY  = [M]EXTQTY(nolign-1)
                        [M:JALK]TRTDAT     = [M]STRDAT(nolign-1)
                        [M:JALK]STRDAT     = [M]STRDAT(nolign-1)
                        [M:JALK]ENDDAT     = [M]ENDDAT(nolign-1)
                        [M:JALK]JAVFLG     = 1
                        [M:JALK]SCDMOD     = 1

                        Call JALONNE From JALLIB
                        ILTI = ([M:JALK]CODRET <> 0)
                        [M]STRDAT(nolign-1) = [M:JALK]STRDAT
                    Endif
                    # --
                    If [M]LTICOD=1 | ILTI=1
                        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB
                    Endif
Endcase

Affzo [M]STRDAT(nolign-1)
Call CHECK_PAST([M]STRDAT(nolign-1), 2) From MFGLIB
GROUTINGCX = 0

Return

