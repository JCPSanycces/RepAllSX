#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICRM012   AUGMENTATION TAILLE ITN.DUR à 6 au lieu de 5 c  Module CRM #
#                                                                        #
##########################################################################
# FGR 23/07/2014 : X3SUIVI101618
##########################################################################
Local Char DOSSIER(30)

  If 1=1 Then
    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTICRM012(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTICRM012(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICRM012(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTICRM012: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If filinfo(filpath("FIL", "INTERVEN", "fde", DOSSIER), 0) <= 0 Then
    End
  Endif
  Local File =DOSSIER + ".INTERVEN"  [ITN]
  If type([F:ITN]DUR)-1 < 6 Then
    End
  Endif
  # --------------------------------------
  COMPTEUR = 0
  Trbegin [ITN]
  Filter [F:ITN] Where len([F:ITN]DUR) < 5
  For [F:ITN]
    [F:ITN]DUR = "0" + [F:ITN]DUR
    Rewrite [ITN]
    If fstat Then
      Call ECR_TRACE("File INTERVEN, Error ="-num$(fstat) - "[" + [F:ITN]NUM + "]",1) From GESECRAN
    Endif
    COMPTEUR += 1
  Next
  Filter [F:ITN]
  Commit
  # --------------------------------------
  Close Local File [ITN]
  Call ECR_TRACE("UTICRM012 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTICRM012(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTICRM012(APPLI)
End
