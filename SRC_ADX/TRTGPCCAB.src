#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# CONSULTATION PIECES COMPTABLES :
# ==============================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
# $OUVRE
#
########################################################################################################################
# Modifications :
# -------------
#
# - CBO - 12.02.2014 - FQ 96276 - Erreur affichage libellé des axes analytiques
# - GLE - 18.06.2013 - FQ 90566 - Erreur sur LLEDTGT si aucune pièce ou "Chargement dernier lu" à Non
# - GBO - 03.02.2010 - FQ 71300 - Erreur ANA(-1) indice incorrect.
# - GBO - 13.12.2010 - FQ 69824 - Prise en compte du multi-référentiels dans la compta avale
# - GBO - 30.06.2010 - Fq 65756 - Consultation successive de pièces à partir du détail plan d'amortissement d'un bien :
#                                 Rémanence des infos de la pièce précédente sur les lignes.
# - GBO - 19.03.2010 - Fq 63269 - Info état tâches comptabilité sur la consultation pièces comptables
#
########################################################################################################################
End

#-------------------------------------------------------------------------------------
$ACTION
 Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "TERMINE"     : Gosub TERMINE
  When Default
 Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE
 Local Char    LTYP
 Local Char    LNUM
 Local Integer LREF
 Local Integer I_LIGNE, I_CCE, LNBLIGANA
 Local Decimal TOTDEB
 Local Decimal TOTCDT

 LTYP    = PARAM(1)
 LNUM    = PARAM(2)
 LREF    = val(PARAM(3))

 Global Char    GLIBDEFTAB(30)
 Global Integer GCPTBAT
 Global Integer GTYPLEDANA
 Global Integer GTMPTAB          : GTMPTAB=1

 Global Char    GTITDIE(20)(15)

Return

#-------------------------------------------------------------------------------------
$DEBUT
 If !clalev([F:LCA]) : Local File LNKCPTABX3 [LCA] : Endif
 If !clalev([F:LCD]) : Local File LNKCPTABD  [LCD] : Endif
 If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif

 Gosub LOAD_PCE
 # FQ96276
 Gosub SET_TITCOL

Return

#-------------------------------------------------------------------------------------
$LOAD_PCE
 GTMPTAB=1

 If clalev([F:HAT])  : Close Local File [F:HAT] : Endif
 If clalev([F:DAT])  : Close Local File [F:DAT] : Endif
 If clalev([F:DAA])  : Close Local File [F:DAA] : Endif
 If !clalev([F:HAT]) : Local File =GTABCPT+"GACCTMP"  [HAT] : Endif
 If !clalev([F:DAT]) : Local File =GTABCPT+"GACCTMPD" [DAT] : Endif
 If !clalev([F:DAA]) : Local File =GTABCPT+"GACCTMPA" [DAA] : Endif

 If [F:LCA]TYP<>LTYP | [F:LCA]NUM<>LNUM
  Read [F:LCA]LCA2=LTYP;LNUM
 Endif

 Read [F:HAT]HAT0=LTYP;LNUM
 If fstat=5
  If clalev([F:HAT])  : Close Local File [F:HAT] : Endif
  If clalev([F:DAT])  : Close Local File [F:DAT] : Endif
  If clalev([F:DAA])  : Close Local File [F:DAA] : Endif
  If !clalev([F:HAT]) : Local File =GTABCPT+"GACCENTRY"   [HAT] : Endif
  If !clalev([F:DAT]) : Local File =GTABCPT+"GACCENTRYD"  [DAT] : Endif
  If !clalev([F:DAA]) : Local File =GTABCPT+"GACCENTRYA"  [DAA] : Endif
  Read [F:HAT]HAE0=LTYP;LNUM
  If !fstat
   GTMPTAB=0
  Else
   Infbox mess(127,7778,1) #"Cette pièce n'existe plus en comptabilité"
   Return
  Endif
 Endif

 Local Integer ERROR : Raz [M:FPC]
 Call LOAD_FASPARCPY([F:HAT]CPY,"",G_OUI,ERROR) From GLOFCYCPY

 #@fq65756
 Raz [M:GC0]
 Raz [M:GC2]

 If !fstat
  [M:GC0]=[F:HAT]
  If GTMPTAB=1
   [M:GC0]TMPTAB="128"
   [M:GC0]DEFTAB="127"
   [M:GC0]TYPTAB=mess(110,7778,1)
  Else
   [M:GC0]TMPTAB="128"
   [M:GC0]DEFTAB="128"
   [M:GC0]TYPTAB=mess(109,7778,1)
  Endif

#Fq63269
# If GCPTBAT
#  [M:GC0]CPTBAT = mess(113,7778,1) #"Tâche comptable active"
# Else
#  [M:GC0]CPTBAT = mess(114,7778,1) #"Tâche comptable inactive"
# Endif

  [M:GC0]TRACE = [F:LCA]TRACE
  [M:GC2]=[F:HAT]
  #[M:GC2]=[F:HAT] : # FQ90566 : redondance
  Local Integer ERR
  Call LOAD_FASPARCPY([F:HAT]CPY,"",G_NON,ERR) From GLOFCYCPY
  Local Char LCRIT(255)
  LCRIT = 'TYP=[F:HAT]TYP & NUM=[F:HAT]NUM'
  #fq69824
  # Détermination de la liste des référentiels disponibles
  Global Integer LLEDTGT(10)
  Local  Integer I_LED, I_FIRSTLED
  Local  Char    LCRIT2(255)
  For I_LED=1 To 10
   LCRIT2 = LCRIT+"&LEDTYP="+num$(I_LED)
   Filter [F:DAT] Where evalue(LCRIT2)
    Read [F:DAT]First
    If fstat
     LLEDTGT(I_LED-1)=0
    Else
     LLEDTGT(I_LED-1)=1
     If !I_FIRSTLED
      I_FIRSTLED=I_LED
     Endif
    Endif
  Next
  Filter [F:DAT]
  [M:GC0]LEDTYP=I_FIRSTLED
  #fq69824-Fin
  LCRIT+='&LEDTYP='+num$(I_FIRSTLED)
  GTYPLEDANA=I_FIRSTLED
  Gosub LOAD_PCE_LIN
  Endif

 Affzo [M:GC0]
 Affzo [M:GC2]

Return

#**
#* Chargement des lignes de la pièce
#*!
$LOAD_PCE_LIN
  Local Integer I_LIGNE
  Raz [M:GC2]TOTDEB, [M:GC2]TOTCDT
  For [F:DAT] Where  evalue(LCRIT)
   I_LIGNE+=1
   nolign = I_LIGNE
   [M:GC2]=[F:DAT]
   If [F:DAT]SNS>0
    [M:GC2]DEB(nolign-1)=[F:DAT]AMTCUR : TOTDEB += [F:DAT]AMTCUR
   Else
    [M:GC2]CDT(nolign-1)=[F:DAT]AMTCUR : TOTCDT += [F:DAT]AMTCUR
   Endif
   #Fq-69824
    Filter [F:DAA] Where TYP=[F:DAT]TYP & NUM=[F:DAT]NUM & LIN=[F:DAT]LIN & LEDTYP=GTYPLEDANA
    LNBLIGANA=rowcount([F:DAA])
    If LNBLIGANA=1
     Local Char LNOMCHAMP
     For [F:DAA]
      For I_CCE=1 To 9
       LNOMCHAMP="[M:GC2]CCE"+num$(I_CCE)+"(nolign-1)" : Assign LNOMCHAMP With evalue("[F:DAA]CCE("+num$(I_CCE-1)+")")
      Next I_CEE
     Next
    Elsif LNBLIGANA>1 | [M:GC2]DSP(nolign-1)<>""
     [M:GC2]CCE1(nolign-1)="$"
    Endif
    Filter [F:DAA]
   #Fq-69824-Fin
  Next
  [M:GC2]NBLIG=I_LIGNE
  [M:GC2]TOTDEB = TOTDEB
  [M:GC2]TOTCDT = TOTCDT
  [M:GC2]SOLDE  = TOTDEB-TOTCDT
Return

#-------------------------------------------------------------------------------------
$TERMINE
 If dim(GLIBDEFTAB)>0 : Kill GLIBDEFTAB : Endif
 If dim(GCPTBAT)>0    : Kill GCPTBAT    : Endif
 If dim(GTMPTAB)>0    : Kill GTMPTAB    : Endif
 If dim(GTYPLEDANA)>0    : Kill GTYPLEDANA    : Endif
Return

######################################################################################
## Gestion de l'écran GACCAB0
######################################################################################

#**
#* @param VALEUR
#*!
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
End

#**
#* Tunnel vers la fonction "Tâches comptabilité"
#*
#* @param VALEUR
#*!
Subprog CL_CPTBATICO(VALEUR)
Variable Char    VALEUR()
 Local Char PARAM(30)(1..2) , VALEUR(10)
 Call SAISIE_CHAR(VALEUR,PARAM,"CPTBATCH","CPTBATCH","") From GSAISIE
End

#**
#* Avant saisie du chammp LEDTYP
#* @param VALEUR
#*!
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
 Local Integer I_LED

 # FQ90566
 If ([M:GC0]NUM='') : mkstat = 2 : End : Endif

 For I_LED=1 To 10
  If LLEDTGT(I_LED-1)=0
   GMENLOC(I_LED)=1
  Endif
 Next I_LED
 Gosub SET_CCECOL
End

#**
#* Après modification du chammp LEDTYP
#* @param VALEUR
#*!
Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR

 [M:GC0]LEDTYP=VALEUR
 #Raz [M:GC2]
 Effzo [M:GC2]20-99 : # FQ90566
 Gosub SET_TITCOL
 LCRIT='TYP="'+[M:GC0]TYP+'"&'+'NUM="'+[M:GC0]NUM+'"&LEDTYP='+num$(VALEUR)
 GTYPLEDANA=VALEUR
 Gosub LOAD_PCE_LIN
 Affzo [M:GC2]
 Call AV_NBLIG
End

######################################################################################
## Gestion de l'écran GACCAB2
######################################################################################

#**
#* Conditionnement de bouton tunnel vers les ventilations analytiques
#*!
Subprog AS_NBLIG

 #> Imputations analytique non ventilées sur la ligne.

 If [M:GC2]CCE1(nolign-1)<>"$"
  GBOUT1=""
 Endif

 #> Pièce toujours en table temporaire, impossible de la consulter par la fonction X3

 If GTMPTAB
  GBOUT2=""
 Endif
End

#**
#* Affichage / masquage des colonnes axes analytiques
#*!
Subprog AV_NBLIG
 Gosub SET_CCECOL
End

#-----------------------------------------------------
$SET_TITCOL
 Local Integer I_DIE
 For I_DIE=1 To 9
  If evalue("[M:FPC]CCE"+num$(I_DIE)+"("+num$([M:GC0]LEDTYP-1)+")=''")
   GTITDIE(I_DIE)=''
  Else
   Local Char LDIE(20)
   LDIE = evalue("[M:FPC]CCE"+num$(I_DIE)+"("+num$([M:GC0]LEDTYP-1)+")")
   If LDIE<>"" : GTITDIE(I_DIE)=LDIE+"-"+[M:FPC]DIEDESSHO(find(LDIE,[M:FPC]DIE)-1) : Endif
          Endif
 Next I_DIE
Return

#-----------------------------------------------------
$SET_CCECOL
 Local Integer I_DIE
 Local Char    LFORMAT

 #Fq71300
 If [M:GC0]LEDTYP<>0 & evalue("[M:FPC]ANA("+num$([M:GC0]LEDTYP-1)+")=G_OUI")
  LFORMAT="K:"+num$(GLONCNA)+"X" : Chgfmt [M:GC2]CNA With LFORMAT
  LFORMAT="K:"+num$(GLONUOM)+"X" : Chgfmt [M:GC2]UOM With LFORMAT
  LFORMAT="K:"+num$(GLONDSP)+"X" : Chgfmt [M:GC2]DSP With LFORMAT
  For I_DIE=1 To 9
   If evalue("[M:FPC]CCE"+num$(I_DIE)+"("+num$([M:GC0]LEDTYP-1)+")=''")
    LFORMAT="-K:"+num$(GLONCCE)+"X"
   Else
    LFORMAT="K:"+num$(GLONCCE)+"X"
   Endif
   Gosub CHGCCEFMT
  Next I_DIE
 Else
  # Référentiel non suivi en analytique
  For I_DIE=1 To 9
   LFORMAT="-K:"+num$(GLONCCE)+"X"
   Gosub CHGCCEFMT
  Next I_DIE
  LFORMAT="-K:"+num$(GLONCNA)+"X" : Chgfmt [M:GC2]CNA With LFORMAT
  LFORMAT="-K:"+num$(GLONUOM)+"X" : Chgfmt [M:GC2]UOM With LFORMAT
  LFORMAT="-K:"+num$(GLONDSP)+"X" : Chgfmt [M:GC2]DSP With LFORMAT
 Endif

Return

#-----------------------------------------------------
$CHGCCEFMT
 Case I_DIE
    When 1 : Chgfmt [M:GC2]CCE1 With LFORMAT
    When 2 : Chgfmt [M:GC2]CCE2 With LFORMAT
    When 3 : Chgfmt [M:GC2]CCE3 With LFORMAT
    When 4 : Chgfmt [M:GC2]CCE4 With LFORMAT
    When 5 : Chgfmt [M:GC2]CCE5 With LFORMAT
    When 6 : Chgfmt [M:GC2]CCE6 With LFORMAT
    When 7 : Chgfmt [M:GC2]CCE7 With LFORMAT
    When 8 : Chgfmt [M:GC2]CCE8 With LFORMAT
    When 9 : Chgfmt [M:GC2]CCE9 With LFORMAT
   Endcase
Return

#**
#* Tunnel vers la trace.
#*!
Subprog B3_NBLIG
 If [M:GC0]TRACE<>""
  GTRACE=[M:GC0]TRACE
  Call LEC_TRACE() From LECFIC
 Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran GPCCAB2) 05/01/2011 16:25:07 (GBO)
######################################################################################
Subprog AVANT_NBLIG
 Call AV_NBLIG
End
