#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier REGUL
Raz GPILOBJ
Call OBJET("RGL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS"       : Gosub LIENS
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "SETBOUT"     : Gosub SETBOUT
 When "FERME"       : Gosub FERME
 When "EXEC"
  Case GACTION
   When "REGULSAL"  : Gosub REGULSAL
  Endcase
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
 When "ANNULE"      : Gosub ANNULE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
Endcase
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
#If the user select a record
If [F:RGL]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:RGL0]LEG)>=0 : [M:RGL0]LEG=[F:RGL]LEG: Endif
 GCURLEG=[F:RGL]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:RGL0]LEG)>=0
  GCURLEG=[M:RGL0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$SETBOUT
If !CLECUR or GREP<>""
 Call VIREBOUT(CHAINE,"18") From GOBJET
Endif
If GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
Return

$OUVRE
Local Integer I, J, POS
Local Char CTRNUM([V]GLONHRCTR), REFNUM([V]GLONEML), CTRCRI([V]GLONEML+[V]GLONHRCTR+1+10)
##**82073
Local Date CTRDAT
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If !clalev([F:ID3])  : Local File EMPLOID   [ID3]  : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$INICRE
Gosub SET_CTRCRI
Return

$INIMOD
Gosub SET_CTRCRI
Return

$LIENS
If dim([M:RGL0]LEG)>0
  GCURLEG=[M:RGL0]LEG
Endif

If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M:RGL0]DES,"REGUL","DES",GCURLEG,[M:RGL0]COD) From ATEXTRA
Call LECTEXTRA([M:RGL0]SHO,"REGUL","SHO",GCURLEG,[M:RGL0]COD) From ATEXTRA

##**82073
Raz [L]REFNUM, [L]CTRNUM, [L]I, [L]J, [L]CTRCRI, [L]CTRDAT

For [L]I = 0 To min(dim([F:RGL]CTRCRI) - 1, dim([M:RGL1]REFNUM) - 1)
    If [F:RGL]CTRCRI([L]I) = ""
        Break
    Endif
    [L]CTRCRI = [F:RGL]CTRCRI([L]I)
    [L]POS = instr(1, [L]CTRCRI, "~")
    If [L]POS > 0
        [L]REFNUM = left$([L]CTRCRI, [L]POS - 1)
        [L]CTRNUM = right$([L]CTRCRI, [L]POS + 1)

        Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM
&                            & [F:HRCTR]CTRNUM = [L]CTRNUM

        Read [F:HRCTR]CTR0 Last

        If fstat < 4
            [M:RGL1]REFNUM([L]J) = [F:HRCTR]REFNUM
            # FQ61463 - segay 29/07/2013 - Homogénéisation nom prénom
            Call UPD_NAMSRN([M:RGL1]REFNUM([L]J),"[M:RGL1]","","SRN",1,[L]J) From DIVPAYE

            [M:RGL1]CTRNUM([L]J) = [F:HRCTR]CTRNUM
            [M:RGL1]CTRDAT([L]J) = [F:HRCTR]CTRDAT

            [L]J += 1
            If [L]J >= dim([M:RGL1]REFNUM)
                # mess(26, 100, 1) : Tableau plein
                Call ERREUR("NBCTR : "-mess(26,100,1)) From GESECRAN
                Break
            Endif
        Endif

        Filter [F:HRCTR]

    Endif
Next
[M:RGL1]NBCTR = [L]J

Return

$MODIF
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("REGUL","DES",CLECUR1,"","REGUL","DES",GCURLEG,[F:RGL]COD)  From ATEXTRA
 Call DUPTEXTRA("REGUL","SHO",CLECUR1,"","REGUL","SHO",GCURLEG,[F:RGL]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:RGL0]DES,"REGUL","DES",GCURLEG,[F:RGL]COD) From ATEXTRA
Call MAJTEXTRA([M:RGL0]SHO,"REGUL","SHO",GCURLEG,[F:RGL]COD) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("REGUL","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call CHGTEXTRA("REGUL","SHO",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call SETPAR From GENPLAN
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("REGUL","DES",[L]CODE,SUPP) From ATEXTRA
Call SUPTEXTRA("REGUL","SHO",[L]CODE,SUPP) From ATEXTRA
Return

$SET_CTRCRI
##**82073 : Add CTRDAT

# Sauvegarde de REFNUM~CTRNUM~CTRDAT dans CTRCRI
# pour évaluation de la régul

Raz [F:RGL]CTRCRI
For [L]I = 0 To min([M:RGL1]NBCTR - 1, dim([F:RGL]CTRCRI) - 1)
 If [M:RGL1]REFNUM([L]I) = "" : Break : Endif
 [F:RGL]CTRCRI([L]I) = [M:RGL1]REFNUM([L]I) + "~" + [M:RGL1]CTRNUM([L]I)+ "~" + format$("D:YYYYMMDD",[M:RGL1]CTRDAT([L]I))
Next
Return

################################################################################
## Etiquettes Ecran RGL0 RGL1 RGL2
################################################################################

Subprog C_EMPSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]EMPSTR & [M]EMPEND=""
 [M]EMPEND = VALEUR
Endif
End

Subprog AS_VARVAL(VALEUR)
Variable Decimal VALEUR
If [M]VARCOD2(nolign-1)<>""
 mkstat=2 : End
Endif
End

Subprog AM_VARVAL(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 Effzo [M]VARCOD2(nolign-1)
 Affzo [M]VARCOD2(nolign-1)
Endif
End

Subprog AS_VARCOD2(VALEUR)
Variable Char    VALEUR()
If [M]VARVAL(nolign-1)<>0
 mkstat=2 : End
Endif
End

Subprog AM_VARCOD2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo [M]VARVAL(nolign-1)
 Affzo [M]VARVAL(nolign-1)
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(VALEUR,"[M:RGL1]","","SRN",1,nolign-1) From DIVPAYE
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
 Gosub DATREF
 Call SELCTR([M:RGL1]REFNUM(nolign-1),[L]DATREF(2), [L]DATREF(1),VALEUR) From DIVPAYE
Endif
If [F:ID]FLGMULCTR<>2 : mkstat=2 : End : Endif
End

$DATREF
Local Date DATREF (1..2)
If [M]ENASTR<>[0/0/0]
 DATREF(1)=[M]ENASTR
Else
 DATREF(1)=GMOIPAY
Endif
If [M]ENAEND<>[0/0/0]
 DATREF(2)=[M]ENAEND
Else
 DATREF(2)=eomonth(GMOIPAY)
Endif
Return

################################################################################
## Liste des salariés
################################################################################
$REGULSAL
Local Char RGLDES([V]GLONAX3)
Read [RGL]RGL0 =GCURLEG;[M:RGL0]COD
Call LECTEXTRA(RGLDES,"REGUL","DES",GCURLEG,[F:RGL]COD) From ATEXTRA
Call POPULATION (GCURLEG,[F:RGL]FCY,[F:RGL]PRF,[F:RGL]SRV,[F:RGL]EMPSTR,[F:RGL]EMPEND,[F:RGL]POP
&              ,[F:RGL]CRI, [F:RGL]CTRCRI, mess(101,10702,1)-":"-[F:RGL]COD-RGLDES) From SUBECH
TRA = 1
Return


#####################################
# B1_NBCTR : Chargement des contrats
#####################################
Subprog B1_NBCTR

Local Integer NBCTR, OK
[L]OK = 2

# Si aucun critère ... interdiction de charger quelquechose qui manifestement fera exploser le
# tableau
If vireblc([M:RGL1]FCY+[M:RGL1]PRF+[M:RGL1]SRV+[M:RGL1]EMPSTR+[M:RGL1]EMPEND+
&                [M:RGL1]POP+[M:RGL1]CRI, 4) = ""
    # mess(169,10702,1) : Aucun filtre défini - Opération impossible
    Call ERREUR(mess(169,10702,1)) From GESECRAN
    mkstat = 2 : End
Endif

If [M:RGL1]NBCTR > 0
    # mess(161,10702,1) : Attention, des données sont présentes, elles seront effacées.
    # mess(172,100,1)   : Voulez-vous-poursuivre le traitement en cours
    Call OUINON(mess(161,10702,1)+"\"+mess(172, 100, 1),
&                [L]OK) From GESECRAN
Endif

If [L]OK = 2
    Raz [M:RGL1] NBCTR
    Raz [L]NBCTR
    ##**82073
    Gosub DATREF
    # Réutilisation de la fonction de chargement utilisée dans les exceptions
    Call CHARGE_CONTRAT([M:RGL1]FCY, [M:RGL1]PRF, [M:RGL1]SRV, [M:RGL1]EMPSTR, [M:RGL1]EMPEND,
&                    [M:RGL1]POP, [M:RGL1]CRI,[L]DATREF(1),[L]DATREF(2),
&                    [L]NBCTR, [M:RGL1]REFNUM, [M:RGL1]CTRNUM, [M:RGL1]CTRDAT, 1)
&                    From SUBECH
    [M:RGL1]NBCTR = [L]NBCTR
    Affzo [M:RGL1]

    mkstat = 4    : # Déclenchement du passage en modif

Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran RGL0) 25/05/2012 18:23:45 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
  Look [RGL]RGL0=VALEUR;[M:RGL0]COD
  If fstat>1
    Effzo [M:RGL1] : Effzo [M:RGL2]
  Endif
Endif

GCURLEG=VALEUR
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran RGL1) 15/04/2013 13:10:31 (DBA)
######################################################################################
##**82073
Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

Gosub DATREF

Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT<=[L]DATREF(2)
&                   & (XITDAT=[0/0/0] | XITDAT>=[L]DATREF(1))
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat>2
 Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1)
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
Endif
If !fstat
 VALEUR=[F:HRCTR]CTRDAT
Endif
End

##**82073
Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Look [F:HRCTR]CTR0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1);VALEUR
If fstat
 GMESSAGE=mess(26,10701,1) #: Contrat inexistant
 mkstat=2 : End
Endif
End
