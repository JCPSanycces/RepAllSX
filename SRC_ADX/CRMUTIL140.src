##########################################################################################################
# Convertit un nombre de secondes d'une journée en heures minutes
###########################################################
Subprog SECTOHOU(INBSEC, SZHOU)
Value Integer INBSEC
Variable Char SZHOU

Local Integer IHOU
Local Integer IMNT
Local Integer IMODMNT
Local Char SZNBHOU(100)
Local Char SZNBMIN(100)

  IHOU = 0
  IMNT = 0
  IMODMNT = 0
  SZNBHOU = ""
  SZNBMIN = ""
  #Calcul du nombre d'heures
  IHOU = int(INBSEC / 3600)
  IMODMNT = mod(INBSEC, 3600)
  #Calcul du nombre de minutes
  IMNT = int(IMODMNT / 60)
  If IHOU < 10 Then
    SZNBHOU = "0" + num$(IHOU)
    If IHOU = 0 Then
      SZNBHOU = "00"
    Endif
  Else
    SZNBHOU = num$(IHOU)
  Endif
  If IMNT < 10 Then
    SZNBMIN = "0" + num$(IMNT)
    If IMNT = 0 Then
      SZNBMIN = "00"
    Endif
  Else
    SZNBMIN = num$(IMNT)
  Endif
  SZHOU = SZNBHOU + SZNBMIN
End

##########################################################################################################
# Convertit une heure en nombre de secondes
###########################################################
Subprog HOUTOSEC(IHOU, IMNT, INBSEC)
Value Integer IHOU
Value Integer IMNT
Variable Integer INBSEC

  INBSEC = 0
  #Heures en nombre de secondes
  If IHOU > 0 Then
    INBSEC = IHOU * 60 * 60
  Endif
  #Minutes en nombre de secondes
  If IMNT > 0 Then
    INBSEC += IMNT * 60
  Endif
End

##########################################################################################################
# Récupère la désignation d'un enregistrement dans une table (action : RECUPDES)
###########################################################
Subprog LIEN_OBJ_DYNAMIC (SZVCHVCR, SZOBJ, SZCHAVCR, SZLINVCR, SZVLIVCR, SZCHADES)
Value Char SZVCHVCR     # Valeur champ VCR
Value Char SZOBJ        # Code objet
Value Char SZCHAVCR     # Nom champ VCR
Value Char SZLINVCR     # Nom champ ligne VCR
Value Char SZVLIVCR     # Valeur champ ligne VCR
Value Char SZCHADES     # Champs dans lequel on doit charger la désignation

Local Char SZTABLE(GLONATB)
Local Char SZABRTB(GLONABR+1)
Local Char SZCHINT(GLONAVA)
Local Char SZWHERE(250)(5)
Local Char SZAND(6)
Local Integer IINDICE
Local Char SZDCO(GLONDCO)

  # FGR 12/02/2009 : # FGR 12/02/2009 : X3SUIVI52443
  If SZCHADES <> "" Then
    Assign SZCHADES With ""
  Endif
  If SZOBJ = "" or SZCHAVCR = "" or SZVCHVCR = "" or SZCHADES = "" Then
    # Si on a ni objet, rubrique ou valeur on repart
    End
  Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Read [AOB]ABREV=SZOBJ
  If fstat Then
    End
  Endif
  SZTABLE = [F:AOB]NOMFIC
  Read [ATB]CODFIC=SZTABLE
  If fstat Then
    End
  Endif
  SZABRTB = [F:ATB]ABRFIC
  If [F:ATB]INTIT <> "" Then
    SZCHINT = [F:ATB]INTIT
  Elsif [F:ATB]INTITC <> "" Then
    SZCHINT = [F:ATB]INTITC
  Else
    # Si on n'a pas l'info on n'affiche rien
    SZCHINT = ""
    End
  Endif
  Local File =SZTABLE [XXX0]
  SZAND = ""
  IINDICE = 0
  SZWHERE(IINDICE) = SZAND - SZCHAVCR - "='" + SZVCHVCR + "'"
  SZAND = "and"
  If SZVLIVCR <> "" Then
    IINDICE += 1
    SZWHERE(IINDICE) = SZAND - ZSLINVCR - "=" - SZVLIVCR
  Endif
  Filter [XXX0] Where evalue(SZWHERE)
  For [XXX0]
    SZDCO = evalue("[F:XXX0]" + SZCHINT)
    Break
  Next
  Filter [XXX0]
  If SZDCO <> "" Then
    Assign SZCHADES With SZDCO
  Endif
  Close Local File [XXX0]
End

