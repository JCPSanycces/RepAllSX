  Call MGGINXML(SZQURNUM, SZTGP, 1, "STD", "", SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBMGGXML
  If IERRINF = 0
    Callui RETOUR = "" With "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) + "Report",
&                           "UILocalFile="+ chr$(1) + SZFILENAME
