##########################################################################################################
$EMAIL_CHECK_BPA
Local Integer NI
Local Integer IFOUND

  # FGR 03/06/2015 : X3SUIVI108602
  IFOUND = -1
  For NI = 0 To dim([F:BPA]WEB)-1
    If [F:BPA]WEB(NI) <> "" Then
      IFOUND = NI
      Break
    Endif
  Next NI
  If IFOUND = -1 Then
    IARENDRE = [V]CST_ANO
  Endif
Return

##########################################################################################################
# Permet d'obtenir la catégorie client d'une famille statistique client.     #
##############################################################################
Subprog GETCATCLI(SZLIB, ICATCLI)
Value Char SZLIB
Variable Integer ICATCLI

Local Integer INUMTAB

  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  INUMTAB = 29 + GCATCLI
  ICATCLI = 0
  Read [ADI]CODE=INUMTAB;SZLIB
  If !fstat Then
    ICATCLI = [F:ADI]N1
  Endif
End

##########################################################################################################
# Convertit un nombre de secondes en jours, heures, minutes, secondes        #
##############################################################################
Subprog SECTODAY(INBSEC, INBHOUPERDAY, IDAY, IHOU, IMNT, ISOD)
Value Integer INBSEC
Value Decimal INBHOUPERDAY
Variable Integer IDAY
Variable Integer IHOU
Variable Integer IMNT
Variable Integer ISOD

Local Integer IMODDAY
Local Integer IMODMNT
Local Integer INBSECINDAY

  IMODDAY = 0
  IMODMNT = 0
  If INBHOUPERDAY = 0
    INBHOUPERDAY = 24
  Endif
  INBSECINDAY = INBHOUPERDAY * 60 * 60
  #Calcul du nombre de jours
  IDAY = int(INBSEC/INBSECINDAY)
  IMODDAY = mod(INBSEC, INBSECINDAY)
  #Calcul du nombre d'heures
  IHOU = int(IMODDAY / 3600)
  IMODMNT = mod(IMODDAY, 3600)
  #Calcul du nombre de minutes
  IMNT = int(IMODMNT / 60)
  #Calcul du nombre de secondes
  ISOD = mod(IMODMNT, 60)
End

##########################################################################################################
# Convertit un nombre de secondes en heures, minutes, secondes               #
##############################################################################
Subprog SECTOHOUMNT(INBSEC, IHOU, IMNT, ISOD)
Value Integer INBSEC
Variable Integer IHOU
Variable Integer IMNT
Variable Integer ISOD

Local Integer IMODMNT

  IMODMNT = 0
  #Calcul du nombre d'heures
  IHOU = int(INBSEC / 3600)
  IMODMNT = mod(INBSEC, 3600)
  #Calcul du nombre de minutes
  IMNT = int(IMODMNT / 60)
  #Calcul du nombre de secondes
  ISOD = mod(IMODMNT, 60)
End

##########################################################################################################
# Convertit un nombre de jours, heures, minutes, secondes en nombre de secondes       #
#######################################################################################
Subprog DAYTOSEC(IDAY, IHOU, IMNT, ISOD, INBHOUPERDAY, INBSEC)
Value Integer IDAY
Value Integer IHOU
Value Integer IMNT
Value Integer ISOD
Value Decimal INBHOUPERDAY
Variable Integer INBSEC

  INBSEC = 0
  #Jours en nombre de secondes
  If IDAY > 0 Then
    INBSEC = IDAY * INBHOUPERDAY * 60 * 60
  Endif
  #Heures en nombre de secondes
  If IHOU > 0 Then
    INBSEC += IHOU * 60 * 60
  Endif
  #Minutes en nombre de secondes
  If IMNT > 0 Then
    INBSEC += IMNT * 60
  Endif
  #Secondes
  INBSEC += ISOD
End

##########################################################################################################
# Test la pile des contexte pour savoir si le contexte indiqué est ouvert             #
#######################################################################################
Subprog ISFUNOPEN(SZCONTEXT, ISOPEN)
Value Char SZCONTEXT
Variable Integer ISOPEN

Local Integer ITER

  ISOPEN = 0
  For ITER = 1 To GPILNAV
    If GNAVIG(ITER) = SZCONTEXT Then
      ISOPEN = 1
      Break
    Endif
  Next
End

##########################################################################################################
# Programme de renvoi du code par défaut d'une table diverse.                #
##############################################################################
Subprog DEFVALADI(CODETAB, PIODEF)
Value Integer CODETAB
Variable Char PIODEF

  PIODEF = ""
  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB Order By [F:ADI]CODE Asc
  For [ADI]
    If [F:ADI]DEFVAL = 2 Then
      PIODEF = [F:ADI]CODE
      Break
    Endif
  Next
  Filter [ADI]
End

##########################################################################################################
# Calcul une nouvelle date et heure à partir d'une ancienne date et d'un nb d'heures
##############################################################################
Subprog DAYFROMHOUR(DOLDDAY, SZOLDHOU, INBHOU, DNEWDAY, SZNEWHOU)
Value Date DOLDDAY
Value Char SZOLDHOU
Value Integer INBHOU
Variable Date DNEWDAY
Variable Char SZNEWHOU

Local Integer ITESTHOU
Local Integer IHALFDAY
Local Integer IWHOLEDAY
Local Integer IMIDNIGHT
Local Integer ICTLDAY
Local Integer IHALFCTL
Local Integer IONEMOREDAY

  #On extrait les heures et les minutes de l'ancienne heure
  ITESTHOU = val(left$(SZOLDHOU, 2))
  #Etape 1
  #On calcul le nombre de secondes qui séparent l'heure courante de minuit.
  Call DAYTOSEC(0, ITESTHOU, 0, 0, 24, IHALFDAY) From CRMUTIL140
  Call DAYTOSEC(0, 23, 59, 59, 24, IWHOLEDAY) From CRMUTIL140
  IWHOLEDAY += 1
  IMIDNIGHT = IWHOLEDAY - IHALFDAY
  ICTLDAY = mod(INBHOU, 24)
  Call DAYTOSEC(0, ICTLDAY, 0, 0, 24, IHALFCTL) From CRMUTIL140
  If IHALFCTL > IMIDNIGHT Then
    IONEMOREDAY = 1
  Else
    IONEMOREDAY = 0
  Endif
  #Calcul du nouveau jour
  If IONEMOREDAY Then
    DNEWDAY = DOLDDAY + (INBHOU / 24) + 1
  Else
    DNEWDAY = DOLDDAY + (INBHOU / 24)
  Endif
  #Calcul de la nouvelle heure
  Call GETNEWHOU(SZOLDHOU, INBHOU, SZNEWHOU)
End

##########################################################################################################
# Programme de calcul d'une nouvelle heure (Dépend de DAYFROMHOUR)
#########################################################################################
Subprog GETNEWHOU(OLDHOU, INB, NEWHOU)
Value Char OLDHOU
Value Integer INB
Variable Char NEWHOU

Local Char SZNEWHOU(100)
Local Char SZNEWMNT(100)
Local Integer IOLDHOU
Local Integer IOLDMNT
Local Integer INEWHOU
Local Integer INEWMNT
Local Integer INBOLDSEC
Local Integer INBLTISEC
Local Integer INBALLSEC
Local Integer IBIDDAY
Local Integer IBIDSEC

  #On extrait les heures et les minutes
  IOLDHOU = val(left$(OLDHOU, 2))
  IOLDMNT = val(mid$(OLDHOU, 3, 2))
  #On convertit l'ancienne heure en nombre de secondes
  INBOLDSEC = 0
  Call DAYTOSEC(0, IOLDHOU, IOLDMNT, 0, 24, INBOLDSEC) From CRMUTIL140
  #On convertit le délai de résolution en nombre de secondes
  INBLTISEC = 0
  Call DAYTOSEC(0, INB, 0, 0, 24, INBLTISEC ) From CRMUTIL140
  #On ajoute le délai de résolution à l'ancienne heure
  INBALLSEC = INBOLDSEC + INBLTISEC
  #Et on reconverti le nombre de secondes dans la nouvelle heure
  Call SECTODAY(INBALLSEC, 24, IBIDDAY, INEWHOU, INEWMNT, IBIDSEC) From CRMUTIL140
  #On rend cela syntaxiquement correct
  If INEWHOU < 10 Then
    SZNEWHOU = "0" + num$(INEWHOU)
  Else
    SZNEWHOU = num$(INEWHOU)
  Endif
  If INEWMNT < 10 Then
    SZNEWMNT = "0" + num$(INEWMNT)
  Else
    SZNEWMNT = num$(INEWMNT)
  Endif
  NEWHOU = SZNEWHOU + SZNEWMNT
End

##########################################################################################################
# Vérifie si une heure est supérieure à l'autre.
#########################################################################################
Subprog ISHOURUPPER(SZSTRHOU, SZENDHOU, IUPPER)
Value Char SZSTRHOU
Value Char SZENDHOU
Variable Integer IUPPER

Local Integer ISTRHOU
Local Integer ISTRMNT
Local Integer IENDHOU
Local Integer IENDMNT
Local Integer INBSTRSEC
Local Integer INBENDSEC

  #On extrait les heures et les minutes
  ISTRHOU = val(left$(SZSTRHOU, 2))
  ISTRMNT = val(mid$(SZSTRHOU, 3, 2))
  IENDHOU = val(left$(SZENDHOU, 2))
  IENDMNT = val(mid$(SZENDHOU, 3, 2))
  Call DAYTOSEC(0, ISTRHOU, ISTRMNT, 0, 0, INBSTRSEC) From CRMUTIL140
  Call DAYTOSEC(0, IENDHOU, IENDMNT, 0, 0, INBENDSEC) From CRMUTIL140
  If INBENDSEC = INBSTRSEC Then
    IUPPER = 2
  Else
    If INBENDSEC > INBSTRSEC Then
      IUPPER = 1
    Else
      IUPPER = 0
    Endif
  Endif
End

##########################################################################################################
#  GETDEFCNT  : Renvoie le contact par défaut d'un tiers
##########################################################################################################
##########################################################################################################
Subprog GETDEFCNT(SZBPRNUM, SARENDRE)
Value Char SZBPRNUM
Variable Char SARENDRE

Local Char SZDEFCNT(GLONAIN)
Local Char SZBPRTYP(GLONDCO)
Local Char SZBPXAOB(GLONAOB)

  Raz SARENDRE
  # ------------------------------------------
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------------
  Local File BPARTNER [BPR]
  Local File CONTACT [CNT]
  # ------------------------------------------
  Read [BPR]BPR0=SZBPRNUM
  If fstat Then
    End
  Endif
  # ------------------------------------------
  Call GETBPRTYP(SZBPRNUM, SZBPRTYP, SZBPXAOB) From CRM_UTIL
  # ------------------------------------------
  Case SZBPXAOB
    When "BPC", "BPP"
      Local File BPCUSTOMER [BPC]
      Read [BPC]BPC0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPC]CNTNAM
      Endif
    When "BPS"
      Local File BPSUPPLIER [BPS]
      Read [BPS]BPS0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPS]CNTNAM
      Endif
    When "BPT"
      Local File BPCARRIER [BPT]
      Read [BPT]BPT0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPT]CNTNAM
      Endif
    When "BPR", "REP"
      SZDEFCNT = [F:BPR]CNTNAM
    When Default
      Raz SARENDRE
  Endcase
  # ------------------------------------------
  If SZDEFCNT = "" Then
    # Si on ne l'a pas trouvé sur le tiers, on prend le premier des contacts
    Filter [CNT] Where [F:CNT]BPATYP = 1 and [F:CNT]BPANUM = SZBPRNUM Order By [F:CNT]CCNCRM Asc
    For [CNT]
      SARENDRE = [F:CNT]CCNCRM
      Break
    Next
    Filter [CNT]
  Else
    Read [CNT]CNT0=1;SZBPRNUM;SZDEFCNT
    If !fstat Then
      SARENDRE = SZDEFCNT
    Endif
  Endif
End

##########################################################################################################
# Programme d'extraction de mots clés pertinents définis dans une table diverse
################################################################################
Subprog EXTWORD(IADINUM, SZLOOKFOR, SZFKEY)
Value Integer IADINUM
Variable Char SZLOOKFOR
Variable Char SZFKEY()(0..)

Local Char SZADISHO(100)
Local Char SZUPADISHO(100)
Local Char SZADILIB(100)
Local Char SZUPADILIB(100)
Local Integer I
Local Integer I2
Local Integer ISPACE(250)
Local Integer ITSDUP
Local Char SZSIGNS(100)
Local Char SZREMSIGN(100)
Local Integer ISIGN
Local Integer ITERSIGN
Local Integer ITERKW
Local Integer IFOUNDKW

  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  #Initialise les variables
  ITERKW = 0
  IFOUNDKW = 0
  I = 0
  I2 = 0
  SZADILIB = ""
  SZUPADILIB = ""
  Raz ISPACE
  Raz SZFKEY
  SZREMSIGN = ""
  SZSIGNS = ",?;.:/!'(){}"
  ISIGN = len(SZSIGNS)
  #On enlève tous ce qui est ponctuation
  For ITERSIGN = 1 To ISIGN
    SZREMSIGN = mid$(SZSIGNS, ITERSIGN, 1)
    Call REMOVECHAR(SZREMSIGN, SZLOOKFOR)
  Next
  # Découpe la chaine en mots indépendants
  If SZLOOKFOR = "" Then
    End
  Endif
  SZLOOKFOR = SZLOOKFOR + ' '
  ISPACE(0) = instr(1, SZLOOKFOR, ' ')
  If ISPACE(0) > 0 Then
    I = 1
    While 1
      ISPACE(I) = instr(ISPACE(I-1) + 1, SZLOOKFOR, ' ')
      If ISPACE(I) = 0 Then
        Break
      Endif
      I += 1
    Wend
  Else
    End
  Endif

Local Char SZWORD(250)(I)

  Raz SZWORD
  SZWORD(0) = toupper(left$(SZLOOKFOR, ISPACE(0)-1))
  I = 1
  While 1
    If ISPACE(I) <> 0 Then
      SZWORD(I) = toupper(mid$(SZLOOKFOR, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1))
    Else
      Break
    Endif
    I += 1
  Wend
  #Vérifie si le mot est défini dans la table diverse
  Filter [ADI] Where [F:ADI]NUMTAB = IADINUM
  For [ADI]
    SZADILIB = ""
    Call GET_LIB(IADINUM, [F:ADI]CODE, SZADILIB) From CRM_UTIL
    Call GET_LIBSHO(IADINUM, [F:ADI]CODE, SZADISHO) From CRM_UTIL
    If SZADILIB <> "" Then
      SZUPADILIB = toupper(SZADILIB)
      If SZADISHO = "" Then
        SZUPADISHO = ""
      Else
        SZUPADISHO = toupper(SZADISHO)
      Endif
      For I = 0 To dim(SZWORD)-1
        If SZWORD(I) <> "" Then
          If SZUPADILIB = SZWORD(I) Then
            Gosub ADDKWORD
          Else
            If instr(1, SZWORD(I), SZUPADILIB) Then
              Gosub ADDKWORD
            Else
              If SZUPADISHO <> "" Then
                If instr(1, SZWORD(I), SZUPADISHO) Then
                  Gosub ADDKWORD
                Endif
              Endif
            Endif
          Endif
        Endif
        If I2 >= dim(SZFKEY) Then
          Break
        Endif
      Next
    Endif
    If I2 >= dim(SZFKEY) Then
      Break
    Endif
  Next
  Filter [ADI]
End

##########################################################################################################
$ADDKWORD
  #Vérifie d'abord si le mot-clé n'est pas déjà trouvé
  IFOUNDKW = 0
  For ITERKW = 0 To dim(SZFKEY)-1
    If SZFKEY(ITERKW) <> "" Then
      If SZFKEY(ITERKW) = SZUPADILIB Then
        IFOUNDKW = 1
        Break
      Endif
    Endif
  Next
  If !IFOUNDKW Then
    SZFKEY(I2) = SZUPADILIB
    I2 += 1
  Endif
Return

##########################################################################################################
# Programme d'extraction d'une chaine dans une chaine.
################################################################################
Subprog REMOVECHAR(SZREMOVE, SZCHAR)
Value Char SZREMOVE
Variable Char SZCHAR

  If SZREMOVE = "" Then
    End
  Endif

Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  While instr(1, SZCHAR, SZREMOVE)
    ISTR = instr(1, SZCHAR, SZREMOVE)
    SZ1 = left$(SZCHAR, ISTR-len(SZREMOVE))
    SZ2 = right$(SZCHAR, ISTR+1)
    SZ3 = SZ1 - SZ2
    SZCHAR = SZ3
    ILOOPSECURE += 1
    If ILOOPSECURE > 200000 Then
      Break
    Endif
  Wend
End

##########################################################################################################
# Reconstruit le com complet d'un interlocuteur
###########################################################################
Subprog BUILDFULNAM(SZCLASSF, SZFULNAM)
Value Char SZCLASSF
Variable Char SZFULNAM

Local Integer ICIV
Local Char SZCIV(50)
Local Char SZFNA(50)
Local Char SZLNA(50)

  If SZCLASSF = "COR" Then
    Assign ("ICIV") With evalue("[F:" + SZCLASSF + "]" + "TTL")
    Assign ("SZFNA") With evalue("[F:" + SZCLASSF + "]" + "FNA")
    Assign ("SZLNA") With evalue("[F:" + SZCLASSF + "]" + "LNA")
  Else
    Assign ("ICIV") With evalue("[F:" + SZCLASSF + "]" + "CNTTTL")
    Assign ("SZFNA") With evalue("[F:" + SZCLASSF + "]" + "CNTFNA")
    Assign ("SZLNA") With evalue("[F:" + SZCLASSF + "]" + "CNTLNA")
  Endif
  SZCIV = mess(ICIV,941,1)
  Case GFMTFULNAM
    When 1
      SZFULNAM = SZCIV - SZFNA - SZLNA
    When 2
      SZFULNAM = SZCIV - SZLNA - SZFNA
    When 3
      SZFULNAM = SZFNA - SZLNA - SZCIV
    When 4
      SZFULNAM = SZFNA - SZCIV - SZLNA
    When 5
      SZFULNAM = SZLNA - SZFNA - SZCIV
    When 6
      SZFULNAM = SZLNA - SZCIV - SZFNA
    When Default
      SZFULNAM = SZCIV - SZFNA - SZLNA
  Endcase
End

##########################################################################################################
# Recherche une chaine de caractère dans un CLOB
###########################################################################
Subprog FINDINCLOB(SZBUFFER, SZTYPE, SZCHAR, IFOUND)
Variable Char SZBUFFER()(0..)
Value Char SZTYPE
Value Char SZCHAR
Variable Integer IFOUND

  IFOUND = 0
  If SZTYPE = "" Then
    End
  Endif
  If SZCHAR = "" Then
    End
  Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif

Local Integer ILNGCLOB
Local Integer INBBYTES
Local Integer IBUFFSIZE
Local Integer ILENCHAR

  Read [ATY]CODTYP=SZTYPE
  If fstat Then
    ILNGCLOB = 6
  Else
    ILNGCLOB = [F:ATY]LNGTYP
  Endif
  If ILNGCLOB = 0 Then
    ILNGCLOB = 6
  Endif
  INBBYTES = 1024 * ( 2^ILNGCLOB)
  IBUFFSIZE = INBBYTES / 200
  IBUFFSIZE += 5

Local Char SZBUFFER2(250)(IBUFFSIZE)
Local Char SZBUFFER3(250)(IBUFFSIZE)
Local Char SZBUFFER4(250)(IBUFFSIZE)
Local Char SZBUFFER5(250)(IBUFFSIZE)
Local Char SZBUFFER6(250)
Local Char SZBUFFER7(250)
Local Char SZBUFFER8(250)
Local Char SZSEA(250)
Local Integer ITER
Local Integer ITERLEN
Local Integer ILENBUFFER
Local Integer IREMOVECHAR
Local Integer ICHKFLG

  ITERLEN = 0
  ILENBUFFER = 0
  IREMOVECHAR = 0
  ICHKFLG = 0
  SZSEA = toupper(ctrans(SZCHAR))
  #On transfère le clob dans le buffer
  Raz SZBUFFER2
  Raz SZBUFFER3
  Raz SZBUFFER4
  Raz SZBUFFER5
  Raz SZBUFFER6
  Raz SZBUFFER7
  Raz SZBUFFER8
  #On évite les mots coupés
  For ITER = 0 To dim(SZBUFFER)-1
    If SZBUFFER(ITER) <> "" Then
      Raz SZBUFFER6
      Raz SZBUFFER7
      Raz SZBUFFER8
      ICHKFLG = 0
      #On vérifie si un mot est coupé
      ILENBUFFER = len(SZBUFFER(ITER))
      ITERLEN = len(SZBUFFER(ITER))
      If !instr(1, mid$(SZBUFFER(ITER), ITERLEN, 1), ' ') Then
        If !instr(1, mid$(SZBUFFER(ITER+1), 1, 1), ' ') Then
          ICHKFLG = 1
          #On prend le bout droit de la ligne courante
          While 1
            If ITERLEN = 0 Then
              Break
            Endif
            If instr(1, mid$(SZBUFFER(ITER), ITERLEN, 1), ' ') Then
              IREMOVECHAR = ILENBUFFER - ITERLEN
              SZBUFFER6 = mid$(SZBUFFER(ITER), ITERLEN+1, IREMOVECHAR)
              Break
            Endif
            ITERLEN -= 1
          Wend
          IREMOVECHAR += 1
          ILENCHAR = len(SZBUFFER(ITER)) - IREMOVECHAR
          If ILENCHAR < 0 Then
            ILENCHAR = 0
          Endif
          SZBUFFER2(ITER) = left$(SZBUFFER(ITER), ILENCHAR)
          #On prend le bout gauche de la ligne suivante
          ILENBUFFER = len(SZBUFFER(ITER+1))
          ITERLEN = 1
          While 1
            If ITERLEN = 250 Then
              Break
            Endif
            If instr(1, mid$(SZBUFFER(ITER+1), ITERLEN, 1), ' ') Then
              SZBUFFER7 = mid$(SZBUFFER(ITER+1), 1, ITERLEN-1)
              SZBUFFER8 = right$(SZBUFFER(ITER+1), ITERLEN+1)
              SZBUFFER(ITER+1) = SZBUFFER8
              Break
            Endif
            ITERLEN += 1
          Wend
          SZBUFFER3(ITER) = SZBUFFER6 + SZBUFFER7
        Endif
      Endif
      If ICHKFLG = 0 Then
        SZBUFFER2(ITER) = SZBUFFER(ITER)
      Endif
    Endif
  Next
  #On transforme en majuscule
  For ITER = 0 To dim(SZBUFFER2)-1
    SZBUFFER4(ITER) = toupper(ctrans(SZBUFFER2(ITER)))
    SZBUFFER5(ITER) = toupper(ctrans(SZBUFFER3(ITER)))
  Next
  #On recherche le mot dans le texte
  For ITER = 0 To dim(SZBUFFER4)-1
    If SZBUFFER4(ITER) <> "" Then
      If instr(1, SZBUFFER4(ITER), SZSEA)
        IFOUND = 1
        Break
      Endif
    Endif
  Next
  If IFOUND = 0 Then
    For ITER = 0 To dim(SZBUFFER5)-1
      If SZBUFFER5(ITER) <> "" Then
        If instr(1, SZBUFFER5(ITER), SZSEA)
          IFOUND = 1
          Break
        Endif
      Endif
    Next
  Endif
End

##########################################################################################################
# Eclate un buffer clob en deux tableaux ne comportant aucun mot découpé
###########################################################################
Subprog SPLITBUFFER(SZBUFFER, SZBUFFER2, SZBUFFER3)
Variable Char SZBUFFER()(0..)
Variable Char SZBUFFER2()(0..)
Variable Char SZBUFFER3()(0..)

Local Char SZBUFFER6(250)
Local Char SZBUFFER7(250)
Local Char SZBUFFER8(250)
Local Integer ITER
Local Integer ITERLEN
Local Integer ILENBUFFER
Local Integer IREMOVECHAR
Local Integer ICHKFLG
Local Integer ILENCHAR

  ITERLEN = 0
  ILENBUFFER = 0
  IREMOVECHAR = 0
  ICHKFLG = 0
  Raz SZBUFFER2
  Raz SZBUFFER3
  Raz SZBUFFER6
  Raz SZBUFFER7
  Raz SZBUFFER8
  #On évite les mots coupés
  For ITER = 0 To dim(SZBUFFER)-1
    If SZBUFFER(ITER) <> "" Then
      Raz SZBUFFER6
      Raz SZBUFFER7
      Raz SZBUFFER8
      ICHKFLG = 0
      #On vérifie si un mot est coupé
      ILENBUFFER = len(SZBUFFER(ITER))
      ITERLEN = len(SZBUFFER(ITER))
      If !instr(1, mid$(SZBUFFER(ITER), ITERLEN, 1), ' ') Then
        If !instr(1, mid$(SZBUFFER(ITER+1), 1, 1), ' ') Then
          ICHKFLG = 1
          #On prend le bout droit de la ligne courante
          While 1
            If ITERLEN = 0 Then
              Break
            Endif
            If instr(1, mid$(SZBUFFER(ITER), ITERLEN, 1), ' ') Then
              IREMOVECHAR = ILENBUFFER - ITERLEN
              SZBUFFER6 = mid$(SZBUFFER(ITER), ITERLEN+1, IREMOVECHAR)
              Break
            Endif
            ITERLEN -= 1
          Wend
          IREMOVECHAR += 1
          ILENCHAR = len(SZBUFFER(ITER)) - IREMOVECHAR
          If ILENCHAR < 0 Then
            ILENCHAR = 0
          Endif
          SZBUFFER2(ITER) = left$(SZBUFFER(ITER), ILENCHAR)
          #On prend le bout gauche de la ligne suivante
          ILENBUFFER = len(SZBUFFER(ITER+1))
          ITERLEN = 1
          While 1
            If ITERLEN = 250 Then
              Break
            Endif
            If instr(1, mid$(SZBUFFER(ITER+1), ITERLEN, 1), ' ') Then
              SZBUFFER7 = mid$(SZBUFFER(ITER+1), 1, ITERLEN-1)
              SZBUFFER8 = right$(SZBUFFER(ITER+1), ITERLEN+1)
              SZBUFFER(ITER+1) = SZBUFFER8
              Break
            Endif
            ITERLEN += 1
          Wend
          SZBUFFER3(ITER) = SZBUFFER6 + SZBUFFER7
        Endif
      Endif
      If ICHKFLG = 0 Then
        SZBUFFER2(ITER) = SZBUFFER(ITER)
      Endif
    Endif
  Next
End

##########################################################################################################
# Contrôle le lock superviseur posé sur un objet
###########################################################
Subprog ISAOBLOCKED(SZSYM, ILOCKED)
Value Char SZSYM
Variable Integer ILOCKED

  ILOCKED = 0
  If SZSYM = "" Then
    End
  Endif
  If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
  Filter [ALK] Where [F:ALK]LCKSYM = SZSYM
  For [ALK]
    If [F:ALK]LCKPID <> adxuid(2) Then
      ILOCKED = 1
      Break
    Endif
  Next
  Filter [ALK]
End

##########################################################################################################
# Contrôle le lock superviseur posé sur un objet
###########################################################
Subprog ISAOB2LOCKED(SZFIRKEY, SZAOB, ILOCKED)
Value Char SZFIRKEY
Value Char SZAOB
Variable Integer ILOCKED

Local Char SZSYMB(100)

  ILOCKED = 0
  If SZFIRKEY = "" Then
    End
  Endif
  If SZAOB = "" Then
    End
  Endif
  # ---------------------
  SZSYMB = SZAOB + SZFIRKEY
  If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
  Filter [ALK] Where [F:ALK]LCKSYM = SZSYMB
  For [ALK]
    If [F:ALK]LCKPID <> adxuid(2) Then
      ILOCKED = 1
      Break
    Endif
  Next
  Filter [ALK]
End

##########################################################################################################
# Renseigne GMESSAGE avec un numéro de message
###########################################################
Subprog BUILDGMESSAGE(INUM)
Value Integer INUM

  If INUM <= 0 Then
    GMESSAGE = ""
  Elsif INUM > 0 and INUM < 1000 Then
    GMESSAGE = mess(INUM,182,1)
  Elsif INUM > 1000 and INUM < 2000 Then
    GMESSAGE = mess(INUM-1000,177,1)
  Endif
End

##########################################################################################################
# Envoi une page HTML par E-Mail.   (Pré-requis : Office XP (Outlook + Word) installés sur la machine cliente)
# Ne fonctionne pas en Web
##########################################################
Subprog SENDHTMLEMAIL(SZHTMLPAGE, SZTO, SZEMAILSUBJECT, ICHAPTER, IERR)
Variable Char SZHTMLPAGE
Variable Char SZTO
Variable Char SZEMAILSUBJECT
Variable Integer ICHAPTER
Variable Integer IERR

  IERR = 0
  ICHAPTER = 0
  If SZHTMLPAGE = "" Then
    End
  Endif
  If SZTO = "" Then
    End
  Endif
  If SZEMAILSUBJECT = "" Then
    End
  Endif
  If GBROWS Then
    #Ce sous-programme ne fonctionne pas en mode Web.
    IERR = 68
    ICHAPTER = 177
    End
  Endif

Local Char RETOUR(1)
#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)
  SP = '_'
  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"

#Buffers d'écriture
Local Char SZBUFFTOFILL(250)
  Raz SZBUFFTOFILL

#Séparateurs
Local Char SZADXIFS(type(adxifs)-10)
Local Char SZADXIRS(type(adxirs)-10)
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)

#Fichier HTML
Local Char SZHTMNAME(250)
Local Char SZFULLHTMNAME(250)
Local Char SZWFULLHTMNAME(250)
  SZHTMNAME = SZHTMLPAGE
  SZFULLHTMNAME = ""
  SZWFULLHTMNAME = ""

#Fichier Javascript
Local Char SZJSNAME(250)
Local Char SZFULLJSNAME(250)
Local Char SZWFULLJSNAME(250)
  SZJSNAME = num$(adxtcp) + SP + nomap + SP + GUSER + SP + "SENDHTMLEMAIL"
  SZFULLJSNAME = ""
  SZWFULLJSNAME = ""

#Fichier csv
Local Char SZCSVNAME(250)
Local Char SZFULLCSVNAME(250)
Local Char SZWFULLCSVNAME(250)
Local Char SZPOSTCSVNAME(250)
Local Char SZWPOSTCSVNAME(250)
  SZCSVNAME = num$(adxtcp) + SP + nomap + SP + GUSER + SP + "SENDHTMLEMAIL"

  SZFULLCSVNAME = ""
  SZWFULLCSVNAME = ""
  #Génération du nom du fichier XML
  # FGR 05/12/2007 : X3Suivi44572 D'après ce que je comprends pas besoin de le faire sur le serveur celui-là (VISTA)
  #                  Le nom sera écrit dans le ".js"
  #Call BUILDFICNAME(1, SZHTMNAME, "htm", SZFULLHTMNAME) From CRMXML140
  Call BUILDFICNAME(1, SZHTMNAME, "xml", SZFULLHTMNAME) From CRMXML140
  If SZFULLHTMNAME = "" Then
    #Erreur lors du nommage du fichier htm.
    IERR = 71
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
  Endif

  #Génération du nom du fichier CSV
  # FGR 05/12/2007 : X3Suivi44572 On genere le fichier sur le serveur (VISTA)
  #Call BUILDFICNAME(1, SZCSVNAME, "csv", SZFULLCSVNAME) From CRMXML140
  Call BUILDFICNAME(0, SZCSVNAME, "csv", SZFULLCSVNAME) From CRMXML140
  If SZFULLCSVNAME = "" Then
    #Erreur lors de l'ouverture du fichier csv.
    IERR = 69
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
  Endif
  Call BUILDFICNAME(1, SZCSVNAME, "csv", SZPOSTCSVNAME) From CRMXML140
  #Génération du nom du fichier JS
  # FGR 05/12/2007 : X3Suivi44572 On genere le fichier sur le serveur (VISTA)
  #Call BUILDFICNAME(1, SZJSNAME, "js", SZFULLJSNAME) From CRMXML140
  Call BUILDFICNAME(0, SZJSNAME, "js", SZFULLJSNAME) From CRMXML140
  If SZFULLJSNAME = "" Then
    #Erreur lors de l'ouverture du fichier js.
    IERR = 70
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
  Endif
  #
  #On obtient le nom window du fichier HTM
  Call GETWNDFNAME(SZFULLHTMNAME, SZWFULLHTMNAME)
  #On obtient le nom window du fichier CSV
  Call GETWNDFNAME(SZPOSTCSVNAME, SZWPOSTCSVNAME)
  #
  #Ouverture du fichier CSV
  Openo SZFULLCSVNAME, 0 Using [FCSV]
  #
  #Ecriture du CSV
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = '"AdresseEMail","EMPTY"'
  Wrseq SZBUFFTOFILL Using [FCSV]
  #
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = '"' + SZTO + '","' + SZTO + '"'
  Wrseq SZBUFFTOFILL Using [FCSV]
  #
  #On ferme le fichier CSV
  Openo Using [FCSV]
  # FGR 05/12/2007 : X3Suivi44572 (DEBUT) On transfert le fichier sur le poste (VISTA)
  Callui RETOUR="" With "UIAction="+chr$(1)+"GetFileAlways",
&                       "UIRemoteFile="+ chr$(1) +SZFULLCSVNAME,
&                       "UILocalDir="+ chr$(1) +"Report",
&                       "UILocalFile="+ chr$(1) +SZCSVNAME + ".csv"
  # FGR 05/12/2007 : X3Suivi44572 (FIN) On transfert le fichier sur le poste (VISTA)
  #
  #Ouverture du fichier JS
  Openo SZFULLJSNAME, 0 Using [FJS]
  #
  #Ecriture du JS
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'var oWord;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'var oDoc;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'var oMerge;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'var oMergeDataSource;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oWord = new ActiveXObject("Word.Application");'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oWord.Visible = false;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oDoc = oWord.Documents.Open("' + SZWFULLHTMNAME + '");'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oWord.Options.SendMailAttach = false;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge = oDoc.MailMerge;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.MainDocumentType = 4;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.OpenDataSource("' + SZWPOSTCSVNAME+ '");'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMergeDataSource = oMerge.DataSource;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMergeDataSource.MappedDataFields(20).DataFieldIndex = 1;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.MailSubject = "' + SZEMAILSUBJECT + '";'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.MailAddressFieldName = "AdresseEMail";'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.Destination = 2;'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oMerge.Execute();'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oDoc.Close();'
  Wrseq SZBUFFTOFILL Using [FJS]

  Raz SZBUFFTOFILL
  SZBUFFTOFILL = 'oWord.Quit();'
  Wrseq SZBUFFTOFILL Using [FJS]

  #On ferme le fichier CSV
  Openo Using [FJS]
  # FGR 05/12/2007 : X3Suivi44572 (DEBUT) On transfert le fichier sur le poste (VISTA)
  Callui RETOUR="" With "UIAction=" + chr$(1) + "GetFileAlways",
&                       "UIRemoteFile=" + chr$(1) + SZFULLJSNAME,
&                       "UILocalDir=" + chr$(1) + "Report",
&                       "UILocalFile=" + chr$(1) + SZJSNAME + ".js"
  # FGR 05/12/2007 : X3Suivi44572 (FIN) On transfert le fichier sur le poste (VISTA)
  #
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #
  Callui RETOUR = "" With "UIAction=" + chr$(1) + "OpenFile",
&                         "UILocalDir=" + chr$(1) + "Report",
&                         "UILocalFile=" + chr$(1) + SZJSNAME + ".js"
End

##########################################################################################################
# Génération d'un nom windows à partir d'un nom X3
##########################################################
Subprog GETWNDFNAME(SZFILE, SZWNDFILE)
Variable Char SZFILE
Variable Char SZWNDFILE

  SZWNDFILE = ""
  If SZFILE = "" Then
    End
  Endif

Local Char SZBUFFFILE(250)
Local Char SZBUFFWFILE(250)
Local Char SZBUFF(250)
Local Integer IPRESLASH
Local Integer IREMAINSLASH
Local Integer ICTLSLASH

  IPRESLASH = 1
  IREMAINSLASH = 0
  ICTLSLASH = 0
  SZBUFFFILE = right$(SZFILE, 3)
  While 1
    IREMAINSLASH = instr(IPRESLASH, SZBUFFFILE, '\')
    If IREMAINSLASH <= 0 Then
      SZBUFF = right$(SZBUFFFILE, IPRESLASH)
      SZBUFFWFILE += SZBUFF
      Break
    Endif
    ICTLSLASH = (IREMAINSLASH - IPRESLASH) + 1
    SZBUFF = mid$(SZBUFFFILE, IPRESLASH, ICTLSLASH) + '\'
    SZBUFFWFILE += SZBUFF
    IPRESLASH = IREMAINSLASH + 1
  Wend
  SZWNDFILE = SZBUFFWFILE
End

##########################################################################################################
# Génération d'un ciblage avancé
#########################################################
Subprog RUNMGG(SZQURNUM)
Value Char SZQURNUM

  If SZQURNUM = "" Then
    End
  Endif

Local Integer IERRINF
Local Integer INBRECORD

  IERRINF = 0
  INBRECORD = 0
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  Gosub OUVRE From TRTMGG
  Gosub OUVTABGLOB From TRTMGC1
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Le ciblage marketing indiqué n'a pas pu être lu.
    GMESSAGE = mess(741,182,1)
    GERR = 1
    End
  Else
    If [F:MQR]TGPNUM = "" Then
      #Aucun support de présentation n'a pu être obtenu.
      GMESSAGE = mess(742,182,1)
      GERR = 1
      End
    Else
      If [F:MQR]TGR = "" Then
        #Cible non précisée sur le ciblage.
        GMESSAGE = mess(743,182,1)
        GERR = 1
        End
      Else
        SZMGC1PARAM2 = [F:MQR]TGR
        SZMGC1PARAM4 = [F:MQR]TGPNUM
      Endif
    Endif
  Endif
  Gosub SETMGCCOL From TRTMGC1
  Call DOMGGBATCH(SZQURNUM, INBRECORD, IERRINF) From TRTMGC1
  If IERRINF Then
    #L'exécution du ciblage a échoué.
    GMESSAGE = mess(738,182,1)
    GERR = 1
  Endif
  Gosub KILLGLOB From TRTMGC1
  Gosub KILLGLOB From TRTMGG
End

