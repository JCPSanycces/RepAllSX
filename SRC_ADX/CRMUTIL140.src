##########################################################################################################
# Renvoi le chemin du repertoire repport LOCAL  pour la langue de l'utilisateur
#########################################################
Subprog GETREPREPCLIENT(SZREPREPCLIENT, INORMEX3 )
Variable Char SZREPREPCLIENT
Value Integer INORMEX3 #indique si il faut rajouter #@ (1 oui sinon non)

  Call DEFAULT_FILECLI(SZREPREPCLIENT, "RptDev", "", "") From ORDSYS
  If INORMEX3 = 1 Then
    SZREPREPCLIENT = "#@" + SZREPREPCLIENT
  Endif
