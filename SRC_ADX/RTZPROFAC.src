#<AdxTL>@(#)7.0.0.0 $Revision$
#Local Char TFAC(15)(10)
#Call PROFAC("ZZFOU1","ZZS",TFAC,GBIDI1)
#End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK : PARAM(3)="1"
 When "END"        : PARAM(3)="0"
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return


$OUVRE
Local Char OPT(1)
If PARAM(3)="9" : FIN=1 : Return : Endif
Call PARAM(PARAM(2),"RTZPRW",OPT) From ADOVAL
If OPT = "1"
 FIN = 1 : Return
Endif
Local Integer I, NOL, OK
Local Decimal MT
Local Char TIERS(GLONBPR), SOC(GLONCPY)
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
If clalev([F:RTZ])=0  : Local File RITENZIONE [RTZ]  : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]  : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
TIERS = PARAM(1)
SOC = PARAM(2)
Return

$DEBUT
# Chargement du "masque au mieux"
Raz [M:DIA] : [M:DIA]BPR = TIERS : [M:DIA]CPY = SOC
Call PARAM("","RTZCUR",[M:DIA]RTZCUR) From ADOVAL
For [PIH]PIH1 Where INVTYP=5 & RITINV="" & STA=3 & RITNBR<>0 & BPR=[M]BPR & CPY=[M]CPY
 Gosub PIH_OK
 If OK
  Gosub SET_LIG
  If NOL=dim([M:DIA]NUMPRO) : Break : Endif
 Endif
Next
[M:DIA]NBPRO = NOL
Affzo [M:DIA]
Return

$OK
# Pré-règlement de la facture
Raz [M:BIS1]PROFAC
For NOL=0 To [M:DIA]NBPRO-1
 [M:BIS1]PROFAC(NOL)=[M:DIA]NUMPRO(NOL)
Next NOL
Return

$PIH_OK
OK=1 : MT=0
For I=0 To [F:PIH]RITNBR-1
 Call LECTURE("RTZ",[F:PIH]RITCOD(I),"") From CONTOBJ
 If [F:RTZ]TYP=1
  If [F:PIH]RITAMTDED(I)<>[F:PIH]RITAMT(I) | [F:PIH]RITBAS(I)<>[F:PIH]RITBASDED(I)
   OK=0 : Break
  Else
   OK=2
   MT += [F:PIH]RITAMT(I)
  Endif
 Endif
Next I
If OK=2 & [F:PIH]RITPAY<>""
 Read [PYH]PYH0 = [F:PIH]RITPAY
 If [F:PYH]STAFLG(2)<>2 : OK=0 : Endif
Endif
Return

$SET_LIG
[M:DIA]NUMPRO(NOL) = [F:PIH]NUM
If [F:PIH]RITPAY<>""
 [M:DIA]NUMPAY(NOL) = [F:PIH]RITPAY
 [M:DIA]RITAMT(NOL) = MT
 Call LECTURE("PAY",[F:PIH]RITPAY,"") From CONTOBJ
 If fstat=0
  [M:DIA]CURPAY(NOL) = [F:PYH]CUR
  If [F:PYH]BPR<>"" : [M:DIA]ACCPAY(NOL) = [F:PYH]BPRSAC-[F:PYH]BPR
  Else              : [M:DIA]ACCPAY(NOL) = [F:PYH]ACC
  Endif
  Filter [PYD] Where NUM=[F:PIH]RITPAY & IPTTYP=4 & VCRNUM=[F:PIH]NUM
  Read [PYD]PYD0 First
  Filter [PYD]
  If fstat<=2
   [M:DIA]AMTPAY(NOL) = [F:PYD]AMTLIN2
   [M:DIA]FCYPAY(NOL) = [F:PYD]FCYLIN
  Endif
 Endif
Endif
NOL+=1
Return

###########################################
## Etiquettes associées à l'écran PROFAC ##
###########################################

########################
Subprog C_NUMPRO(VALEUR)
########################
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Local Decimal MT

Call LECTURE("BIS",VALEUR,"") From CONTOBJ
If fstat | [F:PIH]INVTYP<>5
 GMESSAGE = mess(15,131,1) : mkstat=2 : End : # Proforma fournisseur inexistante
Elsif [F:PIH]CPY<>[M]CPY
 GMESSAGE = mess(78,119,1)-[F:PIH]CPY : mkstat=2 : End : # Facture passée sur la société
Elsif [F:PIH]STA<3
 GMESSAGE = mess(36,119,1) : mkstat=2 : End : # Facture non validée
Elsif [F:PIH]RITINV<>""
 GMESSAGE = mess(19,131,1)-[F:PIH]RITINV : mkstat=2 : End : # Pré-règlement de la facture
Elsif [F:PIH]RITNBR=0
 GMESSAGE = mess(18,131,1) : mkstat=2 : End : # Aucune retenue sur cette facture
Endif
I=find(VALEUR,[M:DIA]NUMPRO(0..NOL-1),[M:DIA]NUMPRO(NOL+1..[M:DIA]NBPRO-1))
If I : # Code déjà saisi en ligne
 GMESSAGE = mess(29,100,1)-num$(I+(I>NOL)) : mkstat=2 : End
Endif

Gosub PIH_OK
If OK : Gosub SET_LIG : Endif
End

########################
#Subprog S_NUMPRO(VALEUR)
########################
#Variable Char    VALEUR()
#Filter [PIH] Where INVTYP=5 & RITINV="" & STA=3 & RITNBR<>0 & BPR=[M:DIA]BPR & CPY=[M:DIA]CPY
#Call SELECT("PIH","#",VALEUR,"") From SELOBJ
#Filter [PIH]
#End

$SEL_TABLE
Case COUZON
 When "NUMPRO" :
  OBJET = "PIH"
  CRITERE = "INVTYP=5 & RITINV='' & STA=3 & RITNBR<>0 & BPR='"+[M:DIA]BPR+"' & CPY='"+[M:DIA]CPY+"'"
  OPTIONS = "#"
Endcase
Return

#########################
Subprog LETPROFAC(NUMFAC)
#########################
Value Char NUMFAC()

If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
If clalev([F:PIH2])=0 : Local File PINVOICE   [PIH2] : Endif
If clalev([F:PAN])=0  : Local File PAYACCNUM  [PAN]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif

If [F:PIH]NUM<>[L]NUMFAC
 Read [PIH]PIH0 = [L]NUMFAC
 If fstat : End : Endif
Endif

Local Mask LETTRECH [LTE]
Local Char TYP(GLONGTE), NUM(GLONVCR), TYPFAC(GLONGTE), CURLET(GLONCUR)
Local Integer NOL, I, IDEV
Local Libelle FLDEV
Local Decimal TOTCRE, TOTDEB, IPTDEB, IPTCRE, MTIPT

# TRAITEMENT DE PROFORMA ASSOCIEES A LA FACTURE

FLDEV=2 : [L]CURLET=[F:PIH]CUR : Raz [M:LTE] : [L]TYPFAC=[F:PIH]GTE
For [PIH2] Where RITINV=[L]NUMFAC & RITPAY<>""
 For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PIH2]RITPAY & STA=3 & RVSACCNUM=0 & TYPVCR="A"
  Read [DAE]DAE2(1) = [F:PAN]ACCNUM
  If fstat<=2
   [L]TYP=[F:DAE]TYP
   [L]NUM=[F:DAE]NUM
   For [DUD]DUD0 Where TYP=[L]TYP & NUM=[L]NUM
&                    & CPY=[F:PIH]CPY & FCY=[F:PIH]FCY & SAC=[F:PIH]BPRSAC & BPR=[F:PIH]BPR
    If FLDEV=2 & [F:DUD]CUR<>[L]CURLET : FLDEV=1 : IDEV=NOL : Endif
    GPE=0
    GPOINT = "PRFMTC" : Gosub ENTREE From EXEFNC
    If !GPE
     Gosub SET_DUD
    Endif
   Next : # [DUD]
  Endif : # fstat
 Next : # [PAN]
Next : # [PIH2]
If NOL=0 : End : Endif

If FLDEV=1 & IDEV
 For I=IDEV To NOL-1
  Read [DUD]DUD1 = [M:LTE]ACCNUM(I);[M:LTE]DUDLIG(I)
  If !fstat
   [M:LTE]AMT(I) = [F:DUD]AMTLOC
   [M:LTE]IPT(I) = [F:DUD]PAYLOC
   [M:LTE]TMP(I) = [F:DUD]TMPLOC
  Endif
 Next I
Endif

# ECHEANCES DE LA FACTURE

For [DUD]DUD0 Where TYP=[L]TYPFAC & NUM=[L]NUMFAC
 Gosub SET_DUD
Next : # [DUD]
[M:LTE]NBLIG = NOL

For I=0 To [M:LTE]NBLIG-1
 Case [M:LTE]SNS(I)
  When 1
   If IPTDEB<TOTCRE
    MTIPT = min(TOTCRE-IPTDEB,[M:LTE]AMT(I)-[M:LTE]IPT(I)-[M:LTE]TMP(I))
    [M:LTE]IPT(I)  += MTIPT
    [M:LTE]NIPT(I) += MTIPT
    IPTDEB         += MTIPT
   Else
    MTIPT = min(IPTDEB-TOTCRE,[M:LTE]IPT(I)+[M:LTE]TMP(I))
    [M:LTE]IPT(I)  -= MTIPT
    [M:LTE]NIPT(I) -= MTIPT
    IPTDEB         -= MTIPT
   Endif
  When 2
   If IPTCRE<TOTDEB
    MTIPT = min(TOTDEB-IPTCRE,[M:LTE]AMT(I)-[M:LTE]IPT(I)-[M:LTE]TMP(I))
    [M:LTE]IPT(I)  += MTIPT
    [M:LTE]NIPT(I) += MTIPT
    IPTCRE         += MTIPT
   Else
    MTIPT = min(IPTCRE-TOTDEB,[M:LTE]IPT(I)+[M:LTE]TMP(I))
    [M:LTE]IPT(I)  -= MTIPT
    [M:LTE]NIPT(I) -= MTIPT
    IPTCRE         -= MTIPT
   Endif
 Endcase
Next I

# LETTRAGE

Call LETDIF2([M:LTE]NBLIG,[M:LTE]ACCNUM,[M:LTE]DUDLIG,[M:LTE]IPT,FLDEV) From CPTLET
End

$SET_DUD
[M:LTE]ACCNUM(NOL) = [F:DUD]ACCNUM
[M:LTE]DUDLIG(NOL) = [F:DUD]DUDLIG
Case FLDEV
When 1
 [M:LTE]AMT(NOL) = [F:DUD]AMTLOC
 [M:LTE]IPT(NOL) = [F:DUD]PAYLOC
 [M:LTE]TMP(NOL) = [F:DUD]TMPLOC
When 2
 [M:LTE]AMT(NOL) = [F:DUD]AMTCUR
 [M:LTE]IPT(NOL) = [F:DUD]PAYCUR
 [M:LTE]TMP(NOL) = [F:DUD]TMPCUR
Endcase
If [F:DUD]SNS>0
 [M:LTE]SNS(NOL) = 1
 TOTDEB += [M:LTE]AMT(NOL)-[M:LTE]TMP(NOL)
 IPTDEB += [M:LTE]IPT(NOL)
Else
 [M:LTE]SNS(NOL) = 2
 TOTCRE += [M:LTE]AMT(NOL)-[M:LTE]TMP(NOL)
 IPTCRE += [M:LTE]IPT(NOL)
Endif
NOL += 1
Return

