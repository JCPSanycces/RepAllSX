$ON_CIVCTRA
Onevent BEFORE_INPUT Call AS_CIVCTRA(zc) From W1CTR4
Onevent CONTROL Call C_CIVCTRA(zc) From W1CTR4
Onevent AFTER_CHANGE Gosub AMM_CIVCTRA From W1CTR4
Return

Subprog IB_CIVCTRA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]NOLIB,"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_CIVCTRA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CIVCTRA(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]CIVCTRA(INDIC) = VALEUR
 Affzo CIVCTRA(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CIVCTRA(zc) From W1CTR4
Onkey   2 Titled GBOUTS Call S_CIVCTRA(zc) From W1CTR4
Gosub _AFF
End

Subprog C_CIVCTRA(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,"M",[M]NOLIB,15,[M]VALINT) From FMTVAR
If mkstat : GERR = 1 : GZONE = "CIVCTRA" : GZNUM = 14401 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M]VALINT,"M","","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "CIVCTRA" : GZNUM = 14401 : Endif
Endif
Gosub _AFF
End

$AMM_CIVCTRA
Call AM_CIVCTRA(zc)
If !mkstat & GOBJET
 zoncou = "CIVCTRA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CIVCTRA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CIVCTRA(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "CIVCTRA" : GZNUM = 14401 : Endif
Gosub _AFF
End

Subprog S_CIVCTRA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CIVCTRA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = "M"
 PARMSK(2) = [M]VALPAR
 PARMSK(3) = num$([M]NOLIB)
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

