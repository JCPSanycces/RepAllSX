End

$ON_ZEVECTRCOD
Onevent BEFORE_AREA Gosub AV_ZEVECTRCOD From W1CTR4
Return

$AV_ZEVECTRCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10345",num$([M]EVECTRCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_EVECTRDAT
Onevent CONTROL Call C_EVECTRDAT(zc) From W1CTR4
Onevent BEFORE_AREA Gosub AV_EVECTRDAT From W1CTR4
Return

$AV_EVECTRDAT
Chgfmt [M]EVECTRDAT(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_EVECTRDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EVECTRDAT" : GZNUM = 212 : Endif
If !mkstat
 ## Action STD
 Call C_EVECTRDAT(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "EVECTRDAT" : GZNUM = 212 : Endif
Endif
Gosub _AFF
End

$ON_WRKFLGADD
Onevent CONTROL Call C_WRKFLGADD(zc) From W1CTR4
Onevent AFTER_CHANGE Gosub AMM_WRKFLGADD From W1CTR4
Onevent INIT_AREA Call D_WRKFLGADD(zc) From W1CTR4
Onevent BEFORE_INPUT Call AS_WRKFLGADD(zc) From W1CTR4
Return

Subprog D_WRKFLGADD(VALEUR)
Variable Integer VALEUR
If varinit([M]WRKFLGADD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WRKFLGADD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_WRKFLGADD(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_WRKFLGADD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "WRKFLGADD" : GZNUM = 1344 : Endif
Gosub _AFF
End

$AMM_WRKFLGADD
Call AM_WRKFLGADD(zc)
If !mkstat & GOBJET
 zoncou = "WRKFLGADD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRKFLGADD(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_WRKFLGADD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "WRKFLGADD" : GZNUM = 1344 : Endif
Gosub _AFF
End

$CHG_STY
Gosub CHG_STY From W5CTR4
Return

$TIT_COL
Gosub TIT_COL From W5CTR4
Return


