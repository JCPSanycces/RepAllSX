#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:43"
A_USER  = "DOC"
A_STAMP = "20181109230343"
Return

$TITRES
Chgtzn [M:CTR4]SSCT1 With mess(32, 11706, 1)
Chgtzn [M:CTR4]PENT2 With mess(33, 11706, 1)
Chgtzn [M:CTR4]PENT3 With mess(34, 11706, 1)
Return

$CHG_FMT
Case zoncou
 When "NBRDP1"
  If [M]NBRDP1=0
  Endif
 When "NBRADD"
  If [M]NBRADD=0
  Endif
 When "NBRAFR"
  If [M]NBRAFR=0
  Endif
 When "NBRMID"
  If [M]NBRMID=0
  Endif
 When "NBCTD"
  If [M]NBCTD=0
  Endif
 When "NBCAR"
  If [M]NBCAR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR4 [CTR4]
Gosub HORODAT
Local Inpbox "CTR4" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR4] As [SIM_]
Grizo [CTR4]5
Grizo [CTR4]10
Grizo [CTR4]15
Grizo [CTR4]19
Grizo [CTR4]20
Grizo [CTR4]25
Grizo [CTR4]30
Grizo [CTR4]50
Grizo [CTR4]55
Grizo [CTR4]60
Grizo [CTR4]65
Grizo [CTR4]70
Grizo [CTR4]75
Grizo [CTR4]80
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=65 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=65 : Y1(1)=4 : Y2(1)=5
X1(2)=66 : X2(2)=163 : Y1(2)=1 : Y2(2)=5
X1(3)=66 : X2(3)=163 : Y1(3)=6 : Y2(3)=25
X1(4)=164 : X2(4)=198 : Y1(4)=1 : Y2(4)=5
X1(5)=1 : X2(5)=198 : Y1(5)=26 : Y2(5)=25
X1(6)=1 : X2(6)=198 : Y1(6)=26 : Y2(6)=34
X1(7)=1 : X2(7)=65 : Y1(7)=35 : Y2(7)=34
X1(8)=1 : X2(8)=65 : Y1(8)=35 : Y2(8)=34
X1(9)=1 : X2(9)=65 : Y1(9)=35 : Y2(9)=41
X1(10)=66 : X2(10)=163 : Y1(10)=35 : Y2(10)=41
X1(11)=1 : X2(11)=65 : Y1(11)=35 : Y2(11)=34
X1(12)=199 : X2(12)=198 : Y1(12)=35 : Y2(12)=41
X1(13)=164 : X2(13)=198 : Y1(13)=35 : Y2(13)=41
Return

$ON_AFFMUT
Onevent INIT_AREA Call D_AFFMUT(zc) From W1CTR4
Onevent CONTROL Call C_AFFMUT(zc) From W1CTR4
Onevent BEFORE_INPUT Call AS_AFFMUT(zc) From W1CTR4
Onevent AFTER_CHANGE Gosub AMM_AFFMUT From W1CTR4
Return

Subprog D_AFFMUT(VALEUR)
Variable Char    VALEUR()
If varinit([M]AFFMUT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10329","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_AFFMUT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10329") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_AFFMUT(zc) From W1CTR4
Onkey   2 Titled GBOUTS Call S_AFFMUT(zc) From W1CTR4
Onkey 144 Titled GBOUTP Call P_AFFMUT(zc) From W1CTR4
Onkey 146 Titled GBOUTA Call SA_AFFMUT(zc) From W1CTR4
Gosub _AFF
End

Subprog C_AFFMUT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10329","") From SUBADI
If mkstat : GERR = 1 : GZONE = "AFFMUT" : GZNUM = 46539 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10329",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "AFFMUT" : GZNUM = 46539 : Endif
Endif
Gosub _AFF
End

$AMM_AFFMUT
Call AM_AFFMUT(zc)
If !mkstat & GOBJET
 zoncou = "AFFMUT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AFFMUT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZAFFMUT)")>indice
 [M]AFFMUT(indice) = VALEUR
 Affzo ZAFFMUT(indice)
Endif
Gosub _AFF
End

Subprog S_AFFMUT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADILEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADILEG"
 PARMSK(1) = "10329"
 PARMSK(2) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILEG","SELTABCPT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_AFFMUT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10329") From GOBJET
Gosub _AFF
End

Subprog SA_AFFMUT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10329"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_AFFMUT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10329"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZAFFMUT
Onevent BEFORE_AREA Gosub AV_ZAFFMUT From W1CTR4
Return

$AV_ZAFFMUT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10329",num$([M]AFFMUT(indice))) From ATEXTRA
Gosub _AFF
Return

