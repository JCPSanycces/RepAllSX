 [M]HOUOCCDAT(INDIC) = VALEUR
 Affzo HOUOCCDAT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action SUBCTRLEG
 Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
 If mkstat=2
  [M]HOUOCCDAT(INDIC) = VALEUR
  Affzo HOUOCCDAT(INDIC) : mkstat = 2
 Endif
Endif
