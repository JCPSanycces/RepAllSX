$ON_SOCSTA
Onevent BEFORE_INPUT Call AS_SOCSTA(zc) From W1CTR4
Onevent INIT_AREA Call D_SOCSTA(zc) From W1CTR4
Onevent CONTROL Call C_SOCSTA(zc) From W1CTR4
Return

Subprog D_SOCSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]SOCSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SOCSTA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11707) From COMBOS
## Action STD
Call AS_SOCSTA(VALEUR) From SUBCTR
If mkstat=2
 [M]SOCSTA(INDIC) = VALEUR
 Affzo SOCSTA(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11707,1))))
Endif
If !mkstat
 Discombo 0 From SOCSTA(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SOCSTA(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SOCSTA(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

