Subprog D_EVECTRCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]EVECTRCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10345","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_EVECTRCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10345") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EVECTRCOD(zc) From W1CTR4
Onkey   2 Titled GBOUTS Call S_EVECTRCOD(zc) From W1CTR4
Onkey 144 Titled GBOUTP Call P_EVECTRCOD(zc) From W1CTR4
Onkey 146 Titled GBOUTA Call SA_EVECTRCOD(zc) From W1CTR4
If VALEUR="" : Call INIADI(VALEUR,"10345") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_EVECTRCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EVECTRCOD" : GZNUM = 1360 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10345","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "EVECTRCOD" : GZNUM = 1360 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10345",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "EVECTRCOD" : GZNUM = 1360 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_EVECTRCOD
Call AM_EVECTRCOD(zc)
If !mkstat & GOBJET
 zoncou = "EVECTRCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

