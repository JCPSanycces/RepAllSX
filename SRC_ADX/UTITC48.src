#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : RBA
# LE          : 19 Février   2013 13:28:24
# Moulinette pour initialisation du champ BOMALTTYP dans la table PLMPAR
# FQ88888
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC48: Initilisation ...") From LECFIC
  Call EXE_UTITC48(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTITC48(APPLI)
 Value Char APPLI
  If clalev([F:PPA]) : Close Local File [PPA] : Endif
  Local File =APPLI+".PLMPAR" [PPA]
  Call ECR_TRACE("UTITC48: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTITC48
  Call ECR_TRACE("UTITC48: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTITC48
  ########################################
  # AJOUTER ICI LE CODE DE LA MOULINETTE #
  ########################################
  # Issue 85472 - 2013-18-01 by RBA : Sous-traitance
  # Moulinette de mise à jour du champ BOMALTTYP = 2 pour tous les enrengistrements <> 3
  # Table : PLMPAR
  # Champ : BOMALTTYP
  Trbegin [PPA]
  Update [PPA] Where BOMALTTYP <> 3 With BOMALTTYP = 2
  If !GOK Then
    Goto AB_UTITC48
  Else
    Commit
  Endif
Return

$AB_UTITC48
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","PLMPAR","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC48(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","PLMPAR","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC48(APPLI)
End
