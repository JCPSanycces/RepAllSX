##################################################################
# Etiquettes écrans [IDA2]
##################################################################

########################################
Subprog C_ETRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[M]ETRDAT : End : Endif
Local Integer TROUVE
Gosub DEBFIN
If VALEUR<DEBANN | VALEUR> FINANN
 # Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat=2 : End
Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
For [F:HRCTR]CTR1 Where REFNUM=[M:IDA0]EMPDDS & CTRNUM=[M:IDA0]CTRNUM  & CTRDAT<=VALEUR
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=VALEUR)
  TROUVE=1 : Break
Endif
Next
If !TROUVE
 # Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-[M:IDA0]CTRNUM
 mkstat=2 : End
Else
 [M:IDA2]ETRDAT=VALEUR
 Gosub INIT_JOB
Endif
End

########################################
Subprog AM_ETRDAT(VALEUR)
Variable Date    VALEUR
# Si la fiche existe je la charge...
Read[F:IDA]IDA0=[M:IDA0]YEAEMPDDS;[M:IDA0]EMPDDS;[M:IDA0]CTRNUM;VALEUR;[M:IDA0]TYPDAE;[M:IDA0]FLGDNA
If !fstat : [M:IDA0]=[F:IDA] : Endif
End

########################################
Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[M]XITDAT : End : Endif
Local Integer TROUVE
Gosub DEBFIN
If VALEUR<DEBANN | VALEUR> FINANN
 # Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat=2 : End
Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
For [F:HRCTR]CTR1 Where REFNUM=[M:IDA0]EMPDDS & CTRNUM=[M:IDA0]CTRNUM  & CTRDAT<=[M:IDA2]ETRDAT
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=VALEUR)
  TROUVE=1 : Break
Endif
Next
If !TROUVE
 # Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-[M:IDA0]CTRNUM
 mkstat=2 : End
Else
 [M:IDA2]XITDAT=VALEUR
 Gosub INIT_JOB
Endif
End

########################################
$DEBFIN
Local Char VALPAR (10)
Local Date DEBANN, FINANN

Local Integer TROUVE , VBTP, VNBT
VBTP=func AFNC.ACTIV("BTP")
If [M:IDA0]TYPDAE>2
 NVBT=0
Else
 VNBT=1
Endif

If VBTP
 DEBANN=gdat$(01,04,val([M:IDA0]YEAEMPDDS))
 FINANN=gdat$(31,03,val([M:IDA0]YEAEMPDDS)+1)
 Return
Endif

Call PARAM([M:IDA0]ETRFCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" : VALPAR="12" : Endif
If val(VALPAR)=12
 DEBANN=gdat$(01,01,val([M:IDA0]YEAEMPDDS))
 FINANN=gdat$(31,12,val([M:IDA0]YEAEMPDDS))
Else
 DEBANN=gdat$(01,val(VALPAR)+1,val([M:IDA0]YEAEMPDDS)-1)
 FINANN=gdat$(eomonth(gdat$(01,val(VALPAR),val([M:IDA0]YEAEMPDDS))),val(VALPAR),val([M:IDA0]YEAEMPDDS))
Endif
Return

