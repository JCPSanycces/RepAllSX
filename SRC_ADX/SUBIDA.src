#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ

Call OBJET("IDA",GBIDC1,"") From GOBJET
End

###################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "VERF_ANU"    : Gosub VERF_ANU
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "RAZCRE"      : Gosub RAZCRE
 When "FILTRE"      : Gosub FILTRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FERME"       : Gosub FERME
Endcase
Return

###################################
$OUVRE
Gosub OUVRE From WPDEFTABLE
If clalev([F:IDA2])=0 : Local File IDADEMP   [IDA2] : Endif
If clalev([F:IDA])=0  : Local File IDADEMP    [IDA]  : Endif
If clalev([F:IDS])=0  : Local File IDADEMP2   [IDS]  : Endif
If clalev([F:HRIDP])=0  : Local File IDADEMP3   [HRIDP]  : Endif
If clalev([F:IDF])=0  : Local File IDADEMP31  [IDF] : Endif
If clalev([F:IDR])=0  : Local File IDADEMP32  [IDR] : Endif
If clalev([F:IDU])=0  : Local File IDADEMP33  [IDU]  : Endif
If clalev([F:IDV])=0  : Local File IDADEMP34  [IDV]  : Endif
If clalev([F:IDW])=0  : Local File IDADEMP35  [IDW]  : Endif
If clalev([F:IDC])=0  : Local File IDADEMP4   [IDC]  : Endif
If clalev([F:IDG])=0  : Local File IDADEMP5   [IDG]  : Endif
If clalev([F:IDH])=0  : Local File IDADEMP6   [IDH]  : Endif
If clalev([F:IDI])=0  : Local File IDADEMP7   [IDI]  : Endif
If clalev([F:IDJ])=0  : Local File IDADEMP8   [IDJ]  : Endif
If clalev([F:IDK])=0  : Local File IDADEMP9   [IDK]  : Endif
If clalev([F:IDL])=0  : Local File IDADEMP10  [IDL]  : Endif
If clalev([F:IDM])=0  : Local File IDADEMP11  [IDM]  : Endif
If clalev([F:IDQ])=0  : Local File IDADEMP12  [IDQ]  : Endif
If clalev([F:IDE])=0  : Local File IDADEMP121 [IDE]  : Endif
If clalev([F:WAC])=0  : Local File TRVACC   [WAC]  : Endif
If clalev([F:WAR])=0  : Local File TRVACCRAT[WAR]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif
If clalev([F:ADI2])=0 : Local File ATABDIV  [ADI2] : Endif
If clalev([F:ADI3])=0 : Local File ATABDIV  [ADI3] : Endif
If clalev([F:ORG])=0  : Local File ORGANISME[ORG]  : Endif

#DNA
If clalev([F:IDN])=0 : Local File IDADDNA   [IDN] : Endif
If clalev([F:ID2])=0 : Local File IDADDNA2  [ID2] : Endif
If clalev([F:ID3])=0 : Local File IDADDNA3  [ID3] : Endif
If clalev([F:ID4])=0 : Local File IDADDNA4  [ID4] : Endif
If clalev([F:ID5])=0 : Local File IDADDNA5  [ID5] : Endif
If clalev([F:ID6])=0 : Local File IDADDNA6  [ID6] : Endif
If clalev([F:ID7])=0 : Local File IDADDNA7  [ID7] : Endif
If GINTMT=1
 If clalev([F:ID8])=0 : Local File IDADDNA8  [ID8] : Endif
Endif

If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif

Local Integer VBPT , VNBT
Local Char VALPAR (10)
Local Char ANCOUR (4)
Local Integer LIBPRU, LIBTYPJOB, LIBTYPIDA
Local Date DEBANN, FINANN
Local Integer NBLOOPS, INDIC, INDIC2, TEMPO
Local Char  ORGCOURANT (GLONORG)

#71625
VBTP=func AFNC.ACTIV("BTP")

# L'année de la date de démarrage=année des fiches dads-u importées
Call PARAM("","IDADAT",VALPAR) From ADOVAL
If VALPAR<>""
 [L]ANCOUR=num$(year(VALPAR))
Else
 [L]ANCOUR=num$(year(date$))
Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###################################
$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP ="1=1"
Endif
Return

###################################
$SETBOUT    #pour désactiver le bouton chgt clé
Call VIREBOUT (CHAINE,"H") From GOBJET
If CLECUR & VERROU : CHAINE+="A" : Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:IDA0]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
GCURLEG=[F:CPY]LEG

If [M:IDA0]TYPDAE>2
 VNBT=0
 Effzo [M:IDA4]10-15 : Grizo [M:IDA4]10-15
 Effzo [M:IDA5] : Grizo [M:IDA5]
 Effzo [M:IDA6] : Grizo [M:IDA6]
 Effzo [M:IDA8] : Grizo [M:IDA8]
 Effzo [M:IDAA] : Grizo [M:IDAA]
 If VBTP :  Actzo [M:IDA7] : Endif
Else
 VNBT=1
 If VBTP :  Effzo [M:IDA7] : Grizo [M:IDA7] : Endif
 Actzo [M:IDA4]10-15
 Actzo [M:IDA5]
 Actzo [M:IDA6]
 Actzo [M:IDA8]
 Actzo [M:IDAA]
Endif
Gosub CHARGE_IDS
If VNBT : Gosub CHARGE_PREVOY : Affzo [M:IDA5] : Endif
If VBTP : Gosub CHARGE_BTP : Affzo[M:IDA7] : Endif
Gosub CHARGE_SITPAR : Affzo[M:IDA9]
TEMPO=[F:IDA]WRKFLGADD
Call GRISE_WRKADD(TEMPO)
LIBTYPJOB=[F:IDA]TYPJOB
Call C_TYPJOB (LIBTYPJOB)
LIBPRU=[F:IDA]PRUCTR
Call AM_PRUCTR(LIBPRU)
Gosub CHARGE_IDG
Gosub CHARGE_IDH
Gosub CHARGE_IDI
Gosub CHARGE_IDJ
Gosub CHARGE_IDK
Gosub CHARGE_IDL
Gosub CHARGE_IDM

#Stock option
Gosub CHARGE_STK
Gosub CHARGE_IDN From TRTIDN

TEMPO=[F:IDA]AGFFLG
Call AM_AGFFLG(TEMPO)

If clalev([M:IDN3])>=0
 TEMPO=[F:IDN]DNASTAPAR
 Call AM_DNAFLGSTA(TEMPO)
 TEMPO=[F:IDN]DNACHOFLG
 Call AM_DNACHOFLG (TEMPO)
Endif

#Salarié importés abset de la base des salariés : on empêche le tunnel
If [F:IDA]FLGNEWSAL=2 : Grizo [M:IDA0]EMPDDS : Else : Actzo [M:IDA0]EMPDDS :  Endif

#N4DS
Grizo [M:IDN1]DNASTRCAE,DNAREFCAE
Grizo [M:IDN1]30
Grizo [M:IDN2]30
If GINTMT : Grizo [M:IDN4]10 : Endif

Return

###################################
$INICRE
$INIMOD
[M:IDA0]FLGDNA=1
[F:IDA]FLGDNA=1
Gosub SAUVE_IDS
Gosub SAUVE_SITPAR
If VNBT : [F:IDA]=[M:IDA5] : Gosub SAUVE_PREVOY: Endif
If VBTP
 [F:IDA]=[M:IDA7]
 [F:IDA]BUINBRYEA(0)=[M:IDA7]BUINBRYEA1
 [F:IDA]BUINBRYEA(1)=[M:IDA7]BUINBRYEA2
 Gosub SAUVE_BTP
Endif
Read [F:WAC]WAC0=[M:IDA2]RSKWRK
If fstat : Raz [F:WAC] : Endif
#Toutes les zones ne sont pas dans l'écran
[F:IDA]=[F:WAC]
[F:IDA]RATWAC=[M:IDA2]RATWAC :#par sécurité
Raz [F:IDA]DADFCY
Read [F:FCY]FCY0=[M:IDA0]ETRFCY
If !fstat & [F:FCY]DADFCY<>""
 [F:IDA]DADFCY=[F:FCY]DADFCY
Else
 Read [F:FCY]FCY0=[M:IDA0]ETRFCY
 If !fstat & [F:FCY]DADFCY<>""
  [F:IDA]DADFCY=[F:FCY]DADFCY
 Else
  [F:IDA]DADFCY=[M:IDA0]ETRFCY
 Endif
Endif
Gosub SAUVE_IDG
Gosub SAUVE_IDH
Gosub SAUVE_IDI
Gosub SAUVE_IDJ
Gosub SAUVE_IDK
Gosub SAUVE_IDL
Gosub SAUVE_IDM

#Stock option
Gosub SAUVE_STK
Gosub SAUVE_IDN From TRTIDN
Return

###################################
$RAZCRE
[M:IDA0]TYPDAE=1
[M:IDA0]FLGDNA=1
[M:IDA0]YEAEMPDDS=[L]ANCOUR
Affzo [M:IDA0]
Return

###################################
$VERF_ANU
Trbegin [IDA],[IDS],[HRIDP], [IDC], [IDG], [IDH], [IDI], [IDJ], [IDK], [IDL],[IDM],[IDF],[IDR],[IDQ],[IDE],[IDU],[IDV],[IDW]
 Delete [IDA] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDS] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP2" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [HRIDP] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP3" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDC] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
& & (ETRDAT>=[M:IDA2]ETRDAT | (ETRDAT>=addmonth([M:IDA2]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[M:IDA2]XITDAT
& & XITDAT<=[M:IDA2]XITDAT
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP4" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDG] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP5" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDH] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP6" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDI] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP7" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDJ] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP8" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDK] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP9" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDL] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP10" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 #TEPA
 Delete [IDM] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP11" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDF] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP31" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDR] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP32" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDQ] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP12" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDE] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP121" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDU] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP33" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDV] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP34" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDW] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP35" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Delete [IDN] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID2] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA2" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID3] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA3" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID4] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA4" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID5] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA5" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID6] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA6" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [ID7] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
& & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$IDADDNA7" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
If GINTMT=1
 Delete [ID8] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS
&  & ETRDAT=[M:IDA0]ETRDAT & CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADDNA8" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return

###################################
$CHARGE_IDS
Local Integer IJK
Read[IDS]IDS0=[F:IDA]YEAEMPDDS;[F:IDA]EMPDDS;[F:IDA]CTRNUM;[F:IDA]ETRDAT;[F:IDA]TYPDAE;[F:IDA]FLGDNA
If fstat=0
 For nolign=0 To [F:IDS]NBRRGM-1
  [M:IDA4]=[F:IDS]
 Next
 [M:IDA4]NBRRGM = nolign
 For nolign=0 To [F:IDS]NBRSPEBAS-1
  [M:IDA4]=[F:IDS]
 Next
 [M:IDA4]NBRSPEBAS = nolign
 For nolign=0 To [F:IDS]NBRSPECLG-1
  [M:IDA4]=[F:IDS]
 Next
 [M:IDA4]NBRSPECLG = nolign
 For nolign=0 To [F:IDS]NBRALO-1
  [M:IDA4]=[F:IDS]
 Next
 [M:IDA4]NBRALO = nolign
 For nolign=0 To [F:IDS]NBRSPEEXO-1
  [M:IDA8]=[F:IDS]
 Next
 [M:IDA8]NBRSPEEXO = nolign
 For nolign=0 To [F:IDS]NBRURSBBE-1
  [M:IDA8]=[F:IDS]
 Next
 [M:IDA8]NBRURSBBE = nolign
 For nolign=0 To [F:IDS]NBRURSBBP-1
  [M:IDA8]=[F:IDS]
 Next
 [M:IDA8]NBRURSBBP = nolign
Endif
Return

###################################
$SAUVE_IDS
Delete [IDS] Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$IDADEMP2" : Return
Endif
[F:IDS]YEAEMPDDS=[F:IDA]YEAEMPDDS
[F:IDS]EMPDDS=[F:IDA]EMPDDS
[F:IDS]ETRDAT=[F:IDA]ETRDAT
[F:IDS]CTRNUM=[F:IDA]CTRNUM
[F:IDS]TYPDAE=[F:IDA]TYPDAE
[F:IDS]FLGDNA=[F:IDA]FLGDNA
[F:IDS]=[M:IDA4]
[F:IDS]=[M:IDA8]
Write [IDS]
If fstat<>0
 GOK = 0 : Call FSTA("IDS") From GLOCK
Endif
Return

###################################
$CHARGE_PREVOY
Raz[M:IDA5]
[M:IDA5]=[F:IDA]
[M:IDA5]DATANC1=[F:IDA]DATANC(0)
[M:IDA5]DATANC2=[F:IDA]DATANC(1)

nolign=0
For I=0 To dim([F:IDA]TYPANC)-1
 If ![F:IDA]TYPANC(I): Break : Endif
 nolign+=1
 [M:IDA5]TYPANC(nolign-1)=[F:IDA]TYPANC(I)
 [M:IDA5]UOMANC(nolign-1)=[F:IDA]UOMANC(I)
 [M:IDA5]AMTANC(nolign-1)=[F:IDA]AMTANC(I)
Next
[M:IDA5]NBRANC=nolign
Gosub PREVOY_CTR
Gosub PREVOY_DRT
Affzo[M:IDA5]
Return

###################################
$PREVOY_CTR
Effzo [M:IDA5]25
# Tableau des contrats prévoyance
nolign=0
For [HRIDP]IDP0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE
 nolign += 1
 [M:IDA5]REFCTR(nolign-1)=[F:HRIDP]REFCTR
 [M:IDA5]NUMDCS(nolign-1)=[F:HRIDP]NUMDCS
 [M:IDA5]CODOBJ(nolign-1)="IDP"
Next
# Tableau des contrats mutuelle
For [IDU]IDU0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE
 nolign += 1
 [M:IDA5]REFCTR(nolign-1)=[F:IDU]REFCTR
 [M:IDA5]NUMDCS(nolign-1)=[F:IDU]NUMDCS
 [M:IDA5]CODOBJ(nolign-1)="IDU"
Next
[M:IDA5]NBRCTRPRV = nolign
Return

###################################
$PREVOY_DRT
Effzo [M:IDA5]30
# Tableau des ayants droits
nolign=0
For [IDQ]IDQ0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE
 nolign += 1
 [M:IDA5]TYPBNF(nolign-1)=[F:IDQ]TYPBNF
 [M:IDA5]NAMBNF(nolign-1)=[F:IDQ]NAMBNF
 [M:IDA5]SRNBNF(nolign-1)=[F:IDQ]SRNBNF
 [M:IDA5]NUMLIG(nolign-1)=[F:IDQ]NUMLIG
Next
[M:IDA5]NBRBNFPRV = nolign
Return

###################################
$SAUVE_PREVOY
[F:IDA]=[M:IDA5]
[F:IDA]DATANC(0)=[M:IDA5]DATANC1
[F:IDA]DATANC(1)=[M:IDA5]DATANC2
nolign=0
For nolign=1 To [M:IDA5]NBRANC
 [F:IDA]TYPANC(nolign-1)=[M:IDA5]TYPANC(nolign-1)
 [F:IDA]UOMANC(nolign-1)=[M:IDA5]UOMANC(nolign-1)
 [F:IDA]AMTANC(nolign-1)=[M:IDA5]AMTANC(nolign-1)
Next
Return

###################################
$CHARGE_BTP
Raz[M:IDA7]
[M:IDA7]=[F:IDA]
[M:IDA7]BUINBRYEA1=[F:IDA]BUINBRYEA(0)
[M:IDA7]BUINBRYEA2=[F:IDA]BUINBRYEA(1)
Return

###################################
$SAUVE_BTP
[F:IDA]=[M:IDA7]
[F:IDA]BUINBRYEA(0)=[M:IDA7]BUINBRYEA1
[F:IDA]BUINBRYEA(1)=[M:IDA7]BUINBRYEA2
Return

###################################
$CHARGE_SITPAR
nolign=0
For [IDC]IDC0 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
& & (ETRDAT>=[F:IDA]ETRDAT | (ETRDAT>=addmonth([F:IDA]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[F:IDA]XITDAT
& & XITDAT<=[F:IDA]XITDAT
 nolign += 1
 [M:IDA9]=[F:IDC]
 [M:IDA9]ETRDAT2(nolign-1)=[F:IDC]ETRDAT
 [M:IDA9]XITDAT2(nolign-1)=[F:IDC]XITDAT
Next
[M:IDA9]NBLIG= nolign

# N4DS - Zones CRPNPAC / RAEP
[M:IDA9]NBPAC = max(0, find(0, [M:IDA9]PACTYPCOT)-1 )
[M:IDA9]NBRAE = max(0, find(0, [M:IDA9]RAETYPSTU)-1 )

Return

###################################
$SAUVE_SITPAR
Delete [IDC] Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS &  CTRNUM=[M:IDA0]CTRNUM & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
& & (ETRDAT>=[M:IDA2]ETRDAT | (ETRDAT>=addmonth([M:IDA2]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[M:IDA2]XITDAT
& & XITDAT<=[M:IDA2]XITDAT
If fstat=1
 GOK =-1 : GLOCK = "$IDADEMP4" : Return
Endif
For nolign=1 To [M:IDA9]NBLIG
 [F:IDC]ETRDAT= [M:IDA9]ETRDAT2(nolign-1)
 [F:IDC]XITDAT= [M:IDA9]XITDAT2(nolign-1)
 [F:IDC]=[M:IDA9]
 [F:IDC]YEAEMPDDS=[F:IDA]YEAEMPDDS
 [F:IDC]EMPDDS=[F:IDA]EMPDDS
 [F:IDC]CTRNUM=[F:IDA]CTRNUM
 [F:IDC]TYPDAE=[F:IDA]TYPDAE
 [F:IDC]FLGDNA=[F:IDA]FLGDNA
 Write [IDC]
 If fstat<>0
  GOK = 0 : Call FSTA("IDC") From GLOCK : Break
 Endif
Next
Return

#TEPA
