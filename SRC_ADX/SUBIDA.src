#Valeur=2 -> code TDS=14
#Valeur=3 -> code TDS=16
#Valeur=4 -> code TDS=20
#Valeur=7 -> code TDS=23
#Valeur=8 -> code TDS=24
Subprog C_DNACODTIM(VALEUR)
Variable Integer VALEUR
Local Integer OK
OK=1
If clalev([F:HRCSP])=0  : Local File HRCATCSP [HRCSP]  : Endif
Call SIMPLEREAD([M:IDA2]CATCSP, GCURLEG, GERRHRM) From SUBHRCSP
Case VALEUR
 When 2 : If [F:HRCSP]CODN4H<>"652b" : OK=0 : Endif
 When 4 : If [F:HRCSP]CODN4H<>"692a" : OK=0 : Endif
 When 7,8 : If [F:HRCSP]CODN4H<"354a" | [F:HRCSP]CODN4H>"354g" : OK=0 : Endif
Endcase
If !OK
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

