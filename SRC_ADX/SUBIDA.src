#Tableau des Indemnités mensuelles
Subprog AS_DNAINDMTH(VALEUR)
Variable Integer VALEUR
For I=1 To len(mess(0,10969,1))
 If I<>5 & I<>6 & I<>15
  GMENLOC(I)=1
 Endif
Next
End

#Les valeurs 5 & 6 s'excluent
Subprog C_DNAINDMTH(VALEUR)
Variable Integer VALEUR
If nolign>1
 If (VALEUR=5 & [M]DNAINDMTH(nolign-2)=6) | (VALEUR=6 & [M]DNAINDMTH(nolign-2)=5)
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

