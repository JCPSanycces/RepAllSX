 [F:IDM]CTRNUM=[F:IDA]CTRNUM
 [F:IDM]TYPDAE=[F:IDA]TYPDAE
 [F:IDM]FLGDNA=[F:IDA]FLGDNA
 [F:IDM]NUMLIG=nolign
 [F:IDM]=[M:IDA3]
