# Etiquettes écrans [IDA4]
##################################################################

########################################
Subprog C_RGMCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ADI]CODE=10355;[M:IDA3]SYSMAL
 Read [ADI2]CODE=10340;VALEUR
 If [F:ADI]A1="120" & [F:ADI2]A1<>"CL001" & [F:ADI2]A1<>"9000" & [F:ADI2]A1<>"R0001"
  #Régime complémentaire invalide pour le régime de base :
  GMESSAGE = mess(13,10705,1)-[M:IDA3]SYSMAL
  mkstat=2 : End
 Endif
 If [F:ADI]A1="121" & [F:ADI2]A1<>"F0002"
  #Régime complémentaire invalide pour le régime de base :
  GMESSAGE = mess(13,10705,1)-[M:IDA3]SYSMAL
  mkstat=2 : End
 Endif
Endif
End

########################################
Subprog AS_RGMNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)
Filter [F:ORG] Where NUMDCS=[M]RGMCOD(nolign-1) & LEG=GCURLEG
Read [F:ORG]ORG0 First
Filter [F:ORG]
If !fstat
 Call ORGAFFIL ([F:ORG]COD,[M:IDA0]ETRFCY,[M:IDA0]EMPDDS,[F:HRCTR]CTRNUM,VNUMAFF,VNUMCTR) From SUBORA
 VALEUR=VNUMCTR
Endif
End

########################################
Subprog C_RGMNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read [ADI2]CODE=10340;[M:IDA4]RGMCOD(nolign-1)
 If ([F:ADI2]A1="I0001" | [F:ADI2]A1="I0002" | [F:ADI2]A1="CL001"
&  | [F:ADI2]A1="F0002" | [F:ADI2]A1="R0001")
  GMESSAGE=mess(10,123,1) #Zone obligatoire.
  mkstat=2 : End
 Endif
Endif
End

