Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNANBRCNG(VALEUR)
Variable Decimal VALEUR
If !VALEUR & find(15,[M]DNACODIND(0..[M]NBRIND2-1))
 #Zone obligatoire
