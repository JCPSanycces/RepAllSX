$CHARGE_STK
# Effzo[M:IDA6]5
# [M:IDA6]NBSTK=0
# nolign=0
# For I=0 To dim([F:IDA]NBRSTK)-1
#  If ![F:IDA]NBRSTK(I): Break : Endif
#  nolign+=1
#  [M:IDA6]=[F:IDA]
# Next
# [M:IDA6]NBSTK=nolign

# N4DS - Chargement des BSPCE et on en profite pour modifier le chargement des stocks options
#        => Il faudrait revoir tous les modes de chargement pour faire quelque chose de simple et basique ...
# RANG 5 : Stock option
# RANG 10 : Actions gratuites - traitées dans CHARGE_DAH
# RANG 15 : BSPCE

Effzo[M:IDA6] 5, 15
Raz [M:IDA6]NBSTK, [M:IDA6]NBBSPCE

# Un seul transclasse général
nolign = 0
[M:IDA6] = [F:IDA]

For I=0 To dim([F:IDA]BSPCENBRTI)-1
    If ![F:IDA]BSPCENBRTI(I): Break : Endif
    [M:IDA6]NBBSPCE += 1
Next

For I=0 To dim([F:IDA]NBRSTK)-1
    If ![F:IDA]NBRSTK(I): Break : Endif
    [M:IDA6]NBSTK += 1
Next
Return

###################################
$SAUVE_STK
#For nolign=1 To [M:IDA6]NBSTK
# [F:IDA]=[M:IDA6]
#Next
nolign = 0
[F:IDA] = [M:IDA6]
Return



###############################################################################################################################

###################################
$APRES_MODIF
Case COUZON
 When "EMPDDS"
  Assign "[M:IDA0]"+COUZON With CZ
  Filter [F:IDA] Where EMPDDS=[M:IDA0]EMPDDS & YEAEMPDDS=[M:IDA0]YEAEMPDDS & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
  Read [F:IDA]IDA0 Last
  Filter [IDA]
  If fstat<=2
   [M:IDA0]=[F:IDA]
  Else
   GMODIF=1
   Gosub INIT_EMP
  Endif
Endcase
Return

###################################
$INIT_EMP
Raz[M:IDA1] : Raz[M:IDA2] : Raz[M:IDA3] : Raz[M:IDA4]
If VNBT : Raz [M:IDA5] : Endif
Raz[M:IDA6]
If VBTP : Raz [M:IDA7] : Endif
Raz[M:IDA8] : Raz[M:IDA9]
Read [F:ID]ID0=[M:IDA0]EMPDDS
If !fstat
 [M:IDA0]=[F:ID]
 [M:IDA0]YEAEMPDDS= [L]ANCOUR
 [M:IDA0]CTRNUM=[F:ID]FCY
 [M:IDA0]TYPDAE=1
 [M:IDA0]FLGDNA=1

 [M:IDA1]=[F:ID]
 Gosub DECALAGE
 MATRI=[M:IDA0]EMPDDS
 DATMAT=FINANN
 Gosub LECEMP From WPDEFTABLE
 [M:IDA6]=[F:AD]
 [M:IDA0]CTRNUM=[F:HRCTR]CTRNUM
 [M:IDA0]ETRFCY=[F:HRCTR]ETRFCY
  # Multi_leg & multi_société
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GSOCIETE=[F:CPY]CPY : GCURLEG=[F:CPY]LEG
 [M:IDA2]=[F:HRCTR]
 [M:IDA2]ETRDAT = [F:HRCTR]CTRDAT
 [M:IDA2]ETRGRD = [F:HRCTR]CTRGRD
 If [M:IDA2]ETRDAT<>[0/0/0] & [M:IDA2]ETRDAT<=FINANN
  If [M:IDA2]ETRDAT<DEBANN  : [M:IDA2]ETRDAT=DEBANN : [M:IDA2]ETRGRD="ACT"  : Endif
 Else
 #Salarié non présent sur xxxx
  Call ERREUR (mess(140,10702,1)-[L]ANCOUR) From GESECRAN
  OK=0 : Return
 Endif
 If [M:IDA2]XITDAT=[0/0/0] | [M:IDA2]XITDAT>FINANN
  [M:IDA2]XITDAT=FINANN : [M:IDA2]XITGRD="ACT"
  #Si contrat droit privé alors contrat en vigueur coché !
  If [M:IDA6]PRUCTR=1  :  [M:IDA6]PRUFLG=2 : Else : [M:IDA6]PRUFLG=1 : Endif
 Endif
 [M:IDA0]ETRDAT=[M:IDA2]ETRDAT
 Gosub INIT_JOB
Endif
Affzo [M:IDA0] : Affzo[M:IDA1] : Affzo[M:IDA2] : Affzo[M:IDA3] : Affzo[M:IDA4]
If VNBT : Affzo [M:IDA5] : Endif
Affzo[M:IDA6]
If VBTP : Affzo [M:IDA7] : Endif
Affzo [M:IDA8] : Affzo[M:IDA9]
Return

###################################
$INIT_JOB
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)
If GREP="M" | GREP="D" : Return : Endif
Raz[M:IDA9]
MATRI=[M:IDA0]EMPDDS
DATMAT=[M:IDA2]ETRDAT
Gosub LECEMP From WPDEFTABLE
[M:IDA3]=[F:HRCTR]
Gosub INIT_IRC
If VNBT : Gosub INIT_IP : Endif
Return

###################################
$INIT_IRC
Raz [M:IDA4]NBRRGM
If [M:IDA0]TYPDAE<3
 If [F:HRCTR]STAEMP>1  : NBLOOPS=2 : Else : NBLOOPS=1 : Endif
 # Indices de travail pour l'ARRCO
 INDIC=GINDARR :  INDIC2=1
Else
 # Indices de travail pour l'ARRCO
 INDIC=GINDBTP :  INDIC2=1  : NBLOOPS=1
Endif
For J=0 To NBLOOPS-1
 # Indices de travail pour l'AGIRC
 If J=1 : INDIC=GINDAGI :  INDIC2=2 : Endif
 ORGCOURANT=""
 Call ORGANISME ([M:IDA0]EMPDDS,[M:IDA0]ETRFCY,[F:HRCTR]CTRNUM,ORGCOURANT,INDIC-1) From SUBORG
 If ORGCOURANT<>""
  Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
  If fstat=0 & [F:ORG]NUMDCS<>""
   [M:IDA4]RGMCOD(J)=[F:ORG]NUMDCS :#Code Régime/Institution (Arrco/Agirc)
   Call ORGAFFIL (ORGCOURANT,[M:IDA0]ETRFCY,[M:IDA0]EMPDDS,[F:HRCTR]CTRNUM,VNUMAFF,VNUMCTR) From SUBORA
   [M:IDA4]RGMNUM(J)=VNUMCTR :#No contrat (Arrco/Agirc)
   [M:IDA4]NBRRGM+=1
  Else
   [M:IDA4]RGMCOD(J)="NON" :#Pas de régime complèmentaire
   [M:IDA4]RGMNUM(J)=""
   [M:IDA4]NBRRGM+=1
  Endif
 Endif
Next
Return

###################################
$INIT_IP
# Retraite
#N4DS - Changement d'écran
[M:IDA4]UOMTIMWRK=1
[M:IDA4]LNGWRK=0
[M:IDA4]AGFFLG=1
# Prevoyance
[M:IDA5]DATANC1=[F:HRCTR]DATCPY
If [F:HRCTR]CTRDAT>[F:HRCTR]DATCPY
 [M:IDA5]DATANC2=[F:HRCTR]CTRDAT
Else
 Raz [M:IDA5]DATANC2
Endif
[M:IDA5]CODSITFAM=[F:ID]SITFAM
[M:IDA5]ORGMAL=[F:HRCTR]ORGMAL
[M:IDA5]ROWBRN=0
Filter [F:RIB] Where REFNUM=[F:HRCTR]REFNUM & find(TYPPAY,"NP","")<>0
Read [F:RIB]RIB0 First
Filter [F:RIB]
If !fstat
 [M:IDA5]IBAN=[F:RIB]IBAN
 [M:IDA5]BIC=[F:RIB]BICCOD
 [M:IDA5]BID=[F:RIB]BIDNUM
Else
 [M:IDA5]IBAN=""
 [M:IDA5]BIC=""
 [M:IDA5]BID=""
Endif
# Ancienneté
If year([M:IDA0]ETRDAT)-year([F:HRCTR]DATANC)>0 & year([M:IDA0]ETRDAT)-year([F:HRCTR]DATANC)<50
 [M:IDA5]TYPANC(0)=1
 [M:IDA5]UOMANC(0)=4
 [M:IDA5]AMTANC(0)=year([M:IDA2]ETRDAT)-year([F:HRCTR]DATANC)
Endif
Return

###################################
$DECALAGE
If VBTP
 DEBANN=gdat$(01,04,val(ANCOUR))
 FINANN=gdat$(31,03,val(ANCOUR)+1)
 [M:IDA2]MOVPAY=1
 Return
Endif
Call PARAM([M:IDA0]ETRFCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" : VALPAR="12" : Endif
If val(VALPAR)=12
 DEBANN=gdat$(01,01,val(ANCOUR))
 FINANN=gdat$(31,12,val(ANCOUR))
 [M:IDA2]MOVPAY=1
Else
 DEBANN=gdat$(01,val(VALPAR)+1,val(ANCOUR)-1)
 FINANN=gdat$(eomonth(gdat$(01,val(VALPAR),val(ANCOUR))),val(VALPAR),val(ANCOUR))
 [M:IDA2]MOVPAY=3
Endif
Return

###################################
$VERIF
For [IDA2]IDA0 Where YEAEMPDDS=[M:IDA0]YEAEMPDDS & EMPDDS=[M:IDA0]EMPDDS & CTRNUM=[M:IDA0]CTRNUM
&                   & (ETRDAT<>[M:IDA2]ETRDAT | ETRFCY<>[M:IDA0]ETRFCY) & TYPDAE=[M:IDA0]TYPDAE & FLGDNA=[M:IDA0]FLGDNA
 If [F:IDA2]ETRDAT<=[M:IDA2]ETRDAT & [F:IDA2]XITDAT>=[M:IDA2]ETRDAT
  # Opération imposible : Une fiche DADS-U existe déjà pour ce salarié à cette période.
  GMESSAGE = mess(45,10705,1)
  OK=0 : Break
 Endif
Next
If !OK : Return : Endif
Return

###################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

##################################################################
# Etiquettes écrans [IDA0]
##################################################################

########################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]CTRNUM : End : Endif
Local Integer TROUVE
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Gosub DEBFIN
For [F:HRCTR]CTR1 Where REFNUM=[M:IDA0]EMPDDS & CTRDAT<=FINANN & CTRNUM=VALEUR
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>DEBANN)
  TROUVE=1 : Break
 Endif
Next
If !TROUVE
 # Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-VALEUR
 mkstat=2 : End
Else
 [M:IDA0]CTRNUM=VALEUR
 [M:IDA2]=[F:HRCTR]
 If [M:IDA2]ETRDAT<DEBANN  : [M:IDA2]ETRDAT=DEBANN : [M:IDA2]ETRGRD="ACT"  : Endif
 If [M:IDA2]XITDAT=[0/0/0] | [M:IDA2]XITDAT>FINANN
  [M:IDA2]XITDAT=FINANN : [M:IDA2]XITGRD="ACT"
 Endif
 Gosub INIT_JOB
Endif
End

########################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
# Si la fiche existe je la charge...
Read[F:IDA]IDA0=[M:IDA0]YEAEMPDDS;[M:IDA0]EMPDDS;VALEUR;[M:IDA0]ETRDAT;[M:IDA0]TYPDAE;[M:IDA0]FLGDNA
If !fstat : [M:IDA0]=[F:IDA] : Endif
End

