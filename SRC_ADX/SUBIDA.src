########################################
Subprog AS_OLDNAM(VALEUR)
Variable Char    VALEUR()
#MABOS-11/04/13-FQ71754-US1516
#If [M:IDA0]CIV <>2
If VALEUR =""
 VALEUR=[M:IDA0]NAM
 Affzo [M:IDA1]OLDNAM
Endif
End

########################################
Subprog AM_CTYBRN(VALEUR)
Variable Char    VALEUR()
#61590
VALEUR=toupper(VALEUR)
#
# 49894
If [M]CTYBRNSEE<>""
 Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR & POSCTYCOD=[M]CTYBRNSEE
 Read [POS]POS0 First
 If fstat
  Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
 Endif
Else
 Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
Endif
Read [POS]POS0 First
Filter [POS]
If fstat<=2
 [M]CTYBRNSEE = [F:POS]POSCTYCOD
    #[M]DEPBRN    = left$([F:POS]POSCOD,2)
  If left$([F:POS]POSCTYCOD,2)="2A" | left$([F:POS]POSCTYCOD,2)="2B"
   [M]DEPBRN    = left$([F:POS]POSCTYCOD,2)
  Else
   [M]DEPBRN    = left$([F:POS]POSCOD,2)
  Endif
  Affzo CTYBRNSEE,DEPBRN
Endif
End

