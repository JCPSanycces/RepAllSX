 If fstat | ([F:HRCSP]CODN4H>="354a" & [F:HRCSP]CODN4H<="354g") |  [F:HRCSP]CODN4H="637c" | [M:IDA2]SEVJOB=2 | [M:IDA2]NATCON="CTT"
  #Zone obligatoire
