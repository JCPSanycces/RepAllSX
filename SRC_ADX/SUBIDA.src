Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:IDA2]XITDAT
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog AM_DNAENDDAT(VALEUR)
Variable Date    VALEUR
Call GRISE_SORTIE (VALEUR)
End

Subprog GRISE_SORTIE (VALEUR)
Value Date VALEUR
If VALEUR=[0/0/0]
 Effzo [M:IDN3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Effzo [M:IDN3]15-25
 Grizo [M:IDN3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Grizo [M:IDN3]15-25
Else
 Actzo [M:IDN3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Actzo [M:IDN3]15-25
Endif
End

Subprog C_DNADATNTF(VALEUR)
Variable Date    VALEUR
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
Call SIMPLEREAD([M:IDA2]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
 Case [F:HRNCT]CODN4H
   When "11","12","14","15","20","25","34","36","41","83" :
    If VALEUR=[0/0/0]
     #Zone obligatoire
     GMESSAGE=mess(10,123,1)
     mkstat=2 : End
    Endif
  Endcase
 Endif
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
If [M]NBRPRV & VALEUR>min([M]DNASTRPRV(0..[M]NBRPRV-1)) & min([M]DNASTRPRV(0..[M]NBRPRV-1))<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNADATLIC(VALEUR)
Variable Date    VALEUR
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
Call SIMPLEREAD([M:IDA2]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
 Case [F:HRNCT]CODN4H
   When "11","12","14"
    If VALEUR=[0/0/0]
     #Zone obligatoire
     GMESSAGE=mess(10,123,1)
     mkstat=2 : End
    Endif
  Endcase
 Endif
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
If [M]NBRPRV & VALEUR>min([M]DNASTRPRV(0..[M]NBRPRV-1)) & min([M]DNASTRPRV(0..[M]NBRPRV-1))<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

