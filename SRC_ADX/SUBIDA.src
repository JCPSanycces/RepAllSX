##################################################################
# Etiquettes écrans [IDA9]
##################################################################

########################################
Subprog C_ETRDAT2(VALEUR)
Variable Date    VALEUR
Local Integer I
If [M:IDA9]OLDSPE(nolign-1)=1 :#Période courante
 If VALEUR <[M:IDA2]ETRDAT | VALEUR >[M:IDA2]XITDAT
  #situation part en dehors de la période d'activité
  GMESSAGE = mess(43,10705,1)
  mkstat=2 : End
 Endif
Else    :#Période antérieure
 Gosub DEBFIN
 If VALEUR < addmonth(DEBANN,-2)
  #situation part en dehors de la période de la situation antérieure
  GMESSAGE = mess(47,10705,1)
  mkstat=2 : End
 Endif
Endif
For I=0 To [M:IDA9]NBLIG-1
 If I<>nolign-1
  If VALEUR>=[M:IDA9]ETRDAT2(I) & VALEUR<=[M:IDA9]XITDAT2(I)
   #Une situation particulière existe déjà à cette date
   GMESSAGE = mess(44,10705,1)
   mkstat=2 : Break
  Endif
 Endif
Next
If mkstat : End : Endif
End

########################################
Subprog C_XITDAT2(VALEUR)
Variable Date    VALEUR
Local Integer I
If [M:IDA9]OLDSPE(nolign-1)=1 :#Période courante
 If VALEUR <[M:IDA2]ETRDAT | VALEUR >[M:IDA2]XITDAT
  #situation part en dehors de la période d'activité
  GMESSAGE = mess(43,10705,1)
  mkstat=2 : End
 Endif
Else
#Période antérieure
 Gosub DEBFIN
 If VALEUR > DEBANN
  #situation part en dehors de la période de la situation antérieure
  GMESSAGE = mess(47,10705,1)
  mkstat=2 : End
 Endif
Endif
For I=0 To [M:IDA9]NBLIG-1
 If I<>nolign-1
  If VALEUR>=[M:IDA9]ETRDAT2(I) & VALEUR<=[M:IDA9]XITDAT2(I)
   #Une situation particulière existe déjà à cette date
   GMESSAGE = mess(44,10705,1)
   mkstat=2 : Break
  Endif
  If [M:IDA9]ETRDAT2(nolign-1)<=[M:IDA9]ETRDAT2(I) & VALEUR>=[M:IDA9]XITDAT2(I)
   #Une situation particulière existe déjà à cette date
   GMESSAGE = mess(44,10705,1)
   mkstat=2 : Break
  Endif
 Endif
Next
If mkstat : End : Endif
End

