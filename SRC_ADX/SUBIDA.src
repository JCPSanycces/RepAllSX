#Tableau des préavis #############
Subprog AS_DNASTRPRV(VALEUR)
Variable Date    VALEUR
If [M]DNACODPRV(nolign-1)>3
 mkstat=1 : End
Endif
End

Subprog C_DNASTRPRV(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
# Chevauchement interdit
For I=0 To [M]NBRPRV-1
 If I<>nolign-1
  If VALEUR<DNAENDPRV(I) & VALEUR>=DNASTRPRV(I)
   #Valeur incorrecte
   GMESSAGE=mess(83,123,1)
   mkstat=2 : End
  Endif
 Endif
Next
End

Subprog AS_DNAENDPRV(VALEUR)
Variable Date    VALEUR
If [M]DNACODPRV(nolign-1)>3
 mkstat=1 : End
Endif
End

Subprog C_DNAENDPRV(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
# Chevauchement interdit
For I=0 To [M]NBRPRV-1
 If I<>nolign-1
  If (VALEUR>[M]DNASTRPRV(I) & [M]DNASTRPRV(nolign-1)<=[M]DNASTRPRV(I))
   #Valeur incorrecte
   GMESSAGE=mess(83,123,1)
   mkstat=2 : End
  Endif
 Endif
Next
End

#IRC
Subprog C_RGMCOD1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[F:ADI]CODE=10340;VALEUR
 If fstat | toupper(left$([F:ADI]A1,1))<>"A" & toupper(left$([F:ADI]A1,1))<>"G"
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_RGMCOD2(VALEUR)
Variable Char    VALEUR()
#N4DS
Read[F:ADI]CODE=10364;[M:IDA2]STACAT
If fstat | val([F:ADI]A1)>1
 mkstat=1 : End
Endif
End

Subprog C_RGMCOD2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[F:ADI]CODE=10340;VALEUR
 If fstat | toupper(left$([F:ADI]A1,1))<>"C" & toupper(left$([F:ADI]A1,1))<>"G"
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

