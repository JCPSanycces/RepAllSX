#<AdxTL>@(#)9.0.0.0 $Revision$
Call IMPORTATION("SOS") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
    When "EXPORT" :        Gosub EXPORT
Endcase
Return

###################################################################################
$EXPORT
If [F:ORD]WIPTYP <> 1 | [F:ORD]WIPSTA <> 3 : OK = 0 : Endif
Return


###################################################################################
# Ouvertures  
################################################################################
# GIMP :                                                                       #
#     GIMP(1) :                                                                #
#                1: Purge de la totalité des prévisions existantes             #
#                2: Purge d'une partie des prévisions existantes               #   
################################################################################
$OUVRE
Local   Integer VS
Local   Char    WITM(GLONITM), WFCY(GLONFCY)
Local   Date    TODAY : TODAY = date$
Local   Char    CRITERE(250), CRITERE1(250)    # 12.03 MM Cohérence avec l'évolution de la fonction std

If clalev ([F:ITM])  <= 0  : Local File   ITMMASTER  [ITM]  : Endif
If clalev ([F:ITF])  <= 0  : Local File   ITMFACILIT [ITF]  : Endif
If clalev ([F:FCY])  <= 0  : Local File   FACILITY   [FCY]  : Endif
If clalev ([F:ORD1])  = 0  : Local File   ORDERS     [ORD1] : Endif

If clalev ([M:ORDK]) <= 0  : Local Mask   ORDK       [ORDK] : Endif
Return

######################################################
# Réinitialisation après création (début de lecture)                           
$RAZCRE
Raz [M:ORDK]
Return

######################################################
$SAIMSK
Return

######################################################
# Contrôles
$CONTROLE_IMP

# controle site
If [F:FCY]FCY <> [M:ORDK]STOFCY
   Read [FCY]FCY0 = [M:ORDK]STOFCY
   If fstat
      GMESSAGE = [M:ORDK]STOFCY-":"-mess(15,104,1) : # Site inexistant
      OK = 0
      Return
   Endif
Endif
#VPO 19/04/10 64127 le site doit être un site de stockage
#If [F:FCY]MFGFLG <> 2
If [F:FCY]WRHFLG <> 2
    #GMESSAGE = mess(1,193,1)
    GMESSAGE = [M:ORDK]STOFCY-":"-mess(358,184,1) : # ce site n'est pas un site de stockage
    OK = 0
    Return
Endif

# controle article
If [F:ITM]ITMREF <> [M:ORDK]ITMREF
    Read [ITM]ITM0 = [M:ORDK]ITMREF
    If fstat 
        GMESSAGE =  [M:ORDK]ITMREF-":"-mess(134,100,1) : # Code article inexistant
        OK = 0
        Return
    Endif
Endif

# controle article-site
If [F:ITF]ITMREF <> [M:ORDK]ITMREF | [F:ITF]STOFCY <> [M:ORDK]STOFCY
    Read [ITF]ITF0 = [M:ORDK]ITMREF;[M:ORDK]STOFCY
    If fstat
       # GMESSAGE = mess(2,196,1)+" : "+[M:ORDK]STOFCY : # Article non géré en stock pour le site
        GMESSAGE = +[M:ORDK]ITMREF+"/"+[M:ORDK]STOFCY-":"-mess(139,197,1) :  # article-site inexistant
        OK = 0
        Return
    Endif
Endif
Return

######################################################
# Contrôles et mises à jour                           
$VALID
If IMPFIN : OK = 0 : Return : Endif

Raz [M:ORDK]                       # FQ 53291 plutôt que Raz faites + tard
[M:ORDK]           = [F:ORD]
# zones obligatoires : Site, article, date fin
If [M:ORDK]STOFCY = "" |
&  [M:ORDK]ITMREF = "" |
&  [M:ORDK]ENDDAT = [0/0/0]
#&  | [M:ORDK]EXTQTY <= 0        : # GH 17/12/2013 bug 94792
    OK = 0
    Return
Endif
Gosub CONTROLE_IMP
If !OK
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    GMESSAGE=""
    Return 
Endif

# écriture SOS
[M:ORDK]WIPTYP     = 1
[M:ORDK]WIPSTA     = 3
[M:ORDK]ORIFCY     = [M:ORDK]STOFCY
#[M:ORDK]PJT        = ""         # FQ 53291 champ importé ?
#[M:ORDK]BPRNUM     = ""         # FQ 53291 champ importé ?
[M:ORDK]STRDAT     = [M:ORDK]ENDDAT
[M:ORDK]VCRTYP     = 1
#[M:ORDK]VCRLIN     = 0          # FQ 53291 champ importé ?
#[M:ORDK]VCRSEQ     = 0          # FQ 53291 champ importé ?
[M:ORDK]CPLQTY     = 0
[M:ORDK]ALLQTY     = 0
[M:ORDK]SHTQTY     = 0
[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1
#[M:ORDK]VCRTYPORI  = 0          # FQ 53291 champ importé ?
#[M:ORDK]VCRNUMORI  = ""         # FQ 53291 champ importé ?
#[M:ORDK]VCRLINORI  = 0
#[M:ORDK]VCRSEQ     = 0          # FQ 53291 champ importé ?
#[M:ORDK]BOMALT     = 0          # FQ 53291 champ importé ?
[M:ORDK]ORI        = 3

# 31132 07.05 MM : donner une valeur par défaut à GIMP(1)
If GIMP(1)<>"2" :  GIMP(1)="1" : Endif

# 12.03 MM 
CRITERE="[F:ORD1]STOFCY = [M:ORDK]STOFCY & [F:ORD1]ITMREF=[M:ORDK]ITMREF & [F:ORD1]WIPTYP =1 & [F:ORD1]WIPSTA=3"

Call DEBTRANS From GLOCK
Trbegin [ORD]
If  GIMP(1)="2"
    CRITERE1="(([F:ORD1]STRDAT >= [M:ORDK]STRDAT & [F:ORD1]ENDDAT <= [M:ORDK]ENDDAT)|"
    CRITERE1+="([F:ORD1]STRDAT<=[M:ORDK]STRDAT & [F:ORD1]ENDDAT>=[M:ORDK]STRDAT)|"
    CRITERE1+="([F:ORD1]STRDAT<=[M:ORDK]ENDDAT & [F:ORD1]ENDDAT>=[M:ORDK]ENDDAT))"
    Delete [ORD1] Where evalue(CRITERE) & evalue(CRITERE1)
    If fstat=1 | fstat>5
       GOK=0
       # Purge partielle des prévisions existantes
       Call ECR_TRACE(mess(208,190,1)-[M:ORDK]ITMREF+"/"+[M:ORDK]STOFCY,0) From GESECRAN
    Endif  
Elsif WITM = "" | WITM <> [M:ORDK]ITMREF | WFCY <> [M:ORDK]STOFCY
    # si rupture sur article-site, purge des SOS existantes ...
    Delete [ORD1] Where evalue(CRITERE)
    If fstat=1 | fstat>5
      GOK=0
    Else
      WITM = [M:ORDK]ITMREF
      WFCY = [M:ORDK]STOFCY
    Endif
    # Purge des prévisions existantes
    Call ECR_TRACE(mess(111,190,1)-[M:ORDK]ITMREF+"/"+[M:ORDK]STOFCY,(GOK<>1)) From GESECRAN
Endif 

If GOK>0 & [M:ORDK]EXTQTY>0 : # GH 17/12/2013 bug 94792
   Gosub MAJSOS
Endif

If !GOK     : Goto AB_IMPSOS
Elsif GOK<0 : Goto ROL_IMPSOS
Endif

Commit
Return

######################################################
$MAJSOS
Call NUMERO(GWIP,[M:ORDK]STOFCY,TODAY,"",[M:ORDK]WIPNUM,VS) From SUBANM
If VS <> 0
    OK = 0
    Goto AB_IMPSOS
Endif

[M:ORDK]MAJCOD     = "C"
[M:ORDK]VCRNUM     = [M:ORDK]WIPNUM
Call WIP From TRTWIP
If GOK>0
# FQ 74427 TRTWIP utilise un autre buffer que [F:ORD] (table ouverte en local)
#    WMESSAGE = mess(59,123,1)-mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)-[F:ORD]STOFCY-[F:ORD]ITMREF-
#&                   [F:ORD]WIPNUM-format$(GFMDAT4,[F:ORD]ENDDAT)-num$([F:ORD]RMNEXTQTY)-
    Call ECR_TRACE(mess(59,123,1)-mess([M:ORDK]WIPTYP,341,1)+mess([M:ORDK]WIPSTA,342,1)-[M:ORDK]STOFCY-[M:ORDK]ITMREF-
&                 [M:ORDK]WIPNUM-format$(GFMDAT4,[M:ORDK]ENDDAT)-num$([M:ORDK]EXTQTY)-[F:ITM]STU,0) From GESECRAN
Endif
Return

$ROL_IMPSOS
Rollback
Call ROLL From GLOCK
If !GROLL : Goto MAJSOS : Endif
Return

$AB_IMPSOS
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Abandon suite à erreur de transaction
Return
