#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION - PJMSNPEXT
##########################################################################################################
# Snapshot Extracts
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"          : Gosub INIT_DIA
    When "EXEC"              : Gosub EXEC
  Endcase
Return

##########################################################################################################
# ACTION
##########################################################################################################
$INIT_DIA
  # Init default values in the screen
  If PARAM(1) = AVOID.ACHAR Then
    [M:DIA]ALLCPY = [V]CST_AYES
    [M:DIA]ALLPRJ = [V]CST_AYES
    [M:DIA]ALLSNP = [V]CST_AYES
  Else
    [M:DIA]SNPCOD = PARAM(1)
    [M:DIA]ALLCPY = [V]CST_AYES
    [M:DIA]ALLSNP = [V]CST_AYES
    [M:DIA]SNPCODF = PARAM(1)
    [M:DIA]SNPCODT = PARAM(1)
    [M:DIA]ALLPRJ = [V]CST_AYES
  Endif
  [M:DIA]LCHDPRJ = [V]CST_AYES
  [M:DIA]CLSDPRJ = [V]CST_AYES
  [M:DIA]LOGFILE = [V]CST_AYES
  zonsui = "[M:DIA]LOGFILE"
  Affzo [M:DIA]1-99
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
Return

##########################################################################################################
$EXEC
Local Char CRITERE(250)(10)
Local Integer ICRITERE
Local Integer IRET
Local Integer IRETSTAT
Local Integer RSMEPROC

  #--------------------------------
  Local File PJMSNPH [PSNPH]
  Local File PIMPL [PIM]
  #--------------------------------
  Link [PSNPH] With [PIM]PIM4=[F:PSNPH]OPPNUM
&              As [NEW]
&              Where ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)
&              Order By Key KEY1=[F:PIM]CPY;[F:PIM]OPPNUM
  #--------------------------------
  Raz CRITERE
  ICRITERE = 0
  #-------------------
  #Set Criteria Values
  #-------------------
  CRITERE(ICRITERE) = "1=1"
  If [M:DIA]SNPCODF <> AVOID.ACHAR Then
    ICRITERE += 1
    CRITERE(ICRITERE) -= "and [F:PSNPH]SNPCOD >= [M:DIA]SNPCODF"
  Endif
  If [M:DIA]SNPCODT <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PSNPH]SNPCOD <= [M:DIA]SNPCODT"
  Endif
  If [M:DIA]OPPNUMF <> AVOID.ACHAR Then
    ICRITERE += 1
    CRITERE(ICRITERE) -= "and [F:PSNPH]OPPNUM >= [M:DIA]OPPNUMF"
  Endif
  If [M:DIA]OPPNUMT <> AVOID.ACHAR Then
    CRITERE(ICRITERE) -= "and [F:PSNPH]OPPNUM <= [M:DIA]OPPNUMT"
  Endif
  If [M:DIA]CPY <> AVOID.ACHAR Then
    ICRITERE += 1
    CRITERE(ICRITERE) -= "and [F:PIM]CPY = [M:DIA]CPY"
  Endif
  #--------------------------------
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call OUVRE_TRACE(mess(410,2260,1)) From LECFIC
    Call PRTSCR("PJMSNPEXT", "DIA", "", 0, 1) From ATRTX3
  Endif
  #--------------------------------
  Filter [F:NEW] Where evalue(CRITERE)
  For [NEW]KEY1
    RSMEPROC = [V]CST_AYES
    Call ECR_TRACE(func AFNC.MES1(mess(1023,2260,1), [F:PSNPH]SNPCOD), 0)
    If [M:DIA]LCHDPRJ = [V]CST_AYES or [M:DIA]CLSDPRJ = [V]CST_AYES Then
      IRETSTAT = func PIMPL_CSTD_PROGS.GET_OPPSTATE_VALUE(GACTX, [F:PSNPH]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)
      If GMESSAGE <> AVOID.ACHAR Then
        Call ECR_TRACE(GMESSAGE, 1)
      Else
        If [M:DIA]LCHDPRJ = [V]CST_AYES and IRETSTAT = 1 Then
          GMESSAGE = func AFNC.MES1(mess(38,2260,1), [F:PSNPH]OPPNUM)
          Call ECR_TRACE(GMESSAGE, 0)
          RSMEPROC = [V]CST_ANO
        Elsif [M:DIA]CLSDPRJ = [V]CST_AYES and IRETSTAT = 4 Then
          GMESSAGE = func AFNC.MES1(mess(11,2260,1), [F:PSNPH]OPPNUM)
          Call ECR_TRACE(GMESSAGE, 0)
          RSMEPROC = [V]CST_ANO
        Endif
      Endif
    Endif
    If RSMEPROC = [V]CST_AYES Then
      IRET = func PROCESS_PSNPH_SNPCOD([F:PSNPH]SNPCOD)
    Endif
  Next
  Filter [F:NEW]
  Call ECR_TRACE(string$(50,"-"), 0)
  If !GSERVEUR Then
    If [M:DIA]LOGFILE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

##########################################################################################################
# Screen : SNPX
##########################################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

##########################################################################################################
Subprog AM_SNPCODF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]SNPCODT = AVOID.ACHAR or [M:DIA]SNPCODT < VALEUR Then
    [M:DIA]SNPCODT = VALEUR
    Affzo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog C_ALLSNP(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]SNPCODT
  Else
    Actzo [M:DIA]SNPCODF
    Actzo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog C_ALLPRJ(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]OPPNUMF
    Grizo [M:DIA]OPPNUMT
  Else
    Actzo [M:DIA]OPPNUMF
    Actzo [M:DIA]OPPNUMT
  Endif
  If [M:DIA]SNPCOD <> AVOID.ACHAR Then
    Grizo [M:DIA]ALLCPY
    Grizo [M:DIA]ALLSNP
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]ALLPRJ
    Grizo [M:DIA]SNPCODF
    Grizo [M:DIA]SNPCODT
  Endif
End

##########################################################################################################
Subprog AM_OPPNUMF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]OPPNUMT = AVOID.ACHAR or [M:DIA]OPPNUMT < VALEUR Then
    [M:DIA]OPPNUMT = VALEUR
    Affzo [M:DIA]OPPNUMT
  Endif
End

##########################################################################################################
# Subroutines
##########################################################################################################
$FORCE_LOGFILE
  If [M:DIA]LOGFILE = [V]CST_ANO Then
    # If the log file is not checked : checked by script to have in the log file the project with its errors
    [M:DIA]LOGFILE = [V]CST_AYES
    Call OUVRE_TRACE(mess(410,2260,1)) From LECFIC
    Call PRTSCR("PJMSNPEXT", "DIA", "", 0, 1) From ATRTX3
    Call ECR_TRACE(func AFNC.MES1(mess(1025,2260,1), SSNPCOD), 0)
  Endif
Return

##########################################################################################################
Funprog PROCESS_PSNPH_SNPCOD(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE
Local Integer ISNPSEQ

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMSNPH [PSNPH]
  Read [PSNPH]PSNPH0=SSNPCOD
  If fstat Then
    IARENDRE = [V]CST_AERROR
    GMESSAGE = func AFNC.MES1(mess(1024,2260,1), SSNPCOD)
  Else
    Call ECR_TRACE(func AFNC.MES1(mess(1025,2260,1), SSNPCOD), 0)
    Trbegin [PSNPH]
    IARENDRE = func PROCESS_SNP(SSNPCOD)
    If IARENDRE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
End IARENDRE

##########################################################################################################
Funprog PROCESS_SNP(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE
Local Integer ISNPSEQ
Local Instance TECFINOVE Using C_TECFINOVE

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMSNPH [SNPH]
  # --------------------
  Read [SNPH]PSNPH0=SSNPCOD
  ISNPSEQ = func GET_NEXT_SNPSEQ(SSNPCOD)
  # --------------------
  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  # Populate TECFINOVE with SNPH values
  TECFINOVE.ISBUDUPD = [V]CST_ANO
  TECFINOVE.SHOWGRP  = [F:SNPH]SHOWGRP
  TECFINOVE.SHOWQTY  = [V]CST_AYES
  TECFINOVE.SHOWMNT  = [V]CST_AYES
  TECFINOVE.OPPNUM   = [F:SNPH]OPPNUM
  TECFINOVE.CUR      = [F:SNPH]CUR
  TECFINOVE.UOM      = [F:SNPH]UOM
  TECFINOVE.ADVINCL  = [V]CST_ANO
  TECFINOVE.MULPRJ   = [V]CST_ANO
  TECFINOVE.PBUCOD   = AVOID.ACHAR
  # --------------------
  SKEYEXT = func GET_KEYEXT(SSNPCOD, ISNPSEQ)
  IARENDRE = func PJMRPTEXT.COMPUTE_TECFINOVE(TECFINOVE, SKEYEXT)
  If IARENDRE = [V]CST_AOK Then
    IARENDRE = func SAVE_PJMSNPD(SSNPCOD, ISNPSEQ, SKEYEXT)
  Else
    Gosub FORCE_LOGFILE
    Call MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG(TECFINOVE, -1, -1) From SYRSTACKTOOLS
  Endif
  # --------------------
  FreeGroup TECFINOVE
End IARENDRE

##########################################################################################################
Funprog GET_NEXT_SNPSEQ(SSNPCOD)
Value Char SSNPCOD

Local Integer IARENDRE

  IARENDRE = 10
  Local File PJMSNPD [PSNPD]
  Filter [PSNPD] Where [F:PSNPD]SNPCOD = SSNPCOD Order By Key KEY0=SNPCOD;SNPSEQ Desc
  Read [PSNPD]First
  If !fstat Then
    IARENDRE = [F:PSNPD]SNPSEQ + 10
  Endif
  Filter [PSNPD]
End IARENDRE

##########################################################################################################
Funprog GET_KEYEXT(SSNPCOD, ISNPSEQ)
Value Char SSNPCOD
Value Integer ISNPSEQ

Local Char SARENDRE(GLONVCR)

  SARENDRE = "SNP" + SSNPCOD + "~" + num$(ISNPSEQ)
End SARENDRE

##########################################################################################################
Funprog SAVE_PJMSNPD(SSNPCOD, ISNPSEQ, SKEYEXT)
Value Char    SSNPCOD
Value Integer ISNPSEQ
Value Char    SKEYEXT

Local Integer IARENDRE
Local Char WRKDESC(60)

  IARENDRE = [V]CST_AOK
  # --------------------
  Local File PJMSNPD [PSNPD]
  # --------------------
  Raz [PSNPD]
  [F:PSNPD]SNPCOD = SSNPCOD
  [F:PSNPD]SNPSEQ = ISNPSEQ
  [F:PSNPD]SNPDDTECRE = date$
  [F:PSNPD]KEYEXT = SKEYEXT
  Write [PSNPD]
  If fstat Then
    IARENDRE = [V]CST_AERROR
    Gosub FORCE_LOGFILE
    Call ECR_TRACE(mess(1021,2260,1), 1)
  Endif
  If IARENDRE = [V]CST_AOK Then
    WRKDESC = func AFNC.MES1(mess(1022,2260,1), format$(GFMDAT,[F:PSNPD]SNPDDTECRE))
    # Issue X3-15630 - 2018-03-05 by FGR : BEGIN
    #Call MAJTEXTRA(WRKDESC, "PJMSNPD", "DDESAXX", [F:SNPH]SNPCOD, num$([F:PSNPD]SNPSEQ)) From ATEXTRA
    Call MAJTEXTRA(WRKDESC, "PJMSNPD", "DDESAXX", [F:PSNPD]KEYEXT, "") From ATEXTRA
    # Issue X3-15630 - 2018-03-05 by FGR : END
  Endif
End IARENDRE

##########################################################################################################
Subprog ECR_TRACE(TEX, ERR)
Value Char    TEX() : # Texte du message
Value Integer ERR

  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call ECR_TRACE(TEX, ERR) From GESECRAN
  Endif
End

