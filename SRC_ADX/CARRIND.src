#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

# Gestion du masque CARRNOF
# Création
#     MABON - 13/05/11 - EXI 66382 LOT 1
#              - Arrêté de notes de frais
######################################################################################

$ACTION

  Case ACTION
    When "INIT"   : Gosub INIT
    When "CONTROLE"   : Gosub CONTROLE
    When "BOUTON"     : Gosub BOUTON
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
  Endcase
Return

#**#####################################################################################
#*
#*!
$INIT

  # Ouverture des tables utilisées
  If clalev([F:FCY])=0    : Local File FACILITY      [FCY]    : Endif
  If clalev([F:CPY])=0    : Local File COMPANY       [CPY]    : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA        [HRPOA]  : Endif
  If clalev([F:PAI])=0    : Local File PARIND        [PAI]    : Endif
  #ADNGO - 2017-05-20 - START
  #** V7 : Waiting Time Mangement **#
  #**If clalev([F:HRPEO])=0  : Local File HRPERIOD      [HRPEO]  : Endif
  #**
  If clalev([F:HRPEOD])=0  : Local File HRPEODET      [HRPEOD]  : Endif
  #ADNGO - 2017-05-20 - END
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR      [HRCTR]  : Endif
  If clalev([F:ID])=0     : Local File EMPLOID       [ID]     : Endif
  If clalev([F:AD])=0     : Local File EMPLOAD       [AD]     : Endif
  If clalev([F:CPT])=0    : Local File EMPLOCPT      [CPT]    : Endif
  If clalev([F:RIB])=0    : Local File EMPLORIB      [RIB]    : Endif
  If clalev([F:MED])=0    : Local File EMPLOMED      [MED]    : Endif
  If GPAYE
    If clalev([F:HRPPH])=0: Local File PPREQUESTH  [HRPPH]: Endif
    If clalev([F:HRPPD])=0: Local File PPREQUESTD  [HRPPD]: Endif
    If clalev([F:VEP])=0  : Local File VALEMP      [VEP]  : Endif
    If clalev([F:VEP2])=0 : Local File VALEMP      [VEP2] : Endif
    If clalev([F:PVI])=0  : Local File PARVARIND   [PVI]  : Endif
  Endif

#81085
Local Mask CARRIND [DIA]
Local Mask LISIND [LIND]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","hrapi") From GMEMO
Call AFF_MEMO From DIVPAYE
#
  If GFONCTION="GESPAI" Then
    Call CALC_CFY([F:PAI]REFNUM, [F:PAI]CTRNUM, [F:PAI]DAT, [M:DIA]FCY, [M:DIA]CPY) From TOOLSVAR
    If [M:DIA]CPY<>"" Then [M:DIA]ALLCPY=1 : Endif
    If [M:DIA]FCY<>"" Then [M:DIA]ALLFCY=1 : Endif

    Filter [F:HRCTR] Where REFNUM=[F:PAI]REFNUM & CTRNUM=[F:PAI]CTRNUM Order By CTRDAT Desc
    Read [F:HRCTR] First
    Filter [F:HRCTR]

    [M:DIA]CTRNUMSTR = [F:PAI]CTRNUM
    [M:DIA]CTRNUMEND = [F:PAI]CTRNUM

    [M:DIA]MATSTR    = [F:PAI]REFNUM
    [M:DIA]MATEND    = [F:PAI]REFNUM

    If [F:HRCTR]PROPRF<>"" Then
      [M:DIA]ALLPRF    = 1
      [M:DIA]PRF       = [F:HRCTR]PROPRF
    Endif

    If [F:HRCTR]ETRSRV<>"" Then
      [M:DIA]ALLSRV    = 1
      [M:DIA]SRV       = [F:HRCTR]ETRSRV
    Endif

    [M:DIA]NUMPARSTR = [F:PAI]NUMPAR
    [M:DIA]NUMPAREND = [F:PAI]NUMPAR

    If [F:HRCTR]CLLCVT<>"" Then
      [M:DIA]ALLCLLCVT = 1
      [M:DIA]CLLCVT    = [F:HRCTR]CLLCVT
    Endif

    [M:DIA]CODFDS    = [F:PAI]CODFDS
    [M:DIA]EXO       = [F:PAI]EXO
  Endif

  # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#  [M:DIA]DAT = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  If func DIVPAYE.INIPARUSR("DATPAY","","")<>[0/0/0] Then
    [M:DIA]DAT    = gdat$(1,month(func DIVPAYE.INIPARUSR("DATPAY","","")),year(func DIVPAYE.INIPARUSR("DATPAY","","")))
  Endif
#  [M:DIA]DATEND = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  # Fin MABON
Return

#####################################
$CONTROLE

  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif
Return

#**
#* Boutons "Tout cocher" et "Tout décocher"
#*!
$BOUTON

  Case BOUT
    When "C" : For I=0 To [M:LIND]NBPAI-1 : [M:LIND]SELFLG(I)=2 : Next
    When "D" : For I=0 To [M:LIND]NBPAI-1 : [M:LIND]SELFLG(I)=1 : Next
    #81085
    When "R" :
     # Button "Rappel MEMO"
     Call AFF_MEMO From DIVPAYE
     If [M:DIA]ALLCLLCVT=1 : Actzo [M:DIA]CLLCVT : Else : Diszo [M:DIA]CLLCVT : Endif
  Endcase
  Affzo [M:LIND]
Return

#**
#* Calcul des critères de sélection
#*!
$CALC_CRIT
Local Integer ONE_CRIT, I
Local Char    LIS_CPY(GLONCPY)(0..100)

  CRITAUT="1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITAUT -= "& find(WCPY,"
      For K=0 To I-1
        CRITAUT += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITAUT += "," : Endif
      Next
      CRITAUT += ")>0"
    Endif
  Endif
  If [M:DIA]ALLFCY<>2       Then CRITAUT  -= "& WFCY='"+[M:DIA]FCY+"'"                    : Endif
  If [M:DIA]POP<>""         Then CRITAUT  -= "& [F:HRPOA]COD='"+[M:DIA]POP+"'"              : Endif
  If [M:DIA]ALLSRV<>2       Then CRITAUT  -= "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"           : Endif
  If [M:DIA]ALLPRF<>2       Then CRITAUT  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"           : Endif
  If [M:DIA]CLLCVT<>""      Then CRITAUT  -= "& [F:HRCTR]CLLCVT='"+[M:DIA]CLLCVT+"'"        : Endif

  # La participation ne doit pas avoir été déjà transférée + elle doit avoir le statut Validée ou Soldée
  CRITERE1 = "[F:PAI]TRFREQ<>2 & [F:PAI]STA>1"
  If [M:DIA]MATSTR<>""      Then CRITERE1 -= "& [F:PAI]REFNUM>='"+[M:DIA]MATSTR+"'"       : Endif
  If [M:DIA]MATEND<>""      Then CRITERE1 -= "& [F:PAI]REFNUM<='"+[M:DIA]MATEND+"'"       : Endif
  If [M:DIA]CTRNUMSTR<>""   Then CRITERE1 -= "& [F:PAI]CTRNUM>='"+[M:DIA]CTRNUMSTR+"'"    : Endif
  If [M:DIA]CTRNUMEND<>""   Then CRITERE1 -= "& [F:PAI]CTRNUM<='"+[M:DIA]CTRNUMEND+"'"    : Endif

  CRITERE2 = "1=1"
  If [M:DIA]NUMPARSTR<>""   Then CRITERE2 -= "& [F:PAI]NUMPAR>='"+[M:DIA]NUMPARSTR+"'"    : Endif
  If [M:DIA]NUMPAREND<>""   Then CRITERE2 -= "& [F:PAI]NUMPAR<='"+[M:DIA]NUMPAREND+"'"    : Endif
  If [M:DIA]CODFDS<>""      Then CRITERE2 -= "& [F:PAI]CODFDS='"+[M:DIA]CODFDS+"'"        : Endif
  If [M:DIA]EXO<>""         Then CRITERE2 -= "& [F:PAI]EXO='"+[M:DIA]EXO+"'"              : Endif
Return

#**
#* Affichage de la fenêtre de sélection des notes de frais
#*!
$DEBUT
Local Char    CRITERE1(250), CRITERE2(250), CRITAUT(250), MESST(250)
Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY)
Local Integer I, OKPAY

  Gosub CALC_CRIT
  Filter [F:PAI] Where evalue(CRITERE1) & evalue(CRITERE2) Order By [F:PAI]REFNUM;[F:PAI]CTRNUM;[F:PAI]EXO
  nolign=1 : Raz [M:LIND]
  For [F:PAI]
    # Détermination des données relatives au matricule de l'inscription, afin d'évaluer CRITAUT
    Call CALC_CFY([F:PAI]REFNUM, [F:PAI]CTRNUM, [F:PAI]DAT, WFCY, WCPY) From TOOLSVAR
    # Lecture de la population pour alimenter [F:HRPOA] utilisé dans CRITAUT
    If [M:DIA]POP<>"" Then
      Read [F:HRPOA]POA0=[M:DIA]POP;[F:PAI]REFNUM
      If fstat Then Raz [F:HRPOA] : Endif
    Endif
    # Lecture du contrat pour alimenter [F:HRCTR] utilisé dans CRITAUT
    Filter [F:HRCTR] Where REFNUM=[F:PAI]REFNUM & CTRNUM=[F:PAI]CTRNUM Order By CTRDAT Desc
    Read [F:HRCTR] First
    If fstat Then Raz [F:HRCTR] : Endif
    Filter [F:HRCTR]

    OKPAY=1
    If [M:DIA]CRI<>"" Then
      # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [M:DIA]CRI
      Read [F:ID]ID0=[F:PAI]REFNUM
      Read [F:AD]AD0=[F:PAI]REFNUM
      Read [F:CPT]CPT0=[F:PAI]REFNUM
      Filter [F:RIB] Where REFNUM=[F:PAI]REFNUM
      Read [F:RIB] Last
      Filter [F:RIB]
      Filter [F:MED] Where REFNUM=[F:PAI]REFNUM
      Read [F:MED] Last
      Filter [F:MED]
      Call CONTROLE([F:PAI]REFNUM,[F:HRCTR]CTRDAT,[F:PAI]CTRNUM,[M:DIA]CRI,OKPAY,0) From DIVPAYE
    Endif
    If OKPAY & evalue(CRITAUT)>0 Then
      If nolign-1<dim([M:LIND]SELFLG) Then
        [M:LIND]SELFLG(nolign-1)    = 2
        [M:LIND]CPY(nolign-1)       = [F:PAI]CPY
        [M:LIND]REFNUM(nolign-1)    = [F:PAI]REFNUM
#segay 06/09/11 75536
        Read [F:ID]ID0=[F:PAI]REFNUM
        [M:LIND]NAM(nolign-1)    = [F:ID]NAM-[F:ID]SRN
#END 06/09/11 75536
        [M:LIND]CTRNUM(nolign-1)    = [F:PAI]CTRNUM
        [M:LIND]EXO(nolign-1)       = [F:PAI]EXO
        [M:LIND]NUMPAR(nolign-1)    = [F:PAI]NUMPAR
        [M:LIND]CODFDS(nolign-1)    = [F:PAI]CODFDS
        [M:LIND]AMTGRO(nolign-1)    = [F:PAI]AMTGRO
        [M:LIND]AMTNET(nolign-1)    = [F:PAI]AMTNET
        [M:LIND]AMTNEW(nolign-1)    = [F:PAI]AMTNEW
        [M:LIND]AMTUNL(nolign-1)    = [F:PAI]AMTUNL
        [M:LIND]DAT(nolign-1)       = [F:PAI]DAT
        [M:LIND]DATAVAINI(nolign-1) = [F:PAI]DATAVAINI

        nolign += 1
      Else
        MESST = mess(54,126,1)-":"-num$(dim([M:LIND]SELFLG)) : # Nombre de lignes maximum dépassé
        MESST += chr$(10)+mess(410,197,1)                    : # Vous pouvez affiner vos critères
        Infbox MESST
        Break
      Endif
    Endif
  Next
  Filter [F:PAI]
  [M:LIND]NBPAI=nolign-1
  Affzo [M:LIND]
#81085
Affzo [DIA]
Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE
Return

#**#####################################################################################
#* Exécution de l'action
#*!
$OK
Local  Char    CODPVI
Local  Integer LOK, NBENREG_IND
Local  Integer ILIG
Local  Char    REF_ENC(GLONEML)
Global Char    KEYFRT(40)(0..1000), CODCOT

  If !find(2, [M:LIND]SELFLG) Then
    Infbox mess(23,10706,1) : # Aucune participation à traiter
    Return
  Endif

  If [M:DIA]SIMUL=1 Then
    Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
    If LOK = 1 Then Return : Endif
  Endif

  TIT=mess(24,10706,1) : # Arrêté de participation
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If [M:DIA]SIMUL=2 Then
    Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
    Call ECR_TRACE("------------------------------------",0) From GESECRAN
  Endif

  # Récupération du code liste à utiliser pour le bordereau de participation
  Call PARAM(GCURLEG, "CODPVI", CODPVI) From ADOVAL

  If [M:LIND]NBPAI>0 and find(2, [M:LIND]SELFLG)>0 Then
    GOK=1
    If GPAYE Then
      Trbegin [F:HRPPH], [F:HRPPD], [F:PAI]
    Endif
    For nolign=1 To [M:LIND]NBPAI
      If [M:LIND]SELFLG(nolign-1)=2 Then
        ILIG = nolign-1
        # Relecture des enregistrements relatifs à la ligne en cours
        Read [F:PAI]PAI0=[M:LIND]CPY(ILIG);[M:LIND]REFNUM(ILIG);[M:LIND]CTRNUM(ILIG);[M:LIND]NUMPAR(ILIG);[M:LIND]CODFDS(ILIG)

        Gosub MAJ_IND : If GOK=0 Then Break : Endif
      Endif
    Next

    If GOK Then
      If [M:DIA]SIMUL=1 Then
        Commit
      Else
        Rollback
      Endif
    Else
      Rollback
    Endif
  Endif

  # Gestion de la trace
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If NBENREG_IND>0 Then
    Call ECR_TRACE(mess(25,10706,1)-":"-num$(NBENREG_IND),0) From GESECRAN : # Nombre de participations mises à jour
  Else
    Call ECR_TRACE(mess(23,10706,1),0) From GESECRAN : # Aucune participation à traiter
  Endif
  Call FERME_TRACE From LECFIC
  # FQ72152 - MABON 08/03/11 - Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
  Call LEC_TRACE From LECFIC
  GMESSAGE=""
Return

#**
#* Création des bordereaux
#*!
$MAJ_IND
Local Integer NBD, AUZCFY
Local Char    WREQNUM
Local Char    DESREQ(255), CRITERE(250)

  GOK=1

  Filter [F:HRCTR] Where REFNUM=[F:PAI]REFNUM & CTRNUM=[F:PAI]CTRNUM Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
  AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "CARRIND")

  If AUZCFY=2 Then
    # On cherche si le bordereau existe déjà, et on crée un nouveau bordereau s'il n'existe pas encore
    CRITERE="REF_ENC<>[F:PAI]REFNUM"
    DESREQ  = mess(24,10706,1) : # Arrêté participation
    # Création du borderau et de ses lignes
    # Le manager est en fait le REFNUM du user qui saisit l'arrêté de formation (donc variable globale GREFNUM
    # en paramètre de CRE_REQ)
    If clalev([F:TBD])=0 : Local File ATABZON [TBD] : Endif
    Filter [F:TBD] Where CODFIC="PARIND" & (CODTYP='MD2' or CODTYP='DCB')
    # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#    Call CRE_REQ(GREFNUM, CODPVI, [M:DIA]DAT, evalue(CRITERE), WFCY, 0, DESREQ, [F:PAI]REFNUM, [F:PAI]CTRNUM, "CARRIND", NBD, WREQNUM) From TOOLSVAR
    Call CRE_REQ(GREFNUM, CODPVI, [M:DIA]DAT, [M:DIA]DATEND, evalue(CRITERE), WFCY, 0, DESREQ, [F:PAI]REFNUM, [F:PAI]CTRNUM, "CARRIND", NBD, WREQNUM) From TOOLSVAR
    # Fin MABON
    Filter [F:TBD]
    REF_ENC=[F:PAI]REFNUM

    If GOK & NBD>0 Then
      [F:PAI]TRFREQ=2
      If WREQNUM<>"" Then [F:PAI]REQNUM=WREQNUM : Endif
      If [M:DIA]SIMUL=1 Then
        Rewrite [F:PAI]
      Endif
      If fstat Then
        GOK=0 : Call FSTA("PAI") From GLOCK
      Else
        NBENREG_IND += 1
        If WREQNUM<>"" Then
          # xxx : Bordereau préparatoire xxx xx/xx/xx
          # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#          Call ECR_TRACE([F:PAI]REFNUM-":"-mess(193,10702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT),0) From GESECRAN
          Call ECR_TRACE([F:PAI]REFNUM-":"-mess(193,10702,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)-format$("D:"+GFMDAT,[M:DIA]DATEND),0) From GESECRAN
          # Fin MABON
        Endif
      Endif
    Endif
  Endif
Return

#**
#* Surcharge de l'étiquette FIND_REQ appelée par CRE_REQ de TOOLSVAR
#*!
$FIND_REQ

  Call FIND_REQNUM([F:PAI]REFNUM, WREQNUM) From TOOLSVAR
Return

#**
#* Surcharge de l'étiquette CALC_VRA appelée par CRE_REQ de TOOLSVAR
#*!
$CALC_VRA
Local Char    ELTAMT, CODFDS, CODREP, CODCOT
Local Integer IKEY, OKCOT

  ELTAMT=[F:TBD]CODZONE : CODFDS=[F:PAI]CODFDS : CODREP=[F:PAI]CODREP
  OKCOT=1
  If instr(1,ELTAMT,"COT")=0 Then
    CODCOT=""
    OKCOT=2
  Else
    CODCOT=[F:PAI]CODCOT(ICOT)
    If CODCOT<>"" Then OKCOT=2 : Endif
  Endif
  If OKCOT=2 Then
    Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;6;"";"";"";"";"";[F:PAI]CTRNUM;"";"";""             : # Niveau Contrat
    If fstat Then
      Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;5;"";"";"";"";[F:PAI]REFNUM;"";"";"";""           : # Niveau Salarié
      If fstat Then
        Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;9;"";"";"";"";"";"";"";"";[F:HRCTR]PROPRF         : # Niveau Profil
        If fstat Then
          Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;7;"";"";"";"";"";"";[F:HRCTR]ETRSRV;"";""       : # Niveau Service
          If fstat Then
            Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;8;"";"";"";"";"";"";"";[F:HRCTR]CLLCVT;""     : # Niveau Convention collective
            If fstat Then
              Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;4;"";"";"";[F:HRCTR]ETRFCY;"";"";"";"";""   : # Niveau Site
              If fstat Then
                Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;3;"";"";[F:FCY]LEGCPY;"";"";"";"";"";"" : # Niveau Société
                If fstat Then
                  Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;2;"";[M:DIA]POP;"";"";"";"";"";"";""  : # Niveau Population
                  If fstat Then
                    Read [F:PVI]PVI0=ELTAMT;CODFDS;CODREP;CODCOT;1;nomap;"";"";"";"";"";"";"";""     : # Niveau Dossier
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    # Fin MABON

    If !fstat Then
      WVRACOD=[F:PVI]VRACOD
    Else
      WVRACOD=""
      If !find([F:PAI]NUMPAR+"~"+[F:TBD]CODZONE, KEYFRT) Then
        # Répartition n° / Montant : Correspondance Montant / Variable non définie
        Call ECR_TRACE(mess(16,10706,1)-num$([F:PAI]NUMPAR)-"/"-[F:TBD]CODZONE-":"-mess(26,10706,1),0) From GESECRAN
        IKEY=find("",KEYFRT)
        KEYFRT(IKEY-1)=[F:PAI]NUMPAR+"~"+[F:TBD]CODZONE
      Endif
    Endif
  Endif
  fstat=0
Return

#**
#* Surcharge de l'étiquette CALC_AMT appelée par CRE_REQ de TOOLSVAR
#*!
$CALC_AMT

  If instr(1,[F:TBD]CODZONE,"COT")=0 Then
    ACPAMT = evalue("[F:PAI]"+[F:TBD]CODZONE)
  Else
    ACPAMT = evalue("[F:PAI]"+[F:TBD]CODZONE+"("+num$(ICOT)+")")
  Endif
Return

#**
#* Surcharge de l'étiquette CALC_CTRDAT appelée par CRE_REQ de TOOLSVAR
#*!
$CAL_CTRDAT

  WCTRDAT=func TPSSTD.CALC_CTRDATDEF([F:PAI]REFNUM,[F:PAI]CTRNUM,[M:DIA]DATEND,[M:DIA]DATEND,[F:PAI]DAT,1)
Return

#**
#* On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
#* en réel après l'avoir lancé en simulation)
#*!
$EXEC

  SAI=1
Return

$FIN

  If dim(KEYFRT)>0 Then Kill KEYFRT : Endif
  If dim(CODCOT)>0 Then Kill CODCOT : Endif
Return

########################################################################################
#                       GESTION DE L'ECRAN
########################################################################################

Subprog AV_ALLCPY(VALEUR)
Variable Integer VALEUR

  Call AV_ALLCPY(VALEUR) From TOOLSVAR
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR

  Call AS_ALLCPY(VALEUR) From TOOLSVAR
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

  Call C_ALLCPY(VALEUR) From TOOLSVAR
End

Subprog AV_ALLSRV(VALEUR)
Variable Integer VALEUR

  Call AV_ALLSRV(VALEUR) From TOOLSVAR
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR

  Call C_ALLSRV(VALEUR) From TOOLSVAR
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR

  Call AS_SRV(VALEUR) From TOOLSVAR
End

Subprog AV_ALLPRF(VALEUR)
Variable Integer VALEUR

