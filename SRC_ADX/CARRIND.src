  Call C_CTRNUMEND(VALEUR) From TOOLSVAR
End

Subprog C_NUMPARSTR(VALEUR)
Variable Char    VALEUR()

  # On ne peut pas passer par l'action de contrôle CONTOBJW car celle-ci vérifie que le champ est renseigné
  # Du coup, cela empêche de saisir des valeurs vides dans les champs NUMPARSTR et NUMPAREND, ce qui n'est pas ce qu'on souhaite
  If VALEUR<>"" Then
    If clalev([F:PAC])=0 : Local File PARCOL [PAC] : Endif
    Read [F:PAC]PAC0=VALEUR
    If fstat Then mkstat=1 : Endif
  Endif
End

Subprog C_NUMPAREND(VALEUR)
Variable Char    VALEUR()

  # On ne peut pas passer par l'action de contrôle CONTOBJW car celle-ci vérifie que le champ est renseigné
  # Du coup, cela empêche de saisir des valeurs vides dans les champs NUMPARSTR et NUMPAREND, ce qui n'est pas ce qu'on souhaite
  If VALEUR<>"" Then
    If clalev([F:PAC])=0 : Local File PARCOL [PAC] : Endif
    Read [F:PAC]PAC0=VALEUR
    If fstat Then mkstat=1 : End : Endif
  Endif

  Call CTLALPV(VALEUR, [M:DIA]NUMPARSTR) From CONTDIV
End

#**
#* La date d'application doit être une date d'extraction
#*
#* @param VALEUR
#*!
Subprog C_DAT(VALEUR)
Variable Date    VALEUR

#  Call C_DAT(VALEUR) From TOOLSVAR
  If VALEUR<>[0/0/0] Then
    VALEUR=gdat$(1,month(VALEUR),year(VALEUR))
  Endif
End

