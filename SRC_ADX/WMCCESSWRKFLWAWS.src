For AINDCLA=1 To maxtab(this.ESSWRKEMP)
 If this.ESSWRKEMP(AINDCLA)<>null& find(this.ESSWRKEMP(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKEMP(AINDCLA)._AMANDATORY : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKSA)
 If this.ESSWRKSA(AINDCLA)<>null& find(this.ESSWRKSA(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKSA(AINDCLA)._AMANDATORY : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKCHD)
 If this.ESSWRKCHD(AINDCLA)<>null& find(this.ESSWRKCHD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESSWRKCHD(AINDCLA)._AMANDATORY : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Return

