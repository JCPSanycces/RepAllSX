#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("TRL",GBIDC1,GBIDC2) From GOBJET
End
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTTRL","TRTTRL",4,"TRTTRL") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SORTIE"    : Gosub SORTIE
 When "DEBUT"     : Gosub DEBUT
 When "BOUTON"    : Gosub BOUTON From EXTRTRL :#81085
Endcase
Return

###################################
$INIT
If clalev([F:TRH])=0 : Local File TIKRESHEA [TRH] : Endif
If clalev([F:TRL])=0 : Local File TIKRESLIG [TRL] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:FEH])=0 : Local File FILEDIH   [FEH] : Endif
If clalev([F:FEL])=0 : Local File FILEDIL   [FEL] : Endif
If clalev([F:TRH2])=0 : Local File TIKRESHEA [TRH2] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY   [CPY2] : Endif
Local Char SYMBOLE(30)
Local Char CRITTRH (250)
Local Mask GENTRL [DIA]

#83271
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG="FRA"
Raz [M:DIA]
If dim([M:DIA]LEG)>0 : [M:DIA]LEG=GCURLEG : Endif
#81085
Call LECMEMO("STD","[M:DIA]","trh2") From GMEMO
Call AFF_MEMO From DIVPAYE
If GFONCTION="GESTRL" & dim([M:TRL0]NUMTRE)>=0
 Raz [M:DIA]DATFRMD, DATFRMF
 [M:DIA]NUMSTR=[M:TRL0]NUMTRE
 [M:DIA]NUMEND=[M:TRL0]NUMTRE
 [M:DIA]DATSTR=[M:TRL0]DATTRE
 [M:DIA]DATEND=[M:TRL0]DATTRE
 [M:DIA]ALLCPY=1
 [M:DIA]CPY=[M:TRL0]CPY
Endif

Return

######################################################
#81085
$DEBUT
 Affzo [DIA]
 Setmok [DIA] With 0
 Call AFF_MEMO From DIVPAYE
Return

##################################
#83271
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP=1
 TRA=1
Endif
Return

###################################
$EXEC
# Génération de commande de TR
[L]TIT=mess(202,10703,1)

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  Link [TRL] With
&    [TRH]TRH0   = [F:TRL]NUMTRE
&,   [CPY]CPY0   = [F:TRL]CPY
&,   [FCY]FCY0   = [F:TRL]FCY
&    As [LNK]

CRITTRH = '[F:TRH2]FLGTRE<>2'
If [M:DIA]DATSTR<>[0/0/0]
 CRITTRH -= '& [F:TRH2]DATTRE>=['+format$(GFMD,[M:DIA]DATSTR)+']'
 CRITTRH -= '& [F:TRH2]DATTRE<=['+format$(GFMD,[M:DIA]DATEND)+']'
Endif
If [M:DIA]NUMSTR<>""
 CRITTRH -= '& [F:TRH2]NUMTRE>="'+[M:DIA]NUMSTR+'"'
 CRITTRH -= '& [F:TRH2]NUMTRE<="'+[M:DIA]NUMEND+'"'
Endif
If [M:DIA]ALLCPY<>2  : CRITTRH -= '& [F:TRH2]CPY="'+[M:DIA]CPY+'"'        : Endif

OK = 1
For [TRH2]TRH0 Where evalue (CRITTRH)
 [L]SYMBOLE="TRH"+[F:TRH2]NUMTRE
 Lock =[L]SYMBOLE
 If fstat
  Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
  Call ECR_TRACE([F:TRH2]NUMTRE+"\"+GMESSAGE,1) From GESECRAN
  Raz GMESSAGE
  OK = 0
 Endif
Next

If !OK
 Call DELOCK("TRH") From GLOCK
 If !TRA : GERR=1 : SAI=1 : Endif
 Return
Endif

Call EMISSION([L]TRA,CRITTRH)
Return

################################################################################
#
# Routines
#
################################################################################

Subprog EMISSION(TRA, P_CRITTRH)
Variable Integer TRA
Value Char P_CRITTRH ()

Local Integer STAT, NBERR, I, NBLIG, TOTTRE, ER
Local Char    FEH(GLONADI), FICHIER (GDIMFIC), FICCLI(GDIMFIC) , URL(GDIMFIC)
Local Char    FILENAM (GDIMFIC)

[L]FEH="TRL"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
Gosub DEFVAR

[L]EMISSION=1

Call DEBTRANS From GLOCK

$TR_EMISSION
[V]GOK=1
Trbegin [TRL],[TRH2]
 Gosub ECRITURE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN : Else Goto TR_EMISSION : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN
 Endif
Commit

#-------------------------------------------------------------------------------
$FIN
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM
End

#-------------------------------------------------------------------------------
$DEFVAR
Local Char    DATFMT(8), SAVIRS(2), SAVIFS(1)
Local Libelle SAVIUM

[L]DATFMT  ="DDMMYYYY"
[L]SAVIRS  =adxirs
[L]SAVIFS  =adxifs
[L]SAVIUM  =adxium
adxirs     =chr$(13)+chr$(10)
adxifs     =""
adxium     =[V]GASCII
Return

#-------------------------------------------------------------------------------
$ECRITURE
Columns [FEH] (LOC,LNG,ZON,TYP)
For [TRH2]TRH0 Where evalue(P_CRITTRH)
 Read[F:CPY2]CPY0=[F:TRH2]CPY
 If !fstat & [F:CPY2]TRECPY<>""
  # Construction des nom de fichier si n génération
  # Commande :
  Call ECR_TRACE(mess(98,197,1)-":"-[F:TRH2]NUMTRE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  If [M:DIA]FILNAM<>"" & [M:DIA]TYPEXP=2
    FICHIER=[M:DIA]FILNAM
  Else
   Gosub TRNO
   If ER
    #Erreur Nom de fichier
    Call ECR_TRACE(mess(6,10719,1),1) From GESECRAN
    Break
   Endif
   FICHIER=[F:TRH2]TRECPY+'_'+num$(year([F:TRH2]DATTRE))+num$(month([F:TRH2]DATTRE))+'_'+num$([C]NUMFIL(2))
  Endif
  If [M:DIA]TYPEXP=2
   #92896 - US2135
   FICHIER=filpath([V]GDIRBQR,FICHIER,"txt",0)
  Else
   FICCLI=FICHIER+'.txt'
   FILENAM=FICCLI
   Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]URL) From ORDSYS
  Endif
  Openo FICHIER, 0 Using [OPO]
  #
  Raz NBLIG, TOTTRE
  #83271 : Ajout de la legislation
  Filter[F:LNK] Where NUMTRE=[F:TRH2]NUMTRE & [F:CPY]LEG=GCURLEG Order By Key CLE=[CPY]CPYNAM;[FCY]FCYNAM;[TRL]NAMSRN
  For [F:LNK]CLE
   If [F:TRL]NBRTRE>0 :#80519
     Gosub EMISSION From =[L]FEHTRT
     Call ECR_TRACE([F:TRL]REFNUM-[F:TRL]NAMSRN-num$([F:TRL]NBRTRE),0) From GESECRAN
     [L]NBERR=0
     Onerrgo ERREURWW
     Gosub CONTROLE From =[L]FEHTRT
     Onerrgo
     If ![L]NBERR
      I=adxseek("OPO")
      For [FEH]FEH0 Where FEH=[L]FEH
       If [F:FEH]ZON=""
        Case [F:FEH]TYP
         When 3
          Wrseq string$([F:FEH]LNG,"0"); Using [OPO]
         When Default
          Wrseq space$([F:FEH]LNG); Using [OPO]
        Endcase
       Else
        If [F:FEH]ZON="NBRTRE"
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
         TOTTRE+=evalue("[L]"+[F:FEH]ZON)
         Elsif [F:FEH]ZON="VALTRE"
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)*100); Using [OPO]
        Else
         Case evalue("type([L]"+[F:FEH]ZON+")")
          When 1,2,4,5,6,7,8,9
           Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
          When 3
           Wrseq format$("D:"+[L]DATFMT,evalue("[L]"+[F:FEH]ZON)); Using [OPO]
          When Default
           Wrseq left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG); Using [OPO]
          Endcase
          Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
        Endif
       Endif
      Next
      Wrseq Using [OPO]
      Gosub MAJFIC From =[L]FEHTRT
      NBLIG+=1
      ##**82073
      Call MAJPRV([F:TRL]REFNUM,[F:TRL]DATTRE,[F:TRL]NBRTRE,[F:TRL]NUMTRE,[F:TRL]CTRNUM,[F:TRL]CTRDAT,time$)
     Else
      #Ligne de commande incorrecte
      Call ECR_TRACE(mess(6,10719,1),1) From GESECRAN
      NBLIG=0 : Break
     Endif
   #80519
   Else
    Call ECR_TRACE([F:TRL]REFNUM-[F:TRL]NAMSRN-num$([F:TRL]NBRTRE),-1) From GESECRAN
   Endif
   #
  Next
  Filter[F:LNK]
  Openo Using [OPO]
  If NBLIG
   [F:TRH2]FLGTRE=2 : # Commandé
   Rewrite [TRH2]
   If fstat
    GOK=0 : Call FSTA("TRH") From GLOCK
    Break
   Endif
   If [M:DIA]FLGWRK=2
    GWRK = FICHIER
    GBIDC1=[F:TRH2]TRECPY
    GBIDI1=TOTTRE
    Call WORKFLOW(1,"EDI","","") From AWRK
    Call ECR_TRACE(mess(205,10703,1),0) From GESECRAN : # Fichier envoyé par le workflow
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   Endif
   Call ECR_TRACE("",0) From GESECRAN
   If [M:DIA]TYPEXP<2
    # Init nom du fichier
    FICCLI=FILENAM
    Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
    If [L]STAT<>0 : [L]TRA = 0 : GOK=0 : Break : Endif
    #Fichier généré xxxxx (Astuce du "|" pour ne pas écrire de retour charriot dans le chemin)
    Call ECR_TRACE("|"+mess(104,121,1)-FICCLI,0) From GESECRAN
   Else
    #Fichier généré xxxxx
    Call ECR_TRACE(mess(104,121,1)-FICHIER,0) From GESECRAN
   Endif
   #
  Endif
 Endif
Next
Columns [FEH]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Openo Using [OPO]
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Goto FIN


###################################
$SEL_TABLE
OBJET="TRL"
SUPP="1"
CRITERE='FLGTRE<>2 & DATTRE>=['+format$(GFMD,[M:DIA]DATSTR)+'] & DATTRE<=['+format$(GFMD,[M:DIA]DATEND)+']'
If [M]CPY<>"" : CRITERE -= "& CPY='"+[M]CPY+"'" : Endif
Return

#Création des variables prev avec nb TR à commander pour le mois suivant...
###################################
Subprog MAJPRV (MATRI,DATMAT,QTE,CDE,CTR,DATCTR,TIMREF)
Value Char MATRI ()
Value Date DATMAT
Value Integer QTE
Value Char CDE ()
Value Char CTR ()
Value Date DATCTR        :##**82073
Value Char TIMREF()      :##**82073

If clalev([F:VPH])=0 : Local File VALPRVH   [VPH] : Endif
If clalev([F:VPR])=0 : Local File VALPRV    [VPR] : Endif
Gosub OUVRE From WPDEFTABLE

Local Char VARIA (GLONVRA)

##**82073
Read [HRCTR]CTR0=MATRI;CTR;DATCTR
If fstat | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<=DATMAT) | [F:HRCTR]FLGVAR=2
 Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT>DATCTR & (XITDAT=[0/0/0] | XITDAT>=eomonth(DATMAT)+1) & FLGVAR<>2
 Read [HRCTR]CTR1 First
 Filter [HRCTR]
 If fstat : Raz [F:HRCTR] : End : Endif
Endif

##**82073
DATMAT=addmonth(DATMAT,1)
If [F:HRCTR]XITDAT<>[0/0/0] : DATMAT=min(DATMAT,[F:HRCTR]XITDAT) : Endif

Read [F:ID]ID0=MATRI
If fstat : End : Endif
VARIA=func AFNC.PARAM("VARTRE",[F:HRCTR]ETRFCY)
If VARIA="" : End : Endif

Readlock [VPH]VPH0=MATRI;CTR;[F:HRCTR]CTRDAT
If !fstat
 [F:VPH]FCY    = [F:HRCTR]ETRFCY
 [F:VPH]SRV    = [F:HRCTR]ETRSRV
 [F:VPH]CODACS = [F:ID]CODACS
 If dim([F:VPH]UPDDAT)>0 : [F:VPH]UPDDAT = date$ : Endif
 If dim([F:VPH]UPDUSR)>0 : [F:VPH]UPDUSR = GUSER : Endif
 If dim([F:VPH]UPDTIM)>0 : [F:VPH]UPDTIM = time  : Endif
 Rewrite [VPH]
Elsif fstat>1
 Raz [F:VPH]
 [F:VPH]EMP    = MATRI
 [F:VPH]CTRNUM = CTR
 ##**82073
 [F:VPH]CTRDAT = [F:HRCTR]CTRDAT
 [F:VPH]FCY    = [F:HRCTR]ETRFCY
 [F:VPH]SRV    = [F:HRCTR]ETRSRV
 [F:VPH]CODACS = [F:ID]CODACS
 If dim([F:VPH]CREDAT)>0 : [F:VPH]CREDAT = date$ : Endif
 If dim([F:VPH]CREUSR)>0 : [F:VPH]CREUSR = GUSER : Endif
 If dim([F:VPH]CRETIM)>0 : [F:VPH]CRETIM = time  : Endif
 Write [VPH]
Endif
If fstat
 GOK = 0 : Call FSTA("VPH") From GLOCK
Endif

If GOK
 ##**82073
 Readlock [VPR]VPR0=MATRI;CTR;[F:HRCTR]CTRDAT;DATMAT;VARIA
 If !fstat
  #Si pas la même génération on RAZ avant de cumuler...
  If dim([F:VPR]UPDUSR)>=0 & [F:VPR]UPDUSR<>"" & [F:VPR]UPDUSR<>GUSER
   Raz [F:VPR]VARVAL
  Elsif dim([F:VPR]UPDDAT)>=0 & [F:VPR]UPDDAT<>[0/0/0] & [F:VPR]UPDDAT<>date$
   Raz [F:VPR]VARVAL
  Elsif time$<>[L]TIMREF
   Raz [F:VPR]VARVAL
  Endif
  [F:VPR]VARVAL += QTE
  [F:VPR]CMT    = mess(98,197,1)-":"-CDE
  If dim([F:VPR]UPDDAT)>=0 : [F:VPR]UPDDAT = date$ : Endif
  If dim([F:VPR]UPDUSR)>=0 : [F:VPR]UPDUSR = GUSER : Endif
  If dim([F:VPR]UPDTIM)>=0 : [F:VPR]UPDTIM = time  : Endif
  Rewrite [VPR]
 Elsif fstat>1
  Raz [F:VPR]
  [F:VPR]EMP    = MATRI
  [F:VPR]DAT    = DATMAT
  [F:VPR]CTRNUM = CTR
  ##**82073
  [F:VPR]CTRDAT = [F:HRCTR]CTRDAT
  [F:VPR]VARCOD = VARIA
  [F:VPR]VARVAL = QTE
  [F:VPR]CMT    = mess(98,197,1)-":"-CDE
  If dim([F:VPR]CREDAT)>=0 : [F:VPR]CREDAT = date$ : Endif
  If dim([F:VPR]CREUSR)>=0 : [F:VPR]CREUSR = GUSER : Endif
  If dim([F:VPR]CRETIM)>=0 : [F:VPR]CRETIM = time  : Endif
  Write [VPR]
 Endif
 If fstat
  GOK = 0 : Call FSTA("VPR") From GLOCK
 Endif
Endif
End

#########################################################################
$TRNO
ER=0
Lock NUMFIL
If fstat=0
 NUMFIL= [C]NUMFIL(2)
 [C]NUMFIL(2) += 1
 If fstat :  ER = 2 : Endif
Else
 ER = 1
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran GENTRL) 28/02/2008 12:26:30 (DBA)
######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
#92896 - US2135
# Effzo CPY, FILNAM, NUMEND, NUMSTR :# Gestion champ FILNAM
# Grizo CPY, FILNAM
 Effzo CPY, VOLFIL, NUMEND, NUMSTR :# Gestion champ VOLFIL
 Grizo CPY, VOLFIL
 Gosub INIT_NOMFIC
Else
 Actzo CPY
 #Active la zone nom de fichier si mode = serveur
 #92896 - US2135
 #If [M]TYPEXP=2 : Actzo FILNAM : Endif
 If [M]TYPEXP=2 : Actzo VOLFIL : Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[F:CPY]CPY0=VALEUR
 If fstat | [F:CPY]TRECPY=""
  #Code client non renseigné pour la société
  GMESSAGE = mess(1,10719,1)-VALEUR
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_DATSTR(VALEUR)
Variable Date    VALEUR
Call AS_DATSTR(VALEUR) From EXTRTRL
End

Subprog AS_DATEND(VALEUR)
Variable Date    VALEUR
Call AS_DATEND(VALEUR) From EXTRTRL
End

Subprog AS_NUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR=[M]NUMSTR : Endif
End

Subprog C_NUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]NUMSTR : mkstat=2 : Endif
[M]NUMEND=VALEUR
#92896 - US2135
If VALEUR<>[M]NUMSTR | (VALEUR=[M]NUMSTR & VALEUR="") | [M]CPY=""
  #Effzo FILNAM : Grizo FILNAM
  Effzo [M]VOLFIL
  Grizo [M]VOLFIL
  Gosub INIT_NOMFIC
Elsif VALEUR=[M]NUMSTR & [M]CPY<>"" &  [M]TYPEXP<>2
  #Effzo FILNAM : Grizo FILNAM
  Effzo [M]VOLFIL : Grizo [M]VOLFIL
  Gosub INIT_NOMFIC
 #Active la zone nom de fichier si mode = serveur
Elsif [M]TYPEXP=2
 #Actzo FILNAM
 Actzo [M]VOLFIL
Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
If dim([M]ALLCPY)>=0
 If [M]ALLCPY=2
 #92896 - US2135
  #Effzo CPY, FILNAM
  #Grizo CPY, FILNAM
  Effzo CPY, VOLFIL
  Grizo CPY, VOLFIL
 # Gosub INIT_NOMFIC
 Else
  Actzo CPY
  #Active la zone nom de fichier si mode = serveur
  #If [M]TYPEXP=2 : Actzo FILNAM : Endif
  If [M]TYPEXP=2 : Actzo VOLFIL : Endif
 Endif
Endif
#Gosub INIT_NOMFIC
End

######################################################################################
$INIT_NOMFIC
#Composition du nom du fichier
#92896 - US2135
Local Char FIC_FILNAM (GDIMFIC)
Local Char FIC_VOLFIL (GDIMFIC)
If [M]TYPEXP<2
 Call AS_FILNAM(FIC_FILNAM)
 Call AS_VOLFIL(FIC_VOLFIL)
 Call SET_NAMCLI(FIC_FILNAM) From ORDSYS
 [M]FILNAM=FIC_FILNAM
 [M]VOLFIL=FIC_VOLFIL
 #Grizo FILNAM
 Grizo VOLFIL
Else
 #Raz [M]FILNAM
 Raz [M]VOLFIL
Endif
#Affzo [M]FILNAM
Affzo [M]VOLFIL
Return

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & [L]VALEUR<2
 GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat=2 : End
Endif
#92896 - US2135
#If [L]VALEUR=2 & [M]NUMSTR<>"" & [M]NUMSTR=[M]NUMEND : Actzo [DIA] FILNAM :# Gestion champ FILNAM
#Else                                                   Grizo [DIA] FILNAM
#Endif
If [L]VALEUR=2 & [M]NUMSTR<>"" & [M]NUMSTR=[M]NUMEND
 Actzo [DIA] VOLFIL :# Gestion champ VOLFIL
Else
 Grizo [DIA] VOLFIL
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
[M]TYPEXP=VALEUR
Gosub INIT_NOMFIC
End

Subprog AS_FILNAM(VALEUR)
Variable Char    VALEUR()
#If VALEUR<>"" | [M]CPY="" | [M]NUMSTR<>[M]NUMEND
# mkstat=1 : End
#Endif
If VALEUR=""
 Read[F:CPY]CPY0=[M]CPY
 If !fstat & [F:CPY]TRECPY<>""
  If len(num$(month([M]DATEND)))<2
   VALEUR=[F:CPY]TRECPY+'_'+num$(year([M]DATEND))+'0'+num$(month([M]DATEND))
  Else
   VALEUR=[F:CPY]TRECPY+'_'+num$(year([M]DATEND))+num$(month([M]DATEND))
  Endif
 Endif
Endif
End

Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(GDIMFIC)
Local Integer OK
Call C_NOMEXP(VALEUR,"txt") From TRTDUE
If mkstat=2 : End : Endif
#92896 - US2135
#Call EXISTE(filpath([V]GDIRBQE,[L]VALEUR,"txt",0),[L]OK) From ORDSYS
Call EXISTE(filpath([V]GDIRBQR,[L]VALEUR,"txt",0),[L]OK) From ORDSYS
If [L]OK
 [V]GMESSAGE = mess(132,133,1) : # Fichier déjà existant
 [V]GERR     = 3
 End
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran GENTRL) 27/08/2013 10:20:25 (LANEG)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Effzo [M]NUMSTR, NUMEND
End

######################################################################################
#92896 - US2135
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#Control that the file exists :
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M:DIA]TYPEXP,VALEUR,[M:DIA]FILNAM,E_TYPE_FILEWRITE,GMESSAGE)
End

Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char NAMFIC
 Read[F:CPY]CPY0=[M:DIA]CPY
 If !fstat & [F:CPY]TRECPY2<>""
  If len(num$(month([M:DIA]DATEND)))<2
   NAMFIC=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+'0'+num$(month([M:DIA]DATEND))
  Else
   NAMFIC=[F:CPY]TRECPY2+'_'+num$(year([M:DIA]DATEND))+num$(month([M:DIA]DATEND))
  Endif
 Endif
 If [M]TYPEXP=2
  VALEUR='['+[V]GDIRBQR+']/'+NAMFIC
 Else
  VALEUR=NAMFIC
 Endif
 Affzo VOLFIL
End
