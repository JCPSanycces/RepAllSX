#<AdxTL>@(#)4.0.0.0 $Revision$
#####################################################################

#########################################################################
$ACTION
#--- Actions liées au traitement standard TRTALLPRO
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
 When "FINSAI"      : Gosub FINSAI
 When "END"         : Gosub ACTEND

 When "EXEC"       : Gosub EXEC
 When Default
Endcase

Return

#########################################################################
$OUVRE_BOITE

Local  Integer WA,WQ,WR,LRET
Global Integer GFILTREAQR
Global Integer GLRET : Raz GLRET

GBIDC1 = mess([M:SHTR]VCRTYP,701,1)

# Lecture des tables article
If [F:ITM]ITMREF <> [M:SHTR]ITMREF
    Read [ITM]ITM0=[M:SHTR]ITMREF
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:SHTR]STOFCY,[F:ITM]TCLCOD,[M:SHTR]TRSTYP,[M:SHTR]TRSCOD,"",LRET) From STKLIB
If LRET<>0
   FIN=1 : GLRET=1 : Return
Endif

# Statuts autorisés par la règle de gestion
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
GFILTREAQR = WA+2*WQ+4*WR

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

[M:ALF]STOFCY = [M:SHTR]STOFCY
[M:ALF]ITMREF = [M:SHTR]ITMREF
[M:ALF]VCRNUM = [M:SHTR]VCRNUM

# Chargement des filtres avec le filtre issu du détail stock
If dim([M:ALF]LOT)>0    [M:ALF]LOT   =[M:SHTR]XLOT    Endif
If dim([M:ALF]LOC)>0    [M:ALF]LOC   =[M:SHTR]XLOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:ALF]LOCTYP=[M:SHTR]XLOCTYP Endif
[M:ALF]STA = [M:SHTR]XSTA

Affzo [M:ALF]

Return

#########################################################################
$SETBOUT

# On est obligé de passer par ETABOU afin d'avoir le bouton enregistrer tout de suite
# La variable REP ne convient pas car elle est RAZ juste après "$DEBUT"
ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

If dim([M:ALF]LOT)>0    [M:SHTR]XLOT   =[M:ALF]LOT    Endif
If dim([M:ALF]LOC)>0    [M:SHTR]XLOC   =[M:ALF]LOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:SHTR]XLOCTYP=[M:ALF]LOCTYP Endif
[M:SHTR]XSTA = [M:ALF]STA

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################
$FINSAI

#If GOK=1 mkstat=4 Endif

Return

#########################################################################
$ACTEND

GLRET=1

Return

###############################################################################
# $EXEC : Alimente STKSHTREG [SHTR] avec des propositions de régul de mvt
###############################################################################
# Pré-requis : Masque ALLPAR [ALP] alimenté
#              Variables GTRUCOD(règle d'alloc), GFILTREAQR(filtre statut)
###############################################################################
$EXEC
Local Integer LRET, LFULLTAB
Local Char    WTRUCOD
Local Integer WSTA, WLOC
Local Decimal SVGQTY, WSTUACTDIS
Local Integer WA, WQ, WR
Local Integer I,J,K

If GLRET
    Return
Endif

Effzo [M:SHTR]20
Effzo [M:SHTR]PECQTYPHY,PECQTYACT
[M:ALP]QTY = [M:SHTR]QTYACT


# Pas de quantité à traiter
If [M:ALP]QTY<=0
    Call ERREUR(mess(99,192,1)) From GESECRAN
    Goto EXEC_SUITE
Endif

# Récupération règle d'allocation et statuts autorisés
# Récupération de la règle d'allocation
#--- Issue X3-4501 : ajout 40 tache affaire
Case [M:ALP]VCRTYP
 When 2,40           : # Commande, Affaire
                       WTRUCOD = [F:ITG]ALLRULORD
 When 3,4,5,8        : # Préparation/Livraison sous-traitance
                       If [M:ALP]TRSTYP=20
                          WTRUCOD = [F:ITG]ALLRULSCO
                       # Préparation, Livraison, Facture, Retour fou
                       Else
                          WTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 6              : # Réception (conso matières sous-rtraitance)
                       WTRUCOD = [F:ITG]ALLRULSCC
 When 10             : # OF (opération de sous-traitance)
                       If [M:ALP]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # OF (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMAT
                       Endif
 When 12             : # Suivi matière (opération de sous-traitance)
                       If [M:ALP]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matière (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       WTRUCOD = [F:ITG]ALLRULTRF
 When 34             : # Réappro zones de consommation
                       If [M:ALP]LOCCAT=4
                          WTRUCOD = [F:ITG]ALLRULSCO
                       Else
                          WTRUCOD = [F:ITG]ALLRULTRF
                       Endif
 When 36             : # Ordre sous-traitance
                       WTRUCOD = [F:ITG]ALLRULSCC
 When Default
Endcase

Raz [F:TRU]
If WTRUCOD <>""
   # Lecture règle d'allocation
   Read [TRU]TRU0=WTRUCOD
   If fstat Raz WTRUCOD Endif
Endif

If WTRUCOD <> ""
   # Statuts autorisés par les règles d'allocation
   For I=0 To dim([F:TRU]STAFLT)-1
      If [F:TRU]STAFLT(I)<>0
         If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
         If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
         If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
      Endif
   Next I
Else
   WA=1
Endif
WSTA    = WA+2*WQ+4*WR

[M:ALP]LOT        = [M:SHTR]XLOT
[M:ALP]LOC        = [M:SHTR]XLOC
[M:ALP]STA        = [M:SHTR]XSTA
[M:ALP]LOCTYP     = [M:SHTR]XLOCTYP
#--- TS 106217
[M:ALP]ECCVALMAJ  = [M:SHTR]WECCVALMAJ

Raz WLOC
# Prise en compte emplacement quai (en attente de rangement)
If [M:ALP]PECPLFLOC=2 WLOC+=1  Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WLOC+=4  Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WLOC=WLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WLOC,WSTA,[M:ALP]PECOWNER,WSTUACTDIS) From STKLIB

SVGQTY = [M:ALP]QTY
# Si pas de stock disponible, pas de proposition
If WSTUACTDIS <=0 Goto EXEC_SUITE Endif
# Si quantité disponible < quantité à sortir, on appelle l'algo avec
# comme quantité à sortir, la quantité disponible
If WSTUACTDIS<[M:ALP]QTY [M:ALP]QTY=WSTUACTDIS Endif

# Appel à l'algorithme d'allocation/sortie
Call STOCKALG(1,WTRUCOD,LFULLTAB,LRET) From STKALL
If LRET<>0 & GMESSAGE<>""
   Call MESSAGE(GMESSAGE) From GESECRAN
   Goto EXEC_SUITE
Endif

Raz K
For I=0 To [M:ALP]NBLIG-1
   J=[M:ALP]NLIG(I)            # C'est le champ NLIG qui donne les n° de lignes dans l'ordre où il faut se servir
   Break ([M:ALP]WFLG(J)=0)    # Les lignes avec WFLG=0 sont à la fin => on peut s'arrêter
   If [M:ALP]WQTYSTUACT(J)<>0
      Read [STO]STO0=[M:ALP]STOFCY;[M:ALP]WSTOCOU(J)
      If !fstat
         If dim([M:SHTR]LOT)>0
            [M:SHTR]LOT(K) = [F:STO]LOT
            If dim([M:SHTR]SLO)>0 [M:SHTR]SLO(K)=[F:STO]SLO Endif
            If dim([M:SHTR]POT)>0
               Read [STL]STL0=[M:SHTR]ITMREF;[F:STO]LOT;[F:STO]SLO
               If !fstat
                  If [M:SHTR]STOMGTCOD=3
                     [M:SHTR]POT(K) = [F:STL]POT
                  Elsif [M:SHTR]STOMGTCOD=4
                     [M:SHTR]POT(K) = [F:STL]ACT
                  Endif
               Endif
            Endif
         Endif

         [M:SHTR]TOTQTY(K)     = [F:STO]QTYSTU
         [M:SHTR]TOTQTYACT(K)  = [F:STO]QTYSTUACT
         If dim([M:SHTR]LOC)>0     [M:SHTR]LOC(K)    = [M:ALP]WLOC(J)    Endif
         If dim([M:SHTR]SERNUM)>0  [M:SHTR]SERNUM(K) = [M:ALP]WSERNUM(J) Endif
         If dim([M:SHTR]SHLDAT)>0  [M:SHTR]SHLDAT(K) = [M:ALP]WSHLDAT(J) Endif
         [M:SHTR]STA(K)        = [M:ALP]WSTA(J)
         [M:SHTR]STOCOU(K)     = [M:ALP]WSTOCOU(J)
         [M:SHTR]QTYSTU(K)     = [M:ALP]WQTYSTU(J)
         [M:SHTR]QTYSTUACT(K)  = [M:ALP]WQTYSTUACT(J)
         [M:SHTR]AVAQTYSTU(K)  = [M:ALP]WQTYSTUAVA(J)
         [M:SHTR]AVAQTYACT(K)  = [M:ALP]WQTYACTAVA(J)
         [M:SHTR]PCU(K)        = [M:ALP]WPCU(J)
         [M:SHTR]PCUSTUCOE(K)  = [M:ALP]WPCUSTUCOE(J)
         If [M:SHTR]PCUSTUCOE(K)=0
            [M:SHTR]PCUSTUCOE(K)=1
         Endif
         [M:SHTR]QTYPCU(K)     = [M:SHTR]QTYSTU(K)/[M:SHTR]PCUSTUCOE(K)
         [M:SHTR]QTYPCUACT(K)  = [M:SHTR]QTYSTUACT(K)/[M:SHTR]PCUSTUCOE(K)
         [M:SHTR]AVAQTYPCU(K)  = [M:SHTR]AVAQTYSTU(K)/[M:SHTR]PCUSTUCOE(K)
         [M:SHTR]AVAQTYPCUA(K) = [M:SHTR]AVAQTYACT(K)/[M:SHTR]PCUSTUCOE(K)

         [M:SHTR]PECQTYPHY += [M:SHTR]QTYSTU(K)
         [M:SHTR]PECQTYACT += [M:SHTR]QTYSTUACT(K)

         K += 1

      Endif
   Endif
Next I

[M:SHTR]NBLIG = K

$EXEC_SUITE
[M:ALP]QTY = SVGQTY

Return

