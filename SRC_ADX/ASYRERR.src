#<AdxTL>@(#)11.0.0.0 $Revision$
#**
#* ERRSTACK
#*!
$ERRSTACK
Call TRACE("***ERROR***") From ASYRCOM
Call TRACE("ERRNUM:"+num$(ERRNUM)) From ASYRCOM
Call TRACE("at "+ errp-"("+num$(errl)+")"-errmes$(errn)-errm) From ASYRCOM
Integer NIVEAU
While adxpno(NIVEAU) <> ""
 If NIVEAU > 0
  Call TRACE("at "+ adxpno(NIVEAU)) From ASYRCOM
 Endif
 NIVEAU += 1
Wend
Return

