#<AdxTL>@(#)2.0.0.0 $Revision$
# Classe PSHSIGM_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
      Case [L]AEVENT
        When "AREAD_AFTER"  : Gosub AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "RCHRONO" # Sequence number
      Case [L]ARULE
        When "GET" : Gosub RCHRONO_GET
      Endcase
    When "RCLEDEC" # Purchase request number
      Case [L]ARULE
        When "GET" : Gosub RCLEDEC_GET
      Endcase
   When "RTIMENV" # Issue time
      Case [L]ARULE
        When "GET" : Gosub RTIMENV_GET
      Endcase
    When "RVALCTX1" # Requester
      Case [L]ARULE
        When "GET" : Gosub RVALCTX1_GET
      Endcase
    When "RVALCTX2" # Inv amt -tax
      Case [L]ARULE
        When "GET" : Gosub RVALCTX2_GET
      Endcase
    When "RVALCTX3" # Currency
      Case [L]ARULE
        When "GET" : Gosub RVALCTX3_GET
      Endcase
    When "RVALCTX4" # Product
      Case [L]ARULE
        When "GET" : Gosub RVALCTX4_GET
      Endcase
    When "RVALCTX5" # Product description
      Case [L]ARULE
        When "GET" : Gosub RVALCTX5_GET
      Endcase
    When "RVALCTX6" # Expected date
       Case [L]ARULE
        When "GET" : Gosub RVALCTX6_GET
      Endcase
    When "RVALCTX7" # Quantity
      Case [L]ARULE
        When "GET" : Gosub RVALCTX7_GET
      Endcase
    When "RVALCTX8" # Unit
      Case [L]ARULE
        When "GET" : Gosub RVALCTX8_GET
      Endcase
    When "RVALCTX9"  # Supplier
      Case [L]ARULE
        When "GET" : Gosub RVALCTX9_GET
      Endcase
    When "RNOMUSR" # Requester name
      Case [L]ARULE
        When "GET" : Gosub RNOMUSR_GET
    Endcase
    When "ROPERATION" # Answer
      Case [L]ARULE
        When "GET" : Gosub ROPERATION_GET
      Endcase
  Endcase
Return


$RCHRONO_GET
  this.RCHRONO = this.AWS.CHRONO
Return

$RCLEDEC_GET
  this.RCLEDEC = this.AWS.CLEDEC
Return

$RTIMENV_GET
  this.RTIMENV = left$(this.AWS.TIMENV,2)+mid$(this.AWS.TIMENV,3,2) +right$(time$,7)
Return

$RVALCTX1_GET
  this.RVALCTX1 = this.AWS.VALCTX1
Return

$RVALCTX2_GET
  this.RVALCTX2 = val(this.AWS.VALCTX2)
Return

$RVALCTX3_GET
  this.RVALCTX3 = this.AWS.VALCTX3
Return

$RVALCTX4_GET
  this.RVALCTX4 = this.AWS.VALCTX4
Return

$RVALCTX5_GET
  this.RVALCTX5 = this.AWS.VALCTX5
Return

$RVALCTX6_GET
  Local Integer IDAY
  Local Integer IMONTH
  Local Integer IYEAR
  IDAY = val(left$(this.AWS.VALCTX6,2))
  IMONTH = val(mid$(this.AWS.VALCTX6,4,2))
  IYEAR = val(mid$(this.AWS.VALCTX6,7,4))
  this.RVALCTX6 = gdat$(IDAY, IMONTH, IYEAR)
Return

$RVALCTX7_GET
  this.RVALCTX7 = val(this.AWS.VALCTX7)
Return

$RVALCTX8_GET
  this.RVALCTX8 = this.AWS.VALCTX8
Return

$RVALCTX9_GET
  this.RVALCTX9 = this.AWS.VALCTX9 + " " + this.AWS.VALCTX10
Return

$RNOMUSR_GET
If clalev([AUS])=0 : Local File "AUTILIS"    [AUS] : Endif
  Read [AUS]CODUSR=this.AWS.VALCTX1
  If !fstat
  this.RNOMUSR = [AUS]NOMUSR
  Endif
Return

$ROPERATION_GET
  If this.AWS.OPERATION = 'VAL'
    this.ROPERATION = 2
  Else
    this.ROPERATION = 1
  Endif
Return

#######################################################################################
$AREAD_AFTER
  If dim(this.RVALCTX4)>0 and this.RVALCTX4 = '' # Product
  Local Integer WOK
    WOK = fmet this.ASETATTRIBUTE("RVALCTX4",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
    WOK = fmet this.ASETATTRIBUTE("RVALCTX5",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
  Endif

  If dim(this.RVALCTX6)>0  and this.RVALCTX6 = [0/0/0]  # Expected date
  Local Integer WOK
    WOK = fmet this.ASETATTRIBUTE("RVALCTX6",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
  Endif

  If dim(this.AWS.VALCTX9)>0 and this.AWS.VALCTX9 = '' # Supplier
  Local Integer WOK
    WOK = fmet this.ASETATTRIBUTE("RVALCTX9",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
  Endif

  If dim(this.RVALCTX7)>0 and this.RVALCTX7 = 0 # Quantity
  Local Integer WOK
    WOK = fmet this.ASETATTRIBUTE("RVALCTX7",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
    WOK = fmet this.ASETATTRIBUTE("RVALCTX8",func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
  Endif
Return

