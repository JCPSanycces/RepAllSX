######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

#JASMI - START
  Effzo [M:DCG1]30

  Link [HRCTR] With
&   [FCY]FCY0=ETRFCY
& As [LNK]
& Where REFNUM=[F:ID]REFNUM & (CTRDAT<=[M:DCG1]DATFIN | (FLGRET=2 & RETDATEFF<=[M:DCG1]DATFIN)) & [FCY]LEG=VALEUR
  Read [LNK] First
  If fstat
    GMESSAGE=mess(23,100,1)
    mkstat=2 : End
  Endif

  GCURLEG=VALEUR
  Gosub OUVRE
  Gosub LIENS
#JASMI - END

End

