Subprog C_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local Integer WRET

  #LIPET - 2017-08-19 - X3-52945 - START

  If func AFNC.ACTIV("GLM")
    If clalev([F:TIM2])=0 : Local File TIMCOD  [TIM2] : Endif
    Filter [F:TIM2] Where COD = [M]TIM(nolign-1) and  ([TIM2]LVEENHANCE=2 & ([TIM2]CATTIM=3 |[TIM2]CATTIM=2))  and [TIM2]ENAFLG=2
    Read [TIM2] First
    Filter [F:TIM2]
    If !fstat Then
      If VALEUR = 0 Then
        GERR=1:GMESSAGE= num$(VALEUR) - " hour is not applicable in this field ":mkstat=2:End
      Endif
    Endif
  Endif
  #LIPET - 2017-08-19 - X3-52945 - END
  Call C_NBLIG_FIELDCONTROL(WRET)
  If !WRET
    mkstat     =2
    End
  Endif
End

