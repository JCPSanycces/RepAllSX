#-------------------------------------------------------------------------------
$EXEACT
Case [L]DEFILE
When 4 : # Défilement / période - chrono
 Case [L]CHODAT
 When 6 : # Période
  If [L]DATDEB=eomonth([L]DATDEB) : I=31 : Else I=day([L]DATDEB) : Endif
  If [L]DATFIN=eomonth([L]DATFIN) : J=31 : Else J=day([L]DATFIN) : Endif
  If find(abs(I-J),0,1,30) : I=1 : J=arr(([L]DATFIN-[L]DATDEB)/30,1)
  Else                       I=0 : J=[L]DATFIN-[L]DATDEB
  Endif

  Case [L]BOUT
  When "0"
   # Ne pas prendre les dates non renseignées
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2017-01-12 - X3-12089- START
    Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=STRDAT
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=STRDAT
#MIPEA - 2017-01-12 - X3-12089- END
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=STRDAT
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-19 - X3-12089- START
   Read [LNK] First
   Filter [DCG]
#   Read [DCG] First
#   Filter [DCG]
#MIPEA - 2016-12-19 - X3-12089- END
   If fstat
    [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
    [V]GERR    =1
    [L]OK      =0
    Return
   Endif

   If [L]DATFIN>=[F:DCG]STRDAT
    While [L]DATDEB>[F:DCG]ENDDAT
    If I : [L]DATDEB=addmonth([L]DATDEB,-J) : Else [L]DATDEB=[L]DATDEB-J-1 : Endif
    Wend
    If I : [L]DATFIN=addmonth([L]DATDEB,J)-1 : Else [L]DATFIN=[L]DATDEB+J : Endif
   Else
    While [L]DATFIN<[F:DCG]STRDAT
     If I : [L]DATFIN=addmonth([L]DATFIN+1,J)-1 : Else [L]DATFIN=[L]DATFIN+J+1 : Endif
    Wend
    If I : [L]DATDEB=addmonth([L]DATFIN,-J)+1 : Else [L]DATDEB=[L]DATFIN-J : Endif
   Endif

  When "9"
   # Ne pas prendre les dates non renseignées
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2017-01-12 - X3-12089- START
    Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=ENDDAT Desc
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=ENDDAT Desc
#MIPEA - 2017-01-12 - X3-12089- END
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=ENDDAT Desc
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-19 - X3-12089- START
   Read [LNK] First
   Filter [DCG]
#   Read [DCG] First
#   Filter [DCG]
#MIPEA - 2016-12-19 - X3-12089- END
   If fstat
    [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
    [V]GERR    =1
    [L]OK      =0
    Return
   Endif

   If [L]DATDEB<=[F:DCG]ENDDAT
    While [L]DATFIN<[F:DCG]STRDAT
     If I : [L]DATFIN=addmonth([L]DATFIN+1,J)-1 : Else [L]DATFIN=[L]DATFIN+J+1 : Endif
    Wend
    If I : [L]DATDEB=addmonth([L]DATFIN,-J)+1 : Else [L]DATDEB=[L]DATFIN-J : Endif
   Else
    While [L]DATDEB>[F:DCG]ENDDAT
     If I : [L]DATDEB=addmonth([L]DATDEB,-J) : Else [L]DATDEB=[L]DATDEB-J-1 : Endif
    Wend
    If I : [L]DATFIN=addmonth([L]DATDEB,J)-1 : Else [L]DATFIN=[L]DATDEB+J : Endif
   Endif

  When "<"
   [L]DATFIN=[L]DATDEB-1
   If I : [L]DATDEB=addmonth([L]DATDEB,-J) : Else [L]DATDEB-=J+1 : Endif

  When ">"
   [L]DATDEB=[L]DATFIN+1
   If I : [L]DATFIN=addmonth([L]DATFIN+1,J)-1 : Else [L]DATFIN+=J+1 : Endif

  When Default
   Return
  Endcase

  Gosub INIFILTRE
  Gosub CHARGE
  Affzo [DCG1] 20-30
  [L]OK=0

 When 5 : # Chrono
  # Ne pas prendre les dates non renseignées
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2016-12-19 - X3-12089- START
  Case [L]BOUT
  When "0"
       Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=DEM
  When "9"
       Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=DEM Desc
  When "<"
      Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]DEM<[L]CHRONO & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=DEM Desc
  When ">"
       Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]DEM<[L]CHRONO & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=DEM
  When Default
   Return
  Endcase
#  Case [L]BOUT
#  When "0"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM
#  When "9"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM Desc
#  When "<"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & DEM<[L]CHRONO & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0]
#&        Order By Key CLE=DEM Desc
#  When ">"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & DEM>[L]CHRONO & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM
#  When Default
#   Return
#  Endcase
#MIPEA - 2016-12-19 - X3-12089- END
#  Case [L]BOUT
#  When "0"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM
#  When "9"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM Desc
#  When "<"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & DEM<[L]CHRONO & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0]
#&        Order By Key CLE=DEM Desc
#  When ">"
#   Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & DEM>[L]CHRONO & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM
#  When Default
#   Return
#  Endcase
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-19 - X3-12089- START
  Read [LNK] First
  Filter [DCG]
#  Read [DCG] First
#  Filter [DCG]
#MIPEA - 2016-12-19 - X3-12089- END
  If fstat
   [V]GMESSAGE=mess(11,100,1) : # Début/fin de fichier
   [V]GERR    =1
   [L]OK      =0
   Return
  Endif
  [L]CHRONO=[F:DCG]DEM

  Gosub INIFILTRE
  Gosub CHARGE
  Affzo [DCG1] 20-30
  [L]OK=0
 Endcase
Endcase
Return

#-------------------------------------------------------------------------------
$EXEBOUT
Case [L]BOUT
When "B" : # Période
 # Ajout de critères dans le filtre : seulement si bouton OK activé
 If GOK = 1
   Gosub INIFILTRE
   Gosub CHARGE
   Affzo [DCG1] 20-30
 Endif
Endcase
Gosub DISPLAY_ATT_ICON
Return

#-------------------------------------------------------------------------------
$STATUT
Case [L]BOUT
When "1", "3" : # Matricule, service
 [L]DEFILE=val([L]BOUT)
 [L]INDGES=[L]DEFILE
When "4" : # Période/Chrono
 [L]DEFILE=4
When "5" : # Chrono
 [L]CHODAT=5
 Effzo [DCG1] DATDEB, DATFIN
 # Ne pas prendre les dates non renseignées
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2016-12-19 - X3-12089- START
    Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&                   [FCY]FCY0 = [HRCTR]ETRFCY
&                   As   [LNK]
&                   Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
&                   Order By Key CLE=DEM Desc

# Filter [DCG] Where REFNUM=[M:DCG1]REFNUM  & LEG=GCURLEG & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM Desc
#MIPEA - 2016-12-19 - X3-12089- END
# Filter [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STRDAT <> [0/0/0] & ENDDAT <> [0/0/0] Order By Key CLE=DEM Desc
 #MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-19 - X3-12089- START
   Read [LNK] First
   Filter [DCG]
#   Read [DCG] First
#   Filter [DCG]
#MIPEA - 2016-12-19 - X3-12089- END
 [L]CHRONO=[F:DCG]DEM
 Gosub INIFILTRE
 Gosub CHARGE
 Affzo [DCG1] 20-30
When "6" : # Période
 [L]CHODAT=6
 Effzo [DCG1] WRKNUM
 Gosub INIFILTRE
 Gosub CHARGE
 Affzo [DCG1] 20-30
Endcase
Return

