Call MANAGE_LOCALISATION("ODCG") From DIVPAYE
#JOJAC - 2017-08-17 - X3-15908 - END

Global Integer GPARENT_NOLIGN

Return

# A la toute première connexion on initilalise la période de saisie à la période annuelle de paie.
# Aux connexions suivantes, on chargera la dernière période utilisée par l'utilisateur. Celle-ci pouvant être modifier par le bouton filtre.
#-------------------------------------------------------------------------------
Subprog LITDAT(OBJ,DEB,FIN)
Value    Char OBJ
Variable Date DEB, FIN
Local Char VALPAR (20)
If !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif
Read [ALS]ALS0=[V]GUSER;tolower([L]OBJ);1
If !fstat
 [L]DEB=gdat$([F:ALS]CLES)
Else
 [L]DEB =gdat$(func DIVPAYE.INIPARUSR("DEBANNPAY","",""))
Endif

Read [ALS]ALS0=[V]GUSER;tolower([L]OBJ);2
If !fstat
 [L]FIN=gdat$([F:ALS]CLES)
Else
 [L]FIN =gdat$(func DIVPAYE.INIPARUSR("FINANNPAY","",""))
Endif

# 28/03/01 - Bug 72654 - Pouvoir saisir quand on n'a pas GPAYE et GTPS
If [L]DEB =[0/0/0]
   [L]DEB =gdat$(1,month(date$),year(date$))
   [L]FIN =gdat$(1,month(date$)+1,year(date$))-1
Endif
# END_Bug 72654

End

#-------------------------------------------------------------------------------
$SETBOUT
If [L]REP>"" | [L]CHODAT<>6 : [L]CHAINE=ctrans([L]CHAINE,"B","") : Endif
If [L]REP=""
 If instr(1,[V]GUSRAUZ(1),"1")
  [L]CHMEN+=ctrans("13",num$([L]DEFILE),"")
  # Par défaut on défile par service
#JASMI - temp
#  [L]INDGES=[L]DEFILE
#JASMI - temp
 Endif
 [L]CHMEN+=ctrans("4",num$([L]DEFILE),"")+ctrans("56",num$([L]CHODAT),"")
Endif

If GCURLEG <> "BRI"
  Call VIREBOUT(CHAINE,"G") From GOBJET
Endif

Return

#-------------------------------------------------------------------------------
$FIN
If !clalev([M:AWP0])
 Call SAVDAT("dcg",[L]DATDEB,[L]DATFIN) From SUBEXS
Endif
Return

