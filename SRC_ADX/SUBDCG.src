  GMESSAGE=mess(9,10709,1)
#  GMESSAGE=mess(9,709,1)
#MIPEA - 2016-12-15 - X3-12089- END
 mkstat=2 : End
Endif
If mkstat
#MIPEA - 2016-12-15 - X3-12089- START
  GMESSAGE = mess(46,10702,1)-"-"-GMESSAGE
# GMESSAGE = mess(46,702,1)-"-"-GMESSAGE  : #Sélection salarié
#MIPEA - 2016-12-15 - X3-12089- END
