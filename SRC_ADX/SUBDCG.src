$FIN_MOD
  Gosub LIENS
Return

$APRES_MOD
For I=0 To [M:DCG1]NBLIG-1
 [M:DCG1]STA0  (I)=[M:DCG1]STA(I)
 [M:DCG1]UPDNUM(I)=[L]UPD2    (I)
 [M:DCG1]UID   (I)=[L]UID2    (I)

  If func AFNC.ACTIV("GLM")
    Local Integer PRAT
    For PRAT = 1 To dim([F:DCG]LVESUBTYP)
      If [F:DCG]LVESUBTYP(PRAT-1) <> ""
        Assign "[M:DCG1]LVESUBRAT" + num$(PRAT-1) + "(" + num$(nolign-1) + ")" With [F:DCG]LVESUBRAT(PRAT-1)
      Endif
    Next
  Endif
 #62293 Pour éviter lors de l'instruction Affzo [DCG1] 30, de déclencher D_TYPPGN sur varinit
 If [M:DCG1]TYPPGN(I)=0 :  [M:DCG1]TYPPGN(I)=0 : Endif
Next
#LIPET - 2017-08-24 - START
#Affzo [DCG1] 30
#LIPET - 2017-08-24 - END

If [M:DCG1]NBDEL : Dela 0, [M:DCG1]NBDEL [M:DCG1]NBDEL : [M:DCG1]NBDEL=0 : Endif

If [V]GTPS
 Gosub MEL From TPSSTD
Endif
Call DELOCK("TPS") From GLOCK

Gosub SOA_ATTACHMENTS_DCG From ESS_FUNCTIONS

#62305 Gosub GRISE_AUZ
Return

################################################################################
#
# Routines
#
################################################################################


$CHARGE
If [V]GWEBSERV : Return : Endif
If [M:DCG1]NBLIG : Dela 0, [M:DCG1]NBLIG [M:DCG1]NBLIG : [M:DCG1]NBLIG=0 : Endif
Local Integer PRAT
nolign=0
Filter [DCG] Order By Key CLE=STRDAT;ENDDAT;TIM
#MIPEA - 2016-12-19 - X3-12089- START
#For [DCG] Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 & evalue([L]FILTRE2)
Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM,
&               [FCY]FCY0 = [HRCTR]ETRFCY
& As   [LNK]
& Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & evalue([L]FILTRE2)
& Order By Key UNIDCG=[DCG]UID

For [LNK]UNIDCG(1)
#For [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & evalue([L]FILTRE2)
#MIPEA - 2016-12-19 - X3-12089- END
 If nolign=dim([M:DCG1]ENDDAT)
  I=find([F:DCG]STRDAT,[M:DCG1]STRDAT)-1
  If I>=0
   Dela I,nolign-I [M:DCG1]NBLIG
   nolign        =I
   [M:DCG1]DATFIN=[M:DCG1]STRDAT(I-1)
  Endif
  Call ERREUR(mess(26,100,1)) From GESECRAN   # Tableau plein
  Break
 Endif

 nolign                +=1
 [M:DCG1]               =[F:DCG]
 [M:DCG1]STA0(nolign-1) =[F:DCG]STA
 ##PEVAN 2017-08-31 X3-54262 START
#  Loop through all sub rates on the parent grid and assign the dimensioned rates from the database

  If func AFNC.ACTIV("GLM")
   For PRAT = 1 To dim([F:DCG]LVESUBTYP)
    If [F:DCG]LVESUBTYP(PRAT-1) <> ""
      Assign "[M:DCG1]LVESUBRAT" + num$(PRAT-1) + "(" + num$(nolign-1) + ")" With [F:DCG]LVESUBRAT(PRAT-1)
#      Assign "[M:DCG1]LVESUBRAT" + num$(nolign-1) + "(" + num$(PRAT-1) + ")" With [F:DCG]LVESUBRAT(PRAT-1)
    Endif
   Next
  Endif
 ##PEVAN 2017-08-31 X3-54262 END

Next
#JASMI - START
Filter [DCG]
#JASMI - END
[M:DCG1]NBLIG=nolign

Affzo [M:DCG1]

Return

#-------------------------------------------------------------------------------
$INIFILTRE
If [V]GWEBSERV : Return : Endif
If [L]CHODAT=5
 [M:DCG1]WRKNUM=[L]CHRONO
 [L]FILTRE2    ="DEM=[L]CHRONO"
 # Ne pas prendre les dates non renseignées
 [L]FILTRE2   -="& STRDAT <> [0/0/0] & ENDDAT <> [0/0/0]"
Else
 [M:DCG1]DATDEB=[L]DATDEB
 [M:DCG1]DATFIN=[L]DATFIN
 [L]FILTRE2    ="STRDAT<=[L]DATFIN & ENDDAT>=[L]DATDEB"
Endif

# Ajout de critères dans le filtre - DEBUT
Raz [L]SELSTA, [L]NBSTA
# Renseignement d'un tableau avec les valeurs cochées
If [L]SELSTA1="2" Then # Brouillon
  [L]SELSTA([L]NBSTA) = 1 : NBSTA += 1
Endif
If [L]SELSTA2="2" Then # Demande
  [L]SELSTA([L]NBSTA) = 2 : NBSTA += 1
Endif
If [L]SELSTA3="2" Then # Accepté
  [L]SELSTA([L]NBSTA) = 3 : NBSTA += 1
Endif
If [L]SELSTA4="2" Then # Refusé
  [L]SELSTA([L]NBSTA) = 4 : NBSTA += 1
Endif
If [L]SELSTA5="2" Then # Demande d'annulation
  [L]SELSTA([L]NBSTA) = 5 : NBSTA += 1
Endif
If [L]SELSTA6="2" Then # Annulation acceptée
  [L]SELSTA([L]NBSTA) = 6 : NBSTA += 1
Endif
If [L]SELSTA7="2" Then # Annulation refusée
  [L]SELSTA([L]NBSTA) = 7 : NBSTA += 1
Endif
# Recherche du flag Suivi de la demande dans le tableau des valeurs cochées
[L]FILTRE2 -= "& find([F:DCG]STA,[L]SELSTA)"
# Filtre éventuel sur le code événement
If [L]TOUS = 1 Then
  [L]FILTRE2 -= "& [F:DCG]TIM='"+[L]L_EVT+"'"
Endif

Return

