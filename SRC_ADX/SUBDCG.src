Subprog C_LVERSN(VALEUR)
Variable Char    VALEUR()
Local Integer NM

  #LIPET - 2017-08-25 - X3-53555 - START
  If clalev([F:TIM3])=0 : Local File TIMCOD  [TIM3] : Endif
  Filter [TIM3] Where COD = [M]TIM(nolign-1) and LEG = GCURLEG and RSNMAN = 2
  Read [TIM3] First
  Filter [TIM3]
  If !fstat Then
   If VALEUR = "" Then
    GERR=1
    [V]GMESSAGE = mess(10,123,1)
    mkstat = 2 :End
   Endif
  Endif
  #LIPET - 2017-08-25 - X3-53555 - END

  #LIPET - 2017-09-05 - X3-54629 - START
  Call CONTLVERSN(VALEUR,[M:DCG1]TIM(nolign-1),NM) From SUBDCG2
  If NM=1:mkstat = 2:End:Endif
  #LIPET - 2017-09-05 - X3-54629 - END

#  Call LECTEXTRA([M:DCG1]LVEDES(nolign-1),"HRLVEREA","DES",VALEUR,GCURLEG) From ATEXTRA
#  Affzo [M:DCG1]LVEDES

End


