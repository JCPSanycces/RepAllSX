######################################################################################
##LIPET - 2017-08-15 - Jira - X3-52728
######################################################################################
Subprog CHECK_EXTR(CTR,TIM,STRDAT,ENDDAT,ERRMESS,CHOK)
Variable Char CTR()
Variable Char TIM
Variable Date STRDAT
Variable Date ENDDAT
Variable Char ERRMESS
Variable Integer CHOK

If clalev([F:TIM2])=0 : Local File TIMCOD  [TIM2] : Endif
If clalev([F:HRCTR2])=0  : Local File EMPLOCTR [HRCTR2]  : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
If clalev([F:PLN])=0 : Local File PLANTYP [PLN] : Endif

  Filter [F:TIM2] Where COD = TIM and  LVEENHANCE = 2
  Read [TIM2] First
  Filter [F:TIM2]
  If !fstat Then
    Filter [F:HRCTR2] Where CTRNUM = CTR
    Read [HRCTR2] First
    Filter [HRCTR2]
    If !fstat Then
      Filter [HRPEOD] Where PERCOD = [F:HRCTR2]PERCOD and PERSTR(1) >= STRDAT  and PEREND(1) <= ENDDAT
      Read [HRPEOD] Last
      Filter [HRPEOD]
      If fstat>4
        ERRMESS= mess(10,11691,1)
        CHOK=1 : End
      Endif
      If [F:HRCTR2]PLNTYP <> "" Then
          Filter [F:PLN] Where COD = [F:HRCTR2]PLNTYP and WEKTYP <> ""
          Read [PLN] First
          Filter [PLN]
          If fstat>4 Then
            ERRMESS= mess(11,11691,1)
            CHOK=1 : End
          Endif
        Else
          ERRMESS= mess(12,11691,1)
          CHOK=1 :End
      Endif
    Endif
  Endif
End
