#MIPEA SOURCE REMERGE
# Modifications :
#     SEGAY - 28/03/11 - Bug 72654
#              - Pouvoir saisir quand on n'a pas GPAYE et GTPS
#     SEGAY - 26/04/11 - Bug 71976
#           - GMOIPAY is now in 'Common module'
#     SEGAY - 11/10/11 - FQ76996 -
#   On ne teste plus les flux métiers dans CHECK_SUBORD sur le matricule
#   depuis le back-office dans la saisie des congés GESDCG(SUBDCG).
#     SEGAY - 21/10/11 - FQ77113 -
#   On ne prend pas le bon contrat pour les multicontrats lors de la maj des réguls
#     SEGAY - 27/10/11 - FQ77350 si on a
# 1/2 journée le matin dans TIP et 1/2 le matin dans DCG
# ou 1/2 journée le l'aprés midi dans TIP et 1/2 le aprés midi dans DCG
# Il y a chevauchement et donc il faut supprimer TIMEMP
#     SEGAY - 31/10/11 - FQ77494 -
#       Pour le test sur C_TIM
#       Tester les dates de début et de fin des demandes / aux bornes
#       des dates tolérées de la période de congés
#     SEGAY 15/05/12 - FQ82397
#        contrôle des demandes avec STA 2(Demande) ou 3(accepte)
#     SEGAY 25/05/12 - FQ82441
#       Pas de contrôle du solde si Portail et ACTION="ANNUL"
#     SEGAY 19/12/12 - FQ86713 - 86831
#      error message "128 trop de constante" quand on utilise find(ETRSRV,[V]GAUTSRV(1..[V]GNBSERV))<>0
#     SEGAY 19/03/13 - FQ88381
#       - Si déjà en paye on passe directement en régul
#     FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#     FQ105844 - 24/02/15 - FLGBUL devient inutile + régularisations sur temps saisis sur 1/2 journée
#     FQ106640 - 27/02/15 - si multi-contrats, le contrat le plus récent n'est pas  forcément celui en cours
######################################################################################


Raz [V]GPILOBJ, [V]GBIDC1, [V]GBIDC2, [V]GPILNAV, [V]GNBMASKOUV
#[V]GDECRCU=9
#[V]GBIDC1 ="ASN200200000014"
Call OBJET("DCG",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
#
#If GUSER = 'JOJAC'
#  Infbox ACTION
#Endif
Case [L]ACTION
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT : Gosub GRISE_AUZ : #62305
 When "FIN"          : Gosub FIN
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "FERME"        : Gosub FERME
#-------------------------------------------------------------------------------
 When "EFFMASK"      : Gosub INIFILTRE
 When "AFFMASK"      : Gosub INIFILTRE : Gosub GRISE_MAT : #62305 Gosub GRISE_AUZ
 When "RAZCRE"       : Gosub INIFILTRE : #62305 Gosub GRISE_AUZ
 When "LIENS"        : Gosub LIENS
 When "DEGRISE"      : Gosub GRISE_MAT
#-------------------------------------------------------------------------------
 When "DROIT"        : Gosub DROIT
#JASMI - START
# When "FILTRE"       : [L]FILTSUP="FLGTPS=2 & NBRCTR>0"
 When "FILTRE"       : [L]FILTSUP="[F:ID]FLGTPS=2 & [F:ID]NBRCTR>0"
#JASMI - END
 When "EXEACT"       : Gosub EXEACT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "STATUT"       : Gosub STATUT
 When "AVANT_VERROU" : [L]SYMBOLE="DCG"+right$([L]SYMBOLE,4)
 When "ABANDON"      : Gosub GRISE_AUZ
#-------------------------------------------------------------------------------
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "FIN_MOD"      : Gosub FIN_MOD
 When "INIMOD"       : Read [ID] =
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AB_MODIF"     : Call DELOCK("TPS") From GLOCK : Affzo [DCG1] 30
#-------------------------------------------------------------------------------
 When "SEL_TABLE"
  Case [L]COUZON
   When "TIM"        : Gosub S_TIM
  Endcase
 When "STYLE"        : Gosub STYLE
Endcase

#JOJAC - 2017-07-02 - START
#If ACTION = "OUVRE"
If func AFNC.ACTIV("FUKGL")
  If func DIVPAYE.IS_BRI_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBDCGUKI") Then
      Gosub ACTION From SUBDCGUKI
  Endif
Endif
#Endif
#JOJAC - 2017-07-02 - END

Return

