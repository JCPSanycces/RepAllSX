########################################
Subprog C_ENDDAY(VALEUR)
Variable Integer VALEUR
Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET)
If !WRET
  mkstat     =2
  End
Endif

#73242 On a inversé les colonnes STRDAY et ENDDAY . Les contrôles sont déplacés dans CONTROLE_DATE
# et appelés par C_STRDAY
End
##################################################################
# Ancien contenu de C_ENDDAY
Subprog CONTROL_DATE(FLG_AFTERNOON,FLG_MORNING)
Variable Integer FLG_AFTERNOON   : # ENDDAY
Variable Integer FLG_MORNING     : # STRDAY

Local Shortint L_I, L_J, L_K

[L]L_I=FLG_MORNING
[L]L_J=FLG_AFTERNOON
If [L]L_J=2 & [L]L_I=2 & [M:DCG1]STRDAT(nolign-1)=[M:DCG1]ENDDAT(nolign-1) : [L]L_I=1 : [L]L_J=1 : Endif : # 73242 ligne non modifiée

If [M:DCG1]STA0(nolign-1)<3 & [M:DCG1]STA(nolign-1)<4

 # / 72113 pas de contrôle dans la paye si paye absente
 If GPAYE
  # CONTROLE DE L'ECRAN COURANT
  For L_K=0 To [M:DCG1]NBLIG-1
   If L_K<>nolign-1 & find([M:DCG1]STA(L_K),1,2,3,5,7)
&    & ( [M:DCG1]STRDAT(L_K)<[M:DCG1]ENDDAT(nolign-1)
&    |  ([M:DCG1]STRDAT(L_K)=[M:DCG1]ENDDAT(nolign-1) & ([M:DCG1]ENDDAY(L_K)<2 | [L]L_I<2))
&        )
&    & ( [M:DCG1]ENDDAT(L_K)>[M:DCG1]STRDAT(nolign-1)
&    |  ([M:DCG1]ENDDAT(L_K)=[M:DCG1]STRDAT(nolign-1) & ([M:DCG1]STRDAY(L_K)<2 | [L]L_J<2))
&        )
&    & uni([M:DCG1]CTRNUM(nolign-1),[M:DCG1]CTRNUM(L_K),"")

   # Chevauchement refusé si la demande concerne une paie non arrêtée dans les temps
    Filter [VEP] Where EMP=[M:DCG1]REFNUM & (CTRNUM=[M:DCG1]CTRNUM(nolign-1) | [M:DCG1]CTRNUM(nolign-1)="")
&   & STRDAT<=[M:DCG1]STRDAT(nolign-1) & ENDDAT>=[M:DCG1]ENDDAT(nolign-1)
    Read [VEP]VEP0 Last
    Filter [VEP]
    If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
     # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE=func AFNC.MES1(mess(169,10709,1),num$(L_K+1))
#     [V]GMESSAGE=func AFNC.MES1(mess(169,709,1),num$(L_K+1)) : # Chevauchement avec la ligne $1$
#MIPEA - 2016-12-15 - X3-12089- END
     mkstat     =2
     Break
    Endif
   Endif
  Next
  If mkstat : End : Endif

  # CONTROLE DES ABSENCES AUX MEMES DATES
  For [DCG] Where REFNUM=[M:DCG1]REFNUM & UID>0 & STA<>4 & STA<>6
&               & STRDAT<=[M:DCG1]ENDDAT(nolign-1)
&               & ENDDAT>=[M:DCG1]STRDAT(nolign-1)
&               & find(UID,[M:DCG1]DELUID(0..[M:DCG1]NBDEL-1))=0
&               & find(UID,[M:DCG1]UID(0..[M:DCG1]NBLIG-1))=0


#bug 74580
# Chevauchement autorisé si pour la même date
# ligne DCG a une 1/2 journée # de la 1/2 journée de la ligne en cours
   If uni([M:DCG1]CTRNUM(nolign-1),[F:DCG]CTRNUM,"")
&      & ( [F:DCG]STRDAT<[M:DCG1]ENDDAT(nolign-1)
&      |  ([F:DCG]STRDAT=[M:DCG1]ENDDAT(nolign-1) & ([F:DCG]ENDDAY<2 | [L]L_I<2))
&          )
&      & ( [F:DCG]ENDDAT>[M:DCG1]STRDAT(nolign-1)
&      |  ([F:DCG]ENDDAT=[M:DCG1]STRDAT(nolign-1) & ([F:DCG]STRDAY<2 | [L]L_J<2))
&    )


    # 59187 - Pas si fonction calcul du portail
#    If !GWEBSERV | ACTPOR <> "CAL"
 # FQ82441 - 25/05/12 -   Test existance globale ACTPOR
    If !GWEBSERV | (dim(ACTPOR) >= 0 & ACTPOR <> "CAL")
     # Chevauchement refusé si la demande concerne une paie non arrêtée dans les temps
     Filter [VEP] Where EMP=[F:DCG]REFNUM & (CTRNUM=[F:DCG]CTRNUM | [F:DCG]CTRNUM="")
&    & STRDAT<=[F:DCG]STRDAT & ENDDAT>=[F:DCG]ENDDAT
     Read [VEP]VEP0 Last
     Filter [VEP]
     If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
      # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
#MIPEA - 2016-12-15 - X3-12089- START
      [V]GMESSAGE=mess(174,10709,1)-"("+num$([F:DCG]DEM)+")"
#      [V]GMESSAGE=mess(174,709,1)-"("+num$([F:DCG]DEM)+")" : # Chevauchement avec d'autres demandes de congé
#MIPEA - 2016-12-15 - X3-12089- END
      mkstat     =2
      Break
     Endif
    Endif
   Endif
  Next
  If mkstat : End : Endif

  ## Si RTE saisi à une date future
  For [TIP]TIP1 Where REFNUM=[M:DCG1]REFNUM & STRDAT<=[M:DCG1]ENDDAT(nolign-1)
&                   & ENDDAT>=[M:DCG1]STRDAT(nolign-1)
&                   & DCGUID=0
   If find([M:DCG1]CTRNUM(nolign-1),"",[F:TIP]CTRNUM)
&    & ( [F:TIP]STRDAT<[M:DCG1]ENDDAT(nolign-1)
&    |  ([F:TIP]STRDAT=[M:DCG1]ENDDAT(nolign-1) & ([F:TIP]STRDAY<2 | [L]L_I<2))
&        )
&    & ( [F:TIP]ENDDAT>[M:DCG1]STRDAT(nolign-1)
&    |  ([F:TIP]ENDDAT=[M:DCG1]STRDAT(nolign-1) & ([F:TIP]ENDDAY<2 | [L]L_J<2))
&        )

    Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT
    #JASMI - 2017-07-13 - X3-48882 - START
#   Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT
    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
      Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:TIP]DATPYR
    Else
      Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT
    Endif
#JASMI - 2017-07-13 - X3-48882 - END

    Read [VEP]VEP0 Last
    Filter [VEP]
    If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
     # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
#MIPEA - 2016-12-09 - X3-12089- START
    Read [TIM]TIM0=GCURLEG;[F:TIP]TIM
#     Read [TIM]TIM0=[F:TIP]TIM
#MIPEA - 2016-12-09 - X3-12089- END
#MIPEA - 2016-12-15 - X3-12089- START

     [V]GMESSAGE =format$([V]GFMD,[F:TIP]STRDAT)
&            - string$([F:TIP]STRDAT<>[F:TIP]ENDDAT,"->"-format$([V]GFMD,[F:TIP]ENDDAT))
&            - ":"-func AFNC.MES1(mess(192,10709,1),[F:TIP]TIM)
#     [V]GMESSAGE =format$([V]GFMD,[F:TIP]STRDAT)
#&            - string$([F:TIP]STRDAT<>[F:TIP]ENDDAT,"->"-format$([V]GFMD,[F:TIP]ENDDAT))
#&            - ":"-func AFNC.MES1(mess(192,709,1),[F:TIM]DES)
#MIPEA - 2016-12-15 - X3-12089- END
     #            Evènement $1$ déjà saisi pour cette date
     mkstat = 2
     Break
    Endif
   Endif
  Next
  If mkstat : End : Endif
 Endif

 # On interdit la saisie d'une demande sur une période qui a des régularisations
 If GTPS=1
  For [TIG]TIG1 Where REFNUM=[M:DCG1]REFNUM & STRDAT<=[M:DCG1]ENDDAT(nolign-1)
&                   & ENDDAT>=[M:DCG1]STRDAT(nolign-1)
#SAVAN - 2018/02/21 -X3-77172 start - Excluding Cancelled Accepted transactions from the checks for re-entry in DCG
#If clalev([F:DCGCONTD])=0 : Local File DEMCONGE [DCGCONTD] : Endif
#Local Integer CONTDCHK
#  CONTDCHK=0
##CHeck for the [TIG]DCGUID that exists where it is cancelled accepted and not to be included in the checks
#Filter [F:DCGCONTD] Where [F:TIG]DCGUID=[F:DCGCONTD]LNK & [F:DCGCONTD]STA=6
#  Read [F:DCGCONTD] First
#If !fstat
#  CONTDCHK=1
#Endif
#Filter [F:DCGCONTD]
#SAVAN - 2018/02/21 -X3-77172 end -  Excluding Cancelled Accepted transactions from the checks for re-entry in DCG
#SAVAN - 2018/02/21 -X3-77172 start -  Excluding Cancelled Accepted transactions from the checks for re-entry in DCG TIG Change
#   If find([M:DCG1]CTRNUM(nolign-1),"",[F:TIG]CTRNUM)
#&   & ( [F:TIG]STRDAT<[M:DCG1]ENDDAT(nolign-1) & CONTDCHK<>1
#&     | ([F:TIG]STRDAT=[M:DCG1]ENDDAT(nolign-1) & ([F:TIG]ENDDAY<2 | [L]L_I<2) & CONTDCHK<>1)
#&     )
#&   & ( [F:TIG]ENDDAT>[M:DCG1]STRDAT(nolign-1) & CONTDCHK<>1
#&     | ([F:TIG]ENDDAT=[M:DCG1]STRDAT(nolign-1) & ([F:TIG]STRDAY<2 | [L]L_J<2) & CONTDCHK<>1)
#&     )
   If find([M:DCG1]CTRNUM(nolign-1),"",[F:TIG]CTRNUM)
&   & ( [F:TIG]STRDAT<[M:DCG1]ENDDAT(nolign-1)
&     | ([F:TIG]STRDAT=[M:DCG1]ENDDAT(nolign-1) & ([F:TIG]ENDDAY<2 | [L]L_I<2))
&     )
&   & ( [F:TIG]ENDDAT>[M:DCG1]STRDAT(nolign-1)
&     | ([F:TIG]ENDDAT=[M:DCG1]STRDAT(nolign-1) & ([F:TIG]STRDAY<2 | [L]L_J<2))
&     )
#SAVAN - 2018/02/21 -X3-77172 end -  Excluding Cancelled Accepted transactions from the checks for re-entry in DCG TIG Change

#MIPEA - 2016-12-19 - X3-12089- START
#SAVAN - 2018/01/26 - start changed for the control on the dates
    Read [TIM]TIM0=GCURLEG;[F:TIG]TIM
    #Read [TIM]TIM0=GCURLEG;[F:TIP]TIM
#SAVAN - 2018/01/26 - end changed for the control on the dates
#     Read [TIM]TIM0=[F:TIP]TIM
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE =format$([V]GFMD,[F:TIG]STRDAT)
&              - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$([V]GFMD,[F:TIG]ENDDAT))
&              - ":"-func AFNC.MES1(mess(170,10709,1),[F:TIG]TIM)
#SAVAN - 2018/01/26 - start changed for the control on the dates
               #- ":"-func AFNC.MES1(mess(170,10709,1),[F:TIP]TIM)
#SAVAN - 2018/01/26 - end changed for the control on the dates
#    [V]GMESSAGE =format$([V]GFMD,[F:TIG]STRDAT)
#&              - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$([V]GFMD,[F:TIG]ENDDAT))
#&              - ":"-func AFNC.MES1(mess(170,709,1),[F:TIM]DES)
#MIPEA - 2016-12-15 - X3-12089- END
    #          Evènement $1$ déjà régularisé pour cette date \ Passer une régularisation
    mkstat=2
    Break
   Endif
  Next
  If mkstat : End : Endif
 Endif
Endif

#If J<>[L]VALEUR                : # 73242 ligne non modifiée
# [L]VALEUR               =1
# [M:DCG1]STRDAY(nolign-1)=1
#Affzo [DCG1] STRDAY(nolign-1)
If [L]L_J<>FLG_AFTERNOON
 FLG_AFTERNOON = 1
 FLG_MORNING   = 1
Endif

End

########################################
$S_TIM
[L]OBJET  ="TIM"
[L]CRITERE="find(CATTIM,2,3)<>0"-string$([V]GTPS,"& CTLDAC<>2")
Return

########################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
Local Char ERRMESS(255)
Local Integer CHOK : CHOK=0
#LIPET - 2017-08-15 - X3-52728 - START
  If func AFNC.ACTIV("GLM")
    Call CHECK_EXTR([M]CTRNUM(nolign-1),VALEUR,[M]STRDAT(nolign-1),[M]ENDDAT(nolign-1),ERRMESS,CHOK)
    If CHOK=1:GERR=1:GMESSAGE=ERRMESS:mkstat=2:End:Endif
  Endif
#LIPET - 2017-08-15 - X3-52728 - END

Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET)
If !WRET
  mkstat     =2
  End
Endif

Local Integer I, N, J , F
Local Decimal NBJ, NBRDAY, SOLNEG , D

Local Date    DEB, FIN
Local Date    DEBTOL, FINTOL

Local Char    VALPAR(20)

Local Char     AM(4), PM(4), C(1)
#MIPEA - 2016-12-15 - X3-12089- START
Local Char L_CTRNUM(GLONHRCTR)
#Local Char L_CTRNUM(GLONCTR) # fiche 72061 - 07/03/2011
#MIPEA - 2016-12-15 - X3-12089- END

N=[M:DCG1]ENDDAT(nolign-1)-[M:DCG1]STRDAT(nolign-1)+1
Local Decimal JOUR(1..N), HEURE(1..N), JOUR2(1..N)

# 77853 14/11/11
If GTPS=1
  If clalev([F:PLE])=0  : Local File PLANEMP   [PLE]  : Endif
Endif
If clalev([F:HLY])=0  : Local File HLYDAY    [HLY]  : Endif
# END 77853 14/11/11

If [F:TIM]COD <> VALEUR   : # pour appel depuis AM_STA
#MIPEA - 2016-12-19 - X3-12089- START
 Read [F:TIM]TIM0 = GCURLEG;VALEUR
# Read [F:TIM]TIM0 = VALEUR
 #MIPEA - 2016-12-19 - X3-12089- END
Endif

Call CONTEXE([F:TIM]ACS) From CPTSUB
If mkstat : End : Endif

# FQ74044 - 13/02/12 - Ajout vérification du nouveau champ FILTRE
If dim(ACTPOR) >= 0 and  ACTPOR="ANNUL" Then
  # Pas de contrôle si Portail est ACTION="ANNUL"
Else
  If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
    Local Integer RET
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M:DCG1]REFNUM,[M:DCG1]CTRNUM(nolign-1),RET) From DIVPAYE
    If RET>0 Then
#MIPEA - 2017-10-20- US X3-60665- START
      GMESSAGE=[F:TIM]COD-":"-mess(220,10709,1) : # Nature d'événement incompatible avec ce salarié
#      GMESSAGE=[F:TIM]COD-":"-mess(320,199,1) : # Nature d'événement incompatible avec ce salarié
#MIPEA - 2017-10-20- US X3-60665- END
      mkstat=2 : End
    Endif
  Endif
Endif

If ([V]GWEBSERV & [F:TIM]AUZPRH<2)
&| ( ![V]GWEBSERV
&  & (!find([F:TIM]CATTIM,2,3) | ([V]GTPS & [F:TIM]CTLDAC=2))
&  )
 [V]GMESSAGE=mess(83,123,1) : # Valeur incorrecte
 mkstat     =2
 End
Endif

If [F:TIM]DAYDAC<2 & eomonth([M:DCG1]STRDAT(nolign-1))<>eomonth([M:DCG1]ENDDAT(nolign-1))
#MIPEA - 2016-12-15 - X3-12089- START
  [V]GMESSAGE=mess(186,10709,1)
# [V]GMESSAGE=mess(186,709,1)
#MIPEA - 2016-12-15 - X3-12089- END
 #           Les dates de début et de fin des évènements saisis en heures doivent être
 #           sur le même mois de paye
 mkstat     =2
 End
Endif

# 77853 14/11/11
# les paramètres de l'appel à PARAM sont inversés
If val(func AFNC.PARAM("CPOUVRA",""))=2
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
 For [HRCTR]CTR0(2) Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&                     & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
&                     & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]ENDDAT(nolign-1))
  If [L]VALEUR=func AFNC.PARAM("CPA",[F:HRCTR]ETRFCY)
&  & func TPSSTD1.OUVRABLE([M:DCG1]REFNUM,[M:DCG1]ENDDAT(nolign-1)+1,[F:HRCTR]CTRNUM)
# For [CTR]CTR0(2) Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
#&                     & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
#&                     & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]ENDDAT(nolign-1))
#  If [L]VALEUR=func AFNC.PARAM("CPA",[F:CTR]ETRFCY)
#&  & func TPSSTD1.OUVRABLE([M:DCG1]REFNUM,[M:DCG1]ENDDAT(nolign-1)+1,[F:CTR]CTRNUM)
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-15 - X3-12089- START
    Call AVERTIR(mess(70,10709,1),I) From GESECRAN
#   Call AVERTIR(mess(70,709,1),I) From GESECRAN : # Reprise d'activité un jour ouvrable
#MIPEA - 2016-12-15 - X3-12089- END
   If I<>2 : mkstat=2 : Endif
   Break
  Endif
 Next
 If mkstat : End : Endif
Endif

# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
Local Date DATDEBCTR
#MIPEA - 2016-12-19 - X3-12089- START
For [HRCTR]CTR0(2) Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&                    & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
&                    & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
 Raz [L]JOUR
 For [HRCTR]CTR0
  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  DATDEBCTR=[F:HRCTR]CTRDAT
  If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
   DATDEBCTR=[F:HRCTR]RETDATEFF
  Endif
  [L]DEB=max([M:DCG1]STRDAT(nolign-1),DATDEBCTR)
  If [F:HRCTR]XITDAT=[0/0/0] : [L]FIN=[M:DCG1]ENDDAT(nolign-1)
  Else                       [L]FIN=min([M:DCG1]ENDDAT(nolign-1),[F:HRCTR]XITDAT)
  Endif

  I=[L]DEB-[M:DCG1]STRDAT(nolign-1)+1
  Raz [L]JOUR2
  If [F:HRCTR]PLNTYP=""
   For J=I To N : [L]JOUR2(J)=1 : Next
  Else
   Call VALORDET( [L]DEB,[L]FIN,[M:DCG1]REFNUM,[L]VALEUR,[L]JOUR2(I..N),[L]HEURE(I..N)
&               , [F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM
&               ) From SUBPLN
  Endif
#For [CTR]CTR0(2) Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
#&                    & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
#&                    & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
# Raz [L]JOUR
# For [CTR]CTR0
#  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#  DATDEBCTR=[F:CTR]CTRDAT
#  If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#   DATDEBCTR=[F:CTR]RETDATEFF
#  Endif
#  [L]DEB=max([M:DCG1]STRDAT(nolign-1),DATDEBCTR)
#  If [F:CTR]XITDAT=[0/0/0] : [L]FIN=[M:DCG1]ENDDAT(nolign-1)
#  Else                       [L]FIN=min([M:DCG1]ENDDAT(nolign-1),[F:CTR]XITDAT)
#  Endif
#
#  I=[L]DEB-[M:DCG1]STRDAT(nolign-1)+1
#  Raz [L]JOUR2
#  If [F:CTR]PLNTYP=""
#   For J=I To N : [L]JOUR2(J)=1 : Next
#  Else
#   Call VALORDET( [L]DEB,[L]FIN,[M:DCG1]REFNUM,[L]VALEUR,[L]JOUR2(I..N),[L]HEURE(I..N)
#&               , [F:CTR]ETRFCY,[F:CTR]CTRNUM
#&               ) From SUBPLN
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
# Si on a pas les temps on ne gère pas les plages horaires
# On se contente des nombres renvoyés par le VALORDET ci-dessus
  If GTPS : # 69211

#  73242 If [M:DCG1]STRDAY(nolign-1)=2 & [L]DEB=[M:DCG1]STRDAT(nolign-1)
  If [M:DCG1]ENDDAY(nolign-1)=2 & [L]DEB=[M:DCG1]STRDAT(nolign-1)
   # On divise si il existe plus d'une plage dans le planning
#MIPEA - 2016-12-19 - X3-12089- START
   Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,F,D,[L]AM,C,[L]PM
&                   , C,C,C
&                   ) From PORTPS
#   Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,F,D,[L]AM,C,[L]PM
#&                   , C,C,C
#&                   ) From PORTPS   : # 62965
#MIPEA - 2016-12-19 - X3-12089- END
   If [L]AM<>"" & [L]PM<>""
    [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
    [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))
   Endif
   If [L]PM = ""
    F = 1
    If !GWEBSERV
#MIPEA - 2016-12-15 - X3-12089- START
    Call AVERTIR(mess(194,10709,1),F) From GESECRAN
#     Call AVERTIR(mess(194,709,1),F) From GESECRAN : # La demi-journée posée est chômée
#MIPEA - 2016-12-15 - X3-12089- END
     [L]HEURE(1)=0
     [L]JOUR2(1)=0
    Endif
    If F<>2
     mkstat = 2
    Endif
   Endif
  Endif

# 73242  If [M:DCG1]ENDDAY(nolign-1)=2 & [L]FIN=[M:DCG1]ENDDAT(nolign-1)
  If [M:DCG1]STRDAY(nolign-1)=2 & [L]FIN=[M:DCG1]ENDDAT(nolign-1)
#MIPEA - 2016-12-19 - X3-12089- START
   Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,F,D,[L]AM,C,[L]PM
&                 , C,C,C
&                 ) From PORTPS
#   Call GETSEMTYP( [F:CTR]PLNTYP,[F:CTR]REFNUM,[F:CTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,F,D,[L]AM,C,[L]PM
#&                 , C,C,C
#&                 ) From PORTPS   : # 62965
#MIPEA - 2016-12-19 - X3-12089- END

   If [L]AM<>"" & [L]PM<>""
   [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
   [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
   Endif

   If [L]AM = ""
    F = 1
    If !GWEBSERV
#MIPEA - 2016-12-15 - X3-12089- START
    Call AVERTIR(mess(194,10709,1),F) From GESECRAN
#     Call AVERTIR(mess(194,709,1),F) From GESECRAN : # La demi-journée posée est chômée
#MIPEA - 2016-12-15 - X3-12089- END
     [L]HEURE(N)=0
     [L]JOUR2(N)=0
    Endif
    If F<>2
     mkstat = 2
    Endif
   Endif

  Endif

  Else : # 69211

#   73242 If [M:DCG1]STRDAY(nolign-1)=2
   If [M:DCG1]ENDDAY(nolign-1)=2
    [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
    [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))
   Endif

#73242   If [M:DCG1]ENDDAY(nolign-1)=2
   If [M:DCG1]STRDAY(nolign-1)=2
    [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
    [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
   Endif

  Endif

  If [F:TIM]CATTIM=3
   If [F:TIM]FLGBLC=2 & [M:DCG1]STA(nolign-1) <> 1
    Raz I, [L]NBJ
    Raz [L]DEBTOL, [L]FINTOL
#MIPEA - 2016-12-19 - X3-12089- START
    Link [CNG] With [F:CNE]CNE0=YEA;[M:DCG1]REFNUM;[F:HRCTR]CTRNUM;TIM As [LNK]
#    Link [CNG] With [F:CNE]CNE0=YEA;[M:DCG1]REFNUM;[F:CTR]CTRNUM;TIM As [LNK]
#MIPEA - 2016-12-19 - X3-12089- END
#JASMI - 2014/08/31 - START
#    For [LNK]CNG0 Where CPY=func DIVPAYE.GETSOC([F:CTR]ETRFCY) & TIM=[L]VALEUR
#&                     & FINDAT>=[L]DEB & DEBDAT<=[L]FIN
    Local Char     CRITERIA(100)
#MIPEA - 2016-12-19 - X3-12089- START
    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#    If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-19 - X3-12089- END
      CRITERIA = '[F:CNE]EMPLEAEND>=[L]DEB & [F:CNE]EMPLEASTR<=[L]FIN'
    Else
      CRITERIA = 'FINDAT>=[L]DEB & DEBDAT<=[L]FIN'
    Endif
#MIPEA - 2016-12-19 - X3-12089- START
    For [LNK]CNG0 Where CPY=func DIVPAYE.GETSOC([F:HRCTR]ETRFCY) & TIM=[L]VALEUR
&                     & evalue(CRITERIA)
#    For [LNK]CNG0 Where CPY=func DIVPAYE.GETSOC([F:CTR]ETRFCY) & TIM=[L]VALEUR
#&                     & evalue(CRITERIA)
#MIPEA - 2016-12-19 - X3-12089- END
#JASMI - 2014/08/31 - END
     If [F:CNE]TIM<>VALEUR
#MIPEA - 2016-12-15 - X3-12089- START
      GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA)
#      GMESSAGE = mess(165,709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
#MIPEA - 2016-12-15 - X3-12089- END
      mkstat = 2 : Break 3
     Endif
#JASMI - 2016-07-22 - ISSUE 117750 - START
#     [L]NBJ+=[F:CNE]NBRDAY-[F:CNE]NBRPRI
     [L]NBJ+=[F:CNE]NBRDAY # days are deducted from the holiday requests detail
#JASMI - 2016-07-22 - ISSUE 117750 - END
     I      =1
     # fiche 77494 - 31/10/2011
#JASMI - 2014/08/31 - START
#     If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNG]DEBDAT
#       [L]DEBTOL = [F:CNG]DEBDAT
#     Endif
#     If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNG]FINDAT
#       [L]FINTOL = [F:CNG]FINDAT
#     Endif
#MIPEA - 2016-12-19 - X3-12089- START
     If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#     If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-19 - X3-12089- END
      If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNE]EMPLEASTR
        [L]DEBTOL = [F:CNE]EMPLEASTR
      Endif
      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNE]EMPLEAEND
        [L]FINTOL = [F:CNE]EMPLEAEND
      Endif
     Else
      If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNG]DEBDAT
        [L]DEBTOL = [F:CNG]DEBDAT
      Endif
      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNG]FINDAT
        [L]FINTOL = [F:CNG]FINDAT
      Endif
     Endif
#JASMI - 2014/08/31 - END
     # END 77494 - 31/10/2011
    Next
    If I
      [L]NBJ-=sum([L]JOUR2)
     # fiche 72061 - 07/03/2011 : ajout du test sur le contrat
     # fiche 77494 - 31/10/2011
     # FQ82397 - 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)
     # SAVAN X3-60378 - start
     #For [F:DCG] Where REFNUM=[M:DCG1]REFNUM & (STA=2 or STA=3) & UID>0 & UID<>[M:DCG1]UID(nolign-1)
     # SAVAN X3-60378 - start
     For [F:DCG] Where REFNUM=[M:DCG1]REFNUM & (STA=2 or STA=3 or STA=5 or STA=7) & UID>0 & UID<>[M:DCG1]UID(nolign-1)
&                    & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&                    & TIM=[L]VALEUR
&                    & ((STRDAT >= [L]DEBTOL & STRDAT <= [L]FINTOL )
&                     | (ENDDAT <= [L]FINTOL & ENDDAT >= [L]DEBTOL))
&                    & !find(UID,[M:DCG1]UID)  : # on regardera l'écran après
# END 77494 - 31/10/2011
      [L]NBJ-=[F:DCG]NBRDAY
     Next

     # On inclue les autres nouvelles lignes de la saisie courante
     For F = 0 To [M:DCG1]NBLIG-1
       # fiche 72061 - 07/03/2011 : ajout du test sur le contrat
       # fiche 77494 - 31/10/2011
 #MIPEA - 2016-12-19 - X3-12089- START
       If F <> nolign-1 & [M:DCG1]TIM(F) = VALEUR & find([M:DCG1]STA(F),2,3)
&      and ([M:DCG1]CTRNUM(F) = "" or [M:DCG1]CTRNUM(F) = [F:HRCTR]CTRNUM)
&      and (([M:DCG1]STRDAT(F) >= [L]DEBTOL & [M:DCG1]STRDAT(F) <= [L]FINTOL )
&         | ([M:DCG1]ENDDAT(F) <= [L]FINTOL & [M:DCG1]ENDDAT(F) >= [L]DEBTOL))
#       If F <> nolign-1 & [M:DCG1]TIM(F) = VALEUR & find([M:DCG1]STA(F),2,3)
#&      and ([M:DCG1]CTRNUM(F) = "" or [M:DCG1]CTRNUM(F) = [F:CTR]CTRNUM)
#&      and (([M:DCG1]STRDAT(F) >= [L]DEBTOL & [M:DCG1]STRDAT(F) <= [L]FINTOL )
#&         | ([M:DCG1]ENDDAT(F) <= [L]FINTOL & [M:DCG1]ENDDAT(F) >= [L]DEBTOL))
#MIPEA - 2016-12-19 - X3-12089- END
# END 77494 - 31/10/2011
        [L]NBJ-=[M:DCG1]NBRDAY(F)
       Endif
     Next

     #64506
     #[L]SOLNEG=min([L]SOLNEG,[L]NBJ)
     [L]SOLNEG=[L]NBJ
#MIPEA - 2016-12-19 - X3-12089- START
     [L]L_CTRNUM = [F:HRCTR]CTRNUM
#     [L]L_CTRNUM = [F:CTR]CTRNUM # fiche 72061 - 07/03/2011
#MIPEA - 2016-12-19 - X3-12089- START
    Else
#MIPEA - 2017-10-20- US X3-60665- START
     GMESSAGE -= '\'-mess(240,10709,1)-[F:TIM]COD  : # Fiche période de congé inexistante pour l'évènement
#     GMESSAGE -= '\'-mess(319,199,1)-[F:TIM]COD  : # Fiche période de congé inexistante pour l'évènement
#MIPEA - 2017-10-20- US X3-60665- END
     mkstat = 2 : Break 2
    Endif
   Endif
  Endif

  For I=1 To N
#73242   If (I=1 & [M:DCG1]STRDAY(nolign-1)=2) | (I=N & [M:DCG1]ENDDAY(nolign-1)=2)
   If (I=1 & [M:DCG1]ENDDAY(nolign-1)=2) | (I=N & [M:DCG1]STRDAY(nolign-1)=2)
    [L]NBJ=0.5
   Else
    [L]NBJ=1
   Endif
   If [L]JOUR(I)+[L]JOUR2(I)<=[L]NBJ : [L]JOUR(I)+=[L]JOUR2(I) : Endif
  Next
 [L]NBRDAY=max([L]NBRDAY,sum([L]JOUR))
 # fiche 72061 - 07/03/2011 : on s'arrête au premier solde négatif
 If [F:TIM]FLGBLC=2 & [L]SOLNEG<[F:TIM]BLCMIN
   Break 2
 Endif
 Next
Next

If mkstat=2 : End : Endif

If dim(ACTPOR) >= 0 & ACTPOR="ANNUL"
 # FQ82441 - 25/05/12 -   Pas de contrôle du solde si Portail et ACTION="ANNUL"
Else
  If [F:TIM]FLGBLC=2 and [L]SOLNEG<[F:TIM]BLCMIN
 # fiche 72061 - 07/03/2011 : ajout du contrat pour plus de clarté (quand multi-contrat)
#MIPEA - 2016-12-15 - X3-12089- START
    GMESSAGE = mess(118,10709,1)-":"-num$([L]SOLNEG)-"("+mess(72,10720,1)-L_CTRNUM+")"
#   GMESSAGE = mess(118,709,1)-":"-num$([L]SOLNEG)-"("+mess(72,720,1)-L_CTRNUM+")"
#MIPEA - 2016-12-15 - X3-12089- END
   mkstat = 2 : End
  Endif
Endif

[M:DCG1]NBRDAY(nolign-1)=[L]NBRDAY
[M:DCG1]NBRHOU(nolign-1)=sum([L]HEURE)

Affzo [DCG1] NBRDAY(nolign-1), NBRHOU(nolign-1)

#56914
If VALEUR<>[M:DCG1]TIM(nolign-1)
 [M:DCG1]TYPPGN(nolign-1)=0
Endif

#JASMI - 2017-10-20 - XXX - START
#JOJAC - 2017-10-26 - X3-15908 - START
If func AFNC.ACTIV("GLM") and (GCURLEG<>'BRI')
#If func AFNC.ACTIV("GLM")
#JOJAC - 2017-10-26 - X3-15908 - END
  If [M:DCG1]UID(nolign-1)=0
    [M:DCG1]STA(nolign-1)=3
    #JOJAC - 2017-10-26 - X3-15908 - START
    #Gosub SPLIT_THIS_DUMMY From SUBDCGGLM
    #SAVAN 2018/01/11 start
    #Call SPLIT_THIS_DUMMY(VALEUR) From SUBDCGGLM
    #SAVAN 2018/01/11 end
    #JOJAC - 2017-10-26 - X3-15908 - END
  Endif
Endif
#JASMI - 2017-10-20 - XXX - END

#CHSUL - 2018-02-05 - X3-75456 START
If func AFNC.ACTIV("FUKGL")
  If func DIVPAYE.IS_BRI_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBDCGSPP") Then
    OK = func SUBDCGSPP.VALIDATE_SPP_DATES([M:DCG1]STRDAT(nolign-1), [M:DCG1]ENDDAT(nolign-1), VALEUR)
    If OK = 0 Then: GERR = 1 : zonsui = "[M:DCG1]STRDAT(" + num$(nolign-1)+ ")" : Endif
  Endif
Endif
#CHSUL - 2018-02-05 - X3-75456 END

End

