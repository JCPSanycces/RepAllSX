#FRLAA 2018-08-15 X3-104072 - START
If func AFNC.ACTIV("GLM")
#Kill global variables
  If dim(GCTRNUMPER)>0
    Kill GCTRNUMPER
  Endif
  If dim(GCTREXTRPER)>0
    Kill GCTREXTRPER
  Endif
