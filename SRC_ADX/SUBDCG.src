Subprog ALTERFIELD(ALTFIELD,ALT,CHANGEWITH)
Value Char ALTFIELD, ALT, CHANGEWITH

If func AFNC.ACTIV("FUKGL")
  If func DIVPAYE.IS_BRI_LEG(GCURLEG)
    If DCGUKINBLIG = -1
      Chgfmt ALTFIELD   With CHANGEWITH
    Else
      If [M:DCG1]SXPCAT(DCGUKINBLIG) = ALT
        Chgfmt ALTFIELD   With CHANGEWITH
      Else
        Chgfmt ALTFIELD   With '-'+CHANGEWITH
      Endif
    Endif
  Else
    Chgfmt ALTFIELD  With '-'+CHANGEWITH
  Endif
Endif

End

