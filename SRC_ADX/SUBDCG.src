Subprog C_2PLAGES(DAT)
Value Date DAT
Local Integer AN, SEM, I
Local Date    SEM0, SEM1

Call DAT([L]DAT,[L]AN,[L]SEM) From SUBPLN
Call SEMAINE([L]AN,0,[L]SEM0,[L]SEM1) From SUBPLN
I=mod([L]DAT-[L]SEM0,7)

# FQ85820 - 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
Link [HRCTR] With [PLN]PLN0=[L]AN;PLNTYP;GCURLEG
&             , [WTY]WTY0=GCURLEG;[PLN]WEKTYP([L]SEM-1)
&            As [LNK]
&         Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
&             & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT)) & (XITDAT=[0/0/0] | XITDAT>=[L]DAT)
&             & ([WTY]STRTIM1(I)="" | ([V]GNBHOR=3 & [WTY]STRTIM2(I)>""))
#Link [CTR] With [PLN]PLN0=[L]AN;PLNTYP
#&             , [WTY]WTY0=[PLN]WEKTYP([L]SEM-1)
#&            As [LNK]
#&         Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
#&             & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT)) & (XITDAT=[0/0/0] | XITDAT>=[L]DAT)
#&             & ([WTY]STRTIM1(I)="" | ([V]GNBHOR=3 & [WTY]STRTIM2(I)>""))
#MIPEA - 2016-12-19 - X3-12089- END

If [V]GNBHOR=1 | rowcount([LNK])
#MIPEA - 2016-12-15 - X3-12089- START
  [V]GMESSAGE=mess(181,10709,1)
# [V]GMESSAGE=mess(181,709,1) : # Cette journée ne contient pas 2 plages horaires
#MIPEA - 2016-12-15 - X3-12089- END
 mkstat     =2
Endif

End

########################################
Subprog C_NBLIG

If !nolign : End : Endif
Gosub DROIT
Local Shortint I, J

#Split the code and added the modification check on the field level
Case status
When 65,68,83
  If status=65
    J=nolign-1
## PEVAN 2017-08-29 X3-53672 START
    If func AFNC.ACTIV("GLM")
      Raz [M:DCG1]WLVESUBTYP
      Raz [M:DCG1]WLVESUBBAL
      Raz [M:DCG1]WNBRHOU
      Raz [M:DCG1]WLVESUBRAT
      Raz [M:DCG1]LVERATDES
      [M:DCG1]LVESUBNNR = 0
      Affzo [M:DCG1]45
    Endif
## PEVAN 2017-08-29 X3-53672 END
  Else J=nolign1-1 : Endif
 For I=nolign-1 To J
  If [M:DCG1]STA0(I)>1 & [M:DCG1]WEBSRV(I)=2
   [V]GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(54,123,1)
   #           ligne no : Suppression impossible
   mkstat     =2
   Break
  Endif
 Next
 If mkstat : End : Endif
 For I=nolign-1 To J
  [M:DCG1]DELUID   ([M:DCG1]NBDEL) =[M:DCG1]UID   (I)
  [M:DCG1]DELUPDNUM([M:DCG1]NBDEL) =[M:DCG1]UPDNUM(I)
  [M:DCG1]NBDEL                   +=1
 Next
Endcase

#JOJAC - 2014-09-04 - X3-15908 - START
If func AFNC.ACTIV("FUKGL")
  If func DIVPAYE.IS_BRI_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBDCGUKI") Then
    Call C_NBLIG From SUBDCGUKI
  Endif
Endif
#JOJAC - 2014-09-04 - X3-15908 - END
End

Subprog C_NBLIG_FIELDCONTROL(WRET)
Variable Integer WRET
If !nolign : End : Endif
Gosub DROIT
Local Shortint I, J
Case status
When 75
 If !find([M:DCG1]STA0(nolign-1),0,1,3) & !instr(1,[V]GUSRAUZ,"2")
& & [M:DCG1]WEBSRV(nolign-1)=2
#MIPEA - 2016-12-15 - X3-12089- START
  [V]GMESSAGE=mess(175,10709,1)
#  [V]GMESSAGE=mess(175,709,1)
#MIPEA - 2016-12-15 - X3-12089- END
  #           Seules les demandes en brouillon ou validées sont modifiables
  mkstat     =2
  End
 Else
#MIPEA - 2016-12-19 - X3-12089- START
  Filter [HRCTR] Order By Key CLE=ETRFCY
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  For [HRCTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
&                     & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
&                     & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
#  Filter [CTR] Order By Key CLE=ETRFCY
## FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#  For [CTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
#&                     & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
#&                     & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
#MIPEA - 2016-12-19 - X3-12089- END
# 28/03/01 - Bug 72654
# - Pouvoir saisir quand on n'a pas GPAYE et GTPS
##71976 : GMOIPAY is now in 'Common module'
#MIPEA - 2016-12-15 - X3-12089- START
   If [M:DCG1]STRDAT(nolign-1)<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY))
#   If [M:DCG1]STRDAT(nolign-1)<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY))
#MIPEA - 2016-12-15 - X3-12089- END
    # La saisie ne peut s'effectuer à une date antèrieure au
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE=mess(13,10715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY)))
#    [V]GMESSAGE=mess(13,715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY)))
#MIPEA - 2016-12-15 - X3-12089- END
    mkstat     =2
    Break
   Endif
  Next
#MIPEA - 2016-12-19 - X3-12089- START
  Filter [HRCTR]
#  Filter [CTR]
#MIPEA - 2016-12-19 - X3-12089- END
 Endif
Endcase
If !mkstat
  WRET = 1
Endif
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Date DAT2

Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET)
If !WRET
  mkstat     =2
  End
Endif

If ![V]GWEBSERV & ([L]VALEUR<[M:DCG1]DATDEB | [L]VALEUR>[M:DCG1]DATFIN)
#MIPEA - 2016-12-15 - X3-12089- START
  [V]GMESSAGE=mess(1,10709,1)
# [V]GMESSAGE=mess(1,709,1) : # Date en dehors de la période
#MIPEA - 2016-12-15 - X3-12089- END
 mkstat     =2
 End
Endif

#57019
#Filter [CTR] Order By Key CLE=ETRFCY
#For [CTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & CTRDAT<=[M:DCG1]ENDDAT(nolign-1)
#&                   & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
#&                   & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0


If [M:DCG1]ENDDAT(nolign-1)=[0/0/0]
 DAT2 = VALEUR
Else
 DAT2 = [M:DCG1]ENDDAT(nolign-1)
Endif
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRCTR] Order By Key CLE=ETRFCY
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
For [HRCTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<=DAT2 | (FLGRET=2 & RETDATEFF<=DAT2))
&                   & (XITDAT=[0/0/0] | XITDAT>=VALEUR)
&                   & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
#Filter [CTR] Order By Key CLE=ETRFCY
## FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#For [CTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<=DAT2 | (FLGRET=2 & RETDATEFF<=DAT2))
#&                   & (XITDAT=[0/0/0] | XITDAT>=VALEUR)
#&                   & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
#MIPEA - 2016-12-19 - X3-12089- END
# 28/03/01 - Bug 72654
# - Pouvoir saisir quand on n'a pas GPAYE et GTPS
##71976 : GMOIPAY is now in 'Common module'
#MIPEA - 2016-12-19 - X3-12089- START  GMOIPAY = [0/0/0]
  If GMOIPAY = [0/0/0]
     GMOIPAY = gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
  Endif
 If [L]VALEUR<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY))
  [V]GMESSAGE=mess(13,10715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY)))
# If [L]VALEUR<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY))
#  # La saisie ne peut s'effectuer à une date antèrieure au
#  [V]GMESSAGE=mess(13,10715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY)))
  #MIPEA - 2016-12-19 - X3-12089- END
#  [V]GMESSAGE=mess(13,715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY)))
#MIPEA - 2016-12-15 - X3-12089- END
   mkstat     =2
   Break
  Endif
Next
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRCTR]
#Filter [CTR]
#MIPEA - 2016-12-19 - X3-12089- END

##JOJAC | 2017-09-19 | X3-15908 | START
#If func AFNC.ACTIV("FUKGL")
#  If func DIVPAYE.IS_BRI_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBDCGUKI") Then
#    Call C_STRDAT(VALEUR) From SUBDCGUKI
#  Endif
#Endif
##JOJAC | 2017-09-19 | X3-15908 | END


#FRLAA X3-86842 2018-05-14 START
Call C_STRDAT(VALEUR) From SUBDCG2
#FRLAA X3-86842 2018-05-14 END

End

########################################
Subprog C_STRDAY(VALEUR)
Variable Integer VALEUR

Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET)
If !WRET
  mkstat     =2
  End
Endif

Call CONTROL_DATE([M:DCG1]ENDDAY(nolign-1),VALEUR)

If [L]VALEUR<2 : End : Endif
End

########################################

##58864

Subprog AS_ENDDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M:DCG1]STRDAT(nolign-1)
Endif
End

