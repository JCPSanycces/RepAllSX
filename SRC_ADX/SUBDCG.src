#FRLAA 2018-08-15 X3-104072 - END



#FRLAA 2018-02-02 X3-74480 - START
Local Char ERRMESSAGE(250)
Local Integer PGOK,IS_SOA # Variable set for GOK that will be used for both V6 and SOA code.

#####MIPEA
  If [V]GWEBSERV : [L]NODEM=[L]DEM : Else : [L]NODEM=0 : Endif
  If !clalev([F:DCGWRK]) : Local File DEMCONGE [DCGWRK] : Endif
#FRLAA 2018-08-13 X3-104072 - START
  If !clalev([F:DCGWRK2]) : Local File DEMCONGE [DCGWRK2] : Endif
  Filter [F:DCGWRK] Where REFNUM=[M:DCG1]REFNUM & WRK>""
  For [F:DCGWRK]
    Read [F:DCGWRK2]DCG3 = [F:DCGWRK]REFNUM;[F:DCGWRK]UID
    If !fstat
      [F:DCGWRK2]WRK=""
      Rewrite [F:DCGWRK2]
      If fstat
        [V]GOK=0
        Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
        Return
       Endif
    Endif
  Next
#For [DCGWRK]DCG3 With Stability
#  [F:DCGWRK]WRK=""
#  Rewrite [F:DCGWRK] #Curr
#  If fstat
#    [V]GOK=0
#    Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#    Break : Return
#   Endif
#Next

#  For [DCGWRK] Where [DCGWRK]REFNUM=[M:DCG1]REFNUM & [DCGWRK]WRK>""
#    [F:DCGWRK]WRK=""
#    Rewrite [F:DCGWRK]
#    If fstat
#      [V]GOK=0
#      Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#      Return
#   Endif
#  Next
#FRLAA 2018-08-13 X3-104072 - END
#  Update [DCG] Where [DCG]REFNUM=[M:DCG1]REFNUM & [DCG]WRK>"" With [DCG]WRK=""
#  If fstat
#    [V]GOK=0
#    Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#  Return
#  Endif
#####MIPEA

  Raz [L]UPD2, [L]UID2
  If ![V]GWEBSERV : Filter [DCG] Where evalue([L]FILTRE2) : Endif
  #MIPEA - 2016-12-19 - X3-12089- START
  #MIPEA - 2016-12-19 - X3-12089- START

#PEVAN - 2018-05-31 - X3-92772 - START
#  Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM, [FCY]FCY0 = [HRCTR]ETRFCY As [LNK]
#& Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
#& Order By Key UNIDCG=[DCG]UID
  Link [DCG] With [HRCTR]CTR0(2)=[DCG]REFNUM;[DCG]CTRNUM, [FCY]FCY0 = [HRCTR]ETRFCY As [LNK]
& Where [DCG]REFNUM=[M:DCG1]REFNUM & [FCY]LEG=GCURLEG & [DCG]UID>0 & [DCG]STRDAT <> [0/0/0] & [DCG]ENDDAT <> [0/0/0]
& & ([HRCTR]CTRDAT <= [DCG]STRDAT & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[DCG]STRDAT))
& Order By Key UNIDCG=[DCG]UID
#PEVAN - 2018-05-31 - X3-92772 - END

  #JOJAC - START
  Local Integer SMPUID : SMPUID =  [DCG]UID
  #JOJAC - END
  For [LNK]UNIDCG(1) With Stability
  #For [DCG]DCG0 Where REFNUM=[M:DCG1]REFNUM & LEG=GCURLEG & UID>0 With Stability
  #MIPEA - 2016-12-19 - X3-12089- END
  #For [DCG]DCG0 Where REFNUM=[M:DCG1]REFNUM & UID>0 With Stability  : # 62113 Ne pas relire les enreg. créés dans cette boucle
  #MIPEA - 2016-12-19 - X3-12089- END
    nolign=find([F:DCG]UID,[M:DCG1]UID(0..[M:DCG1]NBLIG-1))
## PEVAN 2017-08-31 X3-54262 START
    If func AFNC.ACTIV("GLM")
      PARENT_INDEX = nolign-1
    Endif
## PEVAN 2017-08-31 X3-54262 END

    If nolign
      I=([M:DCG1]UPDNUM(nolign-1)=[F:DCG]UPDNUM)
    Else
      nolign=find([F:DCG]UID,[M:DCG1]DELUID(0..[M:DCG1]NBDEL-1))
      If nolign
        I=2*([M:DCG1]DELUPDNUM(nolign-1)=[F:DCG]UPDNUM)
      Elsif [V]GWEBSERV
        I=3
      Else
        I=0
      Endif
    Endif
    If !I
    #MIPEA - 2016-12-15 - X3-12089- START
      [V]GMESSAGE=mess(73,10701,1)
    #  [V]GMESSAGE=mess(73,701,1)
    #MIPEA - 2016-12-15 - X3-12089- END
    #           La table a été modifiée par un autre utilisateur depuis la dernière lecture
      [V]GOK     =0
      Break
    Elsif [V]GWEBSERV & I<2
      [L]NODEM=[F:DCG]DEM
    Endif

    If I=2 : # La ligne d'une demande existante a été supprimée
      If [F:DCG]STA<2
        W_UID(0)=num$([F:DCG]UID)
        Call DELETE_AOX_ATTACH("DCG",[F:DCG]REFNUM,num$([F:DCG]DEM),W_UID,1)From PRHPORATT
        Delete [DCG] Curr
      Else
        If [F:DCG]STA = 2 | [F:DCG]STA = 5
          Call MAJ_HISSUI(0) : # 62113 ici on ne vient pas du circuit de signature=>maj du suivi workflow
        Endif
        [F:DCG]UID*=-1 : # On va supprimer cette ligne dans TIMEMP
        Case [F:DCG]STA
          When 2   : [F:DCG]WRK="S" : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
          When 5   : [F:DCG]WRK="S" : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
          When 3,7 : [F:DCG]WRK="S"
        Endcase
        [F:DCG]UPDDAT =date$
        [F:DCG]UPDUSR =[V]GUSER
        [F:DCG]UPDNUM+=1

        Rewrite [DCG] Curr
        If func AFNC.ACTIV("GLM")
#          Call UPDATE_DEMSPLITS_DCGUID([F:DCG]LNK, [F:DCG]UID) From SUBDCGGLM
          Call DELETE_FROM_DEMSPLITS([F:DCG]UID * -1) From SUBDCGGLM
        Endif
      Endif
      If fstat
        [V]GOK=0
        Call FSTA("DCG") From GLOCK
        Break
      Endif
     #SAVAN - DELETE - 2017/11/06 - start

      If func AFNC.ACTIV("GLM")
        #FRLAA 2018-02-15 X3-74480 - START
#PEVAN - 2018-07-30 - X3-90320 - START
#        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END
#        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
        #Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM) From SUBDCGGLM
        #FRLAA 2018-02-15 X3-74480 - END
        If [V]GOK=0 : Return : Endif
     Endif
    #JASMI - 2017-09-29 - XXX - START
      If func AFNC.ACTIV("GLM")
       #FRLAA 2018-02-15 X3-74480 - START
        Local Integer VUIDS_TO_INCLUDE(20)(1..)
        Local Integer VUIDS_COUNT : VUIDS_COUNT=1
        Call RESET_FUTURE_SPLITS_PROG(PGOK,GCURLEG,IS_SOA,VUIDS_TO_INCLUDE,VUIDS_COUNT) From SUBDCGGLM
        #Gosub RESET_FUTURE_SPLITS From SUBDCGGLM
        #FRLAA 2018-02-15 X3-74480 - END
        If [V]GOK=0 : Return : Endif
      Endif
    #JASMI - 2017-09-29 - XXX - END
    #SAVAN - DELETE - 2017/11/06 - end
    Elsif I=1 : # La ligne d'une demande existante a été modifiée
      For J=0 To [G:DCG]nbzon-1
      Local Integer SUBRATECHANGED: SUBRATECHANGED = 0:
#      Local Integer VALID_FIELD: VALID_FIELD = 1:
      If func AFNC.ACTIV("GLM") and GCURLEG <> "BRI"
        If [G:DCG]adxfname(J) = "LVESUBRAT"
          Call CHECK_SUB_RATE_CHANGED(PARENT_INDEX, SUBRATECHANGED) From SUBDCG2
        Endif
###PEVAN 2017-11-10 X3-63463 START
#        Call VALID_FIELD_FOR_UPDATE([G:DCG]adxfname(J), VALID_FIELD) From SUBDCG2
###PEVAN 2017-11-10 X3-63463 END
      Endif
      #SBA 92896-2040 correctif  sur chp updtick ~W
#JASMI - 2017-11-30 - X3-39430 - START
#        If left$([G:DCG]adxfname(J),1)<>"~" & [G:DCG]adxfname(J)<>"UPDNUM" & evalue("dim([M:DCG1]"+[G:DCG]adxfname(J)+")")>1
#&       & evalue("[F:DCG]"+[G:DCG]adxfname(J)+"<>[M:DCG1]"+[G:DCG]adxfname(J)+"(nolign-1)") | SUBRATECHANGED > 0
#        If left$([G:DCG]adxfname(J),1)<>"~" & [G:DCG]adxfname(J)<>"UPDNUM" & [G:DCG]adxfname(J)<>"DEM" & [G:DCG]adxfname(J)<>"LVERATDES" & evalue("dim([M:DCG1]"+[G:DCG]adxfname(J)+")")>1
#&       & evalue("[F:DCG]"+[G:DCG]adxfname(J)+"<>[M:DCG1]"+[G:DCG]adxfname(J)+"(nolign-1)") | SUBRATECHANGED > 0
        If left$([G:DCG]adxfname(J),1)<>"~"
&       & [G:DCG]adxfname(J)<>"UPDNUM" & [G:DCG]adxfname(J)<>"DEM" & [G:DCG]adxfname(J)<>"WRK"
&       & [G:DCG]adxfname(J)<>"DATPYR" & [G:DCG]adxfname(J)<>"LVESUBRAT" & [G:DCG]adxfname(J)<>"DATLVE"
&       & [G:DCG]adxfname(J)<>"LVERATDES" & [G:DCG]adxfname(J)<>"SXPCAT"
&       & evalue("dim([M:DCG1]"+[G:DCG]adxfname(J)+")")>1
&       & evalue("[F:DCG]"+[G:DCG]adxfname(J)+"<>[M:DCG1]"+[G:DCG]adxfname(J)+"(nolign-1)")
&       | SUBRATECHANGED > 0
        #Infbox [G:DCG]adxfname(J) - " SUBRATECHANGED " - num$(SUBRATECHANGED)
          If find([G:DCG]adxfname(J),"CMT","LVERSN","LVESEQ","LVENOT","DRNAM","PRTNAM")>0
            [F:DCG]       =[M:DCG1]
            [F:DCG]UPDDAT =date$
            [F:DCG]UPDUSR =[V]GUSER

            Rewrite [DCG] Curr
            If fstat
              [V]GOK=0
              Call FSTA("DCG") From GLOCK
              Break 2
            Endif

          Else
#JASMI - 2017-11-30 - X3-39430 - END
        # >un des champs du tableau a été modifié pour l'enreg F:DCG courant
          If [F:DCG]STA = 2 | [F:DCG]STA = 5
            Call MAJ_HISSUI([M:DCG1]STA(nolign-1)) : # 62113 ici on ne vient pas du circuit de signature=>maj du suivi workflow
          Endif
          If [F:DCG]STA>1
            [F:DCG]WRK ="M"
          #JASMI - 2017-10-18 - xxx - START
            If [M:DCG1]STA(nolign-1)=4 | [M:DCG1]STA(nolign-1)=6
              [F:DCG]WRK ="X"
            Endif
          #JASMI - 2017-10-18 - xxx - END
            [F:DCG]UID*=-1 : # On va supprimer cette ligne dans TIMEMP
            Case [F:DCG]STA
              When 2 : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
              When 5 : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
            Endcase
            If ![V]GWEBSERV & [M:DCG1]STA0(nolign-1)=[M:DCG1]STA(nolign-1) : # pour forcer MAJTIP
              Case [M:DCG1]STA(nolign-1)
                When 2 : [M:DCG1]STA0(nolign-1)=1
                When 3 : [M:DCG1]STA0(nolign-1)=2
                # When 4 : [M:DCG1]STA0(nolign-1)=2
                When 5 : [M:DCG1]STA0(nolign-1)=3
                # When 6 : [M:DCG1]STA0(nolign-1)=5
                When 7 : [M:DCG1]STA0(nolign-1)=5
              Endcase
            Endif
          Else
            [F:DCG]       =[M:DCG1]
            [F:DCG]UPDDAT =date$
            [F:DCG]UPDUSR =[V]GUSER
            If [M:DCG1]STA(nolign-1)=2 : [F:DCG]WRK="C" : Else [F:DCG]WRK="" : Endif
          Endif
          [F:DCG]UPDNUM+=1
          Rewrite [DCG] Curr

          If func AFNC.ACTIV("GLM")
#            Call UPDATE_DEMSPLITS_DCGUID([F:DCG]LNK, [F:DCG]UID) From SUBDCGGLM
            Call DELETE_FROM_DEMSPLITS((([F:DCG]UID) * -1)) From SUBDCGGLM
          Endif
          If fstat
            [V]GOK=0
            Call FSTA("DCG") From GLOCK
            Break 2
          Endif
                #SAVAN - DELETE - 2017/11/08 - start
          If func AFNC.ACTIV("GLM")
#            Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM #FRLAA 2018-02-15 X3-74480
#PEVAN - 2018-07-30 - X3-90320 - START
#            Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM #FRLAA 2018-02-15 X3-74480
            Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM #FRLAA 2018-02-15 X3-74480
#PEVAN - 2018-07-30 - X3-90320 - END
            #If [V]GOK=0 : Return : Endif
          Endif
    #JASMI - 2017-09-29 - XXX - START
          If func AFNC.ACTIV("GLM")
            #MIPEA 2018-02-26 X3-74480 - START
            Local Integer VUIDS_TO_INCLUDE(20)(1..)
            Local Integer VUIDS_COUNT : VUIDS_COUNT=1
            Call RESET_FUTURE_SPLITS_PROG(PGOK,GCURLEG,IS_SOA,VUIDS_TO_INCLUDE,VUIDS_COUNT) From SUBDCGGLM
            #Gosub RESET_FUTURE_SPLITS From SUBDCGGLM
#MIPEA 2018-02-26 X3-74480 - END
            #If [V]GOK=0 : Return : Endif
          Endif
    #JASMI - 2017-09-29 - XXX - END
    #SAVAN - DELETE - 2017/11/08 - end
          #FRLAA X3-86032 - 2018-04-17 - START
          If ([F:DCG]WRK="M" | [F:DCG]WRK="X" | [F:DCG]WRK="R")
          #If ([F:DCG]WRK="M" | [F:DCG]WRK="X")
          #FRLAA X3-86032 - 2018-04-17 - END
            [F:DCG]       =[M:DCG1]
            [F:DCG]UPDDAT =date$
            [F:DCG]UPDUSR =[V]GUSER
            [F:DCG]UID    =uniqid([TIP])
            [F:DCG]UPDNUM+=2
            Case [F:DCG]STA
              When 2 : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
              When 5 : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
            Endcase

            #JOJAC - 2017-09-14 - X3-15908 - START
#            If func AFNC.ACTIV("GLM") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SSP'
#              If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") Then
#                Gosub PREVLNKPIW From SUBDCGSSP
#              Endif
#            Endif
            #JOJAC - 2017-09-14 - X3-15908 - END

            ## PEVAN 2017-08-31 X3-54262 START
#            PARENT_INDEX = nolign - 1
           If GCURLEG <> "BRI"
            If func AFNC.ACTIV("GLM")
              Call SET_LVESUBRAT(PARENT_INDEX) From SUBDCG2
            Endif
           Endif
            ## PEVAN 2017-08-31 X3-54262 END

     #JOJAC - 2017-08-28 - X3-15908 - START
#     If func AFNC.ACTIV("GLM") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SSP'
#       If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") Then
#         Gosub PREVLNKPIW From SUBDCGSSP
#       Endif
#     Endif
     #JOJAC - 2017-08-28 - X3-15908 - END

    Write [DCG]

    #JOJAC - 2017-08-28 - X3-15908 - START
        #JOJAC - 2017-10-24 - X3-15908 - START
    #If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SSP'
    If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [F:DCG]SXPCAT='SSP'
    #JOJAC - 2017-10-24 - X3-15908 - END
      #SAVAN - 2018/02/21
      #If func SUBDCGSSP.SSP_SPLIT([F:DCG]UID, "SSP_E") <> 1 : Rollback : Endif
      #SAVAN - 2018/02/21
    Endif
    #JOJAC - 2017-08-28 - X3-15908 - END


    #JOJAC - 2017-10-16 - X3-15908 - START
    If func DIVPAYE.EXISTE_KXX("SUBDCGSMP") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SMP'
      If func SUBDCGSMP.SMP_SPLIT([F:DCG]UID, "SMP_H") <> 1 : Rollback : Endif
    Endif
    #JOJAC - 2017-10-16 - X3-15908 - END
#
#    #JOJAC - 2017-10-16 - X3-15908 - START
#    If func DIVPAYE.EXISTE_KXX("SUBDCGSPP") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SPP'
#      If func SUBDCGSMP.SMP_SPLIT([F:DCG]UID, "SPP_E") <> 1 : Rollback : Endif
#    Endif
#    #JOJAC - 2017-10-16 - X3-15908 - END

     If fstat
      [V]GOK=0
      Call FSTA("DCG") From GLOCK
      Break 2
     Endif
     Gosub MOVE_ATTACHMENTS_DCG From ESS_FUNCTIONS
    Endif
  #JASMI - 2017-09-29 - XXX - START
    If func AFNC.ACTIV("GLM")
#      If ([F:DCG]STA = 1 | [F:DCG]STA = 2 | [F:DCG]STA = 3 | [F:DCG]STA = 5 | [F:DCG]STA = 7)
       If ([M:DCG1]STA(nolign-1)<>6)
#        If !clalev([F:DCGACC]) : Local File DEMCONGE [DCGACC] : Endif
        #Filter [F:DCGACC] Where [F:DCGACC]CTRNUM = [F:DCG]CTRNUM & [F:DCGACC]STRDAT > [DCG]STRDAT
        #SAVAN 2017/10/23 Move to below delete - start
        #Filter [F:DCGACC]
        #SAVAN 2017/10/23 Move to below delete - end
#        If rowcount([F:DCGACC]) > 0
          #FRLAA 2018-02-15 X3-74480 - START
#PEVAN - 2018-07-30 - X3-90320 - START
#          Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
          Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]STRDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END
          #Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM) From SUBDCGGLM
          #FRLAA 2018-02-15 X3-74480 - END
#        Endif
       #SAVAN 2017/10/23 MOVE To BELOW Delete - START
       #   Filter [F:DCGACC]
        #SAVAN 2017/10/23 Move to below delete - end
#      Endif
      #FRLAA 2018-02-15 X3-74480 - START
#MIPEA 2018-02-21 X3-74480 - START
      Call SPLIT_THIS_TRANSACTION_PROG(PGOK,GCURLEG,IS_SOA,[0/0/0],UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
#MIPEA 2018-02-21 X3-74480 - END
      #Gosub SPLIT_THIS_TRANSACTION From SUBDCGGLM
      #FRLAA 2018-02-15 X3-74480 - END
      If [V]GOK=0 : Return : Endif
    Endif
    Endif
  #JASMI - 2017-09-29 - XXX - END

#JASMI - 2017-11-30 - X3-39430 - START
     Endif
#JASMI - 2017-11-30 - X3-39430 - END
    Break
   Endif
  Next
 Endif
 If I=1 : [L]UPD2(nolign-1)=[F:DCG]UPDNUM : [L]UID2(nolign-1)=[F:DCG]UID : Endif
Next
Filter [DCG]
If [V]GOK<1 : Return : Endif

# Lignes créées dans le tableau
# ANCOA - X3-78782 - 04/03/2018 - Store nolign before the loop, to reset later
Local Integer NOLIGN_START : [L]NOLIGN_START = nolign

For nolign=1 To [M:DCG1]NBLIG
 If [M:DCG1]UID(nolign-1)<=0
  Raz [F:DCG]
  [F:DCG]CREUSR=[V]GUSER
  [F:DCG]CREDAT=date$
  [F:DCG]      =[M:DCG1]
  [F:DCG]UID   =uniqid([TIP])
  [F:DCG]LNK   =[F:DCG]UID
  If [F:DCG]STA=2 : [F:DCG]WRK="C" : [F:DCG]CHRONO=num$(-adxuid(2)) : Endif
  If ![L]NODEM : [L]NODEM=uniqid([DCG]) : Endif
  [F:DCG]DEM=[L]NODEM

#JOJAC - 2017-08-21 - X3-15908 - START
  If func AFNC.ACTIV("GLM") & func DIVPAYE.IS_BRI_LEG(GCURLEG) & [M:DCG1]SXPCAT(nolign-1)='SSP'
    If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") Then
        Gosub PREVLNKPIW From SUBDCGSSP
        #SAVAN - 2018/02/23 - start
        # Gosub SSPELI_AWE From SUBDCGSSP
        #SAVAN - 2018/02/23 - end
    Endif
  Endif
#JOJAC - 2017-08-21 - X3-15908 - END

  #X3-39416 SAVAN 20170530 START
#    Write [DCG]
#    If fstat
#      [V]GOK=0
#      Call FSTA("DCG") From GLOCK
#      Break
#    Endif
  If func AFNC.ACTIV("GLM")
    If [M:DCG1]LVESEQ(nolign-1) = ""
      #FRLAA 2018-08-14 X3-104072 - START
      [F:DCG]LVESEQ = func SUBDCG.GET_GLM_UNILVENUM([F:DCG]REFNUM)
      [M:DCG1]LVESEQ(nolign-1) = [F:DCG]LVESEQ
#      Gosub GET_LVENR
#      [F:DCG]LVESEQ = [L]LVESEQNR
#      [M:DCG1]LVESEQ(nolign-1) = [L]LVESEQNR
       #FRLAA 2018-08-14 X3-104072 - END
      Affzo [M:DCG1]LVESEQ(nolign-1)
    Endif
  Endif

  Write [DCG]

  If fstat
    [V]GOK=0
    Call FSTA("DCG") From GLOCK
    Break
  Endif

  #X3-39416 SAVAN 20170530 END
  [L]UPD2(nolign-1)=[F:DCG]UPDNUM
  [L]UID2(nolign-1)=[F:DCG]UID

  #JASMI - 2017-09-25 - XXX - START
  If func AFNC.ACTIV("GLM")

    If ([F:DCG]STA = 1 | [F:DCG]STA = 2 | [F:DCG]STA = 3 | [F:DCG]STA = 7) #| [F:DCG]STA = 5
      #If !clalev([F:DCGACC]) : Local File DEMCONGE [DCGACC] : Endif
      #Filter [F:DCGACC] Where [F:DCGACC]CTRNUM = [F:DCG]CTRNUM & [F:DCGACC]STRDAT > [F:DCG]STRDAT
      #SAVAN 2017/10/23 Move to below delete - start
      #Filter [F:DCGACC]
      #SAVAN 2017/10/23 Move to below delete - end
#      If rowcount([F:DCGACC]) > 0
#        Gosub DELETE_FUTURE_ACCRUALS From SUBDCGGLM
        #FRLAA 2018-02-05 X3-74480 - START
#PEVAN - 2018-07-30 - X3-90320 - START
#        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - START
#        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM
        #Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM) From SUBDCGGLM
        #FRLAA 2018-02-05 X3-74480 - START
#      Endif
       #SAVAN 2018/01/11 start
       #Gosub RESET_FUTURE_SPLITS From SUBDCGGLM
       #SAVAN 2018/01/11 end
      #SAVAN 2017/10/23 Move to below delete - start
        #Filter [F:DCGACC]
       #SAVAN 2017/10/23 Move to below delete - end
       #FRLAA 2018-02-02 X3-74480 - START
       Call SPLIT_THIS_TRANSACTION_PROG(PGOK,GCURLEG,IS_SOA,[0/0/0],UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
       #Gosub SPLIT_THIS_TRANSACTION From SUBDCGGLM
       #FRLAA 2018-02-06 X3-74480 - END
    Endif
      #FRLAA 2018-02-02 X3-74480 - START
       If PGOK = 1
        [V]GOK=0
       Endif
       #FRLAA 2018-02-02 X3-74480 - END
    #Gosub RESPLIT_TRANSACTIONS From SUBDCGGLM
    If [V]GOK=0 : Return : Endif
  Endif
#JASMI - 2017-09-25 - XXX - END

 Endif
Next

# ANCOA - X3-78782 - 04/03/2018 - reset nolign to the value it was before the loop
nolign = [L]NOLIGN_START

If [V]GOK<1 : Return : Endif

If find(0,[L]UID2(0..[M:DCG1]NBLIG-1))
#MIPEA - 2016-12-15 - X3-12089- START
  [V]GMESSAGE=mess(73,10701,1)
# [V]GMESSAGE=mess(73,701,1)
#MIPEA - 2016-12-15 - X3-12089- END
 #           La table a été modifiée par un autre utilisateur depuis la dernière lecture
 [V]GOK     =0
 Return
Endif

[L]CRITERE2(0) ="REFNUM=[M:DCG1]REFNUM & find(UID,[L]UID2(0..[M:DCG1]NBLIG-1))" : # Nouvelle demande ou statut de la demande a changé
[L]CRITERE2(1)="[M:DCG1]STA0(find([F:DCG]UID,[L]UID2(0..[M:DCG1]NBLIG-1))-1)<>[F:DCG]STA"
Read [F:ID]ID0 = [M:DCG1]REFNUM
If fstat
 GMESSAGE = mess(70,122,1)-"[F:ID]" : # erreur de lecture
 GOK = 0
 Return
Endif
Gosub MAJTIP
If [V]GOK<1 : Return : Endif
#SAVAN - put back
#Return
#JASMI - 2017-09-25 - XXX - START
If func AFNC.ACTIV("GLM")
#####MIPEA
#FRLAA - 2018-08-30 - X3-104636 - START
#  If !clalev([F:DCGWRK]) : Local File DEMCONGE [F:DCGWRK] : Endif
  If !clalev([F:DCGWRK2]) : Local File DEMCONGE [DCGWRK2] : Endif
  Filter [F:DCGWRK] Where [F:DCGWRK]REFNUM=[M:DCG1]REFNUM & [F:DCGWRK]UID<0 & [F:DCGWRK]WRK>""
  For [F:DCGWRK]
    Read [F:DCGWRK2]DCG3 = [F:DCGWRK]REFNUM;[F:DCGWRK]UID
    If !fstat
      [F:DCGWRK2]WRK=""
      Rewrite [F:DCGWRK2]
      If fstat
        [V]GOK=0
        Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
        Return
       Endif
    Endif
  Next
#FRLAA - 2018-08-30 - X3-104636 - END
#  Filter [F:DCGWRK]
#  Filter [F:DCGWRK] Where [F:DCGWRK]REFNUM=[M:DCG1]REFNUM & [F:DCGWRK]UID<0 & [F:DCGWRK]WRK>""
#  Read [DCGWRK]DCG3 First
#  For [DCGWRK]DCG3 With Stability
#    [F:DCGWRK]WRK=""
#    Rewrite [F:DCGWRK] #Curr
#    If fstat
#      [V]GOK=0
#      Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#      Break : Return
#     Endif
#  Next
#  For [F:DCGWRK] Where [F:DCGWRK]REFNUM=[M:DCG1]REFNUM & [F:DCGWRK]UID<0 & [F:DCGWRK]WRK>""
#    [F:DCGWRK]WRK=""
#    Rewrite [F:DCGWRK]
#    If fstat
#      [V]GOK=0
#      Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#      Return
#   Endif
#  Next
#  Close File [F:DCGWRK]

#  Update [DCG] Where REFNUM=[M:DCG1]REFNUM & [DCG]UID<0 & [DCG]WRK>"" With WRK=""
#  If fstat
#    [V]GOK=0
#    Call RSTA("DCG",[M:DCG1]REFNUM-'WRK=""') From GLOCK
#    Return
#  Endif
#####MIPEA

  #FRLAA 2018-02-15 X3-74480 - START MIPEA
  Call RESPLIT_TRANSACTIONS_PROG(PGOK,GCURLEG,IS_SOA,[M:DCG1]REFNUM,ERRMESSAGE,[0/0/0]) From SUBDCGGLM
  #Gosub RESPLIT_TRANSACTIONS From SUBDCGGLM
  #FRLAA 2018-02-15 X3-74480 - START
  If PGOK = 1
    [V]GOK=0
#    GMESSAGE = ERRMESSAGE
    Return
  Endif

#PEVAN - 2018-04-04 - X3-81467 - START
   If GCURLEG <> "BRI"
    If func AFNC.ACTIV("GLM")
      If ISNEW = 0
        Call SET_LVESUBRAT(PARENT_INDEX) From SUBDCG2
#PEVAN - 2018-04-04 - X3-81467 - START
#       Rewrite [F:DCG]
        Call UPDATE_LVESUBRAT(PARENT_INDEX,[F:DCG]UID) From SUBDCG2
#PEVAN - 2018-04-04 - X3-81467 - END
      Endif
    Endif
   Endif
#PEVAN - 2018-04-04 - X3-81467 - END

#   If GCURLEG="BRI"
    #Local Integer SSPLNKPIW
    #Infbox "CALL GEN"
    #If func SUBDCGSSP.SOA_SSPLNKPIW([F:DCG]STRDAT,[F:DCG]SXPCAT,[F:DCG]SSPPIW,[F:DCG]REFNUM,SSPLNKPIW) <> 1 : Rollback : Endif
    #[F:DCG]SSPLNKPIW=SSPLNKPIW
#  Endif
  If [V]GOK=0 : Return : Endif

  [L]CRITERE2(0) ="REFNUM=[M:DCG1]REFNUM & find(UID,[L]UIDS_TO_INCLUDE)" : # Nouvelle demande ou statut de la demande a changé
  [L]CRITERE2(1)="1=1"

#JASMI - 2017-11-07 - XXX - START
#  Gosub MAJTIP
#  If [V]GOK<1 : Return : Endif
  If [L]UIDS_TO_INCLUDE(1)<>0
    Gosub MAJTIP
    If [V]GOK<1 : Return : Endif
  Endif
#JASMI - 2017-11-07 - XXX - END
Endif
#JASMI - 2017-09-25 - XXX - END
#JOJAC -X3-15908 - 2017-10-06 - START
#If func AFNC.ACTIV("FUKGL")
#  If DCGUKINBLIG > -1
#    If func DIVPAYE.IS_BRI_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBDCGUKI") Then
#      Gosub SAVED From SUBDCGUKI
#    Endif
#  Endif
#Endif

If [F:DCG]SXPCAT = 'SMP'
  If clalev([SMPLVE])=0 : Local File UKSMPLVE [SMPLVE] : Endif
  Read [SMPLVE]SMPLVE1 = [F:DCG]UID
  If fstat
    [F:SMPLVE] = [M:DCG1]
    [F:SMPLVE]UID = [F:DCG]UID
    Write [SMPLVE]
  Else
    [F:SMPLVE] = [M:DCG1]
    [F:SMPLVE]UID = [F:DCG]UID
    Rewrite [SMPLVE]
  Endif
  #If GUSER = 'JOJAC'
  If !clalev([F:KIT]) : Local File SMPKIT [KIT] : Endif
  Delete [KIT] Where REFNUM = [F:DCG]REFNUM and CTRNUM = [F:DCG]CTRNUM
  For I = 0 To [M:DCG1]NBKIT-1
    If [M:DCG1]KITDAT(I) <> [0/0/0]
      [KIT]REFNUM = [F:DCG]REFNUM
      [KIT]CTRNUM = [F:DCG]CTRNUM
      [KIT]LIGNUM = I+1
      [KIT]KITDAT = [M:DCG1]KITDAT(I)
      Write [KIT]
    Endif
  Next I
#Endif
Endif

If [F:DCG]SXPCAT = 'SPP'
  If clalev([SPPLVE])=0 : Local File UKSPPLVE [SPPLVE] : Endif
  Read [SPPLVE]SPPLVE1 = [F:DCG]UID
  If fstat
    [F:SPPLVE] = [M:DCG1]
    [F:SPPLVE]UID = [F:DCG]UID
    Write [SPPLVE]
  Else
    [F:SPPLVE] = [M:DCG1]
    [F:SPPLVE]UID = [F:DCG]UID
    Rewrite [SPPLVE]
  Endif
Endif
#JOJAC -X3-15908 -  2017-10-06 - END
Return

$APRES_MODIF
#PEVAN - 2017-10-24 - X3-61120 - START
  If func AFNC.ACTIV("GLM")
## PEVAN - 2018-03-02 - X3-80393 - START
    If dim(GLM_NOLIGN) = 0 : Global Integer GLM_NOLIGN : Endif
    GLM_NOLIGN = nolign
## PEVAN - 2018-03-02 - X3-80393 - END
    If status = 82 #NEW line, reset the daughter grid.
      [M:DCG1]LVESUBNNR = 0
      Raz [M:DCG1]WLVESUBTYP
      Raz [M:DCG1]WLVESUBBAL
      Raz [M:DCG1]WNBRHOU
      Raz [M:DCG1]WLVESUBRAT
      Raz [M:DCG1]LVERATDES
      Affzo [M:DCG1]45
    Endif
  Endif
#PEVAN - 2017-10-24 - X3-61120 - END
Return
