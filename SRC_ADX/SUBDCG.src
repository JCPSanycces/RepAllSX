########################################
Subprog C_CMT(VALEUR)
Variable Char    VALEUR()

  #LIPET - 2017-08-25 - X3-53555 - START
  If clalev([F:TIM3])=0 : Local File TIMCOD  [TIM3] : Endif
  Filter [TIM3] Where COD = [M]TIM(nolign-1) and LEG = GCURLEG and CMTOBG = 2
  Read [TIM3] First
  Filter [TIM3]
  If !fstat Then
     If VALEUR = "" Then
      GERR=1
      [V]GMESSAGE = mess(10,123,1)
      mkstat = 2 :End
     Endif
  Endif
  #LIPET - 2017-08-25 - X3-53555 - END

  Local Integer WRET
  Call C_NBLIG_FIELDCONTROL(WRET)
  If !WRET
    mkstat     =2
    End
  Endif

  If [L]VALEUR>"" | [M:DCG1]STA > 2 : End : Endif   : # 63735
  #MIPEA - 2016-12-19 - X3-12089- START
  Read [TIM]TIM0=GCURLEG;[M:DCG1]TIM(nolign-1)
  #Read [TIM]TIM0=[M:DCG1]TIM(nolign-1)
  #MIPEA - 2016-12-19 - X3-12089- END
  If [F:TIM]CMTOBG=2
   [V]GMESSAGE=mess(10,123,1) : # Zone obligatoire
   mkstat     =2
  Endif

End

########################################
Subprog AS_RPL(VALEUR)
Variable Char    VALEUR()

Local Libelle I
#64315
If VALEUR<>"" : End : Endif

If [M:DCG1]CTRNUM(nolign-1)>""
#MIPEA - 2016-12-19 - X3-12089- START
 [L]VALEUR=[F:HRCTR]RPL(0)
# [L]VALEUR=[F:CTR]RPL(0)
 #MIPEA - 2016-12-19 - X3-12089- END
Else
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
 For [HRCTR]CTR1 Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<[M:DCG1]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<[M:DCG1]STRDAT(nolign-1)))
&                  & (XITDAT=[0/0/0] | XITDAT>[M:DCG1]ENDDAT(nolign-1)) & sum(RPL)>""
  For I=0 To dim([F:HRCTR]RPL)-1
   If [F:HRCTR]RPL(I)>"" : [L]VALEUR=[F:HRCTR]RPL(I) : Break 2 : Endif
# For [CTR]CTR1 Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<[M:DCG1]STRDAT(nolign-1) | (FLGRET=2 & RETDATEFF<[M:DCG1]STRDAT(nolign-1)))
#&                  & (XITDAT=[0/0/0] | XITDAT>[M:DCG1]ENDDAT(nolign-1)) & sum(RPL)>""
#  For I=0 To dim([F:CTR]RPL)-1
#   If [F:CTR]RPL(I)>"" : [L]VALEUR=[F:CTR]RPL(I) : Break 2 : Endif
#MIPEA - 2016-12-19 - X3-12089- END
  Next
 Next
Endif

End

########################################
Subprog AV_RPLNAM(VALEUR)
Variable Char    VALEUR()
# bug 81149
# Déclaration de ID2
If !clalev([F:ID2]) : Local File EMPLOID [ID2] : Endif

If [M:DCG1]RPL(nolign-1)="" : [L]VALEUR="" : End : Endif

Read [ID2]ID0=[M:DCG1]RPL(nolign-1)
[L]VALEUR=toupper([F:ID2]NAM)-tolower([F:ID2]SRN)

End

########################################
Subprog AS_TYPPGN(VALEUR)
Variable Integer VALEUR
#60685
#Call NOPROLONG([M:DCG1]TIM(nolign-1),mkstat)
Local Integer OK
Call NOPROLONG([M:DCG1]TIM(nolign-1),OK)
#VALEUR = evalue("OK=0")
mkstat=OK
If OK=1 : End : Endif

If VALEUR : End : Else : VALEUR=1 : Endif

#56914
#Si un congé patho prénatal PATHM est suivi d'un congés maternité, la maternité doit être typé 'prolongation'
If [M]TIM(nolign-1) = func AFNC.PARAM("MATERNITE","")
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPREN","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),func AFNC.PARAM("PATHPREN",""),[M]REFNUM,[M]STRDAT(nolign-1)) From TPSSTD
 Endif
#Si un congé patho postnatal PATHO est suivi d'un congés maladie, la maladie doit être typé 'prolongation'
Elsif [M]TIM(nolign-1) = func AFNC.PARAM("MALADIE","")
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPOST","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),func AFNC.PARAM("PATHPOST",""),[M]REFNUM,[M]STRDAT(nolign-1)) From TPSSTD
 Endif
Elsif !OK :# Prologuation si 2 mêmes evt se suivent...
 If nolign>1
  If ([M]TIM(nolign-2)=[M]TIM(nolign-1)) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,[M]TIM(nolign-1),[M]TIM(nolign-1),[M]REFNUM,[M]STRDAT(nolign-1)) From TPSSTD
 Endif
Endif
End

########################################
Subprog D_STA(VALEUR)
Variable Integer VALEUR
#Initialisation de la demande à "Accepté" pour les utilisateurs qui ont l'option visa
If ![V]GWEBSERV & instr(1,[V]GUSRAUZ,"2") : [L]VALEUR=3 : Endif

End

########################################
Subprog AS_STA(VALEUR)
Variable Integer VALEUR
#58864
If ![V]GWEBSERV & instr(1,[V]GUSRAUZ,"2") & VALEUR=0 : [L]VALEUR=3 : Endif

If !instr(1,[V]GUSRAUZ,"2") :# L'utilisateur n'a pas l'option visa => on grise les statuts
 [V]GMENLOC(3)=1 : # Accepté
 [V]GMENLOC(4)=1 : # Refusé
 [V]GMENLOC(6)=1 : # Annulation acceptée
 [V]GMENLOC(7)=1 : # Annulation refusée
 If find([M:DCG1]STA0(nolign-1),2,5) : mkstat=2 : Endif
Endif
#SAVAN - X3-81285  Hiding Option on Tracking - start
If GCURLEG="BRI"
 Gosub AS_STA1 From SUBDCG2
Endif
#SAVAN - X3-81285  Hiding Option on Tracking - end
# STA0=état N-1 de la demande.1=Brouillon 2=Demande, 3=Accepté, 5=Demande annulation
Case [M:DCG1]STA0(nolign-1)
 When 0,1,2 : [V]GMENLOC(5)=1 : [V]GMENLOC(6)=1 : [V]GMENLOC(7)=1
 When 3     : [V]GMENLOC(1)=1 : [V]GMENLOC(2)=1 : [V]GMENLOC(3)=0 : [V]GMENLOC(4)=1 : [V]GMENLOC(7)=1 :#: [V]GMENLOC(6)=1
 When 4,6,7 : mkstat=2
 When 5     : [V]GMENLOC(1)=1 : [V]GMENLOC(2)=1 : [V]GMENLOC(4)=1
Endcase
End

########################################
Subprog C_STA(VALEUR)
Variable Integer VALEUR

Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET)
If !WRET
  mkstat     =2
  End
Endif


If [L]VALEUR<>5 & [L]VALEUR<>6 : End : Endif : # Demande d'annulation / Annulation acceptée
#MIPEA - 2016-12-19 - X3-12089- START
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
For [HRCTR]CTR0 Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&                 & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
&                 & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
 Filter [HRPEOD] Where PERSTR(0)<=[M:DCG1]ENDDAT(nolign-1)
&                 & PEREND(1)>=[M:DCG1]STRDAT(nolign-1) & find(PERCOD,"",[F:HRCTR]PERCOD)<>0
&      Order By Key CLE=PYRDAT;PERCOD Desc
 For [HRPEOD]CLE(1)
  If [F:HRPEOD]STA<>2 & [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE=mess(58,10709,1)
#   [V]GMESSAGE=mess(58,709,1) : # Période non ouverte à la saisie
#MIPEA - 2016-12-15 - X3-12089- END
   mkstat     =2
   Break 2
  Endif
 Next

 # Fiche 68349 - 25/10/2010 : même message si aucune période d'extraction
 If rowcount([F:HRPEOD]) = 0
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE=mess(58,10709,1)
#   [V]GMESSAGE=mess(58,709,1) : # Période non ouverte à la saisie
#MIPEA - 2016-12-15 - X3-12089- END
   mkstat     =2
   Break 2
 Endif
#For [CTR]CTR0 Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
#&                 & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
#&                 & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
# Filter [PEO] Where PERSTR(0)<=[M:DCG1]ENDDAT(nolign-1)
#&                 & PEREND(1)>=[M:DCG1]STRDAT(nolign-1) & find(FCY,"",[F:CTR]ETRFCY)<>0
#&      Order By Key CLE=PYRDAT;FCY Desc
# For [PEO]CLE(1)
#  If [F:PEO]STA<>2 & [V]GTPS
##MIPEA - 2016-12-15 - X3-12089- START
#    [V]GMESSAGE=mess(58,10709,1)
##   [V]GMESSAGE=mess(58,709,1) : # Période non ouverte à la saisie
##MIPEA - 2016-12-15 - X3-12089- END
#   mkstat     =2
#   Break 2
#  Endif
# Next
#
# # Fiche 68349 - 25/10/2010 : même message si aucune période d'extraction
# If rowcount([F:PEO]) = 0
##MIPEA - 2016-12-15 - X3-12089- START
#    [V]GMESSAGE=mess(58,10709,1)
##   [V]GMESSAGE=mess(58,709,1) : # Période non ouverte à la saisie
##MIPEA - 2016-12-15 - X3-12089- END
#   mkstat     =2
#   Break 2
# Endif
#MIPEA - 2016-12-19 - X3-12089- START
 # Interdire la demande d'annulation si l'arrêté des temps a déjà été fait sur la paie ou si paie suivante faite

#JOJAC - 2017-11-08 - X3-15908 - START
  Read [F:TIM]TIM0 = [M:DCG1]TIM
  If !fstat
    If [F:TIM]MONDAC=1
       Filter [VEP] Where EMP=[M:DCG1]REFNUM & CTRNUM=[F:CTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
&                 & ((STRDAT>=[F:HRPEOD]PERSTR(0) & ENDDAT<=[F:HRPEOD]PEREND(0)) | STRDAT>[F:HRPEOD]PEREND(0))
    Else
       Filter [VEP] Where EMP=[M:DCG1]REFNUM & CTRNUM=[F:CTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
&                 & ((STRDAT>=[F:HRPEOD]PERSTR(1) & ENDDAT<=[F:HRPEOD]PEREND(1)) | STRDAT>[F:HRPEOD]PEREND(1))
    Endif
    Read [VEP]VEP0 First
    If !fstat
      GMESSAGE = mess(20,10702,1)-num$([F:VEP]PYRDAT) : # Paye existante au
      mkstat = 2 : Break
    Endif
  Endif
##MIPEA - 2016-12-19 - X3-12089- START
# Filter [VEP] Where EMP=[M:DCG1]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
#&                 & ((STRDAT<=[M:DCG1]ENDDAT(nolign-1) & ENDDAT>=[M:DCG1]STRDAT(nolign-1)) | STRDAT>[M:DCG1]ENDDAT(nolign-1))
## Filter [VEP] Where EMP=[M:DCG1]REFNUM & CTRNUM=[F:CTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
##&                 & ((STRDAT<=[M:DCG1]ENDDAT(nolign-1) & ENDDAT>=[M:DCG1]STRDAT(nolign-1)) | STRDAT>[M:DCG1]ENDDAT(nolign-1))
##MIPEA - 2016-12-19 - X3-12089- END
# Read [VEP]VEP0 First
# If !fstat
##MIPEA - 2016-12-15 - X3-12089- START
#  GMESSAGE = mess(20,10702,1)-num$([F:VEP]PYRDAT)
##  GMESSAGE = mess(20,702,1)-num$([F:VEP]PYRDAT) : # Paye existante au
##MIPEA - 2016-12-15 - X3-12089- END
#  mkstat = 2 : Break
# Endif
#JOJAC - 2017-11-09 - X3-15908 - END


Next
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRPEOD]
#Filter [HRPEO]
#MIPEA - 2016-12-19 - X3-12089- END
End

Subprog AM_STA(VALEUR)
Variable Integer VALEUR
If VALEUR > 1 & VALEUR <> 4 & VALEUR <> 6 & VALEUR <> 5       : # 65767
 [M:DCG1]STA(nolign-1)=VALEUR
 Call C_TIM([M:DCG1]TIM(nolign-1))
 Call CONTROL_DATE([M:DCG1]ENDDAY(nolign-1),[M:DCG1]STRDAY(nolign-1)): #73469+73242 appel du contrôle pour comportement homogène
Endif
End

######################################################################################
# 60195
######################################################################################

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read [F:ID]ID0=VALEUR
If !fstat
 [M:DCG1]SRNNAM=[F:ID]NAM-[F:ID]SRN
#JASMI - START
##MIPEA - 2016-12-15 - X3-12089- START
#  [M:DCG1]FLGMULCTR =string$([F:ID]FLGMULCTR<>2,"-")+"KM:"+num$([V]GLONHRCTR)+"X"
## [M:DCG1]FLGMULCTR =string$([F:ID]FLGMULCTR<>2,"-")+"KM:"+num$([V]GLONCTR)+"X"
##MIPEA - 2016-12-15 - X3-12089- END
#JASMI - END
#JASMI - START
# [M:DCG1]FCY    = [F:ID]FCY
 [M:DCG1]FCY    = [F:ID]FCYORI
#JASMI - END
 [M:DCG1]SRV    = [F:ID]SRV

Endif

# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
#Filter [CTR] Where REFNUM=VALEUR & (CTRDAT<=[M:DCG1]DATFIN | (FLGRET=2 & RETDATEFF<=[M:DCG1]DATFIN))
#Read[CTR]CTR1 Last
#Filter [CTR]
#If !fstat
# [M:DCG1]FCY    = [F:CTR]ETRFCY
# [M:DCG1]SRV    = [F:CTR]ETRSRV
#Endif
#MIPEA - 2016-12-19 - X3-12089- END
Affzo SRNNAM, FCY, SRV

End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

# FQ106640 - 27/02/15 - si multi-contrats, le contrat le plus récent n'est pas forcément celui en cours
Local    Integer FOUNDCTR : FOUNDCTR=0

# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=VALEUR & (CTRDAT<=[M:DCG1]DATFIN | (FLGRET=2 & RETDATEFF<=[M:DCG1]DATFIN))
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M:DCG1]DATFIN | (FLGRET=2 & RETDATEFF<=[M:DCG1]DATFIN)) Order By CTRDAT Desc
If [F:ID]FLGMULCTR<>2 Then
#  Read [CTR]CTR1 Last
  Read [HRCTR] First
Else
  For [HRCTR]
    If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<[M:DCG1]DATDEB Then
    Else
      FOUNDCTR=1
      Break
    Endif
  Next
  If !FOUNDCTR Then Read [HRCTR] First : Endif
Endif
Filter [HRCTR]
