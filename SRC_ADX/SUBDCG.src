$AVANT_OUVRE
# 1 = accès à tous les utilisateurs
If instr(1,[V]GUSRAUZ(1),"1") : Return : Endif
If !clalev([F:ID]) : Local File EMPLOID [ID] : Endif
If [L]CLE1>"" : Read [ID]ID0=[L]CLE1 : Else Read [ID]ID0=[V]GREFNUM : Endif
If fstat | [F:ID]ENAFLG<>2 | [F:ID]FLGTPS<>2
#MIPEA - 2016-12-15 - X3-12089- START
[V]GMESSAGE=mess(11,10709,1)
# [V]GMESSAGE=mess(11,709,1) : # Pas de saisie des temps pour cet employé
 #MIPEA - 2016-12-15 - X3-12089- END
 [L]OK      =0
Endif
#62305
CLE1 = [ID]REFNUM
Return

