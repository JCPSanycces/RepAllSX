######################################################################################
## Section automatically added (screen DCG1) 08/25/2017 07:32:05 (PEVAN)
######################################################################################
## PEVAN 2017-08-25 X3-52026 START
Subprog S_LVESUBRAT(VALEUR)
Variable Decimal VALEUR
  Local Integer NBRATETYP
  Local Integer RATETYP
  Local Char LIBRATETYP(130)(0..100)
  Local Char TITLE(250) : TITLE = mess(8,11691,1)

  If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif

  Filter [F:HRLSTH] Where LEG = GCURLEG & COD = [M:DCG1]WLVESUBTYP(nolign-1)
  Read [HRLSTH] Last

  If rowcount([HRLSTH]) = 0
    GERR = 2 : GMESSAGE = mess(99,100,1) #### MIPEA make better message here
  Endif

  For RT = 0 To dim([F:HRLSTH]LVEPAYDES)-1
    If [F:HRLSTH]LVEPAYDES(RT)="" : Break : Endif
    NBRATETYP+=1
    LIBRATETYP(NBRATETYP) = [F:HRLSTH]LVEPAYDES(RT)
  Next

  Call SAITEX(NBRATETYP,LIBRATETYP,RATETYP,TITLE) From GESECRAN # Choose rate types from leave sub type setup

  If RATETYP>0
    [M:DCG1]WLVESUBRAT(nolign-1) = RATETYP
    VALEUR = RATETYP
  Else
    VALEUR=""
  Endif
  Filter [F:HRLSTH]
End
## PEVAN 2017-08-25 X3-52026 END

######################################################################################
Subprog C_LVENOT(VALEUR)
Variable Integer VALEUR
Local Integer DIFDAT : DIFDAT = 0
Local Integer DOK : DOK = 0
Local Date BLNKDAT : Raz BLNKDAT

#LIPET - 2017-08-25 - X3-53555 - START
If clalev([F:TIM3])=0 : Local File TIMCOD  [TIM3] : Endif

  DIFDAT = ([M:DCG1]ENDDAT(nolign-1) - [M:DCG1]STRDAT(nolign-1))+1

  Filter [TIM3] Where COD = [M]TIM(nolign-1) and LEG = GCURLEG
  Read [TIM3] First
  Filter [TIM3]
  If !fstat Then
    If [TIM3]NBRDAY > 0 and [M]NBRDAY(nolign-1) >= [TIM3]NBRDAY Then
      If VALEUR = 1 Then
        GERR=1
        [V]GMESSAGE = mess(10,123,1)
        mkstat =2
        GOK=0 :End
      Endif
    Elsif [TIM3]NONBUS = 2 and DIFDAT >= [TIM3]NBRDAY  Then
      If VALEUR = 1 Then
        GERR=1
        [V]GMESSAGE = mess(10,123,1)
        mkstat =2
        GOK=0 :End
      Endif
    Elsif [TIM3]BFRNON = 2 | [TIM3]AFTNON = 2 Then
      If VALEUR = 1 Then
        Local Integer BEFORENON, AFTERNON
        BEFORENON = [TIM3]BFRNON
        AFTERNON = [TIM3]AFTNON
        Call COMPARE_DAYS([M:DCG1]STRDAT(nolign-1), [M:DCG1]ENDDAT(nolign-1), [M:DCG1]CTRNUM(nolign-1), BEFORENON, AFTERNON, DOK) From SUBDCG2
        If DOK=1:mkstat=2:End:Endif
      Endif
    Endif
  Endif
#LIPET - 2017-08-25 - X3-53555 - END

End


