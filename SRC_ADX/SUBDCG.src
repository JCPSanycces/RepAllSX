#JASMI - 2017-09-29 - XXX - END

#PEVAN - 2018-04-04 - X3-81467 - START
  If func AFNC.ACTIV("GLM")
    Local Integer ISNEW #0 = false; 1 = true;
    If [F:DCG]UID = 0 : ISNEW = 1 : Else : ISNEW = 0 : Endif
  Endif
