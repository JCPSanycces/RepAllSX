#-------------------------------------------------------------------------------
$MAJTIP
Local Decimal JOUR(1..400), HEURE(1..400), JOUR1(1..400)
Local Shortint PDEB, PFIN, CDEB, CFIN, DFIN
Gosub DEFVARWRK From TPSSTD
Gosub OUVRE From WODCG
#===================================================================================================
# WG : notes sur les variables de travail. nombres toujours entiers.
# DFIN : Nombre de jour(s) posé(s) du jour début au jour fin demandé
#
# CDEB : Nombre de jour(s) décalage pour jour début
#        depuis date début demandée et en intégrant date de début contrat
#        1=> jour début = 1er jour demandé , 2=> jour début = lendemain du 1er jour demandé , etc.
#
# CFIN : Nombre de jour(s) décalage pour jour fin
#        depuis date début demandée et en intégrant date de fin contrat
#        1=> jour fin = 1er jour demandé , 2=> jour fin = lendemain du 1er jour demandé , etc.
#
# PDEB : Nombre de jour(s) décalage pour jour début
#        depuis date début demandée , en intégrant date de début contrat
#        et date début de période d'extraction
#        même principe que CDEB
#
# PFIN : Nombre de jour(s) décalage pour jour fin
#        depuis date début demandée , en intégrant date fin de contrat
#        et date fin période d'extraction
#        même principe que CFIN
#
# []STRDAY(n) = 2 : []ENDDAY(n) = 1 : # Absent le matin      le dernier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 2 : # Absent l' après-midi le premier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 1 : # Absent la journée    du premier au dernier jour
#===================================================================================================

# UID < 0 : Lignes annulées (les lignes modifiées génèrent 1 ligne annulée et une ligne créée)
For [DCG] Where UID<0 & WRK>"" & REFNUM=[F:ID]REFNUM     : # 62798
  If GTPS=1
   # Suppression d'une demande qui a généré dans TIMREGUL des temps
#   For [TIG1] Where DCGUID=-[F:DCG]UID
    For [TIG1] Where DCGUID=-[F:DCG]UID With Stability  : # 68494
      If [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
        Case [F:DCG]WRK
          When "S" : [L]WRK=mess(74,10709,1) : # Suppression
          When "M" : [L]WRK=mess(76,10709,1) : # Modif (avant)
        Endcase
#     Case [F:DCG]WRK
#      When "S" : [L]WRK=mess(74,709,1) : # Suppression
#      When "M" : [L]WRK=mess(76,709,1) : # Modif (avant)
#     Endcase
#MIPEA - 2016-12-15 - X3-12089- END
        Gosub WORKFLOW From TPSSTD
      Endif
    # Génération régul pour annuler TIMREGUL + pour mettre W
      Raz [F:TIG]
      [F:TIG]       = [F:TIG1]
      [F:TIG]LIG    = uniqid([TIP])
      [F:TIG]NBRDAY = (-1)*[F:TIG1]NBRDAY
      [F:TIG]NBRHOU = (-1)*[F:TIG1]NBRHOU
    # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
#    [F:TIG]FLGBUL = 2

      ####MIPEA - 2017-09-11- US X3-54010- START
      If func AFNC.ACTIV("GLM")
        For X = 0 To dim([F:TIG1]LVESUBTYP)-1
          If [F:TIG]NBRDAY > 0 and [F:TIG1]LVESUBBAL(X) < 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIG1]LVESUBBAL(X)
          Elsif [F:TIG]NBRDAY < 0 and [F:TIG1]LVESUBBAL(X) > 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIG1]LVESUBBAL(X)
          Endif
        Next
      #JASMI - 2017-10-18 - xxx - START
        If [F:TIG]DATBUL<>[0/0/0]
          [F:TIG]DATBUL=[0/0/0]
          [F:TIG]BUL=''
        Endif
      #JASMI - 2017-10-18 - xxx - END
      Endif
      ####MIPEA - 2017-09-11- US X3-54010- END

      LESITE = [F:TIG1]FCY
#MIPEA - 2016-12-19 - X3-12089- START
#    Call PERIO(LESITE,[F:TIG]REFNUM) From SUBHRPEO
#    Call PERIO(LESITE,[F:TIG]REFNUM) From SUBPEO
      Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
      Read [HRPEOD1]HRPEOD0 First
      Filter [HRPEOD1]
#    Filter [HRPEOD1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#    Read [HRPEOD1]HRPEOD0 First
#    If fstat
#     Filter [HRPEOD1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#     Read [HRPEOD1]HRPEOD0 First
#    Endif
#    Filter [HRPEOD1]
#MIPEA - 2016-12-19 - X3-12089- END
      If !fstat
#MIPEA - 2016-12-19 - X3-12089- START
      [F:TIG]DATPYR = [F:HRPEOD1]PYRDAT
#     [F:TIG]DATPYR = [F:PEO1]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
        If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
          [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
      # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
          If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
          Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
          If !fstat Then
            If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
            If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
          Endif
#      If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#      Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#      If !fstat Then
#        If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#        If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#      Endif
#MIPEA - 2016-12-19 - X3-12089- END
        Endif
        Write[TIG]
        If fstat
          [V]GOK=0
          Call FSTA("TIG") From GLOCK
          Break 2
        Endif
        Raz [L]JOUR
#MIPEA - 2016-12-19 - X3-12089- START
        Read [TIM]TIM0=GCURLEG;[F:TIG]TIM
#     Read [TIM]TIM0=[F:TIG]TIM
#MIPEA - 2016-12-19 - X3-12089- END
        Gosub MAJCP1 From TPSSTDR
        If [V]GOK<1 : Break 2 : Endif
      Endif
    Next
  Endif

  # Suppression d'une demande qui a généré dans TIMEMP des temps
###JASMI - 2017-09-22 - START
  For [TIP] Where DCGUID=-[F:DCG]UID
###  Link [F:TIP] With [F:TIM]TIM0 = GCURLEG;[F:TIP]TIM As [LNK2]
###& Where [F:TIP]DCGUID=-[F:DCG]UID & [F:TIM]CATTIM=1
###  For [LNK2]
###JASMI - 2017-09-22 - END
    If [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
      Case [F:DCG]WRK
        When "S" : [L]WRK=mess(74,10709,1) : # Suppression
        When "M" : [L]WRK=mess(76,10709,1) : # Modif (avant)
      Endcase
#    Case [F:DCG]WRK
#     When "S" : [L]WRK=mess(74,709,1) : # Suppression
#     When "M" : [L]WRK=mess(76,709,1) : # Modif (avant)
#    Endcase
#MIPEA - 2016-12-15 - X3-12089- END
      Gosub WORKFLOW From TPSSTD
    Endif
# 28/03/01 - Bug 72654
# - Pouvoir saisir quand on n'a pas GPAYE et GTPS
#   Filter [VEP] Where EMP=[F:DCG]REFNUM & CTRNUM=[F:CTR]CTRNUM & PYRDAT=[F:TIP]DATPYR
#   Read [VEP]VEP0 Last
#   Filter [VEP]
#   If fstat | ([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
    If [V]GPAYE
    # 21/10/11 77113 - on ne prend pas le bon contrat
      Filter [VEP] Where EMP=[F:DCG]REFNUM & CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:TIP]DATPYR
      Read [VEP]VEP0 Last
      Filter [VEP]
    Endif
    If ![V]GPAYE | fstat | ([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
    # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
      Call SUPP_CPPRIS From TPSSTD1
      If [V]GOK<1 : Break 2 : Endif
      Delete [TIP] Curr
      If fstat
        [V]GOK=0
        Call FSTA("TIP") From GLOCK
        Break 2
      Endif
    Else
    # Génération régul pour annuler TIMEMP
      Raz [F:TIG]
      [F:TIG]       = [F:TIP]
      [F:TIG]LIG    = uniqid([TIP])
      [F:TIG]NBRDAY = (-1)*[F:TIP]NBRDAY
      [F:TIG]NBRHOU = (-1)*[F:TIP]NBRHOU
    # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
#    [F:TIG]FLGBUL = 2

      ####MIPEA - 2017-09-11- US X3-54010- START
      If func AFNC.ACTIV("GLM")
        For X = 0 To dim([F:TIP]LVESUBTYP)-1
          If [F:TIG]NBRDAY > 0 and [F:TIP]LVESUBBAL(X) < 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIP]LVESUBBAL(X)
          Elsif [F:TIG]NBRDAY < 0 and [F:TIP]LVESUBBAL(X) > 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIP]LVESUBBAL(X)
          Endif
        Next
      #JASMI - 2017-10-18 - xxx - START
        If [F:TIG]DATBUL<>[0/0/0]
          [F:TIG]DATBUL=[0/0/0]
          [F:TIG]BUL=''
        Endif
      #JASMI - 2017-10-18 - xxx - END
      Endif
      ####MIPEA - 2017-09-11- US X3-54010- END
      LESITE = [F:TIP]FCY
#MIPEA - 2016-12-19 - X3-12089- START
#    Call PERIO(LESITE,[F:TIP]REFNUM) From SUBPEO
      Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:TIP]STRDAT & PEREND(R1)>=[F:TIP]ENDDAT
      Read [HRPEOD1]HRPEOD0 First
      Filter [HRPEOD1]
#    Filter [HRPEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIP]STRDAT & PEREND(R1)>=[F:TIP]ENDDAT
#    Read [HRPEO1]PEO0 First
#    If fstat
#     Filter [HRPEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIP]STRDAT & PEREND(R1)>=[F:TIP]ENDDAT
#     Read [HRPEO1]PEO0 First
#    Endif
#    Filter [HRPEO1]
#MIPEA - 2016-12-19 - X3-12089- END
      If !fstat
#MIPEA - 2016-12-19 - X3-12089- START
        [F:TIG]DATPYR = [F:HRPEOD1]PYRDAT
#     [F:TIG]DATPYR = [F:PEO1]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
        If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
          [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
      # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
          If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
          Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
          If !fstat Then
            If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
            If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
          Endif
#      If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#      Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#      If !fstat Then
#        If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#        If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#      Endif
#MIPEA - 2016-12-19 - X3-12089- END
        Endif
        Write[TIG]
        If fstat
          [V]GOK=0
          Call FSTA("TIG") From GLOCK
          Break 2
        Endif
        Raz [L]JOUR
#MIPEA - 2016-12-19 - X3-12089- START
        Read [TIM]TIM0=GCURLEG;[F:TIG]TIM
#     Read [TIM]TIM0=[F:TIG]TIM
#MIPEA - 2016-12-19 - X3-12089- END
        Gosub MAJCP1 From TPSSTDR
        If [V]GOK<1 : Break 2 : Endif
     # Génération régul pour mettre W
        [F:TIG]LIG = uniqid([TIP])
    #JASMI - 2017-10-18 - xxx - START
#         [F:TIG]TIM = GTPSW
#     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
#        If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
#          [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
#      # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
##MIPEA - 2016-12-19 - X3-12089- START
#          If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
#          Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#          If !fstat Then
#            If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
#            If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
#          Endif
##      If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
##      Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
##      If !fstat Then
##        If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
##        If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
##      Endif
##MIPEA - 2016-12-19 - X3-12089- END
#        Endif
#        Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
         If [F:DCG]WRK="X"
          [F:TIG]TIM = GTPSW
       # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
          If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
            [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
        # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
  #MIPEA - 2016-12-19 - X3-12089- START
            If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
            Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
            If !fstat Then
              If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
              If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
            Endif
  #      If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  #      Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
  #      If !fstat Then
  #        If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
  #        If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
  #      Endif
  #MIPEA - 2016-12-19 - X3-12089- END
          Endif
          Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
        Else
         [F:TIG]NBRDAY = (-1)*[F:TIG]NBRDAY
         [F:TIG]NBRHOU = (-1)*[F:TIG]NBRHOU
         If func AFNC.ACTIV("GLM")
           For X = 0 To dim([F:TIP]LVESUBTYP)-1
             [F:TIG]LVESUBBAL(X) = -1*[F:TIG]LVESUBBAL(X)
           Next
         Endif
       #JASMI - 2017-10-18 - xxx - START
         If [F:TIG]DATBUL<>[0/0/0]
           [F:TIG]DATBUL=[0/0/0]
           [F:TIG]BUL=''
         Endif
       #JASMI - 2017-10-18 - xxx - END
        Endif
    #JASMI - 2017-10-18 - xxx - END
        Write[TIG]
        If fstat
          [V]GOK=0
          Call FSTA("TIG") From GLOCK
          Break 2
        Endif
      Endif
    Endif
  Next

Next
If [V]GOK<1 : Return : Endif

#62798 - For [DCG] Where UID>0 & evalue([L]CRITERE2(0)) & STA=6-[V]GWEBSERV
# STA = 6 : Annulation acceptée
For [DCG] Where UID>0 & evalue([L]CRITERE2(0)) & STA=6

  If evalue([L]CRITERE2(1))
    For [TIP]TIP1 Where REFNUM=[F:DCG]REFNUM & find([F:DCG]CTRNUM,"",CTRNUM)
&                   & STRDAT>=[F:DCG]STRDAT & ENDDAT<=[F:DCG]ENDDAT & TIM=[F:DCG]TIM
#  Si Temps et Absence se chevauchent on supprimme les temps
# 27/10/11 FQ 77350 si on a
# 1/2 journée le matin dans TIP et 1/2 le matin dans DCG
# ou 1/2 journée le l'aprés midi dans TIP et 1/2 le aprés midi dans DCG
# Il y a chevauchement et donc il faut supprimer TIMEMP
      If ( [F:TIP]STRDAT<[F:DCG]ENDDAT
&     | ([F:TIP]STRDAT=[F:DCG]ENDDAT & ([F:TIP]STRDAY<2 | [F:DCG]ENDDAY<2))
&     )
&   & ( [F:TIP]ENDDAT>[F:DCG]STRDAT
&     | ([F:TIP]ENDDAT=[F:DCG]STRDAT & ([F:TIP]ENDDAY<2 | [F:DCG]STRDAY<2))
&     )
        If [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
          [L]WRK=mess(74,10709,1) : # Suppression
#     [L]WRK=mess(74,709,1) : # Suppression
#MIPEA - 2016-12-15 - X3-12089- END
          Gosub WORKFLOW From TPSSTD
        Endif
        Call SUPP_CPPRIS From TPSSTD1
        If [V]GOK<1 : Break 2 : Endif
        Delete [TIP] Curr
        If fstat
          [V]GOK=0
          Call FSTA("TIP") From GLOCK
          Break 2
        Endif
      Endif
    Next
  Endif
Next
If [V]GOK<1 : Return : Endif
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
# FQ??? - 14/03/14 - Pas de test sur la date de rétro, sinon on comptabilise plusieurs fois la même absence avec le Link
#MIPEA - 2016-12-19 - X3-12089- START

#JASMI - START
#Link [DCG] With [HRCTR2]CTR0(1)=REFNUM
#&             , [TIM]TIM0    =TIM
#&             , [FCY]FCY0    =[HRCTR2]ETRFCY
#&             , [CPY]CPY0    =[FCY]LEGCPY
#&            As [LNK]
#&         Where ([HRCTR2]CTRDAT<=ENDDAT & ([HRCTR2]XITDAT=[0/0/0] | [HRCTR2]XITDAT>=STRDAT))
#&             & find(CTRNUM,"",[F:HRCTR2]CTRNUM)<>0
#&  Order By Key CLE=UID
Link [DCG] With [HRCTR2]CTR0(1)=REFNUM
&             , [TIM]TIM0    =GCURLEG;TIM
&             , [FCY]FCY0    =[HRCTR2]ETRFCY
&             , [CPY]CPY0    =[FCY]LEGCPY
&            As [LNK]
&         Where ([HRCTR2]CTRDAT<=ENDDAT & ([HRCTR2]XITDAT=[0/0/0] | [HRCTR2]XITDAT>=STRDAT))
&             & find(CTRNUM,"",[F:HRCTR2]CTRNUM)<>0
&  Order By Key CLE=UID
#JASMI - END

#Link [DCG] With [CTR2]CTR0(1)=REFNUM
#&             , [TIM]TIM0    =TIM
#&             , [FCY]FCY0    =[CTR2]ETRFCY
#&             , [CPY]CPY0    =[FCY]LEGCPY
#&            As [LNK]
#&         Where ([CTR2]CTRDAT<=ENDDAT & ([CTR2]XITDAT=[0/0/0] | [CTR2]XITDAT>=STRDAT))
#&             & find(CTRNUM,"",[F:CTR2]CTRNUM)<>0
#&  Order By Key CLE=UID
#MIPEA - 2016-12-19 - X3-12089- END

# Le statut Accepté, demande annulation et annulation acceptée crée un enreg dans TIMEMP.
# Si demande annulation, suppression de l'enreg TIMEMP associé à la demande acceptée et re-création
# Si annulation acceptée, suppression de l'enreg TIMEMP associé à la demande annulation

Filter [LNK] Where find([F:DCG]STA,3,5,7)<>0  : # 62798

# Demandes acceptées en heures
For [LNK]CLE Where UID>0 & evalue([L]CRITERE2(0)) & [F:TIM]DAYDAC<2
  Raz ITER
  If evalue([L]CRITERE2(1))
#MIPEA - 2016-12-05 - X3-12089- START
    LESITE = [F:HRCTR2]ETRFCY
#  LESITE = [F:CTR2]ETRFCY
#  Call PERIO(LESITE,[F:HRCTR2]REFNUM) From SUBPEO
#MIPEA - 2016-12-05 - X3-12089- END
    For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]ENDDAT & ENDDAT>=[F:DCG]STRDAT
   # FQ105844 - 24/02/15 - Si 1/2 journée, on vérifie qu'on n'est pas sur la même 1/2 journée
      If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
      Else
     # La demande concerne des jours déjà saisis dans TIMEMP : que la paie soit arrêtée ou pas, on passe régul
#MIPEA - 2016-12-19 - X3-12089- START
        If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
#     If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:CTR2]CTRNUM)
#MIPEA - 2016-12-19 - X3-12089- END
          For ITER=1 To 4
            Gosub REGUL
            If GOK<1 : Break 3 : Endif
          Next
        Endif
      Endif
    Next

# 19/03/13 - FQ88381
# - Si déjà en paye on passe directement en régul
    If ITER=0 & [V]GPAYE
      Local Date WPERSTR, WPEREND, WPYRDAT
      Raz WPERSTR, WPEREND, WPYRDAT
    J=([F:TIM]MONDAC=2)
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2017-08-29- US X3-54010- START
      Filter [HRPEOD] Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0 & ((PERSTR(J) >= [F:DCG]STRDAT & PEREND(J) <= [F:DCG]ENDDAT) or
&                  (PERSTR(J) <= [F:DCG]STRDAT & PEREND(J) >= [F:DCG]ENDDAT) or (PERSTR(J) <= [F:DCG]STRDAT & PEREND(J) >= [F:DCG]STRDAT))
&                   Order By Key CLE=PERCOD Desc;PYRDAT
#    Filter [HRPEOD] Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0
#&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
#&         Order By Key CLE=PERCOD Desc;PYRDAT
#MIPEA - 2017-08-29- US X3-54010- END
      For [HRPEOD]CLE(1)
        For [HRPEOD]CLE
          WPERSTR=[F:HRPEOD]PERSTR(J)
          WPEREND=[F:HRPEOD]PEREND(J)
          If [F:HRPEOD]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
#    Filter [HRPEO] Where find(FCY,"",LESITE)<>0
#&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
#&         Order By Key CLE=FCY Desc;PYRDAT
#    For [HRPEO]CLE(1)
#     For [HRPEO]CLE
#       WPERSTR=[F:PEO]PERSTR(J)
#       WPEREND=[F:PEO]PEREND(J)
#       If [F:PEO]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
#MIPEA - 2016-12-19 - X3-12089- END
        Next
        Break
      Next
      If WPERSTR <> [0/0/0] & WPEREND <> [0/0/0] & WPYRDAT <> [0/0/0]
#     & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT)
#MIPEA - 2016-12-19 - X3-12089- START
        Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM) & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
&     & [F:VEP]PYRDAT=[F:HRPEOD]PYRDAT
#      Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM) & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
#&     & [F:VEP]PYRDAT=[F:PEO]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
        Read [VEP]VEP0 Last
        Filter [VEP]
      # FQ??? - 14/03/14 - Il faut vérifier quand même que la date de l'absence est bien <= à la date du dernier temps comptabilisé
      # sur cette paie, sinon on risque d'oublier des temps. D'où le test sur DATTPS.
        If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&               & [F:VEP]DATTPS>=[F:DCG]STRDAT
      # Paie générée ou Paie comptabilisée
          ITER=1
          Gosub REGUL
          If GOK<1 : Break 1 : Endif
        Endif
      Endif
    Endif
    If ITER=0
      Raz [F:TIP]
      [F:TIP]      =[F:DCG]

#MIPEA - 2016-12-19 - X3-12089- START
      [F:TIP]CTRNUM=[F:HRCTR2]CTRNUM
      [F:TIP]FCY   =[F:HRCTR2]ETRFCY
      [F:TIP]SRV   =[F:HRCTR2]ETRSRV
#   [F:TIP]CTRNUM=[F:CTR2]CTRNUM
#   [F:TIP]FCY   =[F:CTR2]ETRFCY
#   [F:TIP]SRV   =[F:CTR2]ETRSRV
#MIPEA - 2016-12-19 - X3-12089- END

      J=([F:TIM]MONDAC=2)
#MIPEA - 2016-12-19 - X3-12089- START
#MIPEA - 2017-08-29- US X3-54010- START
      Filter [HRPEOD] Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0 & ((PERSTR(J) >= [F:DCG]STRDAT & PEREND(J) <= [F:DCG]ENDDAT) or
&                   (PERSTR(J) <= [F:DCG]STRDAT & PEREND(J) >= [F:DCG]ENDDAT) or (PERSTR(J) <= [F:DCG]STRDAT & PEREND(J) >= [F:DCG]STRDAT))
&                   Order By Key CLE=PERCOD Desc;PYRDAT
#   Filter [HRPEOD] Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0
#&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
#&         Order By Key CLE=PERCOD Desc;PYRDAT
#MIPEA - 2017-08-29- US X3-54010- END
      For [HRPEOD]CLE(1)
        For [HRPEOD]CLE
          [F:TIP]DATPYR=[F:HRPEOD]PYRDAT
          If [F:HRPEOD]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
#   Filter [HRPEO] Where find(FCY,"",LESITE)<>0
#&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
#&         Order By Key CLE=FCY Desc;PYRDAT
#   For [HRPEO]CLE(1)
#     For [HRPEO]CLE
#       [F:TIP]DATPYR=[F:PEO]PYRDAT
#       If [F:PEO]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
#MIPEA - 2016-12-19 - X3-12089- END
        Next
        Break
      Next

      [F:TIP]AUTFLG =2
      [F:TIP]STAFLG =[V]GUSER
      [F:TIP]STA    =0 : # à quoi ça sert ?
      [F:TIP]ANAFLG=0
      [F:TIP]DSP   =""
   # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
      If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
        [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
    # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
        If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
        Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
        If !fstat Then
          If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
          If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
        Endif
#    If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#    Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#    If !fstat Then
#      If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#      If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#    Endif
#MIPEA - 2016-12-19 - X3-12089- END
      Endif
   # FQ92876 - 26/06/14 - Ajout [F:TIP]CPY utilisé dans INISEC_DSP_EMPTY
      [F:TIP]CPY= func DIVPAYE.GETSOC([F:TIP]FCY)
      Gosub INICCE
      If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR=[V]GUSER  : Endif
      If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT=date$     : Endif
      If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM=time      : Endif
      If dim([F:TIP]EXPNUM)>0 : [F:TIP]EXPNUM=[C]EXPORT : Endif


#   Infbox 'WRT_TIP1'
      Gosub WRT_TIP
      If [V]GOK<1 : Break : Endif
    Endif
  Endif
Next
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRPEOD]
#Filter [HRPEO]
#MIPEA - 2016-12-19 - X3-12089- END
If [V]GOK<1 : Filter [LNK] : Return : Endif

# Demandes acceptées en jour
Local Date DATDEBCTR
For [LNK]CLE(1) Where UID>0 & evalue([L]CRITERE2(0)) & [TIM]DAYDAC=2
  If evalue([L]CRITERE2(1))
    [L]DFIN=[F:DCG]ENDDAT-[F:DCG]STRDAT+1
    For [LNK]CLE
   # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
      DATDEBCTR=[F:HRCTR2]CTRDAT
      If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
        DATDEBCTR=[F:HRCTR2]RETDATEFF
      Endif
      [L]CDEB=max([F:DCG]STRDAT,DATDEBCTR)-[F:DCG]STRDAT+1
      If [F:HRCTR2]XITDAT=[0/0/0] : [L]CFIN=[L]DFIN
      Else
        [L]CFIN=min([F:DCG]ENDDAT,[F:HRCTR2]XITDAT)-[F:DCG]STRDAT+1
      Endif
      Raz [L]JOUR
      If [F:HRCTR2]PLNTYP=""
        For I=[L]CDEB To [L]CFIN : [L]JOUR(I)=1 : Next
      Else
    #CHECK IGNORE_BEGIN
        Call VALORDET( [F:DCG]STRDAT+[L]CDEB-1,[F:DCG]STRDAT+[L]CFIN-1,[F:DCG]REFNUM
&                , [F:DCG]TIM,[L]JOUR([L]CDEB..[L]CFIN),[L]HEURE([L]CDEB..[L]CFIN)
&                , [F:HRCTR2]ETRFCY,[F:HRCTR2]CTRNUM
&                ) From SUBPLN
#   DATDEBCTR=[F:CTR2]CTRDAT
#   If [F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then
#     DATDEBCTR=[F:CTR2]RETDATEFF
#   Endif
#   [L]CDEB=max([F:DCG]STRDAT,DATDEBCTR)-[F:DCG]STRDAT+1
#   If [F:CTR2]XITDAT=[0/0/0] : [L]CFIN=[L]DFIN
#   Else                        [L]CFIN=min([F:DCG]ENDDAT,[F:CTR2]XITDAT)-[F:DCG]STRDAT+1
#   Endif
#   Raz [L]JOUR
#   If [F:CTR2]PLNTYP=""
#    For I=[L]CDEB To [L]CFIN : [L]JOUR(I)=1 : Next
#   Else
#    #CHECK IGNORE_BEGIN
#    Call VALORDET( [F:DCG]STRDAT+[L]CDEB-1,[F:DCG]STRDAT+[L]CFIN-1,[F:DCG]REFNUM
#&                , [F:DCG]TIM,[L]JOUR([L]CDEB..[L]CFIN),[L]HEURE([L]CDEB..[L]CFIN)
#&                , [F:CTR2]ETRFCY,[F:CTR2]CTRNUM
#&                ) From SUBPLN
#MIPEA - 2016-12-19 - X3-12089- END
    #CHECK IGNORE_END
      Endif
#  73242   If [F:DCG]STRDAY=2 & [L]CDEB=1
      If [F:DCG]ENDDAY=2 & [L]CDEB=1
        If [L]JOUR(1)<=0.5
          Raz [L]HEURE(1), [L]JOUR(1)
        Else
          [L]HEURE(1)*=([L]JOUR(1)-0.5)/[L]JOUR(1) : [L]JOUR(1)-=0.5
        Endif
      Endif
#  73242   If [F:DCG]ENDDAY=2 & [L]CFIN=[L]DFIN
      If [F:DCG]STRDAY=2 & [L]CFIN=[L]DFIN
        If [L]JOUR([L]DFIN)<=0.5
          Raz [L]HEURE([L]DFIN), [L]JOUR([L]DFIN)
        Else
          [L]HEURE([L]DFIN)*=([L]JOUR([L]DFIN)-0.5)/[L]JOUR([L]DFIN)
          [L]JOUR ([L]DFIN)-=0.5
        Endif
      Endif

      J=([F:TIM]MONDAC=2)
#MIPEA - 2016-12-05 - X3-12089- START
      LESITE = [F:HRCTR2]ETRFCY
#   Call PERIO(LESITE,[F:HRCTR2]REFNUM) From SUBPEO
#MIPEA - 2016-12-05 - X3-12089- END

   # Pb si PERIOD a 1 enreg avec un site et une date de paie au 28/01/2009 et 1 enreg avec site="" et une date de paie au 31/01/2009
   # On passe 2 fois la régul
   #Filter [PEO] Where find(FCY,"",LESITE)<>0 & PEREND(J)>=[F:DCG]STRDAT+[L]CDEB-1
   #&& PERSTR(J)<=[F:DCG]STRDAT+[L]CFIN-1
   #&Order By Key CLE=PYRDAT;FCY Desc
   #For [PEO]CLE(1)
#MIPEA - 2016-12-19 - X3-12089- START
      Raz OLDYEA,OLDPERCOD
#   Raz OLDYEA,OLDFCY
#MIPEA - 2016-12-19 - X3-12089- END
   # FQ94174 - 23/12/13 - si décalage de paie, on est forcément dans ce cas. On ne veut pas pour autant faire le filtre sur toutes les périodes
      If val(func AFNC.PARAM("JPAY",LESITE))>0 Then
        Local Date PYRDATPEO
#MIPEA - 2016-12-19 - X3-12089- START
        PYRDATPEO=[F:HRPEOD]PYRDAT
#JASMI - 2016-12-09 - START
#     Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT=PYRDATPEO
#&        Order By Key CLE=PERCOD;YEA Desc;PYRDAT
        Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT=PYRDATPEO
&        Order By Key CLE=PERYEA;PERCOD Desc;PYRDAT
#JASMI - 2016-12-09 - END
      Else
        Filter [HRPEOD] Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0 & PEREND(J)>=[F:DCG]STRDAT+[L]CDEB-1
&                     & PERSTR(J)<=[F:DCG]STRDAT+[L]CFIN-1
&          Order By Key CLE=PERCOD Desc;PERYEA;PYRDAT : #113959 la priorité est au site avant l'année, sinon au aura en 1er la période sans site
#&          Order By Key CLE=YEA;FCY Desc;PYRDAT
      Endif
      For [HRPEOD]CLE(2)
        If OLDYEA<>[F:HRPEOD]PERYEA
          OLDYEA = [F:HRPEOD]PERYEA
          OLDPERCOD = [F:HRPEOD]PERCOD
        Endif
        If [F:HRPEOD]PERCOD = OLDPERCOD
          For [HRPEOD]CLE(3)
#     PYRDATPEO=[F:PEO]PYRDAT
#     Filter [HRPEO] Where FCY=LESITE & PYRDAT=PYRDATPEO
#&        Order By Key CLE=YEA;FCY Desc;PYRDAT
#   Else
#     Filter [HRPEO] Where find(FCY,"",LESITE)<>0 & PEREND(J)>=[F:DCG]STRDAT+[L]CDEB-1
#&                     & PERSTR(J)<=[F:DCG]STRDAT+[L]CFIN-1
#&          Order By Key CLE=FCY Desc;YEA;PYRDAT : #113959 la priorité est au site avant l'année, sinon au aura en 1er la période sans site
##&          Order By Key CLE=YEA;FCY Desc;PYRDAT
#   Endif
#   For [HRPEO]CLE(2)
#    If OLDYEA<>[F:PEO]YEA
#     OLDYEA = [F:PEO]YEA
#     OLDFCY = [F:PEO]FCY
#    Endif
#    If [F:PEO]FCY = OLDFCY
#     For [HRPEO]CLE(3)
#MIPEA - 2016-12-19 - X3-12089- END#
# -- On éclate la demande pour isoler les 1/2 journées dans les temps
#
      # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#MIPEA - 2016-12-19 - X3-12089- START
            DATDEBCTR=[F:HRCTR2]CTRDAT
            If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
              DATDEBCTR=[F:HRCTR2]RETDATEFF
            Endif
            [L]PDEB=max([F:DCG]STRDAT,DATDEBCTR,[F:HRPEOD]PERSTR(J))-[F:DCG]STRDAT+1
            If [F:HRCTR2]XITDAT=[0/0/0]
              [L]PFIN=min([F:DCG]ENDDAT,[F:HRPEOD]PEREND(J))-[F:DCG]STRDAT+1
            Else
              [L]PFIN=min([F:DCG]ENDDAT,[F:HRCTR2]XITDAT,[F:HRPEOD]PEREND(J))-[F:DCG]STRDAT+1
            Endif
#      DATDEBCTR=[F:CTR2]CTRDAT
#      If [F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then
#        DATDEBCTR=[F:CTR2]RETDATEFF
#      Endif
#      [L]PDEB=max([F:DCG]STRDAT,DATDEBCTR,[F:PEO]PERSTR(J))-[F:DCG]STRDAT+1
#      If [F:CTR2]XITDAT=[0/0/0]
#       [L]PFIN=min([F:DCG]ENDDAT,[F:PEO]PEREND(J))-[F:DCG]STRDAT+1
#      Else
#       [L]PFIN=min([F:DCG]ENDDAT,[F:CTR2]XITDAT,[F:PEO]PEREND(J))-[F:DCG]STRDAT+1
#      Endif
#MIPEA - 2016-12-19 - X3-12089- END

            If sum([L]JOUR([L]PDEB..[L]PFIN))

              Gosub INIT_TIP0 : # 73469
              If !GOK : Break 4 : Endif

#Début une 1/2 journée et plus de 1 jour demandé (cmt WG d'après ligne de code avant modif 73242)
# > on crée une ligne dans les temps pour cette 1/2 journée de début
#      73242  If [L]PDEB=1 & [F:DCG]STRDAY=2 & [L]PFIN>1 & [L]JOUR(1)
              If [L]PDEB=1 & [F:DCG]ENDDAY=2 & [L]PFIN>1 & [L]JOUR(1)
                Gosub INIT_TIP1 : # 73469
                I            =1
                Raz ITER
                For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT & ENDDAT>=[F:DCG]STRDAT
         # FQ105844 - 24/02/15 - Si 1/2 journée, on vérifie qu'on n'est pas sur la même 1/2 journée
                  If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
                  Else
           # La demande concerne des jours déjà saisis dans TIMEMP : que la paie soit arrêtée ou pas, on passe régul
#MIPEA - 2016-12-19 - X3-12089- START
                    If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
#           If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:CTR2]CTRNUM)
#MIPEA - 2016-12-19 - X3-12089- END
                      For ITER=2 To 4
                        Gosub REGUL
                        If GOK<1 : Break 4 : Endif
                      Next
                    Endif
                  Endif
                Next
    # 19/03/13 - FQ88381
    # - Si déjà en paye on passe directement en régul
                If ITER=0 & [V]GPAYE
#        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT)
#MIPEA - 2016-12-19 - X3-12089- START
                  Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
&                          & [F:VEP]PYRDAT=[F:HRPEOD]PYRDAT
#          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
#&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
#&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
                  Read [VEP]VEP0 Last
                  Filter [VEP]
          # FQ??? - 14/03/14 - Il faut vérifier quand même que la date de l'absence est bien <= à la date du dernier temps comptabilisé
          # sur cette paie, sinon on risque d'oublier des temps. D'où le test sur DATTPS
                  If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie générée ou Paie comptabilisée
                    ITER=1
                    Gosub REGUL
                    If GOK<1 : Break 1 : Endif
                  Endif
                Endif

                If ITER =0         : # On a pas fait de régul de TIP
#         Infbox 'WRT_TIP2'

                  Gosub WRT_TIP
                  If [V]GOK<1 : Break 3 : Endif
                Else
                  If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
                    Gosub INIT_TIP0
                    If !GOK : Break 4 : Endif
                    Gosub INIT_TIP1
           #  73469 /
                    Raz [F:TIG]
                    [F:TIG] = [F:TIP]
#MIPEA - 2016-12-19 - X3-12089- START
                    Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]STRDAT
                    Read [HRPEOD1]HRPEOD0 First
                    [F:TIG]DATPYR = [F:HRPEOD1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
                    If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
                      [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
                      If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
                      Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
                      If !fstat Then
                        If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
                        If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
                      Endif
#           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]STRDAT
#           Read [PEO1]PEO1 First
#           If fstat
#            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]STRDAT
#            Read [PEO1]PEO1 First
#           Endif
#           [F:TIG]DATPYR = [F:PEO1]PYRDAT
#           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
#           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
#            [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
#            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#            If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#            Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#            If !fstat Then
#              If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#              If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#            Endif
#MIPEA - 2016-12-19 - X3-12089- END
                    Endif
#           Infbox 'WRT_TIP3'
                    Gosub WRT_TIP
                    If [V]GOK<1 : Break 3 : Endif
                  Endif
                Endif
                [L]PDEB=2
              Endif


#Fin une 1/2 journée et plus de 1 jour demandé (cmt WG d'après ligne de code avant modif 73242)
# > on crée une ligne dans les temps pour les jours entiers d'avant la 1/2 journée de fin
#      73242 If [L]PFIN=[L]DFIN & [F:DCG]ENDDAY=2 & [L]PDEB<[L]PFIN
              If [L]PFIN=[L]DFIN & [F:DCG]STRDAY=2 & [L]PDEB<[L]PFIN
&       & sum([L]JOUR([L]PDEB..[L]PFIN-1))
                Gosub INIT_TIP2 : # 73469
                I            =[L]PFIN-1
                Raz ITER
                For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT+[L]PFIN-2 & ENDDAT>=[F:DCG]STRDAT+[L]PDEB-1
         # FQ105844 - 24/02/15 - Si 1/2 journée, on vérifie qu'on n'est pas sur la même 1/2 journée
                  If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
                  Else
           # La demande concerne des jours déjà saisis dans TIMEMP : que la paie soit arrêtée ou pas, on passe régul
#MIPEA - 2016-12-19 - X3-12089- START
                    If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
#MIPEA - 2016-12-19 - X3-12089- END
                      For ITER=2 To 4
                        Gosub REGUL
                        If GOK<1 : Break 4 : Endif
                      Next
                    Endif
                  Endif
                Next
    # 19/03/13 - FQ88381
    # - Si déjà en paye on passe directement en régul
                If ITER=0 & [V]GPAYE
#        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT+[L]PFIN-2  & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT+[L]PDEB-1)
#MIPEA - 2016-12-19 - X3-12089- START
                  Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-2 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
&                          & [F:VEP]PYRDAT=[F:HRPEOD]PYRDAT
#          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
#&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-2 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
#&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
                  Read [VEP]VEP0 Last
                  Filter [VEP]
          # FQ??? - 14/03/14 - Il faut vérifier quand même que la date de l'absence est bien <= à la date du dernier temps comptabilisé
          # sur cette paie, sinon on risque d'oublier des temps. D'où le test sur DATTPS
                  If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie générée ou Paie comptabilisée
                    ITER=1
                    Gosub REGUL
                    If GOK<1 : Break 1 : Endif
                  Endif
                Endif

                If ITER =0
#          Infbox 'WRT_TIP4'
                  Gosub WRT_TIP
                  If [V]GOK<1 : Break 3 : Endif
                Else
                  If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
                  Gosub INIT_TIP0
                  If !GOK : Break 4 : Endif
                  Gosub INIT_TIP2
           #  73469 /
                  Raz [F:TIG]
                  [F:TIG] = [F:TIP]
#MIPEA - 2016-12-19 - X3-12089- START
                  Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-2 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
                  Read [HRPEOD1]HRPEOD1 First
                  [F:TIG]DATPYR = [F:HRPEOD1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
                  If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
                    [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
                    If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
                    Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
                    If !fstat Then
                      If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
                      If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
                    Endif
#           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-2 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
#           Read [PEO1]PEO1 First
#           If fstat
#            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-2 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
#            Read [PEO1]PEO1 First
#           Endif
#           [F:TIG]DATPYR = [F:PEO1]PYRDAT
#           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
#           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
#            [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
#            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#            If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#            Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#            If !fstat Then
#              If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#              If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#            Endif
#MIPEA - 2016-12-19 - X3-12089- END
                  Endif
#            Infbox 'WRT_TIP5'
                  Gosub WRT_TIP
                  If [V]GOK<1 : Break 3 : Endif
                Endif
              Endif
              [L]PDEB=[L]PFIN
            Endif

    # > on crée le reliquat de jour dans les temps (n jours entiers ou 1/2 journée de fin)
            If sum([L]JOUR([L]PDEB..[L]PFIN))
              Gosub INIT_TIP3  : # 73469
              I            =[L]PFIN
              Raz ITER
              For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT+[L]PFIN-1 & ENDDAT>=[F:DCG]STRDAT+[L]PDEB-1
         # Si 1/2 journée, on vérifie qu'on n'est pas sur la même 1/2 journée
                If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
                Else
           # La demande concerne des jours déjà saisis dans TIMEMP : que la paie soit arrêtée ou pas, on passe régul
#MIPEA - 2016-12-19 - X3-12089- START
                  If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
#           If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:CTR2]CTRNUM)
#MIPEA - 2016-12-19 - X3-12089- END
                    For ITER=2 To 4
                      Gosub REGUL
                      If GOK<1 : Break 4 : Endif
                    Next
                  Endif
                Endif
              Next
    # 19/03/13 - FQ88381
    # - Si déjà en paye on passe directement en régul
              If ITER=0 & [V]GPAYE
#        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT+[L]PFIN-1 & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT+[L]PDEB-1)
#MIPEA - 2016-12-19 - X3-12089- START
                Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-1 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
&                          & [F:VEP]PYRDAT=[F:HRPEOD]PYRDAT
#          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
#&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-1 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
#&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
#MIPEA - 2016-12-19 - X3-12089- END
                Read [VEP]VEP0 Last
                Filter [VEP]
          # FQ??? - 14/03/14 - Il faut vérifier quand même que la date de l'absence est bien <= à la date du dernier temps comptabilisé
          # sur cette paie, sinon on risque d'oublier des temps. D'où le test sur DATTPS
                If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3 )
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie générée ou Paie comptabilisée
                  ITER=1
                  Gosub REGUL
                  If GOK<1 : Break 1 : Endif
                Endif
              Endif

              If ITER =0

#        For [DCG]
#          Infbox num$([DCG]STRDAT)
#        Next

#        Infbox 'WRT_TIP6'
                Gosub WRT_TIP
                If [V]GOK<1 : Break 3 : Endif
              Else
                If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
                  Gosub INIT_TIP0
                  If !GOK : Break 4 : Endif
                  Gosub INIT_TIP3
           #  73469 /
                  Raz [F:TIG]
                  [F:TIG] = [F:TIP]
#MIPEA - 2016-12-19 - X3-12089- START
                  Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-1 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
                  Read [HRPEOD1]HRPEOD0 First
                  [F:TIG]DATPYR = [F:HRPEOD1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
                  If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
                    [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
                    If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
                    Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
                    If !fstat Then
                      If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
                      If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
                    Endif
#           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-1 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
#           Read [PEO1]PEO1 First
#           If fstat
#            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-1 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
#            Read [PEO1]PEO1 First
#           Endif
#           [F:TIG]DATPYR = [F:PEO1]PYRDAT
#           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
#           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
#            [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
#            # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#            If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#            Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#            If !fstat Then
#              If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#              If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#            Endif
#MIPEA - 2016-12-19 - X3-12089- END
                  Endif
#           Infbox 'WRT_TIP7'
                  Gosub WRT_TIP
                  If [V]GOK<1 : Break 3 : Endif
                Endif
              Endif
            Endif
          Endif
        Next
      Endif
    Next
  Next
Endif
Next
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRPEOD1]
#Filter [HRPEO]
#MIPEA - 2016-12-19 - X3-12089- END
Filter [LNK]
If [V]GOK<1 : Return : Endif
Return

# / 73469
$INIT_TIP0
# Partie commune d'enregistrement destinée aux temps
Raz [F:TIP]
#MIPEA - 2016-12-19 - X3-12089- START
[F:TIP]REFNUM=[F:HRCTR2]REFNUM
[F:TIP]CTRNUM=[F:HRCTR2]CTRNUM
[F:TIP]FCY   =[F:HRCTR2]ETRFCY
[F:TIP]SRV   =[F:HRCTR2]ETRSRV
#[F:TIP]REFNUM=[F:CTR2]REFNUM
#[F:TIP]CTRNUM=[F:CTR2]CTRNUM
#[F:TIP]FCY   =[F:CTR2]ETRFCY
#[F:TIP]SRV   =[F:CTR2]ETRSRV
#MIPEA - 2016-12-19 - X3-12089- END
If [V]GPAYE and [V]GTPS
#MIPEA - 2016-12-19 - X3-12089- START
Filter [F:VEP] Where EMP=[F:TIP]REFNUM & [F:VEP]CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:HRPEOD]PYRDAT
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat  & [F:VEP]STA>1
  Filter [F:HRPEOD2] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>[F:HRPEOD]PYRDAT
  Read [F:HRPEOD2]HRPEOD0 First
  Filter [F:HRPEOD2]
  If !fstat
    [F:TIP]DATPYR=[F:HRPEOD2]PYRDAT
  Else
    # Opération impossible :  Paye déjà calculée
    GMESSAGE = mess(157,123,1)-":"-num$([F:HRPEOD]PYRDAT)-mess(15,10709,1)
# Filter [F:VEP] Where EMP=[F:TIP]REFNUM & [F:VEP]CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:PEO]PYRDAT
# Read [VEP]VEP0 Last
# Filter [VEP]
# If !fstat  & [F:VEP]STA>1
#  Filter [F:PEO2] Where FCY=[F:PEO]FCY & PYRDAT>[F:PEO]PYRDAT
#  Read [F:PEO2]PEO0 First
#  Filter [F:PEO2]
#  If !fstat
#    [F:TIP]DATPYR=[F:PEO2]PYRDAT
#  Else
#    # Opération impossible :  Paye déjà calculée
#    GMESSAGE = mess(157,123,1)-":"-num$([F:PEO]PYRDAT)-mess(15,10709,1)
#MIPEA - 2016-12-19 - X3-12089- END
    GOK=0 : Raz [F:TIP]
    Return
  Endif
 Else
  #MIPEA - 2016-12-05 - X3-12089- START
  [F:TIP]DATPYR=[F:HRPEOD]PYRDAT
 Endif
Else
  [F:TIP]DATPYR=[F:HRPEOD]PYRDAT
Endif
#  [F:TIP]DATPYR=[F:PEO]PYRDAT
# Endif
#Else
#  [F:TIP]DATPYR=[F:PEO]PYRDAT
#Endif
#MIPEA - 2016-12-05 - X3-12089- END
[F:TIP]TIM   =[F:DCG]TIM
[F:TIP]TYPPGN=[F:DCG]TYPPGN
[F:TIP]AUTFLG =2
[F:TIP]STAFLG =[V]GUSER
[F:TIP]STA    =0 : # à quoi ça sert ?
[F:TIP]ANAFLG=0
[F:TIP]DSP   =""
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
Endif
# FQ92876 - 26/06/14 - Ajout [F:TIP]CPY utilisé dans INISEC_DSP_EMPTY
[F:TIP]CPY= func DIVPAYE.GETSOC([F:TIP]FCY)
Gosub INICCE
If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR=[V]GUSER  : Endif
If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT=date$     : Endif
If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM=time      : Endif
If dim([F:TIP]EXPNUM)>0 : [F:TIP]EXPNUM=[C]EXPORT : Endif
Return

$INIT_TIP1
# Demi-journée de début d'absence
[F:TIP]STRDAT=[F:DCG]STRDAT
[F:TIP]ENDDAT=[F:DCG]STRDAT
#73242  [F:TIP]STRDAY=2
#73242  [F:TIP]ENDDAY=1
[F:TIP]STRDAY=1
[F:TIP]ENDDAY=2
[F:TIP]NBRDAY=[L]JOUR(1)
[F:TIP]NBRHOU=[L]HEURE(1)
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
Endif
Return

$INIT_TIP2
# Demi-journée de fin d'absence
[F:TIP]STRDAT=[F:DCG]STRDAT+[L]PDEB-1
[F:TIP]ENDDAT=[F:DCG]STRDAT+[L]PFIN-2
[F:TIP]STRDAY=1
[F:TIP]ENDDAY=1
[F:TIP]NBRDAY=sum([L]JOUR([L]PDEB..[L]PFIN-1))
[F:TIP]NBRHOU=sum([L]HEURE([L]PDEB..[L]PFIN-1))
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
  #MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
Endif
Return

$INIT_TIP3
# Reliquat des jours
[F:TIP]STRDAT = [F:DCG]STRDAT+[L]PDEB-1
[F:TIP]ENDDAT = [F:DCG]STRDAT+[L]PFIN-1
#  74073 (suite de 73242) [F:TIP]STRDAY = 1+([L]PDEB=1 & [F:DCG]STRDAY=2)
#  74073 (suite de 73242) [F:TIP]ENDDAY = 1+([L]PFIN=[L]DFIN & [F:DCG]ENDDAY=2)
[F:TIP]STRDAY = 1+([L]PFIN=[L]DFIN & [F:DCG]STRDAY=2)
[F:TIP]ENDDAY = 1+([L]PDEB=1 & [F:DCG]ENDDAY=2)
[F:TIP]NBRDAY = sum([L]JOUR([L]PDEB..[L]PFIN))
[F:TIP]NBRHOU = sum([L]HEURE([L]PDEB..[L]PFIN))
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
Endif
Return

#   73469 /


#-------------------------------------------------------------------------------

$REGUL
# ITER=1 : On passe la demande en régul dans [TIG] car période passée ([TIG]=TIMREGUL si GTPS=1 sinon TIMEMP)
# ITER=2 : On passe une régul dans [TIG], pour annuler les temps déjà saisis dans TIMEMP sur période passée
# On passe une régul pour créer les temps déjà saisis dans TIMEMP qui ne se chevauchent pas avec la demande
# ITER=3 : Régul de [F:TIP1]STRDAT à [F:DCG]STRDAT-1
# ITER=4 : Régul de [F:DCG]ENDDAT+1 à [F:TIP1]ENDDAT
Raz [F:TIG]
Case ITER
 When 1
#MIPEA - 2016-12-19 - X3-12089- START
  [F:TIG] = [F:DCG]
  [F:TIG]CTRNUM=[F:HRCTR2]CTRNUM
  [F:TIG]FCY   =[F:HRCTR2]ETRFCY
  [F:TIG]SRV   =[F:HRCTR2]ETRSRV
#  [F:TIG] = [F:DCG]
#  [F:TIG]CTRNUM=[F:CTR2]CTRNUM
#  [F:TIG]FCY   =[F:CTR2]ETRFCY
#  [F:TIG]SRV   =[F:CTR2]ETRSRV
#MIPEA - 2016-12-19 - X3-12089- END
#MIPEA - 2016-12-19 - X3-12089- START
  Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]ENDDAT
  Read [HRPEOD1]HRPEOD1 First
#  Filter [HRPEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]ENDDAT
#  Read [HRPEO1]PEO1 First
#  If fstat
#   Filter [HRPEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]ENDDAT
#   Read [HRPEO1]PEO1 First
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
 When 2
  [F:TIG] = [F:TIP1]
  [F:TIG]NBRHOU = -1*[F:TIP1]NBRHOU
  [F:TIG]NBRDAY = -1*[F:TIP1]NBRDAY
####MIPEA - 2017-09-11- US X3-54010- START
If func AFNC.ACTIV("GLM")
  For X = 0 To dim([F:TIP1]LVESUBTYP)-1
    If [F:TIG]NBRDAY > 0 and [F:TIP1]LVESUBBAL(X) < 0
      [F:TIG]LVESUBBAL(X) = -1*[F:TIP1]LVESUBBAL(X)
    Elsif [F:TIG]NBRDAY < 0 and [F:TIP1]LVESUBBAL(X) > 0
      [F:TIG]LVESUBBAL(X) = -1*[F:TIP1]LVESUBBAL(X)
    Endif
  Next
Endif

####MIPEA - 2017-09-11- US X3-54010- END
  # FQ92876 - 13/10/14 - Ajout test sur [F:TIM] car selon là d'où est appelée l'étiquette REGUL, la classe [F:TIM] peut ne pas être valorisée
  If [F:TIP]TIM<>"" Then
    # Cas d'une demande de 0.5CP alors qu'on a dans TIMEMP 0.5CP et 0.5W ou 1RTT
    If [F:TIP]NBRDAY<1
     If [F:TIP1]NBRDAY=[F:TIP]NBRDAY
      If [F:TIP1]STRDAY<>[F:TIP]STRDAY | [F:TIP1]ENDDAY<>[F:TIP]ENDDAY
       If OLDDATDEMI <> [F:TIP1]STRDAT
        OLDDATDEMI = [F:TIP1]STRDAT
        Raz [TIG] : # pour ne pas passer de régul
       Else
        [F:TIG]TIM = GTPSW
        [F:TIG]STRDAY = 0
        [F:TIG]ENDDAY = 0
        Raz OLDDATDEMI
       Endif
      Else
       Raz OLDDATDEMI
      Endif
     Elsif [F:TIP]NBRDAY<[F:TIP1]NBRDAY
      [F:TIG]NBRHOU = -1*[F:TIP]NBRHOU
      [F:TIG]NBRDAY = -1*[F:TIP]NBRDAY
####MIPEA - 2017-09-11- US X3-54010- START
      If func AFNC.ACTIV("GLM")
        For X = 0 To dim([F:TIP]LVESUBTYP)-1
          If [F:TIG]NBRDAY > 0 and [F:TIP]LVESUBBAL(X) < 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIP]LVESUBBAL(X)
          Elsif [F:TIG]NBRDAY < 0 and [F:TIP]LVESUBBAL(X) > 0
            [F:TIG]LVESUBBAL(X) = -1*[F:TIP]LVESUBBAL(X)
          Endif
        Next
      Endif
####MIPEA - 2017-09-11- US X3-54010- END
#MIPEA - 2016-12-19 - X3-12089- START
      Read [TIM2]TIM0=GCURLEG;[F:TIP1]TIM
#      Read [TIM2]TIM0=[F:TIP1]TIM
#MIPEA - 2016-12-19 - X3-12089- END
      If !fstat & [F:TIM2]CATTIM<>1
       [F:TIG]STRDAY = [F:TIP]STRDAY
       [F:TIG]ENDDAY = [F:TIP]NBRDAY
      Endif
     Endif
    Else
     Raz OLDDATDEMI
    Endif
  Endif
#MIPEA - 2016-12-19 - X3-12089- START
  Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:TIP1]STRDAT & PEREND(R1)>=[F:TIP1]ENDDAT
  Read [HRPEOD1]HRPEOD1 First
#  Filter [HRPEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIP1]STRDAT & PEREND(R1)>=[F:TIP1]ENDDAT
#  Read [HRPEO1]PEO1 First
#  If fstat
#   Filter [HRPEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIP1]STRDAT & PEREND(R1)>=[F:TIP1]ENDDAT
#   Read [HRPEO1]PEO1 First
#  Endif
#MIPEA - 2016-12-05 - X3-12089- END
 When 3 :# Saisie d'un nombre positif de congé
  If [F:TIP1]STRDAT<[F:DCG]STRDAT
   [F:TIG] = [F:TIP1]
   [F:TIG]ENDDAT = [F:DCG]STRDAT-1
   Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
#MIPEA - 2016-12-19 - X3-12089- START
   Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
   Read [HRPEOD1]HRPEOD1 First
#   Filter [HRPEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#   Read [HRPEO1]PEO1 First
#   If fstat
#    Filter [HRPEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#    Read [HRPEO1]PEO1 First
#   Endif
#MIPEA - 2016-12-19 - X3-12089- END
  Endif
 When 4
  If [F:DCG]ENDDAT<[F:TIP1]ENDDAT
   [F:TIG] = [F:TIP1]
   [F:TIG]STRDAT = [F:DCG]ENDDAT+1
   Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
#MIPEA - 2016-12-19 - X3-12089- START
   Filter [HRPEOD1] Where PERCOD=[F:HRCTR]PERCOD & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
   Read [HRPEOD1]HRPEOD1 First
#   Filter [HRPEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#   Read [HRPEO1]PEO1 First
#   If fstat
#    Filter [HRPEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
#    Read [HRPEO1]PEO1 First
#   Endif
#MIPEA - 2016-12-19 - X3-12089- END
  Endif
Endcase

If [F:TIG]STRDAT=[0/0/0] : Return : Endif : # on est pas passé par le Case

If !fstat
#MIPEA - 2016-12-19 - X3-12089- START
[F:TIG]DATPYR=[F:HRPEOD1]PYRDAT
# [F:TIG]DATPYR=[F:PEO1]PYRDAT
 #MIPEA - 2016-12-19 - X3-12089- END
Endif
#62192
#[F:TIG]CTRNUM=[F:CTR2]CTRNUM
#[F:TIG]FCY   =[F:CTR2]ETRFCY
#[F:TIG]SRV   =[F:CTR2]ETRSRV
[F:TIG]DCGUID=[F:DCG]UID
[F:TIG]AUTFLG =2
[F:TIG]STAFLG =[V]GUSER
[F:TIG]STA    =0 : # à quoi ça sert ?
[F:TIG]ANAFLG=0
[F:TIG]DSP   =""
# FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
#[F:TIG]FLGBUL = 2
If dim([F:TIG]CREUSR)>0 : [F:TIG]CREUSR=[V]GUSER  : Endif
If dim([F:TIG]CREDAT)>0 : [F:TIG]CREDAT=date$     : Endif
If dim([F:TIG]CRETIM)>0 : [F:TIG]CRETIM=time      : Endif
If dim([F:TIG]EXPNUM)>0 : [F:TIG]EXPNUM=[C]EXPORT : Endif

Gosub INICCE

[F:TIG]LIG   =uniqid([TIP])
# FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon règle métier
If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0]  Then
  [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
Endif
 Write [TIG]
 If fstat
  [V]GOK=0
  Call FSTA("TIG") From GLOCK
  Return
 Endif
If ITER=1
 If [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
  Case [F:DCG]WRK
   When "C" : [L]WRK=mess(75,10709,1) : # Ajout
   When "M" : [L]WRK=mess(77,10709,1) : # Modif (après)
  Endcase
#  Case [F:DCG]WRK
#   When "C" : [L]WRK=mess(75,709,1) : # Ajout
#   When "M" : [L]WRK=mess(77,709,1) : # Modif (après)
#  Endcase
#MIPEA - 2016-12-15 - X3-12089- END
  Gosub WORKFLOW From TPSSTD
 Endif
Else
 Raz [L]JOUR1
#MIPEA - 2016-12-19 - X3-12089- START
 Read [TIM2]TIM0=GCURLEG;[F:TIG]TIM
# Read [TIM2]TIM0=[F:TIG]TIM
#MIPEA - 2016-12-19 - X3-12089- END
 If [F:TIM2]CATTIM=3
  If ITER=2
   # Nombre négatif de congé
   If [F:TIG]STRDAT<>[F:TIG]ENDDAT
    Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[L]JOUR1,[L]HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
   Else
    [L]JOUR1(1) = [F:TIG]NBRDAY
   Endif
   Call ADD_CPREG([L]JOUR1) From TPSSTDR1
   If [V]GOK<1 : Return: Endif
  Else
   # Nombre positif de congé
   Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[L]JOUR1,[L]HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN
   Raz [F:TIP]
#   Infbox '1'
   [F:TIP] = [F:TIG]
   Call ADD_CPPRIS([L]JOUR1) From TPSSTD1
   If GOK<1 : Return : Endif
  Endif
 Endif
Endif

Return

#-------------------------------------------------------------------------------
$INICCE
#MIPEA - 2016-12-19 - X3-12089- START
[F:HRCTR]=[F:HRCTR2]
#[F:CTR]=[F:CTR2]
#MIPEA - 2016-12-19 - X3-12089- END
# FQ92876 - 23/06/14 - Ajout axe dans les temps
Local Char ABREVT(3) #, NAT(GLONNAT)
If [V]GTPS
 If ITER=0
  ABREVT="TIP"
 Else
  ABREVT="TIG"
 Endif
# NAT=evalue("[F:"+ABREVT+"]NATCOD")
# Call LECT_NATCOD (NAT) From TPSDIV
#LIPET - 2018-10-09 - X3-111793 - START
 Call INISEC_DSP_EMPTY(ABREVT) From TPSSUB
#LIPET - 2018-10-09 - X3-111793 - END
Endif
#LIPET - 2018-10-09 - X3-111793 - START
#Call INISEC_DSP_EMPTY(ABREVT) From TPSSUB
#LIPET - 2018-10-09 - X3-111793 - END
Return

