 If clalev([F:TIG1])=0 : Local File TIMREGUL [TIG1] : Endif
Else
 If clalev([F:TIG])=0 : Local File TIMEMP   [TIG] : Endif
 R1 = 0 : R2 = 20 : # R1=Indice de PERIOD et R2=Nb jours décalage
Endif
