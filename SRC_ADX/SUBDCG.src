Subprog AS_NBLIG
## PEVAN 2017-09-06 X3-54579 START
  If func AFNC.ACTIV("GLM")
      #ANCOA - X3-78782 - 05/03/2018 - START
#    If GCURLEG = "BRI"
#      #Save button isn't enabled yet therefore mark the row we're modifying
#      If GETABOU(GENRE) = 0
#        [M:DCG1]ROWMOD = nolign
#        Affzo [M:DCG1]ROWMOD
#      #In save mode and trying to enter a line we're not modifying
#      Elsif GETABOU(GENRE) = 1 and [M:DCG1]ROWMOD <> nolign
#        mkstat = 2
#        GERR = 2
#        GMESSAGE = mess(28,11691,1)
#        End
#      Endif
#    Else
      Local Integer X
      Local Integer ZEROCOUNTER
      For X = 0 To nolign - 1
        If [M:DCG1]UID(X) < 1
          ZEROCOUNTER += 1
        Endif
      Next
      If ZEROCOUNTER > 1
        mkstat = 2
        GERR = 2
        GMESSAGE = mess(28,11691,1)
        End
      Endif
#    Endif
    #ANCOA - X3-78782 - 05/03/2018 - END
    GPARENT_NOLIGN = nolign - 1
## PEVAN 2017-09-06 X3-54579 END
## PEVAN 2107-09-04 X3-54263 START
    If status = 71 #line change
  #LIPET - 2017-08-30 - X3-X3-54261 - START
      If [M:DCG1]CTRNUM(nolign-1) <> "" Then
        Call GET_LASTUPDATES([M:DCG1]CTRNUM(nolign-1)) From SUBDCG2
      Endif
  #LIPET - 2017-08-30 - X3-X3-54261 - END
      Gosub REFRESHLVESUBNNR From SUBDCG2
    Endif
  Endif
## PEVAN 2107-09-04 X3-54263 END

End

