$VERIF_MOD
  ## PEVAN - 2018-03-01 - X3-80393 - START
  If func AFNC.ACTIV("GLM")
    If [M:DCG1]NBRDAY(GLM_NOLIGN - 1) = 0
      If clalev([F:TIM4])=0 : Local File TIMCOD [TIM4] : Endif
      Read [TIM4]TIM0=GCURLEG;[M:DCG1]TIM(GLM_NOLIGN - 1)
      If !fstat & [TIM4]LVEENHANCE = 2
        GERR = 1 : GMESSAGE=mess(262,10702,1) : [V]GOK = 0
        Close File [TIM4]
        Return
      Endif
      Close File [TIM4]
    Endif
  Endif
  ## PEVAN - 2018-03-01 - X3-80393 - END

For nolign=1 To [M:DCG1]NBLIG

  [F:DCG]=[M:DCG1]
  Gosub VERIF_DCG
  If ![L]OK : Break : Endif
Next
If ![L]OK : Return : Endif

If [V]GWEBSERV
# Filter [DCG] Where find(UID,[M:DCG1]DELUID(0..[M:DCG1]NBDEL-1))<>0 & STA>1
# Au cas où on a un enreg sans UID
 Filter [DCG] Where [F:DCG]UID <> 0 & find([F:DCG]UID,[M:DCG1]DELUID(0..[M:DCG1]NBDEL-1))<>0 & STA>1
 Look [DCG] First
 If !fstat
  [V]GMESSAGE=mess(1,115,1) : # Suppression impossible
  [L]OK      =0
  Return
 Endif
 Filter [DCG]
Endif

Return

