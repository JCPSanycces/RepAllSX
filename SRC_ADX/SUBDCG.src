Subprog AS_PJ(VALEUR)
Variable Char    VALEUR()
End

Subprog CL_PJ(VALEUR)
Variable Char    VALEUR()
Local Integer READSTAT

READSTAT = 0
If VALEUR = "" : End : Endif
If [M:DCG1]UID(nolign-1) = 0 : End : Endif
Call B3_NBLIG
READSTAT = func PRHPORATT.FILTER_AOX("DCG",[M:DCG1]REFNUM,[M:DCG1]DEM(nolign-1),[M:DCG1]UID(nolign-1))
If READSTAT = 1
  VALEUR="175"
Else
  VALEUR=""
Endif
End


Subprog B3_NBLIG
Local Integer READSTAT
READSTAT = 0
If [M:DCG1]UID(nolign-1) = 0 : End : Endif
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal BASPAG
 If !GWEBSERV
    SAVACT = GACTION : GACTION = "AOBJTXT"
    PARMSK(1) = "EML"
    PARMSK(2) = "DCG"+"~"+num$([M:DCG1]REFNUM)+"~"+num$([M:DCG1]DEM(nolign-1))
    PARMSK(3) = num$([M:DCG1]UID(nolign-1))
    PARMSK(4) = "M"
    Call SAISIE_NUM(BASPAG,PARMSK,"AOBJTXT","GOBJTXT","XWAOBJTXT") From GSAISIE
    GACTION = SAVACT
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  If mkstat=2 Then
    READSTAT = func PRHPORATT.FILTER_AOX("DCG",[M:DCG1]REFNUM,[M:DCG1]DEM(nolign-1),[M:DCG1]UID(nolign-1))
    If READSTAT = 1
      [M]PJ(nolign-1)="175"
    Else
      [M]PJ(nolign-1)=""
    Endif
    Affzo [M]PJ(nolign-1)
    mkstat=4
  Endif
End

$DISPLAY_ATT_ICON
Local Integer READSTAT

READSTAT = 0
For nolign = 1 To [M:DCG1]NBLIG
  READSTAT = func PRHPORATT.FILTER_AOX("DCG",[M:DCG1]REFNUM,[M:DCG1]DEM(nolign-1),[M:DCG1]UID(nolign-1))
  If READSTAT = 1
    [M:DCG1]PJ(nolign-1)="175"
  Else
    [M:DCG1]PJ(nolign-1)=""
  Endif
Next
Affzo [M:DCG1]

Return



