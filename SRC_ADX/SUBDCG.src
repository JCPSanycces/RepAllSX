#-------------------------------------------------------------------------------
Funprog WRKMES()

Local Libelle I

Case [F:DCG]WRK
 When "C" : I=75 : # Ajout
 When "S" : I=74 : # Suppression
 When "M" : I=76+([F:DCG]UID>0) : # Modif (après)/(avant)
Endcase

#MIPEA - 2016-12-15 - X3-12089- START
End format$("K:14X",mess(I,10709,1))
#End format$("K:14X",mess(I,709,1))
#MIPEA - 2016-12-15 - X3-12089- END

Funprog DERUID(LNK)
Value Integer LNK
# 62798 Pour les workflow
If clalev([F:DCGK])=0 : Local File DEMCONGE [DCGK] : Endif

Filter [F:DCGK] Where LNK = [L]LNK Order By UID
Read [F:DCGK] Last
Filter

End [F:DCGK]UID


#-------------------------------------------------------------------------------
Subprog WRKSIG(EVT,UID)
Value Char EVT(), UID()
#MIPEA - 2016-12-15 - X3-12089- START
Local Char REFMAT(GLONEML)
Local Integer PREVUID, PREVUIDTIG #FRLAA X3-82396 2018-03-22
#Local Char REFMAT(GLONMAT)
#MIPEA - 2016-12-15 - X3-12089- END
# SBA US : 1634-66520
If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif


# FQ66520 - 03/06/13 - Workflow manuel, action appelée avec VISMAN : il faut lire [F:ID]
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
If [L]EVT="VISMAN" Then
  Read [F:ID]ID0=[F:AWS]VALCTX1
  [L]EVT="VIS"
Endif
Lock ="DCG"+[F:ID]REFNUM
If fstat
 [V]GOK  =-1
 [V]GLOCK="%DCG"+[F:ID]REFNUM
 End
Endif
Local Integer I, J, K

If GFONCTION <> "GESDCG"  : # On vient du moniteur workflow
 Gosub OUVRE
Endif
#
#[L]CRITERE2(0)="UID=val([L]UID) & find(STA,2,5)<>0"   - 62798
[L]CRITERE2(0)="UID="+num$(val([L]UID))
[L]CRITERE2(1)="1=1"

#FRLAA X3-50343 2017-10-03 - START
#GCURLEG must be set for the workflow
Local File DEMCONGE [DCG3]
Local File EMPLOCTR [HRCTR7]
Filter [DCG3] Where evalue([L]CRITERE2(0))
Read [DCG3] First
Filter [DCG3]
If !fstat
 Filter [F:HRCTR7] Where REFNUM = [F:DCG3]REFNUM and CTRNUM = [F:DCG3]CTRNUM
 Read [F:HRCTR7] First
 Filter [F:HRCTR7]
 If !fstat
  GCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR7]REFNUM, [F:HRCTR7]CTRNUM, [F:HRCTR7]CTRDAT, 1)
 Endif
Else
  Unlock ="DCG"+[F:ID]REFNUM
  End
Endif

#FRLAA X3-50343 2017-10-03 - END


Case [L]EVT
When "VIS"                                       : # Accepté
# / 73469 même test que C_ENDDAY pour comportement homogène
 # On interdit la saisie d'une demande sur une période qui a des régularisations
If GTPS=1
  If [DCG]STA = 5
  Else

  If !clalev([F:TIG]) : Local File TIMREGUL [TIG] : Endif

  For [DCG] Where evalue([L]CRITERE2(0))

   For [TIG]TIG1 Where REFNUM=[F:DCG]REFNUM
&                    & STRDAT<=[F:DCG]ENDDAT
&                    & ENDDAT>=[F:DCG]STRDAT
# Si Regule et Absence se chevauchent
# 1/2 journée le matin dans TIG et 1/2 le matin dans DCG
# ou 1/2 journée le l'aprés midi dans TIG et 1/2 le aprés midi dans DCG
# Il y a chevauchement
    If find([F:DCG]CTRNUM,"",[F:TIG]CTRNUM)
&    & (  [F:TIG]STRDAT < [F:DCG]ENDDAT
&      | ([F:TIG]STRDAT = [F:DCG]ENDDAT & ([F:TIG]STRDAY<2 | [F:DCG]ENDDAY<2))
&      )
&    & (  [F:TIG]ENDDAT > [F:DCG]STRDAT
&      | ([F:TIG]ENDDAT = [F:DCG]STRDAT & ([F:TIG]ENDDAY<2 | [F:DCG]STRDAY<2))
&      )
#MIPEA - 2016-12-15 - X3-12089- START
     [V]GMESSAGE =format$([V]GFMD,[F:TIG]STRDAT)
&               - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$([V]GFMD,[F:TIG]ENDDAT))
&               - ":"-func AFNC.MES1(mess(170,10709,1),[F:TIG]TIM)
#     [V]GMESSAGE =format$([V]GFMD,[F:TIG]STRDAT)
#&               - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$([V]GFMD,[F:TIG]ENDDAT))
#&               - ":"-func AFNC.MES1(mess(170,709,1),[F:TIG]TIM)
#MIPEA - 2016-12-15 - X3-12089- END
    #          Evènement $1$ déjà régularisé pour cette date \ Passer une régularisation
     mkstat=2
     Break 2
    Endif
   Next
  Next
  If mkstat=2 : GOK = 0 : Endif
# 27/10/11 FQ 77350 Ne faire afficher le message que s'il y a une erreur
  If GOK=0 and GMESSAGE <> ""
    GERR = 1
    If !GWEBSERV : Call MESSAGE(GMESSAGE) From GESECRAN : Endif
  Endif
  Endif
 Endif
#   73469 /

# Gosub MAJTIP - 62798 déplacé après maj DCG
# If [V]GOK<1 : End : Endif
 If len(GCOMMENTSIG)>0
  Update [DCG] Where evalue([L]CRITERE2(0))
&              With  STA    += 1
&                  , UPDNUM += 1
&                  , CMT2    = GCOMMENTSIG
 Else
  Update [DCG] Where evalue([L]CRITERE2(0))
&              With  STA    += 1
&                  , UPDNUM += 1
 Endif

 #FRLAA X3-74800 - 2018-03-26 - START
# Filter [DCG] Where evalue([L]CRITERE2(0))
#Read [DCG3] First
#Filter [DCG3]
#If func SUBDCGGLM.CHECK_TIG([F:DCG]REFNUM,[F:DCG]STRDAT,[F:DCG]ENDDAT,[F:DCG]CTRNUM)>0
#  [V]GOK = 0
#  Unlock ="DCG"+[F:ID]REFNUM
#  End
#Endif
#FRLAA X3-74800 - 2018-03-26 - END

#FRLAA X3-82396 2018-03-14 - START
 Gosub HANDLE_ID_GLOCK

Gosub HANDLE_DCGSTA From SUBDCG_SOA
#Update GLM
#Check activity code GLM
If func AFNC.ACTIV("GLM")>0
  Gosub MAJTIP_GLM From SUBDCG_SOA
Else
  Gosub MAJTIP
Endif
#Gosub MAJTIP
#FRLAA X3-82396 2018-03-14 - END

When "REF"                                       : # Refusé

 If len(GCOMMENTSIG)>0
  Update [DCG] Where evalue([L]CRITERE2(0))
&              With  STA    += 2
&                  , UPDNUM += 1
&                  , CMT2    = GCOMMENTSIG
 Else
  Update [DCG] Where evalue([L]CRITERE2(0))
&              With  STA    += 2
&                  , UPDNUM += 1
 Endif

#FRLAA X3-82396 2018-03-14 - START

Gosub HANDLE_ID_GLOCK

Gosub HANDLE_DCGSTA From SUBDCG_SOA

#Update GLM
#Check activity code GLM
If func AFNC.ACTIV("GLM")>0
  Gosub MAJTIP_GLM From SUBDCG_SOA
Else
 Gosub MAJTIP
Endif
#Gosub MAJTIP
#FRLAA X3-82396 2018-03-14 - END
When "CMP"                                       : # Complément attendu (pour les statuts Demande)

 If len(GCOMMENTSIG)>0
  Update [DCG] Where evalue([L]CRITERE2(0)) & STA < 3
&              With  STA     = 1
&                  , UPDNUM += 1
&                  , CMT2    = GCOMMENTSIG
 Else
  Update [DCG] Where evalue([L]CRITERE2(0)) & STA < 3
&              With  STA     = 1
&                  , UPDNUM += 1
 Endif
#FRLAA X3-74800 2018-03-27 - START
 Gosub HANDLE_ID_GLOCK
 #FRLAA X3-74800 2018-03-27 - END
When Default
 End
Endcase

#FRLAA X3-74800 2018-03-27 - START - Each operation should handle its own fstat
#If fstat
# [V]GOK=0
# Call RSTA("DCG",[F:ID]REFNUM) From GLOCK
# End
#Endif
#FRLAA X3-74800 2018-03-27 - END

Unlock ="DCG"+[F:ID]REFNUM
End
#-------------------------------------------------------------------------------

#FRLAA X3-74800 2018-03-27 - START
$HANDLE_ID_GLOCK
 If fstat
  [V]GOK=0
  Call RSTA("DCG",[F:ID]REFNUM) From GLOCK
 Endif
Return
#FRLAA X3-74800 2018-03-27 - END
Subprog WRKRER(KRONO,ADEST)
Value Char    KRONO(), ADEST()
#64406 Appellé en fin de workflow demande si 0 signataire trouvé = alimentation CTX(8) avec destinataire routage

 Update [F:AWS2] Where CHRONO = KRONO & DEST = ADEST
&                With  VALCTX8 = DEST

End

#-------------------------------------------------------------------------------
Subprog INICHRONO(CHRONO,UID)
Value Char CHRONO(), UID()

#Assign new CHRONO for ESS transactions, adxuid assignment different - will leave blank
If func AFNC.ACTIV("HRESS")>0
  Local Char ESSUSR(GLONAUS)
  If clalev([F:DCG8])=0 : Local File DEMCONGE [DCG8] : Endif
  Filter [F:DCG8] Where WRK>"" & CHRONO="" & CHRONO2="" & UID=val([L]UID)
  Read [DCG8] First
  Filter [F:DCG8]
  If !fstat
    ESSUSR = [F:DCG8]CREUSR
  Endif

  Update [DCG] Where WRK>"" & CHRONO="" & CHRONO2="" & UID=val([L]UID)
&             With CHRONO=[L]CHRONO
  If fstat
   [V]GOK=0
   Call RSTA("DCG","CHRONO=-"+num$([L]CHRONO)) From GLOCK
   End
  Endif

  Update [DCG] Where WRK>"" & CHRONO=[L]CHRONO & CHRONO2="" & UID=val([L]UID)
&             With UPDUSR=[L]ESSUSR
  If fstat
   [V]GOK=0
   Call RSTA("DCG","CHRONO=-"+num$([L]CHRONO)) From GLOCK
   End
  Endif


Endif


Update [DCG] Where WRK>"" & CHRONO=num$(-adxuid(2)) & CHRONO2="" & UID=val([L]UID)
&             With CHRONO=[L]CHRONO
If fstat
 [V]GOK=0
 Call RSTA("DCG","CHRONO=-"+num$(adxuid(2))) From GLOCK
 End
Endif

Update [DCG] Where WRK>"" & CHRONO>"" & CHRONO2=num$(-adxuid(2)) & UID=val([L]UID)
&             With CHRONO2=[L]CHRONO
If fstat
 [V]GOK=0
 Call RSTA("DCG","CHRONO2=-"+num$(adxuid(2))) From GLOCK
 End
Endif



End
#-------------------------------------------------------------------------------

Subprog NOPROLONG(EVT,OK)
Value    Char    EVT ()
Variable Integer OK
OK = 0
#56914
If !find( EVT,func AFNC.PARAM("AT",""),func AFNC.PARAM("ATTRAJET","")
&       , func AFNC.PARAM("MALADIE",""),func AFNC.PARAM("MALPROF","")
&       , func AFNC.PARAM("MATERNITE",""),func AFNC.PARAM("PATERNITE","")
&       ,func AFNC.PARAM("PATHPREN",""),func AFNC.PARAM("PATHPOST","")
&       )
 OK=1
Endif
End

Subprog MAJ_HISSUI(STA)
Value Integer STA
#62113 - suppression du suivi d'une demande (moniteur workflow)
#ici [F:DCG]STA = 2 ou 5 , [L]STA = valeur saisie

If GWEBSERV : End : Endif

Call MAJ_HISSUIPOR(STA)

End

# 2016-10-27 - Leave cancellations for workflow - START
Subprog MAJ_HISSUIPOR(STA)
Value Integer STA


Local Char REP (GLONADI)
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif

Case [L]STA
 When [F:DCG]STA - 1 : REP = "CMP"
 When [F:DCG]STA + 1 : REP = "VIS"
 When [F:DCG]STA + 2 : REP = "REF"
 When Default        : REP = "ANN"
Endcase

Update [F:AWS] Where VALCTX1 = [F:DCG]REFNUM
&                  & VALCTX3 = "15"
&                  & VALCTX4 = num$([F:DCG]UID)
&                  & FLGSIG  = 3
&              With [F:AWS]FLGSIG = 5
&                 , [F:AWS]ACTSIG = REP
&                 , [F:AWS]USRSIG = GUSER
&                 , [F:AWS]DATSIG = date$

End

