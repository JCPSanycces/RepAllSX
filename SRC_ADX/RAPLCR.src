#<AdxTL>@(#)8.0.0.0 $Revision$ 
#Local Char OFONCTION(20)
#OFONCTION=GFONCTION
#If GFONCTION<>"GESPAB"
# GFONCTION="GESPAB" : Call AUTORIS From EXEFNC
#Endif
#Raz GBIDC1, GBIDC2 
#Call OBJET("PAB",GBIDC1,GBIDC2) From GOBJET 
#If OFONCTION<>GFONCTION
# GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
#Endif
#End

Local Char PARBOUT(250)(1..2)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
#PARBOUT(1)='HB'
#PARBOUT(2)='00000032'
OFONCTION=GFONCTION
If GFONCTION<>"RAPLCRMAN"
 GFONCTION="RAPLCRMAN" : Call AUTORIS From EXEFNC
Endif
GACTION = "RAPLCRMAN" 
Call SAISIE_CHAR(VALBOUT,PARBOUT,"FLCRMAN","RAPLCR","") From GSAISIE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "DEBUT"
  Case PROG
   When "SELOBJAW"  : Gosub DSELPAY
   When Default     : Gosub DEBUT
  Endcase
 When "ABA"          : Gosub ABANDON
 When "APRES_MODIF"  : 
  If !find(COUZON,"BAN","FRMNUM") 
   If !GCONSULT : REP="M" : Else : GERR=1 : Endif
  Endif
 When "ENR"          : Gosub ENR
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" :
  If BOUT="Q"
   OK=2
   If REP="M" 
    # La fiche courante a été modifiée, voulez-vous abandonner la modification
    Call OUINON(mess(7,126,1)+"\"+mess(9,126,1),OK) From GESECRAN
    If OK=2 : Gosub ABANDON : Return : Endif
   Endif
   GOK=1 : Gosub ENR 
   If GOK<1 : FOK=0 : Endif
  Endif
 When "FIN"          :
  Case PROG
   When "SELOBJAW"  : Gosub FSELPAY
   When Default     : Gosub FIN
  Endcase
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "CHX_TABLE"    : Gosub CHX_TABLE
Endcase
Return

$DEBUT
Onerrgo ERREUR From CONTROLE
If !clalev([F:BES])  : Local File BILSTA    [BES]  : Endif 
If !clalev([F:BES2]) : Local File BILSTA    [BES2] : Endif 
If !clalev([F:TPY])  : Local File TABPAYTYP [TPY]  : Endif 
If !clalev([F:PYH])  : Local File PAYMENTH  [PYH]  : Endif 
If !clalev([F:PAN])  : Local File PAYACCNUM [PAN]  : Endif 
If !clalev([F:FRM])  : Local File PAYFRM    [FRM]  : Endif
If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif 
Onerrgo 
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif
Onerrgo CHUT From CONTROLE
If !clalev([F:TCU])  : Local File TABCUR    [TCU]  : Endif 
If !clalev([F:TCH])  : Local File TABCHANGE [TCH]  : Endif 
Onerrgo 
If GERREUR : GERREUR=0 : Endif
Local Integer STAT, I
Local Char    SYMBOLE(30), AUZFCY(20), OLDFRM(GLONVCR), NUMBOR(GLONVCR), BANK(GLONBAN)
Local Date    DATJ
Local Integer MONOCPY # <JFL>
Raz [M]
BANK=PARAM(1)
NUMBOR=PARAM(2)
If BANK<>"" & NUMBOR<>""
 GDIV(0)="0" : Call AM_FRMNUM(NUMBOR)
Endif
Return

$FIN
If [M]FRMNUM<>"" 
 SYMBOLE = "FRM"+[M]FRMNUM+"\2" 
 Unlock =SYMBOLE
Endif  
Return 

$ABANDON
NOL=0 : [M]NB=0
NUMBOR = [M]FRMNUM
Gosub LECTURE
Sorta [M]NB [M]NB Order By [M]DUDDAT(indice),-[M]AMTCUR(indice)
Affzo [M]10
REP = ""
Return

$SETBOUT
Raz CHMEN
If REP="M"
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
ETABOU(GBFIN) = 1 
If [M]FRMNUM<>'' & !GCONSULT
 CHMEN += "Q"   :# Fichier banque
Else
Endif
Gosub SET_BOUT_SPE From GSAISIE
# <JFL>
# suppression des boutons : supprimer, enregistrer, créer + interdiction de duplication
If MONOCPY : Call VIREBOUT(CHAINE,"AMCD") From GOBJET : Endif
# </JFL>
Return

####################
$ENR
[L]DATJ=date$
Call DEBTRANS From GLOCK 
Gosub TR 
REP = ""
Return 
 
$TR 
GOK=1 : GERR=0 : GMESSAGE=""
Trbegin [PYH], [BES], [FRM]
 For I=0 To [M]NB-1 
 
  Readlock [BES]BES0=[M]FRMNUM;[M]LIN(I)  
  If fstat=1  
   GOK=-1 : GLOCK="$BILSTA"-[M]FRMNUM-num$([M]LIN(I)) : Break  
  Elsif fstat  
   GOK=0 : Call RSTA("BES",[M]FRMNUM-num$([M]LIN(I))) From GLOCK : Break
  Endif   
  OLDFRM=[F:PYH]FRMNUM

  If [M]PAYNUM(I)<>[F:BES]PAYNUM 
    
   If [F:BES]PAYNUM<>""  :# Annulation rapprochement
    Readlock [PYH]PYH0=[F:BES]PAYNUM  
    If fstat=1  
     GOK=-1 : GLOCK="$PAYMENTH"-[F:BES]PAYNUM : Break  
    Elsif fstat  
     GOK=0 : Call RSTA("PYH",[F:BES]PAYNUM) From GLOCK : Break
    Endif
    Call DROITSITEF("GESPAY",[F:PYH]FCY,[L]AUZFCY,STAT) From CPTSUB
    If !STAT | !instr(1,[L]AUZFCY,"M"): # Vous n'avez pas les droits pour ce site
     GERR=1 : GMESSAGE=mess(27,117,1)-[F:PYH]NUM+"\"+[F:PYH]FCY-":"-mess(2,104,1)
     GOK=0 : Break
    Endif
    If [F:PYH]STA>7 : # Règlement NUM - Etat : #
     GERR=1 : GMESSAGE=mess(27,117,1)-[F:PYH]NUM+"\"+mess(9,105,1)-":"-mess([F:PYH]STA,689,1)
     GOK=0 : Break 
    Endif
    Filter [PAN] Where TYPNUM=2 & NUM=[F:BES]PAYNUM & RENCOD="R"+[F:PYH]NUM
    Read [PAN]PAN0 First
    If fstat<=2
     # Règlement comptabilisé NUM - Annulation impossible
     GERR=1 : GMESSAGE=mess(54,117,1)-[F:PYH]NUM+"\"+mess(49,117,1)
     GOK=0 : Break 
    Endif
    Raz [F:PYH]FRMFLG 
    Raz [F:PYH]FRMNUM 
    Raz [F:PYH]FRMLIN 
    Raz [F:PYH]STAFLG(6) 
    Raz [F:PYH]PABFLG 
    Raz [F:PYH]PABREN 
    Raz [F:PYH]PABAMTPRT 
    Raz [F:PYH]FRMFCY 
    [F:PYH]STA = 1 
    For J=5 To 1 Step -1 
     If [F:PYH]STAFLG(J) = 2 
      [F:PYH]STA = J+1 : Break 
     Endif 
    Next J 
    Raz [F:PYH]FRMDAT 
    Raz [F:PYH]FRMUSR 
    If [F:PYH]FRMTYP<1 : [F:PYH]FRMTYP = 1  : Endif
    # Point d'entrée ANURAP : réinit des champs std ou spé du règlement (16060)
    GPOINT = "ANURAP" : Gosub ENTREE From EXEFNC
    
    Rewrite [PYH] 
    If fstat 
     GOK=0 : Call FSTA("PYH") From GLOCK : Break 
    Endif 
   Endif 

   If [M]PAYNUM(I)<>""   :# Rapprochement
    Readlock [PYH]PYH0=[M]PAYNUM(I)  
    If fstat=1  
     GOK=-1 : GLOCK="$PAYMENTH"-[M]PAYNUM(I) : Break  
    Elsif fstat  
     GOK=0 : Call RSTA("PYH",[M]PAYNUM(I)) From GLOCK : Break
    Elsif [F:PYH]STA>7 : # Règlement NUM - Etat : #
     GERR=1 : GMESSAGE=mess(9,105,1)-":"-mess([F:PYH]STA,689,1)
    Elsif [F:PYH]BAN<>[M]BAN : # Banque
     If [F:PYH]BAN<>""
      GERR=1 : GMESSAGE = mess([F:TPY]BANCSH,653,1)-[F:PYH]BAN
     Else
      GERR=1 : GMESSAGE = mess([F:TPY]BANCSH,653,1)+"=''"
     Endif 
    Elsif [F:PYH]CPY<>[M]CPY : # Société
     GERR=1 : GMESSAGE = mess(2,116,1)-[F:PYH]CPY
    Endif
    If GERR
     GMESSAGE=mess(27,117,1)-[F:PYH]NUM+"\"+GMESSAGE
     GOK=0 : Break
    Endif
  
    # Règlement sur un autre relevé 
    If [F:PYH]FRMNUM<>"" 
     Readlock [BES2]BES0=[F:PYH]FRMNUM;0 
     If fstat=1  
      GOK=-1 : GLOCK="$BILSTA"-[F:PYH]FRMNUM-"0" : Break 
     Elsif fstat=0 
      If [F:BES2]FLGEXP=2 
       # Règlement X relevé déjà exporté Y 
       GERR=1 : GMESSAGE=mess(27,117,1)-[F:PYH]NUM-mess(193,117,1)-[F:BES2]FRMNUM
       GOK=0 : Break  
      Endif
      Lock ="FRM"+[F:PYH]FRMNUM+"\2"
      If fstat
       GOK=-1 : GLOCK="%"+"FRM"+[F:PYH]FRMNUM+"\2" : Break
      Endif
      STAT=1
      Filter [PAN] Where TYPNUM=2 & NUM=[F:PYH]FRMNUM & RENCOD="R"+[F:PYH]NUM
      Read [PAN]PAN0 First
      Filter [PAN] 
      If fstat<=2 : STAT=0
      Else
       Call DROITSITE([F:PYH]FRMFCY,[L]AUZFCY,STAT) From CPTSUB
      Endif
      If !STAT
       # Règlement X Avis de domiciliation validé Y 
       GERR=1 : GMESSAGE=mess(27,117,1)-[F:PYH]NUM-mess(120,121,1)-[F:PYH]FRMNUM
       GOK=0 : Break 
      Endif
      Readlock [BES2]BES0=[F:PYH]FRMNUM;[F:PYH]FRMLIN   
      If fstat=1  
       GOK=-1 : GLOCK="$BILSTA"-[F:PYH]FRMNUM-num$([F:PYH]FRMLIN) : Break 
      Elsif fstat   
       GOK=0 : Call RSTA("BES2",[F:PYH]FRMNUM-num$([F:PYH]FRMLIN)) From GLOCK : Break  
      Endif
      Raz [F:BES2]PAYNUM 
      Rewrite [BES2] 
      If fstat 
       GOK=0 : Call FSTA("BES2") From GLOCK : Break
      Endif 
     Endif 
    Endif  

    [F:PYH]FRMFLG = 2 
    [F:PYH]FRMNUM = [M]FRMNUM 
    [F:PYH]FRMLIN = [M]LIN(I)
    [F:PYH]STA = 7 
    [F:PYH]STAFLG(6) = 2 
    [F:PYH]PABFLG = [M]PABFLG(I) 
    [F:PYH]PABREN = [M]PABREN(I) 
    [F:PYH]PABAMTPRT = [M]PABAMTPRT(I) 
    [F:PYH]FRMDAT = [L]DATJ 
    [F:PYH]FRMUSR = GUSER 
    [F:PYH]FRMFCY = [M]FCY 
    If [F:PYH]FRMTYP<1 : [F:PYH]FRMTYP = 1  : Endif
    # Point d'entrée CRERAP : mise à jour des champs std ou spé du règlement (16060)
    GPOINT = "CRERAP" : Gosub ENTREE From EXEFNC

    Rewrite [PYH] 
    If fstat 
     GOK=0 : Call FSTA("PYH") From GLOCK : Break
    Endif 
 
    [F:BES]PAYNUM = [M]PAYNUM(I)  
    Raz [F:BES]PABFLG     
    Raz [F:BES]PABREN     
    Raz [F:BES]PABAMTPRT  
    [F:BES]FLGANO = 1
 
   Else  : # [M]PAYNUM(I)="" : annulation rapprochement
    Raz [F:BES]PAYNUM 
    [F:BES]PABFLG    = 1  
    [F:BES]PABREN    = [M]PABREN(I)  
    [F:BES]PABAMTPRT = 0  
    [F:BES]FLGANO    = [M]FLGANO(I)
   Endif  
   Rewrite [BES]  
   If fstat  
    GOK=0 : Call FSTA("BES") From GLOCK : Break  
   Endif  
  
  Else : # [M]PAYNUM(I)=[F:BES]PAYNUM 
   If [M]PAYNUM(I)="" 
    [F:BES]PABFLG    = 1 
    [F:BES]PABREN    = [M]PABREN(I)  
    [F:BES]PABAMTPRT = 0 
    [F:BES]FLGANO    = [M]FLGANO(I) 
    Rewrite [BES]  
    If fstat  
     GOK=0 : Call FSTA("BES") From GLOCK : Break  
    Endif  
   Else 
    Readlock [PYH]PYH0=[M]PAYNUM(I)  
    If fstat=1  
     GOK=-1 : GLOCK="$PAYMENTH"-[M]PAYNUM(I) : Break  
    Elsif fstat  
     GOK=0 : Call RSTA("PYH",[M]PAYNUM(I)) From GLOCK : Break  
    Endif  
    [F:PYH]PABFLG    = [M]PABFLG(I) 
    [F:PYH]PABREN    = [M]PABREN(I) 
    [F:PYH]PABAMTPRT = [M]PABAMTPRT(I) 
    [F:PYH]FRMDAT    = [L]DATJ 
    [F:PYH]FRMUSR    = GUSER 
    If [F:PYH]FRMTYP<1 : [F:PYH]FRMTYP = 1 : Endif
    # Point d'entrée MAJRAP : mise à jour des champs std ou spé du règlement (16060)
    GPOINT = "MAJRAP" : Gosub ENTREE From EXEFNC

    Rewrite [PYH] 
    If fstat  
     GOK=0 : Call FSTA("PYH") From GLOCK : Break  
    Endif 
   Endif 
  Endif 
  
  If OLDFRM<>"" & OLDFRM<>[M]FRMNUM
   Read [PYH]PYH1(2) = 2;OLDFRM
   If fstat>2
    Delete [FRM]FRM0 = 2;OLDFRM
    If fstat=1
     GOK=-1 :  GLOCK="$PAYFRM"-"2"-OLDFRM : Break
    Elsif fstat>5
     GOK=0 :  Call RSTA("FRM","2"-OLDFRM) From GLOCK : Break 
    Endif
   Endif
  Endif

 Next I
 If GOK=0 : Goto AB_TR
 Elsif GOK<0 : Goto ROLL_TR
 Endif
  
 Read [PYH]PYH1(2) = 2;[M]FRMNUM
 If fstat>2
  Delete [FRM]FRM0 = 2;[M]FRMNUM
  If fstat=1
   GOK=-1 :  GLOCK="$PAYFRM"-"2"-[M]FRMNUM : Goto ROLL_TR  
  Elsif fstat>5
   GOK=0 :  Call RSTA("FRM","2"-[M]FRMNUM) From GLOCK : Goto AB_TR 
  Endif
 Else
  Read [FRM]FRM0 = 2;[M]FRMNUM
  If fstat
   Raz [F:FRM]
   [F:FRM] = [F:PYH]
   If dim([F:FRM]UPDDAT)>0 : Raz [F:FRM]UPDDAT : Endif
   If dim([F:FRM]UPDUSR)>0 : Raz [F:FRM]UPDUSR : Endif
   If dim([F:FRM]CREDAT)>0 : [F:FRM]CREDAT=[L]DATJ : Endif
   If dim([F:FRM]CREUSR)>0 : [F:FRM]CREUSR=GUSER : Endif
   Write [FRM]
   If fstat
    GOK=0 :  Call FSTA("FRM") From GLOCK : Goto AB_TR 
   Endif
  Else
   If dim([F:FRM]UPDDAT)>0 : [F:FRM]UPDDAT=[L]DATJ : Endif
   If dim([F:FRM]UPDUSR)>0 : [F:FRM]UPDUSR=GUSER   : Endif
   Rewrite [FRM]
   If fstat
    GOK=0 :  Call FSTA("FRM") From GLOCK : Goto AB_TR 
   Endif
  Endif
 Endif

Commit 
Return 

$ROLL_TR 
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR : Endif 
 
$AB_TR 
Rollback 
Return 
 
#################################### 
## Etiquette de l'écran RAPLCRMAN ## 
#################################### 

$SEL_TABLE
Case COUZON
 When "FRMNUM" : # No relevé
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:BES]) : Local File BILSTA  [BES] : Endif
  TIT(0) = mess(12,123,1)-mess(199,117,1) : # Choix relevé 
  NBCOL=1
  COL(NBCOL) = "FRMNUM" : Gosub TEX_BILSTA
  COL(NBCOL) = "BAN"    : Gosub TEX_BILSTA
  COL(NBCOL) = "PAYDAT" : Gosub TEX_BILSTA
  COL(NBCOL) = "CPY"    : Gosub TEX_BILSTA
  COL(NBCOL) = "FCY"    : Gosub TEX_BILSTA
  NBCOL-=1 : ORDRE = "FRMNUM"
  CRITERE = "BAN='"+[M]BAN+"' & LIN=0 & FLGEXP=1"
  # Filtre sur sites autorisés
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   CRITERE -= "& find([F:BES]FCY,GUSRFCY(1..GNBAUZ))"
  Endif
Endcase
Return

$TEX_BILSTA 
Read [ATZ]CODZONE = "BILSTA";[L]COL(NBCOL) 
Call TEXTE([F:ATZ]NOABREG,TIT(NBCOL)) From OBJDIV   
[L]NBCOL+=1
Return  

$CHX_TABLE
Case COUZON
 When "FRMNUM" : Default File [BES] 
Endcase
Return

Subprog C_FRMNUM(VALEUR)
Variable Char     VALEUR
If !clalev([F:BES]) : Local File BILSTA   [BES] : Endif
Read [BES]BES0=VALEUR;0
If fstat 
 GMESSAGE = mess(191,117,1) : mkstat=1 : # Relevé inexistant
Elsif GUSRFCY(1)<>"\" & !find([F:BES]FCY,GUSRFCY(1..GNBAUZ))
 GMESSAGE=mess(8,123,1) : mkstat=1 : # Accès impossible à cette fiche
Elsif [F:BES]FLGEXP=2 
 GMESSAGE = mess(193,117,1) : mkstat=1 : # Relevé déjà exporté
Elsif [F:BES]BAN<>[M]BAN 
 GMESSAGE = mess(1,653,1)-[F:BES]BAN : mkstat=1 : # Banque 
Else
 Call PARAM([F:BES]FCY,"RAPLCR",GDIV(0)) From ADOVAL
 Read [FRM]FRM0 = 2;VALEUR
 If !fstat & [F:FRM]STA>=9
  GMESSAGE = mess(120,121,1) : mkstat=1  : # Avis de domiciliation validé
 Endif
Endif
End

Subprog AM_FRMNUM(VALEUR)
Variable Char     VALEUR
Local Char    SYMBOLE1(30), SYMBOLE2(30), AUZFCY(10)
Local Integer STAT, I, NOL
SYMBOLE1 ="FRM"+VALEUR+"\2" 
Lock =SYMBOLE1 With lockwait=0 
If fstat
 # Modification en cours sur un autre poste 
 GERR=1 : GMESSAGE=mess(10,100,1) : mkstat=2 : End 
Endif 
If [M]FRMNUM<>"" 
 SYMBOLE2 = "FRM"+[M]FRMNUM+"\2" 
Endif 
If !clalev([F:BES]) : Local File BILSTA    [BES] : Endif 
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif 
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif 
Effzo [M]10-15 : NOL=0 
NUMBOR = VALEUR
Gosub LECTURE
If [M]NB=0 
 # Pas d'effets à rapprocher 
 Unlock =SYMBOLE1
 GERR=1 : GMESSAGE=mess(196,117,1) : mkstat=2
Else 
 Unlock =SYMBOLE2
 Sorta [M]NB [M]NB Order By [M]DUDDAT(indice),-[M]AMTCUR(indice)
 Affzo 
Endif 
End 
 
$LECTURE
Case GDIV(0) 
 When "1"      :# Traites non rapprochées uniquement
  For [BES]BES0 Hint Key BES1 Where FRMNUM=NUMBOR & PAYNUM=""
   Gosub CHARGE 
  Next 
 When Default  :# Toutes traites 
  For [BES]BES0 Where FRMNUM=NUMBOR
   Gosub CHARGE 
  Next 
Endcase  
Return

$CHARGE 
nolign = NOL+1 : [M] = [F:BES] 
If LIN=0   
 [M]DATREG = [F:BES]PAYDAT 
 [M]DATRET = [F:BES]INSDAT
 [M]AMTTOT = [F:BES]AMT 
 [M]DEVTOT = [F:BES]CUR 
 [M]DEVPAY = [F:BES]CUR
 Call SETCUR(1,[F:BES]CPY,[M]CURCPY) From CPTDIV
 Read [PYH]PYH1(2) = 2;[F:BES]FRMNUM
 If fstat<=2
  [M]PAYTYP = [F:PYH]PAYTYP
  Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
  Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
  [M]RATTPY = [F:TPY]RATTYP
 Else [M]RATTPY = 0
 Endif
Else
 If [F:BES]PAYNUM<>""
  Call LECTURE("PAY",[F:BES]PAYNUM,"") From CONTOBJ
  [M]PABFLG(NOL)    = [F:PYH]PABFLG
  [M]PABREN(NOL)    = [F:PYH]PABREN
  [M]PABAMTPRT(NOL) = [F:PYH]PABAMTPRT
  [M]PAYFCY(NOL)    = [F:PYH]FCY
  I=0
  If NOL>1
   I=find([F:PYH]FCY,[M]PAYFCY(0..NOL-1))
   If I : [M]SAI(NOL)=[M]SAI(I-1) : Endif
  Endif
  If I<1
   Call DROITSITEF("GESPAY",[F:PYH]FCY,[L]AUZFCY,I) From CPTSUB
   [M]SAI(NOL)=(I & instr(1,[L]AUZFCY,"M"))
  Endif
 Else [M]SAI(NOL)=1
 Endif 
 If [M]PABFLG(NOL)=2 
  [M]AMTPAY += [F:BES]AMT 
 Elsif [M]PABAMTPRT(NOL)<>0  
  If [M]DEVTOT<>[F:BES]CUR 
   Call CONVERT([F:BES]CUR,[M]DEVTOT,[M]CURCPY,[M]RATTPY,datesyst,[M]PABAMTPRT(NOL), 
&               [M]AMTPRT(NOL),STAT) From TRTDEV 
  Else 
   [M]AMTPRT(NOL) = [M]PABAMTPRT(NOL) 
  Endif
  [M]AMTPAY += [M]AMTPRT(NOL) 
 Endif
 NOL       +=1
 [M]NB +=1 
Endif
Return 

Subprog AVANT_NB 
If [M]PABFLG(nolign-1)=2 
 [M]AMTPAY -= [M]AMT(nolign-1) 
Else 
 [M]AMTPAY -=[M]AMTPRT(nolign-1) 
Endif 
End 
 
Subprog APRES_NB  
If sum([M]PAYNUM(0..[M]NB-1))="" 
 If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
 Read [PYH]PYH1(2) = 2;[M]FRMNUM
 If fstat<=2 : [M]PAYTYP = [F:PYH]PAYTYP
 Else        : [M]PAYTYP = ""
 Endif
Endif
If [M]PABFLG(nolign-1)=2  
 [M]AMTPAY += [M]AMT(nolign-1)  
Elsif [M]PABAMTPRT(nolign-1)<>0 
 If [M]DEVTOT<>[M]CUR(nolign-1)  
  Call CONVERT([M]CUR(nolign-1),[M]DEVTOT,[M]CURCPY,[M]RATTPY,datesyst,
&              [M]PABAMTPRT(nolign-1),[M]AMTPRT(nolign-1),STAT) From TRTDEV  
 Else  
  [M]AMTPRT(nolign-1) = [M]PABAMTPRT(nolign-1)  
 Endif 
 [M]AMTPAY += [M]AMTPRT(nolign-1)  
Endif 
Affzo [M]AMTPAY
End 

Subprog B1_NB  
Local Integer NOL : NOL=nolign-1
If [M]FLGANO(NOL)=2 
 [M]FLGANO(NOL) = 1
Else 
 [M]FLGANO(NOL) = 2 
 If [M]PAYNUM(NOL)<>"" : [M]PAYNUM(NOL)="" : Affzo [M]PAYNUM(NOL) : Endif
Endif 
Gosub SET_COUL
Gosub AFFICHE_COUL 
End   
 
$SET_COUL
If [M]FLGANO(NOL)=2  # Rouge
 [M]ANO(NOL)="*"
 Chgstl [M]NB(NOL) With "BACKRED"
Else
 [M]ANO(NOL)=""
 Chgstl [M]NB(NOL) With "TDB00"
Endif
Return
 
$AFFICHE_COUL 
Affzo [M]ANO(NOL), DUDDAT(NOL), CUR(NOL), AMTCUR(NOL), NAMCDT(NOL), REFDEB(NOL), ACP(NOL)  
Return

Subprog AV_DUDDAT(VALEUR)
Variable Date VALEUR
Local Integer NOL : NOL=nolign-1
Gosub SET_COUL
End

Subprog AS_PAYNUM(VALEUR) 
Variable Char     VALEUR 
If [M]PAYNUM(nolign-1)<>"" & ![M]SAI(nolign-1) : mkstat=2 : End : Endif
Gosub ANO 
End 
 
Subprog C_PAYNUM(VALEUR)
Variable Char     VALEUR

If VALEUR="" : End : Endif
 
Local Integer I , OK , STAT, NOL
Local Char    MESSA(255), TIT(40), AUZFCY(10)
Local Decimal MNT  
NOL = nolign-1

If !clalev([F:BES]) : Local File BILSTA    [BES] : Endif 
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif 
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif 
If !clalev([F:PAN]) : Local File PAYACCNUM [PAN] : Endif 

# Contrôle déjà saisi
If NOL>0 
 I = find(VALEUR,[M]PAYNUM(0..NOL-1))  
Endif
If !I & NOL<[M]NB-1
 I = find(VALEUR,[M]PAYNUM(NOL+1..[M]NB-1)) 
 If I : I+=NOL+1 : Endif
Endif
If I
 # Code déjà saisi en ligne
 GMESSAGE = mess(29,100,1)-num$(I) : mkstat=2 : End
Endif

Lock ="PYH"+VALEUR
If fstat
 GMESSAGE = mess(27,117,1)-VALEUR+"\"+mess(10,100,1) : mkstat=2 : End
Endif
Unlock ="PYH"+VALEUR

# Contrôle existence
Call LECTURE("PAY",VALEUR,"") From CONTOBJ
If fstat
 # Règlement VALEUR - Fiche inexistante
 GMESSAGE = mess(27,117,1)-VALEUR+"\"+mess(23,100,1) : mkstat=2 : End
Endif

# Droit de modif du règlement
I=find([F:PYH]FCY,[M]PAYFCY(0..[M]NB-1))
If I<1
 Call DROITSITEF("GESPAY",[F:PYH]FCY,[L]AUZFCY,OK) From CPTSUB
 If OK & !instr(1,[L]AUZFCY,"M") : OK=0 : Endif
Else OK=[M]SAI(I-1)
Endif
If !OK
 GMESSAGE = [F:PYH]FCY-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 mkstat=2 : End
Endif
 
# Type de règlement 
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
If [F:TPY]ENAFLG<>2
 Gosub TIT From WOTPY
 GMESSAGE = TIT-"\"+[F:PYH]PAYTYP-":"-mess(2,126,1) : # Fiche inactive
 mkstat=2 : End
Elsif dim([F:TPY]ACS)>0
 Call CONTEXE([F:TPY]ACS) From CPTSUB
 If mkstat : End : Endif
Endif

If [F:TPY]STA7<>2
 # Type de règlement non paramétré pour cette fonction 
 GMESSAGE = [F:PYH]PAYTYP-":"-mess(29,117,1) : mkstat=2 : End 
Else 
 If [F:TPY]STA3=2    : STAT=3
 Elsif [F:TPY]STA2=2 : STAT=2
 Else                : STAT=0
 Endif
 If (STAT & [F:PYH]STA<STAT) | [F:PYH]STA>7
  GMESSAGE = mess(9,105,1)-":"-mess([F:PYH]STA,689,1) : mkstat=2 : End : # Etat : #
 Endif
Endif 

# Lecture de la ligne de relevé 
Read [BES]BES0=[M]FRMNUM;[M]LIN(NOL) 

# Société 
If [F:PYH]CPY<>[F:BES]CPY 
 # Société 
 GMESSAGE = mess(2,116,1)-[F:PYH]CPY : mkstat=2 : End 
Endif  

# Banque 
If [F:PYH]BAN<>[F:BES]BAN 
 # Banque 
 GMESSAGE = mess(1,653,1)-[F:PYH]BAN : mkstat=2 : End 
Endif  

# Type de règlement
If [M]PAYTYP<>"" & [F:PYH]PAYTYP<>[M]PAYTYP
 # Type de règlement
 GMESSAGE = mess(198,117,1)-[F:PYH]PAYTYP : mkstat=2 : End
Endif

# Règlement sur un autre bordereau
If !find([F:PYH]FRMNUM,'',[M]FRMNUM) 
 Read [BES]BES0=[F:PYH]FRMNUM;0 
 If fstat=0 & [F:BES]FLGEXP=2 
  # Règlement sur l'avis de domiciliation ... Relevé déjà exporté 
  GMESSAGE = mess(121,117,1)-[F:PYH]FRMNUM-mess(193,117,1) : mkstat=2 : End 
 Else
  Read [BES]BES0=[M]FRMNUM;[M]LIN(NOL)  :# il faut relire la ligne de relevé courante
 Endif
 Lock ="FRM"+[F:PYH]FRMNUM+"\2"
 If fstat=0
  Unlock ="FRM"+[F:PYH]FRMNUM+"\2"
  Filter [PAN] Where TYPNUM=2 & NUM=[F:PYH]FRMNUM & RENCOD="R"+[F:PYH]NUM
  Read [PAN]PAN0 First
  Filter [PAN]
  OK=1 
  If fstat<=2 : OK=0
  Else
   Call DROITSITE([F:PYH]FRMFCY,[L]AUZFCY,OK) From CPTSUB
  Endif
  If !OK
   # Règlement sur l'avis de domiciliation X
   GMESSAGE = mess(121,117,1)-[F:PYH]FRMNUM : mkstat=2 : End
  Else
   # Règlement sur l'avis de domiciliation X
   [L]MESSA = mess(121,117,1)-[F:PYH]FRMNUM
  Endif
 Else
  GMESSAGE = mess(121,117,1)-[F:PYH]FRMNUM+"\"+mess(10,100,1) : mkstat=2 : End
 Endif 
Endif 

# Messages d'avertissement éventuels  
If VALEUR<>[M]PAYNUM(NOL)
 If [F:BES]CUR<>[F:PYH]CUR
  Call CONVERT([F:PYH]CUR,[F:BES]CUR,[M]CURCPY,[M]RATTPY,datesyst,[F:PYH]AMTCUR,[L]MNT,STAT)
&   From TRTDEV 
 Else 
  [L]MNT = [F:PYH]AMTCUR 
 Endif 
 If [F:BES]AMTCUR > [L]MNT 
  TIT="AMTCUR" : Gosub TEX_PYH
  If [L]MESSA<>"" : [L]MESSA+="\" : Endif   
  # Montant : Relevé = MT CUR, Règlement = MT CUR 
  [L]MESSA += TIT-":"-mess(199,117,1)-"="-num$([F:BES]AMTCUR)-[F:BES]CUR
&             -","-mess(27,117,1)-"="-num$([L]MNT)-[F:BES]CUR  
 Elsif [F:BES]AMTCUR < [L]MNT
  # Montant du règlement supérieur au montant du relevé
  GMESSAGE=mess(122,121,1) : mkstat=2 : End
 Endif  
 If [F:BES]DUDDAT<>[F:PYH]DUDDAT
  TIT="DUDDAT" : Gosub TEX_PYH  
  If [L]MESSA<>"" : [L]MESSA+="\" : Endif
  # Date d'échéance : Relevé = DAT1, Règlement = DAT2 
  [L]MESSA += TIT-":"-mess(199,117,1)-"="-num$([F:BES]DUDDAT)
&             -","-mess(27,117,1)-"="-num$([F:PYH]DUDDAT)  
 Endif  
 If [F:PYH]BPRREF<>"" & [F:BES]REFDEB<>"" & [F:BES]REFDEB<>[F:PYH]BPRREF
  TIT="BPRREF" : Gosub TEX_PYH
  If [L]MESSA<>"" : [L]MESSA+="\" : Endif   
  # Référence tiré: Relevé = REF1, Règlement = REF2 
  [L]MESSA += TIT-":"-mess(199,117,1)-"="-num$([F:BES]REFDEB)
&             -","-mess(27,117,1)-"="-num$([F:PYH]BPRREF)  
 Endif  
Endif

If [L]MESSA<>""   
 Call AVERTIR([L]MESSA,[L]OK) From GESECRAN  
 If [L]OK=1 : mkstat=2 : End : Else : [M]PABFLG(NOL)=2 : Endif
Endif

[M]SAI(NOL)=1
[M]PAYFCY(NOL)=[F:PYH]FCY
If [M]PAYTYP="" : [M]PAYTYP = [F:PYH]PAYTYP : Endif
End

$TEX_PYH
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif 
Read [ATZ]CODZONE = "PAYMENTH";TIT
Call TEXTE([F:ATZ]NOCOURT,TIT) From OBJDIV   
Return 

Subprog AS_PABFLG(VALEUR) 
Variable Integer  VALEUR 
Local Integer STAT, NOL
Local Decimal MNT
NOL = nolign-1
If ![M]SAI(NOL) : mkstat=2 : End : Endif
Gosub ANO : If mkstat : End : Endif 
If VALEUR=0 : VALEUR=1 : Endif 
If [M]PAYNUM(NOL)=""
 VALEUR=1 
Else
 Call LECTURE("PAY",[M]PAYNUM(NOL),"") From CONTOBJ
 If [F:BES]CUR=[F:PYH]CUR
  [L]MNT = [F:PYH]AMTCUR 
 Else
  Call CONVERT([F:PYH]CUR,[F:BES]CUR,[M]CURCPY,[M]RATTPY,datesyst,[F:PYH]AMTCUR,[L]MNT,STAT)
&   From TRTDEV 
 Endif 
 If [L]MNT = [M]AMTCUR(NOL)
  VALEUR = 2 
 Else
  VALEUR = 1 
 Endif
Endif
mkstat=2
End 

Subprog AM_PABFLG(VALEUR)    :# Accepté
Variable Integer  VALEUR
Effzo [M]PABREN(nolign-1)
End 
 
Subprog B2_PABFLG(VALEUR) 
Variable Integer  VALEUR 
Local Integer I
For I=nolign-1 To [M]NB-1 
 [M]PABFLG(I) = VALEUR 
Next I
Affzo 
End 
 
Subprog AS_PABREN(VALEUR)    :# Motif 
Variable Char     VALEUR
If ![M]SAI(nolign-1) : mkstat=2 : End : Endif
Gosub ANO : If mkstat : End : Endif
If [M]PABFLG(nolign-1)=2 : mkstat=1 : Endif
End 
 
Subprog C_PABREN(VALEUR)
Variable Char    VALEUR()
If [M]PABFLG(nolign-1)=1 & VALEUR="" & [M]PAYNUM(nolign-1)<>""
 mkstat=2 : GMESSAGE=mess(10,123,1)   :# Zone obligatoire
Endif 
End

Subprog AS_PABAMTPRT(VALEUR)
Variable Decimal  VALEUR
Local Integer STAT, NOL
Local Decimal MNT
NOL=nolign-1
If ![M]SAI(NOL) : mkstat=2 : End : Endif
Gosub ANO : If mkstat : End : Endif
If [M]PABFLG(NOL)=1 
 If [M]PAYNUM(NOL)=""
  VALEUR = 0 
 Else
  Call LECTURE("PAY",[M]PAYNUM(NOL),"") From CONTOBJ
  If [F:BES]CUR=[F:PYH]CUR
   [L]MNT = [F:PYH]AMTCUR 
  Else
   Call CONVERT([F:PYH]CUR,[F:BES]CUR,[M]CURCPY,[M]RATTPY,datesyst,[F:PYH]AMTCUR,[L]MNT,STAT)
&   From TRTDEV 
 Endif 
  VALEUR = [L]MNT
 Endif
Elsif [M]PABFLG(NOL)=2 
 VALEUR=[M]AMTCUR(NOL) 
Endif
mkstat=2
End 

Subprog C_PABAMTPRT(VALEUR)
Variable Decimal  VALEUR
If VALEUR>[M]AMTCUR(nolign-1)
 mkstat=1
Endif
End 

$ANO 
If [M]FLGANO(nolign-1)=2 : mkstat=2 : Endif 
Return  
 
########
$DSELPAY
########
#[L]MEMO="*RLM~sel" #DdM33277
[L]MEMO="RLM~sel"

## Préchargement du tableau de sélection avancée
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

NBSEL = 0 : NBTRI = 0

# Montant
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]AMTCUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "Nf:15F"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]AMTCUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Devise
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]CUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]CUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Date d'échéance
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]DUDDAT" : Gosub TEX_PAY
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "Df:"+GFMDAT
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]DUDDAT"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Référence tiré
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]BPRREF" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]BPRREF"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Site
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]FCY" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)

If dim([L]SELEXP)>0 : Raz [L]SELEXP : Endif
Local Char VALZON(30)(1..NBSEL)

Default Mask [RLM]
VALZON(1) = num$([M]AMTCUR(NOL))                 : # Montant 
VALZON(2) = [M]CUR(NOL)                          : # Devise 
VALZON(3) = format$("D:YYYYMMDD",[M]DUDDAT(NOL)) : # Date d'échéance  
VALZON(4) = [M]REFDEB(NOL)                       : # Référence tiré   
VALZON(5) = [M]FCY                               : # Site  

## Filtre supplémentaire obligatoire sur le fichier PAYMENTH
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Local Char FILTPYH(255)(1..4), SUBCRIT(255)
Local Integer IFILT
Raz FILTPYH, IFILT

Call ADDCRIT(FILTPYH,IFILT,"BAN","BAN='"+[M]BAN+"'"," & ") From GOBJSUB
Call ADDCRIT(FILTPYH,IFILT,"CPY","CPY='"+[M]CPY+"'"," & ") From GOBJSUB
Call ADDCRIT(FILTPYH,IFILT,"FRMNUM","FRMNUM=''"," & ") From GOBJSUB
[L]SUBCRIT=""

If [M]PAYTYP<>""
 Call ADDCRIT(FILTPYH, IFILT,"PAYTYP","PAYTYP='"+[M]PAYTYP+"'"," & ") From GOBJSUB
 If [F:TPY]STA3=2    : I=2
 Elsif [F:TPY]STA2=2 : I=1
 Else                : I=0
 Endif
 Call ADDCRIT(FILTPYH, IFILT,"STA","STA>"+num$(I)," & ") From GOBJSUB
Else
For [TPY]TPY0 Where STA7=2 & ENAFLG=2
 If dim([F:TPY]ACS)>0
   Call CONTEXE([F:TPY]ACS) From CPTSUB
   If !mkstat : OK=1 : Else OK=0 : GMESSAGE="" : mkstat=0 : Endif
  Else OK=1
  Endif
  If OK=1
   If [L]SUBCRIT<>"" : [L]SUBCRIT="|" : Else  [L]SUBCRIT="&(" : Endif
   [L]SUBCRIT+="(PAYTYP='"+[F:TPY]PAYTYP+"'"
   If [F:TPY]STA3=2
    I=2
   Elsif [F:TPY]STA2=2
    I=1
   Else
    I=0
   Endif
   If I : [L]SUBCRIT+=" & STA>"+num$(I)+")"
    Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",[L]SUBCRIT," ") From GOBJSUB
   Else
    [L]SUBCRIT += ")"
    Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",[L]SUBCRIT,"") From GOBJSUB
   Endif
  Endif
 Next : # [TPY]
 [L]SUBCRIT += ")"
 Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",[L]SUBCRIT,"") From GOBJSUB
Endif
Filter [PYH] Where evalue ([L]FILTPYH)


# Autorisation par site
Local Char OFONCTION(20)
OFONCTION = GFONCTION
If GFONCTION<>"GESPAY"
 GFONCTION  = "GESPAY"
 Call AUTORIS From EXEFNC
Endif
Return
  
$TEX_PAY
J=instr(1,SELZON(NBSEL),"]")
If !J : SELLIB(NBSEL)=SELZON(NBSEL) : Else SELLIB(NBSEL)=right$(SELZON(NBSEL),J+1) : Endif
For I=0 To 2
 Read [AMZ]CODE="PAY"+num$(I);SELLIB(NBSEL) 
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,SELLIB(NBSEL)) From OBJDIV 
  Break 
 Endif
Next I
Return  

########
$FSELPAY
########
Filter [PYH]
If dim([L]OFONCTION)>0 & GFONCTION<>OFONCTION
 GFONCTION = OFONCTION
 Call AUTORIS From EXEFNC
Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran RAPLCRMAN) 05/10/2011 15:26:16 (CP)
######################################################################################
Subprog C_NB
End


