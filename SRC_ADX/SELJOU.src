#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
Call S_TAB_CHAR(VALEUR,PARAM,"SELJOU","SELJOU","") From GACTION
End

#######################################################################
# Action SELJOU
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELJOU"    : Gosub SELJOU
  Endcase
Endcase
Return

$SELJOU

If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU] : Endif
If clalev([F:JOUS])=0 : Local File LEGJOUSEL [JOUS] : Endif
If clalev([F:JOUG])=0 : Local File LEGJOUGFY [JOUG] : Endif
If clalev([F:JOUP])=0 : Local File LEGJOUPAR [JOUP] : Endif

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PJO
 FCY = [M:ADWP]FCY
 CPY = [M:ADWP]CMP
 If dim([M:ADWP]LEG)>0 
  LEG = [M:ADWP]LEG
 Else
  LEG = GDOSLEG
 Endif
Elsif dim([M:RPT]ETAT)>0  #GACTION="AFMTSEL" : # = Sélection paramètres d'édition
 I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If I
  CPY = [M:RPT]VALINT1(I-1)
  Call LEC_CPY(CPY) From CPTLEC
  LEG = [F:CPY]LEG
 Endif
Elsif GFONCTION<>"GEXPOBJ"
 LEG    = PARAM(1)
 If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
 If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
 If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif
Endif


# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
Endif
# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données.
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" :  [L]CPY=""
 Endif
Endif


#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------

Gosub OUVRE_LISTE From WOJOU

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("JOU","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:JOU]JOU"
ORDRE  = "[F:JOU]JOU;[F:JOU]LEG"
OBJET  = ""


#--------------------------------------------------------------------------------------------------
# Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout

CRITERE(1)  = '[F:JOU]ENAFLG=2'

If [L]LEG<>""
  CRITERE(1) -= '& ([F:JOU]LEG="'+[L]LEG+'" | [F:JOU]LEG="")'
Endif
If [L]FCY<>""
 CRITERE(1) -= '& ([F:JOU]FCY="" | [F:JOU]FCY="'+[L]FCY+'" | ([F:JOU]FCY<>"" & [F:JOUG]LEGCPY="'+[L]CPY+'"))'
Elsif [L]CPY<>""
 CRITERE(1) -= '& ([F:JOU]FCY="" | ([F:JOU]FCY<>"" & [F:JOUG]LEGCPY="'+[L]CPY+'"))'
Endif

CRITERE(1) -= '& (GUSRACS=2 | [F:JOU]ACS="" | num$([F:ACC]CONSUL)="2")'

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(1) -= '& left$([F:JOU]JOU,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 2
Call FILROLE("JOU",FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif


#--------------------------------------------------------------------------------------------------
# Appel à la vue
#--------------------------------------------------------------------------------------------------

If [L]LEG<>""
 If [L]CPY<>""
  Link [JOU] With [AXX]AXX0     = "GJOURNAL";"DESTRA";GLANGUE;[F:JOU]JOU;[F:JOU]LEG
&               , [ACC]CODACC   =  GUSER;[F:JOU]ACS
&               , [JOUS]JOU0   ~=  [F:JOU]JOU;[F:JOU]LEG;[L]LEG
&               , [JOUG]JOU0    =  [F:JOU]JOU;[F:JOU]LEG;[F:JOU]FCY;[L]CPY
& As [LNC]
 Else
  Link [JOU] With [AXX]AXX0    = "GJOURNAL";"DESTRA";GLANGUE;[F:JOU]JOU;[F:JOU]LEG
&              , [ACC]CODACC   =  GUSER;[F:JOU]ACS
&              , [JOUS]JOU0   ~=  [F:JOU]JOU;[F:JOU]LEG;[L]LEG
& As [LNC]
 Endif
Else
 If [L]CPY<>""
  Link [JOU] With [AXX]AXX0     = "GJOURNAL";"DESTRA";GLANGUE;[F:JOU]JOU;[F:JOU]LEG
&               , [ACC]CODACC   =  GUSER;[F:JOU]ACS
&               , [JOUP]JOU0   ~=  [F:JOU]JOU;[F:JOU]LEG
&               , [JOUG]JOU0    =  [F:JOU]JOU;[F:JOU]LEG;[F:JOU]FCY;[L]CPY
& As [LNC]
 Else
  Link [JOU] With [AXX]AXX0     = "GJOURNAL";"DESTRA";GLANGUE;[F:JOU]JOU;[F:JOU]LEG
&               , [ACC]CODACC   =  GUSER;[F:JOU]ACS
&               , [JOUP]JOU0   ~=  [F:JOU]JOU;[F:JOU]LEG
& As [LNC]
 Endif
Endif
Default File [LNC]
DEFPAG = 1

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG
Return
