# 2017-01-17    | DNE    | 1.0     | Web-service calls via JavaScript-bundles, enhenced logging
# ############################################################################################# #


# < DEBUG> #################################################################################### #
Local Char PARAM(10)(1..2), VALEUR(10) : Call TRAITE_CHAR(VALEUR, PARAM, "", "EVCBAT","EVCBAT", 4, "SPEEVCBAT" ) From GTRAITE : End
# </DEBUG> #################################################################################### #


#** #####################################################################################
#* Sub chunk:  ACTION
#* Purpose:    Standard action dispatcher.
#* Parameters (as variables in the main chunk):
#* @param ACTION      Name of the event (action).
#*! #####################################################################################

$ACTION
If GSERVEUR
    # Batch server mode
    Case ACTION
        When "INIT"        : Gosub BATCH_INIT
        When "EXEC"        : Gosub BATCH_EXEC
    Endcase
Else
    # Interactive mode
    Case ACTION
        When "OUVRE"       : Gosub OUVRE
        When "DEBUT"       : Gosub DEBUT
        When "OK"          : If !GBATCH : Gosub OK : Endif # Do not execute while batch parameterization.
    Endcase
Endif
Return




#** #####################################################################################
#* Sub chunk:  OUVRE
#* Purpose:    Handles OURVE event from supervisor. Introduces process's static variables
#*             and opens additional tables.
#*! #####################################################################################

$OUVRE
    If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif
    If !clalev([F:EVCR]) : Local File EVCRESULT [EVCR] : Endif

    Local Integer B_LOG        : B_LOG = 1          # Flag: Log data?
    Local Integer N_NBVALID    : N_NBVALID = 0      # Number of successfully validated EU VAT IDs
    Local Integer N_NBINVALID  : N_NBINVALID = 0    # Number of not sucessfully validated EU VAT IDs
    Local Char MESSA(255)                           # Contains messages to log.
    Local Char WFILBPR(255)    : WFILBPR = "1=1"    # BP filter
    Local Char CRITERE(255)                         # Filter for additional conditions to be set in Entry-Point
    Local Integer EVCSERVICE                        # Global parameter which web service to use
    Local Char EVCCPY(GLONCPY)                      # Global parameter "source company"
    Local Integer EVCCONFIRM                        # Global parameter "confirmation letter"
    Local Char EVCSENDER(GLONEEC)                   # EU VAT ID of sender company

    EVCSERVICE= int(val(func AFNC.PARAM("EVCSERVICE", "")))
# TODO(DNE): Confirmation letter will be enabled in the future, only.
#    EVCCONFIRM= int(val(func AFNC.PARAM("EVCCONFIRM", "")))
#    If EVCCONFIRM >= 2 : EVCCONFIRM = 1 : Else : EVCCONFIRM = 0 Endif
    Raz EVCCONFIRM
    Call PARAM("","EVCCOMPANY",EVCSENDER) From ADOVAL

    If GFONCTION = "" : GFONCTION = "EVCBAT" : Endif
Return



#** #####################################################################################
#* Sub chunk:  DEBUT
#* Purpose:    Handler for the DEBUT event. Initializes field states (enabling and
#*             disabling).
#*! #####################################################################################

$DEBUT
# Initialize the fields's grayed/disabled states.
Call AM_ALLBPR( [M]ALLBPR )

# Update screen.
Affzo [M]1-99
Return



#** #####################################################################################
#* Sub chunk:  OK
#* Purpose:    Handler for the OK button. Does all the validation work.
#* NOTE:       OK is called from the BATCH_EXEC handler in batch mode, too.
#*! #####################################################################################

$OK
B_LOG = [M]FLGLOG - 1

# Open a log file and export the screen fields to the log file.
If B_LOG
    Gosub OPEN_LOG
Endif

# If in interactive mode open a "Wait..." box.
If !GSERVEUR
    Call TEMPON("V") From GESECRAN
Endif

If EVCSERVICE > 1                         # service to use <> "None"
    # Do the validation.
    Gosub SETUP_FILTER
    Gosub QUERY
    Gosub EVCBAT
Else                                      # service to use = "None"
    MESSA = mess(8,7706,1) - func AFNC.MES1( mess(9,7706,1), "EVCSERVICE" ) : Gosub LOGWARN
Endif

# If in interactive close the previously opened "Wait..." box.
If !GSERVEUR
    Call TEMPOFF From GESECRAN
Endif

# Close the log file.
If B_LOG
    Gosub CLOSE_LOG
Endif
Return



#** #####################################################################################
#* Sub chunk:  BATCH_INIT
#* Purpose:    Handler for the INIT event in batch mode. Initializes EVCBAT mask.
#*! #####################################################################################

$BATCH_INIT
    # Open the dialog window's screen:
    # Note: We do this because we need the mask accessible in batch tasks.
    #
    If clalev([M:EVCBAT])=0 : Local Mask EVCBAT [EVCBAT] : Endif
Return



#** #####################################################################################
#* Sub chunk:  BATCH_EXEC
#* Purpose:    Handler for the EXEC event in batch mode. Starts the validation process.
#*! #####################################################################################

$BATCH_EXEC
    # Initialize
    Gosub OUVRE
    Gosub DEBUT

    # Start mandate validation.
    Gosub OK
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Mass validation tool kit                                                           #
# ##########                                                                                    #
# ############################################################################################# #

$SETUP_FILTER
    If [M]ALLBPR = 1          # BP filter
        WFILBPR = "([F:EVCR]BPR >= [M]BPRSTR and [F:EVCR]BPR <= [M]BPREND)"
    Else
        WFILBPR    = "1=1"    # BP filter
    Endif

    # Entry point to set additional filter criteria
    CRITERE = "1=1"
    GPOINT = "CRITEVCBAT" : Gosub ENTREE From EXEFNC
Return

$QUERY
    Filter [F:EVCR] Where evalue(WFILBPR) and evalue(CRITERE)
Return


$EVCBAT
    Local Clbfile RESHEAD                           # Stream that contains the javascript result header as a comma separated list of values
    Local Clbfile RESBODY                           # Stream that contains the javascript result body as a comma separated list of values
    Local Clbfile ERRMSG                            # Stream that contains the error mesage to be displayed.
    Local Integer EVCVALID                          # Validation status of web service (0 = invalid, 1 = valid, 2 = qualified valid)

    If rowcount( [F:EVCR] ) = 0
        MESSA = mess(299,117,1) : Gosub LOGINFO # "No items to be processed"
    Else
        Raz N_NBVALID
        Raz N_NBINVALID

        # Log web service to be used.
        MESSA = mess(15,7706,1) - mess(EVCSERVICE,3685,1) : Gosub LOGMESS

        # Loop over...
        For [F:EVCR]
            [F:EVCR]CHKDAT = date$  # Update check date
            [F:EVCR]EVCCOUNT += 1   # Update checking counter

            N_NBINVALID += 1

            EVCVALID = func EVCLIB.CHECK_EU_VAT_ID( RESHEAD, RESBODY, ERRMSG, EVCSERVICE, EVCSENDER, [F:EVCR]EVCTARGET, [F:EVCR]BPRNAM(0), [F:EVCR]BPAADDLIG, [F:EVCR]POSCOD, [F:EVCR]CTY, EVCCONFIRM )
            If !EVCVALID # If not vaild:
                # In case of error we do not change anything but log errors.
                MESSA = mess(20,2422,1) - [F:EVCR]EVCTARGET + "~" + [F:EVCR]BPR + "~" + [F:EVCR]CODADR + "~" + num$([F:EVCR]EVCORIGIN)
                Gosub LOGERR  # Invalid
                MESSA = ERRMSG : Gosub LOGWARN # Log EVCLIB.CHECK_EU_VAT_ID's error message.
            Else # If valid:
                [F:EVCR]EVCQUALIFIED = EVCVALID
                [F:EVCR]EVCRESPONSE = RESBODY
                If EVCCONFIRM
                    [F:EVCR]EVCCONREQ = date$
                Else
                    [F:EVCR]EVCCONREQ = [0/0/0]
                Endif

                # Update record.
                Rewrite [F:EVCR]
                If fstat
                    # Update failed.
                    MESSA = mess(118,7711,1) - [F:EVCR]EVCTARGET + "~" + [F:EVCR]BPR + "~" + [F:EVCR]CODADR + "~" + num$([F:EVCR]EVCORIGIN)
                    Gosub LOGERR # "Rewrite Error"
                Else # Success
                    # Update was successful: Increase the counter.
                    N_NBVALID += 1

                    # Log differencing qualified and non-qualified validation.
                    If EVCVALID > 1
                        MESSA = func AFNC.MES1( mess(11,7706,1), [F:EVCR]EVCTARGET ) - [F:EVCR]EVCTARGET + "~" + [F:EVCR]BPR + "~" + [F:EVCR]CODADR + "~" + num$([F:EVCR]EVCORIGIN)
                        Gosub LOGMESS
                    Else
                        MESSA = func AFNC.MES1( mess(1,7706,1), [F:EVCR]EVCTARGET ) - [F:EVCR]EVCTARGET + "~" + [F:EVCR]BPR + "~" + [F:EVCR]CODADR + "~" + num$([F:EVCR]EVCORIGIN)
                        Gosub LOGMESS
                    Endif
                Endif
            Endif
        Next

        # Output a small summary.
        N_NBINVALID -= N_NBVALID
        If B_LOG
            MESSA = string$( 115, "-" ): Gosub LOGMESS
            MESSA = mess(307,117,1) - num$( N_NBVALID )   : Gosub LOGMESS # "Validated items"
            MESSA = mess(308,117,1) - num$( N_NBINVALID ) : Gosub LOGMESS # "Non-validated items"
        Elsif !GSERVEUR
            MESSA = mess(307,117,1) - num$( N_NBVALID )+ "," - mess(308,117,1) - num$( N_NBINVALID )
            Infbox MESSA
        Endif
    Endif
Return

# ############################################################################################# #
# ##########                                                                                    #
# ########## Tool kit (small helpers)                                                           #
# ##########                                                                                    #
# ############################################################################################# #

$OPEN_LOG
    # Open X3 log file (on dialog usage).
    If !GSERVEUR
        Call OUVRE_TRACE( GFONCTION ) From LECFIC
        Call TRACE_MASQUE( GFONCTION, GFONCTION, nomap ) From GTRAITE
    Endif
Return

$CLOSE_LOG
    # Close X3 log/trace file and show it on screen (on dialog usage).
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Return

$LOGMESS
    If B_LOG
        Call ECR_TRACE( MESSA, 0 ) From GESECRAN
    Endif
Return

$LOGWARN
    If B_LOG
        Call ECR_TRACE( MESSA, -1 ) From GESECRAN
    Endif
Return

$LOGERR
    If B_LOG
        Call ECR_TRACE( MESSA, 1 ) From GESECRAN
    Endif
Return

$LOGINFO
    If B_LOG
        Call ECR_TRACE( MESSA, 0 ) From GESECRAN
    Else
        Call MESSAGE( MESSA ) From GESECRAN
    Endif
Return


# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog AM_ALLBPR(VALEUR)
Variable Integer VALEUR

    If VALEUR - 1
        [M]BPRSTR = ""
        [M]BPREND = ""
        Grizo [M]BPRSTR
        Grizo [M]BPREND
    Else
        Actzo [M]BPRSTR
        Actzo [M]BPREND
    Endif
End


######################################################################################




