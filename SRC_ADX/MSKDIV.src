#---------------------------------------#
Subprog TR_DELMSK(MASQUE,APPLI)
Value Char MASQUE
Value Char APPLI
If APPLI=nomap
 Local File AMSK    [AMK]
 Local File AMSKZON [AMZ]
 Local File AMSKACT [AMA]
 Local File AMSKPAR [AMP]
 Local File AMOTCLE [AMC]
Else
 Local File =APPLI+".AMSK"     [AMK]
 Local File =APPLI+".AMSKZON"  [AMZ]
 Local File =APPLI+".AMSKACT"  [AMA]
 Local File =APPLI+".AMSKPAR"  [AMP]
 Local File =APPLI+".AMOTCLE"  [AMC]
Endif
Local File ADOSSIER [ADS]
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [AMK] , [AMZ] , [AMP] , [AMA]
 Call DELMSK(MASQUE,APPLI)
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#---------------------------------------#
Subprog TR_DELWIN(FENETRE,APPLI)
Value Char FENETRE
Value Char APPLI
If APPLI=nomap
 Local File AWINDOW  [AWI]
 Local File AWINPAR  [AWP]
 Local File AWINBRO  [AWB]
 Local File AWINBOUT [AWT]
Else
 Local File =APPLI+".AWINDOW"  [AWI]
 Local File =APPLI+".AWINPAR"  [AWP]
 Local File =APPLI+".AWINBRO"  [AWB]
 Local File =APPLI+".AWINBOUT" [AWT]
Endif
Local File ADOSSIER [ADS]
Call DEBTRANS From GLOCK
Gosub TR2
End

$TR2
GOK = 1
Trbegin [AWI] , [AWP] , [AWB] , [AWT]
 Call DELWIN(FENETRE,APPLI)
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#--------------------------------------------------------------#
# Effacement d'un masque
#--------------------------------------------------------------#
Subprog DELMSK(MASQUE,APPLI)
Value Char MASQUE
Value Char APPLI
If APPLI=nomap
 If clalev([F:AMK])=0 : Local File AMSK    [AMK] : Endif
 If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
 If clalev([F:AMA])=0 : Local File AMSKACT [AMA] : Endif
 If clalev([F:AMP])=0 : Local File AMSKPAR [AMP] : Endif
 If clalev([F:AMC])=0 : Local File AMOTCLE [AMC] : Endif
Else
 If clalev([F:AMK])=0 : Local File =APPLI+".AMSK"     [AMK] : Endif
 If clalev([F:AMZ])=0 : Local File =APPLI+".AMSKZON"  [AMZ] : Endif
 If clalev([F:AMA])=0 : Local File =APPLI+".AMSKACT"  [AMA] : Endif
 If clalev([F:AMP])=0 : Local File =APPLI+".AMSKPAR"  [AMP] : Endif
 If clalev([F:AMC])=0 : Local File =APPLI+".AMOTCLE"  [AMC] : Endif
Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Readlock [AMK]CODMSK = MASQUE
If fstat=1
 GOK=-1 : GLOCK="$AMSK"-MASQUE : End
Elsif !fstat
 Delete [AMK] Curr
Endif
Delete [AMZ] Where CODMSK=MASQUE
If fstat=1
 GOK = -1 : GLOCK = "$AMSKZON"-MASQUE : End
Endif
Delete [AMA] Where TYPAFF=1  & CODAFF=MASQUE
If fstat=1
 GOK = -1 : GLOCK = "$AMSKACT"-MASQUE : End
Endif
Delete [AMP] Where TYPAFF=1  & CODAFF=MASQUE
If fstat=1
 GOK = -1 : GLOCK = "$AMSKPAR"-MASQUE : End
Endif
Delete [AMC] Where TYPZON=2 & IDENT1=MASQUE
If fstat=1
 GOK = -1 : GLOCK = "$AMOTCLE"-MASQUE : End
Endif
If dim(GOPTIMMIG)<0    :   # CC hcb 22/05/2011 pour optimisation moulinettes contrôle qualité
 Call DEL_TRTMSK(MASQUE,APPLI)
Else
 Call SUPSCRN(APPLI,MASQUE) From INTRUTILB
Endif
End

#---------------------------------------#
Subprog DEL_TRTMSK(MASQUE,APPLI)
Value Char MASQUE
Value Char APPLI
Local Integer STAT , K , OKTRT
Local Char    FICHIER(GDIMFIC)
FICHIER = filpath(adxrob(0),MASQUE,"msk",APPLI)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
For K=0 To 9
 FICHIER = filpath("TRT","W"+num$(K)+MASQUE,"src",APPLI)
 If filinfo(FICHIER,0)>=0
  Call EFFACE(FICHIER,STAT) From ORDSYS
 Endif
 Call EXISTE_ADX("",APPLI,"W"+num$(K)+MASQUE,OKTRT) From ORDSYS
 If OKTRT>0
  Call EFFACE_ADX("",APPLI,"W"+num$(K)+MASQUE,STAT) From ORDSYS
 Endif
Next K
End

#--------------------------------------------------------------#
# Effacement d'une fenêtre
#--------------------------------------------------------------#
Subprog DELWIN(FENETRE,APPLI)
Value Char FENETRE
Value Char APPLI
If APPLI=nomap
 If clalev([F:AWI])=0 : Local File AWINDOW  [AWI] : Endif
 If clalev([F:AWP])=0 : Local File AWINPAR  [AWP] : Endif
 If clalev([F:AWB])=0 : Local File AWINBRO  [AWB] : Endif
 If clalev([F:AWT])=0 : Local File AWINBOUT [AWT] : Endif
Else
 If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif
 If clalev([F:AWP])=0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif
 If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif
 If clalev([F:AWT])=0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif
Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Delete [AWI] Where WIN=FENETRE
If fstat=1
 GOK = -1 : GLOCK = "$AWINDOW"-FENETRE : End
Endif
Delete [AWP] Where WIN=FENETRE
If fstat=1
 GOK = -1 : GLOCK = "$AWINPAR"-FENETRE : End
Endif
Delete [AWB] Where WIN=FENETRE
If fstat=1
 GOK = -1 : GLOCK = "$AWINBRO"-FENETRE : End
Endif
Delete [AWT] Where WIN=FENETRE
If fstat=1
 GOK = -1 : GLOCK = "$AWINBOUT"-FENETRE : End
Endif
Call DEL_TRTWIN(FENETRE,APPLI)
End

#---------------------------------------#
Subprog DEL_TRTWIN(FENETRE,APPLI)
Value Char FENETRE
Value Char APPLI
Local Char    FICHIER(GDIMFIC) , TRAIT(GLONADC)
Local Integer STAT , OKTRT
#Call NOMTRTWIN(FENETRE,TRAIT)
If FENETRE<>"" : TRAIT="WG"+FENETRE : Endif
FICHIER = filpath("TRT",TRAIT,"src",APPLI)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
Call EXISTE_ADX("",APPLI,TRAIT,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX("",APPLI,TRAIT,STAT) From ORDSYS
Endif
Call SUPWIND(APPLI,FENETRE) From INTRUTILB
End

#---------------------------------------#
Subprog NOMTRTWIN(WIN,TRAIT)
Value    Char WIN
Variable Char TRAIT()
If WIN=""
    TRAIT =""
Else
    If dim(GOPTWINTRT)<0    : # Bug 90296   --- Optimisation appel ISWINTOGENER
      Global Char GOPTWINTRT,GOPTSTAMPD
      Global Integer GOPTSTAMPH
    Endif
    If GOPTWINTRT = WIN and GOPTSTAMPD=date$ and (time-GOPTSTAMPH)<2
      GOPTSTAMPD=date$
      GOPTSTAMPH=time
      TRAIT = "WG"+WIN
      End
    Endif
#    Optimisation migrations : génération différée des fenêtres    (CC 26/10/2011)
    Local Integer VV
    If dim(GVALIDDIFF)>0 and GVALIDDIFF=3
      GVALIDDIFF=1  : VV=1
    Endif
    Call ISWINTOGENER(nomap,WIN) From INTRUTILB
    GOPTWINTRT=WIN
    GOPTSTAMPD=date$
    OPTSTAMPH=time
    If VV=1 : GVALIDDIFF=3 : Endif
    TRAIT = "WG"+WIN
Endif
End

#---------------------------------------#
Subprog NOMTRTWINDOS(WIN,TRAIT,DOSS)
Value    Char WIN
Variable Char TRAIT()
Value    Char DOSS

If WIN=""
    TRAIT =""
Else
    If dim(GOPTWINTRT)<0    : # Bug 90296   --- Optimisation appel ISWINTOGENER
      Global Char GOPTWINTRT,GOPTSTAMPD
      Global Integer GOPTSTAMPH
    Endif
    If GOPTWINTRT = WIN and GOPTSTAMPD=date$ and (time-GOPTSTAMPH)<2
      GOPTSTAMPD=date$
      GOPTSTAMPH=time
      TRAIT = "WG"+WIN
      End
    Endif
#    Optimisation migrations : génération différée des fenêtres    (CC 26/10/2011)
    Local Integer VV
    If dim(GVALIDDIFF)>0 and GVALIDDIFF=3
      GVALIDDIFF=1  : VV=1
    Endif
    Local Char DOSSI
    DOSSI=DOSS
    If DOSSI="" : DOSSI=nomap : Endif
    Call ISWINTOGENER(DOSSI,WIN) From INTRUTILB
    GOPTWINTRT=WIN
    GOPTSTAMPD=date$
    OPTSTAMPH=time
    If VV=1 : GVALIDDIFF=3 : Endif
    TRAIT = "WG"+WIN
Endif
End


#---------------------------------------#
Subprog NOMTRTWINOPT(WIN,TRAIT)
Value    Char WIN
Variable Char TRAIT()
If WIN=""
    TRAIT = ""
Else
    If dim(GOPTWINTRT)<0      : # Bug 90296   --- Optimisation appel ISWINTOGENER
      Global Char GOPTWINTRT,GOPTSTAMPD
      Global Integer GOPTSTAMPH
    Endif
    If GOPTWINTRT = WIN and GOPTSTAMPD=date$ and (time-GOPTSTAMPH)<2
      GOPTSTAMPD=date$
      GOPTSTAMPH=time
      TRAIT = "WG"+WIN
      End
    Endif
#    Optimisation migrations : génération différée des fenêtres    (CC 11/08/2011)
    Local Integer VV
    If dim(GVALIDDIFF)>0 and GVALIDDIFF=3
      GVALIDDIFF=1  : VV=1
    Endif
    Call ISWINTOGENER(nomap,WIN) From INTRUTILB
    GOPTWINTRT=WIN
    GOPTSTAMPD=date$
    GOPTSTAMPH=time
    If VV=1 : GVALIDDIFF=3 : Endif
#
    TRAIT = "WG"+WIN
Endif
End


#---------------------------------------#
Subprog NOMSPEWIN(WIN,TRAIT)
Value    Char WIN
Variable Char TRAIT()
TRAIT = "XW"+WIN
End

