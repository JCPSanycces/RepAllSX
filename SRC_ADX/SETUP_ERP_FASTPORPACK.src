Subprog SETUP(DOSSIER)
Value Char DOSSIER

#If !GSERVEUR
# Call OUVRE_TRACE(mess(00004,00036,1)-mess(00002,00107,1)) From LECFIC #Transaction Deactivation
#Endif

Local Char    TRANSAC(20)
Local Integer NBREC

Gosub PAYTRS
Gosub ACCTRS
Gosub ACCTYP
Gosub PURTRS
Gosub SALTRS
Gosub STKTRS
Gosub BENCHTRS
Gosub MAJLEG

#If !GSERVEUR
# Call FERME_TRACE From LECFIC
#Endif

End

#----------------
$PAYTRS
Local File =DOSSIER+".TABPAYTYP" [TPY]
TRANSAC="PAY_TRANSACTION"
Filter [TPY] Where ([F:TPY]LEG='' & find([F:TPY]PAYTYP,'BSI')>0)

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [TPY]
 NBREC = 0
 For [TPY]
  NBREC += 1
  GCLE = num$([F:TPY]PAYTYP)-num$([F:TPY]LEG)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:TPY]ENAFLG = 1
  Rewrite [TPY]
  If fstat
    GOK = 0 : Call FSTA("TPY") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return


#----------------

#----------------
$ACCTRS
Local File =DOSSIER+".GDIAENTRY" [GDE]
TRANSAC="ACC_TRANSACTION"
Filter [F:GDE] Where ([F:GDE]LEG='' & find([F:GDE]DIA,'1PAGE','BALAN','NA1PG','STDLI','STDLO','STDON','UNBAL')>0)

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [F:GDE]
 NBREC = 0
 For [F:GDE]
  NBREC += 1
  GCLE = num$([F:GDE]DIA)-num$([F:GDE]LEG)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:GDE]ENAFLG = 1
  Rewrite [F:GDE]
  If fstat
    GOK = 0 : Call FSTA("GDE") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$ACCTYP
Local File =DOSSIER+".GTYPACCENT" [GTE]
TRANSAC="ACC_DOCUMENT_TYPES"
Filter [F:GTE] Where ([F:GTE]LEG='' & find([F:GTE]TYP,'FAAR2','FAIR3','FAIS3','FAR12','FAS12','WIPCO')>0)
&              or ([F:GTE]LEG='POR' & find([F:GTE]TYP,'CCL','FTG','IMI','IMO','OCI','SMG')>0)

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [F:GTE]
 NBREC = 0
 For [F:GTE]
  NBREC += 1
  GCLE = num$([F:GTE]TYP)-num$([F:GTE]LEG)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:GTE]ENAFLG = 1
  Rewrite [F:GTE]
  If fstat
    GOK = 0 : Call FSTA("GTE") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------

$PURTRS
Local File =DOSSIER+".PURTRS" [PTR]
TRANSAC='PUR_TRANSACTION'
Filter [PTR] Where (find([F:PTR]PTRTYP,2,3,6,7,8,9)>0 & find([F:PTR]PTRNUM,'STD','VT')>0)
& or find([F:PTR]PTRTYP,1,4,5)>0

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [PTR]
 NBREC = 0
 For [PTR]
  NBREC += 1
  GCLE = num$([F:PTR]PTRTYP)-num$([F:PTR]PTRNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:PTR]ENAFLG = 1
  Rewrite [PTR]
  If fstat
    GOK = 0 : Call FSTA("PTR") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$SALTRS
Local File =DOSSIER+".SALTRS" [SLT]
TRANSAC='SAL_TRANSACTION'

Filter [SLT] Where
&    (find([F:SLT]STRTYP,1,2,4,5,6)>0 & [F:SLT]STRNUM ='STD')
& or ([F:SLT]STRTYP=2 & find([F:SLT]STRNUM,'ECM','SAL')>0)
& or ([F:SLT]STRTYP=5 & [F:SLT]STRNUM ='STA')
& or (find([F:SLT]STRTYP,3,7,8)>0 & [F:SLT]STRNUM <>'')



Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [SLT]
 NBREC = 0
 For [SLT]
  NBREC += 1
  GCLE = num$([F:SLT]STRTYP)-num$([F:SLT]STRNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:SLT]ENAFLG = 1
  Rewrite [SLT]
  If fstat
    GOK = 0 : Call FSTA("SLT") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$STKTRS
Local File =DOSSIER+".STKTRS" [SRT]
TRANSAC='STK_TRANSACTION'

Filter [SRT] Where
& (find([F:SRT]SRTTYP,1,2,3)>0 & find([F:SRT]SRTNUM,'STD','VT')>0)
& | ([F:SRT]SRTTYP=1 & find([F:SRT]SRTNUM,'ENT')>0)
& | ([F:SRT]SRTTYP=2 & find([F:SRT]SRTNUM,'ISS','REB')>0)
& | ([F:SRT]SRTTYP=3 & find([F:SRT]SRTNUM,'CHG','CHS','CHU','SUR','TRS','TSA')>0)
& | ([F:SRT]SRTTYP=6 & find([F:SRT]SRTNUM,'REV')>0)


Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [SRT]
 NBREC = 0
 For [SRT]
  NBREC += 1
  GCLE = num$([F:SRT]SRTTYP)-num$([F:SRT]SRTNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:SRT]ENAFLG = 1
  Rewrite [SRT]
  If fstat
    GOK = 0 : Call FSTA("SRT") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$BENCHTRS
Local File =DOSSIER+".BENCHTRS" [BTS]
TRANSAC='BENCH_TRANSACTION'

Filter [BTS] Where
& (find([F:BTS]BTSNUM,'PLN','POS','REA','SST','STD','SUB','WOF','WOS','CTR','INR','INT')>0 & [F:BTS]BTSTYP =51)
& or [F:BTS]BTSTYP =52 or [F:BTS]BTSTYP =53

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [BTS]
 NBREC = 0
 For [BTS]
  NBREC += 1
  GCLE = num$([F:BTS]BTSTYP)-num$([F:BTS]BTSNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:BTS]ENAFLG = 1
  Rewrite [BTS]
  If fstat
    GOK = 0 : Call FSTA("BTS") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

$AB_TR1
Rollback
Return

#----------------
$MAJLEG

Local File ADOSSIER [ZADS]
Local Integer ZOK
TRANSAC="MAJ_LEG"

Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

Read [ZADS]DOSSIER = [L]DOSSIER
If !fstat
 ZOK = func COPLEG([F:ZADS]DOSSIER,[F:ZADS]DOSREF,"POR")
Endif

Return

#**
#*
#*
#* @param DOSSIER
#* @param DOSREF
#* @param LEG
#*!
Funprog COPLEG(DOSSIER,DOSREF,LEG)
Value Char DOSSIER()
Value Char DOSREF()
Value Char LEG()

Local File =[L]DOSSIER+".ADOVAL" [ADW]
Local File =[L]DOSREF+".ADOVAL" [LEC]

Local Integer IFLOG

IFLOG = adxlog

If IFLOG=0
  Trbegin [LEC],[ADW]
Endif

For [LEC] Where CMP='*' and FCY=LEG
  Read [ADW]ADW1=[LEC]PARAM;"";""
  If fstat=0
    If [ADW]VALEUR<>[LEC]VALEUR
        [ADW]=[LEC]
        [ADW]CMP="" : [ADW]FCY=""
        Rewrite [ADW]
        Break (fstat<>0)
    Endif
  Else
      [ADW]=[LEC]
      [ADW]FCY=""
      [ADW]CMP=""
      Write [ADW]
      Break (fstat<>0)
  Endif
Next

If fstat<>0
  If IFLOG=0
    Rollback
  Endif
  End 1
Endif

If IFLOG=0
  Commit
Endif

End 0

