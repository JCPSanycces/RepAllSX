#<AdxTL>@(#)4.0.0.0 $Revision$
########################################################################
# Traitement TRTSTOANA - Saisie des sections analytiques stock    V140 #
#                                                                      #
########################################################################
# Action SAISTOANA
#    Paramètres     - LABR    Abréviation masque : "SOR","ENT" ou "SNL1"
#                   - LNOL    No ligne écran (nolign-1)
# 
########################################################################
$ACTION
#--- Actions liées au traitement standard 
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "AVANT_ENR" : Gosub AVANT_ENR
 When "ENR"       : Gosub ENR
 When "ABA"       : Gosub ABA
 When "FINSAI"    : Gosub FINSAI
Endcase

Return

##########################################################################
$OUVRE
# Récupération des paramètres
LABR    = PARAM(1)
Return

##########################################################################
$DEBUT

For I=1 To GNBDIE
    If GACTION="SAISTOANAS"
        [M]CCE(I-1) = evalue("["+LABR+"]CCS(I-1)") 
    Else
        [M]CCE(I-1) = evalue("["+LABR+"]CCE(I-1)") 
    Endif
   [M]DIE(I-1)=GDIE(I)
Next I
[M]NBAXE = GNBDIE

If evalue("["+LABR+"]CCECODS")=2 | GCONSULT=2 | (dim(GSNLSTAIMG3) > 0 & GSNLSTAIMG3 = 2 )   # hcb 74380 
   Diszo [M:STA]
Endif

Affzo [M]1-99

Return

#########################################################################
$SETBOUT

If evalue("["+LABR+"]CCECODS")<2 & GCONSULT<>2 
   If !find("A",CHBOU) CHBOU+="A" Endif
   If !find("E",CHBOU) CHBOU+="E" Endif
Endif

Return

##########################################################################
$AVANT_ENR

For I=1 To GNBDIE
   #Call CTRL_CCEH([M]CCE(I-1),[M]DIE(I-1),GFINRSP,[M]IPTDAT) From TRTX3CPT : # MBT 29/08/06
    Call CTRL_CCEH([M]CCE(I-1),I,GFINRSP,[M]IPTDAT) From TRTX3CPT
    If mkstat Break Endif
Next I
If mkstat FOK=0 Endif

Return

##########################################################################
$ENR

For I=1 To GNBDIE
    If GACTION="SAISTOANAS"
        Assign "["+LABR+"]CCS(I-1)" With [M]CCE(I-1) 
    Else
        Assign "["+LABR+"]CCE(I-1)" With [M]CCE(I-1) 
    Endif
   [M]DIE(I-1)=GDIE(I)
Next I

Gosub AP_ENR 

FIN = 1
Return

##########################################################################
$FINSAI

mkstat = 4

Return

##########################################################################
$ABA

For I=1 To GNBDIE
    If GACTION="SAISTOANAS"
        [M]CCE(I-1) = evalue("["+LABR+"]CCS(I-1)") 
    Else
        [M]CCE(I-1) = evalue("["+LABR+"]CCE(I-1)") 
    Endif
   [M]DIE(I-1)=GDIE(I)
Next I

Affzo [M]1-99

Return

##########################################################################

$AP_ENR
Case  LABR 
     When  "SNL0" Gosub MAJ_ANA_CUL From SUBSNLA    # inventaire entete CUNLISTE 
     When  "SNL1" Gosub MAJ_ANA_CUD From SUBSNLA    # inventaire detail CUNLISDET 
Endcase


Return


Subprog D_NBAXE
If GIMPORT    # hcb 69190 
   End
Endif
Case LABR
     When "SMR0"
          Call INIT_CCEH("STA","NBAXE","STKENDH") From TRTX3CPT
     When "SMO0"
          Call INIT_CCEH("STA","NBAXE","STKSODH") From TRTX3CPT
     When "BBY0"
          Call INIT_CCEH("STA","NBAXE","STKBBYH") From TRTX3CPT
     When "DBY0"
          Call INIT_CCEH("STA","NBAXE","STKDBYH") From TRTX3CPT
Endcase    

End


######################################################################################

