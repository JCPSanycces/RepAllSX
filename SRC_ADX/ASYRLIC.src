#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK
If JSON<>null
 Local Clbfile CLBJSON
 Local Integer COUNT
 COUNT = strDecode(ARCV.JSON,CLBJSON,GUTF8)
 ERROR = func SET_LICENSE(ACTX,JSON,CLBJSON)
 If ERROR = [V]CST_AOK
  Call UPDATE_LIC_DB(ACTX.AFOLDER,CLBJSON,0)
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AOK,[V]CST_AHTTP_CREATED,"")
 Endif
Else
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AOK,[V]CST_AHTTP_CREATED,"")
Endif
End ERROR

#**
#* LOAD_CVGLIC
#* loads the convergence license
#*
#* @param ACTX (in)
#*!
Funprog LOAD_CVGLIC(_ACTX)
Variable Instance _ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT

 Local Clbfile RESHEAD(4)
 Local Clbfile RESBODY(6)
 Local Char MODULE(100)
 Local Char FONCTION(30)
 Local Char MODE(10)
 Local Clbfile ARGUMENTS(2)
 Local Char ENCODINGS(40)
 Local Integer CALLBACKINDEX
 Local Char RETURNS(50)
 Local Char RETURNS_ENC(3)
 Local Integer STATUSCODE

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK

#
#Gosub VERCOM From GLOBVAR
#

MODULE = 'syracuse-x3/lib/convergence/client/CvgLic'
FONCTION = "getManifest"
MODE = "wait"
#ARGUMENTS = '"' + func ASYRLIC.GET_CHPRODUCTSTDCODE + '", "' + left$(VERSION,1) + '"'
ARGUMENTS = '"' + func ASYRLIC.GET_CHPRODUCTSTDCODE + '", "' + func APRODUCT.AGETVERSLIC() + '"'
ENCODINGS = ''
CALLBACKINDEX = 0
RETURNS = ''
RETURNS_ENC = '0'
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, CALLBACKINDEX,    RETURNS, RETURNS_ENC, RESHEAD, RESBODY)
If STATUSCODE = [V]CST_AHTTP_OK & len2(RESBODY)>10
 ERROR = func LOAD_LICENSE(_ACTX,RESBODY)
 If ERROR=[V]CST_AOK
  Call UPDATE_LIC_DB(_ACTX.AFOLDER,RESBODY,0)
 Endif
Endif
End ERROR

#**
#* LOAD_LICENSE
#* loads the license stored in the JSON flow
#*
#* @param ACTX (in)
#* @param JSON (in)
#* @param LICENSE (out)
#*!
Funprog LOAD_LICENSE(ACTX,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile JSON

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK
ERROR = func ASYRJSONPARSE.PARSEJSON(GACTX,JSON,NODES,NODE)
If ERROR = [V]CST_AOK
 ERROR = func SET_LICENSE(ACTX,NODE,JSON)
Endif
If NODES<>null
FreeGroup NODES
Endif
End ERROR

#**
#* SET_LICENSE
#* set the license stored in the json array
#* @param ACTX (in)
#* @param JSON (in)
#* @param LICENSE (out)
#*!
Funprog SET_LICENSE(ACTX,JSON,CLBJSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance JSON Using C_ASYRJSO
Value Clbfile CLBJSON

Local Integer ERROR : ERROR=[V]CST_AOK
Local Integer LEVEL : LEVEL=1
Local Integer AI,AJ
Local Instance  NODE(1..)         Using C_ASYRJSO  : NODE=null

ACTX.isReadonly = 0
If ACTX._ASYRLIC<>null
 FreeGroup ACTX._ASYRLIC
 ACTX._ASYRLIC=null
Endif
ACTX._ASYRLIC = NewInstance [ASYRLIC] With C_ASYRLIC
If dim(ACTX._ASYRLIC.AFILE)>0
 ACTX._ASYRLIC.AFILE=CLBJSON
Endif

NODE(LEVEL) = JSON
While NODE(LEVEL) <> null
  Case tolower(NODE(LEVEL).PRO)
   When "licenses":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.LICENSES(AI) = NewInstance C_ASYRLICMOD AllocGroup ACTX._ASYRLIC

    LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
    While NODE(LEVEL) <> null
     Case tolower(NODE(LEVEL).PRO)
      When "partnerid" : ACTX._ASYRLIC.LICENSES(AI).PARTNERID = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "productcode" : ACTX._ASYRLIC.LICENSES(AI).PRODUCTCODE = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "productversion" : ACTX._ASYRLIC.LICENSES(AI).PRODUCTVER = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "policycode" : ACTX._ASYRLIC.LICENSES(AI).POLICYCODE = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "policyversion" : ACTX._ASYRLIC.LICENSES(AI).POLICYVER = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "licenseexpired" : ACTX._ASYRLIC.LICENSES(AI).EXPIRED = fmet NODE(LEVEL).AGETCNT
      When "productname" : ACTX._ASYRLIC.LICENSES(AI).PRODUCTNAME = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
      When "serial" : ACTX._ASYRLIC.LICENSES(AI).SERIAL = seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
     Endcase
     NODE(LEVEL) = NODE(LEVEL).NEX
    Wend
    LEVEL -= 1

    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "activitycodes":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.ACTIVITIES(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.ACTIVITIES(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.ACTIVITIES(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "languages":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.LANGUAGES(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.LANGUAGES(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.LANGUAGES(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "parameterkits":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.KITS(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.KITS(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.KITS(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
   When "legislations":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.LEGISLATIONS(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.LEGISLATIONS(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.LEGISLATIONS(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "modules":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.MODULES(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.MODULES(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.MODULES(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "keyfunctions":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   AJ = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.KEYFUNCTIONS(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.KEYFUNCTIONS(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.KEYFUNCTIONS(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    If fmet NODE(LEVEL).AGETCNT="false"
     AJ +=1 : ACTX._ASYRLIC.KEYFCTFORBI(AJ) = NODE(LEVEL).PRO
    Endif
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
  When "parameters":
   LEVEL += 1 : NODE(LEVEL) = NODE(LEVEL-1).SUB
   AI = 0
   While NODE(LEVEL) <> null
    AI += 1 : ACTX._ASYRLIC.PARAMETERS(AI) = NewInstance C_ASYRLICELT AllocGroup ACTX._ASYRLIC
    ACTX._ASYRLIC.PARAMETERS(AI).CODE    = NODE(LEVEL).PRO
    ACTX._ASYRLIC.PARAMETERS(AI).SVALUE = fmet NODE(LEVEL).AGETCNT
    NODE(LEVEL) = NODE(LEVEL).NEX
   Wend
   LEVEL -= 1
 Endcase
 NODE(LEVEL) = NODE(LEVEL).NEX
Wend
FreezeInstance ACTX._ASYRLIC
ACTX.isReadonly = 1
End ERROR


#**
#* Update JSON used for license
#*
#*!
Subprog UPDATE_LIC_DB(DOS,JSON,FORCE)
Value Char DOS
Value Clbfile JSON
Value Integer FORCE

Local Char DOSSUP(30)

Local Integer AI,AJ
AI = instr(1,JSON,'"keyFunctions"')
If AI
 AJ = instr(AI,JSON,'}')
 If AJ
  # Remove the keyFunctions part of the licence
  Local Clbfile LEFT,RIGHT

  # the last comma has to be remove as well:
  AI = AI-1
  While AI > 0
  CAR = xgetchar(JSON,AI)
   If  CAR = ','
    LEFT  = left$(JSON,AI-1)
    Break
   Elsif find(CAR,' ',chr$(10),chr$(13))
    AI = AI-1
   Else
    Break
   Endif
  Wend

  If len(LEFT)
   RIGHT = right$(JSON,AJ+1)
   JSON =LEFT
   Append JSON,RIGHT
  Endif
 Endif
Endif

If len2(JSON)>10
 If nomap=[L]DOS or [L]DOS=""
  Local File ADOVAL [ADW_]
 Else
  Local File =[L]DOS+".ADOVAL" [ADW_]
 Endif
 Read [ADW_]ADW0 = "";"";"SUPDOS"
 If fstat
  Close Local File [ADW_]
  End
 Else
  DOSSUP=[F:ADW_]VALEUR
  If [L]DOSSUP=""
   [L]DOSSUP=[L]DOS
  Endif
 Endif
 If [L]DOSSUP=[L]DOS or [L]DOSSUP=""
  Local File ACLOB [ACB_]
 Else
  Local File =[L]DOSSUP+".ACLOB" [ACB_]
 Endif

 If !adxlog
  Gosub AUPDATE_LIC_DB_TR
 Else
  Gosub AUPDATE_LIC_DB
 Endif
 Close Local File [ADW_],[ACB_]
Endif
End

$AUPDATE_LIC_DB_TR
Trbegin [ACB_]
Gosub AUPDATE_LIC_DB
Commit
Return

$AUPDATE_LIC_DB
Read [ACB_]ACB0= "ASYRLIC";"";"";""
If !fstat
 If FORCE=0 & [ACB_]NAMBLB>=format$("YYYYMMDD",date$)
  Return
 Endif
Endif
[ACB_]NAMBLB = format$("YYYYMMDD",date$)
[ACB_]CLOB = JSON
If dim(GACTX)>0 & dim(GACTX.USER)>0
 [ACB_]CREUSR=GACTX.USER
 [ACB_]UPDUSR=GACTX.USER
Elsif dim(GUSER)>0
 [ACB_]CREUSR=GUSER
 [ACB_]UPDUSR=GUSER
Endif
[ACB_]CREDATTIM=datetime$
[ACB_]UPDDATTIM=datetime$
[ACB_]CREDAT=date$
If fstat
 [ACB_]CNTTYP = "ATYPE10-1"
 [ACB_]TYPDOC = "TXT"
 [ACB_]CODBLB = "ASYRLIC"
 Write [ACB_]
Else
 Rewrite [ACB_]
Endif
Return

#**
#* Get license JSON
#*
#*!
Subprog LOAD_LIC_DB(_ACTX)
Variable Instance _ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT

 If _ACTX.AFOLDER=nomap or _ACTX.AFOLDER=""
  Local File ADOVAL [ADW_]
 Else
  Local File =_ACTX.AFOLDER+".ADOVAL" [ADW_]
 Endif
 Read [ADW_]ADW0 = "";"";"SUPDOS"
 If fstat
  Close Local File [ADW_]
  End
 Else
  DOSSUP=[F:ADW_]VALEUR
  If [L]DOSSUP=""
   [L]DOSSUP=_ACTX.AFOLDER
  Endif
 Endif
 If [L]DOSSUP=nomap or [L]DOSSUP=""
  Local File ACLOB [ACB_]
 Else
  Local File =[L]DOSSUP+".ACLOB" [ACB_]
 Endif

 Read [ACB_]ACB0= "ASYRLIC";"";"";""
 If !fstat
  Call LOAD_LICENSE(_ACTX,[ACB_]CLOB)
 Endif

 Close Local File [ADW_],[ACB_]
End

###################################################
Funprog GET_CHPRODUCTSTDCODE
Local Integer PRODUIT
 Case GPRODUIT
  When 0 : PRODUIT=1 : # X3
  When 1 : PRODUIT=2 : # Géode
  When 2 : PRODUIT=3 : # Paye
  When 3 : PRODUIT=4 : # Biens
  When Default : PRODUIT=GPRODUIT
 Endcase
End num$(PRODUIT)

###################################################
#used from GESUSER : real or default license
###################################################
$GESUSER_CHARGE_LIC
If GACTX._ASYRLIC=null
 #Attention adxtyp console et eclipse, on n'a pas de serveur syracuse => pas de licence
 If dim(GFUSION)>0 & GFUSION=1 & !GSERVEUR & adxtyp<>17 and adxtyp<>14
  If func ASYRLIC.CTLLIC
   Call LOAD_CVGLIC(GACTX) From ASYRLIC
  Endif
 Elsif adxtyp=17 or adxtyp=14 : #adxtyp console et eclipse ?????
  Call LOAD_LIC_DB(GACTX) From ASYRLIC
  If GACTX._ASYRLIC=null
   Call LOAD_LIC From AVISULIC_CSTD
  Endif
 #Elsif GACTX._ASYRLIC=null & dim(GSERVEUR)>0 & GSERVEUR
 Else : #Lecture en base dans tous les autres cas
  If func ASYRLIC.CTLLIC
   Call LOAD_LIC_DB(GACTX) From ASYRLIC
  Endif
 Endif
 # cas connexion client lourd
 If GACTX._ASYRLIC=null and func ASYRLIC.CTLLIC=0
  Call LOAD_LIC From AVISULIC_CSTD
 Endif
Endif
Return

###################################################
#used from ASYRMAIN : default license
###################################################
$ASYRMAIN_CHARGE_LIC
If GACTX._ASYRLIC=null and func ASYRLIC.CTLLIC=0
 Call LOAD_LIC From AVISULIC_CSTD
Endif
Return

Funprog CTLLIC
#Gosub VERCOM From GLOBVAR
#100502
#If func ASYRLIC.GET_CHPRODUCTSTDCODE="1" & left$(VERSION,1)="7" & filinfo(filpath("","sophia_gaillard",""),0)<=0
#If func ASYRLIC.GET_CHPRODUCTSTDCODE="1" & left$(VERSION,1)="7"
# 91605
#If find(func ASYRLIC.GET_CHPRODUCTSTDCODE,"1","3") & left$(VERSION,1)="7" : # licence controle for X3 and HRM V7
#105347
Local Char _PRODUCTSTDCODE(1) : [L]_PRODUCTSTDCODE=func ASYRLIC.GET_CHPRODUCTSTDCODE
#109731 control only for the product whatever the version
#If find([L]_PRODUCTSTDCODE,"1","3") & left$(VERSION,1)="7" : # licence controle for X3 and HRM V7 for V7
# End 1
#Elsif find([L]_PRODUCTSTDCODE,"1") & left$(VERSION,1)="8" : # licence controle for X3  for V8
# End 1

#119332 V11: control of license :add GEODE
If find([L]_PRODUCTSTDCODE,"1","2","3")>0
 End 1
Else
 End 0
Endif
End 0

###################################################
Subprog AFF_MES_LIC(FONCTION,BLOCK)
Value Char FONCTION
Value Integer BLOCK
If dim(GACTX)>0
 If fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
   #Call MESSAGE(mess(327,139,1)+"\"+FONCTION-":"-mess(328,139,1)) From GESECRAN
   #Call MESSAGE(mess(327,139,1)+"\"+FONCTION-":"-mess(329,139,1)) From GESECRAN
   If [L]BLOCK=[V]CST_ATRUE
   Call MESSAGE(mess(327,139,1)+"\"+FONCTION-":"-mess(333,139,1)) From GESECRAN
   Else
   Call MESSAGE(mess(327,139,1)+"\"+FONCTION-":"-mess(330,139,1)) From GESECRAN
   Endif
 Elsif fmet GACTX.AGETLICFCT(FONCTION)<>[V]CST_ATRUE
   #Call MESSAGE(FONCTION-":"-mess(329,139,1)+"\"+mess(328,139,1)) From GESECRAN
   #Call MESSAGE(FONCTION-":"-mess(329,139,1)) From GESECRAN
   If [L]BLOCK=[V]CST_ATRUE
   Call MESSAGE(FONCTION-":"-mess(333,139,1)) From GESECRAN
   Else
   Call MESSAGE(FONCTION-":"-mess(330,139,1)) From GESECRAN
   Endif
 Endif
Endif
End

