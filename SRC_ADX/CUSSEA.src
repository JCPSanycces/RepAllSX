#<AdxTL>@(#)0.0.0.0 $Revision$ 
####################################################################################
# Program Name: CUSSEA
# Description : Customer Search
# Author      : GRNA
####################################################################################

$ACTION

Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "AVANT_MEN"     : Gosub AVANT_BOUTON
    When "AVANT_BOUTON"  : Gosub AVANT_BOUTON
    When "BOUTON"        : Gosub BOUTON
    When "APRES_MODIF"   : Gosub APRES_MODIF
Endcase

Return

####################################################################################
$OUVRE

If !clalev([F:ADS])  : Local File ADOSSIER   [ADS]  : Endif
If !clalev([F:TCY])  : Local File TABCOUNTRY [TCY]  : Endif
If !clalev([F:BPD])  : Local File BPDLVCUST  [BPD]  : Endif

# Needed when coming back from GESBPC for New Cust
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif

# Needed to go to History
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif

Local Char BASE(1)
Read [ADS]DOSSIER=nomap
Case [F:ADS]TYPDBA
  When 1 : BASE = "3" # Oracle
  When 2 : BASE = "5" # Sql
  When 3 : BASE = "2" # Cisam
  When 4 : BASE = "4" # DB2
Endcase

Read [TCY]TCY0=GPAYS  # For address line headings

GBIDC2 = "" : Call FILROLE("BPC",GBIDC2) From SUBARL  # 90261

Return


####################################################################################
$DEBUT

Default Mask [CSE]

Gosub CLEAR
Affzo [M]10
Return

####################################################################################
$SETBOUT

# Buttons
If [M]SELECT=""                                # Nothing selected, disable all object buttons
    Call VIREBOUT(CHMEN,"EGRNX") From GOBJET   # Order,Quote,Return,Service,History
    If func SEACAT=""
        Call VIREBOUT(CHMEN,"2K") From GOBJET  # New Cust,Clear
    Endif
Elsif [M]SBPCUST=2                             # Customer selected, enable all object buttons
    If (GMODU(12)<>2 & GMODU(13)<>2) | GACTFTC<>2
        Call VIREBOUT(CHMEN,"X") From GOBJET   # History
    Endif
Else                                           # Prospect selected, only enable Quote & Service
    Call VIREBOUT(CHMEN,"ERX") From GOBJET     # Order,Return,History
Endif

# Prospect selected
If [M]SBPCUST=1
    Call VIREBOUT(CHMEN,"èB0C9V[]POQSU1%?µ") From GOBJET
Endif

# Inquiries
If GACTFTC<>2
    Call VIREBOUT(CHMEN,"Tè091[ABVC]") From GOBJET
Endif

#Support client
If GMODU(12)<>2 | GACTFTC<>2
    Call VIREBOUT(CHMEN,"ù%?µàç") From GOBJET
Endif

# Plan/Save
If GMODU(13)<>2 | GACTFTC<>2
    Call VIREBOUT(CHMEN,"}{~!)(£") From GOBJET
Endif

Return


####################################################################################
$AVANT_BOUTON

# Require ship-to for Sales Order, Quote, Return, Invoice
If find(BOUT,"E","G","R","1") & [M]SSHIPTO<>2 & [M]SBPCUST=2
    GMESSAGE = mess(300,192,1)
    GERR = 1 : Return
Endif

Case BOUT
  When "E" : GFONC1 = "GESSOH"  # Sales Orders
  When "G" : GFONC1 = "GESSQH"  # Quotes
  When "R" : GFONC1 = "GESSRH"  # Returns
  When "N" : GFONC1 = "GESMAC"  # Service
  When "1" : GFONC1 = "GESSIH"  # Invoices
Endcase

# New Customer
If find(BOUT,"2")
    GBCRMFLGNEW = 1
Endif

# Sales Order, Quote, Return, Service, Invoice
If find(BOUT,"E","G","R","N","1")
    GCREFONC = 1
Endif

# Plan Appt, Call, Task or
# Save Appt, Call, Task, Project
If GMODU(13)=2 & find(BOUT,"(",")","£","}","{","~","!")
    GBCRMFLGNEW = 1
Endif

Return


####################################################################################
$BOUTON

Case BOUT
  When "2"
    Gosub CLEAR
    [M]BPRNUM = [F:BPC]BPCNUM
    Gosub SEARCH
  When "E","G","R","N","1"
    Gosub CLEAR
    Raz GFONC1
    GBIDC2 = "" : Call FILROLE("BPC",GBIDC2) From SUBARL  # 101427
  When "K" : Gosub CLEAR
Endcase

GBCRMFLGNEW = 0  #121357.n - JOBRO - get customers out of "new" mode

Return

####################################################################################
$CLEAR
Effzo [M]
Actzo [M]5
Diszo [M]10-15
Actzo [M]SELROW  #Checkbox to allow selection of grid row in convergene client - 97299
Actzo [M]NBLIG  #Issue 118796.n
Return


####################################################################################
$APRES_MODIF

Case COUZON
  When "SELROW" #When "NBLIG" Issue 118796.n
    Call SELECT(nolign-1)
  When Default
    Assign "[M]" + COUZON With zc
    Gosub SEARCH
Endcase

Return


####################################################################################
$SEARCH

Effzo [M]10-15

# Exit if no search fields were entered
If func SEACAT="" : Return : Endif

Gosub SELECT_SEARCH

Append SQL_CLOB,func SET_REQ([M]BPRNUM,1)   # BP
Append SQL_CLOB,func SET_REQ([M]BPRNAM,2)   # Name
Append SQL_CLOB,func SET_REQ([M]TEL   ,3)   # Phone
Append SQL_CLOB,func SET_REQ([M]WEB   ,4)   # Email
Append SQL_CLOB,func SET_REQ([M]ADDLIG,5)   # Address
Append SQL_CLOB,func SET_REQ([M]CTY   ,6)   # City
Append SQL_CLOB,func SET_REQ([M]SAT   ,7)   # State
Append SQL_CLOB,func SET_REQ([M]POSCOD,8)   # Zip
Append SQL_CLOB,func SET_REQ([M]CNTNAM,9)   # Contact Name
Append SQL_CLOB,func SET_REQ([M]CNTTEL,10)  # Contact Phone
Append SQL_CLOB,func SET_REQ([M]CNTMOB,11)  # Contact Cell
Append SQL_CLOB,func SET_REQ([M]CNTWEB,12)  # Contact Email

Gosub FUZZY_SEARCH

Return


######################################################################################
$SELECT_SEARCH

Local Clbfile SQL_CLOB(5)

#SQL_CLOB  = "select BPRNUM_0,cast(BPCFLG_0 as varchar(1)),BPRNAM_0,BPRNAM_1,BPDNAM_0,BPDNAM_1,"
#Append SQL_CLOB," BPAADD_0,BPAADDLIG_0,BPAADDLIG_1,BPAADDLIG_2,CTY_0,SAT_0,POSCOD_0,TEL_0,WEB_0,"
#Append SQL_CLOB," CNTNUM_0,CNTFNA_0,CNTLNA_0,CCNTEL_0,CNTMOB_0,CNTEMA_0,CCNWEB_0"
#Append SQL_CLOB," from VCUSSEA where 1=1"

#102772.sn
SQL_CLOB  = "select BPRNUM_0,cast(BPCFLG_0 as varchar(1)),BPRNAM_0,BPRNAM_1,BPDNAM_0,BPDNAM_1,"
Append SQL_CLOB," BPAADD_0,BPAADDLIG_0,BPAADDLIG_1,BPAADDLIG_2,CTY_0,SAT_0,POSCOD_0,CRY_0,TEL_0,WEB_0,"
Append SQL_CLOB," CNTNUM_0,CNTFNA_0,CNTLNA_0,CNTCRY_0,CCNTEL_0,CNTMOB_0,CNTEMA_0,CCNWEB_0"
Append SQL_CLOB," from VCUSSEA where 1=1"
#102772.en


Return


######################################################################################
$FUZZY_SEARCH

Append SQL_CLOB,"order by BPRNUM_0,BPAADD_0"

# Entry Point to edit to SQL request
GPOINT="SQLREQ" : Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif

Local Char SQL_REQ(255)(20)
Setlob SQL_REQ With SQL_CLOB

Local Integer NOL

GBIDC2 = "" : Call FILROLE("BPC",GBIDC2) From SUBARL # 103532

If GBIDC2<>"" : Filter [BPC] Where evalue(GBIDC2) : Endif  # 90261

#For (Char RES(80)(22)) From BASE Sql SQL_REQ As [CONT] # 102772.o
For (Char RES(80)(24)) From BASE Sql SQL_REQ As [CONT]  # 102772.n

  # 90261
  If GBIDC2<>""
    Look [BPC]BPC0=RES(0)
    If fstat=5 : Goto NXT_RES : Endif
  Endif

    [M]DBPRNUM(NOL)  = RES(0)
    [M]DBPCUST(NOL)  = val(RES(1))
    [M]DBPCFLG(NOL)  = left$(mess(val(RES(1)),3043,1),1)  # 78372
    [M]DBPRNAM(NOL)  = RES(2)
    [M]DBPRNAM2(NOL) = RES(3)
    [M]DBPDNAM(NOL)  = RES(4)
    [M]DBPDNAM2(NOL) = RES(5)
    [M]DBPAADD(NOL)  = RES(6)
    [M]DADDLIG(NOL)  = RES(7)
    [M]DADDLIG2(NOL) = RES(8)
    [M]DADDLIG3(NOL) = RES(9)
    [M]DCTY(NOL)     = RES(10)
    [M]DSAT(NOL)     = RES(11)
#    [M]DPOSCOD(NOL)  = RES(12)
#    [M]DTEL(NOL)     = RES(13)
#    [M]DWEB(NOL)     = RES(14)
#    [M]DCNTNUM(NOL)  = RES(15)
#    [M]DCNTNAM(NOL)  = RES(16)-RES(17)
#    [M]DCNTTEL(NOL)  = RES(18)
#    [M]DCNTMOB(NOL)  = RES(19)
#    [M]DCNTWEB(NOL)  = RES(20)
#    If [M]DCNTWEB(NOL)=""
#        [M]DCNTWEB(NOL) = RES(21)
#    Endif
   #102772.sn
    [M]DPOSCOD(NOL)  = RES(12)
    [M]DCRY(NOL)     = RES(13) #102772.n
    [M]DTEL(NOL)     = RES(14)
    [M]DWEB(NOL)     = RES(15)
    [M]DCNTNUM(NOL)  = RES(16)
    [M]DCNTNAM(NOL)  = RES(17)-RES(18)
    [M]DCNTCRY(NOL)  = RES(19) #102772.n
    [M]DCNTTEL(NOL)  = RES(20)
    [M]DCNTMOB(NOL)  = RES(21)
    [M]DCNTWEB(NOL)  = RES(22)
    If [M]DCNTWEB(NOL)=""
        [M]DCNTWEB(NOL) = RES(23)
    Endif
   #102772.en


    NOL += 1
    If NOL=dim([M]DBPRNUM) : Break : Endif
$NXT_RES
Next

Filter [BPC]  # 90261

[M]NBLIG = NOL

Affzo [M]10

Return


####################################################################################
# FLDVAL = input value
# FLDTYP = enumerated field type
#   1 - Cust Num
#   2 - Name
#   3 - Phone
#   4 - Email
#   5 - Address
#   6 - City
#   7 - State
#   8 - Zip
#   9 - Contact Name
#  10 - Contact Phone
#  11 - Contact Cell
#  12 - Contact Email
######################################################################################
Funprog SET_REQ(FLDVAL,FLDTYP)
Value    Char    FLDVAL
Value    Integer FLDTYP

If FLDVAL="" : End "" : Endif

Local Clbfile OREQ : OREQ = " and ("


#102772.sn  107088.so
#Case FLDTYP
#  When 1  : Append OREQ,func SET_NUM(FLDVAL)
#  When 2  : Append OREQ,func SET_NAME(FLDVAL)
#  When 3  : Append OREQ,func SET_PHONE(FLDVAL)
#  When 4  : Append OREQ,func SET_EMAIL(FLDVAL)
#  When 5  : Append OREQ,func SET_ADDR(FLDVAL)
#  When 6  : Append OREQ,func SET_CITY(FLDVAL)
#  When 7  : Append OREQ,func SET_STATE(FLDVAL)
#  When 8  : Append OREQ,func SET_ZIP(FLDVAL)
#  When 9  : Append OREQ,func SET_CRY(FLDVAL) # 102772.n
#  When 10  : Append OREQ,func SET_CNT_NAME(FLDVAL)
#  When 11 : Append OREQ,func SET_CNT_PHONE(FLDVAL)
#  When 12 : Append OREQ,func SET_CNT_CELL(FLDVAL)
#  When 13 : Append OREQ,func SET_CNT_EMAIL(FLDVAL)
#Endcase
#102772.en  107088.eo


#  107088.N
 #When 9  : Append OREQ,func SET_CRY(FLDVAL) # 102772.n
Case FLDTYP
  When 1  : Append OREQ,func SET_NUM(FLDVAL)
  When 2  : Append OREQ,func SET_NAME(FLDVAL)
  When 3  : Append OREQ,func SET_PHONE(FLDVAL)
  When 4  : Append OREQ,func SET_EMAIL(FLDVAL)
  When 5  : Append OREQ,func SET_ADDR(FLDVAL)
  When 6  : Append OREQ,func SET_CITY(FLDVAL)
  When 7  : Append OREQ,func SET_STATE(FLDVAL)
  When 8  : Append OREQ,func SET_ZIP(FLDVAL)
  When 9  : Append OREQ,func SET_CNT_NAME(FLDVAL)
  When 10 : Append OREQ,func SET_CNT_PHONE(FLDVAL)
  When 11 : Append OREQ,func SET_CNT_CELL(FLDVAL)
  When 12 : Append OREQ,func SET_CNT_EMAIL(FLDVAL)
Endcase

Append OREQ,")"

End OREQ


######################################################################################
# Name - search customer number
######################################################################################
Funprog SET_NUM(NUM)
Value    Char    NUM
End func FUZZIFY("BPRNUM_0",NUM,0)


######################################################################################
# Name - search customer name, both ship-to names
######################################################################################
Funprog SET_NAME(NAME)
Value    Char    NAME

Local Clbfile OREQ
Append OREQ,func FUZZIFY("BPRNAMU_0",NAME,3)
Append OREQ,"or" - func FUZZIFY("BPRNAMU_1",NAME,3)
Append OREQ,"or" - func FUZZIFY("BPDNAMU_0",NAME,3)
Append OREQ,"or" - func FUZZIFY("BPDNAMU_1",NAME,3)

End OREQ


######################################################################################
# Phone - search customer phone
######################################################################################
Funprog SET_PHONE(PHONE)
Value    Char    PHONE

Local Clbfile OREQ
Append OREQ,func FUZZIFY("TELU_0",PHONE,3)
Append OREQ,"or" - func FUZZIFY("TELU_1",PHONE,3)
Append OREQ,"or" - func FUZZIFY("TELU_2",PHONE,3)
Append OREQ,"or" - func FUZZIFY("TELU_3",PHONE,3)
Append OREQ,"or" - func FUZZIFY("TELU_4",PHONE,3)

End OREQ


######################################################################################
# Email - search customer email
######################################################################################
Funprog SET_EMAIL(EMAIL)
Value    Char    EMAIL

Local Clbfile OREQ
Append OREQ,func FUZZIFY("WEBU_0",EMAIL,3)
Append OREQ,"or" - func FUZZIFY("WEBU_1",EMAIL,3)
Append OREQ,"or" - func FUZZIFY("WEBU_2",EMAIL,3)
Append OREQ,"or" - func FUZZIFY("WEBU_3",EMAIL,3)
Append OREQ,"or" - func FUZZIFY("WEBU_4",EMAIL,3)

End OREQ


######################################################################################
# Address - search all 3 address lines
######################################################################################
Funprog SET_ADDR(ADDR)
Value    Char    ADDR

Local Clbfile OREQ
Append OREQ,func FUZZIFY("BPAADDLGU_0",ADDR,3)
Append OREQ,"or" - func FUZZIFY("BPAADDLGU_1",ADDR,3)
Append OREQ,"or" - func FUZZIFY("BPAADDLGU_2",ADDR,3)

End OREQ


######################################################################################
# City - search city
######################################################################################
Funprog SET_CITY(CITY)
Value    Char    CITY
End func FUZZIFY("CTYU_0",CITY,3)


######################################################################################
# State - search state
######################################################################################
Funprog SET_STATE(STATE)
Value    Char    STATE
End func FUZZIFY("SATU_0",STATE,2)


######################################################################################
# Zip - search postal code
######################################################################################
Funprog SET_ZIP(ZIP)
Value    Char    ZIP
End func FUZZIFY("POSCODU_0",ZIP,2)

#102772.sn
######################################################################################
# Country - search country
######################################################################################
Funprog SET_CRY(CRY)
Value    Char    CRY
#End func FUZZIFY("CTYU_0",CRY,3)
End func FUZZIFY("CRYU_0",CRY,3)
#102772.en


######################################################################################
# Contact Name - search contact name
######################################################################################
Funprog SET_CNT_NAME(NAME)
Value    Char    NAME
End func FUZZIFY("CNTFULNAM_0",NAME,3)


######################################################################################
# Contact Phone - search contact phone
######################################################################################
Funprog SET_CNT_PHONE(PHONE)
Value    Char    PHONE
End func FUZZIFY("CCNTELU_0",PHONE,3)


######################################################################################
# Phone - search contact cell
######################################################################################
Funprog SET_CNT_CELL(CELL)
Value    Char    CELL
End func FUZZIFY("CNTMOBU_0",CELL,3)


######################################################################################
# Email - search both contact emails
######################################################################################
Funprog SET_CNT_EMAIL(EMAIL)
Value    Char    EMAIL

Local Clbfile OREQ
Append OREQ,func FUZZIFY("CNTEMAU_0",EMAIL,3)
Append OREQ,"or" - func FUZZIFY("CCNWEBU_0",EMAIL,3)

End OREQ


####################################################################################
# COLUMN = column name
# COLVAL = input value
# FUZZY  = whether or not to do a fuzzy search
#   0 - no fuzzy search (Customer #)
#   1 - fuzzy left only (not currently used)
#   2 - fuzzy right only (State and ZIP)
#   3 - fuzzy on both sides
######################################################################################
Funprog FUZZIFY(COLUMN,COLVAL,FUZZY)
Value    Char    COLUMN
Value    Char    COLVAL
Value    Integer FUZZY

Local Char STR(250)
STR = COLUMN - "like upper('"
If find(FUZZY,1,3) : STR += "%" : Endif
STR += func ENCODE_STR(COLVAL)
If find(FUZZY,2,3) : STR += "%" : Endif
STR += "')"

End STR


####################################################################################
# Replaces quote characters (') with two quote characters so that the
# string may be used in a query as a literal
####################################################################################
Funprog ENCODE_STR(STR)
Value Char STR

Local Char RES(250)

STR = vireblc(STR,5)         # remove consecutive spaces

For J=1 To len(STR)
    If mid$(STR,J,1)="'"
        RES += "''"
    Elsif mid$(STR,J,1)=" "  # replace space
        RES += "%"           # with wildcard
    Else
        RES += mid$(STR,J,1)
    Endif
Next

End RES


####################################################################################
# Concatenate search fields
####################################################################################
Funprog SEACAT

Local Char CAT

CAT += [M]BPRNUM
CAT += [M]BPRNAM
CAT += [M]TEL
CAT += [M]WEB
CAT += [M]ADDLIG
CAT += [M]CTY
CAT += [M]SAT
CAT += [M]POSCOD
CAT += [M]CNTNAM
CAT += [M]CNTTEL
CAT += [M]CNTMOB
CAT += [M]CNTWEB

# Entry Point in case fields were added to the screen
GPOINT="SEACAT" : Gosub ENTREE From EXEFNC

End CAT


####################################################################################
Subprog SELECT(NOL)
Value Integer NOL

#97299 - Uncheck all other rows so that this is the only row selected
Raz [M]SELROW
#[M]SELROW(NOL) = 1 #Issue 118796.o
[M]SELROW(NOL) = 2 #Issue 118796.n
Affzo [M]SELROW

[M]SELECT  = [M]DBPRNUM(NOL)
[M]SBPAADD = [M]DBPAADD(NOL)
[M]SBPDNAM = [M]DBPDNAM(NOL)
[M]SCNTNAM = [M]DCNTNAM(NOL)
[M]SBPCUST = [M]DBPCUST(NOL)

[M]SSHIPTO = 1
Look [BPD]BPD0=[M]SELECT;[M]SBPAADD
If !fstat
    [M]SSHIPTO = 2
Endif

Read [BPC]BPC0=[M]SELECT  # 91542 - make sure correct record in BPC buffer

Affzo [M]15

End


######################################################################################
Subprog IB_NBLIG

If [M]DBPCUST(nolign-1)=2    # Customer Flag
    Raz GBOUT2               # Remove 'Prospect'
Else
    Raz GBOUT1               # Remove 'Customer'
Endif

End


######################################################################################
Subprog IB_BPRNUM

# Hide "Quick customer search"
Raz GBOUT11

End
######################################################################################

