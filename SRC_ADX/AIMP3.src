#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char    TBPAR(20)(1..10) , TBVAL(20)(1..10)
Local Integer NBPAR
Local Char    PARPLAG(20)(0..10) , VALPLAG1(20)(0..10) , VALPLAG2(20)(0..10)
Local Integer BORPLAG(0..10)
Local Integer NBPLAG
GTEST = 1
NBPAR = 0
NBPAR += 1 : TBPAR(NBPAR) = "pays"    : TBVAL(NBPAR) = "FR"
#NBPAR += 1 : TBPAR(NBPAR) = "pays"    : TBVAL(NBPAR) = "DE"
PARPLAG(NBPLAG) = "pays"    : VALPLAG1(NBPLAG) = "FR" : VALPLAG2(NBPLAG) = "FR" : BORPLAG(NBPLAG) = 1 : NBPLAG += 1
PARPLAG(NBPLAG) = "pays"    : VALPLAG1(NBPLAG) = "G" : VALPLAG2(NBPLAG) = "H"   : BORPLAG(NBPLAG) = 2 : NBPLAG += 1
PARPLAG(NBPLAG) = "pays"    : VALPLAG1(NBPLAG) = "IT" : VALPLAG2(NBPLAG) = "IT" : BORPLAG(NBPLAG) = 1 : NBPLAG += 1
PARPLAG(NBPLAG) = "pays"    : VALPLAG1(NBPLAG) = "J"   : VALPLAG2(NBPLAG) = "K" : BORPLAG(NBPLAG) = 2 : NBPLAG += 1
Call OUVRE_TRACE("") From LECFIC
#Call ETAT_PLAG("TABCOUNTRY_PLAG","PREVISU","FRA",1,"MON commentaire",TBPAR,TBVAL,PARPLAG,VALPLAG1,VALPLAG2)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
GTEST=0
End

#-------------------------------------------------------------------------------------------#
# Impression d'un état avec lien sur file d'attente
#-------------------------------------------------------------------------------------------#

Subprog ETATJOB(WETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL,DIFF,IMPDAT,IMPTIM,NOJOB)
Value    Char    WETAT
Value    Char    IMPRIMANTE
Value    Char    LANGUE
Value    Integer TRACE
Value    Char    MSGIMP
Value    Char    TBPAR()(1..)
Value    Char    TBVAL()(1..)
Value    Integer DIFF
Value    Date    IMPDAT
Value    Char    IMPTIM
Variable Char    NOJOB

Local Integer NBPLAG
Goto IMPSIL

#-------------------------------------------------------------------------------------------#
# Impression "silencieuse" d'un état
#-------------------------------------------------------------------------------------------#

Subprog ETAT(WETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL)
Value    Char    WETAT
Value    Char    IMPRIMANTE
Value    Char    LANGUE
Value    Integer TRACE
Value    Char    MSGIMP
Value    Char    TBPAR()(1..)
Value    Char    TBVAL()(1..)

Local Integer DIFF,NBPLAG
Local Char    NOJOB(10)
DIFF = 0
Goto IMPSIL

#-------------------------------------------------------------------------------------------#
# Impression "silencieuse" d'un état avec saisi de plage
#-------------------------------------------------------------------------------------------#

Subprog ETAT_PLAG(WETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL,PARPLAG,VALPLAG1,VALPLAG2)
Value    Char    WETAT
Value    Char    IMPRIMANTE
Value    Char    LANGUE
Value    Integer TRACE
Value    Char    MSGIMP
Value    Char    TBPAR()(1..)
Value    Char    TBVAL()(1..)
Value    Char    PARPLAG()(0..)
Value    Char    VALPLAG1()(0..)
Value    Char    VALPLAG2()(0..)

Local Integer DIFF
Local Char    NOJOB(10)
DIFF = 0

Goto IMPSIL

#-------------------------------------------------------------------------------------------#
# Impression "silencieuse" d'un état en différé
#-------------------------------------------------------------------------------------------#

Subprog ETATDIFF(WETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL,IMPDAT,IMPTIM)
Value    Char    WETAT
Value    Char    IMPRIMANTE
Value    Char    LANGUE
Value    Integer TRACE
Value    Char    MSGIMP
Value    Char    TBPAR()(1..)
Value    Char    TBVAL()(1..)
Value    Date    IMPDAT
Value    Char    IMPTIM

Local Integer DIFF,NBPLAG
Local Char    NOJOB(10)
DIFF = 1

$IMPSIL
Local Char COMPLEMENT(10)
Gosub DECLARE From AIMP1
Gosub OUVRE From AIMP1
ETAT = WETAT
Call CONT_RPTCOD(ETAT,GMESSAGE,STAT) From AIMP1
mkstat = STAT
If mkstat
 ER = 1 : Goto FIN_ETAT
Endif
For I=1 To min(dim([M:AIP]TBPAR),dim(TBPAR))
 [M:AIP]TBPAR(I-1) = TBPAR(I)
 [M:AIP]TBVAL(I-1) = TBVAL(I)
Next I
If dim([L]PARPLAG)>0
 For I=0 To dim([L]PARPLAG)
  If [L]PARPLAG(I) = "" : Break : Endif
  [M]PARPLAG(I)  = [L]PARPLAG(I)
  [M]VALPLAG1(I) = [L]VALPLAG1(I)
  [M]VALPLAG2(I) = [L]VALPLAG2(I)
  If [M]VALPLAG1(I) = [M]VALPLAG2(I) & [M]VALPLAG2(I) <> ""
   [M]BORPLAG(I)  = 1
  Else
   [M]BORPLAG(I)  = 2
  Endif
 Next I
 [M]NBPLAG = I
Endif
Call CHANGE_RPTCOD(ETAT,GFONCTION) From AIMP1
Call COMPLEMENT(COMPLEMENT) From AIMP1
Call SETIMP(ETAT,GUSER,COMPLEMENT,IMPRIMANTE) From IMPRIME
[M]PRT = IMPRIMANTE
Call AIMCONT(IMPRIMANTE,ETAT,([M]BATCH<>0) or ([M]DIFFERE=2)) From IMPRIME
If mkstat
 ER = 1 : Goto FIN_ETAT
Endif
[M]IMPRIME    = [F:AIM]PRT
[M]SERVEUR    = [F:AIM]PRTSRV
[M]IMPRIMANTE = [F:AIM]PRTNAM
[M]PRTPOR     = [F:AIM]PRTPOR
[M]PRTDRV     = [F:AIM]PRTDRV
Raz [M]PRTDES
For [AID]AID0 Where COD=[F:AIM]COD
 [M]PRTDES([F:AID]NUM-1)  = [F:AID]PRTDES
 [M]PRTDESEX([F:AID]NUM-1)  = [F:AID]PRTDESEX
Next
If find([M]IMPRIME,2)
 [M]NBRCPY    = [F:AIM]NBRCPY
 [M]ASSCPY    = [F:AIM]ASSCPY
Elsif find([M]IMPRIME,6)
 [M]NBRCPY    = [F:AIM]NBRCPY
Endif
If find([M]IMPRIME,3,4) or ([M]IMPRIME=1 and GBROWS<>0)
 [M]FMTFIC    = [F:AIM]PRTFMT
Endif

# Issue X3-97495 - 2018-06-28 by CCC : use orientation defined on each report
#[M]PRTORIENT     = [F:ARP]ORIENT
[M]PRTORIENT = 0

If DIFF
 [M]DIFFERE = 2
 If IMPDAT=[0/0/0]
  IMPDAT = date$
 Endif
 If IMPTIM=""
  IMPTIM = left$(time$,2)+mid$(time$,4,2)
 Endif
 [M]DIFDAT  = IMPDAT
 [M]DIFTIM  = IMPTIM
Else
 [M]DIFFERE = 1
Endif
[M]LANGUE = LANGUE
Call IMPRIME([M]RPTCOD,[M]LANGUE,[M]NBRPAR,[M]PARCOD,[M]TYP,[M]PARTYP,[M]NOLIB
&           ,[M]DEBFIN,[M]VALINT1,[M]VALINT2,[M]DIFFERE
&           ,[M]IMPRIME,[M]SERVEUR,[M]IMPRIMANTE,[M]PRTPOR,[M]PRTDRV
&           ,[M]PRTDES,[M]NBRCPY,[M]ASSCPY,[M]PAGDEB,[M]PAGFIN,[M]FICHIER,[M]FMTFIC
&           ,[M]NBSEG,[M]VALSEG,[M]DIFDAT,[M]DIFTIM,[M]DIFSRVC,[M]FORPAP
&           ,[M:AIP]TBPAR,[M:AIP]TBVAL,[M]MESSAGE,[M]NBPLAG,[M]PARPLAG,[M]BORPLAG,[M]VALPLAG1,[M]VALPLAG2,NOJOB,ER)
& From AIMP3

$FIN_ETAT
If TRACE
 If !ER
  Call EDTMSG(ETAT,IMPRIMANTE,MSGIMP) From ETAT
 Elsif GOK=1
  Call ECR_TRACE(ETAT-MSGIMP-IMPRIMANTE-":"-GMESSAGE,1) From GESECRAN
 Endif
Endif
End

#-------------------------------------------------------------------------------------------#
# Impression d'un état
#-------------------------------------------------------------------------------------------#

Subprog IMPRIME(ETAT,LANGUE,NBRPAR,PARCOD,TYP,PARTYP,PARLIB
&              ,DEBFIN,VALEUR1,VALEUR2,DIFFERE
&              ,DESTINATION,SERVEUR1,IMPRIMANTE,PRTPOR,PRTDRV
&              ,PRTDES,NBRCPY,ASSCPY,PAGDEB,PAGFIN,FICHIER,FMTFIC
&              ,NBSEG,VALSEG,DIFDAT,DIFTIM,DIFSRVC,FORPAP
&              ,TBPAR,TBVAL,PARMES,NBPLAG,PARPLAG,BORPLAG,VALPLAG1,VALPLAG2,RETOUR,ER)
Value    Char    ETAT
Value    Char    LANGUE
Value    Integer NBRPAR
Value    Char    PARCOD()(0..)
Value    Integer TYP(0..)
Value    Char    PARTYP()(0..)
Value    Integer PARLIB(0..)

Value    Integer DEBFIN(0..)
Value    Char    VALEUR1()(0..)
Value    Char    VALEUR2()(0..)
Value    Integer DIFFERE

Value    Integer DESTINATION
Value    Char    SERVEUR1
Value    Char    IMPRIMANTE
Value    Char    PRTPOR
Value    Char    PRTDRV

Value    Char    PRTDES()(0..)
Value    Integer NBRCPY
Value    Integer ASSCPY
Value    Integer PAGDEB
Value    Integer PAGFIN
Value    Char    FICHIER
Value    Integer FMTFIC

Value    Integer NBSEG
Value    Char    VALSEG()(0..)
Value    Date    DIFDAT
Value    Char    DIFTIM
Value    Char    DIFSRVC
Value    Integer FORPAP

Variable Char    TBPAR()(1..)
Variable Char    TBVAL()(1..)
Variable Char    PARMES()(1..)
Value    Integer NBPLAG
Value    Char    PARPLAG()(0..)
Value    Integer BORPLAG(0..)
Value    Char    VALPLAG1()(0..)
Value    Char    VALPLAG2()(0..)
Variable Char    RETOUR
Variable Integer ER
$SUBPROG_IMPRIME
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:ARD])=0 : Local File AREPORTD [ARD] : Endif
If clalev([F:ARO])=0 : Local File AREPORTS [ARO] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT  [AFT] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
If clalev([F:AES])=0 : Local File AESPION  [AES] : Endif

Local Char    SOCDEB(GLONCPY) , SOCFIN(GLONCPY) , FCT(GLONAFC)
Local Char    SITDEB(GLONFCY) , SITFIN(GLONFCY) , SITINT(250)
Local Integer I , J , K , L , M , P , J1 , II , I1, I2 , JJ , PS
#SAM 108578
Local Integer R , R1 , R2 , R3 , R4 , R5 , R6 , R7 , R8 , R9 , R10 , R11 , RSI, R12, R13
Local Integer OKSOC , NBOK , OK , OKB , OKSTD , ER , TRA , OKTRT , MULT , OKMES
Local Integer ILEN , IPOS , IPAR
Local Date    DAT
Local Char    BASE(20) , USER(20) , PASSE(20) , TABDAT(20) , TABIDX(20)
Local Char    DOSSIER(20), SERVEUR(250)
Local Integer NBPAR,NBPARSI
Local Char    PARAMETRE(250)(1..250) , PARAMSI(250)(1..50)
Local Char    CLISERV(80)
Local Char    PARAM(250) , VALEUR(250) , TEXTE(250) , CHAINE(250)
Local Integer NUMREQ , TYPT , TYPDBA , NOLIB
Local Char    FICSEG(GDIMFIC) , FICBAS(GDIMFIC)
Local Char    RPTLAN(GLONLAN) , RPTNAM(GLONACR)
Local Char    MACHINE(GDIMFIC) , REPETA(GDIMFIC) , FILETA(GDIMFIC) , TMPDIR(250)
Local Char    SOLUTION(30) , SOLDOS(30) , SOLPSE(30)
Local Char    SOLBASE(20) , SOLUSER(20) , SOLPASSE(20) , SOLTABDAT(20) , SOLTABIDX(20)
Local Char    TABTRI(250)(0..250)
Local Char    VALSEGDEB(250),VALSEGFIN(250)
Local Char    JOBID(250) , MESSAGE(250) , FICJOB(GDIMFIC) , EXT(5) , REP(30)
Local Integer NBJOBID , STAT , MAXBOUC , NBRBOUC , SLEBOUC
Local Integer LANSTD
Local Char    REPLI(GLONLAN)
Local Char    CRITSOC(250)(1..3),CRITSIT(250)(1..3),WCRIT(250)
Local Integer ICRITSOC,ICRITSIT
Local Char    SAVACT(20) , PARPAR(250)(1..20) , PARVAL(250)
Local Integer DOCWEB
Local Char    RPTDEV(4+GLONACR+GLONLAN+GLONAUS+GLONADS+type(GINSTID)-10)
Local Char    SAV_WJOBID(250)                           # 120674 - segmentation in report
Local Integer SAV_PARAM_IDX,SAV_PARAMSI_IDX             # 120674 - segmentation in report
# Issue X3-48208 - 2017-11-02 by CCC
Local Char    DATEFIN(10)        # temporary date in char
Local Integer TYPPARSEG          # type of parameter used for segmentation

If 1=0
 For I=0 To NBRPAR-1
  Call ECR_TRACE("parcod("+num$(I)+")="+PARCOD(I)-"typ="+num$(DEBFIN(I))-"valeur1="+num$(VALEUR1(I))+"valeur2="+num$(VALEUR2(I)),0)
& From GESECRAN
 Next I
Endif

# Prévisu d'une pièce jointe en web
DOCWEB = 0
If GBROWS & DESTINATION=1
 For I=0 To NBRPAR-1
  If tolower(PARCOD(I))="docjoin"
   DOCWEB = 1 : Break
  Endif
 Next I
 If !K
  For [ARD]ARD0 Where RPTCOD=ETAT & tolower(PARCOD)="docjoin"
   DOCWEB = 1 : Break
  Next ARD
 Endif
Endif

# Envoi état en pièce jointe par le workflow
Gosub SET_MEL From AIMP1

# Print Engine sur le client
Gosub SET_CRPE From AIMP1

If !DOCWEB
 SERVEUR = SERVEUR1
Else
 SERVEUR = ""
Endif
If GBROWS<>0 and SERVEUR="" and !DOCWEB
 Local Integer OKI
 Call IMPSERVD(SERVEUR,OKI) From ASELSIMP
 If OKI=0
  GMESSAGE = mess(102,150,1) : # Pas de serveur d'impression disponible pour l'application courante
  ER = 1 : End
 Endif
Elsif GSERVEUR<>0 and SERVEUR="" and DESTINATION<>1
 Call IMPSERVB(IMPRIMANTE,SERVEUR) From ASELSIMP
 If SERVEUR=""
  GMESSAGE = mess(13,135,1) : # Serveur non défini
  ER = 1 : End
 Endif
Endif

# Test présence du serveur d'impression (dem 64375)
If SERVEUR<>"" : # SERVEUR<>"sodbo02.sagefr.adinternal.com:1890"
 SAVACT = GACTION : GACTION = "CONTSERV"
 PARPAR(1) = num$([L]DESTINATION)
 PARVAL = SERVEUR
 Raz mkstat
 Call S_AFF_CHAR(PARVAL,PARPAR,"CONTSERV","ASELSIMP","") From GACTION
 GACTION = SAVACT
 If mkstat : ER = 1 : End : Endif
Endif

# Cas du requêteur en mode serveur d'impression

If SERVEUR<>"" and left$([F:ARP]CRYCOD(0),3)="RQT"
 ETAT = "ALISTE"
Endif

Call LECTURE("ARP",ETAT,"") From CONTOBJ
Read [ARO]ARO0 = ETAT
If fstat : Raz [F:ARO] : Endif

If LANGUE=""
 LANGUE = GLANGUE
Endif
If [F:ARP]MULLAN=2
 Call STDREPLI(LANGUE,LANSTD,REPLI) From SUBTLA
 If LANSTD<>2 and LANGUE<>[F:ARP]LAN and REPLI<>""
  LANGUE = REPLI
 Endif
Endif

If ETAT = "ALISTE"
 If GPRODUIT=1 : ## GEODE
  [F:ARP]CRYCOD(0) = "ALISTENV"
 Else
  [F:ARP]CRYCOD(0) = "ALISTE"
 Endif
Endif

## Autorisations par sites

Call LECTURE("AUS",GUSER,"") From CONTOBJ
Call LECTURE("AFT",GPROFIL,"") From CONTOBJ

If [F:ARP]AUZFCY<>2
 FCT = ""
 SITINT = ""
Else
 If dim([F:ARP]FNC)>0 & [F:ARP]FNC<>""
  FCT = [F:ARP]FNC
 Else
  FCT = "RPT"+format$("N0:##",[F:ARP]GRP)
 Endif
 OKSOC = 0
 If [F:AFT]ALLFCT<>2
  Gosub EVALCRITSOC
 Endif
 If OKSOC
  If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
  If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
  If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
  If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
  If sum(CRITSOC)=""
   Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'(CPY>="" & CPY<="z")',"&") From GOBJSUB
  Endif
  If sum(CRITSIT)=""
   Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'(FCY>="" & FCY<="z")',"&") From GOBJSUB
  Endif
  NBOK = 0
  SITINT = ""
  Call LECTURE("AFC",FCT,"") From CONTOBJ
  If [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
   Read [AFP]AFP0 = GPROFIL ; FCT ; ""
   If !fstat & [F:AFP]ACS=2
    NBOK = 1
   Else
    NBOK = -1
   Endif
  Else
   For [FGR]FGR0 Where evalue("("+CRITSOC+")")  & evalue("("+CRITSIT+")")
    Read [AFF]AFF0 = [F:FGR]FCY;GPROFIL;FCT
    If fstat
     If SITINT = ""
      SITINT = " "+[F:FGR]FCY+" "
     Elsif !instr(1,SITINT," "+[F:FGR]FCY+" ")
      SITINT += [F:FGR]FCY+" "
     Endif
    Else
     NBOK += 1
    Endif
   Next FGR
   SITINT = vireblc(SITINT,2)
  Endif
  If NBOK=0
   If SOCDEB=SOCFIN & SITDEB="" & SITFIN="z"
    GMESSAGE = mess(25,135,1)-SOCDEB : # Vous n'avez pas les droits sur la société
   Else
    GMESSAGE = mess(26,135,1) : # Vous n'avez pas les droits sur cet ensemble de sites
   Endif
   ER = 1
   End
  Elsif NBOK=-1
   GMESSAGE = mess(35,139,1) : # Accès non autorisé par cette fonction
   ER = 1
   End
  Elsif SITINT<>""
   OK = 2 : Call AVERTIR(mess(27,135,1)+"\"+SITINT,OK) From GESECRAN
   # Attention vous n'avez pas les droits sur les sites
   If OK<>2 : ER = 1 : End : Endif
  Endif
 Endif
Endif

# Pas de pré-visu en batch

If DIFFERE=2 or GSERVEUR
 If DESTINATION=1
  GMESSAGE = mess(12,135,1) : # Pas de prévisualisation en batch
  ER = 1 : End
 Endif
 If SERVEUR=""
  GMESSAGE = mess(13,135,1) : # Serveur non défini
  ER = 1 : End
 Endif
Endif
GPE = 0
GPOINT = "IMPRIME" : Gosub ENTREE From EXEFNC

# Il faut renseigner un serveur d'impression:
# - prévisu, si le print engine n'existe pas sur le poste client
# - message, si on utilise le workflow
# - Imprimante ZEBRA

If SERVEUR=""
 If (DESTINATION=3 & MELWRK) or !CRPE or (DESTINATION=1 & GBROWS & !DOCWEB) or DESTINATION=7
  GMESSAGE = mess(13,135,1) : # Serveur d'impression non défini
  ER = 1 : End
 Endif
Endif

# Pas de différé en batch

If GSERVEUR
 DIFFERE = 1
Endif

# Initialisations diverses

Call PASSE(nomap,BASE,USER,PASSE,TABDAT,TABIDX) From ORAPASSE
NUMREQ = uniqid([AES])

Read [ADW]ADW0 = "";"";"TYPDBA"
TYPDBA = val([F:ADW]VALEUR)

# Destination

Raz NBPAR , OKMES
Case DESTINATION
 When 1   :                                                           # Prévisu
 When 2,6 : Gosub IMPRIMANTE                                        : # Imprimante , Imprimante ZPL
 When 3   : OKMES = 1 : Gosub MESSAGERIE : If OKMES=0 : End : Endif : # Messagerie
 When 4,7 : Gosub FICHIER                                           : # Fichier , Archive
Endcase

If DESTINATION=1 and SERVEUR<>""
 If (FMTFIC=0 or FMTFIC=1) and GBROWS : FMTFIC = 29 : Endif : # Pdf       Attention erreur corrigée le 21/04/2010  CC
 If FMTFIC=0 & !GBROWS : FMTFIC = 29 : Endif
 Gosub FORMATFIC
Endif

# Paramètres digérés par X3

TYPT = 7
If [F:ARP]CRYCOD(0)<>""
 PARAM = "__REPORT"        : VALEUR = [F:ARP]CRYCOD(0)+".rpt" : Gosub ECRIT
Endif
If DESTINATION=6
 If IMPRIMANTE<>""
  PARAM = "__DESTINATION"  : VALEUR = "1"                     : Gosub ECRIT
 Else
  PARAM = "__DESTINATION"  : VALEUR = "3"                     : Gosub ECRIT
 Endif
Endif
If (DESTINATION=3 & SERVEUR<>"" & MELWRK)
 PARAM = "__DESTINATION"   : VALEUR = "3"                     : Gosub ECRIT
Elsif DESTINATION=5
 PARAM = "__DESTINATION"   : VALEUR = "1"                     : Gosub ECRIT
Elsif DESTINATION=7
 PARAM = "__DESTINATION"   : VALEUR = "3"                     : Gosub ECRIT
Else
 PARAM = "__DESTINATION"
 VALEUR = num$(DESTINATION-1)
 If GBROWS and VALEUR="0" & !DOCWEB : VALEUR="3" : Endif      : Gosub ECRIT
Endif
PARAM = "__TYPDBA"         : VALEUR = num$(TYPDBA)            : Gosub ECRIT
If TYPDBA=4
 PARAM = "__DBDATABASE"    : VALEUR = nomap                   : Gosub ECRIT
 PARAM = "__DBUSER"        : VALEUR = ""                      : Gosub ECRIT
 PARAM = "__DBPASSWORD"    : VALEUR = ""                      : Gosub ECRIT
Else
 PARAM = "__DBDATABASE"    : VALEUR = BASE                    : Gosub ECRIT
 PARAM = "__DBUSER"        : VALEUR = USER                    : Gosub ECRIT
 PARAM = "__DBPASSWORD"    : VALEUR = PASSE                   : Gosub ECRIT
Endif

# ----  Paramètre serveur d'impression en mode "Print Engine CR" non installé sur le poste client

If SERVEUR<>"" & DESTINATION=1 & !GBROWS
 If GRELCLI>="15c.011"
  VALEUR = SERVEUR
  If right$(SERVEUR,len(SERVEUR))="@"
   VALEUR = left$(SERVEUR,len(SERVEUR)-1)
  Endif
  PARAM = "+X3IMP" : Gosub ECRIT
 Endif
Endif

# ----  Paramètre serveur d'impression en mode Web

If GBROWS & SERVEUR<>""
  VALEUR=SERVEUR
  If right$(SERVEUR,len(SERVEUR))="@"
    VALEUR= left$(SERVEUR,len(SERVEUR)-1)
  Endif
  PARAM = "+X3IMP"  : Gosub ECRIT
  Gosub ECRITSI
Endif

# Initialisation du JOBID dans le cas d'une impression fichier

NBJOBID = 0
If (DESTINATION=3 & SERVEUR<>"" & MELWRK) or DESTINATION=7 : # Message/Archive
 If JOBID=""
  Onerrgo RIEN
  Local File AESPION [AES]
  CHAINE = format$("N0:5#",mod(uniqid([AES]),99999))
  Close Local File [AES]
  Onerrgo
  JOBID = "jobrpt_"+ETAT+"_"+GUSER+"_"+CHAINE
 Endif
 If !instr(1,JOBID,"#")
  JOBID += "#" : # Permet la numérotation des fichiers quand il y en a plusieurs
 Endif
 PARAM = "__wJobID" : VALEUR = JOBID : Gosub ECRIT
Else
 JOBID = ""
Endif

If DESTINATION=1
 If GBROWS=0      : # or (GBROWS=1 and GRELCLI<"15w.021")
   SERVEUR = ""
 Else
   Local Char HORDATT(14) : Call ENVVAR(HORDATT) From INTRUTILA
   Local Char WJID(200)
   WJID=nomap+"-"+num$(adxuid(1))+"-"+HORDATT+"-"+num$(int(rnd(99)))
   PARAM="__wJobID" : VALEUR=WJID : Gosub ECRIT :  Gosub ECRITSI
 Endif
Endif

# ---- Nouveaux paramètres pour l'administration du serveur d'impression

VALEUR=""
If GSERVEUR
 VALEUR = "BATCH"
Else
 VALEUR = adxmac(-2) : # Poste client
Endif
PARAM = "__WSTATION"                                          : Gosub ECRIT
PARAM = "__CDUSER"        : VALEUR = GUSER                    : Gosub ECRIT

If GSERVEUR
 If adxmac(0)<>""
  CLISERV = adxmac(0) : # Machine courante
 Else
  CLISERV = adxmac(-1) : # Machine où tourne Adonix
 Endif
Else
 Call HOSTNAM(CLISERV) From ASELSIMP     : # CC 18/12/2001 pour compatibilité Web
Endif

# CC 17/11/2004  - On envoie le nom de la solution dans les paramètres
PARAM = "__ADXSOL"        : VALEUR = GINSTID                               : Gosub ECRIT

PARAM = "__APPLICATION"   : VALEUR = nomap+";"+CLISERV+";"+num$(adxtcp)    : Gosub ECRIT
PARAM = "__APPRPT"        : VALEUR = ""                                    : Gosub ECRIT
PARAM = "__RPTLAN"        : VALEUR = ""                                    : Gosub ECRIT
PARAM = "X3DOS"           : VALEUR = nomap+";"+CLISERV+";"+num$(adxtcp)
                            VALEUR += ";"+GVERCRY+";"+GLANGUE              : Gosub ECRIT
# mb 14.1.8
PARAM = "__JOBLINKED"     : VALEUR = RETOUR                                : Gosub ECRIT

PARAM = "__REQUETE"       : VALEUR = num$(NUMREQ)                          : Gosub ECRIT
PARAM = "_PreVisuOptions" : VALEUR = "11111111111111111111"                : Gosub ECRIT

If find(DESTINATION,1,4,7) : # Prévisu/Fichier/Archive
 PARAM = "_Orientation="   : VALEUR = chr$(1)+"1"                           : Gosub ECRIT
Endif

If find(DESTINATION,1,3,4,7) : # Prévisu/Message/Fichier/Archive
 If FORPAP=2
  PARAM = "_PaperSize"    : VALEUR = num$([F:ARP]FORETA(0))                : Gosub ECRIT
 Else
  PARAM = "_PaperSize"    : VALEUR = num$(FORPAP)                          : Gosub ECRIT
 Endif
Endif

# Paramètres standard de la charte

PARAM = "X3CLI"           : VALEUR = GRAISON                               : Gosub ECRIT
PARAM = "X3EDT"           : VALEUR = mess(4,135,1)-mess(5,135,1)           : Gosub ECRIT
PARAM = "X3ETA"           : VALEUR = ETAT                                  : Gosub ECRIT
PARAM = "X3TIT"           : CHAINE = GLANGUE : GLANGUE = LANGUE
                          : Call TEXTE([F:ARP]RPTDES,VALEUR) From OBJDIV
                          : GLANGUE = CHAINE                               : Gosub ECRIT : Gosub ECRITSI
PARAM = "X3OPE"           : VALEUR = func AFNC.TEXTRA("AUTILIS","INTUSR",[F:AUS]USR,"") : Gosub ECRIT
PARAM = "X3USR"           : VALEUR = [F:AUS]USR                            : Gosub ECRIT
PARAM = "X3LAN"           : VALEUR = LANGUE                                : Gosub ECRIT
If GPRODUIT=1 : # Pour Géode
 PARAM = "X3FCY"          : VALEUR = GFCY                                  : Gosub ECRIT
 PARAM = "X3DEP"          : VALEUR = GDEP                                  : Gosub ECRIT
Endif

# conservés par compatibilité
PARAM = "X3SIT1"          : VALEUR = "*"                                   : Gosub ECRIT
PARAM = "X3SIT2"          : VALEUR = "z"                                   : Gosub ECRIT
#

## Autorisations par sites

PARAM = "X3PRF"          : VALEUR = GPROFIL                               : Gosub ECRIT
PARAM = "X3FCT"          : VALEUR = FCT                                   : Gosub ECRIT
PARAM = "X3SIT"          : VALEUR = SITINT                                : Gosub ECRIT

# Paramètres de l'état

Local Integer TYPBOR
Local Integer NBPLD : # Compteur des plages dicrets
Local Integer NBPL  : # Compteur des plages

# Paramètres saisis

For I=0 To NBRPAR-1
 PARAM  = PARCOD(I)
 TYPT   = TYP(I)
 NOLIB  = PARLIB(I)
 VALEUR = VALEUR1(I)
 If left$(tolower(PARAM),4)="%src"
  PARAM = "soldos"
  Gosub ECRIT
 Else
  If DEBFIN(I)=3
   NBPL  = 0
   NBPLD = 0
   For L=0 To NBPLAG-1
    If PARPLAG(L) = PARAM
     VALEUR = VALPLAG1(L)
     TYPBOR = [L]BORPLAG(L)
     Gosub TYPDEB
     Gosub ECRIT
     K=instr(1,PARAMETRE(NBPAR),"=")
     If K
      If [L]BORPLAG(L) <> 2
       NBPLD +=1
       PARAMETRE(NBPAR) = "]["+num$(NBPLD)+"_"+left$(PARAMETRE(NBPAR),K)+chr$(255)+right$(PARAMETRE(NBPAR),K+1)
      Else
       NBPL +=1
       PARAMETRE(NBPAR) = "[["+num$(NBPL)+"_"+left$(PARAMETRE(NBPAR),K)+chr$(255)+right$(PARAMETRE(NBPAR),K+1)
       VALEUR = VALPLAG2(L)
       Gosub TYPFIN
       Gosub ECRIT
       K=instr(1,PARAMETRE(NBPAR),"=")
       If K
        PARAMETRE(NBPAR) = "]]"+num$(NBPL)+"_"+left$(PARAMETRE(NBPAR),K)+chr$(255)+right$(PARAMETRE(NBPAR),K+1)
       Endif
      Endif
     Endif
    Endif
   Next
   If NBPL= 0 & NBPLD =0
    TYPBOR = 2
    VALEUR =""
    Gosub TYPDEB
    Gosub ECRIT
    K=instr(1,PARAMETRE(NBPAR),"=")
    If K
     PARAMETRE(NBPAR) = "[[1_"+left$(PARAMETRE(NBPAR),K)+chr$(255)+right$(PARAMETRE(NBPAR),K+1)
    Endif
    VALEUR = ""
    Gosub TYPFIN
    Gosub ECRIT
    K=instr(1,PARAMETRE(NBPAR),"=")
    If K
     PARAMETRE(NBPAR) = "]]1_"+left$(PARAMETRE(NBPAR),K)+chr$(255)+right$(PARAMETRE(NBPAR),K+1)
    Endif
   Endif
  Else
   If tolower(PARAM)="docjoin"
    PARAM = "__DOCUMENT"
   Endif
   TYPBOR =  DEBFIN(I)
   Gosub TYPDEB
   Gosub ECRIT
  Endif
  If DEBFIN(I)=2
   PARAM  = PARCOD(I)
   Case right$(PARAM,len(PARAM)-2)
    When "deb" : PARAM  = left$(PARAM,len(PARAM)-3)+"fin"
    When "str" : PARAM  = left$(PARAM,len(PARAM)-3)+"end"
    When "DEB" : PARAM  = left$(PARAM,len(PARAM)-3)+"FIN"
    When "STR" : PARAM  = left$(PARAM,len(PARAM)-3)+"END"
   Endcase
   TYPT   = TYP(I)
   NOLIB  = PARLIB(I)
   VALEUR = VALEUR2(I)
   Gosub TYPFIN
   Gosub ECRIT
  Endif
 Endif
Next I

# Paramètres non saisis

For [ARD]ARD0 Where RPTCOD=ETAT & PARCOD<>""
 If !find(tolower([F:ARD]PARCOD),PARCOD(0..NBRPAR-1)) & !find(toupper([F:ARD]PARCOD),PARCOD(0..NBRPAR-1))
  Read [ATY]CODTYP = [F:ARD]PARTYP
  TYPT   = [F:ATY]TYPTYP
  NOLIB  = [F:ARD]PARNOLIB
  PARAM  = [F:ARD]PARCOD
  VALEUR = ""
  I = find(PARAM,TBPAR(1..dim(TBPAR)))
  If I : VALEUR = TBVAL(I) : Endif
  If tolower(PARAM)="docjoin"
   PARAM = "__DOCUMENT"
  Endif
  If VALEUR<>""
   Gosub ECRIT
  Else
   Read [ARV]ARV0 = GFONCTION;1;ETAT;[F:ARD]PARCOD
   If !fstat & [F:ARV]VALDEF1<>""
    Call EVALE([F:ARV]VALDEF1,VALEUR,TYPT) From AIMP1
   Else
    Call EVALE([F:ARD]PARDEF1,VALEUR,TYPT) From AIMP1
   Endif
   If find(TYPT,3,4) & VALEUR=""
    VALEUR = "0"
   Endif
   Gosub ECRIT
  Endif
  If find(tolower(right$(PARAM,len(PARAM)-2)),"deb","str")
   VALEUR = ""
   Case right$(PARAM,len(PARAM)-2)
    When "deb" : CHAINE = "fin"
    When "str" : CHAINE = "end"
    When "DEB" : CHAINE = "FIN"
    When "STR" : CHAINE = "END"
   Endcase
   PARAM = left$(PARAM,len(PARAM)-3)+CHAINE
   I = find(PARAM,TBPAR(1..dim(TBPAR)))
   If I : VALEUR = TBVAL(I) : Endif
   If VALEUR<>""
    Gosub ECRIT
   Else
    Read [ARV]ARV0 = GFONCTION;1;ETAT;[F:ARD]PARCOD
    If !fstat & [F:ARV]VALDEF2<>""
     Call EVALE([F:ARV]VALDEF2,VALEUR,TYPT) From AIMP1
    Else
     Call EVALE([F:ARD]PARDEF2,VALEUR,TYPT) From AIMP1
    Endif
    If find(TYPT,3,4) & VALEUR=""
     VALEUR = "0"
    Endif
    Gosub ECRIT
   Endif
  Endif
 Endif
Next ARD

# Sources de données

For I=0 To NBRPAR-1
 PARAM  = PARCOD(I)
 If tolower(left$(PARAM,4))="%src"
  L = val(right$(PARAM,5))
  Call LECTURE("ADS",nomap,"") From CONTOBJ
  VALEUR = VALEUR1(I)
  J = instr(1,VALEUR,";")
  If J
   SOLUTION = left$(VALEUR,J-1)
   SOLDOS   = right$(VALEUR,J+1)
  Else
   SOLUTION = GINSTID
   SOLDOS   = VALEUR
  Endif
  If SOLUTION=GINSTID
   Call PASSE(SOLDOS,SOLBASE,SOLUSER,SOLPASSE,SOLTABDAT,SOLTABIDX) From ORAPASSE
   NBPAR += 1 : PARAMETRE(NBPAR) = "___DSNID_"+num$(L)+"="+chr$(1)+SOLUTION+";"+SOLDOS
   NBPAR += 1 : PARAMETRE(NBPAR) = "___TYPDBA_"+num$(L)+"="+chr$(1)+num$(GTYPDBA)
   NBPAR += 1 : PARAMETRE(NBPAR) = "___DBUSER_"+num$(L)+"="+chr$(1)+SOLUSER
   NBPAR += 1 : PARAMETRE(NBPAR) = "___DBPASSWORD_"+num$(L)+"="+chr$(1)+SOLPASSE
   NBPAR += 1 : PARAMETRE(NBPAR) = "___DBDATABASE_"+num$(L)+"="+chr$(1)+SOLBASE
  Else
   K = 0
   For [ADD] Where DOSSIER=[F:ADS]DOSSIER
    If SOLUTION=[F:ADD]LSOL & SOLDOS=[F:ADD]LDOSTARG
     K = 1 : Break
    Endif
   Next J
   If K
    SOLPSE  = [F:ADD]LPWD
    Call VARPSE(SOLPSE) From GESUSER
    NBPAR += 1 : PARAMETRE(NBPAR) = "___DSNID_"+num$(L)+"="+chr$(1)+VALEUR
    NBPAR += 1 : PARAMETRE(NBPAR) = "___TYPDBA_"+num$(L)+"="+chr$(1)+num$([F:ADD]LTYPDBA)
    NBPAR += 1 : PARAMETRE(NBPAR) = "___DBUSER_"+num$(L)+"="+chr$(1)+[F:ADD]LUSR
    NBPAR += 1 : PARAMETRE(NBPAR) = "___DBPASSWORD_"+num$(L)+"="+chr$(1)+SOLPSE
    NBPAR += 1 : PARAMETRE(NBPAR) = "___DBDATABASE_"+num$(L)+"="+chr$(1)+[F:ADD]LDBA
   Endif
  Endif
  For J=0 To [F:ARO]NBRTBL-1
   If [F:ARO]NUM(J)=L
    NBPAR += 1 : PARAMETRE(NBPAR) = "___TABLE_"+num$(L)+"="+chr$(1)+[F:ARO]TBL(J)
   Endif
  Next J
 Endif
Next I



GPOINT = "PARAM" : Gosub ENTREE From EXEFNC
ACTION = "EXEC"  : Gosub ACTINI
If DIFFERE=2
 Call REQUETE(nomap,GUSER,DIFDAT,DIFTIM,DIFSRVC)
Else
 Call WORKFLOW(4,ETAT,"C","") From AWRK
 If DESTINATION=6 : # Imprimante ZPL
  Call REPORT_ZPL(ETAT,PARAMETRE,NBPAR,RETOUR) From ARZIMP
  GPOINT = "REPORT_ZPL" : Gosub ENTREE From EXEFNC : # Issue X3-103479 - 2018-09-05 by ALSHE : report ZPL
 Elsif [F:ARP]PARSEG<>"" & NBSEG<>0
  Gosub SEGMENTATION
 Else
  Gosub CRYSTAL
 Endif
 If NBJOBID
  Gosub LECJOB
  Case DESTINATION
   When 3 : # Message
    Call WORKFLOW(1,"ARP","","") From AWRK : # Générique
    Call WORKFLOW(4,ETAT,"P","") From AWRK : # New
   When 7 : # Archive
    Call EVENEMENT(2,ETAT,GFILPATH,"") From ARCHIVE
    ACTION = "AFTARC" : Gosub ACTINI : # 118741
  Endcase
  Call DELJOB(GFILPATH)
  GFILPATH = ""
 Endif
Endif : # Batch
End

$RIEN
Resume

#-----------------------------------#
# Suppression des pièces jointes
#-----------------------------------#

Subprog DELJOB(PIECE)
Value Char PIECE
Local Char    FIC(GDIMFIC) , ORDRE(250) , PCEJOI(GDIMFIC)(1..50)
Local Integer I , J , NBJOI , STA
Onerrgo RIEN
While PIECE<>""
 I = instr(1,PIECE,";")
 If I
  FIC = left$(PIECE,I-1)
  PIECE = right$(PIECE,I+1)
 Else
  FIC = PIECE
  PIECE = ""
 Endif
 If instr(1,FIC,"#") or instr(1,FIC,"~~")
  I = func AWRK.TRTFIC(FIC,NBJOI,PCEJOI)
 Else
  NBJOI += 1
  PCEJOI(NBJOI) = FIC
 Endif
Wend
For I=1 To NBJOI
 Call EFFACE(PCEJOI(NBJOI),STA) From ORDSYS
Next I
Onerrgo
End

#--------------------------------------------------------------#
# Gestion des fins d'impressions (destination=fichier)
#--------------------------------------------------------------#

$LECJOB
Case [M]FMTFIC
 When 1       : EXT = "rpt"
 When 3       : EXT = "doc"
 When 5       : EXT = "rtf"
 When 9,10    : EXT = "txt"
 When 27,28   : EXT = "xls"
 When Default : EXT = "pdf"
Endcase
REP = "tmp"
SLEBOUC = 1
J = 0
For I=1 To NBJOBID
 CHAINE = func NUMFIC(JOBID,I)
 FICJOB = filpath(REP,CHAINE,EXT)
 While filinfo(FICJOB,0)>0
  J += 1
  FICJOB = filpath(REP,func NUMFIC(JOBID,J),EXT)
 Wend
 STAT = 0
 While STAT<5
  # Rptstat : sert à savoir si l'état s'est bien terminé sur le serveur d'impression
  # Stat < 5 => impression en cours... boucle
  # Stat = 5 => impression terminée sans erreur
  # Stat > 5 => impression terminée avec erreur
  rptstat STAT, MESSAGE With CHAINE Using SERVEUR
  If STAT<5 : Sleep SLEBOUC : Endif
 Wend
 If STAT=5
  # Rptfile : sert à créer un fichier que le moteur nous donne
  # Stat -> taille du fichier
  GPE = 0 : GPOINT = "RPTFIL" : Gosub ENTREE From EXEFNC
  If GPE=0
   rptfile STAT With CHAINE, FICJOB Using SERVEUR
  Endif
 Else
  # Erreur de récupération du job/Statut
  Call ECR_TRACE(mess(189,75,1)-CHAINE-":"-mess(190,75,1)+"="+num$(STAT)-"->|"+MESSAGE,1) From GESECRAN
 Endif
 GFILPATH = filpath(REP,JOBID,EXT)
Next I
ACTION = "FILPAT" : Gosub ACTAPP : # CCL Add FILPAT action 114397
GPOINT = "FILPAT" : Gosub ENTREE From EXEFNC
Return

#------------------------#
Funprog NUMFIC(FIC,NUM)
Value Char    FIC
Value Integer NUM
Local Char CHAINE(255)
Local Integer I
I = instr(1,FIC,"#")
If I
 If NUM<=1 : # Le premier fichier n'est pas numéroté
  CAR = ""
 Else
  CAR = format$("N0:8#",NUM)
 Endif
 CHAINE = left$(FIC,I-1)+CAR+right$(FIC,I+1)
Else
 CHAINE = FIC
Endif
End CHAINE

#----------------------------------------------#
# Gestion de la segmentation
#----------------------------------------------#

$SEGMENTATION
PS = 0
MULT = 0
Read [ARD]ARD1 = [F:ARP]PARSEG;ETAT
If !fstat
 # Issue X3-48208 - 2017-11-02 by CCC : take into account type of parameter
 Read [ATY]CODTYP = [F:ARD]PARTYP
 If fstat
    PS=0
 Else
    TYPPARSEG = [F:ATY]TYPTYP
 Endif

 Case [ARD]PARSTREND
  When 1 : PS = 0   : # Impossible pour paramètre unique
  When 2 :          : # Ok  pour les bornes
  When 3 : MULT = 1 : # Valeurs multiples
 Endcase
 If find([ARD]PARSTREND,2,3)
  For I=1 To NBPAR
   I1 = instr(1,PARAMETRE(I),"=")
   If I1>0 & tolower(left$(PARAMETRE(I),I1-1)) = tolower([F:ARP]PARSEG)
    PS = I
    Break
   Endif
  Next I
 Endif
Endif
If PS
 If MULT=0
  VALDEB = right$(PARAMETRE(PS),instr(1,PARAMETRE(PS),"=")+1)
  VALFIN = right$(PARAMETRE(PS+1),instr(1,PARAMETRE(PS+1),"=")+1)
 Else
  VALDEB = right$(PARAMETRE(PS),instr(1,PARAMETRE(PS),"="+chr$(255))+1)
  VALFIN = right$(PARAMETRE(PS+1),instr(1,PARAMETRE(PS+1),"="+chr$(255))+1)
 Endif
 If VALDEB="" : VALDEB = " "          : Endif
 If VALFIN="" : VALFIN = "zzzzzzzzzz" : Endif
 Raz SAV_PARAM_IDX,SAV_PARAMSI_IDX,SAV_WJOBID   # 120674-segmentation in report
 For I1=0 To NBSEG
  If I1=0
   VALSEGDEB = VALDEB
  Else
   VALSEGDEB = VALSEG(I1-1)
  Endif
  # Issue X3-48208 - 2017-11-02 by CCC : remove 1 day for dates and 1 for integer
  Case TYPPARSEG:
    When 1, 2, 3: # Local menu & Integer
       If I1=NBSEG
           VALSEGFIN = VALFIN
       Else
           VALSEGFIN = num$(val(VALSEG(I1))-1)
       Endif
    When 7 :    # Alpha
       If I1=NBSEG
        VALSEGFIN = left$(VALSEG(I1),len([F:ARP]PARSEG)+1)+VALFIN
       Else
        VALSEGFIN = left$(VALSEG(I1),len(VALSEG(I1))-1)+chr$(ascii(mid$(VALSEG(I1),len(VALSEG(I1)),1))-1)+"zzz"
       Endif
    When 8 : # Date
       If I1=NBSEG
        VALSEGFIN = VALFIN
       Else
        # Issue X3-48208 - 2017-11-02 by CCC : remove 1 day
        #VALSEGFIN = VALSEG(I1)
        DATEFIN = num$(gdat$( val(right$(VALSEG(I1),7)), val(mid$(VALSEG(I1),5,2)), val(left$(VALSEG(I1),4)))-1)
        # adapt date to parameter format
        Call CONTROLE(DATEFIN,"D",0,0,VALSEGFIN) From FMTVAR
       Endif
  Endcase
  If MULT =0
   PARAMETRE(PS)   = left$(PARAMETRE(PS),instr(1,PARAMETRE(PS),"="))+VALSEGDEB
   PARAMETRE(PS+1) = left$(PARAMETRE(PS+1),instr(1,PARAMETRE(PS+1),"="))+VALSEGFIN
  Else
   PARAMETRE(PS)   ="[[1_"+tolower([F:ARP]PARSEG)+"="+VALSEGDEB
   PARAMETRE(PS+1) ="]]1_"+tolower([F:ARP]PARSEG)+"="+VALSEGFIN
  Endif
  For J=1 To NBPAR
   If left$(PARAMETRE(J),10)="__REQUETE="
    If clalev([F:AES])=0 : Local File AESPION  [AES] : Endif: # 112401 CCL
    NUMREQ = uniqid([AES])
    PARAMETRE(J) = "__REQUETE="+num$(NUMREQ)
   Endif
   If left$(PARAMETRE(J),12)="_ExportFile="
    FICSEG = FICHIER
    J1 = instr(1,FICSEG,".")
    If J1
     FICSEG = left$(FICSEG,J1-1)+format$("N0:2#",I1+1)+right$(FICSEG,J1)
    Else
     FICSEG = FICSEG+format$("N0:2#",I1+1)
    Endif
    PARAMETRE(J) = "_ExportFile="+chr$(1)+FICSEG
   Endif
  Next J
  # 120674 - Report segmentation - start
  If I1=0
   For J=1 To NBPAR
    If instr(1,PARAMETRE(J),"wJobID")
      SAV_WJOBID=PARAMETRE(J)
      SAV_PARAM_IDX=J
      Break
    Endif
   Next J
   For J=1 To NBPARSI
    If instr(1,PARAMSI(J),"wJobID")
      SAV_PARAMSI_IDX=J
      Break
    Endif
   Next J
 Endif
 If SAV_WJOBID<>""
    PARAMETRE(SAV_PARAM_IDX)=SAV_WJOBID+num$(I1)
    PARAMSI(SAV_PARAMSI_IDX)=PARAMETRE(SAV_PARAM_IDX)
 Endif
 # 120674 - Report segmentation - end
  Gosub CRYSTAL
 Next I1
Endif
Return

#--------------------------------------------#
$TYPDEB
Case TYPT
 When 1,2,3,4 : If VALEUR="" : VALEUR = "0" : Endif
 When 7       : If VALEUR="" & TYPBOR = 2 : VALEUR = " " : Endif
 #---------------------------------------------------------------------------------------------#
 # mb 15.11.04 on passe un blanc car le caractère vide n'existe pas sous oracle.
 # Sous Adonix, si on écrit [F]ZONE = " " : Write [F] : Read [F] , [F]ZONE est vide.
 # Jusqu'à la 136 incluse, on passait 2 blancs car Crystal virait un blanc dans les sous-états.
 #---------------------------------------------------------------------------------------------#

 # X3-77398 30.07.2018
 When 8       : If VALEUR="" or VALEUR="000000" or VALEUR="00000000"
                  If GTYPDBA = 1
                    VALEUR = "15991231"
                  Else
                    VALEUR = "17530101"
                  Endif
                Endif
Endcase
Return

#--------------------------------------------#
$TYPFIN
Case TYPT
 When 1 : If val(VALEUR)=0 : VALEUR = "255" : Endif
 When 2 : If val(VALEUR)=0 : VALEUR = "32767" : Endif
 When 3 : If val(VALEUR)=0 : VALEUR = "99999999" : Endif
 When 4 : If val(VALEUR)=0 : VALEUR = "999999999999999" : Endif
 When 7 : If VALEUR=""     : VALEUR = "zzzzzzzzzz" : Endif
 When 8 : If VALEUR="" or VALEUR="000000" or VALEUR="00000000" : VALEUR = "29991231" : Endif
Endcase
Return

#--------------------------------------------#
$CRYSTAL
#SAM 108578
Raz R1 , R2 , R3 , R5 , R7 , R8 , R9 , R10 , R11 , RSI, R12, R13
For R=1 To NBPAR
 If    left$(PARAMETRE(R),8) ="__REPORT"     : R1  = R
 Elsif left$(PARAMETRE(R),8) ="__APPRPT"     : R2  = R
 Elsif left$(PARAMETRE(R),12)="_Orientation" : R8  = R
 Elsif left$(PARAMETRE(R),10)="_PaperSize"   : R10 = R
 Elsif left$(PARAMETRE(R),8) ="__RPTLAN"     : R3  = R
 Elsif left$(PARAMETRE(R),10)="__DOCUMENT"   : R7  = R
 Elsif left$(PARAMETRE(R),11)="_ExportFile"  : R5  = R : FICBAS = right$(PARAMETRE(R),14)
 Elsif left$(PARAMETRE(R),11)="__JOBLINKED"  : R9  = R
 Elsif left$(PARAMETRE(R),8) ="__wJobID"     : R11 = R
 Elsif left$(PARAMETRE(R),5) ="X3ETA"     : R12 = R
 Elsif left$(PARAMETRE(R),5) ="X3TIT"     : R13 = R
 Endif
Next R

# 118141
For R=1 To NBPARSI
 If left$(PARAMSI(R),8) ="__wJobID"     : RSI = R : Endif
Next R

If (R1 & R2 & R3) | R7

 #SAM 108578 : For each report :
 For R=0 To dim([F:ARP]CRYCOD)-1
  Raz M , DOSSIER
  If R=0
   If [F:ARP]CRYCOD(R)<>""
    M = 1
   Elsif R7<>0
    M = 1
    DOSSIER = nomap
   Endif
  Elsif [F:ARP]CRYCOD(R)<>""
   M = 1
   If R7<>0
    For I=1 To NBPAR
     If left$(PARAMETRE(I),10)="__DOCUMENT"
      PARAMETRE(I) = "__DOCUMENT=" : # les pièces jointes ne sont éditées qu'une fois
     Endif
    Next I
   Endif
   If R9
    If [F:ARP]IMPLIE=2
     PARAMETRE(R9) = "__JOBLINKED="+RETOUR
    Else
     PARAMETRE(R9) = "__JOBLINKED="
    Endif
   Endif
  Endif



  # Orientation pour chaque état

  If R8
   #If [F:ARP]ORIENT(R)=2
   #96262
   If dim(PRTORIENT)>0 & PRTORIENT=2
    PARAMETRE(R8) = "_Orientation="+chr$(1)+"1"
   Elsif [F:ARP]ORIENT(R)=2
    PARAMETRE(R8) = "_Orientation="+chr$(1)+"1"
   Else
    PARAMETRE(R8) = "_Orientation="+chr$(1)+"0"
   Endif
  Endif

  # Format du papier

  If R10
   If FORPAP=2
    PARAMETRE(R10) = "_PaperSize="+chr$(1)+num$([F:ARP]FORETA(R))
   Else
    PARAMETRE(R10) = "_PaperSize="+chr$(1)+num$(FORPAP)
   Endif
  Endif

  If M
   If [F:ARP]CRYCOD(1)<>"" & R5<>0 : # Il y en a au moins 2
    FICSEG = FICBAS
    R6 = instr(1,FICSEG+".",".")
    PARAMETRE(R5) = "_ExportFile="+chr$(1)+left$(FICSEG,R6-1)+"_"+num$(R+1)+right$(FICSEG,R6)
   Endif

   # Où se trouve l'état ?

   If RPTDEV<>""
    PARAM = "__SANDBOX"
    Gosub RAZ_ECRIT
    RPTDEV = ""
   Endif
   RPTNAM = [F:ARP]CRYCOD(R)
   Gosub DOSRPT

   If DOSSIER<>""
    If RPTDEV<>""
     PARAMETRE(R1) = "__REPORT="+RPTDEV
    Elsif RPTNAM<>""
     PARAMETRE(R1) = "__REPORT="+RPTNAM+".rpt"
    Endif

    #SAM 108578 : X3ETA = Name of the report
    If R12
     VALEUR = RPTNAM
      PARAMETRE(R12) = "X3ETA="+ETAT :#SAM 109075
      PARAM = "X3ETA" : Gosub RAZ_ECRITSI : Gosub ECRITSI
    Endif

    #SAM 108578 : X3ETA = Title of the report
    #The title is stored at the main level
    If R13
      Local File AREPORT  [ARP2]
      Read [ARP2]ARP0 =  [F:ARP]CRYCOD(R)
      If !fstat : # 113214 CCL
       Call TEXTE([F:ARP2]RPTDES,VALEUR) From OBJDIV
      Else
       Call TEXTE([F:ARP]RPTDES,VALEUR) From OBJDIV
      Endif
      PARAMETRE(R13) = "X3TIT="+VALEUR
      PARAM = "X3TIT" : Gosub RAZ_ECRITSI : Gosub ECRITSI
      Close Local File [ARP2]
    Endif

    PARAMETRE(R2)  = "__APPRPT="+DOSSIER+";"+CLISERV+";"+num$(adxtcp)
    PARAMETRE(R3)  = "__RPTLAN="+RPTLAN
    GPE = 0
    GOK = 1
    If [F:ARP]TRTSPE<>""
     Call EXISTE_ADX("","",[F:ARP]TRTSPE,OKTRT) From ORDSYS
     If OKTRT>0 : Call IMPRIME(NBPAR,PARAMETRE) From =[F:ARP]TRTSPE : Endif
    Endif
    If !GPE & GOK=1 & [F:ARP]TRTINI<>""
     Call EXISTE_ADX("","",[F:ARP]TRTINI,OKTRT) From ORDSYS
     If OKTRT>0 : Call IMPRIME(NBPAR,PARAMETRE) From =[F:ARP]TRTINI : Endif
    Endif

    ACTION = "REPORT_CTL" : Gosub ACTAPP
    If GOK=1

     # Incrémentation du JOBID dans le cas d'une impression fichier

     If R11 & JOBID<>"" & RSI=0
      NBJOBID += 1
      PARAMETRE(R11) = "__wJobID="+chr$(1)+func NUMFIC(JOBID,NBJOBID)
     Endif
     # On change le job ID en Web pour l'indicer avec le rang de l'impression
     If R>0 & RSI>0
      PARAMETRE(R11) ="__wJobID="+chr$(1)+WJID+"-"+num$(R)
      PARAMSI(RSI)="__wJobID="+WJID+"-"+num$(R)
     Endif

     # Remplacer le . par , si séparateur décimal=, dans le panneau de config

     Call SETVIR(ETAT,NBPAR,PARAMETRE) From ETAT

     If GSERVEUR
      If !find("_nolispar",TBPAR(1..dim(TBPAR)))
       Call ECR_TRACE(time$-mess(10,135,1)-RPTNAM,0) From GESECRAN : # Impression de l'état
       Call ECR_TRACE(mess(15,135,1)-": |"+SERVEUR,0) From GESECRAN : # Serveur d'impression
       For I=1 To NBPAR
        If left$(PARAMETRE(I),13)="_PrinterName="
         Call ECR_TRACE(mess(16,135,1)-": |"+right$(PARAMETRE(I),15),0) From GESECRAN : # Imprimante
        Elsif left$(PARAMETRE(I),1)<>"_"
         Call ECR_TRACE("|"+PARAMETRE(I),0) From GESECRAN
        Elsif GDEBUG=2 & GADONIX=2
         L = instr(1,PARAMETRE(I),"=")
         If L & (ascii(mid$(PARAMETRE(I),L+1,1))<20 or ascii(mid$(PARAMETRE(I),L+1,1))=255)
          CHAINE = left$(PARAMETRE(I),L)+right$(PARAMETRE(I),L+2)
         Else
          CHAINE = PARAMETRE(I)
         Endif
         Call ECR_TRACE("|"+CHAINE,0) From GESECRAN
        Endif
       Next I
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Endif
     Elsif GTEST
      TRA = (GTRACE<>"")
      If !TRA
       Call OUVRE_TRACE("Crystal reports"-RPTNAM) From LECFIC
      Endif
      Call ECR_TRACE(mess(174,100,1),0) From GESECRAN: # Paramètres
      Call ECR_TRACE(mess(15,135,1)-": |"+SERVEUR,0) From GESECRAN : # Serveur d'impression
      Call PARAMPRINT(PARAMETRE,NBPAR) From ETAT : # Ajout de Chr$(1) devant les paramètres
      For I=1 To NBPAR
       L = instr(1,PARAMETRE(I),"=")
       CHAINE = "("+num$(ascii(mid$(PARAMETRE(I),L+1,1)))+")"
       Call ECR_TRACE("|"+PARAMETRE(I)-CHAINE,0) From GESECRAN
      Next I
      If !TRA
       Call FERME_TRACE From LECFIC
       Call LEC_TRACE From LECFIC
      Endif
     Endif
     Call PARAMPRINT(PARAMETRE,NBPAR) From ETAT : # Ajout de Chr$(1) devant les paramètres
     If SERVEUR<>"" & right$(SERVEUR,len(SERVEUR))<>"@"
      Report RETOUR=SERVEUR+"@" With PARAMETRE(1..NBPAR)
     Else
      Report RETOUR=SERVEUR With PARAMETRE(1..NBPAR)
     Endif

     # On prévient le serveur Web si on appelle directement le serveur d'impression

     If GBROWS=1 and DESTINATION=1 & !DOCWEB : # and GRELCLI>="15W.021"
      TYPT=7
      PARAM = "+STATE" : VALEUR="LAUNCHED" : Gosub ECRIT : Gosub ECRITSI
      PARAM = "+OUT"   : VALEUR="DISPLAY"  : Gosub ECRIT : Gosub ECRITSI
      If GFUSION=1
       #SAM 108578 Gosub ECRIT
       PARAM="__REPORT"   : VALEUR=RPTNAM+".rpt" : Gosub ECRITSI
       PARAM="__wJobRank" : VALEUR=num$(RETOUR)  : Gosub ECRIT : Gosub ECRITSI
      Endif
      Report RETOUR="" With PARAMSI(1..NBPARSI)
      # mb 27.1.15 bug 105202
      PARAM = "+STATE" : Gosub RAZ_ECRIT : Gosub RAZ_ECRITSI
      PARAM = "+OUT"   : Gosub RAZ_ECRIT : Gosub RAZ_ECRITSI
      If GFUSION=1
       PARAM="__wJobRank" : Gosub RAZ_ECRIT : Gosub RAZ_ECRITSI
      Endif
      #
     Endif
     Call AP_IMPRIME(NBPAR,PARAMETRE)
     GPOINT = "REPORT" : Gosub ENTREE From EXEFNC : # mb 10.2.5 dem 27822
    Endif
   Endif
  Endif
 Next R
Endif
Return

#--------------------------------------------------------------#
# Recherche du répertoire où se trouve l'état
#--------------------------------------------------------------#

$DOSRPT

# On teste d'abord le mode "Développement" en fat client

If GDEVCRY=2 & !GBROWS & !GSERVEUR & DOSSIER="" & (dim(GFUSION)<=0 or !GFUSION)
 Call PARCLI("DevRptMode",CHAINE) From GLOBVAR
 If CHAINE="ON"
  Call EXIST_FILECLI(RPTNAM+".rpt","ReportDev","",LANGUE,CHAINE,K) From ORDSYS
  If K
   DOSSIER = nomap
   RPTLAN = LANGUE
  Endif
 Endif
Endif

# Mode "Développement" en classic client
# 112174 dim(R) becasue call by applicaitf code
If dim(R)>0 & GDEVCRY>=2 & DOSSIER="" & (dim(GFUSION)>0 & GFUSION) & dim([F:ARP]DEVSTA)>0
 If [F:ARP]DEVSTA(R)=3 & [F:ARP]DEVUSR(R)=GUSER & find(toupper([F:ARP]DEVSRV(R)),toupper(SERVEUR),toupper(SERVEUR1))
  If ([F:ARP]MULLAN=2 & [F:ARP]DEVLAN(R)=LANGUE) or [F:ARP]DEVLAN(R)=[F:ARP]LAN
   DOSSIER = [F:ARP]DEVAPP(R)
   RPTLAN  = [F:ARP]DEVLAN(R)
   RPTDEV  = func SUBARP.SET_RPTID(RPTNAM,GUSER,RPTLAN,DOSSIER)
   TYPT = 7 : PARAM = "__SANDBOX" : VALEUR = "sandbox" : Gosub ECRIT
  Endif
 Endif
Endif

#
# Si l'état est multi-langue on va le chercher dans le répertoire REPORT / langue d'impression
#

If DOSSIER=""
 If [F:ARP]MULLAN=2
  For R4=0 To 7
   If nomap(R4)<>""
    If filinfo(filpath(filpath("REPORT",LANGUE,"",R4),RPTNAM,"rpt",R4),0)>=0
     DOSSIER = nomap(R4)
     RPTLAN  = LANGUE
     Break
    Endif
   Endif
  Next R4
 Endif
Endif

#
# Sinon ou si on l'a pas trouvé on va voir dans le répertoire de la langue de conception
#

If DOSSIER=""
 For R4=0 To 7
  If nomap(R4)<>""
   If filinfo(filpath(filpath("REPORT",[F:ARP]LAN,"",R4),RPTNAM,"rpt",R4),0)>=0
    DOSSIER = nomap(R4)
    RPTLAN  = [F:ARP]LAN
    Break
   Endif
  Endif
 Next R4
Endif

#
# Sinon on tente sa chance dans REPORT (provisoirement)
#

If DOSSIER=""
 For R4=0 To 7
  If nomap(R4)<>""
   If filinfo(filpath("REPORT",RPTNAM,"rpt",R4),0)>=0
    DOSSIER = nomap(R4)
    RPTLAN  = ""
    Break
   Endif
  Endif
 Next R4
Endif

#
# Sinon on essaye de voir en local
#

If DOSSIER="" & !GSERVEUR & !GBROWS
 # Cas de l'état généré dans le répertoire ALL (La langue d'édition n'est pas définie)
 Call EXIST_FILECLI(RPTNAM+".rpt","ReportDev",nomap(0),"",CHAINE,K) From ORDSYS
 If K
  DOSSIER = nomap
  TYPT = 7 : PARAM = "__LOCALRPT" : VALEUR = "1" : Gosub ECRIT
  RPTLAN = ""
 Endif
Endif

If DOSSIER=""
 Call ECR_TRACE(RPTNAM+".rpt"-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
Endif
Return

#--------------------------------------------------------------#
# Paramètres imprimante
#--------------------------------------------------------------#

$IMPRIMANTE
Local Integer PRINTERSTOPPAGE : PRINTERSTOPPAGE = 9999

If DESTINATION<>6 or IMPRIMANTE<>""
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterName="+chr$(1)+IMPRIMANTE
Endif
If SERVEUR<>""
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterServer="+chr$(1)+SERVEUR
Endif
NBPAR += 1 :PARAMETRE(NBPAR) = "_PrinterDriver="+chr$(1)+PRTDRV
NBPAR += 1 :PARAMETRE(NBPAR) = "_PrinterPort="+chr$(1)+PRTPOR
#96267
If GFUSION=1
 For I=0 To dim(PRTDESEX)-1
  If PRTDESEX(I)<>""
    NBPAR += 1
    PARAMETRE(NBPAR) = "_PrinterDescriptionEx="+chr$(I+1)+PRTDESEX(I)
  Endif
 Next I
Else
 For I=0 To dim(PRTDES)-1
  If PRTDES(I)<>""
    NBPAR += 1
    PARAMETRE(NBPAR) = "_PrinterDescription="+chr$(I+1)+PRTDES(I)
  Endif
 Next I
Endif
NBPAR += 1 : PARAMETRE(NBPAR) = "_Orientation="         +chr$(1)+num$(PRTORIENT=2)
NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterCopies="     +chr$(1)+num$(max(1,NBRCPY))
NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterCollate="     +chr$(1)+num$( ASSCPY=2)
NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterStartPage=" +chr$(1)+num$(max(1,PAGDEB))
#SAM 108829
If PAGFIN : PRINTERSTOPPAGE= min(PAGFIN,PRINTERSTOPPAGE) : Endif
NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterStopPage=" +chr$(1)+num$(PRINTERSTOPPAGE)

If DESTINATION=6 & FICHIER<>"" : # Imprimante ZEBRA
 NBPAR += 1
 If FICHIER<>"" & instr(1,FICHIER,"\")=0 & instr(1,FICHIER,"/")=0 & !GBROWS
  Call DEFAULT_FILECLI(FICHIER,"UserTemp","","") From ORDSYS
 Endif
 PARAMETRE(NBPAR) = "_ExportFile="+chr$(1)+FICHIER
Endif
Return

#--------------------------------------------------------------#
# Paramètres messagerie + choix destinataires
#--------------------------------------------------------------#

$MESSAGERIE
OK = 1
ACTION = "MESSAGERIE" : Gosub ACTINI
If !OK
 OKMES = 0
Else
 If !MELWRK
  NBPAR = 0
  For I=1 To dim(PARMES)
   If PARMES(I)=""
    Break
   Else
    NBPAR += 1
    PARAMETRE(NBPAR) = PARMES(I)
   Endif
  Next I
  If SERVEUR<>""
   K = 0
   For I=1 To dim(PARAMETRE)
    If left$(PARAMETRE(I),15)="_EmailNoResolve"
     K = 1 : Break
    Endif
   Next I
   If !K
    NBPAR += 1
    PARAMETRE(NBPAR) = "_EmailNoResolve="+chr$(1)+"1"
   Endif
  Endif
  If GSERVEUR
   If dim([M]NBDEST)<=0 or [M]NBDEST=0
    OKMES = 0 : Return
   Else
    For I=1 To [M]NBDEST
     NBPAR += 1
     PARAMETRE(NBPAR) = "_EMailToList="+chr$(I)
     If I>1
      PARAMETRE(NBPAR) += ";"
     Endif
     PARAMETRE(NBPAR) += [M]DEST(I-1)
    Next I
    NBPAR += 1
    PARAMETRE(NBPAR) = "_EMailSubject="+chr$(1)+[M]TEXOBJ
   Endif
  Elsif !GBROWS
   Seldest PARAMETRE = SERVEUR With PARAMETRE
   NBPAR = stat1
   If OKMES=0
    Return
   Else
    For I=1 To dim(PARAMETRE)
     If left$(PARAMETRE(I),13)="_EMailMessage"
      K = instr(16,PARAMETRE(I),chr$(13))
      While K<>0
       PARAMETRE(I) = left$(PARAMETRE(I),K-1)+chr$(10)+right$(PARAMETRE(I),K+1)
       K = instr(K+1,PARAMETRE(I),chr$(13))
      Wend
     Endif
    Next I
   Endif
  Elsif dim([M]NBDEST)<=0
   OKMES = 0 : Return
  Else
   Gosub SAIDEST
   If [M]NBDEST=0
    OKMES = 0 : Return
   Else
    For I=1 To [M]NBDEST
     NBPAR += 1
     PARAMETRE(NBPAR) = "_EMailToList="+chr$(I)
     If I>1
      PARAMETRE(NBPAR) += ";"
     Endif
     PARAMETRE(NBPAR) += [M]DEST(I-1)
    Next I
    NBPAR += 1
    PARAMETRE(NBPAR) = "_EMailSubject="+chr$(1)+[M]TEXOBJ
   Endif
  Endif
 Endif
 Gosub FORMATFIC
 NBPAR += 1
 PARAMETRE(NBPAR) = "_Orientation="+chr$(1)+"1"
 NBPAR += 1
 PARAMETRE(NBPAR) = "_ExportFile="+chr$(1)
Endif
Return

#--------------------------------------------------------------#
# Saisie des destinataires du message (aussi utilisé en batch)
#--------------------------------------------------------------#

$SAIDEST
Local Char DEFMSK(250)
DEFMSK = dbgstr(1)
Local Mask AIMP5 [AIM5]
[M:AIM5] = [M:RPT]
Local Char VALMSK(10) , PARMSK(10)(1..1)
Call SAISIE_CHAR(VALMSK,PARMSK,"AIMP5","AIMP5","") From GSAISIE
[M:RPT] = [M:AIM5]
Close Local Mask [AIM5]
Default Mask DEFMSK
Return

#--------------------------------------------------------------#
# Paramètres fichier
#--------------------------------------------------------------#

$FICHIER
OK = 1
ACTION = "FICHIER" : Gosub ACTINI
If OK
 If FICHIER<>"" & instr(1,FICHIER,"\")=0 & instr(1,FICHIER,"/")=0 & !GBROWS & SERVEUR=""
  Call DEFAULT_FILECLI(FICHIER,"UserTemp","","") From ORDSYS
 Endif
 NBPAR += 1 : PARAMETRE(NBPAR) = '_ExportFile='+chr$(1)+FICHIER
 Gosub FORMATFIC
Endif
Return

#----------------------#
$FORMATFIC
NBPAR += 1
PARAMETRE(NBPAR) = "_FormatExport="+chr$(1)+num$(FMTFIC)
NBPARSI+=1 : PARAMSI(NBPARSI)=PARAMETRE(NBPAR)
If FMTFIC=8
 NBPAR += 1 : PARAMETRE(NBPAR) = '_FormatDelString='+chr$(1)+'"'
 NBPAR += 1 : PARAMETRE(NBPAR) = '_FormatDelRecord='+chr$(1)+chr$(13)+chr$(10)
Endif
Return

#--------------------------------------------------------------#
# Constitution d'un parametre
#--------------------------------------------------------------#

$ECRITSI
IPOS = 0
If 1=0
 For IPAR=1 To NBPARSI
  ILEN = instr(1,PARAMSI(IPAR),"=")
  If ILEN & left$(PARAMSI(IPAR),ILEN-1)=PARAM
   IPOS = IPAR : Break
  Endif
 Next IPAR
Endif
If !IPOS
 NBPARSI += 1
 IPOS = NBPARSI
Endif
If GFUSION=1
 PARAMSI(IPOS)=PARAM+"="+chr$(1)+VALEUR
Else
 PARAMSI(IPOS)=PARAM+"="+VALEUR
Endif
Return

$ECRIT
Case TYPT
 When 1
  If NOLIB=1
   Case val(VALEUR)
    When 1 : VALEUR = "0"
    When 2 : VALEUR = "1"
   Endcase
  Endif
 When 2,3,4,5,6
  If VALEUR=""
   VALEUR = "0"
  Endif
 When 7
  If PARAM="X3FCT" & VALEUR=""
   VALEUR = " " : # mb 16.4.15 bug 107430 Cas de la jointure AFCTFCY dans les .rpt si "Autorisation site" de la fonction est désactivé
  Endif
  # VALEUR = '"'+VALEUR+'"'
 When 8
  # X3-77398 30.07.2018
  # 15991231 is proper empty value for oracle db
  # in this case we have to bypass gdat$ beacues it doesn't work properly for such old date
  If VALEUR <> "15991231"
    DAT = gdat$(left$(VALEUR+"00000000",8))
    If DAT=[0/0/0] : DAT += 1 : Endif
    VALEUR = format$("D:YYYYMMDD",DAT)
  Endif
Endcase
IPOS = 0
If 1=0
 For IPAR=1 To NBPAR
  ILEN = instr(1,PARAMETRE(IPAR),"=")
  If ILEN & left$(PARAMETRE(IPAR),ILEN-1)=PARAM
   IPOS = IPAR : Break
  Endif
 Next IPAR
Endif
If !IPOS
 NBPAR += 1
 IPOS = NBPAR
Endif
PARAMETRE(IPOS) = PARAM+"="+VALEUR
If PARAM="site" & GPRODUIT=1 : ## GEODE
 If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
 Read [FCY]FCY0 = VALEUR
 If !fstat
  CHAINE = "societe"
  K = 0
  For P=1 To NBPAR
   If left$(PARAMETRE(P),len(CHAINE))=CHAINE
    K = P : Break
   Endif
  Next P
  If K
   PARAMETRE(K) = CHAINE+"="+[F:FCY]LEGCPY
  Else
   NBPAR += 1
   PARAMETRE(NBPAR) = CHAINE+"="+[F:FCY]LEGCPY
  Endif
 Endif
Endif
Return

$RAZ_ECRIT
IPOS = 0
For IPAR=1 To NBPAR
 ILEN = instr(1,PARAMETRE(IPAR),"=")
 If ILEN & left$(PARAMETRE(IPAR),ILEN-1)=PARAM
  IPOS = IPAR : Break
 Endif
Next IPAR
If IPOS
 If IPOS=NBPAR
  PARAMETRE(IPOS) = ""
 Else
  For IPAR=IPOS To NBPAR-1
   PARAMETRE(IPAR) = PARAMETRE(IPAR+1)
  Next IPAR
 Endif
 PARAMETRE(NBPAR) = ""
 NBPAR -= 1
Endif
Return

$RAZ_ECRITSI
IPOS = 0
For IPAR=1 To NBPARSI
 ILEN = instr(1,PARAMSI(IPAR),"=")
 If ILEN & left$(PARAMSI(IPAR),ILEN-1)=PARAM
  IPOS = IPAR : Break
 Endif
Next IPAR
If IPOS
 If IPOS=NBPARSI
  PARAMSI(IPOS) = ""
 Else
  For IPAR=IPOS To NBPARSI-1
   PARAMSI(IPAR) = PARAMSI(IPAR+1)
  Next IPAR
 Endif
 PARAMSI(NBPARSI) = ""
 NBPARSI -= 1
Endif
Return

#--------------------------------------------------------------#
# Constitution des criteres CRITSOC et CRITSIT
#--------------------------------------------------------------#

$EVALCRITSOC
K = find("CPY",PARTYP(0..NBRPAR-1))
If K
 L = len(PARCOD(K-1))
 J = 0
 If DEBFIN(K-1)=3
  WCRIT = "("
  For I=0 To NBPLAG-1
   If PARPLAG(I) = PARCOD(K-1)
    If BORPLAG(I)<>2
     If VALPLAG1(I)<> ""
      Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'CPY="'+VALPLAG1(I)+'"',"|") From GOBJSUB
      If J=1
       SOCDEB = VALPLAG1(I)
       SOCFIN = VALPLAG2(I)
      Endif
      J += 1
     Endif
    Else
     WCRIT = "("
     If VALPLAG1(I)<> ""
      WCRIT += 'CPY>="'+VALPLAG1(I)+'"'
     Endif
     If VALPLAG2(I)<> ""
      WCRIT += '& CPY<="'+VALPLAG2(I)+'"'
     Endif
     If WCRIT <> "("
      WCRIT += ")"
      Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",WCRIT,"|") From GOBJSUB
      If J=1
       SOCDEB = VALPLAG1(I)
       SOCFIN = VALPLAG2(I)
      Endif
      J += 1
     Endif
    Endif
   Endif
  Next
  If J>1 : Raz SOCDEB,SOCFIN : Endif
 Elsif L>3 & (tolower(right$(PARCOD(K-1),L-2))="deb" or tolower(right$(PARCOD(K-1),L-2))="str") & DEBFIN(K-1)=2
  SOCDEB = VALEUR1(K-1) : # cas sans valeur multiple
  SOCFIN = VALEUR2(K-1)
  If SOCDEB<> ""
   Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'CPY>="'+SOCDEB+'"',"&") From GOBJSUB
  Endif
  If SOCFIN<> ""
   Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'CPY<="'+SOCFIN+'"',"&") From GOBJSUB
  Endif
 Else
  SOCDEB = VALEUR1(K-1) : # cas sans valeur multiple pour un test plus bas
  SOCFIN = VALEUR2(K-1)
  If SOCDEB<> ""
   Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'CPY'+string$(SOCFIN<>"",">=")+string$(SOCFIN="","=")+'"'+SOCDEB+'"',"&") From GOBJSUB
  Endif
  If  SOCFIN<> ""
   Call ADDCRIT(CRITSOC,ICRITSOC,"CRITSOC",'CPY<="'+SOCFIN+'"',"&") From GOBJSUB
  Endif
 Endif
 OKSOC = 1
Endif
K = find("FCY",PARTYP(0..NBRPAR-1))
If K
 L = len(PARCOD(K-1))
 If DEBFIN(K-1)=3
  J = 0
  For I=0 To NBPLAG-1
   If PARPLAG(I) = PARCOD(K-1)
    If BORPLAG(I)<>2
     If VALPLAG1(I)<> ""
      Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'FCY="'+VALPLAG1(I)+'"',"|") From GOBJSUB
      If J=0
       SITDEB = VALPLAG1(I)
       SITFIN = VALPLAG2(I)
      Endif
      J += 1
     Endif
    Else
     WCRIT = "("
     If VALPLAG1(I)<> ""
      WCRIT += 'FCY>="'+VALPLAG1(I)+'"'
     Endif
     If VALPLAG2(I)<> ""
      WCRIT += '& FCY<="'+VALPLAG2(I)+'"'
     Endif
     If WCRIT <> "("
      WCRIT += ")"
      Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",WCRIT,"|") From GOBJSUB
      If J=0
       SITDEB = VALPLAG1(I)
       SITFIN = VALPLAG2(I)
      Endif
      J += 1
     Endif
    Endif
   Endif
  Next
  If J>1 : Raz SITDEB ,SITFIN : Endif
 Elsif L>3 & (tolower(right$(PARCOD(K-1),L-2))="deb" or tolower(right$(PARCOD(K-1),L-2))="str") & DEBFIN(K-1)=2
  SITDEB = VALEUR1(K-1) : # cas sans valeur multiple
  SITFIN = VALEUR2(K-1)
  If SITDEB<> ""
   Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'FCY'+string$(SITFIN<>"",">=")+string$(SITFIN="","=")+'"'+SITDEB+'"',"&") From GOBJSUB
  Endif
  If SITFIN<> ""
   Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'FCY<="'+SITFIN+'"',"&") From GOBJSUB
  Endif
 Else
  SITDEB = VALEUR1(K-1) : # cas sans valeur multiple pour un test plus bas
  SITFIN = VALEUR2(K-1)
  If SITDEB<> ""
   Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'FCY'+string$(SITFIN<>"",">=")+string$(SITFIN="","=")+'"'+SITDEB+'"',"&") From GOBJSUB
  Endif
  #103286
  #If SITDEB<> ""
  If SITFIN<> ""
   Call ADDCRIT(CRITSIT,ICRITSIT,"CRITSIT",'FCY<="'+SITFIN+'"',"&") From GOBJSUB
  Endif
 Endif
 OKSOC = 1
Endif
Return

#--------------------------------------------------------------#
# Appelé après l'instruction Report (demandé par DBA)
# On ne passe pas le contexte car la boucle est trop sensible
#--------------------------------------------------------------#

Subprog AP_IMPRIME(NBPAR,PARAMETRE)
Value Integer NBPAR
Value Char    PARAMETRE()(1..)
Local Char ACTION(20)
ACTION = "AP_IMPRIME" : Gosub ACTINI
End

#--------------------------------------------------------------#
# Action dans le traitement d'init
#--------------------------------------------------------------#

$ACTINI
GPE = 0
Local Integer OKTRT
If [F:ARP]TRTSPE<>""
 Call EXISTE_ADX("","",[F:ARP]TRTSPE,OKTRT) From ORDSYS
 If OKTRT
  Onerrgo RIEN
  Gosub ACTION From =[F:ARP]TRTSPE
  Onerrgo
 Endif
Endif
If !GPE & [F:ARP]TRTINI<>""
 Call EXISTE_ADX("","",[F:ARP]TRTINI,OKTRT) From ORDSYS
 If OKTRT
  Onerrgo RIEN
  Gosub ACTION From =[F:ARP]TRTINI
  Onerrgo
 Endif
Endif
Return

#--------------------------------------------------------------#
# Action dans le traitement applicatif AIMP3B
#--------------------------------------------------------------#

$ACTAPP
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","AIMP3B",PSUBB) From ORDSYS
Endif
If PSUBB
 Onerrgo RIEN
 Gosub ACTION From AIMP3B
 Onerrgo
Endif
Return

#--------------------------------------------------------------#
# Ecriture requête batch
#--------------------------------------------------------------#

Subprog REQUETE(DOSSIER,USER,DAT,TIM,SERVICE)
Value Char    DOSSIER
Value Char    USER
Value Date    DAT
Value Char    TIM
Value Char    SERVICE
Local Integer REQUETE
Local Char    ABRECR(GLONABR)(2)
ABRECR(0) = "RPT"
ABRECR(1) = "AIP"
Call CRERQT(DOSSIER,USER,"",0,"AIMP",1,DAT,TIM,SERVICE,ABRECR,REQUETE) From REQUETES
If GOK=1
 # Requête transmise au serveur
 Call MESSAGE(mess(29,134,1)+" ("+num$(REQUETE)+")") From GESECRAN
Endif
End

#--------------------------------------------------------------#
# Lecture requête batch
#--------------------------------------------------------------#

Subprog LEC_REQUETE
Local Char    ABRECR(GLONABR)(2)
Local Integer NUMREQ
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
ABRECR(0) = "RPT"
ABRECR(1) = "AIP"
If clalev([M:RPT])>0 : Raz [M:RPT] : Endif
If clalev([M:AIP])>0 : Raz [M:AIP] : Endif
#109897
#NUMREQ = val(getenv$("RQT_ENTREP"))
NUMREQ=val(GBATCHRQT)
Default File [ABL]
Filter [ABL] Where NUMREQ = [L]NUMREQ
Call GETPAR(ABRECR) From REQUETES
Filter [ABL]
End

