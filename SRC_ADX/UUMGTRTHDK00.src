###################################
$OUVRE_HDK
# Déclaration des variables communes de travail
Local Integer COMPTEUR, I, J

#déclaration des variables locales de travail
Local Char     WSOCIETE(GLONCPY),WSITE(GLONFCY)
Local Integer  WI, WJ, WJTUN, WRET , WCCE
Local Decimal  WCOURS
Local Char     WITMREF, WFICD(3), WFICD1(3), WFICE(3)
Local Decimal  WMNTCALC, WMONT
Local Integer  WVCRTYP
Local Char     WVCRNUM

Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".GLED"       [LED]

# Fichiers à ouvrir pour la valorisation des devis des commandes et des livraisons
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU0]
#Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
#Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]

Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".SFOOTINV"   [SFI]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]

Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".TAXLINK"    [TLK]
#Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]                : # Dde 81811 : Optimisation
Local File =[F:ADS]DOSSIER+".TABDEPAGIO" [TDA]

Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
NBTCO=nbrecord([TCO])
Local Char WTCOREF(GLONUOM*3)(0..NBTCO)
Local Decimal WTCOCOEUOM(0..NBTCO)
Raz WJ
For [TCO]
    # Chargement des éléments dans un tableau memoire
    WTCOREF(WJ)=[F:TCO]UOM1+"/"+[F:TCO]UOM2
    WTCOCOEUOM(WJ)=[F:TCO]COEUOM
    WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table AGRPCPY
Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]
Global Integer NBAGC : NBAGC=nbrecord([AGC])
Global Char WAGCGRP(GLONAGF)(0..NBAGC)
Global Char WAGCCPY(GLONCPY)(0..NBAGC)

Raz WJ
For [AGC] AGC1
  WAGCGRP(WJ)=[F:AGC]GRP
  WAGCCPY(WJ)=[F:AGC]CPY
  WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table TABRATVAT
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Global Integer NBTRA : NBTRA=nbrecord([TRA])
Global Char WTRAVAT(GLONVAT)(0..NBTRA)
Global Char WTRACPY(GLONCPY)(0..NBTRA)
Global Date WTRASTRDAT(0..NBTRA)
Global Decimal WTRAVATRAT(0..NBTRA)
Global Decimal WTRADEDRAT(0..NBTRA)
Global Decimal WTRAAMTTSD(0..NBTRA)
Global Integer WTRAVATEXEFLG(0..NBTRA)

Raz WJ
For [TRA]TRA0
    WTRAVAT   (WJ)=[F:TRA]VAT
    WTRACPY       (WJ)=[F:TRA]CPY
    WTRASTRDAT    (WJ)=[F:TRA]STRDAT
    WTRAVATRAT    (WJ)=[F:TRA]VATRAT
    WTRADEDRAT    (WJ)=[F:TRA]DEDRAT
    WTRAAMTTSD    (WJ)=[F:TRA]AMTTSD
    WTRAVATEXEFLG (WJ)=[F:TRA]VATEXEFLG
  WJ+=1
Next

# Dde 81811 : Optimisation : Chargement en mémoire de la table TABVAT
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Global Integer NBTVT : NBTVT=nbrecord([TVT])
Global Char WTVTVAT(GLONVAT)(0..NBTVT)
Global Integer WTVTVATCHA(0..NBTVT)
Global Integer WTVTVATBAS(0..NBTVT)
Global Integer WTVTVATTYP(0..NBTVT)
Raz WJ
For [TVT]
    # Chargement des éléments dans un tableau memoire
    WTVTVAT(WJ)=[F:TVT]VAT
    WTVTVATCHA(WJ)=[F:TVT]VATCHA
    WTVTVATBAS(WJ)=[F:TVT]VATBAS
    WTVTVATTYP(WJ)=[F:TVT]VATTYP
    WJ+=1
Next
# Dde 81811 : Optimisation

Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local Integer NBTUN : NBTUN=nbrecord([TUN])
Local Char WTUNUOM(GLONUOM)(0..NBTUN)
Local Integer WTUNUOMDEC(0..NBTUN)
Local Char WTUNUOMOLD(GLONUOM)
Raz WJTUN
Raz WJ
For [TUN]
    # Chargement des éléments dans un tableau memoire
    WTUNUOM(WJ)=[F:TUN]UOM
    WTUNUOMDEC(WJ)=[F:TUN]UOMDEC
    WJ+=1
Next

# Issue 74556 - 2011-07-04 by LD : chargement code activité PTX
Local File =[F:ADS]DOSSIER+".ACTIV"      [ACV]
Call SET_ACTIVPTX From TRTX3

# 100121 : Init GLOCUSATAX pour la valorisation
# --- Code activité "KUS" Localisation USA
Global Integer GACTKUS
Read [ACV] CODACT="KUS"
If !fstat
  GACTKUS=[F:ACV]FLACT
Else
  GACTKUS=0
Endif
# 100121

# 101380 : gbn
# --- activity code "LTA" Sage Sales Tax
Global Integer GACTLTA
Read [ACV] CODACT="LTA"
If !fstat
  GACTLTA=[F:ACV]FLACT
Else
  GACTLTA=0
Endif
# 101380

Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]

Local File =[F:ADS]DOSSIER+".SVCRVAT"    [SVV]
Local File =[F:ADS]DOSSIER+".SVCRFOOT"   [SVF]

Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]

#----- Définition et chargement des GLONxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

#Gbn-110408
Local Char WHISTFOLD(GLONADS)
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    WHISTFOLD=[F:ADS]DOSSIER
Else
    WHISTFOLD=[F:ADS]DOSREF
Endif
#Local Mask =[F:ADS]DOSSIER+".SIH0" [SIH0]
#Local Mask =[F:ADS]DOSSIER+".SIH1" [SIH1]
#Local Mask =[F:ADS]DOSSIER+".SIH2" [SIH2]
#Local Mask =[F:ADS]DOSSIER+".SIH4" [SIH4]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHV]
#Local Mask =[F:ADS]DOSSIER+".SIHV" [SIHX]
Local Mask =WHISTFOLD+".SIH0" [SIH0]
Local Mask =WHISTFOLD+".SIH1" [SIH1]
Local Mask =WHISTFOLD+".SIH2" [SIH2]
Local Mask =WHISTFOLD+".SIH4" [SIH4]
Local Mask =WHISTFOLD+".SIHV" [SIHV]
Local Mask =WHISTFOLD+".SIHV" [SIHX]
#Gbn-110408-End

#------
If dim(GLONVAT)<1  Global Shortint GLONVAT : Endif
Read [ATY] CODTYP="VAT"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONVAT=[F:ATY]LNGTYP

# Dde 81811 : Optimisation passage en global
Global Integer  WNBSFI
WNBSFI=nbrecord([SFI])
Global Integer  WSFINUM (0..WNBSFI)
Global Integer  WSFIAMTCOD (0..WNBSFI)
Global Char     WSFIDSP (GLONDSP) (0..WNBSFI)
Global Integer  WSFICLCBAS (0..WNBSFI)
Global Integer  WSFICLCORD (0..WNBSFI)
Global Char     WSFICCE (GLONCCE) (GOPTCANA,0..WNBSFI)
Global Char     WSFIVACITM(GLONADI) (0..WNBSFI)
Global Char     WSFICLCVACITM(GLONADI) (0..WNBSFI)
If GACTLTA : Global Char WSFISSTCOD(GLONADI) (0..WNBSFI) : Endif
Raz WJ
For [SFI]SFI0
    # Chargement des éléments de facturation dans un tableau memoire
    # --> Pour connaître le type de valeur : Taux/Montant
    WSFINUM(WJ)=[F:SFI]SFINUM
    WSFIAMTCOD(WJ)=[F:SFI]AMTCOD
    WSFIDSP(WJ)=[F:SFI]DSP
    WSFICLCBAS(WJ)=[F:SFI]CLCBAS
    WSFICLCORD(WJ)=[F:SFI]CLCORD
    WSFIVACITM(WJ)=[F:SFI]VACITM
    WSFICLCVACITM(WJ)=[F:SFI]CLCVACITM
    If GACTLTA : WSFISSTCOD(WJ)=[F:SFI]SSTCOD : Endif
    For WCCE=1 To GOPTCANA
        WSFICCE (WCCE-1,WJ)=[F:SFI]CCE(WCCE-1)
    Next I
    WJ+=1
Next

Gosub INISOC

Return

#################################
$RECUP_SFI
If WJ>0
    [F:SFI]SFINUM=WSFINUM(WJ-1)
    [F:SFI]AMTCOD=WSFIAMTCOD(WJ-1)
    [F:SFI]DSP=WSFIDSP(WJ-1)
    [F:SFI]CLCBAS=WSFICLCBAS(WJ-1)
    [F:SFI]CLCORD=WSFICLCORD(WJ-1)
    For WCCE=1 To GOPTCANA
        [F:SFI]CCE(WCCE-1)=WSFICCE(WCCE-1,WJ-1)
    Next I
Else
    Raz [F:SFI]
Endif
Return

########################################
$READ_ITM
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif
Return

###########################################

#-------------------------------------------------------------#
# Conversion quantité d"une unité vers une autre avec arrondi #
# ----------------------------------------------------------- #
# WUOM1 : Unité d'origine                                     #
# WUOM2 : Unité destination                                   #
# WQTY  : Quantité à convertir puis quantité convertie        #
#-------------------------------------------------------------#
$CONVERT_QTY
#----- Conversion quantité si unités différentes -----#
If WUOM1<>WUOM2
  Local    Decimal WCOEF
  WJ=find(WUOM1+"/"+WUOM2,WTCOREF(0..NBTCO))
  If WJ>0
      WCOEF=WTCOCOEUOM(WJ-1)
  Else
      WJ=find(WUOM2+"/"+WUOM1,WTCOREF(0..NBTCO))
      If WJ>0 & WTCOCOEUOM(WJ-1)<>0
        WCOEF=1/WTCOCOEUOM(WJ-1)
      Else
        WCOEF=1
      Endif
  Endif
  WQTY*=WCOEF
Endif
Gosub RECHTUN
Return

$RECHTUN
#----- Arrondi de la quantité -----#
If WTUNUOMOLD<>WUOM2
    If WUOM2>WTUNUOMOLD
    WJ=find(WUOM2,WTUNUOM(WJTUN..NBTUN))
    WJTUN+=WJ
    Else
    WJTUN=find(WUOM2,WTUNUOM(0..WJTUN))
    Endif
    WTUNUOMOLD=WUOM2
Endif
If WJTUN>0
    WQTY=arr(WQTY,10^-WTUNUOMDEC(WJTUN-1))
Endif
Return


##############################################################
## Init des tables société/sites                            ##
##############################################################
$INISOC

Local Integer LNBSOC : LNBSOC=rowcount([F:CPY])

Global Integer GSSTTAX(1..GDIMSOC) #108649.n

If LNBSOC>GDIMSOC
 GDIMSOC=LNBSOC+20
 Global Char    GSOC(GLONCPY)(1..GDIMSOC)
 Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
 Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
 Global Libelle GTYPSOC(1..GDIMSOC)
 Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
 Global Integer GSSTTAX(1..GDIMSOC) #108649.n
Endif

Raz GNBSOC
For [CPY]
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 If dim([F:CPY]ACCCUR)>0
  GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 Else
  GDEVSOC(GNBSOC) = ""
 Endif
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 If dim(GTYPSOC)>0
  GTYPSOC(GNBSOC) = [F:CPY]CPYLEGFLG
 Endif
 If dim(GGCMSOC)>0
  If dim([F:CPY]ACM)>0
   GGCMSOC(GNBSOC) = [F:CPY]ACM
  Else
   GGCMSOC(GNBSOC) = ""
  Endif
 Endif
 #108649.sn
 If GACTLTA & [F:CPY]SSTTAXACT = 2
   GSSTTAX(GNBSOC) = 1
 Else
   GSSTTAX(GNBSOC) = 0
 Endif
 #108649.en
Next

Local Integer LNBSIT : LNBSIT=rowcount([F:FCY])
If LNBSIT>GDIMSIT
 GDIMSIT=LNBSIT+20
 Global Char GSITE(GLONFCY)(1..GDIMSIT)
 Global Char GSOCSITE(GLONCPY)(1..GDIMSIT)
 Global Char GFINSITE(GLONFCY)(1..GDIMSIT)
Endif

Raz GNBSITE
For [FCY]
 GNBSITE += 1
 GSITE(GNBSITE)    = [F:FCY]FCY
 GSOCSITE(GNBSITE) = [F:FCY]LEGCPY
 GFINSITE(GNBSITE) = [F:FCY]FINRSPFCY
 #----------------------------------------------#
 # si le site financier n'est pas renseigné     #
 # dans ce cas le site est lui même financier   #
 #----------------------------------------------#
 If GFINSITE(GNBSITE)  = ""
  GFINSITE(GNBSITE) = [F:FCY]FCY
 Endif
Next

Return

# Dde 81811 : Optimisation
$LEC_VAT
    Local Integer WJ
    If [F:TVT]VAT<>WVAT
        Raz [F:TVT]
       WJ=find(WVAT,WTVTVAT(0..NBTVT))
        If WJ
            [F:TVT]VAT     = WTVTVAT(WJ-1)
            [F:TVT]VATCHA  = WTVTVATCHA(WJ-1)
            [F:TVT]VATBAS  = WTVTVATBAS(WJ-1)
            [F:TVT]VATTYP  = WTVTVATTYP(WJ-1)
        Else
            Return
        Endif
    Endif

    For WJ=NBTRA-1 To 0 Step -1
        If WTRACPY(WJ)=GSOCIETE & WTRAVAT(WJ)=WVAT & WTRASTRDAT(WJ)<=GBIDA1
                [F:TRA]VAT= WTRAVAT(WJ)
                [F:TRA]CPY       =  WTRACPY       (WJ)
                [F:TRA]STRDAT    =  WTRASTRDAT    (WJ)
                [F:TRA]VATRAT    =  WTRAVATRAT    (WJ)
                [F:TRA]DEDRAT    =  WTRADEDRAT    (WJ)
                [F:TRA]AMTTSD    =  WTRAAMTTSD    (WJ)
                [F:TRA]VATEXEFLG =  WTRAVATEXEFLG (WJ)
           Break
        Elsif WTRACPY(WJ)<GSOCIETE & WTRAVAT(WJ)=WVAT
            Break
        Elsif WTRAVAT(WJ)<WVAT
            Break
        Endif
    Next WJ
    If [F:TRA]VAT=""
        For WJ=NBTRA-1 To 0 Step -1
            If WTRACPY(WJ)="" & WTRAVAT(WJ)=WVAT & WTRASTRDAT(WJ)<=GBIDA1
                    [F:TRA]VAT= WTRAVAT(WJ)
                    [F:TRA]CPY       =  WTRACPY       (WJ)
                    [F:TRA]STRDAT    =  WTRASTRDAT    (WJ)
                    [F:TRA]VATRAT    =  WTRAVATRAT    (WJ)
                    [F:TRA]DEDRAT    =  WTRADEDRAT    (WJ)
                    [F:TRA]AMTTSD    =  WTRAAMTTSD    (WJ)
                    [F:TRA]VATEXEFLG =  WTRAVATEXEFLG (WJ)
               Break
            Elsif WTRAVAT(WJ)<WVAT
                Break
            Endif
        Next WJ
    Endif
Return
# Dde 81811 : Optimisation

