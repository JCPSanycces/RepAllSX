##############################################################################
## Validation des fonctions
##############################################################################
Call OUVRE_TRACE(mess(68,126,1)-"GESFCY") From LECFIC : # Validation des fonctions
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local File =DOSSIER+".AFONCTION" [AFC] , =DOSSIER+".AFCTPRF"   [AFP1] , =DOSSIER+".AFCTFCY"   [AFF]
&        , =DOSSIER+".AFCTFCT"   [AFT] , =DOSSIER+".FACILITY"  [FCY]
OK = 0
Read [AFC]CODINT="GESFCY"
If !fstat & [F:AFC]FCYAUZ=2
 Trbegin [AFF]
  Call MODIFONCTION("GESFCY",[F:AFC]TYP,2,[F:AFC]NBOPT,[F:AFC]FLAG,[F:AFC]TYP,1,[F:AFC]NBOPT,[F:AFC]FLAG) From SUBAFP2
 Commit
Endif
Close Local File
Return
