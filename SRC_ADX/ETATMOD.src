#<AdxTL>@(#)12.0.0.0 $Revision$
Call ETATMOD(GBIDI1)
End

Subprog ETATMOD(GROUPE)
Value Integer GROUPE
Local Char VALEUR(20), PARAM(30)(1..3)
PARAM(1) = ""
PARAM(2) = num$(GROUPE)
Call S_LIS_CHAR(VALEUR,PARAM,"ETATMOD","ETATMOD","") From GACTION
If VALEUR<>""
 Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"XYAIMP1") From GTRAITE
Endif
End

$ACTION
Case ACTION
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
Endcase
Return

$SEL_LISTE
Local File AREPORT [ARP] , ACTIV [ACV]
Local Integer GROUPE , DIME , SIZOL , SIZLIG
DIME = nbrecord([F:ARP])+10
Local Char    TEX(20)(1..DIME) , AUTSIT(10) , CRITLIS(250)
GROUPE = val(PARAM(2))
SIZCOL = 180
SIZLIG = 200
NBTEX = 0
CRITLIS = '(LAN=GLANGUE or MULLAN=2)'
If GROUPE<>0
 CRITLIS -= '& GRP=GROUPE'
Endif
CRITLIS -= '& EXEFLG<>2 & ENAFLG=2'
If GROUPE<>0
 Local Char    TEXTE(GLONDES)(1..DIME,1..2)
 Filter [ARP] Where evalue(CRITLIS)
 For [ARP]ARP1
  OK = 1
  If [F:ARP]CODACT<>""
   Read [ACV]CODACT=[F:ARP]CODACT
   If fstat or [F:ACV]FLACT<>2
    OK = 0
   Endif
  Endif
  If OK
   Call VERF_DROIT([F:ARP]RPTCOD,GUSER,OK,AUTSIT) From AIMP1
  Endif
  If OK
   NBTEX += 1
   TEX(NBTEX)   = [F:ARP]RPTCOD
   Call TEXTE([F:ARP]RPTDES,TEXTE(NBTEX,2)) From OBJDIV
   TEXTE(NBTEX,1) = [F:ARP]RPTCOD
   If NBTEX>=dim(TEXTE)-1 : Break : Endif
  Endif
 Next
 TIT(0) = mess(GROUPE,97,1)
 TIT(1) = mess(36,135,1) : # Code état
 TIT(2) = mess(30,109,1) : # Intitulé
Else
 Local Char    TEXTE(GLONDES)(1..DIME,1..3)
 Filter [ARP] Where evalue(CRITLIS) & RPTCOD>=PARAM(1)
 For [ARP]ARP0
  OK = 1
  If [F:ARP]CODACT<>""
   Read [ACV]CODACT=[F:ARP]CODACT
   If fstat or [F:ACV]FLACT<>2
    OK = 0
   Endif
  Endif
  If OK
   Call VERF_DROIT([F:ARP]RPTCOD,GUSER,OK,AUTSIT) From AIMP1
  Endif
  If OK
   NBTEX += 1
   TEX(NBTEX)   = [F:ARP]RPTCOD
   Call TEXTE([F:ARP]RPTDES,TEXTE(NBTEX,3)) From OBJDIV
   TEXTE(NBTEX,1) = mess(GRP,97,1)
   TEXTE(NBTEX,2) = [F:ARP]RPTCOD
   If NBTEX>=dim(TEXTE)-1 : Break : Endif
  Endif
 Next ARP
 TIT(0) = mess(1,135,1)  : # Choix état
 TIT(1) = mess(97,0,1)   : # Groupe état
 TIT(2) = mess(36,135,1) : # Code état
 TIT(3) = mess(30,109,1) : # Intitulé
Endif
Filter [ARP]
If NBTEX=0
 PARAM(1) = ""
Endif
Return

$VERF_LISTE
PARAM(1) = VALEUR
PARAM(2) = ""
PARAM(3) = num$(GROUPE)
Return

$FIN_LISTE
If GSTATUT=7
 PARAM(1) = ""
 PARAM(2) = ""
 PARAM(3) = ""
Endif
Return

