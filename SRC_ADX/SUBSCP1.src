#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du masque SCP1
########################################
Subprog AM_ASWALH(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR
Local Char SZLIB
Local Integer ICANUSE

  SZVALEUR = ""
  SZLIB = ""
  ICANUSE = 0
  If VALEUR = "" Then
    [M:SCP1]ASWALH = VALEUR
    [M:SCP1]ASWALHBAS = ""
    Affzo [M:SCP1]ASWALH
    End
  Endif
  SZVALEUR = VALEUR
  If GXSZCNDTYP = "" Then
    [M:SCP1]ASWALHBAS = ""
  Endif
  If GXSZCNDTYP = "ADI" Then
    #Vérifie si VALEUR correspond à un code de la table diverse
    Call CHKBAS(GXICNDTYP, SZVALEUR, "ADI", ICANUSE) From TRTSCP1
    If ICANUSE Then
      [M:SCP1]ASWALHBAS = VALEUR
      Call GET_LIB(GXICNDTYP, SZVALEUR, SZLIB) From CRM_UTIL
      VALEUR = SZLIB
    Else
      [M:SCP1]ASWALHBAS = ""
    Endif
  Endif
  If GXSZCNDTYP = "M" Then
    #Vérifie si VALEUR correspond à un code de menu local
    Call CHKBAS(GXICNDTYP, SZVALEUR, "M", ICANUSE) From TRTSCP1
    If ICANUSE Then
      [M:SCP1]ASWALHBAS = VALEUR
      VALEUR = mess(val(SZVALEUR), GXICNDTYP, 2)
    Else
      [M:SCP1]ASWALHBAS = ""
    Endif
  Endif
  GIMUSTSAVE = 1
  [M:SCP1]ASWALH = VALEUR
  Affzo [M:SCP1]ASWALH
End

########################################
Subprog AM_ASWNUM(VALEUR)
Variable Decimal VALEUR

  GIMUSTSAVE = 1
  [M:SCP1]ASWNUM = VALEUR
  Affzo [M:SCP1]ASWNUM
End

########################################
Subprog AM_ASWDAT(VALEUR)
Variable Date    VALEUR

  GIMUSTSAVE = 1
  [M:SCP1]ASWDAT = VALEUR
  Affzo [M:SCP1]ASWDAT
End
