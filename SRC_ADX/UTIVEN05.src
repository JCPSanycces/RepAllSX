#<AdxTL>@(#)8.0.0.0 $Revision$
#############################################################################
# UTIVEN05 : Utilitaire de remise à blanc de la qté         Module Vente    #
#            rupture ds les cdes et les en-cours (Bug 36498)                #  
# ------------------------------------------------------------------------- #
# Problème à résoudre :                                                     #
#   Les qtés rupture (SHTQTY et SHTQTYSTU) de SORDERQ et (SHTQTY) de ORDERS #
#       restent alimentées à tord après modification des allocations depuis #
#       la gestion des commandes (modif de la date d'expédition à reporter  #
#       dans BESDAT de STOALL)                                              #
#   Bug 36681 : Modification de l'utilitaire                                #
#        - Traiter également les Qtés allouées :                            #
#          Raz ALLQTY et ALLQTYSTU ds SORDERQ et ALLQTY ds ORDERS           #
#          s'il n'y a pas d'allocations dans STOALL                         #
#        - Ajout d'un flag simulation                                       #
#############################################################################

Call MAJ_UTIVEN05
End

##################################
Subprog MAJ_UTIVEN05
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
   Call EXE_UTIVEN05(DOSSIER)
Endif
End

##################################
Subprog EXE_UTIVEN05(DOSSIER)
Value Char DOSSIER

Local Integer WSIMFLG : WSIMFLG=2
Call OUINON(mess(6,115,1),WSIMFLG) From GESECRAN

Local Integer I

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIVEN05 : Liste des commandes mises à jour") From LECFIC  
Call ECR_TRACE("UTIVEN05 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SOQ])=0  Local File =DOSSIER+".SORDERQ"    [SOQ]  Endif
If clalev([F:ORD])=0  Local File =DOSSIER+".ORDERS"     [ORD]  Endif
If clalev([F:STA])=0  Local File =DOSSIER+".STOALL"     [STA]  Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Remise à 0 de la qté rupture dans les commandes",0) From GESECRAN 
If WSIMFLG=2 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I

#Dbgaff

#Local Char CRIT(50)
#CRIT='SOHNUM="CDE-2001-0619"'

# ----------------------------------------------------------------------------------- #
# Traitement des lignes de commandes ayant une qté rupture n'existant pas dans STOALL #
# ----------------------------------------------------------------------------------- #

Call DEBTRANS From GLOCK
Trbegin [SOQ]
# --> Lecture des lignes de commandes 
For [SOQ]SOQ3 Where DEMSTA=1 & SOQSTA<>3 & SHTQTYSTU<>0
    Filter [STA] Where VCRTYP=2 & VCRNUM=[F:SOQ]SOHNUM & VCRLIN=[F:SOQ]SOPLIN & VCRSEQ=[F:SOQ]SOQSEQ & find(ALLTYP, 4,5)
    Read [STA]STA1 First
    If fstat 
        # On a pas trouvé d'allocations ruptures alors que [F:SOQ]SHTQTYSTU est <> 0 : Il faut traiter la ligne
        If WSIMFLG=1
            Readlock [SOQ] Curr
            If fstat 
                Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
            Else
                Call ECR_TRACE("*** Ligne Commande :"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ),0) From GESECRAN
                # Remise à 0 de la qté rupture 
                Call ECR_TRACE("Qté rupture remise à 0 : "-num$([F:SOQ]SHTQTYSTU),0) From GESECRAN
                [F:SOQ]SHTQTY=0 : [F:SOQ]SHTQTYSTU=0
                # Remise à 0 de la qté rupture dans l'encours
                For [ORD]ORD0 Where WIPNUM=[F:SOQ]DEMNUM & ITMREF=[F:SOQ]ITMREF & SHTQTY<>0
                    Readlock [ORD] Curr
                    If fstat 
                        Call ECR_TRACE("File ORDERS"-num$([F:ORD]WIPTYP)-[F:SOQ]DEMNUM-[F:ORD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
                    Else
                        Call ECR_TRACE([F:SOQ]DEMNUM-":"-"En cours remis à 0 : "-num$([F:ORD]SHTQTY),0) From GESECRAN
                        Raz [F:ORD]SHTQTY
                        Rewrite [ORD]
                        If fstat
                            Call ECR_TRACE("File ORDERS"-num$([F:ORD]WIPTYP)-[F:SOQ]DEMNUM-[F:ORD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
                        Endif
                    Endif
                Next 
                Rewrite [SOQ]
                If fstat
                    Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                Else
                    I+=1
                Endif
            Endif
        Else
            Call ECR_TRACE("*** Ligne Commande :"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ),0) From GESECRAN
            Call ECR_TRACE(mess(107, 197,1)-":"-num$([F:SOQ]SHTQTYSTU),0) From GESECRAN
            For [ORD]ORD0 Where WIPNUM=[F:SOQ]DEMNUM & ITMREF=[F:SOQ]ITMREF & SHTQTY<>0
                Call ECR_TRACE([F:SOQ]DEMNUM-":"-mess(107, 197,1)-":"-num$([F:ORD]SHTQTY),0) From GESECRAN
            Next 
            I+=1
        Endif
    Endif
Next
Commit 

If I>0
   Call ECR_TRACE("Nbre de commandes traitées : "-num$(I),0) From GESECRAN
Endif

# ----------------------------------------------------------------------------------- #
# Traitement des lignes de commandes ayant une qté allouée n'existant pas dans STOALL #
# ----------------------------------------------------------------------------------- #
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Remise à 0 de la qté allouée dans les commandes",0) From GESECRAN 
If WSIMFLG=2 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
Call DEBTRANS From GLOCK
Trbegin [SOQ]
# --> Lecture des lignes de commandes 
For [SOQ]SOQ3 Where DEMSTA=1 & SOQSTA<>3 & ALLQTYSTU<>0
    Filter [STA] Where VCRTYP=2 & VCRNUM=[F:SOQ]SOHNUM & VCRLIN=[F:SOQ]SOPLIN & VCRSEQ=[F:SOQ]SOQSEQ & find(ALLTYP, 1,2)
    Read [STA]STA1 First
    If fstat 
        # On ne traite la ligne que si elle est gérée en stock :
        # Les kits et composants non gérés en stock ont une qté allouée renseignée non liée àune allocation
        If [F:SOQ]STOMGTCOD>1
            # On a pas trouvé d'allocations alors que [F:SOQ]ALLQTYSTU est <> 0 : Il faut traiter la ligne
            If WSIMFLG=1
                Readlock [SOQ] Curr
                If fstat 
                    Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                Else
                    Call ECR_TRACE("*** Ligne Commande :"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ),0) From GESECRAN
                    # Remise à 0 de la qté allouée
                    Call ECR_TRACE("Qté allouée remise à 0 : "-num$([F:SOQ]ALLQTYSTU),0) From GESECRAN
                    [F:SOQ]ALLQTY=0 : [F:SOQ]ALLQTYSTU=0
                    # Remise à 0 de la qté allouée dans l'encours
                    For [ORD]ORD0 Where WIPNUM=[F:SOQ]DEMNUM & ITMREF=[F:SOQ]ITMREF & ALLQTY<>0
                        Readlock [ORD] Curr
                        If fstat 
                            Call ECR_TRACE("File ORDERS"-num$([F:ORD]WIPTYP)-[F:SOQ]DEMNUM-[F:ORD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
                        Else
                            Call ECR_TRACE([F:SOQ]DEMNUM-":"-"En cours remis à 0 : "-num$([F:ORD]ALLQTY),0) From GESECRAN
                            Raz [F:ORD]ALLQTY
                            Rewrite [ORD]
                            If fstat
                                Call ECR_TRACE("File ORDERS"-num$([F:ORD]WIPTYP)-[F:SOQ]DEMNUM-[F:ORD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
                            Endif
                        Endif
                    Next 
                    Rewrite [SOQ]
                    If fstat
                        Call ECR_TRACE("File SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
                    Else
                        I+=1
                    Endif
                Endif
            Else
                Call ECR_TRACE("*** Ligne Commande :"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ),0) From GESECRAN
                Call ECR_TRACE(mess(106,197,1)-":"-num$([F:SOQ]ALLQTYSTU),0) From GESECRAN
                For [ORD]ORD0 Where WIPNUM=[F:SOQ]DEMNUM & ITMREF=[F:SOQ]ITMREF & ALLQTY<>0
                    Call ECR_TRACE([F:SOQ]DEMNUM-":"-mess(106, 197,1)-":"-num$([F:ORD]ALLQTY),0) From GESECRAN
                Next 
                I+=1
            Endif
        Endif
    Endif
Next
Commit 

If I>0
   Call ECR_TRACE("Nbre de commandes traitées : "-num$(I),0) From GESECRAN
Endif

$FIN_UTIVEN05
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


