#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_TXT  UTI process                                    PAY Module
#                Migration To U12 - Vnext version
#
# ==>  Update ATEXTRA with tables with translatable texts
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update ATEXTRA with tables with translatable texts") From LECFIC

  Call AMAJ_EMHRMAJ90_TXT(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog AMAJ_EMHRMAJ90_TXT(LDOSSIER)
Value Char LDOSSIER

  Onerrgo CYCLECHECKERROR
  Local Char TTABLE(13)(1..)
  Local Integer STAT : STAT = 1

  Call ECR_TRACE("EMHRMAJ90_TXT: Update ATEXTRA with tables with translatable texts",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_TXT: Start of process on : "+LDOSSIER,0) From GESECRAN

  Gosub REMOVE_OBJECTS
  Gosub TR_TEXTRA

  Call ECR_TRACE("EMHRMAJ90_TXT : End of process on : "+LDOSSIER,0) From GESECRAN

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_TXT: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$REMOVE_OBJECTS
  Call ECR_TRACE("EMHRMAJ90_TXT: Start removing objects",0) From GESECRAN
  If clalev([HROBJ])=0    : Local File =LDOSSIER+".AOBJET"  [HROBJ]    : Endif
  If clalev([HROBJTAB])=0 : Local File =LDOSSIER+".AOBJTAB" [HROBJTAB] : Endif
  If clalev([HROBJLST])=0 : Local File =LDOSSIER+".AOBJLST" [HROBJLST] : Endif

##PEVAN - 2018-02-13 - X3-XXX - START
#  Delete [F:HROBJ] Where 1=1
#  Delete [F:HROBJTAB] Where 1=1
#  Delete [F:HROBJLST] Where 1=1

  Delete [F:HROBJ] Where (len([F:HROBJ]CODACT) > 0 & (left$([F:HROBJ]CODACT,1) <> "X" & left$([F:HROBJ]CODACT,1) <> "Y" & left$([F:HROBJ]CODACT,1) <> "Z")) | len([F:HROBJ]CODACT) = 0
  Delete [F:HROBJTAB] Where (len([F:HROBJTAB]TABACT) > 0 & (left$([F:HROBJTAB]TABACT,1) <> "X" & left$([F:HROBJTAB]TABACT,1) <> "Y" & left$([F:HROBJTAB]TABACT,1) <> "Z")) | len([F:HROBJTAB]TABACT) = 0
  Delete [F:HROBJLST] Where (len([F:HROBJLST]ABREV) > 0 & (left$([F:HROBJLST]ABREV,1) <> "X" & left$([F:HROBJLST]ABREV,1) <> "Y" & left$([F:HROBJLST]ABREV,1) <> "Z")) | len([F:HROBJLST]ABREV) = 0
##PEVAN - 2018-02-13 - X3-XXX - END

  Close Local File [HROBJ],[HROBJTAB], [HROBJLST]
  Call ECR_TRACE("EMHRMAJ90_TXT: Done removing objects",0) From GESECRAN

Return

################
$TR_TEXTRA
Local Char W_TLAN(GLONLAN)(0..)
Local Char TABLEARRAY(250)(0..)
Local Integer W_NBLAN

Local Char PDES (50) (1..2)               :#Fields of descriptions
Local Char WCLE1(250) , WCLE2(250)
Local Char PCLE(GLONAVA)(1..16)           :#Fields of the index
Local Char WTMP_TABLE(30)
Local Char DOSLEGMIG(5)

Local Integer W_IL,W_KEY,COUNTER,TABLECOUNTER
Local Char W_VALTEXT(100),W_CLE1(100),W_CLE2(100)
Local Char TABLENAME(250)

  If clalev([WATB])=0 : Local File ATABLE  [WATB]              : Endif
  If clalev([TABZ])=0 : Local File ATABZON [TABZ]              : Endif
  If clalev([WATI])=0 : Local File ATABIND [WATI]              : Endif
  If clalev([WATZ])=0 : Local File =LDOSSIER+".ATABZON" [WATZ] : Endif
  If clalev([AXXX])=0 : Local File =LDOSSIER+".ATEXTRA" [AXXX] : Endif

  [L]DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)
  [L]W_NBLAN=func GET_LANFOLDER(LDOSSIER, W_TLAN)

  TABLECOUNTER=0
  Filter [F:TABZ] Where ([F:TABZ]CODTYP="AX3" | [F:TABZ]CODTYP="AX1")
  Call ECR_TRACE("[F:TABZ] rows " - num$(rowcount([F:TABZ])) ,0) From GESECRAN
  For [F:TABZ]
    If !find([F:TABZ]CODFIC,TABLEARRAY)
      Filter [F:WATZ] Where [F:WATZ]CODFIC = [F:TABZ]CODFIC and [F:WATZ]CODZONE = [F:TABZ]CODZONE and [F:WATZ]CODTYP <> [F:TABZ]CODTYP
      If rowcount([F:WATZ]) > 0
        TABLEARRAY(TABLECOUNTER) = [F:TABZ]CODFIC
          Call ECR_TRACE("TABLEARRAY(TABLECOUNTER) " - TABLEARRAY(TABLECOUNTER),0) From GESECRAN
        TABLECOUNTER += 1
      Endif
      Filter [F:WATZ]
    Endif
  Next

  Filter [F:TABZ]
  Filter [F:WATZ]

  For COUNTER = 0 To TABLECOUNTER
    TABLENAME = TABLEARRAY(COUNTER)
    If TABLENAME > ""
######################### DEBUG #########################
#      Delete [F:AXXX] Where [F:AXXX]CODFIC=TABLENAME
######################### DEBUG #########################
      Filter [F:AXXX] Where [F:AXXX]CODFIC=TABLENAME
      Call ECR_TRACE("Table to check: " + TABLENAME + ", number of rows in ATEXTRA for it: " + num$(rowcount([F:AXXX])),0) From GESECRAN
      If (rowcount([F:AXXX])=0)
        If filinfo(filpath("FIL",TABLENAME,"fde",LDOSSIER),0)>0
          Call ECR_TRACE("Starting with table " + TABLENAME + " ATEXTRA creation" ,0) From GESECRAN
          If clalev([F:WWWW]) : Close Local File [F:WWWW]                 : Endif
          If clalev([WWWW])=0 : Local File =LDOSSIER+"."+TABLENAME [WWWW] : Endif
          WTMP_TABLE=TABLENAME
          Gosub INICLEDES

          If PCLE(1)<>"" & (PDES(1)<>"" | PDES(2)<>"")
            For [F:WWWW]
              Raz W_CLE1, W_CLE2, W_VALTEXT
              W_CLE1=func GET_TABLEVALUE(PCLE(1))
              If PCLE(2)<>""
                W_CLE2=func GET_TABLEVALUE(PCLE(2))
              Endif
              If W_CLE1 = "**" : W_CLE1 = [L]DOSLEGMIG : Endif
              If W_CLE2 = "**" : W_CLE2 = [L]DOSLEGMIG : Endif

              For W_KEY = 1 To 2
                If PDES(W_KEY)<>""
                  W_VALTEXT= func GET_TABLEVALUE(PDES(W_KEY))
                  If W_VALTEXT<>"" & W_VALTEXT<>"||"
                    For  W_IL=0 To [L]W_NBLAN -1
                      Call ECR_TRACE(TABLENAME-"__"-PDES(W_KEY)-"___"-W_TLAN(W_IL)-"___"-W_VALTEXT-"___"-W_CLE1-"___"-W_CLE2,0) From GESECRAN
                      Raz [F:AXXX]
                      [F:AXXX]CODFIC = TABLENAME
                      [F:AXXX]ZONE   = PDES(W_KEY)
                      [F:AXXX]LANGUE = W_TLAN(W_IL)
                      [F:AXXX]TEXTE  = W_VALTEXT #Text value
                      [F:AXXX]IDENT1 = W_CLE1 #LEG
                      [F:AXXX]IDENT2 = W_CLE2 #COD
                      Write [F:AXXX]
                    Next W_IL
                  Endif
                Endif
              Next W_KEY
            Next  # [F:WWWW]
           Else
              Call ECR_TRACE("Not use"-PCLE(1)-"---"-PCLE(2)-": add in function GET_TABLEVALUE" ,0) From GESECRAN
          Endif
        Endif  # filinfo
      Else
        Call ECR_TRACE("Table " + TABLENAME + " has rows in ATEXTRA" ,0) From GESECRAN
      Endif
      Endif
    Filter [F:AXXX]
  Next

  If clalev([F:WWWW]) : Close Local File [F:WWWW] : Endif
  Close Local File [AXXX],[WATZ], [WATB],[TABZ],[WATI]

Return

Funprog GET_TABLEVALUE(CLE)
Variable Char CLE()
Local Char RES(100)

  Onerrgo EMPTY

  RES=evalue("[F:WWWW]"+CLE)
  If RES="||"
    Call ECR_TRACE("Field unknown"-CLE,1) From GESECRAN
  Endif

  Onerrgo

End RES

$EMPTY
  If CLE="LEG"
    RES="**"
  Else
    RES="||"
  Endif

Resume

$INICLEDES
  Raz PCLE, PDES
  #Descriptions
  Read [WATB]CODFIC = WTMP_TABLE
  If !fstat
   Read [TABZ]CODZONE = WTMP_TABLE;[F:WATB]INTITC
   If !fstat
    PDES(1)=[F:WATB]INTITC
   Endif
   Read [TABZ]CODZONE = WTMP_TABLE;[F:WATB]INTIT
   If !fstat
    PDES(2)=[F:WATB]INTIT
   Endif
   If  PDES(2)= PDES(1) : PDES(2)=""  : Endif
  Endif

  #Index
  Read [WATI]NUMLIG(2) = WTMP_TABLE;1
  If !fstat
   WCLE1  = [F:WATI]DESCRIPT
   NBCLE = 0
   While WCLE1<>""
    I1 = instr(1,WCLE1,"+")
    I2 = instr(1,WCLE1,"-")
    If I2
     If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
    Endif
    If I1
     WCLE2 = left$(WCLE1,I1-1)
     WCLE1 = right$(WCLE1,I1+1)
    Else
     WCLE2 = WCLE1
     WCLE1 = ""
    Endif
    NBCLE += 1
    PCLE(NBCLE) = WCLE2
   Wend
  Endif

Return

Funprog GET_LANFOLDER(LDOSSIER,TLAN)
Variable Char LDOSSIER
Variable Char TLAN()()
Local Integer RES
Local Integer I,NBMAX
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

  Read [ADS] DOSSIER=[L]LDOSSIER
  If !fstat
      NBMAX=dim([F:ADS]LAN)
      While(RES<NBMAX and [F:ADS]LAN(RES)<>"")
        TLAN(RES)=[F:ADS]LAN(RES)
        RES+=1
      Wend
  Endif

End RES

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_TXT(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_TXT(APPLI)
End

