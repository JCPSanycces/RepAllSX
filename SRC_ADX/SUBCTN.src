#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "CHANGE"      : Call CHANGE_AXX ("CONTAINERS", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

$LIENS
If  [M:CTN1]CTNMODTAR=0 :  [M:CTN1]CTNMODTAR =1 : Endif
# mm 10.07 - saisie manuelle du poids
If [M:CTN1]CTNSAIMAN = 0 : [M:CTN1]CTNSAIMAN =1 : Endif
Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="CONTAINERS" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]CTNDESAXX,"CONTAINERS","CTNDESAXX",[M]CTN,"") From ATEXTRA
Call MAJTEXTRA([M]CTNSHOAXX,"CONTAINERS","CTNSHOAXX",[M]CTN,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]CTNDESAXX,"CONTAINERS","CTNDESAXX",[M]CTN,"") From ATEXTRA
Call MAJTEXTRA([M]CTNSHOAXX,"CONTAINERS","CTNSHOAXX",[M]CTN,"") From ATEXTRA

Return

#############################################################
Subprog AM_CTNTYP(VALEUR)
Variable Integer VALEUR
If VALEUR =1
    # En cas d'emballage interne, on met le flag tare saisissable par défaut à non
    [M:CTN1]CTNMODTAR = 1
    # mm 10.07 - saisie manuelle du poids
    # En cas d'emballage interne, on met le flag saisie manuelle du poids par défaut à non
    [M:CTN1]CTNSAIMAN =1
Endif
End

#############################################################
Subprog AM_CTNMODTAR(VALEUR)
Variable Integer VALEUR
If [M:CTN1]CTNTYP=1 : Grizo [M:CTN1]CTNMODTAR : Else Actzo [M:CTN1]CTNMODTAR Endif
End

#############################################################
Subprog AV_CTNSAIMAN(VALEUR)
Variable Integer VALEUR
If [M:CTN1]CTNTYP=1 : Grizo [M:CTN1]CTNSAIMAN : Else Actzo [M:CTN1]CTNSAIMAN : Endif
End

#############################################################
Subprog AV_CTNMODTAR(VALEUR)
Variable Integer VALEUR
If [M:CTN1]CTNTYP=1 : Grizo [M:CTN1]CTNMODTAR : Else Actzo [M:CTN1]CTNMODTAR Endif
End

#CATUA X3-68664.sn
#Add master container checkbox and capacity fields
#############################################################
Subprog AM_CTNMST(VALEUR)
Variable Integer VALEUR
  If VALEUR<>2 : [M:CTN1]CTNCAP = 0 : Affzo[M:CTN1]CTNCAP Endif
End

#############################################################
Subprog AV_CTNCAP(VALEUR)
Variable Decimal VALEUR
  If [M:CTN1]CTNMST=2 : Actzo [M:CTN1]CTNCAP : Else Grizo[M:CTN1]CTNCAP Endif
End
#CATUA X3-68664.en

#CATUA X3-107668.sn
#############################################################
Subprog C_CTNMST(VALEUR)
Variable Integer VALEUR
  If VALEUR = CST_ANO & find(GREP,"","M")
    #Verify if record exists Workorder Materials table
    If !clalev([F:MFM]) Local File MFGMAT [MFM]  Endif
    Filter [MFM] Where CTN = [M:CTN1]CTN
    Look [MFM] First
    Filter [MFM]

    If !fstat
      GMESSAGE=mess(93,2324,1)
      mkstat=2
      End
    Endif

    #Verify if record exists Detail BOM table
    If !clalev([F:BOD]) Local File BOMD [BOD]  Endif
    Filter [BOD] Where CTN = [M:CTN1]CTN
    Look [BOD] First
    Filter [BOD]

    If !fstat
      GMESSAGE=mess(92,2324,1)
      mkstat=2
      End
    Endif
  Endif
End
#CATUA X3-107668.en

