#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe ORDERS - PROPERTIES
###################################################################################################
$STOFCY
  # Issue X3-34326 - 2017-04-26 by FGR
  Case [L]ARULE
    When "PROPAGATE" : Gosub STOFCY_PROPAGATE
  Endcase
Return

$STOFCY_PROPAGATE
Local Integer WRET

  # Issue X3-34326 - 2017-04-26 by FGR
  WRET = fmet this.LOAD_TECPJT()
Return

###################################################################################################
$WIPTYP
  Case [L]ARULE
    When "CONTROL"      : Gosub WIPTYP_CONTROL
  Endcase
Return

$WIPTYP_CONTROL
  If this.WIPTYP < 0 Then
    [L]ASTATUS = fmet this.ASETERROR("WIPTYP", mess(126,143,1) - "[" + this.WIPTYP + "]", [V]CST_AERROR)
  Endif
Return

###################################################################################################
$ATECORI
  Case [L]ARULE
    When "INIT"         : Gosub ATECORI_INIT
  Endcase
Return

$ATECORI_INIT
  this.ATECORI = 2
Return

###################################################################################################
$OPTFLG
  Case [L]ARULE
    When "INIT"         : Gosub OPTFLG_INIT
  Endcase
Return

$OPTFLG_INIT
  this.OPTFLG = 1
Return

