#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBPLMINT","PLMINT",4,"SPEPLMINT") From GTRAITE
End


######################################################################
# CONNECTITM : PLM Import des Articles                              #
######################################################################
$ACTION
Case ACTION
 When "IMP_ZONE"      : Gosub IMP_ZONE
Endcase
Return


$IMP_ZONE
If IMPZON = "NBITP"
    If [M:ITP]NBITP=0 : Raz [M:ITP] : Endif
Endif
Return
######################################################################
Subprog TRAITE(OS,FICCSV,FICCLI,CONPIT,CONREF,REJ,FICREJ,REF,FICREF,ERRG,ERRNOFIC)
Value Char OS(),FICCSV(),FICCLI(),CONPIT(),CONREF()
Value Integer REJ
Value Char FICREJ()
Value Integer REF
Value Char FICREF()
Variable Integer ERRG,ERRNOFIC

Local Integer ERR : ERR=0
Local Integer NOLIG : NOLIG=0
Local Integer OUVFICREJ: OUVFICREJ=0
Local Integer OUVFICREF: OUVFICREF=0

Local Clbfile LIGCLOB(10)
Local Clbfile LIGENTETE(10)
Local Integer ERRFIC : ERRFIC=0

If clalev ([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev ([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev ([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub INITPIVOT From CONNECTFCT

If clalev ([F:PDV]) = 0 : Local File PLMDEFVAL [PDV] : Endif
If clalev ([F:PPA]) = 0 : Local File PLMPAR [PPA] : Endif
Read [PPA]PPA0=CONREF
GIMPORT=1

 GCONITM_NBF+=1
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("==========================",0) From GESECRAN
 If FICCLI<>""
  GCONITM_FIC(GCONITM_NBF)=FICCLI
  Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
 Else
  GCONITM_FIC(GCONITM_NBF)=FICCSV
  Call ECR_TRACE(mess(38,115,1)-"|"+FICCSV,0) From GESECRAN : # Lecture du fichier
 Endif

 Gosub OUVFIC
 Onerrgo FIN_ERRGO
 Gosub LIREFIC
 If ERRFIC
    ERRG+=1 : ERRNOFIC+=1
    Call ECR_TRACE(mess(14,7710,1),1) From GESECRAN : # Lecture du fichier impossible
    Goto FIN
 Endif
 While !ERRFIC
     Gosub CHARGEPIVOT From CONNECTFCT
     If !ERR
         Gosub TRAITE_ITM
     Endif
     If ERR & REJ
        ERRG+=1
        # on doit ecrire dans le fichier des rejets
        Gosub ECR_REJ
     Endif
     ERR=0
     Gosub LIREFIC
 Wend

$FIN
 Onerrgo
 Gosub FERMEFIC
 GIMPORT=0
 adxium = SAVADXIUM
 adxifs = SAVADXIFS
 adxirs = SAVADXIRS
End
############
$FIN_ERRGO
 ERRG+=1 : ERRNOFIC+=1
 Call ECR_TRACE(mess(17,7710,1),1) From GESECRAN : # Erreur sur traitement d'une ligne du fichier
 Goto FIN
############

######################################################################
#Ouverture du fichier CSV
$OUVFIC
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openi FICCSV,0 Using [FCSV]
 adxifs=""
 adxirs=IRS
 #VPO 10/12/09 60608 si chinois , il faut UTF8
 If GLANGUE="CHI"
 adxium=GUTF8
 Else
 adxium=GASCII
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FCSV]
 Iomode adxirs adxirs Using [FCSV]
 Iomode adxium adxium Using [FCSV]
 If WPIVHEATYP<>1
    Rdseq LIGCLOB Using [FCSV]
    If fstat=0
        LIGENTETE=LIGCLOB
        Call FILE_UTF8_BOM(LIGENTETE) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
 Endif
Return

$LIREFIC
Rdseq LIGCLOB Using [FCSV]
If fstat<>0
    ERRFIC=1
Else
    If NOLIG=0  & WPIVHEATYP=1
       Call FILE_UTF8_BOM(LIGCLOB) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
    GCONITM_ENR+=1
    NOLIG+=1
Endif
Return

$FERMEFIC
 Openi Using [FCSV]
 Openo Using [FREJ]
 Openo Using [FREF]
Return

######################################################################
#Ouverture du fichier REJ
$OUVFICREJ
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREJ,0 Using [FREJ]
 adxifs=""
 adxirs=IRS
 #VPO 10/12/09 60608 si chinois , il faut UTF8
 If GLANGUE="CHI"
 adxium=GUTF8
 Else
 adxium=GASCII
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREJ]
 Iomode adxirs adxirs Using [FREJ]
 Iomode adxium adxium Using [FREJ]
 OUVFICREJ=1
 If WPIVHEATYP<>1
    Wrseq LIGENTETE Using [FREJ]
 Endif
Return

$ECR_REJ
If !OUVFICREJ
    Gosub OUVFICREJ
Endif
Wrseq LIGCLOB Using [FREJ]
GCONITM_REJ+=1
Return

######################################################################
#Ouverture du fichier REF
$OUVFICREF
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREF,0 Using [FREF]
 adxifs=""
 adxirs=IRS
 #VPO 10/12/09 60608 si chinois , il faut UTF8
 If GLANGUE="CHI"
 adxium=GUTF8
 Else
 adxium=GASCII
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREF]
 Iomode adxirs adxirs Using [FREF]
 Iomode adxium adxium Using [FREF]
 OUVFICREF=1
 If WPIVHEATYP<>1
    Wrseq "PLMITMREF;ITMREF" Using [FREF]
 Endif
Return

$ECR_REF
If REF
    If !OUVFICREF
        Gosub OUVFICREF
    Endif
    Wrseq func CONNECTFCT.GETVAL("ITMMASTER","PLMITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)+";"+[F:ITM]ITMREF Using [FREF]
Endif
Return


######################################################################
$INIVARNB
Global Integer GCONITM_NBF : GCONITM_NBF = 0 : #nombre de fichier ITM
Global Char    GCONITM_FIC(GDIMFIC)(1..1000) : Raz GCONITM_FIC
Global Integer GCONITM_ENR : GCONITM_ENR = 0 : #enreg lus
Global Integer GCONITM_NEW : GCONITM_NEW = 0 : #enreg importés/nouveaux
Global Integer GCONITM_MAJ : GCONITM_MAJ = 0 : #enreg importés/maj
Global Integer GCONITM_REJ : GCONITM_REJ = 0 : #enreg rejetés
Return

$SUPVARNB
  # Désallocation des variables globales
  If dim(GCONITM_NBF)>0 Then Kill GCONITM_NBF Endif
  If dim(GCONITM_FIC)>0 Then Kill GCONITM_FIC Endif
  If dim(GCONITM_ENR)>0 Then Kill GCONITM_ENR Endif
  If dim(GCONITM_NEW)>0 Then Kill GCONITM_NEW Endif
  If dim(GCONITM_MAJ)>0 Then Kill GCONITM_MAJ Endif
  If dim(GCONITM_REJ)>0 Then Kill GCONITM_REJ Endif
Return
######################################################################

$TRAITE_ITM
Onerrgo FIN_ERRGO_ITM
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Char    PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Char    OBJLIS(GLONAOB)(1..8)
Local Integer AMA(0..16) , RESTMSK(0..16)
Local Integer CRE, MODI, SUPPR, ISITE
Local Char    ERRMES(50)
Local Integer NRMASK , ILIS , RELIT
Local Integer PSPE, PSUB, PSPV, PSTD
Local Integer PIMP
Local Char    SYMBOLE(35)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16), CLE2(GLONID2)(0..16)
Local Char    SCLE2(GLONID2) , COUZON(GLONAVA)
Local Integer TPCLE1 , TPCLE2(0..16)
Local Char    SAVCLE1(GLONID1) , SAVCLE2(GLONID2)
Local Char    FILTRE(240) , FILTSUP(240) , CRITTAB(250)
Local Char    CRITERE(250) , FILROLE(250) , FILSUITE(250)
Local Integer ICRITERE , IFILROLE , IFILSUITE
Local Char    ACTION(20) , CHAINE(20) , REP(1)
Local Char    MESSA(250)
Local Char    IDENT(50), ABREV(GLONAOB), SITCUR(15)
Local Integer MA, CL , CLECUR, AFFICHE, AUTENA, OPTENA, OPTDOC , OKTRT,OK
Local Integer TUNNEL, VERROU
Local Integer NBMEN , NBRMEN , ETAMEN(1..60)
Local Char    CHMEN(30) , BOUT(1)
Local Char GCLEPLM(GLONPLM)
Local Char WFICITMREF(GLONITM)
Local Char WFICBPSNUM(GLONBPR)
Local Char WFICSTOFCY(GLONFCY)
Local Char WTCLCOD(GLONITG)
Local Char GREPPLM : # "C" ou "M"
Local Integer WGETREF

OK=1

ABREV="ITM"
# Issue 86381 - 2013-01-03 by RBA
GABREV=ABREV
#/ Issue 86381 - 2013-01-03 by RBA
ABFIC="ITM"
WINPROG="WGOITM"
# Issue 80297 - 2012-27-02 by RBA
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"OITM") From INTRUTILB

##  "WOITM SUBITM SPEITM SPVITM"
Call SETPROG("ITM",PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub DEFVAR From =WINPROG

# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif

Gosub OUVRE_MSK From GOBJET
For MA=0 To NBMASK
    Gosub RAZMASK From =WINPROG
Next MA
Gosub OUVRE From =PROGOBJ

ACTION="OUVRE"
# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
#Gosub ACTION From =PROGSUB
#Appel des actions OUVRE spécifiques et verticales
Gosub ACTIONG From SUBIMPOBJ

If !OK : Goto FIN_ITM_ERR : Endif

Global Integer  GSTK_PCUFLG                        : # Flag presence conditionnement 1 = presence
Raz GSTK_PCUFLG

If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif

Default File [F:ITM]
If [F:PIT]TYP=1 : #PLM Articles
GCLEPLM=func CONNECTFCT.GETVAL("ITMMASTER","PLMITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
Else
GCLEPLM=func CONNECTFCT.GETVAL("ITMMASTER","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If GCLEPLM=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_ITM_ERR
Endif

If !OK : Goto FIN_ITM_ERR : Endif

Raz [F:ITM]
WGETREF=0
Gosub SETCLE : #pour vider les zones
If [F:PIT]TYP=1 : #PLM Articles
    Read [F:ITM]ITM5=GCLEPLM
Else
    Read [F:ITM]ITM0=GCLEPLM
Endif
If fstat
    GREPPLM = "C"
    WFICITMREF=func CONNECTFCT.GETVAL("ITMMASTER","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
    If WFICITMREF=""
        WGETREF=1
        If len(GCLEPLM)<=GLONITM
            WFICITMREF=GCLEPLM
            WTCLCOD=func CONNECTFCT.GETVAL("ITMMASTER","TCLCOD",NBPIVZON,WPIVTABZON,WPIVVAL)
            If WTCLCOD<>""
                Read [ITG]ITG1=WTCLCOD;""
                If !fstat & [F:ITG]ITMREFCOU=""
                    Read [F:ITM]ITM0=WFICITMREF
                    If !fstat
                        If [F:ITM]PLMITMREF<>"" & GCLEPLM<>[F:ITM]PLMITMREF
                            Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(11,7710,1),1) From GESECRAN : # la référence article ne correspond pas
                            Goto FIN_ITM_ERR
                        Endif
                        GREPPLM = "M"
                    Else
                        Call SETVAL("ITMMASTER","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL,WPIVVALFIC,WFICITMREF) From CONNECTFCT
                    Endif
                Endif
            Endif
        Endif
    Else
        Read [F:ITM]ITM0=WFICITMREF
        If !fstat
            If [F:ITM]PLMITMREF<>"" & GCLEPLM<>[F:ITM]PLMITMREF
                Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(11,7710,1),1) From GESECRAN : # la référence article ne correspond pas
                Goto FIN_ITM_ERR
            Endif
            GREPPLM = "M"
        Endif
    Endif
Else
    GREPPLM = "M"
Endif

If GREPPLM = "C"
 CLECUR = 0
 CHAINE = "C"
 # Issue 74944 - 2011-07-12 by VPO : pb lors de l'insertion, supp de cette instruction
 #ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 #If !OK : Goto FIN_ITM_ERR : Endif
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK
   GREP = "C" : REP = "C"
   ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
   ###ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Endif
Else
 If [F:PIT]TYP=1 : #PLM Articles
     WFICITMREF=func CONNECTFCT.GETVAL("ITMMASTER","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
     If WFICITMREF<>"" & WFICITMREF<>[F:ITM]ITMREF
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(11,7710,1),1) From GESECRAN : # la référence article ne correspond pas
        Goto FIN_ITM_ERR
     Elsif WFICITMREF=""
        Call SETVAL("ITMMASTER","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL,WPIVVALFIC,[F:ITM]ITMREF) From CONNECTFCT
     Endif
 Endif
 Gosub SETCLE
 Gosub VERROU
 If !OK : Goto FIN_ITM_ERR : Endif
 Onerrgo FIN_ERRGO_VERROU
 nolign = 1
 For IMA=0 To NBMASK
  If AMA(IMA)
   Gosub CHARGEMSK From =WINPROG
  Endif
 Next IMA
 For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
 Next MA
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
 CLECUR = 1
 CHAINE = "M"
 # Issue 74944 - 2011-07-12 by VPO : pb lors de l'insertion, supp de cette instruction
 #ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M")
  OK = 1
  ACTION = "AVANT_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_AVANT_MOD" : Gosub ACTION  From SUBIMPOBJ
 Else
  OK = 0
 Endif
 GREP = "M" : REP = "M"
Endif

If !OK | GREP="" : Goto FIN_ITM_VERROU : Endif
#on affecte les valeurs du mask
If find("ITMMASTER"+"/"+"TCLCOD",WPIVTABZON(1..NBPIVZON))>0
 [M:ITM0]TCLCOD=func CONNECTFCT.GETVAL("ITMMASTER","TCLCOD",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif

If GREP="C"
    Gosub VALDEFMSK
    Call AM_TCLCOD([M:ITM0]TCLCOD) From =PROGSUB
Endif
nolign = 1
For MA=0 To NBMASK
    If ABMSK(MA)<>"ITP"
        Gosub SETMASK From =WINPROG
        For NOPIV=1 To NBPIVZON
            If pat(WPIVTABZON(NOPIV),"ITMMASTER/*")
                If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                   Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
                Endif
            Endif
        Next
    Endif
Next MA
If !OK : Goto FIN_ITM_VERROU : Endif
#cas particulier des itmdes1,itmdes2 et itmdes3
If find("ITMMASTER"+"/"+"ITMDES1",WPIVTABZON(1..NBPIVZON))>0
 [M:ITM0]DES1AXX=func CONNECTFCT.GETVAL("ITMMASTER","ITMDES1",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If find("ITMMASTER"+"/"+"ITMDES2",WPIVTABZON(1..NBPIVZON))>0
 [M:ITM1]DES2AXX=func CONNECTFCT.GETVAL("ITMMASTER","ITMDES2",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If find("ITMMASTER"+"/"+"ITMDES3",WPIVTABZON(1..NBPIVZON))>0
 [M:ITM1]DES3AXX=func CONNECTFCT.GETVAL("ITMMASTER","ITMDES3",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif

# Issue 93178 - 2013-10-14 by RBA : Traduction 1ere designation
Local Char WLAN(3)
Local Char WITMDES(30)
Local Char WITMDESZON(30)
If find("ITMMASTER"+"/"+"WLAN",WPIVTABZON(1..NBPIVZON))>0
  WLAN=func CONNECTFCT.GETVAL("ITMMASTER","WLAN",NBPIVZON,WPIVTABZON,WPIVVAL)
  #tester si la langue est OK
  If !clalev([F:TLA1]) : Local File TABLAN [TLA1] : Endif
    Read [TLA1]TLA0 = WLAN
    If fstat <> 0 #Pas trouvée --> erreur
      Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(2,150,1),1) From GESECRAN : # Langue inexistante
      Goto FIN_ITM_ERR
    Endif
  Close Local File [TLA1]
  #si oui alors on recupere la designation
  If find("ITMMASTER"+"/"+"WITMDES1",WPIVTABZON(1..NBPIVZON))>0
    WITMDESZON = "DES1AXX"
    WITMDES=func CONNECTFCT.GETVAL("ITMMASTER","WITMDES1",NBPIVZON,WPIVTABZON,WPIVVAL)
    #on insere ou update la designation
    If !clalev([F:AXX1]) : Local File ATEXTRA [AXX1] : Endif
     Read [AXX1]AXX0 = "ITMMASTER";WITMDESZON;WLAN;WFICITMREF;""
    If fstat = 5 #n'existe pas, on le cree
      [F:AXX1]CODFIC = "ITMMASTER"
      [F:AXX1]ZONE   = WITMDESZON
      [F:AXX1]LANGUE = WLAN
      [F:AXX1]IDENT1 = [M:ITM0]ITMREF
      [F:AXX1]IDENT2 = ""
      [F:AXX1]TEXTE  = WITMDES
      Write [AXX1]
    Else #existe, on update
      [F:AXX1]TEXTE  = WITMDES
      Rewrite [AXX1]
    Endif
    Close Local File [AXX1]
  Endif
Endif
#/93178

If [M:ITM3]PUU="" : [M:ITM3]PUU=[M:ITM3]STU : [M:ITM3]PUUSTUCOE=1 : Endif
If [M:ITM3]SAU="" : [M:ITM3]SAU=[M:ITM3]STU : [M:ITM3]SAUSTUCOE=1 : Endif
If [M:ITM3]SSU="" : [M:ITM3]SSU=[M:ITM3]STU : [M:ITM3]SSUSTUCOE=1 : Endif
If [M:ITM3]EEU="" : [M:ITM3]EEU=[M:ITM3]STU : [M:ITM3]EEUSTUCOE=1 : Endif

If !OK : Goto FIN_ITM_VERROU : Endif
# Issue 92956 - 2013-11-08 by RBA
Local Integer WNOITMBPS #to manage if there is a BPS set into the import file
WNOITMBPS = 1
#/ Issue 92956
Gosub AFFECTE_ITP
If !OK : Goto FIN_ITM_VERROU : Endif

For MA=0 To NBMASK
  nolign = 1
  TRTMSK="W0"+NOMMSK(MA)
  ##Infbox num$(MA)-TRTMSK
  If AMA(MA)
    Gosub SETMASK From =WINPROG
    mkstat=0
    GNBAFF=0
    #Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    # Issue 92956 - 2013-11-08 by RBA
    If WNOITMBPS <> 2
      Call SAIMSK("ITM","IMP_ZONE","CONNECTITM") From =TRTMSK
      If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSIMP,1) From GESECRAN : # erreur
      Endif
      Setmode
    Endif
#    Call SAIMSK("ITM","IMP_ZONE","CONNECTITM") From =TRTMSK
#
#    If mkstat
#        GREP = "" : REP="" : OK=0
#        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSIMP,1) From GESECRAN : # erreur
#    Endif
#    Setmode
#/ Issue 92956
  Endif
Next MA

# Issue 85435 - 2012-10-24 by RBA : gestion de la valorisation des TSICOD
If !clalev([F:TAB1]) : Local File ITMMASTER [TAB1] : Endif
Local Integer WI
For WI = 0 To dim([F:TAB1]TSICOD)-1
  If find("ITMMASTER"+"/"+"TSICOD("+num$(WI)+")",WPIVTABZON(1..NBPIVZON))>0
   Assign("[M:ITM1]TSICOD("+num$(WI)+")") With func CONNECTFCT.GETVAL("ITMMASTER","TSICOD("+num$(WI)+")",NBPIVZON,WPIVTABZON,WPIVVAL)
  Endif
Next
Close Local File [TAB1]
#/85435

If !OK : Goto FIN_ITM_VERROU : Endif

Gosub VALID
If !OK : Goto FIN_ITM_VERROU : Endif
Gosub DEVERROU

$FIN_ITM
Return
$FIN_ITM_VERROU
Gosub DEVERROU
$FIN_ITM_ERR
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Return

#####FIN onerrgo###########
$FIN_ERRGO_VERROU
Onerrgo
#on est en erreur sur la ligne
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,1) From GESECRAN : # erreur
If errn
    Call ECR_TRACE(errp+"("+num$(errl)+"):"-errmes$(errn),1) From GESECRAN
Endif
Gosub DEVERROU
$FIN_ERRGO_ITM
Onerrgo
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Resume


$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
###ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
###If !OK : Return : Endif
OK = 1
SYMBOLE = format$("K:3X",ABFIC)+GCLE
Lock =SYMBOLE With lockwait=0
If fstat
  Call ECR_TRACE(GCLEPLM-mess(61,141,1),1) From GESECRAN : # Fiche en cours de modification
  Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
  OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
SYMBOLE = format$("K:3X",ABFIC)+GCLE
If SYMBOLE <> ""
    Unlock =SYMBOLE
Endif
SYMBOLE = ""
Return

$SETCLE
CLECUR1 = [F:ITM]ITMREF
GCLE = [F:ITM]ITMREF
Return

$VALID
 Gosub DEFAUT From =PROGOBJ
 Raz mkstat
 OK = 1
 Gosub VALIDOBJ
 If !OK
   # ici on sort de subprog VALID avec GMESSAGE=vide, si OK a été razé via $ACTIONG
   # qui a mis le message dans la trace puis l’a razé
   If GMESSAGE="" : GMESSAGE=ACTION : Endif
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
   GMESSAGE=""
 Elsif GOK>=1
   If GREP="C"
        GCONITM_NEW += 1
        If WGETREF : Gosub ECR_REF : Endif
   Elsif GREP="M"
        GCONITM_MAJ += 1
   Endif
 Endif
 Raz GREP
Return

$VALIDOBJ
If GREP="C"
 ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(100,141,1),1) From GESECRAN : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"C",IDENT) From AWRK
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(101,141,1),1) From GESECRAN : # Erreur modification
 Else
  Gosub SETCLE
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub CRE_ITF
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub MAJ_ITF
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
# Issue 85436 - 2012-10-24 by RBA : en mise à jour d'article, possibilité de creer d'autres articles sites
 Gosub CRE_ITF2
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
#/85436
 Gosub MAJ_ITF
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#####################################################
$VALDEFMSK
nolign=1
For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    For [PDV]PDV0 Where ID=CONREF & CODFIC="ITMMASTER"
        If evalue("dim([M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With val([F:PDV]VALDEF)
            When 3
                Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With [F:PDV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With [F:PDV]VALDEF
            Endcase
        Endif
    Next
Next MA
Return

#####################################################
$VALDEFMSKITP
For [PDV]PDV0 Where ID=CONREF & CODFIC="ITMBPS"
    If evalue("dim([M:ITP]"+[F:PDV]CODZONE+")")>0
        TYP = evalue("type([M:ITP]"+[F:PDV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:ITP]"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
        When 3
            Assign "[M:ITP]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        When Default
           Assign "[M:ITP]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        Endcase
    Endif
    If evalue("dim([M:ITP]X"+[F:PDV]CODZONE+")")>0
        TYP = evalue("type([M:ITP]X"+[F:PDV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:ITP]X"+[F:PDV]CODZONE With val([F:PDV]VALDEF)
        When 3
            Assign "[M:ITP]X"+[F:PDV]CODZONE With [F:PDV]VALDEF
        When Default
           Assign "[M:ITP]X"+[F:PDV]CODZONE With [F:PDV]VALDEF
        Endcase
    Endif
    If evalue("dim([M:ITP]I"+[F:PDV]CODZONE+")")>0
        TYP = evalue("type([M:ITP]I"+[F:PDV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:ITP]I"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
        When 3
            Assign "[M:ITP]I"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        When Default
           Assign "[M:ITP]I"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        Endcase
    Endif
    If evalue("dim([M:ITP]ITP"+[F:PDV]CODZONE+")")>0
        TYP = evalue("type([M:ITP]ITP"+[F:PDV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:ITP]ITP"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
        When 3
            Assign "[M:ITP]ITP"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        When Default
           Assign "[M:ITP]ITP"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        Endcase
    Endif
Next
Return


#####################################################
$AFFECTE_ITP
If find("ITMBPS"+"/"+"BPSNUM",WPIVTABZON(1..NBPIVZON))<=0
    # Issue 92956 - 2013-11-08 by RBA
    WNOITMBPS = 2
    #/ Issue 92956
    Goto FINITP
Endif
WFICBPSNUM=func CONNECTFCT.GETVAL("ITMBPS","BPSNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
If WFICBPSNUM=""
    # Issue 92956 - 2013-11-08 by RBA
    WNOITMBPS = 2
    #/ Issue 92956
    Goto FINITP
Endif
If clalev([M:ITP])>0 : Default Mask [ITP] : Endif
NOITP=find(WFICBPSNUM,[M:ITP]BPSNUM(0..[M:ITP]NBITP))
If NOITP=0
   [M:ITP]NBITP+=1
   NOITP=[M:ITP]NBITP
   nolign=NOITP
   Call AP_BPSNUM([M:ITP]BPSNUM(nolign-1)) From SUBITP
   Gosub VALDEFMSKITP
Endif
nolign=NOITP
For NOPIV=1 To NBPIVZON
    If pat(WPIVTABZON(NOPIV),"ITMBPS/*")
        nolign=NOITP
        If evalue("dim([M:ITP]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:ITP]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
        If evalue("dim([M:ITP]X"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:ITP]X"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
        If evalue("dim([M:ITP]I"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:ITP]I"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
        If evalue("dim([M:ITP]ITP"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:ITP]ITP"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
    Endif
Next
$FINITP
If [M:ITP]NBITP=0 : Raz [M:ITP] : Endif
Return
#####################################################
$CRE_ITF
Local Char LFCY(GLONFCY)
Raz LFCY
If pat(GVERSION,"1.5.*")
Read [TBO]TBO0=[F:PPA]BOMALT
Else
Read [TBO]TBO0=2;[F:PPA]BOMALT
Endif
If !fstat
    If [F:TBO]FCY=""
        Gosub CRE_ALLITF
    Else
       Call CONTFCY([F:TBO]FCY) From CPTSUB # controle habilitation
       If !mkstat
           LFCY = [F:TBO]FCY
           Gosub CRE_ITMFACILIT From SUBITM
       Endif
    Endif
Endif
Return

# Issue 85436 - 2012-10-24 by RBA : en mise à jour d'article, possibilité de creer d'autres articles sites
$CRE_ITF2
Local Char LFCY(GLONFCY)
Raz LFCY
If pat(GVERSION,"1.5.*")
Read [TBO]TBO0=[F:PPA]BOMALT
Else
Read [TBO]TBO0=2;[F:PPA]BOMALT
Endif
If !fstat
  If [F:TBO]FCY=""
    Gosub CRE_ALLITF
  Else
    #d'abord verifier qu'on a pas deja créé cet article-site
    If !clalev([F:ITF1]) : Local File ITMFACILIT [ITF1] : Endif
    Read [ITF1]ITF0=[M:ITM0]ITMREF;[F:TBO]FCY
    If fstat
      Call CONTFCY([F:TBO]FCY) From CPTSUB # controle habilitation
      If !mkstat
          LFCY = [F:TBO]FCY
          Gosub CRE_ITMFACILIT From SUBITM
      Endif
    Endif
    Close Local File [ITF1]
  Endif
Endif
Return
#/85436

#--------------------------------------------#
# creation ITMFACILIT
#--------------------------------------------#
$CRE_ALLITF
For [FCY] Where WRHFLG=2
    Call CONTFCY([F:FCY]FCY) From CPTSUB # controle habilitation
    If !mkstat
       Look [ITF]ITF0 = [M:ITM0]ITMREF;[F:FCY]FCY
       If fstat
           LFCY = [F:FCY]FCY
           Gosub CRE_ITMFACILIT From SUBITM
           If GOK = 0
              Break
           Endif
       Endif
    Endif
Next
Filter [FCY]
Return

#####################################################
$MAJ_ITF
If find("ITMFACILIT"+"/"+"STOFCY",WPIVTABZON(1..NBPIVZON))<=0
    Return
Endif
WFICSTOFCY=func CONNECTFCT.GETVAL("ITMFACILIT","STOFCY",NBPIVZON,WPIVTABZON,WPIVVAL)
If WFICSTOFCY=""
    Return
Endif
Read [ITF]ITF0 = [M:ITM0]ITMREF;WFICSTOFCY
If fstat
    Call CONTFCY(WFICSTOFCY) From CPTSUB # controle habilitation
    If mkstat
        Return
    Endif
    LFCY = WFICSTOFCY
    Gosub CRE_ITMFACILIT From SUBITM
    If GOK=0 : Return : Endif
Endif
Raz [F:ITF]
Read [ITF]ITF0 = [M:ITM0]ITMREF;WFICSTOFCY
If !fstat
    For NOPIV=1 To NBPIVZON
        If pat(WPIVTABZON(NOPIV),"ITMFACILIT/*")
            If evalue("dim([F:ITF]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
               Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[F:ITF]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),GOK) From CONNECTFCT
            Endif
        Endif
    Next
    If GOK=0 : Return : Endif
    Rewrite [ITF]
    If fstat
       GOK = 0
       Call FSTA("ITF") From GLOCK
    Endif
Endif
Return
