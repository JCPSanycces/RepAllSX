Subprog AM_ADDALLDAY(VALEUR)
Variable Decimal VALEUR
  #TREATS THE DISCOUNT SETTINGS "Allowance days" and "Allways use discount".
  Call SETDISCOUNTSETTINGS(VALEUR, [M:DIA]ALWDISFLG) From PAYDEPLIB
End

Subprog AM_ALWDISFLG(VALEUR)
Variable Integer VALEUR
  #TREATS THE DISCOUNT SETTINGS "Allowance days" and "Allways use discount".
  Call SETDISCOUNTSETTINGS([M:DIA]ADDALLDAY, VALEUR) From PAYDEPLIB
End

