#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"PAYPROPAL"
 GFONCTION="PAYPROPAL" : Call AUTORIS From EXEFNC
Endif
GACTION = "PAYPROPAL"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYPROPAL","DGENPAY",4,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

#####################################
## Etiquettes de l'écran PAYPROPAL ##
#####################################
$SEL_TABLE
Case COUZON
 When "TPY" : # Type de règlement
  OBJET="TPY"
  CRITERE = "PAYPPS=2 & (SNS="+num$([M:DIA]SNS)+" | SNS=3)"

 When "POO" : # Pool bancaire
  OBJET="POO"
  CRITERE = "CPY='"+[M:DIA]CPY+"'"

 When "BAN" : # Banque
  OBJET="BAN"
  CRITERE = "CPY='"+[M:DIA]CPY+"'"
Endcase
Return

Subprog AS_TPY(VALEUR)
Variable Char VALEUR
If [M]ALLTPY=2 : mkstat=1 : Endif
End

# Si transaction typée SEPA, la devise doit être Euro
# Si transaction non typée SEPA, on grise la nature de paiement
Subprog AM_TPY(VALEUR)
Variable Char    VALEUR()
Local    Integer OKVII

  # EPANATPAY dépend du code activité VII
  Call ACTIV("VII",OKVII) From SUBACV
  If VALEUR<>""
    If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
    Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
    If [F:TPY]EPACDTTRF=G_OUI Then
      [M:DI2]CURPAY=GEURO
      Affzo [M:DI2]CURPAY
      If OKVII Then
        Actzo [M:DI2]EPANATPAY
      Endif
    Else
      If OKVII Then
        Grizo [M:DI2]EPANATPAY
      Endif
    Endif
  Endif
End

Subprog C_TPY(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
 Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TPY]PAYPPS<>2
  # type de reglement non paramétré pour cette fonction
  GMESSAGE = mess(29,117,1): mkstat = 2
 Elsif [F:TPY]SNS<>3 & [F:TPY]SNS<>[M]SNS
  # Sens Dépense/Recette/Indéterminé
  GMESSAGE=mess(35,105,1)-mess([F:TPY]SNS,661,1) : mkstat=2
 Elsif dim([F:TPY]ACS)>0
  Call CONTEXE([F:TPY]ACS) From CPTSUB
 Endif
Endif
End

Subprog AS_PAM(VALEUR)
Variable Char     VALEUR
If [M]ALLPAM=2 : mkstat=1 : Endif
End

Subprog C_PAM(VALEUR)
Variable Char     VALEUR
If [M]ALLTPY<>2
 If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
 Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
 If !find(VALEUR,[F:TPY]PAM(0..[F:TPY]NBRPAM-1))
  # Mode de règlement non autorisé pour ce type de règlement
  GMESSAGE=mess(82,117,1) : mkstat=2
 Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AP_CPY(VALEUR)
Variable Char     VALEUR
Call LECMAINPLAN(1,VALEUR,[M]COA) From CPTDIV
Call AM_CPY(VALEUR) From CPTTRT
GSOCIETE = VALEUR

########  SAM REF# 76609 added by angre 06/01/12 ########################
#call to a subprog wich sets the due date in discount section
#visible/invisible depending on the Parameter 'DCSDUDDAT' on CPY level
#########################################################################
Call SETSELECTIONSETTINGS(VALEUR, 0) From PAYDEPLIB

#Localisation Belge --str
If func AFNC.ACTIV("KBE")
  If func AFNC.PARAM("BELVCS",VALEUR)="2"
    [M:DI2]PAYDUD=2    :#-- 1 echeance par reglement
    Effzo [M:DI2]PAYDUDDAT,PAYSAC,PAYFCY
    Grizo [M:DI2]PAYDUD,PAYDUDDAT,PAYSAC,PAYFCY
  Else
    Actzo [M:DI2]PAYDUD,PAYDUDDAT,PAYSAC,PAYFCY
  Endif
  Affzo [M:DI2]PAYDUD,PAYDUDDAT,PAYSAC,PAYFCY
Endif
#Localisation Belge --end
End


Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
[M]CURCPY = [F:CPY]ACCCUR
If clalev([M:DI2])>0
 [DI2]CURDUDMAX = [F:CPY]ACCCUR
 [DI2]CURPAYMIN = [F:CPY]ACCCUR
 [DI2]CURMNTMAX = [F:CPY]ACCCUR
 Affzo [DI2]CURDUDMAX, CURPAYMIN, CURMNTMAX
Else
 [M]CURDUDMAX = [F:CPY]ACCCUR
 [M]CURPAYMIN = [F:CPY]ACCCUR
 [M]CURMNTMAX = [F:CPY]ACCCUR
 Affzo [M]CURDUDMAX, CURPAYMIN, CURMNTMAX
Endif
GCURLEG = [F:CPY]LEG
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2
 Effzo [M]FCY : Grizo [M]FCY
Else
 Actzo [M]FCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If [M]ALLFCY=2 : mkstat = 1 : Endif
End

Subprog AS_TYPBPR(VALEUR)
Variable Integer  VALEUR
If [M]ALLTYPBPR=2 : mkstat=1 : Endif
End

Subprog AS_BPRDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPR=2 : mkstat=1 : Endif
End

Subprog AS_BPRFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPR=2 : mkstat=1 : Endif
If VALEUR="" | VALEUR<[M]BPRDEB : VALEUR=[M]BPRDEB : Endif
End

Subprog C_BPRFIN(VALEUR)
Variable Char VALEUR()
If VALEUR<>"" & VALEUR<[M]BPRDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char     VALEUR
If [M]GRPSAC<>"" : mkstat=1 : Endif
End

Subprog C_SAC(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
End

Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAC]GAC1 = [M:DIA]COA;VALEUR
 If !fstat : [M:DI1]SACACC=[F:GAC]ACC : Else : Raz [M:DI1]SACACC : Endif
Else
 Raz [M:DI1]SACACC
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
If [M]GRPCUR<>"" : mkstat=1 : Endif
End

# Si transaction typée SEPA, la devise doit être Euro
Subprog C_CURPAY(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" and [M]ALLTPY<>2 Then
    If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
    Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
    If [F:TPY]EPACDTTRF=2 and VALEUR<>GEURO Then
      GMESSAGE=mess(243,117,1)-GEURO : # Devise incompatible avec la transaction. La devise doit être EUR
      mkstat=2
    Endif
  Endif
End

Subprog C_BAN(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 # Contrôle bloquant de la banque en fonction du tiers supprimé (bug 3563)
 If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If dim([F:BAN]ACS)>0
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 # Contrôle société
 If [F:BAN]CPY<>[M]CPY
  # Cette banque appartient à la société
  GMESSAGE = mess(42,121,1)-[F:BAN]CPY : mkstat=2 : End
 Endif
 If [M]ALLTPY<>2
  If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
  Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
  If [F:TPY]EPACDTTRF=2
   If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY]  : Endif
   Call LEC_TCY([F:BAN]CRY) From CPTLEC
   If !fstat & [F:TCY]FLGSEPA<>2 : GMESSAGE=mess(267,117,1) : mkstat = 2 : End : Endif
  Endif
 Endif

 # Banque dédiée à un site -> on force le site
 If [F:BAN]FCY<>"" & [F:BAN]FCY<>[M]FCYPAY
  [M]FCYPAY = [F:BAN]FCY
  Affzo FCYPAY
 Endif
 Effzo POO
 Grizo POO,ALLMOD
Else
 Actzo POO
 If [M]MNTMAX=0
  Grizo ALLMOD
 Else
  Actzo ALLMOD
 Endif
Endif
End

Subprog AS_POO(VALEUR)
Variable Char     VALEUR
If [M]BAN<>"" : mkstat=1 : Endif
End

Subprog C_POO(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 If !clalev([F:POO]) : Local File POOL [POO] : Endif
 If !clalev([F:BAN]): Local File BANK [BAN] : Endif
 Call CONTROLE("POO","",VALEUR,"",mkstat) From CONTOBJ
 If !mkstat
  For [POO]POO0 Where POO=VALEUR
   Call LECTURE("BAN",[F:POO]BAN,"") From CONTOBJ
   If dim([F:BAN]ACS)>0
    Call CONTEXE([F:BAN]ACS) From CPTSUB
    If mkstat : Break : Endif
   Endif
   # GH 14/10/99 Pool bancaire POO \ Paramétrage à revoir
   If [F:BAN]CPY<>[F:POO]CPY | ([F:POO]FCY="" & [F:BAN]FCY<>"")
&     | ([F:POO]FCY<>"" & [F:BAN]FCY<>"" & [F:BAN]FCY<>[F:POO]FCY)
    GMESSAGE=mess(54,15,1)-VALEUR+"\"+mess(86,105,1) : mkstat=2 : Break
   Endif
  Next : # [POO]
  If mkstat : End : Endif
  # Contrôle société
  If [F:POO]CPY<>[M]CPY
   # Société
   GMESSAGE = mess(2,116,1)-[F:POO]CPY : mkstat=2 : End
  Endif
  # Pool dédié à un site -> on force le site
  If [F:POO]FCY<>"" & [F:POO]FCY<>[M]FCYPAY
   [M]FCYPAY = [F:POO]FCY
   Affzo FCYPAY
  Endif
 Endif
Elsif [M]BAN=""
 If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
 # Ni une banque ni un pool n'ont été saisis -> contrôle que la banque n'est
 # pas obligatoire pour un type de règlement
 If [M]ALLTPY<>2
  Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
  Gosub TEST_BAN_TPY
 Else
  If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
  If !clalev([F:FGR])  : Local File FACGROUP   [FGR]  : Endif
  If !clalev([F:AGC])  : Local File AGRPCPY    [AGC]  : Endif
  Local Integer OK
  Filter [TPY] Where LEG=GCURLEG | LEG="" Order By Key CLE=PAYTYP Asc ; LEG Desc
  For [TPY]CLE(1)
   [L]OK=1
   If [F:TPY]SNS<>[M]SNS | [F:TPY]PAYPPS<>2 | [F:TPY]BANCSH<>1 | [F:TPY]ENAFLG<>2 : [L]OK=0 : Endif
   If [L]OK & [F:TPY]GFY<>""
    If [M]FCY<>""
     Look [FGR]FGR0=[F:TPY]GFY;[M]FCY
     If fstat : [L]OK=0 : Else : [L]OK=1 : Endif
    Else
     Look [AGC]AGC0=[F:TPY]GFY;[M]CPY
     If !fstat
      [L]OK=1
     Else
      [L]OK = 0
      For [FCY] Where LEGCPY=[M]CPY
       Look [FGR]FGR0=[F:TPY]GFY;[F:FCY]FCY
       If !fstat
        [L]OK = 1 : Break
       Endif
      Next
     Endif
    Endif
   Endif
   If [L]OK & [F:TPY]ACS<>""
    Call CONTEXE([F:TPY]ACS) From CPTSUB
    If !mkstat : [L]OK=1 : Else mkstat=0 : [L]OK=0 : GMESSAGE="" : Endif
   Endif
   If [L]OK
    Gosub TEST_BAN_TPY
    If mkstat : Break : Endif
   Endif
  Next
  Filter [TPY]
 Endif
Endif
End

$TEST_BAN_TPY
If [F:TPY]DACBAN=1
 # Banque obligatoire pour type de règlement [F:TPY]PAYTYP
 GMESSAGE=mess(84,117,1)-[F:TPY]PAYTYP : mkstat=2
Endif
Return

Subprog AS_ALLMOD(VALEUR)
Variable Integer  VALEUR
If [M]POO="" or ![M]MNTMAX : mkstat=1 : Endif
End

Subprog C_PAYDUD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]PAYDUDDAT = 1
 [M]PAYSAC    = 1
 [M]PAYFCY    = 1
 Effzo PAYDUDDAT,PAYSAC,PAYFCY
 Grizo PAYDUDDAT,PAYSAC,PAYFCY
Else
 Actzo PAYDUDDAT,PAYSAC,PAYFCY
Endif
End

Subprog AS_PAYDUDDAT(VALEUR)
Variable Integer  VALEUR
# Si type de règlt géré par date échéance -> 1 règlt / date d'échéance
If [M]PAYDUD=2 : mkstat=1 : End : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If [M]ALLTPY<>2
 Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
 If fstat=0 & [F:TPY]DUDFLG=2 : VALEUR=2 : mkstat=2 : Endif
Else
 Filter [TPY] Where (LEG=GCURLEG | LEG="") & PAYPPS=2 & DUDFLG<>2 Order By Key CLE=PAYTYP Asc ; LEG Desc
 Read [TPY]CLE(1) First
 Filter [TPY]
 If fstat>2 : VALEUR=2 : mkstat=2 : Endif
Endif
End

Subprog AS_PAYSAC(VALEUR)
Variable Integer  VALEUR
If [M]PAYDUD=2 : mkstat=1 : Endif
End

Subprog AS_PAYFCY(VALEUR)
Variable Integer  VALEUR
If [M]PAYDUD=2 : mkstat=1 : Endif
End

# Obligatoire si risque de générer des règlements avec des échéances
# de sites différents.
Subprog AS_FCYPAY(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]ALLFCY=2 & [M]PAYDUD<>2 & [M]PAYFCY<>2
 VALEUR=GFCYDEF
Endif
End

Subprog C_FCYPAY(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 Call CONTFCYCPY(VALEUR,[M]CPY) From CPTSUB
 If mkstat : End : Endif
Endif
If VALEUR="" & [M]ALLFCY=2 & [M]PAYDUD<>2 & [M]PAYFCY<>2
 # Zone obligatoire
 GMESSAGE=mess(10,123,1) : mkstat=2 : End
Endif
If [M]BAN<>""
 If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
 Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
 If [F:BAN]FCY<>"" & [F:BAN]FCY<>VALEUR
  # Banque du site
  GMESSAGE = [M]BAN-":"-mess(13,117,1)-[F:BAN]FCY : mkstat=2 : End
 Endif
Elsif [M]POO<>""
 If clalev([F:POO])=0 : Local File POOL [POO] : Endif
 Call LECTURE("POO",[M]POO,"") From CONTOBJ
 If [F:POO]FCY<>"" & [F:POO]FCY<>VALEUR
  # Pool du site
  GMESSAGE = [M]POO-":"-mess(32,121,1)-[F:POO]FCY : mkstat=2 : End
 Endif
Endif
If VALEUR<>""
 Local Char PARAM(1)
 # OD inter-sites
 Call PARAM(VALEUR,"SEVFCYENT",PARAM) From ADOVAL
 If [L]PARAM="1" :#OD inter-site interdit
  If [M]ALLFCY=2
   [M]ALLFCY = 1
   [M]FCY    = VALEUR
   If clalev([M:DI1])>0
    Affzo [DI1]ALLFCY, FCY
    Actzo [DI1]FCY
   Else
    Affzo [M]ALLFCY, FCY
    Actzo [M]FCY
   Endif
  Elsif [M]FCY<>VALEUR
   # OD inter sites interdit
   GMESSAGE = VALEUR-mess(30,121,1) : mkstat=2
  Endif
 Endif
Endif
End

Subprog C_SACPAY(VALEUR)
Variable Char     VALEUR
Local Char PARAM(1),SITE(GLONFCY)
If VALEUR<>""
 # Contrôle autorisations
 If [M]ALLTYPBPR=1 | [M]ALLBPR=1 :# Un type de tiers ou un tiers
  Call C_SAC(VALEUR)
  If mkstat : End : Endif
 Endif
Endif
# OD inter-collectifs
If [M]FCYPAY<>""
 Call PARAM([M]FCYPAY,"SEVBPRENT",PARAM) From ADOVAL
 [L]SITE = [M]FCYPAY
Elsif [M]ALLFCY=1
 Call PARAM([M]FCY,"SEVBPRENT",PARAM) From ADOVAL
 [L]SITE = [M]FCY
Else
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 For [FCY]FCY1 Where LEGCPY=[M]CPY
  Call PARAM([F:FCY]FCY,"SEVBPRENT",PARAM) From ADOVAL
  If [L]PARAM="1" : [L]SITE = [F:FCY]FCY : Break : Endif
 Next
Endif
If [L]PARAM="1" :# OD inter-collectifs interdit -> 1 collectif/règlement
 If VALEUR<>""
  If [M]GRPSAC<>"" | ([M]SAC<>"" & [M]SAC<>VALEUR)
   # OD inter collectifs interdit
   GMESSAGE = [L]SITE-mess(31,121,1) : mkstat=2 : End
  Else
   [M]SAC = VALEUR
   If clalev([M:DI1])>0
    Affzo [DI1]SAC
   Else
    Affzo [M]SAC
   Endif
  Endif
 Elsif [M]PAYDUD<>2 & [M]PAYSAC<>2 & [M]SAC=""
  [M]PAYSAC=2
  Affzo PAYSAC
 Endif
Endif
If VALEUR="" & [M]PAYSAC<>2
 If !find([M]TYPBPR,1,2) : [M]PAYSAC=2 : Affzo PAYSAC
 Endif
Endif
End

Subprog AM_SACPAY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAC]GAC1 = [M:DIA]COA;VALEUR
 If !fstat : [M:DI2]SACPAYACC=[F:GAC]ACC : Else : Raz [M:DI2]SACPAYACC : Endif
Else
 Raz [M:DI1]SACACC
Endif
End

Subprog AS_ACCDAT(VALEUR)
Variable Date     VALEUR
# Si type de règlt géré par date échéance -> 1 règlt / date d'échéance
# Si (en plus) 1ère comptabilisation = Remise en banque -> Date du règlt généré = [DUD]DUDDAT
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If [M]ALLTPY<>2
 Call LEC_TPY_LEG(GCURLEG,[M]TPY) From CPTLEC
 If fstat=0 & [F:TPY]DUDFLG=2 & [F:TPY]STA3<>2 & [F:TPY]STA8<>2 : mkstat=1 : Endif
Else
 Filter [TPY] Where (LEG=GCURLEG | LEG="") & PAYPPS=2 & (DUDFLG<>2 | [F:TPY]STA3=2 | [F:TPY]STA8=2) Order By Key CLE=PAYTYP Asc ; LEG Desc
 Read [TPY]CLE(1) First
 Filter [TPY]
 If fstat>2 : mkstat=1 : Endif
Endif
End

Subprog C_ACCDAT(VALEUR)
Variable Date VALEUR
Local Integer OK
Local Char DEV(GLONCUR)
# Dans ce cas , pas de test de GREP creation car on est toujours en création d'une propo auto
# de réglement, on fait tjs le test sur la date comptable.
MODULE = 3
Call CTLDATMOD(MODULE,VALEUR,[M]CPY) From CPTSUB
If mkstat : End : Endif

If VALEUR<>[0/0/0]
 Call VERF_DAT([M]CPY,VALEUR,OK)
 If !OK : mkstat=2 : End : Endif
 If [M]BAN<>""
  Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
  If [M]CURPAY<>""
   DEV = [M]CURPAY
  Else
   DEV = [F:BAN]CUR
  Endif
  Call CONTDEV(DEV,VALEUR) From TRTDEV
  If mkstat : End : Endif
  If [F:BAN]CHGDAT<>[0/0/0] & VALEUR>=[F:BAN]CHGDAT
   [M]CURPAY = [F:BAN]CUR
   Affzo [M]CURPAY
  Endif
 Endif
Endif
End

Subprog VERF_DAT(SOC,DAT,OK)
Value Char SOC()
Value Date DAT
Variable Integer OK
Local Decimal EXE, PER
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
Call SETMAINREF(SOC,GTYPGEN,GTYPANA) From CPTDIV
Call GETEXE(SOC,GTYPGEN,DAT,EXE) From CPTSUB
If !EXE | [F:FIY]FIYSTA<>2
 # Exercice non ouvert
 GMESSAGE=mess(20,101,1) : OK=0 : End
Endif
Call GETPERSOC(SOC,GTYPGEN,DAT,EXE,PER) From CPTSUB
If !PER | [F:PER]PERSTA<>2
 # Période non ouverte
 GMESSAGE=mess(35,101,1) : OK=0 : End
Endif
OK=2
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
End

Subprog AS_PCEDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
End

Subprog AS_PCEFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
If VALEUR="" | VALEUR<[M]PCEDEB : VALEUR=[M]PCEDEB : Endif
End

Subprog C_PCEFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]PCEDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

Subprog C_ALLTPY(VALEUR)
Variable Integer VALEUR
Local    Integer OKVII
If VALEUR=2
 Effzo TPY : Grizo TPY
Else
 Actzo TPY
Endif
# FQ63528 - MABON 25/03/10 - EPANATPAY dépend du code activité VII
Call ACTIV("VII",OKVII) From SUBACV
If OKVII Then
  # MABON FQ56469 - 25/09/09 - Si toute transaction et aucune typée SEPA, la nature de paiement doit être grisée
  If VALEUR=2 Then
    Filter [F:TPY] Where EPACDTTRF=G_OUI
    If rowcount([F:TPY])=0 Then
      Grizo [M:DI2]EPANATPAY
    Else
      Actzo [M:DI2]EPANATPAY
    Endif
    Filter [F:TPY]
  Endif
Endif
End

Subprog C_ALLPAM(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo PAM : Grizo PAM
Else
 Actzo PAM
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTYPBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYPBPR : Grizo TYPBPR
Else
 Actzo TYPBPR
Endif
End

Subprog C_ALLBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BPRDEB, BPRFIN : Grizo BPRDEB, BPRFIN
Else
 Actzo BPRDEB, BPRFIN
Endif
End

Subprog C_GRPSAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo SAC : Grizo SAC
Else
 Actzo SAC
Endif
End

Subprog C_GRPCUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo CUR : Grizo CUR
Else
 Actzo CUR
Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP,PCEDEB,PCEFIN : Grizo TYP,PCEDEB,PCEFIN
Else
 Actzo TYP,PCEDEB,PCEFIN
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End

Subprog AS_USR(VALEUR)
Variable Char    VALEUR()
If [M]ALLUSR = 2 : VALEUR="" : mkstat = 2
Elsif VALEUR="" : VALEUR = GUSER
Endif
End

$GRISE
If [M:DI2]BAN<>""
 Effzo [DI2]POO
 Grizo [DI2]POO
Else
 Actzo [DI2]POO
Endif
If [M:DI2]PAYDUD=2
 Effzo [DI2]PAYDUDDAT,PAYSAC,PAYFCY
 Grizo [DI2]PAYDUDDAT,PAYSAC,PAYFCY
Else
 Actzo [DI2]PAYDUDDAT,PAYSAC,PAYFCY
Endif
If [M:DI1]ALLUSR=2
 Effzo [DI1]USR : Grizo [DI1]USR
Else
 Actzo [DI1]USR
Endif
If [M:DI1]ALLPAM=2
 Effzo [DI1]PAM : Grizo [DI1]PAM
Else
 Actzo [DI1]PAM
Endif
If [M:DI1]ALLFCY=2
 Effzo [DI1]FCY : Grizo [DI1]FCY
Else
 Actzo [DI1]FCY
Endif
If [M:DI1]ALLTYPBPR=2
 Effzo [DI1]TYPBPR : Grizo [DI1]TYPBPR
Else
 Actzo [DI1]TYPBPR
Endif
If [M:DI1]ALLBPR=2
 Effzo [DI1]BPRDEB, BPRFIN : Grizo [DI1]BPRDEB, BPRFIN
Else
 Actzo [DI1]BPRDEB, BPRFIN
Endif
If [M:DI1]GRPSAC<>""
 Effzo [DI1]SAC : Grizo [DI1]SAC
Else
 Actzo [DI1]SAC
Endif
If [M:DI1]GRPCUR<>""
 Effzo [DI1]CUR : Grizo [DI1]CUR
Else
 Actzo [DI1]CUR
Endif
If [M:DI1]ALLTYP=2
 Effzo [DI1]TYP,PCEDEB,PCEFIN : Grizo [DI1]TYP,PCEDEB,PCEFIN
Else
 Actzo [DI1]TYP,PCEDEB,PCEFIN
Endif
If [M:DI2]MNTMAX=0 or [M:DI2]BAN<>""
 Grizo [DI2]ALLMOD
Else
 Actzo [DI2]ALLMOD
Endif
If GBIDC1<>""
  If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
  Call LEC_CPY([M]CPY) From CPTLEC
  Call LEC_TPY_LEG([F:CPY]LEG,GBIDC1) From CPTLEC
  If !fstat
   [M:DI1]ALLTPY = 1 : [M:DI1]TPY = GBIDC1
   Affzo [M:DI1]ALLTPY, TPY
   If dim([M:DI1]ZTPY)>0 : Affzo [M:DI1]ZTPY : Endif
   Grizo [DI1]ALLTPY, TPY
  Else
   Actzo [DI1]ALLTPY, TPY
  Endif
Else
 Actzo [DI1]ALLTPY
 If [M:DI1]ALLTPY=2
  Effzo [DI1]TPY : Grizo [DI1]TPY
 Else
  Actzo [DI1]TPY
 Endif
Endif
If [DI2]SIM=2 :
 Effzo [DI2]CTLFLG : Grizo [DI2]CTLFLG
 Effzo [DI2]SELDEF : Grizo [DI2]SELDEF
Else
 Actzo [DI2]CTLFLG
 Actzo [DI2]SELDEF
Endif
If [DI2]CTLFLG=2
 Effzo [DI2]SIM : Grizo [DI2]SIM
Else
 Actzo [DI2]SIM
Endif
Return

Subprog AS_CURPAY(VALEUR)
Variable Char    VALEUR()
If [M]BAN<>""
 Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
 If [F:BAN]CHGDAT<>[0/0/0] & [M]ACCDAT>=[F:BAN]CHGDAT
  VALEUR = [F:BAN]CUR
  mkstat=2
 Endif
Endif
End

Subprog AS_SIM(VALEUR)
Variable Integer VALEUR
If [M]CTLFLG = 2
 mkstat=1 : End
Endif
End

Subprog C_SIM(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CTLFLG = 1 : Grizo [M]CTLFLG
 [M]SELDEF = 1 : Grizo [M]SELDEF
Else
 Actzo [M]CTLFLG
Endif
End

Subprog D_CTLFLG(VALEUR)
Variable Integer VALEUR
If !GBATCH  : VALEUR = 2 Else VALEUR=1 : Endif
End

Subprog AS_CTLFLG(VALEUR)
Variable Integer VALEUR
If [M]SIM = 2 | GBATCH
 mkstat=1 : End
Endif
End

Subprog C_CTLFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 [M]SIM = 1 : Grizo [M]SIM
 # [M]SELDEF = 2 : Actzo [M]SELDEF 103526.o
Else
 Actzo [M]SIM
 # [M]SELDEF = 1 : Grizo [M]SELDEF 103526.o
Endif
End

# 103526.sn
Subprog AM_CTLFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 [M]SELDEF = 2 : Actzo [M]SELDEF
Else
 [M]SELDEF = 1 : Grizo [M]SELDEF
Endif

End
# 103526.en

Subprog D_SELDEF(VALEUR)
Variable Integer VALEUR
If !GBATCH  : VALEUR = 2 Else VALEUR=1 : Endif
End

Subprog AS_SELDEF(VALEUR)
Variable Integer VALEUR
If [M]SIM = 2 | GBATCH
 mkstat=1 : End
Endif
End
