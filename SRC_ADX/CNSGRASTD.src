#<AdxTL>@(#)2.0.0.0 $Revision:   1.36  $ Consultation SFC
#######################################################################################
# CNSGRASTD : Ecran générique d'affichage d'un graphe multi-lignes à partir de la V5  #
#######################################################################################
# Actions :                                                                GA 09/2008 #
# FGRAPHSES   Graphique des saisonnalités - Table SEASON                              #
#######################################################################################


$ACTION
Case GACTION
    When "FGRAPHSES"
        Case ACTION
          When "OUVRE"      : Gosub OUVRE_FGRAPHSES
          When "DEBUT"      : Gosub DEBUT_FGRAPHSES
          When "TITRE"      : Gosub TITRE_FGRAPHSES
        Endcase 
Endcase
Return

#---------------------------------------------------------------------------#
# Action FGRAPHSES  Représentation graphique Saisonalités                   #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_FGRAPHSES
Local    Integer WCOL      : WCOL = 53 : # Nombre de colonnes +1 (52 semaines maxi)
Local    Integer WNBL      : WNBL = 3  : # Nombre de lignes du graphique +1 (WVAL1,2,3,4) # FQ 51441 avant 5
Local    Integer WSEM      : WSEM = 1  : # Premier jour ouvré semaine 
Local    Integer WCOR
Local    Date    WDATD(WCOL)
Local    Date    WDATF(WCOL)
Global   Char    GSCOLDES(20)(WCOL)
Global   Decimal TLIG(WNBL,WCOL)       : # Cumuls lignes
Return

########################################################################
$DEBUT_FGRAPHSES
If [M:SES1]SESNBR = 0 : FIN=1 : Return : Endif
Gosub CHARGE_FGRAPHSES
Affzo [M:GRA1]
Return

###########################################################################
# titre de la fenêtre
$TITRE_FGRAPHSES
TIT=mess(136,196,1) : # Courbe de saisonnalité
Return

######################################################################### 
$CHARGE_FGRAPHSES
Local Integer WROW
Local Integer I

Effzo [M:GRA1]

[M:GRA1]PERCOD  = 3           : # Menu Local 278: Mois
[M:GRA1]REFPER  = gdat$(1,1,year(date$))       : # 01/01/yyyy ?

WROW=0
####Gosub CAL_COLONNES
Gosub VISU_GRAPH_SES

For I = 0 To WROW-1
  [M:GRA1]WABS(I)       = GSCOLDES(I+1)
  [M:GRA1]WVAL1(I)      = TLIG(0,I+1)
  [M:GRA1]WVAL2(I)      = TLIG(1,I+1)
Next I
[M:GRA1]NBLIG = WROW
Return

###########################################################

# Titres colonnes 
$CAL_COLONNES
If WSEM = 1
  WCOR = 7
Else
  WCOR = WSEM-1
Endif
# Autres colonnes selon périodicité
Case [M:GRA1]PERCOD
  When 1 :                # Jour
  When 2 :                # Semaines
    GSCOLDES(0) = "<-"-format$("D:"+GFMDAT4,[M:GRA1]REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = [M:GRA1]REFPER-1
    If dayn([M:GRA1]REFPER) = WSEM
      WDATD(1) = [M:GRA1]REFPER
      WDATF(1) = [M:GRA1]REFPER+6
    Else
      WDATD(1) = [M:GRA1]REFPER
      WDATF(1) = [M:GRA1]REFPER
      While dayn(WDATF(1)) <> WCOR
        WDATF(1) += 1
      Wend 
    Endif
    GSCOLDES(1) = format$("D:"+GFMDAT4,WDATD(1))+"->"
    For I = 2 To WCOL-1                    : # 52 semaines
      WDATD(I) = WDATF(I-1)+1
      WDATF(I) = WDATF(I-1)+7
      GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))+"->"
    Next I
  When 3 :                # Mois
    WDTE = gdat$(1,month([M:GRA1]REFPER),year([M:GRA1]REFPER))          # 1er jour du mois
    WDATF(0) = WDTE-1                                                   # fin de mois précédent
    For I = 1 To 12
      If I = 1
        WDATD(I) = [M:GRA1]REFPER
      Else
        WDATD(I) = WDATF(I-1)+1                                         # début du mois suivant
      Endif
      WDATF(I) = eomonth(WDATD(I))                                      # fin du mois
      GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))+"->"
    Next I  
Endcase
Return

######################################################################################
$VISU_GRAPH_SES
Local Decimal WPOI(366)
Local Date    WDAT(366)
Local Decimal WPRC(52)
Local Char    WABS(03)(52)
Local Decimal WTOT 
Local Integer WJOU
Local Date    WDEB
Local Date    WFIN
Local Decimal WAMT
Local Date    WJAN : WJAN = gdat$(1,1,year(date$))
Local Integer I, J, K
#
If dim([M:GRA1]WLIB1)>0
   [M:GRA1]WLIB1 = mess(38,105,1)        : # Répartition
   [M:GRA1]WLIB2 = mess(38,105,1)-"(%)"  : # Répartition (%)
   # FQ 51441 GA 01/2009
   # le fait de vider les libellés ne fonctionne pas en mode Web: suppression des 2 colonnes inutilisées ?
   If dim([M:GRA1]WLIB3)>0 [M:GRA1]WLIB3 = " " Endif
   If dim([M:GRA1]WLIB4)>0 [M:GRA1]WLIB4 = " " Endif
Endif
#
Raz WPOI, WTOT, WPRC, WABS
For I = 0 To 51
  WABS(I) = " "
Next I
WTOT = sum([M:SES1]SESAMT(0..[M:SES1]SESNBR-1))
If WTOT = 0
  Return
Endif
For I = 1 To [M:SES1]SESNBR
  WDEB = gdat$(day([M:SES1]STRDAT(I-1)),month([M:SES1]STRDAT(I-1)),year(date$))
  WFIN = gdat$(day([M:SES1]ENDDAT(I-1)),month([M:SES1]ENDDAT(I-1)),year(date$))
  WJOU = (WFIN - WDEB) +1
  If WJOU > 0
    WAMT = arr([M:SES1]SESAMT(I-1)/WJOU,0.000001)
    While WJOU > 0
      J = WDEB - WJAN
      WDAT(J) = WJAN + J  : # Date du jour
      WPOI(J) = WAMT
      WDEB += 1
      WJOU -= 1
    Wend
  Endif
Next I
Case [M:GRA1]PERCOD
  When 1 :                # Jour
  When 2 :                # Semaines
       J = 0 : K = 6
       For I = 1 To 52
           WDATD(I) = WDAT(J)
           WDATF(I) = WDAT(J+K)
           TLIG(0,I) = arr(sum(WPOI(J..J+K)),1)           : # Poids
           TLIG(1,I) = TLIG(0,I) * 100 / WTOT             : # Pourcentage ?
           J += K+1     
           GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))+"->"
       Next I
       WROW = 52
  When 3  :               # Mois
       J = 0
       For I = 1 To 12
           WDATD(I) = WDAT(J)
           WDATF(I) = eomonth(WDATD(I))
           K = abs(WDATF(I)-WDATD(I)+1)     : # Nb jours mois courant
           TLIG(0,I) = arr(sum(WPOI(J..J+K-1)),1)         : # Poids
           TLIG(1,I) = TLIG(0,I) * 100 / WTOT             : # Pourcentage ?
           J += K     
           GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))+"->"
       Next I
       WROW = 12
Endcase
Return

######################################################################################
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
Case GACTION
    When "FGRAPHSES" : 
         GMENLOC(1)=1 : # Pas de périodicité <Jours>    pour les Saisonnalités
         VALEUR = 3
    When Default :
Endcase
End

######################################################################################

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"GRA") From SUBGTC

End


