#<AdxTL>@(#)8.0.0.0 $Revision$

#########################################################################
#  SIXBPC : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXBPC                                                        #
#     Création des clients                                              #
#                                                                       #
#    les factors et representants doivent deja integrés  !!!!           #
#    ainsi que les banques (donneesde base/tables communes/banques)     #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################
#Dbgaff
Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=2
Local File SIPARX3  [SPX]
Read [SPX] First
Call EXEC From SIXBPC
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
#  "Migration des clients"
    Call OUVRE_TRACE("SIXBPC : "+SI_MES(4)) From LECFIC     
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement BPCUSTOMER ------#
Call ECR_TIME("SI_BPCUSTOMER : "+mess(213,124,1)+" BPCUSTOMER") From DOSSUB
Call SI_BPCUSTOMER
If GOK<>1 : Onerrgo : Goto FIN_FIN : Endif


$FIN_FIN
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
    GIMPORT = 0    # CCC bug 47023
Resume


#########################################################################
# Création des clients
#########################################################################
Subprog SI_BPCUSTOMER

########--------------------------------------------------------- Ouvertures tables X3 #
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif   # Socièté
If !clalev([F:BPC])  : Local File =SI_DOSSIER+".BPCUSTOMER" [BPC] : Endif   # Clients
If !clalev([F:BPD])  : Local File =SI_DOSSIER+".BPDLVCUST"  [BPD] : Endif   # Clients livrés
If !clalev([F:BPR])  : Local File =SI_DOSSIER+".BPARTNER"   [BPR] : Endif   # Business Partner
If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA] : Endif   # Adresses
If !clalev([F:BID])  : Local File =SI_DOSSIER+".BID"        [BID] : Endif   # Relevé Identité Bancaire
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif   # Pays
If !clalev([F:TCU])  : Local File =SI_DOSSIER+".TABCUR"     [TCU] : Endif   # Devises
If !clalev([F:TMD])  : Local File =SI_DOSSIER+".TABMODELIV" [TMD] : Endif   # Livraison
If !clalev([F:TLA])  : Local File =SI_DOSSIER+".TABLAN"     [TLA] : Endif   # Langues
If !clalev([F:FCT])  : Local File =SI_DOSSIER+".FACTOR"     [FCT] : Endif   # Factors
If !clalev([F:REP])  : Local File =SI_DOSSIER+".SALESREP"   [REP] : Endif   # Representants
If !clalev([F:ABN])  : Local File =SI_DOSSIER+".ABANK"      [ABN] : Endif   # Banque
If !clalev([F:CNT])  : Local File =SI_DOSSIER+".CONTACT"    [CNT] : Endif   # Contact
If !clalev([F:AIN])  : Local File =SI_DOSSIER+".CONTACTCRM" [AIN] : Endif   # Contact crm
If !clalev([F:BCG])  : Local File =SI_DOSSIER+".BPCCATEG"   [BCG] : Endif   # Categorie client
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables   # hcb 70899


If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif   # table diverse
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif   # Textes
If !clalev([F:ATZ])  : Local File =SI_DOSSIER+".ATABZON"    [ATZ] : Endif   # Libellé rubrique 


If !clalev([M:BPC1]) : Local Mask  BPC1                     [BPC1]: Endif   # Réupération éléments facturation


#######--------------------------------------------------------- Ouvertures tables Integrale #

If !clalev([F:XCLT])  : Local File =SI_DOSSIER+".XICLT"      [XCLT]  : Endif  # Clients
If !clalev([F:XCL1])  : Local File =SI_DOSSIER+".XICLT"      [XCL1]  : Endif  # Clients
If !clalev([F:XDQE])  : Local File =SI_DOSSIER+".XICLTDMBQE" [XDQE]  : Endif  # Domiciliation bancaire 
If !clalev([F:XBLN])  : Local File =SI_DOSSIER+".XIBLNFIC"   [XBLN]  : Endif  # Bloc notes
If !clalev([F:XITL])  : Local File =SI_DOSSIER+".XIITLCLT"   [XITL]  : Endif  # Contacts  

########--------------------------------------------------------- Définitions rubriques # 

Local Integer STOP
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur => pas d'écriture de l'enregistrement
Local Char    REG_TVA_ATABZON(25)
Local Char    COD_DEV_ATABZON(25)
Local Char    RGL_ATABZON(25)
Local Char    BPC_INV_ATABZON(25) 
Local Char    BPC_PYR_ATABZON(25) 
Local Char    BPC_RSK_ATABZON(25) 
Local Char    ACC_COD_ATABZON(25)
Local Integer NBPOSTE
Local Integer I
Local Integer Y
Local Char    WCODCPY(GLONCPY)
########--------------------------------------------------------- Initialisation variables contextuelles #

SI_SUBPRG = "SIXBPC"
SI_TABLE  = "XICLT"
Gosub SI_CRITSUP From SIXFONCTION

########--------------------------------------------------------- Récuperation des correspondances #

SI_TABLE = "BPCUSTOMER"
Gosub SI_INIVALEUR From SIXFONCTION
GIMPORT = 2   


# mémorisation libellé regime taxe
Call TEXTFIC("BPCUSTOMER","VACBPR",2,REG_TVA_ATABZON) From OBJDIV  
# mémorisation libellé devise
Call TEXTFIC("BPCUSTOMER","CUR",2,COD_DEV_ATABZON) From OBJDIV  
# mémorisation libellé condition paiement
Call TEXTFIC("BPCUSTOMER","PTE",2,RGL_ATABZON) From OBJDIV  
# mémorisation libellé client facture 
Call TEXTFIC("BPCUSTOMER","BPCINV",2,BPC_INV_ATABZON) From OBJDIV  
# mémorisation libellé tiers payeur  
Call TEXTFIC("BPCUSTOMER","BPCPYR",2,BPC_PYR_ATABZON) From OBJDIV  
# mémorisation libellé tiers risque  
Call TEXTFIC("BPCUSTOMER","BPCRSK",2,BPC_RSK_ATABZON) From OBJDIV  
# mémorisation libellé code comptable  
Call TEXTFIC("BPCUSTOMER","ACCCOD",2,ACC_COD_ATABZON) From OBJDIV  


########--------------------------------------------------------- Traitement #

$LOOP_BPC

Call DEBTRANS From GLOCK


#SI_CRITERE = "CODCLT = 'HCB_L3'"

# Traitement des clients 
For [XCLT] Where left$(CODCLT,2)<>"$$"
&              & FLGREP < 2
&              & evalue(SI_CRITERE) 

   Trbegin [BPC]

   Call AFFBOITE([F:XCLT]CODCLT) From SUBSIM

    LERR  = 0
    # creation client (BPCUSTOMER)
    Gosub CRE_BPC
    If GOK <= 0 & SI_SIMU <> 2
       Break
    Endif

    #----    creation RIB (BID)
    If LERR = 0
       Gosub CRE_BID 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif 
    Endif

    # creation business partner (BPARTNER)
    If LERR = 0
       Gosub CRE_BPR
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation clients livrés (BPDLVCUST)
    If LERR = 0
       Gosub CRE_BPD 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation adresse (BPADDRESS)
    If LERR = 0
       Gosub CRE_BPA 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation contact (CONTACT)
    If LERR = 0
       Gosub CRE_CNT 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif


    If LERR=0 & SI_SIMU<>2
       [F:XCLT]FLGREP = 2
       Rewrite [XCLT]
       Commit
    Else
        Rollback
    Endif

Next

# si pas simulation gestion Tiers payeur et client groupe
If SI_SIMU<>2 
# Traitement des clients 
   For [XCLT] Where left$(CODCLT,2)<>"$$"
&                      & FLGREP  = 2
&                      & evalue(SI_CRITERE) 
      Trbegin [BPC]
      If  !([F:XCLT]CODFAC = "" & [F:XCLT]CEN = "" & [F:XCLT]CENPYE = "N")
          Call AFFBOITE([F:XCLT]CODCLT) From SUBSIM
          LERR  = 0
          Read [BPC]BPC0 = [F:XCLT]X3CLE
          If !fstat
             If [F:XCLT]CODFAC = [F:XCLT]CODCLT
                If [F:XCLT]CEN <> "" 
                   If [F:XCLT]CENPYE = "O"
                      [F:BPC]BPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","")   # Tiers payeur
                   Else
                      [F:BPC]BPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CODFAC ,"","") # Tiers payeur
                   Endif
                      [F:BPC]BPCGRU  = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","")     # client groupe 
                Else
                   [F:BPC]BPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CODFAC ,"","") # Tiers payeur
                   [F:BPC]BPCGRU   = [F:BPC]BPCNUM  # client groupe 
                Endif
             Elsif [F:XCLT]CODFAC = "" 
                   If [F:XCLT]CEN <> "" 
                      If [F:XCLT]CENPYE = "O"
                         [F:BPC]BPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","")   # Tiers payeur
                      Else
                         [F:BPC]BPCPYR   = [F:BPC]BPCNUM  # Tiers payeur
                      Endif
                      [F:BPC]BPCGRU  = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","")     # client groupe 
                   Else
                      [F:BPC]BPCPYR   = [F:BPC]BPCNUM  # Tiers payeur
                      [F:BPC]BPCGRU   = [F:BPC]BPCNUM  # client groupe 
                   Endif
             Elsif [F:XCLT]CODFAC <> ""
                   Read [XCL1]IND0 = [F:XCLT]CODFAC
                   If fstat
                      Raz [F:XCL1]
                   Endif
                   If [F:XCL1]CEN <> "" 
                      If [F:XCL1]CENPYE = "O"
                         [F:BPC]BPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCL1]CEN ,"","")  # Tiers payeur
                      Else
                         [F:BPC]BPCPYR   =  func SIXFONCTION.SI_COR("XICLT",[F:XCL1]CODCLT ,"","") # Tiers payeur
                      Endif
                      [F:BPC]BPCGRU  = func SIXFONCTION.SI_COR("XICLT",[F:XCL1]CEN ,"","")     # client groupe 
                   Else
                      [F:BPC]BPCPYR   =  func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CODFAC ,"","") # Tiers payeur
                      [F:BPC]BPCGRU   =  func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","") # client groupe 
                   Endif
             Endif
          Endif
          If [F:BPC]BPCGRU = "" 
             [F:BPC]BPCGRU   = [F:BPC]BPCNUM  # client groupe 
          Endif 
          If [F:BPC]BPCPYR = "" 
             [F:BPC]BPCPYR = [F:BPC]BPCNUM # Tiers payeur
          Endif
          # Point d'entrée avant écriture
          SI_TABLE = "RBPCUSTOMER"
          Gosub SI_BEFWRI From SIXFONCTION
          If LERR=0 
#            Call ECR_TRACE([F:BPC]BPCNUM-"/"-[F:BPC]BPCINV-"/"-[F:BPC]BPCPYR-"/"-[F:BPC]BPCGRU,-1) From GESECRAN
          Rewrite [BPC]
          Endif
      Endif      
      If LERR = 0
         [F:XCLT]FLGREP = 3
         Rewrite [XCLT]
         Commit
      Else
         Rollback
      Endif
   Next          
Endif
# si pas simulation controle que  le client groupe et facture existent 

If SI_SIMU<>2
    If !clalev([F:BPC1])  : Local File =SI_DOSSIER+".BPCUSTOMER" [BPC1] : Endif   # Clients
    Local Integer WCTRBPC
    Call DEBTRANS From GLOCK
    For [BPC] 
        Raz WCTRBPC 
        If [F:BPC]BPCINV <> "" & [F:BPC]BPCINV <> [F:BPC]BPCNUM 
           Look [BPC1]BPC0=[F:BPC]BPCINV
           If fstat
              # Client facture inexistant
              Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-mess(147,192,1)-"("+[F:BPC]BPCINV+")",-1) From GESECRAN
              WCTRBPC += 2
           Endif
        Endif
        If [F:BPC]BPCGRU <> "" & [F:BPC]BPCGRU <> [F:BPC]BPCNUM 
           Look [BPC1]BPC0=[F:BPC]BPCGRU
           If fstat
              # Client facture inexistant
              Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM+SI_MES(5)-"("+[F:BPC]BPCGRU+")",-1) From GESECRAN
              WCTRBPC += 4
           Endif
        Endif
        If [F:BPC]BPCPYR <> "" & [F:BPC]BPCPYR <> [F:BPC]BPCNUM 
           Look [BPC1]BPC0=[F:BPC]BPCPYR
           If fstat
              # Client facture inexistant
              Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM+SI_MES(256)-"("+[F:BPC]BPCGRU+")",-1) From GESECRAN
              WCTRBPC += 8
           Endif
        Endif
        If WCTRBPC <> 0
           Trbegin [BPC]
#           Readlock [BPC] Curr
           Case  WCTRBPC 
                 When 2,6,10
                      Raz [F:BPC]BPCINV
                 When 4,6,12
                      Raz [F:BPC]BPCGRU
                 When 8,10,12
                      Raz [F:BPC]BPCPYR
           Endcase
           Rewrite [BPC]
           If LERR=0 & SI_SIMU<>2
              Commit
           Else
              Rollback
           Endif
        Endif
    Next
Endif

GIMPORT = 0    

End


##################################################################
#  Creation BPCUSTOMER 
##################################################################
$CRE_BPC
Raz [F:BPC]
Raz [M:BPC1]
Raz Y
Raz WCODCPY
[F:BPC]BCGCOD    = [F:SPX]BCGCOD         # catégorie

GPE = 0
SI_TABLE = "BPCUSTOMER"
Gosub SI_INIVALEUR From SIXFONCTION
If GPE = 0
   Read [BCG]BCG0   = [F:BPC]BCGCOD
   If fstat 
      Raz [F:BCG] 
      Call ECR_TRACE(mess(12,159,1)-[F:XCLT]CODCLT-" : "-SI_MES(270)+" : "-[F:BPC]BCGCOD , 1) From GESECRAN

      LERR=1
   Endif
Endif

[F:BPC]          = [F:BCG]            # tranclasse categorie client  

# recuperation et controle code client
If !func SIXFONCTION.SI_CTL("BPCNUM",[F:XCLT]X3CLE,"XICLT ("+[F:XCLT]CODCLT+")")
    LERR = 1
Else
    [F:BPC]BPCNUM    = [F:XCLT]X3CLE
Endif



# pour le client groupe et facture une mulinette est faits apres creation des clients pour verifier 
#       leur existence
[F:BPC]BPCINV  = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CODFAC ,"","")  # client facture 
If [F:BPC]BPCINV = "" 
   [F:BPC]BPCINV = [F:BPC]BPCNUM 
Endif

If [F:XCLT]CODFAC = "" & [F:XCLT]CEN = "" & [F:XCLT]CENPYE  <> "O"
   [F:BPC]BPCPYR  = [F:BPC]BPCNUM     # Tiers payeur      
   [F:BPC]BPCGRU  = [F:BPC]BPCNUM 
Endif

# factor
If [F:XCLT]CODFCT <> ""
   [F:BPC]FCTNUM = func SIXFONCTION.SI_COR("XIFCTAFT",[F:XCLT]CODFCT,"FACTOR",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
Endif
# representant
If [F:XCLT]REP <> "" 
   [F:BPC]REP(0)    = func SIXFONCTION.SI_COR("XIREP",[F:XCLT]REP,"SALESREP",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
Endif

If [F:XCLT]FACPOR  <> ""
   If [F:XCLT]FACPOR  = "N"
      [F:BPC]FREINV   = 2                 # Facturation du port
   Else
      [F:BPC]FREINV   = 1         
   Endif
Endif

[F:BPC]BPCREM      = [F:XCLT]CMT       # observations  

If [F:XCLT]CPTAUX <> [F:XCLT]X3CLE
   If [F:BPC]BPCREM = ""
      [F:BPC]BPCREM = "CPT_AUX Intégrale : "
      [F:BPC]BPCREM += [F:XCLT]CPTAUX 
   Else
      Local Char WLIB1(100)
      WLIB1 = format$("K:46Xb",[F:BPC]BPCREM)
      WLIB1 += "CPT_AUX Intégrale : "
      WLIB1 += [F:XCLT]CPTAUX 
      [F:BPC]BPCREM = WLIB1
   Endif
Endif

If [F:XCLT]CRDTOL <> 0
   [F:BPC]OSTAUZ      = [F:XCLT]CRDTOL    # en cours autorisé
Endif

[F:BPC]CREDAT      = [F:XCLT]DATCRE    # date création    
If [F:BPC]CREDAT   = [0/0/0]
   [F:BPC]CREDAT   = date$
   [F:BPC]CREUSR   = GUSER
Endif
[F:BPC]UPDDAT      = date$             # date modification
[F:BPC]UPDUSR      = GUSER             # operateur modification

If [F:XCLT]FLGSML   = "O"               
   [F:BPC]BPCSTA   = 1                 # client actif 
Else
   [F:BPC]BPCSTA   = 2                 # client actif 
Endif

If [F:XCLT]NAT      = "C"                 
   [F:BPC]BPCTYP   = 1                 # type (normal)
Endif
If [F:XCLT]NAT      = "D"                 
   [F:BPC]BPCTYP   = 2                 # type (divers)
Endif

[F:BPC]BPCNAM      = [F:XCLT]NOM       # raison sociale            

If [F:BPC]INVPER   = 0                
   [F:BPC]INVPER   = 1                 # périodicité  (1 à la demande)
Endif
#                                      # regime de taxe
If find([XCLT]REGTVA,"O","N","C","E")
   [F:BPC]VACBPR = func SIXFONCTION.SI_VACBPR("C",[F:XCLT]REGTVA,[F:XCLT]REGTPF,[F:XCLT]TAXADD,[F:XCLT]CODPAY)
Endif

If [F:XCLT]TRFTTC  <>  ""
   If [F:XCLT]TRFTTC  = "O"
      [F:BPC]PRITYP   = 2                 # Prix HT/TTC  
   Else
      [F:BPC]PRITYP   = 1                 # Prix HT/TTC  
   Endif
Endif


# Devise
If dim([F:BPC]CUR) > 0
   If [F:XCLT]CODDEV <> ""
      [F:BPC]CUR = func SIXFONCTION.SI_COR("XIDVS",[F:XCLT]CODDEV,"TABCUR",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
   Endif
Endif
# Famille statistique (Famille)
If [F:XCLT]CODFAM <> "" & dim([F:BPC]TSCCOD(0))>0
   [F:BPC]TSCCOD(0) = func SIXFONCTION.SI_COR("XIFAMCLT",[F:XCLT]CODFAM,"30",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
Endif
# Famille statistique (Sous famille)
If [F:XCLT]CODSOUFAM <> "" & dim([F:BPC]TSCCOD(1))>0
   [F:BPC]TSCCOD(1) = func SIXFONCTION.SI_COR2("XISOUFMCLT",[F:XCLT]CODFAM,[F:XCLT]CODSOUFAM,"31",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
Endif


# Condition paiement 
If [F:XCLT]RGL <> ""
   [F:BPC]PTE       = func SIXFONCTION.SI_COR2("XIMODRGL",left$([F:XCLT]RGL,2),right$([F:XCLT]RGL,3),"TABPAYTERM",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
Endif

#---- Reprise du bloc-notes ------#
Read [XBLN]IND0="CL";[F:XCLT]CODCLT
Raz SI_CLOB,I
If !fstat
    For I=1 To 18
        SI_CLOB(I-1) = evalue("[F:XBLN]LIG"+num$(I))
    Next
    [F:BPC]ORDTEX = func SIXFONCTION.SI_CLOB("BPC")
Endif

# initailisation par defaut
# hcb 70899 deb                  
# code comptable
#If [F:BPC]ACCCOD = "" 
#   [F:BPC]ACCCOD = "STD"    # Code comptable inclus dans le dossier de référence. 
#Endif
## comptable par 'STD' (celui livré en standard)
If [F:BPC]ACCCOD = ""
   Read [CAC]CAC0 = 2;"STD"
   If !fstat
      [F:BPC]ACCCOD = "STD"
   Else
      Filter [CAC] Where TYP=2
             Read [CAC]CAC0 First
             If !fstat 
                [F:BPC]ACCCOD = [F:CAC]ACCCOD
             Endif
      Filter [CAC]
   Endif
Endif
# hcb 70899 fin                  
If dim([F:BPC]BPCRSK ) > 0
   If [F:BPC]BPCRSK      = ""   
      [F:BPC]BPCRSK      = [F:BPC]BPCNUM  # Tiers risque 
   Endif 
Endif


# initalisation des Adresses
[F:BPC]BPAINV = "001"                     # Adresse client facture

If dim([F:BPC]BPAPYR) > 0  
   [F:BPC]BPAPYR = "001"                  # Adresse tiers  payeur   
Endif

If dim([F:BPC]BPAADD) > 0   
   [F:BPC]BPAADD = "001"                  # Adresse par defaut    
Endif
If dim([F:BPC]BPDADD) > 0    
   [F:BPC]BPDADD = "001"                  # Adresse par defaut    
Endif

# valeur par defaut
If [F:BPC]CHGTYP = 0
   [F:BPC]CHGTYP = 1                         # Type cours
Endif    
If [F:BPC]OSTCTL = 0
   [F:BPC]OSTCTL = 1                         # Controle en cours
Endif    
If [F:BPC]SOIPER = 0
   [F:BPC]SOIPER = 1                         # Type relevé
Endif    
If [F:BPC]DME    = 0
   [F:BPC]DME    = 1                         # Livraisosn partielle
Endif    
If [F:BPC]IME    = 0
   [F:BPC]IME    = 1                         # Mode facturation
Endif    
If [F:BPC]ODL    = 0
   [F:BPC]ODL    = 1                         # 1 cde/livraisons
Endif    
If [F:BPC]ORDCLE = 0
   [F:BPC]ORDCLE = 1                         # Autorisation solde commande
Endif    
If [F:BPC]OCNFLG = 0
   [F:BPC]OCNFLG = 1                         # Impression ARC
Endif    
If [F:BPC]COMCAT = 0
   [F:BPC]COMCAT = 1                         # Catégorie commission
Endif    
If [F:BPC]DUDCLC = 0
   [F:BPC]DUDCLC = 1                         # Origine echeance 
Endif    
If dim([F:BPC]CNTLASTYP) > 0 Then # FGR 05/08/2009 : X3SUIVI56985 : ces rubriques vont disparaître
  If [F:BPC]CNTLASTYP = 0
     [F:BPC]CNTLASTYP = 1                      # Type dernier contact 
  Endif    
Endif
If dim([F:BPC]CNTNEXTYP) > 0 Then # FGR 05/08/2009 : X3SUIVI56985 : ces rubriques vont disparaître
  If [F:BPC]CNTNEXTYP = 0
     [F:BPC]CNTNEXTYP = 1                      # Type prochain contact 
  Endif    
Endif
If [F:BPC]ABCCLS = 0
   [F:BPC]ABCCLS = 1                         # Categorie ABC  
Endif    

If GACTFTC=2 & [F:BPC]CUR <> ""
   #---- chargt tableau des elements de facturation pour CLIENT seulement #  
  If [M:BPC1]NBFAC = 0  
     NBPOSTE = dim ([M:BPC1]INVDTA)
     Call  SAISFOOT (1,"BPC1",NBPOSTE,[F:BPC]CHGTYP,GSYSCUR,[F:BPC]CUR,"OUI") From SUBSFIT 
     For Y=0 To dim([F:BPC]INVDTA)-1
         If [M:BPC1]INVDTA(Y)=0 
            Break 
         Endif
         If [F:BPC]INVDTAAMT(Y) = 0 
            [F:BPC]INVDTAAMT(Y) = [M:BPC1]INVDTAAMT(Y)  
         Endif
         [F:BPC]INVDTA   (Y) = [M:BPC1]INVDTA   (Y)  
     Next Y
  Endif
Endif


# Point d'entrée avant écriture
SI_TABLE = "BPCUSTOMER"
Gosub SI_BEFWRI From SIXFONCTION

# test Rubriques obligatoires
# Régime de tva
If [F:BPC]VACBPR      = ""
   Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(10,123,1)+" : "+REG_TVA_ATABZON, 1) From GESECRAN
   LERR = 1 
Endif
# Devise
If dim([F:BPC]CUR) > 0         
   If [F:BPC]CUR         = ""
      Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(10,123,1)+" : "+COD_DEV_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
Endif
# Condition paiement       
If [F:BPC]PTE         = ""
   Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(10,123,1)+" : "+RGL_ATABZON, 1) From GESECRAN
   LERR = 1
Endif

# Code comptable        
If [F:BPC]ACCCOD       = ""
   Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(10,123,1)+" : "+ACC_COD_ATABZON, 1) From GESECRAN
   LERR = 1
Endif


# tests suivant uniquement dans le cas d un transcodage correct .........
If [F:BPC]BPCNUM <> ""
# Tiers risque       
   If dim([F:BPC]BPCRSK) > 0
      If [F:BPC]BPCRSK       = ""
         Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(10,123,1)+" : "+BPC_RSK_ATABZON, 1) From GESECRAN
         LERR = 1
      Endif
   Endif
Endif
If LERR = 0
   Write [BPC]
   If fstat
      Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
      LERR = 1
   Endif
Endif

Return


##################################################################
#  Creation BPARTNER
#  + mise a jour du RIB par defaut dans le fichier BID
##################################################################
$CRE_BPR
Local Integer LEXI
Local Char    LBIDNUM
Raz LEXI
Raz mkstat    # 47061

Look [BPR]BPR0 = [F:BPC]BPCNUM
If fstat <> 0
    Readlock [BPR]BPR0 = [F:BPC]BPCNUM
    If fstat
        Raz [F:BPR]
        [F:BPR]CRY = [F:BCG]CRY
        Raz LEXI
    Else
        LEXI = 1
    Endif

    # Rubriques reprises du client Integrale 
    If [F:XCLT]NUMIDE <> ""
       [F:BPR]EECNUM    = [F:XCLT]NUMIDE         # N° tva intraco
    Endif
    If [F:XCLT]NUMSIRET <> "             0"
       [F:BPR]CRN       = [F:XCLT]NUMSIRET    # N° SIRET
    Endif
    # code langue 
    If [F:XCLT]CODLAN <> ""
       [F:BPR]LAN = func SIXFONCTION.SI_COR("XILAN",[F:XCLT]CODLAN,"TABLAN",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif
    # code pays 
    If [F:XCLT]CODPAY <> ""
       [F:BPR]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XCLT]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif

   # hcb 46483 
    If [F:BPR]EECNUM <> ""
       Call CONTTVA([F:BPR]EECNUM,[F:BPR]CRY) From CONTNUM
       If mkstat = 2 
          Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-GMESSAGE,-1) From GESECRAN
       Endif
    Endif
   # hcb 46588 
    If [F:BPR]CRN <> ""
       Call CONTSIRET([F:BPR]CRN,[F:BPR]CRY,"") From CONTNUM
       If mkstat = 2 
          Call ECR_TRACE(mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-GMESSAGE,-1) From GESECRAN
       Endif
    Endif

    # RIB  
    # lecture du fichier integrale RIB   
    If [F:XCLT]NUMDOMBQE <> 0
       Read [XDQE]IND0 = [F:BPC]BPCNUM;[F:XCLT]NUMDOMBQE
       If fstat
          Raz [F:XDQE]
       Endif
       If [F:XDQE]CODBQE <> ""
          Raz LBIDNUM
          LBIDNUM += [F:XDQE]CODBQE
          LBIDNUM += [F:XDQE]CODGUI
          LBIDNUM += [F:XDQE]NUMCPT
          LBIDNUM += [F:XDQE]CLERIB
          Readlock [BID]BID0=1;[F:BPC]BPCNUM;LBIDNUM
          If fstat
             Raz [F:BID]
          Else
       # mise a jour du RIB par defaut dans le fichier BID
             [F:BID]BIDNUMFLG = 2                         # Par defaut
             Rewrite [BID]
          Endif
          [F:BPR]BIDNUM    = [F:BID]BIDNUM     # RIB par défaut
          [F:BPR]BIDCRY    = [F:BID]CRY        # Pays RIB 
       Endif           
    Endif         
    


    # Rubriques reprises du client X3
    [F:BPR]BPRNUM    = [F:BPC]BPCNUM          # Tiers
    [F:BPR]BPRSHO    = [F:BPC]BPCSHO          # Intitule court
    If dim([F:BPR]ENAFLG) > 0
       [F:BPR]ENAFLG    = [F:BPC]BPCSTA       # Actif
    Endif
    [F:BPR]ACCCOD    = [F:BPC]ACCCOD          # Code comptable
    [F:BPR]BPRNAM    = [F:BPC]BPCNAM          # Raison social
    If dim([F:BPC]CNTNAM) > 0 
       [F:BPR]CNTNAM    = [F:BPC]CNTNAM       # Contact par défaut
    Endif
    If dim([F:BPC]BPAADD) > 0   
       [F:BPR]BPAADD    = [F:BPC]BPAADD          # Adresse par défaut
    Else
       [F:BPR]BPAADD    = "001"                  # Adresse par défaut
    Endif
    If dim([F:BPR]CUR) > 0
       If dim([F:BPC]CUR) > 0
         [F:BPR]CUR       = [F:BPC]CUR          # Devise
       Endif
    Endif
    [F:BPR]CREDAT    = [F:BPC]CREDAT          # Date création
    [F:BPR]CREUSR    = [F:BPC]CREUSR          # Opérateur création
    [F:BPR]UPDDAT    = [F:BPC]UPDDAT          # Date modification
    [F:BPR]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
          
    # Rubriques par defaut 
    [F:BPR]BPSFLG    = 1                      # Flag fournisseur
    [F:BPR]BPTFLG    = 1                      # Flag transporteur
    [F:BPR]REPFLG    = 1                      # Flag representant
    [F:BPR]FCTFLG    = 1                      # Flag factor
    [F:BPR]BPRFBDMAG = 1                      # Interdit mailing 

    For I = 0 To 3
        [F:BPR]BPRFLG (I) = 1                 # Flag divers
    Next I 
    [F:BPR]BPCFLG    = 2                      # Flag Client

    # Maj
    If LEXI
       [F:BPR]BPCFLG = 2                      # Flag Client
       [F:BPR]UPDDAT = date$ 
       [F:BPR]UPDUSR = GUSER 
       Rewrite [BPR]
    Else
        SI_TABLE = "BPARTNER"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPR]
        If fstat
           Call ECR_TRACE("Business Partner"-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Else
     Readlock [BPR]BPR0 = [F:BPC]BPCNUM
     If fstat = 1
        Call ECR_TRACE("Business Partner"-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(27,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR  = 1
        Return
     Endif
    [F:BPR]BPCFLG    = 2
    [F:BPR]UPDDAT    = date$
    [F:BPR]UPDUSR    = GUSER
    Rewrite [BPR]
Endif

Return


##################################################################
#  Creation BPDLVCUST
##################################################################
$CRE_BPD
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
If dim([F:BPC]BPAADD) > 0   
   LBPAADD    = [F:BPC]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPD]BPD0 = [F:BPC]BPCNUM;LBPAADD
If fstat <> 0
    Readlock [BPD]BPD0=[F:BPC]BPCNUM;LBPAADD
    If fstat
        Raz [F:BPD]
        Raz LEXI
        [F:BPD]          = [F:BCG]            # tranclasse categorie client  
        [F:BPD]REP(0)    = [F:BCG]REPDLV(0) 
        [F:BPD]REP(1)    = [F:BCG]REPDLV(1) 
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du client Integrale
    # Code langue 
    If [F:XCLT]CODLAN <> ""
       [F:BPD]LAN = func SIXFONCTION.SI_COR("XILAN",[F:XCLT]CODLAN,"TABLAN",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif 
    # Site expédition
    If [F:XCLT]DPOPCP <> ""
       [F:BPD]STOFCY = func SIXFONCTION.SI_COR("XIDPO",[F:XCLT]DPOPCP,"FACILITY",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif 
    # Mode livraison 
    If [F:XCLT]EXD <> ""
       [F:BPD]MDL    = func SIXFONCTION.SI_COR("XIMODEXD",[F:XCLT]EXD,"TABMODELIV",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif
    # Transporteur
    # l existence du transporteur sera controlé lors de la migration des fournisseurs par une RAZ
    # si non existence
    If [F:XCLT]TSP <> ""
       [F:BPD]BPTNUM = func SIXFONCTION.SI_COR("XIFOU",[F:XCLT]TSP,"",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif

    # Tournée
    If [F:XCLT]NUMTRN<>0
        [F:BPD]DRN       = val(func SIXFONCTION.SI_COR("XINUMTNCLT",num$([F:XCLT]NUMTRN),"409",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"))
    Endif

    # Rubriques reprises du client X3
    [F:BPD]BPCNUM    = [F:BPC]BPCNUM          # Tiers
    [F:BPD]CREDAT    = [F:BPC]CREDAT          # Date création
    [F:BPD]CREUSR    = [F:BPC]CREUSR          # Opérateur création
    [F:BPD]UPDDAT    = [F:BPC]UPDDAT          # Date modification
    [F:BPD]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
    If dim([F:BPD]ENAFLG) > 0 
       [F:BPD]ENAFLG    = [F:BPC]BPCSTA       # Actif
    Endif
    [F:BPD]BPDNAM    = [F:BPC]BPCNAM          # Raison social
    [F:BPD]BPAADD    = LBPAADD                # Adresse par défaut
    If dim([F:BPD]VACBPR) > 0  
       [F:BPD]VACBPR    = [F:BPC]VACBPR       # Regime de taxe
    Endif    
 
    # Rubriques par defaut 

    If [F:BPD]UVYDAY1       = 0                       
       [F:BPD]UVYDAY1       = 2                  # Lundi   
    Endif
    If [F:BPD]UVYDAY2       = 0                       
       [F:BPD]UVYDAY2       = 2                  # Mardi 
    Endif
    If [F:BPD]UVYDAY3       = 0                       
       [F:BPD]UVYDAY3       = 2                  # Mercredi  
    Endif
    If [F:BPD]UVYDAY4       = 0                       
       [F:BPD]UVYDAY4       = 2                  # Jeudi  
    Endif
    If [F:BPD]UVYDAY5       = 0                       
       [F:BPD]UVYDAY5       = 2                  # Vendredi  
    Endif
    If [F:BPD]UVYDAY6       = 0                       
       [F:BPD]UVYDAY6       = 2                  # Samedi     
    Endif
    If [F:BPD]UVYDAY7       = 0                       
       [F:BPD]UVYDAY7       = 2                  # Dimanche   
    Endif
    If [F:BPD]NPRFLG        = 0                       
       [F:BPD]NPRFLG        = 2                  # Impression bon preparation
    Endif
    If [F:BPD]NDEFLG        = 0                       
       [F:BPD]NDEFLG        = 2                  # Impression bon livraison
    Endif
    If [F:BPD]EECLOC        = 0                       
       [F:BPD]EECLOC        = 1                  # Lieu transport CEE
    Endif
    If [F:BPD]DRN           = 0                       
       [F:BPD]DRN           = 1                  # N tournée
    Endif
    If [F:BPD]DLVPIO        = 0                       
       [F:BPD]DLVPIO        = 1                  # Priorite livraison
    Endif
    If [F:BPD]ENAFLG        = 0                       
       [F:BPD]ENAFLG        = 2                  # Actif 
    Endif
    # Maj
    If LEXI
       [F:BPD]UPDDAT = date$ 
       [F:BPD]UPDUSR = GUSE  
       Rewrite [BPD]
    Else
        SI_TABLE = "BPDLVCUST"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPD]
        If fstat
           Call ECR_TRACE(mess(42,191,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return


##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
If dim([F:BPC]BPAADD) > 0   
   LBPAADD    = [F:BPC]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPA]BPA0 = 1;[F:BPC]BPCNUM;LBPAADD
If fstat <> 0
    Readlock [BPA]BPA0=1;[F:BPC]BPCNUM;LBPAADD
    If fstat
        Raz [F:BPA]
        [F:BPA]CRY = [F:BCG]CRY
        Raz LEXI
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du client Integrale


    [F:BPA]BPAADDLIG (0) =  [F:XCLT]ADR1      # Ligne adresse 1
    [F:BPA]BPAADDLIG (1) =  [F:XCLT]ADR2      # Ligne adresse 2
    [F:BPA]BPAADDLIG (2) =  [F:XCLT]ADR3      # Ligne adresse 3
    [F:BPA]POSCOD        =  [F:XCLT]CODPST    # Code postal     
    [F:BPA]CTY           =  [F:XCLT]VIL       # Ville 

    Call NUMONLY([F:XCLT]TEL,[F:BPA]TEL) From SIXFONCTION    # Telephone
    Call NUMONLY([F:XCLT]TLC,[F:BPA]FAX) From SIXFONCTION    # Fax   
    [F:BPA]TEL(1)        =  [F:BPA]FAX                       # Fax      # hcb 73119
          
    [F:BPA]WEB           =  [F:XCLT]ADRMAI    # Adresse internet

    # Code pays 
    If [F:XCLT]CODPAY <> ""
       [F:BPA]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XCLT]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif  
    # Nom pays
    If [F:BPA]CRY <> "" 
       Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
    Endif

    # Rubriques reprises du client X3
    [F:BPA]BPATYP    = 1                      # Type entité
    [F:BPA]BPANUM    = [F:BPC]BPCNUM          # Entité
    [F:BPA]BPAADD    = LBPAADD                # Adresse 
    [F:BPA]CREDAT    = [F:BPC]CREDAT          # Date création
    [F:BPA]CREUSR    = [F:BPC]CREUSR          # Opérateur création
    [F:BPA]UPDDAT    = [F:BPC]UPDDAT          # Date modification
    [F:BPA]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
 
    # Rubriques par defaut 
    [F:BPA]BPAADDFLG = 2                      # Par défaut
    [F:BPA]CRETIM    = time                   # Heure
    [F:BPA]UPDTIM    = time                   # Heure

    # Maj
    If LEXI
       [F:BPA]UPDDAT = date$ 
       [F:BPA]UPDUSR = GUSE  
       [F:BPA]UPDTIM = time                   # Heure

       Rewrite [BPA]
    Else
        SI_TABLE = "BPADDRESS"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPA]
        If fstat
           Call ECR_TRACE(mess(33,102,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return

##################################################################
#  Creation RIB 
##################################################################
$CRE_BID
Local Integer LEXI
Local Char    BANQUE(GLONBID)

Raz LEXI

# Traitement des domiciliations bancaire  
For [XDQE] Where CODCLT = [F:BPC]BPCNUM
    Raz [F:BID]BIDNUM
    [F:BID]BIDNUM += [F:XDQE]CODBQE
    [F:BID]BIDNUM += [F:XDQE]CODGUI
    [F:BID]BIDNUM += [F:XDQE]NUMCPT
    [F:BID]BIDNUM += [F:XDQE]CLERIB
    
    Look [BID]BID0 = 1;[F:BPC]BPCNUM;[F:BID]BIDNUM
    If fstat <> 0
       Readlock [BID]BID0=1;[F:BPC]BPCNUM;[F:BID]BIDNUM
       If fstat
          Raz [F:BID]
          [F:BID]CRY = [F:BCG]CRY
          Raz LEXI
       Else
          LEXI = 1
       Endif
       # Rubriques reprises domiciliation bancaire 
       Raz [F:BID]BIDNUM
       [F:BID]BIDNUM += [F:XDQE]CODBQE
       [F:BID]BIDNUM += [F:XDQE]CODGUI
       [F:BID]BIDNUM += [F:XDQE]NUMCPT
       [F:BID]BIDNUM += [F:XDQE]CLERIB
       [F:BID]BICCOD  = [F:XDQE]CODBIC     # Code BIC       

       # code pays 
       If [F:XDQE]CODPAY <> ""
          [F:BID]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XDQE]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
       Endif
       # lecture Pays pour controle RIB
       If [F:BID]CRY <> "" &  [F:TCY]CRY <> [F:BID]CRY
          Read [TCY]TCY0 = [F:BID]CRY
          If fstat
             Raz [F:TCY]
          Endif
       Endif

       If [F:TCY]BIDCTL=2
          BANQUE = left$([F:XDQE]CODBQE,[F:TCY]BANLNG)
          Read [ABN]ABN0 = [F:BID]CRY;BANQUE
          If fstat
             Call ECR_TRACE(mess(145,197,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(173,133,1)-[F:TCY]CRY-BANQUE,1) From GESECRAN
             LERR = 1
             Return
          Endif
       Endif

       # Rubriques reprises de la banque  X3
       [F:BID]PAB1      =  [F:ABN]PAB         # Domiciliation     

       # Rubriques reprises du client X3
       [F:BID]BPATYP    = 1                      # Type entité
       [F:BID]BPANUM    = [F:BPC]BPCNUM          # Entité

       If dim([F:BPC]BPAADD) > 0   
          [F:BID]BPAADD = [F:BPC]BPAADD          # Adresse par défaut
       Else
          [F:BID]BPAADD = "001"                  # Adresse par défaut
        Endif
       [F:BID]CREDAT    = [F:BPC]CREDAT          # Date création
       [F:BID]CREUSR    = [F:BPC]CREUSR          # Opérateur création
       [F:BID]UPDDAT    = [F:BPC]UPDDAT          # Date modification
       [F:BID]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
       # Rubriques reprises du XICLT

       If dim([F:BPC]CUR) > 0
         [F:BID]CUR       = [F:BPC]CUR          # Devise
       Endif

       # Rubriques par defaut 
       [F:BID]CRETIM    = time                   # Heure
       [F:BID]UPDTIM    = time                   # Heure

       # Maj
       If LEXI
          [F:BID]UPDDAT = date$ 
          [F:BID]UPDUSR = GUSE 
          [F:BID]UPDTIM = time                   # Heure
 
          Rewrite [BID]
       Else
          SI_TABLE = "BID"
          Gosub SI_BEFWRI From SIXFONCTION
          Write [BID]
          If fstat
             Call ECR_TRACE("mess(6,865,1)"-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
             LERR = 1 
             Return
          Endif
       Endif
    Endif
Next

Return


##################################################################
#  Creation CONTACT
##################################################################
$CRE_CNT
Local Integer LEXI
Local Char WCCNCRM(15) 
Local Integer  WRET  # 47375
Local Char WADR      # 47375  
WADR = "001"         # 47375
Raz LEXI

# Traitement des contacts 
For [XITL] Where PFX = "C" & CODTIE = [F:XCLT]CODCLT 
    WCCNCRM = [F:BPC]BPCNUM 
    If [F:XITL]INDX >1
       WCCNCRM += num$([F:XITL]INDX) 
    Endif
    Look [CNT]CNT0 = 1;[F:BPC]BPCNUM;WCCNCRM
    If fstat <> 0
       Readlock [CNT]CNT0=1;[F:BPC]BPCNUM;WCCNCRM
       If fstat
          Raz [F:CNT]
          Raz LEXI
       Else
          LEXI = 1
       Endif

       # Rubriques reprises du client X3
       [F:CNT]BPATYP    = 1                      # Type entité
       [F:CNT]BPANUM    = [F:BPC]BPCNUM          # Entité
       [F:CNT]CCNCRM    = WCCNCRM                # Code   

       If dim([F:BPC]BPAADD) > 0   
          [F:CNT]BPAADD = [F:BPC]BPAADD          # Adresse par défaut
       Else
          [F:CNT]BPAADD = "001"                  # Adresse par défaut
       Endif

#dem 47375 deb
       If  [F:XITL]ADR1   <> "" |   
&          [F:XITL]ADR2   <> "" |     
&          [F:XITL]ADR3   <> "" |   
&          [F:XITL]CODPST <> "" |        
&          [F:XITL]VIL    <> "" |     
&          [F:XITL]ADRMAI <> ""      
           If  [F:XITL]ADR1   =  [F:XCLT]ADR1    &   
&              [F:XITL]ADR2   =  [F:XCLT]ADR2    &    
&              [F:XITL]ADR3   =  [F:XCLT]ADR3    &   
&              [F:XITL]CODPST =  [F:XCLT]CODPST  &       
&              [F:XITL]VIL    =  [F:XCLT]VIL     &    
&              [F:XITL]ADRMAI =  [F:XCLT]ADRMAI     
           Else
               Call PLUS_UN(WADR ,WADR ,WRET) From SIXFONCTION
               If WRET 
                  [F:CNT]BPAADD = "001"              # Adresse par défaut
               Else
                  [F:CNT]BPAADD = WADR               # Adresse par défaut
                  Gosub CRE_BPA_CNT 
                  If GOK <= 0 & SI_SIMU <> 2 
                     Break
                  Endif
               Endif
           Endif
       Endif
#dem 47375 fin
       [F:CNT]CREDAT    = [F:BPC]CREDAT          # Date création
       [F:CNT]CREUSR    = [F:BPC]CREUSR          # Opérateur création
       [F:CNT]UPDDAT    = [F:BPC]UPDDAT          # Date modification
       [F:CNT]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
       # Rubriques reprises du XIITLCLT
       Call NUMONLY([F:XITL]TEL1,[F:CNT]TEL) From SIXFONCTION    # Telephone
       Call NUMONLY([F:XITL]TLC,[F:CNT]FAX)  From SIXFONCTION    # Fax   
       [F:CNT]WEB       = [F:XITL]ADRMAI         # E-mail                
       # Rubriques par defaut 
       [F:CNT]CNTFNC    = 12                     # Fonction  (cette valeur est un pre-requis)
       [F:CNT]CRETIM    = time                   # Heure
       [F:CNT]UPDTIM    = time                   # Heure

       # Maj
       If LEXI
          [F:CNT]UPDDAT = date$ 
          [F:CNT]UPDUSR = GUSER
          [F:CNT]UPDTIM = time                   # Heure
          Rewrite [CNT]
       Else
          SI_TABLE = "CONTACT"
          Gosub SI_BEFWRI From SIXFONCTION
          Write [CNT]
          If fstat
             Call ECR_TRACE("mess(183,197,1)"-[F:BPC]BPCNUM-"/"-WCCNCRM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
             LERR = 1 
             Return  
          Endif
          Look [AIN]AIN0 = WCCNCRM
          If fstat <> 0
             Readlock [AIN]AIN0=WCCNCRM
             If fstat
                Raz [F:AIN]
                [F:AIN]          = [F:CNT]
                [F:AIN]CNTNUM    = WCCNCRM                # Code   
                [F:AIN]CNTLNA    = [F:XITL]NOM1           # Nom   
                If dim([F:AIN]CNTTYP) > 0   
                       [F:AIN]CNTTYP    = 1               # Type  (standard)
                Endif
                [F:AIN]CNTTTL    = 1                      # Civilité (Monsieur)
                [F:AIN]CNTFBDMAG = 1                      # Interdit mailing 

                [F:AIN]CNTFULNAM = func SUBAIN.CLE([F:AIN]CNTLNA,[F:AIN]CNTFNA)
                # code pays 
                If [F:XCLT]CODPAY <> ""
                   [F:AIN]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XCLT]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
                Endif
                Call NUMONLY([F:XITL]TEL2,[F:AIN]CNTMOB)  From SIXFONCTION    # Portable   
                SI_TABLE = "CONTACTCRM"
                Gosub SI_BEFWRI From SIXFONCTION
                Write [AIN]
                If fstat
                   Call ECR_TRACE("mess(183,197,1)"-WCCNCRM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
                   LERR = 1
                   Return 
                Endif
             Endif
          Endif
       Endif
    Endif
Next

Return


#dem 47375 deb
##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA_CNT
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
LBPAADD    = [F:CNT]BPAADD          # Adresse par défaut

Look [BPA]BPA0 = 1;[F:BPC]BPCNUM;LBPAADD
If fstat <> 0
    Readlock [BPA]BPA0=1;[F:BPC]BPCNUM;LBPAADD
    If fstat
        Raz [F:BPA]
        [F:BPA]CRY = [F:BCG]CRY
        Raz LEXI
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du client Integrale


    [F:BPA]BPAADDLIG (0) =  [F:XITL]ADR1      # Ligne adresse 1
    [F:BPA]BPAADDLIG (1) =  [F:XITL]ADR2      # Ligne adresse 2
    [F:BPA]BPAADDLIG (2) =  [F:XITL]ADR3      # Ligne adresse 3
    [F:BPA]POSCOD        =  [F:XITL]CODPST    # Code postal     
    [F:BPA]CTY           =  [F:XITL]VIL       # Ville 
    [F:BPA]WEB           =  [F:XITL]ADRMAI    # Adresse internet

    Call NUMONLY([F:XITL]TEL1,[F:BPA]TEL) From SIXFONCTION    # Telephone
    Call NUMONLY([F:XITL]TLC,[F:BPA]FAX)  From SIXFONCTION    # Fax   
    [F:BPA]TEL(1)        =  [F:BPA]FAX                        # Fax      # hcb 73119
          

    # Code pays 
    If [F:XITL]CODPAY <> ""
       [F:BPA]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XITL]CODPAY,"TABCOUNTRY",mess(183,197,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")")
    Endif  
    # Nom pays
    If [F:BPA]CRY <> "" 
       Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
    Endif

    # Rubriques reprises du client X3
    [F:BPA]BPATYP    = 1                      # Type entité
    [F:BPA]BPANUM    = [F:BPC]BPCNUM          # Entité
    [F:BPA]BPAADD    = LBPAADD                # Adresse 
    [F:BPA]CREDAT    = [F:BPC]CREDAT          # Date création
    [F:BPA]CREUSR    = [F:BPC]CREUSR          # Opérateur création
    [F:BPA]UPDDAT    = [F:BPC]UPDDAT          # Date modification
    [F:BPA]UPDUSR    = [F:BPC]UPDUSR          # Opérateur modification
 
    # Rubriques par defaut 
    [F:BPA]BPAADDFLG = 2                      # Par défaut
    [F:BPA]CRETIM    = time                   # Heure
    [F:BPA]UPDTIM    = time                   # Heure

    # Maj
    If LEXI
       [F:BPA]UPDDAT = date$ 
       [F:BPA]UPDUSR = GUSE  
       [F:BPA]UPDTIM = time                   # Heure

       Rewrite [BPA]
    Else
        SI_TABLE = "BPADDRESS"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPA]
        If fstat
           Call ECR_TRACE(mess(33,102,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return

#dem 47375 fin eee










