#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################
# JUCON Print SBONFAC pdf from Syracusa function - Epic X3-64474 #
##################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
Endcase
Return

$INIT
Local Char WNUM(30), WFCY(5), WBPRNUM(30), WRPT(15),  WMESS(250)
Local Integer WINVTYP, WFLG
Local Date WREFDAT

WNUM=PARAM(1)
WFCY=PARAM(2)
WINVTYP=val(PARAM(3))
WBPRNUM=PARAM(4)
WREFDAT=PARAM(5)
WRPT=PARAM(7)
WFLG=1

Call IMPPDF(WNUM,WFCY,WINVTYP,WBPRNUM,WREFDAT,WFLG,WRPT,WMESS) From EDIPRTPDF

PARAM(8)=WMESS
If WMESS<>"" :PARAM(6)="2": Endif

Return

#######################################################
# Subprog IMPPDF(NUM,FCY,INVTYP,BPRNUM,REFDAT,FLG,RPT)
# NUM     - Documnent number
# FCY     - Site
# INVTYP  - Invoice type
# BPRNUM  - BP number
# REFDAT  - Invoice date
# FLG     - Flag
# RPT     - CR to use
# MESSA   - Message
########################################################
Subprog IMPPDF(NUM,FCY,INVTYP,BPRNUM,REFDAT,FLG,RPT,MESSA)
Value    Char    NUM
Value    Char    FCY
Value    Integer INVTYP
Value    Char    BPRNUM
Value    Date    REFDAT
Value    Integer FLG
Value    Char    RPT
Variable Char    MESSA

  Local Char WNUM  (50): WNUM=NUM
  Local Char WDEST (20)
  Local Char WFICNAM (250)
  Local Char WFICDIR (250)
  Local Char WPTC (50)
  Local Char WERRPTC (250)
  Local Char WMESS (250)
  Local Char WDES (250)
  Local Integer NBTEST

  Call GET_ETAT_PROP(WNUM,WDEST,WFICNAM, WFICDIR,WPTC,WERRPTC) From EDILIBPDF

  If WERRPTC <>""
    MESSA=WERRPTC
  Else
    DESTINATION= WDEST
    WFICHIER   = WFICNAM
    If WFICDIR<>""
      Local Char WSEP(1)
      Local Integer WTAG
      WTAG=instr(1,WFICDIR,"/")
      If WTAG>0: WSEP="/"
      Else  WSEP="\"
      Endif
      WFICHIER=WFICDIR+WSEP+WFICNAM
    Endif

    WDES=WFICHIER

     WFICHIER=func EDILIBPDF.SOLUTION(1)
     WFICHIER+="\Temp\"+WFICNAM
#    WFICHIER="D:\Sage\SafeX3\EDTV2\EDTSRV\srvedit\Temp"+"\"+WFICNAM  ##For SCM test

    # Generate the report
    Call ETAT(RPT,DESTINATION,"",0,"",WTBPAR,WTBVAL) From AIMP3

    #Coping to the attachment volume
    Call COPY_ATT(WPTC,WFICNAM,WDES,WSEP,WMESS) From EDILIBPDF

    MESSA=WMESS
    WFICHIER=WDES
  Endif
End

#--------------------------------------------------
$FICHIER
FICHIER=WFICHIER

Return

