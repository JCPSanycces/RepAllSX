#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Recherche les champs dans les masques utilisant des types de données avec action
# Pour chaque action du type de donnée, vérifie que les paramètres sont définis dans AMSKPAR
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Search for missing parameters") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Current folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Current folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = DOSSIER
Call TRAITE_CHAR(VALEUR,PARAM,"","ACTLPARMSK","",1,"") From GTRAITE
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#----------------------------------#
$TERMINE
TRA = !TRACE
GERRTRACE = 0
Return

#-------------------#
$EXEC
Local Char DOSSIER(GLONADS)
DOSSIER = PARAM(1)

TRACE = (GTRACE<>"")

If DOSSIER=GDOSX3 & GADONIX<>2
 Return
Endif

If !GSERVEUR
 Call TEMPON(DOSSIER) From GESECRAN
 If !TRACE
  # Recherche des paramètres actions inexistant dans le dossier $1$
  Call OUVRE_TRACE(func AFNC.MES1(mess(336,115,1),DOSSIER)) From LECFIC
 Endif
Endif

Local Integer NBMSK, NBERR, ERR
 
Local File =DOSSIER+".AMSK"     [AMK] , =DOSSIER+".AOBJET"   [AOB] , =DOSSIER+".AMSKPAR"  [AMP]
Local File =DOSSIER+".AMSKPAR"  [AP2] , =DOSSIER+".AMSKZON"  [AM2] , =DOSSIER+".AMSKACT"  [AMA]
Local File =DOSSIER+".ACTION"   [ACT] , =DOSSIER+".ACTPAR"   [ATR] , =DOSSIER+".ATYPE"    [ATY]

Raz NBMSK , NBERR
For [AMK] Where left$(CODMSK,1)<>"W"
 Call CONTPAR([F:AMK]CODMSK,ERR)
 NBMSK += (ERR<>0)
 NBERR += ERR
Next AMK

# Il y a $1$ erreurs trouvées sur $2$ écrans
Call ECR_TRACE(func AFNC.MES2(mess(335,115,1),num$(NBERR),num$(NBMSK)),0) From GESECRAN

If !GSERVEUR
 If !TRACE
  Call FERME_TRACE From LECFIC
 Endif
 Call TEMPOFF From GESECRAN
Endif

Return
 
#-----------------------------------------------------------#
Subprog CONTPAR(AFF,ERR)
Value    Char    AFF
Variable Integer ERR

Local    Char    ZON(GLONAVA), MESSA(100), ACT(GLONACT), ACTION(GLONACT), PAR(GLONAAR)
Local    Integer OK2, I, J, K, III, PLEIN, CONTYP, TYP
Local    Integer PPP(300)
Local    Char    COD(30)(1000), CCC(30)(300)

ERR = 0
TYP = 1
Raz COD, J, PLEIN
For [AM2]CODE Where CODMSK=AFF
 Raz CCC, PPP, III
 ZON = [F:AM2]CODZON
 Gosub CONTACT : # Contrôle des paramètres des actions
 Gosub CONTTYP : # Contrôle des paramètres liés aux codes types
Next AM2

End

#----------------------#
$CONTACT
CONTYP = 0
Filter [AMA] Where TYPAFF=1 & CODAFF=AFF & CODZON=ZON
For [AMA]
 [L]ACTION = [F:AMA]ACTION
 While [L]ACTION<>""
  Gosub CONT_PAR
  [L]ACTION = [F:ACT]ACTSUI
 Wend
Next
Filter [AMA]
Return

#----------------------#
$CONT_PAR
Read [ACT]ACTION=[L]ACTION
For [ATR]NOPAR Where ACTION=[L]ACTION
 OK2  = 0
 OK2 += ([F:ATR]NOPAR=1 & [F:ACT]TYPACT<>1)
 If !OK2
  PAR = [F:ATR]CODPAR
  Gosub INC_PAR
 Endif
Next
Return

#----------------------#
$CONTTYP
CONTYP = 1
Read [ATY]CODTYP=[F:AM2]CODTYP
For KK=1 To [F:ATY]NBTYP
 ACT = [F:ATY]ACTION(KK-1)
 While ACT<>""
  Read [ACT]ACTION=[L]ACT
  For [ATR]NOPAR Where [F:ATR]ACTION=ACT
   If [F:ACT]TYPACT=1 | [F:ATR]NOPAR<>1
    PAR = [F:ATR]CODPAR
    Gosub INC_PAR
   Endif
  Next ATR
  ACT = [F:ACT]ACTSUI
 Wend
Next KK
If [F:ATY]OBJLIEN<>""
 Read [AOB]ABREV=[F:ATY]OBJLIEN
 If [F:AOB]LIBPAR<>0
  PAR = [F:AOB]ABREV
  Gosub INC_PAR
 Endif
Endif
If [F:ATY]PARTAB<>""
 PAR = [F:ATY]PARTAB
 Gosub INC_PAR
Endif
Return

#-------------------------#
$INC_PAR
If PLEIN : Return : Endif
Raz MESSA
K = find(ZON+PAR,COD(0..J-1))
If !K
 J += 1
 If J>dim(COD)-1
  MESSA = mess(148,123,1) : # Contrôle impossible, trop de paramètres
  PLEIN = 1
 Else
  COD(J-1) = ZON+PAR
  Read [AMP]CODPAR = 1;AFF;ZON;PAR
  If fstat or [F:AMP]VALPAR=""
   MESSA  = mess(149,123,1)-ZON+":" : # Champs
   If fstat
    MESSA -= mess(11,133,1)-PAR : # Paramètre inexistant
   Else
    MESSA -= mess(171,133,1)-PAR : # Paramètre non renseigné
   Endif
   If CONTYP
    MESSA -= "("+mess(59,100,1)-[F:AM2]CODTYP+")" : # Type
   Else
    MESSA -= "("+mess(27,115,1)-[L]ACTION+")" : # Action
   Endif
  Endif
 Endif
 If MESSA<>"" : Gosub TRACE : Endif
Endif
Return

#---------------------#
$TRACE
ERR += 1
Call ECR_TRACE(mess(255,115,1)-[F:AMK]CODMSK+", "+MESSA,1) From GESECRAN
Return

