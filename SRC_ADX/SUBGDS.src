#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GDS",GBIDC1,GBIDC2) From GOBJET
End

# Issue X3-70924 - 2018-01-15 - MDJ : Replace the call to VALID from VALMSK by a call to VALIDFULL from VALMSK

$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub INIT_CHAMP
 When "APRES_CRE"  : Gosub VALID
 When "APRES_MOD"  : Gosub VALID
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub CHANGE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
Endcase
Return

$OUVRE
Local Char    LIBEL(30) , MASKREF(10) , CONSCOD(10)
Local Integer ER
Return

$INICRE
$INIMOD
If dim([F:GDS]DES)>0
 [F:GDS]DES = [M:GDS1]DESTRA
Endif
Return


$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"VUO") From GOBJET
Endif
If GBROWS
  Call VIREBOUT(CHAINE,"OB") From GOBJET : # Visu, Visu Web
Endif
If CLECUR1="STD"
 Call VIREBOUT(CHAINE,"A#") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "V" : # Validation
  Gosub VALID
 When "O" : # Visualisation
  Call VISUM("WMDUD"+[M]COD) From SUBAMK
 When "B"
  Call VISUMWEB("WMDUD"+[M]COD) From SUBAMK
Endcase
Return

$LIENS
[M]NBRFLD = 0
Call LECTEXTRA([M]DESTRA,"GDUDSCR","DESTRA",[M]COD,"") From ATEXTRA
Gosub CHARGE_CHAMP
For NOL=0 To [F:GDS]NBRFLD-1
 K = find([F:GDS]FLD(NOL),[M]FLD(0..[M]NBRFLD))
 If K
  [M]DAC(K-1) = [F:GDS]DAC(NOL)
  [M]SAI(K-1) = [F:GDS]SAI(NOL)
 Endif
Next NOL
Gosub TRI
Return

$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9999 : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=9999 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return

$LIBEL
If [F:AMZ]INTEVAL<>""
 Onerrgo ERRLIB
 ER = 0
 [M]INTIT(NOL) = evalue([F:AMZ]INTEVAL)
 If ER
  [M]INTIT(NOL) = [F:AMZ]INTEVAL
 Endif
 Onerrgo
Else
 Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
 [M]INTIT(NOL) = LIBEL
Endif
Return

$ERRLIB
ER = errn
Resume

$CHARGE_CHAMP
Gosub MASKREF
For [AMZ]CODZON Where CODMSK=MASKREF & NUMBLOC=1
 OK = 1
 If [F:AMZ]CODTYP="ABS" or [F:AMZ]SAIAFF=3
  OK = 0
 Endif
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
 If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
  NOL = [M]NBRFLD
  [M]FLD(NOL)    = [F:AMZ]CODZON
  [M]SAIREF(NOL) = [F:AMZ]SAIAFF
  Gosub LIBEL
  [M]NBRFLD += 1
 Endif
Next
Return

$MASKREF
Local Char MASKREF(10) , WINREF(10)
MASKREF = "DUDATMGT2"
WINREF  = "FMECH"
Return

$INIT_CHAMP
Gosub CHARGE_CHAMP
For NOL=0 To [M]NBRFLD-1
 [M]SAI(NOL) = 1
Next
Gosub TRI
Affzo NBRFLD,FLD,INTIT,DAC,SAI
OK = 1
Return

$ANNULE
#Annulation des textes traduisibles
Call SUPTEXTRA("GDUDSCR","DESTRA",[M]COD,"") From ATEXTRA
# Annulation des écrans
Local Char MASQUE1(10) , NOMWIN(10)
MASQUE1 = "WMDUD"+CODE
NOMWIN  = "WDUD"+CODE
Call DELMSK(MASQUE1,nomap) From MSKDIV
If GOK<1 : Return : Endif
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return

$CHANGE
Call CHGTEXTRA("GDUDSCR","DESTRA",[M]COD,"",NCODE,"") From ATEXTRA
# Annulation ancien écran
Local Char MASQUE1(10) , NOMWIN(10)
MASQUE1 = "WMDUD"+OCODE
Call TR_DELMSK(MASQUE1,nomap) From MSKDIV
NOMWIN  = "WDUD"+OCODE
Call TR_DELWIN(NOMWIN,nomap) From MSKDIV
# Validation du nouveau
Read [GDS]GDS0 = NCODE
Call VALIDATION(NCODE,nomap)
Return


$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GDUDSCR","DESTRA",CLECUR1,"","GDUDSCR","DESTRA",[M]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GDUDSCR","DESTRA",[M]COD,"") From ATEXTRA
Return

$VALID
If !GIMPORT
 Call VALIDATION([F:GDS]COD,nomap)
Endif
Return

######################################################
Subprog PATCH(APPLI)
Value Char APPLI()

If APPLI="X3" : End : Endif
Onerrgo CHUT From CONTROLE
Local File =APPLI+".ADOVAL" [ADW]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [ADW]ADW0 = "";"";"MODULE1"
If fstat=0 & ([F:ADW]VALEUR="" | mid$([F:ADW]VALEUR,3,1)="2") : # si module Tiers
 Call GENDOS(APPLI) From SUBGDS
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI
Local File =APPLI+".AMSK"    [AMK] , =APPLI+".AMSK"    [AMK2]
Local File =APPLI+".AMSKZON" [AMZ] , =APPLI+".AMSKZON" [AMZ2]
Local File =APPLI+".AMSKACT" [AMA] , =APPLI+".AMSKACT" [AMA2]
Local File =APPLI+".AMSKPAR" [AMP] , =APPLI+".AMSKPAR" [AMP2]
Local File =APPLI+".GDUDSCR" [GDS]
Local File =APPLI+".AWINDOW" [AWI] , =APPLI+".AWINDOW" [AWI2]
Local File =APPLI+".AWINPAR" [AWP] , =APPLI+".AWINPAR" [AWP2]
Local File =APPLI+".AWINBRO" [AWB] , =APPLI+".AWINBRO" [AWB2]
Local File =APPLI+".AWINBOUT"[AWT] , =APPLI+".AWINBOUT" [AWT2]
Local File =APPLI+".AOBJET"  [AOB] , =APPLI+".AOBJTAB" [AOT] , =APPLI+".AOBJLST" [AOL]
For [GDS] Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:GDS]COD,0) From GESECRAN : Endif
 Call VALIDATION([F:GDS]COD,APPLI)
Next
End

Subprog VALIDATION(COD,APPLI)
Value Char COD
Value Char APPLI
Local Char    MASKDES(10) , MASKREF(10) , NOMWIN(10) , SAVLAN(3)
Local Integer OK , NOL , RANG, NCOL , LANCUR

# JML 27/03/00
Local Integer  O_X1
Local Integer  O_Y1
Local Integer  O_X2
Local Integer  O_Y2_0
Local Integer  O_Y2_1
Local Integer  O_TITBLOC
Local Integer  O_TYPBLOC
Local Integer  O_RANG
Local Integer  O_LNGLIB
Local Char     O_ACTBLOC(5)
Local Integer  O_NBLIGT
Local Char     O_OPTION(20)
Local Char     O_BASPAG(20)
Local Integer  O_DETBLC

If clalev([F:AMK])=0  : Local File AMSK    [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File AMSKACT [AMA]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR [AMP]  : Endif
If clalev([F:AWI])=0  : Local File AWINDOW [AWI]  : Endif
If clalev([F:AWP])=0  : Local File AWINPAR [AWP]  : Endif
If clalev([F:AWB])=0  : Local File AWINBRO [AWB]  : Endif
If clalev([F:AWT])=0  : Local File AWINBOUT[AWT]  : Endif
If clalev([F:AMK2])=0 : Local File AMSK    [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File AMSKPAR [AMP2] : Endif
If clalev([F:AWI2])=0 : Local File AWINDOW [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File AWINPAR [AWP2] : Endif
If clalev([F:AWB2])=0 : Local File AWINBRO [AWB2] : Endif
If clalev([F:AWT2])=0 : Local File AWINBOUT[AWT2] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV" [ACV] : Endif

Call DEBTRANS From GLOCK
Gosub MASKREF
NOMWIN  = "WDUD"+COD
MASKDES = "WMDUD"+COD
Gosub TR1
If GOK=1
 Read [ADS]DOSSIER = APPLI
 If [F:GDS]ENAFLG=2
  SAVLAN = GLANGUE
  # JML 27/03/00 Suggestion 2354 Total échéances
  If [F:GDS]TOTDUD<>2
   Call DEBTRANS From GLOCK
   Gosub TR2
  Endif
  # CP : 01/2001 : Gestion des échéances / agios.
  NOL = find("AMTDEP",[F:GDS]FLD(0..[F:GDS]NBRFLD-1))
  If !NOL | [F:GDS]DAC(NOL-1)=0 : Gosub TR4 : Endif
  If GOK=1
    #*X3-70924 Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
    Call VALIDFULL(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Endif
  If GOK=1
   Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
  Endif
 Endif
Endif
End

$TR1
GOK=1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [AWI2] , [AWP2]
 Call DELMSK(MASKDES,APPLI) From MSKDIV
 Call DELWIN(NOMWIN,APPLI) From MSKDIV
 If [F:GDS]ENAFLG=2
  Read [AMK]CODMSK = MASKREF
  [F:AMK2] = [F:AMK]
  [F:AMK2]CODMSK = MASKDES
  [F:AMK2]MDL    = 1
#  [F:AMK2]TITBLOC(0) = [F:GDS]DES
  For J=1 To 9
   K = instr(1,[F:AMK2]OPTION(0),num$(J))
   If K
    [F:AMK2]OPTION(0) = left$([F:AMK2]OPTION(0),K-1)+right$([F:AMK2]OPTION(0),K+1)
   Endif
  Next J
  [F:AMK2]OPTION(0) += num$([F:GDS]NBRCOL)
  [F:AMK2]NBLIGT(0)  = [F:GDS]NBRLIG
  [F:AMK2]ACTBLOC(0) = ""
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
  Endif
  For [AMZ]CODZON Where CODMSK=MASKREF
   If [F:AMZ]NUMBLOC<>1 or [F:AMZ]SAIAFF=3
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES
   Else
    NOL = find([F:AMZ]CODZON,[F:GDS]FLD(0..[F:GDS]NBRFLD-1))
    OK = 0
    If NOL & [F:GDS]DAC(NOL-1)<>0
     OK = 1 : RANG = max(3,[F:GDS]DAC(NOL-1))
    Endif
    If [F:AMZ]CODTYP="ABS"
     OK = 1 : RANG = 0
    Endif
    If [F:AMZ]CODZON="TYP" : # On force le type et le numéro de pièce
     OK = 1
     [F:GDS]SAI(NOL-1) = 2
     RANG = 1
    Elsif [F:AMZ]CODZON="NUM"
     OK = 1
     [F:GDS]SAI(NOL-1) = 2
     RANG = 2
    Endif
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MASKDES
    [F:AMZ2]NOZONE = RANG
    If [F:AMZ]CODTYP="ABS"
     [F:AMZ2]SAIAFF = 1
    Elsif !OK | [F:AMZ]SAIAFF=3
     [F:AMZ2]SAIAFF = 3
    Else
     If [F:GDS]SAI(NOL-1)=2
      [F:AMZ2]SAIAFF = 1
     Else
      [F:AMZ2]SAIAFF = 2
     Endif
    Endif
   Endif
   Write [AMZ2]
   If fstat
    GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKREF
   [F:AMA2] = [F:AMA]
   [F:AMA2]CODAFF = MASKDES
   Write [AMA2]
   If fstat
    GOK=0 : Call FSTA("AMA2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKREF
   [F:AMP2] = [F:AMP]
   [F:AMP2]CODAFF = MASKDES
   Write [AMP2]
   If fstat
    GOK=0 : Call FSTA("AMP2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  Read [AWI]AWI0 = WINREF
  [F:AWI2] = [F:AWI]
  [F:AWI2]NOMMSK(0) = MASKDES
  [F:AWI2]FLGMSK(0) = 2
  [F:AWI2]WIN       = NOMWIN
  [F:AWI2]MDL    = 1
  Write [AWI2]
  If fstat
   GOK = 0 : Call FSTA("AWI2") From GLOCK : Goto AB_TR1
  Endif
  For [AWP]AWP0 Where WIN=WINREF
   [F:AWP2] = [F:AWP]
   [F:AWP2]WIN = NOMWIN
   Write [AWP2]
   If fstat
    GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
   Endif
  Next I
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  For [AWT] Where WIN=WINREF
   [F:AWT2]=[F:AWT]
   [F:AWT2]WIN = NOMWIN
   Write [AWT2]
   If fstat
    GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Read [F:AWB]AWB0 = WINREF
  If !fstat
   [F:AWB2]= [F:AWB]
   [F:AWB2]WIN = NOMWIN
   Write [AWB2]
   If fstat
    GOK = 0 : Call FSTA("AWB2") From GLOCK : Goto AB_TR1
   Endif
  Endif

 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
Trbegin [AMK2]
 If [F:GDS]ENAFLG=2
  GCLE = MASKDES
  Readlock [AMK2]CODMSK = MASKDES
  If fstat=1
   GOK = -1 : GLOCK="$AMSK"-GCLE : Goto ROLL_TR2
  Elsif fstat
   GOK = 0 : Call RSTA("AMK2",GCLE) From GLOCK : Goto AB_TR2
  Endif
  # 1ère ligne
  [F:AMK2]LINBLOC(0) += 1
  # 2ème ligne
  [F:AMK2]TYPBLOC(1) = 5  : # LA38 Invisible
  Rewrite [AMK2]
  If fstat
   GOK = 0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR2
  Endif
  For [AMZ2]CODZON Where CODMSK=[F:AMK2]CODMSK & NUMBLOC=2
   [F:AMZ2]SAIAFF = 3
   Rewrite [AMZ2]
   If fstat
    GOK = 0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Next

  If GOK<1 : Goto AB_TR2 : Endif
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$TR4
GOK=1
Trbegin [AMK2]
 If [F:GDS]ENAFLG=2
  GCLE = MASKDES
  Readlock [AMK2]CODMSK = MASKDES
  If fstat=1
   GOK = -1 : GLOCK="$AMSK"-GCLE : Goto ROLL_TR4
  Elsif fstat
   GOK = 0 : Call RSTA("AMK2",GCLE) From GLOCK : Goto AB_TR4
  Endif

 # 3ème ligne
  [F:AMK2]COLBLOC(2) += 1
  [F:AMK2]LNGLIB(2)   = 15
  # 4ème ligne
  [F:AMK2]POSBLOC(3) += 0.1
  [F:AMK2]LNGLIB(3)   = 15
  # 5 ème ligne
  [F:AMK2]TYPBLOC(4) = 5  : # Zone Invisible

  Rewrite [AMK2]
  If fstat
   GOK = 0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR4
  Endif
  For [AMZ2]CODZON Where CODMSK=[F:AMK2]CODMSK & NUMBLOC=5
   [F:AMZ2]SAIAFF = 3
   Rewrite [AMZ2]
   If fstat
    GOK = 0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Goto AB_TR4 : Endif
 Endif
Commit
Return

$AB_TR4
Rollback
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File GDUDSCR [GDS1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GDUDSCR"  [GDS1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GDUDSCR [GDS2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".GDUDSCR"  [GDS2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GDS1], [GDS2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [GDS2]
 Delete [GDS2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GDUDSCR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GDS2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GDS1] Where COD=TABLE
  [F:GDS2] = [F:GDS1]
  Call COPTEXTRA("GDUDSCR","DESTRA",TABLE,"") From ATEXTRA
  If dim([F:GDS2]UPDUSR)>0 : [F:GDS2]UPDUSR = GUSER : Endif
  If dim([F:GDS2]UPDDAT)>0 : [F:GDS2]UPDDAT = date$ : Endif
  Write [GDS2]
  If fstat
   GOK = 0 : Call FSTA("GDS2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog AS_NBRLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
 Local Integer NCOL
 Local Char    MASKREF(10)
 Gosub MASKREF
 Call LECTURE("AMK",MASKREF,"") From CONTOBJ
 NCOL   = find(1,[F:AMK]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
 VALEUR = [F:AMK]NBLIGT(NCOL-1)
Endif
End

########################################
Subprog AS_SAI(VALEUR)
Variable Integer VALEUR
If [M]DAC(nolign-1)=0 or [M]SAIREF(nolign-1)<>1
 VALEUR = 1 : mkstat = 2
Endif
End

########################################
Subprog C_DAC(VALEUR)
Variable Decimal VALEUR
Local Integer NOL1, NOL2
# CP : Gestion des acomptes / agios
# Contrôle sur le champs AMTDEP, celui ci ne peut être affiché sans le champs DEP

If [M]FLD(nolign-1)="DEP" & VALEUR=0
 NOL1 = find("AMTDEP",[M]FLD(0..[M]NBRFLD-1))
 If NOL1 : [M]DAC(NOL1-1)=0 : Affzo [M]DAC(NOL1-1) : Endif
Elsif [M]FLD(nolign-1)="AMTDEP" & VALEUR<>0
 NOL1 = find("DEP",[M]FLD(0..[M]NBRFLD-1))
 If !NOL1 | [M]DAC(NOL1-1)=0
  # Liée avec zone
  GMESSAGE=mess(2,773,1)-mess(17,115,1)-num$(NOL1)-":"-"'"-[M]INTIT(NOL1-1)-"'"
  mkstat = 2
 Endif
Endif
End

