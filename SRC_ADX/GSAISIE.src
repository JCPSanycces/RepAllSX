#<AdxTL>@(#)11.0.0.0 $Revision$
## GPROG    = Traitement
## GWINDOW  = Ecran de saisie

Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GPROGSPE)
End

############################################################
## Gestion fenêtre principale
############################################################
Subprog SAISIE_CHAR(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Char VALEUR
Variable Char PARAM()(1..)
Value    Char BOITE
Value    Char PROG
Value    Char PROGSPE
Local Integer TYPARG
TYPARG = 1
Goto SAISIE

Subprog SAISIE_NUM(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Decimal VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 2
Goto SAISIE

Subprog SAISIE_DAT(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Date    VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 3
Goto SAISIE

Subprog SAISIE_LIB(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Integer VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 4
Goto SAISIE

Subprog SAISIE_BLOB(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Blbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 5
Goto SAISIE

Subprog SAISIE_CLOB(VALEUR,PARAM,BOITE,PROG,PROGSPE)
Variable Clbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 6
Goto SAISIE

$SAISIE

#  A-t-on le droit de naviguer vers cette action
Local Char MESSAG(100)
Call CNAVIG(2,"","","","",BOITE,"",MESSAG) From EXEFNC
If MESSAG<>"" : End : Endif

Local Integer MAXBOU : MAXBOU = 80                       : # 114910 Nb max de boutons spéciaux
Local Integer MAXAFF : MAXAFF = 100
Local Integer I , J , K , N , OK , PAG , BOX
Local Integer ETABOU(1..GNBBOU)
Local Integer REPONSE , NBBOUT , CODBOUT(1..30) , NBOUTSTD , LBOUT(30)
Local Char    REP(1) , ACTION(20) , CBOUT(1)(30) , BOUT(1) , CBOUTD(1)
Local Char    ACT(20) , ACTSTD(20) , SAVGREP(1) , SAVGGRPFCY(GLONAGF) , SAVFONC1(GLONAFC)
Local Char    SAVSOCIETE(GLONCPY) , SAVCURLEG(GLONADI) , SAVCURFCY(GLONFCY)
Local Char    OBJ(GLONAOB) , CLES1(GLONID1) , CLES2(GLONID2)(1..16)
Local Char    REPORT1(GLONARP), REPORT2(GLONARP) , STDBOUT(30)
Local Char    TEXTE(30)(30)
Local Char    CMEN(1)(1..MAXBOU) , TMEN(30)(1..MAXBOU) , XMEN(1)(1..MAXBOU) : #114910
Local Integer NBMEN , NBRMEN , NMEN(1..MAXBOU) , LMEN(1..MAXBOU) : #114910
Local Integer NBTEX , NBMASK , MA , BLOC
Local Char    CHAINE(60) , TIT(50)
Local Integer FIN , STADEF , FOK
Local Char    SUIZON(30) , COUZON(30)
Local Integer COUIND
Local Char    WINPROG(GLONADC)
Local Integer AFFMSK, NBAFF
Local Char    AFFCHP(50) , CHAMP(GLONAVA)
Local Integer NUMTXT , IMGFLG(1..11) , ETAMEN(1..MAXBOU) :#SAM 113397 : #114910
Local Integer PSPE
Local Char    SAVPROG(GLONADC) , SAVBOITE(GLONFEN)
Local Integer SAVOBJ , SAVNOL2 , SAVIND2 , SAVTITCOL , SAVNOLIGN
Local Char    CHSTD(30) , CHBOU(30) , CHMEN(MAXBOU), OCHBOU(30), OCHMEN(MAXBOU) : #114910
Local Char    CZ(250)
Local Integer CHGENV, DROIT
Local Libelle SAVIMG(1..dim(GSTAIMG))
Local Char    SAVBOX(20)
Local Char    FILTSUP(250) , CRITERE(250), SAVCRITERE(255)
Local Char    FILGAUSUP(240)(0..3) , FILSUITE(250)(0..5) , FILROLE(250)(0..5)
Local Integer IFILGAUSUP , ICRITERE , IFILSUITE , IFILROLE
Local Char    FILRAP(250)(0..1) : #109309
Local Integer IFILRAP : #109309
Local Char    HINTLIS(GLONAVA)(0..10)
Local Integer NOHLIS(0..10)
Local Char    NAVIG(GLONANG)
Local Integer FLNAV
Local Integer NPICK , STAPICK , FPICK
Local Char    BOXCURR(20)
Local Integer ILIS
Local Integer VERROU
Local Char    SYMBOLE(80), USRLCK(40), MACLCK(40)
Local Char    PJC(10) , AREPORT(GLONARP)
Local Integer NBFONC

GPILOBJ += 1
CHSTD = "N09><XHILJMPSOEAC" : # Liste des boutons standard

######################################
## Sauvegarde contexte
######################################

Call SAVBOUT From GESECRAN
For I=1 To dim(GSTAIMG)
 SAVIMG(I) = GSTAIMG(I)
 If GSTAIMG(I)<>0
  Call RESET_IMAGE(I) From GESECRAN
 Endif
Next I

SAVNOL2    = nolign
SAVIND2    = indice
SAVOBJ     = GOBJET
SAVBOX     = currbox
SAVPROG    = GPROGRAMME
SAVGREP    = GREP
SAVGGRPFCY = GGRPFCY
SAVSOCIETE = GSOCIETE
SAVCURLEG  = GCURLEG
SAVCURFCY  = GCURFCY
SAVTITCOL  = GORITITCOL
SAVFONC1   = GFONC1
GOBJET     = 1
GORITITCOL = 0
GPROGRAMME = "GSAISIE" : # trtcou
SAVBOITE   = GBOITE
GBOITE     = BOITE
GSTATUT    = 0

ACTION = "AVANT_OUVRE" : Gosub ACTION
Call NOMTRTWINOPT(GBOITE,WINPROG) From MSKDIV

Gosub DEFVAR From =WINPROG

## Ouverture de quelques tables clés

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

If GACTION<>"" & GACTION<>"AIMP1"
 Local File AFONCTION  [AF__]
 NBFONC = 0
 For [AF__] Where ACTION=GACTION
  NBFONC +=1
  If NBFONC>=2 : Break : Endif
 Next
 If NBFONC=1
  GREPORT1 = [F:AF__]RPT1
  GREPORT2 = [F:AF__]RPT2
 Endif
 Close Local File [AF__]
Endif

######################################
## Petites vérifs de routine
######################################

PSPE = 0
If PROGSPE<>""
 Call EXISTE_ADX("","",PROGSPE,PSPE) From ORDSYS
Endif

If dim([V]GCHGENV)>0 & GCHGENV
&& ( instr(1,adxpno(2),"EXEFNC")
&  | instr(1,adxpno(2),"GESUSER")
&  | (instr(1,adxpno(2),"WGAFRQTSUB") & instr(1,adxpno(4),"EXEFNC"))
&  | (instr(1,adxpno(2),"WGOABA") & instr(1,adxpno(6),"EXEFNC"))
&  | (instr(1,adxpno(4),"WGAFRQT") & instr(1,adxpno(6),"EXEFNC"))
&  | (instr(1,adxpno(1),"ARQTSUB") & instr(1,adxpno(4),"EXEFNC"))
&  )
 If (GFCY="" & GCHGENV) or (GDEP="" & GCHGENV=2)
 # Fonction incompatible avec l'environnement
  Call ERREUR(mess(5,310,1)) From GESECRAN
  Goto SORT
 Endif
 CHGENV = GCHGENV
Endif

If dim(GACTX)>0
 If fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE | fmet GACTX.AGETLICFCT(GFONCTION)<>[V]CST_ATRUE
 Goto SORT
 Endif
Endif

######################################
## Définition des boutons
######################################

FIN = 0
ACTION = "OUVRE" : Gosub ACTION
If GERR : Gosub ERREUR : Endif
If FIN  : Goto FIN     : Endif

SAVCRITERE = CRITERE : #109309

Raz NBBOUT , STDBOUT
Gosub BOUTON From =WINPROG
For BOUT = "E" , "C" , "S" , "A" , "O"
 If instr(1,STDBOUT,BOUT)
  NBBOUT += 1
  Case BOUT
   When "E" : CODBOUT(NBBOUT) = GSTAENR : # Enregistrer
   When "C" : CODBOUT(NBBOUT) = GSTACRE : # Créer
   When "S" : CODBOUT(NBBOUT) = GSTAANU : # Supprimer
   When "A" : CODBOUT(NBBOUT) = GSTAFIN : # Abandon
   When "O" : CODBOUT(NBBOUT) = GSTAOK  : # OK
  Endcase
 Endif
Next BOUT
NBOUTSTD = NBBOUT
For I=1 To NBTEX
 If I<=dim(GSTASPE)-1
  NBBOUT += 1
  CODBOUT(NBBOUT) = LBOUT(I)
  GSTASPE(I) = CODBOUT(NBBOUT)
 Endif
Next I
NBBOUT += 1 : CODBOUT(NBBOUT) = GSTAEND : # Fin

## Navigation

If NAVIG<>""
 FLNAV = 1
 GPILNAV += 1
 GNAVIG(GPILNAV) = NAVIG
Endif

######################################
## Etats ??
######################################
REPORT1 = GREPORT1
REPORT2 = GREPORT2

######################################
# Ajout des menus du haut
######################################
Raz K, N
For I=1 To NBMEN
 If int(NMEN(I)/10)<>N : # Menu principal
  N += 1
  GPILOBJ += 1
  J = GSTAMEN+GPILOBJ
 Elsif CMEN(I)="" : # Sous-menu
  GPILOBJ += 1
 Else : # Lignes
  K += 1
  XMEN(K) = CMEN(I)
  GETAMEN(K) = 2
 Endif
Next I
NBRMEN = K

######################################
# Ajout du bouton sélection
######################################

If instr(1,STDBOUT,"X")
 Addmen GSTAMEO+GPILOBJ Titled mess(18,100,1) To 307 At 50            : # Sélection
 Additm GSTASEL Titled mess(18,100,1)+"..."  To GSTAMEO+GPILOBJ At 10 : # Sélection...
Endif
If instr(1,STDBOUT,"Q")
 Addmen GSTAMEO2+GPILOBJ Titled mess(39,310,1) To GSTAMEO+GPILOBJ At 11  : # Sélection picking
 Additm GSTAPCK  Titled mess(173,124,1)        To GSTAMEO2+GPILOBJ At 10 : # Sélection avancée
 Additm GSTAPCK1 Titled mess(43,310,1)         To GSTAMEO2+GPILOBJ At 11 : # Tout cocher
 Additm GSTAPCK2 Titled mess(44,310,1)         To GSTAMEO2+GPILOBJ At 12 : # Tout décocher
Endif

######################################
# Ouverture de la boîte
######################################

If BOITE<>"FCHGENV"
 Gosub FILENV From CHGENV
Endif

SAVNOLIGN = nolign
OK = 1
ACTION = "OUVRE_BOITE" : Gosub ACTION
If GERR : Gosub ERREUR : Endif
If FIN  : Goto FIN     : Endif
If OK
 Gosub OUVRE_BOITE From =WINPROG
Endif
nolign = SAVNOLIGN

BOX = 1
currbox = BOX1
BOXCURR = BOX1

ILIS = val(right$(currbox,8))
If CHGLIS(ILIS)>1
 Gosub REMPLIT
Endif

Onevent

############################################
## Début des opérations
############################################
SUIZON  = ""

For MA=0 To NBMASK
 Gosub SETMASK From =WINPROG
 Gosub TITMASK From =WINPROG
 Setmok [M] With 0
Next MA

ACTION = "DEBUT" : Gosub ACTION
If GERR : Gosub ERREUR : Endif
If FIN  : Goto FIN     : Endif
REP = ""
GREP = ""
PJC = "M"

DROIT = 1
If CHGENV
 Call AFF_ENV From MENU
 If GPRODUIT=1 & GUSRFCY(1)<>"\" & !find(GFCY,GUSRFCY(1..GNBAUZ)) : ## GEODE
  DROIT = 0
 Endif
Endif

For MA=0 To NBMASK
 Gosub SETMASK From =WINPROG
 If NOMMSK(MA)<>""
  Onerrgo RIEN
  Gosub CHG_STY From ="W1"+NOMMSK(MA)
  Onerrgo
 Endif
 If GBATCH & GCONSDIA               : Affzo : Endif
 If (GBATCH & GCONSDIA=1) or !DROIT : Grizo : Endif
 If (GBATCH & GCONSDIA=2)           : Diszo : Endif
Next MA

############################################
## Saisie et traitement des réponses
############################################
$CHOI
Gosub SETBOUT
If GERR : Gosub ERREUR : Endif
If FIN  : Goto FIN     : Endif
Onevent AFTER_CHANGE Gosub APRES_MODIF
ACTION = "AV_CHOIX" : Gosub ACTION
If SUIZON<>"" : zonsui = SUIZON : SUIZON = "" : Endif

Gosub SAISIE_BOITE From =WINPROG
Onevent AFTER_CHANGE
SUIZON = ""
FIN    = 0
GERR   = 0
ACTION = "AP_CHOIX" : Gosub ACTION

$TRTREP

## Actions qui nécessitent une confirmation d'abandon
If find(REPONSE,GSTAESC,GSTAEND,GSTAFIN,GSTANEW,GSTASUI)
& or find(REPONSE,GSTAPRE,GSTAFIR,GSTALAS,GSTALFT,GSTALF2,GSTALF3,GSTALF4)
 Gosub ABORT
 If !OK : Goto CHOI : Endif
Endif

ACT  = ""
BOUT = ""
ACTSTD = ""

## Actions particulières

Case REPONSE
 When GSTAESC, GSTAEND
  REPONSE = GSTAESC : # Pour qu'il n'y ait qu'un status de fin
  FIN = 1
 When GSTARET
  REPONSE = STADEF : # Bouton par défaut
  Goto TRTREP
 When GSTACRE
  If REP="D" & GCONF(2)=2
   OK = 2 : Call OUINON(mess(12,126,1),OK) From GESECRAN : # Confirmation de duplication
   If OK<>2 : Goto CHOI : Endif
  Endif
 When GSTAANU
  If GCONF(1)=2
   OK = 2 : Call OUINON(mess(28,100,1),OK) From GESECRAN : # Confirmation d'annulation
   If OK<>2 : Goto CHOI : Endif
  Endif
 When GSTAOK
  FIN = 1
 When GSTAENV
  Call ACT_CHGENV(OK) From GOBJACT
  Call AFF_ENV From MENU
  If !OK : Goto CHOI : Endif

## Icônes

 When GSTACLK+1 : # Panneau info -> Commentaires
  REPONSE = GSTACOM
 When GSTACLK+2 : # Trombonne -> Pièces jointes
  REPONSE = GSTAJOI
 When GSTACLK+3 : # Cadenas -> Qui locke quoi ?
  If SYMBOLE<>"" & !VERROU
   Call QUILOCKE(SYMBOLE,MACLCK,USRLCK) From OBJDIV
   If USRLCK<>""
    Call MESSAGE(mess(101,126,1)+"\"+USRLCK+"\"+MACLCK) From GESECRAN : # La fiche est utilisée par
   Else
    Call MESSAGE(mess(98,126,1)) From GESECRAN : # La fiche est utilisée par un autre utilisateur
   Endif
  Endif
 When GSTACLK+5 : # Croix blanche => On ne peut pas modifier
  If GCONSULT
   Call MESSAGE(mess(99,126,1)) From GESECRAN : # Vous n'avez accès à cette fonction qu'en consultation
  Else
   Call MESSAGE(mess(2,133,1)) From GESECRAN : # Vous n'avez accès à cette fiche qu'en consultation
  Endif
 When GSTACLK+8 : # Navigation
  Gosub INFO From GOBJNAV
Endcase

If REPONSE>GSTAITM & REPONSE-GSTAITM<dim(XMEN)
 BOUT    = XMEN(REPONSE-GSTAITM)
 ACT     = "MEN"
 REPONSE = 0
Endif

## Cas général

Case REPONSE
 When GSTAESC : ACT = "END"
 When GSTAENR : ACT = "ENR" : ACTSTD = "E"
 When GSTACRE : ACT = "CRE" : ACTSTD = "C"
 When GSTAFIN : ACT = "ABA" : ACTSTD = "A"
 When GSTAANU : ACT = "SUP" : ACTSTD = "S"
 When GSTACHG : ACT = "CHG" : ACTSTD = "H"
 When GSTASUI : ACT = "SUI" : ACTSTD = ">"
 When GSTAPRE : ACT = "PRE" : ACTSTD = "<"
 When GSTAFIR : ACT = "FIR" : ACTSTD = "0"
 When GSTALAS : ACT = "LAS" : ACTSTD = "9"
 When GSTANEW : ACT = "NEW" : ACTSTD = "N"
 When GSTASEL : ACT = "SEL" : ACTSTD = "X"
 When GSTAEDI : ACT = "EDI" : ACTSTD = "I"
 When GSTALIS : ACT = "LIS" : ACTSTD = "L"
 When GSTAJOI : ACT = "JOI" : ACTSTD = "J"
 When GSTACOM : ACT = "COM" : ACTSTD = "K"
 When GSTAOK  : ACT = "OK"  : ACTSTD = "O"
 When GSTADAT : ACT = "PRO" : ACTSTD = "P"
 When GSTAENV : ACT = "ENV"
 When GSTATRN : ACT = "TRN"
 When GSTAHLO : ACT = "HLP"
 When GSTABUR : ACT = "BUR"

 When GSTASRA : ACT = "SRA" : ILIS = val(right$(currbox,8))
 When GSTAPRG : ACT = "PRG" : ILIS = val(right$(currbox,8))
 When GSTASVG : ACT = "SVG" : ILIS = val(right$(currbox,8))
 When GSTARAF : ACT = "RAF" : ILIS = val(right$(currbox,8))
 When GSTATIR : ACT = "TIR" : ILIS = val(right$(currbox,8))
 When GSTABOI : ACT = "FTR" : ILIS = val(right$(currbox,8))
 When GSTAPIC : ACT = "PIC" : ILIS = val(right$(currbox,8))
 When GSTALFT : ACT = "GAU" : ILIS = val(right$(currbox,8))
 When GSTALF2 : ACT = "GAU" : ILIS = val(right$(currbox,8))
 When GSTALF3 : ACT = "GAU" : ILIS = val(right$(currbox,8))
 When GSTALF4 : ACT = "GAU" : ILIS = val(right$(currbox,8))

## Boutons

 When Default

  I = find(REPONSE,CODBOUT(NBOUTSTD+1..NBBOUT))
  If I
   BOUT = CBOUT(I)
   FOK = 1
   ACTION = "AVANT_BOUTON" : Gosub ACTION
   If GERR : Gosub ERREUR : Endif
   If FOK
    Gosub EXEBOUT From =WINPROG
    ACT = "BOUTON"
   Endif
  Endif
Endcase

## Traitements des actions standard


If ACT<>""
 If find(ACT,"TIR","RAF")>0 : #109309
    Raz CRITERE, ICRITERE
    CRITERE = SAVCRITERE
    Raz IFILRAP, FILRAP : #109309
 Endif
 FOK = 1
 If ACT="MEN"
  ACTION = "AVANT_"+ACT : Gosub ACTION
  If GERR : Gosub ERREUR : Endif
  If FOK
   Gosub EXEBOUT From =WINPROG
  Endif
 Elsif ACTSTD<>""
  ACTION = "AVANT_"+ACT : Gosub ACTION
  If GERR : Gosub ERREUR : Endif
  If FOK
   BOUT = ACTSTD
   Gosub EXEACT From =WINPROG
  Endif
 Endif
 If FOK
  ACTION = ACT : Gosub ACTION
  If GERR
   Gosub ERREUR
  Else
   Case ACT
    When "CRE" : Inftxt mess(270,126,1) At 105 : # Fiche créée
    When "ENR" : Inftxt mess(271,126,1) At 105 : # Fiche modifiée
   Endcase
  Endif
 Endif
Endif

## Traitements particuliers nécéssitant une saisie/affichage

Case ACT
 When "EDI"
  If FOK & REPORT1<>""
   Case REPORT1
    When "PRTSCR" : Call HCOPY(TIT)
    When Default  : Call IMPDEF(REPORT1,AREPORT,GFONCTION) From ETAT
   Endcase
  Endif
 When "LIS"
  If FOK & REPORT2<>""
   Call IMPDEF(REPORT2,AREPORT,GFONCTION) From ETAT
  Endif
 When "JOI"
  If FOK & OBJ<>""
   Call PIECE(OBJ,CLES1,CLES2,PJC) From GOBJACT
  Endif
 When "COM"
  If FOK & OBJ<>""
   Call COMMENTAIRE(OBJ,CLES1,CLES2,PJC) From GOBJACT
  Endif
 When "PRO"
  If FOK & OBJ<>""
   Call PROPRIETE(OBJ,CLES1,CLES2) From GOBJACT
  Endif
 When "ENV"
  I=0
  If GPRODUIT=1 : ## GEODE
   If DROIT & GUSRFCY(1)<>"\" & !find(GFCY,GUSRFCY(1..GNBAUZ))
    DROIT=0 : I=1 : FOK=1
   Elsif !DROIT & (GUSRFCY(1)="\" or find(GFCY,GUSRFCY(1..GNBAUZ)))
    DROIT=1 : I=1
   Endif
  Endif
  If FOK
   For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    If FOK : Effzo [M] : Endif
    If I
     If DROIT : Actzo [M] : Else Grizo [M] : Endif
    Endif
   Next MA
  Endif

## Gestion des listes de gauche

 When "SRA"
  If FOK
   #109309
   #Call SELRAP(OBJLIS(ILIS),SAIRAP,IFILSUITE,FILSUITE) From GOBJACT
   Gosub REMPLIT
  Endif
 When "SVG"
  If FOK & CHGLIS(ILIS)<=2 & OBJLIS(ILIS)<>"ALI"
   Case ILIS
    When 1  : Gosub SETCLE_1  From =WINPROG
    When 2  : Gosub SETCLE_2  From =WINPROG
    When 3  : Gosub SETCLE_3  From =WINPROG
    When 4  : Gosub SETCLE_4  From =WINPROG
    When 5  : Gosub SETCLE_5  From =WINPROG
    When 6  : Gosub SETCLE_6  From =WINPROG
    When 7  : Gosub SETCLE_7  From =WINPROG
    When 8  : Gosub SETCLE_8  From =WINPROG
    When 10 : Gosub SETCLE_10 From =WINPROG
   Endcase
   ACTION = "FILGAUCHE" : Gosub ACTION
   ACTION = "HINT" : Gosub ACTION
   #109309
   Call SELRAP(OBJLIS(ILIS),SAIRAP,IFILRAP,FILRAP) From GOBJACT
   Gosub CRITGAURAP

   If dim(GAUTRELIS)<=0 : Local Integer GAUTRELIS : Endif
   Call SUIGAUCHE(">","",CLELISTE,SNSLIS,GAUTRELIS,ILIS,OBJLIS(ILIS),CZ,WINPROG,HINTLIS(ILIS)
&                ,CRITERE,FILTSUP,FILROLE,FILGAUSUP,IFILSUITE,FILSUITE,OK) From GOBJACT
   If OK : Gosub REMPLIT_ : Endif
  Endif
 When "PRG"
  If FOK & CHGLIS(ILIS)<=2 & OBJLIS(ILIS)<>"ALI"
   Case ILIS
    When 1  : Gosub SETCLE_1  From =WINPROG
    When 2  : Gosub SETCLE_2  From =WINPROG
    When 3  : Gosub SETCLE_3  From =WINPROG
    When 4  : Gosub SETCLE_4  From =WINPROG
    When 5  : Gosub SETCLE_5  From =WINPROG
    When 6  : Gosub SETCLE_6  From =WINPROG
    When 7  : Gosub SETCLE_7  From =WINPROG
    When 8  : Gosub SETCLE_8  From =WINPROG
    When 10 : Gosub SETCLE_10 From =WINPROG
   Endcase
   ACTION = "FILGAUCHE" : Gosub ACTION
   ACTION = "HINT" : Gosub ACTION
   #109309
   Call SELRAP(OBJLIS(ILIS),SAIRAP,IFILRAP,FILRAP) From GOBJACT
   Gosub CRITGAURAP

   If dim(GAUTRELIS)<=0 : Local Integer GAUTRELIS : Endif
   Call SUIGAUCHE("<","",CLELISTE,SNSLIS,GAUTRELIS,ILIS,OBJLIS(ILIS),CZ,WINPROG,HINTLIS(ILIS)
&                ,CRITERE,FILTSUP,FILROLE,FILGAUSUP,IFILSUITE,FILSUITE,OK) From GOBJACT
   If OK : Gosub REMPLIT_ : Endif
  Endif
 When "RAF"
  If FOK
   Raz SAIRAP
   Gosub REMPLIT
  Endif
 When "TIR"
  If currbox<>BOXCURR
   BOXCURR = currbox
   If FOK
    Raz FILSUITE, IFILSUITE, SAIRAP
    If CHGLIS(ILIS)>1
     Gosub REMPLIT
    Endif
   Endif
  Endif
  Gosub SETORDER From =WINPROG
  zonsui = currbox
  Goto CHOI
 When "FTR"
  Gosub ENDORDER From =WINPROG
  zonsui = "-"
 When "GAU"
  zoncou = ""
  zonsui = currbox
 When "PIC"
  If FOK
   Gosub PICKING
  Endif
Endcase

## Traitement de l'erreur

Gosub ERREUR

If !FIN
 Goto CHOI
Else
 GSTATUT = REPONSE
Endif

##########################################################################
$FIN
ACTION = "FIN" : Gosub ACTION
If BOX
 Gosub FERME_BOITE From =WINPROG
Endif

$SORT
For I=1 To dim(GSTAIMG)
 If SAVIMG(I)<>GSTAIMG(I)
  If SAVIMG(I)<>0
   Call SET_IMAGE(I) From GESECRAN
  Else
   Call RESET_IMAGE(I) From GESECRAN
  Endif
 Endif
Next I
Call RESTBOUT From GESECRAN
GOBJET     = SAVOBJ
currbox    = SAVBOX
GORITITCOL = SAVTITCOL
GPROGRAMME = SAVPROG
GREP       = SAVGREP
If !instr(1,adxpno(1),"GTRAITE")
 GGRPFCY    = SAVGGRPFCY
 GSOCIETE   = SAVSOCIETE
 GCURLEG    = SAVCURLEG
 GCURFCY    = SAVCURFCY
Endif
GBOITE     = SAVBOITE
GFONC1     = SAVFONC1
nolign = SAVNOL2
indice = SAVIND2
GPILOBJ -= (NBMEN-NBRMEN)+1
If GPILOBJ<0 : GPILOBJ=0 : Endif : #99921
If FLNAV
 GPILNAV -= 1
 GPILNAV = max(GPILNAV,0)
Endif
NBAFF = 0
ACTION = "FINSAI" : Gosub ACTION : # Pour pouvoir positionner mkstat, etc...
If NBAFF : # Raffraichissement de la fenêtre du dessous
 If GBOITE<>"" & !GIMPORT
  Call NOMTRTWINOPT(GBOITE,WINPROG) From MSKDIV
  Gosub DEFVAR From =WINPROG
  For MA=0 To NBMASK
   Gosub AFFMASK From =WINPROG
   If NBAFF=2
    Gosub SETMASK From =WINPROG
    Setmok [M] With 0
   Endif
  Next MA
 Endif
Endif

If dim(GNBMASKOUV)>0
  GNBMASKOUV-=1
  GNBMASKOUV=max(0,GNBMASKOUV)
Endif

End

##########################################################################
$REMPLIT
ACTION = "FILGAUCHE" : Gosub ACTION
#109309
Call SELRAP(OBJLIS(ILIS),SAIRAP,IFILRAP,FILRAP) From GOBJACT
Gosub CRITGAURAP

$REMPLIT_
If CHGLIS(ILIS)>2
 adxmxl = 9999
Else
 adxmxl = GNBGAUCHE
Endif
Gosub DEFAUT_BRO From =WINPROG
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub SET_FIRST From GOBJACT
Endif
Case currbox
 When "GAU_CHE1"  : Gosub REMPLIT_1  From =WINPROG
 When "GAU_CHE2"  : Gosub REMPLIT_2  From =WINPROG
 When "GAU_CHE3"  : Gosub REMPLIT_3  From =WINPROG
 When "GAU_CHE4"  : Gosub REMPLIT_4  From =WINPROG
 When "GAU_CHE5"  : Gosub REMPLIT_5  From =WINPROG
 When "GAU_CHE6"  : Gosub REMPLIT_6  From =WINPROG
 When "GAU_CHE7"  : Gosub REMPLIT_7  From =WINPROG
 When "GAU_CHE8"  : Gosub REMPLIT_8  From =WINPROG
 When "GAU_CHE10" : Gosub REMPLIT_10 From =WINPROG
Endcase
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub UNSET_FIRST From GOBJACT
Endif
ACTION = "AP_FILGAUCHE" : Gosub ACTION
Return

##########################################################################
$SETBOUT
## Init "au mieux"
Raz ETABOU , STADEF , CHBOU

For I=1 To NBTEX
 Case I
  When 1  : ETABOU(GSPE1)  = 1
  When 2  : ETABOU(GSPE2)  = 1
  When 3  : ETABOU(GSPE3)  = 1
  When 4  : ETABOU(GSPE4)  = 1
  When 5  : ETABOU(GSPE5)  = 1
  When 6  : ETABOU(GSPE6)  = 1
  When 7  : ETABOU(GSPE7)  = 1
  When 8  : ETABOU(GSPE8)  = 1
  When 9  : ETABOU(GSPE9)  = 1
  When 10 : ETABOU(GSPE10) = 1
  When 11 : ETABOU(GSPE11) = 1
  When 12 : ETABOU(GSPE12) = 1
 Endcase
Next I

For I=1 To NBRMEN
 ETAMEN(I) = 1
Next I

Case REP
 When ""
  If instr(1,STDBOUT,"S") : ETABOU(GSUPP) = 1 : CHBOU += "S" : Endif
  If instr(1,STDBOUT,"O") : ETABOU(GVALI) = 1 : CHBOU += "O" : STADEF = GSTAOK  : Endif
  ETABOU(GCHENV) = (CHGENV<>0)
 When "M"
  If instr(1,STDBOUT,"E") : ETABOU(GENRE) = 1 : CHBOU += "E" : STADEF = GSTAENR : Endif
  If instr(1,STDBOUT,"A") : ETABOU(GABAN) = 1 : CHBOU += "A" : Endif
  If instr(1,STDBOUT,"O") : ETABOU(GVALI) = 1 : CHBOU += "O" : Endif
 When "C","D"
  If instr(1,STDBOUT,"C") : ETABOU(GCREE) = 1 : CHBOU += "C" : STADEF = GSTACRE : Endif
  If instr(1,STDBOUT,"A") : ETABOU(GABAN) = 1 : CHBOU += "A" : Endif
  If instr(1,STDBOUT,"O") : ETABOU(GVALI) = 1 : CHBOU += "O" : Endif
Endcase

ETABOU(GBFIN) = 1

If instr(1,STDBOUT,"N") & REP=""      : ETABOU(GNOUV) = 1 : CHBOU += "N" : Endif
If instr(1,STDBOUT,"0") & REP=""      : ETABOU(GPREM) = 1 : CHBOU += "0" : Endif
If instr(1,STDBOUT,"9") & REP=""      : ETABOU(GDERN) = 1 : CHBOU += "9" : Endif
If instr(1,STDBOUT,">") & REP=""      : ETABOU(GSUIV) = 1 : CHBOU += ">" : Endif
If instr(1,STDBOUT,"<") & REP=""      : ETABOU(GPREC) = 1 : CHBOU += "<" : Endif
If instr(1,STDBOUT,"X") & REP=""      : ETABOU(GSELE) = 1 : CHBOU += "X" : Endif

If instr(1,STDBOUT,"H") & REP=""      : ETABOU(GCHAN) = 1 : CHBOU += "H" : Endif
If instr(1,STDBOUT,"I") & REPORT1<>"" : ETABOU(GEDIT) = 1 : CHBOU += "I" : Endif
If instr(1,STDBOUT,"L") & REPORT2<>"" : ETABOU(GLIST) = 1 : CHBOU += "L" : Endif
If instr(1,STDBOUT,"J")               : ETABOU(GJOIN) = 1 : CHBOU += "J" : Endif
If instr(1,STDBOUT,"M")               : ETABOU(GCOMM) = 1 : CHBOU += "M" : Endif
If instr(1,STDBOUT,"P")               : ETABOU(GDATC) = 1 : CHBOU += "P" : Endif

CHMEN = sum(CBOUT(1..NBTEX))+sum(XMEN(1..NBRMEN))
OCHBOU = CHBOU
OCHMEN = CHMEN
If GBATCH & CBOUTD<>""
 Call VIREBOUT(CHMEN,CBOUTD) From GOBJET
Endif
ACTION = "SETBOUT" : Gosub ACTION
If CHBOU<>OCHBOU : Gosub SET_BOUT_STD : Endif
If CHMEN<>OCHMEN : Gosub SET_BOUT_SPE : Endif

If instr(1,CHBOU,"T")               : ETABOU(GTRAN) = 1 : Endif
If instr(1,CHBOU,"=")               : ETABOU(GRAFF) = 1 : Endif
If instr(1,CHBOU,"I") & REPORT1<>"" : ETABOU(GEDIT) = 1 : Endif
If instr(1,CHBOU,"L") & REPORT2<>"" : ETABOU(GLIST) = 1 : Endif

If (find(GCONSDIA,1,2) & GBATCH) or !DROIT
 Raz ETABOU, ETAMEN
 ETABOU(GBFIN) = 1
 ETABOU(GCHENV) = (CHGENV<>0)
Elsif CHGENV
  ETABOU(GCHENV) = (REP="")
Endif

Call SETBOUT(ETABOU) From GESECRAN
Call SET_TEXTE(NUMTXT) From GOBJET
For I=1 To dim([L]IMGFLG)
 If [L]IMGFLG(I)
  Call SET_IMAGE(I) From GESECRAN
 Else
  Call RESET_IMAGE(I) From GESECRAN
 Endif
Next I
For I=1 To NBRMEN
 If ETAMEN(I)<>GETAMEN(I)
  If ETAMEN(I)
   Enable GSTAITM+I
  Else
   Disable GSTAITM+I
  Endif
  GETAMEN(I) = ETAMEN(I)
 Endif
Next I

Return

##########################################################################
$ABORT
OK = 2
If REP<>""
 If dim([V]GCONF)<=0 or [V]GCONF(3)=2
  OK = 1
  Case REP
   When "M"
    If GFUSION
     # Continuer et abandonner vos modifications ?
     Call YESNO(mess(265,126,1),OK) From GESECRAN
    Else
     # La fiche courante a été modifiée, voulez-vous abandonner la modification
     Call OUINON(mess(7,126,1)+"\"+mess(9,126,1),OK) From GESECRAN
    Endif
   When "C"
    If GFUSION
     # Continuer et abandonner votre création ?
     Call YESNO(mess(266,126,1),OK) From GESECRAN
    Else
     # La fiche courante n'a pas encore été créée, voulez-vous abandonner la création
     Call OUINON(mess(8,126,1)+"\"+mess(10,126,1),OK) From GESECRAN
    Endif
   When "D"
    If GFUSION
     # Continuer et abandonner votre duplication ?
     Call YESNO(mess(267,126,1),OK) From GESECRAN
    Else
     # La fiche courante n'a pas encore été créée, voulez-vous abandonner la duplication
     Call OUINON(mess(8,126,1)+"\"+mess(11,126,1),OK) From GESECRAN
    Endif
   When Default
    Call ABORT(OK) From GESECRAN
  Endcase
  If OK<>2
   OK = 0
  Endif
 Endif
 If OK
  ACTION = "ABANDON" : Gosub ACTION
 Endif
Endif
Return

##########################################################################
$APRES_MODIF
COUZON = zoncou
If evalue("type([M]"+COUZON+")")=8 or indice>evalue("dim([M]"+COUZON+")-1")
 COUIND = 0
Else
 COUIND = indice
Endif
GERR = 0
GMESSAGE = ""
Case type(zc)
 When 3       : CZ = zc
 When 522,523 : CZ = "" : # Blob, Clob
 When Default : CZ = num$(zc)
Endcase
FOK = 1
ACTION = "APRES_MODIF" : Gosub ACTION
If GERR
 Case GMESSAGE
  When ""  : MA = FOK : GMESSAGE = mess(9,123,1) : Gosub ERREUR : FOK = MA : # Modification impossible
  When "#" : GMESSAGE = "" : FOK = 0
  When Default : Gosub ERREUR
 Endcase
 If FOK=0
  zc = evalue("[M]"+COUZON+"("+num$(COUIND)+")")
  mkstat = 2
  GERR = 0
 Endif
Endif
For MA=0 To NBMASK
 Gosub SETMASK From =WINPROG
 Setmok [M] With 0
Next MA
Gosub SETBOUT
If SUIZON<>"" : zonsui = SUIZON : SUIZON = "" : Endif
Return

##########################################################################
$PICKING
FOK = 1
ACTION = "DEB_PIC" : Gosub ACTION
If GERR : Gosub ERREUR : Endif
If FOK
 FPICK = 0
 NPICK = -1
 Repeat
  NPICK += 1
  Gosub PICKING From =WINPROG
  STAPICK = status
  Case STAPICK
   When 28,37
    FOK = 1
    ACTION = "CRE_PIC" : Gosub ACTION
    If GERR : Gosub ERREUR : Endif
    If !FOK
     Gosub DEPICK
    Endif
   When 41,43
    FOK = 1
    ACTION = "ANU_PIC" : Gosub ACTION
    If GERR : Gosub ERREUR : Endif
    If !FOK
     Gosub REPICK
    Endif
  Endcase
  If FPICK : # Pour ne pas avoir 1000 fois le message d'erreur...
   Repeat
    Gosub PICKING From =WINPROG
    STAPICK = status
    Case STAPICK
     When 28,37 : Gosub DEPICK
     When 41,43 : Gosub REPICK
    Endcase
   Until STAPICK=7
  Endif
 Until STAPICK=7
 If NPICK
  FOK = 1
  ACTION = "FIN_PIC" : Gosub ACTION
  If GERR : Gosub ERREUR : Endif
  If FOK=1 & REP="" : # On passe en modif (les vérifs ont dûes être faites)
   Gosub SETBOUT
   For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    Setmok [M] With 0
   Next MA
  Endif
 Endif
Endif
Return

$DEPICK
Gosub DEPICK From =WINPROG
Return

$REPICK
Gosub REPICK From =WINPROG
Return

##########################################################################
$ACTION
GPE = 0
If dim(PSPE)>0 & PSPE
 Gosub ACTION From =PROGSPE
Endif
If !GPE & dim(PROG)>0 & PROG<>""
 Gosub ACTION From =PROG
Endif
Return

$ERREUR
Gosub ERR
FOK = min(FOK,XOK)
Return

$RIEN
Resume

#109309
$CRITGAURAP
If dim(FILRAP)>0 & FILRAP<>""
 K = 0
 For I=0 To IFILRAP
  If FILRAP(I)<>""
   If K=0
    K = 1
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILRAP(I),"&") From GOBJSUB
   Else
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILRAP(I),"") From GOBJSUB
   Endif
  Endif
 Next I
 If K
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",")","") From GOBJSUB
 Endif
Endif
Return
#####################################################################
## Sous-programme pour positionner les boutons en fonction des codes
#####################################################################

########## Boutons/actions standards

$SET_BOUT_STD
For I=1 To len(CHSTD)
 Case mid$(CHSTD,I,1)
  When "N" : J = GNOUV
  When "0" : J = GPREM
  When "9" : J = GDERN
  When ">" : J = GSUIV
  When "<" : J = GPREC
  When "X" : J = GSELE
  When "H" : J = GCHAN
  When "I" : J = GEDIT
  When "L" : J = GLIST
  When "J" : J = GJOIN
  When "M" : J = GCOMM
  When "P" : J = GDATC
  When "S" : J = GSUPP
  When "O" : J = GVALI
  When "E" : J = GENRE
  When "A" : J = GABAN
  When "C" : J = GCREE
 Endcase
 If instr(1,CHBOU,mid$(CHSTD,I,1))
  ETABOU(J) = 1
 Else
  ETABOU(J) = 0
 Endif
Next I
Return

########## Boutons/actions spécifiques

$SET_BOUT_SPE
If !GIMPORT
 For I=1 To NBRMEN
  If instr(1,CHMEN,XMEN(I))
   ETAMEN(I) = 1
  Else
   ETAMEN(I) = 0
  Endif
 Next I
 For I=1 To NBTEX
  Case I
   When 1  : J = GSPE1
   When 2  : J = GSPE2
   When 3  : J = GSPE3
   When 4  : J = GSPE4
   When 5  : J = GSPE5
   When 6  : J = GSPE6
   When 7  : J = GSPE7
   When 8  : J = GSPE8
   When 9  : J = GSPE9
   When 10 : J = GSPE10
   When 11 : J = GSPE11
   When 12 : J = GSPE12
  Endcase
  If instr(1,CHMEN,CBOUT(I))
   ETABOU(J) = 1
  Else
   ETABOU(J) = 0
  Endif
 Next I
Endif
Return

###################################################################
## Programme appelé en retour d'étiquette standard
###################################################################

$AFF
If GIMPORT
 Local Integer KIMP
 XOK = 1
 If GMESSAGE="" & GZONE<>"" & GERR=1
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
 Endif
 If GMESSAGE<>""
  If GZONE=""
   Case GERR
    When 1   : KIMP = 1
    When 2,3 : KIMP = 0
   Endcase
  Else
   GMESSAGE = ctrans(GMESSAGE,"\"," ")
   If dim([L]VALEUR)>0 & !instr(1,GMESSAGE,num$([L]VALEUR))
    GMESSAGE -="("+num$([L]VALEUR)+")"
   Endif
   If indice>0 : GZONE += "("+num$(indice)+")" : Endif
   Case GERR
    When 1
     If GCLE<>""
      GMESSAGE -= "<"+ctrans(GCLE,"\","/")+">"
     Endif
     Call ERRZON(GZONE,GZNUM,GMESSAGE) From GESECRAN
     XOK = 0
     KIMP = 1
    When 2,3
     If GCLE<>""
      GMESSAGE -= "<"+ctrans(GCLE,"\","/")+">"
     Endif
     GMESSAGE = GZONE-":"-GMESSAGE
     KIMP = 0
   Endcase
  Endif
  Call ECR_TRACE(GMESSAGE,KIMP) From GESECRAN
 Endif
 GMESSIMP = "~"+GMESSAGE
 If dim(GFLDIMP)>0 : GFLDIMP = GZONE : Endif
 Raz GERR, GZONE, GZNUM ,GMESSAGE
 Return
Endif
Gosub ERR
Return

$ERR
Local Integer XOK
XOK = 1
If GMESSAGE<>""
 If mkstat & GERR=0 & mkstat<>4 : GERR = 1 : Endif

 ### Pour la Voice de Géode ###
 If GPRODUIT=1 & GVTMOD=1
  If dim([V]GSAISIEB)<0
   Global Integer GSAISIEB
   Call EXISTE_ADX("","","GSAISIEB",GSAISIEB) From ORDSYS
  Endif
  If GSAISIEB
   Local Char SACTION(20)
   If dim([L]ACTION)<0
    Local Char ACTION(20)
   Endif
   SACTION = ACTION
   ACTION = "MESSAGE"
   Gosub ACTION From GSAISIEB
   ACTION = SACTION
  Endif
 Endif
 ##############################

 Case GERR
  When 1
   If GZNUM<>0
    If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
    Read [ATX]NUMERO = GLANGUE;GZNUM
    If fstat : GZNUM = 0 : Endif
   Endif
   If GZNUM=0
    Call ERREUR(GMESSAGE) From GESECRAN
   Else
    Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+[F:ATX]TEXTE+'"') From GESECRAN : # Erreur zone...
   Endif
   XOK = 0
  When 2
   Call MESSAGE(GMESSAGE) From GESECRAN
   XOK = 1
  When 3
   Call AVERTIR(GMESSAGE,XOK) From GESECRAN
   If XOK<>2 : XOK =0 : mkstat = 2 : Else : XOK = 1 : Endif
  When 4
   Inftxt GMESSAGE At 2
  When 99
   XOK = 0
 Endcase
 If (GERR>0 & GERR<5) or GERR=99 : GMESSAGE = "" : Endif
Endif
Raz GERR , GZNUM
Return

###################################################################
## Programme copies écran de la fenêtre
###################################################################

Subprog HCOPY(TIT)
Value Char    TIT
Local Integer MA , I , K
Local Char    MSK(GLONAMK)(1..16) , ABR(GLONABR)(1..16)
If clalev([F:PSW])=0 :  Local File PRTSCRWRK [PSW] : Endif
If clalev([F:AWI])=0 :  Local File AWINDOW   [AWI] : Endif
If clalev([F:AMK])=0 :  Local File AMSK      [AMK] : Endif
If clalev([F:ACV])=0 :  Local File ACTIV     [ACV] : Endif

Read [AWI]AWI0=GBOITE
If fstat
 End
Elsif [F:AWI]MSKENT<>""
 Read [AMK]CODMSK=[F:AWI]MSKENT
 If fstat
  End
 Elsif [F:AMK]CODACT<>""
  Read [ACV]CODACT = [F:AMK]CODACT
  If fstat or [F:ACV]FLACT<>2
   End
  Endif
  MA += 1
  MSK(MA) = [F:AWI]MSKENT
  ABR(MA) = [F:AMK]ABRMSK
 Endif
Endif
For I=1 To [F:AWI]NBMSK
 K = 1
 If [F:AWI]ACTMSK(I-1)<>""
  Read [ACV]CODACT = [F:AWI]ACTMSK(I-1)
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  Read [AMK]CODMSK=[F:AWI]NOMMSK(I-1)
  If fstat
   K = 0
  Elsif [F:AMK]CODACT<>""
   Read [ACV]CODACT = [F:AMK]CODACT
   If fstat or [F:ACV]FLACT<>2
    K = 0
   Endif
  Endif
 Endif
 If K
  MA += 1
  MSK(MA) = [F:AWI]NOMMSK(I-1)
  ABR(MA) = [F:AMK]ABRMSK
 Endif
Next I
Call PRTSCR(MSK(1..MA),ABR(1..MA),TIT,0,0) From ATRTX3
Call IMPSCR From ATRTX3
End

