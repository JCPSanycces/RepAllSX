#<AdxTL>@(#)0.0.0.0 $Revision$
# --------------------------------------------------------------------------------------------------
#---------------------------------------------------------#
# Calcul de l'en-cours client                             #
#---------------------------------------------------------#
# Entrée  WBPCRSK  : Tiers risque                         #
#         DAT      : Date                                 #
# Sortie  ENCOURS  : En-cours calculé du tiers risque     #
#                    en devise dossier (GOSTCTL=1) ou société (GOSTCTL=2)
#---------------------------------------------------------#
Subprog CALENC (CTX,COMPANY,WBPCRSK,DAT,ENCOURS)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     COMPANY
Value    Char     WBPCRSK
Value    Date     DAT
Variable Decimal  ENCOURS

  #Value   Instance CUSTOMER Using OBJETC
  Gosub CALCUL_ENCOURS
End

# --------------------------------------------------------------------------------------------------
#---------------------------------------------------------#
# Etiquette de calcul de l'en-cours client                #
# Appelée par :                                           #
# --> Subprog CALENC et par l'action visu détail          #
# --> l'action visu détail calcul en-cours client         #
#---------------------------------------------------------#
$CALCUL_ENCOURS
Local Char    WCRITERE(50), WCPY(GLONCPY), WCUR(GLONCUR)

Local Decimal COURS
Local Integer SPSTAT
Local Decimal WDLVOST
Local Decimal WNIVDLV
Local Decimal WNPTINV
Local Decimal WNYTBIL(0..2)
Local Decimal WBLC
Local Decimal WORDBPIATI
Local Decimal WLNDBPIATI
Local Decimal WLNDDLV
Local Decimal WMNTORG (0..9)
Local Decimal WMNTDES (0..9)

Local Integer CTX_OSTCTL
Local Integer CTX_OSTCHGTYP
Local Char  	CTX_CURSHR(GLONCUR)
Local Char  	CTX_SYSCUR(GLONCUR)
Local Char 	  CTX_LOCALDEV(GLONCUR)
Local Char 		CTX_CUR(GLONCUR)
Local Integer CTX_OSTDRAFT
Local Integer CTX_OSTORD
Local Integer CTX_OSTLND
Local Integer CTX_OSTTYPCUR   # FGR 17/12/2014 : X3SUIVI95153 : pas déclaré au bon endroit.

  Local File BPCUSTMVT [MVC]
  Local File COMPANY [CPY]

  #--Init des variables liées au contexte
  CTX_SYSCUR    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"SYSCUR")
  CTX_OSTCTL    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCTL")
  CTX_OSTCHGTYP = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCHGTYP")
  CTX_CURSHR    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"CURSHRFLD")
  CTX_OSTDRAFT  = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTDRAFT")
  CTX_OSTORD    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTORD")
  CTX_OSTLND    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTLND")

  Read [F:CPY]CPY0=COMPANY
  If fstat : Raz [F:CPY] : Endif
  If [F:CPY]ACCCUR<>""
	 CTX_CUR=[F:CPY]ACCCUR
  Else
	 CTX_CUR = CTX_SYSCUR
  Endif
  CTX_LOCALDEV = [F:CPY]ACCCUR
  #--

  CRITERE="BPCRSK=WBPCRSK"
  If CTX_OSTCTL=2 & COMPANY<>"" CRITERE -="& CPY=COMPANY" Endif

  If CTX_OSTCTL=2
    If COMPANY<>""
      # Ctrl au niveau société : Chargement des paramètres nécessaires
      [F:MVC]CPY=COMPANY : Gosub RECH_PARAM
      WCUR=CTX_LOCALDEV           : # La devise utilisée pour calculer les mnts actualisés est la devise société
    Else
      WCUR =CTX_CUR
    Endif
  Else
    # Ctrl au niveau dossier : Chargement des paramètres nécessaires
    WCUR=CTX_CURSHR             : # La devise utilisée pour calculer les mnts actualisés est la devise dossier
  Endif

  Raz WCPY
  For [MVC]MVC0 Where evalue(CRITERE)
    If (CTX_OSTCTL=1 | COMPANY="") & WCPY<>[F:MVC]CPY
      # Ctrl au niveau dossier : Chargement des paramètres nécessaires qd on change de société
      Gosub RECH_PARAM
      WCPY=[F:MVC]CPY
    Endif

    #If GOSTCHGTYP=2             : # Pour les prochaines versions
    If CTX_OSTCHGTYP=2 | CTX_OSTCTL=1 : # Pour la version Béryl (pas de solde comptable en devise dossier)
      # Cours actualisé :
      # On prend les montants en devise txn que l'on convertit en devise dossier (GCURSHR) ou société (GLOCALDEV)
      If [F:MVC]CUR=WCUR
        WMNTDES (0) = [F:MVC]DLVOSTC
        WMNTDES (1) = [F:MVC]NIVDLVC
        WMNTDES (2) = [F:MVC]NPTINVC
        WMNTDES (3) = [F:MVC]NYTBILC(0)
        WMNTDES (4) = [F:MVC]NYTBILC(1)
        WMNTDES (5) = [F:MVC]NYTBILC(2)
        WMNTDES (6) = [F:MVC]BLCC
        WMNTDES (7) = [F:MVC]ORDBPIATIC
        If dim([F:MVC]LNDDLVC) <> -1
          WMNTDES (8) = [F:MVC]LNDBPIATIC
          WMNTDES (9) = [F:MVC]LNDDLVC
        Endif
      Else
        WMNTORG (0) = [F:MVC]DLVOSTC
        WMNTORG (1) = [F:MVC]NIVDLVC
        WMNTORG (2) = [F:MVC]NPTINVC
        WMNTORG (3) = [F:MVC]NYTBILC(0)
        WMNTORG (4) = [F:MVC]NYTBILC(1)
        WMNTORG (5) = [F:MVC]NYTBILC(2)
        WMNTORG (6) = [F:MVC]BLCC
        WMNTORG (7) = [F:MVC]ORDBPIATIC
        If dim([F:MVC]LNDDLVC) <> -1
          WMNTORG (8) = [F:MVC]LNDBPIATIC
          WMNTORG (9) = [F:MVC]LNDDLVC
        Endif
        #MAE, bg 74267
        Raz WMNTDES
        For IJ0=0 To dim(WMNTORG)-1
          If WMNTORG(IJ0)<>0
            Call CONVERT(CTX,[F:MVC]CUR,WCUR,CTX_LOCALDEV,CTX_OSTTYPCUR,DAT, WMNTORG(IJ0),WMNTDES(IJ0),SPSTAT) From TRTDEV_SYRA
          Endif
        Next IJ0
      Endif
    Elsif CTX_OSTCTL=1
      # Niveau dossier et Cours historisé : On prend tel quel les montants en devise dossier (GCURSHR)
      WMNTDES (0) = [F:MVC]DLVOSTR
      WMNTDES (1) = [F:MVC]NIVDLVR
      WMNTDES (2) = [F:MVC]NPTINVR
      WMNTDES (3) = [F:MVC]NYTBILR(0)
      WMNTDES (4) = [F:MVC]NYTBILR(1)
      WMNTDES (5) = [F:MVC]NYTBILR(2)
      WMNTDES (6) = [F:MVC]BLCR
      WMNTDES (7) = [F:MVC]ORDBPIATIR
      If dim([F:MVC]LNDDLVR) <> -1
        WMNTDES (8) = [F:MVC]LNDBPIATIR
        WMNTDES (9) = [F:MVC]LNDDLVR
      Endif
    Else
      # Niveau société et Cours historisé : On prend tel quel les montants en devise société
      WMNTDES (0) = [F:MVC]DLVOSTL
      WMNTDES (1) = [F:MVC]NIVDLVL
      WMNTDES (2) = [F:MVC]NPTINVL
      WMNTDES (3) = [F:MVC]NYTBILL(0)
      WMNTDES (4) = [F:MVC]NYTBILL(1)
      WMNTDES (5) = [F:MVC]NYTBILL(2)
      WMNTDES (6) = [F:MVC]BLCL
      WMNTDES (7) = [F:MVC]ORDBPIATIL
      If dim([F:MVC]LNDDLVL) <> -1
        WMNTDES (8) = [F:MVC]LNDBPIATIL
        WMNTDES (9) = [F:MVC]LNDDLVL
      Endif
    Endif
    WDLVOST        += WMNTDES (0)
    WNIVDLV        += WMNTDES (1)
    WNPTINV        += WMNTDES (2)
    If CTX.AFOLD.AMODULE(5)=2
      If CTX_OSTDRAFT=2
        WNYTBIL(0) += WMNTDES(3)
        WNYTBIL(1) += WMNTDES(4)
        WNYTBIL(2) += WMNTDES(5)
      Endif
    Endif
    WBLC           += WMNTDES (6)
    If CTX_OSTORD=2
      WORDBPIATI += WMNTDES (7)
    Endif
    If CTX_OSTLND=2
      If CTX_OSTORD=2
        WLNDBPIATI += WMNTDES (8)
      Endif
      WLNDDLV    += WMNTDES (9)
    Endif
  Next
  # Calcul du total en-cours
  ENCOURS  = WDLVOST + WNIVDLV + WNPTINV + WNYTBIL(0) + WNYTBIL(1) + WNYTBIL(2)
  ENCOURS += WBLC + WORDBPIATI + WLNDBPIATI + WLNDDLV
Return

# --------------------------------------------------------------------------------------------------
# ------------------------------------- #
# Chargement des paramètres nécessaires #
# ------------------------------------- #
$RECH_PARAM
Local Integer CTX_OSTDRAFT
Local Integer CTX_OSTLND
Local Integer CTX_OSTORD
#Local Integer CTX_OSTTYPCUR   # FGR 17/12/2014 : X3SUIVI95153 : pas déclaré au bon endroit.

  #---
  If CTX.AFOLD.AMODULE(5) = 2
    CTX_OSTDRAFT = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY,[F:MVC]CPY,"OSTDRAFT") :#-- Mnt portefeuille dans en-cours
  Endif
  CTX_OSTLND 		= fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY,[F:MVC]CPY,"OSTLND") 	 :#-- Prêt dans total en-cours
  CTX_OSTORD 		= fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY,[F:MVC]CPY,"OSTORD") 	 :#-- Carnet cde dans total en-cours
  CTX_OSTTYPCUR = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY,[F:MVC]CPY,"OSTTYPCUR") :#-- Type de cours pour contrôle au cours actualisé
  #CTX_OSTTYPCUR = fmet CUSTOMER.ACTX.ACACHE.GET_PARAM_NUM (2,[F:MVC]CPY,"OSTTYPCUR") :#-- Type de cours pour contrôle au cours actualisé
Return

# --------------------------------------------------------------------------------------------------
#**
#* Calcul de l'en-cours client ou client à risque en devise de reporting pour une société
#* SEGAY
#* @since 19/03/10
#* @param  CPY  : Société
#* @param  WBPCRSK  : Tiers risque
#* @param  TYPCOU   : Type de cours
#* @param  DAT      : Date
#* @param  FLACTL   : Client O/N
#* @return LOST     : En-cours calculé
#*!
Funprog CALOSTCPYCTLRSK(CTX, CPY, WBPC, TYPCOU, DAT, FLGCTL)
Value   Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value   Char    CPY            : # Société
Value   Char    WBPC           : # Tiers
Value   Integer TYPCOU         : # Type de cours
Value   Date    DAT            : # Date du cours
Value   Integer FLGCTL         : # Flag client O/N

Local   Decimal LOST           : # En-cours en devise de reporting
Local   Char    WPARAM(10)
Local   Decimal WMNTORG (0..9)
Local   Decimal WMNTDES (0..9)
Local   Integer I, SPSTAT
Local   Char    WCPY(GLONCPY), WCUR(GLONCUR), WCURSOC(GLONCUR), WSOCIETE(GLONCPY)
Local   Char    WCRITERE(50)

Local Char    CTX_SYSCUR(GLONCUR)
Local Integer CTX_OSTCTL
Local Integer CTX_OSTCHGTYP

Local Char    CTX_CURSHR(GLONCUR)
Local Char    CTX_LOCALDEV(GLONCUR)

  # ---------------------------------------
  Local File BPCUSTMVT [MVC]
  Local File COMPANY [CPY1]
  # ---------------------------------------
  #--Init des variables liées au contexte
  CTX_SYSCUR    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"SYSCUR")
  CTX_OSTCTL    = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCTL")
  CTX_OSTCHGTYP = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCHGTYP")
  CTX_CURSHR    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"CURSHRFLD")
  # ---------------------------------------
  Raz WSOCIETE
  # ---------------------------------------
  Read [CPY1]CPY0=CPY
  If !fstat Then
    WSOCIETE = [F:CPY1]CPY
    CTX_LOCALDEV = [F:CPY1]ACCCUR
  Else
    CTX_LOCALDEV = CTX_SYSCUR
  Endif
  WCURSOC = CTX_LOCALDEV
  # ---------------------------------------
  If FLGCTL Then
    CRITERE = "BPCNUM=WBPC"
  Else
    CRITERE = "BPCRSK=WBPC"
  Endif
  If CTX_OSTCTL = 2 and WSOCIETE <> "" Then
    CRITERE -= "& CPY=WSOCIETE"
  Endif
  If CTX_OSTCTL = 2 and WSOCIETE <> "" Then
    If [F:CPY1]ACCCUR <> "" Then
      # Ctrl au niveau société : Chargement des paramètres nécessaires
      [F:MVC]CPY = WSOCIETE
      Gosub RECH_PARAM
      WCUR = [F:CPY1]ACCCUR                      : # La devise utilisée pour calculer les mnts actualisés est la devise société
      WCURSOC = [F:CPY1]ACCCUR
    Endif
  Else
    # Ctrl au niveau dossier : Chargement des paramètres nécessaires
    WCUR = CTX_CURSHR                            : # La devise utilisée pour calculer les mnts actualisés est la devise dossier
  Endif
  Raz LOST
  Raz WCPY
  For [MVC]MVC0 Where evalue(CRITERE)
    If CTX_OSTCTL = 1 and WCPY <> [F:MVC]CPY Then
      # Ctrl au niveau dossier : Chargement des paramètres nécessaires qd on change de société
      Gosub RECH_PARAM
      WCPY = [F:MVC]CPY
    Endif

    Raz WMNTDES :#--CPO 101070

    If CTX_OSTCHGTYP = 2 or CTX_OSTCTL = 1 Then        : # Pour la version Béryl (pas de solde comptable en devise dossier)
      # Cours actualisé :
      # Conversion des montants en devise transaction en devise dossier (GCURSHR)
      If [F:MVC]CUR = WCUR Then
        WMNTDES(0) = [F:MVC]DLVOSTC
        WMNTDES(1) = [F:MVC]NIVDLVC
        WMNTDES(2) = [F:MVC]NPTINVC
        WMNTDES(3) = [F:MVC]NYTBILC(0)
        WMNTDES(4) = [F:MVC]NYTBILC(1)
        WMNTDES(5) = [F:MVC]NYTBILC(2)
        WMNTDES(6) = [F:MVC]BLCC
        WMNTDES(7) = [F:MVC]ORDBPIATIC
        If dim([F:MVC]LNDDLVC) <> -1 Then
          WMNTDES(8) = [F:MVC]LNDBPIATIC
          WMNTDES(9) = [F:MVC]LNDDLVC
        Endif
      Else
        Raz WMNTORG :#--CPO 101070

        WMNTORG(0) = [F:MVC]DLVOSTC
        WMNTORG(1) = [F:MVC]NIVDLVC
        WMNTORG(2) = [F:MVC]NPTINVC
        WMNTORG(3) = [F:MVC]NYTBILC(0)
        WMNTORG(4) = [F:MVC]NYTBILC(1)
        WMNTORG(5) = [F:MVC]NYTBILC(2)
        WMNTORG(6) = [F:MVC]BLCC
        WMNTORG(7) = [F:MVC]ORDBPIATIC
        If dim([F:MVC]LNDDLVC) <> -1 Then
          WMNTORG(8) = [F:MVC]LNDBPIATIC
          WMNTORG(9) = [F:MVC]LNDDLVC
        Endif
        For I = 0 To dim(WMNTORG)-1
          If WMNTORG(I) <> 0 Then
            Call CONVERT(CTX, [F:MVC]CUR, WCUR, WCURSOC, TYPCOU, DAT, WMNTORG(I), WMNTDES(I), SPSTAT) From TRTDEV_SYRA
          Endif
        Next I
      Endif
    Elsif CTX_OSTCTL = 1 Then
      # Niveau dossier et Cours historisé :
      # On prend tel quel les montants en devise dossier (GCURSHR)
      WMNTDES(0) = [F:MVC]DLVOSTR
      WMNTDES(1) = [F:MVC]NIVDLVR
      WMNTDES(2) = [F:MVC]NPTINVR
      WMNTDES(3) = [F:MVC]NYTBILR(0)
      WMNTDES(4) = [F:MVC]NYTBILR(1)
      WMNTDES(5) = [F:MVC]NYTBILR(2)
      WMNTDES(6) = [F:MVC]BLCR
      WMNTDES(7) = [F:MVC]ORDBPIATIR
      If dim([F:MVC]LNDDLVR) <> -1 Then
        WMNTDES(8) = [F:MVC]LNDBPIATIR
        WMNTDES(9) = [F:MVC]LNDDLVR
      Endif
    Else
      # Niveau société et Cours historisé : On prend tel quel les montants en devise société
      WMNTDES(0) = [F:MVC]DLVOSTL
      WMNTDES(1) = [F:MVC]NIVDLVL
      WMNTDES(2) = [F:MVC]NPTINVL
      WMNTDES(3) = [F:MVC]NYTBILL(0)
      WMNTDES(4) = [F:MVC]NYTBILL(1)
      WMNTDES(5) = [F:MVC]NYTBILL(2)
      WMNTDES(6) = [F:MVC]BLCL
      WMNTDES(7) = [F:MVC]ORDBPIATIL
      If dim([F:MVC]LNDDLVL) <> -1 Then
        WMNTDES(8) = [F:MVC]LNDBPIATIL
        WMNTDES(9) = [F:MVC]LNDDLVL
      Endif
    Endif
    # Incrémentation du total en-cours
    LOST += WMNTDES(0) + WMNTDES(1) + WMNTDES(2) + WMNTDES(6)
    If CTX.AFOLD.AMODULE(5) = 2 Then
      If CTX_OSTDRAFT = 2 Then
        LOST += WMNTDES(3) + WMNTDES(4) + WMNTDES(5)
      Endif
    Endif
    If CTX_OSTORD = 2 Then
      LOST += WMNTDES(7)
    Endif
    If CTX_OSTLND = 2 Then
      LOST += WMNTDES(9)
      If CTX_OSTORD = 2 Then
        LOST += WMNTDES(8)
      Endif
    Endif
  Next
End LOST

# --------------------------------------------------------------------------------------------------
#**
#* Calcul de l'en-cours client risque en devise de reporting pour une société
#* SEGAY
#* @since 16/01/09
#* @param  CPY  : Société
#* @param  WBPCRSK  : Tiers risque
#* @param  TYPCOU   : Type de cours
#* @param  DAT      : Date
#* @return LOST     : En-cours calculé
#*!
Funprog CALOSTCPY(CTX, CPY, WBPCRSK, TYPCOU, DAT)
Value   Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value   Char    CPY            : # Société
Value   Char    WBPCRSK       : # Tiers risque
Value   Integer TYPCOU         : # Type de cours
Value   Date    DAT            : # Date du cours

Local   Integer FLGCLT         : # Flag client O/N
Local   Decimal LOST           : # En-cours en devise de reporting

  FLGCLT = 0
  Raz LOST
  LOST = func CALOSTCPYCTLRSK(CTX, CPY, WBPCRSK, TYPCOU, DAT, FLGCLT)
End LOST

# --------------------------------------------------------------------------------------------------
#**
#* Calcul de l'en-cours client en devise de reporting pour une société
#* SEGAY
#* @since 19/03/10
#* @param  CPY  : Société
#* @param  WBPCNUM  : Tiers
#* @param  TYPCOU   : Type de cours
#* @param  DAT      : Date
#* @return LOST     : En-cours calculé
#*!
Funprog CALOSTCPYCTL(CTX, CPY, WBPCNUM, TYPCOU, DAT)
Value   Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value   Char    CPY            : # Société
Value   Char    WBPCNUM       : # Tiers
Value   Integer TYPCOU         : # Type de cours
Value   Date    DAT            : # Date du cours

Local   Integer FLGCLT         : # Flag client O/N
Local   Decimal LOST           : # En-cours en devise de reporting

  FLGCLT = 1
  Raz LOST
  LOST = func CALOSTCPYCTLRSK(CTX, CPY, WBPCNUM, TYPCOU, DAT, FLGCLT)
End LOST
