#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
#    Process Name:    SUBB9M - Maintain Supplier 1099 Text and Check boxes
######################################################################################
$ACTION

Case ACTION
  When "OUVRE":    : Gosub OUVRE
  When "LIENS":    : Gosub LIENS
  When "SETBOUT"   : Gosub SETBOUT
  When "VERIF_CRE"   : Gosub VERIF
  When "VERIF_MOD"   : Gosub VERIF
  When "VERF_ANU"    : Gosub VERIF
  When Default
Endcase
Return

######################################################################################
$OUVRE

If !clalev([F:BX9])  Local File BOX1099    [BX9]  : Endif
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS]  : Endif
If !clalev([F:B9M2]) Local File BPS1099MNT [B9M2] : Endif
If !clalev([F:B9G])  Local File BPS1099GEN  [B9G] : Endif

Return
######################################################################################
$SETBOUT

# Activate the Delete button if there are records displayed
If [M:B9M1]NBBAN > 0
    CHAINE += "A"
Endif

Return
######################################################################################
$LIENS

[M]VALEUR1(nolign-1) = [F:B9M]TXTFLD
Read [F:BX9]BX90=[F:B9M]FRM1099;[F:B9M]BOX1099
If fstat = 0 
    If [F:BX9]BOXTYP=3
        [M]VALEUR1(nolign-1) = mess(val([F:B9M]TXTFLD), 1, 1)
    Endif
Endif

Return
######################################################################################
$VERIF

Look [F:B9G]B9G1 = [M:B9M1]YR1099;[M:B9M1]CPY;[M:B9M1]BPSNUM
If [S]fstat <=2 # Generate record exists     
  If GREP="A"
  Call OUINON(mess(82,122,1),XOK) From GESECRAN
  Else
  Call OUINON(mess(81,122,1),XOK) From GESECRAN # Warning message prompt
  Endif
  If XOK<>2
    GERR=1 
    OK=0              
  Endif            
Endif 

Return
######################################################################################
Subprog C_BOX1099(VALEUR)
Variable Char    VALEUR()

#1099 Verify the selected Box along with Form combination exists

Read [F:BX9]BX90 = [M:B9M1]FRM1099;VALEUR
If fstat 
  GMESSAGE = mess(23,100,1)  : mkstat = 2 : End    # Record does not exist. 
Endif

If [F:BX9]ENAFLG <> 2
  GMESSAGE = mess(2,126,1): mkstat = 2 : End       # Inactive record
Endif

If [F:BX9]BOXTYP <= 1
  GMESSAGE = mess(78,122,1) : mkstat = 2 : End    # Invalid 1099 box
Endif


End

######################################################################################
Subprog AM_FRM1099(VALEUR)
Variable Integer VALEUR

Local Integer II


Raz [M:B9M1]NBBAN
Effzo [M:B9M1]20

Filter [F:B9M2] Where YR1099 = [M:B9M1]YR1099 and CPY = [M:B9M1]CPY and BPSNUM = [M:B9M1]BPSNUM and FRM1099 = VALEUR
Read [F:B9M2] First
If fstat
    #
    # Auto populate the screen with applicable text and checkbox boxes
    #   
    II = 0
    [M:B9M1]FRM1099 = VALEUR

    For [BX9] Where FRM1099 = VALEUR and BOXTYP > 1
    
        [M:B9M1]BOX1099(II) = [F:BX9]BOX1099
        [M:B9M1]DES(II)     = [F:BX9]DES
        [M:B9M1]BOXTYP(II)  = [F:BX9]BOXTYP
        If [F:BX9]BOXTYP = 3
            [M:B9M1]NOLIB(nolign-1)  = 1
            [M:B9M1]PARTYP(nolign-1) = "M"
        Else
            [M:B9M1]NOLIB(nolign-1)  = 0
            [M:B9M1]PARTYP(nolign-1) = "A"
        Endif

        II += 1
    
    Next
    
    [M:B9M1]NBBAN = II
    Affzo [M:B9M1]BOX1099, DES
Endif

Filter [F:B9M2]
End
######################################################################################
Subprog AS_FRM1099(VALEUR)
Variable Integer VALEUR

GMENLOC(1) = 1    # eliminate "None" from the local menu set

End


######################################################################################
Subprog AV_DES(VALEUR)
Variable Char    VALEUR()

If [M]BOX1099(nolign-1) <> ""

    Read [F:BX9]BX90 = [M:B9M1]FRM1099;[M]BOX1099(nolign-1)
    If fstat = 0
        VALEUR = [F:BX9]DES
    Else
        VALEUR = ""
    Endif

    If [F:BX9]BOXTYP = 3
        [M]NOLIB(nolign-1)  = 1
        [M]PARTYP(nolign-1) = "M"
    Else
        [M]NOLIB(nolign-1)  = 0
        [M]PARTYP(nolign-1) = "A"
    Endif

Endif

End

######################################################################################
Subprog C_YR1099(VALEUR)
Variable Decimal VALEUR

If len(num$(VALEUR)) < 4
  GMESSAGE = mess(112,123,1)  : mkstat = 2 : End    # Invalid format
Endif

End


