#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OCLD

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:18"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OCLD",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="CLD0;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "CLD"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "TYPCLD+PERIOD"
If clalev([M:CLD0])=0 : Local Mask CLD0 [CLD0] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOCLD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCLD" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLD0]
&  Listbox [CLD] GAU_CHE
&   [L]SAIRAP(1) = mess([F:CLD]TYPCLD(0),10424,1) Using "" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:CLD]PERIOD Using "K:20X" Titled TITSEL(2)
&  Listbox [CLD9] GAU_CHE9
&   [L]SAIRAP(1) = mess([F:CLD9]A_TAB1,10424,1) Using "" Titled TITSEL9(1) ,
&   [L]SAIRAP(2) = [F:CLD9]A_TAB2 Using "K:20X" Titled TITSEL9(2) 
& As [CLD0]
Titled [CLD0] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOCLD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCLD" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLD0]
& As [CLD0]
Titled [CLD0] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [CLD0] 
Return

$SAISIE_BOITE
Boxinp [CLD0] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [CLD0]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(1802,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL(30)(1..2)
Call TEXTE(25891,TITSEL(1)) From OBJDIV
Call TEXTE(1355,TITSEL(2)) From OBJDIV
Local Char TITSEL9(30)(1..2)
Call TEXTE(25891,TITSEL9(1)) From OBJDIV
Call TEXTE(1355,TITSEL9(2)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(1802,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [CLD] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [CLD0] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [CLD0] GAU_CHE
 Else
  Fillbox [CLD0] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [CLD]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "TYPCLD;PERIOD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [CLD]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [CLD] Order With CLELISTE
  Setlbox [CLD0] GAU_CHE
  Filter [CLD]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [CLD0] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [CLD] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [CLD]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(1) = "CLD0"         : ABMSK(1)  = "CLD0"     : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 1 : If clalev([M:CLD0])>0 : Default Mask [CLD0] : Endif
Endcase
Return

$TITMASK
Case MA
 When 1 : If clalev([M:CLD0])>0 : Gosub TITRES From W1CLD0 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:CLD0])>0 : Close Local Mask [CLD0] : Endif
Return

$RAZMASK
Case MA
 When 1 : If clalev([M:CLD0])>0 : Raz [M:CLD0] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 1 : If clalev([M:CLD0])>0 : Affzo [M:CLD0] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 1 : If clalev([M:CLD0])>0 : [F:CLD] = [M:CLD0] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 1 : If clalev([M:CLD0])>0 : [M:CLD0] = [F:CLD] : Endif
Endcase
Return

$GRISE_CLE
Grizo [CLD0]PERIOD,TYPCLD
Return

$DEGRISE_CLE
Actzo [CLD0]PERIOD,TYPCLD
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


