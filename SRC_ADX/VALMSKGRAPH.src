#<AdxTL>@(#)5.0.0.0 $Revision$

# ecriture des propriétés graphiques d'un tableau
$GRAPHIC
If BLC_TYPG(WE_NOBL)<1 or BLC_TYPG(WE_NOBL)>5 : Return : Endif
#Return
Local Integer NBGDEF,ILABEL,FIRSTALPHA,WFLAGTEMP1
Local Char SAVHIERN(50)
Local Char TEMPTAB(10)(1..4)
If BLC_TYPG(WE_NOBL)=3 : Goto JSONAGENDA : Endif
If BLC_TYPG(WE_NOBL)=5 : Goto JSONGANTT : Endif
If BLC_TYPG(WE_NOBL)=4
  Read [AUR]AUR0=BLC_LIEN1(WE_NOBL)
  If fstat<>0 : Return : Endif

#  Surcharge des valeurs paramètres des blocs XSL
  WE_ORI=instr(1,BLC_ACT1(WE_NOBL),"?")
  For WE_3=0 To 4
    WE_DEST=instr(WE_ORI+1,BLC_ACT1(WE_NOBL),"?")
    If WE_DEST-WE_ORI>1
      [F:AUR]UPARDEF(WE_3)=mid$(BLC_ACT1(WE_NOBL),WE_ORI+1,WE_DEST-WE_ORI-1)
    Endif
    WE_ORI=WE_DEST
  Next WE_3


  If [F:AUR]PARXSL="NOMEN"
    If instr(1,BLC_LIEN1(WE_NOBL),"NOMH")>0 : Goto JSONXSLNOMH : Endif
    If instr(1,BLC_LIEN1(WE_NOBL),"APITL")>0 : Goto JSONTIMELINE : Endif
    Goto JSONXSL
  Endif
  If [F:AUR]PARXSL="RADAR" : Goto GRAPHJSON: Endif
  If [F:AUR]PARXSL="PLANN" : Goto JSONXSLPLAN: Endif
  Return
Endif

#  Traitements graphes et radar
$GRAPHJSON
Wrseq "," Using [JSO_]
Wrseq '"$cube": {'  Using [JSO_]
JSONPROP= "$mode" : JSONVALUE="table" : Gosub ADDJSONPROPV From VALMSKJSON
JSONPROP= "$style"
WE_VALUE=""
If BLC_TYPG(WE_NOBL)=1 or BLC_TYPG(WE_NOBL)=2   : #  Graphes
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If left$(LIG_TRG(WE_NOBL,WE_F),3)="G02" : NBGDEF+=1 : Endif
    If left$(LIG_TRG(WE_NOBL,WE_F),3)="G03" : ILABEL=WE_F : Endif
    If LIG_TYI(WE_NOBL,WE_F)=7 and FIRSTALPHA=0 : FIRSTALPHA=WE_F : Endif
    #Exclude
       If LIG_TRF(WE_NOBL,WE_F)=2 and LIG_TYP(WE_NOBL,WE_F)="AEX"
          LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
          WE_VALUE='$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)
      Endif

  Next WE_F
  If ILABEL=0 : ILABEL=max(1,FIRSTALPHA) : Endif
  Case BLC_GDEF(WE_NOBL)
    When 1 : JSONVALUE="xy"         : # Barres
    When 2 : JSONVALUE="line"       : # Lignes
    When 3 : JSONVALUE="area"       : # Aires    # AKA X3-63481: change from line to area
    When 4 : JSONVALUE="pie"        : # Secteurs
    When Default : JSONVALUE="xy"   : # Barres
  Endcase
  Gosub ADDJSONPROPV From VALMSKJSON
Elsif BLC_TYPG(WE_NOBL)=4
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If left$(LIG_TRG(WE_NOBL,WE_F),3)="R02" : NBGDEF+=1 : Endif
    If left$(LIG_TRG(WE_NOBL,WE_F),3)="R03" : ILABEL=WE_F : Endif
    If LIG_TYI(WE_NOBL,WE_F)=7 and FIRSTALPHA=0 : FIRSTALPHA=WE_F : Endif
  Next WE_F
  If ILABEL=0 : ILABEL=max(1,FIRSTALPHA) : Endif
  JSONVALUE="spiderweb" : Gosub ADDJSONPROPV From VALMSKJSON
Endif


#  S'il n'y a qu'une valeur par défaut on positionne la propriété à true
JSONVALUE="false"
If BLC_TYPG(WE_NOBL)=1  : JSONVALUE="true" : Endif
JSONPROP= "$displaysOneMeasure" : Gosub ADDJSONPROPV From VALMSKJSON
#Exclude
  If(WE_VALUE<>"")
    JSONPROP="$displaySelector"
    JSONVALUE=WE_VALUE
     Gosub ADDJSONPROPV From VALMSKJSON
  Endif



# Titre du graphique = titre du bloc ou "titre" colonne "Libelllé" si il n'y en a pas

WE_NTEX=BLC_TIT(WE_NOBL)  : WE_INTEV=""
If WE_NTEX=0
  WE_NTEX=LIG_TIT(WE_NOBL,ILABEL)  : WE_CAPDEF=LIG_TXT(WE_NOBL,ILABEL)
  WE_INTEV=LIG_EVL(WE_NOBL,ILABEL) : WE_FORCE=0
Endif

WE_NTEXKEY="F_"+ECRAN+"_"+BLC_BAS(WE_NOBL) #LIG_ZON(WE_NOBL, WE_J)
Gosub JSON_ADDNLOC From VALWINJSON
JSONPROP="$title"    : JSONVALUE=WE_VALUE  : Gosub ADDJSONPROPV From VALMSKJSON

For WE_3=0 To 4
  If [F:AUR]UPARDEF(WE_3)<>""
        Case[F:AUR]UPARCOD(WE_3)
          When "SCALE"  : JSONPROP="$scale"
                         If[F:AUR]UPARDEF(WE_3)<>"" : JSONVALUE=[F:AUR]UPARDEF(WE_3)  : Gosub ADDJSONPROPV From VALMSKJSON :Endif
          When "MENSCA" : JSONPROP="$mnu"
                          If ([F:AUR]UPARDEF(WE_3)<>"" and [F:AUR]UPARDEF(WE_3)<>"0"): JSONVALUE=[F:AUR]UPARDEF(WE_3)  : Gosub ADDJSONPROPV From VALMSKJSON :Endif
        Endcase
  Endif
Next WE_3

Wrseq '"$hierarchies": {'  Using [JSO_]
#   '"BA2_h": {'  Using [JSO_]
LIDX=LIG_IDX(WE_NOBL,ILABEL)-BLC_IDX(WE_NOBL)
SAVHIERN='$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'_h'
Wrseq '"'+ SAVHIERN +'": {' Using [JSO_]

WE_NTEX=LIG_TIT(WE_NOBL,ILABEL)  : WE_CAPDEF=LIG_TXT(WE_NOBL,ILABEL)
WE_INTEV=LIG_EVL(WE_NOBL,ILABEL) : WE_FORCE=0
WE_NTEXKEY="F_"+ECRAN+"_"+LIG_ZON(WE_NOBL,ILABEL)
Gosub JSON_ADDNLOC From VALWINJSON
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV From VALMSKJSON

#JSONPROP="$properties" : JSONVALUE='$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX) : Gosub ADDJSONPROPV from VALMSKJSON
Wrseq '"$properties":["'+'$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"],'   Using [JSO_]
Wrseq '"$members": [],'  Using [JSO_]
JSONPROP= "$isDefault" : JSONVALUE="true" : Gosub ADDJSONPROP From VALMSKJSON
Wrseq '}'  Using [JSO_]
Wrseq '},'  Using [JSO_]



Wrseq '"$measures": {'  Using [JSO_]
#  Itérer pour chaque champ
Gosub MEASURES
Wrseq '}},'  Using [JSO_]


Wrseq '"$axes": [{'  Using [JSO_]
Wrseq '"$hierarchies": ['  Using [JSO_]
Wrseq '["'+SAVHIERN+'"]'  Using [JSO_]
Wrseq ']'  Using [JSO_]
Wrseq '}, {'  Using [JSO_]
Wrseq '"$hierarchies": ['  Using [JSO_]
Wrseq '["$measures"]'  Using [JSO_]
Wrseq ']'  Using [JSO_]
Wrseq '}]'  Using [JSO_]
#Wrseq '},'  Using [JSO_]



Return




$MEASURES
NBMM=0
For WE_F=1 To LIG_NBR(WE_NOBL)
#   If LIG_SAI(WE_NOBL,WE_F)<=2 or (LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2)
   If LIG_IDX(WE_NOBL,WE_F)<>0 and  (left$(LIG_TRG(WE_NOBL,WE_F),3)="G01" or left$(LIG_TRG(WE_NOBL,WE_F),3)="G02"
&     or left$(LIG_TRG(WE_NOBL,WE_F),3)="R02")
    If NBMM>=1 :     Wrseq "},"  Using [JSO_] : Endif
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    Wrseq '"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'": {' Using [JSO_]
    NBMM+=1
    Case LIG_TYI(WE_NOBL,WE_F)
      When 1       : If LIG_LIB(WE_NOBL,WE_F)>0
                       If LIG_LIB(WE_NOBL,WE_F)=1
                         If LIG_GRA(WE_NOBL,WE_F) = 1
                          JSONVALUE="application/x-choice"
                         Else
                          JSONVALUE="application/x-boolean"   : # Menu local
                         Endif
                       Else
                         JSONVALUE="application/x-choice"   : # Menu local
                       Endif
                     Else
                       JSONVALUE="application/x-integer"  : # Integer
                     Endif
      When 2,3     : JSONVALUE="application/x-integer"    : # Entier court et long
      When 4       : JSONVALUE="application/x-decimal"    : # Décimal
      When 5       : JSONVALUE="application/x-real"       : # Flottant
      When 6       : JSONVALUE="application/x-real"       : # Double
      When 7       : JSONVALUE="application/x-string"     : # Alphanumérique
      When 8       : JSONVALUE="application/x-date"       : # Date
      When Default : JSONVALUE="application/x-string"
     Endcase
    JSONPROP="$type"   : Gosub ADDJSONPROPV From VALMSKJSON

    WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F)
    WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0
    WE_NTEXKEY="F_"+ECRAN+"_"+LIG_ZON(WE_NOBL,WE_F)
    Gosub JSON_ADDNLOC From VALWINJSON
   # JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV From VALMSKJSON

    #JSONPROP= "$style" : JSONVALUE="stick" : Gosub ADDJSONPROPV From VALMSKJSON

    JSONPROP= "$isStacked" : JSONVALUE="false"
    If BLC_REPD(WE_NOBL)=2 :  JSONVALUE="true" : Endif
    Gosub ADDJSONPROPV From VALMSKJSON


    JSONPROP= "$isNormalized" : JSONVALUE="false"
    If BLC_REPD(WE_NOBL)=3 :  JSONVALUE="true" : Endif
    Gosub ADDJSONPROPV From VALMSKJSON

    JSONVALUE=""

    If LIG_TRP(WE_NOBL,WE_F)=2 : JSONVALUE="stick" : Endif
    If LIG_TRP(WE_NOBL,WE_F)=3 : JSONVALUE="line" : Endif
    If JSONVALUE<>"" :     JSONPROP="$style" : Gosub ADDJSONPROPV From VALMSKJSON : Endif

    JSONVALUE="false"
    If left$(LIG_TRG(WE_NOBL,WE_F),3)="G02" : JSONVALUE="true" : Endif
    JSONPROP= "$isDefault" : Gosub ADDJSONPROP From VALMSKJSON
   Endif
Next WE_F
Wrseq "}" Using [JSO_]
Return


$JSONGANTT
Wrseq "," Using [JSO_]
Wrseq '"$decorator": {' Using [JSO_]
JSONPROP= "$stereotype" :  JSONVALUE="gantt" : Gosub ADDJSONPROPV From VALMSKJSON
Wrseq '"$bindings": {' Using [JSO_]
#  écriture des différents bindings
#  sous la forme       -    "KEY": "EA3",   -
NBMM=0 : VALL1=""
For WE_F=1 To LIG_NBR(WE_NOBL)
   If LIG_IDX(WE_NOBL,WE_F)<>0 and  (left$(LIG_TRG(WE_NOBL,WE_F),2))="T0"
    If NBMM>=1 :     Wrseq VALL1+","  Using [JSO_] : Endif
    NBMM+=1
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    Case left$(LIG_TRG(WE_NOBL,WE_F),3)
      When "T01" : VALL1='"KEY"'
      When "T02" : VALL1='"LIB"'
      When "T03" : VALL1='"DATDI"'
      When "T04" : VALL1='"DURI"'
      When "T05" : VALL1='"TYPDAY"'
      When "T06" : VALL1='"ELAP"'
    Endcase
    VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
   Endif
Next WE_F
Wrseq VALL1+"}}"  Using [JSO_]

Return

$JSONAGENDA
Wrseq "," Using [JSO_]
Wrseq '"$decorator": {' Using [JSO_]
JSONPROP= "$stereotype" :  JSONVALUE="agenda" : Gosub ADDJSONPROPV From VALMSKJSON
Wrseq '"$bindings": {' Using [JSO_]
#  écriture des différents bindings
#  sous la forme       -    "KEY": "EA3",   -
NBMM=0 : VALL1=""
For WE_F=1 To LIG_NBR(WE_NOBL)
   If LIG_IDX(WE_NOBL,WE_F)<>0 and  (left$(LIG_TRG(WE_NOBL,WE_F),2)="A0" or left$(LIG_TRG(WE_NOBL,WE_F),2)="A1")
    If NBMM>=1 :     Wrseq VALL1+","  Using [JSO_] : Endif
    NBMM+=1
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    Case left$(LIG_TRG(WE_NOBL,WE_F),3)
      When "A01" : VALL1='"TYPACT"'
      When "A02" : VALL1='"KEYACT"'
      When "A03" : VALL1='"DATDI"'
  #    When "A04" : VALL1='"DATDI"'     voir ou trouver
      When "A04" : VALL1='"DATFI"'
   #   When "A06" : VALL1='"DATFI"'
      When "A05" : VALL1='"HEUD"'
      When "A06" : VALL1='"HEUF"'
      When "A07" : VALL1='"TIER"'
      When "A08" : VALL1='"INT"'
      When "A09" : VALL1='"CAT"'
      When "A10" : VALL1='"OBJ"'
      When "A11" : VALL1='"EXE"'
    Endcase
    VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
   Endif
Next WE_F
Wrseq VALL1+"}}"  Using [JSO_]

Return

$JSONXSL
# Treeview
Wrseq "," Using [JSO_]
Wrseq '"$treeview": {' Using [JSO_]
Wrseq '"$mode": "parentKey",' Using [JSO_]
Wrseq '"$bindings": {' Using [JSO_]
#  Liste des bindings
NBMM=0 : VALL1=""
VALTEMP1=""
# avoid the limite
WFLAGTEMP1=0
For WE_F=1 To LIG_NBR(WE_NOBL)
   If  VALL1<>""
    If NBMM=1
      Wrseq VALL1  Using [JSO_]
    Else
      Wrseq "," +VALL1 Using [JSO_]
    Endif
    VALL1=""
   Endif
   If LIG_IDX(WE_NOBL,WE_F)<>0
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"PARENT")>0 : VALL1='"$parent"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"KEY")>0 : VALL1='"$clientId"' :  Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"ICO")>0 : VALL1='"$icon"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"LIB")>0 : VALL1='"$description"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"LIBSH")>0 : VALL1='"$title"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"EXP")>0 : VALL1='"$open"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"INF")>0
    If WFLAGTEMP1 =0
      VALTEMP1=',"$data":['
      WFLAGTEMP1=1
    Else
      VALTEMP1+=','
    Endif
    If len(VALTEMP1) > 190
      Wrseq VALTEMP1 Using [JSO_]
      VALTEMP1=""
    Endif
    VALTEMP1+='"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
    Endif
    If VALL1<>"" and instr(1,LIG_TRG(WE_NOBL,WE_F),"INF")<=0
      NBMM+=1
      VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
      #If left$( VALL1, 11)='"$clientId"'
      #  VALL1+=',"$id":"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
      #Endif
    Endif
   Endif
Next WE_F
If WFLAGTEMP1=1
   VALTEMP1+="]"
   Wrseq VALTEMP1 Using [JSO_]
   WFLAGTEMP1=0
   VALTEMP1=""
Endif
If NBMM>1 and VALL1<>""
  Wrseq ','+VALL1+'}}' Using [JSO_]
Else
  Wrseq VALL1+'}}' Using [JSO_]
Endif
Return

$JSONXSLPLAN
NBMM=0 : VALL1="": VALTEMP1="" : Raz TEMPTAB
#Call ECR_TRACE(BLC_LIEN1(WE_NOBL),-1) From GESECRAN
#planing annuel planning mensuel
Wrseq "," Using [JSO_]
Wrseq '"$decorator": {' Using [JSO_]
JSONPROP= "$stereotype" :  JSONVALUE="calendar" : Gosub ADDJSONPROPV From VALMSKJSON
Case BLC_LIEN1(WE_NOBL)
  When "APLANY" :JSONVALUE="year"
  When "APLANM" :JSONVALUE="month"
Endcase
JSONPROP= "$style":  JSONVALUE : Gosub ADDJSONPROPV From VALMSKJSON
For WE_F=0 To 4
  If [F:AUR]UPARDEF(WE_F)<>""
        Case[F:AUR]UPARCOD(WE_F)
          When "MENACT" : If ([F:AUR]UPARDEF(WE_F)<>"" and [F:AUR]UPARDEF(WE_F)<>"0")
                            VALL1=[F:AUR]UPARDEF(WE_F)
                          Endif
          Endcase
  Endif
Next WE_F

If(VALL1<>"")
  VALTEMP1='"$events": ['
   For WE_F=0 To len(mess(0,val(VALL1),1))-1
      VALTEMP1+='"{@M_'+VALL1+'_'+num$(WE_F+1)+'}",'
      WE_NTEXKEY='M_'+VALL1+'_'+num$(WE_F+1)
      WE_NTEX=(((val(VALL1)*1000))+WE_F+1)*(-1)
      Gosub JSON_ADDNLOC From VALWINJSON
   Next WE_F
  Wrseq left$(VALTEMP1,len(VALTEMP1)-1)+'],'  Using [JSO_]
Endif

Wrseq '"$bindings": {' Using [JSO_]
VALTEMP1="":VALL1=""
For WE_F=1 To LIG_NBR(WE_NOBL)
   If  VALL1<>""
      Wrseq VALL1 + ","  Using [JSO_]
      VALL1=""
  Endif

  If LIG_IDX(WE_NOBL,WE_F)<>0
      LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
      If instr(1,LIG_TRG(WE_NOBL,WE_F),"TECDAT")>0 : VALL1='"TECDAT"' : Endif
      If instr(1,LIG_TRG(WE_NOBL,WE_F),"TYPDAY")>0 : VALL1='"TYPDAY"' : Endif
      If instr(1,LIG_TRG(WE_NOBL,WE_F),"PLAG")>0
          TEMPTAB(val(right$(LIG_TRG(WE_NOBL,WE_F), 9)))='"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
      Endif
  Endif
  If(VALL1<>"")
    NBMM+=1
    VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
  Endif
Next WE_F

VALTEMP1='"SLOT": ['
For WE_F=1 To 4
  If(TEMPTAB(WE_F)<>"")
    VALTEMP1+=TEMPTAB(WE_F)+","
  Endif
Next WE_F
VALTEMP1=left$(VALTEMP1,len(VALTEMP1)-1)+']'
Wrseq  VALTEMP1 Using [JSO_]
Wrseq VALL1+'}}' Using [JSO_]

Return

$JSONXSLNOMH
# Orgview
Wrseq "," Using [JSO_]
Wrseq '"$decorator": {' Using [JSO_]
JSONPROP= "$stereotype" :  JSONVALUE="orgview" : Gosub ADDJSONPROPV From VALMSKJSON
  For WE_3=0 To 4
    VALL1=""
    If [F:AUR]UPARDEF(WE_3)<>""
      Case[F:AUR]UPARCOD(WE_3)
        When "MODHIE" : VALL1='"$allowMove"'
                        If [F:AUR]UPARDEF(WE_3)<>"2" : VALL1+=': false,' : Wrseq VALL1 Using [JSO_] : Endif
        When "EXECFL" : VALL1='"$allowDoubleClick"'
                        If [F:AUR]UPARDEF(WE_3)<>"2" : VALL1+=': false,' : Wrseq VALL1 Using [JSO_] : Endif
        When "PINTER" : VALL1='"$interact": "'+[F:AUR]UPARDEF(WE_3)+'",'
                        Wrseq VALL1 Using [JSO_]
        When "SIZEB"  : VALL1='"$boxSize": "'+[F:AUR]UPARDEF(WE_3)+'",'
                        Wrseq VALL1 Using [JSO_]
      Endcase
    Endif
  Next WE_3


Wrseq '"$mode": "parentKey",' Using [JSO_]
Wrseq '"$bindings": {' Using [JSO_]
#  Liste des bindings
NBMM=0 : VALL1=""
VALTEMP1=""
For WE_F=1 To LIG_NBR(WE_NOBL)
   If  VALL1<>""
    If NBMM=1
      Wrseq VALL1  Using [JSO_]
    Else
      Wrseq "," +VALL1 Using [JSO_]
    Endif
    VALL1=""
   Endif
   If LIG_IDX(WE_NOBL,WE_F)<>0
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"PARENT")>0 : VALL1='"$parent"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"KEY")>0 : VALL1='"$clientId"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"ICO")>0 : VALL1='"$icon"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"IMG")>0 : VALL1='"$image"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"LIB")>0 : VALL1='"$description"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"LIBSH")>0 : VALL1='"$title"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"EXP")>0 : VALL1='"$open"' : Endif
    If instr(1,LIG_TRG(WE_NOBL,WE_F),"INF")>0
     If VALTEMP1=""
       VALTEMP1='"$data":['
     Else
       VALTEMP1+=','
     Endif
     VALTEMP1+='"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
    Endif
    If VALL1<>"" and instr(1,LIG_TRG(WE_NOBL,WE_F),"INF")<=0
      NBMM+=1
      VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
      #If left$( VALL1, 11)='"$clientId"'
     #   VALL1+=',"$id":"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
     # Endif
      #VALL1+=':"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
    Endif

   Endif
Next WE_F
If VALTEMP1<>""
   VALTEMP1+="]"
   Wrseq ','+VALTEMP1 Using [JSO_]
   VALTEMP1=""
Endif
If NBMM>1 and VALL1<>""
  Wrseq ','+VALL1+'}}' Using [JSO_]
Else
  Wrseq VALL1+'}}' Using [JSO_]
Endif
Return

$JSONTIMELINE
# Timeline
Wrseq "," Using [JSO_]
Wrseq '"$decorator": {' Using [JSO_]
JSONPROP= "$stereotype" :  JSONVALUE="timeline" : Gosub ADDJSONPROPV From VALMSKJSON
Wrseq '"$bindings": {' Using [JSO_]
#  Liste des bindings
NBMM=0 : VALL1=""
For WE_F=1 To LIG_NBR(WE_NOBL)
   If  VALL1<>""
    If NBMM=1
      Wrseq VALL1  Using [JSO_]
    Else
      Wrseq "," +VALL1 Using [JSO_]
    Endif
    VALL1=""
   Endif
   If LIG_IDX(WE_NOBL,WE_F)<>0 and LIG_ZON(WE_NOBL,WE_F)<>BLC_BAS(WE_NOBL)
    LIDX=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
    NBMM+=1
    VALL1='"'+LIG_ZON(WE_NOBL,WE_F)+'":"$x$'+mid$(WE_ALPHAB,RGBLOC,1)+num$(LIDX)+'"'
   Endif
Next WE_F
If NBMM>1 and VALL1<>""
  Wrseq ','+VALL1+'}}' Using [JSO_]
Else
  Wrseq VALL1+'}}' Using [JSO_]
Endif
Return

$SECLEVEL
  VALL1=""
  If(BLC_LIEN1(WE_NOBL)<>"")
    Read [AUR]AUR0=BLC_LIEN1(WE_NOBL)
    If fstat=0
        VALL1="["
        Call STRLEVEL([F:AUR]SECLEV,VALL1)
        If(BLC_LIEN2(WE_NOBL)<>"")
           Read [AUR]AUR0=BLC_LIEN2(WE_NOBL)
           If fstat=0
              VALL1+=","
              Call STRLEVEL([F:AUR]SECLEV,VALL1)
              If(BLC_LIEN3(WE_NOBL)<>"")
                  Read [AUR]AUR0=BLC_LIEN3(WE_NOBL)
                   VALL1+=","
                  If fstat=0
                    Call STRLEVEL([F:AUR]SECLEV,VALL1)
                  Endif
              Endif
           Endif
       Endif
    Endif
     VALL1+="]"
  Endif
  If(VALL1<>"")
     Wrseq '"$securityLevel":' + VALL1 + ','  Using [JSO_]
  Endif
Return

Subprog STRLEVEL(IVAL,STRVAL)
Value Integer IVAL
Variable Char STRVAL
    Case IVAL
      When 1 : STRVAL+='"high"' :
      When 2 : STRVAL+='"medium"' :
      When 3 : STRVAL+='"low"' :
      When Default : STRVAL+='"medium"'
    Endcase
End

