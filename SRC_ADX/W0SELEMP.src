#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SELEMP 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SELEMP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone OPE
mkstat = 0
zoncou = "OPE"
indice = 0
IMPENT = [M]OPE
If varinit([M]OPE,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPE,indice)=0
 [M]OPE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPE(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_OPE(IMPENT) From SELEMP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "OPE" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]OPE = IMPENT

## Zone VALEUR
mkstat = 0
zoncou = "VALEUR"
indice = 0
If varmode([M]VALEUR,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]VALEUR,[M]TYP) From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]VALEUR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "VALEUR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]VALEUR,[M]TYP,[M]LIB,[M]LNG,[M]VALINT) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VALEUR" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M]VALINT,[M]TYP,"","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VALEUR" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBEXP
mkstat = 0
zoncou = "NBEXP"
indice = 0
status = 1
zoncou = "NBEXP"
If varmode([M]NBEXP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBEXP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBEXP
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBEXP = nolign
   status = 75
   Call SAI_NBEXP(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBEXP(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBEXP
mkstat = 0
zoncou = "NBEXP"

## Zone ETOU
mkstat = 0
zoncou = "ETOU"
IMPENT = [M]ETOU(indice)
If varinit([M]ETOU,indice)=0
 IMPENT = 1
Endif
[M]ETOU(indice) = IMPENT

## Zone WOPE
mkstat = 0
zoncou = "WOPE"
IMPENT = [M]WOPE(indice)
If varinit([M]WOPE,indice)=0
 IMPENT = 1
Endif
[M]WOPE(indice) = IMPENT

## Zone NBEXP
mkstat = 0
zoncou = "NBEXP"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SELEMP"
Return

