#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# UTITC33   Création des valeurs par défaut des nouveaux paramètres      #
#           NULMVTIFA et NULAMTIFA                                       #
##########################################################################
# CCC (2010-05-05) DM 61129
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC33(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC33(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTITC33: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"NULAMTIFA"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "NULAMTIFA"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "2"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("NULAMTIFA: can't create parameter",1) From GESECRAN
      Endif
  Endif
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTITC33 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ADOVAL") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC33(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ADOVAL") : End : Endif
  Call MAJ_UTITC33(APPLI)
End

