#<AdxTL>@(#)7.0.0.0 $Revision$
#---------------------------------------------------------------------------------#
# Recherche code fonction, module et login d'après le no processus
#---------------------------------------------------------------------------------#

Subprog GET_CURFCT(MACHINE,APPLI,UID,FONCTION,MODULE,LOGIN)
Value    Char    MACHINE , APPLI , UID
Variable Char    FONCTION
Variable Integer MODULE
Variable Char    LOGIN
Local    Integer ER , OK
Onerrgo ER
Local Char SUPER(GLONADS)
If MACHINE="" or MACHINE=adxmac(0)
 Local File AFCTCUR  [AFU]
 Local File ADOSSIER [ADS]
Else
 If APPLI=""
  SUPER = APPX3(MACHINE+"@"+nomap)
 Else
  SUPER = APPX3(MACHINE+"@"+APPLI)
 Endif
 Local File =SUPER+".AFCTCUR"  [AFU]
 Local File =SUPER+".ADOSSIER" [ADS]
Endif
Onerrgo
If !ER
 OK = 1
 If APPLI<>""
  Read [ADS]DOSSIER=APPLI
  If fstat
   If MACHINE="" or MACHINE=adxmac(0)
    Local File ABATPAR [ABP]
   Else
    Local File =SUPER+".ABATPAR" [ABP]
   Endif
   Read [ABP]SPOOL First
   If fstat or [F:ABP]APPLI<>[L]APPLI
    OK = 0
   Endif
   LogicClose File [ABP]
  Endif
 Endif

 If OK
  Read [AFU]AFU0(1)=UID
  If !fstat
   If [F:AFU]FCT<>""   : FONCTION = [F:AFU]FCT    : Endif
   If [F:AFU]MODULE<>0 : MODULE   = [F:AFU]MODULE : Endif
   If [F:AFU]LOGIN<>"" : LOGIN    = [F:AFU]LOGIN  : Endif
  Endif
 Endif
 LogicClose File [AFU],[ADS]

Endif
End

$ER
ER = errn
Resume
#---------------------------------------------------------------------------------------------------------#
# Création code fonction, module et login dans la table AFCTCUR (remplace Setfct, Setmdu et Setgus)
#---------------------------------------------------------------------------------------------------------#

Subprog SET_CURFCT(FONCTION,MODULE,LOGIN)
Value Char    FONCTION
Value Integer MODULE
Value Char    LOGIN
Local Integer ER
Local Char MESSAGE(250)
If dim(GOK)<0 : Local Integer GOK : Endif :# security
If [L]LOGIN<>""
 Setgus [L]LOGIN : # Pour pouvoir faire des "psadx -u"
Endif
Onerrgo ER
Local File AFCTCUR [AFU]
Onerrgo
If !ER
 If !adxlog
  Gosub TR_CUR
 Else
  Gosub MAJ_CUR
 Endif
Endif
LogicClose File  [AFU]
End

#------------------#
$TR_CUR
GOK = 1
Trbegin [AFU]
 Gosub MAJ_CUR
 If GOK=0 : Rollback : Return : Endif
Commit
Return

#------------------#
$MAJ_CUR
#SAM 121093
#Readlock [AFU]AFU0(1)=num$(adxuid(1))
Readlock [AFU]AFU0(1)=num$(adxuid(1)) With lockwait=0
If fstat=1
 GOK = 0 : Return
Elsif !fstat
 Delete [AFU] Where UID=num$(adxuid(1))
 If fstat
  GOK = 0 : Call FSTA("AFU",1,MESSAGE) From GLOCK_SYRA
 Endif
Endif
Raz [F:AFU]
[F:AFU]UID    = num$(adxuid(1))
If dim(GACTX)>0 & dim(GACTX.USER)>0 & GACTX.USER<>""
 [F:AFU]USR   = GACTX.USER
#for old batch server
Elsif dim(GUSER)>0 & GUSER<>""
 [F:AFU]USR   = GUSER
Endif
If dim(GACTX)>0 & dim(GACTX.LOGIN)>0 & GACTX.LOGIN<>""
 [F:AFU]LOGIN = GACTX.LOGIN
#for old batch server
Elsif dim([V]GLOGIN)>0 & [V]GLOGIN<>""
 [F:AFU]LOGIN = [V]GLOGIN
Else
 [F:AFU]LOGIN = adxusr
Endif
[F:AFU]FCT    = [L]FONCTION
[F:AFU]MODULE = [L]MODULE
Write [AFU]
If fstat
 GOK = 0 : Call FSTA("AFU",1,MESSAGE) From GLOCK_SYRA
Endif
Return

#---------------------------------------------------------------------------------#
# Epuration des lignes de la table AFCTCUR avec des processus disparus
#---------------------------------------------------------------------------------#

Subprog RAZ_CURFCT(UID)
Value Char UID
Local Char     SID(12) , SCLI(80) , SUID(30)
#SAM 121093
#Local Char     TBUID(12)(1..3000)
Local Char     TBUID(12)(1..)
Local Integer  ER , NBUID
If dim(GOK)<0 : Local Integer GOK : Endif :# security
Onerrgo ER
Local File AFCTCUR [AFU]
Onerrgo
If !ER
 Onerrgo ER
 If UID=""
  Gosub CHARGE_UID
 Endif
 If !adxlog
  Gosub TR_RAZ
 Else
  Gosub MAJ_RAZ
 Endif
 Onerrgo
Endif
LogicClose File  [AFU]

End

$TR_RAZ
GOK = 1
Trbegin [AFU]
 Gosub MAJ_RAZ
 If GOK=0 : Rollback : Return : Endif
Commit
Return

$MAJ_RAZ
#SAM 121093
#If [L]UID="" and NBUID>2
If [L]UID=""
 For [AFU]
  If !find([F:AFU]UID,TBUID(1..NBUID))
   #SAM 121093
   #Readlock [AFU] Curr With lockwait=1 :#119684
   Readlock [AFU] Curr With lockwait=0

   If fstat=0
    Delete [AFU] Curr
    If fstat
     GOK = 0 : Call FSTA("AFU",1,MESSAGE) From GLOCK_SYRA : Break
    Endif
   Endif
  Endif
 Next AFU
Else
 For [AFU] Where UID=[L]UID
  #SAM 121093
  #Readlock [AFU] Curr With lockwait=1 : #119684
  Readlock [AFU] Curr With lockwait=0
  If fstat=0
   Delete [AFU] Curr
   If fstat
    GOK = 0 : Call FSTA("AFU",1,MESSAGE) From GLOCK_SYRA : Break
   Endif
  Endif
 Next AFU
# Delete [AFU] Where UID=[L]UID
# If fstat
#  GOK = 0 : Call FSTA("AFU",1,MESSAGE) From GLOCK_SYRA
# Endif
Endif
Return

$CHARGE_UID
If func ASESSIONS.ISMNGSESSIONS
 Call CHARGE_UID(TBUID,NBUID) From ASESSIONS
 Return
Endif

Local File (SID,SCLI,SUID) From System adxmac(0)+"@psadx -l"-GACTX.LAN As [SYS_]
Raz TBUID , NBUID
For [SYS_]
 If !find([F:SYS_]SID,TBUID(1..NBUID))
  NBUID += 1
  TBUID(NBUID) = [F:SYS_]SID
 Endif
Next SYS_
Close Local File [SYS_]
Return


#--------------------------------------------------#
# Récupérer le  temsp CPU du process
#--------------------------------------------------#

Subprog CPU_PROCESS(MACHINE,PROCESS,TIMECPU,ERRMES)
Value Char    MACHINE , PROCESS
Variable Char TIMECPU,ERRMES

If func ASESSIONS.ISMNGSESSIONSWITHCPU=[V]CST_AFALSE : Raz TIMECPU : End : Endif

Local Char    ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5) , OS(20) , MOTIF(GLONADI)
Local Integer K , STAT , OK
ERRMES = ""
Call GET_OS(MACHINE,OS) From ORDSYS
$CPUPROCESS
Case OS
 When "unix" : ORDSYS(1) = "killadx -u"-PROCESS
 When "dos"  : ORDSYS(1) = "killadx -u"-PROCESS
 When ""
  If !(left$(MACHINE,1)>="0" & left$(MACHINE,1)<="9")
   K = instr(1,MACHINE,".")
   If K
    MACHINE = left$(MACHINE,K-1)
    Call GET_OS(GACTX,MACHINE,OS)From ASYRSYS
   Endif
  Endif
  If OS="" | !find(OS,"unix","dos")
   ERRMES = MACHINE-":"-mess(199,100,1) : # Machine inaccessible
   End
  Endif
  Goto CPUPROCESS
Endcase
FICTRA = filpath("tmp","psadx_"+num$(adxuid(2)),"tra",nomap)
Openo FICTRA,0 Using [TR_]
Openo Using [TR_]
ORDSYS(2)  = FICTRA
Call SYSTEME(GACTX,MACHINE,ORDSYS,"",STAT) From ASYRSYS
If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+ORDSYS(1)
Endif
Openi FICTRA Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Rdseq MESSAGE(4) Using [TR_]
Openi Using [TR_]
Call _EFFACE(FICTRA,STAT) From ASYRSYS
TIMECPU = sum(MESSAGE)
If pat(TIMECPU,"**:**:**")=0 : Raz TIMECPU : Endif
End

