#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# CNSCSRSTD : Consultation des lignes retours    de ventes              #
# ECRAN 1   : CONSCSR1                                                  #
# ECRAN 2   : CONSCSR2                                                  #
# ECRAN CRIT: CRITCSR                                                   #
#########################################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AB6_NBLIG"  : Gosub AB6_NBLIG
 When Default
Endcase
Return

############################################################
$AUTORIS
Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCSR"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFILF(250)
Local Char    DEBNUM(GLONSRH), FINNUM(GLONSRH)
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747

Gosub DEFCRIT
Return
# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations CSR1, CCSR                            #
# --------------------------------------------------------------------------#
$DEFCRIT
#--CPO 88307
#If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If GNBAUZ=1 : PARAM(3)=GUSRFCY(1) : Endif
#--/
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF <> PARAM(I) Read [ITM] ITM0 = PARAM(I)
                                     If fstat  Raz [F:ITM], PARAM(I) : Endif
        Endif
        [M:CSR1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM <> PARAM(I) Then
           Read [BPC] BPC0 = PARAM(I)
           If fstat  Raz [F:BPC], PARAM(I) : Endif
        Endif
        [M:CSR1]BPCNUM = PARAM(I)
      Endif

    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I) Then
           Read [FCY] FCY0 = PARAM(I)
           If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CSR1]STOFCY = PARAM(I)
          Call GETDEV([M:CSR1]STOFCY) From DEVSUB
          [M:CSR1]CPY = GSOCIETE
          [M:CSR1]CURS = GLOCALDEV
       Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CSR1]PJTDEB = PARAM(I)
        [M:CSR1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CSR1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> ""  and PARAM(I) <> "000000" Then
        [M:CSR1]RTNDATDEB = PARAM(I)
        [M:CSR1]RTNDATDEB = gdat$(01,month([M:CSR1]RTNDATDEB),year([M:CSR1]RTNDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I

[M:CSR1]CURD=GSYSCUR
If [M:CSR1]CURS=""  [M:CSR1]CURS=GSYSCUR : Endif
# retour normal oui
If !find([M:CSR1]RTNTYPNOR,1,2) : [M:CSR1]RTNTYPNOR= 2 : Endif
# retour prêt oui
If !find([M:CSR1]RTNTYPLND,1,2) : [M:CSR1]RTNTYPLND= 2 : Endif
# retour sous-traitance oui
If !find([M:CSR1]RTNTYPSCO,1,2) : [M:CSR1]RTNTYPSCO= 2 : Endif
# retour attente d'avoir oui
If !find([M:CSR1]RTNTYPNCN,1,2) : [M:CSR1]RTNTYPNCN= 2 : Endif
# retour avoir effectué oui
If !find([M:CSR1]RTNTYPCNO,1,2) : [M:CSR1]RTNTYPCNO= 2 : Endif

# retour normal oui
If !find([M:CCSR]RTNTYPNOR,1,2) : [M:CCSR]RTNTYPNOR= 2 : Endif
# retour prêt oui
If !find([M:CCSR]RTNTYPLND,1,2) : [M:CCSR]RTNTYPLND= 2 : Endif
# retour sous-traitance oui
If !find([M:CCSR]RTNTYPSCO,1,2) : [M:CCSR]RTNTYPSCO= 2 : Endif
# retour attente d'avoir oui
If !find([M:CCSR]RTNTYPNCN,1,2) : [M:CCSR]RTNTYPNCN= 2 : Endif
# retour avoir effectué oui
If !find([M:CCSR]RTNTYPCNO,1,2) : [M:CCSR]RTNTYPCNO= 2 : Endif

# tri par numéro ou par date
If !find([M:CCSR]TRI,1,2)       : [M:CCSR]TRI = 1   : Endif

#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
# Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
#[M:CSR1]RTNDATDEB=WDATDEB
If [M:CSR1]RTNDATDEB = [0/0/0] Then
  [M:CSR1]RTNDATDEB=WDATDEB
Endif
# Issue Issue X3-15598 - 2017-02-23 by FGR : END
[M:CSR1]RTNDATFIN=WDATFIN
#----- Copie du masque 1 (CSR1) vers l'écran critères (CCSR) -----#
Gosub CRITENT From =PROGCNS
Return
############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCSR]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCSR]ITMREF
            Diszo [M:CCSR]STOFCY
            Diszo [M:CCSR]CPY
        Endif
        If dim([M:CCSR]TSICOD) > 0
          For I = 0 To dim([M:CCSR]TSICOD)-1
            Diszo [M:CCSR]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients
    If find(GNAVIG(GPILNAV-1),"GESBPC")
        Diszo [M:CCSR]BPCNUM
        If dim([M:CCSR]TSCCOD) > 0
          For I = 0 To dim([M:CCSR]TSCCOD)-1
            Diszo [M:CCSR]TSCCOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCSR]PJTDEB
      Diszo [M:CCSR]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5), WMNTHT, WMNTTTC, WARRONDI, WARRONDIS, WARRONDID
Local   Integer  SPSTAT
Local   Integer  WRET
Local   Char     WDEVISE

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CSR1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CSR1]ITMREF
        Diszo [M:CSR1]STOFCY
        Diszo [M:CSR1]CPY
    Endif
    #acces depuis clients
    If find(GNAVIG(GPILNAV-1),"GESBPC")
        Diszo [M:CSR1]BPCNUM
    Endif

    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CSR1]PJTDEB
      Diszo [M:CSR1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSR1"
    Gosub LECTURE From CUSSEALIB
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [SRD] With [SRH]SRH0=[SRD]SRHNUM, [ITM]ITM0=[SRD]ITMREF, [BPC]BPC0=[SRH]BPCORD
&          As [LNK]

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSR]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILF) Order By Key SRD0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILF)
&                    Order By Key CLE=[F:SRH]RTNDAT;[F:SRD]SRHNUM;[F:SRD]SRDLIN :# 69747
#&                    Order By Key CLE=[F:SRH]RTNDAT;[F:SRD]SRHNUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSR]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILF) Order By Key SRD0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFILF)
&                    Order By [F:SRH]RTNDAT Desc ;[F:SRD]SRHNUM Desc ;[F:SRD]SRDLIN Desc :# 69747
#&                    Order By [F:SRH]RTNDAT Desc ;[F:SRD]SRHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSR2] : Endif

#-- lecture
$BOUCLE
For [LNK]

# Filtre sur la société
  If [M:CSR1]CPY <> ""
      If [F:FCY]FCY <> [F:SRH]STOFCY Then
         Read [FCY] FCY0 = [F:SRH]STOFCY
         If fstat  Raz [F:FCY] : Endif
      Endif
      If [F:FCY]LEGCPY <> [M:CSR1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSR2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:SRD]SRHNUM=FINNUM and [F:SRD]SRDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:SRH]SRHNUM
         DEBDAT = [F:SRH]RTNDAT
         DEBLIN = [F:SRD]SRDLIN :# 69747
     Endif
     FINNUM = [F:SRH]SRHNUM
     FINDAT = [F:SRH]RTNDAT
     FINLIN = [F:SRD]SRDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:SRD]SRHNUM=DEBNUM and [F:SRD]SRDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:SRH]SRHNUM
         FINDAT = [F:SRH]RTNDAT
         FINLIN = [F:SRD]SRDLIN :# 69747
     Endif
     DEBNUM = [F:SRH]SRHNUM
     DEBDAT = [F:SRH]RTNDAT
     DEBLIN = [F:SRD]SRDLIN :# 69747
  Endif

  nolign = NOL+1
  [M:CSR2]=[F:SRH] : # trans classe sur SRETURN
  [M:CSR2]=[F:SRD] : # trans classe sur SRETURND
  # Retour de prêt
  If !find([M:CSR2]LNDRTN(nolign-1),1,2) : [M:CSR2]LNDRTN(nolign-1)= 1 : Endif
  # Retour de sous-traitance
  If !find([M:CSR2]SCORTN(nolign-1),1,2) : [M:CSR2]SCORTN(nolign-1)= 1 : Endif
  # Avoir de Retour
  If !find([M:CSR2]RTNCNOFLG(nolign-1),1,2) : [M:CSR2]RTNCNOFLG(nolign-1)= 1 : Endif
  # Commande réactivée
  If !find([M:CSR2]ORDUPD(nolign-1),1,2) : [M:CSR2]ORDUPD(nolign-1)= 1 : Endif
  # Déduction facture
  If !find([M:CSR2]RTNINVUPD(nolign-1),1,2) : [M:CSR2]RTNINVUPD(nolign-1)= 1 : Endif
  # Adresse de livraison
  If [F:SRH]BPAADD<>"" Then
     Read [BPA]BPA0=1;[F:SRH]BPCORD;[F:SRH]BPAADD
     If !fstat Then
        [M:CSR2]BPADES(nolign-1)=[BPA]BPADES
     Endif
  Endif
  # Récupération du numéro de commande dans la livraison
  If [F:SRD]SDHNUM <> "" Then
     Filter [SDD] Where SDHNUM=[F:SRD]SDHNUM and SOHNUM<>"" and SDDLIN=[F:SRD]SDDLIN
     For [SDD]
        [M:CSR2]SOHNUM(nolign-1) = [F:SDD]SOHNUM
        [M:CSR2]SOPLIN(nolign-1) = [F:SDD]SOPLIN
        [M:CSR2]SOQSEQ(nolign-1) = [F:SDD]SOQSEQ
     Next
     Filter [SDD]
  Endif
  Raz WDEVISE
  Raz WARRONDI, WARRONDIS, WARRONDID
  Raz WMNTHT, WMNTTTC
 # Lecture de la devise pour récupérer le format
  If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
  If WDEVISE <> [F:SRD]CUR
     Read [TCU] TCU0 = [F:SRD]CUR
     If fstat Raz [F:TCU] : Endif
     WDEVISE = [F:TCU]CUR
     WARRONDI = [F:TCU]CURRND
  Endif
# Lecture de la devise société pour récupérer le format
  If WDEVISE <> [M:CSR1]CURS
     Read [F:TCU]TCU0 = [M:CSR1]CURS
     If fstat Raz [F:TCU] : Endif
     WARRONDIS = [F:TCU]CURRND
  Endif
# Lecture de la devise dossier pour récupérer le format
  If WDEVISE <> [M:CSR1]CURD
     Read [F:TCU]TCU0 = [M:CSR1]CURD
     If fstat Raz [F:TCU] : Endif
     WARRONDID = [F:TCU]CURRND
  Endif
  WMNTHT=[F:SRD]NETPRINOT*[F:SRD]QTY # Montant ligne HT
  WMNTTTC=[F:SRD]NETPRIATI*[F:SRD]QTY # Montant ligne TTC
  [M:CSR2]RETNOT(nolign-1) = arr(WMNTHT, WARRONDI)
  [M:CSR2]RETATI(nolign-1) = arr(WMNTTTC, WARRONDI)
  [M:CSR2]NETPRINOTL(nolign-1) = [F:SRD]NETPRINOT
  [M:CSR2]NETPRIATIL(nolign-1) = [F:SRD]NETPRIATI
  [M:CSR2]PRIORDL(nolign-1) = arr([F:SRD]PRIORD, WARRONDIS)
  [M:CSR2]RETNOTLOC(nolign-1) = arr(WMNTHT, WARRONDI)
  [M:CSR2]RETATILOC(nolign-1) = arr(WMNTTTC, WARRONDI)
  [M:CSR2]NETPRINOTD(nolign-1) = [F:SRD]NETPRINOT
  [M:CSR2]NETPRIATID(nolign-1) = [F:SRD]NETPRIATI
  [M:CSR2]PRIORDD(nolign-1) = [F:SRD]PRIORD
  [M:CSR2]RETNOTDOS(nolign-1) = arr(WMNTHT, WARRONDI)
  [M:CSR2]RETATIDOS(nolign-1) = arr(WMNTTTC, WARRONDI)


  # Numéro de livraison
  # Si la livraison est renseignée, on va chercher certains renseignements
  # dans la livraison, sinon dans le client livré
  If [F:SRD]SDHNUM<>"" Then
     Filter [SDH] Where SDHNUM=[F:SRD]SDHNUM
     For [SDH]
        [M:CSR2]VACBPR(nolign-1)=[F:SDH]VACBPR # régime
        [M:CSR2]PTE(nolign-1)=[F:SDH]PTE       # condition paiement
        [M:CSR2]DEP(nolign-1)=[F:SDH]DEP       # escompte
        [M:CSR2]BPCPYR(nolign-1)=[F:SDH]BPCPYR # tiers payeur
        [M:CSR2]BPCGRU(nolign-1)=[F:SDH]BPCGRU # client groupe
        # Alimentation en devise société
        If [F:SRD]CUR<>[M:CSR1]CURS Then
   # Alimentation des prix en devise société
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURS,[M:CSR1]CURS,[F:SDH]CHGTYP,
&          datesyst,[F:SRD]NETPRINOT,WMNTDES(0),WRET) From TRTDEV
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURS,[M:CSR1]CURS,[F:SDH]CHGTYP,
&          datesyst,[F:SRD]NETPRIATI,WMNTDES(1),WRET) From TRTDEV
   # Alimentation du prix ordre en devise société (déjà en devise société)
#          Call CONVERT2([F:SRD]CUR,[M:CSR1]CURS,[M:CSR1]CURS,[F:SDH]CHGTYP,
#&          [F:SRD]RTNDAT,[F:SRD]PRIORD,WMNTDES(2),WRET) From TRTDEV
   # Alimentation des montants en devise société
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURS,[M:CSR1]CURS,[F:SDH]CHGTYP,
&          datesyst,WMNTHT,WMNTDES(3),WRET) From TRTDEV
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURS,[M:CSR1]CURS,[F:SDH]CHGTYP,
&          datesyst,WMNTTTC,WMNTDES(4),WRET) From TRTDEV

           [M:CSR2]NETPRINOTL(nolign-1) = arr(WMNTDES(0),WARRONDIS)
           [M:CSR2]NETPRIATIL(nolign-1) = arr(WMNTDES(1),WARRONDIS)
#           [M:CSR2]PRIORDL(nolign-1) = arr(WMNTDES(2),WARRONDIS)
           [M:CSR2]RETNOTLOC(nolign-1) = arr(WMNTDES(3),WARRONDIS)
           [M:CSR2]RETATILOC(nolign-1) = arr(WMNTDES(4),WARRONDIS)
        Endif
        # Alimentation en devise dossier
        If [F:SRD]CUR<>[M:CSR1]CURD Then

   # Alimentation des prix en devise du dossier
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURD,[M:CSR1]CURD,[F:SDH]CHGTYP,
&          datesyst,[F:SRD]NETPRINOT,WMNTDES(0),WRET) From TRTDEV
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURD,[M:CSR1]CURD,[F:SDH]CHGTYP,
&          datesyst,[F:SRD]NETPRIATI,WMNTDES(1),WRET) From TRTDEV
   # Alimentation du prix ordre de devise société en devise dossier
           Call CONVERT2([M:CSR1]CURS,[M:CSR1]CURD,[M:CSR1]CURD,[F:SDH]CHGTYP,
&          datesyst,[F:SRD]PRIORD,WMNTDES(2),WRET) From TRTDEV
   # Alimentation des montants en devise société
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURD,[M:CSR1]CURD,[F:SDH]CHGTYP,
&          datesyst,WMNTHT,WMNTDES(3),WRET) From TRTDEV
           Call CONVERT2([F:SRD]CUR,[M:CSR1]CURD,[M:CSR1]CURD,[F:SDH]CHGTYP,
&          datesyst,WMNTTTC,WMNTDES(4),WRET) From TRTDEV

           [M:CSR2]NETPRINOTD(nolign-1) = arr(WMNTDES(0),WARRONDID)
           [M:CSR2]NETPRIATID(nolign-1) = arr(WMNTDES(1),WARRONDID)
           [M:CSR2]PRIORDD(nolign-1) = arr(WMNTDES(2),WARRONDID)
           [M:CSR2]RETNOTDOS(nolign-1) = arr(WMNTDES(3),WARRONDID)
           [M:CSR2]RETATIDOS(nolign-1) = arr(WMNTDES(4),WARRONDID)
         Endif

     Next
     Filter [SDH]
     Filter [SDD] Where SDHNUM=[F:SRD]SDHNUM and SDDLIN=[F:SRD]SDDLIN
     For [SDD]
        #MAE, le 09/03/09, bg 53286
        If dim([M:CSR2]REP1)>=nolign
         [M:CSR2]REP1(nolign-1)=[F:SDD]REP1 # représentant 1
        Endif
        If dim([M:CSR2]REP2)>=nolign
         [M:CSR2]REP2(nolign-1)=[F:SDD]REP2 # représentant 2
        Endif
     Next
     Filter [SDD]

  Else
     Filter [BPC] Where BPCNUM=[F:SRH]BPCORD
     For [BPC]
         [M:CSR2]VACBPR(nolign-1)=[F:BPC]VACBPR # régime
         [M:CSR2]PTE(nolign-1)=[F:BPC]PTE       # condition paiement
         [M:CSR2]DEP(nolign-1)=[F:BPC]DEP       # escompte
         [M:CSR2]BPCPYR(nolign-1)=[F:BPC]BPCPYR # tiers payeur
         [M:CSR2]BPCGRU(nolign-1)=[F:BPC]BPCGRU # client groupe
         If [F:BPC]REP(0) <> "" Then
            [M:CSR2]REP1(nolign-1)=[F:BPC]REP(0) # représentant 1
         Endif
         If [F:BPC]REP(1) <> "" Then
            [M:CSR2]REP2(nolign-1)=[F:BPC]REP(1) # représentant 2
         Endif
     Next
     Filter [BPC]
  Endif

  $SUIV
  Next
Filter [LNK]
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFILF = "1=1"

# Site de retour
If [M:CSR1]STOFCY <> ""
   WFIL += "&[F:SRH]STOFCY=[M:CSR1]STOFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:SRH]STOFCY,GUSRFCY(1..GNBAUZ))"
Endif
# Numéro de client
If [M:CSR1]BPCNUM <> ""
   WFIL += "&[F:SRH]BPCORD =[M:CSR1]BPCNUM"
Endif
# Numéro de pièce de retour
If [M:CCSR]RTNNUMDEB <> ""
   WFIL += "&[F:SRH]SRHNUM>=[M:CCSR]RTNNUMDEB"
Endif
If [M:CCSR]RTNNUMFIN <> ""
   WFIL += "&[F:SRH]SRHNUM<=[M:CCSR]RTNNUMFIN"
Endif
# Date de retour
If [M:CCSR]RTNDATDEB <> [0/0/0]
   WFIL += "&[F:SRH]RTNDAT>=[M:CCSR]RTNDATDEB"
Endif
If [M:CCSR]RTNDATFIN <> [0/0/0]
   WFIL += "&[F:SRH]RTNDAT<=[M:CCSR]RTNDATFIN"
Endif
# Article
If [M:CSR1]ITMREF <> ""
   WFIL += "&[F:SRD]ITMREF =[M:CSR1]ITMREF"
Endif
# type de retour : normal, prêt, sous-traitance
If [M:CSR1]RTNTYPNOR = 2 Then         # Normal = Oui
   If [M:CSR1]RTNTYPLND = 2 Then        # Prêt = Oui
      If [M:CSR1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
                                              # Pas de filtre supplémentaire
      Else                                # Sous-traitance = Non
         WFIL += "&[F:SRH]SCORTN<>2"
      Endif
   Else                                 # Prêt = Non
      If [M:CSR1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL += "&[F:SRH]LNDRTN<>2"
      Else                                # Sous-traitance = Non
         WFIL += "&[F:SRH]LNDRTN<>2&[F:SRH]SCORTN<>2"
      Endif
   Endif
Else                                  # Normal = Non
     If [M:CSR1]RTNTYPLND = 2 Then      # Prêt = Oui
      If [M:CSR1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL += "&([F:SRH]LNDRTN=2|[F:SRH]SCORTN=2)"
      Else                                # Sous-traitance = Non
         WFIL += "&[F:SRH]LNDRTN=2"
      Endif
   Else                                 # Prêt = Non
      If [M:CSR1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL += "&[F:SRH]SCORTN=2"
      Else                                # Sous-traitance = Non
         WFIL += "&1=2"
      Endif
   Endif
Endif

#--CPO 75115 Prise en compte du "Type retour"
#---Retours normaux
If [M:CSR1]RTNTYPNOR=2
	If [M:CSR1]SRHTYPNOR<>"" : WFIL2 += "&(([F:SRH]SRHCAT=1 & [F:SRH]SRHTYP=[M:CSR1]SRHTYPNOR)|[F:SRH]SRHCAT<>1)" : Endif
Endif
#---Retours de prêt
If [M:CSR1]RTNTYPLND=2
	If [M:CSR1]SRHTYPLND<>"" : WFIL2 += "&(([F:SRH]SRHCAT=2 & [F:SRH]SRHTYP=[M:CSR1]SRHTYPLND)|[F:SRH]SRHCAT<>2)" : Endif
Endif
#---Retours pour sous-traitance
If [M:CSR1]RTNTYPSCO=2
	If [M:CSR1]SRHTYPSCO<>"" : WFIL2 += "&(([F:SRH]SRHCAT=3 & [F:SRH]SRHTYP=[M:CSR1]SRHTYPSCO)|[F:SRH]SRHCAT<>3)" : Endif
Endif
#--/CPO

# Avoir effectué
# Prise en compte des Avoir effectué
# --> Si 1 (Non) On exclut les Avoir effectué
If [M:CSR1]RTNTYPCNO = 1 Then
    #WFIL += "&[F:SRD]RTNCNOFLG <> 2"                                                    # FGR 05/03/2015 : X3SUIVI105941
    WFIL += "& not(([F:SRD]RTNCNOFLG<>2)|([F:SRD]RTNCNOFLG=2&SIHNUM<>''))"               # FGR 05/03/2015 : X3SUIVI105941
Endif
# Prise en compte des attente d'avoir
# --> Si 1 (Non) On prend les Avoir effectué
If [M:CSR1]RTNTYPNCN = 1 Then
    #WFIL += "&[F:SRD]RTNCNOFLG = 2"                                                     # FGR 05/03/2015 : X3SUIVI105941
    WFIL += "& not ([F:SRD]RTNCNOFLG = 2 and SIHNUM = '')"                               # FGR 05/03/2015 : X3SUIVI105941
Endif


# SUR L'ARTICLE ITMMASTER
If dim([M:CCSR]TSICOD) > 0
  For I = 0 To dim([M:CCSR]TSICOD)-1
    If [M:CCSR]TSICOD(I) <> ""
      If len(WFIL) > 200
        WFIL1 += "&[F:ITM]TSICOD("+num$(I)+")='"+[M:CCSR]TSICOD(I)+"'"
      Else
        WFIL += "&[F:ITM]TSICOD("+num$(I)+")='"+[M:CCSR]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif

# SUR LE CLIENT BPCUSTOMER
If dim([M:CCSR]TSCCOD) > 0
  For I = 0 To dim([M:CCSR]TSCCOD)-1
    If [M:CCSR]TSCCOD(I) <> ""
      If len(WFIL) > 200
        WFIL1 += "&[F:BPC]TSCCOD("+num$(I)+")='"+[M:CCSR]TSCCOD(I)+"'"
      Else
        WFIL += "&[F:BPC]TSCCOD("+num$(I)+")='"+[M:CCSR]TSCCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
## 71065 : PJT
#If [M:CSR1]PJTDEB <> ""
#   WFIL1 += "&[F:SRD]PJT>=[M:CSR1]PJTDEB"
#Endif
#If [M:CSR1]PJTFIN <> ""
#   WFIL1 += "&[F:SRD]PJT<=[M:CSR1]PJTFIN"
#Endif
## 71065 : PJT
If dim([M:CSR1]PJTDSPALL) >= 0 and [M:CSR1]PJTDSPALL = [V]CST_AYES and [M:CSR1]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CSR1]PJTDEB, SPJT, SBUDGET, STASK)
  WFIL1 += "&pat([F:SRD]PJT,'" + SPJT + "*')<>0"
Else
  If [M:CSR1]PJTDEB <> ""
     WFIL1 += "&[F:SRD]PJT>=[M:CSR1]PJTDEB"
  Endif
  If [M:CSR1]PJTFIN <> ""
     WFIL1 += "&[F:SRD]PJT<=[M:CSR1]PJTFIN"
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSR]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SRH]SRHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:SRH]RTNDAT>DEBDAT | ([F:SRH]RTNDAT=DEBDAT & [F:SRH]SRHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSR]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:SRH]SRHNUM>FINNUM"
           WFIL += "&[F:SRH]SRHNUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:SRH]RTNDAT>FINDAT | ([F:SRH]RTNDAT=FINDAT & [F:SRH]SRHNUM>FINNUM))"
           WFIL += "&([F:SRH]RTNDAT>FINDAT | ([F:SRH]RTNDAT=FINDAT & [F:SRH]SRHNUM>=FINNUM))" :#69747
     Endcase
   When -2 : # retour
     Case [M:CCSR]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:SRH]SRHNUM<DEBNUM"
           WFIL += "&[F:SRH]SRHNUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:SRH]RTNDAT<DEBDAT | ([F:SRH]RTNDAT=DEBDAT & [F:SRH]SRHNUM<DEBNUM))"
           WFIL += "&([F:SRH]RTNDAT<DEBDAT | ([F:SRH]RTNDAT=DEBDAT & [F:SRH]SRHNUM<=DEBNUM))" :# 69747
     Endcase
Endcase

# Formule supplémentaire
If [M:CCSR]SELFOR <> "" Then
  Read [TFO]TFO0=34;[M:CCSR]SELFOR  # 34 = "Sélection ventes" du chapitre 213
  If fstat = 0
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return
#------------------------------------#
# Avant/Après zone  Bouton commande  #
#------------------------------------#
$AB6_NBLIG
Local Char    WOBJET(GLONAOB)
If [M:CSR2]SOPLIN(nolign-1) = [M:CSR2]SOQSEQ(nolign-1)
    WOBJET= "SOH"
Else
    WOBJET= "SOR"
Endif
Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT
Return
