If VALEUR = 1
  Raz [M]SRHTYPNOR : Diszo [M]SRHTYPNOR
Else
  Actzo [M]SRHTYPNOR
Endif
Affzo [M]SRHTYPNOR : Affzo [M]ZSRHTYPNOR

End
#-------------------------------------------------------------------------------------
Subprog AM_RTNTYPLND(VALEUR)
