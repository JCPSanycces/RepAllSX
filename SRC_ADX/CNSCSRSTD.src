If VALEUR = 1
  Raz [M]SRHTYPLND : Diszo [M]SRHTYPLND
Else
  Actzo [M]SRHTYPLND
Endif
Affzo [M]SRHTYPLND : Affzo [M]ZSRHTYPLND

End
