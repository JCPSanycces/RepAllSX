#############################################################
##     Etiquettes masques CONSCSR1 & CONSCSR2 & CRITCSR    ##
#############################################################
#----------------------#
# Avant zone  société  #
#----------------------#
Subprog AV_CPY(VALEUR)
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, STOFCY : Endif
End

#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Subprog C_CPY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]STOFCY = ""
  [M]CURS = GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
End

#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Affzo CURS, ZCPY : # Utilisé par 2 écrans on ne précise pas la classe
Raz [M]STOFCY, [M]ZSTOFCY
Affzo STOFCY, ZSTOFCY : # Utilisé par 2 écrans on ne précise pas la classe
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

#------------------------------------------------#
# Chargement de la devise
#------------------------------------------------#
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CURS = GLOCALDEV
Elsif [M]CPY = ""
    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR
If VALEUR <> ""
  Affzo CURS, CPY, ZCPY : # Utilisé par 2 ecrans
Endif
End
# 71065 : PJT
#-----------------------------------#
# Après modif du code affaire début #
#-----------------------------------#
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_RTNDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]RTNDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]RTNDATFIN=WDATE : Affzo RTNDATFIN
  Endif
Elsif VALEUR>[M]RTNDATFIN
  [M]RTNDATFIN=VALEUR
Endif
End

#############################################################
# Après modification de la date fin                         #
#############################################################
Subprog AM_RTNDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]RTNDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RTNDATDEB=WDATE : Affzo RTNDATDEB
Endif
End
#############################################################
##     Etiquettes masques  CRITCSR                         ##
#############################################################
#############################################################
#      Controle du numéro de retour   fin                   #
#############################################################
Subprog C_RTNNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]RTNNUMDEB : mkstat = 1 : End : Endif
End
######################################################################################

#----------------------------#
# Initialisation  bouton     #
#----------------------------#
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7

If [M:CSR2]NBLIG<>0
   If clalev([M:SRH1])=0
      # Même message, mais bouton différent qui pointe sur un objet différent (cf écran CONSCRN2)
      If [M:CSR2]LNDRTN = 2 Then  # Retour de prêt
         GBOUT2=mess(192,198,1)-[M:CSR2]SRHNUM(nolign-1)   # Retour
      Elsif [M:CSR2]SCORTN = 2 Then  # Retour de sous-traitance
         GBOUT3=mess(192,198,1)-[M:CSR2]SRHNUM(nolign-1)   # Retour
      Else
         GBOUT1=mess(192,198,1)-[M:CSR2]SRHNUM(nolign-1)   # Retour
      Endif

      If [M:CSR2]RTNCNOFLG(nolign-1) = 2 and [M:CSR2]SIHNUM(nolign-1)<>"" Then
         GBOUT4=mess(225,191,1)-[M:CSR2]SIHNUM(nolign-1) # Avoir sur retour
      Endif
      If [M:CSR2]SDHNUM(nolign-1)<>"" Then
         GBOUT5=mess(54,198,1)-[M:CSR2]SDHNUM(nolign-1) # Livraison
      Endif
      If [M:CSR2]SOHNUM(nolign-1) <> ""  # Commande
         If [M:CSR2]SOPLIN(nolign-1) = [M:CSR2]SOQSEQ(nolign-1)
            GBOUT6 = mess(1,306,1)-[M:CSR2]SOHNUM(nolign-1)
         Else
            GBOUT6 = mess(92,198,1)-[M:CSR2]SOHNUM(nolign-1)
         Endif
      Endif
      If [M:CSR2]PNHNUM(nolign-1)<>"" Then
         GBOUT7=mess(8,701,1)-[M:CSR2]PNHNUM(nolign-1) # Retour fournisseur
      Endif

    Endif
Endif
End


