#<AdxTL>@(#)5.0.0.0 $Revision$
Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If [F:GCM]LED(VALEUR-1)=""
 GMESSAGE = mess(201,111,1) : # Référentiel incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLPRVNUM = 2 : mkstat = 1 : End : Endif
End

Subprog AS_HON(VALEUR)
Variable Integer VALEUR
If [M]ALLHON = 2 : mkstat = 1 : End : Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,year(datesyst)-1) : # Année civile
Endif
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(31,12,year([M]STRDAT))
Endif
End

Subprog AS_DATPCE(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M]ENDDAT
Endif
End




