# Class AQCCONTACT


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER" : Gosub AREAD_AFTER
      When "CONTACTOP"   : Gosub CONTACTOP
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##########################################################################################################

$AREAD_AFTER

Local File AQCBPR [AQCBPR]
Read [AQCBPR]BPR0=this.BPANUM  # Aparent ????? for BPR .. then set BPR = 'AAAAA'.
If !fstat
   this.BPANUM="TEST " +  this.BPANUM   #[F:AQCBPR]BPRNAM(0)
   #If this.APARENT.COD<>null
   ##### this.APARENT.COD.COD="AAAAAA" modify parent property test ...........
Endif
LogicClose File [AQCBPR]
Return


Return
#######################################################################
$CONTACTOP

#Call OUVRE_TRACE("CONTACT_OP") From LECFIC
#Call ECR_TRACE("CONTACT_OP in CSTD hit",0) From GESECRAN
#Call FERME_TRACE From LECFIC
# Display the Trace File
#Call LEC_TRACE From LECFIC

Infbox "CONTACTOP3 infbox in CSTD"
Call OUVRE_TRACE("CONTACTOP3 in CSTD") From LECFIC
#Call ECR_TRACE("CONTACTOP4 in CSTD",0) From GESECRAN
Call FERME_TRACE From LECFIC
# display the log file
GTRACE = "CONTACTOP3 in CSTD"
Call LEC_TRACE From LECFIC




Local Instance  AQCCONTACT Using C_AQCCONTACT
AQCCONTACT = NewInstance C_AQCCONTACT AllocGroup null

[L]ASTATUS = fmet AQCCONTACT.AREAD(BPATYP,mid$(BPANUM,6,7),CCNCRM)
#            WOK= fmet this.ASETATTRIBUTE("TEXTDES","$isDisabled","true")
#            WOK= fmet this.ASETATTRIBUTE("CUR","$isDisabled","true")
AQCCONTACT.CCNCRM="111111111111122"
[L]ASTATUS = fmet this.ASETERROR("","Record operation was fired: " + AQCCONTACT.CCNCRM,[V]CST_AOK)
Infbox "Fired ...."
## [L]ASTATUS=fmet this.ADELETEERROR("") ######################
FreeGroup AQCCONTACT


Return
#######################################################################

