#<AdxTL>@(#)0.0.0.0 $Revision$
$DISPLAY_HIDE

  Call HIDE_ACTIVITYFIELDS From WOHRPEOHIDE
  Call SHOW_LEGACTCALLS From WOHRPEOSHOW

#reshow all fields not protected by localization activity codes
  Local Char WSIGN(1)
  WSIGN=""
  Gosub RESHOW_UNPROTECTED_FIELDS

  WSIGN="-"
  Gosub SPECIFIC_SOUTH_AFRICA
  Gosub SPECIFIC_AFRICA
  Gosub SPECIFIC_ZAMBIA
  Gosub SPECIFIC_FRANCE
  Gosub SPESIFIC_KMIEA
  Gosub SPECIFIC_UK
  Gosub SPESIFIC_ALL
Return

$RESHOW_UNPROTECTED_FIELDS
#  Chgfmt [M:HRPEO1]YEASTRDAT With WSIGN+"D:"+GFMDAT4
#  Chgfmt [M:HRPEO1]YEAENDDAT With WSIGN+"D:"+GFMDAT4
#  Chgfmt [M:HRPEO1]TAXSTRDAT With WSIGN+"D:"+GFMDAT4
#  Chgfmt [M:HRPEO1]TAXENDDAT With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:HRPEO1]STR4 With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:HRPEO1]END4 With WSIGN+"D:"+GFMDAT4
Return



$SPECIFIC_SOUTH_AFRICA
#These fields can be hidden with Activity code KZA on Mask [M:HRPEO1] as well.

#If GCURLEG <> ""
