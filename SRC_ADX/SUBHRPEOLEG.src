#  Endif
#Endif
Return

$SPECIFIC_ZAMBIA
Return

$SPECIFIC_FRANCE
Return

$SPESIFIC_KMIEA
Return

$SPECIFIC_UK
Return

$SPESIFIC_ALL
#HIDE
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) & !func DIVPAYE.IS_KPO_LEG(GCURLEG)
  Chgfmt [M:HRPEO1]STR4 With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:HRPEO1]END4 With WSIGN+"D:"+GFMDAT4
#  Chgfmt [M:HRPEO1]TAXSTRDAT With WSIGN+"D:"+GFMDAT4
#  Chgfmt [M:HRPEO1]TAXENDDAT With WSIGN+"D:"+GFMDAT4
