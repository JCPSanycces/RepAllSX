#<AdxTL>@(#)10.0.0.0 $Revision$
#*********************************************************************#
# FUNLOGINWAS : W-A-S         VP/OL - Septembre 2009                  #
#*********************************************************************#
# Gestion du login                                                    #
#*********************************************************************#
#CHECK UNUSED_BEGIN
Local Char     AXPARCOD(30)(1..10)
Local Char     AXPARVAL(30)(1..10)
Local Char     AXUSERCODE(30)
Local    Char     AXPWD(30)
Local Char     AXUSERPROF(30)
Local Char     AXLOGCOD(30)(1..10)
Local Char     AXLOGVAL(30)(1..10)
Local Integer  NBITM
Local Decimal  TOTPRICE
Local Char     AX3FLDR(30)(1..10)
Local Char     AX3LANG(30)(1..10)
Local Char     AX3USER(30)(1..10)
Local Char     AX3PWD(30)(1..10)
Local Char     LOGINCUSTOM(30)
Local Char     AX3SOL(30)(1..10)
Local Char     LOGINUSER(30)
AXUSERCODE="CCL"
AXPWD=""

LOGINCUSTOM = "NO"
LOGINUSER="YES"


Call AUSLOGIN(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,
&       LOGINCUSTOM,LOGINUSER,NBITM,TOTPRICE)

End
#CHECK UNUSED_END

################################################################################################
Subprog AUSLOGIN(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,
&       LOGINCUSTOM,LOGINUSER,NBITM,TOTPRICE)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Variable Char     AXUSERCODE()
Value    Char     AXPWD()
Variable Char     AXUSERPROF()
Variable Char     AXLOGCOD()()
Variable Char     AXLOGVAL()()
Variable Char     AX3SOL()()
Variable Char     AX3FLDR()()
Variable Char     AX3LANG()()
Variable Char     AX3USER()()
Variable Char     AX3PWD()()
Variable Char     LOGINCUSTOM()
Variable Char     LOGINUSER()

Variable Integer  NBITM
Variable Decimal  TOTPRICE

If !clalev([F:TBA]) : Local File TBASKET  [TBA] : Endif
#FDB
#LOGINCUSTOM="NO"
#LOGINUSER="YES"
#FDB
Local Integer CONNECT
If LOGINCUSTOM="YES" and LOGINUSER="YES"
 Call AUSLOGINWAS(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,0)
 If CONNECT=0
  Call AUSLOGINX3(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,1)
 Endif
 If CONNECT=1
            Gosub MAJ_BK
 Endif
Elsif LOGINCUSTOM="YES" and LOGINUSER="NO"
 Call AUSLOGINWAS(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,1)
 If CONNECT=1
            Gosub MAJ_BK
 Endif
Elsif LOGINCUSTOM="NO" and LOGINUSER="YES"
  Call AUSLOGINX3(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,1)
  If CONNECT=1
            Gosub MAJ_BK
  Endif
Else
  Call ADDMESSERR(mess(00024,00151,1) -":"-mess(00214,00133,1)   ) From AWEB
  Call ADDMESSERR("(LOGINCUSTOM , LOGINUSER) = ( "+LOGINCUSTOM+" ,"+LOGINUSER+" )") From AWEB

Endif

End

################################################################################################
Subprog AUSLOGINWAS(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,AFFEXIST)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Variable Char     AXUSERCODE()
Value    Char     AXPWD()
Variable Char     AXUSERPROF()
Variable Char     AXLOGCOD()()
Variable Char     AXLOGVAL()()
Variable Char     AX3SOL()()
Variable Char     AX3FLDR()()
Variable Char     AX3LANG()()
Variable Char     AX3USER()()
Variable Char     AX3PWD()()
Variable Integer  CONNECT
Value    Integer  AFFEXIST
CONNECT=1

Local Char MESSA(200)
Local Char TEXTE(200)
Local Char CODUSERX3(GLONAUS)
Local Integer OK
MESSA=mess(00002,00072,1) -mess(00012,07901,1)

If !clalev([F:TAU]) : Local File TAUTILIS [TAU] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif


AXUSERCODE=toupper(vireblc(AXUSERCODE,0))
Read [TAU]TAU0=AXUSERCODE
If fstat or vireblc(AXUSERCODE,0)="" or [F:TAU]ENAFLG<>2
        CONNECT=0
        If AFFEXIST
         Call ADDMESSERR(MESSA-":"-mess(00134,00139,1)   ) From AWEB
        Endif
Else
        If [F:TAU]PWD<>vireblc(AXPWD,0)
            CONNECT=0
            Call ADDMESSERR(MESSA-":"-mess(00025,00100,1) ) From AWEB
        Else
            AXLOGCOD(0)="CUR"
            AXLOGVAL(0)=[F:TAU]CUR
            AXLOGCOD(1)="STOFCY"
            AXLOGVAL(1)=[F:TAU]STOFCY
            AXLOGCOD(2)="SALFCY"
            AXLOGVAL(2)=[F:TAU]SALFCY
            AXLOGCOD(3)="BPRNUM"
            AXLOGVAL(3)=[F:TAU]BPRNUM
            Gosub GET_BPCNAM
            Local Char WSITEXTEND(30) : WSITEXTEND=""
            Local Integer WIDX        : WIDX=find("SITCOD",AXPARCOD)
            If WIDX<>0
             WSITEXTEND=AXPARVAL(WIDX-1)
             OK=0
             Call GET_AXUSERPROF(WSITEXTEND,[F:TAU]CODPRF,AXUSERPROF,OK)
             If OK
              CODUSERX3 = [F:TAU]CODUSR
              Gosub SET_PAR_AX3
              If CODUSERX3 <>""
               AX3USER(0)=CODUSERX3
               Read [AUS]CODUSR=[L]CODUSERX3
               If !fstat
                Local Char MOTPASSE(200) : MOTPASSE="CRYX3:"+[AUS]NEWPAS
                If toupper(left$(MOTPASSE,6))="CRYX3:"
                 MOTPASSE = right$(MOTPASSE,7)
                 Call VARPSE(MOTPASSE) From GESUSER
                Endif
                AX3PWD(0)=vireblc(MOTPASSE,0)
               Else
                CONNECT=0
                Call ADDMESSERR(MESSA-":"-mess(00141,00100,1) ) From AWEB
               Endif
              Endif
              If CONNECT=1
               Call LECTEXTRA(TEXTE,"TAUTILIS","INTUSR",[F:TAU]USR,"") From ATEXTRA
               Call ADDMESSINF(MESSA-":"-AXUSERCODE-TEXTE) From AWEB
              Endif
             Else
              CONNECT=0
              Call ADDMESSERR(MESSA-":"-mess(00024,00150,1) ) From AWEB
             Endif
            Endif
        Endif
Endif
End

################################################################################################
Subprog AUSLOGINX3(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD,CONNECT,AFFEXIST)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Variable Char     AXUSERCODE()
Value    Char     AXPWD()
Variable Char     AXUSERPROF()
Variable Char     AXLOGCOD()()
Variable Char     AXLOGVAL()()
Variable Char     AX3SOL()()
Variable Char     AX3FLDR()()
Variable Char     AX3LANG()()
Variable Char     AX3USER()()
Variable Char     AX3PWD()()
Variable Integer  CONNECT
Value Integer  AFFEXIST
CONNECT=1

Local Char MESSA(200)
Local Char TEXTE(200)
Local Char CODUSERX3(GLONAUS)
Local Integer OK
MESSA=mess(00002,00072,1)  -mess(00001,00998,1)

If !clalev([F:TAU]) : Local File TAUTILIS [TAU] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif


AXUSERCODE=toupper(vireblc(AXUSERCODE,0))
Read [AUS]LOGIN=AXUSERCODE

If fstat or vireblc(AXUSERCODE,0)="" or [F:AUS]ENAFLG<>2 or [AUS]USRCONXTD<>2
        CONNECT=0
        If AFFEXIST
         Call ADDMESSERR(MESSA-":"-mess(00134,00139,1)   ) From AWEB
        Endif
Else
        Local Char WSITEXTEND(30) : WSITEXTEND=""
        Local Integer WIDX        : WIDX=find("SITCOD",AXPARCOD)
        If WIDX<>0
         WSITEXTEND=AXPARVAL(WIDX-1)
         OK=0
         Call USERX3(WSITEXTEND,AXUSERCODE,AXUSERPROF,OK) From SUBAUS
         If OK
          Call CTLPAS(AXPWD, OK) From GESUSER
          If OK=0
           CONNECT=0
           Call ADDMESSERR(MESSA-":"-mess(00025,00100,1) ) From AWEB
          Else
            AXLOGCOD(0)="CUR"
            AXLOGVAL(0)=[F:TAU]CUR
            AXLOGCOD(1)="STOFCY"
            AXLOGVAL(1)=[F:TAU]STOFCY
            AXLOGCOD(2)="SALFCY"
            AXLOGVAL(2)=[F:TAU]SALFCY
            AXLOGCOD(3)="BPRNUM"
            AXLOGVAL(3)=[F:TAU]BPRNUM
            Gosub GET_BPCNAM

            CODUSERX3 = [AUS]USR
            Gosub SET_PAR_AX3
            If CODUSERX3 <>""
             AX3USER(0)=toupper(vireblc(AXUSERCODE,0))
             AX3PWD(0)=vireblc(AXPWD,0)
            Endif
            Call LECTEXTRA(TEXTE,"AUTILIS","INTUSR",CODUSERX3,"") From ATEXTRA
            Call ADDMESSINF(MESSA-":"-CODUSERX3-TEXTE) From AWEB
          Endif
         Else
          CONNECT=0
           Call ADDMESSERR(MESSA-":"-mess(00024,00150,1)) From AWEB
         Endif
        Else
         CONNECT=0
         Call ADDMESSERR(MESSA-":"-mess(00134,00139,1)   ) From AWEB
        Endif
Endif
End

###############
$SET_PAR_AX3

AX3SOL(0)=GINSTID
AX3FLDR(0)= nomap(0)

AX3LANG(0)=GLANGUE
Local Integer IRES
IRES=find("USRLANG",AXPARCOD)
If IRES
 AX3LANG(0)=AXPARVAL(IRES-1)
Endif

Return

############################
$GET_BPCNAM
#FDB
 #          AXLOGCOD(4)="BPCNAM"
#           AXLOGVAL(4)="TOTO"
#FDB

    Read [BPC]BPC0=[F:TAU]BPRNUM
    If !fstat
    AXLOGCOD(4)="BPCNAM"
    AXLOGVAL(4)=[F:BPC]BPCNAM
    Endif
Return
###############
$NEW_BK
    Trbegin [TBA]
        Raz [TBA]
        [F:TBA]NUM=AXUSERCODE
        [F:TBA]USR=AXUSERCODE
        Write [F:TBA]
    Commit
Return

###############
$RD_BK


Local Char ZACT(10)
Local Integer ZLINNUM(100)
# Issue 121827 - 2017-03-09 by MAE
#Local Char ZITMREF(20)(100)
Local Char ZITMREF(GLONITM)(100)
Local Integer ZQTY(100)
Local Decimal ZPRICE(100)
Local Char ZCHECKED(100)
ZACT="READ"
Call MAJ_BK(AXUSERCODE,ZACT,ZLINNUM,ZITMREF,ZQTY,ZPRICE,ZCHECKED,NBITM,TOTPRICE) From FUNTBASWAS

Return

###################
$MAJ_BK
Read [TBA]TBA0=AXUSERCODE
If fstat<>0
 Gosub NEW_BK
Endif
Gosub RD_BK

Return

###################
Subprog GET_AXUSERPROF(FCYCOD,XTDPRF,PRFCOD,OK)
Value Char FCYCOD, XTDPRF
Variable Char PRFCOD
Variable Integer OK
Local Integer I

If clalev([F:AYH])=0 : Local File AYTPRFUSR [AYH] : Endif
OK = 0
If [L]XTDPRF <> ""
 Read [AYH]AYH0=[L]XTDPRF
 If !fstat
  For I=0 To [F:AYH]NBFCY-1
   If [F:AYH]FCYXTDCOD(I)=[L]FCYCOD
    OK = 1
    PRFCOD = [F:AYH]PRFXTDCOD(I)
    Break
   Endif
  Next I
 Endif
 Else
  OK=1
Endif
Close Local File [AYH]
End

