#<AdxTL>@(#)11.0.0.0 $Revision$
#####################################################
# DOSDICWIN Remplissage du dico des fenêtres
#####################################################
$DICWIN
Call ECR_TIME(mess(15,125,1)-mess(82,125,1)) From DOSSUB
# MAJ dictionnaire - Fenêtres
Local File =GDOSREF+".AWINDOW"  [AWI]
Local File =GDOSREF+".AWINPAR"  [AWP]
Local File =GDOSREF+".AWINBRO"  [AWB]
Local File =GDOSREF+".AWINBOUT" [AWT]
Local File =[F:ADS]DOSSIER+".AWINDOW"   [DAWI]
Local File =[F:ADS]DOSSIER+".AWINDOW"   [DAW2]
Local File =[F:ADS]DOSSIER+".AWINDOW"   [DAW3]
Local File =[F:ADS]DOSSIER+".AWINBRO"   [DAWB]
Local File =[F:ADS]DOSSIER+".AWINBRO"   [DWB2]
Local File =[F:ADS]DOSSIER+".AWINPAR"   [DAWP]
Local File =[F:ADS]DOSSIER+".AWINBOUT"  [DAWT]
Local File =[F:ADS]DOSSIER+".ACTIV"     [DACV]
Local File =[F:ADS]DOSSIER+".AOBJET"    [DAOB]
Local File =[F:ADS]DOSSIER+".ACTION"    [DACT]

Local File =GDOSREF+".AMSK"    [AMK]
Local File =GDOSREF+".AMSKZON" [AMZ]
Local File =GDOSREF+".AMSKACT" [AMA]
Local File =GDOSREF+".AMSKPAR" [AMP]
Local File =[F:ADS]DOSSIER+".AMSK"      [DAMK]
Local File =[F:ADS]DOSSIER+".AMSKZON"   [DAMZ]
Local File =[F:ADS]DOSSIER+".AMSKACT"   [DAMA]
Local File =[F:ADS]DOSSIER+".AMSKPAR"   [DAMP]

GNBWIN = 0
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(82,125,1),"") From GESECRAN
Endif

## Effacement anciennes fenêtres

If !GCRE
 Trbegin [DAWI]
  For [DAWI] Where WIN<GXX & left$(WIN,1)<>"W" & OBJ<GXX
   Call SPEC([F:DAWI]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [AWI]AWI0 = [F:DAWI]WIN
    If fstat
     Call EFFACE([F:DAWI]WIN)
    Endif
   Endif
  Next
 Commit
Endif

## Mise à jour

For [AWI] Where WIN<GXX & left$(WIN,1)<>"W" & OBJ<GXX

 FENETRE = [F:AWI]WIN
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(82,125,1),FENETRE) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DAWI]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAWI]AWI0 = FENETRE
  If !fstat
   OLD = 1
   Call SPEC([F:DAWI]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AWI]CODACT,[F:AWI]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    Call EFFACE(FENETRE)

   Elsif NEWREC & !OLD

    RWO = 1
    Raz [F:DAWI]
    [F:DAWI] = [F:AWI]
    [F:DAWI]CREDAT = date$
    [F:DAWI]CREUSR = GUSER
    If dim([F:DAWI]CRETIM)>0 : [F:DAWI]CRETIM = time : Endif
    [F:DAWI]UPDFLG = 1
    GNBWIN += 1
    Gosub ACT_MSK
    Write [DAWI]
    If fstat : Call ERREUR("AWINDOW"-FENETRE,1) From DOSDIC : Endif
    For [AWP]AWP0 Where WIN=FENETRE
     Raz [F:DAWP]
     [F:DAWP] = [F:AWP]
     Write [DAWP]
     If fstat : Call ERREUR("AWINPAR"-FENETRE,1) From DOSDIC : Endif
    Next
    For [AWB]AWB0 Where WIN=FENETRE
     Raz [F:DAWB]
     [F:DAWB] = [F:AWB]
     Gosub ACT_BRO
     Write [DAWB]
     If fstat : Call ERREUR("AWINBRO"-FENETRE,1) From DOSDIC : Endif
    Next
    For [AWT]AWT0 Where WIN=FENETRE
     Raz [F:DAWT]
     [F:DAWT] = [F:AWT]
     Write [DAWT]
     If fstat : Call ERREUR("AWINBOUT"-FENETRE,1) From DOSDIC : Endif
    Next
    Gosub MSKWIN

   Elsif NEWREC & OLD

    ## Préservation des zones attribuées à l'utilisateur
    [F:DAW3] = [F:DAWI]
    # Issue 96650 - 2014-02-17 by VPO : : on prend les masques du patch puis on reprend les SPE
    [F:DAW2] = [F:DAWI]

    Read [AWB]AWB0  = FENETRE
    If fstat
     Raz [F:AWB]
     [F:AWB]WIN = FENETRE
     Write [AWB]
     If fstat : Call ERREUR("AWINBRO"-FENETRE,1) From DOSDIC : Endif
     Read [AWB]AWB0  = FENETRE
    Endif
    Read [DAWB]AWB0 = FENETRE
    If fstat
     Raz [F:DAWB]
     [F:DAWB]WIN = FENETRE
     Write [DAWB]
     If fstat : Call ERREUR("AWINBRO"-FENETRE,1) From DOSDIC : Endif
     Read [DAWB]AWB0 = FENETRE
    Endif
    DIFF = 0

    ## Comparaison de l'en-tête

    If [F:AWI]LIBEL     <> [F:DAWI]LIBEL      : DIFF = 1  : Endif
    If [F:AWI]DES       <> [F:DAWI]DES        : DIFF = 1  : Endif
    If [F:AWI]OBJ       <> [F:DAWI]OBJ        : DIFF = 2  : Endif
    If [F:AWI]TRN       <> [F:DAWI]TRN        : DIFF = 3  : Endif
    If [F:AWI]MDL       <> [F:DAWI]MDL        : DIFF = 4  : Endif
    If [F:AWI]CODACT    <> [F:DAWI]CODACT     : DIFF = 5  : Endif
    If [F:AWI]LIBEL     <> [F:DAWI]LIBEL      : DIFF = 6  : Endif
    If [F:AWI]TYP       <> [F:DAWI]TYP        : DIFF = 7  : Endif
    If [F:AWI]MODULE    <> [F:DAWI]MODULE     : DIFF = 8  : Endif
    If [F:AWI]MSKENT    <> [F:DAWI]MSKENT     : DIFF = 9  : Endif
    If [F:AWI]NBMSK     <> [F:DAWI]NBMSK      : DIFF = 10 : Endif
    If [F:AWI]WINTYP    <> [F:DAWI]WINTYP     : DIFF = 11 : Endif
    If !DIFF : Call TXT([F:AWI]DES,DIFF)  From DOSSUB : Endif

    ## Comparaison des écrans
    ## (on peut en ajouter, pas en supprimer...)

    If !DIFF
     For B=0 To [F:AWI]NBMSK-1
      If !find([F:DAWI]ACTMSK(B),GSPE(1..GNBSPE))
       If [F:AWI]NOMMSK(B)    <> [F:DAWI]NOMMSK(B)     : DIFF = 12 : Endif
       If [F:AWI]INTMSK(B)    <> [F:DAWI]INTMSK(B)     : DIFF = 12 : Endif
       If [F:AWI]INTFOLD(B)   <> [F:DAWI]INTFOLD(B)    : DIFF = 12 : Endif
       If [F:AWI]FLGMSK(B)    <> [F:DAWI]FLGMSK(B)     : DIFF = 12 : Endif
       If [F:AWI]ROWMSK(B)    <> [F:DAWI]ROWMSK(B)     : DIFF = 12 : Endif
       If dim([F:DAWI]ACTMSK)>0
        If [F:AWI]ACTMSK(B)   <> [F:DAWI]ACTMSK(B)     : DIFF = 22 : Endif
       Endif
       If !DIFF : Call TXT([F:AWI]INTMSK(B),DIFF)  From DOSSUB : Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:AWI]ACTMSK(B),ACTIV) From DOSSUB
     Next B
    Endif

    ## Chargement des boutons-menu

    #99690 on lit les anciens boutons SPE
    NBOUT = 0
    NPAR = 0
    For [DAWT]AWT0 Where WIN=FENETRE
     If find([F:DAWT]CODACTBOUT,GSPE(1..GNBSPE))
      NBOUT += 1
      BOUTCOD(NBOUT) = [F:DAWT]CODBOUT
      BOUTNUM(NBOUT) = [F:DAWT]NUM
      BOUTTYP(NBOUT) = [F:DAWT]TYPBOUT
      BOUTACT(NBOUT) = [F:DAWT]ACTBOUT
      BOUTVAL(NBOUT) = [F:DAWT]VALBOUT
      BOUTTXT(NBOUT) = [F:DAWT]TXTBOUT
      BOUTACV(NBOUT) = [F:DAWT]CODACTBOUT
      Call DIFFACT([F:ADS]DOSSIER,[F:DAWT]CODACTBOUT,ACTIV) From DOSSUB
     Endif
    Next

    NEWBOUT = 0
    NEWPAR = 0
    For [AWT]AWT0 Where WIN=FENETRE
     #99690 ssi pas SPE
     If !find([F:AWT]CODBOUT,BOUTCOD(1..NBOUT))
      NEWBOUT += 1
      NBOUTCOD(NEWBOUT) = [F:AWT]CODBOUT
      #NBOUTNUM(NEWBOUT) = [F:AWT]NUM
      NBOUTNUM(NEWBOUT) = NEWBOUT
      NBOUTTYP(NEWBOUT) = [F:AWT]TYPBOUT
      NBOUTACT(NEWBOUT) = [F:AWT]ACTBOUT
      NBOUTVAL(NEWBOUT) = [F:AWT]VALBOUT
      NBOUTTXT(NEWBOUT) = [F:AWT]TXTBOUT
      NBOUTACV(NEWBOUT) = [F:AWT]CODACTBOUT
      Call DIFFACT([F:ADS]DOSSIER,[F:AWT]CODACTBOUT,ACTIV) From DOSSUB
      For [AWP]AWP0 Where WIN = FENETRE & NUM=[F:AWT]NUM
       NEWPAR += 1
       #NPARNUM(NEWPAR) = [F:AWP]NUM
       NPARNUM(NEWPAR) = NEWBOUT
       NPARCOD(NEWPAR) = [F:AWP]PARAM
       NPARNO (NEWPAR) = [F:AWP]NOPAR
       NPARVAL(NEWPAR) = [F:AWP]VALEUR
      Next
     Endif
    Next

    #99690 on relit tous les anciens bout
    NBOUT = 0
    NPAR = 0
    For [DAWT]AWT0 Where WIN=FENETRE
      NBOUT += 1
      BOUTCOD(NBOUT) = [F:DAWT]CODBOUT
      BOUTNUM(NBOUT) = [F:DAWT]NUM
      BOUTTYP(NBOUT) = [F:DAWT]TYPBOUT
      BOUTACT(NBOUT) = [F:DAWT]ACTBOUT
      BOUTVAL(NBOUT) = [F:DAWT]VALBOUT
      BOUTTXT(NBOUT) = [F:DAWT]TXTBOUT
      BOUTACV(NBOUT) = [F:DAWT]CODACTBOUT
      Call DIFFACT([F:ADS]DOSSIER,[F:DAWT]CODACTBOUT,ACTIV) From DOSSUB
      For [DAWP]AWP0 Where WIN = FENETRE & NUM=[F:DAWT]NUM
       NPAR += 1
       PARNUM(NPAR) = [F:DAWP]NUM
       PARCOD(NPAR) = [F:DAWP]PARAM
       PARNO (NPAR) = [F:DAWP]NOPAR
       PARVAL(NPAR) = [F:DAWP]VALEUR
      Next
    Next

    ## Chargement des paramètres

    #99690
#    NPAR = 0
#    For [DAWP]AWP0 Where WIN = FENETRE
#     NPAR += 1
#     PARNUM(NPAR) = [F:DAWP]NUM
#     PARCOD(NPAR) = [F:DAWP]PARAM
#     PARNO (NPAR) = [F:DAWP]NOPAR
#     PARVAL(NPAR) = [F:DAWP]VALEUR
#    Next

    #99690 ici on ne charge que les param correspondant ACTSTD
    #NEWPAR = 0
    For [AWP]AWP0 Where WIN = FENETRE & NUM>100
     NEWPAR += 1
     NPARNUM(NEWPAR) = [F:AWP]NUM
     NPARCOD(NEWPAR) = [F:AWP]PARAM
     NPARNO (NEWPAR) = [F:AWP]NOPAR
     NPARVAL(NEWPAR) = [F:AWP]VALEUR
    Next

    ## Comparaison des boutons-menus standard et les paramètres associés

    If !DIFF
     For B=1 To NEWBOUT
      BB = find(NBOUTCOD(B),BOUTCOD(1..NBOUT))
      If !BB
       DIFF = 1 : Break
      Else
       If !find(BOUTACV(BB),GSPE(1..GNBSPE))
        If NBOUTTYP(B) <> BOUTTYP(BB)    : DIFF = 1 : Break : Endif
        If NBOUTACT(B) <> BOUTACT(BB)    : DIFF = 1 : Break : Endif
        If NBOUTACV(B) <> BOUTACV(BB)    : DIFF = 1 : Break : Endif
        If NBOUTVAL(B) <> BOUTVAL(BB)    : DIFF = 1 : Break : Endif
        If NBOUTTXT(B) <> BOUTTXT(BB)    : DIFF = 1 : Break : Endif
        Call TXT(NBOUTTXT(B),DIFF)  From DOSSUB : If DIFF : Break : Endif
        If NBOUTACT(B)<>""
         For P=1 To NEWPAR
          If NPARNUM(P)=NBOUTNUM(B)
           OKPAR = 0
           For P1=1 To NPAR
            If PARNUM(P1)=BOUTNUM(BB) & PARCOD(P1)=NPARCOD(P)
             If PARVAL(P1)<>NPARVAL(P)
              DIFF = 1 : Break 3
             Endif
             OKPAR = 1 : Break
            Endif
           Next P1
           If !OKPAR : DIFF = 1 : Break 2 : Endif
          Endif
         Next P
        Endif
       Endif
      Endif
     Next B
    Endif

    # Boutons standard à virer ?

    If !DIFF
     For B=1 To NBOUT
      If !find(BOUTACV(B),GSPE(1..GNBSPE))
       BB = find(BOUTCOD(B),NBOUTCOD(1..NEWBOUT))
       If !BB
        DIFF = 1 : Break
       Endif
      Endif
     Next B
    Endif

    ## Comparaison des actions standard et des paramètres associés

    If !DIFF
     For B=0 To dim([F:AWI]BSTD)-1
      If [F:AWI]BSTD(B)      <> [F:DAWI]BSTD(B)       : DIFF = 1 : Break : Endif
      If [F:AWI]ACTSTD(B)    <> [F:DAWI]ACTSTD(B)     : DIFF = 1 : Break : Endif
      If [F:AWI]ACTSTD(B)<>""
       For P=1 To NEWPAR
        If NPARNUM(P)=101+B
         OKPAR = 0
         For P1=1 To NPAR
          If PARNUM(P1)=101+B & PARCOD(P1)=NPARCOD(P)
           If PARVAL(P1)<>NPARVAL(P)
            DIFF = 1 : Break 3
           Endif
           OKPAR = 1 : Break
          Endif
         Next P1
         If !OKPAR : DIFF = 1 : Break 2 : Endif
        Endif
       Next P
      Endif
     Next B
    Endif

    ## On vire l'explorateur de liaisons
    #100563
    [F:DWB2] = [F:DAWB]
    EXPLORE = 0
    B = find("ALI",[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))-1
    If B>=0
     EXPLORE  = 1
     INTEXPLO = [F:DAWB]INTLIS(B)
     RGEXPLO  = [F:DAWB]ROWLIS(B)
     Dela B,1 [F:DAWB]OBJLIS,[F:DAWB]INTLIS,[F:DAWB]CLELIS,[F:DAWB]ORDLIS,[F:DAWB]TRELIS
&            ,[F:DAWB]BROLIS,[F:DAWB]CHGLIS,[F:DAWB]ABRLIS,[F:DAWB]FLELIS,[F:DAWB]ACTLIS
&            ,[F:DAWB]EXPLIS,[F:DAWB]ROWLIS
     [F:DAWB]NBLIS -= 1
    Endif

    ## Comparaisons des browsers standard

    If !DIFF
     If [F:AWB]NBLIS<>[F:DAWB]NBLIS
      DIFF = 1
     Else
      For B=0 To [F:AWB]NBLIS-1
       BB = find([F:AWB]OBJLIS(B),[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))-1
       If BB<0
        DIFF = 1 : Break
       Else
        If !find([F:DAWB]ACTLIS(BB),GSPE(1..GNBSPE))
         If [F:AWB]CLELIS(B) <> [F:DAWB]CLELIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]ORDLIS(B) <> [F:DAWB]ORDLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]TRELIS(B) <> [F:DAWB]TRELIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]CHGLIS(B) <> [F:DAWB]CHGLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]ABRLIS(B) <> [F:DAWB]ABRLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]ACTLIS(B) <> [F:DAWB]ACTLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]INTLIS(B) <> [F:DAWB]INTLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]BROLIS(B) <> [F:DAWB]BROLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]ROWLIS(B) <> [F:DAWB]ROWLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]EXPLIS(B) <> [F:DAWB]EXPLIS(BB) : DIFF = 1 : Break : Endif
         If [F:AWB]FLELIS(B) <> [F:DAWB]FLELIS(BB) : DIFF = 1 : Break : Endif
         Call TXT([F:AWB]INTLIS(B),DIFF) From DOSSUB : If DIFF : Break : Endif
        Endif
       Endif
       Call DIFFACT([F:ADS]DOSSIER,[F:AWB]ACTLIS(B),ACTIV) From DOSSUB
      Next B
      If !DIFF
       [F:DAWI] = [F:AWI]
       Gosub ACT_MSK
       If !DIFF
        [F:DAWB] = [F:AWB]
        Gosub ACT_BRO
       Endif
      Endif
     Endif
    Endif
    ## S'il y a une différence, mise à jour de la fenêtre

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff fenêtre"-FENETRE-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1

     ## Mise à jour de l'en-tête
     ## On garde les onglets spécifiques et les onglets supplémentaires

     # Issue 96650 - 2014-02-17 by VPO : : on prend les masques du patch puis on reprend les SPE
     #[F:DAW2] = [F:DAWI]
     [F:DAWI] = [F:AWI]

     For B=0 To [F:DAW2]NBMSK-1
      If find([F:DAW2]ACTMSK(B),GSPE(1..GNBSPE))
       # Issue 96650 - 2014-02-17 by VPO : : on prend les masques du patch puis on reprend les SPE
       #[F:DAWI]NOMMSK(B)  = [F:DAW2]NOMMSK(B)
       #[F:DAWI]INTMSK(B)  = [F:DAW2]INTMSK(B)
       #[F:DAWI]INTFOLD(B) = [F:DAW2]INTFOLD(B)
       #[F:DAWI]ACTMSK(B)  = [F:DAW2]ACTMSK(B)
       #[F:DAWI]FLGMSK(B)  = [F:DAW2]FLGMSK(B)
       #[F:DAWI]ROWMSK(B)  = [F:DAW2]ROWMSK(B)
       #If B>[F:DAWI]NBMSK-1
       # [F:DAWI]NBMSK = B+1
       #Endif

        K=find([F:DAW2]NOMMSK(B),[F:DAWI]NOMMSK(0..[F:DAWI]NBMSK-1))
        If K
          [F:DAWI]NOMMSK(K-1)=[F:DAW2]NOMMSK(B)
          [F:DAWI]INTMSK(K-1)=[F:DAW2]INTMSK(B)
          [F:DAWI]ACTMSK(K-1)=[F:DAW2]ACTMSK(B)
          [F:DAWI]FLGMSK(K-1)=[F:DAW2]FLGMSK(B)
          [F:DAWI]ROWMSK(K-1)=[F:DAW2]ROWMSK(B)
          [F:DAWI]INTFOLD(K-1)=[F:DAW2]INTFOLD(B)
        Elsif [F:DAWI]NBMSK>=dim([F:DAWI]NOMMSK)
          Call ECR_TRACE("[F:DAWI]NOMMSK"-mess(26,100,1),1) From GESECRAN : # Tableau plein
        Else
          K=[F:DAWI]NBMSK
          [F:DAWI]NBMSK+=1
          [F:DAWI]NOMMSK(K)=[F:DAW2]NOMMSK(B)
          [F:DAWI]INTMSK(K)=[F:DAW2]INTMSK(B)
          [F:DAWI]ACTMSK(K)=[F:DAW2]ACTMSK(B)
          [F:DAWI]FLGMSK(K)=[F:DAW2]FLGMSK(B)
          [F:DAWI]ROWMSK(K)=[F:DAW2]ROWMSK(B)
          [F:DAWI]INTFOLD(K)=[F:DAW2]INTFOLD(B)
        Endif

      Endif
     Next B

     ## On garde les actions SPE SPV, et actions spéc

     For B=0 To dim([F:AWI]BSTD)-1
      K = ([F:DAW2]ACTSTD(B)="SPE")
      K += (!VERT & [F:DAW2]ACTSTD(B)="SPV")
      If !K
       Read [DACT]ACTION=[F:DAW2]ACTSTD(B)
       If !fstat : Call SPEC([F:DACT]CODACT,K) From DOSSUB : Endif
      Endif
      If K
       [F:DAWI]BSTD(B)   = [F:DAW2]BSTD(B)
       [F:DAWI]ACTSTD(B) = [F:DAW2]ACTSTD(B)
       For P=1 To NEWPAR
        If NPARNUM(P)=B+1
         NPARNUM(P) = 0
        Endif
       Next P
       For P=1 To NPAR
        If PARNUM(P)=B+1
         NEWPAR += 1
         NPARNUM(NEWPAR) = PARNUM(P)
         NPARCOD(NEWPAR) = PARCOD(P)
         NPARNO (NEWPAR) = PARNO (P)
         NPARVAL(NEWPAR) = PARVAL(P)
        Endif
       Next P
      Endif
     Next B

     ## Browsers
     ## On rajoute les browsers spécifiques

     #100563
     #[F:DWB2] = [F:DAWB]
     [F:DAWB] = [F:AWB]

     For B=0 To [F:DWB2]NBLIS-1
#      If !find([F:DWB2]OBJLIS(B),[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))
#&      & find([F:DWB2]ACTLIS(B),GSPE(1..GNBSPE)) & [F:DAWB]NBLIS<dim([F:DAWB]OBJLIS)
      If find([F:DWB2]ACTLIS(B),GSPE(1..GNBSPE)) & [F:DWB2]OBJLIS(B)<>"ALI"
       K=find([F:DWB2]OBJLIS(B),[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))
       If K
        [F:DAWB]OBJLIS(K-1) = [F:DWB2]OBJLIS(B)
        [F:DAWB]INTLIS(K-1) = [F:DWB2]INTLIS(B)
        [F:DAWB]CLELIS(K-1) = [F:DWB2]CLELIS(B)
        [F:DAWB]ORDLIS(K-1) = [F:DWB2]ORDLIS(B)
        [F:DAWB]TRELIS(K-1) = [F:DWB2]TRELIS(B)
        [F:DAWB]BROLIS(K-1) = [F:DWB2]BROLIS(B)
        [F:DAWB]ROWLIS(K-1) = [F:DWB2]ROWLIS(B)
        [F:DAWB]CHGLIS(K-1) = [F:DWB2]CHGLIS(B)
        [F:DAWB]ABRLIS(K-1) = [F:DWB2]ABRLIS(B)
        [F:DAWB]ACTLIS(K-1) = [F:DWB2]ACTLIS(B)
        [F:DAWB]EXPLIS(K-1) = [F:DWB2]EXPLIS(B)
        [F:DAWB]FLELIS(K-1) = [F:DWB2]FLELIS(B)
       Elsif [F:DAWB]NBLIS>=dim([F:DAWB]OBJLIS)
        Call ECR_TRACE("[F:DAWB]OBJLIS"-mess(26,100,1),1) From GESECRAN : # Tableau plein
       Else
        [F:DAWB]OBJLIS([F:DAWB]NBLIS) = [F:DWB2]OBJLIS(B)
        [F:DAWB]INTLIS([F:DAWB]NBLIS) = [F:DWB2]INTLIS(B)
        [F:DAWB]CLELIS([F:DAWB]NBLIS) = [F:DWB2]CLELIS(B)
        [F:DAWB]ORDLIS([F:DAWB]NBLIS) = [F:DWB2]ORDLIS(B)
        [F:DAWB]TRELIS([F:DAWB]NBLIS) = [F:DWB2]TRELIS(B)
        [F:DAWB]BROLIS([F:DAWB]NBLIS) = [F:DWB2]BROLIS(B)
        [F:DAWB]ROWLIS([F:DAWB]NBLIS) = [F:DWB2]ROWLIS(B)
        [F:DAWB]CHGLIS([F:DAWB]NBLIS) = [F:DWB2]CHGLIS(B)
        [F:DAWB]ABRLIS([F:DAWB]NBLIS) = [F:DWB2]ABRLIS(B)
        [F:DAWB]ACTLIS([F:DAWB]NBLIS) = [F:DWB2]ACTLIS(B)
        [F:DAWB]EXPLIS([F:DAWB]NBLIS) = [F:DWB2]EXPLIS(B)
        [F:DAWB]FLELIS([F:DAWB]NBLIS) = [F:DWB2]FLELIS(B)
        [F:DAWB]NBLIS += 1
       Endif
      Endif
     Next B

     ## On rajoute l'explorateur de liaisons
     If EXPLORE
     For B=0 To [F:DWB2]NBLIS-1
#      If !find([F:DWB2]OBJLIS(B),[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))
#&      & find([F:DWB2]ACTLIS(B),GSPE(1..GNBSPE)) & [F:DAWB]NBLIS<dim([F:DAWB]OBJLIS)
      If find([F:DWB2]ACTLIS(B),GSPE(1..GNBSPE)) & [F:DWB2]OBJLIS(B)="ALI"
       K=find([F:DWB2]OBJLIS(B),[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))
       If K
        [F:DAWB]OBJLIS(K-1) = [F:DWB2]OBJLIS(B)
        [F:DAWB]INTLIS(K-1) = [F:DWB2]INTLIS(B)
        [F:DAWB]CLELIS(K-1) = [F:DWB2]CLELIS(B)
        [F:DAWB]ORDLIS(K-1) = [F:DWB2]ORDLIS(B)
        [F:DAWB]TRELIS(K-1) = [F:DWB2]TRELIS(B)
        [F:DAWB]BROLIS(K-1) = [F:DWB2]BROLIS(B)
        [F:DAWB]ROWLIS(K-1) = [F:DWB2]ROWLIS(B)
        [F:DAWB]CHGLIS(K-1) = [F:DWB2]CHGLIS(B)
        [F:DAWB]ABRLIS(K-1) = [F:DWB2]ABRLIS(B)
        [F:DAWB]ACTLIS(K-1) = [F:DWB2]ACTLIS(B)
        [F:DAWB]EXPLIS(K-1) = [F:DWB2]EXPLIS(B)
        [F:DAWB]FLELIS(K-1) = [F:DWB2]FLELIS(B)
       Elsif [F:DAWB]NBLIS>=dim([F:DAWB]OBJLIS)
        Call ECR_TRACE("[F:DAWB]OBJLIS"-mess(26,100,1),1) From GESECRAN : # Tableau plein
       Else
        [F:DAWB]OBJLIS([F:DAWB]NBLIS) = [F:DWB2]OBJLIS(B)
        [F:DAWB]INTLIS([F:DAWB]NBLIS) = [F:DWB2]INTLIS(B)
        [F:DAWB]CLELIS([F:DAWB]NBLIS) = [F:DWB2]CLELIS(B)
        [F:DAWB]ORDLIS([F:DAWB]NBLIS) = [F:DWB2]ORDLIS(B)
        [F:DAWB]TRELIS([F:DAWB]NBLIS) = [F:DWB2]TRELIS(B)
        [F:DAWB]BROLIS([F:DAWB]NBLIS) = [F:DWB2]BROLIS(B)
        [F:DAWB]ROWLIS([F:DAWB]NBLIS) = [F:DWB2]ROWLIS(B)
        [F:DAWB]CHGLIS([F:DAWB]NBLIS) = [F:DWB2]CHGLIS(B)
        [F:DAWB]ABRLIS([F:DAWB]NBLIS) = [F:DWB2]ABRLIS(B)
        [F:DAWB]ACTLIS([F:DAWB]NBLIS) = [F:DWB2]ACTLIS(B)
        [F:DAWB]EXPLIS([F:DAWB]NBLIS) = [F:DWB2]EXPLIS(B)
        [F:DAWB]FLELIS([F:DAWB]NBLIS) = [F:DWB2]FLELIS(B)
        [F:DAWB]NBLIS += 1
       Endif
      Endif
     Next B
     Endif

    # Issue X3-61860 - 2018-03-16 by CCC : Add test on [F:DAWB]NBLIS
     If EXPLORE & !find("ALI",[F:DAWB]OBJLIS(0..[F:DAWB]NBLIS-1))
&     & [F:DAWB]NBLIS<dim([F:DAWB]OBJLIS)
      [F:DAWB]OBJLIS([F:DAWB]NBLIS) = "ALI"
      [F:DAWB]INTLIS([F:DAWB]NBLIS) = INTEXPLO
      [F:DAWB]CLELIS([F:DAWB]NBLIS) = ""
      [F:DAWB]ORDLIS([F:DAWB]NBLIS) = 1
      [F:DAWB]TRELIS([F:DAWB]NBLIS) = 4
      [F:DAWB]BROLIS([F:DAWB]NBLIS) = 1
      [F:DAWB]ROWLIS([F:DAWB]NBLIS) = RGEXPLO
      [F:DAWB]CHGLIS([F:DAWB]NBLIS) = 2
      [F:DAWB]ABRLIS([F:DAWB]NBLIS) = ""
      [F:DAWB]ACTLIS([F:DAWB]NBLIS) = ""
      [F:DAWB]EXPLIS([F:DAWB]NBLIS) = ""
      [F:DAWB]FLELIS([F:DAWB]NBLIS) = 1
      [F:DAWB]NBLIS += 1
     Endif

     ## On rajoute les boutons spé

     For B=1 To NBOUT
      If find(BOUTACV(B),GSPE(1..GNBSPE))
       NEWBOUT += 1
       NBOUTCOD(NEWBOUT) = BOUTCOD(B)
       NBOUTTYP(NEWBOUT) = BOUTTYP(B)
       NBOUTACT(NEWBOUT) = BOUTACT(B)
       NBOUTVAL(NEWBOUT) = BOUTVAL(B)
       NBOUTTXT(NEWBOUT) = BOUTTXT(B)
       NBOUTACV(NEWBOUT) = BOUTACV(B)
       #99690
       NBOUTNUM(NEWBOUT) = NEWBOUT
       For P=1 To NPAR
        #99690
        #If PARNUM(P)=B
        If PARNUM(P)=BOUTNUM(B)
         NEWPAR += 1
         NPARNUM(NEWPAR) = NEWBOUT
         NPARCOD(NEWPAR) = PARCOD(P)
         NPARNO (NEWPAR) = PARNO (P)
         NPARVAL(NEWPAR) = PARVAL(P)
        Endif
       Next P
      Endif
     Next B

     ## Zones de personnalisation

     [F:DAWB]DERLU  = [F:DWB2]DERLU
     [F:DAWB]FIRLIS = [F:DWB2]FIRLIS
     If dim([F:DWB2]AFLBRO)>0 and [F:DWB2]AFLBRO>0
      [F:DAWB]AFLBRO = [F:DWB2]AFLBRO
     Endif

     ## On réécrit tout

     Gosub ACT_BRO
     Rewrite [DAWB]
     If fstat : Call ERREUR("AWINBRO"-FENETRE,2) From DOSDIC : Endif

     Delete [DAWT] Where WIN=FENETRE
     If fstat=1 : Call ERREUR("AWINBOUT"-FENETRE,3) From DOSDIC : Endif
     For B=1 To NEWBOUT
      [F:DAWT]WIN        = FENETRE
      [F:DAWT]CODBOUT    = NBOUTCOD(B)
      [F:DAWT]NUM        = NBOUTNUM(B)
      [F:DAWT]TYPBOUT    = NBOUTTYP(B)
      [F:DAWT]ACTBOUT    = NBOUTACT(B)
      [F:DAWT]VALBOUT    = NBOUTVAL(B)
      [F:DAWT]TXTBOUT    = NBOUTTXT(B)
      [F:DAWT]CODACTBOUT = NBOUTACV(B)
      Write [DAWT]
      If fstat : Call ERREUR("AWINBOUT"-FENETRE-[F:DAWT]CODBOUT,2) From DOSDIC : Endif
     Next B

     Delete [DAWP] Where WIN=FENETRE
     If fstat=1 : Call ERREUR("AWINPAR"-FENETRE,3) From DOSDIC : Endif
     For P=1 To NEWPAR
      If NPARNUM(P)<>0
       [F:DAWP]WIN    = FENETRE
       [F:DAWP]NUM    = NPARNUM(P)
       [F:DAWP]PARAM  = NPARCOD(P)
       [F:DAWP]NOPAR  = NPARNO(P)
       [F:DAWP]VALEUR = NPARVAL(P)
       Write [DAWP]
       If fstat : Call ERREUR("AWINPAR"-FENETRE-[F:DAWP]PARAM,2) From DOSDIC : Endif
      Endif
     Next P

     [F:DAWI]ENAFLG = [F:DAW3]ENAFLG
     [F:DAWI]ACS    = [F:DAW3]ACS
     [F:DAWI]UPDDAT = date$
     [F:DAWI]UPDUSR = GUSER
     If dim([F:DAWI]UPDTIM)>0 : [F:DAWI]UPDTIM = time : Endif
     [F:DAWI]UPDFLG = 1
     GNBWIN += 1
     Gosub ACT_MSK
     Rewrite [DAWI]
     If fstat : Call ERREUR("AWINDOW"-FENETRE,2) From DOSDIC : Endif

    Elsif ACTIV

     [F:DAWI]ENAFLG = [F:DAW3]ENAFLG
     [F:DAWI]ACS    = [F:DAW3]ACS
     [F:DAWI]UPDFLG = 1
     [F:DAWI]UPDDAT = date$
     [F:DAWI]UPDUSR = GUSER
     If dim([F:DAWI]UPDTIM)>0 : [F:DAWI]UPDTIM = time : Endif
     GNBWIN += 1 : RWO = 1
     Rewrite [DAWI]
     If fstat : Call ERREUR("AWINDOW"-FENETRE,2) From DOSDIC : Endif

    Endif
    Gosub MSKWIN
   Endif
  Endif

 Commit
Next

# Passe pour virer les browsers inexistants

Trbegin [DAWB] , [DAWI]
 For [DAWB]AWB0
  Read [DAWI]AWI0 = [F:DAWB]WIN
  Call NEWREC([F:ADS]DOSSIER,[F:DAWI]CODACT,[F:DAWI]MODULE,NEWREC) From DOSSUB
  If NEWREC
   I = 0
   K = 0
   While I<=[F:DAWB]NBLIS-1
    If left$([F:DAWB]OBJLIS(I),1)<>"W"
     Look [DAOB]ABREV = [F:DAWB]OBJLIS(I)
     If fstat
      Dela I,1 [F:DAWB]OBJLIS,[F:DAWB]INTLIS,[F:DAWB]CLELIS,[F:DAWB]ORDLIS,[F:DAWB]TRELIS
&             ,[F:DAWB]BROLIS,[F:DAWB]CHGLIS,[F:DAWB]ABRLIS,[F:DAWB]FLELIS,[F:DAWB]ACTLIS
&             ,[F:DAWB]EXPLIS,[F:DAWB]ROWLIS
      [F:DAWB]NBLIS -= 1
      K = 1
     Else
      I += 1
     Endif
    Else
     I += 1
    Endif
   Wend
   If K
    Rewrite [DAWB]
    If fstat : Call ERREUR("AWINBRO"-[F:DAWB]WIN,2) From DOSDIC : Endif
    Update [DAWI] Where WIN=[F:DAWB]WIN With UPDFLG=1
   Endif
  Endif
 Next
Commit

# On vire les boutons dont l'action est inexistante

Trbegin [DAWI]
 For [DAWI]AWI0
  RW = 0
  For I=0 To dim([F:DAWI]ACTSTD)-1
   If [F:DAWI]ACTSTD(I)<>""
    Read [DACT]ACTION = [F:DAWI]ACTSTD(I)
    If fstat
     [F:DAWI]ACTSTD(I) = "" : RW = 1
     Delete [DAWP] Where [DAWP]WIN=[DAWT]WIN & [DAWP]NUM=101+I
     If fstat : Call ERREUR("AWINPAR"-[F:DAWT]WIN-num$([F:DAWT]NUM),2) From DOSDIC : Endif
    Endif
   Endif
  Next I
  If RW
   Rewrite [DAWI]
   If fstat : Call ERREUR("AWINDOW"-[F:DAWI]WIN,2) From DOSDIC : Endif
  Endif
 Next
Commit

# On vire les menus/boutons dont l'action est inexistante

Trbegin [DAWT]
 For [DAWT]AWT0 Where ACTBOUT<>""
  Read [DACT]ACTION = [F:DAWT]ACTBOUT
  If fstat
   [F:DAWT]ACTBOUT = ""
   Rewrite [DAWT]
   If fstat : Call ERREUR("AWINBOUT"-[F:DAWT]WIN,2) From DOSDIC : Endif
   Delete [DAWP] Where [DAWP]WIN=[DAWT]WIN & [DAWP]NUM=[F:DAWT]NUM
   If fstat : Call ERREUR("AWINPAR"-[F:DAWT]WIN-num$([F:DAWT]NUM),2) From DOSDIC : Endif
  Endif
 Next
Commit

Close Local File [AWI]  , [AWP]  , [AWB]  , [AWT]  , [DAW3]
Close Local File [DAWI] , [DAWP] , [DAWB] , [DAWT] , [DAW2] , [DWB2] , [DACV] , [DAOB] , [DACT]
Close Local File [AMK]  , [AMZ]  , [AMP]  , [AMA]  , [DAMK] , [DAMZ] , [DAMP] , [DAMA]
Return

# Suppression des onglets inactifs

$ACT_MSK
B = 0
While B<=[F:DAWI]NBMSK-1
 If [F:DAWI]ACTMSK(B)<>""
  Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:DAWI]ACTMSK(B)
  #100563
  #If fstat or [F:ADA]FLACT<>2
  If fstat
   Dela B,1 [F:DAWI]NOMMSK,[F:DAWI]INTMSK,[F:DAWI]ACTMSK,[F:DAWI]FLGMSK,[F:DAWI]ROWMSK,[F:DAWI]INTFOLD
   [F:DAWI]NBMSK -= 1
   B -= 1
   DIFF = 1
  Endif
 Endif
 B += 1
Wend
Return


# Suppression des browsers inactifs

$ACT_BRO
B = 0
While B<=[F:DAWB]NBLIS-1
 If [F:DAWB]ACTLIS(B)<>""
  Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:DAWB]ACTLIS(B)
  #100563
  #If fstat or [F:ADA]FLACT<>2
  If fstat
   Dela B,1 [F:DAWB]OBJLIS,[F:DAWB]INTLIS,[F:DAWB]CLELIS,[F:DAWB]ORDLIS,[F:DAWB]TRELIS
&          ,[F:DAWB]BROLIS,[F:DAWB]CHGLIS,[F:DAWB]ABRLIS,[F:DAWB]FLELIS,[F:DAWB]ACTLIS
&          ,[F:DAWB]EXPLIS,[F:DAWB]ROWLIS
   [F:DAWB]NBLIS -= 1
   B -= 1
   DIFF = 1
  Endif
 Endif
 B += 1
Wend
Return

## Copie des écrans définis dans les fenêtres

$MSKWIN
[L]MSKCOD = [F:DAWI]MSKENT : Gosub MSKWIN2
For B=0 To [F:DAWI]NBMSK-1
 [L]MSKCOD = [F:DAWI]NOMMSK(B)
 K = 1
 If [F:DAWI]ACTMSK(B)<>""
  Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:DAWI]ACTMSK(B)
  If fstat or [F:ADA]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Gosub MSKWIN2
 Endif
Next B
Return

$MSKWIN2
If [L]MSKCOD="" : Return : Endif
Read [DAMK]CODMSK = [L]MSKCOD
If fstat
 Read [AMK]CODMSK = [L]MSKCOD
 If fstat : Return : Endif
 Call ECR_TRACE("("+FENETRE+")"-mess(92,125,1)-[L]MSKCOD,0) From GESECRAN
 # Copie écran associé
 Raz [F:DAMK]
 GNBMSK += 1
 [F:DAMK] = [F:AMK]
 [F:DAMK]UPDFLG = 1
 [F:DAMK]CREDAT = date$
 [F:DAMK]CREUSR = GUSER
 If dim([F:DAMK]CRETIM)>0 : [F:DAMK]CRETIM = time : Endif
 Write [DAMK]
 If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,1) From DOSDIC : Endif
 For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK
  [F:DAMZ] = [F:AMZ]
  Write [DAMZ]
  If fstat : Call ERREUR("AMSKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,1) From DOSDIC : Endif
 Next
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
  [F:DAMA] = [F:AMA]
  Write [DAMA]
  If fstat : Call ERREUR("AMSKACT"-[F:DAMA]CODAFF,1) From DOSDIC : Endif
 Next
 For [AMP]CODPAR Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
  [F:DAMP] = [F:AMP]
  Write [DAMP]
  If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF,1) From DOSDIC : Endif
 Next
Endif
Return

## Effacement fenêtre

Subprog EFFACE(FENETRE)
Value Char FENETRE
Local Char TRAIT(GLONADC)
Call ECR_TRACE(mess(98,125,1)-FENETRE,0) From GESECRAN
#Call NOMTRTWIN(FENETRE,TRAIT) From MSKDIV
If FENETRE=""
  TRAIT=""
Else
  TRAIT="WG"+FENETRE        : #  CC  06/04/2012   Bug 81470
Endif
Call SUPP_TRT(TRAIT) From DOSSUB
Delete [DAWT] Where WIN=FENETRE
If fstat=1 : Call ERREUR("AWINBOUT"-FENETRE,3) From DOSDIC : Endif
Delete [DAWB] Where WIN=FENETRE
If fstat=1 : Call ERREUR("AWINBRO"-FENETRE,3) From DOSDIC : Endif
Delete [DAWP] Where WIN=FENETRE
If fstat=1 : Call ERREUR("AWINPAR"-FENETRE,3) From DOSDIC : Endif
Delete [DAWI] Where WIN=FENETRE
If fstat=1 : Call ERREUR("AWINDOW"-FENETRE,3) From DOSDIC : Endif
End

