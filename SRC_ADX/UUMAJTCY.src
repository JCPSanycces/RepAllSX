#<AdxTL>@(#)6.0.0.0 $Revision$
##############################################################################
## Validation dictionnaire suivant les types de données NCY et CT0
##############################################################################
Call OUVRE_TRACE("Update NCY & CT0") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer VALMOD(20) , I
If DOSSIER=GDOSX3
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Else
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Endif
# Tables et Ecrans
Call ECR_TRACE("** NCY",0) From GESECRAN
Call VALID_TRT(DOSSIER,0,"NCY","","","","","Z","","Z","","","","","","","","","","","","",VALMOD) From VALDICO
Call ECR_TRACE("** CT0",0) From GESECRAN
Call VALID_TRT(DOSSIER,0,"CT0","","","","","Z","","Z","","","","","","","","","","","","",VALMOD) From VALDICO
Return
