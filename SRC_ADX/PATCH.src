#---------------------------------------------#
$INTEGRE

#U11 SCM
If dim([S]adxtrp)> 0 & dim([S]adxtrl)> 0
  Local Char PATCHTRP(type([S]adxtrp)-10)
  Local Char PATCHTRL(type([S]adxtrl)-10)
  PATCHTRP = [S]adxtrp
  PATCHTRL = [S]adxtrl
Endif
ER = 0
BR = 0
For D=1 To NBDOS

 Call MACHINE(DOSSIER(D),MACHINE,APPLI) From ORDSYS
 DOSX3 = func DOSCONT.DOSX3(DOSSIER(D))

 If INTEGRE=2
  Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),2,0,0) : # En cours
 Endif

 If clalev([F:ADS])>0 or clalev([ADA])>0 : Close Local File : Endif : # mb 17.4.2 On ne sait jamais !

 If instr(1,DOSX3,"@")
  Local File =DOSX3+".ADOSSIER" [ADS] , =DOSX3+".ADOSACT"  [ADA]
 Else
  Local File ADOSSIER [ADS] , ADOSACT  [ADA]
 Endif

 Read [ADS]DOSSIER = APPLI
 If fstat
  Call ECR_TRACE(APPLI-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
  If INTEGRE=2
   Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),5,0,0) : # Erreur
  Endif
 Else
  If !SAVSERV & INTEGRE<>3
   If GBROWS
    GSERVEUR = 0
    Call AFF_VLC(TRAIT(P),DOSSIER(D)) From GESECRAN
    GSERVEUR = 1
   Else
    [M:PATA]NBDOS   = D
    [M:PATA]DOSSIER = DOSSIER(D)
    [M:PATA]PCENT   = 0
    [M:PATA]JAUGE   = 0
    Affzo [PATA]NBDOS,DOSSIER,PCENT,JAUGE
    Envzo
   Endif
  Endif

  If INTEGRE<>3
   If FICCLI<>""
    Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
   Else
    # mb 17.1.14 bug 95925
    If dim([M:DIA]VOLFIL)>0
     Call ECR_TRACE(mess(38,115,1)-"|"+func NAMFICVOL(FICPATCH,[M:DIA]VOLFIL),0) From GESECRAN : # Lecture du fichier
    Else
     Call ECR_TRACE(mess(38,115,1)-"|"+FICPATCH,0) From GESECRAN : # Lecture du fichier
    Endif
   Endif
   If INTEGRE=2
    Call ECR_TIME(mess(31,115,1)-":"-APPLI) From DOSSUB : # Intégration dans le dossier
   Endif
  Endif

  # Récupération des législations du dossier validé
  Raz LEGREF,NBLEGREF
  Call SETLEG(DOSSIER(D),LEGREF,NBLEGREF) From DOSCONT
  Read [ADA]ADA0=DOSSIER(D);"LEG"
  MULTILEG = (!fstat & [F:ADA]FLACT=2)

  ACTION = "INTINI" : Gosub ACTION_XTEND :  Gosub ACTION_PRODUIT
  Gosub OUVFIC

  Read [ADW]ADW0 = "";"";"SUPDOS"
  GDOSX3 = [F:ADW]VALEUR
  If GDOSX3="" : GDOSX3 = "X3" : Endif

  Read [ADW]ADW0 = "";"";"SPECIF"
  If !fstat & val([F:ADW]VALEUR)=2 : K = 2 : Else : K = 1 : Endif
  If INTEGRE<>3 : Call ECR_TRACE(APPLI-mess(120,125,1)-":"-mess(K,1,1),0) From GESECRAN : Endif : # Dossier spécifique

  Read [ADW]ADW0 = "";"";"TEST"
  If !fstat & val([F:ADW]VALEUR)=2 : K = 2 : Else : K = 1 : Endif
  If INTEGRE<>3 : Call ECR_TRACE(APPLI-mess(119,125,1)-":"-mess(K,1,1),0) From GESECRAN : Endif : # Dossier test

  Openi FICPATCH
  adxifs = ","
  adxirs = chr$(10)
  adxium = GUTF8

  Gosub LIRE_ENTETE
  If ER : BR = D : Break : Endif

  If INTEGRE<>3
   #U11 SCM
   If dim(GSOPHIA)>0 and GSOPHIA>0 and dim([M:DIA]FULLMOD)>0 and [M:DIA]FULLMOD=2 and find(TYPPTC,1,2)>0
    Call ECR_TRACE(COMMENT-"(FULLMOD)"-mess(40,115,1)-num$(VERSION),0) From GESECRAN : # Version minimum
    If dim([S]adxtrp)> 0 & dim([S]adxtrl)> 0
     [S]adxtrp = ""
     [S]adxtrl = ""
    Endif
   Else
    Call ECR_TRACE(COMMENT-mess(40,115,1)-num$(VERSION),0) From GESECRAN : # Version minimum
   Endif

   #--------------------------------------------------------#
   # Type de patch
   #--------------------------------------------------------#
   # - Normal
   # - Superviseur : réservé pour le patch de doc
   # - Spécifique  : permet la suppression des actions SPE
   # - Vertical    : permet la suppression des actions SPV
   # - Add-on      : ne supprime pas les actions SPV
   #--------------------------------------------------------#

   Call ECR_TRACE(mess(7604,200,1)-":"-mess(TYPPTC,7804,1),0) From GESECRAN

  Endif

  # Issue 60344 - 2017-10-18 by CCC : init of ISFULLMOD must be done before TEST_PRODUIT
  If dim(GSOPHIA)>0 and GSOPHIA>0 and dim([M:DIA]FULLMOD)>0 and [M:DIA]FULLMOD=2 and find(TYPPTC,1,2)>0
    [L]ISFULLMOD = 2
  Endif

  Gosub TEST_PRODUIT
  If ER : BR = D : Break : Endif

  OKFIC = 1
  If INTEGRE=2
   Read [ADW]ADW0 = "";"";"RELEASE"
   If fstat or val([F:ADW]VALEUR)<VERSION
    # Le dossier doit être au moins dans la version
    Call ECR_TRACE(mess(39,115,1)-":"-num$(VERSION)-"("+[F:ADW]VALEUR+")",1) From GESECRAN
    OKFIC = 0
   Endif
   GPE = 0
   GPOINT = "PATCH" : Gosub ENTREE From EXEFNC
   If GPE=1 : OKFIC = 0 : Endif
  Endif

  If OKFIC
   Gosub OBJET
   Case ER
    When 1,22,97 : BR = D : Break
    When Default : If ER & [L]APPLI=GDOSX3 : BR = D : Break : Endif
   Endcase
   If INTEGRE=2
    If 1=1
     If ER
      Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),5,0,0) : # Erreur
    # Else
    #  Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),3,0,0) : # Terminé
     Endif
    Endif
    Gosub SUIVI
   Endif
  Elsif INTEGRE=2
   Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),4,0,0) : # Non installé
  Endif

 Endif

 ACTION = "INTEND" : Gosub ACTION_XTEND : Gosub ACTION_PRODUIT
 Close Local File
 If INTEGRE<2 : Break : Endif

Next D

Openi
Close Local File

If BR & INTEGRE=2
 For D=BR To NBDOS
  Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),5,0,0) : # Erreur
 Next D
Endif

If ER
 Gosub ERREURS
Endif

## Exécution des programmes
For D=1 To NBDOS
 If OKPRGDOS(D)
  NBMERE = 0
  If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER = DOSSIER(D)
  If !fstat
   For I=1 To NBPROG
    OKTRT = 0
    If [F:ADS]TSTFLG<>2 : # Si ce n'est pas un dossier test, on cherche d'abord dans le dossier X3
     Call EXISTE_ADX("","",PROGRAMME(I),OKTRT) From ORDSYS
     If OKTRT>0
      Call EXETRT(DOSSIER(D),PROGRAMME(I))
     Endif
    Endif
    If !OKTRT
     Call EXISTE_ADX("",DOSSIER(D),PROGRAMME(I),OKTRT) From ORDSYS
     If OKTRT>0
      Call EXETRT(DOSSIER(D),DOSSIER(D)+"."+PROGRAMME(I))
     Else
      Gosub SET_MERE
      OKTRT = 0
      For J=1 To NBMERE
       Call EXISTE_ADX("",TBMERE(J),PROGRAMME(I),OKTRT) From ORDSYS
       If OKTRT>0 : OKTRT = J : Break : Endif
      Next J
      If OKTRT>0
       Call EXETRT(DOSSIER(D),TBMERE(OKTRT)+"."+PROGRAMME(I))
      Else
       Call ECR_TRACE(DOSSIER(D)-":"-PROGRAMME(I)-mess(90,123,1),1) From GESECRAN : # Traitement inexistant
      Endif
     Endif
    Endif
   Next I
   If INTEGRE=2
    Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),0,3,0) : # Terminé
   Endif
  Else
   If INTEGRE=2
    Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),0,5,0) : # Erreur
   Endif
  Endif
 Endif
 If INTEGRE=2 & !OKPRGDOS(D)
  Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),TRAIT(P),0,3,0) : # Terminé
 Endif
Next D
#U11 SCM
If dim([S]adxtrp)> 0 & dim([S]adxtrl)> 0
  [S]adxtrp = PATCHTRP
  [S]adxtrl = PATCHTRL
Endif
Return

#-----------------------------------------#
Funprog NAMFICVOL(FICFUL,VOLFIC)
Value Char    FICFUL , VOLFIC
Local Char    NAMFIC(250) , VOL(250)
Local Integer I , J
I = instr(1,VOLFIC,"[")
J = instr(I,VOLFIC,"]")
If I & J
 VOL = seg$(VOLFIC,I+1,J-1)
 Local File AVOLUME [AVL]
 Read [AVL]CODE=VOL
 If !fstat
  NAMFIC = filpath([F:AVL]ROOT,"","","")
  If find(right$(NAMFIC,len(NAMFIC)),"/","\")
   NAMFIC = left$(NAMFIC,len(NAMFIC)-1)
  Endif
  NAMFIC = "["+VOL+"]"+right$(FICFUL,len(NAMFIC)+1)
 Else
  NAMFIC = FICFUL
 Endif
 Close Local File [AVL]
Else
 NAMFIC = FICFUL
Endif
End NAMFIC

#---------------------------------------------#
Subprog EXETRT(APPLI,TRT)
Value Char APPLI , TRT
Local Char SAVLAN(GLONLAN)
# Exécution traitement
Call ECR_TRACE(APPLI-":"-mess(193,123,1)-TRT,0) From GESECRAN
SAVLAN = GLANGUE
Call PATCH(APPLI) From =TRT
GLANGUE     = SAVLAN
adxrob(0)   = "ECR"
messname(0) = GLANGUE
adxtms      = "APLSTD"
adxmbm      = adxmbm
End

#---------------------------------------------#
$SET_MERE
If NBMERE = 0
 FICAPL = filpath("","APL","ini",DOSSIER(D))
 If filinfo(FICAPL,0)>=0
  Openi FICAPL
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>DOSSIER(D) & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
Endif
Return

#-----------------------------------------------------------------#
# Entête
#-----------------------------------------------------------------#
# 1 Commentaires
# 2 Langues -> FRA/ENG
# 3 Version -> Release
# 4 Codes activités -> ACT1/ACT2
# 5 Produit -> SU/X3/GX/PA/AB
# 6 Type de patch -> 1 à 5 (Normal/Superviseur/Spé/Vert/Add-on)
# 7 Autres codes activités -> ACTn/ACTn+1
#-----------------------------------------------------------------#

$LIRE_ENTETE
Gosub LIRE
If fstat        : ER = 1  : Return
Elsif TYPENR<>1 : ER = 21 : Return
Else
 TYPPTC = val(CHAMP(6))
 If !find(TYPPTC,1,2,3,4,5) : ER = 96 : Return : Endif
Endif
VERSION = val(CHAMP(3))
COMMENT = CHAMP(1)
Raz NLANP , LANPATCH
While CHAMP(2)<>""
 NLANP += 1
 K = instr(1,CHAMP(2),"/")
 If K
  LANPATCH(NLANP) = left$(CHAMP(2),K-1)
  CHAMP(2)        = right$(CHAMP(2),K+1)
 Else
  LANPATCH(NLANP) = CHAMP(2)
  CHAMP(2)        = ""
 Endif
Wend
Raz NBACT , ACTIV
For I=4 To dim(CHAMP)-1
 If !find(I,5,6) : # Produit,type de patch
  While CHAMP(I)<>""
   If NBACT<dim(ACTIV)
    NBACT += 1
    K = instr(1,CHAMP(I),"/")
    If K
     ACTIV(NBACT) = left$(CHAMP(I),K-1)
     CHAMP(I)     = right$(CHAMP(I),K+1)
    Else
     ACTIV(NBACT) = CHAMP(I)
     CHAMP(I)     = ""
    Endif
   Endif
  Wend
 Endif
Next I
If TYPPTC>=3 : # Spécifique/Vertical
 #For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X" & COP=2
 # If !find([F:ADA]CODACT,ACTIV(1..NBACT)) & NBACT<dim(ACTIV)
 #  NBACT += 1
 #  ACTIV(NBACT) = [F:ADA]CODACT
 # Endif
 #Next ADA
Endif
PRODUIT = CHAMP(5)
Return

#---------------------------------------------#
$TEST_PRODUIT
FORCE_SUP = 0
If PRODUIT<>""
 Read [ADW]ADW0 = "";"";"TYPDOS"
 If GPRODUIT<>val([F:ADW]VALEUR)-1
  ER = 95 : Return
 Elsif GPRODUIT<>-1 & PRODUIT="SU" & !SAVSERV
  GSERVEUR = 0
  # Etes-vous sûr de vouloir intégrer un patch # dans le produit courant
  Call AVERTIR(func AFNC.MES(mess(254,139,1),'"'+mess(2,39,1)+'"'),ER) From GESECRAN
  GSERVEUR = 1
  If ER<>2 : ER = 98 : Return : Endif
  FORCE_SUP = 1
  ER = 0
 Elsif GPRODUIT=-1 & PRODUIT="SU" : # Cas de la mise à jour d'un superviseur
  FORCE_SUP = 1
 Else
  Case GPRODUIT
   When -1 : If PRODUIT<>"SU" : ER = 98 : Endif
   When  0 : If PRODUIT<>"X3" : ER = 98 : Endif
   When  1 : If PRODUIT<>"GX" : ER = 98 : Endif
   When  2 : If [L]ISFULLMOD=2
                If !find(PRODUIT,"PA","X3") : ER = 98 : Endif
             Else
                If PRODUIT<>"PA" : ER = 98 : Endif
             Endif
   When  3 : If PRODUIT<>"AB" : ER = 98 : Endif
  Endcase
  If ER=98
   If GADONIX=2 & !SAVSERV
    GSERVEUR = 0
    Case PRODUIT
     When "SU"    : CHAINE = mess(2,39,1)   : # Superviseur
     When "X3"    : CHAINE = mess(6,2902,1) : # Sage ERP X3
     When "GX"    : CHAINE = mess(3,2902,1) : # Sage Geode
     When "PA"    : CHAINE = mess(2,2902,1) : # Sage HR Management
     When "AB"    : CHAINE = mess(4,2902,1) : # Sage FRP Fixed Assets
     When Default : CHAINE = "Unknow"
    Endcase
    # Etes-vous sûr de vouloir intégrer un patch # dans le produit courant
    Call AVERTIR(func AFNC.MES(mess(254,139,1),'"'+CHAINE+'"'),ER) From GESECRAN
    GSERVEUR = 1
    If ER<>2 : ER = 98 : Return : Endif
    FORCE_SUP = 1
    ER = 0
   Else
    Return
   Endif
  Endif
 Endif
Endif
Return

#---------------------------------------------#
$OBJET
ER = 0
Gosub LIRE
If fstat
 ER = 1 : Return
Elsif TYPENR=8
 If INTEGRE<>3
  Call ECR_TRACE(mess(32,115,1)-":"-CHAMP(1),0) From GESECRAN : # Fin de fichier
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 Openi
Elsif abs(TYPENR)=2 :#SCM deletion
 TYPOBJ   = CHAMP(1)
 INTITOBJ = CHAMP(3)
 #U11 PATCH SCM
 If dim(GSOPHIA)>0 and GSOPHIA>0 and dim([M:DIA]FULLMOD)>0 and [M:DIA]FULLMOD=2 and find(TYPPTC,1,2)>0
  NOMOBJ = vireblc(CHAMP(2),2)
 Else
  Case TYPOBJ
   When "ATY","ACT","ARP","AML","ADP","ACV","AWI","ACN","AOE","ADV","ANG","GAU","ACLA","ASW","ATYP"
    NOMOBJ = vireblc(format$("K:80c",CHAMP(2)),2)
   When "ELT","BIA","ADO","ADZ","ADF","ASU","ADI","AWA","TFO","ACL"
&    , "AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYX","AYO","AYI","AYM","AYC","AYU","ELX"
    NOMOBJ = vireblc(CHAMP(2),2)
   When Default
    NOMOBJ = vireblc(format$("KT:80X",CHAMP(2)),2)
  Endcase
 Endif
 ABROBJ = TYPOBJ
 CLEOBJ = NOMOBJ
 If !SAVSERV & !GBROWS & INTEGRE<>3
  POSFIC = adxseek(0)
  [M:PATA]PCENT = 100*POSFIC/TAILFIC
  [M:PATA]JAUGE = [M:PATA]PCENT
  [M:PATA]TYP   = TYPOBJ
  [M:PATA]NOM   = NOMOBJ
  Affzo [PATA]PCENT,JAUGE,TYP,NOM
  Envzo
 Endif
 OKOBJ = 1
 OKSPE = 0
 If TYPOBJ="TXT" : README = NOMOBJ : Endif
 If TYPPTC=2 & GDOSX3<>APPLI & !find(TYPOBJ,"ADO","ADZ","ADF")
  ER = 97 : Return
 Else
  If TYPPTC>2 : # Spécifique/vertical/Add-on
   GPE = 0
   GPOINT = "INTEGOBJ" : Gosub ENTREE From EXEFNC
   If GPE=1 : OKOBJ = 0 : Endif
  Endif
 Endif
# Issue 60344 - 2017-10-18 by CCC : init of ISFULLMOD must be done before TEST_PRODUIT
# If dim(GSOPHIA)>0 and GSOPHIA>0 and dim([M:DIA]FULLMOD)>0 and [M:DIA]FULLMOD=2 and find(TYPPTC,1,2)>0
 If [L]ISFULLMOD = 2
#  [L]ISFULLMOD = 2
  If filinfo(filpath("FIL","XXCORT","fde",APPLI),0)>0
   [L]ISOKSPOTTING = 2
  Endif
 Endif
 If [L]USESCM>0
  [L]ISOKSPOTTING = 2
 Endif
 If !find(TYPOBJ,"ADO","ADZ","ADF") or INTEGRE<2
  Gosub SAV_OPENI
  If left$(TYPOBJ,1)="~"
   Call ECR_TRACE(string$(TYPENR=-2,mess(55,125,1))+string$(TYPENR=2,mess(33,115,1))-":"-right$(TYPOBJ,2)-INTITOBJ,0) From GESECRAN : # Objet
  Else
   Call ECR_TRACE(string$(TYPENR=-2,mess(55,125,1))+string$(TYPENR=2,mess(33,115,1))-":"-TYPOBJ-NOMOBJ-INTITOBJ,0) From GESECRAN : # Objet
  Endif
  Gosub REST_OPENI
 Endif
 If INTEGRE<2 or !OKOBJ or (func ISOK_DELETE(TYPOBJ)=0 and TYPENR=-2)
  Gosub FIN_OBJ
 Else
  If TYPENR>0 & GADONIX=2 & filinfo(filpath("FIL","XXCORT","fde",APPLI),0)>=0 and[L]ISOKSPOTTING<>2
   Gosub MARQUAGE
  Endif
  #{X3-23597
  IDXOBJ += 1
  If SYRFLGUPD
   Call ASYNCTRACK(GACTX,"Patch","Patch Integration",IDXOBJ) From ASYRASYNC
  Endif
  #X3-23597}

  Case TYPOBJ
   When "AAA"   : Gosub PATCH      From PATCHMOD
   When "ABA"   : Gosub ABONNE     From PATCHDIV
   When "ABF"   : Gosub TABLE_FAIT From PATCHABI
   When "ABG"   : Gosub GRP_TACHES From PATCHDIV
   When "ABI"   : Gosub DIMENSION  From PATCHABI
   When "ABM"   : Gosub DATAMART   From PATCHABI
   When "ABO"   : Gosub ETAT_BO    From PATCHABI
   When "ABT"   : Gosub TACHES     From PATCHDIV
   When "ABV"   : Gosub SYNCHRO    From PATCHABI
   When "ACD"   : Gosub PLAGE      From PATCHDIV
   When "ACL"   : Gosub TAB_CONT   From PATCHDIV
   When "ACLA"  : Gosub CLASSES    From PATCHACLA
   When "ACN"   : Gosub CONSULT    From PATCHDIV
   When "ACT"   : Gosub ACTION     From PATCHACT
   When "ACST"  : Gosub ACONSTANT  From PATCHDIV
   When "ACTX"  : Gosub CONTEXT    From PATCHDIV
   When "ACV"   : Gosub ACTIV      From PATCHACV
   When "ADC"   : Gosub DICTRT     From PATCHDIV
   When "ADF"   : Gosub LIENS      From PATCHADO
   When "ADI"   : Gosub TABDIV     From PATCHADI
   When "ADO"   : Gosub ADOC       From PATCHADO
   When "ADP"   : Gosub PARAM      From PATCHADP
   When "ADV"   : Gosub PARAM_DIV  From PATCHADI
   When "ADX"   : Gosub TRTBIN     From PATCHDIV
   When "ADZ"   : Gosub AIDE_CHAMP From PATCHADO
   When "AFC"   : Gosub FONCTION   From PATCHAFC
   When "AGB"   : Gosub GLOBVAR    From PATCHDIV
   When "AGS"   : Gosub AGDPRSETTING From PATCHAGS
   When "AHH"   : Gosub HIERARCHIE From PATCHABI
   When "AHI"   : Gosub DICEPU     From PATCHDIV
   When "AII"   : Gosub COND_ABI   From PATCHABI
   When "ALH"   : Gosub REQUETES   From PATCHDIV
   When "ALQ"   : Gosub REQUETES   From PATCHDIV
   When "ALT"   : Gosub REQUETES   From PATCHDIV
   When "AMC"   : Gosub MOTCLE     From PATCHAMC
   When "ATYP"  : Gosub ATYPEPRO   From PATCHDIV
   When "AMK"   : Gosub ECRAN      From PATCHAMK
   When "AML"   : Gosub MENLOC     From PATCHAML
   When "ANG"   : Gosub NAVIG      From PATCHDIV
   When "ANM"   : Gosub COMPTEUR   From PATCHDIV
   When "AOB"   : Gosub AOBJET     From PATCHAOB
   When "AOE"   : Gosub MODELE     From PATCHAOE
   When "APH"   : Gosub MODELE_APH From PATCHDIV
   When "APR"   : Gosub PROCESSUS  From PATCHDIV
   When "ARA"   : Gosub PATTERN    From PATCHDIV
   When "ARP"   : Gosub ETAT       From PATCHARP
   When "ASU"   : Gosub SUBPRG     From PATCHDIV
   When "ASW"   : Gosub PRESENTATIONS From PATCHASW
   When "ASY"   : Gosub STYLES     From PATCHDIV
   When "ATB"   : Gosub TABLE      From PATCHATB
   When "ATN"   : Gosub TRANSAC    From PATCHDIV
   When "ATY"   : Gosub ATYPE      From PATCHATY
   When "AUR"   : Gosub URL        From PATCHDIV
   When "AUTI"  : Gosub AUTILITY   From PATCHAUTI
   When "AVW"   : Gosub VUE        From PATCHAVW
   When "AWA"   : Gosub REGLE_WRK  From PATCHWRK
   When "AWE"   : Gosub WEBSERVICE From PATCHDIV
   When "AWI"   : Gosub FENETRE    From PATCHAMK
   When "AWM"   : Gosub MODELE_WRK From PATCHWRK
   When "AWR"   : Gosub AFFECT_WRK From PATCHWRK
   When "AWW"   : Gosub PARAM_WRK  From PATCHWRK
   When "BIA"   : Gosub BIAR       From PATCHABI
   When "ELT"   : Gosub TRTWEB     From PATCHDIV
   When "ETA"   : Gosub ETABIN     From PATCHDIV
   When "EXE"   : Gosub EXEC
   When "IND"   : Gosub TRANSLATE  From PATCHIND
   When "TAB"   : Gosub TABNEUTRE  From PATCHDIV
   When "TFO"   : Gosub TABFOR     From PATCHDIV
   When "TRT"   : Gosub TRAITE     From PATCHDIV
   When "TXT"   : Gosub TEXTE      From PATCHDIV
   When "AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYX","AYO","AYI","AYM","AYC","AYU","ELX"
    ACTION = "INTEXE" : Gosub ACTION_XTEND
   When Default
        # cg oct 2017
        If left$(TYPOBJ,1)="X" and TYPPTC = 1
            # type de patch standard / standard patch type
            # type objet commence par X pour tests automatises en interne et patch std
            # object type starts with X for internal automated tests and patch std
            #
            # XPATCH_XXX.adx doit exister sinon on ne fait rien comme avant
            # XPATCH_XXX.adx must exist otherwise we do not do anything like before
            Local Integer OKTRT
            Local Char WTRTCOD(GLONADC)
            WTRTCOD = "XPATCH_"+TYPOBJ
            Call EXISTE_ADX("","",WTRTCOD,OKTRT) From ORDSYS
            If OKTRT
                 Gosub XPATCH From =WTRTCOD
            Else
                 OK = 1
                 ACTION = "INTEXE" : Gosub ACTION_PRODUIT
                 If OK
                      Gosub DIVERS From PATCHDIV
                 Endif
            Endif
        Else
            OK = 1
            ACTION = "INTEXE" : Gosub ACTION_PRODUIT
            If OK
                 Gosub DIVERS From PATCHDIV
            Endif
        Endif
  Endcase
  If [L]SYRFLGUPD=2
       Gosub UPDATE_PATCH_FLAG
  Endif
  If !OKOBJ
   If [F:ADS]MODULE(max(1,MODOBJ)-1)<>2
       Call ECR_TRACE("---"-mess(max(1,MODOBJ),14,1)-":"-mess(58,125,1),0) From GESECRAN
       # Module non implanté dans le dossier
   Else
      Call ECR_TRACE("---"-ACVOBJ-":"-mess(24,176,1),0) From GESECRAN
      # Code activité inactif
   Endif
   Gosub FIN_OBJ
  Endif
 Endif
 If ER
  If [L]APPLI=GDOSX3 : Return : Endif
  Gosub ERREURS
 Endif
 Goto OBJET
Else
 ER = 22 : Return
Endif
Return

#---------------------------------------------#
$EXEC
If OKPRGDOS(D)=0
 OKPRGDOS(D) = 1 : # Pour éviter de lancer des moulinettes sur des dossiers où le patch n'a pas été intégré
Endif
If !find(NOMOBJ,PROGRAMME(1..NBPROG))
 NBPROG += 1
 PROGRAMME(NBPROG) = NOMOBJ
Endif
Gosub FIN_OBJ
Return

#---------------------------------------------#
$ERREUR
GMESSAGE = errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-errm
GSILENCE = 0
Call ECR_TRACE("|"+GMESSAGE,1) From GESECRAN
GMESSAGE = ""
GSERVEUR = SAVSERV
If !GSERVEUR & (dim(INTEGRE)<0 or INTEGRE<>3)
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
If dim(SAVGVALID)>0 and dim(GVALIDDIFF)>0
  GVALIDDIFF=SAVGVALID
Endif
End

#--------------------------------------------------------------#
$ERREURS
Case ER
 When 1
  Call ECR_TRACE(mess(35,115,1),1) From GESECRAN : # Fin de fichier anormale
 When 93
  Call ECR_TRACE(NOMPROG-":"-mess(13,123,1),1) From GESECRAN : # Traitement incorrect
 When 94
  Call ECR_TRACE(MODDON-":"-mess(7,140,1),1) From GESECRAN : # Modèle de données inexistant
 When 95
  Call ECR_TRACE(mess(170,139,1),1) From GESECRAN : # Ce patch ne correspond pas au produit courant
 When 96
  Call ECR_TRACE(mess(139,139,1),1) From GESECRAN : # Type de patch incorrect
 When 97
  # Ce patch ne peut être intégré que dans le dossier superviseur
  Call ECR_TRACE(mess(135,125,1),1) From GESECRAN
 When 98
  Case PRODUIT
   When "SU" : ERFIC = "Superviseur"
   When "X3" : ERFIC = mess(1,2902,1)
   When "GX" : ERFIC = mess(3,2902,1)
   When "PA" : ERFIC = mess(2,2902,1)
   When "AB" : ERFIC = mess(4,2902,1)
  Endcase
  Call ECR_TRACE(mess(133,125,1)-":"-ERFIC,1) From GESECRAN : # Ce patch doit être intégré sur un produit
 When 99 : # Erreur transactionnelle
  Call ECR_TRACE(mess(147,100,1)-":"-ERFIC,1) From GESECRAN : # ------------------- Erreur -------------------
 When Default
  Call ECR_TRACE(mess(36,115,1)-"("+num$(ER)+")",1) From GESECRAN : # Structure fichier incorrecte
Endcase
Return

#---------------------------------------------#
$SUIVI
Local File =APPLI+".APATCH" [APT]
Read [APT]APT0 Last
If fstat>2
 PNUM = 1
Else
 PNUM = [F:APT]NUM+1
Endif
Trbegin [APT]
 Raz [F:APT]
 [F:APT]NUM     = PNUM
 [F:APT]FIC     = TRAIT(P)
 [F:APT]DAT     = date$
 [F:APT]USR     = GUSER
 #106969 [F:APT]RELEASE = GVERSION
 [F:APT]RELEASE=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))


 I1_ = instr(1,TRAIT(P),"_")
 I2_ = instr(I1_+1,TRAIT(P),"_")
 I3_ = instr(I2_+1,TRAIT(P),"_")
 If I1_<>0 & I2_<>0 & find(left$(TRAIT(P),I1_-1),"X","Y","Z","P","PX","PP","PG","PA","DX","DP","DG","DA","TX","TP","TG","TA")
  [F:APT]TYP  = left$(TRAIT(P),I1_-1)
  [F:APT]NUMP = val(seg$(TRAIT(P),I1_+1,I2_-1))
#106969
#  If I3_
#   [F:APT]VER  = val(seg$(TRAIT(P),I2_+1,I3_-1))
#  Else
#   [F:APT]VER  = val(right$(TRAIT(P),I2_+1))
#  Endif
  If I3_
   [F:APT]FICRELABR  = seg$(TRAIT(P),I2_+1,I3_-1)
  Else
   [F:APT]FICRELABR  = right$(TRAIT(P),I2_+1)
  Endif

### IG : 18/06/01 on renseigne le n° de patch si possible
  If IPAT > 0
   For WI=1 To IPAT
    If [F:APT]NUMP>= PATMNTD(WI) and [F:APT]NUMP<=PATMNTF(WI)
       [F:APT]PATNUM = PATNUML(WI)
    Endif
   Next WI
  Endif
###IG

 Endif
 [F:APT]COMMENT = COMMENT
 Write [APT]
 If fstat
  Call FSTA("APT") From GLOCK
 Endif
Commit
Close Local File [APT]
Return

