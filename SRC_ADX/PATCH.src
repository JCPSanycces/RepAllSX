#-----------------------------------------------------------------#
$MARQUAGE
Raz MCLE2
MOBJ  = TYPOBJ
Case MOBJ
 When "TAB","ELT","BIA" : # non marqué
 When "ADO"
  MCLE1    = func AFNC.PART(NOMOBJ,1)
  MCLE2(0) = GLANGUE
  MCLE2(1) = func AFNC.PART(NOMOBJ,2)
 When "ADZ"
  MCLE1    = NOMOBJ
  MCLE2(0) = GLANGUE
 When "ADI","ASU","ASB","AWR","TFO","ADF","TCA","AVR","APP","GTC","APR"
  MCLE1    = func AFNC.PART(NOMOBJ,2)
  MCLE2(0) = func AFNC.PART(NOMOBJ,1)
 When Default
  MCLE1    = NOMOBJ
Endcase
#CHECK UNUSED_BEGIN
Call TRACE_COR(MOBJ,MCLE1,MCLE2,"M"+string$(MNUMX<>"","~"+MNUMX)) From SUBXCB
#CHECK UNUSED_END
Return

#---------------------------------------------#
# Sous-programmes généraux
#---------------------------------------------#

$LIRE
Raz CHAMP, TYPENR
Rdseq TYPENR,CHAMP
#Infbox num$(TYPENR)+chr$(13)+CHAMP(1)+chr$(13)+CHAMP(2)+chr$(13)+CHAMP(3)
Call DELIMITE(CHAMP)
Return

#---------------------------------------------#
$LIRE_ZONE
Gosub LIRE
Raz VARIA, IND, VALEUR, LAN, DIME, TYP
Case TYPENR
 When 6  : # Fin de fichier
  Return
 When 4  : # Zone normale
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  VALEUR = CHAMP(3)
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  TYP    = evalue("type([F:"+ABR+"]"+VARIA+")")
  If DIME>1 & IND=0
   Gosub VIDE_ZONE
  Endif
 When 22,24 : # Blob
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  DIML   = evalue("lobsize([F:"+ABR+"]"+VARIA+")")
  If DIME>1 & IND=0
   Gosub VIDE_ZONE
  Endif
  Gosub LIRE_BLOB
 When 23,25 : # Clob
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  DIML   = evalue("lobsize([F:"+ABR+"]"+VARIA+")")
  If DIME>1 & IND=0
   Gosub VIDE_ZONE
  Endif
  Gosub LIRE_CLOB
 When 5 : # Zone texte dico ATX
  NBLAN = 0
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  TYP    = evalue("type([F:"+ABR+"]"+VARIA+")")
  If DIME>1 & IND=0
   Gosub VIDE_ZONE
  Endif
  NUMTXT = val(CHAMP(5))
  #U11 COMT   = CHAMP(6)
  LANT   = CHAMP(4) :#113978
  While CHAMP(4)<>"***"
   NBLAN += 1
   TEXTE(NBLAN)  = CHAMP(3)
   LANGUE(NBLAN) = CHAMP(4)
   COMT(NBLAN)  = CHAMP(6)
  Gosub LIRE
   If fstat
    ER = 1  : Break
   Elsif TYPENR<>5 & TYPENR<>9
    ER = 23 : Break
   Endif
  Wend
 When 9 : # Zone texte traduisible AXX
  NBLAN = 0
  VARIA  = CHAMP(1)
  IND    = val(CHAMP(2))
  DIME   = IND+1
  ID1    = CHAMP(5)
  ID2    = CHAMP(6)
  While CHAMP(4)<>"***"
   NBLAN += 1
   TEXTE(NBLAN)  = CHAMP(3)
   LANGUE(NBLAN) = CHAMP(4)
   Gosub LIRE
   If fstat
    ER = 1  : Break
   Elsif TYPENR<>5 & TYPENR<>9
    ER = 23 : Break
   Endif
  Wend
 When Default
  ER = 24 : Return
Endcase
Return

#-----------------------#
$LIRE_BLOB
Rdseq NOCT
If NOCT>DIML
 # La taille du $1$ est trop grande ($2$) pour le champ $3$
 Call ECR_TRACE(func AFNC.MES3(mess(74,143,1),mess(9,30,1),num$(NOCT),VARIA),-1) From GESECRAN
Endif
If TYPENR=24 : # Nouvelle méthode
 Getseq 1,BLOB Sized NOCT
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Elsif TYPENR=22 : # Ancienne méthode
 FIC_TMP = filpath("tmp",num$(adxuid(2)),"tmp")
 Openo FIC_TMP,0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   Putseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   Putseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
 Openo
 Openi FIC_TMP Using [TMP_]
 Getseq 1,BLOB Using [TMP_]
 Openi Using [TMP_]
 Call EFFACE(FIC_TMP,STAT) From ORDSYS
Endif
Return

#-----------------------#
$LIRE_CLOB
Rdseq NOCT
If NOCT>DIML
 # La taille du $1$ est trop grande ($2$) pour le champ $3$
 Call ECR_TRACE(func AFNC.MES3(mess(74,143,1),mess(9,30,1),num$(NOCT),VARIA),-1) From GESECRAN
Endif
If TYPENR=25 : # Blob -> Clob
 Getseq 1,BLOB Sized NOCT
 K = strDecode(BLOB,CLOB,GUTF8)
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Elsif TYPENR=23 : # Ancienne méthode
 #FIC_TMP = num$(adxuid(2))
 #If dim([M:PATA]NBFIC)>0
 # FIC_TMP += "_"+num$( [M:PATA]NBFIC)
 #Endif
 #If dim([M:PATA]NBDOS)>0
 # FIC_TMP += "_"+num$( [M:PATA]NBDOS)
 #Endif
 #FIC_TMP += "_"+num$(adxseek(0))
 #FIC_TMP = filpath("tmp",FIC_TMP,"tmp")
 FIC_TMP = filpath("tmp",num$(adxuid(2)),"tmp")
 Openo FIC_TMP,0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   Putseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   Putseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
 Openo
 Openi FIC_TMP Using [TMP_]
 SAVIFS = adxifs
 SAVIRS = adxirs
 SAVIUM = adxium
 adxifs = ""
 adxirs = ""
 adxium = GUTF8
 Rdseq CLOB Using [TMP_]
 Openi Using [TMP_]
 adxifs = SAVIFS
 adxirs = SAVIRS
 adxium = SAVIUM
 Call EFFACE(FIC_TMP,STAT) From ORDSYS
Endif
Return

#---------------------------------------------#
$VIDE_ZONE
Local Integer I
Local Clbfile WCLOB : Raz WCLOB
Local Blbfile WBLOB : Raz WBLOB
Local Char WCHARVIDE(10) : Raz WCHARVIDE
Local Char WDATTIMVIDE(30) : WDATTIMVIDE="0000-00-00T00:00:00Z"
Local Char WDATVIDE(30) : WDATVIDE="000000"

For I=0 To DIME-1
 If find(TYPENR,22,24) : # Blob
  Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With WBLOB
 Elsif find(TYPENR,23,25) : # Clob
  Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With WCLOB
 Elsif TYPENR=4
  Case TYP
   When 1,2,4,5,6,7,8,9
    Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With val(WCHARVIDE)
   When 3
    Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With WDATVIDE
   When 526
    Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With gdatetime$(WDATTIMVIDE)
   When Default
    Assign "[F:"+ABR+"]"+VARIA+"("+num$(I)+")" With WCHARVIDE
  Endcase
 Endif
Next I
Return
#---------------------------------------------#
$AFF_ZONE
Local Integer ASTATUS
Local Integer DIFF_TEXTE
Local Char MESSAGE(250)
If find(TYPENR,22,24) : # Blob
     Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With BLOB
Elsif find(TYPENR,23,25) : # Clob
     Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With CLOB
Elsif TYPENR=4
     Case TYP
          When 1,2,4,5,6,7,8,9
                Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With val(VALEUR)
          When 526
                Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With gdatetime$(VALEUR)
          When Default
                Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With VALEUR
          Endcase
Elsif TYPENR=5
    NUMERO = 0
    # On essaye désormais de conserver le même numéro
    # BY 10/05/2005 désormais on l'impose... (mb 15.2.8 sauf si patch SU vers PRO)
    L = find([F:ADS]LAN(0),LANGUE(1..NBLAN))
    #115210/6
    If L & [L]TEXTE(L)<>"" & NUMTXT<>0 & (NUMTXT<GMAXTXTSTD | NUMTXT>GNEWTXTSTD)
& & (!FORCE_SUP | ([L]ISFULLMOD=2 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2")) :#115210/6
          NUMERO = NUMTXT
    Endif
    For LL=0 To [F:ADS]NBRLAN-1
    #113978
        If FORCE_SUP & LANT<>[F:ADS]LAN(0)
             Call ECR_TRACE("First language in the patch file <> first language of folder"-[F:ADS]DOSSIER,1) From GESECRAN
             NUMERO = 0: GOK = 0 : ERFIC = "ATEXTE"-[F:ADS]LAN(0)-num$(NUMERO) : Break
        Endif
        #
        L = find([F:ADS]LAN(LL),LANGUE(1..NBLAN))
        If L
            If NUMERO=0 & [L]TEXTE(L)<>"" : # La première langue qui se présente
            #115210/6
                If NUMTXT<>0 & (NUMTXT<GMAXTXTSTD | NUMTXT>GNEWTXTSTD)
                    Filter [ATX] Where (NUMERO<GMAXTXTSTD | NUMERO>GNEWTXTSTD)
                Elsif NUMTXT<>0 & NUMTXT>=GMAXTXTSTD & NUMTXT<GNEWTXTSTD
                    Filter [ATX] Where NUMERO>=GMAXTXTSTD & NUMERO<GNEWTXTSTD
                Endif
                #U11
                If FORCE_SUP & NUMERO=0
                    For [ATX]TEXTE Where LAN=LANGUE(L) & TEXTE=[L]TEXTE(L) & [F]NUMERO=NUMTXT
                        #U11 If COMT="" or [F:ATX]COMMENT=COMT
                        If [L]COMT(L)="" or [F:ATX]COMMENT=[L]COMT(L)
                              NUMERO = [F:ATX]NUMERO : Break
                        Endif
                    Next
                Endif
                If NUMERO=0
                    For [ATX]TEXTE Where LAN=LANGUE(L) & TEXTE=[L]TEXTE(L)
                        #U11 If COMT="" or [F:ATX]COMMENT=COMT
                        If [L]COMT(L)="" or [F:ATX]COMMENT=[L]COMT(L)
                              NUMERO = [F:ATX]NUMERO : Break
                        Endif
                    Next
                Endif
                Filter [ATX]
                If NUMERO=0
                      # On patche dans la zone 0..100000 si le texte d'origine est <100000
                      #115210/6
                      If NUMTXT<>0 & (NUMTXT<GMAXTXTSTD | NUMTXT>GNEWTXTSTD)
                           #
## ERB fev 2017 : This part was put in comment in order to allow developpers to integrate patches without creaing new texts in the text server
# not comment all the lines.....it is wrong.....
# issue 109702 : september 2018
# comment not for all texts .. we need to be able to create specif texts

##                            If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
##                                  ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,LANGUE(L),[F:ADS]LAN,[L]TEXTE(L), [L]COMT(L),NUMERO,MESSAGE)
##                                  If ASTATUS<>[V]CST_AOK
##                                         ERFIC=MESSAGE : GOK=0 : Break
##                                  Endif
##                            Else
##                                  Filter [ATX] Where NUMERO<GMAXTXTSTD Order By Key CLE=NUMERO;LAN
##                                  Read [ATX] Last
##                                  Filter [ATX]
##                                  If fstat>2 : NUMERO = 1 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
##                            Endif
                            Call ECR_TRACE("Can not create text in standard rang "- [L]TEXTE(L) -"in this folder",-1) From GESECRAN
                     Endif
                     # issue 109702 : september 2018
                     # dans tous les cas on fait du spe en texte appartenant à la tranche >100000 et < 1000000
                     Filter [ATX] Where NUMERO>GMAXTXTSTD & NUMERO<GNEWTXTSTD Order By Key CLE=NUMERO;LAN
                     Read [ATX] Last
                     Filter [ATX]
                     If fstat>2 : NUMERO = GMAXTXTSTD+1 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
                     If NUMERO>0
                            Raz [F:ATX]
                            [F:ATX]LAN     = LANGUE(L)
                            [F:ATX]NUMERO  = NUMERO
                            [F:ATX]TEXTE   = [L]TEXTE(L)
                            #U11 [F:ATX]COMMENT = COMT
                            [F:ATX]COMMENT = [L]COMT(L)
                            If dim([F:ATX]LANORI)>0 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
                                  ASTATUS = func ATXTSVC.GET_LANORI(GPRODUIT, NUMERO, LANGUE(L),[F:ATX]LANORI,MESSAGE)
                            Endif
                            Gosub INITEXTE From PATCH
                            If FORCE_SUP
                                    Call ECR_TRACE('Create new text number '+num$(NUMERO)+' ('+[F:ATX]LAN+') "'+[F:ATX]TEXTE+'"',-1) From GESECRAN
                            Endif
                            Write [ATX]
                            If fstat
                                  Call LOG_ERROR_DETAILS(1, "ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
                                  GOK = 0 : ERFIC = "ATEXTE"-LANGUE(L)-num$(NUMERO) : Break
                            Else
                                  # cg on ne trace que si write ok
                                  If TYPOBJ = "IND"
                                        Gosub SEARCH_ELT From PATCHIND
                                  Endif
                            Endif
                      Endif
                Endif
            Elsif NUMERO<>0 : # On a déjà attribué un numéro, il faut le respecter
                Read [ATX]NUMERO = LANGUE(L);NUMERO
                If fstat
                    Raz [F:ATX]
                    [F:ATX]LAN     = LANGUE(L)
                    [F:ATX]NUMERO  = NUMERO
                    [F:ATX]TEXTE   = [L]TEXTE(L)
                    #U11 [F:ATX]COMMENT = COMT
                    [F:ATX]COMMENT = [L]COMT(L)
                    If dim([F:ATX]LANORI)>0 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
                          ASTATUS = func ATXTSVC.GET_LANORI(GPRODUIT, NUMERO, LANGUE(L),[F:ATX]LANORI,MESSAGE)
                    Endif
                    Gosub INITEXTE From PATCH
                    If FORCE_SUP
                          Call ECR_TRACE('Create text ('+[F:ATX]LAN+') "'+[F:ATX]TEXTE+'" no '+num$(NUMERO),-1) From GESECRAN
                    Endif
                    Write [ATX]
                    # cg on ne trace que si write ok
                    If fstat = 0 and TYPOBJ = "IND"
                            Gosub SEARCH_ELT From PATCHIND
                    Elsif fstat<>[V]CST_AOK
                            Call LOG_ERROR_DETAILS(1, "ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
                    Endif
                #U11 Elsif LL>0 or [F:ATX]COMMENT<>COMT or [F:ATX]TEXTE<>[L]TEXTE(L)
                Elsif LL>0 or [F:ATX]COMMENT<>[L]COMT(L) or [F:ATX]TEXTE<>[L]TEXTE(L)
                    #U11 If [F:ATX]COMMENT<>COMT or [F:ATX]TEXTE<>[L]TEXTE(L)
                    If [F:ATX]COMMENT<>[L]COMT(L) or [F:ATX]TEXTE<>[L]TEXTE(L)
                          DIFF_TEXTE=1
                    Else
                          DIFF_TEXTE=0
                    Endif
                    # comme le superviseur fait tjs le rewrite si ll> 0
                    # Dans le cas de type IND on ne fait le rewrite que si necessaire
                    # a savoir texte vraiment modifié
                    If TYPOBJ = "IND"
                          If [F:ATX]TEXTE<>[L]TEXTE(L)
                                  # ok pour le rewrite si je fais rien
                                  [F:ATX]TEXTE   = [L]TEXTE(L)
                                  #U11 [F:ATX]COMMENT = COMT
                                  [F:ATX]COMMENT = [L]COMT(L)
                                  Gosub INITEXTE From PATCH
                                  If FORCE_SUP & DIFF_TEXTE
                                        Call ECR_TRACE('Update text number ('+[F:ATX]LAN+') "'+[F:ATX]TEXTE+'" no '+num$([F:ATX]NUMERO),-1) From GESECRAN
                                  Endif
                                  If APPLI=GDOSX3 & GADONIX=2 & DIFF_TEXTE & [L]ISFULLMOD<>2
                                         Call ECR_TRACE("Text number"-num$([F:ATX]NUMERO)-'"'+[F:ATX]TEXTE+'"'-":\Can not update file ATEXTE on this folder",1) From GESECRAN
                                  Else
                                         Rewrite [ATX]
                                         If fstat = 0
                                              Gosub SEARCH_ELT From PATCHIND
                                         Else
                                              Call LOG_ERROR_DETAILS(2, "ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
                                         Endif
                                  Endif
                          Endif
                    Else
                          [F:ATX]TEXTE   = [L]TEXTE(L)
                          #U11 [F:ATX]COMMENT = COMT
                          [F:ATX]COMMENT = [L]COMT(L)
                          LLANORI = [F:ATX]LANORI
                          If dim([F:ATX]LANORI)>0 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
                                ASTATUS = func ATXTSVC.GET_LANORI(GPRODUIT, NUMERO, LANGUE(L),[F:ATX]LANORI,MESSAGE)
                          Endif
                          # Issue X3-69277 - 2018-01-10 by CCC : Rewrite only if somthing has been modified
                          If DIFF_TEXTE=1 | [F:ATX]LANORI<>LLANORI
                                  Gosub INITEXTE From PATCH
                                  If FORCE_SUP & DIFF_TEXTE
                                          Call ECR_TRACE('Update text number ('+[F:ATX]LAN+') "'+[F:ATX]TEXTE+'" no '+num$([F:ATX]NUMERO),-1) From GESECRAN
                                  Endif
                                  If APPLI=GDOSX3 & GADONIX=2 & DIFF_TEXTE & [L]ISFULLMOD<>2
                                        Call ECR_TRACE("Text number"-num$([F:ATX]NUMERO)-'"'+[F:ATX]TEXTE+'"'-":\Can not update file ATEXTE on this folder",1) From GESECRAN
                                  Else
                                  Rewrite [ATX]
                                  If fstat
                                        Call LOG_ERROR_DETAILS(2, "ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
                                  Endif
                          Endif
                    Endif
                Endif
            Endif
            If fstat
                GOK = 0 : ERFIC = "ATEXTE"-LANGUE(L)-num$(NUMERO) : Break
            Endif
          Endif
        Endif
    Next LL
    # cg 5 juillet 2011
    # cas de la mise a jour uniqueemnt de texte cas des traductions
    # pas de assign a faire
    # par contre si numero = 0 et cas std on force quand même le 0 pour eviter d avoir des trucs bizarres
    If TYPOBJ <> "IND"
        Assign "[F:"+ABR+"]"+VARIA+"("+num$(IND)+")" With NUMERO
    Endif
Elsif TYPENR=9
 For LL=0 To [F:ADS]NBRLAN-1
  L = find([F:ADS]LAN(LL),[L]LANGUE(1..NBLAN))
  If L
   Read [AXX]AXX0 = FICHIER;VARIA;[L]LANGUE(L);ID1;ID2
   If fstat
    Raz [F:AXX]
    [F:AXX]CODFIC = FICHIER
    [F:AXX]ZONE   = VARIA
    [F:AXX]LANGUE = [L]LANGUE(L)
    [F:AXX]TEXTE  = [L]TEXTE(L)
    [F:AXX]IDENT1 = ID1
    [F:AXX]IDENT2 = ID2
    Write [AXX]
    If fstat
     GOK = 0 : ERFIC = "ATEXTRA"-[L]LANGUE(L)-FICHIER-VARIA-ID1-ID2 : Break
    Endif
   Else : # mb 20.4.6 Demande30585
    [F:AXX]TEXTE  = [L]TEXTE(L)
    Rewrite [AXX]
    If fstat
     GOK = 0 : ERFIC = "ATEXTRA"-[L]LANGUE(L)-FICHIER-VARIA-ID1-ID2 : Break
    Endif
   Endif
  Endif
 Next LL
Endif
Return

#---------------------------------------------#
$INITEXTE
[F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
If dim([F:ATX]UPDDAT)>0 : [F:ATX]UPDDAT = date$ : Endif
Read [AVO]AVO0(1) = [F:ATX]LAN
If !fstat & dim([F:AVO]CUR)>0 & [F:AVO]CUR<>0
 Read [AVO]AVO0 = [F:ATX]LAN;[F:AVO]CUR;1;0;[F:ATX]NUMERO
 If !fstat
  If !find([F:ADS]DOSSIER+"~"+[F:ATX]LAN,AVODOSLAN(1..AVONUM))
   AVONUM += 1
   AVODOSLAN(AVONUM) = [F:ADS]DOSSIER+"~"+[F:ATX]LAN
  Endif
 Endif
Endif
Return

#---------------------------------------------#
$FIN_OBJ
If find(TYPOBJ,"TRT") and TYPENR<>-2
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif find(TYPOBJ,"ADX","ELT","BIA","ELX")
 Rdseq NOCT
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif TYPOBJ="ETA"
 Repeat
  Gosub LIRE
  If TYPENR=3
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Endif
  Endif
 Until TYPENR=7 or ER
Elsif TYPOBJ="TAB"
 Repeat
  Gosub LIRE
  If TYPENR=3
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Break : Endif
  Endif
 Until TYPENR<>3
 If ER : Return : Endif
Endif
If !find(TYPOBJ,"TAB","ETA")
 Repeat
  Gosub LIRE
  If find(TYPENR,22,24,23,25) : # Blob , Clob
   Rdseq NOCT
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat
    ER = 33 : Break
   Endif
  Endif
 Until fstat or TYPENR=7
 If fstat : ER = 25 : Endif
Endif
Return

#---------------------------------------------#
$FIN_FIC
Repeat
 Gosub LIRE
Until fstat or TYPENR=6
If fstat : ER = 26 : Endif
Return

#-----------------------#
$SAV_OPENI
Local Char     SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM , SAVPOS
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
Return

#-----------------------#
$REST_OPENI
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Openi FICPATCH , SAVPOS
Return

#---------------------------------------------#
Subprog DELIMITE(VALIMP)
Variable Char VALIMP()(1..)
Local Integer I , J , K , L , N , IMAX
Local Char    QUOTE(1)
QUOTE = '"'
IMAX = dim(VALIMP)
For I=1 To IMAX
 If VALIMP(I)<>""
  If left$(VALIMP(I),1)=QUOTE
   L = len(VALIMP(I))
   If right$(VALIMP(I),L)=QUOTE
    VALIMP(I) = seg$(VALIMP(I),2,L-1)
   Else
    J = I
    Repeat
     J += 1
     VALIMP(I) = VALIMP(I)+adxifs+VALIMP(J)
     L = len(VALIMP(I))
    Until right$(VALIMP(I),L)=QUOTE | J>=IMAX
    VALIMP(I) = seg$(VALIMP(I),2,L-1)
    N = J-I
    For K=I+1 To IMAX-N
     VALIMP(K) = VALIMP(K+N)
    Next K
    For K=IMAX-N+1 To IMAX
     VALIMP(K) = ""
    Next K
   Endif
  Endif
  VALIMP(I) = ctrans(VALIMP(I),chr$(255)+chr$(254),","+chr$(10))
 Endif
Next I
End

#-------------------------------------------------------#
# Used at start of integration for monitoring
#-------------------------------------------------------#

Subprog INITIAL_PATCH(NUMREQ,SYRUPDATE,SYRIDENT,FOLDS,NBMAINT)
Value Integer NUMREQ
Value Char SYRUPDATE,FOLDS()(1..),SYRIDENT
Value Integer NBMAINT
If [L]NUMREQ=0 or SYRUPDATE="" or SYRIDENT="" : End : Endif
If clalev([F:APL])=0   : Local File APATCHLOG [F:APL] : Endif
If clalev([F:APLD0])=0 : Local File APATCHLOGD  [F:APLD] : Endif

Local Integer I , J
GOK = 1
Trbegin [APL]
 For I=1 To dim([L]FOLDS)
  If [L]FOLDS(I)="" : Break : Endif
  Gosub _PATCH
  If GOK<>1 : Break : Endif
 Next I
 If GOK<>1 : Rollback : End : Endif
Commit
End

#--------------#
$_PATCH
Read [F:APL]APT0=[L]FOLDS(I);[L]SYRUPDATE;[L]SYRIDENT
If fstat
 Raz [F:APL]
 [F:APL]AFOLDER      = [L]FOLDS(I)
 [F:APL]AUPDATE    = [L]SYRUPDATE
 [F:APL]IDENT = [L]SYRIDENT
 [F:APL]FLGPAT    = 1 : # En attente
 [F:APL]FLGTRT    = 1 : # En attente
 [F:APL]FLGVAL    = 1 : # En attente
 [F:APL]REQUESTID    = [L]NUMREQ
 [F:APL]NBMAINT = NBMAINT
 Write [F:APL]
 If fstat
  GOK = 0 : Call FSTA("APL") From GLOCK
 Endif
 Delete [F:APLD] Where AFOLDER= [L]FOLDS(I) and AUPDATE=[L]SYRUPDATE and  IDENT=[L]SYRIDENT
 If fstat=1 : GOK=-1 : GLOCK="$APATCHLOGD" : Return
 Elsif fstat>5 : GOK=0 : Call FSTA("APLD") From GLOCK : Return
 Endif
Else
 [F:APL]CPTMAINT = 0
 [F:APL]FLGMAINT = 0
 [F:APL]FLGPAT    = 1 : # En attente
 [F:APL]FLGTRT    = 1 : # En attente
 [F:APL]FLGVAL    = 1 : # En attente
 [F:APL]REQUESTID    = [L]NUMREQ
 [F:APL]NBMAINT = NBMAINT
 Rewrite [F:APL]
 If fstat
  GOK = 0 : Call FSTA("APL") From GLOCK
 Endif
Endif
Return

#----------------------------------------------------------------------#
# Used for monitoring integration
#----------------------------------------------------------------------#

Subprog UPDATE_PATCH(SYRUPDATE,SYRIDENT,FOLD,CURMAINT,FLGPAT,FLGTRT,FLGVAL)
Value Char    SYRUPDATE,SYRIDENT,FOLD , CURMAINT
Value Integer FLGPAT , FLGTRT , FLGVAL

Local Char TRACK(250)

If SYRUPDATE="" or SYRIDENT="" : End : Endif
If clalev([F:APL])=0 : Local File APATCHLOG [F:APL] : Endif
GOK = 1
Trbegin [F:APL]
 Read [F:APL]APT0=[L]FOLD;[L]SYRUPDATE;[L]SYRIDENT
 If !fstat
  If len(CURMAINT)
   [F:APL]MAINTENANCE=CURMAINT
  Endif
  If [L]FLGPAT>0
   [F:APL]FLGMAINT = [L]FLGPAT
   If [L]FLGPAT=3 and [F:APL]FLGPAT=5:# End
    [F:APL]FLGPAT= 6
   Else
    [F:APL]FLGPAT = max([F:APL]FLGPAT,[F:APL]FLGMAINT)
   Endif
  Endif
  If [L]FLGTRT>0
   If [L]FLGTRT=3 and [F:APL]FLGTRT=5:# End
    [F:APL]FLGPAT= 6
   Else
    [F:APL]FLGTRT = max([F:APL]FLGTRT,[L]FLGTRT)
   Endif
  Endif
  If [L]FLGVAL>0
   If [L]FLGVAL=3 and [F:APL]FLGVAL=5:# End
    [F:APL]FLGVAL= 6
   Else
    [F:APL]FLGVAL = max([F:APL]FLGVAL,[L]FLGVAL)
   Endif
  Endif
  If [F:APL]ERRMAINT="" and [L]FLGPAT>3
   [F:APL]ERRMAINT=[F:APL]MAINTENANCE
  Endif
  If [L]FLGPAT=2
   [F:APL]CPTMAINT +=1
  Endif
  Rewrite [F:APL]
  If fstat
   GOK = 0 : Call FSTA("APL") From GLOCK
  Elsif dim(GACTX)>0
    TRACK = SYRIDENT+ " applied on "+FOLD
    If [L]FLGPAT
    TRACK += " : "+mess([L]FLGPAT,7883,1)
    Endif
    If len(CURMAINT)
     TRACK += " ("+CURMAINT+")"
    Endif
    Call ADDDIAGNOSE(GACTX, TRACK , [V]CST_AINFO) From ASYRASYNC
  Endif
 Endif
 If GOK=0 : Rollback : End : Endif
Commit
End

$UPDATE_PATCH_FLAG
If [L]SYRUPDATE="" or [L]SYRIDENT="" : Return : Endif
If clalev([F:APL])=0 : Local File APATCHLOG [F:APL] : Endif
If clalev([F:APLD])=0 : Local File APATCHLOGD [F:APLD] : Endif

GOK = 1
Trbegin [F:APL]
 Read [F:APL]APT0=[L]APPLI;[L]SYRUPDATE;[L]SYRIDENT
 If !fstat
  Local Integer _NB
  If dim([L]ISTYPMOD)>0 and dim([F:APL]ISTYPMOD)>0
   [F:APL]ISTYPMOD = [L]ISTYPMOD
  Endif
  If dim([L]ISMENMOD)>0 and dim([F:APL]ISMENMOD)>0
   [F:APL]ISMENMOD = [L]ISMENMOD
  Endif
  If dim([L]ISNEWFUN)>0 and dim([F:APL]ISNEWFUN)>0
   [F:APL]ISNEWFUN = [L]ISNEWFUN
  Endif
  If dim([L]ISASYMOD)>0 and dim([F:APL]ISASYMOD)>0
   [F:APL]ISASYMOD = [L]ISASYMOD
  Endif
  If dim([L]ISAGBMOD)>0 and dim([F:APL]ISAGBMOD)>0
   [F:APL]ISAGBMOD = [L]ISAGBMOD
  Endif
  If dim([L]ISACSTMOD)>0 and dim([F:APL]ISACSTMOD)>0
   [F:APL]ISACSTMOD = [L]ISACSTMOD
  Endif
  If dim([L]ISACTXMOD)>0 and dim([F:APL]ISACTXMOD)>0
   [F:APL]ISACTXMOD = [L]ISACTXMOD
  Endif
  If dim([L]ISASWMOD)>0 and dim([F:APL]ISASWMOD)>0
   [F:APL]ISASWMOD = [L]ISASWMOD
  Endif
  If dim([L]ISVUE)>0 and dim([F:APL]ISVUE)>0
   [F:APL]ISVUE = [L]ISVUE
  Endif
  If dim([L]ISMENVALMOD)>0 and dim([F:APL]ISMENVALMOD)>0
   [F:APL]ISMENVALMOD = [L]ISMENVALMOD
  Endif
  If dim([L]ISTRTUSED)>0 and dim([F:APL]ISTRTUSED)>0
   [F:APL]ISTRTUSED = [L]ISTRTUSED
  Endif
  If dim([L]DETAR_WEB)>0 and dim([F:APL]DETAR_WEB)>0
   [F:APL]DETAR_WEB = [L]DETAR_WEB
  Endif
  If dim([L]DETAR_X3C)>0 and dim([F:APL]DETAR_X3C)>0
   [F:APL]DETAR_X3C = [L]DETAR_X3C
  Endif
  If dim([L]DETAR_STD)>0 and dim([F:APL]DETAR_STD)>0
   [F:APL]DETAR_STD = [L]DETAR_STD
  Endif
  If dim([L]DETAR_VER)>0 and dim([F:APL]DETAR_VER)>0
   [F:APL]DETAR_VER = [L]DETAR_VER
  Endif
  If dim([L]DETAR_PER)>0 and dim([F:APL]DETAR_PER)>0
   [F:APL]DETAR_PER = [L]DETAR_PER
  Endif
  If dim([L]DETAR_CLI)>0 and dim([F:APL]DETAR_CLI)>0
   [F:APL]DETAR_CLI = [L]DETAR_CLI
  Endif
  Rewrite [F:APL]
  If fstat
   GOK = 0 : Call FSTA("APL") From GLOCK
  Endif
  If GOK=0 : Rollback : Return : Endif
  If dim([L]NUMINDTXT)>0 and  dim([L]NUMINDNUM)>0
   For [L]_NB=1 To dim([L]NUMINDTXT)
    If [L]NUMINDTXT([L]_NB)<>"" and [L]NUMINDNUM([L]_NB)>0 :#113816
     [F:APLD]AFOLDER= [L]APPLI
     [F:APLD]AUPDATE=[L]SYRUPDATE
     [F:APLD]IDENT=[L]SYRIDENT
     [F:APLD]TYP= "NUMINDTXT"
     [F:APLD]LINE = [L]_NB
     [F:APLD]TXT = [L]NUMINDTXT([L]_NB)
     [F:APLD]NUM = [L]NUMINDNUM([L]_NB)
     Write [F:APLD]
     If fstat
      GOK = 0 : Break
     Endif
    Endif
   Next
   If GOK=0 : Rollback : Return : Endif
  Endif
  If dim([L]AVONUM)>0
   For _NB=1 To [L]AVONUM
    [F:APLD]AFOLDER= [L]APPLI
    [F:APLD]AUPDATE=[L]SYRUPDATE
    [F:APLD]IDENT=[L]SYRIDENT
    [F:APLD]TYP= "AVODOSLAN"
    [F:APLD]LINE = [L]_NB
    [F:APLD]TXT = [L]AVODOSLAN(_NB)
    Write [F:APLD]
    If fstat
     GOK = 0 : Break
    Endif
   Next
   If GOK=0 : Rollback : Return : Endif
  Endif
  If dim([L]CDTYPMOD)>0
   For _NB=1 To dim([L]CDTYPMOD)
    If [L]CDTYPMOD(_NB)<>""
     [F:APLD]AFOLDER= [L]APPLI
     [F:APLD]AUPDATE=[L]SYRUPDATE
     [F:APLD]IDENT=[L]SYRIDENT
     [F:APLD]TYP= "CDTYPMOD"
     [F:APLD]LINE = [L]_NB
     [F:APLD]TXT =  [L]CDTYPMOD(_NB)
     Write [F:APLD]
     If fstat
      GOK = 0 : Break
     Endif
    Endif
   Next
   If GOK=0 : Rollback : Return : Endif
  Endif
  If dim([L]ISBIAMOD)>0
   For _NB=1 To [L]ISBIAMOD
    [F:APLD]AFOLDER= [L]APPLI
    [F:APLD]AUPDATE=[L]SYRUPDATE
    [F:APLD]IDENT=[L]SYRIDENT
    [F:APLD]TYP= "ISBIANAM"
    [F:APLD]LINE = [L]_NB
    [F:APLD]TXT =  [L]ISBIANAM(_NB)
    Write [F:APLD]
    If fstat
     GOK = 0 : Break
    Endif
   Next
   If GOK=0 : Rollback : Return : Endif
  Endif
 Endif
Commit
Return

$READ_PATCH_FLAG
If [L]SYRUPDATE="" or [L]SYRIDENT="" : Return : Endif
If clalev([F:APL])=0 : Local File APATCHLOG [F:APL] : Endif
If clalev([F:APLD])=0 : Local File APATCHLOGD [F:APLD] : Endif
Read [F:APL]APT0=[L]APPLI;[L]SYRUPDATE;[L]SYRIDENT
If !fstat
 If dim([L]ISTYPMOD)>0 and dim([F:APL]ISTYPMOD)>0
  [L]ISTYPMOD= [F:APL]ISTYPMOD
 Endif
 If dim([L]ISMENMOD)>0 and dim([F:APL]ISMENMOD)>0
  [L]ISMENMOD = [F:APL]ISMENMOD
 Endif
 If dim([L]ISNEWFUN)>0 and dim([F:APL]ISNEWFUN)>0
  [L]ISNEWFUN = [F:APL]ISNEWFUN
 Endif
 If dim([L]ISASYMOD)>0 and dim([F:APL]ISASYMOD)>0
  [L]ISASYMOD = [F:APL]ISASYMOD
 Endif
 If dim([L]ISAGBMOD)>0 and dim([F:APL]ISAGBMOD)>0
  [L]ISAGBMOD = [F:APL]ISAGBMOD
 Endif
 If dim([L]ISACSTMOD)>0 and dim([F:APL]ISACSTMOD)>0
  [L]ISACSTMOD = [F:APL]ISACSTMOD
 Endif
 If dim([L]ISACTXMOD)>0 and dim([F:APL]ISACTXMOD)>0
  [L]ISACTXMOD = [F:APL]ISACTXMOD
 Endif
 If dim([L]ISASWMOD)>0 and dim([F:APL]ISASWMOD)>0
  [L]ISASWMOD = [F:APL]ISASWMOD
 Endif
 If dim([L]ISVUE)>0 and dim([F:APL]ISVUE)>0
  [L]ISVUE = [F:APL]ISVUE
 Endif
 If dim([L]ISMENVALMOD)>0 and dim([F:APL]ISMENVALMOD)>0
  [L]ISMENVALMOD = [F:APL]ISMENVALMOD
 Endif
 If dim([L]ISTRTUSED)>0 and dim([F:APL]ISTRTUSED)>0
  [L]ISTRTUSED = [F:APL]ISTRTUSED
 Endif
 If dim([L]DETAR_WEB)>0 and dim([F:APL]DETAR_WEB)>0
  [L]DETAR_WEB = [F:APL]DETAR_WEB
 Endif
 If dim([L]DETAR_X3C)>0 and dim([F:APL]DETAR_X3C)>0
  [L]DETAR_X3C = [F:APL]DETAR_X3C
 Endif
 If dim([L]DETAR_STD)>0 and dim([F:APL]DETAR_STD)>0
  [L]DETAR_STD = [F:APL]DETAR_STD
 Endif
 If dim([L]DETAR_VER)>0 and dim([F:APL]DETAR_VER)>0
  [L]DETAR_VER = [F:APL]DETAR_VER
 Endif
 If dim([L]DETAR_PER)>0 and dim([F:APL]DETAR_PER)>0
  [L]DETAR_PER = [F:APL]DETAR_PER
 Endif
 If dim([L]DETAR_CLI)>0 and dim([F:APL]DETAR_CLI)>0
  [L]DETAR_CLI = [F:APL]DETAR_CLI
 Endif
 Local Integer _NB
 If dim([L]CDTYPMOD)>0
  Raz [L]_NB
  For [F:APLD]APLD0 Where AFOLDER=[L]APPLI and AUPDATE=[L]SYRUPDATE and IDENT=[L]SYRIDENT and  TYP="CDTYPMOD"
   [L]_NB += 1
   [L]CDTYPMOD(_NB) = [F:APLD]TXT
  Next
 Endif
 If dim([L]AVONUM)>0
  Raz [L]AVONUM
  For [F:APLD]APLD0 Where AFOLDER=[L]APPLI and AUPDATE=[L]SYRUPDATE and IDENT=[L]SYRIDENT and  TYP="AVODOSLAN"
   [L]AVONUM += 1
   [L]CDTYPMOD([L]AVONUM) = [F:APLD]TXT
  Next
 Endif
 If dim([L]ISBIAMOD)>0
  Raz [L]_NB, [L]ISBIAMOD
  For [F:APLD]APLD0 Where AFOLDER=[L]APPLI and AUPDATE=[L]SYRUPDATE and IDENT=[L]SYRIDENT and  TYP="ISBIANAM"
   [L]ISBIAMOD +=1
   [L]ISBIANAM([L]ISBIAMOD) =  [F:APLD]TXT
  Next
 Endif
 If dim([L]NUMINDTXT)>0
  Raz [L]_NB,[L]NUMINDTXT,[L]NUMINDNUM
  For [F:APLD]APLD0 Where AFOLDER=[L]APPLI and AUPDATE=[L]SYRUPDATE and IDENT=[L]SYRIDENT and  TYP="NUMINDTXT"
   [L]_NB += 1
   [L]NUMINDTXT([L]_NB)  = [F:APLD]TXT
   [L]NUMINDNUM([L]_NB) = [F:APLD]NUM
  Next
 Endif
Endif
Return

#----------------------------------------------------------------------------------------#
# Ecrasement du champs commentaire dans la table APATCH
# on lit le fichier Pxx.txt qui contient numéro maintenance - libelle
# on recupere le libelle et on ecrase celui du fichier APATCH
#
# résoud le problème des usa qui se retrouve toujours avec un commentaire en francais
# pour la v130 a revoir
#----------------------------------------------------------------------------------------#

Subprog ECRCOMMENT(FICBASE,NBDOS,DOSSIER)
Value    Char    FICBASE
Value    Integer NBDOS
Value    Char    DOSSIER()(1..)

Local Integer  NBFICTXT , WMAINT
Local Shortint MAXFIL : MAXFIL = 4000
Local Char     FICTXT(80)(1..MAXFIL)
Local Char     WNOMFIC(GDIMFIC)
Local Char     WAPPLI
Local Char     WCOMMENT (50)
Local Char     SAVADXIFS(10) , SAVADXIRS(10)
Local Integer  SAVADXIUM
Local Char     REPFIC(GDIMFIC) , MACFIC(GLONAMC)

Call MACHINE(FICBASE,MACFIC,REPFIC) From ORDSYS

NBFICTXT = 0

SAVADXIFS = adxifs
SAVADXIRS = adxirs
SAVADXIUM = adxium

# besoin d'avoir la liste des .txt se trouvant sous ce répertoire
# fichiers qui donnent les libelles en anglais
EXT = "txt"
If MACFIC="#"
 Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+MACFIC+'\*.'+EXTTXT+'"' As [FTR_]
 NBTXT = 0
 For [FTR_]
  If pat([F:FTR_]LISFIC,'*.'+EXTTXT)
   NBTXT += 1
   If NBTXT<=dim(TTXT)
    K = instr(1,[F:FTR_]LISFIC,'.'+EXTTXT)
    If K
     TTXT(NBTXT) = left$([FTR_]LISFIC,K-1)
    Endif
   Endif
  Endif
 Next FTR_
 Close Local File [FTR_]
Else
 Call SYSTEME2(MACFIC,'lsadx -a'-nomap-'"'+REPFIC+'"'-'txt',"",NBFICTXT,FICTXT) From ORDSYS
Endif
If NBFICTXT>dim(FICTXT)
 Call ECR_TRACE(mess(29,139,1)-".txt ("+num$(NBFICTXT)+"/"+num$(dim(FICTXT))+")",1) From GESECRAN
 # Trop de fichiers
Endif

# Lecture de la liste des Pxxx.txt pour recuperer un par un le nom du fichier
# ensuite on lit le fichier et on met à jour le fichier APATCH dans chaque dossier
If NBFICTXT <> 0 & NBFICTXT<=dim(FICTXT)
    For P=1 To NBFICTXT
        # test de la longueur du nom de fichier
        If len (FICTXT(P)) = 4 or len (FICTXT(P)) = 5
            # test de la chaine modele Pxxx
            If pat(FICTXT(P),"P###") or pat(FICTXT(P),"P!###")
                 WNOMFIC = filpath(REPFIC,FICTXT(P),EXT,"","",MACFIC)
                 If filinfo(WNOMFIC,0)>=0
                      Gosub ECRASE
                 Endif
             Endif
        Endif

    Next P
Endif

Openi

adxifs = SAVADXIFS
adxirs = SAVADXIRS
adxium = SAVADXIUM

End

#--------------------------------------------------------------#
$ECRASE
Local Char WRELEASE(50)
WRELEASE=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
Openi WNOMFIC
adxifs = ","
adxirs = chr$(10)
adxium = GUTF8

Repeat
    # lecture de tout le fichier
    Raz WCOMMENT, WMAINT
    Rdseq WMAINT,WCOMMENT
    If fstat = 0
        If WCOMMENT <> ""
            For D=1 To NBDOS
                 WAPPLI = DOSSIER(D)
                 Local File =WAPPLI+".APATCH" [APT]
                 Trbegin [APT]
                  #106969
                  #Update [APT] Where TYP="P" & RELEASE=GVERSION & NUMP=WMAINT With COMMENT=WCOMMENT
                  Update [APT] Where TYP="P" & RELEASE=WRELEASE & NUMP=WMAINT With COMMENT=WCOMMENT
                 Commit
                 Close Local File [APT]
            Next D
        Endif
    Endif
Until fstat <> 0
Openi

Return

#---------------------------------------------#
Subprog REPERT(CHEMIN,REPERT,FICHIER,EXT)
Value    Char CHEMIN
Variable Char REPERT()
Variable Char FICHIER()
Variable Char EXT()
Local Integer I , J , K
K = 0
Repeat
 I = instr(K+1,CHEMIN,"/")
 J = instr(K+1,CHEMIN,"\")
 If I or J
  K = max(I,J)
 Endif
Until I=0 & J=0
If K
 FICHIER = right$(CHEMIN,K+1)
 REPERT  = left$(CHEMIN,K-1)
Else
 FICHIER = CHEMIN
 REPERT  = ""
Endif
I = instr(1,FICHIER,".")
If I
 EXT     = right$(FICHIER,I+1)
 FICHIER = left$(FICHIER,I-1)
Else
 EXT     = ""
Endif
End

##---------------------------------------------------------------------#
## Vérifications
## Jusqu'au 5.9.3  le nom fichier patch est P_nnnnn_vvv.dat
## Après   Pour X3    : PX_nnnnn_vvv.dat
##         Pour PAYE  : PP_nnnnn_vvv.dat
##         Pour GEODE : PG_nnnnn_vvv.dat
##         Pour ABEL  : AB_nnnnn_vvv.dat
## 22.1.08 Rajout des patches de doc (DProduit_CompteurDoc_Version_Langue)
##         Pour X3    : DX_nnnnn_vvv_lll.dat
##         Pour PAYE  : DP_nnnnn_vvv_lll.dat
##         Pour GEODE : DG_nnnnn_vvv_lll.dat
##         Pour ABEL  : DB_nnnnn_vvv_lll.dat
## 04.7.11 ajout des mnts de traductions (TProduit_CompteurInd_Version)
##     pas de notion de langue car inclus dans le dat ....
##         ce sont des patchs non obligatoire
##         Pour X3    : TX_nnnnn_vvv.dat
##         Pour PAYE  : TP_nnnnn_vvv.dat
##         Pour GEODE : TG_nnnnn_vvv.dat
##         Pour ABEL  : TB_nnnnn_vvv.dat
##---------------------------------------------------------------------#

$VERIF
## Vérif de séquentialité pour les patchs standard
Local Char    PTYP(1) , TRAITE(200) , ZTYP(1) , EXTTXT(3)
#Local Integer PNUM , PVER , NBTYP , PSTD
Local Integer PNUM , NBTYP , PSTD
Local Char PFICRELABR(10)
Local Char    WWIFS(10) , WWIRS(10) , PLAN(GLONLAN)
Local Char    TTYP(1)(1..MAXFIL), TFICRELABR(10) (1..MAXFIL)
#Local Integer TVER(1..MAXFIL) , DNUM(1..MAXFIL) , FNUM(1..MAXFIL)
Local Integer DNUM(1..MAXFIL) , FNUM(1..MAXFIL)
Local Integer ERR , ERR2 , MINI , I1_ , I2_ , I3_
ERR = 0 : ERR2 = 0 : OK = 1

If !GSERVEUR
 For P=1 To NBTRAIT
  If FICCLI<>""
   FICPATCH = FICBASE
  Else
   FICPATCH = filpath(FICBASE,TRAIT(P),EXT,"","",MACFIC)
  Endif
  If filinfo(FICPATCH,7)>0
   Openi FICPATCH
   adxifs = ","
   adxirs = chr$(10)
   adxium = GUTF8
   # En-tête
   Gosub LIRE
   Openi
   If find(val(CHAMP(6)),1,2) : # Normal/Superviseur
    If mess(107,126,1)=""
     Call OUINON("Did you read file named ENG_ADXPATCH.htm",OK) From GESECRAN
    Else
     Call OUINON(mess(220,126,1),OK) From GESECRAN : # Avez-vous lu le fichier ADXPATCH.htm
    Endif
    If OK<>2 : OK = 0 : Endif
    Break
   Endif
  Endif
 Next P
Endif
If !OK : Return : Endif


Sorta NBTRAIT TRAIT

If [L]SYRSTAMAINT=3 Then
 For P=1 To NBTRAIT
  #If func SCRIPT_EXTRACT_INFO(TRAIT(P),PTYP,PNUM,PVER,PLAN) & num$(PNUM) = SYRMAINT Then
  If func SCRIPT_EXTRACT_INFO(TRAIT(P),PTYP,PNUM,PFICRELABR,PLAN) & num$(PNUM) = SYRMAINT Then
   Dela 1,P TRAIT
   NBTRAIT -= P
   Break
  Endif
 Next P
Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(30,115,1)) From LECFIC : # Intégration de patch
Else
 Call ECR_TRACE(mess(30,115,1),0) From GESECRAN
Endif
PSTD=0
For P=1 To NBTRAIT
 TRAITE = TRAIT(P)
 Raz ZTYP
 I1_ = instr(1,TRAITE,"_")
 I2_ = instr(I1_+1,TRAITE,"_")
 I3_ = instr(I2_+1,TRAITE,"_")
 If I1_<>0 & I2_<>0 & find(left$(TRAIT(P),I1_-1),"X","Y","Z","P","PX","PP","PG","PA","DX","DP","DG","DA","TX","TP","TG","TA")
  PTYP = left$(TRAITE,I1_-1)
  If I1_ = 3 and PTYP = "P" : ZTYP=seg$(TRAITE,I1_-1,I1_-1) : Endif
  If PTYP ="P" : PSTD=1 : Endif
  PNUM = val(seg$(TRAITE,I1_+1,I2_-1))
  If I3_<>0 & left$(PTYP,1)="D"
   #PVER = val(seg$(TRAITE,I2_+1,I3_-1))
   PFICRELABR=seg$(TRAITE,I2_+1,I3_-1)
   PLAN = right$(TRAITE,I3_+1)
  Else
   #PVER = val(right$(TRAITE,I2_+1))
   PFICRELABR=right$(TRAITE,I2_+1)
   PLAN = ""
  Endif
  K = find(PTYP,TTYP(1..NBTYP))
  If !K
   NBTYP += 1
   TTYP(NBTYP) = PTYP
   #TVER(NBTYP) = PVER
   TFICRELABR(NBTYP) = PFICRELABR
   DNUM(NBTYP) = PNUM
   FNUM(NBTYP) = PNUM
  Else
   #If PVER<>TVER(K)
   If PFICRELABR<>TFICRELABR(K)
    Call ECR_TRACE(PTYP-":"-mess(55,115,1),1) From GESECRAN
    #  Mélange de patchs de versions différentes
    ERR2 = 1
   Endif
   ############
   # on peut avoir un patch 006-FRA et un 006_GEr pour la doc...
   # il ne faut pas controler la sequence
   If PTYP <> "D"
       If PNUM<>FNUM(K)+1
           ########## Il manque des patches dans la tranche
            Call ECR_TRACE(PTYP-":"-mess(56,115,1)-PTYP+ZTYP+"_"+format$("N0:5#",FNUM(K))+"_"
&            +PFICRELABR+"..."+TRAITE,-1) From GESECRAN
#&            +format$("N0:3#",PVER)+"..."+TRAITE,-1) From GESECRAN
        ERR = 1
       Endif
   Endif
   FNUM(K) = PNUM
  Endif
 Endif
Next P

## Pour tous les patchs, vérif de non intégration précédente
NBTYP = 0
For D=1 To NBDOS
 APPLI = DOSSIER(D)
 Local File =APPLI+".APATCH" [APT]
 Local File =APPLI+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"NUMPATCH"
 If fstat
  MINI = 1
 Else
  MINI = val([F:ADW]VALEUR)+1
 Endif
 For P=1 To NBTRAIT
  Raz MESSERR, CODEERR,MAXERR :#SAM 107048

  TRAITE = TRAIT(P)
# A-t-on déjà intégré ce patch ?
  Read [APT]APT1 = TRAITE
  If !fstat
   If [L]SYRFLGUPD<>2 or ([L]SYRFLGUPD=2 and [L]SYRSTAMAINT=1)
    #{SAM 107048 Call ECR_TRACE(APPLI-":"-TRAITE-mess(57,115,1),-1) From GESECRAN : # patch déjà intégré
    MAXERR+=1 :MESSERR(MAXERR)=APPLI-":"-TRAITE-mess(57,115,1) : CODEERR(MAXERR) = 1 :#SAM 117048: it's an error
    #SAM 107048}
    ERR = 1
   Endif
  Endif

# Pour les patchs standard
# vérifs complémentaires pour le premier
  I1_ = instr(1,TRAITE,"_")
  I2_ = instr(I1_+1,TRAITE,"_")
  I3_ = instr(I2_+1,TRAITE,"_")
  If I1_<>0 & I2_<>0 & find(left$(TRAIT(P),I1_-1),"P","PX","PP","PG","PA","DX","DP","DG","DA","TX","TP","TG","TA")
   PTYP = left$(TRAITE,I1_-1)
   PNUM = val(seg$(TRAITE,I1_+1,I2_-1))
   If I3_<>0 & left$(PTYP,1)="D"
    #PVER = val(seg$(TRAITE,I2_+1,I3_-1))
    PFICRELABR=seg$(TRAITE,I2_+1,I3_-1)
    PLAN = right$(TRAITE,I3_+1)
   Else
    #PVER = val(right$(TRAITE,I2_+1))
    PFICRELABR=right$(TRAITE,I2_+1)
    PLAN = ""
   Endif
   If !find(PTYP,TTYP(1..NBTYP))
    NBTYP += 1
    TTYP(NBTYP) = PTYP
# A-t-on intégré un patch de version supérieur ?
    #Filter [APT] Where TYP=PTYP & VER>PVER
    Filter [APT] Where TYP=PTYP & FICRELABR>PFICRELABR
    Read [APT]APT2 First
    If fstat<=2
     #Call ECR_TRACE(APPLI-":"-mess(239,115,1)-":"-[F:APT]FIC-"("+num$([F:APT]VER)+")",1) From GESECRAN
     #{SAM 107048 Call ECR_TRACE(APPLI-":"-mess(239,115,1)-":"-[F:APT]FIC-"("+[F:APT]FICRELABR+")",1) From GESECRAN
#     Vous tentez d'intégrer un patch de version inférieure
     MAXERR+=1 :MESSERR(MAXERR)=APPLI-":"-mess(239,115,1)-":"-[F:APT]FIC-"("+[F:APT]FICRELABR+")" : CODEERR(MAXERR) = 1
     #SAM 107048}
     ERR = 1
    Endif
# A-t-on intégré un patch de numéro supérieur ?
    #Filter [APT] Where TYP=PTYP & VER=PVER & NUMP>PNUM
    Filter [APT] Where TYP=PTYP & FICRELABR=PFICRELABR & NUMP>PNUM
    Read [APT]APT2 First
    If fstat<=2
     #{SAM 107048 Call ECR_TRACE(APPLI-":"-mess(58,115,1)-":"-[F:APT]FIC-"("+num$([F:APT]NUMP)+")",-1) From GESECRAN
     MAXERR+=1 :MESSERR(MAXERR)=APPLI-":"-mess(58,115,1)-":"-[F:APT]FIC-"("+num$([F:APT]NUMP)+")" : CODEERR(MAXERR) = -1
     #SAM 107048}
#     Patch plus récent déjà intégré
     ERR = 1
    Endif
# Y-a-t-il un trou ?
    #Filter [APT] Where TYP=PTYP & VER=PVER & NUMP<PNUM
    Filter [APT] Where TYP=PTYP & FICRELABR=PFICRELABR & NUMP<PNUM
    Read [APT]APT2 Last
    If fstat<=2 & [F:APT]NUMP<PNUM-1
      #{SAM 107048 Call ECR_TRACE(APPLI-":"-mess(59,115,1)-[F:APT]FIC-"("+num$([F:APT]NUMP)+")",0) From GESECRAN
      MAXERR+=1 :MESSERR(MAXERR)=APPLI-":"-mess(59,115,1)-[F:APT]FIC-"("+num$([F:APT]NUMP)+")" : CODEERR(MAXERR) = 0
      #SAM 107048}
#     Il manque des patchs, le dernier patch intégré est
     ERR = 1
    Endif
# Il faut encore vérifier qu'on n'intègre pas un patch plus ancien que la release
    If PTYP="P" & PNUM<MINI
     #{SAM 107048 Call ECR_TRACE(APPLI-":"-mess(60,115,1)-TRAITE,-1) From GESECRAN
     MAXERR+=1 :MESSERR(MAXERR)=APPLI-":"-mess(60,115,1)-TRAITE : CODEERR(MAXERR) = -1
     #SAM 107048}
#     Patch normalement inclus dans la version du dossier
     ERR = 1
    Endif
   Endif
  Endif
  SAVERR = ERR :#SAM 107048
  GPOINT = "PATCHVERIF" : Gosub ENTREE From EXEFNC
  #{SAM 107048: Log message after PATCHVERIF
  For IDXERR=1 To MAXERR
   If ERR
    Call ECR_TRACE(MESSERR(IDXERR), CODEERR(IDXERR) ) From GESECRAN
   Else
    Call ECR_TRACE(MESSERR(IDXERR), 0 ) From GESECRAN
   Endif
  Next IDXERR
  #SAM 107048}
 Next P
 Close Local File [APT]
 Close Local File [ADW]
Next D

### IG : 18/06/01 on renseigne le n° de patch si possible à partir fichier PYxxx.txt
# Lecture de la liste des PYxxx.txt pour trouver celui qui correspond aux maintenances

EXTTXT = "txt"
If MACFIC="#"
 Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+REPFIC+'\*.'+EXTTXT+'"' As [FTR_]
 NBTXT = 0
 For [FTR_]
  If pat([F:FTR_]LISFIC,'*.'+EXTTXT)
   NBTXT += 1
   If NBTXT<=dim(TTXT)
    K = instr(1,[F:FTR_]LISFIC,'.'+EXTTXT)
    If K
     TTXT(NBTXT) = left$([FTR_]LISFIC,K-1)
    Endif
   Endif
  Endif
 Next FTR_
 Close Local File [FTR_]
Else
 Call SYSTEME2(MACFIC,'lsadx -a'-nomap-'"'+REPFIC+'"'-EXTTXT,'',NBTXT,TTXT) From ORDSYS
Endif
If NBTXT>dim(TTXT)
 Call ECR_TRACE(mess(29,139,1)-".txt ("+num$(NBTXT)+"/"+num$(dim(TTXT))+")",1) From GESECRAN
 # Trop de fichiers
 ERR = 1
Endif

IPAT=0

## IG : 02/10/03 : sous Windows , pb chargement n° de patch
WWIFS = adxifs
WWIRS = adxirs
adxifs = ","
adxirs = chr$(10)

If NBTXT <> 0 & NBTXT<=dim(TTXT)
    For WI=1 To NBTXT
        # test de la longueur du nom de fichier
        If len (TTXT(WI)) = 4 or len (TTXT(WI)) = 5
            # test de la chaine modele PYxxx
            If pat(TTXT(WI),"P###") or pat(TTXT(WI),"P!###")
                 WNOMFIC = filpath(REPFIC,TTXT(WI),EXTTXT,"","",MACFIC)
                 If filinfo(WNOMFIC,0)>=0
                    MINPAT=0
                    MAXPAT=0
                    Openi WNOMFIC
                    Repeat
                    Rdseq WPAT ,WCOMMENT
                    If fstat = 0 and WPAT > " "
                       If MINPAT = 0         : MINPAT=val(WPAT) : Endif
                       If MAXPAT < val(WPAT) : MAXPAT=val(WPAT) : Endif
                    Endif
                    Until fstat <> 0
                    Openi
                    If IPAT < dim(PATNUML)
                       IPAT+=1
                       If len (TTXT(WI)) = 4
                           PATNUML(IPAT)=val(seg$(TTXT(WI),2,4))
                       Endif
                       If len (TTXT(WI)) = 5
                           PATNUML(IPAT)=val(seg$(TTXT(WI),3,5))
                       Endif
                       PATMNTD(IPAT)=MINPAT
                       PATMNTF(IPAT)=MAXPAT
                    Endif
                 Endif
             Endif
        Endif
    Next WI
Else
     If PSTD =1
       Call ECR_TRACE("|"+FICBASE-"/PXNNN.txt :"-mess(101,100,1),-1) From GESECRAN : # Fichier inexistant
     Endif
Endif
adxifs=WWIFS
adxirs=WWIRS

### IG

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 If ERR or ERR2
  Call LEC_TRACE From LECFIC
 Endif
Endif
If ERR2
 OK = 0
Elsif ERR
 OK = 1
 If !GSERVEUR
  Call OUINON(mess(61,115,1),OK) From GESECRAN : # Voulez-vous continuer malgré les erreurs
 Endif
 If OK<>2 : OK = 0 : Endif
Else
 OK = 1
Endif
Return

Funprog SCRIPT_EXTRACT_INFO(SCRIPT,PTYP,PNUM,PFICRELABR,PLAN)
Value Char SCRIPT
Variable Char PTYP
Variable Integer PNUM
#Variable Integer PVER
Variable Char PFICRELABR
Variable Char PLAN

Local Integer OK:OK=0
Local Integer I1_,I2_,I3_
 I1_ = instr(1,SCRIPT,"_")
 I2_ = instr(I1_+1,SCRIPT,"_")
 I3_ = instr(I2_+1,SCRIPT,"_")
 If I1_<>0 & I2_<>0 & find(left$(SCRIPT,I1_-1),"X","Y","Z","P","PX","PP","PG","PA","DX","DP","DG","DA","TX","TP","TG","TA")
  PTYP = left$(SCRIPT,I1_-1)
  If I1_ = 3 and PTYP = "P" : ZTYP=seg$(SCRIPT,I1_-1,I1_-1) : Endif
  If PTYP ="P" : PSTD=1 : Endif
  PNUM = val(seg$(SCRIPT,I1_+1,I2_-1))
  If I3_<>0 & left$(PTYP,1)="D"
   #PVER = val(seg$(SCRIPT,I2_+1,I3_-1))
   PFICRELABR=seg$(SCRIPT,I2_+1,I3_-1)
   PLAN = right$(SCRIPT,I3_+1)
  Else
   #PVER = val(right$(SCRIPT,I2_+1))
   PFICRELABR=right$(SCRIPT,I2_+1)
   PLAN = ""
  Endif
  OK=1
 Endif
End OK

Funprog ISOK_DELETE(OBJ)
Value Char OBJ()
If find(OBJ,"ACV","ABA","AAR","ARP","TFO","APP","ACST","ATYP", "ATY",
&        "AGB","ARV","ASY","ABT","ATN","ABM","ANM","AFC","ABG","AHH","AHI","ADC","ATP","ASB",
&        "ARX","GTC","AMM","AOP","AVR","ABF","ABI","ACT","ACD","ACL","TCA","AWW","AWR",
&         "AWM","AWA","AWE","AVW","AUR","AWI","ANG","ASU","APR","ACN","AOB","AII","AOE",
&         "ALH","ALQ","ALT","APH","AI0","ATB","ASW","ABO","ADF","ADV","AML","AMC","ADZ",
&         "ACTX","ACLA","ADP","ADI","ADO","AMK","AGS","AUTI") > 0
  End 1
Elsif left$(OBJ,1)="X"
     # cg oct 2017
     # On prevoit suppression via patch scm sur tous les elements x
     # We are planning the deletion using patch scm for all elements X
     #
     # type objet commence par X pas de test du type de patch std ou non std
     # type object starts with X no test of the type of patch std or not std
     Local Integer OKTRT
     Local Char WTRTCOD(GLONADC)
     WTRTCOD = "XPATCH_"+OBJ
     Call EXISTE_ADX("","",WTRTCOD,OKTRT) From ORDSYS
     If OKTRT
         End 1
   Endif
Endif
End 0

Subprog DBG_OPEN()
 Openo filpath("TRA","patch","tra"),0
 Wrseq "date$="+format$("D:YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$)
 Openo

 Local Integer ST
 Local Char PATH(255)
 ST = CloseLog( )
 PATH = filpath("","TRA","","")
 ST = openLog( PATH, 1)
End

Subprog DBG(MESSAGE)
Value Char MESSAGE
Openo filpath("TRA","patch","tra"),-1
Wrseq MESSAGE
Openo
End

 #{X3-43086
Subprog CLEAN_GROUPS(ABR,FIELDS)
Value Char ABR
Value Char FIELDS

Local Integer IDXFLD,IDXDIM,IDXMAX,FLDMAX
Local Char TABFIELDS(30)(0..)
Local Char TMPFIELDS(250):TMPFIELDS=FIELDS

FLDMAX = func ASYRSUB.SPLIT(TABFIELDS,TMPFIELDS,",")
For IDXFLD = 0 To FLDMAX - 1
 IDXMAX=evalue("dim("+ABR+TABFIELDS(IDXFLD)+")") - 1
 For IDXDIM=0 To IDXMAX
  Assign ABR+TABFIELDS(IDXFLD)+"("+num$(IDXDIM)+")" With ""
 Next IDXDIM
Next IDXFLD
End
#X3-43086}


