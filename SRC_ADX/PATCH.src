#<AdxTL>@(#)0.0.0.0 $Revision$ Intégration de patch
#Local Char DOS(250)(0..)
#Local Char TEXTE(50)
#DOS(0) = "TEST2"
#GSERVEUR = 1
#Call PATCH_UPDSTD("/Sage/sagedev/SUPDVLP/folders/SUPERV/PATCH/TESTCCL.dat","",2,1,DOS,TEXTE,2)
#GSERVEUR = 0
#Infbox "FIN"-TEXTE
#End

GSERVEUR = 0
Local Char VALEUR, PARAM
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

#---------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "EXEC"        : Gosub EXECUTE
Endcase
Return

#---------------------#
$ACTION_XTEND
Local Integer OKTRT
Call EXISTE_ADX("","","APATCHAYT",OKTRT) From ORDSYS
If OKTRT
 Gosub ACTION From APATCHAYT
Endif
Return

#---------------------#
$ACTION_PRODUIT
Local Integer OKTRT
Call EXISTE_ADX("","","APATCHB",OKTRT) From ORDSYS
If OKTRT
 Gosub ACTION From APATCHB
Endif
Return

#---------------------------------------------#
$INIT
Local Integer OK , STAT
Local Char    TEXTE(250)
Local Char    WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(10)
Local Char    OGTRACE(GDIMFIC)
TRA = 1

#---------------------------------------------#
$OUVRE_BATCH
Local Mask PATCH [DIA]
Local File    ADOSSIER [ADS], ADOSACT [ADA]

Raz [M:DIA]

[M:DIA]FICHIER = GFICPATH
#If (GOS(1)="unix" & pat(left$(GFICPATH,3),"!:\")) or left$(GFICPATH,1)="#"
# [M:DIA]TYPEXP = 1
#Elsif GOS(1)<>"unix" & pat(left$(GFICPATH,3),"!:\") & filinfo(GFICPATH,0)<=0
# [M:DIA]TYPEXP = 1
#Else
# [M:DIA]TYPEXP = 2
#Endif
 [M:DIA]TYPEXP = 2
#104343
If dim([M:DIA]ALNKSYNC)>0
 [M:DIA]ALNKSYNC = 2
Endif
Call CHARGE_DOS

Return

#---------------------------------------------#
$EXECUTE
# mb 2.5.5 sinon ces tables ne peuvent réellement être fermées si elles sont patchées
If clalev([F:ATX]) : Close Local File [ATX] : Endif
If clalev([F:AXX]) : Close Local File [AXX] : Endif

If clalev([F:ADS])>0 : Close Local File [ADS] : Endif : # mb 17.4.2 Sinon le Close local file sera inactif

# cg le 20/07/2000  car [m:dia]fichier était ecrasé dans un certain cas après call du patch .....
WFICHIER = [M:DIA]FICHIER
If [M:DIA]TYPEXP=1
 WFICCLI = [M:DIA]FICHIER
 Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
 Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
 If STAT : FIN = 1 : Return : Endif
 GFICPATH = WFICCLI
Else
 WFICCLI = ""
Endif

#111412
#Call DBG_OPEN()

If dim([M:DIA]SYRFLGUPD)>0
 Call PATCH_UPDSTD(WFICHIER,WFICCLI,[M:DIA]INTEG,[M:DIA]NBDOS,[M:DIA]DOSSIER,[M:DIA]SYRFLGUPD,
&                         [M:DIA]SYRUPDATE,[M:DIA]SYRIDENT,[M:DIA]SYRMAINT,[M:DIA]SYRSTAMAINT,
&                         TEXTE)
Else
 Call PATCH(WFICHIER,WFICCLI,[M:DIA]INTEG,[M:DIA]NBDOS,[M:DIA]DOSSIER,TEXTE)
Endif
# cg le 20/07/2000 ecrasement du commentaire par celui se trouvant dans les fichiers Pxx.txt
# ecrasement à la demande et dans tous les fichiers sauf si on se trouve en francais
If dim([M:DIA]REM)>=0
 If [M:DIA]REM=2
  Call ECRCOMMENT(WFICHIER,[M:DIA]NBDOS,[M:DIA]DOSSIER)
 Endif
Endif

If !GSERVEUR & TEXTE<>""
 OGTRACE = GTRACE
 GTRACE = ""
 Call LECFIC(filpath("TXT","","",[M:DIA]DOSSIER),TEXTE,"txt") From LECFIC
 GTRACE = OGTRACE
Endif

#---------------------------------------------#
$FIN
Return

#-------------------------------------------------------------------#
# Le dossier superviseur doit apparaître en premier
# pour que le patch s'applique d'abord sur ce dossier
#-------------------------------------------------------------------#

Subprog CHARGE_DOS
Local Integer I , J, ER , WMAX , WNBDOS , WNBSUP, NLIGNE
WMAX = dim([M:DIA]DOSSIER)
Local Char    WDOSSIER(GLONADS)(1..WMAX) , WDOSSUP(GLONADS)(1..WMAX)
Local Char CURRDOSS(GLONADS)
Onerrgo ERR
Raz CURRDOSS,WDOSSIER , WDOSSUP, WNBDOS , WNBSUP, NLIGNE
For [ADS]
 Raz ER
 If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0
  Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW_]
  If !ER
   Read [ADW_]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat & val([F:ADW_]VALEUR)-1=GPRODUIT
    Read [ADW_]ADW0 = "";"";"SUPDOS"
    WNBDOS += 1
    WDOSSIER(WNBDOS) = [F:ADS]DOSSIER
    If !fstat & [F:ADW_]VALEUR<>"" & !find([F:ADW_]VALEUR,WDOSSUP(1..WNBSUP))
     WNBSUP += 1
     WDOSSUP(WNBSUP) = [F:ADW_]VALEUR
    Endif
   Endif
   Close Local File [ADW_]
  Endif
 Endif
Next ADS
For I=1 To WNBSUP
 Raz ER
 If filinfo(filpath("FIL","ADOVAL","fde",WDOSSUP(I)),0)>=0
  Local File =WDOSSUP(I)+".ADOVAL" [ADW_]
  If !ER
   Read [ADW_]ADW0 = "";"";"TYPDOS"
   If !ER & !fstat & val([F:ADW_]VALEUR)-1=GPRODUIT
    [M:DIA]DOSSIER([M:DIA]NBDOS) = WDOSSUP(I)
    CURRDOSS=WDOSSUP(I)
    NLIGNE=[M:DIA]NBDOS
    Gosub CHARGEINFOS
    [M:DIA]NBDOS += 1
   Endif
   Close Local File [ADW_]
  Endif
 Endif
Next I
For I=1 To WNBDOS
 If !find(WDOSSIER(I),WDOSSUP(1..WNBSUP))
  [M:DIA]DOSSIER([M:DIA]NBDOS) = WDOSSIER(I)
  CURRDOSS=WDOSSIER(I)
  NLIGNE=[M:DIA]NBDOS
  Gosub CHARGEINFOS
  [M:DIA]NBDOS += 1
 Endif
Next I
Onerrgo
#Gosub CHARGEINFOS
End

#--------------------------------------------------------------------------#
$CHARGEINFOS
Local Char WLANLIST(100)

  If filinfo(filpath("FIL","APATCH","fde",CURRDOSS),0)
    If clalev([A_PT])=0 : Local File =CURRDOSS+".APATCH" [A_PT] : Endif
    Filter [A_PT] Where TYP="P"
    Read [A_PT]APT0 Last
    If fstat<>0
      Filter [A_PT]
      Close Local File [A_PT]
      Local File =[V]GDOSX3+".APATCH" [A_PT]
      Filter [A_PT] Where TYP="P"
      Read [A_PT]APT0 Last
    Endif
    If !fstat
      If left$(num$([F:A_PT]DAT),5)="00/00"
       [M:DIA]MAJ(NLIGNE)=num$(date$)
      Else
       [M:DIA]MAJ(NLIGNE)=num$([F:A_PT]DAT)
      Endif
      [M:DIA]PATCH(NLIGNE)=num$([F:A_PT]PATNUM)
      If [F:A_PT]RELEASE<>""
        #106969
        #[M:DIA]VERSION(NLIGNE)=ctrans([F:A_PT]RELEASE,".","")
        [M:DIA]VERSION(NLIGNE)=[F:A_PT]RELEASE
      Else
        #106969
        #[M:DIA]VERSION(NLIGNE)=num$(GVERSION)
        [M:DIA]VERSION(NLIGNE)=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
      Endif
    Else
        [M:DIA]PATCH(NLIGNE)="0"
        [M:DIA]MAJ(NLIGNE)=num$(date$)
        #106969
        #[M:DIA]VERSION(NLIGNE)=num$(GVERSION)
        [M:DIA]VERSION(NLIGNE)=func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
    Endif
    Close Local File [A_PT]
  Endif

  If filinfo(filpath("FIL","ADOVAL","fde",CURRDOSS),0)
    If clalev([A_DW])=0 : Local File =CURRDOSS+".ADOVAL" [A_DW] : Endif
    Read [A_DW]ADW0 = "";"";"RELEASE"
    If !fstat
      [M:DIA]RELEASE(NLIGNE)=num$([F:A_DW]VALEUR)
    Else
      [M:DIA]RELEASE(NLIGNE)="0"
    Endif
    Close Local File [A_DW]
  Endif

  If filinfo(filpath("FIL","ADOSSIER","fde",[M:DIA]DOSSIER(0)),0)
    If clalev([A_DS])=0 : Local File =[V]GDOSX3+".ADOSSIER" [A_DS] : Endif

    Read [A_DS]DOSSIER = CURRDOSS
    If !fstat
      Raz WLANLIST
      For J=1 To [F:A_DS]NBRLAN
        If WLANLIST=""
          WLANLIST=[F:A_DS]LAN(J-1)
        Else
          WLANLIST+=";"+[F:A_DS]LAN(J-1)
        Endif
      Next I
      [M:DIA]LANGUES(NLIGNE)=WLANLIST
    Endif

    Close Local File [A_DS]
  Endif

Return


$ERR
ER = errn
Resume

#-------------------------------------------------------------------------#
Subprog PATCH_UPDSTD(FICBASE,FICCLI,INTEGRE,NBDOS,DOSSIER,SYRFLGUPD,SYRUPDATE,SYRIDENT,SYRMAINT,SYRSTAMAINT,README)
Value    Char    FICBASE
Value    Char    FICCLI
Value    Integer INTEGRE
Value    Integer NBDOS
Value    Char    DOSSIER()(1..)
Value    Integer SYRFLGUPD
Value    Char    SYRUPDATE
Value Char       SYRIDENT
Value Char       SYRMAINT
Value Integer    SYRSTAMAINT
Variable Char    README()

Goto TRTPATCH

#-------------------------------------------------------------------------#
Subprog PATCH(FICBASE,FICCLI,INTEGRE,NBDOS,DOSSIER,README)
Value    Char    FICBASE
Value    Char    FICCLI
Value    Integer INTEGRE
Value    Integer NBDOS
Value    Char    DOSSIER()(1..)
Variable Char    README()

Local     Integer SYRFLGUPD,SYRSTAMAINT
Local    Char     SYRUPDATE(15),SYRIDENT(15),SYRMAINT(30)

Goto TRTPATCH

$TRTPATCH
maxmem = max(int(maxmem/1024),128000)

Local Shortint MAXFIL : MAXFIL = 20000# X3-41808 => 10000 cg 23/08/2018 increase 11000  # CCC increase to 20000
Local Integer  D , I , J , K , L , OK, TYPENR
Local Char     CHAMP(255)(1..50)
Local Integer  ER , STAT , MOK
Local Char     ERFIC(250)
Local Char     TYPOBJ(GLONAOB) , NOMOBJ(80)  , INTITOBJ(80) , IDENT(250) , APPLI(GLONADS)
Local Char     VARIA(GLONAVA) , VALEUR(255) , LAN(GLONLAN)
Local Char     LANS(250)(1..50) , TYPS(250) , CODS(250) , MOTCLE(250)
Local Integer  DIME , TYP , IND , NEWOBJ , NEWZON , NUMACT , NBENR , DIML
Local Integer  NBLAN , NUMERO , PREM
Local Char     LANGUE(GLONLAN)(1..50) , TEXTE(250)(1..50), COMT(250)(1..80) :#U11
Local Char     SAVLAN(GLONLAN)
Local Integer  NBZ , NBI , NUMI
Local Char     ZONE(GLONAVA)(1..500) , INDEX(GLONANX)(1..30) : # mb 3.5.2 bug 14163
Local Char     SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM
Local Char     ABR(GLONABR)
Local Integer  SAVPOS , SAVSERV
Local Integer  NLANP
Local Char     LANPATCH(GLONLAN)(1..60)
Local Integer  OKLAN
Local Integer  NBACT
Local Char     ACTIV(GLONACV)(1..200)
Local Integer  NBCLE , I1 , I2
Local Char     CLE(GLONAVA)(1..16) , CHAINE(250) , SCHAINE(250)
Local Char     FICSRC(GDIMFIC) , FICOLD(GDIMFIC) , REPERT(GDIMFIC)
Local Libelle  LIBEL
Local Char     REP(10) , EXT1(10) , EXT2(10) , SEP(1)
Local Decimal  VERSION :#X3-15226 Manage sub-revision number
Local Integer  TYPPTC
Local Integer  TYPFIC , NBTRAIT
Local Char     FICPATCH(GDIMFIC) , FIC_TRACE(GDIMFIC) , FIC_TMP(GDIMFIC)
Local Char     TRAIT(200)(1..MAXFIL), EXT(10)
Local Integer  P , PNUM
Local Char     PROGRAMME(GLONADC)(1..100)
Local Integer  NBPROG , OKPRGDOS(1..dim([L]DOSSIER))
#U11
#Local Char     COMMENT(80) , COMT(80), LANT(GLONLAN)
Local Char     COMMENT(80) , LANT(GLONLAN)
Local Char     SAVACS(GLONACS)
Local Integer  NB , NOCT
Local Libelle  BUFFER(1..1000)
Local Integer  NUMTXT , FORCE_SUP
Local Integer  OKOBJ , MODOBJ , VALID , ACT , OKFIC , OKSPE , OKENT
Local Char     OLDACT(GLONACV), ACVOBJ(GLONACV)
Local Integer  LONG
Local Char     CHAP(5) , ACTION(20)
Local Char     FIC(250)
Local Date     DATEP : DATEP = date$      : # Pour la post génération Web
Local Integer  TIMEP : TIMEP = val(time$) : # Pour la post génération Web
Local Integer  I1_, I2_
Local Integer  DETAR_WEB , DETAR_X3C , DETAR_STD , DETAR_VER , DETAR_PER , DETAR_CLI
Local Char     MACHINE(GDIMFIC) , DOSX3(GLONADD) , OGDOSX3(GLONADS)
Local Integer  POSFIC , TAILFIC
Local Blbfile  BLOB(12)
Local Clbfile  CLOB(12)
Local Integer  OKTRT , AVONUM , NUMMOD(1..10000) , NBMOD
Local Char     PRG(255) , SUBPRG(255)
Local Char     AVODOSLAN(GLONADS+GLONLAN+1)(1..60)
Local Char     NOMPROG(GLONADC) , CLEOBJ(80) , ABROBJ(20) , MESSA(200) , CLEMOD(250)
Local Char     MODDON(GLONAWM) , TRANSAC(GLONATN) , CODLEG(GLONADI)
Global Char    GCODACTX3(GLONACV)(1..2)
Local Char     LEGREF(GLONADI)(1..dim(GDOSLEG))
Local Integer  NBLEGREF , MULTILEG
Local Char     FLDLEG(GLONAVA) , TABLNK(GLONATB) , CLELNK(GLONAVA)(1..16) , VALLNK(100)(1..16)
Local Char     OLDLEG(GLONADI) , NEWLEG(GLONADI)
Local Integer  NBVAL , NBLNK
Local Integer  NUMREQ , BR

Global Integer ISMENMOD : # Les menus locaux ont-ils été modifiés
Global Integer ISASWMOD : # Modification ASW
Global Integer ISNEWFUN : # Y-a-t-il eu une fonction crée
Local Integer  ISTYPMOD : # Y-a-t-il eu un nouveau type de donnée modifié
Local Char     CDTYPMOD(GLONATY)(1..50) : # Type de donnée modifiés
Local Integer  ISACTXMOD : # modification contexte
Local Integer  ISAGBMOD : # modification variable globale
Local Integer  ISACSTMOD : # modification variable globale
Local Integer  ISASYMOD : # modification style
Local Integer  ISBIAMOD : # Installation d'un biar
Local Integer  ISMENVALMOD : # Modification des menux locaux 9137 et 9138, Call CRELIBALL from VALLANG
Local Char     ISBIANAM(30)(1..100) : # Nom des biar
Local Integer  ISTRTUSED : # Traitement non flushable -> il faut redemarrer la session
Local Integer  ISVUE    : # Patch de vue et/ou patch de table
# jira xxxxx utility management
Local Integer  ISAUTI_PROCESS : # Y-a-t-il eu un utilitaire à executer
Local Char     SAV_GTRACE(GDIMFIC)
Local Integer  SAV_GERRTRACE
Local Char     MOBJ(GLONAOB) , MCLE1(GLONID1) , MCLE2(GLONID2)(0..16) , MNUMX(3)
Local Integer  NBMERE
Local Char     TBMERE(GLONADS)(1..5) , FICAPL(GDIMFIC) , LIGNE(250) , MACFIC(GLONAMC) , REPFIC(GDIMFIC)
Local Integer WLNKSYNC
#{SAM 107048 Local Char     MESSERR(250)
Local Char     MESSERR(250)(1..)
Local Integer CODEERR(1..)
Local Integer IDXERR,MAXERR,SAVERR
#SAM 107048}

Local Char    PTYP(1)
#Local Integer  PVER
Local Char PFICRELABR(10)
Local Char    PLAN(GLONLAN)

Local Integer SAVGVALID : SAVGVALID =GVALIDDIFF
If dim([M:DIA]AVALDIF)>0
 If [M:DIA]AVALDIF=2 and func AFNC.PARTSEP(ver$(0),2," ")>"16r.217"
  GVALIDDIFF = 3
 Else
  GVALIDDIFF=1
 Endif
Endif
#104343
If dim([M:DIA]ALNKSYNC)>0 & [M:DIA]ALNKSYNC=2
 WLNKSYNC = 1
Else
 WLNKSYNC = 0
Endif

# Validations différées fenêtres et écran si lancement en batch       #   CC   13/01/2012
#If GSERVEUR and func AFNC.PARTSEP(ver$(0),2," ")>"16r.217"
#  GVALIDDIFF=3
#Endif

# cg pour patchind - 7 juillet 2011
Local Char NUMINDTXT(GLONADS+GLONLAN+7)(1..10000)
Local Integer NUMINDNUM (1..10000)
Local Integer NBINDTXT
Local Char WDOSSIER(GLONADS)
Local Char WLAN(GLONLAN)
Raz NUMINDTXT, NUMINDNUM
NBINDTXT = 0

### IG : 18/06/01 on renseigne le n° de patch si possible à partir fichier Pxxx.txt
### IG : 07/01/05 bug 27519 - zone PATNUM non renseignée
### WPAT(4)--> WPAT(5)
Local Char     FICPATNAM(250), WPAT(5),WSEP(1),WCOMMENT(50)
Local Char     TTXT(20) (1..MAXFIL)
Local Integer  WPATNUML, IPAT , NBTXT , WI , MINPAT, MAXPAT
Local Integer  PATNUML (1..MAXFIL)
Local Integer  PATMNTD (1..MAXFIL)
Local Integer  PATMNTF (1..MAXFIL)

### IG
Global Decimal GCOEFTAB : GCOEFTAB = 0.5

GCODACTX3(1) = "TRU"
GCODACTX3(2) = "FAL"

# add fullmod ccl 112125
Local Integer ISFULLMOD,ISOKSPOTTING

Local Integer USEETNA,USESCM,ERR_AGET
ERR_AGET = func ASYRFNC.AGET_ENDPOINT_PROPERTIES(USEETNA,USESCM)

If GSERVEUR & filinfo(filpath("FIL","APATCHLOG","fde"),0)>0 and [L]SYRFLGUPD=2
 If NBDOS>1 :# in integration of updates only one folder is mandatory
  Call ECR_TRACE(mess(147,127,1),1) From GESECRAN : # Un seul dossier par mise à jour
  ER = 1
  Goto FINEXE
 Endif
 #109897
 #[L]NUMREQ = val(getenv$("RQT_ENTREP"))
 [L]NUMREQ = val(GBATCHRQT)
Endif

# RECHERCHE dans le répertoire saisi des .dat
# BY 16/06/99 pour être indépendant de l'os
#             et pour pouvoir passer indifféremment un fichier ou un répertoire
If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE = left$(FICBASE,len(FICBASE)-1)
Endif

Call EXISTE(FICBASE,TYPFIC) From ORDSYS
Call MACHINE(FICBASE,MACFIC,REPFIC) From ORDSYS

ER = 0
Case TYPFIC
 When 2 : # C'est un répertoire
  EXT = "dat"
  If MACFIC="#"
   If GBROWS
    Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
    ER = 1
   Else
    Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+REPFIC+'\*.'+EXT+'"' As [FTR_]
    NBTRAIT = 0
    For [FTR_]
     If pat([F:FTR_]LISFIC,'*.'+EXT)
      NBTRAIT += 1
      If NBTRAIT<=dim(TRAIT)
       K = instr(1,[F:FTR_]LISFIC,'.'+EXT)
       If K
        TRAIT(NBTRAIT) = left$([FTR_]LISFIC,K-1)
       Endif
      Endif
     Endif
    Next FTR_
    Close Local File [FTR_]
   Endif
  Else
   Call SYSTEME2(MACFIC,'lsadx -a'-nomap-'"'+REPFIC+'"'-EXT,'',NBTRAIT,TRAIT) From ORDSYS
  Endif
  If NBTRAIT>dim(TRAIT)
   Call ECR_TRACE(mess(29,139,1)-"."+EXT-"("+num$(NBTRAIT)+"/"+num$(dim(TRAIT))+")",1) From GESECRAN
   # Trop de fichiers
   ER = 1
  Endif
 When 1 : # C'est un fichier normal
  NBTRAIT  = 1
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
   Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT)
  Endif
 When Default : # Ca n'existe pas
  Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),1) From GESECRAN : # Fichier ou répertoire inexistant
  ER = 1
Endcase

# Initialise monitoring integration
If INTEGRE=2
 Call INITIAL_PATCH([L]NUMREQ,[L]SYRUPDATE,[L]SYRIDENT,[L]DOSSIER,[L]NBTRAIT)
 If ER
  For D=1 To NBDOS
   Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),"",5,3,3) : # Erreur
  Next D
  Goto FINEXE
 Endif
Endif

If INTEGRE=2
 Gosub VERIF
 If !OK
  For D=1 To NBDOS
   Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),"",5,3,3) : # Erreur
  Next D
  Goto FINEXE
 Else
  #107271 le dossier histo devra être revalidé
  Local Char HISAPL(GLONADS)
  For D=1 To NBDOS
   HISAPL=""
   Call GETPAR(DOSSIER(D),"HISDOS",HISAPL) From SUBADS
   If GPRODUIT<>1 & HISAPL<>""
    Call MAJPARHIS(HISAPL,"AMAJDOSREF","2") From SUBADS
   Endif
  Next D
 Endif
Endif

If [L]INTEGRE=2 and [L]SYRFLGUPD=2 and find([L]SYRSTAMAINT,3,4)>0
 Gosub READ_PATCH_FLAG
Endif

If NBTRAIT=1
 FIC_TRACE = TRAIT(1)
Elsif NBTRAIT>0
 FIC_TRACE = left$(TRAIT(1),13)+"->"+left$(TRAIT(NBTRAIT),13)
Else
 FIC_TRACE = ""
Endif

If !GSERVEUR & INTEGRE<>3
 CHAINE = mess(30,115,1) : # Intégration patch
 # add productname instead of aml 2902
 # link to jira 82177 switch to display name (case of renaming)
 CHAINE -= func APRODUCT._AGETPRODUCTNAME()
 #
 If FIC_TRACE<>""
  CHAINE -= "("+FIC_TRACE+")"
 Endif
 Call OUVRE_TRACE(CHAINE) From LECFIC
 If GBROWS
  Call OUVRE_VLC(CHAINE,mess(55,100,1),mess(85,115,1)) From GESECRAN : # Fichier/Dossier
 Else
  Local Mask PATCHA [PATA]
  Raz GABREV : # cas ou on a lancé un GESxxx avant de lancer PATCH
  Call ISWINDOWOK(nomap,"PATCHA") From INTRUTILB
  Gosub OUVRE_BOITE From WGPATCHA
  Raz [M:PATA]
  [M:PATA]TOTDOS = NBDOS
  [M:PATA]TOTFIC = NBTRAIT
  Affzo [PATA]
  Envzo
 Endif
Endif

Onerrgo ERREUR

If FIC_TRACE=""
 Call ECR_TRACE("|"+mess(56,126,1)-FICBASE,1) From GESECRAN : # Pas de patch dans le répertoire
Endif

SAVSERV  = GSERVEUR
GSERVEUR = 1 : # Pour ne pas avoir les messages de validation
OGDOSX3  = GDOSX3

Local Integer IDXOBJ :#X3-23597

For P=1 To NBTRAIT
 #Call SCRIPT_EXTRACT_INFO(TRAIT(P),PTYP,PNUM,PVER,PLAN)
 Call SCRIPT_EXTRACT_INFO(TRAIT(P),PTYP,PNUM,PFICRELABR,PLAN)

 If !SAVSERV & !GBROWS & INTEGRE<>3
  [M:PATA]NBFIC   = P
  [M:PATA]NBDOS   = 0
  [M:PATA]FICHIER = TRAIT(P)
  Affzo [PATA]NBFIC,NBDOS,FICHIER
  Envzo
 Endif
 Raz NBPROG , PROGRAMME , OKPRGDOS

 If FICCLI<>""
  FICPATCH = FICBASE
 Else
  FICPATCH = filpath(FICBASE,TRAIT(P),EXT,"","",MACFIC)
 Endif
 If GADONIX=2 & len(TRAIT(P))=3
  MNUMX = TRAIT(P)
 Else
  MNUMX = ""
 Endif
 TAILFIC = filinfo(FICPATCH,7)
 If TAILFIC<0 : # Il aurait pu disparaître!!
  Call ECR_TRACE("|"+FICPATCH-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 Else
  If [L]SYRFLGUPD<>2
&   or find([L]SYRSTAMAINT,1,2)>0
&   or ([L]PNUM>val([L]SYRMAINT) & [L]SYRSTAMAINT=3)
&   or ([L]PNUM>=val([L]SYRMAINT) & [L]SYRSTAMAINT=4)
   # integration normal , pas de update
   # cas 1 et 2 : intégration normal ou depuis le depart
   # cas 3 : intégration apres cette maintenance
   # cas 4 : intégration depuis cette maintenance.
   Gosub INTEGRE
  Endif
 Endif
 Close Local File
Next P

Openi
GPOINT = "ENDPATCH" : Gosub ENTREE From EXEFNC

If INTEGRE=2
 For D=1 To NBDOS
  Call ECR_TIME("Call UPDATE_PATCH"-DOSSIER(D)) From DOSSUB
  Call UPDATE_PATCH([L]SYRUPDATE,[L]SYRIDENT,DOSSIER(D),"",3,0,0) : # Terminé
  Call ECR_TIME("UPDATE_PATCH"-mess(3,21,1)) From DOSSUB
  If dim(ISAUTI_PROCESS)>0
        If ISAUTI_PROCESS <> 0
            If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
            # execute uti on each folder (uti after integration)
            Call ECR_TIME("Call PATCHAUTI.EXEC_PATCH_AFTER"-DOSSIER(D)) From DOSSUB
            # flush trace before call exe
            SAV_GTRACE    = GTRACE
            SAV_GERRTRACE = GERRTRACE
            Call FLUSH_TRACE From GESECRAN
            Call EXEC_PATCH_AFTER (DOSSIER(D),SAV_GTRACE,"PATCH") From SUBAUTI
            #
            GTRACE    = SAV_GTRACE
            GERRTRACE = SAV_GERRTRACE
            GLTRACE   = filinfo(GTRACE,7)
            Call ECR_TIME("PATCHAUTI.EXEC_PATCH_AFTER"-mess(3,21,1)) From DOSSUB
        Endif
  Endif
 Next D
Endif

