If INTEGRE=2
 # add fgl synchro dico 103571

 If dim([M:DIA]AFLGSYNCH)>0 and [M:DIA]AFLGSYNCH=2 :#SAM 120763 The synchronization if managed by AFLGSYNCH
  GVALIDDIFF=1
