## Personnalisation vocabulaire
If AVONUM>0
 Call ECR_TIME(mess(148,133,1)) From DOSSUB     # Personnalisation vocabulaire
 ERR = 0
 CHAINE = ""
 For I=1 To AVONUM
  K = instr(1,AVODOSLAN(I),"~")
  If K
   If CHAINE<>left$(AVODOSLAN(I),K-1)
    CHAINE = left$(AVODOSLAN(I),K-1)
    If clalev([F:AVO])>0 : Close Local File [AVO] : Endif
    If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
    Local File =CHAINE+".AVOCAB" [AVO] , =CHAINE+".ATEXTE" [ATX]
   Endif
   SCHAINE = right$(AVODOSLAN(I),K+1)
   Read [AVO]AVO0(1) = SCHAINE
   If !fstat & dim([F:AVO]CUR)>0 & [F:AVO]CUR<>0
    K = [F:AVO]CUR
    GOK = 1
    Raz NUMMOD , NBMOD
    Trbegin [ATX]
     For [AVO]AVO0 Where LAN=SCHAINE & TYP=1 & VER=K
      Read [ATX]NUMERO = [F:AVO]LAN;[F:AVO]NUM
      If fstat
       [F:ATX]LAN    = [F:AVO]LAN
       [F:ATX]NUMERO = [F:AVO]NUM
       [F:ATX]TEXTE  = [F:AVO]TXT
       Write [ATX]
       If fstat
        Call LOG_ERROR_DETAILS(1, "ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
       Endif
      Else
       [F:ATX]TEXTE = [F:AVO]TXT
       Rewrite [ATX]
       If fstat
        Call LOG_ERROR_DETAILS(2,"ATX",[F:ATX]LAN+"~"+num$([F:ATX]NUMERO),"") From GLOCK
       Endif
      Endif
      If fstat
       GOK = 0 : ERFIC = CHAINE+".ATEXTE"-[F:AVO]LAN-num$([F:AVO]NUM) : Break
      Endif
      NBMOD += 1
      NUMMOD(NBMOD) = [F:AVO]NUM
     Next AVO
    If GOK<1
     ER = 99
     NBMOD = 0
     Gosub ERREURS
     Rollback
    Else
     Commit
    Endif
    If NBMOD>0
     Call VALMSK(CHAINE,SCHAINE,NUMMOD,NBMOD) From AVOCAB
    Endif
   Endif
  Endif
 Next I
 Call ECR_TIME(mess(148,133,1)-mess(3,21,1)) From DOSSUB
Endif

# cg patch des trad uniquement pour type ind
# on valide tous les ecrans objets impactés tout comme avocab
# attention le sous prog fonctionne par dossier et par code langue
# pour instant pas d autre optimisation.
If NBINDTXT > 0
    # chargement tableau dans patchind et en fct on valide
     CHAINE  = ""
     SCHAINE = ""
     WDOSSIER = ""
     WLAN = ""
     NBMOD = 0
     # on tri tableau dans ordre dossier +code langue + numero texte
     # on charge numod pour tableau des textes a passer au sous prog
     # remarque le trt avocab est tres tres long
     # voir plus tard a optimiser.
     Sorta NBINDTXT NUMINDTXT
     For I=1 To NBINDTXT
         # appel langue par langue dans chaque dossier avec table des numeros textes modifies
         # si langue non defini dans dossier on ne fait rien
          K = instr(1,NUMINDTXT(I),"~")
          If K
            If CHAINE<>left$(NUMINDTXT(I),K-1)
                CHAINE = left$(NUMINDTXT(I),K-1)
            Endif
            SCHAINE = right$(NUMINDTXT(I),K+1)
            # enlever les car dernier le ~ sur schaine
            K = instr(1,SCHAINE,"~")
            If K
                SCHAINE = left$(SCHAINE,K-1)
            Endif
          Endif
          # rupture dossier
          If CHAINE <> WDOSSIER
              If NBMOD>0
                  Call VALMSK(WDOSSIER,WLAN,NUMMOD,NBMOD) From AVOCAB
              Endif
              Raz NUMMOD , NBMOD
              WDOSSIER = CHAINE
              WLAN = SCHAINE
          Endif
          # rupture lan
          If SCHAINE <> WLAN
              If NBMOD>0
                  Call VALMSK(WDOSSIER,WLAN,NUMMOD,NBMOD) From AVOCAB
              Endif
              Raz NUMMOD , NBMOD
              WDOSSIER = CHAINE
              WLAN     = SCHAINE
          Endif
          # chargement tableau nummod
          NBMOD +=1
          NUMMOD(NBMOD) = NUMINDNUM(I)
     Next I
     # pas eu de rupture dans boucle mais on peut etre sur un seul element
     If NBMOD>0
          Call VALMSK(WDOSSIER,WLAN,NUMMOD,NBMOD) From AVOCAB
     Endif
    # voir aussi la valid des menus?
Endif

