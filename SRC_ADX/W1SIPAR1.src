#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:26"
A_USER  = "DOC"
A_STAMP = "20181109230626"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SIPAR1 [SIP1]
Gosub HORODAT
Local Inpbox "SIPAR1" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP1] As [SIM_]
Grizo [SIP1]5
Grizo [SIP1]10
Grizo [SIP1]15
Grizo [SIP1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=94 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=94 : Y1(1)=4 : Y2(1)=7
X1(2)=1 : X2(2)=94 : Y1(2)=8 : Y2(2)=10
X1(3)=1 : X2(3)=94 : Y1(3)=11 : Y2(3)=17
Return

$ON_PRXFLD1
Onevent CONTROL Call C_PRXFLD1(zc) From W1SIPAR1
Onevent BEFORE_INPUT Call AS_PRXFLD1(zc) From W1SIPAR1
Return

Subprog AS_PRXFLD1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PRXFLD1(zc) From W1SIPAR1
Gosub _AFF
End

Subprog C_PRXFLD1(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_PRXFLD1(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "PRXFLD1" : GZNUM = 27404 : Endif
Gosub _AFF
End

Subprog S_PRXFLD1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELFLDTAB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFLDTAB1"
 PARMSK(1) = "XIART"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELFLDTAB1","LNKSUB","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

