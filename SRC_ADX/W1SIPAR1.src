Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DEFTWD(zc) From W1SIPAR1
Onkey   2 Titled GBOUTS Call S_DEFTWD(zc) From W1SIPAR1
Onkey 144 Titled GBOUTP Call P_DEFTWD(zc) From W1SIPAR1
Onkey 146 Titled GBOUTA Call SA_DEFTWD(zc) From W1SIPAR1
Gosub _AFF
End

Subprog C_DEFTWD(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TWD","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "DEFTWD" : GZNUM = 1809 : Endif
Gosub _AFF
End

$AMM_DEFTWD
Call AM_DEFTWD(zc)
If !mkstat & GOBJET
 zoncou = "DEFTWD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DEFTWD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZDEFTWD)")>indice
 [M]DEFTWD(indice) = VALEUR
 Affzo ZDEFTWD(indice)
Endif
Gosub _AFF
End

Subprog S_DEFTWD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TWD"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_DEFTWD(VALEUR)
Variable Char    VALEUR()
Call OBJET("TWD",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_DEFTWD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TWD"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DEFTWD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TWD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDEFTWD
Onevent BEFORE_AREA Gosub AV_ZDEFTWD From W1SIPAR1
Return

$AV_ZDEFTWD
Call LECTEXTRA(zc,"TABWEEDIA","TWDDESAXX",num$([M]DEFTWD(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_IPTDATSTK
Onevent INIT_AREA Call D_IPTDATSTK(zc) From W1SIPAR1
Onevent BEFORE_AREA Gosub AV_IPTDATSTK From W1SIPAR1
Return

$AV_IPTDATSTK
Chgfmt [M]IPTDATSTK(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog D_IPTDATSTK(VALEUR)
Variable Date    VALEUR
If varinit([M]IPTDATSTK,indice)=0
 VALEUR = date$
Endif
Gosub _AFF
End

$CHG_STY
Return


