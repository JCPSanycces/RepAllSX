Subprog AS_ITGAV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3572,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ITGAV(zc) From W1SIPAR1
Onkey   2 Titled GBOUTS Call S_ITGAV(zc) From W1SIPAR1
Onkey 144 Titled GBOUTP Call P_ITGAV(zc) From W1SIPAR1
Onkey 146 Titled GBOUTA Call SA_ITGAV(zc) From W1SIPAR1
Gosub _AFF
End

Subprog C_ITGAV(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ITG","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "ITGAV" : GZNUM = 39874 : Endif
Gosub _AFF
End

$AMM_ITGAV
Call AM_ITGAV(zc)
If !mkstat & GOBJET
 zoncou = "ITGAV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ITGAV(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZITGAV)")>indice
 [M]ITGAV(indice) = VALEUR
 Affzo ZITGAV(indice)
Endif
Gosub _AFF
End

Subprog S_ITGAV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ITG"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ITGAV(VALEUR)
Variable Char    VALEUR()
Call OBJET("ITG",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_ITGAV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ITG"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ITGAV(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ITG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

