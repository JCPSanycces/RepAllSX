#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GBIDC3, GBIDC1
GBIDI1 = func ASYRFIL.CTL_VOLFIL(2,"[tmp]/toto/patch_amk.dat",GBIDC3)
Infbox num$(GBIDI1)-GBIDC1-"fullpath="+GBIDC3
End

#---------------------------------------------------------------------------------------------------#
# This treatment create a request "Patch integration" in the batch server
# The file contains data must be copied in space directory before this operation
# When there are more one folder, the patch must apply from the folder X3
#
# POST this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/schedule
#
# With content-Type=application/json contents
# {
#   "task": "APATCH",
#   "startDate": "2013-12-31T23:55:00Z",
#   "parameters":{
#     "folders": ["TEST2","MONO"],
#     "fileName": "[tmp]/toto/patch_amk.dat"
#   }
# }
#---------------------------------------------------------------------------------------------------#

#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK

ERROR = func BATCH(ACTX,PSYR,ARCV,JSON,ASND,PSYR.OPERATION,PSYR.SELREP)
End ERROR

#----------------------------------------------------------------#
Funprog BATCH(ACTX,PSYR,PARCV,NODE,ASND,OPER,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance PSYR  Using C_ASYR
Variable Instance PARCV Using C_ASYRRCV
Variable Instance NODE  Using C_ASYRJSO
Variable Instance ASND  Using C_ASYRSND
Value    Char     OPER , KEYS

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Instance UPD(1..) Using C_ADELTA

Local Integer I , J , K , ASTATUS , EXIST , ER
Local Char    MESSAGE(250) , TIM(10) , CHAINE(250)
Local Date    DAT
Local Char    TASK(30) , USER(30)

ASTATUS = func ASYRDEL.PARSEDELTA(GACTX,NODE,UPD)
Raz ASND.DATA

Gosub TRACE_RECEIVE_DELTA

# user
USER = GACTX.USER
Local File AUTILIS [AUS]
Read [AUS]CODUSR=USER
If fstat
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(58,149,1),USER))
Endif
Close Local File [AUS]
If ERROR <> [V]CST_AOK : Goto ERR_DETAIL : Endif

# task
J = find ("task",UPD(1..maxtab(UPD)).PRO)
If J & UPD(J).CHR<>null
 TASK = func ASYRFIL.PARAM(func ASYRSUB.AGETCHR(UPD(J).CHR))
Endif

# date & time of request
J = find ("startDate",UPD(1..maxtab(UPD)).PRO)
If J & UPD(J).CHR<>null
 CHAINE = func ASYRFIL.PARAM(func ASYRSUB.AGETCHR(UPD(J).CHR))
 Onerrgo ERRORS
 DAT = gdat$(ctrans(left$(CHAINE,10),"-",""))
 TIM = ctrans(seg$(CHAINE,12,16),":","")
 Onerrgo
 If ER
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,CHAINE-":"-mess(1,104,1))
  Goto ERR_DETAIL
 Endif
Else
 DAT = date$
 TIM = left$(time$,2)+mid$(time$,4,2)
Endif

Case TASK

 When "APATCH"

  Local Char    FOLDERS(30)(1..50) , NAMFIL(250)
  Local Integer NBFOLD , TYP

  # type devices (1=client, 2=server)
  J = find ("type",UPD(1..maxtab(UPD)).PRO)
  If J & UPD(J).CHR<>null
   TYP = val(func ASYRFIL.PARAM(func ASYRSUB.AGETCHR(UPD(J).CHR)))
  Else
   TYP = 2
  Endif

  # file
  J = find ("fileName",UPD(1..maxtab(UPD)).PRO)
  If J & UPD(J).CHR<>null
   NAMFIL = func ASYRFIL.PARAM(func ASYRSUB.AGETCHR(UPD(J).CHR))
  Endif

  # folders
  NBFOLD = 0
  J = find ("folders",UPD(1..maxtab(UPD)).PRO)
  While J>0
   If UPD(J).CHR<>null
    NBFOLD += 1
    If NBFOLD>dim(FOLDERS)
     ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func AFNC.MES1(mess(266,125,1),num$(NBFOLD)))
     Break
    Endif
    FOLDERS(NBFOLD) = func ASYRFIL.PARAM(func ASYRSUB.AGETCHR(UPD(J).CHR))
   Endif
   K = find ("folders",UPD(J+1..maxtab(UPD)).PRO)
   If K : J += K : Else : J = 0 : Endif
  Wend
  If ERROR : Goto ERR_DETAIL : Endif

  # patch
  ASTATUS = func PATCH(USER,NAMFIL,TYP,FOLDERS,DAT,TIM,MESSAGE)
  If ASTATUS<>CST_AOK
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,MESSAGE)
   Goto ERR_DETAIL
  Endif

  # end ok
  Call SUCCESS_MESSAGE(PSYR,MESSAGE,ASND.DATA)

 When Default
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(57,149,1),TASK))
Endcase

ASND.URL      = PSYR.PREFIX+'/'+OPER
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+OPER

End ERROR

#---------------------#
$ERRORS
ER = errn
Resume

#-----------------------------------------------------#
Subprog SUCCESS_MESSAGE(PSYR,MES,WCLOB)
Variable Instance PSYR  Using C_ASYR
Value    Char     MES
Variable Clbfile  WCLOB
Local Instance  JSO(1..) Using C_ASYRJSO
Local Instance  REP      Using C_AREPENT
Local Integer I , J , REQ
Local Char    REPRES(30)
Local Char DESCRI(250)

REPRES = "APATCHTMP"
Gosub INIVAR From ASYRJSO
I = instr(1,MES,"(")
J = instr(1,MES,")")
If I & J & J>I
 REQ = val(seg$(MES,I+1,J-1))
Endif
NIV = 1
NODEPRO = ''
Gosub ADDOBJECT From ASYRJSO
If REQ
 Call DESCRIPTION_REPRESENTATION(REP,REPRES) From =func SUBASW.PREFIX_TRT+REPRES
 DESCRI = "@"+num$(REP.DES)
 NODEPRO = '"$links"'
 Gosub ADDOBJECT From ASYRJSO

 NODEPRO = '"$query"'
 Gosub ADDOBJECT From ASYRJSO

 NODEPRO = '"$title"'
 NODESVAL = '"{'+DESCRI+'}"'
 Gosub ADDSTRING From ASYRJSO

 NODEPRO = '"$type"'
 NODESVAL = '"'+PSYR.PRELNK+'"'
 Gosub ADDSTRING From ASYRJSO

 NODEPRO = '"$url"'
 NODESVAL = '"'+PSYR.PREFIX+'/'+REPRES
 NODESVAL += PSYR.URLREP+REPRES+'.$query'
 NODESVAL += '&where=(NUMREQ eq '+num$(REQ)+')"'
 Gosub ADDSTRING From ASYRJSO

Gosub ENDNIV From ASYRJSO
 Gosub ENDNIV From ASYRJSO

 NODEPRO = '"$localization"'
 Gosub ADDOBJECT From ASYRJSO

 NODEPRO = '"'+DESCRI+'"'
 NODESVAL = '"'+func ASYRJSO.TEXLOC(DESCRI)+'"'
 Gosub ADDSTRING From ASYRJSO
 Gosub ENDNIV From ASYRJSO
Endif
NODEPRO = '"$diagnoses"'
Gosub ADDOBJECT From ASYRJSO

NODEPRO = ''
Gosub ADDARRAY From ASYRJSO

NODEPRO = '"$severity"'
NODESVAL = '"'+func ASYRSUB.ERROR(1)+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"$message"'
NODESVAL = '"'+func ASYRSUB.STRING_TO_SYR(MES)+'"'
Gosub ADDSTRING From ASYRJSO

Gosub ENDNIV From ASYRJSO
Gosub ENDNIV From ASYRJSO
Gosub ENDNIV From ASYRJSO
Call GENERATE_JSON(TBNIV(1),WCLOB) From ASYRJSO
End

#------------------------------------------#
# Error batch
#------------------------------------------#

$ERR_DETAIL
End ERROR

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

Funprog PATCH(USER,NAMFIL,TYP,FOLDERS,DAT,TIM,MESSAGE)
Value    Char    USER , NAMFIL
Value    Integer TYP
Value    Char    FOLDERS()(1..)
Value    Date    DAT
Value    Char    TIM
Variable Char    MESSAGE

Local Char    ABRSCR(20)(1..16) , MESSAGE(250) , FILE_FULL(250)
Local Integer I , ASTATUS , NBFOLD

ASTATUS = CST_AOK

Local Mask PATCH [PATCH]

ABRSCR(1) = "PATCH"

# control folders
Raz I , [M:PATCH]DOSSIER
NBFOLD = max(0,find("",FOLDERS)-1)
Call RANGE(FOLDERS,NBFOLD,[M:PATCH]DOSSIER,I) From APATCHFOLDER_CSTD
If I=0
 MESSAGE = "No folder for apply this patch"
 ASTATUS = CST_AERROR
Else
 [M:PATCH]NBDOS = I
 For I=1 To NBFOLD
  If !find(FOLDERS(I),[M:PATCH]DOSSIER)
   MESSAGE = FOLDERS(I)-": wrong folder"
   ASTATUS = CST_AERROR
   Break
  Endif
 Next I
Endif
If ASTATUS<>CST_AOK : Goto END_PATCH : Endif

# control file
If NAMFIL=""
 MESSAGE = "The file name isn't defined"
 ASTATUS = CST_AERROR
Else
 If instr(1,NAMFIL,"[")
  [M:PATCH]VOLFIL = NAMFIL
 Else
  [M:PATCH]VOLFIL = "[TMP]/"+func ASYRFIL.CONTROL_PATH(NAMFIL)
 Endif
 ASTATUS = func ASYRFIL.CTL_VOLFIL(GACTX,TYP,[M:PATCH]VOLFIL,[M:PATCH]FICHIER)
Endif
If ASTATUS<>CST_AOK : Goto END_PATCH : Endif

[M:PATCH]TYPEXP  = TYP
[M:PATCH]INTEG   = 2
[M:PATCH]REM     = 2
[M:PATCH]AVALDIF = 2

# create request in folder X3
ASTATUS = func CRERQT(nomap,USER,"",0,"PATCH",1,DAT,TIM,num$(adxtcp),ABRSCR,MESSAGE)

#-----------------#
$END_PATCH
Close Local Mask [PATCH]
End ASTATUS

#--------------------------------------------------------------------------------------------------#
# Create a request in batch server
#--------------------------------------------------------------------------------------------------#
# if it possible use ASYRMNGTREQ.CRERQT
Funprog CRERQT(DOSSIER,USER,GROUPE,GRPNUM,TACHE,FLG,DAT,TIM,SERVICE,ABRECR,MESSAGE)
Value    Char    DOSSIER
Value    Char    USER
Value    Char    GROUPE
Value    Integer GRPNUM
Value    Char    TACHE
Value    Integer FLG
Value    Date    DAT
Value    Char    TIM
Value    Char    SERVICE
Value    Char    ABRECR()
Variable Char    MESSAGE

Local File ABATPAR [ABP_]
Local File ABATTAC [ABT_]
Local File ABATRQT [ABR_]

Local Integer I , K , NBRROL , MAXROL , REQUETE , ASTAT , ASTATUS

ASTATUS = CST_AOK
MAXROL  = 3
NBRROL  = 0

Gosub TR_RQT

If ASTAT=0
 # Requête transmise au serveur
 MESSAGE = TACHE-":"-mess(29,134,1)+" ("+num$(REQUETE)+")"
Else
 ASTATUS = CST_AERROR
 Case ASTAT
  When 1       : MESSAGE = mess(60,100,1)  : # Enregistrement verrouillé
  When 2       : MESSAGE = mess(153,115,1) : # Clé suivante lue
  When 3       : MESSAGE = mess(22,100,1)  : # Clé déjà existante
  When 4       : MESSAGE = mess(11,100,1)  : # Début/fin de fichier
  When 5       : MESSAGE = mess(154,115,1) : # Pas d'enregistrement courant
  When 6       : MESSAGE = mess(240,115,1) : # Enregistrement obsolète
  When Default : MESSAGE = mess(6,123,1)   : # Erreur
 Endcase
 # Erreur soumission requête
 MESSAGE = mess(112,134,1)-":"-MESSAGE
Endif

End ASTATUS

#-----------------#
$TR_RQT
Trbegin [ABP_] , [ABR_]
 Readlock [ABP_]SPOOL First
 If fstat=1
  Goto ROLL_RQT
 Elsif fstat
  ASTAT = fstat
  Goto AB_RQT
 Endif
 REQUETE = [F:ABP_]NUMREQ
 Read [ABT_]CODTAC = TACHE
 Raz [F:ABR_]
 [F:ABR_] = [F:ABT_]
 [F:ABR_]DOSSIER = DOSSIER
 [F:ABR_]USER    = USER
 [F:ABR_]TACHE   = TACHE
 [F:ABR_]ETAT    = [F:ABT_]TRAIT
 [F:ABR_]NUMREQ  = [F:ABP_]NUMREQ
 [F:ABR_]FLAG    = FLG
 [F:ABR_]DAT     = DAT
 [F:ABR_]HEURE   = TIM
 #109897
 #[F:ABR_]SERVICE = SERVICE
 [F:ABR_]GRP     = GROUPE
 [F:ABR_]NUMGRP  = GRPNUM
 Gosub ECRIT_PARAM
 If ASTAT<>0 : Goto AB_RQT : Endif
 [F:ABP_]NUMREQ  += 1
 Rewrite [ABP_]
 If fstat
  ASTAT = fstat
  Goto AB_RQT
 Endif
Commit
Return

#--------------#
$AB_RQT
Rollback
Return

#------------------#
$ROLL_RQT
Rollback
NBRROL += 1
If NBRROL>MAXROL
 ASTAT = fstat
 Return
Else
 Sleep 2
 Goto TR_RQT
Endif

#-------------------------------------------#
$ECRIT_PARAM
Local Integer  LL
LL = [F:ABR_]NUMREQ
Call SETPAR(ABRECR,LL,ASTAT)
If ASTAT<>0 : Return : Endif
Write [ABR_]
If fstat
 ASTAT = fstat
Endif
Return

#----------------------------------------------------#
# Copy contents masks to file [ABL_]
#----------------------------------------------------#

Subprog SETPAR(ABRMSK,REQUETE,ASTAT)
Value Char ABRMSK()
Value Integer REQUETE
Variable Integer ASTAT
If clalev([F:ABL_])=0 : Local File ABATRQTL [ABL_] : Endif
Default File [ABL_]
Call ECRIT(ABRMSK,"","",0,REQUETE,ASTAT)
End

#----------------------------------------------------#
# Copy contents masks to default file
#----------------------------------------------------#

Subprog ECRIT(ABRMSK,CODABT,CODTAC,LIG,NUMREQ,ASTAT)
Value Char    ABRMSK()
Value Char    CODABT , CODTAC
Value Integer LIG , NUMREQ
Variable Integer ASTAT

Local Integer I , J , NBVAR , LNG , TYP , DIME , LMAX , MA , NUMS
Local Char    VARI(20) , PARAM(20) , ABREV(20) , PARS(250)
Local Char    VALEUR(250) , VALS(250)
Local Decimal NOMBRE , NUMERO
Local Date    DAT
Local Clbfile CHAINE(7)

LMAX = type([F]VALEUR)-10
NUMERO = 0

For MA=0 To dim(ABRMSK)-1
 If ABRMSK(MA)<>""
  ABREV = "[M:"+ABRMSK(MA)+"]"
  If evalue("clalev("+ABREV+")")>0
   NBVAR = evalue("clanbs("+ABREV+",1)")
   For I=1 To NBVAR
    VARI = evalue("clavar("+ABREV+","+num$(I)+")")
    TYP  = evalue("type("+ABREV+VARI+")")
    DIME = evalue("dim("+ABREV+VARI+")")
    For J=1 To DIME
     If DIME=1
      [L]PARAM = VARI
     Else
      [L]PARAM = VARI+"("+num$(J-1)+")"
     Endif
     Case TYP
      When 1,2,4,5,6,7,8,9
       NOMBRE = evalue(ABREV+[L]PARAM)
       If NOMBRE<>0
        [L]VALEUR   = num$(NOMBRE)
        Gosub ECRIT_PAR
        If ASTAT<>0 : Break 3 : Endif
       Endif
      When 3
       DAT = evalue(ABREV+[L]PARAM)
       If DAT<>[0/0/0]
        [L]VALEUR   = DAT
        Gosub ECRIT_PAR
        If ASTAT<>0 : Break 3 : Endif
       Endif
      When Default
       LNG = evalue("len("+ABREV+[L]PARAM+")")
       If LNG<>0
        CHAINE = evalue(ABREV+[L]PARAM)
        Repeat
         [L]VALEUR   = left$(CHAINE,LMAX)
         Gosub ECRIT_PAR
         If ASTAT<>0 : Break 4 : Endif
         CHAINE = right$(CHAINE,LMAX+1)
        Until CHAINE=""
       Endif
     Endcase
    Next J
   Next I
  Endif
 Endif
Next MA
If NUMERO=0
 Gosub ECRIT_PAR : # Pour forcer l'écriture au moins d'une enregistrement
Endif
End

#------------------------------------#
$ECRIT_PAR
Raz [F]
[F] = [L]
[L]NUMERO += 1
[F]NUM    = [L]NUMERO
Write [F]
If fstat
 ASTAT = fstat
Endif
Return

#----------------------------#
Funprog ABRDEF
Local Char    ABREV(30)
Local Integer K
ABREV = dbgstr(2)
K = instr(1,ABREV,",")
If K
 ABREV = left$(ABREV,K-1)
Endif
ABREV = ctrans(ABREV,", []","")
End ABREV

#---------------------------------#
$TRACE_RECEIVE_DELTA
Local Char WCHAINE(250)
Call TRACE("asyrbatch receive-delta"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM
For I=1 To maxtab(UPD)
 WCHAINE = "col="+UPD(I).COL-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)-"uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 If UPD(I).CHR<>null : WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR) : Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Call TRACE("end data") From ASYRCOM
Return

