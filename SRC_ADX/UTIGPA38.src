#<AdxTL>@(#)3.0.0.0 $Revision$ [BOH]IDENT1 correction
##########################################################################
# UTIGPA38: Reinit de [F:BOH]IDENT1                     Module GPAO      #
#           à [F:BOH]ITMREF+"~"+[F:BOH]BOMALT                            #
##########################################################################
# GH 31/12/12                                           Bug 85668        # 
##########################################################################

Call MAJ_UTIGPA38
End

##################################
Subprog MAJ_UTIGPA38
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA38: [BOH]IDENT1 correction") From LECFIC
Call EXE_UTIGPA38(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA38(DOSSIER)
Value Char DOSSIER


If filinfo(filpath("FIL","BOM","fde",DOSSIER),0)  <= 0  : End : Endif

Call ECR_TRACE("UTIGPA38 : Process Start on : "+DOSSIER,0) From GESECRAN

Local File =[L]DOSSIER+".BOM"  [BOH]
Local Integer MAJ

GOK=1
Trbegin [BOH]
 For [BOH]
     If [F:BOH]IDENT1 <> [F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT)
         GMESSAGE = mess(153,198,1)-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$( [F:BOH]BOMALTTYP) : # Nomenclature
         [F:BOH]IDENT1=[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT)
         Rewrite [BOH]
          If fstat 
             GOK=0
             # Table ... Erreur en réécriture
             Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"BOM"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
          Else
             MAJ+=1
          Endif
      Endif
 Next
Commit

GMESSAGE=""
If MAJ>0
   GMESSAGE=":"-num$(MAJ)-"Records updated"
Endif
Call ECR_TRACE("UTIGPA38 : Process End on : "+DOSSIER-GMESSAGE,0) From GESECRAN
GMESSAGE=""
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA38(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIGPA38(APPLI)
End



