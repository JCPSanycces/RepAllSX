#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Ajout paramètre ABREV dans l'action SELMBPA
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Add ABREV parameter on SELMBPA action") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ADDPAR
End

#-------------------#
$ADDPAR

Local Char NEWPAR(250)

Local File =DOSSIER+".AMSKACT"   [AMA] 
Local File =DOSSIER+".AMSKPAR"   [AMP]

# Mise à jour de la table AMSKPAR
Call ECR_TRACE(mess(81,125,1)-"AMSKPAR:"-time$,0) From GESECRAN

NEWPAR = "ABREV"

Trbegin [AMP]
 For [AMA] Where TYPAFF=1 & ACTION="SELMBPA"
  Readlock [AMP]CODPAR=1;[F:AMA]CODAFF;[F:AMA]CODZON;NEWPAR
  If fstat
   Raz [F:AMP]
   [F:AMP]TYPAFF = 1
   [F:AMP]CODAFF = [F:AMA]CODAFF
   [F:AMP]CODZON = [F:AMA]CODZON
   [F:AMP]CODPAR = NEWPAR
   [F:AMP]VALPAR = '""'
   Write [AMP] 
   If fstat
    Call ERREUR("AMSKPAR"-[F:AMP]CODAFF-[F:AMP]CODZON,1) From DOSDIC
   Endif
  Endif
 Next AMA
Commit

Close Local File [AMA],[AMP]

Return
