#<AdxTL>@(#)2.0.0.0 $Revision$

Call VALIDATION(0,"ACLATYPE",nomap,1,1,GBIDI1,GBIDI3)  # From ACLAVALTECH
Infbox num$(GBIDI3)-num$(GBIDI1)
End


#-------------------------------------------------------------------#
Subprog VALID_ALL_CLA_TECH(PDOSSIER)
Value Char PDOSSIER

Local Integer OK,TYPAGE
If clalev([F:ACL_])=0   : Local File =[L]PDOSSIER+".ACLASSE"    [ACL_]   : Endif

For [F:ACL_]ACLA0 Where TYPCLA=4 & CODCLA<>"OBJECT"
 Call VALIDATION(0,[F:ACL_]CODCLA,[L]PDOSSIER,1,0,[L]TYPAGE,[L]OK) From ACLAVALTECH
Next

End

#------------------------------------------------------------#
# Génération de la structure C_TECH*
#------------------------------------------------------------#

Subprog VALIDATION(TEST,CODCLA,DOSSIER,SILENCE,VALP,TYPAGE,OK)
Value    Integer TEST
Value    Char    CODCLA
Value    Char    DOSSIER
Value    Integer SILENCE
Value    Integer    VALP
Variable Integer    TYPAGE
Variable Integer OK

Onerrgo ERREUR

Gosub DEFVAR

If TEST
 # Validation de la structure
 Call OUVRE_TRACE(mess(1,140,1)-CODCLA) From LECFIC
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

If !SILENCE
 Call TEMPON(mess(1,140,1)-CODCLA) From GESECRAN
Endif

If GTRACE<>""
 Call ECR_TRACE(mess(1,140,1)-CODCLA,0) From GESECRAN
Endif

Local Integer WLOCKSTC
#----- Contrôle lock logique -----#
Call JELOCKEDOS([L]DOSSIER,"AVALSUPSTC",WLOCKSTC) From OBJDIV
If WLOCKSTC=0
 WLOCKSTC=1
 Lock ="AVALSUPSTC" From =[L]DOSSIER With lockwait=-1
Else
 WLOCKSTC=0
Endif

Gosub OPEN_FILE From ACLAVALLEC

Gosub VERF_CLA
If STA : Goto PERDU : Endif


Call DELETE_STC(DOSSIER,[L]CODCLA) From ACLAVALSUB : # Delete STC and WMCL*

Gosub TRT_CLA
If STA : Goto PERDU : Endif

Call STC_DEB([L]APPLI,[L]MACHINE,[L]NOMSTC,[L]IDENTSTC,[L]CODCLA,[L]INTITCLA,[L]MAGIC,[L]TITETA,"STC") From ACLASUB
Call STC_FIN_TECH([L]CLOB,[L]NOMSTC,[L]DOSSIER,"STC",[L]VALP,[L]TYPAGE,[L]STA,MESSAGE) From ACLASUB

If !STA : Goto PERDU : Endif

#------------------------------------------------------------#
#------------------------------------------------------------#
$FIN
Gosub CLOSE_FILE From ACLAVALLEC
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
If WLOCKSTC
 Unlock ="AVALSUPSTC" From =[L]DOSSIER
Endif
Onerrgo
End

#------------------------------------------------------------#
#------------------------------------------------------------#
$PERDU
If MESSAGE<>""
 Call ECR_TRACE(MESSAGE,1) From GESECRAN
 If dim(GMESSAGE)>0 : GMESSAGE = MESSAGE : Endif
 Raz MESSAGE
Endif
Goto FIN

#------------------------------------------------------------#
#------------------------------------------------------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
Resume

#------------------------------------------------------------#
#------------------------------------------------------------#
$DEFVAR
Local Char      MACHINE(GDIMFIC) , APPLI(GLONADS) , MES(250)
Local Integer   STA
Local Clbfile   CLOB(9)
Local Integer   OK,K,I,WLON,WMENU,WDIME,DIF
Local Schar     LIGNE(250),NOMSTC(60),IDENTSTC(20)
Local Schar     INTITCLA(60), MAGIC(80) , TITETA (60)
IDENTSTC  = "## ACLA-CLASSE ##"
NOMSTC    = func SUBACLA.PREFIX_CLA+[L]CODCLA
MAGIC     = mess(77,133,1) : # Superviseur Adonix
TITETA    = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Return

#------------------------------------------------------------#
#------------------------------------------------------------#
$VERF_CLA
Local Char MESSAGE(250)
Read [F:ACLA]ACLA0 = [L]CODCLA
If fstat
 [L]STA   = 1
 MESSAGE = [L]CODCLA-":"-mess(4,140,1) : # Classe inexistante
 Return
Elsif [F:ACLA]CODACT<>""
 Read [ACV]CODACT = [F:ACLA]CODACT
 If fstat or [F:ACV]FLACT<>2
  [L]STA    = 1
  MESSAGE = [L]CODCLA-":"-mess(31,140,1)-"("+[F:ACLA]CODACT+")" : # Classe inactive
  #91436 warning sur classe/rep inactive
  Call ECR_TRACE(MESSAGE,-1) From GESECRAN
  If dim(GMESSAGE)>0 : GMESSAGE = MESSAGE : Endif
  Raz MESSAGE
  #
  Return
 Endif
Elsif [F:ACLA]CODCLA="OBJECT"
  [L]STA    = 1
  MESSAGE = [L]CODCLA-":"-mess(68,140,1) : #  Classe non générée
  Return
Endif
[L]INTITCLA =  func ASYRFNC.TEXTE([ACLA]INTCLA)
Return

#------------------------------------------------------------#
#------------------------------------------------------------#
$TRT_CLA
Raz CLOB
For [ACLAF]ACLAF1 Where CODCLA = [L]CODCLA
 OK = 0
 Gosub VERF_FLDCLA
 If K>=0
  If [ACLAF]LNKCLA<>""     # Déclaration de la sous-classe
   LIGNE = "Instance"-[ACLAF]FLDCLA
   If WDIME>1
    LIGNE += "(1.."+num$(WDIME)+")"
   Elsif WDIME<>1
    LIGNE += "(1..)"
   Endif
   If [ACLAF]LNKCLA="OBJECT"
    LIGNE -= "Using OBJECT"
   Else
    LIGNE -= "Using C_"+[ACLAF]LNKCLA
   Endif
   Gosub ADDCLB
   LIGNE = "" : Gosub ADDCLB
  Endif
  If [ACLAF]CODTYP<>"" :    # Déclaration du champ
   Case [ATY]TYPTYP
    When 1,2,3   : LIGNE = "Integer "
    When 4,5,6   : LIGNE = "Decimal "
    When 8       : LIGNE = "Date    "
    When 9       : LIGNE = "Blbfile "
    When 10      : LIGNE = "Clbfile "
    When 11      : LIGNE = "Uuident "
    When 12      : LIGNE  = "Datetime "
    When Default : LIGNE = "Char    "
   Endcase
   LIGNE += [ACLAF]FLDCLA
  If find([ATY]TYPTYP,7,9,10) & WLON>0
   LIGNE += "("+num$(WLON)+")"
  Endif
  If WDIME>1
   LIGNE += "(1.."+num$(WDIME)+")"
  Elsif WDIME<>1
   LIGNE += "(1..)"
  Endif
  LIGNE += "{}"  : Gosub ADDCLB
  LIGNE = ""  : Gosub ADDCLB
  Endif
 Endif
Next
LIGNE = "" : Gosub ADDCLB
LIGNE = "%% # End Classe" : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB

LIGNE = "####################################################################" : Gosub ADDCLB
LIGNE = "# Method constructor" : Gosub ADDCLB
LIGNE = "Method CONSTRUCTOR" : Gosub ADDCLB
LIGNE = "####################################################################" : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "####################################################################" : Gosub ADDCLB
LIGNE = "# Set timestamp representation" : Gosub ADDCLB
LIGNE = "####################################################################" : Gosub ADDCLB
LIGNE = "Fmethod STAMP" : Gosub ADDCLB
LIGNE = 'End "'+func SUBADC.CNVSYR(timestamp$)+'"' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
If [L]CODCLA="ASYRJSO"
 LIGNE = "####################################################################" : Gosub ADDCLB
 LIGNE = "# Method GET CNT" : Gosub ADDCLB
 LIGNE = "####################################################################" : Gosub ADDCLB
 LIGNE = "Fmethod AGETCNT" : Gosub ADDCLB
 LIGNE = 'If !this.LENGTH : End "" : Endif' : Gosub ADDCLB
 LIGNE = "End seg2$( this.CLB.CLB, this.START, this.START+this.LENGTH-1)" : Gosub ADDCLB
 LIGNE = "####################################################################" : Gosub ADDCLB
 LIGNE = "# Method SET CNT" : Gosub ADDCLB
 LIGNE = "####################################################################" : Gosub ADDCLB
 LIGNE = "Method ASETCNT(_CNT)" : Gosub ADDCLB
 LIGNE = "Variable Clbfile _CNT" : Gosub ADDCLB
 LIGNE = "this.START = 1+this.CLB.LENGTH" : Gosub ADDCLB
 LIGNE = "this.LENGTH = len(_CNT)" : Gosub ADDCLB
 LIGNE = "this.CLB.LENGTH += this.LENGTH" : Gosub ADDCLB
 LIGNE = "Append this.CLB.CLB , _CNT" : Gosub ADDCLB
 LIGNE = "End" : Gosub ADDCLB
Endif
Return

#------------------------------------------------------------#
#------------------------------------------------------------#
$VERF_FLDCLA
If [F:ACLAF]FLDGRP<>""
 Read [ACLAC]ACLAC0=[F:ACLA]CODCLA;[F:ACLAF]FLDGRP
 If !fstat
   K = [ACLAC]MAXCOL
   If [ACLAC]ACTCOL<>""
    Read [ACV]CODACT = [ACLAC]ACTCOL
    If fstat or [F:ACV]FLACT<>2
     K = -1
    Elsif [F:ACV]DIME<>0
     K = [F:ACV]DIME
    Endif
   Endif
 Endif
Else
 K = 1
 If [F:ACLAF]ACTFLD<>""
  Read [ACV]CODACT = [F:ACLAF]ACTFLD
  If fstat or [F:ACV]FLACT<>2
   K = -1
  Elsif [F:ACV]DIME<>0
   K = [F:ACV]DIME
  Endif
 Endif
Endif
If K>=0
 WDIME = K
 Read [ATY]CODTYP = [ACLAF]CODTYP
 If !fstat
  If find([F:ATY]TYPTYP,7,9,10) & [F:ATY]LNGTYP<>0
   WLON = [F:ATY]LNGTYP
  Else
   WLON =  [ACLAF]LONG
  Endif
  If [F:ATY]TYPTYP=1
   If [F:ATY]NOLIB<>0
    WMENU = [F:ATY]NOLIB
   Else
    WMENU = [ACLAF]NOLIB
   Endif
  Endif
 Endif
Endif
Return

#------------------------------------------------------------#
#------------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

