#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
##########################################################
##  import /export avec le modèle TRDXLS          #######
##########################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_INICRE"    : Gosub IMP_INICRE
 When "IMP_INIMOD"    : Gosub IMP_INIMOD
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CREMOD
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_CREMOD
 When "IMP_FERME"     : Gosub FERME
 When "EXPORT"        : Gosub EXPORT
 When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return


$OUVRE
Global Char SAVE_ZLAN(3)
Global Char TRAD(123)    
Return


$EXP_OUVRE
Global Char LANDEST(3)
If clalev([F:AST2])=0    : Local File APLSTD     [AST2]   : Endif

Return

# l'action EXPORT est la SEULE appellée à chaque record en export
# il n'y en a pas d'autre
$EXPORT
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="1"
Local Char LANG : LANG=LAN

GIMP(1)=""    # en export laisser une colonne vide

If [M:EXP2]NOMEXP <> ""
    Call MAJTRADX(LANG,TRT,ACT,[M:EXP2]NOMEXP) From MAJTRAD
    [M:EXP2]NOMEXP=""
Endif 
Return

$EXP_ZONE
If LANDEST <> ''
  [F:AST]LAN=LANDEST       #en export pour langue exotique mettre ds le fichier la lan destination
Endif
If [F:AST]LANNUM =0        # copier entête de chapitre dans la langue destination
   GIMP(1)=[F:AST]LANMES
Else                       # indiquer la traduction en langue destination si elle existe
   Read [F:AST2]CLE=[F:AST]LANCHP;[F:AST]LANNUM;LANDEST   # lecture en etranger
   If fstat = 0
      GIMP(1)=[F:AST2]LANMES               
   Endif
Endif

Return


$IMP_INICRE
[F:AST]LAN=[M:TRA2]ZLAN
[F:AST]LANCHP=[M:TRA2]LANCHP
[F:AST]LANNUM=[M:TRA2]LANNUM
If [M:TRA2]ZTEXTE<>""
   [F:AST]LANMES=[M:TRA2]ZTEXTE
Else
   [F:AST]LANMES=""
Endif
[F:AST]CREDAT  = date$  
[F:AST]UPDDAT  = date$ 
[F:AST]CRETIM  = time
[F:AST]UPDTIM  = time
[F:AST]CREUSR  = GUSER 
[F:AST]UPDUSR  = GUSER
Return

$IMP_INIMOD
[F:AST]LAN=[M:TRA2]ZLAN

If [M:TRA2]ZTEXTE<>""
   [F:AST]LANMES=[M:TRA2]ZTEXTE
Else
   [F:AST]LANMES=""
Endif

If [F:AST]LAN <>"FRA"
  [F:AST]UPDDAT = date$ 
  [F:AST]UPDTIM = time
  [F:AST]UPDUSR = GUSER
Endif
Return


# Mise à jour suivi des traductions
# TRT=0 traitement de ATEXTE
# TRT=1 traitement de APLSTD
# ACT=0 import
# ACT=1 export
$FERME
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="0"
Local Char LANG : LANG=LAN
Call MAJTRADX(LANG,TRT,ACT,[M:IMP2]NOMIMP) From MAJTRAD
Return

$IMP_ZONE
Case IMPZON
When "ZLAN"
     [M:TRA2]ZLAN=[F:AST]LAN
     IMPMOD=1
     OK=0
When "ZTEXTE"
 # en import récupérer la traduction de la variable *1
     [M:TRA2]ZTEXTE=GIMP(1)
     IMPMOD=1
     OK=0
When "LANNUM"
     [M:TRA2]LANNUM=[F:AST]LANNUM
     IMPMOD=1
     OK=0
Endcase
Return

$IMP_VERIF_CREMOD
If len([M:TRA2]ZTEXTE)=0
   OK=0
   GMESSAGE=mess(572,196,1)
Endif
Return

