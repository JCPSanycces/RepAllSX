#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("RGA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "OUVRE"       : Gosub OUVRE
 When "DEFTRANS"    : Gosub DEFTRANS From SUBCAC
 When "TITRE"       : Gosub TIT    From SUBCAC
 When "AVANT_CHOI"  : Gosub AVANT_CHOI
 When "AFFMASK"     : Gosub AFFMASK
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "APRES_MOD"   : Gosub APRES_MOD
 When "MODIF"       : Gosub MODIF
 When "FIN"         : Gosub FIN
 When 'EXEBOUT'     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
Endcase
Return

$OUVRE_BOITE
BROWRG0 = find("RG0",OBJLIS(1..dim(OBJLIS)-1))
BOXMRG0  = "GAU_CHE"+num$(BROWRG0)
Return

$OUVRE
If clalev([F:RGA])=0  : Local File RUBGAC      [RGA]  : Endif
If clalev([F:RGA2])=0 : Local File RUBGAC      [RGA2] : Endif
If clalev([F:RUB2])=0 : Local File RUBRIQUE    [RUB2] : Endif
If clalev([F:COA])=0  : Local File =GTABCPT+"GCOA"       [COA] : Endif

Local Char    INTCOL(15)
Local Integer I, NBACC, NCOA
Local Integer BROWRG0
Local Char    BOXRG0 (10)
Gosub SETFOR
Return

$FILTRE
FILTSUP = "[F:RUB]FLGCPT=2"
Return

$FILGAUCHE
FILGAUSUP = "[F:RUB]FLGCPT=2"
Case currbox
 When BOXMRG0 : FILGAUSUP += "& [F:RUB]NBRACC<=0"
Endcase
If FILTRE<>""
 Call ADDCRIT(FILGAUSUP,IFILGAUSUP,"FILGAUSUP","("+FILTRE+")","&") From GOBJSUB
Endif
Return

$LIENS
Local Char RUBACC(GLONGAC)
Grizo [M:RGA2]
[M:RGA1]CODTRS = GXFLAG
Read [GCO]GCO0 = GXFLAG
If !fstat
 ##** 1 compte par ligne only
 NOL=0
 [M:RGA1]NBRCOA = [F:GCO]NBRCOA

 For NCOA=0 To [F:GCO]NBRCOA-1
  [M:RGA1]COA(NCOA) = [F:GCO]COA(NCOA)
  ##** Regroupement de comptes par ligne si même type de montant, même sens, même détail/salarié et même condition
  #NOL=0

  For [F:RGA]RGA0 Where COD=[F:RUB]COD & COA=[M:RGA1]COA(NCOA)
   If NCOA>0 Then
    FOUND=0
    For I=0 To [M:RGA1]NBLIG-1
      If evalue("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(I)+")")=""
&      & [M:RGA1]TYPAMT(I)=[F:RGA]TYPAMT & [M:RGA1]SNS(I)=[F:RGA]SNS & [M:RGA1]DETEMP(I)=[F:RGA]DETEMP & [M:RGA1]CNDRGA(I)=[F:RGA]CNDRGA Then
        NOL=I : FOUND=1
        Break
      Endif
    Next
    If !FOUND Then NOL=[M:RGA1]NBLIG : Endif
   Endif
#   Assign("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")") With [F:RGA]ACC
   RUBACC=[F:RGA]ACC
   Call LEC_GAC([F:RGA]ACC,[F:RGA]COA) From CPTLEC
   If [F:GAC]SAC=2 Then RUBACC+="*" : Endif
   Assign("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")") With RUBACC
   [M:RGA1]TYPAMT(NOL)    = [F:RGA]TYPAMT
   [M:RGA1]SNS(NOL)       = [F:RGA]SNS
   [M:RGA1]DETEMP(NOL)    = [F:RGA]DETEMP
   [M:RGA1]CNDRGA(NOL)    = [F:RGA]CNDRGA
   NOL+=1
   [M:RGA1]NBLIG = max(NOL,[M:RGA1]NBLIG)
  Next
 Next
Endif
Return

$VERIF_CRE
$VERIF_MOD
Local Integer NOL, NCOA, OK
If [M:RGA1]NBRCOA=0 Then
  Read [GCO]GCO0 = GXFLAG
  If !fstat
   [M:RGA1]NBRCOA = [F:GCO]NBRCOA
  Endif
Endif
For NOL=0 To [M]NBLIG-1
  OK=0
  If [M]TYPAMT(NOL)>0
   For NCOA=0 To [M:RGA1]NBRCOA-1
    If evalue ("[M]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")<>"" : OK=1 : Break : Endif
   Next
   If !OK
    GMESSAGE="Ligne"-num$(NOL+1)-":"-mess(37,102,1) #: Compte obligatoire
    [L]OK=0 : Break
   Endif
  Endif
Next
Return

$APRES_MOD
Readlock [F:RUB2]RUB0=[F:RUB]COD
If !fstat
 Filter [F:RGA2] Where COD=[F:RUB2]COD
 If [F:RUB2]NBRACC<>rowcount([F:RGA2])
  Call DEBTRANS From GLOCK
  Trbegin [RUB2]
  [F:RUB2]NBRACC=rowcount([F:RGA2])        :# peut être différent en fonction des transactions !
  Rewrite [F:RUB2]
  If fstat
   GOK=0 : Call FSTA("RUB2") From GLOCK
  Endif
  If GOK<0   : Goto ROLL_APRES
  Elsif !GOK : Goto AB_APRES
  Endif
  Commit
 Endif
 Filter [F:RGA2]
Endif
Return

$ROLL_APRES
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto APRES_MOD : Endif

$AB_APRES
Rollback
Return

$MODIF
For NCOA=0 To [M:RGA1]NBRCOA-1
 Delete [F:RGA] Where COD=[F:RUB]COD & COA=[M:RGA1]COA(NCOA)
 If fstat=1
  GOK = -1 : GLOCK = "$RUBGAC"-[F:RUB]COD : Break
 Endif
Next
If GOK<1 : Return : Endif
Gosub SAVE_RGA
Return

$SAVE_RGA
Local Char    RUBACC(GLONGAC)
Local Integer I
For NCOA=0 To [M:RGA1]NBRCOA-1
 For NOL=0 To [M:RGA1]NBLIG-1
  If evalue("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")<>""
   [F:RGA]COD =  [M:RGA0]COD
   [F:RGA]COA =  [M:RGA1]COA(NCOA)
   [F:RGA]LIG =  NOL+1
   [F:RGA]TYPAMT =  [M:RGA1]TYPAMT(NOL)
   [F:RGA]SNS    =  [M:RGA1]SNS(NOL)
   [F:RGA]DETEMP =  [M:RGA1]DETEMP(NOL)
   [F:RGA]CNDRGA =  [M:RGA1]CNDRGA(NOL)
#   [F:RGA]ACC    =  evalue("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")
   RUBACC=evalue("[M:RGA1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")
   I=instr(1,RUBACC,"*")
   If I>0 Then
     RUBACC=left$(RUBACC,I-1)
   Endif
   [F:RGA]ACC    =  RUBACC
   Write [F:RGA]
   If fstat
    GOK = 0 : Call FSTA("RGA") From GLOCK : Break 2
   Endif
  Endif
 Next
Next
If GOK<1 : Return : Endif
Return

#********************************To manage Transaction*****************************************#
$EXEBOUT
Case REP
 When "B" : GOK = 2 : REPONSE = GSTAEND
Endcase
Return

$AVANT_CHOI
Gosub AFFMASK
Return

$AFFMASK
[M:RGA1]CODTRS = GXFLAG
Read [GCO]GCO0 = GXFLAG
If !fstat
# Gosub CACHCOL
 [M:RGA1]NBRCOA = [F:GCO]NBRCOA
 For NCOA=0 To [F:GCO]NBRCOA-1
  Read [COA]COA0 = [F:GCO]COA(NCOA)
  [M:RGA1]COA(NCOA) = [F:GCO]COA(NCOA)
  If !fstat
   Gosub AFFCOL
#   Gosub SHOWCOL
  Endif
 Next
 Gosub EFFCOL
Endif
Return

$EFFCOL
Local Integer NACC
For NACC=NCOA To 8
 Case NACC
   When 0
    Chgfmt [M]ACC1    With "-K:15X"
   When 1
    Chgfmt [M]ACC2    With "-K:15X"
   When 2
    Chgfmt [M]ACC3    With "-K:15X"
   When 3
    Chgfmt [M]ACC4    With "-K:15X"
   When 4
    Chgfmt [M]ACC5    With "-K:15X"
   When 5
    Chgfmt [M]ACC6    With "-K:15X"
   When 6
    Chgfmt [M]ACC7    With "-K:15X"
   When 7
    Chgfmt [M]ACC8    With "-K:15X"
   When 8
    Chgfmt [M]ACC9    With "-K:15X"
 Endcase
Next
Return

$CACHCOL
If [M:RGA1]NBLIG : Return : Endif
Chgfmt [M:RGA1]ACC1 With "-K:15X"
Chgfmt [M:RGA1]ACC2 With "-K:15X"
Chgfmt [M:RGA1]ACC3 With "-K:15X"
Chgfmt [M:RGA1]ACC4 With "-K:15X"
Chgfmt [M:RGA1]ACC5 With "-K:15X"
Chgfmt [M:RGA1]ACC6 With "-K:15X"
Chgfmt [M:RGA1]ACC7 With "-K:15X"
Chgfmt [M:RGA1]ACC8 With "-K:15X"
Chgfmt [M:RGA1]ACC9 With "-K:15X"
Return

$SHOWCOL
If [M:RGA1]NBLIG : Return : Endif
Case NCOA
 When 0  : Chgfmt [M:RGA1]ACC1 With "K:15X"
 When 1  : Chgfmt [M:RGA1]ACC2 With "K:15X"
 When 2  : Chgfmt [M:RGA1]ACC3 With "K:15X"
 When 3  : Chgfmt [M:RGA1]ACC4 With "K:15X"
 When 4  : Chgfmt [M:RGA1]ACC5 With "K:15X"
 When 5  : Chgfmt [M:RGA1]ACC6 With "K:15X"
 When 6  : Chgfmt [M:RGA1]ACC7 With "K:15X"
 When 7  : Chgfmt [M:RGA1]ACC8 With "K:15X"
 When 8  : Chgfmt [M:RGA1]ACC9 With "K:15X"
Endcase
Return

$AFFCOL
Local Char NOMCOL(10)
NOMCOL = evalue("ACC"+num$(NCOA+1))
Call LECTEXTRA(INTCOL,"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
Case NCOA
 When 0
  Titcol [M:RGA1]NBLIG INTCOL For ACC1
 When 1
  Titcol [M:RGA1]NBLIG INTCOL For ACC2
 When 2
  Titcol [M:RGA1]NBLIG INTCOL For ACC3
 When 3
  Titcol [M:RGA1]NBLIG INTCOL For ACC4
 When 4
  Titcol [M:RGA1]NBLIG INTCOL For ACC5
 When 5
  Titcol [M:RGA1]NBLIG INTCOL For ACC6
 When 6
  Titcol [M:RGA1]NBLIG INTCOL For ACC7
 When 7
  Titcol [M:RGA1]NBLIG INTCOL For ACC8
 When 8
  Titcol [M:RGA1]NBLIG INTCOL For ACC9
Endcase
Return

$FIN
If GOK=2 : # Bouton Transaction
 GFLAG="\"
Else
 Raz GFLAG
Endif
Return

