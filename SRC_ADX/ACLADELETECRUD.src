#<AdxTL>@(#)1.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#-------------------------------------------------------#
$ADDCLB
Onerrgo CCL
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Onerrgo
Return

#-------------------------------------------------------#
$CCL
Resume

#-------------------------------------------------------#
# Programme Delete
#-------------------------------------------------------#
$TRT_DELETE
If ACLA.TEST : Call ECR_TRACE("- Delete PRG :ADELETE",0) From GESECRAN  : Endif
Gosub _TRTDELETE
Gosub  TRTDELETE
Return

#-------------------------------------------------------#
# Programme _Delete
#-------------------------------------------------------#
$_TRTDELETE
DIF = 0
NIVEAU = 1
NBFOR = 0
PROGRAM = "_"+[V]CST_APRGADELETE : # Delete
NIVPARCOURS = 0
Gosub ENTETE_SUBPROG From ACLASUBCRUD
Gosub AJOUT_ACCES_SITE From ACLASUBCRUD

PROGRAM = [V]CST_APRGADELETE : # Delete

LIGNE = "Local Instance ALNKDELTAB Using C_ALNKDELTAB" : Gosub ADDCLB
#LIGNE = "If adxlog"   : Gosub ADDCLB
#DIF +=1
LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM  : Gosub ADDCLB
#DIF-= 1
#LIGNE = "Endif"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Programme Delete
#-------------------------------------------------------#
$TRTDELETE
DIF = 0
NIVEAU = 1
NBFOR = 0
ISFOR = 0
PROGRAM = [V]CST_APRGADELETE : # Delete
NIVPARCOURS = 0

Gosub ENTETE_SUBPROG From ACLASUBCRUD
Gosub AJOUT_ACCES_SITE From ACLASUBCRUD

## A_Control
LIGNE ="Gosub "+PROGRAM+"_CONTROL"  : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO From ACLASUBCRUD
LIGNE = ""   : Gosub ADDCLB
LIGNE = "If !adxlog"   : Gosub ADDCLB
DIF +=1 : LIGNE = "Gosub "+PROGRAM+"_TR_"+[L]ROOTNAM : Gosub ADDCLB : DIF -= 1
LIGNE = "Else"   : Gosub ADDCLB
DIF +=1 : LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM   : Gosub ADDCLB : DIF-= 1
LIGNE = "Endif"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB

Gosub A_CONTROL From ACLASUBMAJCRUD

Gosub TR_BEGIN From ACLASUBMAJCRUD

## Transaction
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
NIVEAU = 1
LIGNE = "$"+PROGRAM+"_"+[L]ROOTNAM : Gosub ADDCLB
Call DECLARE_ACTION([L]ROOTCLA,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

#-------------------------------------------------------#
## Boucle de lecture recursive
#-------------------------------------------------------#

Raz TABPARCOURS
For I=2 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
  ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
  ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
  NIVPARCOURS = 2
  Call PRG_ADELETE(ATBORI,ATBDES,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR ,CLOB,DIF)
 Endif
Next I
LIGNE = ""  : Gosub ADDCLB
If ACLA.TYPCLA=2
 LIGNE = "[L]ASTATUS = func ASYRSUB.DELETE_LINKS("+[L]ROOTCLA+",ALNKDELTAB)" : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 LIGNE = ""  : Gosub ADDCLB
Endif
If ACLA.ACLAK(NIVEAU).FLGD= 2
 Gosub MAJSQL_RICHMEDIA From ACLASUBMAJCRUD
 LIGNE ="[L]ASTATUS = max([L]ASTATUS,func "+ACLA.ACLAV.TRTCRUD+"._MAJSQL_"+ACLA.ACLAK(NIVEAU).TABLNK+"("+[L]ROOTCLA+"))" :  Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Else
 Call DECLARE_ACTION([L]ROOTCLA,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif
LIGNE = ""  : Gosub ADDCLB
Call DECLARE_ACTION([L]ROOTCLA,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
NIVEAU = 1
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
Gosub ABORT From ACLASUBCRUD
NIVEAU = 1
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Gosub TRT_AFTERREWRITE_OK From ACLAREWRITECRUD
Return

#-------------------------------------------------------#
# Sous-programme recusive lecture
#-------------------------------------------------------#
Subprog PRG_ADELETE(ATBORI,ATBDES,ACLA,PROGRAM,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS
Variable Integer  NBFOR
Variable Clbfile  CLOB
Variable Integer DIF

Gosub PRG_DEB From ACLAVALCRUD
Local Integer OKPROG

Case PROGRAM
 When "AINSERT" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGC=2)
 When "AUPDATE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGU=2)
 When "ADELETE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGD=2)
Endcase

If ACLA.ACLAK(NIVEAU).CLALNK<>""
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For 1-> N
  ISFOR = 1 : NBFOR +=1
  LIGNE = "For A_N"+num$(NIVPARCOURS)+"=1 To"-ACLA.ACLAK(NIVEAU).STRMAXFOR : Gosub ADDCLB
  DIF += 1
 Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read 1 -> 1
  ISFOR = 0
  LIGNE = "A_N"+num$(NIVPARCOURS)+"="
  If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
   LIGNE += "0"
  Else
   LIGNE += "1"
  Endif
  Gosub ADDCLB
 Endif
Else
 If OKPROG>0
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
Endif
LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR-"<> null" : Gosub ADDCLB
DIF += 1

If OKPROG>0
  If ACLA.ACLAK(NIVEAU).CLALNK<>"" and ACLA.ACLAK(NIVEAU).FLGA<>2
   Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD : # _BEFORE_LINE
   Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
  Endif
Endif

### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_ADELETE(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If OKPROG>0
  Gosub PRG_DEL

  If ACLA.ACLAK(NIVEAU).CLALNK<>"" and ACLA.ACLAK(NIVEAU).FLGA<>2
   Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD : # _LINE
   ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4))
   Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
  Endif
Endif

DIF -= 1
LIGNE = "Endif" : Gosub ADDCLB
If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)>0 :
 DIF -= 1  : LIGNE ="Next A_N"+num$(NIVPARCOURS) : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4))
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 NBFOR -= 1
Endif


If DIF=0
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif

End

#########################################################################
$PRG_DEL
If ACLA.ACLAK(NIVEAU).FLGD <> 2
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Elsif  ACLA.ACLAK(NIVEAU).FLGA<>2
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ADEL"  :  Gosub ADDCLB
  LIGNE ="[L]ASTATUS = func "+ACLA.ACLAV.TRTCRUD+"._MAJSQL_"+ACLA.ACLAK(NIVEAU).TABLNK+"("+ACLA.ACLAK(NIVEAU).STRCUR+")" :  Gosub ADDCLB
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Elsif ACLA.ACLAK(NIVEAU).FLGA=2
  LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+"._"+PROGRAM+")" : Gosub ADDCLB
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
 Return

