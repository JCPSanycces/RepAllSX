######################################################################################################
# Module        : Finance
# Description   : - Payment balance declaration configuration (Representation PBDCONFIG)
######################################################################################################
 # Updates :
 # Date       |Author |Version| Description
 # 2015-04-30 |Bader  |       | CTRL_CROOTACC: set BPGROUP inactive only for Portugal, not for Germany / Austria
 # 2015-12-21 |ANGRE  |U10    | SAM # 111399  Moved content from $METHODS to $EVENTS
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When "PBDCNF"
      Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER_HEADER   # The header has been read
      Endcase
   When "PBDCNF.LINESINCL" :    # manage the handling of the "data to include" collection: set BPGROUP inactive if necessary
      Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
      Endcase
   When "PBDCNF.LINESEXCL" :    # manage the handling of the "data to exclude" collection: set BPGROUP inactive if necessary
      Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
      Endcase
Endcase
Return


# SAM # 111399  Moved content from $METHODS to $EVENTS
$METHODS
#Case [L]CURPTH
#   When "PBDCNF"
#      Case [L]ACTION
#         When "AREAD_AFTER" : Gosub AREAD_AFTER_HEADER   # The header has been read
#      Endcase
#   When "PBDCNF.LINESINCL" :    # manage the handling of the "data to include" collection: set BPGROUP inactive if necessary
#      Case [L]ACTION
#         When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
#      Endcase
#   When "PBDCNF.LINESEXCL" :    # manage the handling of the "data to exclude" collection: set BPGROUP inactive if necessary
#      Case [L]ACTION
#         When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
#      Endcase
#Endcase
Return

# SAM # 111399 changed ACTION to ARULE
$PROPERTIES
Case [L]CURPRO
  When "PBDCNF.LEG"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROP_LEG
      Endcase
  When "PBDCNF.LINESINCL.CROOTACC"
      Case [L]ARULE
        When "CONTROL" : Gosub CTRL_CROOTACC
      Endcase
  When "PBDCNF.LINESEXCL.CROOTACC"
      Case [L]ARULE
        When "CONTROL" : Gosub CTRL_CROOTACC
      Endcase
  When "PBDCNF.LINESINCL.LEG"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROP_LINESINCL_LEG
      Endcase
Endcase
Return


############################################################################################
# Implementation of the PROPERTIES
############################################################################################

$PROP_LEG
  If this.LEG = "GER" or this.LEG = "AUT"
    ASTATUS = fmet this.ASETATTRIBUTE ("PROCESSTYPE","$isHidden","true") # for Germany and Austria process type may not be changed
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("PROCESSTYPE","$isHidden","false") # for all other legislations visible and changeable
  Endif
  If this.LEG = "POR"    # For POR use always "Include tax"..
      this.AMTTYPE = 2
      ASTATUS = fmet this.ASETATTRIBUTE ("AMTTYPE","$isDisabled","true")
  Else
      ASTATUS = fmet this.ASETATTRIBUTE ("AMTTYPE","$isDisabled","false")
  Endif
Return


$AREAD_AFTER_HEADER
  Gosub PROP_LEG
Return

$AREAD_AFTER_LINES
  Gosub CTRL_CROOTACC
  Gosub PROP_LINESINCL_LEG
Return

$CTRL_CROOTACC
If this.LEG = "POR" and this.CROOTACC <> ""
   Local Char TMP (20)
   Local File GACCOUNT [GAC] # accounts

   TMP = right$(this.CROOTACC,len(this.CROOTACC))   # get last character of account to check for "*"
   If TMP <> "*"                                    # only check single accounts (without wildcard *)
     Read [F:GAC]GAC0 = this.COA;this.CROOTACC      # try to find account
     If !fstat                                      # found
       If [F:GAC]MTC <> 2
          ASTATUS = fmet this.ASETATTRIBUTE ("BPGROUP","$isDisabled","true")  # for non collective accounts BPGROUP may not be changed
       Else
          ASTATUS = fmet this.ASETATTRIBUTE ("BPGROUP","$isDisabled","false") # for collective accounts BPGROUP may be changed
       Endif
     Endif
   Endif
   LogicClose File [GAC]
Endif
Return

$PROP_LINESINCL_LEG
  If this.LEG = "POR"    # For POR use only "Balanced".
      this.BALAMT = 2
      ASTATUS = fmet this.ASETATTRIBUTE ("BALAMT","$isDisabled","true")
  Else
      ASTATUS = fmet this.ASETATTRIBUTE ("BALAMT","$isDisabled","false")
  Endif
Return

