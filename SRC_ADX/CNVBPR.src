#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CNVBPR","DCNVBPR",3,"") From GTRAITE
End


#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
Endcase
Return

#######################################################
# Moulinette Passage Euro                             #
#######################################################
$INIT
Local Integer OK, I, ERR
Raz ERR
Onerrgo ERR
Gosub OUVRE
If ERR : FIN=1 : Return : Endif
Local Mask CNVBPR [CNV] : Raz [M]
Return

$CONTROLE
If !GSERVEUR & [M:CNV]TRACE=2
 # Conversion Tiers
 Call OUVRE_TRACE(mess(78,115,1)) From LECFIC
 TRA =1 
Endif
TMP=1
Return

$EXEC
Read [TCY]TCY0 = GPAYS
If fstat
 Read [TCY]TCY0 = ""
Endif
If fstat=0
 GLOCALDEV = [F:TCY]CUR
Else
 GLOCALDEV = "FRF"
Endif

If [M]TOUBPR=2
 For [BPR2] Where CUR=[M]DEVCUR
  Call CNVBPR2([F:BPR2]BPRNUM,[M]DEVCUR,[M]DEVDES,DATPAS)
  If GOK<1 : Break : Endif
 Next
Else
 For I=0 To [M]NBLIG-1
  If [M]CNV(I)=2
   Call CNVBPR2([M]BPR(I),[M]DEVCUR,[M]DEVDES,DATPAS)
   If GOK<1 : Break : Endif
  Endif
 Next I
Endif
Return

$OUVRE
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif
Gosub OPEN_SFI From TRTX3CPY # If clalev([F:SFI])=0  : Local File SFOOTINV   [SFI]  : Endif
If clalev([F:BPR2])=0 : Local File BPARTNER   [BPR2] : Endif
Return

$ERR
ERR = errn
Resume

###########################################################################
Subprog CNVBPR2(CODE,DEVCUR,DEVDES,DATPAS)
Value Char    CODE
Value Char    DEVCUR
Value Char    DEVDES
Value Date    DATPAS

Local Integer I, SPSTAT, TYPCUR
Local Char    VALPAR(20), SYMBOLE(80)
Local Decimal WMONT

Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCUR = val(VALPAR)
If TYPCUR=0 : TYPCUR = 1 : Endif

Read [BPR2]BPR0 = CODE
If [F:BPR2]CUR<>DEVCUR : End : Endif

Gosub OUVRE

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : End : Endif

If GTRACE<>""
 Call ECR_TRACE(CODE-[L]DEVCUR-"->"-[L]DEVDES,0) From GESECRAN
Endif

End

$TR1
GOK = 1
Trbegin [BPR], [BPC], [BPS]

 SYMBOLE = format$("K:3X","BPR")+CODE
 Lock =SYMBOLE With lockwait=0
 If fstat
  Call ECR_TRACE(mess(31,105,1)-CODE-mess(39,107,1),1) From GESECRAN : # Tiers x en cours de modification
  GOK=0 : Goto AB_TR1
 Endif
 Readlock [BPR]BPR0 = CODE
 If fstat=1
  GOK=-1 : GLOCK="$BPARTNER"-[F:BPR]BPRNUM : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("BPR",[F:BPR]BPRNUM) From GLOCK : Goto AB_TR1
 Endif
 [F:BPR]CUR = DEVDES
 Rewrite [BPR]
 If fstat
  GOK=0 : Call FSTA("BPR") From GLOCK : Goto AB_TR1
 Endif

 SYMBOLE = format$("K:3X","BPC")+CODE
 Lock =SYMBOLE With lockwait=0
 If fstat
  Call ECR_TRACE(mess(1,277,1)-CODE-mess(39,107,1),1) From GESECRAN : # Client x en cours de modification
  GOK=0 : Goto AB_TR1
 Endif
 Readlock [BPC]BPC0 = CODE
 If fstat=1
  GOK=-1 : GLOCK="$BPCUSTOMER"-[F:BPC]BPCNUM : Goto ROLL_TR1
 Elsif fstat=0
  For [SFI]
   If [F:SFI]DACBPC<>0 & [F:SFI]AMTCOD=2
    WMONT = [F:BPC]INVDTAAMT([F:SFI]DACBPC-1)
    Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,WMONT,WMONT,SPSTAT) From TRTDEV
    [F:BPC]INVDTAAMT([F:SFI]DACBPC-1) = WMONT
   Endif
  Next
  Rewrite [BPC]
  If fstat
   GOK=0 : Call FSTA("BPC") From GLOCK : Goto AB_TR1
  Endif
 Endif

 SYMBOLE = format$("K:3X","BPS")+CODE
 Lock =SYMBOLE With lockwait=0
 If fstat
  Call ECR_TRACE(mess(2,277,1)-CODE-mess(39,107,1),1) From GESECRAN : # Fournisseur x en cours de modification
  GOK=0 : Goto AB_TR1
 Endif
 Readlock [BPS]BPS0 = CODE
 If fstat=1
  GOK=-1 : GLOCK="$BPSUPPLIER"-[F:BPS]BPSNUM : Goto ROLL_TR1
 Elsif fstat=0
  For I=0 To dim([F:BPS]INVDTAAMT)-1
   If [F:BPS]AMTCOD(I)=2 
    WMONT = [F:BPS]INVDTAAMT(I)
    Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCUR,DATPAS,WMONT,WMONT,SPSTAT) From TRTDEV
    [F:BPS]INVDTAAMT(I) = WMONT
   Endif
  Next I
  Rewrite [BPS]
  If fstat
   GOK=0 : Call FSTA("BPS") From GLOCK : Goto AB_TR1
  Endif
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################
Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEVCUR
 mkstat = 2 : End
Endif
End

$CHARGE
Effzo 10
If [M]TOUBPR=2 : mkstat = 1 : End : Endif
Raz I
For [BPR] Where CUR=[M]DEVCUR
 [M]BPR(I) = [F:BPR]BPRNUM
 [M]DES(I) = [F:BPR]BPRNAM
 If I>=dim([M]BPR)-1
  Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 I +=1
Next
[M]NBLIG = I
Affzo 10
Return

Subprog AS_NBLIG
GBOUT1 = mess(2,1,1)
GBOUT2 = mess(1,1,1)
Local Integer I
If adxgtb : Gosub CHARGE : Endif
End

Subprog B1_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 2 : # Oui
Next I
Affzo
End

Subprog B2_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 1 : # Non
Next I
Affzo
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("BPR","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
[M]DES(nolign-1) = [F:BPR]BPRNAM
End



