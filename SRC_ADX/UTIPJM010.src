#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM010
# Issue X3-17075/120484 - 2016-12-19 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM010(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM010(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Integer IFOUND

  IERR = 0
  Call ECR_TRACE("UTIPJM010: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMPH
  #
  If filinfo(filpath("FIL", "PJMTSKOPE", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSKOPE" [PTKO]
  Local File =SZAPPLI + ".PJMOPEAFF" [PJOA]
  # -------------------------
  Trbegin [PTKO]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM010: Updating PJMTSKOPE/PJMOPEAFF", 0) From GESECRAN
  Filter [PTKO] Where [F:PTKO]OPESTA = 5
  For [PTKO]PTKO0
    # -----------------------------
    If [F:PTKO]RMNQTY <> 0 Then
      [F:PTKO]RMNQTY = 0
      # -----------------------------
      NCOUNT += 1
      Rewrite [PTKO]
      If fstat Then
        Call ECR_TRACE("File PJMTSKOPE" - [F:PTKO]OPPNUM - [F:PTKO]TASCOD - num$([F:PTKO]OPENUM) - num$([F:PTKO]OPESPLNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------------------------
    Endif
    # -----------------------------
    Filter [PJOA] Where [F:PJOA]OPPNUM = [F:PTKO]OPPNUM and [F:PJOA]TASCOD = [F:PTKO]TASCOD and [F:PJOA]OPENUM = [F:PTKO]OPENUM and [F:PJOA]OPESPLNUM = [F:PTKO]OPESPLNUM and [F:PJOA]POARMNQTY <> 0
    For [PJOA]PJOA0
      [F:PJOA]POARMNQTY = 0
      # -----------------------------
      NCOUNT += 1
      Rewrite [PJOA]
      If fstat Then
        Call ECR_TRACE("File PJMOPEAFF" - [F:PJOA]OPPNUM - [F:PJOA]TASCOD - num$([F:PJOA]OPENUM) - num$([F:PJOA]OPESPLNUM) - num$([F:PJOA]POANUM) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------------------------
    Next
    Filter [PJOA]
    # -----------------------------
  Next
  Filter [PTKO]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM010: PJMTSKOPE/PJMOPEAFF" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM010: PJMTSKOPE/PJMOPEAFF" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM010 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM010 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKOPE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKOPE") : End : Endif
  If filinfo(filpath("FIL","PJMOPEAFF","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMOPEAFF") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM010(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKOPE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKOPE") : End : Endif
  If filinfo(filpath("FIL","PJMOPEAFF","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMOPEAFF") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM010(APPLI)
End

