#<AdxTL>@(#)0.0.0.0 $Revision$Class Alias
# Supervisor
## ATY-ATYPE ## EVB
# 2018-11-09 07:14:16 888

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CODREP,ALIAS,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CODREP
Value Char ALIAS
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File ASHWEXPPRO [ASWR]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".ASHWEXPPRO" [ASWR]
Endif

Default File [F:ASWR]
Read [F:ASWR]ASWR0 = [L]CODREP;[L]ALIAS
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODREP)+"~"+num$([L]ALIAS)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODREP)+"~"+num$([L]ALIAS)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


