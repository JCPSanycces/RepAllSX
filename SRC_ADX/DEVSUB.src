#<AdxTL>@(#)6.0.0.0 $Revision$
# GNBSOC    = Nb de sociétés
# GSOC      = Table des sociétés
# GDEVSOC   = Table des devises/sociétés
# GISOC     = Indice société
# GNBSITE   = Nb de sites
# GSITE     = Table des sites
# GSOCSITE  = Tables des sociétés/site
# GFINSITE  = Table des responsabilités financières/site
# GSOCIETE  = Société courante
# GLOCALDEV = Devise courante
# GFINRSP   = Responsablilité financière courante

Subprog GETSOC(SITE)
Value Char SITE
Local Integer ISITE , JSITE
ISITE = find(SITE,GSITE(1..GNBSITE))
If ISITE
 GSOCIETE = GSOCSITE(ISITE)
 GFINRSP  = GFINSITE(ISITE)
Else
 GSOCIETE = GDEFSOC
 GFINRSP  = GDEFFIN
Endif
GCURLEG = ""
JSITE = find(GSOCIETE,GSOC(1..GNBSOC))
If JSITE
 GCURLEG = GLEGSOC(JSITE)
Endif
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
GCURFCY = SITE
End

Subprog GETDEV(SITE)
Value Char SITE
Call GETSOC(SITE)
GISOC = find(GSOCIETE,GSOC(1..GNBSOC))
If GISOC
 GLOCALDEV = GDEVSOC(GISOC)
Else
 GLOCALDEV = "EUR" : # Devise par défaut en cas de pb
Endif
If clalev([F:TCU])>0
 Call LECTURE("TCU",GLOCALDEV,"") From CONTOBJ
Endif
End

Subprog DEFDEV
GISOC = find(GDEFSOC,GSOC(1..GNBSOC))
If GISOC
 GLOCALDEV = GDEVSOC(GISOC)
Else
 GLOCALDEV = "EUR" : # Devise par défaut en cas de pb
Endif
If clalev([F:TCU])>0
 Call LECTURE("TCU",DEV,"") From CONTOBJ
Endif
End

Subprog GETFIN(SITE,FINSITE)
Value    Char    SITE
Variable Char    FINSITE
Local    Integer ISITE
ISITE = find(SITE,GSITE(1..GNBSITE))
If ISITE
 FINSITE = GFINSITE(ISITE)
Else
 FINSITE = GDEFFIN
Endif
End
#------------------------------------------------------------------------------------------#
#--sous-pro qui renvoie la législation de la sté passé en paramètre
#--ORILEG=G : on va chercher dans les variables globales qui doivent être renseignées
#--ORILEG=T : on va chercher dans la table COMPANY
#------------------------------------------------------------------------------------------#

Subprog GETLEG(SOC,ORILEG,LEG)
Value    Char    SOC
Value    Char    ORILEG
Variable Char    LEG
Local    Integer ISOC

Raz LEG
If ORILEG = "G"
  ISOC = find(SOC,GSOC(1..GNBSOC))
  If ISOC
    LEG = GLEGSOC(ISOC)
  Endif
Else
 If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
 Read [CPY]CPY0=SOC
  If fstat End : Endif
  LEG = [F:CPY]LEG
Endif
End
