#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH9 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG9
mkstat = 0
zoncou = "NBLIG9"
indice = 0
status = 1
zoncou = "NBLIG9"
If varmode([M]NBLIG9,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG9" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG9
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG9 = nolign
   status = 75
   Call SAI_NBLIG9(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG9(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG9
mkstat = 0
zoncou = "NBLIG9"

## Zone SELLIN
mkstat = 0
zoncou = "SELLIN"
IMPENT = [M]SELLIN(indice)
WNUM = IMPENT
If varinit([M]SELLIN,indice)=0
 IMPENT = 1
Endif
If varmode([M]SELLIN,indice)=0
 [M]SELLIN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SELLIN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SELLIN(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_SELLIN(IMPENT) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SELLIN" : GZNUM = 8255 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SELLIN(indice) = IMPENT

## Zone NCSQTY
mkstat = 0
zoncou = "NCSQTY"
WNUM = [M]NCSQTY(indice)
If varmode([M]NCSQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSQTY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NCSQTY(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NCSQTY" : GZNUM = 1004207 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NCSQTY([M]NCSQTY(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NCSQTY" : GZNUM = 1004207 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]NCSQTY(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_NCSQTY([M]NCSQTY(indice)) From SUBNCSH
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NCSQTY" : GZNUM = 1004207 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBLIG9
mkstat = 0
zoncou = "NBLIG9"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSH9"
Return

