# Superviseur
# Gestion du masque PJMTAS1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBART
mkstat = 0
zoncou = "NBART"
indice = 0
status = 1
zoncou = "NBART"
If varmode([M]NBART,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBART" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBART
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBART = nolign
   status = 75
   Call SAI_NBART(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBART From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBART" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBART(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBART
mkstat = 0
zoncou = "NBART"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBART From SUBPJTA
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBART" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BTITT
mkstat = 0
zoncou = "BTITT"
If varinit([M]BTITT,indice)=0
 [M]BTITT(indice) = "138"
Endif
If varmode([M]BTITT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BTITT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone STOFCY
mkstat = 0
zoncou = "STOFCY"
WCHAR = [M]STOFCY(indice)
If varmode([M]STOFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STOFCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]STOFCY(indice)) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!D",[M]STOFCY(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]STOFCY(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_STOFCY([M]STOFCY(indice)) From SUBPJTA
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ITMREF
mkstat = 0
zoncou = "ITMREF"
WCHAR = [M]ITMREF(indice)
If varmode([M]ITMREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMREF" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ITMREF(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "VXADCUPC"
  Call ADCCTRUPC([M]ITMREF(indice)) From VXADCUPC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ITM","",[M]ITMREF(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]ITMREF(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_ITMREF([M]ITMREF(indice)) From SUBPJTA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ITMDES1
mkstat = 0
zoncou = "ITMDES1"
WCHAR = [M]ITMDES1(indice)
If varinit([M]ITMDES1,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]ITMDES1(indice),"PJMTSKITM","ITMDES1",[M:PJTA0]OPPNUM + "~" + [M:PJTA0A]TASCOD + "~" + num$([M:PJTA1]ITTSEQ(nolign-1)),"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ITMDES1,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ITMDES1" : Gosub ACTION From =IMPTRT
  Endif
  If WCHAR<>[M]ITMDES1(indice) or IMPMOD
