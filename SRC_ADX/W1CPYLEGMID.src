$ON_PERNTT
Onevent CONTROL Call C_PERNTT(zc) From W1CPYLEGMID
Onevent BEFORE_INPUT Call AS_PERNTT(zc) From W1CPYLEGMID
Onevent AFTER_CHANGE Gosub AMM_PERNTT From W1CPYLEGMID
Onevent INIT_AREA Call D_PERNTT(zc) From W1CPYLEGMID
Return

Subprog D_PERNTT(VALEUR)
Variable Char    VALEUR()
If varinit([M]PERNTT,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_PERNTT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PERNTT(zc) From W1CPYLEGMID
Onkey 144 Titled GBOUTP Call P_PERNTT(zc) From W1CPYLEGMID
Onkey 146 Titled GBOUTA Call SA_PERNTT(zc) From W1CPYLEGMID
Gosub _AFF
End

Subprog C_PERNTT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PERNTT" : GZNUM = 44771 : Endif
Gosub _AFF
End

$AMM_PERNTT
Call AM_PERNTT(zc)
If !mkstat & GOBJET
 zoncou = "PERNTT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PERNTT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPERNTT)")>indice
 [M]PERNTT(indice) = VALEUR
 Affzo ZPERNTT(indice)
Endif
Gosub _AFF
End

Subprog S_PERNTT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PERNTT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PERNTT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPERNTT
Onevent BEFORE_AREA Gosub AV_ZPERNTT From W1CPYLEGMID
Return

$AV_ZPERNTT
Call LECTEXTRA(zc,"TABCOUNTRY","CRYDES",num$([M]PERNTT(indice)),"") From ATEXTRA
Gosub _AFF
Return

