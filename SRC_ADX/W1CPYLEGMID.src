#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGMID 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:31"
A_USER  = "DOC"
A_STAMP = "20181109230331"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "PMTLIGNUM"
  If [M]PMTLIGNUM=0
  Endif
 When "PERNUM"
  If [M]PERNUM=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGMID [CLMID]
Gosub HORODAT
Local Inpbox "CPYLEGMID" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLMID] As [SIM_]
Grizo [CLMID]5
Grizo [CLMID]10
Grizo [CLMID]15
Grizo [CLMID]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLMID]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=27 : X2(0)=86 : Y1(0)=8 : Y2(0)=15
X1(1)=27 : X2(1)=86 : Y1(1)=16 : Y2(1)=20
X1(2)=27 : X2(2)=86 : Y1(2)=21 : Y2(2)=20
X1(3)=27 : X2(3)=86 : Y1(3)=21 : Y2(3)=20
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1CPYLEGMID
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_BOXNUM
Onevent CONTROL Call C_BOXNUM(zc) From W1CPYLEGMID
Return

Subprog C_BOXNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "BOXNUM" : GZNUM = 55594 : Endif
If !mkstat
 ## Action STD
 Call C_BOXNUM(VALEUR) From TRTCPYLEGMID
 If mkstat : GERR = 1 : GZONE = "BOXNUM" : GZNUM = 55594 : Endif
Endif
Gosub _AFF
End

$ON_NUMPRMVIS
Onevent BEFORE_INPUT Call AS_NUMPRMVIS(zc) From W1CPYLEGMID
Return

Subprog AS_NUMPRMVIS(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NUMPRMVIS(VALEUR) From TRTCPYLEGMID
If mkstat=2
 [M]NUMPRMVIS(INDIC) = VALEUR
 Affzo NUMPRMVIS(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$ON_CPYRGTTYP
Onevent BEFORE_INPUT Call AS_CPYRGTTYP(zc) From W1CPYLEGMID
Onevent AFTER_CHANGE Gosub AMM_CPYRGTTYP From W1CPYLEGMID
Onevent INIT_AREA Call D_CPYRGTTYP(zc) From W1CPYLEGMID
Onevent CONTROL Call C_CPYRGTTYP(zc) From W1CPYLEGMID
Return

Subprog D_CPYRGTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CPYRGTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CPYRGTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11730) From COMBOS
## Action STD
Call AS_CPYRGTTYP(VALEUR) From TRTCPYLEGMID
If mkstat=2
 [M]CPYRGTTYP(INDIC) = VALEUR
 Affzo CPYRGTTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11730,1))))
Endif
If !mkstat
 Discombo 0 From CPYRGTTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From CPYRGTTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_CPYRGTTYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPYRGTTYP" : GZNUM = 55591 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_CPYRGTTYP
Call AM_CPYRGTTYP(zc)
If !mkstat & GOBJET
 zoncou = "CPYRGTTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPYRGTTYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CPYRGTTYP(VALEUR) From TRTCPYLEGMID
If mkstat : GERR = 1 : GZONE = "CPYRGTTYP" : GZNUM = 55591 : Endif
Gosub _AFF
End

