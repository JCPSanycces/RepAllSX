#<AdxTL>@(#)3.0.0.0 $Revision$
Call MAJSEC
End

##################################################
## Modification du menu local 693
##################################################
Subprog MAJSEC
Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call MAJCDE(DOSSIER)
Endif
End

Subprog MAJCDE(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".CACCEDEF" [CDE]
Call DEBTRANS From GLOCK
Trbegin [CDE]
 For [CDE]CDE0
  RW = 0
  If [F:CDE]CCE1=17 : [F:CDE]CCE1 = 19 : RW = 1 : Endif
  If [F:CDE]CCE2=17 : [F:CDE]CCE2 = 19 : RW = 1 : Endif
  If [F:CDE]CCE3=17 : [F:CDE]CCE3 = 19 : RW = 1 : Endif
  If [F:CDE]CCE4=17 : [F:CDE]CCE4 = 19 : RW = 1 : Endif
  If [F:CDE]CCE5=17 : [F:CDE]CCE5 = 19 : RW = 1 : Endif
  If [F:CDE]CCE6=17 : [F:CDE]CCE6 = 19 : RW = 1 : Endif
  If [F:CDE]CCE7=17 : [F:CDE]CCE7 = 19 : RW = 1 : Endif
  If [F:CDE]CCE8=17 : [F:CDE]CCE8 = 19 : RW = 1 : Endif
  If [F:CDE]CCE9=17 : [F:CDE]CCE9 = 19 : RW = 1 : Endif
  If RW
   Rewrite [CDE]
   If fstat
    Call ERREUR("CACCEDEF",2) From DOSDIC
   Endif
  Endif
 Next
Commit
Close Local File [CDE]

End
