#<AdxTL>@(#)0.0.0.0 $Revision$ Global variables
Subprog GLOBVAR(SITE)
Value Char SITE
Onerrgo ERREUR
Local File ADOPAR [ADP]
Local File ADOVAL [ADW]
Local Char    PARAM(250)
Global Libelle  GFIRDAY             : # First day of the week
Call PARAM(SITE,"FIRDAY",PARAM) From ADOVAL
GFIRDAY = val(PARAM)
Global Char     GPLANNING(30)       : # Default planning
Call PARAM(SITE,"PLANNING",PARAM) From ADOVAL
GPLANNING = PARAM
Global Char     GTPSDEF(30)         : # Default time code
Call PARAM(SITE,"TPSDEF",PARAM) From ADOVAL
GTPSDEF = PARAM
Global Char     GTPSW(30)           : # Time code for work
Call PARAM(SITE,"TRAVAIL",PARAM) From ADOVAL
GTPSW = PARAM
End

$ERREUR
Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)-errm) From GESECRAN
Resume

