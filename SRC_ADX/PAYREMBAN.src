If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End

Subprog C_ALLBAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
End

Subprog C_ALLFRMTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FRMTYP : Grizo FRMTYP
Else
 Actzo FRMTYP
Endif
End

Subprog C_PRO(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Effzo VALDAT,ACCDAT : Grizo VALDAT,ACCDAT
Else
 Actzo VALDAT,ACCDAT
Endif
End

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 If dim([M]LEG)>0 : Affzo LEG : Endif
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0
  If [M]LEG = ""
   Effzo LEG : Diszo LEG
  Else
   # When go back from Memo the value of LEG should be keep.
   Diszo LEG
  Endif
 Endif
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If [M]ALLBAN=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
If [M]PAY9<>2
 If [M]ALLLOT<>2
  [M]ALLLOT=2 : [M]LOT=""
  Affzo ALLLOT, LOT
 Endif
 Grizo ALLLOT, LOT
Else
 Actzo ALLLOT
 If [M]ALLLOT=2 : Effzo LOT : Grizo LOT : Else : Actzo LOT : Endif
Endif
If [M]PAY5<>2
 If [M]ALLFRMTYP<>2
  [M]ALLFRMTYP=2 : [M]FRMTYP=0
  Affzo ALLFRMTYP, FRMTYP
 Endif
 Grizo ALLFRMTYP, FRMTYP
Else
 Actzo ALLFRMTYP
 If [M]ALLFRMTYP=2 : Effzo FRMTYP : Grizo FRMTYP : Else : Actzo FRMTYP : Endif
Endif
If [M]ALLFRMTYP=2
 Effzo FRMTYP : Grizo FRMTYP
Else
 Actzo FRMTYP
Endif
If [M]ALLUSR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
If [M]PRO<>2
# Effzo TRC,VALDAT,ACCDAT : Grizo TRC,VALDAT,ACCDAT   :# Bug 11232
 Effzo VALDAT,ACCDAT : Grizo VALDAT,ACCDAT
Else
# Actzo TRC,VALDAT,ACCDAT   :# Bug 11232
 Actzo VALDAT,ACCDAT
Endif
If GBIDC1<>""
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP, ZTYP
 Grizo ALLTYP, TYP
Else
 Actzo ALLTYP
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
End

