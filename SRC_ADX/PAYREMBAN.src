#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..1)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"REMBAN"
 GFONCTION="REMBAN" : Call AUTORIS From EXEFNC
Endif
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYREMBAN","DREMBAN",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
 When "SORTIE"    : Gosub SORTIE
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

#########
$INIT_DIA
#########
[M:DIA]ACCSTA=9 : [M:DIA]FRMTYP=0
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return

#########
$CONTROLE
#########
If GSERVEUR : [M:DIA]TRC=2 : Endif
TMP=1
If [M:DIA]PRO=2 : TIT="T" : # Opération en cours
Else            : TIT="R" : # Recherche
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,SAI) From CPTDIV2
If SAI : Return : Endif
Return

#####
$EXEC
#####
Local Char     NUM(GLONVCR), DEVLOC(GLONCUR), SEP(3)
Local Libelle  PAYTYP(GLONTPY)
Local Integer  I
Local Decimal  MT, MT2

If !GSERVEUR & [M:DIA]TRC=2 : # Remise en banque
 Call TITAWI(BCRIT,GMESSAGE) From OBJDIV
 Call OUVRE_TRACE(GMESSAGE) From LECFIC
Endif

[M:DIA]NB=0
If GSERVEUR
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Elsif dim([M:DIA]LEG)>0
  GCURLEG = [M:DIA]LEG
 Endif
Endif
PAYTYP(0)=([M:DIA]PAY5=2)
PAYTYP(1)=([M:DIA]PAY7=2)
PAYTYP(2)=([M:DIA]PAY9=2)

If PAYTYP(0)
 [M:DIA]PAY5=2 : [M:DIA]PAY7=1 : [M:DIA]PAY9=1
 Call PAYCPT(NUM) From PAYCPTA
Endif
If PAYTYP(1)
 [M:DIA]PAY5=1 : [M:DIA]PAY7=2 : [M:DIA]PAY9=1
 Call PAYCPT(NUM) From PAYCPTA
Endif
If PAYTYP(2)
 [M:DIA]PAY5=1 : [M:DIA]PAY7=1 : [M:DIA]PAY9=2
 Call PAYCPT(NUM) From PAYCPTA
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
 TRA=1
Endif

# Allow to display the last captured values if exit and reentry into the function
If PAYTYP(0) : [M:DIA]PAY5=2 : Endif
If PAYTYP(1) : [M:DIA]PAY7=2 : Endif
If PAYTYP(2) : [M:DIA]PAY9=2 : Endif

Return

$TR_RAZ_PYT
GOK=1
Trbegin [PYT]
 Delete [PYT] Where TRC=GTRACE
 If fstat=1 | fstat>5
  GOK=2 : Call RSTA("PYT",GTRACE) From GLOCK
 Endif
Commit
Return

########
$TERMINE
########
If GSERVEUR : Return : Endif
If sum([M:DIA]NB(0..2))=0
 If PAYTYP(2)
  # Aucun règlement traité
  GERR=2 : GMESSAGE=mess(2,117,1)
 Else
  # Aucun bordereau traité
  GERR=2 : GMESSAGE=mess(129,117,1)
 Endif
Elsif [M:DIA]TRC<>2
 GERR=2
 If [M:DIA]NB(2)<>0
  # NB règlement(s) traité(s)
  GMESSAGE=num$([M:DIA]NB(2))-mess(28,117,1)
 Endif
 If ([M:DIA]NB(0)+[M:DIA]NB(1))<>0
  # NB bordereau(x) traité(s)
  If [M:DIA]NB(2)<>0 : GMESSAGE+="\" : Else : GMESSAGE="" : Endif
  GMESSAGE+=num$([M:DIA]NB(0)+[M:DIA]NB(1))-mess(130,117,1)
 Endif
Endif
Return

#######
$SORTIE
#######
[M]BIDON=""
Return

#####################################
## Etiquettes de l'écran PAYREMBAN ##
#####################################
$SEL_TABLE
Case COUZON
 When "BAN" : # Banque
  Gosub SELBAN From CPTSEL

 When "LOT" : # Lot de saisie
  OBJET="PYL"
  If [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
    CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTYP<>2
   CRITERE-="& PAYTYP='"+[M]TYP+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif

Endcase
Return

Subprog AV_BIDON(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR="X"
 If [M]PAY5=1 : Grizo ALLFRMTYP, FRMTYP : Endif
 If [M]PAY9=1 : Grizo ALLLOT, LOT : Endif
Endif
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY = 2 : mkstat = 1 : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 1 : Endif
End

Subprog AM_PAY9(VALEUR)
Variable Integer  VALEUR
If VALEUR<>2
 If [M]ALLLOT<>2
  [M]ALLLOT=2 : [M]LOT=""
  Affzo ALLLOT, LOT
 Endif
 Grizo ALLLOT, LOT
Else
 Actzo ALLLOT
 If [M]ALLLOT=2 : Grizo LOT : Else : Actzo LOT : Endif
Endif
End

Subprog AM_PAY5(VALEUR)
Variable Integer  VALEUR
If VALEUR<>2
 If [M]ALLFRMTYP<>2
  [M]ALLFRMTYP=2 : [M]FRMTYP=0
  Affzo ALLFRMTYP, FRMTYP
 Endif
 Grizo ALLFRMTYP, FRMTYP
Else
 Actzo ALLFRMTYP
 If [M]ALLFRMTYP=2 : Grizo FRMTYP : Else : Actzo FRMTYP : Endif
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
Local Char DES(GLONDES)
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat | [F:TPY]STA9<>2
 # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Elsif [M:DIA]PAY5<>2 & [F:TPY]STA5=2
 Call DESZECR("PAYREMBAN","PAY5",DES)
 GMESSAGE=mess(28,102,1)-DES : mkstat=2
Elsif [M:DIA]PAY7<>2 & [F:TPY]STA7=2
 Call DESZECR("PAYREMBAN","PAY7",DES)
 GMESSAGE=mess(28,102,1)-DES : mkstat=2
Elsif [M:DIA]PAY9<>2 & [F:TPY]STA5<>2 & [F:TPY]STA7<>2
 Call DESZECR("PAYREMBAN","PAY9",DES)
 GMESSAGE=mess(28,102,1)-DES : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog DESZECR(ECR,ZONE,DES)
Value Char    ECR(), ZONE()
Variable Char DES()
If clalev([AMZ])=0 : Local File AMSKZON [AMZ] : Endif
DES=""
Read [AMZ]CODE = ECR;ZONE
If fstat=0
 Call TEXTE([F:AMZ]INTIT,DES) From OBJDIV
Endif
If DES="" : DES=ZONE : Else DES='"'+DES+'"' : Endif
End

Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]ALLCPY<>2 & [F:PYL]CPY<>[M]CPY
 # Lot de saisie de société
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY : mkstat=2
Elsif [M]ALLTYP<>2 & [F:PYL]PAYTYP<>[M]TYP
 # Lot de saisie de transaction
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP  : mkstat=2 : End
Endif
End

Subprog AS_BAN(VALEUR)
Variable Char     VALEUR
If [M]ALLBAN = 2 : [M]BANDES="" : mkstat = 1 Endif
End

Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
Call CONTROLE("BAN","#",VALEUR,"",STAT) From CONTOBJ
If STAT : mkstat=2 : End : Endif
Call CONTEXE([F:BAN]ACS) From CPTSUB
If mkstat : End : Endif
If [M]BAN<>VALEUR
 [M]BANDES=[F:BAN]DES
Endif
End

Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]ALLUSR = 2 : VALEUR="" : mkstat = 2
Elsif VALEUR="" : VALEUR = GUSER
Endif
End

Subprog AS_FRMTYP(VALEUR)
Variable Integer  VALEUR
If [M]ALLFRMTYP=2 : mkstat = 1 : Endif
End

Subprog AS_PRO(VALEUR)
Variable Integer VALEUR
Local Integer I
If [M]FCY<>""
 I=find([M]FCY,GUSRFCY(1..GNBAUZ))
 If !I | !instr(1,GUSRAUZ(I),"G")
  VALEUR=1 : mkstat=2
 Endif
Endif
End

Subprog AS_TRC(VALEUR)
Variable Integer VALEUR
If [M]PRO<>2 : VALEUR=2 : mkstat=2 : Endif
End

Subprog AS_ACCDAT(VALEUR)
Variable Date    VALEUR
If [M]PRO<>2 : mkstat=1 : End : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If [M:DIA]TYP<>""
 Call LEC_TPY_LEG(GCURLEG,[M:DIA]TYP) From CPTLEC
 If fstat=0 & [F:TPY]STA3<>2 & [F:TPY]STA8<>2 : mkstat=1 : Endif
Else
 Local Integer ACS
 Filter [TPY] Where LEG=GCURLEG | LEG="" Order By Key CLE=PAYTYP Asc ; LEG Desc
 For [F:TPY]CLE(1)
  If [F:TPY]STA9=2 & ([F:TPY]STA3=2 | [F:TPY]STA8=2)
&   & ([M:DIA]PAY5=2 & [F:TPY]STA5=2) | ([M:DIA]PAY7=2 & [F:TPY]STA7=2) | ([M:DIA]PAY9=2 & [F:TPY]STA5<>2 & [F:TPY]STA7<>2)
   ACS = 1 : Break
  Endif
 Next
 Filter [TPY]
 If !ACS : mkstat=1 : Endif
Endif
End

Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
Local Libelle TYPGEN,TYPANA
Local Integer OBY
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif

If VALEUR<>[0/0/0]
 If [M]FCY<>""    :
  Call SETMAINREF([M]FCY,TYPGEN,TYPANA) From CPTDIV
  Call CONTPER(VALEUR,TYPGEN,[M]FCY) From CPTSUB
 Elsif [M]CPY<>""
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Filter [FCY] Where LEGCPY=[M]CPY
  Read [FCY]FCY1 First
  Filter [FCY]
  If fstat<=2
   Call SETMAINREF([M]CPY,TYPGEN,TYPANA) From CPTDIV
   Call CONTPER(VALEUR,TYPGEN,[F:FCY]FCY) From CPTSUB
  Endif
 Endif
Else
 OBY=1
 If [M:DIA]TYP<>""
  Call LEC_TPY_LEG(GCURLEG,[M:DIA]TYP) From CPTLEC
  If !fstat & [F:TPY]DUDFLG=2 & ([F:TPY]STA3=2 | [F:TPY]STA8=2)
   OBY=0
  Endif
 Endif
 If OBY
  GMESSAGE=mess(10,123,1) : mkstat=2 : End
 Endif
Endif
End

Subprog AS_VALDAT(VALEUR)
Variable Date    VALEUR
If [M]PRO<>2 : mkstat=1 : Endif
End

########################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

