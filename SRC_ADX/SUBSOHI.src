#<AdxTL>@(#)0.0.0.0 $Revision$
########################################
Subprog IB_NBLIG

Raz GBOUT1, GBOUT2, GBOUT3
If GFONC1 <> "GESSIH" & [M]NUM(nolign-1) <> "" GBOUT1 = mess(55,198,1) Endif
If [M]FMINUM(nolign-1) <> ""
    If GFONC1 <> "GESMFG" & [M]FMI(nolign-1) = 5
        GBOUT2 = mess(166,198,1)
    Elsif GFONC1 <> "GESPOH"
        GBOUT3 = mess(260,198,1)
        Raz GBOUT4
    Endif
Else
    Raz GBOUT4
Endif
Call IB_NOTECHECK([M]ITMREF(nolign-1),"ITMREF",5)  From TRTNTSCTL # product notes EWI 86290
Call IB_PRDINF([M]ITMREF(nolign-1),6) From PRDINFLIB  # DF 79831 EWI 86290
End
