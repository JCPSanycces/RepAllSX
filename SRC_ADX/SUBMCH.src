#70009
If [F:MCH]JOBPOT=""
 [M:MCH1]ALLJOBPOT=2 : Grizo [M:MCH1]JOBPOT
Else
 [M:MCH1]ALLJOBPOT=1
Endif
If [F:MCH]POT=""
 [M:MCH1]ALLPOT=2 : Grizo [M:MCH1]POT
Else
