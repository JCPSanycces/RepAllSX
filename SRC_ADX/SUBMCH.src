#####################################
$MARQUE
#57149
If [M:MCH1]TYPMCH=1 | [M:MCH0]FLGCLO=2 : Return : Endif  :# Scénario initial
ILIS = val(right$(currbox,8))
Case OBJLIS(ILIS)
When "MHV"
If [M:MCH1]NBLIG>0
 For I=0 To [M:MCH1]NBLIG-1
  If [M:MCH1]TYPHYP(I)=1
   Call LECTURE ("MHV",[M:MCH1]CODHYP(I),"") From CONTOBJ
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
 Next I
Endif
When "MHR"
If [M:MCH1]NBLIG>0
 For I=0 To [M:MCH1]NBLIG-1
  If [M:MCH1]TYPHYP(I)=2
   Call LECTURE ("MHR",[M:MCH1]CODHYP(I),"") From CONTOBJ
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
 Next I
Endif
When "MHP"
