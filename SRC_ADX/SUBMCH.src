$SETBOUT
#63913
If GREP<>"" | !VERROU
 Call VIREBOUT (CHAINE,"AHBG") From GOBJET
Elsif [M:MCH0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AHB") From GOBJET
Elsif [M:MCH0]STA=1
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#end 63913
Return

