  [M:MCH1]CODHYP(nolign-1) = [F:MHT]COD
  Call LECTURE ("MHT",[F:MHT]COD,"") From CONTOBJ
  [M:MCH1]DESHYP(nolign-1) = [F:MHT]DES
Endcase
[M:MCH1]STAHYP(nolign-1) = 1
[M:MCH1]CODOBJ(nolign-1) = OBJLIS(ILIS)
[M:MCH1]NBLIG = nolign
[M:MCH1]STRHYP(nolign-1) = [M:MCH1]STRDAT
[M:MCH1]ENDHYP(nolign-1) = [M:MCH1]ENDDAT
[M:MCH1]NUMORD(nolign-1) = max([M:MCH1]NUMORD)+5
Return

#####################################
$FIN_PICK
#57149
If [M:MCH1]TYPMCH=1 | [M:MCH0]FLGCLO=2 : Return : Endif  :# Scénario initial
Affzo [M:MCH1]
Return

#####################################
#63913
$INIT_DIA
  If GACTION="MCHD"
    [DIA]DAT = [M:MCH1]ENDDAT
  Endif
Return

$TERMINE
  If GACTION="MCHD" and OK=2
    PARAM(1)=[M:MCH0]COD
    PARAM(2)=[DIA]DAT
    Call GCONSULT("MAS","",PARAM) From GCONSULT
  Endif
Return
#end 63913

######################################################################################
## Etiquette ajoutée par le superviseur (écran MCH0) 05/03/2009 11:24:08 (DBA)
######################################################################################

Subprog D_STA(VALEUR)
Variable Integer VALEUR
VALEUR=1 :#Saisie
End

Subprog AS_FLGCLO(VALEUR)
Variable Integer VALEUR
If [M:MCH0]STA<2 : mkstat=2 : End : Endif
End

Subprog AM_FLGCLO(VALEUR)
Variable Integer VALEUR
# Aucune hypothèse si scénario initiale
If [M:MCH1]TYPMCH=1 : End : Endif
# Maj des case à cocher 'définitive' des hypothèses du scénario
For I=1 To [M:MCH1]NBLIG
 Case [M:MCH1]TYPHYP(I-1)
  When 1 : Default File [MHV]
  When 2 : Default File [MHR]
  When 3 : Default File [MHP]
  When 4 : Default File [MHE]
  When 5 : Default File [MHX]
  When 6 : Default File [MHC]
  When 9 : Default File [MHT]
  When Default : Default File [MHV]
 Endcase
 If VALEUR=2
  Update [F] Where COD=[M:MCH1]CODHYP(I-1) With FLGCLO=VALEUR
 Else

  If clalev([F:MCL2])=0  : Local File MSSCENAL     [MCL2] : Endif
  If clalev([F:MCH2])=0  : Local File MSSCENAH     [MCH2] : Endif
  Local Integer OK
  # En cas de décochage : vérif si les hypothèses ne sont pas utilisées dans autre scénario definitif
  OK=1
  For [F:MCL2]MCL1 Where COD<>[M:MCH0]COD & TYPHYP=[M:MCH1]TYPHYP(I-1) & CODHYP=[M:MCH1]CODHYP(I-1)
   Read[F:MCH2]MCH0=[F:MCL2]COD
   If fstat | [F:MCH2]FLGCLO=2
    OK=0 : Break
   Endif
  Next
  If OK
   Update [F] Where COD=[M:MCH1]CODHYP(I-1) With FLGCLO=VALEUR
  Endif
 Endif
Next
End

######################################################################################
## TYPE
######################################################################################
Subprog AM_TYPMCH(VALEUR)
Variable Integer VALEUR
Call GRISE_AM_TYPMCH(VALEUR)
# FQ76657 - MABON 29/09/11 - Si sécnario initial, il ne peut pas y avoir d'hypothèses, donc dans le cas
# d'une duplication, on vide le tableau
If VALEUR=1 Then
  [M:MCH1]NBLIG=0 : Affzo [M:MCH1]NBLIG
Endif
# Fin MABON
End

Subprog GRISE_AM_TYPMCH(VTYP)
Variable Integer VTYP
If VTYP=1
 Effzo [M:MCH1]CODINI
 Grizo [M:MCH1]CODINI
 Actzo [M:MCH1]15-20
 Actzo [M:MCH1]STRDAT, ENDDAT, MTHREF
Else
 Actzo [M:MCH1]CODINI
 Grizo [M:MCH1]15-20
 Grizo [M:MCH1]STRDAT, ENDDAT, MTHREF
Endif
If VTYP=3 : # Révision budgétaire
 Actzo [M:MCH1]DATREVBUD
Else
 Effzo [M:MCH1]DATREVBUD
 Grizo [M:MCH1]DATREVBUD
Endif
End


Subprog C_CODINI(VALEUR)
Variable Char    VALEUR()
If clalev([F:MCH2])=0  : Local File MSSCENAH     [MCH2] : Endif
Read[F:MCH2]MCH0=VALEUR
If !fstat
 If [F:MCH2]TYPMCH<>[M:MCH1]TYPMCH-1
  # Ce scénario n'est pas de type
  GMESSAGE = mess(19,10722,1)-mess([M:MCH1]TYPMCH-1,10486,1)
  mkstat = 2 : End
 Endif
 If [F:MCH2]FLGCLO<>2
  # Ce scénario n'est pas coché définitif
  GMESSAGE = mess(20,10722,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_CODINI(VALEUR)
Variable Char    VALEUR()
If clalev([F:MCH2])=0  : Local File MSSCENAH     [MCH2] : Endif
Read[F:MCH2]MCH0=VALEUR
If !fstat
 [M:MCH1]STRDAT=[F:MCH2]STRDAT
 [M:MCH1]ENDDAT=[F:MCH2]ENDDAT
 [M:MCH1]MTHREF=[F:MCH2]MTHREF
 [M:MCH1]CPY=[F:MCH2]CPY
 [M:MCH1]FCY=[F:MCH2]FCY
 [M:MCH1]SRV=[F:MCH2]SRV
 [M:MCH1]PRF=[F:MCH2]PRF
 #70009
 [M:MCH1]JOBPOT=[F:MCH2]JOBPOT
 [M:MCH1]POT=[F:MCH2]POT
 #end 70009
 [M:MCH1]STRMAT=[F:MCH2]STRMAT
 [M:MCH1]ENDMAT=[F:MCH2]ENDMAT
 [M:MCH1]POP=[F:MCH2]POP
 [M:MCH1]CRI=[F:MCH2]CRI
 [M:MCH1]BUD1=[F:MCH2]BUD(0)
 [M:MCH1]BUD2=[F:MCH2]BUD(1)
 Gosub GRISE
 # récup des hypothèses du scénario budgétaire dans la révision
 If [M:MCH1]TYPMCH=3
  Call CHARGE_LIGNES ([F:MCH2]COD)
 Endif
 Affzo [M:MCH1]
Endif
End


