######################################################################################
## Etiquette ajoutée par le superviseur (Objet MCH) 05/03/2009 11:09:11 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "ANNULE"       : Gosub ANNULE
 When "INIMOD"       : Gosub INIMOD
 When "INICRE"       : Gosub INICRE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When "RAZDUP"       : [M:MCH0]STA=1 : [M:MCH0]FLGCLO=1 : Affzo [M:MCH0]10
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
 When "PICKE"        : Gosub PICKE
 When "DEPICK"       : Gosub DEPICK
 When "FIN_PICK"     : Gosub FIN_PICK
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "APRES_CRE"    : Call GENMCH(nomap,[F:MCH]COD)
 When "APRES_MOD"    : Call GENMCH(nomap,[F:MCH]COD)
 When "EXEBOUT"      : Gosub EXEBOUT
 When "INIT_DIA"     : Gosub INIT_DIA #63913
 When "TERMINE"      : Gosub TERMINE #63913
 When "FERME"        : Gosub FERME
Endcase
Return

#####################################
$OUVRE
If clalev ([F:BCB])=0 : Local File BCLOB     [BCB] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
