#####################################
$GRISE
If [M:MCH1]ALLCPY=2
 Diszo [MCH1]CPY,FCY
 [M:MCH1]ALLFCY=2 : Affzo [MCH1]ALLFCY : Diszo [MCH1]ALLFCY
Else
 Actzo [MCH1]CPY,ALLFCY
Endif
If [M:MCH1]ALLFCY=2 : Diszo [MCH1]FCY : Else : Actzo [MCH1]FCY : Endif
If [M:MCH1]ALLSRV=2 : Diszo [MCH1]SRV : Else : Actzo [MCH1]SRV : Endif
If [M:MCH1]ALLPRF=2 : Diszo [MCH1]PRF : Else : Actzo [MCH1]PRF : Endif
#70009
If [M:MCH1]ALLJOBPOT=2 : Diszo [MCH1]JOBPOT : Else : Actzo [MCH1]JOBPOT : Endif
If [M:MCH1]ALLPOT=2 : Diszo [MCH1]POT : Else : Actzo [MCH1]POT : Endif
#end 70009
Call GRISE_AM_TYPMCH([M:MCH1]TYPMCH)
Gosub CHARGE_ENT
Return

#####################################
Subprog CHARGE_LIGNES (CODE)
Value Char CODE
nolign=0
For [MCL]MCL0 Where COD=CODE
 nolign += 1
 [M:MCH1]=[F:MCL]
 Call CODOBJ ([F:MCL]TYPHYP)
 Call LECTURE ([M:MCH1]CODOBJ(nolign-1), [F:MCL]CODHYP,"") From CONTOBJ
 [M:MCH1]DESHYP(nolign-1)= evalue("[F:"+[M:MCH1]CODOBJ(nolign-1)+"]DES")
 [M:MCH1]TYPCODHYP(nolign-1) = num$([M:MCH1]TYPHYP(nolign-1))+"/"+[M:MCH1]CODHYP(nolign-1)
Next
[M:MCH1]NBLIG=nolign
End

#####################################
$INICRE
$INIMOD
Gosub SAUVE_LIGNES
#Codes budgétaires
[F:MCH]BUD(0)=[M:MCH1]BUD1    :#ATM
[F:MCH]BUD(1)=[M:MCH1]BUD2    :#AIA
[F:MCH]MTHREF=eomonth([M:MCH1]MTHREF)
#CMT
Default Mask [M:MCH2]
Call SAUVE_CMT ("SUBMCH",[F:MCH]COD,"","","")From SUBMSR
Return

#74219 The control depends on the order number (NUMORD)
#####################################
#$VERIF
## verifier ordre chrono
#Local Date DEB1, DEB2, FIN1, FIN2
#DEB1 = "00/00/00"
#FIN1 = "00/00/00"
##Verif chronologie
#For I=1 To [M:MCH1]NBLIG
# DEB2 = [M:MCH1]STRHYP(I-1)
# FIN2 = [M:MCH1]ENDHYP(I-1)
# If DEB1>DEB2
#  GMESSAGE = mess(13,10722,1)-num$(I-1)-num$(I) #Ordre chrono non respecté entre les lignes
#  GERR=1 : Break
# Endif
# If FIN1>DEB2 & FIN1<[M:MCH1]ENDDAT
#  GMESSAGE = mess(13,10722,1)-num$(I-1)-num$(I) #Ordre chrono non respecté entre les lignes
#  GERR=1 : Break
# Endif
# DEB1 = DEB2
# FIN1 = FIN2
#Next
#If GERR=1 : Return : Endif
#Return
#####################################
$VERIF
  Local Integer NUMORDISOK
  Local Integer LIGERR1, LIGERR2 :#Lines in error
  If [M:MCH1]NBLIG=0 : Return : Endif

  Local Integer TBLNUMLIG(1..[M:MCH1]NBLIG)
  Local Integer TBLNUMORD(1..[M:MCH1]NBLIG)
  Raz LIGERR1, LIGERR2

  While !NUMORDISOK
    Gosub CTRL_NUMORD
  Wend
  Kill TBLNUMLIG, TBLNUMORD
Return

$CTRL_NUMORD
# control chronological order
Local Date DEB1, DEB2, FIN1, FIN2, VDATE
Local Integer NUMORD1, NUMORD2, NEWNUMORD
DEB1 = "00/00/00"
FIN1 = "00/00/00"
NUMORD1 = 0
#fill arrays with NUMORD and NUMLIG sorted on NUMORD
Call ORDERHYPO(TBLNUMLIG, TBLNUMORD)
NUMORDISOK=1

#control chronological
For I=1 To [M:MCH1]NBLIG
 DEB2 = [M:MCH1]STRHYP(TBLNUMLIG(I)-1)
 FIN2 = [M:MCH1]ENDHYP(TBLNUMLIG(I)-1)
 NUMORD2 = TBLNUMORD(I)
 If DEB1>DEB2
  VDATE=DEB1
  If (LIGERR1=TBLNUMLIG(I-1) & LIGERR2=TBLNUMLIG(I))|(LIGERR1=TBLNUMLIG(I) & LIGERR2=TBLNUMLIG(I-1))
    Raz LIGERR1, LIGERR2
    GMESSAGE = mess(13,10722,1)-num$(TBLNUMLIG(I-1))-tolower(mess(1,56,1))-num$(TBLNUMLIG(I)) #Ordre chrono non respecté entre les lignes
    GMESSAGE -= chr$(10)+chr$(13)+mess(53,10722,1)
    mkstat=2
  Else
    Gosub GETNEWNUMORD
    Gosub MODIFYNUMORD
  Endif
  Break
 Endif
 If FIN1<[M:MCH1]ENDDAT & FIN1>DEB2
  VDATE=FIN1
  If (LIGERR1=TBLNUMLIG(I-1) & LIGERR2=TBLNUMLIG(I))|(LIGERR1=TBLNUMLIG(I) & LIGERR2=TBLNUMLIG(I-1))
    Raz LIGERR1, LIGERR2
    GMESSAGE = mess(13,10722,1)-num$(TBLNUMLIG(I-1))-tolower(mess(1,56,1))-num$(TBLNUMLIG(I)) #Ordre chrono non respecté entre les lignes
    GMESSAGE -= chr$(10)+chr$(13)+mess(53,10722,1)
    mkstat=2
  Else
    Gosub GETNEWNUMORD
    Gosub MODIFYNUMORD
  Endif
  Break
 Endif
 DEB1 = DEB2
 FIN1 = FIN2
 NUMORD1 = NUMORD2
Next I
Return

$MODIFYNUMORD
  Local Char VMESSAGE(250)
  Local Integer VOK

  VMESSAGE = mess(13,10722,1)-num$(TBLNUMLIG(I-1))-tolower(mess(1,56,1))-num$(TBLNUMLIG(I))+"." #Ordre chrono non respecté entre les lignes
  VMESSAGE -= chr$(10)+chr$(13)+func AFNC.MES2(mess(52,10722,1),num$(TBLNUMORD(I-1)),num$(NEWNUMORD))
  Call OUINON(VMESSAGE,VOK) From GESECRAN
  If VOK=2
    [M:MCH1]NUMORD(TBLNUMLIG(I-1)-1)=NEWNUMORD
    Affzo [M:MCH1]NUMORD(TBLNUMLIG(I-1)-1)
    NUMORDISOK=0 # we have to re-control the board.
    LIGERR1=TBLNUMLIG(I-1)
    LIGERR2=TBLNUMLIG(I)
  Else
    GMESSAGE = mess(13,10722,1)-num$(TBLNUMLIG(I-1))-tolower(mess(1,56,1))-num$(TBLNUMLIG(I)) #Ordre chrono non respecté entre les lignes
    mkstat=2
  Endif
Return

$GETNEWNUMORD
  Local Integer MAXBORDER, J

  For J=I+1 To [M:MCH1]NBLIG
    If VDATE<=[M:MCH1]STRHYP(TBLNUMLIG(J)-1)
      MAXBORDER=J
      Break
    Endif
  Next J
  If MAXBORDER>0 & MAXBORDER-1>0
    NEWNUMORD=TBLNUMORD(MAXBORDER-1)+int((TBLNUMORD(MAXBORDER)-TBLNUMORD(MAXBORDER-1))/2)
    #control NEWNUMORD not existing
    While find(NEWNUMORD,TBLNUMORD) and (NEWNUMORD<TBLNUMORD(MAXBORDER))
      NEWNUMORD+=1
    Wend
    If NEWNUMORD=TBLNUMORD(MAXBORDER) : NEWNUMORD=max(TBLNUMORD)+5 : Endif
  Else
    NEWNUMORD=max(TBLNUMORD)+5
  Endif
Return
#end 74219

#####################################
$SAUVE_LIGNES
Delete [MCL] Where COD=[F:MCH]COD
If fstat=1
 GOK =-1 : GLOCK = "MSSCENAL" : Return
Endif
For nolign=1 To [M:MCH1]NBLIG
 Raz [F:MCL]
 [F:MCL]       = [M:MCH1]
 [F:MCL]COD    = [M:MCH0]COD
 [F:MCL]NUMLIG = nolign
 Write[F:MCL]
 If fstat<>0
  GOK = 0 : Call FSTA("MCL") From GLOCK : Break
 Endif
Next
Return

#####################################
$ANNULE
#CMT commun à toutes les lignes
Call ANNULE_CMT ("SUBMCH",[F:MCH]COD,"","","")From SUBMSR
# Suppression du prgrm généré
Call DELTRT("WPMSMCH"+[F:MCH]COD,nomap) From SUBADC
Return

$EXEBOUT
  If BOUT="B"
   Gosub RAFFRAICHIR From GOBJSUB
   Gosub RELIT From GOBJSUB
  Endif
Return

