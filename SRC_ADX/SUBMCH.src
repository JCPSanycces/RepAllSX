#####################################
$DEPICK
#57149
If [M:MCH1]TYPMCH=1 | [M:MCH0]FLGCLO=2 : Return : Endif  :# Scénario initial
ILIS = val(right$(currbox,8))
Case OBJLIS(ILIS)
 When "MHV"
  NOL = find([F:MHV]COD,[M:MCH1]CODHYP(0..[M:MCH1]NBLIG-1))
  If NOL
   Dela NOL-1 [M:MCH1]NBLIG
   [M:MCH1]NBLIG -= 1
  Else
   OK = 0
  Endif
 When "MHR"
  NOL = find([F:MHR]COD,[M:MCH1]CODHYP(0..[M:MCH1]NBLIG-1))
