 For I=0 To [M:MCH1]NBLIG-1
  If [M:MCH1]TYPHYP(I)=3
   Call LECTURE ("MHP",[M:MCH1]CODHYP(I),"") From CONTOBJ
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
 Next I
Endif
When "MHE"
