######################################################################################
## TABLEAU DES HYPOTHESES
######################################################################################
Subprog C_NBLIG
## Bloque la saisie si scénario initial | scénario définitif
If !adxgtb & ([M:MCH1]TYPMCH=1 | [M:MCH0]FLGCLO=2 )
 mkstat=2 : End
Endif
End

Subprog AS_TYPHYP(VALEUR)
Variable Integer VALEUR
GMENLOC(7) = 1
GMENLOC(8) = 1
End

Subprog AM_TYPHYP(VALEUR)
Variable Integer VALEUR
Call CODOBJ (VALEUR)
End

Subprog CODOBJ (CODE)
Value Integer CODE
Case CODE
 When 1 : [M:MCH1]CODOBJ(nolign-1)="MHV"
 When 2 : [M:MCH1]CODOBJ(nolign-1)="MHR"
 When 3 : [M:MCH1]CODOBJ(nolign-1)="MHP"
 When 4 : [M:MCH1]CODOBJ(nolign-1)="MHE"
 When 5 : [M:MCH1]CODOBJ(nolign-1)="MHX"
 When 6 : [M:MCH1]CODOBJ(nolign-1)="MHC"
 When 9 : [M:MCH1]CODOBJ(nolign-1)="MHT"
 When Default : [M:MCH1]CODOBJ(nolign-1)="MHV"
Endcase
End

Subprog C_CODHYP(VALEUR)
Variable Char    VALEUR()
Variable Integer K, I, J, NOL

Call LECTURE ([M:MCH1]CODOBJ(nolign-1), VALEUR,"") From CONTOBJ
If fstat
 GMESSAGE=mess(23,100,1) :# Fiche inexistante
 mkstat=2 : End
Endif

# Contrôle de l'unicité du code hypothèse si ce n'est pas une hypothèse de type variable
[M:MCH1]TYPCODHYP(nolign-1) = num$([M:MCH1]TYPHYP(nolign-1))+"/"+VALEUR
If [M:MCH1]TYPHYP(nolign-1)<>1
 Call UNICITE ([M:MCH1]TYPCODHYP(nolign-1),[M:MCH1]TYPCODHYP) From OBJDIV
 If mkstat=2  End : Endif
Endif

[M:MCH1]DESHYP(nolign-1)= evalue("[F:"+[M:MCH1]CODOBJ(nolign-1)+"]DES")
End

Subprog AS_STRHYP(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M]STRDAT : Endif
End

Subprog AS_ENDHYP(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M]ENDDAT : Endif
End

Subprog C_STRHYP(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:MCH1]STRDAT
 #Date en dehors de la période de simulation
 GMESSAGE = mess(14,10722,1)
 mkstat=2 : End
Endif
End

Subprog C_ENDHYP(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:MCH1]ENDDAT
 #Date en dehors de la période de simulation
 GMESSAGE = mess(14,10722,1)
 mkstat=2 : End
Endif
End

Subprog AS_STAHYP(VALEUR)
Variable Integer VALEUR
If [M:MCH1]TYPMCH=3
 GMENLOC(2) = 0
 If clalev([F:MCL2])=0  : Local File MSSCENAL     [MCL2] : Endif
 Read[MCL2]MCL1=[M:MCH1]CODINI;[M:MCH1]TYPHYP(nolign-1);[M:MCH1]CODHYP(nolign-1)
 If [M:MCH1]STRHYP(nolign-1)>=[F:MCL2]STRHYP
  VALEUR = 2
 Endif
Else
 GMENLOC(2) = 1
Endif
End

Subprog AS_NBRMTH(VALEUR)
Variable Decimal VALEUR
If [M:MCH1]STAHYP(nolign-1)<>2
 mkstat = 1 : End
Else
 # Si révision budgétaire alors calcul du nb de mois
 If [M:MCH1]TYPMCH=3
  If clalev([F:MCL2])=0  : Local File MSSCENAL     [MCL2] : Endif
  Read[MCL2]MCL1=[M:MCH1]CODINI;[M:MCH1]TYPHYP(nolign-1);[M:MCH1]CODHYP(nolign-1)
  If fstat : mkstat = 1 : End : Endif
  If [M:MCH1]STRHYP(nolign-1)>=addmonth(([F:MCL2]STRHYP),1)
   #On avance la date d'au moins 1 mois
   If day([M:MCH1]STRHYP(nolign-1))>=day([F:MCL2]STRHYP)
    VALEUR = month([M:MCH1]STRHYP(nolign-1))-month([F:MCL2]STRHYP)
   Else
    VALEUR = month([M:MCH1]STRHYP(nolign-1))-month([F:MCL2]STRHYP)-1
   Endif
   mkstat = 2 : End
  Elsif [M:MCH1]STRHYP(nolign-1)<=addmonth(([F:MCL2]STRHYP),-1)
   # On recule la date d'au moins un mois
   If day([M:MCH1]STRHYP(nolign-1))<= day([F:MCL2]STRHYP)
    VALEUR = month([M:MCH1]STRHYP(nolign-1))-month([F:MCL2]STRHYP)
   Else
    VALEUR = month([M:MCH1]STRHYP(nolign-1))-month([F:MCL2]STRHYP)+1
   Endif
   mkstat = 2 : End
  Else
   mkstat = 1 : End
  Endif
 Endif
Endif
End


#################################
Subprog GENMCH(APPLI, CODMCH)
Value Char APPLI ()
Value Char CODMCH()

Local Char TETADO (50), PROG (30), FICSRC(250)
Local Integer OK
Local Char    SAVIFS(5) , SAVIRS(5)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

If clalev([F:MCH2])=0  : Local File MSSCENAH    [MCH2]  : Endif

Read [F:MCH2]MCH0=CODMCH
If !fstat
 TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
 PROG = "WPMSMCH"+[F:MCH2]COD
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(16,10722,1) :# Scénario
 Wrseq "###############################################"
 Wrseq "$CONTROLE"
 Gosub GENCTRL
 Wrseq "Return"
 Openo
 Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Endif

adxirs = SAVIRS
adxifs = SAVIFS
End

$GENCTRL
#CHECK IGNORE_BEGIN
Wrseq "OK=1"
If [F:MCH2]CPY<>""         : Wrseq "If SOCIETE <>'" +[F:MCH2]CPY    +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]FCY<>""         : Wrseq "If SITE <>'"    +[F:MCH2]FCY    +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]PRF<>""         : Wrseq "If PROFIL<>'"   +[F:MCH2]PRF    +"': OK = 0 : Return : Endif" : Endif
#70009
If [F:MCH2]JOBPOT<>""      : Wrseq "If EMPLOITYP<>'" +[F:MCH2]JOBPOT +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]POT<>""         : Wrseq "If POSTE<>'"    +[F:MCH2]POT    +"': OK = 0 : Return : Endif" : Endif
#end 70009
If [F:MCH2]SRV<>""         : Wrseq "If SERVICE<>'"  +[F:MCH2]SRV    +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]STRMAT<>""      : Wrseq "If MATRI<'"     +[F:MCH2]STRMAT +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]ENDMAT<>""      : Wrseq "If MATRI>'"     +[F:MCH2]ENDMAT +"': OK = 0 : Return : Endif" : Endif
If [F:MCH2]CRI<>""         : Wrseq "If !evalue('"   +[F:MCH2]CRI  +"') : OK = 0 : Return : Endif" : Endif
If [F:MCH2]POP<>""
# 58837
# Wrseq "Read [POA]POA0="+[F:MCH2]POP+";MATRI"
 Wrseq "Read [HRPOA]POA0='"+[F:MCH2]POP+"';MATRI"
 Wrseq "If fstat : OK = 0 : Return : Endif"
Endif
#CHECK IGNORE_END
Return

##74219
Subprog C_NUMORD(VALEUR)
Variable Decimal VALEUR
  Call UNICITE([L]VALEUR, [M:MCH1]NUMORD) From OBJDIV
End

#fill arrays TBLNUMORD and TBLNUMLIG by hypothesis sorted on NUMORD
Subprog ORDERHYPO(TBLNUMLIG, TBLNUMORD)
  Variable Integer TBLNUMLIG(1..), TBLNUMORD(1..)
  Local Integer NXTNUMORD, NXTNUMLIG
  Raz TBLNUMLIG, TBLNUMORD
  #we treat the smallest number of order
  TBLNUMORD(1)=min([M:MCH1]NUMORD(0..[M:MCH1]NBLIG-1))
  For I=1 To [M:MCH1]NBLIG
    If [M:MCH1]NUMORD(I-1) = TBLNUMORD(1)
      TBLNUMLIG(1)=I
      Break
    Endif
  Next I
  #we treat all others
  For I=2 To [M:MCH1]NBLIG
    NXTNUMORD=0 : NXTNUMLIG=0
    For J=1 To [M:MCH1]NBLIG
      If [M:MCH1]NUMORD(J-1)>TBLNUMORD(I-1) & (NXTNUMORD=0 | NXTNUMORD>[M:MCH1]NUMORD(J-1))
        NXTNUMORD=[M:MCH1]NUMORD(J-1)
        NXTNUMLIG=J
      Endif
    Next J
    If NXTNUMORD>0
      TBLNUMORD(I)=NXTNUMORD
      TBLNUMLIG(I)=NXTNUMLIG
    Endif
  Next I
End

Subprog AS_NUMORD(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : VALEUR=max([M:MCH1]NUMORD)+5 : Endif
End

Subprog B2_NUMORD(VALEUR)
  Variable Decimal VALEUR
  Local Integer TBLNUMLIG(1..[M:MCH1]NBLIG)
  Local Integer TBLNUMORD(1..[M:MCH1]NBLIG)

  Call ORDERHYPO(TBLNUMLIG, TBLNUMORD)
  For I=1 To dim(TBLNUMLIG)
    [M:MCH1]NUMORD(TBLNUMLIG(I)-1)=I*5
  Next I
  Affzo [M:MCH1]
End
#end 74219
######################################################################################
