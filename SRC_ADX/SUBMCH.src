#####################################
$PICKE
#57149
If [M:MCH1]TYPMCH=1 | [M:MCH0]FLGCLO=2 : Return : Endif  :# Scénario initial
ILIS = val(right$(currbox,8))
Case OBJLIS(ILIS)
 When "MHV"
  NOL = find([F:MHV]COD,[M:MCH1]CODHYP(0..[M:MCH1]NBLIG-1))
  If NOL : Return : Endif
  nolign = [M:MCH1]NBLIG + 1
  If nolign>dim([M:MCH1]CODHYP)
   OK = 0 : GMESSAGE = mess(26,100,1) #"Tableau plein"
   FIN = 1
   Return
  Endif
  [M:MCH1]TYPHYP(nolign-1) = 1
  [M:MCH1]CODHYP(nolign-1) = [F:MHV]COD
  Call LECTURE ("MHV",[F:MHV]COD,"") From CONTOBJ
  [M:MCH1]DESHYP(nolign-1) = [F:MHV]DES
 When "MHR"
  NOL = find([F:MHR]COD,[M:MCH1]CODHYP(0..[M:MCH1]NBLIG-1))
  If NOL : Return : Endif
  nolign = [M:MCH1]NBLIG + 1
  If nolign>dim([M:MCH1]CODHYP)
   OK = 0 : GMESSAGE = mess(26,100,1) #"Tableau plein"
   FIN = 1
   Return
  Endif
