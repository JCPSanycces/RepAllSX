  If [M:MCH1]TYPHYP(I)=9
   Call LECTURE ("MHT",[M:MCH1]CODHYP(I),"") From CONTOBJ
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
