Subprog AS_DISCRGPRO(VALEUR)
Variable Integer  VALEUR
If [F:PRS]CLCRUL(nolign-1)=3 & [M:SPC0]PLITYP<>2 : VALEUR=2 : mkstat=3 : Endif
End

######################################################################
# Traitement de la copie un paramétrage tarif
# TABLE = Clé de l'enregistrement à copier
#         (si la cle est numerique val(TABLE)
######################################################################
$TRTCOP
If [M]DOSORG=nomap
  Local File SPRICCONF [SPC1]
  Local File ATEXTRA   [AXX1]
Else
  Local File =[M]DOSORG+".SPRICCONF" [SPC1]
  Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
  Local File SPRICCONF [SPC2]
  Local File ATEXTRA   [AXX2]
Else
  Local File =[M]DOSDES+".SPRICCONF" [SPC2]
  Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif
Look [SPC2] SPC0=TABLE
If !fstat
   OK= 1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   # Issue X3-46673 - 2017-09-14 by SR : Fermer les classes
   #If OK=1 : Return : Endif
   If OK=1 : Gosub CLOSE_TABLES : Return : Endif
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Gosub CLOSE_TABLES           # FGR 20/03/2015 : X3SUIVI107108
Return

#---------------------------------------------------------------------
$CLOSE_TABLES
  # FGR 20/03/2015 : X3SUIVI107108
  Close Local File [SPC1]
  Close Local File [SPC2]
  Close Local File [AXX1]
  Close Local File [AXX2]
Return

#---------------------------------------------------------------------
$TR_COP

GOK=1
Trbegin [SPC2]
  Delete [SPC2] Where PLI=TABLE
  If fstat=1  GOK=-1 : GLOCK="$"+[M]DOSDES+".SPRICCONF"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("SPC2",TABLE) From GLOCK          : Goto AB_TR_COP
  Endif
  Read [SPC1] SPC0=TABLE
  If !fstat
    [F:SPC2]=[F:SPC1]

    Call COPTEXTRA("SPRICCONF","DESAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif

    Write [SPC2]
    If fstat GOK=0 : Call FSTA("SPC2") From GLOCK : Goto AB_TR_COP : Endif
  Endif
Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation tarifs depuis génération des patchs
Call GENDOS(APPLI) From FUNSPCVAL

End

##########################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer TOK
Local File =APPLI+".AWINDOW" [AWI] : # Déjà ouvert en local, le réouvrir !
If clalev ([F:AMK])<=0 : Local File =APPLI+".AMSK" [AMK] : Endif
Raz TOK
Raz TOK
If dim(GVALTRANS)>5 & GVALTRANS(5)=2
  TOK=1
Else
    Read [AWI] AWI0="B1" : If fstat Raz [F:AWI] : Endif
    If [F:AWI]UPDFLG=1
      TOK=1
    Else
      Read [AWI] AWI0="B2" : If fstat Raz [F:AWI] : Endif
      If [F:AWI]UPDFLG=1
        TOK=1
      Else
        Read [AMK] CODMSK="SPLV" : If fstat Raz [F:AMK] : Endif
        If [F:AMK]UPDFLG=1
          TOK=1
        Else
          Read [AMK] CODMSK="SPLW" : If fstat Raz[F:AMK] : Endif
          If [F:AMK]UPDFLG=1
            TOK=1
          Endif
        Endif
      Endif
    Endif
Endif
Close Local File [AWI]
If TOK=1  Call GENDOS(APPLI) From FUNSPCVAL : Endif
End
##########################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SPC0) 02/05/2006 16:36:15 (JL)
######################################################################################
Subprog C_PLICPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If clalev ([F:CPY])<=0 : Local File COMPANY [CPY] : Endif
   Read [CPY]CPY0=VALEUR
   If fstat : mkstat=2 : Endif
   If [F:CPY]CPYLEGFLG<>2
      GMESSAGE=mess(130,121,1) : GERR=1 : mkstat=2 : # Societe non juridique
   Endif
   If [F:CPY]PLISTC<>[M]PLISTC
      GMESSAGE=mess(141,199,1) : GERR=1 : mkstat=2 : # La structure tarif n est pas identique
   Endif
Endif
End

