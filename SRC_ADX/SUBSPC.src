##################### SUBPROG dans SPC3 #################################
#########################################################################
Subprog AS_NBREM
[M:SPC3]NBREM=GNBREM
For nolign=1 To [M:SPC3]NBREM
  [M:SPC3]COLDES(nolign-1)=GLIBDES(nolign-1)
  If [F:PRS]CLCRUL(nolign-1)=3 & [M:SPC0]PLITYP<>2 : [M:SPC3]DISCRGPRO(nolign-1)=2 : Endif
  If [M:SPC3]DISCRGPRO(nolign-1)=0 : [M:SPC3]DISCRGPRO(nolign-1)=1 : Endif
Next nolign
End

