#<AdxTL>@(#)11.0.0.0 $Revision$
########################################################################
# SUBSPC : Gestion du paramétrage tarifs VENTES                JLS     #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:SPC]SPRICCONF                                #
########################################################################
Call OBJET("SPC",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INICRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "APRES_CRE"    : Gosub GEN_ECR
                       Default File [SPC]
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "APRES_MOD"    : Gosub DEL_ECR
                       Gosub GEN_ECR
                       Default File [SPC]
 When "VERF_ANU"     : Gosub AVANT_MOD
 When "ANNULE"       : Gosub ANNULE
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "FERME"        : Gosub FERME
 When "CHANGE"       : Call CHANGE_AXX ("SPRICCONF", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return
#########################################################################
############################# ACTIONS ###################################
#########################################################################

#------------------------------------------------------------------------
# Chargement des libellés Remises/Frais
#------------------------------------------------------------------------
$OUVRE

Local  Char    APPLI    : # nom du dossier (pour generer ecrans et traitements)
APPLI=nomap

Global Char    JGFICFIC (30) (0..10)
Global Integer JGNBFIC

GNBREM=0

Local  Integer I
Local  Integer DESTARIFS
Local  Integer I_MOD
Local  Integer ACVOPEN, NBRCOLONNE

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : ACVOPEN=1 : Endif
If clalev([F:SNE])=0 : Local File SINCENT [SNE] : Endif
If clalev([F:SND])=0 : Local File SINCDET [SND] : Endif

#Global Integer GACTMUL : GACTMUL=1
#Read [ACV] CODACT="MUL" : If fstat  Raz [F:ACV] : Endif
#If [F:ACV]FLACT=2 GACTMUL=2 Endif

Read [ACV]CODACT="SPR"
NBRCOLONNE=[F:ACV]DIME
If fstat : NBRCOLONNE=0 : Endif
If ACVOPEN=1 : Close Local File [ACV] : Endif

Raz GLIBDES
#If GACTMUL=1
#    Global Char    STRUCTURE (10) : STRUCTURE=""
#    If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
#    Read [F:PRS]PRS0=1;STRUCTURE
#    If fstat : Return : Endif
#    For I=0 To NBRCOLONNE-1
#      If [F:PRS]INCDCR(I)=0 : Break : Endif
#      Call LECTEXTRA (GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")","1",[F:PRS]PLISTC) From ATEXTRA
#    Next I
#    GNBREM=I
#    If dim([M:SPC3]NBREM)>0
#      If I>dim([M:SPC3]DISCRGPRO) : GNBREM=dim([M:SPC3]DISCRGPRO) : Endif
#    Else I=0 : GNBREM=0
#    Endif
#Endif

Raz JGNBFIC
Raz JGFICFIC
Local  Integer NOL
# --- préparation du tableau des tables accessibles
#     ( si modif tableau : modifier tables à ouvrir de objet SPL )
JGFICFIC(NOL)="ITMMASTER"  : NOL +=1 : # Articles
JGFICFIC(NOL)="ITMSALES"   : NOL +=1 : # Articles - ventes
JGFICFIC(NOL)="ITMFACILIT" : NOL +=1 : # Articles - sites
JGFICFIC(NOL)="BPARTNER"   : NOL +=1 : # Business Partner
JGFICFIC(NOL)="BPCUSTOMER" : NOL +=1 : # Clients
JGFICFIC(NOL)="BPCUSTMVT"  : NOL +=1 : # Mouvements clients (site financier)
JGFICFIC(NOL)="BPDLVCUST"  : NOL +=1 : # Clients livrés
JGFICFIC(NOL)="SALESREP"   : NOL +=1 : # Représentants
JGFICFIC(NOL)="SPRICLINK"  : NOL +=1 : # Rech tarif (Link)
JGNBFIC=NOL

Return

#------------------------------------------------------------------------
# Désactivation des boutons "Validation" et "Copie"
#------------------------------------------------------------------------
$SETBOUT

#--- si acces par tunnel : Cré / Mod / Sup / Dupli interdits
If GFONC1<>"GESSPC" : Call VIREBOUT(CHAINE,"CMAD") From GOBJET : Endif

#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET
#--- désactivation bouton "Validation et Copie"
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#------------------------------------------------------------------------
# Après appui sur bouton "Validation" ou "Copie"
#------------------------------------------------------------------------
$EXEBOUT
Case BOUT
  When "1" : Gosub DEL_ECR
             Gosub GEN_ECR
             Default File [SPC]
  When Default
Endcase
Return

#------------------------------------------------------------------------
# Activation / Desactivation zones (Grizo/Actzo)
#------------------------------------------------------------------------
$APRES_MODIF
Case COUZON
 When "PLITYP"       : Gosub G_PLITYP
 When "PRIPRO"       : Gosub G_PRIPRO
 When "FOCPRO"       : Gosub G_FOCPRO
 When Default
Endcase
Return

$G_PLITYP
If val(CZ)=1 : Gosub G_PLITYP1 : Endif   : # si tarif normal
If val(CZ)=2 : Gosub G_PLITYP2 : Endif   : # si tarif groupe
If val(CZ)=3 : Gosub G_PLITYP3 : Endif   : # si tarif interdit
If val(CZ)=4 : Gosub G_PLITYP4 : Endif   : # si tarif composant
Affzo [M:SPC2]PRIPRO, PRIFLD, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG,
&     FOCPRO, FOCTYP, COMPRO, UPDNULPRI
If dim([M:SPC3]NBREM)>0 : Affzo [M:SPC3]DISCRGPRO : Endif
Return

#           si Tarif Normal
$G_PLITYP1
Actzo [M:SPC0]PLISEA
If [M:SPC2]PRIPRO<1    : [M:SPC2]PRIPRO=2    : Raz [M:SPC2]PRIFLD   : Endif
If [M:SPC2]PRITYP<1    : [M:SPC2]PRITYP=1    : Endif
If [M:SPC2]PRIQTYFLG<1 : [M:SPC2]PRIQTYFLG=2 : Endif
If [M:SPC2]ATICNVFLG<1 : [M:SPC2]ATICNVFLG=1 : Endif
If [M:SPC2]UOMCNVFLG<1 : [M:SPC2]UOMCNVFLG=1 : Endif
If [M:SPC2]CURCNVFLG<1 : [M:SPC2]CURCNVFLG=1 : Endif
If [M:SPC2]FOCPRO<1    : [M:SPC2]FOCPRO=1    : Raz FOCTYP   : Endif
If [M:SPC2]COMPRO<1    : [M:SPC2]COMPRO=2    : Endif
For I=0 To GNBREM-1
  If [M:SPC3]DISCRGPRO(I)=0 : [M:SPC3]DISCRGPRO(I)=2 : Endif
Next I
Actzo [M:SPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG,
&     FOCPRO, COMPRO
If dim([M:SPC3]NBREM)>0 : Actzo [M:SPC3]DISCRGPRO : Endif
If [M:SPC2]PRITYP<4  Grizo [M:SPC2]PRIFLD
  Else               Actzo [M:SPC2]PRIFLD
Endif
If [M:SPC2]FOCPRO=1  Grizo [M:SPC2]FOCTYP
  Else               Actzo [M:SPC2]FOCTYP
Endif
Raz [M:SPC2]UPDNULPRI : Grizo [M:SPC2]UPDNULPRI
Return

#           si Tarif Groupé
$G_PLITYP2
Raz [M:SPC0]PLISEA
Grizo [M:SPC0]PLISEA
If [M:SPC2]PRIPRO<1    : [M:SPC2]PRIPRO=2    : Raz [M:SPC2]PRIFLD   : Endif
If [M:SPC2]PRITYP<1    : [M:SPC2]PRITYP=1    : Endif
If [M:SPC2]PRIQTYFLG<1 : [M:SPC2]PRIQTYFLG=2 : Endif
If [M:SPC2]ATICNVFLG<1 : [M:SPC2]ATICNVFLG=1 : Endif
If [M:SPC2]UOMCNVFLG<1 : [M:SPC2]UOMCNVFLG=1 : Endif
If [M:SPC2]CURCNVFLG<1 : [M:SPC2]CURCNVFLG=1 : Endif
If [M:SPC2]FOCPRO<1    : [M:SPC2]FOCPRO=1    : Raz [M:SPC2]FOCTYP   : Endif
Raz [M:SPC2]COMPRO
For I=0 To GNBREM-1
  If [M:SPC3]DISCRGPRO(I)=0 : [M:SPC3]DISCRGPRO(I)=2 : Endif
Next I
Actzo [M:SPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG, FOCPRO
If dim([M:SPC3]NBREM)>0 : Actzo [M:SPC3]DISCRGPRO : Endif
If [M:SPC2]PRITYP<4  Grizo [M:SPC2]PRIFLD
  Else               Actzo [M:SPC2]PRIFLD
Endif
If [M:SPC2]FOCPRO=1  Grizo [M:SPC2]FOCTYP
  Else               Actzo [M:SPC2]FOCTYP
Grizo [M:SPC2]COMPRO
Endif
Actzo [M:SPC2]UPDNULPRI
Return

#           si Tarif Interdit
$G_PLITYP3
Raz [M:SPC0]PLISEA
Grizo [M:SPC0]PLISEA
Raz [M:SPC2]PRIPRO, [M:SPC2]PRIFLD, [M:SPC2]PRITYP, [M:SPC2]PRIQTYFLG, [M:SPC2]CUR, [M:SPC2]ATICNVFLG,
&   [M:SPC2]UOMCNVFLG, [M:SPC2]CURCNVFLG, [M:SPC2]FOCPRO, [M:SPC2]FOCTYP, [M:SPC2]COMPRO, [M:SPC2]UPDNULPRI
If dim([M:SPC3]NBREM)>0 : Raz [M:SPC3]DISCRGPRO : Endif
Grizo [M:SPC2]PRIPRO, PRIFLD, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG,
&     FOCPRO, FOCTYP, COMPRO, UPDNULPRI
If dim([M:SPC3]NBREM)>0 : Grizo [M:SPC3] : Endif
Return

#           si Tarif Composant
$G_PLITYP4
Actzo [M:SPC0]PLISEA
If [M:SPC2]PRIPRO<1    : [M:SPC2]PRIPRO=2    : Raz [M:SPC2]PRIFLD   : Endif
If [M:SPC2]PRITYP<1    : [M:SPC2]PRITYP=1    : Endif
If [M:SPC2]PRIQTYFLG<1 : [M:SPC2]PRIQTYFLG=2 : Endif
If [M:SPC2]ATICNVFLG<1 : [M:SPC2]ATICNVFLG=1 : Endif
If [M:SPC2]UOMCNVFLG<1 : [M:SPC2]UOMCNVFLG=1 : Endif
If [M:SPC2]CURCNVFLG<1 : [M:SPC2]CURCNVFLG=1 : Endif
Raz [M:SPC2]FOCPRO, [M:SPC2]FOCTYP
If [M:SPC2]COMPRO<1    : [M:SPC2]COMPRO=2    : Endif
For I=0 To GNBREM-1
  If [M:SPC3]DISCRGPRO(I)=0 : [M:SPC3]DISCRGPRO(I)=2 : Endif
Next I
Actzo [M:SPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG, COMPRO
If dim([M:SPC3]NBREM)>0 : Actzo [M:SPC3]DISCRGPRO : Endif
Grizo [M:SPC2]FOCPRO, FOCTYP
If [M:SPC2]PRITYP<4  Grizo [M:SPC2]PRIFLD
  Else               Actzo [M:SPC2]PRIFLD
Endif
Raz [M:SPC2]UPDNULPRI : Grizo [M:SPC2]UPDNULPRI
Return

$G_PRIPRO
Actzo [M:SPC2]PRITYP, PRIFLD, CUR, ATICNVFLG, UPDNULPRI
If val(CZ) = 0
  Raz   [M:SPC2]PRITYP, [M:SPC2]PRIFLD, [M:SPC2]CUR, [M:SPC2]ATICNVFLG, [M:SPC2]UPDNULPRI
  Grizo [M:SPC2]PRITYP, PRIFLD, CUR, ATICNVFLG, UPDNULPRI
Else
  If [M:SPC2]PRITYP=0    : [M:SPC2]PRITYP=1    : Endif
  If [M:SPC2]ATICNVFLG=0 : [M:SPC2]ATICNVFLG=1 : Endif
Endif
If val(CZ) = 1 or val(CZ) = 2 or val(CZ) = 3
  Raz [M:SPC2]PRIFLD
  Grizo [M:SPC2]PRIFLD
Endif
If val(CZ) = 1
  Raz [M:SPC2]UPDNULPRI
  Grizo [M:SPC2]UPDNULPRI
Endif

Affzo [M:SPC2]PRITYP, PRIFLD, CUR, ATICNVFLG, UPDNULPRI
Return

$G_FOCPRO
Actzo [M:SPC2]FOCTYP
If val(CZ) < 2
    Raz [M:SPC2]FOCTYP
    Grizo [M:SPC2]FOCTYP
  Else
    If [M:SPC2]FOCTYP=0 : [M:SPC2]FOCTYP=1 : Endif
    Actzo [M:SPC2]FOCTYP
Endif
Affzo [M:SPC2]FOCTYP
Return

#------------------------------------------------------------------------
# Chargement de BASTAB (nbre critères) et NBREM (nbre colonnes frais/rem)
#------------------------------------------------------------------------
$LIENS

#If GACTMUL=2
If !clalev ([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
Raz GLIBDES
Read [PRS] PRS0=1;[M:SPC0]PLISTC
If fstat : Return : Endif

For I=0 To dim([F:PRS]INCDCR)-1
    If [F:PRS]INCDCR(I)=0 : Break : Endif
    Call LECTEXTRA(GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")",
&                  "1",[F:PRS]PLISTC) From ATEXTRA
Next I
GNBREM=I
If dim([M:SPC3]NBREM)>0
    If I>dim([M:SPC3]DISCRGPRO)  GNBREM=dim([M:SPC3]DISCRGPRO) : Endif
Else
    I=0 : GNBREM=0
Endif
Actzo [M:SPC0]PLISTC
#Else
#    Grizo [M:SPC0]PLISTC
#Endif

If find([M:SPC0]PLITYP,3,4) : Grizo [M:SPC0]PLIBPRCNR
   Else                       Actzo [M:SPC0]PLIBPRCNR
Endif
For RG = 1 To 5
  If [M:SPC1]FIL(RG-1)="" : Break : Endif
  [M:SPC1]BASTAB +=1
  Call CHARCRIDES([M]FIL(RG-1),[M]FLD(RG-1),[M]CRIDES(RG-1)) From TRTPARAM
Next RG
If dim([M:SPC3]NBREM)>0 : [M:SPC3]NBREM=GNBREM : Endif
For RG = 1 To GNBREM
  [M:SPC3]COLDES(RG-1)=GLIBDES(RG-1)
Next RG

# Grizo
Actzo [M:SPC0]PLISEA
Actzo [M:SPC2]
If dim([M:SPC3]NBREM)>0 : Actzo [M:SPC3] : Endif
If [M:SPC0]PLITYP=2
    Grizo [M:SPC0]PLISEA : Grizo [M:SPC2]COMPRO
Else
    Grizo [M:SPC2]UPDNULPRI
Endif
If [M:SPC0]PLITYP=3
  Grizo [M:SPC0]PLISEA : Grizo [M:SPC2]
  If dim([M:SPC3]NBREM)>0 : Grizo [M:SPC3] : Endif
Endif
If [M:SPC0]PLITYP=4 : Grizo [M:SPC2]FOCPRO, FOCTYP : Endif
If [M:SPC2]PRIPRO<2 : Grizo [M:SPC2]PRIFLD : Endif
If [M:SPC2]PRIPRO=2 or [M:SPC2]PRIPRO=3 : Grizo [M:SPC2]PRIFLD : Endif
If [M:SPC2]FOCPRO<2 : Grizo [M:SPC2]FOCTYP : Endif
#Grizo [M:SPC0]PLISTC
#Affzo [M:SPC0]PLISTC

Affzo [M:SPC2]1-99
If dim([M:SPC3]NBREM)>0 : Affzo [M:SPC3]1-99 : Endif

Return

#------------------------------------------------------------------------
# Chargement de BASTAB (nbre critères) et NBREM (nbre colonnes frais/rem)
#------------------------------------------------------------------------
$RAZCRE
For RG = 1 To 5
  If [M:SPC1]FIL(RG-1)="" : Break : Endif
  [M:SPC1]BASTAB +=1
Next RG

[M:SPC2]PRIPRO=2 : [M:SPC2]PRITYP=1 : [M:SPC2]PRIQTYFLG=2 : [M:SPC2]ATICNVFLG=1
[M:SPC2]UOMCNVFLG=1 : [M:SPC2]CURCNVFLG=1 : [M:SPC2]FOCPRO=1 : [M:SPC2]FOCTYP=0 : [M:SPC2]COMPRO=2

#If GACTMUL=2
#----- Chargement intitulés lignes tableau frais/remises pour structure par défaut -----#
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
If dim([M:SPC3]NBREM)>0  Raz [M:SPC3]NBREM     : Endif
If dim([M:SPC3]NBREM)>0  Raz [M:SPC3]DISCRGPRO : Endif
Raz GLIBDES
Read [PRS] PRS0=1;"" : If fstat  Raz [F:PRS] : Endif
For RG=0 To dim([F:PRS]INCDCR)-1
    If [F:PRS]INCDCR(RG)=0 : Break : Endif
    Call LECTEXTRA(GLIBDES(RG),"PRICSTRUCT","DESAXX("+num$(RG)+")","1",[F:PRS]PLISTC) From ATEXTRA
Next RG
If RG>dim([M:SPC3]DISCRGPRO)
    GNBREM=dim([M:SPC3]DISCRGPRO)
Else
    GNBREM=RG
Endif
Actzo[M:SPC0]PLISTC
#Else
#    Grizo [M:SPC0]PLISTC
#Endif

If dim([M:SPC3]NBREM)>0 : [M:SPC3]NBREM=GNBREM : Raz [M:SPC3]DISCRGPRO : Endif
For RG = 1 To GNBREM
  [M:SPC3]COLDES(RG-1)=GLIBDES(RG-1)
  [M:SPC3]DISCRGPRO(RG-1)=2
Next RG

#Grizo [M:SPC0]PLISTC
#Affzo [M:SPC0]PLISTC

Actzo [M:SPC2] : Affzo [M:SPC2]1-99
If dim([M:SPC3]NBREM)>0: Actzo [M:SPC3] : Affzo [M:SPC3]1-99 : Endif
Return

#------------------------------------------------------------------------
# Chargement des champs annexes
#------------------------------------------------------------------------
$INICRE
Local Char CRIITM_A (5), CRIBPR_A(5)
Raz [F:SPC]CRIITM,[F:SPC]CRIBPR

#   les champs de la table ITMBPC sont des critères articles et clients
For I=0 To dim([F:SPC]FIL)-1
    If find([F:SPC]FIL(I),"ITMMASTER","ITMSALES","ITMBPC")
       CRIITM_A += num$(I+1)
    Endif
    If find([F:SPC]FIL(I),"BPARTNER","BPCUSTOMER","BPCUSTMVT","BPDLVCUST","ITMBPC")
       CRIBPR_A += num$(I+1)
    Endif
Next I
[F:SPC]CRIITM=val(CRIITM_A) : [F:SPC]CRIBPR=val(CRIBPR_A)

For I=GNBREM To 8
  Assign "[F:SPC]DISCRGPRO("+num$(I)+")" With 0
Next I

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:SPC0]DESAXX,"SPRICCONF","DESAXX",[M:SPC0]PLI,"") From ATEXTRA

#    SOS libellés
If dim([F:SPC]LANDESSHO)>0
   [F:SPC]LANDESSHO=GLANGUE+"~"+[M:SPC0]DESAXX
Endif

Return

#------------------------------------------------------------------------
# Controle avant modif : si tarifs déjà créés avec ce paramétrage
#------------------------------------------------------------------------
$AVANT_MOD
DESTARIFS=1
OK=1
Filter [F:SPL] Where PLI=[M:SPC0]PLI
Read [F:SPL]SPL0 First
If fstat : Return : Endif
DESTARIFS=2
Call OUINON(mess(55,199,1),OK) From GESECRAN
# ce tarif contient des lignes. Voulez-vous continuer ?
If OK<>2 : OK=0 : Endif

Return

#------------------------------------------------------------------------
# Pour mise a jour des zones initialisées pour un autre masque
#------------------------------------------------------------------------
$AVANT_MODFIC
[F:SPC]=[M:SPC2]
Return

#------------------------------------------------------------------------
# Suppression d'un parametrage
#------------------------------------------------------------------------
$ANNULE
I_MOD=4  : # pour eviter les tests
Gosub DEL_ECR
Delete [AXX]Where CODFIC="SPRICCONF" & IDENT1=[F:SPC]PLI
Return

#------------------------------------------------------------------------
# Vérification au moins un critère
#------------------------------------------------------------------------
$VERIF_CRE
If [M:SPC1]ABB(0)= ""
  GERR=1
  GMESSAGE=mess(183,199,1)
# aucun critère dans ce paramétrage
  OK = 0
Endif
Return

#------------------------------------------------------------------------
# Vérification qu'une modification a bien été effectuée
#------------------------------------------------------------------------
$VERIF_MOD
If [M:SPC1]ABB(0) = ""
  GERR=1
  GMESSAGE=mess(183,199,1)
# aucun critère dans ce paramétrage
  OK = 0
  Return
Endif
I_MOD=0
# --- champs masques 0 et 1
If [M:SPC0]PLISTC<>[F:SPC]PLISTC : I_MOD=1 : Return : Endif
If [M:SPC0]PLITYP<>[F:SPC]PLITYP : I_MOD=1 : Return : Endif
For I=0 To 4
  If [M:SPC1]ABB(I)<>[F:SPC]ABB(I)       : I_MOD=1 : Break : Endif
  If [M:SPC1]CRIDIE(I)<>[F:SPC]CRIDIE(I) : I_MOD=1 : Break : Endif
  If [M:SPC1]CRIIND(I)<>[F:SPC]CRIIND(I) : I_MOD=1 : Break : Endif
  If [M:SPC1]CRIDES(I)<>[F:SPC]CRIDES(I) : I_MOD=1 : Break : Endif
  If [M:SPC1]FLD(I)<>[F:SPC]FLD(I)       : I_MOD=1 : Break : Endif
  If [M:SPC1]FIL(I)<>[F:SPC]FIL(I)       : I_MOD=1 : Break : Endif
  If [M:SPC1]PPUMNU(I)<>[F:SPC]PPUMNU(I) : I_MOD=1 : Break : Endif
Next I
If I_MOD<>0 : Return : Endif
# --- champs masque 2
If [M:SPC2]PRIPRO<>[F:SPC]PRIPRO : I_MOD=2 : Return : Endif
If [M:SPC2]PRIFLD<>[F:SPC]PRIFLD : I_MOD=2 : Return : Endif
If [M:SPC2]PRITYP<>[F:SPC]PRITYP : I_MOD=2 : Return : Endif
If [M:SPC2]PRIQTYFLG<>[F:SPC]PRIQTYFLG : I_MOD=2 : Return : Endif
If [M:SPC2]CUR<>[F:SPC]CUR : I_MOD=2 : Return : Endif
If [M:SPC2]ATICNVFLG<>[F:SPC]ATICNVFLG : I_MOD=2 : Return : Endif
If [M:SPC2]UOMCNVFLG<>[F:SPC]UOMCNVFLG : I_MOD=2 : Return : Endif
If [M:SPC2]FOCPRO<>[F:SPC]FOCPRO : I_MOD=2 : Return : Endif
If [M:SPC2]FOCTYP<>[F:SPC]FOCTYP : I_MOD=2 : Return : Endif
If [M:SPC2]COMPRO<>[F:SPC]COMPRO : I_MOD=3 : Return : Endif
# --- champs masque 3
For I=0 To dim([M:SPC3]DISCRGPRO)-1
  If [M:SPC3]DISCRGPRO(I)<>[F:SPC]DISCRGPRO(I) : I_MOD=3 : Break : Endif
Next I
Return

#------------------------------------------------------------------------
# Suppression des globales internes
#------------------------------------------------------------------------
$FERME

If dim(JGFICFIC)>0 : Kill JGFICFIC : Endif
If dim(JGNBFIC)>0  : Kill JGNBFIC  : Endif
Return

#------------------------------------------------------------------------
# Suppression des écrans associés au paramétrage
#------------------------------------------------------------------------
$DEL_ECR
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC (15)
Local Char    TZONE (GLONAVA) (200)
Local Integer TMOD (200)
Local Char    TINT (35) (200)
Local Char    TTAB (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Char    TFLD (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer OPT1,OPT2,OPT3,RETOUR
Local Integer IBLO,IZON
# Sup. des enr. fiches et tarifs par liens suppression des tables
#   question si modif. du paramétrage
#   pas de question si revalidation des paramétrages (FUNSPCVAL)
If I_MOD=1 & DESTARIFS=2 : # modif. critères
  OK = 2
#  Call OUINON("Modif type, critères : Sup. des lignes?", OK) From GESECRAN
#              Des éléments majeurs du paramétrage sont modifiés
#              (type de tarif, critères de recherche)
#              Il est conseillé de supprimer les lignes tarif déjà saisies
#              Voulez-vous supprimer les lignes tarifs ?
  Call OUINON(mess(160,199,1)+"\"+mess(161,199,1)+"\"+mess(162,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif
If I_MOD=2 & DESTARIFS=2 : # modif. attribution prix, conversion, gratuits
  OK = 2
#  Call OUINON("Modif prix, conditions : Sup. des lignes?", OK) From GESECRAN
#              La modification du paramétrage
#              (attribution du prix, conditions de conversion, traitement des gratuits
#              nécessite la suppression des lignes tarif ou tout au moins un contrôle détaillé
#              Voulez-vous supprimer les lignes tarifs ?
  Call OUINON(mess(165,199,1)+"\"+mess(166,199,1)+"\"+mess(168,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif
If I_MOD=3 & DESTARIFS=2 : # modif. remises/frais, coef. com.
  OK = 1
#  Call OUINON("Modif frais-remises : Sup. des lignes?", OK) From GESECRAN
#              La modification des colonnes frais/remises, coef. commission
#              nécessite la vérification des lignes tarif déjà saisies
#              Voulez-vous supprimer les lignes tarifs ?
  Call OUINON(mess(170,199,1)+"\"+mess(171,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif

If I_MOD<>0
  Delete [F:SPF] Where PLI=[M:SPC0]PLI
  If fstat=1 : GOK=-1 : GLOCK="$SPRICFICH"-[M:SPC0]PLI : Return : Endif
  Delete [F:SPL] Where PLI=[M:SPC0]PLI
  If fstat=1 : GOK=-1 : GLOCK="$SPRICLIST"-[M:SPC0]PLI : Return : Endif
Endif

# Suppression des ecran
For I=1 To 3
  Raz MFROM,MTO,TBLOC,TZONE,TMOD,OPT2,OPT3
  MTO="WB"+num$(I)+num$([M:SPC0]PLI)+"1"
  OPT1=9
  Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
  If RETOUR<>0 : GOK=0 : Endif
Next I

## Suppression des traitements générés
#Local Char    NOMTRT(GDIMFIC), FICTRT(GDIMFIC), EXT(4)
#Local Integer STAT
#NOMTRT="WBT"+num$([M:SPC0]PLI)
#For EXT = "adx", "src"
#  FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#  While filinfo(FICTRT,0)>=0
#    Call EFFACE(FICTRT,STAT) From ORDSYS
#    FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#  Wend
#Next EXT

## Suppression des traitements générés
Local Char    NOMTRT(GDIMFIC), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT

NOMTRT="WBT"+num$([M:SPC0]PLI)
# Suppression "src"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
# Suppression "adx"
Call EXISTE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
If STAT = 1
     Call EFFACE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
Endif

#--CPO 93062 Price search in mobility
NOMTRT="WBT"+num$([M:SPC0]PLI)+"_SY"
# Suppression "src"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
# Suppression "adx"
Call EXISTE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
If STAT = 1
     Call EFFACE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
Endif
#--/

# Suppression des fenetres
Gosub DEL_FEN
If GOK<>1 : Return : Endif
# Suppression des paramétrages augmentation sur ce code tarif
If I_MOD<>0 : Gosub DEL_INC : Endif

Return

#------------------------------------------------------------------------
# Génération des écrans associés au paramétrage
#------------------------------------------------------------------------
$GEN_ECR
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC (15)
Local Char    TZONE (GLONAVA) (200)
Local Integer TMOD (200)
Local Char    TINT (35) (200)
Local Char    TTAB (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Char    TFLD (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer OPT1,OPT2,OPT3,RETOUR
Local Integer IBLO,IZON
Local Integer ITZ
Local Integer ZZ (35)
Local Char    ZCHAMP (10) (0..35)
# --- Garnissage des zones communes aux 3 écrans
MFROM="SPLW"
ZCHAMP(0)="CRIT"       :ZCHAMP(1)="LIBCRIT"    :ZCHAMP(2)="CRIT1"
ZCHAMP(3)="CRIT2"      :ZCHAMP(4)="CRIT3"      :ZCHAMP(5)="CRIT4"
ZCHAMP(6)="CRIT5"      :ZCHAMP(7)="CUR"        :ZCHAMP(8)="UOM"
ZCHAMP(9)="MINQTY"     :ZCHAMP(10)="MAXQTY"    :ZCHAMP(11)="LTI"
ZCHAMP(12)="PRIDIV"    :ZCHAMP(13)="PRI"       :ZCHAMP(14)="XFRAREM1"
ZCHAMP(15)="XFRAREM2"  :ZCHAMP(16)="XFRAREM3"  :ZCHAMP(17)="XFRAREM4"
ZCHAMP(18)="XFRAREM5"  :ZCHAMP(19)="XFRAREM6"  :ZCHAMP(20)="XFRAREM7"
ZCHAMP(21)="XFRAREM8"  :ZCHAMP(22)="XFRAREM9"  :ZCHAMP(23)="FOCQTYMIN"
#ZCHAMP(24)="FOCBKT"    :ZCHAMP(25)="FOCITMREF" :ZCHAMP(26)="FOCUOM"
ZCHAMP(25)="FOCITMREF" :ZCHAMP(26)="FOCUOM"
ZCHAMP(27)="FOCQTY"    :ZCHAMP(28)="COMCOE"    :ZCHAMP(29)="MINAMT"
ZCHAMP(30)="MAXAMT"
ZCHAMP(31)="FOCAMTMIN" :ZCHAMP(32)="FOCQTYBKT" :ZCHAMP(33)="FOCAMTBKT"
Raz TBLOC,TZONE,TTAB,TFLD,TMOD,TINT,ZZ
# ---------- Garnissage table décision de m.a.j. des rubriques
#            ( uniquement les rubriques hors critères )

# --- Tarif Normal ---
If [F:SPC]PLITYP=1
  If [F:SPC]PLIBPRCNR=2                 : # tarif groupe
     ZZ(11)=1
  Endif
  If [F:SPC]PRIPRO=2                    : # prix = valeur
     ZZ(7)=1 : ZZ(8)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=3                    : # prix = valeur pour N
     ZZ(7)=1 : ZZ(8)=1 : ZZ(12)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=4                    : # prix = coefficient
     ZZ(8)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=5                    : # prix = calcul
#     ZZ(8)=1 : ZZ(13)=1
     ZZ(8)=1
  Endif
  If [F:SPC]PRIQTYFLG=2                 : # tarif par qte = oui
     ZZ(8)=1 : ZZ(9)=1 : ZZ(10)=1
  Endif
  If [F:SPC]UOMCNVFLG=2                 : # conversion unite = oui
     ZZ(8)=1
  Endif
  If [F:SPC]CURCNVFLG=2                 : # conversion devise = oui
     ZZ(7)=1
  Endif
  If [F:SPC]FOCPRO=2                    : # gratuite = N pour M
#     ZZ(26)=1 : ZZ(27)=1
     # LD 23/07/08 : Tests CH:L'UV du gratuit ne doit pas apparaître ds l'écran (non alimentée et non saisissable)
     ZZ(27)=1
  Endif
  If [F:SPC]FOCPRO=3                    : # gratuite = autre article
     ZZ(25)=1 : ZZ(26)=1 : ZZ(27)=1
  Endif
  If [F:SPC]FOCPRO>1 & [F:SPC]FOCTYP=1  : # type gratuite = seuil
     ZZ(23)=1
  Endif
  If [F:SPC]FOCPRO>1 & [F:SPC]FOCTYP=2  : # type gratuite = multiple
     ZZ(23)=1 : ZZ(32)=1
  Endif
  For I=0 To GNBREM-1               : # les frais / remises
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : # application = oui et type = %
       ZZ(14+I)=2
    Endif
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1  : # application = oui et type = montant
       ZZ(7)=1 : ZZ(14+I)=1
      If [F:PRS]CLCRUL(I)=1 :                  : # base de calcul = par unité
        ZZ(8)=1
      Endif
    Endif
  Next I
  If [F:SPC]COMPRO=1                    : # coef. commission = oui
     ZZ(28)=1
  Endif
Endif

# --- Tarif Groupé ---
If [F:SPC]PLITYP=2
  If [F:SPC]PRIPRO=2                    : # prix = valeur
     ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=3                    : # prix = valeur pour N
     ZZ(12)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=4                    : # prix = coefficient
     ZZ(13)=1
  Endif
  If [F:SPC]PRIQTYFLG=3                 : # tarif par qte = tranches qte
     ZZ(8)=1 : ZZ(9)=1 : ZZ(10)=1
  Endif
  If [F:SPC]PRIQTYFLG=4                 : # tarif par qte = tranches prix bruts
     ZZ(7)=1 : ZZ(29)=1 : ZZ(30)=1
  Endif
  If [F:SPC]PRIQTYFLG=5                 : # tarif par qte = tranches prix nets
     ZZ(7)=1 : ZZ(29)=1 : ZZ(30)=1
  Endif
  If [F:SPC]UOMCNVFLG=2                 : # conversion unite = oui
     ZZ(8)=1
  Endif
  If [F:SPC]CURCNVFLG=2                 : # conversion devise = oui
     ZZ(7)=1
  Endif
  If [F:SPC]FOCPRO=3                    : # gratuite = autre article
     ZZ(9)=1 : ZZ(10)=1
  Endif
  If [F:SPC]FOCPRO=4                    : # gratuite = total commande
     ZZ(25)=1 : ZZ(26)=1 : ZZ(27)=1
  Endif
  If [F:SPC]FOCPRO>1 & [F:SPC]FOCTYP=1    : # type gratuite = seuil
     If [F:SPC]PRIQTYFLG=3                : # tranches qtes
        ZZ(23)=1
     Endif
     If find([F:SPC]PRIQTYFLG,4,5)        : # tranches montants (prix bruts ou nets)
        ZZ(31)=1
     Endif
  Endif
  If [F:SPC]FOCPRO>1 & [F:SPC]FOCTYP=2    : # type gratuite = multiple
     If [F:SPC]PRIQTYFLG=3                : # tranches qtes
        ZZ(23)=1 : ZZ(32)=1
     Endif
     If find([F:SPC]PRIQTYFLG,4,5)        : # tranches montants (prix bruts ou nets)
        ZZ(31)=1 : ZZ(33)=1
     Endif
  Endif
  For I=0 To GNBREM-1               : # les frais / remises
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : # application = oui et type = %
       ZZ(14+I)=2
    Endif
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1  : # application = oui et type = montant
       ZZ(14+I)=1
    Endif
  Next I
Endif

# --- Tarif Interdit ---
If [F:SPC]PLITYP=3
Endif

# --- Tarif Composant ---
If [F:SPC]PLITYP=4
  If [F:SPC]PLIBPRCNR=2                 : # tarif groupe
     ZZ(11)=1
  Endif
  If [F:SPC]PRIPRO=2                    : # prix = valeur
     ZZ(7)=1 : ZZ(8)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=3                    : # prix = valeur pour N
     ZZ(7)=1 : ZZ(8)=1 : ZZ(12)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=4                    : # prix = coefficient
     ZZ(8)=1 : ZZ(13)=1
  Endif
  If [F:SPC]PRIPRO=5                    : # prix = calcul
#     ZZ(8)=1 : ZZ(13)=1
     ZZ(8)=1
  Endif
  If [F:SPC]PRIQTYFLG=2                 : # tarif par qte = oui
     ZZ(8)=1 : ZZ(9)=1 : ZZ(10)=1
  Endif
  If [F:SPC]UOMCNVFLG=2                 : # conversion unite = oui
     ZZ(8)=1
  Endif
  If [F:SPC]CURCNVFLG=2                 : # conversion devise = oui
     ZZ(7)=1
  Endif
  For I=0 To GNBREM-1               : # les frais / remises
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : # application = oui et type = %
       ZZ(14+I)=2
    Endif
    If [F:SPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1  : # application = oui et type = montant
       ZZ(7)=1 : ZZ(14+I)=1
      If [F:PRS]CLCRUL(I)=1 :                  : # base de calcul = par unité
        ZZ(8)=1
      Endif
    Endif
  Next I
  If [F:SPC]COMPRO=1                    : # coef. commission = oui
     ZZ(28)=1
  Endif
Endif
# --- Si Devise / Unité vente dans critères
#     pas de saisie dans autre colonne
If [F:SPC]CRICURNUM<>0 : ZZ(7)=0 : Endif
If [F:SPC]CRICURNUM<>0 | ZZ(7)<>0 SAISIEDEV=1 Else SAISIEDEV=0 Endif
If [F:SPC]CRIUOMNUM<>0 : ZZ(8)=0 : Endif

# ------ Création écrans et traitements
#
Gosub ECR_SAISIE
Gosub ECR_VISU
Gosub GEN_TRT  From SUBSPCT
Gosub GEN_TRT  From SUBSPCT_SYRA :#--CPO 93062 Price search in mobility

Return

#------------------------------------------------------------------------
# --- Ecran de saisie des tarifs
#------------------------------------------------------------------------
$ECR_SAISIE
MFROM="SPLW" : MTO="WB1"+num$([F:SPC]PLI)+"1"
TZONE(0)=ZCHAMP(0) :TMOD(0)=3 : # zones supprimées
TZONE(1)=ZCHAMP(1) :TMOD(1)=3
ITZ=1
For I=0 To 4
  If [F:SPC]FLD(I)=""
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=3
  Else
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=5
             TTAB(ITZ)=[F:SPC]FIL(I) : TFLD(ITZ)=[F:SPC]FLD(I)
    Case [F:SPC]FLDTYP(I)
      When "CCE" : ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
                            TINT(ITZ)="func TRTX3FNC.GETCOLDIE('"+[F:SPC]CRIDIE(I)+"')"
      When "ADI"
           If find([F:SPC]FLDTYPCPL(I),"20","21","22","23","24")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-19)+",206,1)"
           Endif
           If find([F:SPC]FLDTYPCPL(I),"30","31","32","33","34")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-29)+",207,1)"
           Endif
           If find([F:SPC]FLDTYPCPL(I),"40","41","42","43","44")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-39)+",208,1)"
           Endif
      When Default
    Endcase
    If [F:SPC]FLDTYP(I)="ITS" | [F:SPC]FLDTYP(I)="BPC" | [F:SPC]FLDTYP(I)="REP" |
&      [F:SPC]FLDTYP(I)="BPD"
      ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=8
               TINT(ITZ)=[F:SPC]FLDTYP(I)
    Endif
  Endif
Next I
Gosub CHAMPS_COMMUNS
Gosub SUP_AMA     # Issue 65677 & 66534 - 2010-10-26 by CCC
Gosub CRE_AMP
Gosub UN_MASQUE
Gosub GEN_FEN
Gosub CRE_AMA     # Issue 65677 & 66534 - 2010-10-26 by CCC
Gosub SUP_AMP
Return

#------------------------------------------------------------------------
# --- Ecran de visu tarifs dans article
#     MEME ECRAN UTILISE EN VISU ARTICLE ET CLIENT
#------------------------------------------------------------------------
$ECR_VISU
#If [F:SPC]CRIITM=0 : Return : Endif
MFROM="SPLV" : MTO="WB2"+num$([F:SPC]PLI)+"1"
TZONE(0)=ZCHAMP(0) :TMOD(0)=3 : # zones supprimées
TZONE(1)=ZCHAMP(1) :TMOD(1)=3
ITZ=1
For I=0 To 4
  If [F:SPC]FLD(I)=""
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=3
  Else
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=5
             TTAB(ITZ)=[F:SPC]FIL(I) : TFLD(ITZ)=[F:SPC]FLD(I)
    Case [F:SPC]FLDTYP(I)
      When "CCE" : ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
                            TINT(ITZ)="func TRTX3FNC.GETCOLDIE('"+[F:SPC]CRIDIE(I)+"')"
      When "ADI"
           If find([F:SPC]FLDTYPCPL(I),"20","21","22","23","24")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-19)+",206,1)"
           Endif
           If find([F:SPC]FLDTYPCPL(I),"30","31","32","33","34")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-29)+",207,1)"
           Endif
           If find([F:SPC]FLDTYPCPL(I),"40","41","42","43","44")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:SPC]FLDTYPCPL(I))-39)+",208,1)"
           Endif
      When Default
    Endcase
    If [F:SPC]FLDTYP(I)="ITS" | [F:SPC]FLDTYP(I)="BPC" | [F:SPC]FLDTYP(I)="BPD"
      ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=8
               TINT(ITZ)=[F:SPC]FLDTYP(I)
    Endif
  Endif
Next I
Gosub CHAMPS_COMMUNS
Gosub CRE_AMP
Gosub UN_MASQUE
Gosub GEN_FEN
Gosub SUP_AMP
Return

# Issue 65677 & 66534 - 2010-10-26 by CCC
# Suppression des actions inutiles
$SUP_AMA
If clalev ([F:AMA]) <= 0 : Local File = APPLI+".AMSKACT" [AMA] : Endif
For I = 1 To 5
    # Les types ITS et BPR ont une sélection particulière (sur les objets ITM et BPC)
    If !find([F:SPC]FLDTYP(I-1),"ITS","BPR")
        # Suppression de la sélection objet pour les autres types. On laisse la sélection du type de donnée fonctionner
        Update [AMA] Where ACTION="SELOBJ1" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=8
&                    With CODAFF="SPLW_"
    Endif
    # 71065 : PJT
    If [F:SPC]FLDTYP(I-1)="PJT"
        # Suppression des actions qui sont gérées par le type de données PJT
        Gosub SUP_AMA_PJT From TRTPJTSAL
    Endif
    # 71065 : PJT
    # 79705 : V7 : SAT in SPRICLINK
    If [F:SPC]FLDTYP(I-1)="SAT"
        # Suppression des actions qui sont gérées par le type de données SAT
        Gosub SUP_AMA_SAT
    Endif
    # 79705 : V7 : SAT in SPRICLINK
Next
Return

# 79705 : V7 : SAT in SPRICLINK
# ---------------------------------------------------------------------------------------------
# Suppression des actions dans AMSKACT
$SUP_AMA_SAT
# Suppression des actions qui se trouvent sur l'écran SPLW pour les chps CRIT1 à CRIT5
# et qui seront remplacées par les actions du type de données SAT sur l'écran généré
# Les actions seront recréées sur l'écran SPLW après génération de l'écran généré

# Sur tous les champs critère :
# Suppression de l'action IB_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=1
&                    With CODAFF="SPLW_"
# Suppression de l'action AS_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=4
&                    With CODAFF="SPLW_"
# Suppression de l'action C_
Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=5
&                    With CODAFF="SPLW_"
# Suppression de l'action B1_
Update [AMA] Where ACTION="GOBJETC" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=9
&                    With CODAFF="SPLW_"

# Sur le 1er champ critère CRIT1
If I=1
  # Suppression des boutons B2 à B4
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=10
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=11
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=12
&                      With CODAFF="SPLW_"
  # Suppression des boutons B5 à B8
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=15
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=16
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=17
&                      With CODAFF="SPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="SPLW" & CODZON="CRIT"+num$(I) & TYPACT=18
&                      With CODAFF="SPLW_"
Endif
Return
# 79705 : V7 : SAT in SPRICLINK

# Issue 65677 & 66534 - 2010-10-26 by CCC
# Récupération des actions supprimées
$CRE_AMA
If clalev ([F:AMA]) <= 0 : Local File = APPLI+".AMSKACT" [AMA] : Endif
Update [AMA] Where CODAFF="SPLW_"
&            With CODAFF="SPLW"
Return

#------------------------------------------------------------------------
# Création temporaire dans AMSKPAR des données pour type ADI CCE ...
# Modif    temporaire dans AMSKZON libelle (prix/coef) de zone PRI
#                                  Lien court / long
#------------------------------------------------------------------------
$CRE_AMP

If clalev ([F:AMP]) <= 0 : Local File = APPLI+".AMSKPAR" [AMP] : Endif
If clalev ([F:AMZ]) <= 0 : Local File =APPLI+".AMSKZON"  [AMZ] : Endif
Default File [SPC]

For I = 1 To 5
    Case [F:SPC]FLDTYP(I-1)
         When "ADI"
             If find([F:SPC]FLDTYPCPL(I-1),"20","21","22","23","24",
&                                          "30","31","32","33","34",
&                                          "40","41","42","43","44")
                Gosub CRE_AMP_STT    : If GOK=0 : Break : Endif
              Else
                Gosub CRE_AMP_ADI    : If GOK=0 : Break : Endif
             Endif

         When "CCE"    Gosub CRE_AMP_CCE      : If GOK=0 : Break : Endif

         When "CAC"    Gosub CRE_AMP_CAC      : If GOK=0 : Break : Endif

         When "BPD"    Gosub CRE_AMP_BPD      : If GOK=0 : Break : Endif
         # 71065 : PJT
         When "PJT"    Gosub CRE_AMP_ATY_PJT  : If GOK=0 : Break : Endif
         # 71065 : PJT
         # 79705 : V7 : SAT in SPRICLINK
         When "SAT"    Gosub CRE_AMP_ATY_SAT  : If GOK=0 : Break : Endif

         # Issue 110646 - 2015-09-01 by CPO : Error while using incoterm city ICTCTY
         When "CTY"    Gosub CRE_AMP_ATY_CTY  : If GOK=0 : Break : Endif

         When Default
    Endcase

    If [F:SPC]LIEN(I-1)>0
       Read [AMZ]CODE="SPLW";"CRIT"+num$(I)
       If !fstat
          [F:AMZ]LIEN=[F:SPC]LIEN(I-1)
          Rewrite [AMZ]
       Endif
       Read [AMZ]CODE="SPLV";"CRIT"+num$(I)
       If !fstat
          [F:AMZ]LIEN=[F:SPC]LIEN(I-1)
          Rewrite [AMZ]
       Endif
    Endif

Next I

If [F:SPC]PRIPRO=4
  Read [AMZ]CODE="SPLW";"PRI"
  If !fstat
    If [F:AMZ]INTIT=1871 : [F:AMZ]INTIT=3377 : Endif
    Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="SPLV";"PRI"
  If !fstat
    If [F:AMZ]INTIT=1871 : [F:AMZ]INTIT=3377 : Endif
    Rewrite [AMZ]
  Endif
Endif

Return

#---
$CRE_AMP_ADI
[F:AMP]CODPAR = "ADI"
Read [ATZ] CODZONE = [F:SPC]FIL(I-1);[F:SPC]FLD(I-1)
If fstat : GOK = 0 : Call FSTA("ATZ") From GLOCK : Return : Endif
J = instr(1,[F:ATZ]EXPLIEN,";")
If J <> 0 : [F:AMP]VALPAR = left$([F:ATZ]EXPLIEN,J-1) : Endif
Gosub CRE_AMP_WRITE
Return

#--- axes analytiques
$CRE_AMP_CCE
[F:AMP]CODPAR = "CCE"
If [F:SPC]FLD(I-1)="CCE"
   [F:AMP]VALPAR = '"'+[F:SPC]CRIDIE(I-1)+'"'
Else [F:AMP]VALPAR = '"'+right$([F:SPC]FLD(I-1),4)+'"'Endif
Gosub CRE_AMP_WRITE
Return

#--- codes stat articles / clients / fournisseurs
$CRE_AMP_STT
[F:AMP]CODPAR = "ADI"
[F:AMP]VALPAR = [F:SPC]FLDTYPCPL(I-1)
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = "TABDIV"
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
Return

#--- code comptable
$CRE_AMP_CAC
[F:AMP]CODPAR = "CAC"
Case [F:SPC]FIL(I-1)
     When "ITMMASTER"     : [F:AMP]VALPAR= "1"
     When "BPARTNER"      : [F:AMP]VALPAR= "17"
     When "BPSUPPLIER"    : [F:AMP]VALPAR= "3"
     When "BPCUSTOMER"    : [F:AMP]VALPAR= "2"
     When "SALESREP"      : [F:AMP]VALPAR= "4"
Endcase
Gosub CRE_AMP_WRITE
Return

#--- Code adresse livraison
$CRE_AMP_BPD
[F:AMP]CODPAR = "BPD"
I0=find("BPC",[F:SPC]FLDTYP(0..I-1))
If I0
   [F:AMP]VALPAR = "[M]CRIT"+num$(I0)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
Return


# 71065 : PJT
#--- Type de donnée PJT
$CRE_AMP_ATY_PJT

Gosub CRE_AMP_ATY_PJT From TRTPJTSAL

Return
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
#--- Type de donnée SAT
#  Création temporaires des paramètres liés au type de données SAT
$CRE_AMP_ATY_SAT

Local Char WCODPAR_SAT(GLONAAR) (0..20)
WCODPAR_SAT(0)  = "PAYS"        : # Pays
WCODPAR_SAT(1)  = "CONTEXT"     : # Context

Local Integer WIND_FLD

[F:AMP]CODPAR = WCODPAR_SAT(0)     : # Code pays
[F:AMP]VALPAR = '""'
# Si le pays est paramétré comme critère de tarif, on l'utilise comme paramètre pour le type de données SAT
WIND_FLD=find("CRY",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR_SAT(1)     : # Contexte
[F:AMP]VALPAR = '"2"'
Gosub CRE_AMP_WRITE
Return
# 79705 : V7 : SAT in SPRICLINK

# Issue 110646 - 2015-09-01 by CPO : Error while using incoterm city ICTCTY
$CRE_AMP_ATY_CTY
Local Char WCODPAR_CTY(GLONAAR) (0..3)
#--Labels of CTY data type actions parameters
WCODPAR_CTY(0) = "PAYS" :# Pays        (Country)
WCODPAR_CTY(1) = "CP"   :# Code postal (Postal code)

Local Integer WIND_FLD

[F:AMP]CODPAR = WCODPAR_CTY(0)     :# Pays        (Country)
[F:AMP]VALPAR = '""'
WIND_FLD=find("CRY",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE

[F:AMP]CODPAR = WCODPAR_CTY(1)     :# Code postal (Postal code)
[F:AMP]VALPAR = '[M]WPOSCOD(nolign-1)'
WIND_FLD=find("POSCOD",[F:SPC]FLD(0..dim([F:SPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE

Return
# End issue 110646

#---
$CRE_AMP_WRITE
[F:AMP]TYPAFF = 1
[F:AMP]CODAFF = MFROM
[F:AMP]CODZON = "CRIT"+num$(I)
Write [AMP]
If fstat
   GOK = 0 : Call FSTA("AMP") From GLOCK : Return
Endif
Return


#------------------------------------------------------------------------
# Suppression dans AMSKPAR masque racine des données pour type ADI CCE STI STC PJT
#------------------------------------------------------------------------
$SUP_AMP

For I=1 To 5
  If [F:SPC]FLDTYP(I-1)="CCE"
    Delete [F:AMP]Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="CCE"
  Endif
  If [F:SPC]FLDTYP(I-1)="ADI"
    Delete [F:AMP]Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="ADI"
    If find([F:SPC]FLDTYPCPL(I-1),"20","21","22","23","24",
&                                 "30","31","32","33","34",
&                                 "40","41","42","43","44")
       Delete [F:AMP]Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="TABDIV"
    Endif
  Endif
  If [F:SPC]FLDTYP(I-1)="CAC"
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="CAC"
  Endif
  If [F:SPC]FLDTYP(I-1)="BPD"
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="BPD"
  Endif

  # 71065 : PJT
  If [F:SPC]FLDTYP(I-1)="PJT"
    Gosub SUP_AMP_PJT From TRTPJTSAL
  Endif
  # 71065 : PJT

  # 79705 : V7 : SAT in SPRICLINK
  If [F:SPC]FLDTYP(I-1)="SAT"
    Gosub SUP_AMP_SAT
  Endif

  # Issue 110646 - 2015-09-01 by CPO : Error while using incoterm city ICTCTY
  If [F:SPC]FLDTYP(I-1)="CTY"
    Gosub SUP_AMT_CTY
  Endif
  # End issue 110646

  Read [AMZ]CODE="SPLW";"CRIT"+num$(I)
  If !fstat
     [F:AMZ]LIEN=0
     Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="SPLV";"CRIT"+num$(I)
  If !fstat
     [F:AMZ]LIEN=0
     Rewrite [AMZ]
  Endif

Next I

If [F:SPC]PRIPRO=4
  Read [AMZ]CODE="SPLW";"PRI"
  If !fstat
    If [F:AMZ]INTIT=3377 : [F:AMZ]INTIT=1871 : Endif
    Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="SPLV";"PRI"
  If !fstat
    If [F:AMZ]INTIT=3377 : [F:AMZ]INTIT=1871 : Endif
    Rewrite [AMZ]
  Endif
Endif

Return


# 79705 : V7 : SAT in SPRICLINK
# Suppression des paramètres dans AMSKPAR
$SUP_AMP_SAT
Local Integer WIND_SAT

For WIND_SAT=0 To dim(WCODPAR_SAT)-1
    If WCODPAR_SAT(WIND_SAT)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR_SAT(WIND_SAT)
Next

Return
# 79705 : V7 : SAT in SPRICLINK

# Issue 110646 - 2015-09-01 by CPO : Error while using incoterm city ICTCTY
$SUP_AMT_CTY
Local Integer WIND_CTY

For WIND_CTY=0 To dim(WCODPAR_CTY)-1
    If WCODPAR_CTY(WIND_CTY)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR_CTY(WIND_CTY)
Next

Return
# End issue 110646

#------------------------------------------------------------------------
# --- Champs communs à tous les écrans (si plusieurs écrans ?)
#------------------------------------------------------------------------
$CHAMPS_COMMUNS
For I=7 To dim(ZCHAMP)-1
    If ZCHAMP(I)<>""
       If ZZ(I)=0 : ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=3 : Endif
       If ZZ(I)<>0 & I>13 & I<23
#               dans champs rem/frais chgt de l'intitulé de atextra
#         ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=4 : TINT(ITZ)=GLIBDES(I-17)
       Endif

#               dans champs rem/frais si % : chgt type de donnée RAT
#       If ZZ(I)=2 & I>13 & I<23
#          ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=8 : TINT(ITZ)="RAT"
#       Endif

#               si champ article gratuit   : chgt type de donnée ITS
       If ZZ(I)<>0 & I=25
          ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=8 : TINT(ITZ)="ITS"
       Endif
    Endif
Next I
Return

#------------------------------------------------------------------------
# --- génération un écran
#------------------------------------------------------------------------
$UN_MASQUE
OPT1=0
OPT2=0                    : # pas affichage du masque genere
OPT3=0
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 : GOK=0 : Endif
Return

#######################################################################
# Génération de la fenêtre par copie de la fenetre standard           #
#                                                                     #
#  - La fenêtre standard doit exister                                 #
#    -    B1        :    Saisie tarif                                 #
#    -    B2        :    Visualisation tarif                          #
#    -    B3        :    Simulation revision (nota: avec ecran B1)    #
#         Elle n'est utilisée que pour la copie                       #
#                                                                     #
#  - Création enr. ds TABLE AWINDOW  [AWI]                            #
#  -                  TABLE AWINPAR  [AWP]                            #
#  -                  TABLE AWINBRO  [AWB]                            #
#  -                  TABLE AWINBOUT [AWT]                            #
#  - Génération du traitement lié à la fenêtre                        #
#                                                                     #
#######################################################################
$GEN_FEN

Local Char    NOMWIN(GLONFEN), WINREF(GLONFEN), NOMMSK (GLONAMK)

Case MFROM
  When "SPLW"    :
        WINREF = "B1"                       : # fenetre de saisie
        NOMWIN = "WB1"+num$([F:SPC]PLI)
        NOMMSK = "WB1"+num$([F:SPC]PLI)+"1"
        Gosub GEN_FEN1
        WINREF = "B3"
        NOMWIN = "WB3"+num$([F:SPC]PLI)     : # fenetre de simulation revision
        NOMMSK = "WB1"+num$([F:SPC]PLI)+"1"
        Gosub GEN_FEN1

  When "SPLV"    :
        WINREF = "B2"                       : # fenetre de visu
        NOMWIN = "WB2"+num$([F:SPC]PLI)
        NOMMSK = "WB2"+num$([F:SPC]PLI)+"1"
        Gosub GEN_FEN1

  When Default : Return
Endcase

Return

#----------------------------------------------------------------------
$GEN_FEN1
# suppression de la fenetre (sauf si celle de base)
If NOMWIN<>WINREF
  Delete [AWI] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINDOW"-NOMWIN : Return : Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINPAR"-NOMWIN : Return : Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINBRO"-NOMWIN : Return : Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINBOUT"-NOMWIN : Return : Endif
Endif

# lecture de la fenêtre de référence
Read [F:AWI]AWI0 = WINREF
If !fstat
    [F:AWI]WIN=NOMWIN
    [F:AWI]NOMMSK(0)=NOMMSK
#    [F:AWI]LIBEL=[F:SPC]PLIDES             : #ts
    Call LECTEXTRA ([F:AWI]LIBEL,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
    [F:AWI]ENAFLG=2                         : # 49953 : Laisser la fenêtre active pour permettre la saisie tarif
    [F:AWI]TRN=[F:SPC]PLI                   : #ts
    If NOMWIN<>WINREF
        GPOINT="CPLWINSPL" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
        Write [AWI]
        If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
        For [AWP]AWP0 Where WIN=WINREF
            [F:AWP]WIN=NOMWIN
            Write [AWP]
            If fstat : GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
        Next
        For [AWB]AWB0 Where WIN=WINREF
            [F:AWB]WIN=NOMWIN
            Write [AWB]
            If fstat : GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
        Next
        For [AWT]AWT0 Where WIN=WINREF
            [F:AWT]WIN=NOMWIN
            Write [AWT]
            If fstat : GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
        Next
        If GOK<1 : Return : Endif
    Else
        Rewrite [AWI]
        If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
    Endif

#    Call GENTRT(APPLI,NOMWIN) From GWINDOW
    Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
    If OK=0 GOK=0 : Return : Endif
Endif

#Call GENTRT(APPLI,"SPL") From OBJWIN                         : # ts

Return

#######################################################################
# Suppression des fenêtres liés a un code tarif                       #
#  - TABLE AWINDOW  [AWI]                                             #
#  - TABLE AWINPAR  [AWP]                                             #
#  - TABLE AWINBRO  [AWB]                                             #
#  - TABLE AWINBOUT [AWT]                                             #
#  - Traitement lié à la fenetre                                      #
#######################################################################
$DEL_FEN
Local Char    NOMWIN(GLONFEN), NOMTRTWIN(GLONADC)

If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif      : #ts
If clalev([F:AWP])=0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif      : #ts
If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif      : #ts
If clalev([F:AWT])=0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif      : #ts

#For I=1 To 2
For I=1 To 3
    NOMWIN    = "WB"+num$(I)+num$([F:SPC]PLI)
    NOMTRTWIN = "WGB"+num$(I)+num$([F:SPC]PLI)

    Call DELWIN(NOMWIN,APPLI) From MSKDIV

#    Call ANNULWIN(APPLI,NOMWIN) From INTRXOUT
#    Delete [AWI] Where WIN=NOMWIN
#    If fstat=1 : GOK=-1 : GLOCK="$AWINDOW"-NOMWIN : Break : Endif
#    Delete [AWP] Where WIN=NOMWIN
#    If fstat=1 : GOK=-1 : GLOCK="$AWINPAR"-NOMWIN : Break : Endif
#    Delete [AWB] Where WIN=NOMWIN
#    If fstat=1 : GOK=-1 : GLOCK="$AWINBRO"-NOMWIN : Break : Endif
#    If I=1 Call GENTRT(APPLI,"SPL") From OBJWIN Endif                  : #ts
#    Call EFFACE(filpath("TRT",NOMTRTWIN,"adx",APPLI),OK) From ORDSYS
#    Call EFFACE(filpath("TRT",NOMTRTWIN,"src",APPLI),OK) From ORDSYS
Next

Return

#######################################################################
# Suppression des paramétrages augmentation pour ce code tarif        #
#  - TABLE SINCENT [SNE]                                              #
#  - TABLE SINCDET [SND]                                              #
#  - Traitement lié WBI+Code Aumentation                              #
#######################################################################
$DEL_INC
Local Char    NOMTRTINC(10)

For [SNE]SNE0 Where PLI=[F:SPC]PLI
  NOMTRTINC = "WBI"+num$([F:SNE]COD)
#  Call EFFACE(filpath("TRT",NOMTRTINC,"adx",0),OK) From ORDSYS
  Call EFFACE_ADX("","",NOMTRTINC,OK) From ORDSYS
  Call EFFACE(filpath("TRT",NOMTRTINC,"src",0),OK) From ORDSYS
  Delete [SND] Where COD=[F:SNE]COD
  If fstat=1 : GOK=-1 : GLOCK="$SINCDET"-[F:SNE]COD : Break : Endif
Next
If GOK<>1 : Return : Endif

Delete [SNE] Where PLI=[F:SPC]PLI
If fstat=1 : GOK=-1 : GLOCK="$SINCENT"-[F:SNE]COD : Return : Endif

Return

#######################################################################
#########################################################################
######## SUBPROG dans SPC0 : Généralités de paramétrage #################
#######################################################################
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SPC0) 19/12/2005 09:33:46 (LD)
######################################################################################
Subprog C_PLISTC(VALEUR)
Variable Char    VALEUR()
Local  Integer I
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
Raz GLIBDES
Read [PRS] PRS0=1;VALEUR
If fstat  mkstat=1 : End : Endif
For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)=0 : Break : Endif
  Call LECTEXTRA(GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")",
&                "1",[F:PRS]PLISTC) From ATEXTRA
Next I
If I > dim([M:SPC3]DISCRGPRO)
     GNBREM = dim([M:SPC3]DISCRGPRO)
Else GNBREM=I
Endif
End

Subprog AM_PLISTC(VALEUR)
Variable Char    VALEUR()
If dim([M]NBREM)>0 : NBREM = GNBREM : Endif
If !GIMPORT
  If dim([M]NBREM)>0 : Actzo [M:SPC3]1-99 : Affzo [SPC3]1-99 : Endif
Endif
End

######################################## code structure
Subprog AV_PLISTC(VALEUR)
Variable Char     VALEUR
#VALEUR=""
End
Subprog AS_PLISTC(VALEUR)
Variable Char    VALEUR()
#mkstat=2
End

##########################################################################
## Etiquette ajoutée par le superviseur 15/03/2004 13:31:42 (JL)
##########################################################################
Subprog AS_PLITYP(VALEUR)
Variable Integer VALEUR
If [M:SPC0]PLIBPRCNR=2 : GMENLOC(3)=1 : GMENLOC(4)=1 : Endif
End

Subprog AP_PLITYP(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
######################################## type de tarif
Subprog AM_PLITYP(VALEUR)
Variable Integer VALEUR
[M:SPC0]PLITYP=VALEUR
If VALEUR=2          : # Groupé
  Raz [M:SPC2]PRIPRO, [M:SPC2]PRIFLD, [M:SPC2]PRITYP
  [M:SPC2]PRIQTYFLG=2
  Raz [M:SPC2]CUR, [M:SPC2]ATICNVFLG, [M:SPC2]UOMCNVFLG
  Raz [M:SPC2]FOCPRO, [M:SPC2]FOCTYP, [M:SPC2]COMPRO
Endif
If VALEUR=3          : # Interdit
  Raz [M:SPC2]PRIPRO, [M:SPC2]PRIFLD, [M:SPC2]PRITYP, [M:SPC2]PRIQTYFLG
  Raz [M:SPC2]CUR, [M:SPC2]ATICNVFLG, [M:SPC2]UOMCNVFLG
  Raz [M:SPC2]FOCPRO, [M:SPC2]FOCTYP, [M:SPC2]COMPRO
Endif
#  si tarif interdit ou composant --> pas inter societe
If find(VALEUR,3,4)   Grizo [M:SPC0]PLIBPRCNR
   Else               Actzo [M:SPC0]PLIBPRCNR
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SPC0) 06/12/2005 17:20:16 (JL)
######################################################################################
Subprog C_PLIBPRCNR(VALEUR)
Variable Integer VALEUR
Local Integer DANSACHATS  # dans achats : 0=absent /1=present hors groupe /2=present groupe
If clalev ([F:PPC])<=0 : Local File PPRICCONF [PPC] : Endif
#            Controle avec parametrage tarifs achats
Read [PPC]PPC0=[M:SPC0]PLI
If !fstat : DANSACHATS=[F:PPC]PLIBPRCNR : Endif
If find (VALEUR,2,3)
   If DANSACHATS=0
#            Absence de tarif achats correspondant
      GMESSAGE=mess(904,196,1) : GERR=3
   Endif
   If DANSACHATS=1
#            Presence d un tarif achats de même code mais avec des regles differentes
      GMESSAGE=mess(905,196,1) : GERR=1 : mkstat=1
   Endif
Endif
End

######################################## priorité
Subprog AM_PIO(VALEUR)
Variable Decimal  VALEUR
If VALEUR<1 | VALEUR>99 : mkstat=1 : Endif
End

#########################################################################
######## SUBPROG dans SPC1 : les critères ###############################
#########################################################################
# --- si sortie du tableau recherche crit. devise, unité, article, client
Subprog C_BASTAB
Local Integer I,I1
[M:SPC1]CRICURNUM=0 : [M:SPC1]CRIUOMNUM=0 : [M:SPC1]CRIITMNUM=0 : [M:SPC1]CRIBPCNUM=0


If status=1  or status=4  or status=5  or status=20 or
&  status=21 or status=26 or status=92 or status=93
  For I=0 To 4
    If [M:SPC1]ABB(I)="ITM" & [M:SPC1]FLD(I)="ITMREF"  : [M:SPC1]FLDTYP(I)="ITS" : Endif
    If [M:SPC1]ABB(I)="BPR" & [M:SPC1]FLD(I)="BPRNUM"  : [M:SPC1]FLDTYP(I)="BPC" : Endif

#    If [M:SPC1]ABB(I)="BPD" & [M:SPC1]FLD(I)="BPCNUM"  : [M:SPC1]FLDTYP(I)="BPD" : Endif
#   --- si code adresse client livre mis a BPD uniquement si presence
#       de BPDLVCUST / BPCNUM dans un critere precedent
    If [M:SPC1]ABB(I)="BPD" & [M:SPC1]FLD(I)="BPAADD"
       [M:SPC1]FLDTYP(I)="A"
       For I1=0 To I-1
           If [M:SPC1]ABB(I1)="BPD" & [M:SPC1]FLD(I1)="BPCNUM"
              [M:SPC1]FLDTYP(I)="BPD" :
           Endif
       Next I1
    Endif
#   ---

#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????
If [M:SPC1]ABB(I)="BP1" : [M:SPC1]ABB(I)="BPR" : Endif
If [M:SPC1]ABB(I)="BC1" : [M:SPC1]ABB(I)="BPC" : Endif
If [M:SPC1]ABB(I)="BD1" : [M:SPC1]ABB(I)="BPD" : Endif
If [M:SPC1]ABB(I)="IM1" : [M:SPC1]ABB(I)="ITM" : Endif
If [M:SPC1]ABB(I)="IU1" : [M:SPC1]ABB(I)="ITU" : Endif
If [M:SPC1]ABB(I)="IS1" : [M:SPC1]ABB(I)="ITS" : Endif
If [M:SPC1]ABB(I)="IV1" : [M:SPC1]ABB(I)="ITV" : Endif
#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????
#????????????????????????? A SUPPRIMER ??????????????????????????????

    If [M:SPC1]ABB(I)="REP" & [M:SPC1]FLD(I)="REPNUM"  : [M:SPC1]FLDTYP(I)="REP" : Endif
    If [M:SPC1]FLDTYP(I)="ITM" : [M:SPC1]FLDTYP(I)="ITS" : Endif
    If [M:SPC1]FLDTYP(I)="BPR" : [M:SPC1]FLDTYP(I)="BPC" : Endif
    If [M:SPC1]FLDTYP(I)="CUR" : [M:SPC1]CRICURNUM=I+1 : Endif
    If [M:SPC1]FLDTYP(I)="UOM" : [M:SPC1]CRIUOMNUM=I+1 : Endif
    If [M:SPC1]FLDTYP(I)="ITS" : [M:SPC1]CRIITMNUM=I+1 : Endif
    If [M:SPC1]FLDTYP(I)="BPC" : [M:SPC1]CRIBPCNUM=I+1 : Endif
#   Chargement Complement type de donnee
    Raz [M:SPC1]FLDTYPCPL(I)
#   - si ADI : no table diverse statistique
    If [M:SPC1]FLDTYP(I)="ADI"
       Case [M:SPC1]FLD(I)
            When "TSICOD"  : [M:SPC1]FLDTYPCPL(I)=num$([M:SPC1]CRIIND(I)+20)
            When "TSICOD1" : [M:SPC1]FLDTYPCPL(I)="20"
            When "TSICOD2" : [M:SPC1]FLDTYPCPL(I)="21"
            When "TSICOD3" : [M:SPC1]FLDTYPCPL(I)="22"
            When "TSICOD4" : [M:SPC1]FLDTYPCPL(I)="23"
            When "TSICOD5" : [M:SPC1]FLDTYPCPL(I)="24"
            When "TSCCOD"  : [M:SPC1]FLDTYPCPL(I)=num$([M:SPC1]CRIIND(I)+30)
            When "TSCCOD1" : [M:SPC1]FLDTYPCPL(I)="30"
            When "TSCCOD2" : [M:SPC1]FLDTYPCPL(I)="31"
            When "TSCCOD3" : [M:SPC1]FLDTYPCPL(I)="32"
            When "TSCCOD4" : [M:SPC1]FLDTYPCPL(I)="33"
            When "TSCCOD5" : [M:SPC1]FLDTYPCPL(I)="34"
            When "TSSCOD"  : [M:SPC1]FLDTYPCPL(I)=num$([M:SPC1]CRIIND(I)+40)
            When "TSSCOD1" : [M:SPC1]FLDTYPCPL(I)="40"
            When "TSSCOD2" : [M:SPC1]FLDTYPCPL(I)="41"
            When "TSSCOD3" : [M:SPC1]FLDTYPCPL(I)="42"
            When "TSSCOD4" : [M:SPC1]FLDTYPCPL(I)="43"
            When "TSSCOD5" : [M:SPC1]FLDTYPCPL(I)="44"
       Endcase
    Endif
  Next I
Endif
End

######################################## fichier
Subprog AV_FIL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
If VALEUR="" : End : Endif
Call CHARFIC(1,"INTFIC","ABB","SPC1",VALEUR) From TRTPARAM
Affzo [M:SPC1]INTFIC(nolign-1), ABB(nolign-1)
End

#---------------------------------------
Subprog C_FIL(VALEUR)
Variable Char    VALEUR()
Local Integer NUMLIB, OK
If VALEUR="" : mkstat=1 : End : Endif
VALEUR=toupper(VALEUR)
OK=find(VALEUR,JGFICFIC(0..JGNBFIC-1))
If OK=0 : mkstat=1 : GERR=1 : GMESSAGE=mess(6,141,1) : End : Endif
CZ=num$(VALEUR)
End

#---------------------------------------
Subprog AM_FIL(VALEUR)
Variable Char    VALEUR()
NOL=nolign-1
# --- appel s/p récupération libellé et abréviation de la table
Call CHARFIC(1,"INTFIC","ABB","SPC1",VALEUR) From TRTPARAM
Affzo [M:SPC1]INTFIC(nolign-1), ABB(nolign-1)
End

######################################## champ fichier
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=1 : End : Endif
Local Integer I, NOL
Local Char    WVAL
VALEUR=toupper(VALEUR)
NOL=nolign-1
WVAL=VALEUR
I=instr(1,WVAL,"(")
If I
  VALEUR=left$(WVAL,I-1)
  [M:SPC1]CRIIND(NOL)=val(right$(WVAL,I+1))
Endif
Read [F:ATZ]CODZONE=[M:SPC1]FIL(NOL); VALEUR
If fstat : mkstat=1 : GMESSAGE=mess(41,100,1) : End : Endif

# 71065 : PJT
# Vérification exclusivité entre les champs PJT et PJTNUM de la table SPRICLINK
If [F:ATZ]CODTYP="PJT"
  Gosub C_FLD_PJT From TRTPJTSAL
Endif
# 71065 : PJT

# 105605 : CCM - Revision index (LD:04/08/15)
# Version fields in SPRINCLINK are used only for price processing (Factor or Calculation)
If [M:SPC1]FIL(NOL)="SPRICLINK" &  find(VALEUR, "ECCVALMAJ", "ECCVALMIN")
    mkstat=1 : GMESSAGE=mess(642,199,1) : End
Endif
# 105605 : CCM - Revision index (LD:04/08/15)

End

#---------------------------------------
Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer NOL, TOTLNG, TOTMAX, OK
NOL=nolign-1

[M:SPC1]CRIIND(NOL)=0

# --- récup. libellé, longueur, indice, menu local type donnée  Rubrique
Call CHARCRIT(1,[M:SPC1]FIL(NOL),"CRIDES","CRILEN","FLDTYP","PPUMNU","SPC1",VALEUR) From TRTPARAM
If !mkstat : Affzo [M:SPC1]CRIDES(NOL) : Endif

# --- controle si longueur totale des critères > longueur type donnée SPX
#     (15 = 10 type alpha + 5 sépateurs)
TOTMAX=mod(type([F:SPL]PLICRI)-15,256)  : # Bug UNICODE
TOTLNG=sum([M:SPC1]CRILEN)
If TOTLNG>TOTMAX
  Call AVERTIR(mess(239,199,1)-"("+num$(TOTLNG)+")"+"\"+mess(240,199,1)-":"-num$(TOTMAX),OK) From GESECRAN
  If OK<>2 : mkstat=2 : Endif
Endif
End

######################################## code axe analytique critère
Subprog AS_CRIDIE(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Read [ATZ] CODZONE=[M:SPC1]FIL(NOL);[M:SPC1]FLD(NOL)
If fstat  mkstat=1 : End : Endif
If !find([M:SPC1]FLD(NOL),"CCE")  mkstat=2 : End : Endif
End

Subprog C_CRIDIE(VALEUR)
Variable Char    VALEUR()
If VALEUR=""  mkstat=1 : End : Endif
End

######################################## indice critère
Subprog AS_CRIIND(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
Read [F:ATZ]CODZONE=[M:SPC1]FIL(NOL) ; [M:SPC1]FLD(NOL)
If fstat : mkstat=1 : End : Endif
#If [F:ATZ]DIME<2 & !find([M:SPC1]FLD(NOL),"TSICOD","TSCCOD","TSSCOD")       # SAM 117373 Setup REP in Sales price list (JUCON 01/12/2016)
If [F:ATZ]DIME<2 & !find([M:SPC1]FLD(NOL),"TSICOD","TSCCOD","TSSCOD","REP")  # SAM 117373 Setup REP in Sales price list (JUCON 01/12/2016)
   mkstat=2 : End
Endif
End

#---------------------------------------
Subprog C_CRIIND(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
Read [F:ATZ]CODZONE=[M:SPC1]FIL(NOL) ; [M:SPC1]FLD(NOL)
If fstat : mkstat=1 : End : Endif
If [M:SPC1]FLD(NOL) = "TSCCOD" & VALEUR < 5 : End : Endif
If [M:SPC1]FLD(NOL) = "TSICOD" & VALEUR < 5 : End : Endif
If [M:SPC1]FLD(NOL) = "TSSCOD" & VALEUR < 5 : End : Endif
# Ini SAM 117373 Setup REP in Sales price list (JUCON 01/12/2016)
If [M:SPC1]FLD(NOL) = "REP" and [F:ATZ]CODACT<>""
  Local Integer DIMREP: DIMREP=1
  Local File ACTIV [REPD]
  Read [REPD]CODACT=[F:ATZ]CODACT
  If !fstat: DIMREP=[F:REPD]DIME: Endif
  Close File [REPD]
  If VALEUR < DIMREP : End : Endif
Endif
# End SAM 117373 Setup REP in Sales price list (JUCON 01/12/2016)
If VALEUR>[F:ATZ]DIME-1 : mkstat=1 : GERR=1 : GMESSAGE=mess(35,199,1) : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SPC1) 13/12/2005 13:12:12 (JL)
######################################################################################
Subprog AS_LIEN(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=max(0,nolign-1)
If !find([M]FLDTYP(NOL),"ITM","ITS","BPR","BPC","BPD","REP","ADI") : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]FLDTYP(NOL),"") From CONTOBJ
If [F:ATY]OBJLIEN="" : mkstat=1 : End : Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]NOMFIC="" : mkstat=1 : End : Endif
Call LECTURE ("ATB",[F:AOB]NOMFIC,"") From CONTOBJ
If [F:ATB]INTIT="" & [F:ATB]INTITC="" : mkstat=1 : End : Endif
If [F:ATB]INTIT="" : GMENLOC(2)=1 : Endif
If [F:ATB]INTITC="" : GMENLOC(3)=1 : Endif
End


