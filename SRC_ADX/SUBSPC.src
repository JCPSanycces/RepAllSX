Raz [M:SPC2]FLTTAB, XXCONV, XXVAR
Case [M:SPC2]PRIPRO
  When 4 : [M:SPC2]FLTTAB="find(ABRFIC,'ITM','ITS','ITC','ITV')"
#  When 5 : [M:SPC2]FLTTAB="find(ABRFIC,'ITM','ITS','ITC','ITV','BPR','BPC','MVC','BPD','REP','SPK')"
  When 5 : [M:SPC2]FLTTAB="find(ABRFIC,'ITM','ITS','ITC','ITV','BPR','BPC','BPD','REP','SPK')"
Endcase
End
