#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Helper function to call the syracuse module for etna bridge
#*
#* @param ETNAMET The method to call (graphQLQuery, graphQLMutation, ...)
#* @param ARGUMENTS : Multiple arguments delimited by ',' ; It can be JSON format or every types
#* @param ENCODINGS : Specify the needs to encode each argument to base64 or not. Can be '0' or '1'. Each value must be delimited by ','
#* @param RESHEAD : The response header
#* @param RESBODY : The response body
#*!
Funprog ETNA_WAIT_CALL(ETNAMET, ARGUMENTS, ENCODINGS, RESHEAD, RESBODY)
  Value Char ETNAMET,ENCODINGS
  Variable Clbfile ARGUMENTS, RESHEAD, RESBODY

  Local Integer STATUSCODE
#  STATUSCODE = func ASYRWEBSER.EXEC_JS('syracuse-4gl-api/lib/etna', ETNAMET, 'wait', ARGUMENTS, ENCODINGS, 0, '', '0', RESHEAD, RESBODY)
  STATUSCODE = func ASYRWEBSER.EXEC_JS('$etna', ETNAMET, 'wait', ARGUMENTS, ENCODINGS, 0, '', '0', RESHEAD, RESBODY)
End STATUSCODE

#**
#* Call a GraphQL query
#*
#* @param CLAS The class name to operate on
#* @param QFILTER The filter to apply
#* @param ORDERBY The order by clause
#* @param RESHEAD The response headers
#* @param RESBODY The response body
#*!
Funprog ETNA_QUERY(CLAS, PROPERTIES, QFILTER, ORDERBY, RESHEAD, RESBODY)
  Value Char CLAS
  Variable Clbfile PROPERTIES, QFILTER, ORDERBY, RESHEAD, RESBODY

  Local Integer STATUSCODE
  Local Clbfile ARGUMENTS
  ARGUMENTS = '"' + CLAS + '",'
  Append ARGUMENTS, '"' + PROPERTIES + '",'
  Append ARGUMENTS, '"' + QFILTER + '",'
  Append ARGUMENTS, '"' + ORDERBY +'"'
  STATUSCODE = func ETNA_WAIT_CALL("graphQLQuery", ARGUMENTS, '', RESHEAD, RESBODY)
End STATUSCODE

#**
#* Call a GraphQL mutation
#*
#* @private
#* @param OP The operation to execute. Can be 'create', 'update', 'delete'
#* @param CLAS The class name to operate on
#* @param DATA The JSON payload for the operation
#* @param RESHEAD The response headers
#* @param RESBODY The response body
#*!
Funprog _MUTATION(OP, CLAS, DATA, RESHEAD, RESBODY)
  Value Char OP, CLAS
  Const Clbfile DATA
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY

  Local Integer STATUSCODE
  Local Clbfile ARGUMENTS
  ARGUMENTS = '"' + tolower(OP) + '","' + CLAS + '",'
  Append ARGUMENTS, DATA

  STATUSCODE = func ETNA_WAIT_CALL("graphQLMutation", ARGUMENTS, '0,0,0', RESHEAD, RESBODY)
End STATUSCODE

#**
#* Create an instance of a class
#*
#* @param CLAS The class name to operate on
#* @param DATA The JSON payload for the operation
#* @param RESHEAD The response headers
#* @param RESBODY The response body
#*!
Funprog ETNA_CREATE(CLAS, DATA, RESHEAD, RESBODY)
  Value Char CLAS
  Const Clbfile DATA
  Variable Clbfile RESHEAD, RESBODY

End func _MUTATION("create", CLAS, DATA, RESHEAD, RESBODY)

