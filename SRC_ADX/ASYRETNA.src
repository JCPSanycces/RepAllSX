  Variable Clbfile RESHEAD, RESBODY

End func _MUTATION("update", CLAS, DATA, RESHEAD, RESBODY)

#**
#* Delete an instance of a class
#*
#* @param CLAS The class name to operate on
#* @param DATA The JSON payload for the operation
#* @param RESHEAD The response headers
#* @param RESBODY The response body
#*!
Funprog ETNA_DELETE(CLAS, DATA, RESHEAD, RESBODY)
  Value Char CLAS
  Const Clbfile DATA
  Variable Clbfile RESHEAD, RESBODY

End func _MUTATION("delete", CLAS, DATA, RESHEAD, RESBODY)

