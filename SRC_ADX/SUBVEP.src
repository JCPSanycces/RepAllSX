$CHECK_LOCK
#JASMI - 2018-02-16 - X3-77499 - START
#  If clalev([F:ADOT])=0 : Local File ADOVAL [ADOT]  : Endif
#  Local Integer ORIGINTIME, ELAPSETIME
#  Repeat
#    Read [F:ADOT]ADW0 = "";"";"BULGENFLG"
#    If !fstat
#      If [F:ADOT]VALEUR="2"
#        ORIGINTIME = time
#        ELAPSETIME = time
#        While ELAPSETIME-ORIGINTIME < 5
#          ELAPSETIME = time
#        Wend
#        [F:ADOT]VALEUR="1"
#      Endif
#    Else
#      Raz [F:ADOT]
#      [F:ADOT]CMP=""
#      [F:ADOT]FCY=""
#      [F:ADOT]PARAM="BULGENFLG"
#      [F:ADOT]VALEUR="1"
#      Write [F:ADOT]
#      Read [F:ADOT]ADW0 = "";"";"BULGENFLG"
#    Endif
#  Until (!fstat) & ([F:ADOT]VALEUR<>"2")
#  If !fstat
#    [F:ADOT]VALEUR="2"
#    Rewrite [F:ADOT]
#  Endif
#  Unlock [ADOT]

Local Integer ITERCOUNT : ITERCOUNT=0
Local Integer ORIGINTIME, ELAPSETIME

  If clalev([F:ADOT])=0 : Local File ADOVAL [ADOT]  : Endif

$CHECK_LOCK_REPEAT
  ITERCOUNT+=1

  If ITERCOUNT>11 : Return : Endif

  Readlock [F:ADOT]ADW0 = "";"";"BULGENFLG"
  If !fstat
    If [F:ADOT]VALEUR="2"
      Unlock [F:ADOT]
      ORIGINTIME = time
      ELAPSETIME = time
      While ELAPSETIME-ORIGINTIME<6
        ELAPSETIME = time
      Wend
      Goto CHECK_LOCK_REPEAT
    Else
      [F:ADOT]VALEUR="2"
      Rewrite [F:ADOT]
#MIPEA - 2018-03-15- US X3-81875- START
      If dim(GACTX)>=0
        Local Integer WIND_RESULT
        WIND_RESULT= fmet GACTX.APARAM._ACLEAN
      Endif
#MIPEA - 2018-03-15- US X3-81875- END
    Endif
  Else
    If fstat=5
      Raz [F:ADOT]
      [F:ADOT]CMP=""
      [F:ADOT]FCY=""
      [F:ADOT]PARAM="BULGENFLG"
      [F:ADOT]VALEUR="2"
      Write [F:ADOT]
    Else
      Unlock [F:ADOT]
      ORIGINTIME = time
      ELAPSETIME = time
      While ELAPSETIME-ORIGINTIME < 6
        ELAPSETIME = time
      Wend
      Goto CHECK_LOCK_REPEAT
    Endif
  Endif
  Unlock [F:ADOT]
#JASMI - 2018-02-16 - X3-77499 - END

Return

$RESET_LOCK_STATUS
  Update [ADOT]
&   Where [ADOT]CMP="" & [ADOT]FCY="" & [ADOT]PARAM="BULGENFLG"
&   With [ADOT]VALEUR="1"
  Unlock [ADOT]
Return
#JASMI - 2017-06-02 - X3-32307 - END

