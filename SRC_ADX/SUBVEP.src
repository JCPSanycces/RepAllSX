#90289
Subprog CTRL_EXT(DAT, MAT, CTR, NBEXT)
Value Date DAT
Value Char MAT
Value Char CTR
Variable Integer NBEXT

NBEXT = 0

Local Char CRITERE (250)
CRITERE="[VEP]EMP='"+[L]MAT+"' & [VEP]PYRDAT=["+format$(GFMD,[L]DAT)+"]"

If [L]CTR<>""
 CRITERE-=" & [VEP]CTRNUM='"+[L]CTR+"'"
Endif

#Vérification qu'il existe bien au moins une paie extournée à cette date de paie et pour ce matricule (éventuellement pour son contrat)
For [VEP]VEP5 Where evalue(CRITERE) & RVSDAT<>[0/0/0]
 # Si oui, alors vérification que la paie de remplacement n'existe pas déjà.
 Filter [F:VEP2] Where EMP=[F:VEP]EMP &  CTRNUM=[F:VEP]CTRNUM & CTRDAT=[F:VEP]CTRDAT
&                     & STRDAT>=[VEP]STRDAT & BUL> [F:VEP]BUL & RVS<>2 & RVSDAT=[0/0/0]
 Read [F:VEP2]VEP5 Last
 Filter [F:VEP2]
 If fstat
  NBEXT += 1 : Break
 Endif
Next
If NBEXT
 [M:DIA]BULEXT = [F:VEP]BUL
 [M:DIA]CTRNUM = [F:VEP]CTRNUM
 [M:DIA]CTRDAT = [F:VEP]CTRDAT
 [M:DIA]STRDAT = [F:VEP]STRDAT
 [M:DIA]ENDDAT = [F:VEP]ENDDAT
 [M:DIA]PAYDAT = [F:VEP]PAYDAT
 [M:DIA]FCY    = [F:VEP]FCY
 [M:DIA]SRV    = [F:VEP]SRV
 [M:DIA]PRF    = [F:VEP]PRF
 Gosub CHARGE_MATRI
 Affzo 5-15
Endif
End

Subprog C_COE(VALEUR)
Variable Decimal VALEUR
Local Integer OK
OK = 0
For I=1 To GOPTCANA
 If evalue("dim([M]CCE"+num$(I)+"(nolign-1))")>0 & evalue("[M]CCE"+num$(I)+"(nolign-1)")<>""
  OK = 1 : Break
 Endif
Next
If OK=0
 # Il faut saisir au moins une section sur la ligne.
 GMESSAGE = mess(188,10703,1)
 mkstat = 2
Endif
End

##################################################
Subprog BULTUN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:VEPB])=0 : Local File VALEMP     [VEPB] : Endif
Local Date CLED
Local Char CLEC (50)
Read [F:VEPB]VEP5 = VALEUR
If fstat = 0
 CLED = [F:VEPB]PYRDAT
 CLEC = [F:VEPB]EMP+"~"+[F:VEPB]BUL
 Call OBJET_DAT(CLED,"VEP",CLEC) From GOBJET
Endif
End

######################################################################################
########################################################################
## INIT Ecran CALPAY appeler par action CALPAY depuis GESVEP
########################################################################
Subprog D_FLGINI(VALEUR)
Variable Char    VALEUR()
# SEGAY  US 2325-88174 BULDEM
If dim([M]FLGDEMA) > 0 : [M]FLGDEMA = 1 :  Grizo [M]FLGDEMA : Affzo [M]FLGDEMA :Endif

If [M:VEP0]MODIF<>1
 [M]CAL = 1 :  Grizo [M]CAL : Affzo [M]CAL
 [M]IMP = 1 :  Grizo [M]IMP : Affzo [M]IMP
Else
 [M]CAL = 2 : Actzo [M]CAL : Affzo [M]CAL
 [M]IMP = 2 : Actzo [M]IMP : Affzo [M]IMP
# SEGAY  US 2325-88174 BULDEM
 If dim([M]FLGDEMA) > 0 & func SUBEML.DISP_BULDEM([M:VEP0]EMP,[M:VEP0]CTRNUM,[M:VEP0]CTRDAT)<>0 : [M]FLGDEMA = 1 :  Actzo [M]FLGDEMA : Affzo [M]FLGDEMA :Endif
Endif
# Verrouillé US1918 65062
If [M:VEP0]MODIF=0
  [M]FLGLOC = 1 :  Grizo [M]FLGLOC : Affzo [M]FLGLOC
Else
  [M]FLGLOC = 1
  If ([M:VEP1]FLGLOCK <> 2 & [M:VEP0]OLDLOCK=2) | [M:VEP1]FLGLOCK = 2 & [M:VEP0]OLDLOCK<>2
     [M]FLGLOC = 2
  Endif
  Actzo [M]FLGLOC : Affzo [M]FLGLOC
Endif
If [M:VEP1]FLGLOCK = 2
   [M]ANU = 1 :  Grizo [M]ANU : Affzo [M]ANU
   [M]INI = 1 :  Grizo [M]INI : Affzo [M]INI
   [M]GEN = 1 :  Grizo [M]GEN : Affzo [M]GEN
   [M]TPS = 1 :  Grizo [M]TPS : Affzo [M]TPS
   [M]VRA = 1 :  Grizo [M]VRA : Affzo [M]VRA
   [M]ANA = 1 :  Grizo [M]ANA : Affzo [M]ANA
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
   If dim([M]IJSS)>=0 : [M]IJSS = 1 :  Grizo [M]IJSS : Affzo [M]IJSS : Endif
#   [M]IJSS = 1 :  Grizo [M]IJSS : Affzo [M]IJSS
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
   [M]FLGPREPAY = 1 :  Grizo [M]FLGPREPAY : Affzo [M]FLGPREPAY
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
   [M]CAL = 1 :  Grizo [M]CAL : Affzo [M]CAL
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
   If [M:VEP0]MODIF=1
      [M]IMP = 2 : Actzo [M]IMP : Affzo [M]IMP
# SEGAY  US 2325-88174 BULDEM
      If dim([M]FLGDEMA) > 0 & func SUBEML.DISP_BULDEM([M:VEP0]EMP,[M:VEP0]CTRNUM,[M:VEP0]CTRDAT)<>0
            [M]FLGDEMA = 1 :  Actzo [M]FLGDEMA : Affzo [M]FLGDEMA
      Endif
   Else
      [M]IMP = 1 : Grizo [M]IMP : Affzo [M]IMP
   Endif
Endif
End

