######################################################################################
#81491
Subprog C_PAYDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]PYRDAT
 GMESSAGE= mess(229,10703,1)
 mkstat=2 : End
Endif
If VALEUR>eomonth([M]PYRDAT)
 Local Integer OK
 OK = 2
 Call AVERTIR(mess(232,10703,1),OK) From GESECRAN
 If OK=1 : mkstat = 2 : End : Endif
Endif
End


