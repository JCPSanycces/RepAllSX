Subprog AS_ANU(VALEUR)
Variable Integer VALEUR
If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2 | [M:VEP1]FLGLOCK = 2
 VALEUR = 1
 Grizo [M]ANU
Endif
End

Subprog AS_INI(VALEUR)
Variable Integer VALEUR
If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2 | [M:VEP1]FLGLOCK = 2
 VALEUR = 1
 Grizo [M]INI
Endif
End

Subprog AS_GEN(VALEUR)
Variable Integer VALEUR
#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2 | [M:VEP0]FLGTPS<>2 | [M:VEP1]FLGLOCK = 2
# VALEUR = 1
# Grizo [M]GEN
#Endif

If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2 | [M:VEP0]FLGTPS<>2 | [M:VEP1]FLGLOCK = 2
 VALEUR = 1
 Grizo [M]GEN
Endif
#LIPET - 2017-05-20 - END
End

Subprog AS_TPS(VALEUR)
Variable Integer VALEUR
#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2 | [M:VEP0]FLGTPS<>2  | [M:VEP1]FLGLOCK = 2
