Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
If GACTION="VEPC"
 If [M]PAYDAT<VALEUR
  [M]PAYDAT=VALEUR
  Affzo PAYDAT
 Endif
Endif
End


