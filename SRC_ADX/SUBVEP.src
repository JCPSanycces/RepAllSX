Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
If VALEUR=2 | (GINTMT & [F:ID]FLGINT=2)
#If VALEUR=2
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
 Actzo [M]CTRNUM
Else
 Grizo [M]CTRNUM
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("HRCTR", VALEUR,"") From CONTOBJ
Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
Call LECTURE("CPY", [F:FCY]LEGCPY, "") From CONTOBJ
If [F:CPY]LEG<>GCURLEG
 GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
 mkstat = 2
Endif
If [M:DIA]DATEXT<>[0/0/0]
 Local Integer STAT
 Call CTRL_EXT([M:DIA]DATEXT,[M:DIA]EMP,VALEUR,STAT)
 If !STAT
  # Aucune paye extournée n'a été faite à cette date
  GMESSAGE = mess(177,10703,1)
  mkstat = 2 : End
 Endif
Endif

#MIPEA - 2017-07-04 - X3-43019- START
#LIPET - 2017-06-12 - X3-28766 - START
#JOJAC - 2017-03-06 - START
#[M:DIA]PERCOD = [F:HRCTR]PERCOD : Affzo [M:DIA]PERCOD
#Call AM_PERCOD([F:HRCTR]PERCOD)
#JOJAC - 2017-03-06 - END
#LIPET - 2017-06-12 - X3-28766 - END
#MIPEA - 2017-07-04 - X3-43019- END
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()

#LIPET - 2017-06-12 - X3-28766 - START
##JOJAC - 2017-03-06 - START
#[M:DIA]PERCOD = [F:HRCTR]PERCOD : Affzo [M:DIA]PERCOD
#Call AM_PERCOD([F:HRCTR]PERCOD)
##JOJAC - 2017-03-06 - END
#LIPET - 2017-06-12 - X3-28766 - END

If [M:DIA]DATEXT=[0/0/0]
 [M]STRDAT = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
 #JOJAC - START
 [M]ENDDAT = gdat$(func DIVPAYE.INIPARUSR("FINPAY",GUSER,""))
 #JOJAC - END

 Gosub INIT_CTR
Endif
End

$INIT_CTR
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
If clalev([F:HRCTRX])=0 : Local File EMPLOCTR   [HRCTRX] : Endif

[M]EMP    = [F:HRCTR]REFNUM
[M]CTRNUM = [F:HRCTR]CTRNUM
[M]FCY    = [F:HRCTR]ETRFCY
[M]SRV    = [F:HRCTR]ETRSRV
[M]PRF    = [F:HRCTR]PROPRF
#JOJAC - X3-27295 -  2017-03-06 - START
#MIPEA - 2017-07-13- US X3-48416- START
#[M]CTRDAT = [F:HRCTR]CTRDAT
#MIPEA - 2017-11-13- US X3-59695- START
[M]CTRDAT = [F:HRCTR]CTRDAT
#[M]CTRDAT = [F:HRCTR]XITDAT
#MIPEA - 2017-11-13- US X3-59695- END
#MIPEA - 2017-07-13- US X3-48416- END
#JOJAC - X3-27295 -  2017-03-06 - END
#JASMI - 2017-02-20 - START
##JOJAC - 2016-12-12 - START
#[M]PERCOD = [F:HRCTR]PERCOD
##JOJAC - 2016-12-12 - END
#JASMI - 2017-02-20 - END
If [F:ID]FLGINT<>2
 Local Integer UPDCTRDAT
 [L]UPDCTRDAT=0
 [M]STRCTRDAT = [F:HRCTR]CTRDAT
 If [F:HRCTR]FLGCREBUL<>2
  #Search the real started contrat record (= checked with breakdown)
  Filter [HRCTRX] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT & FLGCREBUL=2
  Read [HRCTRX]CTR0 Last
  Filter [HRCTRX]
  [M]STRCTRDAT = [F:HRCTRX]CTRDAT
 Endif
 #Search the laster contrat record (= not checked with breakdown)
 If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<[M]ENDDAT
  For [HRCTRX]CTR0 Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT>[F:HRCTR]XITDAT
   If [F:HRCTRX]FLGCREBUL=2 : Break : Endif
   [M]CTRDAT = [F:HRCTRX]CTRDAT
   [L]UPDCTRDAT=1
   Next
 Endif
 If [L]UPDCTRDAT
  # Read the good contrat because [M]CTRDAT could be updated before...
  Read[F:HRCTR]CTR0=[M]EMP;[M]CTRNUM;[M]CTRDAT
 Endif
 [M]STRDAT = max([M]STRCTRDAT,[M]STRDAT)
 ##**
 If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=[M]STRDAT & [F:HRCTR]XITDAT<=[M]ENDDAT
  [M]ENDDAT = [F:HRCTR]XITDAT
 Endif
Elsif GINTMT
 [M]STRCTRDAT = [F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 : [M]STRDAT=[F:HRCTR]RETDATEFF : Else [M]STRDAT = [F:HRCTR]CTRDAT : Endif
 If [F:HRCTR]XITDAT<>[0/0/0]: [M]ENDDAT = [F:HRCTR]XITDAT : Endif
 Gosub INIT_PSN
Endif
Gosub CHARGE_MATRI
Affzo 5-15

Close Local File [HRCTRX]
#[M]CTRNUM = [F:HRCTR]CTRNUM
#[M]FCY    = [F:HRCTR]ETRFCY
#[M]SRV    = [F:HRCTR]ETRSRV
#[M]PRF    = [F:HRCTR]PROPRF
#[M]CTRDAT = [F:HRCTR]CTRDAT
#If [F:HRCTR]CTRDAT>=[M]STRDAT & [F:HRCTR]CTRDAT<=[M]ENDDAT
# [M]STRDAT = [F:HRCTR]CTRDAT
#Endif
#If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=[M]STRDAT & [F:HRCTR]XITDAT<=[M]ENDDAT
# [M]ENDDAT = [F:HRCTR]XITDAT
#Endif
#Gosub CHARGE_MATRI
#Affzo 10-15
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Return

#MIPEA - 2016-07-18 - REQ 114309 US274 - START
########################
$INIT_PSN
Local Integer NBCTR , NUMCTR , TBNUM(1..100)
Local Char    LIBCTR(80)(0..100)
Local Date    TBDEB(0..100) , TBFIN(0..100)
NBCTR = 0 : NUMCTR=1
Filter [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & BUL="" & PSNSTRDAT<=[M]ENDDAT & PSNENDDAT>=[M]STRDAT & CTRDAT=[F:HRCTR]CTRDAT
If [F:HRCTR]CALPAY=1 #Bulletin par contrat
    NBCTR = 1
    TBNUM(NBCTR)  = 0
    LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-":"-format$(GFMD,[F:HRCTR]CTRDAT)-format$(GFMD,[F:HRCTR]XITDAT)
&                     -[F:FCY]FCY-[F:FCY]FCYNAM
   For [PSN]PSN0
    If TBDEB(NBCTR)=[0/0/0]
      TBDEB(NBCTR)  = max([F:PSN]PSNSTRDAT,[M:DIA]STRDAT)
      TBFIN(NBCTR)  = min([F:PSN]PSNENDDAT,[M:DIA]ENDDAT)
    Elsif month([F:PSN]PSNENDDAT)=month(TBDEB(NBCTR))
      TBFIN(NBCTR)  = max([F:PSN]PSNENDDAT,TBFIN(NBCTR))
    Endif
   Next
   If TBDEB(NBCTR)=[0/0/0] : NBCTR=0 : Endif
 Else     :#Bulletin par prestation
  For [PSN]PSN0
   NBCTR += 1
   TBNUM(NBCTR)  = [F:PSN]PSNNUM
   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-"("+num$([F:PSN]PSNNUM)+")"-":"-format$(GFMD,[F:PSN]PSNSTRDAT)-format$(GFMD,[F:PSN]PSNENDDAT)
&               -[F:FCY]FCY-[F:FCY]FCYNAM
   TBDEB(NBCTR)  = max([F:PSN]PSNSTRDAT,GMOIPAY)
   TBFIN(NBCTR)  = min([F:PSN]PSNENDDAT,eomonth(GMOIPAY))
  Next
Endif
Filter [PSN]
If NBCTR=0
 GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
 mkstat = 2 : End
Elsif NBCTR>1
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0 : mkstat = 2 : End : Endif
Endif
[M]PSNNUM = TBNUM(NUMCTR)
[M]STRDAT = TBDEB(NUMCTR)
[M]ENDDAT = TBFIN(NUMCTR)
Return
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

###########################################################################################
## Contrôles des dates
###########################################################################################

#---------------
#Date de paie
#---------------
Subprog AS_PYRDAT(VALEUR)
Variable Date    VALEUR
If GACTION<>"VEPC"
 Raz [M]SELBUL
Else
 If VALEUR=[0/0/0]
  VALEUR = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
 Endif
Endif
End

Subprog C_PYRDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK

If GACTION<>"VEPC"
 If [M]SELBUL<>"" : # On est passé par la sélection
  [M]BUL    = [M]SELBUL
  [M]SELBUL = ""
  mkstat    = 4
  End
 Endif
 If VALEUR<>[M]PYRDAT
  Call SELBUL([M:VEP0]EMP,VALEUR,"",[0/0/0],[M]BUL) From DIVPAYE
  If [M]BUL = ""
   GMESSAGE = mess(23,100,1) : # Fiche inexistante
   mkstat = 2 : End
  Endif
 Endif
Else
 Call LECTURE("EML",[M]EMP,"") From CONTOBJ
 If [F:ID]FLGINT<>2
   Filter [VEP] Where EMP=[M]EMP & CTRNUM=[M]CTRNUM
   Read [VEP]VEP0 Last
   Filter [VEP]
   If fstat<=2 & VALEUR<[F:VEP]PYRDAT
    # Paye existante au
    GMESSAGE = mess(20,10702,1)-format$("D:"+GFMDAT4,[F:VEP]PYRDAT)
    mkstat = 2 : End
   Endif
   If fstat<=2 & [F:VEP]STA<2 & [F:VEP]CTRDAT=[M]CTRDAT & [F:VEP]FCY=[M]FCY
    # Paye non calculée au
    GMESSAGE = [F:VEP]EMP-":"-mess(24,10702,1)-format$("D:"+GFMDAT4,[F:VEP]PYRDAT)
    mkstat = 2
    End
   Endif
   #JOJAC - 2016-12-12 - START
  #If VALEUR<GMOIPAY or VALEUR>eomonth(GMOIPAY)+GJMAX
   ## Date incompatible avec le mois de paye
   #GMESSAGE = mess(21,10702,1)-"("+format$("D:"+GFMMOI,GMOIPAY)+")"
   #mkstat = 2 : End
  #Endif
  #JOJAC - 2016-12-12 - END

  #LIPET - 2018-07-24 -X3-100995 - START
  If [M]STRDAT<[M]CTRDAT
    GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
    mkstat = 2 : End
  Endif
  Read [HRCTR]CTR0=[M]EMP;[M]CTRNUM;[M]CTRDAT
  If fstat<=4
    If ([HRCTR]FLGRET=2 & [M]STRDAT<[HRCTR]RETDATEFF) | ([HRCTR]FLGRET<2 & [M]STRDAT<[M]STRCTRDAT)
      GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
      mkstat = 2 : End
   Endif
   If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<[M]STRDAT
    GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
    mkstat = 2 : End
   Endif
  Endif
  #LIPET - 2018-07-24 -X3-100995 - END

  If VALEUR<GMOIPAY+GJMAX
   # Date en dehors de la période de paye
   OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,GMOIPAY+GJMAX)
&   +"-"+format$("D:"+GFMDAT4,eomonth(GMOIPAY)+GJMAX)+")",OK) From GESECRAN
   If OK<>2 : mkstat = 2 : End : Endif
  Endif
 Endif
Endif

End

