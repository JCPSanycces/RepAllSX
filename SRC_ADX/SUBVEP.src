#############################################################
## Copie texte bas de bulletin
#############################################################
$COPIETXT
Local Char CRITVEP (250)
Local Char CRITPOP (250)
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Local Char WCODPOP(GLONPOP)
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
CRITVEP="[F:VEP2]PST<3"
CRITPOP="1=1"

If [M:DIA]PRF=2
 CRITVEP -= '& [F:VEP2]PRF = "'+[M:VEP1]PRF+'"'
Endif
If [M:DIA]SRV=2
 CRITVEP -= '& [F:VEP2]SRV = "'+[M:VEP1]SRV+'"'
Endif
If [M:DIA]POP=2
 Filter [HRPOA] Where COD<>"" & REFNUM=[M:VEP0]EMP
 Read [HRPOA]POA1 First
 Filter [HRPOA]
 If fstat
  # Opération non réalisée : XXX n'appartient à aucune population
  Call MESSAGE(mess(157,123,1)-":"-[M:VEP0]EMP-mess(107,10702,1)) From GESECRAN
  Return
 Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
   CRITPOP   -= ' & COD<>"" '
   CRITPOP   -= ' & COD="'+[L]WCODPOP+'"'
  Else
   CRITPOP   -= ' & COD="" '
  Endif
# CRITPOP   -= '& [F:HRPOA]REFNUM = "'+[M:VEP0]EMP+'"'
# CRITPOP   -= ' & COD<>"" '
#Else
# CRITPOP   -= ' & COD="" '
#Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

Call DEBTRANS From GLOCK

Gosub TR_TXT
Return


$TR_TXT
GOK=1
Trbegin [VEP2]
For [HRPOA]POA1 Where evalue(CRITPOP)
 For [VEP2]VEP0 Where EMP=[F:HRPOA]REFNUM & PYRDAT=[M:VEP0]PYRDAT & evalue(CRITVEP)
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
  MATRI  = [F:HRPOA]REFNUM
  DATMAT = [M:VEP0]PYRDAT
  CTR    = [F:VEP2]CTRNUM
  Gosub LECEMP From WDEFTABLE
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
  Call CONTROLE([F:VEP2]EMP,[F:VEP2]PYRDAT,[F:VEP2]CTRNUM,"",OK,1) From DIVPAYE
  If OK
   Readlock [F:VEP2]Curr
   If !fstat
    If len([M:VEP1]TXT)=0 & [M:DIA]FLG=2
     Delete [BCB] Where CODBLB="VEPTXT" & IDENT2=[F:VEP2]BUL
    Else
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
     Read [BCB]BCB0="VEPTXT";"";[F:VEP2]BUL;"";""
     If fstat=5 | [M:DIA]FLG=2 | len(vireblc(func ACB.CHAR_([F:BCB]CLOB),2))=0
#     Look [BCB]BCB0="VEPTXT";"";[F:VEP2]BUL;"";""
#     If fstat=5 | [M:DIA]FLG=2
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
      Raz [F:BCB]
      [F:BCB]CLOB    = [M:VEP1]TXT
      [F:BCB]CODBLB  = "VEPTXT"
      [F:BCB]IDENT1  = ""
      [F:BCB]IDENT2  = [F:VEP2]BUL
      If fstat=5
       If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
       If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
       If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
       Write [BCB]
      Else
       If dim([F:BCB]UPDUSR)>0 : [F:BCB]UPDUSR = GUSER : Endif
       If dim([F:BCB]UPDDAT)>0 : [F:BCB]UPDDAT = date$ : Endif
       If dim([F:BCB]UPDTIM)>0 : [F:BCB]UPDTIM = time  : Endif
       Rewrite [BCB]
      Endif
      If fstat : GOK = 0 : Call FSTA("BCB") From GLOCK : Break 2 : Endif
     Endif
    Endif
   Endif
  Endif
 Next :#VEP2
Next :#POA
If GOK<>1
 Goto ROLL_TXT
Elsif !GOK
 Rollback
Endif
Commit
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
MATRI  = [M:VEP0]EMP
DATMAT = [M:VEP0]PYRDAT
CTR    = [M:VEP0]CTRNUM
DATCTR = [M:VEP0]CTRDAT
Gosub LECEMP From WDEFTABLE
# Repositionnement sur le contrat initial car le Lecemp a pu changer !
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Return

$ROLL_TXT
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_TXT : Endif


#############################################################
## Enchaînements
#############################################################
$ENCHAINE
Local Integer PASAPAS , ANUSAI , OKTEMPS
Local Char    MATRI(GLONEML), CTR(GLONHRCTR)
Local Date    DATMAT, DATCTR
Local Char    BULLETIN(GLONVCR)
Local Integer PRESTAT(1..100) , NBPREST
Local Integer STAT :#95723

#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
##**Gosub OUVFIC From TRTTPS
##**
Gosub OUVFIC From TRTTPS
#LIPET - 2017-05-20 - END
MATRI    = [M:VEP0]EMP
DATMAT   = [M:VEP0]PYRDAT
BULLETIN = [M:VEP0]BUL
CTR      = [M:VEP0]CTRNUM
DATCTR   = [M:VEP0]CTRDAT
OKTEMPS  = 1
Gosub LECEMP From WPDEFTABLE

# Repositionnement sur le contrat initial car le Lecemp a pu changer !
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR

If [M:DIA]TRA=2
 Call OUVRE_TRACE([M:VEP0]EMP-[M:VEP0]SRN) From LECFIC
Endif

Read [F:VEP]VEP0 = BULLETIN

# Sauvegarde des prestations avant annulation
Raz PRESTAT , NBPREST
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
If [F:ID]FLGINT=2 & GINTMT=1
#If [F:ID]FLGINT<>2 & GINTMT=1
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
 For [PSN]PSN2 Where BUL=BULLETIN
  NBPREST += 1
  PRESTAT(NBPREST) = [F:PSN]PSNNUM
 Next
Endif

# Annulation calcul
If [M:DIA]ANU=2 or [M:DIA]INI=2
 If [M:DIA]INI=2
  ANUSAI = 1
 Else
  ANUSAI = 0
 Endif
 Gosub TR_ANU
Endif
# Réinit de paye
If [M:DIA]INI=2
 If [M:DIA]TRA=2
  Call ECR_TRACE(mess(45,10709,1),0) From GESECRAN : # Réinitialisation paye
 Endif
 Gosub REINIT
 [M:VEP0]BUL = BULLETIN
 If [M:DIA]TRA=2
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Endif

#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
#If 1=2
# Vérif périodes d'extraction
#If GTPS & [M:VEP0]FLGTPS=2
#If [M:VEP0]FLGTPS=2

#JASMI - 2017-06-06 - START
#If 1=2
#JASMI - 2017-06-06 - END
# Vérif périodes d'extraction
If GTPS & [M:VEP0]FLGTPS=2
#If [M:VEP0]FLGTPS=2
#LIPET - 2017-05-20 - END
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
 If [M:DIA]GEN=2 or [M:DIA]TPS=2 or [M:DIA]VRA=2 or [M:DIA]ANA=2
  #JOJAC - 2017-03-23 - START
  #Raz [F:HRPEO]
  #LESITE = [F:HRCTR]ETRFCY
  #Call PERIO(LESITE,MATRI) From SUBHRPEO
  #Read [HRPEO]PEO0=LESITE;DATMAT
  Raz [F:HRPEOD]
  Read [HRPEOD]HRPEOD1=[F:HRCTR]PERCOD;DATMAT
  #If fstat>2
   #Read [HRPEO]PEO0="";DATMAT
  #JOJAC - 2017-03-23 - END
   If fstat>2
    #On cherche si un paie extournée existe
    If clalev([F:VEPP])=0 : Local File VALEMP [VEPP] : Endif
    If clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
    Local Integer FOUNDPEO : FOUNDPEO=1
    Filter [F:VEPP] Where EMP=[M:VEP0]EMP & FCY=[F:HRCTR]ETRFCY & STRDAT=[M:VEP1]STRDAT & ENDDAT=[M:VEP1]ENDDAT & RVS<>2 & RVSDAT<>[0/0/0] & BUL<>[M:VEP0]BUL
    If rowcount([F:VEPP])>0 Then
     Read [F:VEPP] Last
     Filter [F:VEP2] Where EMP=[M:VEP0]EMP & FCY=[F:HRCTR]ETRFCY & STRDAT=[M:VEP1]STRDAT & ENDDAT=[M:VEP1]ENDDAT & RVS=2 & ORIDAT=[F:VEPP]PYRDAT & BUL<>[M:VEP0]BUL
     If rowcount([F:VEP2])>0 Then
      Read [F:HRPEO]PEO0=LESITE;[F:VEPP]PYRDAT
      If !fstat Then
       FOUNDPEO=2
      Endif
     Endif
     Filter [F:VEP2]
    Endif
    Filter [F:VEPP]

    If FOUNDPEO=1 Then
     #JOJAC - 2017-03-23 - START
     #Read [HRPEO]PEO0(1) = LESITE
     Read [HRPEOD]HRPEOD1(1) = [F:HRCTR]PERCOD
     #JOJAC - 2017-03-23 - END
     If fstat<=2
      #JOJAC - 2017-03-23 - START
#      Filter [HRPEO] Where FCY=LESITE & PYRDAT>=DATMAT
#      Read [HRPEO]PEO0 First
#      Filter [HRPEO]
#      If fstat>2
#       Filter [HRPEO] Where FCY="" & PYRDAT>=DATMAT
#       Read [HRPEO]PEO0 First
#       Filter [HRPEO]
      Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>=DATMAT
      Read [HRPEOD]HRPEOD0 First
      Filter [HRPEOD]
     #JOJAC - 2017-03-23 - END
#      If fstat>2
#       Call ECR_TRACE(MATRI-format$("D:"+GFMDAT,DATMAT)-":"-mess(92,10703,1),1) From GESECRAN
#       # Pas de période d'extraction des temps
#       OKTEMPS = 0
#      Endif
      #Endif
     # FQ89545 - 22/04/13 - Si pas de période d'extraction sur le site
     #JOJAC - 2017-03-23 - START
     #Else
     # Filter [HRPEO] Where FCY="" & PYRDAT>=DATMAT
     # Read [HRPEO]PEO0 First
     Endif
     #JOJAC - 2017-03-23 - START
     If fstat>2
      # FQ89736 - 02/05/13 - DATMAT et non DATPAY
#     Call ECR_TRACE(MATRI-format$("D:"+GFMDAT,DATPAY)-":"-mess(92,10703,1),1) From GESECRAN
      Call ECR_TRACE(MATRI-format$("D:"+GFMDAT,DATMAT)-":"-mess(92,10703,1),1) From GESECRAN
      # Pas de période d'extraction des temps
      OKTEMPS = 0
     Endif
     # Fin FQ89545
   Endif
  Endif
 Endif
Endif
 # Remplissage des temps
 If [M:DIA]GEN=2 & OKTEMPS
  If [M:DIA]TRA=2
   Call ECR_TRACE(mess(39,10709,1),0) From GESECRAN
  Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
  Call MAJ_GEN([M:VEP0]EMP,[M:VEP0]PYRDAT,[M:VEP0]CTRNUM,1,0,[M:VEP0]CTRDAT) From TRTREM #MIPEA - source not on GX3APP
  #Call MAJ([M:VEP0]EMP,[M:VEP0]PYRDAT,[M:VEP0]CTRNUM,1,0) From TRTREM
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
  If [M:DIA]TRA=2
   Call ECR_TRACE("",0) From GESECRAN
  Endif
 Endif

 If ([M:DIA]TPS=2 or [M:DIA]VRA=2) & OKTEMPS
  If [M:DIA]TPS=2 & [M:DIA]TRA=2
   Call ECR_TRACE(mess(40,10709,1),0) From GESECRAN : # Calculs de synthèse des temps
  Endif
  If [M:DIA]VRA=2 & [M:DIA]TRA=2
   Call ECR_TRACE(mess(41,10709,1),0) From GESECRAN : # Mise à jour des variables de paye
  Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
  #Si plusieurs périodes d'activité sur le même mois de paie, on écrasait la synthèse de la 1ère période lors du calcul de
  # la seconde. Maintenant, on ne remet à 0 que sur le calcul de la 1ère période d'activité
  Local Integer FIRSTCTR : FIRSTCTR=0
  Local Date WCTRD(0..8)
  Raz WCTRD
  If clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
  Filter [F:VEP2] Where EMP=[M:VEP0]EMP & PYRDAT=[M:VEP0]PYRDAT Order By CTRDAT
  If rowcount([F:VEP2])>1 Then
    Read [F:VEP2] First
    If [F:VEP2]CTRDAT=[M:VEP0]CTRDAT Then
      FIRSTCTR=0
    Else
      FIRSTCTR=1
