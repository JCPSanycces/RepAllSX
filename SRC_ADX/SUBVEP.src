#[M]SRVLIB = [F:SRV]DES
Call LECTEXTRA([M]PRFLIB,"PROFIL","PRFDES",GCURLEG,[F:PRF]PRFCOD) From ATEXTRA
Call LECTEXTRA([M]SRVLIB,"SERVICE","DES",[F:SRV]COD,"") From ATEXTRA
[M]FLGTPS = [F:ID]FLGTPS
If dim([M]SUPLIB)>0
 Call LECTEXTRA([M]SUPLIB,"PROFIL","PRFDES",GCURLEG,[M]PRFSUP) From ATEXTRA
 Call LECTURE("PRF",[M]PRFSUP,"") From CONTOBJ
 #[M]SUPLIB = [F:PRF]PRFDES
#MIPEA - 2016-07-14 - REQ 114309 US274 - END
Endif

If dim([M]DATCTR)>0
 Read [HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
 If !fstat : [M]DATCTR = [F:HRCTR]CTRDAT : Endif
Endif
# Verrouillé US1918 65062
If [F:VEP]LOCKUSR <> ""
  Call LECTEXTRA([M:VEP1]LOCKNOMUSR,"AUTILIS","INTUSR",[F:VEP]LOCKUSR,"") From ATEXTRA
Endif
# END US1918 65062
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Call VALDEF_FLD_ANA([M]CPY)
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

Return

