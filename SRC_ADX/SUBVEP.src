$OUVRE_BOITE
K = find("EML",OBJLIS(1..8))
If K
 BROWEML = "GAU_CHE"+num$(K)
Endif
Return

$RAZCRE
Gosub CHARGE_TABLE
FLGTXT=0
Return

$FILTRE
Raz FILTSUP
FILTSUP = "[F:CPY]LEG='"+GCURLEG+"'"
If GUSRACS<>2
 FILTSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find(SRV,GAUTSRV(1..GNBSERV))"
Endif
If dim(TUNNEL)=1 & TUNNEL=1 & find("EML",GPILCOD(1..GPILOBJ))
  FILTSUP -= '& EMP="'+CLE2+'"'
Endif
#MIPEA - 2016-07-14 - REQ 114309 US274 - START
If dim(TUNNEL)=1 & TUNNEL=1 & (find("CTR",GPILCOD(1..GPILOBJ)) | find("RET",GPILCOD(1..GPILOBJ))
&                              | find("HRDCV",GPILCOD(1..GPILOBJ)) | find("HRDCC",GPILCOD(1..GPILOBJ))):#90623
#If dim(TUNNEL)=1 & TUNNEL=1 & (find("CTR",GPILCOD(1..GPILOBJ)) | find("RET",GPILCOD(1..GPILOBJ)))
#JOJAC - 2017-04-13 - X3-29549 - START
# FILTSUP -= '& EMP="'+CLE2+'" & CTRNUM="'+GBIDC1+'"'
 FILTSUP -= '& EMP="'+CLE2+'" & CTRNUM="'+[M:CTR0]CTRNUM+'"'
 #JOJAC - 2017-04-13 - X3-29549 - END
Endif
If FILTSUP = "" : FILTSUP = "1" : Endif
#MIPEA - 2016-07-14 - REQ 114309 US274 - END
Return

$FILGAUCHE
FILGAUCHE ="[F:CPY]LEG='"+GCURLEG+"'"
If TUNNEL=1 & (find("CTR",GPILCOD(1..GPILOBJ)) | find("RET",GPILCOD(1..GPILOBJ)))
  FILGAUCHE -= '& EMP="'+CLE2+'" & CTRNUM="'+GBIDC1+'"'
Elsif TUNNEL=1 & find("EML",GPILCOD(1..GPILOBJ))
  FILGAUCHE -= '& EMP="'+CLE2+'"'
Elsif MOICUR<>[0/0/0]
  FILGAUCHE -= "& PYRMON=["+format$(GFMD,MOICUR)+"]"
#MIPEA - 2016-07-14 - REQ 114309 US274 - START
Else
  FILGAUCHE = ""
Endif
If TUNNEL=1 & (find("RET",GPILCOD(1..GPILOBJ))| find("HRDCV",GPILCOD(1..GPILOBJ)) | find("HRDCC",GPILCOD(1..GPILOBJ))):#90623
#If TUNNEL=1 & find("RET",GPILCOD(1..GPILOBJ))
#JOJAC - 2017-04-13 - X3-29549 - START
#  FILGAUCHE -= '& EMP="'+CLE2+'" & CTRNUM="'+GBIDC1+'"'
 FILGAUCHE -= '& EMP="'+CLE2+'" & CTRNUM="'+[M:CTR0]CTRNUM+'"'
#JOJAC - 2017-04-13 - X3-29549 - END


Endif
#MIPEA - 2016-07-14 - REQ 114309 US274 - END
Return

$CLE_GAUCHE
If TUNNEL=1  & ( find("EML",GPILCOD(1..GPILOBJ)) | find("CTR",GPILCOD(1..GPILOBJ)) | find("RET",GPILCOD(1..GPILOBJ)) )
 CLELISTE = "EMP;PYRDAT Desc;BUL Desc"
Endif
Return

$TIT
For I=2 To NBECRAN
 TITFOLD(I-1) = [M:VEP0]TABSHO(I-1)
Next I
TITFOLD(NBECRAN) = mess(104,10703,1) : # Bulletin
Return

$CHARGE_TABLE
Local Integer NBECRAN
NBECRAN = 1
For [ADI]CODE Where NUMTAB=10337 & LEG=GCURLEG : #table diverse "salarié"
 NBECRAN += 1
 [M:VEP0]TABCOD(NBECRAN-1) = [F:ADI]CODE
 Call LECTEXTRA([M:VEP0]TABLIB(NBECRAN-1),"ATABDIV","LNGDES","10337",[F:ADI]CODE) From ATEXTRA
 Call LECTEXTRA([M:VEP0]TABSHO(NBECRAN-1),"ATABDIV","SHODES","10337",[F:ADI]CODE) From ATEXTRA
Next

#Initialisation des zones "CODPAG" des différents écrans
#MIPEA - 2016-07-19 - REQ 114309 US274 - START
#If !NBECRAN : GMESSAGE="Pas d'onglet" : OK=0 : Return : Endif #MIPEA - message to be moved to local menu
#MIPEA - 2016-07-19 - REQ 114309 US274 - END
For I=2 To NBECRAN
 Gosub SETMASK
 [M]CODPAG = [M:VEP0]TABCOD(I-1)
 [M]LIBPAG = [M:VEP0]TABLIB(I-1)   #Initialisation du libellé de l'onglet
 Affzo CODPAG,LIBPAG
Next I
Return

$SETMASK
Case I
 When 1  : Default Mask [VEP1]
 When 2  : Default Mask [VEP2]
 When 3  : Default Mask [VEP3]
 When 4  : Default Mask [VEP4]
 When 5  : Default Mask [VEP5]
 When 6  : Default Mask [VEP6]
 When 7  : Default Mask [VEP7]
 When 8  : Default Mask [VEP8]
 When 9  : Default Mask [VEP9]
 When 10 : Default Mask [VEPA]            :#91862
 When 11 : Default Mask [VEPB]
 When 12 : Default Mask [VEPC]
 When 13 : Default Mask [VEPD]
Endcase
Return

$ENREG_TXT
For I=1 To NBECRAN
 Gosub SETMASK
 If dim([M]TXT)>0
  If len([M]TXT)>0
   Raz [F:BCB]
   [F:BCB]CLOB   = [M]TXT
   [F:BCB]CODBLB = "VEPTXT"
   [F:BCB]IDENT1 = ""
   [F:BCB]IDENT2 = [F:VEP]BUL
   [F:BCB]IDENT3 = ""
   [F:BCB]IDENT4 = ""
   If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
   If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
   If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
   Write [BCB]
   If fstat
    GOK = 0 : Call FSTA("BCB") From GLOCK : Return
   Endif
  Endif
  Break
 Endif
Next
Return

$GAUCHE
Case currbox
 When BROWEML
  Filter [VEP] Where EMP=[F:ID]REFNUM
  Read [VEP]VEP0 Last
 Endcase
Return

$VERROU
SYMBOLEV = "VEP"+format$("D:"+GFMDAT,[M:VEP0]PYRDAT)+"\"+[M:VEP0]CTRNUM+format$("D:"+GFMDAT,[M:VEP0]CTRDAT)
Lock =SYMBOLEV
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 OK = 0
 Return
Endif
Return

$DEVERROU
Unlock =SYMBOLEV
Return

$LIENS
Diszo [VEP0]BUL
Diszo [VEP0]CTRNUM
Gosub CHARGE_MATRI
Gosub CHARGE_TABLE
##**72216
Gosub CHARGE_THR

#JASMI - START
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA   [HRPEOH] : Endif
Read [HRPEOH]HRPEOH0 = [VEP]PERYEA;[VEP]PERCOD
#JASMI - END

#LIPET - 2018-10-15 - X3-112843 - START
If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
Read [HRPEOD]HRPEOD0 = [VEP]PERCOD;[VEP]PERYEA;[VEP]PERNUM
#LIPET - 2018-10-15 - X3-112843 - END

For I=2 To NBECRAN
 Gosub SETMASK
 Raz [M]TBL
Next I
For [VLA]VLA0 Where TYP=4 & LEG="" & CPY="" & FCY="" & EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
 Read [F:VRA]VRA0 = GCURLEG;[F:VLA]VARCOD
 If !fstat
  I = find([F:VRA]PAGEMP,[M:VEP0]TABCOD(0..NBECRAN-1))
  Gosub SETMASK
 Endif
 If I>=2
  nolign = [M]TBL+1
  [M] = [F:VLA]
  [M]VARCOD(nolign-1) = [F:VLA]VARCOD
  [M]VALEUR(nolign-1) = [F:VLA]VARVAL
  [M]RANG(nolign-1)   = [F:VRA]ROWEMP
  [M]TBL += 1
#MIPEA - 2016-07-14 - REQ 114309 US274 - START
  Filter [BCB2] Where CODBLB="VARTXT" & IDENT1=[F:VLA]VARCOD & IDENT2=[F:VEP]BUL
  If rowcount([BCB2])>0 Then
    [M]TXTFLG(nolign-1)=2
  Else
    Filter [BCB2] Where CODBLB="VEPTXT" & IDENT1=[F:VLA]VARCOD & IDENT2=[F:VEP]BUL
    If rowcount([BCB2])>0 Then
      [M]TXTFLG(nolign-1)=2
    Else
      [M]TXTFLG(nolign-1)=1
    Endif
  Endif
  Filter [BCB2]
# Endif
# Filter [BCB2] Where find(CODBLB,"VARTXT","VEPTXT")<>0 & IDENT1=[F:VLA]VARCOD & IDENT2=[F:VEP]BUL
# Read [BCB2]BCB0 Last
# Filter [BCB2]
# If !fstat
#  [M]TXTFLG(nolign-1)=2
# Else
#  [M]TXTFLG(nolign-1)=1
#MIPEA - 2016-07-14 - REQ 114309 US274 - END
 Endif
Next
#MIPEA - 2016-07-14 - REQ 114309 US274 - START
Gosub CHARGE_ANA
#If GOPTCANA>0
# [M:VEP1]NBRVAN = 0
# For [VAN]VAN0 Where EMP=[F:VEP]EMP & PYRDAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
