#    When 5 : If dim([M:VEP1]CCE5)>0 : [M:VEP1]CCE5([M:VEP1]NBRVAN) = [F:VAN]CCE(J-1) : Endif
#    When 6 : If dim([M:VEP1]CCE6)>0 : [M:VEP1]CCE6([M:VEP1]NBRVAN) = [F:VAN]CCE(J-1) : Endif
#    When 7 : If dim([M:VEP1]CCE7)>0 : [M:VEP1]CCE7([M:VEP1]NBRVAN) = [F:VAN]CCE(J-1) : Endif
#    When 8 : If dim([M:VEP1]CCE8)>0 : [M:VEP1]CCE8([M:VEP1]NBRVAN) = [F:VAN]CCE(J-1) : Endif
#    When 9 : If dim([M:VEP1]CCE9)>0 : [M:VEP1]CCE9([M:VEP1]NBRVAN) = [F:VAN]CCE(J-1) : Endif
#   Endcase
#  Next J
#  [M:VEP1]NBRVAN += 1
# Next
#Endif
#MIPEA - 2016-07-14 - REQ 114309 US274 - END

# Par defaut : droit de modif sur le bulletin
[M:VEP0]MODIF = 1

# Par defaut : droit de suppr sur le bulletin
GSUPPR = 1

If [F:ID]FLGINT<>2

 Filter [VEP2] Where EMP=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM
 Read [VEP2]VEP0 Last
 Filter [VEP2]
 If fstat<=2 & [F:VEP2]BUL<>[F:VEP]BUL
  #Pas le droit de supprimer si pas le dernier de la fiche contrat
  GSUPPR = 0
 Endif

 Filter [VEP2] Where EMP=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM & CTRDAT=[M:VEP0]CTRDAT
 Read [VEP2]VEP0 Last
 Filter [VEP2]
 If fstat<=2 & [F:VEP2]BUL<>[F:VEP]BUL
  #Pas le droit de modif  sur le bulletin, ni supprimer si pas le dernier de la fiche contrat
  [M:VEP0]MODIF = 0
 Endif

 If [M:VEP0]MODIF=1
  #Lecture du bulletin suivant
  Filter [VEP2] Where EMP=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM & BUL>[M:VEP0]BUL
  Read [VEP2]VEP0 First
  Filter [VEP2]
  If fstat<=2 & [F:VEP2]STA>1
   [M:VEP0]MODIF = 0
  Endif
 Endif

 If [M:VEP0]MODIF=1
  #Lecture du bulletin précedent
  Filter [VEP2] Where EMP=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM & BUL<[M:VEP0]BUL
  Read [VEP2]VEP0 Last
  Filter [VEP2]
  If fstat<=2 & [F:VEP2]STA<2
   [M:VEP0]MODIF = -1
  Endif
 Endif

Endif
# Le bulletin n'est pas modifiable si l'od de paye est comptabilisée ou en cours
# Le bulletin n'est pas modifiable si c'est une extourne
If [M:VEP1]PST>1 : [M:VEP0]MODIF = 0 : GSUPPR = 0 : Endif
If [M:VEP1]RVS=2 : [M:VEP0]MODIF = 0 : Endif

# Verrouillé US1918 65062
If [M:VEP1]FLGLOCK = 2
   [M:VEP0]OLDLOCK = 2
Endif

For I=2 To NBECRAN
 Gosub SETMASK
 Sorta [M]TBL [M]TBL Order By [M]RANG(indice)
Next I
If [M:VEP1]RVS<>2
 Effzo [VEP1]RVS,ORIDAT
 Grizo [VEP1]RVS,ORIDAT
Else
 Actzo [VEP1]RVS,ORIDAT
Endif
If [M:VEP1]RVSDAT=[0/0/0]
 Effzo [VEP1]RVSFLG,RVSDAT
 Grizo [VEP1]RVSFLG,RVSDAT
Else
 [M:VEP1]RVSFLG = 2
 Affzo [VEP1]RVSFLG,RVSDAT
 Actzo [VEP1]RVSFLG,RVSDAT
Endif
For I=1 To NBECRAN
 Gosub SETMASK
 If dim([M]TXT)>0
  Read [BCB]BCB0 = "VEPTXT";"";[F:VEP]BUL;"";""
  If !fstat
   [M]TXT    = [F:BCB]CLOB
   [M]SAVTXT = [F:BCB]CLOB
  Endif
  FLGTXT = 0
  Break
 Endif
Next
If dim([M:VEPX]NBLIG)>0
 Gosub LECPAY From SUBVEPX
 Actzo [VEPX]NBLIG
Endif
If [M:VEP0]MODIF>0 & VERROU & [M:VEP1]RVS<>2 & [M:VEP1]FLGLOCK <> 2
 [M:VEP0]CLC = "214" : # "258"
 [M:VEP0]ENV = "074" : # "269"
 [M:VEP0]ENC = "212" : # "264"
 [M:VEP0]L1 = mess(130,10703,1) : # Calcul
 [M:VEP0]L2 = mess(131,10703,1) : # Envers
 [M:VEP0]L3 = mess(132,10703,1) : # Enchaîne
Endif

# Verrouillé US1918 65062
If ([M:VEP0]MODIF<0 or [M:VEP1]FLGLOCK = 2) and VERROU
 [M:VEP0]ENC = "212" : # "264"
 [M:VEP0]L3 = mess(132,10703,1) : # Enchaîne
Endif

Gosub GETRPTBUL

### AWAITING MULTI CURRENCY
#MIPEA - 2017-10-11- US X3-59363- START
#JASMI - 2017-11-14 - X3-59363 - START
#Read [CPY]CPY0 = [M:VEP1]CPY
#If [F:CPY]ACCCUR <> [F:VEP]CURCOD
#  If dim([M:VEPX]CONAMT)>0 : Chgfmt [M:VEPX]CONAMT With 'Nz:11.2' : Endif
#Else
#  If dim([M:VEPX]CONAMT)>0 : Chgfmt [M:VEPX]CONAMT With '-Nz:11.2' : Endif
#Endif
If dim([M:VEPX]CONAMT)>0 : Chgfmt [M:VEPX]CONAMT With '-Nz:11.2' : Endif
If [F:VEP]CURCOD<>''
  Read [CPY]CPY0 = [M:VEP1]CPY
  If [F:CPY]ACCCUR <> [F:VEP]CURCOD
    If dim([M:VEPX]CONAMT)>0 : Chgfmt [M:VEPX]CONAMT With 'Nz:11.2' : Endif
  Endif
Endif
#JASMI - 2017-11-14 - X3-59363 - END
#MIPEA - 2017-10-11- US X3-59363- END
Return

$GETRPTBUL
[L]REPORT1=""
If [F:VEP]RPTBUL>""
 [L]REPORT1=[F:VEP]RPTBUL
Else
 If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
 Read [HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
 If !fstat : [L]REPORT1=[F:HRCTR]RPTBUL : Endif
Endif
If [L]REPORT1=""
 # Code review DBA : ce param est de niveau site, donc pas de GCURLEG ici mais le site comme en V6 !
 #Call PARAM(GCURLEG,"NOMRPTBUL",[L]REPORT1) From ADOVAL :#81084
 Call PARAM([M]FCY,"NOMRPTBUL",[L]REPORT1) From ADOVAL
Endif
Return

$CHARGE_MATRI
# Si GACTION=VEPC et pas de fiche salarié VEP, [F:VEP]EMP faux (contient le salarié de la fiche et non de Nouveau
#MIPEA - 2016-07-19 - REQ 114309 US274 - START
If clalev([F:PRF])=0  : Local File PROFIL    [PRF] : Endif
#MIPEA - 2016-07-19 - REQ 114309 US274 - END
If GACTION<>"VEPC"
 Read [F:ID]ID0 = [F:VEP]EMP
Endif
[M]SRN = [F:ID]NAM-[F:ID]SRN
Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#81085
If dim([M]LEG)>=0 : [M]LEG =[F:CPY]LEG : Endif
Call LECTURE("PRF",[M]PRF,GCURLEG) From CONTOBJ
Call LECTURE("SRV",[M]SRV,"") From CONTOBJ
[M]FCYNAM = [F:FCY]FCYNAM
[M]CPYNAM = [F:CPY]CPYNAM
#MIPEA - 2016-07-14 - REQ 114309 US274 - START
