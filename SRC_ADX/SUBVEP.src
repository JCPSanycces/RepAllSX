Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "SAIVALPAY"
GMOIPAY=[01/06/2013]
GFONC1 = "GESVEP"
Raz GBIDC1, GBIDC2
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIVALPAY","SAIVALPAY",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "CREATION"    : Gosub CREATION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "TITRE"       : Gosub TIT
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "AV_ANNULE"   : Gosub AV_ANNULE
 When "STATUT"      : Gosub STATUT
 When "GAUCHE"      : Gosub GAUCHE
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INIMOD"      : Gosub INIMOD
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "ABANDON"     : Gosub ABANDON
 When "CLE_GAUCHE"  : Gosub CLE_GAUCHE
 When "VERROU"      : Gosub VERROU
 When "DEVERROU"    : Gosub DEVERROU
 When "ANNULE"      : Gosub ANNULE #FRLAA - 2017-11-06 - X3-X3-62518
#-------------------------------------------------------------------------------
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
#MIPEA - 2016-07-13 - REQ 114309 US274 - START
 When "VERF_ANU"    : Gosub VERF_ANU
 When "STYLE"       : Gosub STYLE #DEHEN - 2014-05-20 - Requirement 116102  - US 3
 When "AP_IMPRIME"    : Gosub STATUT
#MIPEA - 2016-07-13 - REQ 114309 US274 - END
Endcase
Return





