Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
#LIPET - 2018-07-24 -X3-100995 - START
#
#Control moved to PYRDAT field
#
#If VALEUR<[M]CTRDAT
#  GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
#  mkstat = 2 : End
#Endif
#Read [HRCTR]CTR0=[M]EMP;[M]CTRNUM;[M]CTRDAT
#If fstat<=4
##MIPEA - 2016-07-20 - REQ 114309 US274 - START
#  If ([HRCTR]FLGRET=2 & VALEUR<[HRCTR]RETDATEFF) | ([HRCTR]FLGRET<2 & VALEUR<[M]STRCTRDAT)
#    GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
#    mkstat = 2 : End
# Endif
# If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<VALEUR
#  GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
#  mkstat = 2 : End
# Endif
#Endif
##MIPEA - 2016-07-20 - REQ 114309 US274 - END
#LIPET - 2018-07-24 -X3-100995 - END

If GACTION="VEPC" : # Si bouton Nouveau
 #Si extourne, VAR ou Bulletin suppl alors il faut laisser le droit de créer la paie sur une période identique à une paie existante
 #Paie extournée, Extourne & paie de remplacement sont sur des périodes identiques
 #Paie de VAR & Supp peuvent êtres ur une péridoe identique ou à cheval à une paie existante
#MIPEA - 2017-07-10 - X3-46083 - START
 Filter [VEP] Where EMP=[M]EMP & CTRNUM=[M]CTRNUM & PERCOD=[M]PERCOD & PERYEA=[M]PERYEA & PERNUM=[M]PERNUM
 Read [F:VEP]VEP0 Last
 Filter [VEP]
 If fstat<=2
#Filter [VEP] Where EMP=[M]EMP & CTRNUM=[M]CTRNUM
# Read [F:VEP]VEP0 Last
# Filter [VEP]
# If fstat<=2
#  If ([F:VEP]STRDAT>=[M]STRDAT | [F:VEP]ENDDAT>=[M]STRDAT)
#&      &([F:VEP]STRDAT<=[M]ENDDAT | [F:VEP]ENDDAT<=[M]ENDDAT)
#MIPEA - 2017-07-10 - X3-46083 - END
  #  # La période chevauche la période de la paye précédente
#MIPEA - 2017-06-27 - X3-46083 - START
    GERR = 2 : GMESSAGE = mess(122,10703,1)
#    OK = 2
#    Call AVERTIR(mess(122,10703,1),OK) From GESECRAN
#    If OK<>2 : mkstat=2 : End : Endif
#MIPEA - 2017-06-27 - X3-46083 - END
  Endif
 Endif
#MIPEA - 2017-07-10 - X3-46083 - START
#Endif
#MIPEA - 2017-07-10 - X3-46083 - END
End

#---------------
#Date de fin de période
#---------------
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
Local Integer NBCTR , NUMCTR , TBNUM(1..100)
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(80)(0..100)
Local Date    TBDEB(0..100) , TBFIN(0..100)
If [F:ID]FLGINT<>2
 Read [HRCTR]CTR0=[M]EMP;[M]CTRNUM;[M]CTRDAT
 If fstat<=4
  If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<VALEUR
   GMESSAGE = mess(26,10702,1) : # Période incompatible avec les entrées-sorties
   mkstat = 2 : End
  Endif
 Endif

Elsif GINTMT=1
 NBCTR = 0
 For [HRCTR]CTR0 Where REFNUM=[M]EMP & STACTR=2
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Case [F:HRCTR]CALPAY
   When 1 : # Paye par contrat
    If [F:HRCTR]CTRDAT<=VALEUR & [F:HRCTR]XITDAT>=[M]STRDAT
     Filter [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & BUL="" & PSNSTRDAT<=VALEUR & PSNENDDAT>=[M]STRDAT
     Read [PSN] First
     Filter [PSN]
     If fstat=0
      NBCTR += 1
      TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
      TBNUM(NBCTR)  = 0
      LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-":"-format$(GFMD,[F:HRCTR]CTRDAT)-format$(GFMD,[F:HRCTR]XITDAT)
&                     -[F:FCY]FCY-[F:FCY]FCYNAM
      TBDEB(NBCTR)  = max([F:HRCTR]CTRDAT,[M:DIA]STRDAT)
      TBFIN(NBCTR)  = min([F:HRCTR]XITDAT,VALEUR)
     Endif
    Endif
   When 2,3 : # Paye par prestation ou par jour
    If [F:HRCTR]CTRDAT<=VALEUR & [F:HRCTR]XITDAT>=[M]STRDAT
     For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & BUL="" & PSNSTRDAT<=VALEUR & PSNENDDAT>=[M]STRDAT
      NBCTR += 1
      TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
      TBNUM(NBCTR)  = [F:PSN]PSNNUM
      LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-"("+num$([F:PSN]PSNNUM)+")"-":"-format$(GFMD,[F:PSN]PSNSTRDAT)-format$(GFMD,[F:PSN]PSNENDDAT)
&                     -[F:FCY]FCY-[F:FCY]FCYNAM
      TBDEB(NBCTR)  = max([F:PSN]PSNSTRDAT,GMOIPAY)
      TBFIN(NBCTR)  = min([F:PSN]PSNENDDAT,eomonth(GMOIPAY))
     Next
    Endif
  Endcase
 Next
 If NBCTR=0
  GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
  mkstat = 2 : End
 Elsif NBCTR>1
  Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
  If NUMCTR=0 : mkstat = 2 : End : Endif
 Else
  NUMCTR = 1
 Endif
 [M]CTRNUM = TBCTR(NUMCTR)
 If dim([M]PSNNUM)>0 : [M]PSNNUM = TBNUM(NUMCTR) : Endif
 [M]STRDAT = TBDEB(NUMCTR)
 VALEUR    = TBFIN(NUMCTR)
 Affzo 10
Endif
End

