########################################################################
## MAJ des flags du suivi des temps
########################################################################
#**
#*
#*
#* @param MAT
#* @param DAT
#* @param CTR
#* @param FLG 1= Génération temps, 2=Synthèse des temps, 3=MAj variables, 4=Maj analytique
#* @param VALEUR
#* @param TPSDAT
#*!
Subprog MAJFLGTPS (MAT,DAT,CTR,FLG,VALEUR,TPSDAT)
Value Char MAT (), CTR ()
Value Date DAT
Value Integer FLG
Value Integer VALEUR
Value Date    TPSDAT

If clalev([F:VEP2])=0 : Local File VALEMP    [VEP2] : Endif

Local Date LASTDATE
Filter [F:VEP2] Where EMP=MAT & CTRNUM=CTR
Read [F:VEP2]VEP0 Last
[L]LASTDATE = [F:VEP2]PYRDAT

Local Char CRITVEP (50)
If dim(GNUMBUL)>=0
 CRITVEP="BUL='"+GNUMBUL+"'"
Else
 CRITVEP="1=1"
Endif
# SEGAY  US 2331-88174 BULDEM
Gosub INIT_ISDEMAT

Case FLG
 When 1 : Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & evalue(CRITVEP) With FLGGEN=VALEUR
          If DAT >= [L]LASTDATE : # 68876
           If ![L]WISDEMAT : # 88174
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP) With STA=1 :#Etat saisi
           Else
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP) With STA=1,FLGDEMAT=1 :#no demat
           Endif
          Endif
 When 2 : Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & evalue(CRITVEP) With FLGSYN=VALEUR
          If DAT >= [L]LASTDATE : # 68876
           If ![L]WISDEMAT : # 88174
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP) With STA=1 :#Etat saisi
           Else
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP) With STA=1,FLGDEMAT=1 :#no demat
           Endif
          Endif
 When 3 : Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & evalue(CRITVEP) With FLGVRA=VALEUR, DATTPS=TPSDAT : #64333
          If DAT >= [L]LASTDATE : # 68876
           If ![L]WISDEMAT : # 88174
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP)  With STA=1 :#Etat saisi
           Else
             Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & PST<2 & evalue(CRITVEP) With STA=1,FLGDEMAT=1 :#no demat
           Endif
          Endif
 When 4 : Update [VEP2] Where EMP=MAT & PYRDAT=DAT & CTRNUM=CTR & evalue(CRITVEP) With FLGANA=VALEUR
Endcase

Filter [VEP2]

End

