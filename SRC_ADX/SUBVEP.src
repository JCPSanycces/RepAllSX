Return

$TR_IJSS
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
GOK=1

[L]UPDOK=0    :##**102341-US2920

Trbegin [VLA]
##**102341-US2920 Add filter '& DAT<=[M:VEP1]ENDDAT'
Filter [HRTAT] Where REFNUM=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM & STAATT=2 & DAT<=[M:VEP1]ENDDAT
For [HRTAT]TAT0
 Gosub IJAT From TRTIJSS
 If GOK<=0 : Break : Endif
 [F:HRTAT]STAATT = 3
 [F:HRTAT]BUL    = [F:VEP]BUL
 Rewrite [F:HRTAT]Curr
 If [M:DIA]TRA=2
  #Attestation AT/Maladie prof. du xx/xx/xx déversée dans paie du yy/yy/yy
  Call ECR_TRACE(func AFNC.MES1(mess(38,10710,1),num$([F:HRTAT]DAT))
&                -format$("D:"+GFMDAT4,[F:VEP]PYRDAT),0) From GESECRAN
 Endif
 [L]UPDOK=1    :##**102341-US2920
Next
Filter [HRTAT]
If GOK=1
 ##**102341-US2920 Add filter '& DAT<=[M:VEP1]ENDDAT'
 Filter [MAL] Where REFNUM=[M:VEP0]EMP & CTRNUM=[M:VEP0]CTRNUM & STAATT=2 & DAT<=[M:VEP1]ENDDAT
 For [MAL]MAL0
  Gosub IJMAL From TRTIJSS
  If GOK<=0 : Break : Endif
  [F:MAL]STAATT = 3
  [F:MAL]BUL    = [F:VEP]BUL
  Rewrite [F:MAL]Curr
  If [M:DIA]TRA=2
   #Attestation Mal/Mat/Pat du xx/xx/xx déversée dans paie du yy/yy/yy
   Call ECR_TRACE(func AFNC.MES1(mess(39,10710,1),num$(DATMAT))
&                 -format$("D:"+GFMDAT4,[F:VEP]PYRDAT),0) From GESECRAN
  Endif
  [L]UPDOK=1    :##**102341-US2920
 Next
 Filter [MAL]
Endif
If   GOK<0 : Goto ROLL_TR_IJSS
Elsif !GOK : Goto AB_TR_IJSS
Endif

##**102341-US2920 Add the update of STA
If [L]UPDOK
 Update [VEP] Where BUL=[M:VEP0]BUL With STA=1
Endif
Commit
#GOK=1
