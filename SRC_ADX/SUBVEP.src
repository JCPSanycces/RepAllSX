Gosub OUVRE From WPDEFTABLE

TIT = mess(9,10703,1)     : # Calcul des bulletins de paye
Gosub CHARGE_TABLE
Local Char    BROWEML(10)
Local Char    CRITVEP(250)
Local Integer DEFILE
Local Date    MOICUR
Local Char    REPORT1(GLONARP)
Local Char    TITFOLD(40)(1..14)

Local Char    SYMBOLEV(50)

Global Integer GFLGERR, GSUPPR

If clalev([F:BCB])=0  : Local File BCLOB     [BCB]  : Endif
If clalev([F:BCB2])=0 : Local File BCLOB     [BCB2] : Endif
Local Integer FLGTXT

Local Integer PASANA
Local Char    LESITE(GLONFCY)

Call PARAM(GCURLEG,"NOMRPTBUL",[L]REPORT1) From ADOVAL :#81084

If instr(1,GUSRAUZ,"1")
 DEFILE = 2
Else
 DEFILE = 1
Endif
MOICUR = GMOIPAY
If CLE2<>"" & CLE1<>"" & len(CLE1)=8
 Read [VEP]VEP0(2) = CLE2;gdat$ (CLE1)
 If [F:VEP]PYRMON<>MOICUR
  Filter [VEP] Where EMP=CLE2 & PYRMON=MOICUR
  Read [VEP]VEP0 First
  Filter [VEP]
  If fstat<=2
   CLE1 = [F:VEP]PYRDAT
  Else
   Raz CLE1,CLE2
  Endif
 Endif
Endif
If dim([M:VEPX]NBLIG)>0
 Gosub OUVPAY From SUBVEPX
Endif

#MIPEA - 2016-07-13 - REQ 114309 US274 - START
GORITITCOL = 1
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub SAUV_GLOBAL_CPT From TRTHRCPT

# Table opening for KPO
If func AFNC.ACTIV("KPO")>0
