#   Case J
#    When 1 : If dim([M:VEP1]CCE1)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE1(I-1) : Endif
#    When 2 : If dim([M:VEP1]CCE2)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE2(I-1) : Endif
#    When 3 : If dim([M:VEP1]CCE3)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE3(I-1) : Endif
#    When 4 : If dim([M:VEP1]CCE4)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE4(I-1) : Endif
#    When 5 : If dim([M:VEP1]CCE5)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE5(I-1) : Endif
#    When 6 : If dim([M:VEP1]CCE6)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE6(I-1) : Endif
#    When 7 : If dim([M:VEP1]CCE7)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE7(I-1) : Endif
#    When 8 : If dim([M:VEP1]CCE8)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE8(I-1) : Endif
#    When 9 : If dim([M:VEP1]CCE9)>0 : [F:VAN]CCE(J-1) = [M:VEP1]CCE9(I-1) : Endif
#   Endcase
#  Next J
#  Write [VAN]
#  If fstat
#   GOK = 0 : Call FSTA("VAN") From GLOCK : Break
#  Endif
# Next I
#Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
If FLGTXT | REP="D"
 Gosub ENREG_TXT
Endif
Return

$AV_ANNULE
Local Integer ANUSAI
Local Char    BULLETIN(GLONVCR)
BULLETIN = [M:VEP0]BUL
ANUSAI = 1
Read [VEP]VEP5 = BULLETIN
Call LECTURE("EML",[F:VEP]EMP,"") From CONTOBJ
Gosub DEFSOL From TRTSUP
Gosub ANUPAY From TRTSUP
# Gestion des commentaires par un clob
Delete [BCB] Where CODBLB="VEPTXT" & IDENT2=[F:VEP]BUL
If fstat : GOK = -1 : GLOCK = "$BCLOB" : Return : Endif

Return

$ANNULE
#FRLAA - 2017-11-06 - X3-X3-62518 - START
#Delete ESS payslip
If func AFNC.ACTIV("HRESS")>0
  Local Integer ESSPAYDEL
  ESSPAYDEL = func ESS_FUNCTIONS.DEL_ESS_PAYSLIP("ESSEMLPAY",[M:VEP0]EMP,[M:VEP0]CTRNUM,[M:VEP0]BUL,"pdf")
Endif
#FRLAA - 2017-11-06 - X3-X3-62518 - END
Return

$APRES_CHOI
If MOICUR=[0/0/0] : Return : Endif
Case REPONSE
 When GSTASUI
  Gosub FILVEP
  If DEFILE=1
   Read [VEP_]VEP0 > [M:VEP0]EMP;[M:VEP0]PYRDAT;[M:VEP0]BUL
  Else
   Read [VEP_]VEP7 > [M:VEP1]FCY;[M:VEP1]SRV;[M:VEP0]EMP;[M:VEP0]BUL
  Endif
  Gosub SUIVPREC
 When GSTAPRE
  Gosub FILVEP
  If DEFILE=1
   Read [VEP_]VEP0 < [M:VEP0]EMP;[M:VEP0]PYRDAT;[M:VEP0]BUL
  Else
   Read [VEP_]VEP7 < [M:VEP1]FCY;[M:VEP1]SRV;[M:VEP0]EMP;[M:VEP0]BUL
  Endif
  Gosub SUIVPREC
 When GSTAFIR
  Gosub FILVEP
  If DEFILE=1
   Read [VEP_]VEP0 First
  Else
   Read [VEP_]VEP3(4) First
  Endif
  Gosub SUIVPREC
 When GSTALAS
  Gosub FILVEP
  If DEFILE=1
   Read [VEP_]VEP0 Last
  Else
   Read [VEP_]VEP3(4) Last
  Endif
  Gosub SUIVPREC
 When GSTACLK+50,GSTACLK+51,GSTACLK+52
  Case REPONSE
   When GSTACLK+50 : BOUT = "7"
   When GSTACLK+51 : BOUT = "3"
   When GSTACLK+52 : BOUT = "0"
  Endcase
  K = find(BOUT,CMEN(1..NBMEN))
  If K
   If GREP="M"
    Gosub ENREGISTRER From GOBJSUB
   Endif
   REPONSE = LMEN(K)
  Else
   REPONSE = 0
  Endif
Endcase
Return


$FILVEP
If TUNNEL=1 & (find("CTR",GPILCOD(1..GPILOBJ)) | find("RET",GPILCOD(1..GPILOBJ)))
 CRITVEP = 'EMP="'+[F:VEP]EMP+'" & CTRNUM="'+GBIDC1+'"'
Elsif TUNNEL=1 & find("EML",GPILCOD(1..GPILOBJ))
 CRITVEP = 'EMP="'+[F:VEP]EMP+'"'
Elsif MOICUR<>[0/0/0]
 CRITVEP = "PYRMON=["+format$(GFMD,MOICUR)+"]"
Else
 CRITVEP = "1=1"
Endif
If GUSRACS<>2
 CRITVEP -= "& find([F:VEP]SRV,GAUTSRV(1..GNBSERV))"
 CRITVEP -= "& [F:ACC]CONSUL=2"
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRITVEP -= "& find([F:VEP]FCY,GUSRFCY(1..GNBAUZ))"
Endif
CRITVEP -= "& [F:CPY]LEG='"+GCURLEG+"'"
Filter [VEP_] Where evalue(CRITVEP)
Return

$SUIVPREC
Filter [VEP_]
If fstat<=2
 Gosub SUIVPREC From GOBJSUB
 REPONSE = GSTALFT
Else
 Call MESSAGE(mess(11,100,1)) From GESECRAN : # Début/fin de fichier
 REPONSE = 0
Endif
Return

##################################################################
$INIT
Case GACTION
 When "CALCULBULL"
  TIT = mess(118,10703,1) : # Calcul de paie
  If val(PARAM(1))=0
   BCRIT = ""
  Endif
 When "CALPAY"
  TIT = mess(118,10703,1) : # Calcul de paie
Endcase
Return

$INIT_DIA
Case GACTION
 When "VEPM"
  [M:DIA]MOIS = PARAM(1)
 When "CALCULBULL"
  If dim([M:VEPX]SALNET)>0
   [M]OBJ = [M:VEPX]SALNET
  Endif
  If dim([M:VEPX]LIBNET)>0 & [M:VEPX]LIBNET<>""
   [M]LIBOBJ = [M:VEPX]LIBNET
  Else
   [M]LIBOBJ = mess(106,10703,1) : # Objectif
  Endif
  Endcase
Return

$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

$EXEC
Case GACTION
 When "VEPC"
  Gosub NOUVEAU
 When "CALCULBULL"
  Gosub CALCULBULL
 When "CALPAY"
  Gosub ENCHAINE
 When "VEPM"
  PARAM(1) = [M:DIA]MOIS
 When "TXTPAY"
  Gosub COPIETXT
Endcase
Return

$ABANDON
Raz PASANA
Return

$NOUVEAU
Local Integer OPT , ANA , CRE, OKC
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Local Char    SYMBOLE(50) , MATRI(GLONEML), SYMBOLET(50)
Local Date    DATMAT, DATPAY, DATFINPAY, DATCTR, DATPREST :#US2306_2307(petite correction au passage)
#Local Char    SYMBOLE(50) , MATRI(GLONEML), SYMBOLET(50) , DATPREST
#Local Date    DATMAT, DATPAY, DATFINPAY
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Local Decimal ARRONDI , NEWVAL
#JOJAC - 2016-12-12 - START
#Local Char    BULLETIN(GLONVCR), CTR(GLONHRCTR)
#Local Integer NBPREST , PRESTAT(1..100)
Local Char    BULLETIN(GLONVCR), CTR(GLONHRCTR),PERCOD
Local Integer NBPREST , PRESTAT(1..100),PERNUM,PERYEA
#JOJAC - 2016-12-12 - END

#JASMI - 2017-10-15 - X3-28766 - START
If [M]PERYEA=0 | [M]PERNUM=0
  GERR = 2 : GMESSAGE = mess(00083,00123,1)-"-"-mess(00164,00107,1)
  Return
Endif
#JASMI - 2017-10-15 - X3-28766 - END

#MIPEA - 2017-02-24 - REQ 114309 US274 - START
#MIPEA - 2017-07-10 - X3-46083 - START
 Filter [VEP] Where EMP=[M]EMP & CTRNUM=[M]CTRNUM & PERCOD=[M]PERCOD & PERYEA=[M]PERYEA & PERNUM=[M]PERNUM
 Read [F:VEP]VEP0 Last
 Filter [VEP]
 If fstat<=2
#Filter [VEP] Where EMP=[M]EMP & CTRNUM=[M]CTRNUM
# Read [F:VEP]VEP0 Last
# Filter [VEP]
# If fstat<=2
#  If ([F:VEP]STRDAT>=[M]STRDAT | [F:VEP]ENDDAT>=[M]STRDAT)
#&      &([F:VEP]STRDAT<=[M]ENDDAT | [F:VEP]ENDDAT<=[M]ENDDAT)
#MIPEA - 2017-07-10 - X3-46083 - END
  #  # La période chevauche la période de la paye précédente
#MIPEA - 2017-06-27 - X3-46083 - START
    GERR = 2 : GMESSAGE = mess(122,10703,1)
#    OK = 2
#    Call AVERTIR(mess(122,10703,1),OK) From GESECRAN
#    If OK<>2 : mkstat=2 : End : Endif
#MIPEA - 2017-06-27 - X3-46083 - END
  Endif
#MIPEA - 2017-07-10 - X3-46083 - START
# Endif
#MIPEA - 2017-07-10 - X3-46083 - END
#MIPEA - 2017-02-24 - REQ 114309 US274 - END

MATRI  = [M:DIA]EMP
DATMAT = [M:DIA]PYRDAT
CTR    = [M:DIA]CTRNUM
DATCTR = [M:DIA]CTRDAT

Gosub LECEMP From WPDEFTABLE
Call CONTROLE([M:DIA]EMP,[M:DIA]PYRDAT,[M:DIA]CTRNUM,"",OKC,1) From DIVPAYE
If !OKC : Return : Endif

# Repositionnement sur le contrat initial car le Lecemp a pu changer !
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR
SYMBOLE = "VEP"+format$("D:"+GFMDAT,[M:DIA]PYRDAT)+"\"+[M:DIA]CTRNUM+format$("D:"+GFMDAT,[M:DIA]CTRDAT)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

#LIPET - 2017-05-23 - START
##** V7 : Waiting Time Mangement **#
#SYMBOLET = "TPS"+format$("D:"+GFMDAT,[M:DIA]PYRDAT)+"\"+[M:DIA]CTRNUM+format$("D:"+GFMDAT,[M:DIA]CTRDAT)
#Lock =SYMBOLET
#If fstat
# GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
# GERR = 1 : SAI = 1
# Unlock =SYMBOLE
# Return
#Endif

SYMBOLET = "TPS"+format$("D:"+GFMDAT,[M:DIA]PYRDAT)+"\"+[M:DIA]CTRNUM+format$("D:"+GFMDAT,[M:DIA]CTRDAT)
Lock =SYMBOLET
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Unlock =SYMBOLE
 Return
Endif
#LIPET - 2017-05-23 - END

Gosub DEFVARG From TRTAUT

Raz NBPREST , PRESTAT

If [F:ID]FLGINT=2 & GINTMT=1
 Case [F:HRCTR]CALPAY
  When 1
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
    For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & PSNENDDAT<=[M:DIA]ENDDAT & BUL="" & CTRDAT=[F:HRCTR]CTRDAT
#   For [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & PSNENDDAT<=[M:DIA]ENDDAT & BUL=""
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
    NBPREST += 1
    PRESTAT(NBPREST) = [F:PSN]PSNNUM
   Next
  When 2
   NBPREST = 1 : PRESTAT(1) = [M:DIA]PSNNUM
  When 3
   NBPREST = 1 : PRESTAT(1) = [M:DIA]PSNNUM
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
   Read [PSN]PSN0 = [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[M:DIA]PSNNUM
#  Read [PSN]PSN0 = [F:HRCTR]CTRNUM;[M:DIA]PSNNUM
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
   If [F:PSN]PSNSTRDAT=[F:PSN]PSNENDDAT
    DATPREST = [F:PSN]PSNSTRDAT
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
    For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & PSNNUM<>[L]PRESTAT(1) & BUL="" & CTRDAT=[F:HRCTR]CTRDAT
#   For [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & PSNNUM<>[L]PRESTAT(1) & BUL=""
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
     If [F:PSN]PSNSTRDAT=[L]DATPREST & [F:PSN]PSNENDDAT=[L]DATPREST
      NBPREST += 1
      PRESTAT(NBPREST) = [F:PSN]PSNNUM
     Endif
    Next
   Endif
 Endcase
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
Unlock =SYMBOLET
Read [VEP]VEP5 = BULLETIN
[M:VEP0]EMP    = [M:DIA]EMP
[M:VEP0]PYRDAT = [M:DIA]PYRDAT
[M:VEP0]BUL    = BULLETIN

Gosub KILLVARG From TRTAUT

Return

$TR1
GOK = 1
Trbegin [VEP]
 If [M:DIA]DATEXT<>[0/0/0]
  Call CREPAYEXT([M:DIA]EMP, [M:DIA]CTRNUM, [M:DIA]PYRDAT,[M:DIA]STRDAT,[M:DIA]ENDDAT,
&                [M:DIA]PAYDAT, [M:DIA]DATEXT, [M:DIA]BULEXT, 1, "", BULLETIN)
 Else
  Raz BULLETIN
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
#JOJAC - 2016/12/12 - START
#  Call CREPAY([M:DIA]EMP,[M:DIA]PYRDAT,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]PAYDAT,0
#&              ,[M:DIA]CTRNUM,PRESTAT,[F:HRCTR]CALPAY,BULLETIN,1,[M:DIA]PRFSUP,[M:DIA]CTRDAT,[M:DIA]STRCTRDAT) From TRTAUT
  Call CREPAY([M:DIA]EMP,[M:DIA]PYRDAT,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]PAYDAT,0
&              ,[M:DIA]CTRNUM,PRESTAT,[F:HRCTR]CALPAY,BULLETIN,1,[M:DIA]PRFSUP,[M:DIA]CTRDAT,[M:DIA]STRCTRDAT,[M:DIA]PERCOD,[M:DIA]PERNUM,[M:DIA]PERYEA) From TRTAUT
#JOJAC - 2016/12/12 - END
#  Call CREPAY([M:DIA]EMP,[M:DIA]PYRDAT,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]PAYDAT,0
#&              ,[M:DIA]CTRNUM,PRESTAT,[F:HRCTR]CALPAY,BULLETIN,1,[M:DIA]PRFSUP,[F:HRCTR]CTRDAT) From TRTAUT
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
 Endif
 If    GOK<0 : Goto ROL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

################################################################################
#
# Action SELBUL
#
################################################################################

$SEL_TABLE
Case [L]TABLE
When "SELBUL"
 [L]OBJET  ="VEP"
 [L]OPTIONS="C" : # Bulletins comptabilisés
 [L]ORDRE  ="BUL"
Endcase
Return

$FIN_TABLE
Case [L]TABLE
When "SELBUL"
 [L]VALEUR=[F:VEP]BUL
Endcase
Return
# SEGAY  US 2331-88174 BULDEM
$INIT_ISDEMAT
Local Integer WISDEMAT
[L]WISDEMAT=0
If func AFNC.ACTIV("DEMAT") : [L]WISDEMAT=1 : Endif
Return


# Verrouillé US1918 65062
#**
#* Funprog is called by the FLGLOC field CALPAY the screen to display the title field FLGLOC
#*!
Funprog LIBFLGLOC
Local Char TITFLGLOCK(40)
If [M:VEP1]FLGLOCK<>2
   [L]TITFLGLOCK = mess(219,10703,1) : #Activation du verrou
Else
   [L]TITFLGLOCK = mess(220,10703,1) : #Suppression du verrou
Endif
If [M:VEP0]OLDLOCK=2
   If [M:VEP1]FLGLOCK<>2
      [L]TITFLGLOCK = mess(220,10703,1) : #Suppression du verrou
   Endif
Else
   If [M:VEP1]FLGLOCK=2
      [L]TITFLGLOCK = mess(219,10703,1) : #Activation du verrou
   Endif
Endif
End [L]TITFLGLOCK

## Création d'une paye à partir d'une paye extournée
#---------------------------------------------------------------------------------------------------
Subprog CREPAYEXT(REFNUM, CTRNUM, PYRDAT, STRDAT, ENDDAT, REGDAT, DATEXT, BULEXT, MODE, RETNUM,
&                     NOUVEAU_BULLETIN)
Value Char REFNUM(), CTRNUM()
Value Date PYRDAT
Value Date STRDAT, ENDDAT, REGDAT, DATEXT
Value Char BULEXT()
Value Integer MODE
Value Char RETNUM()
Variable Char NOUVEAU_BULLETIN()

If clalev([F:VLA1])=0 : Local File VALEUR    [VLA1] : Endif
If clalev([F:VAN1])=0 : Local File VALANA    [VAN1] : Endif
If clalev([F:BCB1])=0 : Local File BCLOB     [BCB1] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif
If clalev([F:BCB])=0  : Local File BCLOB     [BCB]  : Endif
If clalev([F:REV])=0  : Local File RETROVRA  [REV]  : Endif

###**72216
If clalev([F:RVL])=0  : Local File RETROVAL  [RVL]  : Endif
If clalev([F:VEPW])=0 : Local File VALEMP    [VEPW] : Endif
If clalev([F:HRHSR])=0  : Local File HISTOREGUL [HRHSR] : Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
If GINTMT
 If clalev([F:PSNW])=0 : Local File PRESTATION [PSNW] : Endif
 Local Char    TBVAR(GLONVRA)(1..100)
 Local Decimal VALEUR(1..100)
 Local Integer NBVAR
 Local Integer NBPREST , PRESTAT(1..100) :#US2306_2307
Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Local Char    COMPTEUR(GLONANM)
Local Char    BULLETIN(GLONVCR)
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Local Char    OLDPRFSUP(GLONPRF)
Local Date      WDATTPS
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Local Integer STAT

Local Date OLDPYRMON, OLDPYRDAT
Read [F:VEPW]VEP5=BULEXT
If !fstat
 OLDPYRMON=[F:VEPW]PYRMON
 OLDPYRDAT=[F:VEPW]PYRDAT
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
 OLDPRFSUP=[F:VEPW]PRFSUP
 WDATTPS = [F:VEPW]DATTPS  :#113131
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
Else
 OLDPYRMON=GMOIPAY
 OLDPYRDAT=[L]PYRDAT
Endif


Case [L]MODE
    When 1
        Filter [HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM & [F:HRCTR]CTRNUM=[L]CTRNUM
&                          & [F:HRCTR]CTRDAT<=[L]ENDDAT
        Read [HRCTR]CTR0 Last
        Filter [HRCTR]
    When 2
        Filter [HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM & [F:HRCTR]CTRNUM=[L]CTRNUM
&                          & [F:HRCTR]FLGRET = 2
&                          & [F:HRCTR]RETDATEFF<=[L]ENDDAT
        Read [HRCTR]CTR0 Last
        Filter [HRCTR]
        If fstat > 2
            # Si on ne trouve pas .... on reprends le cas normal
            Filter [HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM & [F:HRCTR]CTRNUM=[L]CTRNUM
&                              & [F:HRCTR]CTRDAT<=[L]ENDDAT
            Read [HRCTR]CTR0 Last
        Else
            If [F:HRCTR]FLGRET = 2
                Readlock [F:HRCTR] Curr
                If fstat = 1
                    [V]GOK = -1 : [V]GLOCK = "$EMPLOCTR" : End
                Elsif fstat <> 0
                    [V]GOK = 0 : Call RSTA("HRCTR", [L]REFNUM+"/"+[L]CTRNUM+[F:HRCTR]CTRDAT) From GLOCK : End
                Endif
                [F:HRCTR]RETSTATUT = 3
                Rewrite [F:HRCTR]
                If fstat <> 0
                    [V]GOK = 0
                    Call FSTA("HRCTR") From GLOCK
                    End
                Endif
            Endif
        Endif
    When Default
        Filter [HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM & [F:HRCTR]CTRNUM=[L]CTRNUM
&                         & [F:HRCTR]CTRDAT<=[L]ENDDAT
Endcase
Raz [F:VEP]
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Read [TCA]TCA0 = 2 : # Module paye
COMPTEUR = [F:TCA]CODNUM(4)
If COMPTEUR=""
 Call ERREUR(mess(149,10702,1)) From GESECRAN : # Compteur bulletin non défini
 GOK = 0 : End
Endif
#Call LECTCA(15,STAT) From SUBTCA
#If !STAT
#  Call ERREUR(mess(149,10702,1)) From GESECRAN : # Compteur bulletin non défini
#  GOK = 0 : End
#Else
#  COMPTEUR= [F:TCA]CODNUM(4)
#Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

Call NUMERO([L]COMPTEUR,[F:HRCTR]ETRFCY,[L]PYRDAT,[L]CTRNUM,[L]BULLETIN,[L]STAT) From SUBANM

If STAT
 Call ERREUR(mess(4,10702,1)-COMPTEUR) From GESECRAN : # "Erreur sur compteur"
 GOK = 0 : End
Endif

[F:VEP]BUL    = [L]BULLETIN
[F:VEP]CTRNUM = [L]CTRNUM

If dim([F:VEP]CTRDAT) > 0 : [F:VEP]CTRDAT = [F:HRCTR]CTRDAT : Endif
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
[F:VEP]STRCTRDAT = [F:VEPW]STRCTRDAT
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

[F:VEP]CALPAY = [F:HRCTR]CALPAY
[F:VEP]EMP    = [L]REFNUM
[F:VEP]PYRDAT = [L]PYRDAT
[F:VEP]STRDAT = [L]STRDAT
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
#JASMI - 2017-02-20 - START
#[F:VEP]ENDDAT = min(eomonth([L]ENDDAT),max([L]ENDDAT,[F:HRCTR]XITDAT))
If [F:HRCTR]XITDAT>[L]STRDAT Then
  [F:VEP]ENDDAT = min(eomonth([L]ENDDAT),[F:HRCTR]XITDAT)
Else
  [F:VEP]ENDDAT = min(eomonth([L]ENDDAT),max([L]ENDDAT,[F:HRCTR]XITDAT))
Endif
#JASMI - 2017-02-20 - END
#[F:VEP]ENDDAT = [L]ENDDAT
#MIPEA - 2016-07-18 - REQ 114309 US274 - END
[F:VEP]PAYDAT = [L]REGDAT
[F:VEP]STA    = 1
[F:VEP]PST    = 1
[F:VEP]FLGLOCK = 1 : # Verrouillé US1918 65062
# SEGAY  US 2325-88174 BULDEM
If dim([F:VEP]FLGDEMAT) > 0 : [F:VEP]FLGDEMAT = 1 : Endif

If dim([F:VEP]CREDAT)>0 : [F:VEP]CREDAT = date$ : Endif
If dim([F:VEP]CREUSR)>0 : [F:VEP]CREUSR = GUSER : Endif
If dim([F:VEP]CRETIM)>0 : [F:VEP]CRETIM = time  : Endif
[F:VEP]SRV    = [F:HRCTR]ETRSRV
[F:VEP]PRF    = [F:HRCTR]PROPRF
[F:VEP]FCY    = [F:HRCTR]ETRFCY
[F:VEP]CODACS = [F:ID]CODACS
[F:VEP]PYRMON    = OLDPYRMON
[F:VEP]ORIPYRDAT = OLDPYRDAT
[F:VEP]FLGVAR = [F:HRCTR]FLGVAR
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
[F:VEP]PRFSUP    = OLDPRFSUP
[F:VEP]DATTPS       = WDATTPS      :#113131
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

#84720 : Clé de répartition
[F:VEP]DSP=[F:VEPW]DSP

Gosub GETRPTBUL From TRTAUT
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
Gosub CAL_NBREMP From TRTAUT
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

# 0 = Organisme URSSAF
Call ORGANISME ([F:ID]REFNUM,[F:VEP]FCY,[F:VEP]CTRNUM,[F:VEP]ORG,GINDURS-1) From SUBORG
Write [VEP]
If fstat
 GOK = 0 : Call FSTA("VEP") From GLOCK : End
Endif

# Valeurs analytiques
Filter [VAN] Where EMP=[F:ID]REFNUM  & BUL=[L]BULEXT
For [VAN]VAN0
 [F:VAN1]       = [F:VAN]
 [F:VAN1]PYRDAT = [L]PYRDAT
 [F:VAN1]BUL    = [L]BULLETIN
 Write [VAN1]
 If fstat
  GOK = 0 : Call FSTA("VAN1") From GLOCK : Break
 Endif
Next
Filter [VAN]
If GOK=0 : End : Endif

# Valeurs
#MIPEA - 2016-07-18 - REQ 114309 US274 - START
# Valeurs de variables pour les intermittents
If GINTMT & [F:ID]FLGINT=2
 #US2306_2307
 # Mise à jour des prestations
 NBPREST = 0
 Filter [PSNW] Where CTRNUM=[F:VEP]CTRNUM & BUL="" & PSNSTRDAT<=[F:VEP]ENDDAT & PSNENDDAT>=[F:VEP]STRDAT & CTRDAT=[F:VEP]CTRDAT
&        Order By Key CLE = [F:PSNW]CTRNUM;[F:PSNW]PSNSTRDAT;[F:PSNW]PSNENDDAT
 Readlock [PSNW]CLE First
 While !fstat
   [F:PSNW]BUL = BULLETIN
   Rewrite [PSNW]
   If fstat
    GOK = 0 : Call FSTA("PSNW") From GLOCK : Break
   Endif
   NBPREST+=1
   PRESTAT(NBPREST)=[F:PSNW]PSNNUM
   Readlock [PSNW]CLE Next
 Wend
 Filter [PSNW]
 If GOK<1 : End : Endif
 If NBPREST
  Call INIVAR([F:PSNW]CTRNUM,NBPREST,PRESTAT,NBVAR,TBVAR,VALEUR) From INIVAR
 Endif
 If GOK<1 : End : Endif
 #end US2306_2307
Endif

# Valeurs de variables
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

Filter [VLA] Where [F:VLA]TYP=4 & [F:VLA]EMP=[F:ID]REFNUM & [F:VLA]BUL=[L]BULEXT
For [VLA]VLA0
 [F:VLA1]    = [F:VLA]
 [F:VLA1]DAT = [L]PYRDAT
 [F:VLA1]BUL = [L]BULLETIN


#MIPEA - 2016-07-18 - REQ 114309 US274 - START
 # On remplace l'ancienne valeur par la nouvelle contenue dans les prestations de la fiche contrat.
 If GINTMT & [F:ID]FLGINT=2 & NBVAR
   K = find([F:VLA]VARCOD,TBVAR(1..NBVAR))
   If K
    [F:VLA1]VARVAL    = VALEUR(K)
   Endif
 Endif

#MIPEA - 2016-07-18 - REQ 114309 US274 - END

 Write [VLA1]
 If fstat
  GOK = 0 : Call FSTA("VLA1") From GLOCK : Break
 Endif
Next
Filter [VLA]
If GOK=0 : End : Endif

#MIPEA - 2016-07-18 - REQ 114309 US274 - START
# La fiche rétro ne doit pas influencer les paies de remplacements des intermittents
# Seule les prestations comptent...
If !GINTMT | [F:ID]FLGINT<>2
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

# Si on est en mode "RETRO" , on va chercher des variables salariés avec des valeurs différentes
If [L]MODE = 2

    For [F:REV]REV1 Where [F:REV]RETNUM = [L]RETNUM & [F:REV]TYPREV=1         :##**72216

        # Les variables du dernier bulletin du contrat avant la date d'effet (extournes\extournés exclus)
        Link [F:VLA] With
&            [F:VEPW]VEP5 = [F:VLA]BUL
&            As [LNKW]
&            Where [F:VLA]TYP = 4 & [F:VLA]CPY = "" & [F:VLA]FCY = "" & [F:VLA]EMP = [L]REFNUM
&                & [F:VLA]DAT <= [F:REV]DATVAL
&                & [F:VLA]VARCOD = [F:REV]VRACOD
&                & [F:VEPW]CTRNUM = [L]CTRNUM
&                & [F:VEPW]RVSDAT=[0/0/0] & [F:VEPW]RVS<>2
&                Order By Key CLE = [F:VLA]EMP ; [F:VEPW]CTRNUM ; [F:VLA]VARCOD ; [F:VLA]DAT ; [F:VEPW]PYRDAT ; [F:VEPW]BUL

        Read [F:LNKW]CLE Last

        If fstat <= 2

            # Y'en a une, on fait péter l'existante qu'on vient de générer (s'il y en a une)

            Delete [F:VLA1] Where [F:VLA1]TYP = 4 & [F:VLA1]CPY = "" & [F:VLA1]FCY = ""
&                                    & [F:VLA1]EMP = [L]REFNUM & [F:VLA1]DAT = [L]PYRDAT
&                                    & [F:VLA1]VARCOD = [F:REV]VRACOD
&                                    & [F:VLA1]BUL = [L]BULLETIN

            # Et on écrit celle qu'on vient de trouver.
            Raz [F:VLA1]
            [F:VLA1]    = [F:VLA]
            [F:VLA1]DAT = [L]PYRDAT
            [F:VLA1]BUL = [L]BULLETIN
            Write [VLA1]
            If fstat
                [V]GOK = 0 : Call FSTA("VLA1") From GLOCK : Break
            Endif
        Endif
    Next
    If GOK=0 : End : Endif

###**72216
# Mais cette valeur (en date de valeur) a pu être modifiée dans la fiche rétro (valeur de variable)
# Si c'est le cas alors on recherche cette nouvelle valeur et on la change (que le variable de type 4 'salarié')
Filter [F:RVL] Where RETNUM=[L]RETNUM & REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
&                   & STRBUL<=[L]BULEXT & ENDBUL>=[L]BULEXT & TYPRVL=1 & TYP=4
 For [F:RVL]RVL1
  Readlock [F:VLA1]VLA0=4;"";"";[L]REFNUM;[L]PYRDAT;[F:RVL]VARCOD;[L]BULLETIN
  If fstat <= 2
    [F:VLA1]VARVAL=[F:RVL]VALDEN
    Rewrite [VLA1]
    If fstat
     [V]GOK = 0 : Call FSTA("VLA1") From GLOCK : Break
    Endif
  Elsif fstat=5
   Raz [F:VLA1]
   [F:VLA1]TYP = 4
   [F:VLA1]EMP = [L]REFNUM
   [F:VLA1]DAT = [L]PYRDAT
   [F:VLA1]BUL = [L]BULLETIN
   [F:VLA1]VARCOD = [F:RVL]VARCOD
   [F:VLA1]VARVAL = [F:RVL]VALDEN
   Write [VLA1]
   If fstat
     [V]GOK = 0 : Call FSTA("VLA1") From GLOCK : Break
   Endif
  Endif
 Next
 Filter [F:RVL]
 If GOK=0 : End : Endif
Endif
Endif

# Textes
Filter [BCB] Where find(CODBLB,"VARTXT","VEPTXT")<>0 & IDENT2=[L]BULEXT
For [BCB]BCB0
 [F:BCB1] = [F:BCB]
 [F:BCB1]IDENT2 = BULLETIN
 If dim([F:BCB1]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
 If dim([F:BCB1]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
 If dim([F:BCB1]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
 Write [BCB1]
 If fstat
  GOK = 0 : Call FSTA("BCB1") From GLOCK : Break
 Endif
Next
Filter [BCB]
If GOK=0 : End : Endif

[L]NOUVEAU_BULLETIN = [L]BULLETIN

End


########################################
Subprog AS_VARCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Gosub SETNOL
 Gosub VERF_ACCES
Endif
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer IND   #récupère l'indice du tableau des codes
#contrôle de cohérence.........

Call LECTURE("VRA",VALEUR,GCURLEG) From CONTOBJ
If [F:VRA]FLGEMP<>2
 # Variable non saisie au niveau salarié
 GMESSAGE = mess(29,10702,1)
 mkstat = 2 : End
Elsif [F:VRA]FLGEXS=2
 GMESSAGE=mess(18,10703,1) : # Variable de note de frais
 mkstat=2 : End
Else
 IND = find([VRA]PAGEMP,[M:VEP0]TABCOD(1..8))
 If IND
  If [M]CODPAG<>[M:VEP0]TABCOD(IND)
   GMESSAGE = mess(30,10702,1)-num$([M:VEP0]TABSHO(IND))
# Variable à saisir dans l'onglet
   mkstat = 2
  Endif
 Endif
Endif

#contrôle d'unicité sur la colonne
Call UNICITE(VALEUR,[M]VARCOD) From OBJDIV
# contrôle code d'accès
If VALEUR<>[M]VARCOD(nolign-1) & [F:VRA]CODACC<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;ACCES
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(41,10703,1)-[M]VARCOD(nolign-1) : # Accès interdit à cette variable
  mkstat = 2 : End
 Endif
Endif
If [F:VRA]CODACT<>""
 Read [ACV]CODACT = [F:VRA]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = mess(42,10703,1) : # Variable inactive
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_TBL
If [M:VEP0]MODIF=0 | [M:VEP1]RVS=2  | [M:VEP1]FLGLOCK = 2
 GBOUT1 = ""
Endif
Gosub SETNOL
If [M]VALEUR(NOL)=0
 GBOUT2=""
Endif
End

Subprog C_TBL
If [M:VEP1]RVS=2 & !adxgtb
 mkstat=2 : End
Endif

Gosub SETNOL
If status=65
 Gosub VERF_ACCES
Elsif status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  Gosub VERF_ACCES
  If mkstat : Break : Endif
 Next
Endif
If mkstat
 GMESSAGE = mess(41,10703,1)-[M]VARCOD(NOL) : # Accès interdit à la variable
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

#MIPEA - 2016-07-18 - REQ 114309 US274 - START
$VERF_ACCES
If GUSRACS<>2
 Call LECTURE("VRA",[M]VARCOD(NOL),GCURLEG) From CONTOBJ
 If [F:VRA]CODACC<>""
  Read [ACC]CODACC = GUSER;[F:VRA]CODACC
  If fstat or [F:ACC]EXEC<>2 : mkstat = 2 : Endif
 Endif
Endif
Return
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

#MIPEA - 2016-07-18 - REQ 114309 US274 - START
$VERF_ANU
Local Char    SYMBCTR(80)
If [F:ID]FLGINT=2 & GINTMT
 SYMBCTR = func TRTSUP.CTRSYMBOLE
 Lock =SYMBCTR
 If fstat
   GMESSAGE = [F:HRCTR]CTRNUM-":"-mess(10,100,1) : # Modification en cours sur autre poste
   OK=0
 Endif
 Unlock =SYMBCTR
Endif

# FQ111191 - 21/09/15 - On ne peut supprimer un bulletin que si aucun versement DSN ne lui est rattaché
If OK & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#If OK & func AFNC.ACTIV("KFR")>0 Then
  If clalev([F:HRDMV])=0 : Local File HRDSNDMV [HRDMV] : Endif
  Read [F:HRDMV]HRDMV1=[F:VEP]BUL
  If !fstat Then
    GMESSAGE=mess(141,761,1) : # La donnée versement DSN rattachée à ce bulletin doit d'abord être supprimée
    OK=0
  Endif

  If OK Then
    If clalev([F:HRDCV])=0 : Local File HRDSNAMT [HRDCV] : Endif
    Read [F:HRDCV]HRDCV1=[F:VEP]BUL
    If !fstat Then
      GMESSAGE=mess(141,761,1) : # La donnée versement DSN rattachée à ce bulletin doit d'abord être supprimée
      OK=0
    Endif
  Endif
Endif
Return
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

Subprog B1_TBL
Local Integer NBVAR
NBVAR=0
For [VRA]VRA0 Where FLGEMP=2 & PAGEMP=[M]CODPAG & FLGFDR=1 & FLGCPY=1 & FLGFCY=1
&                 & FLGEXS<>2 & LEG=GCURLEG
 OK=1
 If [F:VRA]CODACT<>""
  Read [ACV]CODACT = [F:VRA]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK=0 :   Endif
 Endif
 #
 If OK & !find([F:VRA]COD,[M]VARCOD(0..[M]TBL-1))
  [M]VARCOD([M]TBL) = [F:VRA]COD
  [M]RANG([M]TBL)   = [F:VRA]ROWEMP
  [M]TBL += 1
  NBVAR += 1
 Endif
Next
If NBVAR=0
 # Aucune variable a précharger
 Call MESSAGE(mess(90,10702,1)) From GESECRAN
Else
 Sorta [M]TBL [M]TBL Order By [M]RANG(indice)
 Affzo 10
 mkstat = 4
Endif
End

#######################################################################################
## Contrôles employé
#######################################################################################

Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR = [M:VEP0]EMP : Endif
End

Subprog C_EMP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If GACTION<>"VEPC" : # Pas le bouton Nouveau
 If VALEUR<>[M]EMP
  Filter [F:VEP] Where [F:VEP]EMP=VALEUR
  Read [F:VEP]VEP0 Last
  Filter [VEP]
  If fstat<=2
   [M]PYRDAT = [F:VEP]PYRDAT
   [M]BUL    = [F:VEP]BUL
   [M]CTRNUM = [F:VEP]CTRNUM
   [M]CTRDAT = [F:VEP]CTRDAT
   mkstat = 4
  Else
   # Fiche inexistante
   GMESSAGE = mess(23,100,1)
   mkstat = 2 : End
  Endif
 Endif
Else
 # Bouton Nouveau
 If [F:ID]FLGPAY<>2
  GMESSAGE = mess(79,10702,1) : # Salarié non concerné par la paye
  mkstat = 2 : End
 Endif
 #90289
 If [M:DIA]DATEXT<>[0/0/0]
  Local Integer STAT
  Call CTRL_EXT([M:DIA]DATEXT,VALEUR,"",STAT)
  If !STAT
   # Aucune paye extournée n'a été faite à cette date
   GMESSAGE = mess(177,10703,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

#######################################################################################
# Ecran VEPC
#######################################################################################

Subprog AM_FLGVAR(VALEUR)
Variable Integer VALEUR
If [M]EMP<>""
 [M]FLGVAR=VALEUR
 Call AM_EMP([M]EMP)
Endif
End

Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
Local Char    VALPAR(10)
Local Integer NBCTR , NUMCTR , TBNUM(1..100)
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(80)(0..100)
Local Date    TBDEB(0..100) , TBFIN(0..100)
Local Date    DEBPAY , FINPAY , DATREG , DATPAY

#JASMI - 2017-03-08 - START
If clalev([F:CPY2])=0    : Local File COMPANY    [CPY2]   : Endif
If clalev([F:FCY2])=0    : Local File FACILITY   [FCY2]   : Endif

#JASMI - 2017-06-06 - X3-43019- START
# Link [HRCTR] With
#&   [FCY2]FCY0 = [F:HRCTR]ETRFCY
#& , [CPY2]CPY0 = [F:FCY2]LEGCPY
#&   As [LNK2]
#&   Order By Key CLE=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
# Link [HRCTR] With
#&   [FCY2]FCY0 = [F:HRCTR]ETRFCY
#& , [CPY2]CPY0 = [F:FCY2]LEGCPY
#&   As [LNK2]
#&   Order By Key CLE=[F:HRCTR]REFNUM;[F:HRCTR]CTRDAT
#JASMI - 2017-06-06 - X3-43019- END

DATPAY = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
#JASMI - 2017-06-06 - X3-43019- START
#[M]PYRDAT = DATPAY
[M]PYRDAT = DATPAY
#JASMI - 2017-06-06 - X3-43019- END

Call GRISE_CTRNUM([F:ID]FLGMULCTR)
If dim([M]PSNUM)>0 : [M]PSNNUM = 0 : Affzo [M]PSNNUM : Endif

If [M:DIA]DATEXT<>[0/0/0]
 Call PARAM([M:DIA]FCY,"JPAY",VALPAR) From ADOVAL
 If val(VALPAR)<>0 & val(VALPAR)<>day([M]PYRDAT)
  While day([M]PYRDAT)<>val(VALPAR)
   [M]PYRDAT += 1
  Wend
  Affzo PYRDAT
  If [M]PAYDAT<[M]PYRDAT
   [M]PAYDAT=[M]PYRDAT
   Affzo PAYDAT
  Endif
 Endif
Else
 DEBPAY = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
 FINPAY = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
 DATREG = gdat$(func DIVPAYE.INIPARUSR("DATREG","",""))
 [M]STRDAT = DEBPAY
 [M]ENDDAT = FINPAY
 [M]PAYDAT = DATREG

#MIPEA - 2017-07-14- US X3-45626 - START
If [M]ENDDAT=[00/00/0000]
  GERR = 1
  GMESSAGE = mess(252,10702,1)
  mkstat=2
  End
Endif
#MIPEA - 2017-07-14- US X3-45626 - END

#JASMI - 2017-06-06 - X3-43019- START
 Local Char THISCTRNUM(GLONHRCTR)
 Call SELCTR(VALEUR,[M]ENDDAT,[M]STRDAT,THISCTRNUM) From DIVPAYE

 Filter [HRCTR] Where [F:HRCTR]REFNUM=VALEUR & [F:HRCTR]CTRNUM=THISCTRNUM
 Read [HRCTR] Last
 Filter [HRCTR]

 [M:DIA]PERCOD = [F:HRCTR]PERCOD : Affzo [M:DIA]PERCOD
 Call AM_PERCOD([M:DIA]PERCOD)

 DEBPAY = [M]STRDAT
 FINPAY = [M]ENDDAT

#MIPEA - 2017-07-04 - X3-43019- START
 Filter [HRCTR] Where REFNUM=VALEUR & CTRNUM=THISCTRNUM & ((FLGRET<>2 & CTRDAT<=FINPAY) |(FLGRET=2 & RETDATEFF<=FINPAY))
&                    & FLGVAR=[M]FLGVAR & (XITDAT=[0/0/0] | XITDAT>=DEBPAY) & STACTR=2
# Filter [HRCTR] Where REFNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=FINPAY) |(FLGRET=2 & RETDATEFF<=FINPAY))
#&                    & FLGVAR=[M]FLGVAR & (XITDAT=[0/0/0] | XITDAT>=DEBPAY) & STACTR=2
#MIPEA - 2017-07-04 - X3-43019- END
#  Filter [LNK2] Where [F:HRCTR]REFNUM=VALEUR & [F:HRCTR]CTRDAT<=FINPAY & [F:HRCTR]FLGVAR=[M]FLGVAR
#&         &([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DEBPAY) & [F:CPY2]LEG=GCURLEG

  If !rowcount([HRCTR])
    Filter [HRCTR] Where REFNUM=VALEUR & CTRDAT<=FINPAY & FLGVAR=[M]FLGVAR & STACTR=2
    Read [HRCTR]CTR1 Last
    Filter [HRCTR]
#  If !rowcount([LNK2])
#    Filter [LNK2] Where [F:HRCTR]REFNUM=VALEUR & [F:HRCTR]CTRDAT<=FINPAY & [F:HRCTR]FLGVAR=[M]FLGVAR & [F:HRCTR]STACTR=2
#    Read [LNK2]CLE Last
#    Filter [LNK2]
#JASMI - 2017-06-06 - X3-43019- END
    If fstat>2
      #GMESSAGE = mess(150,702,1) : # Pas de contrat pour ce salarié
      GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
      mkstat = 2 : End
    Endif
#JASMI - 2017-06-06 - X3-43019- START
  Elsif rowcount([HRCTR])=1
   Read [HRCTR]CTR1 Last
   Filter [HRCTR]
#  Elsif rowcount([LNK2])=1
#   Read [LNK2]CLE Last
#   Filter [LNK2]
#JASMI - 2017-06-06 - X3-43019- END
   If fstat>2
    GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
    mkstat = 2 : End
   Endif
#JASMI - 2017-06-06 - X3-43019- START
  Elsif rowcount([HRCTR])>1
#  Elsif rowcount([LNK2])>1
#JASMI - 2017-06-06 - X3-43019- END
   #Si plusieurs fiches contrats valides sur la période de paie alors on recherche la 1ière n'ayant pas encore de bulletin créé sur le mois
   #Si intermittent on va rechercher le bon contrat en se basant sur les prestations et pas sur les bulletins
   If GINTMT & [F:ID]FLGINT=2
#JASMI - 2017-06-06 - X3-43019- START
     For [HRCTR]CTR1
#     For [LNK2]CLE
#JASMI - 2017-06-06 - X3-43019- END
      Filter [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT & BUL=""
      Read[F:PSN]PSN0 First
      Filter [F:PSN]
      If fstat<2 : Break : Endif
     Next
   Else
#JASMI - 2017-06-06 - X3-43019- START
     For [HRCTR]CTR1
#     For [LNK2]CLE
      Filter [F:VEP] Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRCTRDAT<=[F:HRCTR]CTRDAT & CTRDAT>=[F:HRCTR]CTRDAT
&                        & [F:VEP]PERNUM=[M]PERNUM
#      Filter [F:VEP] Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRCTRDAT<=[F:HRCTR]CTRDAT & CTRDAT>=[F:HRCTR]CTRDAT & PYRMON=GMOIPAY
#JASMI - 2017-06-06 - X3-43019- END
      Read[F:VEP]VEP5 Last
      Filter [F:VEP]
      If fstat>=4 : Break : Endif
     Next
   Endif
#JASMI - 2017-06-06 - X3-43019- START
   Filter [HRCTR]
#   Filter [LNK2]
#JASMI - 2017-06-06 - X3-43019- END
  Endif

#JASMI - 2017-06-06 - X3-43019- START
#  #JOJAC - 2017-03-08 - START
#  [M:DIA]PERCOD = [F:HRCTR]PERCOD : Affzo [M:DIA]PERCOD
#  Call AM_PERCOD([M:DIA]PERCOD)
#  #JOJAC - 2017-03-08 - END
#JASMI - 2017-06-06 - X3-43019- END

  Gosub INIT_CTR
  #Call PARAM([F:CTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
  Call PARAM([F:HRCTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
  If val(VALPAR)<>0 & val(VALPAR)<>day([M]PYRDAT)
   While day([M]PYRDAT)<>val(VALPAR)
    [M]PYRDAT += 1
   Wend
   If [M]PAYDAT<[M]PYRDAT
    [M]PAYDAT=[M]PYRDAT
   Endif
  Endif
Endif

