#<AdxTL>@(#)0.0.0.0 $Revision$Class Country table
# Supervisor
## ACLA-CLASSE ## TABCOUNTRY
# 2018-11-06 07:16:31 899

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 61 : CRTOBL Site tax ID mandatory ( Field Local menu number 1)
####################################################################

$SET_CRTOBL
If [L]_AOLDVAL<>this.CRTOBL
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CRTOBL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CRTOBL
 Gosub PROPAGATE_CRTOBL
Endif
Return

$INIT_CRTOBL
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRTOBL"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.CRTOBL=0 and fmet this.AGETATTRIBUTE("CRTOBL","$isMandatory")="true"
 this.CRTOBL = 1
Endif
Return
 
$CONTROL_CRTOBL
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRTOBL"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CRTOBL                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CRTOBL                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CRTOBL
[L]CURPRO = "CRTOBL"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.CRTOBL=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CRTOBL
[L]CURPRO = "CRTOBL"
If this.CRTOBL<0 or this.CRTOBL>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.CRTOBL)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_CRTOBL
[L]CURPRO = "CRTOBL"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CRTOBL
[L]CURPRO = "CRTOBL"
Return

$PROPAGATE_CRTOBL
this.isReadonly = 0
[L]CURPRO = "CRTOBL"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CRTOBL
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRTOBL"
$_LNKPRO_CRTOBL
Return


