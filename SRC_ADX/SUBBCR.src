#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FBUD","BUDGET","DBUDCRI",4,"") From GTRAITE
End

##########################################################################
$ACTION
Case ACTION
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

##########################################################################
$SEL_LISTE
Case GACTION
 When "SELPER"
  Local Char CRITERE(100)
  If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif
  Raz NBTEX
  Case PARAM(1)
   When "1"     : TIT(0) = mess(54,108,1) : # Date début de période
   When "2"     : TIT(0) = mess(55,108,1) : # Date fin de période
   When Default : Return
  Endcase
  CRITERE = 'CPY= "'+PARAM(2)+'"'
  CRITERE += " & LEDTYP ="+PARAM(3)
  For [PER]PER0 Where evalue(CRITERE)
   If NBTEX+1>dim(TEX)-1 : Break : Endif
   NBTEX +=1
   If PARAM(1)="1"
    TEX(NBTEX)   = [F:PER]PERSTR
    TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:PER]PERSTR)-"-"-mess([F:PER]LEDTYP,2644,1)
   Else
    TEX(NBTEX)   = [F:PER]PEREND
    TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:PER]PEREND)-"-"-mess([F:PER]LEDTYP,2644,1)
   Endif
  Next

 When "SELBUDGET"        # SAM 26736 : Call CONTBUD if many budgets entered
  Local Char BUDGET(GLONBUP)
  TIT = mess(90,108,1)   # Choix du budget
  For [BUP]
   If GFONCTION="GESCCE"
    If [M:BCR]BUD(0)<>""
     BUDGET = [M:BCR]BUD(0)
     Raz mkstat
     Gosub CONTBUD
     If !mkstat
      NBTEX+=1
      TEX(NBTEX)=[F:BUP]BUD
      TEXTE(NBTEX)=[F:BUP]BUD-" "-[F:BUP]DES
     Endif
    Else
     NBTEX+=1
     TEX(NBTEX)=[F:BUP]BUD
     TEXTE(NBTEX)=[F:BUP]BUD-" "-[F:BUP]DES
    Endif
   Else
    If [M:BCR]BUD(0)<>""
     BUDGET = [M:BCR]BUD(0)
     Raz mkstat
     Gosub CONTBUD
     If !mkstat
      NBTEX+=1
      TEX(NBTEX)=[F:BUP]BUD
      TEXTE(NBTEX)=[F:BUP]BUD-" "-[F:BUP]DES
     Endif
    Endif
   Endif
  Next
 Raz mkstat : Raz GMESSAGE
Endcase
Return

##########################################################################
# les budgets peuvent avoir des niveaux de définition différents mais doivent être
# définis sur la même société
## => V150 pp : ok il faut virer contrôle sur le croisement d'axe MAIS il faut contrôler que tous les codes
## budgets sont associés au même code plan et code(s) axe(s) et éventuellement à la même pyramide de compte
## et pyramide(s) sections(s)

# The budgets can be parameterized with different definition levels but they must be defined on the same company
## => V150 pp : Remove the control sur le croisement d'axe but we must check that all the budget codes
## are linked to the same chart of accounts and dimension types and eventually to the same account pyramid(s)
## and the same dimension pyramid(s)

$CONTBUD
Local Integer AX
Local Integer I, J

AX = [F:BUP]DIENBR

If clalev([F:BUP2])=0 : Local File BUDPAR [BUP2] : Endif
Read [BUP2]BUP0 = BUDGET

If [F:BUP]COA<>[F:BUP2]COA
 # Tous les codes budgets doivent être associés au même code plan
 GMESSAGE = mess(95,108,1)
 mkstat=2 : Return
Endif
For J=0 To AX-1
 If evalue("[F:BUP]DIE("+num$(J)+")")<>evalue("[F:BUP2]DIE("+num$(J)+")")
  # Tous les codes budgets doivent être associés au même code axe
  GMESSAGE = mess(96,108,1)
  mkstat=2 : Break
 Endif
Next
If mkstat : Return : Endif

# We check that the budget is linked to the same pyramids as [M:BCR]BUD
If ([F:BUP2]PYMACC<>[F:BUP]PYMACC) | ([F:BUP2]PYMACCLEV<>[F:BUP]PYMACCLEV)
 # [F:BUP]BUD n'est pas défini sur la même pyramide nature que [F:BUP2]BUD
 GMESSAGE = [F:BUP]BUD-tolower(mess(41,108,1))-[F:BUP2]BUD
 mkstat = 2 : Return
Endif

For I=1 To AX
 If evalue("[F:BUP]PYMCCE("+num$(I-1)+")") <> evalue("[F:BUP2]PYMCCE("+num$(I-1)+")")
  # [F:BUP]BUD n'est pas défini sur les mêmes pyramides sections que [F:BUP2]BUD
  GMESSAGE = [F:BUP]BUD-tolower(mess(42,108,1))-[F:BUP2]BUD
  mkstat = 2 : Break
 Endif
 If evalue("[F:BUP]PYMCCELEV("+num$(I-1)+")") <> evalue("[F:BUP2]PYMCCELEV("+num$(I-1)+")")
  # [F:BUP]BUD n'a pas le même niveau de définition que [F:BUP2]BUD
  GMESSAGE = [F:BUP]BUD-tolower(mess(77,108,1))-[F:BUP2]BUD
  mkstat = 2 : Break
 Endif
Next
Return
##########################################################################
# Screen BUDCRI
##########################################################################

## 1=Budget by period / 2=Budget by account / 3=Budget by dimension
Subprog C_BUDTYP(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call LECTURE("TBU",VALEUR,num$(1)) From CONTOBJ
If !fstat
 For I=0 To [M:BCR]NBCRI-1
  Call LEC_BUP([M:BCR]BUD(I)) From CPTLEC
  If [F:BUP]DIENBR>[F:TBU]MAXDIENBR
   GMESSAGE = mess(286,108,1)-[M:BCR]BUD(I)
   mkstat = 2 : Break
  Endif
 Next
 If mkstat=2 : End : Endif
 GGRPFCY = [F:TBU]GFY
 [M:BCR]BUDCAT = [F:TBU]BUDCAT

 If [M:BCR]BUDCAT=1      # Period
  Actzo DATD, DATF
  Grizo CCED, CCEF, ACCD, ACCF, DATDEB, DATFIN
  Raz [M]CCED,[M]CCEF, [M]ACCD,[M]ACCF : # DATDEB and DATFIN managed the before field action
  Affzo CCED,CCEF,ACCD,ACCF
 Elsif [M:BCR]BUDCAT=2   # Account
  Actzo CCED, CCEF,DATDEB,DATFIN
  Grizo ACCD, ACCF, DATD, DATF
  Raz [M]ACCD,[M]ACCF, [M]DATD, [M]DATF
  Affzo ACCD,ACCF,DATD,DATF
 Elsif [M:BCR]BUDCAT=3   # Dimension
  Actzo ACCD, ACCF, DATDEB, DATFIN
  Grizo CCED, CCEF, DATD, DATF
  Raz [M]CCED,[M]CCEF, [M]DATD, [M]DATF
  Affzo CCED,CCEF,DATD,DATF
 Endif
 If [F:TBU]LODFLG=1
  Raz [M]CCED,[M]CCEF, [M]ACCD,[M]ACCF
  Grizo CCED, CCEF, ACCD, ACCF
 Endif
Endif
End

##########################################################################
Subprog AM_BUDTYP(VALEUR)
Variable Char    VALEUR()
[M:BCR]NBRBUD = 0
Filter [TBU] Where BUDTYP=VALEUR & LINSELCRI<>0
For [TBU]TBU1(2)
 [M:BCR]NBRBUD +=1
Next
Filter [TBU]
If [M:BCR]NBRBUD>1
 [M:BCR]FLGNBRBUD=2
Else
 [M:BCR]FLGNBRBUD=1
Endif
[M:BCR]LODFLG = [F:TBU]LODFLG
Affzo LODFLG,FLGNBRBUD,NBRBUD
End

##########################################################################
Subprog C_DATD(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] & [M:BCR]BUDCAT=1
 # Budget détaillé par période : Saisie obligatoire des dates
 GMESSAGE = mess(48,108,1)
 mkstat=2 : End
Endif
End

##########################################################################
Subprog AM_DATD(VALEUR)
Variable Date    VALEUR
Local    Integer I
If [M:BCR]BUDCAT=1       # Period
 For I=1 To [M]NBCRI
  If [M]DATDEB(I-1)<>[00/00/00]
   nolign = I
   [M:BCR]DATD = VALEUR : Affzo [M:BCR]DATDEB(I-1)
  Endif
 Next I
Endif
End

##########################################################################
Subprog C_DATF(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] & [M:BCR]BUDCAT=1
 ## Budget détaillé par période : Saisie obligatoire des dates
 GMESSAGE = mess(48,108,1)
 mkstat=2 : End
Endif
End

##########################################################################
Subprog AM_DATF(VALEUR)
Variable Date    VALEUR
Local    Integer I
Gosub SETNOL
If [M:BCR]BUDCAT=1       # Period
 For I=1 To [M]NBCRI
  If [M]DATFIN(I-1)<>[00/00/00]
   nolign = I
   Call CTL_DATE([M:BCR]CPY(NOL), [M:BCR]LEDTYP(NOL), VALEUR, 2)
   If mkstat<>0 : Break : Endif
   [M:BCR]DATF = VALEUR : Affzo [M:BCR]DATFIN(I-1)
  Endif
 Next I
Endif
End

##########################################################################
Subprog AS_NBCRI
If nolign>[M]NBRBUD
 mkstat=2 : End
Endif
End

##########################################################################
Subprog S_BUD(VALEUR)
Variable Char    VALEUR()
If GFONCTION="GESCCE" | nolign>1
 ## Action SELBUDGET
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELBUDGET"
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELBUDGET","SUBBCR","") From GACTION
 GACTION = SAVACT
 If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
 Gosub AFF From GSAISIE
Else
 ## Action SELOBJET
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJET"
 PARMSK(1) = "BUP"
 PARMSK(2) = "BUD"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJET","SELOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
 Gosub AFF From GSAISIE
Endif
End

##########################################################################
Subprog C_BUD(VALEUR)
Variable Char     VALEUR()
Local Char BUDGET(GLONBUP)
Local Integer I
Call CONTROLE("BUP","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTEXE([F:BUP]ACS) From CPTSUB
If mkstat : End : Endif
If [F:BUP]PYMACC<>""
 Call LECTURE("GYM",[F:BUP]PYMACC,"") From CONTOBJ
 Call CONTEXE([F:GYM]ACS) From CPTSUB
 # Pyramide nature [F:BUP]PYMACC : vous n'avez pas les droits d'exécution
 If mkstat : GMESSAGE = mess(33,103,1)-[F:BUP]PYMACC-":"-tolower(GMESSAGE) : End : Endif
Endif

If [F:BUP]DIENBR>[F:TBU]MAXDIENBR
 GMESSAGE = mess(286,108,1)
 mkstat = 2 : End
Endif

For I=1 To dim([F:BUP]DIE)
 If [F:BUP]PYMCCE(I-1)<>""
  Call LECTURE("CYM",[F:BUP]PYMCCE(I-1),"") From CONTOBJ
  Call CONTEXE([F:CYM]ACS) From CPTSUB
  # Pyramide section [F:BUP]PYMCCE(I-1) : vous n'avez pas les droits d'exécution
  If mkstat : GMESSAGE = mess(34,103,1)-[F:BUP]PYMCCE(I-1)-":"-tolower(GMESSAGE) : Break : Endif
 Endif
Next
If mkstat : End : Endif

Call CONTDEV([F:BUP]CUR,datesyst) From TRTDEV
If mkstat : End : Endif

If [M:BCR]BUD(0)<>"" & nolign<>1
 BUDGET = [M:BCR]BUD(0)
 If VALEUR<>BUDGET
  Gosub CONTBUD
  If mkstat : End : Endif
 Endif
Endif
[M:BCR]COA = [F:BUP]COA

# Tunnelling from CCE, we load the company and the dates
If GFONCTION="GESCCE"
 If [F:BUP]LEV = 1       # Budget défini au niveau société
  [M:BCR]CPY(nolign-1) = GDEFSOC
  [M:BCR]FCY(nolign-1) = ""
 Else
  [M:BCR]FCY(nolign-1) = GFCYDEF
  Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
  [M:BCR]CPY(nolign-1) = [F:FCY]LEGCPY
 Endif
 Call LECTURE("CPY",[M:BCR]CPY,"") From CONTOBJ
 If GDATEFIN<>[0/0/0]
  Filter [FIY] Where CPY=[M:BCR]CPY(nolign-1) & LEDTYP=[M:BCR]LEDTYP & FIYEND<=GDATEFIN
 Else
  Filter [FIY] Where CPY=[M:BCR]CPY(nolign-1) & LEDTYP=[M:BCR]LEDTYP & FIYSTA=2
 Endif
 Read [FIY]FIY0 Last
 [M:BCR]FIYSTR(nolign-1) = [F:FIY]FIYNUM
 [M:BCR]FIYEND(nolign-1) = [F:FIY]FIYNUM
 Filter [FIY]
 Call DATEXE([M:BCR]CPY(nolign-1),[M:BCR]LEDTYP(nolign-1),[M:BCR]FIYSTR(nolign-1),[M:BCR]DATDEB(nolign-1),[M:BCR]DATFIN(nolign-1)) From CPTSUB
 Affzo CPY(nolign-1), FCY(nolign-1), DATDEB(nolign-1), DATFIN(nolign-1)
Endif
End

##########################################################################
Subprog AS_CPY(VALEUR)
Variable Char     VALEUR()
Call LECTURE("BUP",[M:BCR]BUD(nolign-1),"") From CONTOBJ
If nolign>1 & [F:BUP]LEV=1 : # Definition level = Company
 VALEUR = [M]CPY(0)
 mkstat=2 : End
Elsif [F:BUP]LEV=2         : # Definition level = Site
 mkstat=2 : End
Endif
End

##########################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
GSOCIETE = VALEUR
Call CONTALLFCY(VALEUR) From CPTSUB
If nolign>1 & VALEUR<>[M]CPY(nolign-2)
 # Société ou site incorrect
 GMESSAGE = mess(86,106,1)
 mkstat = 2 : End
Endif
End


###################################################################################################################################
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
Call CONT_LEDTYP(VALEUR)
End

Subprog CONT_LEDTYP(CPY)
Value Char CPY
Local Integer OK, I , TYPREF

Read [CPY]CPY0=CPY
Read [GCM]GCM0 = [F:CPY]ACM
Read [BUP]BUP0=[M:BCR]BUD(nolign-1)

For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2  : # the ledger type must be manual (not automatic)
  Read [LED]LED0 = [F:GCM]LED(I-1)
  OK  = 1
  OK *= ([F:LED]BUD=2)
  OK *= ([F:LED]COA=[F:BUP]COA)
  OK *= (find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(0)="")
  OK *= (find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(1)="")
  OK *= (find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(2)="")
  OK *= (find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(3)="")
  OK *= (find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(4)="")
  OK *= (find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(5)="")
  OK *= (find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(6)="")
  OK *= (find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(7)="")
  OK *= (find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(8)="")
  If OK
   TYPREF = I
   GMENLOC(I) = 0
  Endif
 Endif
Next I
If !find(0, GMENLOC(1..len(mess(0,2644,1))))
 # Aucun type de référentiel ne correspond aux critères !
 Call ERREUR(mess(97,108,1)) From GESECRAN
 mkstat=2
Endif
End

##########################################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR()
Call LECTURE("BUP",[M:BCR]BUD(nolign-1),"") From CONTOBJ
If [F:BUP]LEV=1
 mkstat=1 : End
Else
 Local File FACGROUP [FGR]
 Local File AGRPCPY  [AGC]
 If [F:TBU]GFY<>""
  # Initialize the site FCY with the first site of the first company of the group
  Link [FCY] With [AGC]AGC0=[FCY]FCY As [LFCY] Where [FCY]LEGCPY=[AGC]CPY
  Read [LFCY] First
  VALEUR = [FCY]FCY
 Endif
Endif
End

##########################################################################
Subprog AP_FCY(VALEUR)
Variable Char     VALEUR()
If [F:BUP]LEV=2
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 [M:BCR]CPY(nolign-1)=[F:FCY]LEGCPY
 Affzo CPY
 If nolign>1 & [M]CPY(nolign-1)<>[M]CPY(nolign-2)
  # Société ou site incorrect
  GMESSAGE = mess(86,106,1)
  mkstat = 2 : End
 Endif
Endif
Call CONT_LEDTYP([M:BCR]CPY(nolign-1))
End

##########################################################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer N, NB, OK, LEDTYP, I
Local Char LED(GLONLED), TCODLED(GLONLED)(1..len(mess(0,2644,1))), CODLED(GLONLED), DEVLED(GLONCUR)
Local Libelle TYPLEDGEN, TYPLEDANA

Gosub SETNOL

Read [CPY]CPY0=[M:BCR]CPY(nolign-1)
Read [GCM]GCM0=[CPY]ACM
Read [BUP]BUP0=[M:BCR]BUD(nolign-1)

# Initialiser le premier type de réferentiel de la société associé à un code référentiel flagué 'budget'
# et qui est cohérent par rapport au code plan et code axes du code budget (tous les axes du code budget
# doivent être présents dans le (ou les) réferentiel(s) 'budget'
# Si on n'en trouve qu'un alors mkstat=2
# Load the consistent ledger types in the menu
# the ledger type belongs to the accounting core model of the company
# the ledger type is ticked budget
# the chart of accounts of the ledger is the same as the chart of accounts of the budget [BUP]
# All the dimensions of the budget are required in the ledger types of the budget
NB = 0
For I=1 To len(mess(0,2644,1))
 GMENLOC(I) = 1
 If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2 : # le référentiel ne doit pas être automatique
  Read [LED]LED0 = [F:GCM]LED(I-1)
# le référentiel appartient au modèle comptable de la société
# le référentiel est flaggé budget
# le plan de comptes du référentiel est égal au plan de comptes du paramétrage budget
# tous les axes du code budget doivent être présents dans le (ou les) réferentiel(s) 'budget'
  OK  = 1
  OK *= ([F:LED]BUD=2)
  OK *= ([F:LED]COA=[F:BUP]COA)
  OK *= (find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(0)="")
  OK *= (find([F:BUP]DIE(1),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(1)="")
  OK *= (find([F:BUP]DIE(2),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(2)="")
    OK *= (find([F:BUP]DIE(3),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(3)="")
  OK *= (find([F:BUP]DIE(4),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(4)="")
  OK *= (find([F:BUP]DIE(5),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(5)="")
  OK *= (find([F:BUP]DIE(6),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(6)="")
  OK *= (find([F:BUP]DIE(7),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(7)="")
  OK *= (find([F:BUP]DIE(8),[F:LED]DIE(0..[F:LED]DIENBR-1)) or [F:BUP]DIE(8)="")
  If OK
   NB    += 1
   LEDTYP = I
   GMENLOC(I) = 0
  Endif
 Endif
Next I

# Un seul type de référentiel compatible : on passe au champ suivant
If NB=1
 # si BUDCAT=1 il faut laisser le C_LEDTYP s'exécuter donc pas de mkstat
 If [M:BCR]BUDCAT<>1 : mkstat = 2 : Endif
 VALEUR=[L]LEDTYP
 Read [LED]LED0 = [F:GCM]LED(LEDTYP-1)
 [M]LED=[F:LED]LED
 End
Endif

# Il y a plusieurs types de référentiels compatibles : on laisse le choix
# proposer par défaut le référentiel analytique principal si celui-ci est compatible

# recherche du référentiel analytique principal
Call LECLEDMAIN(2, [F:CPY]CPY, LEDTYP) From CPTDIV
Read [LED]LED0 = [F:GCM]LED(LEDTYP-1)

If GMENLOC(LEDTYP)=0
 VALEUR=[L]LEDTYP
 [M]LED=[F:LED]LED
Endif
End

##########################################################################
Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer I, NB, LEDTYP
Local Char TCODLED(GLONLED)(1..len(mess(0,2644,1)))

Gosub SETNOL
If [M:BCR]BUDCAT=1       # Period
 Call CTL_DATE([M:BCR]CPY(NOL), VALEUR, [M:BCR]DATD, 1)
 If mkstat : End : Endif
 Call CTL_DATE([M:BCR]CPY(NOL), VALEUR, [M:BCR]DATF, 2)
 If mkstat : End : Endif
Endif

Read [CPY]CPY0=[M:BCR]CPY(nolign-1)
Read [GCM]GCM0=[CPY]ACM
Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
[M]LED=[F:LED]LED
End

##########################################################################
Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR()
Local Integer LEDTYP
Local Char DEVLED(3)

Gosub SETNOL
If [M:BCR]BUDCAT=1 : End : Endif
Call LECTURE("CPY",[M]CPY(NOL),"") From CONTOBJ

Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
[M]LED=[F:LED]LED

If GDATEFIN<>[0/0/0]
 Filter [FIY] Where CPY=[M]CPY(NOL) & LEDTYP=[M:BCR]LEDTYP(NOL) & FIYEND<=GDATEFIN
Else
 Filter [FIY] Where CPY=[M]CPY(NOL) & LEDTYP=[M:BCR]LEDTYP(NOL) & FIYSTA=2
Endif
Read [FIY]FIY0 Last
[M:BCR]FIYSTR(nolign-1) = [F:FIY]FIYNUM
[M:BCR]FIYEND(nolign-1) = [F:FIY]FIYNUM
Filter [FIY]
Gosub INIEXE
End

$SETNOL
Local Integer NOL
NOL = nolign-1
If NOL<0 : NOL = 0 : Endif
Return

$INIEXE
Call DATEXE([M:BCR]CPY(nolign-1),VALEUR,[M:BCR]FIYSTR(nolign-1),[M:BCR]DATDEB(nolign-1),[M:BCR]DATFIN(nolign-1)) From CPTSUB
Return

##########################################################################
Subprog C_VER(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUV",VALEUR,[M]BUD(nolign-1)) From CONTOBJ
If [F:BUV]STA=2
 GMESSAGE = mess(58,109,1) : # Version fermée
 mkstat = 2
Endif
End

##########################################################################
Subprog AV_DATDEB(VALEUR)
Variable Date    VALEUR
If [M:BCR]BUDCAT=1 & [M:BCR]DATD<>[0/0/0]
 VALEUR = [M:BCR]DATD
Endif
End

##########################################################################
Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
Call CTL_DATE([M:BCR]CPY(NOL), [M:BCR]LEDTYP(NOL), VALEUR, 1)
End

Subprog CTL_DATE(STE,LEDTYP,DTE,FLG)
Value Char     STE
Value Integer  LEDTYP
Value Date     DTE
Value Shortint FLG : # 1= Start date / 2 = End date
Local Decimal  EXO

If STE<>""
 Call GETEXE(STE,LEDTYP,DTE,EXO) From CPTSUB
Endif
Read [FIY]FIY0 = STE;LEDTYP;EXO
If fstat
 # Exercice incorrect
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
# The start date must be a start period date
Filter [PER] Where CPY=STE & FIYNUM=EXO
Case FLG
 When 1
  For [PER]PER0
   If [F:PER]PERSTR=DTE
    mkstat = 0 : Break
   Else
    mkstat = 2
   Endif
  Next
  # La date n'est pas une date de début de période
  If mkstat=2 : GMESSAGE = mess(49,108,1) : Filter [PER] : End : Endif
 When 2
  For [PER]PER0
   If [F:PER]PEREND=DTE
    mkstat = 0 : Break
   Else
    mkstat = 2
   Endif
  Next
  # La date n'est pas une date de fin de période
  If mkstat=2 : GMESSAGE = mess(50,108,1) : Filter [PER] : End : Endif
Endcase
Filter [PER]
# The budget code must be active for the period
Call LECTURE("BUP",[M]BUD(nolign-1),"") From CONTOBJ
Case FLG
 When 1
  If ([F:BUP]VLYSTR>DTE)
   GMESSAGE = mess(31,108,1) : # Code budget inactif
   mkstat = 2 : End
  Endif
 When 2
  If [F:BUP]VLYEND<>[0/0/0] & [F:BUP]VLYEND<DTE
   GMESSAGE = mess(31,108,1) : # Code budget inactif
   mkstat = 2 : End
  Endif
Endcase
Case FLG
 When 1 : [M]FIYSTR(nolign-1) = EXO
          [M]PERDEB(nolign-1) = [F:PER]PERNUM
 When 2 : [M]FIYEND(nolign-1) = EXO
          [M]PERFIN(nolign-1) = [F:PER]PERNUM
Endcase
End

##########################################################################
Subprog AV_DATFIN(VALEUR)
Variable Date    VALEUR
If [M:BCR]BUDCAT=1 & [M:BCR]DATF<>[0/0/0]
 VALEUR = [M:BCR]DATF
Endif
End

##########################################################################
Subprog C_DATFIN(VALEUR)
Variable Date     VALEUR
Call CTL_DATE([M:BCR]CPY(nolign-1), [M:BCR]LEDTYP(nolign-1), VALEUR, 2)
End

##########################################################################
Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUP",[M:BCR]BUD(nolign-1),"") From CONTOBJ
VALEUR = [F:BUP]CUR
End

##########################################################################
Subprog AS_CCED(VALEUR)
Variable Char    VALEUR()
Local Integer N
If [M]BUD(0)="" : End : Endif #F55181
# La règle est que la sélection des bornes de sections doit toujours porter sur le dernier axe paramétré au niveau du budget
Read [BUP]BUP0=[M]BUD(0)
Gosub INDDIE From BUDGET3
[M:BCR]DIE=[F:BUP]DIE(INDDIE-1)

If [F:BUP]PYMCCE(INDDIE-1)=""
 Call INICCEFMT([M:BCR]DIE) From SETGLBDIE
 GFMT = GCCEFMT
Else
 GFMT = "15c"
Endif
End

##########################################################################
Subprog AS_CCEF(VALEUR)
Variable Char    VALEUR()
Local Integer N
If VALEUR="" | VALEUR<[M]CCED : VALEUR=[M]CCED : Endif
End

##########################################################################
Subprog C_CCEF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]CCED
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

##########################################################################
Subprog C_ACCD(VALEUR)
Variable Char    VALEUR()
If [F:BUP]PYMACC=""
 If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
 Filter [GAC] Where BUDTRK=2 & COA=[F:BUP]COA and ACC=VALEUR
 # Compte incorrect
 If rowcount([GAC])=0 : mkstat=2 : GMESSAGE=VALEUR-mess(31,102,1) : Endif
 Filter [GAC]
Else
 If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
 Filter [GRY] Where PYM=[F:BUP]PYMACC & LIN=1 & BUDTRK = 2 & LEV=[F:BUP]PYMACCLEV and GRU=VALEUR
 # Valeur incorrecte
 If rowcount([GRY])=0 : mkstat=2 : GMESSAGE=VALEUR-mess(83,123,1) : Endif
 Filter [GRY]
Endif
End

##########################################################################
Subprog AS_ACCF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]ACCD : VALEUR=[M]ACCD : Endif
End

##########################################################################
Subprog C_ACCF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]ACCD
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
Call C_ACCD(VALEUR)
End

