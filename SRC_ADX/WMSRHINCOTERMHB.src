$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 1506: RES='Entête'
   When 2523: RES='Incoterm'
   When 8: RES='Intitulé'
   When 250: RES='Utilisateur'
   When 250: RES='Utilisateur'
  Endcase
 When "ENG":
  Case _ID
   When 1506: RES='Header'
   When 2523: RES='Incoterm'
   When 8: RES='Description'
   When 250: RES='User'
   When 250: RES='User'
  Endcase
 When "ITA":
  Case _ID
   When 1506: RES='Testata'
