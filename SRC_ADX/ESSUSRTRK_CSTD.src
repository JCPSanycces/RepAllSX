#<AdxTL>@(#)0.0.0.0 $Revision$ Users
# Class ESSUSRTRK


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"     : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"     : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return


$AUPDATE_CONTROL_BEFORE
$AINSERT_CONTROL_BEFORE
Local Integer COLLECTION_IND, VLINE

#Upating NUMLIG
If this.HRESSATT <> null
  For COLLECTION_IND = 1 To maxtab(this.HRESSATT)
    If this.HRESSATT(COLLECTION_IND)<>null & find(this.HRESSATT(COLLECTION_IND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      VLINE+=1
      this.HRESSATT(COLLECTION_IND).NUMLIG = VLINE
    Endif
  Next
Endif
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "HRESSATT.BLOB"              : Gosub HRESSATT_BLOB
Endcase
Return

$HRESSATT_BLOB
Case [L]ARULE
  When "PROPAGATE"
    Gosub HRESSATT_BLOB_PROPAGATE
Endcase
Return

$HRESSATT_BLOB_PROPAGATE
Local Char FULLNAME(250)
#Local Instance I_AVOLFIL Using C_AVOLFIL
#I_AVOLFIL = NewInstance C_AVOLFIL AllocGroup null
#[L]ASTATUS = fmet I_AVOLFIL.AINIT()
#I_AVOLFIL.CONTENTS = this.BLOB
#FULLNAME = fmet this.AGETVALPARAMURL("FULLNAME")
#ASTATUS=fmet this.ASETERROR([L]CURPRO,FULLNAME,[V]CST_AINFO)

#FreeGroup I_AVOLFIL
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




