#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:01"
A_USER  = "DOC"
A_STAMP = "20181109230601"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRMIS"
  If [M]NBRMIS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask POT1 [POT1]
Gosub HORODAT
Local Inpbox "POT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT1] As [SIM_]
Grizo [POT1]5
Grizo [POT1]20
Grizo [POT1]25
Grizo [POT1]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POT1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=80 : Y1(1)=5 : Y2(1)=17
X1(2)=1 : X2(2)=80 : Y1(2)=18 : Y2(2)=21
X1(3)=1 : X2(3)=80 : Y1(3)=22 : Y2(3)=25
Return

$ON_DESSHO
Onevent INIT_AREA Call D_DESSHO(zc) From W1POT1
Onevent BEFORE_INPUT Call AS_DESSHO(zc) From W1POT1
Return

Subprog IB_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESSHO(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESSHO,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"POSTE","DESSHO",[M]COD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESSHO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESSHO(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESSHO(zc) From W1POT1
Gosub _AFF
End

Subprog B1_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESSHO" : PROGSUB = "SUBPOT" : PROGSPE = "SPEPOT0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "POSTE"
 PARMSK(2) = "DESSHO"
 PARMSK(3) = [M]COD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESSHO" : PROGSUB = "SUBPOT" : PROGSPE = "SPEPOT0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

