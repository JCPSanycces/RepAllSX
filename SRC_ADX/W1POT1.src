$ON_JOBPOT
Onevent CONTROL Call C_JOBPOT(zc) From W1POT1
Onevent AFTER_CHANGE Gosub AMM_JOBPOT From W1POT1
Onevent BEFORE_INPUT Call AS_JOBPOT(zc) From W1POT1
Return

Subprog AS_JOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45810,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_JOBPOT(zc) From W1POT1
Onkey   2 Titled GBOUTS Call S_JOBPOT(zc) From W1POT1
Onkey 144 Titled GBOUTP Call P_JOBPOT(zc) From W1POT1
Onkey 146 Titled GBOUTA Call SA_JOBPOT(zc) From W1POT1
Gosub _AFF
End

Subprog C_JOBPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_JOBPOT(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
Endif
Gosub _AFF
End

$AMM_JOBPOT
Call AM_JOBPOT(zc)
If !mkstat & GOBJET
 zoncou = "JOBPOT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_JOBPOT(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZJOBPOT)")>indice
 [M]JOBPOT(indice) = VALEUR
 Affzo ZJOBPOT(indice)
Endif
Gosub _AFF
End

Subprog S_JOBPOT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELJOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELJOT"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELJOT","SUBJOT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_JOBPOT(VALEUR)
Variable Char    VALEUR()
Call OBJET("JOT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_JOBPOT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "JOT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_JOBPOT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("JOT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZJOBPOT
Onevent BEFORE_AREA Gosub AV_ZJOBPOT From W1POT1
Return

$AV_ZJOBPOT
Call LECTEXTRA(zc,"JOBTYP","DES",num$([M]JOBPOT(indice)),"") From ATEXTRA
Gosub _AFF
Return

