$ON_MIS
Onevent BEFORE_INPUT Call AS_MIS(zc) From W1POT1
Onevent CONTROL Call C_MIS(zc) From W1POT1
Onevent AFTER_AREA Call AP_MIS(zc) From W1POT1
Onevent AFTER_CHANGE Gosub AMM_MIS From W1POT1
Return

Subprog AS_MIS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16225,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_MIS(VALEUR) From SUBPOT
If mkstat=2
 [M]MIS(INDIC) = VALEUR
 Affzo MIS(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_MIS(zc) From W1POT1
Onkey   2 Titled GBOUTS Call S_MIS(zc) From W1POT1
Onkey 144 Titled GBOUTP Call P_MIS(zc) From W1POT1
Onkey 146 Titled GBOUTA Call SA_MIS(zc) From W1POT1
Gosub _AFF
End

Subprog C_MIS(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("MIS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
 If !mkstat
  ## Action STD
  Call C_MIS(VALEUR) From SUBPOT
  If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog AP_MIS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_MIS(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
Gosub _AFF
End

$AMM_MIS
Call AM_MIS(zc)
If !mkstat & GOBJET
 zoncou = "MIS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MIS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_MIS(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZMIS)")>indice
 [M]MIS(indice) = VALEUR
 Affzo ZMIS(indice)
Endif
Gosub _AFF
End

