#<AdxTL>@(#)0.0.0.0 $Revision$
# Class BSIIMPTC


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "BSITC.LINES.COD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROPAGATE_COD
    Endcase
    When "BSITC.LINES.LEV"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROPAGATE_LEV
    Endcase
        When "BSITC.LINES.REC"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROPAGATE_REC
    Endcase
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


###################################################################################################
$INIT_REC
Gosub $MASK_REC
Return

$PROPAGATE_REC
Gosub $MASK_REC
Return

$MASK_REC
If (this.REC <> "")

While  len(this.REC) <> 2
      this.REC = "0" + this.REC
    Wend
Endif
If pat(this.REC,"##")<>0
       # pattern verified
       Else
       ASTATUS = fmet this.ASETERROR("REC","Code must be numeric",[V]CST_AERROR)
Endif

Return


$INIT_COD
Gosub $MASK_COD
Return

$COD_CONTROL
  If this.COD <> ""
    If func CTRL_EXIST_COD(this.BSICODTC, this.BAN, this.COD) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("COD",mess(45,7779,1)-":"-this.COD,[V]CST_AERROR)
    Endif
  Endif
Return


Funprog CTRL_EXIST_COD(WBSICODTC,WBAN,WCOD)
  Value Char WCOD
  Value Char WBAN
  Value Char WBSICODTC
  Local Integer WOK : WOK = [V]CST_AFALSE

  If WCOD <> ""
    Local File BSIITCD [BSIITCD]
    Read [BSIITCD]BSITCD0 = WBSICODTC;WBAN;WCOD
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSIITCD]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK


$PROPAGATE_COD
Gosub $MASK_COD
Gosub COD_CONTROL
Return

$MASK_COD
If (this.COD <> "")
While  len(this.COD) <> 3
      this.COD = "0" + this.COD
    Wend
Endif
If pat(this.COD,"###")<>0
 ASTATUS = fmet this.ASETATTRIBUTE("LEV", "$isMandatory", "true")
 ASTATUS = fmet this.ASETATTRIBUTE("DESAXX", "$isMandatory", "true")
       # pattern verified
       Else
       ASTATUS = fmet this.ASETERROR("COD","Code must be numeric",[V]CST_AERROR)
       ASTATUS = fmet this.ASETATTRIBUTE("LEV", "$isMandatory", "false")
       ASTATUS = fmet this.ASETATTRIBUTE("DESAXX", "$isMandatory", "false")
 Endif
Return

$INIT_LEV
 Gosub LEVEL_CHANGED
Return

$PROPAGATE_LEV
 Gosub LEVEL_CHANGED
Return

$LEVEL_CHANGED
If this.LEV = 3
  ASTATUS = fmet this.ASETATTRIBUTE("DESFLD", "$isMandatory", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("SIG", "$isMandatory", "true")


Else
ASTATUS = fmet this.ASETATTRIBUTE("DESFLD", "$isMandatory", "false")
ASTATUS = fmet this.ASETATTRIBUTE("SIG", "$isMandatory", "false")

Endif

Return

