$AQCC_KEY1
Case [L]ARULE
  When "PROPAGATE"  : Gosub SET_COLAQC_ISDISABLED
Endcase
Return

$AQCC_COLAQC_LINE
Case [L]ARULE
  When "PROPAGATE"  : Gosub SET_KEY1_ISDISABLED
Endcase
Return

