#<AdxTL>@(#)%I%
# Supervisor
# Inquiry MES

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:10"
A_USER  = "ADMIN"
A_STAMP = "20181109081110"
Return

$DEFAUT
Default File [MHS]
Return

$OUVFIC
Local File MSHISTO [MHS]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(44886,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSMESSTD"
PROGSPE    = "CNSMESSPE"
CBOITE     = "DCNSMES"
BOITE      = "FCNSMES"
NOMMSK(0)  = "CONSMES1"
ABMSK(0)   = "MES1"
NOMMSK(1)  = "CONSMES2"
ABMSK(1)   = "MES2"
NOMMSK(2)  = "CONSMES3"
ABMSK(2)   = "MES3"
CMEMO      = "ctp"
CNOMMSK    = "CRITMES"
CABMSK     = "CMES"
NOMFIC     = "MSHISTO"
ABFIC      = "MHS"
MAGNETO    = 2
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..1), CLEMSK(10)(0..1)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "MHS3"
NBCMP = 2
CLECMP(0) = "COD"
CLEMSK(0) = "COD"
CLECMP(1) = "DAT"
CLEMSK(1) = "DAT"
Return

$OUVRE
If clalev([F:MHS])=0 : Local File MSHISTO      [MHS] : Endif
If clalev([F:MHS])=0 : Local File MSHISTO      [MHS] : Endif
If clalev([F:MCH])=0 : Local File MSSCENAH     [MCH] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CMES]
 When  0 : Local Mask =NOMMSK(0) [MES1]
 When  1 : Local Mask =NOMMSK(1) [MES2]
 When  2 : Local Mask =NOMMSK(2) [MES3]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CMES]
 When  0 : Grizo [MES1]
 When  1 : Grizo [MES2]
 When  2 : Grizo [MES3]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CMES]COD)>0 : Grizo [CMES]COD : Endif
           If dim([M:CMES]DAT)>0 : Grizo [CMES]DAT : Endif
 When  0 : If dim([M:MES1]COD)>0 : Grizo [MES1]COD : Endif
           If dim([M:MES1]DAT)>0 : Grizo [MES1]DAT : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CMES]COD)>0
 Grizo [CMES]COD
Endif
If dim([M:CMES]DAT)>0
 Grizo [CMES]DAT
Endif
If dim([M:CMES]CPY)>0
 Grizo [CMES]CPY
Endif
If dim([M:CMES]FCY)>0
 Grizo [CMES]FCY
Endif
If dim([M:CMES]SRV)>0
 Grizo [CMES]SRV
Endif
If dim([M:CMES]EMP)>0
 Grizo [CMES]EMP
Endif
If dim([M:CMES]CTR)>0
 Grizo [CMES]CTR
Endif
If dim([M:CMES]POP)>0
 Grizo [CMES]POP
Endif
If dim([M:CMES]CODCOMP)>0
 Grizo [CMES]CODCOMP
Endif
If dim([M:CMES]DISPLAY)>0
 Grizo [CMES]DISPLAY
Endif
If dim([M:CMES]DETAIL)>0
 Grizo [CMES]DETAIL
Endif
If dim([M:CMES]TOUTE)>0
 Grizo [CMES]TOUTE
Endif
If dim([M:CMES]PRF)>0
 Grizo [CMES]PRF
Endif
If dim([M:CMES]JOBPOT)>0
 Grizo [CMES]JOBPOT
Endif
If dim([M:CMES]POT)>0
 Grizo [CMES]POT
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CMES])>0 : Close Local Mask [CMES] : Endif
 When  0 : If clalev([M:MES1])>0 : Close Local Mask [MES1] : Endif
 When  1 : If clalev([M:MES2])>0 : Close Local Mask [MES2] : Endif
 When  2 : If clalev([M:MES3])>0 : Close Local Mask [MES3] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CMES]
 When  0 : Default Mask [MES1]
 When  1 : Default Mask [MES2]
 When  2 : Default Mask [MES3]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CMES]
 When  0 : Raz [M:MES1]
 When  1 : Raz [M:MES2]
 When  2 : Raz [M:MES3]
Endcase
Return

$CRITENT
If dim([M:CMES]COD)>0 & dim([M:MES1]COD)>0
 [M:CMES]COD = [M:MES1]COD
Endif
If dim([M:CMES]DAT)>0 & dim([M:MES1]DAT)>0
 [M:CMES]DAT = [M:MES1]DAT
Endif
If dim([M:CMES]CPY)>0 & dim([M:MES1]CPY)>0
 [M:CMES]CPY = [M:MES1]CPY
Endif
If dim([M:CMES]FCY)>0 & dim([M:MES1]FCY)>0
 [M:CMES]FCY = [M:MES1]FCY
Endif
If dim([M:CMES]SRV)>0 & dim([M:MES1]SRV)>0
 [M:CMES]SRV = [M:MES1]SRV
Endif
If dim([M:CMES]EMP)>0 & dim([M:MES1]EMP)>0
 [M:CMES]EMP = [M:MES1]EMP
Endif
If dim([M:CMES]CTR)>0 & dim([M:MES1]CTR)>0
 [M:CMES]CTR = [M:MES1]CTR
Endif
If dim([M:CMES]POP)>0 & dim([M:MES1]POP)>0
 [M:CMES]POP = [M:MES1]POP
Endif
If dim([M:CMES]CODCOMP)>0 & dim([M:MES1]CODCOMP)>0
 [M:CMES]CODCOMP = [M:MES1]CODCOMP
Endif
If dim([M:CMES]DISPLAY)>0 & dim([M:MES1]DISPLAY)>0
 [M:CMES]DISPLAY = [M:MES1]DISPLAY
Endif
If dim([M:CMES]DETAIL)>0 & dim([M:MES1]DETAIL)>0
 [M:CMES]DETAIL = [M:MES1]DETAIL
Endif
If dim([M:CMES]TOUTE)>0 & dim([M:MES1]TOUTE)>0
 [M:CMES]TOUTE = [M:MES1]TOUTE
Endif
If dim([M:CMES]PRF)>0 & dim([M:MES1]PRF)>0
 [M:CMES]PRF = [M:MES1]PRF
Endif
If dim([M:CMES]JOBPOT)>0 & dim([M:MES1]JOBPOT)>0
 [M:CMES]JOBPOT = [M:MES1]JOBPOT
Endif
If dim([M:CMES]POT)>0 & dim([M:MES1]POT)>0
 [M:CMES]POT = [M:MES1]POT
Endif
Return

$ENTCRIT
If dim([M:CMES]COD)>0 & dim([M:MES1]COD)>0
[M:MES1]COD = [M:CMES]COD
Endif
If dim([M:CMES]DAT)>0 & dim([M:MES1]DAT)>0
[M:MES1]DAT = [M:CMES]DAT
Endif
If dim([M:CMES]CPY)>0 & dim([M:MES1]CPY)>0
[M:MES1]CPY = [M:CMES]CPY
Endif
If dim([M:CMES]FCY)>0 & dim([M:MES1]FCY)>0
[M:MES1]FCY = [M:CMES]FCY
Endif
If dim([M:CMES]SRV)>0 & dim([M:MES1]SRV)>0
[M:MES1]SRV = [M:CMES]SRV
Endif
If dim([M:CMES]EMP)>0 & dim([M:MES1]EMP)>0
[M:MES1]EMP = [M:CMES]EMP
Endif
If dim([M:CMES]CTR)>0 & dim([M:MES1]CTR)>0
[M:MES1]CTR = [M:CMES]CTR
Endif
If dim([M:CMES]POP)>0 & dim([M:MES1]POP)>0
[M:MES1]POP = [M:CMES]POP
Endif
If dim([M:CMES]CODCOMP)>0 & dim([M:MES1]CODCOMP)>0
[M:MES1]CODCOMP = [M:CMES]CODCOMP
Endif
If dim([M:CMES]DISPLAY)>0 & dim([M:MES1]DISPLAY)>0
[M:MES1]DISPLAY = [M:CMES]DISPLAY
Endif
If dim([M:CMES]DETAIL)>0 & dim([M:MES1]DETAIL)>0
[M:MES1]DETAIL = [M:CMES]DETAIL
Endif
If dim([M:CMES]TOUTE)>0 & dim([M:MES1]TOUTE)>0
[M:MES1]TOUTE = [M:CMES]TOUTE
Endif
If dim([M:CMES]PRF)>0 & dim([M:MES1]PRF)>0
[M:MES1]PRF = [M:CMES]PRF
Endif
If dim([M:CMES]JOBPOT)>0 & dim([M:MES1]JOBPOT)>0
[M:MES1]JOBPOT = [M:CMES]JOBPOT
Endif
If dim([M:CMES]POT)>0 & dim([M:MES1]POT)>0
[M:MES1]POT = [M:CMES]POT
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
CRITAFF(1) = "DISPLAY" : CRITAFF2(1) = "DISPLAY"
NBCA = 1
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSMES2"
Call AS_NBLIG From ="W1CONSMES3"
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


