#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Etape 1 de la définition d'un mailing                             Module CRM          07 novembre 2000 #
##########################################################################################################
# Caractéristiques du mailing
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer ISDIRTY

  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  ISDIRTY = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:OMM0]
  Raz [M:OMM1]
  If GSZOPGNUM = "" Then
    #Définit la devise par défaut
    [M:OMM0]FCY = [M:CMG0]FCY
    [M:OMM1]CUR = GSYSCUR
    [M:OMM0]CMGNUM = [M:CMG0]NUM
    [M:OMM0]CMGTTR = [M:CMG0]TTR
  Else
    Read [OMM]OMM0=GSZOPGNUM
    If fstat Then
      Return
    Endif
    Read [CMG]CMG0=[F:OMM]CMGNUM
    If fstat Then
      [M:OMM0]CMGTTR = ""
    Else
      [M:OMM0]CMGTTR = [F:CMG]TTR
    Endif
    [M:OMM0]CMGNUM = [F:OMM]CMGNUM
    [M:OMM0]OMMNUM = [F:OMM]OMMNUM
    [M:OMM0]FCY = [F:OMM]FCY
    [M:OMM1]DES = [F:OMM]DES
    [M:OMM1]OBJ = [F:OMM]OBJ
    [M:OMM1]BUD = [F:OMM]BUD
    [M:OMM1]CUR = [F:OMM]CUR
    [M:OMM1]TYPFULOBJ = [F:OMM]TYPFULOBJ
    [M:OMM1]NUMFULOBJ = [F:OMM]NUMFULOBJ
    [M:OMM1]OBJFLG = [F:OMM]OBJFLG
    Read [HD5]HD50=[F:OMM]NUMFULOBJ;[F:OMM]TYPFULOBJ
    If fstat Then
      Raz [M:OMM1]FULOBJ
    Else
      [M:OMM1]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM0]1-99
  Affzo [M:OMM1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:OMM0]
  Raz [M:OMM1]
  Kill ISDIRTY
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCPT(GLONANM)

  SZCPT = ""
  #La description doit être renseignée.
  If [M:OMM1]DES = "" Then
    GMESSAGE = mess(342,196,1) #Aucune description n'a été saisie. Cette information est obligatoire.
    GERR = 2
    FIN = 0
    Return
  Endif
  #La devise doit être renseignée.
  If [M:OMM1]CUR = "" Then
    GMESSAGE = mess(384,196,1) #Aucun code devise n'est renseigné. Création refusée.
    GERR = 2
    FIN = 0
    Return
  Endif
  Read [TCU]TCU0=[M:OMM1]CUR
  If fstat Then
    GMESSAGE = mess(84,116,1) #Devise incorrecte.
    GERR = 2
    FIN = 0
    Return
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 2
          FIN = 0
          Return
        Endif
      Endif
    Endif
  Endif
  # Récupération du compteur Activité commerciale
  If GSZOPGNUM = "" Then
    # ----------------------------------------------------------
    # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
    #    If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
    #    Read [TCA]TCA0=13
    #    If fstat Then
    #      GERR = 1
    #      GMESSAGE = mess(64,199,1)
    #    Endif
    #    GMANCOU = [F:TCA]MANCOU(2)
    #    SZCPT = [F:TCA]CODNUM(2)
    Call READ_COUNTER([M:OMM0]FCY, 13, 2, GSOCIETE, GCURLEG, SZCPT, GMANCOU) From CRM_UTIL
    # FGR 20/12/2012 : X3SUIVI71937 (fin)
    # ----------------------------------------------------------
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMM0]FCY, SZCPT, date$, "", [M:OMM0]OMMNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        GSZOPGNUM = [M:OMM0]OMMNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        Return
      Endif
    Else
      GSZOPGNUM = [M:OMM0]OMMNUM
    Endif
  Endif
  #
  [M:OMM1]TYPFULOBJ = "OMM"
  [M:OMM1]NUMFULOBJ = [M:OMM0]OMMNUM
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=[M:OMM0]OMMNUM
  If fstat Then
    #Il s'agit d'un nouvel enregistrement
    [F:OMM]OMMNUM = [M:OMM0]OMMNUM
    [F:OMM]FCY = [M:OMM0]FCY
    [F:OMM]CMGNUM = [M:CMG0]NUM
    [F:OMM]DES = [M:OMM1]DES
    [F:OMM]OBJ = [M:OMM1]OBJ
    [F:OMM]BUD = [M:OMM1]BUD
    [F:OMM]CUR = [M:OMM1]CUR
    [F:OMM]CREDAT = date$
    [F:OMM]CREUSR = GUSER
    [F:OMM]UPDDAT = [00/00/00]
    [F:OMM]UPDUSR = ""
    [F:OMM]TPL = ""
    [F:OMM]SHIMOD = 1
    [F:OMM]TYPFULOBJ = [M:OMM1]TYPFULOBJ
    [F:OMM]NUMFULOBJ = [M:OMM1]NUMFULOBJ
    [F:OMM]OBJFLG = [M:OMM1]OBJFLG
    Write [OMM]
    If fstat Then
      #L'enregistrement du publipostage a échoué.
      GMESSAGE = mess(886,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMMB
      If GOK < 1 Then
        #L'enregistrement du publipostage a échoué.
        GMESSAGE = mess(886,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Else
    # Il s'agit d'une modification
    [F:OMM]OMMNUM = [M:OMM0]OMMNUM
    [F:OMM]FCY = [M:OMM0]FCY
    [F:OMM]CMGNUM = [M:CMG0]NUM
    [F:OMM]DES = [M:OMM1]DES
    [F:OMM]OBJ = [M:OMM1]OBJ
    [F:OMM]BUD = [M:OMM1]BUD
    [F:OMM]CUR = [M:OMM1]CUR
    [F:OMM]UPDDAT = date$
    [F:OMM]UPDUSR = GUSER
    [F:OMM]TPL = ""
    [F:OMM]SHIMOD = 1
    [F:OMM]TYPFULOBJ = [M:OMM1]TYPFULOBJ
    [F:OMM]NUMFULOBJ = [M:OMM1]NUMFULOBJ
    [F:OMM]OBJFLG = [M:OMM1]OBJFLG
    Rewrite [OMM]
    If fstat Then
      #L'enregistrement du publipostage a échoué.
      GMESSAGE = mess(886,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMMB
      If GOK < 1 Then
        #L'enregistrement du publipostage a échoué.
        GMESSAGE = mess(886,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
  ISDIRTY = 0
Return

##########################################################################################################
$CANCELSTEP
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=GSZOPGNUM
  If fstat Then
    Rollback
    Return
  Endif
  Delete [HD5] Where [F:HD5]NUM = [F:OMM]NUMFULOBJ and [F:HD5]TYP = [F:OMM]TYPFULOBJ
  If fstat Then
    Rollback
    Return
  Endif
  Delete [OMM]Curr
  If fstat Then
    Rollback
    Return
  Else
    Commit
  Endif
Return
