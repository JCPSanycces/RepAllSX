#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_VILLE
 When "VERF_TABLE"  : Gosub VERF_VILLE : #49894
Endcase
Return


$SEL_VILLE
# 55284
DEFPAG = 1
TIT(0)  = mess(12,123,1)
TABLE = "POSCOD"
NBCOL = 3
COL(1) = "POSCTY"    : TIT(1) = mess(24,159,1)
COL(2) = "POSCOD"    : TIT(2) = mess(23,159,1)
COL(3) = "POSCTYCOD" : TIT(3) = mess(15,159,1)
CRITERE = 'CRY="'+PARAM(1)+'"'
CRITERE -= '& POSCTY>="'+left$(VALEUR,1)+'"'
Default File [POS]
Return


#49894
$VERF_VILLE
PARAM(2) = [F]POSCTYCOD
Return

