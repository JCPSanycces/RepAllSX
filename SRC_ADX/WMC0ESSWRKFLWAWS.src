####################################################################
# Traitments
####################################################################
$_ADDTRT
this.AINF.TRT(1) = "ESSWRKFLWAWS_CSTD"
this.AINF.TYP(1) = 1
this.AINF.PTH(1) = ""
this.AINF.NBTRT = 1
Return

####################################################################
#Declaration of variables
####################################################################

$DECLARE_VAR
Local Char    ACTION(50) , CURPRO(250) , VALPRO(250) , CURQRY(50) , CURPTH(250)
Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)
Local Integer ALLSTAT,AISMET,ASTATUS
Return


####################################################################
# Global methods & standards
####################################################################
$AINIT
Gosub DECLARE_VAR
[L]AEVENT = "AINIT" : [L]ACTION = "AINIT" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To maxtab(this.ESSWRKEMP)
 If this.ESSWRKEMP(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKEMP(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKSA)
 If this.ESSWRKSA(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKSA(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKCHD)
 If this.ESSWRKCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKCHD(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To maxtab(this.ESSWRKEMP)
 If this.ESSWRKEMP(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKEMP(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKSA)
 If this.ESSWRKSA(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKSA(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKCHD)
 If this.ESSWRKCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKCHD(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To maxtab(this.ESSWRKEMP)
 If this.ESSWRKEMP(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKEMP(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESSWRKEMP('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKSA)
 If this.ESSWRKSA(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKSA(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESSWRKSA('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESSWRKCHD)
 If this.ESSWRKCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESSWRKCHD(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESSWRKCHD('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0ESSWRKFLWAWS
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
# RICH MEDIA
####################################################################
$AREAD_BLB
Case [L]_PRONAME
 When "EMPPIC"
  If fmet this.AGETATTRIBUTE("EMPPIC","$isLoaded")<>"true"
   Gosub READ_BLB_EMPPIC
  Else
   [L]_BLB = this.EMPPIC
  Endif
  If [L]_CNT=''
   [L]ASTATUS = fmet this.ASETATTRIBUTE("EMPPIC","$contentType","image")
   [L]_CNT = "image"
  Endif
Endcase
Return

$READ_BLB_EMPPIC
If this.ACTX.AFOLDER="" | this.ACTX.AFOLDER=nomap
Local File BBLOB [WBBB]
Else
Local File =this.ACTX.AFOLDER+".BBLOB" [WBBB]
Endif
Raz [L]_BLB
Raz [L]_CNT
Gosub DECODE_KEYVAL From ASYRLOB
[F:WBBB]CODBLB = [L]_KEYVALTAB(1)
[F:WBBB]IDENT1 = [L]_KEYVALTAB(2)
[F:WBBB]IDENT2 = [L]_KEYVALTAB(3)
[F:WBBB]IDENT3 = [L]_KEYVALTAB(4)
[F:WBBB]IDENT4 = [L]_KEYVALTAB(5)
Read [WBBB] =
If !fstat
 [L]_BLB = [F:WBBB]BLOB
Endif
LogicClose File [WBBB]
Return

$READ_EXI_EMPPIC
If this.ACTX.AFOLDER="" | this.ACTX.AFOLDER=nomap
Local File BBLOB [WBBB]
Else
Local File =this.ACTX.AFOLDER+".BBLOB" [WBBB]
Endif
Local Tinyint _EXI : [L]_EXI=1
[F:WBBB]CODBLB = "EMPPIC"
[F:WBBB]IDENT1 = this.REFNUM
[F:WBBB]IDENT2 = ""
[F:WBBB]IDENT3 = ""
[F:WBBB]IDENT4 = ""
Look [WBBB] =
If fstat
 [L]_EXI=0
Endif
LogicClose File [WBBB]
Return

####################################################################
$ACONTROL
####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "ESSWRKCHD"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESSWRKCHD",this)
 When "ESSWRKEMP"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESSWRKEMP",this)
 When "ESSWRKSA"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESSWRKSA",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "ESSWRKCHD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESSWRKCHD","C_ESSWRKCHD",this)
 When "ESSWRKEMP"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESSWRKEMP","C_ESSWRKEMP",this)
 When "ESSWRKSA"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESSWRKSA","C_ESSWRKSA",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "ESSWRKCHD"
  [L]_ALINE = 0
 When "ESSWRKEMP"
  [L]_ALINE = 0
 When "ESSWRKSA"
  [L]_ALINE = 0
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "ESSWRKCHD"
  [L]_ALINE = 1
 When "ESSWRKEMP"
  [L]_ALINE = 1
 When "ESSWRKSA"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ALOAD_KEYS
####################################################################
$_ALOAD_KEYS
this.AKEYS(1) = "UID"
this.AKEYS(2) = "CLA"
this.AKEYS(3) = "REFNUM"
this.AKEYS(4) = "MAIREC"
this.AKEYS(5) = "FLDNAM"
Return

####################################################################
# _ADELINSTANCE
####################################################################
$_ADELINSTANCE
[L]ASTATUS = func ASYRSUBTAB._ADELINSTANCE(this)
Return

####################################################################
# ADDINSTANCE_BOUND
####################################################################
$ADDINSTANCE_BOUND
Return



