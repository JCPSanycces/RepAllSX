#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_SOURCE

##############################################################################
# MAJ du champ TRFDATRCP (date virement entrée)
# Pour les immos actives et qui ont été créées par virement+, on initialise le
# champ TRFDATRCP à la date contenue dans [FAS]TRFDAT. Ce champ est ensuite
# remise à zéro
##############################################################################
Call MAJ_UTIIMM02
End

Subprog MAJ_UTIIMM02

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIIMM02:"-toupper(mess(70,117,1))-tolower(mess(1,89,1))-"TRFDATRCP") From LECFIC
Call SAIDOS(DOSSIER,"UTIIMM02") From SAIDOS
If DOSSIER<>"" Call EXE_UTIIMM02(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTIIMM02(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","FIXASSET","fde",APPLI),0) < 0 : End : Endif
If clalev([F:FAS])=0  Local File =APPLI+".FIXASSET" [FAS] : Endif

Call ECR_TRACE("UTIIMM02: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTIIMM02
Call ECR_TRACE("UTIIMM02: Process End on : "+APPLI,0) From GESECRAN

End

#### Corps de la moulinette - début


$TR_UTIIMM02
Trbegin [FAS]
 For [FAS]FAS0 Where TRFDAT<>[0/0/0] & STA=1
  [F:FAS]TRFDATRCP = [F:FAS]TRFDAT
  [F:FAS]TRFDAT = [0/0/0]
  Rewrite [FAS]
  If fstat
   GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"FIXASSET"-":"-[F:FAS]FASCOD-"/"-num$([F:FAS]FASNUM),1) From GESECRAN
   Break
  Endif
 Next
 If !GOK : Goto AB_UTIIMM02 : Endif
Commit
Return


$AB_UTIIMM02
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI

##1## IF APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(3) <> 2 : End : Endif
Call EXE_UTIIMM02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(3) <> 2 : End : Endif
Call EXE_UTIIMM02(APPLI)
End


