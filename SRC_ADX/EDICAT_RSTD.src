###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"     : Gosub AQUERY_TRANS_AFTER # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
        When "AREAD_AFTER"            : Gosub AREAD_AFTER
        When Default
      Endcase
    When "ECA"
      Case [L]AEVENT
        When "AREAD_AFTER"          : Gosub ECA_AREAD_AFTER
      Endcase
    When "ECA.ECAD"
      Case [L]AEVENT
        When "AREAD_AFTER"          : Gosub ECA_ECAD_AREAD_AFTER
        When Default
      Endcase
    When "ECA.ECAK"
      Case [L]AEVENT
        When "AREAD_AFTER"          : Gosub ECA_ECAK_AREAD_AFTER
        When Default
      Endcase
    When "ECA.ECAL"
      Case [L]AEVENT
        When "AREAD_AFTER"          : Gosub ECA_ECAL_AREAD_AFTER
        When Default
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "ECA.CATACT"        # : Gosub ECA_CATACT
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_CATACT_PROPAGATE
      Endcase
    When "ECA.CATTYP"        # : Gosub ECA_CATTYP      # 110811
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_CATTYP_PROPAGATE
      Endcase
    When "ECA.ECAD.FLD"      # : Gosub ECA_ECAD_FLD
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_ECAD_FLD_PROPAGATE
      Endcase
    When "ECA.ECAD.OPERATOR" # : Gosub ECA_ECAD_OPERATOR
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_ECAD_OPERATOR_PROPAGATE
      Endcase
    When "ECA.ECAD.UPDFLG"   # : Gosub ECA_ECAD_UPDFLG
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_ECAD_UPDFLG_PROPAGATE
      Endcase
    When "ECA.ECAK.FLD"      # : Gosub ECA_ECAK_FLD
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_ECAK_FLD_PROPAGATE
      Endcase
    When "ECA.ECAL.CODE"     # : Gosub ECA_ECAL_CODE
      Case [L]ARULE
        When "PROPAGATE"  : Gosub ECA_ECAL_CODE_PROPAGATE
      Endcase
    When "NOHOMONYM"         # : Gosub NOHOMONYM
      Case [L]ARULE
        When "GET"  : this.NOHOMONYM = [V]CST_ANO
      Endcase
  Endcase
Return

####################################################################
#$ECA_CATACT
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_CATACT_PROPAGATE
#  Endcase
#Return

$ECA_CATACT_PROPAGATE
  Local Integer I
  For I = 1 To maxtab (this.ECAD)
    Call ECA_ECAD_DISPLAY(this.ECAD(I))
  Next I
  For I = 1 To maxtab (this.ECAK)
    Call ECA_ECAK_DISPLAY(this.ECAK(I))
  Next I
Return

####110811 Exceptions duplication by legislation ####################
#$ECA_CATTYP
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_CATTYP_PROPAGATE
#  Endcase
#Return

$ECA_CATTYP_PROPAGATE
  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"

  If this.CATTYP<3
    WOK = fmet this.ASETATTRIBUTE("DUPLICATE", WPROP, "true")
  Else
    WOK = fmet this.ASETATTRIBUTE("DUPLICATE", WPROP, "false")
  Endif

Return
####################################################################
#$NOHOMONYM
#  Case [L]ARULE
#    When "GET"  : this.NOHOMONYM = [V]CST_ANO
#  Endcase
#Return
####################################################################
#$ECA_ECAD_FLD
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_ECAD_FLD_PROPAGATE
#  Endcase
#Return

$ECA_ECAD_FLD_PROPAGATE
  If this.FLD <> ""
    #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = this.APARENT.CATTRGTAB;this.FLD
    If !fstat
      #get text
      Local File ATEXTE [ATX]
      Read [ATX]NUMERO = this.APARENT.ACTX.LAN;[F:ATZ]NOCOURT
      If !fstat
        this.FLDNAM = [F:ATX]TEXTE
      Endif
      LogicClose File [ATX]
    Endif
    LogicClose File [ATZ]
  Endif
Return


####################################################################
#$ECA_ECAD_OPERATOR
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_ECAD_OPERATOR_PROPAGATE
#  Endcase
#Return

$ECA_ECAD_OPERATOR_PROPAGATE
  Call ECA_ECAD_DISPLAY(this)
Return

####################################################################
#$ECA_ECAD_UPDFLG
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_ECAD_UPDFLG_PROPAGATE
#  Endcase
#Return

$ECA_ECAD_UPDFLG_PROPAGATE
  Call ECA_ECAD_DISPLAY(this)
Return


####################################################################
#$ECA_ECAK_FLD
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_ECAK_FLD_PROPAGATE
#  Endcase
#Return

$ECA_ECAK_FLD_PROPAGATE
  If this.FLD <> ""
    #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = this.APARENT.CATTRGTAB;this.FLD
    If !fstat
      #get text
      Local File ATEXTE [ATX]
      Read [ATX]NUMERO = this.APARENT.ACTX.LAN;[F:ATZ]NOCOURT
      If !fstat
        this.FLDNAM = [F:ATX]TEXTE
      Endif
      LogicClose File [ATX]
    Endif
    LogicClose File [ATZ]
  Endif
Return


#$ECA_ECAL_CODE
#  Case [L]ARULE
#    When "PROPAGATE"  : Gosub ECA_ECAL_CODE_PROPAGATE
#  Endcase
#Return

$ECA_ECAL_CODE_PROPAGATE
  Local Char WSTR(100)
  If this.CODE <> ""
    Call LECTEXTRA_SYR(this,"", WSTR,"ATABDIV","LNGDES","909",this.CODE) From ATEXTRA
    this.LEGDES = WSTR
  Else
    this.LEGDES = ""
  Endif
Return

#####################################################################
# STANDARD METHODS
#####################################################################
$AQUERY_TRANS_AFTER # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  If this.ECA.CATOPE = 0  # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
    this.ECA.CATOPE = 2 #Create
  Endif
Return


$AREAD_AFTER
  If this.ECA.CATOPE = 0  # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
    this.ECA.CATOPE = 2 #Create
  Endif
  this.ECA.FLGSYRA = func EDICAT_CSTD.GET_FLGSYRA(this.ECA.CATTYP) # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements

  Local Integer WPOS, WNB

  #display EDI partners using the current category
  WPOS = 0
  WNB = 0
  Local File EDIPARTNER [EPR]
  Local File EDIPARTNERD [EPRD]
  Local File EDIPTC [EPT]
  Link [EPRD] With [EPR]EPR0 = [EPRD]PARCOD, [EPT]EPT0 = [EPRD]PTCCOD As [LIEN] Where [EPRD]CATTYP = this.ECA.CATTYP and [EPRD]CATCOD = this.ECA.CATCOD
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #limit of collection
      WPOS = fmet this.ADDLINE('PART', [V]CST_ALASTPOS)
      this.PART(WPOS).PARTPARCOD = [EPRD]PARCOD
      this.PART(WPOS).PARTCATACT = [EPRD]CATACT
      this.PART(WPOS).PARTPARDES = [EPR]PARDES
      this.PART(WPOS).PARTPTCCOD = [EPRD]PTCCOD
      this.PART(WPOS).PARTPTCDES = [EPT]PTCDES
      this.PART(WPOS).PARTPTCTYP = [EPT]PTCTYP
      this.PART(WPOS).PARTFLGACT = [EPR]FLGACT
    Endif
  Next
  LogicClose File [EPT]
  LogicClose File [EPRD]
  LogicClose File [EPR]


  #display EDI flows using the current category
  WPOS = 0
  WNB = 0
  Local File EDIFLO [EFL]
  Filter [EFL] Where CATCOD = this.ECA.CATCOD Order By FLOCOD; FLOREL
  For [EFL]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #limit of collection
      WPOS = fmet this.ADDLINE('FLO', [V]CST_ALASTPOS)
      this.FLO(WPOS).FLOFLOCOD = [EFL]FLOCOD
      this.FLO(WPOS).FLOFLOREL = [EFL]FLOREL
      this.FLO(WPOS).FLOFLODES = [EFL]FLODES
      this.FLO(WPOS).FLOVALID  = [EFL]VALID
      this.FLO(WPOS).FLOFLGACT = [EFL]FLGACT
    Endif
  Next
  LogicClose File [EFL]


  #display EDIRUN using the current category
  WPOS = 0
  WNB = 0
  Local File EDIRUN [EDR]
  Filter [EDR] Where CATCOD = this.ECA.CATCOD Order By LASRUNDAT Desc #NUM
  For [EDR]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #limit of collection
      WPOS = fmet this.ADDLINE('EDIRUN', [V]CST_ALASTPOS)
      this.EDIRUN(WPOS).RUNCATACT    = [EDR]CATACT
      this.EDIRUN(WPOS).RUNLASRUNDAT = [EDR]LASRUNDAT
      this.EDIRUN(WPOS).RUNNUM       = [EDR]NUM
      this.EDIRUN(WPOS).RUNRUNDES    = [EDR]RUNDES
    Endif
  Next
  LogicClose File [EDR]

Return


#********************************************************************
# Method ECA_AREAD_AFTER
#********************************************************************
#*
#*!
$ECA_AREAD_AFTER
  Call ECA_DISPLAY(this)
Return

#********************************************************************
# Method ECA_ECAD_AREAD_AFTER
#********************************************************************
#*
#*!
$ECA_ECAD_AREAD_AFTER
  Call ECA_ECAD_DISPLAY(this)
  If this.FLD <> "" and this.APARENT.CATACT=1
    #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = this.APARENT.CATTRGTAB;this.FLD
    If !fstat
      #get text
      Local File ATEXTE [ATX]
      Read [ATX]NUMERO = this.APARENT.ACTX.LAN;[F:ATZ]NOCOURT
      If !fstat
        this.FLDNAM = [F:ATX]TEXTE
      Endif
      LogicClose File [ATX]
    Endif
    LogicClose File [ATZ]
  Endif
Return


#********************************************************************
# Method ECA_ECAK_AREAD_AFTER
#********************************************************************
#*
#*!
$ECA_ECAK_AREAD_AFTER
  Call ECA_ECAK_DISPLAY(this)
  this.CODNAM = func EDILIBA.GET_CODNAM(this.CODE)

  If this.FLD <> "" and this.APARENT.CATACT=1
    #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = this.APARENT.CATTRGTAB;this.FLD
    If !fstat
      #get text
      Local File ATEXTE [ATX]
      Read [ATX]NUMERO = this.APARENT.ACTX.LAN;[F:ATZ]NOCOURT
      If !fstat
        this.FLDNAM = [F:ATX]TEXTE
      Endif
      LogicClose File [ATX]
    Endif
    LogicClose File [ATZ]
  Endif
Return


#********************************************************************
# Method ECA_ECAL_AREAD_AFTER
#********************************************************************
#*
#*!
$ECA_ECAL_AREAD_AFTER
  Local Char WSTR(100)
  If this.CODE <> ""
    Call LECTEXTRA_SYR(this,"", WSTR,"ATABDIV","LNGDES","909",this.CODE) From ATEXTRA
    this.LEGDES = WSTR
  Else
    this.LEGDES = ""
  Endif
Return
#####################################################################
# USEFULL FUNCTIONS & SUBPROGS
#####################################################################

#********************************************************************
# Subprog ECA_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog ECA_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"

  If WOBJECT.snapshot = null #.CATTYP <> WOBJECT.CATTYP
    WOK = fmet WOBJECT.ASETATTRIBUTE("CATTYP", WPROP, "true")
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE("CATTYP", WPROP, "false")
  Endif

  #110811 Exceptions duplication by legislation
  If WOBJECT.CATTYP<3
    WOK = fmet WOBJECT.ASETATTRIBUTE("DUPLICATE", WPROP, "true")
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE("DUPLICATE", WPROP, "false")
  Endif
  #End 110811

End

#********************************************************************
# Subprog ECA_ECAD_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog ECA_ECAD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"

  Case WOBJECT.OPERATOR
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL2', WPROP, 'false')
    When 2, 3, 4 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL2', WPROP, 'true')
  Endcase

  WPROP = "$isHidden"

  Case WOBJECT.APARENT.CATACT
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDNAM', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('MANDATORY', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('OPERATOR', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL1', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL2', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('UPDFLG', WPROP, 'false')
    When 2 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDNAM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('MANDATORY', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('OPERATOR', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL1', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDVAL2', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('UPDFLG', WPROP, 'true')
  Endcase


End

#********************************************************************
# Subprog ECA_ECAK_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog ECA_ECAK_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)

  WPROP = "$isHidden"

  Case WOBJECT.APARENT.CATACT
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODE', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODNAM', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDNAM', WPROP, 'false')
    When 2 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODE', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODNAM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDNAM', WPROP, 'true')
  Endcase

End

