#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# X3-76171
# Initialize the new parameter MAXSPEACV value to 300 if not already done
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("MAXSPEACV parameter initialization") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$MAJ_MAXSPEACV
  If DOSSIER=nomap
    Local File ADOPAR [ADP]
    Local File ADOVAL [ADW]
  Else
    Local File =DOSSIER+".ADOPAR" [ADP]
    Local File =DOSSIER+".ADOVAL" [ADW]
  Endif

  Look [F:ADP]ADP1="MAXSPEACV"
  If fstat=[V]CST_AOK
    Local Integer ISUPDATED
    ISUPDATED=[V]CST_AFALSE

    Trbegin [ADW]
    Read [F:ADW]ADW0="";"";"MAXSPEACV"
    If fstat > [V]CST_ALOCK
      Raz [F:ADW]
      [F:ADW]PARAM = "MAXSPEACV"
      [F:ADW]VALEUR = "300"
      If dim([F:ADW]CREDAT)>[V]CST_AFALSE : [F:ADW]CREDAT = date$ : Endif
      If dim([F:ADW]CRETIM)>[V]CST_AFALSE : [F:ADW]CRETIM = time : Endif
      If dim([F:ADW]CREUSR)>[V]CST_AFALSE : [F:ADW]CREUSR = GUSER : Endif
      Write [ADW]
      If fstat
        Call ERREUR("ADOVAL MAXSPEACV",1) From DOSDIC
      Else
        ISUPDATED=[V]CST_ATRUE
      Endif
    Elsif fstat=[V]CST_AOK & ([F:ADW]VALEUR="" | val([F:ADW]VALEUR)=0)
      [F:ADW]VALEUR="300"
      If dim([F:ADW]UPDDAT)>[V]CST_AFALSE : [F:ADW]UPDDAT = date$ : Endif
      If dim([F:ADW]UPDTIM)>[V]CST_AFALSE : [F:ADW]UPDTIM = time : Endif
      If dim([F:ADW]UPDUSR)>[V]CST_AFALSE : [F:ADW]UPDUSR = GUSER : Endif
      Rewrite [ADW]
      If fstat
        Call ERREUR("ADOVAL MAXSPEACV",2) From DOSDIC
      Else
        ISUPDATED=[V]CST_ATRUE
      Endif
    Endif
    If ISUPDATED=[V]CST_ATRUE
      Commit
      Call ECR_TIME("MAXSPEACV :"-mess(167,139,1)-"(300)") From DOSSUB : # Paramètre mis à jour
    Else
      Rollback
    Endif
  Endif

  Close Local File [ADP]
  Close Local File [ADW]
Return

########################################################################
# Automatic executed by patch
########################################################################
Subprog PATCH(DOSSIER)
Value Char    DOSSIER
If [L]DOSSIER<>""
  Gosub MAJ_MAXSPEACV
Endif
End

#######################################################################
# Executed by dosmaj (folder validation)
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char    DOSSIER
If [L]DOSSIER<>""
  Gosub MAJ_MAXSPEACV
Endif
End

