#<AdxTL>@(#)3.0.0.0 $Revision$
#####################################################################################################################
#     ENSEMBLE de sous-programmes utilitaires créés pour le CRM                     Version 140                     #
#                                                                                                                   #
#  ISBANKHOLIDAY : Détermine si un jour férié est présent pendant une durée indiquée.                               #
#                                                                                                                   #
#####################################################################################################################

##############################################################################
# Détermine si un jour férié est présent entre les dates indiquées.          #
##############################################################################
Subprog ISBANKHOLIDAY(DDATSTR, DDATEND, ISHOLIDAY, DALLHOLIDAY)
Value Date DDATSTR
Value Date DDATEND
Variable Integer ISHOLIDAY
Variable Date DALLHOLIDAY()

Local Date DHOLIDAYS(15)

Local Integer IYEARDEB1
Local Integer IYEAREND1
Local Integer IYEAR2
Local Integer ISAMEYEAR
Local Integer INBDAY1
Local Integer INBDAY2
Local Integer ITER
Local Integer ITER2
Local Integer IEXIT
IEXIT = 0

INBDAY1 = nday(DDATEND) - nday(DDATSTR)

IYEARDEB1 = year(DDATSTR)
IYEAREND1 = year(DDATEND)

If IYEARDEB1 = IYEAREND1
    ISAMEYEAR = 1
Else
    ISAMEYEAR = 0
    IYEAREND1 = IYEARDEB1
    IYEAR2 = IYEARDEB1 + 1
Endif

ISHOLIDAY = 0
Raz DALLHOLIDAY

If ISAMEYEAR
    Gosub SAMEYEAR
Else
    Gosub DIFFERENTYEAR
Endif

End

#################
$SAMEYEAR
    #Charge les jours fériés
    Case IYEARDEB1
        When 2003
            Case GPAYS
                When "FR"
                    Gosub SET2003FR
                When "US"
                    Gosub SET2003US
                When "GB"
                    Gosub SET2003UK
                When "IT"
                    Gosub SET2003IT
                When "ES"
                    Gosub SET2003SP
                When "PT"
                    Gosub SET2003PR
                When Default
            Endcase

        When 2004
            Case GPAYS
                When "FR"
                    Gosub SET2004FR
                When "US"
                    Gosub SET2004US
                When "GB"
                    Gosub SET2004UK
                When "IT"
                    Gosub SET2004IT
                When "ES"
                    Gosub SET2004SP
                When "PT"
                    Gosub SET2004PR
                When Default
            Endcase

        When 2005
            Case GPAYS
                When "FR"
                    Gosub SET2005FR
                When "US"
                    Gosub SET2005US
                When "GB"
                    Gosub SET2005UK
                When "IT"
                    Gosub SET2005IT
                When "ES"
                    Gosub SET2005SP
                When "PT"
                    Gosub SET2005PR
                When Default
            Endcase

        When 2006
            Case GPAYS
                When "FR"
                    Gosub SET2006FR
                When "US"
                    Gosub SET2006US
                When "GB"
                    Gosub SET2006UK
                When "IT"
                    Gosub SET2006IT
                When "ES"
                    Gosub SET2006SP
                When "PT"
                    Gosub SET2006PR
                When Default
            Endcase

        When 2007
            Case GPAYS
                When "FR"
                    Gosub SET2007FR
                When "US"
                    Gosub SET2007US
                When "GB"
                    Gosub SET2007UK
                When "IT"
                    Gosub SET2007IT
                When "ES"
                    Gosub SET2007SP
                When "PT"
                    Gosub SET2007PR
                When Default
            Endcase

        When 2008
            Case GPAYS
                When "FR"
                    Gosub SET2008FR
                When "US"
                    Gosub SET2008US
                When "GB"
                    Gosub SET2008UK
                When "IT"
                    Gosub SET2008IT
                When "ES"
                    Gosub SET2008SP
                When "PT"
                    Gosub SET2008PR
                When Default
            Endcase

        When 2009
            Case GPAYS
                When "FR"
                    Gosub SET2009FR
                When "US"
                    Gosub SET2009US
                When "GB"
                    Gosub SET2009UK
                When "IT"
                    Gosub SET2009IT
                When "ES"
                    Gosub SET2009SP
                When "PT"
                    Gosub SET2009PR
                When Default
            Endcase

        When 2010
            Case GPAYS
                When "FR"
                    Gosub SET2010FR
                When "US"
                    Gosub SET2010US
                When "GB"
                    Gosub SET2010UK
                When "IT"
                    Gosub SET2010IT
                When "ES"
                    Gosub SET2010SP
                When "PT"
                    Gosub SET2010PR
                When Default
            Endcase

        When Default
    Endcase

    #On détecte
    ITER = 0
    For ITER = 0 To INBDAY1
        ITER2 = 0
        For ITER2 = 0 To dim(DHOLIDAYS) - 1
            If DHOLIDAYS(ITER2) = [00/00/00] : Break : Endif
            If DDATSTR = DHOLIDAYS(ITER2)
                ISHOLIDAY += 1
                If ISHOLIDAY > dim(DALLHOLIDAY)
                    IEXIT = 1
                    Break
                Else
                    DALLHOLIDAY(ISHOLIDAY - 1) = DHOLIDAYS(ITER2)
                Endif
            Endif
        Next
        DDATSTR = DDATSTR + 1
        If IEXIT : Break : Endif
    Next
Return

##################
$DIFFERENTYEAR
Return


#########################################
# Jours fériés français année 2003
#########################################
$SET2003FR

Raz DHOLIDAYS
DHOLIDAYS(0) = [01/01/2003]
DHOLIDAYS(1) = [21/04/2003]
DHOLIDAYS(2) = [01/05/2003]
DHOLIDAYS(3) = [08/05/2003]
DHOLIDAYS(4) = [29/05/2003]
DHOLIDAYS(5) = [09/06/2003]
DHOLIDAYS(6) = [14/07/2003]
DHOLIDAYS(7) = [15/08/2003]
DHOLIDAYS(8) = [01/11/2003]
DHOLIDAYS(9) = [11/11/2003]
DHOLIDAYS(10) = [25/12/2003]

Return

