#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIGPA08        Initialisation des champs BOMUOM, BOMSTUCOE et BOMQTY  #
#                 dans BOMD                                              #
# ---------------------------------------------------------------------- #
##########################################################################
Call MAJ_UTIGPA08
End


Subprog MAJ_UTIGPA08
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call OUVRE_TRACE("UTIGPA08: BOMD records update") From LECFIC
Call TEMPON("O") From GESECRAN
If DOSSIER<>"" Call EXE_UTIGPA08(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA08(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(200)
Local Integer  CLE2, CLE4, CLE5

Call ECR_TRACE("UTIGPA08: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:BOD])  =0  Local File =DOSSIER+".BOMD"       [BOD] : Endif
If clalev([F:TBO])  =0  Local File =DOSSIER+".TABBOMALT"  [TBO] : Endif
If clalev([F:ITM])  =0  Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif

Local Integer NBBOD : NBBOD = 0

Link [BOD] With [TBO]TBO0=2;[F:BOD]BOMALT, [ITM]ITM0=[F:BOD]CPNITMREF As [NOM] 
&            Order By Key BOD0  


Raz CLE1,CLE2, CLE3,CLE4,STOP
$BOUCLE_BOD
If STOP=1
  STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+' & CPNITMREF>"'+CLE3+'"'
Elsif STOP=2
  STOP=3 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT='+num$(CLE2)+' & BOMSEQ>'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='ITMREF="'+CLE1+'"'+' & BOMALT>'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Call DEBTRANS From GLOCK
Trbegin [BOD]
  For [NOM] Where evalue(CRITERE)
    Readlock [BOD] Curr    
    If fstat
        Call ECR_TRACE("File BOMD, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:BOD]BOMUOM = ""
            [F:BOD]BOMUOM = [F:ITM]STU
            [F:BOD]BOMSTUCOE = 1
            [F:BOD]BOMQTY = [F:BOD]LIKQTY
            NBBOD += 1            
        Endif
        Rewrite [F:BOD]
    Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS 
        CLE1 = [F:BOD]ITMREF 
        CLE2 = [F:BOD]BOMALT
        CLE3 = [F:BOD]CPNITMREF
        CLE4 = [F:BOD]BOMSEQ
        STOP = 1 
        Break 
    Endif
  Next
Commit
If STOP : Goto BOUCLE_BOD : Endif
Filter [BOD]
Close Local File [BOD]

Call ECR_TRACE("UTIGPA08 : "+num$(NBBOD)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTIGPA08(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call EXE_UTIGPA08(APPLI)       
End




