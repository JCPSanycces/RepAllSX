#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("JOU",GBIDC1,GBIDC2) From GOBJET
End

Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"FOPGJOU","SETOPGJOU","XWFOPGJOU") From GSAISIE
End

$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When Default
Endcase
Return

$INIT
If clalev([JST])=0 : Local File GAJOUSTA [JST] : Endif
If clalev([JOU])=0 : Local File GJOURNAL [JOU] : Endif
Return

######################################################################################
## Etiquette du masque JST2 31/10/2005 08:48:40 (JHA)
######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo CPY : Grizo CPY
Else
 Actzo CPY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If ALLCPY = 2
 mkstat = 1 : End
Else
 VALEUR = [M:JOU0]FCY
Endif
End

Subprog C_ALLTYPJOU(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo TYPJOU : Grizo TYPJOU
Else
 Actzo TYPJOU
Endif
End

Subprog AS_TYPJOU(VALEUR)
Variable Integer VALEUR
If ALLTYPJOU = 2
 mkstat = 1 : End
Else
 VALEUR = [M:JOU1]TYP
Endif
End

Subprog C_ALLJOU(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo JOU : Grizo JOU
Else
 Actzo JOU
Endif
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
If ALLJOU = 2
 mkstat = 1 : End
Endif
End

Subprog AS_OPGSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR=date$
 Affzo OPGSTRDAT
Endif
End


