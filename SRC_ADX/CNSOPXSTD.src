[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]STRDATEND = eomonth(VALEUR) : Endif
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M]PJTSTR = ""     : [M]PJTEND = VALEUR : Endif
If [M]PJTEND < VALEUR : [M]PJTEND = VALEUR : Endif
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]MFGNUMSTR = ""     : [M]MFGNUMEND = VALEUR  : Endif
If [M]MFGNUMEND < VALEUR : [M]MFGNUMEND = VALEUR  : Endif
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog C_OWF(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2 &  [M:COPX]OWP <> 2 &  [M:COPX]OWS <> 2
   mkstat = 2 : # une case au moins doit être cochée     (16/02/00    TB)
Endif
[M]WSTA   = 0
If [M]OWS = 2 : [M]WSTA += 1 : Endif
If [M]OWP = 2 : [M]WSTA += 2 : Endif
If VALEUR = 2 : [M]WSTA += 4 : Endif
End

########################################
Subprog C_OPENUMEND(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:COPX]OPENUMSTR : mkstat = 2 : End : Endif
End

########################################

########################################
Subprog C_WSTSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Look [MWS]WST0=VALEUR;[M:OPX1]FCY
If fstat : mkstat = 2 : GMESSAGE = mess(23,100,1) : Endif
End

