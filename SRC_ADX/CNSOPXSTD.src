#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
#                        Consultation                                       #
#                        Encours charge                                     #
#                                                                GPAO 08.99 #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site                                                                 #
# 2  = centre                                                               #
# 3  = poste                                                                #
# 4  = affaire                                                              #
# 5  = OF                                                                   #
# 6  = date début                                                           #
# 7  = date fin                                                             #
# 8  = opération                                                            #
# 9  = filtre        + 1 - charge suggérée                                  #
#                    + 2 - charge planifiée                                 #
#                    + 4 - charge ferme                                     #
# 10 = tri                                                                  #
#                      1 - date début                                       #
#                      2 - centre                                           #
#                      3 - poste                                            #
#                      4 - OF                                               #
#                      5 - type                                             #
#                      6 - statut                                           #
#############################################################################
# 14478  06.02 MM
Local Char PARAM(15)(1..11)
PARAM(1) ="GAL"
PARAM(2) =""
PARAM(3) =""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
PARAM(9) ="15"
PARAM(10) =""
PARAM(11) =""   : # FQ 42839
# 14478  06.02 MM
Call GCONSULT("OPX","",PARAM) From GCONSULT
End


#############################################################################
$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "FERME"      : Gosub FERME
 When "DEB_CRIT"   : [M:COPX] = [M:OPX1]   # Issue 93489 GA 11/2013
 When "FIN_CRIT"   : Gosub FIN_CRIT        # Issue 93489 GA 11/2013
 When "AP_MAGNETO" : Gosub AP_MAGNETO      # Issue 93489 GA 11/2013
 When Default
Endcase
Return

############################################################
$FIN_CRIT                           # Issue 93489 GA 11/2013
[M:OPX1]FLG = 0
[M:OPX1]    = [M:COPX]
Return
############################################################
$AP_MAGNETO                         # Issue 93489 GA 11/2013
[M:OPX1]FLG = 0
Return
#############################################################################
# pour gérer l'accès à la consultation
$AUTORIS
Return

#############################################################################
$FERME
If clalev([F:OPS]) <> 0 : Filter [OPS] : Endif       # Issue 93489 GA 11/2013
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif # Issue 93489 GA 11/2013
Return

#############################################################################
# analyse paramères, initialisations, ouvertures et déclarations
$OUVRE
Local Integer WFLT
Local Integer WSRT
Local Integer I
Local Integer WMAX
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    CRITERE4(200)

Local Char    CUSFLT(255)

If clalev ([F:FCY]) <= 0  : Local File FACILITY [FCY] : Endif  # FQ 64660 GA 07/2010

Local Integer WGCONSULT : WGCONSULT = GCONSULT   # Issue 93489 GA 11/2013

# pb MAE depuis consultation des encours articles (ORD3 index inexistant)
#If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
Local File ORDERS     [ORD]

WMAX = dim([M:OPX2]OPSTYPSTA)     # mémorisation nombre de ligne maxi
Gosub DEFCRIT

[M:OPX1]WSTTYPSTR =1
[M:OPX1]WSTTYPEND =3

# llc 04.02 13344
If [M:COPX]OWS <> 2 &
&  [M:COPX]OWP <> 2 &
&  [M:COPX]OWF <> 2
    [M:COPX]OWS = 2
    [M:COPX]OWP = 2
    [M:COPX]OWF = 2
Endif
If !find([M:COPX]TRI,1,2,3,4,5,6) : [M:COPX]TRI = 1 : Endif
[M:OPX1]WSTA = 7

# Mail TS du 18/03/08
NAVIG="CONSOPX"
SUITE = 1
RETOUR = 1
Return

#############################################################################
# analyse paramètres
$DEFCRIT

[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013

For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:OPX1]FCY = PARAM(I) : Endif
                 Endif
        When 2 : # centre de charge
                 If PARAM(I) <> ""
                     Read [TWC]TWC0 = PARAM(I)
                     If !fstat
                         [M:OPX1]WCRSTR = PARAM(I)
                         [M:OPX1]WCREND = PARAM(I)
                     Endif
                 Endif
        When 3 : # poste de charge
                 If PARAM(I) <> ""
                     Read [MWS]WST0 = PARAM(I);[M:OPX1]FCY
                     If !fstat
                         [M:OPX1]WSTSTR = PARAM(I)
                         [M:OPX1]WSTEND = PARAM(I)
                     Endif
                 Endif
        When 4 : # affaire début
                 If PARAM(I) <> ""
                     [M:COPX]PJTSTR = PARAM(I)
                     [M:COPX]PJTEND = PARAM(I)
                 Endif
        When 5 : # OF début
                 If PARAM(I) <> ""
                     [M:COPX]MFGNUMSTR = PARAM(I)
                     [M:COPX]MFGNUMEND = PARAM(I)
                 Endif
# 14478  06.02 MM
        When 6 : # date début
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:OPX1]STRDATSTR = evalue("["+PARAM(I)+"]") # FQ 64660 GA 07/2010 ajout evalue
                     Else
                         [M:OPX1]STRDATSTR = PARAM(I)
                     Endif
                 Endif
        When 7 : # date fin
                If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:OPX1]STRDATEND = evalue("["+PARAM(I)+"]") # FQ 64660 GA 07/2010 ajout evalue
                     Else
                         [M:OPX1]STRDATEND = PARAM(I)
                     Endif
                 Endif
        When 8 : # opération
                 If PARAM(I) <> ""
                     [M:COPX]OPENUMSTR = val(PARAM(I))
                     [M:COPX]OPENUMEND = val(PARAM(I))
                 Endif

        When 9 : # filtre
                 If PARAM(I) <> ""
                     WFLT = val(PARAM(I))
                     If WFLT < 0 | WFLT > 15 : WFLT = 15 : Endif
# llc 04.02 13344
#                    If WFLT > 7 : [M:COPX]ORS = 2 : WFLT -= 8 : Endif
                     If WFLT > 3 : [M:COPX]OWF = 2 : WFLT -= 4 : Endif
                     If WFLT > 1 : [M:COPX]OWP = 2 : WFLT -= 2 : Endif
                     If WFLT > 0 : [M:COPX]OWS = 2 : WFLT -= 1 : Endif
                 Endif
        When 10 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 6 : WSRT = 1 : Endif
                     [M:COPX]TRI = WSRT
                 Endif
        When 11 : # poste M/O secondaire FQ 42839
                 If PARAM(I) <> ""
                     Read [MWS]WST0 = PARAM(I);[M:OPX1]FCY
                     If !fstat
                         [M:OPX1]WSTLABSTR = PARAM(I)
                         [M:OPX1]WSTLABEND = PARAM(I)
                     Endif
                 Endif
# 14478  06.02 MM
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (COPX) vers le masque 0 (OPX1)
Gosub CRITENT From =PROGCNS

# FQ 62353 Critère par défaut: Opérations antérieures/en-cours si on arrive en tunnel
#If clalev([M:MWK1]) <= 0 : [M:COPX]PAST = 1 : Else : [M:COPX]PAST = 2 : Endif            # 09.01 10476 + 05.05 30047
[M:COPX]PAST = 2
Return

#############################################################################
# chargement tableau
$LECTURE
# Issue 93489 GA 11/2013
SUITE  = 0
RETOUR = 0
NBLU   = 1  # Issue 93489 GA 11/2013 cf GCONSULT

# si le tri n'est pas passé en paramètre, pas de chargement automatique
If PARAM(10) = "" : NBLU=0 : PARAM(10) = "1" : Return : Endif    # 14478  06.02  MM

# Changement d'écran ?
Gosub CHANGE_MSK From GCONSULT

# Issue 93489 GA 11/2013 algo remis à niveau pour gestion <page suiv>/<page prec>
Gosub TRT_FILTER

# Issue 101111 & 102628 GA 10/2014
Raz [M:OPX2]

# Issue 93489 GA 11/2013 algo remis à niveau pour gestion <page suiv>/<page prec>
#Case CHGPAG
#    When 1,3:       Gosub CHARGE_PAGE
#    When Default:   # rien
#Endcase
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [OPE]
      If nolign <= MAXLIG
         Gosub CHARGE_LIGNE
         nolign+=1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [OPE]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub CHARGE_LIGNE
          nolign+=1
        Else
          NBLU=0
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:OPX2]
    WLIG = 0
    For [OPE]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [OPE]
      If WLIG >= WSKIP
        If nolign <= MAXLIG & nolign>0
          Gosub CHARGE_LIGNE
          nolign-=1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [OPE]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub CHARGE_LIGNE
          nolign+=1
        Else
          NBLU=0
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
Gosub TRI_TAB

# FQ 64660 GA 07/2010 ergonomie
Gosub HIGHLIGHT
Return

#############################################################################
# Traitement du bouton recherche
$CHARGE_PAGE_OLD                 # Issue 93489 GA 11/2013 algo remis à niveau
# initialisation variables
nolign = 1

# boucle de lecture
For [OPE]
    If [M:COPX]JAL = 2 & [F:SCH]OPESTRDAT = [0/0/0] : Goto SUIV : Endif

    If nolign > MAXLIG  : NBLU = 2  : Break : Endif           # llc 05.02  14312

    # Flag suspension 11.04 26247
    Read [MFG]MFG0=[F:OPS]MFGNUM
    If fstat : Raz [MFG] : Endif
    If [M:COPX]SUS = 2 & [F:MFG]SUSFLG = 2 : Goto SUIV : Endif

    Gosub CHARGE_LIGNE
    nolign += 1
$SUIV
Next

If nolign > 1
    If nolign > MAXLIG                                        # llc 05.02  14312
        NOL = nolign - 2
    Else
        NOL = nolign - 1
    Endif
    [M:OPX2]NBLIG = NOL
Else
    NOL = 0
    NBLU = 0
    [M:OPX2]NBLIG = 0
Endif
[M:OPX1]FLG = 0
Return

#############################################################################
$CHARGE_LIGNE
Local Integer I , WMFGLIN

# Issue 93489 GA 11/2013
If nolign>MAXLIG : Return Endif
If nolign>[M:OPX2]NBLIG : [M:OPX2]NBLIG=nolign : Endif

[M:OPX2] = [F:OPS]
[M:OPX2]OPSTYPSTA(nolign-1)  = mess([F:OPE]OPSTYP,351,1)+mess([F:OPE]OPSSTA,342,1)
[M:OPX2]RMNEXTQTY(nolign-1)  = [F:OPE]EXTQTY - [F:OPE]CPLQTY
[M:OPX2]WCR(nolign-1)        = [F:MWS]WCR
[M:OPX2]OPESTRFRD(nolign-1)  = [F:SCH]OPESTRFRD                       # llc 06.02 14560
[M:OPX2]LABSETTIM(nolign-1)  = [F:OPE]EXTSETTIM * [F:OPE]SETLABCOE    # llc 09.02 15881
[M:OPX2]LABOPETIM(nolign-1)  = [F:OPE]EXTOPETIM * [F:OPE]OPELABCOE    # llc 09.02 15881
[M:OPX2]SUSFLG(nolign-1)     = [F:MFG]SUSFLG                          # 11.04 26247
[M:OPX2]ROUNUM(nolign-1)     = [F:MFG]ROUNUM                          # 12.06 mm 38621

If [F:OPE]OPSSTA <> 3
    I= 0
    For [F:MFI]MFI0 Where MFGNUM = [M:OPX2]MFGNUM(nolign-1)
        If [F:MFI]ITMTYP<>2 : I+= 1  : WMFGLIN = [F:MFI]MFGLIN : Endif
    Next
# retrouver l'article lancé n'a de sens que dans le cas d'OF mono-article
    If I=1
        Read [MFI]MFI0 = [M:OPX2]MFGNUM(nolign-1); WMFGLIN
        If !fstat
            [M:OPX2]ITMREF(nolign-1) = [F:MFI]ITMREF
        Endif
    Else
         [M:OPX2]ITMREF(nolign-1) = "*"
    Endif
Else
    I = 0
    For [F:ORD]ORD3 Where STOFCY=[F:OPS]MFGFCY & WIPTYP = 5 & VCRTYP = 11 & VCRNUM=[F:OPS]MFGNUM
        I += 1
    Next
    If I = 1
        [M:OPX2]ITMREF(nolign-1) = [F:ORD]ITMREF
    Else
        [M:OPX2]ITMREF(nolign-1) = "*"
    Endif
Endif

Return

####################################################################
$HIGHLIGHT
Local Char WSTYLE(GLONASY)
Affzo [M:OPX2]
# application style
For I=1 To [M:OPX2]NBLIG
    nolign=I
    Case [M:OPX2]OPSSTA(nolign-1)
      When 1 :
        WSTYLE = "BACKGREEN"
      When 2 :
        WSTYLE = "BACKGREY"
      When 3 :
        WSTYLE = "BACKYELLOW"
      When 4 :
        WSTYLE = "BACKRED"
    Endcase
    Chgstl [M:OPX2]NBLIG(nolign-1) With WSTYLE
Next I
Return

#############################################################################
# Tri du tableau
$TRI_TAB
Case [M:COPX]TRI
    When 1: # par date début
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]OPESTR(indice), [M:OPX2]OPESTRFRD(indice)
    When 2: # par centre
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]WCR(indice), [M:OPX2]OPESTR(indice),
&                                                      [M:OPX2]OPESTRFRD(indice)
    When 3: # par poste
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]EXTWST(indice), [M:OPX2]OPESTR(indice),
&                                                      [M:OPX2]OPESTRFRD(indice)
    When 4: # par OF
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]MFGNUM(indice), [M:OPX2]OPESTR(indice),
&                                                      [M:OPX2]OPESTRFRD(indice)
    When 5: # par type charge
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]OPSTYP(indice), [M:OPX2]OPESTR(indice),
&                                                      [M:OPX2]OPESTRFRD(indice)
    When 6: # par statut
            Sorta [M:OPX2]NBLIG [M:OPX2]NBLIG Order By [M:OPX2]OPSSTA(indice), [M:OPX2]OPESTR(indice),
&                                                      [M:OPX2]OPESTRFRD(indice)
Endcase

Return

############################################################
$TRT_FILTER
If [M:OPX1]FLG = 0 # Issue 101111 GA 10/2014
  [M:OPX1]FLG = 1
  Raz [M:OPX2]
  # chargement des filtres
  Gosub LOAD_FILTER
  # sr 10.04 demande 26046
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
  Gosub FILTRE

Endif
Return

#############################################################################
# Préparation du filtre sur la table operations                             #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3
Raz CRITERE4             # 15302 09.02 MM

# llc 04.02 13344
#If [M:COPX]ORS = 2
#    CRITERE  = "([F:OPS]OPSTYP=2&[F:OPS]OPSSTA=3)"
#    Gosub LOAD_CRITERE
#Endif

If [M:COPX]OWF = 2
    CRITERE  = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA=1)"
    Gosub LOAD_CRITERE
Endif

If [M:COPX]OWP = 2
    CRITERE  = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA=2)"
    Gosub LOAD_CRITERE
Endif

If [M:COPX]OWS = 2
# llc 04.02 13344
    Case [M:COPX]MRPFLG
        When 1:    CRITERE  = "([F:OPS]OPSTYP=2&[F:OPS]OPSSTA=3)"
        When 2:    CRITERE  = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA=3)"
        When Default:      CRITERE  = "[F:OPS]OPSSTA=3"
    Endcase
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

# site
If [M:OPX1]FCY <> ""
   CRITERE = "[F:OPS]MFGFCY=[M:OPX1]FCY"                # filtre site
   Gosub LOAD_CRITERE2
Endif

# centre
If [M:COPX]WCRSTR <> ""
    CRITERE = "[F:MWS]WCR>=[M:COPX]WCRSTR"              # borne début centre
    Gosub LOAD_CRITERE2
Endif
If [M:COPX]WCREND <> ""
    CRITERE = "[F:MWS]WCR<=[M:COPX]WCREND"              # borne fin   centre
    Gosub LOAD_CRITERE2
Endif

# poste de charge
If [M:COPX]WSTSTR <> ""
    CRITERE = "[F:OPS]EXTWST>=[M:COPX]WSTSTR"  # borne début poste
    Gosub LOAD_CRITERE2
Endif
If [M:COPX]WSTEND <> ""
    CRITERE = "[F:OPS]EXTWST<=[M:COPX]WSTEND"  # borne fin   poste secondaire
    Gosub LOAD_CRITERE2
Endif

# FQ 42839 poste de main d'oeuvre
If [M:COPX]WSTLABSTR <> ""
    CRITERE = "[F:OPS]EXTLAB>=[M:COPX]WSTLABSTR"  # borne début poste
    Gosub LOAD_CRITERE2
Endif
If [M:COPX]WSTLABEND <> ""
    CRITERE = "[F:OPS]EXTLAB<=[M:COPX]WSTLABEND"  # borne fin   poste secondaire
    Gosub LOAD_CRITERE2
Endif

# affaire
If [M:COPX]PJTSTR <> ""
   CRITERE = "[F:OPS]PJT>=[M:COPX]PJTSTR"               # borne début affaire
   Gosub LOAD_CRITERE2
Endif
If [M:COPX]PJTEND <> ""
   CRITERE = "[F:OPS]PJT<=[M:COPX]PJTEND"               # borne fin   affaire
   Gosub LOAD_CRITERE2
Endif

# tiers
If [M:COPX]MFGNUMSTR <> ""
   CRITERE = "[F:OPS]MFGNUM>=[M:COPX]MFGNUMSTR"         # borne début OF
   Gosub LOAD_CRITERE3
Endif
If [M:COPX]MFGNUMEND <> ""
   CRITERE = "[F:OPS]MFGNUM<=[M:COPX]MFGNUMEND"         # borne fin   OF
   Gosub LOAD_CRITERE3
Endif

# opération début
If [M:COPX]OPENUMSTR <> 0
   CRITERE = "[F:OPS]OPENUM>=[M:COPX]OPENUMSTR"         # borne opé début
   Gosub LOAD_CRITERE3
Endif

# opération fin
If [M:COPX]OPENUMEND <> 0
   CRITERE = "[F:OPS]OPENUM<=[M:COPX]OPENUMEND"         # borne opé fin
   Gosub LOAD_CRITERE3
Endif

# date
If [M:COPX]STRDATSTR <> [0/0/0]
   # llc 08.01 9759 + 13450
   Case [M:COPX]PAST
       When 1: CRITERE = "[F:OPS]OPESTR>=[M:COPX]STRDATSTR"         # borne date début
       When 2: CRITERE = "[F:OPS]OPEEND>=[M:COPX]STRDATSTR"
   Endcase
   Gosub LOAD_CRITERE3
Endif
If [M:COPX]STRDATEND <> [0/0/0]
#  CRITERE = "[F:OPS]OPEEND<=[M:COPX]STRDATEND"         # borne date fin
   CRITERE = "[F:OPS]OPESTR<=[M:COPX]STRDATEND"         # borne date fin    # (llc 07.00)
   Gosub LOAD_CRITERE3
Endif

#15302 09.02 MM : filtre sur type de poste
# type de poste
If [M:COPX]WSTTYPSTR <> 0
    CRITERE = "[F:OPS]EXTWSTTYP>= [M:COPX]WSTTYPSTR"    # borne début type poste
    Gosub LOAD_CRITERE4
Endif
If [M:COPX]WSTTYPEND <> 0
    CRITERE = "[F:OPS]EXTWSTTYP <= [M:COPX]WSTTYPEND"    # borne fin type poste
    Gosub LOAD_CRITERE4
Endif

# Issue 93489 GA 11/2013 critère précédemment traité par CHARGE_PAGE
If [M:COPX]JAL = 2
    CRITERE = "[F:SCH]OPESTRDAT <> [0/0/0]"              # charge jalonnée
    Gosub LOAD_CRITERE4
Endif
# Issue 93489 GA 11/2013 critère précédemment traité par CHARGE_PAGE
If [M:COPX]SUS = 2
    CRITERE = "[F:MFG]SUSFLG <> 2"                       # OF non suspendu
    Gosub LOAD_CRITERE4
Endif
#
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif
If CRITERE4 = "" : CRITERE4 = "1=1" : Endif    # 15302 09.02 MM
#
Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
# 15302 09.02 MM
$LOAD_CRITERE4
If len(CRITERE4)<>0 : CRITERE4 += "&" : Endif
CRITERE4 += CRITERE
Return

#############################################################################
# link + filtre + tri
$FILTRE

# 15302 0902 MM : ajout de CRITERE4
# application des filtres
If [M:COPX]SUS<>2 & CUSFLT="1=1"
# Issue 93489 GA 11/2013 sans [F:MFG] et sans CUSFLT
# Issue 106577 - 2015-11-30 by BEEBE : MFG fields will be read and used, so MFG has to be joined, too
Case [M:COPX]TRI
    When 1: # par date début
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY ,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)&
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:OPS]OPESTR;[F:SCH]OPESTRFRD                   # llc 10.00 6594 + 10476
    When 2: # par centre
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)&
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:MWS]WCR;[F:OPS]OPESTR;[F:SCH]OPESTRFRD        # llc 10.00 6594 + 10476
    When 3: # par poste
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:OPS]EXTWST;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 4: # par OF
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:OPS]MFGNUM;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 5: # par type charge
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:OPS]OPSTYP;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 6: # par statut
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4)
&                      Order By Key CLE = [F:OPS]OPSSTA;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476

  Endcase
Else
# Issue 93489 GA 11/2013 + lien avec [F:MFG] et/ou critères complémentaires
  Case [M:COPX]TRI
    When 1: # par date début
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY ,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)&
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:OPS]OPESTR;[F:SCH]OPESTRFRD                   # llc 10.00 6594 + 10476
    When 2: # par centre
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)&
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:MWS]WCR;[F:OPS]OPESTR;[F:SCH]OPESTRFRD        # llc 10.00 6594 + 10476
    When 3: # par poste
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:OPS]EXTWST;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 4: # par OF
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:OPS]MFGNUM;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 5: # par type charge
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:OPS]OPSTYP;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
    When 6: # par statut
            Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY,
&                           [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                           [MFG]MFG0=[F:OPS]MFGNUM
&                      As [OPE]
&                      Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                            evalue(CRITERE4) & evalue(CUSFLT)
&                      Order By Key CLE = [F:OPS]OPSSTA;[F:OPS]OPESTR;[F:SCH]OPESTRFRD     # llc 10.00 6594 + 10476
Endcase
Endif

Return

#############################################################################
$SETBOUT
#If GBROWS :     Call VIREBOUT(CHAINE,"a") From GOBJET : Endif
Return

#############################################################################
$EXEBOUT
Return

#############################################################################
#    ETIQUETTES ECRAN
#############################################################################

########################################
Subprog IB_NBLIG
Local Integer L : L = nolign-1
#
GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT8 = ""    # 15158 08.02 MM
GBOUT9 = ""    # 15158 08.02 MM

If [M:OPX2]OPSTYPSTA(L) <> ""
    GBOUT1 = mess(96,123,1)                                             # signification
    If clalev ([M:ORD1]) <= 0      : GBOUT2 = mess(272,198,1) : Endif   # Encours article
    If find([M:OPX2]OPSSTA(L),1,2) : GBOUT3 = mess(166,198,1) : Endif   # OF
#    If !GBROWS : GBOUT6 = mess(224,198,1) : Endif
    GBOUT6 = mess(224,198,1)
    If clalev ([M:MWK1])<=0 : GBOUT8 = mess(407,198,1) : Endif          # Charge    # 15158 08.02 MM
    GBOUT9 = mess(29,198,1)                                             # Postes de charge  # 15158 08.02 MM
    If [M:OPX2]OPESTA(L) > 3 : End : Endif
    If [M:OPX2]OPSSTA(L) > 2 : End : Endif
    Read [MFG]MFG0=[M:OPX2]MFGNUM(L)
    If fstat : End : Endif
    Read [SCH]SCH0=[M:OPX2]MFGNUM(L);[M:OPX2]OPENUM(L);[M:OPX2]OPESPLNUM(L)
    If !fstat
       GBOUT4 = mess(171,195,1)
       If [F:SCH]OPESTRDAT <> [0/0/0]
          GBOUT5 = mess(172,195,1)
       Endif
    Endif
Endif

End
########################################
Subprog B1_NBLIG
Local Integer L : L = nolign - 1

Infbox [M:OPX2]OPSTYPSTA(L)+" = " + mess([M:OPX2]OPSTYP(L),350,1) -
&                                   mess([M:OPX2]OPSSTA(L),317,1)
&                                  Titled mess(96,123,1)

End

########################################
Subprog C_NBLIG
End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog AM_WCRSTR(VALEUR)
Variable Char    VALEUR()
If [M]WCRSTR = ""     : [M]WCREND = VALEUR : Endif
If [M]WCREND < VALEUR : [M]WCREND = VALEUR : Endif
[M:OPX1]FLG = 0 # Issue 93489 GA 11/2013
End

########################################
Subprog AM_WSTSTR(VALEUR)
Variable Char    VALEUR()
If [M]WSTSTR = ""     : [M]WSTEND = VALEUR : Endif
