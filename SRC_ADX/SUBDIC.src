#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management DIC
#ADNGO - 2017-05-02 - X3-33738 - START
# JML 19/07/10 New zone POTFLG
Call OBJET("DIC",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "FILTRE"      : Gosub FILTRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
Return

$LIENS
Call TEXTE([F:DIC]DES,[M]WDES) From OBJDIV
Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
[M]TYP = [F:ATZ]CODTYP
Read [ATY]CODTYP = [F:ATZ]CODTYP
Call TEXTE([F:ATY]INTITTYP,[M]DESTYP) From OBJDIV
Return

$FILTRE
If GACTION="SELOBJW" | GACTION="EXPSAL"
 If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
 CRITERE = '1=1'
 For [DIC]DIC2(1) Where CODACT<>""
  Read [ACV]CODACT=[F:DIC]CODACT
  If fstat| [F:ACV]FLACT<>2
   CRITERE -= ' & CODACT<>"'+[F:DIC]CODACT+'"'
  Endif
 Next
Endif
Return

$FIN_SEL
If GACTION="SELOBJW" | GACTION="EXPSAL"
 Filter [DIC]
Endif
Return

$APRES_MODIF
If func AFNC.ACTIV("MAS") > 0
 Case zoncou
  When "MSFLG"
   If zc =2 & [M:DIC1]ENAFLG = 2 & [M:DIC1]CODACT <> "" & func AFNC.ACTIV([M:DIC1]CODACT) < 1
    GMESSAGE = mess(7,14,1)-":"-mess(22,176,1)
   Endif
  When "ENAFLG"
   If [M:DIC1]MSFLG = 2 & zc =2 & [M:DIC1]CODACT <> "" & func AFNC.ACTIV([M:DIC1]CODACT) < 1
    GMESSAGE = mess(7,14,1)-":"-mess(22,176,1)
   Endif
  When "CODACT"
   If [M:DIC1]MSFLG = 2 & [M:DIC1]ENAFLG = 2 & zc <> "" & func AFNC.ACTIV(zc) < 1
    GMESSAGE = mess(7,14,1)-":"-mess(22,176,1)
   Endif
  When Default
 Endcase
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran DIC1) 06/03/2009 10:40:56 (WGA)
######################################################################################
Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("MAS") > 0
 If VALEUR=1
  Effzo [M:DIC1]MSFLG
  Grizo [M:DIC1]MSFLG
 Else
  Actzo [M:DIC1]MSFLG
 Endif
Endif
End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran DIC1) 19/07/2010 13:56:03 (JML)
######################################################################################
Subprog AS_POTFLG(VALEUR)
Variable Integer VALEUR

If [M]TBL<>"EMPLOCTR"
 mkstat = 1 : End
Endif
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran DIC1) 30/05/2011 16:41:10 (DBA)
######################################################################################
#72211
Subprog AS_FLGRET(VALEUR)
Variable Integer VALEUR
If [M]TBL<>"EMPLOCTR"
 mkstat = 1 : End
Endif
End
######################################################################################
#ADNGO - 2017-05-02 - X3-33738 - END

