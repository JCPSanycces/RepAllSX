######################################################################################
## Etiquette ajoutée par le superviseur (écran BRD0) 04/03/2009 11:59:10 (MDJ)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
   #Récupération du code plan associé au référentiel principal de la société
   Call LECPLAN(VALEUR, 1, RCOA1) From CPTDIV
   #Récupération du code plan associé au référentiel IAS/IFRS de la société
   Call LECPLAN(VALEUR, 3, RCOA3) From CPTDIV
   #> Recherche législation de la société
   Read[CPY]CPY0= VALEUR
   If fstat = 0
      [M:BRD0]LEG = [F:CPY]LEG : Affzo [M:BRD0]LEG
      GWLEG       = [F:CPY]LEG
   Endif
   [M:BRD0]CPY = VALEUR  :    Affzo  [M:BRD0]CPY
Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BRD0) 17/03/2009 14:24:29 (MDJ)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
    GMESSAGE = mess(44,7770,1) : # "Code inconnu dans la table"
    mkstat=2 : End
Else
   [M:BRD0]CPY = VALEUR :    Affzo  [M:BRD0]CPY
Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BRD0) 17/03/2009 15:06:23 (MDJ)
######################################################################################
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
   #Récupération du code plan associé au référentiel principal de la société
   Call LECPLAN(VALEUR, 1, RCOA1) From CPTDIV
   #Récupération du code plan associé au référentiel IAS/IFRS de la société
   Call LECPLAN(VALEUR, 3, RCOA3) From CPTDIV
   #> Recherche législation de la société
   Read[CPY]CPY0= VALEUR
   If fstat = 0
      [M:BRD0]LEG = [F:CPY]LEG  :  Affzo  [M:BRD0]LEG
      GWLEG       = [F:CPY]LEG
   Endif
   [M:BRD0]CPY = VALEUR  :    Affzo  [M:BRD0]CPY
Endif


End
