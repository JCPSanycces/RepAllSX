If VALEUR <> [M:BRD0]CHAMP1 and VALEUR <> 0
  [M:BRD0]CHAMP1 = VALEUR  : Affzo [M:BRD0]CHAMP1
  Raz[M:BRD1]VAL1
  Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1), mess(82,123,1), mess(543,7773,1), mess([M:BRD0]CHAMP1,3129,1)
  Affzo [M:BRD1]
