#<AdxTL>@(#)9.0.0.0 $Revision$
# Gestion du masque BRD1
#********************************************************************************
#
#                    GESTION DES CLES DE VENTILATION POUR ECLATEMENT
#
#********************************************************************************
#    Création
#   V6-
#
#********************************************************************************
#   Modification      :  MDJ  - 18.11.2008
#    MWA - 17.06.2015  FQ107224 Code comptable et description quand ils sont utilisés doivent être obligatoirement renseignés
#    CBO - 29.04.2014  FQ69690  Objet FAM
#*********************************************************************************
#
Call OBJET("BRD",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When  "OUVRE"            : Gosub OUVRE        : # Avant toute chose
 When  "RAZCRE"           : Gosub RAZCRE
 When  "RAZDUP"           : Gosub RAZDUP
 When  "SETBOUT"          : Gosub SETBOUT
 When  "CREATION"         : Gosub CREATION     : # Création  - Insertion dans autres tables
 When  "LIENS"            : Gosub LIENS        : # Lecture informations tables liées
 When  "AVANT_MOD"        : Gosub AVANT_MOD
 When  "APRES_MODIF"      : Gosub APRES_MODIF
 When  "ANNULE"           : Gosub ANNULE       : # FQ 31218
 When  "VERIF_CRE"        : Gosub VERIF_CRE
 When  "VERIF_MOD"        : Gosub VERIF_CRE
 When  "MODIF"            : Gosub MODIF        : # Modification     - Mise à jour autres tables
 When  "SEL_TABLE"        : Gosub SEL_TABLE
 When Default
Endcase

Return
#
$SEL_TABLE
Case TABLE
  When "SELVALKEY"     :   Gosub SELVALKEY
  When "SELVALCHP"     :   Gosub SELVALCHP
Endcase
Return
#*********************************************************************
#
$OUVRE

Local Integer OUINON                 : # réponse call OUINON

If clalev([F:BRD])=0 : Local File BRDKEY    [BRD]  : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY]  : Endif      # table des sociétés
If clalev([F:AST])=0 : Local File APLSTD    [AST]  : Endif      # table des menus locaux
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI]  : Endif      # table des tables diverses
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX]  : Endif      # table des textes
If clalev([F:ADV])=0 : Local File ATABTAB   [ADV]  : Endif
If clalev([F:CAC])=0 : Local File GACCCODE  [CAC]  : Endif      # table des codes comptables
If clalev([F:GAC])=0 : Local File GACCOUNT  [GAC]  : Endif      # table des comptes comptables
If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

Global Char      RCOA1 : RCOA1 = ""
Global Char      RCOA3 : RCOA3 = ""
Global Char      GWLEG   # Législation de la société

Return
#=====================================================================
#
$RAZCRE

[M:BRD0]CHAMP1 = 0
[M:BRD0]CHAMP2 = 0
[M:BRD0]CHAMP3 = 0
Affzo [M:BRD0]

Raz[M:BRD1]
Affzo [M:BRD1]

Return
#=====================================================================
#
$RAZDUP

Return
#=====================================================================
#
$SETBOUT

# Désactivation de l'action  Changer de clé
Call VIREBOUT(CHAINE,"H") From GOBJET

If CLECUR CHAINE+="A"
Endif

Return
#=====================================================================
#
$LIENS

Local Integer   I
Local Char      LTEXTE

#Récupération du code plan associé au référentiel principal de la société
Call LECPLAN([F:BRD]CPY, 1, RCOA1) From CPTDIV
#Récupération du code plan associé au référentiel IAS/IFRS de la société
Call LECPLAN([F:BRD]CPY, 3, RCOA3) From CPTDIV

#> Recherche législation de la société
Read[CPY]CPY0= [F:BRD]CPY
If fstat=0
 [M:BRD0]LEG = [F:CPY]LEG
 GWLEG       = [F:CPY]LEG
Endif
# Lecture des valeurs de la clé de répartition
#*
For nolign= 1 To [F:BRD]NBVAL
  If [F:BRD]VALKEY(nolign-1) <> ""
     [M:BRD1]VALKEY(nolign-1) = [F:BRD]VALKEY(nolign-1)
    If [F:BRD]DSPKEY =GVML_CLEFAM
#      Read [ADI]CODE=GTD_FAMCPT;[F:BRD]VALKEY(nolign-1)
#      Call LECTEXTRA (LTEXTE, "ATABDIV", "LNGDES", num$(GTD_FAMCPT), [F:BRD]VALKEY(nolign-1)) From ATEXTRA
      Read [F:FAM]FAM0 = [F:BRD]VALKEY(nolign-1)
      Call LECTEXTRA (LTEXTE, "FASFAM", "FAMDES", [F:BRD]VALKEY(nolign-1), "") From ATEXTRA
      [M:BRD1]INTKEY(nolign-1)  = LTEXTE
      Affzo [M:BRD1]INTKEY(nolign-1)
    Else
      If  [F:BRD]DSPKEY = GVML_CLECCO
        Read [CAC]CAC0 = GVML_COGIMMO;[M:BRD1]VALKEY(nolign-1);RCOA1
        [M:BRD1]INTKEY(nolign-1)  = [F:CAC]DES
        Affzo [M:BRD1]INTKEY(nolign-1)
      Else
          If  ([F:BRD]DSPKEY = GVML_CLEGAC) or ([F:BRD]DSPKEY = GVML_CLEIASC)
            If  ([F:BRD]DSPKEY = GVML_CLEGAC)
               Read [GAC]GAC0 = RCOA1;[M:BRD1]VALKEY(nolign-1)
            Else
               Read [GAC]GAC0 = RCOA3;[M:BRD1]VALKEY(nolign-1)
            Endif
            [M:BRD1]INTKEY(nolign-1)  = [F:GAC]DES
            Affzo [M:BRD1]INTKEY(nolign-1)
          Endif
      Endif

    Endif
    [M:BRD1]BRDPRC(nolign-1) = [F:BRD]BRDPRC(nolign-1)
    [M:BRD1]VAL1(nolign-1)   = [F:BRD]VAL1(nolign-1)
    [M:BRD1]VAL2(nolign-1)   = [F:BRD]VAL2(nolign-1)
    [M:BRD1]VAL3(nolign-1)   = [F:BRD]VAL3(nolign-1)
  Endif
Next

[M:BRD1]NBVAL = nolign-1
Affzo [M:BRD0]


If  [M:BRD0]CHAMP1 > 1
   If  [M:BRD0]CHAMP2 > 1 and [M:BRD0]CHAMP3 > 1
        Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1)     ,
&                            mess(82,123,1), mess(543,7773,1),
&                            mess([M:BRD0]CHAMP1,3129,1), mess([M:BRD0]CHAMP2,3129,1), mess([M:BRD0]CHAMP3,3129,1)
   Else
      If  [M:BRD0]CHAMP2 > 1 and [M:BRD0]CHAMP3 = 1
         Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1) ,
&                             mess(82,123,1), mess(543,7773,1),
&                             mess([M:BRD0]CHAMP1,3129,1), mess([M:BRD0]CHAMP2,3129,1), ""
      Else
        If  [M:BRD0]CHAMP2 = 1
            Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1) ,
&                                mess(82,123,1), mess(543,7773,1),
&                                mess([M:BRD0]CHAMP1,3129,1), "", ""

        Endif
      Endif
   Endif
Else
   Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1)     ,
&                       mess(82,123,1), mess(543,7773,1),
&                       "", "", ""
Endif


Affzo [M:BRD1]
Sorta [M]NBVAL [M]NBVAL Order By VALKEY([S]indice), BRDPRC([S]indice)


Return
#====================================================================*
$AVANT_MOD


Return
#====================================================================
$APRES_MODIF

Return
#********************************************************************
$ANNULE

Delete [BRD] Where CPY = [M:BRD0]CPY and   BRDREF=[M:BRD0]BRDREF
If fstat=1
  GOK=0
  Call RSTA("BRD",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
  Return
Endif

Return

#====================================================================*
$MODIF

Delete [BRD] Where (CPY = [M:BRD0]CPY ) and  ( BRDREF=[M:BRD0]BRDREF )
 If fstat <> 0
  GOK=-1 : Call RSTA("BRD",CLECUR1) From GLOCK : Return
 Endif

Gosub CREATION

Return
#====================================================================*
$VERIF_CRE
Local Char     WCVALKEY
Local Decimal  WMPRCT

If [M:BRD0]CPY= ""
  GMESSAGE = mess(152,7770,1)  # "Société obligatoire"
  GERR     = 1 :   mkstat   = 2
  zonsui = "[M:BRD0]CPY"
Endif

If [M:BRD0]BRDREF= ""
  GMESSAGE = mess(152,7770,1)  # "Référence table obligatoire"
  GERR     = 1 :   mkstat   = 2
  zonsui = "[M:BRD0]BRDREF"
Endif

# FQ107224
For nolign=1 To [M:BRD1]NBVAL
  If func SUBBRD.ERROR_FOUND([M:BRD0]CHAMP1, [M:BRD1]VAL1(nolign-1))
    GMESSAGE = func GLOFUNC.SUBSTIT1(mess(936,GML_MSGFAS,1), mess([M:BRD0]CHAMP1,GML_ZMAJECL,1))
    mkstat=2 : Return
  Endif
  If func SUBBRD.ERROR_FOUND([M:BRD0]CHAMP2, [M:BRD1]VAL2(nolign-1))
    GMESSAGE = func GLOFUNC.SUBSTIT1(mess(936,GML_MSGFAS,1), mess([M:BRD0]CHAMP2,GML_ZMAJECL,1))
    mkstat=2 : Return
  Endif
  If func SUBBRD.ERROR_FOUND([M:BRD0]CHAMP3, [M:BRD1]VAL3(nolign-1))
    GMESSAGE = func GLOFUNC.SUBSTIT1(mess(936,GML_MSGFAS,1), mess([M:BRD0]CHAMP3,GML_ZMAJECL,1))
    mkstat=2 : Return
  Endif
Next nolign


  WVALKEY    =    ""
  WMPRCT     =     0
  Sorta [M]NBVAL [M]NBVAL Order By VALKEY([S]indice), BRDPRC([S]indice)
  Affzo   [M:BRD1]


  For nolign=1 To [M:BRD1]NBVAL
      If VALKEY(nolign-1) <> WVALKEY
           WVALKEY    =     VALKEY(nolign-1)
           WMPRCT     =     0
           WMPRCT     +=    BRDPRC(nolign-1)
      Else
           WMPRCT     +=    BRDPRC(nolign-1)
           If (WMPRCT > 100)
               GERR=1
               #  Pour la valeur WVALKEY la somme des ventilations dépasse 100%
               GMESSAGE = mess(541,7773,1)-" "-num$(WVALKEY)- " "- mess(542,7773,1)
               mkstat=2 : Return
           Endif
      Endif
  Next nolign

Return

Funprog ERROR_FOUND(CHAMP, VALEUR)
Value Integer CHAMP
Value Char    VALEUR
Local Integer B_RET
  B_RET = 0
  If find(CHAMP, GVML_ZMAJCCO, GVML_ZMAJDE1)
    If (VALEUR = "") Then
      B_RET = 1
    Endif
  Endif
End B_RET

#====================================================================*
$CREATION
Local Integer I : I=0

 Delete [BRD] Where (CPY = [M:BRD0]CPY ) and  ( BRDREF=[M:BRD0]BRDREF )
 If fstat <> 0
  GOK=-1 : Call RSTA("BRD",CLECUR1) From GLOCK : Return
 Endif

  Raz [F:BRD]
  [F:BRD] = [M:BRD0]
  For nolign=1 To [M:BRD1]NBVAL
    If [M:BRD1]VALKEY(nolign-1) <> ""
      [F:BRD]VALKEY(I) = [M:BRD1]VALKEY(nolign-1)
      [F:BRD]BRDPRC(I) = [M:BRD1]BRDPRC(nolign-1)
      [F:BRD]VAL1(I)   = [M:BRD1]VAL1(nolign-1)
      [F:BRD]VAL2(I)   = [M:BRD1]VAL2(nolign-1)
      [F:BRD]VAL3(I)   = [M:BRD1]VAL3(nolign-1)
      I +=1
    Endif
  Next nolign
  [F:BRD]NBVAL = nolign-1
  Write [BRD]
  If fstat Then
    GOK=0
    Call FSTA("BRD") From GLOCK
  Endif


If OK=0 : Return : Endif

Return
##########################################################################
##          CONTROLES CHAMPS : écran BRDKEY
##########################################################################
Subprog C_BRDREF(VALEUR)
Variable Char    VALEUR()

If VALEUR= ""
  GMESSAGE = mess(152,7770,1)  # "Référence table obligatoire"
  GERR     = 1 :   mkstat   = 2 :   End
Else
   [M:BRD0]BRDREF = VALEUR
   Affzo [M:BRD0]BRDREF
Endif

End
