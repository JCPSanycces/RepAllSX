#---------------------------------------------------------------------------------------------
# SELVALKEY : sélection saisie valeur de la clé de répartition
#           PARAM(1) contient la rubrique clé de répartition
#---------------------------------------------------------------------------------------------
$SELVALKEY

Local Integer   PDSPKEY

Call LECPLAN([M:BRD0]CPY, 1, RCOA1) From CPTDIV
Call LECPLAN([M:BRD0]CPY, 3, RCOA3) From CPTDIV

PDSPKEY=val(PARAM(1))

Case PDSPKEY
  When GVML_CLECCO
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO and COA = RCOA1"
  When GVML_CLEGAC
    OBJET = "GAC"
    CRITERE = "COA =RCOA1"
  When GVML_CLEIASC
    OBJET = "GAC"
    CRITERE = "COA = RCOA3"
  When GVML_CLEFAM
    OBJET = "FAM"
    CRITERE = ""
#    PARAM(1)=num$(GTD_FAMCPT)
#    PARAM(2)=""
#    PARAM(3) = [M]LEG
#    GSOCIETE = [M]CPY
#    Gosub SELADI From SUBADI
  When Default
Endcase

TIT = mess(12,123,1)-mess(PDSPKEY,3122,1) : # Choix Famille comptable


Return

$TIT_VALTAB
# Pour écraser le titre "Choix table diverse" donné par le modèle
 Case PDSPKEY
   When GVML_CLEFAM
     TIT = mess(12,123,1)-mess(PDSPKEY,3122,1) : # Choix Famille comptable
   When GVML_CLECCO
     TIT = mess(12,123,1)-mess(PDSPKEY,3122,1) : # Choix code comptable
   When GVML_CLEGAC
     TIT = mess(12,123,1)-mess(PDSPKEY,3122,1) : # Choix compte PCG
   When GVML_CLEIASC
     TIT = mess(12,123,1)-mess(PDSPKEY,3122,1) : # Choix compte PCG
   When Default
 Endcase

Return
####################################
Subprog AM_DSPKEY(VALEUR)
Variable Integer VALEUR

If VALEUR <> [M:BRD0]DSPKEY and VALEUR > 1
  [M:BRD0]DSPKEY = VALEUR
  [M:BRD0]CHAMP1 = 0  : Affzo [M:BRD0]CHAMP1
  [M:BRD0]CHAMP2 = 0  : Affzo [M:BRD0]CHAMP2
  [M:BRD0]CHAMP3 = 0  : Affzo [M:BRD0]CHAMP3
  Raz[M:BRD1]
  Titcol [M:BRD1]NBVAL mess([M:BRD0]DSPKEY,3122,1),mess(82,123,1), mess(543,7773,1), "", "", ""
 Affzo [M:BRD1]
Endif

End
######################################################################################
Subprog C_VALKEY(VALEUR)
Variable Char    VALEUR()
End
#-----------------------------------------------
Subprog AM_VALKEY(VALEUR)
Variable Char    VALEUR()

Local Char LTEXTE

If [M:BRD0]DSPKEY = GVML_CLEFAM
#  Read[ADI]CODE=GTD_FAMCPT;VALEUR
  Read [F:FAM]FAM0 = VALEUR

#  If fstat=0   and ([F:ADI]LEG=GWLEG or [F:ADI]LEG ="")
  If fstat=0   and ([F:FAM]LEG=GWLEG or [F:FAM]LEG ="")
#    IDENT1 = num$(GTD_FAMCPT)
#    IDENT2 = [F:ADI]CODE
#    Call LECTEXTRA (LTEXTE, "ATABDIV", "LNGDES", IDENT1, IDENT2) From ATEXTRA
    Call LECTEXTRA (LTEXTE, "FASFAM", "FAMDES", VALEUR, "") From ATEXTRA
    [M:BRD1]INTKEY(nolign-1)  = LTEXTE
    Affzo  [M:BRD1]INTKEY(nolign-1)
  Else
#    If ([F:ADI]LEG <> GWLEG  and [F:ADI]LEG <> "")
    If ([F:FAM]LEG <> GWLEG  and [F:FAM]LEG <> "")
       GMESSAGE = mess(683,7773,1) : GERR=1 # "Cette famille comptable n'est pas autorisée pour la législation "
       mkstat=2 : End
    Else
       GMESSAGE = mess(44,7770,1) :  GERR=1  # "Code inconnu dans la table"
       mkstat=2 : End
     Endif
  Endif
Endif

If [M:BRD0]DSPKEY = GVML_CLECCO
  Read [CAC]CAC0 = GVML_COGIMMO;VALEUR;RCOA1
  If fstat=0
     [M:BRD1]INTKEY(nolign-1)  = [F:CAC]DES
    Affzo [M:BRD1]INTKEY(nolign-1)
  Else
    GMESSAGE = mess(44,7770,1) : # "Code inconnu dans la table"
    mkstat=2 : End
  Endif
Endif


If ([M:BRD0]DSPKEY = GVML_CLEGAC) or [M:BRD0]DSPKEY = GVML_CLEIASC
   If ([M:BRD0]DSPKEY = GVML_CLEGAC)
     Read [GAC]GAC0 = RCOA1;VALEUR
   Else
     Read [GAC]GAC0 = RCOA3;VALEUR
   Endif
   If fstat=0
      [M:BRD1]INTKEY(nolign-1)  = [F:GAC]DES
      Affzo  [M:BRD1]INTKEY(nolign-1)
   Else
      GMESSAGE = mess(44,7770,1) : GERR= 1  # "Code inconnu dans la table"
      mkstat=2 : End
   Endif
Endif

End
######################################################################################
Subprog AP_VALKEY(VALEUR)
Variable Char VALEUR

Call AM_VALKEY(VALEUR)

End
#---------------------------------------------------------------------------------------------
# SELVALCHP: sélection saisie valeur des champs déterminés
#           PARAM(1) contient la valeur de CHAMP1
#           PARAM(2) contient la valeur de CHAMP2
#           PARAM(3) contient la valeur de CHAMP3
#---------------------------------------------------------------------------------------------
$SELVALCHP

Local Integer   PCHAMP1
Local Integer   PCHAMP2
Local Integer   PCHAMP3

PCHAMP1=val(PARAM(1))
PCHAMP2=val(PARAM(2))
PCHAMP3=val(PARAM(3))

Case PCHAMP1
  When GVML_ZMAJCCO
    Gosub TIT_VALCHP
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO & COA = RCOA1"
  When GVML_ZMAJFAM
#    PARAM(1)=num$(GTD_FAMCPT)
#    PARAM(2)=""
#    Gosub SELADI From SUBADI
#    Gosub TIT_VALCHP
    OBJET = "FAM"
    CRITERE = ""
  When Default
Endcase

Case PCHAMP2
  When GVML_ZMAJCCO
    Gosub TIT_VALCHP
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO & COA = RCOA1"
  When GVML_ZMAJFAM
#    PARAM(1)=num$(GTD_FAMCPT)
#    PARAM(2)=""
#    Gosub SELADI From SUBADI
#    Gosub TIT_VALCHP
    OBJET = "FAM"
    CRITERE = ""
  When Default
Endcase


Case PCHAMP3
  When GVML_ZMAJCCO
    Gosub TIT_VALCHP
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO & COA = RCOA1"
  When GVML_ZMAJFAM
#    PARAM(1)=num$(GTD_FAMCPT)
#    PARAM(2)=""
#    Gosub SELADI From SUBADI
#    Gosub TIT_VALCHP
    OBJET = "FAM"
    CRITERE = ""
  When Default
Endcase


Return

$TIT_VALCHP
# Pour écraser le titre "Choix table diverse" donné par le modèle
 Case PCHAMP1
   When GVML_ZMAJFAM
     TIT = mess(12,123,1)-mess(PCHAMP1,3129,4) : # Choix Famille comptable
   When GVML_ZMAJCCO
     TIT = mess(12,123,1)-mess(PCHAMP1,3129,5) : # Choix code comptable
   When Default
 Endcase
 Case PCHAMP2
   When GVML_ZMAJFAM
     TIT = mess(12,123,1)-mess(PCHAMP2,3129,4) : # Choix Famille comptable
   When GVML_ZMAJCCO
     TIT = mess(12,123,1)-mess(PCHAMP2,3129,5) : # Choix code comptable
   When Default
 Endcase

 Case PCHAMP3
   When GVML_ZMAJFAM
     TIT = mess(12,123,1)-mess(PCHAMP3,3129,4) : # Choix Famille comptable
   When GVML_ZMAJCCO
     TIT = mess(12,123,1)-mess(PCHAMP3,3129,5) : # Choix code comptable
   When Default
 Endcase

Return
######################################################################################
Subprog AM_VAL1(VALEUR)
Variable Char    VALEUR()

Local Char LTEXTE

If [M:BRD0]CHAMP1 = GVML_ZMAJFAM
#   Read[ADI]CODE=GTD_FAMCPT;VALEUR
   Read [F:FAM]FAM0 = VALEUR
   If fstat=0
      If ([F:ADI]LEG <> GWLEG  and [F:ADI]LEG <> "")
         GMESSAGE = mess(683,7773,1) : GERR=1 # "Cette famille comptable n'est pas autorisée pour la législation "
         mkstat=2 : End
      Endif
#      IDENT1 = num$(GTD_FAMCPT)
#      IDENT2 = [F:ADI]CODE
#      Call LECTEXTRA (LTEXTE, "ATABDIV", "LNGDES", IDENT1, IDENT2) From ATEXTRA
      Call LECTEXTRA (LTEXTE, "FASFAM", "FAMDES", VALEUR, "") From ATEXTRA
      [M:BRD1]INTVAL1(nolign-1)  = LTEXTE
      Affzo  [M:BRD1]INTVAL1(nolign-1)
   Else
      GMESSAGE = mess(44,7770,1) : # "Code inconnu dans la table"
      mkstat=2 : End
   Endif
Endif

If [M:BRD0]CHAMP1 = GVML_ZMAJCCO
  # Read [CAC]CAC0 = GVML_COGIMMO;VALEUR;"SOC" FQ107224
  Read [CAC]CAC0 = GVML_COGIMMO;VALEUR;RCOA1
  If fstat=0
     [M:BRD1]INTVAL1(nolign-1)  = [F:CAC]DES
  Else
    GMESSAGE = mess(44,7770,1) : # "Code inconnu dans la table"
    mkstat=2 : End
  Endif
Endif

Affzo [M:BRD1]INTVAL1(nolign-1)

End

######################################################################################
Subprog C_VAL1(VALEUR)
Variable Char    VALEUR()

  # FQ107224
  If func SUBBRD.ERROR_FOUND([M:BRD0]CHAMP1, VALEUR)
    GMESSAGE = mess(10,123,1) : # "Champ obligatoire"
    mkstat=2 : End
  Endif

End


