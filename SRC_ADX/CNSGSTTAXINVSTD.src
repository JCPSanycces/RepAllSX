#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry GSTTI
######################################################################################################
# Project       : Australian GST report
# File          : CNSGSTTAXINVSTD
# Version       : 1.0
# Authors       : Ulrike Bader (UBA)
# Creation Date : 2018-09-04
######################################################################################################
# Module        : Finance
# Description   : Tax invoice inquiry for a reporting period (called from function "GST reporting periods")
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
######################################################################################################


$ACTION
Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "DEB_CRIT"   : Gosub DEB_CRIT
    When Default
Endcase
Return

############################################################
##
############################################################
$AUTORIS
Return


############################################################
##
############################################################
$DEB_CRIT
Return


############################################################
#
############################################################
$OUVRE
Local Char    FILTCPT(250)(1..4)
Local Integer IFILT : IFILT = 1
Local Integer ACTPER : ACTPER = val(PARAM(1))
Local Char    LAST_VATCOD(GLONVAT)
Local Char    LAST_NUM(GLONVCR)
Local Decimal TAXAMTSUM, BASAMTSUM

If !clalev ([F:GSTPH])    : Local File GSTPER [GSTPH]            : Endif
If !clalev ([F:DLVBD])    : Local File DCLVATBOXDBD [DLVBD]      : Endif
If !clalev ([F:BPR])      : Local File BPARTNER [BPR]            : Endif
If !clalev ([F:DUD])      : Local File GACCDUDATE [DUD]          : Endif
Return

############################################################
## called when we have to search
############################################################
$LECTURE
  # disable "NEXT" and "BACK" Buttons. We do not have them here! We have no appropiate key for selecting part data
  SUITE   = 1
  RETOUR  = 1

  #delete all entries from the mask
  Raz [M:GSTTI1]
#  Chgstl [M:GSTTI1] With ""
  NBLIG = 0
  NOL    = -1
  nolign = NOL+1
  Raz LAST_VATCOD, LAST_NUM
  Raz TAXAMTSUM, BASAMTSUM

  # create the filter ranges from the header data
  Gosub CREATE_FILTER

  Read [F:GSTPH]GSTPH0 = ACTPER
  If !fstat
      Link [F:DLVBD] With [F:DUD]DUD0~=[F:DLVBD]TYP;[F:DLVBD]NUM;1;1,
&      [F:BPR]BPR0 = [F:DUD]BPR
&     As [LDLVBD]
&     Where [F:DLVBD]NUMRPT = [F:GSTPH]CODGSTPER and [F:DLVBD]ORIMOD <> 2 and
&           !find([F:DLVBD]VATBOX,"1A","1B") and evalue(FILTCPT)
&     Order By [F:DLVBD]CPY;[F:DLVBD]FCY;[F:DLVBD]VAT;[F:DLVBD]NUM

      For [LDLVBD]
        # fill data from file into mask
        Gosub FILL_CNS
      Next

      Gosub CREATE_TOTAL_LINE
  Endif
Return


########################################################################################################################
$CREATE_FILTER
  Raz FILTCPT, IFILT

  # company
  If [M:GSTTI0]CPY <> ""
    Call ADDCRIT(FILTCPT,IFILT,"CPY",'[F:DLVBD]CPY=[M:GSTTI0]CPY'," & ") From GOBJSUB
  Endif

  # date range
  If [M:GSTTI0]STRDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"STRDAT",'[F:DLVBD]ACCDAT>=[M:GSTTI0]STRDAT'," & ") From GOBJSUB
  Endif
  If [M:GSTTI0]ENDDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"ENDDAT",'[F:DLVBD]ACCDAT<=[M:GSTTI0]ENDDAT'," & ") From GOBJSUB
  Endif

  # site
  If [M:GSTTI0]FCY <> ""
    Call ADDCRIT(FILTCPT,IFILT,"FCY",'[F:DLVBD]FCY=[M:GSTTI0]FCY'," & ") From GOBJSUB
  Endif

  # BP
  If [M:GSTTI0]BPR <> ""
    Call ADDCRIT(FILTCPT,IFILT,"BPR",'[F:DUD]BPR=[M:GSTTI0]BPR'," & ") From GOBJSUB
  Endif

  # tax code
  If [M:GSTTI0]VATCOD <> ""
    Call ADDCRIT(FILTCPT,IFILT,"VATCOD",'[F:DLVBD]VAT=[M:GSTTI0]VATCOD'," & ") From GOBJSUB
  Endif

  If FILTCPT = "" : FILTCPT = "1=1" : Endif
Return


############################################################
## Fill data from file into mask in the right order
############################################################
$FILL_CNS
  If NOL >= MAXLIG-1
    Call ERREND(mess(56,176,1)-num$(MAXLIG)) From GESECRAN
    Return
  Endif

  # check if something has changed. If yes > create new line
  If [F:DLVBD]VAT <> LAST_VATCOD or [F:DLVBD]NUM <> LAST_NUM
      NOL    += 1
      nolign = NOL+1
      [M:GSTTI1]ABN(nolign-1)     = [F:BPR]CRN
      [M:GSTTI1]BPR(nolign-1)     = [F:BPR]BPRNUM
      [M:GSTTI1]BPRNAM(nolign-1)  = [F:BPR]BPRNAM
      [M:GSTTI1]INVNUM(nolign-1)  = [F:DLVBD]NUM
      [M:GSTTI1]TOTAMT(nolign-1)  = [F:DLVBD]AMT
      If [F:DLVBD]TYPAMT = 1                              # Base
          [M:GSTTI1]BASAMT(nolign-1)  = [F:DLVBD]AMT
          BASAMTSUM += [F:DLVBD]AMT                       # add to "Total base"
      Else                                                # (Tax) Amount
          [M:GSTTI1]TAXAMT(nolign-1)  = [F:DLVBD]AMT
          TAXAMTSUM += [F:DLVBD]AMT                       # add to "Total tax"
      Endif
      [M:GSTTI1]ACCDAT(nolign-1)  = [F:DLVBD]ACCDAT
      [M:GSTTI1]VATCOD(nolign-1)  = [F:DLVBD]VAT
      [M:GSTTI1]CPY(nolign-1)     = [F:DLVBD]CPY
      [M:GSTTI1]FCY(nolign-1)     = [F:DLVBD]FCY
      [M:GSTTI1]ORIMOD(nolign-1)  = mess([F:DLVBD]ORIMOD,14,1)

      NBLIG=nolign

      LAST_VATCOD = [F:DLVBD]VAT
      LAST_NUM    = [F:DLVBD]NUM
  Else # nothing changed > add amount to existing line
      [M:GSTTI1]TOTAMT(nolign-1) += [F:DLVBD]AMT          # add amount to total
      If [F:DLVBD]TYPAMT = 1                              # Base
          [M:GSTTI1]BASAMT(nolign-1) += [F:DLVBD]AMT
          BASAMTSUM += [F:DLVBD]AMT                       # add to "Total base"
      Else                                                # (Tax) Amount
          [M:GSTTI1]TAXAMT(nolign-1) += [F:DLVBD]AMT
          TAXAMTSUM += [F:DLVBD]AMT                       # add to "Total tax"
      Endif
  Endif
Return



############################################################
$CREATE_TOTAL_LINE
If nolign <= 0 or ([M:GSTTI0]CPY = "" and [M:GSTTI0]FCY = "" and [M:GSTTI0]BPR = "" and [M:GSTTI0]VATCOD = "") : Return : Endif

NOL +=1
nolign = NOL+1
#Chgstl[M:GSTTI1]NBLIG(nolign-1) With "GRAS"

[M:GSTTI1]BPRNAM(nolign-1) = mess(142,124,1)

NBLIG=nolign

[M:GSTTI1]TOTAMT(nolign-1) = BASAMTSUM + TAXAMTSUM
[M:GSTTI1]BASAMT(nolign-1) = BASAMTSUM
[M:GSTTI1]TAXAMT(nolign-1) = TAXAMTSUM
Return



######################################################################################
Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
If !clalev ([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [F:CPY] Where find(CPY,[M:GSTP1]CPY(0..[M:GSTP1]NBLIG-1))
Call SELECT("CPY","",VALEUR,"") From SELOBJ
Filter [CPY]
End


######################################################################################
Subprog D_CODGSTPER(VALEUR)
Variable Decimal VALEUR
VALEUR = [M:GSTPH]CODGSTPER
End

Subprog D_CODGSTGRP(VALEUR)
Variable Char    VALEUR()
VALEUR = [M:GSTPH]CODGSTGRP
End


######################################################################################
Subprog IB_NBLIG
GBOUT1 = mess(1,267,1)+"/"+mess(2,267,1)
GBOUT2 = mess(8,2684,1)
End



######################################################################################
Subprog B1_NBLIG
Local Char VALC1(20), VALC2(20), VALC3(20)
If !clalev ([F:SIH]) : Local File SINVOICE [SIH] : Endif
If !clalev ([F:PIH]) : Local File PINVOICE [PIH] : Endif
[L]VALC3 = ""
[L]VALC2 = [M:GSTTI1]INVNUM(nolign-1)
# first try to find BIC/SIH invoice
Call LECTURE("BIC", [L]VALC2, "") From CONTOBJ
If fstat = 0 Then
    If [F:SIH]ORIMOD = 3 Then
        [L]VALC1 = "BIC"
    Else
        [L]VALC1 = "SIH"
    Endif
Else      # not found > try to find BIS/PIH invoice
    Call LECTURE("BIS", [L]VALC2, "") From CONTOBJ
    If fstat = 0 Then
        If [F:PIH]ORIMOD = 3 Then
            [L]VALC1 = "BIS"
        Elsif [F:PIH]ORIMOD = 6
            [L]VALC1 = "PIH"
        Endif
    Else
        Infbox mess(53,7999,1)-"("+[L]VALC2-mess(40,9016,1)+")"
    Endif
Endif
If fstat = 0 Call OBJET([L]VALC1, [L]VALC2, [L]VALC3) From GOBJET Endif
End



######################################################################################
Subprog B2_NBLIG
Local Char VALC1(20), VALC2(20), VALC3(20)
[L]VALC2 = [M:GSTTI1]INVNUM(nolign-1)
[L]VALC1 = "GAS"
# first try to find BIC/SIH invoice
Call LECTURE("BIC", [L]VALC2, "") From CONTOBJ
If fstat = 0 Then
    [L]VALC3 = [F:SIH]GTE
Else      # not found > try to find BIS/PIH invoice
    Call LECTURE("BIS", [L]VALC2, "") From CONTOBJ
    If fstat = 0 Then
        [L]VALC3 = [F:PIH]GTE
    Else
        If !clalev ([F:HAE]) : Local File GACCENTRY [HAE] : Endif
        Filter [F:HAE] Where NUM = [L]VALC2
        Read [F:HAE] First
        If fstat = 0
            [L]VALC3 = [F:HAE]TYP
        Endif
        Filter [F:HAE]
    Endif
Endif
If fstat = 0 Call OBJET([L]VALC1, [L]VALC2, [L]VALC3) From GOBJET Endif
End

