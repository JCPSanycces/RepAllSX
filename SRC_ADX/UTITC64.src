#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# Created by : RMA
# Date       : 12/11/2014
# Tool for feeding the AUTINV, RECTYP and SAFTINVTYP (according to INVTYP) in table TABSIVTYP
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC64: QAV7.1 P7 : Default values for AUTINV, RECTYP and SAFTINVTYP on TABSIVTYP") From LECFIC
  Call EXE_UTITC64(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog EXE_UTITC64(APPLI)
Value Char APPLI

If clalev([F:TSV]) : Close Local File [TSV] : Endif
Local File =APPLI+".TABSIVTYP" [TSV]

Call ECR_TRACE("UTITC64: Process Start on : "+APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC64
Call ECR_TRACE("UTITC64: Process End on : "+APPLI,0) From GESECRAN

End
########################################
#### Tool - Begin                   ####
########################################
$TR_UTITC64

Local Shortint DO_SAFTINVTYP : DO_SAFTINVTYP = 0
Local Shortint DO_AUTINV     : DO_AUTINV     = 0
Local Shortint DO_RECTYP     : DO_RECTYP     = 0
Local Shortint RUPD          : RUPD          = 0

If dim([F:TSV]AUTINV) > 0
  DO_AUTINV = 1
Endif

If dim([F:TSV]RECTYP) > 0
  DO_RECTYP = 1
Endif

If dim([F:TSV]SAFTINVTYP) > 0
  DO_SAFTINVTYP = 1
Endif

For [F:TSV]
  RUPD = 0
  If DO_AUTINV = 1
    If [F:TSV]AUTINV = 0
      [F:TSV]AUTINV = 1
      RUPD          = 1
      Call ECR_TRACE([F:TSV]SIVTYP + ":AUTINV updated with"-mess([F:TSV]AUTINV,1,1), 0) From GESECRAN
    Endif
  Endif
  If DO_RECTYP = 1
    If [F:TSV]RECTYP = 0
      [F:TSV]RECTYP = 1
      RUPD          = 1
      Call ECR_TRACE([F:TSV]SIVTYP + ":RECTYP updated with"-mess([F:TSV]RECTYP,2029,1), 0) From GESECRAN
    Endif
  Endif
  If DO_SAFTINVTYP > 0
    If [F:TSV]SAFTINVTYP = 0
      Case [F:TSV]INVTYP
        When 1, 5
          [F:TSV]SAFTINVTYP = 1
        When 2, 4
          [F:TSV]SAFTINVTYP = 4
        When 3
          [F:TSV]SAFTINVTYP = 3
      Endcase
      RUPD = 1
      Call ECR_TRACE([F:TSV]SIVTYP + ":SAFTINVTYP updated with"-mess([F:TSV]SAFTINVTYP,2028,1), 0) From GESECRAN
    Endif
  Endif

  If RUPD = 1
    Trbegin [F:TSV]
    Rewrite [F:TSV]
    If fstat
      Rollback
      Break
    Endif
    Commit
  Endif
Next

Return
########################################
#### Tool - End                   ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC64(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier to update
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABSIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC64(APPLI)
End
