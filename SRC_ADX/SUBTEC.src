#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet TEC) 20/09/2011 15:40:47 (MAE)
######################################################################################
$ACTION
  Case ACTION
    When "AFFMASK"        : Gosub AFFMASK
    When "OUVRE"          : Gosub OUVRE
    When "LIENS"          : Gosub LIENS
    When "SETBOUT"        : Gosub SETBOUT
    When "RAZCRE"         : Gosub RAZCRE
    When "INICRE"         : Gosub INICRE
    When "INIMOD"         : Gosub INICRE
    When "ANNULE"         : Gosub ANNULE
    When "CHANGE"         : Call CHANGE_AXX ("TABEECNAT", [L]OCODE, [L]SUPP(0), [L]NCODE, [L]SUPP(0)) From TRTX3TEX
    When "SEL_TABLE"      :
      Case TABLE
        When "SELTECLEG"  : Gosub SELTECLEG
      Endcase
    When "CHGCOD"         : Gosub CHGCOD
    When "FERME"          : Gosub FERME
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  #-----------------------------------#
  # Sauvegarde des variables globales #
  #-----------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #--Lors d'un tunnel depuis un document (exemple : livraison)
  Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
  #--/CPO
Return

######################################################################
$SETBOUT
  #------------------------------#
  # Désactivation bouton "Copie" #
  #------------------------------#
  If GREP <> "" | !CLECUR Then
    Call VIREBOUT(CHAINE, "1") From GOBJET
  Endif
Return

#################################################################################
$CHGCOD
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################
$INICRE
  #--- Creation / Modif de ATEXTRA
  Call MAJTEXTRA ([M:TEC1]DESAXX,"TABEECNAT","DESAXX",[M:TEC1]EECNAT,[M:TEC1]LEG) From ATEXTRA
  Call MAJTEXTRA ([M:TEC1]SHOAXX,"TABEECNAT","SHOAXX",[M:TEC1]EECNAT,[M:TEC1]LEG) From ATEXTRA
  #    SOS libellés
  If dim([F:TEC]LANDESSHO)>0
    [F:TEC]LANDESSHO=GLANGUE+"~"+[M:TEC1]DESAXX+"~"+[M:TEC1]SHOAXX
  Endif
Return

######################################################################
$AFFMASK
  Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
  Gosub GRILEG
Return

######################################################################
$RAZCRE
  Gosub GRILEG
Return

######################################################################################
$LIENS
  GCURLEG = [F:TEC]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Return

######################################################################
$GRILEG
  If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
    Diszo [M:TEC1]LEG
    [M:TEC1]LEG=GDOSLEG(1)
    Affzo [M:TEC1]LEG
  Endif
Return

######################################################################
$ANNULE
  #--CPO 71937 Prise en compte de LEG, ajout de [F:TEC]LEG
  Delete [AXX] Where CODFIC="TABEECNAT" & IDENT1=[F:TEC]EECNAT & IDENT2=[F:TEC]LEG
Return

######################################################################
$FERME
  #--CPO 71937
  #------------------------------------#
  # Restitution des variables globales #
  #------------------------------------#
  Gosub REST_GLOB From TRTX3GLOB
  #If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  #--/CPO
  # To manage the button Tunnel
  If TUNNEL<>1 | dim(VCOD)<1 : Return : Endif
  VCOD = CLE2
Return

######################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

  GCURLEG = VALEUR
End

######################################################################
Subprog C_SOC(VALEUR)
Variable Char    VALEUR()

  GGRPFCY = VALEUR :#--CPO 71937
End

######################################################################
Subprog AM_SOC(VALEUR)
Variable Char    VALEUR()

  GGRPFCY = VALEUR :#--CPO 71937
End

##################################################
## Actions of the data type TEC
##################################################
#-- Control
# FGR 14/01/2013 : X3SUIVI71937
Subprog CONTTEC(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local    Integer CAS
Local    Char    OPTIONS(30)

  If GFONCTION = "GESTEC" | COD = "" Then
    End
  Endif
  # --------------------------------------------------------------------------
  If clalev([F:TEC])  = 0 : Local File TABEECNAT  [TEC] : Endif
  If clalev([F:AMZZ]) = 0 : Local File AMSKZON    [AMZZ] : Endif :#--for the selection options of the object
  # --------------------------------------------------------------------------
  If func AFNC.ACTIV("LEG") = 0 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then : # GCURLEG positionné par programme
    LEG = GCURLEG
  Endif
  # --------------------------------------------------------------------------
  CAS = 1  #--Legislation is empty

  #--CPO 71937
  #--Cas particulier : pas de GCURLEG mais société ou site en ligne
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
  If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
    If [L]FCY<>""
      If [F:FCY]FCY<>[L]FCY
        Read [F:FCY]FCY0=[L]FCY
        If fstat : Raz [F:FCY] Endif
      Endif
      If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
    Endif
    If [L]CPY<>""
      If [F:CPY]CPY<>[L]CPY
        Read [F:CPY]CPY0=[L]CPY
        If fstat : Raz [F:CPY] Endif
      Endif
      [L]LEG=[F:CPY]LEG
    Endif
  Endif
  #--/CPO

  If LEG <> "" Then
    Read [TEC]TEC0=COD;LEG
    If fstat Then
      Read [TEC]TEC0=COD;""
    Else
      CAS = 2  #--Legislation isn't empty
    Endif
  Else
    Read [TEC]TEC0(1)=COD
    If !fstat Then
      LEG = [F:TEC]LEG
      CAS = 2
    Endif
  Endif
  If fstat Then
    Filter [TEC] Where EECNAT=[L]COD
    Look [TEC]TEC0 First
    If !fstat Then
      # "Fiche inexistante pour la législation courante"
      # "No existing record for the curent legislation"
      GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
    Else
      # "Fiche inexistante"
      # "Record does not exist"
      GMESSAGE = [L]COD-":"-mess(23,100,1)
    Endif
    Filter [TEC]
    mkstat = 2
    End
  Endif
  # --------------------------------------------------------------------------
  #--Filtrage par groupe de société
  #--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
  #--Du fait du type de donné AGF sur le champ GRP de TABVAT, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TEC]SOC<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TEC]SOC
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TEC]SOC<>[L]CPY
				  #--CPO 102920 Non existing variable (changed EECNAT with COD)
          GMESSAGE += [L]COD+"\"+mess(63,127,1)-":"-[F:TEC]SOC : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TEC]SOC;[L]CPY
        If fstat
          #--CPO 102920 Non existing variable (changed EECNAT with COD)
          GMESSAGE += [L]COD+"\"+mess(63,127,1)-":"-[F:TEC]SOC : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

  #--Contrôle de cohérence entre le groupe de la taxe et la législation
  If [F:TEC]SOC <> "" and LEG <> "" Then
    Call CTLGFYLEG([F:TEC]SOC, LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'entrée retenue
  If GROUPE <> "" and [F:TEC]LEG <> "" Then
    Call CTLGFYLEG(GROUPE, [F:TEC]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  # --Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
  # --uniquement si le groupe passé est renseigné
  # --uniquement si pas de contexte site ou société !
  If GROUPE <> "" Then
    If CPY = "" and FCY = "" and [F:TEC]SOC <> "" and [F:TEC]SOC <> GROUPE Then
      #--Les groupes doivent avoir au moins une société en commun
      Gosub CTLGFYGRP
      If mkstat Then
        End
      Endif
    Endif
  Endif
  # --------------------------------------------------------------------------
  #--On charge les options définies sur le type de données du champ du masque
  #--Findig Object options defined on the data type of the field in the screen
  OPTIONS = ""
  If CODMSK <> "" & CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat = 0 Then
      OPTIONS = [F:AMZZ]OPTOBJ
    Endif
  Endif
  If CAS = 2 Then
   Call CONTROLE("TEC",OPTIONS,LEG,COD,mkstat) From CONTOBJ
  Else
   Call CONTROLE("TEC",OPTIONS,"",COD,mkstat) From CONTOBJ
  Endif
End

#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [F:TEC]LEG = "" Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTECZGRP"
      Local File =SZVIEW [TECZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TECZ]TECZ0=[L]GROUPE;[F:TEC]EECNAT;[F:TEC]SOC;[F:TEC]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TEC]SOC - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTECYGRP"
      Local File =SZVIEW [TECY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TECY]TECY0=[L]GROUPE;[F:TEC]EECNAT;[F:TEC]SOC;[F:TEC]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TEC]SOC - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Endif
Return

##################################################
## Tunnel Table nature transaction DEB
# FGR 13/11/2012 : X3SUIVI71937
Subprog TUNTEC(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD) < 1 Then
    Global Char VCOD(GLONTEC)

    TOKILL = 1
  Endif
  If clalev([F:TEC])=0 : Local File TABEECNAT [TEC] : Endif
  VCOD = COD
  If GNBLEG = 1 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then
    LEG = GCURLEG
  #--If LEG="" then firstly we search a TRE record with LEG="" secondly a TRE record with TRE<>""
  Elsif LEG = "" Then
    Read [TEC]TEC0=VCOD;LEG
    If fstat Then
      Read [TEC]TEC0(1)=VCOD
      If !fstat Then
        LEG = [F:TEC]LEG
      Endif
    Endif
  Endif
  Read [TEC]TEC0=COD;LEG
  If fstat Then
    LEG = ""
  Endif
  Call OBJET("TEC",LEG,VCOD) From GOBJET
  COD = VCOD
  If TOKILL Then
    Kill VCOD
  Endif
End

############################################################
# FGR 14/01/2013 : X3SUIVI71937
$SELTECLEG
Local Char FCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char LEG(GLONADI)
Local Char GRP(GLONAGC)
Local Char STYPSEL(GLONDES)
Local Integer WNOL
Local Integer ERR
Local Integer I
Local Char SZVIEW(GLONAVW)
Local Char CODMSK(GLONAMK)
Local Char CHAMPCOD(GLONAVA)

  If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
  #--------------------------------------------------------------------------------------------------
  If clalev([F:TEC])=0 : Local File TABEECNAT [TEC] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
  If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
  If clalev([F:AMZZ])=0: Local File AMSKZON   [AMZZ] : Endif
  If clalev([F:AGF])=0 : Local File AGRPFCY   [AGF] : Endif
  #--------------------------------------------------------------------------------------------------
  #--98275 On lit le AMZZ trop tôt
  #--On charge les options définies sur le type de données du champ du masque
  #OPTIONS = ""
  #If CODMSK <> ""  and CHAMPCOD <> "" Then
  #  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  #  If fstat = 0 Then
  #    OPTIONS = [F:AMZZ]OPTOBJ
  #  Endif
  #Endif
  #--------------------------------------------------------------------------------------------------
  If GFONCTION = "GESTEC" Then
    # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
    OBJET = "TEC"
    Return
  Endif

  #--------------------------------------------------------------------------------------------------
  # Récupération des paramètres
  #--------------------------------------------------------------------------------------------------
  LEG      = PARAM(1)
  FCY      = PARAM(2)
  GRP      = PARAM(3)
  CPY      = PARAM(4)
  STYPSEL  = PARAM(5)  # Prévu mais pas utilisé pour le moment
  CODMSK   = PARAM(6)
  CHAMPCOD = PARAM(7)
  #--------------------------------------------------------------------------------------------------
  #--98275 On lit le AMZZ trop tôt
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS = ""
  If CODMSK <> ""  and CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat = 0 Then
      OPTIONS = [F:AMZZ]OPTOBJ
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  # Initialisation de législation
  If func AFNC.ACTIV("LEG")=0
    [L]LEG = GDOSLEG
  Endif
  If [L]LEG = "" Then
    If [L]FCY <> "" Then
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY <> "" Then
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG = "" Then
    [L]LEG = GCURLEG
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Position et taille de la fenêtre
  #--------------------------------------------------------------------------------------------------
  Gosub OUVRE_LISTE From WOTEC
  For I = 1 To NBSEL
    If SELEXP(I) <> "" Then
      COL(I) = SELEXP(I)
    Else
      COL(I) = SELZON(I)
    Endif
    TIT(I) = SELLIB(I)
    If left$(SELFMT(I),2)="LA"
      COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
    Endif
  Next I
  NBCOL   = NBSEL
  SIZCOL  = 260
  SIZLIG  = 100
  TIT(0)  = mess(12,123,1)  # Choix
  Call TITOBJ("TEC", "", TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START   = "[F:TEC]EECNAT"
  ORDRE   = "[F:TEC]EECNAT;[F:TEC]LEG"
  OBJET   = ""
  #--------------------------------------------------------------------------------------------------
  ## Critères pour la sélection standard
  #--------------------------------------------------------------------------------------------------
  # --------------------------------------
  ICRITERE = 1
  CRITERE(ICRITERE) = '1=1'
#--CPO 71937 Ca c'est le bon !
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
	#--Cas du groupe étant une société
 	Read [F:AGF]AGF0=[L]GRP
 	If !fstat
 		If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
 	Endif
 	#--Le filtrage sur les groupes sites/sociétés est fait dans le link directement
Endif
#--/CPO
  If [L]FCY <> "" Then
    #--Site
    CRITERE(ICRITERE) -= '& ([F:TEC]SOC="" | ([F:TEC]SOC<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
  Elsif [L]CPY <> "" Then
    #--Société
    CRITERE(ICRITERE) -= '& ([F:TEC]SOC="" | ([F:TEC]SOC<>"" & [F:TECC]LEGCPY="'+[L]CPY+'"))'
  Endif
  # --------------------------------------
#--CPO 71937 NOK (voir plus haut)
#  #--Groupe de soc/sites
#  If [L]FCY="" & [L]CPY="" & [L]GRP<>""
#    CRITERE(ICRITERE) -= '& ([F:TEC]SOC="" | [F:TEC]SOC="'+[L]GRP+'")'
#  Endif
  ICRITERE += 1
  #--Législation
  If LEG <> "" Then
    CRITERE(ICRITERE) -= '& ([F:TEC]LEG="'+[L]LEG+'" | [F:TEC]LEG="")'
  Endif
  # --------------------------------------
  If dim(SELCAR) > 0 & SELCAR <> 0 Then
    CRITERE(ICRITERE) -= '& left$([F:TEC]EECNAT,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
  Endif
  # --------------------------------------
  # Catégorie
  #STYPSEL    # Prévu mais pas utilisé pour le moment
  # --------------------------------------
  ICRITERE += 1
  Call FILROLE(OBJET, FILROLE) From SUBARL
  If FILROLE <> "" & FILROLE <> "1=1" Then
    For I = 0 To dim(FILROLE)-1
      Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", FILROLE(I), "&") From GOBJSUB
    Next I
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
    If [L]LEG <> "" Then
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTECYGRP"
        Local File =SZVIEW [TECY]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TEC"
        Return
      Endif
    Else
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTECZGRP"
        Local File =SZVIEW [TECZ]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TEC"
        Return
      Endif
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  If 1=1 Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTECCPY"
      Local File =SZVIEW [TECC]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TEC"
      Return
    Endif
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    If [L]LEG <> "" Then
      # Vue via GCURLEG
      #--CPO penser à sauvegarder GCURLEG !!!!!
      #Local Char SAVE_LEG(GLONADI)
      #SAVE_LEG=GCURLEG
      #GCURLEG = [L]LEG
      #Call MAJVUE("LEGTECSEL",nomap) From DOSVUE
      #GCURLEG=SAVE_LEG
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTECSEL"
        Local File =SZVIEW [TECS]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TEC"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TEC] With [F:AXX]AXX0   = "TABEECNAT";"DESAXX";GLANGUE;[F:TEC]EECNAT;[F:TEC]LEG,
&                       [F:TECY]TECY0 ~= [L]GRP;[F:TEC]EECNAT;[F:TEC]SOC;[F:TEC]LEG,
&                       [F:TECS]TEC0  ~= [F:TEC]EECNAT;[F:TEC]LEG;[L]LEG
&                    As [LTEC]
      Else
        Link [TEC] With [F:AXX]AXX0   = "TABEECNAT";"DESAXX";GLANGUE;[F:TEC]EECNAT;[F:TEC]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TEC]SOC,
&                       [F:TECC]TEC0  = [F:TEC]EECNAT;[F:TEC]LEG;[F:TEC]SOC;[L]CPY,
&                       [F:TECS]TEC0 ~= [F:TEC]EECNAT;[F:TEC]LEG;[L]LEG
&                    As [LTEC]
      Endif
    Else
      # Vue LEG vide
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTECPAR"
        Local File =SZVIEW [TECP]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TEC"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TEC] With [F:AXX]AXX0   = "TABEECNAT";"DESAXX";GLANGUE;[F:TEC]EECNAT;[F:TEC]LEG,
&                       [F:TECZ]TECZ0 ~= [L]GRP;[F:TEC]EECNAT;[F:TEC]SOC;[F:TEC]LEG
&                    As [LTEC]
      Else
        Link [TEC] With [F:AXX]AXX0   = "TABEECNAT";"DESAXX";GLANGUE;[F:TEC]EECNAT;[F:TEC]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TEC]SOC,
&                       [F:TECC]TEC0  = [F:TEC]EECNAT;[F:TEC]LEG;[F:TEC]SOC;[L]CPY,
&                       [F:TECP]TEC0 ~= [F:TEC]EECNAT;[F:TEC]LEG
&                    As [LTEC]
      Endif
    Endif
  Endif
  # --------------------------------
  # Options de sélection
  If OPTIONS <> "" Then
    Gosub OPTIONS From WOTEC
    ICRITERE += 1
    For I = 1 To NBCOND
      If instr(1,OPTIONS,OPT(I)) Then
        Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", "("+CONDIT(I)+")", "&") From GOBJSUB
      Endif
    Next I
  Endif
  # --------------------------------
  Default File [LTEC]
  DEFPAG = 1
Return

#-------------------------------------
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

###########################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un régime de taxe                #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File TABEECNAT [TEC1]
    Local File ATEXTRA   [AXX1]
  Else
    Local File =[M]DOSORG+".TABEECNAT" [TEC1]
    Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TABEECNAT [TEC2]
    Local File ATEXTRA   [AXX2]
    Local File ACTIV     [ACV2]
Else
    Local File =[M]DOSDES+".TABEECNAT" [TEC2]
    Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
    Local File =[M]DOSDES+".ATABDIV"   [ADI2]
    Local File =[M]DOSDES+".ACTIV"     [ACV2]
    Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
  Endif
  Gosub OUVDOS From ATEXTRA
  # Multi-Lég... Vérifier que la législation existe dans le dossier destination
  # Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
  # Note FGR : c'est pas top ici. Déjà y a pas de message
  #  If TABLE2 <> "" & clalev([F:ADS2]) > 0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
  #    Return
  #  Endif
  #
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
  Close Local File [TEC1], [TEC2]
  Close Local File [AXX1], [AXX2]
  If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
  If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
  If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
  If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif
Return

###########################################################################
$TRT_COPIE
Local Integer ILIG

  #--------------------------------------------------#
  # Transaction de copie                             #
  #--------------------------------------------------#
  Local Char    LEGDES
  Local Integer WMONOLEGDES
  # Par défaut : Leg destination=leg de l'enregistrement à copier
  LEGDES=TABLE2
  GOK = 1
  # -----------------------------------------------
  # Contrôles
#  If TABLE2 <> "" Then
#    If [M]DOSDES <> nomap Then
#      Local Char SZDOSSIER(GLONADS)
#      Local Integer LG
#
#      Read [ADI2]CODE=909;TABLE2
#      If fstat Then
#        Call MESSAGE([M:TEC1]LEG - ':' - mess(173,187,1)) From GESECRAN     #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#      LG = instr(1, [M]DOSDES, "@")
#      If LG = 0 Then
#        SZDOSSIER = [M]DOSDES
#      Else
#        SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#      Endif
#      Read [ADS2]DOSSIER=SZDOSSIER
#      If !fstat Then
#        If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#          Call MESSAGE([M:TEC1]LEG - ':' - mess(249,133,1)) From GESECRAN   #-- Législation non gérée par ce dossier --#
#          Return
#        Endif
#      Endif
#    Endif
#  Endif
  #

  If [M]DOSDES<>nomap
      # Le dossier destination est-il mono-leg ?
      If [F:ACV2]CODACT<>"LEG"
       Read [ACV2]CODACT = "LEG"
       If fstat Raz [F:ACV2] : Endif
      Endif
      If [F:ACV2]FLACT<>2
       WMONOLEGDES=0
      Else
       WMONOLEGDES=1
      Endif

      If WMONOLEGDES =0
          # Dossier destination mono-leg
          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If fstat
              # Pb lecture dossier
              Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
              Return
          Endif
          If [F:ADS2]DOSLEG(0)=""
              # Pas de législation pour le dossier
              Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
              Return
          Endif
          If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
              # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
              # Pas de copie
              Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
              Return
          Elsif TABLE2=''
              # La leg de l'enreg. à copier est toute leg
              # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
              LEGDES=[F:ADS2]DOSLEG(0)
          Endif
      Else
          # Dossier destination multi-leg
          If TABLE2<>''
            # Enregistrement à copier avec leg<>""
            Local Char SZDOSSIER(GLONADS)
            Local Integer LG
            Read [ADI2]CODE=909; TABLE2
            If fstat
             Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
             Return
            Endif

            LG = instr(1, [M]DOSDES, "@")
            If LG = 0 Then
              SZDOSSIER = [M]DOSDES
            Else
              SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
            Endif
            Read [ADS2]DOSSIER=SZDOSSIER
            If !fstat Then
                If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                  Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                  Return
                Endif
            Endif
          Endif
      Endif
  Endif

  Read [TEC2]TEC0=TABLE;LEGDES
  If !fstat Then
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
  Endif
  # -----------------------------------------------
  Trbegin [TEC2]
  Delete [TEC2] Where EECNAT = TABLE & LEG = LEGDES
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".TABEECNAT"
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK=0
    Call RSTA("TEC2", "") From GLOCK
    Goto AB_COPIE
  Endif
  If !fstat Then
    #-- copie des données
    For [TEC1] Where EECNAT = TABLE & LEG = TABLE2
      [F:TEC2] = [F:TEC1]
      [F:TEC2]LEG=LEGDES
      If TABLE2=LEGDES
           Call COPTEXTRA("TABEECNAT","DESAXX",TABLE,TABLE2) From ATEXTRA
           If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
           Call COPTEXTRA("TABEECNAT","SHOAXX",TABLE,TABLE2) From ATEXTRA
           If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
      Else
           Call COPTEXTRA1("TABEECNAT","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
           If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
           Call COPTEXTRA1("TABEECNAT","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
           If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
      Endif
      If dim([F:TEC2]UPDUSR) > 0 Then
        [F:TEC2]UPDUSR = GUSER
      Endif
      If dim([F:TEC2]UPDDAT) > 0 Then
        [F:TEC2]UPDDAT = date$
      Endif
      If fstat Then
        GOK = 0
        Call FSTA("TEC2") From GLOCK
      Endif
      Write [TEC2]
      If fstat Then
        GOK = 0
        Call FSTA("TEC2") From GLOCK
        Break
      Endif
    Next
  Endif
  If GOK < 0 Then
    Goto ROLL_COPIE
  Elsif !GOK Then
    Goto AB_COPIE
  Endif
  Commit
Return


#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif
Return

