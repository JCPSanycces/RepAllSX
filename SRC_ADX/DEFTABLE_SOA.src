#<AdxTL>@(#)0.0.0.0 $Revision$
$LECEMP
If dim(CTR)<0
 Local Char CTR(GLONHRCTR)
Endif
Read [AD]AD0 = MATRI
Read [CPT]CPT0 = MATRI
Read [ID]ID0 = MATRI
Read [EAF]EAF0 = MATRI
Read [EAUS]EAUS0 = MATRI
Read [IDES]IDES0 = MATRI
Read [EMID]EMID0 = MATRI
Read [IDPOR]IDPOR0 = MATRI
Read [ESA]ESA0 = MATRI
Filter [CHD] Where REFNUM=MATRI
Read [CHD]CHD1 Last
If fstat : Raz [F:CHD] : Endif
Filter [CHD]
Filter [EXM] Where REFNUM=MATRI & DATEXM<=DATMAT
Read [EXM]EXM1 Last
If fstat : Raz [F:EXM] : Endif
Filter [EXM]
Filter [EXN] Where REFNUM=MATRI & EXSDAT<=DATMAT
Read [EXN]EXN1 Last
If fstat : Raz [F:EXN] : Endif
Filter [EXN]
Filter [HAB] Where REFNUM=MATRI
Read [HAB]HAB0 First
If fstat : Raz [F:HAB] : Endif
Filter [HAB]
Filter [JNT] Where REFNUM=MATRI
Read [JNT]JNT0 First
If fstat : Raz [F:JNT] : Endif
Filter [JNT]
Filter [MED] Where REFNUM=MATRI
Read [MED]MED0 First
If fstat : Raz [F:MED] : Endif
Filter [MED]
Filter [PAR] Where REFNUM=MATRI & PARDAT<=DATMAT
Read [PAR]PAR1 Last
If fstat : Raz [F:PAR] : Endif
Filter [PAR]
Filter [RIB] Where REFNUM=MATRI
Read [RIB]RIB0 First
If fstat : Raz [F:RIB] : Endif
Filter [RIB]
Filter [TRY] Where REFNUM=MATRI & STRDATTRY<=DATMAT
Read [TRY]TRY1 Last
If fstat : Raz [F:TRY] : Endif
Filter [TRY]
If CTR<>''
 Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTR]CTR1 Last
If fstat : Raz [F:CTR] : Endif
Filter [CTR]
If CTR<>''
 Filter [CTRAFR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRAFR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRAFR]CTRAFR1 Last
If fstat : Raz [F:CTRAFR] : Endif
Filter [CTRAFR]
If CTR<>''
 Filter [CTRAUS] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRAUS] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRAUS]CTRAUS1 Last
If fstat : Raz [F:CTRAUS] : Endif
Filter [CTRAUS]
If CTR<>''
 Filter [CPR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CPR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CPR]CPR1 Last
If fstat : Raz [F:CPR] : Endif
Filter [CPR]
Filter [CTE] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Read [CTE]CTE0 First
If fstat : Raz [F:CTE] : Endif
Filter [CTE]
If CTR<>''
 Filter [CTRFRA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRFRA] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRFRA]CTRFRA1 Last
If fstat : Raz [F:CTRFRA] : Endif
Filter [CTRFRA]
If CTR<>''
 Filter [CTRMID] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRMID] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRMID]CTRMID1 Last
If fstat : Raz [F:CTRMID] : Endif
Filter [CTRMID]
Filter [CPN] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Read [CPN]CPN0 First
If fstat : Raz [F:CPN] : Endif
Filter [CPN]
If CTR<>''
 Filter [CTRPO] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRPO] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRPO]CTRPO1 Last
If fstat : Raz [F:CTRPO] : Endif
Filter [CTRPO]
If CTR<>''
 Filter [CTRSA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRSA] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRSA]CTRSA1 Last
If fstat : Raz [F:CTRSA] : Endif
Filter [CTRSA]
Filter [EPC] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Read [EPC]EPC0 First
If fstat : Raz [F:EPC] : Endif
Filter [EPC]
Filter [EDM] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Read [EDM]EDM0 First
If fstat : Raz [F:EDM] : Endif
Filter [EDM]
Filter [ELC] Where REFNUM=MATRI
Read [ELC]ELC0 First
If fstat : Raz [F:ELC] : Endif
Filter [ELC]
Filter [HRITM] Where REFNUM=MATRI
Read [HRITM]HRITM0 First
If fstat : Raz [F:HRITM] : Endif
Filter [HRITM]
Filter [EPO] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Read [EPO]EPO0 First
If fstat : Raz [F:EPO] : Endif
Filter [EPO]
If CTR<>''
 Filter [SAL] Where REFNUM=MATRI & CTRNUM=CTR & SALDAT<=DATMAT
Else
 Filter [SAL] Where REFNUM=MATRI & SALDAT<=DATMAT
Endif
Read [SAL]SAL1 Last
If fstat : Raz [F:SAL] : Endif
Filter [SAL]
If CTR<>''
 Filter [ETA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [ETA] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [ETA]ETA1 Last
If fstat : Raz [F:ETA] : Endif
Filter [ETA]
If CTR<>''
 Filter [ETR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [ETR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [ETR]ETR1 Last
If fstat : Raz [F:ETR] : Endif
Filter [ETR]
Return

$OUVRE
Local File EMPLOAD [AD]
Local File EMPLOCPT [CPT]
Local File EMPLOID [ID]
Local File EMPLOIDAFR [EAF]
Local File EMPLOIDAUS [EAUS]
Local File EMPLOIDESS [IDES]
Local File EMPLOIDMID [EMID]
Local File EMPLOIDPOR [IDPOR]
Local File EMPLOIDSA [ESA]
Local File EMPLOCHD [CHD]
Local File EMPLOEXM [EXM]
Local File EMPLOEXN [EXN]
Local File EMPLOHAB [HAB]
Local File EMPLOJNT [JNT]
Local File EMPLOMED [MED]
Local File EMPLOPAR [PAR]
Local File EMPLORIB [RIB]
Local File EMPLOTRY [TRY]
Local File EMPLOCTR [CTR]
Local File EMPLOCTRAFR [CTRAFR]
Local File EMPLOCTRAUS [CTRAUS]
Local File EMPLOCTRCPT [CPR]
Local File EMPLOCTREMP [CTE]
Local File EMPLOCTRFRA [CTRFRA]
Local File EMPLOCTRMID [CTRMID]
Local File EMPLOCTRPEN [CPN]
Local File EMPLOCTRPOR [CTRPO]
Local File EMPLOCTRSA [CTRSA]
Local File EMPLOCUM [EPC]
Local File EMPLODIRNUM [EDM]
Local File EMPLOELC [ELC]
Local File EMPLOITM [HRITM]
Local File EMPLOPOT [EPO]
Local File EMPLOSAL [SAL]
Local File EMPLOTAXAFR [ETA]
Local File EMPLOTAXREC [ETR]
Return

