#<AdxTL>@(#)2.0.0.0 $Revision$
#################################################################################
# UUMGTRTPUR52  Appel de la resynchro des mouvements fournisseurs Module TC #
#################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR52") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR52(DOSSIER)
  Call MAJ_UUMGTRTPUR52(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTPUR52(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR52",ERR) From TRTMIG

End

#################################################################################
#################################################################################
Subprog MAJ_UUMGTRTPUR52(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 112434 - 2015-11-12 by SR : Adaptation Historic folder
If func DOSVUE.ISVIEW(DOSSIER,"BPSUPPMVT")=1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# End issue 112434

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

If filinfo(filpath("FIL","BPSUPPMVT","fde",[F:ADS]DOSSIER),0)<=0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGTRTPUR52 Supplier Transactions Process 2 : Update BPSUPPMVT") From DOSSUB

#-----
Gosub SET_FIRST   From TRTFIRST

#----- Tables tronc commun et superviseur -----#
Local File =[F:ADS]DOSSIER+".BPCUSTMVT"   [MVC]
Local File =[F:ADS]DOSSIER+".BPSUPPMVT"   [MVS]
Local File =[F:ADS]DOSSIER+".LASTSUPMVT"  [LSM]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR]
Local File =[F:ADS]DOSSIER+".BPCUSTOMER"  [BPC]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
Local File =[F:ADS]DOSSIER+".PINVOICE"    [PIH]
Local File =[F:ADS]DOSSIER+".PERIOD"      [PER]
Local File =[F:ADS]DOSSIER+".FISCALYEAR"  [FIY]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU0]
Local File =[F:ADS]DOSSIER+".TABCHANGE"   [TCH]
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]
#----- Tables achats -----#
Local File =[F:ADS]DOSSIER+".PQUOTAT"     [PQH]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [POQ]
Local File =[F:ADS]DOSSIER+".PRECEIPT"    [PTH]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
#----- Tables tiers -----#
If [F:ADS]MODULE(2)=2
  Local File =[F:ADS]DOSSIER+".PAYMENTH"  [PYH]
  Local File =[F:ADS]DOSSIER+".TABPAYTYP" [TPY]
Endif
#----- Tables comptabilité -----#
If [F:ADS]MODULE(1)=2
  Local File =[F:ADS]DOSSIER+".BALANCE"   [BAL]
Endif
#-----
If val(VERSION)<GMIGX3VER60
  Call RESYNCHRO_BPSMVT(2,"",2,"",1) From FUNBPSMVT
Endif
#-----
Close Local File [MVC], [MVS], [LSM], [BPR], [BPC], [BPS], [ITM], [PIH], [PER],
&                [FIY], [GAC], [TCU], [TCU0], [TCH], [CPY], [FCY], [PQH], [POH], [POQ],
&                [PTH], [PTD]
#-----
If [F:ADS]MODULE(2)=2  Close Local File [PYH], [TPY] : Endif
If [F:ADS]MODULE(1)=2  Close Local File [BAL] : Endif
If GOK<1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",7,ERR) From TRTMIG : #7=Erreur
## si terminé OK, le MIGTRTEND suffit
##Else
##  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR52",3,ERR) From TRTMIG : #3=Terminée
Endif
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR52") From TRTMIG
#-----
Gosub UNSET_FIRST From TRTFIRST
Call ECR_TIME("UUMGTRTPUR52 Supplier Transactions Process 2 : Ended") From DOSSUB
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR52(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR52(APPLI)
End

