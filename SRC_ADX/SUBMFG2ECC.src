#<AdxTL>@(#)0.0.0.0 $Revision$
##################################
# Issue X3-6311 - 2017-06-21 by BAKHA : if versioned and user is allowed to make critical changes,
#                                       then do not disable excloude/reinstate, add component, add assembly buttons
# Issue X3-48941 - 2017-08-16 by BAKHA : when adding component, allow product line with version to be selected

Subprog IB_NBLIG
If dim([M:MFG1]ECCVALMAJ)<0 : End :Endif

Local Integer I
I= sigma(0,[M:MFG1]NBLIG-1,(indcum+1)*([M:MFG1]ECCVALMAJ(indcum)="" & [M:MFG1]ITMTYP(indcum)=1))

If !I       # no product without version number
  # Issue X3-6311 - if user can make critical changes, then do not disable buttons
  If !GWOCRICHG or GREP = "C"
    Raz GBOUT2
    Raz GBOUT12
  Endif
Endif
If [M:MFG2]MFGLIN(nolign-1)=0
    # if the component is not linked to a product but to whole work order
    # and products are managed with version => no exclusion
    If I
      # Issue X3-6311 - if user can make critical changes, then do not disable buttons
      If !GWOCRICHG or GREP = "C"
        Raz GBOUT3
      Endif
    Endif
Else
    I= find([M:MFG2]MFGLIN(nolign-1),[M:MFG1]MFGLIN(0..[M:MFG1]NBLIG-1))
    If I & [M:MFG1]ECCVALMAJ(I-1)<>""
      # if component linked to a product managed with version => no exclusion
      # Issue X3-6311 - if user can make critical changes, then do not disable buttons
      If !GWOCRICHG or GREP = "C"
        Raz GBOUT3
      Endif
    Endif
Endif
End

##################################
# Issue 111417 - 2015-09-30 by CCC : refresh line color
Subprog APRES_NBLIG(NOL)
Value Integer NOL
If func ECCLIB.NBRCPN([M:MFG2]ITMREF(NOL))
    Call HIGHLIGHT("MFG2",NOL) From ECCLIB
Endif
End

##################################
Subprog AM_ITMREF(VALEUR)
Variable Char VALEUR

Local Integer LALT

If dim([M:MFMW]ECCVALMAJ)>0
    Effzo [M:MFMW]ECCVALMAJ,ECCVALMIN
    Call ECCAFF(VALEUR,"MFMW") From SUBMFGECC
    If func ECCLIB.NBRCPN(VALEUR)
        # ECC preload of major and minor version
        Call INIECCBOM(VALEUR, [M:MFG0]MFGFCY, [M:MFG1]STRDAT, 4, [M:MFMW]ECCVALMAJ,[M:MFMW]ECCVALMIN,LALT) From MFGECCLIB
        Affzo [M:MFMW]ECCVALMAJ,ECCVALMIN
    Endif
Endif

End

##################################
Subprog AM_GHOST(VALEUR)
Variable Char VALEUR

Local Integer LALT

If dim([M:MFMF]ECCVALMAJ)>0
    Effzo [M:MFMF]ECCVALMAJ,ECCVALMIN
    Call ECCAFF(VALEUR,"MFMF") From SUBMFGECC
    If func ECCLIB.NBRCPN(VALEUR)
        # ECC preload of major and minor version
        LALT = [M:MFMF]GHOSTALT
        Call INIECCBOM(VALEUR, [M:MFG0]MFGFCY, [M:MFG1]STRDAT, 2, [M:MFMF]GHTECCMAJ,[M:MFMF]GHTECCMIN,LALT) From MFGECCLIB
        [M:MFMF]GHOSTALT = LALT
        Affzo [M:MFMF]GHTECCMAJ,GHTECCMIN,GHOSTALT
    Endif
Endif

End

##################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

# Issue 111417 - 2015-09-30 by CCC : same action used in MFMW & MFG2
If maskcou="MFMW"
    If func ECCLIB.NBRCPN([M]ITMREF)=1  # wait ECCVALMIN if necessary
        Call CTRECC([M]ITMREF,"MFMW","ECCVALMAJ",VALEUR,"",
&                   [M]RETDAT,LRET,[M]ECCERRMSG) From ECCLIB
        [M]ECCERRCOD = LRET
    Endif
Else
    If func ECCLIB.NBRCPN([M]ITMREF(nolign-1))=1
        Call CTRECC([M]ITMREF(nolign-1),"MFG2","ECCVALMAJ",VALEUR,"",
&                   [M]RETDAT(nolign-1),LRET,[M]ECCERRMSG(nolign-1)) From ECCLIB
        [M]ECCERRCOD(nolign-1) = LRET
    Endif
Endif

End

##################################
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

# Issue 111417 - 2015-09-30 by CCC : same action used in MFMW & MFG2
If maskcou="MFMW"
    Call CTRECC([M]ITMREF,"MFMW","ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&               [M]RETDAT,LRET,[M]ECCERRMSG) From ECCLIB
    [M]ECCERRCOD = LRET
Else
    Call CTRECC([M]ITMREF(nolign-1),"MFG2","ECCVALMIN",[M]ECCVALMAJ(nolign-1),VALEUR,
&               [M]RETDAT(nolign-1),LRET,[M]ECCERRMSG(nolign-1)) From ECCLIB
    [M]ECCERRCOD(nolign-1) = LRET
Endif

End

##################################
Subprog C_GHTECCMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call CTRECC([M]GHOST,"MFMF","GHTECCMAJ",VALEUR,[M]GHTECCMIN,
&           [M:MFG1]STRDAT,GERR,GMESSAGE) From ECCLIB

If find(GERR,1,4)
    GERR=1
    mkstat=2
Endif
End

##################################
Subprog C_GHTECCMIN(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call CTRECC([M]GHOST,"MFMF","GHTECCMIN",[M]GHTECCMAJ,VALEUR,
&           [M:MFG1]STRDAT,GERR,GMESSAGE) From ECCLIB

If find(GERR,1,4)
    GERR=1
    mkstat=2
Endif
End

##################################
Subprog AS_MFGLINK(VALEUR)
Variable Integer VALEUR

If dim([M:MFG1]ECCVALMAJ)<0 : End :Endif

Local Integer I

For I=0 To [M:MFG1]NBLIG-1
    If [M:MFG1]ECCVALMAJ(I)<>""
        mkstat=2
        VALEUR=2
        Break
    Endif
Next

End

##################################
Subprog C_MFGLIN(VALEUR)
Variable Decimal VALEUR

# If addition of a by-product, no control of versioning mangement of products
If [M:MFMW]CPNTYP=4 : End : Endif

If dim([M:MFG1]ECCVALMAJ)<0 : End :Endif

# Issue X3-48941 - if permitted user, then line with version can be selected
If GWOCRICHG : End : Endif

Local    Integer I
For I=0 To [M:MFG1]NBLIG-1
    If [M:MFG1]MFGLIN(I)=VALEUR & [M:MFG1]ECCVALMAJ(I)<>""
        mkstat=2
        GMESSAGE = mess(83,123,1)
        Break
    Endif
Next
End

##################################
$SETNOL
If dim([M]ECCVALMAJ)>1
    NOL=nolign-1
Else
    NOL = 0
Endif
Return

#####################################################################
$LIENS

If dim([M:MFG2]ECCVALMAJ)>0
    Call CTRECCCPN(-1) From SUBMFGECC
Endif
Return

