#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
  When "INIT"    : Gosub INIT
  When "DEBUT"   : Call TRT_FLG([M:TCFO]CPY,[M:TCFO]FCY): Affzo [M:TCFO]
  When "EXEC"    : Gosub EXEC
  When "TERMINE" : Gosub TERMINE
  When "CONTROLE": Gosub CONTROLE
  When "END"     : Gosub FIN
Endcase
Return

###################### ACTIONS ##########################################
$FIN
GOK=0 : FIN=1
Return

$TERMINE

    Local Char WLOCK(30)
    WLOCK="FUNTRTCFO~"+ [M:TCFO]CPY
    Unlock =WLOCK
    If !GSERVEUR
        TRA=1
    Else
        TRA=0
    Endif
Return

$INIT
If !clalev([FCY]): Local File FACILITY : Endif
If !clalev([CFOT]): Local File CFOTYP : Endif

Local Mask TRTCFO[TCFO]

Raz [M:TCFO]
Call LECTURE("CPY",[M:TCFO]CPY,"") From CONTOBJ
Call LECMEMO ("STD","[M:TCFO]","cfo") From GMEMO


Return
#########################################################################
$CONTROLE
Local Char WLOCK(30)
WLOCK="FUNTRTCFO~"+ [M:TCFO]CPY
Lock =WLOCK With lockwait=0
If fstat
  GMESSAGE= mess(30,100,1)   # The record is used by an other user
  GERR=2 : FIN=1 : Return
Endif

 If GOK < 1  FIN=1 Else TMP=1  Endif
Return
##########################################################################
$EXEC

If !GSERVEUR
  Call OUVRE_TRACE(mess(193,187,1)) From LECFIC
  TRA = 1
Else
  Call ECR_TRACE(mess(193,187,1)-format$("D:",date$)-time$,0) From GESECRAN
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
###### Setup of the CFO type by company
Local Integer HORPAST
Local Integer SNS
Local Integer FLG
Local Integer TDAYS(3)
Local Integer INCRE
Local Integer WCFOTYP
Local Integer NUMDOC
Local Decimal NUMFCY
Local Integer STAT
Local Decimal TOTAL_AMOUNT            ## Total amount by category
Local Decimal TOTAL_AMOUNTR
Local Decimal DOC_AMOUNT, DOC_AMOUNT_INI ## Amount by X3 document (+VAT)
Local Decimal TOTAL_FOOT              ## Amount from invoicing elements
Local Char    CRITSOC(250), CRITDAT(250), CRITSUP(250)  ## Selection criteria
Local Date    CFODAT(50), DAT
Local Decimal AMOUNT(50), AMOUNTLOC
Local Char BANDEF(GLONBAN)
Local Char CFOPBYRAT(10), CFOPAYSTT(10) ## General parameter
Local Integer DELAY_DAYS ## Delay by the behaviou of the payments customer
Local Mask CFO0, CFO1, CFO2 ## Working screen
Local Char WFCY(GLONFCY)
Local Char WCPY(GLONCPY)
Local Char WBPR(GLONBPR)
Local Integer WBPREXD
Local Char WLEG(GLONADI)
Local Char WLED(GLONLED)
Local Char WCOA(GLONCOA)
Local Char WSAC(GLONSAC)
Local Char WBAN(GLONBAN)
Local Char TEXTE(100)
Local Decimal MONTANTBAS   ## Amount without tax
Local Decimal MONTANTLIN
Local Decimal MONTANTTAX(3)     : # Montant des taxes
Local Decimal MONTANTDED(1..)     : # Montant déductible
Local  Integer TYPREG           : # Type de régime
Global Integer GMULACV
Local Char VAT(GLONVAT)(3)

If func AFNC.ACTIV("MUL")
   GMULACV=1
Endif

If !clalev([CFOMM]): Local File CFOMANMVT [CFOMM]: Endif
If !clalev([CFODD]): Local File CFODUDDATE [CFODD]: Endif
If !clalev([CPY]):   Local File COMPANY [CPY]: Endif
If !clalev([FCY]):   Local File FACILITY [FCY]: Endif
If !clalev([GCM]):   Local File GACM [GCM]: Endif
If !clalev([LED]):   Local File GLED [LED]: Endif
If !clalev([TCU]):   Local File TABCUR [TCU]: Endif
If !clalev([BPR]):   Local File BPARTNER [BPR]: Endif
If !clalev([BPC]):   Local File BPCUSTOMER [BPC]: Endif
If !clalev([BPS]):   Local File BPSUPPLIER [BPS]: Endif
If !clalev([BAB]):   Local File BANK [BAN]: Endif
# Issue 56229 - 2017-11-15 by MWA
If func ASYRFNC.ACTIV("MUL") >0
  If !clalev([BPE]):   Local File BPEXCEPT [BPE]: Endif
Endif

Call LEC_CPY([M:TCFO]CPY) From CPTLEC
#### Parameters CFOBANDEF / CFOPBYRAT
If [M:TCFO]FCY<>""
   Call PARAM([M:TCFO]FCY,"CFOBANDEF", BANDEF) From ADOVAL
Endif
Call PARAM([M:TCFO]CPY,"CFOPBYRAT",CFOPBYRAT) From ADOVAL
Call PARAM([M:TCFO]CPY,"CFOPAYSTT",CFOPAYSTT) From ADOVAL

Call READ_LEGLEDCOA([M:TCFO]CPY,WLEG,WLED,WCOA)
GCURLEG=WLEG
## Valeurs of CFOTYP

Filter [FCY] Where FINFLG=2 and LEGCPY=[M:TCFO]CPY
NUMFCY=rowcount([FCY])

Filter [FCY]
Local Char WCFOTYPFCY(3+GLONFCY)((NUMFCY+1)*10)
Local Integer WHORPAST((NUMFCY+1)*10)
Local Integer WSNS((NUMFCY+1)*10)
Local Integer WFLG((NUMFCY+1)*10)
Local Integer WTDAYS1((NUMFCY+1)*10)
Local Integer WTDAYS2((NUMFCY+1)*10)
Local Integer WTDAYS3((NUMFCY+1)*10)
Local Integer WINCRE((NUMFCY+1)*10)
Local Integer WLOG((NUMFCY+1)*10)
Local Integer I
Filter [CFOT] Where CPY=[M:TCFO]CPY and CFOTYP<=10
I=0
For [CFOT]CFOT0
  WCFOTYPFCY(I)=num$([F:CFOT]CFOTYP)+"~"+[F:CFOT]FCY
  WHORPAST(I)=[F:CFOT]PASHOR
  WSNS(I)=[F:CFOT]SNS
  WFLG(I)=[F:CFOT]FLG
  WTDAYS1(I)=[F:CFOT]DAY1
  WTDAYS2(I)=[F:CFOT]DAY2
  WTDAYS3(I)=[F:CFOT]DAY3
  WINCRE(I)=[F:CFOT]DAYINC
  WLOG(I)=0
  I+=1
Next
Filter [CFOT]

#####
If [M:TCFO]CFOPR=2: Gosub TRT_PSH: Endif ## Purchase request
If [M:TCFO]CFOPO=2: Gosub TRT_POH: Endif ## Purchase orders
If [M:TCFO]CFOPC=2: Gosub TRT_POC: Endif ## Open purchase orders
If [M:TCFO]CFORN=2: Gosub TRT_PTH: Endif ## Receipts
If [M:TCFO]CFOQU=2: Gosub TRT_SQH: Endif ## Sales quuotes
If [M:TCFO]CFOSO=2: Gosub TRT_SOH: Endif ## Sales Order
If [M:TCFO]CFOSC=2: Gosub TRT_SOR: Endif ## Open sales orders
If [M:TCFO]CFODN=2: Gosub TRT_SDH: Endif ## Deliveries
If [M:TCFO]CFOCM=2: Gosub TRT_CON: Endif ## Maintenance contracts
If [M:TCFO]CFOLEA=2:Gosub TRT_LEA: Endif ## Lease contracts
Gosub TRT_DUD                            ## Real open items

Gosub TRT_PER                            ## Recalculation of period movements

Gosub TRT_OBS                            ## Treatment of CFOMANMVT with obsolete status


If !GSERVEUR
  Call FERME_TRACE From LECFIC
Else
  Call ECR_TRACE("",0) From GESECRAN
Endif
Kill GMULACV
Return
######################################################################################
## screen TRTCFO
######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End
############################################################################################
####################### Treatment of Purchase Request ######################################
############################################################################################
$TRT_PSH

Call ECR_TRACE(mess(446,197,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(6)<>2
  Call ECR_TRACE(mess(6,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY
Raz TOTAL_AMOUNT

Local Char TBPS(GLONBPR)(50)
Local Char TCUR(GLONCUR)(50)
Local Char TBAN(GLONBAN)(50)

WCFOTYP=1  ## Purchase Requests

If !clalev([PSH]): Local File PREQUIS  [PSH]: Endif
If !clalev([PSD]): Local File PREQUISD [PSD]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ### Deletion of the records of this category / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES  ## definition of the criteres

Link [PSH] With [FCY]FCY0=PSHFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]PSH0
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL #### Parameter CFOBANDEF
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]PRQDAT>=date$-HORPAST  ### If the category is setup for this company / site and the document is not befores date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, TBPS, TCUR, TBAN, DOC_AMOUNT, WBPR

    Filter [PSD] Where PSHNUM=[F:TABX]PSHNUM & LINAPPFLG>2 & LINORDFLG<>2 & LINCLEFLG<>2 and BPSNUM<>""
    For [PSD]PSD0
      If WBPR<>[F:PSD]BPSNUM
        WBPR=[F:PSD]BPSNUM: WBPREXD=0
        Call LEC_BPS([F:PSD]BPSNUM) From CPTLEC
        If !fstat
         If [F:BPS]BPRPAY<>""
           WBPREXD = func FUNTRTCFO.CONT_EXCL([F:BPS]BPRPAY, [F:TABX]CPY )
           Call READ_BAN([F:BPS]BPRPAY,[M:TCFO]CPY,WFCY,2,BANDEF,WBAN)
           Call READ_SAC([F:BPS]BPRPAY,[M:TCFO]CPY,WCOA,2,WSAC)
         Else
           WBPREXD = func FUNTRTCFO.CONT_EXCL([F:PSD]BPSNUM, [F:TABX]CPY )
           Call READ_BAN([F:PSD]BPSNUM,[M:TCFO]CPY,WFCY,2,BANDEF,WBAN)
           Call READ_SAC([F:PSD]BPSNUM,[M:TCFO]CPY,WCOA,2,WSAC)
         Endif
        Endif
      Endif
      If WBPREXD and WBAN<>""
        If [F:PSD]QTYPUU-[F:PSD]ORDQTYPUU>0
          DAT=max([PSD]EXTRCPDAT+INCRE, date$)
          For Y=0 To 49
            If CFODAT(Y)=[0/0/0]
              CFODAT(Y)=DAT
              AMOUNT(Y)=ar2([F:PSD]LINATIAMT*([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)/[F:PSD]QTYPUU)

              If [F:BPS]BPRPAY<>""
                TBPS(Y)=[F:BPS]BPRPAY
              Else
                TBPS(Y)=[F:PSD]BPSNUM
              Endif
              TCUR(Y)=[F:PSD]CUR
              TBAN(Y)=WBAN
              Break
            Endif
            If CFODAT(Y)=DAT and ((TBPS(Y)=[F:BPS]BPRPAY and [F:BPS]BPRPAY<>"") or TBPS(Y)=[F:PSD]BPSNUM)  and TCUR(Y)=[F:PSD]CUR
              # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
              If [F:PSD]VACTYP<>4
                AMOUNT(Y)+=ar2([F:PSD]LINATIAMT*([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)/[F:PSD]QTYPUU)
                Break
              Else
                AMOUNT(Y)+=ar2([F:PSD]LINAMT*([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)/[F:PSD]QTYPUU)
                Break
              Endif
              # END X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
            Endif
          Next
          DOC_AMOUNT+=AMOUNT(Y)
        Endif
      Endif
    Next
    Filter [PSD]
    If DOC_AMOUNT<>0

    ### Creation of CFO register
      Gosub CRE_CFOMVT
      If STAT=0
        NUMDOC+=1

        For Y=0 To 40
           If AMOUNT(Y)=0: Break: Endif
           AMOUNTLOC=AMOUNT(Y)
           If TCUR(Y)<>[F:CPY]ACCCUR
             Call CONVERT(TCUR(Y),[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNT(Y),AMOUNTLOC,STAT) From TRTDEV
           Endif
           TOTAL_AMOUNT+=AMOUNTLOC
        Next
        ### Trace
        If [M:TCFO]DETTRC=2
          TEXTE=format$("K:50X",mess(222,197,1)+":"-[F:TABX]PSHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-TCUR(0)
          Call ECR_TRACE(TEXTE,0) From GESECRAN
          For Y=1 To 40
            If CFODAT(Y)=[0/0/0]: Break: Endif
            TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-TCUR(Y)
            Call ECR_TRACE(TEXTE,0) From GESECRAN
          Next
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(16,195,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return
############################################################################################
####################### Treatment of Purchase orders   #####################################
############################################################################################
$TRT_POH

Call ECR_TRACE(mess(447,197,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(6)<>2
  Call ECR_TRACE(mess(6,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=3  ## Purchase orders

If !clalev([POH]): Local File PORDER [POH]: Endif
If !clalev([POQ]): Local File PORDERQ [POQ]: Endif
If !clalev([POP]): Local File PORDERP [POP]: Endif
If !clalev([PVF]): Local File PVCRFOOT [PVF]: Endif
If !clalev([DUD]): Local File GACCDUDATE [DUD]: Endif

Local Decimal PREPAYMENT, AMOUNTAI

Call DEBTRANS From GLOCK
Gosub DEL_CFO  ### Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ## definition of the criteres

Link [POH] With [FCY]FCY0=POHFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]POH1
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]ORDDAT>=date$-HORPAST ## If the category is setup for this company / site and the document id not befores date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, TOTAL_FOOT, AMOUNTAI, PREPAYMENT, DOC_AMOUNT

    If WBPR<>[F:TABX]BPRPAY
      WBPR=[F:TABX]BPRPAY
      Call LEC_BPS([F:TABX]BPRPAY) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPRPAY,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPRPAY,[F:TABX]CPY,WFCY,2,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPRPAY,[F:TABX]CPY,WCOA,2,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      Filter [POQ] Where POHNUM=[F:TABX]POHNUM and LINCLEFLG<>2 and LININVFLG<>2 and LINSTA<>3 and RCPCLEFLG<>2
      For [POQ]POQ0
        Read [POP]POP0=[POQ]POHNUM;[POQ]POPLIN;[POQ]POQSEQ
        If !fstat and ar2([POP]NETPRI*([POQ]QTYPUU-[POQ]RCPQTYPUU)/[POQ]UOMPUUCOE)>0 #X3-63582
          DAT=max([POQ]EXTRCPDAT+INCRE, date$)
          MONTANTBAS=ar2([POP]NETPRI*([POQ]QTYPUU-[POQ]RCPQTYPUU)/[POQ]UOMPUUCOE)  #X3-63582
          AMOUNTAI+=MONTANTBAS
          Call CALTAXE([F:TABX]CPY,DAT,[F:TABX]VACBPR,[F:TABX]CUR,3,[F:POP]VAT,1,MONTANTBAS,MONTANTTAX,MONTANTDED,TYPREG,STAT) From SUBTVT
          # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          #MONTANTLIN=MONTANTBAS+sum(MONTANTTAX())
          MONTANTLIN=MONTANTBAS+sum(MONTANTTAX())*([F:TABX]VACTYP<>4)
          # End X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          For Y=0 To 49
            If CFODAT(Y)=[0/0/0]
              CFODAT(Y)=DAT
              AMOUNT(Y)=MONTANTLIN
              Break
            Endif
            If CFODAT(Y)=DAT
              AMOUNT(Y)+=MONTANTLIN
              Break
            Endif
          Next
        Endif
      Next
      Filter [POQ]
      DOC_AMOUNT=sum(AMOUNT())

      ### foot amount ###################################
      Filter [PVF] Where VCRNUM=[F:TABX]POHNUM and VCRTYP=3
      For [PVF]PVF0
       If [F:TABX]TOTLINAMT<>0 ## 115156
        If [F:PVF]CLCBAS=2
          # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          TOTAL_FOOT=ar2((AMOUNTAI/[F:TABX]TOTLINAMT)*([F:PVF]INVORDAMT+[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4)))
        Else
          # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          TOTAL_FOOT=ar2((DOC_AMOUNT/[F:TABX]TOTLINATI)*([F:PVF]INVORDAMT+[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4)))
        Endif
       Else ## 115156
           # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
           TOTAL_FOOT=[F:PVF]INVORDAMT+[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4) ## 115156
       Endif ## 115156
        DOC_AMOUNT_INI=sum(AMOUNT())
        For Y=0 To 49
          If AMOUNT(Y)=0: Break: Endif
          AMOUNT(Y)+=ar2(AMOUNT(Y)*TOTAL_FOOT/DOC_AMOUNT_INI)
        Next
        AMOUNT(0)+=(DOC_AMOUNT_INI+TOTAL_FOOT)-sum(AMOUNT())
      Next
      Filter [PVF]
      DOC_AMOUNT=sum(AMOUNT())

      ### Preapyments ####################################
      Filter [DUD] Where TYP="*PO" and NUM=[F:TABX]POHNUM
      For [DUD]DUD0
        PREPAYMENT +=[F:DUD]AMTCUR
      Next
      Filter [DUD]
      If PREPAYMENT<>0
      ### Repartition of the prepayment
        For Y=0 To 49
          If AMOUNT(Y)=0: Break: Endif
          AMOUNT(Y)-=ar2(AMOUNT(Y)*PREPAYMENT/DOC_AMOUNT)
        Next
        AMOUNT(0)+=(DOC_AMOUNT-PREPAYMENT)-sum(AMOUNT())
        DOC_AMOUNT-=PREPAYMENT
      Endif
      If DOC_AMOUNT<>0
        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,DOC_AMOUNT,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(260,198,1)+":"-[F:TABX]POHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(9,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return
############################################################################################
####################### Treatment of Open Purchase orders   ################################
############################################################################################
$TRT_POC

Call ECR_TRACE(mess(1,13,1)-mess(10,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(6)<>2
  Call ECR_TRACE(mess(6,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=2 ## Open purchase orders

If !clalev([POH]): Local File PORDER [POH]: Endif
If !clalev([POQ]): Local File PORDERQ [POQ]: Endif
If !clalev([POP]): Local File PORDERP [POP]: Endif
If !clalev([PVF]): Local File PVCRFOOT [PVF]: Endif

Local Decimal AMOUNTAI

Call DEBTRANS From GLOCK
Gosub DEL_CFO  ### Deletion of the records of this company / site
If STAT: Return: Endif
Gosub TRT_CRITERES  ## Definition of the criteres

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Link [POH] With [FCY]FCY0=POHFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]POH1
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]ORDDAT>=date$-HORPAST ## If the category is setup for this company / site and the document is before date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, AMOUNTAI, DOC_AMOUNT, TOTAL_FOOT
    If WBPR<>[F:TABX]BPRPAY
      WBPR=[F:TABX]BPRPAY
      Call LEC_BPS([F:TABX]BPRPAY) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPRPAY,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPRPAY,[F:TABX]CPY,WFCY,2,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPRPAY,[F:TABX]CPY,WCOA,2,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      Filter [POQ] Where LINSTA<>3 and POHNUM=[F:TABX]POHNUM
      For [POQ]POQ0
        Filter [POP] Where POHNUM=[POQ]POHNUM and POPLIN=[POQ]POPLIN and STRDAT<=[POQ]DEMRCPDAT
        Read [POP]POP0 Last
        If !fstat and ar2([POP]NETPRI*([POQ]QTYPUU-[POQ]RCPQTYPUU))>0
          DAT=max([POQ]DEMRCPDAT+INCRE, date$)
          MONTANTBAS=ar2([POP]NETPRI*([POQ]QTYPUU-[POQ]RCPQTYPUU))
          AMOUNTAI=MONTANTBAS
          Call CALTAXE([F:TABX]CPY,DAT,[F:TABX]VACBPR,[F:TABX]CUR,3,[F:POP]VAT,1,MONTANTBAS,MONTANTTAX,MONTANTDED,TYPREG,STAT) From SUBTVT
          # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          MONTANTLIN=MONTANTBAS+sum(MONTANTTAX()*([F:TABX]VACTYP<>4))
          For Y=0 To 49
            If CFODAT(Y)=[0/0/0]
              CFODAT(Y)=DAT
              AMOUNT(Y)=MONTANTLIN
              Break
            Endif
            If CFODAT(Y)=DAT
              AMOUNT(Y)+=MONTANTLIN
              Break
            Endif
          Next
        Endif
        Filter [POP]
      Next
      Filter [POQ]
      DOC_AMOUNT=sum(AMOUNT())
      If DOC_AMOUNT<>0
      ### foot amount ###################################
      Filter [PVF] Where VCRNUM=[F:TABX]POHNUM and VCRTYP=5
      For [PVF]PVF0
        If [F:PVF]AMTCOD=2
          If [F:PVF]DEBCDT=1
            # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
            TOTAL_FOOT=+[F:PVF]INVDTAAMT +[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4)
          Else
            # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
            TOTAL_FOOT=-[F:PVF]INVDTAAMT +[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4)
          Endif
        Else
          If [F:PVF]CLCBAS=2
            TOTAL_FOOT=ar2(AMOUNTAI*([F:PVF]INVDTAAMT/100))
          Else
            TOTAL_FOOT= -ar2(DOC_AMOUNT*([F:PVF]INVDTAAMT/100))
          Endif
        Endif
        DOC_AMOUNT_INI=sum(AMOUNT())
        For Y=0 To 49
          If AMOUNT(Y)=0: Break: Endif
          AMOUNT(Y)+=ar2(AMOUNT(Y)*TOTAL_FOOT/DOC_AMOUNT_INI)
        Next
        AMOUNT(0)+=(DOC_AMOUNT_INI+TOTAL_FOOT)-sum(AMOUNT())
      Next
      Filter [PVF]
      DOC_AMOUNT=sum(AMOUNT())

        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(28,477,1)+":"-[F:TABX]POHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(10,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

############################################################################################
####################### Treatment of Receipts ##############################################
############################################################################################
$TRT_PTH

Call ECR_TRACE(mess(1,13,1)-mess(11,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(6)<>2
  Call ECR_TRACE(mess(6,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=4  ## Receipts

If !clalev([PTH]): Local File PRECEIPT [PTH]: Endif
If !clalev([PTD]): Local File PRECEIPTD [PTD]: Endif
If !clalev([PVF]): Local File PVCRFOOT [PVF]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO  ## Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ## Definition of the criteres

Link [PTH] With [FCY]FCY0=PRHFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]PTH2
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]RCPDAT>=date$-HORPAST  ## If the category is setup for this company /site and the document is before date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT, TOTAL_FOOT
    If WBPR<>[F:TABX]BPRPAY
      WBPR=[F:TABX]BPRPAY
      Call LEC_BPS([F:TABX]BPRPAY) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPRPAY,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPRPAY,[F:TABX]CPY,WFCY,2,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPRPAY,[F:TABX]CPY,WCOA,2,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      For [PTD]PTD0 Where PTHNUM=[F:TABX]PTHNUM and LININVFLG<>2
        If ar2([PTD]NETPRI*([PTD]QTYPUU-[PTD]INVQTYPUU-[F:PTD]RTNQTYPUU))>0
          DAT=max([F:TABX]RCPDAT+INCRE, date$)
          MONTANTBAS=ar2([PTD]NETPRI*([PTD]QTYPUU-[PTD]INVQTYPUU-[F:PTD]RTNQTYPUU))
          Call CALTAXE([F:TABX]CPY,DAT,[F:TABX]VACBPR,[F:TABX]CUR,3,[F:PTD]VAT,1,MONTANTBAS,MONTANTTAX,MONTANTDED,TYPREG,STAT) From SUBTVT
          # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
          MONTANTLIN=MONTANTBAS+sum(MONTANTTAX())*([F:TABX]VACTYP<>4)
          CFODAT(0)=DAT
          AMOUNT(0)+=MONTANTLIN
        Endif
      Next
      DOC_AMOUNT=sum(AMOUNT())
      ### foot amount ###################################
      Filter [PVF] Where VCRNUM=[F:TABX]PTHNUM and VCRTYP=6
      For [PVF]PVF0
        # X3-85117 In function CONSBTR, the amount of order with the tax code CEE is false
        TOTAL_FOOT=[F:PVF]INVDTAAMT+[F:PVF]DTAAMTTAX*([F:TABX]VACTYP<>4)
        AMOUNT(0)+=TOTAL_FOOT
      Next
      Filter [PVF]
      DOC_AMOUNT=AMOUNT(0)

      If DOC_AMOUNT<>0
      ### Creation of CFO register
        Read [BPS]BPS0=[F:TABX]BPRPAY
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=AMOUNT(0)
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(27,477,1)+":"-[F:TABX]PTHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(11,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

#####################################################################################
####################### Treatment of Sale Quotes #####################################
######################################################################################
$TRT_SQH

Call ECR_TRACE(mess(1,13,1)-mess(1,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(5)<>2
  Call ECR_TRACE(mess(5,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=5 ## Sale Quotes

If !clalev([SQH]): Local File SQUOTE [SQH]: Endif
If !clalev([SQD]): Local File SQUOTED [SQD]: Endif
If !clalev([SVF]): Local File SVCRFOOT [SVF]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ### Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES  ## Definition of the criteres

Link [SQH] With [FCY]FCY0=SALFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]SQH1
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]QUODAT>=date$-HORPAST ## If the category is setup for this company/site and the document is not before date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT, TOTAL_FOOT
    If WBPR<>[F:TABX]BPCORD
      WBPR=[F:TABX]BPCORD
      Call LEC_BPC([F:TABX]BPCORD) From CPTLEC
      If !fstat
        If [F:BPC]BPCPYR<>""
          WBPREXD = func FUNTRTCFO.CONT_EXCL([F:BPC]BPCPYR,[F:TABX]CPY)
          Call READ_BAN([F:BPC]BPCPYR,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
          Call READ_SAC([F:BPC]BPCPYR,[F:TABX]CPY,WCOA,1,WSAC)
        Else
          WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPCORD,[F:TABX]CPY)
          Call READ_BAN([F:TABX]BPCORD,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
          Call READ_SAC([F:TABX]BPCORD,[F:TABX]CPY,WCOA,1,WSAC)
        Endif
      Endif
    Endif
    If WBPREXD and WBAN<>""
      DAT= date$+[F:SQH]DAYLTI
      CFODAT(0)=DAT
      Filter [SQD] Where SQHNUM=[F:TABX]SQHNUM
      For [SQD]SQD0
        If ar2([SQD]NETPRIATI*([SQD]QTY-[SQD]ORDQTY))>0
          AMOUNT(0)+=ar2([SQD]NETPRIATI*([SQD]QTY-[SQD]ORDQTY))
        Endif
      Next
      Filter [SQD]
      DOC_AMOUNT=sum(AMOUNT())
      If DOC_AMOUNT<>0
        ### Moving the date to the first invoice day
        Gosub CALC_INVDAY

        ### Repartition of the total foot amount
        Filter [SVF] Where VCRNUM=[F:TABX]SQHNUM and VCRTYP=1
        For [SVF]SVF0
          If [F:SVF]AMTCOD=1
            TOTAL_FOOT+=ar2(sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))*(DOC_AMOUNT/[F:TABX]QUOATI)
          Else
            TOTAL_FOOT+=ar2(sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))
          Endif
        Next
        Filter [SVF]
        If TOTAL_FOOT <> 0
          For Y=0 To 49
            If AMOUNT(Y)=0: Break: Endif
            AMOUNT(Y)+=ar2(AMOUNT(Y)*TOTAL_FOOT/DOC_AMOUNT)
          Next
          AMOUNT(0)+=(DOC_AMOUNT+TOTAL_FOOT)-sum(AMOUNT())
        Endif
        DOC_AMOUNT=sum(AMOUNT())
        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(9,477,1)+":"-[F:TABX]SQHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(1,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

######################################################################################
####################### Treatment of Sale Orders #####################################
######################################################################################
$TRT_SOH

Call ECR_TRACE(mess(1,13,1)-mess(2,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(5)<>2
  Call ECR_TRACE(mess(5,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

Local Decimal PREPAYMENT, AMOUNTAI
Local Integer IND

## X3-44031
Local Decimal WENCOURS, WENCOURSSHR
Local Integer WCDTSTA, WOSTCHGTYP, SPSTAT
Local Char WPARAM(10), WOSTCUR(3)
Local Date WOSTDAT
GSOCIETE=[M:TCFO]CPY
Call PARAML([M:TCFO]CPY,"OSTCTL",WPARAM) From ADOVAL     : # Niveau ctrl en-cours client
GOSTCTL= val(WPARAM)
If GOSTCTL=1
    WOSTCUR=GCURSHR    : # Ctrl niveau dossier : Devise : Devise dossier
Else
    WOSTCUR=GLOCALDEV  : # Ctrl niveau société : Devise : Devise société
Endif
    WOSTDAT=datesyst
If GOSTCHGTYP=2
    Call PARAML(GSOCIETE,"OSTTYPCUR",WPARAM) From ADOVAL     : # Type de cours : Type de cours ctrl au cours actualisé      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    WOSTCHGTYP= val(WPARAM)
Else
    WOSTCHGTYP=1
Endif
## End X3-44031

WCFOTYP=6  ### Sale Orderfs

If !clalev([SOH]): Local File SORDER [SOH]: Endif
If !clalev([SOQ]): Local File SORDERQ [SOQ]: Endif
If !clalev([SOP]): Local File SORDERP [SOP]: Endif
If !clalev([SVF]): Local File SVCRFOOT[SVF]: Endif
If !clalev([SFI]): Local File SFOOTINV[SFI]: Endif
If !clalev([DUD]): Local File GACCDUDATE [DUD]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ## deletion of the records for this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ### Definition of the criteres

#Trbegin [CFOMM]

Link [SOH] With [FCY]FCY0=SALFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]SOH1

  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]ORDDAT>=date$-HORPAST ## If the category is setup for this company/site and the document is not before date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT, TOTAL_FOOT, PREPAYMENT
    If WBPR<>[F:TABX]BPCPYR
      WBPR=[F:TABX]BPCPYR
      Call LEC_BPC([F:TABX]BPCPYR) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPCPYR,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPCPYR,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPCPYR,[F:TABX]CPY,WCOA,1,WSAC)
      Endif
      ### x3-44031
      WCDTSTA=1: WENCOURS=0
      If [F:BPC]OSTCTL=3 & [F:SOH]UNL <> 2: WCDTSTA = 2 : Endif
      If [F:BPC]OSTCTL = 1 & [F:SOH]UNL <> 2
        Call CALENC([F:BPC]BPCRSK, date$, WENCOURS) From TRTBPMVT
        If WOSTCUR<>GCURSHR
           Call CONVERT(WOSTCUR, GCURSHR, GLOCALDEV, WOSTCHGTYP, date$, WENCOURS, WENCOURSSHR, SPSTAT) From TRTDEV
        Else
           WENCOURSSHR = WENCOURS
        Endif
        If WENCOURSSHR > [F:BPC]OSTAUZ : WCDTSTA = 3 : Endif
      Endif
      ### End X3-44031
    Endif
    If WBPREXD and WBAN<>"" and WCDTSTA=1  : ### x3-44031
      Filter [SOQ] Where SOQSTA<>3 and SOHNUM=[F:TABX]SOHNUM
      For [SOQ]SOQ0
        Read [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
        If !fstat and ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))>0

          DAT=max([SOQ]SHIDAT, date$)
          For Y=0 To 49
            If CFODAT(Y)=[0/0/0]
              CFODAT(Y)=DAT
              AMOUNT(Y)=ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))
              Break
            Endif
            If CFODAT(Y)=DAT
              If [SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY)>0
                AMOUNT(Y)+=ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))
              Endif
              Break
            Endif
          Next
        Endif
      Next
      Filter [SOQ]
      DOC_AMOUNT=sum(AMOUNT())
      If DOC_AMOUNT<>0
        ### Moving the date to the first invoice day
        Gosub CALC_INVDAY

        ### Repartition of the total foot amount
        Filter [SVF] Where VCRNUM=[F:TABX]SOHNUM and VCRTYP=20

        For [SVF]SVF0
          If [F:TABX]DLVSTA=1
            TOTAL_FOOT+=(sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))
          Else
            If [F:SVF]AMTCOD=1
              TOTAL_FOOT+=ar2((sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))*(DOC_AMOUNT/[F:TABX]ORDATI))
            Else
              Read [SFI]SFI0=[F:SVF]DTA
              If !fstat
                Raz IND
                If [TABX]SOHCAT=1: IND=find(10, [F:SFI]ORIVCR): Endif
                If [TABX]SOHCAT=3: IND=find(12, [F:SFI]ORIVCR): Endif
                 If IND and [F:SFI]BRDRUL(IND-1)>4  and [F:SFI]BRDRUL(IND-1)<9
                    TOTAL_FOOT+=(sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))
                 Endif
                 If IND and [F:SFI]BRDRUL(IND-1)>8
                    TOTAL_FOOT+=ar2((sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))*(DOC_AMOUNT/[F:TABX]ORDATI))
                 Endif
              Endif
            Endif
          Endif


        Next
        Filter [SVF]




        If TOTAL_FOOT <> 0
          For Y=0 To 49
            If AMOUNT(Y)=0: Break: Endif
            AMOUNT(Y)+=ar2(AMOUNT(Y)*TOTAL_FOOT/DOC_AMOUNT)
          Next
          AMOUNT(0)+=(DOC_AMOUNT+TOTAL_FOOT)-sum(AMOUNT())
        Endif
        DOC_AMOUNT=sum(AMOUNT())

      ### Preapyments ####################################
      Filter [DUD] Where TYP="*SO" and NUM=[F:TABX]SOHNUM
      For [DUD]DUD0
        PREPAYMENT +=[F:DUD]AMTCUR
      Next
      Filter [DUD]
      If PREPAYMENT<>0
      ### Repartition of the prepayment
        For Y=0 To 49
          If AMOUNT(Y)=0: Break: Endif
          AMOUNT(Y)-=ar2(AMOUNT(Y)*PREPAYMENT/DOC_AMOUNT)
        Next
        AMOUNT(0)+=(DOC_AMOUNT-PREPAYMENT)-sum(AMOUNT())
        DOC_AMOUNT-=PREPAYMENT
      Endif


        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC

          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(8,477,1)+":"-[F:TABX]SOHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(2,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return
###########################################################################################
####################### Treatment of Open Sale Orders #####################################
###########################################################################################
$TRT_SOR

Call ECR_TRACE(mess(1,13,1)-mess(5,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(5)<>2
  Call ECR_TRACE(mess(5,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY,WBPR
Raz TOTAL_AMOUNT

WCFOTYP=7 ## Open sale Orders

If !clalev([SOH]): Local File SORDER [SOH]: Endif
If !clalev([SOQ]): Local File SORDERQ [SOQ]: Endif
If !clalev([SOP]): Local File SORDERP [SOP]: Endif
If !clalev([SVF]): Local File SVCRFOOT[SVF]: Endif
If !clalev([SFI]): Local File SFOOTINV[SFI]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ## Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ### Definition of the criteres

Link [SOH] With [FCY]FCY0=SALFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]SOH1
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL #### Parameter CFOBANDEF
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2  and [TABX]ORDDAT>=date$-HORPAST ## If the category is setup for this company / site and the document is not before date$-HORPAST
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT, TOTAL_FOOT
    If WBPR<>[F:TABX]BPCPYR
      WBPR=[F:TABX]BPCPYR
      Call LEC_BPC([F:TABX]BPCPYR) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPCPYR,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPCPYR,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPCPYR,[F:TABX]CPY,WCOA,1,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      Filter [SOQ] Where SOQSTA<>3 and SOHNUM=[F:TABX]SOHNUM
      For [SOQ]SOQ0
        Filter [SOP] Where SOHNUM=[SOQ]SOHNUM and SOPLIN=[SOQ]SOPLIN and STRDAT<=[SOQ]DEMDLVDAT and ENDDAT>=[SOQ]DEMDLVDAT
        Read [SOP]SOP0 Last
        If !fstat and ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))>0

          DAT=max([SOQ]DEMDLVDAT, date$)
          For Y=0 To 49
            If CFODAT(Y)=[0/0/0]
              CFODAT(Y)=DAT
              AMOUNT(Y)=ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))
              Break
            Endif
            If CFODAT(Y)=DAT
              AMOUNT(Y)+=ar2([SOP]NETPRIATI*([SOQ]QTY-[SOQ]DLVQTY))
              Break
            Endif
          Next
        Endif
        Filter [SOP]
      Next
      Filter [SOQ]
      DOC_AMOUNT=sum(AMOUNT())
      If AMOUNT(0)<>0
        ### Moving the date to the first invoice day
        Gosub CALC_INVDAY



        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          AMOUNTLOC=DOC_AMOUNT
          ##### Currency
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(7,477,1)+":"-[F:TABX]SOHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(5,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

####################################################################################
####################### Treatment of Deliveries ####################################
####################################################################################
$TRT_SDH

Call ECR_TRACE(mess(1,13,1)-mess(9,3636,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(5)<>2
  Call ECR_TRACE(mess(5,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=9 ## Deliveries

If !clalev([SDH]): Local File SDELIVERY: Endif
If !clalev([SDD]): Local File SDELIVERYD: Endif
If !clalev([SFI]): Local File SFOOTINV[SFI]: Endif
If !clalev([SVF]): Local File SVCRFOOT[SVF]: Endif

Local Integer IND

Call DEBTRANS From GLOCK
Gosub DEL_CFO ### Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ### Definition of the criteres

Link [SDH] With [FCY]FCY0=SALFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]SDH1
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]SHIDAT>=date$-HORPAST ## if the category is setup for this comapny / site and the document is not before date$_HORPAST
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT,  TOTAL_FOOT
    If WBPR<>[F:TABX]BPCPYR
      WBPR=[F:TABX]BPCPYR
      Call LEC_BPC([F:TABX]BPCPYR) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]BPCPYR,[F:TABX]CPY)
        Call READ_BAN([F:TABX]BPCPYR,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
        Call READ_SAC([F:TABX]BPCPYR,[F:TABX]CPY,WCOA,1,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      DAT=max([F:TABX]SHIDAT, date$)
      CFODAT(0)=DAT
      If [F:TABX]RTNSTA=1
         AMOUNT(0)=[F:TABX]DLVINVATI
      Endif
      If [F:TABX]RTNSTA=2

        Filter [SDD] Where SDHNUM=[F:TABX]SDHNUM
        For [SDD]SDD0
           AMOUNT(0)+=ar2(([F:SDD]QTY-[F:SDD]RTNQTY)*[F:SDD]NETPRIATI)
        Next
        DOC_AMOUNT=AMOUNT(0)
        Filter [SDD]
        ### Repartition of the total foot amount

        Filter [SVF] Where VCRNUM=[F:TABX]SDHNUM and VCRTYP=2
        For [SVF]SVF0
            If [F:SVF]AMTCOD=1
              TOTAL_FOOT+=ar2((sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))*(DOC_AMOUNT/[F:TABX]DLVINVATI))
            Else
              TOTAL_FOOT+=(sum([F:SVF]DTANET())+sum([F:SVF]DTAVATAMT()))
           Endif
        Next
        Filter [SVF]
        AMOUNT(0)+=TOTAL_FOOT

      Endif

      DOC_AMOUNT=AMOUNT(0)



      If DOC_AMOUNT<>0
        ### Moving the date to the first invoice day
        Gosub CALC_INVDAY

        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(4,477,1)+":"-[F:TABX]SDHNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(9,3636,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

###########################################################################################
####################### Treatment of Service Contract ####################################
##########################################################################################

$TRT_CON
Call ECR_TRACE(mess(1,13,1)-mess(25,2088,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(12)<>2
  Call ECR_TRACE(mess(12,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=8  ### Service contract

If !clalev([CON]): Local File CONTSERV [CON]: Endif
If !clalev([ITM]): Local File ITMMASTER [ITM]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ## Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES ## Definition of the criteres

Link [CON] With [FCY]FCY0=SALFCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)
For [TABX]CON4 Where NEXINVAMT<>0
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2  ## if the category is setup for this comapny / site
    Raz DAT, AMOUNT, CFODAT, DOC_AMOUNT
    If WBPR<>[F:TABX]CONBPCPYR
      WBPR=[F:TABX]CONBPCPYR
      Call LEC_BPC([F:TABX]CONBPCPYR) From CPTLEC
      If !fstat
        WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]CONBPCPYR,[F:TABX]CPY)
        Call READ_BAN([F:TABX]CONBPCPYR,[F:TABX]CPY,WFCY,1,BANDEF,WBAN)
        Call READ_SAC([F:TABX]CONBPCPYR,[F:TABX]CPY,WCOA,1,WSAC)
      Endif
    Endif
    If WBPREXD and WBAN<>""
      DAT=max([TABX]NEXINVDAT, date$)
      CFODAT(0)=DAT
      AMOUNT(0)=ar2([F:TABX]NEXINVAMT)

      Read [ITM]ITM0=[F:CON]ITMREF
      If !fstat
         Call ALITAXEV([F:TABX]CONVACBPR,[F:ITM]VACITM,VAT) From TRTX3
         Call CALTAXE([F:TABX]CPY,DAT,[F:TABX]CONVACBPR,[F:TABX]CUR,3,VAT,1,AMOUNT(0),MONTANTTAX,MONTANTDED,TYPREG,STAT) From SUBTVT
         AMOUNT(0)+=MONTANTTAX
      Endif
      DOC_AMOUNT+=AMOUNT(0)
      If DOC_AMOUNT<>0
        ###################
        Gosub CALC_INVDAY

        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC
          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(19,477,1)+":"-[F:TABX]CONNUM)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]CUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]CUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif
    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(25,2088,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return

########################################################################################
####################### Treatment of Lease Contract #####################################
#########################################################################################
$TRT_LEA

Call ECR_TRACE(mess(1,13,1)-mess(22,602,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If GMODU(14)<>2
  Call ECR_TRACE(mess(14,14,1)+":"-mess(63,199,1),0) From GESECRAN
  Return
Endif
Raz HORPAST, SNS, FLG, NUMDOC, TDAYS, WFCY, WBPR
Raz TOTAL_AMOUNT

WCFOTYP=10  ## Lease contracts

If !clalev([LEA]): Local File LEASE [LEA]: Endif
If !clalev([LBB]): Local File LEABILBOOK [LBB]: Endif

Call DEBTRANS From GLOCK
Gosub DEL_CFO ## Deletion of the records of this company / site
If STAT: Return: Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Return
Endif

Gosub TRT_CRITERES

Link [LEA] With [FCY]FCY0=FCY As [TABX] Where evalue(CRITSOC) & evalue(CRITDAT) & evalue(CRITSUP)

For [TABX]LEA0
  If WFCY<>[F:FCY]FINRSPFCY
    WFCY=[F:FCY]FINRSPFCY
    Call PARAML([F:FCY]FINRSPFCY ,"CFOBANDEF", BANDEF) From ADOVAL
    Gosub CONTR_CFOTYP
  Endif
  If FLG=2 and [F:TABX]ENDLEADAT>=date$-HORPAST and ([F:TABX]TRMLEADAT>=date$-HORPAST | [F:TABX]TRMLEADAT=[0/0/0])
    Raz DAT, AMOUNT, CFODAT,DOC_AMOUNT
    If WBPR<>[F:TABX]LES
      WBPR=[F:TABX]LES
      Call LEC_BPS([F:TABX]LES) From CPTLEC
        If !fstat
         If [F:BPS]BPRPAY<>""
           WBPREXD = func FUNTRTCFO.CONT_EXCL([F:BPS]BPRPAY, [F:TABX]CPY )
           Call READ_BAN([F:BPS]BPRPAY,[M:TCFO]CPY,WFCY,2,BANDEF,WBAN)
           Call READ_SAC([F:BPS]BPRPAY,[M:TCFO]CPY,WCOA,2,WSAC)
         Else
           WBPREXD = func FUNTRTCFO.CONT_EXCL([F:TABX]LES, [F:TABX]CPY )
           Call READ_BAN([F:TABX]LES,[M:TCFO]CPY,WFCY,2,BANDEF,WBAN)
           Call READ_SAC([F:TABX]LES,[M:TCFO]CPY,WCOA,2,WSAC)
         Endif
        Endif
    Endif
    If WBPREXD and WBAN<>""

      Filter [LBB] Where LEAREF=[F:TABX]LEAREF and PAYDAT=[0/0/0] and ENDPERDAT<=[M:TCFO]DAT and ENDPERDAT>=date$-HORPAST
      For [LBB]LBB0

        DAT=max([LBB]ENDPERDAT, date$)
        For Y=0 To 49
          If CFODAT(Y)=[0/0/0]
            CFODAT(Y)=DAT
            AMOUNT(Y)=[F:LBB]RNTAMT
            DOC_AMOUNT+=AMOUNT(Y)
            Break
          Endif
          If CFODAT(Y)=DAT
            AMOUNT(Y)+=[F:LBB]RNTAMT
            DOC_AMOUNT+=AMOUNT(Y)
            Break
          Endif
        Next
      Next
      Filter [LBB]
      DOC_AMOUNT=sum(AMOUNT())
      If DOC_AMOUNT<>0
        ### Creation of CFO register
        Gosub CRE_CFOMVT
        If STAT=0
          NUMDOC+=1
          ##### Currency
          AMOUNTLOC=DOC_AMOUNT
          If [F:TABX]CUR<>[F:CPY]ACCCUR
            Call CONVERT([F:TABX]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[M:TCFO]TYPRAT,date$,AMOUNTLOC,AMOUNTLOC,STAT) From TRTDEV
          Endif
          TOTAL_AMOUNT+=AMOUNTLOC

          ### Trace
          If [M:TCFO]DETTRC=2
            TEXTE=format$("K:50X",mess(22,602,1)+":"-[F:TABX]LEAREF)+format$(GFMD,CFODAT(0))-format$("NZ0:10.2#",AMOUNT(0))-[F:TABX]LEACUR
            Call ECR_TRACE(TEXTE,0) From GESECRAN
            For Y=1 To 40
              If CFODAT(Y)=[0/0/0]: Break: Endif
              TEXTE=format$("K:50X",">")+format$(GFMD,CFODAT(Y))-format$("NZ0:10.2#",AMOUNT(Y))-[F:TABX]LEACUR
              Call ECR_TRACE(TEXTE,0) From GESECRAN
            Next
          Endif
        Endif
      Endif

    Endif
  Endif
Next
Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(22,602,1)-"/"-mess(24,173,1)-format$("NZ:10.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN
Return
##########################################################################################
###################### OPEN ITEMS ########################################################
##########################################################################################
$TRT_DUD
Call ECR_TRACE(mess(1,13,1)-mess(39,117,1),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Raz TOTAL_AMOUNT, TOTAL_AMOUNTR, NUMDOC, WFCY, WBPR
Local Integer STAT, WEXC

If !clalev([HAE]):  Local File GACCENTRY [HAE]: Endif
If !clalev([DAE]):  Local File GACCENTRYD[DAE]: Endif
If !clalev([DAEX]): Local File GACCENTRYD[DAEX]: Endif
If !clalev([PAN]):  Local File PAYACCNUM [PAN]: Endif
If !clalev([PYH]):  Local File PAYMENTH  [PYH]: Endif
If !clalev([BAN]):  Local File BANK      [BAN] : Endif
If !clalev([DUD]):  Local File GACCDUDATE[DUD]: Endif
If !clalev([GTE]):  Local File GTYPACCENT[GTE]: Endif

Call LEC_CPY([M:TCFO]CPY) From CPTLEC
$TRT_DUD_ANNUL
GOK=1
Trbegin [CFODD]
Delete [CFODD] Where left$(TYP,3)<>"*CM" and CPY=[M:TCFO]CPY and ([M:TCFO]FCY="" or FCY=[M:TCFO]FCY)
If fstat=1
 GLOCK = "CFODUDDATE"-"" : Goto ROLL_TR_ANNUL
Elsif fstat>5
 Call RSTA("CFODD","") From GLOCK : Goto AB_TR_ANNUL
Endif

If [M:TCFO]ERACFO=2
  Call ECR_TRACE(mess(20,133,1),0) From GESECRAN
  Call ECR_TRACE(string$(80,"="),0) From GESECRAN
  Commit : Return
Endif

Filter [DUD] Where CPY=[M:TCFO]CPY and ([M:TCFO]FCY="" or FCY=[M:TCFO]FCY) and FLGCLE<>2 and DUDDAT<=[M:TCFO]DAT
For [DUD]DUD5

  Call LEC_GTE_LEG([F:CPY]LEG,[F:DUD]TYP) From CPTLEC
  #If [F:GTE]DUDDATFLG=2                           # X3-72666 Prepayments were excluded
  If [F:GTE]DUDDATFLG=2 or left$([F:DUD]TYP,1)="*" # X3-72666 Prepayments were excluded
    If WBPR<>[F:DUD]BPRPAY
      WEXC = func FUNTRTCFO.CONT_EXCL([F:DUD]BPRPAY, [F:DUD]CPY )
      WBPR = [F:DUD]BPRPAY
    Endif
    If WEXC
      Raz [F:CFODD]
      [F:CFODD]=[F:DUD]
      [F:CFODD]CFODAT=[F:DUD]DUDDAT
      Raz [F:CFODD]CREDATTIM,[F:CFODD]UPDDATTIM,[F:CFODD]CREUSR,[F:CFODD]UPDUSR
      ###### Bank management #############################################################
      If WFCY<>[F:DUD]FCY
        WFCY=[F:DUD]FCY
        Call PARAML([F:DUD]FCY,"CFOBANDEF", BANDEF) From ADOVAL
      Endif
      If [F:DUD]TYPDUD<>3  ## The open item is not a PAYMENTH
        Call READ_BAN([F:DUD]BPRPAY,[F:DUD]CPY,[F:DUD]FCY,[F:DUD]BPRTYP,BANDEF,[F:CFODD]CFOBAN)
      Else  ## The open item is a PAYMENTH. We see if the paymenth has an asigned bank
         Raz [PYH]
         Read [DAE]DAE2=[F:DUD]ACCNUM
         If !fstat
           If left$([F:DAE]REFINTLIN,3)="PYH" and right$([F:DAE]REFINTLIN,5)<>""
              Read [PYH]PYH0=right$([F:DAE]REFINTLIN,5)
              If !fstat and [F:PYH]BAN<>""
                [F:CFODD]CFOBAN=[F:PYH]BAN
              Endif
           Endif
         Endif
         If [F:CFODD]CFOBAN="":
            [F:CFODD]CFOBAN=BANDEF
         Endif
      Endif



      STAT=0
      If [F:CFODD]CFOBAN=""
        STAT=1
      Else
        If [F:CFODD]CFOBAN<>BANDEF
          Call LEC_BAN([F:CFODD]CFOBAN) From CPTLEC
          If !fstat and [F:BAN]CFOEXD=2
            STAT=1
          Endif
        Endif
      Endif
      ####################################################################################
      If STAT=0
        NUMDOC+=1
        If [F:DUD]SNS=1
           TOTAL_AMOUNT+=[F:DUD]AMTLOC-[F:DUD]PAYLOC
        Else
           TOTAL_AMOUNTR+=[F:DUD]AMTLOC-[F:DUD]PAYLOC
        Endif

        Write [CFODD]
        If fstat
          GOK = 0
          Call FSTA("CFODD") From GLOCK
          Break
        Endif
      Endif
    Endif
  Endif
Next

Filter [DUD]
If GOK<1: Goto AB_DUDCFODD: Endif
Commit

Call ECR_TRACE(mess(3,947,1)-num$(NUMDOC)-mess(39,117,1)-"/"-mess(24,173,1)-mess(2,632,1)+":"-format$("NZ:15.2#",TOTAL_AMOUNT)-[F:CPY]ACCCUR
&                            -mess(1,632,1)+":"-format$("NZ:15.2#",TOTAL_AMOUNTR)-[F:CPY]ACCCUR,0) From GESECRAN
Call ECR_TRACE(string$(80,"="),0) From GESECRAN

Return


$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRT_DUD_ANNUL : Endif
Return

##########################################################################################
## Recalculation of periodic documents
$TRT_PER
Local Integer YY
GOK=1
Trbegin [CFOMM]
Filter [CFOMM] Where  RCR=2 and CFOSTA<>4 and CFOSTA<>2 and CPY=[M:TCFO]CPY and ([M:TCFO]FCY="" or FCY=[M:TCFO]FCY)
For [CFOMM]CFOMM0
  Delete [CFODD] Where TYP="*CM"+format$("N0:2#",[F:CFOMM]CFOTYP) and NUM=[F:CFOMM]NUM and LIG=[F:CFOMM]CFOLIN
  If fstat
     GOK=0
     Gosub AB_DELCFODD
     Break
  Endif
  [M:CFO0]=[F:CFOMM]
  [M:CFO1]=[F:CFOMM]
  Raz [M:CFO2]
  Raz [F:CFOMM]DAT, [F:CFOMM]PAMDET, [F:CFOMM]AMTCUR
  Gosub CALC_OPEN_ITEM From SUBCFO
  For YY=0 To [M:CFO2]NBLIG-1
    [F:CFOMM]DAT(YY)    =[M:CFO2]DAT(YY)
    [F:CFOMM]PAMDET(YY)   =[M:CFO2]PAMDET(YY)
    [F:CFOMM]AMTCUR(YY) =[M:CFO2]AMTCUR(YY)
  Next YY

  Rewrite [F:CFOMM]
  If fstat
    GOK=0
    Gosub AB_REWCFOMM
    Break
  Endif
  STAT=0
  Gosub CRE_CFODUD From SUBCFO
  If STAT
    GOK=0
    Gosub AB_CRECFODD
    Break
  Endif
Next
If GOK=1
  Commit
Endif
Return

$AB_REWCFOMM
Rollback
Call ECR_TRACE(mess(195,187,1)+"("+num$([F:CFOMM]CFOTYP)+"/"+NUM=[F:CFOMM]NUM+")",1) From GESECRAN
Return

##########################################################################################
## Treatment of CFOMANMVT that are obsolete
$TRT_OBS
GOK=1
Local Integer I
Trbegin [CFOMM]
Filter [CFOMM] Where (CFOTYP<20 and CFOSTA=3) or (CFOTYP>19 and CFOSTA<>4) and CPY=[M:TCFO]CPY and ([M:TCFO]FCY="" or FCY=[M:TCFO]FCY)
For [CFOMM]CFOMM0
  I = find(0,[F:CFOMM]AMTCUR())
  If I and I>1
    If [F:CFOMM]DAT(I-2)<date$
      Raz [F:CFOMM]DAT, [F:CFOMM]AMTCUR, [F:CFOMM]PAMDET
      [F:CFOMM]CFOSTA=4
      Rewrite [CFOMM]
      If fstat
        GOK=0
        Gosub AB_OBSCFOMM
        Break
      Endif
      Delete [CFODD] Where TYP="*CM"+format$("N0:2#",[F:CFOMM]CFOTYP) and NUM=[F:CFOMM]NUM and LIG=[F:CFOMM]CFOLIN
      If fstat
        GOK=0
        Gosub AB_OBSCFODD
        Break
      Endif
    Endif
  Endif
Next
Filter [CFOMM]
If GOK=1
   Commit
Endif
Return
########################################################################################################
$AB_OBSCFOMM
Rollback
Call ECR_TRACE(mess(196,187,1)+"("+num$([F:CFOMM]CFOTYP)+"/"+NUM=[F:CFOMM]NUM+")",1) From GESECRAN
Return
#########################################################################################################
$AB_OBSCFODD
Rollback
Call ECR_TRACE(mess(197,187,1)+"("+num$([F:CFOMM]CFOTYP)+"/"+NUM=[F:CFOMM]NUM+")",1) From GESECRAN
Return
#########################################################################################################
$AB_DUDCFODD
Rollback
Call ECR_TRACE(mess(194,187,1),1) From GESECRAN
Return
##########################################################################################
$CONTR_CFOTYP



FLG=0
I = find(num$(WCFOTYP)+"~"+WFCY,WCFOTYPFCY(0..dim(WCFOTYPFCY)-1))
If !I
  I = find(num$(WCFOTYP)+"~",WCFOTYPFCY(0..dim(WCFOTYPFCY)-1))
Endif
If I
 Raz HORPAST,SNS,FLG,TDAYS, INCRE
 HORPAST=WHORPAST(I-1)
 SNS=WSNS(I-1)
 FLG=WFLG(I-1)
 TDAYS(0)=WTDAYS1(I-1)
 TDAYS(1)=WTDAYS2(I-1)
 TDAYS(2)=WTDAYS3(I-1)
 INCRE=WINCRE(I-1)
Endif
If !I
  I=find("",WCFOTYPFCY(0..dim(WCFOTYPFCY)-1))
  WCFOTYPFCY(I-1)=num$(WCFOTYP)+"~"+WFCY
  WFLG(I-1)=0: FLG=0
  WLOG(I-1)=0
Endif
If (FLG<>2 or I=0) and WLOG(I-1)=0
  Call ECR_TRACE(mess(189,187,1)-WFCY,1) From GESECRAN
  WLOG(I-1)=2
Endif
Return
##########################################################################################
$TRT_CRITERES
CRITSOC="CPY='"+[M:TCFO]CPY+"'"
If [M:TCFO]FCY<>"": CRITSOC+=" & [F:FCY]FINRSPFCY ='"+[M:TCFO]FCY+"'": Endif
Case WCFOTYP
  When 1 :CRITDAT="PRQDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="APPFLG>2 & ORDFLG<>2 & CLEFLG<>2"
  When 2 :CRITDAT="ORDDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="POHTYP=2 & APPFLG>2 & RCPFLG<>3 & INVFLG<>3 & CLEFLG<>2"
  When 3 :CRITDAT="ORDDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="POHTYP=1 & APPFLG>2 & RCPFLG<>3 & INVFLG<>3 & CLEFLG<>2"
  When 4 :CRITDAT="RCPDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="INVFLG=1"
  When 5 :CRITDAT="QUODAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="QUOSTA<>3 & APPFLG>2 & PBYPRC>="+num$(val(CFOPBYRAT))
  When 6 :CRITDAT="ORDDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="ORDSTA<>2 & (SOHCAT=1 | SOHCAT=3)  & CDTSTA=1 & HLDSTA<>2 & APPFLG>2"
  When 7 :CRITDAT="ORDDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="ORDSTA<>2 & SOHCAT=4 & APPFLG>2 & CDTSTA=1 & VLYDATCON>=["+format$(GFMD,date$)+"]"
  When 8 :CRITDAT="NEXINVDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="1=1"
  When 9 :CRITDAT="SHIDAT<=["+format$(GFMD,[M:TCFO]DAT)+"]"
          CRITSUP="SDHCAT=1 & RTNSTA<>3 & INVFLG<>2"
  When 10:CRITDAT="1=1"
          CRITSUP="LEASTA=2"
Endcase

Return
##########################################################################################
Funprog CONT_EXCL(BPR, CPY)
Value Char BPR
Value Char CPY


If !clalev([BPR]): Local File BPARTNER [BPR]: Endif

If GMULACV=1
  # Issue 56229 - 2017-11-15 by MWA
  If func ASYRFNC.ACTIV("MUL") >0
    If !clalev([BPE]): Local File BPEXCEPT [BPE]: Endif
    Read [BPE]BPE0=BPR;CPY
    If !fstat
      If [F:BPE]CFOEXDCPY=2
        End 0
      Endif
    Endif
  Endif
Endif

Read [BPR]BPR0=BPR
If !fstat and [F:BPR]CFOEXD=2
  End 0
Endif

End 1

###########################################################################################
$DEL_CFO
STAT=0
Trbegin [CFOMM]
Filter [CFOMM] Where CPY=[M:TCFO]CPY and ([M:TCFO]FCY="" | FCY=[M:TCFO]FCY) and CFOTYP=WCFOTYP and CFOSTA<3
For [CFOMM]CFOMM0
  Delete [CFODD] Where TYP="*CM"+format$("N0:2#",[F:CFOMM]CFOTYP) and NUM=[F:CFOMM]NUM and LIG=[F:CFOMM]CFOLIN
  If fstat
    GOK = -1
    GLOCK = "$CFODUDDATE"
    Gosub AB_DELCFODD
    Break
  Endif
  Delete [CFOMM] Curr
  If fstat
    GOK = -1
    GLOCK = "$CFOMANMVT"
    Gosub AB_DELCFOMM
    Break
  Endif
Next

If GOK=1
   Commit
Endif
Filter [CFOMM]
Return
###########################################################################################
$AB_DELCFODD
Rollback : STAT=1
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(197,187,1)+"("+num$(WCFOTYP)+")",1) From GESECRAN
  Return
Else
  Goto DEL_CFO
Endif
Return
############################################################################################
$AB_DELCFOMM
Rollback : STAT=1
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(198,187,1)+"("+num$(WCFOTYP)+")",1) From GESECRAN
  Return
Else
  Goto DEL_CFO
Endif
Return
###########################################################################################
Subprog READ_LEGLEDCOA(CPY,LEG,LED,COA)
Value Char CPY
Variable Char LEG
Variable Char LED
Variable Char COA

Call LEC_CPY(CPY) From CPTLEC
LEG=[F:CPY]LEG
Call LEC_GCM([F:CPY]ACM) From CPTLEC
LED=[F:GCM]LED(0)
Call LEC_LED([F:GCM]LED(0)) From CPTLEC
COA=[F:LED]COA
End
################################################################################################
Subprog READ_SAC(BPR,CPY,COA,TYP,SAC)
Value Char BPR
Value Char CPY
Value Char COA
Value Decimal TYP
Variable Char SAC

If !clalev([CAC]): Local File GACCCODE   [CAC]: Endif
If !clalev([BPS]): Local File BPSUPPLIER [BPS]: Endif
If !clalev([BPC]): Local File BPCUSTOMER [BPC]: Endif
If !clalev([GAC]): Local File GACCOUNT   [GAC]: Endif


Raz [F:CAC], [F:GAC]

If GMULACV=1
  # Issue 56229 - 2017-11-15 by MWA
  If func ASYRFNC.ACTIV("MUL") >0
    If !clalev([BPE]): Local File BPEXCEPT   [BPE]: Endif
    Read [BPE]BPE0=BPR;CPY
    If !fstat
      Case TYP
        When 2: If [F:BPE]VACBPS<>"": Read [CAC]CAC0=3;[F:BPE]VACBPS;COA : Endif
        When 1: If [F:BPE]VACBPC<>"": Read [CAC]CAC0=2;[F:BPE]VACBPC;COA : Endif
      Endcase
    Endif
  Endif
Endif

If [F:CAC]ACCCOD=""
  Case TYP
    When 1: Read [BPS]BPS0=BPR
            If !fstat
              Read [CAC]CAC0=3;[F:BPS]ACCCOD;COA
            Endif
    When 2: Read [BPC]BPC0=BPR
            If !fstat
              Read [CAC]CAC0=2;[F:BPC]ACCCOD;COA
            Endif
  Endcase
Endif
If [F:CAC]ACCCOD<>""
  Call LEC_GAC([F:CAC]ACC(0),COA) From CPTLEC
  SAC=[F:GAC]ACCSHO
Endif
End
#######################################################################################
Subprog READ_BAN(BPR,CPY,FCY,TYP,BANDEF, BAN)
Value Char BPR
Value Char CPY
Value Char FCY
Value Decimal TYP
Value Char BANDEF
Variable Char BAN
If !clalev([BPS]): Local File BPSUPPLIER [BPS]: Endif
If !clalev([BPC]): Local File BPCUSTOMER [BPC]: Endif
If !clalev([BAN]): Local File BANK [BAN]: Endif

Raz [F:BPS], [F:BPC]
Case TYP
  When 2: Read [BPS]BPS0=BPR: BAN=[F:BPS]PAYBAN
  When 1  Read [BPC]BPC0=BPR: BAN=[F:BPC]PAYBAN
Endcase

Call LEC_BAN(BAN) From CPTLEC
If fstat: BAN="": Endif
If [F:BAN]CPY<>CPY or ([F:BAN]FCY <> "" and [F:BAN]FCY<>FCY)
  BAN=""
Endif

If BAN="": BAN=BANDEF: Endif
If BAN<>BANDEF
  Call LEC_BAN(BAN) From CPTLEC
  If !fstat
    If [F:BAN]CFOEXD=2
      BAN=""
    Else
      If [F:BAN]FCY<>"" and [F:BAN]FCY<>FCY
        BAN=BANDEF
      Endif
      If [F:BAN]CPY<>[M:TCFO]CPY
        BAN=BANDEF
      Endif
    Endif
  Else
    BAN=BANDEF
  Endif
Endif
End
#########################################################################################
### Moving the date to the first invoice day
$CALC_INVDAY
Local Integer QUANT,MOIS,DYEAR, WNBDAYFEB, QT
If TDAYS(0)=0: Return: Endif
For Y=0 To 49
  If CFODAT(Y)=[0/0/0]: Break: Endif
  QUANT=day(CFODAT(Y))
  MOIS =month(CFODAT(Y))
  DYEAR = year(CFODAT(Y))
  If ((int(DYEAR/4)=DYEAR/4) and (int(DYEAR/100)<>DYEAR/100))
&   or (int(DYEAR/400)=DYEAR/400) Then
    WNBDAYFEB = 29
  Else
    WNBDAYFEB = 28
  Endif
  If MOIS <> 2
    If    QUANT<=TDAYS(0) QT=TDAYS(0) : Gosub QUANTIEME
    Elsif QUANT<=TDAYS(1) QT=TDAYS(1) : Gosub QUANTIEME
    Elsif QUANT<=TDAYS(2) QT=TDAYS(2) : Gosub QUANTIEME
    Else  QT=TDAYS(0)(0) : Gosub QUANTIEME
    Endif
  Else
    If (QUANT<=TDAYS(0) & TDAYS(0)<=WNBDAYFEB)|(TDAYS(0)=99)
      QT=TDAYS(0) : Gosub QUANTIEME
    Elsif (QUANT<=TDAYS(1) & TDAYS(1)<=WNBDAYFEB)|(TDAYS(1)=99)
      QT=TDAYS(1) : Gosub QUANTIEME
    Elsif (QUANT<=TDAYS(2) & TDAYS(2)<=WNBDAYFEB)|(TDAYS(2)=99)
       QT=TDAYS(2) : Gosub QUANTIEME
    Else  QT=TDAYS(0) : Gosub QUANTIEME
    Endif
  Endif
Next
Return
#############################################################################
$QUANTIEME
If QT=99
  CFODAT(Y) = eomonth(CFODAT(Y))
Elsif day(CFODAT(Y))<=QT
  If QT>28 & month(CFODAT(Y))=2
    CFODAT(Y)=gdat$(QT,month(CFODAT(Y))+1,year(CFODAT(Y)))
  Else
    CFODAT(Y)=gdat$(QT,month(CFODAT(Y)),year(CFODAT(Y)))
  Endif
Else
  If QT>28 & month(CFODAT(Y))=1
    DAT=gdat$(QT,month(CFODAT(Y))+2,year(CFODAT(Y)))
  Else
    DAT=gdat$(QT,month(CFODAT(Y))+1,year(CFODAT(Y)))
  Endif
Endif
Return

################################################################################
### Creation of CFO register
$CRE_CFOMVT
GOK = 1
Trbegin [CFOMM]
For Y=0 To 49
  If CFODAT(Y)=[0/0/0]: Break : Endif
  Raz [F:CFOMM]
  Raz [M:CFO0],[M:CFO1],[M:CFO2]
  [F:CFOMM]CPY=[F:TABX]CPY
  [F:CFOMM]FCY=[F:FCY]FINRSPFCY
  [F:CFOMM]CFOSTA=1
  [F:CFOMM]CFOLIN=Y+1
  [F:CFOMM]CFOTYP=WCFOTYP
  [F:CFOMM]RCR=1
  [F:CFOMM]AMTATI=AMOUNT(Y)
  [F:CFOMM]TYPRAT=[M:TCFO]TYPRAT
  [F:CFOMM]ACCDAT=CFODAT(Y)
  [F:CFOMM]SAC=WSAC
  [F:CFOMM]BAN=WBAN
  [F:CFOMM]LEG=WLEG
  [F:CFOMM]LED=WLED
  [F:CFOMM]COA=WCOA
  Case WCFOTYP
    When 1: [F:CFOMM]NUM=[F:TABX]PSHNUM
            [F:CFOMM]DOCDAT=[F:TABX]PRQDAT
            [F:CFOMM]SNS=1
            [F:CFOMM]DES=mess(31,477,1)-[F:TABX]PSHNUM
            [F:CFOMM]BPRNUM=TBPS(Y)
            [F:CFOMM]BAN=TBAN(Y)
            Read [BPS]BPS0=TBPS(Y)
            # Issue 56229 - 2017-11-15 by MWA
            If func ASYRFNC.ACTIV("MUL") >0
              Read [BPE]BPE0=TBPS(Y);[F:CFOMM]CPY
              If !fstat and [F:BPE]PTEBPS<>""
                 [F:CFOMM]PTE=[F:BPE]PTEBPS
              Else
                 [F:CFOMM]PTE=[F:BPS]PTE
              Endif
            Else
              [F:CFOMM]PTE=[F:BPS]PTE : # Issue 56229 - 2017-11-15 by MWA
            Endif
            [F:CFOMM]CUR=TCUR(Y)
    When 2,3: [F:CFOMM]NUM=[F:TABX]POHNUM
            [F:CFOMM]DOCDAT=[F:TABX]ORDDAT
            [F:CFOMM]SNS=1
            [F:CFOMM]DES=mess(29,477,1)-[F:TABX]POHNUM
            [F:CFOMM]BPRNUM=[F:TABX]BPRPAY
            [F:CFOMM]PTE=[F:TABX]PTE
            [F:CFOMM]CUR=[F:TABX]CUR
    When 4: [F:CFOMM]NUM=[F:TABX]PTHNUM
            [F:CFOMM]DOCDAT=[F:TABX]RCPDAT
            [F:CFOMM]SNS=1
            [F:CFOMM]DES=mess(27,477,1)-[F:TABX]PTHNUM
            [F:CFOMM]BPRNUM=[F:TABX]BPRPAY
            Read [BPS]BPS0=[F:TABX]BPRPAY
            # Issue 56229 - 2017-11-15 by MWA
            If func ASYRFNC.ACTIV("MUL") >0
              Read [BPE]BPE0=[F:TABX]BPRPAY;[F:CFOMM]CPY
              If !fstat and [F:BPE]PTEBPS<>""
                 [F:CFOMM]PTE=[F:BPE]PTEBPS
              Else
                 [F:CFOMM]PTE=[F:BPS]PTE
              Endif
            Else
              [F:CFOMM]PTE=[F:BPS]PTE : # Issue 56229 - 2017-11-15 by MWA
            Endif
            [F:CFOMM]CUR=[F:TABX]CUR
    When 5: [F:CFOMM]NUM=[F:TABX]SQHNUM
            [F:CFOMM]DOCDAT=[F:TABX]QUODAT
            [F:CFOMM]SNS=2
            [F:CFOMM]DES=mess(8,477,1)-[F:TABX]SQHNUM
            If [F:BPC]BPCPYR<>""
              [F:CFOMM]BPRNUM=[F:BPC]BPCPYR
            Else
              [F:CFOMM]BPRNUM=[F:TABX]BPCORD
            Endif
            [F:CFOMM]CUR=[F:TABX]CUR
            [F:CFOMM]PTE=[F:TABX]PTE
    When 6,7: [F:CFOMM]NUM=[F:TABX]SOHNUM
            [F:CFOMM]DOCDAT=[F:TABX]ORDDAT
            [F:CFOMM]SNS=2
            [F:CFOMM]DES=mess(8,477,1)-[F:TABX]SOHNUM
            [F:CFOMM]BPRNUM=[F:TABX]BPCPYR
            [F:CFOMM]CUR=[F:TABX]CUR
            [F:CFOMM]PTE=[F:TABX]PTE
    When 8: [F:CFOMM]NUM=[F:TABX]CONNUM
            [F:CFOMM]DOCDAT=[F:TABX]CONSTRDAT
            [F:CFOMM]SNS=2
            [F:CFOMM]DES=mess(19,477,1)-[F:TABX]CONNUM
            [F:CFOMM]BPRNUM=[F:TABX]CONBPCPYR
            [F:CFOMM]CUR=[F:TABX]CUR
            [F:CFOMM]PTE=[F:TABX]PTE
    When 9: [F:CFOMM]NUM=[F:TABX]SDHNUM
            [F:CFOMM]DOCDAT=[F:TABX]SHIDAT
            [F:CFOMM]SNS=2
            [F:CFOMM]DES=mess(4,477,1)-[F:TABX]SDHNUM
            [F:CFOMM]BPRNUM=[F:TABX]BPCPYR
            [F:CFOMM]PTE=[F:TABX]PTE
            [F:CFOMM]CUR=[F:TABX]CUR
    When 10:[F:CFOMM]NUM=[F:TABX]LEAREF
            [F:CFOMM]DOCDAT=[F:TABX]STRLEADAT
            [F:CFOMM]SNS=1
            [F:CFOMM]DES=mess(10,3636,1)-[F:TABX]LEAREF
            [F:CFOMM]CUR=[F:TABX]LEACUR
            If [F:BPS]BPRPAY<>""
              [F:CFOMM]BPRNUM=[F:BPS]BPRPAY
            Else
              [F:CFOMM]BPRNUM=[F:TABX]LES
            Endif
            Read [BPS]BPS0=[F:CFOMM]BPRNUM
            # Issue 56229 - 2017-11-15 by MWA
            If func ASYRFNC.ACTIV("MUL") >0
              Read [BPE]BPE0=[F:CFOMM]BPRNUM;[F:CFOMM]CPY
              If !fstat and [F:BPE]PTEBPS<>""
                 [F:CFOMM]PTE=[F:BPE]PTEBPS
              Else
                 [F:CFOMM]PTE=[F:BPS]PTE
              Endif
            Else
              [F:CFOMM]PTE=[F:BPS]PTE : # Issue 56229 - 2017-11-15 by MWA
            Endif
    Endcase
    Read [CFOMM]CFOMM0=[F:CFOMM]CFOTYP;[F:CFOMM]NUM;[F:CFOMM]CFOLIN
    If fstat
      ##### SAC
      #Call READ_SAC([F:CFOMM]BPRNUM,[F:CFOMM]CPY,[F:CFOMM]COA,[F:CFOMM]SNS,[F:CFOMM]SAC)
      ##### BAN
      #Call READ_BAN([F:CFOMM]BPRNUM,[F:CFOMM]CPY,[F:CFOMM]FCY,[F:CFOMM]SNS,[F:CFOMM]BAN)
#      If [F:CFOMM]BAN="": [F:CFOMM]BAN=BANDEF: Endif
#        ####################################################################################
#        ## Is the banck excluded of CFO management?
#        STAT=0
#        If [F:CFOMM]BAN<>BANDEF
#          Read [BAN]BAN0=[F:CFOMM]BAN
#          If !fstat
#            If [F:BAN]CFOEXD=2
#               STAT=1
#            Else
#               If [F:BAN]FCY<>"" and [F:BAN]FCY<>[F:CFOMM]FCY
#                 [F:CFOMM]BAN=BANDEF
#               Endif
#               If [F:BAN]CPY<>[F:CFOMM]CPY
#                 [F:CFOMM]BAN=BANDEF
#               Endif
#            Endif
#          Else
#          [F:CFOMM]BAN=BANDEF
#        Endif
#      Endif

        [M:CFO0]=[F:CFOMM]
        [M:CFO1]=[F:CFOMM]
        Gosub CALC_OPEN_ITEM From SUBCFO
        For YY=0 To [M:CFO2]NBLIG-1
          [F:CFOMM]DAT(YY)    =[M:CFO2]DAT(YY)
          [F:CFOMM]PAMDET(YY)   =[M:CFO2]PAMDET(YY)
          [F:CFOMM]AMTCUR(YY) =[M:CFO2]AMTCUR(YY)
        Next YY
        Write [F:CFOMM]
        If fstat
          GOK = 0
          Gosub AB_CRECFOMM
          Break
        Endif
        STAT=0
        Gosub CRE_CFODUD From SUBCFO
        If STAT
          GOK = 0
          Gosub AB_CRECFODD
          Break
        Endif

    Endif
  Next
If GOK=1
   Commit
Endif
Return

