######################################################################################
######################################################################################
## screen TRTCFO
######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char VALEUR()
If VALEUR="" or [M]CPY=""
  Call INIFCY([M:TCFO]FCY,VALEUR) From CPTSUB
  If [M:TCFO]FCY<>""
    Call LECTURE("FCY",[M:TCFO]FCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    [M:TCFO]CPY   = [F:FCY]LEGCPY
    Affzo CPY, FCY
  Endif
Endif
End

#####################################################################################
######################################################################################
## Section automatically added (screen TRTCFO) 02/17/2014 13:23:49 (LUCUE)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call TRT_FLG(VALEUR,[M:TCFO]FCY)
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call TRT_FLG([M:TCFO]CPY,VALEUR)
End

Subprog TRT_FLG(COMPANY, SITE)
Value Char COMPANY
Value Char SITE
Local Integer X, NUM
If !clalev([CFOT]): Local File CFOTYP[CFOT]: Endif

If COMPANY="": End: Endif
For X=1 To 10
  If SITE=""
    Filter [CFOT] Where CPY=COMPANY and CFOTYP=X and FLG=2
    NUM=rowcount([CFOT])
  Else
    Filter [CFOT] Where CPY=COMPANY and FCY=SITE and CFOTYP=X and FLG=2
    NUM=rowcount([CFOT])
    If NUM=0
      Filter [CFOT] Where CPY=COMPANY and FCY=SITE and CFOTYP=X and FLG<>2
      NUM=rowcount([CFOT])
      If NUM
         NUM=0
      Else
        Filter [CFOT] Where CPY=COMPANY and FCY="" and CFOTYP=X and FLG=2
        NUM=rowcount([CFOT])
      Endif
    Endif
  Endif




  If NUM
    Case X
      When 1: Actzo [M:TCFO]CFOPR: [M:TCFO]CFOPR=2: Affzo [M:TCFO]CFOPR
      When 2: Actzo [M:TCFO]CFOPC: [M:TCFO]CFOPC=2: Affzo [M:TCFO]CFOPC
      When 3: Actzo [M:TCFO]CFOPO: [M:TCFO]CFOPO=2: Affzo [M:TCFO]CFOPO
      When 4: Actzo [M:TCFO]CFORN: [M:TCFO]CFORN=2: Affzo [M:TCFO]CFORN
      When 5: Actzo [M:TCFO]CFOQU: [M:TCFO]CFOQU=2: Affzo [M:TCFO]CFOQU
      When 6: Actzo [M:TCFO]CFOSO: [M:TCFO]CFOSO=2: Affzo [M:TCFO]CFOSO
      When 7: Actzo [M:TCFO]CFOSC: [M:TCFO]CFOSC=2: Affzo [M:TCFO]CFOSC
      When 8: Actzo [M:TCFO]CFOCM: [M:TCFO]CFOCM=2: Affzo [M:TCFO]CFOCM
      When 9: Actzo [M:TCFO]CFODN: [M:TCFO]CFODN=2: Affzo [M:TCFO]CFODN
      When 10: Actzo [M:TCFO]CFOLEA: [M:TCFO]CFOLEA=2: Affzo [M:TCFO]CFOLEA
    Endcase
      Else
    Case X
      When 1: Raz [M:TCFO]CFOPR: Affzo [M:TCFO]CFOPR: Diszo [M:TCFO]CFOPR
      When 2: Raz [M:TCFO]CFOPC: Affzo [M:TCFO]CFOPC: Diszo [M:TCFO]CFOPC
      When 3: Raz [M:TCFO]CFOPO: Affzo [M:TCFO]CFOPO: Diszo [M:TCFO]CFOPO
      When 4: Raz [M:TCFO]CFORN: Affzo [M:TCFO]CFORN: Diszo [M:TCFO]CFORN
      When 5: Raz [M:TCFO]CFOQU: Affzo [M:TCFO]CFOQU: Diszo [M:TCFO]CFOQU
      When 6: Raz [M:TCFO]CFOSO: Affzo [M:TCFO]CFOSO: Diszo [M:TCFO]CFOSO
      When 7: Raz [M:TCFO]CFOSC: Affzo [M:TCFO]CFOSC: Diszo [M:TCFO]CFOSC
      When 8: Raz [M:TCFO]CFOCM: Affzo [M:TCFO]CFOCM: Diszo [M:TCFO]CFOCM
      When 9: Raz [M:TCFO]CFODN: Affzo [M:TCFO]CFODN: Diszo [M:TCFO]CFODN
      When 10: Raz [M:TCFO]CFOLEA: Affzo [M:TCFO]CFOLEA: Diszo [M:TCFO]CFOLEA
    Endcase
  Endif
Next
Filter [CFOT]
End
