Gosub _AFF
End

$ON_SEVCTR
Onevent BEFORE_INPUT Call AS_SEVCTR(zc) From W2CTR2
Onevent CONTROL Call C_SEVCTR(zc) From W2CTR2
Onevent INIT_AREA Call D_SEVCTR(zc) From W2CTR2
Return

Subprog D_SEVCTR(VALEUR)
Variable Integer VALEUR
If varinit([M]SEVCTR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEVCTR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_SEVCTR(VALEUR) From SUBCTR
If mkstat=2
 [M]SEVCTR(INDIC) = VALEUR
 Affzo SEVCTR(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SEVCTR(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_SEVCTR(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "SEVCTR" : GZNUM = 46121 : Endif
Gosub _AFF
End

