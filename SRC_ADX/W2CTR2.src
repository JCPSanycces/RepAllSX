$ON_CATFRT
Onevent INIT_AREA Call D_CATFRT(zc) From W2CTR2
Onevent CONTROL Call C_CATFRT(zc) From W2CTR2
Onevent BEFORE_INPUT Call AS_CATFRT(zc) From W2CTR2
Onevent AFTER_CHANGE Gosub AMM_CATFRT From W2CTR2
Return

Subprog D_CATFRT(VALEUR)
Variable Char    VALEUR()
If varinit([M]CATFRT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10453","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CATFRT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10453") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CATFRT(zc) From W2CTR2
Onkey   2 Titled GBOUTS Call S_CATFRT(zc) From W2CTR2
Onkey 144 Titled GBOUTP Call P_CATFRT(zc) From W2CTR2
Onkey 146 Titled GBOUTA Call SA_CATFRT(zc) From W2CTR2
Gosub _AFF
End

Subprog C_CATFRT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10453","") From SUBADI
If mkstat : GERR = 1 : GZONE = "CATFRT" : GZNUM = 44776 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10453",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CATFRT" : GZNUM = 44776 : Endif
Endif
Gosub _AFF
End

$AMM_CATFRT
Call AM_CATFRT(zc)
If !mkstat & GOBJET
 zoncou = "CATFRT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATFRT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCATFRT)")>indice
 [M]CATFRT(indice) = VALEUR
 Affzo ZCATFRT(indice)
Endif
Gosub _AFF
End

Subprog S_CATFRT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10453"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CATFRT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10453") From GOBJET
Gosub _AFF
End

Subprog SA_CATFRT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10453"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CATFRT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10453"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCATFRT
Onevent BEFORE_AREA Gosub AV_ZCATFRT From W2CTR2
Return

$AV_ZCATFRT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10453",num$([M]CATFRT(indice))) From ATEXTRA
Gosub _AFF
Return

