#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_STRDATSEV
Onevent AFTER_CHANGE Gosub AMM_STRDATSEV From W2CTR2
Onevent BEFORE_AREA Gosub AV_STRDATSEV From W2CTR2
Return

$AV_STRDATSEV
Chgfmt [M]STRDATSEV(indice) With "DzZ:"+GFMDAT4
Gosub _AFF
Return

$AMM_STRDATSEV
Call AM_STRDATSEV(zc)
If !mkstat & GOBJET
 zoncou = "STRDATSEV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STRDATSEV(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_STRDATSEV(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "STRDATSEV" : GZNUM = 6845 : Endif
Gosub _AFF
End

$ON_ENDDATSEV
Onevent CONTROL Call C_ENDDATSEV(zc) From W2CTR2
Onevent AFTER_CHANGE Gosub AMM_ENDDATSEV From W2CTR2
Onevent BEFORE_AREA Gosub AV_ENDDATSEV From W2CTR2
Return

$AV_ENDDATSEV
Chgfmt [M]ENDDATSEV(indice) With "DzZ:"+GFMDAT4
Gosub _AFF
Return

Subprog C_ENDDATSEV(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]STRDATSEV) From EXEFNC
If mkstat : GERR = 1 : GZONE = "ENDDATSEV" : GZNUM = 6235 : Endif
Gosub _AFF
End

$AMM_ENDDATSEV
Call AM_ENDDATSEV(zc)
If !mkstat & GOBJET
 zoncou = "ENDDATSEV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ENDDATSEV(VALEUR)
