$ON_DNACCP
Onevent BEFORE_INPUT Call AS_DNACCP(zc) From W2CTR2
Onevent CONTROL Call C_DNACCP(zc) From W2CTR2
Onevent INIT_AREA Call D_DNACCP(zc) From W2CTR2
Return

Subprog D_DNACCP(VALEUR)
Variable Integer VALEUR
If varinit([M]DNACCP,indice)=0
 VALEUR = 4
Endif
Gosub _AFF
End

Subprog AS_DNACCP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10965) From COMBOS
## Action STD
Call AS_DNACCP(VALEUR) From SUBCTR
If mkstat=2
 [M]DNACCP(INDIC) = VALEUR
 Affzo DNACCP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10965,1))))
Endif
If !mkstat
 Discombo 0 From DNACCP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From DNACCP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_DNACCP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_DNACCP(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "DNACCP" : GZNUM = 45909 : Endif
Gosub _AFF
End

