$ON_NUMCCP
Onevent INIT_AREA Call D_NUMCCP(zc) From W2CTR2
Onevent CONTROL Call C_NUMCCP(zc) From W2CTR2
Onevent BEFORE_INPUT Call AS_NUMCCP(zc) From W2CTR2
Return

Subprog D_NUMCCP(VALEUR)
Variable Char    VALEUR()
If varinit([M]NUMCCP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"411","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_NUMCCP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_NUMCCP(zc) From W2CTR2
Onkey 144 Titled GBOUTP Call P_NUMCCP(zc) From W2CTR2
Onkey 146 Titled GBOUTA Call SA_NUMCCP(zc) From W2CTR2
Gosub _AFF
End

Subprog C_NUMCCP(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"411","") From SUBADI
If mkstat : GERR = 1 : GZONE = "NUMCCP" : GZNUM = 47315 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"411",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NUMCCP" : GZNUM = 47315 : Endif
 If !mkstat
  ## Action STD
  Call C_NUMCCP(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "NUMCCP" : GZNUM = 47315 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_NUMCCP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "411"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_NUMCCP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "411"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NUMCCP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "411"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

