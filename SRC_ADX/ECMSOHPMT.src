#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Program Name: ECMSOHPMT (XJZPREPMT)
# Description:  Sales Order Pre-Payment Sub-Program
# Created Date: 06/12/2014
# Created By:   D> Hartman, RKL eSolutions
# Called by Web Service ECMSOHPMT (XJZPREPMT)
#-------------------------------------------------------
# Input Parameters:
# SONBR   - Sales Order Number
# PMTMETH - Payment Method (Valid values come from
#           misc table 3 - Payment Methods)
# PMTAMT  - Payment Amount
# TAXCODE - Tax Code (Valid values come from table TABVAT
#-------------------------------------------------------
# Output Parameters:
# RESULT  - This is an error containing any errors
########################################################
Subprog PREPAYMENT(SONBR, PMTMETH, PMTAMT, TAXCODE, RESULT)

    Value Char SONBR
    Value Char PMTMETH
    Value Decimal PMTAMT
    Value Char TAXCODE

    Variable  Char RESULT() ()

    Local Char DLOG : DLOG = ''

    Local Integer ERR : ERR = 0
    Local Integer ISNEW : ISNEW = 0
    Local Integer EXCEED : EXCEED = 0

    # Validate Input Data
    ######################

    # Open GACCDUDATE Table
    If clalev([F:DUD])= 0 : Local File GACCDUDATE [DUD] : Endif

    # Open SORDER Table & validate SONBR
    If clalev([F:SOH])= 0 : Local File SORDER [SOH] : Endif
    Read [F:SOH]SOH0=SONBR
    If fstat
        RESULT(ERR) = mess(9,7730,1)    # Invalid sales order number
        ERR = ERR + 1
    Else
        # Order partially or totally invoiced [F:SOH]INVSTA <> 1
        If [F:SOH]INVSTA <> 1
            RESULT(ERR) = mess(10,7730,1)   # Order partially or totally invoiced
            ERR = ERR + 1
        Endif

        # No more than 4 pre-payments can be on the same order
        Local Integer PMTCNT : PMTCNT = 0
        Local Integer PMTTOT : PMTTOT = 0
        For [F:DUD] Where TYP="*SO" and NUM = SONBR
            PMTCNT = PMTCNT + 1
            PMTTOT = PMTTOT + [F:DUD]AMTCUR
        Next
        If PMTCNT > 4
            RESULT(ERR) = mess(11,7730,1)   # No more than four prepayments can be on the same order
            ERR = ERR + 1
        Endif

        # Sum of payments cannot exceed open order amount
        PMTTOT = PMTTOT + PMTAMT
        If PMTTOT > [F:SOH]ORDATI
            EXCEED = 1
        Endif
    Endif

    # Open ATABDIV and Validate the PMTTYP
    If clalev([F:ADI])= 0 : Local File ATABDIV [ADI] : Endif
    Read [F:ADI]CODE=3;PMTMETH
    If fstat
        RESULT(ERR) = mess(13,7730,1)   # Invalid payment type
        ERR = ERR + 1
    Endif

    # Open TABVAT and Validate the TAXCODE
    If clalev([F:TVT]) = 0 : Local File TABVAT [TVT] : Endif
    Read [F:TVT]TVT0=TAXCODE
    If fstat
        RESULT(ERR) = mess(14,7730,1)   # Invalid tax code
        ERR = ERR + 1
    Endif

    # Create Payment
    ######################

    # Only continue if no errors
    If ERR = 0

        # Open BPARTNER Table
        If clalev([F:BPR])= 0 : Local File BPARTNER [BPR] : Endif

        # Open Fiscal Periods Table
        If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif

        # Open Customer Table
        If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif

        Read [F:BPR]BPR0=[F:SOH]BPCINV
        If fstat
            RESULT(ERR) = mess(15,7730,1)   # Invalid BP number on order
            ERR = ERR + 1
        Else

            # Get Fiscal Year and Fiscal Period
            Local Integer FISCYR : FISCYR = 0
            Local Integer FISCPD : FISCPD = 0
            Filter [PER] Where CPY = [F:SOH]CPY and LEDTYP = 1 and PERSTR <= date$ and PEREND >= date$ and PERSTA = 2
            Read [F:PER] First
            If !fstat
                FISCYR = [F:PER]FIYNUM
                FISCPD = [F:PER]PERNUM
            Endif

            # Get Pay To Addr Code
            Local Char PYR : PYR = ""
            Read [F:BPC]BPC0=[F:SOH]BPCINV
            If !fstat
                PYR = [F:BPC]BPAPYR
            Endif

            # If pre-payments already exist for this order, use the same ACCNUM, and increment the LIG number
            Local Integer ACCNUM : ACCNUM = 0
            Local Char NUMDUD : NUMDUD = ''
            Local Integer LIGNO : LIG = 0
            For [F:DUD] Where TYP = "*SO" and NUM = SONBR
                ACCNUM = [F:DUD]ACCNUM
                NUMDUD = [F:DUD]NUMDUD
                If [F:DUD]DUDLIG > LIGNO
                    LIGNO = [F:DUD]DUDLIG
                Endif
            Next
            If ACCNUM = 0
                Call ACCNUM(ACCNUM) From SUBGAS
                LIGNO = 1
            Else
                LIGNO = LIGNO + 1
            Endif

            # Return the Payment Number Created
            Read [F:DUD]DUD8=NUMDUD
            If fstat
                If EXCEED
                    RESULT(ERR) = mess(12,7730,1)   # Sum of payments cannot exceed open order amount
                    ERR = ERR + 1
                Endif
                ISNEW = 1
            Else
                ISNEW = 0
                LIGNO = [F:DUD]DUDLIG
            Endif

            Raz [F:DUD]
            [F:DUD]TYP = "*SO"
            [F:DUD]NUM = SONBR                                          # Sales Order Number
            [F:DUD]LIG = 1                                              # Line Number
            [F:DUD]DUDLIG = LIGNO                                       # Due Date Number
            [F:DUD]ACCNUM = ACCNUM                                      # Internal Number
            [F:DUD]CPY = [F:SOH]CPY                                     # Company Number
            [F:DUD]FCY = [F:SOH]SALFCY                                  # Site
            [F:DUD]CUR = [F:SOH]CUR                                     # Currency
            [F:DUD]BPR = [F:SOH]BPCINV                                  # Bill To BP
            [F:DUD]BPRTYP = 1                                           # Customer
            [F:DUD]BPRPAY = [F:SOH]BPCINV                               # Pay by BP TODO
            [F:DUD]DUDDAT = date$                                       # Due Date
            [F:DUD]PAM = PMTMETH                                        # Payment Method
            [F:DUD]PAMTYP = 2                                           # Payment Type (Prepayment)
            [F:DUD]SNS = 1                                              # Sign
            [F:DUD]SAC = "AR"
            [F:DUD]BPAPAY = PYR                                         # Payer Address Code
            [F:DUD]AMTCUR = PMTAMT                                      # Pmt Amount in Currency
            [F:DUD]AMTLOC = PMTAMT                                      # Ref Amt Curr
            [F:DUD]PAYCUR = 0                                           # Paid
            [F:DUD]PAYLOC = 0                                           # Paid Ref Currency
            [F:DUD]TMPCUR = 0                                           # Provisional payment
            [F:DUD]TMPLOC = 0                                           # Provisional payment
            [F:DUD]FLGFUP = 2                                           # Reminder (yes)
            [F:DUD]LEVFUP = 0                                           # Reminder Level
            [F:DUD]FLGPAZ = 4                                           # Pay Approval (Authorized to Pay)
            [F:DUD]SOI = 1                                              # Statement (no)
            [F:DUD]DUDSTA = 0                                           # Status
            [F:DUD]DINAMT = 0                                           # Deducted prepayment
            [F:DUD]IBDAMT = PMTAMT                                      # Prepayment to deduct
            [F:DUD]VAT = TAXCODE                                        # Tax
            [F:DUD]FIY = FISCYR                                         # Fiscal Year
            [F:DUD]PER = FISCPD                                         # Period
            [F:DUD]SENINS = 1                                           # Prepayment issued
            [F:DUD]FLGCLE = 1                                           # Closed (no)
            [F:DUD]TYPDUD = 1                                           # Type of open item (order)
            [F:DUD]NUMDUD = num$([F:DUD]ACCNUM)+"/"+num$([F:DUD]DUDLIG) # Unique number ACCNUM/LIG
            [F:DUD]EXPSENDAT = date$                                    # Expected issue date
            [F:DUD]CREDAT = date$                                       # Create Date
            [F:DUD]CREUSR = mess(24,7730,1)                             # Create User
            If !ISNEW
                Rewrite [F:DUD]
            Else
                Write [F:DUD]
            Endif

        Endif

        Close Local File [PER]
        Close Local File [BPR]
        Close Local File [DUD]
        Close Local File [TVT]
        Close Local File [SOH]
        Close Local File [ADI]
        Close Local File [BPC]

    Endif

End

$INITWS
    # Used to test the web service
    #SONBR = "SO000136"
    #PMTMETH = "CHQ"
    #PMTAMT = 250
    #TAXCODE = "NT"
Return

$RESULTWS

Return





