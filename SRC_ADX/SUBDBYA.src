#<AdxTL>@(#)4.0.0.0 $Revision$


Call OBJET("DBY", GBIDC1, GBIDC2) From GOBJET
End

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#######################################################################
# Les etiquettes suivantes sont définies pour la gestion de l'objet   #
#######################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If GFONC1 <> "GESDBY"  Raz GFLAG Endif
If GFLAG<>""
   Read [F:SRT] SRT0=7;GFLAG
   If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
   If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER & [F:SRT]ABYTYP <> 2
      If clalev ([F:ACC])=0
         Local File ACCES  [ACC]
         OUVFICFLG=1
      Endif
      Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
      If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
   Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=7;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2 | [F:SRT]ABYTYP <> 2
   OK = 0
Endif
Return
######################################################################
$SETTRANS
Global Integer  GCCECOD    : # Flag saisie des sections analytiques
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=7;GFLAG

GSLTSTKFLG  = [F:SRT]STKFLG
GDBYNUM     = [F:SRT]SRTNUM                 # hcb 50197
GSRTNUM     = [F:SRT]SRTNUM

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:SRT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

Return


######################################################################
$OUVRE
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
Local  Integer  LRET
Raz GSOC_ACTIVE                                               # Ana

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

    Global Integer GRELITSMR
    Global Integer GVCRTYP
    Global Char    GVCRNUM
    Global Integer GSAISTOFCY     : # Pour maj picking    # hcb 107851

    Raz GRELITSMR

    GDBYNUM = GFLAG                          # hcb 50197
    GSRTNUM = GFLAG

    # TRSTYP = type de mouvement stock (menu local 704)
    # Sa valeur est utilisée en particulier
    # pour le contrôle de statut

   [M:DBY0]VCRTYP  = 32       #desassemblage
   [M:DBY0]TRSTYP  = 2        # sortie pour le composé
   [M:DBY0]TRSTYPC = 1        # entrée pour les composants


    GFCY=GFCYDEF(7)                                                # Ana
    Gosub CHARG_PARAM                                              # Ana
    If GMODU(2)=2 : # Si module compta actif                       # Ana
      If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
    Endif                                                          # Ana
    GORITITCOL=1                                                   # Ana

    # Initialisation des tables nécessaires à la gestion d'emplacements
    Gosub STK_INILOC From STKLOC

    #  ecran stockage mvt du document entree
    If clalev([M:ENTW])=0
        Local Mask STOENTW   [ENTW]
    Endif
    [M:ENTW]WZONPCU = "PCU"
    [M:ENTW]WZONQUC = "QTYPCU"
    [M:ENTW]WZONCCS = "PCUSTUCOE"
    [M:ENTW]WZONQUS = "QTYSTU"
    [M:ENTW]WZONSTOUPD = ""
    Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT

 #----- Ecran stockage mvt du document  sortie
    If clalev([M:SOW])=0
        Local Mask STOSORW   [SOW]
    Endif
    Raz [M:SOW]

    #  ecran de travail enreg mvt du document
    If clalev([M:STW])=0
        Local Mask STOWORK   [STW]
    Endif
    Raz [M:STW]
    If clalev([M:VALW])=0
        Local Mask STOVALW   [VALW]
    Endif
    Raz [M:VALW]
    [M:VALW]ZONPRI = "[M:DBY1]PRIORD"
    [M:VALW]ZONPRIORD = "[M:DBY1]PRIORD"
    If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

   #----- Ecran des paramètres d'allocations
    If clalev([M:ALP])=0
        Local Mask ALLPAR    [ALP]
    Endif

    If clalev([F:TRU])=0
        Local File TABALLRUL [TRU]
    Endif
    If clalev([F:SRU])=0
        Local File TABSTORUL [SRU]
    Endif

    Gosub DECLARE From TABLEAUX
Return

$FILTRE
Default File [SMH]
# Limite les enregistrement de la liste gauche
FILTSUP = "VCRTYP=32"          #desassemblage
Return
$TIROIR
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
If !find(currbox,GBOXBBY)   Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB

Return


$FILGAUCHE
#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
GBIDI2=1
If GREP<>"C"
  GBIDC2="M": GFCY=[M:DBY0]STOFCY : Gosub AUTORIS_OPT From CONTX3
Endif
#-----
If GREP="C" & [M:DBY0]STOFCY<>"" & GBIDI2=1
#--- Filtre supplémentaire 0 :  assemblage
   FILGAUSUP(0) ="[F:SMH]VCRTYP=31 & [F:SMH]STOFCY=[M:DBY0]STOFCY & [F:SMH]DBYFLG <> 2 "  # hcb 22993
Else
   Case currbox
        When GBOXDBY :  FILGAUSUP(0)= "[F:SMH]VCRTYP=32"             # hcb 107851
        When GBOXBBY :  FILGAUSUP(0)= "[F:SMH]VCRNUM='_'"            # hcb 107851
        When Default :  FILGAUSUP(0)= "[F:SMH]VCRNUM='_'"            # hcb 107851
   Endcase
Endif
Return


$PICKE
#----------------------#
# Nouvel élément pické #
#----------------------#
If !find(currbox,GBOXBBY) Return : Endif
If REP=""
  If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
#  Gosub AVANT_MOD  If !OK  Return  Endif
Endif
Case currbox
  When GBOXBBY : Gosub PICKE_BBY  From SUBDBYA

Endcase
Return

$DEPICK

If !find(currbox,GBOXBBY) Return : Endif
Case currbox
  When GBOXBBY : Gosub DEPICK_BBY From SUBDBYA

Endcase
Return

$FIN_PICK

Affzo [M:DBY0]

Return

$CLE_GAUCHE

Return


$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXBBY(10)
GBOXBBY="GAU_CHE"+num$(find("BBY",OBJLIS(1..8))) : # Assemblage
Global Char     GBOXDBY(10)                                           # hcb 107851
GBOXDBY="GAU_CHE"+num$(find("DBY",OBJLIS(1..8))) : # Desassemblage    # hcb 107851

Return


$LIENS

Local Integer I
If GFCY<>[F:SMH]STOFCY GFCY=[F:SMH]STOFCY : Gosub CHARG_PARAM : Endif    # Ana
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub AFF_TITCOL                                                         # Ana


# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATDBY) > 0
   Kill GCTRDATDBY
Endif

    Raz GRELITSMR
    Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT
    Call RAZSTOSORW From STKSOR



    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GDBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GDBYNUM : If fstat Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif

    [M:DBY0]CCECODS   = [F:DTR]HEACCECOD
 #---- Récupération des sections analytiques  entete ----#
    Local Integer Y
    For Y=1 To GNBDIE
        [M:DBY0]CCE(Y-1) = [F:SMH]CCE(Y-1)
    Next


    Actzo [M:DBY0]
    Actzo [M:DBY0]VCRNUM    # Car il y a un diszo en RAZCRE (et RAZDUP)
    Grizo [M:DBY0]STOFCY
    Grizo [M:DBY0]IPTDAT
    Grizo [M:DBY0]PJT
    Grizo [M:DBY0]TRSFAM
    Grizo [M:DBY0]ENTCOD
    Diszo [M:DBY0]VCRNUMORI # diszo pour conserver les menus contextuels   hcb 22993

    [M:DBY0]VCRTYP  = 32       #desassemblage    HCB

    [M:DBY0]TRSTYP  = 2       # sortie pour le composé
    [M:DBY0]TRSTYPC = 1       # entrée pour les composants

    [M:DBY0]TRSCOD    = [F:SRT]TRSCOD              # hcb 50197

    [M:DBY0]ENTCOD    = [F:SRT]ENTCOD              # hcb 114384

    # Issue 105771 - 2015-01-27 by SR : Zone saisissable en création donc valeur stockée en table doit être conservée
    #[M:DBY0]TRSFAM    = [F:SRT]TRSFAMDEF           # hcb 50197
    [M:DBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 50197
    [M:DBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
    [M:DBY0]MVTPRICOD = [F:SRT]MVTPRICOD           # hcb 50197
    [M:DBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

    Gosub LIENS From TABLEAUX

# hcb 28649 deb
    If  [M:DBY0]VCRNUMORI <> ""
        If clalev([F:SMD1]) = 0 : Local File SMVTD    [SMD1] : Endif
        Read [SMD1]SMD0=31;[M:DBY0]VCRNUMORI;1
        If fstat
           Raz [F:SMD1]
        Endif
        If [F:SMD1]PNTMVTCOD = 1
           [M:DBY0]PNTMVTLIB  = mess(224,184,1)
        Endif
    Endif

    Gosub SANS_COMPOSE

# hcb 28649 fin


    Affzo [M:DBY0]10


    Default Mask [DBY0]
    Call ETAZONSOR("DBY0") From STKECR
    Affzo [M:DBY0]10
    Default Mask [DBY0]

 #   Call GETDEV([M:DBY0]STOFCY) From DEVSUB

    Call STKCTRIPT( [M:DBY0]IPTDAT, [M:DBY0]STOFCY, "1") From STKLIB
    If GERR=1
        Call ERREUR(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:DBY0]10
    Elsif GERR=2
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:DBY0]10
    Else
        Diszo [M:DBY0]
    Endif
# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
Local Integer WRET
WMAX = dim([M:DBY1]ITMREF)     # mémorisation nombre de ligne maxi
Default Mask [DBY1]

Raz [M:DBY1]
nolign = 1
# chargement tableau composants
Filter [SMD] Where VCRTYP = [M:DBY0]VCRTYP    &
&                  VCRNUM = [M:DBY0]VCRNUM    &
&                  LINTYP = 2
&            Order By Key SMD0
For [SMD]
    If nolign = WMAX : Break : Endif

    #--- TS
    [M:DBY1] = [F:SMD]
    #[M:DBY1]VCRLIN    (nolign-1) =  [F:SMD]VCRLIN
    #[M:DBY1]ITMREF    (nolign-1) =  [F:SMD]ITMREF
    #[M:DBY1]PRIORD    (nolign-1) =  [F:SMD]PRIORD
    #[M:DBY1]ITMDES1   (nolign-1) =  [F:SMD]ITMDES1
    #[M:DBY1]PCU       (nolign-1) =  [F:SMD]PCU
    #[M:DBY1]QTYPCU    (nolign-1) =  [F:SMD]QTYPCU
    #[M:DBY1]PCUSTUCOE (nolign-1) =  [F:SMD]PCUSTUCOE
    #[M:DBY1]STU       (nolign-1) =  [F:SMD]STU
    #[M:DBY1]QTYSTU    (nolign-1) =  [F:SMD]QTYSTU
    #--- TS end

    [M:DBY1]FLT       (nolign-1) = "[F:STJ]VCRLIN="+num$([M:DBY1]VCRLIN(nolign-1))

    [M:DBY1]LO        (nolign-1) =  [F:SMD]VCRLINORI
    [M:DBY1]CREFLG    (nolign-1) =  1
    ############################### sections ligne composant  Ana   deb
    Call CHARG_ACCCCE(nolign-1,"","","[M:DBY1]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
    ###############################                         # Ana   fin

    If [F:ITM]ITMREF<>[M:DBY1]ITMREF(nolign-1)
       Read [F:ITM]ITM0 = [M:DBY1]ITMREF(nolign-1)
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    [M:DBY1]STOMGTCOD (nolign-1) =  [F:ITM]STOMGTCOD            # hcb 28654
    If [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
       If [F:ITF]STOFCY <> [M:DBY0]STOFCY | [F:ITF]ITMREF <> [M:DBY1]ITMREF(nolign-1)
          Read [ITF]ITF0 = [M:DBY1]ITMREF(nolign-1);[M:DBY0]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif
       [M:DBY1]STOMGTCOD (nolign-1) =  [F:ITF]STOMGTCOD            # hcb 28654
    Endif
    Call RECSTO_F ("DBY1", [M:DBY0]STOFCY, [M:DBY0]VCRTYP,
&              [M:DBY0]VCRNUM, [M:DBY1]VCRLIN(nolign-1), nolign-1, "") From STKECR

# hcb 28654 deb
    If [M:DBY1]STOMGTCOD (nolign-1) > 1
       If dim([M:DBY1]QTYPCU)>0
          Diszo [M:DBY1]QTYPCU(nolign-1)
       Endif
       If dim([M:DBY1]PRIORD)>0
          Diszo [M:DBY1]PRIORD(nolign-1)
       Endif
    Endif
# hcb 28654 fin
#                                                         # hcb 71276  deb
    If [F:ITM]ECCSTO > 1 & dim([M:DBY1]ECCVALMAJ) >= 0
       If [M:DBY1]ECCVALMAJ(nolign-1) <> ""
          [M:DBY1]ECCVALMAJORI(nolign-1) = [M:DBY1]ECCVALMAJ(nolign-1)
          [M:DBY1]ECCVALMINORI(nolign-1) = [M:DBY1]ECCVALMIN(nolign-1)
          [M:DBY1]ECCSAIFLG   (nolign-1) = 9
       Endif
    Endif
#                                                         # hcb 71276  fin


    [M:DBY1]NBLIG  = nolign
    nolign += 1
Next
Filter [SMD]


Call STKDISCOL("DBY1",[M:DBY1]NBLIG) From STKECR
Diszo [M:DBY1]ITMREF,ITMDES1
Actzo [M:DBY1]ITMREF([M:DBY1]NBLIG),ITMDES1([M:DBY1]NBLIG)
If dim([M:DBY1]PCU)>0
       Diszo [M:DBY1]PCU
#       Diszo [M:DBY1]QTYPCU               # hcb 28654
       Actzo [M:DBY1]PCU([M]NBLIG)
       Actzo [M:DBY1]QTYPCU([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]PCUSTUCOE)>0
        Diszo [M:DBY1]PCUSTUCOE
        Actzo [M:DBY1]PCUSTUCOE([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]STU)>0
        Diszo [M:DBY1]STU
        Diszo [M:DBY1]QTYSTU
        Actzo [M:DBY1]STU([M:DBY1]NBLIG)
        Actzo [M:DBY1]QTYSTU([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]PRIORD)>0
#        Diszo [M:DBY1]PRIORD             # hcb 28654
        Actzo [M:DBY1]PRIORD([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]MVTDES)>0
        Diszo [M:DBY1]MVTDES
        Actzo [M:DBY1]MVTDES([M:DBY1]NBLIG)
Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

Affzo [DBY1]5
Default Mask [DBY0]

Return


$DEFLIG
    Default Mask [DBY0]
    Default File [SMD]
    CRIT = 'VCRTYP='+num$([M:DBY0]VCRTYP)+' and VCRNUM="'+[M:DBY0]VCRNUM+'" and LINTYP = 1'
    FICLIG="SMVTD"
    ABLIG="SMD"
    ZONLIG="VCRLIN"
Return

################
# Chargement de la ligne en cours
$LIENS_LIG
Local Integer WRET

Gosub SET_NOL
Read [F:ITM]ITM0 = [M:DBY0]ITMREF(NOL)
    # Alimentation des zones stock de la ligne
    # à partir de STOJOU ou STOALL
Call RECSTOSOR (!([M:DBY0]CFMFLG)+1, "DBY0",NOL,[M:DBY0]STOFCY,[M:DBY0]ITMREF(NOL),32,
&                 [M:DBY0]VCRNUM,[M:DBY0]VCRLIN(NOL),"",WRET) From STKECR

############################### sections ligne composé  Ana   deb
Call CHARG_ACCCCE(NOL,"","","[M:DBY0]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
###############################                         # Ana   fin

Return

$RAZCRE

    Raz [M:DBY0]

    If GFCY<>GFCYDEF(7)                             # Ana
       GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
    Endif                                           # Ana
#----- Affichage entêtes de colonne variables -----#
    Gosub AFF_TITCOL                                # Ana

    If GSTKCPTMAN(17)<>2
        Effzo [M:DBY0]VCRNUM
        Diszo [M:DBY0]VCRNUM
    Endif
    Actzo [M:DBY0]STOFCY
    Actzo [M:DBY0]IPTDAT
    Actzo [M:DBY0]PJT
    Actzo [M:DBY0]TRSFAM
    Actzo [M:DBY0]ITMREF
    [M:DBY0]VCRTYP = 32        #desassemblage
    [M:DBY0]TRSTYP  = 2
    [M:DBY0]TRSTYPC = 1
    [M:DBY0]CFMFLG  = 2
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GDBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GDBYNUM : If fstat Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif

    [M:DBY0]TRSCOD    = [F:SRT]TRSCOD
    [M:DBY0]TRSFAM    = [F:SRT]TRSFAMDEF
    [M:DBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 28649
    [M:DBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
    [M:DBY0]MVTPRICOD = [F:SRT]MVTPRICOD           # hcb 50197
    [M:DBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

    Affzo [M:DBY0]TRSFAM
    [M:DBY0]ENTCOD = [F:SRT]ENTCOD
    If [M:DBY0]STOFCY = ""
       [M:DBY0]STOFCY = GFCYDEF(7)
    Endif
   [M:DBY0]CCECODS   = [F:DTR]HEACCECOD
   Local Char SECTION
   Gosub SANS_COMPOSE                              # hcb 28649
   If [M:DBY0]PNTMVTCOD <> 1                       # hcb 28649
      For Y=1 To GNBDIE
          Call INISEC(SECTION, "STKDBYH", Y) From TRTX3CPT
          [M:DBY0]CCE(Y-1) =  SECTION
          [F:SMH]CCE(Y-1)  =  SECTION
      Next
   Endif

  [F:SMD]VCRLINPNT =  [F:SMD]VCRLIN
   Diszo [M:DBY0]VCRNUMORI # diszo pour conserver les menus contextuels   hcb 22993

   If dim([M:DBY0]WRHE)>0
      Call WRHINIT([M:DBY0]WRHE,[M:DBY0]STOFCY,10) From STKWRH
   Endif
   # Actzo ou Grizo des dépôts selon le site
   Gosub WRH_ETAT

    Call RAZSTOSORW From STKSOR
    Affzo [M:DBY0]
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif


Return

$RAZDUP
Local Integer  I, WRET
Local Shortint SRET
Local Integer NOL
Local Char     LECCMAJ(GLONECS), LECCMIN(GLONEVL)

    Gosub RAZCRE

    Raz [M:DBY0]VCRLIN
    Raz [M:DBY0]UPDFLG
    Raz [M:DBY0]CREFLG
    #Raz [M:DBY0]BPSLOT    # FGR 22/12/2009 : X3SUIVI60986
    If dim([M:DBY0]LOT) > 0
       Raz [M:DBY0]LOT
    Endif
    If dim([M:DBY0]NBSLO) > 0
       Raz [M:DBY0]NBSLO
       Raz [M:DBY0]SLO
       #Raz [M:DBY0]SLOF    # FGR 22/12/2009 : X3SUIVI60986
    Endif
    #Raz [M:DBY0]GESLOT    # FGR 22/12/2009 : X3SUIVI60986
    Raz [M:DBY0]STA
    If dim([M:DBY0]LOCTYP) > 0
       Raz [M:DBY0]LOCTYP
       Raz [M:DBY0]LOC
    Endif
    If dim([M:DBY0]SERNUM) > 0
       Raz [M:DBY0]SERNUM
       Raz [M:DBY0]SERNUMF
    Endif
    #Raz [M:DBY0]PRIORD    # FGR 22/12/2009 : X3SUIVI60986
    Raz [M:DBY0]MVTDES

    For I=0 To [M:DBY0]NBLIG-1
        # Lecture article et règle de gestion
        Call INIZONSOR("DBY0",[M:DBY0]ITMREF(NOL),[M:DBY0]STOFCY,NOL,[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,"") From STKECR
        # Alimentation de [M:ALP]
        Gosub ALI_ALP From SUBDBYA
        # Détermination du stock à sortir (automatisme, saisie)
        Call OUVSOR("DBY0",NOL,[M:DBY0]NBLIG,[M:DBY0]WSTOSEQ(NOL),[M:DBY0]STKFLG,LRET) From STKSOR              # hcb 50197
    Next I
    Affzo [M:DBY0]

    For NOL=0 To [M:DBY1]NBLIG-1
        Call OUVENT([M:DBY0]STOFCY,"DBY1",[M:DBY0]TRSTYP,[M:DBY0]TRSCOD,"",19,
&                   [M:DBY0]IPTDAT,I,[M:DBY1]NBLIG,"SRT","",SRET) From STKENT
        Raz LECCMAJ, LECCMIN
        If dim([M:DBY1]ECCVALMAJ)>0
            [L]LECCMAJ = string$([M:DBY1]ECCVALMAJ(NOL)<>"$",[M:DBY1]ECCVALMAJ(NOL))
            [L]LECCMIN = string$([M:DBY1]ECCVALMIN(NOL)<>"$",[M:DBY1]ECCVALMIN(NOL))
        Endif
        Call SETNEWPRIOVE([M:DBY1]ITMREF(NOL),LECCMAJ,LECCMIN,[M:DBY0]STOFCY,[M:DBY0]IPTDAT,[M:DBY1]WSTOSEQ(NOL),
&                         [M:DBY1]PRIORD(NOL),1,[M:DBY1]QTYSTU(NOL),"",WRET) From STKVAL
    Next NOL

    Affzo [M:DBY1]

Return

#########################################################################
$AVANT_MOD
# Modification impossible si sortie validée
#If [M:DBY0]CFMFLG=2
#    GERR=1
#    GMESSAGE=mess(30,184,1)
#    OK=0
#Endif
Return

#########################################################################
$AVANT_MODFIC
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:DBY0]WRHE)>0
   [M:DBY0]WRHE = [F:SMH]WRHE
Endif
Return

#########################################################################
$INIMOD
Local Integer Y
For Y=1 To GNBDIE
    [F:SMH]CCE(Y-1) = [M:DBY0]CCE(Y-1)
    [F:SMH]DIE(Y-1) =  GDIE(Y)                 # Ana
Next

Return

$SETBOUT

# hcb 28654  si suppression pas de bouton abandon ou enregistrer
If dim(GSUP) > 0
   GREP = ""
   REP  = ""
   Kill GSUP
Endif
# hcb 286954

If [M:DBY0]NBLIG>0
   Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
# Menu Options / Visu transaction
CHMEN += "c"
# Menu Options / Section analytique
CHMEN += "M"
# Pas de sections analytiques si invisible
If [F:DTR]HEACCECOD=3
   Call VIREBOUT(CHMEN,"M") From GOBJET
Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

$VERIF_CRE
Call CTLSTOENT( "DBY1", "QTYSTU", [M:DBY1]NBLIG, OK ) From STKECR

If [M:DBY0]PNTMVTCOD <> 1           # hcb 28649
   If OK > 0
      Call CTLSTOSOR( "DBY0", "QTYSTU", [M:DBY0]NBLIG, OK ) From STKECR
      OK = !OK
   Endif
Endif                               # hcb 28649

# Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
If OK & !GIMPORT & GSTOTRACE > 1
    Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

Return

$VERIF_MOD

Call CTLSTOENT( "DBY1", "QTYSTU", [M:DBY1]NBLIG, OK ) From STKECR
If [M:DBY0]PNTMVTCOD <> 1           # hcb 28649
   If OK > 0
      Call CTLSTOSOR( "DBY0", "QTYSTU", [M:DBY0]NBLIG, OK ) From STKECR
      OK = !OK
   Endif
Endif                               # hcb 28649
 # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
If OK & !GIMPORT & GSTOTRACE > 1
    Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

Return



$INICRE
Local Integer LSTAT
Local Char    LNUM
    # Création du numéro de document si nécessaire
If GSTKCPTMAN(17)<>2 | [M:DBY0]VCRNUM = ""
   Call NUMERO(GSTKCPT(17), [M:DBY0]STOFCY, [M:DBY0]IPTDAT,
&                       "", LNUM, LSTAT) From SUBANM


        If GOK<0 Return Endif
        If LSTAT=0
          [M:DBY0]VCRNUM = LNUM
          [F:SMH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
Endif
Local Integer Y
For Y=1 To GNBDIE
    [F:SMH]CCE(Y-1)=  [M:DBY0]CCE(Y-1)
    [F:SMH]DIE(Y-1) =  GDIE(Y)                 # Ana
Next

# Alimentation dépôt entête si mono-dépôt
If dim([M:DBY0]WRHE)>0 & GWRHOBY=2
  [F:SMH]WRHE = [M:DBY0]WRHE
Else
  [F:SMH]WRHE = ""
Endif

Return

$CREATION
Gosub CREATION From TABLEAUX

Local Integer I
Local Integer WVCRLIN
WVCRLIN = 1000
Local Integer WECR
Raz WECR

For I = 0 To [M:DBY1]NBLIG-1
    If [M:DBY1]QTYSTU (I) <> 0
       Raz [F:SMD]
       [F:SMD]VCRLINPNT = 1
       [F:SMD]PNTMVTCOD = 0                # hcb 28649
       [F:SMD]VCRTYP    = [F:SMH]VCRTYP
       [F:SMD]VCRNUM    = [F:SMH]VCRNUM
       [F:SMD]VCRLIN    = [M:DBY1]VCRLIN    (I)
       [F:SMD]ITMREF    = [M:DBY1]ITMREF    (I)
       [F:SMD]PRIORD    = [M:DBY1]PRIORD    (I)
       [F:SMD]ITMDES1   = [M:DBY1]ITMDES1   (I)
       [F:SMD]PCU       = [M:DBY1]PCU       (I)
       [F:SMD]QTYPCU    = [M:DBY1]QTYPCU    (I)
       [F:SMD]PCUSTUCOE = [M:DBY1]PCUSTUCOE (I)
       [F:SMD]STU       = [M:DBY1]STU       (I)
       [F:SMD]QTYSTU    = [M:DBY1]QTYSTU    (I)
       [F:SMD]LINTYP    = 2
       [F:SMD]BOMALT    = [M:DBY0]BOMALT
       [F:SMD]CREDAT    = date$
       [F:SMD]CREUSR    = GUSER
       # Alimentation dépôt ligne si renseigné
       If dim([M:DBY1]WRH)>0 & [M:DBY1]WRH(I)<>""
         [F:SMD]WRH = [M:DBY1]WRH(I)
       Else
         [F:SMD]WRH = ""
       Endif
       If [M:DBY0]VCRNUMORI <> ""
          If [M:DBY1]LO (I) <> 0
             [F:SMD]VCRNUMORI = [M:DBY0]VCRNUMORI
             [F:SMD]VCRTYPORI = [M:DBY0]VCRTYPORI
             [F:SMD]VCRLINORI = [M:DBY1]LO (I)
          Endif
       Endif

#       Local Integer Y
#       For Y=1 To GOPTCANA
#           Assign "[F:SMD]CCE"+num$(Y) With evalue("[M:DBY1]CCE"+num$(Y)+"(I)")
#       Next
       Write [SMD]
       If fstat
          GOK = 0
          Call FSTA("SMD") From GLOCK
          Break
       Endif
       WECR = 1
# maj section composant
       Gosub MAJPID_CPTANALIN_CPT  : If GOK<1  Return : Endif     # Ana

       If [M:DBY1]STOMGTCOD (I)  > 1              # hcb 28654
          Call ALISTW (I) From SUBDBYA     # Mvt Entrée
       Endif                                      # hcb 28654
    Endif
    If  GOK < 1
       Break
    Endif

# hcb 22993 deb
# si desassemblage d assemblage mise à jour de l assemblage detail avec les caracteristiques du desassemblage
    If [M:DBY0]VCRNUMORI <> ""
       If [M:DBY1]LO (I) <> 0
          Readlock [SMD]SMD0=[M:DBY0]VCRTYPORI;[M:DBY0]VCRNUMORI;[M:DBY1]LO(I)
          If fstat = 1
             GOK = -1
             GLOCK = "$SMVTD"-[M:DBY0]VCRNUMORI-num$([M:DBY1]LO(I))
             Return
          Elsif fstat
             GOK =  0
             Call RSTA ("SMD",[M:DBY0]VCRNUMORI-num$([M:DBY1]LO(I))) From GLOCK
             Return
          Endif
          If [F:SMD]QTYPCUORI = 0
             [F:SMD]QTYPCUORI = [F:SMD]QTYPCU
          Endif
          If [F:SMD]QTYSTUORI = 0
             [F:SMD]QTYSTUORI = [F:SMD]QTYSTU
          Endif

          If [F:SMD]QTYSTUORI >= [M:DBY1]QTYSTU(I)
             [F:SMD]QTYSTUORI -= [M:DBY1]QTYSTU(I)
          Else
             [F:SMD]QTYSTUORI =  0
          Endif
          If [F:SMD]QTYPCUORI >= [M:DBY1]QTYPCU(I)
             [F:SMD]QTYPCUORI -= [M:DBY1]QTYPCU(I)
          Else
             [F:SMD]QTYPCUORI =  0
          Endif

          [F:SMD]VCRTYPORI = [M:DBY0]VCRTYP
          [F:SMD]VCRNUMORI = [M:DBY0]VCRNUM

          [F:SMD]VCRLINORI = [M:DBY1]VCRLIN (I)
          Rewrite [SMD]
          If fstat
             GOK=0
             Call FSTA("SMD") From GLOCK
             Break
          Endif
       Endif
    Endif
Next

# si pas de detail d ecrit GOK = 0
If WECR = 0
   GOK = 0
    Call ERREUR(mess(89,184,1)) From GESECRAN  # Création impossible ! Aucune ligne de  composant n' est valide ...
Endif

# si desassemblage d assemblage mise à jour de l assemblage entete avec les caracteristiques du desassemblage
If GOK > 0
   If [M:DBY0]VCRNUMORI <> ""
      # mise à jour vcrtypori vcrnumori vcrlinori
#  mise à jour de l assemblage detail ligne 1 avec les caracteristiques du desassemblage
# hcb 22993 deb
          Local Integer WDBYFLG
          Raz WDBYFLG
          Readlock [SMD]SMD0=[M:DBY0]VCRTYPORI;[M:DBY0]VCRNUMORI;[M:DBY0]VCRLINORI
          If fstat = 1
             GOK = -1
             GLOCK = "$SMVTD"-[M:DBY0]VCRNUMORI-num$([M:DBY0]VCRLINORI)
             Return
          Elsif fstat
             GOK =  0
             Call RSTA ("SMD",[M:DBY0]VCRNUMORI-num$([M:DBY0]VCRLINORI)) From GLOCK
             Return
          Endif

          [F:SMD]VCRTYPORI = [M:DBY0]VCRTYP
          [F:SMD]VCRNUMORI = [M:DBY0]VCRNUM
          [F:SMD]VCRLINORI = 1

          If [F:SMD]QTYPCUORI = 0
             [F:SMD]QTYPCUORI = [F:SMD]QTYPCU
          Endif
          If [F:SMD]QTYSTUORI = 0
             [F:SMD]QTYSTUORI = [F:SMD]QTYSTU
          Endif

          If [F:SMD]QTYSTUORI >= [M:DBY0]QTYSTU(0)
             [F:SMD]QTYSTUORI -= [M:DBY0]QTYSTU(0)
          Else
             [F:SMD]QTYSTUORI =  0
          Endif
          If [F:SMD]QTYPCUORI >= [M:DBY0]QTYPCU(0)
             [F:SMD]QTYPCUORI -= [M:DBY0]QTYPCU(0)
          Else
             [F:SMD]QTYPCUORI =  0
          Endif
          If [F:SMD]QTYSTUORI =  0 | [F:SMD]QTYPCUORI =  0
             WDBYFLG = 2
          Endif
          Rewrite [SMD]
          If fstat
             GOK=0
             Call FSTA("SMD") From GLOCK
             Return
          Endif
      # mise à jour vcrtypori vcrnumori vcrlinori dbyflg

          Update [SMH] Where STOFCY = [M:DBY0]STOFCY    &
&                            VCRTYP = [M:DBY0]VCRTYPORI &
&                            VCRNUM = [M:DBY0]VCRNUMORI
&         With  VCRTYPORI = [M:DBY0]VCRTYP , VCRNUMORI = [M:DBY0]VCRNUM , DBYFLG = WDBYFLG
          If fstat
             GOK=0  : Call FSTA("SMH") From GLOCK
          Endif
# hcb 22993 fin
   Endif
Endif

Return

$MODIF

Gosub MODIF From TABLEAUX
#annulation des lignes de composants
Delete [F:SMD] Where VCRTYP     = [F:SMH]VCRTYP      &
&                    VCRNUM     = [F:SMH]VCRNUM    &
&                    LINTYP     = 2

#annulation des sections lignes de composants
Delete [F:CAL] Where VCRTYP     = [F:SMH]VCRTYP      &
&                    VCRNUM     = [F:SMH]VCRNUM      &
&                    VCRLIN     <> 1                 &
&                    ABRFIC     = "SMD"

# creation des lignes de composants
Local Integer I
Local Integer WVCRLIN
WVCRLIN = 1000

For I = 0 To [M:DBY1]NBLIG-1
    If [M:DBY1]QTYSTU <> 0
       Raz [F:SMD]
       [F:SMD]VCRLINPNT = 1
       [F:SMD]PNTMVTCOD = 0                # hcb 28649
       [F:SMD]VCRTYP    = [F:SMH]VCRTYP
       [F:SMD]VCRNUM    = [F:SMH]VCRNUM
       [F:SMD]VCRLIN    = [M:DBY1]VCRLIN    (I)
       [F:SMD]ITMREF    = [M:DBY1]ITMREF    (I)
       [F:SMD]PRIORD    = [M:DBY1]PRIORD    (I)
       [F:SMD]ITMDES1   = [M:DBY1]ITMDES1   (I)
       [F:SMD]PCU       = [M:DBY1]PCU       (I)
       [F:SMD]QTYPCU    = [M:DBY1]QTYPCU    (I)
       [F:SMD]PCUSTUCOE = [M:DBY1]PCUSTUCOE (I)
       [F:SMD]STU       = [M:DBY1]STU       (I)
       [F:SMD]QTYSTU    = [M:DBY1]QTYSTU    (I)
       [F:SMD]LINTYP    = 2
       [F:SMD]BOMALT    = [M:DBY0]BOMALT
       [F:SMD]CREDAT    = date$
       [F:SMD]CREUSR    = GUSER
       If [M:DBY0]VCRNUMORI <> ""
          If [M:DBY1]LO (I) <> 0
             [F:SMD]VCRNUMORI = [M:DBY0]VCRNUMORI
             [F:SMD]VCRTYPORI = [M:DBY0]VCRTYPORI
             [F:SMD]VCRLINORI = [M:DBY1]LO (I)
          Endif
       Endif
#       Local Integer Y
#       For Y=1 To GOPTCANA
#           Assign "[F:SMD]CCE"+num$(Y) With evalue("[M:DBY1]CCE"+num$(Y)+"(I)")
#       Next

       Write [SMD]
       If fstat
          GOK = 0
          Call FSTA("SMD") From GLOCK
          Break
       Endif
# maj section composant
       Gosub MAJPID_CPTANALIN_CPT : If GOK<1  Return : Endif     # Ana

       If [M:DBY1]CREFLG(I) = 0 & [M:DBY1]STOMGTCOD (I) > 1              # hcb 28654
           Call ALISTW (I) From SUBDBYA
       Endif

    Endif
Next

Return

$ANNULE
    Gosub ANNULE From TABLEAUX
Return

$INICRE_LIG

[F:SMD]VCRTYP    = [F:SMH]VCRTYP
[F:SMD]VCRNUM    = [F:SMH]VCRNUM
[F:SMD]LINTYP    = 1              # Composé
[F:SMD]VCRLIN    = 1              # on force a 1
[F:SMD]PNTMVTCOD = [F:SRT]PNTMVTCOD     # hcb 28649
# Alimentation dépôt ligne si renseigné
If dim([M:DBY0]WRH)>0 & [M:DBY0]WRH(nolign-1)<>""
  [F:SMD]WRH = [M:DBY0]WRH(nolign-1)
Else
  [F:SMD]WRH = ""
Endif

Return

$VALLIG
If [M:DBY0]PNTMVTCOD <> 1               # hcb 28649
   If SIGN=1
       Call ALISTWSOR (nolign-1) From SUBDBYA   # Mvt sortie
   Endif
# maj section composé
   Gosub MAJPID_CPTANALIN_CPE : If GOK<1  Return : Endif     # Ana
Endif                                   # hcb 28649
Return

$APRES_CRE
Gosub APRES_ENR
Return

$APRES_MOD
Gosub APRES_ENR
Return

$APRES_ENR
    Local Integer LRET
    Call STKDELRES(0,[M:DBY0]STOFCY,"",LRET) From STKLOC
    #----- Relecture transaction de saisie  -----#
    If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GDBYNUM                   # hcb 50197
       Read [SRT]SRT0=7;GDBYNUM : If fstat Raz [F:SRT] : Endif
    Endif

    #--- Impression des étiquettes uniquement sur les entrées ----#
    If [F:SRT]PRNCOD1 > 1
        Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
        WPARAM(1) = [M:DBY0]STOFCY
        WPARAM(2) = num$([M:DBY0]VCRTYP)
        WPARAM(3) = [M:DBY0]VCRNUM
        Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif

    #---- Régularisation des mouvements et alloc -----#
    Call REGFROMENT( 0, "DBY1", "[M:DBY1]CREFLG(I)=0", "ITMREF", [M:DBY0]STOFCY ) From TRTSHTCOM

    Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC

    Gosub LIENS
Return

$AB_CREATION
    Effzo [M:DBY0]VCRNUM
    If !GIMPORT & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$AB_MODIF
    If !GIMPORT & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return


$APRES_MODIF
If GSAISTOFCY = 2                    # hcb 107851
   Gosub TIROIR From SUBDBYA         # hcb 107851
Endif                                # hcb 107851

    If GRELITSMR
        Gosub RELIT From GOBJSUB
        Raz GRELITSMR
        OK=0
    Endif
Return

$ABANDON
Local Integer WRET
Actzo [M:DBY0]VCRNUM
Actzo [M:DBY0]STOFCY
Actzo [M:DBY0]TRSFAM
Actzo [M:DBY0]PJT

Gosub DEPICK From GSAISIE
Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT
Call DELSTOSORW(-1,-1,"DBY0",[M:DBY0]STOFCY,WRET) From STKSOR
#----- Mise à jour des listes de gauche picking -----#
If GREP="C" & !GIMPORT & BOUT="A" Raz [M:DBY0] : Gosub TIROIR : Endif

Return

$FERME
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATDBY) > 0
   Kill GCTRDATDBY
Endif
If GCONSULT <>2      # hcb 22993
    Kill GRELITSMR
    Kill GVCRTYP
    Kill GVCRNUM
Endif                # hcb 22993
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

Raz GORITITCOL                                         # Ana

Return




#########################################################################
# CHARG_PARAM_STOENT           chargement blocs entete parametrage STOENT
#########################################################################

Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer LLIG
Variable Integer LRET
[M:ENT]STOFCY    = [M:DBY0]STOFCY
[M:ENT]ITMREF    = [M:DBY1]ITMREF   (LLIG)
[M:ENT]QTYTOENT  = [M:DBY1]QTYPCU   (LLIG)
[M:ENT]PCUTOENT  = [M:DBY1]PCU      (LLIG)
[M:ENT]COETOENT  = [M:DBY1]PCUSTUCOE(LLIG)
[M:ENT]STU       = [M:DBY1]STU      (LLIG)
[M:ENT]VCRTYP    = 32
[M:ENT]VCRNUM    = [M:DBY0]VCRNUM
[M:ENT]VCRLIN    = [M:DBY1]VCRLIN   (LLIG)
[M:ENT]WSTOSEQ   = [M:DBY1]WSTOSEQ  (LLIG)
[M:ENT]MVTDES    = [M:DBY1]MVTDES   (LLIG)
[M:ENT]PRI       = [M:DBY1]PRIORD   (LLIG)
[M:ENT]QUAFLG    = [M:DBY1]QUAFLG   (LLIG)       # hcb V6CQ
[M:ENT]QUAFRE    = [M:DBY1]QUAFRE   (LLIG)       # hcb V6CQ
#                                                              # hcb 71276 deb
If dim([M:DBY1]ECCVALMAJORI)>0
   [M:ENT]ECCVALMAJORI  = [M:DBY1]ECCVALMAJORI(LLIG)   # version majeure origine
   [M:ENT]ECCVALMINORI  = [M:DBY1]ECCVALMINORI(LLIG)   # version mineure origine
   [M:ENT]ECCBOMFLG     = [M:DBY1]ECCSAIFLG   (LLIG)# origine nomenclature
Endif
[M:ENT]TYPBPR    = 1
#                                                          # hcb 71276 fin

If dim([M:DBY1]WRH)>0
  [M:ENT]XWRH    = [M:DBY1]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 1
[M:ENT]TYPBPR    = 1                        # hcb 71276
[M:ENT]TRSCOD    = [M:DBY0]TRSCOD     # code mouvement
[M:ENT]TRSFAM    = [M:DBY0]TRSFAM     # famille mouvement
[M:ENT]IPTDAT    = [M:DBY0]IPTDAT     # date imputation
# sert pour le picking assemblage
[M:ENT]STOFCYORI = [M:DBY0]STOFCYORI
[M:ENT]VCRTYPORI = [M:DBY0]VCRTYPORI
[M:ENT]VCRNUMORI = [M:DBY0]VCRNUMORI
[M:ENT]VCRLINORI = [M:DBY1]LO(LLIG)
[M:ENT]CUR       = GLOCALDEV
[M:ENT]BPRNUM    = ""
[M:ENT]CCECODS   = [F:DTR]STOCCECOD

End

#########################################################################
# CHARG_PARAM_STOENTM         chargement blocs entete parametrage STOENTM
#########################################################################

Subprog CHARG_PARAM_STOENTM(LLIG)
Value Integer LLIG
[M:ENM]STOFCY    = [M:DBY0]STOFCY
[M:ENM]ITMREF    = [M:DBY1]ITMREF   (LLIG)
[M:ENM]QTYTOENT  = [M:DBY1]QTYPCU   (LLIG)
[M:ENM]PCUTOENT  = [M:DBY1]PCU      (LLIG)
[M:ENM]COETOENT  = [M:DBY1]PCUSTUCOE(LLIG)
[M:ENM]STU       = [M:DBY1]STU      (LLIG)
[M:ENM]VCRNUM    = [M:DBY0]VCRNUM
[M:ENM]VCRLIN    = [M:DBY1]VCRLIN   (LLIG)
[M:ENM]MVTDES    = [M:DBY1]MVTDES   (LLIG)
[M:ENM]QUAFLG    = [M:DBY1]QUAFLG   (LLIG)       # hcb V6CQ
[M:ENM]QUAFRE    = [M:DBY1]QUAFRE   (LLIG)       # hcb V6CQ
If dim([M:DBY1]WRH)>0
  [M:ENM]XWRH    = [M:DBY1]WRH(LLIG)
Endif
[M:ENM]PJT       = [M:DBY0]PJT
[M:ENM]TRSTYP    = 1                        # entree diverse
[M:ENM]TRSCOD    = [M:DBY0]TRSCOD           # code mouvement
[M:ENM]TRSFAM    = [M:DBY0]TRSFAM           # famille mouvement
[M:ENM]IPTDAT    = [M:DBY0]IPTDAT           # date imputation
[M:ENM]ENTCOD    = [M:DBY0]ENTCOD           # Code pièce auto   # hcb 114384


#                                                              # hcb 71276 deb
If dim([M:DBY1]ECCVALMAJORI)>0
   [M:ENM]ECCVALMAJORI  = [M:DBY1]ECCVALMAJORI(LLIG)   # version majeure origine
   [M:ENM]ECCVALMINORI  = [M:DBY1]ECCVALMINORI(LLIG)   # version mineure origine
   [M:ENM]ECCBOMFLG     = [M:DBY1]ECCSAIFLG   (LLIG)   # origine nomenclature
Endif
[M:ENM]TYPBPR    = 1
#                                                          # hcb 71276 fin

End




########################################################################
# PICKE_BBY          Chargement DBY0 et DBY1 suite à picking Assemblage
########################################################################
$PICKE_BBY
If [M:DBY0]VCRNUMORI <> ""
    OK=0 : GERR=1
#un sassemblage est deja reference !
    Call ERREUR(mess(87,184,1)) From GESECRAN
    Return
Endif

# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
Local Integer WRET

Read [SMD]SMD0=[F:SMH]VCRTYP;[F:SMH]VCRNUM;1
If fstat
   Return
Endif


[M:DBY0]BOMFLG(0) = 2
[M:DBY0]UPDFLG(0) = 0
[M:DBY0]CREFLG(0) = 0
[M:DBY0]CFMCOD(0) = 1
[M:DBY0]CFMFLG(0) = 2
[M:DBY0]NBLIG     = 1

If [F:SMD]PNTMVTCOD <> 1                      # 28649
   [M:ALP]TRSTYP     = 2
   [M:ALP]TRSCOD     = [M:DBY0]TRSCOD
   [M:ALP]VCRTYP     = 31
   [M:ALP]VCRNUM     = [F:SMH]VCRNUM
   [M:ALP]VCRLIN     = [F:SMD]VCRLIN
   [M:ALP]VCRSEQ     =  0
   [M:ALP]STOFCY     = [M:DBY0]STOFCY
   [M:ALP]ITMREF     = [F:SMD]ITMREF
   If [F:SMD]QTYSTUORI = 0                 # hcb 22993
      [F:SMD]QTYSTUORI = [F:SMD]QTYSTU     # hcb 22993
   Endif                                   # hcb 22993
   [M:ALP]QTY        = [F:SMD]QTYSTUORI    # hcb 22993
   [M:ALP]TYPQTY     = 1
   [M:ALP]STA        = ""

   Call STJSTOSORW ("DBY0",0,[M:DBY0]NBLIG,WRET) From STKSOR
   If WRET <> 0
      OK=0 : GERR=1
      Return
   Endif

   If [M:ALP]ALLQTY <> [F:SMD]QTYSTUORI
      OK=0 : GERR=1
      Local Char MES(255)
      MES = mess(236,184,1)+"\"              #Désassemblage impossible ! La situation de l assemblage ne le permet pas :
      If find(GSTJINFO,0)
         MES += "  - "-mess(333,184,1)+"\"   # Mouvement d origine non trouvé     # hcb 107851
      Endif
      If find(GSTJINFO,1,3,5,7,9,11,13,15)
         MES += "  - "-mess(233,184,1)+"\"   # Lignes(s) des stock en inventaire(s)
      Endif
      If find(GSTJINFO,2,3,6,7,10,11,14,15)
         MES += "  - "-mess(234,184,1)+"\"   # Statut(s) de stock non autorisé(s)
      Endif
      If find(GSTJINFO,4,5,6,7,12,13,14,15)
         MES += "  - "-mess(235,184,1)+"\"   # Demandes(s) analyse en cours
      Endif
      If find(GSTJINFO,8,9,10,11,12,13,14,15)
         MES += "  - "-mess(367,199,1)+"\"   # Pas de stock disponible
      Endif
      Call MESSAGE(MES) From GESECRAN
      Return
   Endif

   Raz GRELITSMR
   Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT

   [M:DBY0]       = [F:SMD]                   # hcb 28649
   [M:DBY0]PJT    = [F:SMH]PJT                # hcb 28649
    ############################### sections ligne composé  Ana
    Call CHARG_ACCCCE(0,"","","[M:DBY0]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT

# sert pour le picking assemblage
   [M:DBY0]STOFCYORI = [M:DBY0]STOFCY         # hcb 28649
   [M:DBY0]VCRTYPORI = [F:SMH]VCRTYP          # hcb 28649
   [M:DBY0]VCRNUMORI = [F:SMH]VCRNUM          # hcb 28649
   [M:DBY0]VCRLINORI = [F:SMD]VCRLIN          # hcb 28649

   Call RECSTOSOR (!([M:DBY0]CFMFLG)+1, "DBY0",0,[M:DBY0]STOFCY,[M:DBY0]ITMREF(0),[M:DBY0]VCRTYPORI,
&                    [M:DBY0]VCRNUMORI,[F:SMD]VCRLIN,"",WRET) From STKECR
Else
   [M:DBY0]PNTMVTLIB  = mess(224,184,1)       # hcb 28649
   [M:DBY0]       = [F:SMD]                   # hcb 28649
   [M:DBY0]PJT    = [F:SMH]PJT                # hcb 28649
    ############################### sections ligne composant  Ana   deb
   Call CHARG_ACCCCE(0,"","","[M:DBY0]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT

# sert pour le picking assemblage
   [M:DBY0]STOFCYORI = [M:DBY0]STOFCY         # hcb 28649
   [M:DBY0]VCRTYPORI = [F:SMH]VCRTYP          # hcb 28649
   [M:DBY0]VCRNUMORI = [F:SMH]VCRNUM          # hcb 28649
   [M:DBY0]VCRLINORI = [F:SMD]VCRLIN          # hcb 28649
Endif                                         # hcb 28649

Actzo [M:DBY0]                                # hcb 28649

Grizo [M:DBY0]STOFCY                          # hcb 28649
Grizo [M:DBY0]PJT                             # hcb 28649
Grizo [M:DBY0]TRSFAM                          # hcb 28649
Grizo [M:DBY0]ENTCOD                          # hcb 28649


#[M:DBY0]QTYSTUORI (0) =  [F:SMD]QTYSTU       # hcb 28649


If [F:SMD]QTYPCUORI  = 0                      # hcb 22993
   [F:SMD]QTYPCUORI  = [F:SMD]QTYPCU          # hcb 22993
Endif                                         # hcb 22993
If [F:SMD]QTYSTUORI  = 0                      # hcb 22993
   [F:SMD]QTYSTUORI  = [F:SMD]QTYSTU          # hcb 22993
Endif                                         # hcb 22993
[M:DBY0]QTYPCU(0)    = [F:SMD]QTYPCUORI       # hcb 22993
[M:DBY0]QTYSTU(0)    = [F:SMD]QTYSTUORI       # hcb 22993
[M:DBY0]QTYSTUORI(0) = [M:DBY0]QTYSTU(0)      # hcb 22993
[M:DBY0]QTYPCUORI(0) = [M:DBY0]QTYPCU(0)      # hcb 22993



Raz [M:DBY0]VCRNUM
If GSTKCPTMAN(17)<>2
   Effzo [M:DBY0]VCRNUM
   Diszo [M:DBY0]VCRNUM
Endif
#Diszo [M:DBY0]                              # hcb 22993
Gosub DESASSEMBLAGE_PARTIEL                  # hcb 22993
Diszo [M:DBY0]VCRNUMORI # diszo pour conserver les menus contextuels   hcb 22993

Affzo [M:DBY0]

# chargement tableau composants (entrées)

WMAX = dim([M:DBY1]ITMREF)     # mémorisation nombre de ligne maxi
Raz [M:DBY1]
nolign = 1
Filter [SMD] Where VCRTYP = [M:DBY0]VCRTYPORI   &
&                  VCRNUM = [M:DBY0]VCRNUMORI   &
&                  LINTYP = 2
&            Order By Key SMD0
For [SMD]
    If nolign = WMAX : Break : Endif

    [M:DBY1]VCRLIN    (nolign-1) =  [F:SMD]VCRLIN
    [M:DBY1]FLT       (nolign-1) = "[F:STJ]VCRLIN="+num$([M:DBY1]VCRLIN(nolign-1))

    [M:DBY1]ITMREF    (nolign-1) =  [F:SMD]ITMREF
    [M:DBY1]ITMDES1   (nolign-1) =  [F:SMD]ITMDES1
    [M:DBY1]PCU       (nolign-1) =  [F:SMD]PCU
    [M:DBY1]QTYPCU    (nolign-1) =  [F:SMD]QTYPCU
    [M:DBY1]PCUSTUCOE (nolign-1) =  [F:SMD]PCUSTUCOE
    [M:DBY1]STU       (nolign-1) =  [F:SMD]STU
    [M:DBY1]QTYSTU    (nolign-1) =  [F:SMD]QTYSTU
    [M:DBY1]PRIORD    (nolign-1) =  [F:SMD]PRIORD
    If dim([M:DBY1]WRH)> 0                                 # hcb 71295
       [M:DBY1]WRH    (nolign-1) =  [F:SMD]WRH             # hcb 71295
    Endif                                                  # hcb 71295

#   [M:DBY1]QTYSTUORI (nolign-1) =  [F:SMD]QTYSTU          # hcb 22993


    If [F:SMD]QTYPCUORI  = 0                               # hcb 22993
       [F:SMD]QTYPCUORI  = [F:SMD]QTYPCU                   # hcb 22993
    Endif                                                  # hcb 22993
    If [F:SMD]QTYSTUORI  = 0                               # hcb 22943
       [F:SMD]QTYSTUORI  = [F:SMD]QTYSTU                   # hcb 22993
    Endif                                                  # hcb 22993
    [M:DBY1]QTYPCU(nolign-1)    = [F:SMD]QTYPCUORI         # hcb 22993
    [M:DBY1]QTYSTU(nolign-1)    = [F:SMD]QTYSTUORI         # hcb 22993
    [M:DBY1]QTYSTUORI(nolign-1) = [M:DBY1]QTYSTU(nolign-1) # hcb 22993

    [M:DBY1]CREFLG    (nolign-1) =  0
    [M:DBY1]LO        (nolign-1) = [F:SMD]VCRLIN
    ############################### sections ligne composant  Ana   deb
    Call CHARG_ACCCCE(nolign-1,"","","[M:DBY1]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT

    Call STJSTOENTW("DBY1",1,32,[M:DBY0]IPTDAT,nolign-1,[M:DBY1]NBLIG+1,"SRT",0,WRET) From STKENT
    If WRET
      Raz [M:DBY1]WSTOFLG(nolign-1), [M:DBY1]QTYPCU(nolign-1), [M:DBY1]QTYSTU(nolign-1)
      [M:DBY1]WSTOSAI(nolign-1)="2222222222222"
    Endif

    If [F:ITM]ITMREF<>[M:DBY1]ITMREF(nolign-1)
       Read [F:ITM]ITM0 = [M:DBY1]ITMREF(nolign-1)
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    [M:DBY1]STOMGTCOD (nolign-1) =  [F:ITM]STOMGTCOD            # hcb 28654
    If [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
       If [F:ITF]STOFCY <> [M:DBY0]STOFCY | [F:ITF]ITMREF <> [M:DBY1]ITMREF(nolign-1)
          Read [ITF]ITF0 = [M:DBY1]ITMREF(nolign-1);[M:DBY0]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif
       [M:DBY1]STOMGTCOD (nolign-1) =  [F:ITF]STOMGTCOD            # hcb 28654
    Endif

#    [M:DBY1]STOMGTCOD (nolign-1) = [F:ITF]STOMGTCOD            # hcb 28654

    Call LOAD_FROM_ENTW("DBY1",nolign-1,[M:DBY0]STOFCY, [M:DBY1]WSTOSEQ(nolign-1), [M:DBY1]ITMREF(nolign-1), 32 )  From STKENT
# hcb 28654 deb
    If [M:DBY1]STOMGTCOD (nolign-1) > 1
       If dim([M:DBY1]QTYPCU)>0
          Diszo [M:DBY1]QTYPCU(nolign-1)
       Endif
       If dim([M:DBY1]PRIORD)>0
          Diszo [M:DBY1]PRIORD(nolign-1)
       Endif
    Endif
# hcb 28654 fin

    [M:DBY1]NBLIG  = nolign
    nolign += 1
Next
Filter [SMD]



Call STKDISCOL("DBY1",[M:DBY1]NBLIG) From STKECR
Diszo [M:DBY1]ITMREF,ITMDES1
Actzo [M:DBY1]ITMREF([M:DBY1]NBLIG),ITMDES1([M:DBY1]NBLIG)
If dim([M:DBY1]PCU)>0
       Diszo [M:DBY1]PCU
#       Diszo [M:DBY1]QTYPCU
       Actzo [M:DBY1]PCU([M]NBLIG)
       Actzo [M:DBY1]QTYPCU([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]PCUSTUCOE)>0
        Diszo [M:DBY1]PCUSTUCOE
        Actzo [M:DBY1]PCUSTUCOE([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]STU)>0
        Diszo [M:DBY1]STU
        Diszo [M:DBY1]QTYSTU
        Actzo [M:DBY1]STU([M:DBY1]NBLIG)
        Actzo [M:DBY1]QTYSTU([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]PRIORD)>0
#        Diszo [M:DBY1]PRIORD
        Actzo [M:DBY1]PRIORD([M:DBY1]NBLIG)
Endif
If dim([M:DBY1]MVTDES)>0
        Diszo [M:DBY1]MVTDES
        Actzo [M:DBY1]MVTDES([M:DBY1]NBLIG)
Endif

Affzo [M:DBY1]

Return

########################################################################
# DEPICK_BBY      deChargement DBY0 et DBY1 suite à depicking Assemblage
########################################################################
$DEPICK_BBY
Local Char WFCY
WFCY = [M:DBY0]STOFCY
Raz [M:DBY0]
Raz [M:DBY1]
[M:DBY0]STOFCY = WFCY
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GDBYNUM                   # hcb 50197
   Read [SRT]SRT0=7;GDBYNUM : If fstat Raz [F:SRT] : Endif
Endif

If GSTKCPTMAN(17)<>2
   Effzo [M:DBY0]VCRNUM
   Diszo [M:DBY0]VCRNUM
Endif
Actzo [M:DBY0]STOFCY
Actzo [M:DBY0]IPTDAT
Actzo [M:DBY0]PJT
Actzo [M:DBY0]TRSFAM
Actzo [M:DBY0]ITMREF
[M:DBY0]VCRTYP    = 32        #desassemblage
[M:DBY0]TRSTYP    = 2
[M:DBY0]TRSTYPC   = 1
[M:DBY0]CFMFLG    = 2
[M:DBY0]TRSCOD    = [F:SRT]TRSCOD
[M:DBY0]TRSFAM    = [F:SRT]TRSFAMDEF
[M:DBY0]PNTMVTCOD = [F:SRT]PNTMVTCOD           # hcb 50197
[M:DBY0]SRGWAIFLG = [F:SRT]SRGWAIFLG           # hcb 50197
[M:DBY0]MVTPRICOD = [F:SRT]MVTPRICOD           # hcb 50197
[M:DBY0]STKFLG    = [F:SRT]STKFLG              # hcb 50197

Affzo [M:DBY0]TRSFAM
[M:DBY0]ENTCOD = [F:SRT]ENTCOD
If [M:DBY0]STOFCY = ""
   [M:DBY0]STOFCY = GFCYDEF(7)
Endif
[M:DBY0]CCECODS   = [F:DTR]HEACCECOD
Local Char SECTION
For Y=1 To GNBDIE
    Call INISEC(SECTION, "STKDBYH", Y) From TRTX3CPT
    [M:DBY0]CCE(Y-1) =  SECTION
    [F:SMH]CCE(Y-1)  =  SECTION
Next

Affzo [M:DBY0]
Affzo [M:DBY1]
Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT
Call DELSTOSORW(-1,-1,"DBY0",[M:DBY0]STOFCY,WRET) From STKSOR
Call RAZSTOSORW From STKSOR

Gosub DEPICK From GSAISIE

Return


########################################################################
# MAJ_LIGNE_DOCUMENT          Mise à jour des quantités entrée SAISTOENT
########################################################################
$MAJ_LIGNE_DOCUMENT
# Vérifie que le coefficient UC/US peut être modifié,
# que le coef est unique (>0)
# et que l'unité est unique
[M:DBY1]QTYSTU(LLIGDOC) = LQTYSTU
If  LCOEF>0 & LPCU<>""
    [M:DBY1]PCU(LLIGDOC)       = LPCU
    [M:DBY1]PCUSTUCOE(LLIGDOC) = LCOEF
    [M:DBY1]QTYPCU(LLIGDOC)    = LQTYSTU / LCOEF
Else    # Met tout en US
    [M:DBY1]PCU(LLIGDOC)       = [M:DBY1]STU(LLIGDOC)
    [M:DBY1]PCUSTUCOE(LLIGDOC) = 1
    [M:DBY1]QTYPCU(LLIGDOC)    = LQTYSTU
Endif
Affzo [M:DBY1]QTYSTU(LLIGDOC), PCU(LLIGDOC), QTYPCU(LLIGDOC), PCUSTUCOE(LLIGDOC)

Return

########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

# Mise à jour des quantités
Gosub MAJ_LIGNE_DOCUMENT

#-- Maj du détail entrées
# 1- Locker l'enregistrement de la ligne de document
Readlock [SMD]SMD0=[M:DBY0]VCRTYP;[M:DBY0]VCRNUM;[M:DBY1]VCRLIN(LLIGDOC)
If fstat = 1
   GOK = -1
   GLOCK = "$SMVTD"-[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(LLIGDOC))
   Return
Elsif fstat
   GOK =  0
   Call RSTA ("SMD",[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(LLIGDOC))) From GLOCK
   Return
Endif

# 2- Si la nouvelle quantité est nulle...
If [M:DBY1]QTYSTU (LLIGDOC) = 0
    # ... supprimer la ligne ...
    Delete [SMD]
    #----- Suppression  sections de la ligne de document  -----#     # ana
   Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
   If fstat=1                                                                                           # ana
      GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
   Endif                                                                                                # ana

Else
    # 3- Si la nouvelle quantité n'est pas nulle enregistrer cette nouvelle quantité
    [F:SMD]QTYPCU = [M:DBY1]QTYPCU (LLIGDOC)
    [F:SMD]QTYSTU = [M:DBY1]QTYSTU (LLIGDOC)
    Rewrite [SMD]
Endif
# 4- Délocker l'enregistrement
If fstat
    GOK=0
    Call FSTA("SMD") From GLOCK
    Return
Endif

GRELITSMR = 1

Return




################################################
# Alimente le masque STOWORK entré
# Ce sous programme est à appeler sur les actions:
#    VALLIG
################################################
Subprog ALISTW( NOL )
Value Integer NOL

Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
Raz [M:STW]
[M:STW]STOFCY     = [M:DBY0]STOFCY      # Site
[M:STW]TRSTYP     = [M:DBY0]TRSTYPC     # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:DBY0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:DBY0]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = [M:DBY1]VCRLIN(NOL) # Numero ligne pièce
If [M:DBY0]VCRNUMORI <> ""
    If [M:DBY1]LO (NOL) <> 0
       [M:STW]VCRTYPORI  = [M:DBY0]VCRTYPORI   # Type pièce (M.701)
       [M:STW]VCRNUMORI  = [M:DBY0]VCRNUMORI   # Numéro pièce
       [M:STW]VCRLINORI  = [M:DBY1]LO(NOL) # Numero ligne pièce
    Endif
Endif
[M:STW]ITMREF     = [M:DBY1]ITMREF(NOL) # Article
[M:STW]MVTDES     = [M:DBY1]MVTDES(NOL) # Désignation mouvement
[M:STW]PRIORDH    = [M:DBY1]PRIORD(NOL) # Prix de l'ordre
[M:STW]PJT        = [M:DBY0]PJT         # Affaire
[M:STW]TRSFAM     = [M:DBY0]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:DBY0]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:DBY0]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:DBY0]TRSCOD      # Code mouvement
[M:STW]CCECOD     = "STJEND"            # CODE section analytique stock entrée
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""

Call ALISTOWORK( 2, [M:DBY1]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
If LRET<>0 End Endif


Call MAJ_STOCK From STKMAJ
If GOK
    Call STKFREQCQ("DBY1",[M:DBY0]STOFCY,NOL,[M:DBY1]ITMREF(NOL),"","V",[M:DBY1]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
Endif

End



########################################################################
# ECRAN DBY0   Composants Sortie
########################################################################


#########################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP

[M:ALP]TRSTYP     = [M:DBY0]TRSTYP
[M:ALP]TRSCOD     = [M:DBY0]TRSCOD
[M:ALP]VCRTYP     = 31
[M:ALP]STOFCY     = [M:DBY0]STOFCY
[M:ALP]ITMREF     = [M:DBY0]ITMREF(NOL)
[M:ALP]PCU        = [M:DBY0]PCU(NOL)
[M:ALP]PCUSTUCOE  = [M:DBY0]PCUSTUCOE(NOL)
[M:ALP]QTY        = [M:DBY0]QTYSTU(NOL)
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [M:DBY0]IPTDAT
[M:ALP]DLVDAT     = [M:DBY0]IPTDAT
Raz [M:ALP]ALLDAT
Raz [M:ALP]STOLOC
[M:ALP]PECINTLOC  = 2
[M:ALP]PECSCOLOC  = 1
[M:ALP]PECPLFLOC  = 2
[M:ALP]PECCUNLOK  = 1
[M:ALP]PECOWNER   = ""
Raz [M:ALP]FILSTO
#--- Bug 90028
Raz [M:ALP]ALLQTY

If dim([M:DBY0]LOT) > 0
   [M:ALP]LOT        = [M:DBY0]LOT(NOL)
Endif
If dim([M:DBY0]LOC) > 0
   [M:ALP]LOC        = [M:DBY0]LOC(NOL)
Endif
[M:ALP]STA        = [M:DBY0]STA(NOL)
[M:ALP]PECQLYCTL  = 1
If dim([M:DBY0]WRH)>0 [M:ALP]WRH=[M:DBY0]WRH(NOL) Endif
If dim([M:DBY0]ECCVALMAJ)>0 [M:ALP]ECCVALMAJ=[M:DBY0]ECCVALMAJ(NOL) Endif      # hcb 71276

Return

################################################
# Alimente le masque STOWORK sortie
################################################
Subprog ALISTWSOR( NOL )
Value Integer NOL  # FGR 01/02/2010 : X3SUIVI60986

Local Integer WRET
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:DBY0]STOFCY      # Site
[M:STW]TRSTYP     = [M:DBY0]TRSTYP      # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:DBY0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:DBY0]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = [M:DBY0]VCRLIN(NOL) # Numero ligne pièce
[M:STW]VCRTYPORI  = [M:DBY0]VCRTYPORI   # Type pièce (M.701)
[M:STW]VCRNUMORI  = [M:DBY0]VCRNUMORI   # Numéro pièce
If [M:DBY0]VCRNUMORI <> ""
   [M:STW]VCRLINORI  = 1                # Numero ligne pièce
Endif
[M:STW]ITMREF     = [M:DBY0]ITMREF(NOL) # Article
[M:STW]MVTDES     = [M:DBY0]MVTDES(NOL) # Désignation mouvement
[M:STW]PRIORDH    = 0
[M:STW]PJT        = [M:DBY0]PJT         # Affaire
[M:STW]TRSFAM     = [M:DBY0]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:DBY0]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:DBY0]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:DBY0]TRSCOD      # Code mouvement
[M:STW]CCECOD     = "STJSOR"            # CODE section analytique stock sortie
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""

Call ALISTOWORK( 3, [M:DBY0]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, WRET ) From STKINT
If WRET<>0
   Raz GOK : End  # hcb 62219
Endif

Call MAJ_STOCK From STKMAJ

End




#########################################################################
$CHARGE_STOSOR
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
#-----------------------------------------------------------------------#
[M:SOR]WSTOSEQ   = [M:DBY0]WSTOSEQ(LNOL)
[M:SOR]TRSTYP    = [M:DBY0]TRSTYP
[M:SOR]TRSCOD    = [M:DBY0]TRSCOD
[M:SOR]TRFFCY    = ""
[M:SOR]VCRTYP    = 32
[M:SOR]VCRNUM    = [M:DBY0]VCRNUM
[M:SOR]VCRLIN    = [M:DBY0]VCRLIN(LNOL)
[M:SOR]MVTDES    = [M:DBY0]MVTDES(LNOL)
[M:SOR]STU       = [M:DBY0]STU(LNOL)
[M:SOR]PCU       = [M:DBY0]PCU(LNOL)
[M:SOR]PCUSTUCOE = [M:DBY0]PCUSTUCOE(LNOL)
[M:SOR]SORQTY    = [M:DBY0]QTYSTU(LNOL)
[M:SOR]SORQTYACT = [M:DBY0]QTYSTU(LNOL)
If dim([M:DBY0]ECCVALMAJ)>0 [M:SOR]WECCVALMAJ= [M:DBY0]ECCVALMAJ(LNOL) Endif                       # hcb 71276

[M:SOR]RETDAT    = [M:DBY0]IPTDAT
[M:SOR]DLVDAT    = [M:DBY0]IPTDAT
[M:SOR]PECINTLOC = 2
[M:SOR]PECPLFLOC = 2
[M:SOR]PECSCOLOC = 1
[M:SOR]PECQLYCTL = 1

[M:SOR]STOLOC    = ""
[M:SOR]XLOT      = ""
[M:SOR]XLOC      = ""
[M:SOR]XSTA      = ""
[M:SOR]CUR       = GLOCALDEV
[M:SOR]BPRNUM    = ""
[M:SOR]GLOALLQTY = 0
If dim([M:DBY0]WRH)>0 [M:SOR]XWRH=[M:DBY0]WRH(LNOL) Endif
If dim([M:DBY0]ECCVALMAJ)>0 [M:SOR]WECCVALMAJ=[M:DBY0]ECCVALMAJ(LNOL) Endif            # hcb 71276

Return

#########################################################################

$CHARGE_STOSOM
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOM pour modification des    #
# sorties                                                               #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA       #
#-----------------------------------------------------------------------#
[M:SOM]TRSTYP    = [M:DBY0]TRSTYP
[M:SOM]TRSCOD    = [M:DBY0]TRSCOD
[M:SOM]TRFFCY    = ""
[M:SOM]VCRTYP    = 32
[M:SOM]VCRNUM    = [M:DBY0]VCRNUM
[M:SOM]VCRLIN    = [M:DBY0]VCRLIN(LNOL)
[M:SOM]STU       = [M:DBY0]STU(LNOL)
[M:SOM]PCU       = [M:DBY0]PCU(LNOL)
[M:SOM]PCUSTUCOE = [M:DBY0]PCUSTUCOE(LNOL)
[M:SOM]SORQTY    = [M:DBY0]QTYSTU(LNOL)
[M:SOM]SORQTYACT = [M:DBY0]QTYSTU(LNOL)
[M:SOM]DLVDAT    = [M:DBY0]IPTDAT
[M:SOM]PECINTLOC = 2
[M:SOM]PECPLFLOC = 2
[M:SOM]PECSCOLOC = 1
[M:SOM]PECQLYCTL = 1
[M:SOM]STOLOC    = ""
[M:SOM]XLOT      = ""
[M:SOM]XLOC      = ""
[M:SOM]XSTA      = ""
If dim([M:DBY0]WRH)>0 [M:SOM]XWRH=[M:DBY0]WRH(LNOL) Endif
If dim([M:DBY0]ECCVALMAJ)>0 [M:SOM]WECCVALMAJ= [M:DBY0]ECCVALMAJ(LNOL) Endif                       # hcb 71276

Return

#########################################################################
$APRES_STOSOR
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOR]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOR]SORQTY    contient la quantité US qui était à sortir
#   [M:SOR]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOR]PECQTY    contient la quantité US sortie
#   [M:SOR]PECQTYACT contient la quantité en UA sortie
#   [M:SOR]SHTQTY    contient la quantité US sortie manquante
#   [M:SOR]SHTQTYACT contient la quantité en UA sortie manquante

If WGENR=1
    [M:DBY0]QTYSTU(LNOL) = [M:SOR]PECQTYACT+[M:SOR]SHTQTY
    If [M:DBY0]PCUSTUCOE(LNOL)=0
        [M:DBY0]PCUSTUCOE(LNOL)=1
    Endif
    [M:DBY0]QTYPCU(LNOL) = [M:DBY0]QTYSTU(LNOL)/[M:DBY0]PCUSTUCOE(LNOL)
Endif

Return

#########################################################################
$APRES_STOSOM
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOM]PECQTY    contient la quantité US sortie
#   [M:SOM]PECQTYACT contient la quantité en UA sortie
#   [M:SOM]SHTQTY    contient la quantité manquante

# quantite totale à zero interdit
#-- Contrôle à faire en modif document uniquement
If [M:DBY0]CREFLG(LNOL)<>0
   If [M:SOM]PECQTY = 0
       GMESSAGE=mess(9,184,1)
       GOK =0
       mkstat = 2
    Endif
Endif

If mkstat = 2
   Call ERREUR(GMESSAGE) From GESECRAN
   GMESSAGE= ""
   Return
Endif

If WGENR=1
    [M:DBY0]QTYSTU(LNOL) = [M:SOM]PECQTYACT+[M:SOM]SHTQTY
    If [M:DBY0]PCUSTUCOE(LNOL)=0
        [M:DBY0]PCUSTUCOE(LNOL)=1
    Endif
    [M:DBY0]QTYPCU(LNOL) = [M:DBY0]QTYSTU(LNOL)/[M:DBY0]PCUSTUCOE(LNOL)
Endif


# Maj du détail sortie diverse
Readlock [SMD]SMD0=[M:DBY0]VCRTYP;[M:DBY0]VCRNUM;[M:DBY0]VCRLIN(LNOL)
If fstat = 1 GOK = -1
   GLOCK = "$SMVTD"-[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(LNOL))
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SMD",[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(LNOL))) From GLOCK
   Return
Endif

# Quantité traitée
LQTYSTU = [M:SOM]PECQTYACT + [M:SOM]SHTQTY

If LQTYSTU = 0
   LQTY = 0
Elsif LQTYSTU = [F:SMD]QTYSTU
   LQTY = [F:SMD]QTYPCU
Else
   LQTY = LQTYSTU * [F:SMD]QTYPCU / [F:SMD]QTYSTU
Endif

If LQTYSTU = 0
   Delete [SMD]
    #----- Suppression  sections de la ligne de document  -----#     # ana
   Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
   If fstat=1                                                                                           # ana
      GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
   Endif                                                                                                # ana

Else
   [F:SMD]QTYPCU = LQTY
   [F:SMD]QTYSTU = LQTYSTU
   Rewrite [SMD]
Endif
If fstat GOK=0 : Call FSTA("SMD") From GLOCK : Return Endif

GRELITSMR = 1

Return


# hcb 28649 deb
