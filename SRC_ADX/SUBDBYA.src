# hcb 22993 fin
#########################################################################
$CALCUL_PARTIEL
Local Integer WRET
Local Decimal RAPPORT

# nettoyage des ecrans de travails
Call DELSTOENTW(-1,-1,"DBY1",1,1,[M:DBY0]STOFCY,1,"") From STKENT
Call DELSTOSORW(-1,-1,"DBY0",[M:DBY0]STOFCY,WRET) From STKSOR
# nettoyages des rubriques techniques
Raz [M:DBY0]WSTOSEQ(0)
For I = 0 To [M:DBY1]NBLIG-1
    Raz [M:DBY1]WSTOSEQ(I)
    Raz [M:DBY1]WSRUFLG(I)
    Raz [M:DBY1]WSTOFLG(I)
    Raz [M:DBY1]WSTOSAI(I)
    Raz [M:DBY1]WLOCSEQ(I)
Next

# si qte origine = qte saisie  on sort
If [M:DBY0]QTYSTU (0) = [M:DBY0]QTYSTUORI (0)
   RAPPORT = 1
Else
# calcul du rapport
   If [M:DBY0]QTYSTUORI(0) = 0
      RAPPORT = 1
   Else
      RAPPORT    = [M:DBY0]QTYSTU(0) / [M:DBY0]QTYSTUORI(0)
   Endif
Endif

# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
Local Integer WRET

#Read [SMD]SMD0=[F:SMH]VCRTYP;[F:SMH]VCRNUM;1
Read [SMD]SMD0=[M:DBY0]VCRTYPORI;[M:DBY0]VCRNUMORI;1
If fstat
   Return
Endif
[M:DBY0]BOMFLG(0) = 2
[M:DBY0]UPDFLG(0) = 0
[M:DBY0]CREFLG(0) = 0
[M:DBY0]CFMCOD(0) = 1
[M:DBY0]CFMFLG(0) = 2
[M:DBY0]NBLIG     = 1

If [F:SMD]PNTMVTCOD <> 1
   [M:ALP]TRSTYP     = 2
   [M:ALP]TRSCOD     = [M:DBY0]TRSCOD
   [M:ALP]VCRTYP     = 31
   [M:ALP]VCRNUM     = [M:DBY0]VCRNUMORI
   [M:ALP]VCRLIN     = [F:SMD]VCRLIN
   [M:ALP]VCRSEQ     =  0
   [M:ALP]STOFCY     = [M:DBY0]STOFCY
   [M:ALP]ITMREF     = [F:SMD]ITMREF
   [M:ALP]QTY        = [M:DBY0]QTYSTU(0)
   [M:ALP]TYPQTY     = 1
   [M:ALP]STA        = ""

   Call STJSTOSORW ("DBY0",0,[M:DBY0]NBLIG,WRET) From STKSOR
   If WRET <> 0
      OK=0 : GERR=1
      Return
   Endif
   If [M:ALP]ALLQTY <> [M:DBY0]QTYSTU(0)
      OK=0 : GERR=1

#Désassemblage impossible ! La situation de l assemblage est changée
      Call ERREUR(mess(85,184,1)) From GESECRAN
      Return
   Endif

   Raz GRELITSMR

   Call RECSTOSOR (3, "DBY0",0,[M:DBY0]STOFCY,[M:DBY0]ITMREF(0),[M:DBY0]VCRTYPORI,
&                    [M:DBY0]VCRNUMORI,[F:SMD]VCRLIN,"",WRET) From STKECR
Endif


Affzo [M:DBY0]

# chargement tableau composants (entrées)

For I = 0 To [M:DBY1]NBLIG-1
    If [M:DBY1]QTYSTUORI(I) <> 0
       [M:DBY1]QTYSTU   (I) = RAPPORT * [M:DBY1]QTYSTUORI(I)
       Call QTEARR([M:DBY1]QTYSTU(I),[M:DBY1]STU(I)) From TRTDIV
       [M:DBY1]QTYPCU   (I) = [M:DBY1]QTYSTU    (I)

       Call STJSTOENTW("DBY1",1,32,[M:DBY0]IPTDAT,I,[M:DBY1]NBLIG+1,"SRT",0,WRET) From STKENT
       If WRET
          Raz [M:DBY1]WSTOFLG(I), [M:DBY1]QTYPCU(I), [M:DBY1]QTYSTU(I)
          [M:DBY1]WSTOSAI(I)="2222222222222"
       Endif

       Read [F:ITM]ITM0 = [M:DBY1]ITMREF(I)
       Call LOAD_FROM_ENTW("DBY1",I,[M:DBY0]STOFCY, [M:DBY1]WSTOSEQ(I), [M:DBY1]ITMREF(I), 32 )  From STKENT

#       Call RECSTO_F ("DBY1", [M:DBY0]STOFCYORI, 31,
#&          [M:DBY0]VCRNUMORI , [M:DBY1]LO(I), I, "") From STKECR
    Endif
Next


Affzo [M:DBY1]

Return

###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",7,GDBYNUM) From TRTX3CPT            # hcb 50197

Local Integer LRET
# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(17) = [F:TCA]MANCOU(17)
GSTKCPT   (17) = [F:TCA]CODNUM(17)
#Controle compteur
Call CTRCPT(GSTKCPT(17),type([M:DBY0]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(12,114,1)  # compteur inexistant
   GERR = 1
   GOK  = 0
   Return
Endif
GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)


Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL

If GSOC_UPDFLG & !GIMPORT & dim([M:DBY0]CCE1)>0
  Local Char BASPAG(10)

#                                                           composé
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT07"+GDBYNUM+"0"                 # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:DBY0]NBLIG=0
    [M:DBY0]NBLIG=1 : Affzo [DBY0]10 : Effzo [DBY0]10
  Endif
#                                                           composant
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT07"+GDBYNUM+"1"                 # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:DBY1]NBLIG=0
    [M:DBY1]NBLIG=1 : Affzo [DBY1]5 : Effzo [DBY1]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

#----------------------------------------------------------#
# Ecriture des comptes et sections de la ligne de document composé #
#----------------------------------------------------------#
$MAJPID_CPTANALIN_CPE
Local Integer Z
#-----
If TRTLIG="M"
  Readlock [CAL] CAL0="SMD";[F:SMD]VCRTYP;[F:SMD]VCRNUM;[F:SMD]VCRLIN;0;"";1
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return
  Elsif fstat
    GOK=0  : Call RSTA("CAL","SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN)) From GLOCK : Return
  Endif
Else
  Raz [F:CAL]
  [F:CAL]ABRFIC="SMD"
  [F:CAL]VCRTYP=[F:SMD]VCRTYP
  [F:CAL]VCRNUM=[F:SMD]VCRNUM
  [F:CAL]VCRLIN=[F:SMD]VCRLIN
  [F:CAL]ANALIG=1
Endif
#-----
For Z=1 To max(GNBCOA,2)
    [F:CAL]LED(Z-1)=GLEDSOC(Z)
    [F:CAL]COA(Z-1)=GCOA(Z)
Next Z

For Z=1 To max(GNBDIE,GOPTCANA)
   [F:CAL]DIE(Z-1)=GDIE(Z)
   [F:CAL]CCE(Z-1)=evalue("[M:DBY0]CCE"+num$(Z)+"(nolign-1)")
Next Z
#-----
If TRTLIG="M"  Rewrite [CAL]  Else  Write [CAL] : Endif
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : Return : Endif
Return

#----------------------------------------------------------#
# Ecriture des comptes et sections de la ligne de document composant #
#----------------------------------------------------------#
$MAJPID_CPTANALIN_CPT

Local Integer Z
#-----
If TRTLIG="M"
  Readlock [CAL] CAL0="SMD";[F:SMD]VCRTYP;[F:SMD]VCRNUM;[F:SMD]VCRLIN;0;"";1
  If fstat=1
    GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return
  Elsif fstat
    GOK=0  : Call RSTA("CAL","SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN)) From GLOCK : Return
  Endif
Else
  Raz [F:CAL]
  [F:CAL]ABRFIC="SMD"
  [F:CAL]VCRTYP=[F:SMD]VCRTYP
  [F:CAL]VCRNUM=[F:SMD]VCRNUM
  [F:CAL]VCRLIN=[F:SMD]VCRLIN
  [F:CAL]ANALIG=1
Endif
#-----
For Z=1 To max(GNBCOA,2)
    [F:CAL]LED(Z-1)=GLEDSOC(Z)
    [F:CAL]COA(Z-1)=GCOA(Z)
Next Z

For Z=1 To max(GNBDIE,GOPTCANA)
   [F:CAL]DIE(Z-1)=GDIE(Z)
   [F:CAL]CCE(Z-1)=evalue("[M:DBY1]CCE"+num$(Z)+"(I)")
Next Z
#-----
If TRTLIG="M"  Rewrite [CAL]  Else  Write [CAL] : Endif
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : Return : Endif
Return

###############################                         # Ana   fin

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SMH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M:DBY0]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M:DBY0]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M:DBY0]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M:DBY0]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:DBY0]WRHE
      If GWRHOBY=2
         Diszo [M:DBY0]WRH  :  #--- Bug 82156
         Diszo [M:DBY1]WRH
      Else
         Actzo [M:DBY0]WRH  :  #--- Bug 82156
         Actzo [M:DBY1]WRH
      Endif
   Elsif [M:DBY0]WRHE<>""
      Diszo [M:DBY0]WRHE
      Diszo [M:DBY0]WRH     :  #--- Bug 82156
      Diszo [M:DBY1]WRH
   Else
      Actzo [M:DBY0]WRHE
      Actzo [M:DBY0]WRH     :  #--- Bug 82156
      Actzo [M:DBY1]WRH
   Endif
Else
  Raz   [M:DBY0]WRHE
  Grizo [M:DBY0]WRHE
  Grizo [M:DBY0]WRH         :  #--- Bug 82156
  Grizo [M:DBY1]WRH
Endif
Return

