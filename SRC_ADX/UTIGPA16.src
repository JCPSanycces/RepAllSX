#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA16         Utilitaire de resynchronisation  WIP     Module GPAO  #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Renseigner les WIPCOST lorsqu'ils sont manquants (V6)                #
#   Cette moulinette peut être appelée à tout moment car elle ne         #
#   génère que des WIP de suivis pour lesquels il n'en existe pas encore #
##########################################################################
# Remarque : si une ligne de suivi d'opération contient 2 postes
#            et qu'un seul wipcost est manquant, cet utilitaire ne sait
#             pas créer le wipcost manquant.
##########################################################################

Call MAJ_UTIGPA16
End


Subprog MAJ_UTIGPA16
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("WIP Synchronization") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPA16(DOSSIER)
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA16(DOSSIER)
Value Char DOSSIER

If GMODU(8)<>2
    End
Endif
Call EXE_UTIGPA16_2(DOSSIER,"")
End

Subprog EXE_UTIGPA16_2(DOSSIER,PFILTRE)
Value Char DOSSIER
Value Char PFILTRE

If GMODU(8)<>2
    End
Endif

Call ECR_TRACE("UTIGPA16 : Process start "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If filinfo (filpath ("FIL", "WIPCOST" , "fde",DOSSIER ) ,0) < 0: End : Endif

If !clalev([F:ANM])  : Local File =DOSSIER+".ACODNUM"     [ANM]  : Endif
If !clalev([F:AVN])  : Local File =DOSSIER+".AVALNUM"     [AVN]  : Endif
If !clalev([F:BOD])  : Local File =DOSSIER+".BOMD"        [BOD]  : Endif
If !clalev([F:BOH])  : Local File =DOSSIER+".BOM"         [BOH]  : Endif
If !clalev([F:CDE])  : Local File =DOSSIER+".CACCEDEF"    [CDE]  : Endif
If !clalev([F:CPY])  : Local File =DOSSIER+".COMPANY"     [CPY]  : Endif
If !clalev([F:FCY])  : Local File =DOSSIER+".FACILITY"    [FCY]  : Endif
If !clalev([F:FIY])  : Local File =DOSSIER+".FISCALYEAR"  [FIY]  : Endif
If !clalev([F:ICN])  : Local File =DOSSIER+".ITCNAT"      [ICN]  : Endif
If !clalev([F:ITC])  : Local File =DOSSIER+".ITMCOST"     [ITC]  : Endif
If !clalev([F:ITF])  : Local File =DOSSIER+".ITMFACILIT"  [ITF]  : Endif
If !clalev([F:ITM])  : Local File =DOSSIER+".ITMMASTER"   [ITM]  : Endif
If !clalev([F:MCN])  : Local File =DOSSIER+".MFCNAT"      [MCN]  : Endif
If !clalev([F:MFC])  : Local File =DOSSIER+".MFGCOST"     [MFC]  : Endif
If !clalev([F:MFG])  : Local File =DOSSIER+".MFGHEAD"     [MFG]  : Endif
If !clalev([F:MFI])  : Local File =DOSSIER+".MFGITM"      [MFI]  : Endif
If !clalev([F:MFO])  : Local File =DOSSIER+".MFGOPE"      [MFO]  : Endif
If !clalev([F:MFM])  : Local File =DOSSIER+".MFGMAT"      [MFM]  : Endif
If !clalev([F:MKI])  : Local File =DOSSIER+".MFGITMTRK"   [MKI]  : Endif
If !clalev([F:MKM])  : Local File =DOSSIER+".MFGMATTRK"   [MKM]  : Endif
If !clalev([F:MKO])  : Local File =DOSSIER+".MFGOPETRK"   [MKO]  : Endif
If !clalev([F:MTS])  : Local File =DOSSIER+".MFGTRS"      [MTS]  : Endif
If !clalev([F:MWC])  : Local File =DOSSIER+".WORKCOST"    [MWC]  : Endif
If !clalev([F:MWH])  : Local File =DOSSIER+".MFGWIP"      [MWH]  : Endif
If !clalev([F:MWI])  : Local File =DOSSIER+".WIPCOST"     [MWI]  : Endif
If !clalev([F:MWI2]) : Local File =DOSSIER+".WIPCOST"     [MWI2] : Endif
If !clalev([F:MWS])  : Local File =DOSSIER+".WORKSTATIO"  [MWS]  : Endif
If !clalev([F:ONA])  : Local File =DOSSIER+".OVENAT"      [ONA]  : Endif
If !clalev([F:OVE])  : Local File =DOSSIER+".OVERHEAD"    [OVE]  : Endif
If !clalev([F:PER])  : Local File =DOSSIER+".PERIOD"      [PER]  : Endif
If !clalev([F:STJ])  : Local File =DOSSIER+".STOJOU"      [STJ]  : Endif
If !clalev([F:SJV])  : Local File =DOSSIER+".STOJOUVAL"   [SJV]  : Endif
If !clalev([F:TCA])  : Local File =DOSSIER+".TABCOUAFF"   [TCA]  : Endif
If !clalev([F:TCU])  : Local File =DOSSIER+".TABCUR"      [TCU]  : Endif
If !clalev([F:TFO])  : Local File =DOSSIER+".TABFOR"      [TFO]  : Endif
If !clalev([F:TMA])  : Local File =DOSSIER+".TABMAT"      [TMA]  : Endif


Local Mask =DOSSIER+".STOWORK" [STW]
Local Mask =DOSSIER+".STOVALWORK" [SVW]

Local Integer LRET, LTRA
Local Char LFILTRE(250)

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOJOU","AMTORD") From STKVALECR

LTRA=0
If GTRACE=""
    LTRA=1
    Call OUVRE_TRACE("WIP synchronization") From LECFIC
Endif

If vireblc(PFILTRE,4)<>""
    LFILTRE=PFILTRE
Else
    LFILTRE = "MFGTRKFLG>1 & MFGTRKFLG<6"
Endif

For [MFG] Where evalue(LFILTRE)

    Call DEBTRANS From GLOCK
    Trbegin [MWI]

   # FQ 78771 GA 12/2011 avant [F:MKO]MFGFCY
    If [F:FCY]FCY<>[F:MFG]MFGFCY
        Read [FCY]FCY0=[F:MFG]MFGFCY
    Endif
#----- Suivis opérations ----#
    For [MKO] Where MFGNUM=[F:MFG]MFGNUM
        Filter [MWI] Where VCRTYP    = 10
&                        & VCRNUM    = [F:MFG]MFGNUM
&                        & MFGTRKNUM = [F:MKO]MFGTRKNUM
&                        & MFGTRKLIN = [F:MKO]OPETRKLIN
&                        & find(TXNTYP,2,3,4)>0
        Look [MWI] First
        Filter [MWI]
        If fstat
            Raz [F:MWI],[F:MWS], [F:MFO]

            Read [MFO]MFO0=[F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM

            Read [MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY

            If [F:MWS]WSTTYP = 3
                Call SCEOPETRK_NEW(10,LRET) From MWIPLIB
            Else
                Call OPETRK_NEW(LRET) From MWIPLIB
            Endif
            If !GSERVEUR
                Call ECR_TRACE("1#"-[F:MFG]MFGNUM-num$([F:MWI]TXNTYP)-num$([F:MKO]OPENUM)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT),0) From GESECRAN
            Endif
            If LRET > 0
                GMESSAGE = "1#"-[F:MFG]MFGNUM-[F:MKO]MFGTRKNUM-num$([F:MKO]OPETRKLIN)-num$([F:MWI]TXNTYP)-num$([F:MKO]OPENUM)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT)-":"-GMESSAGE-"("+num$(LRET)+")"
                Break
            Endif
        Endif
    Next

    If !LRET
    #----- Suivis matières ----#
        For [MKM] Where MFGNUM=[F:MFG]MFGNUM
            Filter [MWI] Where VCRTYP    = 10
&                            & VCRNUM    = [F:MFG]MFGNUM
&                            & MFGTRKNUM = [F:MKM]MFGTRKNUM
&                            & MFGTRKLIN = [F:MKM]MATTRKLIN
&                            & TXNTYP=1
            Look [MWI] First
            Filter [MWI]
            If fstat
                Raz [F:MWI], [M:STW], [M:SVW], [F:MFM], [F:ITM]
                nolign=0
                [M:STW] = [F:MKM]
                Read [ITM]ITM0=[F:MKM]ITMREF
                Read [MFM]MFM0=[F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
                For [STJ] Where STOFCY=[F:MFG]MFGFCY
&                         & VCRTYP=12
&                         & VCRNUM=[F:MKM]MFGTRKNUM
&                         & VCRLIN=[F:MKM]MATTRKLIN
&                         & REGFLG=1
&                         & UPDCOD=2
                    nolign += 1
                    [M:STW] = [F:STJ]
                    [M:STW]QTYSTU(nolign-1)    = -[F:STJ]QTYSTU
                    [M:STW]QTYSTUACT(nolign-1) = -[F:STJ]ACTQTY
                    [M:STW]QTYPCU(nolign-1)    = -[F:STJ]QTYPCU
                    [M:STW]MAJCOD(nolign-1)    = "C"

                    Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                    If !fstat
                        Call SJV2SVW(nolign-1,1+2,0) From STKVALECR
                        Call COPSVW(nolign-1, nolign-1, -1, 0, 1+2) From STKVALECR
                    Else
                        [M:SVW]PRIORD(nolign-1)    = [F:STJ]PRIORD
                        [M:SVW]AMTORD(nolign-1)    = -[F:STJ]AMTORD
                        [M:SVW]OMATCST((nolign-1)*GACTMAT+[F:ITM]BRDCOD-1) = -[F:STJ]AMTORD
                        [M:SVW]VMATCST((nolign-1)*GACTMAT+[F:ITM]BRDCOD-1) = -[F:STJ]AMTVAL
                    Endif
                Next
                [M:STW]NBLIG=nolign
                [M:SVW]NBLIG=[M:STW]NBLIG
                If [M:STW]NBLIG>0
                    Call MAJ_WIPCOST(LRET) From MWIPLIB
                    If !GSERVEUR
                        Call ECR_TRACE("2#"-[F:MFG]MFGNUM-num$([F:MWI]TXNTYP)-num$([F:MKM]MFMITMREF)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT),0) From GESECRAN
                    Endif
                    If LRET > 0
                        GMESSAGE = "2#"-[F:MFG]MFGNUM-[F:MKM]MFGTRKNUM-num$([F:MKM]MATTRKLIN)-num$([F:MWI]TXNTYP)-num$([F:MKM]MFMITMREF)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT)-":"-GMESSAGE-"("
&                                  +num$(LRET)+")"
                        Break
                    Endif
                Endif
            Endif
        Next
    Endif

    If !LRET
    #---- Déclarations de production ----#
        For [MKI] Where MFGNUM=[F:MFG]MFGNUM
            Filter [MWI] Where VCRTYP    = 10
&                            & VCRNUM    = [F:MFG]MFGNUM
&                            & MFGTRKNUM = [F:MKI]MFGTRKNUM
&                            & MFGTRKLIN = [F:MKI]ITMTRKLIN
&                            & TXNTYP=14
            Look [MWI] First
            Filter [MWI]
            If fstat
                Raz [F:MWI], [M:STW], [M:SVW], [F:MFI], [F:ITM]
                nolign=0
                [M:STW] = [F:MKI]
                Read [ITM]ITM0=[F:MKI]ITMREF
                Read [MFI]MFI0=[F:MFG]MFGNUM;[F:MKI]MFGLIN
                For [STJ] Where STOFCY=[F:MFG]MFGFCY
&                         & VCRTYP=15
&                         & VCRNUM=[F:MKI]MFGTRKNUM
&                         & VCRLIN=[F:MKI]ITMTRKLIN
&                         & REGFLG=1
&                         & UPDCOD=2
                    nolign += 1
                    [M:STW] = [F:STJ]
                    [M:STW]QTYSTUACT(nolign-1) = [F:STJ]ACTQTY
                    [M:STW]MAJCOD(nolign-1) = "C"

                    Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                    If !fstat
                        Call SJV2SVW(nolign-1,1+2,0) From STKVALECR
                    Else
                        [M:SVW]PRIORD(nolign-1)    = [F:STJ]PRIORD
                        [M:SVW]AMTORD(nolign-1)    = [F:STJ]AMTORD
                        If [F:ITM]BRDCOD<=0 : Infbox [F:ITM]ITMREF-[F:MKI]MFGTRKNUM : Endif
                        [M:SVW]OMATCST((nolign-1)*GACTMAT+[F:ITM]BRDCOD-1) = [F:STJ]AMTORD
                        [M:SVW]VMATCST((nolign-1)*GACTMAT+[F:ITM]BRDCOD-1) = [F:STJ]AMTVAL
                    Endif
                Next
                [M:STW]NBLIG=nolign
                [M:SVW]NBLIG=[M:STW]NBLIG
                If [M:STW]NBLIG>0
                    Call MAJ_WIPCOST(LRET) From MWIPLIB
                    If !GSERVEUR
                        Call ECR_TRACE("3#"-[F:MFG]MFGNUM-num$([F:MWI]TXNTYP)-num$([F:MKI]ITMREF)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT),0) From GESECRAN
                    Endif
                    If LRET > 0
                        GMESSAGE = "3#"-[F:MFG]MFGNUM-[F:MKI]MFGTRKNUM-num$([F:MKI]ITMTRKLIN)-num$([F:MWI]TXNTYP)-num$([F:MKI]ITMREF)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT)-":"-GMESSAGE-"("
&                                 +num$(LRET)+")"
                        Break
                    Endif
                Endif
            Endif
        Next
    Endif
    If LRET
        If GMESSAGE<>""
            Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        Else
            Call ECR_TRACE([F:MFG]MFGNUM-num$([F:MWI]TXNTYP)-[F:MWI]MFGTRKNUM-[F:MWI]MFGTRKLIN-num$([F:MWI]ITMREF)-num$([F:MWI]TXNDAT)-num$([F:MWI]AMOUNT),1) From GESECRAN
        Endif
        Rollback
        Break
    Else
        Commit
    Endif
Next

If LTRA
    Call FERME_TRACE From LECFIC
    Call SUPP_TRACE From LECFIC
Endif

End
