#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORSTB
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
$SBBPJT
  Case [L]ARULE
    When "CONTROL"   : Gosub SBBPJT_CONTROL
    When "PROPAGATE" : Gosub SBBPJT_PROPAGATE    # Issue X3-87228 - 2018-06-26 by FGR/ALMON
  Endcase
Return

$SBBPJT_CONTROL
Local Char SMESS(250)        # Issue X3-87228 - 2018-06-26 by FGR/ALMON
Local Integer IPIMTYP        # Issue X3-87228 - 2018-06-26 by FGR/ALMON

  If this.SBBPJT = this.OPPNUM and this.OPPNUM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SBBPJT", mess(280,196,1), [V]CST_AERROR))
  Endif
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON : BEGIN
  IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.SBBPJT, AVOID.ACHAR, AVOID.ACHAR, SMESS)
  If IPIMTYP = 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SBBPJT", SMESS, [V]CST_AERROR))
  Elsif IPIMTYP <> 1 and IPIMTYP <> 2 and IPIMTYP <> 3 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR(func AFNC.MES1("SBBPJT", mess(1096,2260,1),  this.SBBPJT), [V]CST_AERROR))
  Endif
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON : END
Return

$SBBPJT_PROPAGATE
Local Char SMESS(250)

  # Issue X3-87228 - 2018-06-26 by FGR/ALMON
  If func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.SBBPJT, AVOID.ACHAR, AVOID.ACHAR, SMESS) = 1 Then
    this.CONSFLG = [V]CST_ANO
  Else
    this.CONSFLG = [V]CST_AYES
  Endif
Return

#######################################################################################
$CONSFLG
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON
  Case [L]ARULE
    When "INIT"      : Gosub CONSFLG_INIT
  Endcase
Return

$CONSFLG_INIT
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON
  this.CONSFLG = [V]CST_ANO
Return

