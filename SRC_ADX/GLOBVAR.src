Subprog INIGLOBVAR(STAT)
Variable Integer STAT
Local Integer ER , STAT , PRODUIT , OKTRT , LICENCE
Local Char    TIT(80) , TITSUF(80), TITABR(80)
Local Char    THX(3) , VERCOM(10)
Local Char    ACCESS(250) , BASE(250)
Local Integer I , OKENV , RES , COL , LIG , BRW , HHCC , PORTAIL
Local Char    RETOUR(30) , PARAM(250) , FICHIER(250)
Local Char    A1VERS(30) , A1REL(30) , A1PAT(30)

#109897
If find(adxtyp,34,35)=0
Onerrgo ERRAPP
If func DOSSUB.RELEASE(nomap)<>func DOSSUB.RELSUP(nomap)
 If func DOSSUB.TEST(nomap) : # Dossier test
  # La version ($1$) de ce dossier "test" n'est pas dans la version ($2$) du dossier de rÃĐfÃĐrence
  Call ECR_TRACE(func AFNC.MES2(func APLSTD.MESSUP(238,125),func DOSSUB.RELEASE(nomap),func DOSSUB.RELSUP(nomap)),-1) From GESECRAN
 Else
  # Dossier $1$ inaccessible.\Ce dossier est en release $2$ et il doit ÃŠtre migrÃĐ en release $3$ pour ÃŠtre accessible.
  Call ECR_TRACE(func AFNC.MES3(func APLSTD.MESSUP(201,125),nomap,func DOSSUB.RELEASE(nomap),func DOSSUB.RELSUP(nomap)),1) From GESECRAN
  STAT = 0 : End
 Endif
Endif
Endif

Onerrgo ERRGLOB

If dim([V]C)>=0 : Kill C : Endif

Call EXISTE_ADX("","","WWGLOBLON",OKTRT) From ORDSYS
If OKTRT>0
 Call GLOBLON From WWGLOBLON
Endif

Gosub ADOVALSYS

Call DEFVAR From WWAGLOBDEF

# Dossier historisÃĐ

GHISTO = (filinfo(filpath("","histo","",0),0)>=0)

# ParamÃĻtres Web

Call INIVWEB(GINSTID,GVIRTDIR,ACCESS,BASE) From INTRUTILA

Gosub ADOVAL

##############################################
##  Pour la gestion du serveur BO en dev    ##
##############################################

# Variables liÃĐes aux paramÃĻtres gÃĐnÃĐraux
Call EXISTE_ADX("","","WWAGLOBVAR",OKTRT) From ORDSYS
If OKTRT>0
 Call DEFVAR From WWAGLOBVAR
Endif

Call INIVAR     From GLOBVAR

Call DEFVAR     From GLOBSUP
Call INIVAR     From GLOBSUP

# init des constants
Call INIVAR From ASYRCONST

## VÃĐrif de la licence

STAT = 1
#87108 a faire aprÃĻs crÃĐation contexte
#If GADONIX<>2
# Call NOMBRE(6,PRODUIT) From GLOCK
# Case GPRODUIT
#  When 0 : If PRODUIT<>1  : STAT = 0 : Endif : # X3
#  When 1 : If PRODUIT<>4  : STAT = 0 : Endif : # GÃĐode
#  When 2 : If PRODUIT<>2  : STAT = 0 : Endif : # Paye
#  When 3 : If PRODUIT<>8  : STAT = 0 : Endif : # Biens
#  When 4 : If PRODUIT<>16 : STAT = 0 : Endif : # Loan
# Endcase
#Endif

#
## Utilisateurs nommÃĐs
#V10
#GUSRNOMME = func ARECAUO.NBR_UTINOM
GUSRNOMME = 0

# Titre de la fenÃŠtre suivant le produit

Call TITFENP(TITABR,TIT,TITSUF)
#109897
If find(adxtyp,34,35)=0
 Titled [] nomap-TIT-TITSUF
Endif

#103231
#adxmto = max(adxmto,200)
adxmto = max(adxmto,220)

## Init Globales BO
Gosub INIT_VARBO

#109897
If adxtyp=34
 Gosub VERCOM
Elsif !GSERVEUR
#If !GSERVEUR

# ThÃĻme graphique
# Call NOMBRA(11,PRODUIT) From GLOCK
# Case PRODUIT
#   When 1       : THX = "ADX" : THX="BRY"  : # CC 08/07/2010 thÃĻme V6.2
#   When 2       : THX = "INN"
#   When 3       : THX = "GEO" : THX="GX6"
#   When 4       : THX = "ABE"
#   When 5       : THX = "DIA"
#   When 6       : THX = "AX2" : THX="AX6"   : # AX6 sera le thÃĻme standard pour la V6
#   When 0,-1    : THX = TITABR
#   When Default : THX = "ADX" : THX="BRY" : THX="AX6"
# Endcase
#87106
 Case GPRODUIT
   When -2,-1,0 : THX = "ADX" : THX="BRY"  : # CC 08/07/2010 thÃĻme V6.2
   When 1       : THX = "GEO" : THX="GX6"
   When 2       : THX = "INN"
   When 3       : THX = "ABE"
   When Default : THX = "ADX" : THX="BRY" : THX="AX6"
 Endcase

# PRovisoire
# If (toupper(adxusr)="LV" or toupper(adxusr)="ASK_") and nomap="SUPERV" : THX="GX6"  : Endif

 Global Char GTHEME(30)
 Global Char GTHEMESTD(30)
 GTHEME = THX
 GTHEMESTD = THX

 # "splash" en fonction du produit
 # ParamÃĻtres liÃĐs au produit

 Gosub VERCOM
 Onerrgo ERRGLOB

 # RÃĐsolution
 Call PARAM("","ECRRESOL",PARAM) From ADOVAL
 RES = val(PARAM)
 Call RESOLUTION(RES,COL,LIG,BRW)
 HHCC = RES : If HHCC=3 : HHCC = 2 : Endif

 # Est-on en portail interactif ou pas
 Call INITYPPORT(PORTAIL) From INTRUTILA

 # NumÃĐro de version, release et patch du dossier
 Call VERSX3(nomap,A1VERS,A1REL,A1PAT) From INTRUTILA

 GPOINT = "SPLASH" : Gosub ENTREE From EXEFNC

 ## Envoi des paramÃĻtres au client
 Gosub ENVOI_CLIENT
 ##

Endif

End

#-----------#
$ERRAPP
Resume

#-----------#
$ERRGLOB
If adxusr="jc"
  Resume
#Elsif GSERVEUR
# Openo "/u/by/tradapi",-1
# Wrseq errp+"("+num$(errl)+")"-errmes$(errn)-errm
# Openo
Else
 Call ECR_TRACE(errp+"("+num$(errl)+")"-errmes$(errn)-errm,1) From GESECRAN
Endif
Resume


