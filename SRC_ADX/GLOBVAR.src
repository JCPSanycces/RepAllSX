$INIT_VARBO
Global Char GBOVERSION(3)
Call GETBOVERSION(GBOVERSION) From INTRUTILA
If dim(GREPSOLIND)>0 & dim(GREPBOPROD)>0 & dim(GREPBI)
 #106969
 If func APRODUCT.AGETVERSION()=GVERSION
  Case GPRODUIT
   When -2 : GREPSOLIND = "INDUSPRD~V"+num$(mid$(GVERSION,3,1)) : GREPBOPROD = "INDUSPRD" : # Indus
   When -1 : GREPSOLIND = "SUPERV~V"+num$(mid$(GVERSION,3,1))   : GREPBOPROD = "SUPERV"   : # Superviseur
   When  0 : GREPSOLIND = "X3~V"+num$(mid$(GVERSION,3,1))       : GREPBOPROD = "X3"       : # X3
   When  1 : GREPSOLIND = "GEO~V"+num$(mid$(GVERSION,3,1))      : GREPBOPROD = "GEODE"    : # GÃĐode
   When  2 : GREPSOLIND = "INN~V"+num$(mid$(GVERSION,3,1))      : GREPBOPROD = "PAIE"     : # Paye
   When  3 : GREPSOLIND = "ABE~V"+num$(mid$(GVERSION,3,1))      : GREPBOPROD = "ABELX3"   : # Biens
  Endcase
 Else
  Case GPRODUIT
   When -2 : GREPSOLIND = "INDUSPRD~"+func APRODUCT.AGETRELEASEABR(nomap) : GREPBOPROD = "INDUSPRD" : # Indus
   When -1 : GREPSOLIND = "SUPERV~"+func APRODUCT.AGETRELEASEABR(nomap)   : GREPBOPROD = "SUPERV"   : # Superviseur
   When  0 : GREPSOLIND = "X3~"+func APRODUCT.AGETRELEASEABR(nomap)       : GREPBOPROD = "X3"       : # X3
   When  1 : GREPSOLIND = "GEO~"+func APRODUCT.AGETRELEASEABR(nomap)      : GREPBOPROD = "GEODE"    : # GÃĐode
   When  2 : GREPSOLIND = "INN~"+func APRODUCT.AGETRELEASEABR(nomap)      : GREPBOPROD = "PAIE"     : # Paye
   When  3 : GREPSOLIND = "ABE~"+func APRODUCT.AGETRELEASEABR(nomap)      : GREPBOPROD = "ABELX3"   : # Biens
  Endcase
 Endif
Endif
Return

#---------------------------------------------------------------------#
# Titre de la fenÃŠtre d'aprÃĻs le produit
#---------------------------------------------------------------------#

Subprog TITFENP(TITABR,TIT,TITSUF)
Variable Char TITABR , TIT , TITSUF
Local Integer GAMME

TITSUF = ""
TIT = func APRODUCT._AGETPRODUCTNAME()
Case GPRODUIT
 When -2 : # Industrialization/Maintenance
     TIT    = "Industrialization/Maintenance"
     TITABR = "ADX"
 When -1 : # Superviseur
     TIT    = mess(2,39,1)  : # Superviseur
     TITABR = "ADX"
 When 0 : # X3
     TITABR = "ADX"
 When 1 : # Geode
     TITABR = "GEO"
#87108
#  Call NOMBRE(1,GAMME) From GLOCK
#  Case GAMME
#   When 1        : TITSUF = mess(56,127,1) : # Standard Edition
#   When 2        : TITSUF = mess(60,127,1) : # Advanced Edition
#   When Default  :
     TITSUF = mess(57,127,1) : # Premium Edition
#  Endcase
 When 2 : # Paye
     TITABR = "INN"
 When 3 : # Immos
     TITABR = "ABE"
Endcase
End

