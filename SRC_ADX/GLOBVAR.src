Subprog INIGLOBVAR1
Local Char    MACHINE(GDIMFIC)(1..3)
Local Integer I , J , K , STAT
Onerrgo ERRGLOB
I = type(GLOGNAME)-10
J = type(GTTY)-10
K = max(30,I,J)
Local Char    RESULT(K)(1..2)

I = 0
Gosub SET_MAC
For I=1 To 3
 K = -1
 If adxmac(I-1)=""
  K = 0
 Else
  For J=1 To I-1
   If adxmac(I-1) = adxmac(J-1)
    K = J : Break
   Endif
  Next J
 Endif
 If K<0
  Gosub SET_MAC
 Else
  GOS(I)     = GOS(K)
  GOS2(I)    = GOS2(K)
  GREPTMP(I) = GREPTMP(K)
 Endif
Next I

For I = 0 To 3
 Case GOS(I)
  When "unix"  : GIRS(I) = chr$(10)
  When "dos"   : GIRS(I) = chr$(13) + chr$(10)
  When Default : GIRS(I) = chr$(10)
 Endcase
Next I

# Ce qui nÃĐcessite un ordre systÃĻme doit ÃŠtre effectuÃĐ aprÃĻs...

Call SYSTEME2(adxmac(0),"ae_logname","",STAT,RESULT) From ORDSYS
GLOGNAME = RESULT(1)
GTTY     = RESULT(2)
GUSER    = toupper(left$(GLOGNAME,5))
GSUPER   = "ADMIN"
GIDENT   = format$("K:5X",GUSER)+num$(adxuid(1))

## Langue
GLANDEF = "FRA"                               : # Celle lÃ , faut pas la changer
Call PARAM("","LANGUAGE",GLANGUE) From ADOVAL : # Langue principale du dossier
If GLANGUE=""
 GLANGUE = GLANDEF
Endif
#107939,108171
#111587 fix for all adxtyp except fat client/batch if messname(0) not in the folder
#113941 check laguage in ADOSSIER if possible
Local Integer LANOK
Local Integer LANSTA
If filinfo(filpath("FIL","ADOSSIER","fde"),0)>0
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 LANSTA=func DOSSUB.FILL_ADS(nomap)
 If LANSTA=1
  If find(messname(0),[F:ADS]LAN(0..[F:ADS]NBRLAN-1))>0
    LANOK=1
  Endif
 Endif
Else
 If filinfo(filpath("M"+messname(0),"","",nomap),0)>=0
   LANOK=1
 Endif
Endif
#109897 ajout adxtyp=34+35
If find(adxtyp,25,33,34,35)>0 | (mod(adxtyp,8)>3 & LANOK=0)
 messname(0) = GLANGUE
 adxrob(0)   = "ECR"
 adxrob(1)   = "M"+GLANGUE
Endif
#
GTRAFOR = GUTF8
#If filinfo(filpath("FIL","TABLAN","fde"),0)>0
# Local File TABLAN [TLA]
# Read [TLA]TLA0 = GLANGUE
# If fstat=0
#  Case [F:TLA]LANUNI
#   When 1       : #GTRAFOR = GASCII
#   When Default : #GTRAFOR = GUTF8
#  Endcase
# Endif
# Close Local File [TLA]
#Endif

# Web

If dim(GFUSION)<0
 Global Integer GFUSION
Endif
# 109396 ajout adxtyp=30 eclispse en http
# 109419  ajout adxtyp=20 web services V9
# 109897 ajout adxtyp=35 batch syracuse
# 109897 ajout adxtyp=34 Remote classic call
Case adxtyp
 When 9,10,17,6,14 : GBROWS = 1                : # Session Web : Primaire/Secondaire/Futur/Eclipse/Eclipse 9-> consolackcall
 When 13           : GBROWS = 1 : GVTMOD   = 1 : # Terminal VT
 When 7,15,12,20   : GBROWS = 2 : GWEBSERV = 1 : # Session Bridge java/Web-service
 When 25           : GBROWS = 1 : GFUSION  = 1 : # Session Fusion/Classic page
 When 30           : GBROWS = 0 : GFUSION  = 1 : # Eclipse http
 When Default      : GBROWS = 0                : # Session C/S ou Web page
Endcase

# PrÃĐsence d'un moteur adonix en local pour accÃĐder aux fichiers du poste client en WEB

If dim(GADXLOC)<0
 Global Integer GADXLOC
Endif
If GBROWS & dim(locfshost)>0 & dim(locfsqport)>0 & dim(locfsqon)>0
 GADXLOC = (locfshost<>"" & locfsqport<>0 & locfsqon<>0)
Else
 GADXLOC = 0
Endif

GINTRA = 0
GVTPROF = mess(42,151,1) : # Profil

#117559 ajout alimentation de GSUPERVIS
# Ce qui caractÃĐrise le superviseur, c'est que la table ADOSSIER est locale
If filinfo(filpath("FIL","ADOSSIER","fde",0),0)<0
 GSUPERVIS = 0
Else
 GSUPERVIS = 1
Endif
If filinfo(filpath("","sophia_gaillard",""),0)>=0
 GSUPERVIS = 0
Endif

End

#----------------------------------------------#
$SET_MAC
If I=0
 System MACHINE = "@ae_os"
Else
 System MACHINE = adxmac(I-1)+"@ae_os"
Endif
GOS(I)     = MACHINE(1)
GOS2(I)    = MACHINE(2)
GREPTMP(I) = MACHINE(3)
If vireblc(GREPTMP(I),2)=""
# Case GOS(I)
#  When "unix"
#   GREPTMP(I) = "/tmp"
#  When "dos"
#   GREPTMP(I) = "C:\TEMP"
# Endcase
 If I=0
  GREPTMP(I) = filpath("!tmp","","","","","")
  GREPTMP(I) = right$(GREPTMP(I),instr(0,GREPTMP(I),"@")+1)
 Else
  GREPTMP(I) = filpath("!tmp","","","","",adxmac(I-1))
  GREPTMP(I) = right$(GREPTMP(I),instr(0,GREPTMP(I),"@")+1)
 Endif
Endif

Return

#---------------------------------------------------------------------#
# Init des variables non liÃĐes Ã  ADOENT (ENTREPRISE)
#---------------------------------------------------------------------#

Subprog INIVAR
Onerrgo ERRGLOB

Local Integer I , NB , COM, STAT
Local Char    C(1) , PREMDEP(5) , PREMBAN(3), RESULT(30)(1..2)

If nomap=adxmother(1)
 GSILENCE=1
Endif

If GADONIX=2 : dbgmode=1 : Endif : # PossibilitÃĐ dÃĐbugger en mode dÃĐveloppement
If adxmac(0)=""
 GMACADO = toupper(adxmac(-1))
Else
 GMACADO = toupper(adxmac(0))
Endif

GFMRIB    = '30X'
GLOCALDEV = 'FRF'
GARODEV   = 0.01
GFMT3     = '12.2'
GFM92     = '9.2'
GFM62     = '6.2'

If filinfo(filpath("FIL","TABCOUNTRY","fde",0),0)>0
 Local File TABCOUNTRY [TCY]
 Read [TCY]TCY0 = GPAYS
 If fstat
  Read [TCY]TCY0 = ""
 Endif
 If fstat=0
  GFMRIB    = [F:TCY]BIDFMT
  GLOCALDEV = [F:TCY]CUR
 Endif
Endif
If filinfo(filpath("FIL","TABCUR","fde",0),0)>0
 Local File TABCUR [TCU]
 Read [TCU]TCU0 = GLOCALDEV
 If fstat=0
  GARODEV   = [F:TCU]CURRND
  GFMT3     = [F:TCU]CURFMT3
  GFM92     = [F:TCU]CURFMT1
  GFM62     = [F:TCU]CURFMT2
 Endif
Endif
If nomap=adxmother(1)
 GSILENCE=0
Endif

GOK = 1

GDIRBQE = "BQE"
GDIRBQR = "BQR"
GDIRCASH= "CASH"
GDIRDEC = "DEC" : # Issue 83047 - 2012-11-05 by VPO

GAUTORIS=0
Call AUTORIS    From ENTREPRISE

Call ENTREE

End

#---------------------------------------------------------------------#
# Lecture des paramÃĻtres superviseur -> variables systÃĻmes
#---------------------------------------------------------------------#

$ADOVALSYS
Local Char    PARAM(250)
Local Integer I , J , K , L
Local File    ADOVAL [ADW] , ADOPAR [ADP]

# Date de base
If adxtyp<>25 : # Client fusion
 Call PARAM("","DCS",PARAM) From ADOVAL
 [S]adxdcs = val(PARAM)
Endif

# Temps de verrou
Call PARAM("","TIMLCK",PARAM) From ADOVAL
[S]lockwait = val(PARAM)

## ParamÃĻtres adonix
For I=1 To 30
 Call PARAM("","TUL"+format$("N0:##",I),PARAM) From ADOVAL
 If PARAM<>""
  adxtul(I-1) = left$(PARAM,1)
  J = instr(1,PARAM,":")
  If J
   adxtut(I-1) = seg$(PARAM,2,J-1)
   adxtuc(I-1) = right$(PARAM,J+1)
  Endif
 Endif
Next I

Close Local File [ADW] , [ADP]
Return

#---------------------------------------------------------------------#
# LECTURE des paramÃĻtres superviseur -> globales superviseur
#---------------------------------------------------------------------#

$ADOVAL
Local Char    PARAM(250)
Local Integer I , J , K , L
Local File    ADOVAL [ADW] , ADOPAR [ADP]

# Nombre de rollback
Call PARAM("","ROLLBACK",PARAM) From ADOVAL
GROLLBACK = val(PARAM)

Call PARAM("","MODULE1",PARAM) From ADOVAL
If PARAM="" : PARAM = "2222222222" : Endif
For I=1 To 10
 GMODU(I) = val(mid$(PARAM,I,1))
Next I
Call PARAM("","MODULE2",PARAM) From ADOVAL
If PARAM="" : PARAM = "2222222222" : Endif
For I=1 To 10
 GMODU(I+10) = val(mid$(PARAM,I,1))
Next I
Call PARAM("","ADMUSR",GSUPER) From ADOVAL
If GSUPER="" : GSUPER = "ADMIN" : Endif
Call PARAM("","ADONIX",PARAM) From ADOVAL
GADONIX = val(PARAM)
Call PARAM("","REPBI",PARAM) From ADOVAL
GREPBI = PARAM
If GREPBI ="" : GREPBI ="SAGE" : Endif
Call PARAM("","IMPBI",PARAM) From ADOVAL
GIMPBI = PARAM
If GIMPBI ="" : GIMPBI ="SAGE~IMPORT" : Endif

#109897
#{X3-37890
If !GSERVEUR & adxtyp=20
 Local Integer IDX(0..)
 Local Integer AI,AJ
 Local Char SDATE(10)
 Local Char FMTDAT(10)(0..)
 Local Char FMTDAT3(10)(0..)
 Local Char FMTDAT9(10)(0..)
 SDECIM     = adxfmt2(6) :#decimalSep
 SMIL           =  adxfmt2(7) :#thousandsSep
 GFMDAT    = right$(adxfmt2(0),3) :#shortDateFormat
 GFMDAT4  = right$(adxfmt2(1),3) :#longDateFormat

 AI = instr(1,GFMDAT,"[")
 If AI
  AJ = instr(1,GFMDAT,"]")
  If AJ
   SDATE = mid$(GFMDAT,AI+1,AJ-AI-1)
  Endif
 Endif

 IDX(0) = instr(1,GFMDAT,"D")
 FMTDAT(0)="D"
 FMTDAT3(0)="DD"
 FMTDAT9(0)="DD"
 IDX(1) = instr(1,GFMDAT,"M")
 FMTDAT(1)="M"
 FMTDAT3(1)="MMM"
 FMTDAT9(1)="MMMMMMMMM"
 IDX(2) = instr(1,GFMDAT,"Y")
 FMTDAT(2)="Y"
 FMTDAT3(2)="YYYY"
 FMTDAT9(2)="YYYY"
 Sorta 3 IDX,FMTDAT, FMTDAT3,FMTDAT9  Order By IDX(indice)
 GFMDAT3 = FMTDAT3(0)+"[ ]"+FMTDAT3(1)+"[ ]"+FMTDAT3(2)
 GFMDAT9 = FMTDAT9(0)+"[ ]"+FMTDAT9(1)+"[ ]"+FMTDAT9(2)

 If find("M",FMTDAT) < find("Y",FMTDAT)
  GFMMOI   = "MM["+SDATE+"]YY"
  GFMMOI4 = "MM["+SDATE+"]YYYY"
 Else
  GFMMOI     = "YY["+SDATE+"]MM"
  GFMMOI4 = "YYYY["+SDATE+"]MM"
 Endif

 If find("D",FMTDAT) < find("M",FMTDAT)
  GFMJOU  = "DD["+SDATE+"]MM"
 Else
  GFMJOU  = "MM["+SDATE+"]DD"
 Endif
#X3-37890}
Elsif !GSERVEUR & adxtyp<>34

  ## RÃĐcupÃĐration des paramÃĻtres du client

  Local Char SDATE(1) , IDATE(1) , SDECIM(1) , SMIL(1)
  Call PARCLI("X3Version",GVERCLI)
  Call PARCLI("X3FileVersion",GRELCLI)
  Call PARCLI("SDate",SDATE)
  If SDATE="" : SDATE = "/" : Endif
  Call PARCLI("IDate",IDATE)
  If val(IDATE)<0 or val(IDATE)>2 : IDATE = "1" : Endif
  Call PARCLI("SDecimal",SDECIM)
  If SDECIM="" : SDECIM = "." : Endif
  Call PARCLI("SThousand",SMIL)
  SMIL = chr$(mod(ascii(SMIL),128))
  If SMIL="" : SMIL = " " : Endif
  Case val(IDATE)
   When 0 : # mois, jour, annÃĐe
    GFMDAT  = "MM["+SDATE+"]DD["+SDATE+"]YY"
    GFMDAT4 = "MM["+SDATE+"]DD["+SDATE+"]YYYY"
    GFMDAT3 = "MMM[ ]DD[ ]YYYY"
    GFMDAT9 = "MMMMMMMMM[ ]DD[ ]YYYY"
    GFMMOI  = "MM["+SDATE+"]YY"
    GFMMOI4 = "MM["+SDATE+"]YYYY"
    GFMJOU  = "MM["+SDATE+"]DD"
   When 1 : # jour, mois, annÃĐe
    GFMDAT  = "DD["+SDATE+"]MM["+SDATE+"]YY"
    GFMDAT4 = "DD["+SDATE+"]MM["+SDATE+"]YYYY"
    GFMDAT3 = "DD[ ]MMM[ ]YYYY"
    GFMDAT9 = "DD[ ]MMMMMMMMM[ ]YYYY"
    GFMMOI  = "MM["+SDATE+"]YY"
    GFMMOI4 = "MM["+SDATE+"]YYYY"
    GFMJOU  = "DD["+SDATE+"]MM"
   When 2 : # annÃĐe, mois, jour
    GFMDAT  = "YY["+SDATE+"]MM["+SDATE+"]DD"
    GFMDAT4 = "YYYY["+SDATE+"]MM["+SDATE+"]DD"
    GFMDAT3 = "YYYY[ ]MMM[ ]DD"
    GFMDAT9 = "YYYY[ ]MMMMMMMMM[ ]DD"
    GFMMOI  = "YY["+SDATE+"]MM"
    GFMMOI4 = "YYYY["+SDATE+"]MM"
    GFMJOU  = "MM["+SDATE+"]DD"
  Endcase
  Call PARAM("","SCA",PARAM) From ADOVAL
  adxsca = left$(PARAM,1)+"."+SMIL+SDECIM+right$(PARAM,5)

Else

  # En batch on fait ce qu'on peut pour l'instant
  GVERCLI = "0, 1, 5, 0"
  Call PARAM("","FMTDAT",PARAM) From ADOVAL
  I = val(PARAM)
  If I : GFMDAT = right$(mess(I,19,1),instr(1,mess(I,19,1),":")+1) : Endif
  Call PARAM("","FMTMOI",PARAM) From ADOVAL
  I = val(PARAM)
  If I : GFMMOI = right$(mess(I,19,1),instr(1,mess(I,19,1),":")+1) : Endif
  Call PARAM("","FMTJOU",PARAM) From ADOVAL
  I = val(PARAM)
  If I : GFMJOU = right$(mess(I,19,1),instr(1,mess(I,19,1),":")+1) : Endif
  If GFMDAT="" : GFMDAT = "DD[-]MM[-]YY" : Endif
  If GFMMOI="" : GFMMOI = "MM[-]YY"      : Endif
  If GFMJOU="" : GFMJOU = "DD[-]MM"      : Endif
  I = instr(1,GFMDAT,"YYYY")
  If !I
   I = instr(1,GFMDAT,"YY")
   If I
    GFMDAT4 = left$(GFMDAT,I-1)+"YY"+right$(GFMDAT,I)
   Else
    GFMDAT4 = "DD[-]MM[-]YYYY"
   Endif
  Else
   GFMDAT4 = GFMDAT
  Endif
  I = instr(1,"MM",GFMDAT4)
  If I
   GFMDAT3 = left$(GFMDAT4,I-1)+"M"+right$(GFMDAT4,I)
   GFMDAT9 = left$(GFMDAT4,I-1)+"MMMMMMM"+right$(GFMDAT4,I)
  Endif
  I = instr(1,"YY",GFMMOI)
  If I
   GFMMOI4 = left$(GFMMOI,I-1)+"YY"+right$(GFMMOI,I)
  Endif
  Call PARAM("","SCA",PARAM) From ADOVAL
  adxsca = PARAM
  #109897
  If find(adxtyp,34,35)>0
   Local Char SEPDEC(5) : SEPDEC="."
   adxsca = left$(adxsca,3)+SEPDEC+right$(adxsca,5)
  Endif
Endif

# NumÃĐro de version pour Crystal Report
Case GVERCLI
 When "0, 1, 4, 0" : GVERCRY = "140"
 When Default      : GVERCRY = "150"
Endcase

Close Local File [ADW] , [ADP]
Return

#------------------------------------------------------------------#
# Groupage des Callui envoyÃĐs au client (+ tard en faire un seul)
#------------------------------------------------------------------#

$ENVOI_CLIENT

# Versions !!!! laisser GVERSION et GVERSOL !!!!!
#&                        "ADXVersion="+chr$(1)+A1VERS,
#120436 Supervisor version identification : ADXSupVersEx
If dim(GFUSION)>0 & GFUSION>0
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXVersion="+chr$(1)+ctrans(GVERSION,".",""),
&                        "ADXRelease="+chr$(1)+A1REL,
&                        "ADXNopatch="+chr$(1)+A1PAT,
&                        "ADXSupVers="+chr$(1)+GVERSOL,
&                        "ADXSupVersEx="+chr$(1)+func APRODUCT.AGETRELEASESUP(),
&                        "ADXNamedUser="+chr$(1)+num$(GUSRNOMME)
Else
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXVersion="+chr$(1)+ctrans(GVERSION,".",""),
&                        "ADXRelease="+chr$(1)+A1REL,
&                        "ADXNopatch="+chr$(1)+A1PAT,
&                        "ADXSupVers="+chr$(1)+GVERSOL,
&                        "ADXNamedUser="+chr$(1)+num$(GUSRNOMME)
Endif

# Si le dossier est un dossier historisÃĐ, on le signale au client
If GHISTO
 Callui RETOUR=""   With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXMaskAppName="+chr$(1)+adxmother(0)
Endif

If ACCESS<>""
 Callui RETOUR=""   With "UIAction=" + chr$(1) + "SessionSettings",
&                        "ADXHelpLocation=" + chr$(1) + func AFNC.PART(ACCESS,1),
&                        "ADXHelpType=" + chr$(1) + func AFNC.PART(ACCESS,2),
&                        "ADXHelpName=" + chr$(1) + func AFNC.PART(ACCESS,3)
Endif

If BASE<>""
 Callui RETOUR=""   With "UIAction="+chr$(1)+"SessionSettings" ,
&                        "AdxSolution="+chr$(1)+ GINSTID
 Callui RETOUR=""   With "UIAction=" + chr$(1) + "SessionSettings",
&                        "ODBCType=" + chr$(1) + func AFNC.PART(BASE,1),
&                        "ODBCName=" + chr$(1) + "",
&                        "ODBCDriver=" + chr$(1) + "",
&                        "ODBCBase=" + chr$(1) + func AFNC.PART(BASE,2),
&                        "ODBCServer=" + chr$(1) + func AFNC.PART(BASE,3),
&                        "ODBCPort=" + chr$(1) + func AFNC.PART(BASE,4)
Endif

If !GBROWS : # On envoie au client le nom de la virtual directory X3_PUB
  Callui RETOUR=""  With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXHttpPub="+chr$(1)+ctrans("http://"+GVIRTDIR+"/","\","/")
Endif

# Envoi de la taille de l'ÃĐcran au client
Callui RETOUR=""    With "UIAction="+chr$(1)+"SetWindFeatures",
&                        "UIBrwCol="+chr$(1)+num$(COL-BRW),
&                        "UIWindMaxCol=" +chr$(1)+num$(COL),
&                        "UIWindMaxRow="+chr$(1)+num$(LIG+1),
&                        "UIWindResol="+chr$(1)+num$(HHCC)

# Envoi de la taille maximum du clob (en nb d'octets) Ã  ne pas dÃĐpasser (pour les favoris)
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXSizeClob="+chr$(1)+num$(1024*2^GLONACB)

# Pour le format$(D:MMM)
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "SetMonthList="+chr$(1)+month$(1)+sigma(I=2,12,";"+month$(I))
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "DefaultDateFormat="+chr$(1)+ GFMDAT
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "DefaultDatePivot="+chr$(1)+ num$(adxdcs)

# Portail interactif
If PORTAIL
 Callui RETOUR=""   With "UIAction="+chr$(1)+"SessionSettings","ADXTypportal="+chr$(1)+"1"
Endif

# ThÃĻme et titre de fenÃŠtre
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings","ADXWtitle="+chr$(1)+nomap-TIT-TITSUF
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings","ADXTheme="+chr$(1)+THX
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings","ADXPortalTheme="+chr$(1)+THX

If func APRODUCT.AGETVERSIONABR()<>""
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXProduct="+chr$(1)+TITABR,
&                        "ADXProductLabel=" + chr$(1) + TIT-TITSUF,
&                        "ADXProductPref="  + chr$(1) + TIT,
&                        "ADXProductSuff="  + chr$(1) + TITSUF,
&                        "ADXProductInfoVers=" + chr$(1) + func APRODUCT.AGETVERSIONABR() : #106969 VERCOM
Else
Callui RETOUR=""    With "UIAction="+chr$(1)+"SessionSettings",
&                        "ADXProduct="+chr$(1)+TITABR,
&                        "ADXProductLabel=" + chr$(1) + TIT-TITSUF,
&                        "ADXProductPref="  + chr$(1) + TIT,
&                        "ADXProductSuff="  + chr$(1) + TITSUF,
&                        "ADXProductInfoVers=" + chr$(1) + VERCOM
Endif
Return

#---------------------------------------------#
Subprog RESOLUTION(RES,COL,LIG,BRW)
Value    Integer RES
Variable Integer COL
Variable Integer LIG
Variable Integer BRW
Case RES
 When 3       : # Haute rÃĐsolution avec browser plus grand
  COL = 112 : #-14
  LIG = 28
  BRW = 112-24-14
 When 2       : # Haute rÃĐsolution
  COL = 112
  LIG = 28
  BRW = 112-24
 When Default : # Basse rÃĐsolution
  COL = 84
  LIG = 20
  BRW = 84-20
Endcase
End

#---------------------------------------------------------------------#
# RÃĐcupÃĐration d'un paramÃĻtre client
#---------------------------------------------------------------------#

Subprog PARCLI(PARAM,VALEUR)
Value    Char PARAM
Variable Char VALEUR()
Local Char VALCLI(250)(1..5)
Local Integer I , K
Gosub SET_SSOPAR
For I=1 To dim(SSOPAR)
 SSOPAR(I) = toupper(SSOPAR(I))
Next I
If find(toupper(PARAM),SSOPAR)
 VALEUR = ""
 Getui VALCLI="" With "UserNameEx"
 For I=1 To dim(VALCLI)
  K = instr(1,VALCLI(I),"=")
  If K & toupper(left$(VALCLI(I),K-1))=toupper(PARAM)
   VALEUR = right$(VALCLI(I),K+2)
  Endif
 Next I
Else
 Getui VALCLI="" With PARAM
 K = instr(1,VALCLI,"=")
 If K
  VALEUR = right$(VALCLI,K+2)
 Else
  VALEUR = ""
 Endif
Endif
End

#---------------#
$SET_SSOPAR
Local Char SSOPAR(30)(1..5)
SSOPAR(1) = "NameFullyQualifiedDN" : # Fully qualified distinguished name (example, CN=DOE\, John,OU=MGE R&D X3,OU=Ag Echirolles,...)
SSOPAR(2) = "NameSamCompatible"    : # Windows NTÂŪ 4.0 account name (example, SAGEFR\jdoe)
SSOPAR(3) = "NameCanonical"        : # Complete canonical name (example, sagefr.adinternal.com/SAGE <http://sagefr.adinternal.com/SAGE> Fr)
SSOPAR(4) = "NameUserPrincipal"    : # User principal name (example, jdoe@sage.fr <mailto:jdoe@sage.fr>)
SSOPAR(5) = "NameDnsDomain"        : # The DNS domain name followed by a backward-slash and
Return

#---------------------------------------------------------------------#
# DÃĐfinition des points d'entrÃĐe
#---------------------------------------------------------------------#

Subprog ENTREE
Local Integer K, OK, OKTRT , IOBJ
Call DEFVAR From WWAGLOBENT
GNBENTREE = 0
If filinfo(filpath("FIL","AENTREE","fde"),0)>0
 If clalev([F:APE])=0 : Local File AENTREE [APE] : Endif
 If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
 For [APE]APE0
  OK = 1
  If [F:APE]MODULE<>0
   If GMODU([F:APE]MODULE)<>2 : OK = 0 : Endif
  Endif
  If [F:APE]CODACT<>""
   Read [ACV]CODACT = [F:APE]CODACT
   If fstat or [F:ACV]FLACT<>2 : OK = 0 : Endif
  Endif
  If [F:APE]OBJ<>"" and dim(GCODOBJ)>0 and dim(GNBOBJ)>0 and dim(GVEROBJ)>0
   IOBJ = find([F:APE]OBJ,GCODOBJ(1..GNBOBJ))
   If IOBJ>0 : GVEROBJ(IOBJ) =0 : Endif
  Endif
  Call EXISTE_ADX("","",[F:APE]TRTSPE,OKTRT) From ORDSYS
  If !OKTRT : OK = 0 : Endif
  If OK
   GNBENTREE += 1
   GENTSTD(GNBENTREE) = [F:APE]TRTSTD
   GENTSPE(GNBENTREE) = [F:APE]TRTSPE
   If dim(GENTOBJ)>0
    GENTOBJ(GNBENTREE) = [F:APE]OBJ
    GENTRNG(GNBENTREE) = [F:APE]RNG
   Endif
  Endif
 Next
 Close Local File [APE]
 Close Local File [ACV]
Endif
End

#####################################################################
# VERCOM must not use GVERSION
#####################################################################
$VERCOM
If dim(VERCOM)<=0
 Local Char    VERCOM(10),VERSION(10)
Endif
# "splash" en fonction du produit
 # ParamÃĻtres liÃĐs au produit

 Onerrgo ERRAPP
 Case GPRODUIT
  When -1,-2    : Call VERCOM(VERCOM) From GLOBSUP
  When 0,6      : Call VERCOM(VERCOM) From GLOBX3
  When 1        : Call VERCOM(VERCOM) From GLOBGEO
  When 2        : Call VERCOM(VERCOM) From GLOBPAY
  When 3        : Call VERCOM(VERCOM) From GLOBIMM
 Endcase
 Onerrgo

If left$(VERCOM,1)="V"
 VERSION=right$(VERCOM,2)
Else
 VERSION=VERCOM
Endif
Return

