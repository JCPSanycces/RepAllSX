#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTITRS09   UTI process                                    Module TRS   #
#            Array of ATABDIV 3 to TABPAM
##########################################################################

If clalev([F:ADS])=0  
    Local File ADOSSIER [ADS] 
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER 
  If fstat <> 0 
        Raz [F:ADS] 
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS09(WDOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS09(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)

Call ECR_TRACE("UTITRS09 : Start of process on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:AXX])  = 0 : Local File =DOSSIER+".ATEXTRA"  [AXX] : Endif
If clalev([F:TAM])  = 0 : Local File =DOSSIER+".TABPAM"   [TAM] : Endif
If nbrecord([F:TAM]) : Goto THE_END : Endif

If clalev([F:ADI])  =0  Local File =DOSSIER+".ATABDIV"  [ADI] : Endif
Filter [ADI] Where NUMTAB=3

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [TAM]
For [ADI]

 [F:TAM]PAM    = [F:ADI]CODE
 [F:TAM]LEG    = [F:ADI]LEG
 [F:TAM]SOI    = [F:ADI]A1
 [F:TAM]ACCEPT = val([F:ADI]A2)

 If [F:TAM]ACCEPT>0
  [F:TAM]ACCEPTFLG=2
 Else
  [F:TAM]ACCEPTFLG=1
 Endif

 If [F:ADI]N1=2
  [F:TAM]PAPTRT=2
 Else
  [F:TAM]PAPTRT=1
 Endif

 [F:TAM]TYP=[F:ADI]N2

 # Libellés
 DESIG1 = ""
 Call LECTEXTRA (DESIG1,"ATABDIV","LNGDES","3",[F:ADI]CODE) From ATEXTRA
 Call MAJTEXTRA (DESIG1,"TABPAM","DESAXX",[F:TAM]PAM,[F:TAM]LEG) From ATEXTRA
 DESIG2 = ""
 Call LECTEXTRA (DESIG2,"ATABDIV","SHODES","3",[F:ADI]CODE) From ATEXTRA
 Call MAJTEXTRA (DESIG2,"TABPAM","SHOAXX",[F:TAM]PAM,[F:TAM]LEG) From ATEXTRA

 [F:TAM]UPDUSR = ""
 [F:TAM]UPDDAT = [0/0/0]
 [F:TAM]CREUSR=GUSER
 [F:TAM]CREDAT=date$

 Write [F:TAM]
 If !fstat : WCOMPTEUR += 1 : Endif

Next
Commit

Close Local File [TAM]

$THE_END
Call ECR_TRACE("UTITRS09 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
Trbegin [AXX]
Delete [AXX]  Where CODFIC="ATABDIV" & IDENT1="3"
If fstat
 Call ERREUR("ATEXTRA-3",3) From DOSDIC
Else
 Call ECR_TRACE("UTITRS09 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Commit

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS09 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif                                
If filinfo(filpath("FIL","TABPAM","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTITRS09(APPLI)        
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif                                
If filinfo(filpath("FIL","TABPAM","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTITRS09(APPLI)        
End


