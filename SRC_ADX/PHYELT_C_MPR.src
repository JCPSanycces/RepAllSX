#**
#* =================================
#* Private Operation: _UPD_STOCKTAKE  -  Physical asset stocktake
#* ---------------------------------
#* Update inventory date and hour of the physical asset (an empty PHYELT instance exists).
#*      1. Physical asset is read
#*      2- Inventory date IVYDAT is updated with the date of the day (date$)
#*      3- Inventory time IVYTIM is updated with the current time (time$)
#*      4- Physical asset is updated
#* ---------------------------------
#* @private
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#*!
$_UPD_STOCKTAKE

  [L]ARET_VALUE = [V]CST_AOK

  # Physical asset reading
  [L]ARET_VALUE = fmet this.AREAD(PHYREF)
  If ([L]ARET_VALUE >= [V]CST_AERROR) : Return : Endif


  # Physical asset is inventoried
  this.IVYDAT = date$
  this.IVYTIM = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)

  # Update physical asset
  [L]ARET_VALUE = fmet this.AUPDATE

Return

#**
#* =================================
#* Private Operation: _DEL_STOCKTAKE  -  Physical asset stocktake reset
#* ---------------------------------
#* Delete inventory date and hour of the physical asset (an empty PHYELT instance exists).
#*      1. Physical asset is read
#*      2- Inventory date IVYDAT is reset
#*      3- Inventory date IVYTIM is reset
#*      4- Physical asset is updated
#* ---------------------------------
#* @private
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#*!
$_DEL_STOCKTAKE

  [L]ARET_VALUE= [V]CST_AOK

  # Physical asset reading
  [L]ARET_VALUE = fmet this.AREAD(PHYREF)
  If ([L]ARET_VALUE >= [V]CST_AERROR) : Return : Endif

  # Stocktake data are reseted
  this.IVYDAT = AVOID.ADATE
  this.IVYTIM = "00:00:00"

  # Update physical asset
  [L]ARET_VALUE = fmet this.AUPDATE

Return

#**
#* Return the count number of the collection
#*
#* @private
#* @param PPHYELT
#* @return Count number
#*!
Funprog _PHYMVT_GET_COUNTTAB(PPHYELT)
Variable Instance PPHYELT Using C_PHYELT
Local Integer RCOUNT : [L]RCOUNT = 0

  Local Integer LIN

  For [L]LIN = 1 To maxtab(PPHYELT.PHYMVT)
    If PPHYELT.PHYMVT([L]LIN) <> null and find(PPHYELT.PHYMVT([L]LIN).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
      [L]RCOUNT += 1
    Endif
  Next [L]LIN

End RCOUNT

#**
#* Return the count number of collection
#*
#* @private
#* @param PPHYELT
#* @param PCOLL
#* @return Count number
#*!
Funprog _COLL_GET_COUNTTAB(PPHYELT, PCOLL)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Local Integer RCOUNT : [L]RCOUNT = 0

  Local Integer LIN, NBLIN

  [L]NBLIN = evalue("maxtab(PPHYELT."+PCOLL+")")
  For [L]LIN = 1 To [L]NBLIN
    If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+")") <> null and !find(evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").ASTALIN"), [V]CST_ADEL, [V]CST_ANEWDEL)
      [L]RCOUNT += 1
    Endif
  Next [L]LIN

End RCOUNT

#**
#* Return the index of last movement and return by receive parameter the number of rows
#*
#* @private
#* @param PPHYELT : Class
#* @param RCOUNT  : Row count
#* @return Index of maxtab found
#*!
Funprog _PHYMVT_GET_MAXTAB(PPHYELT, RCOUNT)
Variable Instance PPHYELT Using C_PHYELT
Variable Integer RCOUNT
Local Integer RIND : [L]RIND = 0

  Local Integer LIN

  RCOUNT = 0
  For [L]LIN = 1 To maxtab(PPHYELT.PHYMVT)
    If PPHYELT.PHYMVT([L]LIN) <> null and find(PPHYELT.PHYMVT([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      RCOUNT += 1
      [L]RIND = [L]LIN
    Endif
  Next [L]LIN

End RIND

#**
#* Return the index of last movement and return by receive parameter the number of rows
#*
#* @private
#* @param PPHYELT : Class
#* @param RCOUNT  : Row count
#* @return Index of maxtab found
#*!
Funprog _COLL_GET_MAXTAB(PPHYELT, PCOLL, RCOUNT)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Variable Integer RCOUNT
Local Integer RIND : [L]RIND = 0

  Local Integer LIN, NBLIN

  RCOUNT = 0
  [L]NBLIN = evalue("maxtab(PPHYELT."+PCOLL+")")
  For [L]LIN = 1 To [L]NBLIN
    If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+")") <> null and !find(evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").ASTALIN"), [V]CST_ADEL, [V]CST_ANEWDEL)
      RCOUNT += 1
      [L]RIND = [L]LIN
    Endif
  Next [L]LIN

End RIND

#**
#* Get the date of the last pending movement if found.
#*
#* @private
#* @param PPHYELT : Class
#* @param PMVT    : Search Value
#* @param RMVTDAT : Date value returned
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _PHYMVT_GET_MVTDAT_LAST(PPHYELT, PMVT, RMVTDAT)
Variable Instance PPHYELT Using C_PHYELT
Value Integer PMVT
Variable Date RMVTDAT
Local Integer BFOUND

  Local Integer LIN

  RMVTDAT = AVOID.ADATE
  [L]BFOUND = [V]CST_AFALSE

  For [L]LIN = 1 To maxtab(PPHYELT.PHYMVT)
    If PPHYELT.PHYMVT([L]LIN) <> null and find(PPHYELT.PHYMVT([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      If (PPHYELT.PHYMVT([L]LIN).MVT = PMVT or PMVT = AVOID.AINT)
        RMVTDAT = PPHYELT.PHYMVT([L]LIN).MVTDAT
        [L]BFOUND = [V]CST_ATRUE
      Endif
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Get the date of the last pending movement if found.
#*
#* @private
#* @param PPHYELT : Class
#* @param PCOLL   : Collection
#* @param PMVT    : Search Value
#* @param RMVTDAT : Date value returned
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _COLL_GET_MVTDAT_LAST(PPHYELT, PCOLL, PMVT, RMVTDAT)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Value Integer PMVT
Variable Date RMVTDAT
Local Integer BFOUND

  Local Integer LIN, NBLIN

  RMVTDAT = AVOID.ADATE
  [L]BFOUND = [V]CST_AFALSE

  [L]NBLIN = evalue("maxtab(PPHYELT."+PCOLL+")")
  For [L]LIN = 1 To [L]NBLIN
    If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+")") <> null and !find(evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").ASTALIN"), [V]CST_ADEL, [V]CST_ANEWDEL)
      If (evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").MVT") = PMVT or PMVT = AVOID.AINT)
        RMVTDAT = evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").MVTDAT")
        [L]BFOUND = [V]CST_ATRUE
      Endif
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Get MVT propertie of the last movement
#*
#* @private
#* @param PPHYELT : Class
#* @param RMVT    : MVT propertie returned
#* @param RPOS    : AORDER position returned
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _PHYMVT_GET_MVT_LAST(PPHYELT, RMVT, RPOS)
Variable Instance PPHYELT Using C_PHYELT
Variable Integer RMVT
Variable Integer RPOS
Local Integer BFOUND

  Local Integer LIN

  RMVT = AVOID.AINT
  RPOS = [V]CST_ANOTDEFINED
  [L]BFOUND = [V]CST_AFALSE

  For [L]LIN = 1 To maxtab(PPHYELT.PHYMVT)
    If PPHYELT.PHYMVT([L]LIN) <> null and find(PPHYELT.PHYMVT([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      RMVT = PPHYELT.PHYMVT([L]LIN).MVT
      RPOS = PPHYELT.PHYMVT([L]LIN).AORDER
      [L]BFOUND = [V]CST_ATRUE
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Get MVT propertie of the last movement
#*
#* @private
#* @param PPHYELT : Class
#* @param RMVT    : MVT propertie returned
#* @param RPOS    : AORDER position returned
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _COLL_GET_MVT_LAST(PPHYELT, PCOLL, RMVT, RPOS)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Variable Integer RMVT
Variable Integer RPOS
Local Integer BFOUND

  Local Integer LIN, NBLIN

  RMVT = AVOID.AINT
  RPOS = [V]CST_ANOTDEFINED
  [L]BFOUND = [V]CST_AFALSE

  [L]NBLIN = evalue("maxtab(PPHYELT."+PCOLL+")")
  For [L]LIN = 1 To [L]NBLIN
    If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+")") <> null and !find(evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").ASTALIN"), [V]CST_ADEL, [V]CST_ANEWDEL)
      RMVT = evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").MVT")
      RPOS = evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").AORDER")
      [L]BFOUND = [V]CST_ATRUE
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Find the first movement equal to MVT value parameter and return the index if found, 0 otherwise
#*
#* @private
#* @param PPHYELT : Class
#* @param PMVT    : Search Value
#* @param RPOS    : Index of line if found, CST_ANOTDEFINED otherwise
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _PHYMVT_FIND_MVT(PPHYELT, PMVT, RPOS)
Variable Instance PPHYELT Using C_PHYELT
Value Integer PMVT
Variable Integer RPOS
Local Integer BFOUND : [L]BFOUND = [V]CST_AFALSE

  Local Integer LIN

  RPOS = [V]CST_ANOTDEFINED
  For [L]LIN = 1 To maxtab(PPHYELT.PHYMVT)
    If PPHYELT.PHYMVT([L]LIN) <> null and find(PPHYELT.PHYMVT([L]LIN).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
      If PPHYELT.PHYMVT([L]LIN).MVT = PMVT
        [L]BFOUND = [V]CST_ATRUE
        [L]RPOS = PPHYELT.PHYMVT([L]LIN).AORDER
        Break
      Endif
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Find the first movement equal to MVT value parameter and return the index if found, CST_ANOTDEFINED otherwise
#*
#* @private
#* @see # _COLL_FIND_MVT()
#* @param PPHYELT : Class
#* @param PCOLL   : Collection
#* @param PMVT    : Search Value
#* @param RPOS    : Index of line if found, CST_ANOTDEFINED otherwise
#* @return CST_ATRUE if found, CST_AFALSE otherwise
#*!
Funprog _COLL_FINDPOS_MVT(PPHYELT, PCOLL, PMVT, RPOS)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Value Integer PMVT
Variable Integer RPOS
Local Integer BFOUND : [L]BFOUND = [V]CST_AFALSE

  Local Integer LIN, NBLIN

  RPOS = [V]CST_ANOTDEFINED
  [L]NBLIN = evalue("maxtab(PPHYELT."+PCOLL+")")
  For [L]LIN = 1 To [L]NBLIN
    If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+")") <> null and !find(evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").ASTALIN"), [V]CST_ADEL, [V]CST_ANEWDEL)
      If evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").MVT") = PMVT
        [L]BFOUND = [V]CST_ATRUE
        RPOS = evalue("PPHYELT."+PCOLL+"("+num$([L]LIN)+").AORDER")
        Break
      Endif
    Endif
  Next [L]LIN

End [L]BFOUND

#**
#* Find the first movement equal to MVT value parameter and return the index if found, CST_ANOTDEFINED otherwise
#*
#* @private
#* @see # _COLL_FINDPOS_MVT()
#* @param PPHYELT : Class
#* @param PCOLL   : Collection
#* @param PMVT    : Search Value
#* @return Index of value if found, CST_ANOTDEFINED otherwise
#*!
Funprog _COLL_FIND_MVT(PPHYELT, PCOLL, PMVT)
Variable Instance PPHYELT Using C_PHYELT
Value Char PCOLL()
Value Integer PMVT
Local Integer WPOS

  Local Integer BFOUND
  [L]BFOUND = func _COLL_FINDPOS_MVT(PPHYELT, PCOLL, PMVT, [L]WPOS)

End [L]WPOS

#**
#* Determines whether the transfer is financial transfer and give a few informations
#*
#* @private
#* @param   PPHYELT         Instance
#* @param   PLCTCODD        Location
#* @param   RFCYD           Facility
#* @param   RCPYD           Company
#* @param   RLSTTRFMVT_DAT  Last transfer movement date
#* @return CST_ATRUE if it's a financial transfer, CST_AFALSE otherwise
#*!
Funprog IS_FINANCIAL_TRANSFER(PPHYELT, PLCTCODD, RFCYD, RCPYD, RLSTTRFMVT_DAT)
Variable Instance PPHYELT Using C_PHYELT
Value Char PLCTCODD()
Variable Char RFCYD(), RCPYD()
Variable Date RLSTTRFMVT_DAT
Local Integer B_FINANCIAL_TRF

# New location facility evaluation

  B_FINANCIAL_TRF = [V]CST_AFALSE

  Local Instance LCT Using C_PHYLCT
  LCT = NewInstance C_PHYLCT AllocGroup null
  # Get the destination FCY
  Local Char WPROPERTIES(50)(1..2), WVALUES(50)(1..2)
  WPROPERTIES(1) = "FCY"
  WPROPERTIES(2) = "CPY"
  If fmet LCT.GET_PROPERTIES_VALUE(PLCTCODD, WPROPERTIES, WVALUES) = [V]CST_AOK
    RFCYD = WVALUES(1)
    RCPYD = WVALUES(2)
  Endif
  FreeGroup LCT

  # Financial transfer evaluation
  RLSTTRFMVT_DAT = AVOID.ADATE
  Local Char LSTTRFMVT_FCY(GLONFCY) : [L]LSTTRFMVT_FCY = AVOID.ACHAR
  If (PPHYELT.FCY <> RFCYD)
    Local Char FINFCY_ORIG(GLONFCY)
    Local Char FINFCY_DEST(GLONFCY)
    # Evaluation : transfer date of the last pending transfer movement
    #              transfer facility of the last pending transfer movement
    Local Integer LIN
    If func _COLL_FINDPOS_MVT(PPHYELT, "PHYMVT", [V]CST_PMVGEO, [L]LIN) = [V]CST_ATRUE
      RLSTTRFMVT_DAT = PPHYELT.PHYMVT([L]LIN).MVTDAT
      [L]LSTTRFMVT_FCY = PPHYELT.PHYMVT([L]LIN).MVTFCY
    Endif
    # Financial transfer is evaluated either
    # on the facility of the last pending transfer movement if it exists
    # on the current facility of the physical asset if no pending transfer movement exists.
    If ([L]LSTTRFMVT_FCY = AVOID.ACHAR)
      [L]FINFCY_ORIG = fmet PPHYELT.ACTX.ACACHE.AFCY.AGETVALCHAR(PPHYELT.FCY, "FINRSPFCY")
    Else
      [L]FINFCY_ORIG = fmet PPHYELT.ACTX.ACACHE.AFCY.AGETVALCHAR([L]LSTTRFMVT_FCY, "FINRSPFCY")
    Endif
    [L]FINFCY_DEST = fmet PPHYELT.ACTX.ACACHE.AFCY.AGETVALCHAR(RFCYD,"FINRSPFCY")
    If ([L]FINFCY_ORIG <> [L]FINFCY_DEST)
      B_FINANCIAL_TRF = [V]CST_ATRUE
    Endif
  Endif

End B_FINANCIAL_TRF

#**
#* =================================
#* Private Function: _UPD_PHY_ENAFLG_FROM_FAS  -  Update ENAFLG of all physical asset linked to a fixed asset according to ENAFAS
#* ---------------------------------
#* Update ENAFLG of all physical asset linked to a fixed asset according to its ENAFAS value
#* Returns always "True"
#* ---------------------------------
#* @private
#* @param  PAASREF : Fixed asset reference
#* @param  PENAFLG : Enable flag
#* @return RRET    : CST_ATRUE or CST_AFALSE
#*!
Funprog _UPD_PHY_ENAFLG_FROM_FAS(PAASREF, PENAFLG)
Value Char    PAASREF()
Value Integer PENAFLG
Local Integer RRET

  RRET = [V]CST_ATRUE

  Local File PHYELT [PHY]
  Local Integer B_LOCAL_TRANSACTION : B_LOCAL_TRANSACTION = 1
  If adxlog = 1 : B_LOCAL_TRANSACTION = 0 : Endif
  If [L]B_LOCAL_TRANSACTION : Trbegin [PHY] : Endif

  Update [PHY] Where AASREF = PAASREF With ENAFLG = PENAFLG
  If (fstat) : RRET = [V]CST_AFALSE : Endif

  If (B_LOCAL_TRANSACTION) Then
    If (RRET = [V]CST_ATRUE)
      Commit
    Else
      Rollback
    Endif
  Endif

  LogicClose File [PHY]

End RRET

#**
#* =================================
#* Private Function: _GET_PHY_WITH_ISS_MVT_FROM_FAS  -  Get the reference of a physical asset linked to a fixed asset
#*                                                      if it has a physical disposal pending movement (cancellation included).
#* ---------------------------------
#* Returns "True"
#* if the fixed asset is linked to a physical asset which has got at least one disposal pending movement (cancellation included).
#* If it is true the physical asset reference is returned.
#* ---------------------------------
#* @private
#* @param  PAASREF : Fixed asset reference
#* @param  RPHYREF : Physical asset reference
#* @return RRET    : CST_ATRUE or CST_ATRUE
#*!
Funprog _GET_PHY_WITH_ISS_FROM_FAS(PAASREF, RPHYREF)
Value Char    PAASREF()
Variable Char RPHYREF()
Local Integer RRET

  RPHYREF = AVOID.ACHAR
  RRET    = [V]CST_AFALSE

  Local File PHYELT   [PHY]
  Local File PHYMVT   [PMVT]
  # [PMVT]PMVT0(1) first field of PMVT0 index key
  Link [PHY] With [PMVT]PMVT0(1) ~= PHYREF As [PHYM]
&               Where [F:PHY]AASREF = PAASREF and ([F:PMVT]MVT = [V]CST_PMVISS or [F:PMVT]MVT = [V]CST_PMVAISS )
&               Order By [F:PMVT]NUM

  Read [PHYM] First
  If fstat = [V]CST_AOK
    RRET = [V]CST_ATRUE
    RPHYREF = [F:PHY]PHYREF
  Endif

  LogicClose File [PMVT]
  LogicClose File [PHY]

End RRET

#**
#* =================================
#* Private Function: _GET_PHY_WITH_TRF_MVT_FROM_FAS  -  Get the reference of the first physical asset linked to a fixed asset
#*                                                      if it has a physical transfer pending movement.
#* ---------------------------------
#* Returns "True" if the fixed asset is linked to a physical asset which has got at least one transfer pending movement.
#* If it is true the physical asset reference and the first effective transfer date returned.
#* ---------------------------------
#* @private
#* @param  PAASREF : Asset reference
#* @param  PMVT    : [V]CST_PMVGEO or [V]CST_PMVAGEO or 0 (for the 2 ones)
#* @param  RPHYREF : Physical asset reference
#* @param  RTRFDAT : Effective trasnfer date
#* @param  RFCY    : Movement's facility
#* @param  RLCT    : Movement's location
#* @param  RREN    : Movement's ren
#* @param  RMVT    : Movement = CST_PMVGEO or CST_PMVAGEO
#* @return RRET    : CST_ATRUE or CST_ATRUE
#*!
Funprog _GET_INFO_PHY_WITH_TRF_MVT(PAASREF, PMVT, RPHYREF, RTRFDAT, RFCY, RLCT, RREN, RMVT)
Value Char       PAASREF()
Value Integer    PMVT
Variable Char    RPHYREF()
Variable Date    RTRFDAT
Variable Char    RFCY(), RLCT(), RREN()
Variable Integer RMVT
Local Integer    RRET

  Local Char WFILTER(250)

  RPHYREF = AVOID.ACHAR
  RRET    = [V]CST_AFALSE

  Local File PHYELT [PHY]
  Local File PHYMVT [PMVT]

  # [PMVT]PMVT0(1) first field of PMVT0 index key
  Link [PHY] With [PMVT]PMVT0(1) ~= PHYREF As [PHYM] Order By [F:PMVT]NUM

  WFILTER = "[F:PHY]AASREF = '" + PAASREF + "'"
  If PMVT = 0
    WFILTER += "and ([F:PMVT]MVT = [V]CST_PMVGEO or [F:PMVT]MVT = [V]CST_PMVAGEO)"
  Else
    WFILTER += "and [F:PMVT]MVT =" - num$(PMVT)
  Endif

  Filter [PHYM] Where evalue(WFILTER)
  Read [PHYM] First
  Filter [PHYM]

  If fstat = [V]CST_AOK
    RPHYREF = [F:PHY]PHYREF
    RTRFDAT = [F:PMVT]MVTDAT
    RFCY    = [F:PMVT]MVTFCY
    RLCT    = [F:PMVT]MVTLCTCOD
    RREN    = [F:PMVT]MVTTRANS
    RMVT    = [F:PMVT]MVT

    RRET = [V]CST_ATRUE
  Endif

  LogicClose File [PMVT]
  LogicClose File [PHY]

End RRET

#**
#* =================================
#* Private Function: _GET_SELECTED_MVT_PHY_NBR  -  Get number of movements of physical assets of a filtered population
#* ---------------------------------
#* @private
#* @param  PFILTER : Filter for physical asset selection
#* @return RPHYNBR : Number of selected physical elements
#*!
Funprog _GET_SELECTED_MVT_PHY_NBR(PFILTER)
Value Char PFILTER()

Local Integer RPHYNBR

  RPHYNBR = AVOID.AINT

  Local File PHYELT   [PHY]
  Local File PHYMVT   [PMVT]
  # [PMVT]PMVT0(1) first field of PMVT0 index key
  Link [PHY] With [PMVT]PMVT0(1) ~= PHYREF As [PHYM]
&               Order By [F:PMVT]NUM

  Filter [PHYM] Where evalue(PFILTER)
  RPHYNBR=rowcount([PHYM])
  Filter [PHYM]

  LogicClose File [PMVT]
  LogicClose File [PHY]

End RPHYNBR

# Issue 110656
#**
#* =================================
#* Private Function: _GET_INFOS_IDENTICAL_MVT_TRF  -  Get infos and number of movements
#*                    of physical assets of a filtered population (The movments must have the same facility)
#* ---------------------------------
#* @private
#* @param  PFILTER : Filter for physical asset selection
#* @param  RLCTCOD : Location (if) found
#* @param  RFCY    : Facility (if) found
#* @return RPHYNBR : Number of selected physical elements (if -1 there are differernt movments)
#*!
Funprog _GET_INFOS_IDENTICAL_MVT_TRF(PFILTER, RLCTCOD, RFCY)
Value Char PFILTER()
Variable Char RLCTCOD(), RFCY()

Local Integer RPHYNBR
Local Char WFILTER(250)

RLCTCOD = AVOID.ACHAR
RFCY = AVOID.ACHAR

Local File PHYELT   [PHY]
Local File PHYMVT   [PMVT]

  RPHYNBR = AVOID.AINT

  Link [PHY] With [PMVT]PMVT0(1) ~= PHYREF As [PHYM]
&               Order By [F:PMVT]NUM
  WFILTER = "(" + PFILTER + ") and ([F:PMVT]MVT = [V]CST_PMVGEO or [F:PMVT]MVT = [V]CST_PMVAGEO)"
  Filter [PHYM] Where evalue(WFILTER)

  For [PHYM]
    If RPHYNBR = AVOID.AINT
      RLCTCOD = [F:PMVT]MVTLCTCOD
      RFCY =  [F:PMVT]MVTFCY
      RPHYNBR += 1
    Else
      If RFCY <> [F:PMVT]MVTFCY
        RLCTCOD = AVOID.ACHAR
        RFCY = AVOID.ACHAR
        RPHYNBR = -1
        Break
      Else
        RPHYNBR += 1
      Endif
    Endif
  Next

End RPHYNBR
# End Issue 110656

#**
#* =================================
#* Private Function: _GET_SELECTED_PHY_NBR  -  Get number of physical assets of a filtered population
#* ---------------------------------
#* This function counts the number of physical assets selected through a filter.
#* Returns the number of selected physical assets
#* ---------------------------------
#* @private
#* @param  PFILTER : Filter for physical asset selection
#* @return RPHYNBR : Number of selected physical elements
#*!
Funprog _GET_SELECTED_PHY_NBR(PFILTER)
Value Char    PFILTER()
Local Integer RPHYNBR

  RPHYNBR = AVOID.AINT

  Local File PHYELT   [PHY]
  Filter [PHY] Where evalue(PFILTER)
  RPHYNBR=rowcount([PHY])
  Filter [PHY]
  LogicClose File [PHY]

End RPHYNBR

#**
#* =================================
#* Private Function: _GET_LCT_PHY_NBR  -  Get number of physical assets in the location and
#* those whose stocktake date is NOT null and greater than the gap given by INVVALPER param
#* ---------------------------------
#* This fuction recieves an existing location reference and returns 2 values :
#*      1°/ Number of physical assets belonging to the location.
#*      2°/ Number of physical assets of the location whose stocktake date is NOT null.
#* Returns always "True"
#* ---------------------------------
#* @private
#* @param  PLCTCOD : Location reference
#* @param  PCPY    : Company # Issue 112576
#* @param  RPHYNBR : Number of physical assets of the location
#* @param  RIVYNBR : Number of physical assets of the location whose stocktake date is not null.
#* @return RRET    : [V]CST_ATRUE
#*!
Funprog _GET_LCT_PHY_NBR(PLCTCOD, PCPY, RPHYNBR, RIVYNBR)
Value Char       PLCTCOD()
Value Char       PCPY() # Issue 112576
Variable Integer RPHYNBR()
Variable Integer RIVYNBR()
Local Integer    RRET

  RPHYNBR = AVOID.AINT
  RIVYNBR = AVOID.AINT
  RRET    = [V]CST_ATRUE

  # Issue 112576
  Local Date WDATEIVY
  # An inventory is Ok if the inventory date is greater or equal
  # than the current date minus the gap given by INVVALPER parameter
  WDATEIVY = date$ - fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, PCPY, "INVVALPER")
  # End Issue 112576

  Local File PHYELT   [PHY]
  Filter [PHY] Where LCTCOD=PLCTCOD
  RPHYNBR=rowcount([PHY])
  Filter [PHY]

# Issue 112576
#  Filter [PHY] Where LCTCOD=PLCTCOD and IVYDAT <> AVOID.ADATE
  Filter [PHY] Where LCTCOD=PLCTCOD and IVYDAT <> AVOID.ADATE and IVYDAT >= WDATEIVY
# End Issue 112576

  RIVYNBR=rowcount([PHY])
  Filter [PHY]
  LogicClose File [PHY]

End RRET

#**
#* =================================
#* Private Function: _GET_BUI_PHY_NBR  -  Get number of physical assets in the building and those whose stocktake date is NOT null
#* ---------------------------------
#* This fuction recieves an existing building reference and returns 2 values :
#*      1°/ Number of physical assets belonging to the building.
#*      2°/ Number of physical assets of the building whose stocktake date is NOT null.
#* Returns always "True"
#* ---------------------------------
#* @private
#* @param  PBUICOD : Building reference
#* @param  RPHYNBR : Number of physical assets of the building
#* @param  RIVYNBR : Number of physical assets of the building whose stocktake date is not null.
#* @return RRET    : [V]CST_ATRUE
#*!
Funprog _GET_BUI_PHY_NBR(PBUICOD, RPHYNBR, RIVYNBR)
Value Char       PBUICOD()
Variable Integer RPHYNBR()
Variable Integer RIVYNBR()
Local Integer    RRET

  RPHYNBR = AVOID.AINT
  RIVYNBR = AVOID.AINT
  RRET    = [V]CST_ATRUE

  Local File PHYELT   [PHY]
  Local File PHYLCT   [LCT]

  Link [PHY] With [LCT]LCT0~=LCTCOD As [_PHY]

  Filter [_PHY] Where [LCT]BUICOD=PBUICOD
  RPHYNBR=rowcount([_PHY])
  Filter [_PHY]

  Filter [_PHY] Where [LCT]BUICOD=PBUICOD and IVYDAT <> AVOID.ADATE
  # Issue 112576
  RIVYNBR = 0
  For  [_PHY]
    If [_PHY]IVYDAT >= date$ - fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [_PHY]CPY, "INVVALPER")
      RIVYNBR += 1
    Endif
  Next
  # End Issue 112576

  Filter [_PHY]

  LogicClose File [PHY]
  LogicClose File [LCT]

End RRET

#**
#* Private Function: Turns a disposal reason of a fixed asset into the corresponding one for a physical asset.
#*
#* This function receives disposal reason from fixed asset and returns the corresponding one for a physical asset
#* Returns always "True"
#*
#* @private
#* @param  PFAS_ISSTYP : Disposal reason from Fixed asset
#* @param  RPHY_ISSTYP : Disposal reason from Physical asset
#* @return RRET : [V]CST_ATRUE
#*!
Funprog _GET_PHY_ISSTYP_FROM_FAS(PFAS_ISSTYP, RPHY_ISSTYP)
Value    Tinyint PFAS_ISSTYP
Variable Tinyint RPHY_ISSTYP
Local Integer    RRET

  RRET = [V]CST_ATRUE
  # X3-102073:   link  [V]CST_TSREPRI and RPHY_ISSTYP (in ML 3175) missing
  Case PFAS_ISSTYP
    When [V]CST_TSAPPOR
      RPHY_ISSTYP = [V]CST_PDSALES
    When [V]CST_TSCIG
      RPHY_ISSTYP = [V]CST_PDSALES
    When [V]CST_TSCRESI
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSFCLOC
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSFCONC
      RPHY_ISSTYP = [V]CST_PDSALES
    When [V]CST_TSFCONT
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSFUSION
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSREBUT
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSRENEW
      RPHY_ISSTYP = [V]CST_PDSCRAP
    When [V]CST_TSSCISS
      RPHY_ISSTYP = [V]CST_PDSALES
    When [V]CST_TSVENTE
      RPHY_ISSTYP = [V]CST_PDSALES
    When [V]CST_TSVOLDI
      RPHY_ISSTYP = [V]CST_PDSTOLDI
    When [V]CST_TSREPRI
      RPHY_ISSTYP = [V]CST_PDSALES
    When Default
      RPHY_ISSTYP = AVOID.ALIB
  Endcase

End RRET

#**
#* Private Function: Turns a disposal reason of a physical asset into the corresponding one for a fixed asset.
#*
#* This function receives disposal reason from physical asset and returns the corresponding one for a fixed asset
#* Returns always "True"
#*
#* @private
#* @param  PPHY_ISSTYP : Disposal reason from Physical asset
#* @return RFAS_ISSTYP : Disposal reason from Fixed asset
#*!
Funprog _GET_FAS_ISSTYP_FROM_PHY(PPHY_ISSTYP, RFAS_ISSTYP)
Value    Tinyint PPHY_ISSTYP
Variable Tinyint RFAS_ISSTYP
Local Integer    RRET

  RRET = [V]CST_ATRUE

  Case PPHY_ISSTYP
    When [V]CST_PDSALES
      RFAS_ISSTYP = [V]CST_TSVENTE
    When [V]CST_PDSCRAP
      RFAS_ISSTYP = [V]CST_TSREBUT
    When [V]CST_PDSTOLDI
      RFAS_ISSTYP = [V]CST_TSVOLDI
    When Default
      RFAS_ISSTYP = AVOID.ALIB
  Endcase

End RRET

#**
#* =================================
#* Private Function: Get issue paramaters from all the physical assets of a filtered population
#* ---------------------------------
#* The function reads all the physical element selected through a filter. It returns
#* 1°/ The number of selected physical with a disposal pending movement
#* 2°/ The disposal date which is equal to the min of the disposal date of all the selected physical asset
#* 3°/ The disposal reason of the physical asset from which was inheritated the disposal date
#* Returns "True" if the function executes well.
#* ---------------------------------
#* @private
#* @param  PFILTER : Filter for physical asset selection
#* @param  RPHYNBR : Number of selected physical assets that have a pending disposal movement.
#* @param  RISSDAT : Disposal date
#* @param  RISSTYP : Disposal reason
#* @return RRET    : CST_ATRUE or CST_AFALSE
#*!
Funprog _GET_ISSUE_PARAM_FROM_PHY(PFILTER, RPHYNBR, RISSDAT, RISSTYP)
Value Char        PFILTER()
Variable Integer  RPHYNBR
Variable Date     RISSDAT
Variable Integer  RISSTYP
Local Integer     RRET

  Local Char    ERRMSG(250)
  Local Integer STACK_ERROR

  [L]RRET = [V]CST_ATRUE

  If (PFILTER = AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"PHY_FILTER", "_GET_FAS_ISSUE_PARAM_FROM_PHY")
    [L]STACK_ERROR = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    [L]RRET = [V]CST_AFALSE
  Endif

  If (RRET = [V]CST_ATRUE)
    [L]RPHYNBR = AVOID.AINT
    Local Integer B_FIRST : B_FIRST = [V]CST_ATRUE
    Local File PHYELT   [PHY]
    Local File PHYMVT   [PMVT]
    Filter [PHY] Where evalue(PFILTER)
    Columns [PHY](PHYREF)
    # >>>>>>>
    For [PHY]
      Filter [F:PMVT] Where PHYREF=[F:PHY]PHYREF and MVT=[V]CST_PMVISS
      Read [PMVT]PMVT0 First
      If (fstat = [V]CST_AOK)
        If (B_FIRST = [V]CST_ATRUE)
          B_FIRST = [V]CST_AFALSE
          RISSDAT = [F:PMVT]MVTDAT
          RISSTYP = [F:PMVT]MVTISSTYP
        Else
          If ([F:PMVT]MVTDAT < RISSDAT) Then
            RISSDAT = [F:PHYSM]MVTDAT
            RISSTYP = [F:PMVT]MVTISSTYP
          Endif
        Endif
        RPHYNBR +=1
      Endif
      Filter [PMVT]
    Next
    # >>>>>>>
    Columns [PHY]
    Filter [PHY]
    LogicClose File [PMVT]
    LogicClose File [PHY]
  Endif

End RRET

#**
#* =================================
#* Private Function: _ISSUE_PHYELT_POPULATION - Physical asset disposal  (using a link with location table)
#* ---------------------------------
#* @private
#* @param  PARAM  : PHYELTISS data class instance contains parameters
#* @return RRET   : CST_ATRUE or CST_AFALSE
#*!
Funprog _ISSUE_PHYELT_POPULATION(PARAM)
Variable Instance PARAM Using C_PHYELTISS

Local Integer RRET, LRET

  # Open PHYELT and PHYLCT for loop
  Local File PHYELT [PHY]
  Local File PHYLCT [LCT]

  # Set the 'via fixed asset' flag
  PARAM.FASFLG = [V]CST_ANO
  # Set the 'source action' code
  PARAM.ORIACT = [V]CST_OANONE

  Link [PHY] With [LCT]LCT0~=LCTCOD As [PHYT]
  Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
  Columns [PHYT](PHYREF, PHYDES1)

  # Callback function before transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    # Count number of physical asset
    Local Integer NBPHY : Raz NBPHY
    NBPHY = rowcount([PHYT])
    # Callback function for count filter
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISS" With (PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  # Disposal of all the physical assets of the filtered population
  Gosub _ISSUE_PHYELT_FILTER
  # RRET is set in _ISSUE_PHYELT_FILTER

  # Callback function after disposal
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR# and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISS" With (PARAM, 3, [L]NBRISSPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif

End RRET

#**
#* =================================
#* Private Function: _ISSUE_PHYELT_POPULATION_FROM_FAS  -  Issue all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTISS data class instance contains parameters
#* @param           ISSDAT     : Disposal date
#* @param           ISSTYPFAS  : Disposal reason
#* @param           PHY_FILTER : Filter for physical asset selection
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _ISSUE_PHYELT_POPULATION_FROM_FAS(PARAM)
Variable Instance PARAM Using C_PHYELTISS
Local Integer RRET, NBPHY

  # Set the 'via fixed asset' flag
  PARAM.FASFLG = [V]CST_AYES
  # Set the 'source action' code
  PARAM.ORIACT = CST_OAFASISSPHY
  # Set the physical 'disposal type'
  # CFF : if validated movement, we should keep the ISSTYP physical asset
  RRET = func _GET_PHY_ISSTYP_FROM_FAS(PARAM.ISSTYPFAS, PARAM.ISSTYP)

  # Open PHYELT for loop
  Local File PHYELT [PHYT]
  Filter [PHYT] Where evalue (PARAM.PHY_FILTER)
  Columns [PHYT](PHYREF, PHYDES1)

  # Callback function after disposal
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    [L]NBPHY = rowcount([PHYT])
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISS" With (PARAM, 1, [L]NBPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  # Disposal of all the physical assets of the filtered population
  Gosub _ISSUE_PHYELT_FILTER

  # Callback function after disposal # FQ113984
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR #and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISS" With (PARAM, 3, [L]NBRISSPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif
  # RRET is set in _ISSUE_PHYELT_FILTER
  LogicClose File [PHYT]

End RRET

#**
#* =================================
#* Private Function: _ISSUE_PHYELT_FILTER - Disposal of all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @return RRET : CST_ATRUE or CST_AFALSE
#*!
$_ISSUE_PHYELT_FILTER
  Local Char    ERRMSG(250)
  Local Integer STACK_ERROR, OK

  # Parameter consitency control
  [L]RRET = CST_ATRUE
  If not (PARAM.ISSDAT <> AVOID.ADATE)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"ISSDAT", "_ISSUE_PHYELT_POPULATION")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    [L]RRET = CST_AFALSE
  Endif
  If not (PARAM.ISSTYP <> AVOID.ALIB)
#  If not (PARAM.ISSTYP <> AVOID.AINT)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"ISSTYP", "_ISSUE_PHYELT_POPULATION")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    [L]RRET = CST_AFALSE
  Endif
  If not (PARAM.FASFLG = [V]CST_AYES or PARAM.FASFLG = [V]CST_ANO)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"FASFLG", "_ISSUE_PHYELT_POPULATION")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    [L]RRET = CST_AFALSE
  Endif
  If not (PARAM.PHY_FILTER <> AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"PHY_FILTER", "_ISSUE_PHYELT_POPULATION")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    [L]RRET = CST_AFALSE
  Endif

  If ([L]RRET = CST_ATRUE)
    Local Instance PHY Using C_PHYELT

    Local Integer NBRISSPHY : [L]NBRISSPHY = 0
    Local Integer OPE_RET
    # >>>>>>>
    For [PHYT]
      [L]NBRISSPHY += 1
      # Allocate instance
      PHY = NewInstance C_PHYELT AllocGroup null
      # Execute disposal operation
      [L]OPE_RET = fmet PHY._PHYELT_ISSUE_OPE([F:PHYT]PHYREF, PARAM)
      If [L]OPE_RET <= [V]CST_AWARNING
        [L]RRET = [V]CST_ATRUE
      Else
        [L]RRET = [V]CST_AFALSE
      Endif

      # Callback function to log the key of issued physical asset
      If PARAM.TRT_CALLBACK <> AVOID.ACHAR
        [L]OK = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISS" With (PARAM, 2, [L]NBRISSPHY, [F:PHYT]PHYREF, [F:PHYT]PHYDES1)
      Endif
      # Free instance
      FreeGroup PHY

      # Stop loop if called by a fixed asset
      If ([L]RRET = [V]CST_AFALSE and PARAM.ORIACT = [V]CST_OAFASISSPHY) Then
        Break
      Endif

      # Delete all messages from PARAM class stack
      [L]OK = fmet PARAM.ADELETEERROR([V]CST_ALLERRORS)
    Next
    # If [L]NBRISSPHY = 0
    #   [L]STACK_ERROR = fmet PARAM.ASETERROR("No physical asset disposal !", [L]ERRMSG, [V]CST_AINFO)
    # Endif
    # >>>>>>>
  Endif
Return

#**
#* =================================
#* Private Function: _CNL_ISSUE_PHYELT_POPULATION_FROM_FAS - Disposal cancellation of all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTISS data class instance contains parameters
#* @param           PHY_FILTER : Filter for physical asset selection
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _CNL_ISSUE_PHYELT_POPULATION_FROM_FAS(PARAM)
Variable Instance PARAM  Using C_PHYELTISS

Local Integer RRET, NBPHY

  # Set the 'via fixed asset' flag
  PARAM.FASFLG = [V]CST_AYES
  # Set the 'source action' code
  PARAM.ORIACT = CST_OAFASCISSPHY

  # Open PHYELT for loop
  Local File PHYELT [PHYT]
  Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
  Columns [PHYT](PHYREF, PHYDES1)

  # Callback function after cancellation of disposal  # FQ113984
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    [L]NBPHY = rowcount([PHYT])
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_ISS" With(PARAM, 1, [L]NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # Disposal cancellation of all the physical assets of the filtered population
  Gosub _CNL_ISSUE_PHYELT_FILTER

  # Callback function after cancellation of disposal
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_ISS" With(PARAM, 3, [L]NBRCISSPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # RRET is set in _CNL_ISSUE_PHYELT_FILTER
  LogicClose File [PHYT]

End RRET

#**
#* =================================
#* Private Function: _CNL_ISSUE_PHYELT_POPULATION - Disposal cancellation of all the physical assets of a filtered population
#* ---------------------------------
#* The function executes the cancellation of the disposal of the physical element selected through a filter.
#* Returns "True" if the function executes well
#*          an array containing the physical asset references whose disposal has been canceled.
#*          an array containing the corresponding description
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTISS data class instance contains parameters
#* @param           FASFLG     : [V]CST_AYES Via Fixed assets - [V]CST_ANO Via Physical assets
#* @param           PHY_FILTER : Filter for physical asset selection
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _CNL_ISSUE_PHYELT_POPULATION(PARAM)
Variable Instance PARAM Using C_PHYELTISS

Local Integer RRET, LRET

  # Open PHYELT and PHYLCT for loop
  Local File PHYELT [PHY]
  Local File PHYLCT [LCT]
  Local File PHYMVT [PMVT]

  # Set the 'via fixed asset' flag
  PARAM.FASFLG = [V]CST_ANO
  # Set the 'source action' code
  PARAM.ORIACT = [V]CST_OANONE

  # If the filter clause contains [F:PMVT] or not
  If (instr(1,PARAM.PHY_FILTER,"[F:PMVT]") = 0) Then
    Link [PHY] With [LCT]LCT0~=LCTCOD As [PHYT]
    Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
    Columns [PHYT](PHYREF, PHYDES1, ISSDAT)
  Else
    Link [PHY] With [LCT]LCT0~=LCTCOD, [PMVT]PMVT0(1)= PHYREF As [PHYT] Where evalue(PARAM.PHY_FILTER)
    # Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
    Columns [PHYT](PHYREF, PHYDES1, ISSDAT)
  Endif

  # Callback function before transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    # Count number of physical asset
    Local Integer NBPHY : Raz NBPHY
    NBPHY = rowcount([PHYT])
    # Callback function for count filter
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_ISS" With (PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # Disposal cancellation of all the physical assets of the filtered population
  Gosub _CNL_ISSUE_PHYELT_FILTER
  # RRET is set in _CNL_ISSUE_PHYELT_FILTER

  # Callback function after disposal cancellation
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR #and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_ISS" With (PARAM, 3, [L]NBRCISSPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  LogicClose File [PHY]
  LogicClose File [LCT]
  LogicClose File [PMVT]

End RRET

#**
#* =================================
#* Private Function: _CNL_ISSUE_PHYELT_FILTER - Disposal cancellation of all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @return RRET : CST_ATRUE or CST_AFALSE
#*!
$_CNL_ISSUE_PHYELT_FILTER
  Local Char    ERRMSG(250)
  Local Integer STACK_ERROR, OK

  RRET = [V]CST_ATRUE

  If not (PARAM.FASFLG = [V]CST_AYES or PARAM.FASFLG = [V]CST_ANO)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"FASFLG", "_CNL_ISSUE_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = CST_AFALSE
  Endif
  If not (PARAM.PHY_FILTER <> AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"PHY_FILTER", "_CNL_ISSUE_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = CST_AFALSE
  Endif

  If ([L]RRET = CST_ATRUE)
    Local Instance PHY Using C_PHYELT

    Local Integer NBRCISSPHY : [L]NBRCISSPHY = 0
    Local Integer OPE_RET
    # >>>>>>>
    For [PHYT]
      [L]NBRCISSPHY += 1

      # Call the operation transfert
      PHY = NewInstance C_PHYELT AllocGroup null
      [L]OPE_RET = fmet PHY._PHYELT_CNL_ISSUE_OPE([F:PHYT]PHYREF, PARAM)
      If [L]OPE_RET <= [V]CST_AWARNING
        [L]RRET = [V]CST_ATRUE
      Else
        [L]RRET = [V]CST_AFALSE
      Endif

      # Callback function to log the key of physical assets transfered
      If PARAM.TRT_CALLBACK <> AVOID.ACHAR
        [L]OK = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_ISS" With (PARAM, 2, NBRCISSPHY, [F:PHYT]PHYREF, [F:PHYT]PHYDES1, [F:PHYT]ISSDAT)
      Endif

      # Free the class instanciation
      FreeGroup PHY
      # Stop loop if call by fixed asset
      If ([L]RRET = CST_AFALSE and PARAM.ORIACT = [V]CST_OAFASCISSPHY) Then
        Break
      Endif

      # Delete all messages from PARAM class stack
      [L]OK = fmet PARAM.ADELETEERROR([V]CST_ALLERRORS)
    Next
    # >>>>>>>
  Endif

Return

#**
#* =================================
#* Private Function: _CNL_ISSUE_LST_MVT_POPULATION - Abandon disposal cancellation of all the physical assets of a filtered population
#* ---------------------------------
#* The function executes the cancellation of the disposal of the physical element selected through a filter.
#* Returns "True" if the function executes well
#*          an array containing the physical asset references whose disposal has been canceled.
#*          an array containing the corresponding description
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTISS data class instance contains parameters
#* @param           PHY_FILTER : Filter for physical asset selection
#* @return RRET  : [V]CST_ATRUE or [V]CST_AFALSE
#*!
Funprog _ISSUE_CNL_LST_MVT_PHYELT_POPULATION(PARAM)
Variable Instance PARAM Using C_PHYELTISS

Local Integer RRET, LRET

