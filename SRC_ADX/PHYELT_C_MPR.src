  # Copying messages from PHY class stack to PARAM class stack
  # because the stack will be deleted after the AUPDATE method
  [L]BRET = func FXDFCT_SYRA.COPY_MSG(this, PARAM)

  If ([L]ARET_VALUE >= [V]CST_AERROR) : Return : Endif

  # Update physical asset
