    # >>>>>>>
  Endif

Return

#**
#* =================================
#* Private Function: _TRANSFER_PHYELT_FROM_PHY - Transfer physical assets (using a link with location table)
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTTRF data class instance contains parameters
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _TRANSFER_PHYELT_FROM_PHY(PARAM)
Variable Instance PARAM Using C_PHYELTTRF

Local Integer RRET, LRET

  # Open PHYELT and PHYLCT for loop
  Local File PHYELT [PHY]
  Local File PHYLCT [LCT]

  PARAM.FASFLG = [V]CST_ANO
  PARAM.ORIACT = [V]CST_OANONE
  RRET = [V]CST_ATRUE

  Link [PHY] With [LCT]LCT0~=LCTCOD As [PHYT]
  Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
  Columns [PHYT](PHYREF, PHYDES1, LCTCOD)

  # Callback function before transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    # Count number of physical asset
    Local Integer NBPHY : Raz NBPHY
    NBPHY = rowcount([PHYT])
    # Callback function for count filter
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_TRF" With (PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  # Call transfer physical assets
  Gosub _TRANSFER_PHYELT_FILTER
  # RRET is set in _TRANSFER_PHYELT_FILTER

  # Callback function after transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_TRF" With (PARAM, 3, [L]NBRTRFPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR)
  Endif

End RRET

#**
#* =================================
#* Private Function: _TRANSFER_PHYELT_FROM_FAS - Transfer physical assets from asset
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTTRF data class instance contains parameters
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _TRANSFER_PHYELT_FROM_FAS(PARAM)
Variable Instance PARAM Using C_PHYELTTRF

Local Integer RRET, NBPHY

  PARAM.FASFLG = [V]CST_AYES
  PARAM.ORIACT = [V]CST_OAFASTRFPHY

  # Open PHYELT for loop
  Local File PHYELT [PHYT]
  Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
  Columns [PHYT](PHYREF, PHYDES1, LCTCOD)

  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_TRF" With(PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  # Call transfer physical assets
  Gosub _TRANSFER_PHYELT_FILTER

  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_TRF" With(PARAM, 3, NBRTRFPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR)
  Endif
  # RRET is set in _TRANSFER_PHYELT_FILTER
  LogicClose File [PHYT]

End RRET

#**
#* =================================
#* Private Function: _TRANSFER_PHYELT_FILTER - Transfer of all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @return RRET : CST_ATRUE or CST_AFALSE
#*!
$_TRANSFER_PHYELT_FILTER
  Local Char    ERRMSG(250)
  Local Integer STACK_ERROR, OK

  RRET = [V]CST_ATRUE
  If not (PARAM.TRFDAT <> AVOID.ADATE)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"TRFDAT", "_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif
  If not (PARAM.TRFTYP <> AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"TRFTYP", "_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif
  If not (PARAM.TRFLCTCOD <> AVOID.ACHAR)
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", mess(85,[V]CST_MSGPHY, 1), [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif
  If not (PARAM.FASFLG = [V]CST_AYES or PARAM.FASFLG = [V]CST_ANO)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"FASFLG", "_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif
  If not (PARAM.PHY_FILTER <> AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"PHY_FILTER", "_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif

  If ([L]RRET = CST_ATRUE)
    Local Instance PHY Using C_PHYELT
    Local Integer NBRTRFPHY : [L]NBRTRFPHY = 0
    Local Integer PHYMET_RET
    # >>>>>>>
    For [PHYT]
      [L]NBRTRFPHY += 1

      # Call the operation transfert
      PHY = NewInstance C_PHYELT AllocGroup null
      [L]PHYMET_RET = fmet PHY._PHYELT_TRANSFER_OPE([F:PHYT]PHYREF, PARAM)
      [L]RRET = ([L]PHYMET_RET <= [V]CST_AWARNING)
      FreeGroup PHY

      # Callback function to log the key of physical assets transfered
      If PARAM.TRT_CALLBACK <> AVOID.ACHAR
        [L]OK = func =PARAM.TRT_CALLBACK + ".CALLBACK_TRF" With (PARAM, 2, NBRTRFPHY, [F:PHYT]PHYREF, [F:PHYT]PHYDES1, [F:PHYT]LCTCOD)
      Endif

      # Stop loop if call by fixed asset
      If ([L]RRET = CST_AFALSE and PARAM.ORIACT = [V]CST_OAFASTRFPHY) Then
        Break
      Endif

      [L]OK = fmet PARAM.ADELETEERROR([V]CST_ALLERRORS)
    Next
    # >>>>>>>
NBPHY = NBRTRFPHY # FQ113984
  Endif

Return

#**
#* =================================
#* Private Function: _CNL_TRANSFER_PHYELT_FROM_PHY - Cancel Transfer physical assets
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTTRF data class instance contains parameters
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _CNL_TRANSFER_PHYELT_FROM_PHY(PARAM)
Variable Instance PARAM Using C_PHYELTTRF

Local Integer RRET, NBPHY
Local Char WSEL(250)

  # Open PHYELT and PHYLCT for loop
  Local File PHYELT [PHY]
  Local File PHYLCT [LCT]
  Local File PHYMVT [PMVT]
#  Local File PHYMVT [PMVT] Where (MVT = [V]CST_PMVGEO or MVT = [V]CST_PMVAGEO)

  PARAM.FASFLG = [V]CST_ANO
  PARAM.ORIACT = [V]CST_OANONE

#  Warning :
#  this condition is done here
#  because the test and join with PHYMVT table depend if the [M:PHYM1]TRFDAT date is empty or not.
  If PARAM.TRFDAT = [0/0/0]
    Link [PHY] With [LCT]LCT0~=LCTCOD As [PHYT]
    Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
  Else
    Link [PHY] With [LCT]LCT0~=LCTCOD, [PMVT]PMVT0(1) = PHYREF As [PHYT]

    [L]WSEL  = "(" + PARAM.PHY_FILTER + ") and"
    [L]WSEL -= "(TRFDAT = PARAM.TRFDAT or"
    [L]WSEL -= "([F:PMVT]MVTDAT = PARAM.TRFDAT and"
    [L]WSEL -= "([F:PMVT]MVT =" - num$([V]CST_PMVGEO) - "or [F:PMVT]MVT =" - num$([V]CST_PMVAGEO) + ")))"

    Filter [PHYT] Where evalue([L]WSEL)
  Endif

#  Columns [PHYT](PHYREF, PHYDES1, LCTCOD)

  # Count number of physical asset
  Local Integer NBPHY : Raz NBPHY

  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    NBPHY = rowcount([PHYT])
    # Callback function for count filter
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_TRF" With(PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # Call transfer physical assets
  Gosub _CNL_TRANSFER_PHYELT_FILTER

  # Callback function after transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_TRF" With (PARAM, 3, [L]NBRTRFPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # RRET is set in _TRANSFER_PHYELT_FILTER
  LogicClose File [PHYT]

End RRET

#**
#* =================================
#* Private Function: _CNL_TRANSFER_PHYELT_FROM_FAS - Cancel Transfer physical assets from asset
#* ---------------------------------
#* @private
#* @param  PARAM : PHYELTTRF data class instance contains parameters
#* @return RRET  : CST_ATRUE or CST_AFALSE
#*!
Funprog _CNL_TRANSFER_PHYELT_FROM_FAS(PARAM)
Variable Instance PARAM Using C_PHYELTTRF

Local Integer RRET, NBPHY

  PARAM.FASFLG = [V]CST_AYES
  PARAM.ORIACT = [V]CST_OAFASCTRFPHY

  # Open PHYELT for loop
  Local File PHYELT [PHYT]
  Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
#  Columns [PHYT](PHYREF, PHYDES1, LCTCOD)

  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_TRF" With(PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # Call transfer physical assets
  Gosub _CNL_TRANSFER_PHYELT_FILTER

  # Callback function after transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_TRF" With (PARAM, 3, [L]NBRTRFPHY, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ADATE)
  Endif

  # RRET is set in _TRANSFER_PHYELT_FILTER
  LogicClose File [PHYT]

End RRET

#**
#* =================================
#* Private Function: _CNL_TRANSFER_PHYELT_FILTER - Cancel transfer of all the physical assets of a filtered population
#* ---------------------------------
#* @private
#* @return RRET : CST_ATRUE or CST_AFALSE
#*!
$_CNL_TRANSFER_PHYELT_FILTER
  Local Char    ERRMSG(250), WLCTO(GLONLCT)
  Local Integer STACK_ERROR, OK, I_TRFMVT

  RRET = CST_ATRUE

  If not (PARAM.FASFLG = [V]CST_AYES or PARAM.FASFLG = [V]CST_ANO)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"FASFLG", "_CNL_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif
  If not (PARAM.PHY_FILTER <> AVOID.ACHAR)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60,[V]CST_MSGMIS, 1),"PHY_FILTER", "_CNL_TRANSFER_PHYELT_FILTER")
    [L]STACK_ERROR = fmet PARAM.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    RRET = [V]CST_AFALSE
  Endif

  If ([L]RRET = CST_ATRUE)
    Local Instance PHY Using C_PHYELT

    Local Integer NBRTRFPHY : [L]NBRTRFPHY = 0
    Local Integer PHYMET_RET
    # >>>>>>>
    For [PHYT]
      [L]NBRTRFPHY += 1

      # Call the operation transfert
      PHY = NewInstance C_PHYELT AllocGroup null
      [L]PHYMET_RET = fmet PHY._PHYELT_CNL_TRANSFER_OPE([F:PHYT]PHYREF, PARAM)
      If [L]PHYMET_RET <= [V]CST_AWARNING
        [L]RRET = [V]CST_ATRUE
      Else
        [L]RRET = [V]CST_AFALSE
      Endif

      # Callback function to log the key of physical assets transfered
      If PARAM.TRT_CALLBACK <> AVOID.ACHAR
        WLCTO = AVOID.ACHAR
        If [F:PHYT]LCTCOD <> PHY.LCTCOD
          WLCTO = PHY.LCTCOD
        Endif
        # 1°, pending movement for validation of the TRANSFER must be deleted
        # If found, no extourn movement is needed
        [L]OK = func =PARAM.TRT_CALLBACK + ".CALLBACK_CNL_TRF" With (PARAM, 2, NBRTRFPHY, [F:PHYT]PHYREF, [F:PHYT]PHYDES1, WLCTO, [F:PHYT]LCTCOD, [F:PHYT]TRFDAT)
      Endif

      # Free the class instanciation
      FreeGroup PHY
      # Stop loop if call by fixed asset
      If ([L]RRET = CST_AFALSE and PARAM.ORIACT = [V]CST_OAFASCTRFPHY) Then
        Break
      Endif

      # Delete all messages from PARAM class stack
      [L]OK = fmet PARAM.ADELETEERROR([V]CST_ALLERRORS)
    Next
    # >>>>>>>
  Endif

Return

#**
#* @param P_ISSACT  : Kind of action
#* @param P_ISSDATE : Issue date
#* @param P_ISSTYPE : Issue type
#* #*!
$_PHYELT_ISSUE_MANAGEMENT
Local Char  ERRMSG(140)

  # PHYELTISS Data Class
  Local Instance PARAM Using C_PHYELTISS
  PARAM = NewInstance C_PHYELTISS AllocGroup null

  PARAM.FASFLG = [V]CST_ANO
  Case P_ISSACT
    When [V]CST_IAISS
      # Disposal
      PARAM.ISSDAT = P_ISSDAT
      PARAM.ISSTYP = P_ISSTYP
      If not (fmet this._PHYELT_ISSUE_OPE(this.PHYREF,PARAM) = [V]CST_AOK)
        [L]ASTATUS = fmet this.AGETMAXERROR("")
      Endif
    When [V]CST_IACNLISS
      # Disposal cancellation
      If not (fmet this._PHYELT_CNL_ISSUE_OPE(this.PHYREF,PARAM) = [V]CST_AOK)
        [L]ASTATUS = fmet this.PHYISS.AGETMAXERROR("")
      Endif
    When [V]CST_IADELMVT
      # Abandon disposal cancellation
      If not (fmet this._PHYELT_ISSUE_CNL_LST_MVT_OPE(this.PHYREF) = [V]CST_AOK)
        [L]ASTATUS = fmet this.AGETMAXERROR("")
      Endif
  Endcase

  FreeGroup PARAM
Return

#**
#* @param P_TRFDAT    : Transfer date
#* @param P_TRFTYP    : Transfer reason
#* @param P_TRFLCTCOD : New location
#* #*!
$_PHYELT_TRANSFER_MANAGEMENT
Local Char  ERRMSG(140)
  # PHYELTTRF Data Class
  Local Instance PARAM Using C_PHYELTTRF
  PARAM = NewInstance C_PHYELTTRF AllocGroup null

  PARAM.FASFLG    = [V]CST_ANO
  PARAM.TRFDAT    = P_TRFDAT
  PARAM.TRFTYP    = P_TRFTYP
  PARAM.TRFLCTCOD = P_TRFLCTCOD
  If not (fmet this._PHYELT_TRANSFER_OPE(this.PHYREF,PARAM) = [V]CST_AOK)
    [L]ASTATUS = fmet this.AGETMAXERROR("")
  Endif

  FreeGroup PARAM
Return

#**
#* @param PHYREF    : Physical asset reference
#* #*!
$_CANCEL
Local Char  ERRMSG(140)
  [L]ASTATUS = [V]CST_AOK
Return

#**
#* =================================
#* Private Methode: _PHYELT_DUPLICATE  -  Physical asset duplicate
#* #* ---------------------------------
#*Duplicate physical asset
#*
#* @private
#* @param PARAMETRE : Instance en cours
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#*!
$_PHYELT_DUPLICATE_OPE
  Local Char SMESSAGE(250)
  Local Integer IRET
  Local Char SNUMERO(GLONVCR)
  Local Char _CNT(100)

  ARET_VALUE = [V]CST_AOK

  #New Instance to create
  Local Instance OLDPHYELT Using C_PHYELT : OLDPHYELT = NewInstance C_PHYELT AllocGroup null
  ARET_VALUE =   fmet OLDPHYELT.AREAD(PHYREF)
  Local Instance NEWPHYELT Using C_PHYELT : NEWPHYELT = NewInstance C_PHYELT AllocGroup OLDPHYELT

  If clalev([F:ELT])=0  : Local File PHYELT [ELT]     : Endif

  SetInstanceNoSys   [ELT] With OLDPHYELT #transclass
  SetInstanceNoSys   NEWPHYELT With [ELT]

  Local Integer LIN
  # Charge le Comment ( non chargé sinon ! )
  # [L]ASTATUS = fmet OLDPHYELT.AREAD_CLB("COMMENT", OLDPHYELT.PHYREF ,[L]_CNT,NEWPHYELT.COMMENT)

  If [L]ASTATUS=[V]CST_AOK
  # Issue X3-101936
    # leaving the PHYREF to blank will process to get the right ref counter through the AINSERT
    #IRET = func ANM_TOOL.NUMERO( this.ACTX,"PHY",NEWPHYELT.FCY,date$,"",SNUMERO,SMESSAGE )
    If func AFNC.ACTIV("PHY")
      Local Integer WPHYAUTONUM
      [L]WPHYAUTONUM = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,NEWPHYELT.CPY,"PHYAUTNUM")
      # The parameter PHYAUTNUM should not be set to None
      If [L]WPHYAUTONUM = [V]CST_NAAUCUNE Then
        #"The automatic creation of physical assets is not possible because the PHYAUTNUM parameter is not compatible"
        [L]ASTATUS = fmet this.ASETERROR("",mess(126,[V]CST_MSGPHY, 1), [V]CST_AERROR)
        [L]ARET_VALUE = fmet this.AGETMAXERROR("")
        FreeGroup OLDPHYELT
        Return
      Endif
    Endif
  # End issue X3-101936
    NEWPHYELT.PHYREF = SNUMERO

    NEWPHYELT.ORDBUY=AVOID.ACHAR
    NEWPHYELT.DORDBUY=AVOID.ADATE
    NEWPHYELT.NUMRECEP=AVOID.ACHAR
    NEWPHYELT.DNUMRECEP=AVOID.ADATE # Date reception
    NEWPHYELT.BAC=AVOID.ACHAR
    NEWPHYELT.SRLNBR=AVOID.ACHAR # Numéro de série
    NEWPHYELT.AASREF=AVOID.ACHAR # Rattachement Bien Comptable
    NEWPHYELT.IVYDAT=AVOID.ADATE
    NEWPHYELT.IVYTIM=AVOID.ACHAR
    NEWPHYELT.IVYRES=0
    NEWPHYELT.CURCND=AVOID.ACHAR
    NEWPHYELT.ISSDAT=AVOID.ADATE
    NEWPHYELT.ISSTYP=[V]CST_PDNOTISS #1 Menu Local 3175 Motif de sortie - Non Sorti
    NEWPHYELT.TRFDAT=AVOID.ADATE
    NEWPHYELT.GRUORIPHY=AVOID.ACHAR
    NEWPHYELT.CREORI=[V]CST_COAUTRE
    NEWPHYELT.CREUSR=GACTX.USER
    NEWPHYELT.UPDUSR=GACTX.USER
    NEWPHYELT.PHYREFORI=AVOID.ACHAR
    NEWPHYELT.CREDATTIM=date$
    NEWPHYELT.UPDDATTIM=AVOID.ACHAR
    NEWPHYELT.AUUID=getUuid

    For [L]LIN = maxtab(NEWPHYELT.PHYMVT) To 1 Step -1
      [L]ARET_VALUE = fmet NEWPHYELT.ADELLINE("PHYMVT", [L]LIN)
    Next [L]LIN

    # Create new Instance in database
    [L]ASTATUS = fmet NEWPHYELT.AINSERT()
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR("",mess(00100,00141,1)-NEWPHYELT.PHYREF,[V]CST_AERROR)
     Else
          # Récupération Photo
      [L]ASTATUS = func COPYPHOTO("PHYELT",OLDPHYELT.PHYREF,NEWPHYELT.PHYREF )
      If not [L]ASTATUS = [V]CST_AOK

      Endif
      [L]ASTATUS = fmet this.ASETERROR("",mess(00032,00141,1)-NEWPHYELT.PHYREF,[V]CST_ASUCCESS)
    Endif
  Else
      [L]ASTATUS = fmet this.ASETERROR("",mess(00091,00143,1)-NEWPHYELT.PHYREF,[V]CST_AERROR)
  Endif
  [L]ARET_VALUE = fmet this.AGETMAXERROR("")
  FreeGroup OLDPHYELT
Return

#**
#*
#* Function:  COPYPHOTO
#*
#* Purpose:  Copy the blob photo on the FXTABLE table, return result of copy ( fstat )
#*
#* Parameters:
#* @param CODBLOB          Variable Char() CodeBLOB To copy
#* @param IDENTOLD            OLD ident
#* @param IDENTNEW            New ident
#*
#*!
Funprog COPYPHOTO(CODBLOB, IDENTOLD , IDENTNEW)
Value Char CODBLOB()
Value Char IDENTOLD()
Value Char IDENTNEW()

 Local File FXBLOB [FBB]
 Read [FBB]ABB0= CODBLOB;IDENTOLD
 If fstat = [V]CST_AOK
  [FBB]IDENT1=IDENTNEW
  [FBB]AUUID= getUuid
  Write  [FBB]
 Endif
Close Local File [FBB]

End fstat

