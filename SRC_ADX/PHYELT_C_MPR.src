  # If the filter clause contains [F:PMVT] or not
  If (instr(1,PARAM.PHY_FILTER,"[F:PMVT]") = 0) Then
    Link [PHY] With [LCT]LCT0~=LCTCOD As [PHYT]
    Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
    Columns [PHYT](PHYREF, PHYDES1)
  Else
    Link [PHY] With [LCT]LCT0~=LCTCOD, [PMVT]PMVT0(1)= PHYREF As [PHYT] Where evalue(PARAM.PHY_FILTER)
    # Filter [PHYT] Where evalue(PARAM.PHY_FILTER)
    Columns [PHYT](PHYREF, PHYDES1)
  Endif

  # Callback function before transfer
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR
    # Count number of physical asset
    Local Integer NBPHY : Raz NBPHY
    NBPHY = rowcount([PHYT])
    # Callback function for count filter
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISSUE_CNL_LST_MVT" With (PARAM, 1, NBPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  # Disposal cancellation of all the physical assets of the filtered population
  Gosub _ISSUE_CNL_LST_MVT_FILTER
  # RRET is set in _CNL_ISSUE_PHYELT_FILTER

  # Callback function after disposal cancellation
  If PARAM.TRT_CALLBACK <> AVOID.ACHAR and [L]RRET = [V]CST_ATRUE
    [L]RRET = func =PARAM.TRT_CALLBACK + ".CALLBACK_ISSUE_CNL_LST_MVT" With (PARAM, 3, [L]NBRCISSPHY, AVOID.ACHAR, AVOID.ACHAR)
  Endif

  LogicClose File [PHY]
  LogicClose File [LCT]
  LogicClose File [PMVT]

End RRET

