#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque CRITPATCH
Local Char VALEUR(10)
Local Char PARAM(10)(1..100)
Call TRAITE_CHAR(VALEUR,PARAM,"FAPATCHA","APATCHA","DCRITPAT",3,"") From GTRAITE
End

######################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

######################################################################
$SEL_LISTE
Case LISTE
 When "SELFIC"  : Gosub S_FIC
Endcase
Return

$S_FIC
Local Char    MOT(80)
Local Char    TEX(10)(1..1000) , TEXTE(30)(1..1000,1..3) , TIT(30)(0..3), CRITERE(250)(1..2)
Local Integer NBTEX, OK , OKCODACT
TIT(0) = mess(8,31,1)   : # Sélection
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
TIT(3) = mess(88,100,1) : # Date
For I=0 To NBLIG3-1
 If [M:CPAT]CODACT(I)<>""
  OKCODACT =2 : Break
 Endif
Next
Raz TEX,TEXTE
Raz NBTEX
FORCE = 1
Gosub CHARGE
Return

###################
$CHARGE
Local Char TABLE(30),ABREV(10)
Local Date DATEDEB : [L]DATEDEB = [M]DATDEB
Local Date DATEFIN : [L]DATEFIN = [M]DATFIN

[L]ABREV=[M:APA]CODE(nolign-1)
Read [F:AOB]ABREV=[L]ABREV
[L]TABLE = [F:AOB]NOMFIC

Local Char WAPPEL(30) : WAPPEL="APATCHL/CHARGE"
Gosub LIST_OBJ From APATCHA
Return

$CRITERE_USR
CRITERE(2)  = '& ((UPDUSR<>"" & UPDUSR = [M:CPAT]USR) | (UPDUSR=""  & CREUSR = [M:CPAT]USR))'
Return
