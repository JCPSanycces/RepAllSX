#<AdxTL>@(#)53.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
###########################################################
#Sous programme d'affichage des régularisations de prix
# LFCY = Site de stock
# LTYP = Type pièce
# LNUM = Numéro pièce
# LLIN = Ligne pièce
# LSTU = Unité stock
#
Subprog AFFREG(LFCY,LTYP,LNUM,LLIN,LSTU)
Variable Char    LFCY
Variable Integer LTYP
Variable Char    LNUM
Variable Integer LLIN 
Variable Char    LSTU
#
Local Integer CHOIX
Local Integer SAVOBJET
Local Char    SAVPROG
Local Integer WPRE
Local Integer WNOLIGN
Local Integer WFSTAT 
Local Integer WBOU(1..GNBBOU)  
Local Integer I
Local Integer ISEL
Local Integer WLEC
#
WNOLIGN = nolign
Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME  
GOBJET   = 0 
# 
For I = 1 To GNBBOU  
  WBOU(I) = 0  
Next I  
WBOU(GVALI) = 1
WBOU(GABAN) = 1
WBOU(GSPE1) = 1
Call SETBOUT(WBOU) From GESECRAN   
#  
If clalev([F:SCR]) = 0 Local File STOCSTREG    [SCR] : Endif
Local Mask STKG[STKG]
Local Dlgbox Mask [STKG]
&    Button mess(64,123,1)
&    With left$(mess(64,123,1),1)
&    Coded GSTAOK
&    Titled mess(64,200,1)
&    As [STKG]
Boxact [STKG]
#
Raz [M:STKG]
[M:STKG]STOFCY  = LFCY
[M:STKG]VCRTYP  = LTYP
[M:STKG]VCRNUM  = LNUM
[M:STKG]VCRLIN  = LLIN
[M:STKG]STU     = LSTU
nolign = 0
Filter [SCR] Where STOFCY = LFCY &
&                  VCRTYP = LTYP &
&                  VCRNUM = LNUM &
&                  VCRLIN = LLIN  
&            Order By Key SCR0
For [SCR]
  If nolign < dim([M:STKG]IPTDAT)-1
    nolign += 1
    [M:STKG] = [F:SCR]
  Else
    Break
  Endif
Next   
[M:STKG]BASPAG = nolign
Filter [SCR]
Affzo [M:STKG]1-99
If nolign = 0
  Call ERREUR(mess(99,100,1)) From GESECRAN
Endif  
$AFFEMP1
Boxinp [STKG] Using CHOIX
Close Local File [SCR]
#
nolign     = WNOLIGN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
Call RESTBOUT From GESECRAN
End
