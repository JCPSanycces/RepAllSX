#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : articles/pieces détachées
#                             cf AML 2240 : 19/22
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables ITMWPIV devient WK, 
#                                                   STJWPIV devient SWK
#                                                   ITPWPIV devient PWK
#                                                   ITVWPIV devient VWK
######################################################################
$OUVTAB_ITM
If !clalev([F:TFO]) Local File TABFOR    [TFO] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If !clalev([F:ITG]) Local File ITMCATEG  [ITG] Endif
If !clalev([F:ITV]) Local File ITMMVT    [ITV] Endif
If !clalev([F:ITP]) Local File ITMBPS    [ITP] Endif
If !clalev([F:BPS]) Local File BPSUPPLIER[BPS] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPA]) Local File BPADDRESS [BPA] Endif   
If !clalev([F:ITS]) Local File ITMSALES  [ITS] Endif
If !clalev([F:FCY]) Local File FACILITY  [FCY] Endif

If !clalev([F:STJ]) Local File STOJOU  [STJ] Endif

If !clalev([F:PPL]) Local File PPRICLIST [PPL] Endif
If !clalev([F:PPK]) Local File PPRICLINK [PPK] Endif

Return

######################################################################
Subprog TRT_ITM(ID,CLETRT,PITITM,P_ITMFOR,PITITV,PITITP,PITSTJ,P_CRITSTJ,P_STRDAT,P_NBJOUR,P_ENDDAT,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITITM () 
Value Char P_ITMFOR() 
Value Char PITITV () 
Value Char PITITP() 
Value Char PITSTJ() 
Value Char P_CRITSTJ() 
Value Date P_STRDAT
Value Integer P_NBJOUR
Value Date P_ENDDAT
Variable Integer OK

If PITITM="" & PITITV="" & PITITP="" & PITSTJ="" : Return : Endif

Local Char     FORMULE1(255) : Raz FORMULE1   # chargement de P_ITMFOR
Local Char WFIL1(255),WFIL2(255),WFIL3(255)

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_ITM
Gosub OUVREPIVOT From CONNECTFCT


If PITITM<>""
    Local Integer WNBITM  : Raz WNBITM 
    Local Integer WPREITM : Raz WPREITM
    Local Char    OPTITM(GDIMFIC)
    OPTITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititm")
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP       : Raz WKHEATYP 
    Local Char    WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITITM,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREITM,OPTITM) From CONNECTFCT
Endif
If PITITV<>""
    Local Integer WNBITV  : Raz WNBITV
    Local Integer WPREITV : Raz WPREITV
    Local Char    OPTITV(GDIMFIC)
    OPTITV = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititv")
    Local Integer VWKNBZON        : Raz VWKNBZON
    Local Char    VWKNORECMES (50): Raz VWKNORECMES 
    Local Integer VWKHEATYP       : Raz VWKHEATYP 
    Local Char    VWKHEADMES (250): Raz VWKHEADMES 
    
    Call READPIT(PITITV,VWKNBZON,VWKNORECMES,VWKHEATYP ,VWKHEADMES ) From CONNECTFCT
    Local Char    VWKTABZON(GLONATB+GLONAVA+2)(1..VWKNBZON) : Raz VWKTABZON
    Local Char    VWKTABABR(GLONABR)(1..VWKNBZON) : Raz VWKTABABR
    Local Char    VWKZON(GLONAVA)(1..VWKNBZON) : Raz VWKTABZON
    Local Char    VWKFRM(150)(1..VWKNBZON) : Raz VWKFRM
    Local Integer VWKWRK(1..VWKNBZON) : Raz VWKWRK
    Local Char    VWKVAL(255)(1..VWKNBZON) : Raz VWKVAL
    Local Char    VWKVALFIC(GLONAVA)(1..VWKNBZON) : Raz VWKVALFIC
    Call LOADPIVZON(PITITV,VWKNBZON,VWKTABZON,VWKTABABR,VWKZON,VWKFRM,VWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITITV,VWKNBZON,VWKTABZON,VWKTABABR,VWKZON,VWKWRK,VWKHEATYP,VWKHEADMES,WPREITV,OPTITV) From CONNECTFCT
Endif
If PITSTJ<>""
    Local Integer WNBSTJ  : Raz WNBSTJ
    Local Integer WPRESTJ : Raz WPRESTJ
    Local Char    OPTSTJ(GDIMFIC)
    OPTSTJ = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitstj")
    Local Integer SWKNBZON        : Raz SWKNBZON
    Local Char    SWKNORECMES (50): Raz SWKNORECMES 
    Local Integer SWKHEATYP       : Raz SWKHEATYP 
    Local Char    SWKHEADMES (250): Raz SWKHEADMES 
    
    Call READPIT(PITSTJ,SWKNBZON,SWKNORECMES,SWKHEATYP ,SWKHEADMES ) From CONNECTFCT
    Local Char    SWKTABZON(GLONATB+GLONAVA+2)(1..SWKNBZON) : Raz SWKTABZON
    Local Char    SWKTABABR(GLONABR)(1..SWKNBZON) : Raz SWKTABABR
    Local Char    SWKZON(GLONAVA)(1..SWKNBZON) : Raz SWKTABZON
    Local Char    SWKFRM(150)(1..SWKNBZON) : Raz SWKFRM
    Local Integer SWKWRK(1..SWKNBZON) : Raz SWKWRK
    Local Char    SWKVAL(255)(1..SWKNBZON) : Raz SWKVAL
    Local Char    SWKVALFIC(GLONAVA)(1..SWKNBZON) : Raz SWKVALFIC
    Call LOADPIVZON(PITSTJ,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITSTJ,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKWRK,SWKHEATYP,SWKHEADMES,WPRESTJ,OPTSTJ) From CONNECTFCT
Endif
If PITITP<>""
    Local Integer WNBITP  : Raz WNBITP
    Local Integer WPREITP : Raz WPREITP
    Local Char    OPTITP(GDIMFIC)
    OPTITP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititp")
    Local Integer PWKNBZON        : Raz PWKNBZON
    Local Char    PWKNORECMES (50): Raz PWKNORECMES 
    Local Integer PWKHEATYP       : Raz PWKHEATYP 
    Local Char    PWKHEADMES (250): Raz PWKHEADMES 
    
    Call READPIT(PITITP,PWKNBZON,PWKNORECMES,PWKHEATYP ,PWKHEADMES ) From CONNECTFCT
    Local Char    PWKTABZON(GLONATB+GLONAVA+2)(1..PWKNBZON) : Raz PWKTABZON
    Local Char    PWKTABABR(GLONABR)(1..PWKNBZON) : Raz PWKTABABR
    Local Char    PWKZON(GLONAVA)(1..PWKNBZON) : Raz PWKTABZON
    Local Char    PWKFRM(150)(1..PWKNBZON) : Raz PWKFRM
    Local Integer PWKWRK(1..PWKNBZON) : Raz PWKWRK
    Local Char    PWKVAL(255)(1..PWKNBZON) : Raz PWKVAL
    Local Char    PWKVALFIC(GLONAVA)(1..PWKNBZON) : Raz PWKVALFIC
    Call LOADPIVZON(PITITP,PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKFRM,PWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITITP,PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKWRK,PWKHEATYP,PWKHEADMES,WPREITP,OPTITP) From CONNECTFCT
Endif
#######
Gosub TRT_FORMULE
Link [ITM] With [ITG]ITG1~=[F:ITM]TCLCOD
& As [LNK] 
& Order By Key KEY1=[ITM]ITMREF;[ITG]TCLCOD

Local Date WSTRDAT : WSTRDAT=[0/0/0]
If P_STRDAT<>[0/0/0]
    WSTRDAT=P_STRDAT
Elsif P_NBJOUR>0
    WSTRDAT=P_ENDDAT-P_NBJOUR
Endif

If FORMULE1="" : FORMULE1="1=1" : Endif
For [LNK]KEY1(1) Where [F:ITG]MCEFLG=2 and evalue(FORMULE1)
    Gosub WR_ITM

    If PITITV<>"" | PITSTJ<>""
        For [ITV] Where ITMREF=[F:ITM]ITMREF
            Gosub WR_ITV
            If PITSTJ<>"" : #on fait la lecture des STJ
WFIL1="[F:STJ]STOFCY=[F:ITV]STOFCY&[F:STJ]UPDCOD=2&[F:STJ]REGFLG<>2&[F:STJ]ITMREF=[F:ITV]ITMREF"
WFIL2="[F:STJ]IPTDAT>=WSTRDAT&[F:STJ]IPTDAT<=P_ENDDAT"
WFIL3="[F:STJ]TRSTYP<>0&find([F:STJ]TRSTYP,7,8,9,21,23,25)=0"
                Filter [STJ]
                Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(P_CRITSTJ)
&                  Order By STOFCY; UPDCOD; ITMREF; IPTDAT Desc; MVTSEQ
                For [STJ]
                    Gosub WR_STJ
                Next
                Filter [STJ]
            Endif
        Next
    Endif

    If PITITP<>""
        For [ITP] Where ITMREF=[F:ITM]ITMREF
            Raz [F:PPL]
            # FQ 65322 GA 06/2010 le tarif n'est pas obligatoire
            #If [F:PPL]PLI<>""
                Gosub WR_ITP
            #Endif
        Next
    Endif
Next
#######
If PITITM<>"" : Call WRPIVOT_END(PITITM ,WNBITM ,WKNORECMES ,WPREITM ,OPTITM) From CONNECTFCT : Endif
If PITITV<>"" : Call WRPIVOT_END(PITITV ,WNBITV ,VWKNORECMES ,WPREITV ,OPTITV) From CONNECTFCT : Endif
If PITSTJ<>"" : Call WRPIVOT_END(PITSTJ ,WNBSTJ ,SWKNORECMES ,WPRESTJ ,OPTSTJ) From CONNECTFCT : Endif
If PITITP<>"" : Call WRPIVOT_END(PITITP ,WNBITP ,PWKNORECMES ,WPREITP ,OPTITP) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$TRT_FORMULE
If P_ITMFOR <> ""
    # FQ 65180 GA 06/2010 éviter pb de migration on garde les memes types de formule en V5 et V6
    # Menu local 213 rectifié en V5
    #If pat(GVERSION,"1.5.*")
    #Read [F:TFO]TFO0=27;P_ITMFOR
    #Else
    Read [F:TFO]TFO0=41;P_ITMFOR
    #Endif
    If !fstat 
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif
Return
######################################################################
$WR_ITM
If PITITM<>""
    ################################
    # fichiers ITM
    ################################
    #     Ouverture du fichier OPTITM en écriture
    If WPREITM = 0
      Openo OPTITM,0 Using [FPIV]
      WPREITM = 1
    Else
      Openo OPTITM Using [FPIV]
    Endif
    WNBITM += 1
    Call RAZVALPIVOT(PITITM,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_ITV
If PITITV<>""
    ################################
    # fichiers ITV
    ################################
    #     Ouverture du fichier OPTITV en écriture
    If WPREITV = 0
      Openo OPTITV,0 Using [FPIV]
      WPREITV = 1
    Else
      Openo OPTITV Using [FPIV]
    Endif
    WNBITV += 1
    Call RAZVALPIVOT(PITITV,VWKNBZON,VWKVAL,VWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITITV,VWKNBZON,VWKTABZON,VWKTABABR,VWKZON,VWKFRM,VWKWRK,VWKVAL,VWKVALFIC) From CONNECTFCT
    Call WRPIVOT(VWKNBZON,VWKTABZON,VWKTABABR,VWKZON,VWKFRM,VWKWRK,VWKVAL,VWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_STJ
If PITSTJ<>""
    ################################
    # fichiers STJ
    ################################
    #     Ouverture du fichier OPTSTJ en écriture
    If WPRESTJ = 0
      Openo OPTSTJ,0 Using [FPIV]
      WPRESTJ = 1
    Else
      Openo OPTSTJ Using [FPIV]
    Endif
    WNBSTJ += 1
    Call RAZVALPIVOT(PITSTJ,SWKNBZON,SWKVAL,SWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITSTJ,SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK,SWKVAL,SWKVALFIC) From CONNECTFCT
    Call WRPIVOT(SWKNBZON,SWKTABZON,SWKTABABR,SWKZON,SWKFRM,SWKWRK,SWKVAL,SWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_ITP
If PITITP<>""
    ################################
    # fichiers ITP
    ################################
    #     Ouverture du fichier OPTITP en écriture
    If WPREITP = 0
      Openo OPTITP,0 Using [FPIV]
      WPREITP = 1
    Else
      Openo OPTITP Using [FPIV]
    Endif
    WNBITP += 1
    Call RAZVALPIVOT(PITITP,PWKNBZON,PWKVAL,PWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITITP,PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKFRM,PWKWRK,PWKVAL,PWKVALFIC) From CONNECTFCT
    Call WRPIVOT(PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKFRM,PWKWRK,PWKVAL,PWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
# FQ 65322 GA 06/2010 renseigner les zones si pas de tarif trouvé
Funprog PPL_GETPUU(LITMREF,LBPSNUM,LPSHFCY)
Value Char LITMREF
Value Char LBPSNUM
Value Char LPSHFCY

Gosub OPEN_FILES_PSM
Gosub PPL_READ_FILES

If [F:PPL]UOM<>"" End [F:PPL]UOM Endif
If [F:ITP]PUU<>"" End [F:ITP]PUU Endif
If [F:ITM]PUU<>"" End [F:ITM]PUU Endif
If [F:ITG]PUU<>"" End [F:ITG]PUU Endif

End ""
######################################################################
# FQ 65322 GA 06/2010 renseigner les zones si pas de tarif trouvé
Funprog PPL_GETLTI(LITMREF,LBPSNUM,LPSHFCY)
Value Char LITMREF
Value Char LBPSNUM
Value Char LPSHFCY

Gosub OPEN_FILES_PSM
Gosub PPL_READ_FILES

If [F:PPL]LTI>0 End [F:PPL]LTI Endif
If LPSHFCY<>"" & [F:ITF]OFS>0 End [F:ITF]OFS Endif
If [F:ITM]OFS>0 End [F:ITM]OFS Endif
If [F:ITG]OFS>0 End [F:ITG]OFS Endif

End 0
######################################################################
# FQ 65322 GA 06/2010 renseigner les zones si pas de tarif trouvé
Funprog PPL_GETPRI(LITMREF,LBPSNUM,LPSHFCY)
Value Char LITMREF
Value Char LBPSNUM
Value Char LPSHFCY

Gosub OPEN_FILES_PSM
Gosub PPL_READ_FILES

If [F:PPL]PRI>0 End [F:PPL]PRI Endif

End 0
######################################################################
# FQ 65322 GA 06/2010 renseigner les zones si pas de tarif trouvé
Funprog PPL_GETMINQTY(LITMREF,LBPSNUM,LPSHFCY)
Value Char LITMREF
Value Char LBPSNUM
Value Char LPSHFCY

Gosub OPEN_FILES_PSM
Gosub PPL_READ_FILES

If [F:PPL]MINQTY>0    End [F:PPL]MINQTY    Endif
If [F:ITP]PURMINQTY>0 End [F:ITP]PURMINQTY Endif
If [F:ITG]MINQTY>0    End [F:ITG]MINQTY    Endif

End 0
######################################################################
$OPEN_FILES_PSM
If !clalev([F:BPS]) Local File BPSUPPLIER[BPS] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPA]) Local File BPADDRESS [BPA] Endif   
If !clalev([F:FCY]) Local File FACILITY  [FCY] Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If !clalev([F:ITF]) Local File ITMFACILIT[ITF] Endif
If !clalev([F:ITG]) Local File ITMCATEG  [ITG] Endif
If !clalev([F:ITP]) Local File ITMBPS    [ITP] Endif
If !clalev([F:PPC]) Local File PPRICCONF [PPC] Endif
If !clalev([F:PPL]) Local File PPRICLIST [PPL] Endif
If !clalev([F:PPK]) Local File PPRICLINK [PPK] Endif
If !clalev([F:PSD]) Local File PREQUISD  [PSD] Endif
If !clalev([F:PSH]) Local File PREQUIS   [PSH] Endif
Return
######################################################################^
$PPL_READ_FILES

# Fiche Article
If [F:ITM]ITMREF <> LITMREF 
    Read [ITM]ITM0=LITMREF
    If fstat : Raz [F:ITM] : Endif
Endif

# Fiche Catégorie-Article
If [F:ITG]TCLCOD <> [F:ITM]TCLCOD
    Read [ITG]ITG0=[F:ITM]TCLCOD
    If fstat : Raz [F:ITG] : Endif
Endif

# Fiche Fournisseur
If LBPSNUM<>"" 
    If [F:BPR]BPRNUM <> LBPSNUM 
        Read [BPR]BPR0=LBPSNUM
        If fstat : Raz [F:BPR] : Endif
    Endif
    
    If [F:BPS]BPSNUM <> LBPSNUM 
        Read [BPS]BPS0=LBPSNUM
        If fstat : Raz [F:BPS] : Endif
    Endif
    
    # Fiche Article-Fournisseur
    If [F:ITP]ITMREF <> LITMREF | [F:ITP]BPSNUM <> LBPSNUM
        Read [ITP]ITP0=LITMREF;LBPSNUM
        If fstat : Raz [F:ITP] : Endif
    Endif
Endif

If LPSHFCY<>"" 
    # FQ 66830 GA 09/2010 ctrl des sources erreur [F:ITF]FCY
    # Fiche Article-Site
    If [F:ITF]ITMREF <> LITMREF | [F:ITF]STOFCY <> LPSHFCY
        Read [ITF]ITF0=LITMREF;LPSHFCY
        If fstat : Raz [F:ITF] : Endif
    Endif
Endif

# Fiche Tarif
If [F:PPL]PLI="" # en priorité la fonction des Achats
   Gosub INI_TARIF_PSM
Endif
If [F:PPL]PLI="" # si rien trouvé, on refait une recherche
   Gosub INI_TARIF_ITMBPS
Endif

Return
######################################################################
# FQ 65322 GA 06/2010 chargement du tarif PSM Demande d'achat automatique
$INI_TARIF_PSM 
#----- Variables locales selon RECH_TARIF de TRTACHTAR1 -----#
Local  Char     VAT(GLONVAT)(0..2), FOCITMREF(GLONITM), FOCUOM(GLONUOM)
Local  Decimal  WCLCAMT(1..7)
Local  Decimal  MONTANT(0..10), FOCQTY
Local  Decimal  GROPRI,         DISCRGVAL(0..8),  NETPRI,   COEFUNITE
Local  Date     PLISTRDAT,      PLIENDDAT
Local  Shortint MOTIF(0..10),   PRIORITE(0..10),  FOCMOTIF, SVGNOLIGN, I
Local  Char     PLI   (GLONPLI) (0..10)
Local  Char     PLICRD (30) (0..10)
Local  Integer  PLILIN    (0..10)
Local  Libelle  INTERDIT,       ERR,     LTIFLG
Local  Integer  STAT, PRIREN
Local  Integer  MODULE  : MODULE=6  : # Pour point d'entrée TARIFACH
Local  Integer  PLITYP  : PLITYP=1  : # Pour point d'entrée TARIFACH
#----- Paramètres complémentaires appel recherche tarifs -----# 
Local  Char     PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US    

Raz [F:PSD] : Raz [F:PSH]

[F:PSH]PRQDAT=date$
[F:PSH]PSHFCY=LPSHFCY

[F:PSD]=[F:BPS]
[F:PSD]=[F:ITM]
[F:PSD]BPSNUM=[F:BPS]BPSNUM
[F:PSD]CHGTYP=[F:BPS]CHGTYP

If [F:ITP]PURMINQTY>0 [F:PSD]QTYPUU=[F:ITP]PURMINQTY Else [F:PSD]QTYPUU=[F:ITG]MINQTY : Endif
If [F:ITP]PUU<>""     [F:PSD]PUU   =[F:ITP]PUU       Else [F:PSD]PUU=[F:ITM]PUU : Endif
#If [F:ITP]CUR<>""     [F:PSD]CUR   =[F:ITP]CUR       Else [F:PSD]CUR=[F:BPS]CUR : Endif

#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK ("PSM") From TRTPRICE
#-----
If [F:ITP]PUU<>"" [F:PPK]PUU=[F:ITP]PUU Else [F:PPK]PUU=[F:ITM]PUU : Endif
#----- Chargement des codes taxes -----#
Call RECHVATCOD(1,2,[F:PSD]BPSNUM,[F:PSD]ITMREF,"PSD",0,VAT) From TRTX3
#----- Recherche du tarif -----#
Call TARIFRECH(MODULE,1,"PSM",[F:PSH]PRQDAT,[F:PSD]QTYPUU,[F:PSD]PUU,
&              [F:PSD]CHGTYP,[F:PSD]CUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE

Return

######################################################################
# FQ 65322 GA 06/2010 chargement du tarif Article-Fournisseur
$INI_TARIF_ITMBPS
Local Char WCRIT(250)
Local Integer I

Raz [F:PPC]
Raz [F:PPL]
Filter [F:PPC] Where find("ITMREF",[F:PPC]FLD(0..4))
For [F:PPC]

    # Code Article déclaré dans la structure Tarif (Obligatoire)
    I=find("ITMREF",[F:PPC]FLD(0..4))
    If I    WCRIT="PLICRI"+num$(I)+"=[F:ITM]ITMREF" 
    Else Break Endif

    # Code Fournisseur déclaré dans la structure Tarif (facultatif)
    If LBPSNUM<>"" & [F:ITP]BPSNUM=LBPSNUM
       I=find("BPSNUM",[F:PPC]FLD(0..4))
       If I    WCRIT+="& PLICRI"+num$(I)+"=[F:ITP]BPSNUM" Endif
    Endif
    Filter [F:PPL] Where PLI=[F:PPC]PLI & evalue(WCRIT)
&                    & [F:PPL]PLISTRDAT<=date$
&                    & ([F:PPL]PLIENDDAT=[0/0/0] | [F:PPL]PLIENDDAT>=date$)
    For [F:PPL]
        Break
    Next
    Filter [F:PPL] 
    If [F:PPL]PLICRD<>"" Break Endif
Next
Filter [F:PPC]

Return


