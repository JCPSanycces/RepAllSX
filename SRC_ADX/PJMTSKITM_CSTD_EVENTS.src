#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PJMTSKITM
#######################################################################################
# EVENTS
#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  # Issue X3-101833 - 2018-07-30 by FGR : BEGIN
  If this.FRCDLTALLFLG = [V]CST_AYES and this.FRCDLTALLFLG <> this.snapshot.FRCDLTALLFLG Then
    #In this case ORDERS line is going to be deleted in OPPORPJM_CSTD_GATEWAY.$TAS_RITT_CLOSE_MANUF_PART
    Raz this.WIPNUM
  Endif
  # Issue X3-101833 - 2018-07-30 by FGR : END
Return

#######################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer PARPRIMET
Local Integer PARSECMET
Local Integer PARPURF
Local Integer IRET

  # ---------------------------
  Local File ITMMASTER [ITM]
  # ---------------------------
  Read [ITM]ITM0=this.ITMREF
  IRET = fmet this.SET_COSTMETS(this.STOFCY, [F:ITM]TCLCOD, this.ITMREF, PARPRIMET, PARSECMET, PARPURF)
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.ITMREF <> this.snapshot.ITMREF or this.STOFCY <> this.snapshot.STOFCY)) Then
    If PARPRIMET > 0 Then
      this.BUDVLTCOD = PARPRIMET
    Else
      this.BUDVLTCOD = 1
    Endif
    If PARSECMET > 0 Then
      this.BUDVLT2   = PARSECMET
    Else
      this.BUDVLT2   = 1
    Endif
    this.MANUALBUD = 0
  Endif
  # ----------------------------------
  If this.ITMDES1 = AVOID.ACHAR Then
    Call CHARGE_DEFITMDES("DES1AXX", this.ACTX.LAN, this.ITMREF, this.ITMDES1, "") From TRTX3_SYRA
  Endif
  # ----------------------------------
  If this.ALLQTY = 0 Then
    this.ALLSTA = 1
  Elsif this.ALLQTY > 0 and this.ALLQTY < this.WALLQTY Then
   this.ALLSTA = 2
  Elsif this.ALLQTY > 0 and this.ALLQTY = this.WALLQTY Then
   this.ALLSTA = 3
  Endif
  If this.DLVQTY = 0 Then
    this.DLVSTA = 1
  Elsif this.DLVQTY > 0 and this.TDLQTY > 0 Then
    this.DLVSTA = 2
  Elsif this.DLVQTY > 0 and this.TDLQTY = 0 Then
    this.DLVSTA = 3
  Endif
Return

#######################################################################################
$ACONTROL
Local Char SMESSAGE(250)
Local Integer IRET
Local Integer IRET2

  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  # ----------------------------------
  Local File ITMMASTER [ITM]
  Local File ITMFACILIT [ITF]
  # ----------------------------------
  Read [ITM]ITM0=this.ITMREF
  If [F:ITM]SALFLG = [V]CST_ANO and this.SALITM = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SALITM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  Read [ITF]ITF0=this.ITMREF;this.STOFCY
  If fstat Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMREF", func AFNC.MES2(mess(517,192,1), this.ITMREF, this.STOFCY), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_ANEW Then
    If this.ITMDLVFLG <> [F:ITM]DLVFLG Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMDLVFLG", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.ITMREF = this.snapshot.ITMREF and this.ITMDLVFLG <> this.snapshot.ITMDLVFLG Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMDLVFLG", mess(18,9804,1), [V]CST_AERROR))
    Elsif this.ITMREF <> this.snapshot.ITMREF and this.ITMDLVFLG <> [F:ITM]DLVFLG Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITMDLVFLG", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.UOM <> [F:ITM]STU Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("UOM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHPURFLG = [V]CST_ANO and this.MANUALBUD <> 0 Then
    [L]ASTATUS = fmet this.SETERROR("MANUALBUD", mess(18,9804,1), [V]CST_AERROR)
  Endif
  # ----------------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_ATRUE Then
    IRET = func STKSOR_SYRA.STKCTRECC(this.ACTX, this.ITMREF, this.ECCVALMAJ, this.ECCVALMIN, "", 4, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMIN", SMESSAGE, IRET))
    Endif
    IRET = func STKSOR_SYRA.CTLECCVAL(this.ACTX, this.ECCVALMAJ, this.STOFCY, this.ITMREF, 4, AVOID.ACHAR, [0/0/0], IRET2, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMAJ", SMESSAGE, IRET))
    Endif
  Endif
  # ----------------------------------
  If this.ALLQTY = 0 and this.ALLSTA <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLSTA", func AFNC.MES1(mess(997,2260,1), mess(this.ALLSTA,416,1)), [V]CST_AERROR))
  Elsif this.ALLQTY > 0 and this.ALLQTY < this.WALLQTY and this.ALLSTA <> 2 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLSTA", func AFNC.MES1(mess(997,2260,1), mess(this.ALLSTA,416,1)), [V]CST_AERROR))
  Elsif this.ALLQTY > 0 and this.ALLQTY = this.WALLQTY and this.ALLSTA <> 3 Then
   [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ALLSTA", func AFNC.MES1(mess(997,2260,1), mess(this.ALLSTA,416,1)), [V]CST_AERROR))
  Endif
  If this.DLVQTY = 0 and this.DLVSTA <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVSTA", func AFNC.MES1(mess(997,2260,1), mess(this.DLVSTA,417,1)), [V]CST_AERROR))
  Elsif this.DLVQTY > 0 and this.TDLQTY > 0 and this.DLVSTA <> 2 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVSTA", func AFNC.MES1(mess(997,2260,1), mess(this.DLVSTA,417,1)), [V]CST_AERROR))
  Elsif this.DLVQTY > 0 and this.TDLQTY = 0 and this.DLVSTA <> 3 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("DLVSTA", func AFNC.MES1(mess(997,2260,1), mess(this.DLVSTA,417,1)), [V]CST_AERROR))
  Endif
  If this.ITTQTY < this.DLVQTY + this.ALLQTY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ITTQTY", mess(998,2260,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

