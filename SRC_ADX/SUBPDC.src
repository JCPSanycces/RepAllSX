#---------------------------------------------------------------------------#
# Passage des montants de minoration en négatif et de majoration en positif #
#---------------------------------------------------------------------------#
Subprog SIGN_DISCRGVAL(I,VALEUR)
Value    Integer I
Variable Decimal VALEUR
Local    Shortint J
J=find(GINVDTALIN(I-1),[M:PIH1]INVDTA1(0..[M:PIH1]NBFAC1-1))
If J<>0
  If ([M:PIH0]PIHTYP<3 & [M:PIH1]DEBCDT1(J-1)=2) |
&    ([M:PIH0]PIHTYP>2 & [M:PIH1]DEBCDT1(J-1)=1)
     If VALEUR>0 VALEUR=-VALEUR : Endif
  Elsif VALEUR<0 VALEUR=-VALEUR
  Endif
Endif
End


##############################################
# Chargement du format des montants répartis #
##############################################
Funprog FMT(WABMSK,I)
Value Char    WABMSK
Value Integer I
Local Char FORMAT(15)
FORMAT="NZP:"+GDEVFMT1(max(find([M:PDC1]CUR,GDEVISE(1..GNBDEV)),1))
#----- Faire disparaitre les montants répartis non utilisés -----#
If evalue("[M:"+WABMSK+"]INVDTALIN2(I-1)")=0 & evalue("[M:PDC1]DISCRGAMT"+num$(I))=0
  FORMAT="-"+FORMAT
Endif
#-----
End FORMAT
