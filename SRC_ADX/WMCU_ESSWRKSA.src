#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## CRUD-CLASSE ## ESSWRKSA
# 2018-10-23 06:53:26 130


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(ESSWRKSA,ASTATUS)
Variable Instance ESSWRKSA Using C_ESSWRKSA
Variable Integer ASTATUS

If ESSWRKSA = null : End : Endif

Gosub _AVARIABLES From WMC00ESSWRKSA

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_ESSWRKSA

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(ESSWRKSA,ASTATUS)
Variable Instance ESSWRKSA Using C_ESSWRKSA
Variable Integer ASTATUS

If ESSWRKSA = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKSA
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
ESSWRKSA.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_ESSWRKSA
Else
 Gosub AUPDATE_ESSWRKSA
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = ESSWRKSA.freeSnapshot
ESSWRKSA.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKSA._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKSA._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKSA._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If ESSWRKSA.ASTALIN = [V]CST_ANEWDEL : Return : Endif
ESSWRKSA.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(ESSWRKSA.ASTALIN)<>""
 [L]A_ASTALIN = ESSWRKSA.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(ESSWRKSA.ASTALIN)<>""
 [L]A_ASTALIN = ESSWRKSA.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_ESSWRKSA
Trbegin [F:EWSA]
 Gosub AUPDATE_ESSWRKSA
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_ESSWRKSA
[L]A_ASTALIN = ESSWRKSA.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00ESSWRKSA._MAJSQL_ESSWRKSA(ESSWRKSA))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = ESSWRKSA.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If ESSWRKSA.snapshotEnabled=1
 [L]A_RETIK = ESSWRKSA.revertUpdTick
Endif

[L]ASTATUS = max(fmet ESSWRKSA.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(ESSWRKSA.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 ESSWRKSA.ASTALIN = [V]CST_ALL
Endif
Return



