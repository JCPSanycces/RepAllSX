#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## ATY-ATYPE ## CDE
# 2018-11-09 07:13:59 850

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,COD,CPY,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char COD
Value Char CPY
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File CACCEDEF [CDE]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".CACCEDEF" [CDE]
Endif

Default File [F:CDE]
Read [F:CDE]CDE0 = [L]COD;[L]CPY
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]COD)+"~"+num$([L]CPY)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]COD)+"~"+num$([L]CPY)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


