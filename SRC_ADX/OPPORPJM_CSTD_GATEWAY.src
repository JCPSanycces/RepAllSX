#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORPJM
#######################################################################################
$TAS_RITT_STKALL_CHGALL
#Variable Instance TECSOQITM Using C_TECSOQITM : #
#Local Integer ARET_VALUE

Local Instance MYGATE Using C_AGATEWAYETNA
Local Instance ORDERS Using C_ORDERS
Local Instance TECORDERS Using C_TECORDERS
Local Integer ITASLINE
Local Integer IITMLINE
Local Integer NI
Local Integer NE
Local Integer IIDX
Local Integer IFOUND
Local Integer IRET
Local Integer RETMETH
Local Char WERR(250)
Local Integer IIDXRET
Local Char RTASCOD(GLONTAC)
Local Integer RITTSEQ
Local Decimal RLQTA
Local Decimal RLSHT
Local Integer IXDTSK
Local Integer IDXRITT
Local Char RSOHNUM(GLONSOH)
Local Integer RSOPLIN
Local Integer RSOQSEQ
Local Decimal WQTY
Local Integer ILOG

  [L]ARET_VALUE = [V]CST_AOK
  # ----------------------------------
  Local File SORDER  [SOH]
  Local File SORDERQ [SOQ]
  Local File SORDERP [SOP]
  # ----------------------------------
  MYGATE = NewInstance C_AGATEWAYETNA AllocGroup null
  # -----------------------------------
  IRET = [V]CST_AOK
  If IRET = [V]CST_AOK Then
    ILOG = fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMLOGFIL")
    IRET = fmet MYGATE.ASETVALINTEGER("LOGFILE", ILOG)
  Endif
  # -----------------------------------
  IIDX = 0
  For NI = 1 To maxtab(TECSOQITM.SOQ)
    If TECSOQITM.SOQ(NI) <> null and find(TECSOQITM.SOQ(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ITASLINE = fmet this.TAS_GET_INDEX(TECSOQITM.SOQ(NI).TASCOD)
      IITMLINE = fmet this.TAS(ITASLINE).RITT_GET_INDEX_ITMREF(TECSOQITM.SOQ(NI).ITMREF)
      If this.TAS(ITASLINE).RITT(IITMLINE).ALLQTY > 0 Then
        IIDX += 1
        # -----------------------------------
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALCHAR("OPPNUM" + num$(IIDX), this.TAS(ITASLINE).OPPNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALCHAR("TASCOD" + num$(IIDX), this.TAS(ITASLINE).TASCOD)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALINTEGER("ITTSEQ" + num$(IIDX), this.TAS(ITASLINE).RITT(IITMLINE).ITTSEQ)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALCHAR("KEYCONCAT" + num$(IIDX), this.TAS(ITASLINE).KEYCONCAT)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALCHAR("TASNUM" + num$(IIDX), this.TAS(ITASLINE).TASNUM)
        Endif
        # -----------------------------------
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALDECIMAL("SOQQTY" + num$(IIDX), this.TAS(ITASLINE).RITT(IITMLINE).SOQQTY)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALDECIMAL("SOQQTYSNP" + num$(IIDX), this.TAS(ITASLINE).RITT(IITMLINE).snapshot.SOQQTY)
        Endif
        # -----------------------------------
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALCHAR("SOHNUM" + num$(IIDX), TECSOQITM.SOQ(NI).SOHNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALINTEGER("SOPLIN" + num$(IIDX), TECSOQITM.SOQ(NI).SOPLIN)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet MYGATE.ASETVALINTEGER("SOQSEQ" + num$(IIDX), TECSOQITM.SOQ(NI).SOQSEQ)
        Endif
      Endif
    Endif
  Next NI
  # -----------------------------------
  If IRET = [V]CST_AOK Then
    # Number of lines to read
    If IIDX > 0 Then
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ASETVALINTEGER("INDEX", IIDX)
      Endif
      # -----------------------------------
      If IRET = [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(989,2260,1), "1"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ARPC("OPPORPJM_CSTD_GATEWAY", "STKALL_CHGALL")
      Endif
      If IRET = [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(989,2260,1), "2"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      IRET = fmet MYGATE.AGETVALINTEGER("RETMETH", RETMETH)
      IRET = fmet MYGATE.AGETVALCHAR("WERR", WERR)
      If RETMETH = [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(989,2260,1), WERR), [V]CST_AERROR))
      Endif
      # -----------------------------------
      If RETMETH = [V]CST_AOK Then
        # Faire la boucle pour récupérer les valeurs de retour
        IRET = fmet MYGATE.AGETVALINTEGER("IIDXRET", IIDXRET)
        For NI = 1 To IIDXRET
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALCHAR("RTASCOD" + num$(NI), RTASCOD)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALINTEGER("RITTSEQ" + num$(NI), RITTSEQ)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALDECIMAL("LQTA" + num$(NI), RLQTA)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALDECIMAL("LSHT" + num$(NI), RLSHT)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALCHAR("RSOHNUM" + num$(NI), RSOHNUM)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALINTEGER("RSOPLIN" + num$(NI), RSOPLIN)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALINTEGER("RSOQSEQ" + num$(NI), RSOQSEQ)
          Endif
          # -----------------------------------
          If RLQTA > 0 Then
            IXDTSK = fmet this.TAS_GET_INDEX(RTASCOD)
            IDXRITT = fmet this.TAS(IXDTSK).RITT_GET_INDEX(RITTSEQ)
            this.TAS(IXDTSK).RITT(IDXRITT).TCHACTALLOC = "ALLOC"
            this.TAS(IXDTSK).RITT(IDXRITT).ALLQTY -= RLQTA
            # Update the allocated quantity on the order line (SOQ)
            Read [SOQ]SOQ0=RSOHNUM;RSOPLIN;RSOQSEQ
            Read [SOP]SOP0=RSOHNUM;RSOPLIN;RSOQSEQ
            [F:SOQ]ALLQTYSTU += RLQTA
            WQTY = RLQTA * (1 / [F:SOP]SAUSTUCOE)
            Call QTEARR_CC(this.ACTX, WQTY, [F:SOP]SAU) From TRTDIV_SYRA
            [F:SOQ]ALLQTY += WQTY
            #
            [F:SOQ]SHTQTYSTU += RLSHT
            WQTY = RLSHT * (1 / [F:SOP]SAUSTUCOE)
            Call QTEARR_CC(this.ACTX, WQTY, [F:SOP]SAU) From TRTDIV_SYRA
            [F:SOQ]SHTQTY += WQTY
            #
            [F:SOQ]ALLTYP = 2          # Force to "detailled"
            #
            Rewrite [SOQ]
            If [F:SOQ]DEMNUM <> AVOID.ACHAR Then
              ORDERS = NewInstance C_ORDERS AllocGroup null
              TECORDERS = NewInstance C_TECORDERS AllocGroup null
              #
              TECORDERS.ALLQTY = [F:SOQ]ALLQTYSTU
              IRET = fmet ORDERS.ORDERS_FROM_PJM_SOQ(1, [F:SOQ]DEMNUM, [F:SOQ]ITMREF, TECORDERS)
              If IRET >= [V]CST_AWARNING Then
                Call MSGSTACK_COPY_TO_INST(ORDERS, this.TAS(IXDTSK).RITT(IDXRITT)) From SYRSTACKTOOLS
              Endif
              #
              FreeInstance TECORDERS
              FreeInstance ORDERS
            Endif
          Endif
        Next NI
        If RSOHNUM <> AVOID.ACHAR Then
          RETMETH = func TRTVENCDE_SYR.MAJSTASOH(this.ACTX, RSOHNUM, WERR)
          If RETMETH > [V]CST_AOK Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", WERR, RETMETH))
          Endif
        Endif
      Endif
    Endif
  Endif
  FreeInstance MYGATE
Return

#######################################################################################
$TAS_RITT_CLOSE_MANUF_PART
#Local Integer ARET_VALUE

Local Integer NE
Local Integer NI
Local Integer IRET
Local Integer IIDX
Local Integer ICRELOGFILE
Local Instance MYGATE Using C_AGATEWAYETNA
Local Integer RETMETH
Local Char WERR(250)
Local Decimal NBIDON
Local Integer IBIDON

  # Issue X3-101833 - 2018-07-30 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ----------------------------------
  Raz MYGATE
  IIDX = 0
  For NE = 1 To maxtab(this.TAS)
    If this.TAS(NE) <> null and find(this.TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NI = 1 To maxtab(this.TAS(NE).RITT)
        If this.TAS(NE).RITT(NI) <> null and find(this.TAS(NE).RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NE).RITT(NI).snapshot.WIPNUM <> AVOID.ACHAR Then
            # Note : we have to use snapshot because field has been erased in PJMTSKITM_CSTD_EVENTS.$AUPDATE_CONTROL_BEFORE
            If this.TAS(NE).RITT(NI).FRCDLTALLFLG <> this.TAS(NE).RITT(NI).snapshot.FRCDLTALLFLG and
&              this.TAS(NE).RITT(NI).FRCDLTALLFLG = [V]CST_AYES
&           Then
              # ----------------------------------
              # Initialize gateway class if necessary
              If MYGATE = null Then
                MYGATE = NewInstance C_AGATEWAYETNA AllocGroup null
                #
                ICRELOGFILE = fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMLOGFIL")
                IRET = fmet MYGATE.ASETVALINTEGER("LOGFILE", ICRELOGFILE)
              Endif
              # ----------------------------------
              # Data to gateway
              IIDX += 1
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("OPPNUM" + num$(IIDX), this.TAS(NE).OPPNUM)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("TASCOD" + num$(IIDX), this.TAS(NE).TASCOD)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("KEYCONCAT" + num$(IIDX), this.TAS(NE).KEYCONCAT)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("TASNUM" + num$(IIDX), this.TAS(NE).TASNUM)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("STOFCY" + num$(IIDX), this.TAS(NE).RITT(NI).STOFCY)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALINTEGER("ITTSEQ" + num$(IIDX), this.TAS(NE).RITT(NI).ITTSEQ)
              Endif
              If IRET = [V]CST_AOK Then
                IBIDON = this.TAS(NE).RITT(NI).snapshot.FRCDLTALLFLG
                IRET = fmet MYGATE.ASETVALINTEGER("FRCDLTALLFLG" + num$(IIDX), IBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                # Note : we have to use snapshot because field has been erased in PJMTSKITM_CSTD_EVENTS.$AUPDATE_CONTROL_BEFORE
                IRET = fmet MYGATE.ASETVALCHAR("WIPNUM" + num$(IIDX), this.TAS(NE).RITT(NI).snapshot.WIPNUM)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALCHAR("ITMREF" + num$(IIDX), this.TAS(NE).RITT(NI).ITMREF)
              Endif
              # ----------------------------------
              # To not deallocate stocks
              If IRET = [V]CST_AOK Then
                IBIDON = [V]CST_ANO
                IRET = fmet MYGATE.ASETVALINTEGER("STOCKALL" + num$(IIDX), IBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                WBIDON = 0
                IRET = fmet MYGATE.ASETVALDECIMAL("ALLQTY" + num$(IIDX), WBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                WBIDON = 0
                IRET = fmet MYGATE.ASETVALDECIMAL("SHTQTY" + num$(IIDX), WBIDON)
              Endif
            Endif
          Endif
        Endif
      Next NI
    Endif
  Next NE
  # ----------------------------------
  # Data to gateway
  If MYGATE <> null and IRET = [V]CST_AOK Then
    # Number of lines to read
    If IIDX > 0 Then
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ASETVALINTEGER("INDEX", IIDX)
      Endif
      # -----------------------------------
      If IRET = [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), "1"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ARPC("OPPORPJM_CSTD_GATEWAY", "CLOSE_MANUF_PART")
      Endif
      If IRET > [V]CST_AWARNING Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), "2"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      IRET = fmet MYGATE.AGETVALINTEGER("RETMETH", RETMETH)
      IRET = fmet MYGATE.AGETVALCHAR("WERR", WERR)
      If RETMETH <> [V]CST_AOK Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), WERR), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

#######################################################################################
$TAS_RITT_CLOSE_RELEASE_UNDER
#Value Char STASCOD ()
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

Local Char STBPBUCOD(GLONPBU)(1..)
Local Char STBTASCOD(GLONTAC)(1..)
Local Char STBTASCOD1(GLONTAC)(1..)

Local Integer NE
Local Integer NI
Local Integer NZ
Local Integer IRET
Local Integer IIDX
Local Integer ICRELOGFILE
Local Instance MYGATE Using C_AGATEWAYETNA
Local Integer RETMETH
Local Char WERR(250)
Local Integer IIDXRET
Local Char RTASCOD(GLONTAC)
Local Integer RITTSEQ
Local Char RITMREF(GLONITM)
Local Char RWIPNUM(GLONVCR)
Local Decimal RNALLQTY
Local Decimal RNSHTQTY
Local Integer RISTOCKALL
Local Instance ZTECALLITM Using C_TECALLITM
Local Integer ILINTAS
Local Integer ILINITM
Local Decimal NBIDON
Local Integer IBIDON
Local Char SVTCHACTION(type(this.TCHACTION)-10)

  # Issue X3-101833 - 2018-07-30 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ----------------------------------
  If STASCOD <> AVOID.ACHAR Then
    # Check for a task family
    IRET = fmet this.TAS_GET_FAMILY(STASCOD, STBTASCOD)
  Elsif SPBUCOD <> AVOID.ACHAR Then
    # Check for tasks linked to a budget family
    IRET = fmet this.BUD_GET_FAMILY(SPBUCOD, STBPBUCOD)
    NE = 0
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If find(this.TAS(NI).PBUCOD, STBPBUCOD(1..maxtab(STBPBUCOD))) <> 0 Then
          Raz STBTASCOD1
          IRET = fmet this.TAS_GET_FAMILY(this.TAS(NI).TASCOD, STBTASCOD1)
          For NZ = 1 To maxtab(STBTASCOD1)
            If STBTASCOD1(NZ) <> AVOID.ACHAR Then
              If find (STBTASCOD1(NZ), STBTASCOD(1..maxtab(STBTASCOD))) = 0 Then
                NE += 1
                STBTASCOD(NE) = STBTASCOD1(NZ)
              Endif
            Else
              Break
            Endif
          Next NZ
        Endif
      Endif
    Next NI
  Else
    # check all tasks
    NE = 0
    For NI = 1 To maxtab(this.TAS)
      If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        NE += 1
        STBTASCOD(NE) = this.TAS(NI).TASCOD
      Endif
    Next NI
  Endif
  # ----------------------------------
  Raz MYGATE
  IIDX = 0
  For NZ = 1 To maxtab(STBTASCOD)
    NE = fmet this.TAS_GET_INDEX(STBTASCOD(NZ))
    If this.TAS(NE) <> null and find(this.TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NI = 1 To maxtab(this.TAS(NE).RITT)
        If this.TAS(NE).RITT(NI) <> null and find(this.TAS(NE).RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NE).RITT(NI).WIPNUM <> AVOID.ACHAR Then
            Raz this.TAS(NE).RITT(NI).WIPNUM
          Endif
          # ----------------------------------
          If this.TAS(NE).RITT(NI).FRCDLTALLFLG = [V]CST_ANO  or
&            this.TAS(NE).RITT(NI).ALLQTY > 0 or this.TAS(NE).RITT(NI).SHTQTY > 0
&         Then
            # Initialize gateway class
            If MYGATE = null Then
              MYGATE = NewInstance C_AGATEWAYETNA AllocGroup null
              #
              ICRELOGFILE = fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMLOGFIL")
              IRET = fmet MYGATE.ASETVALINTEGER("LOGFILE", ICRELOGFILE)
            Endif
            # ----------------------------------
            # Data to gateway
            IIDX += 1
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("OPPNUM" + num$(IIDX), this.TAS(NE).OPPNUM)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("TASCOD" + num$(IIDX), this.TAS(NE).TASCOD)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("KEYCONCAT" + num$(IIDX), this.TAS(NE).KEYCONCAT)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("TASNUM" + num$(IIDX), this.TAS(NE).TASNUM)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("STOFCY" + num$(IIDX), this.TAS(NE).RITT(NI).STOFCY)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALINTEGER("ITTSEQ" + num$(IIDX), this.TAS(NE).RITT(NI).ITTSEQ)
            Endif
            If IRET = [V]CST_AOK Then
              IBIDON = this.TAS(NE).RITT(NI).FRCDLTALLFLG
              IRET = fmet MYGATE.ASETVALINTEGER("FRCDLTALLFLG" + num$(IIDX), IBIDON)
            Endif
            If IRET = [V]CST_AOK Then
              # Note : we have to use snapshot because field has been erased in PJMTSKITM_CSTD_EVENTS.$AUPDATE_CONTROL_BEFORE
              IRET = fmet MYGATE.ASETVALCHAR("WIPNUM" + num$(IIDX), this.TAS(NE).RITT(NI).snapshot.WIPNUM)
            Endif
            If IRET = [V]CST_AOK Then
              IRET = fmet MYGATE.ASETVALCHAR("ITMREF" + num$(IIDX), this.TAS(NE).RITT(NI).ITMREF)
            Endif
            # ----------------------------------
            # To deallocate stocks
            If this.TAS(NE).RITT(NI).ALLQTY > 0 or this.TAS(NE).RITT(NI).SHTQTY > 0 Then
              If IRET = [V]CST_AOK Then
                IBIDON = [V]CST_AYES
                IRET = fmet MYGATE.ASETVALINTEGER("STOCKALL" + num$(IIDX), IBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALDECIMAL("ALLQTY" + num$(IIDX), this.TAS(NE).RITT(NI).ALLQTY)
              Endif
              If IRET = [V]CST_AOK Then
                IRET = fmet MYGATE.ASETVALDECIMAL("SHTQTY" + num$(IIDX), this.TAS(NE).RITT(NI).SHTQTY)
              Endif
            Else
              If IRET = [V]CST_AOK Then
                IBIDON = [V]CST_ANO
                IRET = fmet MYGATE.ASETVALINTEGER("STOCKALL" + num$(IIDX), IBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                NBIDON = 0
                IRET = fmet MYGATE.ASETVALDECIMAL("ALLQTY" + num$(IIDX), NBIDON)
              Endif
              If IRET = [V]CST_AOK Then
                NBIDON = 0
                IRET = fmet MYGATE.ASETVALDECIMAL("SHTQTY" + num$(IIDX), NBIDON)
              Endif
            Endif
            # ----------------------------------
          Endif
        Endif
      Next NI
    Endif
  Next NZ
  # ----------------------------------
  # Data to gateway
  If MYGATE <> null and IRET = [V]CST_AOK Then
    # Number of lines to read
    If IIDX > 0 Then
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ASETVALINTEGER("INDEX", IIDX)
      Endif
      # -----------------------------------
      If IRET = [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), "1"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        IRET = fmet MYGATE.ARPC("OPPORPJM_CSTD_GATEWAY", "CLOSE_MANUF_PART")
      Endif
      If IRET > [V]CST_AWARNING Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), "2"), [V]CST_AERROR))
      Endif
      # -----------------------------------
      IRET = fmet MYGATE.AGETVALINTEGER("RETMETH", RETMETH)
      IRET = fmet MYGATE.AGETVALCHAR("WERR", WERR)
      # -----------------------------------
      If RETMETH = [V]CST_AOK Then
        ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
        IRET = fmet MYGATE.AGETVALINTEGER("IIDXRET", IIDXRET)
        For NI = 1 To IIDXRET
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALCHAR("RTASCOD" + num$(NI), RTASCOD)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALINTEGER("RITTSEQ" + num$(NI), RITTSEQ)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALCHAR("RITMREF" + num$(NI), RITMREF)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALCHAR("RWIPNUM" + num$(NI), RWIPNUM)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALINTEGER("RISTOCKALL" + num$(NI), RISTOCKALL)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALDECIMAL("RNALLQTY" + num$(NI), RNALLQTY)
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet MYGATE.AGETVALDECIMAL("RNSHTQTY" + num$(NI), RNSHTQTY)
          Endif
          # -----------------------------------
          If RISTOCKALL = [V]CST_AYES Then
            ILINTAS = fmet this.TAS_GET_INDEX(RTASCOD)
            ILINITM = fmet this.TAS(ILINTAS).RITT_GET_INDEX(RITTSEQ)
            RNALLQTY = this.TAS(ILINTAS).RITT(ILINITM).ALLQTY - RNALLQTY
            RNSHTQTY = this.TAS(ILINTAS).RITT(ILINITM).SHTQTY - RNSHTQTY
            IRET = fmet ZTECALLITM.MANUAL_ADD_LINE(this.TAS(ILINTAS).KEYCONCAT,
&                                                  this.TAS(ILINTAS).RITT(ILINITM).ITMREF,
&                                                  this.TAS(ILINTAS).RITT(ILINITM).UOM,
&                                                  RNALLQTY,
&                                                  RNSHTQTY
&                                                  )
          Endif
        Next NI
        # -----------------------------------
        SVTCHACTION = this.TCHACTION
        this.TCHACTION = "ALLOC"
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._TASK_RITT_ALLOCATION(ZTECALLITM))
        this.TCHACTION = SVTCHACTION
        # -----------------------------------
        FreeGroup ZTECALLITM
      Else
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(1116,2260,1), WERR), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

#######################################################################################
#######################################################################################
$GATEWAYS
  Case AGATEWAY
    When "STKALL_CHGALL"               : Gosub STKALL_CHGALL
    When "CLOSE_MANUF_PART"            : Gosub CLOSE_MANUF_PART        # Issue X3-101833 - 2018-07-30 by FGR
  Endcase
Return

#######################################################################################
#######################################################################################
$STKALL_CHGALL
Local Integer NI
Local Integer IIDX
Local Integer IRET
Local Integer ILOGFILE
Local Instance LOGFILE Using C_ALOG
Local Integer IRETLOG
Local Char SOPPNUM(GLONOPP)
Local Char STASCOD(GLONTAC)
Local Integer IITTSEQ
Local Char SKEYCONCAT(GLONPIM)
Local Char STASNUM(GLONVCR)
Local Decimal NSOQQTY
Local Decimal NSOQQTYSNP
Local Char SSOHNUM(GLONSOH)
Local Integer ISOPLIN
Local Integer ISOQSEQ
Local Integer STAT
Local Decimal WREAQTYSTU
Local Decimal WQTATRTSTU
Local Decimal WSHTTRTSTU
Local Integer IIDXRET
Local Char RTASCOD(GLONTAC)(1..)
Local Integer RITTSEQ(1..)
Local Decimal RLQTA(1..)
Local Decimal RLSHT(1..)
Local Char RSOHNUM(GLONSOH)(1..)
Local Integer RSOPLIN(1..)
Local Integer RSOQSEQ(1..)

  IRET = [V]CST_AOK
  If IRET = [V]CST_AOK Then
    IRET = fmet this.AGETVALINTEGER("LOGFILE", ILOGFILE)
  Endif
  # -----------------------------------
  If IRET = [V]CST_AOK Then
    If ILOGFILE = [V]CST_AYES Then
      LOGFILE = NewInstance C_ALOG AllocGroup null
      IRETLOG = fmet LOGFILE.ABEGINLOG(mess(990,2260,1))
    Endif
  Endif
  # -----------------------------------
  If IRET = [V]CST_AOK Then
    IRET = fmet this.AGETVALINTEGER("INDEX", IIDX)
  Endif
  If IRET = [V]CST_AOK Then
    IIDXRET = 0
    If IIDX > 0 Then
      Local File STOALL    [STA]
      Local File ITMMASTER [ITM]
      Trbegin [STA]
      # -----------------------------------
      For NI = 1 To IIDX
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("OPPNUM" + num$(NI), SOPPNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("TASCOD" + num$(NI), STASCOD)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("ITTSEQ" + num$(NI), IITTSEQ)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("KEYCONCAT" + num$(NI), SKEYCONCAT)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("TASNUM" + num$(NI), STASNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALDECIMAL("SOQQTY" + num$(NI), NSOQQTY)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALDECIMAL("SOQQTYSNP" + num$(NI), NSOQQTYSNP)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("SOHNUM" + num$(NI), SSOHNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("SOPLIN" + num$(NI), ISOPLIN)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("SOQSEQ" + num$(NI), ISOQSEQ)
        Endif
        # -----------------------------------
        If ILOGFILE = [V]CST_AYES Then
          IRETLOG = fmet LOGFILE.APUTLINE(string$(30, "-"), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SOPPNUM=" + SOPPNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("STASCOD=" + STASCOD, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("ITTSEQ=" + num$(IITTSEQ), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SKEYCONCAT=" + SKEYCONCAT, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("STASNUM=" + STASNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("NSOQQTY=" + num$(NSOQQTY), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("NSOQQTY=" + num$(NSOQQTYSNP), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SSOHNUM=" + SSOHNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("ISOPLIN=" + num$(ISOPLIN), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("ISOQSEQ=" + num$(ISOQSEQ), [V]CST_AINFO)
        Endif
        # -----------------------------------
        WREAQTYSTU = NSOQQTY - NSOQQTYSNP        # Current SOQQTY - Previous stored SOQQTY
        If ILOGFILE = [V]CST_AYES Then
          IRETLOG = fmet LOGFILE.APUTLINE("WREAQTYSTU=" + num$(WREAQTYSTU), [V]CST_AINFO)
        Endif
        # -----------------------------------
        If WREAQTYSTU > 0 Then
          # If there is something to transfert
          Call CHGALL(40, STASNUM, IITTSEQ, 0,
&                     2, SSOHNUM, ISOPLIN, ISOQSEQ,
&                     0,
&                     WREAQTYSTU,
&                     WQTATRTSTU, WSHTTRTSTU, STAT)
&         From STKALL
        Else
          WQTATRTSTU = 0
          WSHTTRTSTU = 0
          STAT = 0
        Endif
        # -----------------------------------
        If STAT <> 0 Then
          IRET = [V]CST_AERROR
          IIDXRET = 0
          If ILOGFILE = [V]CST_AYES Then
            IRETLOG = fmet LOGFILE.APUTLINE("", [V]CST_AINFO)
            IRETLOG = fmet LOGFILE.APUTLINE("STAT=" + num$(STAT), [V]CST_AERROR)
            IRETLOG = fmet LOGFILE.APUTLINE("GMESSAGE=" + GMESSAGE, [V]CST_AERROR)
            IRETLOG = fmet LOGFILE.APUTLINE("GLOCK=" + GLOCK, [V]CST_AERROR)
            IRETLOG = fmet LOGFILE.APUTLINE(string$(30, "-"), [V]CST_AINFO)
          Endif
          Break
        Endif
        If ILOGFILE = [V]CST_AYES Then
          IRETLOG = fmet LOGFILE.APUTLINE("WQTATRTSTU=" + num$(WQTATRTSTU), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("WSHTTRTSTU=" + num$(WSHTTRTSTU), [V]CST_AINFO)
        Endif
        # -----------------------------------
        IIDXRET += 1
        RTASCOD(IIDXRET) = STASCOD
        RITTSEQ(IIDXRET) = IITTSEQ
        RLQTA(IIDXRET) = WQTATRTSTU
        RLSHT(IIDXRET) = WSHTTRTSTU
        RSOHNUM(IIDXRET) = SSOHNUM
        RSOPLIN(IIDXRET) = ISOPLIN
        RSOQSEQ(IIDXRET) = ISOQSEQ
        # -----------------------------------
        If IRET = [V]CST_AERROR Then
          IIDXRET = 0
          Break
        Endif
      Next NI
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        For NI = 1 To IIDXRET
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALCHAR("RTASCOD" + num$(NI), RTASCOD(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALINTEGER("RITTSEQ" + num$(NI), RITTSEQ(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALDECIMAL("LQTA" + num$(NI), RLQTA(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALDECIMAL("LSHT" + num$(NI), RLSHT(NI))
          Endif

          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALCHAR("RSOHNUM" + num$(NI), RSOHNUM(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALINTEGER("RSOPLIN" + num$(NI), RSOPLIN(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALINTEGER("RSOQSEQ" + num$(NI), RSOQSEQ(NI))
          Endif
        Next NI
        IRETLOG = fmet this.ASETVALINTEGER("IIDXRET", IIDXRET)
      Else
        IRETLOG = fmet this.ASETVALINTEGER("IIDXRET", 0)
      Endif
      # -----------------------------------
      IRETLOG = fmet this.ASETVALCHAR("WERR", GMESSAGE)
      IRETLOG = fmet this.ASETVALINTEGER("RETMETH", STAT)
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Endif
  # -----------------------------------
  If LOGFILE <> null Then
    IRETLOG = fmet LOGFILE.AFLUSHLOG()
    IRETLOG = fmet LOGFILE.AENDLOG()
    FreeGroup LOGFILE
  Endif
Return

#######################################################################################
$CLOSE_MANUF_PART
Global Instance LOGFILE Using C_ALOG

Local Instance ORDERS Using C_ORDERS
Local Instance WIP_PARAM Using C_ORDK

Local Integer IRET
Local Integer LRET
Local Integer IIDX
Local Integer IIDXRET
Local Integer NI
Local Integer ILOGFILE
Local Integer IRETLOG
Local Char SRETMSG(250)

Local Char SOPPNUM(GLONOPP)
Local Char STASCOD(GLONTAC)
Local Integer IITTSEQ
Local Char SKEYCONCAT(GLONPIM)
Local Char STASNUM(GLONVCR)
Local Char SSTOFCY(GLONFCY)
Local Integer IFRCDLTALLFLG
Local Char SWIPNUM(GLONVCR)
Local Char SITMREF(GLONITM)
Local Integer ISTOCKALL
Local Decimal NALLQTY
Local Decimal NSHTQTY

Local Char RTASCOD(GLONTAC)(1..)
Local Integer RITTSEQ(1..)
Local Char RITMREF(GLONITM)(1..)
Local Char RWIPNUM(GLONVCR)(1..)
Local Integer RISTOCKALL(1..)
Local Decimal RNALLQTY(1..)
Local Decimal RNSHTQTY(1..)
Local Char STEMP(GLONVCR)
Local Integer IMESSAGE

  # Issue X3-101833 - 2018-07-30 by FGR
  IRET = [V]CST_AOK
  If IRET = [V]CST_AOK Then
    IRET = fmet this.AGETVALINTEGER("LOGFILE", ILOGFILE)
  Endif
  # -----------------------------------
  If IRET = [V]CST_AOK Then
    If ILOGFILE = [V]CST_AYES Then
      LOGFILE = NewInstance C_ALOG AllocGroup null
      IRETLOG = fmet LOGFILE.ABEGINLOG(mess(990,2260,1))
    Endif
  Endif
  # -----------------------------------
  If IRET = [V]CST_AOK Then
    IRET = fmet this.AGETVALINTEGER("INDEX", IIDX)
  Endif
  If IRET = [V]CST_AOK Then
    If IIDX > 0 Then
      Local File MTOLINK [LMLK]
      Local File MTOLINK [MLK]
      Local File MTOLINK [MLK1]
      Local File ITMMASTER [ITM]       # need for Call DELALL(40, STASNUM, IITTSEQ, 0, SITMREF, 0, NALLQTY, NSHTQTY, LRET) From STKALL
      #
      Local Mask MLIK [MLIK]
      # -----------------------------------
      Trbegin [MLK]
      # -----------------------------------
      Raz RTASCOD
      Raz RITTSEQ
      Raz RITMREF
      IIDXRET = 0
      For NI = 1 To IIDX
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("OPPNUM" + num$(NI), SOPPNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("TASCOD" + num$(NI), STASCOD)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("ITTSEQ" + num$(NI), IITTSEQ)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("KEYCONCAT" + num$(NI), SKEYCONCAT)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("TASNUM" + num$(NI), STASNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("STOFCY" + num$(NI), SSTOFCY)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("FRCDLTALLFLG" + num$(NI), IFRCDLTALLFLG)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("WIPNUM" + num$(NI), SWIPNUM)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALCHAR("ITMREF" + num$(NI), SITMREF)
        Endif
        # To manage stocks deallocation
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALINTEGER("STOCKALL" + num$(NI), ISTOCKALL)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALDECIMAL("ALLQTY" + num$(NI), NALLQTY)
        Endif
        If IRET = [V]CST_AOK Then
          IRET = fmet this.AGETVALDECIMAL("SHTQTY" + num$(NI), NSHTQTY)
        Endif
        # -----------------------------------
        If ILOGFILE = [V]CST_AYES Then
          IRETLOG = fmet LOGFILE.APUTLINE(string$(30, "-"), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SOPPNUM=" + SOPPNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("STASCOD=" + STASCOD, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("ITTSEQ=" + num$(IITTSEQ), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SKEYCONCAT=" + SKEYCONCAT, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("STASNUM=" + STASNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("STOFCY=" + SSTOFCY, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("IFRCDLTALLFLG=" + mess(IFRCDLTALLFLG,1,1), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SWIPNUM=" + SWIPNUM, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("SITMREF=" + SITMREF, [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("ISTOCKALL=" + mess(ISTOCKALL,1,1), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("NALLQTY=" + num$(NALLQTY), [V]CST_AINFO)
          IRETLOG = fmet LOGFILE.APUTLINE("NSHTQTY=" + num$(NSHTQTY), [V]CST_AINFO)
        Endif
        # -----------------------------------
        # MTOLINK
        If IRET = [V]CST_AOK Then
          If IFRCDLTALLFLG = [V]CST_ANO Then
            Filter [LMLK] Where [F:LMLK]STOFCY = SSTOFCY
&                           and [F:LMLK]ITMREF = SITMREF
&                           and [F:LMLK]DEMTYP = 40 and [F:LMLK]DEMNUM = STASNUM and [F:LMLK]DEMLIN = IITTSEQ and [F:LMLK]DEMSEQ = 0
            For [LMLK]
              If ILOGFILE = [V]CST_AYES Then
                IRETLOG = fmet LOGFILE.APUTLINE(" ", [V]CST_AINFO)
                IRETLOG = fmet LOGFILE.APUTLINE("[F:LMLK]RESSTYP=" + num$([F:LMLK]RESSTYP), [V]CST_AINFO)
                IRETLOG = fmet LOGFILE.APUTLINE("[F:LMLK]RESSNUM=" + [F:LMLK]RESSNUM, [V]CST_AINFO)
                IRETLOG = fmet LOGFILE.APUTLINE("[F:LMLK]RESSLIN=" + num$([F:LMLK]RESSLIN), [V]CST_AINFO)
                IRETLOG = fmet LOGFILE.APUTLINE("[F:LMLK]RESSSEQ=" + num$([F:LMLK]RESSSEQ), [V]CST_AINFO)
              Endif
              # Sample in FUNMDESMTO script
              Raz [M:MLIK]
              [M:MLIK]MAJCOD    = "Z"
              [M:MLIK]STOFCY    = [F:LMLK]STOFCY
              [M:MLIK]DEMTYP    = [F:LMLK]DEMTYP
              [M:MLIK]DEMNUM    = [F:LMLK]DEMNUM
              [M:MLIK]DEMLIN    = [F:LMLK]DEMLIN
              [M:MLIK]DEMSEQ    = [F:LMLK]DEMSEQ
              [M:MLIK]DWIPTYP   = 14
              [M:MLIK]RESSTYP   = [F:LMLK]RESSTYP
              [M:MLIK]RESSNUM   = [F:LMLK]RESSNUM
              [M:MLIK]RESSLIN   = [F:LMLK]RESSLIN
              [M:MLIK]RESSSEQ   = [F:LMLK]RESSSEQ
              [M:MLIK]RWIPTYP   = 14
              [M:MLIK]ITMREF    = [F:LMLK]ITMREF
              [M:MLIK]TRTNAM    = "OPPORPJM_CSTD_GATEWAY"
              [M:MLIK]FRCPRO    = [V]CST_ANO           # To confirm
              [M:MLIK]FEEDBACK  = ILOGFILE
              # -----------------------------------
              Call UPDMTOLINK() From MTOLINKLIB
              If GOK < 0 Then
                IRET = [V]CST_AERROR
                SRETMSG = func AFNC.MES3(mess(1117,2260,1), SITMREF, num$(IITTSEQ), STASCOD)
                If GMESSAGE <> AVOID.ACHAR Then
                  SRETMSG -= "(" + GMESSAGE + ")"
                Endif
                If ILOGFILE = [V]CST_AYES Then
                  IRETLOG = fmet LOGFILE.APUTLINE("", [V]CST_AINFO)
                  IRETLOG = fmet LOGFILE.APUTLINE("GOK=" + num$(GOK), [V]CST_AERROR)
                  IRETLOG = fmet LOGFILE.APUTLINE("SRETMSG=" + SRETMSG, [V]CST_AERROR)
                  IRETLOG = fmet LOGFILE.APUTLINE("GLOCK=" + GLOCK, [V]CST_AERROR)
                  IRETLOG = fmet LOGFILE.APUTLINE(string$(30, "-"), [V]CST_AINFO)
                Endif
                Break
              Endif
            Next
            Filter [LMLK]
          Endif
        Endif
        # -----------------------------------
        # ORDERS
        If IRET = [V]CST_AOK Then
          If IFRCDLTALLFLG = [V]CST_ANO Then
            If ORDERS = null Then
              ORDERS = NewInstance C_ORDERS AllocGroup null
            Endif
            If WIP_PARAM = null Then
              WIP_PARAM = NewInstance C_ORDK AllocGroup null
              #
              WIP_PARAM.MAJCOD = "A"
            Endif
            LRET = fmet ORDERS.WIP(14, SWIPNUM, SITMREF, WIP_PARAM, STEMP)
            If LRET > [V]CST_AWARNING Then
              IRET = [V]CST_AERROR
              IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ORDERS, SRETMSG)
              If ILOGFILE = [V]CST_AYES Then
                Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(ORDERS, LOGFILE) From SYRSTACKTOOLS
              Endif
              Break
            Endif
            FreeGroup ORDERS
            Raz ORDERS
          Endif
        Endif
        # -----------------------------------
        # STKALL
        If IRET = [V]CST_AOK Then
          If ISTOCKALL = [V]CST_AYES Then
            Call DELALL(40, STASNUM, IITTSEQ, 0, SITMREF, 0, NALLQTY, NSHTQTY, LRET) From STKALL
            If LRET <> 0 Then
              GOK = -1
              IRET = [V]CST_AERROR
              SRETMSG = func AFNC.MES3(mess(1122,2260,1), SITMREF, num$(IITTSEQ), STASCOD)
              If GMESSAGE <> AVOID.ACHAR Then
                SRETMSG -= "(" + GMESSAGE + ")"
              Endif
              If ILOGFILE = [V]CST_AYES Then
                IRETLOG = fmet LOGFILE.APUTLINE("", [V]CST_AINFO)
                IRETLOG = fmet LOGFILE.APUTLINE("LRET=" + num$(LRET), [V]CST_AERROR)
                IRETLOG = fmet LOGFILE.APUTLINE("SRETMSG=" + SRETMSG, [V]CST_AERROR)
                IRETLOG = fmet LOGFILE.APUTLINE("GLOCK=" + GLOCK, [V]CST_AERROR)
                IRETLOG = fmet LOGFILE.APUTLINE(string$(30, "-"), [V]CST_AINFO)
              Endif
              Break
            Endif
          Endif
        Endif
        # -----------------------------------
        If IRET = [V]CST_AOK Then
          IIDXRET += 1
          RTASCOD(IIDXRET) = STASCOD
          RITTSEQ(IIDXRET) = IITTSEQ
          RITMREF(IIDXRET) = SITMREF
          RWIPNUM(IIDXRET) = SWIPNUM
          RISTOCKALL(IIDXRET) = ISTOCKALL
          RNALLQTY(IIDXRET) = NALLQTY
          RNSHTQTY(IIDXRET) = NSHTQTY
        Endif
      Next NI
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        For NI = 1 To IIDXRET
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALCHAR("RTASCOD" + num$(NI), RTASCOD(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALINTEGER("RITTSEQ" + num$(NI), RITTSEQ(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALCHAR("RITMREF" + num$(NI), RITMREF(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALCHAR("RWIPNUM" + num$(NI), RWIPNUM(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALINTEGER("RISTOCKALL" + num$(NI), RISTOCKALL(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALDECIMAL("RNALLQTY" + num$(NI), RNALLQTY(NI))
          Endif
          If IRET = [V]CST_AOK Then
            IRET = fmet this.ASETVALDECIMAL("RNSHTQTY" + num$(NI), RNSHTQTY(NI))
          Endif
        Next NI
        IRETLOG = fmet this.ASETVALINTEGER("IIDXRET", IIDXRET)
      Else
        IIDXRET = 0
        IRETLOG = fmet this.ASETVALINTEGER("IIDXRET", IIDXRET)
      Endif
      # -----------------------------------
      IRETLOG = fmet this.ASETVALCHAR("WERR", SRETMSG)
      If IRET = [V]CST_AOK Then
        IRETLOG = fmet this.ASETVALINTEGER("RETMETH", [V]CST_AOK)
      Else
        IRETLOG = fmet this.ASETVALINTEGER("RETMETH", [V]CST_AERROR)
      Endif
      # -----------------------------------
      If IRET = [V]CST_AOK Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Endif
  # -----------------------------------
  If ORDERS <> null Then
    FreeGroup ORDERS
  Endif
  If WIP_PARAM <> null Then
    FreeGroup WIP_PARAM
  Endif
  # -----------------------------------
  If LOGFILE <> null Then
    IRETLOG = fmet LOGFILE.AFLUSHLOG()
    IRETLOG = fmet LOGFILE.AENDLOG()
    FreeGroup LOGFILE
  Endif
  Kill LOGFILE
Return

#######################################################################################
$TRACE_LINK
  # Issue X3-101833 - 2018-07-30 by FGR
  # Label call by $CLOSE_MANUF_PART
  If dim([L]WMESS) <0 Then
    Local Char WMESS(255)
  Endif
  # trace raz (base on buffer [F:MLK1])
  WMESS = mess([F:MLK1]DWIPTYP,341,1) + mess([F:MLK1]DWIPSTA,342,1) + ":" - [F:MLK1]DEMNUM + "/" + num$([F:MLK1]DEMLIN) + "," - mess(80,197,1) + ":" - [F:MLK1]ITMREF
  IRETLOG = fmet LOGFILE.APUTLINE(WMESS, [V]CST_AINFO)

  WMESS = mess([F:MLK1]RWIPTYP,341,1) + mess([F:MLK1]RWIPSTA,342,1) + ":" - [F:MLK1]RESSNUM + "/" + num$([F:MLK1]RESSLIN)
  IRETLOG = fmet LOGFILE.APUTLINE(WMESS, [V]CST_AINFO)

  WMESS = "________" - mess(650,197,1) - mess(170,197,1) - "(" + mess(646,197,1) + ":" - num$([F:MLK1]LIKQTY) + ")"
  IRETLOG = fmet LOGFILE.APUTLINE(WMESS, [V]CST_AINFO)
  IRETLOG = fmet LOGFILE.APUTLINE(AVOID.ACHAR, [V]CST_AINFO)
Return

