#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier AINDEX
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ANX",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
Endcase
Return

$OUVRE
If clalev([F:ANX3])=0 : Local File AINDEX    [ANX3] : Endif
Gosub SETSPE
Return

$LIENS
If dim([M:ANX1]COMDES)>0
 Call LECTEXTRA([M:ANX1]COMDES(nolign-1),"AINDEX","COMDES",[M:ANX1]TABLE(nolign-1),[M:ANX1]CODIND(nolign-1)) From ATEXTRA
Endif
Return

$VERIF_MOD
# Vérif qu'on n'a pas désactivé un index utilisé
OK = 1
For [AOB]ABREV
 If left$([F:AOB]SELCLE,4)=PRFSPE
  OK = 0
  For J=1 To [M]NBLIG
   If [F:AOB]NOMFIC=[M]TABLE(J-1) & [F:AOB]SELCLE=[M]CODIND(J-1)
    If [M]FLACT(J-1)=2 : OK = 1 : Break : Endif
   Endif
  Next J 
  If !OK 
   GMESSAGE = [F:AOB]SELCLE-":"-mess(130,126,1)-[F:AOB]ABREV : # Index utilisé par l'objet
   Break
  Endif
 Endif
 For [AWI]AWI1 Where OBJ=[F:AOB]ABREV
  Read [AWB]AWB0 = [F:AWI]WIN
  For I=1 To [F:AWB]NBLIS
   If left$([F:AWB]CLELIS(I-1),4)=PRFSPE
    OK = 0
    For J=1 To [M]NBLIG
     Read [AOB]ABREV=[F:AWB]OBJLIS(I-1)
     If !fstat & [F:AOB]NOMFIC=[M]TABLE(J-1) & [F:AWB]CLELIS(I-1)=[M]CODIND(J-1)
      If [M]FLACT(J-1)=2 : OK = 1 : Break : Endif
     Endif
    Next J  
    If !OK
     GMESSAGE = [F:AWB]CLELIS(I-1)-":"-mess(105,133,1)-[F:AWI]WIN : # Index utilisé par la fenêtre
     Break 3
    Endif
   Endif
  Next I
 Next AWI
Next AOB
If !OK : Return : Endif

$VERIF_CRE
Call VERF_DESCRIPT(OK)
If !OK
 Return
Endif
For nolign=1 To [M]NBLIG
 [M]LIG(nolign-1) = nolign
Next nolign
Return

Subprog VERF_DESCRIPT(OK)
Variable Integer OK
Local Integer L
OK = 1
# Vérif qu'une description d'index n'existe pas déjà
For L=0 To [M]NBLIG-1
 If [M]FLACT(L)=2
  For [ATI] Where CODFIC=[M]TABLE(L)
   If [M]DESCRIPT(L) = [F:ATI]DESCRIPT
    GMESSAGE = mess(21,176,1)-[M]CODIND(L) : # Composantes de clé déjà saisies pour l'index
    OK = 0 : Break 2
   Endif
  Next ATI
 Endif
Next L
End

$SETBOUT
Call VIREBOUT(CHAINE,"AH") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "1"
  Local Integer NBUSR , K
  Local Char    LISTE(250)
  Call USER_LISTE(nomap,NBUSR,LISTE) From PSADX
  If NBUSR>1
   # Nombre d'utilisateurs connectés :
   # Voulez-vous continuer ?
   Call AVERTIR(mess(150,124,1)-num$(NBUSR)+"\"+LISTE+"\"+mess(205,100,1),OK) From GESECRAN
   If OK<>2 : Return : Endif
  Endif
  For [ANX3]ANX1
   If filinfo(filpath("FIL",[F:ANX3]TABLE,"fde",nomap),0)>0
    Call CTLIND([F:ANX3]TABLE,[F:ANX3]CODIND,K)
    If (K & [F:ANX3]FLACT=1) or (!K & [F:ANX3]FLACT=2)
     Call TEMPON(mess(110,124,1)-[F:ANX3]TABLE) From GESECRAN
     Call MAJFIC([F:ANX3]TABLE,nomap,0) From VALDIC
     Call TEMPOFF From GESECRAN
    Endif
   Endif
  Next ANX3
Endcase   
Return

$CREATION
If dim([M:ANX1]COMDES)>0
 Call MAJTEXTRA([M:ANX1]COMDES(nolign-1),"AINDEX","COMDES",[M:ANX1]TABLE(nolign-1),[M:ANX1]CODIND(nolign-1)) From ATEXTRA
Endif
Return

$MODIF
For [AXX] Where CODFIC="AINDEX"
 K = 0
 For I=1 To [M:ANX1]NBLIG
  If [M:ANX1]TABLE(I-1)=[F:AXX]IDENT1 & [M:ANX1]CODIND(I-1)=[F:AXX]IDENT2
   K = 1 : Break
  Endif
 Next I
 If !K
  Delete [AXX] Curr
 Endif
Next ANX 
Gosub CREATION
Return

###########################################################"
$TRTCOP
If [M]DOSORG=nomap 
 Local File AINDEX  [ANX1]
 Local File ATEXTRA [AXX1] 
Else 
 Local File =[M]DOSORG+".AINDEX"  [ANX1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AINDEX  [ANX2] 
 Local File ATEXTRA [AXX2] 
Else 
 Local File =[M]DOSDES+".AINDEX"  [ANX2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ANX1], [ANX2] , [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Read [ANX2]ANX0 Last
If fstat>2
 K = 0
Else
 K = [F:ANX2]LIG
Endif
Trbegin [ANX2]
 For [ANX1]ANX0
  OK = 1
  For [ANX2]ANX1 Where TABLE=[F:ANX1]TABLE
   If [F:ANX2]DESCRIPT=[F:ANX1]DESCRIPT
    OK = 0 : Break
   Endif
  Next
  If OK
   K += 1
   [F:ANX2]      = [F:ANX1]
   [F:ANX2]FLACT = 1
   [F:ANX2]LIG   = K
   Call COPTEXTRA("AINDEX","COMDES",[F:ANX1]TABLE,[F:ANX1]CODIND) From ATEXTRA
   If dim([F:ANX2]UPDUSR)>0 : [F:ANX2]UPDUSR = GUSER : Endif
   If dim([F:ANX2]UPDDAT)>0 : [F:ANX2]UPDDAT = date$ : Endif
   If dim([F:ANX2]UPDTIM)>0 : [F:ANX2]UPDTIM = time : Endif
   Write [ANX2]
   If fstat
    GOK = 0 : Call FSTA("ANX2") From GLOCK : Goto AB_TR_COP
   Endif
  Endif  
 Next
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

###########################################################"
Subprog C_DESCRIPT(VALEUR)
Variable Char VALEUR()
Local Char    TABLE(GLONATB)
Local Integer L , OK
VALEUR = vireblc(toupper(VALEUR),2)
If VALEUR="" : mkstat=1 : End : Endif
Gosub SETNOL
TABLE = [M]TABLE(NOL)
If VALEUR<>""
 For L=0 To [M]NBLIG-1
  If L<>NOL    
   If TABLE=[M]TABLE(L) & [M]DESCRIPT(L)<>""
    If VALEUR=[M]DESCRIPT(L)
     GMESSAGE = mess(21,176,1)-num$(L+1) : # Composantes de clé déjà saisies pour l'index
     mkstat = 2 : Break
    Endif
   Endif
  Endif
 Next L
Endif
If mkstat : End : Endif
Call VERF_INDEX(TABLE,VALEUR,OK)
If !OK : mkstat=2 : End : Endif
End

Subprog VERF_INDEX(TABLE,INDEX,OK)
Value    Char    TABLE
Variable Char    INDEX()
Variable Integer OK
Local Integer I , J , K , NB , E , P , DIME , DIMAX , MAXCLE
Local Char    DESCRIPTEUR(250), ZINDEX(250) , ZONE(250)
OK = 1
NB = 0
E  = 0
P  = 0
DESCRIPTEUR = INDEX
While DESCRIPTEUR<>""
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If    I & J  : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I=1
  If P=1
   E = 1 : Break
  Endif
  P = 1
  DESCRIPTEUR = right$(DESCRIPTEUR,2)
  ZINDEX      = ""
 Elsif I
  ZINDEX      = left$(DESCRIPTEUR,I-1)
  DESCRIPTEUR = right$(DESCRIPTEUR,I+1)
 Else
  ZINDEX      = DESCRIPTEUR
  DESCRIPTEUR = ""
 Endif
 If ZINDEX<>""
  NB += 1
  K = instr(1,ZINDEX,"(")
  If K
   If right$(ZINDEX,len(ZINDEX))<>")" or len(ZINDEX)<K+2
    E = 1 : Break
   Endif
   For J=K+1 To len(ZINDEX)-1
    If mid$(ZINDEX,J,1)<"0" or mid$(ZINDEX,J,1)>"9"
     E = 1 : Break
    Endif
   Next J
   ZONE = left$(ZINDEX,K-1)
   DIME = val(seg$(ZINDEX,K+1,len(ZINDEX)-1))+1
  Else
   ZONE = ZINDEX
   DIME = 1
  Endif
  Read [ATZ]CODZONE = TABLE;ZONE
  If fstat
   # Index/Zone inexistante
   GMESSAGE = mess(10,176,1)-INDEX+"\"+ZONE-mess(11,176,1)
   OK = 0 : Break
  Endif
  DIMAX = [F:ATZ]DIME
  If [F:ATZ]CODACT<>""
   Read [ACV]CODACT = [F:ATZ]CODACT
   If fstat or [F:ACV]FLACT<>2
    # Index/Zone avec un code activité inactif
    GMESSAGE = mess(10,176,1)-INDEX+"\"+ZONE-mess(22,176,1)
    OK = 0 : Break
   Endif
   If [F:ACV]DIME<>0
    DIMAX = [F:ACV]DIME
   Endif
  Endif
  If DIME>DIMAX
   # Index/Indice incorrect
   GMESSAGE = mess(10,176,1)-INDEX+"\"+ZINDEX-":"-mess(46,105,1)-"(0.."+num$(DIMAX-1)+")"
   OK = 0 : Break
  Endif
  Read [ATY]CODTYP=[F:ATZ]CODTYP
  If find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3") or find([F:ATY]TYPTYP,9,10)
   # Index/Ce type de champ est interdit dans les index
   GMESSAGE = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
   OK = 0 : Break
  Endif
 Endif
Wend
If E
 GMESSAGE = mess(134,141,1) : # Erreur de syntaxe
 OK = 0
Endif
If OK =0 : End : Endif
MAXCLE = 16
If NB>MAXCLE
 GMESSAGE = mess(29,176,1) : # Trop de composantes de clé
 K = instr(1,GMESSAGE,"#")
 If K : GMESSAGE = left$(GMESSAGE,K-1)+num$(MAXCLE)+right$(GMESSAGE,K+1) : Endif
 OK = 0
Endif
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

$SETSPE
PRFSPE = "SPE_"
Return

########################################
Subprog C_FLACT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Local Integer I
If VALEUR=2
 For [ATI]CODIND Where CODFIC=TABLE
  If [M]DESCRIPT(NOL)=[F:ATI]DESCRIPT
   GMESSAGE = mess(21,176,1)-[F:ATI]CODIND
   mkstat = 2 : Break
  Endif
 Next
 If mkstat : End : Endif
Endif
End

Subprog AM_TABLE(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
NOL = nolign-1
Gosub SETSPE
If find([M]CODIND(NOL),PRFSPE,"") : End : Endif
Call CTLIND([M]TABLE(NOL),[M]CODIND(NOL),OK)
If OK
 # Index utilisé dans la table #
 Call ERREUR([M]CODIND(NOL)-":"-func AFNC.MES(mess(287,123,1),[M]TABLE(NOL))) From GESECRAN
 mkstat = 1 : End
Endif
End

Subprog AM_CODIND(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
NOL = nolign-1
Gosub SETSPE
If find([M]CODIND(NOL),PRFSPE,"") : End : Endif
Call CTLIND([M]TABLE(NOL),[M]CODIND(NOL),OK)
If OK
 # Index utilisé dans la table #
 Call ERREUR([M]CODIND(nolign-1)-":"-func AFNC.MES(mess(287,123,1),[M]TABLE(nolign-1))) From GESECRAN
 mkstat = 1 : End
Endif
End

Subprog C_CODIND(VALEUR)
Variable Char    VALEUR()
Local Integer NOL , I
Gosub SETSPE
If left$(VALEUR,4)<>PRFSPE
 # Le code doit commencer par
 GMESSAGE = mess(129,126,1)-PRFSPE : mkstat = 2 : End
Elsif len(VALEUR)<5
 # La longueur du code doit être supérieure ou égale à # caractères
 GMESSAGE = func AFNC.MES(mess(280,123,1),"5") : mkstat = 2 : End
Endif
NOL = nolign-1
For I=0 To dim([M]TABLE)-1
 If I<>NOL & [M]TABLE(I)<>"" & [M]TABLE(I)=[M]TABLE(NOL) & [M]CODIND(I)=VALEUR
  GERR=1
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
End

Subprog AVANT_NBLIG
[M]FLMODIF(nolign-1) = 1
End

Subprog IB_CODIND
Raz GBOUTS
End

Subprog C_NBLIG
Local Integer I , OK
Case status
 When 65 , 83 , 68 : # Supprimer/Suppression mutiples/Couper
  If nolign1=0
   nolign1 = nolign
  Endif
  For I=nolign To nolign1
   If [M]FLACT(I-1)=2
    # Index/Suppression impossible/Index actif
    Call ERREUR(mess(10,176,1)-[M]CODIND(I-1)-":"-mess(1,115,1)-"("+mess(286,123,1)+")") From GESECRAN
    mkstat = 1 : Break
   Else
    Call CTLIND([M]TABLE(I-1),[M]CODIND(I-1),OK)
    If OK
     # Index/Suppression impossible/Index utilisé dans la table #
     Call ERREUR(mess(10,176,1)-[M]CODIND(I-1)-":"-mess(1,115,1)-"("+func AFNC.MES(mess(287,123,1),[M]TABLE(I-1))+")") From GESECRAN
     mkstat = 1 : Break
    Endif
   Endif   
  Next I  
Endcase
End

#-----------------------------#
Subprog CTLIND(FIC,IND,OK)
Value Char FIC , IND
Variable Integer OK
Local Char FICHIER(GDIMFIC) , LIGNE(250)
Local Integer F , C
OK = 0
FICHIER = filpath("FIL",FIC,"srf")
If filinfo(FICHIER,0)>0
 Openi FICHIER Using [AA_]
 Iomode adxifs "" Using [AA_]
 Iomode adxirs chr$(10) Using [AA_]
 Iomode adxium GUTF8 Using [AA_]
 Rdseq LIGNE Using [AA_]
 Rdseq LIGNE Using [AA_]
 Rdseq LIGNE Using [AA_]
 Rdseq LIGNE Using [AA_]
 Rdseq LIGNE Using [AA_]
 For F=1 To val(LIGNE)
  Rdseq LIGNE Using [AA_]
 Next F
 Rdseq LIGNE Using [AA_]
 For C=1 To val(LIGNE)
  Rdseq LIGNE Using [AA_]
  If left$(LIGNE,len(IND))=IND
   OK = 1 : Break
  Endif
 Next C
 Openi Using [AA_]
Endif
End

