#<AdxTL>@(#)9.0.0.0 $Revision$
#################################################################################
# VENMAJ14 : M.a.j à effectuer lors du passage à la V140          Module Ventes #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#                                                                               #
#   - Table SORDER, VSORDER   : Entête commande, Historique Entête commande     #
#           Modif. CNTNAM : Remplacement Nom du contact par le Code du contact  #
#           Idem   CNDNAM                                                       #
#           Idem   CNINAM                                                       #
#           Initialisation : ORDINVNOT=ORDNOT et ORDINVATI=ORDATI               # 
#           Initialisation : BETFCY=1 et BETFCY=1                               # 
#   - Table SORDERP, VSORDERP : Détail commande, Historique Détail commande     #
#           Modif. CNDNAM : Remplacement Nom du contact par le Code du contact  #
#           Initialisation : SAUSTUCOE                                          # 
#   - Table SQUOTE            : Entête devis                                    #
#           Modif. CNCNAM : Remplacement Nom du contact par le Code du contact  #
#           Idem   CNDNAM                                                       #
#           Initialisation : QUOINVNOT=QUONOT et QUOINVATI=QUOATI               # 
#   - Table SQUOTED           : Détail devis                                    #
#           Modif. CNDNAM : Remplacement Nom du contact par le Code du contact  #
#           Initialisation : SAUSTUCOE, STU                                     # 
#   - Table SDELIVERY         : Entête livraison                                #
#           Modif. CNDNAM : Remplacement Nom du contact par le Code du contact  #
#           Idem   CNINAM                                                       #
#           Initialisation : BETFCY=1 et BETFCY=1                               # 
#   - Table SINVOICEV         : Entête facture                                  #
#           Modif. CNDNAM : Remplacement Nom du contact par le Code du contact  #
#           Idem   CNINAM                                                       #
#           Initialisation : BETFCY=1 et BETFCY=1                               # 
#                                                                               #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#                                                                               #
#   - Table SALTRS  Transaction de ventes ( traité par VENMAJTXN14 )            #
#           initialisation pour nouvelles zones                                 #  
#           devis, commandes, cdes ouvertes, livraisons, factures, retours      #  
#   - Table SORDERQ  Lignes commandes                                           #
#           transfert FMINUM vers POHNUM pour les DL inter-sites                #
#           transfert FMILIN vers POPLIN                                        #
#           transfert FMISEQ vers POQSEQ                                        #
#           transfert FMINUM vers POHNUM pour les DL inter-sites                #
#           init. DLVPIOCMP , STA ("A"-->"")                                    #
#   - Table VSORDERQ  Lignes commandes                                          #
#           transfert FMINUM vers POHNUM pour les DL inter-sites                #
#           transfert FMILIN vers POPLIN                                        #
#           transfert FMISEQ vers POQSEQ                                        #
#   - Table SORDERC  Lignes commandes                                           #
#           Init. Coefficient de conversion UV-US                               #
#   - Table VSORDERC  Lignes commandes                                          #
#           Init. Coefficient de conversion UV-US                               #
#   - Table SDELIVERYD  Lignes livraisons                                       #
#           Init. Coefficient de conversion UV-US , STA ("A"-->"")              #
#   - Table SINVOICED  Lignes Factures                                          #
#           Init. Coefficient de conversion UV-US , STA ("A"-->"")              #
#   - Table SRETURN           : Entête retour                                   #
#           Initialisation : BETFCY=1 et BETFCY=1                               # 
#   - Table SRETURND  Lignes Retours                                            #
#           Init. Coefficient de conversion UV-US SAUSTUCOE                     #
#           Prix net pour retours livraison NETPRI, NETPRINOT, NETPRIATI, CUR   # 
#                                                                               #
#################################################################################


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################
Subprog AVENMAJ14

Local Char WDOSSIER 

WDOSSIER=[F:ADS]DOSSIER  

Local Integer WOUV_TRACE

If filinfo(filpath("FIL","CONTACT","fde",WDOSSIER),0) < 0   End   Endif
If filinfo(filpath("FIL","SORDER","fde",WDOSSIER),0)  < 0   End   Endif

If GTRACE = ""
    ###tempo
    If WDOSSIER="DEMOMIGR"
     Call ECR_TRACE("************** AVENMAJ14 VENMAJ14 -ouvre_trace-***************",-1) From GESECRAN
    Endif
    ###tempo

    Call OUVRE_TRACE("DOSMAJ14 : Process for sales") From LECFIC
    WOUV_TRACE=1
Endif

Local File =WDOSSIER+".CONTACT"    [CNT] Order By Key CLE = BPATYP;BPANUM;CNTNAM

Local File =WDOSSIER+".BPARTNER"   [BPR]
Local File =WDOSSIER+".SORDER"     [SOH]
Local File =WDOSSIER+".VSORDER"    [VOH]
Local File =WDOSSIER+".SORDERP"    [SOP]
Local File =WDOSSIER+".VSORDERP"   [VOP]
Local File =WDOSSIER+".SQUOTE"     [SQH]
Local File =WDOSSIER+".SQUOTED"    [SQD]
Local File =WDOSSIER+".SDELIVERY"  [SDH]
Local File =WDOSSIER+".SINVOICEV"  [SIV]
Local File =WDOSSIER+".ITMMASTER"  [ITM]
Local File =WDOSSIER+".ITMBPC"     [ITU]
Local File =WDOSSIER+".TABCOEFF"   [TCO]

Gosub SET_FIRST   From TRTFIRST
Gosub AV_SOH
Gosub AV_VOH
Gosub AV_SOP
Gosub AV_VOP
Gosub AV_SQH
Gosub AV_SQD
Gosub AV_SDH
Gosub AV_SIV
Gosub UNSET_FIRST From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Close Local File [CNT]
Close Local File [BPR]
Close Local File [SOH]
Close Local File [VOH]
Close Local File [SOP]
Close Local File [VOP]
Close Local File [SQH]
Close Local File [SQD]
Close Local File [SDH]
Close Local File [SIV]
Close Local File [ITM]
Close Local File [ITU]
Close Local File [TCO]

End


#-------------------------------------------------------------------------------#
#    ---> Concerne les commandes SORDER                                         #
#-------------------------------------------------------------------------------#
#  CNTNAM : Remplacement du Nom du contact par le Code du contact               #
#  CNDNAM : Remplacement du Nom du contact par le Code du contact               #
#  CNINAM : Remplacement du Nom du contact par le Code du contact               #
#  ORDINVNOT : Non calculé, garni avec valeur de ORDNOT                         # 
#  ORDINVATI : Non calculé, garni avec valeur de ORDATI                         # 
#  BETFCY : Flag inter-site    : Nouveau champs initialisé à 1                  #
#  BETCPY : Flag inter-société : Nouveau champs initialisé à 1                  #
#-------------------------------------------------------------------------------#
$AV_SOH

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update SORDER") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ

Raz NBENR
Raz CLE1

Trbegin [SOH]
$BOUCLE_AV_SOH
Raz COMPTEUR
Raz STOP

For [SOH]SOH0 Where SOHNUM>CLE1 & (sum(CNTNAM,CNDNAM,CNINAM)<>"" | sum(ORDINVNOT,ORDINVATI)=0 | BETCPY=0 | BETFCY=0)
    WMAJ=0
    If [F:SOH]CNTNAM<>"" 
        If [F:CNT]BPANUM<>[F:SOH]BPCORD | [F:CNT]CNTNAM<>[F:SOH]CNTNAM 
            Read [F:CNT]CLE = 1;[F:SOH]BPCORD;vireblc([F:SOH]CNTNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SOH]BPCORD-[F:SOH]CNTNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SOH]SOHNUM-"CNTNAM="-[F:SOH]CNTNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SOH]CNTNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SOH]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:SOH]BPCORD | [F:CNT]CNTNAM <> [F:SOH]CNDNAM
            Read [F:CNT]CLE = 1;[F:SOH]BPCORD;vireblc([F:SOH]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SOH]BPCORD-[F:SOH]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SOH]SOHNUM-"CNDNAM="-[F:SOH]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SOH]CNDNAM = [F:CNT]CCNCRM  : WMAJ=1 : Endif
    Endif
    If [F:SOH]CNINAM<>"" 
        If [F:CNT]BPANUM<>[F:SOH]BPCINV | [F:CNT]CNTNAM <> [F:SOH]CNINAM
            Read [F:CNT]CLE = 1;[F:SOH]BPCINV;vireblc([F:SOH]CNINAM,1)
            If fstat  
#                Call ECR_TRACE([F:SOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SOH]BPCINV-[F:SOH]CNINAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SOH]SOHNUM-"CNINAM="-[F:SOH]CNINAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SOH]CNINAM = [F:CNT]CCNCRM  : WMAJ=1 : Endif
    Endif
    If sum(ORDINVNOT, ORDINVATI)=0
        [F:SOH]ORDINVNOT=[F:SOH]ORDNOT : [F:SOH]ORDINVATI=[F:SOH]ORDATI 
        WMAJ=1
    Endif
    If [F:SOH]BETFCY=0 [F:SOH]BETFCY=1 : WMAJ=1 Endif
    If [F:SOH]BETCPY=0 [F:SOH]BETCPY=1 : WMAJ=1 Endif

    If WMAJ=1
        NBENR+=1

        Rewrite [SOH]
        If fstat
            Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SOH]
        CLE1=[F:SOH]SOHNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SOH : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les commandes VSORDER                                        #
#-------------------------------------------------------------------------------#
# CNTNAM : Remplacement du Nom du contact par le Code du contact                #
# CNDNAM : Remplacement du Nom du contact par le Code du contact                #
# CNINAM : Remplacement du Nom du contact par le Code du contact                #
# ORDINVNOT : Non calculé, garni avec valeur de ORDNOT                          # 
# ORDINVATI : Non calculé, garni avec valeur de ORDATI                          # 
# BETFCY : Flag inter-site    : Nouveau champs initialisé à 1                   #
# BETCPY : Flag inter-société : Nouveau champs initialisé à 1                   #
#-------------------------------------------------------------------------------#
$AV_VOH

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update VSORDER") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [VOH]
$BOUCLE_AV_VOH

If  STOP=1
  CRITERE = 'SOHNUM="'+CLE1+'" & REVNUM>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SOHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR

For [VOH]VOH0 Where evalue(CRITERE) & (sum(CNTNAM,CNDNAM,CNINAM)<>"" | sum(ORDINVNOT,ORDINVATI)=0 | BETCPY=0 | BETFCY=0)
    WMAJ=0

    If [F:VOH]CNTNAM<>"" 
        If [F:CNT]BPANUM<>[F:VOH]BPCORD | [F:CNT]CNTNAM<>[F:VOH]CNTNAM
            Read [F:CNT]CLE = 1;[F:VOH]BPCORD;vireblc([F:VOH]CNTNAM,1)
            If fstat  
#                Call ECR_TRACE([F:VOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:VOH]BPCORD-[F:VOH]CNTNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:VOH]SOHNUM-"CNTNAM="-[F:VOH]CNTNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:VOH]CNTNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:VOH]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:VOH]BPCORD | [F:CNT]CNTNAM <> [F:VOH]CNDNAM
            Read [F:CNT]CLE = 1;[F:VOH]BPCORD;vireblc([F:VOH]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:VOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:VOH]BPCORD-[F:VOH]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:VOH]SOHNUM-"CNDNAM="-[F:VOH]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:VOH]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:VOH]CNINAM<>"" 
        If [F:CNT]BPANUM<>[F:VOH]BPCINV | [F:CNT]CNTNAM <> [F:VOH]CNINAM
            Read [F:CNT]CLE = 1;[F:VOH]BPCINV;vireblc([F:VOH]CNINAM,1)
            If fstat  
#                Call ECR_TRACE([F:VOH]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:VOH]BPCINV-[F:VOH]CNINAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT] 
            Endif
        Endif
#        Call ECR_TRACE([F:VOH]SOHNUM-"CNINAM="-[F:VOH]CNINAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:VOH]CNINAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If sum(ORDINVNOT, ORDINVATI)=0
        [F:VOH]ORDINVNOT=[F:VOH]ORDNOT : [F:VOH]ORDINVATI=[F:VOH]ORDATI 
        WMAJ=1
    Endif
    If [F:VOH]BETFCY=0 [F:VOH]BETFCY=1 : WMAJ=1 : Endif
    If [F:VOH]BETCPY=0 [F:VOH]BETCPY=1 : WMAJ=1 : Endif
       
    If WMAJ=1
        NBENR+=1
        Rewrite [VOH]
        If fstat
            Call ECR_TRACE("File VSORDER, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [VOH]
        CLE1=[F:VOH]SOHNUM : CLE2=[F:VOH]REVNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_VOH : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return



#-------------------------------------------------------------------------------#
#    ---> Concerne les détail commandes SORDERP                                 #
#-------------------------------------------------------------------------------#
# CNDNAM : Remplacement du Nom du contact par le Code du contact                #
# SAUSTUCOE : Coef.conversion UV-US : Nvx chps initialisé à partir de l'article #
#-------------------------------------------------------------------------------#
$AV_SOP

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update SORDERP") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, CLE3, WMAJ
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2, CLE3

Trbegin [SOP]
$BOUCLE_AV_SOP
If STOP=1
  CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN='+num$(CLE2)+' & SOPSEQ>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN>'+num$(CLE2)
  STOP=3
Elsif STOP=3
  CRITERE='SOHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR

#For [SOP]SOP0 Where SOHNUM>=CLE1 & CNDNAM<>""

For [SOP]SOP0 Where evalue(CRITERE) & (CNDNAM<>"" | SAUSTUCOE=0) 
    WMAJ=0
    If [F:SOP]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:SOP]BPCORD | [F:CNT]CNTNAM <> [F:SOP]CNDNAM
            Read [F:CNT]CLE = 1;[F:SOP]BPCORD;vireblc([F:SOP]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SOP]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SOP]BPCORD-[F:SOP]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SOP]SOHNUM-"CNDNAM="-[F:SOP]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SOP]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SOP]SAUSTUCOE=0
        Call ALISAUCOE([F:SOP]ITMREF, [F:SOP]BPCORD, [F:SOP]SAU, [F:SOP]STU, [F:SOP]SAUSTUCOE)
        If [F:SOP]SAUSTUCOE=0 [F:SOP]SAUSTUCOE=1 Endif
        WMAJ=1
    Endif
    If WMAJ=1
        NBENR+=1
        Rewrite [SOP]
        If fstat
            Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SOP]
        CLE1=[F:SOP]SOHNUM : CLE2=[F:SOP]SOPLIN : CLE3=[F:SOP]SOPSEQ : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SOP : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les détail commandes VSORDERP                                #
#-------------------------------------------------------------------------------#
# Remplacement du Nom du contact par le Code du contact                         #
# SAUSTUCOE : Coef.conversion UV-US : Nvx chps initialisé à partir de l'article #
#-------------------------------------------------------------------------------#
$AV_VOP

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update VSORDERP") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, CLE3,CLE4, WMAJ
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2, CLE3, CLE4

Trbegin [VOP]
$BOUCLE_AV_VOP
  If STOP=1
    CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN='+num$(CLE3)+' & SOPSEQ>'+num$(CLE4)
    STOP=2
  Elsif STOP=2
    CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN>'+num$(CLE3)
    STOP=3
  Elsif STOP=3
    CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM>'+num$(CLE2)
    STOP=4
  Elsif STOP=4
    CRITERE='SOHNUM>"'+CLE1+'"'
    STOP=0
  Else
    CRITERE="1=1"
  Endif

Raz COMPTEUR

#For [VOP]VOP0 Where SOHNUM>=CLE1 & CNDNAM<>"" 

For [VOP]VOP0 Where evalue(CRITERE) & (CNDNAM<>"" | SAUSTUCOE=0) 
    WMAJ=0

    If [F:VOP]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:VOP]BPCORD | [F:CNT]CNTNAM <> [F:VOP]CNDNAM
            Read [F:CNT]CLE = 1;[F:VOP]BPCORD;vireblc([F:VOP]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:VOP]SOHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:VOP]BPCORD-[F:VOP]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:VOP]SOHNUM-"CNDNAM="-[F:VOP]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:VOP]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif

    If [F:VOP]SAUSTUCOE=0
        Call ALISAUCOE([F:VOP]ITMREF, [F:VOP]BPCORD, [F:VOP]SAU, [F:VOP]STU, [F:VOP]SAUSTUCOE)
        If [F:VOP]SAUSTUCOE=0 [F:VOP]SAUSTUCOE=1 Endif
        WMAJ=1
    Endif
    If WMAJ=1
        NBENR+=1
        Rewrite [VOP]
        If fstat
            Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [VOP]
        CLE1=[F:VOP]SOHNUM : CLE2=[F:VOP]LINREVNUM : CLE3=[F:VOP]SOPLIN : CLE4=[F:VOP]SOPSEQ : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_VOP : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les devis SQUOTE                                             #
#-------------------------------------------------------------------------------#
# Dans le champs CNCNAM : Remplacement du Nom du contact par le Code du contact #
#                CNDNAM : Remplacement du Nom du contact par le Code du contact #
#                QUOINVNOT : Non calculé, garni avec valeur de QUONOT           # 
#                QUOINVATI : Non calculé, garni avec valeur de QUOATI           # 
#-------------------------------------------------------------------------------#
$AV_SQH

Call ECR_TIME("DOSMAJ14 Sales Quote Process : Update SQUOTE") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ

Raz NBENR
Raz CLE1

Trbegin [SQH]
$BOUCLE_AV_SQH
Raz COMPTEUR
Raz STOP

For [SQH]SQH0 Where SQHNUM>CLE1 & ( sum(CNCNAM, CNDNAM)<>"" | sum(QUOINVNOT, QUOINVATI)=0 )
    WMAJ=0

    If [F:SQH]CNCNAM<>"" 
        If [F:CNT]BPANUM<>[F:SQH]BPCORD | [F:CNT]CNTNAM<>[F:SQH]CNCNAM
            Read [F:CNT]CLE = 1;[F:SQH]BPCORD;vireblc([F:SQH]CNCNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SQH]SQHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SQH]BPCORD-[F:SQH]CNCNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SQH]SQHNUM-"CNCNAM="-[F:SQH]CNCNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SQH]CNCNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SQH]CNDNAM<>"" 
        If [F:CNT]CNTNAM <> [F:SQH]CNDNAM
            Read [F:CNT]CLE = 1;[F:SQH]BPCORD;vireblc([F:SQH]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SQH]SQHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SQH]BPCORD-[F:SQH]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SQH]SQHNUM-"CNDNAM="-[F:SQH]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SQH]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If sum(QUOINVNOT, QUOINVATI)=0
        [F:SQH]QUOINVNOT=[F:SQH]QUONOT : [F:SQH]QUOINVATI=[F:SQH]QUOATI 
        WMAJ=1
    Endif

    If WMAJ=1
        NBENR+=1
        Rewrite [SQH]
        If fstat
            Call ECR_TRACE("File SQUOTE, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SQH]
        CLE1=[F:SQH]SQHNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SQH : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les détail commandes SQUOTED                                 #
#-------------------------------------------------------------------------------#
# CNDNAM : Remplacement du Nom du contact par le Code du contact                #
# SAUSTUCOE : Coef.conversion UV-US : Nvx chps initialisé à partir de l'article #
# STU       : Unité de stock        : Nvx chps initialisé à partir de l'article #
#-------------------------------------------------------------------------------#
$AV_SQD

Call ECR_TIME("DOSMAJ14 Sales Quote Process : Update SQUOTED") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SQD]
$BOUCLE_AV_SQD
If  STOP=1
  CRITERE = 'SQHNUM="'+CLE1+'" & SQDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SQHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif

Raz COMPTEUR

For [SQD]SQD0 Where evalue(CRITERE) & (CNDNAM<>"" | STU="" | SAUSTUCOE=0)
    WMAJ=0
    If [F:SQD]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:SQD]BPCORD | [F:CNT]CNTNAM <> [F:SQD]CNDNAM
            Read [F:CNT]CLE = 1;[F:SQD]BPCORD;vireblc([F:SQD]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SQD]SQHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SQD]BPCORD-[F:SQD]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SQD]SQHNUM-"CNDNAM="-[F:SQD]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SQD]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif

    If [F:SQD]STU="" | [F:SQD]SAUSTUCOE=0
        If [F:ITM]ITMREF <> [F:SQD]ITMREF
            Read [F:ITM]ITM0 = [F:SQD]ITMREF
            If fstat  Raz [F:ITM] : Endif
        Endif
        If [F:SQD]STU = "" [F:SQD]STU=[F:ITM]STU : WMAJ=1 : Endif
        If [F:SQD]SAUSTUCOE = 0
            Call ALISAUCOE([F:SQD]ITMREF, [F:SQD]BPCORD, [F:SQD]SAU, [F:SQD]STU, [F:SQD]SAUSTUCOE)
            If [F:SQD]SAUSTUCOE=0 [F:SQD]SAUSTUCOE=1 Endif
            WMAJ=1
        Endif
    Endif

    If WMAJ=1
        NBENR+=1
        Rewrite [SQD]
        If fstat
            Call ECR_TRACE("File SQUOTED, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SQD]
        CLE1=[F:SQD]SQHNUM : CLE2=[F:SQD]SQDLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SQD : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les livraisons SDELIVERY                                     #
#-------------------------------------------------------------------------------#
# CNDNAM : Remplacement du Nom du contact par le Code du contact                #
# CNINAM : Remplacement du Nom du contact par le Code du contact                #
# BETFCY : Flag inter-site    : Nouveau champs initialisé à 1                   #
# BETCPY : Flag inter-société : Nouveau champs initialisé à 1                   #
#-------------------------------------------------------------------------------#
$AV_SDH

Call ECR_TIME("DOSMAJ14 Sales Delivery Process : Update SDELIVERY") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ

Raz NBENR
Raz CLE1

Trbegin [SDH]
$BOUCLE_AV_SDH
Raz COMPTEUR
Raz STOP

For [SDH]SDH0 Where SDHNUM>CLE1 & (sum(CNDNAM, CNINAM)<>"" | BETCPY=0 | BETFCY=0)
    WMAJ=0
    If [F:SDH]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:SDH]BPCORD | [F:CNT]CNTNAM <> [F:SDH]CNDNAM
            Read [F:CNT]CLE = 1;[F:SDH]BPCORD;vireblc([F:SDH]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SDH]SDHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SDH]BPCORD-[F:SDH]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SDH]SDHNUM-"CNDNAM="-[F:SDH]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SDH]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SDH]CNINAM<>"" 
        If [F:CNT]BPANUM<>[F:SDH]BPCINV | [F:CNT]CNTNAM <> [F:SDH]CNINAM
            Read [F:CNT]CLE = 1;[F:SDH]BPCINV;vireblc([F:SDH]CNINAM,1)
            If fstat  
#                Call ECR_TRACE([F:SDH]SDHNUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SDH]BPCINV-[F:SDH]CNINAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT] 
            Endif
        Endif
#        Call ECR_TRACE([F:SDH]SDHNUM-"CNINAM="-[F:SDH]CNINAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SDH]CNINAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SDH]BETFCY=0 [F:SDH]BETFCY=1 : WMAJ=1 : Endif
    If [F:SDH]BETCPY=0 [F:SDH]BETCPY=1 : WMAJ=1 : Endif

    If WMAJ=1
        NBENR+=1
        Rewrite [SDH]
        If fstat
            Call ECR_TRACE("File SDELIVERY, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SDH]
        CLE1=[F:SDH]SDHNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SDH : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return



#-------------------------------------------------------------------------------#
#    ---> Concerne les livraisons SINVOICEV                                     #
#-------------------------------------------------------------------------------#
# CNDNAM : Remplacement du Nom du contact par le Code du contact                #
# CNINAM : Remplacement du Nom du contact par le Code du contact                #
# BETFCY : Flag inter-site    : Nouveau champs initialisé à 1                   #
# BETCPY : Flag inter-société : Nouveau champs initialisé à 1                   #
#-------------------------------------------------------------------------------#
$AV_SIV

Call ECR_TIME("DOSMAJ14 Sales Invoice Process : Update SINVOICEV") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ

Raz NBENR
Raz CLE1

Trbegin [SIV]
$BOUCLE_AV_SIV
Raz COMPTEUR
Raz STOP

For [SIV]SIV0 Where NUM>CLE1 & (sum(CNDNAM, CNINAM)<>"" | BETCPY=0 | BETFCY=0)
    WMAJ=0
    If [F:SIV]CNDNAM<>"" 
        If [F:CNT]BPANUM<>[F:SIV]BPCORD | [F:CNT]CNTNAM <> [F:SIV]CNDNAM
            Read [F:CNT]CLE = 1;[F:SIV]BPCORD;vireblc([F:SIV]CNDNAM,1)
            If fstat  
#                Call ECR_TRACE([F:SIV]NUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SIV]BPCORD-[F:SIV]CNDNAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT]
            Endif
        Endif
#        Call ECR_TRACE([F:SIV]NUM-"CNDNAM="-[F:SIV]CNDNAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SIV]CNDNAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SIV]CNINAM<>"" 
        If [F:CNT]CNTNAM <> [F:SIV]CNINAM
            Read [F:CNT]CLE = 1;[F:SIV]BPCINV;vireblc([F:SIV]CNINAM,1)
            If fstat  
#                Call ECR_TRACE([F:SIV]NUM-": File CONTACT, Error ="-num$(fstat)-":"-[F:SIV]BPCINV-[F:SIV]CNINAM-mess(23,100,1),0) From GESECRAN
                Raz [F:CNT] 
            Endif
        Endif
#        Call ECR_TRACE([F:SIV]NUM-"CNINAM="-[F:SIV]CNINAM-"CCNCRM="-[F:CNT]CCNCRM,0) From GESECRAN
        If [F:CNT]CCNCRM<>"" [F:SIV]CNINAM = [F:CNT]CCNCRM : WMAJ=1 : Endif
    Endif
    If [F:SIV]BETFCY=0 [F:SIV]BETFCY=1 : WMAJ=1 : Endif
    If [F:SIV]BETCPY=0 [F:SIV]BETCPY=1 : WMAJ=1 : Endif

    If WMAJ=1
        NBENR+=1
        Rewrite [SIV]
        If fstat
            Call ECR_TRACE("File SINVOICEV, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR+=1
        Endif
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SIV]
        CLE1=[F:SIV]NUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_SIV : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################
Subprog VENMAJ14

Local Char WDOSSIER 

WDOSSIER=[F:ADS]DOSSIER  

If filinfo(filpath("FIL","SALTRS","fde",WDOSSIER),0) < 0     End Endif
If filinfo(filpath("FIL","SORDER","fde",WDOSSIER),0) < 0     End Endif
If filinfo(filpath("FIL","SINVOICEV","fde",WDOSSIER),0) < 0  End Endif 

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ14 : Process for sales ") From LECFIC
    WOUV_TRACE=1
Endif

Gosub SET_FIRST   From TRTFIRST
#    ---> Moulinette des transactions  
Call VENMAJTXN14

Local File =WDOSSIER+".SORDER"     [SOH]
Local File =WDOSSIER+".VSORDER"    [VOH]
Local File =WDOSSIER+".SQUOTED"    [SQD]
Local File =WDOSSIER+".SORDERP"    [SOP]
Local File =WDOSSIER+".SORDERQ"    [SOQ]
Local File =WDOSSIER+".VSORDERP"   [VOP]
Local File =WDOSSIER+".VSORDERQ"   [VOQ]
Local File =WDOSSIER+".SORDERC"    [SOC]
Local File =WDOSSIER+".VSORDERC"   [VOC]
Local File =WDOSSIER+".SDELIVERY"  [SDH]
Local File =WDOSSIER+".SDELIVERYD" [SDD]
Local File =WDOSSIER+".SINVOICEV"  [SIV]
Local File =WDOSSIER+".SINVOICED"  [SID]
Local File =WDOSSIER+".SRETURND"   [SRD]
Local File =WDOSSIER+".SRETURN"    [SRH]
Local File =WDOSSIER+".ITMMASTER"  [ITM]
Local File =WDOSSIER+".ITMBPC"     [ITU]
Local File =WDOSSIER+".TABCOEFF"   [TCO]
Local File =WDOSSIER+".ATEXTRA"    [AXX]
Local File =WDOSSIER+".ORDERS"     [ORD]

Gosub AP_SOQ
Gosub AP_VOQ
Gosub AP_SOC
Gosub AP_VOC
Gosub AP_SDD
Gosub AP_SID
Gosub AP_SRH
Gosub AP_SRD
Gosub UNSET_FIRST From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Close Local File [SOH]
Close Local File [VOH]
Close Local File [SQD]
Close Local File [SOP]
Close Local File [VOP]
Close Local File [VOQ]
Close Local File [SOC]
Close Local File [VOC]
Close Local File [SDH]
Close Local File [SDD]
Close Local File [SIV]
Close Local File [SID]
Close Local File [SRD]
Close Local File [SRH]
Close Local File [ITM]
Close Local File [ITU]
Close Local File [TCO]
Close Local File [AXX]
Close Local File [ORD]

End


#-------------------------------------------------------------------------------#
#    ---> Concerne les commandes SORDERQ                                        #
#-------------------------------------------------------------------------------#
# Initialisation lignes commandes                                               #
# --> Transfert FMINUM vers POHNUM pour les DL inter-sites                      #
#     Transfert FMILIN vers POPLIN                                              #
#     Transfert FMISEQ vers POQSEQ                                              #
# --> Initialisation DLVPIOCMP                                                  #
# --> Initialisation STA ("A" --> "")                                           #   
#-------------------------------------------------------------------------------#
$AP_SOQ

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update SORDERQ") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, CLE3
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2, CLE3

Trbegin [SOQ]
$BOUCLE1_SOQ
If STOP=1
  CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN='+num$(CLE2)+' & SOQSEQ>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='SOHNUM="'+CLE1+'"'+' & SOPLIN>'+num$(CLE2)
  STOP=3
Elsif STOP=3
  CRITERE='SOHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR

For [SOQ]SOQ0 Where evalue(CRITERE) 
    [F:SOQ]DLVPIOCMP=9-[F:SOQ]DLVPIO
    If find([F:SOQ]STA,"A","A ","A  ")
        Raz [F:SOQ]STA
    Endif
    If [F:SOQ]SOHCAT=4 & [F:SOQ]FMINUM <> ""
        [F:SOQ]POHNUM=[F:SOQ]FMINUM
        [F:SOQ]POPLIN=[F:SOQ]FMILIN
        [F:SOQ]POQSEQ=[F:SOQ]FMISEQ
        Raz [F:SOQ]FMINUM, [F:SOQ]FMILIN, [F:SOQ]FMISEQ
    Endif
    # Ligne de cde classique non soldée : Si la cde est inter-site intra-société,changer l'encours "SO" en "TP"
    If [F:SOQ]SOHCAT<>4 & [F:SOQ]STOMGTCOD>1 & [F:SOQ]SOQSTA<>3 & [F:SOQ]DEMNUM<>""
        If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
            Read [F:SOH]SOH0 = [F:SOQ]SOHNUM
            If fstat  Raz [F:SOH] : Endif
        Endif
        If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1   
            Read [ORD] ORD0=1;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
            If fstat
                Call ECR_TRACE("File ORDERS, Error ="-num$(fstat),1) From GESECRAN
            Else
                [F:ORD]WIPTYP=8
                Write [ORD]
                If fstat
                    Call ECR_TRACE("File ORDERS, Error ="-num$(fstat),1) From GESECRAN
                Endif
                Delete [ORD] Where WIPTYP=1 & WIPNUM=[F:SOQ]DEMNUM & ITMREF=[F:SOQ]ITMREF
            Endif
        Endif
    Endif
    NBENR+=1
    Rewrite [SOQ]
    If fstat
        Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SOQ]
        CLE1=[F:SOQ]SOHNUM : CLE2=[F:SOQ]SOPLIN : CLE3=[F:SOQ]SOQSEQ : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE1_SOQ : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les commandes VSORDERQ                                       #
#-------------------------------------------------------------------------------#
# Initialisation lignes commandes                                               #
# --> Transfert FMINUM vers POHNUM pour les DL inter-sites                      #
#     Transfert FMILIN vers POPLIN                                              #
#     Transfert FMISEQ vers POQSEQ                                              #
#-------------------------------------------------------------------------------#
$AP_VOQ

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update VSORDERQ") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, CLE3, CLE4 
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2, CLE3, CLE4

Trbegin [VOQ]
$BOUCLE1_VOQ
If STOP=1
  CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN='+num$(CLE3)+' & SOQSEQ>'+num$(CLE4)
  STOP=2
Elsif STOP=2
  CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM='+num$(CLE2)+' & SOPLIN>'+num$(CLE3)
  STOP=3
Elsif STOP=3
  CRITERE='SOHNUM="'+CLE1+'"'+' & LINREVNUM>'+num$(CLE2)
  STOP=4
Elsif STOP=4
  CRITERE='SOHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR

For [VOQ]VOQ0 Where evalue(CRITERE) 
    [F:VOQ]DLVPIOCMP=9-[F:VOQ]DLVPIO
    If find([F:VOQ]STA,"A","A ","A  ")
        Raz [F:VOQ]STA
    Endif
    If [F:VOQ]SOHCAT=4 & [F:VOQ]FMINUM <> "" 
        [F:VOQ]POHNUM=[F:VOQ]FMINUM
        [F:VOQ]POPLIN=[F:VOQ]FMILIN
        [F:VOQ]POQSEQ=[F:VOQ]FMISEQ
        Raz [F:VOQ]FMINUM, [F:VOQ]FMILIN, [F:VOQ]FMISEQ
    Endif
    NBENR+=1
    Rewrite [VOQ]
    If fstat
        Call ECR_TRACE("File VSORDERQ, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [VOQ]
        CLE1=[F:VOQ]SOHNUM : CLE2=[F:VOQ]LINREVNUM : CLE3=[F:VOQ]SOPLIN : CLE4=[F:VOQ]SOQSEQ : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE1_VOQ : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les commandes ouvertes SORDERC                               #
#-------------------------------------------------------------------------------#
# Initialisation lignes articles                                                #
# --> Coefficient de conversion UV-US                                           #
#-------------------------------------------------------------------------------#
$AP_SOC

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update SORDERC") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2 
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SOC]
$BOUCLE_SOC
If  STOP=1
  CRITERE = 'SOHNUM="'+CLE1+'" & SOPLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SOHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR

#     Alimentation des nouvelles zones du détail
For [SOC]SOC0 Where evalue(CRITERE) & SAUSTUCOE=0 
    Call ALISAUCOE([F:SOC]ITMREF, [F:SOC]BPCORD, [F:SOC]SAU, [F:SOC]STU, [F:SOC]SAUSTUCOE)
    If [F:SOC]SAUSTUCOE=0 [F:SOC]SAUSTUCOE=1 Endif
    NBENR+=1
    Rewrite [SOC]
    If fstat
        Call ECR_TRACE("File SORDERC, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SOC]
        CLE1=[F:SOC]SOHNUM : CLE2=[F:SOC]SOPLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SOC : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les historiques commandes ouvertes VSORDERC                  #
#-------------------------------------------------------------------------------#
# Initialisation lignes historiques article                                     #
# --> Coefficient de conversion UV-US                                           #
#-------------------------------------------------------------------------------#
$AP_VOC

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update VSORDERC") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, CLE3
Local Char    CRITERE (90)

Raz STOP
Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2, CLE3

Trbegin [VOC]
$BOUCLE_VOC
If STOP=1
   STOP=2 : CRITERE='SOHNUM="'+CLE1+'"'+' & ITMREVNUM='+num$(CLE2)+' & SOPLIN>'+num$(CLE3)
Elsif STOP=2
   STOP=3 : CRITERE='SOHNUM="'+CLE1+'"'+' & ITMREVNUM>'+num$(CLE2)
Elsif STOP=3
   STOP=0 : CRITERE='SOHNUM>"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Raz COMPTEUR
#     Alimentation des nouvelles zones du détail
For [VOC]VOC0 Where evalue(CRITERE) & SAUSTUCOE=0 
    Call ALISAUCOE([F:VOC]ITMREF, [F:VOC]BPCORD, [F:VOC]SAU, [F:VOC]STU, [F:VOC]SAUSTUCOE)
    If [F:VOC]SAUSTUCOE=0 [F:VOC]SAUSTUCOE=1 Endif
    NBENR+=1
    Rewrite [VOC]
    If fstat
        Call ECR_TRACE("File VSORDERC, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [VOC]
        CLE1=[F:VOC]SOHNUM : CLE2=[F:VOC]ITMREVNUM : CLE3=[F:VOC]SOPLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_VOC : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les livraisons SDELIVERYD                                    #
#-------------------------------------------------------------------------------#
# Initialisation lignes livraisons                                              #
# --> Coefficient de conversion UV-US                                           #
# --> Initialisation STA ("A" --> "")                                           #   
#-------------------------------------------------------------------------------#
$AP_SDD

Call ECR_TIME("DOSMAJ14 Sales Delivery Process : Update SDELIVERYD") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SDD]
$BOUCLE_SDD
If  STOP=1
  CRITERE = 'SDHNUM="'+CLE1+'" & SDDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SDHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif

Raz COMPTEUR

#     Alimentation des nouvelles zones du détail
For [SDD]SDD0 Where evalue(CRITERE) 
    If find([F:SDD]STA,"A","A ","A  ")
        Raz [F:SDD]STA
    Endif
    Call ALISAUCOE([F:SDD]ITMREF, [F:SDD]BPCORD, [F:SDD]SAU, [F:SDD]STU, [F:SDD]SAUSTUCOE)
    If [F:SDD]SAUSTUCOE=0 [F:SDD]SAUSTUCOE=1 Endif
    NBENR+=1
    Rewrite [SDD]
    If fstat
        Call ECR_TRACE("File SDELIVERYD, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SDD]
        CLE1=[F:SDD]SDHNUM : CLE2=[F:SDD]SDDLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SDD : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les factures   SINVOICED                                     #
#-------------------------------------------------------------------------------#
# Initialisation lignes factures                                                #
# --> Coefficient de conversion UV-US                                           #
# --> Initialisation STA ("A" --> "")                                           #   
#-------------------------------------------------------------------------------#
$AP_SID

Call ECR_TIME("DOSMAJ14 Sales Invoice Process : Update SINVOICED") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2
Local Char    CRITERE (90)

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SID]
$BOUCLE_SID
If  STOP=1
  CRITERE = 'NUM="'+CLE1+'" & SIDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'NUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif

Raz COMPTEUR

#     Alimentation des nouvelles zones du détail
For [SID]SID0 Where evalue(CRITERE) 
    If find([F:SID]STA,"A","A ","A  ")
        Raz [F:SID]STA
    Endif
    If [F:SIV]NUM <> [F:SID]NUM
        Read [F:SIV]SIV0 = [F:SID]NUM
        If fstat  Raz [F:SIV] : Endif
    Endif
    If [F:SIV]NUM<>""
        Call ALISAUCOE([F:SID]ITMREF, [F:SIV]BPCORD, [F:SID]SAU, [F:SID]STU, [F:SID]SAUSTUCOE)
        If [F:SID]SAUSTUCOE=0 [F:SID]SAUSTUCOE=1 Endif
    Else
        [F:SID]SAUSTUCOE=1
    Endif
    NBENR+=1
    Rewrite [SID]
    If fstat
        Call ECR_TRACE("File SINVOICED, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SID]
        CLE1=[F:SID]NUM : CLE2=[F:SID]SIDLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SID : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les retours SRETURN                                          #
#-------------------------------------------------------------------------------#
# Initialisation entêtes retours                                                #
# --> Flag inter-site                                                           #
# --> Flag inter-société                                                        #
#-------------------------------------------------------------------------------#
$AP_SRH

Call ECR_TIME("DOSMAJ14 Sales Order Process : Update SRETURN") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2 
Local Char    CRITERE (90)

Raz CLE1
Trbegin [SRH]
$BOUCLE_SRH
Raz COMPTEUR
Raz STOP

For [SRH]SRH0 Where SRHNUM>CLE1 & (BETCPY=0 | BETFCY=0)
    If [F:SRH]BETFCY=0 [F:SRH]BETFCY=1 Endif
    If [F:SRH]BETCPY=0 [F:SRH]BETCPY=1 Endif
    NBENR+=1
    Rewrite [SRH]
    If fstat
        Call ECR_TRACE("File SRETURN, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SRH]
        CLE1=[F:SRH]SRHNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SRH : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les retours    SRETURND                                      #
#-------------------------------------------------------------------------------#
# Initialisation lignes retours                                                 #
# --> Coefficient de conversion UV-US                                           #
#              SAUSTUCOE                                                        #
# --> Prix net pour les retours de livraisons                                   #
#              NETPRI, NETPRINOT, NETPRIATI, CUR                                #
#-------------------------------------------------------------------------------#
$AP_SRD

Call ECR_TIME("DOSMAJ14 Sales Return Process : Update SRETURND") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2
Local Char    CRITERE (90)


Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SRD]
$BOUCLE_SRD
If  STOP=1
  CRITERE = 'SRHNUM="'+CLE1+'" & SRDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SRHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif

Raz COMPTEUR

# 1 ère boucle pour traiter le coefficient UV-US
For [SRD]SRD0 Where evalue(CRITERE) & SAUSTUCOE=0
    If [F:SRH]SRHNUM <> [F:SRD]SRHNUM
        Read [F:SRH]SRH0 = [F:SRD]SRHNUM
        If fstat  Raz [F:SRH] : Endif
    Endif
    Gosub INIT_ITMDES
    # Recherche du coefficient de conversion UV-US
    Call ALISAUCOE([F:SRD]ITMREF, [F:SRH]BPCORD, [F:SRD]SAU, [F:SRD]STU, [F:SRD]SAUSTUCOE)
    If [F:SRD]SAUSTUCOE=0 [F:SRD]SAUSTUCOE=1 Endif
    # Si on doit rechercher le prix net on le fait par la même occasion
    If [F:SRD]SDHNUM <> "" & [F:SRD]NETPRI=0
        If [F:SDD]SDHNUM <> [F:SRD]SDHNUM | [F:SDD]SDDLIN <> [F:SRD]SDDLIN 
            Read [F:SDD]SDD0 = [F:SRD]SDHNUM;[F:SRD]SDDLIN
            If fstat  Raz [F:SDD] : Endif
        Endif
        If [F:SDH]SDHNUM <> [F:SRD]SDHNUM
            Read [F:SDH]SDH0 = [F:SRD]SDHNUM
            If fstat  Raz [F:SDH] : Endif
        Endif
        [F:SRD]CUR = [F:SDH]CUR
        [F:SRD]NETPRI = [F:SDD]NETPRI 
        [F:SRD]NETPRINOT = [F:SDD]NETPRINOT
        [F:SRD]NETPRIATI = [F:SDD]NETPRIATI
    Endif
    NBENR+=1
    Rewrite [SRD]
    If fstat
        Call ECR_TRACE("File SRETURND, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif
    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SRD]
        CLE1=[F:SRD]SRHNUM : CLE2=[F:SRD]SRDLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SRD : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Raz NBENR
Raz COMPTEUR
Raz STOP
Raz CLE1, CLE2

Trbegin [SRD]
$BOUCLE_SRD1
If  STOP=1
  CRITERE = 'SRHNUM="'+CLE1+'" & SRDLIN>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'SRHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif

Raz COMPTEUR

# 2 ème boucle pour traiter le prix net          
For [SRD]SRD0 Where evalue(CRITERE) & SDHNUM<> "" & NETPRI=0
    If [F:SDD]SDHNUM <> [F:SRD]SDHNUM | [F:SDD]SDDLIN <> [F:SRD]SDDLIN 
        Read [F:SDD]SDD0 = [F:SRD]SDHNUM;[F:SRD]SDDLIN
        If fstat  Raz [F:SDD] : Endif
    Endif
    If [F:SDH]SDHNUM <> [F:SRD]SDHNUM
        Read [F:SDH]SDH0 = [F:SRD]SDHNUM
        If fstat  Raz [F:SDH] : Endif
    Endif
    Gosub INIT_ITMDES
    [F:SRD]CUR = [F:SDH]CUR
    [F:SRD]NETPRI = [F:SDD]NETPRI 
    [F:SRD]NETPRINOT = [F:SDD]NETPRINOT
    [F:SRD]NETPRIATI = [F:SDD]NETPRIATI
    NBENR+=1
    Rewrite [SRD]
    If fstat
        Call ECR_TRACE("File SRETURND, Error ="-num$(fstat),1) From GESECRAN
    Else
        COMPTEUR+=1
    Endif

    If COMPTEUR>GMAXUPDTRS
        Commit
        Trbegin [SRD]
        CLE1=[F:SRD]SRHNUM : CLE2=[F:SRD]SRDLIN : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_SRD1: Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

#-------------------------------------------------------------------------------#
# Initialisation de la désignation traduite                                     #
#-------------------------------------------------------------------------------#
$INIT_ITMDES
If [F:SRD]ITMDES="" 
    # Alimentation de la désignation traduite
    Read [AXX] AXX0="ITMMASTER";"DES1AXX";[F:SRH]LAN;[F:SRD]ITMREF;""
    If !fstat  [F:SRD]ITMDES=[F:AXX]TEXTE : Endif
    If [F:SRD]ITMDES="" [F:SRD]ITMDES=[F:SRD]ITMDES1 Endif
Endif
Return

#-------------------------------------------------------------------------------#
# Alimentation du coef. de conversion UV-US                                     #
#              recherche ds ITM, ITU, ITM, TCO                                  #
#-------------------------------------------------------------------------------#
# Entrée  ART      : Article                                                    #
#         CLI      : Client                                                     #
#         SAUORI   : Unité origine                                              # 
#                    Unité de stock ou vente ou condit.                         #
#         SAUDST   : Unité destination                                          #
#                    Unité de stock définie dans ITM                            # 
# Sortie  COEF     : Coefficient trouvé vers US                                 # 
#-------------------------------------------------------------------------------#
# Sous-pro dupliqué de TRTVENQTE                                                #
#          à cause des local file (doivent être fait dans le bon dossier)       #
#-------------------------------------------------------------------------------#

Subprog ALISAUCOE(ART,CLI,SAUORI,SAUDST, COEF)
Value    Char    ART
Value    Char    CLI
Value    Char    SAUORI
Value    Char    SAUDST
Variable Decimal COEF
 
Raz COEF

If SAUORI = SAUDST COEF=1 : End : Endif
#-------------------------------------------------------------------------------#
# Lecture ITM  : Si l'unité est l'unité de vente -->  Récup. coef.conv. UV-US   #
#-------------------------------------------------------------------------------#
If [F:ITM]ITMREF <> ART Read [ITM] ITM0=ART
                        If fstat Raz [F:ITM] : Endif
                        Endif 
Gosub CTR_ITMCOEF     : # init. données ITM utilisées comme diviseurs     
If SAUORI = [F:ITM]SAU  COEF = [F:ITM]SAUSTUCOE :Endif
If COEF <> 0 End : Endif

#-------------------------------------------------------------------------------#
# Lecture ITU  : Si l'unité est l'unité de vente   -->  Récup coef.conv. UV-US  #
#                Si l'unité est une unité de cond. -->  Calcul coef.conv. UC-US #
#                     UC-US = UC-UV (ITU) * UV-US (ITM)                         #
#-------------------------------------------------------------------------------#
If [F:ITU]ITMREF <> ART | [F:ITU]BPCNUM <> CLI
    Read [ITU] ITU0=ART;CLI
    If fstat Raz [F:ITU] : Endif
Endif
Gosub CTR_ITUCOEF     : # init. données ITU utilisées comme diviseurs     
Case SAUORI
     When [F:ITU]SAU  : COEF  = [F:ITU]SAUSTUCOE
     When [F:ITU]PCU1 : COEF  = [F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE
     When [F:ITU]PCU2 : COEF  = [F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE
     When Default
Endcase
If COEF <> 0 End : Endif

#-------------------------------------------------------------------------------#
#                Si l'unité est une unité de cond. ITM                          #
#                -->  Récup. coef.conversion UC-US                              #
#-------------------------------------------------------------------------------#
Local Integer K
For K=0 To dim([F:ITM]PCU)-1
   If SAUORI=[F:ITM]PCU(K)
      COEF=[F:ITM]PCUSTUCOE(K)
      Break
   Endif
Next K
If COEF <> 0 End : Endif

#-------------------------------------------------------------------------------#
# Lecture TCO  : -->  Récup. coef.conversion                                    #
#-------------------------------------------------------------------------------#
If [TCO]UOM1<>SAUORI | [TCO]UOM2<>SAUDST      : # Optimisation
  Read [TCO]TCO0=SAUORI;SAUDST
  If fstat Raz [F:TCO] Endif                  : # Optimisation
Endif                                         : # Optimisation
If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
#If fstat = 0 COEF = [F:TCO]COEUOM : Endif    : # Optimisation
COEF = [F:TCO]COEUOM                          : # Optimisation
End

$CTR_ITMCOEF
Local Integer K
If [F:ITM]SAUSTUCOE=0 : [F:ITM]SAUSTUCOE=1 : Endif
For K=0 To dim([F:ITM]PCU)-1
   If vireblc([F:ITM]PCU(K),2)<>"" & [F:ITM]PCUSTUCOE(K)=0
      [F:ITM]PCUSTUCOE(K)=1
   Endif
Next K
Return
$CTR_ITUCOEF
If [F:ITU]SAUSTUCOE=0  : [F:ITU]SAUSTUCOE=1  : Endif
If [F:ITU]PCUSAUCOE1=0 : [F:ITU]PCUSAUCOE1=1 : Endif
If [F:ITU]PCUSAUCOE2=0 : [F:ITU]PCUSAUCOE2=1 : Endif
Return



#################################################################################
#    Moulinette Après mise à jour concernant le module Vente                    #
#    ---> Concerne les transactions                                             #
#################################################################################

Subprog VENMAJTXN14

Local Char WDOSSIER 

WDOSSIER=[F:ADS]DOSSIER

Local Shortint INDIC
Local Integer  I

Local File =WDOSSIER+".SALTRS"   [SLT]

#-------------------------------------------------------------------------------#
# Initialisation transactions ventes pour les nouvelles zones                   #
#-------------------------------------------------------------------------------#
Call ECR_TIME("DOSMAJ14 Sales Transactions Process : Update SALTRS") From DOSSUB

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 1 ") From DOSSUB
Gosub TXNDEV

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 2 ") From DOSSUB
Gosub TXNCDE

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 3 ") From DOSSUB
Gosub TXNOUV

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 4 ") From DOSSUB
Gosub TXNLIV

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 5 ") From DOSSUB
Gosub TXNFAC

Call ECR_TIME("DOSMAJ14 Sales Transactions Process : --- Step 6 ") From DOSSUB
Gosub TXNRET

Close Local File [SLT]

End


#-------------------------------------------------------------------------------#
# Transaction pour les devis                                                    #
#-------------------------------------------------------------------------------#
$TXNDEV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=1
    Raz INDIC
    If !find([F:SLT]SAUCOECOD,1,2,3)  INDIC=1 : [F:SLT]SAUCOECOD = 1 : Endif
    If !find([F:SLT]STUCOD,1,2)       INDIC=1 : [F:SLT]STUCOD = 2 : Endif
    If [F:SLT]SAUCOECOD<>0  & [F:SLT]SAUCOESCR=0  :INDIC=1 :[F:SLT]SAUCOESCR=1 : Endif
    If [F:SLT]STUCOD<>0     & [F:SLT]STUSCR=0     :INDIC=1 :[F:SLT]STUSCR=1    : Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TXNCDE
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=2
    Raz INDIC
    If !find([F:SLT]CCLRENCOD,1,2)    INDIC=1 : [F:SLT]CCLRENCOD = 2 :    Endif
    If !find([F:SLT]BETCPYCOD,1,2)    INDIC=1 : [F:SLT]BETCPYCOD = 2 :    Endif
    If !find([F:SLT]SAUCOECOD,1,2,3)  INDIC=1 : [F:SLT]SAUCOECOD = 1 : Endif
    If !find([F:SLT]STUCOD,1,2)       INDIC=1 : [F:SLT]STUCOD = 2 : Endif
    If !find([F:SLT]ALLTYPCODD,1,2,3) INDIC=1 : [F:SLT]ALLTYPCODD = 3 : Endif
    If !find([F:SLT]CCLRENCODD,1,2)   INDIC=1 : [F:SLT]CCLRENCODD = 2 : Endif
    If [F:SLT]SAUCOECOD<>0  & [F:SLT]SAUCOESCR=0  :INDIC=1 :[F:SLT]SAUCOESCR=1  : Endif
    If [F:SLT]STUCOD<>0     & [F:SLT]STUSCR=0     :INDIC=1 :[F:SLT]STUSCR=1     : Endif
    If [F:SLT]ALLTYPCODD<>0 & [F:SLT]ALLTYPSCRD=0 :INDIC=1 :[F:SLT]ALLTYPSCRD=1 : Endif
    If [F:SLT]CCLRENCODD<>0 & [F:SLT]CCLRENSCRD=0 :INDIC=1 :[F:SLT]CCLRENSCRD=1 : Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes ouvertes                                       #
#-------------------------------------------------------------------------------#
$TXNOUV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=3
    Raz INDIC
    If !find([F:SLT]BETCPYCOD,1,2)    INDIC=1 : [F:SLT]BETCPYCOD = 2 :    Endif
    If !find([F:SLT]BETFCYCOD,1,2)    INDIC=1 : [F:SLT]BETFCYCOD = 2 :    Endif
    If !find([F:SLT]SAUCOD,1,2,3)     INDIC=1 : [F:SLT]SAUCOD = 1 : Endif
    If !find([F:SLT]SAUCOECOD,1,2,3)  INDIC=1 : [F:SLT]SAUCOECOD = 1 : Endif
    If !find([F:SLT]STUCOD,1,2)       INDIC=1 : [F:SLT]STUCOD = 2 : Endif
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les livraisons                                               #
#-------------------------------------------------------------------------------#
$TXNLIV
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=4
    If !find([F:SLT]BETCPYCOD,1,2)    : [F:SLT]BETCPYCOD = 2 : Endif
    If !find([F:SLT]SAUCOECOD,1,2,3)  : [F:SLT]SAUCOECOD = 1 : Endif
    If !find([F:SLT]STUCOD,1,2)       : [F:SLT]STUCOD = 2    : Endif
    If !find([F:SLT]MFGNUMCOD,1,2)    : [F:SLT]MFGNUMCOD = 1 : Endif
    If [F:SLT]SAUCOECOD<>0  & [F:SLT]SAUCOESCR=0  :[F:SLT]SAUCOESCR=1 : Endif
    If [F:SLT]STUCOD<>0     & [F:SLT]STUSCR=0     :[F:SLT]STUSCR=1    : Endif
    If [F:SLT]MFGNUMCOD<>0  & [F:SLT]MFGNUMSCR=0  :[F:SLT]MFGNUMSCR=1 : Endif
    [F:SLT]CCECODS=3

    #--- Bug 39886
    If !find([F:SLT]LOTCOD,1,2,3)    [F:SLT]LOTCOD=3    : [F:SLT]LOTSCR=1    Endif
    If !find([F:SLT]SLOCOD,1,2,3)    [F:SLT]SLOCOD=3    : [F:SLT]SLOSCR=1    Endif
    If !find([F:SLT]AQRCOD,1,2,3)    [F:SLT]AQRCOD=3    : [F:SLT]AQRSCR=1    Endif
    If !find([F:SLT]LOCCOD,1,2,3)    [F:SLT]LOCCOD=3    : [F:SLT]LOCSCR=1    Endif
    If !find([F:SLT]SERCOD,1,2,3)    [F:SLT]SERCOD=3    : [F:SLT]SERSCR=1    Endif
    If !find([F:SLT]SERECOD,1,2,3)   [F:SLT]SERECOD=3   : [F:SLT]SERESCR=1   Endif
    If !find([F:SLT]MVTDESCOD,1,2,3) [F:SLT]MVTDESCOD=3 : [F:SLT]MVTDESSCR=1 Endif
    #---

    Rewrite [SLT]
    If fstat
       Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures                                                 #
#-------------------------------------------------------------------------------#
$TXNFAC
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=5
    Raz INDIC
    If [F:SLT]INVTYP<>2               INDIC=1 : [F:SLT]CCECODS = 3   : Endif
    If !find([F:SLT]PIHNUMCOD,1,2)    INDIC=1 : [F:SLT]PIHNUMCOD = 1 : Endif
    If !find([F:SLT]BETCPYCOD,1,2)    INDIC=1 : [F:SLT]BETCPYCOD = 2 : Endif
    If !find([F:SLT]SAUCOECOD,1,2,3)  INDIC=1 : [F:SLT]SAUCOECOD = 1 : Endif
    If !find([F:SLT]STUCOD,1,2)       INDIC=1 : [F:SLT]STUCOD = 2    : Endif
    If [F:SLT]SAUCOECOD<>0  & [F:SLT]SAUCOESCR=0  :INDIC=1 :[F:SLT]SAUCOESCR=1 : Endif
    If [F:SLT]STUCOD<>0     & [F:SLT]STUSCR=0     :INDIC=1 :[F:SLT]STUSCR=1    : Endif

    If [F:SLT]INVTYP=2 Gosub TXNSTOCK Endif

    #--- Bug 39886
    If find([F:SLT]INVTYP,1,3,4)
        If !find([F:SLT]LOTCOD,1,2,3)    [F:SLT]LOTCOD=3    : [F:SLT]LOTSCR=1    : INDIC=1 Endif
        If !find([F:SLT]SLOCOD,1,2,3)    [F:SLT]SLOCOD=3    : [F:SLT]SLOSCR=1    : INDIC=1 Endif
        If !find([F:SLT]AQRCOD,1,2,3)    [F:SLT]AQRCOD=3    : [F:SLT]AQRSCR=1    : INDIC=1 Endif
        If !find([F:SLT]LOCCOD,1,2,3)    [F:SLT]LOCCOD=3    : [F:SLT]LOCSCR=1    : INDIC=1 Endif
        If !find([F:SLT]SERCOD,1,2,3)    [F:SLT]SERCOD=3    : [F:SLT]SERSCR=1    : INDIC=1 Endif
        If !find([F:SLT]SERECOD,1,2,3)   [F:SLT]SERECOD=3   : [F:SLT]SERESCR=1   : INDIC=1 Endif
        If !find([F:SLT]MVTDESCOD,1,2,3) [F:SLT]MVTDESCOD=3 : [F:SLT]MVTDESSCR=1 : INDIC=1 Endif
    Endif
    #---

    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les retours                                                  #
#-------------------------------------------------------------------------------#
$TXNRET
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=6
    Raz INDIC
#   Init nouveaux champs vente
#   Champs saisissables
    If !find([F:SLT]BPCINVCOD,1,2,3)  INDIC=1 : [F:SLT]BPCINVCOD = 1    : Endif
    If !find([F:SLT]DATSELCOD,1,2,3)  INDIC=1 : [F:SLT]DATSELCOD = 1    : Endif
    If !find([F:SLT]ITMSELCOD,1,2,3)  INDIC=1 : [F:SLT]ITMSELCOD = 1    : Endif
    If !find([F:SLT]EXTRTNCOD,1,2,3)  INDIC=1 : [F:SLT]EXTRTNCOD = 1    : Endif
    If !find([F:SLT]ITMDESCOD,1,2,3)  INDIC=1 : [F:SLT]ITMDESCOD = 1    : Endif
    If !find([F:SLT]ITMDES1COD,1,2,3) INDIC=1 : [F:SLT]ITMDES1COD = 1   : Endif
    If !find([F:SLT]RTNRENCOD,1,2,3)  INDIC=1 : [F:SLT]RTNRENCOD = 1    : Endif
    If !find([F:SLT]RTNDATCODD,1,2,3) INDIC=1 : [F:SLT]RTNDATCODD= 1    : Endif
    If !find([F:SLT]CNOFLGCOD,1,2,3)  INDIC=1 : [F:SLT]CNOFLGCOD = 1    : Endif
#   Champs affichés
    If !find([F:SLT]BETFCYCOD,1,2)    INDIC=1 : [F:SLT]BETFCYCOD = 2    : Endif
    If !find([F:SLT]BETCPYCOD,1,2)    INDIC=1 : [F:SLT]BETCPYCOD = 2    : Endif
    If !find([F:SLT]DLVQTYCOD,1,2)    INDIC=1 : [F:SLT]DLVQTYCOD = 2    : Endif
    If !find([F:SLT]NETPRICOD,1,2)    INDIC=1 : [F:SLT]NETPRICOD = 2    : Endif
    If !find([F:SLT]INVUPDCOD,1,2)    INDIC=1 : [F:SLT]INVUPDCOD = 2    : Endif
    If !find([F:SLT]DLVNUMCOD,1,2)    INDIC=1 : [F:SLT]DLVNUMCOD = 2    : Endif
    If !find([F:SLT]PNHNUMCOD,1,2)    INDIC=1 : [F:SLT]PNHNUMCOD = 2    : Endif
#   Champs saisissables
    If [F:SLT]ITMDESCOD<>0  & [F:SLT]ITMDESSCR=0  :INDIC=1 :[F:SLT]ITMDESSCR=1   : Endif
    If [F:SLT]ITMDES1COD<>0 & [F:SLT]ITMDES1SCR=0 :INDIC=1 :[F:SLT]ITMDES1SCR=1  : Endif
    If [F:SLT]RTNRENCOD<>0  & [F:SLT]RTNRENSCR=0  :INDIC=1 :[F:SLT]RTNRENSCR=1   : Endif
    If [F:SLT]RTNDATCODD<>0 & [F:SLT]RTNDATSCRD=0 :INDIC=1 :[F:SLT]RTNDATSCRD=1  : Endif
    If [F:SLT]CNOFLGCOD<>0  & [F:SLT]CNOFLGSCR=0  :INDIC=1 :[F:SLT]CNOFLGSCR=1   : Endif
#   Champs affichés
    If [F:SLT]DLVQTYCOD<>0 & [F:SLT]DLVQTYSCR=0   :INDIC=1 :[F:SLT]DLVQTYSCR=1   : Endif
    If [F:SLT]NETPRICOD<>0 & [F:SLT]NETPRISCR=0   :INDIC=1 :[F:SLT]NETPRISCR=1   : Endif
    If [F:SLT]INVUPDCOD<>0 & [F:SLT]INVUPDSCR=0   :INDIC=1 :[F:SLT]INVUPDSCR=1   : Endif
    If [F:SLT]DLVNUMCOD<>0 & [F:SLT]DLVNUMSCR=0   :INDIC=1 :[F:SLT]DLVNUMSCR=1   : Endif 
    If [F:SLT]PNHNUMCOD<>0 & [F:SLT]PNHNUMSCR=0   :INDIC=1 :[F:SLT]PNHNUMSCR=1   : Endif 

    Gosub TXNSTOCK

    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

$TXNSTOCK
#   Init nouveaux champs stock : STOETR2
#    If [F:SLT]SRGWAIFLG=0  [F:SLT]SRGWAIFLG=1  : Endif   : # A quai  (non)

#   Bloc document
    If [F:SLT]UOMSAIFLG=0 [F:SLT]UOMSAIFLG=2 : Endif                         : # Saisie UC     (saisie)
    If !find([F:SLT]BPSLOTCOD,1,2,3) INDIC=1 : [F:SLT]BPSLOTCOD=1 : Endif    : # Num.lot.fourn (saisie)
    If [F:SLT]BPSLOTCOD<>0  & [F:SLT]BPSLOTSCR=0 INDIC=1 : [F:SLT]BPSLOTSCR=1  : Endif
    If !find([F:SLT]LOTCOD,1,2,3)    INDIC=1 : [F:SLT]LOTCOD=1 : Endif       : # Num.lot       (saisie)
    If [F:SLT]LOTCOD<>0  & [F:SLT]LOTSCR=0 INDIC=1 : [F:SLT]LOTSCR=1  : Endif
    If !find([F:SLT]SLOCOD,1,2,3)    INDIC=1 : [F:SLT]SLOCOD=3 : Endif       : # Num.sous-lot  (invisible)
    If [F:SLT]SLOCOD<>0  & [F:SLT]SLOSCR=0 INDIC=1 : [F:SLT]SLOSCR=1  : Endif
    If [F:SLT]NBSLOFLG=0  [F:SLT]NBSLOFLG=1 : Endif                          : # Nbr s-lot     (invisible)
    If !find([F:SLT]AQRCOD,1,2,3)    INDIC=1 : [F:SLT]AQRCOD=3 : Endif       : # Statut        (invisible)
    If [F:SLT]AQRCOD<>0  & [F:SLT]AQRSCR=0 INDIC=1 : [F:SLT]AQRSCR=1  : Endif
    If !find([F:SLT]LOCCOD,1,2,3)    INDIC=1 : [F:SLT]LOCCOD=3 : Endif       : # Emplacement   (invisible)
    If [F:SLT]LOCCOD<>0  & [F:SLT]LOCSCR=0 INDIC=1 : [F:SLT]LOCSCR=1  : Endif
    If !find([F:SLT]SERCOD,1,2,3)    INDIC=1 : [F:SLT]SERCOD=3    : Endif    : # Num série     (invisible)
    If [F:SLT]SERCOD<>0  & [F:SLT]SERSCR=0 INDIC=1 : [F:SLT]SERSCR=1  : Endif
    If !find([F:SLT]SERECOD,1,2)     INDIC=1 : [F:SLT]SERECOD=2   : Endif    : # Num série     (invisible)
    If [F:SLT]SERECOD<>0 & [F:SLT]SERESCR=0 INDIC=1 : [F:SLT]SERESCR=1  : Endif
    If !find([F:SLT]MVTPRICOD,1,2,3) INDIC=1 : [F:SLT]MVTPRICOD=3 : Endif    : # Prix          (invisible)
    If [F:SLT]MVTPRICOD<>0  & [F:SLT]MVTPRISCR=0 INDIC=1 : [F:SLT]MVTPRISCR=1  : Endif
    If !find([F:SLT]MVTDESCOD,1,2,3) INDIC=1 : [F:SLT]MVTDESCOD=3 : Endif    : # Dési.mvt      (invisible)
    If [F:SLT]MVTDESCOD<>0  & [F:SLT]MVTDESSCR=0 INDIC=1 : [F:SLT]MVTDESSCR=1  : Endif
#   Bloc détail
    If [F:SLT]UOMSAIFLG1=0 [F:SLT]UOMSAIFLG1=1 : Endif                       : # Saisie UC     (non)
    If !find([F:SLT]BPSLOTCOD1,1,2,3)  INDIC=1 : [F:SLT]BPSLOTCOD1=1 : Endif : # Num.lot.fourn (saisie)
    If [F:SLT]BPSLOTCOD1<>0  & [F:SLT]BPSLOTSCR1=0 INDIC=1 : [F:SLT]BPSLOTSCR1=1  : Endif
    If !find([F:SLT]IDECOD1,1,2,3)     INDIC=1 : [F:SLT]IDECOD1=3 : Endif    : # Identifiant 1 (invisible)
    If [F:SLT]IDECOD1<>0  & [F:SLT]IDESCR1=0 INDIC=1 : [F:SLT]IDESCR1=1  : Endif
    If !find([F:SLT]IDECOD2,1,2,3)     INDIC=1 : [F:SLT]IDECOD2=3 : Endif    : # Identifiant 2 (invisible)
    If [F:SLT]IDECOD2<>0  & [F:SLT]IDESCR2=0 INDIC=1 : [F:SLT]IDESCR2=1  : Endif
    If !find([F:SLT]PRNCOD1,1,2,3,4,5) INDIC=1 : [F:SLT]PRNCOD1=1 : Endif    : # Impression    (pas impre)
    If [F:SLT]PRNSCR1=0   INDIC=1 : [F:SLT]PRNSCR1=1  : Endif
    If [F:SLT]PRNNBFLG1=0 INDIC=1 : [F:SLT]PRNNBFLG1=1 : Endif               : # Nbr document  (non)
    If [F:SLT]PRNNBFLG1<>0 & [F:SLT]PRNNBSCR1=0 INDIC=1 : [F:SLT]PRNNBSCR1=1 : Endif
    If !find([F:SLT]MVTPRICOD1,1,2,3)  INDIC=1 : [F:SLT]MVTPRICOD1=2 : Endif : # Prix          (invisible)
    If !find([F:SLT]SERECOD1,1,2)      INDIC=1 : [F:SLT]SERECOD1=2 : Endif   : # Num série     (invisible)
    If [F:SLT]SERECOD1<>0 & [F:SLT]SERESCR1=0 INDIC=1 : [F:SLT]SERESCR1=1  : Endif
    If !find([F:SLT]MVTDESCOD1,1,2,3)  INDIC=1 : [F:SLT]MVTDESCOD1=3 : Endif : # Dési.mvt     (invisible)
    If !find([F:SLT]AVSTOCOD1,1,2)     INDIC=1 : [F:SLT]AVSTOCOD1=2  : Endif : # Stock dispo  (invisible)
    If [F:SLT]AVSTOCOD1<>0 & [F:SLT]AVSTOSCR1=0 INDIC=1 : [F:SLT]AVSTOSCR1=1  : Endif
    If !find([F:SLT]SPERFLG,1,2)       INDIC=1 : [F:SLT]SPERFLG=2  : Endif   : # Péremption   (oui) 
    If !find([F:SLT]SPOTFLG,1,2)       INDIC=1 : [F:SLT]SPOTFLG=2  : Endif   : # Titre        (oui)
    If !find([F:SLT]SRUB1FLG,1,2)      INDIC=1 : [F:SLT]SRUB1FLG=1 : Endif   : # Rub 1        (non)
    If !find([F:SLT]SRUB2FLG,1,2)      INDIC=1 : [F:SLT]SRUB2FLG=1 : Endif   : # Rub 2        (non)
    If !find([F:SLT]SRUB3FLG,1,2)      INDIC=1 : [F:SLT]SRUB3FLG=1 : Endif   : # Rub 3        (non)
    If !find([F:SLT]SRUB4FLG,1,2)      INDIC=1 : [F:SLT]SRUB4FLG=1 : Endif   : # Rub 4        (non)
    If !find([F:SLT]CCECODS,1,2,3)     INDIC=1 : [F:SLT]CCECODS=1  : Endif
Return


