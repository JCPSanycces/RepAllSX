#<AdxTL>@(#)2.0.0.0 $Revision$ Exécution ordre système
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = "cat "+adxdir+"/adxvolumes"
#GBIDC1 = 'grep Instance /produits/v160/SOLSUPV6/dossiers/SUPERV/TRT/ASYR*.src'
Call SYSTEME(GBIDC1)
End

Subprog SYSTEME(ORDRE)
Value Char ORDRE()
Local Char PARAM(250)(1..1) , VALEUR(10)
PARAM(1) = ORDRE
Call TRAITE_CHAR(VALEUR,PARAM,"","EXESYS","EXESYS",3,"XYEXESYS") From GTRAITE
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "INIT_DIA"    : Gosub INIT_DIA
Endcase
Return

#-----------------------------#
$INIT
Gosub OUVRE
Gosub PARAM
Return

$PARAM
ORDRE = PARAM(1)
Return

$OUVRE
#109413
If !(dim([S]ADXORIGINALUSER)>0 & [S]ADXORIGINALUSER="admin" & adxusr="admin")
 #102739
 If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE
  GMESSAGE=mess(74,100,1)
  GERR=1
  Return
 Endif
Endif
Local Char    ORDRE(250) , MOTIF(GLONADI)
Local Integer OK , ERCODE
Local Char    ORDSYS(250)(1..2)
Local Char    MACHINE(GDIMFIC)
If !GSERVEUR & func AFNC.PARAMUTIL("ASIGMNT","","")="2"
 Local Char VALSIG(10) , PARSIG(30)(1..2)
 PARSIG(1) = nomap
 Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
 If mkstat : FIN = 1 : Return : Endif
 MOTIF  = PARSIG(2)
Endif
If PARAM(1)<>"" & !GSERVEUR
# BCRIT = ""
Endif
Return

#-----------------------------#
$INIT_DIA
#102739
If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE
 GMESSAGE=mess(74,100,1)
 GERR=1
 Return
Endif
Raz [M]
Gosub PARAM
[M]ORDSYS = [L]ORDRE
[M]MOTIF = [L]MOTIF
Return

#-----------------------------#
$OUVRE_BATCH
Gosub OUVRE
Gosub PARAM
Return

#-----------------------------#
$CONT_BATCH
ORDRE = [M]ORDSYS
Call MACHINE(ORDRE,MACHINE,ORDSYS(1)) From ORDSYS
If ORDSYS(1)=""
 FIN = 1 : Return
Elsif (GBROWS and !GADXLOC) & MACHINE="#"
 Call ERREUR(mess(85,150,1)) From GESECRAN : # Fonction non disponible en mode web
 FIN = 1 : Return
Endif
Return

#-----------------------------#
$CONTROLE
If ORDRE="" or GSERVEUR
 ORDRE = [M]ORDSYS
Endif
Call MACHINE(ORDRE,MACHINE,ORDSYS(1)) From ORDSYS
If ORDSYS(1)= ""
 FIN = 1 : Return
Elsif (GBROWS and !GADXLOC) & MACHINE="#"
 Call ERREUR(mess(85,150,1)) From GESECRAN : # Fonction non disponible en mode web
 If BCRIT<>"" : SAI = 1 : Return : Else : FIN = 1 : Return : Endif
Endif
Return

#-----------------------------#
$EXEC
# Espionnage des ordres systèmes
Call TRACE_ORDRE(MOTIF,ORDSYS(1)) From ESPION
If !GSERVEUR
 Call OUVRE_TRACE(ORDRE) From LECFIC
Else
 Call ECR_TRACE("exec"-ORDRE,0) From GESECRAN
Endif
ORDSYS(2) = filpath("TRA",GTRACE,"tra")
Call SYSTEME(MACHINE,ORDSYS,"",ERCODE) From ORDSYS
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return

#-----------------------------#
$TERMINE
If ORDRE=""
 If BCRIT<>"" : SAI = 1 : Else : FIN = 1 : Endif
Endif
Return

#-------------------------------------------------------------#
Subprog AS_ORDSYS(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ORDSYS(VALEUR)
Variable Char    VALEUR()
End

