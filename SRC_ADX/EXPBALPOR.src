#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXPBALPOR","EXPBALPOR",3,"") From GTRAITE
End

# Gestion du masque EXPBALPOR
$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return
################################################

$INIT
If clalev([GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([PER])=0 : Local File PERIOD     [PER] : Endif

Local Mask EXPBALPOR [DIA]

Local Char    SAVIRS(2), SAVIFS(2)
Local Char    REP(80)
Local Char    PLAN(GLONCOA)
Local Char    DESIG(GLONAX3)
Local Char    SOLDEBC(20), SOLCREC(20)
Local Char    CUMDEBC(30), CUMCREC(30)
Local Char    NAM(GDIMFIC), FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), CRITSPE(250)
Local Integer ETABOU(1..GNBBOU), REPLY, OK, IND, I
Local Decimal PERD, PERF, EXED, EXEF
Local Decimal BALDEB, BALCRE, SOLDEB, SOLCRE
Local Decimal CUMDEB, CUMCRE

# Variables pour Poste Client
Local Char    FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT

############################################################################
## Options d'export
############################################################################
SEPCHP = chr$(59)                               : # Séparateur de champ (;)
SEPENR = chr$(13)+chr$(10)                      : # Séparateur de ligne (CR+LF)
NAM    = "[M:DIA]CPY+num$(year([M:DIA]PERDEB))" : # Nom du fichier
EXT    = "bal"                                  : # Extension du fichier

TRA = 1
TMP = 1
Raz [M:DIA]
Local Char NOMFIC(GDIMFIC)
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 Call PARAM("","EXPBALPOR",NOMFIC) From ADOVAL
 If NOMFIC<>"" & left$(NOMFIC,1)="["
  [M]VOLFIL = NOMFIC
 Else
  [M]VOLFIL = "[TMP]"
 Endif
Endif
Actzo [M]VOLFIL
Return

##############################################
$EXEC
adxirs=SEPENR
adxifs=SEPCHP

FICHIER = [M:DIA]FIC
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = evalue(NAM)

If [M]TYPEXP=1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
 If filinfo(FICDON,7)>0
  ## Fichier existant, souhaitez-vous l'écraser ?
  Call OUINON(mess(127,105,1), OK) From GESECRAN
  If OK=1 : Return : Endif
 Endif
Endif

Openo FICDON,0
Openo

## Exportation balance Portugal
Call OUVRE_TRACE(mess(106,107,1)-mess(7,201,1)) From LECFIC

Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]PERDEB,EXED,PERD) From CPTSUB
Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]PERFIN,EXEF,PERF) From CPTSUB
If PERD=1 : PERD=0 : Endif

Call LECPLAN([M:DIA]CPY,[M:DIA]LEDTYP,PLAN) From CPTDIV

Filter [BAL] Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP & CUR=[M:DIA]CUR & FCY="" & FIY=EXED

Call ECR_TRACE(mess(2,116,1)-[M:DIA]CPY,0) From GESECRAN : # Société
Local Integer I,J : I=J=0
For [GAC]GAC0 Where COA=[L]PLAN
 I=I+1
 Raz SOLDEB , SOLCRE
 Gosub BALAN
 Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 If SOLDEB<>0 | SOLCRE<>0
  Openo FICDON,-1
  Wrseq [F:GAC]ACC;
  Wrseq DESIG;
  Wrseq SOLDEBC;
  Wrseq SOLCREC
  CUMDEB+=val(SOLDEBC)
  CUMCRE+=val(SOLCREC)
  Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[L]DESIG+")",0) From GESECRAN : # Compte
  Call ECR_TRACE(mess(148,111,1)-SOLDEBC-"et"-SOLCREC,0)         From GESECRAN : # Soldes
 Endif
Next

Openo
If [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : TRA=0
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : TRA=0
 Endif
Endif

Call FERME_TRACE From LECFIC

adxifs = ""
adxirs = chr$(10)
Return

$BALAN
For [BAL]BAL0 Where CPY=[M:DIA]CPY & ACC=[F:GAC]ACC
 J=J+1
 If ([F:GAC]SAC=2 & [F:BAL]BPR="") : Goto SKIP : Endif
 BALDEB=sum([F:BAL]DEB(PERD..PERF))
 BALCRE=sum([F:BAL]CDT(PERD..PERF))
 If BALDEB>BALCRE
  SOLDEB += (BALDEB-BALCRE)
 Elsif BALCRE>BALDEB
  SOLCRE += (BALCRE-BALDEB)
 Endif
$SKIP
Next
If SOLDEB-int(SOLDEB)<>0
 SOLDEBC=num$(int(SOLDEB))+","+num$((SOLDEB-int(SOLDEB))*100)
Else
 SOLDEBC=num$(SOLDEB)
Endif
If SOLCRE-int(SOLCRE)<>0
 SOLCREC=num$(int(SOLCRE))+","+num$((SOLCRE-int(SOLCRE))*100)
Else
 SOLCREC=num$(SOLCRE)
Endif
Return


######################################################################################
## Etiquettes écran EXPBALPOR
######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG<>2
  # Attention, société non juridique.
  Call MESSAGE(mess(182,107,1)) From GESECRAN
  mkstat=0
 Endif
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=1 : # Référentiels flagués 'Général'
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
#Vérifications de cohérence entre sociétés dans le cas d'un groupe de société
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>2
 Local Char CODLED(GLONLED),DEVLED(GLONCUR),MESSA(250)
 Local Char PLAN
 Local Integer STAT
 Call CNTCOHDEV([M]CPY,VALEUR,CODLED,DEVLED,STAT,MESSA) From CPTCNT
 If !STAT
   Call MESSAGE([L]MESSA) From GESECRAN
   zonsui = "[M]CPY"
   mkstat = 0 : End
 Endif
 Call CNTCOHCOA([M]CPY,VALEUR,PLAN,STAT,MESSA) From CPTCNT
 If !STAT
   Call MESSAGE([L]MESSA) From GESECRAN
   zonsui = "[M]CPY"
   mkstat = 0 : End
 Endif
Endif
#----- Fin Vérif cohérence -----
End

Subprog C_PERDEB(VALEUR)
Variable Date    VALEUR
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Local Decimal EXERCICE , PERIODE
 Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EXERCICE,PERIODE) From CPTSUB
 If EXERCICE=0 or PERIODE=0
  GMESSAGE = mess(1,104,1) : # Date incorrecte
  mkstat = 2 : End
 Else
  VALEUR = [F:PER]PERSTR
 Endif
Endif
End

Subprog C_PERFIN(VALEUR)
Variable Date    VALEUR
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Local Decimal EXERCICE , PERIODE
 Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EXERCICE,PERIODE) From CPTSUB
 If EXERCICE=0 or PERIODE=0
  # Date incorrecte
  GMESSAGE = mess(1,104,1)
  mkstat = 2 : End
 Else
  VALEUR = [F:PER]PEREND
 Endif
Else
 Local Integer STAT
 Local Char MESSA(250)
 #Vérif cohérence période
 Call CNTCOHPER([M]CPY,[M]LEDTYP,[M]PERDEB,VALEUR,STAT,MESSA) From CPTCNT
 If !STAT
  # Périodes incompatibles entre les sociétés du groupe
  Call MESSAGE(MESSA) From GESECRAN
  zonsui = "[M]CPY"
  mkstat = 0 : End
 Endif
Endif
End

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Actzo [M]VOLFIL
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 # Le poste client est inaccessible en batch
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End
