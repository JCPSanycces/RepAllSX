#<AdxTL>@(#)1.0.0.0 $Revision$
Call IMPORTATION("OIRCPREV") From GIMPOBJ
End

################################################################################
$ACTION
Case [M:DIA]MODIMP
When "OASSEDIC"
 Case [L]ACTION
  When "IMP_OUVRE"    : If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif
  When "IMP_ZONE"     : Gosub IMP_ZONE_ASS
 Endcase
#-------------------------------------------------------------------------------
When "OURSSAF"
 Case [L]ACTION
  When "IMP_OUVRE"    : If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif
  When "IMP_ZONE"     : Gosub IMP_ZONE_URS
 Endcase
#-------------------------------------------------------------------------------
When "OIRCPREV"
 Case [L]ACTION
  When "IMP_OUVRE"    : Gosub IMP_OUVRE_RET
  When "IMP_FERME"    : Gosub IMP_FERME_RET
  When "IMPORT"       : [F:ARM2]CLEA3=[V]GIMP(3) : [F:ARM2]CLEA4=[V]GIMP(4)
  When "IMP_ZONE"     : Gosub IMP_ZONE_RET
  When "IMP_CREATION" : Gosub IMP_CREATION_RET
  When "IMP_MODIF"    : Gosub IMP_MODIF_RET
 Endcase
Endcase
Return

################################################################################
$IMP_ZONE_ASS
[L]IMPMOD=1
Case [L]IMPZON
When "COD"
 If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif

 [M]COD=vireblc(format$("K:"+num$([V]GLONORG)+"c","ASS_"+func FORMATC([V]GIMP(1))),1)

 If len([M]COD)<5 : fstat=0 : Else Read [ORG2]ORG0=GCURLEG;[M]COD : Endif
 If !fstat
  Filter [ORG2] Where left$(COD,4)="ASS_" Order By Key CLE=COD Desc
  Read [ORG2] First
  Filter [ORG2]
  If fstat : I=1 : Else I=1+val(right$([F:ORG2]COD,5)) : Endif
  [M]COD="ASS_"+format$("N0:"+num$([V]GLONORG-4)+"#",I)
 Endif

When "ADD1"
 [M]ADD1  =[F:ORG]ADD(0)
When "ADD2"
 [M]ADD2  =[F:ORG]ADD(1)
When "TYP"
 [M]TYP   =3 : # Caisse
When "KEYORG"
 [M]KEYORG=1 : # Siret
When "TYPIRC"
 [M]TYPIRC=2 : # Assédic
When "TYPASS"
 [M]TYPASS=1 : # Assédic
When Default
 [L]IMPMOD=0
Endcase
Return

################################################################################
$IMP_ZONE_URS
[L]IMPMOD=1
Case [L]IMPZON
When "COD"
 If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif

 [M]COD=vireblc(format$("K:"+num$([V]GLONORG)+"c",func FORMATC([V]GIMP(1))),1)

 If [M]COD="" : fstat=0 : Else Read [ORG2]ORG0=GCURLEG;[M]COD : Endif
 If !fstat
  Filter [ORG2] Where left$(COD,4)="URS_" Order By Key CLE=COD Desc
  Read [ORG2] First
  Filter [ORG2]
  If fstat : I=1 : Else I=1+val(right$([F:ORG2]COD,5)) : Endif
  [M]COD="URS_"+format$("N0:"+num$([V]GLONORG-4)+"#",I)
 Endif

When "ADD1"
 [M]ADD1  =[F:ORG]ADD(0)
When "ADD2"
 [M]ADD2  =[F:ORG]ADD(1)
When "TYP"
 [M]TYP   =3 : # Caisse
When "KEYORG"
 [M]KEYORG=1 : # Siret
When "TYPIRC"
 [M]TYPIRC=1 : # Urssaf
When Default
 [L]IMPMOD=0
Endcase
Return

################################################################################
$IMP_OUVRE_RET
If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif
If !clalev([F:ADI])  : Local File ATABDIV   [ADI]  : Endif
If !clalev([F:ARM])  : Local File AREPORTM  [ARM]  : Endif
If !clalev([F:ARM2]) : Local File AREPORTM  [ARM2] : Endif
If !clalev([F:AES])  : Local File AESPION   [AES]  : Endif

[F:ARM2]NUMREQ=uniqid([AES])
Return

#-------------------------------------------------------------------------------
$IMP_FERME_RET
Trbegin [ARM]
 Delete [ARM] Where NUMREQ=[F:ARM2]NUMREQ
Commit
Return

#-------------------------------------------------------------------------------
$IMP_ZONE_RET
[L]IMPMOD=1
Case [L]IMPZON
When "COD"
 If !clalev([F:ORG2]) : Local File ORGANISME [ORG2] : Endif

 [M]COD=vireblc(format$("K:"+num$([V]GLONORG)+"c",func FORMATC([V]GIMP(1))),1)

 If [M]COD="" : fstat=0 : Else Read [ORG2]ORG0=GCURLEG;[M]COD : Endif
 If !fstat
  Filter [ORG2] Where left$(COD,4)="RET_" Order By Key CLE=COD Desc
  Read [ORG2] First
  Filter [ORG2]
  If fstat : I=1 : Else I=1+val(right$([F:ORG2]COD,5)) : Endif
  [M]COD="RET_"+format$("N0:"+num$([V]GLONORG-4)+"#",I)
 Endif

When "ADD1"
 [M]ADD1  =[F:ORG]ADD(0)
When "ADD2"
 [M]ADD2  =[F:ORG]ADD(1)
When "TYP"
 Case [V]GIMP(4)
  When "G"     : [M]TYP=5 : # Groupe de caisses
  When Default : [M]TYP=3 : # Caisse
 Endcase
When "KEYORG"
 [M]KEYORG=1 : # Siret

When "TYPIRC"
 Case [V]GIMP(4)
 When "A"
  [M]TYPIRC=4 : # Arrco
 When "C"
  [M]TYPIRC=5 : # Agirc
 When "P"
  [M]TYPIRC=3 : # Prévoyance
 When "G"
  Filter [ARM] Where NUMREQ=[F:ARM2]NUMREQ & CLEA3=[V]GIMP(3) & CLEA4="P"
  [M]TYPIRC=7-!rowcount([ARM]) : # IRC+IP, IRC
  Filter [ARM]
 Endcase

When "NUMDCS"
 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif

 If len([V]GIMP(2))<4  & [V]GIMP(2)=num$(val([V]GIMP(2)))
  [V]GIMP(2)=format$("N0:4#",[V]GIMP(2))
 Endif
 Filter [ADI] Where NUMTAB=10340 & A1=[V]GIMP(2)
 Read [ADI] First
 Filter [ADI]
 If !fstat : [M]NUMDCS=[F:ADI]CODE : Else [L]IMPMOD=0 : Endif

When "NBRLIG"
 If [V]GIMP(4)<>"G"
  [L]IMPMOD=0
 Else
  Filter [ARM] Where NUMREQ=[F:ARM2]NUMREQ & CLEA3=[V]GIMP(3)
  [M]NBRLIG=rowcount([ARM])
  Filter [ARM]
 Endif

When "GRPORG"
 Filter [ARM] Where NUMREQ=[F:ARM2]NUMREQ & CLEA3=[V]GIMP(3) & !find(CLEA1,[M]GRPORG)
 Read [ARM] First
 If !fstat : [M]GRPORG(indice)=[F:ARM]CLEA1 : Endif
 Filter [ARM]

When Default
 [L]IMPMOD=0
Endcase
Return

#-------------------------------------------------------------------------------
$IMP_CREATION_RET
$IMP_MODIF_RET
If [F:ARM2]CLEA4="G"
 Delete [ARM] Where NUMREQ=[F:ARM2]NUMREQ & CLEA3=[F:ARM2]CLEA3
 If fstat
  [V]GOK=0
  Call RSTA("ARM",num$([F:ARM2]NUMREQ)-[M:DIA]MODIMP) From GLOCK
  Return
 Endif

Else
 Raz [F:ARM]
 [F:ARM2]NUMLIG+=1
 [F:ARM]NUMREQ  =[F:ARM2]NUMREQ
 [F:ARM]RPTCOD  =[M:DIA]MODIMP
 [F:ARM]USR     =[V]GUSER
 [F:ARM]NUMLIG  =[F:ARM2]NUMLIG
 [F:ARM]CLEA1   =[F:ORG]COD
 [F:ARM]CLEA3   =[F:ARM2]CLEA3
 [F:ARM]CLEA4   =[F:ARM2]CLEA4
 [F:ARM]CREDAT  =date$
 Write [ARM]
 If fstat
  [V]GOK=0
  Call FSTA("ARM") From GLOCK
  Return
 Endif
Endif
Return

################################################################################
Funprog FORMATC(VALEUR)
Value Char VALEUR

[L]VALEUR=toupper(ctrans(vireblc([L]VALEUR,4)))

End ctrans([L]VALEUR,ctrans([L]VALEUR,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",""),"")
