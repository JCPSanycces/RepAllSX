#<AdxTL>@(#)6.0.0.0 $Revision:   1.3  $
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

########################################################################################################
##                                                                                                     #
## Epuration Interface tréso                     -   Module COMTPABILITE                               #
##                                                                                                     #
########################################################################################################
#   - CASH  : Epuration des flux de trésorerie                                                         #
########################################################################################################
# 
#
# EPUR  = 1 => Epuration
#
#    Soit Epuration seule (EPUR=1 et HISTO=0) 
#         Les données sont supprimées d'APPLI
#         Uniquement des contrôles liés au dossier APPLI.
#
#
########################################################################################################

$ACTION
Case ACTION
  When "OUVRE"
   Case [F:AHI]COD
    When "CASH" : Gosub OUVRE_CASH
   Endcase

  When "EPURE"
   Case [F:AHI]COD
    When "CASH"  : Gosub EPU_CASH
   Endcase

  When "FERME"
   Case [F:AHI]COD
    When "CASH"  : Gosub FERME_CASH
   Endcase
Endcase
Return


#####################################################################################################
# Epuration des flux de trésorerie                                                                  #
# Formule d'épuration :   FLG=2                                                                     #
#####################################################################################################
#
#     Epuration d'un flux s'effectue si :
#        le règlement associé a déjà été épuré
#
#######################################################################################

$OUVRE_CASH
If EPUR
 # Epuration seule. 
 # Contrôle sur APPLI
 # Données APPLI à supprimer
 If !clalev([F:P1]) : Local File =[L]APPLI+".PAYMENTH"  [P1] : Endif
Endif 

Return

###################
$EPU_CASH
If [L]TRACEDET
 # Enregistrement
 Call ECR_TRACE(mess(87,116,1)-[F:F1]FIC-[F:F1]REGNUM,0) From GESECRAN
Endif

Read [P1]PYH0=[F1]REGNUM
If !fstat  
 If [L]TRACEDET
  Call ECR_TRACE(mess(5,173,1)-[F:P1]NUM,1) From GESECRAN
   # Le règlement est toujours présent
 Endif
 OKEPU=0 : Return
Endif
Return

##############
$FERME_CASH
If clalev([F:P1])  Close Local File [P1] : Endif
Return
