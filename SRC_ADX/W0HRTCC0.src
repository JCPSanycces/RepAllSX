#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTCC0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TCCCOD
mkstat = 0
zoncou = "TCCCOD"
indice = 0
If varmode([M]TCCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TCCCOD" : Gosub ACTION From =IMPTRT
 Endif
 If [M]TCCCOD=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "HRTCC"
  Local Decimal VALEUR
  VALEUR = [M]TCCCOD
  Call S_AFF_NUM(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]TCCCOD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TCCDES
mkstat = 0
zoncou = "TCCDES"
indice = 0
If varmode([M]TCCDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TCCDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRTCC0"
Return

