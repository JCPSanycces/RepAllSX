$ON_NBCLC
Onevent BEFORE_INPUT Call AS_NBCLC From W1CTRDOC
Onevent CONTROL Call C_NBCLC From W1CTRDOC
Return

Subprog AS_NBCLC
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBCLC From CTRDOC
Gosub _AFF
End

Subprog C_NBCLC
Local Decimal BASPAG
## Action STD
Call C_NBCLC From CTRDOC
If mkstat : GERR = 1 : GZONE = "NBCLC" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_CLASPE
Onevent CONTROL Call C_CLASPE(zc) From W1CTRDOC
Onevent BEFORE_INPUT Call AS_CLASPE(zc) From W1CTRDOC
Onevent AFTER_CHANGE Gosub AMM_CLASPE From W1CTRDOC
Return

Subprog AS_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45815,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CLASPE(VALEUR) From CTRDOC
If mkstat=2
 [M]CLASPE(INDIC) = VALEUR
 Affzo CLASPE(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CLASPE(zc) From W1CTRDOC
Onkey   2 Titled GBOUTS Call S_CLASPE(zc) From W1CTRDOC
Onkey 144 Titled GBOUTP Call P_CLASPE(zc) From W1CTRDOC
Onkey 146 Titled GBOUTA Call SA_CLASPE(zc) From W1CTRDOC
Gosub _AFF
End

Subprog C_CLASPE(VALEUR)
Variable Char    VALEUR()
## Action CONTHRCLC
Call CONTHRCLC(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLC
If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
If !mkstat
 ## Action STD
 Call C_CLASPE(VALEUR) From CTRDOC
 If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
 If !mkstat
  ## Action CONTOBJW
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARMSK(1) = "HRCLC"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CLASPE
Call AM_CLASPE(zc)
If !mkstat & GOBJET
 zoncou = "CLASPE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CLASPE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CLASPE(VALEUR) From CTRDOC
If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
Gosub _AFF
End

Subprog S_CLASPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCLC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCLC"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCLC","SUBHRCLC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CLASPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCLC
 Call TUNHRCLC(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCLC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCLC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DESCLA
Onevent INIT_AREA Call D_DESCLA(zc) From W1CTRDOC
Return

Subprog D_DESCLA(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESCLA,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLACTR","DESCLA",[M]CLASPE(nolign-1),[M]LEG(nolign-1)) From ATEXTRA
Endif
Gosub _AFF
End

