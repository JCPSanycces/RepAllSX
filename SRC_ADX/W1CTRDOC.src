#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTRDOC 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:49"
A_USER  = "DOC"
A_STAMP = "20181109230349"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBDOCGEN"
  If [M]NBDOCGEN=0
  Endif
 When "NBCLC"
  If [M]NBCLC=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTRDOC [CDOC]
Gosub HORODAT
Local Inpbox "CTRDOC" From GFONCTION At A_STAMP With A_WINDPREV Mask [CDOC] As [SIM_]
Grizo [CDOC]5
Grizo [CDOC]10
Grizo [CDOC]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CDOC]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=14 : X2(0)=99 : Y1(0)=7 : Y2(0)=9
X1(1)=14 : X2(1)=45 : Y1(1)=10 : Y2(1)=21
X1(2)=46 : X2(2)=99 : Y1(2)=10 : Y2(2)=21
Return

$ON_REFNUM
Return

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1CTRDOC
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1CTRDOC
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT4
Gosub _AFF
Return

$ON_NOLIB
Return

$ON_NBDOCGEN
Onevent BEFORE_INPUT Call AS_NBDOCGEN From W1CTRDOC
Return

Subprog AS_NBDOCGEN
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBDOCGEN From CTRDOC
Gosub _AFF
End

$ON_SELFLG
Onevent INIT_AREA Call D_SELFLG(zc) From W1CTRDOC
Onevent BEFORE_INPUT Call AS_SELFLG(zc) From W1CTRDOC
Return

Subprog D_SELFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]SELFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SELFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DOCGENA
Return

$ON_ICODOC2
Onevent BEFORE_INPUT Call AS_ICODOC2(zc) From W1CTRDOC
Onevent INIT_AREA Call D_ICODOC2(zc) From W1CTRDOC
Return

Subprog D_ICODOC2(VALEUR)
Variable Char    VALEUR()
If varinit([M]ICODOC2,indice)=0
 VALEUR = 21
Endif
Gosub _AFF
End

Subprog AS_ICODOC2(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
## Action STD
Call AS_ICODOC2(VALEUR) From CTRDOC
If mkstat=2
 [M]ICODOC2(INDIC) = VALEUR
 Affzo ICODOC2(INDIC) : mkstat = 2
Endif
Onkey 178 Titled GBOUTI Call CL_ICODOC2(zc) From W1CTRDOC
Gosub _AFF
End

Subprog CL_ICODOC2(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_ICODOC2(VALEUR) From CTRDOC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

