Call TEXTE(56649,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..2) , CLELIG(GLONAVA)
CLEPRIM = 'REFNUM'
CLESEC(0) = 'YEA'
CLESEC(1) = 'CTRNUM'
CLESEC(2) = 'TIM'
CLELIG = 'TIM'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Shortint A_BUF1(0..GNBDERNIER)
Local Char     A_BUF2(15)(0..GNBDERNIER)
Local Char     A_BUF3(40)(0..GNBDERNIER)
Local Char     A_BUF4(40)(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
If clalev([F:CNE9])>0 : Close Local File [CNE9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Shortint A_TAB1,
& Char     A_TAB2(15),
& Char     A_TAB3(40),
& Char     A_TAB4(40),
& Char     A_TAB5(20)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5
& As [CNE9]
Return

$LEC_DERLU
Read [ID]ID0=[F:CNE]REFNUM
If fstat : Raz [F:ID] : Endif
Read [ACC]CODACC=GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [ECT]ECT0=[F:CNE]REFNUM;[F:CNE]CTRNUM
If fstat : Raz [F:ECT] : Endif
Return

$CHARGE_DERLU
If clalev([F:CNE9])>0
 Read [CNE9] = [F:CNE9]A_TABI
 [L]CLE = [F:CNE9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:CNE9])>0
 Filter [CNE9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [CNE1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:CNE9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:CNE]REFNUM+"~"
 A_CLEDERLU += num$([F:CNE]YEA)+"~"
 A_CLEDERLU += [F:CNE]CTRNUM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:CNE9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:CNE9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:CNE]YEA"
Call TEXTE(1879,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 2
SELFMT(NBSEL) = "N:4F"
SELFOR(NBSEL) = "N:4#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CNE]YEA"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CNE]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CNE]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]NAM"
Call TEXTE(18622,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]NAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRN"
Call TEXTE(1825,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CNE]CTRNUM"
Call TEXTE(5481,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CNE]CTRNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:CNE_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
Link [CNE] With
& [ID]ID0=[F:CNE]REFNUM,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [ECT]ECT0=[F:CNE]REFNUM;[F:CNE]CTRNUM
& As [CNE_]
Return

$DEFAUT_LISTE
Default file [CNE_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3"
Local Shortint A_BUFJ1(1..GNBSEL)
Local Char     A_BUFJ2(15)(1..GNBSEL)
Local Char     A_BUFJ3(20)(1..GNBSEL)
Local Char     A_BUFJ4(5)(1..GNBSEL)
Local Char     A_BUFJ5(15)(1..GNBSEL)
Local Char     A_BUFJ6(80)(1..GNBSEL)
Local File(
& Shortint A_TABJ1,
& Char     A_TABJ2(15),
& Char     A_TABJ3(20),
& Char     A_TABJ4(5),
& Char     A_TABJ5(15),
& Char     A_TABJ6(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5, A_BUFJ6
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..6)
Call TEXTE(1879,TITJOI(1)) From OBJDIV
Call TEXTE(10793,TITJOI(2)) From OBJDIV
Call TEXTE(5481,TITJOI(3)) From OBJDIV
Call TEXTE(47937,TITJOI(4)) From OBJDIV
TITJOI(5) = mess(59,100,1) : # Type
TITJOI(6) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:15c"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Nf:4#"
End

$LIENS
