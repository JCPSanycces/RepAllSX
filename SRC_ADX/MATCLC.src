#<AdxTL>@(#)0.0.0.0 $Revision$

Global Integer ACTSELECT

Raz GPILOBJ
Call OBJET("EML",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "OK"        : Gosub OK
 When "DEBUT"     : Gosub DEBUT
 When "FINSAI"    : If FLGOK : mkstat = 4 : Endif
Endcase
Return

$OUVRE
Local Integer FLGOK
FLGOK = 0
If clalev([F:HRCLC])=0  : Local File CLACTR     [HRCLC] : Endif
Return

## Chargement du tableau "clauses" avec les clauses de l'écran
## PARAM(1) = Nom du champ clause dans l'écran
## PARAM(2) = Numéro de document

$DEBUT


Raz [M:MCL]
For nolign=1 To dim([M:MCL]CLASPE)


 If GNAVIG(GPILNAV)="GESHRENT"
  If evalue(PARAM(2)+num$(nolign-1)+"("+PARAM(1)+")")<>""
   [M:MCL]CLASPE(nolign-1) = evalue(PARAM(2)+num$(nolign-1)+"("+PARAM(1)+")")
  Else
   Break
  Endif
 Else
  If evalue(PARAM(2)+"("+num$(nolign-1)+")")<>""
   [M:MCL]CLASPE(nolign-1) = evalue(PARAM(2)+"("+num$(nolign-1)+")")
   If dim([M:MCL]LEG) > 0 Then
   [M:MCL]LEG(nolign-1) = evalue(PARAM(4)+"("+num$(nolign-1)+")")
   Endif


##Translatable description
 If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
 If dim([M:MCL]LEG(nolign-1))>0
     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;[M:MCL]CLASPE(nolign-1);[M:MCL]LEG(nolign-1)
 Else
     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;[M:MCL]CLASPE(nolign-1);GCURLEG
 Endif
      If fstat=0
      [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE
      Else
      If dim([M:MCL]LEG(nolign-1))>0
       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;[M:MCL]CLASPE(nolign-1);[M:MCL]LEG(nolign-1)
      Else
       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;[M:MCL]CLASPE(nolign-1);GCURLEG
      Endif
If fstat=0
        [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE
       Else
        [M:MCL]DESCLA(nolign-1) = ""
       Endif
      Endif
  Else
   Break
  Endif
 Endif
Next
[M:MCL]NBCLC = nolign-1
[M:MCL]DOCCLA = val(PARAM(3))
Affzo [MCL]
Return

## Affectation des zones invisibles de l'écran par le tableau "clauses"

$OK
For I=1 To dim([M:MCL]CLASPE)

 If GNAVIG(GPILNAV)="GESHRENT"
  Assign PARAM(2)+num$(I-1)+"("+PARAM(1)+")" With [M:MCL]CLASPE(I-1)
 Else
  Assign PARAM(2)+"("+num$(I-1)+")" With [M:MCL]CLASPE(I-1)
  If dim([M:MCL]LEG(nolign-1))>0
  Assign PARAM(4)+"("+num$(I-1)+")" With [M:MCL]LEG(I-1)
  Endif
 Endif
Next
FLGOK = 1
Return

Subprog C_CLASPE(VALEUR)
Variable Char    VALEUR()
#Call UNICITE(VALEUR,[M:MCL]CLASPE(0..[M:MCL]NBCLC-1)) From OBJDIV

Local Integer I, NOL
NOL = nolign-1
For I=0 To [M]NBCLC-1
  If I<>NOL Then
    If VALEUR=[M:MCL]CLASPE(I)    Then
     GERR=1
     GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
     mkstat=2 : End
   Endif
  Endif
Next
End

######################################################################################
## Default to LEG when typed in, if appropriate - SPE and matching DOCCLA type
######################################################################################
Subprog AM_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Integer DOCNUM


If [M:MCL]ACTSELECT(nolign-1)<>2

DOCNUM=DOCCLA


Filter [F:HRCLC] Where [F:HRCLC]TYPCLA=2 and [F:HRCLC]LEG=GCURLEG and [F:HRCLC]CODCLA=VALEUR and find(DOCNUM, [F:HRCLC]DOCCLA(0..9))>0
Look [HRCLC]CLC0 First

 If  fstat =4
[M:MCL]LEG(nolign-1) = ""
Else
[M:MCL]LEG(nolign-1) = GCURLEG
Endif


Endif


 ##Translatable description
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
 If dim([M:MCL]LEG(nolign-1))>0
    Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE; VALEUR;[M:MCL]LEG(nolign-1)
 Else
     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE; VALEUR;GCURLEG
 Endif
      If fstat=0
      [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE

      Else

 If dim([M:MCL]LEG(nolign-1))>0
       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF; VALEUR;[M:MCL]LEG(nolign-1)
      Else
        Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF; VALEUR;GCURLEG
      Endif
       If fstat=0
        [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE
       Else
        [M:MCL]DESCLA(nolign-1) = ""
       Endif
      Endif
 [M:MCL]ACTSELECT(nolign-1)=0

End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran MATCLC) 04/12/2012 18:27:35 (MABOS)
######################################################################################
Subprog AS_CLASPE(VALEUR)
Variable Char    VALEUR()
If VALEUR =""
   Raz [F:HRCLC]
Endif
End


######################################################################################

