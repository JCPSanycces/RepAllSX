#################################################################################################################
##
##    SUBJECT :    Austrian VAT Declaration - Calculation of chamber of commerce fee ("Kammerumlage") (SAM #90740)
##    AUTHOR  :    DNE
##    DATE    :    2013-12-04
##
#################################################################################################################
##
##    NEW/MODIFIED OBJECTS:
##
##    ADP   AUTCOCRAT   NEW
##    AMK   TRAQ        NEW
##    AWI   TRAQ        NEW
##    TRT   TRAQ        NEW
##    AWI   FCNSTRA     MODIFIED    New button "Chamber of commerce fee"
##    TRT   CNSTRASTD   MODIFIED    Slightly modified (e. g. removing of temporary data implemented)
##    TRT   CNSTRGSTD   MODIFIED    SETVATPREVIEWGRID chunk uses COUNT variable instead of dim(...)
##
#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "TRA", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################



#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "DEBUT"   : Gosub DEBUT
        When "BOUTON"  : Gosub BOUTON
        When "OK"      : Gosub OK
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and pre-fills the dialog window.
#*
#*! #############################################################################################################

$DEBUT
    Local Char TMPPARAM(255)
    Local Integer EXTINDEX
    Local Integer I, I2, I3

    # Make sure there aren't any remainders in the grids.
    Effzo 1 -99

    # Copy values from underlying form
    [M]CUR = [M:TRG0]CURSEL

    # Get company group (if set in base) (otherwise company).
    If [M:TRG0]GRP <> ""
        [M]CPY = [M:TRG0]GRP
    Else
        [M]CPY = [M:TRG0]CPY
    Endif

    # Get the levy rate from parameter AUTCOCRAT.
    Call PARAM(  [M]CPY, "AUTCOCRAT", TMPPARAM ) From ADOVAL
    If TMPPARAM = ""
        [M]RATLEVY = 0
    Else
        [M]RATLEVY = val( TMPPARAM )
    Endif

    # Fill summary grid with already known (fixed) values.
    [M]NBLIG  = 4
    For I = 0 To 3
        [M]QUARTER(I) = num$( I + 1 )
    Next

    # Fill detail grid with already known (fixed) values.
    [M]NBLIG2 = 10
    [M]REPLINE( [M]NBLIG2 - 1 ) = mess(70,195,1) # "Totals"

    # Revalidate screen content.
    Affzo [M:TRAQ] 1 - 99
Return



#** #############################################################################################################
#*
#* Sub chunk:  BOUTON
#*
#* Purpose:    Handler for the non-standard buttons.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button.
#*
#*! #############################################################################################################

$BOUTON
    Case BOUT
        When "1" # Button "Calculate"
            Call TEMPON( "C" ) From GESECRAN
            Gosub CALCULATE_GRIDS
            Call TEMPOFF From GESECRAN
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler of the OK button.
#*             Copies the chamber of commerce fee data from the summary grid to the underlying
#*             U31 from in CONSTRA function.
#*
#*! #############################################################################################################

$OK
    # Try to copy all 4 calculated chamber of commerce fee values to the underlying U31 (CONSTRA5) screen.
    For I = 0 To 3

        # Only checked values are taken into account.
        If [M]FLGCOPY(I) = 2

          # Warn if the underlying grid's space is not sufficient.
            If ( [M:TRA5]NBLIG + 1 ) > dim( [M:TRA5]AMT )
                Call ERREURT( mess(33,170,1), 1 ) From GESECRAN  # "Line entry grid full"
                Goto OK_LEAVE
            Endif

            # Otherwise create a new chamber of commerce fee entry.
            #
            # Note: The levy type is fix "040". Such a levy type must exist.
            #
            [M:TRA5]DATDEB([M:TRA5]NBLIG) = [M]DATDEB(I)
            [M:TRA5]DATFIN([M:TRA5]NBLIG) = [M]DATFIN(I)
            [M:TRA5]TYPLEV([M:TRA5]NBLIG) = "040"
            [M:TRA5]AMT([M:TRA5]NBLIG)    = ar2( [M]AMTFEE(I) )
            [M:TRA5]NBLIG += 1
        Endif
    Next

$OK_LEAVE
    # Recalculate and revalidate the U31 screen (CONSTRA5) content.
    [M:TRA5]AMTTOT = sum( [M:TRA5]AMT(0..( [M:TRA5]NBLIG - 1 ) ) )
    Affzo [M:TRA5] 1 - 99
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALCULATE_GRIDS
#*
#* Purpose:    Calculates 4 implicit VAT declarations for quarter 1 to 4 of the given year
#*             and fills detail an summary grid with the necessary values.
#*
#*! #############################################################################################################

$CALCULATE_GRIDS
    Local Char VATBOX(8)
    Local Decimal AMTVATBASE
    Local Decimal AMTVAT

    # Initialize hidden date fields (start and end dates of quarters)
    # and reset all copy checkboxes to unchecked state.
    For I = 0 To 3
        [M]DATDEB(I) = gdat$( 1, I * 3 + 1, [M]SELYEAR  )
        [M]DATFIN(I) = eomonth( gdat$( 1, I * 3 + 3, [M]SELYEAR  ) )
        [M]FLGCOPY(I) = 1
    Next

    # Reset the quarterly tax rates of the summary grid to 0 (for we will add amounts in loop).
    [M]AMTTAX1(I2) = 0
    [M]AMTTAX2(I2) = 0
    [M]AMTTAX3(I2) = 0
    [M]AMTTAX4(I2) = 0

    ###################################################################
    # Calculate detail grid
    ###################################################################
    For EXTINDEX = 0 To 3
        # Do a complete VAT declaration for the corresponding quarter (EXTINDEX + 1).
        Gosub CALC_VAT_DECLARATION

        # Get the boxes (see loop) and fill the detail grid.
        #
        # NOTE (1): Box 901 is a pseudo box that is only needed to collect the VAT of all
        #           box 001 base amounts.
        # NOTE (2): According to ULKUC only the tax of report line "101" (pseudo line "901")
        #           is to be used.
        #
        I2 = 0
        For VATBOX= "000", "060", "061", "083", "057", "048", "044", "065", "032", "901"
            If VATBOX <> "901"
                [M]REPLINE(I2) = VATBOX
            Else
                [M]REPLINE(I2) = "001" # For we need to say "Tax for box 001".
            Endif

            # Search for the given vat box in the result grid.
            I3 = find( VATBOX, KZDIST(0..( dim( KZDIST ) - 1 ) ) ) - 1
            If I3 >= 0
                AMTVATBASE = TRANSVOLUME(I3)
                AMTVAT = TTAX(I3)
            Else
                AMTVATBASE = 0
                AMTVAT = 0
            Endif
            If VATBOX = "000"
                # Fill in the turnover values in the summary grid.
                [M]AMTTRN(EXTINDEX) = -AMTVATBASE
            Else
                # Diverify into the correct column.
                Case EXTINDEX
                    When 0 : [M]AMTTAX1(I2) = AMTVAT
                    When 1 : [M]AMTTAX2(I2) = AMTVAT
                    When 2 : [M]AMTTAX3(I2) = AMTVAT
                    When 3 : [M]AMTTAX4(I2) = AMTVAT
                Endcase

                # Increase line counter
                I2 += 1
            Endif
        Next
    Next

    # Build totals in the input tax total and chamber fee columns.
    For I = 0 To [M]NBLIG2 - 2
        [M]AMTTOTROW(I) =  ar2( [M]AMTTAX1(I) + [M]AMTTAX2(I) + [M]AMTTAX3(I) + [M]AMTTAX4(I) )
        [M]AMTFEEROW(I) =  ar2( [M]AMTTOTROW(I) * [M]RATLEVY * 0.01 )
    Next

    # Build totals in last row.
    [M]AMTTAX1(   [M]NBLIG2 - 1 ) = ar2( sum( [M]AMTTAX1(  0..( [M]NBLIG2 - 2 ) ) ) )
    [M]AMTTAX2(   [M]NBLIG2 - 1 ) = ar2( sum( [M]AMTTAX2(  0..( [M]NBLIG2 - 2 ) ) ) )
    [M]AMTTAX3(   [M]NBLIG2 - 1 ) = ar2( sum( [M]AMTTAX3(  0..( [M]NBLIG2 - 2 ) ) ) )
    [M]AMTTAX4(   [M]NBLIG2 - 1 ) = ar2( sum( [M]AMTTAX4(  0..( [M]NBLIG2 - 2 ) ) ) )
    [M]AMTTOTROW( [M]NBLIG2 - 1 ) = ar2( sum( [M]AMTTOTROW(0..( [M]NBLIG2 - 2 ) ) ) )
    [M]AMTFEEROW( [M]NBLIG2 - 1 ) = ar2( [M]AMTTOTROW( [M]NBLIG2 - 1 ) * [M]RATLEVY * 0.01 )# ar2( sum( [M]AMTFEEROW(0..( [M]NBLIG2 - 2 ) ) ) )

    ###################################################################
    # Calculate summary grid
    #
    # NOTE: The turnover values are already filled in above.
    ###################################################################
    #
    # Copy quarterly tax totals to the summary grid.
    [M]AMTTAX(0) = [M]AMTTAX1( [M]NBLIG2 - 1 )
    [M]AMTTAX(1) = [M]AMTTAX2( [M]NBLIG2 - 1 )
    [M]AMTTAX(2) = [M]AMTTAX3( [M]NBLIG2 - 1 )
    [M]AMTTAX(3) = [M]AMTTAX4( [M]NBLIG2 - 1 )

    # Calculate the quarterly chamber fees.
    #
    # NOTE: Rate is in % so we multiply by 0.01 (or divide by 100)!
    #
    For I = 0 To 3
      [M]AMTFEE(I) =  ar2( [M]AMTTAX(I) * [M]RATLEVY * 0.01 )
    Next

    # Update the display.
    Affzo 1 - 99
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALC_VAT_DECLARATION
#*
#* Purpose:    Does a single (implicit) VAT calculation for the given parameterization.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param EXTCPY    Company for which the VAT calculation is to be done
#* @param EXTLEG    Legislation (especially when using company groups)
#* @param EXTFCY    Site for which the VAT calculation is to be done
#* @param EXTGRP    Company group
#* @param EXTINDEX  Row in the summary grid from which the hidden date range is to get.
#*
#*! #############################################################################################################

$CALC_VAT_DECLARATION
    Local Char EXTCPY(GLONCPY), EXTLEG(255), EXTFCY(GLONFCY), EXTGRP(GLONCPY)
    Local Date EXTDATEB, EXTDATEE

    # Fill parameters.
    EXTCPY   = [M:TRG0]CPY
    EXTLEG   = [M:TRG0]LEG
    EXTFCY   = [M:TRG0]FCY
    EXTGRP   = [M:TRG0]GRP
    EXTDATEB = [M]DATDEB(EXTINDEX)
    EXTDATEE = [M]DATFIN(EXTINDEX)

    # Open necessary tables etc.
    Gosub OUVRE From CNSTRGSTD

    # Flag that indicates call from external process
    EXTFLAG = 1

    # Parameter that indicates that reference date is accounting date or document date
    [L]OPT = func CNSTRGSTD.GETCOMPANYVATDAT( EXTCPY )

    # Set start and end date
    Call SETSTARTANDENDDATE( DATEBEGIN, DATEEND, EXTDATEB, EXTDATEE ) From CNSTRGSTD

    # Set the filter string needed to get the required data.
    Call SETFILTERSTRINGS( EXTCPY, EXTGRP, EXTFCY, [L]OPT, DATEBEGIN, DATEEND, FIL1, FIL2, FIL3, FIL4, FIL5, FIL6, FIL7 ) From CNSTRGSTD

    # Set the count of the linecodes in table replindef for a given legislation.
    [L]COUNT = func CNSTRGSTD.LINECODECOUNT( EXTLEG, 0 )

    # Define and dim required data arrays.
    Gosub KEYDATA From CNSTRGSTD

    # Set legislation and group.
    Call SETLEGISLATIONANDGROUP( LEGISLATION, GROUP, EXTLEG, EXTGRP ) From CNSTRGSTD

    # Join all required tables and filter with FIL1 to FIL7.
    Gosub QUERY From CNSTRGSTD

    # Set data in the arrays.
    #
    # NOTE: We use the SETDATA from the Austrian VAT declaration for the German version does some roundings in
    #       the tax bases which are not allowed in Austria.
    Gosub SETDATA From CNSTRASTD

    # Calculate tax amounts.
    Gosub CALCULATE_VAT
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALCULATE_VAT
#*
#* Purpose:    Calculates the tax amounts from the the VAT bases using hard coded rates.
#*
#*! #############################################################################################################

$CALCULATE_VAT
    # Calculate tax amounts.
    #
    # NOTE: These are the same hard coded rates the Austrian VAT declaration uses in
    #       CNSTRASTD.CALC_VAT_DECLARATION_VAT. Please change rates in both places. In a not so far future
    #       there  should be a possibility to changes these rates via GUI and database table.
    #
    For I = 0 To dim(KZDIST) - 1
        Case KZDIST(I)
            When "022" : TTAX(I) = TRANSVOLUME(I) * 0.20
            When "029" : TTAX(I) = TRANSVOLUME(I) * 0.10
            When "025" : TTAX(I) = TRANSVOLUME(I) * 0.12
            When "037" : TTAX(I) = TRANSVOLUME(I) * 0.19
            When "052" : TTAX(I) = TRANSVOLUME(I) * 0.10
            When "038" : TTAX(I) = TRANSVOLUME(I) * 0.08
            When "072" : TTAX(I) = TRANSVOLUME(I) * 0.20
            When "073" : TTAX(I) = TRANSVOLUME(I) * 0.10
            When "088" : TTAX(I) = TRANSVOLUME(I) * 0.19
        Endcase
    Next
Return
