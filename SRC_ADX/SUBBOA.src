#<AdxTL>@(#)1.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : BOA
#   Fonction : GESBOA - Liste des approbations
#   Action   : GOBJET
#   Ecran concerné : BOA1
#   Description : Définie les approbations passées. La fonction est utilisé
#                 pour lister les approbations, sorte de consultation des
#                 approbation, les infos de l'écran sont seulement affichées
#                 
#--------------------------------------------------------------------------

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "CHANGE"   : Gosub CHANGE
 When "DROIT"    : Gosub DROIT
 When "FILTRE"   : Gosub FILTRE
 When Default
Endcase
Return

$OUVRE
If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([AWS]) : Local File AWRKHISSUI [AWS] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
Local Mask BOA1 [BOA1]
Local Integer OKACS
Return

$DROIT
# Code accès
fstat = 0
If [F:ENV]ENV<>[F:BOA]ENV
 Read [ENV]ENV0 = [F:BOA]ENV
Endif
If !fstat & [F:ENV]ACS<>""
 Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
 If !OKACS
  GMESSAGE = mess(4,104,1)
  CLECUR = 0 : Return
 Endif
Endif
#
Return

$FILTRE
FILTSUP= '(GUSRACS=2 | [F:ENV]ACS="" | num$([F:ACC]CONSUL)="2")'
Return

$LIENS
Read [BOA]BOA0 = [F:BOA]NUM
If !fstat
 If [F:BOA]TYP=4
  Filter [BAD] Where NUMAPP=[F:BOA]NUM
  I=0
  For [BAD]BAD0
   [M:BOA1]LTYP(I)    =[F:BAD]TYP
   [M:BOA1]LENV(I)    =[F:BAD]ENV
   [M:BOA1]LFIY(I)    =[F:BAD]FIY
   [M:BOA1]LACC(I)    =[F:BAD]ACC
   [M:BOA1]LAMT(I)    =[F:BAD]AMT
   I+=1
  Next
  [M:BOA1]NBLIG=I
  Affzo [M:BOA1]
  Gosub COLORIZE
 Endif
Endif
Return

$COLORIZE
For I=0 To [M]NBLIG-1
 Chgstl [M]NBLIG(I) With "GDD"+num$([M]LTYP(I))
Next
Affzo [M]
Return

$CHANGE
# Au cas où on autoriserait le changement de code
For [BAD]BAD0 Where NUMAPP=[L]OCODE
 [F:BAD]NUMAPP=[L]NCODE
 Rewrite [BAD]
 If fstat
  GOK=0 : Call FSTA("BAD") From GLOCK 
 Endif
 If   GOK<=0 : Rollback : Endif
Next
#Table AWRKHISUI
#Les champs à changer : CLEDEC , IDENTGRP , IDENTREF, IDENTRET , TEXSUI
Local Integer DEB, FIN
Local Char DEBCHP(50),FINCHP(50)
Local Char LISTCHP(8)(1..4), VALCHP(250)
LISTCHP(1)="IDENTGRP"
LISTCHP(2)="IDENTREF"
LISTCHP(3)="IDENTRET"
LISTCHP(4)="TEXSUI"
Filter [AWS] Where CLEDEC=[L]OCODE
For [AWS]AWS0
 [F:AWS]CLEDEC=[L]NCODE
 For I=1 To 4
  VALCHP=evalue("[F:AWS]"+LISTCHP(I))
  DEB = instr(1,VALCHP,[L]OCODE)
  FIN = DEB+len([L]OCODE)
  DEBCHP=left$(VALCHP,DEB-1)  
  FINCHP=right$(VALCHP,FIN)
  Assign "[F:AWS]"+LISTCHP(I) With DEBCHP+[L]NCODE+FINCHP
 Next
 Rewrite [AWS]
 If fstat
  GOK=0 : Call FSTA("AWS") From GLOCK 
 Endif
 If   GOK<=0 : Rollback : Endif
Next
Return

######################################################################################

