#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It allows to generate a JWT token corresponding to a connected application configured in the 'connectedApplication' entity given a cient ID.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/integration/node_modules/syracuse-4gl-api/lib/connectedApp.md
#* @param CLIENTID : Char : The id of the connected application.
#* @param PARAMS : ClbFile : a string containing a newline separated list of key/value pair key1: value1\nkey2: value2. (YAML like syntax). Typical keys are: auth, site, ....
#*  eg:
#*  auth:
#*    - auth1
#*    - auth2
#*    - auth3
#*  site: SITE1
#*
#* @param RESHEAD : Clbfile : The response header.
#* @param RESBODY : Clbfile : The response body.
#*
#* @return STATUSCODE : Integer : The status code return by Syracuse javascript code runner.
#*!
Funprog GET_TOKEN(CLIENTID, PARAMS, RESHEAD, RESBODY)
Value Char CLIENTID()
Value Clbfile PARAMS()
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/connectedApp'
Local Char FONCTION(30) : FONCTION = 'getConnectedAppToken'

Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + CLIENTID + '","' + PARAMS + '"'

# Call 'write' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, "wait", ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)

End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It allows to generate an URL corresponding to a connected application configured in the 'connectedApplication' entity given a cient ID.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/integration/node_modules/syracuse-4gl-api/lib/connectedApp.md
#* @param CLIENTID : Char : The id of the connected application.
#* @param PATH : Char : The sub url path to use.
#* @param PARAMS : ClbFile : a string containing a newline separated list of key/value pair key1: value1\nkey2: value2. (YAML like syntax). Typical keys are: auth, site, ....
#*  eg:
#*  auth:
#*    - auth1
#*    - auth2
#*    - auth3
#*  site: SITE1
#*
#* @param RESHEAD : Clbfile : The response header.
#* @param RESBODY : Clbfile : The response body.
#*
#* @return STATUSCODE : Integer : The status code return by Syracuse javascript code runner.
#*!
Funprog FORMAT_URL(CLIENTID, PATH, PARAMS, RESHEAD, RESBODY)
Value Char CLIENTID()
Value Char PATH()
Value Clbfile PARAMS()
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/connectedApp'
Local Char FONCTION(30) : FONCTION = 'formatConnectedAppUrl'

Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + CLIENTID + '","' + PATH + '","' + PARAMS + '"'

# Call 'write' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, "wait", ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)

End STATUSCODE

