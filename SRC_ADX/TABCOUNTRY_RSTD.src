#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# CLASS TABCOUNTRY
##########################################################################################################



##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "TCY"
    Case [L]AEVENT
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TCY.EECFLG"                   : Gosub TCY_EECFLG
  When "TCY.ETAT"                     : Gosub TCY_ETAT
  When "TCY.ETATFLG"                  : Gosub TCY_ETATFLG
  When "TCY.ETATFLG2"                 : Gosub TCY_ETATFLG2
  When "TCY.SOCNUMFLG1"               : Gosub TCY_SOCNUMFLG1
  When "TCY.SOCNUMFLG2"               : Gosub TCY_SOCNUMFLG2
  When "TCY.CRNFMTFLG"                : Gosub TCY_CRNFMTFLG
  When "TCY.BIDCTL"                   : Gosub TCY_BIDCTL
  When "TCY.NIDFMTFLG"                : Gosub TCY_NIDFMTFLG
  When "TCY.EECFMTFLG"                : Gosub TCY_EECFMTFLG
  When "TCY.NAFFMTFLG"                : Gosub TCY_NAFFMTFLG
  When "TCY.CRTFMTFLG"                : Gosub TCY_CRTFMTFLG
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

Funprog GET_URLTCY(VALCRY)
Value Char VALCRY

Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
Local Integer ASTATUS
Local Clbfile WURL
TABKEY(1)="CRY" : TABKEYVAL(1)=VALCRY
ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE,"TABCOUNTRY",1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
If ASTATUS>=[V]CST_AERROR
  Raz WURL
Endif
End WURL

##########################################################################################################
$AREAD_AFTER
If this.ACTX.USER="CCL"
 Local Integer ii,TYPEVT,stat : # Type d'évènement Workflow (objet/import/etc.)
 Local Char    CODEVT(30) : # Code évènement
 Local Char    OPERAT(30) : # Opération (Modification/Bouton/etc.)
 Local Char    m,CLEOBJ(250) : # Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature

 TYPEVT=2
 CODEVT="TCY"
 OPERAT="M"
 CLEOBJ=this.CRY
 STAT = func ASYRWRKCLASSIC.WORKFLOW(this.ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,II,M)

# Local Char CODE(30),FILTRE(250)
# Local Integer SIMUL
#
# CODE="TCYMAN"
# SIMUL = 0
# FILTRE="CRY='CF'"
# STAT = func ASYRWRKCLASSIC.WORKMANUAL(this.ACTX,CODE,FILTRE,SIMUL)

Endif
Gosub TABCOUNTRY_CONTROLS
Return

##########################################################################################################
$TABCOUNTRY_CONTROLS
Gosub EECFLG_DISPLAY
Gosub SOCNUMFLG1_DISPLAY
Gosub SOCNUMFLG2_DISPLAY
Gosub BIDCTL_DISPLAY
Gosub CRNFMTFLG_DISPLAY
Gosub NIDFMTFLG_DISPLAY
Gosub EECFMTFLG_DISPLAY
Gosub NAFFMTFLG_DISPLAY
Gosub CRTFMTFLG_DISPLAY
Gosub ETAT_DISPLAY
Gosub ETATFLG_DISPLAY
Gosub ETATFLG2_DISPLAY
Gosub ETATFLG_ETATFLG2
Return



