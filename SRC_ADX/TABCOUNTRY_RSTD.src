##########################################################################################################
$EECFLG_DISPLAY
If this.EECFLG<>[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("EECDAT","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRYVATNUM","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FLGSEPA","$isDisabled","false")
  If dim(this.GSPFLG)>=0
    [L]ASTATUS = fmet this.ASETATTRIBUTE("GSPFLG","$isDisabled","false") :#X3-58867
  Endif
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("EECDAT","$isDisabled","false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRYVATNUM","$isDisabled","false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FLGSEPA","$isDisabled","true")
  If dim(this.GSPFLG)>=0
    [L]ASTATUS = fmet this.ASETATTRIBUTE("GSPFLG","$isDisabled","true") :#X3-58867
  Endif
Endif
Return

##########################################################################################################
$ETATFLG_DISPLAY
If this.ETATFLG<>[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATNAM","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATFMT","$isDisabled","true")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATNAM","$isDisabled","false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATFMT","$isDisabled","false")
Endif
Return

##########################################################################################################
$ETATFLG2_DISPLAY
If this.ETATFLG2<>[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATNAM2","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATFMT2","$isDisabled","true")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATNAM2","$isDisabled","false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATFMT2","$isDisabled","false")
Endif
Return

##########################################################################################################
$SOCNUMFLG1_DISPLAY
If dim(this.SOCNUMFLG1)>0
  If this.SOCNUMFLG1 = [V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT", "$isDisabled", "false")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT", "$isDisabled", "true")
  Endif
Elsif dim(this.SOCNUMFMT)>0
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT", "$isDisabled", "false")
Endif
Return

##########################################################################################################
$SOCNUMFLG2_DISPLAY
If dim(this.SOCNUMFLG2)>0
  If this.SOCNUMFLG2 = [V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT2", "$isDisabled", "false")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT2", "$isDisabled", "true")
  Endif
Endif
Return

##########################################################################################################
$BIDCTL_DISPLAY
If this.BIDCTL = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BANLNG", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BANLNG", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$CRNFMTFLG_DISPLAY
If this.CRNFMTFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRNFMT", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRNFMT", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$NIDFMTFLG_DISPLAY
If this.NIDFMTFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NIDFMT", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NIDFMT", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$EECFMTFLG_DISPLAY
If this.EECFMTFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("EECFMT", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("EECFMT", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$NAFFMTFLG_DISPLAY
If this.NAFFMTFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NAFFMT", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NAFFMT", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$CRTFMTFLG_DISPLAY
If this.CRTFMTFLG = [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRTFMT", "$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRTOBL", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRTFMT", "$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRTOBL", "$isDisabled", "true")
Endif
Return

##########################################################################################################
$ETAT_DISPLAY
If this.ETAT=1                         # None
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATCTL","$isDisabled","true")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATCTL","$isDisabled","false")
Endif
Return

##########################################################################################################
$ETATFLG_ETATFLG2
If this.ETATFLG2<>[V]CST_AYES & this.ETATFLG<>[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETAT","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATCTL","$isDisabled","true")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETAT","$isDisabled","false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ETATCTL","$isDisabled","true")
Endif
Return

