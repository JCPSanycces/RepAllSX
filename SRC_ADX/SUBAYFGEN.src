#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Element champ
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
#test
Local Integer CHKFLG      : CHKFLG      = find("CHK",OPTION) 
#test
Local Char WSTR1(250)
Local Char WNOMGEN(30) : WNOMGEN="AYTGEN"    # nom du traitement à appeler      
RET=1

Call TITOBJ("AYF","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN : # Validation de l'écran
If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTELTFLD [AYF1] 
 Local File ATEXTE    [ATX1] 
 Local File ATEXTRA   [AXX1]
# modif sb flash
 Local File APTLVW    [APV1]
# fin modif sb flash
Else 
 Local File =[L]DOSORG+".AYTELTFLD"  [AYF1] 
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File = [L]DOSORG+".ATEXTRA"   [AXX1] 
 # modif sb flash
 Local File =[L]DOSORG+".APTLVW"    [APV1]
# fin modif sb flash


Endif 
Default File "[AYF1],[ATX1],[APV1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="FLD"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYF1]AYF0 Where FCYCOD=FCYORG & ENASPE<>2
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(5,7910,1)-[F]FIECOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]FIECOD    
 Call LECTEXTRA(XT_VAL,"AYTELTFLD","INTIT",[F]FCYCOD,[F]FIECOD) From AYTUTIA : Gosub XMLF_ADD From AYTGEN

 XT_TY="FLD"   : XT_ID="TYP"        : XT_VAL=num$([F]TYP)
                                      XT_LAB=mess([F]TYP,7931,1)           : Gosub XMLF_ADD From AYTGEN
 Case [F]TYP
 When 8    # menu local
     XT_TY="FLD"   : XT_ID="NOLIB"      : XT_VAL=num$([F]NOLIB)            : Gosub XMLF_ADD From AYTGEN
 When 6,7  # Image , PJ
     If [F]RESRAC<1 : [F]RESRAC=1 : Endif 
     XT_TY="FLD"   : XT_ID="RESRAC"     : XT_VAL=num$([F]RESRAC)
                                          XT_LAB=mess([F]RESRAC,7937,1)        : Gosub XMLF_ADD From AYTGEN
     If [F]RESRAC>1
         XT_TY="FLD"   : XT_ID="RESSUBREP"  : XT_VAL=[F]RESSUBREP              : Gosub XMLF_ADD From AYTGEN
         XT_TY="FLD"   : XT_ID="EXTFCYOPT"  : XT_VAL=num$([F]EXTFCYOPT)
                                              XT_LAB=mess([F]EXTFCYOPT,1,1)        : Gosub XMLF_ADD From AYTGEN
         If [F]EXTFCYOPT=1
             XT_TY="FLD"   : XT_ID="EXT"        : XT_VAL=[F]EXT                    : Gosub XMLF_ADD From AYTGEN
         Endif
     Endif
 Endcase
 #
 Case [F]TYP
 When 1,2,8
     XT_TY="FLD"   : XT_ID="LSTMEN"  : XT_VAL=[F]LSTMEN                  : Gosub XMLF_ADD From AYTGEN
 Endcase

# modif sb flash
Case [F]TYP
 When 9
     Read [APV1] APV0=[F]FLAVUE
     XT_TY="FLD"   : XT_ID="FLAINT"     : XT_VAL=[F]FLAINT     : Gosub XMLF_ADD From =WNOMGEN
     XT_TY="FLD"   : XT_ID="FLAVUE"     : XT_VAL=[F]FLAVUE     : Gosub XMLF_ADD From =WNOMGEN
     XT_TY="FLD"   : XT_ID="FLADLK"     : XT_VAL=[F]FLADLK     : Gosub XMLF_ADD From =WNOMGEN
     XT_TY="FLD"   : XT_ID="FLATIT"     : XT_VAL=num$([F]FLATIT)
                                          XT_LAB=mess([F]FLATIT,1,1)      : Gosub XMLF_ADD From =WNOMGEN
    If fstat    Then
        XT_TY="FLD"   : XT_ID="FLATYPE"     : XT_VAL=[F]FLATYPVUE     : Gosub XMLF_ADD From =WNOMGEN
    If CHKFLG Then       
         Call ECR_TRACE("  "-mess(214,7900,1)-":"-[F]FLAVUE,1) From GESECRAN
        RET=2
    Endif
    Else
         XT_TY="FLD"   : XT_ID="FLATYPE"     : XT_VAL=[APV1]SRCCODTYP     : Gosub XMLF_ADD From =WNOMGEN
    Endif
   XT_TY="FLD"   : XT_ID="FLASIZ"     : XT_VAL=num$([F]FLASIZ)     : Gosub XMLF_ADD From =WNOMGEN
 Endcase

# fin modif sb flash
# modif sb ajout valeur defaut

 XT_TY="FLD"   : XT_ID="TYPUSE"     : XT_VAL=num$([F]VALDEF)
                                          XT_LAB=mess([F]VALDEF,7941,1)      : Gosub XMLF_ADD From =WNOMGEN


If [F]VALDEF<>1
         XT_TY="FLD"   : XT_ID="CONSTVAL"  : XT_VAL=[F]VALVAL              : Gosub XMLF_ADD From AYTGEN
Endif

# fin modif sb valeur defaut



 If [F]LANNBR<>0
  XT_TY="TAB"   : XT_ID="LANNBR"                                         : Gosub XMLF_ADD From AYTGEN
  For WI=0 To [F]LANNBR-1
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="LANCOD"     : XT_VAL=[F]LANCOD(WI)                  : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="LANFMT"     : XT_VAL=[F]LANFMT(WI)                  : Gosub XMLF_ADD From AYTGEN
  Next
 Endif
Next
#

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYF1],[ATX1],[APV1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

