#<AdxTL>@(#)0.0.0.0 $Revision$
$HEADER
###---- Start and end dates of the exercise
Call DATEXE([L]SOC, [L]LEDT, [L]EXE, [L]STRFYDAT, [L]ENDFYDAT) From CPTSUB

Read [F:CPY]CPY0 = [L]SOC
If fstat : Raz [F:CPY] : Endif

# Issue X3-31864 - 2017-04-06 by MRDAB: small refactor
Call FILTER_BPADDRESS([L]SOC)
# End issue X3-31864

Gosub RAZ_HET From SAFTGENPOR
[L]HETAUDITFILV = [L]SAFTVER
[L]HETCOMPANYID = func SAFTGENPORTG.GETNUMERIC([F:CPY]EECNUM)
[L]HETTAXREGNUM = val([L]HETCOMPANYID)
Case [L]SAFTTYPE
  When 2
    [L]HETTAXACCBAS = "I"
    [L]HETTAXENTITY = "Sede"
  When 3
    [L]HETTAXACCBAS = "F"
    [L]HETTAXENTITY = "Global"
  When 4
    [L]HETTAXACCBAS = "C"
    [L]HETTAXENTITY = "Sede"
  When 5, 7
    [L]HETTAXACCBAS = "S"
    [L]HETTAXENTITY = "Sede"
  When 6, 8
    [L]HETTAXACCBAS = "P"
    [L]HETTAXENTITY = "Global"
Endcase
[L]HETCOMPANAME = [F:CPY]CPYNAM
[L]HETBUSINNAME = [F:CPY]CPYNAM
[L]HETBUILDNUMB = ""
[L]HETSTREETNAM = ""
[L]HETADDREETAI = vireblc([F:ADC]BPAADDLIG(0) + " " + [F:ADC]BPAADDLIG(1) + " " + [F:ADC]BPAADDLIG(2), 2)
[L]HETCITY      = vireblc([F:ADC]CTY,2)
[L]HETPOSTALCOD = vireblc(format$("K:4#[-]3#[]", [F:ADC]POSCOD),2)
[L]HETREGION    = vireblc([F:ADC]SAT,2)
[L]HETCOUNTRY   = "PT" #está PT na especificação da DGCI
[L]HETFISCAYEAR = year([L]STRFYDAT)
[L]HETSTARTDATE = format$("D:YYYY[-]MM[-]DD",[L]STRDATE)
[L]HETENDDATE   = format$("D:YYYY[-]MM[-]DD",[L]ENDDATE)
[L]HETCURRECODE = "EUR" #está EUR na especificação da DGCI
[L]HETDATECREAT = format$("D:YYYY[-]MM[-]DD",date$)
[L]HETPRCOTAXID = "502667583" #Alterar - verificar
[L]HETSOCERTNUM = "213"
[L]HETPRODUCTID = "SAGE ERP X3/SAGE"
[L]HETPRODUCTVE = func APRODUCT.AGETVERSION()#right$(GVERSION, 3)
[L]HETHEADERCOM = [L]COMMENT
[L]HETTELEPHONE = [F:ADC]TEL
[L]HETFAX       = [F:ADC]FAX
[L]HETEMAIL     = ""
[L]HETWEBSITE   = [F:ADC]WEB


If [F:CPY]PORRESFISCDA<>""
  If !clalev([F:CP2]) : Local File COMPANY [CP2] : Endif
  Read [F:CP2]CPY0=[F:CPY]PORRESFISCDA
  If !fstat
    [L]HETTAXACCBAS = "E"
    [L]HETHEADERCOM = ""
    [L]HETHEADERCOM+=format$("K:70X",[F:CP2]CPYNAM)
    [L]HETHEADERCOM+=format$("K:16X",func SAFTGENPORTG.GETNUMERIC([F:CPY]EECNUM))
    # Issue X3-31864 - 2017-04-06 by MRDAB: small refactor
    Call FILTER_BPADDRESS([F:CP2]CPY)
    # End issue X3-31864
    [L]HETHEADERCOM+=format$("K:80X",[F:ADC]BPAADDLIG(0)-''-[F:ADC]BPAADDLIG(1)-''-[F:ADC]BPAADDLIG(2))
    [L]HETHEADERCOM+=format$("K:10X",format$("K:4#[-]3#[]", [F:ADC]POSCOD))
    [L]HETHEADERCOM+=format$("K:40X",[F:ADC]CTY)
  Endif
Endif
Gosub WRITE_HEADER
Return

$WRITE_HEADER

Wrseq '<Header xmlns="urn:OECD:StandardAuditFile-Tax:PT_'+[L]SAFTVER+'">' Using [SAFT]
AUXTAGNAM = 'AuditFileVersion'          : AUXTAGVAL = [L]HETAUDITFILV : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CompanyID'                 : AUXTAGVAL = [L]HETCOMPANYID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TaxRegistrationNumber'     : AUXTAGVAL = num$([L]HETTAXREGNUM) : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TaxAccountingBasis'        : AUXTAGVAL = [L]HETTAXACCBAS : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CompanyName'               : AUXTAGVAL = [L]HETCOMPANAME : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'BusinessName'              : AUXTAGVAL = [L]HETBUSINNAME : Gosub WRITETAG From SAFTGENPORTG
Wrseq '<CompanyAddress>' Using [SAFT]
#AUXTAGNAM = 'BuildingNumber'            : AUXTAGVAL = HETBUILDNUMB : Gosub WRITETAG From SAFTGENPORTG
#AUXTAGNAM = 'StreetName'                : AUXTAGVAL = HETSTREETNAM : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'AddressDetail'             : AUXTAGVAL = [L]HETADDREETAI : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'City'                      : AUXTAGVAL = [L]HETCITY      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PostalCode'                : AUXTAGVAL = [L]HETPOSTALCOD : Gosub WRITETAG From SAFTGENPORTG
If [L]HETREGION <> ""
  AUXTAGNAM = 'Region' : AUXTAGVAL = [L]HETREGION    : Gosub WRITETAG From SAFTGENPORTG
Endif
AUXTAGNAM = 'Country'                   : AUXTAGVAL = [L]HETCOUNTRY   : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</CompanyAddress>' Using [SAFT]
AUXTAGNAM = 'FiscalYear'                : AUXTAGVAL = num$([L]HETFISCAYEAR) : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'StartDate'                 : AUXTAGVAL = [L]HETSTARTDATE       : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'EndDate'                   : AUXTAGVAL = [L]HETENDDATE         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CurrencyCode'              : AUXTAGVAL = [L]HETCURRECODE       : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'DateCreated'               : AUXTAGVAL = [L]HETDATECREAT       : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TaxEntity'                 : AUXTAGVAL = [L]HETTAXENTITY       : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ProductCompanyTaxID'       : AUXTAGVAL = [L]HETPRCOTAXID       : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SoftwareCertificateNumber' : AUXTAGVAL = [L]HETSOCERTNUM : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ProductID'                 : AUXTAGVAL = [L]HETPRODUCTID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ProductVersion'            : AUXTAGVAL = [L]HETPRODUCTVE : Gosub WRITETAG From SAFTGENPORTG
If [L]HETHEADERCOM <> ""
  AUXTAGNAM = 'HeaderComment'             : AUXTAGVAL = [L]HETHEADERCOM : Gosub WRITETAG From SAFTGENPORTG
Endif
If [L]HETTELEPHONE <> "" : AUXTAGNAM = 'Telephone'                 : AUXTAGVAL = [L]HETTELEPHONE : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]HETFAX       <> "" : AUXTAGNAM = 'Fax'                       : AUXTAGVAL = [L]HETFAX       : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]HETWEBSITE   <> "" : AUXTAGNAM = 'Website'                   : AUXTAGVAL = [L]HETWEBSITE   : Gosub WRITETAG From SAFTGENPORTG : Endif
Wrseq '</Header>' Using [SAFT]
[L]RECSWRI += 1
Return

# Issue X3-31864 - 2017-04-06 by MRDAB: common function extracted
Subprog FILTER_BPADDRESS(FILTER_PARAM)
Value Char FILTER_PARAM
  Filter [F:ADC] Where [F:ADC]BPATYP = 2 & [F:ADC]BPANUM = FILTER_PARAM & [F:ADC]BPAADDFLG = 2
  Read [F:ADC] First
  If fstat
    Filter [F:ADC] Where [F:ADC]BPATYP = 2 & [F:ADC]BPANUM = FILTER_PARAM
    Read [F:ADC] First
    If fstat
      Raz [F:ADC]
    Endif
  Endif
  Filter [F:ADC]
End
# End issue X3-31864

