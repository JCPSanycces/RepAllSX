#<AdxTL>@(#)0.0.0.0 $Revision$ Sections analytiques
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CCE",GBIDC1,GBIDC2) From  GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "EFFMASK"   : Gosub EFFMASK
 When "FILGAUCHE" : Gosub FILGAUCHE
 When "FILTRE"    : Gosub FILTRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "STYLE"     : Gosub STYLE
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "CHANGE"    : Gosub CHANGE
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "FIN"       : Gosub FIN
 When "FERME"     : Gosub FERME
 When "VERIF_CRE" : Gosub INTERDICTION_GDD
 When "AV_VERF_ANU" : Gosub INTERDICTION_GDD
 When "AP_VERF_ANU" : Gosub AP_VERF_ANU
Endcase
Return

$OUVRE
Local Integer I , J , K
Local Integer NBPYRAM
Local Char    PYRAM(GLONGYM)(1..50)
Global Char   GWDIE(GLONDIE)

NBPYRAM = 0
If clalev([F:CYM]) = 0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:DIE]) = 0 : Local File GDIE       [DIE] : Endif
If clalev([F:CRY]) = 0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CYK]) = 0 : Local File GCCEPYMLIK [CYK] : Endif
If clalev([F:CYP]) = 0 : Local File GCCEPYMPRT [CYP] : Endif
If clalev([F:CR0]) = 0 : Local File GCCEGRUPYM [CR0] : Endif
If clalev([F:GYM]) = 0 : Local File GACCPYM    [GYM] : Endif
Local Char SAV_GBIDC1(30)
Local Char SAV_GBIDC2(30)
SAV_GBIDC1 = GBIDC1
SAV_GBIDC2 = GBIDC2
If !GIMPORT
 If CLE2=""
  Read [DIE]DIE0 First
  CLE2 = [F:DIE]DIE
 Endif
 GBIDC1 = CLE2
 GWDIE = GBIDC1
Endif
Return

$SETBOUT
CHMEN = ""
If GREP<>"" or TUNNEL or !instr(1,GUSRAUZ(1),"1")
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Call LECTURE("DIE",[M:CCE0]DIE,"") From CONTOBJ
If CLECUR
 Local Integer OKACC
 Call LECACC([F:CCE]ACS,OKACC) From SUBACS
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Else
  CHMEN += "23"
 Endif
Endif
If [F:DIE]ENV=2 | [F:DIE]ENT=2 :#BUO
 Call VIREBOUT(CHAINE,"A") From GOBJET :# No Suppresion Possible
Else
 If GREP=""
  CHMEN += "4"
 Endif
Endif
Return

$FIN
Gosub MAJ_LIENS
GBIDC1 = SAV_GBIDC1
GBIDC2 = SAV_GBIDC2
Return

$FERME
If dim(GWDIE)>0 : Kill GWDIE : Endif
Return

$EFFMASK
If MA=0
 [M:CCE0]DIE = GBIDC1
 Affzo [CCE0]DIE
Endif
Return

$FILGAUCHE
FILGAUCHE = '[F:CCE]DIE="'+GWDIE+'"'
Return

$FILTRE
If GFONCTION="GESCCE" & zoncou<>"DEFCCE" & dim(CRITERE)>0
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:CCE]DIE="'+GWDIE+'"'
Endif
Return

$EXEBOUT
Case REP
 When "1"
  Local Char VALBOUT(250), PARBOUT(250)(1..20)
  VALBOUT = [M]DIE
  PARBOUT(1) = "DIE"
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  FLGEXE = 1
  GACTION = "SELOBJW"
  Call S_TAB_CHAR(VALBOUT,PARBOUT,"SELOBJ","SELOBJ","") From GACTION
  If VALBOUT<>""
   Gosub MAJ_LIENS
   If VALBOUT = "" : Return : Endif
   Gosub DEVERROU From GOBJET
   Effzo
   [M:CCE0]DIE = VALBOUT
   Affzo [CCE0]DIE
   GBIDC1 = [M:CCE0]DIE
   GWDIE = GBIDC1
   Gosub REMPLIT From GOBJSUB
   Filter [CCE] Where DIE=GBIDC1
   Read [CCE]CCE0 First
   Filter [CCE]
   If !fstat
    CLECUR  = 1
    CLECUR1 = [F:CCE]CCE
    CLECUR2 = GBIDC1
   Else
    CLECUR = 0
   Endif
   Gosub RELIT From GOBJSUB
  Endif
Endcase
Return

$MAJ_LIENS
If GBIDC1<>"" & NBPYRAM>0
 Call TEMPON("V") From GESECRAN
 For I=1 To NBPYRAM
  Call PYRAMPRT(GBIDC1,PYRAM(I),nomap) From LIENPYRCCE
  Call PYRAMLIK(GBIDC1,PYRAM(I),nomap) From LIENPYRCCE
 Next I
 Call TEMPOFF From GESECRAN
 NBPYRAM = 0
Endif
Return

$LIENS
Call LECTEXTRA([M:CCE0]DESTRA,"CACCE","DESTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
Call LECTEXTRA([M:CCE0]SHOTRA,"CACCE","SHOTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
If [F:CCE]FCY<>""
 Call LIENFCYCPY([F:CCE]FCY,"[M:CCE1]LIBFCY") From CFYSUB
Endif
Gosub GRISE_RAN
Gosub LOAD_PYRGRU
Gosub GRISE_GDD
Return

$GRISE_GDD
#Grizage intitulé et site dans le cadre GDD, axe enveloppe ou entité
Call LECTURE("DIE",[M:CCE0]DIE,"") From CONTOBJ
If [F:DIE]ENT=2 | [F:DIE]ENV=2
 Grizo [M:CCE0]DESTRA, SHOTRA
 Grizo [M:CCE1]ENAFLG,ACS,FCY,VLYSTR,VLYEND,BUDTRK,IPT
Else
 Actzo [M:CCE0]DESTRA, SHOTRA
 Actzo [M:CCE1]ENAFLG,ACS,FCY,VLYSTR,VLYEND,BUDTRK,IPT
Endif
Return

$RAZCRE
$RAZDUP
Gosub GRISE_RAN
Return

$GRISE_RAN
Call LECTURE("DIE",[M:CCE0]DIE,"") From CONTOBJ
If [F:DIE]PRJMGT=2
 Effzo [CCE1]FRW
 Grizo [CCE1]FRW
Else
 Actzo [CCE1]FRW
Endif
Return

$INICRE
$INIMOD
If dim([F:CCE]DES)>0
 [F:CCE]DES = [M:CCE0]DESTRA
Endif
Return

$LOAD_PYRGRU
Raz [M:CCE2]
# charge  de la table Pramides - groupes
I = 0

For [CRY] Where  pat([M:CCE0]CCE,[F:CRY]CCE)<>0
 Call LECTURE("CYM",[F:CRY]PYM,"") From CONTOBJ
 If [F:CYM]DIE=[M:CCE0]DIE
  [M:CCE2]PYM(I)     = [F:CRY]PYM
  [M:CCE2]GRU(I)     = [F:CRY]GRU
#  Call LECTEXTRA([M:CCE2]DESGRU(I),"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
  [M:CCE2]LEV(I)     = [F:CRY]LEV
  [M:CCE2]PRNROW(I)  = [F:CRY]PRNROW
  [M:CCE2]FLGGES(I)  = 0
  If [M:CCE0]CCE<>[F:CRY]CCE
   [M:CCE2]CRI(I)     = [F:CRY]CCE
   [M:CCE2]FLGGES(I) = 2
  Endif
  I += 1
 Endif
Next
[M:CCE2]NBRPYR = I
Return

$STYLE
Actzo [M:CCE2]PYM,GRU
For I=0 To [M:CCE2]NBRPYR-1
 If [M:CCE2]FLGGES(I)=2
  Grizo [M:CCE2]PYM(I),GRU(I)
 Else
  Actzo [M:CCE2]PYM(I),GRU(I)
 Endif
Next I
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Call CRECCE([F:CCE]DIE,[F:CCE]CCE) From LIENPYRCCE
If GOK<1 : Return : Endif
Gosub ADDGRUPYM
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub DELGRUPYM
If GOK<1 : Return : Endif
Gosub ADDGRUPYM
Return

$AP_CHANGE
#Chgmt ne pas utiliser l'abbréviation [M] car appelé aussi par la fct ACHANGE
Call CHGTEXTRA("CACCE","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("CACCE","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
If !adxlog
 Trbegin [CCE]
 Call DELCCE(SUPP,OCODE) From LIENPYRCCE
 Call DELCCE(SUPP,NCODE) From LIENPYRCCE
 Call CRECCE(SUPP,NCODE) From LIENPYRCCE
 Commit
Else
 Call DELCCE(SUPP,OCODE) From LIENPYRCCE
 Call DELCCE(SUPP,NCODE) From LIENPYRCCE
 Call CRECCE(SUPP,NCODE) From LIENPYRCCE
Endif
Return

$ANNULE
#Class[M] à éviter car $AV_VERF_ANU peut être appelé d'un autre utilitaire
#Call SUPTEXTRA("CACCE","DESTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
#Call SUPTEXTRA("CACCE","SHOTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
Call SUPTEXTRA("CACCE","DESTRA",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("CACCE","SHOTRA",SUPP,[L]CODE) From ATEXTRA
If !adxlog
 Trbegin [CCE]
 Call DELCCE(SUPP,[L]CODE) From LIENPYRCCE
 Commit
Else
 Call DELCCE(SUPP,[L]CODE) From LIENPYRCCE
Endif
Return

$CHANGE
# Schéma de comptes
#JASMI - 2017-06-16 - X3-42325 - START
#If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
#If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
#Local Integer PLCP
#
#Filter [GDC] Where find([L]OCODE,CCE)<>0
#For [GDC]GDC0
# If [F:GDA]DIA<>[F:GDC]DIA
#  Read [F:GDA]GDA0=[F:GDC]DIA
#  If fstat : Raz [F:GDA] : Endif
# Endif
# For PLCP=1 To dim([F:GDC]CCE)
#  If [F:GDA]DIE(PLCP-1)=SUPP
#   Readlock [GDC]GDC0 Curr
#   If fstat=1
#    GOK =- 1 : Call RSTA("GDC",OCODE) From GLOCK : Break 2
#   Elsif fstat=0
#    [F:GDC]CCE(PLCP-1)= NCODE
#    Rewrite [GDC]
#    If fstat
#     GOK = 0 : Call FSTA("GDC") From GLOCK : Break 2
#    Endif
#   Endif
#  Endif
# Next
#Next
#Filter [GDC]
#If GOK<1 : Return : Endif
If GMODU(2)=2 # Financials
  If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
  If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
  Local Integer PLCP

  Filter [GDC] Where find([L]OCODE,CCE)<>0
  For [GDC]GDC0
   If [F:GDA]DIA<>[F:GDC]DIA
    Read [F:GDA]GDA0=[F:GDC]DIA
    If fstat : Raz [F:GDA] : Endif
   Endif
   For PLCP=1 To dim([F:GDC]CCE)
    If [F:GDA]DIE(PLCP-1)=SUPP
     Readlock [GDC]GDC0 Curr
     If fstat=1
      GOK =- 1 : Call RSTA("GDC",OCODE) From GLOCK : Break 2
     Elsif fstat=0
      [F:GDC]CCE(PLCP-1)= NCODE
      Rewrite [GDC]
      If fstat
       GOK = 0 : Call FSTA("GDC") From GLOCK : Break 2
      Endif
     Endif
    Endif
   Next
  Next
  Filter [GDC]
  If GOK<1 : Return : Endif
Endif
#JASMI - 2017-06-16 - X3-42325 - END
Return

$INTERDICTION_GDD
#Class[M] à éviter car $annule peut être appelé d'un utilitaire externe ANUCOD

If dim([M:CCE0]DIE)>0
 Call LECTURE("DIE",[M:CCE0]DIE,"") From CONTOBJ
Else
 Call LECTURE("DIE",SUPP,"") From CONTOBJ
Endif
If [F:DIE]ENT=2 | [F:DIE]ENV=2
 #Création ou suppression de sections sur axe entité ou enveloppe interdits
 Call MESSAGE(mess(186,108,1)) From GESECRAN
 OK=0
Endif
Return

$AP_VERF_ANU
# Contrôle bloquant si la section se trouve dans un schéma de comptes
#JASMI - 2017-06-16 - X3-42325 - START
#If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
#If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
#Local Integer PLCP
#
#Filter [GDC] Where find([L]CODE,CCE)<>0
#For [GDC]GDC0
# PLCP = find([L]CODE,[F:GDC]CCE)
# If [F:GDA]DIA<>[F:GDC]DIA
#  Read [F:GDA]GDA0=[F:GDC]DIA
#  If fstat : Raz [F:GDA] : Endif
# Endif
# If [F:GDA]DIE(PLCP-1)=SUPP
#  OKANU = 0 : Break
# Endif
#Next
#Filter [GDC]
#If OKANU=0
# # Annulation xxx dans
# REFERR(1) = mess(46,150,1)-[L]CODE-SUPP-mess(198,133,1)-"GACCOUNT"
# # La fiche est utilisée par xx dans
# REFERR(2) = mess(101,126,1)-[F:GDC]DIA-mess(198,133,1)-"GDIAACCD"
# # Il faut d'abord supprimer ce lien
# REFERR(3) = mess(176,115,1)
# If !GSERVEUR & !GIMPORT
#  Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
# Else
#  GMESSAGE = REFERR(1)+"\"+REFERR(2)
#  If !GIMPORT
#   GMESSAGE+="\"+REFERR(3)
#  Endif
# Endif
#Endif
If GMODU(2)=2 # Financials
  If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
  If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
  Local Integer PLCP

  Filter [GDC] Where find([L]CODE,CCE)<>0
  For [GDC]GDC0
   PLCP = find([L]CODE,[F:GDC]CCE)
   If [F:GDA]DIA<>[F:GDC]DIA
    Read [F:GDA]GDA0=[F:GDC]DIA
    If fstat : Raz [F:GDA] : Endif
   Endif
   If [F:GDA]DIE(PLCP-1)=SUPP
    OKANU = 0 : Break
   Endif
  Next
  Filter [GDC]
  If OKANU=0
   # Annulation xxx dans
   REFERR(1) = mess(46,150,1)-[L]CODE-SUPP-mess(198,133,1)-"GACCOUNT"
   # La fiche est utilisée par xx dans
   REFERR(2) = mess(101,126,1)-[F:GDC]DIA-mess(198,133,1)-"GDIAACCD"
   # Il faut d'abord supprimer ce lien
   REFERR(3) = mess(176,115,1)
   If !GSERVEUR & !GIMPORT
    Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
   Else
    GMESSAGE = REFERR(1)+"\"+REFERR(2)
    If !GIMPORT
     GMESSAGE+="\"+REFERR(3)
    Endif
   Endif
  Endif
Endif
#JASMI - 2017-06-16 - X3-42325 - END
Return


######################################################################################
$DELGRUPYM
For [CRY] Where CCE=[M:CCE0]CCE
 Read [CYM]CYM0 = [F:CRY]PYM
 If !fstat & [F:CYM]DIE=[M:CCE0]DIE
  OK = 0
  For I=0 To [M:CCE2]NBRPYR-1
   If [M:CCE2]FLGGES(I)=0 & [M:CCE2]PYM(I)=[F:CYM]PYM & [M:CCE2]GRU(I)=[F:CRY]GRU
    OK = 1
   Endif
  Next
  If !OK
   If [F:CRY]LIN=1
    [F:CRY]CCE = ""
    Rewrite [CRY]
    If fstat
     GOK = 0 : Call FSTA("CRY") From GLOCK : Break
    Endif
   Else
    Delete [CRY]
    If fstat=1
     GOK = -1 : GLOCK = "$GCCEGRUPYM"-[F:CRY]PYM-[F:CRY]GRU : Break
    Endif
   Endif
   If !find([F:CYM]PYM,PYRAM(1..NBPYRAM))
    NBPYRAM += 1
    PYRAM(NBPYRAM) = [F:GYM]PYM
   Endif
  Endif
 Endif
Next
Return

######################################################################################
$ADDGRUPYM
For I=0 To [M:CCE2]NBRPYR-1
 If [M:CCE2]FLGGES(I)=1
  Filter [CRY] Where PYM=[M:CCE2]PYM(I) & GRU=[M:CCE2]GRU(I)
  OK = 0
  For [CRY]CRY0
   If pat([M:CCE0]CCE,[F:CRY]CCE)<>0
    OK = 1
   Endif
  Next
  If !OK
   Read [CRY]CRY0 Last
   If fstat<=2
    [F:CRY]PYM    = [M:CCE2]PYM(I)
    [F:CRY]GRU    = [M:CCE2]GRU(I)
    [F:CRY]LIN   += 1
    [F:CRY]CCE    = [M:CCE0]CCE
    [F:CRY]SBBGRU = ""
    Write [CRY]
    If fstat
     GOK=0 : Call FSTA("CRY") From GLOCK : Break
    Endif
    If !find([F:CRY]PYM,PYRAM(1..NBPYRAM))
     NBPYRAM += 1
     PYRAM(NBPYRAM) = [F:CRY]PYM
    Endif
   Endif
  Endif
  Filter [CRY]
 Endif
Next I
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("CACCE","DESTRA",CLECUR2,CLECUR1,"CACCE","DESTRA",[M:CCE0]DIE,[M:CCE0]CCE)  From ATEXTRA
 Call DUPTEXTRA("CACCE","SHOTRA",CLECUR2,CLECUR1,"CACCE","SHOTRA",[M:CCE0]DIE,[M:CCE0]CCE)  From ATEXTRA
Endif
Call MAJTEXTRA([M:CCE0]DESTRA,"CACCE","DESTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
Call MAJTEXTRA([M:CCE0]SHOTRA,"CACCE","SHOTRA",[M:CCE0]DIE,[M:CCE0]CCE) From ATEXTRA
Return

######################################################################################
## Etiquettes masques CCE0, CCE1, CCE2
######################################################################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:CCE1]UOM(0..[M]UOMNBR-1)) From OBJDIV
End

Subprog C_OTHDIE(VALEUR)
Variable Char    VALEUR()
If [M:CCE0]DIE = VALEUR
 # Valeur incorrecte
 Call ERREUR(mess(83,123,1)) From GESECRAN
 mkstat=2 : End
Endif
Call UNICITE(VALEUR,[M:CCE1]OTHDIE(0..[M]DIENBR-1)) From OBJDIV
End

Subprog C_DEFCCE(VALEUR)
Variable Char    VALEUR()
If clalev([F:CCE2]) = 0 : Local File CACCE    [CCE2] : Endif
Gosub SETNOL
Read [CCE2]CCE0 = [M:CCE1]OTHDIE(NOL);VALEUR
If !fstat
 Call COMPAT([M:CCE1]FCY,[F:CCE2]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif
End

Subprog C_NBRPYR
Local Integer I,NOL
I = nolign-1
If status=65 & [M]FLGGES(I)=2
 GMESSAGE = mess(1,115,1) : # Suppression impossible
 mkstat = 2 : End
Endif
End

Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
If clalev([F:CYM]) = 0 : Local File GCCEPYM    [CYM] : Endif
Call LECTURE("CYM",VALEUR,"") From CONTOBJ
If [F:CYM]DIE<>[M:CCE0]DIE
 ## Pyramide associée à l'axe [F:CYM]DIE
 GMESSAGE = mess(94,108,1)-[F:CYM]DIE
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M]PYM(0..[M]NBRPYR-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog C_GRU(VALEUR)
Variable Char    VALEUR()
Filter [CRY] Where PYM=[M]PYM(nolign-1) and GRU=VALEUR
Read [CRY]CRY0 First
If fstat
 GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
 mkstat = 2
Else
 [M]GRU(nolign-1)    = VALEUR
# Call LECTEXTRA([M]DESGRU(nolign-1),"GCCEGRUPYM","DESTRA",[M]PYM(nolign-1),VALEUR) From ATEXTRA
 [M]LEV(nolign-1)    = [F:CRY]LEV
 [M]PRNROW(nolign-1) = [F:CRY]PRNROW
 [M]FLGGES(nolign-1) = 1 #new line
 Affzo PYM(nolign-1),GRU(nolign-1)
Endif
Filter [CRY]
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
If [M]DIE="" : mkstat=2 : GMESSAGE=mess(2,649,1) : End : Endif
End

