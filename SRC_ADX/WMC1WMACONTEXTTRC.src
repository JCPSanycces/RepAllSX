$GET_WRKRMTDIR
Gosub DECLARE_VAR From WMC0WMACONTEXTTRC
[L]CURPRO = "WRKRMTDIR"
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return


