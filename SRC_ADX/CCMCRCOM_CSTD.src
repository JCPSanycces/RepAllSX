    Local Integer LOCAL_ASTATUS

    LOCAL_ASTATUS = fmet HIGH_LEVEL_PLAN.AREAD(this.CRID)
  Endif
  # Issue X3-94378 - end

  If (LOCAL_ASTATUS = CST_AOK)
    ARET_VALUE = HIGH_LEVEL_PLAN.IMPLEMENT
  Endif

