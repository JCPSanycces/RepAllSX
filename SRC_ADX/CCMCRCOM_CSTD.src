# --------------------------------------------------
# Create the plan.
$CREATE_PLAN
  Local Integer LOCAL_ASTATUS, RECOMMENDATIONS, LINE

  # Issue X3-94378 - create NCS plan
  If (this.NCSREC = 2)
    Local Instance PLAN_HEADER Using C_PLANHDR
    PLAN_HEADER = NewInstance C_PLANHDR AllocGroup null

    If (this.NCSSTA = 4)  # if the change request status is Plan then create the Plan ...
      LOCAL_ASTATUS = fmet PLAN_HEADER.AREAD(this.NCSID)

      If (LOCAL_ASTATUS <> CST_AOK) # if the Plan does not exist then create the Plan ...

        # Initialise Plan Header properties ...
        LOCAL_ASTATUS = fmet PLAN_HEADER.AINIT()
        PLAN_HEADER.PLANID = this.NCSID
        PLAN_HEADER.NCSID = this.NCSID

        # Create Plan Header and Detail ...
        LOCAL_ASTATUS = fmet PLAN_HEADER.AINSERT()

        # update PLANID on NC
        this.PLANID = this.NCSID
        # LOCAL_ASTATUS = fmet this.AUPDATE()
      Endif
    Endif
  Else # Issue X3-94378 - end
    Local Instance PLAN_HEADER Using C_CCMPLANH
    PLAN_HEADER = NewInstance C_CCMPLANH AllocGroup null

    If (this.CRSTATUS = 4)  # if the change request status is Plan then create the Plan ...
      LOCAL_ASTATUS = fmet PLAN_HEADER.AREAD(this.CRID)

      If (LOCAL_ASTATUS <> CST_AOK) # if the Plan does not exist then create the Plan ...

        # Initialise Plan Header properties ...
        LOCAL_ASTATUS = fmet PLAN_HEADER.AINIT()
        PLAN_HEADER.CRID = this.CRID

        # Create Plan Header and Detail ...
        LOCAL_ASTATUS = fmet PLAN_HEADER.AINSERT()

      Endif
    Endif

    FreeGroup PLAN_HEADER
  Endif # Issue X3-94378

Return

# --------------------------------------------------
# Delete the plan if changing status from Plan to In-review
$DELETE_PLAN

  # Issue X3-94378 - delete NCS plan
  If (this.NCSREC = 2)
    Local File PLANHDR [PLAHDR]
    Local File PLANDET [PLADET]

    this.PLANID = this.NCSID
    If (this.NCSSTA = 2 and this.snapshot.NCSSTA = 4 and this.PLANID <> "")
      Delete [PLADET] Where PLANID=this.PLANID
      Delete [PLAHDR] Where PLANID=this.PLANID
    Endif
    LogicClose File [PLADET]
    LogicClose File [PLAHDR]
    # update PLANID on NC
    this.PLANID = ""
    #LOCAL_ASTATUS = fmet this.AUPDATE()
  Else # Issue X3-94378 - end
    Local File CCMPLAND [CCMPD]
    Local File CCMPLANH [CCMPH]

    If (this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 4)
      # delete existing plan lines and plan
      Delete [CCMPD] Where CRID=this.CRID
      Delete [CCMPH] Where CRID=this.CRID
    Endif
    LogicClose File [CCMPD]
    LogicClose File [CCMPH]
  Endif # Issue X3-94378

Return

# 110863/3
# --------------------------------------------------
# Custom Method
# Check active change request for a product and/or version
# Parameters
#                 PRODUCT       - product code
#                 MAJOR_VERSION - major version
#                 MINOR_VERSION - minor version
# Return values:
#                 ARET_VALUE - CST_AFALSE and CST_ATRUE
#                            - Change request ID if found
#

$CHECK_ACTIVE_CHGREQ_EXISTS

  Local File CCMCHGREQ [CCMCR]
  Local Char CRITERIA(250)

  REQUESTID = ""
  ARET_VALUE = CST_AFALSE

  # Create new sales order lines
  CRITERIA = "PRODUCT ='" + PRODUCT + "'"
  If (MAJOR_VERSION <> "")
      CRITERIA += " and (ECCVALMAJ ='" + MAJOR_VERSION +"' or ECCVALMAJ = '')"

    If (MINOR_VERSION <>  "")
      CRITERIA += " and (ECCVALMIN = '" + MINOR_VERSION +"' or ECCVALMIN = '')"
    Endif

  Endif

  Filter [CCMCR] Where evalue(CRITERIA) and CRSTATUS > 1 and CRSTATUS < 7
  Read [CCMCR] First
  If (fstat = 0)
    REQUESTID = [F:CCMCR]CRID
    ARET_VALUE = CST_ATRUE
  Endif
  Filter [CCMCR]
  LogicClose File [CCMCR]

Return

# 110863/3

# --------------------------------------------------
# Custom Method
# Delete redundant (blank) rows
# from Originator collections ...
# Return values:
# ARET_VALUE - CST_AOK
$DELETE_REDUNDANT_ROWS
# Issue X3-80591 - 2018-10-15 by JUSYN : Check if row in collection really exists, has got values (<> null).
  Local Integer I
  # Issue X3-94378 - for Non-conformance
  If (this.NCSREC = 2)
    # User
    For I = 1 To maxtab(this.NCSINTUSR)
      If this.NCSINTUSR(I) <> null
        If ((this.NCSINTUSR(I).ASTALIN <> CST_ADEL) and (this.NCSINTUSR(I).ASTALIN <> CST_ANEWDEL))
          If (this.NCSINTUSR(I).USER = "")
            ASTATUS = fmet this.ADELLINE("NCSINTUSR", this.NCSINTUSR(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Customer
    For I = 1 To maxtab(this.NCSBPCCOL)
      If this.NCSBPCCOL(I) <> null
        If ((this.NCSBPCCOL(I).ASTALIN <> CST_ADEL) and (this.NCSBPCCOL(I).ASTALIN <> CST_ANEWDEL))
          If (this.NCSBPCCOL(I).BPCNUM = "" and this.NCSBPCCOL(I).CUSTCONTACT = "")
            ASTATUS = fmet this.ADELLINE("NCSBPCCOL", this.NCSBPCCOL(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Supplier
    For I = 1 To maxtab(this.NCSBPSCOL)
      If this.NCSBPSCOL(I) <> null
        If ((this.NCSBPSCOL(I).ASTALIN <> CST_ADEL) and (this.NCSBPSCOL(I).ASTALIN <> CST_ANEWDEL))
          If (this.NCSBPSCOL(I).BPSNUM = "" and this.NCSBPSCOL(I).SUPPCONTACT = "")
            ASTATUS = fmet this.ADELLINE("NCSBPSCOL", this.NCSBPSCOL(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Other
    For I = 1 To maxtab(this.NCSEXTUSR)
      If this.NCSEXTUSR(I) <> null
        If ((this.NCSEXTUSR(I).ASTALIN <> CST_ADEL) and (this.NCSEXTUSR(I).ASTALIN <> CST_ANEWDEL))
          If (this.NCSEXTUSR(I).EXTCONTACT = "")
            ASTATUS = fmet this.ADELLINE("NCSEXTUSR", this.NCSEXTUSR(I).AORDER)
          Endif
        Endif
      Endif
    Next
  Else # Issue X3-94378 - end
    # User
    For I = 1 To maxtab(this.CCMCRORIGI)
      If this.CCMCRORIGI(I) <> null
        If ((this.CCMCRORIGI(I).ASTALIN <> CST_ADEL) and (this.CCMCRORIGI(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMCRORIGI(I).USER = "")
            ASTATUS = fmet this.ADELLINE("CCMCRORIGI", this.CCMCRORIGI(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Customer
    For I = 1 To maxtab(this.CCMCRORIGC)
      If this.CCMCRORIGC(I) <> null
        If ((this.CCMCRORIGC(I).ASTALIN <> CST_ADEL) and (this.CCMCRORIGC(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMCRORIGC(I).BPCNUM = "" and this.CCMCRORIGC(I).CUSTCONTACT = "")
            ASTATUS = fmet this.ADELLINE("CCMCRORIGC", this.CCMCRORIGC(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Supplier
    For I = 1 To maxtab(this.CCMCRORIGS)
      If this.CCMCRORIGS(I) <> null
        If ((this.CCMCRORIGS(I).ASTALIN <> CST_ADEL) and (this.CCMCRORIGS(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMCRORIGS(I).BPSNUM = "" and this.CCMCRORIGS(I).SUPPCONTACT = "")
            ASTATUS = fmet this.ADELLINE("CCMCRORIGS", this.CCMCRORIGS(I).AORDER)
          Endif
        Endif
      Endif
    Next

    # Other
    For I = 1 To maxtab(this.CCMCRORIGE)
      If this.CCMCRORIGE(I) <> null
        If ((this.CCMCRORIGE(I).ASTALIN <> CST_ADEL) and (this.CCMCRORIGE(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMCRORIGE(I).EXTCONTACT = "")
            ASTATUS = fmet this.ADELLINE("CCMCRORIGE", this.CCMCRORIGE(I).AORDER)
          Endif
        Endif
      Endif
    Next
  Endif # Issue X3-94378

  # Remove approver blank lines
  If (this.NCSREC = 2)
    For I = 1 To maxtab(this.NCSAPPROVER)
      If this.NCSAPPROVER(I) <> null
        If ((this.NCSAPPROVER(I).ASTALIN <> CST_ADEL) and
&         (this.NCSAPPROVER(I).ASTALIN <> CST_ANEWDEL))
          If (this.NCSAPPROVER(I).NCSAPPUSR = "")
            ASTATUS = fmet this.ADELLINE("NCSAPPROVER", this.NCSAPPROVER(I).AORDER)
          Endif
        Endif
      Endif
    Next
  Else
    For I = 1 To maxtab(this.CCMAPPROVER)
      If this.CCMAPPROVER(I) <> null
        If ((this.CCMAPPROVER(I).ASTALIN <> CST_ADEL) and
&       (this.CCMAPPROVER(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMAPPROVER(I).APPRUSER = "")
            ASTATUS = fmet this.ADELLINE("CCMAPPROVER", this.CCMAPPROVER(I).AORDER)
          Endif
        Endif
      Endif
    Next
  Endif

  # Remove attachements blank lines
  # Issue X3-77826 - this only apples to CCM
  If (this.NCSREC <> 2)
    For I = 1 To maxtab(this.CCMCRNOTES)
      If this.CCMCRNOTES(I) <> null
        If ((this.CCMCRNOTES(I).ASTALIN <> CST_ADEL) and
&       (this.CCMCRNOTES(I).ASTALIN <> CST_ANEWDEL))
          If (this.CCMCRNOTES(I).CRNOTES = AVOID.ABLOB)
            ASTATUS = fmet this.ADELLINE("CCMCRNOTES", this.CCMCRNOTES(I).AORDER)
          Endif
        Endif
      Endif
    Next
  Endif

  ARET_VALUE = CST_AOK

# End issue X3-80591
Return


# --------------------------------------------------
# Method: IMPLEMENT
#
# IS_UPDATE parameter determines mode:
# CST_ANO  = Validate IMPLEMENT flag across all Detail Plans, and
# CST_AYES = Validate (above) and Update.
$IMPLEMENT

  Local Integer STAT, CAN_IMPLEMENT, IMPLEMENT_CHANGE
  ARET_VALUE = CST_AOK

  # X3-67944 - if Non-conformance then do not check detailed plans
  If (this.NCSREC = 2)
    # Issue X3-94378 - NCS PLAN class
    Local Instance HIGH_LEVEL Using C_PLANHDR
    HIGH_LEVEL = NewInstance C_PLANHDR AllocGroup null

    IMPLEMENT_CHANGE = CST_ATRUE
  Else

  Local Instance SALES_ORDER Using C_CCMIMPSOH
  SALES_ORDER = NewInstance C_CCMIMPSOH AllocGroup null
  Local Instance PURCHASE_ORDER Using C_CCMIMPPOH
  PURCHASE_ORDER = NewInstance C_CCMIMPPOH AllocGroup null
  Local Instance PURCHASE_REQUEST Using C_CCMIMPPRH
  PURCHASE_REQUEST = NewInstance C_CCMIMPPRH AllocGroup null
  Local Instance WORK_ORDER Using C_CCMIMPMFGH
  WORK_ORDER = NewInstance C_CCMIMPMFGH AllocGroup null
  Local Instance SUB_CONTRACT Using C_CCMIMPSCH
  SUB_CONTRACT = NewInstance C_CCMIMPSCH AllocGroup null
  Local Instance SALES_QUOTE Using C_CCMIMPSQH
  SALES_QUOTE = NewInstance C_CCMIMPSQH AllocGroup null
  Local Instance FORECAST Using C_CCMIMPFOH
  FORECAST = NewInstance C_CCMIMPFOH AllocGroup null
  Local Instance STOCK Using C_CCMIMPITM
  STOCK = NewInstance C_CCMIMPITM AllocGroup null
  Local Instance BOM Using C_CCMIMPBOH
  BOM = NewInstance C_CCMIMPBOH AllocGroup null
  Local Instance ROUTING Using C_CCMIMPROH
  ROUTING = NewInstance C_CCMIMPROH AllocGroup null
  Local Instance HIGH_LEVEL Using C_CCMPLANH
  HIGH_LEVEL = NewInstance C_CCMPLANH AllocGroup null

  # Sales Order
  #
  STAT = fmet SALES_ORDER.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and SALES_ORDER.IMPLEMENT <> 2)
      SALES_ORDER.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and SALES_ORDER.IMPLEMENT = 2)
      SALES_ORDER.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet SALES_ORDER.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet SALES_ORDER.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup SALES_ORDER

  # Purchase Order
  #
  STAT = fmet PURCHASE_ORDER.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and PURCHASE_ORDER.IMPLEMENT <> 2)
      PURCHASE_ORDER.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and PURCHASE_ORDER.IMPLEMENT = 2)
      PURCHASE_ORDER.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet PURCHASE_ORDER.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet PURCHASE_ORDER.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup PURCHASE_ORDER


  # Purchase Request
  #
  STAT = fmet PURCHASE_REQUEST.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and PURCHASE_REQUEST.IMPLEMENT <> 2)
      PURCHASE_REQUEST.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and PURCHASE_REQUEST.IMPLEMENT = 2)
      PURCHASE_REQUEST.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet PURCHASE_REQUEST.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet PURCHASE_REQUEST.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup PURCHASE_REQUEST


  # Work Order
  #
  STAT = fmet WORK_ORDER.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and WORK_ORDER.IMPLEMENT <> 2)
      WORK_ORDER.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and WORK_ORDER.IMPLEMENT = 2)
      WORK_ORDER.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet WORK_ORDER.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet WORK_ORDER.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup WORK_ORDER

  # Sub contract orders
  #
  STAT = fmet SUB_CONTRACT.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and SUB_CONTRACT.IMPLEMENT <> 2)
      SUB_CONTRACT.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and SUB_CONTRACT.IMPLEMENT = 2)
      SUB_CONTRACT.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet SUB_CONTRACT.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet SUB_CONTRACT.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup SUB_CONTRACT

  # Sales Quote
  #
  STAT = fmet SALES_QUOTE.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and SALES_QUOTE.IMPLEMENT <> 2)
      SALES_QUOTE.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and SALES_QUOTE.IMPLEMENT = 2)
      SALES_QUOTE.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet SALES_QUOTE.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet SALES_QUOTE.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup SALES_QUOTE

  # Forecast
  #
  STAT = fmet FORECAST.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and FORECAST.IMPLEMENT <> 2)
      FORECAST.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and FORECAST.IMPLEMENT = 2)
      FORECAST.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet FORECAST.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet FORECAST.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup FORECAST

  # STOCK
  #
  STAT = fmet STOCK.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and STOCK.IMPLEMENT <> 2)
      STOCK.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and STOCK.IMPLEMENT = 2)
      STOCK.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet STOCK.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet STOCK.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup STOCK

  # BOM
  #
  STAT = fmet BOM.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and BOM.IMPLEMENT <> 2)
      BOM.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and BOM.IMPLEMENT = 2)
      BOM.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet BOM.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet BOM.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup BOM

  # ROUTING
  #
  STAT = fmet ROUTING.AREAD(this.CRID)
  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and ROUTING.IMPLEMENT <> 2)
      ROUTING.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and ROUTING.IMPLEMENT = 2)
      ROUTING.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet ROUTING.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet ROUTING.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup ROUTING

  Endif # X3-67944

  # High level
  #
  # Issue X3-94378 - NCS plan
  If (this.NCSREC = 2)
    STAT = fmet HIGH_LEVEL.AREAD(this.PLANID)
  Else
    STAT = fmet HIGH_LEVEL.AREAD(this.CRID)
  Endif
  # Issue X3-94378 - end

  If (STAT = CST_AOK)

    IMPLEMENT_CHANGE = CST_AFALSE

    If (NEW_STATUS = 5 and HIGH_LEVEL.IMPLEMENT <> 2)
      HIGH_LEVEL.IMPLEMENT = 2
      IMPLEMENT_CHANGE = CST_ATRUE
    Elsif (NEW_STATUS = 4 and HIGH_LEVEL.IMPLEMENT = 2)
      HIGH_LEVEL.IMPLEMENT = 1
      IMPLEMENT_CHANGE = CST_ATRUE
    Endif

    If (IMPLEMENT_CHANGE)

      CAN_IMPLEMENT = fmet HIGH_LEVEL.VALIDATE_IMPLEMENT()

      If (CAN_IMPLEMENT = CST_AOK)
        If (IS_UPDATE = CST_AYES)
          STAT = fmet HIGH_LEVEL.AUPDATE()
        Endif
      Else
        ARET_VALUE = CST_AERROR
      Endif

    Endif

  Endif

  FreeGroup HIGH_LEVEL

Return


# --------------------------------------------------
# Method: DETERMINE_IMPLEMENT_STATUS
#
# Determine the IMPLEMENT the state of the IMPLEMENT flag across all Detail Plans.
$DETERMINE_IMPLEMENT_STATUS

  Local Integer HIGH_LEVEL_IMPLEMENT
  Local Integer SALES_ORDER_IMPLEMENT
  Local Integer SALES_QUOTE_IMPLEMENT
  Local Integer PURCHASE_ORDER_IMPLEMENT
  Local Integer WORK_ORDER_IMPLEMENT
  Local Integer SUB_CONTRACT_IMPLEMENT
  Local Integer PURCHASE_REQUEST_IMPLEMENT
  Local Integer FORECAST_IMPLEMENT
  Local Integer STOCK_IMPLEMENT
  Local Integer BOM_IMPLEMENT
  Local Integer ROUTING_IMPLEMENT

  HIGH_LEVEL_IMPLEMENT =       fmet this.HIGH_LEVEL_IMPLEMENT_STATUS()

    # X3-67944 - if Non-conformance then do not check detailed plans
  If (this.NCSREC = 2)
    If (HIGH_LEVEL_IMPLEMENT = 2)
      ARET_VALUE = 2
    Else
      ARET_VALUE = 1
    Endif
  Else
    SALES_ORDER_IMPLEMENT =      fmet this.SALES_ORDER_IMPLEMENT_STATUS()
    SALES_QUOTE_IMPLEMENT =      fmet this.SALES_QUOTE_IMPLEMENT_STATUS()
    PURCHASE_ORDER_IMPLEMENT =   fmet this.PURCHASE_IMPLEMENT_STATUS()
    WORK_ORDER_IMPLEMENT =       fmet this.WORK_ORDER_IMPLEMENT_STATUS()
    SUB_CONTRACT_IMPLEMENT =     fmet this.SUB_CONTRACT_IMPLEMENT_STATUS()
    PURCHASE_REQUEST_IMPLEMENT = fmet this.PURCHASE_REQ_IMPLEMENT_STATUS()
    FORECAST_IMPLEMENT         = fmet this.FORECAST_IMPLEMENT_STATUS()
    STOCK_IMPLEMENT            = fmet this.STOCK_IMPLEMENT_STATUS()
    BOM_IMPLEMENT              = fmet this.BOM_IMPLEMENT_STATUS()
    ROUTING_IMPLEMENT          = fmet this.ROUTING_IMPLEMENT_STATUS()

    If (HIGH_LEVEL_IMPLEMENT = 2 and
&     SALES_ORDER_IMPLEMENT = 2 and
&     SALES_QUOTE_IMPLEMENT = 2 and
&     PURCHASE_ORDER_IMPLEMENT = 2 and
&     WORK_ORDER_IMPLEMENT = 2 and
&     SUB_CONTRACT_IMPLEMENT = 2 and
&     PURCHASE_REQUEST_IMPLEMENT = 2 and
&     FORECAST_IMPLEMENT = 2 and
&     STOCK_IMPLEMENT = 2 and
&     BOM_IMPLEMENT = 2 and
&     ROUTING_IMPLEMENT =2)
      ARET_VALUE = 2
    Else
      ARET_VALUE = 1
    Endif
  Endif
Return

# --------------------------------------------------
