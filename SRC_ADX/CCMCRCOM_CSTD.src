#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMCHGREQ_CSTD, Change Request - Header
###############################################################################
# Issue 110863/3 - 2015-10-27 by BAKHA : add method for checking if active Change reqest for a product exists
# Issue 109094/17 - 2015-11-27 by BAKHA : Use a separate sequence number for non-conformance
# Issue 110210/7 - 2015-12-16 by JUSYN : New labels for supervisor update
# Issue 109094/20 - 2016-01-13 by BAKHA : Check new field NCSCATEGORY
# Issue X3-62810 - 2018-01-05 by BAKHA : For Non-conformance, do not create impact analysis when status is
#                                        changed to review.
# Issue X3-67933 - 2018-01-11 by BAKHA : For Non-conformance allow status to be changes from New to Plan
# Issue X3-66939 - 2018-01-15 by BAKHA : For non-conformance, allow product to be blank
# Issue X3-67933 - 2018-01-18 by BAKHA : Only write Reassigned by/date when QA manager changes
# Issue X3-67944 - 2018-01-19 by BAKHA : If Non-conformance, do not check detailed plans
# Issue X3-77826 - 2018-03-09 by BAKHA : Attaching documents not needed for NCS
# Issue X3-83483 - 2018-05-01 by BAKHA : Remove validation on field NCSREASON
# Issue X3-94378 - 2018-06-05 by BAKHA : Changes due to table/class renaming for NCS
# Issue X3-105283 - 2018-08-29 by BAKHA : Authorisation check removed for NC approvers
# Issue X3-108668 - 2018-09-21 by BAKHA : Changed REJECTCOD from local  menu to ADI

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"       : Gosub TIDY_ROWS
        When "AINSERT_CONTROL_AFTER"        : Gosub VALIDATE
        When "AUPDATE_CONTROL_BEFORE"       : Gosub TIDY_ROWS
        When "AUPDATE_CONTROL_AFTER"
          Gosub VALIDATE
          Gosub AUDIT_STATUS_CHANGE
          Gosub STORE_CLOSEDSTATE
        When "AUPDATE_AFTER"
          Gosub DELETE_PLAN
          Gosub CREATE_PLAN
          Gosub IMPLEMENT_PLANS
          Gosub CREATE_IMPACT_ANALYSIS_BATCH_SERVER
        When "AINSERT_BEFORE"               : Gosub AINSERT_BEFORE
        When "AUPDATE_BEFORE"               : Gosub AUPDATE_BEFORE
      Endcase
  Endcase

Return

$METHODS
  Case [L]AMETHOD
    When "CREATE_IMPACT_ANALYSIS"           : Gosub CREATE_IMPACT_ANALYSIS
    When "CHECK_ACTIVE_CHGREQ_EXISTS"       : Gosub CHECK_ACTIVE_CHGREQ_EXISTS   # 110863/3
    When "DELETE_REDUNDANT_ROWS"            : Gosub DELETE_REDUNDANT_ROWS
    When "IMPLEMENT"                        : Gosub IMPLEMENT
    When "DETERMINE_IMPLEMENT_STATUS"       : Gosub DETERMINE_IMPLEMENT_STATUS
    When "HIGH_LEVEL_IMPLEMENT_STATUS"      : Gosub HIGH_LEVEL_IMPLEMENT_STATUS
    When "SALES_ORDER_IMPLEMENT_STATUS"     : Gosub SALES_ORDER_IMPLEMENT_STATUS
    When "SALES_QUOTE_IMPLEMENT_STATUS"     : Gosub SALES_QUOTE_IMPLEMENT_STATUS
    When "PURCHASE_IMPLEMENT_STATUS"        : Gosub PURCHASE_IMPLEMENT_STATUS
    When "PURCHASE_REQ_IMPLEMENT_STATUS"    : Gosub PURCHASE_REQ_IMPLEMENT_STATUS
    When "WORK_ORDER_IMPLEMENT_STATUS"      : Gosub WORK_ORDER_IMPLEMENT_STATUS
    When "SUB_CONTRACT_IMPLEMENT_STATUS"    : Gosub SUB_CONTRACT_IMPLEMENT_STATUS
    When "FORECAST_IMPLEMENT_STATUS"        : Gosub FORECAST_IMPLEMENT_STATUS
    When "STOCK_IMPLEMENT_STATUS"           : Gosub STOCK_IMPLEMENT_STATUS
    When "BOM_IMPLEMENT_STATUS"             : Gosub BOM_IMPLEMENT_STATUS
    When "ROUTING_IMPLEMENT_STATUS"         : Gosub ROUTING_IMPLEMENT_STATUS
    When "CHECK_USER_SITE"                  : Gosub CHECK_USER_SITE
    When "IS_PRODUCT_VERSION_MANAGED"       : Gosub IS_PRODUCT_VERSION_MANAGED
    When "BUILD_EMAIL"                      : Gosub BUILD_EMAIL
    When "BUILD_EMAIL_URL"                  : Gosub BUILD_EMAIL_URL
    When "SEND_EMAIL"                       : Gosub SEND_EMAIL
    When "GET_USER_EMAIL"                   : Gosub GET_USER_EMAIL
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "CRSTATUS"
      Case [L]ARULE
        When "CONTROL"
          Gosub VALIDATE_STATUS
          If (this.CRSTATUS = 3)
            Gosub CHECK_PRODUCT
          Endif
        When "PROPAGATE"
          Gosub INITIALISE_REJECT
      Endcase

    # Issue X3-94378 - For NCS
    When "NCSSTA"
      Case [L]ARULE
        When "CONTROL"
          Gosub VALIDATE_NCS_STATUS
          If (this.NCSSTA = 3)
            Gosub CHECK_PRODUCT
          Endif
        When "PROPAGATE"
          Gosub INITIALISE_REJECT
      Endcase
    # Issue X3-94378 - end

    When "PRODUCT"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub CHECK_PRODUCT
      Endcase
  Endcase
Return
###############################################################################

# Auto generate the Change request ID (CRID) ...
$AINSERT_BEFORE

  Local Char COUNTER(30)
  Local Char SITE(10)
  Local Date DOCUMENT_DATE
  Local Char COMPLEMENT(30)
  Local Char SEQUENCE_NUMBER(20)
  Local Char ERROR_MESSAGE(100)

  # create transaction counter
  SITE = this.SITE
  DOCUMENT_DATE = date$
  COMPLEMENT = ""
# Issue 109094/17 - separate sequence number for NCM
  If (this.NCSREC = 2)
    COUNTER = "NCSRE"
  Else
    COUNTER = "CCMCR"
  Endif

  ASTATUS = func ANM_TOOL.NUMERO(this.ACTX,
&                                COUNTER,
&                                SITE,
&                                DOCUMENT_DATE,
&                                COMPLEMENT,
&                                SEQUENCE_NUMBER,
&                                ERROR_MESSAGE)

  If (ASTATUS <> CST_AOK)
    ASTATUS = fmet this.ASETERROR("", ERROR_MESSAGE, CST_AERROR)
  Else
    # Issue X3-94378 - for Non-conformance set new ID
    If (this.NCSREC = 2)
      this.NCSID = SEQUENCE_NUMBER
      #this.PLANID = this.NCSID
    Else
      this.CRID = SEQUENCE_NUMBER
    Endif
    # Issue X3-94378 - end
  Endif

Return

# ------------------------------------------------------
# Subroutine: AUPDATE_BEFORE
#
# Called from this Script.
# Set Impact Analysis 'Created' flag = 1 i.e. 'in progress' ...
#
$AUPDATE_BEFORE

  # Issue X3-94378 - do not check to NCS
  If (this.NCSREC <> 2)
    If (this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 1)
      this.IMPACTANAL = 1
    Endif
  Endif

Return

# Subroutine: IMPLEMENT_PLANS
#
# If the Change Request Status changes from Plan to Implement or Implement to Plan then
# sets the IMPLEMENT flag across all Detail Plans.
#
$IMPLEMENT_PLANS

  # Issue X3-94378 - for NCS Plan
  If (this.NCSREC = 2)

      If ((this.NCSSTA = 5 and this.snapshot.NCSSTA = 4) or
&       (this.NCSSTA = 4 and this.snapshot.NCSSTA = 5))
        If (fmet this.IMPLEMENT(CST_AYES, this.NCSSTA) = CST_AERROR)
          ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(57,2038,1), [V]CST_AERROR)
        Endif
      Endif
  Else # Issue X3-94378 - end
    If (this.IMPPLANS <> 100)

      If ((this.CRSTATUS = 5 and this.snapshot.CRSTATUS = 4) or
&       (this.CRSTATUS = 4 and this.snapshot.CRSTATUS = 5))
        If (fmet this.IMPLEMENT(CST_AYES, this.CRSTATUS) = CST_AERROR)
          ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(57,2038,1), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Endif # Issue X3-94378

Return

# --------------------------------------------------
# TIDY_ROWS - Delete redundant (blank) rows,
# from Originator collections ...
$TIDY_ROWS
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet this.DELETE_REDUNDANT_ROWS()

Return

# --------------------------------------------------
$VALIDATE
  If (ASTATUS = CST_AOK)
    Gosub VALIDATE_PRODUCT
  Endif
  If (ASTATUS = CST_AOK)
    Gosub VALIDATE_DROPDOWN
  Endif
  If (ASTATUS = CST_AOK)
    Gosub VALIDATE_ATTACHMENT_CATEGORY
  Endif
Return

# --------------------------------------------------
# Validate product (PRODUCT) and unknown product (PRODDESC).
$VALIDATE_PRODUCT
  # Issue X3-66939 - do not check for Non-conformance
  If (this.NCSREC <> 2)
    If ((this.CRSTATUS = 1 or this.CRSTATUS = 3 or this.CRSTATUS = 7) and this.PRODUCT = "" and this.PRODDESC = "")
      ASTATUS = fmet this.ASETERROR ("", mess(1,2038,1), CST_AERROR)
    Elsif (this.CRSTATUS <> 1 and this.CRSTATUS <> 3 and this.CRSTATUS <> 7 and this.PRODUCT = "")
      ASTATUS = fmet this.ASETERROR ("", mess(6,2038,1), [V]CST_AERROR)
    Endif
  Endif
Return

# --------------------------------------------------
# Validates dropdown lists.
# 1 = - Select -
$VALIDATE_DROPDOWN

  Local Integer I
  # Issue 109094/20 - validate Category
  If (this.NCSREC = 2)
    If (this.NCSCATEGORY = 1)
      ASTATUS = fmet this.ASETERROR ("NCSCATEGORY", mess(22,3702,1), CST_AERROR)
    Endif
  Endif
  # End issue 109094/20

# Version impact (IMPACT)
  If (this.NCSREC = 2)
    If this.IMPACT = 1
      ASTATUS = fmet this.ASETERROR ("IMPACT", mess(7,3702,1), CST_AERROR)
    Endif
  Elsif this.IMPACT = 1
    ASTATUS = fmet this.ASETERROR ("IMPACT", mess(10,2038,1), CST_AERROR)
  Endif

# SEVERITY (SEVERITY)
  If this.SEVERITY = 1
    ASTATUS = fmet this.ASETERROR ("SEVERITY", mess(11,2038,1), CST_AERROR)
  Endif

# Reason for rejection (REJECTCOD)
  # Issue X3-94378 - for NCS
  If (this.NCSREC = 2)
    If this.NCSSTA = 3 and this.REJECTCOD = "" # Issue X3-108668
      ASTATUS = fmet this.ASETERROR ("REJECTCOD", mess(12,2038,1), CST_AERROR)
    Endif
  Else # Issue X3-94378 - end
    If this.CRSTATUS = 3 and this.REJECTCOD = 1
      ASTATUS = fmet this.ASETERROR ("REJECTCOD", mess(12,2038,1), CST_AERROR)
    Endif
  Endif # Issue X3-94378

# Approvers - Transaction type (TRANSTYPE) ...
  If (this.NCSREC <> 2)
    For I = 1 To maxtab(this.CCMAPPROVER)
      If (this.CCMAPPROVER(I).ASTALIN <> CST_ADEL and
&       this.CCMAPPROVER(I).ASTALIN <> CST_ANEWDEL)
        If (this.CCMAPPROVER(I).TRANSTYPE = 1)
          ASTATUS = fmet this.CCMAPPROVER(I).ASETERROR("TRANSTYPE", mess(36,2038,1), CST_AERROR)
        Endif
      Endif
    Next I
  Endif

Return

# --------------------------------------------------
# Validate attachment category (CATEGORY)
# 'Rejection' category can only be assigned if change request status = Rejected
$VALIDATE_ATTACHMENT_CATEGORY

  # Issue X3-77826 - this only applies for CCM
  If (this.NCSREC <> 2)
    For I = 1 To maxtab(this.CCMCRNOTES)
      If (this.CCMCRNOTES(I).CATEGORY = 7 and this.CRSTATUS <> 3)
          ASTATUS = fmet this.ASETERROR ("", mess(4,2038,1), CST_AERROR)
      Endif
    Next
  Endif

# --------------------------------------------------
# If change manager change then audit the user and date.
$AUDIT_STATUS_CHANGE

  If (this.NCSREC =2)
    # Issue X3-67933 - only set if QA manager not blank and changed
    If (this.snapshot.NCSMANAGER <> "" and this.snapshot.NCSMANAGER <> this.NCSMANAGER)
      this.CHGMANDAT = date$
      this.CHGMANUSR = this.ACTX.USER
    Endif
  Else
    If (this.snapshot.CCMUSRID <> this.CCMUSRID)
      this.CHGMANDAT = date$
      this.CHGMANUSR = this.ACTX.USER
    Endif
  Endif

  # Issue X3-94378
  If (this.NCSREC= 2)
    If (this.NCSSTA = 3)
      this.REJECTDAT = date$
      this.REJECTUSR = this.ACTX.USER
    Endif
  Else
    If (this.CRSTATUS = 3)
      this.REJECTDAT = date$
      this.REJECTUSR = this.ACTX.USER
    Endif
  Endif

Return

# --------------------------------------------------
# When status is set to 'Rejected' or 'Completed' set the CLOSEDSTATE.
$STORE_CLOSEDSTATE

  # Issue X3-94378 - for NCS
  If (this.NCSREC = 2)
    If this.NCSSTA = 3
      this.CLOSEDST = 2
    Elsif this.NCSSTA = 6
      this.CLOSEDST = 3
    Elsif this.NCSSTA <> 7
      this.CLOSEDST = 1
    Endif
    If (this.snapshot.NCSSTA <> 7 and this.NCSSTA = 7)
      this.CLOSEDATE = date$
    Endif
  Else
    If this.CRSTATUS = 3
      this.CLOSEDST = 2
    Elsif this.CRSTATUS = 6
      this.CLOSEDST = 3
    Elsif this.CRSTATUS <> 7
      this.CLOSEDST = 1   #When CRSTATUS is not closed assign '-Select-' as default value
    Endif
    If (this.snapshot.CRSTATUS <> 7 and this.CRSTATUS = 7)
      this.CLOSEDATE = date$
    Endif
  Endif
  # Issue X3-94378 - end

Return

# --------------------------------------------------
# Create Impact Analysis for Sales Order ...
$CREATE_IMPACT_SALES_ORDER

  Local Integer LOCAL_STATUS
  Local Char MESSAGE(100), TRANSACTION_TYPE(50)
  Local Instance SO_HEADER Using C_CCMIMPSOH
  SO_HEADER = NewInstance C_CCMIMPSOH AllocGroup null

  LOCAL_STATUS = fmet SO_HEADER.AREAD(this.CRID)

  TRANSACTION_TYPE = mess(10,2039,1)

  If (LOCAL_STATUS = CST_AOK)  # Impact Analysis already exists ...

    MESSAGE = func ASYRFNC.MES1(mess(66,2038,1), TRANSACTION_TYPE)
    ALOG_RET = fmet ALOG.APUTLINE(MESSAGE, CST_AWARNING)

  Else                         # Impact Analysis does not already exist ...

    MESSAGE = func ASYRFNC.MES1(mess(67,2038,1), TRANSACTION_TYPE)
    ALOG_RET = fmet ALOG.APUTLINE(MESSAGE, 0)

    LOCAL_STATUS = fmet SO_HEADER.AINIT()
    SO_HEADER.CRID = this.CRID
    LOCAL_STATUS = fmet SO_HEADER.AINSERT()
    LOCAL_STATUS = fmet SO_HEADER.CREATE_SALES_ORDERS (this.CRID)

  Endif

  FreeGroup SO_HEADER

Return

