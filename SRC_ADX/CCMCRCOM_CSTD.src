# --------------------------------------------------
# Custom Method: CHECK_USER_SITE
#
# Parameters: USER - user to check (blank = logged-in user),
#             SITE - site to check (mandatory),
#             TRANSACTION_TYPE - transaction type to check (mandatory).
#
#
$CHECK_USER_SITE

  Local Integer AFCRIGHTFCY, CONTEXT_STATUS
  Local Char FUNCTION(30)
  Local Instance CONTEXT Using C_WMACONTEXT
  CONTEXT = NewInstance C_WMACONTEXT AllocGroup null
  # Issue X3-38618 - 2017-06-07 by STLIG : Initialise context with user login..
  Local Instance USR Using C_AUTILIS
  USR = NewInstance C_AUTILIS AllocGroup null

  AFCRIGHTFCY = CST_AOK
  FUNCTION = ""

  If (USER <> "")

      Case TRANSACTION_TYPE
        When 3  : FUNCTION = "GESBOD"         # BOMs            ... not Site
        When 4  : FUNCTION = "GESBPC"         # Customer        ... not Site
        When 11 : FUNCTION = "GESITM"         # Stock           ... not Site
        When 13 : FUNCTION = "GESBPS"         # Supplier        ... not Site
      Endcase
    If (SITE <> "")
      Case TRANSACTION_TYPE
        When 5  : FUNCTION = "GESORZ"         # Demand Forecast (Manufacturing)
        When 6  : FUNCTION = "GESPSH"         # PO request
        When 7  : FUNCTION = "GESPOH"         # Purchase Order
        When 8  : FUNCTION = "GESSQH"         # Quotation
        When 9  : FUNCTION = "GESROU"         # Routing
        When 10 : FUNCTION = "GESSOH"         # Sales order
        When 12 : FUNCTION = "GESSCO"         # Sub contract order
        When 14 : FUNCTION = "GESMFG"         # Works order
      Endcase
    Else
      SITE = "X"
    Endif

    If (FUNCTION <> "")

      # Issue X3-38618 - 2017-06-07 by STLIG : Initialise context with user login..
      STAT = fmet USR.AREAD(USER)
      CONTEXT_STATUS = fmet CONTEXT.ACTX_INIT_LAN(this.ACTX.AFOLDER, this.ACTX.LAN, USR.LOGIN)

      If (CONTEXT_STATUS = 0) # context ok ...
        AFCRIGHTFCY = fmet CONTEXT.AGETAFCRIGHTFCY(this, FUNCTION, SITE, CST_AFALSE)
      Else                    # context not ok ...
        ASTATUS = fmet this.ASETERROR("", "", CST_AERROR)
        AFCRIGHTFCY = CST_AERROR
      Endif

    Endif

  Endif

  ARET_VALUE = AFCRIGHTFCY
  FreeGroup CONTEXT
  # Issue X3-38618 - 2017-06-07 by STLIG : Initialise context with user login..
  FreeGroup USR

Return


# ------------------------------------------------------
# Subroutine: CREATE_IMPACT_ANALYSIS_BATCH_SERVER
#
# Called from this Script.
# Save Change Request 'In Review' - Instantiate Batch Server process, Task: CCMIMPBATT.
#
$CREATE_IMPACT_ANALYSIS_BATCH_SERVER

  Local Integer LOCAL_STATUS

  Local Char MESSAGE(250)

  Local Char    AFOLDER(30)
  Local Char    USER(30)
  Local Char    TASKNAME(30)
  Local Date    DAT
  Local Char    TIM(5)
  Local Char    TBPAR(30)(1..10)
  Local Char    TBVAL(250)(1..10)
  Local Integer NBPAR
  Local Integer TASKID
  Local Char    TASKMESSAGE(250)

  Local Integer LTIME
  Local Char    CTIME(4)

  # Issue X3-62810 - for Non-conformance, do not create impact analysis
  If (this.NCSREC <> 2 and this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 1)

    LTIME = time : CTIME = format$("N00:2", int(LTIME/3600)) +format$("N00:2", int((LTIME -(int(LTIME/3600) *3600)) /60))

    USER      = this.ACTX.USER
    TASKNAME  = "CCMIMPBATT"
    DAT       = date$
    TIM       = CTIME
    NBPAR = 1  : TBPAR(NBPAR) = "CRID"        : TBVAL(NBPAR) = this.CRID
    NBPAR += 1 : TBPAR(NBPAR) = "TRANSACTION" : TBVAL(NBPAR) = "0"

    ASTATUS = func ASYRMNGTREQ.CRERQT(this.ACTX,
&                              this.ACTX.AFOLDER,
&                              USER,
&                              TASKNAME,
&                              DAT,
&                              TIM,
&                              TBPAR,
&                              TBVAL,
&                              NBPAR,
&                              TASKID,
&                              TASKMESSAGE)

    If (ASTATUS <> CST_AOK)
      LOCAL_STATUS = fmet this.ASETERROR("", MESSAGE, CST_AERROR)
    Else
      MESSAGE = func ASYRFNC.MES1(mess(71,2038,1), num$(TASKID))
      LOCAL_STATUS = fmet this.ASETERROR("", MESSAGE, CST_AINFO)
    Endif

  Endif

Return

# ------------------------------------------------------
# Class Method: CREATE_IMPACT_ANALYSIS
#
# Parameter:    None
# Return Value: CST_AOK
#
# Called from Batch Server process via Script: CCMIMPBATCH.
#
$CREATE_IMPACT_ANALYSIS

  Local Instance ALOG Using C_ALOG
  ALOG = NewInstance C_ALOG AllocGroup null
  Local Integer ALOG_RET

  ALOG_RET = fmet ALOG.ASETNAME(this.CRID)
  ALOG_RET = fmet ALOG.ABEGINLOG(mess(65,2038,1))

  Gosub CREATE_IMPACT_SALES_ORDER
  Gosub CREATE_IMPACT_SALES_QUOTE
  Gosub CREATE_IMPACT_PURCHASE_ORDER
  Gosub CREATE_IMPACT_PURCHASE_REQUEST
  Gosub CREATE_IMPACT_WORK_ORDERS
  Gosub CREATE_IMPACT_SUB_CONTRACT
  Gosub CREATE_IMPACT_FORECAST
  Gosub CREATE_IMPACT_PRODUCT_BY_SITE
  Gosub CREATE_IMPACT_BOM
  Gosub CREATE_IMPACT_ROUTING

  ALOG_RET = fmet ALOG.AENDLOG()

  ARET_VALUE = CST_AOK

Return

# ------------------------------------------------------------
# Method: IS_PRODUCT_VERSION_MANAGED
#
# Is the Product (Parameter) Version Managed?
# 1 - Not managed
# 2 - Maajor version
# 3 - Major and Minor version
#
$IS_PRODUCT_VERSION_MANAGED

  Local Instance ITMMASTER Using C_ITMMASTER
  ITMMASTER = NewInstance C_ITMMASTER AllocGroup null
  Local Integer LOCAL_STATUS

  ARET_VALUE = 1

  If (PRODUCT <> "")
    LOCAL_STATUS = fmet ITMMASTER.AREAD(PRODUCT)

    If (LOCAL_STATUS = CST_AOK)
      If (ITMMASTER.ECCSTO = 2 or ITMMASTER.ECCSTO = 3)

        ARET_VALUE = ITMMASTER.ECCSTO

      Endif
    Endif

  Endif

  FreeGroup ITMMASTER

Return

#
# --------------------------------------------------
# FUNCTION NAME:        BUILD_EMAIL
# FUNCTION DESCRIPTION: Build the Subject and Body email text.
# FUNCTION TYPE:        Method
# PARAMETERS:           EMAIL_TYPE (Value)   - determines the Local Menu.
#                       SUBJECT (Address)    - the Subject email text.
#                       BODY (Address)       - the Body email text.
#                       OTHER_BODY (Address) - the Other Body email text.
#                       REPRESENTATION       - Representation
# RETURN_VALUE:         Status.
#
#
$BUILD_EMAIL

  Local Integer STAT
  Local Clbfile EMAIL_URL

  STAT = fmet this.BUILD_EMAIL_URL(EMAIL_TYPE, EMAIL_URL, REPRESENTATION)

  # Build Subject ...
  SUBJECT = func ASYRFNC.MES1(mess(1,EMAIL_TYPE,1), this.CRID)

  # Build Body ...
  For I = 2 To len(mess(0,EMAIL_TYPE,1))

    # Insert OTHER_BODY ...
    If (I = len(mess(0,EMAIL_TYPE,1)) and
&       OTHER_BODY <> AVOID.ACLOB)
      Append BODY, chr$(10)
      Append BODY, OTHER_BODY +chr$(10)
      Append BODY, chr$(10)
    Endif

    Append BODY, mess(I,EMAIL_TYPE,1) +chr$(10)
  Next I

  Append BODY, chr$(10)
  Append BODY, EMAIL_URL +chr$(10)

  ARET_VALUE = STAT

Return

#
# --------------------------------------------------
# FUNCTION NAME:        BUILD_EMAIL_URL
# FUNCTION DESCRIPTION: Send Email Notification.
# FUNCTION TYPE:        Method
# PARAMETERS:           EMAIL_TYPE (Value)  - determines the Local Menu.
#                       EMAIL_URL (Address) - the URL.
#                       REPRESENTATION      - Representation.
# RETURN_VALUE:         Status.
#
#
$BUILD_EMAIL_URL

  Local Integer STAT
  Local Integer FULLURL
  Local Integer FACET
  Local Char TABKEY(50)(1..10), TABKEYVAL(50)(1..10), TABPAR(50)(1..10), TABPARVAL(50)(1..10)

  FULLURL = CST_ATRUE
  FACET = CST_AFAC_DETAILS
  TABKEY(1) = "CRID" : TABKEYVAL(1) = this.CRID

  # Format URL ...
  STAT = func ASYRFNC.AGET_SYRAURL
&       (
&         this.ACTX,
&         FULLURL,
&         REPRESENTATION,
&         FACET,
&         TABKEY,
&         TABKEYVAL,
&         TABPAR,
&         TABPARVAL,
&         EMAIL_URL
&       )

  ARET_VALUE = STAT

Return

#
# --------------------------------------------------
# FUNCTION NAME:        SEND_EMAIL
# FUNCTION DESCRIPTION: Build the URL
# FUNCTION TYPE:        Method
# PARAMETERS:           FROM_USER (Value) - the from User.
#                       TO_USER (Value)   - the to User.
#                       CC_USER (Value)   - the cc User.
#                       SUBJECT (Value)   - the Subject email text.
#                       BODY (Value)      - the Body email text.
# RETURN_VALUE:         Status.
#
#
$SEND_EMAIL

  Local Integer STAT
  Local Char FROM_EMAIL(250)(1..), TO_EMAIL(250)(1..), CC_EMAIL(250)(1..)
  Local Char ATTACHMENT(250)(1..)
  Local Integer TRACE
  Local Char ERROR_MESSAGE(250)

  ASTATUS = CST_AOK

  # Get Workflow email addresses ...
  STAT = fmet this.GET_USER_EMAIL(FROM_USER, FROM_EMAIL(1))
  If (STAT > 0)
    ERROR_MESSAGE = func ASYRFNC.MES1(mess(52,2038,1), FROM_USER)
    ASTATUS = fmet this.ASETERROR("", ERROR_MESSAGE, CST_AWARNING)
  Endif
  STAT =   fmet this.GET_USER_EMAIL(TO_USER, TO_EMAIL(1))
  If (STAT > 0)
    ERROR_MESSAGE = func ASYRFNC.MES1(mess(52,2038,1), TO_USER)
    ASTATUS = fmet this.ASETERROR("", ERROR_MESSAGE, CST_AWARNING)
  Endif
  STAT =   fmet this.GET_USER_EMAIL(CC_USER, CC_EMAIL(1))

  If (ASTATUS = CST_AOK)
    ATTACHMENT(1) = ""
    TRACE = CST_ANO

    # Send email ...
    STAT = func ASYRMAIL.ASEND_MAIL
&         (
&           this.ACTX,
&           FROM_EMAIL,
&           TO_EMAIL,
&           CC_EMAIL,
&           SUBJECT,
&           BODY,
&           ATTACHMENT,
&           TRACE
&         )

    If (STAT <> CST_AOK)
      ASTATUS = STAT
    Endif
  Endif

  ARET_VALUE = ASTATUS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        GET_USER_EMAIL
# FUNCTION DESCRIPTION: Get User Workflow email address
# FUNCTION TYPE:        Method
# PARAMETERS:           USER (Value)         - the User.
#                       USER_EMAIL (Address) - the User Workflow email address.
# RETURN_VALUE:         Status.
#
#
$GET_USER_EMAIL

  Local Integer STAT
  Local Instance AUTILIS Using C_AUTILIS
  AUTILIS = NewInstance C_AUTILIS AllocGroup null

  ARET_VALUE = 0
  USER_EMAIL = ""

  If (USER <> "")
    STAT = fmet AUTILIS.AREAD(USER)
    If (STAT = CST_AOK)
      If (AUTILIS.ADDEML <> "")
        USER_EMAIL = AUTILIS.ADDEML
      Else
        ARET_VALUE = 3  # Blank e-mail.
      Endif
    Else
      ARET_VALUE = 2    # Invalid <USER>.
    Endif
  Else
    ARET_VALUE = 1      # Blank <USER>.
  Endif

Return

# --------------------------------------------------
# Validate change request status (CRSTATUS),

$VALIDATE_STATUS

  Local Char MESSAGE(100)
  Local Integer TOTALPLANLINES, I
  Local Integer LOCSTATUS
  Local Instance SELPLANH Using C_CCMPLANH
  SELPLANH = NewInstance C_CCMPLANH AllocGroup null

  # Statuses cannot be reverted to New
  If (this.CRSTATUS = 1 and this.snapshot.CRSTATUS > 1)
    MESSAGE = func ASYRFNC.MES2(mess(24,2038,1), mess(this.snapshot.CRSTATUS,2033,1), mess(this.CRSTATUS,2033,1))
    ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)
  Elsif (this.CRSTATUS <> this.snapshot.CRSTATUS)

    MESSAGE = func ASYRFNC.MES2(mess(24,2038,1), mess(this.snapshot.CRSTATUS,2033,1), mess(this.CRSTATUS,2033,1))

     # Status can only be set to 'in review' if the previous status is 'new' or Rejected, or Plan
     If(this.CRSTATUS = 2 and this.snapshot.CRSTATUS <> 1 and this.snapshot.CRSTATUS <> 3 and this.snapshot.CRSTATUS <> 4)
       ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     Elsif (this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 3)
       LOCSTATUS = fmet this.ASETERROR ("CRSTATUS", mess(37,2038,1), [V]CST_AINFO)

     # Status can only be set to 'rejected' if the previous status is 'New' or 'In review'
     Elsif(this.CRSTATUS = 3 and this.snapshot.CRSTATUS <> 2 and this.snapshot.CRSTATUS <> 1 )
        ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     # Status can only be set to 'plan' if the previous status is 'in review' or Implement
     Elsif (this.CRSTATUS = 4 and this.snapshot.CRSTATUS <> 2 and this.snapshot.CRSTATUS <> 5)
        ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     # Status can only be set to 'Closed'if previously 'Rejected' or 'Completed'
     Elsif (this.CRSTATUS = 7 and (this.snapshot.CRSTATUS <> 3) and (this.snapshot.CRSTATUS <> 6))
        ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     # If setting status to Implement, check previous status is Plan
     Elsif (this.CRSTATUS = 5 and this.snapshot.CRSTATUS <> 4)
        ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     # if setting status to Implement and previous status is Plan, check Plan exists,
     # and Actioner and Complete by date are entered for each action defined
     Elsif (this.CRSTATUS = 5 and this.snapshot.CRSTATUS = 4)

          If (fmet this.IMPLEMENT(CST_ANO, this.CRSTATUS) = CST_AERROR)
            ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(57,2038,1), [V]CST_AERROR)
          Endif

     # if setting status to Plan or In-review  and previous status is Implement, check Plan exists,
     # and is Pending
     Elsif ((this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 4 ) or (this.CRSTATUS = 4 and this.snapshot.CRSTATUS = 5))
       # Check plan exists
        ASTATUS = fmet SELPLANH.AREAD(this.CRID)
        If ASTATUS <> CST_AOK
           ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(25,2038,1), [V]CST_AERROR)
        Elsif (SELPLANH.PLANSTATUS <> 1)
            ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(32,2038,1), [V]CST_AERROR)
        # display warning that Plan will be deleted
        Elsif (this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 4)
            LOCSTATUS = fmet this.ASETERROR ("CRSTATUS", mess(33,2038,1), [V]CST_AINFO)
        Endif

     # If setting status to Complete, check previous status is Implement
     Elsif (this.CRSTATUS = 6 and this.snapshot.CRSTATUS <> 5 )
        ASTATUS = fmet this.ASETERROR ("CRSTATUS", MESSAGE, [V]CST_AERROR)

     # if setting status to Complete and previous status is Implement, check Plan status
     # is Completed
     Elsif (this.CRSTATUS = 6 and this.snapshot.CRSTATUS = 5 )

        # Check plan exists
        ASTATUS = fmet SELPLANH.AREAD(this.CRID)
        If ASTATUS <> CST_AOK
           ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(25,2038,1), [V]CST_AERROR)
        Else
           If (SELPLANH.PLANSTATUS < 3)
              ASTATUS = fmet this.ASETERROR ("CRSTATUS", mess(29,2038,1), [V]CST_AERROR)
           Endif
        Endif
     Endif
  Endif
  FreeGroup SELPLANH
Return

# --------------------------------------------------
# Issue X3-94378 - VALIDATE NON-CONFORMANCE status (NCSSTA),

$VALIDATE_NCS_STATUS

  Local Char MESSAGE(100)
  Local Integer TOTALPLANLINES, I
  Local Integer LOCSTATUS
  Local Instance SELPLANH Using C_PLANHDR
  SELPLANH = NewInstance C_PLANHDR AllocGroup null

  # Statuses cannot be reverted to New
  If (this.NCSSTA < 1 or this.NCSSTA > 7)
    ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(42,3702,1), [V]CST_AERROR)
  Elsif (this.NCSSTA = 1 and this.snapshot.NCSSTA > 1)
    MESSAGE = func ASYRFNC.MES2(mess(24,2038,1), mess(this.snapshot.NCSSTA,2033,1), mess(this.NCSSTA,2033,1))
    ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)
  Elsif (this.NCSSTA <> this.snapshot.NCSSTA)

    MESSAGE = func ASYRFNC.MES2(mess(24,2038,1), mess(this.snapshot.NCSSTA,2033,1), mess(this.NCSSTA,2033,1))

     # Status can only be set to 'in review' if the previous status is 'new' or Rejected, or Plan
     If(this.NCSSTA = 2 and this.snapshot.NCSSTA <> 1 and this.snapshot.NCSSTA <> 3 and this.snapshot.NCSSTA <> 4)
       ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     Elsif (this.NCSSTA = 2 and this.snapshot.NCSSTA = 3)
       LOCSTATUS = fmet this.ASETERROR ("NCSSTA", mess(37,2038,1), [V]CST_AINFO)

     # Status can only be set to 'rejected' if the previous status is 'New' or 'In review'
     Elsif(this.NCSSTA = 3 and this.snapshot.NCSSTA <> 2 and this.snapshot.NCSSTA <> 1 )
        ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     # Status can only be set to 'plan' if the previous status is 'in review' or Implement
     # X3-67933 - for non-conformance status can be changed from New to Plan
     Elsif (this.NCSSTA = 4 and this.snapshot.NCSSTA <> 2 and this.snapshot.NCSSTA <> 5 and this.snapshot.NCSSTA <> 1)
        ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     # Status can only be set to 'Closed'if previously 'Rejected' or 'Completed'
     Elsif (this.NCSSTA = 7 and (this.snapshot.NCSSTA <> 3) and (this.snapshot.NCSSTA <> 6))
        ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     # If setting status to Implement, check previous status is Plan
     Elsif (this.NCSSTA = 5 and this.snapshot.NCSSTA <> 4)
        ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     # if setting status to Implement and previous status is Plan, check Plan exists,
     # and Actioner and Complete by date are entered for each action defined
     Elsif (this.NCSSTA = 5 and this.snapshot.NCSSTA = 4)

          If (fmet this.IMPLEMENT(CST_ANO, this.NCSSTA) = CST_AERROR)
            ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(57,2038,1), [V]CST_AERROR)
          Endif

     # if setting status to Plan or In-review  and previous status is Implement, check Plan exists,
     # and is Pending
     Elsif ((this.NCSSTA = 2 and this.snapshot.NCSSTA = 4 ) or (this.NCSSTA = 4 and this.snapshot.NCSSTA = 5))
       # Check plan exists
        ASTATUS = fmet SELPLANH.AREAD(this.NCSID)
        If ASTATUS <> CST_AOK
           ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(25,2038,1), [V]CST_AERROR)
        Elsif (SELPLANH.PLANSTATUS <> 1)
            ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(32,2038,1), [V]CST_AERROR)
        # display warning that Plan will be deleted
        Elsif (this.NCSSTA = 2 and this.snapshot.NCSSTA = 4)
            LOCSTATUS = fmet this.ASETERROR ("NCSSTA", mess(33,2038,1), [V]CST_AINFO)
        Endif

     # If setting status to Complete, check previous status is Implement
     Elsif (this.NCSSTA = 6 and this.snapshot.NCSSTA <> 5 )
        ASTATUS = fmet this.ASETERROR ("NCSSTA", MESSAGE, [V]CST_AERROR)

     # if setting status to Complete and previous status is Implement, check Plan status
     # is Completed
     Elsif (this.NCSSTA = 6 and this.snapshot.NCSSTA = 5 )

        # Check plan exists
        ASTATUS = fmet SELPLANH.AREAD(this.PLANID)
        If ASTATUS <> CST_AOK
           ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(25,2038,1), [V]CST_AERROR)
        Else
           If (SELPLANH.PLANSTATUS < 3)
              ASTATUS = fmet this.ASETERROR ("NCSSTA", mess(29,2038,1), [V]CST_AERROR)
           Endif
        Endif
     Endif
  Endif
  FreeGroup SELPLANH
Return
# Issue X3-94378 - end

# --------------------------------------------------
# Validate duplicate product ...
$CHECK_PRODUCT

  Local Char DUP_MESSAGE(100)
  Local Integer DUP_STATUS
  Local Integer LOCSTATUS

  DUP_STATUS = fmet this.DUPLICATE_PRODUCT(DUP_MESSAGE)
  If (DUP_STATUS = CST_AERROR)
    ASTATUS = fmet this.ASETERROR("PRODUCT", DUP_MESSAGE, DUP_STATUS)
  Elsif (DUP_STATUS = CST_AINFO)
    LOCSTATUS = fmet this.ASETERROR("PRODUCT", DUP_MESSAGE, DUP_STATUS)
  Endif

Return

# --------------------------------------------------
#  if Change Request status is changed to "In Review" from "Rejected", then initialise REJECTCOD
$INITIALISE_REJECT

# Issue X3-94378 - For NCS
If (this.NCSREC = 2)
  If (this.NCSSTA = 2 and this.snapshot.NCSSTA = 3)
    this.REJECTCOD = "" # Issue X3-108668
    this.REJECTDAT = AVOID.ADATE
    this.REJECTUSR = ""
    this.REJDESC = "{\rtf1\ansi\deff0 {\fonttbl {\f0 Times New Roman;}}\f0\fs20 }"
  Endif
Else
  If (this.CRSTATUS = 2 and this.snapshot.CRSTATUS = 3)
    this.REJECTCOD = 1
    this.REJECTDAT = AVOID.ADATE
    this.REJECTUSR = ""
    this.REJDESC = "{\rtf1\ansi\deff0 {\fonttbl {\f0 Times New Roman;}}\f0\fs20 }"
  Endif
Endif
# End issue X3-94378
Return

