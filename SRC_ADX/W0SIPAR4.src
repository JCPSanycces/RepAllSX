#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBVAC1
mkstat = 0
zoncou = "NBVAC1"
indice = 0
status = 1
zoncou = "NBVAC1"
If varmode([M]NBVAC1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBVAC1" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBVAC1
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBVAC1 = nolign
   status = 75
   Call SAI_NBVAC1(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBVAC2
mkstat = 0
zoncou = "NBVAC2"
indice = 0
status = 1
zoncou = "NBVAC2"
If varmode([M]NBVAC2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBVAC2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBVAC2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBVAC2 = nolign
   status = 75
   Call SAI_NBVAC2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone VACITM3
mkstat = 0
zoncou = "VACITM3"
indice = 0
If varmode([M]VACITM3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VACITM3" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTVI"
 Call CONTTVI([M]VACITM3,"","","","","","") From SUBTVI
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "VACITM3" : GZNUM = 31844 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]VACITM3
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]VACITM3 = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VACITM3" : GZNUM = 31844 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBVACC
mkstat = 0
zoncou = "NBVACC"
indice = 0
status = 1
zoncou = "NBVACC"
If varmode([M]NBVACC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBVACC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBVACC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBVACC = nolign
   status = 75
   Call SAI_NBVACC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBVACS
mkstat = 0
zoncou = "NBVACS"
indice = 0
status = 1
zoncou = "NBVACS"
If varmode([M]NBVACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBVACS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBVACS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBVACS = nolign
   status = 75
   Call SAI_NBVACS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBVAC1(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBVAC1
mkstat = 0
zoncou = "NBVAC1"

## Zone VACITM1
mkstat = 0
zoncou = "VACITM1"
If varmode([M]VACITM1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VACITM1" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]VACITM1(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VACITM1" : GZNUM = 3705 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTTVI"
  Call CONTTVI([M]VACITM1(indice),"","","","","","") From SUBTVI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VACITM1" : GZNUM = 3705 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]VACITM1(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]VACITM1(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VACITM1" : GZNUM = 3705 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBVAC1
mkstat = 0
zoncou = "NBVAC1"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBVAC2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBVAC2
mkstat = 0
zoncou = "NBVAC2"

## Zone VACITM2
mkstat = 0
zoncou = "VACITM2"
If varmode([M]VACITM2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VACITM2" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTVI"
 Call CONTTVI([M]VACITM2(indice),"","","","","","") From SUBTVI
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "VACITM2" : GZNUM = 3705 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]VACITM2(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]VACITM2(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VACITM2" : GZNUM = 3705 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBVAC2
mkstat = 0
zoncou = "NBVAC2"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBVACC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBVACC
mkstat = 0
zoncou = "NBVACC"

## Zone PAYC
mkstat = 0
zoncou = "PAYC"
If varinit([M]PAYC,indice)=0
 [M]PAYC(indice) = GPAYS
Endif

## Zone VACTPF
mkstat = 0
zoncou = "VACTPF"
IMPENT = [M]VACTPF(indice)
If varinit([M]VACTPF,indice)=0
 IMPENT = 1
Endif
[M]VACTPF(indice) = IMPENT

## Zone VACADD
mkstat = 0
zoncou = "VACADD"
IMPENT = [M]VACADD(indice)
If varinit([M]VACADD,indice)=0
 IMPENT = 1
Endif
[M]VACADD(indice) = IMPENT

## Zone VACBPC
mkstat = 0
zoncou = "VACBPC"
If varmode([M]VACBPC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VACBPC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]VACBPC(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VACBPC" : GZNUM = 3673 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTTVB"
  Call CONTTVB([M]VACBPC(indice),GCURLEG,"SIPAR4","VACBPC",[M:SIP0]FCY,"",[M:SIP0]CPY) From SUBTVB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VACBPC" : GZNUM = 3673 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]VACBPC(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]VACBPC(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VACBPC" : GZNUM = 3673 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CLTEXI
mkstat = 0
zoncou = "CLTEXI"
IMPENT = [M]CLTEXI(indice)
If varinit([M]CLTEXI,indice)=0
 IMPENT = 1
Endif
[M]CLTEXI(indice) = IMPENT

## Zone NBVACC
mkstat = 0
zoncou = "NBVACC"

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBVACS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBVACS
mkstat = 0
zoncou = "NBVACS"

## Zone PAYS
mkstat = 0
zoncou = "PAYS"
If varinit([M]PAYS,indice)=0
 [M]PAYS(indice) = GPAYS
Endif

## Zone VACBPS
mkstat = 0
zoncou = "VACBPS"
If varmode([M]VACBPS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VACBPS" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]VACBPS(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VACBPS" : GZNUM = 3673 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTTVB"
  Call CONTTVB([M]VACBPS(indice),GCURLEG,"SIPAR4","VACBPS",[M:SIP0]FCY,"",[M:SIP0]CPY) From SUBTVB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VACBPS" : GZNUM = 3673 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]VACBPS(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]VACBPS(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VACBPS" : GZNUM = 3673 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FOUEXI
mkstat = 0
zoncou = "FOUEXI"
IMPENT = [M]FOUEXI(indice)
If varinit([M]FOUEXI,indice)=0
 IMPENT = 1
Endif
[M]FOUEXI(indice) = IMPENT

## Zone NBVACS
mkstat = 0
zoncou = "NBVACS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR4"
Return

