#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTIACHJ38669  Utilitaire de resynchronisation des         Module ACHAT #
#               Montant totaux lignes en entête                          #
#               de réception                                  25/05/2017 #
# ---------------------------------------------------------------------- #
# Champs de l'entête de réception vérifiés et réajustés si nécessaire    #
#   [F:PTH]TOTAMTNOT : Total HT                                          #
#   [F:PTH]TOTAMTNOTL: Total HT devise soc                               #
#   [F:PTH]TOTTAXAMT : Total taxes                                       #
#   [F:PTH]TOTAMTATI : Total TTC                                         #
#   [F:PTH]TOTAMTATIL: Total TTC devise soc                              #
# ---------------------------------------------------------------------- #
##########################################################################


Call MAJ_UTIACHJ38669
End


Subprog MAJ_UTIACHJ38669
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACHJ38669 - Update Receipts header Amounts") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACHJ38669 : Synchronisation of Receipts header amounts ") From LECFIC
  Call EXE_UTIACHJ38669(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACHJ38669(DOSSIER)
Value Char     DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), WCRITERE(100)
Local Integer  NBENR, NBCOR
Local Char     WCLE1(GLONPTH)
Local Char     WPTHNUM(GLONPTH)
Local Char     WFCY(GLONFCY)
Local Integer  WCOMPTEUR, WSTOP
Local Decimal  WINVDTAAMT, WAMTTAX
Local Decimal  WTOTAMTNOT, WTOTAMTNOTL, WTOTAMTATI,WTOTAMTATIL, WTATTAXAMT
Local Libelle  WFLAG
Local Integer  WSTAT
Local Libelle  WTRACE : WTRACE=2 : # WTRACE=2 --> Trace détaillée
#-----
Call ECR_TIME("UTIACHJ38669 : Start process  "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:PTH])  Local File =DOSSIER+".PRECEIPT"    [PTH] : Endif
If !clalev([F:PVF])  Local File =DOSSIER+".PVCRFOOT"    [PVF] : Endif
If !clalev([F:PVC])  Local File =DOSSIER+".PVCRVAT"     [PVV] : Endif
#----- Début du traitement -----#
Raz NBENR, NBCOR
Gosub TRT_TOTAMTX
#----- Fin du traitement -----#
$FIN_UTIACHJ38669
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACHJ38669 : Records updated :"-num$(NBENR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [PTH], [PVF],[PVV]
End


#------------#
# Traitement #
#------------#
$TRT_TOTAMTX
Call DEBTRANS From GLOCK
Raz WCLE1, WSTOP
#-----
$BOUCLE_TOTAMTX
GOK=1
If WSTOP=1
   WSTOP=0 : WCRITERE='PTHNUM>'+'"'+num$(WCLE1)+'"'
Else
  WCRITERE="1=1"
Endif

WCRITERE += "& TOTAMTNOT = 0"
Raz WCOMPTEUR
#-----
Trbegin [PTH]
  For [PTH] PTH1 Where evalue(WCRITERE)
    NBENR+=1
    WPTHNUM=[F:PTH]PTHNUM
    Raz WINVDTAAMT, WAMTTAX,  WFLAG, WTOTAMTNOT, WTOTAMTNOTL, WTOTAMTATI, WTOTAMTATIL, WTATTAXAMT
    If WFCY <> [F:PTH]PRHFCY
       WFCY =  [F:PTH]PRHFCY
       Call GETDEV(DOSSIER,WFCY) From TRTX3CPT
    Endif
    #-----
    For [PVF]PVF0  Where  VCRNUM=[F:PTH]PTHNUM & VCRTYP = 6
     WINVDTAAMT += [PVF]INVDTAAMT
    Next
    For [PVV]PVV0  Where VCRNUM=[F:PTH]PTHNUM & VCRTYP = 6
     WAMTTAX += [PVV]AMTTAX
    Next
    #-----
    If WTRACE=2
       WMSG ="Receipt"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
       Call ECR_TRACE(WMSG,0) From GESECRAN
    Endif
    WTOTAMTNOT=WINVDTAAMT+[F:PTH]TOTLINAMT
    If [F:PTH]VACTYP<>4
      WTOTTAXAMT=WAMTTAX
      WTOTAMTATI=WINVDTAAMT+[F:PTH]TOTLINAMT+WAMTTAX
    Else
      WTOTTAXAMT=0
      WTOTAMTATI=WINVDTAAMT+[F:PTH]TOTLINAMT
    Endif
    Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&            WTOTAMTNOT,WTOTAMTNOTL,[F:PTH]CHGCOE,WSTAT) From TRTDEV
    Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&            WTOTAMTATI,WTOTAMTATIL,[F:PTH]CHGCOE,WSTAT) From TRTDEV
    #-----
    Update [PTH] Where PTHNUM=WPTHNUM
&                  With TOTAMTNOT=WTOTAMTNOT, TOTAMTNOTL=WTOTAMTNOTL, TOTAMTATI=WTOTAMTATI, TOTAMTATIL=WTOTAMTATIL, TOTTAXAMT=WTOTTAXAMT
      If fstat
        WMSG=mess(13,100,1)-"PRECEIPT"-WPTHNUM
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
        WSTOP=0 : Break
      Endif
      #-----
      WCOMPTEUR+=1 : NBCOR+=1
    #-----
    If WCOMPTEUR>GMAXUPDTRS
      WCLE1=[F:PTH]PTHNUM : WSTOP=1 : Break
    Endif
  Next
Commit
#-----
If WSTOP  Goto BOUCLE_TOTAMTX : Endif
#-----
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH (DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACHJ38669(DOSSIER)
Endif
#-----
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACHJ38669(DOSSIER)
Endif
#-----
End

