$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 52408: RES='Code motif économique'
   When 26213: RES='Législation'
   When 52408: RES='Code motif économique'
   When 250: RES='Utilisateur'
   When 250: RES='Utilisateur'
  Endcase
 When "ENG":
