#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("TPSSAL","") From ETAT
End

####################################################
## Etat des temps par section
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , SERVICE(GLONSRV), POPULATION(GLONPOP)
#LIPET - 10-01-2017 - X3-18688 - START
#Local Char    MATDEB (GLONMAT) , MATFIN (GLONMAT) , SECDEB(GLONCCE) , SECFIN(GLONCCE)
Local Char    MATDEB (GLONEML) , MATFIN (GLONEML) , SECDEB(GLONCCE) , SECFIN(GLONCCE)
#LIPET - 10-01-2017 - X3-18688 - END
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , SECTION(GLONCCE) , TPSDEB(GLONTPS) , TPSFIN(GLONTPS)
Local Char    FSEC(20), FINV(20)
Local Char    ETAT(GLONARP)
Local Char    CRITERE(250), CRITERE2(250)
Local Char    CRITREG(250), CRITREG2(250)
Local Integer DETPAY, FACTU,TYPEW
Local Integer I , J , K , OK
Local Decimal HEURE , JOUR , TOTAL , THEURE , TJOUR, COEFF
Local Integer JNUIT , NJOUR , RJOUR , LIG, NUMREQ, REGUL
#JASMI - 2014-10-13 - 92876 - START
Local Char    AXE(GLONDIE)
Local Integer DIE_INDEX
Local Char    CPY_TIP(GLONCPY)
#JASMI - 2014-10-13 - 92876 - END

If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:TIP])=0 : Local File TIMEMP    [TIP] : Endif
If clalev([F:TIG])=0 : Local File TIMREGUL  [TIG] : Endif
If clalev([F:TIA])=0 : Local File TIMANA    [TIA] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif
If clalev([F:ARM])=0 : Local File AREPORTM  [ARM] : Endif
If clalev([F:ID])=0  : Local File EMPLOID   [ID]  : Endif
If clalev([F:POA])=0 : Local File POPULA    [POA] : Endif
If clalev([F:CTR])=0 : Local File EMPLOCTR  [CTR] : Endif

Local File =GTABCPT+"CACCE" [CCE]
Local File =GTABCPT+"CADSP" [DSP]

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("tpsdeb",NBPAR,PARAMETRE,TPSDEB)
Call GETPARAM("tpsfin",NBPAR,PARAMETRE,TPSFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM)    : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM)    : DATEFIN = PARAM
Call GETPARAM("factu",NBPAR,PARAMETRE,PARAM)      : FACTU = val(PARAM)
Call GETPARAM("typew",NBPAR,PARAMETRE,PARAM)      : TYPEW = val(PARAM)
#JASMI - 2014-10-07 - 92876 - START
#Call GETPARAM("filtre_axe",NBPAR,PARAMETRE,PARAM)        : AXE = val(PARAM)
Call GETPARAM("filtre_axe",NBPAR,PARAMETRE,AXE)
#JASMI - 2014-10-07 - 92876 - END
Call GETPARAM("secdeb",NBPAR,PARAMETRE,SECDEB)
Call GETPARAM("secfin",NBPAR,PARAMETRE,SECFIN)
Call GETPARAM("filtre_sec",NBPAR,PARAMETRE,FSEC)
Call GETPARAM("filtre_inv",NBPAR,PARAMETRE,FINV)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM)  : [L]NUMREQ = val(PARAM)
Call GETPARAM("regul",NBPAR,PARAMETRE,PARAM)      : REGUL = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Read [CPY]CPY0 = [L]SOCIETE
If fstat
 #LIPET - 10-01-2017 - X3-18688 - START
 #Call ERREUR(mess(65,702,1)) From GESECRAN : # Société inexistante
 Call ERREUR(mess(65,10702,1)) From GESECRAN
 #LIPET - 10-01-2017 - X3-18688 - END
 GOK = 0 : End
Endif

#JASMI - 2014-10-13 - 92876 - START
If [F:CPY]CPYLEGFLG=2 : # Legal company
  [L]CPY_TIP = [L]SOCIETE
Else
  Read [FGR]FGR0(1) = [L]SOCIETE
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  [L]CPY_TIP = [F:FCY]LEGCPY
  Call LECTURE("CPY",[L]CPY_TIP,"") From CONTOBJ
Endif
Gosub LISTDIE From TPSSUB
If !find([L]AXE, WLSTDIE(1..WNBRDIE)) Then
 Call ERREUR([L]AXE-":"-mess(40,103,1)) From GESECRAN : # Axe incorrect
 GOK = 0 : End
Endif
#JASMI - 2014-10-13 - 92876 - END


Call TEMPON("O") From GESECRAN

Link [TIP] With [ID]ID0=[F:TIP]REFNUM , [FGR]FGR0=SOCIETE;[F:TIP]FCY , [TIA]TIA0=[F:TIP]LIG
& As [LTIP]

Link [TIG] With [ID]ID0=[F:TIG]REFNUM , [FGR]FGR0=SOCIETE;[F:TIG]FCY , [TIA]TIA0=[F:TIG]LIG
& As [LTIG]

CRITERE = '[FGR]CPY="'+SOCIETE+'"'
If SITEDEB<>"" : CRITERE -= '& [FGR]FCY>="'+SITEDEB+'"' : Endif
If SITEFIN<>"" : CRITERE -= '& [FGR]FCY<="'+SITEFIN+'"' : Endif
If MATDEB<>""  : CRITERE -= '& [TIP]REFNUM>="'+MATDEB+'"' : Endif
If MATFIN<>""  : CRITERE -= '& [TIP]REFNUM<="'+MATFIN+'"' : Endif
If SERVICE<>""
 CRITERE -= '& [TIP]SRV="'+SERVICE+'"'
Endif
If DATEDEB<>[0/0/0]
 CRITERE -= '& [TIP]ENDDAT>=['+format$(GFMD,DATEDEB)+']'
Endif
If DATEFIN<>[0/0/0]
 CRITERE -= '& [TIP]STRDAT<=['+format$(GFMD,DATEFIN)+']'
Endif
If TPSDEB<>""
 CRITERE -= '& [TIP]TIM>="'+TPSDEB+'"'
Endif
If TPSFIN<>""
 CRITERE -= '& [TIP]TIM<="'+TPSFIN+'"'
Endif
If FACTU<>3
 CRITERE -= '& [TIP]INVFLG='+num$(FACTU)
Endif
If TYPEW<>4
 CRITERE -= '& [TIP]TYPDAY='+num$(TYPEW)
Endif

#JASMI - 2014-10-18 - 92876 - START
#CRITERE2 = '1=1'
#If FSEC<>""
# CRITERE2 -= '& (pat([TIP]CCE('+num$(AXE-1)+'),"'+FSEC+'")=1 | pat([TIA]CCE('+num$(AXE-1)+'),"'+FSEC+'")=1)'
#Endif
CRITERE2 = ' (([TIP]DSP<>"")'
CRITERE2 -= ' | ([F:TIP]ANAFLG <> 1 & find("'+[L]AXE+'",[F:TIP]DIE(0..dim([F:TIP]DIE)-1)))'
CRITERE2 -= ' | ([F:TIP]ANAFLG = 1 & find("'+[L]AXE+'",[F:TIA]DIE(0..dim([F:TIA]DIE)-1))))'
#JASMI - 2014-10-18 - 92876 - END

CRITREG = CRITERE
Repeat
 K = instr(1,CRITREG,"TIP]")
 If K
  CRITREG = left$(CRITREG,K-1)+"TIG]"+right$(CRITREG,K+4)
 Endif
Until K=0
CRITREG2 = CRITERE2
Repeat
 K = instr(1,CRITREG2,"TIP]")
 If K
  CRITREG2 = left$(CRITREG2,K-1)+"TIG]"+right$(CRITREG2,K+4)
 Endif
Until K=0

Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
End

$TR1
GOK=1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1 | fstat>5
  GOK = -1 : GLOCK = "$AREPORTM"-GUSER : Goto ROLL_TR1
 Endif

 Gosub TEMPS
 If GOK<1 : Goto AB_TR1 : Endif
 If REGUL
  Gosub REGUL
  If GOK<1 : Goto AB_TR1 : Endif
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

$TEMPS
LIG = 0
For [LTIP]TIP5(2) Where evalue([L]CRITERE) & evalue([L]CRITERE2)
 Filter [CTR] Where REFNUM=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & (CTRDAT<=[F:TIP]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:TIP]ENDDAT))
 Read [CTR]CTR0 Last
 Filter [CTR]
 Call CONTROLE([F:TIP]REFNUM,date$,[F:TIP]CTRNUM,"",OK,0) From DIVPAYE
 If OK=1 & POPULATION<>""
  Read [POA]POA1=[F:ID]REFNUM;POPULATION
  If fstat : OK=0 : Endif
 Endif
 If OK=1
  For [LTIP]TIP5
#JASMI - 2014-10-18 - 92876 - START
#   If [F:TIP]ENDDAT<>[F:TIP]STRDAT
#    Call VALORIS(max([F:TIP]STRDAT,DATEDEB),min([F:TIP]ENDDAT,DATEFIN),[F:ID]REFNUM,[F:TIP]TIM,TJOUR,THEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
#   Else
#    THEURE = [F:TIP]NBRHOU
#    TJOUR  = [F:TIP]NBRDAY
#   Endif
#   If [F:TIP]ANAFLG
#    [L]SECTION = [F:TIA]CCE(AXE-1)
#    HEURE   = THEURE*[F:TIA]NBRHOU/[F:TIP]NBRHOU
#    JOUR    = TJOUR*[F:TIA]NBRHOU/[F:TIP]NBRHOU
#    Gosub LIGNE
#   Elsif [F:TIP]DSP=""
#    [L]SECTION = [F:TIP]CCE(AXE-1)
#    HEURE   = THEURE
#    JOUR    = TJOUR
#    Gosub LIGNE
#   Else
#    TOTAL = 0
#    For [DSP]DSP0 Where DSP=[F:TIP]DSP
#     TOTAL += [F:DSP]COE
#    Next
#    If TOTAL
#     For [DSP]DSP0 Where DSP=[F:TIP]DSP
#      Case AXE
#       When 1 : SECTION = [F:DSP]CCE1
#       When 2 : SECTION = [F:DSP]CCE2
#       When 3 : SECTION = [F:DSP]CCE3
#       When 4 : SECTION = [F:DSP]CCE4
#       When 5 : SECTION = [F:DSP]CCE5
#       When 6 : SECTION = [F:DSP]CCE6
#       When 7 : SECTION = [F:DSP]CCE7
#       When 8 : SECTION = [F:DSP]CCE8
#       When 9 : SECTION = [F:DSP]CCE9
#      Endcase
#      If FSEC="" or pat(SECTION,FSEC)
#       HEURE = THEURE*[F:DSP]COE/TOTAL
#       JOUR  = TJOUR*[F:DSP]COE/TOTAL
#       Gosub LIGNE
#      Endif
#     Next
#    Endif
#   Endif
#  Next
   If [F:TIP]ANAFLG Then
     [L]DIE_INDEX = find([L]AXE,[F:TIA]DIE(0..dim([F:TIA]DIE)-1))-1
   Else
     [L]DIE_INDEX = find([L]AXE,[F:TIP]DIE(0..dim([F:TIP]DIE)-1))-1
   Endif
   OK=1
   If FSEC<>"" Then
     OK=0
     If [L]DIE_INDEX >= 0 Then
       If [F:TIP]ANAFLG Then
         If pat([TIA]CCE([L]DIE_INDEX),FSEC)=1 Then
           OK=1
         Endif
       Else
         If pat([TIP]CCE([L]DIE_INDEX),FSEC)=1 Then
           OK=1
         Endif
       Endif
     Endif
   Endif
   If OK=1 Then
     If [F:TIP]ENDDAT<>[F:TIP]STRDAT
      Call VALORIS(max([F:TIP]STRDAT,DATEDEB),min([F:TIP]ENDDAT,DATEFIN),[F:ID]REFNUM,[F:TIP]TIM,TJOUR,THEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
     Else
      THEURE = [F:TIP]NBRHOU
      TJOUR  = [F:TIP]NBRDAY
     Endif
     If [F:TIP]ANAFLG & [L]DIE_INDEX >= 0 Then
      [L]SECTION = [F:TIA]CCE([L]DIE_INDEX)
      HEURE   = THEURE*[F:TIA]NBRHOU/[F:TIP]NBRHOU
      JOUR    = TJOUR*[F:TIA]NBRHOU/[F:TIP]NBRHOU
      Gosub LIGNE
     Elsif [F:TIP]DSP=""
      [L]SECTION = [F:TIP]CCE([L]DIE_INDEX)
      HEURE   = THEURE
      JOUR    = TJOUR
      Gosub LIGNE
     Else
      TOTAL = 0
      For [DSP]DSP0 Where DSP=[F:TIP]DSP
       TOTAL += [F:DSP]COE
      Next
      If TOTAL
       For [DSP]DSP0 Where DSP=[F:TIP]DSP
        [L]DIE_INDEX = find([L]AXE,[F:DSP]DIE(0..dim([F:DSP]DIE)-1))-1
        If [L]DIE_INDEX >= 0 Then
         SECTION = evalue("[F:DSP]CCE"+num$([L]DIE_INDEX + 1))
         If FSEC="" or pat(SECTION,FSEC)
          HEURE = THEURE*[F:DSP]COE/TOTAL
          JOUR  = TJOUR*[F:DSP]COE/TOTAL
          Gosub LIGNE
         Endif
        Endif
       Next
      Endif
     Endif
   Endif
#JASMI - 2014-10-18 - 92876 - END
  Next
 Endif
Next
Return

$LIGNE
If FINV<>"" & pat(SECTION,FINV)
 Return
Endif
If SECTION<SECDEB or (SECFIN<>"" & SECTION>SECFIN) or (HEURE=0 & JOUR=0)
 Return
Endif
JNUIT = [F:TIP]DAYNGT
Read [CCE]CCE0 = AXE;SECTION
LIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = LIG
[F:ARM]CLEN1  = [F:TIP]LIG
[F:ARM]CLEN2  = JNUIT
[F:ARM]CLEA1  = [F:ID]REFNUM
[F:ARM]CLEA2  = [F:TIP]TIM
[F:ARM]CLEA3  = SECTION
[F:ARM]CLEA4  = left$([F:CCE]DES,15)
[F:ARM]CLEA5  = right$([F:CCE]DES,16)
# FQ90302 - 14/06/13 - Pour faire le lien avec EMPCTR
[F:ARM]CLEA6  = [F:TIP]CTRNUM
# Fin FQ90302
[F:ARM]CLEMD1 = HEURE
[F:ARM]CLEMD2 = JOUR
[F:ARM]CLED1  = max([F:TIP]STRDAT,DATEDEB)
[F:ARM]CLED2  = min([F:TIP]ENDDAT,DATEFIN)
[F:ARM]CREDAT = date$
Write [ARM]
If fstat
 GOK = 0 : Call FSTA("ARM") From GLOCK : Return
Endif
Return

$REGUL

For [LTIG]TIG4(2) Where evalue([L]CRITREG) & evalue([L]CRITREG2)
 #LIPET - 10-01-2017 - X3-18688 - START
# Filter [CTR] Where REFNUM=[F:TIG]REFNUM & CTRNUM=[F:TIG]CTRNUM & (CTRDAT<=[F:TIG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:TIG]ENDDAT))
# Read [CTR]CTR0 Last
# Filter [CTR]
 Filter [HRCTR] Where REFNUM=[F:TIG]REFNUM & CTRNUM=[F:TIG]CTRNUM & (CTRDAT<=[F:TIG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:TIG]ENDDAT))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 #LIPET - 10-01-2017 - X3-18688 - END
 Call CONTROLE([F:TIG]REFNUM,date$,[F:TIG]CTRNUM,"",OK,0) From DIVPAYE
 If OK=1 & POPULATION<>""
  Read [POA]POA1=[F:ID]REFNUM;POPULATION
  If fstat : OK=0  Endif
 Endif
 If OK=1
  For [LTIG]TIG4
#JASMI - 2014-10-18 - 92876 - START
#   COEFF = (min(DATEFIN,[F:TIG]ENDDAT)-max(DATEDEB,[F:TIG]STRDAT)+1)/([F:TIG]ENDDAT-[F:TIG]STRDAT+1)
#   THEURE = [F:TIG]NBRHOU
#   TJOUR  = [F:TIG]NBRDAY
#   If [F:TIG]ANAFLG
#    [L]SECTION = [F:TIA]CCE(AXE-1)
#    HEURE   = THEURE*[F:TIA]NBRHOU/[F:TIG]NBRHOU
#    JOUR    = TJOUR*[F:TIA]NBRHOU/[F:TIG]NBRHOU
#    Gosub LIGNE_REGUL
#   Elsif [F:TIG]DSP=""
#    [L]SECTION = [F:TIG]CCE(AXE-1)
#    HEURE   = THEURE
#    JOUR    = TJOUR
#    Gosub LIGNE_REGUL
#   Else
#    TOTAL = 0
#    For [DSP]DSP0 Where DSP=[F:TIG]DSP
#     TOTAL += [F:DSP]COE
#    Next
#    If TOTAL
#     For [DSP]DSP0 Where DSP=[F:TIG]DSP
#      Case AXE
#       When 1 : SECTION = [F:DSP]CCE1
#       When 2 : SECTION = [F:DSP]CCE2
#       When 3 : SECTION = [F:DSP]CCE3
#       When 4 : SECTION = [F:DSP]CCE4
#       When 5 : SECTION = [F:DSP]CCE5
#       When 6 : SECTION = [F:DSP]CCE6
#       When 7 : SECTION = [F:DSP]CCE7
#       When 8 : SECTION = [F:DSP]CCE8
#       When 9 : SECTION = [F:DSP]CCE9
#      Endcase
#      If FSEC="" or pat(SECTION,FSEC)
#       HEURE = THEURE*[F:DSP]COE/TOTAL
#       JOUR  = TJOUR*[F:DSP]COE/TOTAL
#       Gosub LIGNE_REGUL
#      Endif
#     Next
#    Endif
#   Endif
#  Next
   If [F:TIG]ANAFLG Then
     [L]DIE_INDEX = find([L]AXE,[F:TIA]DIE(0..dim([F:TIA]DIE)-1))-1
   Else
     [L]DIE_INDEX = find([L]AXE,[F:TIG]DIE(0..dim([F:TIG]DIE)-1))-1
   Endif
   OK=1
   If FSEC<>"" Then
     OK=0
     If [L]DIE_INDEX >= 0 Then
       If [F:TIG]ANAFLG Then
         If pat([TIA]CCE([L]DIE_INDEX),FSEC)=1 Then
           OK=1
         Endif
       Else
         If pat([TIG]CCE([L]DIE_INDEX),FSEC)=1 Then
           OK=1
         Endif
       Endif
     Endif
   Endif
   If OK=1 Then
     COEFF = (min(DATEFIN,[F:TIG]ENDDAT)-max(DATEDEB,[F:TIG]STRDAT)+1)/([F:TIG]ENDDAT-[F:TIG]STRDAT+1)
     THEURE = [F:TIG]NBRHOU
     TJOUR  = [F:TIG]NBRDAY
     If [F:TIG]ANAFLG & [L]DIE_INDEX >= 0 Then
      [L]SECTION = [F:TIA]CCE([L]DIE_INDEX)
      HEURE   = THEURE*[F:TIA]NBRHOU/[F:TIG]NBRHOU
      JOUR    = TJOUR*[F:TIA]NBRHOU/[F:TIG]NBRHOU
      Gosub LIGNE_REGUL
     Elsif [F:TIG]DSP=""
      [L]SECTION = [F:TIG]CCE([L]DIE_INDEX)
      HEURE   = THEURE
      JOUR    = TJOUR
      Gosub LIGNE_REGUL
     Else
      TOTAL = 0
      For [DSP]DSP0 Where DSP=[F:TIG]DSP
       TOTAL += [F:DSP]COE
      Next
      If TOTAL
       For [DSP]DSP0 Where DSP=[F:TIG]DSP
        [L]DIE_INDEX = find([L]AXE,[F:DSP]DIE(0..dim([F:DSP]DIE)-1))-1
        If [L]DIE_INDEX >= 0 Then
         SECTION = evalue("[F:DSP]CCE"+num$([L]DIE_INDEX + 1))
         If FSEC="" or pat(SECTION,FSEC)
          HEURE = THEURE*[F:DSP]COE/TOTAL
          JOUR  = TJOUR*[F:DSP]COE/TOTAL
          Gosub LIGNE_REGUL
         Endif
        Endif
       Next
      Endif
     Endif
   Endif
#JASMI - 2014-10-18 - 92876 - END
  Next
 Endif
Next
Return

$LIGNE_REGUL
If FINV<>"" & pat(SECTION,FINV)
 Return
Endif
If SECTION<SECDEB or (SECFIN<>"" & SECTION>SECFIN) or (HEURE=0 & JOUR=0)
 Return
Endif
JNUIT = [F:TIG]DAYNGT
Read [CCE]CCE0 = AXE;SECTION
LIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = LIG
[F:ARM]CLEN1  = [F:TIG]LIG
[F:ARM]CLEN2  = JNUIT
[F:ARM]CLEA1  = [F:ID]REFNUM
[F:ARM]CLEA2  = [F:TIG]TIM
[F:ARM]CLEA3  = SECTION
[F:ARM]CLEA4  = left$([F:CCE]DES,15)
[F:ARM]CLEA5  = right$([F:CCE]DES,16)
# FQ90302 - 14/06/13 - Pour faire le lien avec EMPCTR
[F:ARM]CLEA6  = [F:TIG]CTRNUM
# Fin FQ90302
[F:ARM]CLEMD1 = HEURE
[F:ARM]CLEMD2 = JOUR
[F:ARM]CLED1  = max([F:TIG]STRDAT,DATEDEB)
[F:ARM]CLED2  = min([F:TIG]ENDDAT,DATEFIN)
[F:ARM]CREDAT = date$
Write [ARM]
If fstat
 GOK = 0 : Call FSTA("ARM") From GLOCK : Return
Endif
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

