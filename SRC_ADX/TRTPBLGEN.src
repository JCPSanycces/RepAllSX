#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################
Local Char DOSSIER(30)
Local Integer IERR

  IERR = 0
  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(1007,182,1)) From LECFIC
    Call GENPBLSTAT(DOSSIER, IERR)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#####################################################################################################################
#                                                                                                                   #
# Régénération des statistiques sur compétence                                       Module CRM   24 Novembre 2003  #
#                                                                                                                   #
#####################################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

Local Integer IERR

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
    End
  Endif
  #Si Module Support client non actif. On ne fait rien.
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif
  IERR = 0
  Call GENPBLSTAT(APPLI, IERR)
End

#######################################################################
Subprog GENPBLSTAT(SZAPPLI, IERRINF)
Value Char SZAPPLI
Variable Integer IERRINF

  IERRINF = 0
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME(mess(1009,182,1)) From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #############################
  # Ouverture des tables utiles
  #############################
  If !clalev([F:PBL]) : Local File =SZAPPLI+".FAMPB" [PBL] : Endif
  If !clalev([F:PBR]) : Local File =SZAPPLI+".FAMPBREP" [PBR] : Endif
  If !clalev([F:PBQ]) : Local File =SZAPPLI+".FAMPBQUE" [PBQ] : Endif
  If !clalev([F:SRE]) : Local File =SZAPPLI+".SERREQUEST" [SRE] : Endif
  If !clalev([F:AUS]) : Local File =SZAPPLI+".AUTILIS" [AUS] : Endif
  If !clalev([F:QUE]) : Local File =SZAPPLI+".QUEUE" [QUE] : Endif
  If !clalev([F:SRM]) : Local File =SZAPPLI+".SREMAC" [SRM] : Endif
  #Exécution du traitement
  Gosub EXECPBL
  If IERRINF Then
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TIME(mess(1010,182,1)) From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Else
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TIME(mess(1011,182,1)) From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
End

####################################################################
$EXECPBL
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF

  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  #Pour commencer on remet à zéro les comptages dans PBR et PBQ
  For [PBR]
    If IPERF = 0 Then
      Trbegin [PBR]
      INTR = 1
    Endif
    [F:PBR]SRECOU = 0
    Rewrite [PBR]
    If fstat Then
      IERRINF = 1
      Rollback
      Break
    Endif
    If !IERRINF Then
      If IPERF >= 1024 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
  Next
  If IERRINF Then
    Call ECR_TRACE(mess(1012,182,1) - "(PBR)", 1) From GESECRAN
    Return
  Else
    If INTR Then
      Commit
    Endif
  Endif
  IPERF = 0
  INTR = 0
  For [PBQ]
    If IPERF = 0 Then
      Trbegin [PBQ]
      INTR = 1
    Endif
    [F:PBQ]SRECOU = 0
    Rewrite [PBQ]
    If fstat Then
      IERRINF = 1
      Rollback
      Break
    Endif
    If !IERRINF Then
      If IPERF >= 1024 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
  Next
  If IERRINF Then
    Call ECR_TRACE(mess(1012,182,1) - "(PQB)", 1) From GESECRAN
    Return
  Else
    If INTR Then
      Commit
    Endif
  Endif
  IPERF = 0
  INTR = 0
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [SRE] Where [F:SRE]SRENUM > SZCLE Order By [F:SRE]SRENUM Asc
    For [SRE]
      SZCLE = [F:SRE]SRENUM
      If IPERF = 0 Then
        Trbegin [PBR], [PBQ]
        INTR = 1
      Endif
      If [F:SRE]SREASS = 2 Then
        #Affectation à un collaborateur
        If [F:SRE]SREDET <> "" Then
          If [F:SRE]SREPBLGRP = "" Then
            #Recherche d'une compétence dans le parc concerné
            If [F:SRE]SREMAC <> "" Then
              Read [SRM]SRM1=[F:SRE]SRENUM;[F:SRE]SREMAC
              If !fstat Then
                If [F:SRM]PBLNUM <> "" Then
                  Read [PBR]PBR2=[F:SRM]PBLNUM;[F:SRE]SREDET
                  If fstat Then
                    Raz [F:PBR]
                    [F:PBR]GRPPBLNUM = [F:SRM]PBLNUM
                    [F:PBR]REPNUM = [F:SRE]SREDET
                    Read [AUS]CODUSR=[F:SRE]SREDET
                    If !fstat Then
                      [F:PBR]REPNAM = [F:AUS]NOMUSR
                    Endif
                    [F:PBR]SRECOU = 1
                    [F:PBR]STTFLG = 1
                    Write [PBR]
                    If fstat Then
                      IERRINF = 1
                      Rollback
                      Break
                    Endif
                  Else
                    [F:PBR]SRECOU += 1
                    Rewrite [PBR]
                    If fstat Then
                      IERRINF = 1
                      Rollback
                      Break
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Else
            Read [PBR]PBR2=[F:SRE]SREPBLGRP;[F:SRE]SREDET
            If fstat Then
              Raz [F:PBR]
              [F:PBR]GRPPBLNUM = [F:SRE]SREPBLGRP
              [F:PBR]REPNUM = [F:SRE]SREDET
              Read [AUS]CODUSR=[F:SRE]SREDET
              If !fstat Then
                [F:PBR]REPNAM = [F:AUS]NOMUSR
              Endif
              [F:PBR]SRECOU = 1
              [F:PBR]STTFLG = 1
              Write [PBR]
              If fstat Then
                IERRINF = 1
                Rollback
                Break
              Endif
            Else
              [F:PBR]SRECOU += 1
              Rewrite [PBR]
              If fstat Then
                IERRINF = 1
                Rollback
                Break
              Endif
            Endif
          Endif
        Endif
      Elsif [F:SRE]SREASS = 3 Then
        #Affectation à une queue
        If [F:SRE]SREDET <> "" Then
          If [F:SRE]SREPBLGRP = "" Then
            #Recherche d'une compétence dans le parc concerné
            If [F:SRE]SREMAC <> "" Then
              Read [SRM]SRM1=[F:SRE]SRENUM;[F:SRE]SREMAC
              If !fstat Then
                If [F:SRM]PBLNUM <> "" Then
                  Read [PBQ]PBQ2=[F:SRM]PBLNUM;[F:SRE]SREDET
                  If fstat Then
                    Raz [F:PBQ]
                    [F:PBQ]GRPPBLNUM = [F:SRM]PBLNUM
                    [F:PBQ]QUENUM = [F:SRE]SREDET
                    Read [AUS]CODUSR=[F:SRE]SREDET
                    If !fstat Then
                      # FGR 23/09/2009 : X3SUIVI58037
                      #[F:PBQ]QUENAM = [F:QUE]TTR
                      Call LECTEXTRA([F:PBQ]QUENAM,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
                    Endif
                    [F:PBQ]SRECOU = 1
                    [F:PBQ]STTFLG = 1
                    Write [PBQ]
                    If fstat Then
                      IERRINF = 1
                      Rollback
                      Break
                    Endif
                  Else
                    [F:PBQ]SRECOU += 1
                    Rewrite [PBQ]
                    If fstat Then
                      IERRINF = 1
                      Rollback
                      Break
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Else
            Read [PBQ]PBQ2=[F:SRE]SREPBLGRP;[F:SRE]SREDET
            If fstat Then
              Raz [F:PBQ]
              [F:PBQ]GRPPBLNUM = [F:SRE]SREPBLGRP
              [F:PBQ]QUENUM = [F:SRE]SREDET
              Read [QUE]QUE0=[F:SRE]SREDET
              If !fstat Then
                # FGR 23/09/2009 : X3SUIVI58037
                #[F:PBQ]QUENAM = [F:QUE]TTR
                Call LECTEXTRA([F:PBQ]QUENAM,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
              Endif
              [F:PBQ]SRECOU = 1
              [F:PBQ]STTFLG = 1
              Write [PBQ]
              If fstat Then
                IERRINF = 1
                Rollback
                Break
              Endif
            Else
              [F:PBQ]SRECOU += 1
              Rewrite [PBQ]
              If fstat Then
                IERRINF = 1
                Rollback
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
      If !IERRINF Then
        If IPERF >= 1024 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [SRE]
    If IERRINF Then
      Break
    Endif
  Wend
  If INTR Then
    If !IERRINF Then
      Commit
    Endif
  Endif
Return
