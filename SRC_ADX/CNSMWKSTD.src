#<AdxTL>@(#)1.0.0.0 $Revision$ Consultation WKL

##################################################
#                                                #
#    Consultation des charges                    #
#                                   MM    09/01  #
##################################################

##################################################
#
# 1= site
#
# 2= regroupement
#            1- par site
#            2- par centre
#            3- par poste
#
# 3= poste
#
# 4= centre
#
# 5= date début
#
# 6- date fin
#
##################################################
# 15158 07.02 MM
Local Char PARAM (20)(1..7)
PARAM(1)="GAL"
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)="01/01/2009"
PARAM(6)="01/07/2009"
PARAM(7)="1"
# 15158 07.02 MM
Call GCONSULT("MWK", "",PARAM) From GCONSULT
End

##################################################
$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LECTURE"      : Gosub LECTURE
 When "DEB_CRIT"     : Gosub DEB_CRIT
 When "FIN_CRIT"     : Gosub FIN_CRIT
 When "AV_MAGNETO"   : Gosub AV_MAGNETO
 When Default
Endcase
Return


##################################################
$OUVRE

Local Integer I
Local Char CRITERE(255)
Local Date DATECOUR
Local Decimal WCHARGE
Local Integer WSRT

If clalev ([F:FCY]) <= 0  : Local File FACILITY [FCY] : Endif  # FQ 64660 GA 07/2010
If clalev ([F:WKL]) <= 0  : Local File WORKLOAD [WKL] : Endif
If clalev ([F:MWS]) <= 0  : Local File WORKSTATIO [MWS] : Endif

[M:MWK1]WSTTYPDEB=1    # 15302 09.02 MM
[M:MWK1]WSTTYPFIN=3    # 15302 09.02 MM

Gosub DEFCRIT

If !find([M:MWK1]MENU,1,2,3) :  [M:MWK1]MENU = 1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMWK"
Return

##################################################
$DEFCRIT

# chargement par défaut : en fonction du site de l'utilisateur et de l'horizon de
# consultation par défaut
# Issue 103530 - 2015-01-13 by JUSYN : work center hasn't been transferred and grouping needed to be done before further action.
#  work center not filled and work center group not filled
#  PARAM(2) = "1" # Grouping by site (Grouping by default)
#  work center not filled, but work center group
If PARAM(3) = "" & PARAM(4) <> ""
    PARAM(2) = "2" # Grouping by work center group
Endif
#  work center filled and work center group not filled
If PARAM(3) <> "" & PARAM(4) = ""
    PARAM(2) = "3" # Grouping by work center
Endif
#  work center and work center group filled
If PARAM(3) <> "" & PARAM(4) <> ""
    PARAM(2) = "3" # Grouping by Work Center
Endif

For I= 1 To dim(PARAM)
    Case I
        When 1 :     #site
            If  PARAM(I)<> ""
                #Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                Read [F:FCY]FCY0=PARAM(I)
                If !fstat & [F:FCY]MFGFLG = 2 : [M:MWK1]MFGFCY = PARAM(I) : Endif
            Else
                Call FIND_GFCYDEF(8) From TRTX3  # FQ 66043 GA 07/2010 remplace valeur par défaut dans l'écran
                [M:MWK1]MFGFCY = GFCY
            Endif
        When 2 :    # Menu déroulant
            If PARAM(I)<>""
                WSRT = val(PARAM(I))
                If WSRT <1 | WSRT >3 : WSRT = 1 : Endif
                [M:MWK1]MENU = WSRT
            Else
                [M:MWK1]MENU = 1
            Endif
        When 3 :    # poste de charge
            If PARAM(I)<> "" & [M:MWK1]MENU = 3
              Read [MWS]WST0 = PARAM(I);[M:MWK1]MFGFCY
                If !fstat
                   [M:MWK1]WST = PARAM(I)
                Endif
            Endif
        When 4 :    # Centre de charge
             If PARAM(I)<> ""  & find([M:MWK1]MENU,2,3)
                Read [MWS]WST3= PARAM(I);[M:MWK1]WST
                # Issue 103530 - 2015-01-13 by JUSYN : work center group needed even when no record found
                #If !fstat
                #    [M:MWK1]WCR = PARAM(I)
                #Endif
                [M:MWK1]WCR = PARAM(I)
             Endif
        When 5:    # Date début    # 15158 07.02   MM : filtre sur date en entete
            If PARAM(I)<>""
                If instr(1, PARAM(I),"/")
                   [M:MWK1]STRDATSTR = evalue("["+PARAM(I)+"]") # FQ 64660 GA 07/2010 ajout evalue
                Else
                   [M:MWK1]STRDATSTR = PARAM(I)
                Endif
            Else
                If [M:MWK1]STRDATSTR =[0/0/0]
                   [M:MWK1]STRDATSTR = date$
                Endif
            Endif
       When 6:    # Date fin       # 15158 07.02 MM
            If PARAM(I)<>""
                If instr(1, PARAM(I),"/")
                   [M:MWK1]STRDATEND = evalue("["+PARAM(I)+"]") # FQ 64660 GA 07/2010 ajout evalue
                Else
                   [M:MWK1]STRDATEND = PARAM(I)
                Endif
            Else
                If [M:MWK1]STRDATEND =[0/0/0]
                   [M:MWK1]STRDATEND=  gdat$(day(date$), month(date$)+1,year(date$))
                Endif
            Endif
        When 7 :    # surcharge    11.05 33085
            If PARAM(I)<>""
                [M:MWK1]SURCHARGE = val(PARAM(I))
            Else
                [M:MWK1]SURCHARGE = 1
            Endif
    Endcase
Next I
Affzo [M:MWK1]

# copie du masque entête (MWK1) vers l'écran critère (CMWK)
Gosub CRITENT From =PROGCNS

Return

##################################################
$DEB_CRIT


If [M]MENU = 1
  [M]WST ="":  Grizo [CMWK]WCR : Grizo [MWK1]WCR : Grizo [CMWK]WST : Grizo [MWK1]WST
Endif

If [M]MENU = 2
  [M]WST ="":  Grizo [CMWK]WST : Grizo [MWK1]WST
Endif

If [M]MENU = 3     # 15302 09.02 MM
   [M]WSTTYPDEB = 0 : Grizo [MWK1]WSTTYPDEB : Grizo [CMWK]WSTTYPDEB
   [M]WSTTYPFIN = 0 : Grizo [MWK1]WSTTYPFIN : Grizo [CMWK]WSTTYPFIN
Endif

Return


##################################################
$FIN_CRIT


If [M]MENU = 1
  [M]WST ="":  Grizo [CMWK]WCR : Grizo [MWK1]WCR : Grizo [CMWK]WST : Grizo [MWK1]WST
Endif

If [M]MENU = 2
  [M]WST ="":  Grizo [CMWK]WST : Grizo [MWK1]WST
Endif

If [M]MENU = 3     # 15302 09.02 MM
  [M]WSTTYPDEB = 0 : Grizo [MWK1]WSTTYPDEB : Grizo [CMWK]WSTTYPDEB
  [M]WSTTYPFIN = 0 : Grizo [MWK1]WSTTYPFIN : Grizo [CMWK]WSTTYPFIN
Endif

Return
##################################################
$LECTURE

# Si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MWK1]MFGFCY ="" : NBLU= 0 : Return : Endif
If PARAM(2)="" : PARAM(2)="3" : Endif

#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################


If find([M:MWK1]MENU,1,2)
   Gosub CONSCENT
Endif

If [M:MWK1]MENU = 3
   Gosub CONSPOST
Endif

Case [M:MWK1]MENU
    When 1: Grizo [M:MWK1]WST    # 15158 07.02  MM
            Grizo [M:MWK1]WCR    # 15158 07.02  MM
    When 2: Grizo [M:MWK1]WST
Endcase

# FQ 64660 GA 07/2010 ergonomie affichage
Gosub HIGHLIGHT

Return


##################################################
# consultation des charges par poste
$CONSPOST

#-- Application du filtre et positionnement des boutons
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Filter [WKL] Where evalue (CRITERE) Order By Key WKL0
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Filter [WKL] Where evalue (CRITERE) Order By Key WKL0 Desc
Endif


#-- RAZ du masque
       If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:MWK2] : Endif


 #--  Lecture
 For [WKL]

    If NBLU = 1
        If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWK2] : Endif
        NBLU = 2
    Endif
    If CHGPAG >0
        If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
        NOL += 1
        If NOL = 0
            DEBNUM = [F:WKL]PERNUM
        Endif
        FINNUM = [F:WKL]PERNUM
    Else
        If NOL <= 0 : RETOUR = 2 : Break : Endif
        NOL -= 1
        If NOL = MAXLIG-1
            FINNUM =  [F:WKL]PERNUM
        Endif
        DEBNUM =  [F:WKL]PERNUM
    Endif


    nolign = NOL+1
    [M:MWK2]PERNUM(nolign-1)     = [F:WKL]PERNUM
    [M:MWK2]PERSTR(nolign-1)     = [F:WKL]PERSTR
    [M:MWK2]PEREND(nolign-1)     = [F:WKL]PEREND
    [M:MWK2]PERAVA(nolign-1)     = [F:WKL]PERAVA
    [M:MWK2]ORSLOD(nolign-1)     = [F:WKL]ORSLOD        # llc 03.02 13344
    [M:MWK2]OWSLOD(nolign-1)     = [F:WKL]OWSLOD
    [M:MWK2]OWPLOD(nolign-1)     = [F:WKL]OWPLOD
    [M:MWK2]OWFLOD(nolign-1)     = [F:WKL]OWFLOD
    [M:MWK2]TOTAL(nolign-1)      = [F:WKL]PERLOD
    WCHARGE   = [F:WKL]PERLOD
    Gosub POURCENT

    # 15158 07.02 MM, on n'affiche que les periodes de surcharge
    If CHGPAG >0
        If NOL >-1
          If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
            NOL -=1
          Endif
        Endif
    Else
        #If NOL < MAXLIG
          If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
             NOL +=1
          Endif
       # Endif
    Endif
$NXT_WKL
 Next
 Filter [WKL]
Return

$POURCENT

If [M:MWK2]PERAVA(nolign-1) <>0
    [M:MWK2]PERLOD(nolign-1) = (WCHARGE *100 )/[M:MWK2]PERAVA(nolign-1)
Endif
Return

##################################################
# Consultation des charges par centre
$CONSCENT

DATECOUR = [0/0/0]

If CHGPAG >0
  SUITE = 1
# 15302 09.02 MM
  Link [WKL] With [MWS]WST0=[F:WKL]WST;[F:WKL]MFGFCY
&   As [LIE] Where evalue (CRITERE)
&   Order By [WKL]PEREND
  If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
Else
  RETOUR = 1
  If CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
# 15302 09.02 MM
  Link [WKL] With [MWS]WST0=[F:WKL]WST;[F:WKL]MFGFCY
&   As [LIE] Where evalue (CRITERE)
&  Order By [WKL]PEREND  Desc
Endif


#-- RAZ du masque
  If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:MWK2] : Endif

#-- Lecture
 For [LIE]    # 15302 09.02 MM
   If NBLU = 1
        If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWK2] : Endif
        NBLU = 2
   Endif

      # nouvelle ligne qd nouveau n° fin de période
     If DATECOUR <>[WKL]PEREND
        If CHGPAG >0
            # 15158 07.02 MM, on n'affiche que les periodes de surcharge
            If  NOL >-1
                If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
                  NOL -=1
               Endif
            Endif
            #
            If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
            NOL += 1
            If NOL = 0
                DEBNUM = [F:WKL]PERNUM
            Endif
            FINNUM = [F:WKL]PERNUM
        Else
            # 15158 07.02 MM
            If NOL < MAXLIG
              If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
                 NOL +=1
             Endif
            Endif
            If NOL <= 0 : RETOUR = 2 : Break : Endif
            NOL -= 1
            If NOL = MAXLIG-1
                FINNUM =  [F:WKL]PERNUM
            Endif
            DEBNUM =  [F:WKL]PERNUM
        Endif
        DATECOUR = [WKL]PEREND
        nolign = NOL+1
        [M:MWK2]PERNUM(nolign-1)     = [F:WKL]PERNUM
        [M:MWK2]PERSTR(nolign-1)     = [F:WKL]PERSTR
        [M:MWK2]PEREND(nolign-1)     = [F:WKL]PEREND
        WCHARGE = 0
        # 15158 07.02 MM
        [M:MWK2]OWSLOD(nolign-1)    =0
        [M:MWK2]ORSLOD(nolign-1)    =0
        [M:MWK2]OWPLOD(nolign-1)    =0
        [M:MWK2]OWFLOD(nolign-1)    =0
        [M:MWK2]PERAVA(nolign-1)    =0
        [M:MWK2]PERLOD(nolign-1)    =0
   Endif

   # pour une même période, on somme les charges suggérées, planifiées, fermes
   If  DATECOUR = [WKL]PEREND
        [M:MWK2]OWSLOD(nolign-1) += [F:WKL]OWSLOD
        [M:MWK2]ORSLOD(nolign-1) += [F:WKL]ORSLOD        # llc 03.02 13344
        [M:MWK2]OWPLOD(nolign-1) += [F:WKL]OWPLOD
        [M:MWK2]OWFLOD(nolign-1) += [F:WKL]OWFLOD
        WCHARGE += [F:WKL]PERLOD
        [M:MWK2]PERAVA(nolign-1) += [F:WKL]PERAVA
    Endif
    [M:MWK2]TOTAL(nolign-1) = WCHARGE
    Gosub   POURCENT

$NXT_LIE
 Next

 # 15158 07.02 MM, on n'affiche que les periodes de surcharge
 # pour le cas où la dernière ligne soit à jeter...
 If CHGPAG >0
     If NOL >-1
         If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
             NOL -=1
         Endif
     Endif
 Else
     If NOL < MAXLIG
         If [M:MWK1]SURCHARGE =2 & [M:MWK2]PERLOD(nolign-1)<=100
             NOL +=1
         Endif
     Endif
 Endif

Filter [LIE]    # 15302 09.02 MM

Return

####################################################################
$HIGHLIGHT
Local Char WSTYLE(GLONASY)
[M:MWK2]NBLIG=MAXLIG
Affzo [M:MWK2]
# application style
For I=0 To [M:MWK2]NBLIG-1
    nolign=I+1
    If [M:MWK2]PERLOD(I)=0
        WSTYLE = ""
    Elsif [M:MWK2]PERLOD(I)<=50
        WSTYLE = "BACKYELLOW"
    Elsif [M:MWK2]PERLOD(I)<=75
        WSTYLE = "BACKGREY"
    Elsif [M:MWK2]PERLOD(I)<=100
        WSTYLE = "BACKGREEN"
    Else
        WSTYLE = "BACKRED"
    Endif
    Chgstl [M:MWK2]NBLIG(I) With WSTYLE
Next I
Return


##################################################
$LOAD_FILTER
# Préparation du filtre

CRITERE = "1=1"

#site
If [M:MWK1]MFGFCY <> ""
    CRITERE += "&[F:WKL]MFGFCY=[M:MWK1]MFGFCY"
Endif

# poste
If [M:MWK1]WST <> ""
    CRITERE +="&[F:WKL]WST = [M:MWK1]WST"
Endif

# centre
If [M:MWK1]WCR <> ""
    CRITERE += "&[F:WKL]WCR = [M:MWK1]WCR"
Endif

# 15302 09.02 MM
# type poste
If [M:MWK1]WSTTYPDEB<>0
    CRITERE += "&[F:MWS]WSTTYP>=[M:MWK1]WSTTYPDEB"
Endif

If[M:MWK1]WSTTYPFIN<>0
    CRITERE += "&[F:MWS]WSTTYP<=[M:MWK1]WSTTYPFIN"
Endif

# date début
If [M:MWK1]STRDATSTR <> [0/0/0]                    # 15158 08.02 MM
    CRITERE+="&[F:WKL]PEREND>=[M:MWK1]STRDATSTR"
Endif

If [M:MWK1]STRDATEND <> [0/0/0]                    # 15158 08.02 MM
    CRITERE +="&[F:WKL]PEREND<=[M:MWK1]STRDATEND"
Endif

Case CHGPAG
    When 3 : # rafraichissement
            CRITERE += "&[F:WKL]PERNUM >= DEBNUM"
    When 2 : # suite
            CRITERE +="&[F:WKL]PERNUM > FINNUM"
    When -2: # retour
            CRITERE +="&[F:WKL]PERNUM < DEBNUM"
Endcase

Return


##################################################
$AV_MAGNETO



Case MENU
    When 1:     If [M:MWK1]MFGFCY <> ""                     #  par site
                    NOMFIC ="WORKLOAD"
                    ABFIC = "WKL"
                    CLE = "WKL1"
                    NBCMP = 1
                    CLECMP(0)= "MFGFCY"
                    CLECMP(1)= ""
                    CLECMP(2)= ""
                    CLEMSK(0)= "MFGFCY"
                    CLEMSK(1)= ""
                    CLEMSK(2)= ""
                    FILTRE = ""
                Endif
    When 2:     If [M:MWK1]MFGFCY <>"" & [M:MWK1]WCR<>""    #  par centre
                    NOMFIC ="WORKLOAD"
                    ABFIC = "WKL"
                    CLE = "WKL1"
                    NBCMP = 2
                    CLECMP(0)= "MFGFCY"
                    CLECMP(1)= "WCR"
                    CLECMP(2)= ""
                    CLEMSK(0)= "MFGFCY"
                    CLEMSK(1)= "WCR"
                    CLEMSK(2)= ""
                    FILTRE = ""
                Endif
    When 3:     If [M:MWK1]MFGFCY <>"" & [M:MWK1]WST<>"" & [M:MWK1]WCR<>""    # par poste
                    NOMFIC ="WORKLOAD"
                    ABFIC = "WKL"
                    CLE = "WKL1"
                    NBCMP = 3
                    CLECMP(0)= "MFGFCY"
                    CLECMP(1)= "WCR"
                    CLECMP(2)= "WST"
                    CLEMSK(0)= "MFGFCY"
                    CLEMSK(1)= "WCR"
                    CLEMSK(2)= "WST"
                    FILTRE = ""
                Endif
Endcase
Return


###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If [M:MWK1]MFGFCY = "" & VALEUR <> ""
    [M]WSTTYPDEB=1
    [M]WSTTYPFIN=3
    Grizo [M:MWK1]WCR
    Grizo [M:MWK1]WST
    Grizo [M:CMWK]WCR
    Grizo [M:CMWK]WST
    Actzo [M:MWK1]WSTTYPDEB
    Actzo [M:MWK1]WSTTYPFIN
    Actzo [M:CMWK]WSTTYPDEB
    Actzo [M:CMWK]WSTTYPFIN
Endif

If [M:MWK1]WST <>"" : [M:MWK1]WST ="" : Affzo [M:MWK1]WST : Endif
If [M:MWK1]WCR <>"" : [M:MWK1]WCR ="" : Affzo [M:MWK1]WCR:  Endif
End


########################################

Subprog AV_PERLOD(VALEUR)
Variable Decimal VALEUR
# FQ 64660 GA 07/2010
### If VALEUR >100
###     pcolor = GCOUL(1)
### Else
###     pcolor = GCOUL(0)
### Endif
End


########################################
Subprog AM_MENU(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M]WCR = ""
               [M]WST = ""
               [M]WSTTYPDEB=1                                  # 15302 09.02 MM
               [M]WSTTYPFIN=3                                  # 15302 09.02 MM
               Grizo [M:MWK1]WCR                               # 15158 07.02 MM
               Grizo [M:MWK1]WST                               # 15158 07.02 MM
               Grizo [M:CMWK]WCR
               Grizo [M:CMWK]WST
               Actzo [M:MWK1]WSTTYPDEB                         # 15302 09.02 MM
               Actzo [M:MWK1]WSTTYPFIN                         # 15302 09.02 MM
               Actzo [M:CMWK]WSTTYPDEB                         # 15302 09.02 MM
               Actzo [M:CMWK]WSTTYPFIN                         # 15302 09.02 MM
    When 2:    [M]WST = ""
               [M]WSTTYPDEB=1                                  # 15302 09.02 MM
               [M]WSTTYPFIN=3                                  # 15302 09.02 MM
               Grizo [M:MWK1]WST
               Grizo [M:CMWK]WST
               Actzo [M:MWK1]WCR
               Actzo [M:CMWK]WCR
               Actzo [M:MWK1]WSTTYPDEB                         # 15302 09.02 MM
               Actzo [M:MWK1]WSTTYPFIN                         # 15302 09.02 MM
               Actzo [M:CMWK]WSTTYPDEB                         # 15302 09.02 MM
               Actzo [M:CMWK]WSTTYPFIN                         # 15302 09.02 MM
    When 3:    [M]WSTTYPDEB=0                                  # 15302 09.02 MM
               [M]WSTTYPFIN=0                                  # 15302 09.02 MM
               Actzo [M:MWK1]WCR
               Actzo [M:CMWK]WCR
               Actzo [M:MWK1]WST
               Actzo [M:CMWK]WST
               Grizo [M:MWK1]WSTTYPDEB                        # 15302 09.02 MM
               Grizo [M:MWK1]WSTTYPFIN                        # 15302 09.02 MM
               Grizo [M:CMWK]WSTTYPDEB                        # 15302 09.02 MM
               Grizo [M:CMWK]WSTTYPFIN                        # 15302 09.02 MM

Endcase


End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <>[0/0/0]
    [M]STRDATEND =  gdat$(day(VALEUR), month(VALEUR)+1,year(VALEUR))
Endif
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End


########################################
Subprog IB_WST
    GBOUT1 = mess(29,198,1)
End

########################################
Subprog AM_WSTTYPDEB(VALEUR)    # 15302 09.01 MM
Variable Integer VALEUR
If [M]WSTTYPFIN < VALEUR : [M]WSTTYPFIN = VALEUR : Endif
End

########################################
Subprog C_WSTTYPFIN(VALEUR)    # 15302 09.01 MM
Variable Integer VALEUR
If VALEUR< [M]WSTTYPDEB : GMESSAGE=mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog IB_NBLIG
 # 15158 08.02 MM
Local Integer L : L = nolign-1
Raz GBOUT1

If [M:MWK2]PERNUM(L)>0
    If clalev ([M:OPX1])<=0 : GBOUT1= mess(273,198,1) : Endif      # Encours charge
Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSMWK1) 10/03/2006 14:18:18 (LLCX)
######################################################################################
Subprog S_WCR(VALEUR)
Variable Char    VALEUR()
If [M:MWK1]MENU = 3 : [M:MWK1]WST = [F:MWS]WST : Endif
End


######################################################################################

# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWK") From SUBGTC

End
