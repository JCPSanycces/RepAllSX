#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MIGX0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:24"
A_USER  = "DOC"
A_STAMP = "20181109230524"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MIGX0 [MIGX0]
Gosub HORODAT
Local Inpbox "MIGX0" From GFONCTION At A_STAMP With A_WINDPREV Mask [MIGX0] As [SIM_]
Grizo [MIGX0]5
Grizo [MIGX0]10
Grizo [MIGX0]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MIGX0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=100 : Y1(1)=3 : Y2(1)=5
X1(2)=1 : X2(2)=100 : Y1(2)=6 : Y2(2)=20
Return

$ON_MIGSRCFLD
Onevent CONTROL Call C_MIGSRCFLD(zc) From W1MIGX0
Onevent AFTER_CHANGE Gosub AMM_MIGSRCFLD From W1MIGX0
Onevent BEFORE_INPUT Call AS_MIGSRCFLD(zc) From W1MIGX0
Return

Subprog AS_MIGSRCFLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_MIGSRCFLD(zc) From W1MIGX0
Gosub _AFF
End

Subprog C_MIGSRCFLD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
If !mkstat
 ## Action CONTDOS
 Call C_DOSSIER(VALEUR) From DOSCONT
 If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
 If !mkstat
  ## Action ACCESDOS
  Call CTL_DROIT_DOSSIER(VALEUR,"") From DOSCONT
  If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_MIGSRCFLD
Call AM_MIGSRCFLD(zc)
If !mkstat & GOBJET
 zoncou = "MIGSRCFLD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MIGSRCFLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action APASSWD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "APASSWD"
 PARMSK(1) = ""
 PARMSK(2) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
Endif
Gosub _AFF
End

Subprog S_MIGSRCFLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADS"
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELADS","SUBADS","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_MIGTRGFLD
Onevent CONTROL Call C_MIGTRGFLD(zc) From W1MIGX0
Onevent AFTER_CHANGE Gosub AMM_MIGTRGFLD From W1MIGX0
Onevent BEFORE_INPUT Call AS_MIGTRGFLD(zc) From W1MIGX0
Return

Subprog AS_MIGTRGFLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_MIGTRGFLD(zc) From W1MIGX0
Gosub _AFF
End

Subprog C_MIGTRGFLD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
If !mkstat
 ## Action CONTDOS
 Call C_DOSSIER(VALEUR) From DOSCONT
 If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
 If !mkstat
  ## Action ACCESDOS
  Call CTL_DROIT_DOSSIER(VALEUR,"") From DOSCONT
  If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_MIGTRGFLD
Call AM_MIGTRGFLD(zc)
If !mkstat & GOBJET
 zoncou = "MIGTRGFLD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MIGTRGFLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action APASSWD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "APASSWD"
 PARMSK(1) = ""
 PARMSK(2) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
Endif
Gosub _AFF
End

Subprog S_MIGTRGFLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADS"
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELADS","SUBADS","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_MIGMOD
Onevent INIT_AREA Call D_MIGMOD(zc) From W1MIGX0
Onevent BEFORE_INPUT Call AS_MIGMOD(zc) From W1MIGX0
Onevent CONTROL Call C_MIGMOD(zc) From W1MIGX0
Return

Subprog D_MIGMOD(VALEUR)
Variable Integer VALEUR
If varinit([M]MIGMOD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MIGMOD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_MIGMOD(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MIGMOD" : GZNUM = 943 : Endif
Gosub _AFF
End

$CHG_STY
Return


