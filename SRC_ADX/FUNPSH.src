#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################
# FUNPSH             Solde des demandes d'achat               HN 15/09/00 #
#                                                    Modifié MBT 05/03/03 #
# ----------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                      #
# GCUR    = devise societe          GSYSCUR = devise dossier              #
# GFINRSP = site financier                                                #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#   - TRTFUNPSH : Fonction de solde des demandes d'achat                  #
###########################################################################


$ACTION
#-----------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)        #
# TRTFUNPSH  : Fonction de solde des demandes d'achat #
#-----------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "TITRE"       : Gosub TITRE_INI # MH - 105537 V8 UI TEXT REVIEW
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE        : # Ouverture fichiers et déclaration variables locales
Local Mask PSHCLEAR [DIA]
Raz [M:DIA]
[M:DIA]XFCYFLG = 2
[M:DIA]XUSRFLG = 1
[M:DIA]USR     = GUSER
[M:DIA]TRACE   = 2
Filter [PSH]
Call LECMEMO("STD","[M:DIA]","pm1") From GMEMO
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "R" : Gosub GRISAGE
Endcase
Return

#########################################
# Initial title for the criteria screen #
#########################################
# MH - 105537 UI Text Review
$TITRE_INI
Call TEXTE (10965, TIT) From OBJDIV     #Pur. request automatic close
Return

##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Raz [M:DIA]ARTDEB, [M:DIA]ARTFIN
WNBPCE = 0
If !GSERVEUR
  If [M:DIA]TRACE=2
    #----- Ouverture fichier trace et écriture des sélections -----#
    Call OUVRE_TRACE(mess(104,195,1))    From LECFIC
    Call ECR_TRACE(" ",0)                From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0)    From GESECRAN
    Call PRTSCR("PSHCLEAR","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0)    From GESECRAN
    Call ECR_TRACE(" ",0)                From GESECRAN
  Endif
  Call TEMPON(" ") From GESECRAN
Endif
#----- On traite les DA non soldée -----#
WCRIT = "CLEFLG<>2"
#-----
If [M:DIA]XFCYFLG<>2
  WCRIT -= '& PSHFCY="'+[M:DIA]FCY+'"'
Endif
#----- Attention c'est le demandeur et non l'utilisateur -----#
If [M:DIA]XUSRFLG<>2
  WCRIT -= '& REQUSR="'+[M:DIA]USR+'"'
Endif
#-----
If [M:DIA]STRDAT<>[0/0/0]
  WCRIT -= "& PRQDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"]"
Endif
If [M:DIA]ENDDAT<>[0/0/0]
  WCRIT -= "& PRQDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"
Endif
If [M:DIA]VCRDEB<>""
  WCRIT -= '& PSHNUM>="'+[M:DIA]VCRDEB+'"'
Endif
If [M:DIA]VCRFIN<>""
  WCRIT -= '& PSHNUM<="'+[M:DIA]VCRFIN+'"'
Endif
#-----
Filter [PSH] Where evalue(WCRIT)
OK=1
Raz GFCY
For [PSH] With Nohint
  #-----------------------------------------------------------#
  # Attention si tous sites et pas toutes sociétés            #
  # il faut vérifier que le site appartient bien à la société #
  #-----------------------------------------------------------#
  If [M:DIA]XCPYFLG=1 & [M:DIA]XFCYFLG=2
    OK=0
    If [F:FCY]FCY<>[F:PSH]PSHFCY
      Read [FCY] FCY0=[F:PSH]PSHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY=[M:DIA]CPY
      OK=1
    Endif
  Endif
  If OK=1
    #----- Chargement des paramètres si nécessaire -----#
    If GFCY<>[F:PSH]PSHFCY
      GFCY=[F:PSH]PSHFCY
      Call PARAM(GFCY,"APPPSH",[L]WPARAME) From ADOVAL
      GAPPPSH=val([L]WPARAME)
      Call PARAM(GFCY,"PSHAPPHEA",[L]WPARAME) From ADOVAL
      GPSHAPPHEA=val([L]WPARAME)
    Endif
    #-----
    mkstat=0 : Gosub VERROU_PSH : # Verrou de la DA
    If mkstat<>2
      #----- Demande d'achat non bloquée, on va dans le traitement solde -----#
      WPSHNUM=[F:PSH]PSHNUM : Gosub TR_SOLDE From TRTACHPSH1
      SYMBOLE2="PSH"+num$([F:PSH]PSHNUM) : Unlock=SYMBOLE2 : # Déverrou de la DA
    Endif
  Endif
Next
Filter [PSH]
#----- Restitution des variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
If !GSERVEUR
  Call TEMPOFF From GESECRAN
  If [M:DIA]TRACE=2
    If WNBPCE=0
      Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter !
    Endif
    Call FERME_TRACE From LECFIC
    TRA=1 : Call LEC_TRACE From LECFIC : # Lecture de la trace
  Endif
Endif
FIN=1
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
# Issue 111915 - 2015-10-22 by SR
# si ACTION "DEBUT" : tout le travail sur société/site à  déjà été fait
# Si ACTION "BOUTON" : Gérér l'autorisation sites avant d'activer le flag "Tous sites"
Case ACTION:
    When "DEBUT"
        If [M:DIA]XUSRFLG=2 Diszo [DIA]USR          Else Actzo [DIA]USR          : Endif
    When "BOUTON"
        If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG
        Else
           Actzo [DIA]CPY
           Call INIALLFCY([M]XFCYFLG,[M]CPY)
           If mkstat : Grizo XFCYFLG :  Else Actzo XFCYFLG :  Endif : Raz mkstat
        Endif
        If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
        If [M:DIA]XUSRFLG=2 Diszo [DIA]USR          Else Actzo [DIA]USR          : Endif
Endcase

#If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG Else Actzo [DIA]CPY, XFCYFLG : Endif
#If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
#If [M:DIA]XUSRFLG=2 Diszo [DIA]USR          Else Actzo [DIA]USR          : Endif
# End issue 111915
Return


#---------------------------------------------------------#
# Ouverture des fichiers et déclaration variables locales #
#---------------------------------------------------------#
$OUVRE
Local Mask ORDK   [ORDK]
#-----
Local Integer OK
Local Char    WCRIT (250)
Local Integer STAT
Local Integer WNBPCE
Local Integer WRETOUR, WECRITURE
Local Char    WMESSAGE (80)
Local Char    WPSHNUM(GLONPSH), SYMBOLE2(30), WPARAME(10)
#-----
If !clalev([F:PSH])    Local File PREQUIS     [PSH] : Endif
If !clalev([F:PSD])    Local File PREQUISD    [PSD] : Endif
If !clalev([F:ORD])    Local File ORDERS      [ORD] : Endif
If !clalev([F:CPY])    Local File COMPANY     [CPY] : Endif
If !clalev([F:AUS])    Local File AUTILIS     [AUS] : Endif
If !clalev([F:TCO])    Local File TABCOEFF    [TCO] : Endif
If !clalev([F:BPR])    Local File BPARTNER    [BPR] : Endif
If !clalev([F:BPS])    Local File BPSUPPLIER  [BPS] : Endif
#----- Ouverture fichiers BUD, BUDPAR ...etc, si module Compta à "Oui" -----#
If GMODU(2)=2  : # Compta
  If !clalev([F:BUD])  Local File BUD         [BUD] : Endif
  If !clalev([F:BUP])  Local File BUDPAR      [BUP] : Endif
 #If !clalev([F:BPX])  Local File BUDPARAXI   [BPX] : Endif
  If !clalev([F:BLA])  Local File BALANA      [BLA] : Endif
Endif
#-----
If !clalev([F:FCY])    Local File FACILITY    [FCY] : Endif
If !clalev([F:FIY])    Local File FISCALYEAR  [FIY] : Endif
If !clalev([F:PER])    Local File PERIOD      [PER] : Endif
If !clalev([F:TCU])    Local File TABCUR      [TCU] : Endif
If !clalev([F:TCH])    Local File TABCHANGE   [TCH] : Endif
Return


#---------------------------------#
# Il faut verrouiller symbole PSH #
# personne ne doit modifier la DA #
#---------------------------------#
$VERROU_PSH
Raz mkstat
SYMBOLE2="PSH"+num$([F:PSH]PSHNUM)
Lock=SYMBOLE2 With lockwait=0
If fstat
  If GTRACE<>""
    Call ECR_TRACE(num$([F:PSH]PSHNUM)- mess(10,100,1),1) From GESECRAN
  Endif
  WNBPCE=1
  mkstat=2
Endif
Return


####################################################################################
##############################   SOUS PROGRAMMES   #################################
####################################################################################

Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # Dossier de lancement
Value    Char    USER      : # Utilisateur
Variable Char    P1()(1..) : # On peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK
#-----
Local Char TIT (30)      : TIT=mess(104,195,1)
Local Char WIN (GLONFEN) : WIN="DPSHCLEAR"
#-----
Gosub OUVRE
#---- traitement de la comptabilité ----#
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT
End


####################################################################################
###############################  ACTIONS STANDARD  #################################
####################################################################################

Subprog AV_XCPYFLG(VALEUR)
#--------------------------------------#
# Avant saisie du flag toutes sociétés #
#--------------------------------------#
Variable Integer VALEUR
If varinit([M]XCPYFLG) End : Endif : # Pour n'exécuter qu'une seule fois
#----- Effacement Bornes article si solde non manuel -----#
If GFONCTION<>"FUNPSH2"
  Chgfmt [M]ARTDEB With "-K:1X"
  Chgfmt [M]ARTFIN With "-K:1X"
  Affzo ARTDEB, ARTFIN
Endif
#----- Traitement des champs société -----#
[M]XCPYFLG=2 : VALEUR = 2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR=1 : [M]XCPYFLG=1 : Grizo XCPYFLG
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Diszo CPY
Endif
#----- Traitement des champs site -----#
If VALEUR=2
  Grizo XFCYFLG : Diszo FCY, FCYNAM
Else
  Call INIALLFCY([M]XFCYFLG,[M]CPY)
  If mkstat
    Grizo XFCYFLG : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    Read [FCY] FCY0 = [M]FCY
    If fstat : Raz [F:FCY] : Endif
    [M:DIA]FCYNAM = [F:FCY]FCYNAM
    Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Diszo FCY, FCYNAM
  Endif
Endif
#----- Traitement des champs utilisateur ----#
Call CONTUSR([M]CPY,[M]FCY) From CPTSUB
If mkstat
  Grizo XUSRFLG : Diszo USR : Raz mkstat
Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
  Call INIALLFCY([M]XFCYFLG,[M]CPY)
  If mkstat
    Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
  Else
    Actzo XFCYFLG
    If [M]XFCYFLG=1
      Call INIFCY([M]FCY,[M]CPY) From CPTSUB
      [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
    Else
      Effzo FCY
    Endif
  Endif
Else
  [M]XFCYFLG=2 : Affzo XFCYFLG : Grizo XFCYFLG
  Effzo CPY, FCY, FCYNAM
  If dim([M]ZCPY)>0  Effzo ZCPY : Endif
  Diszo CPY, FCY, FCYNAM
Endif
End


Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Après modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo FCY, FCYNAM
  Call INIFCY([M]FCY,[M]CPY) From CPTSUB
  [M]FCYNAM=[F:FCY]FCYNAM
  Affzo FCY, FCYNAM
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Effzo FCY, FCYNAM
  Diszo FCY, FCYNAM
Endif
End


Subprog AM_CPY(VALEUR)
#----------------------------------#
# Après modification de la société #
#----------------------------------#
Variable Char    VALEUR()
If XCPYFLG=1 & VALEUR=""
  mkstat=2 : End
Endif
Call INIALLFCY([M]XFCYFLG,VALEUR)
If mkstat
  Grizo XFCYFLG : Actzo FCY, FCYNAM : Raz mkstat
  Call INIFCY([M]FCY,VALEUR) From CPTSUB : Affzo FCY, FCYNAM
  If GNBAUZ=1 Diszo FCY, FCYNAM : Endif
Else
  Actzo XFCYFLG
  If [M]XFCYFLG=1
    Call INIFCY([M]FCY,VALEUR) From CPTSUB
    [M]FCYNAM=[F:FCY]FCYNAM : Affzo FCY, FCYNAM
  Endif
Endif
End


Subprog C_CPY(VALEUR)
#------------------------#
# Contrôle de la société #
#------------------------#
Variable Char    VALEUR()
If VALEUR="" & [M]FCY=""
  GMESSAGE=mess(9,109,1) : mkstat=1 : # Vous devez saisir une société ou un site
Endif
End


Subprog C_XFCYFLG(VALEUR)
#----------------------------------#
# Contrôle autorisation tous sites #
#----------------------------------#
Variable Integer VALEUR
Local    Integer  I, OK
#----- Si l'utilisateur veut tous les sites, vérification des possibilités d'accès -----#
If VALEUR = 2
  Raz [M:DIA]FCY, [M:DIA]FCYNAM
  Affzo [DIA]FCY, FCYNAM
  Call CONTALLFCY([M:DIA]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End


Subprog C_FCY(VALEUR)
#----------------------#
# Après modif du site  #
#----------------------#
Variable Char    VALEUR()
If [M]XFCYFLG=1 & VALEUR =""
  mkstat=2 : End
Endif
[M]FCYNAM=[F:FCY]FCYNAM : Affzo FCYNAM
End


Subprog AS_USR(VALEUR)
#--------------------------#
# Avant saisie utilisateur #
#--------------------------#
Variable Char    VALEUR()
If [M]XUSRFLG=2 : mkstat=1 : End : Endif
If VALEUR=""
  VALEUR=GUSER
Endif
End


Subprog AM_USR(VALEUR)
#-------------#
# Apres_modif #
#-------------#
Variable Char    VALEUR()
If XUSRFLG=1 & VALEUR =""
 mkstat=2 : End : Endif
End


Subprog AM_XUSRFLG(VALEUR)
#------------------------------#
# Après modif du flag tous uti #
#------------------------------#
Variable Integer VALEUR
If VALEUR = 2
  Effzo [M]USR : If dim([M]ZUSR)>0  Effzo [M]ZUSR : Endif
  Diszo [M]USR
Else
  Actzo [M]USR
  [M]USR=GUSER
Endif
End


Subprog AM_STRDAT(VALEUR)
#------------------------#
# Après modif date début #
#------------------------#
Variable Date    VALEUR
If VALEUR<>[0/0/0] & ([M]ENDDAT=[0/0/0] | [M]ENDDAT<VALEUR)
  [M]ENDDAT=VALEUR
Endif
End


Subprog AM_VCRDEB(VALEUR)
#--------------------------#
# Après modif numéro début #
#--------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]VCRFIN="" | [M]VCRFIN<VALEUR)
  [M]VCRFIN=VALEUR
Endif
End


Subprog C_VCRFIN(VALEUR)
#---------------------#
# Contrôle numéro fin #
#---------------------#
Variable Char    VALEUR()
If VALEUR<[M]VCRDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End


Subprog AM_ARTDEB(VALEUR)
#-------------------------------------#
# Après modif référence article début #
#-------------------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]ARTFIN="" | [M]ARTFIN<VALEUR)
  [M]ARTFIN=VALEUR : Affzo ARTFIN
Endif
End


Subprog C_ARTFIN(VALEUR)
#--------------------------------#
# Contrôle référence article fin #
#--------------------------------#
Variable Char    VALEUR()
If VALEUR<[M]ARTDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End


#############################################
# Contrôle si tous les sites sont autorisés #
#############################################
Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\"  End : Endif
If GNBAUZ=GNBSITE  End : Endif
If !clalev([F:FGR])  Local File FACGROUP [FGR] : Endif
If !clalev([F:CPY])  Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
 OK=1
 Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2  : # Société juridique
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK=0 : Break
   Endif
  Next I
 Else
  For [FGR]FGR0 Where CPY=[L]SOC
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK=0 : Break
   Endif
  Next
 Endif
Endif
If !OK
 VALEUR=1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

