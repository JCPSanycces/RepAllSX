#<AdxTL>@(#)0.0.0.0 $Revision$

#Handle all property code for EMPLOID
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ENAFLG"           : Gosub EMPLOID_ENAFLG
  When "NCKNAM"           : Gosub EMPLOID_NCKNAM
  When "SRN"              : Gosub EMPLOID_SRN
  When "NAM"              : Gosub EMPLOID_NAM
  When "PSD"              : Gosub EMPLOID_PSD
  When "DATBRN"           : Gosub EMPLOID_DATBRN
  When "CIV"              : Gosub EMPLOID_CIV
Endcase
Return


$EMPLOID_ENAFLG
Case [L]ARULE
  When "PROPAGATE"    : Gosub EMPLOID_ENAFLG_PROPAGATE
Endcase
Return

$EMPLOID_NCKNAM
Case [L]ARULE
  When "PROPAGATE"    : Gosub EMPLOID_NCKNAM_PROPAGATE
Endcase
Return

$EMPLOID_SRN
Case [L]ARULE
  When "PROPAGATE"    : Gosub EMPLOID_SRN_PROPAGATE
Endcase
Return

$EMPLOID_NAM
Case [L]ARULE
  When "PROPAGATE"    : Gosub EMPLOID_NAM_PROPAGATE
Endcase
Return

$EMPLOID_PSD
Case [L]ARULE
  When "CONTROL"    : Gosub EMPLOID_PSD_CONTROL
Endcase
Return

$EMPLOID_DATBRN
Case [L]ARULE
  When "PROPAGATE"    : Gosub EMPLOID_DATBRN_PROPAGATE
Endcase
Return

$EMPLOID_CIV
Case [L]ARULE
  When "CONTROL"    : Gosub EMPLOID_CIV_CONTROL
Endcase
Return



$EMPLOID_ENAFLG_PROPAGATE
#Gosub EMPLOID_ENAFLG_PROPAGATE From EMPLOID_CSTD_PRO
Return


$EMPLOID_NCKNAM_PROPAGATE
Gosub EMPLOID_NCKNAM_PROPAGATE From EMPLOID_CSTD_PRO
Return

$EMPLOID_SRN_PROPAGATE
Gosub EMPLOID_SRN_PROPAGATE From EMPLOID_CSTD_PRO
Return

$EMPLOID_NAM_PROPAGATE
Gosub EMPLOID_NAM_PROPAGATE From EMPLOID_CSTD_PRO
Return

$EMPLOID_PSD_CONTROL
Gosub EMPLOID_PSD_CONTROL From EMPLOID_CSTD_PRO
Return

$EMPLOID_DATBRN_PROPAGATE
Gosub EMPLOID_DATBRN_PROPAGATE From EMPLOID_CSTD_PRO
Return

$EMPLOID_CIV_CONTROL
Gosub EMPLOID_CIV_CONTROL From EMPLOID_CSTD_PRO
Return

