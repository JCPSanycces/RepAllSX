#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGCTLCPT00                                         Module Accounting   #
#                Pre-migration                                             #
#                                                                          #
# Controls                                                                 #
#                                                                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLCPT00") From LECFIC
  Endif

  Call MAJ_UUMGCTLCPT00(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
Subprog MAJ_UUMGCTLCPT00(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, COMPTEUR, ERR
Local Char REQSQL (250) (3)

If [F:ADS]MODULE(1)<>2 : End : Endif
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Local Integer EXE_SQL :  EXE_SQL = 1

Call ECR_TIME("UUMGCTLCPT00 Accounting Control Process") From DOSSUB
Call ECR_TRACE("UUMGCTLCPT00 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- n°version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  Call ECR_TRACE("UUMGCTLCPT00 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#

#-- All version
Gosub VERIFMAJ30

# Version V6
If val(VERSION)<GMIGX3VER60
 If EXE_SQL
  Gosub GACCENTRY_LIN0_SQL
  Gosub GACCENTRYD_HEA0_SQL
 Else
  Gosub GACCENTRY_LIN0_X3
  Gosub GACCENTRYD_HEA0_X3
 Endif
Endif


$FIN
Call ECR_TIME("UUMGCTLCPT00: Accounting Requests Process END.")  From DOSSUB
End

$VERIFMAJ30
If (filinfo(filpath("FIL","MTCBATCH","fde",DOSSIER),0))>0
 Call ECR_TRACE("MTCBATCH",0) From GESECRAN
 Local File =DOSSIER+".MTCBATCH" [MTB]
 COMPTEUR = nbrecord([MTB])
 If COMPTEUR>0
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
 Else
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
 Endif
 Close Local File [MTB]
Endif
If (filinfo(filpath("FIL","GACCTMP","fde",DOSSIER),0))>0
 Call ECR_TRACE("GACCTMP",0) From GESECRAN
 Local File =DOSSIER+".GACCTMP" [HAT]
 COMPTEUR = nbrecord([HAT])
 If COMPTEUR>0
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
 Else
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
 Endif
 Close Local File [HAT]
Endif
If (filinfo(filpath("FIL","GACIASTMP","fde",DOSSIER),0))>0
 Call ECR_TRACE("GACIASTMP",0) From GESECRAN
 Local File =DOSSIER+".GACIASTMP" [HIT]
 COMPTEUR = nbrecord([HIT])
 If COMPTEUR>0
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
 Else
  Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
 Endif
 Close Local File [HIT]
Endif
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$GACCENTRY_LIN0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT HAE.TYP_0, HAE.NUM_0 FROM "-DOSSIER+".GACCENTRY HAE "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".GACCENTRYD DAE WHERE DAE.TYP_0=HAE.TYP_0 and DAE.NUM_0=HAE.NUM_0) "
REQSQL(2)="ORDER BY HAE.TYP_0,HAE.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("GACCENTRY without GACCENTRYD",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSTYP(50),Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"TYP/NUM="-[BXX]VPSTYP+'/'+[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return

###################################################################################
$GACCENTRYD_HEA0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT DISTINCT DAE.TYP_0,DAE.NUM_0 FROM "-DOSSIER+".GACCENTRYD DAE "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".GACCENTRY HAE WHERE HAE.TYP_0=DAE.TYP_0 and HAE.NUM_0=DAE.NUM_0) "
REQSQL(2)="ORDER BY DAE.TYP_0,DAE.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("GACCENTRYD without GACCENTRY",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSTYP(50),Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"TYP/NUM="-[BXX]VPSTYP+'/'+[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return

###################################################################################
$GACCENTRY_LIN0_X3
# Non-existent Journal Line / Ligne de pièce inexistante
Call ECR_TIME("UUMGCTLCPT00 Control Process : GACCENTRY "-mess(262,197,1)) From DOSSUB

If clalev([F:HAE]) = 0 :  Local File =DOSSIER+".GACCENTRY"    [HAE]   : Endif    # Acccounting Journal Entry
If clalev([F:DAE]) = 0 :  Local File =DOSSIER+".GACCENTRYD"   [DAE]   : Endif    # General Acccounting Line

Raz NBLUS, COMPTEUR

# Problem - Accounting Journal Entry without line
For [HAE]HAE0
 NBLUS+=1
 Look [DAE]DAE0(2) = [F:HAE]TYP;[F:HAE]NUM
 If fstat
  Call ECR_TRACE("File GACCENTRY(TYP/NUM)"-[F:HAE]TYP-[F:HAE]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLCPT00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return

###################################################################################
$GACCENTRYD_HEA0_X3
# Line without Journal / Ligne sans pièce
Call ECR_TIME("UUMGCTLCPT00 Control Process : GACCENTRYD "-mess(9,116,1)) From DOSSUB

If clalev([F:HAE]) = 0 :  Local File =DOSSIER+".GACCENTRY"    [HAE]   : Endif    # Acccounting Journal Entry
If clalev([F:DAE]) = 0 :  Local File =DOSSIER+".GACCENTRYD"   [DAE]   : Endif    # General Acccounting Line

Raz NBLUS, COMPTEUR

# Problem - Accounting Journal Entry without header
For [DAE]DAE0(2)
 NBLUS+=1
 Look [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
 If fstat
  Call ECR_TRACE("File GACCENTRYD(TYP/NUM)"-[F:DAE]TYP-[F:DAE]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLCPT00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return

