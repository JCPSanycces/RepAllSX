#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMAUTSPLD
##########################################################################################################
# dbgmode = 1 : dbgaff
# We are in an action mandatory called from OPJM object
# So, globale instance GZINSPJM is mandatory existing too.
# But to be sure, It's possible to check it in $OUVRE action (**1**)
##########################################################################################################
# Issue X3-5348/119525 - 2016-10-31 ALMON    : Begin Allow consolidation of PJMSALITMD at                #
#                                           1. Project Item Level (New) "PJM"                            #
#                                           2. Budget Item Level        "PJMBUD"                         #
#                                           3. Task Item Level          "PJMTAS"                         #
##########################################################################################################
# Issue X3-7285/119926 - 2016-11-21 ALMON   : Begin Changed Process drivers from LM Codes to Numbers     #
##########################################################################################################
# Issue X3-17297/120494 - 2016-12-20 ALMON : Intercept call by param and pass to TECAUTSPLD              #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "OK"                          : Gosub OK_BUTTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  NAVIG = GACTION
  # -----------------------------
Return

##########################################################################################################
$DEBUT
Local Char STUNBUD(GLONPBU)  # Contain the budget given by parameter
Local Char STUNOPP(GLONPIM)  # Contain the Project given by parameter
Local Char STUNTAS(GLONTAC)  # Contain the Project given by parameter
Local Char CALLBY (6)        # Issue X3-17297/120494 - 2016-12-20 ALMON
  # -----------------------------------
  Raz STUNOPP
  If PARAM(1) <> AVOID.ACHAR Then
    STUNOPP = PARAM(1)
  Endif
  # -----------------------------------
  Raz STUNBUD
  If PARAM(2) <> AVOID.ACHAR Then
    STUNBUD = PARAM(2)
  Endif
  # -----------------------------------
  Raz STUNTAS
  If PARAM(3) <> AVOID.ACHAR Then
    STUNTAS = PARAM(3)
  Endif
  # -----------------------------------
  CALLBY = PARAM(4)
  # -----------------------------------
  If CALLBY = AVOID.ACHAR
    GMESSAGE = mess(465,2260,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------------
  Gosub LOAD_SCREEN
Return

##########################################################################################################
$LOAD_SCREEN
# Issue X3-40227 - 2017-05-23 by TEJAC
  Effzo [M:SPLD10]1-99
  # -------------------------------------------------------
  If STUNOPP = STUNBUD
    STUNBUD = AVOID.ACHAR
  Endif
  If STUNOPP = STUNTAS
    STUNTAS = AVOID.ACHAR
  Endif
  [M:SPLD10]OPPNUM = STUNOPP
  [M:SPLD10]PBUCOD = STUNBUD
  [M:SPLD10]TASCOD = STUNTAS
  [M:SPLD10]INCALL = [V]CST_AYES
  [M:SPLD10]INCLOG = [V]CST_AYES
  # -------------------------------------------------------
  If [M:SPLD10]PBUCOD <> AVOID.ACHAR
    [M:SPLD10]PBUDES = fmet GZINSPJM.PJM(1).BUD_GET_PIMDESAXX([M:SPLD10]PBUCOD)
  Endif
  If [M:SPLD10]TASCOD <> AVOID.ACHAR
    [M:SPLD10]TASDES = fmet GZINSPJM.PJM(1).TAS_GET_PIMDESAXX([M:SPLD10]TASCOD)
  Endif
  # -------------------------------------------------------
  If STUNTAS = AVOID.ACHAR and STUNBUD = AVOID.ACHAR Then
    [M:SPLD10]PJTALL = [V]CST_AYES
    [M:SPLD10]PRODGRPLVL = 2
    Diszo [M:SPLD10]PJTALL
    Diszo [M:SPLD10]INCALL
  Elsif STUNTAS <> AVOID.ACHAR Then
    [M:SPLD10]PJTALL = [V]CST_ANO
    [M:SPLD10]INCTAS =  [V]CST_AYES
    [M:SPLD10]INCOPE =  [V]CST_AYES
    [M:SPLD10]INCITM =  [V]CST_AYES
    [M:SPLD10]PRODGRPLVL = 4
    # Diszo [M:SPLD10]PRODGRPLVL # Issue X3-107681 - 2018-09-11 ALMON : Allow selection
    Diszo [M:SPLD10]INCBUD
  Else
    [M:SPLD10]INCBUD =  [V]CST_AYES
    [M:SPLD10]PJTALL = [V]CST_ANO
    [M:SPLD10]PRODGRPLVL = 3
    # Diszo [M:SPLD10]PRODGRPLVL # Issue X3-107681 - 2018-09-11 ALMON : Allow selection
  Endif
  # -------------------------------------------------------
  Affzo [M:SPLD10]1-99
Return

##########################################################################################################
$OK_BUTTON
Local Integer IRET
Local Instance TECSPLDAUT Using C_TECSPLDAUT
Local Instance SPLDLOG Using C_ALOG

  # --------------------------------------
  TECSPLDAUT = NewInstance C_TECSPLDAUT AllocGroup null
  If [M:SPLD10]PJTALL = [V]CST_ANO Then
    TECSPLDAUT.PBUCOD  = [M:SPLD10]PBUCOD
    TECSPLDAUT.TASCOD  = [M:SPLD10]TASCOD
  Endif
  TECSPLDAUT.SUMMLVL = CALLBY
  # -----------------------------------
  SPLDLOG = NewInstance C_ALOG AllocGroup null
  IRET = fmet SPLDLOG.ABEGINLOG(mess(910,2260,1)-": "-GZINSPJM.OPPNUM)
  TECSPLDAUT.LOGNAME = fmet SPLDLOG.AGETNAME()
  # --------------------------------
  SetInstance TECSPLDAUT With [M:SPLD10]
  # --------------------------------
  IRET = fmet GZINSPJM.PJM_SPLD_AUTOMATION([M:SPLD10]OPPNUM,TECSPLDAUT,SPLDLOG)
  If TECSPLDAUT.INCLOG = [V]CST_AYES and TECSPLDAUT.LOGNAME <> AVOID.ACHAR Then
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(GZINSPJM, SPLDLOG) From SYRSTACKTOOLS
      GTRACE = TECSPLDAUT.LOGNAME
      IRET = fmet SPLDLOG.AENDLOG()
      Call LEC_TRACE From LECFIC
  Endif
  FreeGroup SPLDLOG
  If TECSPLDAUT <> null Then
    FreeGroup TECSPLDAUT
  Endif
  # -----------------------------------
  Gosub RELIT_GZINSPJM From SUBPJMA
Return

######################################################################################
Subprog AM_INCBUD(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Raz [M:SPLD10]INCTAS
    Raz [M:SPLD10]INCOPE
    Diszo [M:SPLD10]INCTAS
    Diszo [M:SPLD10]INCITM
    Diszo [M:SPLD10]INCOPE
  Else
    Actzo [M:SPLD10]INCTAS
    Actzo [M:SPLD10]INCITM
    Actzo [M:SPLD10]INCOPE
  Endif
  Affzo [M:SPLD10]1-99
End

######################################################################################
Subprog AM_INCTAS(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Raz [M:SPLD10]INCBUD
    Diszo [M:SPLD10]INCBUD
    [M:SPLD10]INCOPE  = [V]CST_AYES
    [M:SPLD10]INCITM  = [V]CST_AYES
    # -----------------------------
  Elsif VALEUR = [V]CST_ANO Then
    # -----------------------------
    If [M:SPLD10]INCOPE = [V]CST_ANO and [M:SPLD10]TASCOD = AVOID.ACHAR Then
      Actzo [M:SPLD10]INCBUD
    Endif
    # -----------------------------
  Endif
  Affzo [M:SPLD10]1-99
End

######################################################################################
Subprog AM_INCOPE(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Raz [M:SPLD10]INCBUD
    Diszo [M:SPLD10]INCBUD
    # -----------------------------
  Elsif VALEUR = [V]CST_ANO Then
    # -----------------------------
    If [M:SPLD10]INCTAS = [V]CST_ANO and [M:SPLD10]TASCOD = AVOID.ACHAR Then
      Actzo [M:SPLD10]INCBUD
    Endif
    # -----------------------------
  Endif
  Affzo [M:SPLD10]1-99
End

######################################################################################
Subprog AM_INCITM(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Raz [M:SPLD10]INCBUD
    Diszo [M:SPLD10]INCBUD
    # -----------------------------
  Elsif VALEUR = [V]CST_ANO Then
    # -----------------------------
    If [M:SPLD10]INCOPE = [V]CST_ANO and [M:SPLD10]TASCOD = AVOID.ACHAR Then
      Actzo [M:SPLD10]INCBUD
    Endif
    # -----------------------------
  Endif
  Affzo [M:SPLD10]1-99
End

######################################################################################

######################################################################################
## Section automatically added (screen PJMSPLD9) 08/24/2017 07:55:01 (MAPAD)
######################################################################################
Subprog AM_PAANS(VALEUR)
Variable Integer VALEUR
End


