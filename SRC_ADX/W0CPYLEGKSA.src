zoncou = "EQUORG"
indice = 0
IMPENT = [M]EQUORG
If varinit([M]EQUORG,indice)=0
 IMPENT = 1
Endif
If varmode([M]EQUORG,indice)=0
 [M]EQUORG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQUORG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EQUORG(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
