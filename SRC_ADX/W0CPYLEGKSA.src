Endif

## Zone HOLCPY
mkstat = 0
zoncou = "HOLCPY"
indice = 0
If varmode([M]HOLCPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HOLCPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]HOLCPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "HOLCPY" : GZNUM = 55812 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]HOLCPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "HOLCPY" : GZNUM = 55812 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SDLSETA
mkstat = 0
zoncou = "SDLSETA"
indice = 0
If varinit([M]SDLSETA,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SDLSETA,"11671","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SDLSETA,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SDLSETA" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]SDLSETA,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SDLSETA" : GZNUM = 55802 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]SDLSETA,"11671","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SDLSETA" : GZNUM = 55802 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]SDLSETA,"11671",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "SDLSETA" : GZNUM = 55802 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SDLNUM
mkstat = 0
zoncou = "SDLNUM"
indice = 0
If varmode([M]SDLNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SDLNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SDLNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SDLNUM" : GZNUM = 55801 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_SDLNUM([M]SDLNUM) From TRTCPYLEGKSA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SDLNUM" : GZNUM = 55801 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SDLEXP
mkstat = 0
zoncou = "SDLEXP"
indice = 0
IMPENT = [M]SDLEXP
If varinit([M]SDLEXP,indice)=0
 IMPENT = 1
Endif
If varmode([M]SDLEXP,indice)=0
 [M]SDLEXP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SDLEXP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SDLEXP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SDLEXP" : GZNUM = 55800 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]SDLEXP = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone EQUBUSTYP
mkstat = 0
zoncou = "EQUBUSTYP"
indice = 0
IMPENT = [M]EQUBUSTYP
If varinit([M]EQUBUSTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]EQUBUSTYP,indice)=0
 [M]EQUBUSTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQUBUSTYP" : Gosub ACTION From =IMPTRT
