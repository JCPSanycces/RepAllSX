# Superviseur
# Gestion du masque CPYLEGKSA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TCCCOD
mkstat = 0
zoncou = "TCCCOD"
indice = 0
If varmode([M]TCCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TCCCOD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTNUM("HRTCC","!",[M]TCCCOD,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 55798 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SICSUBCLS
mkstat = 0
zoncou = "SICSUBCLS"
indice = 0
If varmode([M]SICSUBCLS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SICSUBCLS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTNUM("HRSIC","!",[M]SICSUBCLS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SICSUBCLS" : GZNUM = 55753 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PAYREFNUM
mkstat = 0
zoncou = "PAYREFNUM"
indice = 0
If varmode([M]PAYREFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAYREFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PAYREFNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PAYREFNUM" : GZNUM = 55807 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PAYREFNUM([M]PAYREFNUM) From TRTCPYLEGKSA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PAYREFNUM" : GZNUM = 55807 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SEZCOD
mkstat = 0
zoncou = "SEZCOD"
indice = 0
If varinit([M]SEZCOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SEZCOD,"11674","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SEZCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SEZCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SEZCOD,"11674","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SEZCOD" : GZNUM = 55241 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SEZCOD,"11674",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SEZCOD" : GZNUM = 55241 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone UIFNUM
mkstat = 0
zoncou = "UIFNUM"
indice = 0
If varmode([M]UIFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UIFNUM" : Gosub ACTION From =IMPTRT
