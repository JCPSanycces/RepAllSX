IMPENT = [M]ETIELIEMP
If varinit([M]ETIELIEMP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ETIELIEMP,indice)=0
 [M]ETIELIEMP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETIELIEMP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ETIELIEMP(indice)
 Endif
Endif
[M]ETIELIEMP = IMPENT

## Zone EMPCNT
mkstat = 0
zoncou = "EMPCNT"
indice = 0
IMPENT = [M]EMPCNT
If varinit([M]EMPCNT,indice)=0
 IMPENT = 1
Endif
If varmode([M]EMPCNT,indice)=0
 [M]EMPCNT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPCNT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EMPCNT(indice)
 Endif
Endif
[M]EMPCNT = IMPENT

## Zone DTIRGTNAM
