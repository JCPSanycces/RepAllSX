zoncou = "DTIRGTNAM"
indice = 0
If varmode([M]DTIRGTNAM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DTIRGTNAM([M]DTIRGTNAM) From TRTCPYLEGKSA
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DTIRGTNAM : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTIRGTNAM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]DTIRGTNAM,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DTIRGTNAM" : GZNUM = 55810 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DTIRGTNUM
mkstat = 0
zoncou = "DTIRGTNUM"
indice = 0
If varmode([M]DTIRGTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTIRGTNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DTIRGTNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
