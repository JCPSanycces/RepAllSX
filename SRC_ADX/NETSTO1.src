#<AdxTL>@(#)4.0.0.0 $Revision$
#################################################
# NETSTO1: Details Netvibes pour le code STO1   #
#             Articles à réceptionner           #
#################################################


#------------#
# Pour tests #
#------------#
If !clalev([F:ITM])  Local File ITMMASTER [ITM] : Endif
#-----
Local Char    WMSG(250)
Local Char    COD_OBJ(GLONAOB)
Local Char    CLE_LEC(GLONBPS)
Local Char    CHAMPS_LUS(50)(1..8)
Local Blbfile BLOB_LUS(1)
Local Date DATMIN : DATMIN=gdat$( 1, 1,year(date$))
Local Date DATMAX : DATMAX=gdat$(31,12,year(date$))
#-----
COD_OBJ="ITM"
CLE_LEC="PLAYSTATION"
Call LECTURE(COD_OBJ,CLE_LEC,CHAMPS_LUS,BLOB_LUS) From WMNETSTO1
#-----
WMSG ="Article       ="-CLE_LEC-"-"-CHAMPS_LUS(1)+"\"
WMSG+="Désignation   ="-CHAMPS_LUS(2)+"\"
WMSG+="Poids de l'US ="-CHAMPS_LUS(3)+"\"
WMSG+="Unite poids   ="-CHAMPS_LUS(4)+"\"
WMSG+="Gestion lot   ="-CHAMPS_LUS(5)+"\"
WMSG+="Image article ="-CHAMPS_LUS(6)+"\"
Call MESSAGE(WMSG) From GESECRAN
#-----
End


#############################################
$ACTION
Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################


#-------------------------------------------------------#
# Sous-programme de description du web service de liste #
#-------------------------------------------------------#
$DESC_LISTE
Return


#---------------------------------------------------------#
# Sous-programme de description du web service de lecture #
#---------------------------------------------------------#
$DESC_LEC
Return


#-------------------------#
# Sous-programme de liste #
#-------------------------#
$LISTE
Return


#----------------------------------#
# Sous-programme de lecture détail #
# -------------------------------- #
# BLOB_LUS       =  Image article  #
#                                  #
#                                  #
# La classe [F:POQ] est chargée    #
#----------------------------------#
$LECTURE
#----- Image article -----#
#BLOB_LUS =func TRTX3FNC.GETIMGITM([F:POQ]ITMREF)
If !clalev([F:CBB])  Local File CBLOB  [CBB] : Endif
Read [CBB]CBB0="ITM";[F:POQ]ITMREF;""
If !fstat
   BLOB_LUS= [F:CBB]BLOB
Endif
Return


#--------------------------------------------#
# Sous-programme de rafraichissement favoris #
#--------------------------------------------#
$RAFRAICHIR
Return



