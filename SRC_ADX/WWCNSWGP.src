#<AdxTL>@(#)%I%
# Supervisor
# Inquiry WGP

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:30"
A_USER  = "ADMIN"
A_STAMP = "20181109081130"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(43368,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSWGPSTD"
PROGSPE    = "CNSWGPSPE"
CBOITE     = "DCNSWGP"
BOITE      = "FCNSWGP"
NOMMSK(0)  = "CONSWGP1"
ABMSK(0)   = "WGP1"
NOMMSK(1)  = "CONSWGP2"
ABMSK(1)   = "WGP2"
CMEMO      = "wgp"
CNOMMSK    = "CRITWGP"
CABMSK     = "CWGP"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER    [ITM] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT   [ITF] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS      [AUS] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT      [TUN] : Endif
If clalev([F:MFG])=0 : Local File MFGHEAD      [MFG] : Endif
If clalev([F:WGG])=0 : Local File WEIGHING     [WGG] : Endif
If clalev([F:WGP])=0 : Local File WEIGHPRT     [WGP] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CWGP]
 When  0 : Local Mask =NOMMSK(0) [WGP1]
 When  1 : Local Mask =NOMMSK(1) [WGP2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CWGP]
 When  0 : Grizo [WGP1]
 When  1 : Grizo [WGP2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CWGP]ITMREFSTR)>0
 Grizo [CWGP]ITMREFSTR
Endif
If dim([M:CWGP]ITMREFEND)>0
 Grizo [CWGP]ITMREFEND
Endif
If dim([M:CWGP]BOMOPESTR)>0
 Grizo [CWGP]BOMOPESTR
Endif
If dim([M:CWGP]BOMOPEEND)>0
 Grizo [CWGP]BOMOPEEND
Endif
If dim([M:CWGP]MFGNUMSTR)>0
 Grizo [CWGP]MFGNUMSTR
Endif
If dim([M:CWGP]MFGNUMEND)>0
 Grizo [CWGP]MFGNUMEND
Endif
If dim([M:CWGP]CBTDATSTR)>0
 Grizo [CWGP]CBTDATSTR
Endif
If dim([M:CWGP]CBTDATEND)>0
 Grizo [CWGP]CBTDATEND
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CWGP])>0 : Close Local Mask [CWGP] : Endif
 When  0 : If clalev([M:WGP1])>0 : Close Local Mask [WGP1] : Endif
 When  1 : If clalev([M:WGP2])>0 : Close Local Mask [WGP2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CWGP]
 When  0 : Default Mask [WGP1]
 When  1 : Default Mask [WGP2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CWGP]
 When  0 : Raz [M:WGP1]
 When  1 : Raz [M:WGP2]
Endcase
Return

$CRITENT
If dim([M:CWGP]ITMREFSTR)>0 & dim([M:WGP1]ITMREFSTR)>0
 [M:CWGP]ITMREFSTR = [M:WGP1]ITMREFSTR
Endif
If dim([M:CWGP]ITMREFEND)>0 & dim([M:WGP1]ITMREFEND)>0
 [M:CWGP]ITMREFEND = [M:WGP1]ITMREFEND
Endif
If dim([M:CWGP]BOMOPESTR)>0 & dim([M:WGP1]BOMOPESTR)>0
 [M:CWGP]BOMOPESTR = [M:WGP1]BOMOPESTR
Endif
If dim([M:CWGP]BOMOPEEND)>0 & dim([M:WGP1]BOMOPEEND)>0
 [M:CWGP]BOMOPEEND = [M:WGP1]BOMOPEEND
Endif
If dim([M:CWGP]MFGNUMSTR)>0 & dim([M:WGP1]MFGNUMSTR)>0
 [M:CWGP]MFGNUMSTR = [M:WGP1]MFGNUMSTR
Endif
If dim([M:CWGP]MFGNUMEND)>0 & dim([M:WGP1]MFGNUMEND)>0
 [M:CWGP]MFGNUMEND = [M:WGP1]MFGNUMEND
Endif
If dim([M:CWGP]CBTDATSTR)>0 & dim([M:WGP1]CBTDATSTR)>0
 [M:CWGP]CBTDATSTR = [M:WGP1]CBTDATSTR
Endif
If dim([M:CWGP]CBTDATEND)>0 & dim([M:WGP1]CBTDATEND)>0
 [M:CWGP]CBTDATEND = [M:WGP1]CBTDATEND
Endif
Return

$ENTCRIT
If dim([M:CWGP]ITMREFSTR)>0 & dim([M:WGP1]ITMREFSTR)>0
[M:WGP1]ITMREFSTR = [M:CWGP]ITMREFSTR
Endif
If dim([M:CWGP]ITMREFEND)>0 & dim([M:WGP1]ITMREFEND)>0
[M:WGP1]ITMREFEND = [M:CWGP]ITMREFEND
Endif
If dim([M:CWGP]BOMOPESTR)>0 & dim([M:WGP1]BOMOPESTR)>0
[M:WGP1]BOMOPESTR = [M:CWGP]BOMOPESTR
Endif
If dim([M:CWGP]BOMOPEEND)>0 & dim([M:WGP1]BOMOPEEND)>0
[M:WGP1]BOMOPEEND = [M:CWGP]BOMOPEEND
Endif
If dim([M:CWGP]MFGNUMSTR)>0 & dim([M:WGP1]MFGNUMSTR)>0
[M:WGP1]MFGNUMSTR = [M:CWGP]MFGNUMSTR
Endif
If dim([M:CWGP]MFGNUMEND)>0 & dim([M:WGP1]MFGNUMEND)>0
[M:WGP1]MFGNUMEND = [M:CWGP]MFGNUMEND
Endif
If dim([M:CWGP]CBTDATSTR)>0 & dim([M:WGP1]CBTDATSTR)>0
[M:WGP1]CBTDATSTR = [M:CWGP]CBTDATSTR
Endif
If dim([M:CWGP]CBTDATEND)>0 & dim([M:WGP1]CBTDATEND)>0
[M:WGP1]CBTDATEND = [M:CWGP]CBTDATEND
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


