            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYZV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYZV9]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND190_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif


    #---------------------------------------------
    # mise a jour geode v9 
    If GFOLDER_V190(2) <> ""
        # lecture dans le fichier XYXv9 code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYXV9] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYXV9]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYXV9]NUMERO
        Next
        Filter [XYXV9]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur geode on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYXV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYXV9]COMMENT = WTEXTE_COMMENT
                    Gosub GEOIND190_TEXTE From ATRADTEX
               Endif
            Endif
