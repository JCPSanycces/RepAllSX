#<AdxTL>@(#)5.0.0.0 $Revision$
##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits pour la V9
#  utilise par INDUS
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_190
Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE


#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en v8 X3 X3INDAKIRA
# et ensuite on regarde pour la v190
# ----------------------------------------


If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour X3INDAKIRA
    # lecture dans le fichier XYZV8 code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 180 pour x3 code XYZV8 X3INDAKIRA


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XYZV8] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XYZV8]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XYZV8]NUMERO
    Next
    Filter [XYZV8]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur X3INDAKIRA
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYZV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XYZV8]COMMENT = WTEXTE_COMMENT
                Gosub X3IND180_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYZV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYZV8]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND180_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif
Endif

If GPRODUIT = 1
    #---------------------------------------------
    # mise a jour GEOIND180
    # lecture dans le fichier Xxxxx code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 180 pour code XxxxX GEOIND180
    # a faire plus trad
Endif

If GPRODUIT = 2
  # pas de hrm en v8
  If GFOLDER_V180(3) <> ""
    #---------------------------------------------
    # mise a jour PAYIND180
    # lecture dans le fichier XyPv8 code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XYPV8] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XYPV8]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYPV8]NUMERO
    Next
    Filter [XYPV8]
    If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
    Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYPV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYPV8]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND180_TEXTE From ATRADTEX
               Endif
            Endif
    Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYPV8]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYPV8]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND180_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
    Endif
  Endif
Endif

If GPRODUIT = 3
    # n'existe plus en V6
    # abelx3 est dans X3......... depuis la v6
Endif


#--------------------------------------------#
# mise a jour ATEXTE de SUPERV190
# lecture dans le fichier XYSV9 code langue FRA
# recherche du texte correspond 
# dans superv190 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 
#--------------------------------------------#

Raz WTAB_NUM
W_INDICE  =0

Filter [XYSV9] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XYSV9]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XYSV9]NUMERO
Next
Filter [XYSV9]


If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv190 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3 ou geode
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYSV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XYSV9]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV190_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYSV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYSV9]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV190_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif


#--------------------------------------------#
# on fait idem si on est sur x3
# mise a jour ATEXTE de geode et de la paye
#--------------------------------------------#

If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour ABELX V9 : jamais plus 
     If GFOLDER_V190(4) <> ""
     Endif
    #---------------------------------------------
    # mise a jour geode v9 
