                Read [XYXV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYXV9]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub GEOIND190_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif
    #---------------------------------------------
    # mise a jour paye v9 
    If GFOLDER_V190(3) <> ""
        # lecture dans le fichier XYPv9 code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYPV9] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYPV9]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYPV9]NUMERO
        Next
        Filter [XYPV9]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYPV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYPV9]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND190_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYPV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYPV9]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND190_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif

    Endif
Endif

#--------------------------------------------#
# on fait idem si on est sur geodev9
# mise a jour ATEXTE de X3 et la paye
# a faire plus tard
#--------------------------------------------#

If GPRODUIT = 1
Endif

#--------------------------------------------#
# on fait idem si on est sur payev9
# mise a jour ATEXTE de X3  et de geode
#--------------------------------------------#
If GPRODUIT = 2

    #---------------------------------------------
    # mise a jour x3 v9 
    If GFOLDER_V190(1) <> ""
        # lecture dans le fichier XYZv9 code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYZV9] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYZV9]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYZV9]NUMERO
        Next
        Filter [XYZV9]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur x3 on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYZV9]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYZV9]COMMENT = WTEXTE_COMMENT
                    Gosub X3IND190_TEXTE From ATRADTEX
