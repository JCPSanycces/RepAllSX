#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("LISTPOTVAC","") From ETAT
End

####################################################
## Postes vacants
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250)
Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    SRVDEB(GLONSRV), SRVFIN(GLONSRV)
Local Char    JOBDEB(GLONJOT), JOBFIN(GLONJOT), POTDEB(GLONPOT), POTFIN(GLONPOT)
Local Decimal NUMREQ, WNUMLIG, POSTVAC
Local Date    DAT, DATMAT, DATVAC
Local Char    MATRI (GLONEML), CTR(GLONHRCTR)

If clalev([F:ARM])=0 : Local File AREPORTM [ARM] : Endif
If clalev([F:POT])=0 : Local File POSTE    [POT] : Endif
Gosub OUVRE From WPDEFTABLE

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB)
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("jobdeb",NBPAR,PARAMETRE,JOBDEB)
Call GETPARAM("jobfin",NBPAR,PARAMETRE,JOBFIN)
Call GETPARAM("srvdeb",NBPAR,PARAMETRE,SRVDEB)
Call GETPARAM("srvfin",NBPAR,PARAMETRE,SRVFIN)
Call GETPARAM("potdeb",NBPAR,PARAMETRE,POTDEB)
Call GETPARAM("potfin",NBPAR,PARAMETRE,POTFIN)
Call GETPARAM("dat",NBPAR,PARAMETRE,PARAM): DAT=PARAM

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE = "1=1"
If CPYDEB<>"" : CRITERE -= "& [F:POT]CPYPOT>='"+CPYDEB+"'"   : Endif
If CPYFIN<>"" : CRITERE -= "& [F:POT]CPYPOT<='"+CPYFIN+"'"   : Endif
If FCYDEB<>"" : CRITERE -= "& [F:POT]FCYPOT>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE -= "& [F:POT]FCYPOT<='"+FCYFIN+"'"    : Endif
If JOBDEB<>"" : CRITERE -= "& [F:POT]JOBPOT>='"+JOBDEB+"'"    : Endif
If JOBFIN<>"" : CRITERE -= "& [F:POT]JOBPOT<='"+JOBFIN+"'"    : Endif
If SRVDEB<>"" : CRITERE -= "& [F:POT]SRVPOT>='"+SRVDEB+"'"    : Endif
If SRVFIN<>"" : CRITERE -= "& [F:POT]SRVPOT<='"+SRVFIN+"'"    : Endif
If POTDEB<>"" : CRITERE -= "& [F:POT]COD>='"+POTDEB+"'" : Endif
If POTFIN<>"" : CRITERE -= "& [F:POT]COD<='"+POTFIN+"'" : Endif


Call DEBTRANS From GLOCK
Gosub TR1
Call DEBTRANS From GLOCK
Gosub TR2
Call TEMPOFF From GESECRAN
End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]
 I=1
 #Parcours des postes valides à la date de vacance demandée & satisfaisant les critères
 For [POT]POT0 Where evalue(CRITERE) & (DATENDVLY=[0/0/0] | DATENDVLY>=DAT)
  POSTVAC=1
  If [F:POT]DATSTRVLY<>[0/0/0]
   DATVAC = [F:POT]DATSTRVLY
  Else
   DATVAC = DAT
  Endif
  Filter [EPO] Where POT=[F:POT]COD & DATPOT<=DAT
  Read [EPO]EPO2 Last
  Filter [EPO]
  If !fstat
   #Un salarié est affecté au poste courant...
   # Mais fait-il encore partie de l'entreprise ?
   MATRI  = [F:EPO]REFNUM
   DATMAT = DAT
   CTR    = [F:EPO]CTRNUM
   Gosub LECEMP From WPDEFTABLE
   If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT
    POSTVAC = 0
   Else
    DATVAC = [F:HRCTR]XITDAT
   Endif
  Endif
  If POSTVAC=1
   Raz [F:ARM]
   [F:ARM]USR    = GUSER
   [F:ARM]RPTCOD = [L]ETAT
   [F:ARM]NUMREQ = [L]NUMREQ
   [F:ARM]NUMLIG = I
   [F:ARM]CLEA1  = [F:POT]COD
   [F:ARM]CLED1  = DATVAC
   Write [ARM]
   If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break
   Endif
  Endif
  I+=1
 Next
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

