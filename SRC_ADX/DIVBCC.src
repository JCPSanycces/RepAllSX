Raz GPILOBJ
Call OBJET("PIA",GBIDC1,GBIDC2) From GOBJET
End


##################################################
# Contrôles sections
##################################################
Subprog CNTBCC(CCE,AXE,NAMCCE)
Variable Char    CCE()
Value    Char    AXE
Value    Char    NAMCCE
End 


##################################################
# Section disable sur axe interdit
##################################################
Subprog DISBCC(AXE)
Value    Integer AXE
End

