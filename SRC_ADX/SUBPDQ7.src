#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque PDSYPTH
##########################################################################
# SUBPDQ7 : Affichage de la situation d'une rcp       HN 05/02/03        #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action         #
# VISUETAPTH et sert à gérer le masque  écran "PDQ7 [PDQ7]"              #
##########################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUV_VISUETAPTH
 When "TITRE"       : Gosub TITRE_VISUETAPTH
 When "DEBUT"       : Gosub DEB_VISUETAPTH
 When "FINSAI"      : Gosub FINSAI_VISUETAPTH
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "AB1_NBRCP"    : Gosub AB1_NBRCP
Endcase
Return

#############################################################################
# Remplacé par l'action VISUETAPTH                                          #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETAPTH
#----- Variables locales -----#
Local Char     NUMRCP(GLONPTH) : NUMRCP=[M:PTH0]PTHNUM
Local Shortint I, J, K, L, J2, L2
If [M:PTH1]NBLIG=0 FIN=1 : Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETAPTH
TIT=mess(064,198,1)-NUMRCP
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETAPTH
Raz [M:PDQ7]
Call TEMPON("O") From GESECRAN
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:PND])<=0 Local File PRETURND  [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE  [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED [PID] : Endif
If clalev([F:POQ])<=0 Local File PORDERQ   [POQ] : Endif
If clalev([F:POH])<=0 Local File PORDER    [POH] : Endif
#----- Lecture ligne commande à traiter si nécessaire -----#
If [F:PTH]PTHNUM<>NUMRCP
  Read [PTH] PTH0=NUMRCP : If fstat Raz [F:PTH] : Endif
Endif
#-----
[M:PDQ7]=[F:PTH]
If [F:PTH]INVFLG=3  [M:PDQ7]WCLEFLG=2  Else  [M:PDQ7]WCLEFLG=1 : Endif
If [F:PTH]INVLINCTR=0
  [M:PDQ7]INVFLG=1
Elsif [F:PTH]INVLINNBR<[F:PTH]LINNBR
  [M:PDQ7]INVFLG=2
Elsif [F:PTH]INVFLG=3 &
&  sigma(I=0,[M:PTH1]NBLIG-1,([M:PTH1]INVQTYSTU(I)>=[M:PTH1]QTYSTU(I)))<[M:PTH1]NBLIG
  [M:PDQ7]INVFLG=2
Endif
#-----
For [PTD] Where PTHNUM=NUMRCP
  #----- Chargement des zones dans le masque -----#
  [M:PDQ7]PTDLIN(K) =[F:PTD]PTDLIN
  [M:PDQ7]ITMREF(K) =[F:PTD]ITMREF
  [M:PDQ7]POHNUM(K) =[F:PTD]POHNUM
  [M:PDQ7]POPLIN(K) =[F:PTD]POPLIN
  [M:PDQ7]QTYUOM(K) =[F:PTD]QTYUOM
  [M:PDQ7]UOM(K)    =[F:PTD]UOM
  [M:PDQ7]QTYSTU(K) =[F:PTD]QTYSTU
  [M:PDQ7]STU(K)    =[F:PTD]STU
  [M:PDQ7]LININVFLG(K)=[F:PTD]LININVFLG
  #-- Si quantité facturée >= quantité de la réception
  If [F:PTD]INVQTYPUU>0 & [F:PTD]INVQTYPUU>=[F:PTD]QTYPUU
    [M:PDQ7]WLININVFLG(K)=3 : # Totalement facturée
    [M:PDQ7]WINVLINNBR+=1
  Elsif [F:PTD]INVQTYPUU=0
    [M:PDQ7]WLININVFLG(K)=1 : # Non facturée
  Else
    [M:PDQ7]WLININVFLG(K)=2 : # Facturation partielle
  Endif
  If [F:PTD]POHNUM<>""
    If [F:POH]POHNUM<>[F:PTD]POHNUM
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat  Raz [F:POH] : Endif
    Endif
    #----- Lecture ligne commande quantités si nécessaire -----#
    If [F:POQ]POHNUM<>[F:PTD]POHNUM | [F:POQ]POPLIN<>[F:PTD]POPLIN
      Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
      If fstat  Raz [F:POQ] : Endif
    Endif
  Else
    Raz [F:POH], [F:POQ]
  Endif
  [M:PDQ7]POQQTYUOM(K) =[F:POQ]QTYUOM
  [M:PDQ7]POQUOM(K)    =[F:POQ]UOM
  [M:PDQ7]POHTYP(K)    =[F:POH]POHTYP
  Raz I
  Filter [PID] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & SEQORI=0
&                Order By Key PID1
  For [PID]
    Gosub CHARG_LIG_FAC
    If GERR<>0 Break : Endif
  Next
  Filter [PID]
  # Issue 86405 - 2012-12-19 by MUARN : facture sur x commandes avec 1 réception existante sur x commandes
  #If [F:PTD]POHNUM<>"" & sum([M:PDQ7]FACQTYPUU(0..max(0,I-1)))<[F:PTD]INVQTYPUU
  If [F:PTD]POHNUM<>""
    #----- Chargement des factures effectuées sur la ligne de commande -----#
    Filter [PID] Where TYPORI=1 & NUMORI=[F:PTD]POHNUM & LINORI=[F:PTD]POPLIN & SEQORI=[F:PTD]POQSEQ
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC
      If GERR<>0 Break : Endif
    Next
    Filter [PID]
  Endif
  #-- Il y a une qté facturé mais pas sur la réception, ni sur la commande
  #-- Il s'agit d'une autre réception surfacturée
  If [F:PTD]INVQTYPUU>0 & [M:PDQ7]NBFAC=0
  #----- Chargement des factures effectuées sur la ligne de commande -----#
    Filter [PID] Where TYPORI=2 & POHNUM=[F:PTD]POHNUM & POPLIN=[F:PTD]POPLIN & POQSEQ=[F:PTD]POQSEQ
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC
      If GERR<>0 Break : Endif
    Next
    Filter [PID]
  Endif
  Filter [PND] Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[F:PTD]PTDLIN
&              Order By Key PND1
  For [PND]
    Gosub CHARG_LIG_RET
    If GERR<>0 Break : Endif
  Next
  Filter [PND]
  Filter [PID] : Filter [PND]
  K+=1 : [M:PDQ7]NBRCP=K
  If K>dim([M:PDQ7]PTDLIN)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
  Gosub CHARG_COM_FAC
Next
Affzo [PDQ7]
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETAPTH
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
I=[M:PDQ7]NBFAC
If I>dim([M:PDQ7]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
OK=1
For L2=0 To [M:PDQ7]NBFAC-1
  If [M:PDQ7]NUM(L2)=[F:PID]NUM & [M:PDQ7]PIDLIN(L2)=[F:PID]PIDLIN
    OK=0 : Break
  Endif
Next L2
If OK<>0
  [M:PDQ7]PTDLIN1(I)  =[F:PTD]PTDLIN
  [M:PDQ7]TYPORI(I)   =[F:PID]TYPORI
  [M:PDQ7]NUM(I)      =[F:PID]NUM
  [M:PDQ7]PIDLIN(I)   =[F:PID]PIDLIN
  If [F:PIH]NUM<>[F:PID]NUM
    Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
  Endif
  [M:PDQ7]FACQTYPUU(I)=[F:PID]QTYPUU
  If [F:PID]PIHTYP>2 [M:PDQ7]FACQTYPUU(I)=0-[M:PDQ7]FACQTYPUU(I) : Endif
  [M:PDQ7]FACPUU(I)   =[F:PID]PUU
  [M:PDQ7]FACQTYSTU(I)=[F:PID]QTYSTU
  [M:PDQ7]FACSTU(I)   =[F:PID]STU
  If [F:PID]PIHTYP>2 [M:PDQ7]FACQTYSTU(I)=0-[M:PDQ7]FACQTYSTU(I) : Endif
  [M:PDQ7]NETPRI(I)   =[F:PID]NETPRI
  [M:PDQ7]CUR(I)      =[F:PIH]CUR
  [M:PDQ7]AMTNOTLIN(I)=[F:PID]AMTNOTLIN
  If [F:PID]PIHTYP>2 [M:PDQ7]AMTNOTLIN(I)=0-[M:PDQ7]AMTNOTLIN(I) : Endif
  I+=1 : [M:PDQ7]NBFAC=I
  If I>dim([M:PDQ7]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Endif
Return

#----------------------------#
# Chargement ligne de retour #
#----------------------------#
$CHARG_LIG_RET
[M:PDQ7]PTDLIN2(J)  =[F:PND]PTDLIN
[M:PDQ7]PNHNUM(J)   =[F:PND]PNHNUM
[M:PDQ7]PNDLIN(J)   =[F:PND]PNDLIN
[M:PDQ7]RTNQTYPUU(J)=[F:PND]QTYPUU
[M:PDQ7]RTNPUU(J)   =[F:PND]PUU
[M:PDQ7]RTNQTYSTU(J)=[F:PND]QTYSTU
[M:PDQ7]RTNSTU(J)   =[F:PND]STU
#----- Positionnement indicateur facturé -----#
If [F:PND]LININVFLG=2
  [M:PDQ7]XLININVFLG(J)=3 : # Totalement facturé
Elsif [F:PND]INVQTYPUU<>0
  [M:PDQ7]XLININVFLG(J)=2 : # Facturation partielle
Else
  [M:PDQ7]XLININVFLG(J)=1 : # Non facturé
Endif
#-----
J+=1 : [M:PDQ7]NBPNH=J
If J>dim([M:PDQ7]PNHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Gosub CHARG_RET_FAC
Return

$CHARG_RET_FAC
#---------------------------#
# Chargement des avoir      #
#---------------------------#
For J2=0 To [M:PDQ7]NBPNH-1
  If [M:PDQ7]XLININVFLG(J2)>1
    I=[M:PDQ7]NBFAC
    If I+1>dim([M:PDQ7]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Filter [PID] Where TYPORI=3 & PNHNUM=[M:PDQ7]PNHNUM(J2) & PNDLIN=[M:PDQ7]PNDLIN(J2)
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC : If GERR=2  Break : Endif
    Next
    Filter [PID]
  Endif
Next J2
Return


$CHARG_COM_FAC
#---------------------#
# Chargement fac comp #
#---------------------#
For L=0 To [M:PDQ7]NBFAC-1
   I=[M:PDQ7]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDQ7]NUM(L) & LINORI=[M:PDQ7]PIDLIN(L)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC : If GERR=2  Break : Endif
   Next
   Filter [PID]
Next L
Return

##########################################################################

Subprog IB_NBRCP
#-------------------#
# Init bouton nbrcp #
#-------------------#
Raz GBOUT1
If dim([M:PDQ7]POHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDQ7]POHNUM(nolign-1)<>"" & GFONC1<>"GESPOH"
  GBOUT1=mess(191,198,1)-[M:PDQ7]POHNUM(nolign-1)
Endif
Call IB_NOTECHECK([M:PDQ7]ITMREF(nolign-1),"ITMREF",2) From TRTNTSCTL # product notes  EWI 86291
End

$AB1_NBRCP
#------------------------------------------------------#
# Avant exécution du bouton Tunnel commandes, contrats #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONPOH)
Local Char     WCLE2(GLONPOH)
If [F:POH]POHNUM<>[M:PDQ7]POHNUM(NOL)
 Read [POH]POH0=[M:PDQ7]POHNUM(NOL)
 If fstat Raz [F:POH] : Endif
Endif
If [F:POH]POHTYP = 2
  WOBJET="POD"
  WCLE1 =num$([M:PTH1]POPLIN (NOL))
  WCLE2 =[M:PTH1]POHNUM (NOL)
Else
  WOBJET="POH"
  WCLE1=[M:PTH1]POHNUM (NOL)
  WCLE2=""
Endif
Return

Subprog IB_NBFAC
#-------------------#
# Init bouton nbfac #
#-------------------#
Raz GBOUT1
If dim([M:PDQ7]NUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDQ7]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(55,198,1)-[M:PDQ7]NUM(nolign-1)
Endif
End

Subprog IB_NBPNH
#-------------------#
# Init bouton nbpnh #
#-------------------#
Raz GBOUT1
If dim([M:PDQ7]PNHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDQ7]PNHNUM(nolign-1)<>"" & GFONC1<>"GESPNH"
  GBOUT1=mess(192,198,1)-[M:PDQ7]PNHNUM(nolign-1)
Endif
End
