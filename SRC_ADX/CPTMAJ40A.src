 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 167
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/25-1",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 25;2
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 25
 [F:CCL]NUMLIG = 2
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 168
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/25-2",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 15;31
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 15
 [F:CCL]NUMLIG = 31
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 180
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/15-31",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 23;6
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 23
 [F:CCL]NUMLIG = 6
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 178
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/23-6",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 23;7
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 23
 [F:CCL]NUMLIG = 7
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 179
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/23-7",1) From DOSDIC
 Endif
Endif

Commit
Close Local File [CCL]
Return
# Update ADI 97 + GRP AREPORT
$AREPORT_97
Local Integer OK_GRP

Local File =[F:ADS]DOSSIER+".APLSTD" [APL]
Local File =[F:ADS]DOSCOP +".APLSTD" [APLC]

Call ECR_TIME(mess(81,125,1)-": APLSTD - 97 ") From DOSSUB : # maj table

Filter [APLC] Where LANCHP=97

Trbegin [APL]
For [F:APLC]
 Read [F:APL]CLE = [F:APLC]LANCHP;[F:APLC]LANNUM;[F:APLC]LAN
 [F:APL] = [F:APLC]
 If !fstat
  Rewrite [F:APL]
 Else
  Write [F:APL]
 Endif
 If fstat
  Call ERREUR("APLSTD"-":"-num$([F:APLC]LANCHP)-num$([F:APLC]LANNUM)-[F:APLC]LAN,1) From DOSDIC : Break
 Endif
Next

Commit
Filter [APLC]
Close Local File [APL], [APLC]


Call ECR_TIME(mess(81,125,1)-": AREPORT (GRP-97) ") From DOSSUB : # maj table
Local File =DOSSIER+".AREPORT"  [ARP]

OK_GRP = 1
Trbegin [ARP]

Update [ARP] Where RPTCOD="CONTVAENC"       With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="CONTVAPCE"       With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLESD2"         With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLVATDEB2"      With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLVATENC2"      With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="GLVATGEN"        With GRP=60 : If fstat : OK_GRP = 0 : Endif  #V8/V7

Update [ARP] Where RPTCOD="TRG"             With GRP=61 : If fstat : OK_GRP = 0 : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL1"         With GRP=61 : If fstat : OK_GRP = 0 : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL2"         With GRP=61 : If fstat : OK_GRP = 0 : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL3"         With GRP=61 : If fstat : OK_GRP = 0 : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL4"         With GRP=61 : If fstat : OK_GRP = 0 : Endif  #V8

Update [ARP] Where RPTCOD="S-LIBROREP"      With GRP=62 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROREPCAJA"  With GRP=62 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROSOP"      With GRP=62 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROSOPCAJA"  With GRP=62 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-RETENCION"     With GRP=62 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-RESIVA"        With GRP=62 : If fstat : OK_GRP = 0 : Endif  ###/V7

Update [ARP] Where RPTCOD="P-PERVAT"        With GRP=63 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="P-VATPORBAS"     With GRP=63 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="P-YEAVAT"        With GRP=63 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="DADSU"           With GRP=64 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="DAS2"            With GRP=64 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="LETTREDAS"       With GRP=64 : If fstat : OK_GRP = 0 : Endif  #V8/V7

Update [ARP] Where RPTCOD="HON281"          With GRP=65 : If fstat : OK_GRP = 0 : Endif  #V8/V7

Update [ARP] Where RPTCOD="1099ACT"         With GRP=66 : If fstat : OK_GRP = 0 : Endif  #V8/V7

Update [ARP] Where RPTCOD="AUTRS"           With GRP=67 : If fstat : OK_GRP = 0 : Endif  #V8/V7
Update [ARP] Where RPTCOD="AUTRSVAL"        With GRP=67 : If fstat : OK_GRP = 0 : Endif  #V8/V7

Update [ARP] Where RPTCOD="HONPRV"          With GRP=68 : If fstat : OK_GRP = 0 : Endif  #V8/V7

If !OK_GRP
 Call ERREUR("AREPORT (GRP-97)",2) From DOSDIC
Endif

Commit
Close Local File [ARP]
Return

