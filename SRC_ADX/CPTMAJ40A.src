#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Call ACPTMAJ30 From CPTMAJ40
#Call ATRSMAJ30 From CPTMAJ40
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##--------------------------------------------------------------------------------------------------------------------
# ... MAJ40 : Mises à jour à effectuer lors du passage à la version 7
##--------------------------------------------------------------------------------------------------------------------
# $MAJTXTGTE    : Update ATEXTRA for GTE
# $MAJTXTJOU    : Update ATEXTRA for JOU
# $MAJTXTTPY    : Update ATEXTRA for TPY
# $MAJTXTCDA    : Update ATEXTRA for CDA
# $MAJTXTTFB    : Update ATEXTRA for TFB
# $MAJAOBGTE    : Update ACLOB, ABLOB, AOBJTXT, AOBJTXTA for GTE
# $MAJAOBJOU    : Update ACLOB, ABLOB, AOBJTXT, AOBJTXTA for JOU
# $MAJAOBTPY    : Update ACLOB, ABLOB, AOBJTXT, AOBJTXTA for TPY
# $MAJAOBCDA    : Update ACLOB, ABLOB, AOBJTXT, AOBJTXTA for CDA
# $MAJAOBTFB    : Update ACLOB, ABLOB, AOBJTXT, AOBJTXTA for TFB
# $GJOUCOA      : Init. new field LEG in the GJOUCOA
# $GJOUSTA      : Init. new field LEG in the GJOUSTA
# $PARAMLEGVAT  : Init. new parameters [LEG]VAT  - BRI/GER/POR/SPA/SWI
# $INILEGGAUGAD : Init new field LEG for GAU/GAD
# $TABFILBAN    : Texts of translate
# $MAJAMKTPY    : Cancellation of Obselete's screen and windows for object TPY
# $MAJTXTTBU    : Update ATEXTRA for TBU
# $MAJTAM       : Init new records (ATABDIV 3 Obselete)
# $MAJTED       : Init new records (ATABDIV 304 Obselete)
# $CACCEDEF     : ML693 : 2 news values
# $GACCCODLIG   : Accounting code lines V7
# $AREPORT_97   : Update ADI 97 + GRP AREPORT
##--------------------------------------------------------------------------------------------------------------------

#

##--------------------------------------------------------------------------------------------------------------------
##--------------------------------------------------------------------------------------------------------------------
$MAJTXTGTE
TABLE="GTYPACCENT"  : CODE="GTE" : Gosub MAJTXT
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTXTJOU
TABLE="GJOURNAL"    : CODE="JOU" : Gosub MAJTXT
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTXTTPY
TABLE="TABPAYTYP"   : CODE="TPY" :  Gosub MAJTXT
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTXTCDA
TABLE="GACCDENCOD"  : CODE="CDA" :  Gosub MAJTXT
Return

$MAJTXT
If filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSSIER),0)>0

 Call ECR_TIME(mess(81,125,1)-": ATEXTRA-"+TABLE) From DOSSUB : # maj table
 Local File =[F:ADS]DOSSIER+"."+TABLE  [LEG]
 Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX]

 Trbegin [AXX]
 For [LEG]
  If [F:LEG]LEG<>""
   Gosub MAJTXT_2
  Endif
 Next
 Commit

 Close Local File [LEG],[AXX]
Endif
Return

$MAJTXT_2
Case CODE
 When "JOU" : Gosub JOU_TXT
 When "GTE" : Gosub GTE_TXT
 When "TPY" : Gosub TPY_TXT
 When "CDA" : Gosub CDA_TXT
Endcase
Return

$GTE_TXT
Update [AXX] Where CODFIC=TABLE & IDENT1=[F:LEG]TYP With IDENT2=[F:LEG]LEG
If fstat
 Call ERREUR("ATEXTRA"-TABLE-[F:LEG]TYP-[F:LEG]LEG,2) From DOSDIC
Endif
Return

##--------------------------------------------------------------------------------------------------------------------
$JOU_TXT
Update [AXX] Where CODFIC=TABLE & IDENT1=[F:LEG]JOU With IDENT2=[F:LEG]LEG
If fstat
 Call ERREUR("ATEXTRA"-TABLE-[F:LEG]JOU-[F:LEG]LEG,2) From DOSDIC
Endif
Return
##--------------------------------------------------------------------------------------------------------------------
$TPY_TXT
Update [AXX] Where CODFIC=TABLE & IDENT1=[F:LEG]PAYTYP With IDENT2=[F:LEG]LEG
If fstat
 Call ERREUR("ATEXTRA"-TABLE-[F:LEG]PAYTYP-[F:LEG]LEG,2) From DOSDIC
Endif
Return

##--------------------------------------------------------------------------------------------------------------------
$CDA_TXT
Update [AXX] Where CODFIC=TABLE & IDENT1=[F:LEG]COD With IDENT2=[F:LEG]LEG
If fstat
 Call ERREUR("ATEXTRA"-TABLE-[F:LEG]COD-[F:LEG]LEG,2) From DOSDIC
Endif
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAOBGTE
Local File =[F:ADS]DOSSIER+".GTYPACCENT"  [GTE]
TABLE="GTYPACCENT" : CODE="GTE" :  COD_C = "CO_GTE" : COD_P = "PJ_GTE" : Gosub MAJAOB
Close Local File [GTE]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAOBJOU
Local File =[F:ADS]DOSSIER+".GJOURNAL"  [JOU]
TABLE="GJOURNAL"   : CODE="JOU" :  COD_C = "CO_JOU" : COD_P = "PJ_JOU" : Gosub MAJAOB
Close Local File [JOU]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAOBTPY
Local File =[F:ADS]DOSSIER+".TABPAYTYP" [TPY]
TABLE="TABPAYTYP"   : CODE="TPY" :  COD_C = "CO_TPY" : COD_P = "PJ_TPY" : Gosub MAJAOB
Close Local File [TPY]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAOBCDA
Local File =[F:ADS]DOSSIER+".GACCDENCOD"  [CDA]
TABLE="GACCDENCOD"   : CODE="CDA" :  COD_C = "CO_CDA" : COD_P = "PJ_CDA" : Gosub MAJAOB
Close Local File [CDA]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAOBTFB
Local File =[F:ADS]DOSSIER+".TABFILBAN"  [TFB]
TABLE="TABFILBAN"   : CODE="TFB" :  COD_C = "CO_TFB" : COD_P = "PJ_TFB" : Gosub MAJAOB
Close Local File [TFB]
Return

$MAJAOB
For J=1 To 4
 Case J
  When 1
   TABAOB = "ACLOB"
   Call ECR_TIME(mess(81,125,1)-":"-TABAOB-TABLE) From DOSSUB : # maj table
   Local File =[F:ADS]DOSSIER+".ACLOB"    [FIC]
   Local File =[F:ADS]DOSSIER+".ACLOB"    [FIC1]
   For [FIC] Where CODBLB=COD_C
    Gosub MAJAOB_2
   Next
   Close Local File [FIC], [FIC1]
  When 2
   TABAOB = "ABLOB"
   Call ECR_TIME(mess(81,125,1)-":"-TABAOB-TABLE) From DOSSUB : # maj table
   Local File =[F:ADS]DOSSIER+".ABLOB"    [FIC]
   Local File =[F:ADS]DOSSIER+".ABLOB"    [FIC1]
   For [FIC] Where CODBLB=COD_P
    Gosub MAJAOB_2
   Next
   Close Local File [FIC], [FIC1]
  When 3
   TABAOB = "AOBJTXT"
   Call ECR_TIME(mess(81,125,1)-":"-TABAOB-TABLE) From DOSSUB : # maj table
   Local File =[F:ADS]DOSSIER+".AOBJTXT"    [FIC]
   Local File =[F:ADS]DOSSIER+".AOBJTXT"    [FIC1]
   For [FIC] Where ABREV=CODE
    Gosub MAJAOB_2
   Next
   Close Local File [FIC], [FIC1]
  When 4
   TABAOB = "AOBJTXTA"
   Call ECR_TIME(mess(81,125,1)-":"-TABAOB-TABLE) From DOSSUB : # maj table
   Local File =[F:ADS]DOSSIER+".AOBJTXTA"    [FIC]
   Local File =[F:ADS]DOSSIER+".AOBJTXTA"    [FIC1]
   For [FIC] Where ABREV=CODE
    Gosub MAJAOB_2
   Next
   Close Local File [FIC], [FIC1]
 Endcase
Next
Return

$MAJAOB_2
Case CODE
 When "JOU" : Gosub JOU_AOB
 When "GTE" : Gosub GTE_AOB
 When "TPY" : Gosub TPY_AOB
 When "CDA" : Gosub CDA_AOB
 When "TFB" : Gosub TFB_AOB
Endcase
Return

$JOU_AOB
Read [JOU]JOU0=[F:FIC]IDENT1
If !fstat
 [F:FIC1] = [F:FIC]
 [F:FIC1]IDENT1 = [F:JOU]LEG
 [F:FIC1]IDENT2 = [F:JOU]JOU
 Write [FIC1]
 If fstat
  Call ERREUR(TABAOB-[F:FIC1]IDENT1-[F:FIC1]IDENT2,1) From DOSDIC
 Endif
 Delete [FIC]Curr
 If fstat
  Call ERREUR(TABAOB-[F:FIC]IDENT1-[F:FIC]IDENT2,3) From DOSDIC
 Endif
Endif
Return

$GTE_AOB
Read [GTE]GTE0=[F:FIC]IDENT1
If !fstat
 [F:FIC1] = [F:FIC]
 [F:FIC1]IDENT1 = [F:GTE]LEG
 [F:FIC1]IDENT2 = [F:GTE]TYP
 Write [FIC1]
 If fstat
  Call ERREUR(TABAOB-[F:FIC1]IDENT1-[F:FIC1]IDENT2,1) From DOSDIC
 Endif
 Delete [FIC]Curr
 If fstat
  Call ERREUR(TABAOB-[F:FIC]IDENT1-[F:FIC]IDENT2,3) From DOSDIC
 Endif
Endif
Return

$TPY_AOB
Read [TPY]TPY0=[F:FIC]IDENT1
If !fstat
 [F:FIC1] = [F:FIC]
 [F:FIC1]IDENT1 = [F:TPY]LEG
 [F:FIC1]IDENT2 = [F:TPY]PAYTYP
 Write [FIC1]
 If fstat
  Call ERREUR(TABAOB-[F:FIC1]IDENT1-[F:FIC1]IDENT2,1) From DOSDIC
 Endif
 Delete [FIC]Curr
 If fstat
  Call ERREUR(TABAOB-[F:FIC]IDENT1-[F:FIC]IDENT2,3) From DOSDIC
 Endif
Endif
Return

$CDA_AOB
Read [CDA]CDA0=[F:FIC]IDENT1
If !fstat
 [F:FIC1] = [F:FIC]
 [F:FIC1]IDENT1 = [F:CDA]LEG
 [F:FIC1]IDENT2 = [F:CDA]COD
 Write [FIC1]
 If fstat
  Call ERREUR(TABAOB-[F:FIC1]IDENT1-[F:FIC1]IDENT2,1) From DOSDIC
 Endif
 Delete [FIC]Curr
 If fstat
  Call ERREUR(TABAOB-[F:FIC]IDENT1-[F:FIC]IDENT2,3) From DOSDIC
 Endif
Endif
Return

$TFB_AOB
I  = instr(1,[F:FIC]IDENT2,"~")
Filter [TFB] Where COD=left$([F:FIC]IDENT2,I-1) & BAN=[F:FIC]IDENT1 & RECTYP=val(mid$([F:FIC]IDENT2,I+1,1))
&                & ORDNUM=val(mid$([F:FIC]IDENT2,I+3,len([F:FIC]IDENT2)-(I+3)))
Read [TFB]TFB0 First
Filter [TFB]
If !fstat
 [F:FIC1] = [F:FIC]
 [F:FIC1]IDENT2 = [F:FIC]IDENT2+[F:TFB]LEG+"~"
 Write [FIC1]
 If fstat
  Call ERREUR(TABAOB-[F:FIC1]IDENT1-[F:FIC1]IDENT2,1) From DOSDIC
 Endif
 Delete [FIC]Curr
 If fstat
  Call ERREUR(TABAOB-[F:FIC]IDENT1-[F:FIC]IDENT2,3) From DOSDIC
 Endif
Endif
Return

##--------------------------------------------------------------------------------------------------------------------
$GJOUCOA
## Mise à jour du nouveau champ LEG dans la table GJOUCOA. Il est vide par défaut.
## Pour les journaux ayant une législation, il faut mettre ce champ à la législation du journal
Call ECR_TIME(mess(81,125,1)-": GJOUCOA") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".GJOURNAL"  [JOU]
Local File =[F:ADS]DOSSIER+".GJOUCOA"   [JCO]

Trbegin [JCO]
 For [JOU] Where LEG<>""
  For [JCO] Where JOU=[F:JOU]JOU
   [F:JCO]LEG    = [F:JOU]LEG
   Rewrite [JCO]
   If fstat
    Call ERREUR("JCO"-[F:JCO]JOU-[F:JCO]COA-[F:JCO]LEG,2) From DOSDIC
   Endif
  Next
 Next
Commit
Close Local File [JOU], [JCO]
Return

##--------------------------------------------------------------------------------------------------------------------
$GAJOUSTA
## Mise à jour du nouveau champ LEG dans la table GAJOUSTA. Il est vide par défaut.
## Pour les sociétés ayant une législation, il faut mettre ce champ à la législation du journal

## NB : dans le contexte d'une migration V5->V7, la législation est mise à jour dans le traitement CPTMAJ30B
If filinfo(filpath("FIL","GAJOUSTA","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif

Call ECR_TIME(mess(81,125,1)-": GAJOUSTA") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".COMPANY"  [CPY]
Local File =[F:ADS]DOSSIER+".GAJOUSTA" [JST]

Trbegin [JST]
 For [CPY] Where LEG<>"" & CPYLEGFLG=2
  For [JST] Where CPY=[F:CPY]CPY
   [F:JST]LEG = [F:CPY]LEG
   Rewrite [JST]
   If fstat
    Call ERREUR("JST"-[F:JST]JOU-[F:JST]CPY-[F:JST]LEG,2) From DOSDIC
   Endif
  Next
 Next
Commit
Close Local File [CPY], [JST]
Return

##--------------------------------------------------------------------------------------------------------------------
$PARAMLEGVAT
## Alimentation des paramètres [LEG]VAT  - BRI/GER/POR/SPA/SWI #

# Affectation of [LEG]VAT parameters in migration
# Rules :
# * at 'No' in the folder level
# * at 'Yes' in the Legislation level

Call ECR_TIME(mess(81,125,1)-": ADOVAL (VATxxx)") From DOSSUB : # maj table

LEGTAB(1) = "BRI"
LEGTAB(2) = "GER"
LEGTAB(3) = "POR"
LEGTAB(4) = "SPA"
LEGTAB(5) = "SWI"

Trbegin [MADW]
For I=1 To NBLEG
 [L]DOLEG=0
 Case LEGTAB(I)
  When "BRI" : [L]DOLEG = func ACTIV("KUK")
  When "GER" : [L]DOLEG = func ACTIV("KDE")
  When "POR" : [L]DOLEG = func ACTIV("KPO")
  When "SPA" : [L]DOLEG = func ACTIV("KSP")
  When "SWI" : [L]DOLEG = func ACTIV("KSW")
 Endcase
 If [L]DOLEG
  PARAMETER = LEGTAB(I)+"VAT"
  Read [MADP]ADP0 = "LOC";PARAMETER
  If !fstat
    # Folder level
    Read [MADW]ADW0 = "";"";PARAMETER
    If !fstat
     [F:MADW]VALEUR = "1"
     [F:MADW]UPDUSR = GUSER
     [F:MADW]UPDDAT = date$
     [F:MADW]UPDDATTIM = time
     Rewrite [MADW]
     If fstat
      Call ERREUR("ADOVAL"-[F:MADW]CMP+"/"+[F:MADW]FCY+"/"+[F:MADW]PARAM,2) From DOSDIC
     Endif
    Else
     Raz [MADW]
     [F:MADW]CMP    = ""
     [F:MADW]FCY    = ""
     [F:MADW]PARAM  = PARAMETER
     [F:MADW]VALEUR = "1"
     [F:MADW]CREUSR = GUSER
     [F:MADW]CREDAT = date$
     [F:MADW]CREDATTIM = time
     Write [MADW]
     If fstat
      Call ERREUR("ADOVAL"-[F:MADW]CMP+"/"+[F:MADW]FCY+"/"+[F:MADW]PARAM,1) From DOSDIC
     Endif
    Endif
    # Legislation level
    Read [MADW]ADW0 = "*";LEGTAB(I);PARAMETER
    If !fstat
     [F:MADW]VALEUR = "2"
     [F:MADW]UPDUSR = GUSER
     [F:MADW]UPDDAT = date$
     [F:MADW]UPDDATTIM = time
     Rewrite [MADW]
     If fstat
      Call ERREUR("ADOVAL"-[F:MADW]CMP+"/"+[F:MADW]FCY+"/"+[F:MADW]PARAM,2) From DOSDIC
     Endif
    Else
     Raz [MADW]
     [F:MADW]CMP    = "*"
     [F:MADW]FCY    = LEGTAB(I)
     [F:MADW]PARAM  = PARAMETER
     [F:MADW]VALEUR = "2"
     [F:MADW]CREUSR = GUSER
     [F:MADW]CREDAT = date$
     [F:MADW]CREDATTIM = time
     Write [MADW]
     If fstat
      Call ERREUR("ADOVAL"-[F:MADW]CMP+"/"+[F:MADW]FCY+"/"+[F:MADW]PARAM,1) From DOSDIC
     Endif
    Endif
  Else
   # Parameter doesn't exist !
   # I don't know yet what to do in that case?
  Endif
 Endif
Next
Commit
Return

Funprog ACTIV(COD)
Value Char COD
If COD="" : End 1 : Endif
If [F:MACV]CODACT<>COD
 Read [MACV]CODACT = COD
 If fstat : End 0 : Endif
Endif
If [F:MACV]FLACT<>2
 End 0
Elsif [F:MACV]TYP=2
 End [F:MACV]DIME
Else
 End 1
Endif
End 0

##--------------------------------------------------------------------------------------------------------------------
$TXSAC

If filinfo(filpath("FIL","TXSAC","fde",[F:ADS]DOSSIER),0)>0
 Call ECR_TIME(mess(81,125,1)-": TXSAC") From DOSSUB : # Mise à jour de la table


 Local File =[F:ADS]DOSSIER+".TXSA"    [TXS]
 Local File =[F:ADS]DOSSIER+".TXSAC"   [TXA]
 Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX]

 Trbegin [TXA]
 For [TXS]TXS1
  For I=0 To [F:TXS]NBRCOL-1
   Raz [F:TXA]
   [F:TXA]TXSNAM = [F:TXS]TXSNAM
   [F:TXA]NUMCOL = I+1
   [F:TXA]COLNUM = [F:TXS]COLNUM(I)
   If dim([F:TXS]SAICOL)>0
    [F:TXA]SAICOL = [F:TXS]SAICOL(I)
   Else : # C'est une migration V5->V7, on initialise SAICOL à 1 comme dans la migration V5->V6
    [F:TXA]SAICOL = 1
   Endif
   [F:TXA]FMTCOL = [F:TXS]FMTCOL(I)
   [F:TXA]EFFCOL = [F:TXS]EFFCOL(I)
   [F:TXA]DIVCOL = [F:TXS]DIVCOL(I)
   [F:TXA]DECCOL = [F:TXS]DECCOL(I)
   [F:TXA]CREDAT = date$
   [F:TXA]CREUSR = GUSER
   Write [TXA]
   If fstat
    Call ERREUR("TXSAC"-[F:TXS]TXSNAM-num$(I+1),1) From DOSDIC
   Endif
  Next
 Next
 Commit

 Trbegin [AXX]
  Update [AXX] Where CODFIC="TXSA" & ZONE="NAMCOL" With CODFIC="TXSAC"
  If fstat
   Call ERREUR("ATEXTRA"-"TXSA-NAMCOL",2) From DOSDIC
  Endif
 Commit
 Close Local File [TXS], [TXA], [AXX]
Endif
Return


##--------------------------------------------------------------------------------------------------------------------
$INILEGGAUGAD
# Initialisation des législations dans les pièces automatiques, toutes les législations présentes
# dans la table diverse 909 sont activées
Call ECR_TIME(mess(81,125,1)-": GAUTACE &"-mess(81,125,1)-": GAUTACED") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI]
Local File =[F:ADS]DOSSIER+".GAUTACE"  [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED" [GAD]

Local Integer NB

Trbegin [GAU],[GAD]
 Filter [ADI] Where NUMTAB=909
 # En-têtes
 For [GAU]GAU0
  NB=0
  For [ADI]CODE
   [F:GAU]ACTLEG(NB) = [F:ADI]CODE
   NB+=1
  Next
  [F:GAU]NBRLEG=NB
  Rewrite [GAU]
  If fstat
   Call ERREUR("GAU"-[F:GAU]COD,2) From DOSDIC
  Endif
 Next
 # Lignes
 For [GAD]GAD0
  NB=0
  For [ADI]CODE
   [F:GAD]ACTLEG(NB) = [F:ADI]CODE
   NB+=1
  Next
  [F:GAD]NBRLEG=NB
  Rewrite [GAD]
  If fstat
   Call ERREUR("GAD"-[F:GAD]COD-num$([F:GAD]LINNUM),2) From DOSDIC
  Endif
 Next
 Filter [ADI]
Commit

Close Local File [ADI], [GAU], [GAD]
Return

$TABFILBAN
If filinfo(filpath("FIL","TABFILBAN","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TABFILBAN"  [TFB]
Call ECR_TIME(mess(81,125,1)-": TABFILBAN") From DOSSUB : # maj table
Trbegin [TFB]
For [TFB]TFB0
 If dim([F:TFB]DES)>0  & [F:TFB]RECTYP=1
  Call MAJTEXTRA([F:TFB]DES,"TABFILBAN","DESTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From CPTMAJ40
 Endif
 If dim([F:TFB]DESSHO)>0 &  [F:TFB]RECTYP=1
  Call MAJTEXTRA([F:TFB]DESSHO,"TABFILBAN","SHOTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From CPTMAJ40
 Endif
 [F:TFB]BANLEG = [F:TFB]BAN+"~"+[F:TFB]LEG
 Rewrite [TFB]
 If fstat
  Call ERREUR("TFB"-[F:TFB]COD-[F:TFB]BAN-num$([F:TFB]RECTYP)-num$([F:TFB]ORDNUM)-[F:TFB]LEG-num$([F:TFB]NUM),1) From DOSDIC
 Endif
Next
Commit
Close Local File [TFB]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJAMKTPY
If filinfo(filpath("FIL","TABPAYTYP","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TABPAYTYP"   [TPY]
Call ECR_TIME(mess(63,125,1)-mess(54,125,1)-mess(98,125,1)) From DOSSUB : # Transaction de règlement : suppression écran, suppression fenêtre

Local Char OLDMSK1(12),OLDMSK2(12),OLDWIN(12)

For [TPY]
 OLDMSK1 = "WMPY1"+[F:TPY]PAYTYP
 OLDMSK2 = "WMPY2"+[F:TPY]PAYTYP
 Call TR_DELMSK(OLDMSK1,[F:ADS]DOSSIER) From MSKDIV
 Call TR_DELMSK(OLDMSK2,[F:ADS]DOSSIER) From MSKDIV
  OLDWIN = "WOPY"+[F:TPY]PAYTYP
 Call TR_DELWIN(OLDWIN,[F:ADS]DOSSIER) From MSKDIV
Next
Close Local File [TPY]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTXTTBU
If filinfo(filpath("FIL","TABBUDTYP","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif

Call ECR_TIME(mess(81,125,1)-": ATEXTRA-TABBUDTYP") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX]
Trbegin [AXX]

Update [AXX] Where CODFIC="TABBUDTYP" & ZONE="DESTRA" With IDENT2=""
If fstat : Call ERREUR("ATEXTRA-TABBUDTYP-DESTRA",2) From DOSDIC : Endif
Update [AXX] Where CODFIC="TABBUDTYP" & ZONE="SHOTRA" With IDENT2=""
If fstat : Call ERREUR("ATEXTRA-TABBUDTYP-SHOTRA",2) From DOSDIC : Endif
Commit
Close Local File [AXX]

Local File =[F:ADS]DOSSIER+".TABBUDTYP"  [TBU]
Trbegin [TBU]
For [TBU]TBU0
 If dim([F:TBU]COLDES)>0
  Call MAJTEXTRA([F:TBU]COLDES,"TABBUDTYP","COLDESTRA",[F:TBU]BUDTYP,num$([F:TBU]COLNUM)) From CPTMAJ40
 Endif
Next
Commit
Close Local File [TBU]
Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTAM
If filinfo(filpath("FIL","TABPAM","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TABPAM"   [TAM]
Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI]
Local File =[F:ADS]DOSSIER+".ATEXTRA"  [AXX]
Filter [ADI] Where NUMTAB=3

Trbegin [TAM]
For [ADI]
 [F:TAM]PAM    = [F:ADI]CODE
 [F:TAM]LEG    = [F:ADI]LEG
 If [F:TAM]LEG="" & WVERSION<30  : [F:TAM]LEG=LEGREF : Endif
 [F:TAM]SOI    = [F:ADI]A1
 [F:TAM]ACCEPT = val([F:ADI]A2)

 If [F:TAM]ACCEPT>0
  [F:TAM]ACCEPTFLG=2
 Else
  [F:TAM]ACCEPTFLG=1
 Endif

 If [F:ADI]N1=2
  [F:TAM]PAPTRT=2
 Else
  [F:TAM]PAPTRT=1
 Endif

 [F:TAM]TYP=[F:ADI]N2
 If [F:ADI]N2=9 : [F:TAM]SDDFLG=2 : Endif

 Update [AXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="3" & IDENT2=[F:ADI]CODE
&              With CODFIC="TABPAM", ZONE="DESAXX", IDENT1=[F:TAM]PAM, IDENT2=[F:TAM]LEG
 If fstat
  Call ERREUR("ATEXTRA-TABPAM-DESAXX"-[F:TAM]PAM-[F:TAM]LEG,2) From DOSDIC
 Endif

 Update [AXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="3"  & IDENT2=[F:ADI]CODE
&              With CODFIC="TABPAM", ZONE="SHOAXX", IDENT1=[F:TAM]PAM, IDENT2=[F:TAM]LEG
 If fstat
  Call ERREUR("ATEXTRA-TABPAM-SHOAXX"-[F:TAM]PAM-[F:TAM]LEG,2) From DOSDIC
 Endif

 [F:TAM]UPDUSR = ""
 [F:TAM]UPDDAT = [0/0/0]
 [F:TAM]CREUSR = GUSER
 [F:TAM]CREDAT = date$

 [F:TAM]ENAFLG = 2

 Write [F:TAM]
 If fstat
  Call ERREUR("TABPAM"-[F:TAM]PAM-[F:TAM]LEG,2) From DOSDIC
 Endif

Next
Commit
Filter [ADI]
Close Local File [TAM], [ADI], [AXX]

# Delete of record ADI/ADV
Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI]
Local File =[F:ADS]DOSSIER+".ATABTAB"  [ADV]

Trbegin [ADI]
GOK=1
Delete [ADI] Where NUMTAB="3"
If fstat
 Call ERREUR("ATABDIV-3",3) From DOSDIC
Else
 Call ECR_TRACE("ATABIDV-3 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Delete [ADV] Where NUMTAB="3"
If fstat
 Call ERREUR("ATABTAB-3",3) From DOSDIC
Else
 Call ECR_TRACE("ATABTAB-3 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Commit

Close Local File [ADI], [ADV]

Return

##--------------------------------------------------------------------------------------------------------------------
$MAJTED
If filinfo(filpath("FIL","TABCODEDT","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TABCODEDT"  [TED]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]
Filter [ADI] Where NUMTAB=304

Trbegin [TED]
For [ADI]

 [F:TED]CODEDT = [F:ADI]CODE
 [F:TED]LEG    = [F:ADI]LEG
 If [F:TED]LEG="" & WVERSION<30  : [F:TED]LEG=LEGREF : Endif
 [F:TED]TRT    = [F:ADI]A1

 Update [AXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="304" & IDENT2=[F:ADI]CODE
&              With CODFIC="TABCODEDT", ZONE="DESAXX", IDENT1=[F:TED]CODEDT, IDENT2=[F:TED]LEG
 If fstat
  Call ERREUR("ATEXTRA-TABCODEDT-DESAXX"-[F:TED]CODEDT-[F:TED]LEG,2) From DOSDIC
 Endif

 Update [AXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="304" & IDENT2=[F:ADI]CODE
&              With CODFIC="TABCODEDT", ZONE="SHOAXX", IDENT1=[F:TED]CODEDT, IDENT2=[F:TED]LEG
 If fstat
  Call ERREUR("ATEXTRA-TABCODEDT-SHOAXX"-[F:TED]CODEDT-[F:TED]LEG,2) From DOSDIC
 Endif

 [F:TED]UPDUSR = ""
 [F:TED]UPDDAT = [0/0/0]
 [F:TED]CREUSR = GUSER
 [F:TED]CREDAT = date$

 Write [F:TED]
 If fstat
  Call ERREUR("TABCODEDT"-[F:TED]CODEDT-[F:TED]LEG,2) From DOSDIC
 Endif

Next
Commit
Close Local File [TED], [ADI], [AXX]

# Delete of record ADI/ADV
Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI]
Local File =[F:ADS]DOSSIER+".ATABTAB"  [ADV]

Trbegin [ADI]
GOK=1
Delete [ADI] Where NUMTAB="304"
If fstat
 Call ERREUR("ATABDIV-304",3) From DOSDIC
Else
 Call ECR_TRACE("ATABIDV-304 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Delete [ADV] Where NUMTAB="304"
If fstat
 Call ERREUR("ATABTAB-304",3) From DOSDIC
Else
 Call ECR_TRACE("ATABTAB-304 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Commit

Close Local File [ADI], [ADV]

Return


##--------------------------------------------------------------------------------------------------------------------
$CACCEDEF
Local File =[F:ADS]DOSSIER+".CACCEDEF"  [CDE]


Local Integer NO_IDENT
Local Integer AXE, I, IND, VU

Call ECR_TIME(mess(81,125,1)-": CACCEDEF") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CDE
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CDE]COD='"+ACLE1+"' & [F:CDE]CPY>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:CDE]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CDE]
GOK = 1

For [CDE]CDE0 Where evalue(CRITERE)
 For AXE=1 To 20
  For IND=0 To dim([F:CDE]CCE1)-1
   If evalue("[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")") = 22
    Assign "[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")" With 24
   Endif
  Next
 Next

 Rewrite [CDE]
 If fstat
  GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,1) From DOSDIC
 Endif
 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:CDE]COD
  ACLE2 = [F:CDE]CPY
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CDE
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CDE]
Return

#-- Accounting code lines V7
$GACCCODLIG
Local Integer NBRLIG
Local File =[F:ADS]DOSSIER+".GACCCODLIG"  [CCL]

Call ECR_TIME(mess(81,125,1)-": GACCCODLIG") From DOSSUB : # maj table

Trbegin [CCL]

Read [CCL]CCL0 = 1;70
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
 [F:CCL]NUMLIG = 70
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 176
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-70",1) From DOSDIC
 Endif
Endif

Read [CCL]CCL0 = 1;71
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
