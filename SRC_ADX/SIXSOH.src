#<AdxTL>@(#)11.0.0.0 $Revision$
 
#########################################################################
#  SIXSOH: pour traitements de bascule Integrale --> X3                 #
#########################################################################
# Subprog SI_SOH                                                        #
#     Création des commandes clients                                    #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
#SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXSOH
End


#########################################################################
Subprog EXEC
Local Integer WOUV_TRACE, WERR
Local Char    WMSG

If GTRACE = ""
    Call OUVRE_TRACE("SI_SOH : "+SI_MES(53)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#----- Vérification cohérence nbre d'axes définis dans "Intégrale" et code activité ANA -----#
Call VARGLOBANA(WMSG,WERR) From SIXGAS
If WERR
    Call ECR_TRACE(WMSG,1) From GESECRAN 
Else
    #---- Création enregistrements SORDER / SORDERP / SORDERQ ------#
    Call ECR_TIME("SI_SOH : "+mess(213,124,1)+" SORDER / SORDERP / SORDERQ") From DOSSUB
    Call SI_SORDER
Endif

$FIN_SOH
Onerrgo 
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GIMPORT=0    # Bug 47776
Resume

#########################################################################

Subprog SI_SORDER

#--- pour appel GENSOH

Local Integer LCOD   : LCOD=1                : # 1=Création complète / 2=Garnissage uniquement des classes [M]
Local Char    LMAJ   : LMAJ="C"              : # C=Création 
Local Integer LTEST  : LTEST=1               : # 1=Pas ecriture du fichier trace / 2=Ecriture de la trace
Local Char    LTRT   : LTRT="SIXSOH"         : # Traitement contenant les actions appelees par TRTVENCDEG
Local Char    LORINUM                        : # No du document origine ( utilisation facultative )
Local Char    LNEWNUM                        : # No de commande creee            
Local Integer LERR   : LERR=0                : # Code retour erreur 
Local Integer LNBSOH, LNBERR : LNBSOH=0 : LNBERR=0

If SI_SIMU=2 LTEST+=2 Endif

#--- Ouverture standard documents ventes  
Gosub OPEN_STD From SIXSQH

#--- Ouverture des tables Integrale
Gosub OPEN_INT From SIXSQH

#--- Ouverture des tables Integrale spécifiques aux commandes
If !clalev([F:XMSL]) : Local File =SI_DOSSIER+".XIMVTSTVAL" [XMSL] : Endif  : # Mouvement Série Lot valeur

#--- Ouverture specifique des tables et masques de l'objet SQH
If !clalev([F:SOH])  : Local File =SI_DOSSIER+".SORDER"     [SOH] : Endif
If !clalev([F:SOP])  : Local File =SI_DOSSIER+".SORDERP"    [SOP] : Endif
If !clalev([F:SOQ])  : Local File =SI_DOSSIER+".SORDERQ"    [SOQ] : Endif
If !clalev([F:TSO])  : Local File =SI_DOSSIER+".TABSOHTYP"  [TSO] : Endif
If !clalev([F:SQD])  : Local File =SI_DOSSIER+".SQUOTED"    [SQD] : Endif

If !clalev([M:STOK]) : Local Mask =SI_DOSSIER+".STOK"       [STOK] : Endif
If !clalev([M:ALP])  : Local Mask =SI_DOSSIER+".ALLPAR"     [ALP]  : Endif
If !clalev([M:ORDK]) : Local Mask =SI_DOSSIER+".ORDK"       [ORDK] : Endif

If !clalev([M:SOH0]) : Local Mask =SI_DOSSIER+".SOH0"       [SOH0] : Endif
If !clalev([M:SOH1]) : Local Mask =SI_DOSSIER+".SOH1"       [SOH1] : Endif
If !clalev([M:SOH2]) : Local Mask =SI_DOSSIER+".SOH2"       [SOH2] : Endif
If !clalev([M:SOH3]) : Local Mask =SI_DOSSIER+".SOH3"       [SOH3] : Endif
If !clalev([M:SOH4]) : Local Mask =SI_DOSSIER+".SOH4"       [SOH4] : Endif

GORDCAT=1  : # Catégorie de commande autorisée : 1=Normale
Global Integer G_LINTYP : G_LINTYP=1 : # Pour les articles gérés avec des nomenclatures, pour ne pas décliner la nomenclature
Global Integer GDISCRGNUM1, GDISCRGNUM2

SI_SUBPRG = "SI_SOH"
SI_TABLE = "XIEPV"

Local Char CRITERE (250), CRITDET(250)
CRITERE  = 'TYPPIE="CO"'               : # type de piece commande 
CRITERE += '& FLGREP<2'               : # pas encore migre dans X3
CRITERE += '& FLGMAJ<>"S"'             : # non supprime 
CRITERE += '& DATPIE>=[F:SPX]STRPER'   : # date >= date premier exercice

CRITDET='LIGSUP<>"S" & !find(NATART, "SD", "ST", "TD", "TP")'

Gosub SI_CRITSUP From SIXFONCTION    : # dans PE : variable SI_SUBPRG a tester car XIEPV commun (devis,cde,facture)

#SI_CRITERE='find(NUMORD,2054,2055,1798,1800,2105,2107,2128,1775)'
#SI_CRITERE='find(NUMORD,2105)'
#--- Boucle de creation du fichier de travail ( un enr. par no ordre avec la + grande lettre reliquat ) 
For [XVH0] Where evalue(CRITERE)
&              & evalue(SI_CRITERE)

   Gosub SINUM_AFF From SIXSQH : Call AFFBOITE(SINUM) From SUBSIM
   If GTRACE<>"" Call ECR_TRACE(mess(98,197,1)-SINUM,0) From GESECRAN Endif    

   # -- alimenter les classes [F] nécessaires à l'entete ainsi que le masque SIWRKEPV
   Gosub SIWRKEPV From SIXSQH

   # Bug 48749 : Ne pas prendre les lignes dont la qté = 0
#   Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & evalue(CRITDET) &
#& sum([F:XVLI]QTELIV, [F:XVLI]QTERLQ)<>0
   # Bug 48758 : On prend les lignes dont la qté = 0 uniquement pour les mettre dans la trace
   Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & evalue(CRITDET) 

   Call GENSOH (LCOD,LMAJ,LTEST,LTRT,LORINUM,LNEWNUM,LERR) From TRTVENCDEG
   If LERR=0 LNBSOH+=1 Else LNBERR+=1 Endif
Next

Call ECR_TIME("SIXSOH :"-SI_MES(118)-num$(LNBSOH)-SI_MES(172)-num$(LNBERR)) From DOSSUB

Kill G_LINTYP
Kill GDISCRGNUM1, GDISCRGNUM2

End


#########################################################################
#    Pour GENSOH composant calcul facture 
#    chargement masques SOH0 SOH1 SOH2 SOH3 SOH4 
#    Actions appelées dans le TRTVENCDEG
#########################################################################
$ACTION_GS

Case GWACTION_GS   
     When "READ_DETAIL"     Gosub READ_DETAIL
     When "MSK_ENTETE"      Gosub MSK_ENTETE
     When "MSK_DETAIL"      Gosub MSK_DETAIL
     When "AP_READ_DETAIL"  Gosub AP_READ_DETAIL
     When "RAZCRE"          Gosub RAZCRE
     When "INICRE"          Gosub INICRE
     When "ERREUR"          Gosub ERREUR
     When "CREATION"        Gosub CREATION
Endcase

Return

#------------------------------------------------------------------------ 
# RAZCRE specifique a reprise intégrale ( apres RAZCRE objet )  
#------------------------------------------------------------------------ 
$RAZCRE
[M]ALLTYP=1 : # On alloue toujours en global
Return

#------------------------------------------------------------------------ 
# Chargement des ecrans entete de commande 
#------------------------------------------------------------------------ 
$MSK_ENTETE
Local Integer WINDVAC
Local Char    WBPCPYR(GLONBPC)

Case IMPZON
     When "SOHTYP"     :  If [F:SPX]SOHTYP<>[M]SOHTYP & [SPX]SOHTYP<>""     :  #--- Masque SOH0
                              [M]SOHTYP=[F:SPX]SOHTYP
                          Endif
     When "SALFCY"     :  [M]SALFCY=[F:SPX]FCY    
     When "CUSORDREF"  :  [M]CUSORDREF=[F:XVH0]REFCMD
# Vu 14/03/08 : Mettre systématiquement REF_CMD
#                         [M]CUSORDREF=num$([F:XVH0]NUMORD)

     When "ORDDAT"     :  [M]ORDDAT=[F:XVH0]DATPIE
     When "BPCORD"     :  If [F:XVH0]CODCLT<>"" [M]BPCORD=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","") Endif
                          # Chargement champs affiches et invisibles sur appel champ saisissable obligatoire
                          If [F:XVH0]CODTRN<>0 
                              Local Integer WDRN
                              WDRN=val(func SIXFONCTION.SI_COR("XINUMTNCLT",num$([F:XVH0]CODTRN),"409",""))
                              # On ne garde le code tournée de la cde que s'il existe 
                              If WDRN<>0 [M]DRN=WDRN Endif
                          Endif
                          If [F:XVH0]NBREXL<>0 [M]COPNBR=[F:XVH0]NBREXL Endif : # V6
                        #--- Masque SOH1
     When "BPCINV"     :  If [F:XVH0]CLTFAC<>"" [M]BPCINV=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CLTFAC,"","") Endif
     When "BPCPYR"     :  Gosub CHARG_BPCPYR From SIXSQH : [M]BPCPYR=WBPCPYR : # Bug 47519 
     When "REP" 
          Case indice
               When 0  :  If [F:XVH0]CODREP<>"" 
                              [M]REP(0)=func SIXFONCTION.SI_COR("XIREP",[F:XVH0]CODREP,"","") 
                          Else
                              [M]REP(0)=""
                          Endif
          Endcase     
     When "VACBPR"     :  [M]VACBPR=func SIXFONCTION.SI_VACBPR("C",[F:XVH0]ASJTVA,[F:XVH0]ASJTPF,[F:XVH0]ASJTAXADD,[M:SIW0]CODPAY)
                          If [M]VACBPR="" : # Bug 48060 : Amélio trace
                            Call ECR_TRACE (SI_MES(276),1) From GESECRAN
                            Call ECR_TRACE (SI_MES(277)-":"-[F:XVH0]ASJTVA-SI_MES(278)-":"-[F:XVH0]ASJTPF-SI_MES(279)-":"-[F:XVH0]ASJTAXADD-SI_MES(280)-":"-[M:SIW0]CODPAY,1) From GESECRAN
                          Endif
     When "CUR"        :  If [F:XVH0]CODDVS=""   [M]CUR=[F:SPX]CUR
                            Else                 [M]CUR=func SIXFONCTION.SI_COR("XIDVS",[F:XVH0]CODDVS,"","") 
                          Endif 
     When "PRITYP"     :  If [F:XVH0]FACTTC="O"  [M]PRITYP=2 
                            Else                 [M]PRITYP=1 
                          Endif
                        #--- Masque SOH2
     When "STOFCY"     :  If [F:XVH0]CODDPO<>"" 
                            [M]STOFCY=func SIXFONCTION.SI_COR("XIDPO",[F:XVH0]CODDPO,"","") 
                          Endif
     When "MDL"        :  If [F:XVH0]MODEXD<>"" 
                              [M]MDL=func SIXFONCTION.SI_COR("XIMODEXD",[F:XVH0]MODEXD,"","") 
                          Else
                              [M]MDL=""
                          Endif
     When "BPTNUM"     :  If [F:XVH0]TSP<>"" 
                              # 48703 : Si le transporteur n'existe, on met le champs à blanc
                              [M]BPTNUM=func SIXFONCTION.SI_COR("XIFOU",[F:XVH0]TSP,"#BPCARRIER","") 
                          Else
                              [M]BPTNUM=""
                          Endif                                                          
                        #--- Masque SOH3
     When "PTE"        :  If [F:XVH0]MODRGL1<>""
                              Local Char WCLERGL1, WCLERGL2                                       : # Bug 79385
                              If len([F:XVH0]MODRGL1)>2                                         
                                 WCLERGL1=left$ ([F:XVH0]MODRGL1,2)                               : # Bug 79385
                                 WCLERGL2=right$([F:XVH0]MODRGL1,3)                               : # Bug 79385
                              Else 
                                 WCLERGL1=[F:XVH0]MODRGL1                                         : # Bug 79385
                              Endif 
                              [M]PTE=func SIXFONCTION.SI_COR2("XIMODRGL",WCLERGL1,WCLERGL2,"","") : # Bug 79385
                          Endif
     When "NBFAC"      :  [M]NBFAC=[M:SIW0]NBFAC
                          For I=0 To [M:SIW0]NBFAC-1 : [M]INVDTAAMT(I)=[M:SIW0]INVDTAAMT(I) : Next I

Endcase

Return

#------------------------------------------------------------------------ 
# Lecture des enregistrements details
# - le filter des lignes doit être actif
# - on ne fait que de la création de lignes
#------------------------------------------------------------------------ 
$READ_DETAIL
nolign=0 : LIG_DETAIL="C"     : # uniquement de la creation
Local Decimal CUMQTY

If LEC_DETAIL=0 
    Read [XVLI] First
Else
    Read [XVLI] Next
Endif
If    !fstat        : # lecture ok
   LEC_DETAIL=1 
   # Bug 48758 : Qté à 0 : Ligne non reprise
   If sum([F:XVLI]QTELIV, [F:XVLI]QTERLQ)=0 
       GBIDC3=SI_MES(273)-":"-SI_MES(274)
       GBIDC3-="<"-mess(3,40,1)-num$([F:XVLI]NUMLIG)-mess(18,7,1)-[F:XVLI]CODART-">"
       LEC_DETAIL=4
   Endif 
Elsif fstat=4       : # fin lecture
   LEC_DETAIL=2 
Elsif fstat         : # erreur   
   LEC_DETAIL=3   : GBIDC3="XILPV [XVLI]" 
Endif

Return

#------------------------------------------------------------------------ 
# Chargement d'une ligne dans l'ecran SOH4 de devis
#------------------------------------------------------------------------ 
$MSK_DETAIL
Local Char WSAU(GLONUOM)

Case IMPZON

     When "ITMREF"     :  If [F:XVLI]CODART<>"" 
                              [M]ITMREF(nolign-1) =func SIXFONCTION.SI_COR("XIART",[F:XVLI]CODART,"","")
                          Endif
# V6
                          If [F:XVLI]CODDPO<>""
                              [M]DSTOFCY(nolign-1)=func SIXFONCTION.SI_COR("XIDPO",[F:XVLI]CODDPO,"","")
                          Endif  
# V6
     When "ITMDES"     :  [M]ITMDES(nolign-1) =[F:XVLI]NOMART             
# V6
#     When "DSTOFCY"    :  If [F:XVLI]CODDPO<>""
#                              [M]DSTOFCY(nolign-1)=func SIXFONCTION.SI_COR("XIDPO",[F:XVLI]CODDPO,"","")
#                          Endif  
# V6
     When "SAU"        :  WSAU=[M]SAU(nolign-1)
                          If [F:XVLI]UNIVEN<>""
                              [M]SAU(nolign-1)=func SIXFONCTION.SI_COR("XIUNIFAC",[F:XVLI]UNIVEN,"","")
                          Endif
                          If WSAU<>[M]SAU(nolign-1) & [M]SAU(nolign-1)<>""
                              # Bug 47303 
                              # On vérifie si l'unité de la cde fait partie des unités définies dans l'article 
                              # Si ce n'est pas la cas, pour ne pas bloquer :
                              # On garde l'unité initialisée au départ (unité de vente définie ds l'article)
                              #----- Lecture de l'article et article-client si nécessaire -----#
                              If [F:ITM]ITMREF<>[M:SOH4]ITMREF(nolign-1)
                                  Read [ITM] ITM0=[M:SOH4]ITMREF(nolign-1)
                                  If fstat Raz [F:ITM] : Endif
                              Endif
                              If [F:ITU]ITMREF<>[M:SOH4]ITMREF(nolign-1) | [F:ITU]BPCNUM<>[M:SOH0]BPCORD
                                  Read [ITU] ITU0=[M:SOH4]ITMREF(nolign-1);[M:SOH0]BPCORD
                                  If fstat Raz [F:ITU] : Endif
                              Endif
                              #----- Contrôle que l'unité est présente dans l'article ou article-client -----#
                              If !find([M:SOH4]SAU(nolign-1),[F:ITM]STU,[F:ITM]SAU,[F:ITM]PCU,[F:ITU]SAU,[F:ITU]PCU1,[F:ITU]PCU2)
                                  #----- Si ce n'est pas le cas, on remplace par l'unité de vente -----#
                                  [M:SOH4]SAU(nolign-1)=WSAU
                              Endif
                              #-----
                          Endif
     When "QTY"        :  #[M]QTY(nolign-1)=[F:XVLI]QTECMD
                          #If [F:XVLI]QTERLQ<>0 
                          #    # Si la cde a généré une cde reliquat, la qtée cdée est initialisée avec la qté livrée
                          #    # Si la qté livrée est à 0, on solde la ligne de cde  
                          #    If [F:XVLI]QTELIV<>0 
                          #        [M]QTY(nolign-1)=[F:XVLI]QTELIV
                          #    Else 
                          #        [M]SOQSTA(nolign-1)=3 
                          #    Endif
                          #Endif             
                          # Vu 14/03/08 : Tjs initialiser avec la qtée livrée
                          [M]QTY(nolign-1)=[F:XVLI]QTELIV 
                          If [F:XVLI]QTERLQ<>0 
                              # Si la qté livrée est à 0, on solde la ligne de cde  
                              If [F:XVLI]QTELIV=0 [M]SOQSTA(nolign-1)=3 Endif
                          Endif             
                          Gosub RECH_VACITM From SIXSQH : # Bug 47592
                          Gosub TRAIT_VACITM From SIXSQH
     When "WALLQTY"    :  [M]WALLQTY(nolign-1)=[F:XVLI]QTELIV
     When "TDLQTY"     :  [M]TDLQTY(nolign-1)=[F:XVLI]QTELIV             
     When "GROPRI"     :  [M]GROPRI(nolign-1)=[F:XVLI]PRXUNI 
                          Gosub CHARG_DISCRGNUM From SIXSQH 
                          Gosub RAZ_DISCRGVAL From SIXSQH
     When "DISCRGVAL1" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL2" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL3" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL4" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL5" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL6" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL7" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL8" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL9" :  Gosub CHARG_DISCRGVAL From SIXSQH             
     When "CPRPRI"     :  [M]CPRPRI(nolign-1)=[F:XVLI]PRXVALFRS : # Bug 48023
                          Gosub TRAIT_NETPRI From SIXSQH  
     When "REP1"       :  If [F:XVLI]CODREP<>""
                               [M]REP1(nolign-1)=func SIXFONCTION.SI_COR("XIREP",[F:XVLI]CODREP,"","")
                          Else
                               [M]REP1(nolign-1)=""
                          Endif
     When "REPRAT1"    :  If [M]REP1(nolign-1)<>"" [M]REPRAT1(nolign-1)=[F:XVLI]TAUCOM Endif
     When "DDEMDLVDAT" :  If [F:XVLI]DATLIV<>[0/0/0] [M]DDEMDLVDAT(nolign-1)=[F:XVLI]DATLIV Endif
     When "CCE1"       :  Call SI_INICCE("XILPVANA",[F:XVLI]NUMORD,[F:XVLI]LETRLQ,[F:XVLI]NUMLIG,
&                             "[M:SOH4]CCE",nolign-1)  From SIXFONCTION
Endcase



# pour avoir le no. de la ligne et la reference article dans l'erreur
#GCLE  ="\"+[F:XVH0]TYPPIE+[F:XVH0]CODSTT+[F:XVH0]NUMSER+[F:XVH0]NUMPIE

GCLE=mess(3,40,1)-num$([F:XVLI]NUMLIG)-mess(18,7,1)-[M]ITMREF(nolign-1)

Return

#------------------------------------------------------------------------ 
# AP_READ_DETAIL : Après chargement de la ligne dans l'écran   
#                  (Après SAI_NBLIG)
#------------------------------------------------------------------------ 
$AP_READ_DETAIL

# Forcer LINTYP à 1 pour les composés 
# G_LINTYP a évité la déclinaison de la nomenclature mais LINTYP reste positionné
[M]LINTYP(nolign-1)=1

# 58798 : Vérification des codes taxes
# Message alerte si Code TPF dans intégrale mais pas de code taxe2 dans X3 et inversement
#                si Code taxe additionnelle dans intégrale mais pas de code taxe3 dans X3 et inversement
If  ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"     & [M:SOH4]VAT2(nolign-1)="") |
&  (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O")   & [M:SOH4]VAT2(nolign-1)<>"") |
&   ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SOH4]VAT3(nolign-1)="") |
&  (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O")  & [M:SOH4]VAT3(nolign-1)<>"") 
    Call ECR_TRACE (SI_MES(287)-num$(nolign)-":"-[M:SOH4]ITMREF(nolign-1)-":"-SI_MES(285),-1) From GESECRAN
    If ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"    & [M:SOH4]VAT2(nolign-1)="") |
&      (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O") & [M:SOH4]VAT2(nolign-1)<>"") 
        Call ECR_TRACE (SI_MES(39)+SI_MES(278)+":"+[F:XVH0]ASJTPF-SI_MES(283)+":"+num$([F:XVLI]CODTPF),-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SOH4]VACITM2(nolign-1)-SI_MES(283)+":"+[M:SOH4]VAT2(nolign-1),-1) From GESECRAN
    Endif
    If ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SOH4]VAT3(nolign-1)="") |
&      (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O") & [M:SOH4]VAT3(nolign-1)<>"") 
        Call ECR_TRACE (SI_MES(39)+SI_MES(279)+":"+[F:XVH0]ASJTAXADD-[F:XART]TAXADD,-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SOH4]VACITM3(nolign-1)-SI_MES(283)+":"+[M:SOH4]VAT3(nolign-1),-1) From GESECRAN
    Endif
Endif

Return

#------------------------------------------------------------------------ 
# INICRE specifique a reprise intégrale ( apres INICRE objet )  
#------------------------------------------------------------------------ 
$INICRE

#-- Stockage des donnees adresse
Gosub SIADD From SIXSQH
#-- Stockage du no document Integrale
Gosub SINUM From SIXSQH
#-- Ecriture du texte entete et des textes lignes  
Gosub SIWRKTXT From SIXSQH
#-- Stockage des sections analytiques des éléments de facturation
Gosub SIWRKSFICCE From SIXSQH : # V6
Return

#------------------------------------------------------------------------ 
# Erreur lors du garnissage des ecrans facture 
#------------------------------------------------------------------------ 
$ERREUR
If LERR=4 
   GBIDC3=GBIDC3-mess(532,197,1)-[F:SGD]VCRNUM+"   "+mess(18,7,1)-[M:SOH4]ITMREF(nolign-1) 
Endif
Return

#------------------------------------------------------------------------ 
# Tables mises a jour lors de la creation de la commande 
# ( on est dans une transaction : en cas d'erreur positionner GOK )
#------------------------------------------------------------------------ 
$CREATION

#----- Suppression des acomptes générés en standard -----#
Call ACOMPTES(5,2,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&            [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&            1,OK) From TRTTPT
If GOK < 1 : Return : Endif
#----- Création    des acomptes à partir de ceux de l'intégrale -----#
If [M:SIW0]NBEAV<>0 
    Call SIXACOMPTES(5,1,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&            [F:SOH]CUR,[F:SOH]CHGTYP,[F:SOH]BPCINV,[F:SOH]BPCPYR,[F:SOH]BPAPYR,
&            1,OK) From SIXSOH
    If GOK < 1 : Return : Endif
    # Bug 48060 : Amélio. trace
    If [M:SIW0]NBEAV>dim([M:SIW0]NUMAPT)-1 Call ECR_TRACE(SI_MES(275),0) From GESECRAN Endif
Endif

#----- Mise à jour indicateur "traité" sur entête commande "Intégrale" -----#
# Bug 47682 : Maj du flag ssi on est pas en simulation
If find (GWLTEST,1,2)
#  Update [XVH0] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ With FLGREP=2
  Local Integer WNUMORD : WNUMORD=[F:XVH0]NUMORD
  Local Char    WLETRLQ : WLETRLQ=[F:XVH0]LETRLQ
  Update [XVH0] Where NUMORD=WNUMORD & LETRLQ=WLETRLQ With FLGREP=2
Endif
#-----
# 58798 : Vérification du montant TTC
# Message alerte montant TTC dans intégrale différent montant TTC dans X3
If [M:SOH4]ORDINVATI<>[F:XVH0]MNTTOTTTC
    Call ECR_TRACE (SI_MES(129),-1) From GESECRAN
Endif

Return

#########################################################################
#########################################################################
#        RECUPERATION DES ACOMPTES                                      #
#########################################################################
# 1er) Stocker dans [M]SIWRKEPV les données acomptes :                  #
#                                                                       #
# Cas n.1 : Pas de génération des acomptes mais le mnt acpte>0          #
#           On remplit à la main [M]SIWRKEPV                            #
# Cas n.2 : Génération des acomptes                                     #
#           Aucune liaison comptable : On remplit [M]SIWRKEPV avec EAV  #
#           Liaison comptable        : On ne fait rien                  #
#                                                                       #
# 2ème) Crééer les acomptes :                                           #
#                                                                       #
# Ne pas faire la création standard                                     #
# Faire la création à la main à partir de [M]SIWRKEPV                   #
#                                                                       #
#########################################################################

#########################################################################
# Stockage dans [M] SIWRKEPV des données acomptes                       #
#########################################################################
$SIW0_EAV
Local Char WCODTVA(GLONVAT)

If !clalev([F:XVEA]) : Local File =SI_DOSSIER+".XIEAV"      [XVEA] : Endif  : # Entête acompte
If !clalev([F:XVLA]) : Local File =SI_DOSSIER+".XILAV"      [XVLA] : Endif  : # Ligne acompte
If !clalev([F:XVAR]) : Local File =SI_DOSSIER+".XILAVMDRGL" [XVAR] : Endif  : # Ligne acompte mode reglement

If [F:XVH0]GENAPT="O"
    # Il y a eu génération d'acompte       : On récupère les acomptes s'il n'y a pas eu liaison comptable
    Filter [XVEA] Where NUMORD=[F:XVH0]NUMORD & LETRLQNUMORD=[F:XVH0]LETRLQ & FLGMAJ<>"C"
    For [XVEA]
        # Bug 47215 : Ajout ctrl nb lignes acompte défini dans SIWRKEPV
        If [M:SIW0]NBEAV>dim([M:SIW0]NUMAPT)-1 Break Endif
        # Lecture de l'entête de l'acompte
        [M:SIW0]NUMAPT ([M:SIW0]NBEAV)=[F:XVEA]NUMAPT       : # Numéro acompte
        [M:SIW0]NUMPIEAPT ([M:SIW0]NBEAV)=[F:XVEA]NUMPIE    : # Numéro de pièce
        [M:SIW0]MODRGL ([M:SIW0]NBEAV)=[F:XVEA]MODRGL1      : # Mode de règlement
        [M:SIW0]MNTECH ([M:SIW0]NBEAV)=[F:XVEA]MNTECH1      : # Montant de l'échéance
        [M:SIW0]DATECH ([M:SIW0]NBEAV)=[F:XVEA]DATECH1      : # Date de l'échéance
        WCODTVA=func SIXFONCTION.SI_COR2("XITVAVEN",num$([F:XVEA]CODTVA),[F:XCLT]CODPAY,"#","") 
        [M:SIW0]CODTVA ([M:SIW0]NBEAV)=WCODTVA              : # Code tva

        [M:SIW0]NBEAV+=1
        # Pour chaque acompte, lecture des lignes de règlements si le règlement a plusieurs échéances 
        Filter [XVAR] Where NUMORD=[F:XVEA]NUMORD & LETRLQ=[F:XVEA]LETRLQNUMORD & NUMAPT=[F:XVEA]NUMAPT & TYPLIG="O"
        For [XVAR]
            # Bug 47215 : Ajout ctrl nb lignes acompte défini dans SIWRKEPV
            If [M:SIW0]NBEAV>dim([M:SIW0]NUMAPT)-1 Break Endif
            [M:SIW0]NUMAPT ([M:SIW0]NBEAV)=[F:XVEA]NUMAPT       : # Numéro acompte
            [M:SIW0]NUMPIEAPT ([M:SIW0]NBEAV)=[F:XVEA]NUMPIE    : # Numéro de pièce
            [M:SIW0]MODRGL ([M:SIW0]NBEAV)=[F:XVAR]MODRGL       : # Mode de règlement
            [M:SIW0]MNTECH ([M:SIW0]NBEAV)=[F:XVAR]MNTECH       : # Montant de l'échéance
            [M:SIW0]DATECH ([M:SIW0]NBEAV)=[F:XVAR]DATECH       : # Date de l'échéance
            [M:SIW0]CODTVA ([M:SIW0]NBEAV)=WCODTVA              : # Code tva
            [M:SIW0]NBEAV+=1
        Next
        Filter [XVAR]
    Next
    Filter [XVEA]
Elsif [F:XVH0]MNTAPT<>0
    # Il n'y a pas eu génération d'acompte : On génère une ligne ds SIWRKEPV si le mnt acpte <> 0
    [M:SIW0]NUMAPT ([M:SIW0]NBEAV)= 1               : # Numéro acompte
    [M:SIW0]MNTECH ([M:SIW0]NBEAV)= [F:XVH0]MNTAPT  : # Montant de l'échéance
    [M:SIW0]DATECH ([M:SIW0]NBEAV)= [F:XVH0]DATECH1 : # Date de l'échéance   # Non renseignée !!
    If [M:SIW0]DATECH([M:SIW0]NBEAV)="000000" [M:SIW0]DATECH ([M:SIW0]NBEAV)=[F:XVH0]DATPIE Endif
    [M:SIW0]NBEAV+=1
Endif
Return

############################################################################
#                                                                          #
# Création des acomptes à partir de [M] SIWRKEPV                           #
#                                                                          #
############################################################################
############################################################################
# Subprog SIXACOMPTES (MODULE,TRAIT,NUMCDE,NBLIN,CODECHE,DEPECHE,MONTANT,  #
#                   CURECH,TYPCOURS,TFACT,TPAYE,COLPU,COLVAT,NOLIN,OK      #
#--------------------------------------------------------------------------#
# DEFINI les acomptes et retenues garantie en saisie cde achats ventes     #
#  MODULE    : Achat/Vente                                                 #
#  TRAIT     : Code traitement(1,2,3)creation annulation controle          #
#  NUMCDE    : Numéro de commande                                          #
#  NBLIN     : Nbre de ligne CDE                                           #
#  CODECHE   : code réglement                                              #
#  DEPECHE   : date origine des calculs d'échéances                        #
#  MONTHT    : HTC à répartir                                              #
#  MONTTTC   : TTC à répartir                                              #
#  CURECH    : code devise                                                 #
#  TYPCOURS  : Type de cours                                               #
#  TFACT     : Tiers Facturé/Facturant                                     #
#  TPAYE     : Tiers Payé/Payeur                                           #
#  ADRPAY    ; Adresse Tiers Payé/Payeur                                   #
#  NOLIN     : Numéro de la ligne de départ(sert pour cdes par articles)   #
#  OK        : Code retour en CONT_ACOMPTES                                #
#   Les noms de colonnes sous la forme [M:mmm]XXXX                         #
############################################################################
Subprog SIXACOMPTES (MODULE,TRAIT,NUMCDE,NBLIN,CODECHE,DEPECHE,MONTHT,MONTTTC,CURECH,TYPCOURS,TFACT,TPAYE,ADRPAY,NOLIN,OK)
Value    Integer MODULE    
Value    Integer TRAIT
Value    Char    NUMCDE    
Value    Integer NBLIN     
Value    Char    CODECHE   
Value    Date    DEPECHE   
Value    Decimal MONTHT  
Value    Decimal MONTTTC  
Value    Char    CURECH  
Value    Integer TYPCOURS
Value    Char    TFACT
Value    Char    TPAYE
Value    Char    ADRPAY
Value    Integer NOLIN

Variable Integer OK

## Historisation des échéances supprimées
Local Char CRITSUPPR (250)

#Local Char    TABTAXE(3) (0..NBLIN)
#Local Decimal TABMNT   (0..NBLIN)
Local Integer WRET, WDUDLIG, WLIG, STAT, WACCNUM
Local Char    CODCPT(GLONCAC)

#Ouverture des fichiers nécessaires
If clalev([F:TPT])<=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:TCU])<=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:CAC])<=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:GAC])<=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:ADI])<=0 : Local File ATABDIV    [ADI] : Endif

If TRAIT<>1        End Endif    : # Uniquement création d'acomptes

Local Integer WI, WJ, J
Local Char    WPTE, WMODECHE

#----- Chargement du code comptable par société -----#
Case MODULE
     When 5 : Read [F:BPC]BPC0 = TFACT
              Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",[L]CODCPT) From CPTSUB 
              Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(1))             From CONTOBJ 
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ 
     When 6 : Read [F:BPS]BPS0 = TFACT
              Call INIT_COMPTE([F:BPS]BPSNUM,GSOCIETE,"F",[L]CODCPT) From CPTSUB 
              Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ 
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ 
     When Default
Endcase

Call LECDEV(CURECH) From TRTDIV
NBECH=[M:SIW0]NBEAV-1

Local Char     MODECHE(15) (0..NBECH)

Local Integer  TYPECHE (0..NBECH)
Local Decimal  MNTECHE (0..NBECH)
Local Date     DATECHE (0..NBECH)
Local Integer  RELEVE  (0..NBECH)
Local Char     TABTAXE(GLONVAT)(0..NBECH+1)
Local Decimal  TABMNT  (0..NBECH+1)
Local Shortint NECHE : NECHE=0

For WI=0 To [M:SIW0]NBEAV-1
    If [M:SIW0]MODRGL (WI)<>""
        Local Char WCLERGL1, WCLERGL2                                     : # Bug 79385
        If len([M:SIW0]MODRGL (WI))>2       
            WCLERGL1=left$([M:SIW0]MODRGL (WI),2)                         : # Bug 79385  
            WCLERGL2=right$([M:SIW0]MODRGL (WI),3)                        : # Bug 79385
        Else 
            WCLERGL1=[M:SIW0]MODRGL (WI)                                  : # Bug 79385
        Endif 
        WPTE=func SIXFONCTION.SI_COR2("XIMODRGL",WCLERGL1,WCLERGL2,"","") : # Bug 79385      
    Else
        # Aucun mode de règlement sur la ligne d'acompte : On prend la condition de paiement de l'entête commande
        WPTE=CODECHE
    Endif    
    # Init mode de règlement avec mode de règlement de la 1ère ligne de type acompte
    Filter [TPT] Where PTE=WPTE & PAMTYP=2
    Read [TPT]TPT0 First 
    If !fstat WMODECHE = [F:TPT]PAM
    Else
        # Aucune ligne de type acompte : Init mode de règlement avec mode de règlement de la 1ère ligne 
        Filter [TPT] Where PTE=CODECHE 
        Read [TPT]TPT0 First 
        If !fstat WMODECHE = [F:TPT]PAM Endif
    Endif 
    Filter [TPT]

    MODECHE(NECHE) = WMODECHE
    TYPECHE(NECHE) = 2
    MNTECHE(NECHE) = [M:SIW0]MNTECH (WI)    
    DATECHE(NECHE) = [M:SIW0]DATECH (WI)
    RELEVE(NECHE)  = 1    : # Inutilisé à la création de l'acompte
    
    If [M:SIW0]CODTVA(WI)<>"" & !find([M:SIW0]CODTVA(WI), TABTAXE(0..NBECH-1))
        TABTAXE (WJ) = [M:SIW0]CODTVA (WI)
        TABMNT  (WJ)+= [M:SIW0]MNTECH (WI) : WJ+=1 : # V6 
    Endif

    NECHE+=1
Next

J=WJ
Gosub CREA_ACOMPTE From TRTTPT

End

############################################################################




