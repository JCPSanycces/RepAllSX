#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTISTO08 - Moulinette pour agréger les lignes de stocks - Module STOCK #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTISTO08 : Stock lines aggregation") From LECFIC
  Call MAJ_UTISTO08(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO08(DOSSIER)
Value Char    DOSSIER
Local Integer CPT

Call ECR_TRACE("UTISTO08: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:STO]) =0  Local File =DOSSIER+".STOCK"   [STO]  : Endif
If clalev([F:STO1])=0  Local File =DOSSIER+".STOCK"   [STO1] : Endif
If clalev([F:STA]) =0  Local File =DOSSIER+".STOALL"  [STA]  : Endif
If clalev([F:STA1])=0  Local File =DOSSIER+".STOALL"  [STA1] : Endif
If clalev([F:SWW]) =0  Local File =DOSSIER+".STOWIPW" [SWW]  : Endif
If clalev([F:SWW1])=0  Local File =DOSSIER+".STOWIPW" [SWW1] : Endif

Raz CPT
Call DEBTRANS From GLOCK

Trbegin [STO]

WSIMU=0
#WSIMU=1

For [STO1]STO0 Where SERNUM="" & QTYSTU>0
   # Positionnement sur une ligne de stock précédente identique
   Gosub CLE_STO
   If [F:STO]STOCOU>0
      Readlock [STO] Curr
      [F:STO]QTYPCU    += [F:STO1]QTYPCU
      [F:STO]QTYSTU    += [F:STO1]QTYSTU
      [F:STO]QTYSTUACT += [F:STO1]QTYSTUACT
      [F:STO]CUMALLQTA += [F:STO1]CUMALLQTA
      [F:STO]CUMALLQTY += [F:STO1]CUMALLQTY
      [F:STO]CUMWIPQTA += [F:STO1]CUMWIPQTA
      [F:STO]CUMWIPQTY += [F:STO1]CUMWIPQTY
      If WSIMU=0
         Rewrite [STO]
      Endif
      CPT += 1
      Call ECR_TRACE(num$([F:STO1]STOCOU)-"is deleted and added to"-num$([F:STO]STOCOU),0) From GESECRAN
      For [STA]STA0 Where STOFCY=[F:STO1]STOFCY & ITMREF=[F:STO1]ITMREF & STOCOU=[F:STO1]STOCOU
         [F:STA]STOCOU = [F:STO]STOCOU
         # Récupération prochain no séquence
         Filter [STA1] Where STOFCY=[F:STA]STOFCY & ITMREF=[F:STA]ITMREF & STOCOU=[F:STA]STOCOU      
&                      Order By Key STA0
         Read [STA1] First
         If fstat=0
            [F:STA]SEQ =[F:STA1]SEQ-1
         Else
            [F:STA]SEQ = 99999999
         Endif                 
         Filter [STA1]
         [F:STA1] = [F:STA]
         If WSIMU=0
            Write [STA1]
            Delete [STA] Curr
         Endif
      Next

      For [SWW]SWW0 Where STOCOU=[F:STO1]STOCOU
         [F:SWW]STOCOU = [F:STO]STOCOU
         # Récupération prochain no séquence
         Filter [SWW1] Where STOCOU=[F:SWW]STOCOU & PRONUM=[F:SWW]PRONUM
         Read [SWW1] Last
         If fstat=0
            [F:SWW]SEQ = [F:SWW1]SEQ+1
         Else
            [F:SWW]SEQ = 1
         Endif
         Filter [SWW1]         
         [F:SWW1] = [F:SWW]
         If WSIMU=0
            Write [SWW1]
            Delete [SWW] Curr
         Endif
      Next
      If WSIMU=0
         Delete [STO1] Curr
      Endif
   Endif
Next

Commit

Close Local File [STO]
Close Local File [STO1]
Close Local File [STA]
Close Local File [STA1]
Close Local File [SWW]
Close Local File [SWW1]

Call ECR_TRACE("UTISTO08 : "+num$(CPT)+" records processed",0) From GESECRAN

End

########################################################################
# Recherche de la 1ère ligne de stock respectant les caractéristiques  # 
# de [F:STO1] et dont STOCOU est inférieur à celui de [F:STO1]         #
########################################################################
$CLE_STO
Filter [STO] Where ITMREF   =[F:STO1]ITMREF
&                & STOFCY   =[F:STO1]STOFCY
&                & LOT      =[F:STO1]LOT
&                & LOC      =[F:STO1]LOC
&                & STOCOU   <[F:STO1]STOCOU
&                & SLO      =[F:STO1]SLO
&                & PALNUM   =[F:STO1]PALNUM
&                & CTRNUM   =[F:STO1]CTRNUM
&                & STA      =[F:STO1]STA
&                & PCU      =[F:STO1]PCU
&                & PCUSTUCOE=[F:STO1]PCUSTUCOE
&                & SERNUM   =[F:STO1]SERNUM
&                & QLYCTLDEM=[F:STO1]QLYCTLDEM
&                & OWNER    =[F:STO1]OWNER
Read [STO]STO3 First
If fstat Raz [F:STO] Endif
Filter [STO]
Return

