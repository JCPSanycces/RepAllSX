## Etiquette Ecrans
######################################################################################

########################################





Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR<1900
 GMESSAGE = mess(106,10709,1) : # Année incorrecte
 mkstat = 2 : End
Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
#ADNGO - X3PEOP-1243 - 2016-10-19 - START

# FQ76178 US1931 2006 - SEGAY 18/09/13
Local Char WCPA(GLONTPS),WCPE(GLONTPS)
Local Integer WOK
Local Char    FCYF(GLONCPY)(0..)
Local Integer IFCYF
If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
# END FQ76178
If clalev([F:TIM])=0 : Local File TIMCOD    [TIM] : Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
#JASMI - 2016-10-31 - START
#Call LECTURE("HRTIM",VALEUR,"") From CONTOBJ
  #Read [F:TIM]TIM0 = VALEUR
#JASMI
#  Filter [F:TIM] Where COD=VALEUR &  GCURLEG = [F:TIM]LEG
  Filter [F:TIM] Where COD=VALEUR &  LEG=GCURLEG
#JASMI
  Read [F:TIM] First
  Filter [F:TIM]
  If fstat
    #Filter [F:TIM] Where COD=VALEUR & LEG = GCURLEG | COD = VALEUR & LEG = ""
    If [F:TIM]LEG<>""
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:TIM]LEG
      mkstat = 2 : End
    Endif
   Endif

#JASMI - 2016-10-31 - END
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
If [F:TIM]CATTIM<>3
 GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
 mkstat = 2 : End
Endif
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 Call CONTEXE([F:TIM]ACS) From CPTSUB
 If mkstat : End : Endif
Endif

#If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
#  Local Integer RET
##  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M]REFNUM,[M]CTRNUM,RET) From DIVPAYE
#  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,"","",RET) From DIVPAYE
#  If RET>0 Then
##    GMESSAGE= VALEUR-":"-mess(320,199,1) : # Nature d'événement incompatible avec ce salarié
#    GMESSAGE= VALEUR-":"-mess(105,709,1) : # Type d'événement incorrect
#    mkstat=2 : End
#  Endif
#Endif
# END FQ88082
# FQ76178 US1931 2006 - SEGAY 18/09/13
Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
# FQ76178 US1931 - SEGAY 18/09/13 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
[L]WOK = 1
Call VERIF_TYPCP([M]CPY,[L]WCPA,[L]WCPE,VALEUR,[L]WOK) From CNSCNGSTD
If ![L]WOK
    Filter [F:FGR] Where CPY=[M]CPY
    IFCYF=0
    For [F:FGR]
      If !find([F:FGR]FCY,FCYF(0..IFCYF)) Then
        FCYF(IFCYF)=[F:FGR]FCY
        IFCYF+=1
        Call VERIF_TYPCP([F:FGR]FCY,[L]WCPA,[L]WCPE,VALEUR,[L]WOK) From CNSCNGSTD
        If [L]WOK : Break : Endif
      Endif
    Next
    Filter [F:FGR]
    If ![L]WOK
       GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
       mkstat = 2 : End
    Endif
Endif
# END FQ76178

#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog C_CUM(VALEUR)
Variable Char    VALEUR()
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
#65872
If !GPAYE & VALEUR="" : End : Endif
#57377

If clalev([F:CUM])=0 : Local File CUMUL    [CUM] : Endif
Read [F:CUM]CUM0=GCURLEG;VALEUR
 If fstat
    #Infbox num$([F:CUM]LEG)
    GMESSAGE=VALEUR-":"-mess(223,10709,1)-":"-GCURLEG
   mkstat=2 : End
  Else  If !fstat
        If [F:CUM]CUMPER<>1
            GMESSAGE=mess(193,10709,1)

            mkstat=2:End
        Endif
    Endif
Endif
End
#Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR<[M]STRPER
 GMESSAGE = mess(47,10709,1) #Date incorrecte
 mkstat=2 : End
Endif

#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog AS_DEBDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR=[0/0/0] : VALEUR=[M]STRDAT : Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
#If dim([M:CNG0]DEBDAT)>0    : Chgfmt [M:CNG0]DEBDAT     With "-D:"+GFMDAT4  : Endif
End

Subprog C_DEBDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR<>[0/0/0] & VALEUR>[M]STRDAT
 GMESSAGE =mess(47,10709,1) #Date incorrecte
 mkstat=2 : End
Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

End

Subprog AS_FINDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START

If !func DIVPAYE.IS_KZA(GCURLEG) | !func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) | !func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
If VALEUR=[0/0/0] : VALEUR=[M]ENDDAT : Endif
Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

End

Subprog C_FINDAT(VALEUR)
Variable Date    VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR<>[0/0/0] & VALEUR<[M]ENDDAT
 GMESSAGE = mess(47,10709,1) #Date incorrecte
 mkstat=2 : End
Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog C_LVESEL(VALEUR)
Variable Integer VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START

If VALEUR = 2
  Actzo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT
#JASMI - 2014/08/27 - Rollback changes - START
#  Actzo [M]LVESTR
#  Actzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  [M]LVETRM=0
#  Grizo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
Else
#JASMI - 2014/08/27 - Rollback changes - START
#  [M]LVESTR=gdat$(0,0,0)
#  [M]LVEEND=gdat$(0,0,0)
#  Grizo [M]LVESTR
#  Grizo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Actzo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
  Diszo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT

Endif
If VALEUR=3
  Actzo [M]LVEFOR
Else
  [M]LVEFOR=""
  Grizo [M]LVEFOR
Endif
#JASMI - 2014/08/27 - Rollback changes - START
#Affzo [M]LVESTR
#Affzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
Affzo [M]LVEFOR
Affzo [M]LVETRM
End

#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End

Subprog AM_LVETRM(VALEUR)
Variable Decimal VALEUR
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If VALEUR > 3
  GMESSAGE=mess(13,11662,1)
  mkstat=2
Endif
#ADNGO - X3PEOP-1243 - 2016-10-19 - END
End



