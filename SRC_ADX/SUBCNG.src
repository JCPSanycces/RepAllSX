Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Filter [CPY] Where CPY=VALEUR
Read [F:CPY]CPY0=VALEUR
#ADNGO - 2016-11-29 - X3PEOP-1243 - START
Filter [CPY]
#ADNGO - 2016-11-29 - X3PEOP-1243 - END
GCURLEG=[F:CPY]LEG
Gosub STYLE
End


