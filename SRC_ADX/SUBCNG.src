Subprog AM_CUMACQ0(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2016-11-29 - X3PEOP-1243 - START
If !clalev([F:CUM]) : Local File CUMUL [CUM] : Endif
Filter [CUM] Where CUMCOD=VALEUR & LEG=GCURLEG
Look [CUM] First
Filter [CUM]
If fstat
  If VALEUR <> ""
    mkstat=2
    GMESSAGE=VALEUR-mess(223,10709,1)-'"'+GCURLEG-'"':
  Endif
Endif
End

Subprog AM_CUMPRI0(VALEUR)
Variable Char    VALEUR()
If !clalev([F:CUM]) : Local File CUMUL [CUM] : Endif
Filter [CUM] Where CUMCOD=VALEUR & LEG=GCURLEG
Look [CUM] First
Filter [CUM]
If fstat
   If VALEUR <> ""
    mkstat=2
    GMESSAGE=VALEUR-mess(223,10709,1)-'"'+GCURLEG-'"':
  Endif
Endif
End

