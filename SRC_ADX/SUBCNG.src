#ADNGO - X3PEOP-1243 - 2016-10-19 - START
Raz GPILOBJ
Call OBJET("CNG",GBIDC1,"") From GOBJET
End
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

#ADNGO - X3PEOP-1243 - 2016-10-19 - START
$ACTION

Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"      :  Gosub OUVRE
 When "LIENS"      :  Gosub LIENS
 When "STYLE"      :  Gosub STYLE
 When "INIMOD"     :  Gosub INIMOD
 When "INICRE"     :  Gosub INICRE
 When "SETBOUT"    :  Gosub SETBOUT
 When "FILTRE"     :  Gosub FILTRE # FQ88082 - SEGAY 23/04/13 test ACS de TIM
 When "RAZCRE"     :  Gosub RAZCRE
 When "FILGAUCHE"  :  Gosub FILGAUCHE
 When "MODIF"      : Gosub MODIF #ADNGO - 2017-06-05 - X3-33759
 When "CREATION"   : Gosub CREATION #ADNGO - 2017-06-05 - X3-33759
Endcase


Return
#SAVAN 2017/04/06
$AVANT_OUVRE

Return

#ADNGO - X3PEOP-1243 - 2016-10-19 - END

#ADNGO - X3PEOP-1243 - 2016-10-19 - START
$OUVRE
#SAVAN X3-30974
#deactivate when selected from menu item.
#  If func AFNC.ACTIV("GLM") Then
#  Infbox "Module has been de-activated."
#  OK=0
#  Else
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  Call MANAGE_LOCALISATION("OCNG") From DIVPAYE
##  Endif
 Return
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

#ADNGO - X3PEOP-1243 - 2016-10-19 - START
$LIENS

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Filter [CPY] Where CPY=[F:CNG]CPY
Read [F:CPY]CPY0=[F:CNG]CPY
#ADNGO - 2016-11-29 - X3PEOP-1243 - START
Filter [CPY]
#ADNGO - 2016-11-29 - X3PEOP-1243 - END
GCURLEG=[F:CPY]LEG

#65872
If GPAYE
 [M]CUMACQ0=[F:CNG]CUMACQ(0)
 [M]CUMACQ1=[F:CNG]CUMACQ(1)
 [M]CUMPRI0=[F:CNG]CUMPRI(0)
 [M]CUMPRI1=[F:CNG]CUMPRI(1)
Endif

#FLNEL 7 March 2014 - gray ouot start and end dates if lve cycle not "from a specific date"
If func AFNC.ACTIV("KGZA") Then        :#21/03/2014 : test added by DBA
 If [F:CNG]LVESEL = 2
#JASMI - 2014/08/27 - Rollback changes - START
#  Actzo [M]LVESTR
#  Actzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Grizo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
  Actzo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT
 Else
#JASMI - 2014/08/27 - Rollback changes - START
#  Grizo [M]LVESTR
#  Grizo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Actzo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
  Diszo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT
 Endif
 If [F:CNG]LVESEL=3
  Actzo [M]LVEFOR
 Else
  Grizo [M]LVEFOR
 Endif
#JASMI - 2014/08/27 - Rollback changes - START
# Affzo [M]LVESTR
# Affzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
 Affzo [M]LVEFOR
 Affzo [M]LVETRM
#nd FLNEL
Endif

Gosub STYLE
Return

# FQ88082 - SEGAY 23/04/13 test ACS de TIM
# On ne filtre pas les listes car coté Back on doit voir toutes les lignes.
# On teste uniqument en saisie au contrôle de la nature d'évènement
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
$FERME
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

#ADNGO - X3PEOP-1243 - 2016-10-19 - START
$STYLE
  Gosub DISPLAY_HIDE From SUBCNGLEG
Return
#ADNGO - X3PEOP-1243 - 2016-10-19 - END

$FILTRE
# If GUSRACS<>2
#  If FILTSUP<>"" : FILTSUP += " & " : Endif
#  FILTSUP -= '([F:TIM]ACS="" or [F:ACC]CONSUL=2)'
# Else
#  FILTSUP ="1=1"
# Endif
Return
# END FQ88082
$INIMOD
$INICRE
#65872
If GPAYE
 [F:CNG]CUMACQ(0)=[M]CUMACQ0
 [F:CNG]CUMACQ(1)=[M]CUMACQ1
 [F:CNG]CUMPRI(0)=[M]CUMPRI0
 [F:CNG]CUMPRI(1)=[M]CUMPRI1
Endif

Return
#JOJAC - 2016-11-21 - START
$FILGAUCHE

If GLEGFIL <> ""
  FILGAUCHE ="[F:CPY]LEG='"+GLEGFIL+"'"
Else
  FILGAUCHE = ""
Endif

Return
#JOJAC - 2016-11-21 - END


$RAZCRE
#ADNGO - X3PEOP-1243 - 2016-10-19 - START
If [M:CNG0]CPY = ""
  Raz GCURLEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Endif

#FLNEL 7 March 2014 - gray ouot start and end dates if lve cycle not "from a specific date"
If func AFNC.ACTIV("KGZA") Then        :#21/03/2014 : test added by DBA
 If [F:CNG]LVESEL = 2
#JASMI - 2014/08/27 - Rollback changes - START
#  Actzo [M]LVESTR
#  Actzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Grizo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
  Actzo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT
 Else
#JASMI - 2014/08/27 - Rollback changes - START
#  Grizo [M]LVESTR
#  Grizo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Actzo [M]LVETRM
#JASMI - 2015-11-04 - Req. No. 111578 - END
  Diszo [M:CNG0]STRDAT,ENDDAT,DEBDAT,FINDAT
 Endif
 If [F:CNG]LVESEL=3
  Actzo [M]LVEFOR
 Else
  Grizo [M]LVEFOR
 Endif
#JASMI - 2014/08/27 - Rollback changes - START
# Affzo [M]LVESTR
# Affzo [M]LVEEND
#JASMI - 2014/08/27 - Rollback changes - END
 Affzo [M]LVEFOR
 Affzo [M]LVETRM
#nd FLNEL
Endif

Return


###################################
$SETBOUT
#Ajout du bouton "Supprimer" : mais je ne comprend pas pourquoi il n'y est pas en standard !!!
If CLECUR : CHAINE+="A" : Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

#ADNGO - X3PEOP-1243 - 2016-10-19 - END

#ADNGO - 2017-06-05 - X3-33759 - START
$MODIF
If LVESEL = 2 Then
  If [M:CNG0]STRDAT = [0/0/0]
    GERR = 1
    GMESSAGE = mess(54,108,1) -":"- mess(10,123,1)
    zonsui = "[M:CNG0]STRDAT"
    GOK = 0
    Return
  Endif
Endif
Return

$CREATION
  Gosub MODIF
Return
#ADNGO - 2017-06-05 - X3-33759 - END

