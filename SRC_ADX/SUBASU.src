Raz GPILOBJ,GNBMASKOUV
Call OBJET("ASU",GBIDC1,GBIDC2) From GOBJET
End
######################################################
######################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "STATUT"      : Gosub STATUT
 When "LIENS"       : Gosub LIENS
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "APRES_CRE"   : Gosub CRE_DOC
 When "APRES_MOD"   : Gosub MAJ_DOC
Endcase
Return


#######################################################
$AVANTBOUT
If  BOUT="5"
 Gosub VERIF_PUBLI
 Global Char GPG_WEB : GPG_WEB=[M:ASU1]PRG
 Global Char GSPG_WEB : GSPG_WEB=[M:ASU1]SUBPRG
Endif
Return

#######################################################
$OUVRE
Local File ASUBPROG [AS2]
Local File ASUBPROGD [ASP]
Local Char PRG(GLONADC) , SUB(GLONASU) , MESSA(80)
Local Integer T , ER , NBER , INTE
Return


#######################################################
$CRE_DOC
Call TRACE_COR_ADO("ASU",[M]PRG+"_"+[M]SUBPRG,"C") From AGENLIBA
Return

$MAJ_DOC
Call TRACE_COR_ADO("ASU",[M]PRG+"_"+[M]SUBPRG,"M") From AGENLIBA
Return

#######################################################
$LIENS
[M]PUBNAM = ""
If [M]WEBS=2 and dim([F:ASU]PUBLINAM)>0
  If clalev([F:AWE])=0 : Local File AWEBSERVIC [AWE] : Endif
  Read [AWE]AWE1=[F:ASU]PUBLINAM
  If fstat=0
    [M]PUBNAM = [F:ASU]PUBLINAM
  Endif
Endif
Affzo [M]PUBNAM
Call TEXTE([M:ASU1]INTIT,[M:ASU1]ZINTIT) From OBJDIV
I = 0
For [ASP]ASP0 Where PRG = [M]PRG & SUBPRG=[M]SUBPRG
 [M:ASU1]PARAM(I)    = [ASP]PARAM
 [M:ASU1]TYPPAR(I)   = [ASP]TYPPAR
 [M:ASU1]ADRVAL(I)   = [ASP]ADRVAL
 [M:ASU1]INTITPAR(I) = [ASP]INTITPAR
 [M:ASU1]DIME(I)     = [ASP]DIME
 [M:ASU1]PUBLI(I)    = [ASP]PUBLI
 [M:ASU1]LONG(I)     = [ASP]LONG
 [M:ASU1]CODCLA(I)   = [ASP]CODCLA
 Call TEXTE([M:ASU1]INTITPAR(I),[M:ASU1]ZINTITPAR(I)) From OBJDIV
 I += 1
Next I
Call LECTURE_DOC("ASU",[M]PRG+"_"+[M]SUBPRG,[M]TEXTE,K) From SUBADO
Gosub GRISE_FONCTION
Return

$GRISE_FONCTION
If [M]FONCTION=2
 Actzo TYPFCT
Else
 [M]TYPFCT = 0
 Affzo TYPFCT
 Grizo TYPFCT
Endif
Return

#######################################################
$FILGAUCHE
Case currbox
 When "GAU_CHE1"
  FILGAUSUP = '[F:ASU]FONCTION = 2'
 When "GAU_CHE2"
  FILGAUSUP = '[F:ASU]FONCTION <> 2'
 When "GAU_CHE"
  FILGAUSUP = ''
 When "GAU_CHE3"
  FILGAUSUP = '[F:ASU]WEBS = 2'
Endcase
Return

#######################################################
$MODIF
Delete [ASP] Where PRG=[M]PRG & SUBPRG=[M]SUBPRG
If fstat
 GOK = -1 : Call RSTA("ASP",[M]PRG+"~"+[M]SUBPRG) From GLOCK : Return
Endif
$CREATION
For nolign=1 To [M:ASU1]NBRPAR
 Raz [F:ASP]
 [F:ASP] = [M:ASU1]
 [F:ASP]LIGNE = nolign-1
 Write [ASP]
 If fstat
  GOK = 0 : Call FSTA("ASP") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
Call ECRIRE_DOC("ASU",[M]PRG+"_"+[M]SUBPRG,[M]TEXTE,[M]ZINTIT,[M]MODULE,[M]CODACT) From SUBADO
Return

#######################################################
$APRES_MODIF
Case zoncou
 When "WEBS"
  If CZ="2"
    CHMEN+="5"
    Gosub SET_BOUT_SPE From GSAISIE
    Gosub VERIF_PUBLI
#  Else
#    Local Integer TOSUP
#    For I=1 To [M:ASU1]NBRPAR
#      If [M:ASU1]PUBLI(I-1)<>""
#        TOSUP=1
#        Break 1
#      Endif
#    Next I
#    Call VIREBOUT(CHAINE,"5") From GOBJET
#
#   "Voulez vous supprimer les noms de publication ?"
#    If TOSUP=1
#      Local Integer IOK
#      Call OUINON(mess(150,150,1),IOK) from GESECRAN
#      If IOK=2
#        For I=1 To [M:ASU1]NBRPAR
#          Raz [M:ASU1]PUBLI(I-1)
#        Next I
#        Affzo [M]
#      Endif
#    Endif
  Endif

Endcase
Return

#######################################################
$ANNULE
Delete [ASP] Where PRG=[L]SUPP & SUBPRG=[L]CODE
If fstat
 GOK = -1 : Call RSTA("ASP",[L]SUPP+"~"+[L]CODE) From GLOCK
 Return
Endif
#   Supprime la publication si le Web service est publié
If [F:ASU]PUBLINAM<>""
#   Suppression de [F:ASU]PUBLINAM.xml
#   Suppression du programme wrapper (src et adx)
  Local Char NAMEFIC1(200),NPUBLI,PROGWR(20)
  Local Integer IOK
  NPUBLI=[F:ASU]PUBLINAM
  PROGWR="WJ"+[F:ASU]PUBLINAM
  NAMEFIC1=filpath("TRT",PROGWR,"src")
  Call EFFACE(NAMEFIC1,IOK) From ORDSYS
  Call EFFACE_ADX("","",PROGWR,IOK) From ORDSYS
  Call NAMEFIC(nomap,"WEBS","",[F:ASU]PUBLINAM,NAMEFIC1) From INTRUTILA
  Call EFFACE(NAMEFIC1,IOK) From ORDSYS
Endif
Call EFFACE_DOC("ASU",[L]SUPP+"_"+[L]CODE) From SUBADO
Return

#----------------------------------------------------------------------------#
$AP_ANNULE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ASU",[L]SUPP+"_"+[L]CODE,"A") From AGENLIBA
Return

#######################################################
$SETBOUT
CHMEN += "346"
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
 Call VIREBOUT(CHAINE,"5") From GOBJET
 Call VIREBOUT(CHMEN,"3") From GOBJET
Endif
If [M]PRG="" | [M]SUBPRG=""
 Call VIREBOUT(CHMEN,"3") From GOBJET
Endif
If [F:ASU]PUBLINAM<>""
  If clalev([F:AWE])=0 : Local File AWEBSERVIC [AWE] : Endif
  Read [AWE]AWE1=[F:ASU]PUBLINAM
  If fstat=0
    Call VIREBOUT(CHAINE,"A") From GOBJET : # Supprimer
  Else
    [F:ASU]PUBLINAM=""
  Endif
Endif
If [M]WEBS<>2 or dim(GWEBTUNSP)>0
  Call VIREBOUT(CHAINE,"5") From GOBJET
Endif
Return

#######################################################
$STATUT
Case BOUT
 When "3" : Gosub VERIF_UN
 When "4" : Gosub VERIF_TOUS
Endcase
Return

$VERIF_UN
PRG = [M]PRG
SUB = [M]SUBPRG
If PRG="" | SUB=""
 Return
Endif
Gosub VERIF_PAR
If ER=0
 Call MESSAGE(MESSA) From GESECRAN
Else
 Call ERREUR(MESSA) From GESECRAN
Endif
Return

$VERIF_PAR
Gosub CHERCHE_PAR
Raz ER , MESSA
If TRT=0
 ER = 4
Elsif SPG=0
 ER = 3
Elsif !((FCT=[F:ASU]FONCTION) | (FCT=1 & find([F:ASU]FONCTION,0,1)))
 ER = 2
Elsif [F:ASU]NBRPAR<>NBPAR
 ER = 1 : MESSA = "("+num$(NBPAR)+")"
Else
 I = 0
 For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
  I+=1
  MESSA = [F:ASP]PARAM
  If vireblc([F:ASP]PARAM,2)<>TBPAR(I)
   ER = 1 : MESSA -= "("+TBPAR(I)+")"
  Elsif TBTYP(I)<>0 & [F:ASP]TYPPAR<>TBTYP(I)
   ER = 1 : MESSA -= "("+mess(TBTYP(I),33,1)+")"
  Elsif TBADR(I)<>0 & [F:ASP]ADRVAL<>TBADR(I)
   ER = 1 : MESSA -= "("+mess(TBADR(I),34,1)+")"
  Endif
 Next I
Endif
Case ER
 When 0 : MESSA = mess(64,123,1)       : # OK
 When 1 : MESSA = mess(9,135,1)-MESSA  : # Paramètres incorrects
 When 2 : MESSA = mess(51,139,1)       : # Type incorrect
 When 3 : MESSA = mess(71,150,1)       : # Sous-programme inexistant
 When 4 : MESSA = mess(90,123,1)       : # Traitement inexistant
Endcase
Return

$VERIF_TOUS
Filter [ASU] Where SUBPRG<>"" & PRG<>""
Call OUVRE_BOITE(mess(57,123,1)-mess(34,9005,1),100) From GESECRAN
Call SET_BOITE(mess(57,123,1)-mess(34,9005,1),nbrecord([F:ASU])) From GESECRAN
NBER = 0
T = 0
For [ASU]
 T += 1
 Call AFF_BOITE([F:ASU]PRG,T,INTE) From GESECRAN
 PRG = [F:ASU]PRG
 SUB = [F:ASU]SUBPRG
 Gosub VERIF_PAR
 If ER
  If NBER=0
   Call OUVRE_TRACE(mess(57,123,1)-mess(34,9005,1)) From LECFIC : # Vérifications Sous-programmes
  Endif
  NBER += 1
  Call ECR_TRACE(mess(19,123,1)-PRG-mess(34,9005,1)-SUB-":"-MESSA,1) From GESECRAN
  # Traitement/Sous-programme :
 Endif
Next ASU
Call FERME_BOITE From GESECRAN
Call FERME_TRACE From LECFIC
Filter [ASU]
If NBER=0
 Call MESSAGE(MESSA) From GESECRAN
Else
 Call LEC_TRACE From LECFIC
Endif
Read [ASU]ASU0 = [M]PRG;[M]SUBPRG
Return

$VERIF_PUBLI
#  For I=1 To [M:ASU1]NBRPAR
#    If [M:ASU1]PUBLI(I-1)=""
#      If I=1 or (I>1 and [M:ASU1]DIME(I-1)<>[M:ASU1]DIME(I-2))
#        [M:ASU1]PUBLI(I-1)="G"+num$(I)
#      Elsif I>1 and [M:ASU1]PUBLI(I-2)<>""
#        [M:ASU1]PUBLI(I-1)=[M:ASU1]PUBLI(I-2)
#      Endif
#    Endif
#  Next I
#  Affzo [M:ASU1]
Return


##################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ASUBPROG  [ASU1]
 Local File ASUBPROGD [ASP1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ASUBPROG"  [ASU1]
 Local File =[M]DOSORG+".ASUBPROGD" [ASP1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ASUBPROG  [ASU2]
 Local File ASUBPROGD [ASP2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ASUBPROG"  [ASU2]
 Local File =[M]DOSDES+".ASUBPROGD" [ASP2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
Local Integer I
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ASU1], [ATX1], [ASU2], [ATX2] , [ASP1]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2] , [ASP2]
Return

$TR_COP
GOK = 1
Trbegin [ASU2]
 Delete [ASU2] Where PRG=TABLE & SUBPRG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASUBPROG" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ASU2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ASP2] Where PRG=TABLE & SUBPRG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASUBPROGD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AOD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ASU1]ASU0 Where PRG=TABLE & SUBPRG=TABLE2
  [F:ASU2] = [F:ASU1]
  Call COPTEXTE([F:ASU1]INTIT,[F:ASU2]INTIT) From OBJDIV
  If dim([F:ASU2]UPDUSR)>0 : [F:ASU2]UPDUSR = GUSER : Endif
  If dim([F:ASU2]UPDDAT)>0 : [F:ASU2]UPDDAT = date$ : Endif
  Write [ASU2]
  If fstat
   GOK=0 : Call FSTA("ASU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ASP1]ASP0 Where PRG=TABLE & SUBPRG=TABLE2
  [F:ASP2] = [F:ASP1]
  Call COPTEXTE([F:ASP1]INTITPAR,[F:ASP2]INTITPAR) From OBJDIV
  Write [ASP2]
  If fstat
   GOK=0 : Call FSTA("ASP2") From GLOCK : Break
  Endif
 Next ASP
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPIE_DOC("ASU",TABLE+"_"+TABLE2,[M]DOSORG,[M]DOSDES) From SUBADO
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog B1_NBRPAR
Local Char PRG(GLONADC) , SUB(30)
PRG = [M]PRG
SUB = [M]SUBPRG
Gosub CHERCHE_PAR
Local Integer FD1
Local Integer TBINTIT(1..500)

If NBPAR>0
 [M]NBRPAR = NBPAR

#  On conserve la dimension des tableaux déjà définis
#  On conserve les intitulés si ils sont définis

 For I=1 To NBPAR
  FD1=find(TBPAR(I),[M]PARAM(0..NBPAR-1))
  If FD1>0
    If [M]DIME(FD1-1)>1 and TBDIM(I)>1
      TBDIM(I)=[M]DIME(FD1-1)
    Endif
    TBINTIT(I)=[M]INTITPAR(FD1-1)
  Endif
 Next I

 For I=1 To NBPAR
  [M]PARAM(I-1) = TBPAR(I)
  [M]TYPPAR(I-1) = TBTYP(I)
  [M]ADRVAL(I-1) = TBADR(I)
  [M]DIME(I-1) = max(TBDIM(I),1)
  [M]CODCLA(I-1) = TBCLA(I)
  [M]INTITPAR(I-1)=TBINTIT(I)
  [M:ASU1]ZINTITPAR(I-1)=""
  If TBINTIT(I)<>0 : Call TEXTE([M:ASU1]INTITPAR(I-1),[M:ASU1]ZINTITPAR(I-1)) From OBJDIV : Endif
 Next I
 Affzo NBRPAR,NUMLIG2,PARAM,TYPPAR,ZINTITPAR,ADRVAL,DIME,CODCLA
 mkstat=4
Endif
End

Subprog AP_SUBPRG(VALEUR)
Variable Char    VALEUR()
#If (GREP="C" | GREP="D") & VALEUR<>[M]SUBPRG
#    Bug 79959      CC  13/02/2012
If VALEUR<>[M]SUBPRG
 Local Char PRG(GLONADC) , SUB(GLONASU)
 PRG = [M]PRG
 SUB = VALEUR
 Gosub CHERCHE_PAR
 If NBPAR>0
  [M]NBRPAR = NBPAR
  For I=1 To NBPAR
   [M]PARAM(I-1)  = TBPAR(I)
   [M]TYPPAR(I-1) = TBTYP(I)
   [M]ADRVAL(I-1) = TBADR(I)
   [M]DIME(I-1) = max(TBDIM(I),1)
   [M]CODCLA(I-1) = TBCLA(I)
  Next I
  [M]FONCTION = FCT
  Affzo NBRPAR,NUMLIG2,PARAM,TYPPAR,ZINTITPAR,ADRVAL,DIME,FONCTION,CODCLA
 Endif
Endif
End

$CHERCHE_PAR
Local Integer I , J , K , L , TP , TYP , FCT , TRT , SPG, DIMC, K1, K2, K3, KJ, ISDIM
Local Char    TRAIT(GDIMFIC) , LIGNE(250) , LIGNE2(250), AVARC, AVART(50), CNSUB(50),L_CLA
Local Char    LIGNEIN(250)(1..10)    : # CC 03/11/04 on peut dépasser 250 caractères
Local Char    TBPAR(30)(1..500),TBCLA(GLONACLA)(1..500)
Local Integer TBTYP(1..500) , TBADR(1..500) ,TBDIM(1..500), NBPAR , NBIN, INBIN
TRAIT  = filpath("TRT",PRG,"src")
Raz NBPAR , TRT , SPG
If filinfo(TRAIT,0)>0
 TRT = 1
 Openi TRAIT Using [TTT]
 Iomode adxifs "" Using [TTT]
 Iomode adxirs chr$(10) Using [TTT]
 Rdseq LIGNE Using [TTT]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  Case left$(LIGNE,7)
   When "Subprog" : FCT = 1
   When "Funprog" : FCT = 2
   When Default   : FCT = 0
  Endcase
  If FCT<>0
   LIGNE = vireblc(right$(LIGNE,8),2)
   NBIN=1
   LIGNEIN(NBIN)=LIGNE
   KJ=instr(1,LIGNE,"(")
   If KJ=0
    CNSUB=vireblc(left$(LIGNE,len(SUB)+1),2)
   Elsif KJ>len(SUB)
    CNSUB=vireblc(mid$(LIGNE,len(SUB)+1,KJ-len(SUB)),2)
   Else
    CNSUB=""
   Endif
   If LIGNE=SUB | (left$(LIGNE,len(SUB))=SUB & CNSUB="(")
    SPG = 1
    While 1
     Rdseq LIGNE2 Using [TTT]
     If left$(LIGNE2,1)="&"
      If len(LIGNEIN(NBIN))+len(vireblc(right$(LIGNE2,2),2))<250
        LIGNEIN(NBIN)+=vireblc(right$(LIGNE2,2),2)
      Else
        If right$(LIGNEIN(NBIN),len(LIGNEIN(NBIN)))<>","
          LIGNEIN(NBIN)+=","
        Endif
        NBIN+=1
        If left$(vireblc(right$(LIGNE2,2),2),1)=","
          LIGNEIN(NBIN)=vireblc(right$(LIGNE2,2),2)
        Else
          LIGNEIN(NBIN)=","+vireblc(right$(LIGNE2,2),2)
        Endif
      Endif
     Else
      Break
     Endif
    Wend
    INBIN=1
    LIGNE=LIGNEIN(INBIN)
    K = instr(1,LIGNE,"(")
    If K
     While 1
      J = instr(K+1,LIGNE,",")
      If J
       NBPAR += 1
       TBPAR(NBPAR) = vireblc(seg$(LIGNE,K+1,J-1),2)
       K = J
      Else
       J = instr(K+1,LIGNE,")")
       If J
        NBPAR += 1
        TBPAR(NBPAR) = vireblc(seg$(LIGNE,K+1,J-1),2)
        If len(TBPAR(NBPAR))=0 : NBPAR-=1 : Endif    :# Si on a saisi ( ) sans paramètre
        K = J
        Break
       Else
        If INBIN<NBIN
          INBIN+=1
          LIGNE=LIGNEIN(INBIN)
          K= 1
        Else
          Break
        Endif
       Endif
      Endif
     Wend
    Endif
    LIGNE = LIGNE2
    While 1
     LIGNE = vireblc(LIGNE,2)
     If LIGNE="" | left$(LIGNE,1)="#"
      TYP = 0
     Elsif left$(LIGNE,5)="Value"
      TYP = 2
      LIGNE = vireblc(right$(LIGNE,6),2)
     Elsif left$(LIGNE,8)="Variable"
      TYP = 1
      LIGNE = vireblc(right$(LIGNE,9),2)
     Else
      Break
     Endif
     If TYP
      TP = 0 : L = 0
      If left$(LIGNE,4)="Char"
       TP = 1 : L = 4
      Elsif left$(LIGNE,7)="Integer"
       TP = 2 : L = 7
      Elsif left$(LIGNE,8)="Shortint"
        L=8
        # Le type shortint n'est pas géré, modifiez votre programme
        Call ECR_TRACE(mess(160,150,1)+"\"-LIGNE,1) From GESECRAN
      Elsif left$(LIGNE,7)="Decimal"
       TP = 3 : L = 7
      Elsif left$(LIGNE,8)="Datetime"  # KUYAN
       TP = 10: L = 8
      Elsif left$(LIGNE,4)="Date"
       TP = 4 : L = 4
      Elsif left$(LIGNE,7)="Libelle"
       TP = 5 : L = 7
      Elsif left$(LIGNE,7)="Clbfile"
       TP = 6 : L = 7
      Elsif left$(LIGNE,7)="Blbfile"
       TP = 7 : L = 7
      Elsif left$(LIGNE,8)="Instance"
       TP = 8 : L = 8
      Elsif left$(LIGNE,7)="Uuident"
       TP = 9 : L = 7
      Endif
      LIGNE = vireblc(right$(LIGNE,L+1),2)
      DIMC=1
      While LIGNE<>""
       K = instr(1,LIGNE,",")
       If K
        AVART = left$(LIGNE,K-1)
        LIGNE = right$(LIGNE,K+1)
       Else
        AVART = LIGNE
        LIGNE = ""
       Endif
       If TP = 8
        K = instr(1,AVART," Using ")
        If K
         L_CLA = right$(AVART,K+7)
         AVART = left$(AVART,K-1)
        Endif
       Endif
       AVARC = AVART
       ISDIM=0
       K = instr(1,AVART,"(")
       If K
        AVARC = vireblc(left$(AVART,K-1),2)
        K1 = instr(K,AVART,"(0..")
        K2 = instr(K,AVART,"(1..")
        If K1<>0 or K2<>0
         ISDIM=1
         K3 = instr(max(K1,K2)+1,AVART,")")
         AVART=mid$(AVART,max(K1,K2)+4,K3-4-max(K1,K2))
         DIMC=val(vireblc(AVART,2))
        Endif
        If K1<>0 : DIMC+=1 : Endif
        If ISDIM=1 and DIMC<=1
 #         If TP<>1 and TP<>6 and TP<>7
            DIMC=10
 #         Else
 #           K1 = instr(K+1,AVART,"(")   : # Pour les Char, blob et Clob il faut déclarer la taille avant la dim
 #           If K1<>0 : DIMC=10 : Endif
 #         Endif
        Endif
       Endif
       K = find(AVARC,TBPAR(1..NBPAR))
       If K
        TBTYP(K) = TP
        TBADR(K) = TYP
        TBDIM(K) = DIMC
        If TP = 8
         TBCLA(K) = L_CLA
        Endif
       Endif
      Wend
     Endif
     Rdseq LIGNE Using [TTT]
     If fstat : Break : Endif
    Wend
    Break
   Endif
  Endif
  Rdseq LIGNE Using [TTT]
 Wend
 Openi Using [TTT]
Endif
Return

Subprog C_PRG(VALEUR)
Variable Char    VALEUR()
Local Integer OKTRT
Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
If !OKTRT
 GMESSAGE = VALEUR-":"-mess(90,123,1) : mkstat = 2 : # Traitement inexistant
Endif
End

