Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Integer OK
Call MODIF_DOC("ASU",[M]PRG+"_"+[M]SUBPRG,OK) From SUBADO
If !OK : VALEUR = [M]TEXTE : Affzo TEXTE : Endif
End

Subprog AM_FONCTION(VALEUR)
Variable Integer VALEUR
[M]FONCTION = VALEUR
Gosub GRISE_FONCTION
End

Subprog AS_TYPASU(VALEUR)
Variable Integer VALEUR
End

Subprog AS_TYPFCT(VALEUR)
Variable Integer VALEUR
GMENLOC(8) = 1
End


Subprog C_SUBPRG(VALEUR)
Variable Char    VALEUR()

Local Integer NBSPG
Local Char LSPG(30)(0..200)
Call LISTSUB(nomap,[M]PRG,NBSPG,LSPG) From ASELSIMP
If !find(VALEUR,LSPG(0..NBSPG)) and LSPG(1)<>"NOSOURCE"
  GMESSAGE=mess(71,150,1) : # Sous-programme inexistant
  mkstat=2
Elsif !find(VALEUR,LSPG(0..NBSPG))
  Infbox(mess(274,123,1)) : # Source non livré, vérification impossible
Endif
End

Subprog AM_WEBS(VALEUR)
Variable Integer VALEUR
If VALEUR=1 and [F:ASU]PUBLINAM<>""
  mkstat=2
# Modification impossible, le sous-programme est publié. Il faut au préalable supprimer la publication
  GMESSAGE=mess(271,123,1)
Endif
End

Subprog AS_CODCLA(VALEUR)
Variable Char    VALEUR()
If [M]TYPPAR(nolign-1)<>8
 mkstat =1 : End
Endif
End

Subprog CL_WA(VALEUR)
Variable Char    VALEUR()
If [M]PUBNAM<>""
 Read [F:AWE]AWE1 = [M]PUBNAM
 If !fstat
  GBIDC1  = [M]PUBNAM
  GBIDC2  = ""
  Call OBJET("AWE",GBIDC1,GBIDC2) From GOBJET
 Endif
Endif
End

Subprog AS_ADRVAL(VALEUR)
Variable Integer  VALEUR
GMENLOC(3) = 1
End


Subprog LISTE_ASU(TRAIT,PROG,NBASU,INTIT,DOSSIER,CRITERE)
Variable Char     TRAIT()(1..)
Variable Char     PROG()(1..)
Variable Integer  NBASU
Variable Char     INTIT()(1..)
Value    Char     DOSSIER()
Value    Char     CRITERE()


Local File =DOSSIER+".ASUBPROG" [ASU]
Local File =DOSSIER+".ATEXTE"   [ATX]

Link [ASU] With
& [ATX]NUMERO = GLANGUE;[ASU]INTIT
& As [LNK_]

If [L]CRITERE="" : [L]CRITERE = "1=1" : Endif

NBASU=0
For [LNK_] Where evalue(CRITERE)
 NBASU += 1
 TRAIT(NBASU) = [ASU]PRG
 PROG(NBASU)  = [ASU]SUBPRG
 INTIT(NBASU) = [ATX]TEXTE
Next

End

