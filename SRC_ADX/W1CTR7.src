#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR7 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:48"
A_USER  = "DOC"
A_STAMP = "20181109230348"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR7 [CTR7]
Gosub HORODAT
Local Inpbox "CTR7" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR7] As [SIM_]
Grizo [CTR7]5
Grizo [CTR7]10
Grizo [CTR7]15
Grizo [CTR7]20
Grizo [CTR7]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR7]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=74 : Y1(1)=4 : Y2(1)=5
X1(2)=1 : X2(2)=39 : Y1(2)=6 : Y2(2)=7
X1(3)=40 : X2(3)=74 : Y1(3)=6 : Y2(3)=7
X1(4)=1 : X2(4)=74 : Y1(4)=8 : Y2(4)=22
Return

$ON_BUICODASS
Onevent INIT_AREA Call D_BUICODASS(zc) From W1CTR7
Onevent BEFORE_INPUT Call AS_BUICODASS(zc) From W1CTR7
Return

Subprog D_BUICODASS(VALEUR)
Variable Integer VALEUR
If varinit([M]BUICODASS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BUICODASS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

