$ON_BUICAT
Onevent BEFORE_INPUT Call AS_BUICAT(zc) From W1CTR7
Onevent INIT_AREA Call D_BUICAT(zc) From W1CTR7
Onevent CONTROL Call C_BUICAT(zc) From W1CTR7
Return

Subprog D_BUICAT(VALEUR)
Variable Integer VALEUR
If varinit([M]BUICAT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BUICAT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10380) From COMBOS
## Action STD
Call AS_BUICAT(VALEUR) From SUBCTR
If mkstat=2
 [M]BUICAT(INDIC) = VALEUR
 Affzo BUICAT(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10380,1))))
Endif
If !mkstat
 Discombo 0 From BUICAT(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From BUICAT(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_BUICAT(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

