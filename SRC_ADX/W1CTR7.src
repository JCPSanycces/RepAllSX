$ON_BUIDAYTYP
Onevent BEFORE_INPUT Call AS_BUIDAYTYP(zc) From W1CTR7
Onevent INIT_AREA Call D_BUIDAYTYP(zc) From W1CTR7
Onevent CONTROL Call C_BUIDAYTYP(zc) From W1CTR7
Return

Subprog D_BUIDAYTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]BUIDAYTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BUIDAYTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10404) From COMBOS
## Action STD
Call AS_BUIDAYTYP(VALEUR) From SUBCTR
If mkstat=2
 [M]BUIDAYTYP(INDIC) = VALEUR
 Affzo BUIDAYTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10404,1))))
Endif
If !mkstat
 Discombo 0 From BUIDAYTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From BUIDAYTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_BUIDAYTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

