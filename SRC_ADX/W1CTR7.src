$ON_BUICODJOB
Onevent INIT_AREA Call D_BUICODJOB(zc) From W1CTR7
Onevent CONTROL Call C_BUICODJOB(zc) From W1CTR7
Onevent BEFORE_INPUT Call AS_BUICODJOB(zc) From W1CTR7
Onevent AFTER_CHANGE Gosub AMM_BUICODJOB From W1CTR7
Return

Subprog D_BUICODJOB(VALEUR)
Variable Char    VALEUR()
If varinit([M]BUICODJOB,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10403","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_BUICODJOB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10403") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_BUICODJOB(zc) From W1CTR7
Onkey   2 Titled GBOUTS Call S_BUICODJOB(zc) From W1CTR7
Onkey 144 Titled GBOUTP Call P_BUICODJOB(zc) From W1CTR7
Onkey 146 Titled GBOUTA Call SA_BUICODJOB(zc) From W1CTR7
Gosub _AFF
End

Subprog C_BUICODJOB(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10403","") From SUBADI
If mkstat : GERR = 1 : GZONE = "BUICODJOB" : GZNUM = 46541 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10403",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BUICODJOB" : GZNUM = 46541 : Endif
Endif
Gosub _AFF
End

$AMM_BUICODJOB
Call AM_BUICODJOB(zc)
If !mkstat & GOBJET
 zoncou = "BUICODJOB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BUICODJOB(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZBUICODJOB)")>indice
 [M]BUICODJOB(indice) = VALEUR
 Affzo ZBUICODJOB(indice)
Endif
Gosub _AFF
End

Subprog S_BUICODJOB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10403"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_BUICODJOB(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10403") From GOBJET
Gosub _AFF
End

Subprog SA_BUICODJOB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10403"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BUICODJOB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10403"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZBUICODJOB
Onevent BEFORE_AREA Gosub AV_ZBUICODJOB From W1CTR7
Return

$AV_ZBUICODJOB
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10403",num$([M]BUICODJOB(indice))) From ATEXTRA
Gosub _AFF
Return

