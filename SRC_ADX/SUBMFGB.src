########################################################################

########################################################################
Subprog LECT_FICLIG(NLIG)
Value Integer NLIG
#--------------------------------------------------------------------#
# Lecture des fichiers associés à la ligne pour mise à jour          #
#   - ITMMASTER  [ITM] : Articles                                    #
#   - FACILITY   [FCY] : Site de production                          #
#   - ITMFACILIT [ITF] : Articles-sites                              #
#--------------------------------------------------------------------#
Call LECTURE ("ITM",[M:MFG1]ITMREF(NLIG),"") From CONTOBJ
Call LECTURE ("ITF",[M:MFG1]ITMREF(NLIG),[M:MFG0]MFGFCY) From CONTOBJ
End

########################################################################
#--------------------------------------------------------------------#
# Décrémentation de la quantité lancée totale                        #
#--------------------------------------------------------------------#
Subprog SUB_TOT(NLIG)
Value Integer NLIG
[M:MFG1]MFGEXTQTY -= [M:MFG1]EXTQTY(NLIG)
[M:MFG2]MFGEXTQTY -= [M:MFG1]EXTQTY(NLIG)
End

########################################################################
#----------------------------------------------------------------------#
# Incrémentation de la quantité lancée totale                          #
#----------------------------------------------------------------------#
Subprog ADD_TOT(NLIG)
Value Integer NLIG
[M:MFG1]MFGEXTQTY += [M:MFG1]EXTQTY(NLIG)
[M:MFG2]MFGEXTQTY += [M:MFG1]EXTQTY(NLIG)
End

########################################################################
#----------------------------------------------------------------------#
# Recherche dans le tableau de l'article ayant le + long délai         #
#----------------------------------------------------------------------#
Subprog RECH_ART_L(WLTI, WART)
Variable Integer WLTI
Variable Char    WART
Local    Integer I
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD

# un seul article lancé
If [M:MFG1]NBLIG=1
    I=0
    If [F:ITF]ITMREF<>[M:MFG1]ITMREF(I)
        Read [ITF]ITF0=[M:MFG1]ITMREF(I);[M:MFG0]MFGFCY
        If fstat : End : Endif
    Endif
    Call CALCUL_DELAI([F:ITF]MFGLTI, [M:MFG1]MFGEXTQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD<>0 : ILTI += 1 : Endif
    WLTI=ILTI
    WART=[F:ITF]ITMREF
    End
Endif

# multi-article
For I=0 To [M:MFG1]NBLIG-1
    Read [ITF]ITF0=[M:MFG1]ITMREF(I);[M:MFG0]MFGFCY
    If !fstat
        Call CALCUL_DELAI([F:ITF]MFGLTI, [M:MFG1]MFGEXTQTY, XLTI) From MFGLIB
        ILTI    = int(XLTI)
        WRMD    = XLTI - ILTI
        If WRMD<>0 : ILTI += 1 : Endif
        If ILTI>WLTI : WLTI=ILTI : WART=[F:ITF]ITMREF : Endif
        If WART=""   : WLTI=ILTI : WART=[F:ITF]ITMREF : Endif
    Endif
Next
End

########################################################################
#----------------------------------------------------------------------#
# Sauvegarde contexte avant traitement d'une ligne                     #
#----------------------------------------------------------------------#
Subprog SAVE_CTX(NLIG)
Value Integer NLIG
#
GEXTQTY=[M:MFG1]MFGEXTQTY
GMFGLIN=[M:MFG1]XMFGLIN(NLIG)
End

########################################################################
#----------------------------------------------------------------------#
# Analyse contexte après traitement d'une ligne
# si quantité lancée totale a changée, maj matières, recalcul délai... #
#----------------------------------------------------------------------#
Subprog ANALYSE_CTX(NLIG)
Value    Integer NLIG
Local    Date    WORIDAT  # Ctrl des sources GA 10/2010 avant Value
Local    Char    WORIFCY  # Ctrl des sources GA 10/2010 avant Value
Local    Date    WMEMDAT
Local    Integer WLTI
Local    Char    WART
Local    Integer WMAX
Local    Integer I,WRET,WI


# si quantité inchangée, pas de traitement
If [M:MFG1]MFGEXTQTY=GEXTQTY : End : Endif

# mise à jour opérations
If (find([M:MFG0]MFGMOD,1,3) & ([M:MFG3]NBLIG <> 0))
    WMAX = [M:MFG3]NBLIG - 1
    Call UPD_QTY_GLOB(0, WMAX) From MFGLIBO
    If [M:MFG3]SCDFLG > 1 : Call MOD_JAL From MFGLIBO : Endif
Endif
# mise à jour quantité matières si modification
# sr 01.03 17012
# sr 01.03 Si multi article lancé et cumul des matières au lancement on recharge
# complètement le tableau des matières

# Issue 84429 - 2012-09-19 by CCC : en suppression de ligne il faut aussi màj les composants
#If (find([M:MFG0]MFGMOD,1,2) & GMODIF = 0)  & (GFLGMAT = 1 | GREP <> "C")
If (find([M:MFG0]MFGMOD,1,2) & find(GMODIF,0,1))  & (GFLGMAT = 1 | GREP <> "C")
    If GCUMMAT <>  2 | [M:MFG1]NBLIG = 1 | GREP <> "C"
        # Issue 84429 - 2012-09-19 by CCC : le msg est déjà affiché en test de l'annulation (SUBMFGA.$TEST_ANU)
        #If GCUMMAT = 2 & [M:MFG1]NBLIG > 1
        If GCUMMAT = 2 & [M:MFG1]NBLIG > 1 & GMODIF<>1
            Call MESSAGE(mess(55,190,1)) From GESECRAN
        Endif
        Call UPD_MAT_QTY(NLIG,[M:MFG1]EXTQTY(NLIG)) From MFGLIBM
    Else
        GMODIF = 2
        Raz [M:MFG2]
        # GH 13/01/2014 bug 95499 suppresion des sous-produits
        For WI = 0 To  [M:MFG1]NBLIG-1
            If [M:MFG1]ITMTYP(WI)=2
               Dela WI,1 [M:MFG1]NBLIG
               [M:MFG1]NBLIG-=1
            Endif
        Next
        For WI = 0 To [M:MFG1]NBLIG-1
            Call UPDMAT(WI,0) From MFGLIBM
            GFLGMAT = 1
        Next
        GMODIF = 0
    Endif
    Affzo [M:MFG2]10
Endif
# si date non renseignée (phase création), pas de traitement
If [M:MFG1]STRDAT=[0/0/0] | [M:MFG1]ENDDAT=[0/0/0] : End : Endif

WORIFCY=[M:MFG0]MFGFCY
WLTI=0

# recherche article avec délai le + long
Call RECH_ART_L(WLTI, WART)

# si article vide (cas de la suppression de ligne) pas de calcul
If WART=""
    If [M: MFG1]SCDMOD=1
        [M:MFG1]STRDAT=[M:MFG1]ENDDAT
    Else
        [M:MFG1]ENDDAT=[M:MFG1]STRDAT
    Endif
    Affzo [M:MFG1]10
    End
Endif

# lecture ITF
If [F:ITF]ITMREF<>WART
    Read [ITF]ITF0=WART;[M:MFG0]MFGFCY
    If fstat : End : Endif
Endif
# calcul date
If [M:MFG1]SCDMOD=1
    WORIDAT=[M:MFG1]ENDDAT
    WMEMDAT=[M:MFG1]STRDAT
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MFG1]STRDAT) From MFGLIB

# si nouvelle date début, mise à jour dates matières
    If [M:MFG1]STRDAT <> WMEMDAT : Call MAJDAT([M:MFG1]STRDAT,WORIFCY) : Endif
Else
    WORIDAT=[M:MFG1]STRDAT
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MFG1]ENDDAT) From MFGLIB

Endif

Affzo [M:MFG1]10
Call CHECK_PAST([M:MFG1]STRDAT, 2) From MFGLIB
End

########################################################################
#----------------------------------------------------------------------#
# Recalcul de la date des matières                                     #
#----------------------------------------------------------------------#
Subprog MAJDAT(LORIDAT, LFCY)
Value  Date LORIDAT
Value  Char LFCY
#
If (find([M:MFG0]MFGMOD,1,2)) & (GFLGMAT = 1 | GREP <> "C")
    Call UPD_MAT_DAT(LORIDAT, LFCY) From MFGLIBM
Endif
End

########################################################################
#----------------------------------------------------------------------#
# mise à jour des matières                                             #
#----------------------------------------------------------------------#
Subprog MAJMAT(L)
Value  Integer L
#
If GMODIF <> 2                 : End : Endif
If !find([M:MFG0]MFGMOD,1,2)   : End : Endif
#
Case GREP
    When "C":      If GFLGMAT = 1
                        Call GETLINE(L)  From MFGLIBM
                        Call UPDMAT(L,1) From MFGLIBM
                        End
                   Endif
    When Default:   Call GETLINE(L)  From MFGLIBM
                    Call UPDMAT(L,1) From MFGLIBM
                    End
Endcase
#
End

#########################################################################
# Contrôle de validité des nomenclatures par rapport à une date         #
#-----------------------------------------------------------------------#
Subprog CONTROL_NOM_VAL(LDAT, LMSG)
Value    Date     LDAT
Value    Integer  LMSG
Local    Integer  I

For I=0 To [M:MFG1]NBLIG-1
    Read [BOH]BOH0=[M:MFG1]ITMREF(I);[M:MFG1]BOMALT(I);2
    If fstat : Break : Endif
    If ([F:BOH]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH]BOHSTRDAT)
        If LMSG=1 : GMESSAGE=mess(50,193,1) : Endif
        mkstat=2
        Break
    Endif
    If ([F:BOH]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH]BOHENDDAT)
        If LMSG=1 : GMESSAGE=mess(50,193,1) : Endif
        mkstat=2
        Break
    Endif
Next
End

########################################################################
#----------------------------------------------------------------------#
# Pour forcer le flag update des lignes articles lancés                #
#----------------------------------------------------------------------#
Subprog ITMUPDFLG
Local Integer I
#
If find(GREP,"C","D") : End : Endif
#
For  I=0 To [M:MFG1]NBLIG-1
    [M:MFG1]UPDFLG(I)=1
Next I
#
End

#########################################################################
# Contrôle de validité des données tableau après modif site de prod     #
# (le moteur n'effectue jamis les contrôlesdans les tableaux            #
# donc on les fait soi-même ...
#-----------------------------------------------------------------------#
Subprog CONTROL_NEW_FCY(LFCY, LMSG)
Value    Char    LFCY
Variable Char    LMSG
Local    Integer WALT
Local    Date    WDAT
Local    Char    WFCY
Local    Integer I
Local    Integer LERRCOD    # 107513
#
WFCY = LFCY
LMSG = ""
# boucle de contrôle des articles lancés
For  I = 0 To [M:MFG1]NBLIG - 1
    # contrôle article
    # lecture article et article/site
    Read [ITM]ITM0=[M:MFG1]ITMREF(I)
    If fstat
        LMSG = mess(134,100,1)-"("+[M:MFG1]ITMREF(I)+")"
        mkstat = 2
        End
    Endif
    # lecture article/site
    Read [ITF]ITF0=[M:MFG1]ITMREF(I);WFCY
    If fstat
        LMSG = mess(45,193,1)-"("+[M:MFG1]ITMREF(I)+")"
        mkstat = 2
        End
    Endif
    #
    Call CONTMFGITM(WFCY, 1) From MFGLIB
    If mkstat <> 0 : LMSG = GMESSAGE : LMSG -= "("+[M:MFG1]ITMREF(I)+")" : End : Endif
    # Contrôle filtre par planificateur
    Call CTLPLNFLT(LFCY, [M:MFG1]ITMREF(I), GUSER) From MFGLIB
    If mkstat <> 0 : LMSG = GMESSAGE : LMSG -= "("+[M:MFG1]ITMREF(I)+")" : End : Endif
    # contrôle nomenclature
    If [M:MFG1]STRDAT=[0/0/0]
        WDAT=date$
    Else
        WDAT=[M:MFG1]STRDAT
    Endif
    # lecture BOM
    Read [TBO]TBO0=2;[M:MFG1]BOMALT(I)
    If fstat : mkstat=2 : End : Endif
    Read [BOH]BOH0=[M:MFG1]ITMREF(I);[M:MFG1]BOMALT(I);2
    If fstat : mkstat=2 : End : Endif
    Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
    If WALT=0 : LMSG=GMESSAGE : LMSG -= "("+num$([M:MFG1]BOMALT(I))+")" : mkstat=2 : End : Endif
Next I

# boucle de contrôle des matières
For  I = 0 To [M:MFG2]NBLIG - 1
#    # lecture article et article/site
#    Read [ITM]ITM0=[M:MFG2]ITMREF(I)
#    If fstat
#        LMSG = mess(134,100,1)-"("+[M:MFG2]ITMREF(I)+")"
#        mkstat = 2
#        End
#    Endif
#    # lecture article/site
#    Read [ITF]ITF0=[M:MFG2]ITMREF(I);WFCY
#    If fstat
#        LMSG = mess(45,193,1)-"("+[M:MFG2]ITMREF(I)+")"
#        mkstat = 2
#        End
#    Endif
#    #
#    Call CONTMATITM(WFCY, 1) From MFGLIB
#    If mkstat <> 0 : LMSG = GMESSAGE : LMSG -= "("+[M:MFG2]ITMREF(I)+")" : End : Endif
    Call CONTMATITM([M:MFG2]ITMREF(I), WFCY, "MFG2", LERRCOD, LMSG) From MFGLIB
    If find(LERRCOD,4,1)
        LMSG = "("+[M:MFG2]ITMREF(I)+")" + LMSG
        mkstat=2
        End
    Endif
Next I
#
End

#########################################################################
# Modification des données                                              #
#-----------------------------------------------------------------------#
Subprog UPD_NEW_FCY(LFCY)
Value    Char    LFCY
Local    Integer I
Local    Char    WFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WORIDAT
Local    Date    WMEMDAT
Local    Integer WMSG
Local    Date    WDAT
Local    Integer WALT
Local    Integer TABTBO(3)

#
WFCY = LFCY
# boucle de mise à jour des articles lancés
For  I = 0 To [M:MFG1]NBLIG - 1
    # lecture article/site
    Read [ITF]ITF0=[M:MFG1]ITMREF(I);WFCY
    If fstat
        GMESSAGE = mess(45,193,1)-"("+[M:MFG1]ITMREF(I)+")"
        mkstat = 2
        End
    Endif
    [M:MFG1]ABCCLS(I)     = [F:ITF]ABCCLS
    [M:MFG1]PLANNER(I)    = [F:ITF]PLANNER
    [M:MFG1]UPDFLG(I)     = 1
Next I

If [M:MFG1]STRDAT <> [0/0/0] & [M:MFG1]STRDAT <> [0/0/0]
    # recalcul délai
    # recherche article avec délai le + long
    WLTI=0
    WART=""
    Call RECH_ART_L(WLTI, WART)

    # si article vide pas de calcul
    If WART=""
        If [M:MFG1]SCDMOD=1
            [M:MFG1]STRDAT=[M:MFG1]ENDDAT
        Else
            [M:MFG1]ENDDAT=[M:MFG1]STRDAT
        Endif
        End
    Endif

    # lecture ITF
    If [F:ITF]ITMREF<>WART
        Read [ITF]ITF0=WART;WFCY
        If fstat : End : Endif
    Endif

    # calcul date
    If [M:MFG1]SCDMOD=1
        WORIDAT=[M:MFG1]ENDDAT
        WMEMDAT=[M:MFG1]STRDAT
        # révision calendriers (llc 06.00)
        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WFCY, 1, [M:MFG1]STRDAT) From MFGLIB

    # si nouvelle date début, mise à jour dates matières
        If [M:MFG1]STRDAT <> WMEMDAT : Call MAJDAT([M:MFG1]STRDAT, WFCY) : Endif
    Else
        WORIDAT=[M:MFG1]STRDAT
        # révision calendriers (llc 06.00)
        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WFCY, 0, [M:MFG1]ENDDAT) From MFGLIB

    Endif
Endif

# mise à jour matières
For  I = 0 To [M:MFG2]NBLIG - 1
    # lecture article/site
    Read [ITF]ITF0=[M:MFG2]ITMREF(I);WFCY
    If fstat
        GMESSAGE = mess(45,193,1)-"("+[M:MFG2]ITMREF(I)+")"
        mkstat = 2
        End
    Endif
    [M:MFG2]PLANNER(I)     = [F:ITF]PLANNER
    Call ANALYSE_LOC("MFG2", WFCY, [M:MFG2]BOMOPE(I), I, [M:MFG2]ITMREF(I)) From MFGLIBM
Next I
#
# mise à jour Gamme
# lecture article/site, premier article lancé
If [M:MFG3]NBLIG <> 0
    Read [ITF]ITF0=[M:MFG1]ITMREF(0);WFCY
    If fstat
        GMESSAGE = mess(45,193,1)-"("+[M:MFG1]ITMREF(I)+")"
        mkstat = 2
        End
    Endif
    WDAT=[M:MFG1]STRDAT
    WMSG=0
    WALT=0
    If [M:MFG1]ROUNUM <> ""
        #    Lecture ROUTING
        For [ROH] Where [F:ROH]ITMREF=[M:MFG1]ROUNUM & [F:ROH]FCY = [M:MFG0]MFGFCY
            Read [TRO]TRO0=[F:ROH]ROUALT
            If !fstat
                Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MFG1]MFGEXTQTY,
&                               [M:MFG1]MFGSTU,WMSG) From MFGLIB
                If WALT <> 0
                    [M:MFG1]ROUALT=WALT
                    # FGR 18/09/2009 : X3SUIVI57927
                    #[M:MFG1]ROUALTDES=[F:TRO]TROSHO
                    Call LECTEXTRA([M:MFG1]ROUALTDES,"TABROUALT","TROSHOAXX",num$([F:TRO]ROUALT),"") From ATEXTRA
                    Break
                Endif
            Endif
        Next
    Endif
    If WALT <> 0
        # Contrôle de cohérence des alternatives de nomenclature
        TABTBO(0)=[F:TRO]BOMALT1
        TABTBO(1)=[F:TRO]BOMALT2
        TABTBO(2)=[F:TRO]BOMALT3
        For I=0 To [M:MFG1]NBLIG-1
            If ([M:MFG1]ITMTYP(I) = 1 & !find([M:MFG1]BOMALT(I), TABTBO))                        # 12.04 27352
                GMESSAGE=mess(53,193,1) - "(" + num$(WALT)+"/"+num$([M:MFG1]BOMALT(I))+")"
                mkstat=2
                End
            Endif
        Next I
        # mise à jour de la liste des opérations
        Call UPDOPE(2,0,WALT) From MFGLIBO
        [M:MFG1]WORTYP = [F:ROH]WORTYP
    Endif
Endif

# V6 Règle affectation : # GH 19/11/13 bug 94579
For  I = 0 To [M:MFG1]NBLIG - 1
     [M:MFG1]PTOCOD(I)=func ITMLIB.GET_PTOCOD([M:MFG1]ITMREF,WFCY)
Next
For  I = 0 To [M:MFG2]NBLIG - 1
     [M:MFG2]PTOCOD(I)=func ITMLIB.GET_PTOCOD([M:MFG2]ITMREF,WFCY)
Next

Affzo [M:MFG1]
Affzo [M:MFG2]
Affzo [M:MFG3]
#
End

