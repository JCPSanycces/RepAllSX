#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs clients
# Superviseur
## CRUD-CLASSE ## CCMCRORIGC
# 2018-10-19 07:50:18 100


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CCMCRORIGC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGC
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_CCMCRORIGC
Else
 Gosub AINSERT_CCMCRORIGC
Endif

Gosub _AINSERT_AFTER
[L]A_I = CCMCRORIGC.freeSnapshot
CCMCRORIGC.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If CCMCRORIGC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGC.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_CCMCRORIGC
Trbegin [F:CCMCROC]
 Gosub AINSERT_CCMCRORIGC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_CCMCRORIGC
Raz [F:CCMCROC]
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGC._MAJSQL_CCMCRORIGC(CCMCRORIGC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If CCMCRORIGC.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGC.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGC.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(CCMCRORIGC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGC.ASTALIN = [V]CST_ALL
Endif
Return



