#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGPOSPUR01                                         Module purchase     #
#                                                                          #
#              Post-migration of Open item                                 #
#                                                                          #
# Management of olds fields in TRANSPORT table                             #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSPUR01") From LECFIC
  Endif
  #Call RAZ_UUMGPOSPUR01(DOSSIER)
  Call MAJ_UUMGPOSPUR01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSPUR01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSPUR01",ERR) From TRTMIG

End


###################################################################################
Subprog MAJ_UUMGPOSPUR01(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(8)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSPUR01",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSPUR01",2,ERR) From TRTMIG
#-----  n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSPUR01",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSPUR01",3,ERR) From TRTMIG : End
Endif


Call ECR_TIME("UUMGPOSPUR01 Open items Process : Update TRANSPORT - Fields : VESNAM, VESSEL, VOYNUM, MBOL, HBOL") From DOSSUB
Call ECR_TIME("Fields : FLYNAM, FLINUM, AWB, HAWB, WAGNAM, TRANUM, WAGNUM, CIM, ROANAM, REGNUM, CMR, CTBL") From DOSSUB
Call ECR_TRACE("UUMGPOSPUR01 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Opening of files  -----#
If clalev([F:TRNP]) : Close File [TRNP] : Endif
If clalev([F:TRNP])  = 0 :  Local File =DOSSIER+".TRANSPORT"  [F:TRNP]   : Endif      # Transport


#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PUR01
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:TRNP]TRNNUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1 "
Endif

Trbegin [TRNP]
GOK = 1

For [TRNP]TRNP0 Where evalue(CRITERE)

   NBLUS+=1

   #--- New field assignation

   # Others
   If val(VERSION)>=GMIGX3VER110
    Gosub MAJ_POS_V10
    Gosub WRI_TRNP
    If GOK <1 | STOP = 1:  Break : Endif
   Endif

Next

If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSPUR01",7,ERR) From TRTMIG
Else
  Commit
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSPUR01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PUR01
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [TRNP]

$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSPUR01") From TRTMIG
Call ECR_TIME("UUMGPOSPUR01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$MAJ_POS_V10
[F:TRNP]VESNAM = AVOID.ACHAR
[F:TRNP]VESSEL = AVOID.ACHAR
[F:TRNP]VOYNUM = AVOID.ACHAR
[F:TRNP]MBOL   = AVOID.ACHAR
[F:TRNP]HBOL   = AVOID.ACHAR
[F:TRNP]FLYNAM = AVOID.ACHAR
[F:TRNP]FLINUM = AVOID.ACHAR
[F:TRNP]AWB    = AVOID.ACHAR
[F:TRNP]HAWB    = AVOID.ACHAR
[F:TRNP]WAGNAM = AVOID.ACHAR
[F:TRNP]TRANUM = AVOID.ACHAR
[F:TRNP]WAGNUM = AVOID.ACHAR
[F:TRNP]CIM    = AVOID.ACHAR
[F:TRNP]ROANAM = AVOID.ACHAR
[F:TRNP]REGNUM = AVOID.ACHAR
[F:TRNP]CMR    = AVOID.ACHAR
[F:TRNP]CTBL   = AVOID.ACHAR
Return

$WRI_TRNP
Rewrite [F:TRNP]
If fstat
  Call ECR_TRACE("File TRANSPORT(TRNNUM)"-[F:TRNP]TRNNUM+", Error ="-num$(fstat),1) From GESECRAN
  GOK=0
Endif

NBCOMMIT += 1
NB+=1
If NB>GMAXUPDTRS
  ACLE1 = [F:TRNP]TRNNUM
  STOP=1
Endif
Return

