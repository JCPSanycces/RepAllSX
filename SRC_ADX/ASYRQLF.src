#----------------------------------------------------------------------------------------------------------#
# This operation is used for about version
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/about
#
# use GET for get about informations
#
#----------------------------------------------------------------------------------------------------------#

Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char SCRIPT(250),TEST_CASE(250)
SCRIPT         =  func ASYRMAIN.PARVAL(ARCV,"script")
TEST_CASE  =  func ASYRMAIN.PARVAL(ARCV,"test_case")

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null
Local Instance  RESULTS     Using C_ASYRJSO  : RESULTS=null

Call JSON_ADDARRAY(NODES,JNULL,"",RESULTS) From ASYRJSO
Call =TEST_CASE With RESULTS From =SCRIPT

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO


ASND.URL      = PSYR.PREFIX+'/QLF'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".qlf"

End ERROR

Subprog CHECK_EQUAL( RESULTS, GOT, EXPECT)

Local Char OK(10)
Local Clbfile MESSAGE
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  RESULT Using C_ASYRJSO: RESULT=null
NODES = RESULTS.FAT

If GOT = EXPECT Then
 OK = "true"
Else
 OK = "false"
Endif
MESSAGE = "Expected "
Append MESSAGE, num$(EXPECT)
Append MESSAGE," GOT "
Append MESSAGE,num$(GOT)

Call JSON_ADDOBJECT(NODES,RESULTS,"",RESULT)  From ASYRJSO
Call JSON_ADDSTRING_WITHOUTQUOTE(NODES,RESULT,'ok'    ,OK)  From ASYRJSO
Call JSON_ADDCLB(NODES,RESULT,'message'    ,MESSAGE)  From ASYRJSO

End

Subprog TC_QLF(RESULTS)
Call CHECK_EQUAL(RESULTS, 1, 1) From ASYRQLF
Call CHECK_EQUAL(RESULTS, 4, 4) From ASYRQLF
Call CHECK_EQUAL(RESULTS, 2, 2) From ASYRQLF
End
