#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table intitulé traduisibles sur les lignes des modèles export
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update translated field AOBJEXTD file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESAOE
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub DESAOE
End

#-------------------#
$DESAOE

Local File =DOSSIER+".AOBJEXTD"  [AOD] 
Local File =DOSSIER+".ATEXTRA"   [AXX]

If dim([F:AOD]COM)<0
 Close Local File [AOD],[AXX]
 Return 
Endif

# Mise à jour de la table AOBJEXTD
Call ECR_TRACE(mess(81,125,1)-"AOBJEXTD:"-time$,0) From GESECRAN
Trbegin [AOD]
 For [AOD]AOD0
  If find(left$([F:AOD]FLD,1),"","/","*","=") & [F:AOD]COM<>""
   Call MAJTEXTRA([F:AOD]COM,"AOBJEXTD","INTFLD",[F:AOD]EXT,[F:AOD]FIL+[F:AOD]FLD) From ATEXTRA
   [F:AOD]COM = ""
   Rewrite [AOD]
   If fstat
    Call ERREUR("AOBJEXTD"-[F:AOD]EXT-num$([F:AOD]NUMLIG),2) From DOSDIC
   Endif 
  Endif
 Next AOD
Commit

Close Local File [AOD],[AXX]

Return
