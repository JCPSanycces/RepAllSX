Subprog C_LANCOD(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]LANCOD) From OBJDIV
End

Subprog AS_LANFMTINT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
VALEUR="N:6#"
End

Subprog AM_DIRLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local Integer WOK,RET
 Call OUINON(mess(227,7900,1)+"\"+mess(228,7900,1),WOK) From GESECRAN
 If WOK=2
  Call OUVRE_TRACE(mess(10,7900,1)-[M]FCYCOD) From LECFIC
  Call DIRXTUPD("",nomap,RET) From AYTGESFILE
  Call DIRFCYUPD("",nomap,[M]FCYCOD, [M]LANCOD,VALEUR, RET) From AYTGESFILE
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE  From LECFIC
 Endif 
Endif
End

Subprog AS_LANFMTDEC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
VALEUR="N:"+GFMT3
End

Subprog AS_LANFMTDAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
VALEUR="DZ:"+GFMDAT
End

Subprog AS_LANFMTCUR(VALEUR)
Variable Char     VALEUR
Local Integer WI
If VALEUR<>"" : End : Endif

If GLOCALDEV <> ""
 WI = find(GLOCALDEV, GDEVISE)
 VALEUR="N:"+GDEVFMT1(WI)+ "[ " + GDEVISE + "]"
Else
 VALEUR="N:11.2#[ EUR]"
Endif
End

Subprog AM_LNKADSDEF(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL = nolign-1
If VALEUR=2 
   WI = find(2,[M]LNKADSDEF(0..NOL-1),0,[M]LNKADSDEF(NOL+1..dim([M]LNKADSDEF)-1))
   If WI
    WI=WI-1
    [M]LNKADSDEF(WI)=1
    Affzo [M]LNKADSDEF(WI)
   Endif
Else
   If [M]LNKADSDEF(NOL)=2 : VALEUR=2 : Endif
Endif
End


Subprog D_LNKADSDEF(VALEUR)
Variable Integer VALEUR
If nolign=1
    VALEUR=2
Endif
End


Subprog AP_LNKNBR
If adxgtb=2
    If !find(2,[M]LNKADSDEF) : GERR=3 : GMESSAGE = mess(4,7900,1) : Endif
Endif
End

Subprog AP_LANNBR
If adxgtb=2
    If [M]LANNBR=0 
        GERR=3 : GMESSAGE = mess(3,7900,1)
    Else   
        Local Integer RET, WOK
        GSILENCE=1
        Call DIRFCYVER("",nomap,[M]FCYCOD, [M]LANCOD,[M]DIRLAN, RET) From AYTGESFILE
        GSILENCE=0
        If RET=0
         WOK=2
         Call OUINON(mess(13,7900,1),WOK) From GESECRAN
         If WOK=2
            Call OUVRE_TRACE(mess(10,7900,1)-[M]FCYCOD) From LECFIC
            Call DIRXTUPD("",nomap,RET) From AYTGESFILE
            Call DIRFCYUPD("",nomap,[M]FCYCOD, [M]LANCOD,[M]DIRLAN, RET) From AYTGESFILE
            Call FERME_TRACE From LECFIC
            Call LEC_TRACE  From LECFIC
         Endif   
        Endif
    Endif
Endif
End

Subprog AP_PAGSTR(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 GERR=3 : GMESSAGE=mess(5,7900,1)
Endif
End

Subprog D_LANDEF(VALEUR)
Variable Integer VALEUR
If nolign=1
    VALEUR=2
Endif
End

Subprog AM_LANDEF(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL = nolign-1
If VALEUR=2 
   WI = find(2,[M]LANDEF(0..NOL-1),0,[M]LANDEF(NOL+1..dim([M]LANDEF)-1))
   If WI
    WI=WI-1
    [M]LANDEF(WI)=1
    Affzo [M]LANDEF(WI)
   Endif
Else
   If [M]LANDEF(NOL)=2 : VALEUR=2 : Endif
Endif
End

Subprog C_PAGSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : GERR=2 : GMESSAGE=mess(118,7900,1) : Endif
End

Subprog C_PAGLOG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : GERR=2 : GMESSAGE=mess(119,7900,1) : Endif
End

Subprog C_PAGERR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : GERR=2 : GMESSAGE=mess(120,7900,1) : Endif
End

Subprog C_PAGMCE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:AYS1]MCEFLG=2 : mkstat=2 : GMESSAGE=mess(200,7900,1) : Endif
End

Subprog C_PAGRECNX(VALEUR)
Variable Char    VALEUR()
# If VALEUR="" : GERR=2 : GMESSAGE=mess(119,7900,1) : Endif
