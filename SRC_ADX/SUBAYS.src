Subprog C_IMGDEF(VALEUR)
Variable Char    VALEUR()
Value Char    LAN
If VALEUR="" : End : ENDIf
LAN = func SUBAYS.LANDEF([M]FCYCOD)

Local Char RACINE(200),FILEPATH(250)
Local Integer WI
RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",LAN,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>1     # pas un fichier
    GERR=3 : GMESSAGE=mess(202,7900,1)-VALEUR        # GERR=3: avertissement GERR=2: message
Endif
End

Subprog S_IMGDEF(VALEUR)
Variable Char    VALEUR()
Value Char    LAN
LAN= func SUBAYS.LANDEF([M]FCYCOD)
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Char LANDEF(GLONLAN)
 Local Integer WI
 
 RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",LAN,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
 WVAL=RACINE+VALEUR
 ## Action SELFICREP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 Call SAISIE_CHAR(WVAL,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 WI=instr(0,WVAL,RACINE)
 If WI
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(16,7900,1)-WVAL
 Endif 
Endif
End


