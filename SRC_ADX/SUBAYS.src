#----------------------------------------------------------------------------------------------------------#
# Copie des textes du dossier origine sans supprimer les autres textes du dossier destination special xtend
#----------------------------------------------------------------------------------------------------------#

Subprog COPTEXTRA(TABLE,CHAMP,CLE1,CLE2,SITDES)
Value    Char    TABLE, CHAMP, CLE1, CLE2 ,SITDES

For [AXX1] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:AXX2]AXX0 = TABLE;CHAMP;[F:AXX1]LANGUE;SITDES;CLE2
 If !fstat
  [F:AXX2]TEXTE = [F:AXX1]TEXTE
  If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = date$  : Endif
  If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = GUSER  : Endif
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = SITDES
  If dim([F:AXX2]CREDAT)>0 : [F:AXX2]CREDAT = date$ : Endif
  If dim([F:AXX2]CREUSR)>0 : [F:AXX2]CREUSR = GUSER : Endif
  If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = [0/0/0] : Endif
  If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = "" : Endif
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next
End


Subprog AM_FCYCOD(VALEUR)
Variable Char    VALEUR()
Local Char ZVAL
Local File =GDOSX3+".ADOVAL" [ADW]
Read [F:ADW]ADW1 = "ADONIX";"";""
If !fstat
 ZVAL = [F:ADW]VALEUR
Endif
If left$(VALEUR,1) = "A" & ZVAL<>"2"
 GMESSAGE = mess(223,7900,1) : # "Code site commençant par A résevé à SAGE"
 mkstat =2 : End 
Endif
End
