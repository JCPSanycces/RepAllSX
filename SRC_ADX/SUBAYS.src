#--
Subprog S_PAGSTR(VALEUR)
Variable Char    VALEUR()
# Ce site comme site courant
Local Char SAV_FCY(GLONAYS)  : SAV_FCY=""
If GAYTFCYWRK <> [M]FCYCOD
 SAV_FCY=GAYTFCYWRK 
 Call SETFCYWRK([M]FCYCOD)
 Gosub INICTLFCY
 Gosub DSYFCY
Endif

Local Char PARMSK(250)(1..16)
PARMSK(1) = "AYG"
PARMSK(2) = "!"
PARMSK(3) = num$([M]FCYCOD)
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION

# Restauration site
If SAV_FCY <> ""
 Call SETFCYWRK(SAV_FCY)
 Gosub INICTLFCY
 Gosub DSYFCY
Endif
End

Subprog S_PAGLOG(VALEUR)
Variable Char    VALEUR()
Call S_PAGSTR(VALEUR)
End

Subprog S_PAGERR(VALEUR)
Variable Char    VALEUR()
Call S_PAGSTR(VALEUR)
End

Subprog S_PAGMCE(VALEUR)
Variable Char    VALEUR()
Call S_PAGSTR(VALEUR)
End

Subprog S_PAGRECNX(VALEUR)
Variable Char    VALEUR()
Call S_PAGSTR(VALEUR)
End
Subprog S_PARRECNX(VALEUR)
Variable Char    VALEUR()
Call S_PAGSTR(VALEUR)
End

#--
Subprog B1_PAGSTR(VALEUR)
Variable Char    VALEUR()
# Ce site comme site courant
Local Char SAV_FCY(GLONAYS)  : SAV_FCY=""
If GAYTFCYWRK <> [M]FCYCOD
 SAV_FCY=GAYTFCYWRK 
 Call SETFCYWRK([M]FCYCOD)
 Gosub INICTLFCY
 Gosub DSYFCY
Endif
Call OBJET("AYG",VALEUR,num$([M]FCYCOD)) From GOBJET

# Restauration site
If SAV_FCY <> ""
 Call SETFCYWRK(SAV_FCY)
 Gosub INICTLFCY
 Gosub DSYFCY
Endif
End

Subprog B1_PAGLOG(VALEUR)
Variable Char    VALEUR()
Call B1_PAGSTR(VALEUR)
End

Subprog B1_PAGERR(VALEUR)
Variable Char    VALEUR()
Call B1_PAGSTR(VALEUR)
End

Subprog B1_PAGMCE(VALEUR)
Variable Char    VALEUR()
Call B1_PAGSTR(VALEUR)
End

Subprog B1_PAGRECNX(VALEUR)
Variable Char    VALEUR()
