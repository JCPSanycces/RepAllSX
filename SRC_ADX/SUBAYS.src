#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet AYS
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYS",GBIDC1,GBIDC2) From GOBJET
End

#####################################################################################
## Xtend: Gestion Sites
#  Version 0001
#
######################################################################################
### Utilitaires
##    SubProg
#       SETFCYWRK       Mise à jour site de travail (global et paramétre utilisateur)
#       GETTITFCYWRK    Titre du site de travail
#       FILTFCY         Filtre sur les objets liés au site
#       LANDEF          Langue par défaut du site
#       LANDEF          Langue par défaut du site
#       FCYINFOS        Infos sur un site
#       FORMA           Vérification saisie format
#     Gosub
#       DSYFCY          Affichage site courant Xtend
#       DSYCLRFCY       Clear Affichage site courant Xtend
#       INICTLFCY       Initialisation et ctl à l'ouverture sur les objets liés à un site Xtend
######################################################################################
$ACTION
If dim([L]PSUBB)<=0        # Perso par produit
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAYSB",PSUBB) From ORDSYS
# PSUBB += (GPRODUIT=0)
Endif

Case ACTION
 When "RAZCRE"         : Gosub RAZCRE
 When "RAZDUP"         : Gosub RAZDUP
 When "AB1_LNKADS"     : Gosub AB1_LNKADS
 When "BB1_LNKADS"     : Gosub BB1_LNKADS
 When "AP_ANNULE"      : Gosub AP_ANNULE
 When "AP_FILGAUCHE"   : Gosub AP_FILGAUCHE
 When "EXEBOUT"        : Gosub EXEBOUT
 When "FERME"          : Gosub FERME
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "OUVRE"          : Gosub OUVRE
 When "SETBOUT"        : Gosub SETBOUT
 When "STATUT"         : Gosub STATUT
 When "MODIF"          : Gosub MODIF
 When "CREATION"       : Gosub CREATION
 When default
Endcase
If PSUBB                 # Perso par produit
 Gosub ACTION From SUBAYSB
Endif
Return

#---------------------------------------------------------------#
$RAZDUP
$RAZCRE
Raz   [M:AYS3]PAGSTR,PAGLOG,PAGERR,PAGMCE
Raz   [M:AYS1]MCEFLG
Affzo [M:AYS1]MCEFLG
Affzo [M:AYS3]PAGSTR,PAGLOG,PAGERR,PAGMCE
If LANNBR=0
 [M:AYS1]LANCOD(LANNBR)=GLANGUE
 [M:AYS1]LANADS(LANNBR)=GLANGUE
 [M:AYS1]LANDEF(LANNBR)=2
 Call AS_LANFMTCUR([M:AYS1]LANFMTCUR(LANNBR))
 Call AS_LANFMTDEC([M:AYS1]LANFMTDEC(LANNBR))
 Call AS_LANFMTINT([M:AYS1]LANFMTINT(LANNBR))
 Call AS_LANFMTDAT([M:AYS1]LANFMTDAT(LANNBR))
 LANNBR+=1
 Affzo [M:AYS1]10
Endif
Return


#---------------------------------------------------------------#
$AB1_LNKADS
Local Char SAVVAL(250)
SAVVAL = VALEUR
For [AYO] Where POOCOD = VALEUR
 VALEUR = [F:AYO]POOX3
 Break
Next
Return

$BB1_LNKADS
VALEUR = SAVVAL
Return

#---------------------------------------------------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT,"AYTFCY","INTIT",[M]FCYCOD,"") From ATEXTRA
Return

#---------------------------------------------------------------#

#---------------------------------------------------------------#
$OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Local Char WSTR1 (250)
Local Integer WI, WOK, WEXIST
#
Local Char WFCY_TIT(50): Local Char WFCY_CODACT(GLONACT) : Local Char WFCY_LANDEF(GLONLAN)
Call FCYINFOS( WEXIST, WFCY_TIT, WFCY_CODACT, WFCY_LANDEF)
Local File AYTPOOWEB [AYO]
Gosub DSYFCY
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY # Clear affichage site
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN +="13456"    # Menu haut
Endif
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$EXEBOUT
Case BOUT
Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$STATUT
#Local Integer INFACT
Case BOUT
When "1" # Ce site comme site couant
    Call SETFCYWRK([M]FCYCOD)
    Gosub INICTLFCY
    Gosub DSYFCY
    Call GES_ICOWRK()
When "3" # Mise à jour 
    Call OUVRE_TRACE(mess(10,7900,1)-[M]FCYCOD) From LECFIC
    Call DIRXTUPD("",nomap,RET) From AYTGESFILE
    Call DIRFCYUPD("",nomap,[M]FCYCOD,[M]LANCOD,[M]DIRLAN,RET) From AYTGESFILE
    Call DIRFCYUNIX("",nomap,[M]FCYCOD, RET) From AYTGESFILE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE  From LECFIC
When "4" # Vérification
    Call OUVRE_TRACE(mess(11,7900,1)-[M]FCYCOD) From LECFIC
    Call DIRFCYVER("",nomap,[M]FCYCOD, [M]LANCOD,[M]DIRLAN, RET) From AYTGESFILE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE  From LECFIC
When "5" # Suppression 
    WOK=1
    Call OUINON(mess(9,7900,1)-[M]FCYCOD,WOK) From GESECRAN
    If WOK=2
      Call OUVRE_TRACE(mess(12,7900,1)-[M]FCYCOD) From LECFIC
      Call DIRFCYDEL("",nomap,[M]FCYCOD, RET) From AYTGESFILE
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE  From LECFIC
    Endif
When "Z" # test

Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$LIENS
Call GES_ICOWRK()
Call GES_HCE([M:AYS2]HCEDEF)
Call GES_SCRIPT(1, [M:AYS2]SCTROO)
Call GES_TIMESTAMP([M:AYS2]CTSDEF)


Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INICRE
#Gosub VER_ENR
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INIMOD
#Gosub VER_ENR
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$AP_FILGAUCHE
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$AP_ANNULE
If GAYTFCYWRK = [M]FCYCOD : Call SETFCYWRK("")  : Endif    # sup. site de travail
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
#$FCYWRK_VAL
#[M]FCYWRK = 1
#If GAYTFCYWRK = [M]FCYCOD : [M]FCYWRK = 2 : Endif
#Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$VER_ENR
#If [F:AYS]LANNBR=0 : GERR=2 : GMESSAGE = mess(3,7900,1) : Endif
Return
#---------------------------------------------------------------#


######################################################################################
### Utilitaires
######################################################################################

# Init et ctl à l'ouverture sur les objets liés à un site Xtend
# $$$$
#------------------------------------------------------------#
$INICTLFCY
If dim(GAYTFCYWRK)<0 | GAYTFCYWRK=""
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  Local Char WFCY_SAVACT(12)
  WFCY_SAVACT=GACTION
  FLGEXE = 1
  GACTION = "AYSCHGFCYW"
  Call S_TAB_CHAR(VALBOUT,PARBOUT,"CHGFCYW","SUBAYSACT","") From GACTION
  GACTION = WFCY_SAVACT
  If GAYTFCYWRK=""
    OK=0
    GMESSAGE=mess(6,7900,1)
    Return
  Endif
Endif

Local Char WFCY_TIT(50), WFCY_CODACT(GLONACT), WFCY_LANDEF(GLONLAN)
Local Integer WFCY_EXIST
Call FCYINFOS( WFCY_EXIST, WFCY_TIT, WFCY_CODACT, WFCY_LANDEF)
If !WFCY_EXIST
    Call SETFCYWRK("")
    Goto INICTLFCY
Endif
Return

# Affichage site courant Xtend
# $$$$
#------------------------------------------------------------#
$DSYFCY
If dim(GAYTFCYWRK)>0 
  Inftxt mess(2,7900,1)+":"-WFCY_TIT At 1
  If dim([M]FCYLIB)>0 : [M]FCYLIB=WFCY_TIT : Endif
Endif
Return

# Clear Affichage site courant Xtend
# $$$$
#------------------------------------------------------------#
$DSYCLRFCY
Inftxt "" At 1
Return

# Filtre sur les objets liés à un site Xtend
# $$$$
#------------------------------------------------------------#
Funprog FILTFCY
Local Char WFILT(200)
If dim([M:AYS0]FCYCOD)<0
  If dim(GAYTFCYWRK)>=0
    WFILT='FCYCOD = "' + GAYTFCYWRK+ '"'
  Endif
Else
  WFILT='FCYCOD = "' + [M:AYS0]FCYCOD+ '"'
Endif
End WFILT

# Infos site
# $$$$
#------------------------------------------------------------#
Subprog FCYINFOS(EXIST, TIT, CODACT, LANDEF)
Variable Integer EXIST
Variable Char TIT
Variable Char CODACT
Variable Char LANDEF
Local Char WSTR(100)
EXIST=0
If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
Read [F:AYS]AYS0 = GAYTFCYWRK 
If !fstat
    EXIST=1
    CODACT=[F:AYS]CODACT
    WI=find(2,[AYS]LANDEF) : If WI : LANDEF=[AYS]LANCOD(WI-1) : Endif
    Call LECTEXTRA(WSTR,"AYTFCY","INTIT",[F:AYS]FCYCOD,"") From ATEXTRA
    TIT=GAYTFCYWRK 
    If WSTR<>"" :  TIT= TIT-"-"-WSTR : Endif
Endif
End 

# Mise à jour site de travail (global et paramétre utilisateur)
# $$$$
#------------------------------------------------------------#
Subprog SETFCYWRK(FCYWRK)
Value Char FCYWRK
Local Integer DEL
Local Char WSTR(50)
If clalev([F:ADU])=0 : Local File ADOVALAUS   [ADU] : Endif
   
GAYTFCYWRK = FCYWRK

If FCYWRK = "" : DEL=1 : Endif
Gosub TR_CF
End

$TR_CF
GOK=1
Trbegin [ADU]
Readlock [ADU]ADU0 = GUSER ; "AYTFCYWRK"
If fstat=1
    GOK=-1 : GLOCK = "$ADOVALAUS"-GUSER -"AYTFCYWRK" : Goto ROLL_CF
Elsif (fstat & DEL=0)
    Raz [F:ADU]
    [F:ADU]CODUSR = GUSER
    [F:ADU]PARAM  = "AYTFCYWRK"
    [F:ADU]VALEUR = GAYTFCYWRK 
    [F:ADU]JEU    = ""
    If dim([F:ADU]CREDAT)>0 : [F:ADU]CREDAT = date$ : Endif
    If dim([F:ADU]CREUSR)>0 : [F:ADU]CREUSR = GUSER : Endif
    If dim([F:ADU]CRETIM)>0 : [F:ADU]CRETIM = time  : Endif
    Write [ADU]
    If fstat
        GOK = 0 : Call FSTA("ADU") From GLOCK : Goto AB_CF
    Endif
Elsif DEL
    Delete [ADU] Where CODUSR=GUSER & PARAM="AYTFCYWRK"
Elsif [F:ADU]VALEUR<>GAYTFCYWRK 
    [F:ADU]VALEUR = GAYTFCYWRK
    [F:ADU]JEU    = ""
    If dim([F:ADU]UPDDAT)>0 : [F:ADU]UPDDAT = date$ : Endif
    If dim([F:ADU]UPDUSR)>0 : [F:ADU]UPDUSR = GUSER : Endif
    If dim([F:ADU]UPDTIM)>0 : [F:ADU]UPDTIM = time  : Endif
    Rewrite [ADU]
    If fstat
        GOK = 0 : Call FSTA("ADU") From GLOCK : Goto AB_CF
    Endif
Endif
Commit
Return

$ROLL_CF
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_CF : Endif
Return

$AB_CF
Rollback
Return


#   Gestion icone site courant
#---------------------------------------------------------------#
Subprog GES_ICOWRK()
If([M]FCYCOD=GAYTFCYWRK )
    [M]ICOWRK="131"
Else
    [M]ICOWRK=""
Endif
Affzo [M:AYS0]ICOWRK
End

# Langue par défaut du site
# $$$$
#------------------------------------------------------------#
Funprog LANDEF(FCY)
Value Char FCY
Local Integer WI
Local Char LAN(GLONLAN) : LAN=" "
If clalev([F:AYS])=0 : Local File AYTFCY[AYS] : Endif
Read [AYS]AYS0 = FCY
If fstat=0
    WI=find(2,[AYS]LANDEF)
    If WI : LAN=[AYS]LANCOD(WI-1) : Endif
Endif
End LAN


# Vérification saisie format (AYS et AYF)
#   Base reprise de SUBTCY - Format
#---------------------------------------------------------------#
Subprog FORMA(FMT, TYPXTD)
Variable Char    FMT()
Value Integer    TYPXTD    # Rang dans Mnl 7931
Local Char TMP(250)
Local Integer WI
Local Char FMTTYP(1)

# <JPJ>
#
If vireblc(FMT,2)="" : End : Endif
# Verif 1er
FMTTYP = mid$(FMT,1,1)
# Cohérence type
If TYPXTD=1             and FMTTYP<>"K"
 GERR=1 : GMESSAGE = mess(181,7900,1)-'X' : mkstat=2 : End
Endif
If find(TYPXTD,2,3,4)   and FMTTYP<>"N"
 GERR=1 : GMESSAGE = mess(181,7900,1)-'N' : mkstat=2 : End
Endif
If TYPXTD=5             and FMTTYP<>"D"
 GERR=1 : GMESSAGE = mess(181,7900,1)-'D' : mkstat=2 : End
Endif
If TYPXTD=8             and !find(FMTTYP,"L","N")
 GERR=1 : GMESSAGE = mess(181,7900,1)-'N ou LA' : mkstat=2 : End
Endif

# Verif :
WI=instr(2,FMT,":")
If !WI
 GERR=1 : GMESSAGE = mess(180,7900,1) : mkstat=2 : End
Endif
# </JPJ>

Local Integer L , D , E , COM
Local Char    C(1)
COM = 0 : D = 0
For I=WI+1 To len(FMT)
 C = mid$(FMT,I,1)
 If C="["
  If COM=0 & D=0 : COM = 1 : Else : E = 1 : Break : Endif
 Elsif C="]"
  If COM=1 & D=0 : COM = 0 : Else : E = 1 : Break : Endif
 Elsif COM=1
  L += 1
 Elsif instr(1,"0123456789",C)
  D = 10*D+val(C)
 Elsif FMTTYP="X" and !instr(1,"XAaBbCH ",C)
  E = 1 : Break
 # entier Xtend
 Elsif FMTTYP="N" and TYPXTD=2 and !instr(1,"#",C)
  E = 1 : Break
 # autre numérique
 Elsif FMTTYP="N" and find(TYPXTD,3,4) and !instr(1,"#.F",C)
  E = 1 : Break
 Elsif FMTTYP="D" and !instr(1,"DMYhms",C)
  E = 1 : Break
# Elsif FMTTYP="L" and !instr(1,"AABBCLX#",C)  pas de ctl
#  E = 1 : Break
 Else
  If D=0 : L += 1
  Else   : L += D
  Endif
  D = 0
 Endif
Next I
#If D<>0 | COM=1 : E = 1 : Endif        # Pas compris le test sur D (de plus ne fonctionne pas avec 10 en numérique)
If COM=1 : E = 1 : Endif
If E
# format incorrect
 GERR=1 : GMESSAGE = mess(149,100,1) : mkstat=2 : End
#Elsif L>LNG pas de verif en Xtend
# format trop long
# GERR=1 : GMESSAGE = mess(150,100,1) : mkstat=2 : End
Endif
End




