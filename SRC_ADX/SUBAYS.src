Subprog C_SCTSUBREP(VALEUR)
Variable Char    VALEUR()
Local Char RACINE(200),FILEPATH(250)
Local Integer WI
Local Char WLAN(GLONLAN) : 
If [M]DIRLAN=2
 WLAN= func SUBAYS.LANDEF([M]FCYCOD)
Endif
RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M]SCTROO) 
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>2     # pas un répertoire
 GERR=3 : GMESSAGE=mess(203,7900,1)-VALEUR        # GERR=3: avertissement GERR=2: message
Endif
End

Subprog S_SCTSUBREP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Integer WI
 Local Char WLAN(GLONLAN) : WLAN= func SUBAYS.LANDEF([M]FCYCOD)
  
 RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M]SCTROO) :  WVAL=RACINE+VALEUR
 # <=> Action SELFICREP  (TRT SELFICREP)
 Call SELREPREP(WVAL) From SELFICREP
 #
 WI=instr(0,WVAL,RACINE)
 If WI
    # Remove eventuel du dirsep en dernière position
    If right$(WVAL,len(WVAL))= func AYTGESFILE.GETPATH("","","DIRSEP","","","") : WVAL=left$(WVAL,len(WVAL)-1) : Endif
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(16,7900,1)-WVAL
 Endif 
Endif



End

