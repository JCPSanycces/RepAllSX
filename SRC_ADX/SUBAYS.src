End


######################################################################################
## Gestion partie HCE
######################################################################################


Subprog GES_HCE(FIETYP)
Value Integer FIETYP
If FIETYP=2 Then
    Effzo [M:AYS2]30
    Affzo [M:AYS2]30
    Grizo [M:AYS2]30
    Actzo [M:AYS2]HCEDEF
Else
    Actzo [M:AYS2]30
Endif

End

Subprog GES_SCRIPT(AFFZO_FLG, FIETYP)
Value Integer FIETYP
If FIETYP<>1        # FD: pas de menu local car double indication
    Actzo [M:AYS2] SCTSUBREP
Else
    Effzo [M:AYS2] SCTSUBREP : Grizo [M:AYS2] SCTSUBREP
Endif
#
If AFFZO_FLG : Affzo [M:AYS2] SCTSUBREP : Endif
End

Subprog GES_TIMESTAMP(FIETYP)
Value Integer FIETYP
If FIETYP=2 Then
    Effzo [M:AYS2]70
    Affzo [M:AYS2]70
    Grizo [M:AYS2]70
    Actzo [M:AYS2]CTSDEF
Else
    Actzo [M:AYS2]70
Endif

End


