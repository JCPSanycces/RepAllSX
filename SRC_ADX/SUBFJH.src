######################################################################################
## Etiquette ajoutée par le superviseur (écran FJH0) 27/07/2012 17:51:41 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End


