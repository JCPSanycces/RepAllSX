#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion objet FJH
#-------------------------------------------------------------------------------------------------
# SUBFJH : Gestion des paramétrages par flux métiers
#-------------------------------------------------------------------------------------------------
# (C) PROSPER 23/09/2010 : Permet de donner une liste de type d'interlocuteur pour un flux métier
#                          A enrichir par d'autres éléments de paramétrage liés au flux métier
#-------------------------------------------------------------------------------------------------

####################################
#
#  key ATEXTRA COD,LEG
#
#####################################

Call OBJET("FJH", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
 When "ANNULE"      : Gosub ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
Endcase
Return

########################################
# To delete translated texts (data type AX3 & AX1)
# SBA-114309
$ANNULE
 Call SUPTEXTRA("FLXJOB","DES",[L]CODE,SUPP) From ATEXTRA
Return
# SBA-114309
$AP_CHANGE
Call CHGTEXTRA("FLXJOB","DES",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:FJH]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:FJH0]LEG)>=0 : [M:FJH0]LEG=[F:FJH]LEG: Endif
 GCURLEG=[F:FJH]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:FJH0]LEG)>=0
  GCURLEG=[M:FJH0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return
# SBA-114309
$CREATION
Gosub WRITE_FJR
Gosub TEXTRA
Return
# SBA-114309
$MODIF
Gosub DELETE_FJR
Gosub WRITE_FJR
Gosub TEXTRA
Return
# SBA-114309
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("FLXJOB","DES",CLECUR1,"","FLXJOB","DES",[F:FJH]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"FLXJOB","DES",[F:FJH]COD,GCURLEG) From ATEXTRA

Return

$LIENS
GCURLEG = [F:FJH]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

# SBA-114309
Call LECTEXTRA([M]DES,"FLXJOB","DES",[M]COD,GCURLEG) From ATEXTRA

Raz [M:FJH1]
Raz nolign
For [F:FJR]FJR0 Where [F:FJR]COD = [M:FJH0]COD & [F:FJR]LEG = GCURLEG
&                    & [F:FJR]TYP = 1
    nolign += 1
    [M:FJH1] = [F:FJR]
Next
[M:FJH1]NBLIGRSP = nolign
Affzo [M:FJH1]
Return

$WRITE_FJR
For nolign = 1 To [M:FJH1]NBLIGRSP
    Raz [F:FJR]
    [F:FJR] = [M:FJH0]
    [F:FJR] = [M:FJH1]
    [F:FJR]LEG = GCURLEG
    [F:FJR]TYP = 1
    [F:FJR]NUMLIG = nolign
    Write [F:FJR]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("FJR") From GLOCK
        Break
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

$DELETE_FJR
Delete [F:FJR] Where [F:FJR]COD = [M:FJH0]COD & [F:FJR]LEG = GCURLEG
&                & [F:FJR]TYP = 1
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("FJH") From GLOCK
Endif
Return

