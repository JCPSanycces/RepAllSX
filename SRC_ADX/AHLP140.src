#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_SOURCE

GBIDC1 = ""
Call AIDE(GBIDC1)
End

Subprog HELP
If maskcou<>"" & zoncou<>""
 Local File AMSKZON [AMZ]
 Read [AMZ]CODE = maskcou;zoncou
 If [F:AMZ]MOTCLE<>""
  Call AIDE([F:AMZ]MOTCLE)
 Else
  Call MESSAGE(mess(169,124,1)) From GESECRAN : # Pas d'aide sur ce champ
 Endif
Endif
mkstat = 2
End

Subprog AIDE(MOTCLE)
Variable Char MOTCLE()

Local Integer SAVOBJET , REPONSE , ETABOU(1..GNBBOU)
Local Integer OK , SAVMXL , TUNNEL
Local Char    SAVPROG(10)
Local Char    CHEMIN(250) , FILTRE(250) , EXTENSION(10)

Gosub REPERT
CHEMIN    = REPERT + "/" : # Chemin où se trouve l'aide
EXTENSION = "rtf"
FILTRE    = "A*"

If MOTCLE<>"" : TUNNEL = 1 : Else : TUNNEL = 0 : Endif

Local File (MOT) From System "cd"-CHEMIN-";"-"ls" As [RTF]
Filter [RTF] Where pat(MOT,FILTRE+".rtf")
SAVMXL = adxmxl
adxmxl = GNBGAUCHE

SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME
Call SAVBOUT From GESECRAN

Local Mask AHLP [HLP] , AOBJTXTB [HLP2]
If TUNNEL
 Local Mesbox Mask [HLP]
& Button mess(64,123,1) , mess(65,123,1)
& With left$(mess(14,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(171,124,1)
& As [HLP]
Else
 Local Inpbox Mask [HLP]
& Button mess(64,123,1) , mess(65,123,1)
& With left$(mess(14,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(171,124,1)
& Leftbox [RTF] GAU_CHE
& [F:RTF]MOT Titled mess(172,124,1)
& As [HLP]
Endif

Boxact [HLP]
If !TUNNEL : Fillbox [HLP] : Endif
Onevent
Raz [M:HLP]
Affzo TEXTE
If MOTCLE<>""
 [M]MOTCLE = MOTCLE
 Gosub SET_TEXTE
 Affzo MOTCLE
Endif

$SAI
Gosub SETBOUT
Onevent AFTER_CHANGE Gosub APRES_MODIF
Boxinp [HLP] Using REPONSE
Onevent AFTER_CHANGE
Case REPONSE
 When GSTAOK:   Goto SAI
 When GSTASEL : Gosub SELECT
 When GSTALFT , GSTALF2 , GSTALF3 , GSTALF4 : Gosub GAUCHE
 When GSTAESC, GSTAFIN : Goto FIN
Endcase
Goto SAI

$SETBOUT
Raz ETABOU
If !TUNNEL : ETABOU(GSELE) = 1 : Endif
ETABOU(GVALI)=1 :         # OK
ETABOU(GABAN)=1 :         # ABANDON

ETABOU(GSUIV) = 0
Call SETBOUT(ETABOU) From GESECRAN
Return

$SELECT
[M:HLP2]MODELE = FILTRE
Call SELHLP(OK,"") From AHLP
If OK=2
 FILTRE = [M:HLP2]MODELE
 Close Local File [RTF]
 Local File (MOT(30)) From System "cd"-CHEMIN-";"-"ls" As [RTF]
 Filter [RTF] Where pat(MOT,FILTRE+".rtf")
 Fillbox [HLP]
Endif
Return

$GAUCHE
K = instr(1,[F:RTF]MOT,"."+EXTENSION)
If K
 [M]MOTCLE = left$([F:RTF]MOT,K-1)
Else
 [M]MOTCLE = [F:RFT]MOT
Endif
Gosub LECTURE
zonsui = "GAU_CHE"
Return

$LECTURE
Affzo MOTCLE
Gosub SET_TEXTE
Return

$FIN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG
adxmxl     = SAVMXL
If [M]MOTCLE<>""
 MOTCLE = [M]MOTCLE
Endif
Boxclr [HLP]
Call RESTBOUT From GESECRAN
End

$APRES_MODIF
If zoncou="MOTCLE"
 [M]MOTCLE = zc
 Gosub SET_TEXTE
Endif
Return

$SET_TEXTE
[M]TEXTE = CHEMIN+[M]MOTCLE+"."+EXTENSION
Affzo TEXTE
Return

Subprog SELHLP(OK,TIT)
Variable Integer OK
Value    Char    TIT
Local Mesbox Mask [HLP2]
& Button mess(64,123,1),mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled TIT
& As [HLP2]
Local Integer REPONSE, ETABOU(1..GNBBOU) , SAVGOBJET
SAVGOBJET = GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
Boxact [HLP2] 
Affzo [HLP2] 
ETABOU(GVALI) = 1 : # OK
ETABOU(GABAN) = 1 : # Fin
Call SETBOUT(ETABOU) From GESECRAN
Boxinp [HLP2] Using REPONSE 
Case REPONSE
 When GSTAOK  , GSTARET : OK = 2
 When GSTAESC , GSTAFIN : OK = 1
 When Default           : OK = 1
Endcase
Boxclr [HLP2]
Call RESTBOUT From GESECRAN
GOBJET = SAVGOBJET
End

####################################################################
$REPERT
Local Char REPERT(30)
Local Char MACHINE(40)
If adxmac(0)=""
 MACHINE = toupper(adxmac(-1))
Else
 MACHINE = toupper(adxmac(0))
Endif
If instr(1,MACHINE,"ROTULE") : # à revoir plus tard 
 REPERT = "/adx/x3/rtf/"+GLANGUE
Else
 REPERT = "/home1/adonix/rtf/V140"

Endif
Return

Subprog S_MOTCLE(VALEUR)
Variable Char VALEUR()
If GADONIX=2 : # C'est que pour nous!! na!!
 Gosub REPERT
 Local File (NOMFIC) From System "ls"-REPERT-"*.rtf" As [AFF] 
 Choose [AFF]  
&  Where NOMFIC>=left$(VALEUR,2)
&  Using NOMFIC Titled "Nom des fichiers"
&  Sized(80,240)   
&  Starting At NOMFIC>=VALEUR   
&  Titled "Sélection des textes d'aides"
 If status<>0 & status<>7 
  VALEUR = left$([F:AFF]NOMFIC,instr(1,[F:AFF]NOMFIC,".rtf")-1) 
 Endif
Endif
mkstat = 2
End

Subprog C_MOTCLE(VALEUR)
Variable Char VALEUR()
# Pour l'instant on ne contrôle plus rien
End





