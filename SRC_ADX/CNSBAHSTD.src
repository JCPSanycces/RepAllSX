   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMHDU<'+num$(HDUF)+')'+
&        'or ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM<"'+VCRF+'")'+
&        'or ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP<"'+TYPF+'")'+
&        'or  [HDU]DUDDAT<['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When -2 : # Retour
   If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU>'+num$(HDUD)+')'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATD)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU>'+num$(HDUD)+')'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:HDU]DUDDAT>['+format$(GFMD,DUDDATD)+'])'," & ") From GOBJSUB
   Endif
 Endcase
Return

############################################
$DEVISE
If dim([M:BAH2]ACCCUR2)>0
 [M:BAH2]ACCCUR2=[M:BAH1]ACCCUR
 Affzo [M:BAH2]ACCCUR2
Endif
Return


############################################
# Détermination Si Groupes de sites (GRP=1) / Société (GRP=0) / Toutes sociétés confondues (GRP=-1)
$INIT
GRP=-1
Raz TSITE
If [M:BAH1]CPY<>""
 Call LECTURE("CPY",[M:BAH1]CPY,"") From CONTOBJ
 GRP=([F:CPY]CPYLEGFLG<>2)
 If !GRP
  #-- Société juridique
  [M:BAH1]ACCCUR = [F:CPY]ACCCUR
 Else
  #-- Société non juridique
  NBSITE = 0 : NBSOC=0
  For [FGR]FGR0 Where CPY = [M:BAH1]CPY
   NBSITE+=1
   TSITE(NBSITE) = [F:FGR]FCY
   Call LECTURE("FCY",TSITE(NBSITE),"") From CONTOBJ
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   If find([F:CPY]CPY,TBSOC(1..NBSOC))=0
    NBSOC+=1
    TBSOC(NBSOC)   = [F:CPY]CPY
    TDEVSOC(NBSOC) = [F:CPY]ACCCUR
   Endif
  Next : # [FGR]

  [M:BAH1]ACCCUR = TDEVSOC(1)
  If [M:BAH1]ACCCUR=""
   [M:BAH1]ACCCUR = GCURSHR
  Else
   For I=2 To NBSOC
    If TDEVSOC(1)<>TDEVSOC(I) : [M:BAH1]ACCCUR = GCURSHR : Break : Endif
   Next I
  Endif
 Endif
Else
 [M:BAH1]ACCCUR = GCURSHR
Endif
Return

############################################
# Lecture des reglements
$LECT_REGL
Filter [PYD] Where DUDNUM=[F:HDU]ACCNUM & DUDLIG=[F:HDU]DUDLIG
&            Order By Key CLE=DUDNUM;DUDLIG
Read [F:PYD]CLE First
If fstat = 0
 [M:BAH2]REG (nolign-1) = [F:PYD]NUM
Endif
Filter [PYD]
Return

###############################################################################
##              Etiquettes masque CONSBAH2                                  ##
###############################################################################
Subprog IB_NBLIG
Gosub SETNOL From TRTZOMBAG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
mkstat = 0
If NOL>=[M:BAH2]NBLIG | [M:BAH2]NBLIG=0 : End : Endif
If [M:BAH2]ACCNUM(NOL)<>0
    GBOUT1 = mess(53,117,1) :#"Document origine"
Endif
If [M:BAH2]TYP(NOL)="" or [M:BAH2]NUM(NOL)=""  : End : Endif
## Bouton 2 : Zoom sur la facture
Read [F:SIH]SIH2 = [M:BAH2]TYP(NOL);[M:BAH2]NUM(NOL)
If !fstat
    Case [F:SIH]ORIMOD
        When 3 : GBOUT2 = mess(43,109,1) : # Facture tiers client
        When 5 : GBOUT2 = mess(45,109,1) : # Facture vente
    Endcase
Elsif fstat=5
    Read [F:PIH]PIH2 = [M:BAH2]TYP(NOL);[M:BAH2]NUM(NOL)
    If !fstat
        Case [F:PIH]ORIMOD
            When 3 : GBOUT2 = mess(44,109,1) : # Facture tiers fournisseur
            When 6 : GBOUT2 = mess(46,109,1) : # Facture achat
        Endcase
    Endif
Endif
## Bouton 3 : Zoom sur pièce
Read [F:HAE] = [M:BAH2]TYP(NOL);[M:BAH2]NUM(NOL)
If !fstat
  GBOUT3 = mess(18,109,1) : #  Pièce
Endif
## Bouton 4 : Zoom sur réglement
Read [PYH]PYH0 = [M]REG(NOL)
If !fstat
    GBOUT4 = mess(47,109,1) : # Règlement
Endif
End

Subprog B1_NBLIG
Gosub SETNOL From TRTZOMBAG
If find([M:BAH2]TYP(NOL),"",GDIV(0),GDIV(1)) : End : Endif
Read [F:HAE]HAE0=[M:BAH2]TYP(NOL);[M:BAH2]NUM(NOL)
If fstat | [F:HAE]BPRVCR="" : End : Endif
# "Document origine"
GERR = 2
GMESSAGE = mess(53,117,1)-":"-num$([F:HAE]BPRVCR)
End


###############################################################################
##              Etiquettes masque CONSBAH1                                  ##
###############################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call AM_CPY(VALEUR) From CNSBAGSTD
Call LECPLAN(VALEUR,GTYPGEN,[M:BAH1]COA) From CPTDIV
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CNSBAGSTD
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call AM_FCY(VALEUR) From CNSBAGSTD
Call LECPLAN([M:BAH1]CPY,GTYPGEN,[M:BAH1]COA) From CPTDIV
End

Subprog AM_FNCCNT(VALEUR)
Variable Integer VALEUR
Call AM_FNCCNT(VALEUR) From CNSBAGSTD
End

Subprog C_COLLEC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]GROUPE
 Affzo GROUPE
 Read [GAC]GAC1 = [M]COA;VALEUR
 If [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   ## Vous n'avez pas les droits pour ce code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_GROUPE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]COLLEC
 Affzo [M]COLLEC
 Call LECTURE("GSC",VALEUR,"") From CONTOBJ
 For [GSC]GSC0 Where COA=[M]COA & GRU=VALEUR
  Read [GAC]GAC1 = [M]COA;[F:GSC]SAC
  If !fstat & [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT
    # Vous n'avez pas les droits pour ce code
    GMESSAGE = mess(4,104,1)-" : "-[F:GSC]SAC
    mkstat = 2 : Break
   Endif
  Endif
 Next
 If mkstat : End : Endif
Endif
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Call C_BPR(VALEUR) From CNSBAGSTD
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
Call AM_BPR(VALEUR) From CNSBAGSTD
End


######################################################################################

