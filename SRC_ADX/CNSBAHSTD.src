#<AdxTL>@(#)1.0.0.0 $Revision$ Consultation BAH
#######################################################
Raz GTUNCPT
Local Char PARAM(10)(1..7)
PARAM(1)="1"
PARAM(2)="DEL011"
PARAM(3)="C1"
PARAM(4)="ASN"
PARAM(6)=date$
PARAM(7)="2"     :#Balance âgée historisée
Call GCONSULT("BAH","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AFF_LIB
 When "SETBOUT"    : Gosub SETBOUT From CNSBAGSTD
 When "CLECUR"     : If !CLECUR & [M:BAH1]BPR<>"" : CLECUR=1 : Endif

 When "AV_MAGNETO" : Gosub AV_MAGNETO From CNSBAGSTD
 When "AP_MAGNETO" : Gosub AP_MAGNETO From CNSBAGSTD
 When "AP_CHOIX2"  : Gosub AP_CHOIX2  From CNSBAGSTD
 When "DEB_CRIT"   : Gosub DEB_CRIT   From CNSBAGSTD

 When "FERME"      : Gosub FERME From CNSBAGSTD
Endcase
Return

############################################
$OUVRE
Gosub OUVRE From CNSBAGSTD
Local Char TEMP(15)
Local Integer X, NBRCLE
Local Char SVGSAC(GLONSAC),SVGBPR(GLONBPR),SVGPAY(GLONBPR),SVG_FLGEVT
Local Char SACCUR(GLONSAC),GSCCUR(GLONGSC)
Local Integer COL1CUR,COL2CUR,COL3CUR,COL4CUR,COL5CUR,COL6CUR,COL7CUR,COL8CUR
Return

############################################
$AUTORIS
If clalev([F:LED]) = 0 : Local File GLED     [LED] : Endif
If clalev([F:GAC]) = 0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY  [CPY] : Endif
Local Char WCOA(GLONCOA)

Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(14)
If GTUNCPT(14)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une même fonction ne peut pas être appelée deux fois !
Else
 GTUNCPT(14) = 1
Endif

MEMO="bah"
If PARAM(1)="2" : MEMO="bh2" : Endif

If PARAM(3)<>"" : # : # Collectif renseigné
 If PARAM(4)<>"" | PARAM(5)<>""
  If PARAM(5)=""
   Call LECTURE("FCY",PARAM(4),"") From CONTOBJ
   PARAM(5)=[F:FCY]LEGCPY
  Endif
  If PARAM(4)<>""
   Call GETSOC(PARAM(4)) From DEVSUB
  Else
   Call LEC_CPY(PARAM(5)) From CPTLEC
   Call GETSOC([F:CPY]MAIFCY) From DEVSUB
  Endif
  Call LECPLAN(PARAM(5),GTYPGEN,WCOA) From CPTDIV
  Read [GAC]GAC1 = WCOA;PARAM(1)
  If !fstat & [F:GAC]SAC=2 & [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : Call MESSAGE(mess(4,104,1)) From GESECRAN : OK=0  :  Endif   # "Vous n'avez pas les droits pour ce code"
  Endif
 Endif
Endif
Return

############################################
#Gestion des libellés de colonne suivant les intervalles choisies et de ceux des totaux.
$AFF_LIB
Local Char ZLIB(20)
Gosub SET_ECRAN
#libellés des colonnes
Raz [M:BAH2]LIB
For I=1 To NBCOL
 If I=1
  [M:BAH2]LIB(I-1)= ">=" - num$(evalue("[M:CBAG]COL"+num$(I)))-mess(38,104,1)
 Elsif I<NBCOL
  [M:BAH2]LIB(I-1)= num$(evalue("[M:CBAG]COL"+num$(I))) -tolower(mess(41,101,1))- num$(evalue("[M:CBAG]COL"+num$(I-1))-1)-mess(38,104,1) #MH 07/08/15 Changed -"/"- to -tolower(mess(41,101,1))-
 Else
  [M:BAH2]LIB(I-1)= "<" - num$(evalue("[M:CBAG]COL"+num$(I-1)))-mess(38,104,1)
 Endif
 #libellés des totaux
 If dim([M:BAH2]AMTTOTLOC)>0 & I<8
  ZLIB="[M:BAH2]LIBTOT"+num$(I)
  #Cadrage à droite mais bon c'est pas génial !!!
  If len([M:BAH2]LIB(I-1))<15
   [M:BAH2]LIB(I-1)=space$(15-len([M:BAH2]LIB(I-1)))+[M:BAH2]LIB(I-1)
  Endif
  Assign ZLIB With [M:BAH2]LIB(I-1)
 Endif
Next
If dim([M:BAH2]AMTTOTLOC)>0 & NBCOL>7
 [M:BAH2]LIBTOT7 = "<"-num$([M:CBAG]COL6)-mess(38,104,1)
Endif
If dim([M:BAH2]AMTTOTLOC)>0
 [M:BAH2]LIBTOTLOC = mess(155,121,1)
Endif
Affzo [M:BAH2]
Return

############################################
#Récupération du nombre d'intervalles à utiliser en fonction de l'écran de consultation choisi
$SET_ECRAN
If [M:CBAG]ECRAN=""
 Read [GBS]GBS0=2;"STD" :#écran par défaut
 If fstat
  Read [GBS]GBS0 First
 Endif
 If fstat=0
   NBCOL=[F:GBS]NBRINT+1
  [M:CBAG]ECRAN=[F:GBS]COD
 Endif
Else
 Read [GBS]GBS0=2;[M:CBAG]ECRAN
 If fstat=0
  NBCOL=[F:GBS]NBRINT+1
 Endif
Endif
Effzo [M:CBAG]FLGDUD2 : Grizo [M:CBAG]FLGDUD2
Return

############################################
#Affectation des zones par les paramètres
$DEFCRIT
Default Mask [BAH1]

If [M:BAH1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:BAH1]FCY,GUSRFCY(1..GNBAUZ))
 [M:BAH1]FCY=""
Endif
For I=1 To dim(PARAM)
 Case I
  When 1 :
   If val(PARAM(I))=2
    [M:BAH1]CLIFOUR="F"
    [M:BAH1]OBJ="BPS"
   Else
    [M:BAH1]CLIFOUR="C"
    [M:BAH1]OBJ="BPC"
   Endif
  When 2 : # Tiers risque
   If PARAM(I)<>""
    Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAH1]BPR = PARAM(I)
     Call AFFCNT ([M:BAH1]BPR,"") From CNSBAGSTD
    Endif
   Endif
  When 3 : # Collectif
   If PARAM(I)<>""  & [M:BAH1]COA<>""
    Read [GAC]GAC0 = [M:BAH1]COA;PARAM(I)
    If !fstat & [F:GAC]SAC=2
     [M:BAH1]COLLEC = PARAM(I) : [M:BAH1]GROUPE = ""
    Endif
   Endif
  When 4 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BAH1]FCY = PARAM(I)
     [M:BAH1]CPY = [F:FCY]LEGCPY
     PARAM(4)= [M:BAH1]CPY    :#Evite de mettre GDEFSOC dans CPY si FCY<>""
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     If !fstat : [M:BAH1]ACCCUR = [F:CPY]ACCCUR : Endif
    Endif
   Endif
  When 5 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAH1]CPY = PARAM(I)
     [M:BAH1]ACCCUR = [F:CPY]ACCCUR
     If [M:BAH1]FCY<>""
      Call LECTURE("FCY",[M:BAH1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BAH1]CPY : [M:BAH1]FCY="" : Endif
     Endif
    Else
     Call LECTURE("CPY",GDEFSOC,"") From CONTOBJ
     If !fstat
      [M:BAH1]CPY = GDEFSOC
      [M:BAH1]ACCCUR = GDEVSOC
     Endif
    Endif
   Endif
  When 6 : # Date
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BAH1]DAT = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:BAH1]DAT = PARAM(I)
    Endif
   Endif
  When 7 : # type de balance âgée
    If PARAM(I)=""
     [M:BAH1]CNSOPT="1"
    Else
     [M:BAH1]CNSOPT=PARAM(I)
    Endif
  Endcase
Next I
If [M:BAH1]FCY="" & [M:BAH1]CPY="" & (GUSRFCY="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
 [M:BAH1]FCY = GFCYDEF
 Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
 [M:BAH1]CPY = [F:FCY]LEGCPY
Endif
If [M:BAH1]CPY="" : [M:BAH1]CPY = GDEFSOC : Endif
Call GETSOC([M:BAH1]CPY) From DEVSUB
Call LECPLAN([M:BAH1]CPY,GTYPGEN,[M:BAH1]COA) From CPTDIV
If PARAM(3)<>"" & [M:BAH1]COA<>""
 Read [GAC]GAC1 = [M:BAH1]COA;PARAM(3)
 If !fstat & [F:GAC]SAC=2 : [M:BAH1]COLLEC = PARAM(3) : Else Raz [M:BAH1]COLLEC : Endif
Endif
If [M:BAH1]DAT=[0/0/0] : [M:BAH1]DAT=date$ : Endif

Default Mask [BAH1]
Gosub CRITENT From =PROGCNS
Return

############################################
#Chargement du tableau
$LECTURE
Gosub AFF_LIB    :#Obliger de le faire ici car dans $OUVRE c'est trop tôt...
Gosub DEVISE

If  [M:BAH1]BPR="" : NBLU=0 : Return : Endif

Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

# La consultation de la balance âgée passe par $CHERCHE_ECH pour stocker les échéances à afficher
# Parcours de HISTODUD pour lire et évaluer les échéances à afficher.
# Si le bloc totaux est demandé dans la consultation, les totaux sont indépendants de la taille de l'écran/pagination.
# Par conséquent, les variables de travails doivent être dimentionnées à un maximum...
#  - 1er appel à CHERCHE_ECH permet d'afficher les échéances => boucle sur la taille de l'écran
#  - 2ème appel à CHERCHE_ECH permet le calcul des totaux => boucle sur totues les échances.
#
# Variable MAXLIG = Variable de GCONSULT = taille de l'écran.
Local Integer MAXTOTLIN, SVGMAXLIG
SVGMAXLIG = MAXLIG
MAXTOTLIN = max(9999,MAXLIG)
Local Char TABACC(15)(0..[L]MAXTOTLIN)
Local Integer TABCLE(0..[L]MAXTOTLIN)

Gosub INIT
Gosub DEVISE

# Filtres
Gosub FILTRE
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# Parcours de page en page
If CHGPAG>0 # Page suivante
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else         # Page précédente
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:BAH2]5 : Endif

# Ordre (choix dans la fenêtre de critère)
If [M:CBAG]ORDDUD=2 #Desc
 If CHGPAG>0    :# Page suivante
  If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
   ORDRE = "[HAE]ACCDAT Desc;[HAE]TYP Desc;[HAE]NUM Desc;[HDU]NUMHDU Desc"
  Else
   ORDRE = "[HDU]DUDDAT Desc;[HAE]TYP Desc;[HAE]NUM Desc;[HDU]NUMHDU Desc"
  Endif
 Else           :# Page précédente
  If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
   ORDRE = "[HAE]ACCDAT;[HAE]TYP;[HAE]NUM;[HDU]NUMHDU"
  Else
   ORDRE = "[HDU]DUDDAT;[HAE]TYP;[HAE]NUM;[HDU]NUMHDU"
  Endif
 Endif
Else
 If CHGPAG>0   :# Page suivante
  If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
   ORDRE = "[HAE]ACCDAT;[HAE]TYP;[HAE]NUM;[HDU]NUMHDU"
  Else
   ORDRE = "[HDU]DUDDAT;[HAE]TYP;[HAE]NUM;[HDU]NUMHDU"
  Endif
 Else          :# Page précédente
  If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
   ORDRE = "[HAE]ACCDAT Desc;[HAE]TYP Desc;[HAE]NUM Desc;[HDU]NUMHDU Desc"
  Else
   ORDRE = "[HDU]DUDDAT Desc;[HAE]TYP Desc;[HAE]NUM Desc;[HDU]NUMHDU Desc"
  Endif
 Endif
Endif

Case [M:BAH1]CLIFOUR
 When "F" :
   Link [HDU] With [HAE]HAE0=[HDU]TYP;[HDU]NUM , [F:BPS]BPS0=[F:HDU]BPR As [LNK]
&  Order With [L]ORDRE
   Columns [HDU] ([F:HDU],[F:HAE]ACCDAT,[F:HAE]TYP,[F:HAE]NUM,[F:HAE]BPRVCR,[F:HAE]BPRDATVCR)
 When "C" :
   Link [HDU] With [HAE]HAE0=[HDU]TYP;[HDU]NUM , [F:BPC]BPC0=[F:HDU]BPR As [LNK]
&  Order With [L]ORDRE
   Columns [HDU] ([F:HDU],[F:HAE]ACCDAT,[F:HAE]TYP,[F:HAE]NUM,[F:HAE]BPRVCR,[F:HAE]BPRDATVCR)
Endcase

Gosub CHERCHE_ECH
For X=0 To NBRCLE-1
 For [F:LNK] Where [F:HDU]NUMHDU=TABCLE(X)
  If NBLU=1
   If CHGPAG=2 or CHGPAG=-2 : Effzo [M:BAH2]5 : Endif
   NBLU=2
  Endif
  If CHGPAG>0
   If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
   NOL += 1
   If NOL = 0
    DUDDATD = [F:HDU]DUDDAT
    ACCDATD = [F:HAE]ACCDAT
    HDUD    = [F:HDU]NUMHDU
    TYPD    = [F:HAE]TYP
    VCRD    = [F:HAE]NUM
   Endif
   DUDDATF = [F:HDU]DUDDAT
   ACCDATF = [F:HAE]ACCDAT
   HDUF    = [F:HDU]NUMHDU
   TYPF    = [F:HAE]TYP
   VCRF    = [F:HAE]NUM
  Else
   If NOL<=0 : RETOUR=2 : Break : Endif
   NOL -= 1
   If NOL = MAXLIG-1 :
    DUDDATF = [F:HDU]DUDDAT
    ACCDATF = [F:HAE]ACCDAT
    HDUF    = [F:HDU]NUMHDU
    TYPF    = [F:HAE]TYP
    VCRF    = [F:HAE]NUM
   Endif
   DUDDATD = [F:HDU]DUDDAT
   ACCDATD = [F:HAE]ACCDAT
   HDUD    = [F:HDU]NUMHDU
   TYPD    = [F:HAE]TYP
   VCRD    = [F:HAE]NUM
  Endif
  nolign=NOL+1
  [M:BAH2]=[F:HAE]
  [M:BAH2]=[F:HDU]
  Case [M:BAH1]CLIFOUR
   When "F" :
   [M:BAH2]BPRRSK(NOL)=[F:BPS]BPSRSK
   [M:BAH2]BPRGRU(NOL)=[F:BPS]BPSGRU
   When "C"
   [M:BAH2]BPRRSK(NOL)=[F:BPC]BPCRSK
   [M:BAH2]BPRGRU(NOL)=[F:BPC]BPCGRU
  Endcase
  If dim([M:BAH2]REG)>0
   Gosub LECT_REGL
  Endif
  Gosub MTT_CUR
  Gosub MTT_LOC
 Next
Next
# Re-calcul des totaux et du risque si besoin...
If BPRCUR<>[M:BAH1]BPR | BPRPAYCUR<>[M:BAH1]BPRPAY | CPYCUR<>[M:BAH1]CPY | FCYCUR<>[M:BAH1]FCY |  DATCUR<>[M:BAH1]DAT |
&  SACCUR<>[M:BAH1]COLLEC | GSCCUR<>[M:BAH1]GROUPE | ECRCUR<>[M:CBAG]ECRAN  |
&  COL1CUR<>[M:CBAG]COL1 | COL2CUR<>[M:CBAG]COL2 | COL3CUR<>[M:CBAG]COL3 | COL4CUR<>[M:CBAG]COL4 |
&  COL5CUR<>[M:CBAG]COL5 | COL6CUR<>[M:CBAG]COL6 | COL7CUR<>[M:CBAG]COL7 | COL8CUR<>[M:CBAG]COL8
 If dim([M:BAH2]AMTTOTLOC)>0 | GMODIF=1
  Gosub TOTAL : GMODIF=0
 Endif
Endif

BPRCUR    = [M:BAH1]BPR
BPRPAYCUR = [M:BAH1]BPRPAY
FCYCUR    = [M:BAH1]FCY
CPYCUR    = [M:BAH1]CPY
DATCUR    = [M:BAH1]DAT
SACCUR    = [M:BAH1]COLLEC
GSCCUR    = [M:BAH1]GROUPE
ECRCUR    = [M:CBAG]ECRAN
COL1CUR   = [M:CBAG]COL1
COL2CUR   = [M:CBAG]COL2
COL3CUR   = [M:CBAG]COL3
COL4CUR   = [M:CBAG]COL4
COL5CUR   = [M:CBAG]COL5
COL6CUR   = [M:CBAG]COL6
COL7CUR   = [M:CBAG]COL7
COL8CUR   = [M:CBAG]COL8
Return

############################################
#Recherche des échéances concernées
$CHERCHE_ECH
NBRCLE=0
Raz TABACC
Raz TABCLE

Filter [F:LNK] Where evalue (FILTBAG) & evalue(FILTPAG)

For [F:LNK]
 If NBRCLE>MAXLIG : Break : Endif
 OK=1
 If NBRCLE>0
  Raz OK
  TEMP=num$([F:HDU]ACCNUM)+num$([F:HDU]DUDLIG)
  If !find(TEMP,TABACC(0..NBRCLE-1)) : OK=1 : Endif
 Endif
 If OK
  Raz OK
  [L]SVGSAC = [F:HDU]SAC
  [L]SVGBPR = [F:HDU]BPR
  [L]SVGPAY = [F:HDU]BPRPAY
  Filter [HDU2] Where ACCNUM=[HDU]ACCNUM & DUDLIG=[HDU]DUDLIG & (DATEVT<>[0/0/0] | FLGCLE=3)
  For [HDU2]HDU3
   # Echéances validées... 1ère étape
   If !OK & ([F:HDU2]FLGCLE=1 or [F:HDU2]FLGCLE=4) & [F:HDU2]DUDSTA=2 & [F:HDU2]DATEVT<=[M:BAH1]DAT & SVG_FLGEVT=""
    If [F:HDU2]SAC=[L]SVGSAC & [F:HDU2]BPR=[L]SVGBPR & [F:HDU2]BPRPAY=[L]SVGPAY
     Raz X
     TEMP=num$([F:HDU2]ACCNUM)+num$([F:HDU2]DUDLIG)
     If NBRCLE>0 : X=find(TEMP,TABACC(0..NBRCLE-1)) :  Endif
     If !X
      TABACC(NBRCLE)=TEMP
      TABCLE(NBRCLE)=[F:HDU2]NUMHDU
      NBRCLE+=1 : OK = 1
     Endif
    Endif
   Elsif OK
    # Echéances annulées (annulation comptable ou suppression réel)
    If [F:HDU2]DUDSTA<>2 or [F:HDU2]FLGCLE=3
     NBRCLE-=1   : Raz OK
    # Echéances annulation comptable avec changement d'"entête"
    Elsif ([F:HDU2]SAC<>[L]SVGSAC or [F:HDU2]BPR<>[L]SVGBPR or  [F:HDU2]BPRPAY<>[L]SVGPAY) and [F:HDU2]DATEVT<=[M:BAH1]DAT
     NBRCLE-=1   : Raz OK
    # Echéances soldées (déjà réglées)
    Elsif [F:HDU2]FLGCLE=2 and [F:HDU2]DATEVT<=[M:BAH1]DAT
     NBRCLE-=1   : Raz OK
     # Modification d'échéances avant règlements
    Else
     If [F:HDU2]DATEVT<=[M:BAH1]DAT
      If SVG_FLGEVT="" | (SVG_FLGEVT<>"" & [F:HDU2]TMPCUR=0)
       TEMP=num$([F:HDU2]ACCNUM)+num$([F:HDU2]DUDLIG)
       X=find(TEMP,TABACC(0..NBRCLE-1))
       If X>0 :  TABCLE(X-1)=[F:HDU2]NUMHDU  :  Endif
      Else
       Raz SVG_FLGEVT
      Endif
     Else
      SVG_FLGEVT = [F:HDU2]FLGEVT
     Endif
    Endif
   Else
    SVG_FLGEVT = [F:HDU2]FLGEVT
   Endif
  Next
 Endif
 Filter [HDU2]
Next
Filter [F:LNK]
Return

############################################
#Ligne en devise courante
$MTT_CUR
Local Integer NBJ
Local Char ZONE (200)
NBJ = [M:BAH1]DAT - [M:BAH2]DUDDAT(nolign-1)
For I=1 To NBCOL
 If I=1
  If NBJ>=[M:CBAG]COL1
  [M:BAH2]AMTCUR1(nolign-1) = ([M:BAH2]AMTCUR(nolign-1)-[M:BAH2]PAYCUR(nolign-1))*[M:BAH2]SNS(nolign-1)
  Break : Return
  Endif
 Elsif I<NBCOL
  If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
   ZONE="[M:BAH2]AMTCUR"+num$(I)+"(nolign-1)"
   Assign ZONE With ([M:BAH2]AMTCUR(nolign-1)-[M:BAH2]PAYCUR(nolign-1))*[M:BAH2]SNS(nolign-1)
   Break : Return
  Endif
 Else
  ZONE="[M:BAH2]AMTCUR"+num$(NBCOL)+"(nolign-1)"
  Assign ZONE With ([M:BAH2]AMTCUR(nolign-1)-[M:BAH2]PAYCUR(nolign-1))*[M:BAH2]SNS(nolign-1)
  Break : Return
 Endif
Next
[M:BAH2]AMTCUR(nolign-1) = ([F:HDU]AMTCUR-[F:HDU]PAYCUR)*[F:HDU]SNS
Return

############################################
#Ligne en devise locale
$MTT_LOC
Local Integer NBJ
Local Char ZONE (200)
NBJ = [M:BAH1]DAT - [M:BAH2]DUDDAT(nolign-1)
For I=1 To NBCOL
 If I=1
  If NBJ>=[M:CBAG]COL1
  [M:BAH2]AMTLOC1(nolign-1) = ([M:BAH2]AMTLOC(nolign-1)-[M:BAH2]PAYLOC(nolign-1))*[M:BAH2]SNS(nolign-1)
  Break : Return
  Endif
 Elsif I<NBCOL
  If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
   ZONE="[M:BAH2]AMTLOC"+num$(I)+"(nolign-1)"
   Assign ZONE With ([M:BAH2]AMTLOC(nolign-1)-[M:BAH2]PAYLOC(nolign-1))*[M:BAH2]SNS(nolign-1)
   Break : Return
  Endif
 Else
  ZONE="[M:BAH2]AMTLOC"+num$(NBCOL)+"(nolign-1)"
  Assign ZONE With ([M:BAH2]AMTLOC(nolign-1)-[M:BAH2]PAYLOC(nolign-1))*[M:BAH2]SNS(nolign-1)
  Break : Return
 Endif
Next
[M:BAH2]AMTLOC(nolign-1) = ([F:HDU]AMTLOC-[F:HDU]PAYLOC)*[F:HDU]SNS
Return

############################################
#Affectation des totaux en bas d'écran toujours en devise locale
$TOTAL
Local Integer NBJ
Local Char TEMPO (3)
Local Decimal MTT
#Remise à zéro des totaux (7 totaux max dans l'écran)
For I=1 To 7
 ZONE="[M:BAH2]AMTTOT"+num$(I)
 Assign ZONE With 0
Next
[M:BAH2]AMTTOTLOC=0
FILTPAG="1=1"
MAXLIG = [L]MAXTOTLIN
Gosub CHERCHE_ECH
MAXLIG = SVGMAXLIG
For X=0 To NBRCLE-1
 For [F:LNK] Where [F:HDU]NUMHDU=TABCLE(X)
  MTT=([F:HDU]AMTLOC-[F:HDU]PAYLOC)*[F:HDU]SNS
  NBJ = [M:BAH1]DAT - [F:HDU]DUDDAT
  For I=1 To NBCOL
   If I=1
    If NBJ>=[M:CBAG]COL1
     [M:BAH2]AMTTOT1 += MTT
     Break
    Endif
   Elsif I<NBCOL & I<7
    If NBJ>=evalue("[M:CBAG]COL"+num$(I)) & NBJ<evalue("[M:CBAG]COL"+num$(I-1))
     ZONE="[M:BAH2]AMTTOT"+num$(I)
     Assign ZONE With (evalue(ZONE)+MTT)
     Break
    Endif
   Elsif I=NBCOL & I<=7
    ZONE="[M:BAH2]AMTTOT"+num$(NBCOL)
    Assign ZONE With (evalue(ZONE)+MTT)
    Break
   Else
    [M:BAH2]AMTTOT7 += MTT
    Break
   Endif
  Next
  [M:BAH2]AMTTOTLOC+=MTT
 Next
Next
If [M:BAH2]AMTTOTLOC<>0
 [M:BAH2]PER1 = arr([M:BAH2]AMTTOT1 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER2 = arr([M:BAH2]AMTTOT2 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER3 = arr([M:BAH2]AMTTOT3 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER4 = arr([M:BAH2]AMTTOT4 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER5 = arr([M:BAH2]AMTTOT5 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER6 = arr([M:BAH2]AMTTOT6 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
 [M:BAH2]PER7 = arr([M:BAH2]AMTTOT7 / [M:BAH2]AMTTOTLOC  * 100 ,0.1)
Else
 Raz [M:BAH2]PER1
 Raz [M:BAH2]PER2
 Raz [M:BAH2]PER3
 Raz [M:BAH2]PER4
 Raz [M:BAH2]PER5
 Raz [M:BAH2]PER6
 Raz [M:BAH2]PER7
Endif
Return

############################################
#Création de critère de selection
############################################
$FILTRE
Raz FILTBAG, IFILT

# Date
Call ADDCRIT(FILTBAG,IFILT,"DATEVT",'[F:HDU]DATEVT<=['+num$([M:BAH1]DAT)+']'," & ") From GOBJSUB

# Collectif et groupe de collectif
If [M:BAH1]COLLEC<>""
  Call ADDCRIT(FILTBAG, IFILT,"COLLEC",'[F:HDU]SAC="'+[M:BAH1]COLLEC+'"'," & ") From GOBJSUB
Elsif [M:BAH1]GROUPE<>""
  Call ADDCRIT(FILTBAG, IFILT,"COLLEC",'find([F:HDU]SAC',"&") From GOBJSUB
  Filter [GSC] Where [F:GSC]COA=[M]COA & [F:GSC]GRU=[M:BAH1]GROUPE
  For [GSC]
    Call ADDCRIT(FILTBAG, IFILT,"GROUPE",'"'+[F:GSC]SAC+'"',",") From GOBJSUB
  Next
  Filter [GSC]
  Call ADDCRIT(FILTBAG, IFILT,"GROUPE",')',"") From GOBJSUB
Endif

# Tiers
Call ADDCRIT(FILTBAG,IFILT,"BPR",'[F:HDU]BPR="'+[M:BAH1]BPR+'"'," & ") From GOBJSUB
If [M:BAH1]BPRPAY<>""
 Call ADDCRIT(FILTBAG,IFILT,"BPRPAY",'[F:HDU]BPRPAY="'+[M:BAH1]BPRPAY+'"'," & ") From GOBJSUB
Endif

# Société & Site
Case GRP
 When 0 :
  # Société juridique
  Call ADDCRIT(FILTBAG,IFILT,"CPY",'[F:HDU]CPY="'+[M:BAH1]CPY+'"'," & ") From GOBJSUB
  If [M:BAH1]FCY<>""
   Call ADDCRIT(FILTBAG,IFILT,"FCY",'[F:HDU]FCY="'+[M:BAH1]FCY+'"'," & ") From GOBJSUB
  Endif
 When 1
  # Groupement de sites
  Call ADDCRIT(FILTBAG,IFILT,"FCY",'find([F:HDU]FCY,TSITE(1..NBSITE))'," & ") From GOBJSUB
Endcase

# Type d'échéances (Fournisseur/Client)
If [M:BAH1]CLIFOUR="F"
 Call ADDCRIT(FILTBAG,IFILT,"BPRTYP",'[F:HDU]BPRTYP=2'," & ") From GOBJSUB
Else
 Call ADDCRIT(FILTBAG,IFILT,"BPRTYP",'[F:HDU]BPRTYP=1'," & ") From GOBJSUB
Endif

# Statut de l'échéance (Toujours validées & non soldées)
Call ADDCRIT(FILTBAG,IFILT,"DUDSTA",'[F:HDU]DUDSTA=2'," & ") From GOBJSUB
Call ADDCRIT(FILTBAG,IFILT,"FLGCLE",'[F:HDU]FLGCLE=1'," & ") From GOBJSUB

# Retrait des échéance sur pièce d'à-nouveau
Call ADDCRIT(FILTBAG,IFILT,"FLGREP",'[F:HAE]FLGREP<>2'," & ") From GOBJSUB

# Autres conditions à partir de la fenetre critières
#--- Inclure les écritures de simulation
If [M:CBAG]FLGDUD1 = 2
 Call ADDCRIT(FILTBAG,IFILT,"CAT",'find([F:HAE]CAT,1,2,4)<>0'," & ") From GOBJSUB
Else
 Call ADDCRIT(FILTBAG,IFILT,"CAT",'find([F:HAE]CAT,1,4)<>0'," & ") From GOBJSUB
Endif

#--- Odre  (1/Ascendant & 2/Déscendant)
Raz FILTPAG, PFILT
If BPRCUR=[M:BAH1]BPR
 If [M:CBAG]ORDDUD=2
  Gosub FILTRE_DESC
 Else
  Gosub FILTRE_ASC
 Endif
Endif
If FILTPAG="" : FILTPAG="1=1" : Endif
Return


############################################
#Création de critère de selection pour la pagination
$FILTRE_ASC
Case CHGPAG
 When 3 : # Rafraichissement
   If [M]NBLIG=0 : Return : Endif
   If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU>='+num$(HDUD)+')'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATD)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'"& NUMHDU>='+num$(HDUD)+')'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM>"'+VCRD+'")'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP>"'+TYPD+'")'+
&        'or  [F:HDU]DUDDAT>['+format$(GFMD,DUDDATD)+'])'," & ") From GOBJSUB
   Endif
  When 2 : # Suite
   If [M:CBAG]TRIDUD=2 :#tri par pièce comptable

    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMHDU>'+num$(HDUF)+')'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [F:HAE]ACCDAT>['+format$(GFMD,ACCDATF)+'])'," & ") From GOBJSUB
   Else

    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM="'+VCRF+'" & NUMHDU>'+num$(HDUF)+')'+
&        'or ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP="'+TYPF+'" & NUM>"'+VCRF+'")'+
&        'or ([HDU]DUDDAT=['+format$(GFMD,DUDDATF)+'] & TYP>"'+TYPF+'")'+
&        'or  [HDU]DUDDAT>['+format$(GFMD,DUDDATF)+'])'," & ") From GOBJSUB
   Endif
  When -2 : # Retour
   If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU<'+num$(HDUD)+')'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM<"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP<"'+TYPD+'")'+
&        'or  [F:HAE]ACCDAT<['+format$(GFMD,ACCDATD)+'])'," & ") From GOBJSUB
   Else
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU<'+num$(HDUD)+')'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP="'+TYPD+'" & NUM<"'+VCRD+'")'+
&        'or ([F:HDU]DUDDAT=['+format$(GFMD,DUDDATD)+'] & TYP<"'+TYPD+'")'+
&        'or  [F:HDU]DUDDAT<['+format$(GFMD,DUDDATD)+'])'," & ") From GOBJSUB

   Endif
 Endcase
Return

############################################
#Création de critère de selection pour la pagination
$FILTRE_DESC
Case CHGPAG
 When 3 : # Rafraichissement
   If [M]NBLIG=0 : Return : Endif
   If [M:CBAG]TRIDUD=2 :#tri par pièce comptable
    Call ADDCRIT(FILTPAG, PFILT,"NUMHDU",
&        '(  ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM="'+VCRD+'" & NUMHDU<'+num$(HDUD)+')'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP="'+TYPD+'" & NUM<"'+VCRD+'")'+
&        'or ([F:HAE]ACCDAT=['+format$(GFMD,ACCDATD)+'] & TYP<"'+TYPD+'")'+
