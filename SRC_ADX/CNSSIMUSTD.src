#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
#    CONSULTATION SIMULATION
#    Création le : 27/02/2012
#    Modification le :
#
#
################################################################################

################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "LECTURE"      : Gosub LECTURE
    When "DEB_CRIT"     : Gosub DEB_CRIT
    When "AP_CHOIX2"    : Gosub AP_CHOIX2
    When Default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
# Déclaration des variables
#-------------------------------------------------------------------------------
$OUVRE
  If clalev([F:DEP2])=0   : Local File DEPREC    [DEP2]  : Endif
  If clalev([F:FAS])=0    : Local File FXDASSETS [FAS]   : Endif
  If clalev([F:ACN2])=0   : Local File ACONSULT  [ACN2]  : Endif
  If clalev([M:FPC])=0
    # Sauvegarde de la liste des masques par défaut
    Global Char DEF_MASK(255)
    DEF_MASK = dbgstr(1)
    Local Mask FASPARCPY [FPC]
    DEF_MASK = dbgstr(1)+","+DEF_MASK
    Default Mask DEF_MASK
  Endif

  Local Char    CRITFIL1(250), CRITFIL2(250), CRITFIL3(250)
  Local Char    CRITSUP1(250)
  Local Date    DEBEXE, FINEXE, DEBPER, FINPER
  Local Char    DEBREF, FINREF, DEBSIT, FINSIT
  Local Libelle PLEIN
  Global Char   CODECR

  Raz [M:SIM1]

  Read [ACN2]ACN0="SIM"
  If fstat = 0
    [V]CODECR = [F:ACN2]SCRCOD
  Endif
Return

#-------------------------------------------------------------------------------
# Désactivation des boutons Recherche - Suite - Retour - Dernier - Export
#-------------------------------------------------------------------------------
$SETBOUT
  If [M:SIM1]CPY = ""
    Call VIREBOUT(CHAINE,"R+-DX") From GCONSULT
  Endif
Return

#-------------------------------------------------------------------------------
# Traitement du bouton Recherche
#-------------------------------------------------------------------------------
$LECTURE
  #-- critères obligatoires (section facultative)
  If [M:SIM1]CPY="" : NBLU=0 : Return : Endif

  Gosub CHANGE_MSK From GCONSULT

  If CHGPAG<0 : NOL = MAXLIG : Endif

  # Getion du filtre pour la sélection des éléments à afficher
  Gosub LOAD_FILTER

  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  If CHGPAG > 0
    SUITE = 1
    # < Recherche >
    If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
    Filter [DPS] Where evalue(CRITFIL1) & (evalue (CRITFIL2) | evalue (CRITFIL3))
&                Order By Key CLE=FCY;AASREF;DPRPLN;FIYENDDAT;PERSTRDAT
  Else
    RETOUR = 1
    # < Dernier >
    If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
    Filter [DPS] Where evalue(CRITFIL1) & (evalue (CRITFIL2) | evalue (CRITFIL3))
&                Order By Key CLE=FCY Desc;AASREF Desc;DPRPLN Desc;FIYENDDAT Desc ;PERSTRDAT Desc
  Endif

  #-- raz du masque si 1ere ou dernière page
  If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SIM2] : Endif

#-----------------------------
#-- boucle de lecture
#-----------------------------
$BOUCLE
  PLEIN = 0
  For [DPS]
    For [FAS] Where [F:FAS]CPY=[F:DPS]CPY and [F:FAS]FCY=[F:DPS]FCY and [F:FAS]AASREF=[F:DPS]AASREF and evalue(CRITSUP1)
      If NBLU = 1
        # Suite ou retour
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:SIM2] : Endif
          NBLU = 2
        Endif

        #-- stockage des bornes début et fin d'enregistrement pour l'écran
        If CHGPAG>0
          If NOL>=MAXLIG-1 : SUITE=2 : PLEIN=1 : Break : Endif
            NOL += 1
            If NOL=0
              DEBREF = [F:DPS]AASREF
              DEBEXE = [F:DPS]FIYSTRDAT
              DEBPER = [F:DPS]PERSTRDAT
              DEBSIT = [F:DPS]FCY
            Endif
            FINREF = [F:DPS]AASREF
            FINEXE = [F:DPS]FIYSTRDAT
            FINPER = [F:DPS]PERSTRDAT
            FINSIT = [F:DPS]FCY
        Else
          If NOL<=0 : RETOUR = 2 : PLEIN=1 : Break : Endif
          NOL -= 1
          If NOL=MAXLIG-1
            FINREF = [F:DPS]AASREF
            FINEXE = [F:DPS]FIYSTRDAT
            FINPER = [F:DPS]PERSTRDAT
            FINSIT = [F:DPS]FCY
          Endif
          DEBREF = [F:DPS]AASREF
          DEBEXE = [F:DPS]FIYSTRDAT
          DEBPER = [F:DPS]PERSTRDAT
          DEBSIT = [F:DPS]FCY
        Endif
        nolign = NOL+1
        #-----------------------------
        # Remplissage du tableau
        #-----------------------------
        [M:SIM2]FIYENDDAT(NOL)      = [F:DPS]FIYENDDAT
        [M:SIM2]PERENDDAT(NOL)      = [F:DPS]PERENDDAT
        [M:SIM2]DPRPLN   (NOL)      = [F:DPS]DPRPLN
        [M:SIM2]AASREF   (NOL)      = [F:DPS]AASREF
        [M:SIM2]FCY      (NOL)      = [F:DPS]FCY
        [M:SIM2]DPRBAS   (NOL)      = [F:DPS]DPRBAS
        [M:SIM2]DPRCUM   (NOL)      = [F:DPS]DPRCUM
        [M:SIM2]PERCLOCUM(NOL)      = [F:DPS]PERCLOCUM
        [M:SIM2]PERENDDPE(NOL)      = [F:DPS]PERENDDPE
        [M:SIM2]EXCCUM   (NOL)      = [F:DPS]EXCCUM
        [M:SIM2]PERCLOEXC(NOL)      = [F:DPS]PERCLOEXC
        [M:SIM2]PEREXCDPR(NOL)      = [F:DPS]PEREXCDPR
        [M:SIM2]IMLBLC   (NOL)      = [F:DPS]IMLBLC
        [M:SIM2]IML      (NOL)      = [F:DPS]IML
        [M:SIM2]IMLRVE   (NOL)      = [F:DPS]IMLRVE
        [M:SIM2]IMLRVETRF(NOL)      = [F:DPS]IMLRVETRF
        [M:SIM2]NBV      (NOL)      = [F:DPS]NBV
        [M:SIM2]RATCUR   (NOL)      = [F:DPS]RATCUR
        If PLEIN : Break : Endif
      Next
    Next

    # < Raffraichissement >
    If CHGPAG=3
      CHGPAG=1 : Gosub LOAD_FILTER : CHGPAG=3 : RETOUR=1 : Goto BOUCLE
    Endif
Return

#-----------------------------
#--- Préparation du filtre #
#-----------------------------
$LOAD_FILTER
  Raz CRITFIL1
  Raz CRITFIL2
  Raz CRITFIL3
  Raz CRITSUP1

  CRITFIL1 = "1=1"
  CRITFIL2 = "1=1"
  CRITFIL3 = "1=1"
  CRITSUP1 = "1=1"

  # Société
  CRITFIL1 = "[F:DPS]CPY='"+[M:SIM1]CPY+"'"

  # Site
  If [M:SIM1]FCY <> ""
    CRITFIL1 += " & [F:DPS]FCY='"+[M:SIM1]FCY+"'"
  Endif

  # Bien
  If [M:SIM1]AASREF <> ""
    CRITFIL1 += " & [F:DPS]AASREF='"+[M:SIM1]AASREF+"'"
  Endif

  # Contexte et plan
  CRITFIL1 += " & [F:DPS]CNX="+num$([M:SIM1]CNX)+" & [F:DPS]DPRPLN="+num$([M:SIM1]DPRPLN)

  # Date début/fin exercice
  If [M:SIM1]FIYSTRDAT <> [0/0/0]
    CRITFIL1 += " & [F:DPS]FIYSTRDAT=["+format$(GFMD,[M:SIM1]FIYSTRDAT)+"] & [F:DPS]FIYENDDAT=["+format$(GFMD,[M:SIM1]FIYENDDAT)+"]"
  Endif

  # Date début/fin période
  If [M:SIM1]PERSTRDAT <> [0/0/0]
    CRITFIL1 += " & [F:DPS]PERSTRDAT=["+format$(GFMD,[M:SIM1]PERSTRDAT)+"] & [F:DPS]PERENDDAT=["+format$(GFMD,[M:SIM1]PERENDDAT)+"]"
  Endif

  #---------------------------------------------------
  # Autres filtres à partir de l'écran des critères
  #---------------------------------------------------
  # Famille
  If [M:CSIM]ACGGRP <> ""
    CRITSUP1 += " & [F:FAS]ACGGRP='"+[M:CSIM]ACGGRP+"'"
  Endif

  # Code comptable
  If [M:CSIM]ACCCOD <> ""
    CRITSUP1 += " & [F:FAS]ACCCOD='"+[M:CSIM]ACCCOD+"'"
  Endif

  # Compte PCG
  If [M:CSIM]GAC <> ""
    CRITSUP1 += " & [F:FAS]GAC='"+[M:CSIM]GAC+"'"
  Endif

  # Compte IAS
  If [M:CSIM]IASACC <> ""
    CRITSUP1 += " & [F:FAS]IASACC='"+[M:CSIM]IASACC+"'"
  Endif

  # UGT
  If [M:CSIM]IASCGU <> ""
    CRITSUP1 += " & [F:FAS]IASCGU='"+[M:CSIM]IASCGU+"'"
  Endif

  # Axe analytique
  Local Integer N_CCE
  For N_CCE = 0 To [M:CSIM]NBRCCE-1
    If [M:CSIM]CCE(N_CCE) <> ""
      CRITSUP1 += " & [F:FAS]CCE("-num$(find([M:CSIM]DIE(N_CCE),[M:FPC]DIE)-1)-")='"+[M:CSIM]CCE(N_CCE)+"'"
    Endif
  Next


  #Gestion des mouvements de page en fonction du tri qui est : date début exercice, date début période, bien
  Case CHGPAG
    When 3  : # < rafraichissement >
              CRITFIL2 += " &(([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF='"+DEBREF+"'"
              CRITFIL2 += " & [F:DPS]FIYSTRDAT=["+format$(GFMD,DEBEXE)+"] & [F:DPS]PERSTRDAT<["+format$(GFMD,DEBPER)+"]))"
              CRITFIL3 += " &(([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF='"+DEBREF+"' & [F:DPS]FIYSTRDAT>["+format$(GFMD,DEBEXE)+"])"
              CRITFIL3 += " | ([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF>'"+DEBREF+"')"
              CRITFIL3 += " | ([F:DPS]FCY>'"+DEBSIT+"'))"

    When 2  : # < suite >
              CRITFIL2 += " & (([F:DPS]FCY='"+FINSIT+"' & [F:DPS]AASREF='"+FINREF+"'"
              CRITFIL2 += " & [F:DPS]FIYSTRDAT=["+format$(GFMD,FINEXE)+"] & [F:DPS]PERSTRDAT>["+format$(GFMD,FINPER)+"]))"
              CRITFIL3 += " & (([F:DPS]FCY='"+FINSIT+"' & [F:DPS]AASREF='"+FINREF+"' & [F:DPS]FIYSTRDAT>["+format$(GFMD,FINEXE)+"])"
              CRITFIL3 += " | ([F:DPS]FCY='"+FINSIT+"' & [F:DPS]AASREF>'"+FINREF+"')"
              CRITFIL3 += " | ([F:DPS]FCY>'"+FINSIT+"'))"

    When -2 : # < retour >
              CRITFIL2 += " &(([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF='"+DEBREF+"'"
              CRITFIL2 += " & [F:DPS]FIYSTRDAT=["+format$(GFMD,DEBEXE)+"] & [F:DPS]PERSTRDAT<["+format$(GFMD,DEBPER)+"]))"
              CRITFIL3 += " &(([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF='"+DEBREF+"' & [F:DPS]FIYSTRDAT<["+format$(GFMD,DEBEXE)+"])"
              CRITFIL3 += " | ([F:DPS]FCY='"+DEBSIT+"' & [F:DPS]AASREF<'"+DEBREF+"')"
              CRITFIL3 += " | ([F:DPS]FCY<'"+DEBSIT+"'))"
  Endcase
Return

#------------------------------------------------------
# Initialisation des champs de la fenêtre Critères
#------------------------------------------------------
$DEB_CRIT
  [M:CSIM]ECRAN = [V]CODECR

  If [M]FCY<>""
    Gosub CHARGE_AXES
  Endif
Return

#------------------------------------------------------
# clique sur bouton OK
#------------------------------------------------------
$AP_CHOIX2
  If REPONSE = 1029 and [M:CSIM]CPY = "" and [M:CSIM]FCY = ""
    # La sélection d'au moins un site est obligatoire
    Call ERREUR (mess(48,GML_MSGREC,1)) From GESECRAN
    zonsui = "[M:CSIM]FCY"
    REPONSE = 0
  Endif
Return


######################################################################################
# Gestion du masque CONSSIMU1
# Ecran -- SIM1 --

######################################################################################
# Raz du site si on change de société
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  # Raz du site si on change de société
  If VALEUR <> ""
    Raz [M]FCY
    Raz [M]ZFCY
    Raz [M]AASREF
  Endif
  Affzo [M]FCY
  Affzo [M]ZFCY
  Affzo [M]AASREF

  If VALEUR <> ""
    Local Integer ERR
    Call LOAD_FASPARCPY(VALEUR,"",G_NON,ERR) From GLOFCYCPY

    If dim([M]NBRCCE)>=0
      Gosub CHARGE_AXES
    Endif
  Endif
End

######################################################################################
# Le site est obligatoire si la société est vide
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
  If [M]CPY = "" and VALEUR = ""
    # La sélection d'au moins un site est obligatoire
    Call ERREUR (mess(48,GML_MSGREC,1)) From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
# Désactive les contextes non gérés par la société
######################################################################################
Subprog AS_CNX(VALEUR)
Variable Integer VALEUR
  Call VIRE_CNX_NON_GERES ([M]CPY) From GLOBIENS
End

######################################################################################
# Désactive les plans non gérés par le contexte de la société
######################################################################################
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR
  Call VIRE_PLN_NON_GERES ([M]CPY, [M]CNX) From GLOBIENS
End

######################################################################################
# Récupère la société si on ne saisi que le site
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Raz [M]AASREF
  Read [FCY]FCY0=VALEUR
  If fstat = 0
    [M]CPY = [F:FCY]LEGCPY
  Endif
  Affzo [M]CPY
  Affzo [M]ZCPY
  Affzo [M]AASREF

  Local Integer ERR
  Call LOAD_FASPARCPY([M]CPY,"",G_NON,ERR) From GLOFCYCPY

  If dim([M]NBRCCE)>=0
    Gosub CHARGE_AXES
  Endif
End

######################################################################################
## Contrôle l'existence du bien
######################################################################################
Subprog AM_AASREF(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> ""
    Read[DEP2]DEP0(1)=VALEUR
    If fstat
      # Bien comptable inexistant
      Call ERREUR (mess(262,GML_MSGFAS,1)) From GESECRAN
      mkstat = 2
    Endif
  Endif
End

######################################################################################
## Contrôle la date de fin exercice
######################################################################################
Subprog C_FIYENDDAT(VALEUR)
Variable Date    VALEUR
  If [M]FIYSTRDAT<>[0/0/0]
    If VALEUR = [0/0/0] or VALEUR<[M]FIYSTRDAT
      # La date de fin doit être supérieure à la date de début
      Call ERREUR (mess(3,GML_MSGFASPR,1)) From GESECRAN
      mkstat=2
    Endif
  Else
    If VALEUR <> [0/0/0]
      # Date de début invalide
      Call ERREUR ("Date de début incorrecte") From GESECRAN
      mkstat=2
    Endif
  Endif
End

######################################################################################
## Contrôle la date de fin de période
######################################################################################
Subprog C_PERENDDAT(VALEUR)
Variable Date    VALEUR
  If [M]PERSTRDAT<>[0/0/0]
    If VALEUR = [0/0/0] or VALEUR<[M]PERSTRDAT
      # La date de fin doit être supérieure à la date de début
      Call ERREUR (mess(3,GML_MSGFASPR,1)) From GESECRAN
      mkstat=2
    Endif
  Else
    If VALEUR <> [0/0/0]
      # Date de début invalide
      Call ERREUR ("Date de début incorrecte") From GESECRAN
      mkstat=2
    Endif
  Endif
End

######################################################################################
## Chargement des axes analytiques
######################################################################################
$CHARGE_AXES
  Effzo [M]DIE
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
    [M]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
  Next I_DIE
  Affzo [M]20
Return

######################################################################################
