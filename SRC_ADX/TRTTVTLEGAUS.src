#<AdxTL>@(#)0.0.0.0 $Revision$ 
#**###########################################################
#
#  Legal datas for legislation KAU for table TABVAT
#
# Window AWI=>TVTLEGAUS
# Mask/Screen AMK=>TVTLEGAUS[TVTAUS]
#
# X3-52567_Australian GST report issue
############################################################**!


$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
 When "AS_AUSVAT"     : Gosub S_AUSVAT
Endcase
Return

$AV_CHOIX



Return

$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
#Local Char COD(max(GLONTVB,GLONVAT,5))
Local Char COD(GLONVAT)
[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:TVT]) : Local File TABVAT [TVT] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif

#----- Masque local -----#
Local Mask TVTLEGAUS [TVTAUS]

[M]CURLEG=[L]LEG
#----- Variables locales pour sauvegarde du masque -----#
Local Char AUSVAT(GLONVAT)
Local Integer AUSG1TOTSA
Local Integer AUSG2EXPSAL
Local Integer AUSG3GSTFRES
Local Integer AUSG10CAPPUR
Local Integer AUSG11NCAPPU
Local Integer AUS1AGSTSAL
Local Integer AUS1BGSTPUR


Return

$DEBUT
Local Integer WRET :#--CPO 71937

#--- Alimentation des champs de l'écran ---#
#--CPO 71937 TVT and LEG as part of the key
Call LEC_TVT_LEG([L]LEG,[L]COD,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] Endif
[M:TVTAUS] = [F:TVT]
#Read [TVT]TVT0 = [L]COD;[L]LEG
#If !fstat
# [M:TVTAUS] = [F:TVT]
#Endif
#--/CPO
#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:TVTAUS]

Affzo [M:TVTAUS]
Setmok [M:TVTAUS] With 0


If [M:TVTAUS]AUSBAS = 1 #1A
 Actzo [M:TVTAUS]AUSG1TOTSA
 Actzo [M:TVTAUS]AUSG2EXPSAL
 Actzo [M:TVTAUS]AUSG3GSTFRES
 Diszo [M:TVTAUS]AUSG10CAPPUR
 Diszo [M:TVTAUS]AUSG11NCAPPU
 Actzo [M:TVTAUS]AUS1AGSTSAL
 Actzo [M:TVTAUS]AUS1BGSTPUR
Else  #1B
 Diszo [M:TVTAUS]AUSG1TOTSA
 Diszo [M:TVTAUS]AUSG2EXPSAL
 Diszo [M:TVTAUS]AUSG3GSTFRES
 Actzo [M:TVTAUS]AUSG10CAPPUR
 Actzo [M:TVTAUS]AUSG11NCAPPU
 Diszo [M:TVTAUS]AUS1AGSTSAL
 Diszo [M:TVTAUS]AUS1BGSTPUR
Endif

Affzo [M:TVTAUS]

Return

$ENR
Trbegin [TVT]
Readlock [TVT]TVT0 = [L]COD;[L]LEG
#--CPO 71937
If fstat=5
  Readlock [TVT]TVT0 = [L]COD;""
Endif
#--/CPO

If !fstat
 [F:TVT]AUSVAT    = [M:TVTAUS]AUSVAT

 [F:TVT]AUSG1TOTSA    = [M:TVTAUS]AUSG1TOTSA
 [F:TVT]AUSG2EXPSAL   = [M:TVTAUS]AUSG2EXPSAL
 [F:TVT]AUSG3GSTFRES  = [M:TVTAUS]AUSG3GSTFRES
 [F:TVT]AUSG10CAPPUR  = [M:TVTAUS]AUSG10CAPPUR
 [F:TVT]AUSG11NCAPPU  = [M:TVTAUS]AUSG11NCAPPU
 [F:TVT]AUS1AGSTSAL   = [M:TVTAUS]AUS1AGSTSAL
 [F:TVT]AUS1BGSTPUR   = [M:TVTAUS]AUS1BGSTPUR
 [F:TVT]AUSBAS        = [M:TVTAUS]AUSBAS

 Rewrite [TVT]
 If fstat
  GOK = 0 : Call FSTA("TVT") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:TVTAUS] : REP=""
Return

$ABA
[M:TVTAUS]=[L] : REP=""
Gosub ENR
Affzo [M:TVTAUS]
Return

$APRES_MODIF
Read [ALK]LCKCLE="TVT"+[L]LEG+"\"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:TVTAUS]=[L]
 Affzo [M:TVTAUS] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="TVT"+[L]LEG+"\"+[L]COD
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return

$S_AUSVAT
START   = "[F:TVT]VAT"
ORDRE   = "[F:TVT]VAT;[F:TVT]LEG"
Return
######################################################################################
## Etiquettes écran TVTLEGAUS
######################################################################################
Subprog IB_AUSVAT
Raz GBOUT1
End

Subprog AS_AUSVAT(VALEUR)
Variable Char    VALEUR()
 If dim([M:TVT1]VATTYP)>0 & [M:TVT1]VATTYP<>2
  Grizo [M]AUSVAT
  mkstat=1
 Else
  Actzo [M]AUSVAT
 Endif
End

Subprog C_AUSVAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer CODOK : CODOK=0
 Local Integer CODEXIST : CODEXIST=0
 Read [TVT]TVT0=VALEUR;[M]CURLEG
 If fstat
  Filter [TVT] Where VAT=VALEUR
  For [TVT]TVT0
   CODEXIST+=1
   If [F:TVT]LEG=[M]CURLEG | [F:TVT]LEG=""
    CODOK=1
   Endif
  Next
  Filter [TVT]
 Else
  CODEXIST=1
  CODOK=1
 Endif
 If !CODEXIST
  GMESSAGE = mess(23,100,1) : # Fiche inexistante
  mkstat = 2 : End
 Elsif [M]CURLEG<>""
  If !CODOK
   # Fiche inexistante pour la législation courante
   GMESSAGE = mess(232,107,1)-"["+[M]CURLEG+"]"
   mkstat=2 : End
  Endif
 Endif
Else
 If dim([M:TVT1]VATTYP)>0 & [M:TVT1]VATTYP=2
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2
 Endif
Endif
End

######################################################################################
## Section automatically added (screen TVTLEGAUS) 08/24/2016 13:34:49 (JAMUL)
######################################################################################
Subprog AM_AUSBAS(VALEUR)
Variable Integer VALEUR


 Raz [M:TVTAUS]AUSG1TOTSA
 Raz [M:TVTAUS]AUSG2EXPSAL
 Raz [M:TVTAUS]AUSG3GSTFRES
 Raz [M:TVTAUS]AUSG10CAPPUR
 Raz [M:TVTAUS]AUSG11NCAPPU
 Raz [M:TVTAUS]AUS1AGSTSAL
 Raz [M:TVTAUS]AUS1BGSTPUR


If VALEUR = 1 #1A
 Actzo [M:TVTAUS]AUSG1TOTSA
 Actzo [M:TVTAUS]AUSG2EXPSAL
 Actzo [M:TVTAUS]AUSG3GSTFRES
 Diszo [M:TVTAUS]AUSG10CAPPUR
 Diszo [M:TVTAUS]AUSG11NCAPPU
 Actzo [M:TVTAUS]AUS1AGSTSAL
 Actzo [M:TVTAUS]AUS1BGSTPUR
Else  #1B
 Diszo [M:TVTAUS]AUSG1TOTSA
 Diszo [M:TVTAUS]AUSG2EXPSAL
 Diszo [M:TVTAUS]AUSG3GSTFRES
 Actzo [M:TVTAUS]AUSG10CAPPUR
 Actzo [M:TVTAUS]AUSG11NCAPPU
 Diszo [M:TVTAUS]AUS1AGSTSAL
 Diszo [M:TVTAUS]AUS1BGSTPUR
Endif

Affzo [M:TVTAUS]

End


######################################################################################

